ó."],[771,834,"Ồ!"],[896,959,"Có chuyện gì thế?"],[1042,1159,"Cậu ta đang tán tỉnh cô ấy."],[1159,1359,"Ý tôi là, giờ tôi ăn mặc"],[1359,1455,"không hợp tập yoga lắm."],[1551,1626,"Anh không sao chứ?"],[1626,1689,"Ôi, lỗi tôi."],[1810,1918,"Anh ta đang căng thẳng kìa."],[2010,2106,"Sao anh làm cho ngực"],[2118,2210,"giật giật được thế?"],[2218,2314,"Chỉ là phản xạ khi căng thẳng thôi."],[2381,2498,"Giờ nhịp tim của anh đang tăng lên à?"],[2498,2594,"Ối chà, sao cơ?"],[2627,2756,"Giờ nhịp tim của anh đang tăng lên à?"],[2756,2911,"Này, anh cũng là người bằng xương bằng thịt mà, cưng."],[2911,2965,"Cưng á?"],[2965,3086,"Xin lỗi, ý anh là, cô ấy cắt ngang."],[3086,3199,"Trước tiên,"],[3199,3269,"tên tôi là Meghane. - Lỗi anh, lỗi anh."],[3269,3370,"Giờ cô đúng là"],[3370,3415,"kẻ phá đám đấy."],[3415,3482,"Tôi đâu định phá đám."],[3482,3586,"Tôi chỉ muốn vui vẻ"],[3586,3678,"cùng hai người thôi."],[3678,3737,"Anh thích thế à?"],[3737,3845,"Đó là gu của anh sao?"],[3845,3945,"Ý tôi là, anh mới là người hào hứng,"],[3945,4108,"chứ không, đó không phải gu của tôi."],[4108,4149,"Ok, thấy chưa?"],[4149,4254,"Em cũng nghĩ vậy."],[4266,4358,"Làm ơn ra khỏi đây đi."],[4358,4404,"Anh xin lỗi."],[4404,4600,"Ý anh là, anh bị phân tâm."],[4671,4750,"Cô ấy quyến rũ mà."],[4750,4871,"Vòng một của cô ấy lộ hết ra kìa."],[4871,4967,"Khoan, ai cơ, ai cơ?"],[4967,5000,"Gì thế?"],[5000,5059,"Hả?"],[5059,5142,"Sao?"],[5155,5230,"Anh nói gì cơ?"],[5230,5296,"Ý anh là"],[5317,5451,"Nên anh không thể kiểm soát được bản thân."],[5451,5534,"Ý anh là thế đúng không?"],[5534,5726,"Anh không giỏi kiểm soát"],[5726,5809,"Đã lâu rồi anh không rơi vào,"],[5809,5980,"bị đặt vào tình huống này."],[5980,6126,"Nên em không thể trách anh được."],[6131,6222,"Anh ta mất kiểm soát rồi."],[6222,6360,"Tưởng tượng gã này lúc say xem?"],[6360,6548,"Tôi nghĩ anh ta sắp ngất tới nơi rồi."],[6564,6719,"Em thấy rõ tim anh,"],[6719,6865,"đang giật liên hồi qua,"],[6931,7044,"cơ ngực của anh luôn."],[7044,7136,"Họ đang thử thách anh ta đấy."],[7136,7219,"Đúng là ác quỷ."],[7219,7344,"Cô ta mặc váy đỏ."],[7390,7586,"Cô ta là Lucifer."],[7586,7807,"Cám dỗ luôn đội lốt thế này mà."],[7836,7928,"Có lẽ tôi nên đi."],[7928,8024,"Hai người cứ tận hưởng"],[8024,8108,"buổi hẹn này đi."],[8108,8220,"Cô ấy đang bảo muốn đi kìa!"],[8258,8362,"Anh đùa tôi à?"],[8395,8546,"Tùy em nghĩ sao."],[8679,8837,"Họ định chia tay luôn bây giờ à?"]],"31":[[33,287,"Điều gì ở anh ấy thu hút cô nhất?"],[287,412,"Anh ấy có đôi mắt rất đẹp."],[412,504,"Đôi mắt màu xanh,"],[504,713,"rất thu hút."],[742,888,"Tôi cảm thấy chắc chắn anh ấy có"],[888,1026,"một năng lượng rất tích cực."],[1026,1117,"Tôi phải làm gì"],[1117,1155,"bây giờ đây?"],[1155,1280,"Cô đang phá đám buổi hẹn của tôi,"],[1280,1422,"hơi khó xử đấy."],[1422,1597,"Thôi, tôi phải đi rồi."],[1597,1643,"Ừ."],[1643,1710,"Không!"],[1710,1856,"Chúng ta xong sớm vậy sao?"],[1856,1964,"Không, tôi phải đi."],[1964,2031,"Cứ ở lại đi."],[2031,2097,"Cứ ở lại đi."],[2156,2268,"Tôi có thể cho anh số điện thoại"],[2268,2360,"nếu anh muốn, nhưng,"],[2360,2464,"- Không sao đâu. - Tôi sẽ để lại cho cô ấy."],[2464,2552,"Cứ để ở quầy nhé."],[2552,2648,"Tôi phải đi rồi,"],[2669,2827,"có thể gặp lại sau chứ?"],[2898,2998,"Có thể."],[3015,3161,"Ừ, anh cứ suy nghĩ đi."],[3174,3299,"Được, tôi sẽ suy nghĩ."],[3299,3370,"Nhé?"],[3370,3461,"Ừ, cảm ơn."],[3474,3553,"Được rồi, tạm biệt."],[3553,3628,"Tạm biệt."],[3657,3774,"Tạm biệt Andres."],[3803,3858,"Tạm biệt."],[4158,4279,"Khó xử thật."],[4366,4471,"Bọn tôi ổn rồi."],[4479,4542,"Làm tốt lắm."],[4554,4637,"Làm tốt lắm."],[4654,4763,"Làm tốt lắm."],[4796,4975,"Tôi đã thử nhưng cô ấy kiểu"],[5000,5150,"Có nhiều cô gái tán tỉnh anh"],[5150,5217,"ở phòng tập,"],[5217,5376,"chuyện đó có từng là vấn đề"],[5376,5551,"với người yêu cũ không?"],[5605,5655,"Không."],[5655,5739,"Kiểu gặp gỡ mọi người ở phòng tập ấy."],[5739,5914,"Tôi là người rất chung thủy."],[5914,5993,"Anh chung thủy á?"],[5993,6051,"Ừ."],[6051,6139,"Anh có hay ghen không?"],[6139,6185,"Có chứ."],[6185,6268,"Còn em có ghen không?"],[6268,6352,"Câu hỏi hay đấy."],[6352,6402,"Có không?"],[6519,6690,"Em không phủ nhận đâu."],[6690,6969,"Trong những mối tình trước,"],[6969,7152,"nếu có ai đó chạm vào anh"],[7152,7236,"như thế này,"],[7236,7428,"anh có nói với họ là,"],[7428,7536,"xin lỗi, tôi có bạn gái rồi không?"]],"32":[[0,33,"Hai người sao rồi?"],[33,87,"Ồ, chào cô."],[87,258,"Buổi hẹn hò thế nào rồi?"],[258,337,"Khá ổn."],[337,437,"Ừ, bọn tôi nói chuyện"],[437,542,"rất hợp nhau."],[542,638,"Rất suôn sẻ. - Ừ. Tốt."],[638,775,"Không biết hai người"],[775,892,"có biết điều này về tôi không,"],[892,1059,"nhưng tôi rất đam mê"],[1059,1188,"chiêm tinh học và"],[1188,1322,"xem chỉ tay."],[1322,1472,"Nên bọn tôi đã"],[1472,1605,"bàn bạc với nhau."],[1605,1685,"Và rồi bọn tôi nảy ra"],[1685,1805,"ý tưởng xem chỉ tay,"],[1805,1868,"và tôi thấy,"],[1868,1997,"ý đó thật sự rất hay."],[1997,2164,"Tôi nghĩ mình có thể làm tốt việc đó."],[2164,2327,"Tôi đoán mọi người có lẽ"],[2327,2431,"cũng nghĩ tôi vốn thích mấy trò đó,"],[2431,2569,"mấy thứ kiểu tâm linh."],[2569,2648,"Nên tôi kiểu,"],[2648,2702,"được thôi,"],[2702,2794,"tôi thấy trò này sẽ hiệu quả."],[2794,2961,"Hai người thuộc cung gì?"],[2961,3065,"Tôi là Nhân Mã."],[3065,3144,"Tôi là Kim Ngưu."],[3144,3328,"Nhân Mã và Kim Ngưu sao?"],[3328,3474,"Kim Ngưu hơi phức tạp đó,"],[3474,3586,"vì tôi thấy"],[3586,3778,"Kim Ngưu thường không phải là"],[3778,4024,"cung chung thủy nhất."],[4024,4137,"Cô biết đấy, tôi thấy sự chung thủy"],[4137,4287,"rất quan trọng với tôi."],[4287,4366,"Sự chung thủy"],[4366,4437,"thực sự quan trọng"],[4437,4504,"với anh sao? - Chắc chắn rồi."],[4504,4567,"Vậy anh có nghĩ"],[4567,4725,"mình là người rất chung thủy không?"],[4725,4871,"Chắc chắn rồi. Đúng vậy."],[4871,4963,"Được thôi."],[4963,5030,"Tôi phải"],[5030,5184,"hỏi xem buổi hẹn hôm qua của anh thế nào"],[5184,5305,"khi Autumn không có ở đó?"],[5413,5505,"Ôi, chết tiệt."],[5505,5580,"Gì cơ? Gì chứ?"],[5580,5680,"Cô ta đang nhắc đến buổi hẹn kìa!"],[5764,5905,"Ừ"],[5905,6135,"Thật sự không thể tin nổi."],[6135,6256,"Chào! - Chào."],[6310,6381,"Cô không phải Autumn."],[6381,6552,"Tôi ngồi cùng anh được không?"],[6552,6673,"Được chứ. Cứ tự nhiên."],[6673,6748,"Ý tôi là, rõ ràng"],[6748,6865,"tôi đã bị cho leo cây rồi."],[6865,6973,"Ồ. - Ừ."],[6973,7165,"Thật đáng tiếc."],[7286,7415,"Vậy anh muốn chia sẻ"],[7415,7520,"điều gì không?"],[7520,7570,"Khi mà chúng ta đang ở đây."],[7570,7732,"Buổi hẹn kéo dài khá lâu đấy"],[7732,7820,"Ồ. Vậy sao?"],[7820,7932,"Chuyện này tôi mới nghe đấy."],[7932,8083,"Khoảng bao lâu vậy?"],[8258,8404,"'Buổi hẹn kết thúc thế nào?'"],[8404,8546,"mới là câu hỏi lớn hơn."]],"33":[[0,275,"Trong các mối quan hệ trước,"],[275,446,"nếu có người"],[446,621,"chạm vào anh thế này,"],[621,734,"anh có định"],[734,809,"nói với họ là"],[809,1005,"không, xin lỗi, tôi có bạn gái rồi chứ?"],[1005,1130,"Ồ, tôi cho là hầu hết-"],[1130,1280,"hầu hết phụ nữ không"],[1280,1359,"tự dưng bước tới"],[1359,1501,"và sờ tay tôi đâu."],[1805,2002,"Chà, chúc hai người may mắn nhé."],[2002,2156,"Mong là mọi chuyện suôn sẻ."],[2156,2293,"Còn nếu không thì thôi."],[2560,2660,"Tạm biệt."],[2660,2806,"Điên rồ thật."],[2806,2902,"Quá đáng thật."],[2902,2998,"Lần đầu tôi thấy"],[2998,3148,"nhiều người cố ý"],[3148,3261,"phá đám buổi hẹn đến vậy."],[3261,3390,"Anh thấy sao?"],[3390,3465,"Hơi bối rối."],[3465,3595,"Anh có thấy buổi hẹn của chúng ta,"],[3595,3807,"kiểu như, vẫn đang tiến triển tốt không?"],[3937,4049,"Có chứ."],[4049,4133,"Thật lòng đấy."],[4133,4229,"Anh nghĩ vậy."],[4229,4354,"Mình vẫn đang vui vẻ mà nhỉ?"],[4354,4421,"Ừ."],[4421,4571,"Còn may chán."],[4571,4804,"Lên nào. Ồ! Cố lên cô gái! Tới luôn!"],[4804,5009,"Tới luôn. Tới luôn đi!"],[5009,5117,"Chơi tới đi Patches!"],[5117,5242,"Lên nào cưng!"],[5242,5330,"Em có thích chuyện án mạng có thật không?"],[5330,5417,"Rất thích luôn."],[5417,5534,"Em có thích, kiểu như kinh dị không?"],[5534,5568,"Hay là không?"],[5568,5634,"Có mà cũng không."],[5634,5759,"Kiểu như nó không còn làm em sợ nữa."],[5759,5847,"Anh ghét kinh dị."],[5847,5885,"Ok."],[5885,5972,"Nhưng anh thích kiểu,"],[5972,6051,"án mạng có thật."],[6051,6352,"Chào mọi người."]],"34":[[16,171,"Anh chỉ định,"],[171,362,"giúp em thư giãn một chút."],[362,467,"Chỉ định"],[467,729,"xoa bóp lưng cho em thôi."],[729,921,"Ôi trời ơi."],[1009,1201,"Trời đất ơi."],[1201,1397,"Tới luôn đi anh bạn."],[1397,1488,"Ôi, cái gì thế!"],[1488,1718,"Gì cơ? Thế này hơi kỳ đấy."],[1718,1818,"Tim em đang đập nhanh đúng không?"],[1818,1910,"Này, đây là"],[1910,2118,"Thử thách của ác quỷ!"],[2118,2181,"Anh không hề cự tuyệt,"],[2181,2339,"mà cứ mặc kệ cho nó xảy ra."],[2339,2464,"Ta xua đuổi ác quỷ!"],[2464,2594,"Cút khỏi đây đi!"],[2594,2690,"Sao cô ta vẫn ở đây?"],[2690,2756,"Đồ ác quỷ."],[2756,2819,"Biết gì không?"],[2819,2923,"Sáng mắt ra rồi đấy. - Ác quỷ!"],[2990,3290,"Ôi... trời... ơi!"],[3340,3490,"Gái à, bà suýt tóm được rồi."],[3490,3599,"Tôi suýt tóm được thật."],[3599,3712,"Bà tóm được rồi mà."],[3712,3812,"Chúng ta bỏ qua chuyện này được chứ?"],[3812,3899,"Tôi không muốn một chàng trai"],[3899,3974,"dễ bị cám dỗ thế đâu."],[3974,4058,"Gì chứ? Ngay ngày đầu tiên á?"],[4058,4129,"Ngày thứ hai rồi."],[4129,4283,"Ừ, chuẩn. Lỗi do tôi hết."],[4283,4362,"Còn anh thì sao?"],[4362,4508,"Đã bảo rồi, tôi là trai tân tái sinh."],[4508,4579,"Ừ. Từ lúc nào?"],[4579,4859,"Hôm qua chắc?"],[4859,4971,"Anh là con nít"],[4971,5184,"hay đàn ông thế? Là đàn ông."],[5184,5330,"Chuẩn rồi. Ừ."],[5330,5388,"Cái gã mà"],[5388,5518,"cô gặp ở đây hôm qua ấy."],[5518,5568,"Chà."],[5568,5634,"Ý tôi là... - Ồ, anh nghĩ"],[5634,5726,"tôi là loại con gái đó sao?"],[5726,5801,"Tôi không biết,"],[5801,5864,"cô đang để mắt đến ai?"],[5864,5976,"Gã kia là ai?"],[5976,6047,"Anh đang suy diễn à?"],[6047,6147,"Không, tôi chỉ bảo là,"],[6147,6218,"mới có... - Anh đang suy diễn phải không?"],[6218,6272,"mười phút thôi."],[6272,6389,"Suy diễn! Toàn là suy diễn!"],[6389,6489,"Giờ tới lượt anh ngồi ghế nóng"],[6489,6585,"rồi đấy nhé cưng."],[6585,6710,"Phản đối, toàn là suy diễn."],[6710,6856,"Họ đang cãi nhau kìa."],[6856,6977,"Tôi có phải lựa chọn đầu tiên của em?"],[6977,7032,"Anh có phải"],[7032,7111,"lựa chọn đầu tiên của tôi á?"],[7111,7248,"Anh là lựa chọn đầu của tôi sao?"],[7248,7369,"Thấy chưa? - Mọi người khỏe không?"],[7369,7428,"Chào anh bạn."],[7428,7499,"Chào, dạo này sao rồi?"],[7499,7553,"Cậu khỏe không?"],[7553,7724,"Thằng đ** này là ai vậy?"],[7724,7757,"Meghane."],[7757,7845,"Khỏe không?"],[7845,7932,"Này!"]],"35":[[8,120,"Các cậu có phiền nếu mình xem"],[120,316,"chỉ tay cho các cậu một chút không?"],[316,533,"Vậy tôi có được bỏ tay"],[533,617,"khỏi máy đo"],[617,763,"nhịp tim này để cô xem chỉ tay không?"],[763,888,"Anh đành phải thế thôi."],[888,946,"Tôi nghĩ tôi sẽ"],[946,1067,"xem tay trái của anh."],[1067,1109,"Được thôi."],[1109,1192,"Tôi chưa từng xem chỉ tay"],[1192,1267,"ngày nào trong đời cả."],[1276,1380,"Nếu anh hỏi tôi, kiểu như,"],[1380,1443,"tính cách"],[1443,1568,"của Song Tử là gì,"],[1714,1814,"thì tôi chịu không biết đâu."],[1814,1864,"Tôi đang thấy"],[1864,1931,"sự không chung thủy,"],[1931,2031,"kiểu như trong tình cảm,"],[2031,2147,"anh có chung thủy không?"],[2147,2256,"Tuyệt đối có. - Anh có thích"],[2256,2348,"Ừ. Tôi từng bị cắm sừng"],[2348,2414,"trong mối quan hệ trước."],[2414,2473,"Vậy điều này có ý nghĩa gì?"],[2473,2552,"Thật sao? - Vậy chắc là"],[2552,2665,"nó đã hằn"],[2665,2773,"lên đường chỉ tay của tôi."],[2773,2869,"Anh từng bị lừa dối sao?"],[2869,3007,"Tôi bị cắm sừng suốt thời gian đó."],[3007,3048,"Anh biết không,"],[3048,3153,"có lẽ tôi đã thấy việc anh bị"],[3153,3261,"cắm sừng."],[3261,3486,"Có lẽ tôi đoán cũng gần đúng."],[3486,3528,"Tôi rất tiếc."],[3528,3611,"Tôi chiều cô đó,"],[3611,3699,"không sao đâu."],[3699,3766,"Chà! Vậy"],[3766,3899,"Không, ý là"],[3899,3983,"không chung thủy hả?"],[3983,4054,"Không bao giờ."],[4054,4145,"Không bao giờ? Không bao giờ,"],[4145,4229,"chưa một lần sao? Anh chưa từng"],[4229,4291,"lạc lối à."],[4291,4371,"Không. - Anh chưa từng"],[4371,4475,"ngó ngàng đến phụ nữ khác luôn?"],[4475,4525,"Đâu để làm gì."],[4525,4658,"Cậu biết không?"],[4658,4688,"Có thể anh ấy"],[4688,4771,"không đến nỗi tệ,"],[4771,4879,"Giờ tớ phải xem cho cậu, người đẹp à."],[4879,4934,"Tớ á?"],[4934,4996,"Ừ, cậu đó."],[4996,5030,"Lại đây nào."],[5030,5092,"Đúng rồi. Kéo cô ấy qua."],[5092,5167,"Tớ qua đó đây."],[5167,5263,"Ừ. Được thôi."],[5263,5338,"Tay tớ thực ra"],[5338,5434,"cũng hơi đổ mồ hôi."],[5434,5463,"Tớ sẽ"],[5463,5551,"xem đường tình duyên"],[5551,5684,"của cậu luôn."],[5684,5747,"Được."],[5747,5830,"Đáng yêu chưa nè?"],[5830,5935,"Nó là chữ T,"],[5935,5997,"và tên tớ"],[5997,6085,"bắt đầu bằng chữ T."],[6085,6247,"Đúng là rất đáng yêu,"],[6247,6393,"nhưng cậu biết thế có nghĩa là gì không"],[6393,6481,"Thế có nghĩa là gì?"],[6481,6548,"Nghĩa là sao?"]],"36":[[41,125,"Robyn đâu rồi?"],[125,171,"À, cô ấy"],[171,350,"vừa phải"],[350,563,"đi nói chuyện"],[563,646,"một chút với"],[646,930,"Emily kia. - Cái đ*o gì vậy?"],[930,1005,"Bọn tôi đang"],[1005,1071,"dở chuyện mà."],[1071,1180,"Còn nhiều"],[1180,1276,"thời gian mà."],[1276,1384,"Đành vậy."],[1384,1409,"Ừ thì."],[1409,1505,"Vậy tụi mình nói chuyện sau nhé."],[1505,1593,"Tâm sự một chút."],[1593,1801,"Thế à? Không phải bây giờ sao?"],[1801,1889,"Thật sự thì tôi"],[1889,1964,"đang rất vui,"],[1964,2089,"tôi xin lỗi."],[2089,2118,"Ừ."],[2118,2156,"Tôi không cố ý"],[2156,2381,"phá đám đâu."],[2381,2602,"Không, tôi mất hứng thật rồi."],[2602,2669,"Không, có ai"],[2669,2831,"phá đám gì đâu."],[2831,2994,"Tôi... tôi thực sự,"],[2994,3061,"rất thích"],[3061,3345,"cuộc trò chuyện với Robyn."],[3345,3445,"Cố lên cô gái, cố"],[3445,3541,"lên, đừng bỏ cuộc!"],[3541,3620,"Cố lên, cố lên nào."],[3620,3682,"Cậu làm được mà!"],[3682,3853,"Không, cô ấy bỏ cuộc rồi."],[3853,3974,"Ừ, cô ấy rất tuyệt."],[4049,4149,"Vậy gu của anh là gì"],[4149,4200,"trước khi"],[4200,4283,"tham gia chương trình?"],[4283,4371,"Anh muốn"],[4371,4454,"tìm kiếm điều gì?"],[4454,4688,"Ý anh là, ai còn thở là được."],[4763,4813,"Không, anh đùa thôi."],[4813,4879,"Anh chỉ"],[4879,4963,"Thành thật thì."],[4963,5017,"Một người anh có thể"],[5017,5067,"tâm sự-"],[5067,5088,"Có"],[5088,5155,"rất nhiều người"],[5155,5201,"đẹp ở đây,"],[5201,5267,"rồi em xuất hiện."],[5267,5384,"Anh biết em rất đẹp."],[5384,5434,"Anh biết em"],[5434,5488,"thực sự rất đẹp."],[5488,5622,"Nhưng"],[5622,5684,"Anh nghĩ"],[5684,5855,"nhịp tim em đang tăng kìa."]],"37":[[0,141,"Đôi khi em cần một"],[141,196,"nụ hôn lên"],[196,287,"má hoặc một cái ôm nhẹ."],[287,333,"Anh nghĩ mình có thể"],[333,442,"lo liệu việc đó."],[442,529,"Anh á?"],[529,558,"Ừ."],[558,667,"Thường thì mẹ cậu ấy"],[667,729,"hay làm việc đó thay cậu ấy."],[729,875,"Chà!"],[875,930,"Anh biết đấy,"],[930,996,"em thích người đàn ông"],[996,1059,"đối xử tốt với mẹ."],[1059,1142,"Nếu cậu ấy tốt với mẹ mình,"],[1142,1263,"cậu ấy cũng sẽ tốt với em."],[1263,1355,"Chính xác."],[1355,1426,"Chuẩn luôn."],[1426,1526,"Em hoàn toàn đồng ý."],[1526,1580,"Vậy là anh đang"],[1580,1643,"nói đỡ cho cậu ấy nhỉ."],[1643,1743,"Chính xác."],[1743,1797,"Này các bạn,"],[1797,1847,"tôi chỉ muốn"],[1847,1960,"ghé qua chút thôi."],[1960,2022,"Rất vui vì buổi hẹn"],[2022,2143,"diễn ra suôn sẻ."],[2143,2273,"Cảm ơn nhé. - Người anh em."],[2273,2410,"Quý cậu lắm đó, ông bạn."],[2410,2439,"Bạn hiền,"],[2439,2573,"Trân trọng tình cảm này, người anh em."],[2573,2694,"Nhưng mà, ờ... - Em rất xinh đẹp."],[2694,2761,"Em cảm ơn."],[2761,2869,"Thật tuyệt khi được gặp anh."],[2869,3003,"Rất vui được gặp em."],[3003,3044,"Nhân tiện,"],[3044,3232,"em không bận tâm chuyện anh"],[3232,3349,"từng uống rượu đâu."],[3349,3403,"Thật chứ?"],[3403,3453,"Em thấy"],[3453,3528,"chuyện đó rất bình thường."],[3528,3591,"Miễn là anh"],[3591,3753,"không phải kiểu nát rượu,"],[3803,3874,"Không đâu!"],[3874,3941,"Ừ, à, cũng có lúc"],[3941,4095,"vậy anh không phải là kẻ nát rượu chứ?"],[4095,4183,"Có thể đã từng,"],[4183,4266,"em biết đấy,"],[4266,4308,"trong những"],[4308,4441,"ngày hội đốt lửa trại."],[4441,4525,"Em không nghĩ đó là nát-"],[4525,4662,"Đó chỉ là thời"],[4662,4775,"sinh viên thôi,"],[4775,4850,"Làm sinh viên thì phải thế,"],[4850,4929,"em hiểu không?"],[4929,5213,"Chỉ là vui vẻ chút thôi."],[5213,5259,"Có thể nói là,"],[5259,5288,"em biết đấy,"],[5288,5367,"để tạo thêm kỷ niệm."],[5367,5409,"Nhưng anh chẳng"],[5409,5526,"nhớ được gì nhiều."],[5526,5601,"Thật kỳ cục,"],[5601,5668,"cứ như cậu ấy tự vạch áo"],[5668,5780,"cho người xem lưng vậy."],[5780,5851,"Bạn biết đấy, trưởng thành"],[5851,5976,"cũng nhiều áp lực mà."],[5976,6085,"Đó là... đó là"],[6085,6156,"những gì tôi muốn nói."],[6156,6206,"Hơn nữa, ở Quận Orange"],[6206,6302,"anh sống ngay ở bãi biển."],[6302,6360,"Em thấy đó giống như"],[6360,6448,"một lối sống vậy. - Ôi trời ơi."],[6448,6527,"Phải tận hưởng chứ."],[6527,6589,"Vậy anh có"],[6589,6656,"chắc là anh"],[6656,6740,"ổn không vì"],[6740,6877,"nhịp tim của anh"],[6877,6977,"đã tăng rất cao!"],[6977,7086,"Ừ, đúng là vậy."],[7086,7140,"Có phải anh sợ"],[7140,7173,"anh ấy sẽ"],[7173,7236,"định nói điều gì"],[7236,7303,"nữa mà anh không"],[7303,7365,"muốn tôi biết sao?"]],"38":[[16,116,"Em thực sự muốn hỏi"],[116,162,"buổi hẹn của anh"],[162,287,"hôm qua thế nào khi Autumn"],[287,425,"không có ở đây."],[425,492,"Anh không biết nữa, cái"],[492,729,"ghế này ngồi thật sự không thoải mái."],[729,825,"Cái ghế đó không thoải mái á?"],[825,942,"Ừ."],[942,1021,"Anh có nghĩ"],[1021,1109,"cái ghế này,"],[1109,1255,"sao nhỉ, thoải mái hơn không?"],[1255,1272,"Thật ra,"],[1272,1313,"em định"],[1313,1355,"sẽ"],[1355,1493,"ngồi lên đùi anh, nếu anh thấy"],[1493,1576,"ổn?"],[1789,1897,"Không sao, ổn mà."],[1897,1976,"Em biết không,"],[2081,2135,"Tới"],[2135,2227,"lúc này, em biết đấy,"],[2227,2314,"anh cứ tưởng"],[2314,2348,"em đã"],[2348,2448,"hoàn toàn, kiểu như,"],[2448,2648,"nằm ngoài cuộc chơi rồi."],[2698,2798,"Thế này thoải mái"],[2798,2919,"hơn nhiều."],[2919,3040,"Tự nhiên như ở nhà à?"],[3040,3073,"Như thể em đã"],[3073,3148,"ở đây nhiều năm rồi."],[3148,3303,"Ừ."],[3303,3370,"Được rồi."],[3553,3641,"Nãy em định hỏi xem"],[3641,3724,"có thể mặc thử cái này không,"],[3724,3895,"lúc nãy em lạnh lắm."],[3895,3958,"Em có thể"],[3958,4066,"mặc thử nếu muốn."],[4066,4237,"Thật sao? - Ừ, được chứ."],[4237,4437,"Được rồi, đưa em xem nào."],[4437,4483,"Máy quay"],[4483,4558,"sẽ chứng minh"],[4558,4617,"rằng anh chắc chắn"],[4617,4675,"đã nhắc đến em"],[4675,4804,"nhiều lần."],[4804,4967,"Và anh vẫn cứ"],[4967,5171,"tự hỏi, kiểu như,"],[5171,5296,"liệu cô ấy có xuất hiện không."],[5296,5426,"Nên"],[5426,5467,"Anh không biết nữa, kiểu,"],[5467,5551,"nó cứ văng vẳng trong đầu anh."],[5551,5626,"Và anh vẫn"],[5626,5739,"đang nghĩ, kiểu,"],[5739,5768,"em biết đấy,"],[5768,5889,"chuyện gì đã xảy ra,"],[5889,5939,"em hiểu mà,"],[5939,6043,"bởi vì, kiểu như"],[6043,6114,"Sao anh lại bị bơ á?"],[6114,6185,"Anh thật sự đã nghĩ."],[6185,6406,"Giữa chúng ta có gì đó."],[6406,6443,"Dù tôi"],[6443,6623,"không thích anh ta cho lắm."],[6623,6740,"Kiểu anh ta không phải gu của tôi."],[6740,6835,"Nhưng anh ta rất"],[6835,6923,"chung thủy với cô ấy."],[7027,7090,"Đó là sự trung thành."],[7090,7240,"Buổi hẹn kết thúc như vậy sao?"],[7240,7357,"Ý cô là sao,"],[7357,7394,"cụ thể cơ?"],[7394,7532,"Trước khi bạn hẹn của anh rời phòng,"],[7532,7607,"chuyện gì đã xảy ra?"],[7607,7665,"Ồ, ý tôi là,"],[7665,7745,"ừ thì, cô ấy"],[7745,7849,"cô ấy đã hôn lên má tôi"],[7849,7982,"một cái."]],"39":[[8,100,"Tôi sẽ xem thử đường tình duyên"],[100,233,"của cô nữa."],[233,296,"Được."],[296,379,"Nhìn đáng yêu nhỉ?"],[379,483,"Đây là chữ T,"],[483,546,"và tên tôi"],[546,633,"cũng bắt đầu bằng chữ T."],[633,796,"Đáng yêu thật đấy,"],[796,934,"nhưng cô biết thế nghĩa là gì không?"],[934,1030,"Nghĩa là sao?"],[1030,1126,"Nghĩa là gì thế?"],[1126,1197,"Nghĩa là cô"],[1197,1247,"hơi bị,"],[1247,1447,"kiểu có vấn đề về sự cam kết."],[1447,1576,"Chứng sợ gắn bó."],[1576,1680,"Cô có thấy"],[1680,1764,"mình là kiểu người né tránh không?"],[1764,1810,"Cô có thấy"],[1810,1843,"mình"],[1843,1872,"hơi"],[1872,2068,"sợ gắn bó không?"],[2068,2152,"Không, ý tôi là,"],[2152,2227,"có vài chuyện,"],[2227,2402,"có lẽ cần sửa đổi?"],[2402,2460,"Cô ấy-"],[2460,2660,"cô ấy có vẻ tự ái rồi."],[2660,2698,"Này,"],[2698,2848,"cô cần đi cấp lại"],[2848,2998,"chứng chỉ xem"],[2998,3082,"chỉ tay đi,"],[3082,3115,"vì tôi"],[3115,3211,"không nghĩ mình bị chứng"],[3211,3324,"sợ gắn bó."],[3324,3432,"Tôi thấy là"],[3432,3582,"Cứ thành thật đi cô gái."],[3582,3670,"Chỗ này an toàn mà."],[3670,3816,"Chỗ này... an toàn á?"],[3816,3874,"Tôi không biết-"],[3874,3916,"với cả,"],[3916,3995,"chúng ta nên bắt đầu"],[3995,4033,"bằng việc"],[4033,4145,"thành thật trong mối quan hệ,"],[4145,4287,"chứ không phải những lời dối trá."],[4287,4346,"Ờ không."],[4346,4512,"Tôi chắc chắn không hề"],[4512,4562,"sợ gắn bó."],[4562,4675,"Tôi là kiểu người si tình đấy."]],"40":[[8,37,"Em khỏe không?"],[37,104,"Rất vui được gặp em. Trông em"],[104,187,"rất xinh đẹp hôm nay."],[187,362,"Ồ. Cảm ơn anh. Anh cũng vậy."],[362,396,"Em có nghĩ anh"],[396,429,"nên cởi"],[429,554,"áo ra như anh chàng này,"],[554,588,"hay như thế"],[588,692,"hơi làm quá?"],[692,788,"Ý anh là, em biết đấy."],[788,871,"Thích những gì em thấy chứ? - Anh ấy tự đề nghị đấy."],[871,938,"Anh ấy tự đề nghị mà."],[938,992,"Nhịp tim của em"],[992,1067,"đang đập thế nào rồi?"],[1067,1292,"Ồ, anh ấy đang cởi đồ kìa."],[1292,1317,"Đây có phải là"],[1317,1363,"anh chàng mà em"],[1363,1472,"đã nói chuyện lúc nãy không?"],[1472,1534,"Gì cơ?"],[1534,1647,"Lúc nãy em đâu có nói chuyện với ai"],[1647,1676,"đâu chứ."],[1676,1730,"Đừng có suy diễn!"],[1730,1780,"Em thích con trai"],[1780,1893,"có hình xăm à, có phải chuyện này"],[1893,1968,"là do anh có hình xăm không?"],[1968,2047,"Anh tưởng anh là chàng trai duy nhất"],[2047,2131,"có hình xăm ở đây chứ."],[2131,2214,"Anh tự luy