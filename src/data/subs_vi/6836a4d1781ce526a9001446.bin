á"],[5305,5451,"cô Emily đầu tiên khỏi đùi anh ta."],[5451,5668,"Tôi cảm thấy mình đã nỗ lực"],[5668,5868,"cho tôi và Chris."],[5868,6006,"Có thể chúng ta sẽ có buổi hẹn nữa?"],[6006,6106,"Ai biết được?"],[6106,6252,"Anh đang rủ em hẹn hò à?"],[6252,6335,"Đúng vậy."],[6335,6502,"Emily, anh có chuyện này"],[6502,6631,"có thể em sẽ muốn biết."],[6631,6698,"Ôi trời."],[6769,6806,"Vâng."],[6806,6944,"Em vừa thắng 2.000 đô."],[7169,7315,"Tuyệt quá!"],[7315,7411,"Đỉnh quá, Emily!"],[7653,7824,"Chúng ta sẽ uống sâm panh ngon"],[7824,7949,"và ăn trứng cá muối."],[7949,8041,"Ăn mừng chút chứ?"],[8041,8141,"Chắc chắn rồi!"],[8141,8279,"Anh rất hào phóng."],[8279,8425,"Anh là một người tình hào phóng."],[8425,8612,"Một điều về anh em nên biết"],[8692,8771,"Biết vậy thì tốt."],[8771,8888,"Tigerlily là người tuyệt vời."],[8888,8938,"Sẽ có người làm cô ấy"],[8938,9009,"rất hạnh phúc."],[9054,9184,"Nhưng giữa chúng tôi chưa từng có"],[9246,9396,"Kiểu muốn lột sạch đồ của nhau"],[9434,9555,"cảm giác như vậy,"],[9622,9709,"điều mà tôi cảm thấy"],[9709,9893,"mình có với cô nàng Emily kia."],[10030,10110,"Tôi hơi thất vọng"],[10110,10176,"vì chúng tôi đã không"],[10176,10397,"có buổi hẹn hò cho riêng mình."]],"78":[[12,120,"Nhưng cô ấy đã từ chối tôi."],[120,241,"Chào mọi người!"],[241,379,"Nhìn xem tôi có gì này!"],[567,675,"Yay!"],[675,792,"Ôi trời ơi."],[838,955,"Rất vui được có mặt ở đây."],[1101,1222,"Wow."],[1255,1384,"Nhìn cơ bắp kìa!"],[1384,1443,"Chào."],[1463,1555,"Trời đất ơi."],[1655,1814,"Gia nhập phe bóng tối đi."],[1943,2027,"Đang có chuyện gì vậy?"],[2027,2156,"Các cậu thấy hết mọi thứ sao?"],[2156,2214,"Ừ."],[2268,2381,"Và nghe nữa."],[2573,2631,"Nhìn này,"],[2631,2727,"có cái bàn"],[2727,2781,"mát-xa nếu anh"],[2781,2919,"muốn nằm xuống luôn."],[2932,3023,"Ừm... - Tôi"],[3057,3144,"Thật ra tôi rất giỏi"],[3144,3240,"khoản mát-xa,"],[3240,3386,"người ta bảo tôi thế."],[3386,3461,"Thế à?"],[3461,3541,"Ừ."],[3574,3657,"Chắc tôi sẽ phải"],[3657,3732,"tự kiểm chứng xem"],[3732,3799,"có đúng vậy không."],[3799,3958,"Anh ấy có định cởi áo không nhỉ?"],[3958,4104,"Nếu từ chối thì đúng là ngốc."],[4104,4166,"Được thôi."],[4166,4262,"Nghe hay đấy."],[4683,4750,"Anh từng được"],[4750,4917,"ai mát-xa cho bao giờ chưa?"],[4917,5117,"Đã rất lâu rồi,"],[5117,5163,"nên"],[5213,5326,"Tôi hơi sợ một chút."],[5326,5413,"Nói thật đấy."],[5455,5543,"Tôi hơi sợ, vì-"],[5543,5743,"Chắc tôi cũng hơi lục nghề rồi."],[5743,5901,"Giờ tôi chẳng biết mình đang làm gì nữa."],[5955,6093,"Không biết luôn."],[6093,6243,"Cô ấy không"],[6243,6339,"thích thế đâu. - thích anh ấy."],[6364,6477,"Cậu nghĩ cô ấy không thích à?"],[6477,6552,"Không. - Không hề."],[6552,6690,"Và anh ấy xứng đáng với người tốt hơn."],[6702,6802,"Chỉ nói vậy thôi."]],"79":[[87,158,"Mọi chuyện sao rồi?"],[304,446,"Hôm qua hơi căng thẳng quá."],[525,571,"Ý tôi là"],[571,709,"Ôi trời ơi."],[709,855,"Mọi chuyện bắt đầu rồi."],[855,1042,"Tôi sẽ mát-xa cho anh."],[1159,1205,"Chúng ta có nên dùng-"],[1205,1330,"Cô có biết mình đang làm gì không?"],[1451,1484,"Được rồi,"],[1484,1555,"Tôi định hỏi anh,"],[1555,1647,"nên dùng loại dầu nào."],[1647,1805,"Nhưng tôi sẽ tự quyết. - Tôi không thích dầu."],[1805,1881,"Tôi thích mát-xa khan."],[1943,2039,"Tôi có hơi bực,"],[2039,2160,"hơi buồn vì,"],[2160,2289,"sao anh dám không coi tôi"],[2289,2444,"như một công chúa và nữ hoàng chứ?"],[2631,2706,"Được rồi."],[2706,2756,"Vậy, anh từng"],[2756,2869,"được mát-xa bao giờ chưa?"],[2869,2998,"Rồi, nhiều lần là đằng khác."],[2998,3103,"Tôi thích mạnh tay chút nhé."],[3103,3153,"Lần cuối cùng"],[3153,3224,"anh được mát-xa là khi nào,"],[3224,3307,"Gấu Reigny?"],[3307,3411,"Hai ngày trước."],[3411,3503,"Không, ba ngày trước."],[3545,3611,"Từ ai?"],[3724,3832,"Một cô gái ở cuối phố."],[3883,3970,"Một bà cô người Thái."],[4116,4366,"Những người điên rồ lại khiến tôi bình tĩnh."],[4366,4596,"Tôi nghĩ đó là điều mà"],[4596,4683,"tôi không quá sợ hãi."],[4683,4833,"Tôi nghĩ tôi tìm thấy sự thoải mái"],[4833,4971,"trong những việc như vậy."],[4971,5100,"Cô vẫn còn giận tôi chuyện hôm qua à?"],[5100,5138,"Không."],[5138,5238,"Cô làm hơi yếu đấy."],[5238,5401,"Làm mạnh tay lên chút được không?"],[5401,5572,"Và tôi thích con gái ít nói."],[5601,5743,"Ai ít nói cơ?"],[5793,5910,"Ừm, được thôi."],[5910,6189,"Tôi thích tình dục, sự im lặng và sandwich."],[6243,6373,"Ba chữ S đó."],[6456,6631,"Nhưng anh ta bảo đã kiêng tình dục"],[6631,6748,"được năm năm rồi"],[6810,6927,"Còn hiện giờ đang mát-xa,"],[6927,7040,"nên lo tập trung đi."],[7165,7269,"Tôi không hiểu sao anh tập trung được"],[7269,7419,"khi anh thực sự quá-"],[7419,7557,"Này, cô thô lỗ thật đấy."],[7557,7649,"Tôi thô lỗ á?"],[7649,7791,"Rõ ràng là thế."],[7841,7912,"Được rồi-"],[7912,8070,"Kiểu, anh tham gia chương trình này làm gì?"],[8070,8166,"Tôi thậm chí còn không hiểu"],[8166,8245,"sao chúng ta lại ở đây."],[8324,8404,"Anh nên thấy biết ơn"],[8404,8550,"vì tôi đang mát-xa cho anh đấy, Reign."],[8625,8750,"Cô bị sao vậy?"],[8750,8900,"Ấn mạnh tay hơn một chút được không?"],[8921,9004,"Họ thậm chí chẳng cần chúng ta"],[9004,9067,"ở dưới đó."],[9067,9163,"Không, họ,"],[9163,9288,"họ tự chuốc lấy thôi."]],"80":[[70,312,"Anh có tưởng tượng được việc cưới Robyn không?"],[354,621,"Cô biết đấy, nếu mọi"],[621,759,"Nếu mọi"],[759,855,"Vì sao thẳng hàng. - Vì sao thẳng hàng."],[896,946,"Đồng thanh!"],[946,1055,"Chúng ta vừa cùng nói"],[1055,1213,"Bánh kẹp - Bánh kẹp!"],[1213,1338,"Cái đ*o gì vậy?"],[1405,1455,"Thật á?"],[1472,1539,"Tuyệt thật đấy."],[1539,1593,"Cô biết không,"],[1593,1685,"Tôi chưa từng làm thế bao giờ."],[1685,1780,"Không! - Đỉnh thật đấy."],[1780,1889,"Họ đồng điệu quá."],[1889,2027,"Hay thật đấy."],[2027,2122,"Anh có còn nghĩ về"],[2122,2239,"người yêu cũ nào không?"],[2360,2456,"Ừm"],[2548,2594,"Thỉnh thoảng."],[2594,2631,"Nếu có chuyện gì đó,"],[2652,2756,"hoặc một bài hát gợi lại,"],[2756,2852,"thì tôi sẽ nhớ."],[2852,2915,"Ừ."],[2915,3132,"Tôi không nghĩ mãi về nó, nhưng tự nhiên-"],[3132,3257,"Chỉ trả lời bằng có hoặc không."],[3257,3370,"Ồ, tôi xin lỗi."],[3440,3545,"Cô hỏi lại được không?"],[3545,3603,"Anh có"],[3603,3787,"nghĩ về người yêu cũ không?"],[3928,3991,"Có."],[3999,4099,"Tôi đoán là có."],[4099,4200,"Đó là sự thật."],[4200,4304,"Thỉnh thoảng."],[4304,4391,"Thấy chưa,"],[4391,4650,"anh ta toàn trả lời kiểu biện minh."],[4650,4717,"Thấy không?"],[4717,4792,"Lúc nào cũng kiểu, ồ,"],[4792,4892,"đúng vậy, trong tương lai,"],[4892,5080,"ồ có lẽ... Chúa ơi."],[5159,5367,"Anh ta tức điên rồi."],[5505,5643,"Anh từng ngoại tình chưa?"],[5726,5805,"Rồi."],[5905,6006,"Đó là sự thật."],[6060,6164,"Anh ta từng ngoại tình!"]],"81":[[12,204,"Tôi từng đi mát-xa cặp đôi"],[204,321,"với người yêu trước đây,"],[321,533,"nhưng chưa bao giờ"],[533,738,"được mát-xa ở buổi hẹn thứ hai"],[738,909,"lại còn bởi một người hoàn toàn xa lạ."],[909,988,"Chắc giờ em đang được"],[988,1105,"mát-xa đôi đấy-"],[1105,1188,"Không đâu, ông bạn."],[1188,1313,"Đó là điều tôi không-"],[1313,1484,"Có thể ông thích mấy trò đó,"],[1484,1551,"nhưng tôi thì không."],[1551,1618,"Nên ông sẽ phải"],[1618,1718,"rời khỏi đây đi."],[1718,1776,"Em thấy sao?"],[1776,1926,"Để Autumn chọn đi."],[1926,2014,"Để cô ấy nói."],[2014,2118,"Được rồi, để cô ấy chọn đi."],[2118,2223,"Em thấy sao, Autumn?"],[2364,2556,"Cả hai đều rất tuyệt."],[2556,2594,"Cô ấy kiểu-"],[2594,2748,"Cả hai đều rất tuyệt."],[2781,2919,"Vì cô ấy không muốn làm"],[2919,3019,"tổn thương Sherif."],[3019,3069,"Đúng vậy."],[3094,3161,"Ừ."],[3190,3315,"Nhưng ai làm tốt hơn?"],[3336,3436,"Em nghĩ sao?"],[3724,3828,"Ai làm em thấy"],[3828,3937,"thoải mái hơn?"],[3958,4087,"Chà, em thấy anh thực sự"],[4087,4225,"bóp đúng chỗ mỏi."],[4225,4379,"Nên có lẽ tôi"],[4379,4537,"mát-xa giỏi hơn một chút?"],[4583,4633,"Đúng vậy."],[4679,4884,"Tôi là huấn luyện viên cá nhân có bằng cấp."],[4909,5109,"Thỉnh thoảng, tôi cũng phải giúp"],[5109,5280,"khách hàng thư giãn"],[5280,5367,"nếu họ bị mỏi"],[5367,5505,"ở vùng vai-"],[5505,5559,"Cứ tưởng"],[5559,5709,"một huấn luyện viên có bằng cấp"],[5709,5943,"thì thân hình phải đẹp hơn chứ."],[5943,6051,"Ông nghĩ thế à?"],[6051,6168,"Ừ. - Ồ, chà."],[6168,6373,"Ồ, anh ta đang chê bai thân hình cậu ấy!"],[6414,6510,"Đối mặt như một người đàn ông xem nào!"],[6510,6648,"Này, ông đang làm cái gì thế?"]],"82":[[8,108,"Anh nghĩ điểm trừ"],[108,191,"lớn nhất của anh"],[191,283,"hiện tại là gì?"],[283,421,"Rõ ràng là khoản giao tiếp."],[421,513,"Nhưng chắc là,"],[513,709,"điều mà mọi người"],[709,821,"hay phàn nàn về anh nhất,"],[821,930,"chính là việc anh"],[930,1109,"quá bận rộn,"],[1109,1222,"hoặc là thiếu"],[1222,1355,"sự giao tiếp."],[1355,1501,"Vậy lúc duy nhất em gặp anh"],[1501,1555,"là những lúc"],[1555,1626,"chúng ta mát-xa sao?"],[1626,1710,"Ý anh là vậy à?"],[1710,1801,"Có lẽ vậy."],[1830,1931,"Tay anh bắt đầu mỏi rồi,"],[1931,2031,"em ngồi dậy nhé."],[2072,2127,"Và để anh có thể"],[2127,2273,"ngắm đôi mắt xanh tuyệt đẹp của em."],[2273,2302,"Phải rồi."],[2302,2344,"Được thôi."],[2364,2414,"Nghe hay đấy."],[2452,2523,"Vui vẻ nhé."],[2523,2598,"Cậu làm được mà."],[2610,2690,"Tiến lên, Emily!"],[2690,2798,"Cậu là nhất!"],[2861,2961,"Anh thấy mình đã nói"],[2961,3073,"hơi nhiều về bản thân"],[3073,3236,"và việc anh là người bận rộn."],[3236,3299,"Vâng, anh làm nhiều việc thật."],[3299,3424,"Còn em làm gì?"],[3424,3599,"Kinh doanh."],[3599,3666,"Ừ."],[3695,3757,"Chào."],[3757,3824,"Chào."],[3853,3974,"Chà, cô ấy tự dưng xuất hiện kìa!"],[3974,4104,"Cô ấy ở ngay đây này."],[4104,4133,"Chào."],[4133,4208,"Khỏe không?"],[4208,4262,"Khỏe."],[4262,4362,"Còn anh?"]],"83":[[54,166,"Thế này tốt hơn chưa? - Rồi, đúng rồi đấy."],[166,275,"Dùng khuỷu tay ấy."],[275,342,"Đúng rồi."],[342,408,"Ôi!"],[446,558,"Thế đủ mạnh chưa?"],[804,875,"Cô ấy là nữ hoàng mà."],[875,959,"Có mạnh quá không?"],[959,1009,"Chà."],[1071,1130,"Bình thường anh có như vậy"],[1130,1180,"khi yêu không?"],[1180,1267,"Hay càu nhàu ấy?"],[1267,1359,"Không, ý tôi là"],[1555,1605,"Thấy chưa?"],[1605,1693,"Vì tôi không thích"],[1693,1881,"kiểu đàn ông"],[1881,1993,"lắm mồm."],[1993,2160,"Tôi thích đàn ông dịu dàng và ngọt ngào."],[2235,2473,"Mấy ngày nay tôi vẫn thế mà."],[2540,2660,"Tôi cảm giác cô đang lợi dụng"],[2660,2715,"Thế à?"],[2715,2769,"lòng tốt của tôi."],[2769,2890,"Lòng tốt nào cơ?"],[2890,2982,"Tôi bị ảo giác chắc?"],[2982,3090,"Mấy ngày qua là sao cơ?"],[3090,3182,"Anh đang nói cái gì vậy?"],[3182,3436,"Anh đã rất, rất, RẤT"],[3436,3507,"thất thường"],[3507,3616,"Anh đang thao túng tâm lý tôi à?"],[3753,3974,"Đừng có cười, vì tôi biết mà,"],[3974,4137,"tôi biết ngay từ ngày đầu gặp rồi."],[4137,4250,"Anh cũng dễ thương này nọ đấy,"],[4250,4325,"nhưng anh"],[4412,4504,"Tôi dễ thương, cảm ơn"],[4504,4612,"Bị thần kinh."],[4612,4662,"Anh điên rồi."],[4662,4721,"Thần kinh á?"],[4721,4825,"Cô mới điên thì có."],[4871,5071,"Chẳng phải hôm qua cô khóc sao?"],[5071,5155,"Lúc nào?"],[5280,5392,"Tôi khóc lúc nào cơ?"]],"84":[[20,154,"Anh từng ngoại tình chưa?"],[154,408,"Buồn thay là có."],[408,546,"Ồ, điều đó vừa làm cô ấy"],[546,613,"hơi đau lòng đấy."],[684,788,"Không đáng tự hào-"],[788,888,"Nói thật."],[888,1080,"Bản tính anh có hay ngoại tình không?"],[1176,1251,"Không."],[1297,1347,"Không."],[1547,1647,"Nói thật."],[1710,1789,"Anh có thích hẹn hò"],[1789,2010,"cùng lúc nhiều phụ nữ không?"],[2243,2485,"Dù nghe có vẻ cũng,"],[2485,2615,"khá vui đấy."],[2615,2727,"Tôi chưa từng"],[2727,2973,"Thường thì khi gặp ai đó"],[2973,3053,"Có hay không!"],[3086,3157,"Có hay không!"],[3157,3261,"Khoan, chỉ được trả lời có hoặc không à?"],[3261,3324,"Ừ. - Tôi cứ nhầm hoài."],[3324,3374,"Xin lỗi."],[3374,3436,"Hỏi lại đi."],[3436,3557,"Anh có thích nhiều hơn một"],[3557,3691,"phụ nữ cùng lúc không?"],[3691,3841,"Này, cô đang hỏi gài đấy."],[3841,3991,"Mấy câu này được diễn đạt rất-"],[3991,4154,"Trả lời đi!"],[4154,4245,"Tôi có bao giờ nghĩ đến"],[4245,4350,"nhiều cô gái cùng lúc không á?"],[4350,4383,"Không."],[4383,4458,"Anh có muốn ở bên"],[4458,4571,"nhiều cô gái cùng lúc không?"],[4725,4817,"Hiện tại thì không."],[5367,5497,"Dấu hiệu nói dối."]],"85":[[4,137,"Nói thật nhé, anh bạn,"],[137,221,"tôi biết anh là một người"],[221,300,"rất tuyệt vời."],[300,392,"Tôi và Autumn thật sự"],[392,567,"đang rất tốt đẹp."],[567,625,"Nên ý tôi là,"],[625,792,"tôi không thích việc"],[792,875,"anh cứ xen vào"],[875,1092,"cố phá đám hết lần này đến lần khác,"],[1092,1163,"anh hiểu không?"],[1163,1247,"Ngoài kia còn"],[1247,1334,"đầy phụ nữ mà."],[1334,1451,"Tôi nghĩ có lẽ anh nên dành"],[1451,1659,"năng lượng đó,"],[1659,1697,"anh biết đấy,"],[1697,1797,"để tìm một người khác"],[1797,1926,"mà anh có thể kết nối sâu sắc hơn."],[1926,2002,"Bởi vì, anh biết đấy,"],[2002,2064,"tôi và Autumn thật sự"],[2064,2122,"rất hợp nhau."],[2122,2227,"Nên là"],[2227,2293,"Em thích thế."],[2293,2377,"Cũng hợp lý thôi."],[2377,2448,"Nói thật nhé."],[2448,2535,"Nếu tôi có cơ hội"],[2535,2694,"để tiến tới với em, Autumn,"],[2694,2773,"chắc chắn tôi đã"],[2773,2848,"tiến tới rồi."],[2848,2973,"Tôi chỉ muốn nói rõ vậy thôi."],[3019,3069,"Aww."],[3098,3211,"Ý tôi là cô ấy đã chọn rồi."],[3211,3257,"Anh hiểu ý tôi chứ?"],[3257,3432,"Anh đã kể cho cô ấy nghe về cả buổi hẹn"],[3432,3599,"với Emily hôm nọ chưa?"],[3599,3728,"Rồi, chúng tôi đã nói chuyện đó"],[3728,3803,"cả triệu lần rồi."],[3803,3970,"Thế đã kể cô ấy nghe về nụ hôn"],[3970,4070,"thứ hai lên má chưa?"],[4070,4195,"Còn một nụ hôn nữa sao?"],[4270,4416,"Anh còn giấu cô ấy chuyện gì nữa hả?"],[4416,4504,"Tôi đang cho anh cơ hội"],[4504,4579,"để thành thật đấy, anh bạn."],[4579,4629,"Tôi không muốn"],[4629,4746,"làm anh mất mặt thế này đâu,"],[4746,4838,"nhưng hãy nói sự thật đi."],[4838,5075,"Chủ động tán tỉnh là một chuyện."],[5075,5321,"Bị người khác tán tỉnh lại là chuyện khác."],[5321,5376,"Anh hiểu ý tôi chứ?"],[5376,5559,"Việc cô ta sấn sổ vào tôi,"],[5559,5676,"đòi ngồi lên đùi tôi, hôn lên"],[5676,5793,"má tôi, cũng giống như việc"],[5793,5943,"anh mò đến đây"],[5943,6060,"đòi mát xa cho cô ấy thôi."],[6060,6114,"Vậy ý anh là-"],[6114,6252,"Cô ấy không hề chủ động"],[6252,6381,"cô ấy không yêu cầu việc đó."],[6381,6514,"Cô ta đã tán tỉnh anh."],[6514,6619,"Đúng, chắc chắn rồi."],[6619,6802,"Vậy sao anh lại đưa áo khoác cho cô ta?"],[6802,6927,"Anh đáng lẽ có thể bỏ đi mà."],[6927,7102,"Sao anh lại để chuyện đó xảy ra?"],[7102,7328,"Anh hoàn toàn có thể bỏ đi mà."]],"86":[[20,83,"Anh thấy sao?"],[83,216,"Tuyệt vời lắm."],[216,312,"Tốt."],[312,412,"Ừ, tôi vừa được"],[412,550,"mát xa cực đã."],[550,717,"Tuyệt lắm à? / - Không chê vào đâu được-"],[717,834,"Ừ"],[834,880,"Tôi nghĩ vậy."],[880,938,"Phần bả vai"],[938,1021,"khá là"],[1021,1076,"Đã đúng không?"],[1076,1180,"Rất là sướng."],[1180,1259,"Thế là tôi đang mát xa"],[1259,1326,"cho anh ấy, và tôi"],[1326,1409,"Tôi chẳng biết"],[1409,1505,"mình đang làm gì nữa."],[1559,1701,"Chẳng biết nữa."],[1701,1780,"Anh có muốn tôi"],[1780,1851,"mát xa cho không?"],[1889,1951,"Mát xa à?"],[1951,2014,"Ý tôi là"],[2014,2147,"Chỉ thử một chút thôi."],[2147,2202,"Sao lại không? / - Ừ"],[2202,2243,"Ừ."],[2243,2306,"Thử một chút."],[2306,2352,"Nhỉ?"],[2352,2510,"Thế còn"],[2510,2619,"Mục đích của cô-"],[2619,2660,"Mục đích á?"],[2660,2811,"Ý tôi là mục đích của việc mát xa."],[2811,2852,"Ý anh là sao?"],[2852,2923,"Tôi muốn anh thư giãn"],[2923,2986,"và cảm thấy thoải mái."],[2986,3015,"Được chứ?"],[3015,3107,"Tôi ngồi ngay đây được không?"],[3107,3215,"Đương nhiên là được rồi."],[3215,3261,"Tuyệt."],[3261,3315,"Ý em là-"],[3315,3445,"Và em cứ phải ngồi đây nhìn thôi sao?"],[3445,3595,"Không, ý anh là mình đang nói chuyện-"],[3595,3720,"Cô không cần phải ngồi đây nhìn đâu."],[3720,3791,"Cô có thể đi nếu muốn."],[3791,3849,"Không, không, em có thể-"],[3849,3941,"Ồ! / - Không sao đâu."],[3941,3974,"Cô cứ đi đi."],[4008,4104,"Anh có muốn em ở lại không?"],[4104,4241,"Anh rất muốn em ở lại."],[4241,4383,"Cô ta nói cô có thể đi nếu muốn sao?"],[4383,4466,"Ừ!"],[4466,4562,"Và rồi cô ấy hỏi anh ta."],[4562,4658,"Nghe này,"],[4658,4758,"tôi rất muốn mát xa"],[4758,4817,"cho anh thế này,"],[4817,4904,"nhưng sẽ dễ hơn"],[4904,5030,"nếu anh nằm xuống."],[5055,5146,"Nằm xuống á?"],[5146,5205,"Ừ, nếu anh nằm xuống."],[5205,5301,"Cô muốn tôi nằm xuống sao?"],[5301,5417,"Ở đâu, tôi chỉ- / - Có được không?"],[5417,5526,"Ừ, anh nghĩ mình"],[5526,5643,"có thể nằm xuống đây không?"],[5643,5780,"Anh không tự quyết định được."],[5834,5889,"Ý anh là,"],[5889,5951,"em biết đấy, thật khó"],[5951,6068,"để từ chối một suất mát xa,"],[6068,6126,"anh nghĩ vậy."],[6156,6302,"Ồ, thật khó để từ chối"],[6302,6489,"một suất mát xa."],[6489,6719,"Cái đ*o gì vậy!"],[6719,6798,"Nhưng"],[6798,6902,"Ừ."],[6902,6973,"Ý anh là, chúng ta có thể-"],[6973,7052,"và tiếp tục / - Vừa mát xa."],[7052,7119,"trò chuyện, đúng không?"],[7173,7248,"Anh vẫn có thể tìm hiểu em-"],[7248,7332,"Trong khi nhìn"],[7332,7461,"anh được người khác mát xa á?"],[7461,7603,"À thì, cũng không hẳn"]],"87":[[16,95,"Em điên rồi."],[95,316,"Không phải hôm qua em là người khóc lóc sao?"],[316,446,"Bởi vì mọi chuyện cũng ảnh hưởng"],[446,583,"đến anh, anh cũng là con người mà."],[583,608,"Ý anh là,"],[608,675,"chỉ vì anh trông giống"],[675,767,"một con quái thú đ*o nào đó"],[892,967,"Anh ấy không hề giống"],[967,1046,"một con quái thú."],[1046,1105,"Anh ta nói, chỉ vì anh ta trông giống"],[1105,1201,"một con quái thú đ*o nào đó hả?"],[1201,1267,"Trời ạ."],[1267,1409,"Anh ở đây được mười năm rồi."],[1409,1518,"Anh đến từ Philippines."],[1518,1676,"Bố anh làm trong quân đội."],[1730,1801,"Cứ mỗi ba năm."],[1801,1956,"Lại chuyển đi nơi khác,"],[1956,2122,"rồi đến tận Los Angeles,"],[2122,2281,"với chất giọng tiếng Anh"],[2381,2469,"Philippines kỳ quặc."],[2469,2681,"Anh bị bắt nạt, bị đánh đập."],[2681,2819,"Nên anh đã học võ."],[2819,3098,"Anh biết cách tự bảo vệ mình."],[3119,3319,"Anh cũng có cảm xúc,"],[3319,3607,"và anh đang tìm kiếm"],[3607,3728,"một điều gì đó đặc biệt."],[3728,3895,"Và anh cảm thấy như em chỉ"],[3895,4095,"Cứ như,"],[4095,4333,"anh không biết nữa, em chẳng hề để tâm."],[4333,4546,"Ồ, vậy là anh dễ xúc động."],[4546,4708,"Đúng thế, thực ra là vậy."],[4708,4825,"Anh phải bảo vệ trái tim mình."],[4825,4954,"Reign là người mà"],[4992,5034,"tôi cảm thấy"],[5034,5163,"anh ấy không thích bộc lộ quá nhiều cảm xúc."],[5163,5417,"Nên bạn phải rất cẩn trọng"],[5417,5518,"với những người như vậy."],[5518,5872,"Nhưng tôi nghĩ nếu cố gắng nhiều,"],[5872,6051,"có thể khi Reign đi trị liệu tâm lý,"],[6051,6177,"chúng tôi có thể đưa mối quan hệ này"],[6177,6297,"lên một tầm cao mới."],[6352,6535,"Em rất thích những chàng trai nhiệt huyết."],[6560,6623,"Và đó là"],[6623,6806,"điều em thích ở anh hôm qua."],[6806,6990,"Nhưng thái độ hỗn xược, cáu kỉnh này"],[6990,7169,"thì không hấp dẫn chút nào."],[7169,7207,"Bởi vì-"],[7207,7336,"Nhưng em thích khi anh ngọt ngào cơ."],[7336,7382,"Nghe này- - Cứ phát huy nhé."],[7570,7636,"Em thao túng giỏi thật đấy."],[7636,7703,"Điên rồ thật."],[7745,7828,"Thao túng á?"],[7828,7932,"Có khi anh mới là người thao túng."],[7932,8033,"Có thể anh mới là người"],[8033,8204,"đang suy diễn đấy, Reign."],[8204,8270,"Thấy chưa?"],[8270,8412,"Thao túng tâm lý đỉnh cao luôn."],[8412,8546,"Trời ạ, cái đ*o gì thế này?"],[8546,8604,"Cứ tự nhiên nhé."],[8604,8683,"Tuyệt lắm người anh em!"],[8683,8800,"Cố lên nhé!"],[8800,8863,"Vui vẻ nhé."],[8863,8938,"Đàn hát vài bài đi."],[8938,9079,"Anh chơi guitar giỏi thật đấy."],[9079,9171,"Đàn hát cho cô ấy đi."],[9388,9446,"Ồ!"],[9484,9743,"Chúng ta có âm nhạc rồi!"]],"88":[[50,187,"Anh có thể cứ thế bỏ đi mà."],[233,316,"Anh không biết, ý anh là,"],[316,467,"anh bị cho leo cây,"],[467,533,"và anh cảm thấy"],[533,621,"hơi hụt hẫng một chút-"],[621,729,"Vì em bị tai nạn mà!"],[771,888,"Anh đâu có biết."],[888,930,"Chà."],[930,959,"Em biết đấy,"],[959,1130,"và, ừ, anh xin lỗi, thật sự xin lỗi."],[1130,1217,"Anh đâu biết chuyện - Sau tai nạn đó"],[1217,1305,"gì đã xảy ra. -em có sao không?"],[1347,1480,"Cũng tàm tạm."],[1480,1630,"Kiểu như, thể chất thì em ổn rồi."],[1630,1697,"Thế còn tinh thần thì sao?"],[1697,1793,"Em thấy thế nào?"],[1793,1951,"Chuyện này chắc chắn chẳng giúp ích gì."],[1951,2006,"Chà."],[2006,2198,"Nghĩa là không chỉ hôn một lần,"],[2198,2414,"mà tận hai lần, còn ngồi lên đùi anh."],[2414,2523,"Và anh cứ thế hả?"],[2523,2619,"Để yên cho chuyện đó xảy ra?"],[2619,2761,"Thật điên rồ."],[2902,2969,"Ý anh là-"],[2969,3132,"Mà đó là ở buổi hẹn đầu tiên ư?"],[3132,3240,"Ở buổi hẹn đầu tiên đấy."],[3240,3328,"Thật hoang đường."],[3349,3436,"Anh xin lỗi vì lúc nãy"],[3436,3566,"không nói rõ với em,"],[3566,3678,"nhưng anh thấy"],[3678,3807,"chúng ta hoàn toàn có thể"],[3807,3849,"tiến tới sau chuyện này."],[3849,3895,"Em tưởng-"],[3895,4004,"Autumn này, do em nhầm hay mình vừa nói"],[4004,4191,"chuyện này lúc nãy rồi"],[4212,4258,"Đúng thế."],[4258,4325,"Với anh chàng này á?"],[4491,4608,"Đó chỉ là đi chơi thôi."],[4646,4800,"Đúng rồi đấy, Emily."],[4821,4929,"Emily, vào làm rõ đi kìa."],[4929,5059,"Chúng ta cần làm rõ mọi chuyện."],[5059,5246,"Share-rife này, đến giờ rồi người anh em."],[5280,5326,"Đến lúc chuồn rồi."],[5326,5409,"Chỉ vì tên anh"],[5409,5555,"không ngầu bằng tôi không có nghĩa là"],[5555,5709,"anh phải, kiểu như, cố tình"],[5709,5847,"cứ phát âm sai tên tôi."],[5847,5914,"Share-rife là-"],[5914,6072,"Vì tôi thấy thế cực kỳ thiếu tôn trọng"],[6072,6218,"Share-rife là một cái tên ngầu mà."],[6218,6352,"Và nếu anh không cẩn thận lời ăn tiếng nói,"],[6352,6402,"anh biết đấy"],[6423,6493,"Thì sẽ xảy ra chuyện gì?"],[6493,6564,"Có chuyện sẽ xảy ra đấy."],[6594,6702,"Thì sẽ xảy ra chuyện gì?"],[6765,6898,"Chuyện gì sẽ xảy ra?"],[6940,6994,"Ôi không."],[7007,7077,"Họ sắp đánh nhau rồi."],[7111,7169,"Anh ta định đánh anh ấy sao?"],[7194,7253,"Ừ, có vẻ như"],[7253,7315,"anh ta sẽ đánh anh ấy."],[7357,7411,"Ôi Chúa ơi."]],"89":[[16,79,"Anh có muốn hẹn hò"],[79,233,"cùng lúc với nhiều cô không?"],[250,362,"Hiện tại thì không."],[362,479,"Dấu hiệu nói dối."],[613,750,"Thì chúng ta đang đi hẹn hò mà."],[771,846,"Ừ."],[846,955,"Ở đây có nhiều cô gái đẹp."],[955,1030,"Rất đúng."],[1030,1263,"Anh có nghĩ hẹn hò thì phải trả tiền không?"],[1263,1434,"Trả tiền hẹn hò á?"],[1434,1605,"Kiểu như đưa một cô gái đi ăn tối."],[1605,1735,"À, và trả tiền cho bữa đó."],[1735,1868,"Ừ, ừ, tất nhiên rồi."],[1868,1943,"Anh lại tưởng ý em là"],[1943,2081,"Vâng, tất nhiên rồi."],[2102,2218,"Anh đã bao giờ trả tiền cho một phụ nữ"],[2218,2327,"để họ đi hẹn hò với anh chưa?"],[2327,2385,"Đó chính là điều"],[2385,2477,"anh tưởng em định hỏi."],[2527,2698,"Kiểu trả tiền để được hẹn hò ấy."],[2698,2861,"Đúng, anh từng làm vậy chưa?"],[2861,2902,"Chưa-"],[3011,3119,"Nhìn mặt ổng kìa."],[3119,3315,"Kiểu như, ừ, tôi thích gái gọi lắm."],[3315,3411,"Anh từng trả tiền"],[3411,3649,"À, chưa, chưa, chưa."],[3753,3887,"Ý anh là, thế thì kỳ lắm."],[3887,3991,"Anh nói câu đó nghe kỳ ghê."],[3991,4054,"Thế thì kỳ lắm."],[4054,4116,"Đúng là kỳ thật."],[4116,4362,"Bảo sao lại có dấu hiệu nói dối."],[4362,4542,"Ừ, chắc là ta có thể trả lời-"],[4608,4742,"Câu hỏi là gì nhỉ?"],[4742,4892,"Anh đã từng trả tiền"],[4892,5205,"để phụ nữ đi hẹn hò hoặc"],[5242,5401,"làm mấy chuyện đó với anh chưa?"],[5543,5730,"Anh ta sợ câu này rồi."],[5730,5855,"Ôi, sh*t!"],[5855,6014,"Trả lời đi chứ."],[6014,6185,"Ôi, f**k."],[6185,6310,"Anh đang bị dồn vào thế bí."],[6310,6423,"Anh ta đang né tránh."],[6423,6514,"Né tránh kìa."],[6514,6710,"Anh từng... anh đã từng"],[6710,6781,"F**k."],[6781,6919,"Em hỏi lại lần nữa được không?"],[6919,7107,"Cô ấy nhắc lại lần thứ ba rồi kìa."],[7107,7403,"Anh đã bao giờ trả tiền cho phụ nữ"],[7403,7553,"để họ hẹn hò với anh chưa?"],[7553,7615,"Chưa."],[7724,7853,"Sự thật."],[7857,8170,"Anh đã bao giờ trả tiền cho phụ nữ để quay,"],[8229,8466,"nội dung 18+ với anh chưa?"],[8466,8583,"F**k!"]],"90":[[8,70,"Khó mà từ chối"],[70,145,"một suất mát-xa thật đã"],[145,216,"Em nghĩ vậy."],[216,383,"Nếu người em đang hẹn hò"],[383,533,"để người phụ nữ khác mát-xa,"],[533,617,"thì coi như xong."],[617,709,"Em chia tay luôn."],[709,821,"Ý em là, ừ thì,"],[821,905,"có hơi kỳ cục"],[905,1205,"và khó chịu, mờ ám,"],[1222,1322,"một chút."],[1322,1368,"Ừ."],[1426,1501,"Chà, em nói đúng."],[1501,1547,"Thành thật mà nói,"],[1547,1643,"em nói khá đúng chuyện đó."],[1643,1776,"Anh không, anh không muốn"],[1776,1835,"Chúng ta đang"],[1835,2010,"giữa một cuộc trò chuyện"],[2010,2181,"khá là ăn ý,"],[2181,2331,"và anh không muốn phá hỏng nó."],[2331,2498,"Anh ta đang chùn bước."],[2498,2615,"Vậy ý định của cô là gì"],[2615,2677,"khi xuống đây-"],[2677,2761,"Không, em chỉ là,"],[2761,2927,"anh từng nói anh rất thích"],[2927,3011,"thời gian chất lượng."],[3011,3053,"Anh bảo"],[3053,3153,"anh thích tiếp xúc cơ thể."],[3153,3244,"Đó là hai"],[3294,3353,"Ngôn ngữ tình yêu-"],[3353,3478,"Ừ, anh biết, nhưng bọn anh,"],[3478,3591,"bọn anh đang-"],[3591,3712,"Và em thấy anh rất dễ thương,"],[3712,3841,"nên em chỉ muốn xuống đây"],[3841,3933,"để cho anh biết điều đó."],[3958,4049,"Em nghĩ anh xứng đáng với người"],[4049,4225,"muốn dành thời gian cho anh"],[4225,4383,"và thực sự, anh biết đấy"],[4383,4466,"Được rồi."],[4466,4587,"Ừm... - Ừ."],[4587,4879,"Anh nghĩ sao về việc cô ta"],[4879,5038,"chen ngang cuộc trò chuyện của ta?"],[5038,5146,"Thì"],[5146,5259,"Chà"],[5259,5359,"anh có thể tự lên tiếng,"],[5359,5547,"nhưng tôi nghĩ anh ấy"],[5547,5693,"đang muốn bảo cô rời đi đấy."],[5693,5793,"Ừ, anh không-"],[5793,5893,"Một cách lịch sự nhất."],[5893,5955,"Ừ."],[5955,6106,"Và tôi cũng muốn bảo cô"],[6106,6193,"rời đi đấy."],[6193,6318,"Ái chà."],[6318,6485,"Cũng được thôi nếu cô muốn tôi"],[6485,6685,"rời đi, nhưng tôi đang hỏi anh ấy."],[7132,7261,"Cờ đỏ."],[7261,7323,"Cờ đỏ!"]],"91":[[225,592,"Ồ, chúng ta có nhạc kìa."],[592,684,"Cô ấy thậm chí"],[684,825,"còn không nhận ra anh ta là người chơi."],[825,1042,"Nhìn Josip đang nhìn anh ta kìa."],[1042,1126,"Cô ấy nghĩ"],[1126,1238,"đó là nhạc công được thuê sao?"],[1238,1322,"Đúng thế!"],[1322,1434,"Đáng yêu quá."],[1480,1580,"Dạo này sao rồi?"],[1580,1630,"Anh chàng này là ai thế?"],[1630,1701,"Tôi ổn."],[1701,1772,"Còn cậu?"],[1772,1847,"Tôi khỏe."],[1910,2031,"Nhạc hay lắm."],[2031,2198,"Trời ơi, như một bữa tiệc vậy!"],[2198,2318,"Ừ, dành cho em đó."],[2318,2444,"Chuyện gì đang xảy ra thế?"],[2519,2631,"Ồ. - Anh chàng đó-"],[2631,2794,"Lãng mạn quá."],[2794,2915,"Này, cảm ơn nhé, đồ ngốc."],[2915,3094,"Cứ gảy tiếp đi... gảy những"],[3115,3169,"Dây đàn đó."],[3169,3228,"Cảm ơn."],[3228,3328,"Cứ tiếp tục chơi đàn đi."],[3328,3382,"Chuyện gì vậy?"],[3382,3503,"Cái này cho em hay cho anh?"],[3503,3595,"Cho chúng ta."],[3595,3766,"Cho tất cả mọi người."],[3766,3958,"Tôi ở đây vì mọi người."],[3958,4087,"Khỏe không? - Có chuyện gì vậy?"],[4087,4145,"Tôi khỏe."],[4145,4341,"Anh cũng muốn viết một bài hát cho em."],[4341,4462,"Anh viết nhạc cho em sao?"],[4462,4637,"Cưng ơi, anh ấy viết nhạc cho em này."],[4792,4825,"Nghe thử xem."],[4825,4946,"Được rồi, tôi sẽ cho anh ấy một cơ hội."],[5230,5326,"Anh có muốn hát theo không?"],[5326,5472,"Lần đầu nhìn thấy em,"],[5472,5709,"anh đã không thể kiềm lòng."],[5755,6060,"Nụ cười đó là điều đẹp nhất"],[6093,6252,"anh từng thấy."],[6356,6456,"Thật đấy."],[6456,6598,"Tôi đã học võ thuật, nên"],[6598,6781,"tôi biết cách tự vệ."]],"92":[[29,229,"Em là một người rất chung thủy."],[229,275,"Ừ."],[275,458,"Và em không thích cái kiểu"],[458,563,"nói chuyện với nhiều người"],[563,658,"cùng một lúc."],[658,800,"Và vì tôn trọng anh,"],[800,859,"bởi vì em nghĩ"],[859,905,"chúng ta đang tiến triển tốt,"],[967,1021,"em sẽ"],[1021,1130,"từ chối ngay lập tức."],[1205,1263,"Đó là điều em nghĩ"],[1263,1334,"sẽ xảy ra sao?"],[1372,1405,"Đúng vậy."],[1405,1463,"Được rồi."],[1509,1614,"Đúng, 100% luôn."],[1614,1643,"Được rồi, chắc anh"],[1643,1701,"chỉ còn cách,"],[1701,1851,"tin em chuyện đó thôi."],[1851,1889,"Vâng."],[1889,2047,"Em mới là người phải tin anh."],[2047,2122,"Anh là người suýt nữa"],[2122,2185,"đã để người khác"],[2185,2239,"mát-xa cho,"],[2239,2327,"lúc đó đấy. - Anh đã nói không mà."],[2327,2414,"Đến phút cuối anh vẫn từ chối."],[2414,2519,"Anh đã chần chừ"],[2519,2715,"suốt mấy phút liền đấy."],[2715,2840,"Cậu biết điều gì bực mình không."],[2840,2990,"Là cô ta có vẻ thích anh ấy hơn"],[2990,3140,"sau khi tớ bước vào đó."],[3203,3345,"Nhưng chúng ta ổn, đúng không?"],[3345,3436,"Mình ổn chứ?"],[3436,3595,"Chúng ta ổn."],[3678,3720,"Ừ."],[3720,3816,"Chúng ta ổn."],[3816,3928,"Càng không có được thì càng muốn."],[3928,4070,"Và anh ta suýt nữa thì mủi lòng."],[4070,4133,"Tớ biết nhưng"],[4133,4208,"Cô ta đã cuống lên."],[4208,4287,"Thật bực mình."],[4329,4433,"Tha cho anh đi."],[4433,4529,"Đó chỉ là mát-xa thôi."],[4529,4596,"Chỉ có thế thôi mà."],[4750,4850,"Em vui vì chúng ta cùng suy nghĩ."],[4850,4888,"Em vui-"],[4888,4992,"Anh suýt làm em trông"],[4992,5096,"như con ngốc ở đó đấy."],[5096,5317,"Anh mừng vì em có thể tha thứ cho anh."],[5317,5405,"Dù anh không nghĩ"],[5405,5547,"mình thực sự đã làm gì sai"],[5547,5622,"anh nghĩ mình đã quyết định đúng-"],[5622,5697,"Anh 'suýt',"],[5697,5801,"làm sai chuyện đó đấy."],[5801,5905,"Anh suýt,"],[5905,5955,"chỉ suýt thôi-"],[5955,6018,"Là suýt."],[6018,6139,"Từ khóa đấy."],[6139,6222,"Chúng ta vẫn đang tốt mà."],[6222,6277,"Suýt."],[6277,6318,"Nên là"],[6318,6452,"Cứ coi như"],[6452,6539,"chưa có chuyện gì xảy ra đi."],[6539,6644,"Cô ta chẳng thèm để ý đến anh ấy"],[6644,6785,"cho đến khi Emily xuất hiện,"],[6785,6881,"rồi cô ta kiểu,"],[6881,7048,"ồ, mình không thể thua vụ này."],[7048,7261,"Nên cô ta mới vồ vập anh ấy hơn."],[7261,7399,"Đó có phải là điều"],[7399,7582,"sẽ tiếp tục xảy ra,"],[7582,7736,"hay là thói quen của bạn không?"],[7736,7957,"Kiểu nửa chân trong,"],[7957,8045,"nửa chân ngoài sao?"],[8045,8199,"Bạn luôn vậy trong các mối quan hệ à?"]],"93":[[62,233,"Khi em"],[291,442,"đi ngang qua."],[579,754,"Trông anh ta bực kìa!"],[1013,1163,"Hay quá đi!"],[1263,1313,"Cái quái gì thế?"],[1472,1543,"Cảm ơn em."],[1543,1730,"Này, em chỉ đang cảm ơn thôi mà."],[1730,1864,"Này, bài này là hát cho tôi hay cho cô ấy?"],[1864,2027,"Chuyện gì vậy? - Cho cả hai mà!"],[2027,2089,"Sao anh lại"],[2089,2210,"nặng lời với cô ấy như thế?"],[2210,2277,"Cô ấy là bạn gái tôi."],[2277,2348,"Là người tôi đang hẹn hò."],[2348,2464,"Cô ấy mát-xa cho tôi."],[2464,2527,"Đó là"],[2527,2573,"anh biết đấy,"],[2573,2623,"Tôi không nói"],[2623,2806,"cô ấy là tài sản của tôi, nhưng,"],[2806,2923,"thôi nào, tôn trọng nhau chút đi."],[2923,3023,"Anh ấy chỉ là, anh biết đấy,"],[3023,3119,"người mua vui cho chúng ta thôi!"],[3119,3215,"Tôi tưởng cô ấy thích"],[3215,3332,"người đàn ông tinh tế."],[3332,3365,"Anh biết đấy,"],[3365,3461,"tôi tưởng cô ấy thích"],[3461,3620,"người biết thấu cảm."],[3620,3653,"Anh thì"],[3653,3824,"chẳng có vẻ gì là như thế cả."],[3899,3962,"Gì cơ?"],[4037,4120,"Anh nói đúng, tôi thích thế."],[4200,4250,"Thấy chưa?"],[4250,4375,"Anh nên tinh tế hơn đi, cưng à."],[4375,4471,"Cô ấy bảo anh nên"],[4471,4621,"tinh tế hơn đấy, cưng à."],[4683,4808,"Ôi trời ơi."],[4808,4967,"Đúng là một mối quan hệ độc hại."],[4967,5075,"Và tôi không muốn em"],[5075,5209,"phải chịu đựng điều đó."],[5209,5384,"Tên ngốc này nhạt nhẽo thật đấy."],[5384,5492,"Anh nghiêm túc đấy à?"],[5492,5555,"Suỵt"],[5555,5597,"Ừ,"],[5597,5780,"nhưng anh chàng này biết chơi guitar"],[5780,6118,"và hát hay, lại còn sùng đạo, nên là"],[6339,6423,"Tôi rất xin lỗi về anh ấy."],[6423,6493,"Anh ấy có"],[6493,6594,"anh ấy có chút vấn đề."],[6594,6752,"Thật nhảm nhí, tôi muốn xuống."],[6752,6802,"Ôi Chúa ơi."],[6802,6865,"Được rồi."],[6865,6961,"Bái bai. - Tôi muốn xuống."],[6961,7127,"Thật luôn!"],[7198,7319,"Ôi trời ơi, anh ấy dỗi rồi."],[7319,7424,"Anh ấy dỗi rồi."],[7424,7494,"Anh lại dỗi đấy à?"],[7494,7595,"Anh dỗi xong chưa?"],[7595,7670,"Rõ ràng là cô đang thử thách tôi."],[7670,7749,"Anh đang làm quá lên đấy."],[7749,7836,"Anh ấy đang làm quá lên."],[7836,8037,"Anh còn bài nào khác không?"],[8037,8174,"Hát bài khác đi."],[8174,8345,"Nhưng tôi"],[8433,8558,"Không thể"]],"94":[[20,179,"Chuyện gì sẽ xảy ra."],[246,325,"Tôi cũng nghĩ vậy."],[325,521,"Thôi nào, ra khỏi đây đi."],[521,654,"Cậu đang nói gì vậy?"],[654,792,"Đúng, tôi đã cho cô ấy mượn áo khoác."],[792,921,"Đúng, cô ấy đã hôn lên má tôi."],[921,1084,"Chúng tôi đã nói chuyện."],[1084,1180,"Emily. - Cô ấy đến rồi."],[1180,1422,"Ôi trời, xin chào."],[1422,1463,"Tôi nghe nói"],[1463,1764,"có chút hiểu lầm về"],[1785,1872,"những chuyện"],[1872,2006,"đã xảy ra hôm qua."],[2006,2239,"Và tôi luôn đứng về phe phụ nữ."],[2239,2314,"Tôi muốn đảm bảo"],[2314,2406,"cô sẽ được giải đáp"],[2406,2502,"mọi khúc mắc."],[2502,2606,"Được thôi."],[2606,2781,"Chúng ta có máy phát hiện nói dối."],[2781,2890,"Không thể nào, máy thật sao?"],[2890,2994,"Đúng vậy."],[2994,3294,"Những ai mà tôi đã phá đám,"],[3311,3495,"đều tự hại mình trước rồi."],[3495,3611,"Anh đã kể cho cô ấy"],[3611,3770,"về nụ hôn thứ hai lên má chưa?"],[3770,3883,"Còn nụ hôn nữa sao?"],[3987,4083,"Chà."],[4083,4141,"Hay thật đấy."],[4141,4441,"Nên nếu anh sẵn sàng."],[4471,4700,"Chắc chắn rồi, tôi không có gì phải giấu."],[4700,4825,"Ta bắt đầu được chứ?"]],"95":[[12,191,"Anh từng có nhiều mối quan hệ mập mờ."],[191,258,"Trời ạ."],[258,358,"Anh ta là trai hư à?"],[358,467,"Quan hệ mập mờ á?"],[467,550,"Trong đời anh thì đúng."],[550,650,"Kiểu chưa vượt qua"],[650,792,"ranh giới để chính thức quen nhau,"],[792,942,"nhưng thiên về kiểu"],[942,1038,"anh thích em"],[1038,1205,"và anh sẽ tiếp tục tán tỉnh,"],[1205,1505,"vì anh thích tận hưởng thời gian như thế."],[1530,1735,"Vâng, em không thích mập mờ."],[1735,1805,"Được thôi."],[1805,1872,"Nhìn cách"],[1872,2035,"cô ấy nhìn anh ta kìa."],[2035,2306,"Cô ấy chẳng bận tâm đến gã này."],[2306,2406,"Ánh mắt đó chẳng có chút tình ý nào."],[2406,2556,"Cô ấy chẳng có vấn đề gì."],[2556,2715,"Chỉ là cô ấy không thích anh ta."],[2715,2907,"Như em đã nói, em tiến triển khá chậm,"],[2907,2944,"nên"],[2944,3023,"kiểu như anh"],[3023,3324,"hoặc là toàn tâm toàn ý với em, hoặc thôi."],[3390,3453,"Chà, chúng ta luôn có thể"],[3453,3503,"nhượng bộ nhau mà."],[3503,3645,"Sao có tiếng bước chân nhỉ?"],[3645,3778,"Chào hai người. - Ôi trời."],[3858,4016,"Cô ấy trông vui vẻ quá."],[4016,4104,"Anh ta trông"],[4104,4258,"hoảng hồn trong tích tắc."],[4287,4375,"Cô lại đến xem chỉ tay cho tôi à?"],[4375,4508,"Tôi nghe ai đó nhắc"],[4508,4721,"về người xem chỉ tay."]],"96":[[29,283,"Tất cả những gì anh muốn là-"],[283,458,"Để anh nhảy cho em xem, cưng à."],[458,558,"Lại đây."],[558,671,"Thôi nào, anh bạn."],[671,784,"Anh biết hát không?"],[784,934,"Không, nhưng tôi biết nhảy."],[934,1084,"Bài này đâu phải để nhảy."],[1084,1188,"Không quan trọng chuyện đó."],[1188,1343,"Này, sao anh- - Nhảy đi nào."],[1343,1505,"Anh cần bình tĩnh lại."],[1593,1735,"Trời đất."],[1735,1797,"Bình tĩnh."],[1893,1997,"Bình tĩnh nào."],[2043,2218,"Reign có những lúc quá bốc đồng."],[2218,2289,"Và"],[2335,2610,"Điều đó thực sự rất mất điểm."],[2610,2706,"Nhưng rồi anh ấy lại đấu tranh vì tôi."],[2706,2827,"Lúc đó thì"],[2827,2907,"Cứ như một vòng lặp,"],[2907,3057,"nên tôi thực sự không biết nói sao,"],[3057,3128,"nhưng, đúng vậy,"],[3128,3319,"tôi không hề thích kiểu hành xử thất thường này"],[3319,3353,"một chút nào."],[3353,3415,"Thế nên"],[3453,3641,"Một phần trong tôi đang suy nghĩ lại."],[3641,3920,"Có lẽ Reign,"],[3920,3991,"không phải chàng Reigny bé bỏng của tôi?"],[3991,4041,"Eo ôi!"],[4041,4137,"Tôi không thích cách"],[4137,4216,"anh ta lôi kéo cô ấy."],[4216,4366,"Josip, vào can đi."],[4366,4487,"Ồ, để anh trổ tài cho em xem nhé, cưng."],[4671,4729,"Chà!"],[4729,4909,"Anh là kiểu người sẽ làm em hứng thú."],[4909,4988,"Thực ra-"],[4988,5050,"Anh nhảy hăng lắm."],[5050,5146,"Nhảy đi!"],[5384,5442,"Sao hả?"],[5442,5634,"Anh cần hít một hơi thật sâu đi."],[5634,5659,"Thấy chưa?"],[5659,5714,"Mày chán phèo, thằng ngốc."],[5714,5814,"Cút m* ra khỏi đây đi."],[5814,5893,"Anh ấy đang hát tặng"],[5893,5964,"tôi một bài rất hay mà."],[5964,6039,"Anh là diễn viên được thuê à? - Bình tĩnh đi."],[6039,6106,"Biến khỏi đây đi."],[6106,6252,"Anh cần bình tĩnh lại đi!"]],"97":[[16,333,"Anh từng trả tiền cho phụ nữ để"],[392,633,"quay nội dung 18+ cùng anh chưa?"],[905,984,"Ồ, hình như"],[1034,1084,"Đừng có - Mẹ tôi"],[1084,1130,"lảng chuyện... - đang gọi tôi."],[1130,1376,"Trả lời câu hỏi đi."],[1376,1468,"Người của tôi cần tôi."],[1468,1718,"Không, đừng nói vậy."],[1960,2093,"Có."],[2227,2293,"Sự thật."],[2293,2356,"Ừ."],[2356,2431,"Được rồi."],[2431,2485,"Anh ấy bảo có kìa."],[2485,2615,"Thấy chưa, tôi đã bảo"],[2615,2777,"anh ta giấu giếm nhiều lắm mà."],[2898,2998,"F**k."],[3082,3244,"Tôi nghe chưa rõ"],[3244,3361,"câu trả lời vừa rồi."],[3361,3716,"Anh từng trả tiền cho hàng hóa"],[3716,3887,"hay dịch vụ nào chưa?"],[3908,4037,"Và nếu có thì là bao nhiêu?"],[4058,4120,"Tôi chỉ muốn biết"],[4120,4204,"chúng ta đang đối phó với điều gì."],[4204,4325,"Hai đô la và 50 xu."],[4400,4608,"Chịu chi ghê!"],[4608,4688,"Cho việc gì?"],[4688,4754,"Anh ta luôn lảng tránh"],[4754,4854,"bằng một câu đùa hay gì đó."],[4854,4913,"Cô biết đấy."],[4913,5005,"Điên rồ thật nhỉ?"],[5025,5134,"Không, chuyện đó hẳn là-"],[5155,5176,"Được rồi."],[5176,5246,"Không, anh thậm chí còn chẳng biết"],[5246,5309,"chuyện gì đã xảy ra."]],"98":[[16,150,"Thầy bói xem chỉ tay!"],[150,221,"Ồ, wow."],[221,350,"Cầm lấy bàn tay đầy dầu của tôi đi."],[350,479,"Nói xem cô thấy gì nào?"],[508,654,"Tôi rất vinh hạnh."],[654,784,"Trông anh ấy có vẻ hoảng hốt"],[784,880,"trong chốc lát."],[880,996,"Tôi đến nói chuyện với anh"],[996,1213,"vì tôi không thích những gì mình thấy."],[1238,1301,"Đoạn nào cơ?"],[1301,1351,"Cái đoạn"],[1351,1505,"mà anh để cô gái"],[1505,1576,"anh đang hẹn hò"],[1576,1814,"chà xát khắp lưng anh."],[1847,1931,"Chuyện đó là sao?"],[1951,2122,"Đó là bối cảnh chuyên nghiệp,"],[2122,2189,"tôi đoán vậy."],[2189,2298,"Bối cảnh chuyên nghiệp á?"],[2298,2339,"Ừ."],[2339,2410,"Anh coi đây là"],[2410,2464,"bối cảnh chuyên nghiệp á?"],[2464,2565,"Dầu ở ngay đằng kia kìa."],[2565,2877,"Khi hoàn toàn để cho"],[2877,3044,"cảm xúc cá nhân của Jude,"],[3044,3244,"và 100% tình cảm"],[3244,3415,"chi phối, nhưng lại không có chiến lược"],[3415,3524,"đi kèm,"],[3524,3611,"tôi đã tự làm"],[3611,3745,"tổn thương chính mình, đúng không?"],[3745,3941,"Đó là việc nhìn nhận các mối quan hệ"],[3941,4162,"một cách có chiến lược hơn"],[4162,4275,"vào đúng thời điểm."],[4275,4366,"Mục đích của việc này là gì?"],[4366,4425,"Kiểu như"],[4425,4496,"Ý định của đối phương là gì,"],[4496,4571,"đại loại vậy."],[4571,4667,"Đó là lúc Jude lý trí"],[4667,4792,"đang cố gắng tập trung,"],[4792,5000,"và tìm hiểu ý định"],[5000,5180,"đằng sau mọi chuyện, ừ."],[5180,5280,"Cả hai chúng tôi đều bối rối!"],[5280,5417,"Và tôi chẳng hiểu chuyện gì đang xảy ra."],[5417,5588,"Chỉ là, tôi không biết nữa."],[5588,5663,"Đáng lẽ anh"],[5663,5818,"phải xoa lưng cho cô ấy,"],[5818,5910,"nên tôi không hiểu"],[5910,6010,"anh đang làm cái gì,"],[6010,6097,"khi để một cô gái khác"],[6097,6193,"đụng chạm khắp người anh trong buổi hẹn."],[6193,6364,"Cảm ơn vì đã lo cho tôi,"],[6364,6539,"nhưng thành thật mà nói,"],[6539,6652,"tôi biết đó là"],[6652,6740,"tôi biết"],[6740,6869,"vấn đề là do tôi,"],[6869,7027,"toàn lao vào những gã cứ tiếp tục"],[7027,7165,"chơi đùa với tình cảm của tôi."]],"99":[[41,204,"Hay là anh cứ thư giãn"],[204,379,"và nhảy đi,"],[379,629,"trong lúc anh ấy đàn."],[629,792,"Rồi tôi sẽ xem có muốn tiếp tục"],[792,913,"cho anh một cơ hội không."],[913,1063,"Để tôi xem anh nhảy nào."],[1063,1117,"Nhảy đi."],[1117,1167,"Nói thật nhé,"],[1167,1317,"chứng tỏ anh có thể trưởng thành đi."],[1317,1380,"Nhìn này, nhìn này."],[1380,1497,"Được thôi."],[1497,1568,"Đúng rồi."],[1568,1647,"Thấy chưa!"],[1689,1801,"Chà!"],[1918,2102,"Tôi là võ sĩ, diễn viên,"],[2122,2210,"nghệ sĩ võ thuật,"],[2256,2423,"vũ công,"],[2439,2581,"đôi khi là vũ công thoát y."],[2594,2665,"Ồ, nhìn kìa."],[2665,2731,"Bùm."],[2777,2852,"Bùm."],[2894,2961,"Bùm."],[3599,3749,"Trời ơi!"],[3828,4016,"Anh ta dẻo dã man!"],[4016,4104,"