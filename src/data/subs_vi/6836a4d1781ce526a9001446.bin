],[959,996,"Em thích"],[996,1084,"Em chưa được mát-xa đâu."],[1084,1267,"Một cô gái ngoan ngoãn hơn chút."],[1330,1472,"Và tay anh ấy cực kỳ khỏe."],[1472,1568,"Tay anh ta"],[1568,1730,"thật sự trông nhớp nháp quá."],[1730,1810,"Trông nhớp nháp sao?"],[1810,1872,"Là dầu đó, đồ ngốc."],[1872,1931,"Anh có thể sờ tay tôi."],[1931,2064,"Cảm giác rất tuyệt."],[2064,2268,"Anh ấy như chuyên gia vậy."],[2268,2373,"Thực ra tay anh tuyệt lắm."],[2373,2481,"Tay anh rất mềm."],[2481,2577,"Tôi biết mình đang làm gì."],[2577,2652,"Thấy chưa?"],[2652,2786,"Tay anh ấy mềm, không như anh."],[2786,2857,"Chà!"],[2882,2982,"Còn gồng cơ ngực"],[2982,3107,"khi mát-xa cho cô ấy nữa!"],[3107,3153,"Ôi trời,"],[3153,3307,"anh ấy thực sự biết cách làm."],[3307,3440,"Meghane, em có còn muốn"],[3440,3503,"cứu vãn chuyện này"],[3503,3582,"Mày đúng là đồ ẻo lả. - Đừng có mà"],[3582,3636,"Muốn thử không?"],[3636,3716,"Đúng rồi, mày ẻo lả lắm, nhóc."],[3716,3795,"Cút khỏi đây đi!"],[3795,3883,"Khoan, khoan đã."],[3883,3970,"Chuẩn đàn ông đấy."],[3970,4083,"Đó là điều em muốn sao?"],[4145,4287,"Ý tôi là, tôi không muốn thế."],[4287,4341,"Chà."],[4341,4471,"Tôi thà chọn ác quỷ còn hơn."]],"109":[[12,158,"Kể tôi nghe về mối quan hệ"],[158,287,"mà anh là người ngoại tình đi."],[462,642,"Đó là mối tình đầu của tôi."],[750,809,"Và"],[809,925,"Cô ấy học dưới tôi một lớp,"],[925,1055,"nên khi tôi"],[1055,1197,"tốt nghiệp cấp ba,"],[1247,1393,"và vào đại học,"],[1393,1601,"cô ấy mới lên năm cuối."],[1601,1672,"Ừ."],[1672,1972,"Đó là thời gian đầu tôi học đại học,"],[1972,2056,"ngày đầu tiên."],[2056,2189,"Và tôi gặp một cô gái"],[2189,2285,"rất, rất, rất, rất,"],[2285,2398,"rất, rất, rất, rất"],[2398,2464,"xinh đẹp."],[2519,2627,"Một tuần sau"],[2827,2907,"chúng tôi, ừ thì"],[3065,3165,"Chết tiệt, tệ thật."],[3278,3349,"Ừ, nhưng"],[3457,3511,"Tôi đã làm vậy."],[3528,3620,"Tôi đã"],[3707,3766,"làm điều"],[3766,3870,"mà tôi ước mình không làm."],[3953,4066,"Và rồi-"],[4066,4141,"Sao cô ấy phát hiện ra?"],[4233,4308,"Cô ấy không biết."],[4333,4375,"Ồ."],[4433,4542,"Nhưng giờ cô ấy sẽ biết."],[4542,4658,"Ừ, trên TV."],[4658,4867,"Anh từng cắm sừng ai chưa?"],[4867,4954,"Câu hỏi đó hơi"],[4954,5084,"Nhất là khi cô gái tôi"],[5084,5263,"đang tán tỉnh lại ngồi ngay cạnh."],[5263,5392,"Phải, và tôi sẽ không nói dối đâu."],[5392,5492,"Nên đương nhiên, kệ m* nó,"],[5492,5618,"tôi cứ nói sự thật thôi."],[5634,5789,"Đó là lý do anh lo lắng à?"],[5789,5843,"Ừ."],[5843,6014,"Tôi ít khi nói về chuyện này."],[6043,6143,"Tôi nghĩ thật dũng cảm"],[6143,6373,"khi tiết lộ điều đó với người"],[6373,6452,"mà chúng ta mới chỉ"],[6452,6556,"đang ở giai đoạn đầu,"],[6556,6619,"khi mà tôi có thể dễ dàng"],[6619,6756,"nói kiểu,"],[6756,6852,"Ồ,"],[6852,6911,"dừng lại thôi."],[6911,7027,"Bạn biết đấy, nhưng"],[7057,7311,"Nhưng anh ấy đã mở lòng như thế."],[7311,7390,"Và, bạn biết đấy,"],[7390,7557,"tôi nghĩ thế là rất can đảm."],[7557,7649,"Ừ, ý tôi là,"],[7649,7766,"tôi thấy mình đã trưởng thành"],[7766,7828,"và chín chắn hơn,"],[7828,7966,"cũng như học được nhiều từ sai lầm."],[7966,8058,"Nên việc tôi biết chắc mình"],[8058,8216,"sẽ không tái phạm nữa,"],[8216,8383,"vì tôi từng thấy rất tội lỗi,"],[8491,8579,"khiến tôi thấy thoải mái"],[8579,8646,"khi nói ra"],[8646,8750,"những chuyện kh*n nạn mình từng làm."],[8750,8883,"Điều tôi thực sự trân trọng,"],[8883,8988,"là anh ấy đã"],[8988,9121,"nhanh chóng thành thật."],[9150,9321,"Và tôi nghĩ cũng một phần"],[9321,9455,"vì anh ấy biết mình đang"],[9455,9622,"bạn biết đấy, sẽ bị phát hiện. Nhưng"],[9622,9809,"Em muốn hỏi,"],[9809,10001,"em hôn giỏi hơn người yêu cũ anh không?"],[10035,10172,"Cô ấy muốn được hôn kìa."],[10172,10256,"Ừ, nhìn kìa!"],[10256,10397,"Cô ấy muốn được hôn!"],[10397,10460,"Tới luôn."],[10460,10560,"Trời ơi, tôi không dám nhìn."],[10560,10639,"Anh ấy sẽ hôn cô ấy chứ?"],[10639,10756,"Chắc chắn rồi. -Phải thế chứ."]],"110":[[4,141,"Đây là cơ hội để anh nói"],[141,271,"điều anh cần nói đấy."],[271,412,"Nãy giờ anh vẫn luôn cố đây."],[412,542,"Vậy thì nói đi, làm ơn."],[542,592,"Về chuyện gì?"],[592,692,"Ý anh là, có,"],[692,763,"có quá nhiều chuyện."],[763,821,"Anh thậm chí không biết,"],[821,871,"anh còn chẳng biết"],[871,938,"phải chọn sao nữa."],[938,1042,"Anh ta không biết liệu mình nên"],[1042,1159,"chọn cô hay Emily."],[1159,1205,"Anh biết. -Anh ta không biết"],[1205,1255,"Anh biết. -phải chọn gì."],[1255,1288,"Anh biết. -Ý tôi là,"],[1288,1380,"Anh ta chẳng biết chọn cái gì cả."],[1380,1463,"Anh ta quá thiếu quyết đoán."],[1463,1530,"Không, anh có biết-"],[1530,1668,"Cô có muốn một kẻ thiếu quyết đoán không?"],[1676,1772,"Ồ, tôi nghĩ cô ấy đang cố-"],[1864,1985,"Tôi nghĩ cô ấy đang cố ghép đôi"],[1985,2056,"cô ấy với cậu đấy, Chris."],[2056,2122,"Từ từ đã nào."],[2122,2273,"Cô ấy bảo có một ứng viên tuyệt vời"],[2273,2456,"vừa mới độc thân."],[2456,2556,"Chuyện gì vừa xảy ra vậy?"],[2556,2610,"Paul, xử cậu ta đi."],[2610,2702,"Rõ rồi."],[2790,2932,"Lên nào Wonder Bread."],[2965,3069,"Vì cá nhân tôi thì không đâu."],[3069,3178,"Anh đã chọn rồi."],[3178,3299,"Tôi chỉ lo cho cô thôi, cưng à."],[3299,3407,"Và tôi biết,"],[3407,3503,"có một người ở trên kia"],[3503,3724,"rất dứt khoát muốn chọn cô."],[3724,3778,"Anh chọn rồi."],[3778,3899,"Tôi nghĩ cô nên đi theo tôi."],[3899,3937,"Anh đã chọn-"],[3937,4087,"Và cô nên đi gặp anh ấy."],[4291,4441,"Tôi nghĩ cô nên đi cùng tôi."],[4517,4667,"Jude, nói gì đi chứ."],[4667,4721,"Anh chọn rồi."],[4721,4829,"Thế là sao?"],[4829,4984,"Anh vừa bảo cần phải suy nghĩ"],[5105,5196,"Về việc liệu em có định"],[5196,5355,"đi với người đàn ông khác không."],[5355,5430,"Thế thì có gì"],[5430,5501,"khác biệt chứ?"],[5501,5630,"Người anh em à."],[5705,5822,"Chuyện gì thế này?"]],"111":[[8,141,"Khoan, vậy đây là điều anh muốn sao?"],[141,279,"Ý tôi là, tôi không muốn thế, nên"],[279,362,"Cảm giác sướng thật."],[362,496,"Khoan, ý anh là sao?"],[496,575,"Tôi chịu đủ rồi."],[575,650,"Vậy, khoan đã,"],[650,738,"vậy anh có nên"],[738,934,"Tôi mặc kệ anh làm gì."],[934,1038,"Tôi sẽ đợi anh trên lầu."],[1038,1109,"Tôi chán trò này rồi."],[1109,1267,"Mối quan hệ này mới chớm thôi."],[1267,1338,"Tôi dừng lại đây."],[1338,1397,"Khoan đã."],[1609,1701,"Thấy sao hả, Cưng?"],[1701,1793,"Tuyệt vời lắm."],[1793,1897,"Anh thích em gọi là Cưng hả?"],[1897,2043,"Chắc rồi, em muốn gọi sao cũng được,"],[2043,2198,"cứ tiếp tục xoa bóp chân anh thế đi."],[2198,2352,"Đây là trò đùa à?"],[2373,2494,"Hôm qua anh vừa gọi tôi là Cưng đấy."],[2494,2556,"Ừ, nhưng cô"],[2556,2706,"Mới có 24 tiếng trôi qua thôi."],[2748,2790,"Khoan,"],[2790,2861,"vậy chuyện này thực sự"],[2861,2927,"chuyện gì đang diễn ra thế này?"],[2927,3053,"Cô ấy là tình mới của tôi."],[3182,3228,"Vậy,"],[3228,3345,"đây là, đây là"],[3345,3424,"đây là thứ anh thích sao?"],[3424,3503,"Anh có chỗ nào,"],[3557,3695,"cần được chăm sóc nữa không?"],[3695,3832,"Gì cơ?"],[3832,3924,"Quanh cổ anh."],[3924,3966,"Cổ anh á?"],[3966,4012,"Cổ anh"],[4012,4112,"Khoan, vậy, đây là"],[4145,4283,"Tôi có nên đi không?"],[4283,4341,"Tôi đi nhé?"],[4341,4437,"Tôi nên đi chứ?"],[4437,4496,"Anh muốn tôi đi sao?"],[4496,4604,"Tôi bảo cô đi đi."],[4604,4829,"Đi tìm gã có đôi tay mềm mại đó đi."],[4829,4896,"Biết gì không... - Tạm biệt."],[4896,5038,"Anh ta còn nam tính hơn anh đấy."],[5038,5196,"Khoan, vậy đây là điều cô muốn sao?"],[5196,5280,"Tôi biết giá trị của mình."],[5280,5397,"Thế thì cút m* khỏi đây đi."],[5397,5630,"Tôi nghĩ anh ta chỉ đang hoang mang và lạc lối."],[5630,5818,"Anh ta vẫn là một đứa trẻ."],[5818,5955,"Đúng hơn là một đứa trẻ to xác."],[5955,6035,"Chà."],[6035,6139,"Tôi biết giá trị của mình."],[6139,6285,"Cô biết không, tôi cũng vậy."],[6285,6398,"Mà này, Noel đâu rồi?"],[6398,6448,"Noel!"],[6448,6506,"Cút khỏi đây đi!"],[6506,6619,"Khoan, Meghane, quay lại đi."],[6619,6740,"Cô có muốn thấy anh ta làm"],[6740,6835,"bài kiểm tra nói dối không?"],[6835,6940,"Cô có muốn xem... - Gì cơ?"],[6940,7065,"liệu ta có thể hỏi anh ta vài câu không."],[7065,7123,"Sao lại là tôi?"],[7123,7207,"Còn cô ta thì sao?"]],"112":[[41,129,"Vậy, Autumn,"],[129,196,"em có muốn hẹn hò"],[196,296,"với anh lần nữa không?"],[554,717,"Ừm"],[905,980,"Từ chối đi, Autumn."],[980,1059,"Cứ nói không đi!"],[1059,1188,"Kiên định lên nào."],[1188,1267,"Mạnh mẽ lên! - Thôi nào, em."],[1267,1368,"Cô ấy không muốn. - Cứng cỏi lên!"],[1368,1484,"Cô ấy không muốn mà."],[1484,1626,"Trưởng thành lên đi."],[1935,2035,"Một lần nữa thôi."],[2035,2147,"Cô ấy lại vừa bảo 'một lần nữa'."],[2147,2369,"Lần trước cậu cũng nói vậy rồi mà."],[2369,2498,"Còn định bao nhiêu lần nữa đây?"],[2565,2790,"Nhưng tôi không thích những gì mình nghe."],[2790,2882,"Và,"],[2965,3107,"điều đó khá là tồi tệ."],[3153,3282,"Nên là, ừ,"],[3282,3428,"đó có thể là cờ đỏ,"],[3428,3582,"bạn biết đấy, vì ta không thể chắc chắn."],[3582,3732,"Ông bà có câu,"],[3732,3791,"một lần ngoại tình,"],[3791,3866,"mãi mãi ngoại tình."],[3866,3953,"Tôi chưa từng ngoại tình."],[3953,4166,"Nên tôi dám khẳng định vậy."],[4166,4371,"Và tôi sẵn sàng chứng minh điều đó"],[4371,4567,"bằng máy phát hiện nói dối."],[4567,4654,"Thế là quá nhiều 'một lần' rồi đấy."],[4654,4763,"Cô ấy rõ ràng đã nói,"],[4763,4875,"đây là cơ hội cuối cùng."],[4875,5000,"Đó là cơ hội cuối rồi."],[5000,5138,"Tôi muốn có cơ hội đưa cô ấy đi hẹn hò"],[5138,5184,"và cho cô ấy thấy"],[5184,5263,"một người đàn ông đích thực"],[5263,5347,"sẽ đối xử với cô ấy ra sao."],[5347,5417,"Nói thật thì,"],[5417,5509,"đó có lẽ là"],[5509,5630,"buổi hẹn hò gượng gạo nhất"],[5630,5864,"tôi từng chứng kiến trong đời."]],"113":[[8,191,"Tôi luôn phải lo cho anh em mà."],[258,383,"Bây giờ hoặc không bao giờ. - Cảm ơn người anh em."],[383,467,"Và tôi biết mình có thể"],[467,638,"Tôi thực sự chỉ muốn cho Jude"],[638,888,"một cơ hội để nói gì đó."],[888,1051,"Ý tôi là, anh có nghĩ ra"],[1051,1151,"điều gì để nói không? - Anh có một cơ hội đấy."],[1151,1238,"Và nếu anh không thể"],[1238,1351,"làm gì để đổi ý cô ấy,"],[1351,1459,"tôi sẽ lên lầu với cô ấy ngay bây giờ."],[1459,1626,"Hãy nhìn người phụ nữ xinh đẹp này,"],[1626,1780,"và nói cho cô ấy cảm giác thật của anh đi."],[1847,2218,"Nên cô ấy nói anh đã không dứt khoát"],[2218,2402,"khi phải đứng giữa"],[2402,2552,"người phụ nữ đến đây,"],[2552,2694,"bắt đầu mát-xa lưng cho anh,"],[2694,2765,"và em."],[2861,2961,"Anh bảo anh cần phải suy nghĩ."],[2961,3082,"Cô ấy bắt đầu tra khảo anh"],[3082,3224,"sau khi anh nói từ suy nghĩ."],[3224,3311,"Em cũng phải suy nghĩ về việc"],[3311,3390,"đi với chàng trai khác mà."],[3390,3503,"Anh phải suy nghĩ về"],[3503,3607,"hoàn cảnh đó, đúng chứ?"],[3607,3670,"Chúng ta chưa biết"],[3670,3774,"nhau quá lâu."],[3920,4124,"Nhưng anh vẫn chọn."],[4145,4295,"Chúng ta vẫn ở đây cùng nhau."],[4341,4400,"Và anh không biết"],[4400,4508,"họ từ đâu chui ra."],[4525,4650,"Cô gái kia bước vào,"],[4650,4779,"rồi Patches bước vào,"],[4779,4875,"rồi tất cả mọi người đều vào."],[4875,4984,"Thế là làm"],[4984,5084,"lu mờ lý trí,"],[5084,5180,"và đổ thêm dầu vào lửa,"],[5180,5246,"làm mọi thứ rối tung lên,"],[5246,5447,"và khiến chúng ta thêm bối rối."],[5447,5538,"Chà,"],[5538,5693,"Tôi sẽ lên lầu,"],[5693,5801,"nơi người đàn ông trong mộng của cô"],[5801,5893,"mà tôi biết đang đứng đợi."],[5893,6085,"Em nghĩ chúng ta cần nói rõ mọi chuyện."],[6143,6231,"Em không cần ai đó"],[6231,6360,"đưa ra quyết định thay em."],[6360,6539,"Em nghĩ em chỉ muốn"],[6539,6635,"Em không biết nữa."],[6635,6744,"Chúng ta có thể tiếp tục"],[6744,6886,"xem chuyện này đi tới đâu không?"],[6886,6990,"Và giờ, sau khi"],[6990,7090,"mọi chuyện đã xảy ra"],[7290,7553,"thấy bối rối, em biết đấy, bối rối."],[7553,7670,"Lại về vạch xuất phát."],[7670,7778,"Này, vậy"],[7957,8229,"Em cảm thấy thế nào sau mọi chuyện?"],[8370,8500,"Em thấy bối rối."]],"114":[[16,116,"Reign, anh có buồn vì"],[116,258,"chuyện xảy ra hôm qua không?"],[283,396,"Khoan, gì cơ?"],[454,529,"Anh biết đấy,"],[529,604,"với mọi chuyện đã xảy ra,"],[604,784,"anh đã ra ngoài khóc."],[784,984,"Anh đã ra ngoài khóc mà."],[984,1059,"Lau người đi."],[1059,1151,"Đúng, bọn tôi cần xem cơ ngực."],[1151,1418,"Bọn tôi cần thấy rõ cơ ngực chuyển động."],[1718,1805,"Rất đúng lúc."],[1805,1881,"Thật điên rồ."],[2072,2152,"Một chút thôi."],[2243,2369,"Đó là sự thật."],[2406,2460,"Anh có thấy"],[2460,2565,"Meghane hấp dẫn không?"],[2673,2740,"Có."],[2861,2919,"Sự thật."],[3023,3094,"Lúc mới"],[3094,3186,"được ghép đôi với Meghane,"],[3186,3311,"anh có hào hứng không?"],[3511,3607,"Hơi lo lắng một chút."],[3653,3732,"Aww."],[3753,3862,"Đó cũng là sự thật."],[3899,4095,"Tôi kiểu, ý là, cô ấy trông điên điên."],[4095,4191,"Cô ấy dễ thương,"],[4191,4337,"nhưng trông cô ấy như"],[4337,4421,"Em nhìn là biết."],[4421,4542,"Em rất giỏi đọc vị người khác."],[4542,4688,"Tôi cũng thế, thưa ngài."],[4688,4829,"Tôi nói thật chứ?"],[4829,4896,"Phải không?"],[4925,5005,"Sự thật."],[5038,5113,"Khoan đã."],[5113,5255,"Phần nào là sự thật?"],[5309,5426,"Anh nghĩ em bị điên."],[5426,5488,"Nhưng em dễ thương"],[5488,5576,"nên làm gì cũng được cho qua."],[5576,5714,"Anh cá em có giết người cũng thoát tội."],[5714,5818,"Vậy tiếp tục nào."],[5818,5885,"Reign,"],[5885,6081,"anh sẽ cưới Meghane chứ?"],[6414,6485,"Ý tôi là,"],[6485,6560,"cô ấy chẳng có gì nhiều"],[6560,6781,"để chu cấp hay mang lại cho tôi, nên"],[6781,6886,"Gì cơ?"],[6886,6940,"Ý anh là sao,"],[6940,7027,"tôi không có gì nhiều để chu cấp"],[7027,7094,"hay mang lại cho anh?"],[7094,7161,"Anh có gì để chu cấp"],[7161,7265,"và mang lại cho tôi?"],[7265,7453,"Anh có gì mang lại cho tôi?"],[7515,7670,"Anh đem lại giá trị gì cho đời tôi,"],[7670,7732,"hả Reign?"],[7732,7899,"Ý tôi là, tôi có nhiều thứ mang lại mà."],[7899,8041,"Thôi nào, rõ ràng là cô biết-"],[8041,8158,"Rõ ràng là không."],[8158,8291,"Reign, anh có mang lại được nhiều thứ không?"],[8312,8450,"Tôi có rất nhiều thứ để mang lại."]],"115":[[0,175,"Anh hôn giỏi hơn người yêu cũ của em chứ?"],[175,271,"Dễ ợt."],[316,375,"Dễ-"],[375,450,"Dễ gì chứ?"],[450,588,"Đáng lẽ họ nên hôn từ lâu rồi."],[588,721,"Hôn đại cho rồi."],[721,838,"Họ hút nhau quá chừng."],[838,905,"Tôi chẳng hiểu"],[905,992,"sao họ không hôn luôn đi."],[992,1059,"Dễ ợt"],[1121,1197,"Dễ gì cơ?"],[1197,1330,"Thôi nào, họ cứ vờn nhau mãi."],[1393,1551,"Họ cứ chơi trò này mãi."],[1551,1701,"Trả lời đi."],[1701,1818,"Dễ ợt gì... đúng là"],[1889,2139,"Họ cứ xích lại ngày càng gần."],[2139,2298,"Kiểu, sao họ không khóa môi luôn đi?"],[2469,2544,"Anh á?"],[2694,2761,"Anh đoán, ờ"],[2919,2990,"anh đoán chắc ta phải,"],[2990,3119,"chắc ta phải thử lại rồi."],[3178,3294,"Cô ấy đang tạo mọi cơ hội cho hắn."],[3294,3349,"Trời đất ơi."],[3349,3470,"Họ xích lại rồi kìa."],[3470,3653,"Triển luôn đi!"],[3853,3958,"Lại đây."],[3958,4074,"Ồ!"],[4145,4241,"Thế chứ!"],[4241,4354,"Biết ngay mà!"],[4537,4633,"Trời đất ơi!"],[4633,4696,"Đá lưỡi kìa."],[4696,4859,"Á, đá lưỡi quá trời luôn!"],[4859,5013,"Đá lưỡi quá trời luôn!"],[5492,5613,"Việc chúng ta đến với nhau"],[5613,5705,"và nghĩ rằng, em biết đó,"],[5705,5805,"ta thậm chí có thể kết nối"],[5805,5897,"sâu sắc đến vậy,"],[5897,5980,"mặc dù xuất thân từ"],[5980,6156,"những hoàn cảnh quá khác biệt,"],[6156,6293,"anh thấy thật sự rất tuyệt."],[6293,6414,"Vậy nên"],[6602,6902,"Em có nghĩ đến buổi hẹn thứ ba không?"],[6902,7115,"Tốt nhất là có mặc quần áo."],[7165,7461,"Để em suy nghĩ đã."],[7490,7574,"Có chứ."],[7674,7836,"Họ sắp có buổi hẹn thứ ba kìa."],[7895,8103,"Đương nhiên rồi."],[8149,8274,"Anh rất mong chờ đấy."],[8312,8425,"Nếu ta có thể vượt qua quá khứ,"],[8425,8641,"vượt qua những gánh nặng và"],[8641,8846,"dối trá lẫn chuyện ngoại tình khi xưa,"],[8846,8992,"thì đương nhiên, điều đó sẽ chỉ"],[8992,9084,"giúp chúng ta mạnh mẽ hơn thôi."],[9225,9359,"Tắt máy quay đi được không?"],[9488,9542,"Cắt!"],[9542,9726,"Thật vui khi được cười cùng em."],[9726,9805,"Đút cho nhau ăn"],[9805,9976,"chỉ bằng tay không."],[9976,10214,"Đừng có vào đây."],[10243,10326,"Chào."]],"116":[[41,225,"Em đang thấy bối rối"],[225,279,"về chuyện gì sao?"],[358,425,"Anh biết đó, mọi người"],[425,546