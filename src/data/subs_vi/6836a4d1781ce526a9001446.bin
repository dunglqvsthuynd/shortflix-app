hơn."],[5910,5980,"Ồ, tốt thôi."],[5980,6114,"Chà, em không phải trả tiền cho vụ này đâu."],[6177,6277,"Ít nhất là đắt hơn"],[6277,6435,"hai đô la mười lăm xu."],[6435,6685,"Cô ấy thích kiểu điên rồ của anh ta."],[6685,6760,"Anh vô-"],[6760,6840,"Anh đáng giá cả triệu đô đấy, cưng à."],[6840,6911,"Anh là vô giá."],[6911,7073,"Cảm ơn em, cảm ơn em."],[7073,7148,"Chúng tôi nói về mọi"],[7148,7315,"điều tốt lành, nhiệt huyết trong đời,"],[7315,7390,"rồi sau đó,"],[7390,7428,"bạn biết đấy,"],[7428,7745,"chúng tôi cứ gác lại những thứ kiểu như,"],[7745,7916,"không biết nữa, những thứ phức tạp hơn"],[7916,7995,"để bàn sau,"],[7995,8095,"vì chúng tôi cứ mải mê"],[8095,8174,"nói về mọi thứ tốt đẹp."],[8229,8375,"Kể em nghe về mối quan hệ đó đi,"],[8375,8504,"chuyện mà anh là người ngoại tình ấy."]],"104":[[16,141,"Vì anh không định"],[141,329,"đáng mặt đàn ông mà mát-xa cho cô ấy"],[367,525,"Tôi đã ngỏ ý ngay từ đầu rồi."],[525,629,"Em thấy mát-xa thế này được chứ?"],[629,696,"Và em đang-"],[696,763,"Dễ chịu lắm."],[763,917,"Nhưng em vẫn rất bối rối,"],[917,996,"lúc này."],[996,1117,"Em cực kỳ bối rối-"],[1117,1217,"Không hiểu chuyện gì đang xảy ra nữa."],[1297,1430,"Tôi thì không."],[1430,1555,"Anh cần giao tiếp bằng mắt."],[1555,1626,"Anh ta cần thế."],[1626,1730,"Tôi giao tiếp bằng mắt rất tốt."],[1730,1914,"Anh ta muốn được chú ý."],[1914,2002,"Mục đích của anh là gì"],[2002,2060,"khi xuống đây?"],[2060,2122,"Có phải để-"],[2122,2285,"Mục đích của tôi là-"],[2285,2360,"Anh định nẫng tay trên-"],[2360,2477,"Vạch trần sự thật rằng,"],[2477,2552,"Ý tôi là, tôi có thể."],[2552,2623,"Anh là một kẻ dối trá."],[2623,2723,"Tôi có thể cướp cô ấy khỏi tay anh"],[2723,2823,"nếu em muốn."],[2823,2927,"Và tôi tin chắc"],[2927,2969,"mình chẳng gặp"],[2969,3073,"khó khăn gì để làm việc đó,"],[3073,3194,"nhất là khi"],[3194,3332,"anh còn không thèm mát-xa cho cô ấy."],[3332,3495,"Anh để gái khác đụng chạm vào mình,"],[3495,3599,"còn anh thì dối trá."],[3599,3741,"Giờ em thực sự bối rối