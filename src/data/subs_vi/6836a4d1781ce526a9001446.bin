."],[4625,4788,"Ôi trời ơi,"],[4788,4909,"không phải chăn lông chứ. Đúng không?"],[4909,5030,"Đúng không? Em cảm giác"],[5030,5109,"chúng ta càng lúc"],[5109,5251,"càng lãng mạn hơn."],[5376,5447,"Anh có lên giường không?"],[5447,5518,"Anh lên đây."],[5518,5597,"Em đùa à?"],[5597,5684,"Anh không thể, anh sẽ không"],[5684,5801,"nhìn thấy giường mà lại"],[5930,6110,"hoàn toàn ngó lơ nó đâu."],[6110,6339,"Tôi có giả thuyết về buổi hẹn của họ."],[6339,6623,"Tôi nghĩ Olivia là một"],[6623,6815,"cô gái mang năng lượng mèo đen mạnh mẽ."],[6815,6865,"Và cô ấy"],[6865,7190,"cần một người đàn ông mạnh mẽ tương xứng."],[7190,7257,"Như một con hổ."],[7257,7394,"Còn Jude lại là một"],[7394,7449,"anh chàng siêu, siêu,"],[7449,7549,"siêu ngọt ngào."],[7549,7836,"Vậy em nghĩ sao về buổi hẹn"],[7836,7932,"hôm qua so với"],[7932,8041,"buổi hẹn đầu tiên?"],[8041,8116,"Ừm"],[8116,8233,"Cô ấy không thích đâu."],[8233,8329,"Chuyện gì thế?"],[8329,8454,"Anh ấy hỏi cô ấy nghĩ sao"],[8454,8529,"về buổi hẹn,"],[8529,8654,"và cô ấy biểu cảm kiểu như."]],"124":[[41,125,"Okay, chúng ta vào nào!"],[125,287,"Dừng hết lại đi."],[287,417,"Ồ wow!"],[508,621,"Hai người ơi!"],[621,746,"Tôi mê trang phục của họ quá."],[746,825,"Ôi, chiếc váy đẹp quá đi."],[825,980,"Trông cứ như kiểu"],[980,1146,"ông bà Smith vậy."],[1146,1284,"Họ đang yêu đấy. Chắc chắn luôn."],[1284,1455,"Vậy anh thấy thế nào"],[1455,1664,"từ buổi hẹn trước?"],[1664,1839,"Ừ, ấm áp hơn nhiều."],[1839,1976,"Nhưng cổ anh thấy tuyệt lắm."],[1976,2014,"Cảm ơn em nhé."],[2014,2173,"Thật á? F**k yeah! - Ừ!"],[2173,2260,"Cảm giác rất tuyệt."],[2260,2318,"Tuyệt, biết đâu đấy,"],[2318,2456,"em sẽ làm thợ mát-xa."],[2456,2686,"Ồ, anh làm khách ruột của em nhé?"],[2686,2811,"Anh biết gì không?"],[2811,2848,"Anh thậm chí"],[2848,2894,"không cần trả tiền đâu."],[3015,3103,"Em sẽ làm miễn phí."],[3103,3190,"Anh thích thế."],[3190,3395,"Ngược lại, anh sẽ trả tiền cho em."],[3395,3616,"Ha ha."],[3616,3720,"Ồ, anh sao rồi?"],[3720,3795,"Rất ổn."],[3795,3866,"Hôm qua thế nào?"],[3866,3987,"Có quá... ờ"],[4087,4371,"Anh từng trả tiền mua dịch vụ chưa?"],[4371,4500,"Anh từng ngoại tình chưa?"],[4500,4625,"Có,"],[4625,4738,"đáng buồn là vậy."],[4738,4929,"Những 12 năm!?"]],"125":[[154,333,"Ồ, chà."],[333,546,"Đẹp quá! - Hoa sao?"],[546,729,"Anh ấy tán tỉnh cô ấy bằng hoa à?"],[729,867,"Làm tốt lắm Sherif."],[867,996,"Đẹp quá."],[996,1167,"Trời ơi."],[1167,1451,"Lãng mạn quá. - Chà, em biết."],[1451,1689,"Anh mua hoa cho em này."],[1689,1801,"Cảm ơn anh."],[1801,1976,"Anh thật ngọt ngào."],[2110,2160,"Lạ thật."],[2160,2323,"Và còn thơm nữa."],[2323,2469,"Ừ, thơm lắm."],[2469,2581,"Có thơm bằng em không?"],[2581,2840,"Á, thôi đi!"],[2952,3053,"Thế này chắc chắn là bù đắp"],[3053,3257,"cho ngày hôm qua rồi."],[3257,3411,"Hôm qua em bị leo cây,"],[3411,3436,"và em"],[3436,3520,"đã cảm thấy"],[3520,3570,"khá hụt hẫng. - Bởi vì anh"],[3570,3661,"đã bị tai nạn mà."],[3661,3799,"Anh đã kể cho cô ấy nghe"],[3799,3937,"về nụ hôn má thứ hai chưa?"],[3937,4116,"Còn nụ hôn nữa sao?"],[4116,4262,"Vậy là không chỉ có"],[4262,4383,"một nụ hôn, mà là hai."],[4383,4533,"Và cô ta còn ngồi lên đùi anh."],[4533,4629,"Và anh cứ thế,"],[4629,4754,"để mặc chuyện đó xảy ra à?"],[4754,4833,"Thì, anh chỉ cảm thấy,"],[4833,4921,"em biết đấy, em đã trải qua"],[4921,5055,"rất nhiều chuyện trong tuần này"],[5055,5176,"cả về thể chất lẫn tinh thần."],[5176,5326,"Và anh thấy em đã chứng tỏ được"],[5326,5442,"mình là một người phụ nữ"],[5442,5526,"mạnh mẽ và xinh đẹp nhường nào."],[5526,5563,"Nên anh chỉ"],[5563,5638,"thực sự muốn bày tỏ"],[5638,5997,"sự trân trọng, tình cảm"],[5997,6056,"và cho em thấy những gì"],[6056,6168,"em xứng đáng được nhận."],[6181,6297,"Cảm ơn anh."],[6306,6364,"Anh hy vọng có thể"],[6364,6564,"làm lại từ đầu,"],[6564,6614,"và có một,"],[6614,6765,"khởi đầu suôn sẻ hơn lần này."],[6765,6865,"Anh cảm thấy,"],[6865,6969,"có quá nhiều chuyện cản bước"],[6969,7086,"chúng ta, khiến ta chưa thực sự"],[7086,7244,"có cơ hội để kết nối."],[7244,7449,"Nên anh rất kỳ vọng."],[7449,7532,"Anh đang rất mong"],[7532,7615,"có cơ hội để"],[7615,7703,"tìm hiểu"],[7703,7849,"em nhiều hơn và tiếp tục"],[7849,7899,"xem chặng đường này"],[7899,7987,"sẽ đưa chúng ta đến đâu."],[8124,8254,"Em cũng vậy."],[8254,8316,"Biết đâu đôi ta lại"],[8316,8425,"nảy sinh tình cảm thì sao."],[8425,8491,"Nên cứ chờ xem"],[8491,8629,"chuyện gì sẽ đến."],[8629,8746,"Có vẻ như chúng ta có"],[8746,8858,"vài tấm thẻ ở đây."],[8858,8938,"Ồ, chà."],[8938,9025,"Sẽ thú vị lắm đây."],[9025,9138,"Được rồi."],[9138,9263,"Tình yêu."],[9263,9342,"Đúng rồi,"],[9342,9638,"chủ đề trò chuyện"],[9638,9793,"trong tối nay."]],"126":[[12,150,"Ba."],[150,304,"Hai."],[304,450,"Một."],[725,896,"Cởi trần kìa!"],[896,1030,"Anh ta cởi đồ sẵn luôn."],[1205,1251,"Em thấy sao?"],[1251,1430,"Đáng yêu đó!"],[1430,1451,"Ừ."],[1451,1509,"Anh đang cố cho em thấy"],[1509,1593,"sự dịu dàng của anh."],[1593,1685,"Em hiểu ý anh chứ?"],[1685,1856,"Ồ, anh cũng biết dịu dàng sao?"],[1856,1943,"Có chứ."],[1943,1989,"Thật khó tin."],[1989,2160,"Anh đã muốn làm thế này."],[2160,2327,"Nằm xuống đi."],[2327,2519,"Anh chuẩn bị từ lúc nào thế?"],[2519,2681,"Trước khi em tới."],[2681,2827,"Vì em đến trễ mà."],[2827,3032,"Anh ấy làm như tự tay mình chuẩn bị vậy."],[3032,3161,"Vậy điều gì khiến anh - Ồ."],[3161,3457,"thay đổi tâm ý thế?"],[3457,3503,"Reign,"],[3503,3599,"anh có nghĩ Meghane là"],[3599,3712,"chân ái của mình không?"],[3712,3795,"Chân ái của tôi ư?"],[3795,3870,"Không!"],[3870,3987,"Chỉ là anh"],[3987,4158,"tối qua không ngủ được."],[4158,4362,"Chỉ nghĩ ngợi lung tung và"],[4362,4537,"Còn em thì ngủ cực kỳ ngon."],[4558,4637,"Tất nhiên rồi, vì... - Anh đã"],[4637,4721,"nghĩ về chuyện gì?"],[4721,4783,"Có lẽ anh đã"],[4783,4850,"có vài thứ"],[4850,4938,"anh cần phải sửa đổi,"],[4938,5063,"kiểu như là anh"],[5063,5167,"hơi quá nóng nảy."],[5167,5217,"Tại sao anh"],[5217,5309,"vẫn cứ hành xử như vậy chứ?"],[5422,5543,"Quá dễ nổi cáu."],[5543,5701,"Là anh bày ra à!"],[5701,5759,"Ai chuẩn bị việc này vậy?"],[5847,5914,"Em biết đấy,"],[5914,6068,"anh đã cô đơn quá lâu rồi,"],[6068,6164,"anh hoàn toàn có thể"],[6164,6210,"sống mà không có"],[6210,6281,"thị phi, nhưng mà,"],[6281,6343,"anh không muốn"],[6343,6410,"đánh mất đi thứ"],[6410,6510,"khiến anh cảm thấy được sống,"],[6510,6569,"em hiểu ý anh chứ?"],[6569,6635,"Nhưng nếu anh"],[6635,6760,"chịu thay đổi một chút,"],[6760,6952,"em có sẵn lòng làm vậy không?"],[6952,7044,"Thể hiện chút tình cảm với anh đi."],[7044,7152,"Kiểu như là,"],[7152,7253,"hãy lắng nghe anh"],[7253,7386,"khi anh cần."]],"127":[[29,100,"Ừm"],[100,296,"Ngoài"],[296,462,"những lần bị làm phiền ra, ừm"],[588,888,"tôi là người thiếu quyết đoán,"],[888,975,"tôi hay"],[975,1105,"đắn đo quá nhiều."],[1105,1238,"Tôi nghĩ mọi chuyện kết thúc"],[1238,1451,"đúng như tôi mong muốn, nên"],[1451,1526,"Thật sao?"],[1526,1664,"Hy vọng mọi chuyện sẽ"],[1664,1789,"tiếp tục tiến triển như vậy"],[1789,1830,"và chúng ta không"],[1830,2006,"bị phá bĩnh nữa."],[2043,2081,"Thật á?"],[2081,2122,"Cô ấy nói là"],[2122,2235,"kết thúc đúng như cổ mong đợi."],[2235,2344,"Thành thật mà nói, tôi không nghĩ"],[2344,2389,"mọi chuyện đã kết thúc"],[2389,2544,"tốt đẹp đến vậy đâu."],[2544,2602,"Ý tôi là, đã có"],[2602,2765,"rất nhiều chuyện xao nhãng."],[2765,2898,"Cậu sao rồi?"],[2898,3065,"Thầy xem chỉ tay kìa!"],[3094,3257,"Người anh em."],[3257,3395,"Anh bạn Jude."],[3424,3636,"Cảm giác giao tiếp hơi kém."],[3678,3883,"Tất cả những gì anh muốn làm là"],[4033,4320,"ân ái với em."],[4320,4396,"Em hiểu chứ? - Vâng."],[4396,4483,"Nên tôi thấy cả hai chúng ta"],[4483,4704,"đều kiểu như bị"],[4704,4900,"nhét chữ vào miệng."],[4900,5063,"Vâng, em thực sự"],[5063,5167,"cảm thấy áp lực từ,"],[5167,5438,"kiểu như mọi người và mọi thứ,"],[5438,5488,"cứ bảo em"],[5488,5676,"phải làm gì và... - Ừ,"],[5676,5780,"thực sự rất khó"],[5780,5935,"để kiểu như là,"],[5935,6010,"nhận ra bản thân"],[6010,6101,"thực sự muốn gì."],[6101,6143,"Sao cô ấy lại có thể không biết"],[6143,6206,"mình muốn gì chứ?"],[6206,6297,"Tôi định nói là,"],[6297,6493,"nếu cô thấy bối rối thì"],[6493,6627,"cô không thích anh ta đâu."],[6627,6740,"Tôi không biết, cảm xúc của tôi"],[6740,6848,"chưa đủ mãnh liệt đến mức,"],[6848,6911,"Không, tôi sẽ"],[6911,7002,"nghe theo con tim."],[7002,7178,"Kiểu như, tôi đã để người khác"],[7178,7315,"ảnh hưởng đến suy nghĩ của mình."]],"128":[[29,158,"Em, em sao rồi?"],[158,241,"Rất tốt."],[241,308,"Hôm qua sao rồi?"],[308,462,"Có quá... ừm"],[462,525,"Không, em cảm thấy"],[525,646,"như hiểu anh hơn."],[646,713,"Và em thích"],[713,775,"việc chúng ta, anh biết đấy,"],[775,938,"kiểu như kết nối"],[938,1059,"ở mức độ sâu sắc hơn và"],[1059,1109,"cùng trò chuyện"],[1109,1213,"về quá khứ của chúng ta,"],[1213,1468,"bởi vì, em không muốn"],[1468,1559,"gọi đó là gánh nặng,"],[1559,1659,"nhưng kiểu như, ai cũng"],[1659,1826,"có quá khứ riêng"],[1826,1956,"và điều đó tạo nên con người họ."],[1956,2052,"Và rồi,"],[2052,2131,"khi em càng tìm hiểu"],[2131,2214,"nhiều hơn về anh,"],[2214,2389,"thì kiểu như, anh biết đấy,"],[2389,2535,"cảm xúc của em dành cho anh"],[2535,2677,"lại càng sâu đậm và"],[2677,2852,"trở nên"],[2990,3069,"chân thật hơn."],[3069,3219,"Trời ơi, họ"],[3219,3415,"đẹp đôi quá đi."],[3415,3616,"Cô ấy xinh quá!"],[3616,3974,"Ừ. Ý anh là, anh,"],[4066,4233,"anh... thành thật mà nói, từ hôm qua,"],[4233,4320,"từ vụ máy phát hiện nói dối"],[4320,4667,"Anh từng trả tiền cho phụ nữ để"],[4700,4925,"làm nội dung 18+ với anh chưa?"],[5071,5192,"Em biết. - Anh đã rất sợ"],[5192,5259,"rằng em sẽ kiểu,"],[5259,5347,"'Tên này đang làm cái quái gì vậy?'"],[5347,5434,"Đấy, tôi thấy tò mò"],[5434,5630,"là tại sao cô ấy"],[5630,5826,"lại chấp nhận"],[5826,5955,"chấp nhận con người"],[5955,6018,"thật của tôi."],[6018,6076,"Bởi vì tôi biết"],[6076,6193,"mình là một mớ rắc rối."],[6193,6281,"Bởi vì, như em đã nói"],[6281,6356,"rồi đấy, em rất coi trọng"],[6356,6498,"sự bình đẳng trong"],[6498,6664,"tình cảm, và em thấy"],[6664,6790,"như thế hơi bất công"],[6790,6902,"vì giờ em biết"],[6902,6994,"về anh nhiều hơn"],[6994,7073,"những gì anh biết về em."],[7073,7215,"Và anh biết đấy, anh"],[7215,7303,"đã rất mở lòng với em."],[7303,7340,"Và em không nghĩ"],[7340,7486,"mình đã tạo cơ hội"],[7486,7732,"để bản thân mở lòng với anh."],[7732,7828,"Anh không biết nữa, lúc đó,"],[7828,7924,"đáng sợ thật, anh đã rất"],[7924,8008,"sợ rằng em sẽ"],[8008,8187,"nghĩ anh là"],[8187,8487,"kẻ ngoại tình, mà đúng là vậy."]],"129":[[141,433,"Thế em muốn anh phải kiểu"],[433,596,"Ý anh là, anh đang cố gắng mà."],[596,738,"Vâng, anh có cố gắng, nhưng,"],[738,950,"anh biết đấy, anh bảo"],[950,1051,"đêm qua anh gần như không chợp mắt,"],[1051,1142,"nhưng em lại ngủ rất ngon."],[1142,1230,"Chỉ mỗi anh bị vậy sao?"],[1230,1347,"Người có lỗi là anh à?"],[1347,1518,"Là lỗi của anh sao? Kiểu"],[1518,1618,"Anh chính là vấn đề đấy."],[1618,1705,"Nói tiếp đi."],[1705,1751,"Tôi nghĩ Reign"],[1751,1881,"chắc chắn là vấn đề."],[1881,1976,"Thế em không có lỗi gì à?"],[1976,2085,"Không, em chẳng có lỗi gì cả."],[2202,2356,"Em đến đây là"],[2356,2510,"để tìm kiếm điều gì đó? Hay chỉ"],[2510,2665,"vì muốn nổi tiếng? Ý anh là"],[2665,2802,"Em đã nổi tiếng sẵn rồi, nhưng em"],[2802,2890,"đến đây là có mục đích."],[2890,2965,"Ồ, chính xác."],[2965,3082,"Thành thật mà nói, em từng nghĩ"],[3082,3140,"anh là người đặc biệt,"],[3140,3194,"nhưng giờ thì em"],[3194,3345,"không chắc liệu anh"],[3345,3440,"liệu anh có đủ chín chắn không."],[3495,3682,"Anh ta vẫn như một đứa trẻ."],[3682,3795,"Một đứa trẻ to xác thì đúng hơn."],[3795,3983,"Nhưng em sẵn sàng nghe anh nói."],[3983,4237,"Cứ nói đi, tiếp đi, em đang nghe đây."],[4237,4383,"Thôi nào, Reign,"],[4383,4454,"anh muốn cái gì chứ?"]],"130":[[8,95,"Em hôn giỏi chứ?"],[95,179,"Chà, chà."],[554,625,"Ừ."],[625,700,"Em giỏi lắm."],[700,863,"Anh, anh đã có cảm giác,"],[863,996,"anh đã có cảm giác gì đó."],[1055,1130,"Ồ. Anh ấy nói ảnh có cảm giác."],[1130,1222,"Ảnh có cảm giác á?"],[1222,1317,"khi hai người hôn nhau."],[1317,1497,"Thật lòng thì, cảm xúc trước đó"],[1497,1685,"rất tuyệt. Anh nghĩ là,"],[1685,1760,"thực ra chúng ta đã"],[1760,1947,"kết nối với nhau từ trước."],[2018,2118,"Và em biết đấy, ta đã nói về"],[2118,2239,"việc anh từng có"],[2239,2481,"rất nhiều mối quan hệ mập mờ."],[2481,2610,"Đúng không?"],[2610,2848,"Anh tin là"],[2848,2936,"anh chưa từng thực sự có"],[2936,3044,"sự kết nối như vậy trước đây."],[3044,3073,"Và đó là"],[3073,3261,"lý do mọi thứ chỉ"],[3261,3453,"dừng lại ở mức mập mờ."],[3453,3532,"Anh ta lại nhắc đến"],[3532,3628,"mấy mối quan hệ mập mờ kìa."],[3628,3712,"Lại nữa!"],[3712,3807,"Cứ nhắc đi nhắc lại mãi."],[3807,3920,"Vẫn y như cũ."],[3920,4179,"Ừ, mình từng nói về thời gian chất lượng."],[4179,4275,"Đây chính xác là điều chúng ta"],[4275,4316,"đang có lúc này."],[4316,4408,"Thời gian chất lượng của chúng ta."],[4408,4637,"Mình chỉ cần bật chút TV,"],[4637,4700,"và ăn vài quả dâu tây"],[4700,4750,"bọc sô-cô-la"],[4750,4825,"hay gì đó đại loại vậy."],[5050,5167,"Có vài câu hỏi ở đây."],[5167,5201,"Ừ,"],[5201,5238,"anh đoán là"],[5238,5413,"chúng ta có thể chơi một trò nhỏ."],[5413,5501,"Sẽ vui lắm đây."],[5501,5755,"Nghe hợp lý đấy."]],"131":[[29,120,"Được rồi, đây là"],[120,246,"thẻ thử thách nhịn cười."],[246,325,"Ok không?"],[325,542,"Uống nước và cố nhịn cười"],[542,729,"trong khi người kia cố làm"],[729,846,"bạn cười."],[846,900,"Ok."],[900,1030,"Trời, em chẳng biết phải làm gì nữa."],[1096,1180,"Nước ở đây"],[1180,1368,"ngon tuyệt."],[1368,1463,"Em sẽ"],[1484,1614,"Nhấp từng ngụm thật chậm. Rồi"],[1614,1697,"bất cứ khi nào anh sẵn sàng"],[1697,1826,"để cười một trận. - Anh phải"],[1826,1922,"nghĩ ra trò gì đó."],[1922,2047,"Ok, đợi chút, đợi chút."],[2152,2256,"Thật khó để tỏ ra hài hước"],[2256,2360,"khi bị ép"],[2360,2585,"phải hài hước. - Bị ép, đúng rồi."],[2585,2715,"Ok, anh có trò này."],[2715,2790,"Có một lần"],[2790,2948,"khi đang ở phim trường,"],[2948,3044,"anh bị,"],[3044,3253,"ướt sũng. Và rồi"],[3390,3687,"anh lỡ tè ra quần."],[3770,3903,"Và vì lúc đó anh"],[3903,4175,"cũng đang ướt sũng sẵn rồi,"],[4175,4295,"nên anh cứ thế"],[4295,4391,"thả trôi luôn,"],[4391,4608,"cứ để nó tuôn trào."],[4767,4938,"Kiểu như, ôi, đã thật."],[4938,5021,"F**k!"],[5021,5159,"Cuối cùng cũng được xả"],[5176,5192,"Ôi!"],[5330,5526,"Đó là chuyện có thật đấy."],[5526,5709,"Hài hước thật đấy."],[5709,5880,"Vâng, anh kể chuyện hay lắm."],[5880,6172,"Cảm ơn em. - Vâng."],[6172,6473,"Khi nhìn Sherif, tôi chỉ thấy"],[6502,6639,"một sự bình yên."],[6639,6777,"Đặc biệt là khi tôi nhìn"],[6777,7057,"vào mắt anh ấy, tôi cảm giác"],[7057,7178,"mình có thể tâm sự với anh ấy"],[7178,7261,"về bất cứ chuyện gì."],[7261,7374,"Và tôi chưa từng có cảm giác đó"],[7374,7515,"với bất kỳ ai khác."],[7515,7686,"Đúng vậy."],[7686,7728,"Em rất thích khi"],[7728,7845,"anh làm em cười."],[7845,8045,"Chắc anh ấy thích cô ta."],[8045,8108,"Tôi nghĩ anh ấy"],[8108,8153,"chỉ đang mỉa mai thôi."],[8153,8229,"Tôi nghĩ anh ấy làm thế"],[8229,8291,"chỉ vì không muốn"],[8291,8354,"làm cô ta buồn."],[8354,8454,"Ừ, tôi biết."],[8454,8500,"Ok,"],[8500,8650,"mình chuyển sang thẻ khác nhé?"],[8946,9088,"Ok, tiếp theo sẽ"],[9088,9234,"là thẻ vuốt ve khuôn mặt."],[9234,9421,"Khi bị bịt mắt,"],[9421,9576,"bạn và người kia sẽ thay phiên"],[9576,9951,"vuốt ve mặt nhau trong 60 giây."],[10097,10276,"Cái gì?"]],"132":[[12,150,"Tèn ten ten!"],[150,287,"Thẻ bóc phốt."],[287,462,"Chà. - Gì vậy?"],[462,692,"Họ cần mấy tấm thẻ để"],[692,813,"để gợi cảm xúc. - Để thêm gia vị."],[813,900,"Ôi trời."],[900,1030,"Người chơi phải bóc phốt"],[1030,1230,"nhau trong 60 giây."],[1230,1380,"Ây da. - Ôi trời."],[1380,1468,"Đây là cách để xây dựng"],[1468,1584,"một mối quan hệ lành mạnh."],[1584,1685,"Được thoải mái"],[1685,1830,"trêu đùa lẫn nhau,"],[1830,1960,"anh không biết nữa. - Anh coi trọng"],[1960,2027,"mối quan hệ lành mạnh ư?"],[2027,2110,"Ồ, có chứ."],[2110,2239,"Tuyệt vời."],[2239,2494,"Ok, anh làm trước đi."],[2494,2706,"Để em không áy náy. - Ôi không!"],[2706,2827,"Ok, mình sẽ làm gắt"],[2827,2948,"đến mức nào? - Bóc phốt em đi,"],[2948,3057,"bóc phốt đi, moi hết mọi thứ"],[3057,3132,"anh biết về em ra."],[3132,3228,"Ok, mình không được nắm tay"],[3228,3403,"khi làm trò này. - Ác quá đi."],[3403,3566,"Sao em lại bốc thẻ này nhỉ?"],[3566,3687,"Ác á? Đây là"],[3687,3782,"một trong những điều tuyệt nhất"],[3782,3891,"khi yêu đương mà."],[3891,4020,"Nói thật, tôi sẽ bóc phốt"],[4020,4137,"cả hai đứa nó. - Chuẩn!"],[4137,4229,"Vậy có nghĩa là cô ấy"],[4229,4383,"đang nghĩ ra những"],[4383,4517,"điều thực sự ác ý để nói về cậu ấy sao?"],[4517,4592,"Ồ, đúng thế."],[4592,4738,"Chà, em nghĩ màn bóc phốt"],[4738,4929,"có thể xoay quanh chuyện hôm qua."],[4929,4988,"Chà."],[5050,5121,"Em đã thực sự"],[5121,5271,"mong đợi một hành động"],[5271,5355,"lãng mạn hoành tráng."],[5355,5422,"Và em cảm thấy"],[5422,5526,"hành động hoành tráng của anh"],[5526,5726,"hơi bị"],[5726,5826,"Thật sao? - Hơi nhạt nhẽo."],[5826,6126,"Thật luôn? - Hơi nhạt."]],"133":[[108,158,"Lật lên đi,"],[158,458,"đọc thử xem. - Tình yêu."],[500,650,"Thẻ nắm tay."],[650,779,"Hãy nắm tay bạn cặp"],[779,1046,"trong bảy phút tới."],[1046,1146,"Em làm được không?"],[1146,1267,"Em sẵn lòng thử."],[1267,1363,"Bảy phút."],[1363,1438,"Cái trò này."],[1438,1559,"Được rồi, bảy phút trên thiên đường-"],[1559,1664,"Trò chơi này của mấy người."],[1664,1751,"Hoặc bảy phút dưới địa ngục."],[1751,1860,"Cứ thử xem sao."],[1860,1922,"Bảy phút."],[1922,2047,"Ai bấm giờ vậy?"],[2085,2202,"Nói thật thì Reign còn phải cố nhiều,"],[2202,2318,"để thực sự"],[2318,2510,"chinh phục được trái tim tôi."],[2510,2648,"Mình vẫn phải nắm tay đó."],[2648,2756,"Trời ơi, Reign."],[2756,2848,"Này! Sao cổ lại buông tay?"],[2848,2961,"Em nắm cho có tâm chút đi."],[2961,3057,"Em vẫn đang nắm mà."],[3057,3157,"Em diễn một chút được không?"],[3303,3374,"Em có nên bốc"],[3374,3528,"thêm thẻ không? - Bốc đi!"],[3591,3649,"Được rồi,"],[3649,3824,"cùng lúc đó, hãy"],[3832,4020,"Thẻ 'Em yêu anh'. - Thử đi."],[4083,4237,"Hãy diễn tả lại cách"],[4237,4400,"em nói lời yêu lần đầu tiên."],[4796,4913,"Reign,"],[4913,5121,"Gấu Reigny."],[5355,5563,"Reigny cưng."],[5780,5876,"Em"],[5968,6043,"yêu"],[6122,6172,"Ôi trời."],[6356,6452,"Sờ ngực kìa!"],[6606,6656,"anh!"],[6877,7052,"Cô ấy sờ ti cậu ta."],[7052,7102,"Cô ấy sờ"],[7102,7194,"vào ti cậu ta như này."],[7194,7424,"Thôi xin đấy."],[7424,7678,"Anh chả cảm nhận được gì."],[7678,7749,"Ý anh là, thôi nào."],[7749,7845,"Anh không cảm thấy gì cả."],[7845,7912,"Hãy cho anh thấy"],[7912,8012,"là em thực sự yêu anh."],[8012,8070,"Rằng em sẵn sàng."],[8070,8128,"Rằng em,"],[8128,8270,"em có tình cảm đó,"],[8270,8412,"ẩn trong trái tim sắt đá của em."],[8412,8521,"Em không biết mình có làm được không."],[8521,8821,"Thử đi mà."],[8837,9138,"Reigny cưng."],[9200,9292,"Reigny cưng."],[9755,9880,"Biểu cảm của cổ kìa!"]],"134":[[20,83,"Anh không biết nữa,"],[83,162,"nhưng nó khá đáng sợ."],[162,266,"Anh đã rất sợ"],[266,379,"em sẽ nghĩ anh"],[379,492,"là kẻ ngoại tình,"],[525,621,"dù sự thật là vậy."],[754,867,"Hay một kẻ dối trá."],[867,1030,"Điều anh luôn cố tránh."],[1030,1109,"Không đâu!"],[1180,1267,"Anh đã chia sẻ"],[1267,1372,"những lời thật lòng, đó là điều"],[1372,1455,"em rất thích,"],[1455,1614,"và rất trân trọng."],[1614,1751,"Tôi cảm thấy rất thoải mái."],[1751,1851,"Dù anh ấy,"],[1851,2031,"đã thừa nhận từng ngoại tình."],[2031,2156,"Tôi có thể hiểu, anh ấy bảo"],[2156,2306,"lúc đó mình còn quá trẻ."],[2306,2464,"Và việc"],[2464,2585,"anh ấy"],[2585,2790,"tỏ ra hối hận, và"],[2790,2886,"kể từ đó đến nay"],[2886,2982,"anh ấy đã có nhiều"],[2982,3069,"mối quan hệ tốt đẹp."],[3069,3236,"Tôi nghĩ đó"],[3236,3319,"như một,"],[3319,3378,"một cờ xanh"],[3378,3520,"đủ sức lấn át"],[3520,3666,"cờ đỏ ngoại tình kia."],[3666,3749,"Ít ra anh cũng thành thật,"],[3749,3799,"vì em biết"],[3799,3866,"rất nhiều người sẽ không"],[3866,4020,"dám thành thật chuyện này."],[4020,4112,"Và em nghĩ chính điều đó"],[4112,4166,"khiến anh"],[4166,4308,"trở nên thực sự"],[4308,4371,"chân thành."],[4371,4525,"Đó là anh dám"],[4525,4629,"chịu trách nhiệm."],[4629,4679,"Và điều đó thực sự"],[4679,4800,"rất dũng cảm."],[4800,4884,"Cảm ơn em."],[4884,4992,"Anh xin nhận lời khen."],[5497,5543,"Hình như đằng kia"],[5543,5634,"có mấy tấm thẻ?"],[5697,5860,"Ừ, có vẻ vậy."],[5860,6010,"Ừ, gì vậy nhỉ?"],[6122,6164,"Ồ, wow."],[6164,6281,"Anh ấy bốc trúng thẻ tình yêu."],[6281,6464,"Thẻ đút ăn."],[6464,6548,"Đút cho nhau ăn"],[6548,6848,"chỉ bằng tay."]],"135":[[16,95,"Ồ, cô ấy đang bóc phốt cậu ta"],[95,191,"về chuyện hôm qua kìa."],[250,329,"Em đã rất"],[329,563,"mong chờ một cử chỉ thật lãng mạn."],[563,629,"Nhưng em lại thấy"],[629,738,"cử chỉ lãng mạn của anh"],[738,955,"hơi bị"],[955,1034,"Hơi bị nhạt nhẽo."],[1034,1084,"Ngay khoảnh khắc"],[1084,1197,"anh nhìn vào mắt em,"],[1197,1443,"anh hiểu rằng mình đã sẵn sàng"],[1443,1676,"tiến xa hơn trong cuộc đời."],[1676,1797,"Đây là cử chỉ lãng mạn của anh đó hả?"],[1797,1860,"Đúng vậy!"],[1860,2035,"Ý em không phải là hơi nhạt mà là"],[2035,2081,"cực kỳ nhạt nhẽo."],[2081,2139,"Chà."],[2252,2339,"Em chỉ cảm thấy anh"],[2339,2585,"không phải tuýp người lãng mạn."],[2585,2798,"Như anh vẫn tưởng đâu."],[2798,3098,"Anh không hề bảnh như"],[3098,3186,"anh nghĩ."],[3215,3332,"Cậu ta không bảnh"],[3332,3457,"như cậu ta tưởng đâu."],[3570,3645,"À, đúng rồi, đôi giày đó."],[3645,3774,"Giày của anh... thì sao?"],[3774,3866,"Vâng."],[3866,3949,"Anh biết đấy, ngày đầu"],[3949,4091,"em mang"],[4091,4170,"đôi giày lấp lánh."],[4170,4379,"Ngày hai, em mang"],[4379,4508,"đôi đính hạt quanh cổ chân."],[4508,4662,"Ngày ba là đôi màu đỏ bóng."],[4662,4779,"Và em thấy hình như anh"],[4779,4846,"chỉ mang đúng một đôi giày"],[4846,5025,"suốt từ đầu đến giờ."],[5025,5084,"Chà, cô ấy đang chê"],[5084,5167,"gu ăn mặc của bạn mình kìa."],[5167,5209,"Tôi biết."],[5209,5288,"Thấy xót xa giùm luôn."],[5288,5363,"Tôi không nghĩ cô ấy"],[5363,5459,"Anh sai rồi, bọn tôi đúng."],[5459,5513,"Tôi thấy họ rất đẹp đôi,"],[5513,5643,"nhưng xét về tính cách,"],[5689,5747,"thì họ không"],[5747,5889,"Cô ta không xứng với bạn tôi."],[5889,5989,"Đương nhiên là họ đẹp đôi rồi."],[5989,6156,"Cả hai đều quyến rũ, nhưng,"],[6156,6260,"họ không hề thích nhau."],[6260,6468,"Cô ấy hoàn hảo. - Cậu ấy cũng hoàn hảo."],[6468,6585,"Hai người họ đều hoàn hảo."],[6585,6752,"Nhưng lại hoàn hảo theo kiểu khác nhau."],[6752,6894,"Vài người sinh ra đã không dành cho nhau."],[6894,7027,"Được rồi, đến lượt anh."],[7027,7223,"Trời ạ, tới luôn đi."],[7223,7282,"Đừng lo, - Được."],[7282,7369,"Em không dễ tự ái đâu."],[7394,7599,"Em mở đầu bằng chuyện hôm qua,"],[7599,7845,"nói về những gì đã xảy ra."],[7845,8037,"Có"],[8037,8145,"một điều ở em"],[8145,8258,"mà anh nghĩ em không nhận ra."],[8258,8341,"Đó là em"],[8341,8437,"hơi đạo đức giả đấy."]],"136":[[16,95,"Thực ra anh rất"],[95,287,"thích trò sờ mặt này."],[337,525,"Anh nghĩ đây sẽ là một"],[525,596,"Vậy ý anh là"],[596,700,"anh từng... - Trò vui."],[700,925,"sờ mặt người khác rồi à?"],[925,1084,"Cũng không hẳn, nhưng anh luôn"],[1084,1384,"muốn thử, nên"],[1718,1805,"Anh cảm thấy,"],[1805,1868,"mặt em rất hợp"],[1868,1956,"để chơi trò này."],[1956,2177,"Nên anh hào hứng lắm."],[2177,2285,"Được rồi."],[2548,2665,"Ok."],[3044,3278,"Cậu ta làm gì vậy? Đang làm gì thế?"],[3278,3482,"Còn không biết thắt nút nữa."],[3716,3820,"Ôi, f**k."],[3903,3991,"Chắc được rồi đấy."],[3991,4099,"Xong chưa? Anh không biết"],[4099,4320,"mặt em ở đâu."],[4320,4454,"Đưa tay anh đây."],[4454,4554,"Đang thử"],[4554,4662,"Sao vậy?"],[4746,4829,"Cô ấy kiểu, cô ấy kiểu,"],[4829,5130,"Trông dễ chịu quá ha."],[5171,5401,"Anh bắt đầu nhé."],[5401,5584,"Xương hàm này, - Đầu này."],[5584,5689,"và tai."],[5689,5764,"Tai."],[5797,5914,"Tai quan trọng lắm đấy."],[5914,6001,"Cằm."],[6001,6089,"Môi."],[6126,6197,"Tuyệt lắm."],[6197,6331,"Mũi, môi."],[6602,6719,"Chuẩn."],[6719,6894,"Yeah, ôi trời ơi."],[6894,7082,"Cậu ta đang đòi hôn kìa!"]],"137":[[12,262,"Reigny cưng à."],[383,508,"Cô ấy chỉ đang đọc thẻ thôi."],[508,721,"Cô ấy đâu có yêu anh ta."],[721,825,"Dĩ nhiên anh ấy không cảm nhận được"],[825,1017,"vì cô ấy có cảm xúc thật đâu-"],[1101,1267,"Biết mà, đừng buông tay."],[1267,1814,"Em yêu anh!"],[1843,1968,"Em yêu anh."],[2122,2331,"Thử đi! Ít nhất cũng phải thử chứ."],[2331,2498,"Đây là liệu pháp tâm lý cho chúng ta mà."],[2498,2552,"Được rồi, được rồi."],[2552,2690,"Em sẽ thử lần cuối."],[2690,2773,"Được rồi, tiếp nào."],[2773,2890,"Thử lần cuối nhé."],[2890,3028,"Quá tam ba bận."],[3328,3399,"Reign."],[3490,3657,"Reign, Reign, Reign, Reign."],[3657,3770,"Reigny cưng à."],[3920,4024,"Reign."],[4170,4295,"Reigny cưng à,"],[4346,4437,"Em yêu anh."],[4437,4525,"Em yêu anh,"],[4629,4696,"yêu tất cả con người anh."],[4704,4779,"Diễn xuất dở tệ."],[4779,4871,"Hình xăm này."],[4988,5134,"Làn da rám nắng này."],[5201,5301,"Cả đôi giày nữa!"],[5301,5397,"Tôi chả tin cô ấy."],[5430,5538,"Tôi hiểu rồi-"],[5538,5647,"Đó không phải tôi, là cô ấy."],[5647,5864,"Rõ ràng là cô ấy đang đùa."],[5864,5976,"Cô ấy chả quan tâm gì tới anh ta cả."],[5976,6085,"Em yêu anh, Reign!"],[6143,6293,"Anh có yêu em không, Reigny cưng?"],[6502,6548,"Nghe này, anh yêu mọi người."],[6548,6606,"Vấn đề là ở chỗ đó."],[6606,6706,"Ôi trời ơi, anh đang-"],[6706,6886,"Sau ba ngày qua,"],[6886,7115,"thành thật mà nói, trong thử nghiệm điên rồ này,"],[7157,7444,"anh có thể thật lòng nói về con người em và"],[7444,7599,"cách em giúp anh trưởng thành."],[7774,7949,"Và học cách hít thở."],[8304,8475,"Anh thật lòng yêu em vì điều đó."],[8600,8792,"Anh thực sự yêu em... vì điều đó."],[8892,9134,"Em có tin anh không?"]],"138":[[45,208,"Em cứ"],[208,429,"tra hỏi anh về"],[429,483,"Patches!"],[558,763,"Cứ nghĩ xem liệu anh"],[763,884,"có muốn mát-xa miễn phí không,"],[884,1126,"và anh đành phải"],[1126,1209,"chấp nhận sự thật"],[1209,1334,"rằng em đã tính đến chuyện"],[1334,1397,"qua lại với gã khác."],[1397,1501,"Anh nghĩ,"],[1501,1651,"thật lòng đấy, cưng à,"],[1651,1822,"chúng ta có thể tìm cho em người tốt hơn."],[1822,1943,"Và nếu em đi cùng anh ngay bây giờ,"],[1943,2143,"anh hứa sẽ làm được điều đó."],[2143,2273,"Em không nghĩ là mình đã tính"],[2273,2352,"chuyện qua lại với gã khác."],[2352,2494,"Em nghĩ nó giống như là"],[2494,2656,"em chỉ đang tính chuyện rời bỏ"],[2656,2756,"anh thôi thì đúng hơn."],[2756,2836,"Kiểu như Patches"],[2836,2965,"chỉ đang cố thuyết phục em-"],[3007,3115,"Vừa nhắc đã tới."],[3115,3265,"Ôi trời ơi!"],[3265,3407,"Chào mọi người!"],[3407,3490,"Anh vào nằm ôm"],[3490,3582,"em được không cưng?"],[3582,3687,"Được, ở đây thoải mái lắm."],[3687,3832,"Ok, ôm nào."],[3891,4045,"À này, anh chỉ muốn đến"],[4045,4204,"trò chuyện với cô gái của anh vì"],[4204,4366,"không biết em ấy đã đọc"],[4366,4525,"tử vi hôm nay chưa."]],"139":[[16,141,"Đút cho nhau ăn"],[141,271,"bằng tay không."],[271,333,"Tuyệt."],[333,471,"Ồ"],[471,558,"Em thích ăn nho."],[663,763,"Được rồi, chỉ dùng tay thôi, đây."],[763,809,"Anh muốn em đút cho"],[809,846,"quả này chứ?"],[846,880,"Ok."],[963,1013,"Cảm ơn em."],[1013,1138,"Ngon lắm, giờ thì."],[1159,1209,"Ok."],[1209,1267,"Ok, vậy"],[1267,1376,"Anh đút cho em trước à?"],[1426,1518,"Chắc chắn rồi."],[1522,1626,"Sao họ lại bóc chuối"],[1626,1751,"từ dưới lên thế?"],[1751,1864,"Chẳng lẽ cả đời này"],[1864,2006,"tôi ăn chuối sai cách sao?"],[2006,2085,"Đúng. - Chuẩn đấy."],[2122,2256,"Tôi nghĩ chắc do cô ấy,"],[2256,2369,"hoặc anh ta đã trêu chọc cô ấy."],[2531,2585,"Tôi không dám nhìn luôn."],[2585,2723,"Anh ấy không muốn ăn kiểu"],[2840,2894,"Ồ đúng rồi."],[3128,3215,"Tôi tưởng cô ấy phải"],[3215,3265,"đút cho anh ấy chứ. - Tôi thích cách họ"],[3265,3332,"cố làm cho nó"],[3332,3470,"trong sáng nhất có thể."],[3470,3553,"Ồ!"],[3553,3616,"Tới công chuyện rồi."],[3616,3787,"Eo ôi, trời đất."],[3787,3883,"Không dám nhìn luôn. - Ok."],[3883,3983,"Ok, thế là hơi"],[3983,4070,"quá đà rồi đấy."],[4137,4183,"Thấy sao?"],[4291,4387,"Thì là vị chuối thôi."],[4450,4571,"Đưa họ thẻ khác đi."],[4708,4783,"Ok."],[4800,4913,"Lại là một từ T to bự."],[4917,5013,"Ừ. - Ok."],[5013,5096,"Tôi chả hiểu ý đó là gì."],[5142,5309,"Thẻ khiêu vũ chậm."],[5309,5513,"Khiêu vũ chậm cùng nhau"],[5547,5618,"thật gượng gạo mà không có nhạc."],[5618,5722,"Anh không thấy gượng đâu, làm thôi."],[5722,5801,"Anh không thấy gượng đâu."],[5885,5922,"Em ổn chứ?"],[5947,5989,"Em ổn."],[6227,6322,"Họ yêu nhau rồi."],[6389,6506,"Kiểu như họ vừa - Họ thực sự"],[6506,6652,"hôn phớt một cái. - đang yêu."],[6652,6698,"Hiểu ý tôi không?"],[6698,6815,"Đó là kiểu của những người"],[6815,6956,"đã hôn nhau rất nhiều... hay làm."],[6956,7107,"Đúng, những người cảm thấy thoải mái"],[7107,7169,"và đang yêu."],[7169,7203,"Ừ."],[7203,7269,"Ok. - Ok."],[7269,7444,"Thường thì bạn gái sẽ xoay"],[7444,7549,"dưới cánh tay."],[7549,7586,"Ok."],[7599,7711,"Kiểu như vậy."],[7711,7745,"Chắc rồi."],[7745,7887,"Và thường sẽ kết thúc"],[7937,8045,"như thế này. - Ok, tuyệt."],[8083,8187,"Xoay ra nào."],[8187,8258,"Ok."],[8266,8345,"Lối này."],[8345,8487,"Thấy chưa? Tốt hơn"],[8487,8591,"là để anh dẫn."],[8591,8712,"Nếu anh dẫn, thực ra anh"],[8712,8812,"sẽ ở bên đó. - Xin mời. Vâng."],[8812,8896,"Anh như vũ công chuyên nghiệp vậy."],[8896,8938,"Vậy thì-"],[8938,9121,"Bật cho họ tí nhạc lãng mạn đi."],[9259,9371,"Cứ làm như họ cần không bằng."],[9371,9409,"Không."],[9409,9530,"Anh nhảy không giỏi đâu."],[9530,9597,"Chân tay anh lóng ngóng lắm."],[9597,9667,"Không sao đâu."],[9705,9805,"Vụng về hả?"]],"140":[[75,129,"Nói lại lần nữa đi."],[129,216,"Anh chỉ muốn nghe em nói lại lần nữa."],[433,542,"Nhìn anh này, nhìn anh này."],[859,942,"Này. - Chà."],[1105,1217,"Không đời nào cậu ta định hôn đâu."],[1217,1272,"Anh bạn tôi."],[1272,1388,"Tôi thách cậu ta đấy. - Tôi mong là thế."],[1388,1530,"Ôi không. - Cậu thách à?"],[1530,1597,"Làm đi, Reign. - Làm đi."],[1680,1755,"Anh yêu em."],[1810,1943,"Ý em là, như em đã nói,"],[1943,1989,"Em là-"],[2364,2444,"Như em đã nói,"],[2444,2585,"em là người thuần hóa trai đểu."],[2619,2806,"Anh tin em chứ? Ý em là, em"],[2806,2944,"Tất nhiên là anh tin em rồi."],[2944,3032,"Ai mà chẳng yêu em chứ?"],[3032,3132,"Câu hỏi tiếp theo."],[3428,3490,"Được rồi."],[3536,3632,"Thẻ tiếp theo."],[3632,3745,"Thẻ quyến rũ."],[3812,3978,"Người chơi phải cố"],[3978,4133,"quyến rũ bạn cặp của mình."],[4312,4412,"Anh có muốn thử quyến rũ em không,"],[4412,4454,"Reign?"],[4533,4654,"Anh không nghĩ mình làm được đâu."],[4733,4825,"Em nghĩ anh làm được mà."],[4825,4959,"Hôm qua anh làm tốt lắm cơ mà."],[4984,5096,"Cho xin câu hỏi đi."],[5096,5196,"Ừ."],[5372,5459,"Anh định làm gì đây?"],[5472,5555,"Nhưng, ý anh là,"],[5555,5693,"đó là màn dạo đầu với anh."],[5814,5910,"Và anh thì không, em biết đấy."],[5964,6060,"Được rồi, tới luôn."],[6252,6377,"Ừ, cậu có thể thử quyến rũ cô ấy."],[6377,6506,"Cô ấy vô tình lắm, ông bạn."],[6506,6564,"Anh có thể"],[6564,6639,"làm những gì anh có thể."],[6648,6735,"Em có trái tim nhé."],[6752,6881,"Sao cậu không ra ngồi ghế kia"],[6881,6956,"và để tôi thử xem."],[7027,7136,"Nhường cậu tất."],[7211,7344,"Xem cậu có tài cán gì nào, người anh em."],[7369,7453,"Khỏe không, Meghane?"],[7474,7511,"Chào anh."],[7511,7599,"Rất vui được gặp em."],[7599,7703,"Em cũng rất vui được gặp anh."]],"141":[[8,171,"Anh chỉ muốn đến nói chuyện với cô gái của anh,"],[171,237,"vì,"],[237,362,"anh không biết cô ấy"],[362,504,"đã xem tử vi"],[504,592,"hôm nay chưa."],[604,650,"Mà tôi đoán... - Ôi không."],[650,867,"nói đúng ra thì đó cũng là tử vi của cậu."],[867,938,"Vậy nên, - Được rồi."],[938,1046,"với cung Cự Giải, tử vi nói là"],[1046,1176,"hôm nay cậu nên,"],[1176,1355,"tránh xa những cám dỗ."],[1430,1622,"Vậy hôm nay cậu có"],[1622,1893,"đang cố cám dỗ cô ấy chuyện gì không?"],[1972,2060,"Sao cậu lại ghét tôi?"],[2310,2381,"Tôi không ghét cậu."],[2381,2577,"Tôi chỉ quá rành những người như cậu."],[2577,2669,"Và tôi biết cậu chẳng có"],[2669,2815,"ý đồ gì tốt đẹp cả."],[2877,3057,"Cậu đi guốc trong bụng tôi hay"],[3057,3103,"À không, cậu đang"],[3103,3207,"xem chỉ tay cho tôi, đúng chứ?"],[3207,3361,"Cậu ta cay lắm rồi."],[3361,3424,"Cáu rồi kìa."],[3449,3603,"Kiểu bị tự ái thôi, chứ không phải"],[3603,3695,"là đau lòng gì đâu."],[3695,3757,"Cậu nghĩ... - Ý tôi là, tôi cũng sẽ"],[3757,3895,"tự ái thôi, nếu có người xen vào"],[3895,4049,"và bảo, tôi quá rành những kẻ như cậu"],[4049,4158,"và tôi không ưa gì cậu."],[4158,4304,"Tôi từng gặp những gã như cậu rồi."],[4304,4425,"Tôi biết cô ấy cũng từng gặp"],[4425,4504,"những gã như cậu trước đây."],[4504,4550,"Đúng thế."],[4550,4662,"Và tôi chỉ đang cố,"],[4662,4771,"giúp cô ấy đỡ mất thời gian. - Phải."],[4771,4942,"Cô ấy đang nhìn đời qua lăng kính màu hồng."]],"142":[[450,625,"Gì cơ? - Ôi trời ơi."],[821,980,"Bị từ chối phũ thật."],[980,1130,"Ồ. Sao cơ?"],[1305,1363,"Cạn lời."],[1363,1476,"Em đã rất bất ngờ"],[1476,1634,"khi anh ấy định hôn, nhưng kiểu"],[1655,1789,"em thấy khá thích."],[1789,1901,"Kiểu, em không thấy phiền đâu."],[1931,2022,"Thế..."],[2060,2147,"sờ mặt thế nào?"],[2289,2352,"Bọn em bị bịt mắt."],[2352,2444,"Nên em không lường trước được,"],[2444,2565,"nên em thấy hơi hoảng."],[2565,2698,"Em kiểu, khoan đã, nhưng mà,"],[2744,2911,"nếu lúc đó không bị bịt mắt,"],[2911,3044,"chắc chắn em đã để anh ấy hôn."],[3219,3353,"Phũ phàng thật."],[3353,3449,"Cú đó đau đấy."],[3449,3591,"Khó mà gỡ gạc lại được lắm."],[3666,3791,"Mặt em đẹp tuyệt."],[3853,3941,"Chà, cảm ơn anh."],[4204,4266,"Bọn mình xong chưa?"],[4346,4567,"Chà, ta vừa sờ mặt nhau đấy."],[4696,4838,"Khi mà con trai nói"],[4838,5025,"nhiều gấp tám lần con gái khi hẹn hò,"],[5025,5113,"thì đó không phải là buổi hẹn tốt."],[5146,5317,"Tha cho cậu chàng tội nghiệp đó đi."],[5317,5380,"Sao chứ?"],[5380,5584,"Chê. - Biết gì không?"],[5584,5734,"Thôi nào, giờ tôi thấy tội cho cậu ấy rồi."],[5734,5805,"Tôi thì không."]],"143":[[4,83,"Rất vui được gặp em."],[83,187,"Em cũng rất vui được gặp anh."],[187,291,"Hôm nay trông em rất tuyệt."],[304,421,"Cảm ơn anh. Anh cũng vậy."],[421,550,"Cảm ơn em rất nhiều."],[596,696,"Anh nghe nói mọi người đang chơi"],[696,784,"một trò chơi nhỏ trong này."],[800,896,"Đúng vậy."],[896,1005,"Bé Reigny lẽ ra phải"],[1005,1084,"quyến rũ em."],[1101,1230,"Cậu ta phải quyến rũ em á?"],[1230,1372,"Vâng, nhưng anh ấy lại sợ."],[1401,1551,"Sợ quyến rũ em sao?"],[1580,1647,"Đúng thế."],[1689,1772,"Sao lại thế nhỉ?"],[1822,1889,"Chà."],[1939,2043,"Trông cậu ta tiu nghỉu kìa."],[2043,2223,"Cậu ta cứ thế... cứ để mặc hắn làm tới."],[2344,2435,"Đúng là trẻ ranh."],[2452,2573,"Nhưng, em biết đấy, có lẽ,"],[2640,2744,"em có thể truyền cảm hứng cho cậu ta."],[2765,2831,"Được thôi."],[2857,2990,"Cho cậu ta xem phải làm thế nào."],[3003,3040,"Anh nghĩ em có thể"],[3040,3107,"làm mẫu cho cậu ta."],[3107,3178,"Em nghĩ mình làm được không?"],[3178,3261,"Em nghĩ là được."],[3261,3307,"Được."],[3307,3365,"Quyến rũ anh đi."],[3399,3553,"Được rồi, thử chơi trò này nhé?"],[3586,3674,"Ừ thì, chơi luôn."],[3691,3753,"Được rồi."],[3753,3920,"Cô ấy khô khan như sa mạc Sahara,"],[3920,3970,"ông bạn ạ."],[3970,4049,"Cậu bảo cô ấy khô khan... - Khoan, gì cơ?"],[4049,4162,"Sao cậu biết được?"],[4245,4295,"Tiếp tục đi."],[4295,4404,"Để xem cậu có gì nào, anh bạn da trắng?"],[4416,4496,"Vậy, Meghane này,"],[4525,4679,"Anh thấy em có vẻ chật vật ở đây,"],[4679,4771,"và có vẻ như em thấy rất"],[4771,4859,"không thoải mái,"],[4896,5005,"với cái tên"],[5046,5296,"lập dị thích khoe cơ ngực này."],[5359,5463,"Bé Reigny."],[5492,5543,"Cái đ**"],[5638,5764,"Nhưng anh biết hôm nọ"],[5764,5889,"chúng ta khá là hợp nhau."],[5997,6126,"Anh biết trước đây em có hơi"],[6143,6289,"thiếu quyết đoán"],[6289,6519,"về tình cảm dành cho Reign."],[6519,6648,"Nhưng anh thực sự muốn thử"],[6648,6781,"cho chúng ta một cơ hội cuối,"],[6806,6948,"và đưa em đi một buổi hẹn hò thật sự"],[6948,7115,"vào dịp nào đó, để cho em thấy"],[7148,7290,"anh có thể đối xử tốt với em thế nào."],[7290,7378,"Và tốt hơn nhiều"],[7378,7553,"so với cách Reign từng đối xử với em."],[7620,7686,"Thật sao?"],[7716,7811,"Anh thực sự nghĩ vậy."],[7832,7920,"Nói thêm cho em nghe đi."]],"144":[[4,183,"Tôi đang nhìn chuyện này từ bên ngoài,"],[183,300,"đúng với bản chất thật của nó."],[333,475,"Và tôi biết đây"],[475,625,"chính là cái ổ thao túng."],[692,779,"Lúc đó mới nhận ra"],[779,892,"những gì người khác đã thấy"],[892,971,"từ bên ngoài."],[971,1088,"Rằng một phần trong đó là sự thật."],[1113,1234,"Rõ ràng là tôi đã bán tín bán nghi,"],[1234,1338,"và đó là lý do chúng tôi trải qua"],[1338,1422,"đến ba buổi hẹn hò trước khi"],[1422,1543,"tôi đưa ra quyết định cuối cùng."],[1543,1626,"Thế nên tôi nghĩ, mình sẽ tự"],[1626,1726,"đưa ra quyết định."],[1726,1860,"Không ai được thao túng tôi."],[1872,1951,"Tôi sẽ là người"],[1951,2064,"đưa ra quyết định này."],[2064,2185,"Và đó cũng là một yếu tố"],[2185,2373,"khiến chuyện này kéo dài quá lâu,"],[2373,2473,"bởi vì tôi cứ liên tục"],[2515,2648,"đi hẹn hò để"],[2648,2802,"chứng minh với bản thân rằng tôi có thể"],[2802,2994,"tự đưa ra quyết định của riêng mình."],[2994,3107,"Hôm qua, lẽ ra anh phải"],[3107,3253,"làm một hành động thật lãng mạn để"],[3253,3328,"giành lại cô ấy."],[3353,3490,"Vậy mà hành động lãng mạn nhất"],[3503,3703,"anh dành cho cô ấy là"],[3749,3883,"Là điều anh chưa từng làm."],[3991,4074,"Anh không, anh không"],[4074,4158,"Hành động lãng mạn nhất"],[4158,4262,"anh dành cho cô ấy là nói,"],[4287,4437,"anh không thích mập mờ."],[4446,4542,"Này, đó là điều tối thiểu đấy."],[4554,4625,"Tối thiểu thôi, cưng à."],[4637,4700,"Không, đó là"],[4700,4775,"Tối thiểu thôi, cưng à."],[4775,4925,"Là trước đây anh hay mập mờ."],[4925,5100,"Nhưng anh không muốn mập mờ"],[5100,5142,"với cô ấy."],[5142,5263,"Anh muốn tiến tới bước tiếp theo."],[5263,5363,"Đó là điều anh muốn nói."],[5363,5455,"Được rồi, anh tham gia chuyện này"],[5455,5534,"vì mục đích đúng đắn chứ?"],[5684,5764,"Có không?"],[5818,5989,"Chà. Ôi trời ơi."]],"145":[[12,254,"Và cho em thấy anh đối xử tốt với em ra sao."],[275,362,"Và tốt hơn nhiều"],[362,533,"so với cách Reign đối xử với em."],[600,667,"Thật sao?"],[696,804,"Anh thực sự nghĩ vậy."],[813,905,"Kể thêm về chuyện đó đi."],[992,1134,"Chà, anh muốn đưa em đi chơi."],[1151,1213,"Em không biết, chúng ta chưa"],[1213,1313,"có cơ hội- - Đợi, đợi, đợi đã."],[1313,1422,"Các người đang lảng tránh."],[1459,1572,"Cả hai người đều đang lảng tránh"],[1572,1626,"thẻ quyến rũ."],[1626,1680,"Hai người không định"],[1680,1772,"giành lấy tôi sao?"],[1772,1864,"Tôi muốn các người giành lấy tôi."],[1864,1976,"Đáng ra các người phải quyến rũ tôi."],[2027,2135,"Tôi chẳng thấy bị quyến rũ gì cả."],[2173,2302,"Tôi biết, tôi có thể thấy"],[2302,2348,"Thực ra các anh biết không,"],[2348,2427,"các anh đã làm tôi"],[2427,2531,"mất hết cả hứng rồi."],[2569,2681,"Khoe cơ ngực kìa."],[2715,2765,"Thôi nào, Reigny cưng."],[2765,2861,"Đừng để bụng chuyện này-"],[2861,2927,"Anh muốn gì?"],[2927,2969,"Anh có muốn ở bên tôi không?"],[2969,3082,"Hay tôi nên đi hẹn hò với-"],[3082,3261,"Tôi không, cứ đi đi!"],[3261,3328,"Tên anh là gì nhỉ?"],[3328,3382,"Paul."],[3382,3470,"Paul."],[3511,3645,"Tôi có nên đi hẹn hò với Paul không?"],[3674,3749,"Reigny cưng?"],[3787,3891,"Có vẻ anh ấy chẳng quan tâm"],[3891,3974,"đến cô chút nào."],[4004,4104,"Reign. - Anh nghĩ"],[4104,4245,"Anh có đang xem chuyện gì xảy ra không?"],[4245,4283,"Anh có thấy"],[4283,4429,"Anh nghĩ cô ấy thật sự quan tâm sao?"],[4429,4500,"Tôi không nghĩ cô ấy quan tâm-"],[4500,4587,"Anh đang đứng về phe ai vậy?"],[4587,4637,"Rõ ràng là,"],[4679,4738,"anh chỉ lo cho bản thân mình."],[4738,4792,"Trước hết,"],[4792,4892,"sao anh lại ngồi trên cái ghế đó?"],[4892,4959,"Vì tôi không phe nào cả."],[4959,5025,"Tôi không muốn dính dáng"],[5025,5142,"đến chuyện này nữa."],[5142,5305,"Nhìn xem, cô làm tôi trông như thằng ngốc!"],[5305,5417,"Anh bị suy nhược thần kinh à?"],[5509,5576,"Reign,"],[5576,5622,"Lại đây."],[5659,5751,"Tôi nghĩ,"],[5751,5901,"tôi nghĩ Reign muốn quyến rũ tôi."],[5922,6026,"Anh ta muốn quyến rũ cô?"],[6026,6101,"Và thành thật mà nói."],[6101,6206,"Tôi không nghĩ vậy."],[6206,6285,"Anh ta vừa bảo là không muốn."],[6285,6373,"Nhìn anh ta đi."],[6373,6523,"Thế à? Còn anh? - Nhìn anh ta đi."],[6523,6623,"Tôi thấy bài của anh rồi."],[6623,6727,"Tôi nghĩ anh ta muốn rời đi."],[6727,6831,"Anh ta đang co rúm ở kia kìa."],[6831,6911,"Tôi không nghĩ có ai-"],[6911,6981,"Cô muốn anh ta sao?"],[6981,7061,"Đúng vậy không, Reign?"],[7061,7148,"Cô muốn anh ta sao?"],[7148,7236,"Đúng vậy không, Reign?"],[7236,7382,"Cho cô ấy thấy bản lĩnh đi, người anh em."],[7465,7545,"Ừ. - Tôi"],[7545,7753,"Thấy chưa. Hai người đâu có cần nhau."],[7761,7949,"Tôi đến đây để tìm tình yêu."],[7949,8070,"Nên... ồ, được rồi."],[8070,8179,"Ừ, cô không tin vào chuyện đó sao?"],[8224,8454,"Thôi nào, mỗi tôi tin thôi à?"],[8566,8658,"Bình tĩnh nào."],[8666,8796,"Ồ, đây rồi. Đây."],[8829,8933,"Chào mừng đến với buổi thác loạn."],[8958,9075,"Buổi thác loạn ư?"]],"146":[[162,300,"Anh tham gia chuyện này"],[300,358,"có thật lòng không?"],[358,421,"Mục đích của tôi"],[421,575,"ở đây là tốt đẹp, đúng vậy."],[575,729,"Anh nói rất nhiều, nhưng"],[729,867,"chẳng có gì thực tế"],[867,955,"trong những lời anh nói."],[955,1071,"Tất cả chỉ là sáo rỗng."],[1071,1288,"Chẳng có cảm xúc thật nào"],[1288,1368,"đằng sau đó cả."],[1418,1555,"Tôi phải nói là"],[1639,1839,"chuyện này khá giống với mọi thứ"],[1839,1935,"tôi từng trải qua"],[1951,2068,"cho đến tận bây giờ."],[2139,2335,"Khoảng hai, ba năm qua,"],[2369,2527,"cách tôi và Olivia"],[2527,2673,"giao tiếp và,"],[2723,2898,"cách bạn cô ấy can thiệp vào,"],[2898,3036,"mọi thứ quá đỗi quen thuộc."],[3057,3244,"Anh chưa từng nói"],[3290,3365,"điều gì tốt đẹp về tôi."],[3365,3436,"Vì cô chưa làm gì"],[3436,3549,"tốt đẹp để tôi nói cả."],[3670,3728,"Tôi chỉ"],[3728,3807,"Nói điều gì tốt đẹp đi."],[3807,3870,"Thôi nào."],[3970,4133,"Cô ấy có thể cho anh nhiều thứ."],[4133,4254,"Tôi chắc chắn luôn. - Không, không, không."],[4254,4329,"Tôi muốn anh tự"],[4329,4462,"nói về bản thân mình. - Chúng tôi đồng điệu."],[4496,4692,"Anh ta đang bảo vệ hình ảnh cá nhân,"],[4692,4871,"chứ không phải tình cảm dành cho cô ấy."],[4871,4934,"Cô hiểu ý tôi chứ?"],[4934,5030,"Tôi cũng nghĩ thế. Đó là lý do"],[5030,5171,"tôi cho là anh ta không thực sự thích cô ấy."],[5171,5288,"Và cô ấy thì chẳng quan tâm"],[5288,5480,"chuyện anh ta đang bị vùi dập tơi tả"],[5480,5530,"ngay lúc này."],[5530,5626,"Cô ấy kiểu, cứ nói tiếp đi,"],[5626,5701,"chuyện này vui mà."],[5730,5789,"Tôi không hiểu"],[5789,5839,"sao cô lại trên giường. - Anh không biết"],[5839,5897,"Chúng ta đang ở trên giường. - một điểm tốt-"],[5897,5922,"Anh"],[5985,6076,"Sao anh lại lảng tránh"],[6076,6143,"câu hỏi của tôi? Anh biết đấy,"],[6156,6247,"anh không biết một điểm tốt nào"],[6247,6331,"về bản thân mình sao?"]],"147":[[25,141,"Lại thêm cái nữa à?"],[296,417,"Thế em đang tìm kiếm điều gì"],[417,542,"trong một mối quan hệ?"],[925,988,"Trời ạ."],[1071,1201,"Chắc chắn là"],[1259,1426,"sự cởi mở,"],[1426,1676,"sự ổn định, và"],[1751,2039,"một sự kết nối chân thành."],[2039,2235,"Ôi, cưng à."],[2235,2327,"Tiến tới đi. - Đúng rồi."],[2327,2439,"Ơn trời."],[2439,2602,"Tuyệt. - Thêm chút gia vị nào."],[2644,2723,"Còn anh thì sao?"],[2840,3011,"Anh hoàn toàn đồng ý với"],[3011,3174,"những gì em vừa nói."],[3232,3411,"Anh thực sự muốn tìm"],[3428,3528,"tình yêu của đời mình."],[3528,3641,"Một người mà anh có thể"],[3645,3774,"dành cả đời ở bên cạnh"],[3774,3841,"và cùng nhau"],[3924,4116,"xây dựng gia đình. Và"],[4141,4291,"nhưng đồng thời, em biết đấy,"],[4333,4491,"những chuyện này cần thời gian."],[4491,4800,"Nên anh sẵn sàng vun đắp"],[4800,5005,"và dành đủ sự kiên nhẫn"],[5005,5176,"để đạt được điều đó."],[5176,5259,"Anh thực sự tìm kiếm"],[5259,5355,"sự kết nối với"],[5430,5518,"một ai đó."],[5613,5697,"Mong là em."],[5905,6001,"Chào hai người?"],[6093,6185,"Mọi chuyện ổn chứ?"],[6206,6289,"Ổn. - Ổn."],[6289,6385,"Hai người có phiền nếu tôi"],[6385,6506,"chen vào đây không?"],[6602,6752,"Ồ."],[6760,6952,"Thế mới phải chứ."],[6952,7044,"Chà, được thôi."],[7044,7165,"Xin lỗi nhé."]],"148":[[12,91,"Là việc"],[91,279,"tôi sẵn sàng gạt bỏ mọi thứ"],[279,412,"liên quan tới cô ấy."],[412,508,"Tất cả bạn bè của cô ấy"],[508,638,"tới đây tìm cách chia rẽ chúng tôi."],[642,725,"Tôi sẵn sàng gạt"],[725,871,"những điều vớ vẩn đó sang một bên,"],[892,1021,"và thực sự cho cô ấy cơ hội."],[1080,1205,"Đây là buổi hẹn thứ ba"],[1205,1359,"mà cô chen vào và nói"],[1359,1551,"toàn những điều tiêu cực về chúng tôi."],[1551,1618,"Hôm qua,"],[1705,1876,"tôi có chần chừ một chút"],[1918,2118,"trước khi đuổi người phụ nữ"],[2118,2277,"định cướp tôi khỏi tay cô ấy,"],[2293,2452,"vậy mà cô cũng xỉa xói chuyện đó,"],[2452,2590,"nên nó cực kỳ mâu thuẫn."],[2602,2756,"Thực ra, cô ấy... - Gì cơ?"],[2756,2923,"mới là người đuổi cô ta đi."],[2940,3019,"Anh đâu có đuổi... - Có chứ."],[3019,3069,"cô ta đi."],[3069,3128,"Tôi đã mắng cô ta."],[3128,3249,"Cô ta tới... - Cô ta bỏ đi"],[3249,3349,"Tôi đã mắng cô ta."],[3349,3457,"Mắng á? Tôi không nghĩ vậy."],[3457,3495,"Có đấy."],[3495,3616,"Em không biết nữa, kiểu như,"],[3616,3753,"em đã cho anh cơ hội thứ hai."],[3753,3858,"Kiểu, được rồi, sao cũng được,"],[3858,3974,"mục đích của chúng ta ở đây là"],[3974,4116,"tìm hiểu tất cả các mối quan hệ mà."],[4116,4204,"Nên em đã để anh có"],[4204,4283,"chút không gian riêng."],[4308,4421,"Khoảng thời gian đó có kéo dài"],[4421,4567,"hơi quá lâu và rõ ràng là"],[4567,4621,"làm em khó chịu ư?"],[4621,4654,"Ừ, có."],[4654,4742,"Có. - Chắc vậy."],[4754,4863,"Phải. - Nhưng em đã cho anh"],[4863,5046,"cơ hội thứ hai. - Anh hiểu."],[5046,5205,"Thực ra anh vẫn chưa kịp"],[5205,5309,"nói ra cảm xúc của mình"],[5309,5447,"về việc em có ý định"],[5447,5584,"theo người đàn ông khác"],[5584,5684,"sau khi nghe cô ta xúi giục."],[5751,5847,"Đó là điều cô ta cố làm."],[5847,6039,"Tôi không xúi giục. Tôi nói sự thật."],[6060,6185,"Chuyện anh không đuổi cô gái kia đi."],[6185,6297,"Đó là sự thật,"],[6297,6423,"đó không phải ý kiến cá nhân."],[6460,6564,"Olivia và Jude khiến tôi phát bực."],[6564,6673,"Để tôi nói lý do cho bạn nghe."],[6673,6936,"Cả hai đều rất hấp dẫn, được chứ?"],[6944,7094,"Họ trông rất đẹp đôi,"],[7107,7265,"nhưng lại chẳng hề thích nhau."],[7265,7349,"Đơn giản là không."],[7349,7449,"Họ không có chút phản ứng hóa học nào."],[7449,7578,"Tôi nghĩ họ có thể làm"],[7578,7703,"bạn bè tốt của nhau,"],[7728,7841,"nhưng việc họ cứ ra sức"],[7841,8028,"chứng minh với nhau rằng,"],[8058,8128,"ồ, tôi thích"],[8128,8229,"Vậy là không hề thích nhau."],[8237,8379,"Cô không tin rằng"],[8379,8508,"con người có khả năng"],[8508,8591,"tiến lên phía trước sao?"],[8616,8708,"Tôi nghĩ họ có khả năng"],[8708,8771,"tiến lên phía trước."],[8771,8825,"Nhưng tôi cũng nghĩ"],[8825,8967,"họ có khả năng dối trá."],[8983,9054,"Và đó là điều"],[9054,9163,"tôi thấy rất rõ ở anh."]],"149":[[25,133,"Bình tĩnh lại đi."],[145,216,"Này, chúng tôi đang cố"],[216,325,"quyến rũ cô ấy. - Paul, nghỉ ngơi đi."],[346,408,"Anh ta không làm được."],[408,508,"Tôi không làm được."],[513,558,"Chào, Paul."],[558,600,"Ý cậu là sao?"],[600,667,"À, ý tôi là cậu là Paul."],[667,767,"Lên giường lại đi. - Tôi là Paul."],[792,875,"Tôi không lên giường"],[875,946,"với ba gã đàn ông đâu."],[1001,1105,"Lên giường lại đi."],[1134,1313,"Vui vẻ nhé, cứ cố tán tỉnh đi."],[1330,1443,"Rõ ràng là anh không đủ trình."],[1455,1726,"Tôi đã cố suốt ba ngày chết tiệt rồi."],[1743,1926,"Tôi đã cố tỏ ra dịu dàng."],[1926,2072,"Thôi nào, thể hiện đi"],[2072,2135,"Cô muốn gì?"],[2135,2252,"Cô tìm kiếm điều gì ở đây?"],[2268,2389,"Tôi muốn anh, Reigny cưng à."],[2389,2502,"Nhưng anh không đủ trình."],[2665,2907,"Buồn cười thật đấy."],[2961,3015,"Meghane, để tôi nói chuyện"],[3015,3098,"với anh bạn này."],[3098,3186,"Được thôi. - Ngồi xuống đi."],[3186,3315,"Nói chuyện với cậu ấy đi, Reign."],[3349,3428,"Anh lên giường đi."],[3457,3636,"Không, tôi không lên giường với tên này đâu."],[3661,3807,"Chết tiệt... - Ra ngoài đi,"],[3807,3845,"anh bạn."],[3924,4041,"Này, đừng chạm vào tôi, được chứ?"],[4350,4429,"Cậu đến đây để giúp à?"],[4458,4550,"Tôi chỉ đến chơi thôi."],[4558,4642,"Cậu định giúp"],[4646,4783,"về mối quan hệ này à?"],[4783,4850,"Những gì chúng tôi đang có,"],[4850,4963,"hay cậu gọi là gì cũng được."],[4963,5021,"Anh có muốn được giúp"],[5021,5105,"về mối quan hệ này không?"],[5125,5246,"Là đàn ông, tôi"],[5246,5372,"Ý tôi là, tôi không biết cậu định"],[5372,5447,"tán tỉnh cô ấy,"],[5451,5559,"cướp cô ấy khỏi tôi"],[5559,5672,"hay cậu đang cố giúp tôi."],[5672,5730,"Tôi chỉ đến chơi thôi."],[5730,5793,"Nhưng là đàn ông,"],[5797,5918,"Bịt tai lại đi. Bịt tai vào."],[6006,6110,"Là đàn ông,"],[6110,6231,"hãy cho tôi"],[6260,6539,"Là đàn ông, tôi thấy dấu hiệu bất ổn là"],[6694,6810,"Việc kiêng quan hệ năm năm"],[6810,6931,"có vẻ là một lời nói dối."],[6994,7061,"Gì cơ?"],[7061,7148,"Nghe như nói dối."],[7148,7261,"Đó là một dấu hiệu bất ổn với tôi."],[7298,7353,"Tôi"],[7419,7490,"Nên tôi nghĩ"],[7490,7603,"dấu hiệu bất ổn có thể là"],[7603,7741,"anh có hơi dối trá."],[7741,7820,"Thỉnh thoảng thôi. - Ôi trời."],[7820,7941,"Tôi thừa nhận mình giỏi nói dối"],[7941,8041,"chỉ khi cần thiết."],[8083,8216,"Vậy anh thừa nhận mình giỏi nói dối."],[8216,8316,"Anh hiểu ý tôi chứ?"]],"150":[[8,129,"Cô nghĩ tôi dọn chiếc giường này,"],[158,291,"để cố lừa cô ấy"],[291,342,"làm chuyện gì đó à?"],[342,400,"Tôi không làm thế."],[412,529,"Tôi không hề biết chuyện gì đang xảy ra."],[529,621,"Chúng tôi chỉ vừa mới bước vào."],[625,759,"Không, nhưng tôi nghĩ những lời"],[759,963,"anh nói với cô ấy đều là giả tạo."],[992,1130,"Cô thấy điều đó trong mắt tôi hay"],[1130,1197,"hay là sao?"],[1197,1343,"Cô thấy qua chỉ tay tôi à?"],[1397,1493,"Chà, tôi đã xem chỉ tay anh."],[1493,1593,"Tôi thấy anh là kẻ nói dối."],[1593,1647,"Thật sao?"],[1664,1722,"Thật mà."],[1780,1997,"Nói thật nhé, tôi rất muốn cô"],[1997,2156,"thấy một thứ khác trên tay tôi."],[2156,2218,"Vậy sao?"],[2218,2369,"Nói thật nhé, tôi rất muốn cô"],[2369,2515,"thấy một thứ khác trên tay tôi."],[2569,2623,"Chà."],[2623,2698,"Dành riêng cho cô đấy."],[2698,2740,"Chà."],[2740,2823,"Phải, tôi thấy vậy đó."],[2823,2877,"Ôi!"],[3007,3111,"Giơ ngón giữa cơ đấy."],[3148,3232,"Gì cơ?"],[3265,3353,"Thật khó tin."]],"151":[[0,166,"Khi đi nhớ giữ im lặng nhé?"],[191,275,"Hả? - Ồ."],[296,404,"Đáng ra phải gượng gạo cơ."],[404,458,"Được rồi. - Đáng ra chúng ta"],[458,521,"không được nói chuyện."],[554,675,"Bọn tôi là kiểu người thích giao du."],[675,813,"Nên cứ nói không ngừng thôi."],[838,980,"Buồn cười thật, người ta phải năn nỉ"],[980,1142,"họ gượng gạo với nhau vì họ"],[1142,1230,"vốn đã quá ăn ý rồi."],[1247,1355,"Được rồi. Xin lỗi nhé."],[1459,1514,"Không sao đâu."],[1514,1605,"Lát nữa nói tiếp cũng được."],[1634,1847,"Ồ, lát nữa mình nói tiếp."],[1847,2022,"Lẽ ra chúng ta phải gượng gạo cơ."],[2081,2181,"Ồ."],[2198,2364,"Tôi từng nghĩ buổi hẹn hò đầu tiên"],[2364,2544,"sẽ là khiêu vũ chậm dưới nền nhạc."],[2627,2773,"Trong đời tôi, các buổi khiêu vũ"],[2790,2882,"thường diễn ra như vậy."],[2898,2994,"Thường sẽ có âm nhạc."],[3107,3190,"Nhưng,"],[3203,3274,"nhưng thế này cũng không tệ."],[3274,3365,"Cũng khá tuyệt"],[3365,3561,"khi chỉ tập trung vào cô ấy, vào ánh mắt,"],[3561,3670,"và giọng nói của cô ấy."],[3699,3837,"Một điều mà tôi rất trân trọng"],[3837,3949,"ở anh ấy là,"],[3970,4129,"tôi vốn là người ruột để ngoài da,"],[4129,4341,"nên tôi hay nói đủ thứ chuyện."],[4341,4466,"Tôi có thể nói quá nhiều"],[4466,4592,"và anh biết đấy,"],[4592,4771,"cứ bộc lộ đúng con người thật của mình."],[4783,4934,"Tôi ồn ào, thích nói và muốn"],[4934,5030,"kết nối với mọi người."],[5030,5192,"Và anh ấy chấp nhận điều đó."],[5192,5284,"Rồi tôi"],[5363,5497,"chỉ thấy anh ấy mỉm cười"],[5497,5605,"khi tôi đang nói,"],[5605,5755,"và chăm chú lắng nghe tôi."],[5801,5872,"Đó là điều"],[5905,6051,"tôi không hề ngờ tới ở anh ấy."],[6051,6139,"Nên khi điều đó xảy ra,"],[6139,6227,"tôi thấy rất tuyệt vời."],[6268,6385,"Lên nào, Josip!"],[6385,6493,"Tuyệt."],[6493,6581,"Đi thôi."],[6581,6769,"Tới chơi chút nhạc lãng mạn cho họ đi."]],"152":[[91,221,"Tôi là người đáng tin."],[221,337,"- Ai mà biết? - Anh á?"],[337,396,"Ừm."],[408,450,"Phải rồi."],[458,600,"Vì tôi từng thấy chuyện thế này"],[600,725,"xảy ra, và tôi không thích nhìn"],[725,867,"bạn mình lãng phí thời gian."],[1034,1167,"Và tôi nghĩ anh chỉ tổ tốn thời gian."],[1201,1305,"Anh có rất nhiều cờ đỏ"],[1305,1380,"cần phải chỉ ra."],[1468,1718,"Có vẻ cô ấy sẵn sàng"],[1730,1818,"cho anh một cơ hội,"],[1847,1997,"dù có những cờ đỏ đó."],[2260,2356,"Cô mong đợi gì ở tôi?"],[2394,2477,"Tôi cũng là con người."],[2502,2652,"Tớ không biết, mới hôm qua tớ bảo cậu"],[2652,2794,"rằng nếu anh ta không có"],[2794,2936,"một cử chỉ hoành tráng thì dẹp đi."],[2936,3028,"Và cậu đã đồng ý với tớ,"],[3028,3148,"vậy mà anh ta thậm chí không làm"],[3148,3249,"được điều đó."],[3324,3470,"Anh ta chỉ làm những thứ tối thiểu."],[3499,3645,"Và tớ chỉ"],[3645,3816,"nếu mới bắt đầu đã như vậy,"],[3816,3908,"thử tưởng tượng xem anh ta sẽ làm gì"],[3908,3987,"về lâu về dài."],[4012,4124,"Tớ nghĩ cậu xứng đáng với người tốt hơn."],[4124,4179,"Và tớ nghĩ,"],[4216,4366,"cậu có thể tìm một chàng trai thực sự"],[4366,4617,"làm cho cậu nhiều hơn mức tối thiểu."],[4725,4804,"- Tớ yêu cậu. - Tớ cũng yêu cậu."],[4921,5042,"Mong cậu đưa ra quyết định đúng đắn"],[5042,5113,"và tớ hy vọng,"],[5150,5288,"lát nữa cậu sẽ ra chỗ tớ,"],[5288,5513,"và đá gã tép riu yếu đuối đó đi."],[5768,5885,"Gắt thật đấy."],[5885,5964,"Cái câu về"],[5964,6089,"gã tép riu yếu đuối đó,"],[6089,6193,"sao cậu nghĩ ra được hay vậy?"],[6227,6373,"Tớ đọc trên một bài đăng Instagram."],[6373,6473,"Trời đất ơi."],[6602,6702,"Bốc thẻ khác đi."],[6756,6806,"Thế nào?"],[6819,6906,"Ừ, được."],[6906,6944,"Ừ."],[6944,7061,"Cứ tiếp tục như lúc nãy nhé."],[7061,7098,"Ừ."],[7332,7507,"Ồ, anh ấy đặt thẻ tình yêu."],[7507,7628,"Nhìn mặt cô ấy kìa."],[7628,7736,"Trông chán ngán chưa kìa."],[7766,7874,"Cô ấy chán lắm rồi."]],"153":[[12,95,"Ai cần nói dối chứ?"],[95,216,"Ai cũng nói dối mà?"],[300,346,"Em không à?"],[346,408,"Thú vị đấy."],[408,546,"Em không à? - Thú vị đấy."],[550,675,"Tóm lại, cờ đỏ khác là gì?"],[700,800,"Cờ đỏ khác sao?"],[884,1080,"Em hiếm khi thấy anh mặc áo."],[1092,1142,"Được thôi."],[1205,1380,"Kiểu tóc cũng hơi cờ đỏ."],[1388,1455,"Sao tóc lại là cờ đỏ?"],[1455,1647,"Sợi dây chuyền cũng hơi cờ đỏ."],[1647,1718,"F**kboy à?"],[1739,1860,"Trông giống f**kboy lắm sao?"],[1860,2068,"Mấy hình xăm cũng hơi cờ đỏ."],[2156,2281,"Cách anh đối xử"],[2281,2419,"với Meghane cũng hơi cờ đỏ."],[2419,2544,"Người ta chỉ hỏi hai cái thôi."],[2573,2740,"Được rồi, em cũng có những cờ đỏ"],[2740,2781,"mà anh không biết vì"],[2781,2857,"Để cậu ấy nói."],[2857,2923,"Cho cậu ấy nói đi."],[2923,3157,"Anh ta kể hơn hai cái rồi, được chứ?"],[3157,3253,"Để cậu ấy nói xem."],[3353,3407,"Không."],[3991,4087,"Tôi sắp bóp cổ"],[4087,4270,"thằng bảnh chọe m* kiếp này mất."]],"154":[[120,225,"Xin lỗi nhé."],[312,396,"Chà, được thôi."],[396,504,"Xin lỗi."],[525,625,"Anh có lẽ nên xin phép"],[625,821,"quý cô đây trước đã."],[1096,1259,"Autumn, hôm nay em thế nào?"],[1259,1359,"Em trông rất xinh."],[1376,1476,"Cảm ơn anh."],[1501,1597,"Chán ngắt."],[1597,1689,"Anh khỏe không?"],[1772,1901,"Tôi khỏe. Cảm ơn."],[1901,1981,"Được rồi."],[2027,2164,"Thành thật mà nói, đây có lẽ"],[2164,2318,"là buổi hẹn hò gượng gạo nhất"],[2318,2556,"tôi từng chứng kiến trong đời."],[2569,2635,"Thật sao? - Ừ."],[2635,2715,"Vì tôi thấy nó"],[2715,2827,"Ý tôi là, em đồng ý chứ?"],[2911,3053,"Nhưng tôi lại thấy gượng gạo hơn"],[3053,3153,"khi có anh ở đây đấy."],[3211,3361,"Chà. Ý tôi là, không biết nữa,"],[3361,3553,"tôi chỉ thấy, kiểu như,"],[3553,3712,"hai người cần thêm chút"],[3732,3858,"năng lượng trong phòng này."],[3887,3974,"Tôi đang tận hưởng mà."],[4004,4204,"Tôi thuộc kiểu người trầm tính,"],[4225,4371,"thích không gian riêng,"],[4371,4508,"và tôi nghĩ Sherif cũng vậy."],[4508,4658,