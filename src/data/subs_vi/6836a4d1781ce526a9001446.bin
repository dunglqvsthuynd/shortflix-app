"],[7257,7278,"vì đã"],[7278,7349,"được nói"],[7349,7432,"sự thật với cô."],[7432,7561,"Dù sao thì,"],[7561,7628,"chúc hai người"],[7628,7770,"hẹn hò vui vẻ."],[7770,7832,"Cô ta chỉ đang"],[7832,7924,"chơi đòn tâm lý."],[7924,7982,"Rõ ràng là"],[7982,8033,"cô ta đang cố"],[8033,8112,"phá hoại tôi."],[8112,8166,"Nên kiểu như,"],[8166,8237,"rồi cô ta kiểu"],[8237,8324,"Tại sao cô ta"],[8324,8475,"lại muốn phá cô?"],[8475,8516,"Bạn sẽ"],[8516,8566,"nhận được"],[8566,8779,"2.000 đô la"],[8779,8963,"cho mỗi cặp đôi bạn"],[8963,9021,"chia rẽ thành công."]],"48":[[83,133,"Được rồi."],[133,158,"Anh định"],[158,196,"làm gì đây?"],[200,275,"Anh định làm gì đây?"],[312,371,"Anh muốn chiến đấu"],[371,467,"vì tình yêu."],[467,688,"Anh ấy quay lại kìa?"],[688,750,"Trốn đi!"],[779,905,"Khoan! Anh ấy đang vào à?"],[1009,1142,"Ôi, anh ấy cuồng nhiệt quá!"],[1142,1292,"Cứ như"],[1292,1376,"Lọ Lem và"],[1376,1443,"hoàng tử vậy!"],[1443,1551,"Không thể nào."],[1551,1651,"Ôi trời ơi!"],[1651,1739,"Cứ như Rapunzel vậy!"],[1739,1805,"Chuyện gì đang xảy ra vậy?"],[1805,1868,"Ôi trời ơi."],[1868,1985,"Trời đất ơi."],[1985,2160,"Này, chuyện gì vậy?"],[2160,2327,"Cái đ** gì vậy?"],[2327,2535,"Anh đã quay lại vì em."],[2535,2644,"Sao rồi?"],[2644,2756,"Anh xin lỗi."],[2756,2857,"Anh đúng là ông hoàng rắc rối của em."],[2857,2940,"Em thích sự cuồng nhiệt của anh."],[2940,2986,"Hãy nhận lại em."],[2986,3078,"Ồ em thích trò đó à?"],[3078,3190,"Anh biết ngay mà,"],[3190,3424,"em thích trai hư."],[3549,3674,"Đúng thế!"],[3707,3812,"Chúng ta bù trừ cho nhau, đúng không?"],[3812,3962,"Hai ta như âm với dương."],[3962,4175,"Âm với dương cơ đấy."],[4425,4471,"Này người anh em, những người còn lại"],[4471,4529,"ở ngoài này là ai vậy?"],[4817,4904,"Anh dễ thương quá!"],[4904,4975,"Cảm ơn em."]],"49":[[16,166,"Máy đo nhịp tim báo:"],[166,271,"tăng vọt."],[271,396,"Không có nghĩa là anh nói dối,"],[396,533,"chắc chỉ là do"],[563,721,"một chủ đề nhạy cảm thôi."],[721,871,"Không phải nhạy cảm, mà chỉ là"],[884,959,"Cảm xúc gì?"],[980,1055,"Ừm"],[1138,1234,"Anh không biết."],[1284,1338,"Vậy,"],[1376,1480,"niềm vui, hạnh phúc, vì nó"],[1480,1543,"đã qua. - Niềm vui, đúng vậy!"],[1543,1601,"Hú!"],[1601,1664,"Tự do rồi!"],[1672,1885,"Thật ra em cũng hơi cảm thấy thế"],[1885,2010,"sau khi chúng ta chia tay."],[2010,2110,"Chuyện qua rồi."],[2110,2248,"Chắc chắn là quá khứ rồi."],[2248,2373,"Anh ấy đang khó xử."],[2373,2510,"Cực kỳ khó xử luôn."],[2527,2577,"Chắc chắn là"],[2577,2706,"đã qua rồi sao? - Đúng 1.000%"],[2706,2769,"là quá khứ."],[2769,2923,"1.001% là quá khứ rồi."],[2940,3069,"Vào đi, ngồi lên đùi anh ấy đi."],[3069,3132,"Nhanh nào."],[3132,3328,"Tiến tới đi, Emily."],[3328,3449,"Lên đi, lên đi. - Đúng rồi."],[3449,3520,"Thay vì chỉ"],[3520,3632,"tìm cách tách họ ra,"],[3632,3762,"cố gắng giành lấy chàng trai,"],[3778,3870,"ở một khía cạnh nào đó, đây cũng là,"],[3870,4066,"tôi cũng đang cố để thành chị em tốt,"],[4066,4316,"và kết bạn với cô ấy nữa."],[4329,4475,"Mỗi cặp đôi một khác,"],[4475,4679,"nhưng với đa số các cặp,"],[4679,4904,"chiến lược của tôi là cho họ thấy"],[4904,5021,"rằng họ thực sự không hề thích"],[5021,5088,"nhau."],[5180,5238,"Được rồi."],[5334,5476,"Vậy chúng ta cứ, tiếp tục thôi."],[5497,5630,"Chào mọi người."],[5672,5772,"Ồ, chào. - Chào nhé."],[5793,5826,"Ồ."],[5935,5980,"Hừm. - Hửm?"],[6268,6377,"Chuyện gì vậy?"],[6377,6510,"Tôi chỉ là, không có chỗ ngồi thôi."],[6519,6577,"Ngồi lên đùi đi."],[6577,6656,"Cứ ngồi lên đùi anh ấy."],[6656,6785,"Trời ơi, cô ấy định ngồi lên đùi anh ấy kìa."],[6785,6823,"Tuyệt."],[6823,6948,"Những người khác bước vào đây,"],[6948,7148,"chưa ai ngồi như thế cả."],[7148,7198,"Khoan đã."],[7198,7290,"Có phải cô ấy"],[7290,7436,"Cô có đang... ghen không vậy?"],[7436,7582,"Không, tôi không hay ghen lắm,"],[7582,7628,"thành thật mà nói."],[7628,7678,"Ồ, thật sao?"],[7711,7857,"Chắc cô ấy rất tự tin vào bản thân."],[7857,7987,"Ừ, rất tự tin."],[8062,8220,"Ý tôi là, thế này mãnh liệt quá đó."],[8220,8324,"Cô đang ngồi hẳn lên hông anh ấy kìa."],[8324,8425,"Tôi làm gì còn chỗ nào để ngồi."],[8425,8525,"Cô có thể ngồi đằng kia mà."],[8525,8696,"Nhưng thế thì đâu có thoải mái."],[8696,8846,"Tôi tưởng cô là chị em tốt cơ mà, không phải sao?"]],"50":[[4,75,"Được rồi, tôi sẽ kiểu,"],[75,171,"xem qua chỗ này một chút."],[171,212,"Kiểu như đường... - Ừ."],[212,300,"tính cách của anh."],[312,437,"Tôi thấy là, - Ừ."],[437,500,"thì"],[533,688,"Có một đường chính ở đây, đúng không?"],[688,763,"và có rất nhiều đường,"],[763,888,"kiểu như phân nhánh ra."],[888,1017,"Ừ, tôi thấy rồi. - Nó cho thấy"],[1017,1092,"rằng,"],[1092,1222,"anh không thành thật lắm."],[1238,1363,"Không thành thật lắm. - Ồ."],[1363,1459,"Anh ấy hay nói dối."],[1480,1622,"Một tên nói dóc chính hiệu."],[1622,1785,"Kiểu như những khuyết điểm của tôi"],[1785,1868,"của một con người,"],[1868,2068,"đã ảnh hưởng đến việc tôi cố gắng,"],[2085,2185,"bạn biết đấy, sống"],[2185,2481,"thật 100% với phụ nữ."],[2573,2715,"Tôi đã học cách che giấu"],[2715,2798,"những điều đó"],[2798,2994,"để thành công hơn."],[3111,3228,"Mong là các cậu đưa ra"],[3228,3311,"lựa chọn đúng đắn."],[3311,3361,"Tôi phải làm"],[3361,3428,"ra nhẽ chuyện này - Mọi người biết đấy."],[3428,3511,"ngay bây giờ."],[3595,3678,"Ừ."],[3678,3757,"Hay lắm."],[3757,3791,"Chà."],[3791,3920,"Làm tốt lắm. - Giỏi đấy."],[4012,4158,"Một vấn đề lớn nhất của em, và kiểu,"],[4158,4270,"tổn thương quá khứ, chắc vậy,"],[4270,4454,"khi yêu đương là bị lừa dối."],[4454,4479,"Ừ."],[4479,4617,"Hoặc kiểu, bị cắm sừng, hay kiểu,"],[4617,4721,"đại loại thế."],[4767,4817,"Anh đã bao giờ"],[4817,4921,"cắm sừng ai chưa?"]],"51":[[4,175,"Cô ta chỉ đang chơi trò tâm lý."],[175,279,"Rõ ràng cô ta đang muốn, kiểu,"],[279,371,"phá đám tôi."],[392,467,"Vào đó đi."],[513,583,"Woo!"],[717,804,"Làm tụi này tự hào nhé."],[813,938,"Sao rồi các chàng trai?"],[975,1092,"Ừ, chào."],[1092,1163,"Em sao rồi, Autumn?"],[1376,1539,"Em không ổn lắm."],[1539,1609,"Sao lại thế?"],[1609,1689,"Em không biết, kiểu,"],[1689,1818,"anh có muốn giải thích, kiểu,"],[1818,1951,"chuyện gì đang xảy ra không?"],[1951,2002,"Sao rồi ông bạn?"],[2002,2064,"Tên anh là gì nhỉ?"],[2264,2348,"Sherif."],[2348,2398,"Paul."],[2469,2577,"Rất vui được gặp, sếp."],[2690,2777,"Trời nóng lên rồi đấy."],[2777,2898,"Anh có muốn cởi áo ra luôn không,"],[2898,3028,"để cùng tắm nắng chứ?"],[3078,3186,"Không, ổn mà anh bạn."],[3186,3244,"Tôi không sao."],[3278,3319,"Được thôi."],[3461,3595,"Nhìn mặt Sherif kìa."],[3620,3703,"Ô, gì cơ?"],[3774,3849,"Chà, sao,"],[3849,3945,"sao em lại nói"],[3978,4083,"mình không ổn lắm?"],[4083,4329,"Em chỉ không biết là hôm qua"],[4329,4500,"có cô gái khác hôn anh ấy."],[4508,4650,"Anh ấy có vẻ cũng khá hứng thú"],[4650,4692,"với cô ta."],[4692,4792,"Nói thật là vậy."],[4946,5038,"Chà."],[5092,5130,"Ừ. - Được rồi,"],[5130,5230,"ra là thế."],[5251,5451,"Giờ đã có hai người nói vậy rồi."],[5476,5559,"Thú vị đấy."],[5580,5618,"Ok. - Ừ."],[5618,5734,"Hơi điên rồ thật."]],"52":[[29,120,"Tôi luôn bênh vực chị em."],[120,204,"Ok. - Tôi cũng tưởng vậy."],[212,392,"Ừ, đó là chỗ duy nhất tôi có thể ngồi."],[392,471,"Thì, tôi đang hẹn hò,"],[471,575,"còn cô thì ngồi vào lòng anh ấy."],[575,704,"Nhưng có vẻ anh ấy cũng khá sẵn lòng"],[704,779,"hạ chân xuống mà."],[800,888,"Tôi á?"],[888,1017,"Anh để cô ấy ngồi vào lòng mình."],[1255,1380,"Em cũng để Andres cho anh"],[1380,1447,"ra rìa một lúc đấy thôi."],[1539,1718,"Chà, Andres."],[1751,1935,"Giờ thì họ, họ đang cãi nhau kìa."],[1951,2006,"Thật mà!"],[2064,2131,"Sao cũng được. - Anh chỉ đang cố"],[2131,2193,"Em đâu có lựa chọn. - chọc em chút thôi."],[2193,2281,"Anh đâu nghĩ em sẽ đồng ý chứ?"],[2281,2373,"Em làm gì có lựa chọn."],[2373,2548,"Em phải làm sao đây?"],[2585,2752,"Em có thấy như mình đang ở tù không."],[2752,2794,"Không, em"],[2794,2902,"Đây là nhà tù sao?"],[2902,3098,"Không, em thấy như đang, đang hẹn hò vậy."],[3123,3236,"Với anh à?"],[3340,3478,"Đùa thôi, đùa thôi."],[3495,3566,"Bọn em đùa thôi."],[3582,3724,"Ồ, nhịp tim cô đang tăng lên à?"],[3724,3820,"Một chút."],[3858,4037,"Là do tôi sao?"],[4091,4175,"Thì, ý tôi là... - Được rồi."],[4191,4358,"Có phải tôi, tôi đang làm cô hơi"],[4400,4500,"bất an không?"],[4525,4679,"Thì, cô đang ngồi trong lòng bạn hẹn của tôi mà."],[4679,4767,"Ừ, vì tôi chẳng có"],[4767,4850,"chỗ nào khác để ngồi."],[4850,5005,"Có cái bàn ngay kia kìa."],[5005,5121,"Andres ngồi đó rồi."],[5121,5251,"Ồ, anh ấy là đàn ông."],[5251,5347,"Thế nên, cô biết đấy."],[5347,5472,"Ồ, ok."],[5472,5551,"Tôi không làm thế đâu."],[5588,5655,"Phụ nữ,"],[5655,5701,"phải ngồi trong lòng."],[5847,6022,"Kiểu như, tôi thấy rõ sự ghen tuông ở đó."],[6068,6164,"Anh có nghĩ Tigerlily"],[6164,6252,"xinh đẹp không?"],[6252,6310,"Cô ấy đẹp."],[6310,6377,"Tuyệt đẹp!"],[6377,6493,"Cảm ơn nhé. - Ừ."],[6493,6594,"Tôi cũng thấy cô xinh đẹp."],[6594,6698,"Cảm ơn."],[6698,6869,"Và tôi nghĩ anh ấy cũng thấy vậy,"],[6869,7077,"vì anh ấy cho tôi ngồi vào lòng."],[7152,7215,"Anh nghĩ mỗi người đều có"],[7215,7328,"vẻ đẹp riêng của mình."],[7449,7553,"Thú vị đấy!"],[7553,7611,"Hừm."],[7645,7791,"Nhịp tim đang tăng lên à?"]],"53":[[116,212,"Không. Không, tôi sẽ"],[212,408,"không bao giờ cắm sừng ai."],[408,517,"Nhịp tim anh ta sao rồi?"],[533,588,"Nói dối à?"],[588,667,"Hay nói thật?"],[667,704,"Đúng rồi."],[734,838,"Đang tăng lên."],[838,946,"Tăng vọt kìa, chà."],[959,1013,"Vậy nên"],[1013,1076,"Chà, gì cơ?"],[1076,1151,"Khoan đã. - Giải thích thêm đi."],[1151,1197,"Chuyện đó,"],[1197,1313,"hoàn toàn không đúng."],[1313,1409,"Tôi sẽ"],[1426,1518,"Giải thích chuyện gì?"],[1518,1551,"Chuyện"],[1551,1668,"nhịp tim tôi đang tăng ấy à."],[1668,1801,"Phải biết đúng lúc nào nên"],[1801,2022,"che giấu đi sự yếu đuối"],[2022,2102,"của bản thân."],[2102,2285,"Tôi đã phải thay đổi"],[2285,2389,"toàn bộ con người mình"],[2389,2477,"bởi vì tôi"],[2598,2840,"bởi vì sự phản bội đã xảy ra"],[2840,2957,"từ phía đối phương."],[3098,3224,"Ôi Chúa ơi!"],[3224,3265,"Sao cơ?"],[3265,3390,"Chuyện gì đang xảy ra vậy?"],[3415,3536,"Anh từng bị cắm sừng sao?"],[3716,3937,"Nói một cách đơn giản là vậy."],[3987,4091,"Ừ, đúng thế."],[4091,4200,"Anh ta nói gì vậy?"],[4266,4441,"Đang cố biện minh tại sao"],[4441,4558,"anh ta lại dối trá."],[4612,4692,"Gì cơ?"],[4821,4896,"Anh ta nói dối."],[4896,5017,"Chỉ tay anh ta báo thế."],[5017,5196,"Tôi từng có một mối quan hệ mập mờ."],[5221,5338,"Điều đó cơ bản đã"],[5338,5447,"làm tôi tan nát cõi lòng,"],[5492,5697,"vào năm cuối cấp ba."],[5697,5910,"Nên tôi đã,"],[5910,6089,"bước vào giai đoạn khốn nạn."],[6089,6302,"Tôi gần như suy sụp."],[6302,6410,"Tôi chỉ cố gắng"],[6410,6581,"vớt vát lại lòng tự trọng"],[6581,6656,"vào lúc đó."],[6664,6727,"Được rồi,"],[6727,6810,"Tôi đoán mình sẽ, - Ok."],[6810,6919,"Tôi sẽ tin anh chuyện này."],[6919,6973,"Cảm ơn em."],[6973,7040,"Lần này thôi."],[7040,7132,"Lần này thôi. - Ok, tuyệt quá."],[7132,7207,"Vì tôi là người"],[7207,7353,"rất bao dung."],[7353,7390,"Được."],[7411,7453,"Ok."],[7453,7532,"Biết vậy tốt quá."],[7615,7686,"Nhưng đừng coi đó,"],[7686,7782,"để lợi dụng tôi."],[7782,7853,"Được rồi, tôi biết."],[7853,7962,"Em nói rõ vậy"],[7962,8020,"thì tốt. - Đừng coi sự"],[8020,8153,"tốt bụng là yếu đuối."],[8153,8287,"Chà, tôi sẽ không bao giờ,"],[8287,8370,"không bao giờ làm vậy đâu."],[8370,8441,"Thế mới đúng."],[8441,8796,"Tôi rất thẳng thắn và quyết đoán."],[8796,8925,"Nên anh sẽ luôn biết"],[8925,8983,"vị trí của mình ở đâu."],[8983,9104,"Khuôn mặt tôi không biết nói dối."],[9104,9263,"Nó hiện rõ hết lên mặt."],[9284,9409,"Tuyệt, tiến tới đi."],[9459,9517,"Cố lên."],[9701,9893,"Tôi nghĩ buổi hẹn này rất ổn."],[9930,9984,"Này, này."],[9984,10097,"Chào. - Ôi không."],[10105,10151,"Đúng vậy."],[10226,10356,"Tôi cần nói chuyện này,"],[10402,10531,"nhưng không để cô ấy nghe thấy."],[10573,10623,"Cậu có thể"],[10623,10727,"ra đây một lát không?"],[10731,10769,"Ừm"]],"54":[[8,133,"Ừ, anh dời cái này đi nhé."],[133,246,"Anh thấy hai đứa ngồi hơi xa."],[246,362,"Anh dời ghế được chứ?"],[362,454,"Anh ngồi lên đây được không?"],[454,500,"Thế này"],[500,571,"gần hơn nhiều. - Lúc nãy"],[571,617,"siêu xa luôn."],[617,692,"Thế này tốt hơn nhiều."],[692,717,"Vâng."],[717,829,"Ồ, đây. Suýt thì anh quên."],[829,880,"Đúng rồi."],[880,988,"Em làm anh hồi hộp quá."],[1172,1292,"Tay anh đã đổ mồ hôi"],[1292,1426,"từ trước khi xích lại gần,"],[1426,1551,"mà giờ còn đổ mồ hôi nhiều hơn."],[1551,1685,"Chào mọi người."],[1685,1772,"Chào!"],[1772,1830,"Bọn mình là bạn mà. - Rất vui"],[1830,1997,"được gặp hai bạn. - Ừ."],[1997,2235,"Được rồi, mình rất đam mê chiêm tinh."],[2235,2277,"Tuyệt."],[2277,2460,"Và mình rất muốn biết"],[2460,2552,"cung hoàng đạo của hai bạn."],[2552,2660,"Mình"],[2660,2748,"Anh vừa bảo tháng Ba là"],[2748,2852,"Song Ngư."],[2852,2932,"Anh là Song Ngư. - Ừ, đúng rồi."],[2932,3019,"Bạn là Song Ngư á. - Ừ."],[3019,3053,"Bạn biết không,"],[3053,3098,"thú vị thật đấy. - Mình hay khóc lắm."],[3098,3207,"Đó là cung Mặt Trăng của mình."],[3207,3282,"Mình sẽ tâng bốc bạn ấy một chút"],[3282,3345,"ngay tại đây. - Được."],[3345,3528,"Song Ngư, họ rất đa cảm."],[3528,3641,"Họ rất thấu hiểu cảm xúc của bản thân."],[3641,3678,"Nhiều khi họ biết rõ"],[3678,3778,"mình đang nghĩ gì."],[3778,3949,"Và họ cảm nhận rất sâu sắc."],[4049,4070,"Đúng vậy."],[4070,4170,"Nhưng phải công nhận là,"],[4191,4446,"ai cũng biết Song Ngư"],[4458,4554,"hôn rất giỏi."],[4596,4662,"Mình nghĩ có lẽ chúng ta"],[4662,4792,"nên kiểm chứng giả thuyết này."],[4808,4859,"Nếu hai người sẵn sàng"],[4859,4942,"và thoải mái."],[4942,5063,"Khóa môi xem nào. - Ồ."]],"55":[[4,58,"Không sao đâu."],[58,141,"Ý em là,"],[141,266,"chắc em cũng sẽ hơi ngại đấy,"],[266,337,"nói thật là vậy."],[358,408,"Ý là, đúng thế."],[408,550,"Cậu đang ngồi trên đùi anh ấy mà."],[550,608,"Nên là... - Ừ."],[608,671,"Hơi bị"],[671,800,"Tiện thể thì, ngồi êm lắm đấy."],[813,900,"Anh có tập gym đúng không?"],[900,959,"Chỗ này kiểu... - Không."],[971,1105,"Đời anh chưa tập phần đó bao giờ."],[1105,1176,"Thật luôn, đâu phải"],[1176,1209,"Ừ."],[1209,1301,"Nói thật nhé, dáng anh kiểu,"],[1301,1376,"nhìn ốm mà đô ngầm ấy."],[1376,1472,"Anh biết đô ngầm là gì không?"],[1472,1584,"Tức là nhìn anh như không tập tành gì à?"],[1584,1655,"Không, kiểu là,"],[1655,1789,"vì anh mặc đồ"],[1789,1885,"che hết dáng đi ấy."],[1885,1926,"Hiểu rồi."],[1926,2064,"Nhưng hôm nay em kiểu, khoan đã."],[2064,2227,"Anh ấy cơ bắp phết."],[2227,2293,"Đúng vậy."],[2293,2335,"Anh cũng"],[2335,2419,"có cơ bắp mà. - Và anh"],[2498,2598,"Anh không bỏ tập chân."],[2598,2660,"Anh không bỏ."],[2677,2731,"Thấy chưa."],[2731,2798,"Tuyệt."],[2798,2836,"Ừ."],[2836,2898,"Biết vậy là tốt."],[2898,3011,"Hơi bất ngờ là cậu không chớp"],[3011,3115,"cơ hội để ngồi đây đấy."],[3115,3244,"Tưởng cậu thích anh ấy, nhưng"],[3244,3345,"Tớ thậm chí còn"],[3345,3545,"chẳng nghĩ là được làm vậy lúc này."],[3545,3661,"Được mà. - Ý là"],[3757,3841,"Đùi anh vẫn còn chỗ trống."],[3841,4008,"Ồ. - Sao thế?"],[4058,4120,"Anh muốn em"],[4120,4233,"ngồi lên đùi anh ngay bây giờ à?"],[4233,4350,"Em nghĩ anh sẽ từ chối sao?"],[4350,4583,"Khoan, em đuổi cô ấy xuống nhé?"],[4583,4754,"Hay là anh"],[4779,4875,"muốn cả hai?"],[4875,5025,"Anh đâu có quyết định thay mấy em được."],[5196,5280,"Được thôi."],[5372,5447,"Tớ sẽ đuổi cậu xuống."],[5447,5538,"Bọn mình chia sẻ được mà."],[5538,5597,"Trời đất ơi."],[5597,5684,"Cậu có thể ngồi bên này."],[5793,5826,"Lên đi."],[5876,5914,"Không."],[5985,6076,"Điên rồ quá."],[6118,6156,"Không."],[6156,6218,"Không đời nào."],[6218,6318,"Nhìn mặt anh ấy kìa."],[6318,6368,"Lạy chúa."],[6519,6560,"Ừ."],[6585,6652,"Được rồi."],[6694,6865,"Bọn em sẽ bám lấy anh cả buổi hẹn nhé."],[6898,6990,"Anh thấy sao rồi?"],[6990,7090,"Anh thấy rất tuyệt."],[7090,7140,"Kiểu như"],[7140,7290,"Chắc chắn là anh ấy đang sướng rơn."],[7290,7369,"May mà lúc này"],[7369,7449,"anh không đeo"],[7449,7511,"máy đo nhịp tim đấy."]],"56":[[4,108,"Anh ấy không kể với cô sao?"],[162,208,"Không."],[246,358,"Sao anh không kể với cô ấy đi?"],[621,729,"Ý tôi là, như tôi đã nói,"],[729,913,"cô ấy hôn lên má tôi."],[967,1117,"Chuyện cũng chẳng có gì to tát."],[1138,1292,"Nhưng nếu không to tát, thì kiểu như,"],[1292,1418,"sao anh lại không kể?"],[1488,1668,"Anh ta cố giấu cô chuyện nụ hôn,"],[1676,1793,"chuyện đó khá tệ, kiểu"],[1793,1901,"Nếu anh cứ thẳng thắn về chuyện đó,"],[1901,1993,"thì đã chẳng có vấn đề gì."],[2006,2135,"Không, anh ta thật sự đã giấu."],[2135,2218,"Chẳng có gì sai trái"],[2218,2364,"khi hôn lên má con gái."],[2364,2494,"Thật đấy, các cô gái."],[2515,2602,"Đó là ý của cô."],[2644,2727,"Chúng tôi không nghĩ thế."],[2798,2936,"Tôi chỉ thích nói thẳng mọi chuyện,"],[2936,3023,"và thành thật với nhau."],[3023,3303,"Đó là cách giải quyết tốt nhất."],[3340,3507,"Vậy giả sử hôm qua tôi tiến tới"],[3507,3649,"và hôn lên má cô."],[3649,3774,"Cô có kể cho anh ấy không?"],[3807,3858,"Ôi, chắc chắn rồi."],[3899,4012,"Cô sẽ kể luôn với anh ấy à?"],[4012,4083,"Tôi sẽ làm vậy."],[4083,4124,"Và cô mong"],[4124,4258,"Vì đâu có gì phải giấu."],[4291,4354,"Thật sao? - Ừ."],[4354,4454,"Không có gì phải giấu cả."],[4496,4592,"Chà, vậy,"],[4629,4738,"cô nghĩ chúng ta nên"],[4792,4909,"làm gì để bù đắp chuyện đó?"],[4954,5046,"Kiểu như, nhỡ tôi"],[5063,5292,"Tôi có thể hôn lên má cô không?"],[5292,5426,"Vậy là huề nhau nhé."],[5555,5697,"Cô nghĩ vậy có công bằng không?"],[5768,5972,"Nếu... ý tôi là nếu anh muốn thế,"],[5972,6143,"nhưng kiểu như, anh biết đấy,"],[6193,6377,"cứ làm bất cứ điều gì,"],[6452,6569,"trái tim anh mách bảo."],[6589,6698,"Kiểu như, liệu đó có phải điều"],[6698,6815,"tôi muốn xảy ra không? Anh hiểu chứ?"],[6815,6961,"Nhưng đồng thời thì kiểu"],[6961,7032,"Cô có thoải mái"],[7032,7161,"nếu tôi hôn lên má cô không?"],[7194,7282,"Được thôi."],[7440,7557,"Wow! - Ồ!"]],"57":[[50,150,"Chắc hẳn anh thích cô ấy lắm."],[187,241,"Ừ."],[241,346,"Anh ấy thích thật mà."],[383,513,"Tình yêu đích thực đấy!"],[513,638,"Chúng ta đang chứng kiến tình yêu đích thực."],[696,759,"Đúng vậy."],[809,1009,"Mọi người biết đấy, bọn tôi từng có chút xích mích."],[1038,1213,"Em đã bỏ đi với gã khác."],[1247,1430,"Ý em là, em đâu có bỏ đi cùng anh ta."],[1430,1576,"Suýt thì thế, nhưng rồi anh"],[1576,1689,"Anh đã giành lại em! - Đúng thế thật."],[1697,1743,"Hai người đã"],[1743,1826,"làm gì trong phòng thế?"],[1830,1956,"Khoan, anh nghĩ em dễ dãi vậy sao?"],[1981,2118,"Ai biết được, em bỏ đi dễ dàng thế mà."],[2118,2223,"Anh ta không hề hôn em."],[2223,2335,"Và anh cũng vừa dán mắt vào"],[2335,2419,"của cô gái khác đó thôi."],[2619,2823,"Vậy ra em chỉ đang thử anh thôi sao?"],[2857,2994,"Cô ấy chẳng có chút hứng thú nào với hắn."],[3032,3144,"Cô ấy chỉ đang cố"],[3144,3203,"làm rối trí tôi, và"],[3203,3294,"chơi trò mèo vờn chuột quá nhiều."],[3349,3465,"Nhưng mà,"],[3511,3574,"cực kỳ thú vị,"],[3574,3649,"tôi phải thú thật là vậy."],[3649,3728,"Rất vui."]],"58":[[25,91,"Chúng ta phải đi thôi."],[116,208,"Cậu phải đi rồi."],[237,325,"Được, mình sẽ ngồi đây."],[383,525,"Không sao đâu. - Bọn mình đổi chỗ."],[579,759,"Thế này... Mình thấy thế này rất tuyệt."],[821,909,"Được rồi."],[934,1146,"Mình chỉ tò mò về,"],[1146,1326,"mấy cái cờ đỏ hay đại loại thế."],[1326,1463,"Mình không nghĩ là mình có"],[1539,1743,"cái nào mà mình nghĩ ra được."],[1743,1906,"Nhưng cậu có thấy cờ đỏ,"],[1926,2010,"từ người khác không?"],[2010,2198,"À, có, có chứ, kiểu như nếu mình, ừ."],[2227,2298,"Có phải,"],[2298,2498,"kiểu để một cô gái ngồi lên đùi anh ấy,"],[2498,2598,"là cờ đỏ không?"],[2698,2848,"Ý mình là, cũng hơi hơi,"],[2848,2982,"nhưng đồng thời, mình lại thấy"],[2982,3123,"anh ấy không có nhiều lựa chọn"],[3123,3194,"trong chuyện đó."],[3194,3328,"Ồ, anh cảm thấy thế nào"],[3336,3603,"khi để một cô gái, như em,"],[3603,3670,"ngồi lên đùi anh?"],[3795,3937,"Ừm"],[3949,4066,"Anh thấy"],[4333,4542,"Kiểu như anh, ừm"]],"59":[[20,171,"Cậu lại đây một lát được không?"],[250,354,"Được. -Bí mật nhé."],[621,721,"Chuyện gì thế?"],[855,909,"Ồ!"],[909,1109,"Không tin nổi là anh ta ngồi xuống ghế!"],[1159,1397,"Này, cô gái xinh đẹp,"],[1405,1697,"mặc chiếc váy màu vàng này."],[1722,1947,"Và anh đang ở ngay đây,"],[1997,2193,"ngồi bên cạnh em."],[2193,2260,"Anh ấy đang viết cho mình một bài hát kìa."],[2260,2331,"Tôi"],[2331,2414,"Cậu đâu làm được thế."],[2414,2552,"Tôi không biết gã này là ai,"],[2552,2677,"nhưng tôi chắc chắn."],[2677,2719,"Em không biết-"],[2719,2794,"Hắn không hợp đâu. - Em không biết"],[2794,2861,"anh là ai."],[3044,3111,"Trời ạ. Thật sự thì"],[3153,3207,"Em cạn lời luôn."],[3207,3324,"Thật lòng thì, giọng anh rất hay."],[3324,3420,"Anh tên là gì?"],[3532,3699,"Tên của anh"],[3699,3762,"Vẫn hát tiếp nữa à?"],[3762,3916,"là Josip."],[3983,4024,"Josip?"],[4024,4200,"Và em biết thế nghĩa là gì không."],[4200,4295,"Anh đến từ đâu?"],[4295,4654,"Nghĩa là anh đến từ Croatia."],[4667,4733,"Croatia."],[4733,4792,"Tuyệt đó."],[4792,5046,"Ừ, tuyệt thật."],[5080,5326,"Tất cả những gì anh muốn là"],[5451,5601,"làm tình với em."],[5601,5634,"Ồ."],[5634,5768,"Ồ! -Ồ!"],[5768,5947,"Anh ta nói muốn làm tình kìa."]],"60":[[4,162,"Reign thất thường lắm."],[162,300,"Và hy vọng là"],[300,446,"chúng tôi sẽ tìm được điểm cân bằng."],[446,600,"Nhưng mà, hiện tại thì,"],[600,838,"chúng tôi đang khá rối trí."],[921,1076,"Anh không đến giành lấy em, cứ như,"],[1076,1176,"đó là một phép thử."],[1176,1313,"Chúng ta sẽ thử bao nhiêu lần nữa đây?"],[1313,1413,"Anh là đàn ông -Em thử anh."],[1413,1459,"hay trẻ con?"],[1459,1589,"Không, em thử anh."],[1597,1739,"Công chúa không đi theo đuổi."],[1739,1856,"Kẻo vương miện sẽ rơi."],[1856,2052,"Nhưng anh là vua của em. Em phải,"],[2052,2168,"ý anh là, thôi nào, em là hoàng hậu của anh."],[2168,2277,"Em cũng phải hỗ trợ anh chứ."],[2277,2394,"Không, em sẽ không theo đuổi anh đâu."],[2394,2460,"Như Jezebel."],[2460,2552,"Anh biết mà, Jezebel."],[2669,2761,"Thành thật đi."],[2761,2882,"Anh có chung thủy hay không?"],[2882,3069,"Có chứ, rõ ràng là anh đã về bên em."],[3073,3161,"Nhưng ai biết được chuyện gì đã xảy ra"],[3161,3224,"trong hai phút đó?"],[3224,3282,"Ừ, em"],[3282,3386,"Nhưng em sẽ cho anh thêm cơ hội,"],[3386,3499,"vì anh cũng làm em"],[3499,3557,"thấy hơi thú vị."],[3578,3674,"Em thích thử thách."],[3674,3791,"Trông anh có vẻ,"],[3845,3945,"vẫn cần cải thiện nhiều."],[3945,4091,"Và em cũng thấy chút tiềm năng ở đây."],[4091,4183,"Thật đó. -Anh cũng vậy."],[4233,4425,"Anh nghĩ anh và Emily... ý anh là, ờ,"],[4446,4500,"ờ"],[4525,4587,"chết tiệt."],[4688,4750,"Meghane."],[4896,4967,"Ừ,"],[5009,5251,"anh nghĩ chúng ta là cặp đôi chiến thắng."],[5296,5392,"Ý anh là, em có muốn"],[5392,5472,"làm lại chuyện này không?"],[5534,5655,"Làm lại chuyện này á? Không."],[5655,5759,"Anh biết, không phải chuyện này."],[5759,5814,"Nhưng em có muốn"],[5814,5951,"hẹn hò lần hai không?"],[5964,6060,"Hẹn hò lần hai á?"],[6085,6172,"Để em suy nghĩ đã."],[6664,6794,"Điên rồ thật."],[6890,6940,"Ừ."],[6940,7044,"Đi khỏi đây thôi."],[7152,7469,"Cuộc sống không thể cứ tẻ nhạt được."],[7486,7636,"Âm dương hòa hợp, như người ta nói,"],[7636,7757,"làm em thấy hứng thú."],[7770,7841,"Ý em là vậy đó."],[7841,7957,"Đó là tính độc hại của em."],[7957,8208,"Kiểu như, em không thích sự ổn định."],[8208,8262,"Ý em là, không,"],[8262,8358,"em không nên nói là ổn định."],[8358,8483,"Em có muốn sự ổn định,"],[8512,8658,"nhưng em cũng muốn nó phải hơi"],[8658,8867,"phức tạp và thú vị. Anh hiểu không?"],[8883,9021,"Tình yêu, đó mới là... đúng không?"],[9021,9100,"Đó mới là phần thưởng thực sự."],[9100,9259,"Đó chính là tình yêu."],[9259,9317,"Vậy nên,"],[9371,9551,"chúng ta có cơ hội rất tốt."],[9605,9693,"Ý anh là, em nghĩ sao?"],[9855,10014,"Vậy ra anh dễ xúc động."],[10014,10122,"Cứ tiếp tục với âm nhạc đi."],[10122,10172,"Chuyện gì thế?"],[10172,10285,"Cái này cho em hay cho anh?"],[10285,10381,"Anh đang dạt dào cảm xúc kìa."],[10381,10460,"Anh ấy đang dạt dào cảm xúc."],[10577,10677,"Đến lượt em."],[10677,10785,"Khoan. Vậy đây là điều anh muốn sao?"],[10785,10927,"Ý em là, em không muốn vậy, nên"],[10944,10990,"Chà."],[10990,11102,"Tôi thà chọn ác quỷ còn hơn."]],"61":[[16,112,"Anh thấy thế nào"],[112,308,"về việc để một cô gái như em,"],[308,387,"ngồi lên đùi anh?"],[400,596,"Lúc đó anh kiểu, ừm"],[638,688,"Sao?"],[688,925,"Đang chờ xem phản ứng của Tigerlily."],[1021,1117,"Ồ. -Ừ."],[1117,1280,"Ồ, ra là một bài kiểm tra!"],[1292,1493,"Ồ. -Chết tiệt."],[1522,1659,"Ồ. Cô ấy làm thật kìa."],[1676,1743,"Hạ đo ván luôn."],[1743,1889,"Anh cố tình thử em."],[1889,1976,"Anh sẽ không bao giờ nói thế."],[1976,2060,"Với anh thì,"],[2060,2214,"ghen tuông là điều cấm kỵ sao?"],[2227,2331,"Anh không bận tâm. Không,"],[2331,2389,"bởi vì anh nghĩ bản thân"],[2389,2502,"cũng có chút ghen tuông."],[2502,2711,"Anh thấy ghen một chút cũng không sao."],[2711,2786,"Kiểu như nếu anh có bạn bè"],[2786,2861,"là con gái,"],[2911,2986,"em không bận tâm."],[3036,3103,"Nhưng rồi kiểu,"],[3103,3253,"nếu họ ngồi lên đùi anh, thì"],[3253,3403,"em thấy, ừm, thế thì hơi kỳ cục."],[3403,3449,"Em không biết"],[3449,3511,"anh ấy đã trả lời câu hỏi chưa."],[3511,3670,"Em thấy hơi bối rối một chút"],[3670,3778,"vì anh không thực sự nói"],[3778,3933,"rằng anh không thích chuyện đó."],[3978,4120,"Cô ấy trông có vẻ rất tức giận."],[4258,4387,"Anh nghĩ gã nào cũng thích có con gái"],[4387,4487,"ngồi vào lòng mình."],[4504,4608,"Nên chẳng có gì khác biệt"],[4608,4688,"khi đổi người cả."],[4688,4758,"Đó chỉ là"],[4758,4838,"Chỉ là một cô gái thôi."],[4838,4959,"Ồ, chỉ là một cô gái."],[4959,5100,"Cụ thể thì đó là em đấy."],[5100,5271,"Vậy anh thích có con gái ngồi lên đùi."],[5271,5426,"Cụ thể thì, anh thích người yêu mình"],[5426,5518,"ngồi lên đùi anh hơn."],[5518,5634,"Cô ấy là người yêu anh sao?"],[5918,6001,"Bởi vì nếu cô ấy là người yêu anh,"],[6001,6135,"thì sao anh lại để em ngồi lên đùi?"],[6139,6272,"Đó mới là vấn đề ở đây."]],"62":[[4,145,"Nhưng đồng thời thì kiểu như"],[145,216,"Có ổn không"],[216,354,"nếu anh hôn lên má em?"],[383,450,"Được chứ."],[458,538,"Được rồi."],[1071,1163,"Giờ chúng ta huề nhé."],[1197,1234,"Xong rồi đó."],[1234,1372,"Giờ hai người huề rồi."],[1384,1493,"Anh chỉ muốn xuống đây"],[1493,1605,"để nói rằng trông em rất đẹp"],[1605,1659,"hôm nay."],[1659,1735,"Cảm ơn anh. - À, anh rất thích tóc em,"],[1735,1797,"sẵn tiện nói luôn."],[1797,1935,"Và cả phong cách của em nữa."],[1935,2093,"Bộ đồ quá đỉnh."],[2122,2202,"Cho anh hôn lên má em"],[2202,2323,"thêm cái nữa trước khi đi nhé?"],[2381,2444,"Được chứ."],[2444,2506,"Được rồi."],[2627,2911,"Ồ! - Ồ!"],[2911,3015,"Nhìn mắt anh ta kìa!"],[3036,3215,"Anh ta đang đảo mắt."],[3215,3374,"Sao anh ta không hôn lại cô ấy?"],[3386,3503,"Em xứng đáng với một người tốt."],[3503,3591,"Nói cho em biết vậy thôi."],[3591,3674,"Cảm ơn anh. - Được rồi."],[3712,3828,"Thôi được rồi. Chúc hai người"],[3828,3937,"có một ngày vui vẻ nhé."],[4329,4400,"Chàng trai tốt đấy."],[4604,4746,"Anh không, anh không lo sao?"],[4800,4875,"Không hẳn."],[4938,5042,"Chà."],[5084,5238,"Chà, tôi biết là rất áp lực."],[5263,5463,"Vì mọi thứ không diễn ra 100%"],[5463,5563,"theo đúng kế hoạch"],[5584,5705,"vào lúc này."],[5718,5843,"Vậy em có muốn đi hẹn hò"],[5843,5918,"lần hai với anh không?"],[6101,6277,"Không nói dối nữa nhé."],[6448,6531,"Hợp lý."],[6652,6715,"Ừ."],[6748,6806,"Được thôi."],[6881,7015,"Anh rất mong chờ buổi hẹn thứ hai."],[7115,7186,"Em cũng vậy."],[7303,7507,"Phản ứng ban đầu của tôi"],[7507,7720,"là khép lòng lại với Sherif."],[7720,7866,"vì tôi nghĩ kiểu, chà,"],[7866,7999,"nghe thấy cũng hơi nản."],[7999,8162,"Nhưng cuối cùng tôi lại cho anh ấy"],[8195,8341,"như bạn biết đấy, thêm một cơ hội."],[8341,8508,"Tôi chỉ muốn,"],[8508,8662,"dành thêm thời gian bên cô ấy,"],[8725,8858,"đi hẹn hò nhiều hơn."],[8858,8988,"Và bạn biết đấy,"],[9025,9180,"xem chúng tôi có thể vun đắp ra sao,"],[9180,9280,"và xem liệu mối quan hệ này"],[9280,9421,"có thực sự bền lâu không."],[9484,9630,"Chúng ta triển thôi."],[9630,9743,"Ồ, chà, lạnh lùng thật."],[9751,9847,"M** kiếp, chỉ cần-"],[9847,9968,"Sha-roof, đúng không?"],[9989,10126,"Không chỉ có một nụ hôn đâu,"],[10126,10339,"mà là hai, cô ấy còn ngồi lên đùi cậu."],[10347,10477,"Thật khó tin."]],"63":[[12,196,"Ai cũng biết là"],[196,396,"Song Ngư hôn rất giỏi."],[450,521,"Anh nên,"],[521,646,"Em nghĩ anh nên thử với cô ấy."],[667,838,"Anh nghĩ cô ấy nên là người đánh giá."],[838,900,"Đúng vậy."],[900,1009,"Em có thể là người đánh giá."],[1009,1051,"Được thôi."],[1051,1096,"Cô ấy có thể"],[1096,1188,"là người đánh giá. - Em cực kỳ sẵn lòng."],[1188,1263,"Được. - Được rồi, sẵn sàng chưa?"],[1263,1334,"Vậy tới đi."],[1388,1497,"Ừ."],[1497,1614,"Ồ. - Eo ôi."],[1614,1747,"Trời đất ơi."],[1768,1926,"Ồ, điên rồ thật!"],[2043,2243,"Chắc tôi phải xin phép lảng đi thôi."],[2243,2435,"Cứ tận hưởng đi."],[2531,2652,"Lỗi tại anh. Máy đo nhịp tim của anh."],[2652,2711,"Em biết."],[2857,2902,"Được rồi."],[2902,2965,"Ừ, anh ổn!"],[2965,3019,"Anh xin lỗi."],[3069,3174,"Vậy cô ấy nói đúng chứ?"],[3232,3282,"Đúng."],[3282,3378,"Ồ, ừ, được. - Ừ."],[3395,3611,"Ngọt ngào thật đấy!"],[3616,3657,"Chà."],[3657,3762,"Cậu bạo thật đấy."],[3762,3899,"Có dùng lưỡi luôn."],[3899,3949,"Đỉnh."],[3949,4079,"Tôi đành lảng đi thôi."],[4079,4120,"Mãnh liệt quá."],[4120,4270,"Thật sự rất tuyệt vì em cảm giác"],[4270,4429,"em chưa từng có sự kết nối như vậy,"],[4475,4579,"đã một thời gian rồi."],[4592,4654,"Vậy là tốt rồi."],[4654,4792,"Em có thấy trán anh hơi vã mồ hôi không?"],[4792,4875,"Không, cũng không tệ lắm."],[4875,4929,"Cảm ơn em."],[4929,5017,"Em đẹp lắm."],[5050,5121,"Cảm ơn anh."],[5130,5326,"Không chỉ rất tuyệt khi thấy"],[5326,5451,"một chàng trai rất hấp dẫn"],[5451,5538,"như anh ấy,"],[5547,5730,"có tính cách rất,"],[5730,5876,"biết đấy, tử tế và cởi mở"],[5876,5955,"và tuyệt vời."],[5968,6177,"Mà còn nhắc nhở em rằng,"],[6177,6352,"rằng, này, em rất vui tính."],[6352,6435,"Em cũng dễ mến."],[6435,6573,"Mọi người, biết đấy, thích trò chuyện với em"],[6573,6660,"và tìm hiểu em."],[6694,6844,"Biết đấy, cảm giác đó rất tuyệt."],[6894,6973,"Vậy,"],[7002,7127,"bây giờ em đang cảm thấy thế nào?"],[7228,7282,"Cảm thấy rất ổn."],[7282,7323,"Ổn chứ?"],[7323,7369,"Vâng."],[7469,7682,"Em có, em có cởi mở với khả năng"],[7682,7766,"về buổi hẹn hò thứ hai không?"],[7903,8012,"Ngợp thật đấy."],[8049,8124,"Khá là ngợp."],[8124,8191,"Thật sự rất ngợp."],[8429,8504,"Chắc chắn rồi."],[8562,8675,"Mọi thứ thật hoàn hảo."],[8675,8817,"Không, xạo quá đi."],[8817,8896,"Thôi nào. - Ừ."],[8917,9009,"Đúng là vậy."],[9017,9167,"Họ thích mọi điểm ở nhau sao?"],[9167,9255,"Ừ, phải rồi. - Ừ."],[9267,9367,"Chắc vậy. - Thôi nào."],[9367,9430,"Ý em là, vâng, em-"],[9430,9572,"Nhân tiện thì, đó là cờ đỏ đấy."],[9572,9738,"Sao họ không hôn nhau tiếp đi?"],[9755,9813,"Ồ, ừ."],[9813,9951,"Ồ!"],[10014,10122,"Đi thuê phòng đi."],[10231,10360,"12 năm ư?"],[10360,10506,"Trả tiền cho các buổi hẹn."],[10527,10643,"Ý tôi là, nhìn mặt anh ấy kìa."],[10643,10798,"Kiểu như, ừ, tôi thích gái điếm."],[10798,11006,"Trả lời câu hỏi đi. - Hừm"],[11027,11086,"Chết tiệt."],[11098,11219,"Bị bắt bí rồi."],[11340,11432,"Chết tiệt!"]],"64":[[4,50,"Đang cố-"],[50,258,"Ôi, chết tiệt."],[258,433,"Tôi thấy lời mình đang bị xuyên tạc."],[450,571,"Ừ, vì kiểu như anh đang"],[571,692,"hơi lảng tránh câu hỏi."],[692,784,"Tôi chỉ tò mò là,"],[784,859,"anh có"],[913,1071,"thích người thẳng thắn không?"],[1084,1155,"Có."],[1155,1238,"Ừ, vì tôi"],[1238,1359,"đoán là cậu muốn anh ấy bảo,"],[1359,1543,"không, tôi không thích cô ngồi lên đùi tôi."],[1543,1605,"Ừ."],[1605,1647,"Đúng vậy."],[1647,1747,"Nhưng nói thật nhé,"],[1747,1835,"ngay từ đầu, kiểu như,"],[1835,1864,"tôi cảm giác"],[1864,1968,"lẽ ra anh ấy nên bảo là,"],[1968,2052,"không, chúng ta"],[2097,2143,"Cậu sẽ thích nếu anh ấy bảo,"],[2143,2189,"anh ấy nói thẳng là,"],[2189,2273,"đừng ngồi lên đùi tôi."],[2306,2464,"Đúng không? - Ừ, đúng vậy."],[2464,2494,"Lạ thật."],[2494,2610,"Anh cứ để chuyện đó xảy ra."],[2610,2690,"Ừ."],[2702,2865,"Em cũng thích nếu anh bảo Andres"],[2865,3023,"rời đi, nhưng anh lại không."],[3028,3115,"Ôi trời ơi."],[3144,3294,"Khoan, vậy đây là trả đũa sao?"],[3307,3403,"Anh không nghĩ đó là trả đũa."],[3403,3495,"Anh chỉ-"],[3495,3582,"Anh chỉ tỏ ra lịch sự thôi."],[3582,3732,"Đâu phải Andres ngồi lên đùi anh."],[3903,4008,"Nếu cậu ta đòi,"],[4008,4079,"anh có cho không?"],[4079,4283,"Tất nhiên là không. - Khoan, khoan, khoan."],[4283,4341,"Anh định"],[4341,4487,"anh ta đang bóp méo câu chuyện."],[4487,4587,"Thật điên rồ."],[4587,4637,"Cậu có hiểu - Đang thao túng tâm lý mình."],[4637,4700,"những gì anh ta vừa làm không?"],[4700,4813,"Sao cậu lại hùa theo cô ấy?"],[4875,4942,"Sao cậu lại,"],[4942,5042,"sao cậu lại bênh vực cô ấy?"],[5042,5150,"Không, vì suy cho cùng,"],[5150,5342,"như tôi đã nói, tôi luôn bênh chị em."],[5438,5534,"Hơi điên rồ đấy."],[5568,5822,"Tôi thấy cụm từ \"bênh chị em\""],[5843,5997,"đang bị dùng quá vô tội vạ."],[5997,6035,"Vậy sao?"],[6035,6122,"Nhưng dù sao thì,"],[6122,6193,"tôi vẫn giúp"],[6193,6364,"cậu nhận ra, anh ta là"],[6423,6481,"người thế nào mà."],[6485,6606,"Có nhiều kiểu"],[6606,6710,"chị em mà. - Chúng ta vẫn,"],[6710,6806,"Chúng ta vẫn mới bắt đầu."],[6848,6931,"Ừ, đây mới là"],[6931,7027,"buổi hẹn đầu. - Vẫn còn sớm mà."],[7027,7077,"Ừ."],[7077,7232,"Một buổi hẹn đáng nhớ nhỉ?"]],"65":[[66,287,"Tất cả những gì anh muốn làm là"],[442,579,"ân ái với em."],[579,629,"Ồ."],[679,775,"Táo bạo đấy."],[809,909,"Nhưng tôi xin khiếu."],[909,975,"Vậy, anh có biết"],[975,1051,"chuyện gì đang xảy ra không?"],[1051,1134,"Anh có biết chuyện gì đang diễn ra không?"],[1134,1209,"Bọn tôi đang hẹn hò-"],[1209,1263,"Được rồi."],[1263,1355,"Cảm ơn anh đã ghé qua."],[1355,1488,"Bài hát của anh rất hay."],[1488,1605,"Tạm biệt."],[1618,1814,"Tôi vẫy tay chào đây."],[1814,1864,"Ừ."],[1960,2043,"Chúc một ngày tốt lành."],[2064,2139,"Chuyện gì thế này?"],[2139,2214,"Anh không biết,"],[2214,2323,"anh không biết đó là chuyện gì."],[2323,2506,"Đó là chuyện gượng gạo nhất"],[2506,2656,"anh từng phải trải qua"],[2656,2756,"trong suốt cuộc đời mình."],[2957,3061,"Giọng hát tuyệt lắm,"],[3061,3148,"chúng tôi rất thích."],[3148,3257,"Anh không biết anh ta có cưa đổ em không,"],[3257,3516,"nhưng em có muốn tiếp tục"],[3611,3695,"buổi hẹn thứ hai không?"],[4300,4429,"Anh biết không, đã có vài người"],[4491,4625,"bước vào và thực sự"],[4625,4692,"thu hút sự chú ý của em"],[4696,4758,"Không, em đùa thôi."],[4758,4917,"Em rất muốn có buổi hẹn thứ hai!"],[4917,5005,"Được, tuyệt quá, tuyệt vời."],[5100,5146,"Ừ."],[5176,5230,"Ồ, không."],[5230,5405,"Cô ấy đồng ý buổi hẹn thứ hai rồi sao?"],[5430,5522,"Anh ta là kẻ nói dối."],[5538,5634,"Anh hơi lo là"],[5634,5722,"em đã bắt đầu tin"],[5722,5893,"vào mấy đường chỉ tay đó."],[5893,5964,"Nhưng."],[6018,6147,"Nhưng, anh rất vui vì"],[6181,6306,"em muốn tiếp tục buổi hẹn thứ hai."],[6306,6435,"Em đành phải đồng ý thôi."],[6489,6560,"Ừ."],[6602,6677,"Anh rất mong chờ."],[6677,6744,"Nghe hay đấy."],[6827,6940,"Nhưng với đúng người,"],[6990,7057,"em nghĩ là,"],[7173,7319,"ở một nơi và thời điểm nhất định,"],[7319,7524,"anh sẽ không phải kìm nén gì cả."],[7540,7624,"Anh có muốn mối quan hệ này"],[7670,7778,"tiến triển không?"],[7786,7878,"Anh nghĩ là anh sẵn sàng."],[7899,8062,"Mối tình cuối và duy nhất của anh"],[8062,8137,"là hồi lớp tám,"],[8137,8216,"và anh hoàn toàn bị"],[8216,8299,"bạn bè ép buộc phải quen cô ấy."],[8320,8508,"Bởi vì bạn của cô ấy"],[8508,8616,"nói làm vậy sẽ khiến cô ấy vui."],[8616,8742,"Anh phải tận hưởng cuộc sống chứ. Anh phải sống,"],[8742,8867,"Anh cứ trải nghiệm mọi thứ thôi."],[8867,8954,"Anh phải ngừng nghĩ ngợi đi."],[8963,9054,"Anh có muốn em"],[9054,9125,"mát-xa cho không?"],[9146,9288,"Mát-xa á, ý anh là-"],[9288,9413,"Đó có phải là chuyện sẽ,"],[9413,9576,"thường xuyên xảy ra không?"],[9576,9705,"Anh vừa nghe ai đó nhắc đến"],[9705,9909,"thầy bói xem chỉ tay kìa!"],[9955,10022,"Chúng tôi không cần đâu."],[10076,10147,"Mình không cần đâu nhỉ?"]],"66":[[4,233,"Hội chị em có đủ kiểu."],[233,333,"Chúng ta vẫn mới bắt đầu."],[371,437,"Đúng, đây là buổi"],[437,550,"hẹn đầu. - Vẫn mới bắt đầu mà."],[550,600,"Đúng vậy."],[650,784,"Điều này chẳng giúp tôi xích lại gần"],[784,871,"Chris chút nào."],[896,1105,"Phải. - Đỉnh quá!"],[1167,1234,"Ôi trời ơi."],[1234,1484,"Cậu làm tốt lắm. - Quá đỉnh."],[1484,1609,"Bọn tôi kiểu kinh ngạc luôn! - Phải."],[1609,1722,"Làm tốt lắm. - Dũng cảm đấy."],[1722,1818,"Tuyệt lắm. - Cậu tuyệt lắm."],[1818,1889,"Tuyệt lắm."],[1889,1997,"Hôm nay thật"],[2093,2231,"khác thường"],[2243,2377,"đối với buổi hẹn hò đầu tiên."],[2427,2531,"Đúng vậy."],[2627,2748,"Trên thang điểm 10,"],[2748,2857,"vui vẻ hay tồi tệ"],[2857,2936,"Anh chấm mấy điểm?"],[3332,3470,"Này, nhìn điệu bộ của cô ấy kìa."],[3470,3570,"Cô ấy đang cáu."],[3624,3762,"Cô ấy hoàn toàn khép mình."],[3762,3853,"Anh làm tốt lắm."],[3870,3991,"Ôi trời ơi."],[4008,4175,"Chúng ta chắc chắn có vài"],[4266,4371,"điều cần"],[4500,4650,"tìm hiểu về nhau,"],[4650,4746,"khám phá, - Phải."],[4746,4863,"và, anh biết đấy."],[4863,4921,"Cô có nghĩ mình"],[4921,5000,"giành được anh ấy không? - Có."],[5000,5038,"Cô nghĩ mình"],[5038,5146,"chắc thắng chứ? - Có."],[5163,5263,"Ý tôi là, anh ấy để tôi ngồi lên đùi."],[5263,5413,"Tôi bước vào và ngồi lên đùi anh ấy."],[5434,5584,"Sẽ không có cô gái nào khác ngồi lên đùi anh"],[5584,5680,"ở buổi hẹn thứ hai."],[5718,5860,"Chà, đâu ai biết được."],[5880,6026,"Không biết chuyện gì sẽ xảy ra đâu."],[6085,6131,"Cứ chờ xem sao."],[6131,6277,"Có lẽ lần tới anh nên bảo cô ấy"],[6277,6381,"đừng ngồi lên đùi anh nữa."],[6489,6556,"Vậy em sẽ hẹn hò"],[6556,6702,"lần thứ hai với anh chứ, Tigerlily?"],[7032,7186,"Vâng, em sẽ hẹn hò lần thứ hai"],[7186,7273,"với anh."],[7436,7586,"Căng đấy."],[7620,7811,"Emily bước vào và ngồi lên đùi anh."],[7832,8062,"Nghe này, anh có tình cảm với em."],[8062,8233,"Nói thật là giờ em"],[8233,8420,"đang hối hận vì đã bước lên chọn anh."],[8479,8546,"Em nói sao?"],[8546,8650,"Anh thấy rõ là chúng ta"],[8650,8787,"sẽ không thể sống sót ra khỏi đây."]],"67":[[20,108,"Hẹn hò lần hai"],[108,279,"là thử thách mát-xa."],[279,425,"Các cặp đôi sẽ"],[425,633,"tương tác thân mật với nhau."],[633,796,"Ồ, anh ấy cởi áo cô ấy kìa."],[796,950,"Ồ, anh ấy cởi hẳn ra luôn."],[950,1117,"Và họ sẽ cố gắng"],[1117,1305,"tạo kết nối gợi cảm."],[1343,1476,"Có chuyện quá khứ nào em cần biết không?"],[1476,1689,"Trong khi né những kẻ phá bĩnh độc thân"],[1689,1801,"sắp ập đến"],[1801,1918,"LIÊN TỤC!"],[1918,2139,"Hình như có cả máy phát hiện nói dối."],[2139,2235,"Này, đến lượt cô ấy thì sao?"],[2235,2285,"Tôi không biết,"],[2285,2394,"sao lại đổ hết lên đầu tôi?"],[2552,2690,"Một trong hai ta được mát-xa chứ?"],[2690,2794,"Nên thế chứ."],[2915,3007,"Oẳn tù tì,"],[3007,3086,"ra!"],[3269,3365,"Tuyệt."],[3420,3486,"Được thôi"],[3591,3657,"Anh cứ việc"],[3657,3824,"tận hưởng mát-xa đi."],[3824,3903,"Cậu ta bắt cô ấy à?"],[3903,4033,"Cậu ta đang được mát-xa kìa!"],[4033,4137,"Chà!"],[4137,4245,"Em biết mát-xa chứ?"],[4245,4283,"Không."],[4283,4320,"Được rồi."],[4320,4466,"Thử xem sao nhé."],[4842,4979,"Em dùng dầu nhé?"],[5030,5134,"Chắc chắn rồi. - Thật sao?"],[5134,5238,"Chắc chắn rồi. - Được."],[5238,5305,"Mọi người muốn nghe"],[5305,5417,"chuyện điên rồ này không?"],[5417,5593,"Cô ta hất nước vào tớ lúc ăn trưa."],[5593,5676,"Làm gì có?"],[5676,5768,"Cô ta không làm vậy."],[5768,5822,"Cô ta có làm."],[5822,5872,"Tớ có thấy."],[5872,6097,"Tớ đang ngồi cạnh Chris,"],[6097,6260,"và bọn tớ chỉ đang nói chuyện,"],[6260,6443,"rồi cô ta,"],[6443,6564,"nhoài người qua bàn"],[6639,6777,"Và hất hết lên người tớ."],[6777,6906,"Để làm loạn lên. - Không thể nào."],[6906,6998,"Thật mà! - Là lỡ tay à?"],[6998,7169,"Paul thấy mà. - Tớ có thấy."],[7169,7340,"Chà, tớ không biết có phải lỡ tay không."],[7340,7436,"Chúng ta có nên nói về"],[7436,7611,"hôm qua và buổi hẹn hò chứ?"],[7611,7736,"Anh thấy thế nào?"],[7736,7824,"Ừ thì, nó"],[7920,8041,"Cũng ổn."]],"68":[[50,116,"Thú vị đấy."],[116,287,"Trông giống,"],[287,429,"một chiếc bàn mát-xa."],[429,517,"Ừ."],[517,625,"Có vài"],[625,767,"Chắc là anh nợ em một lần đấy."],[767,888,"Buổi hẹn hò của anh ấy"],[888,1038,"lúc tôi vắng mặt."],[1038,1172,"Chuyện đó làm tôi rất bồn chồn"],[1172,1347,"vì anh ấy có kể đôi chút"],[1347,1509,"về việc đó, nhưng tôi không hề biết"],[1509,1626,"có cô gái đã hôn anh ấy."],[1626,1801,"Và họ kiểu như"],[1801,1997,"rất tâm đầu ý hợp với nhau."],[1997,2093,"Anh làm cho tốt vào đấy."],[2093,2398,"Phản ứng ban đầu của tôi là khép mình"],[2398,2602,"với Sherif vì tôi kiểu, ôi trời,"],[2602,2769,"nghe chuyện đó thật hụt hẫng."],[2769,2982,"Nhưng rốt cuộc tôi vẫn cho anh ấy,"],[2982,3115,"một cơ hội khác."],[3115,3253,"Có hai loại chai xịt."],[3253,3324,"Em nghĩ anh nên"],[3324,3390,"dùng loại nào?"],[3390,3490,"Nâu hay xanh lá?"],[3520,3636,"Chắc là màu nâu?"],[3757,3899,"Bắt đầu thôi nào."],[3899,4033,"Ôi, lạnh quá!"],[4054,4145,"Á!"],[4295,4446,"Cậu ta mới thoa lên thôi!"],[4446,4596,"Trời ơi, lạnh quá đi."],[4596,4683,"Đâu, ấm lắm mà."],[4683,4779,"Cậu ta xịt thêm kìa."],[4779,4896,"Nhìn mặt cô ấy kìa!"],[4934,5109,"Anh xịt bao nhiêu thế?"],[5109,5205,"Bê bết quá."],[5205,5301,"Bê bết thật."],[5355,5492,"Anh nghĩ mình có thể cởi cái này ra"],[5492,5626,"để dễ mát-xa hơn"],[5626,5734,"Ừ."]],"69":[[8,83,"Nóng quá đi,"],[83,191,"nhìn anh đổ mồ hôi này."],[350,475,"Trời, dễ thương quá!"],[517,700,"Ngày xưa anh hay mát-xa cho chị gái,"],[700,809,"không có chuyện loạn luân đâu."],[934,1001,"Hồi anh còn nhỏ,"],[1001,1084,"vì chị ấy lớn hơn anh nhiều,"],[1084,1222,"chị ấy thường trả anh một đô la"],[1222,1384,"cho mỗi phút mát-xa."],[1384,1497,"Thích vậy."],[1497,1605,"Nên,"],[1605,1693,"lạ lùng thay,"],[1693,1801,"những gì anh đang làm bây giờ"],[1801,1939,"đều học từ chị anh đó."],[1939,2031,"Tuyệt thật."],[2031,2077,"Ừ."],[2077,2285,"Cậu ta từng mát-xa cho chị gái,"],[2285,2523,"mà không có ý loạn luân sao?"],[2523,2694,"Cậu ta làm gì vậy? - Tạ ơn trời ư?"],[2694,2773,"Sao cậu lại phải"],[2773,2840,"rào trước chuyện đó?"],[2840,2911,"Kỳ cục thật. - Nghe"],[2911,2986,"Kỳ cục thật. - tệ quá."],[2986,3069,"Sao cậu ta lại"],[3069,3157,"tự nhiên nhắc chuyện đó nhỉ?"],[3157,3261,"Thành thật thì em thấy sao?"],[3261,3349,"Thích lắm."],[3349,3440,"Anh rất tự ti,"],[3440,3528,"vì tay hay đổ mồ hôi,"],[3528,3649,"mong là dầu mát-xa che được."],[3649,3745,"Anh không thích bị gọi là"],[3745,3870,"chàng trai tay đẫm mồ hôi đâu."],[3870,3995,"Không, đâu có. - Không á?"],[3995,4070,"Không."],[4145,4258,"Thế còn,"],[4258,4362,"các mối quan hệ cũ"],[4362,4421,"em có... ờ"],[4421,4646,"vướng bận gì anh cần biết không?"],[4646,4800,"Khoảng một năm rưỡi trước,"],[4800,4913,"em vừa kết thúc"],[4913,5055,"mối tình dài 12 năm."],[5113,5255,"12 năm á?"],[5255,5376,"Nhìn mặt anh ấy kìa!"],[5376,5526,"Cái đ** gì vậy?"]],"70":[[4,145,"Buổi hẹn đầu khá thú vị."],[145,275,"Có rất nhiều chuyện"],[275,362,"đã xảy ra."],[362,433,"Ừ."],[433,684,"Buổi hẹn thứ hai khó nhằn hơn,"],[684,788,"chắc chắn là thế."],[788,921,"Vì chuyện duy nhất mà tôi"],[921,1038,"và cô ấy thật sự nói tới"],[1038,1088,"giữa buổi hẹn đầu"],[1088,1188,"và buổi thứ hai"],[1188,1297,"là chuyện cô nàng"],[1297,1447,"Emily tới ngồi lên đùi tôi."],[1514,1726,"Emily tới và ngồi lên đùi anh."],[1818,1981,"Anh thấy sao về chuyện đó?"],[2047,2193,"Ờ"],[2264,2335,"Phải, Emily."],[2335,2410,"Ồ, hy vọng"],[2410,2573,"cô ấy sẽ không hắt nước vào anh nữa."],[2573,2627,"Lúc đó kỳ cục lắm."],[2627,2794,"Có vẻ anh thích thế mà."],[2794,2919,"Anh kiểu"],[2977,3169,"Anh kiểu cứ để yên cho nó xảy ra."],[3169,3299,"Có vẻ anh thích thế."],[3324,3453,"Anh để yên mà."],[3503,3578,"Tôi chưa từng gặp chuyện đó"],[3578,3670,"khi hẹn hò bao giờ."],[3670,3707,"Được rồi,"],[3707,3770,"nếu chúng ta không thể nào"],[3770,3908,"bỏ qua được chuyện này,"],[3908,4070,"tôi sẽ cố tận hưởng buổi mát-xa."],[4091,4233,"Anh để cô ta ngồi lên đùi,"],[4233,4350,"rồi anh kiểu,"],[4350,4579,"tận hưởng chuyện đó."],[4579,4696,"Anh ấy có thể nói chuyện với tôi."],[4725,4838,"Chào."],[5342,5463,"Tôi thấy rõ là chúng ta sẽ"],[5463,5597,"không thể sống sót rời khỏi đây."]],"71":[[237,304,"Uầy!"],[304,492,"Ồ, anh ta đang cởi đồ cô ấy kìa."],[492,671,"Ồ, cởi sạch luôn kìa."],[1142,1209,"Em có muốn anh"],[1209,1380,"mát-xa cả thân dưới không?"],[1422,1484,"Ừm"],[1509,1597,"Sao lại không chứ?"],[1614,1730,"Anh làm tốt hơn hắn không?"],[1730,1901,"Anh chắc chắn làm tốt hơn."],[1901,1985,"Anh nên bảo hắn là,"],[1985,2139,"cảm ơn người anh em đã khởi động giúp tôi."],[2139,2214,"Rồi nhảy vào làm luôn."],[2389,2523,"Rõ rồi, mãnh hổ. - Ồ"],[2523,2610,"Paul đang tiến vào kìa."],[2627,2748,"Trông hắn thậm chí"],[2748,2848,"không ấn đủ lực."],[2848,2915,"Nhìn cứ như hắn"],[2915,3036,"chỉ đang xoa tay lên người cô ấy."],[3036,3136,"Hắn đang hát kìa!"],[3136,3265,"Anh có một câu hỏi."],[3265,3440,"Em có đang hứng thú với tình yêu không?"],[3440,3599,"Anh thấy em đang suy nghĩ,"],[3599,3795,"vì em không có hứng yêu đương,"],[3795,3895,"nhưng câu hỏi là thế này."],[3937,4137,"Chuyện đó thì liên quan gì đến chúng ta?"],[4137,4187,"Hãy quyết định"],[4187,4300,"đi, tại sao lại-"],[4350,4537,"Sharrouf, đúng không?"],[4667,4746,"Sharrouf à?"],[4746,4779,"Này người anh em,"],[4779,4888,"tốt nhất là anh nên gọi đúng tên tôi đi."],[4888,5038,"Tôi không rảnh để đôi co đâu."],[5038,5121,"Ồ!"],[5121,5363,"Tốt nhất là gọi đúng tên tôi đi."],[5363,5484,"Anh định cởi áo ra à?"],[5484,5597,"Ý tôi là, ta đang ở hồ bơi mà."],[5597,5793,"Tôi không thích kiểu cạnh tranh vặt vãnh"],[5793,5914,"với những kẻ không cùng đẳng cấp,"],[5914,5972,"anh hiểu ý tôi chứ?"],[5972,6068,"Chà!"],[6068,6131,"Tuyệt đấy."],[6131,6318,"Ừ, gồng cơ bắp lên đi."],[6368,6485,"Cứ tự nhiên, hát tiếp đi chứ."],[6485,6560,"Anh đang hát gì thế?"],[6681,6794,"Không phải việc của anh."],[6794,6886,"Tôi chỉ hát cho cô ấy nghe thôi."],[6886,6915,"Autumn,"],[6915,6990,"em thấy thế nào"],[6990,7102,"về bài mát-xa này?"],[7102,7169,"Ừm"],[7169,7319,"Cảm giác rất tuyệt."],[7319,7478,"Có muốn tuyệt hơn một chút không?"],[7478,7586,"Ý anh là sao?"],[7620,7716,"Ý anh là,"],[7716,7799,"em có muốn m