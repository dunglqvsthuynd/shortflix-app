n thân thật,"],[6256,6356,"rõ ràng"],[6356,6410,"và kiểu,"],[6410,6539,"hãy nghe mọi điểm mạnh của em."],[6539,6623,"Và, anh biết đấy,"],[6623,6760,"như điểm yếu lớn nhất của em là,"],[6760,6844,"em yêu quá đậm sâu."],[6844,6944,"Anh bị phàn nàn nhiều"],[6944,7077,"vì đôi tay ướt mồ hôi đấy."],[7077,7152,"Chuyện gì vậy?"],[7152,7178,"Ừ."],[7178,7219,"Tay ướt mồ hôi"],[7219,7294,"v** ra, chết tiệt."],[7294,7394,"Mọi người cứ"],[7394,7453,"nhắc đến nó mãi."],[7453,7503,"Anh không biết nữa,"],[7503,7561,"anh chỉ không,"],[7561,7653,"anh không muốn bị gọi là"],[7653,7782,"chàng trai mồ hôi tay."],[7782,7907,"Thật lòng thì, em rất tò mò"],[7907,8070,"ấn tượng đầu của anh về em."],[8070,8128,"Anh bước vào"],[8128,8191,"hồi sáng nay,"],[8191,8320,"và rồi em thấy anh."],[8320,8525,"Em để mắt đến anh luôn và tự nhủ,"],[8525,8804,"không, anh ấy đẹp trai quá!"],[8804,8942,"Đừng xạo nữa... Trời ơi, không đâu."],[8979,9063,"Em sẽ kiểu,"],[9063,9154,"liếc mắt"],[9154,9192,"kiểu như,"],[9192,9238,"cố gắng chạm"],[9238,9330,"chạm mắt rồi"],[9538,9667,"Tôi nghĩ cô ấy thực sự"],[9667,9730,"thích anh ấy. - Tôi không rõ nữa,"],[9730,9797,"nhưng tôi ủng hộ họ."],[9797,9901,"Thế à?"],[9901,9997,"Ôi, không!"],[9997,10181,"Trông họ mê nhau lắm mà!"],[10393,10627,"Anh từng trả tiền cho phụ nữ"],[10627,10689,"Robyn!"],[10689,10898,"để quay nội dung"],[10898,11048,"18+ cùng anh chưa?"]],"13":[[8,137,"Nhắc đến tình yêu,"],[137,321,"mọi thứ có thể đến rất nhanh."],[321,471,"Và đôi khi,"],[471,517,"nó có thể khiến bạn"],[517,696,"hoàn toàn suy sụp."],[696,788,"Nhưng đừng lo."],[788,884,"Trong lúc các người chơi"],[884,988,"bắt đầu buổi hẹn,"],[1096,1176,"chúng tôi sẽ trao cho các bạn"],[1176,1447,"cơ hội thứ hai... giành TIỀN MẶT."],[1447,1576,"Những cặp đôi kia"],[1576,1643,"có thể đã chọn"],[1643,1789,"người khác thay vì bạn,"],[1789,1881,"nhưng đây là cơ hội"],[1881,1976,"để bạn phục thù."],[1976,2285,"Bạn sẽ nhận được 2.000 đô la"],[2285,2389,"cho mỗi cặp đôi"],[2389,2464,"mà các bạn"],[2464,2702,"chia rẽ thành công. - Tuyệt."],[2702,2852,"Vậy, hội độc thân,"],[2852,2898,"các bạn đã sẵn sàng"],[2898,3003,"cho thử thách chưa?"],[3003,3165,"Sẵn sàng."],[3574,3636,"Chà, sao giờ mọi chuyện"],[3636,3732,"lại không suôn sẻ nữa?"],[3841,3916,"Không!"],[4037,4175,"Anh còn nhảy cho cô ta xem."],[4175,4291,"Tôi không hiểu lầm đâu."],[4291,4366,"Chắc giờ anh đang được"],[4366,4487,"mát-xa kép rồi."]],"14":[[8,196,"Buổi hẹn đầu tiên của các cặp đôi"],[196,396,"là Thử thách Đồng bộ Nhịp tim."],[396,533,"Mục đích của buổi hẹn này là để"],[533,709,"các cặp đôi đồng bộ nhịp tim,"],[709,938,"nhằm xây dựng sự gắn kết và niềm tin,"],[938,1138,"đồng thời xem liệu các cặp đôi"],[1138,1297,"có thoải mái bên nhau hay không."],[1309,1488,"Và dĩ nhiên, tất cả những điều này"],[1488,1589,"sẽ diễn ra"],[1589,1718,"khi hội độc thân theo dõi buổi hẹn"],[1718,1843,"qua màn hình,"],[1843,1981,"và phá đám chuyện của họ."],[2181,2348,"Mỗi cặp đôi bị họ chia rẽ,"],[2348,2677,"họ sẽ nhận được 2.000 đô la."],[2711,2790,"Đam mê-"],[2790,2873,"Em có đồng ý"],[2873,3003,"cho anh hôn lên má em không?"],[3003,3199,"Sự thao túng và đòn tâm lý"],[3199,3269,"kết hợp cùng-"],[3269,3390,"Anh để cô ta ngồi lên đùi mình."],[3390,3632,"Và trận chiến quyến rũ đỉnh cao."],[3695,3741,"Chào."],[3787,3878,"Chào em, sao rồi?"],[3899,4041,"Rất tốt, vui được gặp lại anh."],[4041,4133,"Ừ, em"],[4133,4233,"có hồi hộp không?"],[4245,4304,"Em hồi hộp à?"],[4304,4416,"Hay chỉ là hào hứng khi gặp anh?"],[4416,4554,"Em không biết nữa."],[4583,4729,"Mới là ngày thứ hai"],[4729,4821,"của chương trình hẹn hò,"],[4821,4979,"à không, ngày đầu tiên chính thức chứ."],[4979,5188,"Nên có rất nhiều cảm giác"],[5188,5359,"vui vẻ, phấn khích,"],[5359,5576,"như ngày đầu tiên đi học vậy."],[5597,5693,"Có vẻ như chúng ta có một chiếc"],[5693,5801,"máy đo nhịp tim."],[5801,6093,"Chắc chúng ta nên bắt đầu thôi nhỉ."]],"15":[[12,120,"Được rồi, chúng ta có nên-"],[120,216,"Nên làm gì cơ?"],[221,329,"Dùng mấy cái"],[396,471,"máy đo này á?"],[508,625,"Thật đấy, em dùng tiếng Anh"],[625,746,"giỏi quá cơ."],[759,834,"Cảm ơn anh."],[834,884,"Không có gì."],[942,1046,"Tới luôn đi Tiger!"],[1238,1301,"Cậu làm được mà!"],[1301,1397,"Andres, cháy lên nào."],[1397,1472,"Triển thôi!"],[1505,1672,"Cuộc trò chuyện giữa họ"],[1672,1789,"như kiểu,"],[1805,1897,"rất hời hợt."],[1897,2064,"Nên tôi không tin là họ"],[2064,2198,"có kết nối gì với nhau."],[2198,2419,"Và tôi thấy"],[2419,2552,"Tigerlily rất dễ thương."],[2590,2740,"Thân hình linh hoạt của tuổi 30"],[2740,2865,"với tâm trí của đứa trẻ lên 9."],[2865,3115,"Đúng, tôi nghĩ đó là câu trả lời chuẩn đấy."],[3115,3403,"Chấp nhận rủi ro bị Alzheimer để"],[3420,3503,"Ừ. Tệ cỡ nào cơ?"],[3503,3620,"Gia đình tôi không có tiền sử bệnh này nên-"],[3620,3682,"Chào em."],[3682,3753,"Ồ!"],[3803,3908,"Anh ta vừa hôn cô ấy kìa!"],[3924,3999,"Em sao rồi?"],[3999,4141,"Em rất tuyệt."],[4141,4187,"Thế à?"],[4195,4254,"Vâng."],[4254,4341,"Sao rồi anh bạn?"]],"16":[[779,850,"Tôi không biết chuyện gì đang xảy ra nữa."],[850,955,"Cô ấy không tới, hay là"],[996,1209,"Không thể tin là tôi bị cho leo cây."],[1209,1351,"Buổi hẹn đầu tiên rõ ràng đã"],[1351,1468,"không theo kế hoạch chút nào."],[1468,1655,"Tôi hoàn toàn bị cho leo cây."],[1676,1793,"Tôi đã ngồi đợi Autumn"],[1793,1972,"xuất hiện suốt một lúc lâu."],[1993,2181,"Chỉ biết giết thời gian, và tôi"],[2181,2360,"càng lúc càng thấy bực bội."],[2385,2489,"Cũng hơi thất vọng một chút,"],[2489,2540,"vì tôi đã"],[2540,2669,"rất mong chờ"],[2694,2882,"buổi hẹn đầu của chúng tôi, và rồi"],[2898,2944,"Nhưng sau đó,"],[2944,2990,"Nhưng sau đó,"],[2990,3119,"đã có một cú bẻ lái bất ngờ."],[3190,3249,"Chào anh."],[3249,3311,"Chào em."],[4258,4383,"Hôm qua có chuyện gì vậy?"],[4383,4466,"Chuyện là thế này,"],[4466,4600,"em thực sự rất muốn đến,"],[4600,4708,"nhưng em lại gặp tai nạn."],[4729,4867,"Em không sao, nhưng xe thì hỏng."],[4867,5055,"Nhưng em không muốn anh nghĩ"],[5096,5296,"đó là vì em không có tình cảm gì."]],"17":[[158,225,"Được rồi."],[271,437,"Được rồi."],[454,529,"Xin lỗi, anh chỉ là,"],[588,692,"anh thích thoải mái hơn."],[692,779,"Em hiểu ý anh chứ?"],[788,934,"- Thú vị đấy. - Và anh đang hồi hộp."],[980,1055,"- Ôi trời ơi. - Không, không, không."],[1055,1222,"- Được rồi, làm thôi. - Không, không, không."],[1288,1380,"Được rồi, vậy thì,"],[1380,1438,"chắc là chúng ta sẽ đo"],[1438,1509,"nhịp tim của mình."],[1509,1672,"Chà, ở đây bắt đầu nóng lên rồi đấy."],[1672,1751,"Anh bảo rồi mà."],[1751,1851,"Em cũng có thể cởi áo ra,"],[1851,1914,"nếu muốn."],[1914,2027,"Anh biết không, cơ ngực đó thực sự"],[2027,2127,"làm em bất ngờ lúc đầu,"],[2127,2293,"và em coi đó là một tài năng."],[2293,2348,"Ôi trời."],[2348,2398,"- Em làm anh... - Anh biết đấy."],[2398,2610,"hồi hộp đó cô gái, anh bảo rồi."],[2610,2715,"Nhịp tim đang tăng lên."],[2715,2961,"Ghét ghê, ghét ghê, ghét ghê."],[2961,3036,"Thôi nào."],[3036,3140,"Em ghét cảm giác này quá."],[3148,3411,"Nó thực sự làm em xốn xang."],[3411,3591,"Ôi trời, ừm, đúng vậy."],[3611,3778,"Ôi, sh*t, được rồi."],[3778,3887,"Nhịp tim cô ấy đang tăng kìa."],[3887,3999,"Này, thấy chưa."],[4049,4116,"Cái gì thế?"],[4116,4208,"Vừa xong đó hả?"],[4208,4404,"Ôi trời, tôi không thể rời mắt."],[4404,4479,"Cứ như là"]],"18":[[37,145,"Càng nói chuyện với anh,"],[145,271,"em càng muốn tìm hiểu anh,"],[271,358,"càng muốn trò chuyện nhiều hơn."],[358,437,"Nên em... - Từ từ thôi."],[437,571,"Em rất mong chờ"],[571,704,"được tiếp tục tìm hiểu anh."],[721,804,"Cảm ơn em."],[813,892,"Dù họ kiểu,"],[892,971,"nói hơi lan man,"],[971,1096,"nhưng trò chuyện rất vui."],[1096,1259,"Tôi nghe nói đó là"],[1259,1376,"máy theo dõi."],[1376,1451,"Máy đo nhịp tim."],[1451,1555,"Tôi cảm thấy nếu cậu"],[1555,1685,"có chuyện muốn giấu,"],[1685,1772,"nhịp tim sẽ tố cáo cậu."],[1776,1864,"Không, không có gì."],[1864,1972,"Không giấu gì cả. - Tôi cũng vậy."],[1972,2060,"Tôi chẳng biết gì đâu."],[2060,2164,"Thật điên rồ khi cậu ấy không"],[2164,2243,"dùng đến mắt cá chân"],[2243,2381,"vì đầu gối cậu ấy chệch ra rồi!"],[2381,2473,"Cậu làm được mà!"],[2473,2548,"Tuyệt lắm."],[2731,2882,"Những người đẹp ở sân khấu một."],[2882,2998,"Buona sera."],[3028,3203,"Chào, em khỏe không, Robyn?"],[3203,3265,"Em khỏe."],[3265,3299,"Chào."],[3299,3436,"Ôi trời, anh khỏe không?"],[3436,3495,"Cho em sao?"],[3495,3570,"Ừ. - Không, cái này cho cô ấy."],[3570,3661,"Xin hãy nhận lấy."],[3661,3737,"Thô lỗ quá đấy, anh bạn."],[3737,3816,"Cái này cho em."],[3832,3953,"Không, tôi đang bận tay."],[3970,4024,"Cậu không phải người Ý."],[4024,4079,"Cậu không biết quy tắc đâu."],[4079,4229,"Không được chạm vào quà của phái nữ."],[4229,4341,"Anh nghĩ tôi thô lỗ"],[4341,4592,"khi chạm vào món quà này, còn anh chen ngang"],[4592,4733,"buổi hẹn hò thì không sao à?"],[4733,4825,"Tôi chỉ cần đảm bảo"],[4825,4967,"hai người vẫn ổn,"],[4967,5084,"mọi chuyện sao rồi-"],[5084,5188,"Cảm ơn anh đã quan tâm."],[5188,5342,"Giữa hai người có phản ứng hóa học."],[5347,5405,"Thật đẹp."],[5405,5480,"Đúng là có đấy."],[5480,5584,"Anh là một-"],[5584,5663,"Anh ta đang nói dối."],[5663,5860,"Cô ấy chẳng thích việc bị chen ngang chút nào."],[5860,5968,"Cô ấy không hề thích anh ta."],[5968,6097,"Kiểu như cô ấy chẳng mảy may để tâm."],[6097,6197,"Anh xin một sợi lông mi được không?"],[6197,6368,"Ôi trời, các cậu,"],[6368,6489,"cuốn lấy nhau quá rồi đấy."],[6514,6585,"Đẹp đôi thật."],[6844,7007,"Trời đất ơi."],[7007,7115,"Ôi không."],[7115,7240,"Họ, họ đang-"],[7240,7403,"Ấn tượng đấy. - Đáng sợ quá."],[7403,7503,"Thế anh định đưa cô ấy đi đâu"],[7503,7574,"trong buổi hẹn đầu tiên?"],[7599,7736,"Anh có thể nấu mì Ý cho em."],[7736,7937,"Nghe đơn giản nhỉ. - Em thích mì Ý."],[7937,8049,"Anh biết nấu ăn sao?"],[8058,8191,"Ồ, cho em công thức đỉnh nhất xem nào."],[8191,8295,"Mì ống Rigatoni sốt Vodka."],[8295,8412,"Em mua món đó ở Ralph's."],[8412,8466,"Em lấy-"],[8466,8541,"Em mua ở Ralph's sao?"],[8541,8671,"Đúng vậy. - Ồ, không được rồi."],[8671,8729,"Anh tự nấu món đó cơ."],[8729,8829,"Anh cũng là một đầu bếp xịn đấy."],[8854,8946,"Ồ, ra vậy."],[8946,9013,"Đúng, anh biết nấu ăn."],[9013,9142,"Rất vui được làm bữa tối cho em."],[9142,9200,"Cho cả hai chúng ta!"],[9200,9300,"Chúng ta có thể mở tiệc riêng tư"],[9300,9388,"và anh nấu ăn cho bọn tôi."],[9388,9505,"Anh có định đưa cô ấy"],[9505,9609,"về ra mắt bố mẹ không?"]],"19":[[37,129,"Có vẻ như chúng ta đang đeo"],[129,266,"máy đo nhịp tim, nên"],[283,379,"Được rồi. - Vậy hãy bắt đầu"],[379,496,"thôi nào!"],[496,608,"Cậu biết không, trông anh ta"],[608,746,"hơi có nét giống George Washington."],[746,867,"Ồ!"],[896,1021,"Không, anh ta có"],[1021,1063,"cặp lông mày khá giống."],[1063,1146,"Trông khá là giống"],[1146,1242,"George Washington."],[1242,1413,"Trước khi gọi điện thoại,"],[1413,1488,"anh có nhẩm trước"],[1488,1580,"những gì mình định nói không?"],[1601,1668,"Ồ, chà."],[1676,1772,"Khi đến quầy drive-through"],[1772,1906,"của Starbucks, anh có kiểu,"],[1918,2018,"ngồi trong xe,"],[2018,2118,"và nhẩm trước đồ mình gọi không?"],[2118,2164,"Ồ, có chứ."],[2164,2327,"Anh có mắc chứng sợ xã hội không?"],[2327,2431,"Ồ, có."],[2502,2585,"Triển đi người anh em."],[2656,2765,"Phá đám họ đi."],[2802,2840,"Làm đi."],[2861,2944,"Anh định nói, em biết đấy, rồi lại quên mất."],[2944,3044,"Thế là anh lại đi hỏi họ"],[3044,3128,"mấy câu như,"],[3128,3265,"bạn nghĩ tôi nên gọi gì?"],[3278,3390,"Chào mọi người."],[3395,3495,"Sao rồi? -Chào."],[3495,3666,"Olivia, trông em rất xinh đẹp."],[3666,3737,"Người anh em, Jude."],[3737,3820,"Ừ, sao rồi ông bạn?"],[3899,3962,"Ừ, thì"],[4016,4058,"Chào."],[4099,4187,"Nhớ cậu lắm đấy, anh bạn."]],"20":[[12,133,"Em không muốn anh nghĩ rằng,"],[196,400,"là do em không có cảm tình với anh."],[429,479,"Buổi hẹn đầu tiên"],[479,579,"đáng lẽ chúng ta đã có,"],[579,725,"trên đường đến trường quay,"],[775,917,"em đã bị tai nạn xe."],[934,1042,"Em có làm anh buồn không?"],[1138,1184,"Có chứ, ý anh là,"],[1184,1263,"Em xin lỗi."],[1263,1418,"Anh đã rất háo hức chờ buổi hẹn."],[1418,1564,"Rồi em lại không xuất hiện,"],[1564,1743,"anh có cảm giác như bị cho leo cây."],[1743,1822,"Chắc chắn là làm anh thấy"],[1822,1885,"hơi hụt hẫng,"],[1885,1981,"em biết mà? - Không, ôi trời ơi."],[1981,2010,"Không mà."],[2010,2097,"Nhưng thật lòng thì,"],[2097,2344,"giờ anh lại thấy thương em."],[2344,2427,"Ý anh là,"],[2427,2506,"em hoàn toàn ổn chứ?"],[2531,2606,"Rồi sẽ ổn thôi."],[2648,2765,"Nhưng giờ em ở đây rồi."],[2777,2844,"Nên... - Được rồi."],[2844,2907,"Chà,"],[2944,3048,"ý anh là, giờ chúng ta có"],[3048,3148,"cơ hội thứ hai, nên"],[3148,3228,"Vâng."],[3244,3353,"Cùng xem hai ta tiến triển tới đâu,"],[3353,3395,"nhé?"],[3407,3628,"Đầu óc tôi hơi bấn loạn một chút"],[3628,3870,"khi bước vào buổi hẹn đầu với Sherif."],[3870,3958,"Chỉ vì"],[4004,4208,"phải, tôi đã gặp tai nạn"],[4208,4316,"vào hôm trước đó."],[4346,4421,"Mong là anh ấy"],[4421,4571,"không để bụng chuyện đó."],[4617,4696,"Bạn có hồi hộp không?"],[4754,4829,"Chắc là chờ xem thế nào."]],"21":[[8,62,"Chào."],[87,137,"Ồ!"],[162,262,"Xin lỗi vì đến muộn."],[279,316,"Xin chào."],[316,379,"Em dạo này sao rồi?"],[392,446,"Bạo thật."],[508,600,"Anh ta thực sự"],[600,688,"- Nhìn mặt anh ta kìa. - đã thản nhiên"],[688,763,"hôn cô ấy."],[763,834,"Nhìn mặt anh ta kìa."],[834,884,"Sao rồi?"],[884,938,"Em khỏe chứ?"],[980,1026,"Khỏe."],[1051,1155,"Tôi vẫn phải cầm cái này à?"],[1155,1222,"Vậy"],[1222,1267,"Được rồi."],[1267,1372,"Xin lỗi vì anh đến muộn."],[1372,1472,"Anh vừa tan làm."],[1472,1655,"Nhưng rất vui vì anh đã đến được."],[1864,1993,"Nhìn gân cổ anh ta kìa."],[2077,2227,"Anh đang nghĩ,"],[2227,2352,"em có muốn đi đâu khác không?"],[2377,2489,"Em có muốn đi chỗ khác á?"],[2494,2544,"Ừ."],[2548,2610,"Chắc là không đâu."],[2610,2690,"Đi đâu cơ?"],[2711,2781,"Ồ."],[2973,3036,"Thế,"],[3036,3107,"kể tụi này nghe về anh đi."],[3174,3236,"Gì nhỉ,"],[3236,3361,"mối tình gần nhất của anh là bao giờ?"],[3370,3474,"Anh tên gì thế, ông bạn?"],[3490,3561,"Andrés."],[3599,3712,"Anh kể cho tụi tôi chứ?"],[3712,3803,"Về mối tình trước đó á?"],[3803,3845,"Ừ."],[3845,3920,"- Tôi tò mò đấy. - Sao lại không?"],[3920,3995,"Mọi người muốn biết gì?"],[3995,4154,"Tại sao lại không"],[4237,4300,"thành đôi?"],[4312,4396,"Tôi quen cô ấy,"],[4483,4571,"lúc cô ấy đang hẹn hò"],[4571,4658,"với bạn trai."]],"22":[[25,66,"Nhớ cậu quá."],[66,171,"Cậu là anh em của tôi mà."],[171,316,"Chúng ta đã cùng trải qua bao chuyện."],[316,421,"Ừ, ừ, chắc chắn rồi."],[571,684,"Như cái lần đó,"],[684,788,"lúc chúng ta ở bãi biển."],[809,909,"Tôi rất thích đi biển."],[955,1163,"Cậu say bí tỉ đến mức bất tỉnh"],[1163,1309,"trước mặt bao nhiêu cô gái."],[1313,1518,"Chiến thuật của tôi chỉ là"],[1559,1776,"làm cậu ta bẽ mặt trước cô ấy,"],[1805,1906,"để kiểu như,"],[1926,2085,"gieo vào đầu cô ấy suy nghĩ"],[2085,2210,"rằng có thể cậu ta có"],[2210,2410,"một quá khứ mờ ám hay gì đó."],[2627,2731,"Cậu ta đang lo lắng kìa."],[2740,2865,"Chà, lúc đó đâu có nhiều gái đến thế."],[2865,2969,"Ừ, nó chỉ giống như kiểu"],[2969,3061,"đốt lửa trại thôi mà -"],[3061,3186,"Tên này, đúng là điên thật."],[3224,3303,"Tôi đâu có ngờ"],[3303,3440,"cậu ta lại hùa theo chứ."],[3440,3557,"Thế nên kế hoạch của tôi"],[3557,3687,"hơi đổ bể một chút."],[3728,3820,"Ý tôi là, từ nhỏ chúng tôi đã"],[3820,3916,"đá bóng cùng nhau rồi."],[3916,4033,"Những chuyện đã xảy ra"],[4033,4099,"trong quá khứ,"],[4154,4287,"cũng không sai sự thật lắm đâu."],[4312,4379,"Nhưng mà,"],[4416,4575,"sai hoàn cảnh, sai thời điểm rồi ông ạ."],[4575,4692,"Kiểu như, cậu đang làm cái quái gì vậy?"],[4692,4792,"Còn nhận là anh em nữa chứ."],[4792,4909,"Thực ra bây giờ thì không."],[4909,4988,"Buổi hẹn đầu tuyệt quá ha."],[5025,5159,"Dù vậy cô ấy đang hoảng hốt kiểu,"],[5159,5271,"mấy gã này bị cái đ** gì vậy?"],[5288,5434,"Tôi nên dè chừng chuyện gì"],[5447,5509,"ở Jude đây?"],[5547,5714,"Anh rành tật xấu của anh ấy quá mà."],[5722,5784,"Khai mau đi."]],"23":[[8,212,"Nó cũng làm em rạo rực đấy."],[212,354,"Ôi trời ơi."],[404,454,"Ừ."],[517,596,"Vãi thật."],