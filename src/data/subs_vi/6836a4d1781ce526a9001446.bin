,"Anh ta ở trong quân đội."],[1839,1956,"Nên cũng khá dễ dàng"],[1956,2027,"để cô ấy giấu chuyện đó."],[2031,2248,"Và rồi, sau vài tháng,"],[2248,2414,"bọn anh chuẩn bị... - Vài tháng sao?"],[2448,2560,"Thì, anh ta không hề hay biết."],[2560,2652,"Ừ, hiểu rồi."],[2652,2752,"Bọn anh đã đón các dịp lễ,"],[2752,2911,"Giáng sinh, Valentine."],[2911,2973,"Xin lỗi nhé."],[2977,3182,"Giờ cứ như hẹn hò đôi vậy."],[3182,3249,"Em không ngại đâu."],[3249,3340,"Có lẽ anh ấy ngại đấy."],[3340,3432,"Anh có ngại."],[3457,3553,"Cô ấy từng nói"],[3553,3678,"họ không thể tách rời."],[3678,3778,"Nên chuyện này tuyệt thật."],[3791,3941,"Vậy anh muốn rời đi à?"],[3953,4008,"Không."],[4020,4070,"Không á?"],[4070,4124,"Không."],[4137,4241,"Vì chúng ta cùng chung suy nghĩ mà."],[4241,4350,"Anh không ngại, em cũng không ngại."],[4462,4612,"Giờ em đang thấy rất căng thẳng."],[4612,4692,"Đừng căng thẳng."],[4692,4771,"Mọi chuyện ổn mà."]],"25":[[29,183,"Để giới thiệu cô ấy với bố mẹ cậu."],[225,325,"Bình tĩnh, bình tĩnh."],[325,375,"Ý cậu là sao?"],[375,483,"Cậu không muốn tìm hiểu cô ấy"],[483,588,"kỹ hơn chút à?"],[633,746,"Thì, ta có thể làm cùng lúc mà."],[746,863,"Anh có thể vừa tìm hiểu em vừa"],[863,955,"Phụ huynh thích em lắm."],[955,1026,"Được rồi,"],[1026,1151,"hai người ăn ý lắm."],[1151,1280,"Không, một đôi hoàn hảo đấy."],[1280,1459,"Rất vui khi các cậu duyệt."],[1459,1597,"Phải, chà, tuyệt thật."],[1597,1710,"Cậu có câu hỏi nào cho tôi không?"],[1755,1830,"Ồ, không."],[1830,2014,"Họ gắn kết đến khó tin."],[2027,2189,"Chúng ta sẽ phải nói dối họ"],[2189,2268,"về đối phương."],[2268,2402,"Phải, chúng ta thật sự sẽ phải"],[2402,2515,"bịa chuyện thôi."],[2515,2719,"Chúc hai người mọi điều tốt đẹp."],[2736,2823,"Và"],[2823,2890,"Cảm ơn nhé."],[2890,2961,"Tôi sẽ lấy lại cái này."],[2961,3028,"Chắc rồi."],[3053,3178,"Chúc vui vẻ nhé. - Tận hưởng đi."],[3249,3340,"Không nhiều buổi hẹn của anh"],[3340,3428,"bị phá bĩnh thế này đâu."],[3428,3574,"Phải, thật sự là lần đầu đấy."],[3574,3636,"Đúng là lần đầu."],[3636,3778,"Đây là lần đầu cho rất nhiều thứ."],[3958,4087,"Tôi xin lỗi."],[4087,4137,"Này, đợi đã,"],[4137,4266,"sự tự tin vẫn còn."],[4300,4350,"Ừ."],[4350,4466,"Họ khăng khít lắm."],[4508,4604,"Khó nhằn đấy, các anh bạn."],[4604,4704,"Cô ấy còn chẳng thèm nhận hoa của cậu."],[4704,4833,"Cô ấy phũ quá."],[4904,5042,"Chúc may mắn khi vào trong đó."],[5059,5113,"Nhưng,"],[5146,5188,"Nhưng,"],[5188,5271,"sẽ rất tuyệt"],[5271,5392,"nếu ta đi ăn chút mì Ý."],[5392,5609,"Em biết, nghe tuyệt thật đấy."],[5747,5851,"Ai rước gã này vậy?"],[5851,5943,"Đúng là rắc rối nhân đôi."],[5943,6081,"Tôi sợ quá đi."]],"26":[[29,179,"Đặc biệt là năm nay,"],[179,333,"em đang cố bứt phá bản thân hơn,"],[333,458,"và thử"],[517,642,"mạo hiểm làm những việc"],[642,754,"khiến em thấy sợ."],[788,829,"Nhưng,"],[829,934,"Vậy điều khiến em sợ nhất"],[934,1034,"mà em lại rất muốn làm là gì?"],[1151,1343,"Ừm, chắc là âm nhạc."],[1343,1380,"Thật sao?"],[1380,1430,"Vâng."],[1430,1530,"Em biết không, anh cũng"],[1530,1676,"tự viết nhạc đấy."],[1676,1747,"Thật á."],[1747,1789,"Ừ."],[1843,2014,"Anh hiểu sao người ta gọi em là Autumn rồi,"],[2014,2185,"vì em làm anh 'đổ' mất rồi."],[2260,2298,"Hiểu không?"],[2339,2489,"Em có tận hai tên chính."],[2489,2631,"Anh có hai ý đồ xấu đây."],[2631,2719,"Nếu ta kết hợp chúng"],[2719,2777,"lại với nhau,"],[2777,2907,"anh biết ta có thể rời khỏi đây."],[2907,2961,"Bởi vì,"],[2986,3136,"Cứ gã nào bảo mình là rapper,"],[3136,3207,"là thôi luôn."],[3207,3274,"Tôi xin kiếu."],[3361,3520,"Dù quen em trên Love Bomb,"],[3520,3695,"nhưng bom sẽ xịt nếu tình ta bền chặt."],[3695,3803,"Đây không phải trên tivi."],[3803,3887,"Đây là đời thực."],[3916,4024,"Ta không cần băn khoăn"],[4024,4124,"nếu thấy điều đó là đúng."],[4187,4279,"Vì đúng là vậy mà."],[4358,4441,"Ồ."],[4579,4662,"Ồ, nhìn cô ấy kìa."],[4662,4808,"Ồ, cô ấy thích rồi."],[4808,4900,"Thế á?"],[4900,5013,"Cô ấy thích mà."],[5034,5130,"Tôi không nghĩ vậy đâu."],[5146,5246,"Anh vừa nghĩ ra mấy câu đó,"],[5246,5317,"ngay lúc này luôn á?"],[5330,5405,"Ừ, anh cũng không biết nữa."],[5405,5455,"Anh chỉ kiểu,"],[5455,5613,"nhìn vào mắt em rồi tự nhiên,"],[5613,5743,"cứ thế tuôn ra thôi."],[5743,5809,"Em thấy sao?"],[5868,5930,"Em thích lắm."],[5947,6031,"Patches, lại đây."],[6031,6114,"Ồ, tôi á?"],[6164,6206,"Được thôi."],[6231,6343,"Cậu sẽ được xem chỉ tay này."],[6381,6485,"Xem đi nào."],[6485,6548,"Đúng vậy."],[6548,6715,"Được rồi, bắt đầu thú vị rồi đây."],[6877,6994,"Vậy điều gì đang kìm hãm cậu?"],[6994,7098,"Kiểu như, cậu phải"],[7098,7261,"làm điều gì đó sâu thẳm"],[7261,7369,"trong tim mà cậu cứ"],[7369,7507,"giấu kín mãi ấy, hiểu không?"],[7540,7695,"Chào mọi người. - Tôi nhìn là biết, ồ."],[7695,7841,"Có chuyện gì thế? - Chào."]],"27":[[20,116,"Tigerlily,"],[179,246,"có chuyện gì vậy?"],[254,300,"Nói mình nghe cậu đang"],[300,379,"nghĩ gì thế?"],[379,588,"Mình đang rất căng thẳng"],[588,650,"ngay lúc này."],[650,834,"Mình không biết chuyện gì đang xảy ra."],[846,888,"Mình-"],[888,1071,"Chưa từng có hai chàng trai tán tỉnh cậu à?"],[1071,1292,"Anh ấy tấn công dồn dập quá,"],[1338,1434,"làm mình kiểu,"],[1509,1626,"rất sợ luôn."],[1647,1810,"Anh ấy rất biết cách ăn nói."],[1839,1931,"Ghê thật đấy."],[1931,2010,"Tới luôn đi cô gái."],[2056,2131,"Cậu làm được mà."],[2131,2223,"Làm được mà."],[2223,2281,"Tôi không tin đâu. - Mình chưa từng"],[2281,2348,"gặp chuyện này-"],[2348,2510,"Chắc chắn là cậu gặp chuyện này suốt."],[2606,2656,"Đúng không?"],[2727,2815,"Không."],[2869,3019,"Không hề. - Cậu không bao giờ đi chơi à?"],[3048,3132,"Không."],[3132,3236,"Chào mọi người."],[3236,3411,"Xin lỗi, tôi tới muộn."],[3411,3599,"Chào mừng nhập hội."],[3620,3766,"Mọi chuyện sao rồi?"],[3766,3824,"Cũng ổn."],[3824,4054,"Anh mặc chiếc áo này đẹp lắm."],[4054,4191,"Cảm ơn, mẹ anh chọn đấy."],[4191,4325,"Hơi sặc sỡ, nhưng mà,"],[4325,4475,"rất tôn cơ bắp."],[4475,4567,"Cảm ơn nhé."],[4567,4679,"Phải, anh ấy có tập gym."],[4833,4971,"Giờ cô ấy có vẻ ghen tị rồi kìa."],[5000,5100,"Cảm ơn. - Ừ."],[5109,5221,"Phải, anh ấy có tập gym."],[5255,5476,"Phải, chuyện này đang ngày càng điên rồ."]],"28":[[12,154,"Tôi không có quá nhiều điểm trừ,"],[154,225,"tôi nghĩ vậy."],[225,312,"Kiểu như,"],[346,425,"không phải như vậy đâu."],[425,525,"Mọi người biết đấy, tôi không phải"],[525,613,"Tôi có ý tốt mà."],[613,829,"Tôi sẽ không gọi đó là điểm trừ."],[829,1042,"Tôi chỉ nghĩ cậu ấy thích uống nhiều rượu."],[1042,1117,"Ý tôi là."],[1138,1234,"Ai mà"],[1234,1355,"Ở tuổi đó tôi cũng rất ngốc."],[1405,1514,"Cậu ấy đang ở tuổi đó. - Chà, ở tuổi đó,"],[1514,1593,"cậu biết đấy, tận thâm tâm."],[1593,1755,"Cậu ấy, cậu ấy hay khóc."],[1785,1843,"Đúng vậy."],[1843,1914,"Cậu ấy dễ buồn."],[1914,1989,"Tôi cung Cự Giải."],[2006,2064,"Và hay khóc"],[2064,2147,"Tôi cũng cung Cự Giải."],[2147,2202,"Thật sao?"],[2202,2248,"Ừ."],[2248,2335,"Vậy cậu hiểu mà, đúng không?"],[2335,2381,"Ừ."],[2590,2702,"Nhịp tim của anh đang tăng kìa."],[2702,2781,"Anh ổn chứ?"],[2790,2911,"Tại cà phê đấy."],[2919,3044,"Do ly cà phê anh vừa uống."],[3053,3186,"Không phải do em làm anh hồi hộp sao?"],[3232,3324,"Anh cứ thành thật đi."],[3324,3415,"Nhịp tim của anh thực sự"],[3415,3482,"đang được kiểm tra đó."],[3482,3682,"Chà, chiếc váy đó cũng không giúp ích gì."],[3745,3816,"Em rất đẹp"],[3816,3891,"trong bộ váy đó."],[3891,3962,"Cảm ơn anh."],[3991,4120,"Anh rất thích tóc uốn gợn sóng."],[4120,4266,"Em để kiểu tóc đó rất hợp."],[4312,4400,"Anh có thể nói đó là lý do"],[4400,4533,"nhịp tim của anh hiện đang"],[4533,4608,"Anh chắc không phải do em"],[4608,4696,"làm anh hồi hộp chứ?"],[4696,4779,"Không, không hề."],[4808,4913,"Em không hề xâm phạm"],[4913,5042,"vùng an toàn của anh."],[5042,5176,"Nếu tim anh đập nhanh,"],[5176,5284,"thì là do anh đang nhìn em"],[5284,5342,"ngay lúc này."],[5342,5422,"Em rất đẹp,"],[5422,5492,"trong bộ váy đó."],[5492,5618,"Ừ, chuyện đó không cần"],[5651,5743,"Làm gì ở đây vậy ông bạn?"],[5743,5885,"Tôi cảm giác cậu ấy"],[5885,5960,"đang hơi căng th