{"1":[[0,229,"Bốn mươi người độc thân, một mục tiêu:"],[229,387,"tìm kiếm tình yêu."],[387,533,"Nếu không tìm được, hãy phá đám"],[533,684,"tình yêu của người khác để kiếm tiền."],[684,855,"Người độc thân sẽ tham gia và kiếm tiền"],[855,1001,"bằng cách chia rẽ các cặp đôi."],[1001,1101,"Tôi là Rebecca Stoughton."],[1101,1351,"Và đây là Love Bombing."],[1351,1472,"Để xem ai sẽ trở thành"],[1472,1614,"những cặp đôi của chúng ta,"],[1614,1726,"các chàng trai sẽ đứng một bên"],[1780,1889,"và các cô gái xinh đẹp"],[1889,1997,"ở bên còn lại."],[2035,2152,"Khi đến lượt,"],[2152,2273,"họ sẽ bước lên phía trước"],[2273,2348,"để gặp gỡ người"],[2348,2427,"đối diện mình."],[2427,2585,"Nếu bạn thấy ưng ý,"],[2585,2727,"hãy bước lên một bước."],[2727,2857,"Nếu không có cảm xúc,"],[2857,3007,"hãy lùi lại một bước."],[3165,3253,"Cái gì cơ?"],[3478,3607,"Nếu cả hai cùng quyết định"],[3607,3737,"bước lên,"],[3737,3837,"họ sẽ thành một cặp!"],[3837,3933,"Nhưng mọi chuyện chưa kết thúc"],[3933,4029,"khi họ ghép đôi xong."],[4029,4137,"Đó mới là lúc Love Bombing"],[4137,4237,"thực sự bắt đầu."],[4237,4412,"Hôm nay tôi thấy nhiều anh chàng"],[4412,4558,"khá là điên."],[4612,4758,"Kiểu điên thật sự ấy."],[4775,4838,"Đùi to"],[4838,4942,"là chân ái."],[5034,5138,"Có một gã còn bảo"],[5138,5238,"rằng kiểu, bạn gái của hắn"],[5238,5317,"không được phép"],[5317,5451,"nói chuyện trong xe."],[5451,5755,"Tiêu chuẩn của tôi rất cụ thể."],[5755,5918,"Cô ấy phải thấp hơn tôi."],[5918,6051,"Mắt xanh dương hoặc xanh lá."],[6051,6206,"Phải theo đạo Công giáo."],[6206,6364,"Phải muốn có con."],[6364,6569,"Và kiểu, ít nhất khoảng sáu,"],[6569,6681,"bảy đứa."],[6681,6815,"Dấu hiệu cờ đỏ là gì?"],[6815,6981,"Nếu con gái nói chuyện trên xe."],[6981,7190,"Tôi thích yên lặng trên xe"],[7190,7394,"và khi đi du lịch,"],[7394,7524,"cô ấy cần phải trật tự."],[7599,7816,"Gì vậy trời? Đồ điên."]],"2":[[0,125,"Tôi là Tigerlily."],[125,404,"Tôi 22 tuổi và đến từ"],[404,567,"Nam California."],[608,679,"Ý tôi là,"],[679,855,"có tình yêu thì thật tuyệt nhỉ?"],[1259,1409,"Tôi thấy rất lo lắng về"],[1409,1526,"chuyện"],[1526,1639,"bước lên chọn,"],[1639,1860,"rồi chuyện vuốt chọn và"],[1922,1989,"mọi thứ."],[1989,2127,"Bởi vì nếu chỉ dựa vào"],[2127,2239,"ấn tượng ban đầu,"],[2239,2389,"tôi thường hay bị"],[2389,2523,"ngượng ngùng."],[2936,3136,"Ôi!"],[3136,3211,"Xin lỗi nha!"],[3294,3386,"Xin lỗi."],[3386,3557,"Nên là, ừ,"],[3557,3682,"đây chắc chắn là trải nghiệm mới"],[3682,3803,"đối với tôi."],[3970,4124,"Tôi có một gu nhất định,"],[4124,4237,"thật không may,"],[4237,4375,"tôi thấy hơi tệ vì chuyện đó."],[4667,4825,"Chris có đôi mắt xanh rất đẹp,"],[4825,5071,"mà tôi thì thích ánh mắt thu hút."],[5105,5176,"Anh ấy có điểm đó, ừ."],[5176,5284,"Anh ấy rất tốt."],[6306,6452,"Đúng thế!"],[6773,6831,"Chiếc váy trắng"],[6831,6994,"mọi thứ trông thật tuyệt vời."],[6994,7111,"Tôi nghĩ chẳng có lý do gì"],[7111,7232,"để mình không bước lên."],[7232,7340,"Cô ấy cười rất tươi,"],[7340,7486,"nên tôi cũng đinh ninh"],[7486,7561,"rằng cô ấy sẽ bước lên"],[7561,7640,"để chọn tôi."],[7691,7807,"Nên tôi cũng không quá sợ"],[7807,7882,"chuyện bị từ chối."],[7932,7995,"Ai biết được,"],[8053,8170,"biết đâu lại nên chuyện."]],"3":[[25,120,"Tigerlily,"],[120,191,"sao em lại bước lên"],[191,266,"chọn anh?"],[367,467,"Em cảm nhận được năng lượng tốt"],[467,550,"từ anh."],[550,646,"Thế à? Ý em là sao?"],[646,817,"Em thấy anh có vẻ vui tính"],[817,900,"và tốt bụng."],[921,1055,"Em thích đôi mắt xanh của anh."],[1055,1142,"Ok."],[1142,1247,"Cảm giác như ta sẽ có khoảng"],[1247,1355,"thời gian vui vẻ bên nhau."],[1355,1547,"Em không hay hẹn hò lắm."],[1547,1726,"Kiểu em cũng từng hẹn hò chút ít,"],[1726,1935,"đôi ba lần thôi, nhưng"],[2072,2214,"ngoài kia khó kiếm người lắm."],[2214,2427,"Tôi không ưng áo của anh ấy lắm."],[2427,2569,"Hay bất cứ cái áo nào mà"],[2569,2665,"Tôi không thích đàn ông"],[2665,2761,"mặc áo hoa."],[2790,2932,"Nhưng bù lại,"],[2932,3065,"con chúng tôi giờ có phân nửa"],[3065,3144,"cơ hội"],[3144,3244,"mang mắt màu xanh."],[3244,3407,"Chà, chúng ta có mắt xanh"],[3407,3507,"mắt nâu"],[3566,3678,"mỗi người một màu!"],[3678,3807,"Tôi từng ở trong một mối quan hệ"],[3807,3916,"khá lâu, nên giờ tôi kiểu"],[3916,4029,"muốn,"],[4104,4287,"tìm hiểu mọi người và"],[4287,4379,"kiểu xem, xem thử"],[4379,4475,"ngoài kia có gì."],[4496,4587,"Anh từ đâu đến?"],[4587,4683,"New Jersey."],[4683,4750,"Anh có nhận ra"],[4750,4842,"em là gái California"],[4842,4909,"kiểu thung lũng không? - Có."],[4909,4979,"Một chút. - Hoàn toàn luôn."],[4979,5017,"Thật á?"],[5017,5096,"Giọng em giống mọi cô gái"],[5096,5180,"anh từng xem trên phim."],[5180,5334,"Ý tôi là, tất nhiên tôi muốn"],[5334,5438,"tình yêu."],[5438,5543,"Ai mà chẳng muốn chứ?"],[5543,5618,"Tôi muốn được yêu thương."],[5618,5693,"Tôi muốn đắm chìm trong tình yêu."],[5826,5960,"Anh để cô ta ngồi lên đùi mình."],[5960,6060,"Anh có thấy mình mắc chứng"],[6060,6210,"sợ cam kết không?"],[6210,6335,"Cứ để xem tới đâu."],[6335,6448,"Không, tôi không muốn làm bạn"],[6448,6510,"với anh đâu."]],"4":[[379,442,"Anh chàng cởi trần"],[442,633,"có ngực bự kia"],[813,934,"Xin khiếu."],[934,1013,"Nhanh vậy sao?"],[1013,1113,"Chà!"],[1113,1301,"Đợi đếm ngược đã chứ cô gái."],[1330,1430,"Họ bảo tôi cứ ăn mặc"],[1430,1555,"thoải mái nhất, nên tôi"],[1555,1730,"Biết đấy... có sao tôi mặc vậy."],[2569,2765,"Ồ!"],[2977,3157,"Chào! Tôi là Meghane Lex."],[3157,3432,"Tôi 25, đang độ tuổi mặn mà."],[3432,3607,"Trước kia, tôi hay quen những anh"],[3607,3720,"từng ra vào"],[3720,3899,"trại cai nghiện hoặc nhà tù."],[3903,4008,"Tôi là người rất thoải mái."],[4008,4145,"Và tôi không hề thích drama."],[4667,4863,"Ồ, không phải gu tôi rồi."],[4863,4988,"Có một anh chàng cởi trần,"],[4988,5121,"nhưng tôi nghĩ anh ta cố tình,"],[5121,5276,"nên tôi tôn trọng việc đó."],[5276,5376,"Tôi đang cố đổi gu của mình."],[5376,5501,"Tôi muốn tìm một chàng trai"],[5501,5622,"chưa từng vào tù"],[5622,5747,"hay đi cai nghiện,"],[5747,5968,"mà lỡ có thì cũng không sao"],[5968,6118,"F**kboys cũng cần tình yêu mà."],[6235,6352,"Mọi người hiểu ý tôi chứ?"],[6352,6544,"Anh ấy kiểu như đang gồng cơ ngực"],[6544,6673,"và tôi cảm thấy,"],[6673,6869,"đó là một tín hiệu."],[6869,6952,"Đó là điềm báo"],[6952,7036,"rằng có lẽ,"],[7036,7157,"tôi đã làm anh ấy phấn khích,"],[7157,7236,"bạn biết không?"],[7236,7411,"Nên khi anh ấy làm vậy, tôi biết"],[7411,7607,"chúng tôi đã bắt sóng được nhau."]],"5":[[629,821,"Anh ấy đúng là rất có sức hút."],[821,980,"Và anh ấy,"],[980,1121,"rất chú ý đến tôi."],[1130,1222,"Tôi thích điều đó."],[1222,1288,"Cho đến giờ,"],[1288,1363,"anh ấy làm tôi cười,"],[1363,1438,"làm tôi khúc khích."],[1438,1551,"Bạn biết đấy, nếu anh ta"],[1551,1722,"chọc bạn cười, thì cũng có thể làm bạn sướng."],[1722,1881,"Và vâng, anh ấy đang ghi điểm với tôi."],[1881,1989,"Một người cười với trò đùa của bạn."],[1989,2097,"Làm bạn thấy mình thú vị."],[2097,2139,"Và,"],[2202,2373,"cả quan trọng nữa."],[2373,2598,"Và cô ấy làm vậy. Nên"],[2598,2736,"Em khỏe không?"],[2736,2961,"Tốt. Ngoài kia nóng thật."],[2961,3078,"Khá là nóng."],[3078,3190,"Bình thường anh không quen mặc"],[3190,3336,"áo, nhưng anh nghĩ nên tươm tất vì em."],[3336,3503,"Anh ấy đã tự nhắc đến"],[3503,3657,"chuyện cởi áo rồi."],[3695,3807,"Tôi không nghĩ anh ấy lại"],[3807,3887,"vào đề như thế."],[3887,4037,"Là vậy đấy."],[4037,4124,"Nó đã làm em chú ý."],[4154,4200,"Cơ thể anh à?"],[4225,4416,"Cơ thể, cơ ngực,"],[4416,4491,"cả cử động nữa."],[4491,4587,"Màn lắc ngực đó."],[4587,4667,"Lắc ngực sao?"],[4667,4688,"Vâng."],[4688,4779,"Nó tự như vậy khi anh"],[4779,4875,"hào hứng hoặc lo lắng."],[4875,4971,"Vậy em làm anh hào hứng sao?"],[4971,5071,"Anh ấy đã"],[5071,5171,"lắc lư cặp ngực rồi."],[5171,5242,"Ồ."],[5242,5338,"Em làm anh bị cả hai,"],[5338,5438,"em hiểu ý anh chứ?"],[5497,5605,"Nên anh mới chọn em."],[5676,5722,"Anh chịu thôi."],[5722,5797,"Anh thử rồi, - Gì cơ?"],[5797,5847,"Không được."],[5847,5910,"Cái trò anh ta đang làm ấy."],[5910,6043,"Ồ, vâng. Em còn"],[6043,6131,"không muốn thử."],[6131,6218,"Em đã"],[6327,6510,"Em đã kiêng quan hệ"],[6510,6652,"gần năm năm rồi."],[6669,6802,"Chà, coi như anh là trai tân,"],[6802,6923,"nên anh hiểu mà."],[6923,6998,"Ừ, anh cảm nhận được tần số của em,"],[6998,7073,"em hiểu ý anh chứ?"],[7073,7182,"Họ gọi em là"],[7182,7286,"chuyên trị f**kboy."],[7286,7340,"Anh ấy chắc chắn cần được"],[7340,7457,"quản lý một chút."],[7457,7611,"Nhưng, em nghĩ em lo được."],[7611,7699,"Có gian nan mới có được Reign."],[7774,7916,"Mình tìm hiểu thêm không?"],[7916,8033,"Với cái"],[8033,8103,"Ừ, sao mấy thứ này lại ở đây?"],[8103,8162,"Cái này để làm gì?"],[8174,8245,"Anh nghĩ nó để"],[8245,8329,"đo nhịp tim chúng ta."],[8329,8404,"Mình thử xem nhé?"],[8404,8529,"Phải dán lên da đúng không?"],[8587,8666,"Để anh cởi cái này ra."],[8804,8850,"Được."],[9059,9171,"Sao tôi vẫn làm trò này nhỉ?"],[9171,9300,"Đây là trò đùa à?"],[9300,9484,"Tình dục, im lặng và bánh mì kẹp."],[9513,9567,"Anh đang bất ổn à?"],[9567,9655,"Anh bình tĩnh xong chưa?"],[9655,9718,"Rõ ràng là anh"],[9718,9747,"đang thử thách tôi."]],"6":[[0,37,"Anh tìm kiếm điều gì"],[37,100,"ở một người phụ nữ?"],[100,237,"Một người mạnh mẽ,"],[237,396,"độc lập, biết rõ"],[396,567,"mình muốn gì trong đời,"],[567,717,"và có thể tương thích với"],[717,896,"lối sống độc lập của tôi."],[1001,1146,"Tôi nghĩ điểm trừ lớn nhất"],[1146,1301,"đối với tôi"],[1301,1584,"là khi rốt cuộc"],[1584,1701,"tôi không hợp tính"],[1701,1789,"với người đó."],[1847,1931,"Tôi đang tìm một người"],[1931,2018,"có chí cầu tiến."],[2018,2143,"Thực sự chưa có ai khiến tôi"],[2143,2289,"thấy rung động ngay lập tức."],[2289,2402,"Tôi thích một người"],[2402,2460,"có chí hướng và biết rõ"],[2460,2519,"mình đang làm gì, biết"],[2519,2660,"mình muốn làm gì,"],[2660,2740,"biết mình muốn"],[2740,2819,"tương lai của mình ra sao."],[2932,3094,"Một người có hoài bão"],[3094,3274,"và có kế hoạch rõ ràng."],[3349,3436,"Có động lực."],[3837,3941,"Thiếu cá tính."],[4087,4187,"Tôi là Olivia."],[4187,4291,"Tôi 23 tuổi."],[4291,4462,"Tôi đến từ New Jersey,"],[4462,4575,"và tôi thấy"],[4575,4713,"rất khó"],[4713,4796,"để làm quen với các chàng trai."],[4796,4900,"Tôi phải nói là"],[4900,4963,"tôi có"],[4963,5059,"một gu rất cụ thể,"],[5059,5130,"nên tôi cũng biết"],[5130,5263,"có lẽ đó là do tôi."],[5263,5372,"Tôi rất, rất,"],[5372,5497,"rất kén chọn."],[5497,5593,"Tôi đang tìm một người"],[5593,5672,"rất hấp dẫn,"],[5672,5730,"giống như tôi."],[5730,5793,"Đồng thời là người"],[5793,5843,"có đôi mắt"],[5843,5914,"sáng màu."],[5914,5976,"Họ có xuất thân từ"],[5976,6081,"gia đình gia giáo không?"],[6118,6193,"Chỉ là rất khó"],[6193,6268,"để tìm được một người"],[6268,6352,"hoàn hảo về mọi mặt."],[7065,7107,"Khá là"],[7107,7223,"khó để tôi"],[7223,7328,"lập tức nói không,"],[7399,7453,"chỉ dựa trên"],[7453,7532,"vẻ bề ngoài."]],"7":[[358,437,"Không."],[437,642,"Ôi không."],[642,867,"Không."],[867,942,"Có vài anh chàng"],[942,1055,"mà tôi thấy khá dễ thương."],[1055,1138,"Nhưng hiển nhiên,"],[1138,1255,"tâm trí tôi bắt đầu"],[1255,1317,"lo nghĩ lung tung,"],[1317,1380,"và tôi kiểu, ôi, chà,"],[1380,1438,"anh nọ trông giống"],[1438,1518,"một tra nam,"],[1518,1584,"còn anh kia trông"],[1584,1655,"như tay sát gái,"],[1655,1714,"và anh này trông"],[1714,1797,"có vẻ quá ồn ào với tôi."],[1797,1847,"Và, ôi trời-"],[1931,1993,"Khi tôi bước"],[1993,2252,"tới vạch và"],[2252,2327,"đó là Jude,"],[2327,2373,"tôi chỉ nhìn vào"],[2373,2464,"đôi mắt xanh lục"],[2464,2569,"dễ thương của anh ấy"],[2711,2898,"và tôi kiểu,"],[2898,3073,"ôi, mình toát mồ hôi rồi."],[3073,3115,"Ôi Chúa ơi,"],[3115,3178,"chuyện gì vậy nè?"],[3403,3474,"Tôi quay lại"],[3474,3532,"chốn tình trường"],[3532,3586,"bởi vì tôi tin"],[3586,3670,"cuối cùng vẫn còn hy vọng."],[3670,3770,"Tôi tin rằng,"],[3770,3870,"tôi đang bắt đầu"],[3870,3933,"hiểu phụ nữ"],[3933,3991,"thêm một chút"],[3991,4120,"khi trưởng thành hơn."],[4120,4216,"Và,"],[4279,4354,"biết đấy, họ,"],[4354,4475,"