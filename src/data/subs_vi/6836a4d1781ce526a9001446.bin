791,"Phá đám thôi nào!"],[3791,3878,"Mọi người,"],[3908,4037,"đi thôi!"],[4362,4429,"Chưa phải câu hay nhất em từng nghe,"],[4429,4491,"nhưng có thể cải thiện."],[4491,4525,"Anh không biết"],[4525,4600,"đó có phải phong cách của anh,"],[4600,4667,"nhưng-"],[4779,4829,"Thôi nào."],[4829,5017,"Ồ, ừ."],[5017,5100,"Chắc chắn em sẽ giành"],[5100,5134,"quyền chỉnh nhạc trên xe"],[5134,5188,"sau vụ vừa rồi."],[5188,5309,"Chào hai người."],[5309,5359,"Tôi chỉ muốn"],[5359,5426,"qua đây"],[5426,5609,"chơi với hai người thôi."],[5609,5718,"Nhớ mọi người quá,"],[5718,5768,"và tôi muốn,"],[5768,5847,"kiểu như, thử,"],[5847,5947,"xem chỉ tay cho bạn,"],[5947,6039,"đường này ở đây,"],[6039,6106,"và dấu hiệu này ở đây,"],[6106,6231,"hơi cắt nhau một chút."],[6231,6289,"Và điều đó mang lại"],[6289,6464,"cảm giác bất an."]],"42":[[45,166,"Tôi nghĩ nhịp tim của anh"],[166,287,"đang tăng lên đấy."],[287,362,"Gì cơ? Chỉ vì"],[362,458,"cô làm tôi hồi hộp"],[458,513,"và tôi thấy cô"],[513,558,"hấp dẫn,"],[558,796,"không có nghĩa là tôi"],[796,934,"sẽ không tiếp tục"],[934,1059,"theo đuổi Robyn,"],[1172,1230,"nên không có chuyện đó đâu."],[1230,1409,"Xin lỗi nhé."],[1409,1484,"Chúc cô tận hưởng nốt"],[1484,1572,"buổi hẹn của mình."],[1572,1634,"Chắc chắn rồi, cảm ơn anh."],[1634,1701,"Rất vui được nói chuyện"],[1701,1743,"với anh."],[1743,1768,"Cảm ơn."],[1768,1814,"Thật tuyệt khi"],[1814,2010,"bị che mắt thế này."],[2010,2077,"Ừ."],[2164,2398,"Ôi không, xin lỗi mọi người nhé."],[2398,2481,"Làm tốt lắm, tốt lắm, cậu giỏi lắm."],[2481,2569,"Xin lỗi nhé!"],[2569,2627,"Họ thực sự"],[2627,2773,"rất tập trung thôi."],[2773,2936,"Chào!"],[2936,2973,"Chuyện gì vậy?"],[2973,3032,"Ừ, cậu vừa mới"],[3032,3086,"biến mất tăm."],[3086,3140,"Ừ, đúng thế."],[3140,3332,"Bỏ tôi lại đây một mình với"],[3415,3536,"với một cái bịt mắt."],[3536,3724,"Hành xử kiểu trẻ trâu cấp ba."],[3724,3824,"Ừ, hơi kỳ cục."],[3824,3933,"Ừ, đúng vậy."],[3933,3966,"Sao họ lại"],[3966,4070,"cố tình chơi khăm mình nhỉ?"],[4070,4162,"Tôi không biết!"],[4162,4404,"Ôi. - Ôi, lạy Chúa."],[4404,4454,"Bởi vì chúng ta đang ở đây."],[4454,4500,"Kiểu như"],[4500,4596,"cố gắng tiếp tục"],[4596,4696,"trò chuyện."],[4696,4846,"Tôi biết, chuyện đang rất ổn mà."],[4846,4879,"Đó là lý do"],[4879,4950,"tôi thích thế."],[4950,5038,"Tôi rất trân trọng"],[5038,5113,"việc anh đã,"],[5113,5226,"thành thật đấy."],[5226,5271,"Và anh nói"],[5271,5326,"kiểu như,"],[5326,5417,"ồ, anh cũng có"],[5417,5459,"chịu khó"],[5459,5593,"tiếp chuyện cô ấy,"],[5593,5789,"như thế cũng tốt."],[5789,5947,"Biết được vậy cũng tốt. Ừ."],[5947,5997,"Ý tôi là, tôi"],[5997,6056,"không nói dối,"],[6056,6089,"với lại,"],[6089,6231,"đeo thứ này thì sao nói dối được."],[6231,6297,"Chuẩn. - Nhưng mà."],[6297,6364,"Ừ."],[6364,6431,"Ừ, nhưng tôi nghĩ"],[6431,6510,"điều đó thật tốt."],[6510,6619,"Anh biết đấy,"],[6619,6669,"tất cả các cô gái"],[6669,6715,"đều rất"],[6715,6819,"xinh đẹp và,"],[6819,6898,"đó là một điều"],[6898,6998,"Cả các chàng trai nữa!"],[6998,7119,"Chắc chắn rồi."]],"43":[[0,116,"Tôi hoàn toàn không có"],[116,191,"nỗi sợ gắn kết đâu."],[191,241,"Kiểu như, nếu tôi"],[241,404,"thích ai, tôi sẽ hết lòng."],[404,454,"Chỉ vậy thôi."],[454,533,"Cô từng trải qua"],[533,654,"bao nhiêu mối tình rồi?"],[654,721,"Chỉ một."],[721,871,"Nhưng tôi mới 22 tuổi mà."],[871,971,"Mối tình đó được bao lâu?"],[971,1071,"Được"],[1071,1176,"ba năm."],[1176,1259,"Ồ, cũng lâu đấy."],[1259,1363,"Hai người chia tay khi nào?"],[1393,1438,"Cô có nghĩ"],[1438,1547,"anh ấy là tình yêu của đời mình không?"],[1572,1643,"Tôi từng nghĩ mình"],[1643,1705,"sẽ cưới anh ấy,"],[1705,1801,"nhưng chúng tôi còn quá trẻ."],[1801,1981,"Quen nhau lúc mới 18, nên"],[2010,2068,"Đúng là trẻ thật."],[2089,2122,"Ừ."],[2122,2189,"Nên chúng tôi"],[2189,2318,"chia tay rất êm đẹp."],[2318,2435,"Cả hai không còn hợp nhau nữa."],[2435,2531,"Và tôi chúc anh ấy những điều tốt đẹp nhất."],[2531,2590,"Hai người"],[2590,2681,"- vẫn làm bạn chứ? - Không."],[2681,2765,"- Không nói chuyện luôn? - Không."],[2765,2865,"Thậm chí không hỏi thăm nhau à?"],[2865,2952,"- Không. - Anh ta tồi lắm à?"],[2952,3040,"Không, anh ấy rất tốt."],[3040,3115,"Tồi lắm à?"],[3115,3274,"Không, anh ấy rất tốt."],[3274,3340,"Nhưng tôi chỉ"],[3340,3382,"không nghĩ"],[3382,3490,"làm bạn với người yêu cũ"],[3490,3566,"là một ý hay."],[3566,3724,"Sao cô lại nghĩ vậy?"],[3724,3858,"Vì kì cục lắm."],[3858,3983,"Vẫn còn vương vấn"],[3983,4070,"chút tình cảm sao."],[4070,4158,"Nhịp tim của cô đang tăng lên"],[4158,4270,"khi nhắc về người yêu cũ kìa?"],[4295,4404,"Chuyện qua cả năm rồi."],[4404,4462,"Anh ấy cũng sống"],[4462,4542,"ở bờ bên kia nước Mỹ."],[4542,4662,"Và kể cả không phải vậy."],[4662,4725,"Tôi cam đoan"],[4725,4896,"Cụ thể là ở đâu?"],[4896,4959,"Ở bờ bên kia,"],[4959,5005,"có phải những nơi"],[5005,5080,"chúng ta sắp tới thăm không?"],[5080,5146,"Ý anh"],[5146,5201,"là vậy sao?"],[5201,5255,"Ví dụ như New York à?"],[5255,5326,"Anh ấy sống ở vùng ngoại ô,"],[5326,5405,"nên anh ấy không sống"],[5405,5501,"Ngoại ô New York á?"],[5501,5534,"Bật mí nhé,"],[5534,5638,"năm nào gia đình tôi"],[5638,5714,"cũng đến ngoại ô New York"],[5714,5822,"vào kỳ nghỉ gia đình."],[5822,5893,"Vậy nên, đúng rồi đấy."],[5893,5968,"Vậy nên, này,"],[5968,6068,"biết đâu hai người lén gặp nhau"],[6068,6185,"trong kỳ nghỉ gia đình"],[6185,6318,"khi cô ấy vắng mặt một chút."],[6318,6410,"Đó chính là"],[6410,6498,"nỗi sợ gắn kết đấy."],[6498,6602,"- Có lẽ tôi thích trai... - Tôi đã định nói"],[6602,6748,"- ...từ New York. - ...với cậu về"],[6748,6798,"Nhịp tim của cô vẫn"],[6798,6856,"đang tăng lên à?"],[6856,6911,"Khi nghe về"],[6911,6998,"kỳ nghỉ gia đình này."],[6998,7052,"Chà"],[7052,7102,"Việc mà"],[7102,7178,"cô có thể gặp lại anh ta."],[7178,7223,"Tôi nghĩ tôi"],[7223,7349,"Để lại cho hai người"],[7349,7499,"nhiều điều để suy nghĩ đấy."],[7499,7674,"Chúc hai người mọi điều tốt đẹp."],[7674,7766,"Hãy suy nghĩ kỹ về những gì"],[7766,7882,"tôi đã nói nhé."],[7882,8003,"Hãy ngẫm lại xem."],[8003,8049,"Nhé."],[8049,8137,"Chúng tôi rất cảm kích."],[8137,8216,"Hẹn gặp lại hai người sau."],[8216,8333,"Tạm biệt."],[8333,8420,"Vậy em vẫn còn yêu người cũ à?"],[8420,8458,"Lạ thật đấy."],[8458,8683,"Em không còn yêu người cũ."],[8683,8742,"Được thôi."],[8742,8837,"Nhịp tim cô ấy tăng kìa."],[8837,8963,"Anh ấy ghen quá."],[8963,9009,"Bọn em chia tay"],[9009,9117,"rất êm đẹp."],[9117,9196,"Được rồi."],[9196,9242,"Thế ai chia tay"],[9242,9296,"ai trước?"],[9296,9325,"Thì"],[9325,9392,"Cả hai"],[9392,9438,"cùng quyết định"],[9438,9476,"chia tay,"],[9476,9526,"nhưng chủ yếu"],[9526,9688,"vẫn là em,"],[9688,9734,"Nên"],[9734,9843,"Thú vị nhỉ."],[9843,9880,"Em chắc là mình"],[9880,9926,"không nói dối chứ,"],[9926,9989,"khi nhịp tim của em vẫn"],[9989,10076,"đang tăng kìa? - Không, em"],[10076,10189,"Em thề đấy."],[10189,10489,"Máy đo nhịp tim bảo thế mà."]],"44":[[0,66,"Anh, anh đã nói"],[66,133,"em rất đẹp."],[133,237,"Ý anh là, sao... - Em không"],[237,271,"Em không thích"],[271,312,"việc anh ta"],[312,387,"lớn tiếng này nọ."],[387,417,"Em nghĩ"],[417,483,"có lẽ chúng ta nên... - Anh cũng thế."],[483,546,"rời khỏi đây."],[546,642,"Em muốn rời khỏi đây sao?"],[642,742,"Anh nghĩ sao?"],[742,817,"Ồ, anh ta"],[817,963,"đang thở phì phò kìa."],[963,1059,"Biết sao không?"],[1059,1297,"Thật lòng thì, sao lại không chứ?"],[1297,1338,"Đi thôi."],[1338,1405,"Thật sao?"],[1405,1580,"Anh ta đi kìa, họ đi kìa!"],[1580,1626,"Anh ta đi kìa, họ đi kìa!"],[1655,1876,"Không thể nào!"],[1876,1968,"Ý tôi là"],[1968,2106,"Thật luôn à? - Được rồi người anh em."],[2106,2264,"Không! Gì cơ?"],[2264,2331,"Đầu ngón tay-"],[2331,2460,"Ăn miếng trả miếng,"],[2460,2556,"hay người ta gọi là gì nhỉ."],[2556,2690,"Thôi nào!"],[2690,2781,"Chuyện này quá đáng thật."],[2781,2819,"Sao mình-"],[2819,2932,"Sao mình vẫn làm chuyện này chứ?"],[2932,3011,"Ồ."],[3261,3345,"Chết tiệt."],[3586,3832,"Tôi nghĩ vậy đấy. - Ôi trời ơi."],[3832,3978,"Anh ta vừa bỏ đi kìa!"],[3978,4116,"Theo anh ta, theo anh ta mau!"],[4116,4287,"Đi nào! Nhanh lên!"],[4287,4408,"Chúng ta mất dấu anh ta rồi,"],[4408,4529,"mất dấu rồi."],[4558,4633,"Nhanh nào,"],[4633,4767,"Chuyện gì đang xảy ra vậy?"],[4767,4996,"Chúc mừng. Anh đã thắng 2.000 đô la."],[5113,5155,"Đúng vậy."],[5155,5288,"Đúng thế."],[5288,5422,"Anh ta khóc kìa, anh ta khóc kìa!"],[5422,5522,"Anh ta đang khóc!"],[5522,5605,"Ôi trời ơi."],[5605,5772,"Anh ta thực sự đang khóc kìa!"],[5772,5955,"Ôi trời ơi."],[5955,6126,"Không thể nào."],[6126,6281,"Ôi trời ơi."],[6281,6402,"Ôi trời."],[6402,6581,"Không thể tin được, anh ta vẫn-"],[6873,7044,"Đưa anh ta máy đo nhịp tim đi."],[7044,7169,"Điên rồ thật."],[7169,7311,"Ôi trời ơi."],[7311,7503,"Tức quá bỏ cuộc luôn."],[7503,7674,"Ai đã bày ra trò này vậy?"]],"45":[[0,125,"Chào mọi người."],[125,179,"Hội con gái bọn tôi,"],[179,350,"đã kết bạn với nhau"],[350,433,"ngoài chương trình này."],[433,500,"Nên các anh tưởng"],[500,663,"họ sẽ ủng hộ các anh,"],[663,717,"nhưng nghĩ lại thì,"],[717,863,"tôi hơi quên mất rằng"],[863,996,"đây cũng là trò chơi với họ."],[996,1076,"Được rồi, mọi người"],[1076,1130,"biết tôi thích kiểu,"],[1130,1238,"mấy trò tâm linh,"],[1238,1355,"đúng không? - Ừ."],[1355,1409,"Nên tôi chỉ muốn,"],[1409,1514,"kiểu, đến đây"],[1514,1618,"và muốn thử,"],[1618,1751,"xem chỉ tay cho anh."],[1751,1856,"Được chứ?"],[1856,1960,"Được thôi."],[1960,2002,"Vậy tôi sẽ"],[2002,2035,"xem đường"],[2035,2335,"giao tiếp của anh."],[2419,2473,"Đường của anh"],[2473,2506,"ngay đây"],[2506,2573,"và đường ngay đây"],[2573,2698,"hơi giao nhau một chút."],[2698,2831,"Nó cho tôi cảm giác"],[2831,2982,"anh giao tiếp kém. Kiểu-"],[2982,3123,"Giao tiếp kém sao? - Ừ."],[3123,3182,"Kiểu như anh"],[3182,3286,"giao tiếp kém thật à?"],[3286,3353,"Đúng vậy không?"],[3353,3403,"Tôi không nghĩ mình"],[3403,3457,"Anh có nghĩ là"],[3457,3632,"giao tiếp kém. Nhưng tôi"],[3632,3795,"chắc chắn gặp"],[3795,3908,"khó khăn khi diễn đạt"],[3908,3962,"cảm xúc của mình"],[3962,4037,"thành lời."],[4037,4070,"Tôi cảm giác"],[4070,4149,"có lẽ chúng ta"],[4149,4300,"đang hơi bịa chuyện."],[4300,4358,"Thật mà,"],[4358,4408,"những gì cô ấy"],[4408,4462,"nói là thật."],[4462,4529,"Cô ấy đang nói"],[4529,4562,"sự thật."],[4562,4596,"Ừ, giá như"],[4596,4625,"cô ấy đừng"],[4625,4775,"quá ép uổng chuyện đó"],[4775,4879,"và kiểu,"],[4879,5000,"hơi làm quá"],[5000,5059,"đến mức tôi lại đi"],[5059,5196,"làm mọi người bực"],[5196,5234,"và kiểu,"],[5234,5447,"khiến ai cũng hoảng."],[5447,5534,"Ừ."],[5534,5651,"Tôi chưa từng xem chỉ tay"],[5651,5751,"ngày nào trong đời."],[5751,5980,"Trò đó khá là"],[5980,6101,"nhảm nhí."],[6131,6393,"Nhưng cô ấy nói đúng."],[6393,6481,"Đó có phải là"],[6481,6602,"lý do các mối tình trước"],[6602,6710,"không thành"],[6710,6769,"và tại sao anh"],[6769,6898,"vẫn độc thân không? Kiểu"],[6898,6973,"do giao tiếp kém?"],[7052,7203,"Chắc một chút."],[7203,7323,"Có thể."],[7323,7428,"À, chắc là nhiều đấy."],[7428,7494,"Vì mấy đường này"],[7494,7620,"rất lớn. - Đúng không?"],[7620,7720,"Chúng rất sâu."],[7720,7849,"Khá là sâu đấy."],[7849,7899,"Kiểu như mấy"],[7899,8008,"vấn đề giao tiếp đó."],[8008,8049,"Ừ. Chuẩn luôn."],[8049,8128,"Không, điều đó đúng mà."],[8128,8187,"Anh chắc chắn"],[8187,8291,"em không thấy nó trên tay mình."],[8291,8420,"Nhưng thật đấy."],[8420,8483,"Em có ngại"],[8483,8587,"nếu anh xem thử không?"],[8587,8725,"Chỉ tay em á?"]],"46":[[20,141,"Cô ấy bỏ đi dễ vậy sao."],[141,187,"Dễ vậy à?"],[187,237,"Ý tôi là, thôi nào."],[237,337,"Làm như tôi là"],[337,383,"Tôi là"],[383,496,"kẻ phản diện vậy."],[496,558,"Anh ấy tức rồi."],[558,709,"Anh ấy thật sự tức giận."],[709,775,"Ý tôi là, tôi thấy"],[775,796,"như có"],[796,892,"chút tình cảm."],[892,980,"Cảm thấy rất thật,"],[980,1046,"kiểu như cảm thấy"],[1046,1201,"sự kết nối, hiểu không?"],[1201,1288,"Tôi đã cố hít thở."],[1288,1351,"Có lẽ tôi"],[1351,1488,"đã mất bình tĩnh."],[1488,1689,"Ôi, f**k."],[1697,1780,"Nhưng còn nữa."],[1780,1851,"Còn có một cô gái khác"],[1851,1901,"trong đó,"],[1901,2031,"mà-"],[2031,2077,"Tôi không định"],[2077,2147,"chuyển mục tiêu nhanh đâu."],[2147,2323,"Tôi nghĩ mình vẫn có thể"],[2323,2385,"giành lại cô ấy."],[2385,2540,"Ý tôi là, cô ấy là"],[2540,2644,"cô gái đảo nhỏ của tôi,"],[2644,2677,"cậu hiểu ý tôi chứ?"],[2677,2790,"Kiểu như,"],[2790,2957,"Ồ"],[2957,3136,"Tên đó hơn tôi điểm nào?"],[3136,3294,"Cái f**k gì?"],[3294,3370,"Cậu có hình xăm."],[3370,3499,"Ừ, chắc hắn bôi"],[3499,3557,"kem ủ tê"],[3557,3716,"lên đống sh*t đó,"],[3716,3787,"còn mớ sh*t này của tôi"],[3787,3916,"là xăm sống."],[3916,4112,"Hắn chẳng có sh*t gì bằng tôi."],[4112,4225,"Tôi là alpha, cậu hiểu"],[4225,4400,"ý tôi chứ?"],[4400,4525,"Này, làm sao giành lại cô ấy đây?"],[4525,4558,"Cậu định"],[4558,4633,"cho một cơ hội à?"],[4633,4721,"Thật lòng hả? - Cậu"],[4721,4742,"có định"],[4742,4846,"cho nó cơ hội không?"],[4846,5055,"Ôi, không. Mình không biết nữa."],[5055,5217,"Thôi đi! Ôi, đúng rồi."],[5217,5359,"Nhìn anh ấy kìa. - Này!"],[5359,5459,"Mình có nên kéo anh ấy lại không?"],[5459,5551,"Cậu nên đi kéo anh ấy lại!"],[5551,5709,"Không! Đi đi!"],[5709,5834,"Mình có nên kéo anh ấy lại không?"],[5834,5889,"Không!"],[5889,5955,"Thật sự thì,"],[5955,6026,"cậu nên chạy ra đó."],[6026,6131,"Mình sẽ thử mở lòng."],[6131,6151,"Mình sẽ"],[6151,6247,"cho nó một cơ hội."]],"47":[[0,45,"Ý anh là, ừ,"],[45,100,"cô ấy kiểu"],[100,204,"cô ấy đã hôn"],[204,312,"lên má anh,"],[312,425,"nhưng kiểu như,"],[425,487,"Ồ."],[487,675,"Ý anh là, cô ấy hôn anh."],[675,767,"Anh không hôn cô ấy. - Nếu anh đang nghĩ"],[767,875,"về Autumn."],[875,988,"Kiểu, sao anh lại cho phép"],[988,1080,"chuyện đó xảy ra chứ."],[1080,1126,"Anh hiểu không?"],[1126,1197,"Nhìn mặt cô ấy kìa."],[1197,1380,"Nhìn mặt cô ấy đi. Trông cô ấy"],[1380,1480,"rất giận."],[1480,1526,"Có người"],[1526,1614,"tiến đến chỗ mình"],[1614,1751,"để chào tạm biệt."],[1751,1839,"Mình đâu biết"],[1839,1872,"liệu họ"],[1872,1939,"sẽ hôn mình"],[1939,1997,"lên má"],[1997,2093,"hay sẽ ôm mình chứ?"],[2093,2127,"Mình cũng 