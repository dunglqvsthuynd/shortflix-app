ào đây kìa."],[10072,10206,"Ôi, tội nghiệp Emily."],[10231,10310,"Chào."],[10339,10381,"Chào."],[10397,10443,"Xin chào."],[10443,10510,"Chào cưng."],[10510,10664,"Họ không muốn cô ấy vào đó đâu."],[10689,10752,"Tuyệt."]],"157":[[16,154,"Chắc do cậu kiểu như,"],[154,258,"có quá nhiều năng lượng thôi."],[258,387,"Cậu có quá nhiều năng lượng à?"],[387,517,"Có thể khi hai người"],[517,671,"thấy gắn kết, họ cảm thấy cần"],[671,775,"thư giãn cùng nhau."],[800,938,"Và họ không cảm thấy cần phải"],[975,1042,"Tôi không biết nữa."],[1042,1255,"Tôi thì chả thấy thư giãn gì cả."],[1288,1351,"Đó đúng là,"],[1351,1505,"nụ hôn gượng gạo nhất"],[1505,1735,"tôi từng chứng kiến trên máy quay đấy."],[1951,2093,"Cậu biết đấy, tôi thấy việc"],[2093,2264,"chúng tôi có vẻ hơi"],[2281,2427,"lo lắng và ngại ngùng khi bên nhau"],[2427,2619,"lại là một điều tốt, bởi vì"],[2635,2831,"nếu chúng tôi không thực sự thích nhau,"],[2831,2969,"tôi nghĩ chúng tôi đã không"],[3011,3090,"hành xử như vậy."],[3107,3269,"Phải, có vẻ như,"],[3340,3620,"sự hiện diện của cậu không được chào đón đâu."],[3620,3657,"Và"],[3657,3745,"Không biết nữa, tôi chỉ muốn"],[3745,3837,"tham gia chơi cùng hai người thôi."],[3837,3945,"Hai người có muốn chơi cùng không?"],[4008,4108,"Không hẳn."],[4129,4204,"Thử hỏi Autumn xem."],[4204,4254,"Cô ấy"],[4254,4358,"Em nghĩ sao?"],[4366,4491,"Em nghĩ mình ổn."],[4521,4612,"Em ổn chứ? - Vâng."],[4662,4800,"Này anh bạn, cậu có muốn ra"],[4800,4975,"ngồi ở cái ghế đằng kia không?"],[5025,5113,"Trong lúc chúng tôi,"],[5113,5184,"chỉ ngồi chơi. - Không."],[5184,5234,"một chút."],[5234,5309,"Tôi kiểu như muốn"],[5309,5397,"Tôi ngồi đây ổn mà."],[5397,5555,"Tôi cảm thấy tôi và Autumn chưa thực sự"],[5555,5651,"có cơ hội để"],[5651,5772,"tìm hiểu nhau kỹ lắm."],[5822,5885,"Và tôi muốn... - Tôi nghĩ,"],[5885,6031,"tôi nghĩ cô ấy đã phần nào thể hiện rằng"],[6031,6093,"cô ấy,"],[6093,6202,"cô ấy không thực sự thích"],[6202,6277,"sự hiện diện của cậu ở đây."],[6302,6427,"Cậu đi được rồi đấy, người anh em."],[6439,6552,"Tôi không biết nữa. - Với tất cả sự tôn trọng."],[6552,6694,"Tôi nghĩ chúng ta nên thử"],[6694,6819,"Autumn, em đồng ý không?"]],"158":[[87,279,"Không."],[963,1096,"Cái quái"],[1096,1326,"Lolo của tôi tặng tôi món đó đấy, anh bạn."],[1326,1438,"Cái đ** gì thế?"],[1438,1651,"Ra khỏi đây đi. - Ừ, cậu ta nên đi."],[1651,1751,"Ra khỏi đây!"],[1751,1830,"Cậu ta nên rời đi."],[1830,1988,"Nhặt lên đi. - Ừ, cậu ấy nên... Chào!"],[2252,2498,"Chà, ngay khi thấy"],[2498,2644,"dây chuyền cậu ấy đứt,"],[2644,2765,"tôi đã há hốc mồm."],[2765,2927,"Tôi kiểu, ôi trời ơi,"],[2927,3053,"không thể tin nổi vì tôi biết"],[3053,3161,"điều đó có nghĩa gì."],[3161,3340,"Tôi không biết ai đã tặng cậu ấy,"],[3340,3449,"nhưng tôi biết khi"],[3449,3557,"có người tặng dây chuyền"],[3557,3712,"như thế, nó rất có ý nghĩa."],[3712,3832,"Đâu phải kiểu bạn cứ ra cửa hàng"],[3832,3966,"rồi mua là được, đúng không?"],[3991,4083,"Nên tôi tự nhủ, được rồi,"],[4083,4191,"Chris phải đi thôi."],[4229,4300,"Cậu phải rời đi."],[4329,4425,"Cậu ổn không?"],[4425,4487,"Cậu vừa,"],[4487,4629,"Lolo của tôi tặng chúng đấy."],[4738,4859,"Vậy cô đến đây làm gì?"],[4859,4963,"Tôi muốn đến xem cậu thế nào"],[4963,5100,"vì tôi nghe nói"],[5100,5196,"dây chuyền của cậu bị đứt."],[5196,5338,"Tôi lập tức cố gắng"],[5338,5417,"an ủi cậu ấy, và đó là"],[5417,5522,"sự thật lòng."],[5522,5705,"Tôi thấy rất tệ khi chuyện đó xảy ra."],[5705,5930,"Ừ, có gã nào đó định"],[5930,6072,"Ờ, xin lỗi."],[6072,6164,"Xin lỗi."],[6164,6281,"Chúng tôi đang hẹn hò."],[6281,6348,"Ồ."],[6348,6448,"Ừ, nên cô có thể đi."],[6448,6698,"Đến lượt cô ấy thử quyến rũ tôi."],[6698,6777,"Không, không, không."],[6777,6844,"Có phải dây chuyền gỗ Koa không?"],[6844,6923,"Đây là... - Gỗ Koa."],[6923,7011,"Reigny cưng à."],[7023,7173,"Dây chuyền gỗ Koa á?"],[7278,7344,"Reigny cưng,"],[7390,7540,"tự kiếm tên tội phạm của cô đi."],[7820,8037,"Anh ấy không muốn nghe cô đâu."],[8037,8287,"Thật vậy sao Reign?"]],"159":[[0,95,"Có vẻ như em,"],[95,208,"ý anh là, em vẫn ở đây."],[208,266,"Có vẻ như em"],[266,575,"vẫn muốn cho anh cơ hội."],[575,633,"Anh nói vậy,"],[633,729,"có đúng không?"],[809,909,"Mình không biết nữa, chắc là"],[909,1180,"mình đang dần nhận ra"],[1330,1413,"ngày càng rõ hơn"],[1413,1501,"khi có những người mới đến."],[1501,1543,"Kiểu như,"],[1543,1689,"mình không muốn bị ảnh hưởng"],[1689,1785,"bởi mọi người xung quanh,"],[1785,1935,"và mình cũng không muốn ai"],[1935,2043,"bảo mình phải làm gì"],[2043,2152,"hay quyết định thay mình."],[2152,2235,"Mình muốn tự"],[2235,2289,"tìm ra câu trả lời."],[2289,2389,"Mình muốn làm điều mình thích"],[2389,2469,"và xem thử,"],[2469,2681,"đây có đúng là điều mình muốn?"],[2681,2861,"Nhưng rồi mình cứ mải nghĩ,"],[2861,2994,"trời ơi, liệu tất cả những"],[2994,3103,"sự xao nhãng và những"],[3103,3199,"chuyện đang xảy ra này,"],[3199,3403,"có phải là một điềm báo?"],[3403,3624,"Hay là điều mình cần nghe?"],[3624,3774,"Hoặc có khi nào"],[3774,3870,"không biết nữa, liệu điều này"],[3870,4049,"vốn dĩ phải xảy ra không?"],[4049,4158,"Chắc chắn là vậy rồi."],[4158,4254,"Rồi mình lại tự hỏi,"],[4254,4354,"mình chỉ thấy anh ấy dễ thương,"],[4354,4458,"hay mình thật sự thích anh ấy?"],[4458,4562,"Và mình"],[4612,4742,"ranh giới đó"],[4742,4838,"đang dần mờ đi,"],[4838,5017,"và mình thực sự không thể"],[5017,5167,"xác định được lúc này."],[5167,5246,"Giờ nghĩ lại"],[5246,5376,"vài cuộc trò chuyện của bọn mình,"],[5376,5442,"mình nhận ra"],[5442,5580,"rằng chúng có lẽ"],[5580,5730,"đã quá đỗi hời hợt."],[5730,5797,"Mình nghĩ đó chỉ thiên về"],[5797,5930,"sự hấp dẫn thể xác,"],[5930,6014,"và bọn mình kiểu như,"],[6014,6252,"đã để chuyện đi hơi quá xa."],[6252,6306,"Vì anh cảm thấy"],[6306,6510,"chúng ta thật sự có gì đó."],[6510,6614,"Anh thấy mỗi khi"],[6614,6781,"ai đó rời đi,"],[6781,6944,"anh lại thấy chúng ta đang"],[6944,7036,"hướng về nhau."],[7036,7107,"Em hiểu chứ?"],[7215,7311,"Và anh không có cảm giác đó"],[7311,7486,"với nhiều người phụ nữ đâu."],[7486,7640,"Chắc tôi phải vào dò xét thử"],[7640,7736,"xem Olivia"],[7736,7841,"có thực sự thích cậu ấy không,"],[7841,8024,"hay cô ấy đang để mắt tới ai khác."]],"160":[[0,112,"Trời ơi."],[112,287,"Chào cưng."],[287,375,"Chào Emily."],[375,487,"Chị khỏe không?"],[487,604,"Trông hai đứa rất tuyệt."],[604,692,"Lộng lẫy,"],[709,771,"xuất sắc."],[771,817,"Quá tuyệt."],[817,955,"Không, ý chị là, chị không"],[955,1092,"Chị đến đây vì chuyện tốt mà."],[1092,1309,"Tuyệt quá, mừng khi nghe vậy."],[1309,1376,"Em còn tưởng mình phải"],[1401,1438,"Không đâu!"],[1451,1505,"xắn tay áo lên,"],[1505,1593,"và sẵn sàng chiến đấu nữa chứ."],[1593,1664,"Không!"],[1747,1856,"Bọn chị rất thích, chị rất thích."],[1856,1985,"Thật đấy. - Ôi, tuyệt."],[1985,2164,"Phải, chị cũng hơi ghen tị đấy."],[2164,2218,"Có lẽ chị đã"],[2218,2439,"buồn nôn vài lần rồi."],[2439,2719,"Em cũng thấy bọn em sến mà, biết rồi, gớm ghê."],[2719,2948,"Hai đứa có nghĩ là dù không"],[2948,3086,"trang điểm lộng lẫy hay mặc vest,"],[3086,3211,"thắt cà vạt, mang cao gót, nhưng"],[3211,3353,"vẫn sẽ lại đi chơi với nhau trong tương lai chứ?"]],"161":[[0,125,"Tôi nghĩ anh đi được rồi đấy."],[125,250,"Tôi không biết nữa. - Mong anh tôn trọng cho."],[250,400,"Tôi nghĩ ta nên thử-"],[400,546,"Autumn, em thấy sao?"],[546,704,"Vâng, đúng vậy vì bọn em"],[704,942,"đang cố có một buổi hẹn hò tử tế."],[942,1113,"Này, nếu em muốn thế, Autumn,"],[1113,1230,"anh sẽ hoàn toàn tôn trọng."],[1230,1326,"Và anh hiểu."],[1326,1484,"Xin lỗi vì đã cắt ngang,"],[1484,1705,"và cảm ơn hai người"],[1705,1839,"đã cho anh ngồi cùng."],[1839,1976,"Cảm ơn rất nhiều."],[1976,2027,"Cảm ơn."],[2027,2198,"Rất vui được gặp hai người."],[2198,2464,"Này ông bạn, tôi sẽ đi khỏi đây,"],[2464,2723,"để hai người tự nhiên."],[2761,2919,"Trời ạ, lần này,"],[2919,3153,"bọn mình bảo anh ấy đi vì"],[3153,3324,"mọi thứ đang loạn lên"],[3324,3599,"vì cứ có người phá đám."],[3599,3757,"Nên là, có lẽ mình nên đặt"],[3757,3870,"chuyến đi tới Hawaii"],[3870,4024,"và không để mấy,"],[4024,4095,"mấy cái... - Ừ, có lẽ"],[4095,4320,"người kỳ quặc làm phiền mình nữa."],[4320,4433,"Chắc vậy."],[4562,4617,"Thế thì tuyệt quá."],[4617,4688,"Sẽ rất - Tuyệt đấy."],[4688,4742,"vui đấy."],[4763,4817,"Ừ. - Ừ."],[5121,5242,"Ồ, không sao đâu ông bạn."],[5242,5459,"Gì cơ?"],[5459,5622,"Đây là thẻ nắm tay."],[5622,5743,"Hãy nắm tay người ấy-"],[5743,5955,"Trong 7 phút tiếp theo."],[5955,6026,"Được thôi."],[6181,6306,"Chấp nhận thử thách."],[6306,6423,"Được."],[6423,6539,"7 phút."],[6777,6936,"Duy trì giao tiếp bằng mắt"],[6936,7044,"trong 3 phút."],[7098,7215,"Vậy là đang nắm tay rồi,"],[7215,7315,"giờ mình phải"],[7315,7478,"Nhìn vào mắt nhau."],[7716,7932,"Mặc dù có hơi ngượng ngùng, như là"],[7932,8141,"khi phải nhìn thẳng vào mắt nhau,"],[8141,8270,"nhưng chỉ cần nhìn vào mắt người ta,"],[8270,8537,"thì đã thấy rất lãng mạn rồi."],[8537,8654,"Ít nhất thì em nghĩ vậy."],[8654,8808,"Làm ơn đừng - Tôi không muốn anh ấy"],[8808,8913,"hôn thêm lần thứ ba đâu."],[8913,9079,"Không? Không, đừng làm thế."],[9079,9417,"Ôi trời ơi, đừng làm thế."]],"162":[[12,79,"Chị ổn chứ?"],[79,125,"Tôi ổn."],[125,229,"Chỉ là tôi đang hơi sốc thôi."],[229,304,"Reign, chị ta có làm anh chán"],[304,487,"như đang làm em chán không?"],[487,600,"Eo ôi, chán thật sự."],[600,700,"Mà thôi."],[700,788,"Ngôn ngữ"],[788,842,"Reign!"],[842,921,"Ngôn ngữ tình yêu của anh là gì?"],[921,984,"Reign."],[984,1059,"Cử chỉ âu yếm."],[1059,1255,"Cứ tập trung vào, Đúng rồi-"],[1255,1434,"Và"],[1434,1593,"Cho cô ấy cơ hội đi. - Reign, Reign!"],[1593,1643,"Thời gian chất lượng."],[1693,1772,"Và thời gian chất lượng."],[1785,1835,"Reign!"],[1835,1968,"Tôi để hai người ở riêng nhé?"],[1968,2010,"Cô ấy không phải - Có."],[2010,2093,"gái Latin vòng ba khủng,"],[2093,2227,"nhưng là gái Philippines bốc lửa của tôi."],[2227,2339,"Các người muốn tôi để hai người ở riêng à?"],[2339,2414,"Đúng."],[2414,2477,"Đây là điều - Xin đấy!"],[2477,2527,"anh muốn sao?"],[2527,2640,"Ôi trời ơi. - Chị ổn chứ?"],[2640,2681,"Cho em một cái ôm được không?"],[2681,2798,"Tất nhiên rồi."],[2798,2965,"Eo ôi!"],[2965,3094,"Reign!"],[3094,3224,"Ôi, không!"],[3224,3403,"Chà, ôi trời ơi."],[3403,3545,"Nhưng, xin lỗi nhé"],[3566,3653,"Chị ổn không?"],[3778,3920,"Chị đi được rồi đấy."],[3920,4054,"Tôi biết nếu có một cặp đôi"],[4054,4175,"mà tôi có thể phá đám, thì đó"],[4175,4258,"sẽ là Reign và Meghane."],[4258,4454,"Chỉ vì tôi có nhiều điểm"],[4454,4587,"chung nhất với Reign."],[4587,4679,"Nên việc tôi"],[4679,4825,"thực sự có thể tận dụng điều đó."],[4825,4950,"Tận dụng điều đó"],[4950,5176,"và thực sự nói về,"],[5176,5330,"bạn biết đấy, văn hóa của chúng tôi,"],[5330,5409,"nguồn cội của chúng tôi."],[5409,5676,"Và tôi biết đó sẽ là"],[5676,5764,"cách để tôi giành chiến thắng."],[5764,5939,"Xin lỗi nhé"],[5939,6026,"Chị ổn không?"],[6168,6306,"Chị đi được rồi đấy."],[6306,6373,"Chris đâu rồi?"],[6373,6639,"Thật sự, thật sự thì,"],[6639,6810,"chuyện này thật đáng xấu hổ."],[6810,7115,"Ôi trời ơi, Chris!"]],"163":[[208,308,"Jude, người anh em."],[308,379,"Sao."],[379,475,"Sao cậu không ra"],[475,725,"ghế đằng kia ngồi đi?"],[725,800,"Này."],[800,992,"Mọi chuyện đang tốt đẹp."],[992,1180,"Mọi người đâu có"],[1180,1297,"thấy vậy."],[1297,1405,"Nói thật đấy."],[1405,1434,"Olivia,"],[1434,1543,"em thấy sao?"],[1647,1697,"Ừm"],[1747,1922,"Chắc em cũng nghe"],[1922,2035,"những gì anh vừa nói."],[2072,2147,"Cô ấy đang bối rối,"],[2147,2281,"và tôi đang cố... - Cô ấy bối rối thật."],[2281,2452,"Và tôi nghĩ chúng ta cần xem"],[2552,2673,"cô ấy bối rối chuyện gì."],[2673,2823,"Cậu lúc nào cũng,"],[2823,3036,"lúc nào cũng giở trò này."],[3036,3228,"Mọi buổi lửa trại ta tham gia,"],[3228,3440,"mọi cô gái tôi định bắt chuyện,"],[3440,3599,"cậu luôn giở mấy trò này ra."],[3599,3678,"Nghe này. - Lúc nào cũng vậy!"],[3678,3782,"Bình tĩnh, bình tĩnh nào."],[3782,3924,"Đừng có lớn tiếng"],[3924,4016,"trước mặt phái nữ chứ."],[4016,4095,"Sao cậu không"],[4095,4195,"ra đằng kia ngồi"],[4195,4329,"và để cô ấy quyết định?"],[4329,4446,"Tôi chịu hết nổi rồi."],[4446,4533,"Tôi đi đây."],[4533,4696,"Không, mặc kệ tên này đi. - Nhìn kìa."],[4813,5075,"Ôi không, cậu ấy đi rồi! - Đi cho rảnh nợ."],[5075,5242,"Cậu ta ra ghế ngồi thôi mà."],[5242,5321,"Để xem chuyện gì sẽ xảy ra."],[5321,5434,"Đi nào, Paul!"],[5434,5522,"Đi nào, Paul!"],[5530,5697,"Trước đây cậu đâu có vậy."],[5697,5784,"Vậy là sao?"],[5784,5993,"Cậu từng đùa giỡn tình cảm"],[5993,6147,"của phụ nữ suốt mà."],[6147,6252,"Giờ tự nhiên lại"],[6252,6327,"bênh vực họ à?"],[6327,6435,"Chuyện này là sao hả?"],[6435,6510,"Tôi không biết nữa."],[6510,6556,"Tôi không nhớ"],[6556,6664,"mình từng như thế."],[6664,6806,"Nhưng nếu có, chắc do tôi"],[6806,6940,"đã trưởng thành hơn rồi."],[6940,7065,"Còn cậu thì chưa chắc."],[7173,7265,"Có lẽ cậu phải trải qua"],[7265,7415,"nhiều chuyện hơn để thực sự hiểu ra"],[7415,7574,"hoặc tự mình ngẫm nghĩ thêm."],[7574,7665,"Rõ ràng cậu đang làm"],[7665,7749,"cô ấy khó chịu, sao-"],[7749,7811,"Tôi không biết nữa."],[7811,7891,"Tôi nghĩ cô ấy"],[7891,8083,"chỉ đang khó xử thôi."],[8083,8208,"Tôi không nghĩ cô ấy muốn"],[8208,8320,"bên cậu. Tôi không rõ cô ấy"],[8320,8412,"có muốn bên tôi không,"],[8412,8512,"nhưng có lẽ cô ấy"],[8512,8637,"không muốn bên ai cả."],[8637,8854,"Nhưng thế cũng không sao."],[8854,8996,"Tôi nghĩ ta nên để Olivia quyết định"],[8996,9150,"điều cô ấy muốn."],[9150,9246,"Cô ấy đã lớn,"],[9246,9296,"và hoàn toàn độc lập."],[9296,9421,"Cô ấy có thể tự quyết định."],[9421,9555,"Patches nói đúng."],[9555,9713,"Thấy chưa, tôi đã bảo"],[9713,9951,"chuyện này sẽ xảy ra mà."]],"164":[[0,108,"Hai người có nghĩ rằng"],[108,275,"sau này sẽ đi chơi lại với nhau không?"],[275,387,"Có chứ, quá dễ."],[387,458,"Chắc chắn rồi."],[458,600,"Tôi biết cảm xúc có thể thay đổi,"],[600,671,"nhưng điểm hai người thích nhất"],[671,863,"ở đối phương lúc này là gì?"],[863,980,"Dễ thôi, là cách ăn nói"],[980,1021,"khéo léo của em."],[1084,1213,"Câu trả lời hay quá!"],[1213,1305,"Thật dễ thương."],[1305,1388,"Đó là một câu trả lời"],[1388,1455,"tuyệt vời."],[1455,1543,"Không chỉ dễ nói chuyện,"],[1543,1622,"mà cách em"],[1622,1797,"diễn đạt, cách em nói chuyện,"],[1797,1885,"phong thái của em,"],[1885,2118,"cách chọn từ, ôi chao."],[2118,2281,"Ai cũng thích vốn từ phong phú."],[2281,2494,"Vốn từ rộng. - Đỉnh quá!"],[2494,2681,"Em thích sự chân thành của anh."],[2681,2723,"Vì em cảm thấy"],[2723,2919,"như lúc nói chuyện với anh,"],[2919,3023,"em đã nhận ra từ lúc"],[3023,3119,"mới nhìn anh, kiểu như lúc đó"],[3119,3265,"em còn chưa tìm hiểu anh."],[3265,3499,"Từ vẻ ngoài, anh đã toát lên"],[3499,3591,"vẻ của một người, anh biết đấy,"],[3687,3845,"hiểu rất rõ bản thân mình"],[3845,4016,"và biết rõ những gì"],[4016,4083,"mình muốn"],[4083,4208,"thể hiện với thế giới."],[4208,4312,"Điều đó làm em thấy an toàn"],[4312,4487,"khi thể hiện con người thật với anh,"],[4487,4696,"vì em có linh cảm tốt"],[4696,4833,"rằng anh sẽ chấp nhận điều đó."],[4833,4979,"Anh làm em thấy rất thoải mái."],[4979,5088,"Chính là cảm giác đó, đúng không?"],[5088,5259,"Đúng, đó cũng là câu trả lời của anh."],[5259,5359,"Là khi ở cạnh nhau, chúng ta"],[5359,5559,"rất thoải mái, anh không thấy"],[5559,5709,"áp lực hay kiểu như"],[5709,5793,"mình phải cố diễn."],[5793,5893,"Đúng thế, em cứ như đã quen anh"],[5893,6089,"từ kiếp trước vậy, hoặc"],[6089,6197,"Ừ, kiểu kiểu vậy!"],[6227,6264,"Vâng."],[6264,6364,"Anh nghĩ chúng ta giống nhau"],[6364,6514,"ở vài khía cạnh"],[6514,6727,"cơ bản rất tốt đẹp."],[6727,6990,"Và anh nghĩ cả hai đều thích nói,"],[6990,7203,"và đều mang lại cùng một"],[7203,7444,"kiểu năng lượng cho nhau."],[7444,7657,"Được rồi, tôi còn một câu hỏi cuối."],[7657,7849,"Đây là câu quan trọng nhất."],[7849,7953,"Chuẩn bị tinh thần nhé."]],"165":[[133,308,"Gì cơ?"],[308,525,"Không có gì."],[738,1176,"Vậy, bài hát yêu thích của em là gì?"],[1176,1434,"Không biết nữa, khó chọn thật."],[1434,1551,"Anh trước đi."],[1551,1714,"Purple Rain của Prince."],[1714,1839,"Được."],[1839,2010,"Phim yêu thích của em là gì?"],[2010,2118,"Girl Interrupted."],[2118,2239,"Blade Runner."],[2239,2385,"Mì Ý."],[2385,2489,"Al Pastor."],[2489,2573,"Tôi chỉ muốn cho cô ấy thấy,"],[2573,2794,"tôi là kiểu người thế nào."],[2794,2936,"Một người đàn ông thực sự quan tâm"],[2936,3144,"và vô cùng tôn trọng phụ nữ."],[3144,3311,"Và tôi sẵn sàng dành thời gian,"],[3311,3490,"sự cam kết và trân trọng"],[3490,3599,"mà một người tuyệt vời"],[3599,3799,"như cô ấy xứng đáng có được."],[3799,3933,"Tôi muốn cho cô ấy thấy về tinh thần,"],[3933,4066,"thể chất và cả cảm xúc."],[4066,4350,"Rằng tôi luôn có mặt vì cô ấy."],[4350,4421,"Trời ơi."],[4421,4533,"Anh ấy mất thăng bằng kìa."],[4533,4788,"Trời đất ơi."],[4788,4875,"Paul!"],[4875,5034,"Chuẩn."],[5638,5784,"Anh ấy thực sự rất đặc biệt."],[5784,6106,"Nên tôi rất mong chờ xem"],[6106,6281,"tương lai mang đến điều gì cho cả hai."]],"166":[[20,87,"Chris đâu rồi?"],[87,291,"Thật sự, nói thật nhé."],[375,600,"Trò này không vui đâu"],[600,759,"Chris!"],[759,838,"Chris đâu rồi?"],[838,921,"Tạm biệt, Meghane."],[921,1030,"Thế này là sao?"],[1030,1121,"Trời ơi."],[1222,1284,"Tôi thực sự"],[1284,1397,"chuyện này thực sự quá xấu hổ."],[1397,1488,"Tôi về rồi đây!"],[1488,1659,"Ra ngoài ngay!"],[1659,1760,"Cô ta là ai?"],[1760,1864,"Cuối cùng thì, ôi anh thơm quá."],[1864,1926,"Cô là ai!"],[1926,2031,"Hai người trông đẹp đôi đấy."],[2031,2072,"Cảm ơn nhé."],[2072,2110,"Tụi tôi biết mà!"],[2110,2181,"Dễ thương thật."],[2181,2344,"Cô làm ơn ra ngoài được không?"],[2344,2456,"Thực ra đây là phòng tôi."],[2456,2548,"Reign chuẩn bị thế này cho tôi."],[2548,2706,"Tôi chuẩn bị cho... ồ, đúng vậy nhưng"],[2706,2827,"Anh ta làm cho tôi, nhục nhã thật."],[2827,2965,"Tôi đổi ý rồi."],[2965,3065,"Ồ, được thôi Reign."],[3065,3161,"Cô có thấy anh ta"],[3161,3224,"lật mặt nhanh cỡ nào"],[3224,3324,"khi tôi bước vào không?"],[3324,3415,"Cô là Melissa à?"],[3440,3507,"Hay Morgan?"],[3507,3624,"Không. - Margaret hả?"],[3624,3987,"Lúc nãy, ồ, được thôi."],[4049,4245,"Tôi là người chiến thắng."],[4245,4400,"Anh là kẻ thua cuộc, Reign."],[4400,4579,"Đúng nghĩa là một kẻ thua cuộc."],[4579,4788,"Kẻ thua cuộc thảm hại."],[4788,4900,"Được rồi, nghe này,"],[5038,5167,"chọn đi."],[5167,5271,"Sau cùng thì,"],[5271,5509,"tôi không thể chịu đựng được"],[5509,5622,"sự mập mờ này."],[5622,5797,"Anh có thể rời đi cùng tôi"],[5797,5989,"hoặc ở lại với cô ta."],[5989,6085,"Tôi hoàn toàn không biết"],[6085,6331,"mình phải làm gì nữa."],[6331,6577,"Tôi không biết chọn ai."],[6577,6702,"Họ rất khác nhau,"],[6702,6802,"và đều xinh đẹp"],[6802,6898,"theo cách riêng của mình."],[7044,7248,"Hiện tại tôi hoàn toàn mù mờ."],[7248,7349,"Có vẻ hơi thao túng đấy,"],[7349,7449,"cứ như cô đang cố"],[7449,7540,"Tôi thao túng anh sao?"],[7540,7574,"Đúng thế,"],[7574,7674,"cô đang ra giới hạn"],[7674,7807,"thời gian và ép tôi chọn."],[7807,7903,"Đúng, vì tôi đang"],[7903,7995,"bị thiếu tôn trọng ở đây."],[7995,8158,"Tôi sẽ chọn bản thân mình."]],"167":[[379,538,"Em đi được không?"],[538,625,"Em có thể"],[625,709,"Em không muốn ở đây nữa."],[709,900,"Được rồi, cho anh một cơ hội đi."],[900,1051,"Cho anh thêm một cơ hội thôi được không?"],[1051,1146,"Em chỉ muốn đi thôi."],[1146,1238,"Em muốn đi với Patches."],[1238,1267,"Để cô ấy đi đi."],[1267,1326,"Cứ để"],[1326,1405,"Để cô ấy đi với Patches đi."],[1405,1493,"Em không muốn làm"],[1493,1614,"Em không muốn nói chuyện với anh."],[1614,1672,"Không có ý xúc phạm đâu."],[1697,1739,"Không sao."],[1739,1910,"Và, kiểu như, dù chuyện này là gì đi nữa,"],[1910,2164,"Anh nghĩ, kiểu như em chỉ đang"],[2164,2214,"Anh không biết nữa."],[2231,2281,"Kệ cô ấy đi."],[2281,2364,"Cứ để cô ấy đi đi, ông bạn."],[2364,2506,"Em chỉ muốn quay lại với Patches."],[2506,2635,"Nếu cô ấy thực sự thích ông,"],[2635,2794,"thì cô ấy sẽ quay lại thôi."],[2794,2890,"Để cô ấy đi đi."],[2990,3136,"Em thấy mình đã quá mù quáng"],[3136,3349,"bởi toàn bộ chuyện này"],[3349,3465,"đến nỗi em thực sự không,"],[3465,3678,"hề suy nghĩ gì."],[3678,3862,"Chỉ là mọi thứ diễn ra quá nhanh,"],[3862,4104,"và em cảm thấy mình chỉ"],[4104,4304,"Ôi! Đeo mic vào! Đeo mic vào!"],[4304,4358,"Chờ chút."],[4562,4692,"Ôi, tội nghiệp Jude."],[4692,4746,"Lại đây nào,"],[4746,4904,"cô gái."],[4992,5217,"Thấy chưa, mình biết ngay mà."],[5292,5413,"Ôi, cậu ấy khóc kìa."],[5413,5501,"Cậu ổn không?"],[5576,5655,"Đừng làm bất cứ chuyện gì"],[5655,5747,"mà cậu không muốn, hiểu không?"],[5747,5834,"Được chứ?"],[5834,5901,"Mình ở đây với cậu."],[5901,5976,"Cậu không hề ngốc."],[5976,6081,"Bọn mình ai cũng từng"],[6081,6227,"trải qua những chuyện thế này với con trai."],[6227,6402,"Chuyện đó giống như một phần"],[6402,6514,"của việc làm con gái thôi, cậu hiểu không?"],[6514,6577,"Kiểu như,"],[6577,6631,"Ừm."],[6710,7048,"đôi khi chúng ta đều mù quáng vì tình yêu."],[7048,7057,"đôi khi chúng ta đều mù quáng vì tình yêu."],[7057,7123,"Không sao đâu."],[7123,7211,"Mình sẽ ở đây với cậu,"],[7211,7436,"- Mình nghĩ thế, - Ổn chứ?"],[7436,7561,"Mình không muốn tiếp tục nữa."],[7561,7686,"Cậu không cần phải tiếp tục nữa đâu."],[7686,7820,"- Mình chỉ muốn về nhà. - Được rồi."],[7820,7878,"- Mình chỉ muốn về nhà. - Được rồi."],[7878,8103,"Mình không nghĩ... ừ, đây đúng là một"],[8103,8241,"sai lầm ch*t tiệt."],[8241,8387,"Cảm ơn cậu."],[8387,8433,"Đương nhiên rồi."],[8470,8516,"Cậu là"],[8516,8633,"người bình thường duy nhất trong toàn bộ"],[8633,8787,"trải nghiệm dở hơi này."],[8787,8863,"Chà"],[8863,8967,"Ôi trời ơi."],[9154,9309,"Bọn mình cũng yêu cậu."],[9534,9617,"Lỗi của tôi."],[9889,9997,"Thôi nào ông bạn."],[9997,10076,"Không sao đâu."],[10076,10130,"Này,"],[10130,10201,"cái đ-"],[10201,10314,"Ôm một cái nào ông bạn."],[10443,10510,"Lại đây."],[10539,10639,"Giờ chúng ta làm gì đây?"],[10639,10744,"Ổn mà."]],"168":[[16,200,"Đây là câu hỏi quan trọng nhất,"],[200,383,"nên hãy chuẩn bị tinh thần đi."],[383,775,"Tôi làm phù dâu chính được không?"],[775,880,"Chốt vậy nhé."],[880,1096,"Được rồi, việc của tôi xong rồi."],[1096,1155,"Cảm ơn nhé, Emily."],[1155,1259,"Hai người dễ thương lắm."],[1259,1480,"Tôi rất mừng cho hai người."],[1480,1801,"Tôi ra kia khóc đây."],[1981,2068,"Tôi sẽ làm phù dâu chính"],[2068,2127,"trong đám cưới của họ."],[2147,2243,"Đừng khóc nhiều quá nhé."],[2293,2456,"Nước mắt hạnh phúc. - Nước mắt hạnh phúc."],[2456,2540,"Họ dễ thương thật."],[2540,2644,"Tuyệt thật."],[2644,2736,"Vui thật đấy."],[2781,2815,"Tuyệt."],[2815,2998,"Anh cứ tưởng là"],[2998,3061,"Có ai đó định gây chuyện."],[3061,3144,"Vâng, em biết mà."],[3144,3278,"Anh đã sẵn sàng tẩn ai đó"],[3278,3353,"trên đó rồi đúng không. - Ừ."],[3415,3507,"Ý anh là,"],[3607,3745,"với những gì cô ấy nói,"],[3933,4020,"Cho anh nhé? - Vâng."],[4020,4308,"Anh nghĩ là anh"],[4450,4525,"Lạ thật đấy."],[4525,4617,"Mới có bốn ngày thôi,"],[4617,4804,"mà anh ngày càng"],[4900,5121,"Thích em hơn à?"],[5121,5251,"Ừ, anh rất thích em."],[5251,5376,"Em cũng rất thích anh!"],[5376,5547,"Anh rất muốn tìm hiểu em thêm."],[5547,5605,"Em cũng thế."],[5605,5651,"Dành nhiều thời gian"],[5651,5701,"bên em hơn."],[5701,5755,"Em cũng vậy."],[5755,5955,"Có lẽ khi máy quay không còn"],[5955,6122,"theo chúng ta khắp nơi."],[6122,6260,"Và có lẽ ta sẽ có"],[6260,6364,"một nụ hôn đầu,"],[6364,6448,"đầu tiên thực sự,"],[6448,6510,"Vâng."],[6510,6644,"chứ không phải... - Vâng."],[6644,6815,"kiểu trước mặt mọi người"],[6815,6931,"hay dưới ánh đèn sáng chói."],[6931,7152,"Hoặc mình có thể đi dã ngoại."],[7152,7253,"Đi dã ngoại sao! - Ừ."],[7253,7311,"Sẽ tuyệt lắm đấy."],[7336,7507,"Lâu rồi em mới thấy"],[7620,7778,"xao xuyến thế này."],[7778,7895,"Em có cảm giác"],[7895,8083,"mình rất háo hức"],[8083,8170,"được trò chuyện với anh ấy,"],[8170,8387,"hay chỉ là háo hức được chia sẻ"],[8387,8537,"cùng một nguồn năng lượng với người ta."],[8600,8679,"Thật sao?"],[8846,9313,"Ồ! Chà!"],[9367,9426,"Chúng ta đi chứ?"],[9484,9555,"Đi thôi."]],"169":[[187,283,"Em thấy hồi đầu tuần"],[283,446,"mình đã rất lo lắng"],[446,704,"vì em chưa từng tham gia"],[704,829,"chương trình nào như thế này,"],[829,913,"và em cũng không biết"],[913,1080,"mình sẽ gặp ai,"],[1080,1226,"hay liệu có ghép đôi được không."],[1226,1384,"Thật sự rất căng thẳng."],[1384,1484,"Rồi khi được ghép đôi"],[1484,1864,"với Sherif, mọi thứ rất tự nhiên."],[1864,2027,"Cứ như hai đứa đã quen nhau"],[2027,2293,"từ lâu lắm rồi. Thú thực em từng nghĩ"],[2293,2456,"mình sẽ chẳng tìm được ai."],[2456,2627,"Em cứ ngỡ mọi chuyện"],[2627,2719,"sẽ chẳng đi đến đâu."],[2719,2877,"Nhưng mọi chuyện lại rất tuyệt."],[3311,3449,"Chuyện gì đã xảy ra?"],[3636,3720,"Đúng vậy, tuần qua quả thực"],[3720,3895,"rất điên rồ và nhiều biến cố."],[3895,4091,"Nhiều thử thách."],[4091,4279,"Nhiều trở ngại."],[4279,4454,"Nhiều bài học trưởng thành."],[4454,4592,"Và cả những lúc"],[4592,4808,"cực kỳ điên rồ, hỗn loạn."],[4808,4913,"Nhưng hai đứa đã vượt qua"],[4913,4992,"mọi chông gai,"],[4992,5125,"sát cánh bên nhau,"],[5159,5255,"và mạnh mẽ hơn."],[5255,5405,"Nên suy cho cùng,"],[5405,5484,"đó là kết quả tốt đẹp nhất."],[5484,5676,"Thành thật mà nói, rất điên rồ."],[5676,5780,"Lúc đầu mọi chuyện"],[5780,6035,"hơi điên rồ, như anh vừa nói."],[6035,6247,"Nhưng hai đứa đã vượt qua!"]],"170":[[37,79,"Thôi nào, Reign."],[79,150,"Tôi chọn chính mình."],[221,329,"Tôi chọn chính mình."],[329,437,"Tôi yêu bản thân,"],[504,633,"tôi mới là người chiến thắng."],[684,734,"Tôi đang yêu... - Vậy là anh không,"],[734,800,"chính bản thân mình."],[800,909,"vậy anh không quen cô ấy à?"],[909,1046,"Tôi không quen cô ấy. - Ok, ok."],[1046,1138,"Tôi quen chính mình."],[1138,1292,"Luôn yêu bản thân, cưng à."],[1292,1384,"Đồ ái kỷ."],[1393,1463,"Và tôi thích thế."],[1505,1664,"Tôi mới là người thắng, mọi người ạ."],[1664,1747,"Tôi thấy vui vì"],[1747,1926,"Thế giới của Reign!"],[1926,1993,"Theo tôi nào."],[1993,2131,"Không đau đớn không có Reign, cưng à."],[2131,2356,"Điều tôi thấy vui"],[2356,2481,"là"],[2552,2698,"tôi đã giúp anh nhận ra"],[2698,2806,"cô ta không hợp với anh."],[2806,2877,"Và biết gì không?"],[2877,2982,"Anh chẳng làm gì ngoài việc"],[2982,3040,"bước tiếp."],[3040,3115,"Vì thế nên tôi mới yêu anh."],[3140,3274,"Anh ấy nói yêu tôi trước."],[3453,3516,"Tạm biệt."],[3553,3620,"Eo ôi!"],[3661,3732,"Quá đỉnh. - Tạm biệt!"],[3732,3920,"Quá đỉnh."],[3920,4083,"Người chiến thắng đích thực."],[4083,4295,"Anh đúng là kẻ thua cuộc, Reign."],[4295,4579,"Tôi đã tốn quá nhiều thời gian."],[4579,4833,"Tôi đi thư giãn đây."],[4833,4929,"Ai muốn nếm thử không?"],[5171,5380,"Bùm!"],[5484,5764,"Thấy chưa cưng! Ai muốn thử không?"],[5764,5855,"Không đau đớn không có Reign."],[5855,5989,"Gọi cảnh sát đi."],[5989,6281,"Tôi mới là người chiến thắng."],[6281,6456,"Tôi vui khi ở một mình."],[6456,6715,"F**k tất cả các người."],[7086,7157,"Mọi người vẫn ở đây à?"],[7157,7394,"Ôi trời đất ơi."],[7394,7474,"Tôi đi lấy"],[7474,7624,"Này, anh diễn lại trò ác quỷ ngực bự"],[7624,7803,"một lần nữa xem sao được không?"],[7912,8128,"Ác quỷ ngực bự!"],[8128,8425,"Cho tôi úp mặt vào cặp ngực đó nào!"]],"171":[[33,137,"Cô ấy không... nghe này, anh bạn,"],[137,204,"lý do duy nhất tôi"],[204,287,"làm vậy là vì cô ấy"],[287,408,"không dành cho cậu."],[408,558,"Cô ta không hợp với cậu đâu, anh bạn."],[558,642,"Tôi nói thật đấy,"],[642,825,"tôi làm vậy để bảo vệ cậu."],[875,980,"Và vì quan tâm cậu."],[1026,1192,"Ừ. - Thật lòng đấy."],[1192,1380,"Chúc mừng!"],[1914,1997,"Cô ta không hứng thú đâu."],[1997,2127,"Mà nghe này, anh em thì"],[2127,2193,"phải bảo vệ nhau chứ."],[2193,2264,"Cảm ơn người anh em."],[2264,2318,"Ừ, ừ."],[2318,2385,"Có tôi đây."],[2385,2515,"Tôi sẽ luôn sát cánh cùng cậu."],[2569,2711,"Mình phải bắt cặp nhiều hơn đấy."],[2711,2756,"Chuẩn rồi, anh bạn."],[2756,2861,"Quay lại cuộc chơi thôi."],[2861,2948,"Cậu hiểu - Nhanh nào, anh bạn."],[2948,3015,"ý tôi chứ. - Đi thôi, chiến nào."],[3015,3061,"Đi nào."],[3061,3123,"Triển thôi."],[3123,3240,"Rời khỏi đây thôi."],[3240,3336,"Em nói thật nhé."],[3336,3645,"Em không có ác cảm gì với anh ấy."],[3645,3812,"Em chỉ đang cố tham gia cuộc chơi thôi."],[3987,4079,"Lỗi của em."],[4079,4200,"Em xin lỗi."],[4208,4275,"Không sao đâu."],[4275,4362,"Anh sẽ luôn ở bên em,"],[4362,4587,"anh nghĩ là, - Được chứ?"],[4587,4713,"Em không muốn làm chuyện này nữa."],[4713,4838,"Em không cần phải tiếp tục nữa đâu."],[4838,4971,"Em chỉ muốn về nhà thôi. - Được rồi."]],"172":[[0,145,"Tôi thích mọi thứ ở cô ấy."],[145,300,"Tôi chưa tìm được điểm nào"],[300,437,"mà mình không thích ở cô nàng này."],[437,521,"Nên là, tôi phải tiếp tục"],[521,588,"đi chơi với cô ấy đến khi"],[588,654,"vì"],[654,825,"cô ấy không thể hoàn hảo thế được."],[825,996,"Lúc mới ghép đôi,"],[996,1288,"em nghĩ, anh ấy rất nóng bỏng, là người mẫu mà."],[1288,1455,"Không đời nào anh ấy lại vui tính, cuốn hút,"],[1455,1689,"dễ thương, thú vị và tuyệt vời đến thế."],[1689,1822,"Không thể nào."],[1822,2031,"Nhưng khi trò chuyện thì đúng là vậy."],[2031,2135,"Và thế là em nghĩ,"],[2189,2277,"đời thật bất công."],[2310,2477,"Trải nghiệm này thật sự,"],[2477,2598,"rất bất ngờ."],[2598,2711,"Em không"],[2711,3057,"nghĩ một là anh sẽ"],[3057,3311,"để mắt đến em, và"],[3311,3482,"hai là anh lại thú vị"],[3482,3661,"và dễ gần đến vậy."],[3661,3799,"Ý em là, chẳng có gì để chê cả."]],"173":[[4,33,"Thôi đi."],[33,529,"Trời ơi, sao cũng được."],[529,650,"Này, đợi đã!"],[838,1026,"Anh làm gì vậy, Reign?"],[1109,1242,"Anh đang làm gì thế?"],[1242,1309,"Gì chứ?"],[1309,1447,"Anh không thể nhìn em bỏ đi như thế,"],[1447,1584,"em biết đấy, vì anh không bao giờ bỏ cuộc."],[1584,1672,"Anh đang cố"],[1735,1776,"Anh vừa mới,"],[1776,1851,"anh đã bỏ cuộc rồi."],[1851,2027,"Anh muốn gì đây?"],[2027,2152,"Rốt cuộc thì anh đã chọn bản thân mình,"],[2152,2310,"em nên tôn trọng điều đó."],[2331,2385,"Tôn trọng?"],[2385,2464,"Nhưng em đến đây để tìm kiếm"],[2464,2531,"một thứ gì đó."],[2656,2727,"Em đã,"],[2727,2890,"tìm được thứ em muốn chưa?"],[2890,2948,"Em không biết, Reign."],[2948,2994,"Anh đang làm gì vậy?"],[2994,3103,"Thế này là sao?"],[3153,3244,"Anh, anh chỉ"],[3319,3411,"Gì cơ? - Không sao."],[3620,3699,"Vậy là xong sao?"],[3841,4012,"Thấy chưa, em lại bắt anh đấu tranh vì em à?"],[4012,4145,"Đúng vậy, đấu tranh vì em đi, Reign."],[4145,4320,"F**k, không đời nào, anh vừa bảo-"],[4320,4383,"Gì cơ?"]],"174":[[8,112,"Tôi nghĩ với Jude,"],[112,229,"không có gì để bụng cả."],[229,362,"Anh ấy rất ngọt ngào."],[362,462,"Anh ấy có ý tốt."],[462,546,"Anh ấy là người tốt."],[546,692,"Rõ ràng anh ấy rất hấp dẫn."],[809,884,"Chỉ là,"],[884,1051,"tôi nghĩ bọn tôi đã cố gắng"],[1051,1242,"biến sự hấp dẫn đó"],[1242,1388,"thành thứ gì đó sâu sắc hơn."],[1388,1509,"Nhưng thực ra chỉ đến thế thôi."],[1509,1626,"Và tôi nghĩ"],[1626,1710,"lúc bắt đầu trò chuyện,"],[1710,1818,"bọn tôi mới nhận ra sự kết nối"],[1818,1901,"hoàn toàn không tồn tại."],[1901,2027,"Tôi thấy hoàn toàn ổn với việc"],[2027,2106,"chỉ là bạn tốt,"],[2106,2202,"bạn rất tốt của cô ấy."],[2202,2260,"Cô ấy cũng là một"],[2260,2410,"mối quan hệ tốt đáng giữ lại."],[2410,2723,"Cô ấy rất có đầu óc kinh doanh."],[2869,3136,"Nên chúng tôi khá hợp điểm đó."],[3136,3240,"Mong anh ấy tìm được người"],[3240,3390,"yêu chính con người anh ấy."],[3390,3465,"Bạn biết đấy, vì anh ấy không"],[3465,3570,"cần phải thay đổi và tôi"],[3570,3670,"cũng không cần thay đổi."],[3670,3803,"Và chúng tôi sẽ tìm được người"],[3803,4083,"chấp nhận con người thật của mình."],[4083,4124,"Đúng vậy."],[4124,4220,"Tôi đang thấy rất tuyệt."],[4287,4412,"Tôi đã gặp những người tuyệt vời."],[4446,4554,"Thực ra chúng tôi định"],[4554,4692,"đi chơi với nhau sau vụ này,"],[4692,4934,"đi bar các thứ, và,"],[5063,5184,"mọi chuyện thực sự khá bối rối."],[5184,5397,"Và tôi nghĩ với ai cũng vậy,"],[5397,5588,"đôi khi cũng khá mệt mỏi."],[5588,5814,"Nhưng chính điều đó lại khiến nó"],[5814,5935,"trở nên đáng nhớ và ý nghĩa"],[5935,5980,"theo một cách nào đó."]],"175":[[33,112,"Thế thôi à?"],[254,425,"Thấy không, em lại bắt anh tranh giành em à?"],[425,558,"Đúng thế, giành lấy em đi, Reign."],[558,734,"Đ** nhé, anh vừa nói-"],[734,796,"Gì cơ?"],[796,896,"Anh ấy quá khó đoán."],[896,1076,"Nên là, một phần trong tôi kiểu như,"],[1076,1188,"tôi nghĩ điều duy nhất"],[1188,1313,"dễ đoán về hai đứa, là việc"],[1313,1401,"chúng tôi khó đoán ra sao."],[1401,1551,"Anh ấy bảo anh ấy chọn bản thân,"],[1551,1747,"nhưng thâm tâm tôi biết anh ấy hiểu"],[1747,1931,"trái tim mình muốn gì, đó là tôi."],[1931,2027,"Bản tính Reign là vậy."],[2027,2189,"Khó đoán và chứa đầy"],[2189,2293,"những bất ngờ."],[2293,2448,"Nên là, cũng có phần dễ đoán,"],[2448,2531,"nhưng biết nói gì đây?"],[2640,2748,"Anh định đề nghị gì?"],[2748,2948,"Làm người yêu anh nhé?"],[3682,3803,"Tạm biệt!"]]}