{"1":[[684,842,"Cypher, còn gọi tôi một lần nữa"],[842,1001,"trong lúc tôi đang lái xe đường dài,"],[1001,1046,"tôi cho anh biết,"],[1046,1230,"tôi sẽ cán chiếc bán tải này ngay vào mặt anh đấy."],[1267,1305,"Anh,"],[1305,1505,"người đứng đầu tối cao của Dominion Tech,"],[1505,1693,"một công ty buôn vũ khí trị giá hàng tỷ đô,"],[1710,1847,"lại làm tài xế lái xe tải?"],[1868,2018,"Còn sống thì mới làm được chứ."],[2018,2102,"Tôi phải tìm ra"],[2102,2223,"kẻ nào âm mưu hãm hại tôi."],[2227,2373,"Đó là lý do tôi gọi anh, thưa sếp."],[2394,2523,"Có vẻ chúng ta đã tìm ra anh ta..."],[2615,2690,"Chết tiệt."],[3657,3770,"Chết tiệt."],[3912,4016,"Cô ta đây rồi, bắt lấy mau."],[4404,4500,"Lái đi."],[4525,4633,"Anh muốn bao nhiêu tôi cũng trả,"],[4633,4742,"chỉ cần bỏ xa họ giúp tôi."],[6252,6385,"Cái xe này có thể chạy nhanh hơn không?"],[6418,6610,"Thưa cô, đây là một chiếc Peterbilt sáu xi-lanh."],[6610,6644,"Được chứ?"],[6644,6727,"Không phải Ferrari."],[6823,6965,"Chừng này đã đủ để chạy nhanh hơn chưa?"],[7419,7557,"Để xem cô bé này có thể làm được gì."],[8124,8324,"Em yêu, thôi nào, di chuyển đi."],[8879,8992,"Cẩn thận bức tường."],[9788,9868,"Chết tiệt."],[9914,9989,"Cẩn thận."],[10702,10748,"Hú."],[10802,10910,"Chúng ta an toàn rồi."],[11131,11194,"Cô không sao chứ?"],[11394,11540,"Tôi cần phải nằm xuống."],[12074,12195,"Anh có thể ôm tôi không?"],[12233,12354,"Tôi thấy không khỏe."],[12650,12737,"Được rồi, để tôi."],[13025,13079,"Này."],[13321,13405,"Không sao cả."],[13405,13488,"Mọi thứ đã kết thúc rồi."],[13830,13901,"Sao vậy?"],[13930,14093,"Tôi chỉ thấy trong người hơi nóng."],[14122,14197,"Nóng quá."],[14197,14260,"Tôi chỉ..."],[14285,14393,"Được thôi, này, cô biết gì không?"],[14418,14585,"Tôi có thể gọi bác sĩ nếu cô cần."],[14652,14798,"Không, tôi không cần bác sĩ."],[15069,15165,"Tôi cần anh."],[15219,15298,"Ngay bây giờ."],[15461,15540,"Này."],[15665,15736,"Chờ đã, chờ đã."],[15769,15890,"Chúng ta không nên đâu."],[16145,16282,"Tôi biết tôi cần gì."],[1663