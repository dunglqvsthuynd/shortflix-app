được chứ?"],[7870,8028,"Bởi vì tuần này tôi sẽ có"],[8028,8091,"một chuyến hàng lớn."],[8137,8224,"Anh thật sự"],[8224,8329,"muốn sống theo cách này sao?"],[8383,8462,"Ngoài đường ngoài xá,"],[8462,8616,"sống bằng từng ngày lương ít ỏi?"],[8679,8929,"Anh không muốn để tôi chiều chuộng anh sao?"],[9109,9351,"Tôi sẽ không bị bó buộc bởi bất kỳ ai."],[9380,9471,"Không vợ."],[9501,9609,"Không con."],[9609,9680,"Không gì cả."],[9713,9780,"Bố ơi."],[10301,10452,"Cuối cùng con cũng tìm thấy bố."],[10627,10785,"Không con cái rắm."],[10852,10931,"Đồ dối trá."],[10977,11056,"Này, à..."],[11086,11127,"Cô bé."],[11148,11240,"Cháu nhận nhầm người rồi."],[11340,11511,"Không, mẹ bảo bố là bố của con."],[11540,11695,"Nói dối là không tốt đâu."],[11724,11853,"Con bé không nói dối."],[13613,13742,"Anh là bố của con bé."]],"4":[[0,100,"Đồ kiêu ngạo,"],[100,246,"tên khốn vô trách nhiệm."],[246,417,"Tôi đã đuổi theo anh"],[417,529,"trong bốn năm trời."],[529,742,"Những đứa trẻ khác bảo con không có bố."],[763,888,"Bố sẽ không bỏ rơi con,"],[888,980,"đúng không ạ?"],[1209,1288,"Con bé thật sự là con của tôi?"],[1539,1643,"Xét nghiệm DNA."],[1672,1814,"Chính xác và hợp pháp."],[2047,2139,"Chết tiệt."],[2168,2335,"Đây thật sự là con của anh sao?"],[2427,2640,"99.9998%."],[2640,2694,"Vậy thì vì sao"],[2694,2811,"cô không tìm tôi sớm hơn?"],[2836,2948,"- Tìm anh? - Ừ."],[2948,3090,"Anh nghĩ tôi có thể lên Google để tìm"],[3090,3353,"người cha bí ẩn của con gái và nhận được địa chỉ?"],[3386,3561,"Tôi đã truy tìm anh suốt nhiều năm."],[3595,3699,"Anh chưa từng ở cùng một nơi"],[3699,3778,"nhiều hơn một ngày."],[3807,3903,"Chết tiệt."],[3937,4058,"Thời gian qua mình luôn lẩn trốn"],[4058,4116,"vì mình tưởng"],[4116,4233,"bọn khủng bố đang bám theo mình."],[4258,4371,"Hóa ra chính là cô ấy."],[4433,4579,"Được thôi, nói thật thì,"],[4625,4763,"tôi không nghĩ một lần có thể..."],[4763,4821,"Một lần?"],[4842,4896,"Không."],[4963,5092,"Nếu anh nhớ chính xác,"],[5176,5330,"là ba lần."],[5405,5559,"Không"],[5655,5705,"ngừng nghỉ."],[5818,5993,"Chết tiệt, cô ấy thích vào thẳng vấn đề nhỉ?"],[6064,6193,"Và nếu anh là một tên đàn ông chân chính,"],[6218,6393,"anh sẽ kết hôn với tôi ngay lập tức."],[6427,6535,"Thứ lỗi cho tôi, cô nói cái gì?"]],"5":[[41,112,"Tôi xin lỗi."],[150,358,"Kết hôn với tôi là gánh nặng sao?"],[433,608,"Con quá xấu xí trong mắt bố à?"],[608,759,"Không, tất nhiên là không."],[759,913,"Nhìn con xinh xắn đến nhường nào kìa."],[950,1059,"Bố sẵn lòng..."],[1105,1167,"làm bố của con."],[1167,1284,"Bố chỉ, bố..."],[1284,1547,"Tôi không hẳn là kiểu người thích hợp để làm bố..."],[1547,1710,"Im miệng và vào xe ngay."],[1768,1910,"Chúng ta sẽ đi kết hôn."],[2398,2623,"Giờ con có bố rồi."],[2623,2727,"Con thật sự có bố rồi."],[2752,2998,"Phải, và bố có một cô con gái"],[2998,3119,"xinh xắn nhất trên đời."],[3132,3253,"Con yêu bố lắm."],[3440,3661,"Giờ thì Summer đã gặp được bố con bé,"],[3712,3870,"mình có thể tập trung dọn dẹp đống rắc rối"],[3870,3983,"ở công ty."],[4758,4904,"Tôi có việc khẩn cấp"],[4904,4967,"cần xử lý."],[4992,5084,"Tôi sẽ gọi anh."],[5092,5159,"Được thôi."],[5455,5593,"Nếu anh có ý định bỏ chạy lần nữa,"],[5622,5776,"tôi sẽ thiến anh."],[5826,5939,"Đã nghe rõ."],[6343,6585,"Bố ơi, bố có thể lưu số vào đây"],[6585,6777,"để con có thể gọi cho bố mỗi khi nhớ bố không?"],[6777,6865,"Tất nhiên rồi."],[6877,6911,"Lại đây nào."],[7640,7745,"Tạm biệt bố."],[7803,7903,"Tạm biệt con."]],"6":[[521,642,"Khu vực đã được kiểm soát."],[642,821,"Nơi này chính thức là vùng vô tín hiệu."],[842,1009,"Hãy bày tỏ sự kính trọng với người đứng đầu."],[1509,1614,"Thủ lĩnh Reed."],[1655,1768,"Tôi có việc cho anh."],[1801,1897,"Scarlett Hayes."],[1935,2047,"Anh cần gì từ cô ta?"],[2081,2156,"Điều tra liệu con gái cô ta"],[2156,2252,"có phải con ruột của tôi hay không."],[2356,2498,"Cái gì?"],[2535,2727,"Thưa sếp, rõ ràng cô ta đang lừa anh,"],[2727,2848,"để chiếm hàng tỷ của anh."],[2873,2952,"Cypher,"],[2990,3128,"nếu anh còn nói thêm một câu,"],[3178,3232,"tôi sẽ tự tay"],[3232,3349,"cắt lưỡi anh đấy."],[3399,3474,"Vâng, thưa sếp."],[3503,3586,"Tôi xin lỗi."],[4008,4120,"Cảm ơn sếp."],[4200,4287,"Hãy dùng nó để xét nghiệm"],[4287,4450,"và báo cáo cho tôi"],[4450,4542,"ngay khi có kết quả."],[4637,4767,"Tôi sẽ trực tiếp đi kiểm chứng."],[4842,4946,"Đi thôi."],[5426,5634,"Nếu cô bé ấy thật sự là con của mình,"],[5663,5755,"mình sẽ dành"],[5864,5997,"cả đời"],[6022,6131,"để cho con bé"],[6131,6335,"mọi thứ mà con bé hằng mong muốn."],[6456,6535,"Cô Hayes,"],[6581,6669,"cô nên biết rằng,"],[6669,6756,"bố cô..."],[6873,6931,"đang giận dữ."],[7144,7248,"Tất nhiên rồi."],[8062,8174,"Scarlett!"],[8283,8541,"Sao con dám?"]],"7":[[8,116,"Scarlett,"],[129,229,"công ty"],[229,367,"đang thua lỗ nặng,"],[367,521,"vậy mà con còn dám"],[521,646,"ló mặt ở đây."],[804,880,"Theo con được biết,"],[880,988,"bố là chủ tịch của hội đồng quản trị."],[988,1117,"Mớ hổ lốn này thuộc về bố, không phải con."],[1151,1255,"Làm ơn đi."],[1288,1480,"Nếu chị chịu kết hôn với Bennett Whitmore,"],[1480,1639,"thay vì bỏ chạy và sinh ra"],[1639,1735,"đứa con hoang này,"],[1768,1847,"chúng ta đã có đủ tiền"],[1847,1935,"để giải cứu công ty."],[1960,2127,"Câm miệng đi, Danielle."],[2160,2289,"Summer không phải con hoang."],[2302,2452,"Con bé có cả bố lẫn mẹ để yêu quý con bé."],[2510,2648,"Chúa ôi."],[2711,2815,"Mẹ, bố,"],[2815,2936,"mọi người có nghe gì không?"],[2965,3082,"Con chỉ mới nói một câu,"],[3103,3207,"vậy mà chị ấy đã muốn ăn tươi nuốt sống con."],[3240,3319,"Scarlett,"],[3353,3528,"sao con dám nói chuyện với em gái của mình"],[3528,3574,"như vậy?"],[3616,3841,"Con là kẻ đã mang thai,"],[3862,4008,"không khác gì một con đ*** lăng loàn"],[4074,4233,"mà không biết bố đứa trẻ là ai."],[4358,4412,"Chao ôi,"],[4412,4546,"con là nỗi xấu hổ"],[4546,4625,"của chúng ta."],[4654,4871,"Bennett Whitmore nói rằng cậu ta"],[4913,5067,"sẽ chấp nhận con, nếu con"],[5105,5171,"loại bỏ..."],[5267,5392,"dòng giống này."],[5430,5543,"Sao bố có thể nói như vậy?"],[5543,5663,"Đây là cháu gái của bố đấy."],[5697,5776,"Không hề."],[5809,5872,"Nó"],[5893,6072,"là một tai nạn không cha,"],[6114,6247,"chỉ hợp để sống ở cô nhi viện."],[6327,6464,"Cháu có bố."],[6481,6544,"Cháu có mà."],[6623,6798,"Bố sao?"],[6844,6911,"Anh ta đã ở đâu"],[6911,7061,"suốt bốn năm qua?"],[7127,7194,"Cháu có biết người ta nói gì"],[7194,7273,"về mẹ cháu không?"],[7311,7478,"Người ta nói chị ta là một con đ*** ngu xuẩn"],[7478,7632,"không biết giữ mình."],[7678,7749,"Và cháu chẳng là gì"],[7749,7878,"ngoài một tai nạn vô dụng"],[7878,8028,"không xứng đáng được ra đời."],[8128,8249,"Á, á."],[8287,8433,"Các người có thể sỉ nhục tôi."],[8479,8637,"Nhưng tôi thề, nếu các người còn nói lời nào"],[8637,8721,"về con gái tôi,"],[8754,8871,"Danielle, chính tay tôi"],[8892,9021,"sẽ cắt lưỡi cô."]],"8":[[20,237,"Bố, con khốn đó vừa đánh con."],[337,513,"Sao con dám động vào em gái?"],[558,692,"Giờ thì xin lỗi con bé ngay,"],[700,784,"còn không,"],[784,921,"bố sẽ cho con một trận"],[942,1109,"ngay trước đứa con gái hèn hạ của con."],[1113,1234,"Cô ta không phải em gái của con."],[1255,1472,"Cô ta chỉ là đứa con hoang của tiểu tam"],[1472,1593,"mà bố ngoại tình sau lưng mẹ."],[1735,1872,"Stephen,"],[1926,2127,"anh không thể để nó nói về mẹ con em như vậy."],[2160,2193,"Giờ,"],[2223,2310,"hãy là một người đàn ông,"],[2335,2444,"và ra mặt"],[2444,2606,"vì vợ và con gái của anh."],[3311,3449,"Mau xin lỗi đi."],[3820,3920,"Dừng lại."],[3953,4079,"Ông ngoại ơi, làm ơn."],[4079,4200,"Đừng đánh mẹ."],[4200,4337,"Làm ơn, ông đang làm đau mẹ."],[4404,4487,"Bỏ tao ra."],[4537,4575,"Á."],[4667,4742,"Summer."],[4913,5017,"Bố làm gì vậy?"],[5017,5113,"Con bé bị hen suyễn đấy."],[5134,5246,"Nếu nó chết,"],[5280,5359,"mọi thứ"],[5397,5568,"sẽ quay về quỹ đạo ban đầu."],[5601,5705,"Bố là một con quái vật."],[5734,5905,"Đưa thứ quái quỷ này ra khỏi đây."],[5935,5993,"Nhốt nó vào."],[6193,6318,"Summer, con yêu, mau thở đi."],[6343,6456,"Cố gắng thở đi."],[6906,6990,"Summer."],[7311