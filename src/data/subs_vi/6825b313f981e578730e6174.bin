{"1":[[291,446,"Ồ, này Chloe, cậu có thấy Jack đâu không?"],[446,704,"Tớ thấy cậu ấy vào phòng thí nghiệm 5 với cô gái nào đó."],[704,796,"Bạn cùng nhóm sao?"],[880,1084,"Jack đâu có bạn cùng nhóm."],[2477,2552,"Jack?"],[2727,2786,"Cái quái,"],[2786,2890,"chuyện quái gì đang xảy ra vậy?"],[2890,2952,"Anh đang làm gì vậy?"],[3007,3169,"Em đang hỏi anh đấy."],[3186,3328,"Trông giống chúng tôi đang làm gì?"],[3328,3424,"Bọn tôi đang hú hí."],[3499,3674,"Hôm nay là ngày đầu học cao học"],[3674,3849,"và em đã chuyển đến đây vì anh."],[3849,3983,"Thế mà anh lại cắm sừng em sao?"],[3983,4141,"Anh có bắt em làm vậy đâu."],[4170,4346,"Hơn nữa, em nghĩ mình trụ lại"],[4346,4500,"ở Princeton được bao lâu chứ?"],[4537,4658,"Anh chỉ chuẩn bị sẵn phương án dự phòng thôi."],[4854,4963,"Anh là đồ khốn."],[5413,5584,"Cứ vui vẻ hốt rác hộ tôi đi."],[6523,6740,"Trời ạ, không ngờ mình chuyển đến đây vì"],[6740,6902,"gã khốn đó, rồi bị hắn cắm sừng"],[6902,7019,"ngay ngày đầu tiên."],[7132,7240,"Chết tiệt."],[7486,7615,"Tôi, tôi xin lỗi."],[7820,7966,"Tôi, tôi tưởng đây là"],[8299,8366,"xe của mình."],[9113,9255,"Vậy cô cần tôi giết ai nào?"]],"2":[[538,704,"Tôi... tôi không, tôi không để ý."],[1084,1213,"Em đang chảy máu kìa."],[1334,1384,"Ngồi xuống đi."],[1509,1647,"Không, không sao đâu."],[3107,3178,"Ngậm vào đi."],[3319,3390,"Sao cơ?"],[4120,4179,"Ừm."],[4237,4466,"Thật sự không sao đâu."],[4466,4579,"Có sao đấy."],[4779,4884,"Em tự làm mình bị thương mà."],[5167,5347,"Nghiên cứu sinh tiến sĩ Khoa học Thần kinh."],[5347,5497,"Đáng lẽ em không nên"],[5543,5726,"đấm vào cửa kính chứ."],[5993,6135,"Sao anh biết chuyên ngành của tôi?"],[6193,6443,"Chúng tôi chỉ nhận 12 nghiên cứu sinh tiến sĩ"],[6443,6627,"vào chương trình mỗi năm."],[6861,6977,"Điều đó có nghĩa"],[7123,7278,"em là một cô gái xuất chúng."],[7716,7895,"Bạn trai tôi không nghĩ vậy."],[8041,8137,"Chuyện gì đã xảy ra?"],[8220,8358,"Tôi bắt quả tang anh ta ngoại tình."],[8412,8583,"Tôi chuyển đến đây chỉ vì anh ta, nên"],[8712,8858,"giờ tôi chẳng còn ai."],[9067,9180,"Em không đơn độc."],[9250,9438,"Em ở đây vì chính bản thân em."],[9476,9563,"Không phải vì hắn."],[9597,9801,"Hơn nữa, em là người phụ nữ đẹp nhất"],[9801,9897,"mà tôi từng gặp."],[10085,10197,"Vậy nên theo tôi thấy,"],[10335,10443,"người yêu cũ của em là một tên ngốc."],[12028,12199,"Em có thể về ký túc xá"],[12199,12328,"và khóc lóc vì người yêu cũ,"],[12529,12670,"hoặc em có thể về nhà với tôi."]],"3":[[2469,2540,"Sao vậy?"],[2656,2765,"Muốn anh chậm lại không?"],[2765,2819,"Không."],[2977,3148,"Em muốn anh đ** em thật mạnh để"],[3148,3449,"em quên mất thằng người yêu cũ khốn nạn cỡ bự của em."],[5038,5284,"Em sẽ không bao giờ dùng từ cỡ bự"],[5326,5530,"và người yêu cũ trong cùng một câu nữa đâu."],[6018,6143,"Hắn ta có làm em sướng thế này không?"],[6143,6206,"Không."],[6235,6364,"Ôi! - Gì vậy?"],[6381,6435,"Không."],[6823,6927,"Ngoan lắm."],[7203,7361,"Sao anh lại giỏi chuyện này thế?"],[7703,7828,"Vì trước giờ em toàn quen mấy thằng nhãi."],[7962,8058,"Còn anh là đàn ông."],[9330,9567,"Rất vui vì cô đã có mặt, cô Miller."],[9772,9943,"Chương trình Tiến sĩ Khoa học Thần kinh"],[9943,10181,"tại Princeton là chương trình khó nhất,"],[10181,10322,"và khắt khe nhất"],[10322,10606,"trong toàn bộ lĩnh vực khoa học não bộ."],[10606,10698,"Và đừng nghĩ rằng chỉ vì"],[10698,10848,"các cô cậu đã trúng tuyển"],[10890,11023,"Nhớ báo tôi nếu cô cần giúp dọn đồ nhé,"],[11023,11098,"Emily."]],"4":[[29,145,"Cút đi, Jack."],[145,371,"Ồ, vẫn giận vì một lỗi nhỏ à?"],[437,675,"Ngoại tình không phải lỗi nhỏ."],[867,1101,"Nghe này, chương trình Tiến sĩ"],[1101,1230,"toàn dựa vào quan hệ."],[1255,1484,"Khác với anh, em đâu quen ai."],[1576,1722,"Sẽ rất tiếc nếu không dự án nào của em"],[1722,1839,"được cấp vốn."],[1897,2010,"Anh đang định nói gì?"],[2097,2235,"Anh đang cố giúp em thôi."],[2298,2398,"Cứ suy nghĩ đi."],[2456,2619,"Cho anh lên giường bất cứ khi nào anh muốn."],[2652,2794,"Anh sẽ đảm bảo em luôn được cấp vốn."],[2873,2948,"Đôi bên cùng có lợi."],[2948,3048,"Eo ôi, Jack, không đời nào."],[3048,3228,"Còn anh nghe tôi này... - Và tiếp theo đây,"],[3228,3490,"tôi xin được nhường lời cho"],[3490,3661,"cố vấn chính mới của các bạn,"],[3732,3820,"Tiến sĩ Hayes."],[4112,4204,"Vãi thật."],[4204,4320,"Là Tử Thần đó."],[4396,4533,"Thầy ấy là học giả trẻ nhất"],[4533,4700,"từng được đề cử giải Nobel."],[4717,4946,"Thầy ấy từng khiến các tiến sĩ Princeton suy sụp"],[4946,5125,"và từ bỏ hoàn toàn sự nghiệp."],[7061,7127,"Chào bố."]],"5":[[0,262,"Tất cả hãy gọi tôi là Giáo sư Hayes."],[471,575,"Tôi không phải người nhà,"],[734,817,"hay bạn bè."],[975,1142,"Trong bốn năm tới,"],[1142,1222,"tôi sẽ định đoạt"],[1313,1405,"sự nghiệp,"],[1580,1685,"và tương lai của các cô cậu."],[2127,2181,"Chào mừng đến với chương trình"],[2181,2398,"Khoa học Thần kinh Tính toán của tôi."],[2631,2706,"Như các cô cậu đã biết,"],[2706,2894,"tỉ lệ hoàn thành là 20%."],[2990,3086,"Và tôi sẽ quên sạch tên các cô cậu,"],[3086,3182,"khả năng cao là thế."],[3182,3261,"Tuy nhiên,"],[3286,3440,"trong suốt học kỳ này, tôi sẽ"],[3440,3620,"tổ chức các buổi thảo luận 1-1."],[3774,3841,"Người đầu tiên,"],[3933,4012,"Emily Miller."],[4220,4304,"Vào văn phòng tôi,"],[4379,4437,"ngay đi."],[4904,5080,"Cô nói xấu tôi nửa lời,"],[5080,5184,"là cô sẽ bị đuổi."],[7061,7178,"Phiền cô đóng cửa lại được không?"],[7378,7469,"Được rồi, vậy thằng người yêu cũ,"],[7469,7653,"thằng khốn đó, chính là con trai tôi."],[7695,7866,"Và đây là một phần trong kế hoạch hoàn hảo,"],[7866,8049,"đây là thứ cái đầu tiến sĩ non nớt của cô"],[8049,8141,"nghĩ ra sao."],[8237,8370,"Là trả đũa thằng người yêu cũ"],[8370,8475,"bằng cách lên giường với bố nó à."]],"6":[[33,237,"Em không hề biết thầy là bố anh ta."],[283,533,"Thế cái đầu tiến sĩ non nớt của thầy không nghĩ đến"],[533,729,"khả năng em có thể là sinh viên của thầy"],[729,813,"trước khi đưa em về nhà sao,"],[813,900,"Giáo sư Hayes?"],[900,1034,"Lúc đó tôi không nghĩ gì cả, cô Miller à."],[1514,1622,"Nhìn thấy cô như vậy."],[1714,1951,"Nhìn thấy cô, đã làm tôi ngừng suy nghĩ."],[2143,2239,"Thầy có"],[2435,2598,"hối hận vì đã không suy nghĩ không?"],[2698,2765,"Không."],[2819,2927,"Tôi không hối hận."],[3003,3136,"Và tôi không biết điều gì tệ hơn."],[3315,3478,"Ngủ với người yêu cũ của con trai mình?"],[3582,3670,"Sinh viên của mình?"],[4283,4471,"Hay việc tôi lại muốn làm chuyện đó lần nữa?"],[4854,4938,"Ngay tại đây."],[5109,5188,"Ngay bây giờ."],[5868,5989,"Chúng ta không thể làm thế, hiểu chứ?"],[5989,6072,"Như vậy là sai trái."],[6268,6360,"Và tôi cảnh báo cô,"],[6523,6610,"đừng kể cho bất cứ ai."],[6690,6731,"Thầy đang"],[6819,6919,"cảnh báo em á?"],[7036,7107,"Thật luôn?"],[7157,7311,"Thầy thực sự nghĩ em muốn bắt đầu học kỳ"],[7311,7461,"bằng cách rêu rao cho cả trường biết"],[7461,7611,"rằng em đã lên giường với giáo sư sao?"],[7615,7782,"Đừng nói như thế, được không?"],[7853,7945,"Nghe thô thiển lắm."],[8643,8808,"Ngay khi cô bước ra khỏi căn phòng này,"],[9013,9117,"tôi là giáo sư của cô."],[9221,9325,"cô là sinh viên của tôi."],[9701,9864,"Mối quan hệ của chúng ta chỉ dừng ở đó."],[11198,11382,"Em đã chia sẻ bí mật của mình với thầy, giáo sư ạ."],[11569,11690,"Giờ thì chính thầy lại trở thành một bí mật."]],"7":[[1005,1126,"Chỉ một đoạn nữa thôi,"],[1126,1380,"rồi mình sẽ về."],[4642,4808,"Tập trung làm việc đi, Emily."],[4950,5217,"Nghiên cứu tiến sĩ"],[5342,5497,"rất quan trọng đấy."],[5751,5872,"Trông em căng thẳng thế."],[5893,6006,"Để anh giúp em giải tỏa nhé."],[6006,6064,"Á!"],[6064,6185,"Đừng chạm vào tôi, Jack."],[6214,6314,"Đừng có làm giá nữa."],[6406,6577,"Em biết ngoài anh ra chẳng ai thèm ngủ với em mà."]],"8":[[271,346,"Bố?"],[346,396,"Cái quái-"],[500,617,"Làm thầy của một thằng khốn nạn"],[617,767,"như mày đã đành."],[779,917,"Đằng này mày lại là con tao."],[917,1021,"Bố đừng can thiệp vào,"],[1021,1134,"bọn con chỉ đùa chút thôi."],[1222,1351,"Đừng có m* nó gọi tao như thế."],[1372,1451,"Khi phụ nữ đang khóc,"],[1451,1559,"mày phải để người ta yên."],[1597,1639,"Nhưng-"],[1639,1801,"Đi ngay! Trước khi tao đuổi học mày."],[2565,2648,"Emily."],[2886,3011,"Xin lỗi vì chuyện của Jack."],[3073,3199,"Đừng nghĩ đó là lỗi của em,"],[3261,3324,"chỉ tại nó"],[3324,3445,"chỉ biết suy nghĩ bằng thân dưới."],[3674,3737,"Em xin lỗi."],[3824,3912,"Đó là con trai thầy mà."],[4033,4145,"Đừng xin lỗi."],[4266,4346,"Nó là một nỗi nhục."],[4642,4713,"Em sẽ chết mất"],[4713,4842,"nếu không có anh ấy ngay lúc này."],[5188,5267,"Emily."],[5518,5593,"Chuyện gì vậy?"],[5722,5822,"Mất điện rồi."],[5955,6039,"Để tôi đi kiểm tra."],[6139,6222,"Khoan đã, thưa thầy."],[6364,6427,"Thầy đừng đi."]],"9":[[1230,1351,"Em nghĩ mình đang làm gì vậy?"],[1947,2047,"Làm điều em thấy đúng."],[2327,2460,"Điều cả hai ta đều muốn."],[3582,3678,"Đây là điều em muốn sao?"],[3678,3828,"Vâng, thưa Giáo sư Hayes."],[4396,4517,"Em biết em là học trò của tôi mà."],[4608,4833,"Chuyện này có thể hủy hoại sự nghiệp của hai ta"],[5046,5134,"mãi mãi đấy."],[5280,5380,"Em không quan tâm."],[6285,6348,"Ôi!"],[6481,6539,"Ồ."],[6785,6940,"Em muốn thế này sao?"],[7127,7315,"Vậy thì đừng lên tiếng."],[8621,8679,"Emily."],[8717,8804,"Cậu không sao chứ?"],[8804,8917,"Vừa mất điện một lúc."]],"10":[[16,158,"Emily, cậu không sao chứ?"],[196,333,"Vừa mất điện một lúc."],[387,483,"Bảo cô ta đi đi."],[709,775,"Ừ, Mia."],[775,946,"Tớ... tớ... tớ ổn."],[1459,1609,"Suỵt."],[1751,1876,"Đừng lên tiếng."],[1876,1993,"Cậu chắc chứ?"],[1993,2181,"Về luôn không? Muộn rồi đấy."],[2193,2431,"Ừm, cậu cứ về trước đi."],[2431,2556,"Tớ... tớ ra sau."],[3123,3219,"Ngoan lắm."],[4973,5146,"Dữ liệu sai bét rồi."],[5643,5764,"Mình bị sao thế này?"],[7525,7631,"Không, không thể thế được."],[7807,7918,"Đang xem gì đấy, Emily?"]],"11":[[304,404,"Đang xem gì đấy, Emily?"],[663,754,"Không phải việc của anh."],[788,846,"Tránh ra."],[1514,1822,"Ồ, vậy ứng viên tiến sĩ xuất sắc"],[1822,1951,"có thai rồi hả?"],[1993,2067,"Gì chứ, chúng ta mới chia tay"],[2067,2186,"được hai tháng thôi."],[2186,2306,"Đứa bé chắc chắn là của tôi."],[2306,2389,"Không. Buông tôi ra."],[2389,2485,"Đồ khốn."],[2485,2623,"Đâu ai lại ăn nói với cha"],[2623,2694,"của con mình như thế."],[2698,2786,"Hơn nữa, cô đâu muốn tôi kể"],[2786,2911,"chuyện cô có thai cho cả khoa,"],[2911,2969,"phải không?"],[3036,3132,"Họ không muốn phải mất công"],[3132,3274,"tuyển nghiên cứu viên mới đâu."],[3274,3353,"Đứa bé không phải của anh,"],[3353,3457,"không liên quan đến anh."],[3457,3607,"Ồ, thế ra cô cắm sừng tôi à?"],[3607,3745,"Trời ạ, cô đúng là con đ* lăng loàn."],[3745,3945,"Không, anh mới ngoại tình, đồ khốn."],[3945,4108,"Thế nên tôi mới chia tay anh."],[4108,4270,"Tôi chẳng nợ nần gì anh. Buông ra!"],[4270,4454,"Cô nghĩ mình có quyền quyết định à?"],[4454,4604,"Cô nghĩ muốn bỏ tôi là được sao?"],[4650,4738,"Mơ đi."]],"12":[[479,638,"Bố, bố làm gì ở đây vậy?"],[2218,2394,"Bố làm cái đ*o gì thế?"],[2481,2552,"Em không sao chứ?"],[2552,2715,"Cô ấy không sao đâu bố."],[2794,2907,"Bố sắp làm ông nội rồi đấy."],[2915,3065,"Không, không phải vậy đâu ạ."],[3065,3111,"Emily."],[3111,3178,"Thôi nào."],[3194,3307,"Mình đã ở bên nhau nhiều năm."],[3357,3428,"Không đời nào em lại mang thai"],[3428,3549,"con của người khác."],[3695,3778,"Em có thai à?"],[4062,4191,"Đứa bé không phải của anh."],[4191,4283,"Emily."],[4300,4429,"Anh biết em nghĩ anh là thằng khốn,"],[4429,4542,"nhưng anh thật sự muốn làm bố."],[4542,4683,"Đứa bé không phải của anh."],[4683,4767,"Bởi vì,"],[5021,5138,"vì nó không phải của tôi."],[5205,5355,"Que thử thai đó không phải của tôi."],[5355,5422,"Là của Mia."],[5422,5509,"Vớ vẩn."],[5509,5663,"Sao em lại có que thử thai của Mia?"],[5663,5847,"Thêm một lời nào về trò vớ vẩn này nữa"],[5847,5985,"là tôi đuổi cậu khỏi chương trình ngay."],[5985,6035,"Bố!"],[6035,6185,"Gọi tôi là Giáo sư Hayes!"],[6322,6564,"Đừng làm tôi bẽ mặt thêm nữa."],[6619,6715,"Về lớp ngay."],[8687,8821,"Đứa bé là của tôi, đúng không?"]],"13":[[362,521,"Không, tôi không có thai."],[521,575,"Tôi đã bảo anh rồi,"],[575,704,"đó là hiểu lầm."],[1030,1155,"Vậy tại sao cô lại xin"],[1155,1284,"bảo lưu?"],[1505,1630,"Em xin lỗi, Giáo sư Hayes."],[1630,1710,"Nhưng đây là việc cá nhân."],[1710,1830,"Em không thể nói được."],[2089,2198,"Vậy thì tôi sẽ không ký."],[2198,2260,"Sao cơ?"],[2373,2452,"Thầy không thể làm vậy."],[2452,2610,"Tôi sẽ không ký trừ khi cô nói cho tôi"],[2610,2677,"sự thật."],[2715,2802,"Tôi đã kiểm tra,"],[2886,3036,"bài nghiên cứu của cô đang tiến triển rất tốt"],[3036,3144,"để được xuất bản."],[3244,3349,"Cô sẽ không từ bỏ nó"],[3349,3461,"trừ khi có chuyện nghiêm trọng"],[3461,3524,"đang xảy ra."],[3699,3782,"Em đã nói rồi,"],[3891,4037,"em không tiện nói mà."],[4846,5005,"Mày không thể nói với giáo sư"],[5005,5234,"rằng mày đang mang thai con của thầy ấy, Emily."],[5280,5484,"Việc đó sẽ hủy hoại cuộc đời của cả hai."],[5613,5818,"Mình sẽ hoàn thành luận văn rồi nghỉ học."],[5910,6097,"Rồi sẽ chỉ có hai mẹ con mình thôi, bé con à."],[6806,6911,"Cậu biết Giáo sư Hayes"],[6911,6990,"nói gì với tớ không?"],[7007,7165,"Thầy bảo tớ để sai chỗ câu luận điểm,"],[7165,7336,"vì nó đáng bị vứt vào thùng rác"],[7336,7428,"chứ không phải trong bài làm."],[7503,7665,"Ừ thì, thầy ấy thực sự"],[7665,7820,"đã ném bài của tớ đi, nên"],[7882,8041,"Cậu nghĩ thầy có chiếu cố tớ nếu tớ"],[8041,8183,"thổi kèn cho thầy sướng nhất đời không?"],[8216,8462,"Eo ôi. Cậu ngủ với con trai thầy rồi mà."],[8462,8583,"Ôi dào, Giáo sư Hayes"],[8583,8679,"còn nóng bỏng hơn Jack."],[8679,8796,"Ai mà chẳng biết."],[8796,8933,"Chúc may mắn nhé."],[8975,9109,"Có bốn sinh viên đã bị đuổi học"],[9109,9200,"vì chuyện đó rồi."],[9200,9351,"Chính thầy ấy đã báo cáo họ."],[9351,9638,"Cứ như thầy miễn nhiễm với gái hay sao ấy."],[9826,9876,"Chuẩn."],[9939,10060,"Nhưng rõ ràng trừ cô kia ra."],[10097,10285,"Trời ạ, thầy dành hết thời gian cho cô ta."],[10301,10435,"Tớ cá là cô ta đang ngủ với thầy."],[10435,10602,"Trước là con trai rồi giờ đến ông bố."],[10602,10710,"Kinh tởm."],[10794,11052,"Ừ, tớ luôn nghĩ Emily là con lăng loàn."],[11052,11123,"Dù sao thì."],[11265,11357,"Nhìn đây."],[12120,12241,"Trời ơi, con tôi!"]],"14":[[87,183,"Úi."],[321,404,"Bụng tôi."],[454,538,"Thì làm sao?"],[538,679,"Tôi thấy bình thường mà."],[825,917,"Trời ạ, Tiff."],[980,1105,"Cậu quá đáng rồi đấy."],[1105,1272,"Bọn mình nỗ lực bao lâu mới"],[1272,1338,"vào được chương trình này."],[1338,1493,"Còn con lăng loàn này lên giường để được nhận."],[1580,1714,"Tớ không thấy có gì là quá đáng cả."],[2097,2202,"Ôi trời ơi."],[2202,2419,"Emily, báo cáo của cô kìa."],[2519,2723,"Chắc cô không nộp đúng hạn được nữa rồi."],[2769,2932,"Tiff, cô đúng là con khốn."],[3115,3207,"Có chuyện quái gì ở đây vậy?"]],"15":[[417,500,"Chuyện gì vậy?"],[550,608,"Có phải-"],[900,1021,"Bụng cô không sao chứ?"],[1359,1522,"Tử thần cũng biết mủi lòng sao?"],[1718,1818,"Cô đã làm gì?"],[2047,2231,"Emily trượt chân làm đổ cà phê của em."],[2298,2381,"Đúng không nào?"],[2494,2568,"Đúng vậy."],[2786,2898,"Ai cũng biết bố mẹ em"],[2898,2990,"chơi thân với viện trưởng."],[3011,3174,"Nên sẽ chẳng ai dám hé răng đâu."],[3232,3350,"Tôi cho cô thêm một cơ hội"],[3350,3486,"để nói sự thật."],[3536,3716,"Cô đã làm gì cô Miller?"],[3895,3991,"Có ai biết không?"],[4195,4396,"Ôi, Giáo sư Hayes."],[4396,4529,"Có khi em nên kể với viện trưởng"],[4529,4629,"về việc thầy thân thiết thế nào,"],[4629,4708,"với Emily bé nhỏ đây."],[4708,4859,"Trong bữa tối cuối tuần này."],[4938,5117,"Cả sự ưu ái đặc biệt thầy dành cho cô ta nữa?"],[5559,5676,"Thầy làm cái quái gì vậy?"],[5764,5868,"Dọn rác thôi."],[5939,6022,"Cô bị đuổi rồi."],[6022,6085,"Gì cơ?"]],"16":[[0,45,"Gì cơ?"],[91,187,"Ông không thể đuổi tôi."],[187,321,"Tôi sẽ gọi cho viện trưởng."],[321,450,"Viện trưởng sao?"],[450,652,"Viện trưởng vừa nhận 200.000.000 đô la"],[652,871,"tiền tài trợ nhờ nghiên cứu của tôi á?"],[963,1142,"Tôi không nghĩ bà ấy sẽ chọn cô đâu."],[1142,1348,"Một đứa ranh vô não, bất tài,"],[1348,1500,"và vô dụng"],[1500,1676,"đã dùng tiền mua suất vào chương trình"],[1676,1872,"thay vì người đoạt giải Nobel của bà ấy."],[1918,2110,"Tiffany dùng tiền để vào đây á?"],[2193,2406,"Tưởng cô ta bảo tự nỗ lực mà."],[2406,2485,"Chuyện đó-"],[2485,2590,"Ông ta nói dối."],[2590,2815,"Ai đó cản ông ta lại đi, tôi đang bị quấy rối!"],[2815,2919,"Cút khỏi lớp học này và"],[2919,3073,"biến f**k khỏi chương trình của tôi"],[3073,3186,"trước khi tôi kiện cô."],[3261,3457,"Vì đổ cà phê lên cái báo cáo ngu ngốc của cô ta á?"],[3486,3520,"Không."],[3549,3628,"Và cũng không phải chỉ vì"],[3628,3795,"cô là sinh viên tệ nhất tôi từng dạy."],[3832,3941,"Mà vì cô là một con người"],[3974,4066,"rất tồi tệ."],[4304,4504,"Cô chẳng bằng một góc của Emily."],[4562,4675,"Tôi cần cô nhét điều đó vào đầu"],[4675,4833,"trước khi nộp đơn lại."],[4833,4992,"Dù tôi nghĩ các trường Ivy"],[4992,5150,"cũng chẳng hứng thú gì với cô đâu."],[5301,5397,"Con b**ch!"],[5455,5643,"Mày và lão già f**k này sẽ phải hối hận."],[5805,5922,"Giáo sư Hayes."],[5922,6018,"Tất cả ra ngoài hết."],[6018,6126,"Lớp nghỉ."],[6202,6377,"Nhưng bọn em có làm gì đâu."],[6377,6456,"Đúng, chính xác."],[6456,6535,"Các cô cậu chỉ ngồi đó và nhìn"],[6535,6673,"bạn học của mình bị bắt nạt."],[6769,6861,"Thật đáng xấu hổ."],[6981,7065,"Tất cả ra ngoài!"],[7769,7869,"Còn em ở lại."]],"17":[[258,462,"Thầy không cần phải làm vậy đâu, Giáo sư."],[625,700,"Tôi phải làm vậy."],[825,896,"Em biết là tôi phải làm mà."],[1351,1484,"Sao em cứ đẩy tôi ra xa?"],[1593,1672,"Nói tôi nghe đi."],[1868,2022,"Em đang giấu tôi chuyện gì?"],[2039,2117,"Không có gì, em,"],[2177,2381,"em phải đi viết lại báo cáo."],[2419,2556,"Mặc kệ báo cáo đó đi."],[3261,3374,"Giáo sư."],[3724,3766,"Tôi biết."],[3766,3916,"Không, thầy không biết đâu."],[3991,4167,"Emily, xin em đừng khóc nữa."],[4279,4396,"Nói tôi nghe có chuyện gì."],[4471,4608,"Em biết phải nói gì đây?"],[4654,4804,"Giáo sư, chúng ta sắp có con,"],[4804,4984,"và em muốn thầy từ bỏ sự nghiệp"],[4984,5125,"để cùng em nuôi con sao?"],[5309,5401,"Nói gì đi chứ."],[5826,5914,"Không có gì đâu."],[6031,6151,"Thầy không hiểu được đâu."],[6277,6339,"Emily."],[6531,6702,"Đó chỉ là tình một đêm thôi, Giáo sư."],[6831,6940,"Một sai lầm."],[6981,7115,"Chúng ta không có mối quan hệ nào,"],[7115,7269,"nên thầy đừng hành xử như thể chúng ta có."],[7269,7361,"Đó không phải là lời thật lòng."],[7399,7520,"Xin lỗi, em phải đi."],[7836,7966,"Charles Hayes."],[8037,8166,"Anh bị sao vậy?"],[8316,8395,"Anh"],[8491,8629,"yêu cô ta à?"]],"18":[[621,834,"Người mình nồng nặc mùi axit clohydric."],[934,1084,"Mình phải đi tắm thôi."],[1172,1285,"Em nói thật đấy, Viện trưởng Hearst."],[1285,1453,"Emily Miller đã hãm hại em."],[1509,1710,"Vâng! Em dám chắc cô ta có"],[1710,1926,"quan hệ bất chính với Giáo sư Hayes."],[2131,2268,"Vâng, thưa Viện trưởng Hearst,"],[2298,2427,"em sẽ tìm bằng chứng."],[3812,3866,"Để xem mày chối tội"],[3866,4054,"tắm chung với giáo sư kiểu gì."],[4083,4179,"Con khốn."],[6819,6923,"Có ai không?"],[7570,7636,"Trời ơi."],[7636,7695,"Emily, cô làm gì"],[7695,7799,"trong nhà tắm nam vậy?"],[7828,7982,"Đây là phòng thay đồ nữ mà."],[7982,8133,"Emily Miller, bọn tôi biết cô"],[8133,8270,"ở trong này với giáo sư."],[8270,8362,"Ra đây đi."]],"19":[[104,200,"Emily."],[246,437,"Đừng trốn nữa."],[1188,1297,"Nếu họ bắt được cô ở đây,"],[1297,1388,"tôi có thể bị đuổi học đấy."],[2277,2435,"Tìm thấy mày rồi, con khốn."],[2460,2573,"Tôi không biết sao cô lại"],[2573,2723,"vào phòng thay đồ,"],[2723,2894,"Tiffany, nhưng cô nên ra ngoài đi."],[2894,3107,"Nếu không cô sẽ chuốc lấy hậu quả đấy."],[3107,3265,"Vâng, chắc rồi, Giáo sư."],[3265,3449,"Bọn tôi biết thầy ở trong này cùng Emily."],[3528,3774,"Này, tôi đảm bảo tôi chỉ ở đây một mình."],[3774,3995,"Nếu các cô khăng khăng vào kiểm tra,"],[3995,4158,"tôi sẽ báo cáo tội quấy rối."],[4216,4379,"Nhưng, sao có thể?"],[4379,4546,"Tôi thề là Emily ở đâu đó trong này!"],[4546,4750,"Sao cô lại ám ảnh với Emily thế?"],[4788,4896,"Cô không cần bằng tiến sĩ đâu."],[4896,5005,"Cô cần đi trị liệ