,[625,721,"Để anh đuổi nó về."],[1605,1772,"Bố mở cửa lâu thế."],[1772,1872,"Bố giấu cô nàng nào ở trong đó"],[1872,1981,"hay sao thế?"],[1981,2189,"Jack, không có việc gì quan trọng thì về đi."],[2189,2277,"Bố đang bận."],[2356,2548,"Hôm nay con có đến bệnh viện."],[2548,2798,"Định thăm Emily, nhưng bác sĩ"],[2798,2944,"bảo cô ấy xuất viện rồi."],[3107,3349,"Con là con trai bố, đúng không?"],[4295,4491,"Mấy năm rồi con mới thấy bố nấu ăn đấy."],[4525,4717,"Thì bố bảo rồi, bố đang bận."],[4717,4859,"Bố biết chuyện gì buồn cười không?"],[4904,5050,"Bệnh viện nói người"],[5050,5192,"làm thủ tục xuất viện cho Emily"],[5292,5376,"lại chính là bố."]],"25":[[0,159,"Bệnh viện nói người làm thủ tục"],[159,362,"xuất viện cho Emily lại chính là bố."],[513,596,"Đúng thế."],[675,825,"Hoàn cảnh gia đình của Emily"],[825,975,"hơi phức tạp một chút."],[975,1226,"Nên bố là số liên lạc khẩn cấp của con bé."],[1272,1418,"Vậy rốt cuộc chuyện gì đã xảy ra?"],[1447,1576,"Cô ấy ngã trong phòng tắm,"],[1576,1747,"đập đầu trúng đâu đó hay sao?"],[1776,1906,"Sao lại nghiêm trọng đến thế?"],[1947,2139,"Bố nghĩ chuyện đó không liên quan đến con đâu, Jack."],[2481,2656,"Vitamin cho bà bầu."],[2748,2932,"Bố giấu Emily trong đó đúng không?"],[3053,3148,"Bố muốn con ra ngoài."],[3174,3269,"Đúng không?"],[3303,3432,"Và con muốn bố nói cho con biết"],[3432,3528,"cái quái gì đang xảy ra"],[3528,3687,"giữa bố và bạn gái cũ của con?"],[3753,3895,"Bố đối xử với cô ấy rất khác."],[3962,4162,"Sinh viên gọi bố là Thần Chết,"],[4162,4337,"nhưng với cô ấy, bố lại khác."],[4337,4471,"Bố lại mềm mỏng quá mức."],[4533,4646,"Bố không biết người ngoài nhìn vào"],[4646,4763,"sẽ đánh giá thế nào à?"],[4763,4913,"Con nghĩ nhiều quá rồi!"],[4913,5100,"Bố chỉ làm đúng bổn phận của giáo viên hướng dẫn."],[5142,5276,"Không giáo viên nào lại đứng nhìn"],[5276,5388,"học trò của mình bị bắt nạt cả."],[5426,5505,"Chứng minh đi."],[5526,5638,"Nói con nghe cô ấy ở đâu."]],"26":[[20,145,"Nói con nghe cô ấy ở đâu."],[191,300,"Bố sẽ không nói."],[404,500,"Con không tốt cho con bé."],[500,604,"Sao bố lại quan tâm?"],[671,855,"Cô ta chỉ là học trò của bố thôi mà?"],[1005,1305,"Bố à, bố là một học giả đạt giải Nobel."],[1305,1418,"Bố thực sự định đánh đổi"],[1418,1576,"danh tiếng vì một con nhỏ ngu ngốc sao?"],[1584,1793,"Hơn nữa, bố đâu có thật lòng quan tâm cô ta."],[1872,1972,"Bố còn chẳng thèm đoái hoài đến con"],[1972,2068,"dù con là con ruột của bố."],[2122,2235,"Bố đâu phải kiểu người vì gia đình."],[2256,2410,"Mẹ con không muốn bố xuất hiện trong đời con,"],[2410,2519,"nhớ không, Jack?"],[2556,2681,"Bà ấy cho rằng nghiên cứu của bố"],[2681,2823,"chẳng đi đến đâu nên đã bỏ đi."],[2940,3069,"Ý bố là, con có cần bố phải nhắc lại"],[3069,3211,"rằng chúng ta chưa từng qua lại"],[3211,3378,"cho đến khi con xin vào chương trình của bố?"],[3407,3566,"Hay việc con chỉ xuất hiện trong đời bố"],[3566,3728,"vì bố đoạt giải Nobel."],[3774,3899,"Con và mẹ con."],[3899,3999,"Đều là lũ kền kền!"],[4029,4187,"Nên m* kiếp, đừng hòng dạy đời bố"],[4187,4308,"về hai chữ gia đình, con trai ạ!"],[4308,4458,"Con chẳng biết gì về chuyện đó đâu."],[4491,4654,"Bố nghĩ con là kền kền sao?"],[4654,4783,"Vậy cô ta là một con đ** rẻ tiền."],[4846,4954,"Về với mẹ con đi."],[5030,5163,"Đừng quay lại nữa."],[6523,6614,"Giáo sư."]],"27":[[554,671,"Em nghe thấy hết rồi à?"],[888,1071,"Em không biết thầy từng trải qua chuyện đó."],[1430,1509,"Này,"],[1659,1768,"sao em lại khóc?"],[1805,2018,"Thầy đã phải chịu đựng quá nhiều rồi."],[2193,2260,"Và giờ,"],[2364,2469,"em chỉ"],[2560,2752,"em lại trở thành gánh nặng của thầy."],[2752,2869,"Em không phải gánh nặng."],[2977,3111,"Nghe này, đừng nghĩ như vậy."],[3140,3353,"Em không thể không nghĩ như vậy được."],[3482,3586,"Jack nói đúng."],[3624,3849,"Thầy là người đạt giải Nobel, và,"],[3920,4029,"và là thành viên của"],[4029,4175,"Viện Hàn lâm Khoa học Quốc gia."],[4258,4329,"Còn,"],[4366,4504,"còn em chỉ là"],[4725,4859,"một kẻ vô danh."],[5075,5230,"Cùng một đứa con vô danh."],[5397,5518,"Và mẹ con em sẽ"],[5718,6010,"hủy hoại sự nghiệp và danh tiếng của thầy."],[6010,6122,"Không đâu."],[6260,6343,"Hãy tin tôi."],[6427,6535,"Cho tôi thêm chút thời gian."],[6535,6656,"Mọi chuyện rồi sẽ ổn thôi."],[6810,7032,"Giáo sư, em không thể là lý do khiến"],[7140,7307,"thầy hủy hoại cuộc đời mình."],[7399,7528,"Hãy gọi anh là Charles."],[7674,7774,"Nhưng"],[8796,8925,"Emily,"],[9071,9175,"ở lại với anh nhé."],[9317,9509,"Em là điều chân thật duy nhất với anh."],[9768,9943,"Anh nghĩ anh yêu em mất rồi."]],"28":[[0,171,"Em nghĩ em yêu anh mất rồi."],[275,337,"Chà,"],[508,688,"anh nghĩ anh đã yêu em trước rồi."],[1997,2081,"A lô?"],[2122,2260,"Bố đang giấu chuyện gì đó."],[2314,2469,"Con nghĩ bố có người phụ nữ khác."],[2502,2640,"Charles là của mẹ."],[2640,2723,"Ông ấy từng yêu mẹ."],[2723,2819,"Bây giờ ông ấy vẫn yêu mẹ."],[2819,2894,"Không một ai khác."],[2894,3044,"Mẹ à, chính mẹ đã bỏ bố mà."],[3086,3174,"Jack con yêu,"],[3174,3311,"nếu hồi đó mẹ cưới bố con,"],[3311,3507,"thì chúng ta đã sống ở một xó xỉnh nào đó rồi."],[3507,3641,"Hồi đó ông ấy trắng tay, chẳng là ai cả."],[3737,3853,"Nhưng giờ thì khác."],[3899,4045,"Ông ấy gần như là tỷ phú rồi."],[4045,4200,"Một thiên tài hay người ta gọi là gì đi nữa."],[4200,4371,"Và chúng ta là gia đình của ông ấy."],[4404,4567,"Tất cả những thứ đó cũng là của chúng ta."],[4583,4808,"Và không con khốn nào được cướp đồ của mẹ."],[5000,5100,"Mẹ, đợi đã."],[5100,5276,"Con nghĩ con biết con b**ch đó là ai rồi."],[6297,6343,"Thì ra,"],[6414,6581,"cô là người mà ông ấy giấu ở trên đó."],[6581,6690,"Nói tôi nghe đi, Emily."],[6690,6852,"Cô ngủ với bố tôi bao lâu rồi?"],[6869,6990,"Đồ sl*t đê tiện."],[6990,7061,"Ôi trời ơi."]],"29":[[742,917,"Cô ngủ với bố tôi bao lâu rồi?"],[917,1038,"Đồ sl*t đê tiện."],[1038,1109,"Ôi trời ơi."],[1109,1247,"Lại còn mang thai con ông ta à?"],[1247,1418,"Con f**king điên này!"],[1622,1676,"Buông ra-"],[1705,1805,"Buông ra!"],[2060,2160,"Giáo sư."],[2485,2581,"Bố là bố của con mà."],[2581,2694,"Cô ta là bạn gái cũ của con."],[2694,2798,"Ừ, thì sao?"],[2831,2944,"Thì sao à?"],[2944,3086,"Bố đang ngủ với bạn gái cũ của con!"],[3115,3240,"Con sl*t này."],[3278,3432,"Cô có f**k ông ta như f**k tôi không?"],[3474,3553,"Ông ta có thích-"],[3945,4166,"Bố chọn cô ta thay vì con sao?"],[4166,4266,"Con trai ruột của bố ư?"],[4266,4354,"Tao đã cảnh báo mày rồi!"],[4354,4446,"Mày còn ăn nói kiểu đó nữa,"],[4446,4604,"mẹ mày sẽ không còn nhận ra mày nữa đâu."],[4633,4888,"Con sẽ phanh phui chuyện này, bố biết mà."],[4888,5075,"Chuyện này sẽ hủy hoại sự nghiệp của bố."],[5075,5180,"Muốn làm gì thì làm,"],[5180,5284,"mày không động được vào tao đâu."],[5330,5426,"Tao thề có Chúa,"],[5426,5593,"mày mà còn vác mặt đến trước Emily lần nữa,"],[5593,5734,"tao sẽ lấy lại từng xu tao đã cho mày,"],[5734,5826,"và cả mẹ mày."],[5880,6056,"Theo như tao biết, mày sẽ trắng tay thôi."],[7528,7682,"Người phụ nữ bố đang ngủ cùng,"],[7741,7912,"là bạn gái cũ của con, Emily."]],"30":[[12,212,"Người phụ nữ bố đang ngủ cùng,"],[212,417,"là bạn gái cũ của con, Emily."],[417,671,"Và tệ hơn là cô ta đang mang thai."],[671,809,"Cô ta sao cơ?"],[809,930,"Nếu bố cưới cô ta,"],[930,1067,"Ý con là, ngay cả khi bố không cưới."],[1067,1197,"Đứa con hoang đó sẽ cướp đi"],[1197,1280,"những gì của chúng ta."],[1280,1455,"Và con sẽ không để chuyện đó xảy ra."],[3428,3478,"Em sẽ nộp đơn"],[3478,3624,"xin bảo lưu vào ngày mai."],[3624,3737,"Em không thể để anh hy sinh"],[3737,3824,"sự nghiệp vì em được."],[3824,3895,"Xin bảo lưu sao?"],[3895,3983,"Không."],[4041,4141,"Giờ em cần ở lại đây,"],[4141,4291,"và anh sẽ đảm bảo em an toàn."],[4320,4475,"Giáo sư."],[4658,4808,"Em nghĩ biến mất khỏi cuộc đời anh"],[4808,5013,"là cách duy nhất để giải quyết mọi chuyện."],[5013,5155,"Sao cơ, sau tất cả những chuyện đó,"],[5155,5372,"em vẫn nghĩ anh là gã vô tâm, ích kỷ"],[5372,5509,"sẽ bỏ rơi mẹ con em"],[5509,5647,"để tự bảo vệ mình sao?"],[5647,5734,"Không,"],[5805,5960,"em không thể là người ích kỷ được."],[5985,6331,"Em không thể để anh từ bỏ mọi thứ vì em."],[6381,6448,"Anh đã nói rồi."],[6644,6752,"Anh nghĩ là anh yêu"]],"31":[[525,684,"Không được đâu anh."],[888,1109,"Đừng đẩy anh ra nữa."],[1288,1476,"Em không muốn làm liên lụy anh."],[1568,1830,"Anh đã vất vả lắm mới có được ngày hôm nay."],[1926,2085,"Nếu anh mất tất cả vì em,"],[2085,2264,"em sẽ không thể tha thứ cho bản thân."],[2873,2986,"Emily Miller."],[3165,3324,"Em thật sự rất đặc biệt."],[3378,3591,"Giáo sư, em nghiêm túc đấy."],[3728,3878,"Mọi thứ anh có."],[3941,4241,"Mọi thứ anh có đều vô nghĩa,"],[4300,4450,"nếu anh không có em."],[4792,5034,"Nhưng còn Jack và, và mẹ cậu ấy."],[5163,5388,"Người ta sẽ nói gì về tuổi tác của chúng ta?"],[5417,5547,"Tuổi tác thì sao chứ?"],[5643,5784,"Anh lớn tuổi hơn một chút,"],[5935,6060,"từng trải hơn một chút,"],[6164,6289,"giàu hơn một chút."],[6368,6468,"Em không thích sao?"],[6468,6594,"Giáo sư!"]],"32":[[1167,1284,"Chào buổi sáng."],[1284,1397,"Chào buổi sáng."],[1505,1647,"Sao anh dậy sớm thế?"],[1820,1951,"Anh không ngủ được."],[2100,2230,"Anh sợ em lại định"],[2230,2402,"bỏ đi lần nữa."],[2602,2777,"Giáo sư."],[3307,3470,"Anh chắc là sẽ ổn chứ?"],[3645,3820,"Nhỡ người ta bàn tán thì sao?"],[3858,3953,"Tin anh đi."],[4108,4233,"Em tin anh mà."],[4412,4612,"Nhưng chỉ vì anh đang quá đáng yêu thôi."],[4963,5176,"Khi ở trường"],[5176,5347,"Khi ở trường,"],[5347,5484,"anh là giáo sư của em."],[5609,5764,"Còn em là cô học trò thông minh,"],[5830,5964,"chăm chỉ,"],[6010,6168,"và dũng cảm của anh."],[6352,6477,"Có chuyện gì xảy ra được chứ?"],[8550,8612,"Ra ngoài!"],[8700,8787,"Vào thì phải gõ cửa chứ."],[8787,8855,"Ồ, vợ anh đâu cần"],[8855,9063,"tuân theo mấy quy tắc ngớ ngẩn đó."]],"33":[[4,125,"Cô đến đây làm gì?"],[125,312,"Em nghe được vài tin đồn chấn động đấy, Charles."],[325,483,"Em đến xem chúng có đúng không."],[483,650,"Xem chồng em có thật sự ngốc đến mức"],[650,763,"làm nữ sinh có bầu không."],[763,938,"Tôi không có gì để nói với cô cả, hiểu chứ?"],[938,1034,"Mời cô ra ngoài."],[1080,1155,"Khoan đã."],[1242,1418,"Nghe này, em biết năm xưa em đã sai."],[1418,1472,"Nhưng"],[1551,1668,"em đã thay đổi rồi."],[2089,2260,"Giáo sư Hayes, em vào được không ạ?"],[2260,2385,"Không, lúc này không tiện."],[2385,2485,"Vào đi."],[2585,2886,"Sao trong phòng Charles lại có phụ nữ thế này?"],[2911,3094,"Em sẽ quay lại sau."],[3349,3549,"Ồ! Cô có chuyện muốn bàn"],[3549,3674,"với chồng tôi sao?"],[3958,4079,"Chồng ư?"]],"34":[[233,325,"Chồng ư?"],[367,500,"Phải, là chồng."],[500,633,"Tôi và Charles đã bên nhau"],[633,729,"từ hồi đại học."],[729,813,"Được rồi, đủ rồi đấy."],[813,896,"Đừng có nói dối nữa."],[896,1005,"Charles,"],[1005,1105,"anh đã bỏ em khi em mang thai"],[1105,1230,"bé Jack."],[1297,1426,"Mẹ con em chỉ cần anh thôi."],[1426,1564,"Vậy mà anh còn chẳng thèm cho-"],[1564,1705,"Bớt nói nhảm đi, Ruby!"],[1797,1897,"Là cô bỏ tôi."],[1935,2147,"Giữa chúng ta không còn gì nữa đâu."],[2147,2352,"Cô tự chọn thì tự mà chịu đi."],[2352,2485,"Em có lý do của mình mà."],[2736,2861,"Em cần gì à, Emily?"],[3090,3269,"Vâng, thưa Giáo sư."],[4421,4512,"Emily."],[4621,4846,"Ra đây là con khốn bị chồng tao làm cho có chửa."]],"35":[[229,279,"Emmy-"],[279,404,"Đó là mẹ của Jack, đúng không?"],[421,550,"Em tưởng anh nói mọi chuyện đã kết thúc"],[550,617,"giữa hai người rồi."],[617,679,"Đúng thế."],[800,896,"Và bọn anh chưa từng kết hôn."],[930,1051,"Vậy sao anh lại thấy cần"],[1051,1201,"phải giấu em khỏi cô ta?"],[1201,1280,"Phải nói dối?"],[1280,1363,"Emmy."],[1422,1526,"Không, anh nghe em nói này."],[1605,1735,"Chính anh đã nói là"],[1735,1793,"khi chúng ta ở trường-"],[1793,1956,"Nhưng nó, nó khác lắm. Nó,"],[1956,2202,"Nó khác và khó khăn, và"],[2227,2335,"Em không biết nữa."],[2498,2598,"Vợ cũ của anh,"],[2598,2898,"người tình cũ của anh, hay gì cũng được-"],[3003,3082,"cô ta được làm"],[3082,3174,"mọi điều cô ta muốn với anh"],[3174,3257,"bất cứ lúc nào cô ta muốn."],[3257,3570,"Còn em thì vẫn phải gọi anh là"],[3570,3820,"giáo sư kể cả khi không ở trường."],[3899,4045,"Sao anh lại cười?"],[4208,4337,"Vì anh thấy kích thích"],[4337,4433,"khi thấy em ghen."],[4625,4783,"Em không thèm ghen."],[5280,5372,"Ở trường sao?"],[5372,5501,"Anh điên à?"],[5551,5718,"Anh tưởng em bảo em muốn làm"],[5893,5989,"những gì em thích với anh?"],[7845,7978,"Ôi, Giáo sư."],[9451,9634,"Em dám lớn tiếng với tôi, cô Miller."],[9726,9976,"Tôi không để sinh viên ăn nói kiểu đó đâu."],[10035,10151,"Rõ chưa?"],[10744,10869,"Em nghe rõ chưa?"],[10869,10990,"Vâng, thưa Giáo sư."],[11378,11461,"Giờ thì."],[11594,11753,"Em đã biết lỗi chưa?"],[11928,12112,"Hay là muốn nữa?"],[12404,12474,"Em muốn nữa."]],"36":[[1297,1459,"Giáo sư Hayes."],[1722,1910,"Sinh viên của anh à, Charles, thật sao?"],[1951,2135,"Cô ta đủ tuổi làm con gái anh đấy."],[2177,2323,"Bọn trẻ thời nay đúng là lăng loàn."],[2323,2531,"Cấm cô nói thêm câu nào về cô ấy."],[2677,2800,"Tôi tự hỏi chuyện gì sẽ xảy ra nếu"],[2800,2977,"bức ảnh này đến tay Trưởng khoa."],[2994,3161,"Lúc đó anh có mạnh miệng thế không?"],[3161,3286,"Cô không dám đâu."],[3315,3436,"Nếu cô hủy hoại sự nghiệp của tôi,"],[3436,3603,"cô cũng sẽ mất cuộc sống sung sướng đấy."],[3603,3691,"Có thể."],[3749,3920,"Nhưng ít nhất giờ tôi nắm đằng chuôi."],[4091,4233,"Chuyện này sẽ vui lắm đây."],[4483,4633,"Chuyện quái gì vừa xảy ra vậy?"],[4683,4845,"Mình tiêu chắc nếu cô ta báo Trưởng khoa."],[4845,5055,"Sự nghiệp, danh tiếng của anh."],[5055,5150,"Sẽ tiêu tan hết."],[5309,5417,"Nhìn anh này, Emily."],[5484,5572,"Không sao đâu."],[5618,5797,"Anh không quan tâm nếu mất công việc này."],[6439,6589,"Em phải đi đây, Charles."],[6652,6773,"Về nhà chúng ta sẽ nói tiếp."]],"37":[[629,813,"Em không quan tâm dù có mất việc."],[2010,2310,"Jack, tôi cần nói chuyện với mẹ cậu."],[3816,3962,"Tôi đến để nói về-"],[4154,4295,"Cô biết về mối quan hệ của tôi"],[4295,4391,"với Charles rồi chứ?"],[4558,4708,"Cô có từng nghĩ tình cảm mà"],[4708,4863,"Charles dành cho cô,"],[4938,5088,"không đơn giản như vẻ ngoài không?"],[5196,5292,"Ý bà là sao?"],[5405,5672,"Cô là một cô gái trẻ,"],[5709,6031,"xinh đẹp, khỏe mạnh và có học thức."],[6039,6135,"Ờ thì,"],[6231,6360,"Emily à,"],[6360,6564,"cô chỉ là người đẻ thuê cho Charles thôi."],[6794,7119,"Tôi biết nghe rất tàn nhẫn, nhưng đó là sự thật."],[7161,7386,"Charles chọn cô để sinh con cho ông ta"],[7403,7574,"như cách ông ta từng chọn tôi ngày trước."],[7711,7799,"Bà nói dối."],[7953,8033,"Emily."],[8033,8216,"Charles là người từng đoạt giải Nobel."],[8216,8304,"Còn cô?"],[8375,8654,"Ngoài số trứng khỏe và một cái tử cung,"],[8654,8725,"cô có gì chứ?"],[8892,9067,"Sao Charles lại đánh đổi sự nghiệp"],[9067,9192,"chỉ để ngủ với cô?"],[9234,9292,"Không đúng."],[9292,9542,"Vì Charles đã bảo tôi rằng ông ấy-"],[9542,9688,"Đàn ông cái gì cũng dám nói"],[9688,9809,"khi muốn lên giường với cô."],[9989,10101,"Nhưng hành động lúc nào cũng"],[10101,10189,"đáng tin hơn lời nói."],[10189,10364,"Ông ta đã cầu hôn cô chưa?"],[10560,10698,"Ông ta đã công khai quan hệ của hai người"],[10698,10860,"với ai chưa?"],[11457,11524,"Nghe này,"],[11690,11853,"cô là sinh viên của Charles."],[11853,12053,"Chắc cô nhận ra nét chữ của ông ta."],[12095,12312,"Đây là tấm séc ông ta chuẩn bị cho cô"],[12391,12537,"sau khi đứa bé chào đời."],[12892,13104,"Không, không, không thể nào."],[13263,13471,"Tôi đã một mình nuôi lớn Jack."],[13530,13780,"Tôi rất hiểu nỗi khổ của một người mẹ."],[13822,13938,"Cầm lấy tấm séc này đi."],[14068,14326,"Đủ để hai mẹ con cô có thể"],[14326,14476,"sống một cuộc đời sung túc."]],"38":[[1926,2056,"Giáo sư Hayes."],[2143,2473,"Em muốn tin anh, nhưng thật khó."],[3232,3370,"Con không biết nữa, mẹ. Mẹ chắc cách này"],[3370,3445,"sẽ hiệu quả chứ?"],[3461,3574,"Tin mẹ đi."],[3574,3670,"Với những cô gái như cô ta,"],[3670,3845,"con chỉ cần gieo chút hoài nghi là đủ."],[3933,4095,"Mẹ chỉ mới giả chữ ký của Charles,"],[4095,4241,"mà cô ta đã run như cầy sấy rồi."],[4279,4404,"Mẹ, mẹ cao tay thật."],[4429,4596,"Không ai được cướp thứ thuộc về chúng ta."],[7444,7540,"Emily."],[7987,8087,"Emily?"],[8742,8829,"Giáo sư."],[8917,9044,"Em đã rất trăn trở để hiểu được"],[9044,9171,"mối quan hệ của chúng ta."],[9196,9496,"Em chỉ cần thời gian để thông suốt mọi chuyện."],[9551,9743,"Nên em sẽ sang ở nhà Mia vài ngày."],[9822,9964,"Đây không phải là em đang bỏ cuộc."],[10010,10160,"Em chỉ cần được tĩnh tâm lại."],[10243,10397,"Cảm ơn anh đã thấu hiểu."],[10452,10593,"Yêu anh, Emmy của anh."]],"39":[[446,550,"Giáo sư Hayes."],[550,684,"Trời ơi!"],[684,796,"Cậu mang thai"],[796,1001,"con của Giáo sư Hayes sao?"],[1088,1176,"Tớ cũng đâu có biết."],[1176,1259,"Được chưa?"],[1459,1659,"Chuyện này điên rồ quá, Emmy."],[1693,1805,"Tình cũ của anh ấy đã quay về,"],[1805,1943,"và tớ không muốn đối mặt với anh ấy."],[2010,2156,"Nên tớ mới tới đây."],[2293,2560,"Cô ta đúng là một con khốn."],[2736,2940,"Tớ mệt mỏi quá, Mia."],[3132,3311,"Mai tớ có một buổi hội thảo,"],[3386,3545,"và tớ mong là mình sẽ dậy kịp."],[7407,7511,"Hội thảo à?"],[8179,8345,"Chào cô, vâng, tôi là Charles Hayes."],[8345,8483,"Tôi vẫn sẽ tham dự buổi hội thảo"],[8483,8608,"vào cuối tuần này."],[8800,8925,"Vâng, diễn giả chính."],[9084,9196,"Không có gì."]],"40":[[1017,1259,"Chào mừng đến với Hội thảo Nghiên cứu Não bộ,"],[1259,1463,"nơi chúng ta khám phá những tiến bộ"],[1463,1655,"trong lĩnh vực khoa học thần kinh."],[1697,1981,"Tối nay là dịp để trao đổi ý tưởng"],[1981,2227,"và tìm kiếm cảm hứng."],[2752,2882,"Phiền cô dọn chỗ này,"],[2882,2957,"cảm ơn."],[2957,3069,"À, thật ra tôi không phải"],[3169,3370,"Sao cô ta lại ăn mặc kiểu đó?"],[3370,3482,"Đây là sự kiện trang trọng mà."],[3482,3549,"Đáng ra cô ta phải"],[3549,3649,"đại diện cho trường chứ."],[3695,3883,"Ý tôi là, nếu không có tiền mua váy,"],[3883,4020,"thì cũng có thể mượn mà."],[4049,4162,"Thật đáng xấu hổ."],[4162,4241,"Đúng vậy."],[4421,4496,"Ông Williams-"],[4496,4667,"Xin lỗi, hiện tại tôi không cần gì đâu."],[4742,4921,"Phiền cô tránh ra. - Tôi, tôi không,"],[4975,5063,"tôi không phải phục vụ."],[5063,5163,"Thật ra tôi là"],[5163,5309,"nghiên cứu sinh ngành khoa học thần kinh,"],[5309,5447,"và tôi chỉ xin ba phút"],[5447,5513,"của ông thôi."],[5555,5680,"Ăn mặc kiểu đó thì không đâu."],[5743,5818,"Emily."],[5972,6064,"Charles!"],[6064,6231,"Thật bất ngờ."],[6339,6481,"Trời ơi."],[6523,6690,"Đó là Giáo sư Charles Hayes,"],[6690,6856,"người từng đoạt giải Nobel."],[6898,7065,"Sao người như ông ấy lại đi"],[7065,7211,"nói chuyện với một cô phục vụ chứ?"],[7278,7382,"Ông có bao giờ dự mấy sự kiện này đâu."],[7382,7486,"Cơn gió nào đưa ông tới đây đêm nay vậy?"],[7549,7682,"Tôi đến đây để gặp sinh viên của mình,"],[7757,7832,"Emily."]],"41":[[20,175,"Emily Miller là sinh viên của tôi."],[175,316,"Và là một trong những người dẫn dắt tương lai"],[316,437,"cho công trình của chúng ta"],[483,642,"về khoa học thần kinh nhận thức."],[763,959,"Cô ấy là sinh viên của Giáo sư Hayes sao?"],[1001,1130,"Tôi còn tưởng cô ấy là phục vụ."],[1172,1376,"Phải xuất sắc lắm mới vào được phòng thí nghiệm của ông ấy."],[1376,1522,"Cô ấy hẳn phải rất đặc biệt."],[1589,1747,"Chà, thật xấu hổ quá."],[1789,1885,"Ông chưa từng nhắc đến việc"],[1885,2093,"mình có nghiên cứu sinh mới đấy, Charles."],[2189,2281,"Cô Miller,"],[2344,2452,"tôi có thể giúp gì cho cô không?"],[2481,2640,"À, thật ra thì-"],[2640,2902,"Tôi không nghĩ ông có thể cho cô ấy điều gì mà tôi không thể."],[2940,3069,"Trừ phi ông"],[3069,3178,"không đồng ý."],[3178,3478,"Không, không đâu, tôi hoàn toàn đồng ý."],[3516,3595,"Thưa Giáo sư,"],[3595,3837,"thật vinh hạnh khi được gặp một"],[3837,3978,"nhà khoa học trẻ sáng giá như vậy."],[4141,4287,"Giờ thì, nếu ông không phiền,"],[4287,4404,"tôi muốn đưa Emily đi tham quan quanh đây."],[4404,4533,"Tất nhiên rồi."],[4854,4954,"Sao thầy lại tới đây?"],[4988,5113,"Vì em đã chạy trốn khỏi tôi,"],[5113,5305,"ngay cả khi tôi đã bảo em đừng làm vậy."],[5305,5438,"Thưa Giáo sư, chúng ta đang ở nơi đông người."]],"42":[[37,141,"Thưa Giáo sư, chúng ta đang ở nơi đông người."],[141,350,"Em nghi ngờ uy tín của tôi trong ngành sao?"],[350,504,"Ơ. Gì cơ? Không, em"],[504,633,"Vậy sao em lại tham gia"],[633,729,"buổi hội thảo này mà không báo cho tôi?"],[729,804,"Bởi vì,"],[975,1067,"bởi vì,"],[1101,1263,"em muốn chứng minh rằng mình có thể"],[1263,1393,"tự mình làm được điều gì đó."],[1422,1518,"Em không muốn mọi người nghĩ"],[1518,1630,"rằng thầy cho em vị trí này"],[1630,1772,"chỉ vì đứa con của chúng ta."],[1772,1818,"Nếu,"],[2031,2185,"nếu chúng ta đến với nhau."],[2402,2623,"Sẽ chẳng ai coi trọng công sức của em."],[2677,2798,"Hiểu rồi."],[2798,3032,"Phải tìm cho em ấy một cố vấn."],[3032,3315,"Một người tài giỏi và đáng tin cậy."],[3495,3699,"Được rồi, quên Tiến sĩ Williams đi."],[3699,3787,"Tôi sẽ giới thiệu cho em"],[3787,3870,"một người rất giỏi."],[4283,4391,"Đây là Peter,"],[4391,4475,"giám đốc phòng thí nghiệm"],[4475,4637,"điện toán quy mô lớn của New York."]],"43":[[154,283,"Bệnh nhân mắc một"],[283,513,"chứng rối loạn thần kinh chưa xác định."],[513,600,"Thường là do"],[725,959,"nguyên nhân gần đây"],[1393,1468,"Ông là ai?"],[1580,1739,"Nghiên cứu của cô là về thần kinh học"],[1739,1876,"điện toán, phải không?"],[2052,2152,"Vâng."],[2460,2581,"Tôi tên là"],[2581,2736,"Peter Smith."],[2765,2998,"Tôi là giám đốc phòng thí nghiệm điện toán."],[3265,3374,"Dạ không, cảm ơn"],[3374,3482,"Giáo sư Smith."],[3499,3620,"Tôi phải đến lớp rồi."],[3620,3749,"Cô ngốc thật đấy."],[3795,3987,"Đây là cơ hội cả đời có một đấy."],[4191,4333,"Cô mặc chiếc váy khoét sâu này"],[4333,4487,"để quyến rũ tôi, đúng không?"],[4512,4617,"Vậy,"],[4633,4713,"sao tự dưng"],[4713,4800,"lại làm giá thế?"],[5776,5893,"Cô mặc chiếc váy khoét sâu này"],[5893,6010,"để quyến rũ tôi, đúng không?"],[6064,6131,"Vậy,"],[6189,6268,"sao tự dưng"],[6268,6356,"lại làm giá thế?"]],"44":[[12,108,"Đây là Peter."],[538,650,"Emily, Emily!"],[1121,1226,"Xin lỗi cậu nhé."],[1259,1368,"Để tôi đi xem cô ấy thế nào."],[1789,1901,"Không ngờ cô gái này"],[1901,2010,"lại là học trò của Charles."],[2093,2210,"Thú vị đấy."],[2740,2948,"Cô mặc chiếc váy khoét sâu này để quyến rũ tôi,"],[2948,3015,"đúng không?"],[3065,3123,"Vậy,"],[3182,3324,"sao tự dưng lại làm giá thế?"],[3507,3632,"Emily, em không sao chứ?"],[4004,4187,"Vâng, em chỉ thấy hơi buồn nôn thôi."],[4371,4529,"Em xin lỗi vì đã làm thầy bẽ mặt,"],[4575,4667,"thưa Giáo sư."],[4667,4733,"Không sao đâu."],[4733,4888,"Peter là bạn tốt của tôi."],[5150,5347,"Thầy và Peter thực sự là bạn thân sao?"],[5447,5538,"Ừ, chúng tôi là bạn"],[5538,5613,"từ thời đại học."],[5722,5809,"Ra là vậy."],[5939,5985,"À."],[6006,6110,"Em thấy không khỏe."],[6143,6356,"Charles, chắc em nên về nhà."],[6356,6456,"Em ổn chứ?"],[6539,6673,"Hay để tôi đưa em đến bệnh viện?"],[6719,6840,"Không ạ, chỉ là buồn nôn thôi."],[6840,6940,"Em muốn về nhà."],[7123,7248,"Được rồi, tôi sẽ đưa em về."],[7361,7515,"Em để hết đồ ở nhà Mia rồi."],[7741,7887,"Tôi sẽ đưa em đến đó."]],"45":[[212,350,"Charles Hayes,"],[383,608,"vợ cũ anh nói em chỉ là người đẻ thuê."],[667,775,"Ngoài"],[800,930,"tử cung và trứng khỏe mạnh,"],[955,1021,"cô còn có gì chứ?"],[1138,1263,"Bạn thân của anh,"],[1263,1434,"cũng coi em như đồ bỏ đi."],[1555,1718,"Có lẽ họ nói đúng."],[1718,1856,"Người như em sẽ chẳng bao giờ"],[1856,1997,"đủ xứng với anh."],[2786,3019,"Tớ lại đụng mặt tên khốn Peter đó,"],[3019,3244,"mà lão lại là bạn thân của Charles."],[3244,3432,"Tớ phải làm sao đây, Mia?"],[4696,4796,"Có chuyện gì vậy?"],[5067,5167,"Trông em cứ bồn chồn từ khi"],[5167,5280,"Peter xuất hiện."],[5534,5718,"Em có nên nói sự thật không?"],[6035,6131,"Em chỉ hơi mệt thôi."],[6302,6460,"Đây là lần đầu tiên em tham dự,"],[6519,6706,"một sự kiện như vậy."],[6986,7090,"Tôi nghĩ em đang nói dối."],[7207,7361,"Sao em có thể kể chuyện đã xảy ra"],[7361,7449,"với bạn thân của anh,"],[7449,7536,"trong khi em đã khiến anh"],[7536,7682,"quay lưng với con trai mình chứ?"],[7878,8062,"Em đang giấu tôi chuyện gì vậy, Emily?"]],"46":[[417,500,"Vậy ra,"],[629,779,"hồi đó cô từ chối tôi là vì"],[779,955,"cô đang qua lại với Charles đúng không?"],[1217,1297,"Ý ông là sao?"],[1355,1455,"Ý tôi là sao à?"],[1609,1739,"Chính Charles đã"],[1739,1901,"nhờ tôi giúp cô."],[1956,2056,"Cậu ta"],[2085,2198,"chưa từng ưu ái"],[2198,2323,"sinh viên nào đến thế."],[2360,2473,"Tôi không hiểu ông đang nói gì,"],[2473,2577,"Giáo sư Smith."],[2644,2802,"Nhưng gu của cô cũng tốt đấy."],[2873,3107,"Charles là nhà khoa học hàng đầu."],[3153,3303,"Gu của cậu ta cũng không tồi."],[3482,3586,"Cô tăng cân à?"],[3724,3841,"Giờ trông cô đẫy đà hơn."],[3920,4008,"Còn quyến rũ hơn"],[4008,4145,"hồi đại học nữa."],[4145,4245,"Đủ rồi đấy."],[4308,4437,"Ông không phải bạn thân của Charles sao?"],[4437,4550,"Tôi là học trò của ông ấy."],[4571,4708,"Gọi thẳng tên luôn cơ à?"],[4796,4871,"Nghe này,"],[4917,5075,"tôi biết Charles"],[5075,5230,"còn lâu hơn số tuổi của cô."],[5301,5397,"Tin tôi đi."],[5488,5588,"Năm sau,"],[5651,5793,"cậu ta sẽ có người khác như cô thôi."],[5930,6018,"Một kẻ qua đường."],[6135,6227,"Dễ dàng thay thế."],[6356,6519,"Ông ta nói thật chứ?"],[6560,6681,"Được rồi. Đừng làm giá nữa,"],[6681,6773,"con đĩ này!"],[6798,6886,"Tôi muốn cô ngay bây giờ."],[6886,7032,"Không, đừng"],[7778,8016,"Trời ơi, cuối cùng cậu cũng nghe máy."],[8016,8183,"Tớ đã suy nghĩ rất nhiều,"],[8183,8345,"và cậu cần phải nói với Charles."],[8345,8500,"Hoặc trực tiếp tố cáo ông ta."],[8500,8737,"Emily, đừng ngốc thế."],[8737,8879,"Tớ hiểu vì sao cậu không công khai chuyện"],[8879,8950,"với Peter."],[8950,9075,"Vì ông ta đã biến khỏi đời cậu"],[9075,9196,"và cậu nghĩ ông ta sẽ không quay lại."],[9196,9346,"Nhưng giờ ông ta đã về,"],[9346,9463,"và sẽ không đi đâu cả."],[9463,9642,"Tên cặn bã đó sẽ ám ảnh cậu"],[9642,9751,"trừ khi cậu đứng lên chống lại ông ta."],[9751,9838,"Khoan, gì cơ?"],[9897,9989,"Đã có chuyện gì với Emily?"],[9989,10139,"Chuyện về Peter là thế nào?"],[10181,10322,"Giáo sư Hayes ạ?"],[10598,10839,"Năm ngoái, Peter đã gạ gẫm Emily,"],[10839,10969,"và ông ta đã cố ép cô ấy"],[10969,11073,"làm trò đồi bại với ông ta."]],"47":[[154,271,"Con ranh ngu ngốc!"],[371,479,"Cô mặc chiếc váy khoét sâu này"],[479,563,"để quyến rũ tôi,"],[563,642,"phải không?"],[767,855,"Chết tiệt!"],[1213,1372,"Cứ hét thoải mái đi cưng!"],[1397,1547,"Không ai nghe thấy cô đâu."],[1547,1643,"Và cũng chẳng ai tin"],[1643,1747,"một kẻ vô danh như cô."],[1985,2077,"Dừng lại đi!"],[2143,2235,"Thả tôi ra!"],[2323,2414,"Buông tôi ra!"],[2489,2581,"Charles,"],[2644,2740,"Mong cậu không để bụng,"],[2740,2827,"tôi đã nẫng tay trên."],[2861,2982,"Đợi tôi xong thì đến lượt cậu."],[3140,3203,"Ôi trời."],[3203,3365,"Tôi đã thèm khát cô ta"],[3365,3449,"nhiều năm rồi."]],"48":[[204,300,"Tôi đến rồi đây."],[688,850,"Tao sẽ giết mày, đồ kh*n này!"],[850,934,"Mày xong đời rồi."],[1163,1313,"Cô ta, cô ta quyến"],[1313,1401,"cô ta quyến rũ tôi."],[1401,1601,"Đây là đoạn ghi âm Giáo sư Smith"],[1601,1755,"quấy rối Emily."],[1768,1830,"Hả?"],[1872,1972,"Peter Smith."],[1972,2177,"Tôi là trưởng phòng thí nghiệm điện toán."],[2273,2369,"Con ranh ngu ngốc."],[2485,2602,"Cô mặc chiếc váy khoét sâu này"],[2602,2736,"để quyến rũ tôi, đúng không?"],[2773,2894,"Không, không, không."],[2894,3136,"Cái đó... rõ ràng là giả."],[3215,3357,"Đó là AI."],[3432,3536,"Tất cả là AI."],[3703,3774,"Charles,"],[3858,4024,"sau những gì chúng ta đã trải qua sao."],[4191,4270,"Còn mày,"],[4362,4458,"con kh*n này!"],[4504,4600,"Mày đã chờ ngày này,"],[4600,4688,"có đúng không?"],[4763,4833,"Cầm lấy."],[5100,5242,"Đừng có hòng chạm vào."],[5242,5401,"Mày nói thêm một câu nữa xem."],[5401,5563,"Cảnh sát sẽ không nhận ra xác mày đâu."],[5630,5768,"Tao sẽ không bỏ qua chuyện này đâu."]],"49":[[546,629,"Em xin lỗi."],[771,867,"Dạo này anh nghe em nói câu đó"],[867,1005,"nhiều lắm rồi."],[1088,1242,"Em có gì phải xin lỗi chứ?"],[1393,1547,"Đáng ra em không nên giấu anh."],[1668,1747,"Em chỉ là,"],[1797,1947,"em sợ lắm."],[1981,2085,"Sợ gì chứ?"],[2206,2348,"Sợ anh sẽ bảo em bỏ qua chuyện này sao?"],[2435,2577,"Sợ anh sẽ đứng về phía Peter à?"],[2577,2781,"Anh và Peter làm bạn nhiều năm rồi."],[2827,2977,"Còn... còn em"],[3007,3148,"Sao? Nên em giấu anh ư?"],[3228,3411,"Và đem mạng sống của em và con ra đánh cược?"],[3411,3520,"Thay vì tin tưởng anh,"],[3520,3716,"như anh đã nhắc đi nhắc lại với em."],[3795,3866,"Em vẫn ổn,"],[3916,3999,"mà đúng không?"],[4120,4191,"Ổn ư."],[4304,4466,"Nếu Mia không gọi cho anh,"],[4496,4633,"nếu anh không ở trường,"],[4633,4738,"thì chuyện gì sẽ xảy ra?"],[4808,4879,"Em có từng nghĩ đến"],[4879,4984,"hậu quả chưa?"],[5050,5221,"Emily, em đang mang thai con của anh."],[5251,5342,"Nhưng hơn thế nữa,"],[5384,5463,"anh yêu em."],[5497,5605,"Anh phải làm gì đây?"],[5768,5851,"Anh phải làm gì"],[5851,5943,"để em chịu tin anh đây?"]],"50":[[108,212,"Em xin lỗi, Charles."],[212,487,"Chỉ là từ tờ séc đến chuyện của Peter."],[533,700,"Mọi người đều bảo em rằng chúng ta không nên"],[700,813,"ở bên nhau, và em-"],[813,942,"Khoan đã. Tờ séc ư? Séc gì?"],[1026,1272,"Hôm đó ở... ở văn phòng."],[1351,1459,"Ruby đưa em một tờ séc."],[1459,1576,"Và cô ta nói em chẳng qua chỉ là"],[1576,1726,"người đẻ thuê."],[1726,1939,"Trên đó có chữ ký của anh."],[2018,2093,"Anh xem đi."],[2093,2185,"Lại đây."],[2331,2444,"Nhìn xem."],[2531,2706,"Khoảng cách giữa chữ A và chữ R này."],[2706,2827,"Nét chữ bị run."],[3023,3161,"Ai đó đã làm giả chữ ký này."],[3361,3436,"Ra là vậy."],[3616,3703,"Đương nhiên rồi."],[3991,4099,"Với lại anh sẽ không xúc phạm em"],[4099,4233,"bằng một triệu đô la đâu."],[4308,4454,"Anh sẽ thêm một số không nữa."],[4642,4713,"Sao em biết được"],[4713,4934,"anh đang nói thật, Charles?"],[5075,5188,"Em không thể biết được."],[5647,5797,"Và anh nhận lỗi về chuyện đó."],[5797,6026,"Lỗi do anh nên em mới không tin anh."],[6026,6235,"Nhưng Emily à, em là người anh yêu."],[6477,6614,"Một kẻ vô danh, bỏ học,"],[6652,6760,"lại mang thai con của"],[6760,6940,"giáo sư hướng dẫn ư?"],[7002,7140,"Em là mẹ của con anh."],[7182,7311,"Và là người phụ nữ anh yêu."],[7457,7557,"Dù có chuyện gì xảy ra,"],[7557,7778,"dù ai cố tình chia rẽ chúng ta."],[7907,8058,"Anh sẽ luôn chọn em."]],"51":[[671,779,"Cút đi!"],[859,1009,"Để tôi đoán nhé. Chỗ làm không suôn sẻ à?"],[1009,1251,"Hay là gặp đồng nghiệp đáng ghét?"],[1480,1564,"Ừ."],[1614,1830,"Bạn thân đã hủy hoại đời tôi"],[1885,1997,"vì một con khốn."],[2202,2348,"Tôi sẽ không để hắn yên đâu."],[2389,2573,"Vậy chúng ta nên hợp tác,"],[2573,2752,"vì con khốn đó"],[2752,2890,"cũng hủy hoại đời tôi."],[3148,3219,"Cạn ly."],[3286,3411,"Cùng xử đẹp bọn chúng nhé."],[4808,4909,"Sao thế em?"],[5055,5121,"Em chỉ"],[5251,5401,"có dự cảm không lành."],[5718,5839,"Đừng nghĩ nhiều quá,"],[5976,6031,"Charles,"],[6031,6239,"trực giác của phụ nữ không sai đâu."],[6498,6577,"Được rồi,"],[6623,6773,"vậy có chuyện gì nhớ kể anh nghe nhé."],[6902,7011,"Điều anh sợ nhất"],[7111,7257,"là em đẩy anh ra xa."],[7353,7469,"Chỉ cần có anh ở bên,"],[7469,7611,"em chẳng sợ gì cả."]],"52":[[79,287,"Hợp đồng của cậu vẫn chưa hết hạn."],[287,437,"Nghỉ sớm tức là cậu sẽ"],[437,517,"bị phạt đấy."],[646,713,"Tôi biết ạ."],[884,967,"Charles,"],[1059,1226,"cậu từng đoạt giải Nobel."],[1292,1422,"Cậu còn trẻ,"],[1422,1622,"tương lai vô cùng xán lạn."],[1622,1747,"Cậu có thể tạo ra bước ngoặt"],[1747,1830,"trong ngành thần kinh học,"],[1889,2031,"điều mà chưa ai làm được."],[2114,2227,"Sao lại từ chức?"],[2435,2585,"Do chuyện cá nhân thôi ạ."],[2660,2811,"Chỗ khác mời cậu phải không?"],[2877,2944,"Họ đưa điều kiện gì?"],[2990,3119,"Chúng tôi sẽ đáp ứng mức đó."],[4029,4187,"Xin lỗi cô, chỉ là chuyện cá nhân ạ."],[4200,4291,"Được rồi,"],[4371,4500,"nhưng sinh viên của cậu"],[4500,4625,"sắp có kỳ thi đánh giá"],[4625,4746,"trong thời gian tới."],[4796,4959,"Cậu phải phụ trách xong việc đó."],[4959,5138,"Tất nhiên rồi, tôi sẽ không bỏ mặc họ."],[5205,5309,"Xin cô giúp tôi một việc,"],[5388,5518,"hãy giữ kín chuyện này"],[5555,5634,"cho đến khi tôi đi."],[5718,5851,"Tôi không rõ đang có chuyện gì,"],[5922,6014,"nhưng Charles,"],[6014,6193,"bất cứ khi nào cậu muốn quay lại,"],[6193,6339,"chỗ tôi luôn chào đón."],[7061,7132,"Em yêu,"],[7165,7336,"tương lai của chúng ta bắt đầu từ đây."]],"53":[[1422,1676,"Cảm ơn anh nhiều lắm, Charles."],[2047,2127,"Vậy,"],[2127,2273,"khi nào em định tạm nghỉ"],[2273,2360,"việc học?"],[2444,2598,"Sau kỳ thi sàng lọc ạ."],[2794,2957,"Thi đậu xong,"],[2957,3174,"em có thể yên tâm sinh con."],[3457,3528,"Em còn chẳng biết"],[3528,3641,"mình có đậu không nữa."],[3753,3933,"Nghe nói kỳ thi đó khó lắm và"],[4145,4295,"dạo này em hay mất tập trung."],[4396,4508,"Rồi em sẽ đậu thôi."],[4604,4800,"Em có vị giáo sư nổi tiếng nhất"],[4800,4892,"ngành khoa học thần kinh"],[4892,5042,"làm gia sư riêng cơ mà."],[5301,5451,"Nghe anh nói này."]],"54":[[1330,1468,"Tôi làm em chán sao, cô Miller?"],[1576,1705,"Dạ không,"],[1705,1856,"nhưng bài giảng thì có."],[1947,2131,"Em không biết mình có hợp với việc này không, Giáo sư ạ."],[2131,2273,"Em không thể tập trung được."],[2623,2686,"Đứng dậy đi."],[2773,2844,"Sao cơ?"],[3011,3090,"Em sẽ làm cho"],[3090,3190,"hình phạt của mình nặng hơn đấy."],[3253,3349,"Lại đây."],[3553,3712,"Đừng để tôi phải nhắc lại lần nữa."],[4191,4295,"Anh định-"],[4909,5017,"Tôi sẽ đọc tên"],[5017,5155,"một phân tử tín hiệu."],[5230,5380,"Và em phải nói cho tôi chức năng của nó."],[5530,5643,"Nếu em trả lời sai"],[6393,6439,"Chết tiệt."]],"55":[[150,279,"Insulin, cô Miller."],[487,579,"Glucose."],[650,750,"Glucose, làm sao?"],[817,1009,"Tôi tưởng em là học trò cưng của tôi chứ."],[1222,1463,"Em không, em không tập trung được, Giáo sư."],[1559,1747,"Hấp thụ glucose vào cơ ạ?"],[1793,1914,"Theo kịp đi, cô Miller."],[1914,2193,"Sẽ rất, rất đau đấy."],[2644,2752,"Epinephrine."],[2873,3078,"Ở, ở tim ạ."],[3136,3224,"Chỗ nào ở tim?"],[3407,3666,"Thụ thể Adrenergic, chết tiệt!"],[3666,3778,"Giáo sư Hayes, đừng dừng lại."],[3870,3953,"Em là học trò của tôi,"],[3953,4091,"đừng có ra lệnh cho tôi."],[4141,4245,"Câu đó đúng."],[4333,4471,"Em có phần thưởng."],[4583,4767,"Muốn tôi dừng lại à? - Không."],[4767,4992,"Ý em là, em muốn"],[4992,5130,"Em muốn thầy tiếp tục."],[5526,5730,"Tôi còn phải dạy em nhiều lắm."],[7874,7970,"Cảm ơn thầy,"],[8045,8183,"đã kèm cặp em."],[9984,10143,"Nếu em hồi hộp, để anh xem cho."],[10143,10272,"Ai nói em hồi hộp chứ?"],[10460,10581,"Em tự xem được, chỉ là"],[11094,11257,"Chà, 30 phút rồi đấy."],[11711,11836,"Này, Emmy."],[12028,12103,"Em đậu rồi!"],[12103,12208,"Trời ơi, em đậu rồi."],[12283,12424,"Em đậu rồi, em đậu rồi!"],[12462,12566,"Ôi, Charles!"]],"56":[[29,204,"Ôi, Charles!"],[504,617,"Nhìn xem này."],[650,921,"Giáo sư Hayes đang ôm ấp sinh viên."],[950,1084,"Thảo nào anh lại tố cáo tôi."],[1109,1251,"Chỉ là anh không muốn dùng chung thôi!"],[1292,1426,"Charles Hayes,"],[1426,1593,"chúng tôi đã nhận được báo cáo,"],[1593,1768,"rằng anh có quan hệ không đúng mực"],[1768,1989,"với một sinh viên."],[2173,2252,"Đúng vậy."],[2318,2402,"Không phải đâu."],[2444,2590,"Tôi và Emily không chỉ là"],[2590,2706,"giáo sư và sinh viên."],[2706,2869,"Không, là, là lỗi của em."],[2869,3032,"Em đã xin thầy ấy kèm cặp và"],[3032,3161,"Emily, đủ rồi."],[3265,3345,"Nhưng không có gì sai trái"],[3345,3449,"trong mối quan hệ của chúng tôi,"],[3486,3566,"bởi vì,"],[3611,3737,"tôi đã từ chức một tháng trước."]],"57":[[33,179,"Tôi đã từ chức một tháng trước."],[179,271,"Sao cơ?"],[321,408,"Từ chức sao?"],[529,600,"Cái gì?"],[629,754,"Tôi đã nộp đơn từ chức"],[754,842,"hơn một tháng trước."],[905,1092,"Và tôi chỉ đang hoàn tất nốt công việc."],[1092,1205,"Hôm nay là ngày cuối của tôi."],[1247,1430,"Đúng vậy. Giáo sư Hayes"],[1430,1618,"đã nộp đơn từ chức,"],[1618,1755,"và tôi đã phê duyệt."],[1839,1910,"Không thể nào."],[2039,2160,"Chuyện này không thể là thật."],[2160,2360,"Hôm nay tôi sẽ rời trường hẳn."],[2427,2527,"Còn việc gì khác không?"],[2527,2573,"Không."],[2573,2652,"Không thể nào."],[2652,2802,"Thầy ấy không thể từ bỏ tất cả"],[2802,2894,"chỉ vì một cô gái."],[2965,3153,"Xin lỗi vì đã cắt ngang."],[3153,3261,"Giờ chúng tôi xin phép."],[4054,4204,"Vậy là thầy đã lên kế hoạch từ trước?"],[4304,4500,"Đây là cách thầy bảo vệ em sao."],[4600,4721,"Emily, đó là cách duy nhất"],[4721,4838,"tôi có thể giữ an toàn cho em."],[4900,4946,"Không."],[5080,5134,"Em không muốn thầy"],[5134,5280,"từ bỏ sự nghiệp vì em."],[5280,5338,"Chúng ta nên,"],[5338,5447,"chúng ta nên đến gặp trưởng khoa ngay,"],[5447,5551,"và em sẽ nói sự thật."],[5551,5730,"Em sẽ nói chính em đã quyến rũ thầy,"],[5730,5768,"Emily,"],[5768,5876,"và Giáo sư,"],[5876,6068,"Emily Miller, làm ơn nghe tôi."],[6168,6348,"Nếu em vẫn coi tôi là người hướng dẫn,"],[6406,6548,"thì hãy nghe những gì tôi nói."],[6652,6848,"Hãy tập trung vào việc học"],[6848,7040,"và trở thành nhà khoa học tài ba"],[7040,7152,"như em được định sẵn."],[7244,7386,"Em có quá nhiều tài năng"],[7386,7507,"và vô vàn tiềm năng."],[7766,7962,"Em sẽ làm nên những điều vĩ đại."],[8158,8291,"Hứa với tôi đi, Emily,"],[8479,8641,"đừng lãng phí tài năng của mình."]],"58":[[479,563,"Thưa bà,"],[563,658,"Anh đang làm gì thế này?"],[688,829,"Cô ta có đáng không?"],[988,1134,"Em ấy hoàn toàn xứng đáng."],[2060,2235,"Tôi còn một thỉnh cầu nữa."],[2235,2464,"Lại chuyện về cô gái đó sao?"],[2498,2644,"Tôi không muốn việc mình từ chức"],[2644,2798,"ảnh hưởng đến tương lai của Emily."],[2894,2994,"Em ấy có thai rồi."],[3036,3132,"Có thai sao?"],[3174,3345,"Vâng, em ấy đang mang thai."],[3378,3557,"Và vì tôi đã từ chức,"],[3557,3712,"giờ tôi có thời gian chăm sóc em ấy."],[3728,3862,"Tôi muốn kết quả học tập của em ấy"],[3862,3962,"được bảo lưu."],[3962,4083,"Để khi nào sẵn sàng,"],[4083,4241,"em ấy có thể quay lại học tiếp."],[4329,4421,"Xin bà."],[4550,4625,"Được rồi."],[4692,4825,"Tôi sẽ lo việc này."],[5784,5905,"Emmy, đây là việc cuối cùng"],[5905,6022,"tôi có thể làm cho em ở đây."]],"59":[[1872,2027,"Anh xin lỗi vì đã giấu em."],[2469,2590,"Nhưng điều quan trọng nhất"],[2590,2765,"lúc này là sức khỏe của em,"],[2765,2886,"và của con chúng ta."],[3011,3144,"Anh muốn ở bên cạnh em,"],[3261,3370,"trên mỗi chặng đường."],[3553,3699,"Khi em sinh con,"],[3770,3895,"và khi chúng ta chào đón con"],[3895,4008,"đến với thế giới này."],[4542,4700,"Anh muốn em làm vợ anh."],[4917,5096,"Anh không muốn em mãi là bí mật của anh."],[5246,5547,"Anh từ bỏ một thứ để đổi lấy mọi thứ, Emily à."],[5668,5764,"Để có được em."],[5897,5997,"Em không bận tâm."],[6097,6306,"Em chẳng màng việc làm người tình trong bóng tối."],[6306,6360,"Em chỉ"],[6594,6790,"Em không muốn anh phải từ chức!"],[6881,7002,"Đừng lo chuyện đó."],[7107,7344,"Cứ coi như anh đang tạm nghỉ ngơi đi."],[7799,7895,"Nhưng"],[8304,8600,"đừng quyết định những chuyện thế này"],[8600,8804,"sau lưng em nữa,"],[9171,9300,"nếu em sẽ làm vợ anh."],[9597,9751,"Không còn bí mật nào nữa."]],"60":[[513,596,"Charles,"],[667,771,"anh thật sự"],[771,930,"tự đi chợ và nấu ăn sao?"],[959,1092,"Emily hủy hoại anh rồi."],[1176,1380,"Người đoạt giải Nobel mà phải làm việc nhà."],[1422,1559,"Đây là điều cô muốn mà, đúng không?"],[1614,1726,"Không, Charles, em chỉ"],[1793,1881,"em chỉ muốn anh quay lại-"],[1881,2077,"Đừng bao giờ mở miệng với tôi nữa."],[2097,2260,"Kể từ lúc cô định xúi giục Emily"],[2260,2398,"chống lại tôi, cô và Jack"],[2398,2527,"đã coi như chết đối với tôi rồi."],[2852,2961,"Không, không."],[2961,3128,"Làm giả là phạm pháp đấy, Ruby."],[3128,3307,"Thưa cô, mời đi theo chúng tôi."],[3307,3420,"Ôi, không."],[3453,3666,"Charles, xin anh đừng bỏ mặc em."],[3666,3787,"Xin anh, em xin lỗi!"],[3787,3958,"Charles! Bọn em là gia đình của anh mà!"],[5359,5476,"Em tưởng mình vừa thấy Ruby."],[5613,5697,"Ừ."],[5697,5797,"Cô ta tìm đến anh,"],[5897,6010,"nhưng anh xử lý xong rồi."],[6131,6168,"Cô ta-"],[6168,6360,"Cô ta sẽ phải rũ tù."],[6723,6819,"Này, đừng lo."],[6865,7023,"Sẽ không còn ai làm hại em nữa đâu."]],"61":[[20,187,"Chúc mừng các em."],[187,446,"Các em đã vượt qua kỳ thi sàng lọc."],[446,563,"Bắt đầu từ hôm nay,"],[592,913,"các em chính thức bước vào"],[913,992,"hành trình học tiến sĩ."],[1251,1468,"Xin mời Emily Miller,"],[1468,1764,"đại diện cho các nghiên cứu sinh"],[1764,1926,"lên phát biểu."],[2694,2886,"Tôi rất tự hào khi được đại diện"],[3807,3937,"Emily."],[3937,3999,"Emily."],[4212,4283,"Sắp sinh rồi."],[4358,4558,"Bác sĩ? Chúng tôi cần bác sĩ!"]],"62":[[487,679,"Anh chưa từng nghĩ một sinh linh bé nhỏ"],[679,892,"lại làm anh thấy sợ hãi,"],[934,1105,"mà cũng hạnh phúc đến vậy."],[1822,1910,"Emmy,"],[2010,2143,"chúng ta đã cùng nhau trải qua bao chuyện,"],[2273,2435,"nhưng vẫn còn thiếu một điều."],[3148,3274,"Anh yêu em, Emily."],[3470,3603,"Mình từng cãi vã"],[3670,3816,"và hoài nghi."],[4020,4158,"Nhưng khi anh nhìn con,"],[4308,4412,"rồi nhìn em."],[4675,4900,"Anh mới nhận ra đây là tất cả."],[5042,5276,"Hai mẹ con là cả thế giới của anh."],[5509,5643,"Hãy để anh làm chồng em."],[5730,5880,"Để anh làm cha của con."],[6018,6147,"Anh muốn bảo vệ em."],[6256,6406,"Muốn chăm sóc em."],[6452,6606,"Và muốn luôn ở bên em."],[6715,6915,"Từ lúc bình minh tới khi chiều tà."],[7265,7361,"Emily,"],[7590,7707,"làm vợ anh nhé?"],[7878,7962,"Vâng!"],[8153,8295,"Em đồng ý, Charles."]],"63":[[688,863,"Bố ơi, đây có phải nơi bố gặp mẹ không?"],[984,1092,"Không hẳn đâu, Ellen."],[1092,1234,"Thực ra bố mẹ gặp-"],[1426,1618,"Hẹn gặp các em tuần sau."],[1643,1793,"Chúc cuối tuần vui vẻ."],[2131,2289,"Mẹ ơi."],[2715,2948,"Chúc mừng em, Giáo sư Miller."],[3048,3199,"Phó giáo sư thôi."],[3219,3349,"Em vẫn còn một chặng đường dài."],[3349,3490,"Chỉ là vấn đề thời gian thôi."],[3661,3812,"Cảm ơn anh, Charles,"],[3812,3916,"nếu không có anh-"],[3916,4066,"Không, Emily, em chẳng cần phải"],[4066,4195,"cảm ơn ai ngoài chính em cả."],[4375,4483,"Giáo sư Miller,"],[4562,4683,"em đang làm gì vậy?"],[4767,5005,"Em nghĩ mình sẽ hôn anh,"],[5005,5121,"Giáo sư Hayes."]]}