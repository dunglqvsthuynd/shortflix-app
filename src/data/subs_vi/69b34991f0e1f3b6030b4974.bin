204,"Cháu tôn trọng quyết định của Grayson."],[4241,4358,"Dù bọn cháu không còn bên nhau,"],[4479,4620,"cháu vẫn xem bác như người nhà."],[4666,4720,"Bác không quan tâm"],[4720,4879,"bạn gái mới của Grayson là ai."],[4904,5120,"Chỉ có cháu mới là người phù hợp với nó."],[5583,5795,"Reese Foster, đến đúng giờ đấy."],[6495,6604,"Grayson, tôi đến rồi."],[7962,8129,"Reese Foster?"],[8254,8470,"Cô là bạn gái mới của con trai tôi sao?"]],"16":[[8,220,"Cháu... cháu xin lỗi, bác Hayes."],[229,366,"Cháu sẽ dọn ngay ạ."],[441,570,"Người giúp việc sẽ lo."],[608,795,"Bác Amy, đừng giận cô ấy."],[795,1033,"Ý cháu là cô ấy chỉ hậu đậu thôi."],[1145,1295,"Cháu biết một tiệm bánh nổi nhất thị trấn,"],[1295,1416,"cháu sẽ gọi cho họ"],[1416,1566,"và sửa lại mọi thứ."],[1604,1770,"Piper, cháu đúng là thiên thần,"],[1845,2045,"khác hẳn bạn gái mới của con trai bác,"],[2070,2166,"rõ ràng chẳng biết"],[2166,2233,"một chút gì"],[2233,2408,"về việc làm bạn gái cầu thủ hockey."],[2454,2608,"Hay là để tài xế"],[2608,2745,"đưa cô về nhé, Reese?"],[2783,2970,"Bác... bác đuổi cháu đi à?"],[2979,3029,"Không,"],[3066,3283,"tôi đang lịch sự mời cô về"],[3283,3333,"sau khi cô"],[3333,3445,"tự làm mình mất mặt"],[3454,3683,"và phá hỏng bao nhiêu công sức của tôi"],[3683,3758,"trong bếp."],[3916,4045,"Cho phép cháu nói thẳng,"],[4095,4170,"bác Hayes."],[4216,4320,"Chính con trai bác đã mời cháu,"],[4320,4433,"bác không thể cứ thế"],[4433,4495,"đuổi cháu đi được."],[4529,4654,"Cho phép tôi nói thẳng,"],[4720,4791,"tôi sẽ rất cảm kích"],[4791,4908,"nếu cô đừng cãi lại tôi"],[4908,4983,"ngay trong chính nhà của tôi."],[5108,5320,"Nhưng tôi cũng không mong đợi phép tắc gì"],[5320,5495,"từ một đứa mồ côi không ai cần đến."],[5708,5970,"Cháu không phải là đứa không ai cần."],[5995,6095,"Nếu bác không tin,"],[6095,6220,"sao không đi hỏi con trai bác đi?"],[6420,6633,"Piper, cháu với bạn của cháu"],[6633,6758,"đưa Reese ra cửa giúp bác nhé?"],[6883,6983,"Rất sẵn lòng ạ."],[7195,7316,"Không, không, không."],[7320,7491,"Gray... Grayson! Grayson!"],[7566,7683,"Cô ấy sẽ không đi đâu cả."],[9016,9120,"Bánh cupcake đẹp đấy, mẹ."],[9395,9445,"À.."],[9516,9604,"Chào mọi người."],[9633,9766,"Mọi người đã gặp Reese, bạn gái tôi"],[9766,9829,"rồi chứ?"]],"17":[[487,591,"Grayson, con đang làm gì vậy?"],[641,775,"Con đang bảo vệ bạn gái của con,"],[779,891,"vì rõ ràng mẹ"],[891,979,"chẳng phải là một chủ nhà tử tế chút nào."],[1004,1141,"Và vì Reese đang hẹn hò với con,"],[1141,1179,"cô ấy sẽ là"],[1179,1300,"một trong những phù dâu của Josie."],[1475,1529,"Cái gì?"],[1541,1650,"Phù dâu á?"],[1691,1854,"Grayson, anh chắc chứ?"],[1854,1904,"Ý em là"],[1912,2054,"Reese biến mất"],[2054,2116,"suốt bốn năm"],[2116,2229,"rồi đột nhiên xuất hiện lại,"],[2229,2404,"anh không thấy đáng nghi sao?"],[2429,2650,"Anh vừa giành MVP của NHL,"],[2666,2766,"anh không nghĩ cô ta đến đây"],[2804,2937,"vì danh tiếng và tiền bạc của anh à?"],[2975,3116,"Dù chuyện này chẳng liên quan gì đến cô,"],[3150,3212,"Piper."],[3454,3512,"Nhưng Reese và tôi"],[3512,3612,"thật ra đã gặp lại nhau hai tháng trước"],[3612,3725,"ở tiệm bánh Macy’s."],[3741,3891,"Bọn tôi còn tranh nhau"],[3904,3966,"miếng cuối cùng của gì nhỉ?"],[3979,4079,"Bánh chanh mâm xôi à?"],[4254,4379,"Và ngay lúc đó tôi biết"],[4379,4462,"mình phải tỏ tình với cô ấy,"],[4462,4579,"vì từ đó tôi không thể ngừng nghĩ về cô ấy."],[4700,4866,"Tôi thề sẽ không để mất cô ấy thêm lần nữa."],[4925,5083,"Biết là đang giả vờ yêu,"],[5083,5266,"mà sao cảm giác lại thật đến vậy?"],[5279,5429,"Họ dễ thương quá đi mất."],[5629,5704,"Không, không đúng."],[5737,5929,"Tôi biết Reese và Grayson"],[5962,6054,"đang giấu chuyện gì đó."],[6900,7041,"Váy của tôi!"],[7050,7166,"Mặt tôi nữa!"],[7212,7437,"Cảnh báo: người yêu cũ điên loạn!"],[8004,8129,"Trời ơi!"],[8325,8475,"Tôi biết cô đang giở trò gì đó."],[8487,8591,"Để xem khi tôi lật tẩy được,"],[8591,8654,"cái chuyện cổ tích của cô"],[8654,8791,"sẽ sụp đổ như thế nào."],[9287,9379,"Để tôi đưa cậu đi lau sạch."],[9854,9937,"Chết tiệt,"],[9937,9991,"không thể tin được"],[9991,10104,"họ lại tin sái cổ như vậy."],[10304,10366,"Grayson,"],[10450,10641,"những gì cậu vừa nói"],[10712,10825,"nghe thật đến mức"],[10966,11066,"giống như cậu thật sự"],[11066,11137,"có ý vậy."],[11254,11350,"À thì, Reese à."]],"18":[[16,104,"À thì, Reese à."],[579,683,"Còn nhớ đêm prom,"],[683,820,"Reese đã chọn Nate thay vì mày."],[820,975,"Giờ cô ấy giúp mày"],[975,1120,"chỉ vì muốn gặp thần tượng của mình,"],[1120,1179,"Lana Winter."],[1179,1241,"Tôi biết."],[1241,1354,"Không thể tin họ lại tin thật."],[1429,1562,"Chỉ là mày tự tưởng tượng thôi, Reese."],[1562,1754,"Hai người chỉ đang giả vờ hẹn hò, không hơn."],[1779,1837,"Ừ."],[1887,1966,"Ừ, đúng là vậy."],[1991,2116,"Lâu rồi mới quay lại, nhưng"],[2300,2429,"phòng cậu chẳng thay đổi gì mấy."],[2816,2891,"Twilight?"],[2979,3037,"Thật luôn?"],[3141,3300,"Cậu ghét ma cà rồng mà."],[3479,3654,"Cái đó là của Piper."],[3704,3762,"À."],[3891,4012,"Ừ, thế còn cái này?"],[4287,4391,"Mùi bí đỏ?"],[4416,4504,"Nghiêm túc đấy à?"],[4504,4616,"Trước giờ cậu luôn chê"],[4616,4779,"cái mùi nhân tạo vớ vẩn này mà."],[4804,4904,"Cũng là của Piper."],[5016,5079,"Ừm."],[5225,5275,"Màu đỏ à?"],[5312,5466,"Cậu đâu bao giờ mặc đồ đỏ."],[5504,5662,"Trời ơi, đó là màu đỏ rượu."],[5766,5979,"À, cũng là Piper nói cậu thế à?"],[5979,6154,"Ừ thì tôi có vài món đồ của cô ta."],[6154,6300,"Vấn đề không phải là"],[6300,6416,"vài món đồ, được chứ?"],[6416,6641,"Cô ta đã thay đổi cậu rất nhiều"],[6654,6854,"và ai nhìn cũng thấy rõ."],[6854,6979,"Nếu cậu không muốn tôi thay đổi,"],[6979,7062,"thì bốn năm qua"],[7062,7175,"cậu ở đâu hả?"]],"19":[[45,204,"Không một cuộc gọi, không một tin nhắn."],[279,320,"Nên là"],[320,441,"tôi đã quay sang hẹn hò với Piper"],[441,516,"một thời gian"],[516,629,"vì cô ấy thật sự ở đó."],[679,720,"Không giống cậu,"],[720,920,"cậu biến mất không một lời."],[1495,1629,"Cậu biết là tôi đã nhớ cậu đến mức nào không?"],[1833,1908,"Tôi quay lại"],[2129,2195,"vì cậu."],[2508,2570,"Có người tới."],[2583,2625,"Có người tới."],[2633,2733,"Grayson?"],[2808,2883,"Cởi đồ ra đi!"],[2895,2945,"Cởi ra nhanh!"],[2945,3029,"Cởi đồ á?"],[3029,3083,"Ừ!"],[3241,3354,"Cậu đang làm gì vậy?"],[3354,3433,"Cứ làm theo tôi đi,"],[3433,3516,"trừ khi cậu muốn người yêu cũ của mình"],[3516,3641,"phát hiện ra chúng ta đang làm gì, hiểu chưa?"],[3795,3879,"Anh ở trong đó không?"],[4108,4158,"Được rồi."],[4216,4291,"Ôi."],[4741,4837,"Mình đang ép sát"],[4837,5012,"vào cơ bụng của Grayson."],[5012,5245,"Trời ơi, cái này không có trong kế hoạch!"]],"20":[[258,345,"Nghiêm túc đấy, Grayson,"],[345,445,"con nhỏ đó đúng là một mớ hỗn độn."],[445,583,"Cậu thấy gì ở Re..."],[1162,1237,"Trời ơi!"],[1825,1937,"Cái quái gì đây?"],[1987,2087,"Cô là con nít à?"],[2087,2200,"Cô nghĩ đây là gì hả, Piper?"],[2475,2633,"Ra ngoài nhớ đóng cửa lại."],[3675,3783,"Cậu nghĩ họ tin không?"],[3850,3950,"Tôi thấy tụi mình diễn cũng ổn đấy chứ."],[3995,4325,"Chết rồi, bánh dính lên..."],[4445,4475,"Cậu kìa."],[4475,4595,"Ừ, không sao đâu."],[4900,5025,"Giống như ngày xưa nhỉ?"],[5487,5683,"Cảm ơn cậu đã giúp tôi, Reese."],[5770,5850,"Vẫn là bạn chứ?"],[5887,6008,"Cô bạn Reese."],[6087,6225,"Sau bốn năm rồi,"],[6225,6370,"cái biệt danh đó vẫn đau như cũ."],[6483,6570,"Nhưng sẽ còn đau hơn"],[6570,6725,"nếu tôi lại rời khỏi cuộc đời cậu ấy lần nữa."],[6925,7012,"Bạn thân."],[7125,7233,"Được rồi, phù dâu."],[7387,7483,"Hẹn gặp ở lễ đường nhé?"],[7687,7758,"Ừ, hẹn gặp nha."],[8112,8225,"Tôi vẫn còn yêu cậu ấy,"],[8283,8375,"và chính vì vậy tôi không thể cho cậu ấy"],[8375,8500,"cơ hội làm tan nát trái tim mình."],[8608,8670,"Thêm một lần nào nữa."]],"21":[[829,887,"Nhiệm vụ tiếp theo"],[887,1041,"trong vai bạn gái giả của Grayson"],[1041,1279,"là trận tennis tại đám cưới chị gái cậu ấy."],[1554,1725,"Đối thủ là người yêu cũ của cậu ấy."],[1737,1804,"Tuyệt vời thật đấy."],[1804,1925,"Sẵn sàng cho trận đấu chưa, Reese?"],[1925,2079,"Tôi sinh ra là để thắng rồi, Piper."],[2179,2304,"Tự tin ghê nhỉ?"],[2366,2416,"Vậy thì"],[2466,2700,"tăng độ khó bằng một ván cược đi."],[2775,2954,"Ai ghi điểm quyết định trước"],[2954,3091,"thì tối nay được ở lại"],[3116,3216,"cùng gia đình."],[3716,3816,"Được thôi, Reese."],[3854,3929,"Nghe cho rõ đây,"],[3954,4179,"vì tôi không thích nói lại."],[4179,4400,"Nếu tối nay tôi phải nuôi thêm một miệng ăn"],[4404,4529,"hay chứa thêm một người"],[4529,4704,"dưới mái nhà này,"],[4712,4791,"thì chắc chắn"],[4791,4929,"không phải loại người như cô."],[5041,5216,"Nên cầm lấy số tiền này"],[5466,5629,"và biến khỏi cuộc đời con trai tôi mãi mãi."]],"22":[[4,254,"Grayson sắp trở thành Gretzky tiếp theo rồi,"],[262,391,"còn cô thì vẫn chỉ lo"],[391,537,"mấy trò thủ công vớ vẩn."],[537,675,"Cô không xứng với con trai tôi"],[675,779,"và sẽ không bao giờ xứng."],[829,941,"Vậy nên nhận lấy số tiền này đi,"],[975,1166,"vì số tiền này"],[1166,1250,"còn nhiều hơn cả những gì"],[1250,1354,"cô từng thấy trong đời nghèo hèn của mình."],[1354,1516,"Theo cháu nhớ thì"],[1516,1675,"con trai bác đã là người trưởng thành rồi,"],[1675,1816,"nên cháu nghĩ cậu ấy có thể tự quyết"],[1816,1929,"việc có muốn cháu ở đây hay không."],[1950,2279,"Cô chẳng khác gì một con gián."],[2312,2437,"Tôi phải đập chết cô bao nhiêu lần"],[2437,2579,"thì cô mới chịu biến mất?"],[2587,2654,"Được thôi,"],[2691,2766,"cháu ở đây"],[2787,2954,"vì cháu quan tâm đến Grayson."],[2954,3029,"Nếu cô thật sự quan tâm,"],[3079,3254,"thì cô sẽ để Piper thắng trận tennis này."],[3262,3379,"Piper sẽ ở lại qua đêm,"],[3404,3516,"sáng mai Grayson sẽ"],[3516,3591,"quay lại với nó,"],[3629,3791,"và con gái tôi sẽ có một đám cưới"],[3791,4041,"không có mấy con sâu bọ phá đám."],[4075,4412,"Đừng quên, chúng tôi mới là gia đình của nó."],[4529,4600,"Còn cô là ai?"],[4641,4779,"Cháu sẽ không đứng đây"],[4779,4962,"bắt Grayson phải chọn phe,"],[5012,5237,"vì cháu đến đây vì cậu ấy, không phải vì bác."],[5275,5375,"Dù bác có đưa bao nhiêu tiền đi nữa"],[5412,5504,"cũng không khiến cháu"],[5504,5629,"rời bỏ cậu ấy."],[6575,6637,"Đến giờ thi đấu rồi."],[7079,7216,"Reese giao bóng trước."],[7225,7329,"Cô ấy từng chơi thời cấp ba."],[7379,7504,"Cho mọi người thấy đi nào."],[8391,8500,"Chúc may mắn nhé, Reese."],[9291,9379,"Cô sẽ cần đấy."]],"23":[[629,691,"Reese."],[1054,1216,"Cô chắc vẫn chơi được chứ, Reese?"],[1229,1400,"Cú ngã vừa rồi khá nặng đấy."],[1400,1475,"Ừ, ngã chút xíu"],[1475,1562,"không đủ"],[1562,1650,"để hạ gục tôi đâu."],[2466,2641,"Cô sẽ để Piper thắng trận tennis này."],[3325,3462,"Cô không xứng với con trai tôi,"],[3462,3566,"và sẽ không bao giờ xứng."],[4041,4266,"Cô chẳng khác gì một con gián."],[4312,4441,"Tôi phải đập chết cô bao nhiêu lần"],[4441,4579,"thì cô mới chịu biến mất?"],[4591,4675,"Điểm quyết định."],[4741,4854,"Đội Piper ghi điểm."],[4920,5041,"Đừng buồn, Reese."],[5041,5154,"Ai rồi cũng có lúc xuống phong độ."],[5166,5279,"Cô cũng đã cố hết sức rồi."],[5320,5425,"Tôi biết mẹ của Grayson"],[5425,5550,"đã bảo cô cố tình thua trận"],[5550,5691,"để tối nay không được ở lại."],[5704,5791,"Cảm giác thế nào"],[5791,5929,"khi biết bà ta sẵn sàng làm mọi thứ"],[5929,6116,"chỉ để xua đuổi cô khỏi con trai mình?"],[6125,6204,"Tôi không quan tâm"],[6250,6412,"bác Amy nghĩ gì, được chưa?"],[6412,6529,"Tôi ở đây chỉ vì Grayson."],[6529,6675,"Ồ, đừng lo cho Grayson."],[6704,6891,"Tôi sẽ giữ giường của anh ấy thật ấm,"],[6904,7079,"và khi anh ấy rên tên tôi xong,"],[7116,7291,"anh ấy thậm chí còn chẳng nhớ đến cô."],[8254,8325,"Của tôi!"]],"24":[[1408,1537,"Chắc cô hài lòng rồi chứ,"],[1537,1600,"Reese?"],[1608,1712,"Piper từ đầu đến giờ"],[1712,1812,"chỉ đối xử tốt với cô thôi."],[1862,1975,"Chúng tôi đều nghe thấy rồi."],[1975,2158,"Tôi cá là Reese cố tình đánh vào Piper."],[2162,2375,"Rõ ràng cô ta ghen với Piper."],[2408,2575,"Không hiểu Grayson thấy gì ở cô ta nữa."],[2583,2737,"Không, không sao đâu."],[2737,2850,"Reese không cố ý đâu."],[2850,3025,"Hôm nay là tiệc trước đám cưới của Josie,"],[3025,3170,"đừng biến tôi thành tâm điểm."],[3462,3595,"Grayson đâu rồi?"],[3612,3700,"Làm ơn, bác Hayes,"],[3700,3800,"bác phải tin cháu."],[3800,4037,"Tôi không cần phải làm gì cả, Reese."],[4070,4187,"Đây là nhà của tôi,"],[4233,4316,"và cô"],[4316,4462,"không còn được chào đón nữa."],[4700,4837,"Nhưng tôi... tôi..."],[4837,5050,"Cô không xứng với con trai tôi,"],[5087,5195,"và sẽ không bao giờ xứng."],[5241,5383,"Nhớ lấy điều đó lần sau"],[5383,5558,"khi cô định len lỏi quay lại cuộc đời nó."],[5583,5737,"Ai đó đưa cô ta ra ngoài giúp tôi đi."],[5745,5783,"Cái gì?"],[5783,5983,"Không, không, dừng lại!"],[6000,6125,"Xin lỗi mẹ,"],[6125,6300,"con không kịp đến chỗ Lana Winter."],[6587,6762,"Này, bỏ tay ra khỏi bạn gái tôi."],[6937,7062,"Trận đấu đã được ghi lại,"],[7075,7150,"và tôi nghĩ có thứ"],[7150,7262,"mọi người nên xem."]],"25":[[0,100,"Mẹ của Grayson đã bảo cô"],[100,187,"cố tình thua trận"],[187,341,"để tối nay không được ở lại."],[366,429,"Cái gì?"],[679,775,"Cảm giác thế nào"],[775,904,"khi biết bà ta sẵn sàng làm mọi thứ"],[904,1104,"chỉ để xua đuổi cô khỏi con trai mình?"],[1116,1291,"Tôi đã gắn mic ở cái cột kia,"],[1316,1387,"nhưng không ngờ"],[1387,1529,"lại thu được thứ như thế này."],[1704,1879,"Không, không phải như vậy."],[1879,2029,"Nhưng tôi biết nó trông như thế nào, Piper."],[2162,2237,"Cổ chân cô sao rồi?"],[2579,2691,"Tôi nghĩ quá rõ ràng rồi,"],[2691,2741,"ai là người thắng"],[2741,2841,"và ai mới là kẻ gian lận."],[2941,3066,"Reese sẽ ở lại tối nay."],[3362,3541,"Tôi không quan tâm mấy cái cược vớ vẩn đó."],[3583,3679,"Đây là nhà tôi,"],[3691,3866,"và Piper sẽ ở phòng khách."],[3866,3966,"Quyết định cuối cùng."],[3966,4062,"Vậy cũng không sao,"],[4062,4154,"vì Reese sẽ ở lại"],[4154,4262,"phòng của con cùng con."],[4608,4679,"Cái quái gì vậy?"],[4716,4841,"Để tôi nói cho rõ này."],[4879,5012,"Reese là cô gái duy nhất tôi yêu,"],[5012,5166,"và tôi sẽ làm mọi thứ để bảo vệ cô ấy."],[5204,5316,"Vậy nên tránh xa ra,"],[5475,5562,"trước khi tôi buộc cô phải làm vậy."]],"26":[[441,554,"Để tôi xử lý vết thương cho cậu."],[937,1037,"Sẽ hơi xót một chút."],[1091,1304,"Nhưng không đau bằng việc ở gần cậu thế này"],[1412,1604,"mà tôi lại không thể làm gì."],[2037,2304,"Không ngờ cậu lại giỏi mấy việc này đấy."],[2337,2454,"Lớn lên ở sân khúc côn cầu,"],[2454,2566,"thì phải quen"],[2566,2675,"sống chung với máu me và vết bầm thôi."],[2716,2850,"Với lại, từ khi bố tôi rời đi"],[2850,3000,"và mẹ lúc nào cũng bận rộn,"],[3029,3116,"thì chỉ có mình tôi"],[3116,3250,"chăm sóc cho bản thân và chị gái."],[3329,3412,"Đúng rồi."],[3429,3616,"Chỉ là thế này thôi, Reese."],[3641,3841,"Cậu ấy đang quan tâm mày như một người bạn,"],[3900,3991,"như một người em gái."],[4041,4154,"Từ trước đến giờ vẫn vậy."],[4191,4379,"Đây là quan tâm, không phải yêu."],[4379,4437,"Mày có còn nhớ"],[4437,4541,"lần trước"],[4541,4650,"mày đã nhầm lẫn hai thứ này ra sao."],[4687,4766,"Tôi... tôi tự làm được rồi,"],[4875,4937,"giờ để tôi lo."],[5500,5625,"Sao cậu lại làm vậy, Reese?"],[5779,5850,"Ý cậu là sao?"],[5904,5991,"Cậu nghĩ tôi không nhận ra"],[5991,6100,"cậu đang dần né tránh tôi à?"],[6166,6366,"Cậu cười theo mọi câu chuyện của tôi,"],[6366,6550,"cậu nói toàn những điều đúng đắn,"],[6654,6766,"nhưng sâu bên trong"],[6966,7104,"có thứ gì đó cậu đang giữ lại."],[7250,7341,"Còn tôi thì ở đây,"],[7416,7600,"gõ cửa, cầu xin"],[7704,7775,"hãy để tôi bước vào."]],"27":[[750,854,"Kit."],[1854,1941,"Kit."],[1975,2116,"Lần cuối cùng tôi còn là \"Kit\" của cậu ấy,"],[2116,2266,"cậu ấy đã xé nát trái tim tôi."],[2266,2354,"Tôi mất mấy năm trời"],[2354,2466,"mới hàn gắn lại được."],[2804,2929,"Tôi không hề chuẩn bị cho chuyện này."],[2975,3066,"Cô ấy đã không chọn mày"],[3066,3137,"từ bốn năm trước,"],[3137,3254,"và giờ cũng vậy thôi."],[3304,3379,"Tránh xa ra đi,"],[3379,3520,"nếu mày còn muốn cô ấy ở lại bên mình."],[3650,3741,"Tôi xin lỗi."],[3779,3925,"Xin lỗi, sẽ không xảy ra nữa đâu."],[4029,4125,"Đây là một sai lầm."],[4379,4441,"Được rồi."],[4629,4812,"Cảm ơn cậu đã làm bạn gái giả của tôi."],[5054,5179,"Cậu là một người bạn tuyệt vời, Reese."],[5837,5912,"Bạn à?"],[5991,6191,"Đến bao giờ từ đó mới thôi làm mình đau đây?"],[6366,6579,"Không. Thế này là tốt nhất."],[6579,6737,"Mình không thể chơi lại trò này nữa."],[6841,7066,"Thua thêm lần nữa, chắc mình không chịu nổi."]],"28":[[166,279,"Không đời nào"],[279,416,"một ngôi sao khúc côn cầu như Grayson"],[416,533,"lại thật sự qua lại"],[533,695,"với một đứa vô danh như Reese."],[708,854,"Và giờ thì đến lúc có bằng chứng rồi."],[3245,3358,"Kit, anh đã nghĩ về em"],[3358,3504,"hơn cả một người bạn."],[3591,3670,"Nói với anh là em cũng muốn anh"],[3670,3783,"như cách anh muốn em đi."],[3866,3966,"Quên cái tình bạn đó đi."],[4070,4183,"Hãy thuộc về em, Gray."],[5020,5083,"Chết tiệt, Reese!"],[5233,5295,"Reese?"],[5320,5495,"Grayson thật sự đang tưởng tượng"],[5495,5658,"về con nhỏ bạn thân đó sao?"]],"29":[[762,895,"Cái quái gì vậy?"],[895,962,"Grayson vốn dĩ"],[962,1050,"đã ở một đẳng cấp khác"],[1050,1162,"so với Reese từ thời cấp ba rồi,"],[1170,1312,"mà giờ lại đang tưởng tượng"],[1312,1379,"về cô ta sao?"],[1404,1579,"Nhưng chắc mình vẫn lợi dụng được chuyện này."],[1641,1825,"Chỉ cần chỉnh sửa video một chút thôi, Reese,"],[1854,2041,"cô sẽ bò trở lại \"vùng bạn bè\""],[2041,2216,"như một bọ sâu đáng thương."],[2479,2575,"Nào các cô gái,"],[2579,2700,"ai sẵn sàng cho đám con trai thấy"],[2700,2837,"tiệc ngủ của phù dâu tụi mình"],[2837,2929,"đỉnh hơn hẳn"],[2929,3137,"cái tiệc khúc côn cầu của bọn họ chưa?"],[3287,3437,"Và tiệc ngủ thì không thể thiếu"],[3437,3600,"chút giải trí đúng không?"],[4100,4275,"Trời ơi, đó là Grayson à?"],[4300,4437,"Tôi không xem đâu."],[4466,4604,"Tùy cậu thôi."],[4604,4716,"Tôi biết mấy anh chàng hockey này"],[4716,4879,"body ngon rồi, nhưng mà..."],[4904,5141,"Đủ rồi, chết tiệt, Piper!"],[5183,5250,"Grayson vừa"],[5250,5375,"gọi tên Piper sao?"]],"30":[[266,387,"Làm quá lên rồi đấy, Reese."],[387,516,"Phản ứng gì mà sốc dữ vậy."],[516,591,"Cậu thật sự nghĩ"],[591,762,"mình có cửa với Grayson à?"],[787,954,"Cái kiểu Reese ngây thơ của cô"],[954,1016,"sao mà đủ"],[1016,1166,"làm hài lòng"],[1166,1254,"chàng cầu thủ hot nhất NHL được."],[1266,1466,"Piper là mối tình đầu của Grayson"],[1466,1650,"và còn là bạn gái suốt bốn năm."],[1650,1804,"Không ai có thể thay thế được điều đó."],[1804,1954,"Tỉnh lại khỏi cái ảo tưởng"],[1954,2091,"cổ tích của mình đi."],[2166,2341,"Chỉ cần chỉnh sửa video một chút thôi"],[2341,2500,"mà Reese đã tin sái cổ"],[2500,2679,"rằng Grayson gọi tên tôi."],[2962,3054,"Cô cũng nghe rồi đấy,"],[3079,3279,"Grayson muốn tôi, không phải cậu."],[3325,3566,"Cô mãi là con bạn Reese nghèo hèn,"],[3579,3837,"tuyệt vọng và bị từ chối."],[4016,4075,"Họ nói đúng đấy."],[4104,4187,"Có thể Grayson từng muốn có mày,"],[4187,4316,"nhưng cậu ấy đã muốn Piper"],[4316,4516,"suốt bao năm rồi."],[4554,4641,"Mày chỉ là đoạn đường vòng"],[4641,4791,"trên con đường hạnh phúc của họ thôi."],[5354,5479,"Chuyện quái gì đang xảy ra vậy?"]],"31":[[29,237,"Piper, cô quay lén tôi trong phòng tắm à?"],[254,425,"Chiêu này của cô đúng là hèn thật."],[454,516,"Cái gì cơ?"],[600,791,"Cũng có gì đâu mà em chưa thấy."],[925,1054,"Nếu cô thích chia sẻ như vậy,"],[1054,1162,"thì hay là tôi cũng chia sẻ"],[1162,1279,"cho mọi người ở đây biết"],[1279,1337,"về cái lần"],[1337,1454,"cô ăn pizza quá đà"],[1454,1641,"đến mức trào ra cả hai đầu cùng lúc."],[1704,1787,"Eo ơi!"],[1850,1916,"Cái quái..."],[1954,2079,"Chuyện đó chưa từng xảy ra!"],[2512,2587,"Reese."],[2825,2904,"Reese, dừng lại!"],[2904,3004,"Tay cậu đang chảy máu kìa."],[3116,3250,"Trời ơi, cái quái gì vậy?"],[3250,3337,"Chuyện gì đang xảy ra vậy?"],[3341,3462,"Rốt cuộc là chuyện quái gì đây?"],[3479,3725,"Tôi vừa thấy cậu trong phòng tắm,"],[3725,3854,"tự xử và gọi tên người yêu cũ!"],[3854,3991,"Đó là chuyện đang xảy ra đấy!"],[4037,4187,"Tôi chưa từng gọi tên Piper."],[4237,4366,"Tôi gọi tên cậu, Reese."],[4366,4487,"Vậy mà cậu vẫn đứng đây"],[4512,4587,"và nói dối à?"],[4600,4762,"Không định nói thật với tôi sao?"],[4787,4854,"Tôi muốn nói với cô ấy"],[4854,4962,"rằng tôi đã yêu cô ấy suốt những năm qua"],[4962,5100,"nhưng nếu cô ấy không muốn tôi thì sao?"],[5179,5362,"Nếu cô ấy đi và không quay lại thì sao?"],[5441,5566,"Reese, đoạn video đó, tôi..."],[5716,5775,"Gì cơ?"]],"32":[[120,212,"Tôi không thể mất cô ấy thêm lần nữa."],[212,400,"Không phải lúc này, khi tôi vừa có lại được."],[450,545,"Tôi không biết phải nói gì nữa."],[700,775,"Tôi không quan tâm"],[775,900,"cậu đã làm gì trong phòng tắm."],[925,1050,"Tôi đang nói dối trắng trợn"],[1050,1225,"chỉ mong cậu đừng nhận ra sự thật."],[1237,1487,"Chính cậu là người nhờ tôi ở lại đây,"],[1500,1650,"làm bạn gái giả của cậu."],[1662,1825,"Vậy mà chưa được một tuần đã thế này rồi?"],[1883,2058,"Cậu biết không, tôi chịu được"],[2058,2187,"sự coi thường từ mẹ cậu và từ Piper,"],[2187,2262,"nhưng từ chính cậu thì..."],[2283,2312,"Reese,"],[2312,2462,"không ai ép cậu phải ở đây cả."],[2487,2575,"Cậu muốn đi lúc nào cũng được."],[2575,2695,"Cửa ở ngay kia kìa."],[2783,2995,"Cậu đúng là vô ơn."],[2995,3075,"Trời ơi,"],[3075,3337,"tôi đã lãng phí quá nhiều thời gian của mình"],[3337,3475,"để ở đây vì cậu."],[3512,3775,"Lẽ ra tôi có thể ở nhà làm luận văn,"],[3775,3908,"làm thiết kế thời trang của tôi,"],[3920,4008,"kiếm tiền"],[4008,4162,"để tự trả tiền thuê nhà,"],[4162,4358,"nhưng tôi lại ở đây vì cậu!"],[4366,4445,"Đừng có ngồi đó"],[4445,4575,"mà giả vờ như cậu làm tất cả vì tôi."],[4920,5037,"Tôi nhớ rõ thỏa thuận của chúng ta."],[5062,5112,"Cậu sẽ có được"],[5112,5225,"cơ hội quý giá gặp thần tượng Lana của mình"],[5225,5387,"tại đám cưới,"],[5387,5487,"rồi sau đó"],[5487,5608,"cậu sẽ bay sang London"],[5625,5770,"trước khi kịp nói \"chết tiệt\"."],[5775,6025,"Cậu thật sự nghĩ tôi ở đây"],[6062,6225,"chỉ để nịnh bợ Lana Winter thôi sao?"],[6225,6375,"Vậy thì còn vì lý do gì nữa?"],[6400,6475,"Cậu đã biến mất"],[6475,6608,"suốt bốn năm qua."],[6625,6725,"Cậu còn lý do gì"],[6725,6850,"để quay lại đây nữa?"],[6912,7045,"Nói đi."],[7137,7237,"Nói ra đi, Kit."],[7279,7366,"Nói là cậu cũng muốn tôi đi."],[7366,7520,"Tôi đã chờ suốt bốn năm rồi."]],"33":[[70,225,"Tôi ở đây là vì mẹ tôi,"],[225,325,"đồ khốn."],[495,587,"Thật không thể tin nổi"],[587,687,"là cậu lại không nhớ chuyện đó."],[762,825,"Reese, tôi..."],[837,962,"Vậy là cậu nhớ,"],[1020,1175,"chỉ là cậu không quan tâm thôi!"],[1358,1387,"Reese,"],[1387,1508,"mẹ cậu đã dạy cậu may vá"],[1508,1637,"từ khi cậu mới năm tuổi."],[1687,1833,"Còn nhớ cái máy may màu hồng"],[1833,1920,"cậu được tặng Giáng Sinh không?"],[1920,2008,"Tôi gần như phải giật nó"],[2008,2100,"khỏi tay cậu đấy."],[2175,2258,"Giấc mơ của mẹ cậu"],[2258,2387,"là được học thời trang ở London."],[2387,2570,"Bà đã từ bỏ tất cả để nuôi cậu."],[2608,2845,"Và rồi việc cậu vào học cao học"],[2845,2937,"ở trường Thời trang London"],[2937,3050,"trở thành giấc mơ mới của bà."],[3095,3250,"Cũng là giấc mơ của cả hai người."],[3358,3525,"Và tôi vừa... vừa nộp đơn"],[3575,3687,"cho kỳ học tới."],[3812,3908,"Được, tôi không thể tin"],[3908,3987,"là cậu vẫn nhớ chuyện đó."],[4020,4120,"Reese, cậu có thể đứng đây"],[4120,4237,"mắng tôi, gọi tôi bằng đủ thứ tên"],[4237,4308,"hay làm gì cũng được,"],[4308,4395,"nhưng đừng bao giờ nói"],[4395,4512,"là tôi không quan tâm đến cậu,"],[4600,4687,"vì tôi chưa từng"],[4687,4775,"ngừng quan tâm đến cậu."],[5550,5750,"Cậu có cái áo thun nào không?"],[5887,6025,"Tôi không mang đồ ngủ theo."],[6187,6300,"Tôi cứ nghĩ cậu sẽ không hỏi chứ."]],"34":[[666,891,"Gần đến mức tôi chỉ cần với tay là chạm được."],[987,1291,"Vậy mà giữa chúng tôi lại có khoảng cách lớn"],[1337,1516,"từ những điều chưa từng nói ra."],[3541,3616,"Grayson?"],[3704,3779,"Con dậy chưa?"],[4016,4075,"Dậy đi."],[4262,4341,"Cho tôi thêm mười phút."],[4416,4529,"Mười giây nữa thôi"],[4529,4637,"là mẹ cậu xông vào đây"],[4637,4775,"và phát hiện ra tụi mình không ngủ cùng nhau."],[4866,4937,"Dậy mau!"],[5012,5066,"Nhanh lên."],[5179,5354,"Chết tiệt."],[5354,5554,"Chết tiệt."],[5729,5941,"Grayson, anh định lơ tụi này luôn à?"],[5966,6125,"Tuyệt, giờ thì người yêu cũ của cậu"],[6125,6191,"đang đứng ngoài kia rồi."],[6216,6300,"Trời ơi,"],[6300,6491,"tôi nghĩ tụi mình không cần thêm khách nữa."]],"35":[[75,166,"Bình tĩnh đi."],[754,879,"Cậu nghiêm túc đấy à?"],[912,979,"Họ sắp xông vào đây"],[979,1091,"thấy tụi mình vẫn mặc nguyên quần áo"],[1104,1150,"rồi phát hiện ra"],[1150,1262,"tụi mình không hề hẹn hò thật."],[1279,1416,"Reese, cứ tin tôi đi."],[1566,1837,"Trời ơi, cái đó là...?"],[2583,2687,"Cháu nói rồi mà, bác Amy,"],[2704,3004,"mối quan hệ này không đơn giản như vẻ ngoài."],[3687,3766,"Nhìn lên đây này,"],[3791,3879,"đồ biến thái."],[4579,4654,"Ôi trời,"],[4729,4825,"tôi cảm nhận được rồi."],[4854,4954,"Chuyện này không thể nào"],[5429,5487,"Hai người định để bọn tôi"],[5487,5566,"tắm buổi sáng"],[5566,5654,"hay là thật sự muốn chúng tôi"],[5654,5750,"làm trước mặt khán giả luôn?"],[5791,5866,"Anh đang nói dối."],[5904,6016,"Hai người đang giấu chuyện gì đó"],[6016,6150,"và em sẽ vạch trần"],[6150,6304,"ngay tại đây, ngay bây giờ."]],"36":[[408,458,"Piper!"],[529,620,"Cháu bị điên à?"],[654,779,"Cháu định cho bác xem"],[779,870,"con trai bác khỏa thân thật sao?"],[929,995,"Nhưng... nhưng họ..."],[995,1058,"Đủ rồi."],[1079,1183,"Dừng lại ngay đi,"],[1216,1358,"khi cháu vẫn còn chút thể diện."],[2970,3083,"Vừa rồi suýt lộ rồi."],[3433,3541,"Tôi còn muốn gần hơn cơ."],[4191,4220,"Cậu biết không,"],[4220,4333,"chắc cậu nên đi thay đồ đi."],[5129,5216,"Tôi có cuộc họp"],[5370,5445,"trong thành phố."],[5654,5729,"Gặp lại cậu sau."],[6766,6895,"Reese quên túi à?"],[7279,7391,"Cô ấy vẫn mang theo"],[7391,7558,"cuốn sổ phác thảo từ hồi cấp ba sao?"],[8508,8616,"Có phải Reese...?"]],"37":[[816,966,"Tập trung vào công việc đi, Reese."],[983,1141,"Đừng nghĩ nữa."],[1595,1658,"Gray."],[4933,5058,"Đừng trốn tránh nữa, Kit."],[5191,5333,"Trong mắt tôi, cậu chưa bao giờ chỉ là bạn."],[5333,5470,"Và tôi biết cậu cũng cảm thấy như vậy."],[5483,5541,"Tôi có."],[5620,5754,"Tôi đã muốn cậu suốt cả cuộc đời này rồi,"],[5754,5804,"Gray."],[7070,7133,"Grayson."],[7533,7679,"Reese, tôi vào được không?"],[7745,7820,"Trời ơi."],[7845,7954,"Grayson vừa nghe thấy"],[7954,8045,"tôi gọi tên cậu ấy à?"],[8070,8129,"Cậu ổn chứ?"]],"38":[[50,141,"- Reese, cậu ổn không? - Trời ơi."],[600,791,"Cậu... cậu làm gì ở đây vậy?"],[879,1041,"Cậu để quên túi ở nhà."],[1200,1304,"Tôi nghĩ cậu sẽ cần."],[1475,1600,"Cậu đang làm gì bên đó vậy?"],[1600,1641,"Hả?"],[1691,1791,"Không, không có gì."],[1916,1991,"Không phải..."],[2004,2129,"không phải chuyện của cậu."],[2412,2529,"Tôi không nghĩ vậy đâu, Reese."],[2550,2704,"Tôi nghĩ nó rất liên quan đến tôi,"],[2762,2850,"đặc biệt là khi"],[2850,2950,"trên đó có mặt tôi."],[3054,3129,"Mặt cậu?"],[3475,3541,"Cái này là gì vậy?"],[3729,3837,"Ôi tuyệt."],[3837,3954,"Được rồi, có lẽ lúc nãy Grayson"],[3954,4054,"không nghe thấy mình,"],[4054,4162,"nhưng giờ thì mình có thêm lý do"],[4162,4304,"để độn thổ vì xấu hổ rồi."],[4450,4487,"Tôi..."],[4504,4616,"tôi có thể giải..."],[4625,4691,"giải thích mà."],[4729,4829,"Nghĩ đi, Reese."],[4854,4966,"Nói là không phải của mình đi."],[4991,5125,"Đừng chối nữa, Reese."],[5154,5266,"Tôi nhận ra nét vẽ của cậu."],[5275,5362,"Cậu nghĩ tôi quên rồi à?"],[5491,5566,"Nói thật với tôi đi."],[5566,5737,"Tại sao cậu lại vẽ cái này?"],[5825,5941,"Cậu ấy thậm chí còn không nhớ sao?"],[6025,6216,"Grayson, tôi biết đã bốn năm rồi,"],[6216,6404,"nhưng cậu thật sự cần nhắc lại"],[6404,6512,"chuyện đã xảy ra ở prom à?"],[6579,6679,"Cậu đang nói gì vậy?"],[6716,6804,"Cậu không chỉ"],[6804,6879,"làm tan nát trái tim tôi,"],[6879,7075,"mà rõ ràng với cậu nó chẳng có ý nghĩa gì"],[7075,7179,"đến mức cậu còn quên luôn."],[7241,7354,"Reese, bình tĩnh lại đi."],[7404,7516,"Nếu cậu cần nhớ lại,"],[7566,7754,"thì tôi vẽ cái này từ hồi cấp ba"],[7779,7979,"vì tôi đã từng thích cậu"],[7979,8079,"một cách ngốc nghếch, mãnh liệt."]],"39":[[25,187,"Khoan, Reese từng thích mình hồi cấp ba sao?"],[379,445,"Thế còn Nate thì sao?"],[495,545,"Hả?"],[745,866,"Tôi... tôi chưa từng thích Nate."],[945,1033,"Nhưng ở prom, cậu..."],[1041,1195,"Đúng, ở prom, khi tôi nói với cậu"],[1195,1295,"rằng tôi yêu cậu,"],[1295,1441,"và chỉ mười giây sau,"],[1441,1554,"cậu quay sang hôn Piper."],[1625,1729,"Tất cả là lỗi của mình."],[1741,1891,"Đáng lẽ phải cho Reese biết cảm xúc của mình."],[1941,2020,"Reese, tôi có thể..."],[2383,2570,"Chết tiệt, mình nói quá rồi."],[2595,2720,"Grayson không bao giờ được phép biết"],[2720,2808,"những chuyện này."],[2833,2908,"Mình phải khiến cậu ấy nghĩ"],[2908,3029,"rằng mình không còn thích cậu ấy nữa."],[3083,3129,"Được rồi."],[3258,3345,"Nói thật thì,"],[3579,3783,"tôi đã biến mất một thời gian"],[3783,3895,"sau tất cả mọi chuyện,"],[3904,4016,"và cậu luôn"],[4016,4133,"giống như gia đình đối với tôi,"],[4133,4383,"cậu từng là tất cả với tôi"],[4558,4620,"ngày xưa."],[4908,4958,"Nhưng bây giờ"],[5195,5308,"không còn như vậy nữa."],[5308,5370,"Chúng ta chỉ là"],[5504,5579,"bạn thôi."],[5658,5754,"Mọi chuyện trước đây"],[5920,5995,"coi như quên đi."],[6137,6237,"Buông đi, Grayson."],[6237,6383,"Dù cô ấy từng thích mày bốn năm trước,"],[6383,6533,"giờ cũng không còn cảm xúc đó nữa đâu."],[6612,6804,"Chính mày đã phá hỏng tất cả khi hôn Piper."],[6883,6979,"Mày nợ cô ấy điều này."],[7108,7154,"Này,"],[7241,7345,"đừng bận tâm, Reese."],[7495,7529,"Được rồi,"],[7529,7620,"ai rồi cũng từng có sai lầm ngu ngốc"],[7620,7691,"thời cấp ba mà."],[7754,7829,"Cậu tuyệt lắm."],[8216,8354,"Nhân tiện đang nói"],[8354,8495,"thật lòng với nhau,"],[8545,8595,"tôi có chuyện này"],[8595,8708,"cần nói với cậu."],[8745,8816,"Tôi đến đây"],[8816,8920,"không chỉ để đưa lại túi cho cậu."]],"40":[[125,266,"Quần tôi rộng quá, không mặc vừa đi đám cưới."],[366,487,"Cậu đến đây chỉ để sửa đồ thôi à?"],[541,566,"Ý tôi là"],[566,712,"bạn bè thì giúp nhau mà, đúng không?"],[716,787,"Lao động miễn phí?"],[829,950,"Ừ, cũng đúng."],[1004,1041,"Được rồi,"],[1104,1291,"mặc vào đi, thưa điện hạ."],[1416,1491,"Điện hạ cơ đấy."],[3066,3179,"Tập trung đi, Reese."],[3179,3279,"Chính mày vừa nói"],[3279,3466,"chỉ muốn làm bạn thôi."],[4604,4691,"Phải xử lý"],[4691,4766,"chuyện này thôi."],[4916,4979,"Được rồi."],[5279,5341,"Được rồi."],[5591,5741,"Grayson chỉ là một người mẫu thôi mà."]],"41":[[191,466,"Và còn là MVP trẻ nhất NHL"],[466,562,"của thế hệ mới,"],[562,800,"nghĩa là cơ bụng thì săn chắc,"],[800,1025,"cánh tay thì quyến rũ nhất tôi từng thấy."],[1825,1891,"Dừng lại đi."],[1891,1979,"Chúng ta vừa thống nhất rồi mà,"],[1979,2104,"chỉ nên làm bạn thôi."],[2891,2941,"Reese?"],[3000,3054,"Gì vậy?"],[3254,3312,"Chết rồi."],[3379,3504,"Tôi làm cậu chảy máu à?"],[4279,4350,"Không, không, không, không."],[4350,4416,"Làm ơn, dừng lại đi,"],[4416,4500,"dừng lại trước khi mọi chuyện"],[4500,4566,"đi quá xa."]],"42":[[275,325,"Ồ."],[604,654,"Cậu biết không,"],[666,812,"đây là lần thứ hai trong hai ngày rồi đấy."],[929,1054,"Tôi sắp tính phí cậu rồi đấy."],[1241,1475,"Tôi thề là tôi không nhìn đâu, được chưa?"],[1479,1600,"Tôi chỉ muốn chắc là cậu"],[1691,1750,"ổn thôi."],[1862,1991,"Chỉ hơi nhói chút xíu."],[2654,2716,"Nhưng mà..."],[3254,3366,"cái này tôi giữ nhé."],[3429,3625,"Không thể để cậu cầm nữa đâu."],[3829,4104,"Tôi hứa sẽ không làm cậu bị thương nữa."],[4154,4204,"Tôi nghĩ người nên nói câu đó"],[4204,4329,"phải là tôi mới đúng."],[4404,4454,"Hả?"],[4566,4641,"Cậu đâu có làm tôi đau."],[4754,4866,"Thế còn bốn năm trước thì sao?"],[5204,5329,"Reese, tôi biết tôi đã nói"],[5329,5441,"chỉ muốn làm bạn,"],[5441,5504,"nhưng tôi..."],[5579,5650,"nhưng tôi không muốn"],[5650,5729,"chỉ dừng lại ở bạn bè."],[5766,5829,"Cậu ấy đang nói"],[5829,5987,"không chỉ muốn làm bạn sao?"],[6525,6629,"Này Reese, tôi biết..."],[7062,7254,"Tôi có làm phiền hai người không?"]],"43":[[25,108,"Anh là ai vậy hả?"],[200,362,"Tôi đến gặp Reese."],[500,620,"Đây là Dominic."],[675,845,"Anh ấy học tài chính."],[912,1087,"Đang giúp tôi biến luận văn"],[1087,1170,"thành một dự án kinh doanh."],[1200,1408,"Và tôi có mang quà đến."],[1512,1670,"Ô, cảm ơn nhé."],[1725,1950,"Ôi, tiếc thật."],[2075,2175,"Reese ghét cà phê đen."],[2175,2300,"May cho anh, tôi thì thích."],[2487,2658,"Anh đúng kiểu mấy thằng dân tài chính"],[2658,2770,"chỉ muốn kiếm tiền nhanh"],[2770,2837,"từ bạn gái tôi nhỉ?"],[3050,3145,"Ôi Grayson!"],[3225,3295,"Làm ơn đi."],[3408,3475,"Vậy chắc anh là"],[3475,3725,"thằng vận động viên đầu óc rỗng tuếch đó à?"],[3737,3800,"Ít nhất tôi biết"],[3800,3908,"đấm người cho ra hồn."],[3908,3987,"Được rồi, được rồi."],[4150,4225,"Nghe này Grayson,"],[4225,4450,"chỉ vì cậu là ngôi sao khúc côn cầu"],[4450,4495,"không có nghĩa là"],[4495,4775,"cậu phải gây sự với mọi thằng đàn ông"],[4775,4925,"để chứng minh mình mạnh nhất."],[4962,5004,"Sao anh..."],[5004,5108,"Khoan, sao anh lại ở đây?"],[5108,5187,"Tôi tưởng chúng ta"],[5187,5312,"hẹn gặp nhau ở thư viện mà?"],[5370,5437,"Ờ thì tôi nghĩ"],[5437,5520,"chúng ta có thể đi ăn tối trước."],[5520,5637,"Có quán này"],[5637,5745,"ngay gần trong khuôn viên."],[5783,5975,"Ừ, được đó."],[5983,6045,"Ừm..."],[6200,6295,"Tôi mang theo sổ nhé."],[6295,6408,"Mình có thể xem qua ý tưởng của tôi."],[6583,6645,"Không đi đâu hết."],[6850,6908,"Anh nên dừng"],[6908,7025,"cái trò tán tỉnh bạn gái tôi đi, ông bạn."],[7062,7375,"Hay là Grayson đang ghen rồi?"]],"44":[[16,66,"Ờ..."],[162,266,"Cậu ấy chỉ đùa thôi."],[266,404,"Bọn tôi... bọn tôi không có gì với nhau."],[641,741,"Còn Dominic,"],[741,904,"anh ấy chỉ... chỉ là bạn tôi thôi."],[1087,1162,"Giống như chúng ta,"],[1291,1354,"nhớ không?"],[1379,1537,"Nghe khó tin thật đấy."],[1654,1754,"Ý tôi là, anh ta lúc nào cũng cư xử"],[1754,1875,"như ông anh trai đáng sợ của cô à?"],[1875,2012,"Hay chỉ hôm nay thôi?"],[2029,2154,"Ăn nói cho cẩn thận."],[2250,2391,"Được rồi, Grayson, dừng lại đi."],[2400,2429,"Tôi không hiểu"],[2429,2529,"sao cậu lại hành xử như vậy."],[2550,2750,"Và kể cả anh ấy có rủ tôi đi hẹn hò thì sao?"],[2766,2866,"Chuyện đó không liên quan đến cậu,"],[2866,3004,"vậy cậu quan tâm làm gì?"],[3062,3179,"Cô ấy thật sự muốn"],[3179,3262,"đi với hắn sao?"],[3304,3462,"Được rồi, tôi... tôi ra lấy xe trước."],[3462,3587,"Gặp cô ngay nhé."],[3766,3904,"Khoan, cái này là thiết kế của cô à?"],[4187,4312,"Ừ, lúc nãy tôi vừa may tay"],[4329,4475,"đính hạt xong."],[4525,4641,"Khoan, may tay á?"],[4679,4754,"Không, không, không."],[4816,4916,"Nếu muốn làm lớn,"],[4916,4979,"phải làm kiểu"],[4979,5154,"có thể sản xuất bằng máy."],[5191,5279,"Tôi sẽ cho cô xem số liệu sau."],[5279,5416,"Đừng... đừng lo chuyện đó."],[5454,5504,"Ừ"],[5704,5779,"Này Desmond."],[5879,5954,"Coi chừng!"],[6091,6250,"Phản xạ cho nhanh vào, anh bạn,"],[6250,6362,"nếu muốn bảo vệ Reese."],[6566,6675,"Tôi không muốn thấy anh bị đánh"],[6675,6800,"rồi thành não phẳng đâu."],[6891,6966,"Tôi đợi ngoài xe."],[7350,7450,"Cậu bị làm sao vậy hả?"],[7466,7500,"Tôi á?"],[7500,7537,"Chính cậu mới là người"],[7537,7625,"để mấy thằng lạ hoắc"],[7625,7729,"tự nhiên mò tới nhà mình."],[7750,7966,"Thế bốn năm qua"],[7966,8075,"cậu ở đâu?"],[8075,8216,"Sao tự dưng giờ cậu lại có quyền"],[8241,8429,"quyết định ai được vào nhà tôi?"]],"45":[[12,41,"Cậu biết không,"],[41,229,"không giống như thằng giao pizza kia,"],[287,416,"tôi biết cậu mê"],[416,516,"mấy chi tiết đính hạt thủ công"],[516,641,"từ hồi năm hai cấp ba rồi."],[691,791,"Ừ, từ khi cậu thấy"],[791,929,"tấm ảnh prom của mẹ cậu"],[929,1116,"mặc chiếc váy đính hạt đó."],[1416,1537,"Đây chính là cảm hứng đó, đúng không?"],[1616,1704,"Cậu vẫn nhớ chuyện đó à?"],[1791,1929,"Tôi biết điều này hơi khó hiểu với cậu,"],[1929,2041,"nhưng cậu là kiểu người"],[2041,2079,"rất khó để quên."],[2079,2291,"Đến cả thằng ship pizza Dominic kia,"],[2404,2479,"người mà cảm xúc"],[2479,2616,"chắc cũng do AI tạo ra,"],[2616,2700,"còn nhận ra điều đó."],[2700,2741,"Được rồi,"],[2741,3054,"cậu đang hành xử rất kỳ quặc và ghen tuông."],[3054,3166,"Tôi không hiểu chuyện gì đang xảy ra,"],[3187,3387,"nhưng sao cậu lại có quyền"],[3404,3537,"quyết định tôi được hẹn hò với ai?"],[3537,3616,"Chúng ta chỉ là bạn thôi mà."],[3616,3766,"Bạn bè đâu có nói với nhau như vậy."],[3791,3941,"Vậy nên lúc cậu gọi chúng ta là bạn"],[4025,4091,"trong khi tôi là bạn đi cùng cậu"],[4091,4200,"tới đám cưới chị gái tôi?"],[4250,4329,"Cậu ấy nghĩ mình sẽ làm lộ"],[4329,4450,"màn giả vờ hẹn hò."],[4475,4641,"Đương nhiên cậu ấy đâu có ghen thật."],[4675,4791,"Được rồi, vậy thì nghe này."],[4829,4941,"Cậu không cần lo đâu."],[4941,5066,"Ngày mai là đám cưới rồi,"],[5075,5179,"và chúng ta sẽ diễn"],[5179,5266,"một màn thật hoàn hảo."],[5266,5354,"Mọi người sẽ nghĩ"],[5354,5516,"tôi là bạn gái giả xuất sắc nhất."],[5545,5591,"Nhưng"],[5637,5766,"tôi lại muốn nó là thật."],[5841,5900,"Sẽ không ai biết"],[5900,6004,"tất cả chỉ là giả vờ"],[6004,6116,"cho đám cưới này thôi."],[6241,6387,"Và tôi sẽ giới thiệu cậu với Lana Winter."],[6625,6737,"Đi tận hưởng buổi hẹn hò thật của cậu đi,"],[6854,6929,"bạn gái giả."],[7050,7104,"Tôi sẽ làm vậy,"],[7304,7391,"bạn trai giả."],[9133,9254,"Mình biết mà, bám theo Grayson"],[9254,9341,"kiểu gì cũng có chuyện hay."],[9341,9475,"Tất cả mọi người trong đám cưới sẽ biết"],[9475,9575,"con bạn Reese"],[9575,9795,"thảm hại đến mức nào."]],"46":[[433,508,"Cậu ấy nói"],[508,658,"không chỉ muốn làm bạn sao?"],[1091,1158,"Dù đáng lẽ tôi phải"],[1158,1304,"tập trung vào Dominic,"],[1333,1495,"tôi vẫn không thể ngừng nghĩ về Grayson."],[1579,1620,"Cô vẫn còn nghĩ"],[1620,1708,"về tên vận động viên khúc côn cầu đó à?"],[1783,1908,"Tôi dễ đoán vậy sao?"],[1995,2033,"Cô biết không,"],[2033,2283,"có lẽ cô chỉ cần thứ gì đó để phân tâm thôi."],[3483,3570,"Grayson từng nói"],[3570,3783,"tôi uống vào là hậu đậu lắm,"],[3783,4116,"nên tôi nghĩ đó không phải ý hay."],[4191,4241,"Biết sao không?"],[4316,4429,"Bọn tôi kết thúc khá là kỳ cục."],[4429,4570,"Tôi chỉ muốn hỏi thăm cậu ấy"],[4570,4641,"một chút thôi."],[4733,4791,"Ý tôi là,"],[4879,4991,"nếu anh ta thật sự tốt như vậy,"],[4991,5108,"thì anh ta đã không"],[5158,5245,"chỉ nhắn tin cho cô đâu, đúng không?"],[5245,5279,"Ý tôi là,"],[5279,5504,"anh ta phải ở đây, ngồi cạnh cô rồi."],[5554,5620,"Tôi chỉ nói thôi,"],[5620,5733,"cô thật sự để một tên đầu đất như vậy"],[5733,5808,"chi phối mình"],[5808,5920,"trong khi anh ta còn không ở đây à?"],[6583,6620,"Biết sao không?"],[6620,6720,"Ừ, đúng rồi."],[6754,6804,"Ừ."],[6833,6883,"Ý tôi là,"],[6904,7141,"Grayson có thể làm chủ trên sân băng,"],[7141,7483,"nhưng cậu ấy không thể phá cuộc vui của tôi."],[7520,7691,"Nào, uống đi."],[7691,7745,"Uống!"]],"47":[[1866,1991,"Người duy nhất tôi từng cần"],[1991,2116,"cổ vũ mình là Reese."],[2195,2370,"Cô ấy luôn ở bên tôi ngay từ đầu."],[2441,2587,"Tôi không thể mất cô ấy thêm lần nữa."],[3162,3291,"Cô ấy phải biết cảm xúc của tôi"],[3291,3441,"trước khi mọi thứ thật sự quá muộn."],[3966,4154,"Dominic, tôi muốn về nhà."],[4250,4341,"Không, không, Reese."],[4416,4491,"Cô phải làm cho tôi"],[4491,4579,"một việc trước đã."],[5537,5612,"Anh đang làm gì vậy?"],[5837,5979,"Đừng có như vậy chứ, Reese."],[5991,6125,"Ý tôi là, tôi đã giúp cô ở trường,"],[6204,6337,"còn đãi cô một bữa tử tế."],[6366,6412,"Cô không nghĩ"],[6412,6566,"đã đến lúc trả ơn sao?"],[6633,6779,"Không, dừng lại, dừng lại!"],[6887,6979,"Bỏ tôi ra!"]],"48":[[4,100,"Bỏ tôi ra!"],[279,425,"Anh... anh đúng là biến thái,"],[425,529,"và thật ghê tởm nữa."],[579,675,"Đồ khốn!"],[716,879,"Tôi giúp cô"],[887,979,"chỉ vì cá cược"],[991,1116,"xem có thể dụ được con nhỏ"],[1116,1229,"chưa từng có bạn trai"],[1254,1425,"tự dâng mình lên không thôi."],[1425,1537,"Vậy nên đừng chống cự nữa."],[1537,1616,"Chúng ta đều biết"],[1641,1804,"cô cũng chẳng có gì đặc biệt để mất đâu."],[2033,2137,"Là mình đã đẩy cô ấy"],[2137,2308,"vào vòng tay thằng khác sao?"],[2337,2462,"Có ai không, cứu với!"],[2587,2641,"Cô nghĩ"],[2641,2812,"có ai quan tâm đến cô không, Reese?"],[2841,3025,"Grayson không cần cô."],[3041,3212,"Chẳng ai cần cô cả."],[3429,3529,"Ít ra theo cách này,"],[3541,3737,"cái thân cô cũng còn có chút giá trị."],[4091,4141,"Không!"],[4191,4279,"Không!"],[4591,4704,"Tôi đến đây, Reese!"],[4729,4845,"Đừng nói là tôi đến quá muộn."],[5041,5179,"Giờ tôi đã nói thật rồi,"],[5237,5304,"đến lượt cô"],[5304,5391,"ngoan ngoãn nghe lời đi."],[5641,5787,"Bỏ tay ra khỏi bạn gái tôi."]],"49":[[41,208,"Bỏ tay ra khỏi cô ấy!"],[408,575,"Cậu ấy lại cứu mình nữa sao?"],[962,1004,"Dừng lại!"],[1029,1104,"Tôi xin lỗi!"],[1120,1208,"Tôi xin lỗi!"],[1379,1629,"Nếu mày còn dám nói chuyện với cô ấy,"],[1645,1708,"chỉ cần mày"],[1708,1895,"có ý định liên lạc với Reese thêm lần nữa,"],[2004,2158,"tao sẽ giết mày!"],[3258,3404,"Mày thích trói lắm đúng không?"],[3683,3729,"Đây."],[3970,4016,"Không, không."],[4016,4116,"Mày không thể bỏ tao lại đây!"],[4129,4216,"Mày không thể bỏ tao!"],[4241,4345,"Yên tâm, tao không bỏ đâu."],[4404,4541,"Cảnh sát sẽ tìm thấy mày vào sáng mai."]],"50":[[33,208,"Không, không."],[208,266,"Làm ơn!"],[270,308,"Không!"],[308,383,"Không sao đâu, Reese."],[429,475,"Ổn rồi."],[541,616,"Tôi ở đây rồi, Reese."],[666,716,"Tôi ở đây."],[2441,2579,"Tôi đúng là đồ ngốc."],[2754,2933,"Không hiểu sao tôi lại không nghe lời cậu."],[3191,3316,"Đừng bận tâm đến thằng khốn đó nữa."],[3383,3520,"Cậu xứng đáng có cả thế giới này."],[4191,4395,"Tôi không cần cả thế giới, Gray."],[4629,4729,"Tôi chỉ cần cậu thôi."]],"51":[[37,87,"Khoan đã."],[95,145,"Khoan đã."],[270,366,"Không, Dominic đã bỏ thuốc cậu rồi."],[366,445,"Chúng ta không thể làm vậy."],[458,554,"Cậu không tỉnh táo."],[654,704,"Không, không, không."],[704,783,"Đầu óc tôi"],[795,970,"rất tỉnh táo,"],[979,1033,"được chứ?"],[1195,1420,"Tôi... tôi muốn,"],[1420,1520,"- tôi muốn chuyện này. - Không."],[1545,1654,"Tôi sẽ không để cậu làm điều"],[1654,1758,"sẽ khiến cậu hối hận."],[2008,2079,"Ý cậu là điều"],[2079,2204,"mà cậu sẽ hối hận sao?"],[2266,2408,"Giống như lần trước cậu hôn tôi."],[2433,2570,"Chính cậu là người đẩy tôi ra."],[2645,2779,"Vì tôi đang"],[2779,2895,"yêu cậu lần nữa."],[3179,3229,"Cái gì?"],[3233,3404,"Cậu biết không, tôi đúng là đồ ngốc"],[3404,3566,"khi hết lần này đến lần khác lao về phía cậu"],[3566,3783,"trong khi cậu thậm chí còn không..."],[3783,3966,"Kit, điều duy nhất tôi hối hận"],[4079,4120,"là đã nói với cậu"],[4120,4245,"rằng nụ hôn đó là sai lầm."],[4383,4458,"Vì sự thật là"],[4458,4533,"tôi đã muốn hôn cậu"],[4533,4608,"từ hồi cấp ba."],[4716,4933,"Từ hồi cấp ba?"],[5016,5120,"Kit, tôi đang muốn nói với cậu"],[5120,5283,"là tôi yêu cậu, thật sự."],[5379,5466,"Tôi luôn yêu cậu,"],[5545,5629,"và sẽ luôn như vậy."],[5791,5916,"Cậu yêu tôi sao?"],[6616,6708,"Tôi thề."]],"52":[[3645,3775,"Em cần anh, Gray."],[3912,3987,"Làm ơn."],[4175,4225,"Đừng cầu xin như vậy."],[4225,4362,"Em không biết điều đó khiến anh thế nào đâu."],[5162,5225,"Gray."],[5783,5825,"Anh có cảm giác"],[5825,5970,"như đã chờ khoảnh khắc này cả trăm năm rồi,"],[5970,6020,"Kit."],[6070,6133,"Em cũng vậy."],[7033,7137,"Đêm nay, chúng ta sẽ không rời đi"],[7137,7233,"cho đến khi khám phá"],[7233,7358,"từng chút một của nhau."]],"53":[[775,829,"Gray?"],[937,1050,"Có thư đặc biệt nè."],[1358,1525,"Quyết định vào trường thời trang của mình."],[1616,1741,"Cuối cùng mình cũng biết"],[1741,1833,"có thể thực hiện giấc mơ của mẹ không."],[2637,2704,"Em đậu rồi."],[2825,2975,"Trời ơi, em đậu rồi!"],[3200,3291,"Ôi trời ơi."],[3291,3387,"Anh biết mà, Kit."],[3425,3466,"Anh biết mà."],[3466,3554,"Em xứng đáng với điều này."],[3566,3712,"Em xứng đáng hơn bất kỳ ai."],[3787,3866,"Em không thể tin được"],[3866,3979,"cả hai giấc mơ của mình"],[3991,4125,"cuối cùng cũng thành sự thật."],[4154,4316,"Anh và London."],[4550,4620,"Gray"],[4679,4783,"và London?"],[4820,4983,"Mình... mình không thể có cả hai."],[5300,5350,"Chết tiệt."],[5479,5529,"Này."],[5666,5716,"Này."],[5841,5929,"Đây là tin mừng mà."],[6012,6125,"Chúng ta nên ăn mừng chứ."],[6212,6329,"Nhưng rồi phải làm sao đây?"],[6425,6541,"Chúng ta sẽ tìm ra cách."],[6562,6654,"Không công bằng chút nào."],[6666,6875,"Cuối cùng chúng ta cũng đến được với nhau,"],[6954,7141,"mà giờ lại cách nhau nửa vòng trái đất."],[7304,7462,"Kit, anh đã chờ bốn năm rồi."],[7525,7600,"Anh sẽ chờ tiếp."],[7616,7800,"Không, em không muốn anh phải chờ thêm nữa."],[7841,7950,"Vậy thì sao, Kit?"],[7979,8037,"Ý em là"],[8037,8175,"đây là dấu chấm hết cho chúng ta sao?"]],"54":[[8,112,"Có lẽ chúng ta vốn chỉ nên"],[112,212,"ở bên nhau"],[350,420,"trong một đêm thôi."],[475,625,"Vậy em bỏ luôn chuyện của chúng ta sao?"],[625,787,"Không, em không muốn thế."],[875,1025,"Em... em... em chỉ,"],[1025,1162,"em chỉ không biết phải làm gì."],[1233,1345,"Ý em là, dù sao đi nữa,"],[1345,1575,"chỉ một ngày ở bên anh cũng giống như"],[1725,1825,"điều hoàn hảo nhất"],[1825,1958,"mà em từng có thể mơ tới."],[2100,2312,"Dù cho nó chỉ kéo dài vài tiếng."],[4170,4262,"Em biết là chúng ta vốn"],[4262,4387,"sẽ phải chia tay sau đám cưới."],[4475,4575,"Nếu như ta chỉ"],[4737,4837,"thật sự ở bên nhau"],[5000,5062,"cho đến lúc đó thì sao?"],[5783,5862,"Reese Foster,"],[5958,6075,"em có đồng ý làm bạn gái anh"],[6175,6262,"chỉ trong một ngày không?"],[6487,6550,"Em đồng ý."],[6683,6775,"Grayson, nếu..."],[6875,7012,"nếu chúng ta chỉ có một ngày thì"],[7162,7312,"chúng ta sẽ biến nó thành cả một đời."]],"55":[[1408,1620,"Mẹ thấy Reese lại đến muộn rồi."],[1695,1841,"Trước là tiệc mừng cô dâu,"],[1841,1958,"giờ đến bữa tối tổng duyệt nữa."],[1991,2179,"Chúng ta có nên dời cả đám cưới"],[2179,2316,"chỉ để chiều theo chuyện"],[2316,2408,"nó không biết xem đồng hồ không?"],[2454,2566,"Nghe này, mẹ buồn cười thật đấy."],[2595,2658,"Đến bao giờ mẹ mới"],[2658,2754,"ngừng lạnh nhạt với cô ấy"],[2754,2891,"và chấp nhận sự thật là bọn con ở bên nhau?"],[2908,3029,"Cô ấy đang trên đường tới, bỏ qua đi."],[3158,3220,"Mẹ thề,"],[3283,3470,"nếu cô ta lại xuất hiện trong"],[3470,3641,"bộ đồ tự may lôi thôi khác thì..."]],"56":[[8,87,"Xin lỗi mẹ."],[162,325,"Bạn đời của con tới rồi."],[691,775,"Anh cần phải thôi"],[775,900,"nhìn em kiểu đó đi, Gray."],[933,1033,"Kiểu gì cơ?"],[1037,1183,"Như thể anh đang mắc kẹt giữa sa mạc"],[1183,1345,"và chẳng có giọt nước nào"],[1408,1637,"trong hàng dặm, hàng dặm, hàng dặm liền."],[1970,2087,"Ý em là anh đang khát khao à?"],[3312,3387,"Thế này thì khá hơn chưa?"],[3437,3637,"Chẳng khá hơn nổi một chút nào."]],"57":[[16,116,"Em đẹp đến nghẹt thở."],[200,275,"Thật điên rồ."],[579,700,"Nhưng anh có một tin không vui."],[729,862,"Lana Winter nói là cô ấy không tới được."],[862,975,"Cô ấy hủy vào phút chót."],[1154,1379,"Cô ấy không... cô ấy hoàn toàn không đến sao?"],[1416,1466,"Ừ."],[1550,1629,"Anh xin lỗi."],[1629,1750,"Anh biết em chỉ đồng ý chuyện này"],[1750,1804,"vì anh nói với em"],[1804,1937,"là sẽ giới thiệu em với cô ấy, nhưng..."],[1966,2087,"Anh thề anh sẽ bù đắp cho em,"],[2087,2141,"được không?"],[2179,2275,"Sao em lại cười?"],[2275,2366,"Em có đang nghe anh nói không,"],[2416,2466,"Reese?"],[2566,2666,"Gray, em không quan tâm."],[2829,2891,"Ý em là, ừ,"],[2891,2979,"được gặp cô ấy"],[2979,3062,"thì hẳn là rất tuyệt,"],[3191,3316,"nhưng em làm chuyện này là vì anh."],[3841,4000,"Mọi người làm ơn chú ý một chút được không?"],[4312,4487,"Tôi thực sự không muốn"],[4487,4729,"phá hỏng không khí của một buổi lễ thế này."],[4816,5104,"Nhưng tôi có một tin đáng lo ngại"],[5104,5216,"cần chia sẻ với tất cả mọi người."],[5291,5391,"Tôi có bằng chứng"],[5429,5666,"cho thấy mối quan hệ giữa Reese và Grayson"],[5700,5791,"là giả."]],"58":[[500,587,"Tôi sẽ là"],[587,725,"cô bạn gái giả tuyệt nhất mà cậu từng có,"],[725,900,"đến mức gia đình cậu sẽ không bao giờ nhận ra"],[900,1050,"chúng ta chỉ đang đóng kịch vì đám cưới."],[1079,1283,"Và tôi sẽ giới thiệu cậu với Lana Winter."],[1387,1500,"Như mọi người vừa nghe,"],[1537,1666,"thì Reese thực chất chẳng hề quan tâm"],[1666,1741,"đến Grayson."],[1766,1929,"Cô ta chỉ đang lợi dụng anh ấy"],[1929,2066,"để tiếp cận Lana Winter."],[2116,2237,"Và tôi thực sự rất ghét"],[2237,2404,"mọi người phải biết sự thật theo cách này,"],[2462,2650,"nhưng tôi không thể ngồi im"],[2650,2854,"nhìn Reese lừa dối tất cả những người"],[2854,3012,"mà Grayson thật lòng quan tâm,"],[3091,3166,"là gia đình của anh ấy."],[3204,3312,"Grayson, chuyện này có đúng không?"],[3341,3550,"Reese đã bắt con nói dối chúng ta sao?"],[3591,3954,"Vậy Grayson chưa từng thật lòng thích Reese?"],[3975,4054,"Dĩ nhiên là không."],[4087,4225,"Một ngôi sao khúc côn cầu thì"],[4225,4329,"việc gì phải để ý đến một kẻ vô danh?"],[4387,4487,"Kịch hạ màn rồi."],[4541,4654,"Vậy sao cô không rời đi đi,"],[4654,4712,"trước khi tiếp tục"],[4712,4841,"làm mình bẽ mặt thêm nữa,"],[4887,5029,"hả cô bạn Reese."],[5066,5229,"Reese mãi mãi là bạn thôi!"],[5254,5404,"Reese mãi mãi là bạn thôi!"],[5425,5575,"Reese mãi mãi là bạn thôi!"],[5604,5750,"Reese mãi mãi là bạn thôi!"],[5779,5925,"Reese mãi mãi là bạn thôi!"],[5950,6087,"Reese mãi mãi là bạn thôi!"],[6366,6525,"Để tôi nói rõ chuyện này cho mọi người."],[6525,6616,"Tình cảm của tôi dành cho Kit"],[6616,6825,"từ trước đến nay đều là thật."],[6854,7091,"Thực tế là tôi mê cô gái này"],[7091,7154,"đến phát điên,"],[7154,7229,"đến mức mà tôi đã giữ lại thứ này"],[7229,7329,"từ đêm prom cuối cấp của mình."],[8250,8354,"Sau bốn năm rồi,"],[8479,8637,"anh vẫn còn giữ nó sao?"]],"59":[[54,116,"Grayson,"],[154,229,"anh không cần phải tiếp tục"],[270,366,"che chở cho cô ta đâu."],[366,500,"Ý em là, ai cũng biết"],[500,712,"anh chỉ xem cô ta như em gái thôi."],[779,887,"Cô sai rồi, Piper."],[937,1016,"Bốn năm qua,"],[1016,1116,"tôi đã tuyệt vọng"],[1116,1254,"chỉ để giữ lấy dù là chút ít về Reese."],[1325,1429,"Và giờ khi tôi đã thật sự có cô ấy rồi,"],[1429,1529,"tôi sẽ không buông tay nữa."],[2154,2237,"Tôi thề."],[3541,3604,"Tám năm trước,"],[3604,3775,"tôi gặp người bạn thân của mình ở sân băng."],[3804,3904,"Cô ấy, ờ..."],[3904,4004,"đã cứu thanh sô-cô-la yêu thích của tôi"],[4004,4158,"khỏi cái máy bán hàng"],[4208,4291,"độc ác đó."],[4341,4416,"Nhưng bốn năm trước,"],[4416,4554,"tôi đã phạm sai lầm lớn nhất đời mình"],[4554,4654,"khi để cô ấy bước ra khỏi cuộc đời tôi."],[4691,4800,"Tôi sẽ không buông tay nữa."],[4987,5029,"Kit,"],[5154,5312,"hãy xóa tan mọi nghi ngờ trong em."],[5425,5575,"Em đã và sẽ luôn là"],[5750,5816,"cô gái duy nhất."],[6112,6262,"Em yêu anh, Gray."],[7000,7066,"Không!"],[7312,7404,"Lẽ ra tôi đã phải tiêu hủy"],[7404,7579,"mảnh vải rẻ tiền đó từ nhiều năm trước"],[7579,7679,"khi còn có cơ hội."],[7691,7791,"Xem ra thì chẳng bao giờ là quá muộn"],[7791,7929,"để đi đổ rác."]],"60":[[408,558,"Amy, bác đang làm cái gì vậy?"],[587,662,"Bảo vệ!"],[1075,1200,"Cháu chỉ muốn giúp thôi mà."],[1233,1350,"Vậy mà cuối cùng cô chỉ làm"],[1350,1483,"chính mình bẽ mặt,"],[1500,1575,"gia đình tôi,"],[1587,1712,"và chứng tỏ quá rõ ràng"],[1712,1950,"rằng cô không xứng đáng với con trai tôi."],[2025,2150,"Tôi không thể tin là ngày trước"],[2150,2233,"tôi đã để thằng bé dẫn cô đi prom"],[2233,2325,"năm đó."],[2725,2912,"Anh đã không mời Piper"],[2912,3012,"đi prom cùng anh sao?"],[3083,3237,"Em không nghe anh nói gì nãy giờ à, Kit?"],[3287,3450,"Em vẫn luôn là, và mãi mãi vẫn sẽ là"],[3450,3537,"người duy nhất."],[3900,3950,"Người phụ nữ này"],[3950,4087,"đang gây náo loạn nơi công cộng"],[4087,4245,"tại bữa tiệc tổng duyệt của con gái tôi."],[4287,4383,"Tôi muốn cô ta rời khỏi đây."],[4520,4570,"Buông tôi ra!"],[4570,4725,"Đừng có chạm vào tôi!"],[4775,4962,"Được rồi, chuyện đó ngầu thật đấy, mẹ."],[5112,5300,"Cảm ơn bác, bác Hayes."],[5300,5358,"Ý cháu là..."],[5487,5620,"cháu thậm chí còn không biết phải nói gì nữa."],[5637,5687,"Bác thì biết."],[5750,5825,"Cháu đã nói dối."]],"61":[[8,104,"Cháu đã nói dối."],[158,270,"Và cháu còn giúp Grayson"],[270,379,"nói dối cả gia đình nó."],[379,433,"Và"],[633,745,"chính cháu là người duy nhất"],[745,1045,"khiến con trai bác thực sự hạnh phúc."],[1133,1270,"Từ khi cháu quay trở lại,"],[1320,1570,"Grayson lại mỉm cười trên sân băng."],[1683,1908,"Bác chưa bao giờ hoàn toàn ủng hộ,"],[2054,2204,"nhưng bác cũng biết hai đứa"],[2291,2404,"có một sợi dây gắn kết đặc biệt."],[2858,2908,"Cảm ơn bác,"],[3033,3083,"Amy."],[3179,3245,"Đừng được đằng chân lân đằng đầu."],[3745,3858,"Nhà Hayes ôm nhau nha?"],[5804,5887,"Đi theo anh."]],"62":[[41,116,"Được rồi."],[229,350,"Từ khi còn nhỏ,"],[350,475,"chúng ta lúc nào cũng ăn mừng"],[475,591,"những chiến thắng của anh trên sân băng."],[1375,1429,"Nhưng giờ anh nghĩ"],[1429,1562,"đã đến lúc ăn mừng cho em rồi."],[1766,1941,"Một cái cho mỗi ước mơ"],[1962,2104,"đã thành hiện thực trong tuần này."],[2191,2337,"Được nhận vào cao học,"],[2391,2504,"và cho anh một cơ hội."],[2729,2866,"Cảm ơn anh, Gray."],[3466,3579,"Em không muốn chuyện này kết thúc."],[3629,3729,"Kit, anh đã..."],[3729,3791,"Biết gì không?"],[3866,4004,"Chúng ta không còn nhiều thời gian nữa."],[4104,4154,"Vậy nên,"],[4337,4391,"hãy cứ"],[4391,4516,"tận hưởng khoảng thời gian chúng ta có."]],"63":[[1387,1575,"Em trông thật đẹp."],[1758,1900,"Anh chắc là chiếc váy này ổn chứ?"],[1900,2037,"Em mua gấp vào phút chót."],[2037,2112,"Em không chắc lắm."],[2158,2212,"Reese, anh khá chắc là"],[2212,2325,"dù em có mặc một cái túi rác"],[2325,2437,"thì trông em vẫn xinh đẹp thôi"],[2570,2720,"Ai đã nói với anh về luận án của em?"],[2983,3037,"Sẵn sàng chưa?"],[3108,3175,"Em muốn nói với anh"],[3175,3262,"một chuyện trước đã."],[3400,3470,"Em sẽ không..."],[3520,3633,"em sẽ không sang London nữa."],[3758,3850,"Em muốn ở lại đây."],[3912,4008,"Em đang nói gì vậy?"],[4225,4362,"Reese, đó là ước mơ của mẹ em,"],[4362,4450,"và cũng là của em mà."],[4587,4658,"Em biết."],[4837,4950,"Nhưng ước mơ có thể thay đổi."],[5120,5233,"Và giờ anh chính là ước mơ của em."],[5400,5475,"Và em đã biết"],[5475,5595,"cuộc sống sẽ ra sao nếu không có anh."],[5758,5862,"Em không muốn phải trải qua điều đó"],[5862,5925,"thêm một lần nào nữa."],[6037,6095,"Ờ thì..."],[6200,6295,"Anh định sẽ đợi"],[6295,6487,"đến sau buổi lễ mới nói chuyện này,"],[6537,6595,"nhưng..."],[6812,6925,"Em sẽ sang London, Kit."],[7025,7170,"Anh ấy không muốn mình ở bên sao?"],[7216,7345,"Anh ấy đang đẩy mình đi à?"]],"64":[[8,95,"Em là nhà thiết kế thời trang"],[95,179,"tài năng nhất"],[179,258,"mà anh từng gặp."],[283,433,"Em xứng đáng đi học từ những người giỏi nhất"],[520,595,"ở London."],[700,829,"Không sao đâu, Reese."],[829,995,"Hôm nay chúng ta đã nói là sẽ chia tay mà."],[995,1225,"Anh ấy chỉ là đang giữ lời hứa thôi."],[1241,1283,"Ừ."],[1429,1604,"Ừ, chắc là em nên sang London thật."],[1670,1758,"Và em biết không?"],[1929,2008,"Anh sẽ đi cùng em."],[2391,2458,"Chờ đã, cái gì cơ?"],[2483,2645,"Thế còn, thế còn đội Hawks thì sao?"],[2645,2783,"Thế còn sự nghiệp của anh?"],[2854,2995,"À, anh đã nói chuyện với một học viện hockey"],[2995,3033,"bên đó rồi,"],[3033,3095,"và họ sẽ để anh"],[3095,3216,"huấn luyện những trẻ có hoàn cảnh khó khăn."],[3283,3370,"Những đứa trẻ mang giấc mơ lớn,"],[3370,3445,"nhưng không có ai"],[3445,3520,"ở bên cạnh chúng."],[3895,3966,"Giống như em ngày trước."],[4141,4229,"Anh đã nói chuyện với huấn luyện viên,"],[4229,4345,"và ông ấy bảo sẽ giữ lại"],[4345,4433,"vị trí đội trưởng cho anh."],[4483,4620,"Và sau khi em tốt nghiệp trong hai năm nữa,"],[4620,4745,"nó vẫn sẽ ở ngay đó,"],[4745,4820,"chờ anh trở về"],[4895,5020,"như thể anh chưa từng rời đi."],[5091,5191,"Anh nói thật chứ?"],[5291,5366,"Về chuyện của em à?"],[5583,5725,"Mãi mãi và luôn luôn."],[5970,6083,"Chúng ta sẽ đến London."],[6145,6254,"Chúng ta sẽ đến London."],[6254,6383,"Chúng ta sẽ đến London."],[6895,6995,"Được rồi."],[7041,7266,"Giờ thì chuyện đó đã xong xuôi,"],[7308,7445,"anh cần em giúp thêm một việc nữa."],[8141,8245,"Em có thể giúp anh đeo cái này được không?"],[8595,8679,"Tất nhiên rồi."],[10933,11058,"Hẹn gặp anh ở lễ đường nhé?"],[11158,11279,"Và cả mỗi ngày sau đó nữa."]]}