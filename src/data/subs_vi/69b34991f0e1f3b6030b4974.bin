{"1":[[62,166,"Thưa quý vị."],[187,304,"Đây là trận chung kết"],[304,429,"đêm quan trọng nhất của mùa giải"],[441,566,"trường trung học Maple."],[600,750,"Mọi ánh mắt đều đổ dồn vào ngôi sao"],[750,850,"Grayson Hayes."],[962,1075,"Đây chính là thời khắc quyết định."],[1075,1166,"Chỉ còn năm giây"],[1166,1387,"để trường Maple phá vỡ thế cân bằng của trận."],[1404,1554,"Liệu đội trưởng huyền thoại của chúng ta,"],[1562,1691,"Grayson Hayes có làm được không?"],[1704,1779,"Cố lên, Gray."],[1875,1979,"Cố lên, cậu làm được mà."],[2037,2116,"Năm!"],[2141,2250,"Bốn!"],[2266,2366,"Ba!"],[2437,2516,"Hai!"],[2625,2704,"Một!"],[3416,3516,"Grayson Hayes,"],[3554,3650,"bạn thân nhất của tôi"],[3650,3812,"và là người luôn ở bên tôi"],[3812,3954,"từ ngày đầu bước vào cấp ba."],[4004,4166,"Một vận động viên nổi tiếng"],[4166,4404,"và đứa mọt sách như tô chẳng hợp chút nào."],[4450,4612,"Nhưng cậu ấy đã thấy tôi những lúc tốt nhất"],[4716,4841,"và cả lúc tệ nhất."],[5837,5987,"Chính những lúc như vậy"],[5987,6170,"khiến tôi chắc chắn một điều,"],[6308,6391,"tôi yêu cậu ấy."],[6508,6666,"Tôi đã giữ tình cảm này suốt nhiều năm."],[6666,6845,"Và tối nay, trong buổi prom,"],[6845,7016,"tôi sẽ nói hết lòng mình với cậu ấy."],[7241,7291,"Cái gì cơ?"],[7441,7537,"Trời ơi Reese,"],[7541,7704,"tôi không ngờ cậu lại ám ảnh"],[7704,7837,"bạn trai tôi đến vậy."],[7904,8029,"Bạn… bạn trai cậu á?"],[8029,8066,"Cái gì?"],[8079,8262,"Không, tôi… tôi ăn trưa với Grayson"],[8262,8316,"mỗi ngày"],[8316,8379,"mà cậu ấy chưa từng"],[8379,8491,"nhắc đến cậu bao giờ."],[8537,8687,"Grayson là đội trưởng đội khúc côn cầu,"],[8712,8829,"còn Piper là đội cổ vũ."],[8829,8900,"Rõ ràng"],[8900,9004,"họ sinh ra là dành cho nhau."],[9029,9166,"Cậu đừng mơ có cơ hội"],[9166,9491,"với cái bộ đồ tự may xấu xí này."],[9741,9962,"Ôi trời, cô bạn Reese"],[9962,10179,"còn tự làm cà vạt cho Grayson cơ à?"],[10229,10316,"Cậu thật sự nghĩ"],[10316,10416,"cậu ấy sẽ mời cậu đi hẹn hò"],[10416,10541,"chỉ vì thứ này sao?"],[10741,10779,"Này,"],[10779,10954,"cậu chẳng hiểu gì về cậu ấy cả."],[10995,11291,"Tôi chỉ biết là cậu ấy không chọn cậu."],[11366,11554,"Cậu có biết vì sao"],[11554,11654,"Grayson vẫn làm bạn với cậu không?"],[11750,11829,"Vì chỉ cần nghĩ đến"],[11829,11941,"chuyện ngủ với cậu"],[11979,12150,"cũng đủ khiến cậu ấy thấy ghê tởm rồi."],[12291,12604,"Như cái cà vạt này làm tôi phát tởm vậy."],[13037,13091,"Không."],[13229,13291,"Không."]],"2":[[0,54,"Không!"],[87,179,"Piper, cậu ấy đến kìa!"],[1012,1216,"Tận hưởng sự chú ý đi khi còn có thể."],[1241,1387,"Tối nay tôi sẽ đi prom với Grayson"],[1412,1679,"và tôi sẽ hôn cậu ấy."],[2500,2591,"Ba thanh KitKat"],[2604,2729,"cho ba bàn thắng hôm nay của cậu."],[2741,2891,"KitKat của Kit cho nè."],[3516,3641,"Grayson gọi tôi là \"Kit\""],[3641,3741,"từ ngày đầu gặp nhau,"],[3837,3941,"khi cậu ấy nói KitKat"],[3941,4104,"ngon hơn Reese nhiều."],[4554,4612,"Và mỗi lần nghe vậy"],[4612,4741,"tim tôi lại loạn nhịp."],[4816,5016,"Vừa ghét lại vừa thích."],[5041,5154,"Vậy buổi prom tối nay..."],[5216,5404,"Trông cậu ấy có vẻ hồi hộp."],[5466,5541,"Trời ơi,"],[5575,5712,"liệu cậu ấy có mời mình đi cùng không?"],[5766,5879,"Cậu vẫn đi cùng tôi chứ?"],[6000,6204,"Ừ, ừ, tất nhiên rồi,"],[6204,6350,"bạn bè thì đi cùng nhau mà."],[6487,6541,"Ừ."],[6625,6679,"Mà này,"],[6691,6745,"ừm..."],[6954,7075,"Để cảm ơn cậu đã cho tôi đi nhờ,"],[7187,7379,"tôi làm cái này cho cậu, hợp với bộ đồ."],[7391,7541,"Ôi trời, không thể tin nổi."],[7612,7716,"Hàng thiết kế riêng từ Kit luôn à!"],[7766,7862,"Cậu còn nhớ cả"],[7862,7941,"cây gậy khúc côn cầu nữa chứ."],[8100,8179,"Để tôi đeo thử."],[9429,9500,"Đừng lo."],[9616,9691,"Tôi sẽ \"tính tiền\" cậu sau."],[9754,9854,"Hoàn hảo lắm, Kit."],[9950,10016,"Tôi thích lắm."],[10112,10216,"Mình muốn hôn cậu ấy."],[10266,10429,"Và cách cậu ấy nhìn mình,"],[10429,10566,"cảm giác như cậu ấy cũng muốn vậy."],[10937,11054,"Grayson, chụp ảnh đội kìa!"],[11150,11216,"Tôi phải đi đây."],[11254,11320,"Ừm."],[11366,11479,"Nhưng tối nay nhé, Kit,"],[11575,11691,"sẽ là một đêm không thể quên."],[11887,11966,"Tôi hứa đấy."],[12366,12504,"Tối nay mình sẽ nói với Grayson"],[12504,12641,"rằng cậu ấy không chỉ là bạn."],[12679,12779,"Cậu ấy là tất cả."],[12816,12941,"Và rồi có lẽ mình sẽ có được"],[12941,13100,"nụ hôn đầu hoàn hảo ở buổi prom"],[13100,13237,"giống như mình luôn mơ."],[13612,13754,"Cuối cùng cũng đến đêm prom"],[13791,13941,"và mình sẽ nói với bạn thân của mình,"],[13941,14054,"chàng trai trong mơ của mình,"],[14054,14166,"rằng mình yêu cậu ấy."],[14479,14675,"Được rồi, thêm một tấm nữa thôi con."],[14679,14741,"Được rồi."],[14779,14891,"Ước gì mẹ ở đây,"],[14962,15041,"nhưng không sao."],[15091,15191,"Tất cả những gì mẹ dạy con"],[15191,15266,"về may vá"],[15266,15379,"đều nằm trong chiếc váy này."],[15437,15550,"Mẹ đang ở bên con."],[16041,16129,"Này Gray,"],[16129,16237,"tôi chuẩn bị xong sớm"],[16237,16391,"nên ghé tìm cậu."],[17204,17329,"Không thể nào."],[17375,17604,"Grayson đang dẫn đứa bắt nạt mình đi prom?"]],"3":[[791,950,"Này, xin lỗi nhé, tôi sẽ đến trễ một chút."],[1025,1091,"Đúng rồi,"],[1166,1329,"bạn thân nhất của tôi, người tôi thích"],[1329,1504,"lại đi prom với cô gái khác."],[1629,1704,"Không sao đâu."],[1804,1862,"Cậu không cần"],[1862,1962,"đến đón tôi nữa."],[1962,2091,"Bạn đi cùng tôi sẽ chở tôi."],[2112,2262,"Khoan đã, gì cơ, cậu có bạn đi cùng á?"],[2300,2341,"Gì cơ?"],[2879,2966,"Cứ làm cho xong chuyện đi."],[2966,3029,"Grayson,"],[3066,3216,"mẹ nuôi con thành một quý ông."],[3262,3387,"Chuyện Piper bị trật chân"],[3387,3512,"không phải lỗi của con bé."],[3529,3762,"Với lại, nó là một cô gái ngoan"],[3762,3941,"lại xuất thân gia đình tử tế."],[3979,4141,"Nó là bạn prom hoàn hảo."],[4262,4375,"Con chỉ chở cô ta"],[4375,4500,"vì mẹ nhờ thôi."],[4504,4579,"Đừng ép con."],[4754,4916,"Tôi có người đang đợi rồi."],[4954,5050,"Cô ấy mới là người duy nhất"],[5050,5150,"tôi muốn ở bên."],[5412,5591,"Để xem nhé, Grayson Hayes."],[5875,5975,"Sau đêm nay,"],[5991,6075,"cậu sẽ là của tôi."],[6766,7116,"Cảm ơn vì tối nay đã cứu tôi nhé."],[7191,7300,"Bạn bè là để làm gì chứ."],[7362,7416,"Cạn ly."],[7950,8004,"Cậu ổn chứ?"],[9495,9595,"- Cậu ấy thật sự đi cùng - Cậu ấy thật sự đi cùng"],[9595,9675,"- người khác sao? - cô gái khác sao?"],[10012,10162,"Cậu ấy còn tặng cô ta hoa cài tay."],[10266,10362,"Mình đúng là ngốc."],[12166,12370,"Mình vừa va vào Grayson sao?"],[12420,12545,"Hay là mình uống nhiều quá rồi?"],[13091,13241,"Trời ơi Reese, cậu uống rượu à?"],[13441,13570,"Ánh mắt cậu ấy ấm áp quá."],[13670,13775,"Có lẽ vẫn chưa muộn,"],[13833,13929,"có lẽ cậu ấy vẫn còn quan tâm."],[13995,14095,"Nào Reese,"],[14095,14262,"nói đi trước khi mất cậu ấy mãi mãi."],[14329,14450,"Tôi đang yêu một người."],[14725,14854,"Và người đó đang ở ngay đây."]],"4":[[866,1020,"Cậu ấy đang yêu Nate à?"],[1079,1304,"Mình vừa tỏ tình với Gray rồi."],[1345,1504,"Sao cậu ấy không nói gì hết vậy?"],[1758,1891,"Xin lỗi, tôi phải đi đây."],[1962,2066,"Đợi đã, Grayson, đợi tôi!"],[2087,2145,"Gì cơ?"],[2545,2804,"Ôi, TikTok chắc là bùng nổ luôn."],[2854,2933,"Tôi phải đi đây."],[2995,3058,"Gì cơ?"],[3241,3404,"Wow, cô bạn Reese cơ đấy."],[3433,3545,"Cậu dốc hết lòng"],[3545,3608,"tỏ tình với Grayson"],[3608,3783,"mà cậu ấy lại chạy mất"],[3783,3904,"không thể nhanh hơn."],[3916,4045,"Nhưng cũng phải thôi,"],[4045,4191,"khi một đứa mồ côi bị ruồng bỏ"],[4191,4320,"quên mất vị trí của mình."],[4383,4545,"Cậu biết không, dù cậu ấy không yêu tôi,"],[4620,4795,"thì vẫn là bạn thân của tôi."],[4879,5033,"Và cậu ấy sẽ không bao giờ chọn cậu."],[5183,5245,"Thật không?"],[5329,5458,"Mở to mắt mà xem, đồ khốn."],[5583,5641,"Cái gì?"],[5666,5695,"Cái gì vậy?"],[5695,5808,"Dừng lại, dừng lại!"],[6008,6295,"Và vua và nữ hoàng prom năm nay là"],[6345,6566,"Grayson và Piper!"]],"5":[[0,62,"Buông tôi ra."],[62,125,"Dừng lại."],[162,220,"Gray!"],[1275,1425,"Đã là vua thì phải ra dáng."],[2450,3012,"Hôn đi!"],[3520,3650,"Tôi đang yêu một người."],[4095,4183,"Cậu ấy không yêu mình,"],[4183,4320,"chưa từng yêu."],[4487,4870,"Hôn đi!"],[5287,5362,"Đến rồi."],[5412,5570,"Cơn ác mộng của tôi thành sự thật."],[6270,6487,"Giờ vẫn nghĩ Grayson quan tâm đến cậu à?"],[6537,6683,"Nào, bảo cậu ấy dừng lại đi."],[6700,6750,"Đi đi."],[6950,7025,"Tôi không thể."],[7087,7270,"Cậu ấy đã cho tôi thấy cảm xúc thật của mình."],[7270,7433,"Tôi sẽ không làm kẻ ngốc nữa."],[7987,8237,"Ôi, cô bạn Reese lại xuất hiện rồi."],[8470,8775,"Cô bạn Reese!"]],"6":[[0,133,"Cô bạn Reese!"],[141,262,"Cô bạn Reese!"],[262,300,"Đợi đã!"],[300,416,"Cô bạn Reese!"],[454,504,"Kit."],[650,791,"Đừng giả vờ như cậu quan tâm."],[825,966,"Cậu vừa hôn nhau say đắm"],[966,1104,"với con nhỏ ong chúa đó ngay trước mặt tôi"],[1104,1216,"và tất cả mọi người."],[1229,1345,"Cậu bị sao vậy?"],[1404,1550,"Tôi đâu có can thiệp cậu đi prom với ai,"],[1550,1650,"thì cậu cũng đừng xen vào việc tôi hôn ai."],[1650,1712,"Chúng ta là bạn mà."],[1712,1841,"Chết tiệt, gần như là người nhà rồi."],[1841,2041,"Tôi không muốn làm người nhà của cậu!"],[2054,2179,"Vậy cậu muốn là gì?"],[2283,2341,"Không là gì cả!"],[2412,2541,"Tôi không muốn là gì hết!"],[2579,2666,"Tôi ghét cậu!"],[3025,3266,"Đêm đó, tôi mất đi người bạn thân nhất,"],[3304,3504,"người con trai duy nhất tôi từng yêu."],[3537,3600,"Và tôi đã nghĩ"],[3600,3837,"mình sẽ không bao giờ gặp lại cậu ấy nữa."],[4475,4537,"Mời thưởng thức."],[5229,5304,"Không thể nào."],[5766,5954,"Grayson và Piper sắp kết hôn sao?"]],"7":[[20,204,"Tôi từng mơ được mặc váy trắng"],[204,316,"bước vào lễ đường"],[316,395,"cùng Grayson,"],[445,620,"nhưng mơ không phải lúc nào cũng thành thật."],[729,816,"Mình phải bước tiếp thôi."],[1404,1470,"Grayson Hayes,"],[1470,1583,"ngôi sao của Maple City Hawks,"],[1583,1770,"là MVP ba mùa liên tiếp trẻ nhất"],[1770,1895,"trong lịch sử NHL."],[1916,2033,"Và anh ấy còn có chiếc nhẫn Stanley"],[2033,2104,"để chứng minh tất cả."],[2920,3058,"Đó chính là Grayson Hayes."],[3070,3254,"Cầu thủ hot nhất NHL."],[3254,3341,"Đúng là cực phẩm!"],[3341,3408,"Xin chào!"],[4208,4279,"Đã bốn năm rồi,"],[4279,4366,"nhưng chỉ cần thấy tên Reese"],[4366,4495,"là tim tôi lại..."],[4587,4645,"Thôi bỏ đi,"],[4725,4770,"cô ấy đã nói rõ"],[4770,4879,"không muốn tôi xuất hiện nữa."],[4879,5016,"Chỉ mong dù cô ấy ở đâu,"],[5016,5154,"cũng luôn được hạnh phúc."],[5691,5745,"Reese."],[6233,6329,"Tôi có thể giúp gì cho anh không?"],[6445,6533,"Xin lỗi nhé,"],[6541,6691,"tôi tưởng cô là người khác."],[6870,7016,"Mình phải quên Reese đi."],[7083,7191,"Cô ấy là quá khứ,"],[7229,7312,"không phải tương lai."],[8558,8679,"Này cô, cô ổn chứ?"],[9545,9745,"Đùa tôi à?"],[10495,10570,"Grayson?"],[10633,10820,"Khoan đã, cái quái gì thế này?"],[10820,10979,"Bạn thân cũ kiêm crush của mình ở đây?"]],"8":[[150,200,"Reese."],[229,329,"Trời ơi, xin lỗi nhé."],[329,391,"Đây, để tôi."],[445,516,"- Không, không cần đâu. - Để tôi làm cho."],[516,587,"Không sao đâu,"],[587,675,"tôi... tôi tự lo được."],[866,912,"Pilsner à?"],[912,1179,"Tôi... tôi tưởng cậu thích bia đen cơ mà?"],[1262,1337,"Cậu vẫn nhớ à?"],[1462,1541,"Muốn quên cũng không quên được,"],[1579,1766,"dù đã cố đến mức nào."],[1779,2029,"Này, chúc mừng đám cưới nhé."],[2062,2216,"Tôi thấy bài đăng của cậu rồi."],[2229,2391,"Mẹ cậu chắc vui lắm"],[2441,2575,"khi cậu cưới"],[2575,2687,"cô gái mà bà ấy rất ưng."],[2716,2775,"Gì cơ?"],[2812,2975,"Không, không, Reese,"],[2975,3041,"không phải vậy đâu."],[3062,3091,"Ý tôi là..."],[3091,3154,"Grayson!"],[3266,3341,"Anh yêu!"],[3545,3816,"Đây chẳng phải bạn Reese của anh sao?"],[3954,4037,"Lâu rồi không gặp."],[4366,4529,"Reese, cậu còn nhớ Piper chứ?"],[4787,4879,"Quên sao được."],[4916,4987,"Vậy..."],[5100,5254,"cậu có đến dự đám cưới không?"],[5291,5404,"Đúng rồi, mời mình đến dự"],[5404,5462,"đám cưới của họ"],[5462,5616,"chỉ để khoe là cô ta đã thắng,"],[5650,5829,"như thể mình còn quan tâm sau từng ấy năm."],[5862,5979,"Đủ rồi, Reese, đừng bận tâm nữa."],[6025,6166,"Tôi... tôi không nghĩ là..."],[6166,6204,"Tất nhiên 