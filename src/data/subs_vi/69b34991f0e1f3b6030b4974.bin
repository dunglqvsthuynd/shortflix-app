... vậy là chúng ta phải giả vờ"],[4687,4820,"làm chuyện đó trong xe à?"],[5433,5637,"Tống cổ con bạn Reese của anh đi chưa?"],[6208,6320,"Chúng ta đang hẹn hò, Reese."],[6395,6512,"Nghĩa là chúng ta không thể"],[6600,6787,"rời tay khỏi nhau."],[7120,7225,"Nào Grayson,"],[7250,7375,"em biết anh vẫn còn muốn em mà."],[7383,7520,"Để em cho anh một đêm đáng nhớ."],[7558,7662,"Cô ta mà phát hiện"],[7662,7775,"chúng ta đang giả vờ"],[7812,7962,"thì mình chết vì nhục mất."],[8183,8300,"Làm ơn đừng đánh tôi."],[10025,10100,"Trời ơi!"]],"12":[[37,125,"Anh thật sự ở trong đó"],[125,287,"với con bạn Reese"],[287,425,"chỉ để chọc tức em sao?"],[612,666,"Đừng lo."],[754,850,"Để tôi xử lý."],[958,1125,"Yeah, Grayson!"],[1212,1333,"Oh, đúng rồi!"],[1550,1625,"Reese."],[1745,1858,"Chuyện này chưa xong đâu,"],[1858,1925,"- Reese. - Oh yeah."],[1925,2070,"Cô sẽ không bao giờ có được Grayson đâu."],[2100,2162,"Không bao giờ!"],[2704,2850,"Tôi đã nói rồi, để tôi lo mà."],[3220,3287,"Chúng ta làm được rồi."],[3375,3458,"Vừa rồi đỉnh thật đấy."],[3662,3762,"Cậu đúng là..."]],"13":[[12,145,"Cậu lúc nào cũng hết mình"],[145,237,"vì bạn bè."],[375,525,"Có những thứ chẳng bao giờ thay đổi, nhỉ?"],[562,633,"Đương nhiên rồi."],[645,725,"Dù thời gian"],[725,837,"có trôi qua bao lâu,"],[862,1037,"Tôi vẫn mãi bị kẹt trong mối quan hệ bạn bè."],[1150,1287,"Đã bốn năm rồi."],[1333,1500,"Mọi thứ đã thay đổi"],[1575,1695,"và cậu chẳng còn hiểu tôi"],[1695,1775,"một chút nào nữa."],[2358,2545,"Vậy để tôi nói cậu nghe tôi còn nhớ gì."],[2587,2775,"Nước ép cậu thích nhất là cranberry."],[2837,2933,"Mỗi lần kiểm tra Toán"],[2933,3075,"là cậu lại đau bụng."],[3100,3187,"Và giấc mơ của cậu là"],[3187,3320,"trở thành nhà thiết kế thời trang ở London"],[3320,3462,"giống như mẹ cậu mong muốn."],[3495,3570,"Cậu thì luôn muốn"],[3570,3683,"giành được cúp Stanley."],[3683,3787,"Và giờ tôi đã có ba cái rồi."],[3825,4037,"Hồi đó cậu hay dậy sớm đi tập"],[4037,4137,"rồi tiện đường"],[4175,4270,"đón tôi"],[4270,437