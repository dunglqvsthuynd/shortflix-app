u của bầy."],[1409,1484,"Ta không hiểu sao"],[1484,1551,"Thần Mặt trăng"],[1551,1605,"lại ghép đôi bọn ta,"],[1605,1743,"nhưng ta không quan tâm, rõ chứ?"],[1743,1805,"Ta sẽ không"],[1805,1860,"chấp nhận đâu."],[1989,2072,"Vâng, thưa Alpha."],[2285,2348,"Ngài dự định"],[2348,2544,"làm gì với cô ấy?"],[2544,2631,"Cô ta sẽ biết"],[2631,2715,"ta là bạn đời của mình"],[2715,2865,"khi tròn 18 tuổi."],[2986,3086,"Và ta sẽ từ khước cô ta"],[3086,3169,"ngay lúc đó."],[3278,3328,"Chuyện đó sẽ"],[3328,3420,"hủy hoại cô ấy"],[3465,3528,"cả về tinh thần"],[3528,3611,"lẫn thể xác."],[3611,3695,"Ta không quan tâm."],[3812,3953,"Ngươi lui ra đi,"],[3953,4045,"Beta Luke."],[5046,5184,"Chết tiệt, Selene."]],"7":[[112,237,"Beta Drake,"],[237,308,"ta cần cậu chuẩn bị"],[308,354,"một món quà tử tế"],[354,471,"cho Alpha Jackson."],[529,613,"Gì cơ?"],[613,721,"Sao ngài lại làm vậy?"],[721,813,"Vì Drake à, chúng ta"],[813,1001,"phải giữ bạn bè ở gần"],[1001,1059,"và giữ kẻ thù"],[1059,1117,"ở gần hơn."],[1234,1343,"Vâng, thưa Alpha."],[1438,1676,"Còn về bữa tiệc,"],[1676,1747,"đây là những sói nữ"],[1747,1818,"chưa có bạn đời"],[1818,1910,"trong bầy,"],[1910,2018,"đích thân tôi chọn."],[2147,2289,"Xem này, nòi giống tốt"],[2289,2439,"và cực kỳ nóng bỏng."],[2577,2631,"Ta sẽ không dẫn theo"],[2631,2711,"bạn nhảy."],[2877,2961,"Nhưng thưa Alpha,"],[3103,3165,"nếu bầy Blood Moon"],[3165,3244,"phát hiện ra ngài"],[3244,3353,"chưa có bạn đời ở tuổi này,"],[3390,3511,"họ sẽ nghi ngờ ngài."],[3595,3728,"Mặc kệ họ."],[3728,3908,"Ta là Alexander Kane."],[4083,4154,"Cứ hy vọng rằng"],[4154,4216,"bạn đời của ta là một trong"],[4216,4333,"số khách dự tiệc đi, được chứ?"]],"8":[[2690,2890,"Chúc mừng sinh nhật mình."],[2990,3086,"Chúc mừng sinh nhật,"],[3086,3157,"Selene."],[3311,3532,"Là mình, Lyla đây."],[3532,3691,"Mình là sói của cậu."],[3691,3778,"Sói Lyla của mình,"],[3778,3824,"cậu đây rồi."],[3824,3912,"Cậu là sói của mình."],[3912,4079,"Đúng vậy, Selene,"],[4079,4195,"thật vui vì cuối cùng"],[