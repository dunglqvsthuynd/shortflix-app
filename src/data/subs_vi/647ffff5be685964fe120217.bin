hính là chị."],[4917,5000,"Nên sao nào?"],[5622,5739,"A lô?"],[5739,5847,"Có ai ở nhà không?"],[5847,5918,"Hửm?"],[6122,6252,"Trời ơi, không thể nào."],[6410,6493,"Hai người chưa làm à."],[6735,6840,"Không, bọn chị định làm rồi,"],[6840,6923,"chỉ là"],[6923,6998,"Trời đất, chị"],[6998,7119,"cũng vẫn còn trinh."],[7119,7232,"Vãi thật,"],[7232,7315,"em có cả tá chuyện"],[7315,7407,"cần kể cho chị đây."]],"32":[[12,250,"Vậy cậu không tìm thấy con bé sao?"],[250,450,"Tôi xin lỗi, Alpha Ethel."],[450,558,"Tôi đã tìm thấy một Selene,"],[558,658,"nhưng"],[658,825,"không phải người của bà."],[825,875,"Mọi chuyện trở nên"],[875,955,"phức tạp."],[1096,1213,"Cô ấy là bạn đời của tôi."],[1368,1463,"Sao cậu biết"],[1463,1609,"đó không phải Selene của chúng ta?"],[1739,1835,"Cô ấy là trẻ mồ côi."],[1835,1918,"Không có bầy đàn."],[1918,1972,"Phải, và ai đã nói"],[1972,2077,"với cậu điều đó?"],[2077,2193,"Hả?"],[2193,2281,"Đám người Blood Moon"],[2281,2360,"dối trá đó sao?"],[2456,2565,"Thằng Jackson đó cũng"],[2565,2698,"là một tên khốn dối trá"],[2698,2815,"y hệt như cha nó vậy."],[3023,3053,"Chúng từng bảo"],[3053,3136,"sẽ không tấn công."],[3319,3382,"Nhưng nhìn xem chuyện gì"],[3382,3490,"đã xảy ra kìa."],[4016,4145,"Milan, chúng ta tiêu cỡ"],[4145,4316,"7.000 đô la rồi đó."],[4316,4404,"Em có chắc là"],[4404,4466,"Alexander"],[4466,4592,"lo nổi khoản này không?"],[4717,4900,"Lo nổi sao?"],[4900,4950,"Luna, chị"],[4950,5130,"thực sự không biết à?"],[5130,5226,"Alexander đã sáng lập"],[5226,5330,"WolfByte,"],[5330,5417,"một trong những công ty khởi nghiệp"],[5417,5492,"về tiền điện tử lớn nhất"],[5492,5593,"nước Mỹ."],[5593,5663,"Anh ấy lo được"],[5663,5772,"mọi thứ."]],"33":[[792,842,"Thu thập mọi thứ cậu"],[842,875,"có"],[875,930,"về vụ Blood Moon"],[930,1051,"tấn công Red Dawn."],[1051,1163,"Tôi muốn mọi chi tiết,"],[1163,1255,"mọi hồ sơ."],[1338,1568,"Vâng thưa Alpha, tôi sẽ cố,"],[1589,1672,"nhưng có rất nhiều điều"],[1672,1881,"vẫn chưa rõ ràng."],[1881,1989,"Chính xác."],[1989,2093,"Thi thể của Selene Lovette"],[2093,2248,"chưa bao giờ được tìm thấy."],[2248,2331,"Tôi nghi ngờ"],[2748,2794,"Mấy thứ đó trông"],[2794,2857,"đẹp thật đấy."],[2873,2911,"Chị biết,"],[2911,3011,"chị cũng thích lắm."],[3165,3249,"Anh trai em đang"],[3249,3390,"theo dõi chị à?"],[3390,3616,"Không, không, là Jackson."],[3732,3895,"Tên Jackson của bầy Blood Moon"],[3895,4079,"đó hả?"],[4079,4250,"Eo ôi. Chặn hắn đi."],[4250,4391,"Hắn đúng là đồ khốn."],[4500,4600,"Ừ."],[4929,5188,"Jackson: Mình nói chuyện đi."],[5284,5672,"Selene: Không có gì để nói cả."],[5730,5885,"Jackson: Nếu anh nói"],[5885,6085,"em không phải trẻ mồ côi thì sao?"],[6143,6410,"Jackson: Em từng có một bầy trước bọn anh."]],"34":[[137,212,"Hmm, mấy cái này"],[212,271,"cũng thú vị đấy."],[521,696,"Xin lỗi nhé, tôi phải"],[696,759,"ra ngoài gọi điện"],[759,817,"một lát."],[950,1030,"Được."],[1393,1476,"Anh tốt nhất nên"],[1476,1543,"giải thích rõ đi."],[1643,1747,"Anh nhớ thái độ này của em đấy."],[1747,1926,"Giải thích mau!"],[1926,2072,"À thì, bố mẹ anh"],[2072,2110,"tìm thấy em"],[2110,2164,"đang đi lang thang"],[2164,2268,"quanh lãnh thổ của một bầy,"],[2268,2402,"ngay sát biên giới."],[2402,2498,"Họ đã hỏi"],[2498,2535,"bố mẹ em ở đâu,"],[2535,2619,"nhưng em không"],[2619,2648,"chịu nói."],[2736,2823,"Nên họ đã"],[2823,2857,"bắt cóc tôi sao?"],[2952,3019,"Vấn đề là, họ không"],[3019,3111,"thấy bố mẹ em chết."],[3111,3190,"Biết đâu họ"],[3190,3370,"vẫn còn sống."],[3370,3482,"Đó là bầy nào?"],[3570,3716,"Gặp rồi anh sẽ kể."],[3716,3795,"Chết tiệt, Jackson,"],[3795,3862,"nói ngay đi!"],[3928,4024,"Anh sẽ nói, nếu em"],[4024,4091,"chịu quay về."],[4091,4158,"Một mình."],[4275,4350,"Hẹn gặp em ở nhà,"],[4350,4521,"Selene."]],"35":[[1030,1205,"Anh nhớ mùi hương của em."],[1205,1343,"Cả ngày hôm nay."],[1343,1455,"Anh về rồi."],[1868,1939,"Anh tưởng Milan đã đưa"],[1939,2093,"em đi mua sắm."],[2093,2173,"Cô em gái được cưng chiều của anh"],[2173,2227,"lại bắt em làm"],[2227,2339,"việc nhà sao?"],[2339,2394,"Em biết là em không bao giờ"],[2394,2477,"phải làm việc nhà"],[2477,2573,"mà, đúng không?"],[2573,2727,"Không, tụi em có đi, và cô ấy"],[2727,2865,"rất dễ thương."],[2865,2957,"Chỉ là"],[3153,3286,"em không biết làm gì"],[3286,3511,"quanh quẩn ở đây cả."],[3887,3962,"Chuyện này."],[6202,6289,"Nghe này,"],[6289,6427,"chuyện tối qua"],[6606,6669,"Milan đã kể anh nghe"],[6669,6760,"mọi chuyện."],[6865,6927,"Khoan, cô ấy đã"],[6927,7011,"kể gì cơ?"],[9317,9642,"Anh rất vui vì em đã chờ."],[9642,9726,"Em cũng vậy."],[10201,10343,"Này, hỏi hơi đường đột,"],[10343,10443,"nhưng"],[10443,10502,"em có nhớ"],[10502,10543,"chút gì"],[10543,10643,"về bố mẹ mình không?"],[10814,10952,"Không. Sao vậy,"],[10952,11081,"anh nghe được gì à?"],[11081,11169,"Không có gì."],[11169,11252,"Anh chỉ thắc mắc thôi."],[11353,11515,"Không sao, mình có thể nói"],[11515,11619,"về chuyện này sau."],[11728,11857,"Chết tiệt."],[11857,11970,"Anh phải đi gặp Drake rồi."]],"36":[[83,191,"Khuya rồi. Có chuyện gì vậy?"],[300,383,"Hầu hết các bầy"],[383,417,"đã quyết định"],[417,558,"duy trì hiệp ước hòa bình."],[558,692,"Chúng ta không đủ phiếu đâu, Alpha."],[692,821,"Bọn chúng là lũ sát nhân!"],[821,950,"Tôi biết."],[950,1042,"Nhưng các Alpha khác nói"],[1042,1313,"ngài và Alpha Ethel không có bằng chứng."],[1313,1418,"Họ không muốn gây chiến"],[1418,1639,"chỉ vì những suy đoán."],[1639,1726,"Suy đoán sao?"],[1818,2002,"Đi bảo Alpha Ethel cái chết của con gái ông"],[2002,2156,"chỉ là suy đoán đi."],[2156,2239,"Xin lỗi, Alpha."],[2327,2414,"Tôi không có ý đó."],[2510,2623,"Không phải lỗi của cậu."],[2740,2823,"Chết tiệt."],[2919,3078,"Bốn ngày nữa là diễn ra hội nghị hòa bình."],[3078,3249,"Tôi phải làm họ đổi ý trước lúc đó."],[3549,3687,"Lỡ ngài không thể thì sao?"],[3687,3803,"Bắt buộc phải được."],[3866,4041,"Không còn cách nào khác."],[4041,4258,"Tôi đã hứa báo thù cho con gái Alpha Ethel,"],[4258,4441,"nhưng tôi không thể phá vỡ hiệp ước."],[4441,4600,"Chúng ta không thể bị trừng phạt."],[4875,5055,"Giờ tôi còn có Luna cần bảo vệ."]],"37":[[1259,1422,"Chào buổi sáng, Alexander."],[1422,1547,"Anh đói không?"],[1547,1634,"Đói rã ruột."],[1814,1972,"Nhưng không phải thèm ăn."],[5951,6126,"Thế, mấy lần rồi?"],[6126,6185,"Ba?"],[6185,6252,"Bốn?"],[6252,6423,"Không, để em đoán nhé."],[6423,6531,"Sáu."],[6531,6706,"Milan, thôi đi!"],[6706,6773,"Quan trọng gì"],[6773,6861,"bao nhiêu lần"],[6861,7007,"nếu không phải là lần đầu chứ?"],[7107,7248,"Biến đi, Caitlin."],[7428,7749,"Đây là Selene sao."],[7941,8037,"Không như tôi tưởng."],[8037,8241,"Trông khá nhạt nhẽo."],[8241,8329,"Ngậm miệng lại đi,"],[8329,8358,"Caitlin."],[8358,8441,"Cô ấy là Luna của cô đấy."],[8441,8637,"Cô ta không phải Luna của tôi."],[8637,8829,"Đó là danh hiệu của tôi."],[8829,8896,"Đáng lẽ tôi"],[8896,8954,"mới là người ở chung"],[8954,9088,"phòng với Alpha Alexander."],[9225,9384,"Cô rốt cuộc là ai?"],[9747,9947,"Ồ, ra là cô không biết."],[10055,10322,"Tôi là người đầu tiên của Alexander."],[10322,10460,"Chúng tôi đã ngủ với nhau."]],"38":[[37,271,"Tôi là người đầu tiên của Alexander."],[271,425,"Chúng tôi đã ngủ với nhau."],[592,692,"Cô đã ngủ với"],[692,775,"Alexander sao?"],[913,992,"Mọi người đều thấy tôi"],[992,1055,"qua đêm"],[1055,1146,"trong phòng của"],[1146,1205,"Alpha Alexander."],[1322,1380,"Cô có muốn tôi"],[1380,1426,"kể lại chi tiết"],[1426,1543,"chúng tôi đã làm gì không?"],[1543,1714,"Câm miệng và đi đi."],[1714,1776,"Tôi nghe nói cô"],[1776,2010,"ghê gớm lắm mà, Selene."],[2010,2147,"Sao giờ lại im re thế?"],[2147,2210,"Cô đ**ch biết gì"],[2210,2264,"về tôi cả."],[2264,2381,"Thật sao?"],[2381,2485,"Vì tôi biết cô là bạn tình không bầy,"],[2485,2565,"một kẻ hoàn toàn"],[2565,2681,"vô dụng với Alpha của mình."],[2781,2923,"Tôi biết mình là con gái một trưởng lão,"],[2923,3186,"một trong những con sói mạnh nhất bầy,"],[3186,3382,"nên cô biết tôi nghĩ gì không?"],[3382,3595,"Tôi nghĩ cô nên quay lại quỳ gối"],[3595,3703,"mà quét sàn đi. Câm miệng!"],[3703,3787,"Tôi