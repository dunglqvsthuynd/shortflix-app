{"1":[[2648,2790,"Đồ uống"],[2790,2882,"anh gọi đây."],[3136,3365,"Trời ạ, con khốn."],[3365,3532,"Mày đui à?"],[3532,3636,"Rõ ràng là Jackson"],[3636,3753,"đang bận."],[4475,4558,"Vậy chắc Jackson"],[4558,4633,"có thể tự rót"],[4633,4704,"đồ uống rồi."],[4792,4913,"Mày vừa nói gì hả?"],[5005,5096,"Mày dám gọi Alpha của mày"],[5096,5255,"là Jackson à?"],[5321,5438,"Trời ạ, đồ khốn"],[5438,5568,"xấc xược ngu ngốc."],[5568,5672,"Đủ rồi, Tiffany."],[5672,5789,"Biết thân biết phận đi,"],[5789,5864,"Selene."],[6001,6168,"Cô là trẻ mồ côi."],[6168,6352,"Không nhà cửa."],[6352,6464,"Không chốn dung thân."],[6702,6773,"Tôi sẽ bỏ đi và làm"],[6773,6956,"Sói hoang sao?"],[6956,7023,"Cô thậm chí còn"],[7023,7144,"chưa có sói."],[7194,7407,"Cho đến lúc đó,"],[7407,7515,"cô là của tôi."],[8354,8429,"Đến văn phòng của tôi"],[8429,8500,"khi cô dọn xong"],[8500,8600,"đống rác rưởi này."],[9534,9622,"Nữ thần Mặt trăng,"],[9622,9701,"xin người,"],[9701,9822,"xin hãy ban cho con"],[9822,9951,"một con sói dũng mãnh"],[9951,10076,"khi con tròn 18 tuổi"],[10076,10193,"trong vài ngày tới."],[10256,10352,"Con không thể chịu đựng"],[10352,10472,"thêm được nữa."],[10502,10643,"Chúng con sẽ sống khiêm nhường"],[10643,10748,"trong rừng sâu,"],[10748,10852,"chỉ săn những gì"],[10852,10923,"cần thiết,"],[10923,11019,"không cầu mong gì hơn."],[11549,11624,"Xin người,"],[11624,11753,"Nữ thần Mặt trăng."],[11753,11853,"Xin hãy ban cho con"],[11853,11953,"sói của mình"],[12057,12258,"và giải thoát cho con."]],"2":[[387,525,"15 năm."],[525,617,"15 năm ròng không một"],[617,742,"tin tức về con gái tôi."],[742,779,"Cậu còn cần"],[779,821,"gì nữa?"],[821,1055,"Tôi hiểu, Alpha Ethel."],[1055,1138,"Nhưng giết người là"],[1138,1222,"cáo buộc rất nghiêm trọng."],[1222,1326,"Nghe này,"],[1326,1397,"lũ khốn bầy Blood Moon đó"],[1397,1505,"đã tấn công bầy tôi"],[1505,1647,"vào 15 năm trước,"],[1647,1739,"và con gái tội nghiệp"],[1739,1826,"của tôi đã biến mất."],[1826,1956,"Tôi biết chúng đã giết con bé,"],[19