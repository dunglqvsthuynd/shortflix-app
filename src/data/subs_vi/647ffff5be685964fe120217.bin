ó, nên"],[4104,4175,"Trừ khi"],[4175,4258,"cậu không muốn đi."],[4258,4383,"Không!"],[4383,4491,"Mình muốn đến đó."],[4491,4575,"Đi thôi."]],"57":[[988,1046,"Chúng ta sẽ bắt đầu"],[1046,1134,"phiên tòa."],[2056,2160,"Tiffany Harrington của"],[2160,2277,"đàn Blood Moon,"],[2277,2348,"bước lên đây."],[2711,2811,"Tiffany,"],[2811,2890,"cô bị buộc tội"],[2890,2998,"đã hạ độc"],[2998,3144,"và âm mưu sát hại"],[3144,3261,"Luna của tôi"],[3261,3386,"và Alpha tương lai"],[3386,3474,"của Red Dawn,"],[3474,3578,"Selene Lovette."],[4254,4462,"Cô có nhận tội không?"],[4462,4583,"Ồ, thì ra cô ấy là Alpha."],[4583,4708,"Cô có nhận tội không?"],[4842,5055,"Không."],[5055,5121,"Jackson"],[5121,5263,"đã ép tôi làm vậy."],[5263,5380,"Tôi đã bảo anh ta đó là"],[5380,5434,"một ý kiến tồi."],[5434,5518,"Câm miệng!"],[5638,5809,"Cô ta nói dối đó, Selene."],[5809,5893,"Cô ta đang nói dối."],[6056,6168,"Tôi biết."],[6168,6252,"Tôi đọc được suy nghĩ của cô ta."]],"58":[[8,116,"Cô nói gì cơ?"],[229,333,"Tôi có năng lực đặc biệt."],[429,500,"Đó là lý do tôi đến"],[500,625,"đây hôm nay."],[625,675,"Để đảm bảo rằng"],[675,788,"không ai có thể nói dối"],[788,942,"thêm lần nào nữa."],[942,1142,"Alpha Ethel, cha tôi,"],[1142,1334,"có thể xác nhận điều này."],[1334,1589,"Đúng vậy, con gái tôi là một"],[1589,1710,"Alpha thiên bẩm."],[1805,2014,"Còn Tiffany, cô là một"],[2014,2097,"kẻ dối trá đê tiện."],[2097,2239,"Jackson đã làm nhiều việc, nhưng không đầu độc tôi."],[2239,2339,"nhưng không đầu độc tôi."],[2435,2560,"Tôi đề nghị trục xuất"],[2560,2715,"Tiffany khỏi cộng đồng,"],[2715,2873,"phải sống lang bạt"],[2873,3015,"mãi mãi."],[3015,3098,"Ai tán thành?"],[3499,3582,"Không."],[3582,3741,"Không, Selene."],[3741,3899,"Xin cô, tôi thực sự,"],[3899,4037,"thực sự xin lỗi."],[4037,4200,"Tôi có thể làm tốt hơn."],[4200,4337,"Tôi có thể tốt hơn."],[4337,4408,"Ý tôi là, cô có thể có"],[4408,4466,"Jackson."],[4466,4567,"Cô có thể có tất cả. Khốn k**p,"],[4567,4704,"khốn k**p, khốn k**p!"],[4788,4925,"Tiffany,"],[4925,5034,"cô cũng khốn k**p lắm."],[5230,5397,"Không, không, mọi người không thể làm vậy!"],[5397,5463,"Không!"],[5463,5547,"Không!"],[5547,5630,"Không!"],[5793,5930,"Chà, vui thật đấy."],[5930,6064,"Muốn đi mua sắm không?"],[6172,6239,"Cảm ơn, Luna của tôi."],[6239,6335,"Tôi có thể lo liệu"],[6335,6439,"phiên tòa của Jackson từ đây."],[6560,6627,"Khoan, em không định"],[6627,6735,"ở lại dự phiên tòa của anh sao?"],[6923,7011,"Không."],[7011,7094,"Anh vẫn sống và tôi"],[7094,7198,"vui vì điều đó,"],[7198,7365,"nhưng phần còn lại do"],[7365,7507,"tòa án định đoạt."],[7636,7757,"Anh hiểu."],[8062,8216,"Anh yêu em, Selene."],[8216,8316,"Anh xin lỗi."]],"59":[[116,283,"Á, đau quá!"],[283,371,"Ồ, em xin lỗi,"],[371,433,"Luna."],[433,550,"Em làm chị đau à?"],[671,754,"Chị vẫn không hiểu sao"],[754,821,"chúng ta phải làm việc này."],[821,946,"Ý chị là, sau bao chuyện,"],[946,1021,"chị chỉ muốn"],[1021,1263,"chẳng làm gì cả, mãi mãi."],[1263,1338,"Vâng, nhưng chị không thể"],[1338,1484,"làm Luna của Nightwind"],[1484,1534,"nếu chưa có một buổi lễ"],[1534,1701,"nhậm chức tử tế."],[1701,1876,"Với lại, trông chị sẽ"],[1876,2110,"như một nữ hoàng."],[2110,2268,"Vậy chị chỉ việc bước lên đó"],[2268,2389,"và nói chị chấp nhận vai trò"],[2389,2581,"Luna của bầy Nightwind sao?"],[2581,2665,"Vâng."],[2665,2790,"Dễ ợt mà."],[2923,3048,"Xong rồi."],[3691,3858,"Chị lộng lẫy quá!"],[4012,4137,"Đẹp tuyệt vời."],[4258,4458,"Trông chị tuyệt lắm."],[4458,4662,"Được rồi, đi thôi!"],[4771,4842,"Chị đâu thể tự làm việc này"],[4842,4988,"một mình được, ngốc ạ."],[4988,5084,"Nam chính đâu rồi?"],[5176,5267,"Không ngờ anh ấy lại không ở đây."],[5267,5342,"Chính anh ấy là người muốn"],[5342,5572,"chị làm buổi lễ này mà."],[5855,5943,"Không thể tin anh lại không"],[5943,6022,"tìm thấy em sớm hơn,"],[6022,6118,"Luna của anh."],[6268,6343,"Em có thể là"],[6343,6539,"Luna của anh, và một Alpha,"],[6539,6664,"nhưng vẫn còn một danh xưng"],[6664,6752,"mà em còn thiếu."],[6865,6948,"Vợ của anh."],[7073,7173,"Selene Lovette,"],[7207,7328,"em đồng ý lấy anh chứ?"],[7511,7595,"Em đồng ý!"],[7678,7803,"Em phấn khích quá!"]],"60":[[834,1021,"Em, Selene Lovette,"],[1021,1146,"chấp nhận vai trò"],[1146,1267,"Luna của Nightwind"],[1380,1501,"và làm vợ anh."],[1618,1910,"Anh, Alexander Kane,"],[1947,2114,"f**king yêu em."],[3115,3199,"Ôi."],[3507,3749,"Chà, hai Alpha thành đôi."],[3749,3974,"Mau đẻ mấy đứa siêu nhí đi."],[3974,4129,"Ngay bây giờ luôn."],[4129,4212,"Bố!"],[5188,5284,"Đợi đã!"],[5284,5367,"Khoan đã."],[5647,5701,"Đừng nói với em là"],[5701,5801,"anh cần đi tắm nhé."],[6368,6448,"Anh thấy chuyện này"],[6448,6498,"buồn cười lắm à?"],[6648,6727,"Em rất vui vì"],[6727,6835,"sự đau khổ của em"],[6835,6865,"lại giúp anh giải trí."],[7094,7244,"Khoan, vãi sh*t,"],[7244,7344,"anh nghĩ sao về"],[7344,7474,"Alexander Jr.?"],[7603,7761,"AJ?"],[7761,7882,"AJ Lovette-Kane?"]]}