{"1":[[792,900,"Mình thích lắm."],[1030,1142,"Adam sẽ không thể"],[1142,1263,"rời mắt khỏi mình."],[1288,1401,"Adam!"],[1518,1630,"Anh yêu, nhìn này."],[1922,2006,"Adam?"],[3578,3632,"Em à."],[4133,4312,"Với bạn thân của tôi"],[4358,4475,"ngay trước đám cưới sao?"],[4487,4621,"Trách anh được sao?"],[4671,4713,"Thôi nào."],[4713,4775,"Em có cho anh chạm vào người đâu."],[4775,4867,"Chúng ta đã hứa sẽ đợi"],[4867,4950,"tới lúc cưới mà."],[4950,5075,"Flora, thực tế đi."],[5075,5355,"Được rồi. Chia tay đi."],[5355,5488,"Cô chỉ là đồ trinh nữ lãnh cảm"],[5488,5547,"với tôi thôi."],[5663,6031,"Chỉ nghĩ đến chuyện lên giường với cô"],[6031,6110,"cũng làm tôi mất hứng."],[6293,6423,"Thằng kh*n."],[6519,6627,"Chúng ta xong rồi."],[8988,9100,"Đừng lo chuyện đó."],[9100,9271,"Adam là con trai tôi."],[9271,9392,"Tôi sẽ dự đám cưới của nó,"],[9392,9572,"và sẽ sớm gặp cô dâu thôi."],[9718,9793,"M* kiếp."],[10727,10848,"Mất trí rồi sao?"]],"2":[[62,108,"Tôi xin lỗi."],[108,233,"Tôi không thấy xe anh."],[241,337,"Nếu tôi không đạp phanh"],[337,421,"kịp lúc thì cô đã mất mạng rồi."],[437,542,"Làm ơn đừng quát tôi nữa."],[575,692,"Tôi biết tôi sai rồi,"],[692,834,"và tôi cũng đã xin lỗi,"],[834,1030,"nhưng chồng sắp cưới vừa cắm sừng tôi"],[1030,1134,"với bạn thân của tôi,"],[1146,1263,"và hôm nay đã là ngày"],[1263,1355,"tồi tệ nhất đời tôi rồi."],[1355,1426,"Nên anh có thể"],[1426,1564,"tha cho tôi được không?"],[1564,1593,"Được không?"],[1645,1931,"Làm ơn đi."],[3390,3457,"Cô không sao chứ?"],[3787,3887,"Chồng sắp cưới của cô đúng là gã ngốc"],[3887,4020,"khi cắm sừng một người phụ nữ tuyệt đẹp"],[4020,4108,"như cô."],[4391,4667,"Anh thấy tôi tuyệt đẹp sao?"],[4700,4909,"Vì anh ta đã nói thẳng"],[4909,5092,"rằng anh ta chỉ coi tôi là một"],[5092,5280,"trinh nữ lãnh cảm."],[5280,5467,"Đừng bận tâm lời hắn nói."],[5467,5584,"Cô"],[5739,5922,"Cô vô cùng tuyệt vời."],[7098,7248,"Cô là một viên ngọc hiếm"],[7248,7340,"đang chờ được mài giũa."],[7557,7607,"Anh"],[7607,7695,"Anh đang đùa."],[7695,7770,"Đúng không?"],[7941,8099,"Tôi có thể giúp cô tỏa sáng"],[8128,8295,"nếu cô đủ tin tưởng để tôi"],[8295,8362,"dẫn dắt."],[8554,8679,"Nghe như một ý tồi."],[8833,9029,"Ồ đúng vậy, một ý cực tồi."],[9129,9217,"Cô sẽ thích nó cho xem."]],"3":[[633,775,"Hộp đêm thoát y."],[775,850,"Thật sao?"],[850,942,"Không như cô nghĩ đâu."],[996,1084,"Nó còn hơn thế nữa."],[1096,1163,"Thật á?"],[1180,1284,"Đây là thiên đường."],[1284,1418,"Là nơi những khao khát"],[1418,1509,"được tự do trỗi dậy."],[1509,1609,"Mà không bị ai phán xét."],[1710,1989,"Nhưng nếu cô chưa sẵn sàng hay quá sợ,"],[1989,2093,"tôi vẫn có thể đưa cô về."],[2093,2193,"Ai bảo là tôi sợ chứ?"],[3516,3595,"Cảm ơn, Mike."],[3624,3757,"Các cậu kiểm kê xong chưa?"],[3837,3974,"Trông ổn cả đấy."],[3974,4091,"Làm tốt lắm."],[4091,4208,"Mang cái này qua phòng kế toán giúp tôi,"],[4208,4270,"được chứ?"],[4416,4550,"Anh là chủ câu lạc bộ này sao?"],[4550,4750,"Đến văn phòng đợi tôi đi."],[4750,4921,"Và đừng đi lung tung."],[8128,8291,"Ôi trời ơi!"]],"4":[[25,158,"Cô em mới đến à."],[658,792,"Tên gì vậy, cưng?"],[880,955,"Tránh ra đi, Derek."],[955,1055,"Cô ấy đi cùng tôi."],[1146,1388,"Bình tĩnh nào, Marco."],[1605,1772,"Làm gì mà bảo vệ gắt thế."],[1772,2002,"Chẳng bao giờ chịu chia sẻ đồ ngon."],[2031,2177,"Cô ấy không phải để chia sẻ."],[2177,2331,"Ngoài ra, ai cho phép cậu"],[2331,2498,"mở tiệc trong phòng riêng của tôi hả?"],[2498,2594,"Ồ, là cái cô ừm"],[2698,2765,"Tên cô ta là gì nhỉ?"],[2765,2836,"Thôi bỏ đi."],[2836,2936,"Ra ngoài!"],[2936,2994,"Cindy!"],[2994,3048,"Cô cũng thế."],[3048,3157,"Đi thôi."],[4383,4491,"Còn cô."],[4579,4738,"Tôi đã bảo cô đừng đi lung tung rồi mà?"],[4738,4946,"Người phụ nữ đó đang bị tra tấn."],[4946,5055,"Derek nứng đến mức"],[5055,5242,"có thể f**k bất cứ ai trên 18 tuổi."],[5242,5363,"Nhưng cậu ta sẽ không thực sự"],[5363,5434,"làm hại ai đâu."],[5455,5551,"Cô ấy đã rất đau đớn."],[5551,5663,"Cô ấy còn la hét nữa."],[5663,5789,"Tin tôi đi, cưng à,"],[5914,6181,"tất cả chỉ vì khoái cảm thôi."],[6306,6460,"Và cô ta đã đồng thuận."],[6460,6752,"Sao cô ta có thể thích"],[6752,6886,"việc bị đánh roi chứ?"],[6927,7228,"Không thử sao biết được."],[7278,7319,"Được rồi."],[7319,7511,"Có lẽ tôi nên về."],[7766,7849,"Phải, cô có thể về."],[8095,8366,"Về mà khóc cho gã chồng sắp cưới ngu ngốc đi."],[8541,8687,"Hoặc cô có thể ở lại đây."],[8796,8971,"Và để một người đàn ông thực thụ chăm sóc."],[9046,9300,"Cô đối với tôi chỉ là một trinh nữ lãnh cảm."],[9563,9626,"Tôi tham gia."]],"5":[[79,191,"Ngoan lắm."],[241,475,"Nhưng trước khi chúng ta vui vẻ,"],[475,721,"cô nên biết điều này."],[721,988,"Tôi không làm tình kiểu bình thường."],[988,1213,"Sở thích của tôi rất đặc biệt."],[1213,1472,"Không chỉ đơn thuần là tình dục đâu."],[1547,1826,"Cô sẽ không hối hận đâu."],[1826,1981,"Sẵn sàng chưa?"],[5192,5342,"Anh định dùng"],[5342,5438,"tất cả đống này lên người tôi sao?"],[5484,5655,"Chỉ khi có sự đồng ý của cô."],[5693,5993,"Được rồi, hơi nhiều thứ để tiếp thu đấy."],[6535,6656,"Vậy."],[6723,6919,"Ta bắt đầu từ đâu đây?"]],"6":[[0,141,"Ta bắt đầu từ đâu đây?"],[204,262,"Không."],[379,500,"Mọi chuyện không diễn ra thế đâu."],[500,633,"Trước khi làm người thống trị của cô,"],[633,796,"tôi cần hỏi cô vài câu."],[888,946,"Và sau đó chúng ta sẽ"],[946,1059,"ký hợp đồng."],[1076,1151,"Được."],[1284,1347,"Lại đây."],[1397,1468,"Ngồi xuống."],[2489,2640,"Tư thế quan hệ cô thích nhất là gì?"],[2765,2994,"Tôi không biết."],[3040,3190,"Tôi và người yêu cũ chưa"],[3211,3332,"Thế còn màn dạo đầu?"],[3507,3611,"Màn dạo đầu?"],[3787,3937,"Cô từng chạm vào đàn ông chưa?"],[3937,3991,"Chưa."],[4062,4212,"Cô từng tự thỏa mãn chưa?"],[4612,4833,"Chưa, tôi"],[4875,4984,"chưa có kinh nghiệm."],[4996,5163,"Vậy ý cô là cô vẫn còn trinh sao?"],[5259,5326,"Đúng."],[5401,5488,"Chết tiệt."],[5584,5672,"Cô thậm chí còn không biết"],[5672,5864,"ta sắp làm gì, đúng không?"],[5914,5985,"Nếu đó là vấn đề,"],[5985,6227,"tôi không muốn còn trinh nữa."],[6227,6498,"Tôi muốn thấy mình gợi cảm và được khao khát."],[6498,6723,"Được khao khát ư?"],[6723,6898,"Cô có biết bao nhiêu gã ngoài kia"],[6898,7098,"sẵn sàng bất chấp để lên giường với cô không?"],[7265,7390,"Kể cả anh sao?"],[7457,7661,"Đến phát điên."],[7766,7970,"Với tình hình này,"],[8012,8145,"chúng ta sẽ tiến hành từ từ."],[8145,8283,"Từ từ á? Tôi không muốn"],[8283,8391,"Không nhưng nhị gì hết."],[8433,8608,"Tôi đưa cô về nhà ngay bây giờ."]],"7":[[1397,1659,"Mặc kệ luật lệ đi, tôi muốn cô ngay."],[4904,5167,"Cởi áo tôi ra."]],"8":[[1384,1514,"Tiếp tục đi."]],"9":[[575,671,"Mình thực sự đã"],[671,871,"tình một đêm với người lạ sao?"],[1622,1822,"Chắc mẹ lo lắm."],[2277,2389,"Chào buổi sáng, người đẹp."],[2389,2531,"Đêm qua em ngủ ngon chứ?"],[2606,2777,"Cũng ngon."],[2777,2894,"Cảm ơn anh."],[2894,2977,"Chắc vậy."],[3023,3115,"Mà này,"],[3182,3315,"em còn chưa biết tên anh."],[3315,3490,"Anh là Marco Russo."],[3703,3803,"Sao cơ?"],[3832,3883,"Chồng sắp cưới của em"],[3883,4066,"cũng mang họ đó."],[4066,4183,"Họ đó phổ biến mà."],[4258,4446,"Trùng hợp thật nhỉ?"],[4550,4637,"Còn em thì sao?"],[4637,4729,"Em tên gì?"],[4775,4846,"Flora."],[4913,5000,"Flora Wade."],[5084,5221,"Cho em đấy."],[5359,5484,"Ký đi và làm người phục tùng của anh."]],"10":[[596,800,"Hợp đồng phục tùng."],[800,855,"Đúng vậy."],[855,971,"Để cả hai cùng thỏa mãn,"],[971,1117,"chúng ta cần làm rõ mọi thứ."],[1130,1301,"Người phục tùng phải tuân theo"],[1301,1447,"mọi hoạt động tình dục"],[1447,1647,"do người chi phối yêu cầu."],[1676,1939,"Thế này hơi quá nhỉ?"],[1939,2068,"Không hề."],[2068,2218,"Em sẽ làm chính xác những gì anh bảo"],[2218,2310,"khi ở trên giường."],[2364,2498,"Nhưng nếu có điều khoản nào"],[2498,2660,"khiến em thấy không thoải mái,"],[2660,2740,"chúng ta có thể gạch đi."],[2777,3032,"Em chấp nhận bị trói, nhưng"],[3098,3261,"tuyệt đối không qua cửa sau,"],[3261,3461,"không đút tay hay dùng kẹp vùng kín."],[3465,3666,"Coi như đã gạch bỏ."],[3916,4062,"Mẹ em gọi."],[4062,4233,"Em có phải ký ngay không?"],[4233,4433,"Không hề. Cứ từ từ suy nghĩ."],[4433,4633,"Nhưng anh muốn dạy dỗ em"],[4692,4838,"trong phòng riêng của anh trước cuối"],[4838,4929,"tuần này."],[5618,5693,"Sao anh chắc chắn"],[5693,5759,"là em sẽ ký?"],[5759,5926,"Vì anh biết em cũng muốn chuyện này"],[5926,6010,"nhiều như anh."]],"11":[[8,104,"Con ổn chứ, con yêu?"],[104,216,"Hôm qua mẹ gọi cả ngàn cuộc"],[216,337,"mà con chẳng chịu nghe máy."],[342,417,"Con ổn ạ."],[417,558,"Con phát hiện Adam cắm sừng con"],[558,646,"và bọn con chia tay rồi."],[663,771,"Con xin lỗi mẹ."],[771,838,"Ôi, con yêu,"],[838,984,"sao con phải xin lỗi chứ?"],[1030,1201,"Bà muốn nhìn thấy con"],[1201,1284,"lên xe hoa trước khi nhắm mắt,"],[1284,1514,"và con thấy như mình làm bà thất vọng."],[1514,1672,"Con không làm ai thất vọng cả."],[1672,1789,"Adam không xứng đáng với con."],[1789,1931,"Mẹ mừng vì con đã bỏ cậu ta."],[2010,2068,"Và bà chắc chắn"],[2068,2156,"cũng sẽ nghĩ vậy thôi."],[2293,2494,"Thế tối qua con ở đâu?"],[2631,2686,"Con-"],[2731,3299,"Con... con chỉ đi chơi với bạn thôi."],[3345,3549,"Trông con có vẻ hơi khác."],[3591,3707,"Khác thế nào ạ?"],[3707,3908,"Ý mẹ là theo hướng tích cực."],[3953,4166,"Trông con tự tin hơn đấy."],[4208,4279,"Tốt ạ."],[4279,4383,"Chắc là do rời bỏ một gã tồi"],[4383,4496,"nên con mới được như vậy."]],"12":[[271,471,"Tôi không ngờ em quay lại sớm thế."],[608,809,"Em đã ký rồi."],[1184,1384,"Chúng ta bắt đầu chứ?"],[2102,2281,"Chết tiệt, em đẹp quá."],[2794,2886,"Quỳ xuống."],[3132,3236,"Vâng."],[4220,4421,"Em phải làm theo lời tôi."],[4466,4567,"Gọi tôi là chủ nhân."],[4567,4738,"Rõ chưa?"],[4738,4896,"Vâng, thưa chủ nhân."],[4896,5096,"Ngoan lắm."],[6039,6126,"Em đẹp đúng như"],[6126,6235,"những gì tôi tưởng tượng."],[7419,7620,"Em muốn ngài, thưa chủ nhân."],[7757,7970,"Chúa ơi! Tôi muốn đ*t em ngay tại đây,"],[7970,8133,"ngay lúc này."],[8170,8370,"Vâng, thưa chủ nhân."],[9551,9688,"Bố ơi?"],[9809,9947,"Bố có nhà không?"],[9993,10185,"Đó là giọng của Adam."],[10185,10385,"Em biết con trai tôi sao?"],[10397,10589,"Con trai anh là tên chồng sắp cưới cũ cắm sừng tôi sao?"]],"13":[[975,1059,"Adam."],[1059,1151,"Con làm gì ở đây thế?"],[1151,1351,"Con chỉ đến chào bố thôi."],[1459,1639,"Con có làm phiền bố không?"],[1655,1780,"Cô gái nào thế? Xinh không bố?"],[1780,1943,"Không phải chuyện của con."],[1943,2043,"Con nên về đi."],[2043,2143,"Được rồi."],[2152,2306,"Con chỉ đùa thôi."],[2306,2464,"Con về đây."],[2731,2836,"Đợi đã."],[2994,3178,"Đó là giày của Flora sao?"],[3390,3591,"Bố đang ngủ với vợ sắp cưới của con à?"],[3599,3782,"Chú ý thái độ đi, con trai."],[3782,3878,"Con là người lớn rồi."],[3878,4079,"Bố có thể ở bên bất kỳ ai bố muốn,"],[4112,4275,"và bố không có nghĩa vụ phải"],[4275,4329,"giải thích với con."],[4337,4466,"Nhưng con nhận ra đôi giày đó."],[4466,4542,"Là của Flora."],[4550,4679,"Thì sao? Chỉ là giày thôi mà."],[4679,4796,"Hàng ngàn người cũng đi chúng"],[4796,4879,"mỗi ngày."],[5005,5109,"Bố nói đúng."],[5109,5309,"Chắc con chỉ hoang tưởng thôi."],[5405,5605,"Con hứa sẽ không lặp lại đâu."],[5709,5910,"Gặp bố sau nhé."],[6439,6619,"Adam là tên người yêu cũ cắm sừng em sao?"],[6619,6710,"Em ngủ với tôi chỉ để"],[6710,6881,"trả thù con trai tôi sao?"]],"14":[[29,183,"Em hận nó vì đã cắm sừng em"],[183,271,"và hủy hôn với em."],[283,358,"Sao cơ?"],[358,546,"Nên em mới tiếp cận tôi"],[546,713,"và đồng ý phục tùng tôi."],[713,880,"Là do anh suýt tông trúng em,"],[880,1105,"chứ em không hề biết anh là bố anh ta."],[1121,1267,"Và nói cho anh biết,"],[1267,1368,"chính em đã đá Adam"],[1368,1522,"và hủy bỏ đám cưới."],[1576,1885,"Không ngờ số phận lại trớ trêu thế này."],[1922,2093,"Mới vừa nãy, tôi còn rất hạnh phúc"],[2093,2168,"vì đã gặp được em."],[2193,2327,"Thế mà đùng một cái!"],[2360,2494,"Em lại là tình cũ của con trai tôi."],[2585,2690,"Anh có hối hận không?"],[2773,2911,"Tôi ước là có,"],[2977,3132,"nhưng tôi chỉ muốn em nhiều hơn."],[3174,3345,"Em cũng thế."],[3365,3561,"Tuyệt đối không được để Adam biết chuyện này."],[3632,3728,"Sẽ không đâu."],[3766,3966,"Tôi rất muốn có em."],[4187,4379,"Nhưng tôi phải làm điều đúng đắn."],[4379,4546,"Điều đúng đắn sao?"],[4546,4642,"Mọi chuyện đang diễn ra"],[4642,4859,"giữa hai ta phải chấm dứt ngay."],[4904,5105,"Hợp đồng của chúng ta bị hủy."],[5146,5234,"Em không thể chấp nhận chuyện đó."],[5372,5534,"Còn anh thì sao,"],[5534,5709,"chủ nhân?"],[6498,6602,"Flora."],[6785,6877,"Flora!"],[6877,6973,"Xin lỗi. Dạ."],[6973,7052,"Mẹ cần gì ạ?"],[7052,7253,"Hai cái bánh táo!"],[7374,7474,"Dạ đây ạ."],[7474,7574,"Con cứ như người mất hồn"],[7574,7661,"suốt hai tuần nay rồi."],[7661,7795,"Có chuyện gì vậy?"],[7795,7995,"Không có chuyện gì đâu mẹ."],[8291,8366,"Tiệm bánh Happy Hours xin nghe."],[8366,8425,"Tôi là Flora."],[8425,8500,"Tôi có thể giúp gì ạ?"],[8500,8671,"Tôi gọi thay mặt ngài Russo."],[8671,8812,"Tôi muốn đặt một chiếc bánh phô mai"],[8812,9084,"đến câu lạc bộ Paradise."],[9159,9371,"Câu lạc bộ Paradise sao?"],[9371,9522,"Vâng, và chúng tôi muốn cô Wade,"],[9522,9676,"đích thân đem giao nó."],[9838,9959,"Có vẻ như ngài Russo"],[9959,10043,"đã đổi ý."]],"15":[[271,529,"Bánh của ngài giao đến rồi đây, ngài Russo."],[1113,1205,"Vẫn đang đợi Marco sao,"],[1205,1322,"cô Wade?"],[1376,1497,"Thật ngây thơ."],[1497,1605,"Là anh."],[1860,1993,"Anh cố tình dụ tôi đến đây."],[2031,2185,"Anh thật sự muốn gì?"],[2185,2385,"Tôi muốn cô"],[2414,2615,"làm sub mới của tôi."],[2615,2927,"Và tôi hứa sẽ nâng niu cô"],[2927,3094,"hơn bất cứ"],[3094,3211,"ai khác."],[3211,3345,"Đừng hòng."],[3345,3532,"Tôi rất thích thử thách,"],[3532,3636,"nhất là trong việc"],[3636,3732,"thuần phục kẻ bướng bỉnh."],[3770,3987,"Không phải tôi. Tôi về đây."],[4041,4212,"Vẫn còn vương vấn Marco sao?"],[4329,4491,"Tội nghiệp chưa."],[4637,4725,"Cô chưa nghe tin gì sao?"],[4808,4934,"Tin gì cơ?"],[4984,5184,"Ồ, anh ta có người mới rồi."],[5267,5513,"Chắc giờ này anh ta đang"],[5588,5789,"lên giường với một cô học trò"],[5826,6026,"mới nào đó."],[6122,6231,"Chấp nhận sự thật đi, cô Wade."],[6231,6431,"Cô cũng chỉ là một sub khác của anh ta thôi."],[6477,6677,"Rất dễ thay thế."],[6781,6898,"Tôi không tin một từ nào"],[6898,6981,"anh nói."],[7165,7365,"Tự tin thế cơ à."],[7661,7862,"Chơi một trò chơi nhỏ nhé?"],[7999,8199,"Để xem Marco có thực sự quan tâm cô không."],[8224,8279,"Nếu cô thắng,"],[8420,8575,"tôi sẽ buông tha cho cô mãi mãi."],[8575,8775,"Nhưng nếu tôi thắng,"],[9088,9163,"cô sẽ thuộc về tôi."]],"16":[[25,225,"Hợp đồng của chúng ta đã chấm dứt."],[367,496,"Được thôi."],[496,679,"Tôi ổn với chuyện đó."],[679,842,"Còn anh thì sao?"],[842,975,"Chủ nhân?"],[975,1146,"Có chuyện gì làm ngài phiền lòng sao, chủ nhân?"],[1163,1267,"Để tôi yên!"],[1267,1463,"Thôi nào."],[1463,1651,"Ngài biết ngài muốn thế mà."],[2957,3119,"Cô ta làm gì ở đây?"],[3199,3399,"Cô ta không đáng để ngài bận tâm đâu."],[3611,3732,"Nào."],[3820,4020,"Nhìn tôi này."],[4112,4312,"Marco đang nhìn chúng ta kìa."],[4341,4483,"Anh không cần phải đứng sát vậy đâu."],[4483,4654,"Tôi vẫn nghe rõ mà."],[4654,4879,"Cô phải biết diễn chứ,"],[4879,5042,"nếu muốn làm anh ta ghen."],[5267,5467,"Giờ cô tự thấy rồi đấy."],[5559,5697,"Tôi không hề nói dối."],[5851,6026,"Marco có người mới rồi."],[6026,6227,"Rõ ràng là anh ta"],[6272,6460,"đang vui vẻ với sub mới."],[6460,6631,"Chẳng hề quan tâm cô đang ở cùng tôi."],[6681,6790,"Cô thua rồi."],[6790,6977,"Cô Wade."],[6977,7203,"Không. Tôi chưa từng đồng ý thỏa thuận đó."],[7369,7536,"Cô dám giỡn mặt với tôi à?"],[7536,7691,"Dừng lại! Đừng chạm vào tôi!"],[7691,7857,"Tôi không quan tâm cô nghĩ gì."],[7857,8041,"Cô là sub của tôi và cô phải nghe lời tôi."],[8591,8742,"Bỏ tay khỏi cô ấy ngay!"],[8742,8804,"Cô ấy là của tôi."]],"17":[[233,412,"Bình tĩnh đi, Marco."],[412,525,"Chỉ đùa chút thôi mà."],[525,684,"Anh bị cấm đến câu lạc bộ này vĩnh viễn."],[684,884,"- Giờ thì cút đi. - Thật sao?"],[938,1034,"Tôi đã tiêu hàng ngàn đô ở đây."],[1034,1126,"Anh định đuổi tôi"],[1126,1234,"chỉ vì cô ta sao?"],[1234,1376,"Buông tôi ra."],[1376,1476,"Cút khỏi đây ngay!"],[1476,1622,"Chúng ta có thể nói chuyện mà!"],[1622,1776,"Thôi nào."],[1993,2072,"Sao Derek lại nói"],[2072,2210,"em là sub của hắn?"],[2210,2318,"Anh đã chấm dứt hợp đồng,"],[2318,2410,"nhớ chứ?"],[2444,2510,"Anh không phải dom của em,"],[2510,2644,"anh không có quyền ra lệnh cho em."],[2644,2811,"Em biết anh buộc phải làm vậy mà."],[2811,2932,"Vậy thì làm vậy lần nữa đi."],[2932,3065,"Và để em đi."],[3286,3449,"Anh đã cố."],[3449,3591,"Cố lắm rồi."],[3928,4045,"Chết tiệt!"],[4195,4275,"Anh muốn em."]],"18":[[41,200,"Anh định làm gì em?"],[241,392,"Tin anh chứ?"],[2373,2531,"Cứ cảm nhận đi."],[2915,3069,"Cảm thấy thế nào?"],[3215,3340,"Trả lời anh."],[3365,3566,"Sướng chết đi được."],[4625,4867,"Em muốn anh, chủ nhân."],[5130,5267,"Cầu xin đi, Flora."],[5384,5555,"Em xin anh,"],[5622,5668,"chủ nhân."]],"19":[[4546,4746,"Đúng rồi."],[7699,7778,"Em thích chứ?"],[7932,8012,"Dạ."]],"20":[[1042,1176,"Chắc em phải đi rồi."],[1242,1368,"Đừng."],[1368,1484,"Tôi không biết em đã làm gì tôi,"],[1484,1626,"nhưng tôi không thể ngừng nghĩ về em."],[1651,1826,"Dù có cố gắng thế nào."],[1856,1968,"Anh từng nói hợp đồng của chúng ta"],[1968,2056,"đã chấm dứt rồi mà."],[2072,2273,"Đúng, đó là một sai lầm lớn."],[2352,2502,"Tôi luôn hối hận vì điều đó."],[2556,2665,"Vậy thì sửa sai đi."],[2723,2902,"Chúng ta có thể tiếp tục hợp đồng."],[2902,3082,"Em là vợ sắp cưới cũ của con trai tôi."],[3382,3582,"Mình không cần nói cho nó biết."],[4471,4654,"Chết thật."],[4654,4842,"Nhìn giờ xem."],[4842,4963,"Em phải đi đây."],[4963,5088,"Đi làm gì?"],[5088,5259,"Em có tiệm bánh, nhớ không?"],[5292,5451,"Bọn em phải làm từ sớm."],[5609,5726,"Gặp lại anh sau."],[6118,6214,"Không đâu, mẹ."],[6252,6352,"Mẹ đừng lo."],[6385,6519,"Con vẫn sẽ tiến hành đám cưới"],[6519,6610,"để lấy tài sản thừa kế"],[6610,6706,"của ông già đó."],[6977,7069,"Con phải cúp máy đây."],[7323,7411,"Đồ khốn!"],[7436,7607,"Tôi biết cô đang làm gì."],[7607,7703,"Adam đã phát hiện ra chuyện"],[7703,7791,"tôi và bố anh ta sao?"]],"21":[[0,145,"Cô đi rêu rao với mọi người"],[145,254,"rằng đám cưới bị hủy à?"],[287,412,"Vì anh đã cắm sừng tôi"],[412,500,"với bạn thân tôi,"],[513,642,"nên tôi hủy đám cưới."],[642,859,"Chỉ là qua đường thôi."],[917,1026,"Có gì to tát đâu."],[1026,1163,"Tôi đã mời tất cả bạn bè"],[1163,1242,"tới dự đám cưới."],[1259,1359,"Tôi đã tốn cả đống tiền."],[1359,1547,"Cô không thể nói hủy là hủy."],[1547,1751,"Đó là chuyện của anh, đâu phải tôi."],[1893,2018,"Cô nghĩ có thể cứ thế"],[2018,2093,"mà bỏ đi sao?"],[2106,2218,"Cô sẽ phải cưới tôi"],[2218,2339,"đúng như kế hoạch."],[2339,2444,"Anh không thể ép tôi"],[2444,2535,"cưới anh được, rõ chưa?"],[2535,2640,"Buông tôi ra!"],[2640,2727,"Cái quái gì đây?"],[2802,2890,"Dấu hôn à?"],[3003,3157,"Cô cắm sừng tôi sao?"],[3186,3290,"Thằng nào?"],[4596,4779,"Anh cắm sừng tôi trước."],[4779,4975,"Nên bớt quản chuyện của tôi đi."],[4975,5050,"Chúng ta xong rồi."],[5050,5238,"Không, cô không thể quay lưng"],[5238,5317,"dễ dàng thế được."],[5317,5422,"Rõ chưa?"],[5438,5518,"Tiền địa điểm,"],[5518,5626,"cỗ bàn."],[5659,5801,"Tôi đã tiêu một triệu đô la"],[5801,5889,"vào đám cưới này."],[5889,6047,"Một triệu đô la? Đám cưới mình"],[6047,6151,"làm gì tốn đến mức-"],[6435,6552,"À, tôi hiểu rồi."],[6552,6669,"Anh đang định ép tôi"],[6669,6819,"cưới anh bằng cách đe dọa sao?"],[6952,7073,"Thật thảm hại."],[7073,7178,"Tôi dám đấy,"],[7178,7349,"nghe chưa?"],[7349,7549,"Cô luôn thuộc về tôi."],[7590,7791,"Đến khi tôi chán và đá cô."],[7811,8012,"Luật chơi là thế đấy."],[8099,8291,"Bỏ tôi ra, đồ điên!"]],"22":[[475,638,"Này, cô không sao chứ?"],[650,713,"Tôi không sao."],[713,846,"Bố làm gì ở đây vậy?"],[1659,1751,"Đánh phụ nữ sao?"],[1764,1860,"Bố đâu có dạy con như thế."],[1860,1989,"Không, bố. Không như bố nghĩ đâu."],[2039,2173,"Bố nghe hết chuyện rồi."],[2223,2364,"Bố sẽ trả toàn bộ chi phí đám cưới,"],[2364,2498,"và con phải tránh xa Flora ra"],[2498,2577,"từ nay về sau."],[2923,3065,"Sao bố lại bênh cô ta?"],[3290,3411,"Sao bố biết tên cô ta?"],[3653,3720,"Có phải bố đang ngủ"],[3720,3874,"với bạn gái con sau lưng con không?"],[3974,4179,"Nếu Adam biết mình đã ngủ với bố anh ta,"],[4229,4350,"anh ta sẽ phát điên mất."],[4500,4696,"Flora và bố"],[4942,5088,"Ông Marco là khách hàng"],[5088,5159,"ở tiệm bánh."],[5192,5317,"Nên chúng tôi mới biết nhau,"],[5317,5372,"đúng không ạ?"],[5405,5505,"Đúng thế."],[5563,5630,"Thật sao?"],[5705,5809,"Vì cái cách hai người"],[5809,6114,"Adam, chúng ta xong rồi."],[6239,6406,"Anh buông tha tôi đi"],[6406,6498,"và sống tiếp đi."],[6602,6710,"Con nghe cô ấy nói rồi đấy."],[6802,6902,"Đừng để bố thấy"],[6902,7102,"con quấy rối cô ấy lần nữa."],[7236,7436,"Nếu không thì đừng trách bố."],[7457,7499,"Rõ chưa?"],[7761,7795,"Rõ rồi."]],"23":[[45,171,"Anh xin lỗi vì mọi chuyện."],[241,304,"Anh đừng nói vậy."],[308,354,"Adam mới là người"],[354,475,"làm em tổn thương, không phải anh."],[579,684,"Anh thấy mình có trách nhiệm"],[684,804,"khi thằng bé thành ra như vậy."],[842,955,"Em từng gặng hỏi"],[955,1134,"nhưng Adam chẳng bao giờ chịu"],[1134,1242,"nói về bố mẹ."],[1251,1476,"Rốt cuộc đã có chuyện gì?"],[1518,1634,"Mandy,"],[1664,1780,"mẹ của Adam."],[1910,2031,"Anh và cô ấy"],[2056,2114,"đến với nhau"],[2114,2231,"khá chóng vánh,"],[2331,2573,"rồi cô ấy mang thai."],[2711,2907,"Bọn anh đã quyết định làm điều đúng đắn."],[2915,3065,"Cả hai kết hôn và sinh ra Adam,"],[3078,3219,"nhưng sau một thời gian"],[3257,3486,"cô ấy thấy ngột ngạt, và cảm thấy"],[3495,3632,"phải đệ đơn ly hôn."],[3874,3903,"Em biết không,"],[3908,4024,"anh đã cất công tìm, nhưng không thể"],[4024,4083,"tìm ra."],[4083,4229,"Họ trốn quá kỹ."],[4333,4487,"Mãi đến tận vài năm trước,"],[4496,4642,"Adam mới quay lại đời anh."],[4650,4833,"Nhưng thằng bé không còn là"],[4842,5050,"cậu bé ngoan ngoãn"],[5059,5180,"như anh từng nhớ."],[5188,5288,"Thảo nào anh và Adam"],[5288,5447,"trông chẳng hề thân thiết."],[5451,5655,"Em rất tiếc."],[5818,5939,"Đời là vậy mà."],[6252,6368,"Nhưng mọi chuyện đã qua rồi."],[6544,6623,"Anh chỉ cảm thấy"],[6623,6810,"thật may mắn khi có em."]],"24":[[1359,1480,"Tiền bạc không thành vấn đề."],[1488,1689,"Tôi muốn khu đất ở phía Tây đó."],[1730,1893,"Mấy giếng nước đó sẽ"],[1893,2027,"đáng giá hàng tỷ."],[2031,2206,"Nhưng tôi cần các anh đảm bảo"],[2206,2285,"rằng các bản hợp đồng"],[2285,2427,"phải thật hoàn hảo."],[2427,2527,"Marco."],[2761,2877,"Hôm nay tới đây thôi, các vị."],[2882,3003,"Cảm ơn."],[4675,4854,"Em đang mặc áo của tôi đấy."],[4863,4959,"Thế có sao không?"],[4967,5071,"Thưa Chủ nhân?"],[5388,5463,"Em trông còn quyến rũ hơn"],[5463,5572,"khi không mặc gì."],[5689,5889,"Vậy sao em không chiều tôi,"],[6297,6348,"Và giúp tôi"],[6348,6468,"cởi nó ra."],[6802,6927,"Em thật biết cách trêu người."]],"25":[[8779,8917,"Ngài đã về, thưa Chủ nhân."],[9346,9751,"Vậy ra cô là thú cưng mới của Marco."]],"26":[[33,125,"Cô là ai?"],[229,446,"Tôi mới là người phải hỏi câu đó."],[500,596,"Và cô đang làm gì"],[596,796,"trong văn phòng của chồng tôi vậy?"],[809,925,"Cô là Mandy."],[930,1130,"Cô biết tôi sao?"],[1155,1334,"Có vẻ Marco rất chiều chuộng"],[1334,1422,"thú cưng mới của anh ấy."],[1430,1497,"Anh ấy nói hai người"],[1497,1697,"đã ly hôn từ lâu rồi."],[1805,1989,"Chà,"],[1997,2089,"Marco có kể với cô tôi là"],[2089,2235,"sub đầu tiên của anh ấy không?"],[2243,2331,"Tất cả những người khác"],[2331,2427,"chỉ là kẻ thế chỗ"],[2427,2619,"vì anh ấy không thể có lại tôi."],[2627,2736,"Giờ thì biến đi."],[2744,2944,"Marco bảo tôi đợi ở đây."],[2998,3148,"Là vợ cũ,"],[3157,3311,"cô không có quyền bảo tôi"],[3311,3399,"rời đi."],[3407,3653,"Ồ, vậy sao?"],[3762,3858,"Chắc cô thích tôi"],[3858,4058,"phải dùng biện pháp mạnh."],[4120,4195,"Đừng động vào cô ấy!"],[4204,4341,"Marco!"],[4350,4504,"Anh về rồi."],[4512,4637,"Em thực sự rất nhớ anh."],[4642,4721,"Anh có nhớ em không?"]],"27":[[37,120,"Đừng động vào cô ấy!"],[129,258,"Marco!"],[266,400,"Anh về rồi."],[429,513,"Em thực sự rất nhớ anh."],[592,713,"Anh có nhớ em không?"],[734,888,"Cô làm gì ở đây?"],[896,938,"Em chỉ"],[938,1109,"dạy dỗ thú cưng của anh thôi."],[1163,1355,"Sao anh phải căng thẳng thế?"],[1363,1564,"Bỏ tay ra khỏi người cô ấy."],[1647,1760,"Thôi nào."],[1768,1968,"Cô ta chỉ là một sub thôi."],[2077,2331,"Ồ, em hiểu rồi."],[2473,2540,"Anh thực sự"],[2540,2677,"phải lòng cô ta rồi à?"],[2798,2940,"Không ngờ gu của anh"],[2940,3040,"lại xuống cấp đến thế"],[3040,3144,"từ khi bỏ em."],[3186,3303,"Không phải việc của cô."],[3311,3499,"Giờ thì biến khỏi đây và đừng"],[3499,3653,"quay lại khi tôi chưa cho phép."],[4371,4454,"Cô ta có làm em đau không?"],[4462,4662,"Không, em đâu cho cô ta cơ hội."],[5000,5201,"Này, nhìn anh đi."],[5226,5326,"Sao thế?"],[5547,5638,"Mandy nói rằng"],[5638,5839,"cô ta là sub đầu tiên của anh."],[5872,6072,"Và sau cô ta, anh còn nhiều người khác."],[6285,6410,"Marco, em là gì của anh?"]],"28":[[12,150,"Em biết anh quan tâm em mà."],[204,237,"Vâng."],[241,296,"Cũng như cách anh"],[296,496,"quan tâm mọi sub khác của anh."],[517,684,"Còn Mandy là người đầu tiên."],[692,875,"Sao em lại bận tâm chuyện đó?"],[884,1034,"Vì rất đau"],[1042,1146,"khi nghĩ đến mọi thứ"],[1146,1238,"chúng ta đã chia sẻ,"],[1247,1347,"và anh cũng từng chia sẻ"],[1347,1518,"điều tương tự với người khác."],[1526,1580,"Anh-"],[1614,1659,"Anh thậm chí từng hủy"],[1659,1776,"hợp đồng của chúng ta."],[1785,1889,"Và giờ em mới nhận ra"],[1889,1993,"em quan tâm đến anh"],[1993,2189,"nhiều hơn em tưởng."],[2198,2435,"Điều đó làm em sợ."],[3365,3445,"Phải."],[3478,3607,"Anh từng có vài sub"],[3607,3703,"trước em."],[3749,3949,"Nhưng chưa ai khiến anh thấy"],[4112,4245,"nghiện thế này."],[4295,4387,"Anh không muốn ai khác"],[4387,4496,"ngoài em."],[4562,4717,"Mandy có thể là người đầu tiên."],[4725,4925,"Nhưng anh muốn em là người cuối cùng."],[5609,5847,"Em muốn anh f**k em."]],"29":[[154,271,"Cởi đồ cho anh."],[329,400,"Không."],[625,792,"Em muốn nằm trên."],[3845,3912,"Đúng là một cô nhóc"],[3912,4083,"hư hỏng, phải không?"],[4170,4346,"Anh định phạt em sao?"],[4354,4458,"Chủ nhân?"],[4642,4842,"Em không tưởng tượng nổi đâu."],[12620,12771,"Cuối tuần này, anh có một bữa tiệc."],[12771,12829,"Và anh muốn em"],[12829,13029,"đi cùng anh làm bạn đồng hành."],[13242,13350,"Nghe tuyệt đấy."],[13350,13605,"Nhưng lỡ Adam thấy chúng ta thì sao?"]],"30":[[29,150,"Lỡ Adam thấy chúng ta thì sao?"],[175,229,"Đừng lo."],[229,283,"Bữa tiệc diễn ra"],[283,350,"ở Washington,"],[350,504,"nơi chúng ta không phải giấu giếm."],[583,617,"Và anh sẽ"],[617,817,"đưa em đi hẹn hò thực sự."],[925,1126,"Em thấy sao?"],[1317,1518,"Vâng. Quyết vậy đi."],[2994,3194,"Anh bắt đầu hối hận vì đưa em đi rồi đấy."],[3203,3365,"Ồ, anh cũng ghen tuông gớm nhỉ."],[3365,3503,"Phải không?"],[3557,3636,"Em vừa đảo mắt"],[3636,3720,"với anh đấy à?"],[3895,4049,"Giờ chúng ta đang ở Washington."],[4058,4145,"Anh làm sao có thể"],[4145,4333,"phạt em ở đây được chứ?"],[4341,4542,"Ồ, anh thừa sức."],[4654,4825,"Cởi quần lót ra ngay đi."]],"31":[[20,221,"Cởi quần lót ra ngay đi."],[6790,6969,"Anh Russo,"],[6977,7094,"tôi rất vui vì anh"],[7094,7207,"đã đến dự tiệc."],[7211,7336,"Rất hân hạnh."],[7344,7545,"Chắc anh nhớ bạn gái tôi, Stephanie chứ."],[7620,7770,"Rất vui được gặp lại anh."],[7778,7824,"Chào chị."],[7853,7978,"Chào Flora. Rất vui được gặp cô."],[7978,8041,"Rất vui được gặp chị."],[8058,8312,"Tôi nghe nói anh đã mua"],[8320,8433,"mảnh đất đó"],[8433,8712,"ở phía tây với giá 100 triệu đô."],[8767,8967,"Anh luôn biết cách đưa ra"],[8975,9104,"những quyết định táo bạo."]],"32":[[8,150,"Tôi chỉ tin vào trực giác"],[150,346,"và luôn có được thứ mình muốn."],[354,500,"Trực giác kinh doanh của ngài Russo"],[500,700,"luôn rất chuẩn xác."],[888,1042,"Vậy anh dự định"],[1042,1259,"làm gì với mảnh đất đó?"],[1368,1568,"Tôi đã có dự tính."],[1597,1743,"Ngay khi nhìn thấy nó,"],[1751,1851,"tôi đã biết nó sẽ"],[1851,1943,"trở thành một trong những"],[1943,2185,"nơi tuyệt đẹp nhất"],[2193,2394,"ở Mỹ."],[3065,3119,"Xin phép mọi người."],[3119,3319,"Tôi sẽ quay lại ngay."],[3611,3732,"Anh vừa nhắc đến"],[3741,3899,"sự tuyệt đẹp."],[4617,4688,"Thôi nào, Flora,"],[4692,4850,"bình tĩnh lại đi."],[5255,5384,"Vâng."],[5847,5943,"Không, không đâu mẹ."],[5943,6126,"Mẹ đừng lo nhé?"],[6135,6235,"Con sẽ làm hòa với bố"],[6235,6368,"để lấy được tiền của ông."],[6702,6831,"Flora?"],[6902,7040,"Em làm gì ở đây vậy?"]],"33":[[79,287,"Flora?"],[287,408,"Em làm gì ở đây vậy?"],[479,771,"Chết tiệt. Không thể để Adam thấy mình."],[867,980,"Flora, đợi đã!"],[1242,1497,"Khỉ thật! Tránh đường ra!"],[2339,2473,"Suýt nữa thì."],[2740,2911,"Không! Không, buông tôi ra!"]],"34":[[0,150,"Không! Buông tôi ra!"],[154,325,"Này, đừng sợ, anh đây."],[496,575,"Em tưởng anh ở trong đó"],[575,671,"bàn chuyện làm ăn."],[713,759,"Đúng vậy,"],[759,850,"nhưng lâu quá,"],[850,938,"nên anh phải ra ngoài"],[938,1063,"tìm em."],[1368,1522,"Thật á?"],[1530,1697,"Anh không thể xa em"],[1697,1897,"dù chỉ một phút à."],[1985,2043,"Em vừa mới lườm"],[2043,2206,"anh nữa đúng không?"],[2281,2352,"Tối nay em"],[2352,2548,"hư quá rồi đấy."],[2585,2702,"Đến lúc cho em thấy"],[2702,2902,"hậu quả rồi."],[2940,3078,"Ý anh là sao?"],[5947,6072,"Flora?"],[6239,6381,"Chúng ta phải dừng lại."],[6473,6673,"Vậy bắt anh dừng đi."],[7490,7628,"Flora, em đó à?"]],"35":[[2369,2473,"Mẹ kiếp!"],[2635,2736,"Alo?"],[2915,3053,"Thỏa thuận đổ bể rồi."],[3286,3332,"Ừ."],[3340,3386,"Được rồi."],[3395,3516,"Tôi đến ngay."],[4337,4512,"Đừng làm vậy với em nữa."],[4521,4658,"Anh hứa."],[5038,5113,"Em đã từng nghĩ đến việc"],[5113,5221,"công khai chuyện này chưa?"],[5643,5739,"Ý anh là-"],[5747,5822,"Anh không muốn giấu"],[5822,5976,"mối quan hệ của chúng ta nữa."],[6060,6172,"Anh muốn mọi người biết"],[6172,6277,"em là của anh."],[6531,6690,"Em cũng muốn vậy nhưng"],[6898,7098,"có lẽ chưa phải lúc."],[7207,7374,"Mọi chuyện vẫn còn quá phức tạp."],[7382,7503,"Không sao."],[7511,7665,"Chúng ta có thể từ từ."],[7845,7970,"Anh thực sự muốn thế sao?"],[8024,8208,"Tất nhiên rồi."],[8216,8345,"Anh đang yêu em mất rồi."]],"36":[[62,162,"Em không biết."],[225,379,"Adam là người yêu cũ của em."],[387,533,"Và cậu ta là con trai anh."],[671,763,"Phải."],[913,1076,"Mỗi khoảnh khắc ở bên anh"],[1080,1155,"em đều thấy như mang tội."],[1155,1297,"Em không thể gạt bỏ được,"],[1480,1593,"nhưng"],[1705,1893,"em chấp nhận điều đó."],[1901,2056,"Còn anh thì sao?"],[2135,2335,"Anh có thể."],[2444,2686,"Vì em cũng yêu anh mất rồi."],[3983,4104,"Flora, khoan đã!"],[4412,4500,"Chết tiệt!"],[4508,4683,"Vậy ra, Flora,"],[4692,4775,"cô nghĩ mình có thể"],[4775,4975,"cắm sừng tôi rồi cứ thế bỏ đi sao."],[5159,5355,"Xong việc này,"],[5363,5563,"tôi sẽ đến tìm cô."],[5584,5743,"Cô sẽ phải là của tôi."],[5751,5851,"Cứ chờ đấy."]],"37":[[179,287,"Xin lỗi vì tối qua"],[287,487,"anh hơi quá trớn."],[588,788,"Anh hứa sẽ không tái phạm."],[821,921,"Không sao đâu anh."],[930,1051,"Sẽ mau mờ thôi."],[1105,1326,"Em phải về đây,"],[1334,1509,"không mẹ lại lo."],[1518,1630,"Được rồi."],[1722,1851,"Gặp em sau."],[2648,2748,"Mẹ."],[2756,2882,"Chào buổi sáng."],[2927,3086,"Chào buổi sáng."],[3132,3278,"Không định giới thiệu sao?"],[3332,3415,"Chàng trai trẻ"],[3415,3503,"đẹp trai này là ai đây?"],[3824,3983,"Chỉ là"],[4216,4275,"Ôi trời ơi."],[4275,4379,"Nói mẹ nghe con"],[4379,4454,"không hẹn hò với người này đi."],[4454,4521,"Ông ta trông đủ tuổi"],[4521,4688,"làm bố con luôn đấy."],[4821,5025,"Chào bà Wade, tôi là Marco Russo."],[5034,5125,"Tôi là"],[5163,5242,"Con và Marco"],[5242,5309,"Khoan đã."],[5317,5522,"Anh Russo, trông anh rất quen."],[5601,5801,"Chúng ta từng gặp nhau chưa?"],[5839,6039,"Mẹ nhận ra Marco sao?"],[6060,6214,"Mẹ biết anh ấy là bố Adam sao?"]],"38":[[75,196,"Vâng, vâng."],[204,404,"Mẹ à, anh Marco"],[433,521,"hay ghé tiệm bánh"],[521,588,"của nhà mình,"],[588,629,"nên chắc mẹ mới"],[629,829,"thấy anh ấy quen đó."],[913,1013,"Marco?"],[1076,1167,"À"],[1167,1267,"Đúng vậy."],[1530,1730,"Vậy nếu anh ta chỉ là khách,"],[1751,1818,"thì sao anh ta lại"],[1818,2010,"đưa con về nhà sau khi"],[2018,2218,"con đi qua đêm chứ?"],[2306,2427,"Chỉ là trùng hợp thôi ạ."],[2427,2565,"Con gặp anh Marco ở tiệc,"],[2573,2802,"tiệc tàn muộn nên anh ấy"],[2811,3011,"ngỏ ý đưa con về."],[3153,3261,"Được rồi."],[3269,3411,"Vậy,"],[3420,3591,"cảm ơn anh, anh Russo."],[3657,3787,"Không có gì đâu ạ."],[3795,4054,"Flora đã về an toàn rồi,"],[4158,4329,"tôi xin phép về trước."],[6156,6356,"Mẹ thấy có gì đó không ổn."],[6402,6523,"Đang có chuyện gì vậy?"],[6523,6773,"Đâu có gì ạ. Con mệt quá thôi."],[6881,7027,"Vậy con giải thích sao về"],[7027,7228,"vết bầm trên tay?"],[7236,7432,"Đừng bảo là vô ý nhé."],[7453,7595,"Có phải anh Russo làm con đau không?"],[7595,7636,"Không đâu mẹ."],[7645,7757,"Không ai làm con đau cả."],[7761,7849,"Con thề đó."],[7941,8033,"Khoan đã."],[8241,8408,"Mối quan hệ"],[8408,8525,"giữa Marco Russo"],[8525,8658,"và Adam Russo là gì?"]],"39":[[83,308,"Marco là bố của Adam."],[404,671,"Ồ, thảo nào trông ông ta quen thế."],[684,809,"Mẹ từng gặp ông ấy ạ?"],[817,1017,"Không, tất nhiên là chưa."],[1172,1330,"Thật ra mẹ chưa kể con chuyện này."],[1388,1514,"Nhưng lúc con bảo"],[1514,1593,"là con sắp cưới"],[1593,1664,"Adam Russo,"],[1664,1810,"mẹ đã tìm tên cậu ta trên mạng."],[1818,1918,"Chắc là mẹ vô tình thấy"],[1918,2006,"ảnh của Adam"],[2006,2206,"chụp cùng bố cậu ta thôi."],[2394,2610,"Có phải ông Russo đó quấy rối con"],[2610,2819,"vì con chia tay con trai ông ta không?"],[3015,3107,"Mẹ gọi cảnh sát đây."],[3107,3153,"Khoan, đừng mẹ!"],[3153,3282,"Mẹ ơi, không ai quấy rối con cả,"],[3282,3428,"nhé? Con lớn rồi."],[3428,3566,"Con tự lo cho bản thân được."],[3570,3770,"Ồ, vậy sao? Thật không?"],[3816,3895,"Mẹ cứ tin con"],[3895,4095,"chuyện này đi, nhé?"],[4208,4350,"Mẹ tin con."],[4458,4567,"Nhưng con biết là có thể kể mẹ nghe"],[4567,4738,"mọi chuyện mà, đúng không?"],[4875,4992,"Con biết ạ."],[5221,5376,"Con yêu mẹ."]],"40":[[575,613,"Mọi chuyện ổn chứ?"],[613,754,"Anh gọi cho em mãi."],[754,880,"Sao em không bắt máy?"],[971,1096,"Đến phòng chơi gặp anh."],[5939,6051,"Trèo lên đi."],[6364,6485,"Vâng, thưa Chủ nhân."],[7011,7194,"Em đẹp đến mê hồn."],[7244,7428,"Nhưng lại bướng bỉnh đến phát bực."],[7724,7849,"Anh sẽ đánh đòn"],[7849,8066,"em thật đau vì tội hư hỏng."],[8229,8404,"Em đã làm gì sai chứ?"],[8516,8654,"Em sẽ làm đúng những gì"],[8654,8746,"anh bảo."],[8754,8846,"Không thắc mắc."],[8846,8954,"Rõ chưa?"],[9034,9163,"Sao anh lại cư xử thế này?"],[9167,9321,"Đây đâu giống anh."],[9330,9496,"Ồ, đây mới là con người thật của anh."],[9496,9626,"Rồi em sẽ thấy."],[9697,9897,"Em còn nhớ từ an toàn của chúng ta chứ?"],[10143,10231,"Paradise."],[10239,10331,"Ngoan lắm."]],"41":[[8,91,"Đây là phạt tội nói dối"],[95,250,"mẹ em về chuyện chúng ta."],[492,579,"Vâng, thưa Chủ nhân."],[734,817,"Đây là phạt vì giấu giếm"],[817,975,"mối quan hệ của hai ta."],[1205,1297,"Vâng, thưa Chủ nhân."],[1305,1438,"Và đây là phạt vì không chịu dừng,"],[1438,1514,"dù em biết rõ"],[1514,1655,"chuyện này hoàn toàn sai trái."],[1993,2077,"Vâng, thưa Chủ nhân."],[2836,2907,"Sao em không nói"],[2907,2994,"từ an toàn?"],[3161,3290,"Vì em muốn xem anh"],[3290,3399,"sẽ đi xa tới đâu."],[3407,3566,"Anh sẽ làm em đau đến mức nào."],[3912,4020,"Đây là phòng chơi của chúng ta"],[4029,4112,"và ta đã có thỏa thuận."],[4116,4200,"Ta chưa bao giờ thỏa thuận"],[4200,4350,"dùng hợp đồng để trả thù."],[4458,4600,"Anh tức giận, nên đã chọn cách"],[4600,4708,"làm tổn thương em."],[4800,4946,"Đây là con người thật của anh sao?"],[5084,5196,"Anh rất xin lỗi."],[5196,5438,"Anh chỉ bực bội chuyện chúng ta."],[5526,5826,"Không, chẳng còn chúng ta nữa đâu."],[5993,6114,"Anh nói đúng."],[6247,6448,"Mối quan hệ này không có tương lai."],[6723,6973,"Em muốn chấm dứt hợp đồng."]],"42":[[212,337,"Bình tĩnh lại đi, Flora."],[396,500,"Mình làm đúng mà."],[3282,3357,"Trời ạ."],[3461,3557,"Chào mừng em quay lại,"],[3624,3774,"vị hôn thê của anh."],[3849,4049,"Anh đập phá tiệm bánh của mẹ tôi sao?"],[4099,4300,"Anh bị điên à?"],[4441,4621,"Anh đã nói rồi, em không"],[4621,4846,"được quyền kết thúc chuyện đôi ta."],[5292,5492,"Giờ thì, lấy anh đi."],[5526,5726,"Và anh hứa"],[5739,5897,"sẽ không ai động đến tiệm bánh"],[5897,6006,"nữa."],[6264,6431,"Anh điên rồi."],[6431,6498,"Tôi sẽ báo"],[6498,6531,"cảnh sát,"],[6531,6656,"và anh sẽ phải vào tù."],[6656,6856,"Em nên nghĩ kỹ lại đi."],[6952,7127,"Anh có quen biết đấy, Flora,"],[7190,7390,"từ cảnh sát đến nhiều thế lực khác."],[7424,7549,"Anh sẽ không sao đâu."],[7620,7820,"Nhưng em và mẹ em"],[7899,8062,"chưa chắc đã may mắn vậy đâu."],[8504,8679,"Anh không dám đâu."],[8687,8804,"Cứ thử xem."],[8933,9154,"Giờ anh hỏi em"],[9230,9446,"một lần nữa."],[9584,9784,"Em sẽ lấy anh chứ?"],[10126,10226,"Được thôi."],[10356,10556,"Tôi sẽ lấy anh,"],[10589,10664,"đồ khốn."]],"43":[[300,358,"Được rồi, Adam."],[358,496,"Sao chúng ta lại ở đây?"],[546,633,"Tôi không đói."],[633,738,"Tôi đã bảo là tôi bị cảm rồi."],[738,896,"Tôi chỉ muốn về nhà ngủ thôi."],[934,1121,"Ngồi đi, chúng ta đến đây để bàn"],[1121,1272,"chuyện đám cưới với bố mẹ anh."],[1280,1426,"Hiểu chứ? Đừng có làm hỏng chuyện đấy."],[1426,1476,"Khoan, khoan đã."],[1484,1597,"Chúng ta đến gặp bố mẹ anh á?"],[1597,1860,"Cứ mỉm cười và cư xử ngoan ngoãn."],[1897,1976,"Chúng ta có thể thuyết phục"],[1976,2177,"bố anh rằng chúng ta đang yêu nhau, hiểu chứ?"],[2198,2327,"Ông ấy có thể sẽ cho chúng ta biệt thự đấy."],[3440,3616,"Bố! Chào bố."],[3716,3916,"Đây là Flora Wade."],[3995,4133,"Vợ sắp cưới của con."],[4596,4771,"Con biết hai người đã gặp nhau,"],[4779,4917,"nhưng giờ con mới có thể"],[4925,5125,"chính thức giới thiệu."],[5288,5442,"Thật vậy sao?"],[5501,5568,"Cô thực sự định"],[5568,5668,"cưới con trai tôi ư?"]],"44":[[233,375,"Nghĩ đến mẹ cô đi."],[633,809,"Đúng vậy, thưa ông Russo."],[863,1088,"Chúng cháu có cãi vã một chút."],[1088,1213,"Nhưng giờ làm hòa rồi."],[1634,1701,"Bố."],[1822,1943,"Bố, bố ổn chứ?"],[2060,2156,"Ừ."],[2231,2381,"Bố chỉ là,"],[2448,2623,"quá mừng cho hai đứa thôi."],[2811,2873,"Hãy bàn"],[2873,2973,"chuyện đám cưới nào."],[3399,3482,"Con và Flora"],[3482,3645,"đang rất mong chờ đám cưới."],[3691,3795,"Con đã đặt một chuyên cơ"],[3803,4049,"để chở hàng ngàn đóa hồng cao cấp"],[4049,4129,"từ Columbia về."],[4137,4225,"Vâng,"],[4233,4358,"chuyện ăn uống cũng lo xong rồi."],[4358,4537,"Tất nhiên là từ khắp nơi trên thế giới."],[4546,4688,"Từ các nhà hàng ngon nhất."],[4750,4884,"Và vâng,"],[4884,4938,"bọn con sẽ"],[4938,4996,"ở lại"],[4996,5121,"khách sạn con gửi bố lúc trước."],[5309,5401,"Em thấy sao, em yêu?"],[5467,5534,"Nghe tuyệt lắm."],[5534,5734,"Mọi thứ tùy anh quyết định."],[5764,5897,"Thôi nào."],[5905,6035,"Đây là đám cưới của chúng ta mà."],[6076,6193,"Được rồi, nên anh muốn"],[6193,6322,"em nói ra bất cứ thứ gì em cần."],[6381,6527,"Anh chắc bố cũng muốn vậy."],[6785,7065,"Đúng thế, cô Wade."],[7132,7219,"Bất cứ điều gì cô muốn."],[7469,7603,"Thật ra có một điều"],[7603,7682,"cháu muốn từ ông."]],"45":[[116,204,"Ông đang nghe đây."],[504,650,"Dạ,"],[658,829,"bố cháu mất từ khi cháu còn nhỏ."],[875,1051,"Nên cháu tự hỏi liệu ông,"],[1051,1192,"ông Russo, có thể"],[1238,1305,"dắt tay cháu"],[1305,1438,"vào lễ đường và"],[1518,1718,"trao tay cháu cho Adam không?"],[1997,2156,"Đó thực sự là điều cháu muốn sao?"],[2256,2410,"Ông đã nói cháu có thể yêu cầu bất cứ điều gì mà."],[2907,3094,"Coi như ông đồng ý."],[3324,3566,"Tuyệt quá."],[3682,3883,"Đám cưới của chúng ta sẽ thật hoàn hảo."],[4074,4275,"Xin lỗi, tôi đến muộn."],[4900,4971,"Thôi xong."],[4971,5121,"Mindy biết mình đã ở cùng Marco."]],"46":[[258,346,"Ồ."],[433,658,"Cháu hẳn là vị hôn thê của Adam."],[759,880,"Cháu không sao chứ?"],[996,1067,"Cháu ổn ạ."],[1071,1167,"Chỉ là"],[1259,1430,"cháu bị cảm thôi."],[1543,1668,"Thế à, nhưng"],[1714,1881,"sao trông cháu quen thế?"],[1939,2139,"Chúng ta từng gặp nhau chưa?"],[2214,2414,"Cháu không nghĩ vậy đâu ạ."],[2531,2673,"À,"],[2681,2882,"Mong cháu mau khỏe."],[2907,2940,"Cháu cảm ơn."],[2944,3019,"Thực ra cháu đang thấy"],[3019,3073,"hơi chóng mặt."],[3078,3203,"Chắc cháu xin phép về trước."],[3207,3324,"Thật sao?"],[3332,3516,"Ngay lúc này á?"],[3524,3603,"Flora, mẹ anh"],[3607,3732,"vừa mới đến mà."],[3741,3924,"Ừ, bố cũng có cuộc họp."],[3933,4083,"Hay hôm nay đến đây thôi?"],[4433,4542,"Vâng."],[4550,4667,"Được ạ."],[4675,4875,"Nếu bố đã nói thế."],[5180,5305,"Chuyện quái gì đã xảy ra"],[5305,5397,"trước khi tôi đến vậy?"]],"47":[[617,713,"Lên xe đi."],[1080,1272,"Để anh đưa em về nhà."],[4450,4575,"Cảm ơn anh đã đưa về."],[4654,4842,"Em thực sự định cưới Adam sao?"],[5213,5359,"Vậy thì có sao đâu?"],[5405,5618,"Nếu không thể ở bên người em yêu,"],[5618,5722,"thì cuối cùng em lấy ai"],[5722,5847,"cũng có khác gì nhau đâu?"],[5855,5980,"Đừng làm vậy."],[5989,6143,"Con trai anh không hợp làm chồng đâu."],[6143,6343,"Nó sẽ làm em đau khổ đấy."],[6360,6456,"Anh nghĩ trái tim em"],[6456,6656,"chưa đủ tan nát sao?"],[7073,7115,"Này."],[7265,7374,"Đừng khóc."],[7503,7557,"Em còn cả một tương lai"],[7557,7699,"tươi sáng phía trước."],[8020,8153,"Bỏ nó đi, anh sẽ giúp em"],[8153,8354,"làm lại từ đầu ở bất cứ đâu em muốn."],[8483,8683,"Nếu em bỏ Adam,"],[8742,8837,"anh sẽ cưới em chứ?"]],"48":[[458,538,"Em không muốn thế đâu."],[542,579,"Chúng ta"],[579,671,"còn chẳng dám"],[671,871,"nói sự thật cho mẹ em."],[942,1126,"Vậy giờ ai mới là kẻ hèn đây?"],[1134,1326,"Không phải là hèn nhát."],[1334,1426,"Trong lúc xa nhau,"],[1426,1626,"anh đã nghĩ rất nhiều về hai ta."],[1730,1868,"Nếu ở bên anh, em sẽ"],[1868,2060,"không bao giờ thoát khỏi Adam."],[2068,2164,"Và thử nghĩ xem người ta"],[2164,2243,"sẽ nói gì"],[2243,2444,"về chuyện chúng ta kết hôn."],[2502,2669,"Thì sao chứ?"],[2677,2877,"Ai thèm quan tâm họ nói gì?"],[3023,3224,"Em sẽ không hạnh phúc bên anh đâu."],[3303,3453,"Em sẽ hạnh phúc bên anh,"],[3453,3620,"Marco."],[3628,3795,"Em yêu anh."],[4200,4371,"Anh cũng yêu em."],[4512,4713,"Nhưng em vẫn còn quá trẻ."],[4742,4859,"Em xứng đáng với một người"],[4859,4925,"phù hợp với em hơn."],[4925,5146,"Một người... trạc tuổi em."],[5192,5309,"Không có bí mật nào."],[5309,5547,"Không, em không muốn ai khác"],[5555,5755,"ngoài anh."],[7503,7703,"Hai người đang làm gì vậy?"],[7803,7987,"Flora, vào nhà ngay!"],[8033,8158,"Vào nhà ngay lập tức!"],[8433,8562,"Còn ông thì không, ông Russo."],[8562,8604,"Ông không được"],[8604,8712,"chào đón ở nhà tôi."]],"49":[[0,212,"Con đang làm cái trò gì vậy hả?"],[266,508,"Hôn bố của chồng sắp cưới sao?"],[663,825,"Ông ta dụ dỗ con à?"],[834,925,"Không, mẹ. Không đâu."],[934,1076,"Không như mẹ nghĩ đâu."],[1084,1226,"Vậy giải thích cho mẹ xem."],[1234,1363,"Thế con đang làm gì"],[1363,1484,"mà lại hôn ông ta trong xe hả?"],[1484,1718,"Con và Marco yêu nhau."],[1793,1906,"Phải lòng"],[1914,2110,"bố của chồng sắp cưới."],[2168,2302,"Flora, mẹ không-"],[2310,2377,"Mẹ thậm chí chẳng nhận ra"],[2377,2506,"con là ai nữa."],[2515,2594,"Mẹ thậm chí không muốn"],[2594,2794,"nhìn mặt con lúc này."],[2857,2940,"Mẹ. Không. Xin mẹ!"],[3153,3194,"Con chỉ"],[3194,3395,"muốn làm điều đúng đắn."],[3420,3620,"Nhưng cuối cùng,"],[3632,3732,"con lại làm mọi người thất vọng."]],"50":[[3837,3891,"Này."],[3983,4079,"Mai là ngày trọng đại rồi."],[4087,4245,"Ôi, đừng có nhắc nữa."],[4254,4408,"Ai mà ngờ mày"],[4408,4571,"trong đám anh em"],[4579,4675,"lại là đứa đầu tiên"],[4675,4767,"chịu yên bề gia thất."],[4775,4975,"Ôi, câm m** mồm đi, được không?"],[5009,5205,"Tao làm gì có lựa chọn."],[5213,5409,"Cái quỹ tín thác chết tiệt của bố tao quy định"],[5413,5613,"tao chỉ được nhận thừa kế nếu kết hôn."],[5680,5772,"Nếu không thì tao phải đợi"],[5772,5972,"đến tận năm 35 tuổi."],[6026,6131,"Còn khuya tao mới lấy"],[6131,6214,"con b**ch tẻ nhạt đó"],[6214,6339,"nếu không vì tiền."],[6348,6493,"Được rồi,"],[6502,6544,"Được rồi."],[6556,6660,"Bọn mình... mày biết đấy-"],[6664,6777,"Quên hết chuyện đó đi."],[6785,6923,"Đừng làm mất vui."],[6931,6961,"Hơn nữa,"],[6961,7148,"tao có bất ngờ cho mày đây."],[7716,7841,"Chào cưng."],[7849,7941,"Em là Della."],[8016,8128,"Chà,"],[8208,8341,"đúng là một bất ngờ thú vị."]],"51":[[1201,1317,"Thế,"],[1463,1668,"bao nhiêu cho chuyện đó?"],[1805,1868,"Không phải ngày mai"],[1868,1993,"anh lấy vợ sao?"],[2147,2348,"Lỡ vợ sắp cưới của anh biết thì sao?"],[2435,2635,"Cô ta chưa phải vợ anh."],[2911,3111,"Một nghìn."],[3311,3511,"Tới luôn đi."],[5522,5697,"Ôi, ch*t tiệt."],[5705,5905,"Này, anh đi đâu đấy?"],[6260,6460,"Bọn con chỉ đang vui vẻ thôi mà."],[6552,6706,"Mai là đám cưới của mày."],[6715,6802,"Vậy mà mày dám lén lút"],[6802,7002,"sau lưng vợ sắp cưới."],[7015,7215,"Bố quan tâm làm gì?"],[7286,7494,"Flora sẽ không bao giờ biết."],[7524,7661,"Thề có Chúa,"],[7670,7720,"nếu mày không phải"],[7720,7766,"con tao,"],[7766,7811,"tao đã bẻ gãy"],[7811,8012,"từng khúc xương của mày."],[8049,8199,"Thật luôn?"],[8208,8274,"Bố chọn con đ* đó"],[8274,8475,"thay vì con ruột mình."],[8637,8783,"Làm đi."],[8792,8963,"Đánh con nữa đi."],[9067,9184,"Nhớ cho kỹ,"],[9192,9371,"con mới là người kết hôn."],[9380,9526,"Không phải bố."],[9655,9738,"Hay bố ước mình mới là người"],[9738,9801,"cưới cô ta?"]],"52":[[266,404,"Con lớn rồi."],[450,650,"Chung thủy với vợ đi."],[671,842,"Không thì sẽ hối hận đấy."],[1205,1259,"Này, Richard."],[1259,1292,"Xin lỗi"],[1292,1388,"vì gọi muộn thế này,"],[1388,1447,"nhưng tôi cần cậu"],[1447,1547,"giúp một việc."],[1572,1689,"Được, anh cần gì?"],[1743,1893,"Tôi muốn cậu bán câu lạc bộ."],[1901,1997,"Câu lạc bộ Paradise."],[2002,2089,"Bán đi."],[2106,2202,"Sao vậy?"],[2435,2560,"Tôi chán ngấy rồi."],[2569,2690,"Tôi muốn rút lui."],[6260,6327,"Em tưởng anh"],[6327,6398,"sẽ không đến."]],"53":[[16,83,"Con tưởng mẹ sẽ không"],[83,208,"đến chứ."],[216,283,"Sao mẹ có thể bỏ lỡ"],[283,454,"đám cưới của con gái cưng?"],[846,1046,"Mẹ ơi, con xin lỗi."],[1059,1222,"Con không bao giờ muốn làm mẹ thất vọng."],[1230,1497,"Con chưa từng làm mẹ thất vọng."],[1614,1655,"Mẹ không biết"],[1655,1764,"dạo này có chuyện gì,"],[1764,1926,"nhưng mẹ tin là"],[1926,2072,"con có lý do riêng."],[2081,2164,"Cứ làm những gì con cho là"],[2164,2277,"đúng nhé?"],[2285,2485,"Mẹ luôn đứng về phía con."],[3987,4079,"Jessica bảo cô muốn"],[4079,4237,"nói chuyện với tôi."],[4308,4362,"Cô lại giở trò gì"],[4362,4462,"nữa đây?"],[4471,4658,"Tôi muốn hủy hôn."],[4750,4867,"Con kh**n này."],[4867,4921,"Được."],[4929,5130,"Tất cả bạn bè và gia đình tôi"],[5138,5221,"đều đang ở ngoài kia."],[5230,5417,"Nếu cô hủy đám cưới này"],[5417,5518,"và làm tôi bẽ mặt"],[5518,5718,"trước mặt mọi người,"],[5759,5834,"tôi thề"],[5834,6039,"sẽ bắt cô và mẹ cô"],[6047,6118,"phải trả giá."],[6118,6310,"Buông tôi ra. - Này."],[6348,6498,"Rõ chưa hả?"],[6656,6827,"Rồi."],[6965,7190,"M* nó, được rồi."],[7465,7532,"Được rồi."],[7540,7741,"Nghe này, cô là một cô dâu xinh đẹp."],[7799,7932,"Giờ thì cười lên."]],"54":[[2769,2940,"Em đẹp lắm."],[2948,3044,"Anh có yêu em không,"],[3053,3165,"Marco?"],[3174,3236,"Anh không thể làm vậy."],[3236,3307,"Không phải lúc này."],[3307,3370,"Em phải làm vậy."],[3424,3557,"Trước khi đọc lời thề nguyện,"],[3557,3657,"em yêu anh."],[3691,3887,"Anh có yêu em không?"],[3895,3995,"Em biết câu trả lời mà."],[3995,4154,"Vậy thì nói đi."],[4241,4316,"Anh thật sự định"],[4316,4379,"im lặng"],[4379,4437,"và để chuyện này thành"],[4437,4521,"nỗi ân hận lớn nhất"],[4521,4721,"suốt quãng đời còn lại sao?"],[4746,4788,"Anh xin lỗi."],[4788,4871,"Anh không thể."],[7895,7991,"Hôm nay,"],[7999,8145,"chúng ta tề tựu tại đây"],[8153,8274,"để chứng kiến khoảnh khắc"],[8274,8383,"hạnh phúc của"],[8383,8508,"Adam và Flora."],[8516,8604,"Không, khoan đã."]],"55":[[95,166,"Đủ rồi."],[175,296,"Flora."],[304,504,"Cưới anh đi."],[554,629,"Em phải hỏi anh"],[629,829,"một lần cuối."],[938,1138,"Anh muốn em cưới con trai anh sao?"],[1488,1689,"Hay anh muốn em?"],[1976,2052,"Giờ tôi mới nhận ra"],[2052,2185,"cô là ai."],[2277,2435,"Cô là kẻ phục tùng của Marco."],[2444,2644,"Đồ đ* trơ trẽn!"],[2736,2890,"M* kiếp!"],[2898,3007,"Không thể tin nổi!"],[3015,3086,"Cô thật sự"],[3086,3186,"lén lút sau lưng tôi"],[3186,3386,"và ngủ với bố tôi."],[3395,3524,"Để cô ấy yên!"],[4237,4346,"Phải."],[4446,4625,"Anh yêu em."],[4671,4821,"Cái quái gì vậy?"],[4829,4975,"Anh đã luôn trốn tránh cảm xúc này,"],[4975,5150,"nhưng giờ thì không."],[5476,5634,"Em có muốn"],[5638,5805,"cưới anh không?"],[5914,6047,"Có. Có chứ."],[6047,6177,"Ngàn lần đồng ý."],[6177,6247,"Đồng ý."],[6406,6535,"Cái gì?"],[6544,6798,"Vậy cô dâu của tôi giờ thành mẹ kế sao?"]],"56":[[2736,2890,"Không! Marco!"],[3582,3703,"Anh đã làm gì thế này?"],[4375,4429,"Đừng bỏ em!"],[4429,4546,"Anh sẽ không sao đâu."],[4562,4608,"Vâng!"],[4608,4671,"Vâng! Có người-"],[4679,4779,"Có người bị đâm."],[4788,4850,"Vâng. Xin hãy cho"],[4850,4925,"người đến ngay được không?"],[4929,5050,"Địa chỉ ở đâu ạ?"],[5050,5134,"Có người"],[5209,5271,"Anh sẽ không sao đâu."],[5271,5388,"Không, làm ơn nhanh lên."],[5388,5451,"Anh sẽ ổn thôi."],[6435,6681,"Cậu xem tin tức sáng nay chưa?"],[6690,6752,"Thật không thể tin nổi."],[6752,6948,"Adam chỉ lãnh án 3 năm thôi sao?"],[6952,7203,"Mình biết, nhưng đó là điều Marco muốn."],[7253,7453,"Ừ, chắc vậy là tốt nhất rồi."],[7532,7620,"Khi nào Marco"],[7620,7699,"xuất viện vậy?"],[7703,7816,"Ngày mai."],[7824,7878,"Nhưng anh ấy không muốn"],[7878,7941,"mình đến đón"],[7941,8045,"vì-"],[8158,8366,"Ôi! Cậu thấy trong người sao rồi?"],[8379,8483,"Khỏe lắm."],[8516,8629,"Ồ. Ai vậy nhỉ?"],[8662,8712,"Để mình ra mở cửa."],[8721,8858,"Ừ."],[9784,9926,"Này, có chuyện gì vậy?"],[9934,10026,"Anh xuất viện sớm một ngày"],[10026,10168,"và muốn tạo bất ngờ cho em"],[10168,10251,"với con."],[10251,10402,"Ôi, anh cố tình làm thế mà."],[10410,10564,"Anh nhớ em điên lên được."]]}