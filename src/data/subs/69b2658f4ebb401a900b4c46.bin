{"1":[[2392,2484,"What's your name?"],[2572,2652,"Rosemary."],[4388,4524,"Tonight's spotlight:"],[4528,4632,"Caroline Miller,"],[4632,4852,"Chief Marketing Officer of the Miller Group,"],[4872,5116,"known as \"The Execution Machine \"—"],[5116,5344,"calm, efficient, the backbone holding"],[5344,5568,"the entire conglomerate steady."],[5768,5876,"Peter, give me that proposal"],[5876,5952,"by tomorrow."],[6016,6164,"Once I land the Rousseau deal,"],[6164,6328,"that'll be Edward's second surprise."]],"2":[[596,784,"You know, I always took Caroline to be"],[784,876,"such a prude."],[952,1192,"Never thought she'd own something like this."],[1192,1316,"She didn't buy this dress."],[1376,1456,"I did."],[1456,1552,"She only wore it once."],[1552,1600,"But"],[1620,1760,"it looks way better on you."],[2188,2336,"Edward, why you do this?"],[2348,2452,"Stop, Edward!"],[5120,5200,"Caroline."],[5356,5493,"Finally awake?"],[5516,5636,"What are you doing here?"],[5636,5708,"You know you're right."],[5708,5920,"I probably shouldn't be here, but..."],[5976,6168,"You know, Edward was so worried about you."],[6176,6313,"He kept holding me"],[6313,6516,"and saying how pathetic you are."],[6548,6836,"I have something fun you might want to see."],[6836,7000,"Maybe it'll clear your head."],[7396,7544,"Baby, Caroline is just an..."],[7596,7713,"obligation."],[7816,7948,"She's a boring, beautiful portrait"],[7948,8000,"on the wall."],[8020,8297,"What I really want is someone like you."],[8348,8496,"You really know how to make a girl"],[8496,8619,"feel special."],[9208,9369,"Easy now, bestie."],[9428,9580,"And once you're getting all worked up"],[9580,9801,"in this fragile state,"],[9801,9995,"you might just lose the baby."],[10072,10376,"Wait, your baby's already dead."],[10376,10460,"No, it's not true!"],[10460,10864,"Your very existence is wrong, Caroline!"],[10892,11168,"Everything you have... It should've been mine."],[11208,11324,"But that's fine,"],[11324,11560,"because now your house is mine."],[11872,11966,"Sign it."]],"3":[[28,236,"All your things? Well, I burned them."],[260,476,"The house feels much cleaner"],[476,572,"without them!"],[748,936,"Oh, and one more thing,"],[984,1248,"this whole hospital belongs to my brother."],[1260,1472,"So sign it, and you walk free."],[1520,1835,"Refuse, and we'll just call this an \"accident\"."],[1835,1904,"Your choice."],[1904,1980,"Get out!"],[2668,2788,"Vanessa, you're insane!"],[2820,2984,"You're a goddamn monster!"],[2984,3249,"Fine, just bleed out there."],[4168,4264,"Help!"],[4744,4856,"Help..."],[4856,4980,"Somebody help me!"]],"4":[[640,752,"Caroline,"],[752,920,"you are always so sharp"],[980,1196,"and easy on the eyes."],[1272,1612,"No wonder Edward calls you the company's ace."],[1700,1807,"I think everyone here has an ace"],[1807,1880,"in their own way."],[1988,2064,"Cheers, guys."],[2140,2232,"Cheers."],[3696,3864,"If you'll excuse me,"],[3900,4080,"I need to use the ladies' room."],[4720,4984,"And I need to make a phone call."],[7620,7764,"Aren't you worried Caroline's gonna"],[7764,7832,"find out?"],[7836,7940,"Not at all."],[7976,8084,"Isn't the thrill of getting caught"],[8084,8176,"half the fun?"],[8180,8414,"Besides, she won't catch us."]],"5":[[664,788,"You're awake."],[799,908,"Thanks, God."],[940,1109,"The doctor was worried you wouldn't make it"],[1109,1220,"after the miscarriage."],[1272,1448,"You lost so much blood."],[1572,1680,"How did I end up here?"],[1708,1860,"A gentleman brought you here."],[1892,2012,"He didn't give his name."],[2040,2240,"Just asked to get you the best room,"],[2240,2332,"the best doctor."],[2372,2452,"Then he left."],[2484,2580,"What was he like?"],[2700,2780,"Tall"],[2820,2940,"and grandly handsome."],[2980,3200,"And he left a $1 million cashier's check"],[3200,3320,"with an offer of recovery."],[3368,3528,"Then poof and gone."],[6232,6340,"Where's Edward Miller?"]],"6":[[428,536,"I know everything you and Vanessa"],[536,624,"have been doing."],[708,820,"You want a divorce?"],[820,888,"Fine."],[920,1064,"After everything I've built for Miller Group,"],[1064,1144,"I will not"],[1160,1272,"walk away with nothing."],[1440,1552,"Vera, thank god you're here!"],[1632,1760,"Bring the documents I gave you?"],[2692,2840,"I don't know what documents"],[2840,2960,"you are talking about."],[2960,3168,"But as for settlements,"],[3184,3368,"I'll be fighting for Mr. Miller's"],[3368,3479,"best interests."],[3512,3592,"What are you saying?"],[3700,3792,"You're betraying me, too?"],[3792,3872,"Oh,"],[3960,4144,"Caroline, come on."],[4168,4468,"Betrayal is such a strong word."],[4484,4784,"This isn't a soap opera. It's business."],[4820,4942,"Vera's loyalty is to the CEO,"],[4942,5080,"which is me."],[5120,5223,"It's nothing personal."],[5272,5352,"Perfect."],[5392,5468,"Thanks for showing"],[5468,5612,"what shameless really looks like."],[5760,5952,"You've won for now, not forever."],[6320,6480,"Glad I never sold this place."],[6504,6592,"Pre-marriage buy,"],[6592,6764,"so Edward can't touch it."]],"7":[[664,816,"Hey, here you are!"],[820,976,"VIP's sick of waiting."],[976,1048,"Move!"],[4056,4144,"You're late."],[4240,4336,"If you're upset,"],[4336,4508,"I can just leave."],[5476,5684,"You're wilder than I expected."],[6700,6876,"Your adrenaline's spiking."],[7184,7288,"You're too..."],[7484,7588,"tense."],[7760,7880,"Are you scared of me?"],[8020,8104,"The manager said"],[8104,8340,"you're supposed to be the top girl here."],[8416,8492,"Of course."]],"8":[[432,512,"I work here."],[4100,4212,"On your knees."],[4224,4320,"No."],[4344,4468,"Wrong answer."],[4556,4696,"What you should have said,"],[4820,5076,"\"Yes, Master.\""],[5084,5164,"Enough."],[5240,5452,"I'm not playing your stupid little BDSM game."],[5656,5784,"You broke the rule."],[5828,6064,"Now, it's punishment time."],[8648,8740,"What's your name?"],[8820,8900,"Rosemary."],[9132,9188,"Now,"],[9188,9300,"Rosemary,"],[9412,9580,"surrender to me."]],"9":[[1572,1708,"No. I can't."],[4400,4556,"Per my executive contract,"],[4596,4696,"I have three months."],[4700,5020,"So, Mr. CEO, what's my next assignment?"],[5684,5860,"Assignment? Please."],[5884,6168,"You have no place here. No value."],[6208,6388,"So help me, do yourself a favor and..."],[6432,6500,"get out."],[6528,6704,"The Rousseau deal's still in my hands."],[6724,6844,"Nine figures."],[6844,6936,"If I walk,"],[6988,7096,"that deal walks with me."],[7124,7328,"Cut the crap, Caroline."],[7348,7400,"There's no way"],[7400,7512,"you close the Rousseau deal."],[7512,7684,"They're impossible to land."],[7744,7884,"I'm here to talk business."],[7916,8040,"Just reminding you both,"],[8072,8216,"profit comes first."],[8354,8457,"Wow."],[8472,8624,"The Rousseau project is real."],[8628,8797,"We are talking hundreds of millions."]],"10":[[0,232,"I strongly recommend that Caroline stay"],[232,324,"with Miller Group."],[372,560,"Mr. Miller, don't let personal grudges"],[560,648,"sink this company."],[728,808,"Fine."],[840,924,"If the board insists"],[924,1092,"that she's a crucial role to Rousseau,"],[1092,1172,"then..."],[1320,1628,"Caroline, you can stay. But hear me out."],[1664,1776,"This deal slips,"],[1812,1984,"you'll be digging your own grave."],[2804,3115,"Since you are so confident,"],[3120,3231,"you'll be the one that brings"],[3231,3407,"Rousseau's director to the table."],[3948,4084,"I'll set it up as soon as possible."],[4084,4346,"Oh, please, Caroline. Stop pretending."],[4346,4552,"Like you could land Rousseau's top guy."],[4556,4726,"If he's not here within the month, and I..."],[4726,4821,"I'll know you're bluffing."],[4821,4976,"And if you're lying,"],[4976,5216,"the Miller Group will sue you into the ground."],[5216,5428,"And I won't be there to save you."],[6084,6356,"So, Julien, I heard you're French."],[6356,6500,"Perhaps we could grab a glass of"],[6500,6632,"Corton Charlemagne,"],[6684,6826,"talk Paris nights."],[6831,6924,"I'm not into wine."],[6992,7143,"Even less into you."],[7196,7300,"Well, that's a shame."],[7336,7512,"I happen to like your face."],[9740,9812,"Rosemary."]],"11":[[16,84,"Rosemary."],[116,196,"Now,"],[196,296,"Rosemary,"],[312,557,"surrender to me."],[616,668,"I meant"],[696,792,"your perfume."],[820,912,"Unique."],[972,1036,"I like it."],[1092,1196,"It's custom."],[1196,1376,"Not something you can buy off the shelf."],[1416,1588,"And remember your place."],[2396,2497,"Alright."],[2600,2756,"Let's get started."],[2788,2900,"The Rousseau report."],[2900,3065,"I expect you all to contribute."],[3128,3268,"I'd like to co-lead this project"],[3268,3412,"with Caroline."],[3412,3553,"Look, I know the framework very well,"],[3554,3671,"and I'm very familiar"],[3671,3816,"with Rousseau's key players."],[3823,3927,"And you are...?"],[3938,4056,"Julien."],[4056,4144,"New intern here."],[4144,4225,"It's a pleasure to meet you"],[4225,4363,"in person, Caroline."],[4380,4506,"I heard a lot about you."],[4512,4612,"An intern?"],[4628,4696,"Julien,"],[4696,4863,"I appreciate the enthusiasm,"],[4863,4930,"but"],[4930,5100,"this is a billion-dollar deal,"],[5100,5218,"not a class project."],[5224,5372,"Why not?"],[5372,5516,"We value giving"],[5516,5756,"young talent new opportunities."],[5756,5871,"And as a senior exec,"],[5872,6106,"maybe you should nurture him."],[6106,6222,"Happy to mentor on a project"],[6222,6356,"that won't bankrupt the company."],[6444,6520,"This is not it."],[6520,6644,"He's French."],[6644,6752,"That's leverage."],[6804,6914,"Culture,"],[6928,7042,"language."],[7052,7185,"- You'll need it. - But he's just..."],[7185,7288,"Enough."],[7288,7388,"It's settled."],[7420,7488,"Julien,"],[7568,7652,"welcome to the team."]],"12":[[168,308,"You've changed."],[316,444,"You mean the obedient wife"],[444,572,"you trained so well?"],[680,828,"Sorry to disappoint you, but..."],[876,1000,"she's retired."],[1388,1528,"I've always wondered..."],[1556,1808,"what secrets you share with Vanessa that"],[1840,2094,"I'm just not worthy of hearing?"],[2228,2338,"What secrets?"],[2404,2576,"Like that little private club you run."],[2672,2772,"What's it called again?"],[2827,2918,"Vanta."],[2952,3028,"But...."],[3060,3260,"careful what you ask about, Caroline."],[3260,3565,"Vanta is an adult playground,"],[3584,3891,"one with very specific rules."],[3892,3966,"Rules"],[3968,4280,"that I would be delighted to teach you"],[4306,4380,"personally."],[4380,4480,"Edward, what are you doing?"],[4856,5024,"Sorry to interrupt."],[5024,5193,"Brought the files for tomorrow's meeting."],[5193,5428,"What the hell? Knock next time."],[5428,5479,"I did."],[5480,5660,"You just didn't hear."],[5960,6072,"You okay?"],[6106,6224,"None of your business."]],"13":[[1176,1352,"It can't be him."],[1468,1660,"It can't."],[2928,3064,"You're Mr. Rousseau?"],[3128,3276,"You came here just for me?"],[3328,3464,"Whatever it takes."],[3480,3644,"Please work with Miller Group."],[3828,3968,"Show me what you got."],[4036,4104,"Then..."],[4136,4252,"we can talk business."],[4920,5012,"Drop."],[5700,5812,"Good girl."]],"14":[[2408,2624,"That wasn't part of the rules."],[2696,2840,"You cheated."],[2904,3060,"Know"],[3060,3198,"your place."]],"15":[[892,1021,"She really thinks she can just"],[1021,1172,"win Edward back?"],[1212,1353,"Dream on."],[2468,2652,"It screams your submissive side."],[2684,2796,"Look good."],[2796,2920,"I knew you'd enjoy"],[2920,3028,"wearing something like that."],[3396,3468,"Hold on."],[3468,3607,"What's that supposed to mean?"],[3904,4084,"Caroline."],[4860,4964,"How come you never dress like that"],[4964,5068,"for me before?"],[5208,5368,"Because you didn't deserve it."]],"16":[[36,148,"How come you never dress like that"],[148,244,"for me before?"],[300,468,"Because you didn't deserve it."],[588,676,"So."],[864,1048,"You didn't dress like that for..."],[1096,1168,"me?"],[1484,1615,"You're not worth it."],[1615,1758,"Don't forget."],[1780,1984,"Legally, you're still my wife."],[1984,2104,"If not for me, then"],[2104,2301,"who are you trying to seduce?"],[2424,2528,"Caroline."],[2596,2804,"We need to go over the Rousseau quote."],[2908,3008,"Fine."],[3008,3120,"In my office."],[4660,4712,"Rosemary."],[5724,5825,"Rosemary..."]],"17":[[92,272,"Rosemary..."],[272,496,"that plant on your desk,"],[496,580,"you like it?"],[660,756,"You put that there?"],[1336,1452,"You did all this?"],[1512,1580,"Like it?"],[1644,1732,"Like what?"],[1824,1896,"Rosemary."],[1952,2068,"Rosemary."],[2124,2208,"Now,"],[2208,2344,"surrender"],[2344,2424,"to me."],[2448,2516,"Caroline?"],[2552,2656,"Caroline?"],[4204,4352,"Alright, team, listen up."],[4352,4484,"Presentation draft, Tim."],[4484,4648,"I want the first cut on my desk by Friday."],[4724,4839,"Parts procurement, Lucy."],[4839,4972,"I want all vendor contracts confirmed"],[4972,5036,"by Monday."],[5268,5392,"Caroline,"],[5392,5668,"looks like there's been a misunderstanding."],[5668,5795,"I was actually assigned"],[5795,5959,"the flagship project, and..."],[5959,6096,"I already passed it along"],[6096,6223,"to Lucy and Tim."],[6292,6456,"I'm sorry."],[6456,6716,"Looks like you're a team of one."],[6716,7062,"Unless... is anyone feeling ambitious today?"],[7164,7240,"No?"],[7376,7544,"So that's how you build your teams?"],[7544,7648,"By poaching them?"],[7712,7808,"Or is that just another perk"],[7808,7976,"you get for sleeping with the boss?"],[8012,8136,"Careful, Caroline."],[8156,8334,"You keep running your mouth like that,"],[8334,8480,"and the only \"team\" you'll be a part of"],[8480,8656,"is the unemployment line."],[8656,8776,"And I'll be the one"],[8820,9004,"signing your severance check."],[9168,9344,"Did you just slap me?"],[9344,9420,"You're dead!"]],"18":[[12,124,"You're dead!"],[552,724,"Are you defending her?"],[732,836,"Looks like the Miller Group's"],[836,1044,"\"team spirit\" runs pretty deep."],[1044,1160,"Caroline."],[1160,1308,"She was right about one thing."],[1324,1488,"You are a team of one."],[1544,1668,"Let's make it a team of two."],[1692,1776,"You lead."],[1776,1908,"I execute."],[1908,2024,"We'll land Rousseau."],[2024,2196,"Be smart, Julien."],[2220,2412,"If you fail, you're both out."],[2436,2544,"And I'll make sure you're gone"],[2544,2664,"from the Miller Group."],[2916,3044,"Pick that up."],[3792,3956,"You didn't have to go that far."],[3956,4128,"We've only met a handful of times."],[4172,4268,"Or maybe"],[4308,4532,"we've met more times than you realize."],[4752,4964,"What's your angle, Julien?"],[4984,5070,"You and Vanessa seemed"],[5070,5212,"pretty cozy in the conference room."],[5228,5268,"Look,"],[5268,5420,"I wouldn't read too much into that,"],[5420,5504,"okay?"],[5504,5732,"I'm only interested in the Rousseau account"],[5732,5824,"professionally."],[5864,5956,"It's a challenge."],[6024,6100,"That's it."],[6100,6228,"Really?"],[6252,6347,"Just the account?"]],"19":[[928,984,"Of course."],[1076,1324,"If I pull this off, I get the offer."],[1360,1460,"Wouldn't you agree?"],[2800,2940,"Caroline."],[2940,3092,"You're still at it?"],[3140,3368,"Why don't you cut the act?"],[3368,3452,"But you can't even get"],[3452,3584,"in front of the client."],[3584,3724,"Burning the midnight oil"],[3724,3924,"won't change that."],[3924,4224,"Edward will kick you out soon enough."],[6260,6380,"Hey, Caroline."],[6444,6700,"I brought you some coffee,"],[6776,7076,"and I got you a sandwich."],[7156,7224,"Oh, and..."],[7264,7376,"look, your eyes..."],[7384,7536,"looks like they're killing you, so..."],[7568,7668,"Use this, okay?"],[7668,7748,"They're gonna help."],[8016,8104,"Look, I'm gonna"],[8176,8256,"stay tonight,"],[8276,8348,"okay?"],[8388,8492,"Help you push through."],[8560,8656,"This won't help."],[8744,8896,"I'm not into your type."],[9380,9480,"Tell me,"],[9576,9666,"what's your type?"],[9816,9892,"What are you into?"]],"20":[[176,296,"Tell me."],[324,404,"What's your type?"],[492,596,"What are you into?"],[896,967,"You're late."],[1808,1876,"Relax."],[1876,1952,"It's not you."],[2548,2596,"Okay."],[2668,2772,"Let's get one thing straight."],[2828,3030,"I am the only ally you have"],[3030,3140,"in this entire company."],[3236,3368,"Smart people"],[3388,3492,"play to win."],[3548,3776,"So now teaming up with me isn't optional."],[3868,4000,"It's survival."],[5532,5614,"Get in."],[5684,5779,"Tonight,"],[5836,5939,"I'm your driver."]],"21":[[56,172,"You thinking about something?"],[364,468,"Nice hands."],[540,700,"And those cufflinks are..."],[760,848,"distinctive."],[900,980,"Thanks."],[1072,1172,"They're custom."],[1256,1422,"You can't buy these off the shelf."],[1572,1715,"Too bad it's custom."],[1753,1908,"Not something you can buy off the shelf."],[2212,2336,"Have you lost a matching pair?"],[2664,2715,"Don't tell me"],[2715,2892,"you found one and recognized mine."],[3140,3245,"You trying to get closer to me?"],[3245,3323,"Enough."],[3396,3528,"I'm not someone you can toy with."],[3552,3736,"Well, I like breaking that kind of woman,"],[3804,3972,"turning her into an obedient..."],[4000,4051,"pup."],[8376,8448,"Good girl."]],"22":[[7208,7424,"Is she celebrating something today?"],[7460,7624,"She's a drama queen."],[7644,7920,"She's just trying to get attention."]],"23":[[316,396,"Edward."],[484,692,"You've been so busy lately."],[1214,1313,"Not in my office."],[1313,1452,"I'm... not in the mood."],[1800,1904,"Enough."],[1904,2019,"Don't freak out here."],[2030,2178,"Like \"in the office\""],[2178,2396,"has ever bothered you before!"],[2436,2560,"Don't treat me like I'm stupid."],[2560,2776,"I've been watching you stare at Caroline"],[2776,2856,"all day!"],[3072,3212,"So what?"],[3212,3288,"Don't forget."],[3288,3396,"The divorce isn't finalized."],[3396,3596,"Legally, she's still my wife."],[3892,4080,"How can you do this to me?"],[4304,4440,"I think you're a little confused"],[4440,4540,"about our arrangement."],[4560,4724,"You don't get to ask me questions. You..."],[4736,4824,"You do as you're told."],[5496,5776,"Caroline, you bitch!"],[5836,5996,"I'll make you wish you were"],[5996,6220,"never even born!"],[7164,7252,"Who are you, really?"]],"24":[[28,120,"Who are you, really?"],[196,297,"Every time you show up,"],[297,494,"I get those weird gifts and orders."],[616,696,"Caroline."],[952,1072,"And your touch."],[1204,1332,"You're the man from the club."],[1372,1416,"You've been pulling"],[1416,1544,"all the strings, haven't you?"],[1620,1712,"It doesn't add up."],[1972,2184,"All Vanta's VIPs are big shots."],[2212,2380,"How does an intern even get in?"],[2412,2528,"You ever think"],[2576,2796,"maybe I'm not just an intern?"],[3012,3104,"Caroline!"],[3504,3604,"Hey, wait."],[3620,3796,"What are you doing? Let go of me!"],[3848,3948,"Caroline, you're in there?"],[4016,4164,"Shh."],[4540,4656,"Do you want the truth?"],[4836,4996,"Or do you just want to know"],[5116,5280,"if the guy at the club,"],[5416,5580,"the one that made you burn,"],[5748,5828,"was me?"],[6244,6332,"You're insane."],[6424,6532,"Maybe."],[6604,6688,"But Caroline,"],[6756,7080,"that night, you were crazier."]],"25":[[32,240,"What do you want? Let go of me!"],[344,428,"I assume"],[440,712,"you don't want to get caught, do you?"],[772,924,"Okay. Caroline."],[1084,1212,"I wanna make a deal."],[1452,1560,"On what grounds?"],[1628,2052,"That night, every shiver,"],[2260,2388,"every sound,"],[2388,2552,"I recorded it all,"],[2552,2652,"clear as day."],[2820,3086,"And you wanna see how irresistible"],[3115,3228,"you look?"],[4020,4112,"You're insane."],[4160,4240,"Maybe."],[4356,4576,"But Caroline, you like insane,"],[4576,4660,"don't you?"],[4920,5204,"Get me Edward's transaction list,"],[5204,5304,"the data sheet,"],[5424,5496,"and I will delete"],[5496,5724,"all the footage on this USB."],[6064,6122,"Get off me."],[6122,6380,"Caroline, don't get reckless!"],[6384,6491,"Okay?"],[6491,6820,"Otherwise, Edward is going to find out."],[6952,7084,"We both want him gone."]],"26":[[1508,1588,"What are you doing?"],[3476,3624,"Edward, you in there?"],[3624,3842,"The meeting's starting. Everyone's waiting."],[3884,3992,"Okay, coming."],[4516,4596,"Okay."],[4672,4828,"I'll get you that list."],[4828,4954,"But Miller's encryption..."],[5088,5152,"It's airtight."],[5152,5248,"Nobody cracks that."],[5376,5548,"My hacker friend, X."],[5652,5728,"He can handle it."],[5824,5912,"You know X?"],[5936,6224,"My hacker friend runs a very wide operation."],[6284,6512,"Funny thing is, you happen to be"],[6512,6644,"one of his clients."],[6704,6824,"So the person"],[6824,6940,"pulling the strings was you?"],[6980,7176,"Yeah. And the Vanta persona?"],[7264,7484,"X fabricated the whole thing for me."],[7684,7844,"I'm not some Rousseau heir."],[7988,8144,"Easier, Caroline."],[8192,8304,"You keep pushing,"],[8332,8424,"and I might mistake"],[8424,8578,"vengeance for something else."]],"27":[[24,104,"Fine."],[152,300,"I'll get you that file."],[472,736,"But we split it. We share everything."],[784,864,"Lucky us."],[940,1124,"Looks like we have the same enemy."],[4088,4228,"You dress like this today."],[4292,4448,"You trying to make me lose my head?"],[4544,4748,"Since you can't resist a little temptation..."],[4940,5028,"how disappointing."],[5608,5712,"Shall we talk numbers?"],[6284,6644,"This is the best offer we can make."],[7508,7630,"Not nearly enough."],[7684,7872,"I want a major bump, or I pull the order."],[8060,8188,"So what exactly do you want?"],[8288,8488,"I want the divorce terms renegotiated."],[8508,8644,"Caroline, are you messing with me?"],[8684,8753,"So you never planned on us"],[8753,8848,"getting back together?"],[8848,8984,"I want a fresh start."]],"28":[[0,140,"I want a fresh start."],[224,340,"You're actually serious?"],[408,684,"First, sort the assets. Split everything clean."],[801,1009,"Then maybe I'll give you a shot"],[1009,1141,"at getting back with me."],[2662,2787,"You asked me here?"],[2818,2920,"What's this about?"],[3320,3568,"I have a little present."],[3760,4012,"An authorization letter from Rousseau."],[4072,4196,"How did you get this?"],[4260,4440,"I tweaked their client list a little bit."],[4472,4678,"X handled the rest."],[4732,4830,"Easy for him."],[4924,5068,"So what do you want from me?"],[5276,5356,"Simple."],[5436,5700,"A return on my investment."],[5784,5916,"Submit to my training,"],[6088,6300,"and the letter is yours."],[6450,6563,"Enough, Julien."],[6587,6712,"I'm not your toy."],[6816,6904,"Rules are simple,"],[6972,7052,"okay?"],[7156,7368,"I say, you do."],[7368,7592,"\"Velvet\" is your safe word."],[7648,7916,"You say that, and I stop."],[9604,9920,"Perfect. Hold that pose."]],"29":[[1420,1596,"- Julien... - Shh."],[1776,1986,"A sub doesn't ask questions"],[1986,2240,"unless the master gives permission."],[4804,5064,"Obey my rules,"],[5153,5328,"then you will get your reward."],[5504,5680,"Got it, brat?"],[6884,7004,"Pretty little thing..."],[7060,7220,"but the game's not over."]],"30":[[1032,1232,"Weren't you just training me?"],[1308,1408,"Training"],[1444,1594,"comes in many forms."],[1652,2084,"Mine makes you obedient and addicted."],[2420,2652,"Julien, are you going to ruin me?"],[2680,2760,"Ruin?"],[2792,2904,"No, no, no."],[2992,3100,"I'm gonna make sure"],[3100,3376,"you can never walk away."],[6368,6416,"Hi."],[6416,6696,"Wow, I was not expecting that."],[6696,7008,"Your report was perfect. Utterly brilliant."],[7052,7264,"How about dinner tonight?"],[7264,7384,"We can go over details."],[7496,7672,"Though I've got another report to finish,"],[7780,7904,"since you asked,"],[7904,8028,"I can make some time to talk."],[8076,8188,"Edward, I was..."],[8188,8324,"I'm talking to Caroline."],[8324,8432,"Can't you see that?"],[8500,8620,"Oh, Edward,"],[8620,8784,"so you already had plans tonight."],[8808,8844,"What?"],[8844,8936,"Never mind."],[8936,9076,"I'll just stay working today."],[10700,10940,"What was that look back there? Huh?"],[10940,11113,"Still soft for Edward?"],[11184,11288,"None of your business."],[11340,11488,"Please stop playing house."],[11488,11580,"Games are games."]],"31":[[384,516,"You arrogant lunatic!"],[516,584,"You're mine,"],[636,796,"whether it's a part of the game or not."],[852,972,"Let's make this official."],[1008,1092,"You're taken..."],[1092,1172,"by me."],[1224,1296,"So listen up."],[1324,1440,"Keep that mark"],[1456,1564,"on your neck showing."],[2344,2436,"Raw material costs"],[2436,2632,"saw a small uptick last month."],[2632,2816,"But we kept everything within budget."],[2924,3100,"We're projecting a 32% increase"],[3100,3228,"in procurement next quarter,"],[3320,3520,"focusing resources on the high-margin projects"],[3520,3643,"that I'm overseeing."],[5616,5658,"It has now"],[5658,5824,"come to the end of my presentation."],[5896,6006,"I hope you've taken notes,"],[6006,6125,"but you can always come find me"],[6125,6275,"if you have any questions about anything."],[6432,6540,"Nice work, Caroline."],[6580,6688,"Clean numbers."],[7216,7300,"Hey. Hey!"]],"32":[[180,285,"Hey. Hey!"],[336,475,"Who left that mark on your neck?"],[500,603,"You're playing these games"],[603,733,"right under my nose."],[756,832,"You forgot?"],[876,984,"We are getting a divorce."],[1140,1296,"Since when is it only okay for you and Vanessa"],[1296,1405,"to play these games?"],[1452,1636,"You're daring me?"],[3920,4044,"You're trying to get close to me?"],[4100,4244,"Full disclosure,"],[4256,4359,"I'm not interested."],[4488,4644,"I know your secret —"],[4680,4756,"what's going on"],[4756,4892,"between you and Caroline."],[5076,5140,"You know."],[5184,5328,"Secrets are a funny thing."],[5404,5530,"Sometimes,"],[5530,5705,"people that talk too much"],[5728,5864,"don't always get a second chance"],[5864,5964,"to keep talking."],[6044,6224,"Oh, that's too bad."],[6224,6526,"I happen to like playing with dangerous things."]],"33":[[792,852,"I..."],[1024,1136,"I got carried away."],[1612,1720,"I don't blame you."],[1820,1888,"You getting angry"],[1888,2040,"just proves you still care about me."],[2184,2292,"But you never act."],[2384,2446,"It's hard to tell"],[2446,2584,"how much you actually love me."],[2960,3008,"Baby,"],[3196,3328,"I'll show you."],[3504,3580,"Just wait."],[4552,4616,"Alright."],[4656,4728,"Spit it out."],[4792,4860,"What do you want?"],[4936,5288,"Caroline isn't legally divorced yet."],[5324,5388,"If we have proof"],[5388,5540,"she cheated during the marriage,"],[5572,5697,"she gets nothing."],[5728,5834,"Not a cent."],[5916,6091,"I want us to work together."],[6136,6502,"All I need is some private photos."],[6696,6816,"What's in it for me?"],[6956,7150,"A large sum of money."],[7184,7240,"Money?"],[7296,7372,"That's cute."],[7416,7534,"See, I don't need money."],[7636,7724,"I've got a problem"],[7724,7852,"with the local PD here."],[7912,8092,"So if you have a connection to fix that,"],[8168,8284,"maybe I'll think about it."],[8444,8572,"Funny you should ask."],[8640,8760,"My brother just so happens"],[8760,9000,"to be a very high-ranking officer."]],"34":[[236,440,"This is my brother, Chief Kim."],[472,620,"The one you've been waiting to meet."],[736,796,"Now, it's time"],[796,951,"to make good on your promise."],[1108,1196,"Let's see..."],[2732,2840,"Well, Julien,"],[2892,3192,"this is such a surprise."],[3292,3380,"This gift could take"],[3380,3531,"everything away from Caroline."],[4464,4749,"Oh, the French are generous, huh?"],[4772,4922,"My problem is with the cops."],[4960,5088,"Go after him."],[5088,5195,"See if you've got the guts."],[5372,5444,"Trouble?"],[5520,5804,"Kid, you're underestimating me."],[5804,5936,"I took care of a cop once."],[5996,6112,"A French one, too."],[6140,6308,"Looks like... you."],[6360,6456,"Oh."],[6548,6664,"You sure you're not bluffing?"],[6756,6820,"Tell me,"],[6928,7068,"what was the name of the French cop"],[7068,7136,"that you..."],[7220,7316,"\"took care of\"?"],[7584,7695,"Benjamin."]],"35":[[496,644,"Caroline, can we talk?"],[712,856,"I'd really like for us to try again."],[924,980,"Sure."],[1200,1264,"Really?"],[1348,1492,"Tomorrow are the divorce talks."],[1544,1704,"If you're really serious about starting over,"],[1728,1859,"give up all your assets."],[1944,2066,"Then you can try to win me back."],[2124,2245,"That's ridiculous."],[2260,2448,"You and I both know I can't do that."],[2448,2526,"You don't love me"],[2526,2653,"as much as you say you do."],[2712,2800,"I should've known."],[2800,2940,"You always put profit first."],[2940,3132,"The person you love most is yourself."],[3214,3318,"What?"],[3324,3424,"Caroline."],[3476,3568,"Caroline!"],[4672,4800,"You're trying to shove these"],[4800,4966,"unfair divorce terms down my throat?"],[4984,5088,"Not happening."],[5340,5492,"Hello, everyone."],[5492,5628,"Perfect timing."],[5628,5760,"I just got new evidence"],[5760,5896,"that Caroline over here"],[5896,6072,"has been cheating in her marriage."],[6168,6378,"So, should we all view it together?"]],"36":[[24,204,"By the way, Caroline,"],[204,384,"this is your sex tape"],[384,580,"with your French lover."],[580,792,"He's the one who gave it to me."],[792,980,"You know, you're so creative."],[980,1280,"Who knew you liked being tied up?"],[1352,1524,"Alright, Caroline, get ready"],[1524,1792,"to be embarrassed in front of everyone."],[1792,1884,"Lucy."],[1884,1996,"Project it."],[1996,2171,"Let's see what our dear Caroline"],[2171,2256,"likes to get up to"],[2256,2419,"behind closed doors."],[2668,2812,"Oh my god. Is that..."],[2888,2956,"Oh, no way."],[3404,3532,"Wait. Hold on!"],[3536,3656,"That's not Caroline."],[3656,3788,"That's Vanessa!"],[4752,4804,"Oh, no."],[4804,4932,"No, no, no. Enough!"],[4988,5176,"Vanessa, get the heck out of my office. Now!"],[5224,5320,"You!"],[5320,5548,"This is all your fault, you bitch!"],[5548,5812,"You and that French bastard set me up!"]],"37":[[8,308,"You and that French bastard set me up!"],[388,592,"You think I'm still the same easy mark?"],[592,728,"You're the bitch here."],[728,814,"Ah!"],[948,1116,"Vanessa, this isn't my doing."],[1152,1280,"You set yourself up."],[1344,1440,"Don't act like you can keep"],[1440,1563,"stepping on people to get ahead."],[1588,1656,"From now on,"],[1728,1904,"you're the one who's gonna pay for it."],[2316,2432,"Serves you right."],[2500,2636,"She just lost her face"],[2636,2732,"big time."],[2780,2924,"Get out of here!"],[2924,3176,"All of you! Get out! Out!"],[3272,3384,"Ugh!"],[4720,4796,"Caroline."],[4848,4998,"I don't even know where to begin."],[5080,5144,"I was..."],[5324,5416,"I was blind."],[5520,5648,"I was fooled by her."],[5776,5900,"I don't want a divorce."],[6000,6155,"We can rewrite the settlement."],[6216,6436,"Get you what you actually deserve."],[6540,6620,"Even more."],[6780,6884,"I want to win you back."],[6996,7080,"Just like before."]],"38":[[1968,2176,"He's hardly left her side lately."],[2176,2296,"They're even holding hands."],[2340,2476,"Think she's gone soft?"],[2576,2640,"So..."],[2744,2920,"that's how you play it,"],[2920,3040,"my dear."],[3388,3632,"Caroline, you damn bitch!"],[3632,3732,"What? You get divorced"],[3732,4028,"and then you just crawl back into his bed."],[4028,4176,"The divorce is not final yet."],[4176,4324,"She is still his wife, you know."],[4384,4489,"The real bitch is the one"],[4489,4709,"who jumps into someone else's marriage."],[5000,5104,"Shut up!"],[5104,5300,"All of you, get out!"],[5464,5580,"Get out of here now!"]],"39":[[364,470,"Baby, you know,"],[568,748,"you still belong to me."],[885,995,"Well, that depends on how you act"],[995,1093,"from now on."],[1176,1292,"Don't make me wait."],[1524,1576,"Edward."],[1612,1764,"Urgent docs for your signature."],[2132,2202,"Wait right here."],[2256,2332,"I'll be right back."],[4368,4464,"What are you doing?"],[4512,4600,"Checking e-mails."]],"40":[[688,816,"Go through with the divorce."],[876,1020,"I dare you."],[1048,1160,"I'll lock you out of everything."],[1212,1292,"But"],[1380,1492,"tonight..."],[1612,1672,"you"],[1748,1848,"are still my wife."],[2024,2130,"Then stop threatening me"],[2130,2236,"and start talking."],[2288,2392,"What are your terms?"],[2456,2536,"Be crystal clear."],[2536,2720,"You are really"],[2720,2880,"going to bring up divorce right now?"],[2880,3015,"You keep pushing me"],[3015,3100,"and pushing me."],[3108,3317,"And my patience is running thin."],[3480,3556,"Edward!"],[3760,3884,"Let go of me!"],[4720,4808,"You are..."],[4892,5048,"You're just a stupid intern."],[5048,5244,"You're fired!"],[5292,5404,"Get out! Now!"],[5480,5540,"Sorry, boss."],[5540,5717,"I thought I just saw someone"],[5717,5836,"messing with an employee."],[5932,5976,"I..."],[6200,6240,"You!"]],"41":[[500,590,"Do you like it"],[604,760,"when Edward grabs you like that?"],[760,840,"Huh?"],[940,1020,"Jealous?"],[1156,1236,"Tonight,"],[1284,1404,"I will show you"],[1444,1556,"who you belong to."],[1612,1696,"I did it for you."],[1772,2004,"For me? Should I, uh,"],[2044,2236,"say thank you, huh?"],[2300,2424,"Do you know how it feels"],[2424,2564,"watching you with him?"],[2600,2668,"It feels like"],[2668,2832,"someone's twisting a damn knife"],[2840,2952,"through my chest."],[3852,4032,"I want you to remember"],[4228,4356,"who you belong to."],[4444,4648,"No, no, no."],[4684,4820,"This is just the beginning."],[6568,6728,"You really like torturing me, huh?"],[6816,6936,"Say the word,"],[7024,7120,"and I'll stop."],[7356,7496,"I'm not gonna beg you."],[8996,9268,"Don't ever leave me, okay?"],[9268,9568,"Don't ever tempt anyone else. Got it?"],[9892,10064,"This is the encrypted list you wanted."],[10172,10252,"Take a look."],[10324,10404,"Tonight,"],[10544,10660,"I only want you."]],"42":[[332,536,"Oh my god, what happened?"],[620,768,"Who did this to you?"],[1480,1560,"Edward."],[1960,2108,"Julien faked the video."],[2164,2292,"I would never cheat on you."],[2384,2520,"It's always been you."],[2780,2892,"Julien again？"],[3040,3128,"Get him out."],[3200,3280,"Now."],[3360,3452,"I'll get rid of him."],[3532,3660,"If he crossed you,"],[3660,3852,"then I'll fire him myself."],[5460,5540,"You're so sweet."],[6300,6380,"Julien."],[6476,6634,"You arrogant asshole."],[6668,6808,"Draft your resignation."],[6872,6952,"Now!"],[7016,7108,"Why should I quit?"],[7176,7336,"For punching the sleazy boss"],[7336,7488,"who was groping his ex-wife?"],[7696,7908,"Do you think no one can touch you?"],[7976,8284,"I represent Edward, the CEO,"],[8284,8422,"and I want you gone."],[8496,8576,"Fire me?"],[8668,8744,"No, I don't think"],[8744,8888,"you have the power to do that."],[9268,9412,"Do you know who I am?"]],"43":[[364,420,"That..."],[420,632,"How is that possible?"],[772,860,"No."],[987,1100,"Impossible."],[1400,1460,"What is it now?"],[1460,1592,"Intern, why are you still here?"],[1844,1948,"Good afternoon, sir."],[1952,2180,"This is Miller Group's newest mega deal"],[2204,2312,"from France's Rousseau."],[2352,2482,"I closed it."],[2482,2860,"Contract value: $1 billion."],[2918,3028,"If I walk,"],[3100,3197,"that deal is dead."],[4486,4607,"$1 billion?"],[4607,4840,"You really expect us to believe this?"],[4869,5016,"You're an intern."],[5056,5224,"It's impossible. It's fake!"],[5292,5495,"Well, good luck forging Rousseau's letterhead."],[5540,5696,"No one's been dumb enough to try."],[5724,5804,"Simple choice."],[5860,5964,"You keep me,"],[6028,6108,"or you keep her."],[6224,6364,"The decision is yours."],[7347,7454,"Vanessa."],[7536,7703,"You're fired. Effective immediately."]],"44":[[100,180,"What?"],[260,472,"Edward, you can't be serious!"],[500,548,"Are you really"],[548,768,"choosing this intern over me?"],[804,900,"An intern!"],[900,1180,"Edward, you are being insane!"],[1204,1364,"I've seen Rousseau's security seal."],[1364,1424,"This letter?"],[1460,1540,"It's legit."],[1584,1756,"$1 billion, Vanessa."],[1756,1856,"Are you really worth one billion?"],[1856,1900,"Oh."],[1920,2108,"So this is about the money?"],[2120,2256,"What about all the meals"],[2256,2352,"I cooked for you?"],[2368,2528,"And all the messes I cleaned up for you?"],[2528,2685,"How about all the deals I landed...?"],[2685,2920,"Spare me the martyr act, Vanessa!"],[2968,3050,"I know exactly"],[3050,3243,"what you did to close those deals and..."],[3324,3404,"who you did it with."],[3804,4100,"Listen, Edward, you'll regret this!"],[4100,4240,"Don't think you can dump me"],[4240,4344,"and just walk away."],[4344,4532,"You are nothing without me!"],[4532,4704,"You can't leave me!"],[4792,4868,"You're mine!"],[4868,4988,"Edward, you're mine!"],[4988,5120,"You can't walk away!"],[5120,5268,"You will regret this!"],[5292,5440,"You will regret this!"],[6344,6528,"Security, get her out of here!"],[6592,6792,"No, no!"],[6792,6932,"Mark my words!"],[6932,7027,"This isn't over!"],[7027,7284,"Not until you are all on your knees,"],[7284,7635,"begging for mercy that I will not give you!"],[8280,8400,"You pathetic bitch!"]],"45":[[84,244,"You pathetic bitch!"],[244,440,"Don't think for a second anyone believes you"],[440,616,"actually won that account on merit."],[644,776,"I heard exactly"],[776,1048,"what you had to do to close it."],[1268,1388,"All you've ever had to do to close"],[1388,1503,"is get on your knees."],[1528,1576,"Don't assume"],[1576,1724,"everyone else operates the same way."],[1724,2032,"Please, don't act so pure, Caroline."],[2044,2216,"The only difference between you and me"],[2216,2368,"is I get paid for it."],[2372,2624,"You just call it a \"relationship\"."],[3876,4052,"How do you like that, bitch!"],[4052,4264,"Nice and wet, filthy!"],[4312,4444,"Enough, you psycho!"],[5004,5144,"There are no cameras here."],[5184,5416,"No one here to hear you scream!"],[5416,5564,"I'm gonna make you suffer."],[5564,5700,"And I'm gonna make you wish"],[5700,5832,"you were never even born!"],[5880,6044,"You're the one who's gonna be begging."],[6540,6664,"You bitch!"],[6668,6828,"Did you just hit me?"],[7184,7320,"You said there were no cameras."]],"46":[[640,740,"Don't worry, okay?"],[804,884,"I got you."],[1360,1504,"I will make everyone"],[1584,1715,"that hurt you pay."],[3440,3612,"Vanessa, you need to resign."],[3668,3780,"Rousseau just blacklisted you"],[3780,3900,"across the industry."],[3928,4088,"I can't have you dragging Miller down."],[4212,4315,"Edward..."],[4908,5120,"Why is this happening?"],[5440,5580,"Vanessa, bad news."],[5584,5679,"Your funds,"],[5679,5892,"your investments, they're crashing."],[5924,6072,"It looks like a targeted short."],[6148,6324,"I'm sorry. I did what I could."],[6404,6484,"No..."],[6520,6772,"No, no, no!"],[6880,7018,"Why is this happening?"],[7018,7248,"Who is trying to ruin me?"],[7248,7280,"Who?"]],"47":[[808,908,"Who the hell are you?"],[960,1016,"And how did you pull"],[1016,1180,"a billion-dollar deal with Rousseau?"],[1244,1337,"Don't dare tell me"],[1337,1439,"it was your little hacker buddy \"X\""],[1439,1562,"who did all the dirty work."],[1660,1852,"I am X."],[1884,1964,"Figures."],[2040,2188,"So what's your deal with the Rousseau heir?"],[2280,2388,"He had a brother,"],[2480,2680,"Benjamin Rousseau."],[2748,2948,"An Interpol undercover."],[3032,3272,"Three months ago, he went into Vanta Club"],[3288,3580,"to trace illicit assets and gray deals."],[3792,3900,"He never came back."],[3988,4152,"Local cops called it an..."],[4204,4360,"\"accidental death\"."],[6320,6600,"When I was investigating Vanta as X,"],[6728,6808,"I first met you."],[6920,7108,"Caroline, you were at your lowest"],[7120,7300,"when Edward was cheating with Vanessa."],[7460,7672,"Later, I went back as a customer."],[7800,7938,"That's when we first met."],[8000,8080,"Oh, great."],[8132,8308,"So you already knew about Edward and Vanessa?"],[8400,8480,"How comforting."],[9304,9548,"The man who \"saved\" me was you, wasn't he?"],[10088,10248,"You came to me with a purpose."],[10328,10460,"I don't care about"],[10460,10640,"your personal vendetta with Edward."],[10660,10752,"That's on you."],[10812,10936,"Everything that happened to me?"],[10936,11012,"You set it in motion."],[11012,11176,"You used me from the start."],[11176,11300,"Caroline..."],[11300,11388,"I am done"],[11416,11520,"with liars."],[11688,11780,"We're finished."]],"48":[[792,876,"So..."],[952,1064,"I looked into Julien."],[1108,1244,"You know he's really shady, right?"],[1276,1380,"No one knows his past,"],[1380,1552,"and his resume in Miller Group?"],[1624,1696,"Fake."],[1852,1964,"I can't believe you're staying with him."],[2036,2144,"You really are?"],[2252,2408,"Vanessa's shown her true colors."],[2584,2664,"Please,"],[2728,2791,"come back."],[2984,3084,"I'll give you everything."],[3688,3888,"You said you have good news?"],[3968,4068,"Took your advice."],[4128,4252,"I broke things off with Julien."],[4312,4408,"Smart move."],[4536,4616,"So"],[4664,4764,"about your promise..."],[4844,4948,"Call the shareholders' meeting,"],[4948,5024,"push Rousseau through,"],[5024,5172,"and make my authority official."],[5212,5504,"Of course, we're partners."],[5532,5664,"What's yours is mine, and..."],[5664,5784,"mine is yours."],[6332,6407,"This signing"],[6407,6564,"is critical to Miller's future."],[6616,6724,"I officially announce:"],[6812,7016,"Caroline has full decision-making authority"],[7016,7176,"for these negotiations."],[7684,7904,"Now, whatever Rousseau wants,"],[7904,8044,"the board will follow."],[8084,8248,"This is my decision as CEO."],[8296,8468,"This is Caroline's official appointment."],[9268,9344,"Hello."],[9344,9512,"I'm here representing Rousseau."],[9644,9720,"Our terms:"],[9720,10048,"Rousseau names Caroline the exclusive rep"],[10068,10176,"and a beneficiary."],[10204,10316,"If you want to keep the deal,"],[10424,10500,"give her the equity."]],"49":[[108,207,"You can't make Caroline"],[207,320,"a sole beneficiary on her own."],[320,448,"Julien, are you insane?"],[532,664,"That's Rousseau's condition."],[728,808,"Take it or leave it."],[832,1016,"I fully trust the board to decide."],[1152,1230,"As Miller's rep"],[1230,1442,"and decision maker, I accept."],[1442,1696,"You bitch! You played me!"],[1776,1912,"Edward, you can't backtrack."],[1912,2064,"You just named Caroline in charge."],[2104,2219,"Yeah. If we flip now,"],[2219,2364,"Miller's reputation gets wrecked."],[2396,2478,"If we want the order,"],[2478,2576,"we accept the terms."],[2636,2756,"Are you..."],[2784,2904,"Are you all insane?"],[2928,3152,"This... this is a setup."],[3164,3304,"This woman and that Frenchman?"],[3356,3532,"They're trying to gut Miller Group."],[3536,3680,"Feels like you abused your power"],[3680,3764,"for personal gain."],[3772,3836,"We've decided."],[3836,4004,"Move forward with Julien's terms."],[4004,4132,"Nothing's bigger than this order."],[4600,4648,"Fine."],[4708,4788,"Fine!"],[4956,5036,"Caroline."],[5156,5236,"You win."],[5964,6044,"Okay."],[6116,6236,"Let's go over the process"],[6236,6316,"and the details."],[6772,6852,"Caroline."],[7004,7168,"I lost it, okay?"],[7168,7348,"Think about what we had."],[7420,7468,"You?"],[7524,7620,"You belong to me."],[7620,7732,"You're not leaving."],[7848,7908,"Let go."],[8284,8352,"Who do you think you are,"],[8352,8456,"acting like this?"],[8548,8604,"Alright?"],[8604,8800,"I am sick and tired of your..."]],"50":[[396,476,"You're dead."],[1116,1196,"Alright."],[1244,1312,"Don't be afraid, okay?"],[1320,1384,"I got you."],[2652,2821,"Don't think this means I forgive you."],[2920,3068,"You used me from the start."],[3160,3240,"You're right."],[3396,3476,"I screwed up."],[3628,3696,"But we agreed"],[3696,3928,"the split was to fool Edward."],[4028,4240,"I can't say any more right now, okay?"],[4348,4428,"But you'll see."],[4512,4716,"Look, I'm not here for revenge or"],[4772,4888,"any sort of scheme."],[5020,5116,"I'm here for you."],[5392,5472,"Caroline."],[5592,5688,"I love you."],[5808,6000,"Saving you wasn't part of the plan."],[6108,6216,"From the moment"],[6300,6408,"I first saw you,"],[6516,6624,"I was drawn to you."]],"51":[[24,192,"Need any"],[192,360,"extra instructions?"],[424,504,"No."],[636,760,"I'm right where I want to be."],[848,924,"Just hold me."],[2548,2808,"Nice of you to finally show up."],[2872,3020,"I had Julien checked out."],[3140,3288,"I think he's targeting me."],[3352,3448,"Go and get Kim."],[3496,3586,"Have him handled."],[4180,4312,"Wasn't that the cop that"],[4376,4468,"Kim took out...?"],[4608,4720,"He's French too, wasn't he?"],[4856,4955,"Don't you think"],[4955,5194,"that cop also looks like Julien?"],[6304,6448,"Caroline."],[6556,6832,"Baby, I missed you so much."],[7020,7277,"Leave that French guy. He's..."],[7277,7367,"real shady."],[7367,7572,"He doesn't love you like I do."],[7584,7684,"Get off me."],[8184,8248,"What do I have to do"],[8248,8552,"to make you forgive me?"],[8664,8824,"I dream about you"],[8892,9004,"all the time."],[9128,9336,"You always wear that black suit,"],[9388,9592,"sitting at my desk,"],[9592,9736,"cleaning up my messes."],[9804,9931,"I don't wear that black suit"],[9931,10041,"anymore, Edward."],[10076,10196,"You betrayed me."],[10224,10320,"You filed for divorce"],[10320,10448,"the minute I lost the baby."],[10496,10744,"How dare you crawl back now?"]],"52":[[20,60,"Oh."],[60,132,"God."],[132,276,"Caroline, I know."],[372,548,"I know you hate me, but"],[608,808,"it's not my fault, okay?"],[860,984,"And that's just always like"],[984,1128,"stirring up the pot."],[1128,1198,"And then there's..."],[1198,1296,"you know, Julien..."],[1296,1456,"Julien gets things done."],[1536,1608,"And unlike you,"],[1608,1776,"he reminds me that I'm still alive."],[1912,2108,"In every possible way."],[3108,3200,"Before we start,"],[3284,3364,"Edward,"],[3464,3579,"you need to see this."],[5876,5928,"Caroline."],[5928,6008,"Wait up."],[6124,6204,"Yes?"],[6268,6428,"First, congrats."],[6456,6584,"Huge win on the divorce."],[6628,6768,"You got what you deserved,"],[6772,6976,"and congrats on being single again."],[7008,7097,"On what authority"],[7097,7224,"are you congratulating me?"],[7224,7312,"Vera."],[7312,7424,"You're Edward's lawyer."],[7452,7548,"Last I checked,"],[7568,7676,"we aren't friends."],[7736,7828,"We need to talk."],[7828,7968,"There's nothing to talk about."],[8068,8156,"What if I told you"],[8156,8408,"Edward's been hiding other marital assets."],[8812,8924,"Find a place to talk?"]],"53":[[60,144,"Look."],[144,324,"I didn't have my choice before."],[328,460,"Let me buy you a drink, okay?"],[516,628,"Don't waste my time."],[664,840,"If you've got value, spit it out."],[944,1004,"Caroline."],[1004,1180,"Think like me for a second."],[1182,1304,"I'm Miller's counsel"],[1340,1432,"and a mom of three."],[1432,1556,"I've got to protect my job."],[1556,1720,"I can't cross Edward."],[1744,1928,"This time, I'm sincere."],[1928,2032,"I want to help."],[2056,2180,"Save it."],[2180,2356,"I don't want your excuses."],[3668,3804,"Still don't trust me?"],[5004,5228,"Well, that's just too damn bad, Caroline."],[5236,5404,"Stupid as always."],[5552,5628,"Nice work."]],"54":[[1160,1380,"Oh, Caroline."],[1716,1840,"Don't be shy."],[2032,2208,"I know you're used to this."],[2208,2370,"I know all about"],[2370,2620,"your little games with that Frenchman."],[2756,2856,"Every secret."],[3648,3728,"Now"],[3812,3964,"before I erase him,"],[4176,4408,"I want to rediscover"],[4408,4716,"every part of you he touched."],[5952,6180,"Now, Kim's outside."],[6236,6360,"And once I'm done with you,"],[6400,6548,"Kim is going to kill you"],[6548,6696,"and make it look like an accident."],[6732,7064,"Just like your lover boy's little brother."],[8168,8244,"Julien?"]],"55":[[728,804,"What?"],[1208,1332,"Hey, let me go."],[1336,1472,"What are you doing?"],[2104,2456,"This is Spirytus Rektyfikowany."],[2456,2680,"Ninety-six percent ABV."],[2760,2972,"Pour this on any open wound and..."],[3148,3232,"No."],[3252,3364,"It'll sting like hell."],[3364,3580,"How dare you?"],[3632,3724,"This is my company."],[3724,3872,"This is Vanta."],[4012,4132,"No, no."],[4176,4292,"Not anymore."],[4392,4692,"See, after Vanessa's stocks crashed."],[4744,4936,"She dumped Vanta's shares."],[5050,5204,"And you know, that means"],[5204,5372,"the ones she held for you—"],[5540,5624,"gone."],[5708,5832,"But"],[5934,6031,"Vanta"],[6420,6588,"now belongs to me."],[6636,6824,"No more dirty deals around here."],[7084,7216,"Vanessa. That idiot."],[7396,7452,"The cops have"],[7452,7540,"all the proof they need"],[7540,7680,"that Kim killed Benjamin."],[7744,7912,"Your backup's gone."],[8004,8080,"But I mean,"],[8080,8156,"don't worry."],[8180,8375,"I'm pretty sure that Caroline..."],[8375,8476,"What?"],[8476,8660,"will take excellent care of you."],[9224,9400,"No."],[9428,9700,"No, no, please, you, you really can't..."],[10260,10400,"Okay."],[10400,10512,"I..."],[10512,10656,"I was..."],[10656,10876,"I was wrong, okay?"],[10948,11024,"Please."],[11024,11132,"Please have mercy on..."],[11240,11404,"You betrayed our marriage."],[11484,11620,"You killed my baby."],[11927,12072,"No, no."],[12248,12364,"You and Vanessa"],[12364,12660,"staged that whole public humiliation."]],"56":[[1220,1300,"Who are you?"],[1368,1492,"What do you want?"],[1492,1568,"You know what you did."],[1604,1728,"Come with us to the station."],[1884,2116,"Don't make it harder for yourself."],[2392,2548,"How do you have this much pull...?"],[2700,2896,"Time will tell."],[3052,3204,"Doesn't matter anymore."],[3260,3371,"If you're not the Rousseau heir,"],[3371,3584,"then you're not exactly ordinary, either."],[5676,5752,"After tonight,"],[5752,5912,"I might be done with that game."],[6040,6172,"Will that disappoint you?"],[6272,6476,"No. No, no, no."],[6564,6756,"I fell in love with the woman"],[6796,6972,"who isn't afraid of pleasure."],[7060,7204,"The game was never part of it."],[9140,9376,"I'll pay back."],[9376,9600,"Whatever it costs."],[9600,10028,"Julien bought Vanta and fired the manager."],[10116,10288,"The guy gave me this."],[10524,10654,"Caroline slipped in"],[10654,10896,"disguised as a performer."],[10896,11032,"Tapes on here."]],"57":[[500,680,"Always so prim at work..."],[704,871,"Who knew she played that wild?"],[996,1176,"Guess talent wasn't the only thing"],[1176,1300,"getting her this far."],[1388,1656,"Yeah. I went to that BDSM club."],[1656,1891,"I mean, after all, Edward forced me."],[1931,2040,"I went to get the evidence"],[2040,2204,"on Edward's offshore accounts."],[2240,2429,"Evidence to protect myself."],[2468,2572,"Evidence?"],[2572,2748,"Or a little field test?"],[2760,2912,"Who can tell?"],[2912,2972,"My sex life"],[2972,3148,"is not a topic for public debate."],[3192,3460,"What I did was with someone I trust."],[3492,3579,"Just more than I can say"],[3579,3707,"for anyone here."],[3888,4120,"Her \"someone\" isn't that intern, is it?"],[4148,4344,"Heard he's got serious connections."],[4480,4632,"You filthy little slut."],[4632,4776,"You are going to—"],[5147,5226,"Shit."],[5380,5448,"Okay."],[5448,5568,"Now I get it."],[5596,5764,"That is an upgrade."],[5804,5920,"He just took a chair"],[5920,6036,"to the back for her."],[6048,6148,"Is he insane?"],[6148,6296,"Her name is Caroline."],[6316,6448,"And I'm her boyfriend."],[6448,6636,"So if any of you"],[6636,6776,"are gonna talk about her,"],[6788,6860,"listen to me,"],[6860,7044,"you can say it to my damn face."],[7044,7165,"Oh."],[7208,7304,"And yes."],[7380,7480,"We met at Vanta."]],"58":[[56,192,"Holy shit."],[192,272,"Okay."],[272,424,"Team Julien."],[424,504,"We have fun."],[504,600,"You should try it sometime."],[872,1200,"Caroline, you handled that like a champ."],[1212,1372,"Yeah, we all saw."],[1400,1452,"Owning it"],[1452,1692,"beats sneaking around and playing dirty."],[2184,2264,"Edward."],[2344,2498,"My brother took the fall for you,"],[2498,2684,"and you still left me."],[2764,2976,"I fucking hate you!"],[3184,3364,"Thanks to Caroline,"],[3388,3528,"the Rousseau-Miller deal went through."],[3528,3653,"Profits are up big."],[3664,3812,"Our market cap has doubled."],[3876,4004,"So I'll take my cut,"],[4004,4116,"per our agreement."],[4116,4172,"Of course."],[4172,4352,"Caroline was the key to this deal."],[4384,4450,"Without her,"],[4450,4584,"we wouldn't have the contract."],[4608,4754,"Also, the board has voted"],[4754,4987,"to promote Caroline to CMO of Miller."],[5004,5136,"Don't get cocky."],[5204,5412,"Cash out now while you still can."],[5512,5592,"Or"],[5636,5822,"I won't hesitate to burn this place down"],[5822,5989,"with you in it."],[7252,7388,"Caroline."],[7388,7540,"It's time we end this."]],"59":[[288,413,"Miller Group"],[413,636,"was just acquired by Rousseau."],[636,768,"And you,"],[768,860,"Caroline,"],[888,1160,"Rousseau appointed you the CEO."],[2148,2268,"Rousseau pulled all the orders."],[2268,2476,"Every new deal is gone."],[2524,2580,"Caroline."],[2588,2736,"How the hell can you run this place?"],[2840,3096,"You'll pay for the losses."],[3392,3500,"You bitch!"],[3500,3624,"You don't deserve that seat."],[3692,3788,"Edward."],[3864,3960,"You're fired."],[4756,4936,"Oh God."],[4936,5116,"Caroline, have you lost it?"],[5148,5224,"You think you can fire me?"],[5224,5344,"Who the hell do you think you are?"],[5740,5956,"I'm Rousseau's newly appointed CEO."],[6100,6264,"That gives me full authority."],[6320,6440,"Expect your termination email."],[6880,6960,"Fake."],[7064,7172,"All of it."],[7220,7312,"Rousseau would never"],[7312,7560,"put someone like you in charge."],[7760,7884,"You?"],[7884,7976,"You're just a girl"],[7976,8168,"I used up and tossed aside."],[8168,8328,"So why don't you show me some respect?"],[8328,8390,"Or I'll make you"],[8390,8648,"get on your hands and knees and beg."],[9056,9110,"That's it."],[9110,9220,"You're done for. You know that?"],[9220,9284,"I'm gonna make sure..."],[9284,9376,"Edward Miller."],[9376,9464,"You are under arrest"],[9464,9588,"for fraud, sex trafficking,"],[9588,9760,"money laundering, and murder."]],"60":[[144,252,"No."],[316,508,"Caroline set me up. You have nothing..."],[508,576,"The victims"],[576,780,"turned in a full evidence chain."],[780,984,"And Vanessa's cooperating with the FBI."],[984,1048,"She handed over"],[1048,1248,"all your transaction records."],[1532,1612,"No..."],[2508,2588,"Well."],[2736,2841,"Since you've been wanting to"],[2841,2987,"meet Rousseau's heir,"],[3068,3204,"I think the timing is right."],[3212,3444,"Let me introduce you to my friend,"],[3476,3596,"your new boss."],[4560,4708,"A hotel for a meeting?"],[4804,4912,"Weird choice."],[4972,5148,"Aren't you gonna say hi to your boss?"],[5272,5352,"You?"],[5412,5520,"You're the Rousseau heir?"],[5924,6004,"Caroline."],[6132,6193,"Will you let me"],[6193,6400,"dominate you for life?"],[6404,6500,"Marry me."],[6744,6824,"No."],[7084,7214,"Next time,"],[7214,7394,"I'll be the one to dominate you."]]}