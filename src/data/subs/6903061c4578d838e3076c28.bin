{"1":[[283,371,"Alright, ladies."],[408,487,"Today we'll be learning"],[487,667,"how to do a pelvic ultrasound."],[742,779,"Cora,"],[796,942,"we'll use you for our demonstration."],[1084,1197,"Yes, Dr. Mills."],[2293,2481,"Now, take a close look."],[2686,2886,"This is what a typical uterus..."],[3474,3603,"See that dark spot?"],[3616,3753,"That's a gestational sac."],[3762,3887,"I read about it in a book."],[3920,4024,"Cora is pregnant!"],[4558,4654,"Who's the father?"],[4700,4850,"Wait, isn't she single?"],[4875,5100,"OMG, what a slut!"],[5130,5351,"Wow, I guess Little Miss Perfect is"],[5351,5518,"not so innocent after all."],[5593,5739,"Her love life must be a mess."],[5805,5968,"She should be expelled for that."],[5993,6064,"That's enough."],[6097,6318,"That was a polyp, not a fetus,"],[6368,6510,"so no more gossiping."],[6556,6635,"Is that clear?"],[6840,6902,"Now listen."],[6944,7098,"Our new visiting professor,"],[7098,7182,"Dr. Hawkins,"],[7182,7298,"will be here any minute."],[7340,7607,"He's not only a brilliant researcher,"],[7649,7882,"but also the sponsor of this program."],[7895,8166,"And he'll be hand picking interns"],[8166,8254,"for his company."],[8345,8516,"So if you want a shot at the job,"],[8637,8717,"cut the drama."],[8808,8883,"That's all for today."],[8938,9000,"Dismissed."],[9255,9305,"Slut!"],[9592,9634,"Cora,"],[9734,9834,"can I talk to you for a second?"],[10010,10118,"Yes, Dr. Mills."],[10414,10468,"Earlier,"],[10493,10668,"I told the class it was a polyp."],[10764,10935,"But the truth is, it's not."],[11065,11169,"It is a fetus."],[11373,11457,"Wait, what?"],[11565,11749,"So I'm actually pregnant?"],[11895,12012,"What am I supposed to do?"]],"2":[[4,175,"Well, first things first."],[262,417,"You should probably tell the father."],[875,1038,"Howdy there, sweetheart."],[1105,1305,"Join us for a drink?"],[1430,1493,"Out of my-"],[1493,1584,"Don't be shy."],[1634,1776,"We'll show you a good time."],[1860,1893,"Stop!"],[1893,2006,"You got the wrong girl."],[2010,2081,"Seriously!"],[2085,2185,"Now, don't be"],[2185,2364,"pretend to be all innocent now."],[2364,2419,"Stop!"],[2444,2565,"Look at that cute red bra."],[2565,2606,"Come on."],[2606,2660,"Stop!"],[2681,2777,"Come on, open wide."],[2777,2869,"Let go of me!"],[2894,2948,"Stop!"],[2957,3019,"Somebody!"],[3019,3073,"Oh no!"],[3073,3157,"Somebody help!"],[3157,3353,"Oh no!"],[3370,3465,"Let her go!"],[4804,4929,"Who is he?"],[4963,5067,"Who the hell are you?"],[5088,5142,"Get him!"],[6310,6456,"Wait, look at his wrist."],[6531,6648,"That's an Aura Celeste."],[6690,6831,"Twenty million on his wrist."],[6902,6940,"Fuck."],[6994,7123,"We can't afford to mess with this guy."],[7165,7232,"Clear out."],[7269,7311,"Now!"],[7353,7399,"Shit."],[7411,7457,"God."],[7912,7962,"Thank you."],[8274,8345,"Thank you, sir."],[9355,9417,"Hey, hey."],[9459,9513,"Oh my God."],[9576,9651,"Are you alright?"],[9738,9838,"I think I was drugged."],[10014,10076,"What do you need?"],[10185,10231,"Help me."],[10352,10406,"My car."],[10514,10568,"It's,"],[10660,10777,"it's in the back lot."],[10777,10814,"Okay."]],"3":[[91,154,"Hey, hey."],[183,262,"Hey, are you okay?"],[337,425,"Here, I got you."],[1347,1509,"He's nothing like the others."],[1584,1659,"He's"],[1735,1793,"gentle"],[1897,2118,"and so handsome."],[2252,2506,"Is this from when he saved me?"],[3345,3415,"I'm sorry."],[3561,3649,"It's the drugs."],[3762,3883,"They're messing with my head."],[3966,4079,"They make me want you"],[4145,4208,"too much."],[4270,4337,"His skin."],[4408,4496,"He's burning up."],[4571,4667,"I need to help him."],[4963,5130,"I want to help him."],[5405,5480,"You smell"],[5672,5759,"so sweet."],[6865,6931,"I'm sorry."],[6981,7065,"It's the drug."],[7665,7724,"Will you"],[7828,7941,"be gentle"],[8083,8187,"and teach me how?"],[8258,8366,"Is this your first time?"],[8546,8633,"Then I'll go slow."],[8938,9050,"And I'll be a good teacher."],[9634,9718,"He's inside."],[9976,10101,"And I don't want him to stop."],[11649,11690,"No."],[11853,11941,"It was a mistake."],[12053,12153,"A one time thing."],[12362,12466,"But I'm keeping the baby."],[12558,12687,"In case you change your mind,"],[12687,12804,"there are other options"],[12804,12887,"available. - I won't"],[12925,13017,"change my mind."],[13117,13217,"My mom passed away"],[13217,13304,"a few weeks ago."],[13367,13446,"I had no one."],[13546,13609,"But now,"],[13709,13817,"I'll have the baby."]],"4":[[442,517,"My baby..."],[567,754,"What am I supposed to do with you?"],[800,1013,"This is a Dr. Hawkins' class,"],[1038,1172,"the new rotating professor."],[1238,1368,"Good thing we got here early."],[1409,1551,"First row seats."],[1697,1856,"Did you hear about the new professor?"],[1910,1993,"What was his name again?"],[2047,2160,"Dr. Hawkins."],[2181,2456,"I heard Dr. Hawkins is rich,"],[2456,2669,"powerful, and hot."],[2723,2869,"God, I hope he's single."],[2882,3015,"Okay, well, I heard that"],[3015,3111,"Dr. Hawkins owns"],[3111,3328,"like a billion medical laboratories."],[3345,3495,"There's no way that he would fall"],[3495,3657,"for an average medical student."],[5651,5776,"Oh wow."],[5839,6022,"He's younger than I thought"],[6097,6306,"and way hotter."],[7198,7323,"I'm Damon Hawkins,"],[7344,7545,"entrepreneur, investor,"],[7549,7678,"and your guest lecturer"],[7699,7832,"for this semester's course"],[7836,7982,"on Medical Entrepreneurship"],[7987,8066,"and Innovation."],[8095,8183,"I'll be selecting"],[8183,8362,"one outstanding student"],[8375,8479,"to be my assistant"],[8483,8733,"on a confidential research project."],[9818,9855,"No."],[9914,9984,"Oh my God!"],[9993,10051,"It's him!"],[10147,10439,"My baby daddy is my professor?"],[11928,12003,"Do I know you?"]],"5":[[41,116,"Do I know you?"],[221,262,"No."],[333,383,"Um,"],[500,654,"I don't think so, Dr. Hawkins."],[1422,1576,"Is there a problem, Hawkins?"],[1730,1872,"Ah, no."],[2006,2068,"Nothing at all."],[2344,2519,"Well, this is Cora."],[2552,2761,"In fact, she's one of our top students."],[2765,2865,"She's been involved"],[2865,3057,"in almost every research project"],[3057,3161,"you said you were interested in."],[3161,3282,"So, if you're looking"],[3282,3386,"for a research assistant,"],[3403,3536,"she'd be an excellent choice."],[3582,3699,"He doesn't remember me."],[3791,3862,"Why would he?"],[3945,4133,"He's rich and powerful."],[4191,4408,"I was probably just another lay to him."],[4479,4546,"Very well."],[4658,4813,"I'll assign her to be my new RA."],[5171,5313,"Oh my gosh, Cora!"],[5334,5480,"You hit the jackpot!"],[5572,5622,"You're going to be"],[5622,5814,"Hawkins' new assistant!"],[5960,6118,"Congratulations!"],[6193,6410,"Do I tell him that a woman"],[6410,6535,"he doesn't even remember"],[6598,6785,"is now carrying his child?"],[6898,7011,"Would he even want anything"],[7011,7102,"to do with us?"],[7323,7478,"Boss, why'd you pick that Cora girl"],[7478,7590,"to be your assistant?"],[7728,7782,"You into her?"],[7862,7995,"If you have time to chit chat,"],[7995,8108,"you have time to be working."],[8204,8329,"The girl from the bar that night,"],[8337,8495,"have you been able to track her down?"],[8521,8600,"I still got nothing."],[8762,8850,"Boss, if I may,"],[8896,9000,"why are you so determined"],[9000,9134,"to find that girl anyway?"],[9939,10126,"Because she saved me that night."],[10552,10660,"I owe her everything."]],"6":[[204,337,"I can't let Dr. Hawkins know"],[337,425,"I'm pregnant."],[450,650,"With his status and money,"],[650,809,"he could take my baby"],[838,1076,"and I'd have no way to fight back."],[1130,1305,"This child is my everything."],[1359,1518,"I won't let anyone take that."],[1747,1830,"Dr. Smith."],[1835,1876,"Cora."],[1943,2014,"I think it's best"],[2014,2097,"if you pick someone else"],[2097,2223,"to be Dr. Hawkins' RA."],[2306,2352,"Cora,"],[2394,2427,"this is a"],[2427,2590,"once in a lifetime opportunity."],[2648,2752,"I recommended you"],[2752,2923,"because I know your family situation."],[3028,3165,"You impress Dr. Hawkins,"],[3311,3432,"this could be your golden ticket"],[3432,3541,"for your future career."],[3928,4074,"He doesn't remember me anyway."],[4091,4216,"There's nothing to be afraid of."],[4550,4600,"Okay."],[4725,4796,"Okay, I'll do it."],[4854,4900,"Thank you"],[4942,5025,"for the opportunity."],[5034,5059,"Yeah."],[5121,5217,"Come on, get in there."],[5217,5301,"He's waiting on you."],[5518,5563,"Boss,"],[5626,5726,"Miss Johnson is here."],[6364,6498,"Morning, Dr. Hawkins."],[6539,6602,"I'll be assisting you"],[6602,6685,"with your research."],[6690,6856,"If you have any questions"],[6856,6961,"about what we've done so far,"],[6961,7090,"I'd be happy to help."],[7127,7173,"Alright."],[7328,7369,"Tell me,"],[7432,7511,"what do you know"],[7511,7703,"about T cell immunotherapy?"],[8450,8612,"It's a type of experimental therapy"],[8612,8779,"that extracts T-cells from the patient,"],[8796,8954,"genetically modifies them in vitro,"],[8958,9067,"and then reintroduces them"],[9067,9142,"to the patient to directly..."],[9142,9547,"Her voice is intoxicating."],[9601,9693,"That's my understanding"],[9693,9813,"of our current progress."],[9909,10076,"You're Cora, right?"],[10239,10364,"Are you sure"],[10381,10502,"that we've never met before?"],[11069,11194,"Boss, you're scaring her."]],"7":[[304,375,"Dr. Hawkins."],[467,542,"Damn it, Damon."],[567,663,"The girl that you should be"],[663,725,"thinking about"],[725,880,"is the one that saved you that night."],[1142,1226,"Miss Johnson,"],[1297,1359,"I'm sorry."],[1359,1497,"I thought I saw something"],[1497,1572,"on your shirt."],[1572,1856,"If I crossed the line, I apologize."],[1976,2035,"Dr. Hawkins,"],[2035,2177,"if you don't require anything further,"],[2177,2273,"I'll excuse myself."],[3065,3207,"You know, boss, if you're into her,"],[3253,3374,"you could just ask her out."],[3453,3528,"Look, I'm not supposed to"],[3528,3574,"tell you this"],[3574,3807,"but, your grandma's on live TV right now,"],[3807,3945,"and she's trying to get you a wife-"],[3945,4083,"Who said that I'm into her?"],[4175,4362,"Wait, my grandma's doing what?"],[4421,4504,"See for yourself."],[4650,4708,"Ms. Evelyn,"],[4708,4867,"what can you tell us about Damon?"],[4925,5196,"And as I was saying,"],[5217,5409,"he is only 32."],[5417,5618,"He is incredibly handsome,"],[5618,5872,"and not only is he incredibly handsome,"],[5885,6051,"he is filthy rich."],[6076,6222,"So, Damon Hawkins"],[6227,6460,"is looking for his lucky bride,"],[6473,6719,"and that could be you."],[6760,6835,"Great."],[6856,6990,"Grandma's at it again."],[7069,7173,"I mean, can you blame her?"],[7240,7374,"All that wealth and no heir?"],[7478,7582,"I'd be scared too."],[7653,7711,"Save it!"],[7791,7974,"Your only job right now"],[7974,8062,"is to find that girl"],[8062,8153,"that I met at the bar."],[8241,8333,"Understood, boss."]],"8":[[120,262,"That's exactly what I was saying."],[479,688,"Look, Alyssa, there goes Cora Johnson."],[713,825,"Dr. Hawkins picked her"],[825,980,"to be his research assistant today."],[1017,1180,"Fucking social climber bitch."],[1217,1451,"Ew, Damon chose that Cora slut?"],[1488,1572,"Disgusting."],[2118,2227,"Cora Johnson."],[2252,2406,"A broke bitch like you"],[2419,2552,"doesn't deserve to be anywhere"],[2552,2698,"near Dr. Hawkins."],[2731,2902,"How is that any of your business?"],[2948,3140,"Alyssa's dad is one of the biggest"],[3144,3336,"investors of our university."],[3370,3574,"Her family's super close to Dr. Hawkins."],[3574,3770,"If you had a shred of self preservation,"],[3799,3987,"you'd give that RA spot to her."],[3999,4104,"If you have a problem,"],[4166,4358,"address it directly to Dr. Hawkins."],[4446,4537,"Don't bother me."],[5188,5296,"What did you get for lunch, girl?"],[5334,5526,"Oh, this is it for today."],[6564,6652,"Oh my God."],[6744,6848,"Are you nauseous?"],[6919,6990,"I knew it."],[7023,7119,"You are pregnant."],[7223,7311,"She's pregnant?"],[7361,7507,"What a filthy whore."],[7507,7640,"You know, I know you can't afford rent,"],[7640,7803,"but you didn't have to spread your legs"],[7803,7857,"to get it."],[7903,8008,"I bet she doesn't even know"],[8008,8108,"who the father is."],[8149,8187,"Wait."],[8249,8358,"Do you think it's from that time"],[8358,8479,"when we saw her at the nightclub"],[8479,8533,"last month?"],[8616,8717,"That's enough!"],[8754,8992,"She probably just has a stomach bug."],[9013,9209,"You can't say stuff without proof."],[9221,9342,"If she isn't lying,"],[9413,9509,"then prove it."],[9563,9688,"Come with me to the bathroom."],[9780,9880,"And pee on the stick."],[10068,10160,"If it's negative,"],[10247,10343,"I'll get on my knees"],[10343,10493,"and grovel in front of the whole school."]],"9":[[45,141,"Wow Stacy,"],[141,337,"that is a brilliant idea."],[496,596,"What's wrong, Cora?"],[617,684,"Scared?"],[1109,1334,"I don't owe you or anyone proof."],[1368,1468,"And just to be clear,"],[1501,1609,"there's nothing wrong"],[1614,1718,"with being pregnant."],[1747,1906,"If your moms weren't pregnant,"],[1922,2006,"you wouldn't be here"],[2056,2193,"running your fat mouths."],[2206,2285,"You bitch!"],[2327,2502,"You can't even afford to feed yourself."],[2531,2598,"How many more men"],[2598,2665,"are you going to sleep with"],[2665,2802,"to take care of the baby, huh?"],[2877,3032,"That's none of your business."],[3094,3161,"And besides,"],[3199,3282,"why do you even have"],[3282,3357,"a pregnancy test"],[3357,3499,"in your purse in the first place?"],[3595,3728,"Worried you might need it?"],[3903,3970,"They passed them out"],[3970,4049,"in class yesterday."],[4062,4112,"Whatever!"],[4124,4216,"Cora Johnson,"],[4300,4483,"you're a big fat liar."],[4571,4617,"Okay."],[4637,4863,"If you truly have nothing to hide,"],[4992,5155,"pee on the stick."],[5242,5326,"Like I said,"],[5347,5634,"I don't owe anyone an explanation."],[5776,5951,"Especially not you, Alyssa."],[6126,6193,"She's lying."],[6231,6281,"Stacy,"],[6310,6452,"go tell the faculty that she's unfit"],[6452,6585,"to be Dr. Hawkins' assistant."],[6681,6752,"Gladly."],[6952,7044,"Don't you dare."],[7065,7286,"Dr. Hawkins is here for research."],[7294,7436,"Whether I'm pregnant or not"],[7503,7711,"has nothing to do with him."],[7849,8066,"Shut up, okay?"],[8095,8162,"You're nothing"],[8162,8358,"but a slut with a bastard child"],[8358,8470,"that you can't even feed."],[8504,8600,"They'll kick you out"],[8600,8683,"once they realize"],[8683,8817,"you can't afford tuition."]],"10":[[95,191,"Why is he here?"],[258,433,"Did he hear what Stacy was saying?"],[771,917,"What on earth is going on here?"],[950,1038,"Cora's pregnant."],[1176,1222,"What?"],[1405,1539,"No, I can't let him know"],[1539,1647,"I'm carrying his baby."],[1689,1856,"It would ruin everything."],[1897,1972,"You're pregnant?"],[2047,2198,"No, it's not true."],[2198,2385,"I just was nauseous at lunch."],[2448,2565,"They're making stuff up."],[2698,2748,"Stacy,"],[2748,2894,"are you spreading rumors again?"],[2932,3103,"Consider your scholarship revoked."],[3148,3319,"Dr. Smith, we were just concerned"],[3319,3428,"that someone who's pregnant"],[3495,3607,"can't handle the research."],[3845,3899,"Damon,"],[3928,4112,"she's just a poor girl from the boonies."],[4120,4237,"My dad's the president"],[4245,4312,"of the school."],[4383,4454,"Let me be your research"],[4454,4558,"assistant instead."],[4742,5046,"That's Dr. Hawkins to you."],[5105,5309,"I've worked with your father for years,"],[5342,5430,"but that gives you"],[5430,5626,"no special privileges."],[6101,6239,"Is that all you brought for lunch?"],[6485,6539,"Uh,"],[6698,6936,"I just wasn't hungry today."],[7073,7236,"Well, you're under my supervision now."],[7269,7457,"Nobody on my team skips a meal."],[7703,7912,"Come on, let's get you a proper lunch."],[8466,8558,"Alyssa,"],[8583,8762,"this is a medical college,"],[8783,8900,"not one of your family's"],[8900,9042,"annual Christmas parties."],[9067,9129,"I don't care"],[9129,9296,"how powerful your family is."],[9309,9488,"If you keep up these shenanigans,"],[9501,9588,"I'll be forced"],[9693,9834,"to take disciplinary action."],[10093,10260,"The entire time I've known Damon,"],[10260,10456,"he's never had a wife or a girlfriend."],[10456,10585,"So what makes Cora different?"],[10668,10789,"You're sure she's pregnant, right?"],[10806,10894,"A hundred percent."],[10931,11127,"The nausea, the ultrasound."],[11177,11298,"Someone knocked her up."],[11390,11428,"Fine."],[11465,11561,"If she won't admit it,"],[11565,11782,"then we'll just have to make her talk."],[11870,12016,"That stupid little fetus"],[12016,12091,"growing inside of her"],[12112,12253,"will never make it out alive."],[12433,12562,"Lure her into the storage room"],[12562,12675,"and I'll handle the rest."]],"11":[[175,375,"Oh, uh, I'm good."],[792,850,"Monsieur,"],[880,946,"Mademoiselle."],[988,1055,"Bon appétit."],[1313,1343,"Eat."],[1401,1493,"You'll need your protein."],[1493,1614,"We've got a long day in the lab."],[1705,1747,"Okay."],[2423,2481,"Are you okay?"],[2627,2798,"Cora, be honest."],[2877,3015,"Is it really just the nausea?"],[3057,3107,"I,"],[3174,3228,"um..."],[3244,3470,"I don't like when people lie to me."],[3545,3645,"So tell me the truth."],[3991,4049,"I'm pregnant."],[4262,4458,"I promise it won't interfere"],[4458,4525,"with the research,"],[4525,4654,"but I understand"],[4654,4758,"if you want to replace me."],[4871,5009,"Just please don't tell anyone."],[5067,5121,"You're what,"],[5121,5255,"a third-year med student?"],[5255,5409,"Are you and the father still together?"],[5488,5568,"Does it matter?"],[5609,5730,"Of course it matters."],[5830,5905,"It's your life."],[5947,6068,"Your child's life."],[6227,6343,"Did he walk out on you?"],[6460,6610,"Why is she getting under my skin"],[6610,6685,"like this?"],[6740,6877,"She's just a student."],[6961,7032,"My assistant."],[7144,7186,"Look,"],[7265,7428,"never mind what he did."],[7474,7695,"Your life is in your hands now."],[7724,7816,"I'm keeping you on,"],[7903,8041,"as long as the work is solid."],[8074,8320,"And I promise not to say a word"],[8320,8437,"to anyone else."],[8504,8558,"Thank you,"],[8771,8858,"Dr. Hawkins."],[8933,8992,"It's alright."],[9063,9321,"Just tell me, what is your plan after?"],[9388,9555,"I'll finish out the semester."],[9626,9705,"I'll take a gap year"],[9797,9872,"to have the baby."],[9939,10014,"You're throwing away"],[10014,10226,"three years of med school"],[10281,10456,"for a coward that dumped you?"],[10510,10668,"I'm not doing this for him."],[10785,10885,"I'm doing it for me."],[10994,11127,"Dr. Smith told me"],[11127,11282,"about your financial situation."],[11307,11528,"You can barely afford lunch."],[11574,11657,"How are you planning"],[11657,11757,"to raise a child?"],[11820,11916,"I'll start working again."],[12107,12208,"I'll save what I can."],[12291,12366,"No matter what,"],[12399,12583,"I'm protecting this baby."],[13192,13234,"Hello?"],[13334,13430,"Oh, she needs some now."],[13584,13680,"Okay, I'll be right there."],[13784,13880,"Sorry, Dr. Hawkins,"],[13880,13988,"Dr. Mills needs me."],[14055,14105,"She needs something"],[14105,14185,"from the storage room."],[14326,14397,"See you at the lab?"],[14518,14552,"Yeah,"],[14627,14668,"see you."],[14814,14869,"Thanks again."],[15315,15578,"She's pregnant, poor, single,"],[15644,15707,"vulnerable."],[15840,15953,"Why do I want to be the one"],[15953,16028,"to protect her,"],[16066,16141,"to save her?"]],"12":[[1851,1922,"What are you doing?"],[1981,2060,"You slut."],[2106,2268,"I tried to sleep with you for years"],[2268,2348,"and you ignored me"],[2348,2469,"just to get knocked up"],[2469,2623,"by some no-name prick."],[2677,2748,"You tricked me."],[2852,2986,"Dr. Mills didn't need anything."],[3053,3140,"You set me up."],[3178,3286,"Damon doesn't let women"],[3286,3361,"get close to him,"],[3365,3516,"so do tell, Cora,"],[3536,3724,"what tricks did you use to seduce him?"],[3812,3924,"I didn't do anything."],[4008,4133,"He picked me to be his RA"],[4133,4295,"because I know the research best."],[4325,4391,"That's all."],[4487,4587,"Yeah, right."],[4612,4808,"I suspected that you wouldn't spill, so"],[4850,4904,"Stacy,"],[4992,5067,"feed her the pill."],[5096,5226,"You said you're not pregnant, right?"],[5246,5321,"In that case,"],[5347,5526,"this chemical abortion pill"],[5555,5676,"should have no effect on you."],[5826,5955,"How could you do this to me?"],[6014,6177,"You're all in school to be doctors."],[6177,6289,"You know the risks."],[6314,6527,"Uterine damage, infertility,"],[6560,6715,"massive internal hemorrhaging."],[6773,6919,"You'd risk all of that"],[6952,7115,"just to humiliate me?"],[7148,7282,"Well, well, well."],[7319,7440,"Seems like consequences"],[7440,7611,"are a bitter pill to swallow."],[7795,7820,"No."],[7866,8024,"No, no, no!"],[8066,8116,"Stop!"],[8133,8204,"Let me go!"],[8479,8512,"No!"],[8554,8654,"Hold her down."],[8683,8829,"Cora, if you're not pregnant,"],[8829,8921,"then what's the big deal?"],[8996,9117,"Open your fucking mouth"],[9117,9209,"and take the pills."],[9259,9296,"No!"],[9492,9538,"Boss,"],[9601,9847,"you've been acting different"],[9868,9993,"since your lunch with Cora."],[9993,10135,"Did she say something"],[10135,10222,"that pissed you off?"],[10256,10339,"She's pregnant."],[10460,10502,"What?"],[10539,10689,"The father's not even in the picture."],[10806,10910,"Whoever he is,"],[10935,11098,"he is a goddamn asshole!"]],"13":[[12,129,"She wants to keep the baby."],[129,241,"She's willing to throw away"],[241,379,"her entire future"],[404,479,"for this child."],[504,563,"It's too bad."],[583,688,"I really thought you liked her."],[713,763,"Enough!"],[842,930,"What's important now"],[930,1080,"is finding the girl from the bar,"],[1105,1234,"the one that helped me that night."],[1234,1380,"Have you found any trace of her?"],[1497,1530,"Yeah."],[1576,1634,"Wait, what?"],[1705,1768,"Are you sure?"],[1901,1947,"Boss,"],[2006,2060,"it's Cora."],[2152,2289,"The girl that saved you that night"],[2289,2385,"at the bar is none other"],[2385,2540,"than your research assistant,"],[2590,2673,"Cora Johnson."],[2802,2844,"What?"],[2898,2944,"Are you,"],[2986,3048,"are you sure?"],[3069,3240,"Look, that is definitely her."],[3294,3357,"That means that"],[3357,3486,"the child she's carrying..."],[3545,3624,"Could be yours."],[3661,3716,"So, uh,"],[3883,3949,"sorry, boss,"],[3953,4149,"but I guess that damn asshole"],[4149,4312,"was you all along."],[4571,4654,"I'm gonna be a father."],[4879,4979,"Where is she right now?"],[5180,5246,"Stop it!"],[5255,5309,"Stop!"],[5447,5513,"I'm pregnant!"],[5513,5626,"I can't take the pill!"],[5676,5764,"I knew it."],[5839,6047,"Your lies got me in trouble."],[6114,6181,"So now,"],[6210,6285,"you're gonna pay."],[6673,6710,"No!"],[6852,6906,"Please!"],[7069,7165,"Fess up, bitch."],[7228,7315,"Who's the baby daddy?"],[7394,7611,"That's none of your business."],[7695,7732,"Fine."],[7770,7857,"If you won't tell us,"],[7857,7937,"then we'll just have to make sure"],[7937,8087,"there's no baby left."],[8362,8479,"What a coincidence."],[8500,8621,"We just went over abortion pills"],[8621,8708,"in class this week."],[8754,8850,"How did it go again?"],[8913,8975,"That's right."],[9009,9042,"First,"],[9042,9221,"your uterus starts cramping so bad"],[9221,9317,"that it feels like your bones"],[9317,9455,"are breaking from the inside."],[9534,9597,"And, you know,"],[9597,9647,"if you're lucky,"],[9647,9759,"it'll last a few hours."],[9788,9843,"If not,"],[9922,10035,"it can last for days."],[10068,10256,"Either way, it won't be an experience"],[10256,10318,"you'll forget."],[10539,10581,"Please!"],[10673,10710,"No!"],[10756,10802,"Please!"],[10881,10923,"Stop!"],[10994,11065,"Somebody!"],[11065,11111,"Cora!"]],"14":[[137,183,"Cora!"],[404,492,"Where the hell is she?"],[521,629,"She told me to meet her here."],[642,759,"I'll give Miss Johnson a call."],[905,1013,"Boss, she's not picking up."],[1096,1205,"You think something happened to her?"],[1317,1413,"Sorry, Dr. Hawkins,"],[1413,1514,"Dr. Mills needs me."],[1597,1647,"She needs something"],[1647,1726,"from the storage room."],[1818,1889,"The storage room."],[2102,2139,"Cora!"],[2273,2310,"Shh!"],[2752,2815,"He left."],[2911,2944,"No!"],[2965,3111,"No one's coming to save you."],[3123,3174,"Help!"],[3490,3557,"You can't!"],[3603,3732,"Dr. Hawkins is the dad!"],[3862,3991,"If you touch me again,"],[4087,4279,"he'll destroy every last one of you."],[4358,4529,"You trashy whore."],[4529,4617,"You wormed your way"],[4617,4700,"into Damon's bed."],[4804,4900,"I will never"],[4963,5092,"let you have his baby."],[5271,5313,"No!"],[5359,5401,"No!"],[5472,5505,"No!"],[5618,5655,"No!"],[5826,5864,"Fine!"],[5885,5989,"If you won't take the pills,"],[5989,6126,"then we'll just have to do it"],[6126,6272,"the surgical way."],[6802,6835,"No!"],[7265,7303,"No!"],[7340,7390,"Please!"],[7478,7524,"Please!"],[7553,7599,"Stop!"],[7599,7640,"Please!"],[7857,7953,"Hold her down!"],[8003,8053,"Stop!"],[8145,8195,"No!"],[8320,8379,"No!"],[8379,8470,"Go to hell, bitch!"],[8579,8700,"Get your hands off her!"]],"15":[[87,291,"Drop it now!"],[800,892,"Dr. Hawkins!"],[980,1021,"Cora."],[1134,1172,"Cora."],[1330,1380,"Damon,"],[1413,1576,"Cora's pregnant with some hobo's baby."],[1576,1622,"We're just"],[1685,1810,"trying to teach her a lesson, right?"],[2118,2298,"She's mine!"],[2348,2623,"If you ever do anything"],[2648,2727,"to hurt her,"],[2769,3015,"I will destroy you!"],[3073,3136,"Wait, what?"],[3174,3349,"Adam, teach them a lesson."],[3766,3903,"I'm the Wilson family heiress."],[3908,4041,"Don't you dare touch me."],[4054,4200,"You're right, Miss Wilson."],[4216,4325,"I can't hurt you."],[4358,4525,"But Dr. Hawkins is mad."],[4567,4713,"Someone needs to pay."],[4750,4829,"How do you feel about"],[4829,4938,"your two little yes men?"],[4954,5113,"I want you to teach them a lesson."],[5142,5188,"Now!"],[5818,5889,"Are you happy?"],[5926,5989,"Ecstatic."],[6289,6477,"This is all that bitch Cora's fault."],[6623,6744,"I'm gonna destroy her!"],[7223,7278,"Doctor,"],[7323,7415,"is the exam over?"],[7511,7582,"Is she okay?"],[7640,7703,"Shh."],[7991,8028,"There."],[8091,8199,"That's the baby's heartbeat."],[8266,8354,"This is our baby."],[8529,8704,"I need to give Cora and this child"],[8704,8758,"a home."],[8896,8933,"No."],[9071,9125,"I will."]],"16":[[112,300,"Cora should recover from her injuries,"],[300,496,"but she's severely malnourished."],[517,696,"The baby's doing fine for now,"],[734,900,"but they'll both need proper nutrition"],[900,975,"and medical treatment"],[975,1051,"moving forward."],[1142,1205,"I understand."],[1301,1347,"Thank you."],[1768,1931,"Malnutrition in this day and age?"],[2089,2202,"She must have been starving."],[2298,2498,"All she ate today was a tiny sandwich."],[2535,2615,"She probably hasn't had"],[2615,2773,"a proper meal in weeks."],[2823,2911,"Well, that stops now."],[2952,3007,"From now on,"],[3007,3174,"Miss Johnson will be under your care."],[3178,3303,"She'll never have to worry about food"],[3303,3403,"or money ever again."],[3878,3966,"Dr. Hawkins?"],[4074,4133,"You're awake."],[4245,4300,"How are you?"],[4371,4571,"I'm so sorry, Dr. Hawkins."],[4571,4667,"I didn't mean for you"],[4688,4750,"to get... - No!"],[4750,4904,"Please don't apologize."],[4963,5113,"This is my responsibility."],[5125,5409,"You're carrying my baby after all."],[5476,5605,"No, Dr. Hawkins."],[5705,5780,"I think there's been"],[5780,5885,"some misunderstanding."],[5922,5993,"This child has"],[5993,6089,"nothing to do with you."],[6302,6373,"A month ago"],[6427,6548,"at the Nightshade Bar,"],[6614,6702,"I was drugged."],[6731,6911,"And you were the one who saved me,"],[6931,6990,"weren't you?"],[7207,7319,"If I'm not the father,"],[7407,7461,"who is?"],[7670,7866,"I was at that bar,"],[7866,8033,"but I didn't see you there."],[8112,8179,"Miss Johnson,"],[8179,8295,"why can't you just admit it?"],[8350,8512,"If you're pregnant with the boss's kid,"],[8512,8675,"it's gonna change your life."],[8721,8771,"I know."],[8896,9000,"But I'm not willing to lie."]],"17":[[41,87,"Adam,"],[141,237,"give us a moment alone."],[308,354,"Yes, sir."],[996,1059,"What are you doing?"],[1113,1226,"The one detail"],[1272,1505,"I have clear in my mind from that night"],[1539,1634,"was a birthmark."],[1764,1897,"The girl who saved me"],[1960,2052,"had a birthmark"],[2164,2318,"of a butterfly on her collarbone."],[2394,2665,"Just like yours."],[2911,3057,"Cora, how long were you planning"],[3057,3178,"on keeping this from me?"],[3244,3399,"Why didn't you just say something?"],[3490,3566,"Were you planning"],[3566,3724,"to use this child against me?"],[3816,3862,"No."],[3949,4024,"Of course not."],[4183,4233,"Yes."],[4371,4425,"Okay."],[4537,4646,"The baby is yours."],[4900,4975,"But that night"],[5063,5155,"was an accident."],[5226,5351,"I never planned to trap you"],[5351,5430,"with a child."],[5555,5638,"I don't care"],[5734,5847,"if it was an accident."],[5914,6056,"The only thing I care about"],[6064,6139,"is that you"],[6222,6410,"and this child are mine."],[6631,6690,"Yours?"],[6886,7011,"Dr. Hawkins, please."],[7090,7265,"You can't just throw money at us"],[7353,7461,"or give me some room"],[7461,7540,"in your mansion."],[7620,7703,"I don't want to be another"],[7703,7849,"nameless child's mother"],[7849,7928,"in your world."],[8020,8208,"Cora, it's not what you think."],[8304,8516,"Dr. Hawkins, we're very different."],[8591,8700,"I know this is just"],[8754,8938,"responsibility for you."],[9054,9092,"No."],[9142,9200,"You're wrong."],[9275,9396,"You think that this is just"],[9396,9501,"duty to me."],[9559,9688,"That we would never last."],[9859,10181,"But I'm not just saying responsibility."],[10281,10326,"Cora,"],[10402,10485,"I'm saying,"],[10552,10673,"I want you to marry me."]],"18":[[37,83,"What?"],[212,312,"You want to marry me?"],[383,429,"Yes."],[629,784,"I want you to be my wife."],[917,1005,"Dr. Hawkins,"],[1138,1309,"we come from two different worlds."],[1334,1443,"You have everything."],[1568,1643,"I have nothing."],[1730,1826,"You deserve better."],[2027,2127,"And you're my professor."],[2277,2439,"I'm only a visiting professor."],[2523,2711,"And I'm leaving the university soon."],[2794,2882,"And you, Cora,"],[2965,3111,"you're carrying my child."],[3219,3307,"I'm serious."],[3474,3611,"Unless it's the age gap."],[3645,3883,"I'm almost ten years older than you."],[4041,4137,"Okay, of course"],[4137,4200,"you want to run."],[4200,4291,"No, no."],[4375,4479,"It's not that at all."],[4733,4779,"Alright."],[4913,4996,"It's settled then."],[5017,5105,"Let's go get married."],[5234,5472,"Maybe marriage really would be"],[5472,5638,"the best choice for the baby."],[5797,5964,"Dr. Hawkins is a good man."],[6101,6252,"He would be a good father."],[6343,6477,"Can you promise me one thing?"],[6577,6685,"If we get divorced,"],[6894,6952,"please,"],[7002,7119,"let me raise our child."],[7303,7432,"We haven't even tied the knot"],[7432,7474,"and you're already"],[7474,7570,"thinking about divorce?"],[7695,7862,"What if you regret marrying me?"],[8016,8087,"Regret it?"],[8408,8450,"Never."],[8579,8717,"But if the day ever comes"],[8717,8842,"that we do get a divorce,"],[9088,9230,"the child stays with you."],[9367,9455,"You have my word."],[9513,9718,"As if I'd ever let you go."],[9889,10030,"And if it eases your heart,"],[10201,10306,"we can put it in writing."],[10422,10464,"No."],[10698,10773,"I believe you."],[10940,10994,"Alright."],[11144,11232,"Let's get married then."],[11953,12087,"I can't believe it."],[12208,12508,"I'm Mrs. Damon Hawkins?"],[12579,12629,"It's real."],[12683,12812,"You're Mrs. Hawkins now."],[12954,12996,"What?"],[13058,13138,"How did you know?"],[13209,13250,"Boss!"],[13317,13434,"Boss, it's your grandma Evelyn."],[13492,13542,"She's ill."],[13609,13646,"What?"],[13730,13767,"Come on."],[13767,13830,"We gotta go home."]],"19":[[412,533,"Aunt Miranda, how's Grandma?"],[538,667,"Oh, finally!"],[709,771,"Damon,"],[821,1001,"your grandma's worried sick."],[1021,1109,"Literally!"],[1172,1351,"She hasn't eaten for days."],[1355,1501,"And she barely sleeps."],[1601,1755,"It's all because you refuse"],[1755,1939,"to settle down with a nice girl."],[2039,2168,"The doctors just said"],[2168,2348,"there's nothing more they can do."],[2473,2727,"This might be the end of her."],[2936,3007,"Haha."],[3044,3119,"Very funny."],[3136,3269,"She was fine yesterday."],[3624,3878,"Oh, dearest Grandma!"],[3878,4024,"What a shame!"],[4279,4408,"Meet my new wife."],[4642,4688,"Cora."],[4963,5217,"We were just married a few hours ago."],[5259,5388,"It's too bad"],[5480,5655,"Grandma will never get to meet her."],[5751,5826,"Your wife?"],[5839,5951,"I, Damon."],[6047,6214,"You've never even brought a girl home."],[6322,6489,"Why did you offer this poor girl"],[6489,6560,"to play along?"],[6614,6681,"No games."],[6756,6835,"Cora's pregnant."],[6944,7036,"But at this rate,"],[7094,7357,"Grandma's not only missing a wedding,"],[7428,7645,"she's never going to meet"],[7670,7907,"her great grandchild."],[7924,7978,"What?"],[8299,8412,"A baby?"],[8454,8579,"Oh, my grandchild!"],[8591,8654,"Oh, baby!"],[8654,8746,"Oh my goodness!"],[8888,9004,"Oh my goodness!"],[9104,9209,"Wonderful!"],[9572,9705,"I thought the doctors said"],[9705,9826,"you were never gonna make it."],[9859,9922,"What?"],[10043,10322,"I was so sick and worried, but..."],[10372,10418,"This!"],[10506,10556,"This!"],[10631,10789,"With this, I'm cured!"],[10814,10923,"Oh my goodness!"],[11006,11173,"It's a miracle!"],[11357,11482,"And look at you!"],[11519,11649,"So beautiful!"],[11949,12078,"You really are pregnant, yeah?"],[12112,12166,"You sure?"],[12183,12374,"Yeah, yes, yes, of course,"],[12387,12483,"Oh my goodness!"]],"20":[[8,91,"Oh, it's such a... - Mom!"],[129,166,"Mom!"],[208,237,"What?"],[237,583,"I don't mean to sour the mood,"],[642,684,"but"],[809,955,"you know how hard it's been"],[955,1071,"for people in our family"],[1071,1146,"to get pregnant."],[1201,1493,"You, me, my siblings,"],[1522,1668,"it's been hard for all of us."],[1701,1943,"But Damon just gets a woman pregnant"],[1943,2010,"out of the blue?"],[2064,2127,"Aunt Miranda,"],[2127,2331,"what exactly are you trying to say?"],[2410,2619,"Damon, your kid is going to"],[2619,2756,"inherit the Hawkins Group."],[2786,2877,"An empire!"],[2915,3111,"We can't afford any mistakes."],[3157,3269,"The least you can do"],[3269,3420,"is get a paternity test."],[3436,3599,"And I'm saying this for your own good."],[3666,3732,"That's enough."],[3920,4008,"I trust Cora."],[4054,4241,"And I know the baby's mine."],[4291,4400,"That's not the same"],[4400,4621,"as seeing the cold hard facts."],[4667,4863,"This is about our future, Damon."],[4896,4975,"Our legacy."],[5009,5205,"Miranda, look at you!"],[5267,5472,"That is just rude!"],[5522,5693,"I trust Damon,"],[5718,5939,"and I trust his wife."],[5972,6172,"And if you cannot find something"],[6172,6314,"nice to say about this,"],[6364,6594,"then you can just"],[6648,6869,"let your own self out."]],"21":[[112,200,"Thank you, Grandma."],[221,417,"Oh, this is so wonderful."],[417,542,"Oh my goodness."],[550,725,"Okay, I cannot wait"],[738,942,"to tell the whole world"],[950,1134,"about the new,"],[1176,1443,"wonderful Mrs. Hawkins."],[1451,1568,"So we're gonna start"],[1568,1747,"putting the wedding together right away."],[1780,1851,"Actually,"],[1922,2064,"I was thinking"],[2064,2160,"maybe we could wait"],[2218,2273,"on the wedding."],[2352,2548,"I don't want everyone at school"],[2548,2644,"to know I'm married."],[2711,2752,"Why?"],[2848,2957,"Are you embarrassed of me?"],[2990,3219,"No, no, no, no, of course not, Damon."],[3303,3524,"I mean, if everyone at school found out"],[3524,3657,"I married my professor,"],[3757,3916,"I would never be able to live it down."],[4099,4145,"Okay."],[4237,4433,"Alright, so let's do this."],[4491,4667,"Let's wait until you graduate,"],[4725,4938,"and wait until the baby comes."],[5084,5150,"The baby!"],[5221,5438,"And then we'll do the wedding."],[5438,5559,"We'll make it big."],[5559,5680,"We'll make it exciting."],[5693,5797,"Okay, Grandma,"],[5814,6014,"I'm gonna take Cora back to our room."],[6056,6156,"I love you, Grandma."],[6177,6218,"Okay."],[6222,6272,"Bye."],[6281,6322,"Bye."]],"22":[[417,467,"Come in."],[963,1046,"Dr. Hawkins?"],[1076,1263,"We're back to Dr. Hawkins now,"],[1272,1322,"are we?"],[1522,1572,"Damon."],[2102,2168,"You're my wife."],[2243,2373,"There's nothing to be shy about."],[2669,2961,"Just not used to it yet."],[4337,4408,"What are you doing?"],[4450,4525,"I'm pregnant."],[5505,5618,"I was just tucking you in."],[6164,6289,"What did you think I was doing?"],[6535,6573,"Um,"],[6765,6806,"nothing."],[7228,7369,"You're blushing, sweetie."],[8308,8458,"I need you to be honest with me."],[8583,8754,"Are you keeping our marriage a secret"],[8837,9017,"because you already want a divorce?"]],"23":[[37,116,"Is that why you don't want"],[116,183,"a big wedding?"],[246,346,"No, no."],[396,467,"Of course not."],[517,633,"I guess I'm just scared"],[821,925,"that you'll regret it."],[1013,1080,"Regret it?"],[1205,1522,"Cora, I will never regret marrying you."],[1572,1726,"I will spend every day"],[1776,1931,"for the rest of my life"],[2022,2106,"proving it to you."],[2293,2394,"Now get some sleep."],[2435,2569,"I'll drive you to class in the morning."],[2961,3036,"Sweet dreams."],[3324,3370,"Good night,"],[3440,3486,"Damon."],[3557,3607,"Good night,"],[3757,3853,"Mrs. Hawkins."],[4387,4550,"Oh, my baby."],[4625,4788,"I think we might've lucked out"],[4788,4859,"with your dad."]],"24":[[166,300,"Okay, Damon, I'm ready."],[704,796,"You're wearing the same thing"],[796,867,"as yesterday."],[1005,1067,"Yeah."],[1151,1255,"The clothes Emma brought me"],[1255,1413,"were a bit much."],[1472,1735,"Style-wise or too expensive?"],[1793,1860,"Um,"],[1947,1993,"both."],[2043,2085,"Okay."],[2139,2281,"We'll have them curate a closet"],[2281,2444,"that feels more like you."],[2489,2548,"Thanks."],[2698,2869,"Come on, let's get you to class."],[3549,3666,"This is perfect."],[3703,3816,"You can drop me off here."],[3883,4079,"But we're four blocks away from school."],[4162,4233,"Exactly."],[4295,4416,"Any closer and half the school"],[4416,4475,"is gonna see me"],[4475,4579,"get out of a Hawkins car."],[4733,5005,"And that's a problem because?"],[5075,5242,"Because you're my professor,"],[5342,5442,"and my boss,"],[5593,5759,"and kind of a big deal."],[6006,6081,"People talk."],[6322,6448,"Please, Damon."],[6664,6715,"For me."],[7136,7178,"Alright."],[7344,7407,"Be safe."],[7486,7528,"I will."],[7757,7799,"Bye."],[8191,8283,"And the boys."],[8858,8954,"Alyssa, look."],[8971,9129,"Still wearing the same clothes."],[9142,9230,"Charity case."],[9284,9338,"I knew Damon"],[9338,9426,"couldn't be the father."],[9476,9572,"If that were his baby,"],[9580,9651,"he would've showered her"],[9651,9755,"in pearls by now."],[9851,9922,"What are you doing?"],[9964,10097,"We don't have anything due."],[10214,10364,"It's for the research project."],[10381,10489,"I need to check my figures"],[10489,10656,"before I present them to Dr. Hawkins."],[10773,10860,"She's still working"],[10860,10994,"as Dr. Hawkins' assistant?"],[11106,11240,"I can't believe he hasn't fired her."],[11290,11444,"I don't know what kind of dirty tricks"],[11444,11561,"this bitch is playing on Damon,"],[11603,11765,"but I swear I'm gonna make sure"],[11765,11916,"he sees her for the whore that she is."]],"25":[[37,175,"She's clearly obsessed"],[175,258,"with that baby."],[258,362,"Whoever the father is,"],[387,558,"she's probably still sneaking off"],[558,621,"to see him."],[713,788,"Good point."],[859,905,"Tail her."],[942,1117,"Make sure you get dirt on her fast."],[1130,1184,"Got it."],[2686,2761,"Mrs. Hawkins."],[2823,2940,"Your husband's in a meeting"],[2940,3053,"with some other professors,"],[3053,3194,"but should I let him know you're here?"],[3249,3474,"Shh, don't call me that at school."],[3687,3774,"Could you just give this to him"],[3774,3849,"after his meeting?"],[3874,4012,"Why not just give it to him yourself?"],[4045,4200,"I have to head to my next class."],[4262,4446,"Just make sure he gets it, please?"],[4617,4667,"Thanks."],[4942,5096,"Mr. Hawkins, today we're presenting"],[5096,5305,"our latest technology in immunotherapy."],[5326,5451,"It's where we're targeting"],[5451,5568,"cancer cells"],[5597,5714,"through immobilized T-cells."],[5751,5805,"One minute."],[5964,6006,"Adam?"],[6168,6318,"Cora asked me to deliver this to you."],[6385,6439,"Where is she?"],[6485,6602,"She said she had class"],[6602,6698,"and then she left."],[6798,6906,"She's avoiding me."]],"26":[[100,145,"Call her."],[175,296,"Tell her I need her to double-check"],[296,362,"some figures."],[408,467,"Understood."],[638,725,"My apologies."],[771,834,"Please continue."],[921,996,"As I was saying,"],[996,1146,"we're targeting cancer cells"],[1146,1272,"through immobilized T-cells."],[1868,1914,"Hello?"],[2052,2097,"Okay."],[2181,2256,"I'll be right there."],[2723,2802,"She's heading somewhere"],[2802,2861,"by herself."],[2948,3078,"She's totally having a secret"],[3078,3190,"rendezvous with her lover."],[3249,3307,"Perfect."],[3315,3382,"I want you to wait"],[3382,3478,"until they're in the middle of it"],[3478,3566,"and then barge in."],[3566,3703,"And make sure the camera's rolling."],[3749,3812,"I'm on my way."],[3983,4087,"Cora Johnson,"],[4170,4250,"you're done for."]],"27":[[834,913,"Dr. Hawkins?"],[1038,1096,"What are you doing?"],[1272,1368,"I just needed a word."],[1505,1572,"Was there something wrong"],[1572,1659,"with the documents?"],[2193,2298,"Why are you avoiding me?"],[2356,2439,"I'm not."],[2456,2560,"It's just we're at school."],[2635,2773,"You promised we'd play it cool."],[2811,2886,"You promised."],[2927,3111,"But you won't even call me Damon."],[3169,3294,"Because we're in public."],[3566,3749,"Nobody else is here."],[3962,4020,"Say it."],[4341,4383,"Damon."],[4621,4671,"Good girl."],[4896,5005,"You know, I've been regretting"],[5005,5138,"making you that promise."],[5205,5417,"You breeze past me in the hallways"],[5417,5530,"like I'm nobody."],[5697,5789,"You flinch"],[5876,5993,"every time I touch you."],[6081,6389,"It drives me crazy."],[6560,6673,"I want everyone"],[6790,6915,"to know you're my wife."],[7365,7407,"Mine."],[8858,8938,"Someone might see."],[9054,9104,"Let them."],[9405,9463,"Bingo."]],"28":[[120,171,"Damon,"],[208,329,"someone might hear us."],[412,487,"Who cares?"],[571,654,"You're my wife,"],[709,863,"and I want everyone to know"],[900,1005,"who you belong to."],[1267,1313,"Damon."],[1476,1543,"Say it again."],[1676,1772,"Not professor,"],[1864,2002,"not Dr. Hawkins."],[2152,2477,"Just my name."],[2748,2802,"Damon."],[3490,3691,"I thought you said we'd be careful."],[3928,3987,"I lied."],[4354,4587,"You drive me insane."],[4696,4763,"You know that?"],[4825,4888,"Maybe."],[5205,5271,"Well, well."],[5321,5430,"Look what we've got here."]],"29":[[0,158,"Cora Johnson caught red-handed."],[171,333,"I got everything on video."],[396,508,"I can't believe you're making out"],[508,696,"with some random dilf at school."],[825,934,"You're done, slut."],[963,1167,"Once I send this to Dr. Hawkins,"],[1192,1280,"no one's gonna want to work"],[1280,1351,"with you again."],[1393,1480,"Stacy, stop it."],[1488,1568,"Delete it now."],[1597,1643,"Why?"],[1676,1739,"In fact,"],[1743,1914,"I think I'll text it to him right now."],[2131,2164,"Hey,"],[2285,2364,"mystery man."],[2444,2481,"What?"],[2498,2656,"Too ashamed to show your face?"],[2698,2840,"Turn around, you coward."],[3324,3415,"Dr. Hawkins?"],[3532,3611,"Why are you here?"],[3661,3774,"I thought you were gonna text me"],[3774,3832,"that video."],[3878,3937,"I'm waiting."],[3953,4070,"Stacy, did you get that video?"],[4070,4216,"I want that bitch exposed."],[4404,4450,"Damon?"],[4533,4658,"What are you doing here with her?"],[4738,4863,"Alyssa Wilson."],[4917,5030,"I should have guessed."],[5063,5205,"Still wasting your time"],[5205,5442,"harassing the mother of my child?"],[5559,5588,"What?"],[5697,5830,"You're the baby's father?"]],"30":[[41,75,"No,"],[129,166,"no way."],[221,333,"If that were the case,"],[333,433,"then she wouldn't be walking around"],[433,529,"like she's homeless."],[596,717,"And it would be front-page news."],[729,809,"You're rich."],[867,934,"You hear that?"],[971,1092,"It's what most people see"],[1092,1172,"when they look at me."],[1197,1413,"Labels, money, power."],[1593,1680,"But not Cora."],[1739,1847,"Cora's better than that."],[1976,2114,"Damon, I don't care what they think."],[2223,2293,"Let them talk."],[2494,2535,"Good."],[2794,2927,"Because in three months,"],[2969,3098,"the world will know"],[3169,3269,"that the Hawkins"],[3345,3511,"don't just protect her."],[3570,3732,"They'll know that we cherish her"],[3807,3891,"and this baby."],[4058,4108,"Alyssa,"],[4216,4341,"I've let your behavior go"],[4371,4487,"because of the Wilsons."],[4571,4637,"But now,"],[4708,4950,"you have crossed a line."],[5084,5380,"I don't ever want to see you"],[5442,5559,"or your minions"],[5597,5834,"on the same campus as Cora again."],[5910,6164,"Transfer or quit medicine."]],"31":[[379,471,"Dr. Hawkins,"],[508,563,"please!"],[604,721,"I can't afford to transfer"],[721,834,"in the middle of the semester."],[863,959,"My, my family's"],[959,1076,"struggling enough as it is."],[1126,1205,"Please forgive me."],[1372,1651,"You're apologizing to the wrong person."],[1755,1793,"Cora."],[1981,2060,"Cora, please!"],[2181,2264,"Please forgive me."],[2364,2531,"It was wrong for me to do that to you."],[2681,2719,"Damon,"],[2794,2869,"I think we let her off"],[2869,2965,"with a warning this time."],[3144,3278,"You should be grateful"],[3315,3440,"she gave you grace."],[3541,3607,"Now go."],[3920,3999,"And leave your phone."],[4612,4713,"What do you need her phone for?"],[4746,4954,"Well, she got a video of me holding you."],[4996,5084,"Then delete it."],[5138,5209,"Delete it?"],[5271,5367,"It's a great shot."],[5563,5726,"Why would you save something like that?"],[5776,5855,"Research,"],[5910,6043,"scientific study."],[6068,6206,"See how your body reacts"],[6206,6272,"when I touch you."],[6614,6773,"Come on, where were we?"]],"32":[[225,492,"I'd taste his lips forever if I could."],[1134,1230,"Earth to Cora."],[1397,1505,"Who was the lucky boy?"],[1593,1647,"Nothing."],[1668,1751,"I was just"],[1814,1960,"thinking about something."],[2027,2127,"Uh huh."],[2198,2314,"With that smile,"],[2314,2427,"you're probably thinking about"],[2427,2573,"Alyssa's transfer."],[2748,2840,"Guess Daddy's money"],[2840,2982,"couldn't help her this time."],[3048,3307,"That girl has been a nightmare"],[3307,3461,"to everyone forever."],[3566,3624,"It's about time"],[3624,3749,"she got what she deserves."],[3858,3933,"So true."],[4312,4375,"Alyssa,"],[4433,4496,"don't worry."],[4521,4700,"Us Wilsons won't let anyone"],[4700,4788,"walk over us."],[4833,4896,"Damon Hawkins"],[4896,5034,"cannot force you to transfer."],[5080,5267,"He's gone too far."],[5292,5409,"Dad, we can't, okay?"],[5409,5463,"Not yet."],[5463,5593,"We're nowhere near as powerful"],[5593,5668,"as the Hawkins Group."],[5705,5855,"Besides, it's not even Damon's fault."],[5855,5976,"It's that bitch Cora."],[6006,6177,"She's totally manipulated Damon."],[6235,6281,"Cora?"],[6314,6385,"Who's Cora?"],[6402,6539,"Cora Johnson, she's in my program."],[6606,6723,"She convinced Damon"],[6723,6856,"that she's pregnant with his baby."],[6911,7098,"But if we prove it's not his,"],[7119,7203,"then he'll break up with her."],[7340,7390,"I see."],[7486,7553,"Leave it to me."],[7674,7799,"Thank you, Daddy, you're the best."],[8249,8324,"Sir, don't you think"],[8324,8483,"you're taking it a little easy"],[8521,8621,"on the young miss?"],[8708,8796,"After all, she's not even"],[8796,8908,"your biological daughter."]],"33":[[58,154,"Alyssa's my daughter"],[154,300,"in every sense of the word."],[350,450,"Josh, you know I can't have"],[450,600,"biological children of my own."],[642,829,"Alyssa and I might not be blood-related,"],[892,1026,"but I love her just the same."],[1080,1255,"And she shares a striking resemblance"],[1255,1343,"to your late sister."],[1484,1639,"Maybe that's why I'm so fond of her."],[1705,1772,"My sister was"],[1772,1872,"the only one who loved me."],[1935,2064,"I remember seeing little Alyssa"],[2064,2160,"for the first time."],[2206,2323,"It was like seeing my sister"],[2335,2414,"all over again."],[2506,2610,"And I swore then"],[2648,2740,"I would protect her,"],[2790,2907,"no matter what."],[2969,3103,"No wonder you've always spoiled her."],[3148,3240,"I'll give Alyssa"],[3240,3382,"everything she wants,"],[3403,3653,"and I mean no one will stand in my way."],[3883,4079,"Damon Hawkins has an aunt, right?"],[4183,4254,"Miranda."],[4466,4592,"She wanted the Hawkins Group"],[4592,4675,"to go to her"],[4721,4808,"instead of him."],[4884,4950,"You know what?"],[5021,5142,"We can use that."],[5501,5559,"That'll be all."],[5572,5613,"Thank you."]],"34":[[16,62,"Okay."],[116,229,"I grabbed everything I needed"],[229,291,"from the dorm."],[563,700,"All you got was a photo?"],[779,821,"Yeah."],[917,1126,"It's my only photo of me and my mom."],[1497,1547,"Wow,"],[1605,1714,"you look just like her."],[1901,1956,"Thanks."],[2039,2131,"Everyone says that."],[2448,2515,"So,"],[2577,2761,"both of your parents passed away."],[2927,3119,"Do you have any other relatives?"],[3228,3274,"No."],[3374,3490,"I mean, I don't know anyone"],[3490,3595,"on my dad's side."],[3703,3774,"My mom said she had"],[3774,3895,"a younger brother, but"],[4004,4175,"they lost contact a long time ago."],[4258,4304,"So no,"],[4408,4496,"I don't have anyone."],[4733,4817,"Well, you have our baby."],[5100,5176,"And you have me."],[5234,5376,"I just need you to realize"],[5376,5534,"that I'm not going anywhere,"],[5534,5597,"sweetheart."],[5622,5689,"Buckle up."],[5839,5897,"Let's go home."],[6131,6160,"Okay."]],"35":[[225,408,"Mom, your birthday soiree"],[408,538,"is the perfect occasion"],[538,709,"to announce that Damon and Cora"],[709,792,"are expecting."],[859,1084,"That baby is the future of our family."],[1159,1326,"The sooner the world knows, the better."],[1505,1618,"Aunt Miranda,"],[1760,1935,"just last night you were saying"],[1935,2110,"how Cora wasn't good enough for me."],[2164,2248,"What changed?"],[2348,2498,"Damon, you're back."],[2644,2727,"Last night was all just"],[2727,2831,"a misunderstanding."],[2886,3036,"I got a little emotional."],[3140,3299,"Seeing how in love you are"],[3299,3499,"and with a baby on the way,"],[3557,3703,"this is the best thing to happen"],[3703,3878,"to our family in years."],[3908,4241,"Cora is just a few weeks along."],[4275,4441,"I think it would be better"],[4441,4692,"if we just waited a little bit of time"],[4721,4758,"and..."],[4758,4896,"Actually, Grandma,"],[4942,5130,"I think Aunt Miranda has a point."],[5255,5301,"Damon."],[5501,5659,"If this is what you want, Damon,"],[5659,5910,"then we'll do what Miranda says."],[5976,6039,"Perfect."],[6097,6227,"I'll handle the arrangements."]],"36":[[800,859,"But Damon,"],[963,1059,"everyone at med school's"],[1059,1113,"gonna find out"],[1113,1197,"that I'm pregnant."],[1255,1313,"Don't worry."],[1355,1493,"Only close family, friends,"],[1493,1589,"and business partners"],[1589,1705,"will be allowed to attend"],[1705,1818,"Grandma's birthday soiree."],[1839,1881,"But"],[1960,2018,"I..."],[2110,2164,"Do you remember"],[2164,2281,"what Alyssa said today?"],[2327,2460,"If my family doesn't show"],[2460,2594,"that we're serious about you,"],[2598,2723,"people will take it as a chance"],[2723,2802,"to hurt you."],[2882,2973,"Or even the baby."],[3123,3282,"Is it really that serious?"],[3349,3395,"Yes."],[3445,3566,"Yes, it is, sweetheart."],[3699,3741,"Okay."],[3816,3945,"Then we'll announce that I'm pregnant"],[4087,4191,"at your birthday soiree."],[4587,4637,"Good girl."]],"37":[[196,375,"So what you're saying is,"],[408,642,"you're the father of Cora's"],[642,850,"little bastard spawn?"],[900,959,"That's right."],[1071,1155,"I'm the father."],[1480,1710,"That conniving snake!"],[1785,1939,"I want you to expose her"],[1939,2056,"at my mother's birthday"],[2064,2160,"in front of everyone."],[2235,2406,"And I'll handle the rest."],[2473,2519,"Yes, ma'am."],[3386,3495,"It worked, Alyssa."],[3524,3616,"Alyssa, she bought it."],[3699,3757,"Good."],[3858,3945,"You know I've never even"],[3945,4083,"kissed Cora before."],[4120,4208,"We can't get caught."],[4233,4312,"Relax, okay?"],[4312,4462,"I've got everything covered."],[4475,4567,"We'll ruin Cora"],[4567,4758,"and she won't ever be able"],[4758,4879,"to show her face at school again."]],"38":[[112,291,"Oh Mom, happy birthday!"],[546,729,"Evening, Mrs. Hawkins."],[771,880,"I heard you had big news"],[880,984,"to announce tonight."],[1046,1197,"Maybe Damon Hawkins"],[1197,1297,"got engaged."],[1297,1405,"Oh my goodness."],[1418,1514,"Wait and see."],[1530,1680,"Oh, look who's just come."],[1680,1685,"Oh, look who's just come."],[1685,1697,"Oh, look who's just come."],[2786,2873,"This is the first time"],[2873,3003,"I've seen Damon Hawkins"],[3003,3119,"look this smitten."],[3219,3357,"Guess the rumors are true."],[3445,3607,"They really did tie the knot."],[3699,3816,"Thank you all for being here."],[3816,3824,"Thank you all for being here."],[3899,3916,"Tonight, I'm celebrating"],[3916,4066,"Tonight, I'm celebrating"],[4066,4191,"two women in my life."],[4275,4341,"My grandmother,"],[4412,4479,"of course,"],[4587,4963,"and my beautiful, amazing wife,"],[5138,5184,"Cora."],[5405,5505,"Give me that,"],[5509,5547,"give me."],[5547,5551,"give me."],[5705,5751,"Now,"],[5809,6089,"there is no official wedding yet,"],[6126,6377,"because the baby's on the way,"],[6377,6531,"and Cora is in the middle"],[6531,6652,"of all her studies."],[6673,7219,"But we will do the wedding next year."],[7265,7349,"That's wonderful."],[7436,7440,"Congratulations, Damon and Cora."],[7440,7774,"Congratulations, Damon and Cora."],[7945,7999,"Wow!"],[8041,8087,"Stop!"],[8700,8812,"I can't take this anymore."],[9042,9271,"I am the father of her unborn child."]],"39":[[25,154,"Who the hell let you in?"],[158,229,"Security,"],[254,404,"get this lunatic out of the party."],[404,446,"No!"],[588,684,"I'm telling the truth."],[767,896,"Cora and I have been together for years."],[988,1071,"The baby is mine."],[1109,1176,"Bullshit."],[1251,1330,"You asked her out"],[1330,1488,"but she never gave you the time of day."],[1509,1559,"And now,"],[1584,1755,"you're trying to make things up"],[1755,1981,"to hide your own hurt pride."],[2097,2202,"Is that what she told you?"],[2243,2469,"She slept with me behind your back."],[2527,2681,"Dr. Hawkins, she's playing you."],[2694,2790,"Shut your mouth"],[2811,2948,"before I shut it for you."],[3028,3199,"I believe my wife."],[3265,3499,"Cora's baby is next in line"],[3499,3749,"to be the leader of the Hawkins Group."],[3774,3866,"Do you think"],[3883,4099,"that we would have made this public"],[4099,4187,"if it were not"],[4187,4362,"a hundred percent certain?"],[4421,4617,"Security, throw him out."],[4621,4671,"Wait!"]],"40":[[0,45,"Wait!"],[112,266,"Mom, Damon hasn't even"],[266,421,"taken a paternity test."],[487,638,"And the kid seems serious"],[638,771,"about being Cora's lover."],[871,925,"What if"],[946,1021,"they... - Miranda,"],[1026,1305,"are you trying to humiliate us"],[1305,1497,"at my birthday party?"],[1534,1714,"No, I would never."],[1801,1918,"But think about it."],[1960,2072,"Why would he come here"],[2072,2210,"and make a huge deal about it"],[2210,2318,"if he wasn't sure?"],[2389,2598,"He's not even scared we'll retaliate."],[2640,2736,"That says something."],[2869,2977,"Miranda has a point."],[3036,3153,"What if the Hawkins family's"],[3153,3311,"being tricked?"],[3390,3532,"Then what do you suggest,"],[3532,3607,"aunt Miranda?"],[3661,3716,"Simple."],[3782,3924,"Take a paternity test."],[3991,4162,"Right here, right now."],[4233,4371,"Prove that Cora's innocent"],[4371,4471,"in front of everyone."]],"41":[[20,87,"Miranda,"],[112,308,"I raised you better than this."],[358,462,"Mom, I'm just doing"],[462,575,"what's best for the family."],[692,759,"And Cora,"],[825,942,"if you're telling the truth,"],[971,1076,"you have nothing to fear."],[1263,1317,"You're right."],[1476,1630,"Mrs. Hawkins, Damon,"],[1722,1793,"thank you both,"],[1885,1960,"for trusting me."],[2185,2356,"I'm okay with a paternity test."],[2502,2540,"Huh."],[2569,2736,"She's not nervous at all?"],[2756,2811,"Alright."],[2915,2998,"Bring in the doctor."],[3178,3253,"Wow."],[3278,3340,"Huh?"],[3516,3628,"You came prepared."],[3703,3749,"You?"],[3770,3924,"No, you, you misunderstand."],[3924,4104,"I only have a doctor on call"],[4137,4266,"because you were sick earlier."],[4266,4396,"I just didn't want anything to happen"],[4396,4462,"at the party."],[5063,5150,"We'll get the result"],[5150,5296,"in about 30 minutes."]],"42":[[400,487,"Oh, and him."],[533,625,"Take his sample too."],[700,734,"Yeah."],[804,900,"Check my blood as well."],[984,1159,"I'm ready to take full responsibility"],[1159,1309,"for my child."],[1372,1509,"David, you know damn well"],[1543,1668,"this child isn't yours."],[1747,1843,"You're just ashamed of me"],[1843,1922,"because I'm poor."],[1976,2198,"You'd rather live it up with Dr. Hawkins"],[2218,2385,"instead of admitting to the truth."],[2389,2485,"Shut him up!"],[3023,3228,"Damon's completely under her spell."],[3307,3499,"But soon, she'll be in Hell."],[3787,3862,"Dr. Hawkins!"],[4066,4166,"The results are in."],[4658,4767,"I'm sorry, but"],[4900,5017,"you are not the father."],[5050,5113,"What?"],[5276,5321,"What?"]],"43":[[0,162,"Are you sure the child isn't mine?"],[471,525,"It's okay."],[679,771,"I still believe you."],[1001,1046,"Doctor."],[1159,1359,"Are you absolutely sure?"],[1455,1509,"Now, Damon,"],[1551,1739,"why would Dr. Vicario lie to us?"],[1801,1922,"But now that we have proof,"],[1981,2139,"you need to divorce this whore."],[2164,2214,"Shut up!"],[2381,2477,"Last chance."],[2598,2848,"Talk, or you'll regret it later."],[3098,3190,"Nice try, Damon."],[3215,3332,"He's not going to turn on us"],[3332,3478,"just because he got a little scared."],[3574,3816,"I dropped ten fucking million on this."],[3924,3962,"No."],[4033,4133,"No, Dr. Hawkins."],[4216,4312,"I, I'm sure."],[4450,4646,"You have no biological relations"],[4646,4721,"to the child."]],"44":[[37,150,"Can you believe this?"],[200,329,"The Hawkins have been praying"],[329,396,"for an heir."],[421,508,"And it turns out,"],[571,729,"the baby isn't even Damon's."],[825,971,"You dirty slut."],[1026,1255,"How dare you pass off a bastard child"],[1255,1368,"as a Hawkins heir?"],[1443,1576,"Get the hell out of here."],[1626,1714,"And you're not taking"],[1714,1847,"any of our stuff with you."],[1881,2156,"Don't you dare lay a finger on her!"],[2193,2344,"Damon, what's going on here?"],[2444,2631,"Grandma, the doctor is lying."],[2781,2882,"I believe Cora."],[2923,2986,"Then you're out of"],[2986,3115,"your goddamn mind!"],[3132,3315,"Why would Dr. Vicario lie to us?"],[3407,3490,"Unbelievable."],[3490,3624,"He's still not buying it?"],[3678,3716,"Damon,"],[3774,3853,"Cora's nothing"],[3853,3983,"but a streetwalking whore."],[3983,4008,"Okay,"],[4008,4108,"the proof is right"],[4108,4170,"underneath your nose."],[4170,4245,"Why are you refusing"],[4245,4316,"to see the truth?"]],"45":[[41,262,"You put the doctor up to this, Alyssa."],[367,487,"Try again, okay?"],[487,621,"This is your family doctor."],[704,850,"That's right, he's on my payroll."],[905,946,"Damon,"],[1063,1184,"you don't really think"],[1184,1292,"that I would conspire"],[1292,1397,"with the doctor"],[1418,1593,"just to frame Cora?"],[1651,1747,"Mom, you don't think"],[1747,1847,"that I would do that, right?"],[1881,1997,"I would never do that!"],[2006,2185,"I don't know what to believe anymore."],[2281,2406,"The baby is Damon's."],[2494,2585,"I'm sure of it."],[2673,2748,"I believe her."],[2811,2848,"Why?"],[2865,3015,"She is lying to you, Damon."],[3032,3182,"The only liars here"],[3207,3399,"are you and that doctor."],[3507,3595,"A few days ago,"],[3632,3787,"I took Cora to the hospital."],[3812,4129,"I secretly requested a paternity test."],[4362,4479,"The results show"],[4533,4821,"that I am the biological father."],[4921,5234,"The proof is right here in my hand!"]],"46":[[100,216,"Wait, so you knew everything"],[216,279,"all along?"],[542,604,"It's true."],[721,992,"Cora, I'm so sorry I doubted you."],[1063,1242,"It's okay, Mrs. Hawkins."],[1634,1768,"I thought he trusted me."],[1851,2006,"He did a paternity test"],[2081,2181,"without telling me?"],[2277,2573,"This proves that Cora is innocent."],[2802,2852,"And you,"],[2957,3098,"you are preposterous."],[3203,3340,"Get ready for your license"],[3340,3432,"to be revoked."],[3636,3674,"No."],[3774,3874,"No, Dr. Hawkins."],[3953,4033,"I, I'm sorry."],[4108,4254,"I must have been missing something."],[4287,4483,"This was no simple human error."],[4550,4683,"Someone was using you"],[4742,4938,"to turn me against Cora."],[5059,5117,"Speak!"],[5217,5497,"Who told you to frame my wife?"]],"47":[[33,187,"No one put me up to this."],[229,387,"It was a mistake!"],[450,579,"My mistake."],[1447,1655,"If I find any evidence"],[1685,1835,"implicating that it was you,"],[1943,2127,"you won't just lose your license."],[2243,2444,"You'll wish that you were dead."],[2623,2744,"Confess now,"],[2794,3007,"and I might let you walk out of here"],[3065,3182,"in one piece."]],"48":[[145,187,"What?"],[208,262,"I, you,"],[296,404,"you sick liar!"],[404,583,"I, when did I tell you to do anything?"],[608,654,"It's true!"],[696,750,"It was her."],[750,871,"She told me to frame Cora."],[884,1026,"She said if I didn't do it,"],[1030,1238,"that she would make sure"],[1238,1380,"I didn't graduate medical school!"],[1451,1584,"Dr. Hawkins, please forgive me."],[1605,1751,"You lying bastard!"],[1789,1956,"You told me you're the father!"],[2027,2152,"I was trying to protect Damon"],[2152,2256,"from getting used."],[2302,2419,"If that was your concern,"],[2444,2602,"why didn't you mention it to me"],[2602,2702,"or to Damon?"],[2790,2907,"But instead, you turned it"],[2907,3107,"into this huge game."],[3190,3415,"And you turned my birthday"],[3445,3591,"into a circus!"],[3678,3795,"What were you thinking?"],[3878,3970,"I'm sorry."],[4091,4195,"Get them out of here!"],[4537,4583,"Shit."],[4617,4800,"How did things get this out of control?"],[4838,5017,"They better not drag me down with them."],[5113,5180,"It was Alyssa!"],[5230,5317,"She told me to do it."],[5317,5413,"It was all her idea!"],[5442,5467,"What?"],[5467,5526,"You're lying!"]],"49":[[0,87,"Alyssa, it's over!"],[316,421,"I'm not getting screwed"],[462,550,"over lying for you."],[596,650,"Me too!"],[667,821,"I should have never taken your money!"],[971,1067,"Fucking traitors!"],[1126,1234,"So you admit it."],[1305,1463,"It was you all along."],[1614,1801,"You planned everything."],[1876,2014,"You used Aunt Miranda"],[2014,2135,"as a scapegoat,"],[2181,2285,"all just because"],[2285,2414,"you were jealous of Cora."],[2606,2806,"And you thought that we would never"],[2806,2969,"trace it back to you."],[2994,3048,"Geez,"],[3107,3261,"Alyssa's rotten to the core."],[3353,3420,"Thank goodness"],[3420,3599,"Dr. Hawkins saw through her act."],[3636,3712,"Why, Alyssa?"],[3812,3999,"I have done nothing to you."],[4112,4208,"Why are you always"],[4208,4333,"trying to destroy me?"],[4371,4508,"Because you don't deserve"],[4508,4558,"to be with Damon,"],[4558,4642,"and you don't deserve"],[4642,4717,"to have his babies."],[5005,5196,"I want her out, now!"],[5276,5376,"I'm the Wilson heiress."],[5376,5530,"You touch me, you'll regret it!"],[5543,5759,"I don't give a shit who your dad is."],[5843,6093,"It's my house, my rules."],[6139,6214,"Let go of me!"],[6247,6289,"Get out."],[6348,6456,"Get your filthy hands"],[6456,6539,"off my daughter!"],[6660,6702,"Daddy!"],[6760,6877,"Sweetheart, are you okay?"],[6890,6940,"I'm fine."],[7082,7140,"Damon Hawkins,"],[7148,7328,"pick on somebody your own size."],[7353,7469,"Is that an invitation?"],[7524,7661,"Let's settle this like men."],[8074,8137,"That face..."],[8366,8404,"Faye?"]],"50":[[95,133,"Faye?"],[200,279,"Dad, are you okay?"],[279,354,"What's going on?"],[412,567,"I, nothing, sweetheart."],[629,792,"What an uncanny resemblance."],[863,1034,"That girl just looks like my sister,"],[1034,1084,"Faye."],[1159,1209,"Wilson,"],[1272,1480,"you owe my wife an apology."],[1518,1651,"My apologies, Dr. Hawkins."],[2018,2118,"To make amends,"],[2152,2281,"Wilson Group will concede"],[2281,2452,"an extra one percent"],[2594,2644,"on the deal"],[2644,2761,"we discussed last month."],[2794,2869,"Does that sound alright?"],[2940,2990,"Deal?"],[3115,3240,"You think that we have a deal"],[3274,3349,"after this?"],[3382,3545,"Please, okay, three percent."],[3570,3832,"And I'll sign over my French villa"],[3933,4045,"as an early wedding present."],[4058,4112,"That villa's worth"],[4112,4233,"a hundred million dollars."],[4233,4337,"That's supposed to be mine!"],[4763,4859,"What do you think, Cora?"],[5005,5167,"The man's offering you his villa."],[5388,5430,"Me?"],[5559,5597,"What?"],[5680,5830,"But it's supposed to be yours."],[5851,5885,"I-"],[5889,6101,"What's mine is yours."],[6427,6493,"Her eyes,"],[6627,6698,"her face,"],[6773,6906,"she looks just like Faye."],[6948,7082,"Could she be Faye's daughter?"],[7182,7353,"But they told me the kid died years ago."],[7453,7540,"Was that a lie?"]],"51":[[362,550,"Why is he staring at my wife?"],[600,742,"Now that Cora has accepted"],[742,821,"your apology,"],[913,1030,"you can fuck off."],[1105,1326,"Keep your daughter on a tighter leash."],[1384,1514,"Or the next time you see her,"],[1589,1685,"will be in prison."],[1818,1872,"I will,"],[1976,2072,"Dr. Hawkins."],[2177,2277,"Alyssa, let's go."],[2306,2373,"Move it."],[2836,3036,"And take the others to the police."]],"52":[[588,692,"I made you some tea."],[963,1009,"Thank you."],[1113,1372,"I'm sure you have a lot of questions."],[1493,1530,"No."],[1751,1830,"You're not mad"],[1843,2014,"that I went behind your back"],[2014,2139,"to get a paternity test?"],[2502,2627,"I mean, we barely knew each other"],[2627,2736,"before we got married."],[2819,2965,"It's normal for you to have doubts"],[2965,3036,"on my character."],[3186,3278,"You're saying that,"],[3349,3520,"but your smile seems forced."],[3737,3812,"To be honest,"],[3883,4062,"I never got that DNA test."]],"53":[[70,216,"The document that I showed today"],[216,287,"was a fake."],[371,538,"And I had it created to protect you."],[617,767,"Today, it finally did."],[938,980,"What?"],[1076,1305,"Do you remember when Aunt Miranda"],[1334,1497,"suddenly insisted"],[1647,1789,"that you announce your pregnancy"],[1789,1889,"at Grandma's soiree?"],[2114,2160,"I knew"],[2248,2327,"then and there,"],[2423,2531,"that she was cooking up"],[2540,2731,"some sort of scheme,"],[2827,2998,"and that if I didn't attack first,"],[3028,3136,"she was going to hurt you."],[3336,3474,"Why didn't you just tell me?"],[3553,3766,"Because I didn't want you to think"],[3766,3933,"that I was making up excuses."],[4041,4229,"Everything I did was planned."],[4425,4533,"It was to protect you"],[4708,4813,"and our child."]],"54":[[95,262,"So you've been suspicious of Alyssa"],[262,329,"this whole time?"],[417,529,"A little at the start,"],[621,834,"but we have strong ties"],[834,1001,"with the Wilson Group in business."],[1092,1272,"So, if I exposed her too early,"],[1351,1422,"Robert wouldn't have"],[1422,1518,"given us anything."],[1593,1785,"By exposing Alyssa when I did,"],[1918,2022,"he had to pay us out,"],[2081,2139,"big time."],[2260,2369,"I see."],[2477,2619,"So if you'd called her out too early,"],[2619,2798,"she would have just changed her ruse."],[2848,2919,"Exactly."],[2998,3044,"Cora,"],[3144,3332,"you and this baby"],[3470,3607,"are the most important things"],[3607,3670,"in my life."],[3787,4016,"Now, and always."]],"55":[[204,354,"You really trust me that much?"],[504,696,"You have the kindest soul."],[821,909,"I trusted you"],[984,1134,"from the moment that you told me."],[1330,1434,"Damon, you're amazing."],[1580,1685,"And I need you to know"],[1906,2102,"I'm not here out of duty."],[2431,2489,"Cora,"],[2736,2802,"I love you."],[2944,2994,"Damon."],[3903,3974,"Okay, kids."],[3999,4058,"What we have here-"],[4158,4208,"Oh."],[4333,4391,"Uh, I,"],[4450,4617,"Cora, I am so sorry."],[4617,4717,"I, I didn't, um"],[4775,4829,"It's okay. - Cora, I,"],[4829,4896,"It's okay. - Cora, I didn't"],[4896,4971,"see anything."],[4971,5030,"I'll just go."],[5030,5100,"Come in, come in."],[5105,5155,"It's okay."],[5205,5251,"What do you need, - Come in."],[5251,5301,"Grandma?"],[5522,5563,"Well,"],[5747,6035,"I just happen to have the deed"],[6072,6214,"to the lakeside villa."],[6247,6302,"Robert was"],[6302,6477,"incredibly cooperative."],[6552,6902,"And, he insisted that the entire thing"],[6902,7057,"be signed over to Cora."]],"56":[[104,145,"Really?"],[254,321,"Cora's name?"],[554,646,"He was staring at you"],[646,850,"at Grandma's birthday soiree, too."],[1005,1071,"Do you know him?"],[1159,1363,"No, I've never met him."],[1422,1509,"You don't think he has"],[1509,1780,"any sinister intentions for Cora,"],[1780,1818,"do you?"],[1910,1989,"I'll look into it."],[2089,2139,"Either way,"],[2139,2260,"what happened with Aunt Miranda?"],[2344,2381,"Oh."],[2656,2831,"Well, it seems as though"],[2831,2952,"Miranda has signed"],[2952,3148,"over all of her shares"],[3219,3328,"to Cora."],[3465,3599,"And some of those shares"],[3599,3762,"will go to Cora for compensation."],[3841,3953,"You're brilliant, Grandma."],[4120,4179,"Well, thank you."],[4179,4258,"I think so, too."],[4542,4604,"Sign it."],[4671,4729,"With this,"],[4804,5067,"you'll be the third largest shareholder"],[5088,5209,"of the Hawkins Group."]],"57":[[95,145,"Oh."],[246,296,"No."],[316,500,"I mean, the villa's already a lot,"],[500,592,"but the shares?"],[713,875,"Come on, we want you to have it."],[930,980,"Mm-hmm."],[1121,1288,"Everyone's been so nice to me."],[1380,1501,"It almost feels like a dream."],[1739,1780,"Well..."],[1914,1964,"Ow!"],[1989,2031,"See?"],[2168,2227,"No dream."],[2281,2431,"This is reality, sweetheart."],[3153,3345,"I totally blew it for Dad today."],[3403,3541,"He hasn't said anything,"],[3541,3720,"but I know he's mad."],[3774,3878,"I need to calm him down."],[3928,3970,"Sir,"],[4066,4245,"are you telling me that you think"],[4245,4416,"the new Mrs. Hawkins"],[4466,4612,"is your late sister's daughter?"]],"58":[[20,191,"Are you telling me that you think"],[191,375,"the new Mrs. Hawkins"],[425,558,"is your late sister's daughter?"],[633,779,"He's talking about Cora."],[855,1017,"Doesn't just look like her, Josh."],[1163,1322,"She's a spitting image of her."],[1509,1639,"I think Cora's my niece."],[1693,1760,"Understood."],[1830,1989,"I'll arrange for a DNA test."],[2056,2202,"If Cora is Faye's daughter,"],[2373,2510,"I have a lot to make up for her."],[2540,2798,"If Cora is your niece,"],[2873,3123,"what will happen to Miss Alyssa?"],[3203,3290,"I raised Alyssa."],[3370,3490,"I'm not going to abandon her."],[3603,3707,"She's still my daughter."]],"59":[[20,125,"Dad only dotes on me"],[125,258,"because I look like his dead sister?"],[321,442,"I'm not letting anyone"],[442,508,"take my place,"],[508,671,"especially not that bitch Cora."],[763,880,"Don't say anything to Alyssa"],[905,1034,"until I've confirmed everything."],[1084,1138,"Yes, sir."],[1197,1280,"I won't say a word."],[1630,1830,"Sir, you think that Mrs. Hawkins"],[1864,2006,"is related to Robert Wilson?"],[2264,2381,"He had an older sister,"],[2531,2615,"Faye Wilson."],[2827,2965,"She gave up her dreams"],[2965,3128,"to support his business ventures,"],[3294,3440,"but she died before he made it."],[3541,3678,"I believe Faye Wilson"],[3732,3853,"may be Cora's mother."],[3924,3970,"Really?"],[4037,4204,"When Robert saw Cora last night,"],[4208,4408,"he completely lost his composure."],[4479,4646,"Like he saw Faye's ghost."],[4700,4825,"And I've seen a picture"],[4825,4942,"of Cora's mother."],[4975,5171,"The resemblance is uncanny."]],"60":[[25,154,"And I've seen a picture"],[154,266,"of Cora's mother."],[308,496,"The resemblance is uncanny."],[696,938,"So, Cora's found more family."],[1071,1138,"Perhaps."],[1380,1484,"But that's not always"],[1484,1543,"a good thing."],[1626,1856,"Robert has spoiled Alyssa for years."],[1901,2210,"And even if Cora is his niece,"],[2256,2389,"I doubt he would throw Alyssa"],[2423,2494,"to the curb."],[2556,2623,"I see, sir."],[2806,2865,"I'll keep digging."]],"61":[[342,412,"Josh."],[433,500,"Miss Alyssa."],[542,613,"I just squeezed"],[613,709,"some fresh orange juice."],[709,788,"Would you like some?"],[871,971,"Thank you, miss."],[1117,1163,"Ah!"],[1322,1434,"I am so sorry."],[1438,1480,"It's alright."],[1480,1564,"I'll go clean up."],[2848,3015,"So, Cora really is Dad's niece?"],[3082,3278,"No, I won't let her take everything"],[3278,3353,"away from me."]],"62":[[62,100,"Sir?"],[116,150,"Yeah."],[166,291,"We extracted Cora's DNA"],[291,412,"from some of her belongings."],[450,525,"This is the report."],[1238,1276,"Sir?"],[1701,1818,"No genetic relation."],[2002,2122,"Are you sure this is right, Josh?"],[2131,2185,"Positive."],[2214,2298,"I didn't even look at it."],[2298,2414,"I brought it straight to you."],[2506,2644,"God doesn't dole out miracles"],[2715,2769,"that easy."],[2952,3053,"Destroy this document."],[3199,3294,"I don't want Alyssa"],[3294,3403,"to even know it exists."],[3411,3457,"Understood."],[3620,3661,"Dad."],[3716,3824,"Hi, sweetheart, hi."],[3899,4012,"I had a bad dream last night"],[4012,4162,"that you didn't want me anymore."],[4179,4346,"How could you think that?"],[4371,4562,"I would never abandon my baby."],[4587,4629,"I know,"],[4629,4733,"but every time"],[4733,4900,"I think about Damon doting on Cora,"],[4900,5059,"then my chest hurts, and I can't breathe,"],[5059,5205,"and I hate her."],[5205,5338,"I want her to disappear!"],[5405,5467,"There, there."],[5593,5805,"If making Cora disappear"],[5830,5968,"makes my baby happy,"],[6118,6239,"then leave it to your father."]],"63":[[8,133,"Boss, I found something."],[196,250,"You were right,"],[283,471,"Robert Wilson is likely Cora's uncle."],[563,663,"Explain it to me."],[709,821,"Cora's mother, Faye,"],[867,1001,"handed off all of her assets"],[1001,1138,"to support her brother's business."],[1184,1288,"And then she had a child"],[1288,1372,"with Cora's father."],[1434,1559,"But when Robert tried to find them,"],[1601,1755,"that man claimed that Faye"],[1755,1947,"already died from illness."],[2052,2168,"No wonder Robert"],[2168,2310,"spoiled Alyssa rotten."],[2348,2519,"He's been trying to make it up to Faye,"],[2540,2681,"because she looks just like her."],[2744,2827,"Boss, should I tell him?"],[2940,2973,"No."],[3128,3307,"If Robert's sincere, he'll come to us."],[3378,3440,"Got it, boss."],[3895,4008,"Cora hasn't called me back"],[4008,4095,"in two hours."],[4158,4254,"Well, she's probably just busy."],[4358,4462,"Or she's avoiding me,"],[4562,4658,"in her own head,"],[4658,4792,"trying to convince herself"],[4792,4884,"that I love her."],[5034,5176,"Sir, if I may?"],[5296,5372,"You come from two"],[5372,5513,"completely different worlds."],[5593,5734,"She's just scared to trust you."],[5776,5847,"It'll take time,"],[5910,5964,"but she will."],[6047,6214,"Then I'll keep proving to her"],[6293,6377,"that I love her."],[6802,6944,"No matter how long it takes."],[7015,7057,"Wow,"],[7127,7223,"who'd have thought boss"],[7223,7378,"is such a hopeless romantic?"]],"64":[[392,433,"Cora."],[658,763,"I called you in,"],[779,884,"because you've been asked"],[884,1005,"to present your research"],[1005,1092,"at today's seminar."],[1201,1292,"You'll leave after lunch."],[1384,1434,"Wait, what?"],[1434,1547,"That's like no notice."],[1564,1793,"Yeah, I just heard about it myself."],[1839,1914,"It's sponsored"],[1914,2147,"by a mysterious billionaire."],[2206,2327,"It is a great"],[2327,2435,"networking opportunity"],[2435,2477,"for you."],[2702,2740,"Okay."],[2852,2986,"Thank you, Dr. Mills."],[3741,3795,"You're funny."],[3866,4004,"I'll pick you up after your classes."],[4012,4133,"Oh, no need."],[4166,4212,"I'm actually going"],[4212,4316,"to this research seminar."],[4337,4462,"I’ll just get a taxi home when I'm done."],[4521,4621,"A seminar?"],[4650,4846,"Yeah, they want me to present"],[4846,4984,"our research, so..."],[5188,5338,"Oh, sorry, I think my car's here."],[5447,5530,"Talk to you later, okay?"],[5613,5647,"Bye."],[6206,6302,"Oh, sorry,"],[6302,6443,"is no one else going to the seminar?"],[6477,6577,"The others already left."]],"65":[[108,262,"Dr. Mills recommended this."],[329,417,"So it should be fine,"],[517,554,"right?"],[1430,1559,"Adam, I need you to look into"],[1559,1680,"this research seminar."],[1710,1814,"Something feels off."],[1826,1889,"On it, boss."],[1997,2164,"Sir, the seminar is sponsored"],[2164,2264,"by Wilson Group."],[2302,2377,"Could Robert Wilson"],[2377,2456,"have figured out"],[2456,2565,"that Cora is his niece?"],[2615,2723,"Maybe this is his way"],[2723,2869,"of giving her more opportunities?"],[3011,3048,"No."],[3157,3290,"If Robert found out"],[3290,3445,"that Cora was his niece,"],[3557,3682,"he would have come straight to me."],[3782,3883,"Track her location."],[3941,4029,"Something's off."]],"66":[[542,663,"Where, where,"],[750,813,"where am I?"],[896,1042,"I was in the car to go to the seminar."],[1117,1226,"Wake up, bitch."],[1267,1455,"You've fallen right into my trap."],[1484,1543,"Alyssa?"],[1693,1780,"What are you doing?"],[1918,2035,"You might have tricked Damon"],[2035,2181,"to falling head over heels for you,"],[2218,2356,"but that all ends today."],[2414,2494,"Because you're gonna die."],[2619,2715,"You're crazy!"],[2844,2998,"Damon won't let you get away with this!"],[3061,3186,"All anybody'll know"],[3186,3315,"is you got kidnapped"],[3365,3470,"on the way to the seminar."],[3574,3724,"You brought this on yourself, Cora."],[3795,3837,"Robert,"],[3916,4004,"you're gonna murder me"],[4004,4112,"because your daughter's in love"],[4112,4195,"with my husband?"],[4283,4383,"Is that how you show her"],[4383,4446,"you love her?"],[4450,4562,"Shut up, orphan!"],[4621,4692,"You know nothing"],[4692,4804,"about a father's love."],[4859,4979,"Damon will never love you,"],[5017,5121,"even if I'm dead!"],[5146,5205,"Shut up!"],[5230,5330,"You don't know that."],[5434,5547,"This isn't even about"],[5547,5634,"Damon anymore."],[5684,5826,"It's about taking Dad's love"],[5834,5935,"away from me."]],"67":[[50,104,"Alyssa,"],[191,271,"let's wait outside."],[400,521,"Let's give Josh the honor."],[596,729,"I wanted to do it myself!"],[729,771,"No."],[880,1001,"You don't wanna see this."],[1155,1188,"Fine."],[1505,1539,"No."],[1622,1659,"No!"],[2277,2364,"Where's Cora?"],[2381,2565,"What did you do with my wife?"],[2569,2673,"I don't know what you're fucking"],[2673,2719,"talking about."],[2719,2844,"You fucking imbecile!"],[2902,3107,"If you hurt her, you'll regret it!"],[3178,3269,"She's your niece."],[3345,3428,"That's impossible."],[3532,3687,"We did a DNA test. - Yeah."],[3803,3933,"Cora and I are not related."],[3953,4054,"We have her records."],[4129,4308,"Cora's mother was named Faye Wilson."],[4391,4441,"Faye?"],[4496,4675,"No, that's my sister."],[4708,4783,"That means that..."],[4859,4909,"Oh my God!"],[4988,5096,"Too late, Daddy."],[5130,5271,"Josh never hesitates."],[5309,5413,"Cora's dead meat."]],"68":[[1197,1247,"Damon."],[2548,2585,"Cora,"],[2681,2736,"you're awake."],[2794,2877,"Damon, the baby."],[2919,3007,"Is the baby okay?"],[3019,3103,"Perfectly fine."],[3274,3486,"I'm so sorry to make you worry again."],[3632,3712,"Don't say that."],[3820,3978,"I should be the one apologizing."],[4225,4366,"I should have been there to protect you."],[4738,4884,"I do have something to tell you."],[5071,5125,"What is it?"],[5372,5459,"You said your mother"],[5459,5559,"had a younger brother,"],[5701,5818,"who vanished years ago."],[5926,6031,"You thought he was gone."],[6181,6222,"Yeah?"],[6381,6427,"Why?"],[6560,6627,"He's not."],[6986,7061,"Your uncle,"],[7365,7461,"it's Robert Wilson."],[7561,7603,"What?"]],"69":[[8,50,"What?"],[166,279,"No, no way."],[462,604,"He tried to kill me, Damon."],[746,863,"How could he be my uncle?"],[942,1067,"You don't have to forgive him."],[1292,1372,"You don't even have to"],[1372,1468,"acknowledge him."],[1760,1881,"I just thought you should know."],[2097,2185,"I don't want him."],[2715,2848,"Then from this moment on,"],[2894,3032,"he doesn't exist."],[3482,3616,"Mr. Wilson is insisting"],[3616,3766,"on seeing Mrs. Hawkins."],[3812,3933,"He says that he didn't know"],[3933,4012,"she was his niece"],[4012,4133,"and he regrets everything."],[4191,4337,"He is begging for a chance"],[4341,4458,"to explain himself."],[4537,4642,"He tried to kill me."],[4725,4825,"Family or not,"],[4867,5046,"I don't want a man like that in my life."],[5196,5263,"You heard her."],[5397,5568,"Tell Mr. Wilson he can go to Hell."]],"70":[[913,1113,"Sweetheart, are you alright?"],[1151,1305,"Yeah, I'm fine, Grandma."],[1593,1751,"Better than fine, actually."],[1780,1910,"I'm surrounded by the best people."],[2122,2248,"Sir, ma'am,"],[2310,2535,"Mr. Wilson insists on seeing Cora."],[2590,2736,"He says he won't leave until he does."],[2781,2915,"I can't believe that bastard"],[2915,3057,"had the nerve to show up here."],[3107,3157,"Let him in."],[3261,3349,"I'll handle this."],[3561,3657,"Okay, fine."],[3912,3962,"Cora!"],[4170,4320,"Cora, I know you hate me"],[4366,4454,"and I don't blame you."],[4487,4533,"I didn't know"],[4533,4642,"you were Faye's daughter."]],"71":[[50,120,"I panicked!"],[154,225,"I'm sorry."],[275,346,"I was wrong."],[412,496,"Terribly wrong."],[538,600,"My mother"],[692,909,"was a kind and gentle soul."],[942,1088,"And Alyssa has been nothing"],[1130,1205,"but cruel."],[1234,1380,"Cora, he's not worth your time."],[1539,1730,"I want Alyssa punished."],[1751,1872,"No, no, please."],[1964,2031,"She just,"],[2214,2344,"she just lost control."],[2398,2552,"She didn't know you were my niece."],[2798,2873,"Robert, leave."],[3003,3219,"I don't care that we're related."],[3432,3687,"As long as Alyssa is in your life,"],[3791,4008,"I want nothing to do with you."],[4029,4091,"You heard her."],[4220,4270,"Get out."],[4312,4391,"Cora, please."],[4642,4696,"Cora."],[4825,4934,"We're family!"],[4979,5121,"You're my only family!"]],"72":[[41,137,"Josh!"],[287,425,"Are you sure nobody tampered"],[425,550,"with that DNA report?"],[550,734,"It never even left my sight!"],[859,921,"Wait."],[934,984,"What?"],[1146,1247,"Before I brought it to you,"],[1393,1618,"Alyssa accidentally spilled"],[1618,1726,"some juice on me."],[1981,2323,"I left the report on the coffee table"],[2323,2431,"while I went to clean up."],[2477,2635,"Are you kidding me?"],[2719,2836,"Check the security reports."],[2882,2944,"On it, sir."],[3086,3123,"Sir,"],[3190,3307,"someone deleted the footage."],[3353,3591,"The maids say Miss Wilson"],[3620,3732,"asked to see it earlier."],[3837,3941,"So it was Alyssa."],[4170,4320,"She switched the reports."],[4567,4688,"That little-"],[4871,5038,"Dad, you wanted to see me?"]],"73":[[33,300,"You knew Cora was my niece."],[450,588,"You just wanted her out of the way,"],[588,638,"didn't you?"],[709,763,"Didn't you?"],[892,1180,"You even faked a suicide attempt"],[1180,1276,"to convince me."],[1351,1451,"That's, that's not-"],[1459,1522,"Enough!"],[1705,1797,"I cared about you."],[1797,1876,"I loved you."],[1939,2110,"I gave you everything."],[2185,2264,"Everything!"],[2381,2544,"And you still try to convince me"],[2544,2677,"to kill my own niece."],[2731,2777,"Dad, please-"],[2777,2811,"Don't!"],[2898,3028,"Don't ever call me that again."],[3136,3261,"I am no longer your father."],[3440,3578,"As of now, I'm disowning you."],[3782,3895,"You're no longer my daughter."],[3983,4116,"I want you out of this house"],[4170,4329,"and out of my life, now."],[4387,4425,"Go!"],[4512,4592,"Just get out!"],[4650,4688,"Go!"]],"74":[[383,738,"This is all your fault, you bitch."],[771,913,"You ruined my life."],[938,1055,"So, I'm gonna kill you."],[1059,1138,"Alyssa, no!"],[1280,1334,"Alyssa?"],[1689,1743,"Dad?"],[1914,1964,"No."],[1997,2043,"Dad."],[2114,2168,"Robert!"],[2210,2252,"Cora,"],[2402,2485,"I'm so sorry."],[2656,2840,"I owed Faye everything I have."],[2998,3244,"I've paid her back, now."],[3399,3440,"Robert!"],[3524,3566,"No!"],[3620,3670,"Someone!"],[3745,3870,"Someone call an ambulance!"],[4012,4087,"Uncle Robert."],[4154,4371,"I can die now in peace."],[4487,4542,"Thank you."]],"75":[[717,792,"Thank you, Cora,"],[905,984,"for giving me the life"],[984,1088,"I always dreamed of."],[1184,1280,"A beautiful wife"],[1488,1559,"and children."],[1768,1860,"Being a mother"],[2039,2122,"is the best thing"],[2122,2248,"that ever happened to me."],[3345,3411,"Hi, Cora."],[3465,3528,"It's Robert."],[3545,3620,"I was wondering"],[3620,3812,"if I might come see the babies."],[3933,4070,"Now that Alyssa passed away,"],[4070,4179,"you're really the only family"],[4179,4295,"I have left, I-"],[4295,4329,"Yeah."],[4483,4554,"Come see them,"],[4725,4800,"Uncle Robert."],[4904,4963,"You're sure?"],[5080,5155,"Oh, thank you!"],[5155,5230,"I'm on my way."],[5684,5768,"Sometimes,"],[5818,5939,"the family you're born with"],[5939,6031,"is taken away,"],[6143,6218,"by choice,"],[6272,6398,"by circumstance,"],[6439,6573,"or by tragedy."],[6706,6777,"And sometimes"],[6777,6881,"we get another chance"],[6881,6961,"to start over."],[7119,7244,"This is my fresh start."],[7407,7615,"And with Damon holding me close,"],[7711,7928,"the future is nothing but hopeful."]]}