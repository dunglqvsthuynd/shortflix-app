"],[1725,1862,"That's so sweet of you to care."],[1862,1962,"But I'm fine."],[1962,2041,"I'll have all this done by the time"],[2041,2112,"you get back."],[2112,2200,"Counting on it."],[3862,4012,"Still alive?"],[4012,4212,"Not too bad for a first timer."],[4450,4541,"Tyler?"],[4650,4791,"Never mind."],[4791,4954,"Tyler, come on!"],[5050,5166,"Hey!"],[5166,5341,"Tyler, do not pass out on me."],[5341,5412,"Do not."],[5412,5600,"Come on. Come on."],[5600,5700,"No, Tyler!"],[5700,5900,"Come here, come here."],[6012,6191,"Come on, come on."],[6312,6466,"Daddy! Wake up!"],[6537,6637,"Daddy, you got to get up!"],[6637,6925,"You got to get up now, okay? Please!"],[7025,7137,"Oh God!"],[7212,7404,"Come on, please, Daddy!"],[7404,7650,"Come on, Daddy, wake up!"]],"36":[[741,966,"Come on, come on, come on."],[966,1100,"Tyler!"],[1241,1429,"Yes, yes, yes, yes."],[1429,1541,"Hey!"],[1541,1625,"Oh God!"],[1625,1704,"You're okay!"],[1704,1862,"What happened?"],[1950,2154,"You almost died of heatstroke."],[2462,2575,"What's wrong?"],[2575,2737,"You look like you've been crying."],[2737,2825,"Oh, no."],[2825,2962,"I'm just..."],[2962,3212,"hot and tired from saving you, so..."],[3212,3350,"I guess"],[3350,3454,"I'm not the only one that needs to"],[3454,3525,"cool off."],[3525,3662,"Tyler, don't you dare."],[3662,3854,"No, Tyler!"],[3854,3925,"I swear-"],[4600,4850,"Avery?"],[4950,5000,"Tyler!"],[5000,5087,"Avery, what's wrong?"],[5087,5212,"I can't-"],[5441,5563,"This is everything Wyatt had on him"],[5563,5662,"when he passed."],[6075,6212,"Where's his watch?"],[6212,6391,"Beau, he hardly ever took it off."],[6391,6550,"Beau, where's the watch?"],[6550,6654,"Where?"],[6654,6762,"Tell me now!"],[6900,7041,"Avery, what's wrong?"],[7166,7229,"Calm down."],[7229,7304,"Tyler..."],[7304,7450,"- It's okay. - I can't breathe..."]],"37":[[16,141,"Deep breath, deep breath."],[350,479,"Deep breath, come on."],[479,629,"You're okay."],[700,862,"You're okay."],[979,1150,"I think I just need a minute"],[1150,1325,"to not be okay."],[1512,1600,"You don't have to go hold back"],[1600,1725,"with me, Avery."],[2050,2225,"Speak for yourself."],[3550,3700,"You want to come in?"],[3854,4116,"Don't do anything stupid, Tyler."],[4116,4241,"I should..."],[4241,4387,"finish some chores"],[4387,4566,"before the cookout tomorrow."],[4850,5025,"I'll sleep on the couch."],[5141,5237,"Yep."],[5237,5362,"Stand your ground, Ty."],[5404,5604,"Find a chore, something to do, just..."],[5604,5762,"Just don't follow her..."],[5816,5954,"Don't follow her..."],[6062,6170,"Or follow her."]],"38":[[704,850,"We should get some rest."],[937,1062,"Big day tomorrow."],[1604,1779,"Tyler, give it to me straight."],[1779,1900,"Are you avoiding me?"],[1900,2029,"Absolutely."],[2166,2350,"Then I did do something wrong."],[2350,2487,"You didn't."],[2750,2937,"Then why won't you even look at me?"],[2937,3162,"Because it's getting hard to stop."],[3162,3304,"I'm just tired."],[3650,3779,"What if..."],[3837,4075,"I promise to wear clothes this time?"],[4137,4275,"Goodnight."],[4275,4462,"Can I at least have my pillow back?"],[4525,4625,"No."],[4729,4966,"Give it back, Tyler!"],[5029,5187,"Give it back!"],[5854,6054,"Tyler, you,"],[6054,6216,"dill my pickle."]],"39":[[150,237,"Do you want to know why I wanted"],[237,375,"to sleep on the couch?"],[500,607,"It's so I didn't do something"],[607,737,"like this."],[2354,2475,"Tyler..."],[4137,4266,"Oh."],[4266,4441,"What the hell is wrong with me?"],[4516,4662,"I don't know."],[4750,4798,"Did you know you"],[4798,4962,"moan in your sleep?"],[5212,5337,"I think I'll take five more minutes"],[5337,5437,"for penance."],[5437,5541,"Yeah."],[5954,6125,"Please tell me this clock is wrong."],[6325,6425,"Shit!"],[6425,6566,"We start serving in ten minutes!"]],"40":[[150,279,"Tyler, what the"],[279,387,"hell are you doing?"],[487,562,"You look like a stiff."],[562,675,"Take this off."],[954,1087,"Here."],[1137,1225,"Simple fit,"],[1225,1387,"for simple folks."],[1387,1550,"Okay, Mom."],[1600,1737,"Just so you know,"],[1737,1812,"I've been to more banquets"],[1812,1900,"than you can count."],[1900,2012,"Oh, wow."],[2012,2166,"Class matters."],[2166,2275,"Not here."],[2275,2354,"If you...."],[2354,2500,"Here."],[2579,2766,"If you look like an outsider,"],[2766,2950,"they will treat you like one."],[3041,3125,"Am I a mess?"],[3125,3316,"I feel like my hair's a mess right now."],[3437,3566,"You look great."],[3675,3816,"Okay, come on, hurry!"],[3816,3875,"God!"],[4525,4679,"Tyler, what if this is a flop?"],[4679,4829,"What if no one comes?"],[4925,5018,"They'll come."]],"41":[[466,575,"I told you."],[900,1012,"Howdy!"],[1012,1109,"Welcome!"],[1109,1210,"Hi."],[1362,1454,"Tyler, how is this-"],[1454,1612,"how is this possible?"],[1612,1729,"You go talk to the guests."],[1729,1875,"I'll handle the kitchen, okay?"],[1875,1975,"You got it."],[1975,2104,"Go."],[2104,2250,"Hi!"],[2250,2466,"So, we got some pulled pork for you."],[2466,2525,"Beau!"],[2525,2604,"It's good to see you."],[2604,2700,"You want to have a seat?"],[2700,2887,"No need. I'll eat after we talk."],[2887,2962,"About what?"],[2962,3075,"Where I know you from."],[3075,3291,"Been bothering me since you first showed up."],[3291,3441,"I never forget a face."],[3537,3604,"Beau, I think"],[3604,3741,"I'd remember if we'd met."],[3741,3879,"You're Marissa Sinclair's son,"],[3879,4004,"ain't you?"]],"42":[[41,150,"You look just like her."],[150,202,"Your mom and I were"],[202,337,"neighbors growing up."],[337,416,"She grew up out here?"],[416,525,"Yes, sir."],[525,612,"Figures she wouldn't tell you,"],[612,779,"being the big land buyer she is now."],[779,941,"Is that why are you here, son?"],[1091,1225,"I am, listen, it's-"],[1225,1375,"It's alright."],[1375,1455,"Y'all probably think you're doing"],[1455,1575,"something good for the farmers with"],[1575,1675,"that money you offering."],[1762,1912,"I used to think so."],[1912,2050,"Money's nice,"],[2050,2108,"but it's hard for"],[2108,2241,"people like us to leave."],[2241,2350,"We're a part of this community"],[2350,2550,"as much as it's a part of us."],[2550,2691,"Does Avery know?"],[2775,2879,"Know what?"],[2879,3104,"You might end up taking her farm."],[3104,3316,"Hey Beau, welcome."],[3316,3487,"- Hey, darling. - I'm so glad you're here."],[3487,3550,"Thank you."],[3550,3675,"- Get some food! Come on! - Yeah! Let me get some."],[3675,3850,"Yeah!"],[3912,4050,"Hey, how's it going over here?"],[4050,4100,"Good."],[4100,4141,"Yeah?"],[4141,4250,"Everything's going great."],[4250,4300,"I know."],[4300,4404,"Hey, Avery!"],[4641,4729,"Do you want me to handle that?"],[4729,4850,"Ignore it."],[5537,5656,"Take your goons and get out of here,"],[5656,5704,"Sawyer."],[5704,5975,"Oh, no can do, sweetheart."],[5975,6200,"I'm here on official Bauer business."],[6200,6404,"Let's go, superstar."],[6404,6562,"Come on."],[6625,6787,"Come on."],[6854,7016,"We need to talk."]],"43":[[41,187,"We need to talk."],[712,912,"What the hell do you want, Sawyer?"],[912,1012,"See? I'm looking for a real"],[1012,1175,"important guy."],[1175,1300,"You're going to help me find him."],[1300,1462,"What are you talking about?"],[1462,1654,"Come on, Avery."],[1654,1775,"You really think a famous"],[1775,1929,"CEO like that"],[1929,2025,"would be interested in"],[2025,2262,"country trash like you?"],[2350,2416,"Tyler?"],[2416,2575,"A CEO?"],[2625,2850,"You got to lay off the drinking, Sawyer."],[2850,3091,"He's just a lowly real estate guy."],[3091,3229,"Is that what he told you?"],[3441,3675,"He's playing you, sweetheart."],[3675,3800,"My relationship is none of your"],[3800,3887,"goddamn business."],[3887,4050,"Your relationship"],[4050,4154,"is bullshit!"],[4241,4350,"Now look, I already know"],[4350,4475,"all about Tyler."],[4475,4541,"So you can go ahead and"],[4541,4629,"stop lying for him."],[4629,4787,"Lying about what?"],[4975,5175,"You really don't know, do you?"],[5612,5837,"This is going to be fun!"],[5837,5912,"Avery,"],[5912,6100,"let me ask you something."],[6212,6375,"What would you do"],[6375,6562,"if you found out that Tyler"],[6562,6862,"ain't who you think he is?"]],"44":[[266,404,"Corner me one more time,"],[404,541,"and I will bury you somewhere"],[541,787,"the dogs can't even sniff you out!"],[850,975,"Tootles, boys."],[1329,1423,"Hey."],[1450,1504,"You're shaking."],[1504,1579,"Tyler,"],[1579,1662,"are you hiding something"],[1662,1754,"from me?"],[1754,1850,"I'm hiding"],[1850,1979,"everything from you."],[1979,2112,"Because Sawyer just said-"],[2112,2212,"I said..."],[2212,2379,"he's playing you."],[2379,2579,"Just like I did."],[2579,2687,"Let me tell you something."],[2687,2854,"You're never"],[2854,3062,"going to be good enough for anyone."],[3116,3266,"She's good enough for me."]],"45":[[100,237,"Well, ain't that sweet?"],[375,687,"Shut up!"],[904,1062,"You jealous?"],[1062,1204,"Funny coming from you, Sawyer."],[1204,1312,"Someone who used Avery for her"],[1312,1387,"land and cheated on her"],[1387,1504,"with her sister."],[1504,1729,"You son of a bitch!"],[1987,2200,"Easy now, city boy."],[2200,2350,"We're on the same damn team."],[3029,3125,"Ma'am,"],[3125,3325,"I believe your son"],[3325,3475,"is dating"],[3475,3579,"Avery Rogers."],[3579,3675,"If you're accusing"],[3675,3937,"my son of betraying the company,"],[3937,4129,"get me proof or you're fired!"],[4129,4254,"Alright,"],[4254,4404,"consider it done."]],"46":[[312,479,"What would you do"],[479,700,"if you found out Tyler"],[700,937,"ain't who you think he is?"],[1162,1341,"You're not usually this quiet."],[1487,1612,"Is this about the kiss?"],[1612,1750,"I'm sorry. I should have asked you, I-"],[1750,1891,"No, I'm-"],[1891,2087,"I'm glad you did that."],[2087,2156,"You got the whole town"],[2156,2262,"talking about us."],[2262,2462,"If kissing you keeps Sawyer away,"],[2462,2612,"I don't mind if you don't."],[2612,2850,"I don't mind kissing you, Tyler."],[2850,3037,"But..."],[3037,3166,"you never asked me"],[3166,3366,"how I want to be kissed."],[3487,3662,"Well, excuse me,"],[3662,3850,"Ms. Avery."],[3850,4037,"How would you like to be kissed?"],[4125,4362,"A little something like this."],[4579,4712,"Whoever is at the door"],[4712,4841,"is a dead man."]],"47":[[200,325,"Ms. Avery."],[579,766,"Forgot your earnings for today."],[912,979,"Thank you for"],[979,1075,"keeping it safe for us."],[1075,1187,"Welcome."],[1237,1475,"And a little something extra for you, son."],[1612,1750,"Had my cousin fix you up."],[1750,1900,"She's free of charge."],[1900,2025,"Thanks, Beau, but"],[2025,2091,"I can pay you, though."],[2091,2225,"No, no, no."],[2225,2437,"You just keep doing right by Ms. Avery."],[2437,2541,"That's payment enough."],[2541,2725,"He ain't too bad."],[2725,2862,"For a city boy."],[2862,2962,"Thanks, Beau."],[2962,3179,"You should really let me pay you back."],[3179,3454,"I will take an invite to the next cookout."],[3454,3562,"Whole town's talking about your"],[3562,3737,"food, Ms. Avery."],[3737,3850,"We will let you know"],[3850,3987,"when we're hosting the next one."],[3987,4091,"Thank you."],[4141,4300,"You are"],[4300,4462,"staying for the next one,"],[4462,4575,"right?"],[5062,5212,"We got a farm to save."],[5212,5275,"Remember?"],[5275,5450,"Leave you lovebirds to it."],[5450,5529,"Night, y'all."],[5837,6029,"Tyler, we did it!"],[6175,6312,"You did it."],[6312,6425,"I just waited tables."],[6775,6891,"You want to count it?"],[7862,8000,"I can't believe it."],[8175,8300,"What's wrong?"]],"48":[[25,287,"We made $50,000."],[287,375,"You're halfway there."],[587,737,"Okay, well..."],[825,941,"I say, let's"],[941,1054,"make the next cookout"],[1054,1287,"an even bigger fundraiser. We..."],[1375,1512,"Tyler, we could save the farm."],[1512,1700,"More people, more profits."],[1887,2025,"Oh, God."],[2025,2187,"Daddy would've loved this."],[2187,2329,"He's up there watching."],[2412,2491,"Bragging to the angels"],[2491,2616,"all about you."],[2762,2912,"You are"],[2912,3104,"a good man,"],[3104,3175,"you know that?"],[3175,3375,"I'm an even better kisser."],[3679,3762,"Remind me."],[3762,3879,"I don't..."],[4466,4683,"Got you now, you sons of bitches!"]],"49":[[1112,1362,"Country life looks good on you, Tyler."],[1687,1787,"I better stop staring"],[1787,1991,"before I beg him to stay."],[2250,2350,"Shit."],[2900,3027,"Think Sawyer had a charger"],[3027,3225,"for one of these things somewhere."],[3479,3587,"Here we go."],[3587,3712,"There."],[4141,4275,"Who's this?"]],"50":[[66,150,"Tyler..."],[150,262,"Elizabeth..."],[262,525,"whatever the the heck your last name is!"],[525,654,"I want the truth."],[654,912,"Who the heck is M.S.?"],[912,1087,"If you got a girl somewhere,"],[1087,1216,"I will"],[1216,1312,"tan your hide!"],[1312,1450,"I swear."],[1450,1587,"Those are my mom's initials."],[1700,1866,"That okay?"],[1866,2000,"Yeah, I guess."],[2000,2137,"I'm sorry, I..."],[2137,2237,"snooped."],[2237,2275,"I just found your"],[2275,2350,"- phone and- - It's okay."],[2350,2454,"It's okay."],[2454,2525,"Thanks for charging that."],[2525,2675,"I honestly thought it was dead."],[2737,2879,"No problem."],[2879,2954,"Hey, I saw you"],[2954,3100,"bonding with Buckeye."],[3100,3250,"We've got some time together."],[3391,3529,"Hey, I bet you"],[3529,3633,"50 bucks, you can't even"],[3633,3725,"mount him right."],[3725,3900,"Well, little lady."],[4350,4475,"You're on."],[6729,6800,"Why don't you take Buckeye"],[6800,6925,"back to the barn?"],[6925,7062,"I'll be right behind you."],[7062,7162,"Everything alright?"],[7162,7275,"Everything's fine."],[7275,7387,"Alright."],[7387,7487,"Come on."],[7775,7887,"Hey, Mom."],[7887,8004,"Sorry I've been MIA, the..."],[8004,8250,"signal out here is terrible, I don't-"],[8250,8554,"Tell me you've closed the deal."]],"51":[[41,412,"Tell me you've closed the deal."],[412,604,"I just need a few more days."],[1112,1229,"Days?"],[1229,1425,"She should have signed the papers by now."],[1425,1600,"You are a Sinclair!"],[1600,1729,"Act like it!"],[1729,1837,"Your father would be-"],[1837,2012,"Don't even talk to me about him!"],[2012,2187,"I know what he did to Wyatt Rogers."],[2187,2300,"How he sent guys like Sawyer to"],[2300,2387,"drive her into the ground."],[2387,2629,"Your father did what was necessary"],[2629,2862,"as CEO of Bauer Industries!"],[2862,3075,"I expect you to do it the same."],[3075,3154,"Fuck the company!"],[3154,3325,"What about what's necessary for her?"],[3325,3466,"For the town?"],[3466,3570,"You get me that farm"],[3570,3850,"in the next 24 hours."],[3850,3975,"Or Avery"],[3975,4079,"dies."]],"52":[[454,616,"Hey, stranger!"],[616,800,"What do you think about having lunch here?"],[800,887,"Maybe some other time."],[887,962,"There's still some things"],[962,1075,"that need to be fixed around here."],[1075,1161,"That can wait."],[1325,1441,"Hey,"],[1441,1550,"what's wrong?"],[1550,1729,"Tyler, look at me."],[1729,1987,"What is going on?"],[1987,2212,"I'm more trouble than you know, Avery."],[2212,2354,"I know."],[2354,2500,"You're right."],[2500,2612,"You are."],[2612,2737,"So you know?"],[2737,2816,"Yeah,"],[2816,2987,"I know that you..."],[3187,3341,"Broke my fence"],[3341,3554,"and lost my cows."],[3554,3625,"Avery, there's something that I"],[3625,3737,"need to tell you-"],[3841,4037,"I know that you are stubborn."],[4037,4350,"And you argue like the devil."],[4429,4591,"And I know that I really"],[4591,4787,"hated you for a little while."],[4787,4962,"I don't anymore."],[4962,5075,"Tyler..."],[5141,5229,"I..."],[5229,5437,"Don't. Don't say it. Not to me."],[5437,5612,"You don't know me, Avery."],[5612,5662,"If you did-"],[5662,5775,"Then what?"],[5825,5925,"Would it make you not want to"],[5925,6079,"kiss me?"],[6079,6187,"No."],[6262,6387,"Then come here."],[7475,7616,"Avery, we should stop."],[7616,7687,"That's not what you said"],[7687,7741,"five minutes ago."],[7741,7887,"Seriously, there's..."],[8012,8162,"some things that I haven't told you."],[8162,8259,"It's okay."],[10450,10608,"Time's up, Tyler."]],"53":[[25,91,"You shouldn't be here."],[91,212,"I told you, I can take care of it."],[212,362,"Clearly, you haven't."],[362,562,"Beautiful property, Avery."],[562,800,"Tyler has excellent taste."],[800,900,"Thank you, ma'am."],[900,987,"Do we know each other?"],[987,1137,"You sound familiar."],[1137,1341,"Oh, your father and I were..."],[1341,1412,"acquainted."],[1412,1525,"I tried to"],[1525,1600,"help him make better"],[1600,1712,"business decisions,"],[1712,1979,"but he was such a stubborn man."],[1979,2150,"What kind of decisions?"],[2150,2212,"Well, ones that would've"],[2212,2379,"given him a future."],[2437,2687,"Shame he was so short-sighted."],[2687,2837,"Dying over this"],[2837,2925,"piece of dirt"],[2925,3087,"was stupid at best."],[3341,3675,"Careful, kitten. I have claws."],[3675,3787,"That's enough!"],[3837,3937,"I want to know who she is"],[3937,4029,"and why the hell she's here?"],[4029,4187,"Avery, just stay out of it."],[4187,4450,"She doesn't know yet, does she?"],[4450,4554,"Doesn't know what?"],[4554,4650,"Oh, you know,"],[4650,4829,"Tyler's big surprise."],[4941,5091,"Can't wait for you to find out,"],[5091,5179,"\"darling\"."],[5179,5350,"What the hell is going on?"],[5350,5429,"Oh!"],[5429,5550,"Can't wait to see y'all"],[5550,5716,"at the big cookout!"],[5975,6062,"Sawyer,"],[6062,6312,"come to the Rogers Farm with your boys."],[6312,6633,"And do exactly as we discussed."]],"54":[[50,105,"You want to tell me"],[105,204,"what all that was about?"],[204,375,"Who was she, Tyler?"],[375,491,"My boss."],[491,600,"Your boss?"],[600,787,"You work for someone like that?"],[787,850,"You don't know her."],[850,925,"And I'm starting to think"],[925,1062,"I don't know you!"],[1062,1254,"What secret is she talking about?"],[1254,1350,"What are you hiding?"],[1350,1475,"Everything!"],[1525,1650,"You want to know the truth?"],[1650,1812,"This little thing we got going on?"],[1812,1941,"It's a fever dream!"],[1941,2087,"Avery, wake up!"],[2087,2237,"Why are you acting like this?"],[2237,2412,"Because this is me!"],[2412,2600,"I go to little towns just like this one,"],[2600,2737,"and convince people like you"],[2737,2979,"that I'm a better guy than what I am!"],[2979,3100,"I'm a land buyer,"],[3100,3225,"Avery."],[3225,3387,"You were just part of the job."],[3387,3562,"You don't mean a damn thing"],[3562,3687,"you're saying to me right now."],[3687,3879,"- Tell me you don't- - I'm a CEO."],[3879,4037,"I mean"],[4037,4162,"everything"],[4162,4304,"that I say."],[4904,5075,"They're burning the farm!"],[5075,5179,"Oh no!"],[5287,5454,"Avery! Wait, Avery!"],[5629,5754,"Avery!"]],"55":[[212,337,"Oh, God."],[750,854,"Tyler?"],[975,1054,"Oh, God."],[1054,1187,"Please don't be gone."],[1600,1700,"It's okay."],[1916,2129,"He was always going to leave."],[2316,2500,"Everyone leaves."],[2629,2787,"Everyone..."],[3179,3362,"Got everything lined up just back here."],[3362,3475,"Thank you so much."],[3475,3587,"The rest you, have a seat."],[3587,3716,"Make yourselves at home."],[3716,3812,"Appreciate you."],[3904,4016,"Ms. Avery,"],[4016,4133,"we all heard you can use some help"],[4133,4316,"with the cookout this morning."],[4316,4462,"I could"],[4462,4566,"use some help."],[4566,4825,"And I'm so glad everyone's here, but..."],[4962,5062,"Oh, what about Sawyer and all-"],[5062,5200,"Oh, we arrested him and his boys"],[5200,5354,"early this morning."],[5354,5466,"Found him tied up and beaten"],[5466,5650,"in the middle of one of your fields."],[5650,5862,"Tyler's work, I'm guessing."],[5862,6016,"You seen him?"],[6016,6150,"No."],[6150,6275,"But we all heard from him."],[6275,6375,"He called the whole town"],[6375,6591,"one by one to come help you out."],[6591,6754,"Then disappeared."],[6754,6841,"He-"],[7279,7391,"It's okay."],[7391,7550,"It's going to be okay."],[7662,7862,"I know Tyler's not here,"],[7862,7950,"but the whole town's here"],[7950,8100,"to help you, Ms. Avery."],[8100,8212,"Now,"],[8212,8366,"you ready to save your farm?"],[8366,8550,"Hell yeah I am!"]],"56":[[762,925,"Hi!"],[1116,1237,"Thanks for coming."],[1337,1550,"Stop looking for ghosts."],[1550,1687,"He ain't coming back."],[1800,1900,"My mind's wandering"],[1900,1987,"a little bit."],[2037,2150,"You got nothing to wonder."],[2250,2350,"Enjoy, guys."],[2350,2450,"Ms. Avery,"],[2450,2535,"I figured you'd want to hear"],[2535,2625,"the news from me first."],[2625,2762,"Everything okay?"],[2762,2879,"More than okay!"],[2879,2991,"You blew past your goal!"],[2991,3137,"Congratulations, Ms. Avery!"],[3137,3275,"No..."],[3275,3479,"- Oh my God! - You did it, darling!"],[3479,3525,"You did it!"],[3525,3675,"Shut up!"],[3675,3775,"You did it, darling."],[3775,3900,"You want to say a few words?"],[3900,3950,"Okay!"],[3950,4000,"Come on."],[4000,4112,"Okay."],[4112,4229,"Hi, everyone."],[4229,4404,"I just have to say,"],[4404,4662,"I could not have saved this farm"],[4662,4904,"without each and every one of you."],[4904,5062,"And I know my daddy"],[5062,5241,"would be so"],[5241,5466,"gosh darn grateful."],[5466,5587,"So..."],[5587,5762,"thank you!"],[5762,5937,"And this farm belongs to-"],[5937,6100,"Bauer Industries!"]],"57":[[75,200,"Proof of purchase."],[200,316,"Bauer bought your farm's"],[316,425,"debt this morning."],[425,675,"Your land is ours now."],[675,812,"And y'all"],[812,925,"are trespassing."],[925,1062,"Boys!"],[1162,1325,"No, don't you touch them!"],[1325,1454,"They didn't do nothing wrong."],[1454,1541,"I don't know"],[1541,1712,"who the hell you think you are!"],[1712,1850,"Marissa Sinclair!"],[1850,1962,"Tyler's mother."],[1962,2112,"And chairwoman of Bauer."],[2112,2187,"Turns out,"],[2187,2402,"you're just as stubborn as your father."],[2402,2591,"And look where that got him."],[2591,2775,"Oh, save your claws, kitten."],[2775,2887,"I'm not the one who bought your"],[2887,3075,"decrepit farm."],[3075,3262,"What do you mean you didn't buy it?"],[3262,3429,"Well, I'll give you a hint."],[3429,3550,"He's been right in front of you"],[3550,3641,"the whole time."],[3691,3825,"Sawyer."],[3825,3941,"That son of a bitch!"],[3941,4104,"It wasn't Sawyer."],[4375,4500,"It was me."]],"58":[[237,325,"What exactly are you"],[325,437,"saying right now?"],[437,700,"Bauer told me to buy the farm."],[700,837,"And as the CEO, I did."],[837,1025,"No! Don't touch me!"],[1025,1187,"Beau, get him out of here!"],[1187,1366,"Beau, just... give me a second."],[1416,1625,"I own the farm now,"],[1625,1700,"but I'm not leaving here"],[1700,1862,"until you understand why."],[1912,2212,"I told you everything"],[2212,2416,"and you used it against me!"],[2491,2587,"You knew"],[2587,2804,"this farm is the one thing I have left!"],[2804,3066,"- And you chose- - I paid off this farm,"],[3066,3291,"so that I could give it back to you."],[3375,3512,"You're debt-free."],[4029,4112,"Bauer Industries won't"],[4112,4204,"bother you anymore."],[4204,4400,"You did what?!"]],"59":[[12,150,"You transferred ownership"],[150,279,"back to her?"],[350,462,"The board and I won't allow-"],[462,619,"Mom, you and the board are under investigation"],[619,829,"for your involvement in Wyatt Roger's death."],[929,1000,"I don't know what you're talking-"],[1000,1125,"Coercion,"],[1125,1279,"slander, bribery."],[1337,1427,"Beau'll explain the rest to you"],[1427,1504,"down at the station."],[1791,2041,"Tyler, you didn't just save the farm,"],[2154,2325,"you got us back all our land."],[2325,2491,"Why would you do this for us?"],[2562,2737,"I fell in love with this place."],[2916,3166,"But first, I fell in love with you."],[3412,3562,"Wait, no!"],[3612,3725,"I'm still mad at you!"],[3725,3818,"I hold a grudge"],[3818,3954,"like you wouldn't believe."],[3954,4066,"That's okay."],[4125,4275,"We got time."],[5054,5116,"I'm already late."],[5116,5212,"It's not charged."],[5554,5691,"Can I get a ride?"],[5787,5925,"Should've bought a horse."],[6800,6962,"Now that you're all settled in,"],[6962,7037,"I'd like to introduce you"],[7037,7141,"to the head of the new land"],[7141,7300,"preservation initiative."],[7300,7390,"And the heart and soul"],[7390,7525,"of Bauer Industries."],[7804,7929,"Morning, y'all."],[8012,8154,"Let's get to work."]]}