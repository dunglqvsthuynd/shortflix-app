amily."],[525,737,"No parents, no real background."],[750,975,"If anyone is the heiress, it's Felicia."],[1000,1112,"The real Mafia Heiress"],[1112,1300,"would never shop at a thrift store."],[1500,1675,"Yeah, look at them side by side."],[1700,1925,"Who screams mafia royalty here?"],[1937,2125,"God, she's so dirty."],[2187,2275,"Fucking slut."],[2325,2412,"And a liar."],[2450,2537,"Pathetic."],[2575,2712,"They turn so easily."],[2737,2812,"It doesn't matter."],[2837,2912,"Any minute now,"],[2912,3112,"they'll all be kissing my feet."],[3187,3262,"Get off me."],[3350,3425,"Look at you."],[3487,3600,"You worthless slut."],[3675,3787,"The truth always comes out,"],[3837,3912,"doesn't it?"],[4000,4187,"You ignorant piece of shit."],[4262,4375,"You don't know."],[4450,4637,"You have no fucking idea"],[4637,4750,"who you're talking to."]],"57":[[12,200,"I know exactly who I'm talking to."],[237,387,"The boss's fuck toy."],[475,537,"And you?"],[575,725,"You pathetic lapdog,"],[737,925,"you're always licking boots for scraps."],[975,1100,"Always groveling,"],[1137,1275,"looking for the first chance"],[1287,1475,"to flatter a slut."],[1675,1725,"Yeah,"],[1725,1912,"fuck toy is a perfect name for her."],[1937,2062,"You know what, Santini?"],[2137,2287,"I've always fucking hated you."],[2387,2500,"Look at you walking around"],[2500,2650,"like you own everything."],[2725,2925,"But you're nothing but a dog on a leash."],[2975,3062,"Guess what?"],[3087,3287,"Half the crew, they answer to me now."],[3337,3437,"But you don't even know that."],[3775,3862,"Half the crew,"],[3875,4050,"they take orders from me now."],[4087,4212,"But you're too arrogant"],[4212,4312,"to even notice that."],[4375,4512,"The East Side shipments,"],[4525,4600,"the gun running,"],[4650,4816,"money laundering operations,"],[4912,5087,"that's me, they're mine."],[5275,5475,"So you and your dirty little slut"],[5525,5600,"aren't even gonna make it"],[5600,5758,"out of here alive tonight."],[6000,6070,"Oh..."],[6175,6275,"Did you catch all that, Dad?"],[8050,8150,"Who dares lay a finger"],[8150,8237,"on my daughter?"]],"58":[[54,141,"Boss."],[191,379,"It's him, Eddard Valenti,"],[479,591,"the Mafia Boss."],[1429,1579,"Boss, boss, you don't understand."],[1891,2054,"I was protecting your reputation."],[2066,2141,"That whore,"],[2166,2304,"she's responsible for everything."],[2304,2504,"She's a mockery for what we stand for."],[2729,2916,"You pathetic piece of shit."],[3129,3191,"Think I don't know"],[3191,3429,"about your little side businesses?"],[3616,3704,"Your skimming?"],[3829,3966,"Your deals behind my back?"]],"59":[[16,166,"Take this worthless shit"],[166,254,"out of my sight."],[329,429,"Feed him to the sharks"],[429,566,"and make sure nothing's left."],[1141,1204,"Oh my God,"],[1204,1404,"Arya is the real Mafia Heiress."],[1416,1554,"We're so fucked."],[1604,1754,"Arya, my sweet daughter."],[1816,1966,"You choose to hide your identity,"],[1991,2104,"and I respected that,"],[2104,2154,"but tonight"],[2154,2266,"has gotten way out of hand."],[2304,2416,"I will not allow my daughter,"],[2429,2491,"a Valenti,"],[2504,2679,"to be abused or talked down."],[2804,2916,"And these cocksuckers"],[2916,3004,"are done!"],[3104,3179,"You're all expelled"],[3179,3304,"and your futures are ruined."],[3366,3466,"I own the city,"],[3516,3591,"and I'll make sure"],[3641,3704,"that you're gonna spend"],[3704,3866,"the rest of your miserable lives"],[3866,3991,"in the gutter where you belong."],[4066,4241,"And if any of you other maggots"],[4266,4404,"even looks at my daughter wrong,"],[4479,4741,"I'll bury you so deep"],[4791,4916,"your mothers won't remember"],[4916,4991,"your names."],[5066,5229,"This can't be happening."]],"60":[[79,279,"Arya, our Mafia Heiress."],[579,641,"Woo!"],[1154,1291,"As for Felicia and Jack,"],[1379,1454,"they're yours."],[1829,1941,"We were just following orders"],[1941,2066,"from that psycho bitch."],[2116,2329,"Please, Arya, we're so sorry."],[2354,2491,"We never wanted to hurt you."],[2541,2654,"She made us do it."],[2679,2766,"Tell them, Felicia."],[2791,2954,"Tell them how you planned all of this"],[2954,3054,"and how you would destroy anyone"],[3054,3204,"that didn't follow your orders."],[3204,3316,"We were scared of her."],[3354,3479,"You have to believe us."],[3504,3641,"She is the real monster here."],[3679,3741,"She is the one"],[3741,3879,"who wanted to hurt Daisy too."],[3929,4041,"Arya, please,"],[4116,4191,"give us mercy."],[4191,4279,"We'll do anything."],[4666,4741,"Take them out."],[5416,5479,"Please!"],[5529,5804,"Please, Arya, I'm begging you."],[5804,5954,"Don't, don't listen to them."],[5979,6041,"From now on,"],[6041,6204,"I'll worship the ground you walk on."],[6254,6404,"I'll be your servant."],[6579,6654,"Interesting,"],[6691,6791,"because I don't recall you"],[6791,6891,"showing me any mercy"],[6891,7041,"when you pushed me out of the window."],[7104,7179,"What window?"]],"61":[[29,266,"Right, she doesn't know I was reborn."],[304,491,"To her, that's still in the future."],[554,679,"Arya, baby, please."],[691,804,"Remember what we had."],[841,929,"I made a mistake,"],[929,1066,"I was stupid because of..."],[1079,1191,"because of that bitch."],[1229,1354,"I'll leave Felicia right now."],[1366,1504,"I'll do anything that you want."],[1504,1579,"Okay, please?"],[1804,1866,"You made me"],[1866,2004,"your personal punching bag,"],[2104,2266,"the laughingstock of the school,"],[2316,2379,"the orphan"],[2379,2516,"that everyone could spit on."],[2604,2679,"You know what?"],[2729,2904,"Tonight, everything changes."],[3316,3441,"Karma isn't just a bitch."],[3479,3566,"She's a Valenti."],[3629,3804,"And we always collect our debts."],[3825,4020,"Tonight, you two will be our servants."],[4037,4112,"To pay me back"],[4112,4295,"for the humiliation you caused me."],[5816,5891,"Just remember,"],[6016,6091,"hurt my daughter,"],[6116,6229,"and you'll find out exactly"],[6229,6329,"how creative I can be