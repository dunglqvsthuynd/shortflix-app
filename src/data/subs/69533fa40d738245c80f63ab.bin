{"1":[[16,179,"My name is Arya Valenti,"],[179,391,"but instead I chose to become Arya Doe,"],[429,504,"a nobody."],[579,791,"My father runs the largest mafia family"],[791,866,"in the country."],[891,1016,"I cut ties with the family"],[1016,1179,"so I could become an FBI agent"],[1216,1329,"to fight for justice"],[1329,1454,"under a new identity."],[1616,1754,"Please stop!"],[1954,2041,"Please stop!"],[2041,2129,"Get away from her!"],[2166,2304,"Arya Doe."],[2416,2529,"You've got to be kidding me."],[2645,2754,"You know who I am, right?"],[2904,3091,"I'm the Mafia Heiress."],[3266,3454,"Are you sure about that title, Felicia?"],[3491,3566,"Because I'm pretty sure"],[3566,3716,"I'm the real Valenti heiress."],[3779,3954,"Do you hear how insane you sound?"],[4154,4250,"Want proof?"],[4291,4441,"I have the family crest tattoo."],[4458,4550,"You can't fake it."],[4679,4779,"No, no, no, no."],[4841,4920,"She can't be,"],[4966,5091,"the Mafia Heiress?"],[5141,5316,"This is your last chance, Felicia."],[5366,5591,"Let her go or I'll expose everything."],[5716,5829,"She knows too much."],[5854,5991,"If word gets back to her father,"],[6016,6091,"I'm dead."],[6141,6254,"She has to die."],[6329,6504,"Right here, right now."],[6616,6708,"Arya look out!"],[6891,6966,"Over here!"],[7066,7166,"Hold this bitch down."],[7204,7516,"You made a big mistake, little Doe."],[7641,7816,"Power belongs to me,"],[7916,8179,"and you have no one by your side."],[8454,8516,"I need you."],[8604,8716,"Classroom 204."],[8816,8879,"Now."],[9191,9241,"Arya?"],[9254,9329,"Jack?"],[9404,9491,"Why are you here?"],[9616,9654,"Honey,"],[9679,9791,"what are you doing with Felicia?"],[9791,9954,"Surprise, surprise."],[10004,10266,"Your dear little boyfriend,"],[10316,10504,"your one and only support,"],[10566,10691,"is on my side too."],[10791,10966,"You know they're nothing but filth."],[10979,11129,"How could you be a part of this?"],[11204,11329,"Because I realized"],[11329,11466,"that power is everything."],[11491,11616,"You know, without it, you're nothing."],[11641,11779,"I was tired of being invisible."],[11779,11916,"I was tired of being a nobody."],[11966,12179,"Felicia is the real Mafia Heiress."],[12179,12304,"You don't want to mess with her, Arya."],[12329,12454,"No, Jack, she's lying."],[12516,12679,"She can't be the real Mafia Heiress"],[12679,12704,"because-"],[12704,12779,"Please!"],[12841,12891,"Everyone knows"],[12891,12979,"you've been jealous of me"],[12979,13066,"since high school."],[13966,14120,"This is the last time"],[14120,14279,"you'll threaten me, Doe."],[15166,15304,"Giving up your real identity"],[15304,15404,"to play the hero?"],[15479,15579,"Pathetic."],[15654,15779,"You're destined to fail."],[15879,16116,"Not even another life could change that."],[16179,16329,"I'm still the Mafia Heiress,"],[16366,16504,"and you're still nothing."],[16604,16741,"And you'll die nothing."],[16925,17083,"It can't end this way,"],[17137,17320,"I tried so hard to be good."],[17395,17654,"Yet, all I get is betrayal and pain."],[17666,17816,"If I had a second chance,"],[17904,18016,"I'd make them pay."],[18116,18291,"I'd show them what real power is."]],"2":[[16,104,"Power is everything."],[104,229,"You're destined to fail."],[229,366,"I'm still the Mafia Heiress."],[479,591,"I'd make them pay."],[666,829,"If I had a second chance."],[1004,1179,"Whoa, what's happening?"],[1270,1316,"I'm-"],[1341,1454,"I'm supposed to be dead."],[1454,1541,"Earth to Doe."],[1579,1791,"Did the cafeteria mystery meat"],[1804,2016,"finally kill your last brain cell?"],[2254,2329,"High school?"],[2379,2479,"2021?"],[2541,2641,"Am I dreaming?"],[2766,2879,"This can't be real."],[2891,2991,"What's wrong, freak?"],[3041,3229,"Having another mental breakdown?"],[3291,3416,"Look at her just lying there"],[3416,3529,"like a roadkill."],[3541,3716,"Probably dreaming about having parents"],[3716,3866,"who actually wanted her."],[4154,4195,"Wait,"],[4216,4341,"this exact moment."],[4416,4541,"I've lived this before."],[4679,4745,"You look more - You look more"],[4745,4800,"pathetic than - pathetic than"],[4800,4875,"than usual today. - than usual today."],[5241,5329,"What the fuck?"],[5354,5466,"Are you mocking me?"],[5479,5579,"Holy shit."],[5641,5754,"I'm actually back."],[5779,5891,"I'm really reborn."],[6116,6216,"I remember everything."],[6291,6429,"Everything you've ever done to me."],[6429,6591,"You think you can talk to me like that?"],[6641,6716,"You little-"],[7116,7204,"Saved by the bell."],[7404,7504,"But this isn't over."],[7516,7604,"This life,"],[7616,7754,"you're the ones who are gonna suffer."],[8091,8166,"I'm not going to be seen"],[8166,8454,"as a pathetic, weak, poor orphan Doe."],[8504,8579,"I'll show you"],[8579,8754,"that you're messing with the wrong girl."],[9062,9154,"But how?"],[10354,10504,"There's my princess."],[10616,10691,"Dad?"]],"3":[[20,158,"Why is my daughter covered in food?"],[170,233,"What happened?"],[270,345,"Did someone hurt you?"],[358,558,"In my past life, I thought cutting ties"],[558,658,"with my mafia father"],[658,745,"would give me a chance"],[745,858,"to live my own life,"],[883,970,"away from crime"],[970,1158,"and seek justice under a new identity."],[1170,1270,"But I was wrong."],[1283,1358,"Dad, I'm fine."],[1445,1533,"Last time I checked,"],[1533,1645,"you've already come to visit me"],[1645,1770,"like ninety-nine times."],[1808,1870,"I know,"],[1958,2108,"but maybe a hundred times is the charm."],[2808,2908,"Sweetie, come home with me."],[2920,2958,"Dad-"],[2958,3083,"Before you say no again,"],[3133,3270,"I know you think our family"],[3270,3395,"is dangerous."],[3408,3520,"I know you probably"],[3520,3608,"won't change your mind,"],[3658,3733,"but you're my daughter."],[3758,3895,"I don't care if you ever touch the work."],[3908,3983,"It's just,"],[3995,4120,"I keep hoping you'll come back home."],[4220,4295,"Dad,"],[4333,4408,"I'll come home."],[4458,4520,"What?"],[4633,4758,"Did you just say yes?"],[4845,4945,"I've realized that"],[4995,5108,"wolves in sheep's clothing"],[5108,5220,"are the worst kind."],[5270,5383,"At least you've always been honest"],[5383,5483,"about being a wolf."],[5558,5720,"I thought I could hide who I was,"],[5733,5770,"but,"],[5808,5958,"wanting to do good isn't enough."],[5995,6095,"You need power to protect"],[6095,6195,"what matters."],[6270,6408,"Everyone deserves a second chance,"],[6445,6570,"for you and for me."],[6608,6695,"You've grown up."],[6920,7020,"Finally seeing the world"],[7020,7120,"as it really is."],[7233,7320,"I've been,"],[7358,7433,"carrying this,"],[7520,7608,"waiting for this moment."],[7745,7858,"Welcome home, my princess."],[7958,8020,"Last life,"],[8037,8183,"I abandoned my identity,"],[8183,8270,"but in the end,"],[8270,8433,"I was still betrayed and killed."],[8445,8633,"This life, I'll embrace who I am,"],[8658,8808,"the Mafia Heiress,"],[8820,9045,"and fight for justice on my own terms."]],"4":[[300,350,"Arya."],[450,562,"Thank God I found you."],[675,837,"I heard about the cafeteria thing."],[862,925,"Are you okay?"],[950,1100,"Oh, that's right."],[1116,1250,"We were already dating back"],[1250,1312,"in high school."],[1325,1500,"Look at him, putting on an act."],[1525,1725,"So concerned, so caring."],[1737,1887,"How did I ever fall for this shit?"],[1900,1962,"I'm fine."],[1975,2100,"You did so well,"],[2141,2212,"on your exam"],[2212,2275,"that I thought maybe"],[2275,2437,"we could celebrate tonight"],[2437,2575,"at the costume party."],[2600,2687,"Costume party?"],[2750,2800,"Yeah,"],[2912,3000,"I have something special"],[3000,3112,"planned there for us."],[4091,4241,"Such a loser!"],[4700,4754,"Right,"],[4787,4937,"my public humiliation."],[4975,5125,"How could I forget the grand finale?"],[5125,5200,"So what do you say?"]],"5":[[112,262,"That sounds absolutely amazing."],[350,450,"Aw!"],[575,675,"Trust me."],[850,937,"It'll be unforgettable."],[1225,1425,"Should I wear something special"],[1462,1562,"underneath the costume?"],[1587,1637,"No,"],[1662,1762,"just be yourself."],[1825,1950,"You're perfect no matter what."],[2650,2775,"This is going to be too easy."],[3425,3500,"Arya Doe,"],[3516,3612,"dies tonight."],[3650,3800,"Time for the real Arya Valenti"],[3800,3900,"to make her entrance."],[4050,4137,"They want a show?"],[4387,4562,"I'll give them one they'll never forget."],[5050,5225,"Did our little charity case"],[5225,5312,"get the invite?"],[5325,5487,"She was practically begging for it."],[5512,5587,"Even asked me what to wear"],[5587,5687,"under the costume."],[5762,5841,"I,"],[5862,6025,"already set up the livestream."],[6062,6187,"So the moment she comes in,"],[6187,6275,"this is going viral."],[6675,6725,"You know what I can't"],[6725,6812,"stand about her?"],[6837,6962,"She's always thinking"],[6962,7112,"she's better than everyone else."],[7162,7362,"That she's so smart,"],[7362,7525,"so righteous,"],[7525,7675,"so above it all."],[8087,8275,"Ever since she started dating Jack,"],[8287,8487,"suddenly she thinks she matters."],[8512,8662,"But she has no clue."],[8700,8875,"Jack does whatever I tell him to."],[8912,8987,"Tonight,"],[9000,9162,"I'm going to show her exactly"],[9162,9275,"where she belongs."],[9637,9725,"Who is she?"],[10000,10150,"She's fucking gorgeous."]],"6":[[441,579,"What the actual fuck?"],[604,766,"You stole my life once."],[779,891,"I'm taking it back."],[929,1029,"This time you'll pay."],[1104,1229,"Down you go, Felicia."],[1316,1391,"Arya?"],[1391,1566,"Holy shit!"],[1591,1716,"You look incredible."],[1791,1916,"I mean, you were always pretty,"],[1916,2029,"but tonight,"],[2104,2179,"damn."],[2304,2404,"You deserve"],[2420,2516,"a reward"],[2541,2654,"for looking this good."],[2779,2904,"How about a dance with Jack?"],[2966,3054,"How nice of you,"],[3079,3116,"but,"],[3129,3216,"no thank you."],[3229,3304,"Did she just,"],[3358,3441,"reject me?"],[3479,3591,"She usually follows me around"],[3591,3666,"like a puppy."],[3679,3829,"The smallest bit of attention from me"],[3829,3916,"makes her day."],[3966,4079,"Nice makeover, Doe."],[4116,4279,"But wearing designer knockoffs"],[4341,4504,"doesn't change who you are underneath."],[4541,4666,"You can't polish a turd."],[4704,4829,"Guess some people will always"],[4829,4966,"be desperate for attention."],[5016,5204,"And some people will always be the same."],[5254,5429,"Jealous, cruel, and pitiful."],[5654,5779,"You never change, Felicia."],[5816,5908,"Not in college,"],[5908,5979,"not ever."],[6029,6091,"What?"],[6141,6254,"You can see the future now?"],[6429,6566,"And what if I actually can?"],[6641,6779,"What if I already know exactly"],[6779,6891,"where you'll be, Felicia?"],[6916,7016,"Still pretending,"],[7041,7179,"still desperately clinging"],[7179,7266,"to the Valenti name"],[7266,7391,"that was never yours."],[7416,7591,"What the fuck are you talking about?"],[7654,7804,"You're insane, freak."],[7929,8004,"Maybe."],[8029,8104,"Or maybe I already know"],[8104,8216,"how your future lands."],[8241,8454,"Every single piece."],[8816,8979,"You fucked up our plans, dipshit."]],"7":[[145,220,"So, Felicia,"],[345,458,"tell us about your uncle's"],[458,558,"mafia stuff."],[587,650,"Ooh."],[658,783,"You want the real gossip?"],[795,908,"Well, I heard that"],[908,1083,"the mafia boss's daughter"],[1120,1308,"returned home after years."],[1320,1408,"No way."],[1445,1533,"The legendary Valenti"],[1533,1633,"family heiress?"],[1645,1820,"No one's ever seen her publicly."],[1833,1920,"Do you have a photo?"],[1995,2108,"Well, the Mafia Heiress"],[2108,2208,"likes to keep her identity"],[2208,2308,"on lockdown."],[2333,2420,"She doesn't want to just,"],[2483,2558,"walk around"],[2558,2733,"and randomly run into people."],[2820,2945,"That's how you stay powerful."],[3083,3195,"But I do have a picture"],[3195,3345,"of something she owns."],[3583,3708,"My uncle got this photo."],[3783,3845,"Wow."],[3895,4020,"Imagine meeting her."],[4058,4108,"Well, my uncle's"],[4108,4208,"gonna introduce me"],[4208,4320,"to her really soon."],[4358,4483,"We'll be best friends in no time."],[4520,4608,"And then I'll introduce"],[4608,4683,"you guys to her."],[4758,4820,"Last life,"],[4820,5045,"you stole my Mafia Heiress identity."],[5095,5295,"That's why in this life, I returned home"],[5308,5420,"before you could do it again."],[5458,5620,"And now you're just trying every way"],[5620,5758,"to be as relevant to the heiress"],[5758,5833,"as possible."],[5883,5933,"God,"],[5958,6108,"how desperate can you be?"],[6858,6983,"No, that's impossible."]],"8":[[270,345,"Where did you get that?"],[408,520,"What is wrong with you?"],[545,733,"This girl delivers pizzas to my house."],[758,808,"How does she have"],[808,945,"a Valenti family heirloom?"],[983,1095,"I don't know what you're talking about."],[1095,1245,"It's always belonged to me."],[1295,1383,"That's impossible."],[1383,1420,"Do you even know"],[1420,1520,"how much that is worth?"],[1520,1670,"If that's a million-dollar"],[1670,1758,"necklace,"],[1845,2008,"why do you still look like trash?"],[2033,2233,"I swear to God that's fake."],[2258,2308,"Yeah."],[2333,2483,"Where'd you get that pathetic replica?"],[2558,2633,"Off of eBay?"],[2795,2920,"Just trying to pretend"],[2920,3058,"that she's somebody."],[3145,3233,"Pretending has always been"],[3233,3395,"your specialty, Felicia."],[4033,4208,"How dare you hit me!"],[4258,4383,"This is my party"],[4383,4520,"and I want you the fuck out!"],[4570,4620,"Since when"],[4620,4745,"does she fight back like that?"],[4783,4895,"What the hell happened to her?"],[4908,4983,"Security!"],[5058,5170,"Get this psycho out of here."],[5220,5383,"Arya, just stop putting up that front"],[5383,5483,"and say you're sorry."],[5483,5608,"Felicia will let you stay if you do."],[5633,5708,"What if I don't want to stay"],[5708,5795,"at this party?"],[5845,5920,"I just want her to stop"],[5920,6045,"smearing my name."],[6258,6333,"Wait."],[6520,6633,"You want proof it's real?"],[6645,6708,"What?"],[6783,6870,"A fake receipt?"],[6983,7095,"There's a serial number."],[7120,7245,"Only the real one has it."],[7333,7445,"Oh, I know about this."],[7470,7608,"My dad collects jewelry"],[7633,7783,"and there's this authentication app"],[7783,7995,"that all the jewelry collectors trust."],[8045,8170,"Authentic heirloom pieces"],[8183,8295,"always have embedded"],[8295,8383,"microchips."],[8408,8537,"One quick scan with this app"],[8537,8645,"and well,"],[8695,8820,"I can tell whether that necklace"],[8820,8895,"is real,"],[8945,9008,"or fake."],[9033,9083,"Ha!"],[9120,9245,"Didn't expect there to be an app,"],[9245,9320,"did you?"],[9370,9545,"Now we'll see that it's really a fake."],[9658,9758,"Expose her right now."],[9833,9920,"Be my guest."],[9983,10083,"We'll see how long you can keep"],[10083,10208,"that smile on your face"],[10208,10295,"after the scan."]],"9":[[79,158,"Oh man,"],[158,241,"it is real."],[391,466,"Well,"],[495,604,"that settles that."],[616,829,"Does this mean she's the actual heiress?"],[1095,1166,"Could she actually be"],[1166,1258,"the mafia daughter?"],[1404,1479,"What, wait."],[1604,1741,"Just because the necklace is real"],[1791,1916,"doesn't mean that she is."],[2029,2204,"She obviously stole it."],[2254,2291,"That,"],[2304,2416,"makes more sense."],[2529,2791,"There is no way that this pathetic loser"],[2791,2929,"is the Mafia Heiress."],[3004,3179,"She does work at a pizza place."],[3179,3266,"Exactly."],[3316,3466,"I, I mean, look at her."],[3466,3616,"Does she seem dangerous?"],[3841,4041,"More like wannabe loser."],[4166,4266,"I'm going to call my uncle"],[4266,4366,"about this theft."],[4679,4791,"Give that to me."],[4829,4891,"I'm going to return it"],[4891,5041,"to the mafia heiress herself."],[5516,5579,"I don't remember"],[5579,5666,"giving you the permission"],[5666,5729,"to touch me."]],"10":[[329,404,"Holy shit."],[429,504,"Where did that come from?"],[504,641,"Don't walk away from me."],[729,841,"We are not done here."],[954,1004,"Doe!"],[1079,1166,"I'm talking to you."],[1341,1491,"Do you want me to throw you again?"],[1516,1654,"Just because you have the necklace"],[1666,1791,"doesn't make you a Valenti."],[1841,1929,"No, you don't."],[1966,2116,"You leave when I say you can leave."],[2704,2791,"Holy shit."],[2841,2958,"Whose cars are those?"],[2958,3129,"Well, they must be for you, Felicia."],[3158,3279,"Your uncle saw the livestream"],[3279,3354,"and sent them."],[3416,3616,"Uncle Vinny has never done anything"],[3616,3754,"this extravagant before."],[3916,4029,"Who else could it be for?"],[4054,4254,"Obviously not these pathetic losers"],[4254,4329,"standing around here."],[4429,4491,"Of course."],[4579,4679,"I was expecting this."],[4704,4791,"I was told to pick up"],[4791,4891,"the family heiress,"],[5041,5129,"but I've never seen"],[5129,5254,"Miss Valenti's face before."],[5516,5616,"You're here for me, right?"]],"11":[[12,175,"From the Valenti family?"],[187,350,"Oh, that must be the heiress."],[362,500,"Yes, please, Miss Valenti,"],[512,575,"right this way."],[625,675,"See?"],[712,787,"I'm the real deal."],[800,887,"Are you sure about that?"],[887,950,"Of course."],[1037,1175,"Why else would he be here?"],[1237,1337,"This car is mine."],[1350,1429,"How far"],[1429,1562,"are you going to take this lie?"],[1937,2087,"What are you doing, Arya?"],[2100,2287,"This is obviously Felicia's car."],[2300,2437,"You're embarrassing yourself."],[2450,2625,"Apologize to Felicia right now,"],[2650,2737,"or I'll be pissed"],[2737,2900,"and I won't talk to you for three days."],[2962,3150,"Oh no, three days without you?"],[3150,3275,"How will I survive?"],[3437,3500,"Open this door"],[3500,3575,"and I'll forgive you"],[3575,3675,"for not recognizing me."],[4225,4266,"I,"],[4300,4487,"think maybe I should double-check."],[4537,4687,"You know Vincent Torres, right?"],[4712,4812,"He's a core member."],[4950,5087,"She knows Mr. Torres,"],[5087,5187,"it must be her."],[5300,5500,"Please forgive me, Miss Valenti."],[5850,5937,"Nice try, kid."],[5975,6137,"Maybe don't aim so high next time."],[6412,6537,"I tried to warn you, Arya."],[6562,6687,"This is the lesson you learn"],[6687,6750,"when you pretend"],[6750,6862,"to be someone you're not."],[7625,7712,"Drive."]],"12":[[16,154,"God, did she really think"],[154,266,"she could pull that off?"],[266,454,"The delusion is actually concerning."],[716,779,"What now?"],[816,979,"Calling an Uber you can't afford?"],[1016,1104,"Your car just left"],[1104,1204,"with the wrong heiress."],[1204,1316,"Who's she even calling?"],[1316,1391,"Doesn't matter."],[1429,1495,"Whoever it is,"],[1495,1591,"too late to save her."],[1629,1741,"A drama queen."],[1754,1829,"Always pretending"],[1829,1991,"she's the center of the story."],[2295,2429,"The car will be back in a minute."],[2429,2483,"Girl,"],[2483,2658,"the car is gone"],[2658,2779,"with Felicia."],[2779,2841,"You know what?"],[2841,3004,"If that car comes back for you,"],[3054,3229,"I'll get on the ground right now"],[3229,3329,"and bark like a dog."]],"13":[[20,120,"What the hell?"],[258,508,"It actually came back for her."],[508,570,"What the hell?"],[620,745,"Do you even know who I am?"],[758,908,"I don't care who the hell you are."],[908,1008,"Just stay out of the car."],[2170,2395,"Miss, we are here to take your home."],[2445,2633,"Miss, I am deeply sorry."],[2645,2766,"Just drive like you mean it next time"],[2766,2858,"and we'll call it even."],[2983,3083,"Now, did you say"],[3083,3195,"you would bark like a dog?"],[3258,3433,"Come on, I wasn't serious."],[3433,3520,"It was just a joke."],[3520,3683,"We're classmates, you know?"],[3695,3808,"No bad feelings, right?"],[3845,3958,"Make her keep her word."],[4433,4520,"We're waiting, Ella."],[4583,4695,"Don't disappoint us."]],"14":[[700,775,"Woof, woof."],[787,875,"Louder."],[875,962,"Like you mean it."],[1087,1175,"Woof, woof, woof."],[1212,1312,"Woof, woof, woof."],[1512,1662,"What tricks did you just pull?"],[1675,1837,"You dragged Felicia out of the car"],[1837,1887,"like that?"],[1887,1950,"Do you have any idea"],[1950,2087,"how much trouble you just caused?"],[2112,2200,"If you keep acting like that,"],[2200,2325,"I'm going to have to break up with you."],[2350,2475,"Miss, shall we leave now?"],[2600,2737,"So this car's actually for you?"],[2962,3050,"You're just going to have to explain it"],[3050,3087,"to me on the way."],[3087,3150,"Let's go."],[3175,3275,"We're not going anywhere."],[3312,3475,"I still have some trash to take out."],[3550,3587,"Trash?"],[3587,3725,"What, what trash?"],[3950,4000,"Wait-"],[4725,4766,"Oh,"],[4766,4875,"and about the breakup?"],[4887,4975,"Consider it done."],[5000,5100,"We're finished, Jack."],[5125,5250,"And just so we're clear,"],[5275,5425,"you were never worth my time."],[5487,5550,"Drive."],[5612,5712,"Bye, Felicia."],[6275,6350,"You bitch!"],[6425,6550,"How dare you dump me?"],[6612,6725,"If the relationship ends,"],[6737,6850,"I'll be the one to end it."],[6875,7025,"I won't let you walk away this easily."],[7050,7200,"She's got fucking balls."],[7200,7337,"Obviously she's a fraud."],[7350,7587,"She rented a car, hired actors,"],[7587,7712,"and stole an heirloom."],[7712,7887,"All just to humiliate me."],[7912,8100,"You think she set this up?"],[8137,8350,"It's too elaborate for that loser."],[8350,8450,"I know she did."],[8487,8600,"And when I prove it,"],[8675,8837,"I will rip her to pieces."]],"15":[[262,350,"Did you hear?"],[350,462,"The mafia boss's daughter"],[462,550,"is at our school."],[562,637,"Bullshit."],[662,737,"How would you know?"],[762,900,"My cousin's friend told me."],[912,1050,"Can't wait to spot her."],[1075,1187,"Probably nothing like"],[1225,1387,"that one over there."],[1400,1512,"You already spotted her."],[1550,1712,"You've got to be kidding me."],[1725,1862,"She's like a cockroach."],[1912,2000,"Everywhere I turn,"],[2025,2187,"there's her stupid face."],[3450,3662,"Jesus, that look and technique."],[3687,3837,"Mason Kane."],[3875,4125,"His dad is a CIA director."],[4187,4325,"Ah, Mason."],[4375,4650,"Perfect genes, perfect training,"],[4650,4887,"perfect everything."],[4925,5112,"The total package."],[5175,5237,"Please,"],[5262,5437,"just some fancy throwing moves."],[5437,5600,"Not exactly rocket science."],[5612,5725,"Excuse me?"],[5750,5850,"Did you just- - What?"],[5887,6000,"Call out the golden boy?"],[6025,6112,"Yeah, I did."],[6125,6250,"I've seen better technique."],[7075,7175,"Better technique, huh?"],[7262,7350,"Care to demonstrate?"]],"16":[[37,137,"You don't look impressed."],[187,287,"It's a first round here."],[287,425,"I guess I got to step up my game."],[487,550,"Please don't."],[575,687,"I've seen Kung Fu Panda"],[687,787,"with better technique."],[862,925,"Ouch."],[1000,1125,"Here I thought I was being impressive."],[1137,1300,"Your fan club seems impressed."],[1400,1512,"You know what's interesting, Doe?"],[1650,1737,"I have a feeling there's more to you"],[1737,1862,"than you get others to believe."],[1950,2025,"Or maybe you have secrets"],[2025,2100,"that make mine look like"],[2100,2212,"kindergarten gossip."],[2500,2562,"Oh my God."],[2587,2687,"Is he testing me?"],[2737,2862,"Does he really know something?"],[2962,3100,"Careful, CIA boy."],[3125,3312,"Curiosity killed more than just cats."],[3362,3450,"CIA boy?"],[3525,3587,"Looks like someone's been"],[3587,3662,"doing their homework."],[3725,3787,"I'm flattered, Doe."],[3825,3900,"Don't be."],[3912,4087,"I research all the local predators."],[4087,4150,"Predators?"],[4187,4237,"That's the nicest thing"],[4237,4337,"anyone's called me all week."],[4750,4812,"Finally,"],[4912,5000,"someone who actually might be"],[5000,5062,"worth the trouble."],[5337,5537,"She thinks one night changes everything?"],[5637,5737,"She shows up,"],[5766,5862,"makes a scene,"],[5887,5962,"and then is flirting"],[5962,6075,"with the hottest guy in school"],[6075,6175,"like she has a shot?"],[6412,6487,"Time to remind her"],[6487,6637,"who really runs this school."]],"17":[[633,795,"This is going to be perfect."],[2508,2658,"Too easy."],[3783,3895,"Where are my clothes?"],[3945,3995,"Oh my God,"],[3995,4108,"no, this can't be happening."],[4583,4695,"What are you doing here?"],[4720,4820,"What are you doing here?"],[4833,4958,"This is the boys' locker room."],[5795,5883,"Stop looking."],[5958,6045,"You stop looking."]],"18":[[70,270,"Please, you have nothing to see."],[308,370,"Really?"],[383,433,"Because,"],[458,558,"your face says otherwise."],[595,720,"And for the record,"],[783,845,"you are,"],[870,1045,"definitely worth seeing."],[1058,1120,"Shut up!"],[1133,1233,"Why are you still in here?"],[1233,1295,"The sign said"],[1295,1358,"girls!"],[1395,1445,"What?"],[1608,1720,"Someone must have switched the sign."],[1920,1970,"My clothes!"],[1970,2108,"Where are my clothes?"],[2758,2833,"Put me down."],[2920,2995,"If you say so."],[3270,3333,"Oh my God,"],[3383,3545,"what kind of cursed day is this?"],[3633,3695,"Yo,"],[3720,3870,"is it true there's a girl in there?"],[3920,4083,"Yeah, Doe's in there half-naked."],[4183,4258,"You should see her."],[4345,4508,"That prude is so desperate."],[4945,5033,"Where is she?"],[5533,5608,"What the hell are you doing?"],[5608,5658,"Hey."],[5783,5833,"Shh."],[5870,5995,"They can't see me like this."],[6008,6095,"This is insane."],[6133,6233,"It's better than going viral"],[6233,6370,"as a school laughingstock."],[6395,6595,"I can hear you."]],"19":[[1041,1141,"Where the hell is she?"],[1291,1404,"She can't go anywhere."],[1479,1591,"She has no clothes."],[1616,1704,"What are you doing here?"],[1729,1891,"Looking for your bitch-ass girlfriend."],[1904,2041,"She made a fool out of both of us"],[2041,2116,"last night."],[2129,2229,"Now I'm going to get her."],[2229,2279,"What?"],[2291,2366,"She's whoring around"],[2366,2479,"in the boys' locker room?"],[2516,2604,"That shameless orphan"],[2604,2704,"is out of control lately."],[2729,2841,"Think you can hide from me?"],[2879,2991,"I know you're in there."],[3041,3254,"Come out, come out."],[3891,3966,"You know what?"],[4079,4154,"I'm going to livestream"],[4154,4216,"the whole thing."],[4241,4404,"Everyone's going to see what a desperate"],[4404,4541,"little freak you are, Doe."],[4541,4741,"Hey, stop wasting our time, Doe."],[4804,4929,"We all saw you come in here."],[4929,5066,"You better not actually be in here,"],[5066,5104,"Arya."],[5104,5204,"That's crossing the line."],[5841,5979,"When I find you,"],[6054,6166,"everyone's going to see"],[6166,6379,"your pathetic naked body,"],[6466,6566,"your tears,"],[6629,6716,"all of it."]],"20":[[208,270,"What the hell are you doing"],[270,358,"in the boys' locker room?"],[433,470,"Mason,"],[470,670,"I, I didn't know you were in there."],[670,758,"Yeah, and who exactly"],[758,858,"are you looking for?"],[933,1033,"Just that loser, Doe."],[1095,1295,"She came in here hiding from us."],[1370,1445,"I haven't seen her."],[1508,1595,"It's just me in here."],[1633,1695,"Are you sure?"],[1720,1858,"I swore I saw her come this way."],[1908,1958,"Let me go in there"],[1958,2095,"and check your stall, man."],[2120,2208,"Making sure you're not messing around"],[2208,2320,"with my girlfriend."],[2345,2445,"I'm not your man."],[2470,2520,"You don't have the right"],[2520,2658,"to invade my personal space."],[2670,2820,"Plus, Arya already dumped you."],[2858,2983,"She's not even your girlfriend anymore."],[2995,3120,"I didn't get dumped!"],[3120,3220,"Just open the curtain."],[3458,3558,"What are you all doing in here?"],[3695,3758,"Coach,"],[3758,3845,"it's Felicia."],[3870,3933,"She's trying to sneak"],[3933,3995,"into the boys' shower"],[3995,4058,"and take videos"],[4058,4183,"for her social media post."],[4220,4295,"And Jack here,"],[4295,4383,"her accomplice,"],[4408,4533,"is trying to open my shower curtain."],[4795,4845,"Completely"],[4845,4945,"inappropriate behavior."],[4970,5120,"Wait, I can explain."],[5120,5258,"Coach, it's not what it seems like."],[5258,5395,"You're going to the principal's office."],[5770,5820,"Wait!"],[5870,5995,"This isn't over!"]],"21":[[83,208,"I can't believe that worked."],[245,420,"That was way too close."],[970,1095,"Arya Valenti."],[1233,1383,"You enjoying your little undercover act?"],[1508,1608,"How the hell could he know?"],[1708,1770,"Valenti?"],[1820,1920,"What are you talking about?"],[1970,2083,"Eddard Valenti,"],[2133,2208,"your father."],[2283,2320,"You know,"],[2358,2433,"head of the most powerful"],[2433,2483,"mafia family"],[2483,2595,"on both coasts, but,"],[2637,2758,"no contact for four years"],[2758,2883,"because she just refuses"],[2883,3008,"to take over the family business."]],"22":[[12,100,"Of course,"],[100,275,"his father is a CIA director."],[312,425,"Of course they have intel."],[450,554,"Congratulations,"],[554,687,"you did your homework."],[687,775,"It's amazing what you can learn"],[775,887,"when your dad runs the CIA."],[937,1012,"So now what?"],[1062,1212,"Expose me to the entire school?"],[1237,1287,"No,"],[1350,1450,"that would be too easy."],[1550,1637,"Actually,"],[1825,1962,"I have a proposition for you."],[2125,2250,"I'll keep your little secret"],[2287,2400,"if you tutor me in chemistry."],[2487,2550,"Tutoring?"],[2600,2662,"That's it?"],[2687,2762,"I'll keep your secret"],[2762,2950,"and I'll even protect you from assholes."],[3087,3162,"Protect me?"],[3187,3250,"Please."],[3275,3425,"I already lived through this once."],[3450,3600,"I know what happens next, pretty boy."],[3600,3700,"And if I refuse?"],[3737,3812,"Then I can't promise"],[3812,3937,"your identity will be safe."],[4412,4462,"Fine."],[4700,4804,"Chemistry tutoring,"],[4804,4925,"nothing else."],[5025,5075,"Deal."],[5312,5425,"Guess we're partners now."],[5650,5762,"More like hostages."]],"23":[[241,295,"Daisy,"],[333,491,"my sweet best friend."],[554,666,"The only true friend"],[666,766,"who showed me kindness"],[766,879,"in the previous life."],[1666,1766,"The only one who shared"],[1766,1883,"her seat with me."],[2541,2683,"So they punished her for it."],[2829,2929,"Oh my God."],[2929,3029,"Somebody record this."],[3191,3304,"Slap her, slap her."],[3391,3504,"Oh, shit."],[3504,3666,"Get her ass, get her."],[3666,3841,"Beat her ass!"],[3841,3966,"They abused and humiliated her"],[3966,4191,"and posted it all online."],[4204,4329,"Now this is going viral."],[4366,4466,"What a freak."],[4516,4691,"They pushed her to the edge."]],"24":[[533,595,"Daisy, no!"],[608,833,"And in the end she took her own life."],[833,908,"No!"],[995,1245,"From then on, I trained relentlessly"],[1270,1445,"and even took the championship title."],[1483,1550,"But still,"],[1562,1670,"it was too late."],[1708,1870,"Nothing could buy your life back."],[2095,2195,"Not this time."],[2208,2333,"I'm Arya Valenti now,"],[2358,2520,"Mafia Boss's daughter reborn."],[2533,2808,"I swear nobody will touch you again."],[2983,3020,"Arya,"],[3020,3145,"can you give me a hand real quick?"],[3758,3883,"I can't believe that Arya bitch"],[3883,3983,"got me sent to the dean."],[4045,4145,"Three days of detention"],[4145,4233,"because of her."],[4233,4370,"The nerve of that nobody."],[4395,4508,"Who does she think she is?"],[4545,4633,"We need to show everyone"],[4633,4708,"what happens"],[4708,4845,"when they mess with us."]],"25":[[25,137,"Well, well,"],[175,375,"if it isn't the freak of nature."],[900,962,"Oops."],[1062,1162,"Even your bag's embarrassed"],[1162,1237,"to be seen with you."],[1350,1462,"Even inanimate objects"],[1462,1587,"have standards."],[1587,1675,"Can't blame it."],[1825,1975,"Look at this pathetic mess."],[2087,2237,"Maybe if you weren't such a loser,"],[2237,2337,"your bag wouldn't be trying"],[2337,2437,"to run away from you."],[2487,2637,"Please, I didn't-"],[2637,2762,"Didn't mean to what?"],[2837,2937,"Exist?"],[3500,3562,"Please,"],[3562,3675,"just let me go."],[3675,3900,"I'm sorry for whatever I did."],[3912,4037,"You know what, Daisy?"],[4162,4337,"You're actually kind of pretty"],[4337,4412,"when you cry."],[4504,4666,"Well, you're not crying yet."],[4825,4912,"But you will be."]],"26":[[62,125,"Please."],[650,750,"Oh my God, please."],[812,937,"I'm begging you, don't do that."],[937,1037,"I'll do anything."],[1175,1250,"Anything?"],[1362,1525,"Well, how about you hold still for me?"],[1700,1825,"This is going to be fun."],[1862,1904,"Please!"],[1904,1987,"Hold her steady."],[2087,2175,"Don't worry."],[2262,2375,"It's just a little scar."],[2512,2662,"Something for you to remember me by."],[2862,2925,"Stop!"]],"27":[[12,175,"That championship title from last life"],[175,275,"wasn't just for show."],[312,387,"In this life,"],[400,587,"anyone who crosses me will regret it."],[612,712,"My face!"],[800,975,"I have a modeling audition next week."],[975,1137,"You ruined my fucking face!"],[1137,1200,"Thank you."],[1587,1700,"You think this is funny?"],[1812,2000,"Touch her again and you'll regret it."],[2137,2312,"How's this bitch so strong?"],[2450,2587,"You think you're tough now, Doe?"],[2662,2850,"You're still some pathetic orphan"],[2850,2937,"who has nothing."],[2937,3087,"At least I have a true friend."],[3187,3237,"Fine."],[3312,3475,"You want to protect her so badly."],[3725,3775,"Daisy,"],[3887,3950,"slap her,"],[3954,4012,"hard."],[4150,4200,"Do it,"],[4300,4412,"and the money's yours."]],"28":[[237,266,"But,"],[316,462,"she's my best friend."],[500,600,"So, what?"],[687,737,"Remember,"],[737,900,"your father works for my uncle."],[937,1075,"One word from me,"],[1104,1212,"and he'll come home"],[1250,1404,"and beat your sick mother's"],[1404,1512,"worthless ass."],[1537,1750,"Please, leave my mother out of this."],[1775,1887,"How long does she have left?"],[1962,2075,"With her heart condition,"],[2125,2212,"a week?"],[2250,2325,"Less?"],[2387,2475,"Simple choice,"],[2525,2612,"slap her"],[2687,2887,"or your mommy suffers."],[3112,3200,"Don't worry, Daisy."],[3237,3287,"I'll take care"],[3287,3412,"of your mom's medical bills."],[3450,3525,"And I promise"],[3525,3612,"your father will never"],[3612,3725,"lay a hand on her again."],[3762,3825,"Really?"],[4300,4487,"Are you fucking serious right now?"],[4525,4637,"You'll give her the money?"],[4662,4775,"How are you going to do that?"],[4812,4937,"Empty your life savings?"],[4937,5050,"The orphan thinks"],[5050,5262,"she can compete with real money."],[5287,5375,"Listen, loser."],[5400,5612,"My uncle works directly"],[5612,5762,"under the Mafia Boss."],[5800,6000,"Only someone with real connections"],[6037,6137,"can protect people."],[6187,6291,"The Mafia Boss you're bragging"],[6291,6425,"about is my dad."]],"29":[[475,637,"She's actually gonna do it?"],[1725,1900,"I don't want your stinky money."],[1937,2162,"I would never betray my best friend."],[2300,2450,"You just signed your death warrant,"],[2450,2562,"you stupid cow."],[2612,2737,"And your dying mother's too."],[2800,2925,"Since you won't take the reward,"],[3025,3175,"you'll take the punishment instead."],[3175,3287,"Hey, back off of her."],[3325,3400,"Whatever you want,"],[3400,3525,"just deal with me instead."],[3700,3925,"Wonder Woman to the rescue again."],[4000,4162,"You're the one who started this all,"],[4162,4225,"Doe."],[4300,4375,"And today,"],[4462,4562,"you're finished."],[5237,5300,"Rex,"],[5387,5475,"bring your boys over here"],[5475,5562,"to building B."],[5612,5700,"I've got"],[5754,5837,"a little rat"],[5837,5950,"you can get rid of for me."]],"30":[[370,433,"Oh, man,"],[495,633,"Rex and his guys are psycho."],[670,745,"I heard they put someone"],[745,820,"in the hospital"],[833,958,"and the mental institution,"],[983,1058,"just last year."],[1120,1258,"This is your last chance, Doe."],[1458,1533,"Kiss my shoe,"],[1595,1683,"and maybe,"],[1745,1895,"I'll only have your legs broken."],[1983,2083,"Break my legs?"],[2170,2258,"What if I told you"],[2258,2358,"you couldn't hurt me at all?"],[2533,2683,"Do you even know what you're saying?"],[2733,2833,"Didn't you just hear about"],[2833,3008,"Rex's gang's track record?"],[3020,3158,"You think you're untouchable"],[3158,3308,"with a few little kicks"],[3308,3408,"and little tricks?"],[3433,3533,"Then let's make a bet."],[3583,3745,"If your goons manage to land"],[3745,3858,"a single hit on me,"],[3883,3962,"I'll kneel,"],[3962,4070,"lick your shoe,"],[4070,4183,"and immediately drop out"],[4183,4295,"and disappear for good."],[4583,4758,"You brought this on yourself."],[5283,5395,"But if I win the fight,"],[5433,5645,"you pour this crap all over your face,"],[5670,5845,"wipe off all your clown makeup,"],[5858,5983,"and livestream yourself"],[5983,6120,"saying I'm a fake-ass bitch"],[6120,6295,"in front of the entire school."],[6470,6545,"You're insane."],[6608,6683,"Then crawl away"],[6683,6858,"and admit you're a lying piece of shit."]],"31":[[16,154,"Is Arya losing her mind?"],[166,329,"She's one person against, what,"],[329,404,"ten people?"],[416,541,"And not a single hit?"],[579,704,"How is that even possible?"],[729,804,"Probably the only one"],[804,891,"who could pull that off"],[916,1054,"is the mafia heiress herself."],[1104,1254,"Arya's really taking this pride thing"],[1254,1341,"way too far."],[1391,1491,"Everyone's watching."],[1541,1679,"I can't chicken out now."],[1754,1866,"This bitch is bluffing."],[1929,2041,"There's no way"],[2041,2179,"Rex can't take her down."],[2266,2341,"You think I'm scared"],[2341,2466,"of some stupid orphan?"],[2504,2641,"You're a delusional bitch."],[2654,2866,"Let's show her who the real queen is,"],[2866,2929,"Felicia."],[2941,3016,"That's right."],[3016,3229,"Let's get rid of her fake ass."],[3266,3329,"Arya,"],[3358,3479,"don't make this bet."],[3504,3666,"Don't risk your life like this."],[3741,3829,"I'll kneel for you."],[3891,3991,"Thank you, Daisy."],[4016,4141,"It means a lot that you care."],[4204,4279,"And