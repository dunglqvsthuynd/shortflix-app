[4500,4625,"have a screening exam"],[4625,4746,"coming up soon."],[4796,4959,"You need to see that through."],[4959,5138,"Of course, I wouldn't leave them hanging."],[5205,5309,"If you could do me a favor,"],[5388,5518,"and keep this between us,"],[5555,5634,"until I leave."],[5718,5851,"I don't know what's going on,"],[5922,6014,"but Charles,"],[6014,6193,"if you ever want to return,"],[6193,6339,"my door is always open."],[7061,7132,"Honey,"],[7165,7336,"our future together begins now."]],"53":[[1422,1676,"Thank you so much, Charles."],[2047,2127,"So,"],[2127,2273,"when do you plan on taking a break"],[2273,2360,"from school?"],[2444,2598,"After the screening exam."],[2794,2957,"Once you pass your exam,"],[2957,3174,"you can welcome the baby."],[3457,3528,"I don't even know"],[3528,3641,"if I'm going to pass them."],[3753,3933,"I heard it's really tough and..."],[4145,4295,"I've been so distracted."],[4396,4508,"And you'll pass."],[4604,4800,"You have the most famous professor"],[4800,4892,"in neuroscience"],[4892,5042,"as your personal tutor."],[5301,5451,"You listen to me."]],"54":[[1330,1468,"Am I boring you, Ms. Miller?"],[1576,1705,"No,"],[1705,1856,"but this lesson is."],[1947,2131,"I don't know if I'm cut out for this, Professor."],[2131,2273,"I can't pay attention."],[2623,2686,"Get up."],[2773,2844,"What?"],[3011,3090,"You're going to make"],[3090,3190,"your punishment worse."],[3253,3349,"Come here."],[3553,3712,"Don't make me ask you again."],[4191,4295,"What are you-"],[4909,5017,"I'm gonna name"],[5017,5155,"a signaling molecule."],[5230,5380,"And you're gonna tell me what it does."],[5530,5643,"If you get it wrong..."],[6393,6439,"Shit."]],"55":[[150,279,"Insulin, Ms. Miller."],[487,579,"Glucose."],[650,750,"Glucose, what?"],[817,1009,"I thought you were my star student."],[1222,1463,"I can't, I can't focus, Professor."],[1559,1747,"Glucose uptake in the muscle?"],[1793,1914,"Keep up Ms. Miller."],[1914,2193,"This is going to be very, very painful."],[2644,2752,"Epinephrine."],[2873,3078,"Uh, uh, the heart."],[3136,3224,"Where in the heart?"],[3407,3666,"A-Adrenergic receptors, fuck!"],[3666,3778,"Professor Hayes don't stop."],[3870,3953,"You are my student,"],[3953,4091,"you don't tell me what to do."],[4141,4245,"That was correct."],[4333,4471,"You’ve learned a reward."],[4583,4767,"You want me to stop? - No."],[4767,4992,"What I mean, I want..."],[4992,5130,"I want you to keep going."],[5526,5730,"There's a lot I still have to teach you."],[7874,7970,"Thank you,"],[8045,8183,"for tutoring me."],[9984,10143,"If you're nervous, I can check for you."],[10143,10272,"Who said I'm nervous?"],[10460,10581,"I can do it myself, I just..."],[11094,11257,"Well, it's been 30 minutes."],[11711,11836,"Hey, Emmy."],[12028,12103,"You passed!"],[12103,12208,"Oh my God, I passed."],[12283,12424,"I passed, I passed!"],[12462,12566,"Oh, Charles!"]],"56":[[29,204,"Oh, Charles!"],[504,617,"Look at this."],[650,921,"Professor Hayes embracing a student."],[950,1084,"No wonder you reported me."],[1109,1251,"You just didn't want to share!"],[1292,1426,"Charles Hayes,"],[1426,1593,"we received a report,"],[1593,1768,"that you engaged in an inappropriate"],[1768,1989,"relationship with a student."],[2173,2252,"It's true."],[2318,2402,"It's not true."],[2444,2590,"Emily and I are more than"],[2590,2706,"just a professor and a student."],[2706,2869,"No, it's, it's my fault."],[2869,3032,"I begged him to tutor me and-"],[3032,3161,"Emily, enough."],[3265,3345,"But there's nothing wrong"],[3345,3449,"with our relationship."],[3486,3566,"because,"],[3611,3737,"I resigned a month ago."]],"57":[[33,179,"I resigned a month ago."],[179,271,"What?"],[321,408,"Resigned?"],[529,600,"What?"],[629,754,"I turned in my resignation"],[754,842,"over a month ago."],[905,1092,"And I've been finishing up my work."],[1092,1205,"Today is my last day."],[1247,1430,"Yes. Professor Hayes"],[1430,1618,"did submit his resignation,"],[1618,1755,"and I signed off on it."],[1839,1910,"No."],[2039,2160,"This can't be real."],[2160,2360,"I'll be leaving the school for good today."],[2427,2527,"Is there anything else?"],[2527,2573,"No."],[2573,2652,"No way."],[2652,2802,"He wouldn't give up just everything"],[2802,2894,"for some girl."],[2965,3153,"Sorry to interrupt."],[3153,3261,"We'll be leaving now."],[4054,4204,"So you planned this all along?"],[4304,4500,"This was your way of protecting me."],[4600,4721,"Emily, it was the only way"],[4721,4838,"I could keep you safe."],[4900,4946,"No."],[5080,5134,"I don't want you to"],[5134,5280,"give up your career for me."],[5280,5338,"We should,"],[5338,5447,"we should go to the dean right now,"],[5447,5551,"and I'll tell them the truth."],[5551,5730,"I'll tell them that I seduced you-"],[5730,5768,"Emily-"],[5768,5876,"and Professor-"],[5876,6068,"Emily Miller, please listen to me."],[6168,6348,"If you still see me as your mentor,"],[6406,6548,"then listen to what I have to say."],[6652,6848,"Stay focused on your studies"],[6848,7040,"and become the brilliant scientist"],[7040,7152,"that you're meant to be."],[7244,7386,"You have too much talent"],[7386,7507,"and too much potential."],[7766,7962,"You're going to achieve great things."],[8158,8291,"Promise me, Emily,"],[8479,8641,"don't waste your gift."]],"58":[[479,563,"Ma'am,"],[563,658,"what are you doing?"],[688,829,"Is she worth it?"],[988,1134,"She's worth everything."],[2060,2235,"I do have one more request."],[2235,2464,"It's about that girl, isn't it?"],[2498,2644,"I don't want my resignation"],[2644,2798,"to affect Emily's future."],[2894,2994,"She's pregnant."],[3036,3132,"Pregnant?"],[3174,3345,"Yes, she's expecting."],[3378,3557,"And since I resigned,"],[3557,3712,"I have time to take care of her now."],[3728,3862,"I want her academic status"],[3862,3962,"to remain intact."],[3962,4083,"That way when she's ready,"],[4083,4241,"she can come back and study."],[4329,4421,"Please."],[4550,4625,"All right."],[4692,4825,"I'll make sure of it."],[5784,5905,"Emmy, this is the last thing"],[5905,6022,"I can do for you here."]],"59":[[1872,2027,"I'm sorry I kept it from you."],[2469,2590,"But the most important thing"],[2590,2765,"right now is your health,"],[2765,2886,"and our baby's."],[3011,3144,"I wanna be here for you,"],[3261,3370,"every step of the way."],[3553,3699,"When you deliver our baby,"],[3770,3895,"and when we welcome our baby"],[3895,4008,"into the world."],[4542,4700,"I want you to be my wife."],[4917,5096,"I don't want you to be my secret."],[5246,5547,"I gave up one thing for everything, Emily."],[5668,5764,"To have you."],[5897,5997,"I don't care."],[6097,6306,"I don't care if I'm your dirty little secret."],[6306,6360,"I just-"],[6594,6790,"I don't want you to resign!"],[6881,7002,"Don't worry about it."],[7107,7344,"Just think of it as me taking a break."],[7799,7895,"Just..."],[8304,8600,"don't make decisions like this"],[8600,8804,"behind my back ever again,"],[9171,9300,"if I'm gonna to be your wife."],[9597,9751,"No more secrets."]],"60":[[513,596,"Charles,"],[667,771,"are you seriously"],[771,930,"grocery shopping and cooking?"],[959,1092,"Emily ruined you."],[1176,1380,"A Nobel Prize winner doing housework."],[1422,1559,"This is what you wanted, isn't it?"],[1614,1726,"No, Charles, I just"],[1793,1881,"I just want you back-"],[1881,2077,"Don't speak to me ever again."],[2097,2260,"The moment you tried to turn Emily"],[2260,2398,"against me is the moment you and Jack"],[2398,2527,"became dead to me."],[2852,2961,"No, no."],[2961,3128,"Forgery is a crime, Ruby."],[3128,3307,"Ma'am, please come with us."],[3307,3420,"Oh, no."],[3453,3666,"Charles, please don't leave me."],[3666,3787,"Please, I'm sorry!"],[3787,3958,"Charles! We're your family!"],[5359,5476,"I though I saw Ruby."],[5613,5697,"Yeah."],[5697,5797,"She found me,"],[5897,6010,"but it's handled."],[6131,6168,"She-"],[6168,6360,"She's going to rot in jail."],[6723,6819,"Hey, don't worry."],[6865,7023,"No one's going to hurt you anymore."]],"61":[[20,187,"Congratulations."],[187,446,"You have passed your screening exams."],[446,563,"Starting today,"],[592,913,"you are officially entering your PhD"],[913,992,"journey."],[1251,1468,"Please welcome Emily Miller,"],[1468,1764,"representing our PhD candidates"],[1764,1926,"to give a speech."],[2694,2886,"I am proud to represent..."],[3807,3937,"Emily."],[3937,3999,"Emily."],[4212,4283,"It's happening."],[4358,4558,"Doctor? We need a doctor!"]],"62":[[487,679,"I never thought that something so small"],[679,892,"would make me feel so terrified,"],[934,1105,"and happy at the same time."],[1822,1910,"Emmy,"],[2010,2143,"we've been through a lot together,"],[2273,2435,"but there's just one thing missing."],[3148,3274,"I love you, Emily."],[3470,3603,"We've had our fights"],[3670,3816,"and doubts."],[4020,4158,"But when I look at her,"],[4308,4412,"I look at you."],[4675,4900,"I finally realize that this is everything."],[5042,5276,"You two are my whole world."],[5509,5643,"Let me be your husband."],[5730,5880,"Let me be her father."],[6018,6147,"I want to protect you."],[6256,6406,"I want to take care of you."],[6452,6606,"And I want to be there for you."],[6715,6915,"From every sunrise to sunset."],[7265,7361,"Emily,"],[7590,7707,"will you marry me?"],[7878,7962,"Yes!"],[8153,8295,"Yes, Charles."]],"63":[[688,863,"Daddy, is this where you met mommy?"],[984,1092,"Not exactly, Ellen."],[1092,1234,"We met actually-"],[1426,1618,"I will see you all next week."],[1643,1793,"Have a nice weekend."],[2131,2289,"Mommy."],[2715,2948,"Congratulations, Professor Miller."],[3048,3199,"Assistant professor."],[3219,3349,"I've still got a long way to go."],[3349,3490,"It's just a matter of time."],[3661,3812,"Thank you Charles,"],[3812,3916,"if it weren't for you-"],[3916,4066,"No, Emily, you have no one to"],[4066,4195,"thank but yourself."],[4375,4483,"Professor Miller,"],[4562,4683,"what are you doing?"],[4767,5005,"I think I'm going to kiss you,"],[5005,5121,"Professor Hayes."]]}