{"1":[[2777,2852,"Don't turn around."],[2998,3094,"Keep taking out the money."],[3474,3557,"Is that your van?"],[3607,3661,"Yes."],[3787,3903,"You being carjacked?"],[4020,4233,"Yes, my baby's still inside."],[4521,4600,"They have guns?"],[4637,4704,"Yes."],[4846,4929,"Watch my bag."],[5109,5209,"This won't take long."],[5576,5676,"Your mom better hurry up,"],[5676,5839,"or you're gonna be in a lot of trouble."],[7244,7315,"You prick."],[8345,8429,"Hey kiddo,"],[8466,8562,"you wanna see your mom?"],[8963,9071,"Hi, honey."],[9180,9313,"Mommy's here, it's okay."],[9630,9693,"Sir,"],[9709,9780,"who are you?"],[9889,10085,"Just your ordinary, retired vet."],[10456,10518,"Listen,"],[10577,10648,"I'm a lawyer."],[10735,10940,"Let me know if you ever need anything."],[11219,11348,"Thank you so much."],[13784,13930,"Ah, shit."]],"2":[[746,838,"Good day, sir."],[1113,1251,"Corbin, I'm retired."],[1301,1397,"And you're the director of"],[1397,1472,"the FBI now."],[1488,1626,"There's no need for sirs and salutes."],[1626,1722,"Negative, sir."],[1764,1914,"Whether you're actively serving"],[1914,1993,"or retired,"],[2068,2185,"I'll always be your soldier."],[2823,2886,"Sir,"],[2886,3044,"the President of the United States"],[3044,3153,"is awarding you,"],[3178,3290,"the Medal of Honor."],[3303,3382,"I'm here"],[3390,3595,"to escort you to the ceremony."],[3645,3741,"Medal of Honor?"],[3912,4029,"It's unnecessary."],[4070,4262,"I just did what any soldier would do."],[6377,6468,"Ethan, watch out."],[7440,7611,"Oh, Pierce, Pierce!"],[7711,7999,"I, I don't wanna be left in foreigen land."],[8170,8350,"Take, take me home, bro."],[8362,8450,"No, Pierce."],[8450,8516,"Pierce!"],[8692,8754,"Pierce."],[9688,9822,"This is the real hero."],[9905,9997,"He deserves the medal"],[9997,10097,"more than anyone."],[13968,14039,"Pierce,"],[14118,14264,"your courage will live on."],[14906,14964,"Ethan,"],[14994,15060,"I've arranged"],[15060,15231,"a grand escort for your trip home."],[15231,15432,"It's the hero's send-off"],[15444,15553,"that you deserve."],[15578,15694,"It's unnecessary, sir."],[15819,15982,"We spent half of our lives"],[15982,16082,"defending this country."],[16099,16224,"I think we'd like to enjoy"],[16224,16399,"some of the peace we protected."],[16541,16700,"Pierce would've wanted it that way."],[16783,16866,"Understood."],[16908,17017,"And thank you"],[17087,17225,"for your service."],[17279,17375,"Thank you, sir."],[18430,18572,"Welcome back home, Pierce."],[19094,19198,"Fun is here."]],"3":[[800,896,"Excuse me, boy."],[909,1063,"What are you doing around these parts?"],[1126,1242,"You here to see somebody?"],[1251,1326,"Yeah, officer."],[1401,1547,"Looking like you do, uh,"],[1647,1818,"seems like you might be a troublemarker."],[2018,2143,"Come on, I'll give you a ride."],[3728,3799,"Where'd you take me?"],[3799,3958,"I'm trying to get into town."],[3999,4104,"No, you're not, son."],[4137,4220,"I'm taking you right"],[4220,4308,"where you need to be."],[4383,4462,"And where's that?"],[4483,4717,"As far away as I can take you."],[4850,4950,"Why are you doing this to me?"],[4971,5075,"I didn't do anything to you."],[5096,5150,"Look,"],[5163,5217,"folks like you"],[5217,5334,"ain't welcome around here."],[5372,5518,"We don't want no homeless, vagrant"],[5518,5663,"types running around"],[5663,5826,"causing havoc in our town."],[5930,6035,"Now, git!"],[8083,8262,"That son of a bitch."],[8483,8591,"I've told him,"],[8591,8750,"get out of this town."],[9150,9280,"Boy, I thought I told you"],[9280,9392,"you ain't welcome."],[9463,9630,"You need to get lost, or you-"],[9630,9809,"Hey, don't touch my stuff."],[9809,9884,"You!"],[9968,10168,"Get your hands on that car right now."]],"4":[[66,166,"Put that stuff down"],[166,404,"and get your hands on that car right now."],[1292,1422,"Don't you move."],[1647,1839,"What you got here?"],[2064,2127,"Oh, Pierce!"],[2143,2193,"Boy!"],[2227,2381,"You put your hands on the car."],[2398,2469,"Right now!"],[2540,2606,"Drop it!"],[3470,3574,"Give me your hand, boy."],[3616,3695,"Don't you move."],[4041,4195,"You're lucky my stuff's still intact."],[4245,4371,"Or you'd already be dead."],[4662,4829,"Wait till we get back to the station."],[4871,5080,"We'll see who the real dead man is."],[5167,5251,"Get out of here."],[5417,5522,"Strip, boy."],[6602,6773,"Gang fight battle scars?"],[6815,6973,"Mitchell, are strip searches"],[6973,7094,"even legal anymore?"],[7132,7261,"I don't think we should be doing this."],[7261,7374,"Relax, Helen."],[7436,7549,"We're just having some fun."],[7778,7836,"Hmm..."],[7870,7928,"Mitchell,"],[7945,8120,"let's help our guest get cleaned up."],[8133,8216,"We don't want, uh,"],[8216,8400,"people thinking our station is a shithole."],[8433,8508,"Alright."],[8575,8650,"Well,"],[8692,8787,"what've we got?"],[9046,9092,"Well,"],[9167,9296,"what is this?"],[9367,9446,"Yeah."],[9538,9613,"Ethan..."],[9680,9755,"Barrett?"],[9980,10172,"Run this through the ID scanner."],[10172,10389,"I wanna know exactly who he is."],[10739,10969,"You got the right to remain silent, son."],[10969,11011,"But,"],[11073,11140,"you're gonna be"],[11140,11294,"squealing soon enough."],[12074,12145,"If I were you,"],[12274,12408,"I'd make sure I knew who I was"],[12408,12508,"before I did that."],[12529,12645,"Is that a threat, boy?"],[12700,12821,"What do you think?"],[12862,12950,"Alright!"],[13013,13096,"Excellent!"],[13113,13196,"Clean him up."]],"5":[[29,141,"Shower time!"],[1146,1317,"Hey don't forget his hair!"],[2002,2177,"She-Sheriff, he's, he's uh-"],[2177,2310,"Kid, give me that."],[2723,2802,"That's right!"],[2861,3053,"Hey, what's in that bag?"],[3107,3249,"Kind of important to you, huh?"],[3958,4029,"There."],[4054,4229,"Now you know who runs this place."],[4558,4646,"What's this?"],[4742,4838,"Can't verify?"],[4909,5021,"You know what that means?"],[5038,5171,"That's a fake ID."],[5205,5405,"You're either an illegal immigrant"],[5426,5559,"or a criminal on the run."],[5618,5697,"Get down on the ground,"],[5697,5822,"and hands where I can see them!"],[6081,6147,"Well, son."],[6193,6327,"It doesn't matter if you forge"],[6327,6452,"the government document,"],[6452,6635,"or you're in this country illegally."],[6652,6802,"I can arrest you right here."],[6802,6956,"Now, I wanna know who you are."],[6981,7236,"Or there's another possibility."],[7311,7494,"My identity's highly classified."],[7494,7557,"And you,"],[7615,7732,"small-town sheriff,"],[7732,7811,"don't have the clearance"],[7811,7887,"to access it."],[7887,8095,"Stop with the lies, son."],[8095,8254,"I'm tired of it."],[8345,8479,"Who is this, anyway?"],[8625,8775,"Somebody special?"],[8783,8863,"Do not"],[8879,8988,"touch that or you're gonna die"],[8988,9129,"a slow, painful death."],[9163,9321,"Well, look at that."],[9346,9509,"Everybody in this station"],[9509,9642,"is gonna pay for your stupid..."],[9642,9809,"Get your hands off!"],[9834,9959,"Get your hands off!"],[9993,10097,"Look, I'm gonna give you"],[10097,10181,"one more chance."],[10218,10368,"I want to know who you are"],[10368,10506,"and where you come from!"],[10568,10639,"Fuck you!"],[10935,11006,"Sorry, boy."],[11023,11090,"That wasn't the answer"],[11090,11198,"I was looking for."],[11824,11995,"Take, take me home, bro."]],"6":[[533,575,"Woah, hey."],[588,704,"You son of a bitch!"],[1101,1155,"Sir,"],[1163,1267,"put the gun down."],[1288,1397,"Let's talk this out."],[1488,1568,"Put the gun down!"],[1584,1676,"You can't escape."],[1714,1839,"Who says I'm trying to escape?"],[1926,2035,"Hey, look, look, look."],[2035,2139,"We can talk this out."],[2139,2252,"But if you shoot me,"],[2264,2364,"my officers are going to put you"],[2364,2477,"in the ground real quick."],[2502,2581,"All I wanted to do"],[2581,2731,"was bring my war buddy back home."],[2756,3011,"You desecrated his body with your foot!"],[3078,3207,"You deserve to die."],[3370,3528,"Drop the weapon, now!"],[3586,3678,"Now your only chance"],[3678,3791,"is to surrender."],[3883,4066,"Surrender is not my vocabulary."],[4412,4529,"I wanna call my lawyer."],[4600,4729,"Who the hell you think you are?"],[4783,4846,"Take him!"],[4867,4959,"If he resists,"],[4959,5155,"deadly force is authorized!"],[6031,6168,"If you don't want to be incriminated"],[6168,6252,"along with him,"],[6414,6594,"I suggest you let me call my lawyer."],[8083,8183,"Miss Lawson."],[8220,8308,"You're back again."],[8341,8441,"I told you,"],[8441,8562,"Mr. Corbin is busy today and doesn't"],[8562,8650,"have time to meet with you."],[8666,8867,"Oh, but I only need five minutes."],[8879,9017,"Sir, I promise that we have"],[9017,9213,"best law firm in the nation and"],[9221,9338,"we're even willing to do some"],[9338,9467,"pro bono work for you."],[9505,9659,"Just five minutes, that's all I need,"],[9659,9751,"and I promise you"],[9751,9939,"Corbin is going to love-"],[9939,10072,"Goodbye, Miss Lawson."],[10935,10994,"Hello?"],[11015,11106,"Remember me?"],[11106,11273,"The ordinary, retired vet?"],[11282,11323,"Oh."],[11636,11686,"It's you."],[11686,11857,"Yeah, and right now,"],[11882,11957,"I need you."]],"7":[[29,200,"Son, who do you think you're fooling?"],[258,383,"How's a broke bum like you"],[417,521,"afford a lawyer?"],[538,663,"I'm exercising my right to"],[663,867,"remain silent until my lawyer arrives."],[934,1134,"Son, this is my territory."],[1155,1230,"You understand?"],[1247,1430,"I don't care if you got a regular lawyer"],[1430,1568,"or the head of the FBI."],[1580,1701,"You ain't getting out of here."],[1710,1843,"The director of the FBI?"],[1856,1960,"You mean Corbin?"],[2102,2202,"You think you're gonna keep up this"],[2202,2360,"tough guy act if I give him a call?"],[2469,2627,"Sheriff, don't waste your breath."],[2686,2798,"Let's just give him the usual."],[2806,2932,"Turn off the security cams,"],[2932,3086,"and beat him until he confesses."],[3336,3424,"Now, I'll admit,"],[3440,3545,"you're a tough fighter,"],[3574,3691,"but in our station,"],[3787,3870,"nobody leaves"],[3870,3958,"without our permission."],[4012,4129,"Do your worst."],[4162,4333,"It's all child's play anyway."],[4504,4658,"What happens in the station,"],[4658,4788,"stays in the station."],[4821,4925,"I can even kill you"],[4925,5088,"and no one's gonna know."],[5267,5413,"Release my client!"],[6285,6418,"I've recorded everything."],[6431,6619,"If you lay a finger on him, I will make sure"],[6619,6781,"every news outlet has this video"],[6781,6877,"by tomorrow morning."]],"8":[[16,91,"Don't worry, sir."],[112,216,"I'll make sure you walk out of here"],[216,296,"a free man."],[529,613,"Hey, lady."],[725,884,"This is an interrogation room."],[913,1038,"This ain't the court room."],[1038,1134,"You got a problem?"],[1142,1297,"Take it up with the judge."],[1422,1597,"We're busy interrogating this"],[1597,1710,"illegal immigrant."],[1906,2027,"Illegal immigrant?"],[2047,2143,"Yeah, don't you even know"],[2143,2264,"who you're representing?"],[2548,2610,"Look at this,"],[2610,2744,"ID scanner."],[2798,2894,"What's that say?"],[2915,3044,"Cannot verify."],[3065,3174,"You know what that means?"],[3199,3353,"He is undocumented."],[3365,3553,"So mind your little business,"],[3574,3682,"and screw it on out."],[3682,3724,"Mitchell,"],[3741,3895,"take miss lawyer out here, will you?"],[4704,4754,"Sir,"],[4754,4842,"who are you?"],[4917,5084,"Just your ordinary, retired vet."],[5271,5359,"Ma'am."],[5384,5551,"Sir, you're accusing my client"],[5551,5705,"of being an illegal immigrant."],[5726,5860,"I'd like to see some evidence."],[5910,6093,"And if you can't provide any,"],[6122,6222,"I'm gonna have to ask you"],[6222,6297,"to let him go."],[6414,6552,"I've about had enough of you."],[6552,6710,"He is not leaving here today."],[6756,6911,"Small town lawyer like you"],[6911,7048,"should know when to quit."],[7123,7186,"Now, get out."],[7278,7386,"You ain't gonna be able to handle"],[7386,7490,"what's to come."],[7570,7720,"Well, maybe I can't handle it."],[7786,7987,"But what about the director of the FBI?"]],"9":[[70,145,"What'd you say?"],[183,354,"Hopefully this will scare them."],[392,513,"Right before I came here,"],[513,625,"I was in a meeting with the"],[625,825,"director of the FBI, Officer Corbin."],[900,1013,"She knows Corbin?"],[1234,1376,"This nobody lawyer said,"],[1376,1555,"she knows the FBI director."],[1685,1830,"Well, if you don't believe me,"],[1876,2022,"why don't I give him a call?"],[2160,2314,"Go right ahead!"],[2686,2831,"You trying to get one over on us?"],[2873,2990,"You know what happens"],[3003,3119,"when you lie to an officer?"],[3132,3240,"Well, who says I'm lying?"],[3294,3407,"I will call him."],[4070,4229,"Hi, this is Corbin."],[4250,4400,"I can't get to the phone right now."],[4421,4546,"So please leave a message"],[4546,4704,"and I'll get back to you as soon as I can."],[4838,5059,"It sounds like he's busy right now."],[5163,5238,"Enough!"],[5480,5613,"You seem real desperate to"],[5613,5789,"help this boy get him out of here."],[5860,5964,"Why is that?"],[6097,6222,"Is that because you're..."],[6264,6510,"ading and abetting an illegal immigrant?"],[6873,6981,"Fucking savage!"],[7007,7107,"Didn't anybody ever teach you"],[7107,7211,"how to treat a lady?"],[7599,7703,"You want to talk to Corbin?"],[7703,7862,"Well just so happens I know him too."]],"10":[[162,304,"Hey Mitchell, get a load of that."],[346,462,"He knows Corbin too."],[504,604,"That's a good one."],[604,729,"You know, my mama knows the director"],[729,846,"of the FBI too."],[855,967,"Why don't we call her on over."],[967,1121,"Hell, I even know the president."],[1180,1313,"You don't have to say anything, okay?"],[1313,1434,"I will handle this."],[1522,1685,"You tried his work number?"],[1726,1780,"Well."],[1818,2022,"As it happens, I have his personal number."],[2189,2314,"Personal number?"],[2335,2456,"He's got the personal number"],[2456,2590,"of the FBI director."],[2610,2694,"Hey, zip it!"],[2719,2777,"Okay?"],[2777,2907,"Even I can see through that lie."],[2907,2994,"There's no way these officers"],[2994,3098,"are gonna buy it."],[3178,3370,"Yeah, well, let's try it."],[3386,3553,"Hell, maybe he'll even answer."],[4550,4692,"Sir, how can I help?"],[4771,4909,"Director Corbin?"],[4921,5025,"Who are you?"],[5025,5084,"Why do you have"],[5084,5171,"General Barrett's phone?"],[5188,5292,"Oh, uh..."],[5309,5392,"Hey, it's Ethan."],[5392,5513,"You've got ten minutes to get to"],[5513,5663,"the police station at Twin Maples."],[5930,6006,"Helicopter!"],[6006,6106,"Twin Maples Lodge."],[6106,6185,"Stat!"],[6564,6735,"Who you think you are, the president?"],[6785,6844,"Ten minutes?"],[6844,6931,"You kidding, nobody can"],[6931,7019,"get here that fast."],[7032,7244,"Except that FBI helicopter."]],"11":[[316,487,"Who you think you are, the president?"],[613,713,"You sound so serious,"],[713,821,"I almost fell for it."],[988,1130,"Why did you fake that phone call?"],[1130,1280,"I told you to leave it to me."],[1451,1655,"Sheriff, I'm going to bail my client out."],[1689,1755,"Bail?"],[1872,1972,"He ain't going nowhere."],[2006,2097,"I'm gonna escort him"],[2097,2298,"to the electric chair myself."],[2460,2602,"What is wrong with you?"],[2602,2777,"Look, I'm done humoring you."],[2777,2882,"Get this bitch out of here."],[3007,3119,"Get your hands off me-"],[3119,3232,"Hey, get your hands off!"],[3274,3307,"Hey!"],[3307,3536,"This is illegal, I will sue you!"],[3870,3962,"Looks like you ain't got"],[3962,4145,"nobody here to save you now."],[4229,4300,"I'd be worried about"],[4300,4454,"saving myself if I were you."],[4742,4842,"Five minutes."],[5747,5930,"Two of you, secure the premises."],[5947,6101,"Two of you, follow me inside."],[6598,6727,"How's this for a headline?"],[6785,6998,"Illegal immigrant assault officer."],[7061,7203,"Sheriff saves the day"],[7203,7361,"by shooting him dead."],[7444,7595,"It's a bit wordy, honestly."],[7653,7732,"One minute."],[7774,7882,"I told you earlier,"],[7912,8049,"I'd get back to the station."],[8078,8291,"You'll see who the real dead man is."],[8537,8888,"Now, you can rot in hell, bastard."],[9288,9359,"Stop!"],[10360,10514,"That homeless man..."],[10869,11015,"is an American hero."]],"12":[[125,271,"An American hero?"],[291,371,"He's just some"],[371,533,"vagrant creep walking around with"],[563,675,"freaky ashes."],[1755,1872,"Look at his face!"],[2014,2198,"That is a real hero."],[2235,2427,"Not somebody a pencil-pushing"],[2427,2615,"worm like you can humiliate."],[2686,2819,"That is not possible!"],[3078,3219,"What the hell did you do?"],[3282,3382,"Sir, sir, I-"],[3403,3645,"You know Pierce bled for this country."],[3674,3737,"Pig like you"],[3737,3916,"who just hides behind your badge."],[3937,4041,"Bullying the weak,"],[4041,4183,"humiliating the poor."],[4220,4379,"Apologize to him."],[4742,4954,"I ain't apologize to a"],[5000,5155,"pile of ashes!"],[5776,5905,"Apologize now!"],[6022,6147,"Or the next one's in your head."],[6147,6214,"Now!"],[6402,6527,"I'm sorry!"]],"13":[[20,104,"All of you!"],[734,800,"Sir,"],[800,917,"I know you and Pierce"],[917,1096,"wanted to stay out of the spotlight."],[1121,1313,"But people should know who you are."],[1313,1393,"Otherwise,"],[1413,1551,"things like this..."],[1593,1676,"keep happening."],[1693,1826,"This is all my fault."],[1893,2064,"I'm holding a Hero's Memorial"],[2064,2314,"at the Twin Maple Lodge in two days,"],[2314,2510,"to honor your achievements,"],[2665,2827,"and Pierce's sacrifice."],[2848,2986,"Bring Pierce's family."],[3032,3178,"That's the only way to help them."],[3244,3315,"Got it."],[3516,3728,"Sheriff James Jones,"],[3728,3941,"as director of the FBI."],[3962,4175,"I'm putting you under arrest."],[4454,4562,"You can't arrest me."],[4562,4696,"No, you can't-"],[4696,4788,"Get off me!"],[4804,4875,"You can't arrest me!"],[4875,4996,"I'm the police!"],[5238,5338,"Not anymore."],[5438,5492,"Now,"],[5530,5697,"you're just another criminal."],[5776,5880,"We're charging you"],[5880,6085,"with abuse of authority,"],[6085,6247,"use of excessive force,"],[6247,6481,"and desecration of the deceased."],[6589,6690,"And all of you"],[6690,6931,"will be suspended without pay"],[6931,7090,"during the investigation."],[7319,7374,"No!"],[7532,7640,"I want bail!"],[7678,7832,"All of you, out!"],[7841,7928,"Now!"],[8888,8963,"Who is she?"],[9351,9526,"Director Corbin, hi."],[9526,9563,"Uhm."],[9584,9793,"My name is Victoria Lawson."],[9793,9951,"I... it's an honor really."],[9951,10068,"I was actually at your office"],[10068,10256,"just earlier today because I wanted to"],[10256,10418,"discuss a partnership between"],[10456,10610,"the FBI and my law firm."],[10635,10756,"But you were in a meeting,"],[10756,10894,"so you weren't really available."],[10910,10994,"It's fine."],[11015,11286,"And what's your relationship with"],[11286,11428,"General Barrett?"],[11657,11836,"Oh, I'm his..."],[11903,11986,"fiancée."]],"14":[[154,250,"Go along with it."],[513,684,"Well, Miss Lawson,"],[721,792,"you're welcome to"],[792,925,"visit my office anytime."],[1021,1234,"I'd be happy to discuss the contract."],[1255,1334,"Really?"],[1409,1526,"I mean, thank you, sir."],[3190,3274,"Good for a drink?"],[5109,5176,"So,"],[5280,5397,"who are you really?"],[5447,5576,"I've been trying to get a meeting with"],[5576,5689,"the director of the FBI"],[5689,5809,"for some time now,"],[5809,5980,"and you show up,"],[5980,6156,"and instantly he says yes."],[6268,6402,"Maybe you're a really good lawyer."],[6402,6468,"Emmm."],[6961,7007,"Come on."],[7023,7148,"Don't patronize me."],[7232,7336,"How many other secrets"],[7336,7419,"are you hiding?"]],"15":[[108,321,"I'm just your ordinary, retired vet."],[429,571,"I don't think an ordinary vet"],[571,754,"could order around the director"],[754,884,"of the FBI."],[1076,1201,"The less you know, the better."],[1276,1343,"Fine."],[2298,2410,"Cheers."],[2444,2606,"Mr. Ordinary Vet."],[3495,3591,"Yes, you did."],[3591,3691,"No, you started it."],[3691,3853,"It was you."],[4462,4571,"Excuse me."],[5117,5226,"Um, well."],[5226,5347,"I guess I should go."],[5634,5705,"Wait."],[6544,6669,"Why don't you stay?"],[11444,11565,"Morning, sunshine."],[12283,12345,"Hi."]],"16":[[196,371,"Do you always wear those same clothes?"],[529,633,"Yeah, they're comfortable."],[788,846,"Okay."],[896,1046,"They're familiar, safe."],[1376,1547,"I get to bring Pierce home today."],[1943,2047,"Do you want to come with me?"],[2181,2285,"I'd be honored."],[2715,2890,"I'll go get us some breakfast."],[5547,5613,"Oh."],[5847,5972,"Oh, I'm so sorry."],[6060,6147,"Are you okay?"],[6239,6306,"Ew!"],[6339,6556,"Get your filthy hand away from me!"],[6723,6798,"What?"],[6848,6952,"Where the hell is security?"],[6981,7127,"Who let this disgusting homeless"],[7127,7298,"man into the Twin Maple's Lodge?"],[7307,7503,"This is supposed to be a five-star hotel."],[7520,7653,"Okay, I already apologized."],[7670,7707,"Alright?"],[7707,7853,"There's no need to talk to me like that."],[7920,8020,"Apologies?"],[8083,8174,"If apologies were enough,"],[8174,8324,"what would we need the police for?"],[8641,8754,"You bastard!"],[8754,8850,"You ruined the dress"],[8850,8992,"that Daniels gave me!"],[9217,9359,"This is haute couture."],[9359,9430,"It costs over"],[9430,9676,"three hundred thousand dollars!"]],"17":[[41,221,"Three hundred thousand dollars?"],[250,375,"That homeless man is about to"],[375,467,"get destroyed."],[508,608,"Serves him right."],[629,804,"Good for nothing, vagrant like him."],[842,1034,"Doesn't deserve any sympathy."],[1084,1134,"Okay."],[1176,1351,"I'll pay for the dress, all right?"],[1430,1514,"Pay for it?"],[1534,1622,"With what?"],[1622,1785,"Just look at what you're wearing."],[1785,1914,"I mean, if you didn't steal it,"],[1914,2027,"then there's no way you paid more than"],[2027,2147,"50 bucks for it."],[2173,2277,"I didn't steal-"],[2277,2489,"Do you understand how much"],[2489,2802,"three hundred thousand dollars is?"],[2936,3153,"It's enough to buy your pathetic life."],[3153,3232,"Enough."],[3261,3424,"Don't degrade yourself."],[3424,3603,"Speaking to a peasant like him,"],[3603,3653,"okay?"],[3724,3937,"Let the police deal with this."],[3966,4200,"Mr. Daniels is still waiting for us."],[4216,4325,"Yes, Father."],[4533,4608,"You know what?"],[4692,4804,"If you got on your knees"],[4804,4984,"and begged for me right now,"],[5005,5138,"I might maybe consider"],[5138,5280,"not calling the police."],[5417,5668,"OMG, she's so kind."],[5668,5901,"She's even given him a chance to go free."],[5926,6010,"Hey, man."],[6010,6235,"I suggest you get down on your knees"],[6235,6381,"and apologize."],[6423,6698,"Your dignity is not worth 300,000."],[6752,6798,"Well,"],[6894,6977,"thought about it yet?"],[7040,7111,"Kneel."],[7119,7194,"Kneel."],[7203,7278,"Kneel."],[7290,7353,"Kneel."],[7374,7432,"Kneel."],[7449,7515,"Kneel."],[7536,7799,"Kneel."]],"18":[[0,529,"Kneel."],[529,650,"What's going on here?"],[813,867,"Finally!"],[905,1096,"Can nobody do their jobs around here?"],[1113,1322,"Who let this filthy homeless freak"],[1322,1443,"into the Twin Maple's Lodge?"],[1463,1555,"We're so sorry, ma'am."],[1555,1730,"We'll take him away immediately."],[1764,1976,"Sir, we're gonna have to ask you to leave."],[2027,2122,"Oh, and don't forget this."],[2122,2239,"You don't want his trash"],[2239,2364,"stinking up the place."],[2911,2986,"Don't"],[3036,3123,"touch"],[3148,3265,"my stuff."],[4475,4546,"Hold it!"],[5359,5530,"Oh, my God."],[5563,5626,"If it isn't my"],[5626,5860,"hotshot lawyer big sis, Victoria?"],[5943,6014,"Emily?"],[6151,6227,"Dad?"],[6427,6560,"What are you guys doing here?"]],"19":[[154,325,"Oh my God, Vicky."],[362,487,"You're unbelievable."],[487,613,"Is this your new man?"],[638,746,"A homeless bum?"],[855,884,"Well,"],[884,1059,"what gives you the right to judge me?"],[1101,1176,"Emily,"],[1255,1359,"you were adopted."],[1801,1972,"I might be adopted, but at least I can"],[1972,2093,"keep up appearances."],[2131,2210,"Unlike you."],[2210,2335,"Picking up random homeless"],[2335,2473,"weirdos off the street."],[2648,2765,"Watch it, Emily."],[2902,2982,"Enough."],[2998,3315,"You've disgraced the Lawson family."],[3315,3520,"How scandalous."],[3520,3678,"The socialite of the Lawson family"],[3678,3832,"is sleeping with a homeless guy."],[3832,3895,"What if he's some"],[3895,4049,"disease-ridden junkie?"],[4049,4183,"If that was my daughter,"],[4191,4329,"I'd break her legs."],[4354,4496,"Make sure she would never"],[4496,4596,"leave the house."],[4704,4884,"Dad, Ethan is-"],[4884,5142,"I don't care who the hell he is."],[5142,5271,"Break it off now!"],[5280,5463,"And get your ass back home."],[5463,5509,"No."],[5568,5651,"You don't get to tell me"],[5651,5784,"what to do with my life-"]],"20":[[171,362,"Hey, this is my family, okay?"],[404,479,"I can handle it."],[479,571,"Let me deal with them."],[709,842,"So this is the man you chose?"],[880,959,"Someone who"],[975,1109,"cowards behind women?"],[1288,1401,"Well, at least I'm with"],[1401,1539,"someone I actually like."],[1568,1768,"Unlike you, who's just hiding behind"],[1768,1872,"an arranged marriage"],[1872,1985,"to someone who's old enough"],[1985,2097,"to be your father."],[2147,2214,"Shut up!"],[2410,2473,"Ow!"],[2519,2656,"If you don't want your wrist to break,"],[2698,2857,"stop talking."],[2957,3140,"Let go, that hurts!"],[3495,3536,"Dad."],[3628,3766,"Do you remember three years ago,"],[3803,3916,"you said I could be"],[3916,4058,"with whoever I wanted as long as"],[4058,4195,"I made ten million dollars."],[4258,4358,"You're right, I did."],[4400,4608,"But all you have to show for yourself"],[4608,4733,"in three years"],[4733,4921,"is twenty thousand dollars!"],[4938,5167,"You have one month left."],[5167,5234,"Unless..."],[5255,5372,"Well, actually"],[5518,5676,"I have a contract with the FBI"],[5676,5826,"coming up for ten million."],[6051,6106,"Come on."],[6135,6310,"A ten million dollar deal?"],[6310,6443,"With the FBI?"],[6477,6639,"Please, you're just a third rate lawyer"],[6639,6752,"who couldn't even get into"],[6752,6873,"a top rated law firm."],[6886,6981,"Or did this homeless freak"],[6981,7065,"give you some help?"],[7065,7102,"Like..."],[7123,7215,"Yes, actually,"],[7215,7353,"that's exactly what happened."],[7432,7732,"FBI contract is all thanks to Ethan."]],"21":[[12,150,"Come on!"],[150,237,"I mean if you're gonna make up"],[237,291,"a story,"],[291,479,"at least make up a believable one."],[504,608,"God, Emily."],[633,771,"Is everyone just a liar to you?"],[846,900,"Vicky,"],[950,1096,"Dad and I can see right through"],[1096,1197,"your half-assed lie."],[1213,1326,"I assume you're the one"],[1326,1493,"fronting all the money for this hotel?"],[1614,1693,"OMG!"],[1693,1881,"I totally forgot to tell you!"],[1918,2060,"My fiancé,"],[2060,2189,"Don Daniels,"],[2210,2356,"actually owns this hotel."],[2364,2423,"What?"],[2456,2660,"She's Mr. Daniels' fiancée?"],[2673,2761,"Shhh."],[2761,2877,"Keep it down."],[2877,2986,"You have a death wish?"],[2986,3119,"Don't say his name."],[3199,3324,"I don't know what dirty tricks"],[3324,3545,"you use to seduce my daughter."],[3582,3703,"But remember this."],[3762,3933,"Deadbeat vagrant like you"],[3962,4250,"does not deserve my daughter."],[4383,4546,"Don't ever touch me again."],[4754,4900,"If you leave Victoria right now,"],[4975,5217,"I can get you a job at this hotel."],[5234,5388,"Wouldn't mopping the floors be"],[5388,5547,"better than begging for change?"],[5939,6085,"You think I'm a charity case?"],[6339,6569,"Nobody insults a soldier's dignity."]],"22":[[16,237,"Oh, so that isn‘t just a costume?"],[237,358,"You really are a soldier?"],[567,700,"You used to be one."],[746,1009,"Now you're just some disabled vet."],[1026,1359,"Too traumatized by PTSD or whatever"],[1359,1518,"to go get a real job!"],[1572,1735,"Vicky, you really picked a charity case"],[1735,1839,"with this one."],[1847,1976,"It's really sweet."],[1976,2031,"But,"],[2068,2168,"you probably should have just died"],[2168,2235,"on the battlefield"],[2235,2364,"like the rest of your comrades."],[2381,2460,"Quietly."],[2464,2635,"But no, you're a killing machine."],[2656,2794,"Burning and looting"],[2794,2990,"and running amok in other countries."],[2990,3111,"And then coming home,"],[3111,3257,"and accepting pension payments"],[3257,3395,"from the government every month."],[3395,3586,"And burning through our tax dollars!"],[3586,3687,"You know what, Emily?"],[3687,3870,"You're so ignorant."],[3887,4070,"You don't even know who he is."],[4091,4266,"He's an American hero."],[4496,4571,"Shut up!"],[4604,4888,"You're a disgrace to the Lawson family."],[5013,5130,"Listen here, old man."],[5201,5347,"I have more blood on my hands"],[5347,5459,"than you will ever know."],[5534,5659,"And if it weren't for Victoria,"],[5730,5901,"you would be dead already."],[5901,6035,"Let go of my dad!"],[6535,6619,"You psycho!"],[6619,6773,"You filthy, homeless freak!"],[6773,6852,"How dare you!"]],"23":[[396,517,"You, you..."],[880,1055,"Call Daniels, now!"],[1084,1251,"He'll make sure this homeless vet"],[1251,1426,"gets chopped to bits!"],[1914,2089,"Never thought I'd get to sit down and"],[2089,2360,"have a drink with the Director of the FBI."],[2494,2606,"Mr. Daniels,"],[2652,2827,"I'd like to hold a War Hero's Memorial"],[2827,2990,"at your hotel."],[2990,3065,"Tonight."],[3144,3244,"There's a veteran"],[3244,3415,"and a fallen soldier I'd like to honor."],[3432,3653,"We'd like your help in organizing"],[3653,3732,"this event."],[3774,3920,"Oh, the irony."],[3920,4179,"Who knew, a mafioso like me would"],[4179,4366,"get to organize a government event"],[4366,4441,"like this?"],[4483,4558,"Well, Corbin,"],[4558,4708,"I don't know if I can be much help."],[4708,4884,"I'm just your ordinary citizen."],[5509,5647,"You're Don Daniels,"],[5647,5939,"founder of America's largest hotel chain."],[5939,6076,"Your other business operations"],[6076,6289,"include brokerage firms,"],[6289,6489,"loans, real estate..."],[6773,6877,"Must I go on?"],[7044,7194,"It's a pleasure to do business with you,"],[7194,7282,"Mr. Corbin."],[7753,7924,"I'll need you to prepare four"],[7924,8174,"of your most exclusive invitations"],[8174,8279,"to this event."],[8329,8562,"I'm sending them to my guests of honor."],[8921,8992,"Those,"],[9059,9351,"are my VVVIP"],[9351,9547,"platinum-access invitations."],[9559,9722,"As long as they're holding those,"],[9743,9930,"we'll fulfill their every request."],[10397,10447,"Don."],[10493,10706,"Help me kill this homeless psycho!"]],"24":[[25,100,"What happened?"],[383,563,"Deliver these to Ethan right now."],[608,692,"Don't worry about it, baby."],[692,842,"I'll have Paulo deal with him."],[1067,1163,"I need to..."],[1192,1359,"go downstairs and take care of"],[1359,1526,"a few things, Mr. Corbin."],[1555,1718,"Of course, Mr. Daniels."],[1785,1868,"I'll be seeing you"],[1868,2014,"at the memorial event tonight."],[2502,2748,"You're so dead, you homeless mutt."],[2769,2894,"Daniels is gonna kill you."],[2932,3140,"That homeless man must be real brave"],[3140,3374,"to lay a hand on Mr. Daniels' fiancée."],[3399,3486,"Too bad."],[3499,3741,"Looks like the show is coming to an end."],[4346,4487,"Oh, it's Mr. Lewis."],[4546,4667,"Who's Mr. Lewis?"],[4679,4800,"It's Logan Lewis."],[4817,5000,"Deputy Director for the FBI."],[5013,5171,"He's the right-hand man"],[5180,5434,"to FBI director, Kent Corbin."],[5434,5555,"I mean, I cannot believe"],[5555,5868,"Mr. Daniels sent for Lewis."],[5868,6106,"That homeless man is done for."],[6168,6373,"You must be a real psychopath,"],[6373,6464,"you homeless mutt."],[6464,6577,"How are you staying so calm"],[6577,6685,"in this situation?"],[6748,6810,"You know what?"],[6810,6890,"It doesn't even matter."],[6915,7011,"I'm just gonna make sure that"],[7011,7219,"you die a slow, painful death."],[7265,7353,"Mr. Lewis."],[7461,7620,"It's been a pleasure to see you again."],[7649,7736,"This is him."],[7761,7941,"This is the vagrant that attacked me."],[7974,8133,"Arrest him right now!"],[8525,8625,"What are you waiting for?"],[8658,8842,"Come on, I'm gonna get Don to fire you."],[9359,9463,"Greetings, sir."]],"25":[[196,296,"Are you all insane?"],[316,458,"This is a homeless man!"],[596,671,"Don't."],[905,975,"Mr. Barrett,"],[1009,1092,"your invitations to"],[1092,1263,"the War Hero Memorial tonight."],[1555,1618,"Thank you."],[1718,1805,"See you tonight, sir."],[2081,2139,"Do you require"],[2139,2260,"assistance with them, sir?"],[2619,2736,"You know what, actually?"],[2802,2986,"I think we'll deal with them ourselves."],[3174,3294,"Please contact me if you need any help."],[3328,3386,"Will do."],[4333,4466,"It's time for the real hero"],[4466,4587,"of tonight's memorial."],[4688,4804,"Pierce's widow and son."],[4942,5009,"Yeah."],[5155,5259,"Let's take Pierce home."],[5943,6006,"Dad."],[6047,6172,"Why did you stop me just now?"],[6206,6343,"I don't understand"],[6343,6485,"why Lewis helped them."],[6514,6606,"But I do know,"],[6606,6756,"causing a scene right now"],[6777,6915,"won't help us."],[7119,7273,"Let's go find Daniels."]],"26":[[125,175,"Paulo,"],[216,283,"tell me,"],[316,483,"why do our profits"],[504,767,"keep getting smaller and smaller?"],[817,884,"Well, boss,"],[917,1009,"ever since we raised our"],[1009,1146,"interest rates 20%,"],[1146,1238,"people just started"],[1238,1368,"defaulting on their loans."],[1459,1518,"Well,"],[1555,1685,"looks like people are getting"],[1685,1797,"a bit comfortable."],[1856,2056,"Maybe we need to remind them"],[2118,2235,"who they're dealing with."],[2352,2444,"Understood, boss."],[2569,2631,"Don!"],[2752,2869,"Don, you have to help me."],[2894,2990,"God, Emily,"],[2990,3119,"what is that smell?"],[3336,3511,"That's what I'm trying to tell you."],[3574,3716,"It's all because of that stupid"],[3716,3816,"homeless man."],[3816,4024,"He dumped trash all over me,"],[4024,4162,"and he even attacked my dad!"],[4212,4258,"Don,"],[4291,4412,"you need to find him,"],[4446,4558,"and you need to kill him!"],[4654,4721,"Paulo,"],[4792,4879,"deal with this."],[4884,4959,"On it."],[5434,5509,"Mommy,"],[5655,5768,"did those bad guys come again"],[5768,5851,"last night?"],[5926,6026,"Don't worry, Ian."],[6101,6206,"I'll protect you, honey."],[6281,6435,"When's daddy coming home?"],[6502,6690,"I had another dream about Daddy again."],[6719,6819,"If he was here,"],[6819,6994,"he'd beat up all those bad guys."],[7036,7140,"He would, wouldn't he?"],[7444,7503,"Hey,"],[7536,7615,"don't worry."],[7749,7862,"Remember that letter we got from Daddy"],[7862,7945,"a few days ago?"],[8049,8166,"Well, I'm sure he's gonna be home"],[8166,8241,"very soon."]],"27":[[191,271,"Look at that, huh?"],[287,350,"I told you they were gonna"],[350,533,"get in trouble sooner or later."],[558,654,"How unsightly."],[704,771,"This is supposed to be"],[771,892,"a good neighborhood."],[925,1009,"I know, right?"],[1376,1468,"Nice shot, boss!"],[1501,1593,"Three pointer."],[1735,1881,"Whoa, whoa, whoa, whoa, mama!"],[1881,1922,"Hey!"],[1922,1989,"Where you going?"],[1989,2056,"No, no, no!"],[2068,2143,"Get off of me!"],[2168,2243,"Stop."],[2243,2289,"Hey."],[2289,2460,"You can't run from your problem, Marie."],[2469,2677,"We already paid your loan back."],[2727,2815,"So why are you back?"],[2831,2915,"Paid it off?"],[3148,3274,"Says right here you‘re past due."],[3357,3407,"What?"],[3411,3524,"Five hundred thousand dollars?"],[3578,3687,"No, no, we only borrowed"],[3687,3757,"ten thousand."],[3757,3883,"So why does it say five hundred now?"],[3883,3937,"That..."],[3953,4091,"You can't do that, that's illegal."],[4137,4212,"It, is it?"],[4279,4387,"It says the interest"],[4387,4496,"depends on the lender."],[4542,4612,"And me, the lender,"],[4612,4754,"I get to decide whatever it is."],[4800,4888,"What the...."],[5000,5050,"But..."],[5050,5146,"But what?"],[5171,5309,"But if you can't pay with money,"],[5392,5526,"then we can use something else."]],"28":[[262,333,"Hey."],[333,483,"Don‘t touch me!"],[483,646,"You're a little spicy mama."],[646,734,"I like this."],[809,930,"You'd better just back off."],[1013,1134,"My husband is a soldier."],[1209,1351,"Oh, you're military wife?"],[1409,1509,"Oh, even better."],[1559,1747,"I hear you girls are all pent up."],[1776,1922,"I know you're gonna scream for me"],[1922,2031,"real good later."],[2056,2306,"God, Pierce, where are you?"],[2331,2419,"Grab her, guys."],[2419,2523,"No, no, no."],[2531,2648,"Don't you come anywhere near me."],[2648,2769,"Woah! -Back off!"],[2873,3007,"You a firecracker!"],[3032,3232,"I hope you fight this hard later on."],[3249,3332,"Grab her, guys."],[3349,3457,"No, no, no, no."],[3895,3920,"Stop!"],[3920,4095,"Whoa, I like this."],[4116,4204,"Take her inside."],[4220,4300,"Get off of me."],[4320,4437,"Stop, leave me alone."],[4487,4533,"Stop it."],[4621,4733,"Ow, ow."],[4742,4871,"Stop, let go!"],[5355,5417,"No."],[6356,6427,"Ah!"],[6535,6702,"Bit me, you little shit!"]],"29":[[133,279,"Bit me, you little shit!"],[279,392,"Are you okay, Ian?"],[412,492,"Don't worry, Mom."],[492,663,"I'll protect you just like daddy."],[809,875,"Tie them up!"],[905,1021,"I'll beat them with my own hands."],[1038,1180,"No, stay back!"],[1209,1409,"I told you that my husband is a soldier."],[1443,1551,"And the law's on our side!"],[1551,1747,"So you try anything and I call the police!"],[1747,1830,"The law?"],[1906,1985,"The law is a leash"],[1985,2097,"for ordinary people like you."],[2097,2202,"This is my town."],[2252,2402,"The law doesn't apply to me here."],[2444,2535,"No, no, no, no!"],[3094,3253,"But since you wanna talk about the law,"],[3282,3395,"let's talk about the law."],[3420,3528,"Pay your debts, Marie."],[3549,3720,"I gave you everything I have!"],[3720,3962,"I don't have any money!"],[4045,4112,"Is that so?"],[4154,4300,"You don't want to give us the cash?"],[4325,4496,"I guess we'll find it for ourselves."],[4717,4779,"No."],[4792,4929,"My boys can be a little rough."],[5084,5184,"No, stop."],[5280,5338,"Stop."],[5442,5501,"No."],[5638,5743,"No, stop."],[5960,6143,"Uh, oh, sorry in advance"],[6143,6256,"that they break anything."],[6297,6448,"Find the cash, guys!"],[6481,6627,"Just stop."]],"30":[[316,425,"You're almost home, brother."],[996,1059,"No."],[1488,1584,"Oh my God!"],[1693,1826,"Mommy, where is daddy?"],[1839,1926,"I‘m scared."],[1981,2256,"Pierce, when are you coming home?"],[2268,2427,"I can't hold out much longer."],[2431,2502,"Boss,"],[2552,2652,"there's nothing here."],[2681,2861,"Because I already told you."],[2886,3015,"I don't have anything left."],[3057,3119,"Fine."],[3274,3365,"You don't want to pay."],[3386,3624,"I'll sell you to the nastiest pimp I know."],[3745,3837,"No. Mommy! -No, no, no, no."],[3837,3891,"Mommy! -No, no, no, no."],[3924,4099,"No, no, no, no, not my son."],[4104,4187,"Not my son."],[4195,4291,"Take her away!"],[4375,4504,"No, no, no, not my son!"],[4504,4667,"Please, please, no, please stop."],[4675,4829,"Get your hands off her."],[5296,5372,"Ethan?"],[6160,6231,"Marie, I..."],[6348,6431,"No..."],[6573,6677,"I brought Pierce home."]],"31":[[70,162,"I brought Pierce home."],[250,333,"No."],[437,529,"No, Pierce..."],[575,692,"He, he just..."],[763,880,"Is this some kind of joke?"],[1042,1105,"No."],[1138,1292,"Mom, mommy, mom! -Hey, hey."],[1305,1363,"Ian."],[1605,1672,"Pierce."],[1730,1876,"This isn't funny, come out."],[1997,2106,"Pierce,"],[2131,2289,"where are you?"],[2423,2502,"Ian."],[3349,3420,"Your dad,"],[3490,3624,"is a true American hero."],[3732,3874,"Don't you ever forget that."],[3928,4037,"Who is that?"],[4037,4145,"I don't know, but he said"],[4145,4283,"Pierce was some sort of hero."],[4421,4525,"What happened here?"],[4608,4738,"I am so confused,"],[4738,4859,"who the fuck are you?"],[5059,5188,"So you did all this?"],[5201,5376,"Yes, I sure did."],[5376,5551,"Now if you know what's best for you?"],[5580,5784,"Run along, or you're gonna get this too."],[5805,5943,"Nobody messes with the family"],[5943,6064,"of an American hero."],[6260,6348,"So what?"],[6373,6531,"In this town, I'm the hero."],[6564,6660,"I'm the law!"],[6660,6727,"Even the police"],[6727,6856,"have nothing to do with me."],[6865,7132,"Let along some widow and her brat!"],[7298,7469,"Well, if the cops won't do anything,"],[7482,7665,"I guess I'll have to send you to God."]],"32":[[283,375,"Do you hear that?"],[396,533,"He‘s gonna send me to God."],[550,679,"I never thought in a million years"],[679,767,"some homeless loser"],[767,863,"would be threatening me."],[880,1042,"Looks like another body"],[1042,1130,"is going to be showing up"],[1130,1309,"in the river again tomorrow."],[1359,1547,"Everybody knows that Twin Maples,"],[1547,1839,"Paulo is Mr. Daniels‘ right-hand man."],[1860,2027,"You mess with Mr. Daniels?"],[2027,2193,"You're pretty much good as dead."],[2268,2414,"Mr. Daniels."],[2427,2548,"Kill them."],[5355,5447,"What are you doing?"],[5447,5613,"Sending you to meet your maker."],[5626,5739,"You can't hurt me."],[5755,5885,"My boss is Don Daniels!"],[5885,6056,"He runs the entire Northeast!"],[6056,6164,"If you hurt me,"],[6164,6285,"he'll kill them!"],[6510,6585,"Listen,"],[6585,6660,"I'll admit"],[6660,6790,"you're pretty damn tough."],[6790,6835,"Okay?"],[6835,6886,"But,"],[6890,7036,"you have to leave this town eventually."],[7090,7186,"And when you do,"],[7203,7298,"it's up to me what happens"],[7298,7419,"to that widow and that brat."],[7582,7820,"No hero's family deserves to"],[7820,7962,"get humiliated like this."],[8016,8108,"What did you say?"],[8145,8287,"I said anybody who touches"],[8287,8462,"a soldier's family will die."]],"33":[[25,145,"You can protect them for a day,"],[145,233,"maybe a month."],[246,383,"But you can't protect them forever."],[412,588,"And one day, when you leave,"],[629,704,"I decide."],[759,892,"I'm gonna think of a million ways"],[892,955,"to kill them."],[1305,1418,"What should we do?"],[1509,1701,"You know, Pierce and I were surrounded."],[1701,1785,"Ten to one."],[1785,1926,"And we thought we were finished."],[1989,2118,"We took out their commander."],[2335,2510,"You know what a soldier calls that?"],[2627,2690,"What?"],[2740,2890,"A decapitation strike."],[4521,4592,"You kill me."],[4654,4838,"Mr. Daniels will destroy everyone."],[4838,4934,"Everyone!"],[5000,5138,"He won't stand for this."],[5221,5438,"You tell Don Daniels I'm coming for him."],[5860,5968,"Don Daniels,"],[6047,6151,"you ready for this?"]],"34":[[692,775,"What happened?"],[867,971,"Boss, there's a homeless man,"],[1021,1138,"there's like nine guys-"],[1138,1280,"Take, take that off your nose."],[1334,1413,"It hurts, boss."],[1413,1518,"Fucking embarrass me."],[1539,1618,"God damn."],[1751,1822,"Mr. Daniels."],[1872,1935,"Yes, sir."],[1985,2110,"It's time for the memorial to start."],[2110,2210,"Excellent, excellent."],[2210,2298,"Thank you."],[3003,3078,"Don."],[3161,3244,"We‘re here."],[3741,3837,"Soldiers,"],[3874,4058,"are the soul of this country."],[4087,4170,"They are the blood,"],[4170,4437,"the sweat, and the tears of America."],[4508,4637,"And we must remember"],[4637,4783,"their sacrifices."],[4808,4879,"Now,"],[4896,5134,"let's honor our American hero."]],"35":[[354,508,"It's that homeless bum!"],[538,767,"But what's he still doing in town?"],[859,1055,"You tell Don Daniels I'm coming for him."],[1280,1368,"It's you!"],[1409,1472,"Emily,"],[1472,1539,"you know him?"],[1555,1605,"Yeah."],[1622,1705,"Remember that homeless"],[1705,1893,"psychopath I was telling you about?"],[1935,2039,"That's him."],[2127,2223,"I can't believe"],[2223,2389,"a filthy homeless freak like him"],[2389,2469,"would sneak into"],[2469,2623,"a dignified event like this."],[2631,2698,"Ugh!"],[2698,2806,"I think we need to sanitize"],[2806,2927,"this whole place now."],[2986,3186,"You disgusting bum!"],[3224,3336,"You are so dead now."],[3336,3432,"I‘ll kill you."],[3432,3507,"Wait."],[3545,3787,"He's attending an event at my hotel."],[3820,4037,"That means he must be my guest."],[4074,4337,"This homeless man must be hungry."],[4354,4571,"Let's have the chef prepare him a meal."]],"36":[[0,171,"No wonder they call Mr. Daniels"],[171,400,"the great American philanthropist."],[450,617,"He has such a kind heart."],[671,809,"You should be grateful."],[846,1042,"Not only did Mr. Daniels"],[1042,1313,"let a filthy vagrant like you stay."],[1343,1555,"He's also invited you to a meal."],[1555,1701,"So get on your knees!"],[1751,1864,"And thank him."],[2077,2264,"You still think I'm a charity case?"],[2527,2690,"If it weren't for Pierce's memory,"],[2706,2869,"I wouldn't waste my time with you idiots."],[2907,3082,"Oh, well, we're so honored"],[3082,3199,"that you've decided to"],[3199,3349,"grace us with your presence,"],[3349,3516,"Mr. homeless loser!"],[3516,3645,"Who even invited this guy?"],[3674,3812,"He was invited?"],[3812,3908,"That's an embarrassment"],[3908,3999,"to all of us."],[4029,4341,"This is an invitation only event."],[4371,4512,"Where's your invitation?"],[4546,4600,"Huh?"],[4621,4733,"Show it to us."],[4804,4942,"If he can pull out an invitation,"],[4942,5046,"I will eat my words."],[5046,5205,"Hell, I'll eat the invitation."],[5330,5459,"But if he can't, I..."],[5530,5597,"I guess we'll just have to"],[5597,5772,"break his legs and he'll have to"],[5772,5922,"army crawl out of here."],[5943,6039,"Watch it, Emily."],[6093,6160,"Before you get"],[6160,6272,"what's coming to you."],[6293,6456,"Enough, Victoria!"],[6506,6731,"If you apologize now,"],[6760,7036,"I'll give you one last chance."],[7052,7198,"And you can return"],[7257,7403,"to the Lawson family."],[7469,7624,"I don't care what happens to me."],[7665,7749,"I'm with Ethan."],[7974,8037,"Come here."],[8274,8379,"Oh, Victoria."],[8416,8600,"Just look at how far you've fallen."],[8612,8704,"You've started behaving like"],[8704,8842,"your vagrant boy toy."],[8858,9046,"Crashing society events like a..."],[9092,9200,"well, like a criminal?"],[9300,9417,"Oh, how I pity you."],[10114,10206,"I can already imagine you"],[10206,10406,"screaming and crying on your knees."],[10443,10639,"Kick out these losers now!"],[11094,11261,"Who says we weren't invited?"]],"37":[[166,216,"No!"],[358,487,"That's impossible."],[517,625,"Those are the highest level"],[625,813,"invitations from Twin Maple's Lodge."],[834,1005,"Only the most exclusive,"],[1005,1276,"top 1% clientele get that invite."],[1297,1459,"But how did it end up in the hands of that"],[1459,1576,"homeless man?"],[1597,1826,"My Don, you're the only one"],[1826,1956,"with those invitations."],[1976,2018,"Did,"],[2018,2160,"did you happen to give him one?"],[2160,2406,"No, no, I don't know what‘s this all about."],[2719,2794,"Those..."],[2823,3098,"are my VVVIP"],[3098,3294,"platinum-access invitations."],[3307,3470,"As long as they're holding those,"],[3490,3670,"we'll fulfill their every request."],[3712,3849,"Could he be the guest of"],[3849,4037,"honor Director Corbin mentioned?"],[4062,4200,"He‘s just clearly"],[4200,4466,"a filthy, homeless, vagrant!"],[4471,4662,"Oh, I know."],[4662,4725,"Duh!"],[4750,4934,"He forged them, obviously."],[4959,5059,"Oh my,"],[5080,5217,"he forged the exclusive"],[5217,5438,"Twin Maple's Lodge invitations?"],[5438,5609,"He's about to get wrecked."],[5622,5680,"Sir,"],[5730,5880,"could I see that invitation?"]],"38":[[417,521,"These exclusive"],[521,692,"platinum access invitations"],[692,800,"have a special counterfeiting"],[800,888,"technology."],[905,1105,"So if we find out it's fake,"],[1134,1209,"you're dead."],[1242,1393,"How are you so sure mine are fake?"],[1426,1484,"Please."],[1501,1643,"Since the lodge has been founded,"],[1643,1797,"only two of these invitations"],[1797,1906,"have ever been created,"],[1906,2081,"and the last one was"],[2081,2239,"for the President of the United States."],[2268,2356,"And I'm pretty sure you're not"],[2356,2494,"on the same level as the President of"],[2494,2615,"the United States, are you?"],[2648,2723,"I'm pretty sure that"],[2723,2844,"you're ignorant about this."],[2952,3078,"Don't waste your breath."],[3094,3203,"Let's just break his legs and"],[3203,3311,"throw him out already."],[3365,3449,"Yes, the guests of honor"],[3449,3528,"are about to arrive."],[3549,3728,"We can't let them see such a mess."],[3728,3803,"Get out!"],[3803,3949,"Get out, go away."],[4091,4204,"What are you waiting for?"],[4250,4371,"Kick them out now!"],[4500,4571,"No!"],[4596,4800,"Mr. Ethan and Daddy are the real heroes."],[4808,4938,"You can't kick them out!"],[4954,5150,"Don't get excited just yet, brat."],[5167,5242,"None of you are gonna be"],[5242,5342,"leaving here alive."],[5739,5801,"Wait!"],[6022,6193,"This invitation is real."]],"39":[[412,513,"The invitation is real?"],[513,600,"It's real."],[779,934,"This guy, let me see this guy."],[1080,1126,"Sir."],[1605,1772,"Who gave you this invitation?"],[1856,1960,"That doesn't matter."],[1960,2118,"All that matters is that it's real."],[2281,2373,"And she said,"],[2373,2473,"if it was real,"],[2494,2606,"she would eat it."],[2794,2932,"Oh, I, I..."],[2948,3023,"Sir, sir!"],[3086,3182,"We've established that"],[3182,3336,"the invitation is real."],[3336,3386,"So I'm gonna"],[3386,3511,"let you stay at the event."],[3524,3770,"But you should know your place."],[3770,3841,"Exactly."],[3883,3958,"All you have right now"],[3958,4045,"is permission to stay."],[4696,4804,"Mr. Daniels,"],[4821,4950,"I just heard you say"],[4950,5125,"if anybody has this invitation,"],[5134,5251,"Twin Maples Lodge"],[5251,5397,"will fulfill any request."],[5430,5618,"As a guest with this invitation,"],[5638,5864,"I just want her to fulfill her promise."],[5930,6035,"Why is that so hard?"],[6114,6502,"Or is this very exclusive invitation..."],[6777,6835,"Nothing,"],[7065,7173,"than scrap paper?"],[7970,8066,"Emily,"],[8083,8153,"do it!"]],"40":[[221,433,"But I'm your fiancée, you can't just ask me"],[433,521,"to do something-"],[521,675,"It's a Lodge rule!"],[675,821,"It can't be broken."],[1001,1109,"By anyone!"],[1551,1618,"Eat!"],[3386,3470,"You happy?"],[3641,3774,"Actions have consequences."],[3816,3933,"She's just getting hers."],[4016,4083,"You're right."],[4104,4316,"We all have to pay for our own actions."],[4316,4383,"I just hope"],[4383,4533,"you're ready to pay for yours."],[4717,4900,"Let's get this party started!"],[5459,5651,"Listen, I'm not here today for myself."],[5718,5910,"I'm here to seek justice."],[5910,6151,"And bring glory to a fallen hero."],[6227,6297,"Pierce is the one"],[6297,6414,"who should be standing up here,"],[6448,6610,"celebrating his achievements."],[6623,6752,"Not some scumbag,"],[6773,6977,"who harasses a soldier's family,"],[6977,7140,"and humiliates his wife."]],"41":[[58,187,"Boss, what do we do now?"],[187,271,"I'm not gonna let some"],[271,458,"homeless bastard defeat me."],[467,617,"Let's create a hero of our own."],[679,742,"Okay."],[855,1030,"Well, Don Daniels,"],[1063,1234,"what do you have to say for yourself?"],[1710,1826,"Well, well."],[1872,2027,"If it isn't Sheriff James."],[2139,2373,"Oh, how the mighty has fallen?"],[2448,2681,"I am not the Sheriff anymore."],[2702,2936,"What the hell does Don want with me?"],[2977,3098,"I know what happened, sir."],[3165,3257,"And I know it's all because of"],[3257,3390,"that homeless vagrant,"],[3390,3453,"Ethan."],[3712,3774,"Listen."],[3795,3958,"I have a chance of a lifetime for you."],[3991,4083,"I have a chance for you"],[4083,4216,"to become a hero again."],[4291,4396,"Take revenge!"],[4587,4909,"And so he shall rise again."],[5317,5447,"I would do anything to"],[5447,5568,"get rid of that bastard!"],[5743,5889,"Ethan, you say you and"],[5914,6160,"Pierce are the real American heroes?"],[6185,6306,"So where's your proof?"],[7136,7290,"I have Pierce's ashes,"],[7332,7461,"and his Medal of Honor."],[7536,7649,"That's proof enough."],[7724,7820,"Oh, is that so?"],[7878,7999,"Well, our hero..."],[8049,8187,"just arrived too."],[8541,8662,"Ladies and gentlemen,"],[8729,8871,"tonight's guest of honor,"],[8892,9129,"the real hero, James Jones."]],"42":[[0,141,"Please give a warm welcome"],[141,358,"for my hero, James Jones!"],[400,571,"He's dedicated his life"],[596,792,"to serving this country!"],[1192,1288,"I'm sorry,"],[1288,1430,"James Jones?"],[1451,1564,"Didn't you get fired?"],[1626,1789,"And weren't you a sheriff?"],[1960,2143,"That was part of an undercover mission"],[2143,2264,"to hide my identity."],[2285,2502,"So I could expose his lies."],[2594,2686,"I knew it."],[2686,2827,"How could a homeless bum"],[2827,2969,"be an American hero?"],[2990,3228,"He probably stole those invitations."],[3228,3349,"Exactly. -Probably."],[3349,3478,"Now that the real American hero"],[3478,3670,"is here, let's see if this homeless man"],[3670,3816,"can keep up the act."],[3828,3908,"Ethan,"],[3908,4058,"what is he doing here?"],[4058,4170,"He's obviously a fraud."],[4275,4325,"Son,"],[4362,4450,"I will never forget"],[4450,4608,"how you humiliated me."],[4642,4704,"And now,"],[4813,4938,"it's your turn."],[5259,5388,"Ladies and gentlemen,"],[5409,5651,"the word hero is a sacred word."],[5668,5784,"Right, yeah."],[5818,5914,"To associate it with a"],[5914,6206,"dirty, lying, cheating, vagrant like him"],[6289,6456,"is an insult to all the real"],[6456,6623,"American heroes."],[6623,6856,"Yeah."],[6986,7086,"Like myself."],[7086,7182,"You're lying."],[7211,7311,"Mr. Ethan and Dad,"],[7311,7453,"they're the real heroes."],[7469,7615,"You're the bad guy."],[7736,7836,"You son of a..."],[7907,7962,"Ow."],[8654,8725,"No, no, don't step"],[8725,8825,"on my daddy's medal."],[9242,9371,"As long as they believe,"],[9413,9726,"I, James Jones, am the real hero."]],"43":[[988,1067,"My God!"],[1372,1501,"Goddamn!"],[1818,1910,"Mr. Ethan,"],[1910,2056,"I saved Daddy's medal."],[2185,2314,"Yeah, that's a good job, kiddo."],[2598,2690,"You've got some nerve."],[2786,2936,"You attack a child,"],[2936,3098,"and dare to call yourself a hero?"],[3132,3253,"You're just a worthless,"],[3253,3336,"homeless bum!"],[3353,3449,"What right do you have"],[3449,3536,"to criticize me?"],[3574,3720,"I'm the real hero here."],[3770,3832,"Oh, yeah?"],[3912,3983,"Prove it."],[5088,5221,"These are my medals."],[5255,5422,"Battle scars that prove I bled"],[5422,5522,"for my country."],[5568,5626,"Oh,"],[5651,5780,"he's a true hero."],[5814,5976,"We can't let the real American hero"],[5976,6072,"get humiliated."],[6101,6222,"Get him off the stage,"],[6222,6272,"throw him out!"],[6272,6377,"Get off the stage!"],[6431,6544,"Get out of here!"],[6577,6652,"What do you have to say"],[6652,6840,"for yourself now, vagrant?"]],"44":[[16,87,"Mommy,"],[100,204,"why does he only have scars"],[204,275,"on his back?"],[337,467,"Daddy had a lot of scars"],[467,546,"on his front."],[667,746,"Oh, yes."],[771,892,"When I covered Iraq,"],[892,1084,"most soldiers had battle scars"],[1084,1159,"on the front."],[1159,1297,"Is he lying to us?"],[1568,1672,"Quiet, quiet!"],[1805,1943,"You're just a deadbeat bum."],[1985,2118,"Never seen the battlefield."],[2168,2339,"You don't have right to criticize me."],[2369,2489,"Cowards like you run screaming"],[2489,2690,"to the hills for a sight of a gun."],[2786,2927,"You think I've never seen battle?"],[3057,3157,"You sure about that?"],[4746,4871,"Hostage rescue,"],[4917,5042,"in the Afghan border."],[5075,5167,"Drug bust,"],[5180,5280,"in South America."],[5347,5430,"Relief mission,"],[5467,5547,"in Ukraine."],[5588,5722,"Oh my God!"],[5726,5839,"He could draw a world map"],[5839,5968,"with all his scars."],[6235,6373,"My scars aren't medals."],[6402,6527,"They were just part of the job."],[6627,6781,"But there was one type of person"],[6781,6931,"who left the battlefield"],[6931,7065,"with only scars on their backs."],[7152,7240,"A deserter!"],[7557,7632,"No, no."],[7632,7741,"That‘s slanderous."],[7749,7932,"Don‘t believe a word he said, he's a-"],[7962,8091,"You're a filthy liar!"],[8137,8279,"A real soldier is always"],[8279,8395,"charging forward,"],[8425,8562,"and would never turn their backs"],[8562,8646,"towards the enemy."],[8687,8804,"And they sure as shit"],[8804,8938,"wouldn't brag about"],[8938,9013,"scars that they got"],[9013,9205,"while abandoning their fellow soldier."]],"45":[[0,66,"Deserter!"],[66,229,"You're a zero, not a hero!"],[229,312,"Don't listen to a word, he's,"],[312,379,"he's a..."],[496,642,"Don't come any closer."],[671,734,"I, I..."],[734,930,"I don't wanna be a hero anymore."],[930,1055,"You're useless."],[1055,1222,"You shouldn't have touched that medal."],[1242,1380,"And you really shouldn't have"],[1380,1539,"messed with Pierce's family."],[1968,2085,"What‘s happening?"],[2131,2256,"Is he crazy?"],[2306,2402,"Mr. Daniels."],[2577,2702,"Mr. Daniels, save me!"],[2752,2869,"You gotta save me."],[2902,2969,"No..."],[3019,3140,"Mr. Daniels, you..."],[3165,3294,"you gotta save me."],[3474,3611,"You're the one that wanted me to"],[3611,3749,"act like a hero!"],[4041,4179,"You explain yourself."],[4191,4316,"Yeah, he should."],[4542,4692,"This man is total fraud."],[4713,4825,"I mean look at him."],[4825,5021,"He impersonates a national hero."],[5071,5251,"Now he's trying to blame me?"],[5313,5422,"How you could"],[5422,5597,"throw me under the bus?"],[5822,5926,"It was him!"],[6031,6135,"He's the one that told me to"],[6135,6264,"impersonate a soldier."],[6264,6306,"No..."],[6306,6481,"All so he can take down Ethan."],[6573,6802,"No, this man is obviously insane."],[6802,6948,"Get him out of here right now!"],[6961,7065,"Hey, no."],[7065,7265,"No, hold..."],[7269,7344,"You all think"],[7344,7499,"he's some philanthropist."],[7511,7645,"He's the evil mastermind"],[7645,7736,"behind it all!"],[7995,8099,"Can you silence him?"],[8099,8166,"Can you do something"],[8166,8208,"about him?"],[8208,8366,"No, you let him finish!"]],"46":[[25,154,"You let him finish!"],[496,579,"Don, you,"],[579,838,"you knew Pierce was a national hero."],[867,1026,"And you went after his widow,"],[1088,1247,"and jacked up her rates."],[1267,1447,"And sent this thug to collect."],[1676,1789,"So what are you waiting for?"],[1789,1868,"Let's... come on."],[1868,1897,"Hey!"],[1926,1972,"Let's go!"],[1972,2010,"Hey!"],[2022,2252,"No, you're a greedy monster!"],[2298,2331,"Everything's"],[2331,2385,"fine. - Only cares"],[2385,2419,"about himself!"],[2419,2506,"It's fine. - about himself!"],[2506,2635,"The bar is still open. - Get off me!"],[2660,2761,"Get off me!"],[2794,2940,"Get off me!"],[3490,3541,"Don,"],[3595,3666,"now would be a good time to"],[3666,3787,"explain yourself."],[3824,3937,"Unbelievable!"],[3953,4091,"So that whole charitable act"],[4091,4170,"is fake?"],[4617,4700,"Paulo,"],[4746,4884,"you better step up."],[5263,5372,"Everyone."],[5380,5455,"Stop!"],[5467,5601,"I'm responsible for it."],[5647,5755,"Mr. Daniels had nothing"],[5755,5830,"to do with this."],[5901,6031,"No, he's lying."],[6068,6243,"Oh, Paulo, Paulo."],[6268,6468,"I'm so greatly disappointed in you."],[6468,6710,"I owe everybody here an apology."],[6740,6873,"This whole mess"],[6873,6994,"wouldn't have happened"],[7007,7161,"if I kept my men in line."]],"47":[[20,187,"Don't apologize, Mr. Daniels."],[212,354,"You're a victim too."],[396,525,"I knew Mr. Daniels wasn't"],[525,596,"that kind of person."],[596,746,"He wouldn't do something like this."],[784,917,"It's all his fault."],[917,1101,"I bet you he teamed up with James"],[1101,1217,"just to frame him."],[1297,1405,"Ladies and gentlemen,"],[1434,1639,"that homeless man stormed into"],[1639,1814,"our sacred event"],[1814,1972,"with a stolen invitation."],[1989,2218,"And now he's trying to frame Don?"],[2285,2360,"Really?"],[2377,2439,"Come on."],[2498,2635,"We must call the police and"],[2635,2827,"have him arrested immediately!"],[2844,2952,"Yes, call the police!"],[2952,3044,"Arrest him!"],[3336,3415,"You know what?"],[3428,3578,"I'll call the police right now,"],[3578,3641,"and we'll find out"],[3641,3807,"who the real criminal is."],[4195,4329,"This is our first big call"],[4329,4487,"since I got promoted to Sheriff."],[4504,4608,"I can‘t believe someone is"],[4608,4721,"desecrating the Hero‘s Memorial"],[4721,4821,"at the Lodge."],[4867,4929,"Let‘s go!"],[5167,5242,"You know,"],[5309,5422,"you're just a worthless,"],[5422,5497,"homeless vagrant."],[5522,5655,"I'm the biggest taxpayer"],[5655,5780,"in all of Twin Maples."],[5780,5980,"Now who do you think the police"],[5980,6093,"are going to believe?"],[6139,6247,"Ethan, let's just leave."],[6277,6402,"We can't beat Don."],[6527,6623,"It's too late."],[6698,6856,"Team one, secure the premises."],[6881,7044,"Team two, follow me for the arrest."],[7069,7198,"Let's see what kind of bastard‘s trying to"],[7198,7328,"ruin tonight's memorial!"]],"48":[[20,137,"Have fun in prison."],[137,308,"Try to stay alive in there."],[308,358,"Who knows?"],[358,521,"Maybe something"],[521,771,"unfortunate is gonna happen to you."],[796,905,"The police are here."],[905,1117,"That homeless liar‘s screwed."],[1155,1201,"Oh,"],[1213,1292,"you must be Helen,"],[1292,1376,"the new Sheriff now."],[1376,1484,"I‘m Don Daniels."],[1484,1651,"And I am so glad to meet you."],[2127,2273,"I hope you like prison food."],[2273,2414,"I hope you like being alone."],[2414,2573,"I hope you like bars."],[2573,2744,"Because you're going away, my friend."],[2865,2982,"Sheriff Helen, this has"],[2982,3165,"nothing to do with Ethan, all right?"],[3165,3249,"This is all because of me-"],[3249,3332,"Marie,"],[3424,3516,"it's okay."],[3695,3866,"It's good to see you again, Helen."],[4208,4375,"Didn't think you'd be the new Sheriff."],[4421,4521,"Does that homeless man"],[4521,4750,"actually know the new Sheriff?"],[4750,4833,"That‘s impossible!"],[4833,4984,"He must be faking it."],[4984,5075,"Officers!"],[5075,5155,"Salute!"]],"49":[[20,166,"Whoa, whoa, whoa!"],[191,283,"What are you doing?"],[300,387,"This is just some"],[387,508,"worthless homeless bum."],[508,671,"Why would the police salute him?"],[721,917,"As officers, we salute out of respect"],[917,1067,"for this American hero."],[1338,1434,"Is that homeless man"],[1434,1589,"really an American hero?"],[1614,1893,"Did we just humiliate a national hero?"],[1943,2168,"Did Victoria already know he's a hero?"],[2206,2373,"No, I mean there's no way."],[2394,2531,"He's just some homeless man."],[2531,2619,"He needs a woman"],[2619,2736,"to buy him a hotel room."],[2756,2890,"There's no way he's a national hero."],[2923,3028,"Sheriff Helen,"],[3044,3203,"I don't care who this man is."],[3203,3499,"I need you to arrest him immediately!"],[3553,3616,"Just now,"],[3674,3812,"this homeless vagrant,"],[3849,3966,"he tried to frame me."],[3966,4112,"Everybody here saw it."],[4112,4270,"The whole crowd saw it."],[4287,4433,"So, are you gonna stand there"],[4433,4521,"and defend..."],[4567,4629,"a criminal?"],[4683,4733,"I-"],[4733,4804,"Hang on."],[4804,4884,"Don't forget,"],[4884,5071,"this whole war memorial"],[5071,5380,"was organized by FBI Director Kent Corbin."],[5401,5530,"You're going to stand there"],[5530,5655,"and defend this vagrant"],[5655,5851,"who's desecrating this whole event?"],[5930,6114,"Or do I need to call Corbin over?"],[6156,6243,"Call Corbin?"],[6297,6460,"I don't think that's gonna be necessary."],[6539,6602,"Corbin,"],[6627,6681,"how long are you gonna hide"],[6681,6740,"back there?"],[6810,6952,"Whoa, whoa, Corbin?"],[7015,7115,"Corbin's already here?"],[7611,7716,"How'd you know I was outside?"],[7824,7962,"Taught you everything you know,"],[8003,8162,"including stealth tactics."]],"50":[[291,333,"I-"],[379,483,"Director Corbin,"],[483,567,"then let me explain."],[567,713,"This is just some homeless guy"],[713,767,"you don't want-"],[909,1080,"Oh my God!"],[1146,1343,"This homeless man"],[1343,1501,"is an American hero."],[1522,1639,"I was listening"],[1651,1789,"from the very start."],[1818,2035,"Great job in organizing this event,"],[2035,2127,"Mr. Daniels."],[2127,2273,"Director Corbin, let me explain."],[2273,2394,"This is all because of him-"],[2394,2498,"Shut up!"],[2615,2719,"Did you think"],[2765,2923,"you could hide all of your crimes"],[2923,3040,"from the FBI?"],[3144,3244,"Arms dealing,"],[3282,3395,"extortion,"],[3395,3524,"drug trafficking."],[3674,3803,"You're going away"],[3832,3999,"for a long time."],[4033,4129,"Sheriff Helen,"],[4149,4316,"arrest Don Daniels,"],[4329,4529,"and dismantle his gang."],[4558,4625,"Yes, sir!"],[4758,4833,"No!"],[4971,5042,"He's got a gun! - What are you"],[5042,5084,"He's got a gun! - doing?"],[5321,5459,"This is all your fault."],[5459,5613,"This is all because of you."],[5613,5714,"If it weren't for you,"],[5714,5885,"none of this would have happened."],[5922,6047,"Hey, hey, we can still talk-"],[6093,6181,"Victoria!"],[6468,6560,"Let her go!"],[6589,6744,"I will be your hostage instead."],[6765,6890,"If you come any closer"],[6890,7002,"I will blow her brain out."],[7002,7119,"This is all because of you."],[7132,7269,"Do you think you can beat me?"]],"51":[[0,108,"This is all because of you."],[108,262,"Do you think you can beat me?"],[321,404,"If it wasn‘t for you,"],[404,500,"none of this would happen."],[525,684,"I'd still be Twin Maple's"],[684,880,"most beloved philanthropist."],[925,1155,"You ruined everything!"],[1368,1430,"Ow!"],[1897,1943,"It‘s okay."],[1943,2010,"We‘re safe."],[2139,2227,"We are safe now."],[2648,2744,"Don Daniels,"],[2819,3019,"I'm representing the FBI in your case."],[3107,3332,"Expect the harshest sentence possible."],[3424,3611,"No, no, this isn't gonna happen."],[3649,3841,"I told you actions have consequences."],[3887,3949,"What are you-"],[3962,4058,"What are you doing?"],[4079,4275,"Everything is gonna be just fine."],[4275,4325,"All right,"],[4325,4579,"everybody let‘s just go back to our seats."]],"52":[[1730,1856,"Oh, Pierce."],[1918,2077,"I know you wished you could be here"],[2077,2181,"with your boy, but..."],[2431,2519,"We'll watch over him."],[2715,2865,"I'm sure he's raised up right."],[2986,3048,"Daddy,"],[3111,3228,"you're a real hero."],[3290,3382,"When I grow up,"],[3395,3557,"I wanna be just like you."],[3741,3953,"We honor a true American hero."],[4120,4295,"Present, arms!"],[4642,4808,"Detail attention!"],[5050,5163,"Right face."],[5321,5388,"Aim."],[5459,5522,"Fire."],[5651,5718,"Aim."],[5784,5847,"Fire."],[5930,6001,"Halt."],[6081,6143,"Fire."],[6239,6414,"Present, arms!"]]}