{"1":[[471,633,"My name is Penelope Jones,"],[809,959,"but everyone calls me Penny for short."],[1372,1409,"Well,"],[1476,1618,"everyone except for..."],[1685,1768,"him."],[1864,1931,"Mason Brown,"],[2006,2177,"star quarterback of Maple High,"],[2231,2414,"my neighbor, my best friend,"],[2464,2610,"and the boy I've had a crush on"],[2610,2752,"since the third grade."],[2765,2823,"Penelope,"],[2894,2948,"come down."],[3007,3103,"I'm here to rescue you."],[3578,3728,"Mason, where the heck are we going?"],[4008,4083,"Shh,"],[4162,4270,"I don't want to wake your mom up."],[4416,4529,"It was the kind of summer"],[4529,4642,"you'd never forget."],[4708,4833,"Every moment with Mason"],[4833,4954,"made my heart race"],[5050,5213,"and he had no idea."],[5259,5372,"Look at the surprise."],[5409,5459,"Let's go."],[5730,5780,"Okay."],[6243,6393,"Mason, the pool's closed."],[6435,6535,"How did you get the keys?"],[6535,6652,"Courtesy of lifeguard Brett."],[6723,6802,"He owed me a favor."],[6981,7057,"Oh, Penelope."],[7057,7186,"My sweet, sweet Penelope."],[7261,7311,"You gotta stop"],[7311,7394,"worrying about everything"],[7415,7482,"and live a little."],[8562,8625,"What are you waiting for?"],[8625,8662,"Come on."],[8662,8796,"We're not supposed to be in here."],[10573,10698,"Eyes up here, Romeo."],[11365,11448,"Why are you looking at me"],[11448,11503,"like that?"],[11578,11661,"Penelope,"],[11711,11790,"you've been there for me"],[11853,11916,"through everything,"],[11982,12116,"every failed driver's test,"],[12195,12287,"bad hair cuts,"],[12495,12633,"when I lost my mom to cancer."],[12850,12971,"You are the most important person"],[12971,13038,"in my life."],[13175,13300,"I want you in it forever."],[13496,13634,"All summer I've wanted to do this."],[16295,16374,"Mason Brown,"],[16374,16516,"do you have any idea"],[16516,16574,"what you're doing?"],[16574,16704,"It's not my fault they made girls'"],[16704,16833,"clothing so complicated."],[16946,17071,"Who even designed these damn things?"],[18956,19190,"My first time with my best friend,"],[19190,19265,"Mason Brown."],[19352,19469,"The boy I love."],[19823,20161,"It was everything I ever wanted."]],"2":[[183,300,"Never been in the community center"],[300,396,"at night."],[400,546,"A lot of firsts tonight, I guess."],[675,750,"Are you sure you're okay?"],[788,938,"Stop worrying, Mason."],[984,1084,"Just don't be weird"],[1084,1192,"when school starts, okay?"],[1238,1359,"Alright, come on."],[1368,1426,"Hey, wait."],[1584,1622,"What?"],[3257,3486,"Mom, I, I, I just went for-"],[3511,3557,"Honey,"],[3649,3720,"take a seat."],[3757,3803,"There's something"],[3803,3895,"we need to talk about."],[4842,4904,"Hey, Penelope."],[5171,5334,"So, homecoming's coming up."],[5543,5622,"Do you wanna be my girlfriend"],[5622,5689,"and come with me?"],[6940,7094,"No, Mason."],[7236,7303,"I don't wanna go to"],[7303,7394,"homecoming with you,"],[7399,7524,"and I definitely don't wanna"],[7524,7620,"be your girlfriend."],[7620,7728,"Oh my gosh. - My God."],[7749,7836,"What's her problem?"],[7836,7878,"What?"],[7878,7932,"Oh my gosh."],[7932,8016,"She might be off."],[8016,8062,"What?"],[8103,8199,"Oh my God."],[8237,8324,"You're not serious, right?"],[8324,8375,"I thought-"],[8375,8462,"You thought wrong."],[8491,8516,"Look,"],[8516,8683,"let's not confuse sex with love."],[8704,8821,"It was fun for the summer,"],[8892,8979,"but I don't want anything"],[8979,9050,"serious with you."],[9138,9192,"Sorry."],[9317,9442,"Did that dumb bitch seriously"],[9442,9597,"just turn down Mason Brown?"],[9597,9738,"Who does she even think she is?"],[9738,9930,"She's like bottom of the food chain."],[9943,10051,"Mason's the quarterback."],[10064,10105,"Everyone knows"],[10105,10243,"he should be with you, Valerie."],[10873,10969,"I gotta get to class."],[11061,11148,"I'll see you around, okay?"],[11211,11323,"Penelope, is something wrong?"],[11353,11419,"Look, Penelope,"],[11419,11532,"I've known you for twelve years."],[11532,11578,"This isn't you-"],[11578,11695,"Can we please just talk later?"],[11695,11745,"But is something's wrong,"],[11749,11782,"let's talk"],[11782,11845,"about it now. - Mason,"],[11845,11953,"please, just stop!"],[11953,12032,"That night was real."],[12057,12162,"Okay, I didn't imagine it."],[12191,12241,"So why-"],[12241,12433,"You're just bad at sex, okay?"],[12729,12837,"Oh my God! - Oh my God..."],[12837,12954,"Yeah, I mean,"],[13000,13196,"you were terrible in bed."],[13238,13309,"I tried it."],[13396,13471,"Didn't like it."],[13509,13605,"Let's not make it a big deal."],[13684,13772,"We're just friends."],[13855,13893,"Okay?"],[15590,15653,"Penelope,"],[15736,15828,"what are you hiding from me?"],[15828,15865,"Just..."],[15903,16007,"go away!"],[16282,16437,"I'm so sorry, Mason."],[16474,16587,"You don't deserve this,"],[16791,16883,"but I'm dying"],[16883,17012,"from cancer."],[17033,17175,"And I can't be another person"],[17175,17233,"you lose."],[17292,17404,"If I need to push you away"],[17404,17479,"to protect you,"],[17509,17559,"I will."]],"3":[[4,87,"Whatever it takes"],[87,204,"to keep you from any pain,"],[204,321,"just like I promised."],[646,763,"My mommy said your mom's"],[763,867,"in a better place now."],[925,1001,"One where she won't have"],[1001,1080,"to hurt anymore."],[1117,1255,"But she didn't want me anymore."],[1276,1488,"Now I'm all alone and I'm so scared."],[1564,1730,"And it just hurts so bad."],[1789,1893,"Why did you leave me?"],[1931,1985,"Why?"],[1989,2064,"She didn't leave you."],[2143,2335,"She's up there now in the clouds,"],[2352,2435,"watching over you"],[2439,2535,"and keeping you safe."],[2565,2656,"And here on Earth,"],[2673,2769,"I will keep you safe,"],[2790,2840,"so your mommy"],[2840,2936,"doesn't have to worry."],[3003,3182,"I will protect you, Mason,"],[3253,3482,"so you never ever have to hurt again."],[3624,3762,"Don't worry, Mrs. Brown!"],[3782,4095,"I will protect Mason, always, I promise!"],[4421,4592,"Oh honey, you look exhausted."],[4771,4838,"I really just wish"],[4838,4975,"you'd reconsider dropping out"],[4975,5109,"just until your cancer treatments"],[5109,5180,"are finished."],[5205,5326,"Focus on getting better."],[5351,5509,"We already talked about this, Mom."],[5538,5643,"There's no guarantee"],[5643,5747,"the treatment will work."],[5780,5935,"Besides, if I drop out now,"],[5947,6056,"that means giving up"],[6056,6160,"Romeo and Juliet."],[6306,6414,"And I can't do that."],[6431,6664,"Penny, it's just a play."],[6664,6765,"It's not."],[6802,6915,"Mom, this is everything"],[6915,7015,"I've ever dreamed of"],[7015,7140,"since I was a little kid."],[7190,7257,"I just,"],[7340,7520,"I wanna be on stage with Mason,"],[7599,7711,"like when we were kids"],[7711,7882,"and forget that I have cancer,"],[7928,8041,"forget that I'm dying."],[8095,8241,"If he gets a part of Romeo"],[8241,8366,"and I get Juliet,"],[8433,8541,"I'll be able to hold on"],[8541,8779,"to one perfect moment"],[8779,8863,"before I'm..."],[9009,9067,"gone."],[9075,9250,"Okay, alright, you can do the play."],[9409,9505,"Alright, but you have to take care"],[9505,9572,"of your health."],[10043,10168,"The minute you get into"],[10168,10276,"any kind of trouble,"],[10276,10389,"I am pulling you out."],[10389,10523,"That's no more school,"],[10543,10677,"no Romeo and Juliet."],[10819,10865,"Okay."],[10919,11019,"Have you told Mason"],[11027,11111,"about the cancer?"],[11390,11503,"Penelope, you home?"],[11649,11707,"Oh my God,"],[11753,11811,"it's Mason."],[11820,11870,"Mom!"],[11911,12020,"Please tell him I'm not here."],[12062,12128,"And whatever you do,"],[12128,12316,"do not tell him about the cancer."],[12374,12424,"Please."],[12462,12591,"I think you should tell him the truth."],[12666,12779,"He'll understand. - Mom,"],[12779,12896,"just do this for me."],[12929,13108,"His mom died of cancer, remember?"],[13142,13234,"If he finds out,"],[13254,13396,"it'll only break him even more."],[13434,13542,"Why put him through that?"],[14109,14226,"Oh, hey, Mrs. J."],[14285,14360,"Is Penelope home?"],[14497,14556,"Um,"],[14643,14731,"she's..."],[14848,14985,"she's not home right now."],[14998,15152,"She's out with some friends."],[15219,15323,"You wanna come back later?"],[15461,15502,"Okay."],[15578,15657,"Thanks, Mrs. J."],[16462,16533,"Oh Mason,"],[16587,16658,"I may not know"],[16658,16800,"how much time I have left,"],[16833,16954,"but I do know this."],[16987,17137,"I want my last words for you"],[17137,17250,"to be honest,"],[17317,17367,"real."],[20453,20724,"Mason, did you just climb my balcony?"],[20787,20870,"Are you insane?"],[20870,20983,"What if you slipped and fell"],[20983,21158,"and broke your neck or something?"],[21308,21408,"Penelope, what was that in your hand?"],[21654,21709,"What are you hiding?"]],"4":[[87,129,"Um."],[250,342,"Hiding something?"],[371,442,"Please, Mason,"],[442,546,"I was just rehearsing"],[558,621,"for the play."],[930,1101,"So what are you doing here?"],[1101,1180,"I wanted to talk."],[1251,1330,"I know you got your mom"],[1330,1418,"to cover for you,"],[1447,1509,"who by the way"],[1509,1622,"has always sucked at lying."],[1689,1772,"Now you're avoiding me?"],[1805,1889,"I wasn't home."],[1889,1972,"Since when did best friends"],[1972,2035,"lie to each other?"],[2089,2206,"First, you embarrassed me"],[2206,2310,"in front of the whole school."],[2356,2423,"And now you can't even"],[2423,2477,"be honest with me?"],[2665,2711,"Please."],[2923,3082,"Mason, I already told you, I,"],[3148,3290,"I just don't like you like that."],[3311,3386,"We're just friends,"],[3386,3532,"that's all we'll ever be."],[3557,3666,"That night was just"],[3749,3799,"for fun."],[4070,4179,"I want the truth, Penelope."],[4366,4412,"Fine."],[4466,4550,"You want the truth?"],[4642,4717,"It's because"],[4917,5013,"I'm in love with Dean."],[5034,5117,"He's the one I want."],[5117,5176,"Bullshit!"],[5263,5334,"You don't love Dean."],[5334,5434,"You barely even talk to him."],[5434,5534,"I didn't say it earlier"],[5534,5609,"because I didn't think"],[5609,5714,"I had to spell it out."],[5726,5901,"He's hot and he's smart,"],[5935,6110,"and, he understands me"],[6110,6227,"in a way you could never."],[6272,6410,"Oh, give me a break, Penelope."],[6410,6552,"Look, I know you the best."],[6560,6677,"Dean's the biggest dick in school."],[6710,6840,"He's just gonna find a way to fuck you,"],[6844,6894,"and then drop you"],[6894,6973,"like he does with every girl."],[6973,7090,"You're one to talk?"],[7119,7215,"At least he's not someone"],[7215,7369,"who can't take no for an answer."],[7403,7574,"Hey, it's not romantic, Mason,"],[7574,7682,"it's desperate."],[7691,7820,"Why can't you just accept the fact"],[7820,7962,"that I will never love you?"],[7987,8062,"It's pathetic."],[8062,8116,"You're being..."],[8350,8408,"pathetic."],[8671,8721,"You're right."],[8883,8975,"I'm being pathetic."],[9313,9388,"You know what, Penelope?"],[9526,9597,"I'm tired."],[9634,9864,"I'm tired of your games, your lies,"],[9964,10026,"and you."],[10101,10168,"From now on,"],[10256,10326,"you're dead to me."]],"5":[[162,392,"I'm tired of your games, your lies,"],[429,483,"and you."],[542,608,"From now on,"],[696,767,"you're dead to me."],[779,963,"Maybe it's better if Mason hates me."],[1017,1117,"It won't hurt him so much"],[1117,1255,"when this cancer wins and I..."],[1347,1388,"die."],[1413,1476,"Oh my God."],[1530,1685,"The cast list for Romeo and Juliet"],[1685,1730,"is up."],[3003,3148,"So what if it's pretend?"],[3186,3340,"At least I'll get to be with Mason,"],[3374,3536,"even if it's just for a little while."],[3574,3687,"Star-crossed lovers,"],[3720,3841,"just like when we were kids."],[3870,4133,"Romeo, wherefore art thou, Romeo?"],[4258,4295,"Oh!"],[5455,5559,"I'm not playing Romeo."],[5618,5709,"Not if you're Juliet."],[5776,5922,"I'm telling Mr. Felix I quit."],[6277,6360,"Mason, please."],[6481,6610,"Romeo's important to you too."],[6656,6715,"Remember?"],[6760,6865,"Can't we just be civil?"],[6881,7048,"No, Penelope, we can't."],[7073,7169,"You used to go on and on"],[7169,7273,"about how Juliet was someone"],[7273,7424,"who was kind and who's sweet,"],[7440,7553,"and who'd risk it all for love."],[7561,7640,"You're none of that."],[7778,7899,"You don't deserve to play Juliet."],[7937,8033,"Mason, please!"],[8133,8199,"Like I said,"],[8274,8337,"you're dead to me."]],"6":[[158,304,"Don't be delusional, Penny."],[325,433,"You did this to yourself."],[483,633,"But if Mason won't play Romeo,"],[658,738,"what's the point of me"],[738,846,"staying here any longer?"],[909,1105,"Mason, being in this play with you,"],[1172,1284,"it's my last wish."],[1743,1830,"Come on, Mason."],[1876,1968,"She said it herself."],[1968,2056,"She doesn't want you."],[2122,2181,"Forget her."],[3082,3249,"Pathetic Penny is Juliet?"],[3265,3403,"You have got to be kidding me."],[3445,3574,"Talk about a pity casting."],[3787,3883,"Everyone knows"],[3883,4033,"that I'm the best actress,"],[4054,4175,"and I'm the cheer captain."],[4183,4320,"So I'm the one who belongs up there"],[4320,4421,"with Mason Brown"],[4429,4567,"while you belong in the back"],[4579,4671,"with the furniture!"],[4671,4800,"Leave me alone, Valerie."],[4875,5017,"I don't have time for your pettiness."],[5021,5134,"Me, petty?"],[5234,5317,"I'll show you petty."]],"7":[[437,579,"Enjoy your fifteen minutes of fame,"],[579,625,"freak."],[996,1051,"Freak. - Freak."],[1463,1576,"Aw, Val."],[1622,1735,"She looks upset."],[1789,1922,"Maybe we should fix her up."],[1939,2093,"Great idea."],[2118,2239,"You know, Penny,"],[2239,2364,"if you're gonna be the lead"],[2364,2464,"in the school play,"],[2481,2623,"then you've really got to do something"],[2623,2731,"about this hair."],[2756,2911,"I might be dying of cancer,"],[2948,3086,"but I'm done letting Valerie"],[3086,3174,"walk all over me."],[3178,3303,"No matter what you do,"],[3332,3566,"I earned the lead role in the play."],[3611,3732,"While on the other hand, Val,"],[3757,3862,"you're just a pick-me"],[3862,4108,"who in the end will never get picked."],[4179,4346,"What the fuck did you just say to me?"],[4612,4696,"My hair!"],[4729,4792,"From the chemo."],[4800,4979,"OMG, gross!"],[4979,5146,"Ew, is she shedding?"],[5155,5305,"As if you weren't disgusting enough,"],[5305,5359,"you freak!"],[5359,5480,"And you have the audacity"],[5480,5597,"to even look at me?"],[6122,6385,"Let's see what dirty secrets you're hiding."],[6385,6664,"No! My medical report is in there."],[7494,7553,"No, no, no!"],[7574,7636,"My hair!"],[7699,7803,"Mason can't see this."]],"8":[[141,262,"Get your fucking hands off of her."],[1551,1676,"What the fuck is your problem, Valerie?"],[1718,1835,"Relax, Mason."],[1868,2093,"I was just trying to sweetly explain"],[2093,2210,"to Penny here"],[2218,2414,"that you and I belong together."],[2427,2540,"Isn't that right, girls?"],[2815,2886,"Nice try, Val."],[2936,2994,"I almost forgot"],[2994,3082,"you're a complete bitch."],[3140,3253,"If you think tormenting Penelope"],[3253,3370,"is gonna make me like you,"],[3407,3470,"you're wrong."],[3511,3570,"Grow up!"],[3628,3678,"But, Mason."]],"9":[[108,158,"Thank you,"],[225,325,"for saving me back there."],[371,442,"I didn't save you"],[442,546,"because I still like you"],[546,696,"or, care or whatever."],[709,788,"I just did what anyone"],[788,892,"would've done, so,"],[950,1034,"don't read into it, alright?"],[1084,1138,"You know, the truth is,"],[1138,1184,"I don't even know"],[1184,1292,"why I bothered saving you"],[1292,1330,"after the way"],[1330,1426,"you gutted me yesterday."],[1518,1580,"What'd you call me?"],[1580,1626,"Pathetic?"],[1785,1889,"Mason, stop."],[1997,2047,"Please."],[2335,2481,"I'm just trying to stay friends."],[2481,2560,"Oh, don't do that!"],[2598,2669,"Don't throw friends at me"],[2669,2765,"like that fixes anything."],[2777,2865,"I'm not some backup toy"],[2865,2948,"you can pull off the shelf"],[2948,3044,"whenever you're bored, alright?"],[3078,3186,"You hurt me, Penelope."],[3240,3361,"I poured out my heart to you,"],[3395,3453,"and you broke it."],[3453,3524,"You stomped on it"],[3524,3607,"in front of the entire school."],[3607,3691,"You think we can stay friends"],[3691,3737,"after that?"],[3841,3933,"No, I don't wanna be friends"],[3933,3987,"with someone who-"],[4041,4083,"But-"],[4120,4241,"Hey, Penelope!"],[4404,4454,"Penelope!"]],"10":[[671,813,"Where, where am I?"],[1001,1063,"Where's Mason?"],[1101,1209,"I sent him back to class."],[1242,1401,"Penny, I just got off the phone"],[1401,1459,"with your mom."],[1488,1639,"I gotta say, I'm really surprised"],[1639,1730,"you're still in school."],[1797,1851,"You know?"],[2164,2277,"Oh my God, did you tell Mason?"],[2293,2410,"No, of course not."],[2477,2610,"I'm not gonna tell another student"],[2610,2711,"your medical history."],[2798,3044,"But that boy was worried sick."],[3073,3153,"He was crying."],[3211,3332,"He wouldn't leave your side."],[3486,3557,"Class is out."],[3632,3770,"I'm sure he'll be back any moment."],[3820,3866,"Okay."],[4037,4091,"Penelope."],[4191,4262,"No, Penny."],[4316,4408,"You already lost him."],[4433,4496,"Act like it."],[4537,4608,"Are you okay?"],[4671,4729,"That was so scary."],[4729,4838,"I've never seen you pass out before."],[4838,4884,"What happened?"],[4950,5084,"It's a recent thing."],[5155,5372,"It's just low blood sugar."],[5492,5597,"Just because I play football"],[5597,5689,"doesn't mean I'm dumb."],[5764,5830,"Low blood sugar"],[5830,5960,"doesn't cause nosebleeds."],[6131,6218,"Be honest, Penelope."],[6389,6448,"Are you sick?"]],"11":[[91,258,"My God, Mason, no."],[371,579,"I just got stressed about the situation."],[721,796,"Can we just let it go?"],[934,1001,"Just, I was worried."],[1051,1092,"You know,"],[1155,1247,"when my mom was sick,"],[1247,1422,"she had nosebleeds"],[1430,1501,"and was fainting."],[1614,1668,"I..."],[1751,1910,"I just can't imagine if I lost you, too."],[2014,2127,"I needed to make sure you're okay."],[2235,2323,"But, uh, anyway,"],[2452,2556,"I came here for a truce."],[2623,2686,"A truce?"],[2923,2969,"Does this mean"],[2969,3061,"you'll still play Romeo?"],[3182,3294,"Penelope, you're my best friend."],[3399,3507,"And maybe kind of a shitty one"],[3507,3611,"the past couple days,"],[3611,3757,"but I'm willing to get past that."],[3803,3862,"Okay."],[3949,4112,"So yeah, I'll play Romeo."],[4208,4270,"Yes."],[4325,4383,"Mason."],[4637,4683,"Whatever"],[4796,4875,"you're not telling me,"],[4929,5096,"whatever you're going through,"],[5125,5188,"it's whatever."],[5255,5330,"I just wanna go back"],[5330,5434,"to being best friends again."],[5722,5759,"Okay."],[5939,5985,"Truce."],[6777,6815,"Um,"],[6852,6965,"a few ground rules, though."],[7007,7044,"Okay?"],[7111,7269,"One, no flirting,"],[7353,7486,"even if it's a joke."],[7645,7853,"Two, if it ever does get too hard"],[7853,7970,"for us to just be friends,"],[8045,8112,"please let me know."],[8254,8337,"And three,"],[8470,8521,"Mason,"],[8641,8687,"don't..."],[8821,8917,"fall in love with me."],[9100,9309,"Because I'm going to die."],[9672,9755,"Alright, alright."],[9763,9843,"If that's what it takes"],[9843,9901,"for us to go back"],[9901,10001,"to being best friends,"],[10051,10118,"consider it done."],[10627,10714,"You win, Penelope."],[10789,10881,"You always win."],[11015,11131,"I may not know what's wrong,"],[11182,11327,"but I can't let you go through it alone."],[11419,11561,"I'm gonna find out what you're hiding."]],"12":[[79,179,"Attention, class."],[262,425,"Please partner up."],[1501,1609,"Mr. Felix,"],[1668,1839,"uh, it looks like the mutt of the class"],[1839,1951,"got left behind again."],[2277,2356,"Well, does no one wish"],[2356,2498,"to partner with Miss Jones?"],[2857,3032,"I suppose I will step in."],[3207,3390,"Mr. Felix as my partner?"],[3415,3611,"I'd rather choke on my own spit."],[3953,4083,"Look at you, Penny."],[4108,4262,"You got the teacher as your partner now."],[4304,4379,"What's next?"],[4433,4571,"Lunch duty with the janitor?"],[4746,4829,"I'm busy, Val."],[4896,5034,"Can I ignore you some other time?"],[5100,5296,"Oh, Penny, you're so touchy."],[5363,5459,"I suppose not everyone"],[5459,5555,"can be like me."],[5580,5718,"I'm just so lucky"],[5718,5851,"that Mason's my partner."],[5897,5993,"Someone has to save him"],[5993,6181,"from being stuck with losers like you."],[6227,6314,"Really, Val?"],[6414,6577,"Because I know Mason,"],[6664,6752,"and I know that"],[6752,6890,"he'd rather eat glass"],[6915,6990,"than be with you."],[7161,7219,"Please,"],[7244,7344,"do you really expect me"],[7344,7407,"to believe that?"],[7457,7595,"Who would he pick over me?"],[7649,7691,"You?"],[7811,7887,"Mason doesn't wanna"],[7887,7953,"be your partner,"],[7953,8053,"you reject."],[8078,8212,"Do you really think"],[8212,8324,"that you wanna drag him"],[8324,8412,"down to your level?"],[8454,8579,"I'm seriously asking."],[8612,8666,"Deep down,"],[8692,8833,"do you think that being with Mason"],[8833,8917,"is good for him?"],[8975,9034,"She's right."],[9063,9142,"No matter what,"],[9184,9271,"being close to me"],[9280,9380,"isn't good for Mason."],[9601,9701,"I wanna be with Penelope."],[10339,10443,"I wanna be with her"],[10523,10639,"as her best friend,"],[10710,10802,"as her partner,"],[10869,11052,"as her everything."],[11152,11156,"If she'll have me."],[11156,11252,"If she'll have me."]],"13":[[0,125,"And Valerie, I've seen you act,"],[129,200,"it needs some work."],[250,304,"Mason!"],[375,521,"You're supposed to be my partner."],[546,825,"Oh, Valerie, no need for tears."],[838,988,"I'll be your partner then."],[1138,1180,"Now,"],[1272,1334,"class,"],[1372,1593,"we all know how important"],[1618,1722,"chemistry is"],[1730,1889,"in Romeo and Juliet,"],[1918,2310,"which is why today's exercise is..."],[2314,2556,"the... waltz, yes."],[2556,2656,"Now, everyone,"],[2711,2806,"face your partner."],[2844,2957,"Yep, there we go."],[3032,3186,"Let go of control."],[3257,3415,"Surrender to the moment"],[3482,3578,"and yourselves."],[4408,4454,"Oh."],[4525,4592,"Sorry."],[4592,4742,"I always knew you had two left feet."],[4779,4825,"Hey."],[4879,5009,"If I'm remembering correctly,"],[5009,5142,"it was you that broke your leg"],[5142,5271,"in Mrs. Toffman's dance class"],[5271,5317,"last year."],[5326,5355,"Okay,"],[5355,5413,"but who was carrying"],[5413,5522,"my books to class every day"],[5522,5618,"when I was on crutches?"],[5776,5847,"That's what I thought."],[5943,6014,"Hey, next year at state,"],[6014,6089,"you think we'll be able to be"],[6089,6177,"in the same dorms?"],[6235,6352,"Can't wait to bug you all the time."],[6435,6560,"Mason, I don't even know"],[6560,6681,"if I'm gonna live long enough"],[6681,6810,"to make it to summer."],[6902,7023,"Oh, look at that!"],[7073,7136,"Everyone,"],[7211,7323,"have a great rest of your day"],[7323,7482,"and don't forget your homework!"],[8208,8266,"Actually, wait."]],"14":[[29,125,"I was thinking, um,"],[241,329,"we should practice,"],[392,563,"try to perfect our performance"],[563,613,"for the play."],[671,759,"At least this way,"],[796,900,"I get to spend time with you."],[1046,1121,"Okay, Romeo."],[1230,1326,"I'll get my script."],[1885,2047,"Ay, pilgrim,"],[2047,2356,"lips that they must use in prayer."],[2811,2840,"Hey."],[2840,2915,"Oh, okay."],[2957,3007,"Sorry."],[3119,3194,"This is serious."],[3269,3311,"Okay?"],[3390,3461,"I need you to lock in."],[4350,4466,"Oh then, dear saint,"],[4629,4763,"let lips do as hands do."],[5242,5321,"So move not"],[5438,5580,"while my prayer's effect I take."],[5805,5893,"To smooth that"],[6006,6072,"rough touch..."],[6548,6598,"with a kiss."],[6648,6694,"Mason,"],[6694,6931,"you're everything I've ever wanted."],[7749,7828,"Sorry, I,"],[7866,7999,"I got caught up in the scene."],[8053,8103,"It's okay."],[8224,8270,"It's nothing,"],[8270,8429,"it's just, this is just rehearsal."],[8550,8704,"If that's all you want it to be."],[8971,9100,"Is that all you want it to be?"],[9146,9305,"Mason, we already talked about this."],[9355,9438,"Please don't make it harder"],[9438,9505,"than it has to be."],[9617,9751,"I'm going to die, Mason."],[9818,9893,"My cancer."],[9955,10118,"I just don't wanna hurt you even more."],[10206,10352,"I can't, please."],[10464,10527,"Can we just-"]],"15":[[0,79,"Dean, what are you doing here?"],[129,171,"Hey, man."],[196,329,"I just came to say hi to Penny,"],[329,367,"alright?"],[392,542,"No need to get your panties in a twist."],[604,646,"Hi, Penny."],[742,788,"Hi, Dean."],[855,925,"Well, you've seen her,"],[980,1096,"so you can leave now."],[1121,1247,"You know, you're acting awful hard"],[1247,1384,"for someone who just got curved."],[1405,1530,"Penny couldn't be more obvious, man."],[1572,1659,"She doesn't wanna kiss you."],[1705,1776,"She doesn't want you."],[1826,1918,"I think I know Penelope"],[1918,2043,"a hell of a lot better than you do."],[2122,2189,"Why don't you tell him?"],[2310,2452,"I wanna tell Mason the truth,"],[2498,2565,"but I can't."],[2627,2748,"If Mason knows how I feel"],[2748,2877,"and he finds out that I'm sick,"],[2915,3028,"it'll only hurt him more."],[3165,3215,"Dean's right."],[3315,3432,"I don't wanna kiss you,"],[3516,3632,"and I do not want you."],[3674,3753,"I never will."],[3799,3958,"We're just friends, Mason."],[3987,4104,"Please respect that."],[4275,4346,"Are you serious?"],[4462,4596,"Bro, she doesn't want you."],[4633,4733,"What don't you understand?"],[4833,4888,"Penny, um,"],[4921,5030,"if you ever do need"],[5030,5167,"a shoulder to cry on,"],[5230,5338,"my room's always open."],[6072,6126,"Penelope."]],"16":[[25,104,"Penelope, please."],[287,437,"I told you not to follow me."],[717,855,"Hey, get the fuck off of me, man."],[855,950,"Can't you just put your ego"],[950,1042,"aside for a second?"],[1076,1176,"You've hurt her enough, man."],[1789,1914,"I'm so sorry, Mason."],[2377,2656,"So I just got this new red bikini,"],[2686,2752,"and it looks-"],[2790,2890,"There she goes,"],[2952,3065,"laughing again,"],[3107,3232,"and looking so beautiful."],[3307,3403,"What could that prick have said"],[3403,3486,"that's so funny?"],[3503,3566,"My parents are gonna be"],[3566,3611,"out of town."],[3666,3728,"We're having a party."],[3762,3916,"Of course, Valerie's all over him."],[3987,4124,"And he's actually listening?"],[4291,4316,"Hey,"],[4354,4412,"I was saying,"],[4454,4529,"my parents are gonna be"],[4529,4583,"out of town."],[4625,4700,"We're having a party."],[4738,4800,"You should come."],[4913,4954,"Oh,"],[5042,5105,"a party."]],"17":[[33,83,"Party, huh?"],[200,333,"Yeah, it's not really Penelope's scene."],[433,475,"Um,"],[517,667,"he doesn't speak for me."],[750,800,"It sounds fun."],[896,950,"I'll be there."],[1005,1042,"Yeah."],[1088,1130,"See, man."],[1201,1280,"She says she'll be there."],[1622,1659,"Hey."],[1864,1981,"I told you Dean's an asshole."],[2039,2093,"Why are you still hanging out"],[2093,2127,"with him?"],[2147,2364,"Oh, so you can get all cozied up"],[2364,2419,"to Valerie,"],[2419,2552,"but I can't even talk to the guy"],[2552,2635,"that I like?"],[2677,2731,"You like him?"],[2865,2977,"It doesn't matter, Mason."],[3036,3115,"This is too much."],[3186,3282,"We're just friends."],[3345,3440,"It's all we ever will be."],[3862,3987,"You can shut me out all you want,"],[3987,4041,"Penelope,"],[4079,4204,"but I'm not giving up on you."],[5342,5455,"Everything's changing."],[5505,5663,"I wonder if I'll ever feel"],[5663,5734,"beautiful again."],[5880,5993,"If I'll even live long enough"],[5993,6081,"to find out."],[6410,6619,"Mason would know exactly what to say."],[6706,6915,"He'd look at me like nothing's changed."],[7127,7307,"Should I just tell him the truth?"]],"18":[[1330,1418,"How does she manage"],[1418,1514,"to get more beautiful"],[1514,1614,"every time I see her?"],[2460,2519,"You look..."],[2673,2727,"Wow."],[2886,2932,"Um,"],[3073,3128,"thanks."],[3278,3449,"Pathetic Penny just won't stay"],[3449,3516,"in her lane."],[3591,3657,"I need to make sure"],[3657,3778,"she stays away from Mason."],[3853,3983,"Listen, Penelope,"],[4008,4104,"can we talk about earlier?"],[4245,4387,"Let's go get another drink, Mason."],[4462,4567,"I'm getting thirsty."],[4621,4704,"I was starting to think"],[4704,4796,"you weren't gonna show up."]],"19":[[16,95,"Let me tell you,"],[175,346,"it was definitely worth the wait."],[412,446,"Wow."],[917,1063,"Well, thanks for inviting me."],[1063,1238,"It's a really cool party."],[1430,1543,"Party's just getting started."],[1584,1672,"Would you like a tour?"],[1714,1818,"No, man, she's good."],[1910,2039,"I thought Penny speaks for herself."],[2102,2202,"Isn't that right, Penny?"],[2481,2569,"She deserves better"],[2569,2652,"than this side of me."],[2794,2857,"Just because we're about"],[2857,2944,"to play spin the bottle, man."],[3165,3215,"After you."],[3532,3699,"Oh!"],[3699,3787,"Yeah!"],[4412,4650,"Oh!"],[5551,5814,"Ooh!"]],"20":[[0,120,"Kiss, kiss, kiss!"],[120,216,"Come on, everybody,"],[216,371,"can't you see that she's shy?"],[404,500,"If you want some privacy,"],[500,588,"there's a room up there."],[646,704,"Um."],[842,967,"What if we played"],[967,1101,"a different game, guys?"],[1142,1343,"Truth or dare or something?"],[1368,1655,"Okay, then I dare you to kiss Dean."],[1755,1876,"Back off, Valerie, okay?"],[1889,2043,"No, rules are rules."],[2089,2189,"She doesn't get a free pass"],[2189,2302,"just because she's a chicken."],[2348,2506,"Come on, Penny, it's just a kiss."],[2531,2619,"Unless you want more."],[2702,2890,"Come on, just do it! - Just do it!"],[2902,3078,"Come on, just do it!"],[3078,3190,"Woo! - Come on, just do it!"],[3219,3311,"Just do it!"],[3311,3374,"Come on!"],[3374,3432,"Do it!"],[3445,3591,"Just do it! - Come on, just do it!"],[3649,3732,"Do it!"],[3732,3795,"Do it!"],[3795,3858,"Woo!"],[3878,4020,"Come on!"],[4154,4312,"Don't be such a cockblock, Mason."],[4362,4466,"They clearly are just trying"],[4466,4521,"to have fun."],[4537,4637,"This is what she wants."],[5313,5534,"This is for your own good, Mason."]],"21":[[362,467,"Oh, um, we,"],[487,621,"we don't have to close the door."],[658,763,"Don't you wanna be alone with me?"],[1705,1747,"Wait."],[1864,1981,"Hey, hey relax."],[2002,2068,"Let me help you."],[2748,2798,"Wait."],[2840,2965,"I don't mind if it gets a little messy."],[3253,3299,"Dean."],[3328,3411,"Just relax."],[3457,3561,"I'm gonna make you feel better."],[3795,3849,"Calm down."],[3920,3962,"Hey."],[4362,4462,"I'm gonna let that slide"],[4462,4537,"because I'm a nice guy."],[4688,4771,"Hey, where are you going?"],[4771,4875,"You're the one that wanted this."],[4929,5034,"You can't just get up and leave."],[5034,5184,"Someone, anyone, help me!"],[5267,5342,"Something's not right."],[5563,5668,"Stop, Dean."],[5709,5839,"Please, stop!"],[5839,6010,"I don't feel good."],[6010,6114,"I'm gonna fix that."],[6114,6256,"I'm just trying to be a nice guy."],[6656,6710,"Ah!"],[6794,6848,"I knew it."]],"22":[[283,375,"I'm coming, Penelope."],[412,471,"Just hold on!"],[767,817,"Mason?"],[1251,1313,"Mason."],[1347,1418,"Hey, what the fuck?"],[1418,1505,"You'll get your turn!"],[1526,1639,"Don't fucking touch her."],[1735,1876,"Hey, she hit me first!"],[1889,2043,"I always knew you were a piece of shit."],[2369,2427,"Hey, what the fuck?"],[2427,2552,"She was flirting with me, I swear."],[2573,2715,"You're doing this all over some slut?"],[2840,2969,"Say that again, I dare you."],[3299,3378,"Underage drinking,"],[3461,3536,"attempted rape."],[3620,3724,"Good luck getting into college now,"],[3724,3803,"you sick fuck."],[3803,3953,"No, please, you'll ruin my life!"],[3953,3999,"You didn't care"],[3999,4049,"when she was screaming"],[4049,4108,"for you to stop."],[4154,4212,"So why should I care"],[4212,4287,"what happens to you?"],[4404,4471,"You so much as look"],[4471,4567,"at Penelope again,"],[4608,4683,"then you're really gonna see"],[4683,4771,"how far I can go."],[5422,5480,"I got you."]],"23":[[321,400,"You're still bleeding."],[671,725,"Does it hurt?"],[1176,1226,"It's fine."],[1305,1355,"I'm fine."],[1463,1597,"These stupid nosebleeds"],[1597,1664,"from the chemo."],[1718,1780,"Here, let me see."],[2656,2798,"You've always had the prettiest eyes."],[3003,3078,"Please."],[3153,3211,"In sixth grade,"],[3211,3294,"you told everyone"],[3294,3432,"I had poop-colored eyes"],[3432,3516,"because you couldn't stop"],[3516,3607,"staring at me."],[3653,3745,"Yeah, well I lied."],[4333,4487,"You've always been beautiful, Penelope."],[4596,4650,"Always."],[4775,4913,"Ever since I can remember,"],[4975,5100,"Mason has been there for me."],[5163,5292,"How can I keep lying to him?"],[5472,5509,"Um,"],[5764,5793,"Mason,"],[5793,5980,"I have something I have to tell you."],[6110,6156,"What is it?"]],"24":[[33,150,"Oh shit, the cops."],[258,333,"What do we do?"],[421,483,"I think I know what to do."],[483,521,"Follow me."],[521,558,"Okay."],[813,942,"Kids, let's get a move on."],[2527,2656,"Can't believe I almost told Mason"],[2656,2740,"about my cancer."],[2831,3032,"God, Penny, don't be so weak."],[3115,3199,"You can't tell him."],[3269,3345,"You know this."],[3528,3616,"You are so lucky"],[3616,3782,"that your dad's chief of police, Mason."],[3849,3953,"But you are seriously"],[3995,4137,"in deep trouble."],[4191,4300,"Dad, it wasn't our fault."],[4350,4433,"I don't wanna bail you guys"],[4433,4546,"out anymore, okay?"],[4587,4800,"Good behavior for the rest"],[4800,4954,"of the semester, okay?"],[5117,5192,"It won't happen again,"],[5255,5317,"Mr. Brown."]],"25":[[846,942,"So what's the arrangement"],[942,1021,"looking like tonight?"],[1051,1326,"I sleep on the sofa, floor, bathtub?"],[1501,1676,"You can sleep here if you want."],[1780,1868,"Do you want me to?"],[2256,2360,"It's better than the couch."],[2619,2669,"Yeah."],[3561,3687,"Thanks for staying over tonight."],[3782,3878,"I really appreciate it."],[4008,4087,"Of course."],[4279,4341,"Just wanted to make sure"],[4341,4387,"you're safe."],[4550,4600,"Penelope,"],[4658,4771,"you're the most important person"],[4771,4829,"in my life."],[4996,5088,"I just want you to know,"],[5146,5271,"I'll always be there for you."],[5680,5764,"Good night, Mason."],[5935,6018,"Good night, Penelope."],[7357,7486,"I'm sorry I couldn't tell you"],[7486,7615,"the truth tonight, Mason."],[7774,7853,"I have cancer."],[8062,8270,"It's everywhere, and it's not going away."],[8324,8420,"I guess I just"],[8462,8591,"wanted to say it out loud,"],[8633,8746,"even if you're not listening."],[9092,9180,"I love you, Mason."],[9409,9501,"It's always been you."]],"26":[[671,725,"God."],[888,1038,"How many more chemo sessions"],[1038,1151,"am I gonna have to go through?"],[1522,1643,"I've always loved my hair."],[2173,2331,"Mason always loved my hair."],[3340,3411,"Who am I kidding?"],[3616,3712,"It's just one more thing"],[3712,3824,"I have to let go of."]],"27":[[5138,5234,"You're stronger than you know,"],[5234,5276,"Penny."],[5347,5413,"No more fear."],[5451,5522,"You got this."]],"28":[[734,917,"I can't keep overexerting myself"],[917,1055,"before the Autumn Showcase,"],[1109,1230,"or else I might not..."],[1301,1422,"Absolutely not. - Obviously."],[1609,1672,"Is it just me"],[1672,1830,"or is she being freakier than usual?"],[1864,1989,"She's like totally tweaking."],[2114,2185,"You know, Val,"],[2202,2389,"if something happened to her,"],[2419,2540,"they'd need a new Juliet."],[2648,2786,"What a great idea."],[2994,3086,"Gather round, everyone."],[3169,3336,"Listen, you didn't hear it from me,"],[3336,3428,"but Pathetic Penny"],[3428,3528,"has been talking shit"],[3528,3641,"behind all of your backs."],[3657,3757,"She's saying that the whole team"],[3757,3883,"is a bunch of dumb whores."],[3908,3970,"Really, Val?"],[4008,4149,"Penny's always been nice to us."],[4191,4254,"Excuse me?"],[4316,4454,"Are you calling me a liar?"],[4512,4592,"Without me, do you think"],[4592,4708,"that you would be valuable, you..."],[4992,5205,"Anyways, I am the only one"],[5205,5313,"who sees your self-worth,"],[5313,5401,"alright, ladies?"],[5467,5584,"So I think it's time"],[5647,5797,"for a little revenge."],[6260,6343,"Hey, reject."],[6343,6406,"are you gonna spend"],[6406,6519,"the entire class"],[6519,6660,"being a creepy loner"],[6660,6790,"or are you gonna pull your weight?"],[7123,7203,"We don't tolerate"],[7211,7374,"slacking in this class, Penny."],[7390,7528,"You're gonna have to face a penalty."],[7599,7653,"What are you..."]],"29":[[884,1059,"I'm too weak from my chemo session."],[1451,1547,"Cancer or not,"],[1639,1772,"I'm done letting Valerie"],[1772,1847,"push me around."],[1889,1989,"This ends now."],[2352,2598,"This bottom-feeder just won't give up."],[2648,2761,"Someone's bold."],[2827,2869,"You know,"],[2898,3073,"ever since you got the role of Juliet,"],[3073,3215,"you have been an absolute parasite"],[3215,3353,"to me and to Mason,"],[3357,3536,"so I think it is my civil duty"],[3557,3645,"to bring you down."],[3670,3770,"Isn't that right, girls?"],[3795,3883,"Mhm."],[3916,4116,"It's funny how loud you are"],[4116,4283,"for a girl who's so wrong."],[4371,4450,"Excuse me?"],[4496,4675,"I run this school, loser."],[4717,4788,"That's what happens"],[4788,4859,"when you're at the top"],[4859,4917,"of the food chain."],[4917,5017,"You know everything"],[5017,5125,"that is going on around here."],[5180,5230,"Really?"],[5246,5388,"Because from where I'm standing,"],[5451,5601,"you just look like a little girl"],[5601,5739,"who's begging for attention"],[5793,5918,"and throwing a tantrum"],[5985,6051,"when she doesn't get"],[6051,6164,"the toy she wants."],[6410,6506,"Tell me, girls,"],[6539,6669,"is it possible to lead"],[6669,6781,"the Autumn Showcase"],[6781,6873,"with a broken leg?"]],"30":[[417,508,"Don't be a psycho,"],[558,608,"Valerie."],[688,804,"Are you gonna stop me?"],[1163,1272,"You should have backed out"],[1272,1438,"when I asked you nicely, Penny."],[1989,2060,"What are you doing?"],[2139,2323,"Reminding you of your place."],[2615,2744,"Oh my God."],[2777,2844,"I should have known"],[2844,2923,"that the fake girl"],[2923,3040,"would have fake hair."],[3215,3307,"Oh, Penny,"],[3315,3528,"you continue to impress me."],[3586,3649,"Look, girls,"],[3691,3870,"the star of the Autumn Showcase"],[3870,3995,"is wearing the fakest wig"],[3995,4204,"I have ever seen in my entire life."],[4262,4308,"Is that the one"],[4308,4433,"that you use for your night job?"],[4571,4625,"Stop."],[4717,4800,"It's not what you think."],[4967,5113,"Let's get a closer look, shall we?"],[5292,5467,"What in the hell's going on over here?"]],"31":[[246,304,"Coach!"],[362,421,"Um,"],[421,529,"I was just telling Penny"],[538,650,"that she needs to take her hood down."],[688,825,"It's against the dress code,"],[825,942,"as you know, of course."],[1121,1172,"She's right."],[1263,1317,"Take it off."],[2477,2619,"Alright, ladies, back to practice."],[2811,2961,"Now, where were we?"],[2990,3053,"Oh, right."],[3094,3186,"The hooker wig."],[3407,3461,"Don't touch her!"]],"32":[[246,291,"Mason!"],[462,533,"What are you doing here?"],[546,617,"You okay?"],[1242,1376,"You have got to be kidding me."],[1426,1472,"Her?"],[1509,1589,"Keep pushing, Val."],[1659,1772,"You're seriously gonna choose"],[1772,1872,"this frizzy-haired,"],[1872,1989,"friendless freak over me?"],[2014,2164,"You try so hard to matter, Valerie."],[2214,2335,"Penelope does it without even trying."],[2356,2419,"You all bully her"],[2419,2535,"because she makes you feel small."],[2552,2635,"That's your fault."],[2660,2727,"It's not hers."],[2786,2869,"You're really that pathetic"],[2869,2936,"to make fun of someone"],[2936,3036,"who's only ever been nice to you?"],[3048,3199,"We never wanted to bully Penny."],[3219,3353,"Yeah, Valerie lied to us."],[3357,3428,"She forced us."],[3495,3570,"Shut up!"],[3770,3820,"Mason,"],[3845,3899,"baby,"],[3924,4049,"without me, you are nothing."],[4095,4241,"I make you valuable, okay?"],[4258,4379,"Not her, me."],[4421,4491,"Sound familiar?"],[4571,4662,"Is that what she says to you guys"],[4662,4813,"that you'd be nothing without her?"],[4888,4946,"That's how she gets you"],[4946,5030,"to do her dirty work, huh?"],[5259,5342,"Tired of being used?"],[5659,5705,"Guys."],[5805,5847,"No."],[5947,5993,"Get her."],[6047,6101,"Stop, stop,"],[6101,6202,"stop, stop, stop!"],[6239,6314,"Let's get the fuck out of here."],[6389,6544,"Enjoy it while it lasts, Penny."],[6573,6715,"But Mason's always been mine."],[6735,6902,"And I will remind you both why."],[6927,7182,"In the end, he will always pick me."]],"33":[[437,517,"Why didn't you call me?"],[650,746,"I could've protected you."],[900,1055,"I don't want you to keep protecting me"],[1055,1138,"because I'm weak."],[1217,1276,"I just,"],[1601,1710,"I need to be stronger."],[1780,1897,"You are not weak."],[2072,2156,"You're the opposite."],[2285,2389,"When we were just kids,"],[2402,2494,"you were the one that got me"],[2502,2627,"through the worst parts of my life."],[2665,2815,"My mom's hospital visits,"],[2886,2961,"her funeral,"],[3107,3199,"the nights I couldn't breathe,"],[3199,3345,"crying because I missed her so much."],[3490,3595,"You've always been my rock."],[3757,3891,"You're the strongest person I know."],[4091,4195,"I wish you could see yourself"],[4195,4279,"the way I see you."],[4396,4542,"How did I ever push you away?"],[4600,4763,"I can't keep hurting you like this."],[4792,4884,"I can't keep denying"],[4884,4988,"my feelings for you."],[5088,5192,"I'll let you have some space."],[5209,5363,"I know I can be a lot sometimes,"],[5409,5534,"but, um, come find me later."],[5534,5613,"I gotta tell you something."],[5689,5730,"Wait."]],"34":[[1026,1151,"I'm sorry, I shouldn't have."],[1213,1276,"Come back."],[3103,3174,"Is this okay?"],[4304,4362,"Are you okay?"]],"35":[[196,283,"Did I do something wrong?"],[604,646,"Um."],[742,905,"Rule number three, Mason."],[1034,1151,"Yeah, no falling in love."],[1347,1451,"But screw the rules, right?"],[1726,1810,"Penelope, look at me."],[2102,2152,"Look, I,"],[2348,2452,"I told you."],[2631,2756,"I think we should just be friends."],[2823,2932,"I'm sorry that I did that."],[3040,3115,"Let's just stop."],[3228,3361,"This is real, Penelope."],[3449,3574,"Why won't you acknowledge that?"],[3695,3795,"Okay, I don't wanna"],[3795,3887,"make you uncomfortable."],[4091,4124,"Uh,"],[4229,4287,"what was that thing"],[4287,4416,"you wanted to tell me?"],[4491,4696,"Oh, yeah, uh, I'm moving in."],[4913,5059,"Just temporarily, it'll..."],[5263,5347,"Where'd you get that scar?"],[5747,5851,"You know, my mom had one"],[5851,5922,"in the same spot."],[6210,6297,"You're not sick, right?"],[6606,6769,"Mason, baby, can I come in?"]],"36":[[12,75,"Oh my God."],[216,262,"Mason, I,"],[304,446,"I can't be in the boys' locker room."],[446,546,"My mom will kill me."],[729,846,"The minute you get into"],[846,955,"any kind of trouble,"],[955,1067,"I am pulling you out."],[1067,1201,"That's no more school,"],[1230,1380,"no more Romeo and Juliet."],[1626,1793,"Mason, she'll pull me out of the play."],[1818,1964,"I know you're in there, Mase."],[1981,2089,"I just wanna talk."],[2177,2231,"Please."],[2260,2331,"Alright."],[2364,2431,"Over here."],[4183,4316,"Playing hard to get, are we?"]],"37":[[346,387,"Wow, Val,"],[387,479,"I didn't know you're such a pervert."],[571,671,"I'm trying to take a shower."],[692,775,"I'll talk to you later."],[950,1046,"Well, why don't you let me"],[1046,1109,"join you then?"],[1659,1814,"Jesus, Val, stop it, okay?"],[1843,1926,"You really that desperate?"],[5138,5251,"Is Penny in there with you?"]],"38":[[66,179,"Is Penny in there with you?"],[229,358,"What? Hell no, are you crazy?"],[367,454,"Look, get the hell out of here."],[487,563,"Mason Brown,"],[592,704,"if you don't wanna be with me,"],[704,775,"that's fine."],[800,875,"But like hell"],[875,996,"am I gonna let that nobody"],[996,1105,"have you instead!"],[1951,2114,"Oh, please tell me that's not..."],[2177,2323,"Principal Miller, they're in there."],[2452,2510,"I'll show you."],[2544,2598,"Valerie,"],[2627,2711,"I do not need to see"],[2711,2806,"my student naked."],[3211,3253,"Son,"],[3436,3528,"Valerie here says"],[3528,3636,"you have a girl in there with you."],[3699,3762,"Is that true?"],[3933,3978,"No sir,"],[4037,4124,"Valerie here actually thought"],[4124,4204,"it'd be a good idea to"],[4233,4354,"try to get in the shower with me."],[4592,4746,"Just imagine if I did what she did."],[4808,4888,"I'm trusting you'll handle this"],[4888,4971,"the same way you would've if,"],[5021,5146,"if I was the one crossing that line."],[5184,5342,"Oh..."],[5367,5455,"Well, Valerie,"],[5488,5618,"you're off the cheer team,"],[5618,5709,"that's for sure."],[5955,6060,"And I think some serious"],[6060,6177,"cleanup duty will help you"],[6177,6281,"understand the weight"],[6281,6373,"of your choices."],[6498,6594,"No..."],[6681,6777,"Sorry about that, Mason."],[6831,6915,"I'll make sure Ms. Stein"],[6915,7015,"receives the necessary"],[7015,7107,"punishment."],[7411,7520,"Principal Miller, please no,"],[7520,7595,"she's in there!"]],"39":[[1163,1238,"Can you put me down?"],[1951,2039,"So, um,"],[2202,2364,"about what you were saying earlier."],[2552,2769,"You're moving in with me?"],[2840,3028,"Um, yeah, you know. I hope that's okay."],[3082,3136,"My dad's having"],[3136,3290,"some construction done, so,"],[3315,3411,"I figured it'd be more fun"],[3411,3524,"to stay with you than a,"],[3624,3741,"in a hotel room with him."],[3866,3966,"Um, yeah."],[4029,4074,"Sure."],[4170,4262,"I like having you around."],[4512,4604,"Now let's go dry off."],[4671,4746,"Yeah."],[5409,5526,"I want all of it spotless,"],[5526,5588,"you hear me?"],[5618,5764,"Like I could eat off it."],[6710,6827,"Watch your back, Penny."],[6852,6998,"You've got no idea"],[6998,7115,"how far I'm willing to go"],[7115,7278,"to make your life a living hell."]],"40":[[417,525,"Somebody better tell my dad"],[525,588,"that I'm here"],[608,700,"so you incompetent people"],[700,871,"stop wasting my time!"],[1351,1522,"Um, I'm here for Dr. Stein."],[1568,1630,"He′ll be down there."],[1647,1743,"Okay, thank you. - Yeah."],[1993,2122,"Hey Penny, how are you?"],[2156,2227,"I'm okay - Let's go on in"],[2227,2289,"how are you? - let's talk."],[2344,2410,"You're welcome."],[2477,2510,"Wait,"],[2560,2740,"why is she talking to my dad?"],[2769,2973,"He's literally an oncologist."],[2973,3098,"That can't be right."],[3432,3699,"I... have been losing alot of hair so."],[3824,3937,"I knew it."],[3978,4099,"The freak has cancer."],[4137,4200,"Looks good on you."],[4225,4358,"We're gonna get the hair back"],[4358,4412,"because what we've been"],[4412,4479,"This just got - seeing..."],[4479,4637,"a whole lot more interesting."]],"41":[[162,212,"Alright."],[308,379,"You got this."],[412,454,"Thanks."],[638,709,"You're welcome, Penny."],[709,834,"You have a good rest of your day, okay?"],[1138,1292,"Valerie, what are you doing here?"],[1292,1472,"Dad, I, I came with my friend Penny."],[1505,1630,"She's really sick, isn't she?"],[1739,1839,"Can you tell me exactly"],[1839,1906,"what's going on?"],[1989,2135,"You know that I can't talk"],[2143,2277,"about a patient, Val."],[2523,2848,"But I just need you to be kind to Penny."],[2882,2923,"Okay?"],[2990,3107,"I don't think that she has long."],[4562,4754,"Start counting your days, Penny."],[4796,4854,"I'm gonna get you"],[4854,5009,"even before the cancer does."],[5063,5159,"That role is mine."],[5292,5526,"And Mason is mine."]],"42":[[913,1026,"What happened to studying?"],[1063,1130,"It's hard to study"],[1130,1272,"when you breathe like a leaf blower."],[1568,1651,"Shut it."],[1743,1776,"Hey,"],[1872,1918,"Mason."],[3069,3153,"Penelope, I..."],[3649,3732,"Hey, what's this?"],[3966,4029,"Shit..."],[4095,4241,"Is that my diagnosis paper?"]],"43":[[308,550,"Um, it's called,"],[650,750,"none of your business."],[779,838,"Come on, let me see it."],[838,900,"It looks fun."],[1071,1188,"It's my bucket list."],[1422,1484,"So silly."],[1484,1618,"Why would you have a bucket list?"],[1693,1747,"We're eighteen,"],[1747,1868,"we got long lives ahead of us."],[1939,2102,"Maybe for you, Mason,"],[2160,2235,"but not for me."],[2798,2915,"Alright, look, I'm sorry."],[3132,3165,"I haven't done"],[3165,3303,"a lot of these things either, actually."],[3382,3428,"Maybe we can do"],[3428,3495,"some of them together."]],"44":[[262,421,"I don't think I've felt this happy"],[421,529,"in a long time."],[767,888,"Every second with Mason"],[888,1005,"feels like a dream."],[1226,1347,"One of those perfect dreams"],[1347,1501,"you never wanna wake up from."],[1730,1780,"I just wish"],[1780,1947,"I could stay in this moment forever"],[2031,2127,"That I could..."],[2314,2464,"Be with him forever."],[3490,3645,"I know my time's running out,"],[3712,3832,"but if this is all I get,"],[3878,3949,"Cheers."],[4133,4262,"I'm glad it's with him."],[4954,5025,"Thank you,"],[5084,5171,"for all of this."],[5355,5472,"It means everything to me."],[5588,5722,"Anything for you, Penelope."],[5768,5830,"Always."],[6056,6181,"Hey, we only got two left."],[6398,6481,"Think you can handle it?"],[6639,6748,"I was born for this."],[6969,7086,"I gotta do something real quick,"],[7098,7173,"but meet me back here"],[7173,7269,"before midnight, okay?"],[7315,7357,"I'm going to make sure"],[7357,7494,"you get that wish on a shooting star."]],"45":[[333,392,"I'm gonna do it."],[421,525,"I'm going to finally"],[525,650,"tell Mason how I feel."],[696,746,"And when I see"],[746,855,"that shooting star tonight,"],[905,1013,"I'll wish to beat this cancer,"],[1046,1209,"to live, to be with him,"],[1247,1484,"so we can finally be happy, together."],[2327,2385,"Mom!"],[2619,2681,"Oh, honey."],[2781,2902,"Hey baby, I know."],[2902,3019,"It won't stop-"],[3053,3174,"Oh, I know, honey, I know."],[3174,3282,"Baby, you're gonna be okay."],[3390,3516,"I'm gonna go grab my keys, okay?"],[3524,3599,"I'll be right back."],[4900,5009,"It's been a half hour."],[5009,5063,"Where is she?"],[5497,5622,"Your call has been forwarded"],[5622,5693,"to voicemail."],[5693,5764,"The person you're trying to..."]],"46":[[183,283,"Hey Penelope!"],[283,371,"This star isn't gonna wish"],[371,437,"on itself,"],[467,525,"where you at?"],[1993,2035,"Penny."],[2435,2502,"I am sorry."],[2585,2756,"Your cancer is spreading."],[2794,2911,"It's the chemo, it's, it's"],[2961,3073,"it has stopped working."],[3103,3299,"You have a couple of months at most."],[3607,3712,"I kind of figured."],[3899,4037,"I guess I just had hope."]],"47":[[817,867,"Penelope?"],[1230,1297,"We need to talk."],[1584,1659,"I know you're in there."],[1768,1814,"Please."],[2919,3065,"I don't wanna see you, Mason."],[3136,3169,"Penelope,"],[3169,3290,"you can't keep doing this to me."],[3290,3465,"You can't one second say"],[3465,3524,"you want me,"],[3586,3645,"and then next"],[3653,3737,"you change your mind."],[3824,3928,"Mason, I-"],[3966,4062,"Just, forget it."],[4091,4191,"You know, I wanted to believe"],[4266,4400,"that you'd finally given us a chance,"],[4475,4558,"but I guess I was wrong."],[4658,4775,"All you ever do is hurt me,"],[4838,5000,"over and over again."],[5021,5084,"I've had it."],[5234,5434,"I'm done with the play,"],[5505,5601,"whatever the fuck is going on"],[5601,5680,"between us,"],[5709,5739,"all of it."],[5939,5989,"I'm done."],[6210,6389,"Mason, I'm doing this to protect you."],[6473,6602,"I know it doesn't make sense,"],[6602,6752,"but I can't bring you into this."],[6806,7015,"The cancer, it's everywhere."]],"48":[[275,362,"Mason, baby,"],[396,554,"I have two tickets to tonight's game."],[567,642,"They're court side,"],[642,775,"so I was thinking that you and I-"],[917,971,"Mason Brown,"],[971,1084,"you can't ignore me forever."],[1084,1180,"You and I were meant to-"],[1272,1355,"So you would rather be"],[1355,1476,"with Pathetic Penny"],[1493,1572,"than be with me?"],[1576,1701,"Hey, watch your fucking mouth."],[1810,1885,"I think you might feel"],[1885,1997,"a little bit differently"],[1997,2252,"once I tell you the truth about Penny."],[2373,2527,"So are you ready to be a good boy"],[2527,2619,"and listen to me?"],[2736,2802,"Whatever Penelope's"],[2802,2877,"keeping to herself,"],[2898,3007,"she'll tell me when she's ready."],[3148,3203,"Good luck with that"],[3203,3319,"because you're running out of time."],[3478,3561,"Because that's what happens"],[3561,3641,"when you're dying."]],"49":[[58,133,"You don't joke about that."],[133,266,"I'm not joking about it, Mason."],[266,325,"I'm the only one"],[325,429,"who's been honest with you."],[521,592,"See for yourself."],[1372,1426,"This is fake."],[1514,1685,"There is no point in wasting your time"],[1685,1797,"on a charity case."],[1830,1972,"She lied to you and led you on."],[1972,2081,"Is that really what you want"],[2081,2147,"in a girlfriend?"],[2177,2335,"Someone with a flat chest"],[2335,2481,"and an expiration date?"],[2585,2652,"You and I"],[2686,2769,"were meant to be together."],[2769,2844,"Don't you see that?"],[3048,3132,"This is the reason."],[3207,3249,"This is why"],[3249,3365,"she's been pushing me away."],[3440,3516,"The nosebleeds,"],[3516,3670,"the scar, the fainting."],[3732,3812,"I missed it all."],[3920,4045,"It's all my fault."],[4200,4275,"I should have known."],[4337,4483,"Mason, where are you going?"]],"50":[[0,4,"This is just like her."],[4,87,"This is just like her."],[133,187,"Pushing me away"],[187,271,"so I wouldn't be hurt."],[291,346,"She must've thought"],[346,421,"this would protect me."],[433,521,"I'm not going anywhere,"],[521,571,"Penelope."],[621,767,"You will not go through this alone."],[1317,1405,"God, Penelope."],[1634,1710,"He knows."],[1730,1914,"After all this time, he knows."],[2202,2298,"I know I'm not always"],[2356,2439,"a good friend."],[2556,2619,"I'm dumb,"],[2736,2869,"make stupid jokes,"],[2969,3023,"tease you,"],[3082,3169,"I get you in trouble."],[3249,3378,"I'm so bad that you couldn't trust me"],[3378,3449,"to stand by you?"],[3549,3720,"You're my best friend, Mason."],[3799,3878,"Getting hurt by you"],[3928,4049,"still feels a hundred times"],[4049,4166,"better than not being with you."],[4258,4358,"But what difference does it make"],[4358,4475,"if you keep trying to leave me?"],[4650,4704,"I'm here."],[4817,4984,"For good, bad,"],[5171,5292,"through sickness, health."],[5580,5684,"Even life and death."],[5864,5943,"I'm here with you."],[6256,6322,"Now it's your turn."],[6443,6535,"Will you be here with me,"],[6652,6798,"despite all the odds against us?"],[7015,7157,"I'm always here with you."],[7336,7432,"I'm so sorry."],[7686,7736,"Come here."]],"51":[[50,154,"No more secrets."],[296,362,"You promise?"],[521,617,"No more secrets."],[1572,1697,"You're still the most beautiful girl"],[1697,1760,"I've ever seen."],[3390,3507,"I'm here with you till the end."],[3712,3757,"Okay?"],[3924,3970,"Okay."]],"52":[[437,533,"Why didn't you tell me?"],[696,821,"I would've been by your side"],[871,934,"for everything."],[1322,1505,"I remember when your mom passed"],[1505,1676,"and when I got my diagnosis,"],[1676,1856,"I just couldn't help but think,"],[1901,1997,"I don't wanna be"],[1997,2135,"another person you lose."],[2189,2356,"It was just easier to let you hate me."],[2402,2523,"Penelope Jones,"],[2560,2640,"you're so silly."],[2669,2815,"You're pushing me away to protect me?"],[2969,3061,"If only I had known."],[3224,3374,"For however long that is."],[3553,3687,"Hopefully, till we're 100."],[3887,4012,"Opening night is next week."],[4116,4258,"I really wanna do the play."],[4383,4521,"But your health?"],[4658,4804,"The stress, the bright lights,"],[4804,4917,"that can't be good for you."],[4942,5088,"It's the most important item"],[5088,5205,"on my bucket list."],[5313,5413,"I have to do it."],[5622,5697,"I promise,"],[5726,5830,"it'll be the best production"],[5830,5930,"this town has ever seen."]],"53":[[721,804,"Deep breath, Penny."],[984,1059,"It's just you,"],[1184,1255,"and the stage,"],[1384,1543,"and him."],[1655,1701,"You ready?"],[2610,2673,"This is everything"],[2673,2765,"you've been working for."],[2886,2965,"You're gonna crush it."],[3570,3687,"To our greatest adventure."],[3791,3866,"Will you join me?"],[3978,4041,"Always."]],"54":[[525,642,"You know what to do, girls."],[996,1109,"Let's give her a costume"],[1109,1263,"that actually suits her."],[2502,2573,"Go get ready."],[2669,2744,"This town's gonna see"],[2744,2902,"the most beautiful Juliet of all time."],[4441,4491,"No."]],"55":[[4,158,"Do you know the girl playing Juliet?"],[196,408,"I heard she's a slut for Mason Brown."],[425,487,"No way."],[500,654,"Everyone knows that he likes her."],[667,846,"Besides, she is like kind of pretty."],[859,996,"Don't let Valerie hear that."],[1009,1159,"She threw a fit when she found out"],[1159,1259,"Penny got the lead role."],[1388,1505,"Looks like it's starting soon."],[1555,1672,"No, no, no, no, no!"],[1818,1906,"What am I gonna do?"],[2018,2131,"The play's about to start."],[2673,2819,"Wow, full house."],[2861,2998,"Penelope will be so happy."],[3186,3249,"Where is she?"],[3303,3378,"It's almost time."],[3841,4004,"I'm not gonna be able to perform,"],[4004,4049,"Jenna."],[4158,4258,"It's all ruined."],[4275,4437,"Hey, hey, it's gonna be okay."],[5125,5192,"I have a plan."]],"56":[[633,709,"Where is she?"],[763,842,"It's almost time."],[921,967,"Mason,"],[1021,1201,"it's almost time for you to go on."],[1251,1334,"I know, Mr. Felix,"],[1334,1418,"but she's not here yet,"],[1418,1468,"so could we just have"],[1468,1539,"a couple more minutes?"],[1618,1743,"As I once told"],[1768,1960,"my second favorite acting student,"],[2002,2189,"the stage waits for no one."],[2243,2369,"You must go now."],[2419,2606,"Just improvise until she gets there."],[3532,3599,"But, soft!"],[3716,3807,"What light through yonder"],[3807,3874,"window breaks?"],[3999,4083,"It is the east,"],[4124,4212,"and Juliet"],[4279,4371,"is the sun."],[4934,5038,"Where are you?"],[5209,5372,"Do you think she chickened out?"],[5372,5442,"I told you,"],[5455,5584,"she never had what it takes."],[5605,5768,"Pathetic Penny is toast."]],"57":[[679,850,"Oh. Wow."],[1197,1472,"Holy shit, she looks beautiful."],[1509,1718,"Like straight out of a fairy tale."],[1785,1889,"You are breathtaking."],[2268,2373,"How the hell did she manage"],[2373,2481,"to find another costume?"],[2652,2698,"That's it."],[2940,3128,"You leave me with no choice, Penny."],[3261,3353,"Time to show everyone"],[3353,3465,"who you really are."]],"58":[[41,162,"What's in a name?"],[237,429,"A rose by any other name"],[621,775,"would still be as sweet."],[1209,1313,"The line is-"],[1326,1384,"I love you."],[1947,1989,"Mason, I-"],[2077,2114,"I can't help it."],[2114,2198,"I just had to say it."],[2310,2452,"I love you so much,"],[2489,2548,"Penelope."],[2615,2681,"I've loved you,"],[2740,2865,"since the moment I met you."],[2952,3103,"I loved you when we were eight"],[3103,3174,"and you said my mom"],[3174,3307,"was in the clouds looking down at me."],[3399,3616,"I loved you when we were thirteen"],[3632,3687,"and you pretended"],[3687,3795,"you didn't like scary movies,"],[3807,3908,"so my friends wouldn't play one"],[3908,3953,"because you knew"],[3953,4074,"I was the one that was afraid."],[4291,4358,"I love you."],[4479,4550,"And I loved you,"],[4587,4713,"the first time I held your hand"],[4733,4829,"when we crossed the street."],[4963,5092,"I never want to let go of that hand"],[5092,5155,"ever again."],[5184,5242,"Not now,"],[5342,5401,"not ever."],[5434,5501,"Look I,"],[5501,5593,"I love you, Penelope."],[5668,5709,"Mason."],[5709,5801,"Even if you don't love me back,"],[5876,5960,"even if you do"],[5960,6106,"and you change your mind someday,"],[6156,6247,"I just needed you to know,"],[6322,6389,"that I love you."],[6544,6673,"I'll say it a thousand times."],[6694,6781,"I, I love you."],[8337,8500,"What a performance!"],[8629,8675,"My turn."]],"59":[[58,104,"My turn."],[396,563,"Val, what are you doing here?"],[667,855,"Mason, baby, I just have a question."],[884,930,"Don't you think"],[930,1026,"the whole school"],[1051,1155,"deserves to know the truth"],[1155,1326,"about your precious Penelope?"],[1384,1472,"Why should we keep"],[1472,1776,"such a juicy secret to ourselves, right?"],[1776,1968,"That's just sick."],[2097,2198,"What secret?"],[2223,2264,"I don't know."],[2264,2398,"Maybe like she's a hooker"],[2398,2464,"or something?"],[2581,2698,"Val, I swear to God."],[2702,2752,"Boys."],[2894,2948,"Get the hell off me!"],[3011,3098,"Val, let him go."],[3161,3345,"This is between you and me,"],[3370,3532,"so let's just take it off the stage"],[3536,3607,"and we can talk."],[3607,3716,"Oh, Penny, dearest,"],[3716,3845,"I think it is a little too late"],[3845,3887,"for that."],[3920,4074,"See, I am done watching you"],[4074,4162,"parade around"],[4183,4295,"and take what is mine!"],[4458,4558,"Ladies and gentlemen,"],[4612,4779,"it's time for the real show."]],"60":[[567,738,"What is wrong with this stupid thing!"],[1005,1247,"Dude, Valerie is losing it."],[1255,1426,"I told you she's like a psycho."],[1639,1835,"That is it, I have had enough!"],[1889,2043,"Let's show that pretty bald head"],[2043,2106,"to everyone,"],[2106,2264,"you Make-A-Wish bitch."],[2581,2619,"No!"],[3628,3820,"This is your Juliet!"],[4992,5050,"See that?"],[5184,5251,"What do you have to say"],[5251,5359,"for yourself now, Penny?"],[5376,5455,"Now that we all know"],[5455,5588,"you're just a dead girl walking."],[6564,6614,"Yes,"],[6731,6785,"it's true."],[6861,6915,"I'm sick."],[7065,7136,"I wear a wig."],[7240,7323,"I have cancer."],[7532,7624,"And it's terminal."]],"61":[[196,283,"I'm so proud of you."],[521,604,"And now you all know."],[725,767,"Okay."],[792,842,"Oh please,"],[888,1046,"don't let this pity party fool you."],[1046,1217,"Penny's not inspirational,"],[1217,1330,"she's pathetic."],[1347,1526,"She is a stage-four freak,"],[1526,1659,"who stole Mason from me."],[1668,1876,"And cancer or not, she's still a loser."],[1960,2035,"Who thinks I'm right?"],[2506,2602,"Don't you all get it?"],[2660,2836,"Penny hid this from all of us."],[2844,3044,"She took my role as Juliet."],[3048,3190,"She, it doesn't even matter to her"],[3190,3286,"because she's gonna die."],[3286,3403,"It doesn't mean anything."],[3403,3611,"She's just a selfish bitch."],[3666,3720,"You're wrong."],[3878,3978,"What did you say to me?"],[4079,4145,"I said,"],[4245,4312,"you're wrong."],[4404,4475,"You said this role"],[4475,4583,"didn't mean anything to me"],[4583,4675,"because I'm dying."],[4829,5071,"This role meant everything to me."],[5196,5417,"To be on stage with someone I love,"],[5497,5622,"create all these memories,"],[5668,5855,"it's everything I've ever dreamed of."],[5889,6018,"So I kept this a secret."],[6093,6177,"But I don't regret it."],[6222,6406,"I can't regret it."],[6468,6706,"I have made a lifetime of memories"],[6748,6931,"up here in these past few hours."],[6948,7048,"Through a small play,"],[7048,7148,"I got to experience"],[7148,7307,"a lifetime of happiness."],[7353,7507,"And when I die,"],[7707,7841,"I'll have no regrets."]],"62":[[1397,1493,"You're all idiots!"],[1530,1584,"Stop it!"],[1589,1668,"Stop clapping!"],[1751,1847,"All of you, stop!"],[1889,1960,"Wow, Valerie."],[2027,2143,"You really got my attention now."],[2198,2323,"Thank God, Mason."],[2360,2406,"I knew it."],[2419,2485,"I knew that you would"],[2502,2619,"finally understand."],[2635,2723,"You went through so much trouble"],[2723,2836,"photoshopping these fake reports"],[2836,2882,"for us."],[2911,2969,"Photoshop?"],[3048,3153,"You think I really have time"],[3153,3215,"for that shit?"],[3224,3311,"Then you must be lying."],[3336,3503,"I told you I am not lying."],[3503,3691,"I stole these files from the hospital"],[3691,3787,"and I took pictures of them."],[3787,3862,"It's all real!"]],"63":[[258,417,"Ah, thanks for the clarification, Val."],[446,558,"Turns out you're not just a mean girl"],[558,667,"with a God complex."],[754,825,"You're also a felon."],[875,1013,"Who just admitted she broke the law"],[1013,1126,"in front of an entire crowd."],[1722,1835,"You're eighteen now, right, Val?"],[2072,2152,"Have fun in prison."],[2314,2369,"Maybe orange will be"],[2369,2439,"a good look on you."],[2481,2573,"Oh, and by the way,"],[2660,2761,"you never stood a chance."],[2852,2948,"It's always been Penelope."],[3019,3090,"No, Mason, please!"],[3107,3165,"Please, no!"],[3219,3290,"Get off of me!"],[3357,3436,"Get off of me!"],[3445,3645,"Bro, isn't she off the cheer team?"],[3682,3778,"Why the fuck is she still"],[3778,3912,"wearing the cheer uniform?"],[3916,3978,"Catch this. - No, wait!"],[3978,4116,"I have five thousand - Please, no!"],[4116,4191,"watches right now"],[4200,4241,"on my stream. - Stop!"],[4279,4412,"Valerie is done for. - Let me go!"],[4429,4500,"Let me go!"],[4517,4683,"This is for Penny, bitch."],[5059,5130,"Let me go!"],[5209,5321,"No! Stop!"],[5422,5505,"Let me go!"],[5847,5910,"That's my girl."],[6085,6202,"It was all thanks to you."],[7323,7365,"You okay?"],[7540,7586,"Penelope?"],[7670,7720,"Penelope?"],[7770,7816,"Penelope!"]],"64":[[321,404,"You have to save her."],[483,567,"You can't let her die."],[600,713,"That's as far as you can go, kid."],[779,838,"I love her."],[888,996,"We'll do everything we can."],[1026,1146,"Please, have a seat."],[3128,3265,"You've been here for hours, honey."],[3324,3382,"Why don't you go home"],[3382,3461,"and get some sleep?"],[3507,3607,"I'm not going anywhere."],[3716,3816,"I'm staying with Penelope."]],"65":[[225,354,"I can't believe I almost lost you."],[521,583,"I'm here."],[809,967,"I thought I was gonna die"],[967,1096,"before I got to tell you."],[1205,1292,"I love you too."],[1488,1639,"I love you so much, Mason."],[1780,1872,"You're my best friend."],[2060,2147,"The love of my life."],[2369,2515,"I'm always gonna love you, Penelope."],[2898,2948,"Hi, Mom."],[3240,3324,"Hi, Mr. Brown."],[3440,3561,"I don't know what I would have done"],[3561,3753,"if I'd lost you today, Penelope."],[3895,3962,"I love you."],[4099,4291,"You are my world."],[4366,4487,"I'm really glad that we were able"],[4487,4600,"to have Mason move in."],[4637,4713,"So that you two could"],[4713,4850,"really enjoy the time together"],[4850,4942,"while you still can."],[4996,5038,"What?"],[5038,5242,"Mason asked if he could move in"],[5251,5326,"a while ago."],[5376,5447,"I, um,"],[5447,5643,"I told James about your condition and,"],[5718,5901,"I mean, it was just a no-brainer, honey."],[5926,6022,"We just wanted to give you kids"],[6022,6164,"the opportunity to be happy."],[6293,6352,"Thank you."],[7469,7586,"You're always up to something,"],[7586,7632,"aren't you?"],[7724,7832,"Always for you, Penelope."]],"66":[[479,546,"Hey."],[688,759,"You're here."],[959,1076,"I said I always will be."],[1242,1338,"Promise me"],[1447,1559,"one more thing."],[1730,1785,"Anything."],[1918,2027,"Promise me"],[2068,2173,"you'll be happy."],[2352,2489,"That you'll live your life"],[2519,2719,"for the both of us when I..."],[2857,2915,"Hey."],[3103,3153,"Hey."],[3340,3407,"It's okay."],[3524,3724,"I know my life's been short,"],[3787,3958,"but to love you like this,"],[4041,4170,"it's more than most people"],[4170,4325,"get their whole life."],[4358,4512,"Kind of makes it all worth it."],[4700,4779,"Will you wait for me,"],[4825,4929,"so I can see you again?"],[5059,5163,"Of course, Mason."],[5246,5367,"You were..."],[5563,5701,"the greatest"],[5764,5926,"love of my life."],[7982,8074,"Penelope wanted me"],[8074,8174,"to give this to you,"],[8341,8441,"when she passed."]],"67":[[446,542,"To my Romeo,"],[592,709,"if you're reading this,"],[750,884,"it means I didn't make it."],[959,1117,"I fought, I really did."],[1217,1388,"But some things are bigger than love"],[1388,1539,"and stronger than promises."],[1776,1931,"I don't want you to remember me"],[1931,2027,"in a hospital bed."],[2060,2193,"Remember me as the girl"],[2193,2381,"who laughed too loud at your jokes,"],[2423,2510,"who held your hand"],[2510,2690,"like she'd lose you if she let go."],[2748,2865,"Remember my voice,"],[2911,2990,"not the machines"],[2990,3098,"that kept me here too long."],[3169,3453,"You were my first love, my only love,"],[3490,3678,"the kind of love that will only happen"],[3678,3820,"once in a lifetime."],[3878,4029,"I wish we had years."],[4062,4166,"I wish I had been the girl"],[4166,4275,"who got to marry you."],[4316,4425,"I wish I had been the girl"],[4425,4562,"who grew old next to you,"],[4612,4788,"who got to watch your hair turn silver"],[4788,4925,"and your face grow softer."],[4975,5134,"I'm so sorry I didn't get to be"],[5134,5226,"that girl for you."],[5305,5372,"But Mason,"],[5426,5609,"please promise me something, okay?"],[5676,5730,"Live."],[5768,5926,"I need you to live your life"],[5926,6022,"to its fullest,"],[6047,6177,"to laugh with someone new"],[6177,6231,"one day,"],[6264,6381,"to fall in love again."],[6423,6594,"I need you to choose happiness"],[6614,6719,"for the both of us."],[6835,7011,"And one day, when it's time,"],[7052,7190,"I'll be waiting for you up there"],[7223,7411,"and we'll finally get our forever."],[7524,7653,"I love you, Mason Brown."],[7691,7874,"With love, your Juliet."]],"68":[[271,367,"Grandpa, look."],[392,550,"This one has the same name as me."],[583,684,"She's Penny too."],[788,880,"That's because you were named"],[880,975,"after her, sweetheart."],[1067,1180,"Everything I learned about love,"],[1180,1313,"I learned from her."],[1418,1505,"Wanna say hi to her?"],[1647,1701,"Hi, Penny."],[1726,1914,"I'm Penny and this is my grandpa."],[2489,2565,"Hello, Penelope."]]}