{"1":[[695,854,"Please, High Priestess."],[929,1029,"Seal my wolf."],[1091,1320,"So I can finally be with Blaze,"],[1566,1729,"the Alpha I love."],[2058,2195,"I won't allow it, Nessa."],[2254,2358,"You're my sole heir"],[2416,2541,"and the future Alpha Queen"],[2541,2629,"of this kingdom."],[2654,2741,"You bear the mark"],[2741,2891,"of the Stormcrest pack."],[3054,3141,"Your Highness,"],[3191,3283,"the Alpha is right."],[3329,3450,"You have the legendary"],[3450,3541,"White Wolf,"],[3579,3745,"the most powerful wolf"],[3770,3954,"born once in centuries."],[3966,4054,"I don't want power"],[4054,4204,"if it means losing Blaze."],[4220,4379,"You're giving up your White Wolf"],[4437,4654,"for a nobody Alpha from a weak pack?"],[4654,4729,"Why?"],[4904,5033,"Because he is my mate."],[5112,5204,"It was our destiny."],[5320,5412,"We bonded the moment"],[5412,5512,"we first met."],[5750,5858,"And I've loved him"],[5858,6070,"ever since that first glance."],[6375,6454,"I know"],[6495,6591,"that the White Wolf must stay"],[6591,6729,"within our pack's bloodline."],[6783,6920,"That's why I must give up my wolf"],[6920,7029,"to be with Blaze."],[7125,7208,"Very well!"],[7329,7395,"Just remember,"],[7470,7554,"once you become a rogue,"],[7554,7729,"you cannot come back to this pack"],[7779,8008,"without your White Wolf!"],[8166,8291,"Don't regret it!"],[8954,9029,"Nessa."],[9116,9183,"We've been friends"],[9183,9333,"since we were kids, Thorne."],[9391,9504,"But I've made my decision."],[9591,9704,"Take care of my father."],[9741,9804,"Please."],[11166,11266,"High Priestess."],[11458,11579,"Seal my wolf."],[13312,13383,"It's done."],[13529,13641,"You're now wolfless."],[13729,13891,"I did this for you, Blaze."],[13958,14129,"You're all I want in this world."],[14554,14633,"Oh my goodness,"],[14633,14787,"you like that, it's pretty good huh?"],[14895,14945,"You okay?"],[14945,15016,"Oh yeah."],[15079,15145,"Let's go."],[15320,15508,"They don't like a wolfless rogue"],[15508,15595,"as their Luna."],[15858,15958,"But we didn't care."],[16079,16154,"We were happy."],[16154,16216,"You okay?"],[16275,16308,"Yeah."],[16670,16720,"And then,"],[17083,17191,"our son was born."],[17520,17629,"Just one more push, baby."],[17679,17791,"Just one more push."],[17866,17925,"You got this."],[18591,18658,"Our first pup."],[19379,19433,"Nessa."],[19566,19629,"You did it."],[20695,20816,"Why does our child have the mark of"],[20816,20954,"the Stormcrest Pack?"],[21333,21504,"Nessa, did you cheat on me?"]],"2":[[95,225,"Did you cheat on me?"],[287,391,"Our son has this mark"],[391,637,"because I'm the sole heir of Stormcrest,"],[637,775,"the strongest pack of all."],[1162,1283,"I gave up my wolf,"],[1312,1491,"hid my identity to be with Blaze."],[1583,1700,"No, Blaze, I didn't,"],[1700,1779,"I didn't cheat on you."],[1779,1900,"He has that mark because-"],[1925,2016,"Because what?"],[2066,2250,"You're just a wolfless rogue."],[2262,2337,"There's no way"],[2337,2525,"you gave that mark to your son."],[3037,3183,"This bastard child's dad"],[3183,3387,"must be from Stormcrest pack."],[3441,3575,"You're too foolish, son."],[3666,3766,"I told you."],[3829,4020,"Rogue can't be trusted."],[4262,4362,"That's not true."],[4437,4591,"I am from the Stormcrest-"],[4787,4991,"You don't even have the Stormcrest mark,"],[5158,5387,"so stop spilling lies."],[5454,5537,"Blaze,"],[5695,5812,"Britney's baby,"],[5854,6000,"your brother left us"],[6041,6237,"is our only heir now."],[6437,6500,"Nessa."],[6670,6787,"I trusted you!"],[6975,7029,"Blaze."],[7091,7262,"Blaze, it really is our child. I-"],[7262,7362,"you have to believe me."],[7604,7750,"I swear it's our child."],[7750,7912,"No, don't trust her."],[7979,8037,"Okay?"],[8037,8200,"She's just a rogue with no wolf,"],[8200,8262,"no power."],[8300,8537,"She's just been using you all along."],[8741,8875,"So that's it, huh?"],[9016,9112,"You sleep with members of"],[9112,9312,"the Stormcrest pack for favors?"],[9412,9504,"And try and convince me"],[9504,9637,"that that's my son?"],[9762,9875,"My wolf is sealed."],[9941,10012,"I can't prove"],[10012,10162,"I'm the heir of Stormcrest."],[10316,10362,"See?"],[10400,10525,"She's speechless."],[10525,10700,"This is a disgrace, Blaze."],[10700,10791,"You need to break the bond"],[10791,10887,"with her now."],[11125,11216,"I'm wolfless,"],[11254,11445,"if he rejects me I'll die."],[11629,11700,"And..."],[11800,11925,"Please, please, please, no."],[12450,12700,"As for this bastard child,"],[12800,12879,"I say,"],[13029,13112,"we kill it!"]],"3":[[54,229,"No, no, don't hurt my baby."],[229,441,"Oh, you don't want me to hurt it?"],[462,604,"Oh, well then admit that you"],[604,675,"cheated on Blaze"],[675,841,"and let him break the bond with you."],[887,991,"Blaze, please, please,"],[1004,1204,"please don't let them hurt our baby."],[1545,1733,"I don't have such grandchild."],[1837,1908,"Blaze,"],[2137,2333,"kill that bastard child."],[2554,2608,"Three."],[2650,2737,"Please, I swear,"],[2737,2933,"I swear, you have to believe me."],[2954,3029,"Two."],[3045,3304,"I swear, I swear, I'm telling the truth."],[3358,3408,"One."],[3479,3570,"Just break,"],[3570,3708,"just break the bond with me."],[3708,3983,"I will die in the place of my son!"]],"4":[[100,166,"Enough!"],[600,654,"What?"],[654,829,"Blaze, this isn't even your child."],[866,1025,"This is a disgrace, son."],[1075,1212,"You're the Alpha of this pack-"],[1212,1354,"I'm an Alpha, not a murderer!"],[1550,1700,"She's just a powerless rogue."],[1800,1904,"They pose no threat."],[2191,2337,"We'll keep them as slaves."],[2400,2500,"Slaves?"],[2529,2587,"Yes."],[2700,2825,"Keep your enemies closer."],[2937,3025,"That's final."],[3737,3870,"You betrayed me, Nessa."],[3929,4091,"Consider this my final mercy."],[4625,4687,"You'll be staying"],[4687,4804,"in the maid's quarters."],[4854,4979,"And even though you're slaves,"],[5141,5229,"you're still mine."],[6212,6312,"Once you become a rogue,"],[6312,6475,"you cannot come back to this pack"],[6475,6687,"without your White Wolf!"],[6750,6875,"Don't regret it!"],[6962,7191,"Blaze, I gave up my pack,"],[7250,7379,"my wolf, to be with you."],[7425,7591,"Is this really how you're treating me"],[7591,7687,"and our child?"],[7754,7912,"We can't go back now."],[8175,8204,"And,"],[8250,8412,"even though I don't have my wolf,"],[8504,8812,"Mommy will always protect you."],[8825,8900,"Okay?"]],"5":[[25,195,"It's been five years since my mate"],[195,391,"enslaved me and our child."],[458,641,"He took everything from us."],[708,833,"I had to scrape everything"],[833,950,"I had just to get this"],[950,1079,"cupcake for Kaelib."],[1208,1516,"But the look on his face will be worth it."],[1591,1687,"Mommy!"],[2029,2141,"Kaelib."],[2233,2395,"How was your first day in school?"],[2545,2616,"Mommy"],[2712,2841,"got you a little something."],[2991,3116,"Is it from Daddy?"],[3262,3433,"Blaze hasn't looked at our son once,"],[3433,3562,"since he was born."],[3616,3837,"But, all Kaelib wants is his daddy's love."],[3987,4041,"Yes."],[4116,4229,"It's from Daddy."],[4354,4541,"Caught you, you disgusting thief."]],"6":[[504,687,"You filthy barn rat."],[712,850,"You dare steal from our pack,"],[850,937,"when we spared you and"],[937,1050,"that runt's life?"],[1279,1412,"I didn't steal anything."],[1500,1700,"And my son deserves to eat, too."],[2150,2375,"My son is Alpha Blaze's nephew,"],[2375,2570,"the only legitimate Ashclaw heir."],[2637,2787,"Now that my mate is dead,"],[2812,3100,"I will make Alpha Blaze mine."],[3162,3287,"And I will be Luna,"],[3287,3537,"and my son, the future Alpha."],[3741,3879,"I am still Blaze's mate."],[3912,4112,"He would never bond with you, Britney."],[4162,4329,"And I already have a son with Blaze."],[4329,4412,"That's Kaelib."],[4462,4587,"Quit spreading your filthy lies"],[4587,4754,"that you bore Blaze's son."],[4775,4912,"You're getting in my way!"],[5400,5516,"I'm not afraid of you."],[5525,5591,"Oh yeah?"],[5641,5825,"Then I'll make you cower."],[5912,6079,"Don't hurt my mom, please."],[6662,6912,"Bow down to me, you filthy peasant."],[7600,7775,"Stay away from my son."]],"7":[[25,212,"Well, my son can do whatever he wants."],[270,404,"He's the future Alpha."],[445,675,"Your son is a monster."],[933,1037,"Know your place."],[1095,1191,"You and your bastard child"],[1191,1375,"are just slaves to the Ashclaw pack."],[1766,1862,"Look at you,"],[1870,2037,"you can't even protect your own son"],[2037,2141,"because you're wolfless."],[2325,2525,"Yeah, you're helpless."],[3129,3212,"What are you gonna do?"],[3395,3625,"No, my daddy gave that to me."],[3637,3729,"That was the only thing"],[3729,3866,"he ever gave to me."],[3945,4033,"Oh yeah?"],[4758,4895,"Daddy this, daddy that."],[4908,5016,"Your mommy's too powerless"],[5016,5112,"to even save you,"],[5112,5250,"so you don't even deserve a daddy."],[5283,5333,"No."],[5362,5545,"I have a daddy and a mommy."],[5670,5754,"Come after me instead of"],[5754,5895,"picking on a child!"],[5987,6079,"If I hadn't sealed my"],[6079,6200,"powerful white wolf,"],[6250,6387,"I could've protected my son."],[6466,6612,"You don't get to choose!"],[6637,6750,"You threw yourself at Blaze"],[6750,6816,"and now you're just his"],[6816,6929,"little gold digger."],[6950,7108,"You can't even protect yourself."],[7183,7520,"You lay one finger on my son,"],[7520,7620,"and I will-"],[7620,7725,"Oh, you'll what?"],[7754,7920,"Be helpless and cry?"],[7937,8079,"Watch me while I hurt your son"],[8079,8308,"and you can't do anything about it."],[8433,8575,"The hell is going on in here?"]],"8":[[41,191,"What the hell is going on in here?"],[312,391,"Daddy."],[666,725,"Blaze,"],[762,945,"it was all Nessa and her twerp son."],[970,1133,"They were trying to bully Leonard."],[1166,1395,"Yeah, Kaelib was bullying me,"],[1395,1591,"it hurt so much."],[1641,1691,"Blaze, he didn't."],[1691,1787,"Britney is framing us."],[1787,1883,"They were trying to hurt-"],[1883,2079,"You're just a rogue slave."],[2079,2254,"No wonder you can't teach your son"],[2254,2366,"proper behavior."],[2454,2591,"You have to believe me, Blaze."],[2629,2766,"Our son has always been a good boy."],[3020,3175,"The guards were witnesses, okay?"],[3175,3308,"They saw him bully him."],[3316,3429,"Yes, yes, we did."],[3479,3591,"It was Nessa and her son."],[3758,3929,"Stop lying, Britney."],[3941,3991,"No!"],[4050,4150,"You're the liars."],[4208,4350,"Remember, okay?"],[4387,4520,"She cheated on you with someone"],[4520,4637,"and had this kid with someone"],[4637,4783,"from Stormcrest."],[4883,5016,"No, you're right."],[5141,5241,"She betrayed me."],[5254,5354,"No, really."],[5404,5554,"Kaelib only has the Stormcrest mark"],[5554,5666,"because I am from Storm-"],[5666,5729,"Enough!"]],"9":[[4,75,"Enough!"],[650,712,"Kaelib."],[762,962,"If you step out of line again,"],[1075,1337,"you are going to end up like this wall!"],[1837,2041,"But, I didn't hurt him."],[2075,2175,"He hurt me."],[2262,2454,"Why are you so scary, Daddy?"],[2575,2666,"Punish them Blaze."],[2675,2766,"Cast them away."],[2783,2908,"I didn't do it, Daddy."],[2950,3062,"Blaze, how could you treat"],[3062,3216,"your own child this way?"],[3304,3516,"No, I never betrayed you, Blaze."],[3587,3712,"You can't do this to our son."],[3750,3812,"Shut up."],[3891,3962,"Blaze is the Alpha,"],[3962,4100,"and he never had a son with you."],[4116,4216,"And the Stormcrest mark"],[4216,4337,"on your son's arm"],[4362,4479,"is damn proof!"],[4587,4654,"That's because"],[4654,4804,"I'm the Stormcrest Alpha Queen."],[4887,5000,"But I gave up my wolf"],[5000,5179,"and there's nothing to prove it."],[5212,5350,"And if Blaze tosses us out,"],[5416,5666,"I'm wolfless and can't protect my son."],[5725,5800,"We'll die."],[5879,6012,"I bet you whored around so much,"],[6012,6187,"you don't even know who the father is."],[6550,6687,"No, you're my daddy."],[6687,6800,"I'm not a bastard."],[6916,7037,"I love you, Daddy."],[7262,7316,"Kaelib."],[7441,7525,"From now on,"],[7579,7741,"you will not call me Daddy."]],"10":[[150,254,"But he's our son."],[266,362,"No, he's not."],[387,475,"But, Daddy-"],[475,629,"I will be addressed as Alpha"],[629,779,"from this point forward!"],[841,925,"If you fail to do so,"],[925,1029,"I will kick you"],[1029,1204,"and your mother out of this pack!"],[1287,1404,"Do you understand me?"],[1450,1750,"Yes, I understand, Alpha."],[1887,2112,"I regret ever falling for you, Blaze."],[2112,2187,"I sealed my"],[2187,2362,"wolf power to be with you."],[2425,2620,"I gave up everything for you."],[2637,2750,"You were supposed to be"],[2750,2950,"my faithful Luna, Nessa."],[3029,3129,"As punishment,"],[3266,3425,"you two will be chained to this hall"],[3450,3512,"until dawn."],[3579,3666,"No, no Blaze, you can't do this."],[3666,3804,"Kaelib is just a child."],[4175,4400,"If only my White Wolf wasn't sealed."],[4825,4979,"I wouldn't be treating you like this,"],[4979,5100,"if you didn't cheat on me."],[7175,7275,"We're under attack!"],[7725,7791,"Kaelib!"],[7904,7991,"Kaelib."]],"11":[[112,229,"Ah, Leonard."],[895,979,"Blaze, Blaze."],[1020,1237,"Blaze, please, please help our son."],[1579,1695,"Blaze, Leonard is your"],[1695,1804,"dead brother's only son."],[1804,1954,"You have to help him."],[2250,2325,"Mommy."],[2366,2454,"Blaze, please."],[2462,2591,"Please help Kaelib!"],[2695,2891,"Leonard has Ashclaw blood."],[2937,3066,"You have to help him."],[3087,3266,"This runt's life is worthless."],[3354,3445,"He's your son, Blaze,"],[3445,3637,"I gave up everything for you."],[4633,4804,"No, no, Blaze!"]],"12":[[33,191,"No, no, Blaze!"],[404,570,"Blaze is mine!"],[800,850,"Blaze,"],[895,1020,"are you really gonna let"],[1020,1158,"me and your son die?"],[1191,1341,"Does Daddy really not"],[1341,1558,"want me anymore, Mommy?"],[1600,1716,"Kaelib, he just..."],[1950,2204,"Daddy doesn't want me anymore."],[2479,2554,"Kaelib!"],[2912,2987,"Kaelib!"],[3704,3829,"Kaelib! I'm back!"],[4400,4491,"It's the White Wolf."],[4600,4708,"The legendary Wolf Queen?"]],"13":[[1816,1995,"Only the White Wolf can break this chain,"],[1995,2108,"how did Nessa escape?"],[3083,3166,"Mommy."],[3216,3258,"Mom."],[3341,3391,"Mommy."],[3391,3441,"Nessa!"],[3608,3666,"Kaelib."],[3704,3770,"Daddy."],[4066,4129,"I've never let him"],[4129,4258,"so close to me before."],[4333,4416,"Why does it feel"],[4504,4620,"so right?"],[4720,4879,"Like he's actually my son?"],[6170,6291,"Mommy, you're awake."],[6320,6470,"You saved me."],[6541,6654,"You have a wolf."],[6695,6866,"And it's the White Wolf."],[6891,7083,"That means you're the Wolf Queen."],[7354,7466,"Why are we back here?"],[7491,7758,"You fainted, but Daddy found us."],[7970,8145,"Listen, Kaelib."],[8258,8420,"Now that I have my wolf back,"],[8466,8608,"I am strong enough"],[8608,8779,"to get us out of this hellhole,"],[8816,9029,"and back to our true home."]],"14":[[87,300,"We're leaving Daddy forever?"],[387,458,"Honey,"],[650,820,"Alpha Blaze doesn't want us here."],[970,1070,"He chose"],[1108,1245,"to save Leonard instead of you."],[1337,1550,"We will go home to Grandpa."],[1633,1720,"In our pack,"],[1733,2095,"many others will love and respect you."],[2150,2287,"But I want Daddy."],[2337,2487,"For the first time ever,"],[2512,2612,"he hugged me."],[3212,3270,"He did?"],[3516,3608,"Please, Mommy."],[3645,3858,"Just give him one more chance."],[3912,4112,"At least let me celebrate"],[4112,4308,"my birthday with him."],[4645,4820,"Well, it's your lucky day, Nessa."],[5166,5320,"The Alpha is having a ceremony."],[5370,5470,"He wants you two to be there."],[5633,5733,"These are your outfits."],[5745,5887,"He ordered me to bring them to you."],[6237,6295,"Yay."],[6320,6475,"It's my birthday tomorrow."],[6537,6708,"Daddy must have remembered."],[6858,7045,"Why is Blaze making a one eighty now?"],[7100,7308,"Is it because he saw my White Wolf?"],[7487,7575,"And realizes that I'm"],[7575,7725,"the Stormcrest Wolf Queen,"],[7837,7995,"that I never cheated on him?"],[8262,8433,"Are you finally trying to save"],[8433,8558,"our marriage, Blaze?"],[8912,9087,"That kid thinks that the ceremony"],[9087,9287,"is going to be his birthday party?"],[9325,9462,"They have no clue that"],[9462,9733,"his daddy's about to break their hearts."],[11570,11620,"Yay."],[11620,11725,"Daddy's throwing me"],[11725,11883,"a giant birthday party."],[11912,12025,"I told you,"],[12058,12237,"he cares about us, Mommy."],[12412,12683,"Maybe there is hope for me and Blaze."],[13562,13720,"Blaze is taking another she-wolf"],[13720,13820,"as his Luna?"]],"15":[[225,404,"Blaze is making another she-wolf"],[404,491,"his Luna?"],[604,791,"Mommy, I thought Daddy"],[816,941,"was going to celebrate"],[941,1029,"my birthday."],[1045,1195,"I thought he loved me."],[1316,1391,"Blaze,"],[1416,1595,"I hid my identity as the strongest"],[1595,1795,"future Wolf Queen in this kingdom,"],[1804,1929,"just to be with you."],[1991,2129,"Not anymore."],[2466,2670,"Oh, oops, did I"],[2670,2816,"give you the wrong invitation?"],[2895,2991,"It was you."],[3079,3166,"You lied to my son"],[3166,3329,"that this was his birthday party."],[3429,3579,"You were just toying with us."],[3591,3666,"You're the idiot"],[3666,3808,"to believe that Blaze"],[3829,4016,"gives a damn about that little runt."],[4041,4316,"Stop calling the Alpha your daddy."],[4379,4566,"You're just a little bastard child"],[4566,4691,"with no father."],[4716,4879,"Don't talk to my son like that."],[4979,5208,"We can talk to him however we want."],[5491,5729,"Your son has the Stormcrest mark"],[5729,5804,"on his arm,"],[5804,5966,"which means he's not Blaze's son."],[5979,6066,"Which also means that"],[6066,6291,"you are a liar and a slut!"],[6404,6512,"My son has the mark"],[6512,6754,"because I am the sole heir"],[6754,6954,"of the powerful Stormcrest pack."],[7008,7166,"What they don't know is,"],[7204,7354,"I've regained my legendary"],[7354,7495,"White Wolf strength."],[7616,7720,"Come on, Blaze."],[7754,7879,"Break the bond with her now"],[7879,8016,"and make me your Luna."],[8108,8204,"She's wolfless."],[8320,8491,"If I reject her, she might die."],[8533,8629,"Who cares?"],[8804,8908,"She's just a rogue."],[9041,9104,"Yeah."],[9154,9341,"This pack needs a real Luna."],[9404,9616,"Get rid of that dirty slave."],[9616,9704,"Break the bond!"],[9716,9804,"Break the bond!"],[9816,9904,"Break the bond!"],[9908,9995,"Break the bond!"],[10008,10095,"Break the bond!"],[10108,10191,"Break the bond!"],[10516,10591,"Nessa."]],"16":[[4,204,"Stop right there, Blaze."],[266,533,"You will not reject me."],[629,716,"Not today."],[841,929,"Not ever."],[1279,1541,"Moon Goddess, hear my prayer."],[1566,1679,"Let my pack know"],[1716,1845,"that the White Wolf,"],[1866,1979,"their Alpha Queen,"],[2104,2179,"is returning."],[2350,2504,"Their Alpha Queen"],[2570,2679,"is returning."],[3141,3279,"Inform Alpha Caelum"],[3279,3395,"and General Thorne."],[3458,3533,"His heir,"],[3579,3704,"our Alpha Queen"],[3716,3858,"is coming back!"],[3991,4120,"Okay, what the hell are you"],[4120,4216,"murmuring about?"],[4216,4416,"Stop stalling, you're wasting our time."],[4441,4554,"Reject her, Blaze."],[4554,4729,"Who cares if she dies?"],[4745,5029,"And your bastard child."],[5091,5270,"Let go of my son or you will pay."],[5270,5491,"I'll burn this eyesore off his arm,"],[5508,5641,"and I'll make him"],[5654,5966,"my son's personal slave forever!"],[7066,7429,"Nobody messes with my son."]],"17":[[45,212,"How dare you hurt Britney?"],[358,437,"That"],[562,720,"is for choosing someone else"],[725,925,"over me and our son."],[1433,1650,"Blaze, I'm taking Kaelib"],[1687,1845,"and I'm leaving you"],[1887,1962,"forever."],[2000,2066,"Leaving me?"],[2187,2337,"Nessa, you don't have a wolf."],[2337,2437,"If you take him out there,"],[2437,2550,"there's thousands of packs"],[2550,2737,"that will rip you to shreds in seconds."],[2750,2975,"She's weak and powerless."],[3004,3091,"That's why"],[3100,3325,"she seduced you for protection"],[3366,3712,"and leeched off of us for five years, son."],[3887,3979,"Oh Nessa,"],[4029,4237,"are you seriously threatening me?"],[4250,4412,"You're a wolfless nobody."],[4437,4675,"I'll show you what a real wolf can do."],[5062,5150,"Oh, try me."],[5325,5387,"Stop."],[5400,5462,"Forget it."],[5550,5600,"Nessa,"],[5637,5825,"you're powerless without a wolf, okay?"],[5829,5912,"Stand down."],[5954,6100,"Just apologize."],[6125,6279,"And I might let you two stay."],[6291,6337,"Besides,"],[6337,6479,"even if you survive the rejection,"],[6479,6687,"you need me to protect you."],[6762,6887,"Don't make me laugh."],[6950,7037,"You abandoned us"],[7037,7187,"to save another woman's kid."],[7300,7500,"What kind of a father are you?"],[7558,7604,"Okay."],[7679,7725,"You're mad."],[7725,7812,"So what?"],[7850,7966,"Nessa, it doesn't change the fact"],[7966,8075,"that you don't have a wolf"],[8087,8237,"and you can't protect him out there."],[8262,8537,"I can protect my son just fine."],[8625,8675,"Fine."],[8704,8791,"You want to leave?"],[8841,8904,"Leave."],[8937,9037,"You're going to die out there"],[9037,9091,"without me."],[9091,9137,"Here."],[9316,9391,"Here's some cash."],[9391,9450,"Why don't you"],[9450,9587,"buy yourself a bodyguard or-"],[9750,9887,"Don't give them any money."],[9925,10037,"If they want to die, let them."],[10079,10279,"Their lives are worthless anyways."],[10312,10629,"You filthy pigs"],[10700,10850,"think we are worthless?"],[10887,10991,"You have no idea"],[11025,11187,"what I'm capable of, Blaze."],[11466,11612,"You can take back your scraps."]],"18":[[95,329,"Because we are done begging."],[362,441,"I never got with you"],[441,591,"because I needed anything."],[670,750,"Remember this?"],[929,1054,"You gave this to me."],[1137,1287,"When you asked me to run away with you."],[1383,1466,"You told me"],[1562,1641,"to never part with it,"],[1641,1845,"just like you would never part with me."],[1912,1995,"But now I see,"],[2045,2245,"that it was just a shackle to me."],[2483,2575,"I don't want it anymore."],[2858,3133,"That was a token of our mating bond."],[3162,3250,"And you just throw it aside"],[3250,3337,"like it's nothing?"],[3337,3470,"I don't want anything"],[3525,3708,"from this pack anymore."],[3762,3908,"In fact, this gown you gave me,"],[4062,4170,"I'm better off without it."],[5562,5637,"You"],[5745,6033,"are the biggest mistake of my life."],[6350,6400,"Wait."],[6562,6670,"You two aren't going anywhere"],[6670,6783,"without my permission."],[7662,7820,"My blood activated his wolf."],[7870,8020,"And that's the Ashclaw mark."],[8158,8245,"He's my son!"],[8783,8970,"Don't fucking touch my son."],[8970,9108,"If you go out there, you'll die"],[9108,9258,"in five seconds without me."],[9270,9333,"Oh yeah?"],[9458,9558,"Watch me."],[12162,12270,"Who the hell are they?"]],"19":[[1262,1391,"Welcome back, my lady."],[1587,1641,"Look,"],[1716,1800,"that's the symbol of"],[1800,1954,"the Stormcrest pack."],[1966,2162,"The most powerful pack of them all."],[2179,2266,"Your highness,"],[2312,2412,"it's been five years"],[2412,2537,"since I've seen you last."],[2654,2716,"Thorne."],[3187,3250,"Come on."],[3312,3437,"You're not just my general."],[3537,3641,"We grew up together."],[3737,3904,"I never should've let you go."],[4141,4262,"Who the hell is that?"],[4262,4391,"I bet that's the chauffeur"],[4391,4462,"or something."],[4462,4504,"See?"],[4504,4662,"I told you she was cheating on you."],[4987,5200,"I once loved you so much, Blaze."],[5325,5400,"But now you're nothing"],[5400,5500,"but a stranger to me."],[5629,5712,"Come on, Kaelib,"],[5812,5866,"let's go home."],[6179,6337,"Oh, I almost forgot."],[6587,6712,"Blaze Ashclaw."],[6762,7000,"I reject you."],[8112,8175,"Son."],[8850,9037,"Even with my wolf protecting me,"],[9037,9212,"I can barely withstand the force"],[9212,9295,"of our mate-bond breaking."],[9325,9508,"How can Nessa still be standing?"]],"20":[[25,145,"Now your mating ceremony"],[145,287,"doesn't have to be just"],[308,395,"a piece of paper."],[458,633,"Bye bye, Alpha Blaze."],[658,883,"He actually stopped calling me daddy,"],[1016,1170,"why does it hurt so much?"],[2162,2212,"Nessa,"],[2320,2400,"who are you?"],[2433,2537,"No wonder her son has"],[2537,2708,"the Stormcrest mark on his arm."],[2800,2870,"She's probably been"],[2870,2987,"sleeping with that chauffeur."],[3037,3100,"To think,"],[3208,3370,"I thought that runt was my son."],[3550,3695,"You betrayed me, Nessa!"],[3708,3920,"Oh, forget about them, okay?"],[3954,4045,"Uh, let's just go back"],[4045,4158,"to the marking ceremony."],[4195,4295,"Fuck off."],[4345,4387,"Son!"],[4400,4508,"Ceremony's over!"],[4608,4658,"Go home!"],[4658,4708,"Son."],[4708,4775,"Now!"],[6408,6475,"Father."],[6983,7070,"Nessa."],[7483,7595,"Our Alpha Queen to be."],[8062,8258,"Welcome back, Alpha Queen."]],"21":[[229,329,"My grandson."],[566,633,"Kaelib."],[812,925,"Look at that, Kaelib."],[966,1054,"We're a match."],[1837,1900,"I'm sorry"],[1900,2037,"for disappointing you, father."],[2166,2325,"I should have never sealed my wolf"],[2325,2450,"and run away with Blaze."],[2562,2662,"Your Highness,"],[2791,2866,"normally,"],[2912,3054,"once the wolf is sealed,"],[3087,3204,"it's permanent."],[3237,3325,"The fact that you broke"],[3325,3537,"through the seal all on your own."],[3637,3854,"Shows just how powerful you are."],[3912,4141,"And how deep your love is for your son."],[4470,4612,"It's all in the past now."],[4625,4729,"You're still my daughter."],[4837,4925,"And when you're ready,"],[5100,5212,"take your crown"],[5262,5454,"and become the ruler of Stormcrest."],[5504,5725,"The most powerful pack in this land."],[5762,5945,"Since nobody has seen you"],[5945,6062,"in five years,"],[6100,6237,"surely the entire kingdom"],[6237,6375,"will doubt your powers."],[6500,6762,"But I will always be by your side."],[6858,7004,"Thank you, Thorne."],[7320,7491,"Then it's time to make your debut"],[7491,7625,"at the Grand Summit."],[7637,7879,"Your ex-husband will regret"],[7929,8166,"what he did to you and Kaelib."]],"22":[[445,545,"Damn it, Nessa!"],[595,687,"A nobody"],[758,862,"defying an Alpha."],[908,1025,"You gotta be kidding me."],[1133,1250,"What a disgrace."],[1708,1820,"Nessa's scent."],[2020,2095,"I knew she'd be back."],[2095,2162,"I knew she couldn't"],[2162,2283,"dare to live without me."],[2358,2462,"I knew you'd come back!"],[2933,3133,"Who said you could wear Nessa's dress."],[3370,3525,"She's already gone, Blaze."],[3583,3770,"She left you for another man."],[3783,3862,"Remember,"],[3895,4158,"I'm the strongest she-wolf of Ashclaw."],[4183,4358,"Nessa is nothing compared to me."],[4370,4445,"Blaze."],[4525,4595,"Blaze."],[4675,4850,"Justin, your Beta, just returned."],[4970,5020,"Alpha."],[5262,5433,"We traced the attack three days ago"],[5433,5587,"to the North Star pack."],[5587,5675,"North Star?"],[5683,5858,"They've been our tails for decades."],[5883,5995,"Oh shit."],[6020,6133,"Six years ago,"],[6145,6300,"I wanted to take over the pack,"],[6325,6475,"so I helped our enemy attack"],[6475,6620,"and kill my ex-husband,"],[6633,6725,"Blaze's brother."],[6770,6950,"I can't let them know I'm the traitor."]],"23":[[25,204,"I can't let them know I'm the traitor."],[212,266,"What should we do"],[266,425,"about the North Star pack now, Alpha?"],[475,579,"Stormcrest,"],[612,762,"the most powerful clan of them all"],[862,1075,"is hosting a grand summit next week."],[1104,1200,"Said that all the"],[1212,1362,"important packs will be there."],[1366,1462,"That's so smart, son."],[1525,1675,"We can form an alliance with them."],[1716,1879,"And I heard the Wolf Queen"],[1879,2037,"and the legendary White Wolf,"],[2100,2225,"just returned to them."],[2275,2412,"Nobody can touch us then,"],[2429,2566,"if we can gain her favor."],[2579,2750,"Oh, perfect."],[2775,2950,"My cousin is the ambassador"],[2950,3054,"of the Grand Coucil,"],[3054,3166,"I'll have him hook us up."],[3187,3337,"And this is why,"],[3400,3687,"Britney should be your new Luna."],[3754,3862,"Blaze."],[3987,4116,"Might I remind you, Alpha,"],[4212,4450,"that Nessa is still with Stormcrest."],[4637,4737,"So what?"],[4779,4937,"She's just a wolfless rogue,"],[4937,5075,"who cheated on Blaze."],[5137,5275,"They probably pushed her aside"],[5275,5437,"anyways once they were done using her."],[5562,5625,"Then I will go,"],[5766,6004,"I should see just how miserable she is"],[6100,6175,"without me."]],"24":[[579,754,"You're getting much stronger, Nessa."],[779,954,"I thought the general of our pack"],[954,1066,"would be a more formidable"],[1066,1154,"opponent than this."],[2254,2416,"Don't underestimate me just yet,"],[2445,2516,"Alpha Queen."],[3583,3683,"Hey, come on."],[3683,3795,"You really wanna do this again?"],[3954,4091,"I see you're both having fun."],[4266,4383,"Father, uh,"],[4408,4520,"Thorne is teaching me some"],[4520,4591,"new moves."],[4658,4770,"With Thorne by your side,"],[4783,4879,"I have no worries."],[4929,5041,"But the other packs of the kingdom"],[5041,5158,"are fighting with one another,"],[5158,5320,"trying to gain the Alpha Queen's"],[5320,5420,"first alliance treaty."],[5579,5691,"Including your ex-husband."],[5741,5816,"Oh really?"],[5929,6116,"Well, then I shall watch"],[6116,6295,"as they grovel at my feet."]],"25":[[1662,1720,"Justin,"],[1883,1983,"any word on Nessa?"],[2058,2133,"I'm sorry, Alpha."],[2200,2375,"We've exhausted all our intel but"],[2400,2558,"still no whereabouts of your"],[2620,2725,"former mate."],[2775,2845,"Nessa,"],[2937,3083,"you're nothing without me."],[4608,4670,"Hey, look."],[4708,4820,"There's Nessa over there."]],"26":[[250,400,"Slut."],[416,562,"She's kissing him?"],[566,687,"Oh, I told you"],[687,791,"she was cheating on you."],[891,1012,"Thank you for setting up"],[1012,1154,"my first alliance treaty today."],[1191,1262,"Of course."],[1325,1412,"Now you get in there"],[1412,1541,"and show them who's boss,"],[1554,1625,"the High Priestess"],[1625,1762,"will bring your secret weapon soon."],[1887,2025,"I will leave the stage"],[2050,2162,"to you now, my dear."],[3425,3537,"Let's see how"],[3537,3729,"you get out of this one, Nessa."],[4091,4212,"So you did cheat on me."],[4312,4437,"And with that old man?"],[4487,4625,"He still doesn't realize"],[4625,4762,"I'm Alpha Caelum's daughter,"],[4837,4937,"the Wolf Queen."]],"27":[[29,229,"You're so quick to jump to conclusions."],[283,420,"You're not leaving yet."],[491,604,"You're my slave."],[641,741,"You're coming back with me."],[916,983,"Excuse me?"],[1091,1254,"My son and I have no interest in"],[1254,1379,"being your chained slaves"],[1379,1508,"for another five years."],[1529,1695,"I ran away with you because I thought"],[1695,1804,"you would treat me right."],[1804,1879,"So what are you gonna do,"],[1879,2008,"run off with that old man?"],[2091,2166,"What is it, Nessa,"],[2170,2229,"honestly."],[2266,2304,"Money?"],[2379,2416,"Power?"],[2416,2666,"You think my dad is my new lover?"],[2695,2791,"Your dad?"],[2904,3066,"I think you mean sugar daddy."],[3104,3329,"Nessa, you are a wolfless,"],[3341,3566,"penniless orphan, remember?"],[3595,3716,"A wolfless orphan."],[3791,4020,"That's all you think of me when I gave up"],[4020,4158,"everything for you, Blaze?"],[4229,4441,"I'm never leaving with you again."],[4466,4633,"You're going to beg for me back"],[4633,4791,"as soon as I get this alliance treaty"],[4791,4870,"with the Alpha Queen."],[4916,5033,"It's gonna make me the second most"],[5033,5266,"powerful Alpha in all of the land."],[5429,5641,"Only the second most powerful?"]],"28":[[33,241,"Only the second most powerful?"],[270,370,"And that's more than a"],[370,483,"lowly orphan wolf"],[483,604,"like you could ask for."],[625,725,"You know you threw"],[725,866,"yourself onto my son,"],[866,966,"because you knew"],[966,1091,"he was going to become Alpha."],[1145,1241,"And now"],[1266,1479,"you sneak into this venue again,"],[1545,1704,"looking and seeking"],[1704,1879,"for a new sugar daddy?"],[2041,2258,"You are something else."],[2295,2441,"I was actually gonna take you back,"],[2516,2758,"but you're just a cheap slut."],[2833,2908,"And Britney,"],[3066,3116,"well,"],[3166,3304,"she'll make a better Luna"],[3329,3454,"than you ever could be."],[3466,3529,"So,"],[3633,3879,"you did make this snake your luna."],[3941,4066,"You deserve each other."],[4066,4141,"Bullshit!"],[4154,4304,"Oh, she's so much better"],[4304,4429,"than the trash you are."],[4504,4591,"You know, she comes with"],[4608,4666,"power"],[4708,4841,"and connections."],[4866,5141,"Oh, you're making me blush, Patricia."],[5195,5258,"You see,"],[5304,5416,"I pulled some strings"],[5416,5608,"to get our returning Wolf Queen's"],[5608,5820,"alliance treaty for Blaze."],[5870,6091,"You pulled some strings?"],[6191,6283,"Last I checked,"],[6304,6391,"the Wolf Queen"],[6391,6541,"hadn't made any announcements yet."],[6541,6633,"Oh, right."],[6654,6758,"I know you're just questioning it,"],[6758,6854,"because you're jealous."],[6895,6970,"But it's over."],[7054,7104,"Nessa,"],[7145,7270,"you missed out on your chance with me."],[7279,7441,"No, no."],[7491,7679,"You lost your chance to be with me."],[7766,7920,"I gave up my family,"],[7979,8220,"my wolf, my power to be with you."],[8241,8383,"And you never knew, Blaze."]],"29":[[12,145,"And you never knew, Blaze."],[145,283,"Oh, stop making shit up"],[283,383,"just because you're jealous of"],[383,520,"me and Britney, okay?"],[537,683,"I know you're doing all this just to"],[733,795,"one-up me."],[858,983,"Finding new sugar daddies"],[983,1200,"because you're weak and helpless"],[1220,1308,"all on your own."],[1350,1508,"Don't make me laugh."],[1608,1733,"I broke our mate-bond"],[1733,1958,"because you left our son to die."],[1983,2083,"While you were off saving"],[2083,2220,"some other woman's kid."],[2245,2308,"We did that"],[2308,2537,"because your son's life is worthless."],[2537,2745,"My son is worth thousands,"],[2833,3045,"millions times more than the price"],[3045,3220,"on both of your heads."],[3220,3387,"If he was worth something,"],[3387,3545,"you wouldn't have been our slaves"],[3545,3675,"the last five years."],[3720,3962,"I always kept these videos to laugh at."],[4383,4450,"Kaelib."],[4520,4600,"You..."],[4683,4887,"You recorded what you did to us?"],[5050,5195,"You are demented."],[5345,5445,"It's because you are"],[5495,5683,"too weak to protect him."],[5737,5858,"We should have just"],[5858,6012,"killed her son sooner,"],[6100,6250,"so she wouldn't have to suffer."]],"30":[[729,941,"Everything you put my son through,"],[1016,1154,"I will make you pay."],[3804,3870,"Alpha. - Alpha."]],"31":[[2733,2895,"Alpha Blaze of Ashclaw pack."],[2933,3033,"You're one of the strongest."],[3070,3170,"I look up to you."],[3387,3512,"What the hell is this crazy woman"],[3512,3695,"storming in to the Grand Summit for?"],[3758,3825,"Grand Elder."],[3845,3937,"Do something."],[4175,4308,"I'm the Grand Elder"],[4312,4450,"in charge of this summit."],[4537,4712,"Who are you?"],[4745,4875,"I don't recognize you"],[4875,5008,"as any of the known Lunas"],[5008,5100,"that we're inviting."],[5183,5333,"Everyone, listen up."],[5375,5470,"This woman is a"],[5470,5633,"high-power hungry whore."],[5633,5720,"A low-life!"],[5720,5887,"I bet she slept with someone"],[5887,6020,"to get into this summit."],[6020,6158,"I don't need to stoop so low"],[6158,6370,"to get into my own summit."],[6420,6570,"Enough, Nessa."],[6662,6820,"We all know you're doing this"],[6820,6920,"to get my attention."],[6945,7158,"So why don't you just apologize,"],[7183,7370,"beg, and uh,"],[7658,7870,"I might take you back as a side piece."],[7995,8095,"In your dreams."]],"32":[[16,212,"I might take you back as a side piece."],[341,450,"In your dreams."],[516,704,"You let these vile vermin"],[725,937,"hurt my son again and again."],[1050,1291,"You are worthless, Blaze."],[1400,1504,"Worthless?"],[1550,1691,"Blaze is about to receive"],[1691,1812,"the Queen's treaty."],[1837,2050,"He's the man of the hour."],[2070,2112,"Oh."],[2150,2250,"You sure about that?"],[2312,2375,"Nessa,"],[2375,2500,"you're embarrassing yourself"],[2500,2654,"by airing out our dirty laundry"],[2654,2779,"in front of all these people."],[2816,2962,"Nobody's on your side."],[3000,3087,"Yes."],[3116,3350,"Leave now before we make you."],[3454,3566,"We'll see who's embarrassing"],[3566,3737,"themselves soon enough."],[4587,4691,"What the hell is she doing?"],[4691,4787,"She's a nobody."],[4812,5012,"Someone throw her out already."],[5012,5291,"This summit is for pack leaders only."],[5500,5587,"Then I'm the rule."]],"33":[[54,279,"How dare you sit in that throne."],[295,441,"That throne is reserved"],[441,616,"for the most powerful Alphas"],[616,704,"of them all."],[704,754,"Yeah."],[904,1079,"Alpha Caelum of Stormcrest"],[1079,1216,"has found his daughter."],[1266,1429,"The legendary White Wolf."],[1470,1579,"And he's gonna announce"],[1579,1654,"who she is today."],[1679,1770,"That's right."],[1841,1941,"The Alpha will be"],[1941,2083,"handing over the crown to her"],[2083,2270,"and announce her as the Alpha Queen."],[2304,2483,"Good, can't wait."],[2516,2695,"To see your face when you realize"],[2695,2854,"what you've lost, Blaze."],[2904,3029,"You will be punished."],[3054,3233,"So step off of that throne now,"],[3266,3333,"Nessa."],[3441,3616,"Your wolfless rogue scent"],[3616,3816,"is gonna piss the Alpha Queen off."],[3841,4008,"And get us all in trouble."],[4066,4145,"Son,"],[4220,4529,"this scorned wench is trying to ruin you"],[4529,4679,"in front of the Alpha Queen."],[4695,4783,"Then you won't get"],[4783,4908,"that alliance treaty."],[4916,5083,"So leave, Nessa,"],[5191,5304,"before it's too late."],[5366,5491,"You know I can't protect you"],[5529,5691,"once the Alpha Queen arrives."],[5704,5866,"You just don't get it, do you?"],[5916,6079,"I don't need your protection."],[6166,6304,"The one you should all fear"],[6391,6466,"is me."]],"34":[[25,166,"The one you should all fear"],[262,329,"is me."],[362,429,"Ooh!"],[437,562,"We're so scared"],[562,675,"of how you're gonna keep"],[679,829,"leeching off of us."],[829,1079,"Like you did for the past five years."],[1100,1287,"You are wolfless,"],[1329,1387,"Nessa,"],[1450,1550,"don't you understand?"],[1600,1666,"With no wolf,"],[1666,1850,"you have no power in this world."],[1875,1991,"Just because you slept with some"],[2000,2150,"butler from Stormcrest,"],[2162,2266,"doesn't mean you can walk in here"],[2266,2400,"and act like you own the place."],[2400,2462,"Yeah."],[2587,2712,"Even though you've got the butler"],[2712,2812,"by your side,"],[2850,3062,"you're still nothing beside my son."],[3150,3329,"Because he's going to become"],[3329,3604,"contract allies with the Alpha Queen."],[3604,3875,"Oh, that's what you're counting on?"],[3941,4112,"Not even your own pack's strength?"],[4175,4316,"He still doesn't realize"],[4316,4437,"I'm the Alpha Queen."],[4475,4704,"Don't talk to Blaze like that."],[4766,5075,"My cousin, AKA, the Ambassador,"],[5087,5287,"is on their way right now"],[5287,5537,"with the Queen's treaty for Blaze."],[5550,5629,"That's right."],[5700,5812,"And after we have that,"],[5812,6012,"my pack will be unstoppable."],[6050,6200,"I wouldn't expect someone,"],[6291,6441,"a worthless runt like you"],[6500,6675,"to recognize how amazing"],[6704,6891,"of a specimen that I am."],[7037,7112,"Well then,"],[7250,7375,"why don't you show me,"],[7525,7629,"ex-husband?"]],"35":[[12,137,"Why don't you show me,"],[287,387,"ex-husband?"],[587,766,"I can crush you."],[775,1004,"Yeah, go on and do it, Blaze."],[1012,1141,"Before she pisses the rest of"],[1141,1337,"the Stormcrest pack off."],[1362,1587,"Yes, I stand by you, Alpha Blaze."],[1612,1812,"My pack is also with you, Blaze."],[1862,1912,"See?"],[1987,2175,"You're so screwed, Nessa."],[2216,2412,"The 3 most powerful packs"],[2412,2662,"after Stormcrest has united"],[2762,2866,"against you."],[2887,2987,"This is what you get"],[2987,3137,"for stepping out of place"],[3241,3387,"and staying on the low end."],[3387,3541,"You're just a sewer rat."],[3587,3700,"Get her, Blaze."],[3737,3787,"Well,"],[3937,4066,"don't let your fans down."],[4187,4254,"Okay then."],[4375,4612,"I guess you leave me no choice, Nessa."],[4612,4812,"I'll do it for you, Blaze."],[5287,5379,"Stop!"],[6225,6454,"General Thorne of Stormcrest?"]],"36":[[241,316,"General Thorne,"],[379,570,"Stormcrest's best fighter and son"],[570,708,"of the High Priestess."],[745,929,"Whoever dares"],[954,1116,"to put their claws on Nessa"],[1120,1241,"will have to face me."],[1404,1545,"He's a general?"],[1579,1629,"What?"],[1666,1829,"General Thorne would stand up"],[1829,2020,"for this wolfless rogue?"],[2041,2304,"I've never seen him do that before."],[2329,2483,"Then could she be someone important?"],[2495,2554,"Never."],[2720,2866,"Nessa has been our useless"],[2870,3054,"maid for the past five years."],[3066,3195,"She has no authority."],[3279,3395,"And that little tramp"],[3395,3495,"is sleeping with him."],[3529,3679,"That must be it."],[3716,3933,"Oh, how disgusting."],[3954,4129,"The lengths this woman will go"],[4129,4358,"to climb the ranks of the elite."],[4379,4554,"How many men have you slept with?"],[4616,4679,"Nessa?"],[4708,4854,"I know you come from nothing."],[4866,4970,"And you would do anything"],[4970,5070,"to sleep with anybody"],[5070,5216,"with an inkling of power."],[5229,5304,"But this?"],[5541,5654,"This is disgusting."],[5729,5895,"You all better shut your traps"],[5895,6029,"if you wanna leave here"],[6029,6141,"with your limbs still attached."],[6141,6279,"It's okay, Thorne."],[6404,6504,"They're small fry."],[6604,6708,"Don't waste your energy on them."]],"37":[[4,141,"It's okay, Thorne."],[287,387,"They're small fry."],[479,591,"Don't waste your energy on them."],[625,737,"Small fry?"],[837,941,"Just because you bring a new"],[941,1150,"boy toy in here to make me jealous,"],[1150,1300,"doesn't mean he's better than me."],[1425,1575,"Sorry, I wasn't trying."],[1612,1683,"But thanks for admitting"],[1683,1800,"that you're jealous."],[1850,1954,"Oh, shut up."],[2075,2154,"Blaze"],[2154,2275,"does not belong to you anymore."],[2325,2504,"He belongs with me."],[2612,2762,"And you, soldier boy."],[2825,2962,"When the Queen arrives,"],[2962,3241,"you will be fired for rebellion."],[3262,3475,"Yes, Nessa, don't push my limits."],[3512,3654,"I'm only being patient with you"],[3654,3812,"because you once gave me a son."],[4025,4175,"Once gave you a son?"],[4241,4391,"A son that you abandoned."],[4391,4537,"It is an embarrassment"],[4575,4737,"for an Alpha of my stature"],[4762,4912,"to mate with a wolfless"],[4912,5025,"rogue like you."],[5112,5237,"You didn't deserve me then,"],[5266,5379,"and you sure as hell"],[5379,5466,"don't deserve me now"],[5466,5629,"that I have the Queen on my side."],[5662,5725,"You're the one"],[5725,5879,"who's not good enough for me"],[5916,6000,"or my son."]],"38":[[33,170,"When you abandoned your son,"],[220,358,"did you not know"],[358,558,"that he was the son of someone"],[720,925,"truly amazing?"],[987,1108,"You don't get to talk."],[1120,1300,"You're just another boy toy she's using,"],[1300,1433,"just like she used me."],[1487,1583,"Oh, I promise you,"],[1583,1745,"once I have the Queen on my side,"],[1745,1908,"she'll smite both of you."],[1937,1995,"Yeah,"],[2012,2225,"no one is above the Alpha Queen."],[2250,2475,"You two are in deep shit."],[2562,2670,"They really don't know"],[2670,2820,"they're about to meet their end,"],[2845,2908,"do they?"],[2995,3133,"They're none the wiser."],[3345,3433,"Quit laughing."],[3550,3670,"Pissing off the Alpha Queen"],[3670,3800,"is not a laughing matter."],[3945,4045,"You're right about that."],[4058,4137,"Therefore,"],[4183,4333,"you should start worrying about"],[4333,4470,"the future of your pack."],[4525,4587,"Because"],[4662,4729,"you won't have a future"],[4729,4800,"here much longer."],[4895,5145,"Oh, you talk big."],[5250,5333,"But aren't you two here to"],[5333,5470,"kiss the Queen's ass?"],[5508,5583,"Yes."],[5620,5770,"She has the White Wolf,"],[5808,5908,"the most powerful"],[5908,6075,"wolf according to legend."],[6075,6195,"No one dares challenge her."],[6220,6395,"She can destroy ten kingdoms."],[6395,6520,"without lifting a finger."],[6558,6683,"Then you better do something"],[6683,6800,"to appease her soon."]],"39":[[58,175,"Then you better do something"],[175,295,"to appease her soon."],[308,345,"No,"],[412,520,"I don't think we will."],[562,645,"Because we already have the"],[645,783,"Queen's treaty in the bag."],[795,1000,"And, yeah, because my cousin"],[1000,1108,"is the ambassador"],[1108,1245,"of the Grand Council,"],[1270,1420,"the Queen's right-hand man."],[1483,1570,"Ambassador?"],[1600,1712,"Don't think I know him."],[1770,1883,"But I guess he works for me."],[1937,2050,"And you wanna know how"],[2087,2237,"I won the Queen's favor?"],[2245,2408,"I gave her as tribute"],[2437,2558,"the most powerful"],[2558,2833,"magical item in all of existence."],[2833,3045,"Yeah, and do you not know that?"],[3070,3150,"In order to be"],[3150,3295,"granted into the summit,"],[3295,3525,"you must offer tribute to the Queen."],[3608,3870,"Grand Elder, kick Nessa out."],[3870,4058,"She has nothing to offer."],[4112,4175,"Yes."],[4258,4445,"That is only fair."],[4470,4650,"You never gave anything"],[4662,4870,"to our son after all these years."],[4937,5037,"And here you are"],[5070,5170,"bragging about giving"],[5170,5333,"some gift to a stranger?"],[5408,5520,"Have you no shame?"],[5583,5679,"I'd kiss the floor"],[5679,5833,"that the Queen walked on,"],[5875,6050,"if it meant I get this treaty."],[6087,6233,"He wants my treaty?"],[6300,65