0,"Good."],[3979,4062,"It's a deal."],[4141,4254,"And if I lose,"],[4350,4587,"I will willingly cut off"],[4641,4762,"all of my limbs."],[4912,5112,"Be careful what you wish for, Nessa."],[6262,6350,"Behold,"],[6462,6654,"the gift that guarantees"],[6691,6950,"my alliance with the Alpha Queen."]],"42":[[345,387,"That's..."],[525,645,"Ashclaw Pack's heirloom."],[662,808,"The Impenetrable Armor."],[820,1070,"Wolves literally die fighting over it."],[1133,1350,"Whoever has it is as good as invincible."],[1370,1570,"That's why Ashclaw Alphas are"],[1583,1745,"almost undefeatable."],[1783,1987,"All these territorial disputes,"],[2062,2275,"but no one can land a paw"],[2275,2437,"on the Ashclaw Alpha."],[2437,2500,"That's right."],[2545,2870,"This is a one-of-one magical item,"],[2887,3095,"forged by the legendary craftsmith,"],[3108,3245,"Hephaestus himself."],[3283,3408,"And I'm offering it as tribute"],[3408,3495,"to my loyalty"],[3670,3787,"to the Alpha Queen."],[3858,3920,"Heirloom?"],[4195,4308,"Meaning something you should"],[4308,4458,"be passing on to our son,"],[4495,4570,"but instead,"],[4620,4745,"you're giving it to someone else?"],[4758,4858,"You're just jealous"],[4858,5045,"you can't measure up, Nessa."],[5058,5133,"See?"],[5208,5520,"I told you she's a blood-sucking leech."],[5587,5808,"That is what makes Blaze"],[5808,6050,"the second-most powerful Alpha."],[6050,6262,"And you are nowhere close to that."],[6283,6437,"Mythical armor like this"],[6495,6633,"is only befitting"],[6675,6870,"for the one and true"],[7100,7195,"Alpha Queen."],[7345,7508,"I can't wait to see his face"],[7508,7675,"when he realizes the Alpha Queen"],[7675,7920,"he so reveres is actually you."],[8283,8408,"Looks like Blaze"],[8408,8583,"wins this show of power."],[8858,9008,"I haven't even started yet."],[9075,9200,"High Priestess should be here"],[9200,9308,"in about two minutes"],[9308,9462,"with my secret weapon."]],"43":[[25,154,"High Priestess should be here"],[154,275,"in about two minutes"],[275,412,"with my secret weapon."],[462,666,"If you give up and leave now,"],[687,850,"we'll only cut off"],[1004,1287,"three of your limbs instead of four."],[1329,1450,"Just so you can, you know,"],[1450,1587,"have one extra to spoonfeed"],[1587,1704,"that runt of yours."],[1704,1900,"You have nothing on us, Nessa."],[1916,2100,"So why don't you apologize now,"],[2129,2225,"before my queen"],[2225,2354,"gets here to smite you."],[2354,2554,"Yeah, you don't belong here."],[2600,2875,"Oh, and what if I have is"],[2912,3200,"more powerful and more magical?"],[3341,3525,"You'd get real jealous then."],[3579,3675,"You seem so keen"],[3675,3837,"and confident to continue,"],[3904,4037,"why don't we up the stakes then?"],[4066,4241,"If it's more ways of how you'd like"],[4241,4387,"my limbs severed, I'm-"],[4387,4562,"I want our son, Kaelib back."]],"44":[[41,183,"You want our son?"],[229,516,"After you abandon him to die"],[558,679,"for some other woman?"],[691,779,"First off,"],[816,966,"I didn't know he was my son then."],[983,1079,"And second off,"],[1104,1366,"he'll be better off being raised by me."],[1408,1516,"You're powerless,"],[1541,1704,"you sleep around for protection."],[1741,1816,"And honestly,"],[1883,2020,"I don't think Kaelib should have"],[2020,2191,"a whore for a mother,"],[2191,2266,"do you?"],[2341,2420,"Unbelievable."],[2491,2641,"I would give my life to save"],[2641,2766,"and protect Kaelib."],[2779,2991,"Sexual favors are cheap"],[3020,3208,"for a bottom-feeder like you."],[3208,3366,"What right do you have to say that"],[3366,3541,"you'd be a better parent, Blaze?"],[3616,3766,"You are putting his life"],[3766,3866,"on the betting table."],[3895,3983,"Because,"],[4033,4191,"everybody who's somebody"],[4229,4341,"says that I can."],[4379,4558,"Yeah, give Alpha Blaze his son back."],[4579,4766,"A whore like you can't raise a child."],[4766,4933,"Give his son back!"],[4945,5091,"Give his son back!"],[5104,5516,"Give his son back. - Pray! Silence!"]],"45":[[20,375,"Give his son back. - Pray! Silence!"],[508,658,"The wolves have roared"],[658,837,"in favor of Alpha Blaze."],[933,1112,"You know you can't keep your son"],[1112,1275,"hidden from us forever."],[1300,1458,"I'm taking my son back,"],[1470,1583,"and I'm raising him better"],[1583,1720,"than you ever could."],[1770,1858,"After we win,"],[1900,2008,"we will exile you"],[2045,2283,"and you will never see him ever again."],[2320,2370,"No."],[2520,2808,"I will never let you hurt my son again."],[3370,3433,"It's time."],[3850,4033,"Bring in my secret weapon."],[4070,4329,"High Priestess arrives!"]],"46":[[54,254,"High Priestess, welcome."],[466,575,"What the heck."],[612,712,"That's the High Priestess,"],[800,875,"the most knowledgeable"],[875,1062,"elder of the entire kingdom."],[1300,1404,"Did Nessa"],[1416,1562,"just order the High Priestess"],[1562,1650,"around like that?"],[1662,1750,"No, there's no way that"],[1750,1912,"Nessa has that type of authority."],[1925,2075,"She was just my slave."],[2087,2237,"This must be a coincidence."],[2266,2400,"She just snaps her fingers"],[2400,2525,"and the High Priestess shows up"],[2525,2629,"at the spur of the moment?"],[2654,2712,"That's right."],[2775,2975,"She probably caught wind of this slut"],[2975,3091,"destroying her venue."],[3125,3300,"Came here to punish Nessa herself."],[3354,3441,"Isn't that right?"],[3462,3529,"Oh no."],[3550,3791,"If the High Priestess is angry,"],[3862,3954,"the Wolf Queen"],[3954,4104,"will be even more upset."],[4125,4366,"The High Priestess serves the Queen."],[4375,4450,"That's right."],[4462,4562,"That means we need to"],[4562,4762,"take Nessa down now."],[4775,4966,"This will be your end, Nessa."],[4979,5112,"You are a disappointment"],[5112,5212,"of a mother."],[5229,5325,"You are weak."],[5387,5500,"You are powerless."],[5516,5766,"And I am taking my son back."],[6200,6450,"How dare you speak to her like that."]],"47":[[25,237,"How dare you speak to her like that."],[241,312,"What the hell?"],[316,512,"So you're the damn fool,"],[537,666,"who betrayed Nessa."],[675,975,"When Nessa had me seal her wolf,"],[975,1129,"so she ran away with you."],[1362,1475,"What are you talking about?"],[1475,1637,"I've never heard anything about this."],[1637,1875,"She's the Wolf Queen, you idiot!"],[2150,2250,"That's impossible."],[2266,2387,"You tossed her aside,"],[2441,2612,"as she was a dirty shoe."],[2637,2766,"You don't deserve her."],[2816,2891,"There's no way that"],[2891,3025,"Nessa is the Alpha Queen."],[3054,3225,"She's just a wolfless orphan."],[3225,3441,"No, no family, no connections."],[3475,3587,"Absolutely."],[3587,3700,"Zero power."],[3716,3841,"She's helpless."],[3887,4037,"She's just been scraping by,"],[4037,4166,"by sleeping with more powerful"],[4166,4291,"wolves for protection."],[4341,4487,"Nobody trust this woman."],[4566,4666,"I know what happened."]],"48":[[29,216,"Nessa slept with Thorne."],[229,433,"And Thorne is the High Priestess' son,"],[441,533,"which means"],[533,808,"she's just protecting her son's whore."],[820,1016,"That must be it, Luna Britney."],[1041,1154,"They're all colluding."],[1183,1258,"That's a crime!"],[1283,1404,"She's betraying the council!"],[1429,1541,"High Priestess,"],[1541,1779,"I am disappointed to see"],[1779,2041,"you've sunk so low."],[2054,2341,"Together, the other Alphas and I"],[2366,2508,"will vote to see you"],[2508,2683,"stripped of your position."],[2704,3304,"Strip her power!"],[3316,3516,"How dare you! - Strip her power!"],[3608,3695,"Do you have any idea"],[3695,3791,"who- - It's okay."],[3841,3929,"High Priestess."],[3958,4141,"You've done me a great service."],[4191,4308,"They will all be punished,"],[4379,4604,"when they realize who I truly am."],[4641,4704,"Bullshit!"],[4733,4891,"You've got nothing on us,"],[4891,4979,"when we're receiving"],[4979,5120,"the Queen's alliance treaty."],[5145,5254,"You and your boy toy"],[5254,5354,"and your boy toy's mom"],[5354,5570,"are gonna rot in the sewer."],[5604,5679,"And I won't be there"],[5679,5783,"to save you this time."],[5783,5916,"And I won't be able to save you"],[5916,6058,"from your embarrassment,"],[6066,6241,"that's about to dawn on you"],[6254,6329,"any second."],[6333,6479,"How can she be so confident?"],[6479,6641,"What does she have up her sleeve?"],[6854,7058,"You suck up to the Alpha Queen,"],[7116,7304,"because you want to be seated"],[7358,7541,"next to the pinnacle of power."],[7691,7816,"Well, Blaze,"],[7829,7895,"let me show you"],[7895,8016,"exactly what you lost,"],[8016,8129,"when you abandoned me"],[8141,8316,"and our son to die."]],"49":[[183,362,"Is that the mythical Artemis Bow?"],[387,470,"It is said"],[550,670,"that millennia ago,"],[720,820,"the moon"],[895,1050,"was just an asteroid"],[1133,1320,"falling towards the Earth."],[1345,1408,"But then,"],[1445,1608,"a powerful she-wolf"],[1608,1970,"shot it back out into space."],[2012,2145,"That she-wolf"],[2145,2408,"became the moon Goddess."],[2458,2545,"And this"],[2633,2775,"is the bow she used."],[2808,2958,"That's impossible."],[2958,3133,"I thought that was just a legend."],[3158,3212,"How do you think"],[3212,3412,"the Stormcrest pack became so strong?"],[3583,3658,"This"],[3770,3995,"heirloom impenetrable armor"],[4008,4137,"of yours is nothing"],[4150,4287,"compared to what I have."],[4320,4420,"And this"],[4433,4562,"is what I'm going to pass on"],[4562,4633,"to our son."],[4645,4720,"No."],[4787,4887,"No, no, no, no, no, no."],[4887,4987,"How can that be?"],[5045,5158,"That's a mythical item"],[5158,5337,"only the Alpha Queen could acquire."],[5337,5437,"I know she slept with"],[5437,5525,"basically everybody,"],[5525,5670,"but how the hell did she get that?"],[5683,5825,"Exactly, Blaze."],[5833,5920,"Do you see now?"],[6033,6245,"What you lost when you betrayed me?"],[6245,6325,"No!"],[6358,6458,"Don't be fooled."],[6495,6620,"This must be a copy."],[6637,6770,"Nessa lost her wolf,"],[6783,6920,"so how could she"],[6920,7075,"have the most powerful weapon"],[7075,7270,"that only the Alpha Queen wields?"],[7270,7433,"The truth is right in front of you."],[7445,7520,"Who I really am."],[7520,7770,"The power that I have over you."],[7883,8033,"You just don't wanna believe it."]],"50":[[4,141,"You just don't want to believe it."],[150,250,"Nonsense."],[279,454,"If Nessa is powerful enough"],[454,570,"to have one of these,"],[595,745,"then how come she was in chains"],[745,904,"for the last five years."],[933,1079,"I watched her and her son"],[1079,1254,"clean toilets, eat scraps,"],[1254,1395,"and not one peep."],[1416,1479,"Thank you"],[1529,1641,"for reminding me"],[1641,1866,"what you put me and my son through."],[2079,2279,"It's survival of the fittest."],[2291,2454,"No wolf means you're the lowest"],[2454,2620,"of the lows, Nessa."],[2620,2758,"You don't even rank high enough to"],[2758,2929,"talk to me, Britney."],[3104,3208,"Stand down."],[4170,4279,"Are you glad, Blaze?"],[4279,4520,"To see that I am powerful enough"],[4529,4845,"to protect and support my son?"],[4883,5016,"No, I'm not."],[5016,5158,"Because that's a fake."],[5179,5291,"You haven't been able to"],[5291,5429,"defend yourself this whole time."],[5429,5641,"Remember, I saved you six years ago."],[5641,5795,"And that's why I fell for you,"],[5829,5879,"Blaze."]],"51":[[141,287,"And that's why I fell for you,"],[329,379,"Blaze."],[554,662,"Why I loved you."],[700,900,"But you abandoned both me"],[950,1050,"and our son."],[1125,1237,"When in reality,"],[1375,1462,"I don't need you."],[1512,1712,"No, this is all a scheme."],[1729,1862,"Still don't believe me?"],[1937,2025,"Then I will just have to"],[2025,2154,"punish you first,"],[2312,2479,"as the Alpha Queen!"],[3175,3250,"Stop!"],[3304,3416,"Ambassador Crowley"],[3416,3650,"of the Grand Council has arrived!"],[3729,3929,"I come bearing an important message."],[4000,4075,"The Alpha Queen"],[4075,4191,"and Alpha Caelum"],[4237,4375,"have signed an alliance treaty,"],[4566,4700,"with the Ashclaw Pack."]],"52":[[62,212,"Congratulations, Alpha Blaze."],[241,362,"You are the first ally"],[362,425,"the Queen has"],[425,537,"formed an alliance with."],[562,729,"My cousin, the Ambassador"],[729,925,"of the Grand Council, pulled through."],[962,1087,"And I'm sure"],[1087,1212,"the Queen was impressed"],[1212,1362,"by your gifts of armor."],[1375,1537,"I'm so proud of you, son."],[1600,1829,"We are truly unstoppable now."],[1850,2000,"You see this, Nessa?"],[2062,2212,"The Queen chose me."],[2262,2337,"That means you weren't"],[2337,2416,"a Queen at all."],[2425,2525,"Just a nobody."],[2537,2612,"That's right."],[2612,2850,"Now sink down and beg for mercy."],[2862,3029,"Or else we'll tell the Alpha Queen,"],[3029,3204,"that you're trying to pose as her."],[3241,3504,"And Queen Alpha will be so furious."],[3575,3712,"Maybe she'll rip off"],[3712,3850,"your limbs herself."],[3991,4125,"Ambassador Crowley"],[4125,4266,"was just assigned to his position"],[4266,4366,"in recent years,"],[4400,4537,"so he won't recognize you."],[4600,4850,"Even then, I never gave the order."],[4954,5125,"There seems to have been a mistake"],[5200,5325,"and I better correct it."],[5637,5725,"Hephaestus."],[5741,5837,"You have three minutes"],[5837,5962,"to get over here"],[5991,6216,"and destroy the Ashclaw Pack's"],[6237,6437,"sole source of power."]],"53":[[575,687,"You have three minutes"],[687,808,"to get over here"],[833,1083,"and destroy the Ashclaw Pack's"],[1083,1262,"sole source of power."],[1395,1487,"The Queen,"],[1550,1658,"needs me!"],[1733,1833,"Hephaestus?"],[1858,2058,"The mythical, magical craftsman"],[2058,2212,"of weapons and armor?"],[2225,2395,"How could she know how to contact him?"],[2408,2595,"He's been known to be off-the-grid."],[2620,2700,"He is."],[2800,2983,"But I have a direct line open to him."],[2983,3025,"No."],[3037,3145,"Bullshit."],[3195,3383,"She was just talking to ocean waves."],[3570,3795,"Aw, Nessa, haven't you heard about"],[3795,3975,"the poor girl who cried wolf?"],[4062,4195,"We ate her alive."],[4270,4470,"We have the Queen's treaty now,"],[4483,4720,"we can punish her however we want."],[4733,4895,"Let's turn her and her son"],[4895,5045,"into wolf stew."],[5108,5162,"Yeah."],[5233,5383,"Rejoice now while you still can."],[5487,5633,"Because I will be having"],[5633,5808,"the last laugh."]],"54":[[20,120,"Alright, fine."],[120,308,"Let's wait three minutes for this"],[312,758,"magical, mystical Hephaestus to come."],[770,875,"And you know, and then"],[875,1050,"let's see if you have the last word."],[1050,1145,"I think you forget."],[1187,1370,"Hephaestus was the one who created"],[1370,1495,"my Impenetrable Armor."],[1533,1712,"He oils my plates every year."],[1733,1895,"And he would never show up"],[1895,2112,"to a wolfless nobody like you."],[2145,2283,"Well, I am so glad"],[2320,2475,"that you will all recognize him."],[2633,2833,"You are so confident,"],[2862,2970,"because you think you have"],[2970,3133,"the Alpha Queen's treaty,"],[3162,3508,"because of this cheap, junk armor"],[3725,3883,"that Hephaestus made."],[3958,4145,"When he shows up,"],[4220,4475,"he'll let you all know why I"],[4525,4600,"can do"],[4683,4762,"this."],[5712,5887,"No! - Oh my God."],[5987,6070,"Oh."],[6158,6212,"Oh."],[6400,6500,"The treaty."],[6500,6670,"No, Blaze, the power."],[6675,6737,"No!"],[6775,6845,"No!"]],"55":[[8,79,"You..."],[129,295,"you are so dead!"],[704,854,"Get our fastest horse ready."],[883,1045,"The Queen is summoning us!"],[1045,1129,"Yes, Master."],[1279,1354,"Make haste."],[1429,1558,"I am still sitting"],[1629,1716,"in this throne."],[1791,1941,"Very much alive."],[1979,2191,"You better enjoy your last breaths."],[2204,2316,"I'm only keeping you alive"],[2316,2454,"because once the Alpha Queen"],[2454,2516,"gets here,"],[2591,2729,"what she's going to do to you,"],[2779,2891,"you can't even fathom!"],[2891,3229,"Our sponsor is the real Alpha Queen."],[3254,3395,"Not a fraud like you."],[3395,3620,"She'll chop you into pieces."],[3620,3820,"And feed you to her children."],[3820,4008,"And she'll burn your skull"],[4054,4179,"into ashes."],[4179,4366,"And your poor, helpless son"],[4366,4495,"will be an orphan!"],[4495,4670,"We'll have him as our slave again"],[4670,4966,"and torture him day and night!"],[5183,5266,"Your impudence"],[5266,5395,"knows no boundaries."],[5408,5508,"But I promise you,"],[5508,5666,"as soon as that door opens,"],[5733,5820,"your smile"],[5904,6066,"will be permanently erased"],[6066,6195,"from this world."]],"56":[[0,50,"You know,"],[50,229,"I think the Alpha Queen and I"],[229,404,"will be best friends."],[412,600,"Only the shrewd gets power."],[600,887,"And that's why you were born wolfless."],[887,1062,"You'll be weak and pathetic"],[1062,1312,"and destined to be preyed upon by us,"],[1312,1379,"the predators."],[1379,1500,"Shut your fucking mouth."],[1504,1604,"The more you talk,"],[1625,1729,"the deeper you're digging"],[1729,1787,"your own grave."],[1787,1887,"By the time you're done,"],[1900,2012,"it'll be fifty feet."],[2500,2587,"What's that?"],[3037,3279,"Sounds like a powerful queen"],[3279,3441,"coming in here to punish you."],[3525,3641,"You're about to meet your end."]],"57":[[670,895,"Your Highness, my Goddess Queen,"],[933,1158,"thank you so much for the treaty."],[1175,1458,"Yes, my Queen, I'm endlessly grateful"],[1470,1620,"that you chose me to be your retainer."],[1645,1850,"But- - That lowlife bitch."],[1895,2058,"She ripped up your scroll."],[2087,2212,"Your Majesty, please,"],[2283,2383,"will you punish them?"],[2500,2558,"Sounds like"],[2558,2687,"you're a little bit in a pickle."],[2695,2795,"Are you gonna punish me?"],[2795,2970,"Your Majesty, do as you please,"],[2970,3095,"but as long"],[3133,3283,"as I get the alliance treaty."],[3295,3445,"It doesn't matter if Nessa"],[3470,3733,"was with my son as his former mate."],[3770,3837,"Yeah, yeah,"],[3837,3958,"their bond has been broken"],[3958,4070,"and they're nothing now."],[4125,4237,"Wow, a mate-bonded"],[4237,4375,"by the Moon Goddess herself?"],[4433,4520,"Sounds like it would hurt."],[4533,4745,"It did, but I would do anything for you."],[4795,4983,"I guess you'll have to punish me, Lily."],[5037,5083,"Wait,"],[5120,5325,"my rejected ex-wife"],[5433,5562,"knows the Alpha Queen?"],[6008,6183,"Welcome, Master Hephaestus."]],"58":[[50,287,"That wench actually summoned,"],[337,500,"the ancient and mystical"],[500,675,"Master of the Forge?"],[687,762,"That man has made"],[762,912,"so many legendary weapons."],[925,1087,"Excalibur and Mjolnir."],[1137,1187,"Wait,"],[1266,1554,"this caveman is Hephaestus?"],[1604,1725,"He looks like a hired actor."],[1766,1887,"Hired actors?"],[1900,1987,"Are you sure?"],[1987,2166,"Well, yeah, I mean, look at him."],[2166,2312,"He's so poor and ugly,"],[2312,2450,"and he's wearing loincloth."],[2450,2525,"Britney!"],[2591,2700,"Shut up."],[2700,2816,"No, that does make sense."],[2887,3004,"These must be hired actors."],[3025,3104,"Yeah, well,"],[3104,3237,"now that you all agree with me"],[3237,3387,"and that it's just a scheme,"],[3387,3450,"they're trying to"],[3450,3575,"pull an alliance together."],[3591,3637,"I say,"],[3637,3850,"we throw all of these buffoons out."],[3887,3966,"Throw them out!"],[4012,4487,"Throw them out!"],[4487,4550,"Ah!"],[4691,4850,"How dare you insult my master."],[4925,5225,"You puny little brat."],[5225,5412,"You just slapped me?"],[5441,5641,"I am the future Luna."],[5687,5837,"Blaze, do something."],[5854,6137,"No, no, we, we, we can't."],[6187,6250,"She actually"],[6250,6375,"summoned Hephaestus."],[6675,6804,"It's an honor to serve you,"],[6837,7037,"my almighty Alpha Queen!"]],"59":[[0,125,"No, no, no way in hell"],[125,275,"is Nessa the Alpha Queen."],[295,420,"That is Hephaestus."],[487,637,"He doesn't bow to just anybody."],[670,725,"Shit."],[725,833,"Did I fuck up?"],[833,933,"It's true."],[1000,1137,"That is Hephaestus."],[1137,1420,"He made Blaze's impenetrable armor."],[1420,1495,"What?"],[1520,1575,"This?"],[1825,1937,"Ah, this was supposed to be"],[1937,2058,"a toy for my dog."],[2075,2295,"But it didn't quite fit the pup."],[2325,2445,"It's trash to me."],[2795,2850,"How can you just throw"],[2850,3025,"my legendary armor like that?"],[3320,3458,"Legendary?"],[3520,3583,"Oh my boy,"],[3695,3858,"you really don't know your stuff."],[3858,3970,"By the way, my queen."],[4008,4208,"Your magical weapons,"],[4262,4408,"it create storms."],[4437,4595,"Outside I saw a hurricane"],[4620,4850,"that blew away all the Ashclaw guys."],[4858,4908,"What?"],[5520,5795,"And that's Blaze calling for our pack."],[6125,6195,"Justin."],[6245,6300,"Alpha."],[6320,6533,"There was a hurricane"],[6562,6708,"that killed all our men."],[6733,6808,"Justin."],[6845,6945,"Justin, stay with me."],[6975,7070,"Stay with me."],[7283,7358,"Oops."],[7383,7583,"This is all your fault, Nessa!"]],"60":[[12,120,"Looks like your plot"],[120,225,"to become the new Luna"],[225,358,"of the Ashclaw pack"],[383,587,"has gone up in flames, Britney."],[587,750,"You can't become the ruler"],[750,920,"with no subjects to rule."],[920,1012,"I still don't believe"],[1012,1120,"you're the Alpha Queen."],[1120,1208,"And that hurricane"],[1208,1333,"was just a coincidence."],[1333,1458,"Ambassador Crowley,"],[1595,1683,"that stamp of approval"],[1683,1837,"of the Queen's treaty was real."],[1837,1983,"And that can't be fake."],[2045,2133,"I... uh..."],[2158,2375,"Yes, how did you do this?"],[2462,2650,"Father, I want to give Thorne's"],[2650,2820,"original pack my first treaty."],[2825,2933,"Brilliant decision, my dear."],[3083,3208,"Have you prepared the treaty,"],[3208,3250,"Crowley?"],[3258,3420,"The treaty is prepared."],[3570,3620,"Good."],[3675,3712,"My daughter,"],[3712,3812,"the future Alpha Queen,"],[3812,3937,"will be very happy."],[4495,4658,"Britney told me to get this"],[4658,4770,"treaty for Ashclaw pack."],[4850,5012,"This is the only way I can do it."],[5095,5270,"Blaze is a remarkable alpha,"],[5270,5379,"I'm sure the Queen wouldn't"],[5379,5500,"have a problem with this anyway."],[5708,5808,"I never actually saw"],[5808,5925,"the Alpha Queen herself."],[6025,6087,"What?"]],"61":[[191,370,"Then you must have swindled my father,"],[370,441,"Alpha Caelum."],[441,516,"No, I didn't."],[516,754,"Alpha Caelum signed that treaty himself"],[770,883,"and approved it."],[883,1054,"I'm dead if they find out"],[1054,1229,"I did trick the Alpha Queen's father."],[1229,1404,"Besides, you're the fraud here."],[1404,1508,"Just because I didn't see"],[1508,1629,"the Alpha Queen herself,"],[1629,1754,"does not mean you can bully me"],[1754,1833,"into admitting a crime"],[1833,1904,"I didn't commit."],[1933,2116,"Ah, I get it now."],[2166,2291,"Since the Queen's father"],[2291,2408,"approved the treaty..."],[2920,3016,"That means"],[3058,3329,"we are now in the Queen's favor."],[3416,3470,"That's right."],[3470,3645,"The Queen wouldn't disobey her father."],[3716,3779,"That means,"],[3866,3991,"you're just a fraud."],[4041,4233,"Then how would you explain"],[4254,4358,"Hephaestus?"],[4416,4516,"Well, that's easy."],[4541,4733,"It's because Nessa slept with him."],[4816,4970,"Oh my God."],[5091,5208,"You're disgusting."],[5229,5333,"Is that your explanation"],[5333,5416,"for everything?"],[5429,5554,"You'd rather think the worst of me,"],[5554,5729,"than believe I could be better than you."],[5754,5904,"Enough, Nessa."],[5995,6108,"We all know you're just doing this"],[6108,6266,"to get back at me and Britney."],[6308,6366,"Okay?"],[6366,6458,"I don't know what kind of"],[6458,6629,"sexual favors you had to trade"],[6629,6754,"to put on this show,"],[6783,6891,"and act like some kind of"],[6920,7133,"special magical deity-"],[7133,7341,"Well, if you can't see that the Alpha Queen"],[7341,7458,"is right in front of you,"],[7495,7641,"I know a way to prove"],[7641,7816,"that Nessa is the Alpha Queen."]],"62":[[12,108,"I have a way of proving"],[108,295,"that Nessa is the Alpha Queen."],[308,395,"Speak up, my man."],[420,470,"What is it?"],[483,645,"This bowstring"],[670,800,"requires a nine hundred"],[800,908,"pound drawforce"],[925,1158,"to pull and shoot an arrow."],[1183,1312,"Only the Alpha Queen"],[1312,1462,"with her white wolf powers"],[1462,1633,"is born with that strength."],[1645,1770,"Even I struggle"],[1820,1945,"and I made this."],[1945,2133,"Nine hundred pounds?"],[2200,2308,"A typical bow only"],[2308,2475,"requires forty pounds."],[2475,2662,"That's an insane amount of force."],[2670,2875,"Even I can draw a bowstring"],[2875,3133,"maximum of eighty pound drawforce."],[3158,3312,"Nessa was born a weakling."],[3320,3470,"There's no way that she could do it."],[3470,3725,"Unless she's the Alpha Queen."],[3800,3983,"Then what do we say we play a game?"],[3987,4120,"To see who can shoot"],[4120,4320,"from this mythical-tier bow."],[4370,4620,"Oh, I don't believe all this bow thing."],[4620,4758,"Anyone can do it."],[4770,4833,"Oh yeah?"],[4933,5120,"Then why don't you try, Britney?"]],"63":[[0,95,"Why don't you try?"],[104,179,"What?"],[191,254,"Me?"],[254,395,"I think somebody's scared."],[416,691,"I'm not scared of a little archery."],[741,1004,"I just don't wanna mess up my nails."],[1083,1191,"You forget."],[1204,1366,"Britney is the most powerful"],[1366,1516,"she-wolf in our pack."],[1654,1954,"Show Nessa who the better match is"],[1954,2133,"for my son, Britney."],[2154,2408,"Well, if I must."],[2470,2554,"Remember,"],[2570,2679,"a full draw is,"],[2695,2916,"holding one arm out extended fully,"],[2916,3079,"and then taking the drawstring"],[3079,3279,"and pulling it back behind your ear."],[3354,3445,"I know what I'm doing."],[3466,3583,"Don't underestimate her."],[3608,3758,"She has phenomenal aim,"],[3791,3991,"she's the best assassin in our pack."],[4029,4179,"In fact, she was the one"],[4179,4391,"who shot our last enemy Alpha."],[4420,4641,"Oh, then she definitely won't lose."],[5433,5616,"What the hell is this thing made of?"],[6083,6229,"This fucking thing is useless."],[6229,6429,"Blame the archer, not the bow."],[6429,6579,"All right, give her a break."],[6579,6708,"Okay, she's just a lady."],[6708,6766,"She doesn't have"],[6766,6883,"the best upper body strength."],[6883,7008,"Excuses."],[7016,7179,"Would anyone else like to try"],[7191,7354,"before I prove my might?"],[7383,7479,"I will."]],"64":[[66,120,"Whoa."],[120,216,"I didn't know the Grand Elder"],[216,316,"was this buff."],[316,466,"You know nothing, kid."],[504,704,"The Grand Elder was a true warrior."],[704,829,"His power matching that of"],[829,991,"the entire Stormcrest pack"],[991,1083,"back in the day."],[1083,1354,"This will be easy as crushing an ant."],[2529,2666,"Only one inch."],[2679,2883,"Oh my goodness."],[2883,3083,"Not even far enough to hit a fly."],[3129,3383,"Let me try again."],[4191,4329,"Kudos for trying, my guy."],[4354,4466,"Two inches."],[4629,4795,"He's just old, he's not this prime."],[4833,4908,"Well, then."],[5016,5070,"Blaze?"]],"65":[[8,254,"If anyone can do it, you can."],[304,379,"Thank you, Mother."],[395,541,"While the others may have struggled,"],[591,733,"this will be pretty easy for me."],[820,941,"I am in my prime."],[970,1104,"I'm not a weak girl."],[1129,1229,"Sorry, Nessa."],[1708,1904,"That was a lot harder than I expected."],[1970,2033,"Why?"],[2079,2204,"What's holding you up?"],[2220,2316,"Embarrassment?"],[2333,2508,"Hey, stop distracting him."],[2508,2629,"You can do it, Blaze."],[2629,2716,"You got this."],[3504,3579,"Better."],[3629,3729,"Four inches."],[4091,4145,"Damn it."],[4279,4470,"That was all of the strength that I had."],[4479,4641,"That wasn't a full draw, though."],[4695,4833,"It has to be brought back"],[4833,5016,"all the way to your ears."],[5033,5216,"Try again, Alpha Blaze?"],[5258,5354,"All of my strength"],[5354,5579,"and I can only pull back four inches."],[5666,5829,"I don't have another pull in me."],[6016,6229,"Now, it's my turn."],[6416,6533,"Ah!"]],"66":[[179,316,"Ah, don't shoot."],[325,425,"There's no way."],[479,575,"I don't believe it."],[600,712,"There's no way she got it."],[712,912,"Hephaestus says only the Alpha Queen"],[912,1025,"can draw that bowstring."],[1025,1212,"That means Nessa is the Alpha Queen."],[1287,1412,"Oh, we are so screwed."],[1412,1529,"We pissed her off."],[1529,1637,"We're gonna be exiled"],[1637,1779,"from the kingdom, son!"],[1904,2075,"Oh, one single arrow,"],[2075,2175,"and you're already shaking"],[2175,2262,"in your boots?"],[2262,2325,"No."],[2362,2450,"Not yet."],[2466,2550,"This shit again?"],[2604,2787,"What crazy thing do you have to say now?"],[2787,2966,"You just have the mythical craftsman"],[2966,3100,"Hephaestus on your side."],[3100,3200,"He probably put some trickery"],[3200,3312,"on that bowstring."],[3329,3375,"Yeah."],[3450,3562,"It was probably some sort of"],[3575,3662,"black magic."],[3700,3787,"He kept messing with it"],[3787,3879,"every time we tried."],[3879,3925,"Yeah."],[3925,4037,"Yeah, so if this hobo"],[4037,4125,"doesn't touch it again,"],[4125,4229,"maybe Blaze could actually"],[4229,4337,"draw this bowstring."],[4512,4641,"I love this."],[4787,4937,"I love how you all jumped through"],[4937,5091,"so many hoops"],[5091,5279,"to try to prove that you are worthy."],[5375,5529,"But I am already bored"],[5562,5716,"with this cat and mouse game, so"],[5812,5975,"let's put an end to this."],[6054,6262,"With a life and death"],[6341,6450,"challenge."]],"67":[[100,191,"You say"],[200,337,"someone tampered with my bow?"],[404,462,"Well then,"],[475,687,"let me put on your armor"],[687,775,"and you"],[829,962,"can shoot me."],[1100,1250,"Let's see if I can survive this."],[1250,1404,"Nessa is so gutsy,"],[1450,1537,"no wonder she's destined"],[1537,1637,"to be the Alpha Queen."],[1650,1779,"She's fearless."],[1791,1975,"Well, if you're asking for death,"],[1975,2112,"we won't deny you that."],[2129,2362,"Oh, I'm so excited to watch."],[2362,2450,"Do it, Blaze."],[2525,2604,"Shoot her."],[2687,2929,"She's humiliated us enough."],[2937,3054,"Can I really do this?"],[3087,3262,"Nessa is still the mother of my child."],[3262,3337,"Oh, you know what?"],[3404,3579,"I think I'll blindfold myself too."],[3612,3750,"Do you want me to tie you up too?"],[3800,4012,"That is a great idea, Thorne."],[4066,4262,"Blaze, if I'm not afraid,"],[4333,4425,"then why are you?"]],"68":[[8,237,"Using all of the strength in my body,"],[237,383,"I can barely keep this bow"],[383,470,"from dropping."],[495,645,"How did Nessa pull the drawstring"],[645,770,"so easily like that?"],[787,900,"Come on, Blaze."],[908,1075,"This is your time for revenge."],[1083,1250,"Come on, Blaze, finish her off."],[1275,1408,"Then we'll be in the Queen's favor"],[1408,1575,"and be totally unstoppable."],[1662,1783,"I'm waiting, Blaze."],[2300,2450,"Oh, right, my bad."],[2462,2491,"That has a"],[2491,2633,"nine hundred pound drawforce."],[2695,2833,"Hephay, you might need to"],[2833,2945,"do something about that."],[2975,3120,"Yes, of course, my Queen."],[3783,4008,"You can now load and fire this bow."],[4083,4258,"Look who needs assistance now,"],[4295,4383,"Alpha Blaze?"],[4383,4595,"I am not a weakling."]],"69":[[241,370,"Come on, Blaze, you can do it."],[379,445,"Kill her!"],[554,691,"Avenge your manhood."],[691,883,"Avenge our pack!"],[908,1008,"Do it, Blaze."],[1058,1141,"Nessa?"],[1270,1408,"Do you remember how we met,"],[1433,1483,"Blaze?"],[1616,1729,"You saved me."],[1920,2058,"We had good memories once,"],[2058,2254,"but that is now the distant past."],[2291,2408,"In the past five years,"],[2454,2620,"you thought I cheated on you,"],[2708,2908,"that Kaelib wasn't your son."],[3020,3283,"You made us chained slaves."],[3283,3441,"Daddy, help me."],[3458,3616,"No, no, Blaze!"],[3916,4029,"Our mate-bond"],[4104,4204,"is broken."],[4366,4545,"I do not love you anymore."],[4641,4758,"The old me that you had wrapped"],[4758,4941,"around your finger is gone."],[4991,5079,"So please,"],[5179,5304,"put an end to this"],[5366,5520,"one way or another,"],[5520,5766,"and I will rise from the ashes."],[5829,5991,"I just have one question to ask you."],[6120,6295,"Did you ever cheat on me?"],[6333,6416,"Shoot."],[6591,6691,"And you'll find out."],[8754,8879,"That's the White Wolf."],[8979,9108,"The legendary Alpha Queen."]],"70":[[845,995,"The legendary Alpha Queen."],[1416,1591,"That's for not believing me."],[1708,1945,"You only care about your pride,"],[1966,2120,"whether or not I cheated on you."],[2166,2308,"I never did."],[2354,2454,"You're the White Wolf."],[2454,2545,"You're the mythical"],[2683,2754,"Wolf Queen."],[2791,2841,"No way."],[2841,2966,"Nessa's the Wolf Queen?"],[2966,3066,"What have we done?"],[3079,3191,"We've pissed her off."],[3191,3295,"And tortured her son."],[3316,3458,"We kept her as a slave."],[3470,3541,"Fuck!"],[3604,3791,"And you're from the Stormcrest pack."],[3833,3920,"That's why our son"],[3954,4095,"has the Stormcrest mark."],[4141,4258,"You never cheated on me."],[4291,4416,"I'm such an idiot!"],[4529,4729,"So, you finally realized."],[5004,5104,"Alpha Caelum."],[5145,5233,"You've arrived."],[5233,5329,"And you're fired"],[5345,5445,"from the Grand Council"],[5445,5554,"for letting my daughter"],[5570,5679,"be harassed."],[6004,6120,"I hereby announce"],[6166,6295,"that I'm passing on my crown"],[6295,6554,"to my daughter, Nessa Stormcrest."],[7416,7654,"Nessa is the new Alpha Queen."],[8116,8316,"Yay, mommy."],[8429,8491,"Kaelib!"],[8679,8720,"You're my son."],[8791,9029,"But you are not my dad."]],"71":[[8,187,"You are not my dad."],[233,312,"Help me."],[637,725,"You didn't want me,"],[758,1008,"so I don't want you anymore."],[1020,1120,"He deserves it."],[1158,1270,"It is your own undoing"],[1270,1362,"that you lost Nessa."],[1437,1600,"All the power you ever wanted"],[1620,1770,"to make up for whatever it is"],[1770,1862,"that you're lacking."],[1883,2070,"She could have shared it all with you."],[2108,2183,"So thank you"],[2237,2395,"for all the terrible things you've done."],[2470,2558,"Because without that,"],[2637,2720,"I never would have realized"],[2720,2833,"my full potential."],[2858,2950,"And I"],[2995,3170,"never would have had the opportunity"],[3220,3425,"to win Nessa's heart over."],[3437,3570,"I lost everything."],[3645,3720,"My pack,"],[3750,3925,"my powers, my family, my son."],[3958,4170,"And it is all because of one person."],[4258,4320,"It was Britney."]],"72":[[12,91,"It was Britney."],[91,154,"What?"],[162,204,"Not me."],[204,337,"I didn't do anything."],[354,462,"She is the one"],[475,666,"behind the North Star Pack's attack."],[725,900,"She's also the one,"],[900,1012,"who killed your brother."],[1204,1279,"That was you?"],[1279,1500,"Here is all the evidence"],[1500,1591,"that proves it."],[2250,2400,"I swear to the Moon Goddess."],[2416,2575,"I had nothing to do with this."],[2591,2662,"This was all Britney."],[2662,2741,"It was all her idea."],[2741,2866,"Yeah, she had me start turmoil"],[2866,2937,"with the packs"],[2937,3100,"because she wants to become Luna."],[3125,3262,"Don't rat me out now!"],[3266,3400,"You're my baby's daddy."],[3775,3825,"Too late."],[3900,3975,"You already said it."],[4125,4229,"You tricked us?"],[4229,4337,"We all believed that"],[4337,4562,"your son was our next heir."],[4587,4754,"We treated you like royalty."],[4754,4929,"You fed us all those lies"],[4937,5112,"and turned us against Nessa."],[5212,5387,"You were just too dumb to realize."],[5412,5579,"It is not my fault."],[5587,5650,"Enough!"],[5787,5912,"You have made a mess"],[5912,6041,"of my ceremony today."],[6087,6162,"Exile them."],[6200,6362,"Think about the way they treated you,"],[6387,6454,"when they thought"],[6454,6600,"you were just wolfless rogues."],[6625,6750,"Good suggestion, Thorne."],[6816,7054,"I hereby banish"],[7087,7279,"the Ashclaw Pack from this land."],[7312,7487,"If you survive, bravo."],[7575,7700,"But if you perish"],[7700,7862,"in the harsh conditions,"],[8004,8079,"then so be it."],[8137,8300,"Survival of the fittest, baby."]],"73":[[58,120,"No!"],[204,254,"Please."],[354,420,"Nessa."],[579,816,"I'm too old and feeble."],[941,1054,"I wouldn't survive out there"],[1054,1166,"without a pack."],[1229,1304,"Please!"],[1358,1504,"Spare me!"],[1633,1779,"I will be your slave"],[1779,1904,"for the rest of my life."],[1945,2008,"Please."],[2016,2145,"Did you not think about that"],[2145,2279,"when you were mistreating Kaelib,"],[2333,2483,"a helpless five year old?"],[2529,2579,"Nessa."],[2641,2691,"Kaelib."],[2795,2895,"I'm so sorry."],[3033,3133,"I mistreated you."],[3154,3229,"I'm sorry for everything"],[3229,3333,"I put you guys through."],[3333,3445,"Everything that I did was"],[3541,3679,"absolutely unforgivable."],[3704,3804,"It was all his fault."],[3833,4091,"We were swayed by this scumbag idiot!"],[4091,4195,"Yeah, we didn't know any better."],[4208,4266,"Please."],[4266,4391,"You're the almighty Alpha Queen."],[4391,4479,"Please spare us."]],"74":[[0,91,"Oh, damn it."],[91,266,"I was so close to having everything."],[291,416,"I could have been Luna!"],[541,783,"You are all parasites."],[891,1104,"You are all banished."],[1116,1208,"No!"],[1216,1329,"Beat, beat him up."],[1329,1383,"Your fault."],[1383,1445,"Beat him up!"],[1991,2054,"Stop it!"],[2066,2191,"They're an eyesore."],[2191,2279,"Take them away."],[2308,2379,"Nessa,"],[2416,2541,"we could've had everything together."],[2541,2683,"I, I threw it all away."],[2683,2716,"No."],[2716,2770,"Please."],[2791,2854,"I regret it!"],[2854,2929,"I'll, I'll regret it"],[2929,2987,"for the rest of my life!"],[2987,3141,"No! Please stop!"],[3183,3295,"Nessa!"],[3358,3533,"No!"],[3545,3591,"Save it."],[3654,3729,"Now,"],[3858,3929,"where were we?"],[3966,4045,"Everyone."],[4091,4454,"The new Alpha King and Queen."]]}