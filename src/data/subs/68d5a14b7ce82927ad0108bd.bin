{"1":[[2477,2544,"Look babe,"],[2544,2706,"we're just like Jack and Rose."],[2752,2819,"Titanic."],[3069,3174,"You jump, I jump."],[3432,3541,"You promise?"],[3586,3661,"Always."],[3874,3891,"Ah."],[4029,4070,"Thank you."],[4170,4225,"To future."],[4379,4446,"To future."],[5793,5864,"Give me a second."],[5943,6001,"Are you okay?"],[6014,6060,"Yeah."],[6623,6681,"Mia!"],[6873,6936,"You jump."],[7086,7203,"I don't."],[7494,7611,"Let go, Ryan!"],[7937,8041,"Your company,"],[8095,8187,"your empire!"],[8458,8583,"It's all mine now, baby."],[9939,10130,"I am Ryan Chase,"],[10168,10322,"the CEO of the Chase Corporation."],[10402,10598,"Youngest billionaire under 30 in Forbes."],[10660,10773,"My fiancée,"],[10831,11019,"Mia, tried to murder me."],[11019,11102,"She poisoned me,"],[11102,11261,"pushed me off the yacht."],[11307,11578,"I survived, but I lost my voice,"],[11578,11674,"my empire,"],[11728,11824,"my life."],[11928,12203,"But fate threw me a lifeline,"],[12291,12420,"a girl with no voice,"],[12424,12641,"but the kindest soul I've ever met."],[14894,14960,"Are you okay?"],[15611,15753,"She saved me,"],[15874,16045,"gave me a second shot at life."],[16403,16491,"Are you okay?"]],"2":[[16,91,"I'm like you."],[191,337,"I can't speak either."],[825,913,"But losing your voice"],[913,1130,"doesn't mean surrendering to life."],[2277,2373,"What's in here"],[2469,2544,"speaks louder"],[2544,2656,"than your voice ever could."],[3023,3190,"My diner needs some extra hands."],[3190,3315,"Just the grunt work."],[3428,3536,"Pays crap, but..."],[3661,3795,"at least it comes with a bed."],[3883,4041,"Better than sleeping next to garbage."],[6856,6890,"Mia."],[6977,7186,"You stole my company."],[7253,7349,"Tried to kill me."],[7457,7570,"This isn't over."],[7674,7791,"I'll make you pay."],[8166,8224,"Cheers."],[8233,8295,"Woo."],[9413,9451,"Oh."],[9509,9592,"What's that smell?"],[9592,9705,"I don't know, what's that?"],[9822,9851,"Oh!"],[9889,9964,"Smells so bad!"],[10439,10502,"Sophia,"],[10556,10727,"are you out of your fucking mind?"],[10769,10919,"This isn't a soup kitchen."],[10952,11065,"You can't go bringing"],[11065,11219,"bums into my diner!"],[11282,11398,"He's not a bum!"],[11536,11611,"He just..."],[11715,11807,"He needs a job."],[11920,12045,"Well, he looks like roadkill."],[12082,12132,"Oh."],[12166,12212,"Jesus,"],[12212,12458,"that smell could clear out a sewer."],[12520,12654,"Get him the hell out of here!"],[12816,12862,"Hello?"],[12933,13013,"Anyone there?"],[13125,13209,"What makes you think"],[13209,13300,"you can come in here,"],[13329,13434,"smelling like death,"],[13434,13555,"like, like a corpse,"],[13555,13717,"even flies wouldn't touch."],[13763,13880,"Are you trying to scare off"],[13880,14018,"my customers or something?"]],"3":[[100,200,"He can work."],[312,392,"He's tough."],[462,629,"Tougher than anyone I've met."],[692,742,"Tough?"],[859,1009,"He's a goddamn sewer rat."],[1038,1101,"Look at him."],[1159,1388,"He's too filthy to even mop the floor."],[1422,1555,"He can scrub toilets,"],[1555,1634,"lift crates,"],[1634,1814,"even fix the busted faucet"],[1814,1935,"in the back, right?"],[1985,2156,"Get him the hell out of here."],[2185,2477,"I won't have trash sticking up my diner."],[2477,2515,"Aw!"],[2660,2819,"You ungrateful brat!"],[2986,3203,"I feed you, I house you."],[3261,3374,"And this is how you want to show"],[3374,3520,"your appreciation?"],[3536,3661,"One more stunt like that,"],[3695,3903,"and you're sleeping on the curb tonight."],[4800,4979,"Free labor?"],[4988,5121,"What's going on here?"],[5643,5805,"You have any job experience, kid?"],[6322,6473,"We're short-staffed around here."],[6577,6639,"You're hired."],[8249,8387,"Ryan's reign is over."],[8470,8533,"Now,"],[8692,8850,"this is my empire."],[9959,10039,"Ms. Vaughn,"],[10122,10193,"you have no right"],[10193,10331,"to set foot in Chase Corp"],[10331,10439,"without board approval."]],"4":[[41,137,"You sure about that?"],[200,271,"Last I checked,"],[271,396,"I was the sole heir of"],[396,492,"Chase Corporation."],[550,621,"Ryan's missing,"],[688,750,"not dead."],[825,925,"The board hasn't authorized"],[925,1055,"a transfer of ownership."],[1080,1126,"Missing?"],[1201,1347,"He's been gone for two months."],[1418,1572,"I think you're living in a fantasy world."],[1634,1805,"Even if he were dead,"],[1839,1939,"you'd still get nothing."],[2010,2185,"You're his fiancée,"],[2252,2318,"not his heir."],[2527,2598,"Fiancée?"],[2656,2715,"Please,"],[2740,2886,"we've been married for months."],[3098,3428,"As of today, I'm Mrs. Ryan Chase,"],[3470,3749,"the legal heir of this entire empire."],[3816,3870,"Funny."],[3899,3978,"Last I'd heard,"],[4020,4091,"he hadn't even bought you"],[4091,4183,"an engagement ring."],[4270,4350,"Now you're married."],[4362,4454,"We kept it hidden."],[4567,4738,"He didn't want the media"],[4738,4929,"poking around in our lives."],[5067,5138,"Let me see that."],[5993,6068,"You psycho!"],[6081,6197,"Chase Corporation"],[6218,6406,"plays by just one rule."],[6506,6614,"If Ryan's alive,"],[6669,6748,"he's the king."],[6856,6936,"If he's dead,"],[7023,7186,"his company burns to the ground"],[7186,7365,"before it ever falls into your hands."],[7820,7924,"One more word,"],[7941,8133,"and I spray this lobby red"],[8145,8262,"with your brains!"]],"5":[[41,104,"Try it."],[166,275,"You pull that trigger,"],[333,458,"and our legal team will make sure"],[458,583,"that you spend the rest of your life"],[583,696,"scrubbing toilets,"],[742,855,"in a federal prison."],[1689,1856,"Activate the contingency plan."],[1914,2139,"If Ryan doesn't show in three days,"],[2218,2364,"continue with the takeover."],[2681,2811,"Three days, Thomas."],[2840,2952,"That's your countdown."],[3457,3649,"Word out to every news outlet,"],[3678,3845,"I'm putting out a $10,000,000 bounty."],[3899,3983,"Find"],[3983,4058,"the"],[4058,4124,"boss."],[4141,4183,"Now!"],[6218,6297,"Keep it, kid."],[6318,6427,"It's been two months."],[6493,6669,"Go get yourself some decent clothes."],[6748,6819,"Thank you."],[7278,7357,"Get a haircut."],[7449,7549,"You'll look handsome."],[7645,7828,"What the hell are you giving money"],[7828,7949,"to the bum for?"],[7991,8183,"He agreed to no pay."],[8254,8404,"He's still an employee, Diane."],[8404,8516,"You wanna him to work for free?"],[8558,8692,"You agreed!"],[8779,8879,"He wants money,"],[8888,9171,"he can get the hell out!"],[9342,9459,"You wanna defend yourself?"],[9576,9722,"Speak up!"],[9980,10256,"You pathetic mute freak."],[10577,10719,"Ryan's not pathetic!"],[10781,10877,"That's enough, Diane."],[10898,11011,"One step too far."],[11106,11182,"Am I wrong?"],[11215,11353,"Oh, please."],[11353,11469,"Don't tell me you're feeling"],[11469,11649,"sorry for him now."],[11703,11828,"Why don't you just go ahead"],[11828,11999,"and marry him off to Sophia then?"],[12049,12349,"Let the two mute misfits rot together."],[12612,12666,"Fine!"],[12762,12841,"We'll get married!"],[13108,13221,"And my whole paycheck"],[13221,13288,"goes to him!"]],"6":[[58,137,"This is rich."],[150,404,"You want to marry a bum?"],[613,754,"You must be as stupid"],[754,859,"as your mother."],[867,980,"That's enough, Diane!"],[1142,1197,"Sophia,"],[1209,1372,"I'm not gonna let you do this."],[1459,1559,"You might be different, but..."],[1659,1776,"you deserve better than him."],[1789,1872,"Way better."],[1951,2177,"Oh, wake up already, James!"],[2218,2298,"This bum"],[2314,2477,"is the best Sophia's ever gonna get."],[2677,2815,"Dad, I'm not embarrassed of him."],[2907,3044,"He works tough days,"],[3078,3211,"and he never complains."],[3265,3390,"Compare that to the men who,"],[3399,3486,"who mock me."],[3528,3611,"Sophia,"],[3628,3799,"your wedding day should be-"],[4212,4275,"A real wedding"],[4275,4416,"doesn't need a five-star hotel."],[4512,4671,"Just someone who treats me right."],[4796,4934,"At least he doesn't make fun of me"],[4934,5100,"for being mute behind my back."],[5234,5355,"Sorry, I failed you."],[5467,5559,"I couldn't even protect"],[5559,5643,"my own daughter."],[5726,5814,"If you hadn't..."],[5880,6010,"pulled me out of that alley,"],[6056,6151,"I'd be dead."],[6206,6427,"Now it's my turn to protect you, Sophia."],[6815,6919,"I swear."],[7032,7232,"I'll protect you with my life."],[7824,7874,"Fine."],[7949,8083,"Take your precious paycheck,"],[8137,8387,"and get the hell out."],[8466,8633,"Let's see how long the two of you"],[8650,8800,"can last in the real world."]],"7":[[208,300,"Wow!"],[371,542,"Have you always been this hot?"],[713,913,"Well, I'm all yours."],[3757,3824,"Thank you."],[3941,4024,"For showing me"],[4024,4158,"I deserve to be loved, too."],[4216,4262,"No."],[4354,4441,"Thank you."],[4675,4808,"For making me feel human again."],[7887,7941,"What?"],[8116,8208,"Oh, I see."],[8341,8425,"Finally realizing"],[8425,8616,"your husband's actually a stud?"],[8896,9013,"Guess I hit the jackpot."]],"8":[[225,304,"Two months after"],[304,425,"the mysterious disappearance"],[425,684,"of Wall Street titan Ryan Chase,"],[684,784,"the Chase Corporation"],[784,971,"has issued a $10,000,000 reward"],[971,1096,"for any information."],[1117,1167,"James!"],[1213,1343,"James, get in here!"],[1847,1926,"Sophia!"],[2314,2377,"Sophia!"],[2544,2727,"Get your butt down here!"],[3449,3603,"Wait, are you the"],[3641,3795,"billionaire who vanished?"],[3870,4033,"Who you really are?"]],"9":[[325,383,"Ryan,"],[442,579,"are you really a billionaire?"],[579,667,"The Chase Corporation"],[667,846,"has announced, if Ryan Chase"],[846,1063,"remains missing after 24 hours,"],[1063,1309,"the asset transfer will be finalized."],[1309,1372,"Shit."],[1372,1497,"If I reveal myself now,"],[1497,1614,"my entire revenge plan"],[1614,1697,"goes up in smoke."],[1726,1810,"But if I don't reach Thomas"],[1810,1918,"before the deadline..."],[1989,2047,"Nah."],[2089,2152,"Not me."],[2214,2335,"I see the resemblance though."],[2398,2498,"I knew it."],[2552,2581,"You?"],[2606,2694,"A billionaire?"],[2740,2811,"Please."],[2844,2973,"You're not even worth the gum"],[2986,3103,"under my shoe."],[3119,3215,"I still can't believe"],[3215,3432,"you married this broke leech."],[3432,3524,"What a joke."],[3570,3624,"Please."],[3687,3828,"Don't talk about Ryan like that."],[3903,4099,"Kitty's got claws."],[4099,4362,"You two really are a perfect pair."],[4408,4642,"A leech and a loser."],[4675,4879,"Wasn't enough to eat our food"],[4879,5121,"and sleep under our roof, was it?"],[5142,5271,"You had to go and con Sophia"],[5271,5392,"into marrying you too."],[5497,5547,"You must think"],[5555,5734,"we're pretty stupid, huh?"],[5739,5855,"That's enough, Diane!"],[5905,5964,"Ignore her."],[5985,6139,"This place, this diner,"],[6139,6293,"it was always meant for Sophia."],[6302,6356,"What!"],[6381,6544,"You're leaving it to her?"],[6573,6773,"Me and my late wife built this diner."],[6773,6961,"It was always meant for Sophia!"],[7019,7144,"Bullshit!"],[7178,7244,"Who do you think's been"],[7244,7298,"keeping this place"],[7298,7411,"running all these years!"],[7449,7565,"You're gonna leave it to"],[7586,7757,"two broke losers"],[7757,7953,"who can't even afford the rent?"],[8124,8204,"You really think that"],[8204,8337,"they can keep it running?"]],"10":[[29,166,"That's enough, Diane!"],[200,371,"This diner was built by Sophia's mom."],[392,508,"It belongs to her."],[529,642,"What about me!"],[684,867,"What about Mike, my son!"],[884,1076,"That's already been settled."],[1247,1363,"The diner goes to Sophia."],[1376,1530,"The savings account goes to Mike."],[2039,2352,"Over my dead body."],[2414,2615,"They both belong to my son!"],[2665,2769,"As for you,"],[2806,2927,"you can start picking your"],[2927,3023,"double shifts."],[3048,3140,"And you can crawl back"],[3140,3340,"into whatever gutter you came out of."],[3657,3766,"They are my family."],[3832,3953,"Don't you dare!"],[4016,4133,"Marrying you"],[4216,4508,"was the biggest mistake of my life!"],[4959,5005,"Dad?"],[5088,5196,"Dad, are you okay?"],[5376,5593,"Take a good look, honey."],[5647,5889,"This diner belongs to you"],[5939,6076,"and me."],[6114,6172,"What?"],[6185,6239,"When?"],[6289,6368,"Last year,"],[6402,6539,"while you were in the hospital."],[6589,6777,"We had the deed changed."],[6810,7111,"Now you two pack up your little bags,"],[7123,7432,"and get the hell out of my diner!"],[7507,7578,"Diane!"],[8825,9034,"All the subsidiary accounts are frozen."],[9050,9159,"And here are"],[9159,9325,"the transfer documents, ma'am."],[9509,9630,"In 12 hours,"],[9630,9859,"everything Ryan Chase ever owned,"],[9859,9947,"will be mine."],[10064,10164,"All of it."]],"11":[[525,638,"The surgery your father needs"],[638,784,"would cost a million dollars."],[1001,1101,"He's uninsured."],[1121,1305,"No payment, no procedure."],[1393,1459,"Please."],[1472,1597,"You can't let him die."],[2227,2289,"Diane!"],[2323,2435,"She has the money!"],[2494,2548,"Honey,"],[2569,2598,"wait."],[2615,2665,"I'll beg."],[3178,3324,"Please, I am begging you."],[3340,3420,"He needs the surgery."],[3420,3490,"And the doctor said that"],[3490,3599,"it would cost a million."],[3699,3837,"So you've come crawling back."],[3874,3924,"You know,"],[3924,4008,"you could have begged like this"],[4008,4170,"when your daddy was giving away"],[4179,4329,"my son's diner."],[4400,4550,"He's going to die!"],[4562,4625,"Please!"],[4679,4767,"Then let him die."],[4842,4921,"When he's gone,"],[4959,5084,"everything's mine anyway."],[5100,5192,"This diner."],[5221,5321,"This cash."],[5367,5451,"All mine."],[5518,5705,"Why don't you start a GoFundMe page"],[5705,5764,"or something?"]],"12":[[446,538,"Tell me you found Ryan."],[558,754,"We've searched every private jet log,"],[754,896,"every hotel, every port."],[934,1001,"He's vanished."],[1001,1076,"Keep looking!"],[1130,1213,"I don't care if you have to dig"],[1213,1334,"through every alley in New York!"],[1472,1609,"That psycho Mia's already"],[1609,1735,"planning her victory party."],[2097,2289,"If I go back now, it's over."],[2323,2623,"But I will not let Sophia suffer."],[2731,2932,"Are you gonna hit me?"],[3053,3148,"Go ahead."],[3186,3278,"Try it."],[3315,3557,"I'll have the police here so fast,"],[3557,3753,"it will make your head spin."],[4216,4287,"You know,"],[4350,4517,"I should have sent you away"],[4571,4758,"a long time ago."],[5376,5714,"Don't touch my wife!"]],"13":[[16,312,"Don't touch my wife!"],[379,554,"You can talk!"],[721,775,"Big deal."],[813,913,"So you can speak."],[950,1080,"You want that money so badly?"],[1096,1201,"Why don't you go beg"],[1201,1309,"for it on the street?"],[1334,1468,"It's what you're good at, right?"],[1580,1659,"I'll work for free"],[1659,1743,"for the rest of my life."],[1743,1906,"Please, just save my dad."],[2039,2106,"Aww."],[2114,2285,"So touching!"],[2335,2506,"But not my problem."],[2531,2744,"As you said, without that surgery,"],[2773,2890,"your daddy's gonna die."],[2940,3090,"And when he does,"],[3090,3178,"you're not getting"],[3178,3415,"a single cent from me."],[3457,3532,"You know you're not gonna"],[3532,3653,"get away with this, right?"],[3728,3974,"You're threatening me?"],[4041,4112,"Keep it up,"],[4170,4350,"and I'll dump the both of you out"],[4350,4600,"back for the rats to pick clean."],[4658,4721,"Don't hurt him!"],[4750,4871,"Let's go, we're leaving right now."],[5747,5818,"You're finished."],[6644,6856,"One more hour, and this entire"],[6873,7169,"billion-dollar empire is mine."],[7828,7978,"Three hundred people searching."],[8037,8149,"All of New York."],[8174,8279,"And you're telling me"],[8329,8608,"that we still found nothing."],[9342,9530,"Thomas, it's me."],[9601,9667,"I'm back."]],"14":[[20,75,"Sir,"],[112,191,"where are you?"],[229,287,"We'll have a car"],[287,396,"sent to you immediately."],[458,617,"I can't leave right now, Thomas."],[638,688,"But I need you to"],[688,779,"send me a million dollars."],[779,875,"I need you to do it right now."],[938,1105,"Sir, what do you mean you"],[1105,1213,"can't leave?"],[1259,1363,"You've got 10 minutes"],[1363,1518,"before Mia takes everything."],[1547,1647,"I'm still recovering."],[1964,2285,"Wow, such dramatics!"],[2306,2385,"Oh, oh, wait."],[2398,2640,"Let me guess your tragic backstory."],[2656,2823,"You faked an injury,"],[2823,3048,"so that you could beg for money,"],[3048,3098,"hmm?"],[3290,3374,"Are you okay?"],[3778,3862,"As for Mia,"],[3924,4066,"initiate Protocol Zero."]],"15":[[187,329,"Mr. Chase, are you sure?"],[404,558,"That would split the ownership shares"],[558,746,"between all 37 executives."],[759,892,"Your ownership would tank"],[892,1005,"below 10%."],[1055,1113,"Now."],[1234,1301,"Also, Thomas,"],[1301,1418,"I'm gonna write a public letter,"],[1476,1559,"describing every detail"],[1559,1685,"of my disappearance."],[1726,1864,"I'm trusting you to handle it."],[1906,1968,"Understood."],[2043,2147,"I'll take care of it personally."],[2285,2398,"But Mia's already signing."],[2398,2656,"Do what the CEO says."],[2686,2736,"Now."],[3132,3261,"Well, you're committed to the bid,"],[3261,3378,"I'll give you that."],[3411,3557,"Protocol zero?"],[3632,3732,"What do you think you are?"],[3732,3958,"Some Wall Street king or something?"],[4062,4175,"What makes you think I'm not?"],[4241,4387,"Well okay, Mr. Wall Street."],[4421,4679,"You produce one million dollars"],[4679,4821,"right here, right now,"],[4859,5280,"and I'll apologize on my knees."],[5438,5534,"Three minutes."],[5559,5672,"You're gonna be on your knees"],[5672,5797,"apologizing to my face."]],"16":[[262,316,"Faster."],[362,446,"Almost there."],[446,521,"Come on."],[521,638,"Come on, big money."],[700,817,"10 more seconds."],[1468,1555,"What the hell's happening?"],[1622,1718,"System access."],[1926,1997,"We're locked?"],[2039,2131,"We've been frozen!"],[2173,2273,"Are you fucking kidding me?"],[2373,2456,"It was one second."],[2510,2698,"It was one goddamn second!"],[2723,2819,"Unlock it!"],[2831,2886,"Now!"],[2902,3098,"Or I swear both of you are fired."],[3461,3541,"They can't"],[3591,3661,"unlock it."],[3787,3862,"Thomas."],[3928,4124,"Of course, you again."]],"17":[[45,116,"On the day that"],[116,283,"Chase Corporation was founded,"],[304,450,"Ryan drafted something called"],[504,600,"Protocol Zero."],[880,955,"Once triggered,"],[988,1117,"all assets are frozen."],[1176,1280,"Shares redistributed."],[1326,1509,"No one touches a thing."],[1589,1730,"Ryan planned this?"],[2202,2331,"He was planning this"],[2448,2548,"from day one."],[3353,3465,"This isn't over."],[3516,3586,"Did you hear me?"],[3628,3720,"None of you"],[3795,3870,"are safe."],[4429,4542,"I'm sending you an account."],[4592,4717,"Wire one million into it."],[4763,4875,"What should I list it under?"],[4917,5017,"Let's just say,"],[5080,5201,"reward money for information"],[5201,5301,"on Mr. Chase."],[5601,5730,"Three minutes?"],[5759,5955,"You couldn't cough up 50 bucks,"],[5955,6227,"if you had three years."],[6252,6493,"Well, if Sophia hadn't gone soft,"],[6493,6606,"you would still be eating"],[6606,6773,"out of dumpsters."],[6827,6902,"Two minutes."],[7052,7136,"Let's just go."],[7182,7282,"Forget the money."],[7390,7536,"What's the matter?"],[7549,7691,"Losing your nerve?"],[7728,7941,"Can't keep the act going, hmm?"],[8037,8103,"One minute."],[8133,8350,"This is comedy gold."],[8379,8550,"Now, tell us, Mr. Wall Street,"],[8600,8767,"what magic trick is going to"],[8767,8958,"produce this one million dollars"],[8958,9138,"in the next 60 seconds?"]],"18":[[871,1092,"Honey, I told you,"],[1230,1518,"nobody is gonna hurt you ever again."],[1597,1830,"This can't be real!"],[1830,1926,"You promised."],[1960,2043,"What promise?"],[2106,2223,"Apologize."],[2256,2377,"On your knees."],[2410,2464,"Now!"],[3219,3294,"Let's just go."],[3536,3691,"Dad's surgery is what's important."],[3791,3862,"I'm sorry."],[4170,4262,"Let's get out of here."],[5263,5442,"You think you've won?"],[5513,5559,"No."],[5689,5814,"James' money"],[5893,6006,"is mine."]],"19":[[579,692,"Sophia."],[963,1051,"I swear,"],[1051,1213,"I will never let anything bad"],[1213,1334,"happen to you again."],[1718,1789,"James!"],[1901,1964,"Oh."],[2006,2093,"You're awake!"],[2248,2469,"Oh, I was so worried."],[2523,2640,"I was so scared."],[2677,2719,"Scared?"],[2719,2848,"You were probably"],[2848,3032,"praying I wouldn't make it."],[3057,3107,"What,"],[3107,3319,"how can you say that?"],[3357,3616,"This surgery cost a million dollars."],[3674,3749,"A million?"],[3803,3883,"Is that true?"],[3974,4129,"Guess I was wrong about you."],[4179,4250,"The diner..."],[4441,4637,"Well, we can talk about it later."],[5113,5209,"Wait a second."],[5209,5292,"Where's Ryan?"],[5476,5522,"Ryan?"]],"20":[[58,250,"Oh, uh, he talks now."],[250,362,"Says he's off doing"],[400,596,"rehab or whatever."],[696,884,"More like dodging actual work."],[884,971,"That's not true."],[971,1030,"Ryan's-"],[1063,1130,"Please."],[1176,1255,"He hasn't shown up"],[1255,1518,"once in three whole days."],[1539,1689,"Who's been doing all the cooking?"],[1710,1826,"Who's been wiping the sweat"],[1826,1947,"off your father's brow?"],[1947,2022,"Me!"],[2039,2214,"That's enough, I'm tired."],[2227,2381,"Please, just go."],[3824,3958,"My body's coming back."],[4270,4354,"And why hasn't Thomas"],[4354,4400,"sent me back?"],[4400,4462,"It's been two days."],[4508,4579,"Come on, Thomas."],[4579,4637,"Don't tell me you're"],[4637,4750,"trying to get my job too."],[5234,5388,"Sir, Mia's people are"],[5388,5547,"tracking Ryan's wire transfers."],[5651,5730,"Let her dig."],[5776,5868,"She won't find anything."],[5955,6222,"Oh, Ryan, if you really were dead,"],[6306,6460,"man, this would be so much easier."]],"21":[[475,567,"Mr. Chase!"],[596,658,"Finally."],[671,817,"I'm starting to think you ghosted me."],[871,1026,"Thomas, did you get my"],[1088,1172,"letter that I sent?"],[1188,1322,"Oh, yeah, I got it."],[1368,1505,"But Mia's people are on your"],[1505,1676,"bank records like bloodhounds."],[1697,1814,"I had to be careful, you know?"],[1864,2010,"Anyways, Mr. Chase,"],[2014,2139,"those overseas contracts"],[2139,2248,"are about to expire."],[2281,2377,"We need you back steering"],[2377,2439,"the ship."],[2506,2669,"How about I come pick you up myself?"],[2711,2857,"Just drop your location."],[2919,3015,"Just like I thought."],[3065,3207,"You're not trying to welcome me back."],[3249,3382,"You're trying to track me down."],[3449,3528,"And what's waiting for me"],[3528,3628,"isn't a warm reception."],[3707,3782,"It's a bullet."],[3899,3937,"No, thanks."],[3937,4024,"I'm still recovering."],[4054,4141,"But as far as the"],[4141,4220,"contract's concerned,"],[4220,4287,"why don't you set up a"],[4287,4387,"video meeting for tomorrow?"],[4483,4546,"2 p.m."],[4675,4733,"Damn it!"]],"22":[[304,362,"Schedule a meeting"],[362,442,"with the international board"],[442,550,"for 2 p.m. tomorrow."],[650,700,"Wait."],[909,1059,"Make sure Mia's invited too."],[1438,1484,"Let's see."],[1484,1584,"Mia's digging in for me."],[1634,1730,"Thomas wants me dead,"],[1730,1822,"and I'm in no condition"],[1822,1951,"go head-to-head with these fuckers."],[2469,2602,"If I can't reclaim the company,"],[2727,2802,"I'll be damned"],[2815,2927,"if those cocksuckers"],[2927,2998,"walk away with it."],[3115,3249,"This meeting contains"],[3249,3440,"top-tier classified intel."],[3474,3578,"Phones on silent."],[3603,3712,"No recordings."],[3732,3933,"Break that rule, face legal hell."],[4020,4175,"What is this, the CIA?"],[4212,4371,"Talk faster, Thomas."],[4383,4475,"What the hell does any of this"],[4475,4575,"have to even do with me?"],[4708,4788,"Patience, Mia."],[4829,4909,"You got a big surprise"],[4909,4984,"coming your way."]],"23":[[25,171,"Look, I don't give a shit"],[171,266,"about any of this."],[291,408,"All I care about"],[429,538,"are Ryan's shares."],[538,604,"Understood?"],[679,746,"Start the feed."],[1101,1180,"Hello, everyone."],[1272,1309,"What?"],[1355,1388,"No."],[1434,1463,"No."],[1534,1651,"This isn't possible."],[1676,1768,"I pushed him into the"],[1768,1918,"damn ocean myself."],[1972,2164,"How the hell is he still breathing?"],[2185,2239,"Mia,"],[2302,2360,"you look pale."],[2423,2544,"Should I call a doctor?"],[2606,2736,"Spare me your fake concern!"],[2786,2827,"I'm"],[2848,2952,"just surprised, that's all."],[3069,3148,"What is this?"],[3190,3299,"Did you get a body double?"],[3332,3503,"I have to say, the acting is impressive."],[3545,3745,"Well, I appreciate your concern."],[3824,3949,"Seems like I rattled some cages"],[3949,4041,"in my hiatus."]],"24":[[4,87,"Mr. Chase,"],[87,254,"Wall Street's been holding its breath"],[254,375,"waiting for your return."],[404,529,"Our stocks have already"],[529,704,"tanked 18% without you!"],[896,1013,"Mr. Chase!"],[1034,1309,"Praise be-by Allah, it's really you!"],[1355,1447,"Bloody hell!"],[1501,1680,"We've been holding off every deal"],[1680,1839,"waiting for your signature."],[1947,2014,"Brother Ryan,"],[2043,2160,"if you don't come back soon,"],[2206,2335,"we're all screwed out here!"],[2431,2523,"Ahmed,"],[2552,2806,"the oil deal's ready."],[2873,3044,"Contracts go out next week."],[3132,3182,"Lucas,"],[3374,3507,"tell the London Exchange"],[3507,3695,"to please prepare for a 30% surge"],[3695,3787,"in Chase stock."],[3862,3895,"Victor,"],[3978,4091,"I've set aside 10% equity"],[4091,4262,"in the Shanghai project, just for you."],[4441,4504,"I knew it."],[4542,4629,"Only Ryan Chase"],[4629,4788,"could pull a power move like that."],[4850,4925,"But boss,"],[5013,5167,"most of our major partners are"],[5167,5359,"requesting a face-to-face signing."],[5376,5401,"If"],[5434,5572,"you don't show up and soon,"],[5630,5697,"we could kiss"],[5697,5855,"a trillion-dollar deal goodbye."],[6047,6131,"Show up."],[6172,6247,"I dare you."],[6306,6398,"This time,"],[6418,6573,"I'm gonna watch that bullet"],[6573,6748,"rip through your heart."]],"25":[[37,154,"Well, let's see, the doctor said"],[154,329,"I'll need at least 3 months to recover."],[404,479,"Don't worry, Mia."],[538,658,"If only the Chase Foundation"],[658,729,"is standing,"],[759,884,"then business will be booming."],[963,1017,"Understood."],[1088,1155,"We'll handle it."],[1255,1359,"Ma sha Allah!"],[1426,1559,"We'll see you when you return,"],[1576,1705,"stronger than ever!"],[1764,1860,"Ta-da, cheerio."],[2168,2398,"And what about the stock?"],[2448,2527,"Well, as all of you know,"],[2527,2673,"I've already initiated Protocol Zero."],[2765,2936,"So stock initiation is underway."],[3044,3161,"And I've decided to"],[3207,3332,"donate all of my shares"],[3332,3457,"to the Chase Foundation."],[3628,3687,"A charity!"],[3687,3841,"What about our preferred shares?"],[3916,3995,"Bullshit!"],[4041,4129,"That's not Ryan."],[4162,4283,"He would never hand over"],[4283,4408,"his empire so easily!"],[4479,4567,"Mr. Chase,"],[4583,4738,"doesn't this all seem a little"],[4859,4917,"sudden?"],[4942,4979,"Why?"],[5080,5163,"It's my fortune."],[5292,5367,"Shouldn't I get to decide"],[5367,5434,"what to do with it?"],[5559,5668,"I don't buy it!"],[5714,5855,"Not unless you show up here,"],[5855,6006,"and sign them yourself."],[6047,6139,"Otherwise,"],[6189,6402,"this whole thing is a goddamn scam!"]],"26":[[4,45,"Mia,"],[137,225,"do you really think that"],[225,354,"I've forgotten what you did to me?"],[392,483,"The day I come back"],[554,721,"is the day that we settle the score."],[963,1101,"Oh, please!"],[1101,1217,"You don't even have the balls"],[1217,1363,"to show your face!"],[1393,1539,"You really think you can threaten me?"],[1589,1622,"Thomas,"],[1622,1755,"this is a closed board meeting."],[1793,1860,"Why is she here?"],[1918,2081,"He invited me!"],[2168,2398,"This whole thing is a goddamn setup!"],[2431,2560,"Mr. Chase, she has been"],[2585,2769,"hounding your whereabouts,"],[2786,2915,"harassing our employees."],[2961,3069,"I only let her in"],[3069,3199,"so she could see with her own eyes"],[3199,3286,"that you're alive."],[3378,3486,"So maybe she could finally"],[3486,3653,"shut the hell up."],[3816,3878,"Security."],[3937,3999,"Mia,"],[4024,4204,"this room is for board members only."],[4283,4358,"You've seen enough."],[4383,4483,"It's time for you to go."],[4579,4646,"Let go of me."],[4871,4913,"Fake!"],[4959,5121,"This is all fake!"],[5213,5355,"Get your hands off of me!"],[5501,5618,"This is the fake Ryan!"],[5855,5897,"Bye."],[5980,6218,"Boss, if you're really donating"],[6218,6335,"all of your shares,"],[6423,6539,"what happens to the board?"]],"27":[[0,83,"Well, Thomas,"],[145,246,"what do you think should happen?"],[287,404,"According to protocol,"],[433,579,"the second largest shareholder"],[600,792,"will assume the role as chairman."],[884,971,"That would be me."],[1096,1192,"Unless you object,"],[1192,1334,"I see no problem with"],[1334,1505,"steering this company forward."],[1572,1676,"Steering it forward?"],[1735,1847,"Or swallowing it whole?"],[1935,2006,"Thomas,"],[2147,2214,"answer me."],[2339,2406,"Ryan,"],[2444,2598,"this company cannot be run"],[2598,2790,"by a ghost behind the screen."],[2877,2998,"I'm simply doing what's best"],[2998,3086,"for Chase Corp."],[3182,3265,"And if I don't agree?"],[3340,3424,"Don't agree?"],[3536,3599,"Too late."],[3653,3757,"The second you initiated"],[3757,3841,"Protocol Zero,"],[3841,4004,"I started locking down support."],[4054,4225,"I've already secured all of my votes."],[4300,4354,"Let's vote."],[4379,4446,"Right now."],[4500,4679,"Who supports me taking over his chair?"],[4746,4817,"I support."]],"28":[[75,141,"I support."],[204,304,"Thomas really might"],[304,408,"be the better fit now."],[654,717,"You see, Ryan?"],[784,871,"This company"],[930,1026,"is mine now."],[1155,1242,"We'll see about that."],[1280,1413,"This is just the beginning."],[1463,1622,"As CEO of Chase Corp,"],[1685,1793,"I'm a billionaire."],[1901,1947,"You"],[2052,2160,"are a ghost."],[2377,2540,"GPS signal confirmed."],[2573,2694,"Location locked."],[2990,3069,"He's calling me."],[3370,3545,"While I'm still on the damn call."],[3782,3945,"You really did it, Thomas, didn't you?"],[4337,4404,"Doesn't matter."],[4450,4600,"You're a viper, a liar,"],[4600,4704,"and a fucking snake."],[4833,4929,"But I'm coming for you."]],"29":[[150,279,"Losing the company doesn't matter."],[529,696,"70% of our business is overseas,"],[696,850,"and those CEOs only answer to me."],[942,1051,"It's not over."],[1438,1568,"Hi, how are you?"],[2072,2218,"You look tired today."],[2489,2648,"No, it, it's just"],[2694,2773,"business headaches."],[2773,2823,"Don't worry."],[2877,2923,"I'm okay."],[3557,3599,"Hey."],[3682,3741,"What's wrong?"],[4754,4875,"We're..."],[5063,5321,"having a baby."],[5605,5676,"Baby, you..."],[5905,5976,"Oh my God!"],[6498,6569,"Oh my God."],[6844,6994,"This is the best news of my life."],[6994,7069,"I, I'm..."],[7298,7436,"I'm gonna be a dad."],[7999,8183,"This is the best news"],[8249,8370,"of my life!"],[8825,8904,"You've got me."],[8992,9084,"You've got our baby."],[9200,9275,"She's right."],[9426,9538,"I've still got Sophia,"],[9538,9647,"and now our baby."],[9801,9972,"There's no way I'm losing this fight."],[9972,10089,"I'm gonna be a dad."],[10168,10314,"Time to launch phase two."]],"30":[[29,129,"Why so serious?"],[166,216,"You pulled off"],[216,333,"one hell of an upset today."],[425,504,"Cut the act."],[525,567,"You were the one"],[567,679,"who planned the whole thing."],[700,842,"I was just bait for Ryan."],[1088,1180,"Cut to the chase."],[1322,1380,"What are you after?"],[1493,1530,"Money?"],[1697,1747,"Power?"],[1835,1918,"Or..."],[2031,2152,"you just wanna watch Ryan"],[2152,2235,"crash and burn?"],[2460,2615,"What if I told you..."],[2919,3028,"I want it all?"],[3249,3340,"I'd say that's exactly"],[3340,3495,"the kind of greed I admire."],[3628,3791,"I want Ryan's shares."],[3820,3945,"A seat at the board."],[3958,4187,"And a VP title over International."],[4333,4379,"Too late."],[4429,4483,"He's already locked"],[4483,4575,"all his damn shares"],[4575,4717,"into that charity trust fund."],[4800,4900,"It's untouchable."],[5363,5509,"Then let's make it touchable."],[6110,6256,"You're the new CEO now."],[6285,6389,"I'm sure you've got a few"],[6389,6519,"tricks up your sleeve."],[6627,6756,"And what do I get in return?"],[6931,7073,"You see something you like."],[7265,7365,"Then take it."],[7407,7511,"Even if it's me."],[7987,8149,"Starting tomorrow,"],[8220,8345,"Chase Corp will officially"],[8345,8516,"label Ryan dead."],[8587,8787,"Anybody claiming to be him afterwards,"],[8908,9079,"they'll just be labeled another fraud."]],"31":[[225,291,"Well,"],[392,446,"looks like"],[446,654,"we're on the same team now, Thomas."],[829,980,"I hope you play nice."],[1034,1134,"Of course, sweetheart,"],[1134,1222,"don't you worry."],[1322,1422,"This time tomorrow,"],[1455,1593,"the Wall Street Journal will be"],[1622,1751,"flooded with headlines"],[1826,1935,"about Ryan's death."],[2077,2164,"What's your next move,"],[2164,2327,"Mr. Brilliant CEO?"],[2356,2452,"Well, first,"],[2464,2581,"we start by locking down"],[2581,2711,"the international waters."],[2786,2940,"Chase Corp pulls about 70% of"],[2940,3111,"its revenue from overseas."],[3174,3240,"You remember Ahmed"],[3240,3315,"from the video call?"],[3374,3457,"Word is"],[3486,3628,"he's vacationing in Palm Beach"],[3628,3707,"this month."],[3732,4070,"I've got a $2,000,000 gift"],[4120,4229,"lined up for him."],[4358,4604,"A $2,000,000,000 oil contract,"],[4692,4783,"ours for the taking."],[4871,4971,"I'm coming, too."],[5055,5134,"Besides,"],[5201,5280,"when it comes to men,"],[5280,5363,"I've got you beat."],[5584,5689,"Don't go giving that body"],[5689,5889,"to anyone else, Mia."],[6177,6335,"You belong to me now."]],"32":[[0,166,"Okay, so what we've got"],[187,350,"is a wagyu seared,"],[350,508,"perfectly seared ribeye."],[563,834,"Uh, crispy on the outside, but"],[938,1059,"juicy in the middle."],[1301,1338,"All right."],[1785,1906,"That is for you, my dear."],[2056,2164,"And I, I love you,"],[2181,2314,"but you really need to eat some"],[2314,2460,"more protein these days."],[2686,2727,"What?"],[2898,2944,"What?"],[3048,3153,"It's the, it's this."],[3378,3457,"You look hotter than"],[3457,3603,"a Michelin chef right now."],[3845,4024,"Only the best for the love of my life."],[4416,4675,"Something's on your mind?"],[4859,4934,"Honey, I think"],[4934,5080,"I need to take a quick trip."],[5292,5430,"Just to see some friends,"],[5430,5522,"but I'll be gone"],[5522,5638,"for just like two days at most."]],"33":[[87,141,"Friends?"],[237,346,"Anyone I know?"],[471,696,"Think of them more like colleagues,"],[855,925,"but I'll be right back."],[946,1092,"We're just gonna do some catching up."],[1292,1618,"If they're old colleagues,"],[1655,1768,"shouldn't you change into"],[1768,1922,"something less chef-y?"],[2318,2473,"Well, I mean, they don't really judge."],[2477,2577,"They're good friends."],[2602,2673,"They love me."],[2711,2823,"We'll just say that they loved me."],[3028,3090,"Fine."],[3148,3269,"Just be careful."],[3407,3541,"And no drinking."],[3616,3812,"And oh, take dad's car!"],[3978,4037,"Yes, ma'am."],[4070,4129,"You got it."],[5055,5092,"Hey."],[5201,5271,"Bon appetit."],[5889,5993,"Mia, Thomas."],[6206,6385,"When I take back control overseas,"],[6456,6539,"you're both done."]],"34":[[233,454,"That oil crisis three years ago,"],[483,696,"Ryan flipped the market with one call."],[729,900,"40% spike."],[1021,1138,"Just like that."],[1197,1334,"His hedge strategy"],[1334,1647,"is still printing money to this day!"],[1789,1901,"Nobody has seen a"],[1901,2110,"business move like that in years."],[2189,2252,"Uh. - Mmm."],[2318,2423,"When Ryan shows up,"],[2464,2635,"call us immediately."],[3090,3365,"A guy with oil sheiks, finance sharks,"],[3365,3582,"and Asian tycoons at his beck and call."],[3661,3816,"Bet he rolls up in an Armani suit"],[3816,3974,"and a million-dollar watch."],[4008,4187,"Oh, or maybe he lands"],[4225,4396,"in his private jet on the roof."],[4450,4562,"Ten bodyguards,"],[4633,4808,"and a hawk on his arm."],[5814,5897,"Ew."],[6247,6302,"Sorry."],[6348,6481,"Kitchen deliveries go out back."],[6481,6573,"We wouldn't want"],[6614,6806,"scruffy people like you"],[6806,6961,"ruining the guest experience."],[7065,7152,"I'm here to see Ahmed."],[7336,7403,"Wearing that?"],[7440,7595,"You really think that oil tycoon"],[7595,7703,"is gonna meet with you?"],[7845,7978,"Tell Ahmed that Ryan Chase is here"],[7978,8062,"to see him, please."],[8070,8120,"Wait."],[8208,8437,"You're Ryan Chase?"]],"35":[[12,254,"You're, you're really Ryan Chase?"],[287,358,"The one and only."],[479,563,"Hold up."],[608,704,"Ryan Chase has some of the"],[704,817,"wealthiest men in the world"],[817,909,"waiting on him."],[925,1034,"Oil sheiks,"],[1042,1113,"finance sharks,"],[1117,1247,"Asian tycoons."],[1247,1343,"He wouldn't show up"],[1343,1430,"dressed like some"],[1468,1630,"greasy line cook."],[1630,1680,"Come on."],[1747,1972,"But he did say that he's Ryan Chase."],[1989,2068,"Please."],[2085,2206,"What billionaire shows up"],[2206,2302,"looking like that?"],[2344,2464,"If he's Ryan Chase,"],[2464,2615,"then I'm the Queen of England!"],[2656,2777,"Well, I have no reason to lie."],[2802,2932,"Call Ahmed, he'll tell you."],[3007,3132,"If we bother our VIPs,"],[3132,3203,"and it turns out"],[3203,3328,"you're some type of fraud,"],[3361,3482,"who's gonna make it up to them?"],[3520,3566,"You?"],[3578,3720,"With your apron?"],[3895,3949,"That's fine."],[3949,4029,"I'll call him myself."],[4646,4808,"That's not Ryan Chase!"],[5647,5843,"Because Ryan Chase is dead."],[5876,5939,"Well,"],[6068,6377,"this just got very, very interesting."]],"36":[[25,91,"Figures."],[116,291,"Mia really did team up with Thomas."],[346,429,"Disgusting."],[487,571,"Ryan."],[642,813,"It's really you, isn't it?"],[871,1009,"I pushed you into the ocean"],[1009,1126,"with my bare hands."],[1192,1305,"And you're still here."],[1376,1534,"My own personal nightmare."],[1605,1672,"Mia."],[1751,1847,"Thomas, nice suit."],[2035,2202,"Hey, I want you both to know,"],[2289,2410,"you're gonna pay for what you did."],[2535,2681,"Get a grip."],[2831,2907,"Ladies and gentlemen,"],[2986,3103,"as you've probably read"],[3103,3257,"in today's Wall Street Journal,"],[3336,3432,"Ryan Chase,"],[3474,3707,"former CEO of Chase Corporation,"],[3782,3999,"has been confirmed dead."],[4137,4208,"And you?"],[4295,4554,"You're just some look-alike nobody"],[4612,4758,"trying to stir shit up!"],[4821,4892,"I knew it."],[4925,5067,"I knew Mr. Al-Masri's guest"],[5067,5221,"wouldn't show up looking like some"],[5255,5363,"greasy fry cook."],[5555,5613,"Shit."],[5651,5743,"How the hell does he know"],[5743,5826,"Ahmed's in town?"],[5964,6093,"You think he's here for the oil deal?"],[6097,6168,"What's wrong?"],[6243,6348,"Now you two wouldn't be"],[6348,6548,"planning on faking my death or..."],[6610,6719,"I don't know, snatching my deal"],[6719,6790,"with Ahmed, are you?"],[6790,6890,"Or am I mistaken?"],[6973,7098,"He is here for Ahmed."],[7165,7248,"Shit."],[7278,7386,"He must be planning to shift"],[7386,7574,"the entire operation overseas!"],[7599,7782,"That's 70% of Chase Corp's revenue!"],[7828,7962,"I can't let him take it."]],"37":[[70,179,"You've done an excellent job"],[179,279,"remaining cautious."],[387,458,"Allow me to introduce"],[458,538,"myself properly,"],[575,638,"Thomas Blake,"],[650,775,"CEO of Chase Corporation."],[855,992,"And that man right there?"],[1063,1180,"He's a pathetic wannabe."],[1205,1334,"Mr. Al-Masri wants to meet"],[1334,1488,"the CEO of Chase Corp,"],[1497,1730,"not some low-rent greasy cook."],[1751,1847,"Of course, Mr. Blake."],[1847,1951,"We know better than to"],[1951,2077,"fall for a stunt like that."],[2077,2152,"Exactly."],[2152,2218,"And no billionaire"],[2218,2335,"would show up in shoes"],[2389,2527,"looking like they've been just"],[2548,2673,"fished out of the trash."],[2882,2998,"Oh, come on, you two."],[3019,3090,"You both know that"],[3090,3261,"you can't become royalty"],[3261,3399,"from just stealing a throne."],[3449,3520,"You're idiots."],[3691,3870,"From suits and skyscrapers"],[3870,4029,"to burnt grease and failure."],[4070,4275,"Oh, how the mighty have fallen."],[4350,4483,"You still fantasizing about that"],[4483,4604,"corner office while you"],[4642,4733,"flip your burgers?"],[4792,4888,"No, not at all."],[4984,5084,"Because at least I didn't"],[5163,5288,"sleep my way into the boardroom."],[5301,5401,"Don't pretend like"],[5401,5563,"you have the upper hand here, Ryan."],[5613,5755,"Ahmed won't waste his time"],[5755,5889,"on a dead man."],[5951,6051,"He's here for the"],[6051,6189,"real head of Chase Corp."],[6206,6464,"Not some filthy cook,"],[6464,6644,"too poor to even afford a suit."]],"38":[[12,79,"Well, you know what?"],[120,246,"That brings up a good point."],[266,333,"I've got an idea."],[442,529,"Let's place a wager."],[617,717,"Let's call Ahmed."],[800,846,"Let's see"],[846,955,"who he wants to do business with."],[955,1180,"If it's not me, I'm gone forever."],[1180,1284,"A wager?"],[1384,1455,"A wager."],[1509,1643,"What do you even have to bet?"],[1672,1839,"With your greasy apron"],[1839,1918,"and a frying pan?"],[1981,2143,"Thomas, don't waste your breath."],[2156,2364,"Ahmed doesn't like uninvited guests."],[2385,2544,"And he especially doesn't like"],[2544,2652,"uninvited guests"],[2652,2806,"without an appointment."],[2948,3194,"This is a world of capital, Ryan."],[3236,3319,"Power talks."],[3370,3461,"Chase Corporation"],[3461,3586,"doesn't need you anymore."],[3603,3674,"It's still a"],[3674,3858,"multi-billion-dollar empire"],[3858,4070,"with or without your face on it."],[4170,4375,"You flip burgers for a living."],[4575,4629,"What, what do you,"],[4642,4725,"what makes you think"],[4725,4796,"that you can land"],[4796,4946,"a multi-billion-dollar deal?"]],"39":[[0,87,"What makes you think"],[87,158,"that you can land"],[158,300,"a multi-billion-dollar deal?"],[367,446,"Are you planning to"],[446,563,"charm them or something?"],[646,721,"Good luck with that."],[829,1005,"A billionaire wouldn't dress like a"],[1005,1142,"broke line cook."],[1180,1309,"Yeah, you'll be lucky enough"],[1309,1413,"with the guards."],[1443,1551,"Don't escort him out"],[1551,1739,"before Mr. Al-Masri gets you."],[1747,2018,"Oh, guys, congratulations."],[2077,2185,"All four of you are officially"],[2185,2331,"dumber than circus clowns."],[2410,2560,"And I can guarantee you,"],[2598,2702,"you're gonna regret it."],[2748,2919,"Oh, I'm so scared!"],[3061,3190,"Look, we have a contract"],[3190,3286,"to sign with Ahmed,"],[3286,3390,"so why don't you"],[3478,3549,"move along?"]],"40":[[921,988,"Thank you, bud."],[1101,1226,"How about I give you a little tour?"],[1601,1772,"Ah, the limited edition"],[1785,1947,"Patek Philippe Celestial,"],[2010,2106,"only three in the world."],[2135,2285,"Oh my god!"],[2310,2502,"Finally, someone with some class."],[2540,2752,"Mr. Blake, your taste is impeccable!"],[2902,3257,"A handcrafted gold Arabian scimitar,"],[3336,3574,"custom-made by the Dubai royal smiths."],[3753,3895,"And this,"],[3974,4341,"the 1945 Romanée-Conti."],[4471,4846,"One bottle worth $550,000."],[4971,5046,"All in,"],[5100,5217,"two million bucks."]],"41":[[12,79,"All in,"],[145,258,"two million bucks."],[333,429,"Quite the power move."],[462,579,"I've never seen anything"],[579,654,"like this before."],[658,729,"Mr. Blake,"],[775,1042,"you must be Mr. Al-Masri's VIP"],[1042,1155,"of the century."],[1226,1317,"Mr. Blake,"],[1343,1430,"Ms. Mia,"],[1484,1530,"I,"],[1580,1647,"we,"],[1726,1885,"we're so sorry about earlier."],[1931,2010,"We had no idea"],[2010,2143,"who we were even speaking to."],[2256,2331,"Impressive."],[2444,2540,"But unfortunately,"],[2540,2619,"you got it all wrong."],[2740,2923,"Ahmed's not into shiny toys."],[3044,3140,"He cares about people,"],[3253,3403,"not garbage wrapped in glitter."],[3511,3582,"Please."],[3599,3732,"Don't delude yourself."],[3745,3891,"Ahmed lives for luxury."],[3903,3953,"This?"],[3999,4145,"This is exactly his style."],[4254,4341,"Too bad you won't be here"],[4341,4433,"for the signing."],[4466,4596,"Get him out of here."],[4612,4729,"I don't want his stink"],[4729,4900,"anywhere near Ahmed."]],"42":[[0,108,"Get him out of here!"],[129,250,"I don't want his stink"],[250,387,"anywhere near Ahmed."],[550,617,"You're gonna regret it."],[650,800,"Trying to scare us, fraud?"],[846,950,"Might wanna think of"],[950,1138,"a better disguise first."],[1201,1259,"Front desk,"],[1309,1397,"get Ahmed on the line."],[1455,1564,"Chase Corp came prepared."],[1568,1722,"Oh, and be sure to mention"],[1722,1805,"the gifts we got him."],[1826,1914,"Right away, Mr. Blake."],[1914,2002,"Connecting you now."],[3257,3349,"Speak."],[3374,3420,"Sir,"],[3490,3649,"there is a CEO of Chase Corp"],[3649,3745,"waiting for you."],[3774,3841,"And they've got"],[3841,4012,"2-million-dollar worth of gifts."],[4537,4679,"Ryan brought gifts?"]],"43":[[33,166,"Ryan brought gifts?"],[358,462,"That's not his style."],[492,588,"Strange."],[688,829,"Last time I saw him in Monaco,"],[829,938,"he said he hated"],[938,1080,"performative gift-giving."],[1146,1326,"Maybe he's trying to surprise us."],[1447,1501,"Come on."],[1572,1672,"Let's see what this is about."],[1985,2127,"If we must."],[2135,2189,"Ten seconds."],[2298,2398,"You're all gonna be on your knees"],[2398,2506,"begging for forgiveness."],[2515,2577,"Shut it."],[2635,2727,"Trash like you belongs"],[2727,2815,"to the curb."],[3219,3303,"We did it."],[3541,3616,"Stop!"],[3770,3820,"Sir."],[3841,3978,"Mr. Al-Masri."]],"44":[[25,141,"Sir."],[145,296,"Mr. Al-Masri."],[316,483,"Is this your idea of management?"],[508,588,"What are you running here?"],[592,671,"A fucking flea market."],[717,821,"Where's Ryan?"],[850,988,"If he's already left because of you,"],[1009,1138,"I'll have you all fired."],[1163,1213,"Well."],[1301,1368,"Where is he?"],[1430,1505,"Didn't you say that-"],[1505,1589,"Mr. Al-Masri,"],[1626,1735,"I am Mia. - Mr. Al-Masri."],[1830,1910,"Pleasure to meet you."],[1910,2002,"It's an honor really."],[2031,2139,"I am Thomas Blake,"],[2160,2273,"acting CEO of-"],[2273,2339,"Shut up."],[2394,2523,"I'm here to see Ryan Chase."],[2527,2640,"Where is he?"],[2681,2873,"I thought the CEO of Chase Corp"],[2873,2944,"would be here."],[3015,3161,"Where the hell is Ryan?"],[3169,3390,"They said that they were from Chase,"],[3407,3561,"and they brought gifts."],[3691,3766,"Mr. Al-Masri,"],[3766,3966,"I, uh, am acting on behalf"],[3966,4091,"of Chase Corporation."],[4095,4179,"I'm here to discuss"],[4179,4329,"our Middle Eastern oil project."],[4329,4504,"I am here for personal."],[4504,4646,"Not for the business."],[4879,5005,"Next time, verify with me"],[5005,5184,"before dragging me into the circus."],[5196,5376,"I do not deal with stray dogs."]],"45":[[4,87,"Mr. Al-Masri,"],[120,191,"please."],[250,375,"Chase Corp needs this deal."],[375,479,"What makes you think"],[479,617,"you're remotely qualified"],[617,792,"to speak on behalf of Chase Corp?"],[834,942,"When Ryan and I were"],[942,1113,"toasting friendship over drinks,"],[1130,1263,"you were in the mailroom"],[1267,1368,"sweating it out,"],[1376,1534,"dreaming of a promotion."],[1647,1793,"Mr. Al-Masri,"],[1843,2385,"we got you a very cool sword."],[2385,2510,"Ah, baby."],[2623,2827,"My business here with Chase Corp"],[2827,3115,"is with Ryan Chase."],[3186,3261,"Period!"],[3324,3390,"Got it?"],[3411,3440,"Yep."],[3461,3603,"Because he is Ryan Chase."],[3732,3803,"Hey!"],[3820,3874,"Oh."],[3920,4087,"What are you two whispering about?"],[4141,4179,"Nothing."],[4237,4400,"Uh, uh, it's just-"],[4421,4550,"Shut up!"],[4562,4633,"Spit"],[4679,4717,"it"],[4717,4771,"out."],[4792,4854,"Now."],[4934,4988,"It was just..."],[5113,5234,"There was a guy earlier"],[5234,5388,"who was wearing chef's clothes,"],[5388,5622,"and he was driving a rusty old car."],[5634,5797,"And he said he was"],[5843,5947,"Ryan Chase."],[6043,6114,"What did you say?"],[6131,6227,"What did he look like?"],[6281,6435,"Uh, blonde hair,"],[6435,6656,"blue eyes, six feet tall."],[6656,6923,"You fucking idiots!"],[6923,7040,"Where is he?"]],"46":[[87,166,"Mr. Al-Masri,"],[208,412,"I'm sorry to be the one"],[412,550,"have to tell you this, but"],[667,821,"Ryan Chase tragically"],[834,984,"passed away in a yacht accident"],[984,1055,"two months ago."],[1138,1284,"What did you just say?"],[1363,1422,"I know."],[1422,1572,"I'm so sorry."],[1572,1701,"What did you just say?"],[1735,1814,"Funny, uh,"],[1843,2043,"we all video-chatted him"],[2043,2164,"about a month ago."],[2223,2356,"So you're saying"],[2356,2489,"he was dead before that?"],[2489,2573,"That,"],[2573,2715,"that was an impersonator."],[2715,2948,"And I do apologize for any confusion."],[2969,3073,"In fact, I have-"],[3094,3165,"Nah, nah."],[3253,3311,"Liar."],[3395,3599,"He contacted us just two days ago"],[3599,3745,"to meet him here today!"],[4054,4166,"This isn't going well."],[4200,4275,"What do we do?"],[4275,4429,"Stick to the plan."],[4429,4504,"No matter what."],[4608,4729,"Mr. Al-Masri, I'm sorry."],[4729,4884,"I'm sorry for any confusion,"],[4884,5042,"And I, I know how this must feel,"],[5042,5221,"but I have the coroner's report-"],[5238,5309,"Shut up!"],[5430,5534,"He's a liar!"],[5568,5638,"Let's leave!"],[5684,5755,"Wait!"],[5851,5997,"We'll double your profit margin,"],[5997,6164,"and we'll give you"],[6164,6335,"full access to Chase Corp."],[6343,6435,"Full access?"],[6514,6669,"Without Ryan's signature,"],[6669,6815,"you can't do shit."],[7086,7157,"Tried to warn you."],[7261,7407,"Ahmed was never gonna be"],[7407,7540,"swayed by your flashy gifts."],[7578,7678,"Or your desperate lies."],[7745,7807,"Ryan!"],[7811,7937,"Miss me, fellas? - God damn it!"],[7941,8070,"You certainly made us wait!"]],"47":[[4,70,"Ryan!"],[75,141,"God damn it!"],[145,304,"You certainly made us wait!"],[400,558,"Oh, you wanker."],[583,754,"Trying to pull the disappearing act."],[767,863,"Real funny."],[863,967,"Another moment"],[967,1059,"with these two clowns"],[1059,1172,"and we would have died from a"],[1172,1288,"secondhand embarrassment."],[1297,1368,"I missed you, too."],[1401,1476,"Wait a second."],[1534,1626,"He's an imposter!"],[1659,1910,"I'm the real legal CEO of-"],[1910,2081,"Will you shut the fuck up?"],[2160,2264,"Can you believe this?"],[2264,2344,"Dumbass didn't think"],[2344,2456,"I would recognize you."],[2469,2569,"He doesn't know the details"],[2569,2677,"between us."],[2752,2869,"Do you remember that Rolex"],[2869,2957,"you got me in Dubai?"],[2957,3053,"Of course!"],[3053,3194,"You chucked it into the fountain,"],[3194,3370,"you crazy bastard!"],[3445,3578,"He doesn't even"],[3578,3703,"own a goddamn suit."],[3720,3858,"He's ridiculous!"],[3953,4108,"Okay, yeah."],[4116,4320,"This isn't your usual look."],[4341,4458,"What the hell happened?"],[4471,4629,"Well, someone"],[4679,4842,"threw my closet into the ocean"],[4842,4938,"along with me,"],[4996,5159,"stole my name and my life,"],[5159,5267,"and left me for dead."]],"48":[[50,258,"Someone threw my closet"],[258,437,"into the ocean along with me,"],[487,638,"stole my name and my life,"],[638,738,"and left me for dead."],[738,788,"So..."],[834,1030,"Brother, let's go catch up."],[1134,1226,"I have that Macallan"],[1226,1384,"that you love waiting upstairs."],[1393,1468,"Yes, please."],[1714,1818,"And just so we're clear."],[1976,2127,"Don't allow these two entry."],[2198,2335,"Put up a sign if you have to."],[2377,2464,"No riffraff."],[2477,2598,"No stray dogs!"],[2831,2919,"Stray dogs!"],[3061,3186,"Stray dogs."]],"49":[[0,50,"Hmm."],[91,141,"Hmm."],[283,421,"Damn, Ryan, what happened?"],[437,513,"You looked like you"],[513,654,"crawled out of a drive-thru."],[704,746,"What?"],[746,896,"You couldn't afford a proper suit?"],[938,1021,"Hey, now."],[1117,1242,"Ahmed, when have you ever been a"],[1242,1359,"man who's judged another man"],[1359,1468,"by his dry cleaning?"],[1501,1576,"Look at you."],[1730,1851,"Still cocky as hell."],[1960,2118,"Ahmed, let him breathe."],[2389,2523,"Ryan, what the hell happened?"],[2573,2669,"We heard you were dead,"],[2698,2802,"and now here you are,"],[2857,2990,"rocking a greasy apron"],[2990,3073,"like it's nothing?"],[3103,3165,"Well, fellas, I know"],[3165,3265,"it's gonna be hard to believe."],[3411,3532,"But Mia and Thomas happened."],[3678,3824,"They literally threw me in the ocean"],[3824,3916,"and faked my death."],[3974,4020,"Fuck!"],[4074,4266,"You couldn't trust that bastard."],[4320,4408,"Piece of shit!"],[4483,4637,"So now,"],[4671,4842,"Chase Corp's their little toy?"],[4867,4909,"Hmm."],[4954,5121,"For now, but not for long."],[5188,5267,"Ryan."],[5488,5634,"Do you want to play for real?"],[5676,5759,"I'm listening."]],"50":[[62,283,"I want you to run my U.S. operation."],[550,696,"Full control-capital,"],[863,950,"contacts,"],[988,1155,"infrastructure, everything."],[1305,1422,"Bloody hell, Ahmed."],[1480,1622,"You're not holding back, are you?"],[1659,1868,"Ryan, that seat is worth"],[1926,2039,"10 Chase Corp."],[2110,2189,"Alright, Ahmed."],[2352,2448,"But what's the catch?"],[2535,2660,"I have a few rivals"],[2660,2811,"I want to wipe off the board."],[2831,2907,"And..."],[3028,3157,"I want to see that"],[3157,3370,"creep Thomas on his knees,"],[3420,3582,"begging you for mercy."],[3787,3870,"Well Ahmed,"],[4129,4233,"you got yourself a deal."],[4567,4629,"Revenge."],[4688,4788,"Revenge."]],"51":[[54,154,"Find out what the fuck"],[154,275,"Ahmed's company is planning!"],[287,354,"Now!"],[421,575,"They're, they're in the VIP suite."],[575,713,"The Serenity VIP Suite."],[713,796,"Just calm down."],[896,984,"What the hell is Ryan"],[984,1105,"talking to them about in there?"],[1209,1409,"Security, can you escort these two"],[1409,1597,"troublemakers outside?"],[1605,1697,"Oh."],[1747,1868,"Troublemakers?"],[2364,2444,"No, I, no."],[2444,2519,"I...I can explain. - No."],[2519,2627,"There is, I have things to do."],[2627,2669,"Bitch!"],[2669,2748,"I have business."],[2748,2811,"I need to"],[2811,2873,"attend to!"],[2882,3144,"I'm the CEO of Chase Corporation!"],[3395,3486,"Alright, Ryan."],[3566,3641,"Cut the mystery."],[3753,3824,"How are you gonna burn"],[3824,3937,"those two to the ground?"],[3999,4037,"Easy."],[4170,4241,"Stock market."]],"52":[[33,104,"Stock market."],[246,279,"Oh."],[337,387,"You serious?"],[387,496,"You're going to try to"],[496,592,"short Chase Corp?"],[638,729,"Love, you don't even own"],[729,838,"any shares anymore."],[867,934,"You're gonna attack them"],[934,975,"with what?"],[1030,1096,"Good vibes?"],[1134,1326,"Which is exactly,"],[1326,1401,"fellas,"],[1509,1626,"why I need to take it back."],[1793,1864,"Crash the market."],[1939,2022,"Retail panic."],[2072,2135,"Buy it back."],[2135,2210,"They sell cheap."],[2306,2389,"Hell yes!"],[2410,2581,"That's the Ryan I remember!"],[2627,2765,"How much capital do you need?"],[2802,2882,"I can move a portion."],[2894,2969,"No, thanks, Viktor."],[3007,3086,"I appreciate that."],[3123,3186,"But no, thank you."],[3232,3324,"I'm gonna take care of this one."],[3374,3586,"And I just started a new company."],[3666,3824,"For my wife, Sophia."],[3962,4066,"And she's the one"],[4066,4141,"who's gonna be handling"],[4141,4254,"all of your contracts."]],"53":[[66,133,"God damn."],[300,412,"You're gonna let your wife"],[437,542,"step on your ex's neck,"],[567,692,"on her way to billionaire status?"],[834,959,"That's colder than killing her."],[1117,1159,"Deal!"],[1309,1501,"All my contracts go to your girl."],[1522,1755,"I can't wait to see that punk Thomas"],[1755,1914,"crying on his knees."],[1947,2052,"Do us a favor,"],[2127,2223,"live stream it."],[2293,2423,"I wanna see those two snakes"],[2423,2548,"burn in real time."],[2598,2831,"To the birth of a new billionaire."],[2915,2982,"Hip, hip, hip!"],[3107,3203,"Hooray!"],[3841,3945,"Hand over the money."],[4058,4179,"Or I swear,"],[4200,4416,"I'll rip her pretty little face off."],[4512,4592,"They're threatening"],[4592,4675,"to kill me!"],[4783,4842,"Whatever."]],"54":[[246,425,"Mom, you see this?"],[442,554,"I got an interview"],[554,771,"with Ahmed Al-Masri's"],[784,913,"U.S. Division."],[930,984,"He's one of the"],[984,1126,"global conglomerates."],[1138,1347,"Right up there next to Chase Corp."],[1351,1509,"As one of the best places"],[1526,1755,"for an Ivy League graduate to land."],[1755,1968,"Oh, that's my boy!"],[2035,2235,"Unlike some freeloader"],[2235,2414,"surviving off a man's pity."],[2427,2581,"Oh, I'm gonna have to show up"],[2581,2777,"in a new $50,000 suit."],[2831,2940,"Can't be having a meeting"],[2940,3094,"with a Middle Eastern royalty"],[3094,3261,"looking like a Target rack."],[3390,3516,"You heard him, Sophia."],[3549,3691,"Hand over the fucking money!"],[3728,3841,"My son's future"],[3841,3987,"is infinitely more important"],[3987,4112,"than whatever stupid little thing"],[4112,4262,"you think you need it for."]],"55":[[25,208,"I need the money for the baby!"],[371,475,"You don't need"],[475,646,"a fancy suit for the interview!"],[684,871,"Interviews are about showing up,"],[871,996,"showing heart!"],[1067,1142,"Bullshit!"],[1176,1309,"What do you think you know"],[1309,1484,"about the real world?"],[1789,1885,"Come on, Mom."],[1885,1989,"Make it snappy."],[2168,2348,"We have to get our money."],[3019,3128,"I'm pregnant."],[3178,3428,"I need the money for prenatal exams."],[3599,3691,"Little Cinderella"],[3691,3816,"wants to have a baby."],[3970,4058,"Please."],[4266,4496,"You stupid girl!"],[4717,4863,"You think you can play the victim,"],[4884,4979