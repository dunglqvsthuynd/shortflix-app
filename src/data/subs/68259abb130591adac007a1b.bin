{"1":[[1480,1676,"Dad's coming back today."],[1676,1918,"My days in Hell are finally over."],[2210,2314,"So sorry."],[3520,3682,"There is no easy"],[3682,3862,"way to say this,"],[3862,4024,"but unfortunately,"],[4024,4312,"Mr. Green was in a car collision."],[4646,4804,"He..."],[4804,5105,"was pronounced dead at the scene"],[5105,5271,"when EMTs arrived."],[5376,5568,"I am so sorry."],[6477,6594,"No..."],[6840,6956,"Thank you, officer, I think we"],[6956,7069,"just need a moment."],[7136,7236,"Sure."],[7920,8087,"I've been waiting for this day"],[8087,8216,"for three years."],[8495,8596,"Now that you father's dead,"],[8596,8775,"I can finally kick you out of the house."],[8879,9000,"I'm your daughter."],[9017,9117,"Stepdaughter."],[9209,9396,"Olivia here is my real daughter."],[9426,9630,"You're nothing but a leeching parasite."],[9743,9851,"Poor Vivian."],[9893,10041,"Now I'll be the Green Heiress"],[10041,10247,"and take all the inheritance."],[10264,10389,"No, you can't."],[10389,10523,"Dad has a will,"],[10523,10698,"and you can't take everything from me."],[10739,10839,"Oh!"],[10839,11010,"Do you mean this?"],[11257,11398,"Well, look here."],[11457,11611,"No signature."],[11611,11715,"Guess he dropped dead"],[11715,11928,"before he could get it notarized."],[13200,13388,"Now get the fuck out of my house."],[13763,13851,"Get her out of here."],[13851,13943,"Yes, ma'am."]],"2":[[2786,2915,"I'm burning up."],[3002,3123,"Where am I gonna go?"],[3123,3236,"What am I gonna do?"],[4295,4617,"I haven't had a fresh piece of ass in weeks."],[4771,4888,"Come here, little girl."],[5000,5251,"No, please. No, no!"],[5288,5472,"Please..."],[7223,7332,"I got you!"],[7907,8033,"Damien Russo?"],[8116,8249,"The Mafia King."],[8304,8491,"What are you doing in my house?"],[8879,9071,"Get rid of him."],[9538,9622,"And burn this"],[9622,9755,"fucking place to the ground."]],"3":[[2690,2811,"Damn, he's hot."],[2869,2932,"You're awake."],[3349,3449,"Don't move, I will shoot!"],[3449,3541,"I will shoot!"],[3782,3844,"Don't grab something"],[3844,3924,"you don't know how to use."],[4813,4896,"You wanna learn to shoot?"],[5138,5221,"Use this."],[6835,6911,"Pull the trigger."],[8487,8604,"Remember me now?"],[8687,8759,"Two years ago,"],[8759,8850,"you threw me into a van"],[8850,8925,"and sold me into"],[8925,8988,"human trafficking auction."],[8988,9054,"Please, please..."],[9054,9129,"Don't kill me, don't kill me..."],[9129,9234,"I was just paid to grab you."],[9234,9317,"That's it, that's it."],[9317,9409,"You paid by who?"],[9409,9534,"I don't know, I don't know..."],[9580,9691,"But it's the same guy"],[9691,9806,"who murdered your father"],[9806,9893,"in the car accident."],[10122,10264,"My father was murdered?"],[11094,11257,"Find out who's really"],[11257,11332,"behind my kidnapping"],[11332,11461,"and my father's death."],[11536,11649,"I want them dead."]],"4":[[145,287,"Whoever did this is ruthless."],[329,533,"No survivor, no witness."],[571,661,"But they did leave behind"],[661,792,"a rather unique bullet casing."],[1000,1159,"I sent you the photo of the casing."],[1872,1981,"I've seen this one."],[3036,3178,"So as you can see, it's a heart."],[3211,3340,"We don't know who it is yet, boss,"],[3340,3453,"but we will find this."],[3453,3557,"It could be anybody in here."],[3574,3666,"Enough."],[3774,3849,"Sweep the scene."],[3849,3987,"Make it spotless. Now!"],[4796,4884,"Vivian,"],[4884,5038,"don't go anywhere after school."],[5238,5363,"We need to talk right now."],[6752,6810,"Wait!"],[6986,7155,"That's the tux I got Damien"],[7155,7233,"for his birthday."],[7286,7499,"He only wears it for special occasions."],[7515,7678,"What's... what's the event?"],[7703,7841,"I think it's for a wedding..."],[7937,8074,"Wedding?"],[9134,9313,"Legs down."],[9417,9513,"Now."],[9730,9793,"And who told you"],[9793,9922,"you can drink? You are not..."],[9922,10060,"I'm twenty one."],[10276,10489,"And you don't get to tell me what to do."],[10543,10706,"You will do what I tell you"],[10706,10890,"as long as you live under my roof."],[11720,11853,"And..."],[12178,12383,"what're you gonna do to me?"],[12416,12545,"Mr. Russo?"],[14051,14151,"You know,"],[14239,14368,"your bullet casing's"],[14435,14568,"matched the ones"],[14568,14693,"found at the warehouse."],[14843,14944,"Care to explain?"]],"5":[[75,150,"I killed them."],[387,517,"They were behind my kidnapping."],[596,738,"And you know what I also found there?"],[888,975,"My father's death..."],[1055,1163,"It wasn't an accident."],[1197,1405,"You should have come to me first."],[1438,1593,"I handled it."],[1639,1851,"You taught me a set of skills"],[1851,1976,"and I applied them."],[2093,2206,"Don't walk away from me"],[2206,2323,"when I'm talking to you."],[2377,2489,"Alright, from now on,"],[2489,2635,"you go to school"],[2635,2748,"and you come home."],[2765,2861,"That's it."],[2861,3232,"No drinking, no smoking, no drugs, no boys."],[3415,3536,"If that's how you're gonna be,"],[3595,3741,"I'm gonna get my own place."],[3753,4087,"No, you will go where I tell you to go."],[4087,4170,"I'll lock you in the basement"],[4170,4245,"if I have to."],[5251,5367,"You didn't wrap it right."],[8116,8299,"Behind that cold exterior,"],[8299,8462,"he's always had a soft spot for me."],[8516,8608,"Why do I always feel"],[8608,8725,"like I'm drawn to him?"],[8833,8900,"Almost done."],[10402,10474,"Wait."],[10474,10541,"The maid said"],[10541,10685,"the tux was for a wedding."],[10735,10885,"And he just said no boys to me,"],[10885,10944,"and now the ring?"],[11023,11282,"This... this isn't for me, is it?"]],"6":[[371,446,"What's that for?"],[525,625,"It's for my fiancée."],[709,842,"The wedding is in a few days."],[946,1051,"You're getting married?"],[1197,1251,"But..."],[1376,1576,"How could you not tell me about that?"],[1584,1658,"It's part of"],[1658,1764,"a business arrangement."],[1773,1981,"I had to solve a critical supply chain issue"],[1981,2102,"with the partner family."],[2135,2225,"The wedding is just"],[2225,2302,"part of the deal."],[2381,2556,"Thank God it's not me."],[2602,2719,"But what?"],[2969,3153,"So you're getting married,"],[3153,3228,"And yet you want me"],[3228,3336,"all to yourself?"],[3545,3661,"I don't own you an explanation."],[5042,5155,"Vivian, hey."],[5188,5280,"Good to see you."],[5338,5497,"There's a new girl coming on campus."],[5543,5684,"Everyone's talking about her."],[5743,5834,"Friend of Claudia's?"],[5876,6076,"I bet she's a spoiled brat too."],[6760,6915,"You're fucking kidding me..."],[7040,7228,"How the fuck is this bitch here?"],[7228,7407,"I thought she got sold ages ago."]],"7":[[12,250,"Vivian! Darling!"],[404,700,"Oh, it's been so long."],[792,884,"You look..."],[884,1050,"Well, considering you were"],[1050,1184,"on the black market."],[1231,1331,"Are you gonna pretend"],[1331,1463,"you had nothing to do with that?"],[1476,1618,"Oh, wow!"],[1651,1876,"Quite the hostility. Jeez."],[1876,1972,"Relax, Vivian."],[2014,2147,"Shut up, Claudia."],[2275,2362,"Did you or your mom"],[2362,2464,"have anything to do with it?"],[2464,2585,"I'm not gonna ask you again."],[2602,2777,"I had nothing to do with"],[2777,2861,"what happened to you."],[2923,3086,"And you look like you're doing pretty well,"],[3086,3236,"living with your new sugar daddy."],[3486,3670,"Hey, hey! You're still injured."],[4049,4137,"You're getting a little kinky"],[4137,4258,"with your sugar daddy, huh?"],[4475,4658,"Aw, just curious, Vivian."],[4738,4884,"Do you ever dream of the fortune"],[4884,5007,"that you could've inherited"],[5007,5059,"if you weren't"],[5059,5213,"whoring yourself out right now?"],[5259,5409,"You and your mother"],[5409,5528,"stole my inheritance,"],[5528,5612,"and you probably"],[5612,5726,"killed my Dad to do it."],[5797,5914,"Be careful."],[5914,6022,"He was my dad too."],[6022,6116,"And I'm not gonna let you"],[6116,6322,"throw around these baseless accusations."],[6352,6550,"Yeah, shut up, Vivian,"],[6550,6773,"before Olivia's fiancé gets here."],[6773,6894,"He's the Mafia King."],[6990,7123,"Is she talking about Damien?"]],"8":[[133,229,"That's impossible."],[271,354,"Bullshit."],[379,504,"There's only one Mafia King"],[504,596,"and I live with him."],[909,1046,"Oh, here we go again."],[1059,1205,"Always the Drama Queen"],[1205,1376,"with the lies."],[1522,1620,"Oh, if you have a problem"],[1620,1777,"with me marrying the Mafia King,"],[1797,1922,"what are you gonna do about it?"],[2081,2180,"I just need to find a place"],[2180,2302,"to bury your body."],[2385,2535,"Oh, you need some sense"],[2535,2644,"slapped into you."],[2761,2886,"Okay, it's on!"],[3991,4187,"Both of you! Stop!"],[4208,4383,"Thomas, get out of my way!"],[4429,4496,"Stop!"],[4496,4675,"Get your fucking hands off my girl!"]],"9":[[20,83,"You okay?"],[608,679,"Oh! Oh!"],[909,1084,"Oh! Honey!"],[1113,1213,"You came!"],[1334,1543,"Everyone, this is my fiancé,"],[1543,1664,"Damien Russo,"],[1685,1914,"the city's most powerful mafia boss."],[1939,2131,"Our wedding's in just a couple days."],[2206,2327,"You’re Olivia Green?"],[2364,2531,"Well, soon I'll be Olivia Russo."],[2602,2752,"You're getting married to the bitch"],[2752,2902,"who kicked me out of my own house,"],[2902,3098,"stole my inheritance, and ruined my life?"],[3970,4104,"Wait! Damien!"],[4587,4679,"Vivian?"],[4867,5013,"The marriage is just a business deal."],[5684,5797,"It's over once I get"],[5797,5893,"the shipping routes."],[6339,6523,"Your hand looks like it's healing."],[7057,7140,"Why her?"],[7307,7486,"After everything she did to me,"],[7524,7640,"I can't believe you'd do"],[7640,7761,"something like this."],[7932,8116,"Don't follow me."],[8295,8437,"If you go through with this,"],[8454,8679,"you will never see me again."],[9601,9701,"Follow her."],[9743,9855,"Make sure she's safe."],[10789,10969,"Dig up everything you can"],[10969,11140,"on Olivia Green."],[11223,11386,"I wanna know what she's done"],[11490,11611,"and what she's up to."],[12016,12166,"Mom, that bitch we sold to the mafia"],[12166,12308,"is living with my fiancé."],[12337,12391,"We have to do"],[12391,12499,"something about this."]],"10":[[583,655,"The one behind"],[655,855,"your kidnapping will be here."],[1993,2064,"Do you think Vivian"],[2064,2214,"will actually show up?"],[2394,2494,"Of course she will."],[2686,2848,"And when she does,"],[2848,2957,"we'll humiliate her"],[2957,3036,"in front of everyone."],[3036,3044,"in front of everyone."],[3103,3182,"She'll be gone"],[3182,3328,"before the wedding even starts."],[3390,3570,"Oh, cheers."],[3570,3712,"Cheers to that, darling."],[4216,4283,"I know."],[4529,4608,"So good."],[5338,5463,"Well, well, well."],[5480,5597,"Someone missed the memo"],[5597,5730,"about the wedding day."],[5844,5979,"Dressed like that,"],[5979,6172,"I should've called the Back Alley Boys."],[6172,6248,"And they could've"],[6248,6502,"given you some of their handy work."],[6631,6790,"Aww, Viv."],[6831,7023,"Damian took care of you for so long."],[7023,7150,"You must be so happy"],[7150,7303,"he's finally getting married."],[7399,7565,"My father gave me that necklace."],[7620,7741,"How did you get it?"],[8274,8400,"Damian gave it to me."],[8412,8562,"I think it looks better on me, don't you?"],[8612,8696,"Get it back!"],[8754,8804,"No!"],[9488,9576,"What the fuck?!"]],"11":[[20,137,"What the fuck?!"],[621,746,"How dare you push my daughter"],[746,909,"and try to steal her necklace"],[946,1026,"when we graciously"],[1026,1188,"invited you to this wedding,"],[1213,1255,"despite you"],[1255,1409,"abandoning our family?"],[1814,2022,"My dress is ruined!"],[2114,2285,"Damien is the Mafia King."],[2285,2464,"He's gonna kill you for this."],[2900,3045,"Typical Vivian,"],[3045,3319,"always ruining everyone's big day"],[3319,3482,"just because your life went to shit."],[3549,3728,"You're fucking liars!"],[3837,3999,"You stole everything from me"],[3999,4237,"and now you wanna play the victim, hm?"],[4337,4562,"The Green Corporation is thriving"],[4562,4704,"under our management"],[4704,4833,"and what have you done?"],[4871,4996,"Left the family?"],[4996,5096,"Sold yourself to be"],[5096,5180,"my husband's mistress?"],[5284,5351,"Fuck you!"],[5351,5576,"Once a whore, always a whore."],[5772,5814,"Enough."],[5993,6164,"Damien, what are you doing here?"],[6164,6252,"Don't you know it's bad luck"],[6252,6377,"to see the bride before the wedding?"],[6468,6594,"I saw what just happened."],[6598,6705,"Do you still think I'm fucking"],[6705,6773,"marrying you?"],[6906,6998,"This wedding is off."]],"12":[[83,241,"You promised to marry my daughter."],[287,583,"You'll never get your shipping routes"],[583,721,"if you abandon her now."],[750,834,"Damien, please!"],[849,1056,"If I had known that you two had been"],[1056,1251,"tormenting Vivian this entire time,"],[1280,1384,"I never would've"],[1384,1534,"agreed to this arrangement."],[1568,1648,"So our wedding's off"],[1648,1818,"just for this worthless bitch?"],[2118,2339,"If you touch any of her things again,"],[2485,2585,"I'll cut your fingers off."],[2969,3119,"He still cares about me."],[3165,3298,"Everyone knows"],[3298,3478,"she's just a gold digger."],[3741,3849,"Mom, do something!"],[3908,4145,"Olivia, leave it."],[4400,4495,"You can take everything"],[4495,4579,"you stole from me"],[4721,4838,"straight to hell."]],"13":[[700,746,"Vivian!"],[813,950,"I didn't know you were gonna be here."],[1134,1330,"Yeah, the wedding's off."],[1347,1572,"Olivia completely embarrassed herself."],[1651,1743,"- Wow. - Yeah."],[1772,1881,"Can't believe I missed that."],[2181,2310,"Hey, we need to go."],[2435,2573,"Be careful around him."],[2727,2819,"What's that supposed to mean?"],[2952,3098,"Just looking out for her, man."],[3357,3503,"He didn't mean anything about it."],[3503,3653,"Sorry. Let's go."]],"14":[[500,688,"What a shitshow, huh？"],[734,821,"Yeah."],[829,917,"Yeah."],[1247,1355,"Stay away from Thomas."],[1551,1618,"Are you nervous"],[1618,1768,"I'll run away with him?"],[1893,2039,"He's not the right man for you."],[2181,2260,"Then..."],[2306,2540,"who is the right man for me?"],[3261,3390,"Still my sweet girl."],[5818,5947,"I'm gonna make you famous,"],[5947,6160,"you gold-digging whore."]],"15":[[1192,1263,"What the hell?"],[2640,2711,"You've seen it?"],[2773,2907,"I'm gonna kill Olivia!"],[3161,3269,"Let me handle it."],[3324,3432,"I will teach the Greens a lesson"],[3432,3545,"they will not forget."],[3599,3732,"Wait, Damien."],[3824,4012,"This is my fight and..."],[4012,4237,"I wanna handle it myself."],[4295,4366,"Okay."],[4517,4604,"Not without me."]],"16":[[896,1267,"Damien, what a pleasant surprise."],[1267,1459,"Have you reconsidered marrying Olivia?"],[1630,1822,"No, but I'm sure you know"],[1822,1926,"what she's done."],[2043,2210,"Olivia, what happened?"],[2623,2773,"Mr. Russo, I'm sure whatever it is,"],[2819,2982,"it's just all a misunderstanding."],[3103,3407,"Well, I mean, I'll let Vivian decide that."],[3541,3678,"Vivian, darling,"],[3707,3807,"let's be lenient."],[3807,3991,"We are family after all."],[4108,4396,"Oh, now we're family?"],[4441,4654,"After you stole everything from me"],[4654,4821,"and had me kicked out of my own house,"],[4846,5013,"now you want mercy?"],[5080,5167,"No."],[5422,5539,"Cancel all contracts"],[5539,5693,"with the Green Corporation."],[5697,5922,"I want them bankrupt."]],"17":[[29,171,"I want them bankrupt."],[600,784,"It's already done."],[834,950,"You think you can just"],[950,1130,"shut down Green Corp?"],[1451,1601,"Mr. Russo is the Mafia King, but..."],[1634,1906,"Mom? What's happening?"],[2231,2502,"They're canceling all our contracts."],[2806,2973,"Mr. Russo, please..."],[3015,3215,"Please don't do this to us."],[3311,3636,"Again, Vivian is calling the shots."],[3791,3895,"Vivian..."],[4041,4216,"Vivian,"],[4216,4525,"I'm sorry for whatever happened to you,"],[4525,4825,"but Green Corp is everything to this family."],[4871,5230,"If you do this to us, we are fucked."],[5230,5442,"Stop it, Mom. Don't beg this bitch."],[5442,5538,"It's useless."],[5663,5826,"Shut up, you stupid child."],[5897,6097,"I gambled all our money away."],[6106,6268,"We don't have anything left"],[6268,6398,"if the company tanks."],[6398,6459,"What?"],[6459,6637,"Your inheritance is gone!"],[6637,6766,"All of it!"]],"18":[[12,175,"Your inheritance is gone!"],[241,354,"No fucking way!"],[354,492,"All of it! It's gone."],[554,600,"Oh my god."],[746,842,"I am so sorry, sis."],[867,1067,"I never meant to. I swear..."],[1067,1242,"If you want those contracts back,"],[1242,1363,"tell me who had me kidnapped"],[1363,1451,"and my father killed."],[1614,1747,"Wait, wait a minute."],[1780,1972,"Who said he was killed?"],[2093,2289,"We had nothing to do with that."],[2289,2438,"And we had nothing to do"],[2438,2540,"with your kidnapping either."],[2540,2650,"I mean, how do you even"],[2650,2740,"kidnap somebody?"],[2740,2852,"I don't know."],[2886,3107,"Then you can kiss your contracts goodbye"],[3107,3311,"and enjoy the bankruptcy."],[3311,3603,"And actually, I'm taking the mansion."],[3707,3937,"No, Vivian."],[4008,4237,"This mansion is the only collateral I have"],[4237,4491,"when the debt collectors come knocking."],[4592,4808,"If I can't sell it and pay them back,"],[4954,5038,"they're gonna kill me."]],"19":[[133,254,"That really sounds"],[254,354,"like a you problem."],[471,668,"This mansion belonged to my late parents,"],[668,779,"and now it belongs to me."],[829,996,"It never belonged to you."],[1080,1263,"Oh, come on. I mean, we never"],[1263,1363,"meant to hurt you."],[1459,1593,"I was just jealous that you were"],[1593,1701,"always Dad's favorite."],[1776,2039,"You made your bed. Now lie in it."],[2118,2355,"Clearing them out of here is not a problem."],[2355,2481,"Say the word."],[2915,3065,"Vivian, we are family."],[3161,3240,"It was her!"],[3499,3599,"What?"],[3603,3697,"Now you're selling out"],[3697,3812,"your own mother?"],[3837,3995,"She told me that Dad was planning"],[3995,4226,"on giving a bunch of money to Greenpeace"],[4226,4379,"and that if we killed him,"],[4379,4519,"we'd get to keep the money."],[4542,4671,"You backstabbing bitch!"],[4671,4808,"I did all of this for you."],[4833,4904,"Maybe if you hadn't"],[4904,5030,"gambled away the profits,"],[5030,5180,"I wouldn't be forced to do this."],[5301,5438,"Breathe, Vivian."],[5447,5509,"Breathe."],[5676,5768,"Lock Catherine up"],[5768,5922,"and take Olivia away."],[5960,6014,"I don't want them"],[6014,6114,"anywhere near this house."]],"20":[[37,104,"Please."],[104,225,"Vivian, please."],[225,342,"- No. - Please."],[342,442,"Vivian, I can't"],[442,533,"fend off the debts."],[533,667,"Don't do this, Vivian! Stop!"],[696,821,"Don't do this! No!"],[1789,1847,"Vivian."],[1968,2027,"Are you okay?"],[2060,2114,"I heard Olivia"],[2114,2256,"did a number on you."],[2256,2335,"Why are you everywhere?"],[2419,2489,"Get lost."],[2519,2598,"I'm just here to"],[2598,2686,"help out a friend."],[2752,2827,"Bullshit."],[2831,2973,"What do you want with Vivian anyway?"],[3002,3098,"You know, maybe I should be worried"],[3098,3215,"about her being around you."]],"21":[[583,658,"Hey! Hey!"],[709,763,"Stop."],[925,1076,"One more word,"],[1076,1176,"I'll blow your fucking head off."],[1251,1359,"Damien, stop!"],[1622,1789,"You're gonna regret being with him, Vivian."],[1814,1889,"I'm telling you."],[2515,2602,"Why do you have to be"],[2602,2740,"so controlling all the time?"],[3516,3636,"Does he know what I'm feeling?"],[3724,3924,"Does he even care?"],[3995,4275,"He would just ignore it, as always."],[5689,5910,"You're breaking the rules again."],[6114,6239,"So?"]],"22":[[33,150,"So?"],[467,563,"Go ahead."],[596,671,"Punish me."],[775,875,"I don't care."],[1168,1294,"I've lost everything"],[1294,1451,"that was important to me."],[1576,1630,"And you..."],[1714,2093,"You drove away the one friend I had left."],[2206,2423,"You're acting out over him?"],[2598,2848,"You don't even see he's not good for you."],[2848,3103,"I can make my own decisions."],[3632,3953,"Enough! Vivian!"],[4715,4824,"Come on."],[4824,4975,"Let's get you cleaned up."],[6961,7152,"Why did I do that?"],[7152,7344,"Was I trying to piss him off?"]],"23":[[183,221,"Sober now?"],[538,688,"Damien, I'm..."],[688,838,"I really shouldn't have..."],[1651,1764,"Just like old times, huh?"],[1868,1926,"Hmm."],[2414,2494,"What are you thinking?"],[2673,2886,"That I can't help but fall for you?"],[3115,3232,"You wouldn't care."],[3415,3620,"I care about you, Vivian."],[3737,3908,"More than you know."]],"24":[[296,500,"I'm... I'm sorry."],[629,767,"I'm sorry."],[1359,1568,"Damn it."],[2097,2389,"We kissed. We actually kissed."],[2448,2573,"What am I thinking?"],[2585,2840,"Did he... feel anything?"],[2944,3215,"Oh! Why did I run?"],[3215,3365,"I should've pushed him down"],[3365,3486,"and gone for it."],[4066,4287,"Vivian, where are you?"],[4287,4383,"I need to tell you something."],[4496,4583,"Can we meet?"],[4629,4763,"Uh, what's the rush, Thomas?"],[4763,4875,"I'm in bed."],[4892,4962,"I can't hide"],[4962,5096,"how I feel about you anymore."],[5246,5292,"What?"]],"25":[[116,187,"What?"],[326,430,"No, Thomas,"],[430,671,"we're just friends, that's all."],[754,875,"I don't believe that."],[913,1000,"Is it because of Damien?"],[1059,1184,"Are you in love with him?"],[1584,1751,"Okay. Stay focused, Viv."],[1868,2027,"Don't let anyone distract you."],[2335,2581,"If Damien won't make the first move,"],[2581,2731,"then I will."],[6064,6260,"Vivian, what are you doing?"],[6468,6719,"I think we both know what I want."],[11323,11444,"Was that a dream?"],[12082,12141,"Okay."],[13000,13196,"I can do this. I can do this."]],"26":[[725,779,"Damien?"],[888,959,"Hold on."],[1330,1403,"I'm gonna wait"],[1403,1509,"in the living room."],[2394,2527,"Okay, sir."],[2840,2948,"Oh, I'm sorry."],[2965,3178,"Uh, where's Damien?"],[3244,3365,"Mr. Russo went out already."],[3395,3440,"He said he had"],[3440,3545,"something urgent to do."],[3803,3891,"He's gone?"],[3962,4008,"Yes."],[5063,5226,"Fucking great."],[6239,6410,"What did I say about drinking?"],[6523,6627,"Viv, go to bed..."],[7115,7336,"Did she wear this for me?"]],"27":[[166,387,"Damien, I love you."],[3040,3219,"Still a biter."],[3269,3407,"I should probably leave her here."],[3420,3536,"Like I don't know what she did."],[6535,6823,"Fuck, I can't let him see me like this."],[8020,8179,"Stop staring."],[8179,8266,"Come eat breakfast."],[9242,9401,"Where were you last night?"],[9734,9843,"Does it matter?"],[10126,10326,"Was he with another woman last night?"]],"28":[[45,225,"Was he with another woman last night?"],[788,867,"Wait, where are you going?"],[1042,1201,"Just gonna change."],[2310,2469,"I'm so stupid."],[2681,2802,"He doesn't want me."],[2873,3069,"He's sleeping with other women."],[3949,4024,"Vivian?"],[4104,4245,"Hey, Thomas."],[4550,4821,"Yeah, I was thinking, and you're right."],[4963,5163,"I think we should be more than friends."],[5584,5768,"No... I wondered... I didn't..."],[5814,5943,"It's not that easy."]],"29":[[487,554,"Damien?"],[592,763,"What the fuck, man?"],[775,859,"Damien!"],[909,1005,"What was he doing in my house?"],[1005,1078,"I invited him"],[1078,1192,"and we were just talking!"],[1272,1380,"Keep your distance."],[1380,1547,"Or I will not hesitate to blow your head off."],[1547,1714,"Don't!"],[3107,3294,"Why are you so uptight all the time?"],[3474,3670,"But I can't have anyone around."],[3703,3837,"It's not up for debate, Vivian."],[3837,4016,"I told you to stay away from him."],[4058,4187,"Well, I'm seeing him."],[4312,4587,"You know what? We're dating."],[5271,5392,"What did you just say?"]],"30":[[120,258,"He really cares about me."],[358,489,"Why does he sleep around"],[489,638,"if he actually cares about me?"],[771,996,"I said we're dating."],[1076,1224,"And you're seeing other women"],[1224,1355,"so I don't know what the big deal is."],[1355,1459,"No, I'm not seeing anyone."],[1459,1572,"What are you talking about?"],[1576,1643,"Tell that to the"],[1643,1780,"bite mark on your neck."],[1805,1926,"What do I tell her?"],[1968,2110,"That it's her?"],[2110,2210,"No."],[2214,2385,"I don't have to explain anything to you."],[3011,3332,"Are you secretly screwing Olivia?"],[4220,4333,"Are you happy?"],[4333,4433,"Is this what you want?"],[4746,4800,"No."],[5000,5092,"That's not enough."]],"31":[[1518,1597,"Damien..."],[1714,1822,"Tell me what you want."],[1906,2160,"You. Only you."],[2669,2761,"Leave it!"],[3499,3570,"What?"],[3866,4049,"Alright, I'm coming to you."],[4200,4362,"Catherine escaped custody."],[4362,4466,"I've got to go find her."],[4483,4533,"What?"]],"32":[[100,216,"Catherine escaped custody."],[258,375,"I've got to go find her."],[425,563,"Let me come with you!"],[571,750,"No, it's not safe."],[779,1021,"Stay here. I'll be back."],[1247,1330,"I promise."],[2869,3015,"You're worthless, Vivian."],[3107,3186,"My friend here is"],[3186,3286,"gonna take you out."],[3311,3561,"You're the reason, you're–"],[3591,4016,"You worthless little piece of slime."],[4091,4265,"Just think"],[4265,4400,"of how good this feels."],[4421,4583,"You like that, right?"],[4612,4825,"You're the scum of the earth."],[4825,4988,"You're lower than the lowest."],[5021,5142,"You're the scum."],[5176,5388,"You have nothing."],[5388,5638,"I took everything from you."],[5638,5851,"I was giving you your mind."],[6110,6556,"No, help, no. Please don't. Don't."],[6623,6706,"Please, don't take me!"],[6715,6915,"- Hey, Vivian, wake up! - Damien, please!"],[6981,7253,"No, I can't escape. Please, Damien."],[7294,7520,"Vivian, I got you. Okay?"],[7520,7620,"You're safe."],[7628,7728,"I got you."],[7916,8108,"Wait, wait. Where's Catherine?"],[8108,8187,"What happened?"],[8224,8375,"We know where she's headed, but..."],[8375,8504,"it's gonna take some time."],[8587,8837,"Look, look. I promise you,"],[8837,9000,"we will get her. Okay?"],[9000,9154,"Okay, okay."],[9488,9793,"Hey. I've got a surprise for you."]],"33":[[1201,1334,"Damien,"],[1413,1643,"you did all this for me?"],[1906,2060,"You deserve the world."],[2214,2331,"I want you to know,"],[2423,2552,"you're never gonna be alone again."],[2631,2736,"Never again."],[3324,3524,"Boss, they need you at the office."],[3787,3899,"No, no, no, no, no."],[3899,4012,"Duty calls."],[4333,4483,"Wait, don't..."],[4525,4642,"just take me with you."],[4688,4859,"I promise I'll be good."],[7198,7307,"Have you ever had sex in here?"]],"34":[[70,304,"Have you ever had sex in this office?"],[442,608,"Strictly business here."],[913,984,"Really?"],[1151,1230,"Not even once?"],[1343,1526,"Not even with..."],[1526,1714,"whoever gave you that hickey?"],[1818,1893,"Oh, that one."],[1910,1968,"Mm-hmm."],[2027,2156,"She was a feisty one."],[2373,2498,"Hey, why don't we get rid of that hickey"],[2498,2698,"and add a new one?"],[6798,6873,"Okay."],[7102,7226,"I'm gonna go to a party"],[7226,7323,"with some friends."],[7478,7636,"Is Thomas gonna be there?"],[7795,7862,"Don't worry."],[8007,8112,"If he is, I won't let him near me."],[9280,9325,"Follow her."],[9442,9534,"Make sure she's safe."]],"35":[[529,617,"Damien didn't ask me"],[617,704,"to stay home tonight."],[829,967,"Does he still care about me?"],[1509,1747,"Oh! Look who's here."],[1747,1910,"The mafia's little pet."],[1914,2047,"Did he dump you already"],[2047,2235,"that you're looking for new clients?"],[2281,2364,"I came here to have"],[2364,2544,"a good time, Claudia, so..."],[2544,2698,"why don't you shoo and piss off"],[2698,2769,"someone else?"],[2777,2940,"Yeah, back off, Claudia."],[2990,3224,"Your family's company is in shambles,"],[3224,3395,"and you're here acting like hero?"],[3582,3762,"You two are perfect for each other."],[3832,4070,"It's pathetic, both of you."]],"36":[[358,412,"Nice shot."],[412,462,"Thanks."],[462,613,"The precision is uncanny."],[734,855,"She had it coming."],[880,959,"Hey, what?"],[971,1121,"What happened to your family's company?"],[1288,1401,"Damien's what happened."],[1518,1655,"I think he's taking the jealousy thing"],[1655,1764,"to a whole new level."],[1805,1901,"Hey, don't worry."],[2014,2118,"I'm gonna fix that."],[2281,2369,"It's not your fault."],[2627,2815,"But how about a dance"],[2861,2969,"for old time's sake?"],[3415,3465,"Sure."],[5405,5467,"Let's go."],[6502,6577,"Damien..."],[6715,6840,"You are on thin ice."]],"37":[[8,145,"You are on thin ice."],[275,387,"You told me you were going to"],[387,550,"stay away from Thomas."],[550,675,"Do you care to explain"],[675,775,"what I just saw out there?"],[825,925,"You don't want me near him"],[925,996,"because you wanted to"],[996,1117,"tank his family company?"],[1155,1234,"Is that it?"],[1655,1899,"Why are you so obsessed"],[1899,2022,"with challenge me?"],[2118,2218,"You love it,"],[2256,2356,"don't you?"],[3186,3382,"Don't take your anger out"],[3382,3582,"on Thomas and his family."],[3645,3720,"Please."],[4875,5025,"Have my men stopped the collections"],[5025,5201,"on the Thomas Family Foundation now."],[5338,5397,"And there's no need to"],[5397,5501,"hit their sites anymore."],[6022,6122,"Better now?"],[6256,6356,"Yeah."],[6756,7019,"As long as you are with me,"],[7019,7198,"you can have whatever you want."],[7378,7436,"Really?"],[7474,7532,"Really."],[8450,8696,"Hold still! Damien!"]],"38":[[29,250,"Oh. I'm not the one ruining my face."],[362,513,"Uh... Boss?"],[963,1063,"Well?"],[1609,1864,"It's... artistic."],[1968,2110,"A genius artist!"],[2139,2243,"A soulful painter!"],[2318,2377,"Yes!"],[2498,2635,"Okay, I'm gonna go get"],[2635,2748,"some more products,"],[2748,2932,"but this is just the beginning."],[3123,3178,"Okay."],[3586,3732,"You're getting a pay cut this month."],[3866,3953,"Out."],[4421,4517,"Hey!"],[4654,4825,"That was my fault."],[4892,5034,"Take this. It'll cover your pay cut."],[5088,5167,"I can't."],[5167,5359,"No, come on. Consider it a gift."],[5505,5743,"Well, thank you."],[5764,5914,"No problem."],[6243,6398,"Nobody's ever done this for me."]],"39":[[333,454,"Sir, I can help with this."],[554,767,"No, I want to do this for her."],[1059,1259,"Hey, sit."],[1334,1451,"Breakfast is just about ready."],[1655,1785,"You're dismissed for the day."],[2239,2344,"Did you sleep alone?"],[2489,2569,"Yeah."],[2723,2865,"I always sleep alone."],[2911,2965,"Yeah?"],[2965,3053,"Mm-hmm."],[3053,3224,"I'm not..."],[3224,3307,"I'm not used to it anymore."],[3536,3699,"He's obsessed with me now."],[3766,3891,"I hope it never ends."],[4220,4525,"Okay, that's really good."],[4625,4708,"You like?"],[5138,5263,"Did you burn your hand?"],[5351,5547,"Yeah, cooking accident."],[5809,5889,"Okay."],[7841,7933,"I'm gonna be..."],[8091,8191,"by your school later taday."],[8223,8323,"Do you mind if I stop by?"],[8417,8533,"Are you spying on me?"],[8669,8769,"Maybe."]],"40":[[563,663,"What do you want?"],[746,896,"You think you can just waltz back in here"],[896,1071,"after what happened at the party?"],[1109,1167,"Oh."],[1242,1426,"Are we still talking about that?"],[1647,1739,"Do you wanna end up"],[1739,1985,"like your bestie, Olivia?"],[2064,2168,"You know, everyone at the party"],[2168,2398,"saw how pissed Damien was at you."],[2444,2565,"and saw how your ass kicked"],[2565,2756,"as soon as your mafia protector"],[2756,2911,"kicks you to the curb."],[3169,3240,"That's really cute."],[3325,3431,"You know, I wonder"],[3431,3516,"what Damien would think"],[3516,3649,"of what you just said."],[3716,3787,"Me too."],[4149,4187,"Hi."],[4316,4441,"Yeah, I'm in the side garden."],[4487,4604,"You better hurry, Damien."],[4696,4917,"You're not fooling anyone."],[4950,5055,"Damien doesn't want you"],[5055,5234,"and he's probably already kicked you out."],[5947,6047,"Sorry for the delay."],[6202,6360,"I was just picking the right bouquet for you."],[6401,6569,"Thanks."],[6600,6682,"Um..."]],"41":[[233,342,"Thanks."],[342,629,"Um... Hi, um..."],[638,934,"You two look perfect together."],[1009,1176,"That's not what you said earlier."],[1230,1330,"Oh, what did she say?"],[1363,1559,"Um, no, it's just a"],[1559,1705,"misunderstanding, Mr. Russo."],[1705,1906,"I would never want to offend you"],[1906,2089,"or anyone that you love."],[2285,2410,"I'm gonna go. I'm gonna go."],[2615,2715,"Thanks for coming."],[3232,3328,"So you're..."],[3478,3624,"gonna sleep in your room again?"],[3699,3832,"Don't worry, I'll just be"],[3832,4008,"out here..."],[4008,4099,"alone..."],[4229,4425,"Fine, I'll ’come over."],[4471,4612,"Just give me a few minutes."],[4625,4788,"Let me fix myself up."],[4808,4975,"But don't get used to it."],[5597,5709,"Too late."]],"42":[[145,212,"Boss..."],[347,445,"I never thought I'd see you"],[445,625,"do the \"sad puppy\" act on a girl."],[792,909,"You don't wanna get paid at all"],[909,1009,"this year, do you?"],[1092,1205,"Sorry. Didn't see"],[1205,1292,"or hear a thing!"],[2815,2994,"Your old injuries are flaring up."],[3353,3432,"I'm okay."],[3782,3949,"As long as you're here with me,"],[3949,4033,"I'm okay."],[4058,4141,"Damien,"],[4479,4696,"I want you to know that"],[4763,4896,"I'll never leave you."],[4929,5130,"And I need you"],[5130,5463,"to know that I love you."],[6781,6877,"Slow?"]],"43":[[442,663,"Boss, are you sure about this?"],[742,992,"She deserves more than just jewelry."],[1059,1422,"This year, I'm gonna give her something"],[1422,1639,"thoughtful,"],[1639,1797,"personal."],[2360,2427,"Hey."],[2469,2535,"Vivian."],[2544,2648,"I know you have birthday coming up,"],[2648,2736,"so..."],[2823,3036,"well, I gotcha a thing."],[3486,3682,"It's really interesting packaging."],[4237,4396,"Boss made that cat himself!"],[4542,4696,"Oh my god, I'm..."],[4725,4888,"I'm so sorry, Damien."],[4909,5042,"I thought there was something inside."],[5075,5201,"No, it's..."],[5201,5330,"It's okay. It's just..."],[5330,5422,"a silly little thing."],[5422,5559,"I'll..."],[5559,5709,"I'll get you another gift."]],"44":[[141,204,"Vivian."],[321,525,"Hey, I wanted to thank you"],[629,750,"for saving my family's company."],[792,1017,"Yeah, don't mention it."],[1188,1259,"What's wrong?"],[1292,1413,"Damien made me a gift"],[1413,1568,"and I broke it."],[2652,2811,"Let me help fix it."],[2837,2910,"I'll make sure"],[2910,3019,"you can give him something back."],[3086,3269,"Something that surprises him."],[3303,3370,"Really?"],[3453,3516,"Come on."],[3516,3578,"Okay."],[4179,4329,"Boss, Ms. Vivian's missing."],[4329,4450,"We can't find her anywhere."],[4496,4592,"Where was she last seen?"],[4608,4788,"She was last seen getting into Thomas' car."],[4788,4879,"That college boy."],[5075,5155,"Go find her!"],[5409,5563,"I'll kill that fucking kid."]],"45":[[183,321,"They are headed toward the border."],[321,525,"Get every available man on this."],[1622,1726,"It'll get dark soon."],[1872,2027,"Where's that fixer guy"],[2027,2139,"you were talking about?"],[2273,2414,"That'll just be a little longer."],[3032,3140,"Remember these sandwiches?"],[3203,3250,"Our favorite"],[3250,3357,"from when we were freshmen."],[3586,3703,"Hmm, thanks."],[4471,4600,"It's getting late."],[4696,4875,"I think we should head back, and"],[4875,5080,"I'll just get it fixed another time."],[5205,5276,"No."],[5359,5488,"We can't go back."],[5593,5676,"I have to take you"],[5676,5784,"far away from Damien."],[5851,5935,"Whoa."],[6072,6210,"What are you talking about?"]],"46":[[25,175,"What... what are you talking about?"],[233,362,"Damien's dangerous, Vivian."],[429,565,"I mean, see how he manipulates you"],[565,679,"with something as simple as a"],[679,884,"broken clay cat? I mean, he's..."],[900,1076,"Who do you think you are?"],[1213,1455,"I don't need you to save me."],[1568,1768,"In fact, I'm gonna find my own way home."],[1801,1881,"How much do you"],[1881,1989,"really know about him?"],[2035,2196,"He killed his father and uncle"],[2196,2298,"to get to where he is."],[2335,2419,"You know that?"],[2519,2610,"You're lying."],[2765,2890,"He wouldn't do that to his own family."],[3157,3240,"Shit!"],[4166,4275,"Vivian."],[4346,4471,"Come here. Now!"]],"47":[[304,408,"I'm sorry, I was just trying to"],[408,513,"fix the gift I broke"],[513,608,"and I felt terrible."],[734,813,"I told her about how you"],[813,917,"killed your family, Damien."],[1009,1130,"But I guess you brainwashed her well"],[1130,1267,"to believe everything she's been fed."],[1347,1497,"No more passes. I'm sick of you."],[1497,1622,"Hey, wait!"],[1843,2168,"Look, I'm sorry that I don't feel"],[2168,2306,"the same way as you,"],[2364,2573,"but I don't need you to save me."],[2773,2911,"And you're wrong about Damien."],[3249,3357,"So leave us alone."],[4354,4537,"Aren't you scared?"],[4537,4654,"After everything he told you?"],[4800,4864,"You do a good job"],[4864,4988,"of playing the tough guy."],[5080,5180,"Everyone may know you as"],[5180,5401,"the Mafia King, but..."],[5401,5526,"I know the real you."],[5693,5851,"And I'm not afraid of you, Damien."],[5939,6056,"I love you."],[6189,6293,"I love you too."]],"48":[[625,709,"What do you want?"],[763,859,"Let's finish this."],[1084,1222,"I've done some digging,"],[1238,1368,"and the Green Family fall,"],[1418,1576,"the bankruptcy moving,"],[1659,1864,"all ordered by the Mafia King himself."],[1956,2014,"Okay."],[2043,2093,"And?"],[2139,2394,"And I heard you injured him,"],[2410,2638,"and that his feelings for you have faded."],[2638,2731,"Completely."],[3028,3232,"I think you're a little misinformed."],[3478,3666,"I'm gonna make sure"],[3666,3812,"you suffer, Vivian,"],[3870,4091,"especially on campus."],[4508,4763,"I'm done with your bullshit threats."],[4950,5088,"Give it up, Claudia,"],[5163,5384,"or you're not gonna like how this ends."]],"49":[[675,750,"Vivian!"],[838,967,"Hey, can we talk?"],[1055,1180,"What are you doing here?"],[1197,1284,"It's about Dad."],[2156,2273,"Caramel latte,"],[2273,2431,"your favorite. I remembered."],[3415,3536,"So, um..."],[3774,3945,"Everything that happened to you,"],[4033,4245,"my mom and I were at fault."],[4391,4529,"I am so sorry."],[4608,4813,"Can you find it anywhere"],[4813,4979,"in your heart to forgive us?"],[5059,5184,"I don't wanna hear"],[5184,5342,"your sob stories."],[5426,5512,"You said you wanted to"],[5512,5609,"talk about Dad."],[5609,5709,"Let's talk."],[5709,5826,"Yes, yes, the Green Corp."],[5847,5926,"It's..."],[5985,6097,"Damien is crushing it."],[6151,6275,"Can you really bear to see"],[6275,6485,"Dad's life work destroyed like that?"],[6514,6656,"I'll take care of the company."],[6723,6865,"Don't you worry."],[6894,6977,"And as for that"],[6977,7132,"dear mother of yours,"],[7178,7336,"better give her up"],[7336,7503,"or you're gonna have hell to pay."],[8729,8863,"Gotcha, bitch."]],"50":[[387,538,"I should've been the Green heiress."],[538,746,"I should've married the Mafia King."],[746,950,"But you ruined everything for me!"],[1051,1217,"Now I have to sell myself"],[1217,1349,"to gross old men"],[1349,1555,"to make up for what you took."],[1622,1826,"You have no idea what that feels like."],[1885,2043,"But you will."],[2089,2289,"I've got some boys on the varsity team"],[2289,2510,"who are gonna love having fun with you."],[2652,2890,"Hey, she's all ready."],[2890,2977,"Come and get her."],[3611,3795,"What the hell? I drugged you!"],[3866,4095,"Not as gullible as you think, huh?"],[4287,4450,"No, no, no!"],[6147,6306,"Good luck with those clients."],[6340,6439,"Glad you're putting that"],[6439,6623,"whore mouth of yours to good use."]],"51":[[400,563,"I'm coming home, Damian."],[563,729,"My last class got cancelled."],[925,1105,"You think you've won, Vivian?"],[1309,1576,"Please, just fucking die!"],[1609,1818,"Go to hell. You fucking bitch!"],[3161,3328,"Damien, are you okay?"]],"52":[[133,300,"Damien, are you okay?"],[1518,1584,"No!"],[1776,2122,"Don't do it. She is not worth it."],[2256,2398,"Please, give it back!"],[2398,2535,"She deserves to fucking die."],[2585,2635,"Trust me."],[2823,2887,"You don't want"],[2887,3011,"that blood on your hands."],[3032,3215,"She's half the reason my father was killed,"],[3224,3361,"and she's trying to kill me."],[3378,3532,"Please, please don't kill me."],[3532,3703,"Please, please! My mom, my mom..."],[3703,3920,"I can take you to her. Please!"],[3933,4137,"Please, I know where she is. Please."]],"53":[[746,846,"Did you take care of her?"],[905,1096,"Yeah, mom, I took care of her."],[1209,1259,"Good girl."],[1347,1501,"Now we just have to get rid of"],[1501,1643,"the debt collectors somehow."],[1672,1814,"Well, mom, when I said that I"],[1814,1893,"took care of her,"],[1893,2010,"I really meant that I, that..."],[2156,2264,"She'd meant that she'd taken"],[2264,2344,"great care of me."],[3349,3428,"Ah-uh..."],[3524,3570,"Off."],[3703,3803,"Vivian."],[3941,4099,"I didn't mean you any harm."],[4099,4175,"Oh."],[4683,4917,"Mr. Russo, you have to"],[4917,5092,"talk some sense into Vivian."],[5134,5409,"She's a sweet girl, not a killer."],[5497,5709,"Yeah, I used to be a sweet girl."],[5822,6106,"Until you took that away from me"],[6106,6264,"all those years ago."],[6264,6356,"And now, I'm gonna take"],[6356,6498,"something away from you."],[6756,6927,"Put the gun down, Vivian."]],"54":[[120,321,"Put the gun down, Vivian."],[579,784,"You are not gonna stop me"],[784,925,"from avenging my father's death!"],[1067,1159,"Trust me."],[1514,1651,"There's a better way to do this."],[1872,2027,"Take her to the debt collectors."],[2068,2143,"What?"],[2181,2248,"No!"],[2273,2410,"No, not the debt collectors!"],[2410,2490,"No, do you know"],[2490,2619,"what they do to people like us?"],[2619,2786,"They'll peel off our skin!"],[2786,2840,"No!"],[2861,3007,"No, no, no..."],[3007,3105,"I don't think these men"],[3105,3219,"give second chances"],[3219,3378,"like we did, Catherine."],[3378,3586,"You know, this is more satisfying"],[3586,3745,"than just an easy bullet"],[3745,3805,"to the head."],[3849,4087,"Vivian, you have to stop them."],[4154,4216,"They are going to"],[4216,4354,"cut me into pieces."],[4354,4528,"We offered you a safe haven"],[4528,4675,"and one of our cozy little cells,"],[4675,4817,"but you just had to run."],[5009,5134,"Vivian, please!"],[5171,5271,"I'm your mother."],[5296,5422,"Stepmother."],[5488,5659,"Rot in hell, bitch."],[5709,5880,"Vivian, no!"],[5918,6076,"No, you can't!"],[6076,6122,"No!"],[6122,6373,"Oh, no, no, no!"],[6439,6606,"No!"]],"55":[[675,788,"I did it, dad."],[925,1076,"I avenge your death."],[2394,2727,"Your stone-cold attitude is fading,"],[2806,2902,"Mr. Mafia King."],[2961,3053,"Well,"],[3053,3203,"finding the love of your life"],[3265,3411,"was right in front of you the whole time,"],[3411,3586,"tends to change man."],[3821,3940,"I never expected you"],[3940,4108,"to say anything like that."],[4204,4350,"Well, then you won't"],[4350,4562,"possibly expect this."],[5217,5572,"Vivian Green, will you marry me?"],[5684,5768,"Yes."],[5868,5947,"Yes."]]}