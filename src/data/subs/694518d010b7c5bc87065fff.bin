{"1":[[20,216,"Gambling Legend Henry Smith just bet"],[225,636,"his entire fortune, 4.6 billion dollars,"],[636,717,"along with the"],[717,909,"Legendary God of Gambling Ring!"],[1976,2147,"Oh my god! That's a royal flush!"],[2147,2285,"Henry just won again!"],[2285,2356,"Oh man!"],[2356,2452,"How did he play?"],[2452,2623,"- I have no idea. - Damn!"],[2790,3001,"Again, you can't keep winning."],[4800,4960,"Another divine move!"],[5259,5365,"Fuck you, Henry!"],[5388,5568,"There can only be one Gambling God."],[5689,5780,"Oh my god!"],[6040,6108,"Henry,"],[6108,6260,"this whole game was Lip's trap..."],[6260,6356,"to kill you!"],[11207,11516,"Boss, tomorrow at 10, it's a death bet."],[11536,11725,"Lip just sent Luca."],[11765,11882,"If we lose,"],[11882,11991,"we're dead!"]],"2":[[734,796,"Dad."],[1359,1564,"Boss! Sophia brought Tim!"],[1564,1776,"Tim's the reigning Gambling King"],[1776,2047,"of Chicago, three years running."],[2047,2181,"We're saved!"],[2502,2894,"Relax. As long as Lip doesn't show up,"],[2927,3061,"I've got this."],[3061,3263,"The man who beat Lip in the finals"],[3263,3365,"was years ago..."],[3365,3495,"No one knows what happened to him."],[3528,3657,"I wish we could find him."],[3687,3858,"You mean the Gambling God, Henry Smith?"],[3858,4083,"He was Sophia's only idol back then."],[4133,4233,"What a shame."],[4316,4454,"Oh, hi, my love!"],[4558,4704,"Oh my god! You're so hot!"],[4775,4913,"You're my blackjack!"],[4975,5096,"How about our Tim?"],[5138,5359,"He's also perfect for our Sophia."],[5392,5655,"After I win the death match tomorrow,"],[5689,5801,"we're getting married."],[6039,6076,"What?"],[6118,6260,"He'll only agree to help us"],[6260,6439,"if I would marry him."],[6806,6869,"Fuck!"],[7136,7365,"That's Gambling God Henry's ring!"],[7378,7582,"Vanished with him three years ago."],[7599,7703,"That's right."],[7721,7996,"With this ring, you can cash chips at any casino."],[7996,8083,"No limit!"],[8087,8199,"Not just that."],[8199,8470,"You get access to all the VIP rooms."],[8470,8575,"With that ring,"],[8575,8829,"I'll become a legend in the gambling world."],[8837,9013,"Boss said this is the guy."],[9071,9250,"Anyone who can beat me in roulette..."],[9300,9401,"gets the ring!"],[9446,9535,"Okay!"],[10677,10764,"Don't go!"],[10823,10935,"That gun's been tampered with."],[10935,11010,"You won't win."],[11013,11160,"Oh my, how does he know that?"],[11177,11340,"Who the hell is this idiot?"],[11340,11453,"Fire him tomorrow."],[11453,11578,"You're just a janitor."],[11578,11699,"What do you know?"],[11699,12016,"Tim's gambling skills are unmatched in Chicago."],[12016,12095,"He's got this."],[12107,12224,"Exactly!"],[12224,12374,"Tim plus the ring?"],[12374,12566,"A match made in heaven!"],[12566,12666,"Don't be fooled."],[12700,12928,"That ring? It's a fake!"]],"3":[[196,350,"Shut the hell up!"],[350,596,"Trash like you couldn't even touch"],[596,729,"a ring like that."],[734,955,"Carl, go clean the shit up."],[955,1098,"How the hell would you even"],[1098,1376,"recognize the Gambling God's ring?"],[1393,1522,"How would he know that?"],[1551,1793,"He spotted it after just one look."],[1822,1943,"Oh yeah."],[2039,2324,"Alright, this will be perfect."],[2431,2577,"I'll use him as a warm-up"],[2577,2781,"before the death match tomorrow."],[2802,2915,"You're on!"],[2957,3065,"Let's keep it fair."],[3136,3236,"One spin,"],[3361,3474,"one shot."],[3741,3841,"With Tim's skill,"],[3841,3958,"there should be no problem"],[3958,4137,"with him beating that drunk."],[4154,4233,"You'd better stop him."],[4233,4341,"That drunk's trouble."],[4346,4562,"First it's the gun, now it's the guy?"],[4567,4867,"Sounds like the only problem here is you."],[5776,5964,"See? Nothing happened."],[5964,6210,"What makes you think trash like you"],[6210,6331,"can question Tim?"],[6331,6493,"Enough, all of you."],[6523,6698,"Carl's just trying to help Tim."],[6740,6881,"The third shot will kill him."],[6894,7036,"That drunk, when he gets the gun,"],[7048,7232,"he's gonna lock the firing pin right on the bullet."],[7286,7407,"They say the Gambling God"],[7407,7540,"can see time slow down."],[7549,7657,"This kid too?"],[7674,7882,"Why are you trying to curse him?"],[7882,8087,"Tim knows exactly what he's doing."],[9330,9430,"Oh..."],[9488,9584,"Shit!"],[10210,10301,"This is it. Stop him!"],[10301,10407,"Don't let him pull the trigger!"],[10427,10610,"Shut up, Carl!"],[10627,10681,"Yeah,"],[10694,10794,"talking like that,"],[10806,10960,"you just want him to die."]],"4":[[1463,1647,"Luca Ciangretti."],[1797,1922,"He's the Chicago mafia boss."],[2022,2131,"He's also our opponent in"],[2131,2239,"tomorrow's death match."],[2289,2435,"A fake ring for the life"],[2435,2606,"of Chicago's gambling king?"],[2627,2819,"That dumbass actually thought he was a king."],[3119,3249,"Luca, you planned this."],[3261,3428,"The death match isn't until tomorrow."],[3470,3678,"Don Bazzini is not gonna let this slide."],[3720,3937,"He's dead and you're still putting on a show?"],[3970,4095,"Smash this place up!"],[4187,4346,"Consider it a renovation."],[4408,4501,"No!"],[5221,5367,"Sign it! You old bastard!"],[5397,5505,"Make my boss happy"],[5505,5643,"and maybe he'll let you live."],[5659,5714,"Lip?"],[5805,5885,"Him again?"],[6168,6335,"This is all Carl's fault!"],[6335,6468,"He knew that the gun was"],[6468,6598,"rigged and didn't stop it."],[6614,6735,"You're the one who should've"],[6735,6848,"taken that bullet."],[6890,7048,"You ungrateful rat!"],[7061,7194,"Sophia should've let you die"],[7194,7382,"on the street like a stray dog!"],[7799,7899,"This is it. Stop him!"],[7899,7970,"Don't let him pull the trigger!"],[8045,8184,"Who said we don't have a player?"],[8233,8329,"Tomorrow's death match is"],[8329,8451,"going to proceed as planned."],[8483,8679,"Chicago's Gambling King is dead."],[8725,8808,"You're gonna summon the"],[8808,8925,"Gambling God next?"],[9034,9070,"Dad!"],[9672,9822,"Who do we have left to turn to?"]],"5":[[241,462,"Boss, Tim's dead!"],[462,625,"There's no one!"],[625,721,"We're not even gonna make it"],[721,834,"through tomorrow."],[867,955,"Don't worry!"],[967,1084,"Someone's gonna help us."],[1134,1301,"Frank, you've lost your damn mind!"],[1334,1547,"Luca, life or death,"],[1547,1701,"you'll find out tomorrow."],[1755,1951,"Fine. Keep bluffing, old man."],[1951,2085,"You're all going to hell."],[2160,2206,"Let's go."],[2456,2498,"Carl."],[2673,2723,"Come with me."],[3399,3553,"You know, I don't know where you came from,"],[3553,3653,"and I don't care."],[3712,3824,"But tomorrow,"],[3824,3908,"I need your help."],[3958,4141,"And I know you're not an ordinary guy."],[4148,4258,"You're special."],[5484,5551,"Jesus."],[5676,5789,"Ever since Lip Orville"],[5800,5918,"became the new Gambling God,"],[5947,6101,"he joined forces with Luca"],[6101,6231,"to swallow up all the"],[6231,6423,"underground casinos like ours."],[6631,6756,"They're the ones who took my hand."],[7211,7311,"I finally got Don Bazzini"],[7311,7490,"to step in and mediate but..."],[7561,7665,"If we lose again,"],[7665,7811,"those bastards are not only gonna"],[7811,7899,"abuse Sophia..."],[7916,8049,"they'll really kill us all."],[8454,8537,"Please."],[8587,8746,"Please, you have to help us."],[9476,9522,"Lip,"],[9542,9667,"I've been enduring the pain for years."],[9667,9738,"This time,"],[9747,9889,"I'm making you pay in blood."],[9901,10018,"David, I'll revenge you."],[10193,10281,"I'll do it."]],"6":[[304,375,"I'll do it."],[458,533,"Thank you."],[992,1055,"Carl!"],[1332,1415,"Hey!"],[2861,3082,"It's like suddenly he's a different person..."],[4925,4988,"Don Bazzini."],[5251,5355,"Don Bazzini."],[5747,5830,"Let's begin."],[6026,6172,"Please, Don Bazzini. Uh…"],[6202,6314,"Our player isn't here yet."],[6368,6523,"Stop fucking stalling, Frank."],[6539,6631,"He has no one,"],[6652,6715,"Don Bazzini."],[6752,6969,"Please, just be patient a moment longer."],[6969,7040,"He'll be here."],[7044,7148,"Tim's dead."],[7165,7328,"No one's coming to save you now."],[7741,7899,"Stop wasting time."],[7924,8062,"Just kneel down and surrender to"],[8062,8124,"Mr. Bazzini."],[8170,8320,"Over my dead body!"],[8375,8600,"Oh, we've got a feisty one, do we?"],[8608,8700,"I like that."],[8700,8858,"Maybe if you blow me,"],[8879,9063,"I'll let your friends live a little longer."],[9150,9401,"I would rather die than let you touch me."],[9755,9809,"Time's up!"],[9909,9972,"Luca wins."],[10126,10222,"It's over."],[10247,10314,"We're done for."],[10397,10589,"He'll be here. He promised me."],[10643,10706,"Take her."],[10965,11090,"Sure my boss wouldn't mind"],[11090,11271,"if I took a little test drive?"],[11271,11338,"Off!"],[11373,11448,"No!"],[11486,11636,"Get off of me!"],[11690,11774,"Let her go."],[12625,12721,"This is him!"],[12867,12983,"Carl?!"]],"7":[[0,79,"Boss!"],[150,429,"The guy you found is Carl?"],[433,567,"This loser can't even sweep"],[567,654,"the floor right."],[654,850,"There's no way he knows how to gamble!"],[850,913,"Shut up!"],[1109,1251,"We have to believe in Carl."],[1405,1568,"You brought a janitor?"],[1622,1768,"You think this is a fucking joke?"],[1801,1935,"My apologies, Don Bazzini."],[1935,2056,"But we're ready to begin now."],[2056,2160,"He's a janitor!"],[2177,2285,"That's your gambler?"],[2314,2485,"Yeah. That's him."],[2656,2731,"Let's play!"],[3382,3516,"Best two out of three."],[3516,3611,"First round,"],[3670,3749,"Sic Bo."],[3870,4008,"Both sides roll three dice."],[4037,4158,"Highest total wins, right?"],[4212,4258,"Yep."],[4312,4429,"It's a niche format."],[4441,4608,"Not sure if Carl even knows it."],[4646,4767,"Total dice?"],[4838,4959,"That's a coward's game."],[4975,5092,"We'll play with six dice."],[5113,5176,"Lowest"],[5201,5392,"total wins."],[5743,6097,"From Las Vegas!"],[6126,6331,"The Gambling King..."],[6360,6435,"Hank!"],[6831,6952,"Who the hell are you?"],[7002,7198,"Janitor. Carl."],[7219,7432,"Suicidal idiot!"],[9305,9413,"That technique."],[9467,9705,"It's no wonder he's won three"],[9726,9964,"Vegas Golden Dice Awards."],[10001,10247,"Let's see if this trash can beat that."],[11123,11378,"It's the legendary Tower of Ones!"],[11699,11903,"And this dumbass is still fiddling"],[11903,12011,"with his dice!"],[12929,13113,"We're dead. Totally dead."],[13113,13275,"He doesn't know what he's doing."],[13292,13446,"We're all going to die."],[13450,13580,"Did I misjudge him?"],[13621,13726,"Reveal yours."],[14547,14660,"Where are the dice?"],[14668,14768,"You trying to cheat in front"],[14768,14877,"of all these people?"],[14877,14994,"Even if you're gonna lose,"],[14994,15102,"don't cheat."],[15261,15386,"You trying to die today?"],[15469,15594,"This round goes to Luca."],[15594,15648,"Wait."],[15765,15899,"Keep running your mouth!"],[16866,16991,"Zero points!"],[17108,17225,"A divine move!"],[17467,17646,"This is the Gambling God's technique."],[17671,17809,"Is he the Gambling God?"]],"8":[[0,241,"Could he really be the Gambling God?"],[291,417,"It's the Divine Dust!"],[425,604,"A move only Henry Smith can pull off!"],[621,721,"Henry Smith?"],[721,792,"Bullshit!"],[800,850,"Yeah!"],[850,1017,"Henry Smith is dead!"],[1021,1063,"Dead!"],[1063,1109,"Hey!"],[1572,1739,"You worthless piece of shit!"],[1747,1893,"I spend a fortune for you and"],[1893,2068,"you can't even beat a janitor!"],[2068,2252,"Could he really be the Gambling God?"],[2648,2773,"These are defective dice."],[2815,2961,"This's not a divine move!"],[2961,3103,"This is a scam!"],[3891,4029,"You bastard!"],[4041,4179,"You try to trick me?"],[4179,4475,"And you, impersonating Henry?"],[4483,4696,"Luca, a bet's a bet."],[4696,4838,"We won fair and square."],[4929,5130,"And you call yourself a Gambling King?"],[5130,5301,"Then you can't beat a fucking janitor?"],[5301,5384,"Die!"],[5384,5543,"Luca, please!"],[5543,5768,"Luca, it's him. It's not me."],[5855,5964,"Get out of here."],[6310,6489,"Luca, this round goes to Frank."],[6548,6806,"Don Bazzini, this win is a sham."],[6831,6965,"You had one point."],[6973,7178,"We had zero. How is that a sham?"]],"9":[[0,87,"Don Bazzini,"],[87,254,"Frank is an old sly fox."],[254,450,"He used fake dice to scam me!"],[450,633,"Those dice were legit."],[1359,1493,"Shattered on impact,"],[1493,1630,"and you call those legit dice?"],[1839,1943,"Don Bazzini,"],[1943,2018,"you're the most"],[2018,2273,"respected godfather in the business."],[2302,2485,"You can't let this fraud slide!"],[2519,2640,"I can't believe Frank tried to"],[2640,2816,"con the mafia with fake dice."],[2823,2936,"And that janitor"],[2936,3069,"thinks he's Henry Smith now?"],[3082,3178,"What a joke!"],[3182,3240,"Silence!"],[3303,3432,"This round goes to Frank."],[3561,3720,"You win this round, Frank."],[3741,4003,"But I swear I will bury each"],[4003,4175,"and every one of you."],[4208,4350,"This is all your fault!"],[4350,4454,"Acting like a hero"],[4454,4688,"when you're just a worthless janitor!"],[4725,4817,"We're finished."],[4817,4992,"There's no escaping now."],[5030,5125,"Next round."],[5292,5397,"Blackjack."]],"10":[[25,50,"Carl?"],[129,379,"Boss! You still trust this loser?"],[387,613,"He only won last round by luck."],[633,754,"He's not Henry Smith!"],[779,880,"You're seriously putting"],[880,1071,"our lives in his hands again?"],[1322,1509,"That technique has to be real."],[1534,1764,"Even if he's not Henry, his skills are top-tier."],[1814,2052,"Boss, he's just a janitor with a broom."],[2072,2127,"Enough!"],[2289,2335,"Carl,"],[2410,2498,"I'm counting on you."],[2802,3015,"If you're gonna let that loser"],[3015,3165,"decide our fate,"],[3165,3399,"I'd rather die right now!"],[3432,3474,"You!"],[3503,3603,"Take it away from her!"],[4262,4354,"You can't even convince"],[4354,4546,"your own people to trust him."],[4546,4842,"And you're still gonna bet your life on this trash?"],[5063,5134,"I'll do it."]],"11":[[333,408,"Sweetheart?"],[429,513,"Finally!"],[517,608,"Sophia should have stepped in"],[608,692,"from the start!"],[692,817,"She grew up in casinos."],[829,980,"She knows every card game,"],[980,1080,"inside and out."],[1109,1263,"Especially Blackjack."],[1297,1413,"She's never lost."],[1480,1609,"Boss, she's got this."],[1651,1764,"You forgot she used to be"],[1764,1906,"called the Gambling Goddess?"],[1947,2081,"Dad, it's fine."],[2339,2419,"Wow."],[2448,2544,"Oh my god."],[2573,2919,"Such a touching pair of father, daughter."],[3019,3140,"I guess I have no other choice"],[3140,3319,"than to send you both to hell."],[3382,3436,"Mike!"],[4195,4295,"Let me introduce you."],[4312,4458,"This is Mike Orville,"],[4458,4667,"little brother of the current"],[4667,4963,"Gambling God, Mr. Lip, himself."],[4963,5038,"Mike?"],[5084,5188,"I know him."],[5201,5388,"The guy in black who's always with Lip?"],[5405,5492,"That's him!"],[5509,5668,"He was trained by Lip personally."],[5668,5809,"No one knows how good he is."],[5885,5943,"Lip."],[5993,6114,"Stop wasting time."],[6222,6306,"Begin."],[6418,6485,"Be careful."],[6602,6673,"He's dangerous."],[6685,6748,"Dangerous?"],[6765,6844,"Please!"],[6856,6973,"Just sit back and watch how"],[6973,7157,"Sophia wipes the floor with him."],[7357,7432,"This man!"],[7490,7549,"Wait."],[7716,7845,"You can't beat him."]],"12":[[12,162,"Boss, relax."],[162,300,"When Sophia's playing,"],[316,479,"we'll win this fair and square."],[529,638,"You've got this, girl!"],[654,884,"Blackjack, get as close as you can to 21 as"],[884,1159,"possible without going over, or you're bust."],[4909,4984,"She is done."],[4984,5176,"This is not a good start at all."],[5271,5476,"Women belong serving drinks,"],[5476,5622,"not playing cards."],[6339,6423,"Perfect!"],[6456,6664,"Just one more face card and she hits 21."],[6685,6831,"Unlike Carl,"],[6831,6911,"who dragged us"],[6911,7073,"into this mess in the first place."],[7086,7173,"Another?"],[7962,8078,"That's 19!"],[8558,8641,"That's enough!"],[8675,8921,"19 gives us a big chance to win!"],[10285,10377,"Take another."]],"13":[[930,996,"No."],[1172,1267,"It's too late."],[1267,1393,"She already said it."],[1801,1893,"She busted!"],[1926,2010,"She lost!"],[2168,2456,"Her total exceeded 21. You lose."],[2873,2940,"Hold on."],[3015,3157,"He hasn't revealed his hand."],[3169,3299,"What do you care, janitor?"],[3303,3440,"Doesn't matter what I have."],[3440,3628,"She busted. I win."],[3657,3745,"Win or lose,"],[3895,4045,"he has to show his cards."],[4320,4471,"How could I get a same card?"],[4508,4704,"Revealing your hand is casino rules."],[4704,4871,"And you have a jack of spades, don't you?"],[4888,5000,"Are you looking to die?"],[5184,5296,"Go to hell!"],[5789,5880,"Sophia!"]],"14":[[246,321,"Sophia!"],[1184,1317,"She was going to win."],[1317,1493,"And you told her to hit!"],[1543,1693,"Trying to get us killed?"],[1705,1901,"If you hadn't opened your damn mouth,"],[1901,2022,"she wouldn't have busted"],[2022,2147,"and she wouldn't be bleeding"],[2147,2293,"all over the place right now."],[3411,3482,"Go to hell!"],[4200,4346,"What are you standing around for?"],[4346,4475,"Get her to a hospital!"],[4496,4640,"She's already half dead"],[4640,4771,"because she knows she'll lose."],[4842,4929,"What's the point of taking"],[4929,5013,"her to a hospital?"],[5042,5130,"You son of a-"],[5593,5755,"Even after we took you in,"],[5843,5997,"you're nothing but bad luck!"],[6043,6147,"You're a curse!"],[6181,6314,"Just get the hell out of here!"],[6331,6402,"Enough!"],[6477,6577,"Leave him alone!"],[6594,6719,"Boss, she's hurt!"],[6723,6844,"And you're still defending"],[6844,6969,"that useless nobody?"],[6990,7094,"Enough."],[7232,7349,"Round two..."],[7453,7524,"Luca wins."],[8358,8462,"You got a death wish?"]],"15":[[387,492,"You got a death wish?"],[984,1076,"Let him go."],[1634,1818,"Already turning on yourselves already?"],[1826,2122,"Garbage like you can't beat Mike."],[2177,2335,"How about you sign it now?"],[2656,2748,"I'll make it quick."],[2752,2882,"I'll finish you off swiftly."],[2894,3073,"There's no need to waste Don's time"],[3073,3199,"with a final round."],[3224,3345,"Why not just kill them now?"],[3374,3474,"Us mafia"],[3620,3724,"have rules."],[3878,3999,"Still dreaming, old man?"],[4083,4166,"Don Bazzini"],[4166,4479,"would never ever back a loser like you."],[4562,4750,"You've got no one left"],[4750,4842,"to face Luca."],[4888,4959,"Take him!"],[5121,5240,"No, let me go!"],[5240,5488,"Let me go!"],[5488,5572,"Don Bazzini!"],[5618,5701,"It's one-one."],[5830,5922,"The match isn't over."],[5922,6001,"He's right."],[6001,6089,"Let go of me."],[6185,6331,"We still have one more round."]],"16":[[29,166,"We still have one more round."],[266,346,"Please, Don Bazzini."],[563,663,"Don Bazzini!"],[792,905,"Very well."],[1105,1217,"We'll have the final round."],[1217,1343,"Then I get to pick the game!"],[1463,1576,"This time,"],[1576,1735,"we do it Mafia-style:"],[1830,2164,"Five Finger Fillet."],[2231,2298,"No!"],[2331,2573,"No, no, no, no, not that."],[2656,2794,"If you bust, that's game."],[2827,2911,"I can't believe Frank's side"],[2911,3048,"is still whining after losing."],[3716,3749,"Oh!"],[3908,3949,"Oh!"],[5634,5689,"Fine."],[5876,5951,"I'll do it."]],"17":[[58,145,"I'll do it."],[371,654,"You only have one hand, old man."],[654,779,"What are you gonna be betting with?"],[963,1255,"Five Finger Fillet requires speed and coordination"],[1272,1393,"and two hands."],[1397,1488,"You?"],[1501,1597,"You don't have shit."],[1647,1847,"Let's not waste Don Bazzini's time."],[1872,1968,"Just call it now."],[2348,2419,"I'll do it."],[2456,2540,"Sophia!"],[2690,2769,"Sophia..."],[2823,2902,"You can't go again."],[3019,3111,"Shut it!"],[3119,3236,"Nobody asked you!"],[3253,3395,"You ungrateful mutt!"],[3403,3524,"She saved your life"],[3524,3687,"and this is how you repay her?!"],[4129,4208,"Could he really be"],[4208,4316,"the Gambling God?"],[4358,4425,"Fine."],[4637,4704,"Carl'll do it."],[4854,4917,"Dad?"],[4975,5096,"You better be sure."],[5167,5317,"Nobody gets lucky twice..."],[5434,5505,"Bring in Jimmy."],[5672,5747,"Boss…"],[5784,5834,"Carl, please!"],[5834,5905,"Enough!"],[5989,6101,"Carl's our only shot."]],"18":[[150,237,"Jimmy's here."],[809,984,"Why does he look so familiar?"],[984,1151,"I know, he won the Tri-State Gambling"],[1151,1284,"Championship last week."],[1288,1383,"He's the top contender to be the"],[1383,1493,"next Gambling God,"],[1493,1580,"Jimmy McConnell."],[1589,1655,"Luca,"],[1672,1797,"is that the champion,"],[1797,1885,"Jimmy McConnell?"],[2014,2072,"That's right."],[2160,2306,"Took a lot to get him here, too."],[2323,2414,"And get this,"],[2419,2565,"he's Henry's apprentice."],[2631,2711,"The Gambling God"],[2711,2894,"passed down every secret"],[2894,3002,"before he died."],[3065,3224,"Henry's apprentice?!"],[3274,3482,"Since when do I have an apprentice?"],[3549,3620,"We're finished."],[3649,3766,"There is no way this"],[3766,3949,"janitor is gonna be able to"],[3958,4195,"beat the Gambling God's disciple."],[4204,4450,"I missed my chance years ago"],[4458,4679,"to see Henry Smith's amazing technique."],[4704,4800,"Now,"],[4817,4929,"I get to see it."],[4954,5042,"Enough talk."],[5167,5217,"Let's go."],[7040,7127,"That's it!"],[7132,7273,"The \"Phantom Sword Dance\"."],[7307,7436,"Henry's signature move!"],[7499,7670,"He really is Henry's apprentice!"]],"19":[[1343,1484,"Still grinding your knife, janitor?"],[1509,1634,"Just give it a rest."],[1655,1755,"There's no suspense."],[1822,1989,"Unless Henry himself walks in,"],[2001,2097,"no one's beating Jimmy's"],[2097,2206,"Phantom Sword Dance."],[2260,2339,"Don Bazzini,"],[2339,2573,"let's just call it. It's over."],[2677,2736,"This round"],[2744,2819,"goes to Luca."],[3023,3073,"Wait!"],[3140,3299,"That was a fake Phantom Sword Dance."],[3311,3490,"You dare insult the Gambling God's"],[3490,3611,"signature move?"],[6819,6919,"Who... who are you?"],[6969,7140,"That's the real Phantom Sword Dance!"],[7173,7257,"Exactly!"],[7294,7401,"That's the light of Jesus"],[7401,7528,"that formed from the blade,"],[7536,7670,"shielding the gambler's fingers!"],[7699,7770,"That silhouette…"],[8053,8095,"That aura..."],[8120,8162,"It's him!"],[8216,8262,"Henry."],[8287,8433,"He's the Gambling God!"]],"20":[[291,563,"Oh my god!"],[638,717,"No."],[763,955,"No, he can't be Henry. Henry's dead."],[1017,1163,"He's just a janitor!"],[1201,1334,"That's the Gambling God?"],[1368,1480,"Doesn't look the part…"],[1547,1672,"No mistake."],[1672,1847,"There's no one else in the world"],[1847,1993,"that could perform that move."],[2010,2189,"To witness the Gambling God's"],[2189,2369,"ultimate technique in my lifetime…"],[2427,2640,"A true Gambling God. This round"],[2798,3019,"goes to Frank!"],[3048,3123,"Yes!"],[3157,3336,"No..."],[3420,3682,"If I fail, the family and Lip,"],[3712,3816,"they'll kill me."],[3903,3991,"He's a fake!"],[4066,4179,"He has to be!"],[4191,4295,"He's just a janitor!"],[4329,4546,"He can't be Henry the Gambling God?!"],[4708,4758,"Luca!"],[4954,5063,"How dare you!?"],[5063,5209,"Let that filth"],[5209,5330,"come out of your mouth!"],[5330,5638,"I can execute you right here!"]],"21":[[191,358,"There's no way that he's..."],[358,542,"really the Gambling God…"],[583,759,"He just used"],[759,1030,"the Phantom Sword Dance!"],[1042,1284,"It was insane!"],[3820,3941,"Leave!"],[3991,4133,"And don't come back."],[4154,4295,"You really gotta let him walk?"],[4329,4429,"No need."],[4558,4829,"The Ciangretti family will not let this"],[4829,5167,"slide whether he lives or whether he dies."],[5305,5472,"They will rip him"],[5472,5701,"to shreds."],[5989,6110,"Mike! Help me up."],[6331,6452,"Gambling God,"],[6464,6648,"I've admired you from before."],[6673,6794,"Please let me be your apprentice."],[6794,6894,"I'll do anything, I..."],[6894,7048,"I'll be your… Sir, wherever you need it."],[7048,7132,"I swear."],[7140,7207,"You!"],[7661,7820,"Shameless fuck!"],[7820,8020,"You pretended to be his disciple,"],[8024,8220,"and now you're begging to be"],[8220,8354,"accepted for real?"],[8362,8433,"You fraud."],[8433,8550,"Get out of my sight."],[8621,8750,"You saw what I can do."],[8750,8896,"I've got talent, please!"],[8896,9029,"Is he really the Gambling God?"],[9029,9167,"He's not even reacting..."],[9180,9263,"Carl…"],[9292,9363,"Are you…"],[9380,9484,"really Henry?"],[9567,9680,"The Gambling God?"],[9801,9955,"No, I'm not the Gambling God."]],"22":[[70,191,"That can't be."],[200,312,"Only Henry could perform"],[312,471,"a Phantom Sword Dance like that."],[521,600,"Exactly."],[709,829,"You're Henry Smith."],[846,1088,"You don't need to hide your identity anymore,"],[1088,1234,"now that Luca's gone."],[1472,1605,"I'm so sorry."],[1655,1822,"All of these years, we've had you"],[1885,2001,"cleaning floors."],[2068,2152,"Carl,"],[2177,2281,"I know we probably wronged"],[2281,2381,"you at some point,"],[2389,2519,"but whatever it was,"],[2535,2635,"I hope you'll forgive us."],[2686,3029,"You're still not revealing your identity."],[3036,3257,"Is there something you're worried about?"],[3278,3411,"No."],[3500,3623,"No, it's nothing like that."],[3666,3820,"You didn't just save our lives."],[3820,4020,"Sophia got to see her idol again."],[4191,4305,"Only a beauty like Sophia"],[4305,4471,"could be worthy of someone like you!"],[4500,4654,"Why are you still here?"],[4654,4863,"Get the fuck out, dude."],[4871,4954,"Alright, alright."],[4963,5071,"Get out."],[5075,5171,"I'll never give up!"],[5509,5593,"Don Bazzini."],[5593,5701,"A message from the leaders"],[5701,5809,"of the Four Families."],[6131,6339,"Miss it, and face the consequences."],[6339,6460,"Lip Orville."]],"23":[[120,208,"Don Bazzini?"],[241,304,"What is it?"],[759,905,"Lip has gone too far this time."],[963,1071,"Ever since he's been calling"],[1071,1197,"himself the Gambling God,"],[1247,1397,"he's just been out of control."],[1509,1609,"Ridiculous."],[1680,1739,"No."],[1822,2072,"He's not the true Gambling God yet."],[2097,2285,"As far as I know, he doesn't have"],[2302,2439,"the Gambling God's ring."],[2502,2660,"Carl, do you still have the ring?"],[2719,2823,"Show us!"],[2886,2977,"We want to see it!"],[3015,3103,"I don't have it on me."],[3549,3691,"It's from the Ciangretti family."],[3691,3807,"Luca's family?"],[3807,3941,"What do they want now?"],[4074,4258,"Hello, Mr. Ciangretti."],[4279,4404,"Don Bazzini."],[4404,4729,"I trust you've received our messages."],[4733,4921,"We expect to see you at the tournament."],[4946,5034,"And if I don't go?"],[5038,5221,"Then every piece"],[5226,5467,"of your family's Las Vegas Holdings"],[5467,5651,"will become ours."],[5851,6039,"The International Gambling Tournament…"],[6051,6222,"So, it begins again."],[6798,6990,"Congratulations to Henry Smith..."],[7011,7127,"the new Gambling God."]],"24":[[62,100,"Don,"],[108,241,"the four families want to use Lip"],[241,333,"to divide our empire."],[333,425,"What should we do?"],[688,800,"Gambling God…"],[1021,1184,"Would you help my family?"],[1238,1330,"Right now, only you"],[1330,1534,"can beat Lip in Las Vegas."],[1647,1843,"Yeah, I'll do it."],[1872,1922,"But I need you to"],[1922,2127,"keep my identity secret for now."],[3370,3561,"What if it's dangerous? I mean..."],[3912,4074,"Do you really have to go?"],[4124,4266,"There's something I need to finish."],[4362,4500,"Then I'm coming with you!"],[4713,4804,"Good!"],[5071,5201,"With you by my side,"],[5201,5492,"we'll crush Lip and take Vegas!"],[6439,6539,"Over here."],[6886,6977,"Wow!"],[6986,7190,"He looks so handsome."],[7611,7661,"Let's go."]],"25":[[241,329,"Wow."],[442,650,"This is all part of the Bazzini empire?"],[650,846,"This is... stunning."],[1017,1138,"Welcome back to Las Vegas,"],[1188,1405,"Mr. Gambling God."],[1539,1593,"Dad,"],[1639,1751,"this is the guy you"],[1751,1872,"brought in to help us?"],[2018,2181,"Doesn't look like much to me."],[2581,2736,"Mind your manners."],[2823,2936,"Let me introduce you."],[3036,3119,"This is my son,"],[3182,3232,"George."],[3361,3499,"Nice fake watch."],[3636,3803,"Smells like thrift store cologne."],[3853,3920,"How rude."],[3949,4029,"You know we are your"],[4029,4183,"father's honored guests!"],[4216,4308,"Honored guests?"],[4341,4400,"Please."],[4412,4537,"I know what he is:"],[4558,4733,"a Chicago janitor."],[4767,4846,"How could you let"],[4846,5009,"a cleaner represent us?"],[5017,5130,"If he loses,"],[5130,5355,"the four families will take our business."],[5405,5689,"His identity is way more complicated"],[5689,5864,"than your little pea brain can pass..."],[5864,6001,"I don't care what you have to say."],[6001,6082,"We can not hand"],[6082,6235,"this over to some nobody."],[6260,6309,"That's enough."]],"26":[[25,91,"Shut it!"],[145,308,"You show a little respect."],[371,471,"If we're not welcome here,"],[538,642,"Don Bazzini, then..."],[688,829,"we can return to Chicago."],[1284,1388,"You little brat!"],[1447,1664,"You show some respect."],[2110,2260,"That was great!"],[2281,2452,"Oh my goodness."],[2464,2677,"Wasn't that a touching little scene?"],[2677,2806,"You know, I didn't think..."],[2806,2957,"Don Bazzini"],[2961,3207,"would slap his own son for a stranger."],[3269,3457,"Mr. Little Arthur,"],[3457,3595,"what are you doing here?"],[3666,3874,"I'm just here to inspect my soon-to-be"],[3874,4133,"property and to see for myself"],[4149,4346,"the help."],[4458,4512,"Who is he?"],[4546,4738,"He's Arthur Ciangretti."],[4750,4838,"He's the heir"],[4838,4996,"to the Chiangretti family."],[4996,5188,"He's been assigned to Las Vegas"],[5188,5309,"to take over duties."],[5309,5367,"He's a..."],[5376,5501,"pretty good gambler."],[5501,5580,"Luca's brother?"],[5597,5980,"He is Lip's loyal little lapdog."],[5985,6110,"Why don't you fuck off?"],[6135,6260,"You're not welcome here."],[6414,6498,"So,"],[6635,6856,"you're the so-called Gambling God"],[6856,7119,"that Luca keeps on babbling about,"],[7161,7261,"Henry?"]],"27":[[16,95,"Dad…"],[112,283,"you think he's Henry?"],[287,367,"The Gambling God"],[367,546,"who disappeared three years ago?"],[571,688,"Let me tell you the truth..."],[690,866,"Henry died three years ago."],[866,1101,"See? This guy's a fraud,"],[1151,1359,"riding the name of a dead man."],[1451,1676,"We have nothing to say to someone like you."],[1735,1876,"So why don't you get lost?"],[1906,2085,"Little beauty..."],[2114,2364,"you smell delicious."],[2394,2619,"I wonder what you're like in bed."],[2840,2915,"Arthur!"],[2969,3165,"One inch closer,"],[3211,3420,"and I'll consider this an act of war."],[3516,3737,"Relax, Don Bazzini."],[3770,3887,"I'm just a little bored."],[3887,3945,"I..."],[3958,4162,"I figured I would have some fun with your"],[4191,4375,"fraudulent Gambling God here."],[4562,4662,"It's not even time"],[4662,4788,"for the tournaments yet."],[4913,5080,"We're not playing your little games."],[5096,5234,"Don't fall for it, Carl."],[5284,5392,"Don't worry, sweetheart."],[5530,5680,"When I'm done with him,"],[5705,5784,"you're next."]],"28":[[20,100,"What's wrong?"],[125,196,"Scared?"],[208,425,"If so, go crawling back to Chicago."],[425,558,"You worthless crap."],[675,725,"Carl."],[771,1046,"Do not listen to this little piece of shit."],[1071,1126,"Dad!"],[1151,1338,"Why do you keep defending this loser?"],[1338,1493,"He must have tricked you in Chicago!"],[1493,1618,"Don't you see that?"],[1680,1851,"You're a disgrace to your father."],[1893,2035,"A rat in his own house."],[2127,2256,"They're not worth it."],[2318,2406,"Let's go."],[2635,2698,"Oh!"],[2719,2948,"Did I forget to mention? I think I did."],[2952,3161,"I am one of the official referees"],[3161,3319,"of the Vegas Tournament."],[3328,3507,"I have the authority"],[3536,3766,"to verify your qualifications."],[3878,4074,"Don't you take this too far!"],[4175,4254,"Dad,"],[4279,4400,"Arthur's right."],[4421,4596,"How can we trust this guy"],[4596,4779,"if we can't even test his skills?"],[5110,5213,"And if you lose…"],[5238,5317,"then what?"],[5355,5409,"Lose?"],[5434,5488,"Me?"],[5605,5705,"Not a chance."],[5714,5839,"If I lose,"],[5851,6010,"I'll resign as referee."],[6014,6247,"Hell, I'll get on my knees"],[6252,6581,"and lick your shoes."],[6656,6777,"You're not even worth that."],[6823,6948,"Well, then let's play"],[7165,7244,"the game."]],"29":[[158,304,"You know, word is,"],[304,496,"you're some type of dice master."],[508,692,"Yeah, even took down King Hank."],[713,859,"But I heard that your"],[875,1105,"methods were less than honorable."],[1714,1851,"I have one condition."],[1856,1960,"You lose,"],[2001,2139,"Lip comes to me."],[2164,2252,"In person."],[2314,2369,"Deal!"],[2394,2523,"But only if you beat me."],[2552,2790,"You cheap little cheat."],[2873,2936,"Carl."],[2952,3065,"No more talk."],[3082,3219,"Five dice."],[3303,3436,"Highest total wins."],[5150,5251,"One, two, three..."],[5259,5338,"30 points?"],[5376,5588,"That's the max! It's already over!"],[5755,5889,"I heard you got"],[5893,6035,"a zero last time,"],[6035,6339,"but getting over 30 is just simply impossible."]],"30":[[312,513,"Oh my god, it's over."],[521,588,"30 points?"],[588,834,"Not even the Gambling God could top that."],[1100,1292,"Now give it up, loser."],[1292,1455,"I don't have time for your drama."],[1455,1551,"What are you even doing?"],[1551,1764,"Just roll already, fraud!"],[2761,2819,"Enough!"],[2886,3065,"Open the damn cup."],[3065,3219,"You son of a bitch."],[3712,3824,"What now, huh?"],[3849,4058,"Gonna try that zero-point trick again?"],[4074,4175,"Nice try."],[4216,4437,"This time we're playing for highest score."],[5372,5505,"30 points again?"],[5518,5572,"No."],[5697,5739,"Look."],[5830,5997,"One of them is a 7."],[6322,6398,"That's true."],[6510,6606,"It's a 7."],[6777,7015,"Did he really roll 31 points?"]],"31":[[0,104,"What the-"],[104,200,"Wait,"],[204,346,"could he really be the Gambling God,"],[346,404,"Henry?"],[442,525,"Arthur,"],[538,604,"you lost."],[663,746,"Honor your word."],[884,971,"Step down."],[1021,1084,"Yeah."],[1142,1251,"Get on your knees"],[1251,1438,"and kiss Carl's shoes."],[1447,1595,"Who the hell are you really, huh?"],[1609,1776,"Who the hell do you think you are?"],[1780,1885,"Get the hell out of here,"],[1885,2031,"you Ciangretti trash!"],[2035,2114,"Tell Lip..."],[2127,2218,"I'm coming for him."],[2256,2339,"He's gonna pay."],[2544,2660,"I'm leaving."],[2723,2786,"Are you really just gonna"],[2786,2904,"let him walk away like that?"],[2923,3073,"The show hasn't even begun."],[3524,3603,"Forgive me,"],[3616,3787,"our great Gambling God."],[3787,3949,"I was blind and ignorant."],[4099,4220,"Is it hurt for you,"],[4220,4329,"being back here?"],[4500,4575,"That watch must be"],[4575,4696,"pretty important to you."],[4950,5046,"How'd you know?"],[5110,5260,"Well, the hands don't even move"],[5260,5497,"and you're still wearing it."],[5597,5714,"You're gonna tell me you're not."],[5793,5847,"Boss."],[5847,5889,"That's..."],[6010,6051,"That's..."],[6177,6239,"That's them."],[6310,6364,"Get him!"],[6402,6527,"When he's gone,"],[6527,6685,"the throne is mine."]],"32":[[387,425,"Who are you?"],[512,558,"What do you want?"],[641,675,"Enough talk."],[875,941,"Get them."],[1058,1094,"Run!"],[1136,1197,"Now!"],[1866,1920,"Go!"],[1937,2012,"Okay, I'll get help!"],[2845,3075,"Long time no see, Henry."],[3258,3320,"Shit!"],[3841,3883,"Ah!"],[3970,4070,"Crush his hands."],[4158,4225,"Take his eyes."],[4333,4450,"I want him alive."],[4558,4646,"Broken."],[5237,5266,"Ah!"],[5300,5345,"Ha ha!"],[5462,5616,"Ha ha ha ha ha!"],[6175,6304,"The World Gambling League..."],[6470,6662,"the World Gambling Throne... is mine."],[6720,6809,"All mine!"],[6870,7108,"Ha ha ha ha ha ha ha ha ha!"]],"33":[[0,142,"Show yourself! Who the hell"],[142,304,"dares cause trouble on my turf?"],[354,495,"But where's Carl? He was just here!"],[654,704,"Find him!"],[833,916,"Now!"],[2212,2479,"Whoa there. Easy."],[2604,2679,"You alright?"],[2708,3004,"Been wandering around for days, or how?"],[3125,3190,"Hungry?"],[3237,3312,"Here."],[3612,3691,"Hey, hey, hey."],[3762,3845,"No, no, no."],[3845,3925,"Come on, come on."],[3962,4066,"Let's get you cleaned up."]],"34":[[37,245,"Make yourself comfortable, alright?"],[291,404,"Alright, easy now."],[766,925,"Are you alright?"],[1100,1437,"Name's Jim. I run this little joint."],[1637,1725,"You hungry?"],[2183,2270,"Easy, easy."],[2370,2550,"Easy now, easy now. Don't choke!"],[2950,2995,"Carl."],[3025,3150,"Carl? Your name's Carl?"],[3508,3683,"Hey, don't just stare."],[3725,3820,"Get over here and help me."],[3820,3879,"Dad,"],[3879,3970,"come on."],[4495,4595,"Another bum?"],[4762,4908,"Really?"],[4908,5133,"We haven't had a paying customer in days."],[5237,5333,"Filthy..."],[5483,5645,"reeks..."],[6020,6125,"His eyes are wrecked."]],"35":[[91,145,"You know, you're right."],[145,235,"I didn't even notice."],[362,487,"Alright, let's get him cleaned up,"],[487,652,"so his wounds don't become infected."],[666,816,"Dad, our casino's"],[816,1009,"on the verge of shutting down."],[1020,1098,"We don't have the money"],[1098,1287,"to patch up some random guy."],[1383,1487,"Relax."],[1487,1566,"George,"],[1566,1695,"who owns the Atlantic Casino,"],[1695,1795,"is going to invest in us."],[1829,1945,"Things are about to turn around."],[1970,2133,"Wait, seriously?"],[2266,2383,"That's amazing."],[2404,2500,"Yes, it is."],[2866,3154,"Alright, come with me."],[3183,3308,"Let's get you cleaned up."],[3404,3462,"Easy."],[4016,4185,"Gambling legend, Henry Smith,"],[4185,4350,"missing for three years now,"],[4350,4570,"has vanished en route"],[4570,4729,"to the World Gambling Championship."],[4741,4865,"Anyone with information is"],[4865,5013,"urged to please come forward."],[5016,5095,"Great."],[5191,5325,"My idol's missing again."],[5341,5462,"Hope nothing bad happened."],[5654,5729,"I quit."],[5729,5825,"Hawthorne, what's wrong?"],[5825,5920,"I'm entering the World"],[5920,6002,"Gambling Championship."],[6137,6233,"I want to be like him."],[6310,6649,"Look, you're just still a junior dealer."],[6675,6883,"That championship isn't for people like us."],[6941,7241,"Besides, George from the Atlantic Casino is"],[7241,7400,"coming over soon to inspect us."],[7400,7572,"So, just wait till after his visit,"],[7572,7687,"then decide, alright?"],[7687,7908,"That investment's mine, lard ass!"]],"36":[[237,341,"Disgusting."],[362,487,"You two?"],[525,633,"Come on, dubs."],[637,862,"Ain't a gambling genius like Hawthorne just"],[862,1082,"gonna waste away his potential in a pitiful"],[1082,1208,"little joint like yours?"],[1329,1566,"Now that with me, better make it count."],[1570,1748,"I won't let you down, Mr. Ross."],[1995,2195,"You traitor!"],[2483,2820,"Hawthorne? You two-faced snake."],[2820,2941,"We helped you to get to"],[2941,3050,"where you are right now."],[3050,3141,"I got where I am because"],[3141,3341,"of my talent, not your pity."],[3429,3541,"Please, old man."],[3595,3808,"Don't tell me this is little stray"],[3808,4004,"that you brought in this time. What is he?"],[4058,4341,"Your blind bum? You gotta be kidding me!"],[4341,4519,"He is always playing savior."],[4519,4620,"Meanwhile, the rest of us are just"],[4620,4833,"starving off his charity handouts."],[4841,5018,"Hawthorne, I've treated you like my own son."],[5037,5170,"Please, help us out—"],[5170,5333,"just one last time."],[5470,5541,"No."],[5633,5762,"It's time to give it up, Jimbo."],[5820,5937,"Hawthorne's mine now."],[5937,6045,"That Atlantic investment?"],[6087,6166,"It's going to my casino."],[6241,6312,"Not this dump."],[6404,6530,"Who in their right mind"],[6530,6637,"is gonna pour good money..."],[6683,6992,"You two snakes."],[7025,7171,"Get the hell out of our place!"],[7195,7250,"Now!"],[7250,7550,"Whoa! Whoa! Whoa!"],[7550,7721,"Why don't you come with me instead, Fiona?"],[7721,7842,"Leave your old man to rot"],[7842,8087,"with his little dying dream."]],"37":[[279,345,"Dad!"],[354,475,"You little bitch!"],[475,597,"Here I am offering you a favor"],[597,725,"and you raise your hand to me?"],[754,883,"Hey, back off!"],[1237,1300,"Jim!"],[1433,1506,"Where's this gambling"],[1506,1625,"prodigy you promised me?"],[1625,1700,"Mr. Bazzini."],[1870,1975,"Name's Ross."],[1975,2087,"The prodigy you're looking for"],[2125,2220,"is right here with me."],[2454,2537,"Shameless."],[2620,2793,"What's going on, Jim?"],[2845,2995,"Apologies, Mr. George."],[3100,3141,"George?"],[3179,3258,"Hawthorne has just been"],[3258,3407,"poached by Ross's casino."],[3425,3603,"He's no longer under our roof."],[3604,3666,"I see."],[3726,3829,"Then my investment will be withdrawn—"],[3829,3904,"Then my investment will be withdrawn—"],[3904,4062,"You're open to it, Mr. Bazzini."],[4062,4225,"I'd be happy to accept your"],[4225,4391,"investment into my casino."],[4604,4641,"Yes!"],[4750,4975,"Mr. Ross's casino will be so much better."],[5366,5420,"You."],[5491,5554,"Come with me."],[5662,5720,"Half a mil."],[5920,6070,"You'll see it in your account tomorrow."],[6166,6237,"Mr. George!"],[6675,6805,"I'm the real gambling"],[6805,6945,"talent you were promised."],[7354,7433,"He's a fraud."]],"38":[[337,441,"What are you doing?"],[566,691,"Mr. George is not someone"],[691,850,"we can afford to offend."],[891,1119,"Dad, we finally got the investor"],[1125,1266,"and he's stealing it from us."],[1341,1400,"She doesn't know a"],[1400,1568,"thing about gambling, sir."],[1683,1787,"Hawthorne's the real deal."],[1883,2119,"Hawthorne's just a dealer."],[2119,2329,"When it comes to actual gambling skill,"],[2329,2437,"he's nowhere near me."],[2475,2599,"You do know what"],[2599,2920,"happens to people who lie to me."],[2987,3062,"I'm not lying."],[3229,3400,"I'm the only real player here."],[3737,3820,"How do you prove it?"],[4437,4520,"Let's gamble."],[4600,4791,"Right here, right now."],[4912,4975,"Two rounds."],[5041,5079,"Fine."],[5270,5316,"You're up."],[5366,5458,"Go against her."],[6191,6276,"Keep it quick."],[6400,6650,"You roll the dice."],[6654,7008,"You call it, high or low."],[7033,7331,"Whoever wins gets the investment."]],"39":[[0,207,"Whoever wins gets the investment."],[1450,1670,"Don't cry when you lose, princess."],[1837,1950,"Guess."],[2208,2270,"Low."],[3283,3404,"Cool, we got… what was that?"],[3416,3650,"Five, six, three. That makes..."],[3695,3766,"Fourteen."],[3833,4029,"That's a little high, wouldn't you say?"],[4116,4337,"See that? She's a total fraud!"],[4441,4550,"How do you explain that?"],[4650,4826,"One round doesn't prove anything."],[4891,4988,"Let's go again."],[5254,5429,"I don't believe I can't"],[5429,5584,"guess right eventually."],[5591,5791,"Two more tries."],[5900,5962,"Go!"],[7083,7204,"Your call, princess."],[7479,7641,"Low."],[8116,8279,"Low."]],"40":[[412,481,"It is low."],[512,587,"What the hell? I re-"],[587,691,"I rigged that round."],[891,1000,"She's just gotten lucky!"],[1000,1104,"You embarrassed me…"],[1429,1529,"Can you see?"],[1708,1787,"Interesting."],[1925,1981,"Again!"],[2958,3198,"Your move, princess."],[3325,3541,"Four, five, six. High."],[4479,4695,"Four, five, six."],[4750,4825,"High."],[5483,5545,"No way!"],[5545,5600,"What?!"],[5837,5920,"No way!"],[5920,6115,"She didn't even really get into the gambling!"],[6437,6566,"She guessed not just the"],[6566,6725,"size but the exact numbers?"],[7095,7257,"He's the real prodigy?"]],"41":[[133,379,"Impossible. He's just a blind man."],[462,637,"Looks like she's the real prodigy."],[825,1241,"Well, now that it's settled, Mr. George,"],[1262,1433,"can we count on your investment?"],[1454,1850,"Yes. In seven days, I'll come pick you up"],[1850,1979,"for the World Gambling Tournament."],[2012,2177,"Be ready."],[2354,2454,"Mr. Bazzini, please, we..."],[2529,2754,"the… the World Gambling Tournament."],[2875,3045,"I don't have any idea what trick you just"],[3045,3250,"pulled to fool him. Let's see you fake it"],[3250,3375,"at the real competition, huh?"],[3420,3616,"Get out of here, you shameless loser!"],[4275,4470,"What are we gonna do?"],[4478,4608,"The tournament is about to start and"],[4608,4733,"there's still no sign of Carl."],[4983,5062,"Did you find him?"],[5062,5129,"Yes."],[5129,5212,"Where is he?"],[5287,5579,"It isn't Carl. It's a female gambling master."],[5579,5708,"We still have a shot."],[5708,5933,"Screw that female master."],[5933,6095,"Bullshit! You keep looking."],[6145,6241,"You do whatever it takes to"],[6241,6403,"find Carl. Do it now!"],[6410,6537,"Go! Go!"]],"42":[[0,175,"The World Gambling"],[175,283,"Tournament we're talking here."],[487,641,"The top players on the planet!"],[641,708,"Dad,"],[758,895,"it's okay. Don't worry."],[970,1075,"We've got Carl!"],[1100,1330,"Carl? But he's blind…"],[1366,1633,"Dad, we finally got the money."],[1670,1913,"Let's have Carl's eyes and hands treated."],[1975,2025,"Hmm?"],[2100,2254,"Good thing we got you here in time."],[2354,2504,"The doctor said a few more days and your"],[2504,2670,"hands and eyes would have been done for."],[2670,2750,"Thank you."],[2750,2800,"No problem."],[2837,2925,"Once you get healed up,"],[2925,3020,"I'll give you a ride home."],[3041,3116,"Where do you live?"],[3137,3208,"I don't have a home."],[3325,3504,"Well, in that case, why"],[3504,3608,"don't you just stay with us?"],[3725,3845,"Once you get healed up,"],[3933,4049,"I'll let you marry Fiona."]],"43":[[141,305,"Yeah, I don't think that'd be a good idea."],[321,450,"Hey, don't overthink it."],[450,625,"I know that girl better than anyone."],[670,750,"And the way she looked at"],[750,933,"you yesterday was different."],[941,991,"Yeah, but..."],[1025,1150,"Ah, it's all settled then."],[1154,1216,"Let's head back and"],[1216,1325,"get Fiona the good news."],[1795,1892,"The finals of the World"],[1892,2020,"Gambling Tournament are tomorrow!"],[2020,2108,"Where the hell is Carl?"],[2845,2956,"It's all my fault."],[3066,3166,"I wasn't there for him"],[3166,3279,"when he needed me the most."],[3316,3418,"Don't blame yourself."],[3454,3580,"None of us wanted this to happen."],[3678,3777,"I just wish I could"],[3777,3898,"have done more to help him."],[3954,4029,"It's not your fault."],[4075,4162,"The fact that the Gambling"],[4162,4316,"God got hurt on our watch…"],[4458,4508,"it's on us."],[4620,4749,"We owe you the apology."],[5004,5137,"Then to hell with it."],[5279,5362,"Let's go to war."],[5458,5637,"The female gambler that you told me about."],[5754,5845,"Bring her tomorrow."],[5887,5966,"I'll get her now."]],"44":[[87,287,"Your hands are healed?"],[437,686,"What about your eyes?"],[820,916,"Can you see?"],[1075,1208,"A little. Doctor says"],[1208,1400,"I still need to avoid bright light."],[1533,1587,"So..."],[1766,1900,"am I pretty?"],[2258,2454,"Cut the guy some slack."],[2504,2633,"Let him rest properly."],[3250,3600,"Wow. You're really good at this."],[3687,3816,"This kid..."],[3850,4083,"could he really be a gambling master?"],[4279,4345,"Come with me."],[4345,4444,"The tournament's about to start."],[4444,4509,"Come on."],[4712,4833,"Mr. George,"],[4858,4954,"I'm sorry."],[5020,5112,"I lied to you."],[5208,5475,"I don't know how to actually gamble."],[5475,5654,"Mr. George, please calm down."],[5654,5875,"You lying bitch."],[5895,6091,"I'm mafia, not some damn charity case."],[6091,6287,"Wait, I have a solution."],[6287,6416,"What solution?"]],"45":[[595,683,"A blind guy?"],[683,808,"Are you fucking kidding me?"],[808,862,"You want to take a"],[862,981,"blind guy to a tournament?"],[991,1216,"No, he's not actually blind."],[1241,1379,"His eyes are injured,"],[1379,1566,"but he can actually see. Just..."],[1566,1791,"Please, trust us."],[1891,2112,"Look, he just rolled this a minute ago."],[2416,2496,"Is that for real?"],[2516,2683,"I swear on my life."],[2879,3079,"Not like I have any better options."],[3233,3350,"You come with me."]],"46":[[1629,1766,"That's Carl's ring."],[1795,1937,"It's definitely real."],[1983,2345,"Oh, long time no see, Mr. Bazzini."],[2441,2520,"You again."],[2625,2900,"I'm sorry to disappoint."],[2900,3054,"This time, I'm just a spectator."],[3054,3208,"Though I can't seem to find your"],[3208,3433,"so-called Gambling God anywhere."],[3433,3533,"I got a great idea."],[3575,3845,"Why don't you mind your own goddamn business?"],[4108,4262,"See how this plays out."],[4262,4345,"Yeah."],[5104,5250,"Have you reached George yet?"],[5275,5475,"No, no, he's not answering."],[5725,5804,"Fuck!"],[5836,5889,"Fuck!"],[5958,6166,"Move! Fucking move!"],[6308,6458,"Get the fuck out of my lane!"],[6937,7003,"Oh!"],[7193,7280,"Ugh..."]],"47":[[16,287,"Attention! Attention! All attention!"],[287,517,"All players, we're 30 minutes away."],[517,750,"All players, please head to your station."],[787,983,"And I'm excited to announce this year's"],[983,1191,"grand prize, the long-lost"],[1191,1408,"Ring of the Gambling God!"],[2704,2965,"Correction! Here's one of the players"],[2965,3114,"has yet to arrive,"],[3114,3370,"and failure to do so does result in forfeit."],[3375,3601,"So I would like to announce"],[3601,3870,"this year's winner, Mr. Lip!"],[4729,4899,"Who said we're not here?"],[5583,5870,"George, who's the blind guy?"],[6041,6116,"Carl?"]],"48":[[0,108,"Who's playing, huh?"],[216,320,"Don't tell me it's her."],[400,675,"Go home and make a baby, sweetheart."],[675,855,"How about you go home"],[855,1050,"and breed with your own cousin,"],[1104,1233,"freakshow?"],[1662,1930,"He's our player."],[2191,2370,"Seriously? A blind guy?"],[2495,2601,"You're the blind one."],[2604,2737,"Watch closely."],[2791,3154,"This nobody will wipe the floors with you."],[3212,3302,"Losers."],[4610,4858,"What kind of trick is this?"],[4916,4995,"I'll shuffle."],[7116,7266,"Who the hell are you?"],[7495,7645,"Could it be… Carl?"],[7658,7800,"Save the chatter."],[7879,8025,"We're here to win."]],"49":[[0,195,"Do you even know who you're up against?"],[262,333,"This is Lip,"],[333,541,"the reigning Gambling God!"],[555,683,"Shut up!"],[766,1120,"This man, sitting right across from Lip..."],[1220,1591,"He's the real Gambling God,"],[1650,1829,"Las Vegas's last one."],[2233,2312,"A blind man?"],[2350,2466,"Please don't make me laugh."],[2558,2688,"Cut the bullshit."],[2770,2842,"Let's play."],[2900,2969,"Wait."],[3058,3191,"I want to inspect the deck."],[3875,3950,"Alright, let's play."],[3950,4191,"Relax, boss. He's just some punk."],[5179,5436,"Let's go on, genius."],[6470,6620,"Show your hand, Mr. Lip."],[7037,7133,"Yes!"],[7479,7672,"Another straight flush."],[7854,7954,"We win."],[7987,8145,"All these years and you're still"],[8145,8304,"stuck on straight flushes."],[9066,9245,"Oh wow!"],[9587,9750,"Royal Flush!"],[9854,9979,"Who the hell are you?"],[10770,10900,"The man who came to end you."],[10958,11037,"-Carl? -Henry?"],[11070,11150,"Carl?"]],"50":[[262,358,"Henry?"],[412,583,"The real Gambling God?!"],[808,875,"You?"],[950,1054,"You can see again?"],[1087,1191,"Thanks to you."],[1287,1483,"You helped me see the true essence of gambling."],[1512,1791,"There's still one more round, okay?"],[1805,1929,"You beat him,"],[1929,2033,"the title's yours."],[2523,2567,"Whoa!"],[2733,2900,"I beat you three years ago!"],[3016,3095,"I'll do it again."],[3391,3433,"Carl?!"],[3504,3545,"No!"],[7016,7114,"David,"],[7124,7258,"I finally avenged you."],[7270,7395,"Everybody leave!"],[7520,7650,"I'll take care of the rest."]],"51":[[262,662,"So, Mr. Gambling God,"],[754,870,"when are you marrying me?"],[1000,1253,"Who said that he's marrying you?"],[1283,1612,"He has always loved me."],[1620,1894,"He already promised to marry me."],[2041,2100,"Marry me."],[2162,2225,"Marry me."],[2291,2366,"Marry me."],[2412,2533,"Marry me, huh?"],[2595,2762,"You let go of me both, please."],[3033,3234,"If you ask me, I say marry them both."],[3550,3625,"Your ring."],[3812,4010,"It's time it belongs to the rightful owner."],[4087,4237,"Keep it."],[4237,4350,"As a memento."],[4445,4570,"I don't need it anymore."],[4770,4987,"Come back to Chicago and marry me."],[4987,5087,"Stay in Vegas."],[5154,5215,"Wait."],[5425,5662,"What is the true essence of gambling?"],[5695,5808,"To be yourself."],[5829,5920,"To find yourself."],[5991,6133,"To live only as yourself."],[6625,6733,"Please marry me."],[6937,7103,"Stay in Vegas!"]]}