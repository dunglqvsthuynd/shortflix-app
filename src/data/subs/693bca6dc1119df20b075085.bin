{"1":[[225,347,"Damn,"],[347,462,"you're irresistible."],[567,722,"I'm very exhausted."],[779,875,"Don't play me like that."],[875,1011,"You know I'll lose control."],[1091,1237,"You're so greedy."],[1641,1753,"I'll lose it when I can't"],[1753,1963,"have you like this anymore."],[2278,2379,"What's that supposed to mean?"],[2514,2659,"You've been incredible,"],[2754,2971,"both in skill and service."],[3014,3134,"I did my homework."],[3229,3426,"I know what someone like you usually earns."],[3566,3705,"Don't worry."],[3705,3907,"I'll make sure you're properly rewarded."],[4159,4239,"Here,"],[4282,4394,"a million dollars,"],[4459,4606,"for three years of your"],[4606,4718,"dedication."],[5018,5106,"And this villa,"],[5221,5310,"it's yours."],[5488,5587,"With all this,"],[5587,5885,"you don't need to hustle in night clubs again."],[5914,5990,"Wait."],[5990,6116,"You're paying me off?"],[6116,6217,"Dumping me?"],[6311,6443,"Do you even know who I am?"],[6489,6578,"Whoever you are,"],[6578,6708,"it doesn't matter."],[6708,6790,"We're done."],[7510,7634,"This is where it ends."],[7902,8051,"But I'll miss you dearly."],[9701,9751,"Honey,"],[9751,9864,"it's been a while."],[9869,9984,"Don't call me that."],[10025,10193,"I don't feel a damn thing for you."],[10261,10465,"Why not make this clear?"],[10465,10660,"The only woman I love is Chloe."],[10717,10862,"If grandpa hadn't forced me,"],[10917,11112,"never would have married you."],[11269,11312,"Fine,"],[11378,11489,"stick with Chloe."],[11544,11713,"I'll go party every night"],[11713,11913,"to make sure the whole world knows"],[11925,12020,"I'm not yours."],[12020,12100,"Happy?"]],"2":[[80,173,"Hi, Mia."],[173,298,"It's good to see you."],[315,535,"Thanks for coming all this way to pick us up."],[630,735,"Save it, Chloe."],[744,857,"you don't have to pretend"],[857,987,"you're glad to see me."],[999,1102,"I know you're not."],[1142,1327,"No, it's not true."],[1383,1631,"Back in school, everyone picked on me,"],[1639,1786,"you always had my back."],[1838,2007,"And this is how you thank me?"],[2047,2178,"By stealing my husband?"],[2323,2389,"Mia,"],[2389,2627,"feelings can not be forced."],[2691,2907,"I never meant to take him away from you."],[3019,3119,"It's just that..."],[3334,3463,"You're pregnant?"],[3558,3703,"Can I keep this baby?"],[3788,3977,"Go on, have the baby."],[4025,4174,"We're family now, aren't we?"],[4300,4472,"Like in the old days,"],[4541,4646,"nobles,"],[4646,4781,"mistresses,"],[4821,5001,"illegitimate children..."],[5065,5236,"Nothing new under the sun."],[5308,5428,"Oh, and honey,"],[5462,5625,"when the baby's born,"],[5657,5905,"do I get to be called Mom too?"],[5969,6061,"Mia!"],[6061,6166,"What?"],[6177,6304,"Can't handle a joke?"],[6438,6534,"Anyway,"],[6534,6833,"since Chloe's carrying your child,"],[6856,7165,"shouldn't she at least get a couples villas"],[7222,7317,"for her trouble?"],[7385,7449,"Ah,"],[7449,7577,"silly me."],[7629,7721,"When the Ford's arranged"],[7721,7852,"this engagement,"],[7872,8289,"all the property was signed under my name."],[8353,8446,"Fine,"],[8446,8697,"consider those houses your compensation."],[8742,8857,"But if you keep pushing me,"],[8933,9159,"I'll strip you of the Mrs. Ford title"],[9159,9285,"in an instant."],[9309,9389,"Perfect!"],[9389,9549,"Then, let's divorce."],[9566,9801,"Chloe's pregnant, the child is innocent."],[9818,10038,"I won't stay in the way of your"],[10038,10256,"happy little family."],[10301,10363,"Mia!"],[10363,10505,"What do you mean by that?"],[10568,10632,"Fine,"],[10632,10790,"divorce it is then."],[10790,10940,"Enough!"],[10940,11087,"If you dare divorce Mia,"],[11087,11262,"I will transfer more than 80%"],[11262,11466,"of the Ford family shares into her name."]],"3":[[0,109,"Enough!"],[113,291,"If you dare divorce Mia,"],[291,467,"I will transfer more than 80%"],[467,670,"of the Ford family shares into her name."],[814,1117,"Grandpa, why are you siding with her?"],[1166,1358,"Because Mia grew up under our roof."],[1358,1608,"I won't let her be treated unfairly."],[1643,1818,"You may stop being my grandson,"],[1818,1951,"but Mia will never stop being"],[1951,2130,"my granddaughter-in-law."],[2302,2525,"But I'm the true heir of the family."],[2540,2682,"Then start acting like one."],[2711,2907,"Today is Madam Dawson's birthday."],[2947,3089,"You'll go with Mia,"],[3106,3366,"and you'll secure the Hamilton Resort deal."],[3573,3765,"That project is huge."],[3777,3997,"Every competitor out there wants it."],[4045,4325,"Then secure the one person who matters."],[4417,4532,"And who would that be?"],[4586,4729,"The Dawson heir,"],[4729,4893,"Henry Dawson."],[5113,5208,"Mr. Dawson,"],[5208,5465,"Madam Dawson's birthday party is tonight."],[5568,5682,"Mia's on the guest list."],[5859,5939,"Mia,"],[6016,6219,"what we have isn't yours to end—"],[6256,6488,"not now, not ever."]],"4":[[0,70,"Wow,"],[70,225,"leave it to the Dawsons."],[256,408,"This birthday party"],[408,565,"looks straight out of a movie—"],[565,694,"so lavish."],[694,792,"Oh, Mia,"],[792,889,"you made it."],[894,1097,"Your mom and sister already arrived."],[1097,1177,"Wait,"],[1177,1289,"haven't you heard?"],[1341,1593,"Emma's the real Jenkins daughter."],[1703,1788,"And,"],[1788,1950,"the Jenkins family"],[1950,2240,"doesn't even acknowledge Mia anymore."],[2405,2574,"What are you even doing here?"],[2597,2814,"You're not the Jenkins heiress anymore."],[2897,3036,"You've been stuck in an empty"],[3036,3198,"marriage for three years."],[3209,3398,"That \"Mrs. Ford\" title of yours"],[3398,3538,"doesn't mean a thing now."],[3553,3705,"Take my advice and leave."],[3762,3928,"If you pissed off the Dawsons,"],[3928,4149,"don't go parading around as a Jenkins."],[4149,4305,"You'll only make a fool of yourself."],[4314,4539,"Next, the Jenkins family."],[4973,5113,"Mrs. Dawson."],[5125,5345,"On behalf of the Jenkins family,"],[5345,5542,"please accept this jewelry set,"],[5542,5754,"worth 1.5 million dollars."],[5817,5974,"But price is secondary."],[5974,6196,"What really matters is that,"],[6196,6321,"it's a custom,"],[6346,6458,"one of the kind."],[6473,6606,"Only something truly"],[6606,6761,"unique can meet your status."],[7462,7614,"One and a half million?"],[7620,7762,"She even doesn't realize"],[7762,7929,"Mrs. Dawson's bracelet"],[7932,8173,"alone is worth 50 million."],[8350,8585,"Mrs. Dawson didn't even blink at my gift."],[8616,8817,"Let's see what you can possibly come up with."],[9074,9262,"How much is the gift you prepared worth?"],[9262,9389,"Zero."],[9446,9617,"Are you out of your mind?"],[9686,9789,"Mrs. Dawson."]],"5":[[1,110,"Mrs. Ford,"],[110,241,"don't tell me you actually"],[241,433,"made this candle yourself."],[457,682,"Yes, it's a little hobby of mine."],[685,829,"I even have my own recipe."],[889,1046,"A homemade candle,"],[1101,1393,"as a birthday gift for Mrs. Dawson?"],[1393,1604,"Don't you think it's insulting?"],[1664,1798,"What happened?"],[1850,1981,"The Ford family is"],[1981,2182,"too broke to bring a real gift?"],[2242,2335,"Seriously?"],[2335,2569,"Is this how you handle things?"],[2781,2851,"Oh wow!"],[2851,2986,"This smells amazing."],[3078,3210,"I heard that Mrs. Dawson's"],[3210,3345,"been struggling with sleep."],[3345,3538,"So I made this to help."],[3625,3717,"No wonder!"],[3717,3973,"When I just smelled it, I felt so relaxed."],[4217,4589,"Look at all these so-called society ladies."],[4621,4851,"Thinking a simple candle can impress"],[4851,4964,"Mrs. Dawson."],[5018,5155,"Or make them worthy"],[5155,5342,"of marrying into the family."],[5430,5694,"Emma, don't fool yourself."],[5725,5942,"Henry Dawson isn't someone"],[5942,6109,"you can win over."],[6161,6264,"I actually met"],[6264,6433,"Mr. Dawson last month."],[6433,6609,"He told me I looked prettier."],[6624,6718,"Oh please,"],[6718,6840,"with his schedule?"],[6840,7073,"Like he'd have time to notice you."],[7145,7369,"Great, now Mia's laughing at us."],[7389,7520,"Not at all,"],[7520,7614,"I just think you both"],[7614,7726,"are accomplished women."],[7726,7946,"You don't need to fight over a man."],[8006,8118,"You don't get it."],[8153,8433,"We don't like Henry just because he's rich."],[8445,8753,"If you ever saw him in person, you'd understand."],[8785,9025,"His face's unforgettable."],[9025,9134,"Is that so?"],[9309,9494,"I've seen such a face too,"],[9601,9778,"the one I'll never forget."]],"6":[[320,474,"I wonder how this Henry Dawson"],[474,607,"compares to him."],[1925,2250,"After this, how about I take care of you?"],[3476,3545,"Wait,"],[3545,3625,"who's that?"],[3660,3823,"That's the Henry Dawson."],[3877,4017,"Henry Dawson."],[4017,4155,"Henry."],[5407,5468,"Wait,"],[5468,5699,"that Pretty Boy's Henry Dawson?"],[5779,5862,"Say something."],[6302,6434,"What are you standing here for?"],[6438,6594,"Let's go talk to Mr. Dawson."],[6603,6835,"This resort deal has to get done tonight."],[6846,6926,"Hurry up!"]],"7":[[20,143,"Cheers!"],[220,358,"Mr. Dawson,"],[358,503,"I'm Emma Jenkins."],[507,680,"Good afternoon Mr. Dawson."],[724,855,"My name is Jason Ford."],[1076,1204,"I've heard a lot about you."],[1259,1399,"Sir, you're the legend."],[1416,1603,"Let me raise a glass to you,"],[1636,1788,"to Mr. Dawson."],[1788,1863,"Ford?"],[1991,2063,"Yes, sir."],[2090,2187,"Jason Ford."],[2207,2344,"Ford Construction Company."],[2420,2529,"Mr. Dawson,"],[2529,2739,"giving the Ford family a shot"],[2764,2939,"at the Hamilton Resort project"],[2987,3151,"would mean everything to us."],[3299,3535,"Anyone could work on the Hamilton Resort project,"],[3580,3812,"just not the Fords."],[4000,4137,"Sorry, did-"],[4220,4382,"did the Ford family ever do"],[4382,4511,"anything to upset you?"],[4525,4577,"Well..."],[4734,4901,"It's a question for Mrs. Ford."]],"8":[[133,300,"It's a question for Mrs. Ford."],[387,487,"Mia,"],[553,724,"I can't believe you actually"],[724,895,"angered the Dawsons."],[1039,1164,"I feel sorry for the Fords"],[1164,1246,"because of you."],[1453,1556,"Okay."],[1556,1683,"What's going on here?"],[1716,1920,"Three years ago, she got on my bad side,"],[1966,2087,"and then she just disappeared,"],[2153,2280,"no explanation,"],[2280,2377,"nothing."],[2427,2537,"No way."],[2537,2742,"I've never heard Mr. Dawson"],[2742,2939,"publicly dated anyone."],[2946,3079,"Oh, I remember now."],[3119,3383,"Three years ago, I messed up."],[3440,3653,"I scratched your car."],[3677,3803,"Are you kidding me?"],[3833,3977,"Do you even know how much"],[3977,4107,"Mr. Dawson's car's worth?"],[4174,4372,"Apologize now."],[4419,4723,"Mr. Dawson. I didn't mean to upset you."],[4756,4946,"I just want to make things right."],[5043,5293,"Let me raise a glass to clear the air."],[5387,5487,"Mrs. Ford."],[5553,5647,"One drink,"],[5680,5879,"it's like wiping away 3 years of resentment,"],[5879,5965,"just like that?"],[6132,6312,"Excuse me. I'm not feeling good."],[6479,6671,"I'm so sorry, Mrs. Ford."],[6706,6790,"If you'd like,"],[6790,6943,"I can take you upstarts to change."]],"9":[[1152,1291,"Mr. Dawson."],[1291,1434,"Isn't it against the rules"],[1434,1516,"for a guy"],[1516,1675,"to just walk into a girl's room?"],[1801,1901,"This is my hotel."],[2217,2302,"Besides,"],[2382,2481,"I've seen more."],[2729,2969,"I'm changing. Please go outside."],[4933,5038,"Leave him."]],"10":[[55,191,"Three years, Henry."],[220,353,"We had our peace."],[573,710,"You forgive my leaving,"],[710,834,"I forgive your lies."],[870,967,"Let's end this clean."],[1191,1287,"So that's it?"],[1394,1491,"I was just a weapon against"],[1491,1599,"your cheating husband?"],[1713,1886,"If you already know, why ask?"],[2087,2208,"Mia Jenkins,"],[2208,2520,"no one uses me and then tosses me aside."],[2540,2657,"If this ends,"],[2657,2834,"it ends on my turn."],[3196,3441,"And you'll secure the Hamilton Resort deal."],[3913,4017,"Mr. Dawson,"],[4212,4372,"I know I crossed the line."],[4432,4532,"But someone"],[4544,4741,"running an empire like yours should know"],[4776,4968,"how to separate business from personal."],[5113,5226,"Mrs. Ford,"],[5226,5428,"don't mistake me for that kind of man."],[5540,5752,"I never separate business from personal."],[5832,5960,"I act on emotion."],[6292,6441,"Then let your personal emotion"],[6441,6589,"change your business decision."],[6685,6771,"Please let the Fords"],[6771,6965,"take the Hamilton Resort project."]],"11":[[1781,1870,"Mrs. Ford,"],[1870,2018,"you're not drunk anymore."],[2178,2345,"You always see right through me."],[2642,2722,"Okay,"],[2762,2842,"I'll do it,"],[2926,3069,"if you move back to my villa."],[3366,3506,"Then send the file to the Fords."],[4154,4294,"Send the bid to the Fords."],[4382,4557,"They've got the Hamilton Project."],[5662,5757,"Pick you up tomorrow."],[5957,6074,"I'll move back,"],[6102,6234,"but in five years."],[6726,6806,"Huh,"],[6890,6981,"gutsy move."],[7093,7195,"Never thought anyone would mess"],[7195,7282,"with me like that."]],"12":[[13,126,"Good morning, everyone."],[130,377,"It's Thursday, October 2, 2025."],[382,462,"Boss,"],[565,785,"the NY TV station sent another invite."],[802,997,"Should I turn them down like usual?"],[1017,1109,"Not this time."],[1117,1226,"I think I'll actually go."],[1519,1741,"Thanks for tuning into Morning News."],[2365,2457,"Big news, Mia,"],[2465,2674,"Alex just got promoted to WA."],[2681,2869,"That prime-time anchor spot?"],[2869,3026,"It's basically yours now."],[3053,3260,"Prime-time anchor isn't about sponsors,"],[3260,3391,"it's about talent."],[3391,3608,"Honestly, Mia, you might not make it."],[3780,4020,"Look, talent matters,"],[4029,4167,"at least the beats leaching off"],[4167,4247,"everyone else."],[4416,4534,"Speaking of which,"],[4619,4764,"I heard some rumors at"],[4764,4878,"the William Group dinner"],[4878,4989,"the other night."],[5020,5236,"Some girl at our station"],[5236,5538,"was all over Mr. William."],[5538,5815,"Mrs. William caught her several times."],[5820,5915,"Slapped her"],[5915,5982,"right there"],[5982,6127,"in front of everyone."],[6132,6236,"Crazy, right?"],[6316,6504,"Wonder who that could be?"],[6544,6745,"Mia, don't pin that on me."],[6751,6958,"There are so many girls at our station."],[6958,7123,"No one said it was you."],[7180,7263,"You-"],[7352,7475,"What's all this yelling?"],[7532,7744,"Enough! Focus, everyone."],[7844,7929,"By the way,"],[7974,8108,"meet our new hire."]],"13":[[5,80,"Alright,"],[108,300,"go ahead and introduce yourself."],[345,493,"Hi everyone, I'm Chloe."],[503,613,"Just started here,"],[622,805,"looking forward to working with you all."],[977,1249,"Hi Mia, looks like we're coworkers now."],[1257,1349,"Well, actually"],[1349,1513,"Mia and I went to the same high school"],[1513,1589,"together."],[1601,1750,"We used to be best friends."],[1893,1980,"Best friends?"],[2043,2172,"That's a bit of a stretch."],[2242,2328,"Here's the deal—"],[2389,2554,"the prime-time anchor spot"],[2554,2719,"is still wide open."],[2806,2982,"We need to land an interview"],[2982,3193,"with a big-name guest."],[3193,3341,"Who ever secures it first"],[3341,3433,"gets the seat."],[3453,3636,"And who's the big name guest?"],[3665,3763,"Henry Dawson,"],[3777,3983,"CEO of the Dawson Group."],[4042,4145,"Good luck to you."],[4205,4329,"I'm counting you."],[4386,4541,"Everyone else, back to work."],[4581,4646,"Director."],[4646,4716,"Mia,"],[4749,4904,"they don't know you're Mrs. Ford?"]],"14":[[41,115,"Everyone else,"],[115,188,"back to work."],[293,358,"Director."],[358,428,"Mia,"],[462,600,"they don't know you're Mrs. Ford?"],[648,722,"What？"],[722,877,"I'm supposed to live my whole life"],[877,980,"as someone's wife,"],[980,1129,"just to prove I'm worth something?"],[1174,1237,"Okay, Mia,"],[1237,1429,"you don't have to come at me like this."],[1429,1538,"Let's keep it fair."],[1538,1651,"Whoever wins,"],[1659,1860,"it's still a win for the station."],[1970,2177,"Honestly, I didn't care much about"],[2177,2305,"that prime-time slot."],[2362,2540,"But since you're in the game,"],[2564,2691,"I'm all in."],[2694,2781,"So..."],[2869,2939,"Play fair,"],[2939,3058,"and we're fine."],[3058,3175,"Try anything shady,"],[3175,3353,"and I'll end you fast."],[3358,3470,"Don't worry,"],[3470,3633,"I don't need to cheat to beat you."],[3907,4005,"Oh, Mia."],[4017,4169,"Of course I'm competing with you."],[4177,4304,"I'm gonna take it all."],[4304,4369,"Your husband,"],[4369,4434,"your job,"],[4434,4499,"your family."],[4501,4642,"And when you've got nothing left,"],[4659,4804,"I'll be there to watch."]],"15":[[0,115,"First day at the station."],[138,275,"Mia didn't give you a hard time,"],[275,342,"did she?"],[342,415,"I'm fine."],[415,514,"You know her."],[518,722,"She's always been that way with me."],[742,884,"If she does anything that"],[884,1002,"makes you feel uncomfortable,"],[1062,1152,"just tell me."],[1169,1312,"I can handle this."],[1326,1428,"Don't, Jason."],[1439,1539,"I can handle her."],[1566,1750,"Besides, the director already"],[1750,1820,"made it clear."],[1823,1998,"Who ever gets Henry's interview"],[1998,2192,"will win the prime-time slot."],[2197,2354,"I can take her down by myself."],[2372,2454,"Then play smart."],[2550,2688,"I heard Henry spends"],[2688,2889,"every weekend at the Royal Tennis Club."],[2890,3064,"But it's a private club."],[3077,3199,"No way I'm getting in"],[3199,3378,"without a premium membership."],[3481,3576,"Lucky for you."],[3576,3658,"I've got you one."],[3725,3867,"You can go in under my"],[3885,4000,"Mrs. Ford's name."],[4000,4129,"No one will question it."],[4174,4374,"Mrs. Ford? Really?"],[4406,4486,"To me,"],[4551,4776,"you'll always be my Mrs. Ford."],[5241,5493,"Miss, I don't think I've seen you before."],[5513,5605,"Are you a member?"],[5633,5830,"My father-in-law is Johnason Ford."],[5830,5948,"That should get me in."],[5954,6044,"Oh,"],[6044,6164,"so you're Mrs. Ford too."],[6207,6294,"Too?"]],"16":[[38,106,"Oh,"],[106,246,"so you're Mrs. Ford too?"],[260,330,"Too?"],[331,442,"There's another Mrs. Ford?"],[442,583,"Uh, yes actually,"],[623,827,"a lady also claimed herself as Mrs. Ford."],[945,1141,"But the Ford family only has one son."],[1146,1281,"How come there are two wives?"],[1312,1501,"Mia, what are you doing here?"],[1506,1624,"What do you think?"],[1633,1838,"Someone's out here pretending to be me."],[1845,2045,"I'm not just gonna sit back and watch."],[2429,2549,"What's going on?"],[2582,2817,"Playing the \"Real Mrs. Ford\" game now, are we?"],[2837,3041,"Man, this city's wild."],[3041,3218,"One guy, two wives."],[3264,3435,"Ah, Mr. Dawson."],[3478,3615,"Mrs. Ford went to your mother's"],[3615,3713,"birthday party, right?"],[3713,3792,"You can tell which one is"],[3792,3900,"the real Mrs. Ford."],[3930,4074,"If you really wanna know,"],[4105,4257,"let's FaceTime Jason Ford."],[4285,4386,"I'm sure he'll tell you."],[4386,4497,"That's a brilliant idea."],[4529,4646,"Thank you, Mr. Dawson."],[4926,5169,"Hi, sorry to bother you, Mr. Ford."],[5169,5315,"We've got two Mrs. Ford's here."],[5353,5503,"Can you tell us which one's the real one?"]],"17":[[0,93,"The one in white shirt."],[103,251,"Understood, Mr. Ford."],[286,447,"I apologize for the interruption."],[647,702,"Ma'am,"],[767,887,"I'm gonna have to ask you to leave."],[1316,1394,"So,"],[1448,1603,"you still wanna be Mrs. Ford?"],[1735,1841,"Play nice with me,"],[1868,2024,"and I'll make them all disappear."],[2247,2370,"Recognize this card?"],[2459,2619,"That's the Black Elite Card!"],[2650,2786,"Less than twenty in the whole world."],[2839,3014,"Around here, only Henry's got one."],[3014,3094,"Impossible."],[3094,3201,"Not even the Fords"],[3201,3334,"or the Jenkins could get that card."],[3346,3460,"How the hell does she have it?"],[3468,3675,"So if I get membership on my own,"],[3678,3815,"I can go in, right?"],[3815,4087,"Yes, but ma'am, the fee is-"],[4097,4220,"One million, I know."],[4240,4351,"Just run it."],[4351,4426,"Yes, ma'am."],[4436,4517,"Please wait a moment."],[4803,4914,"Miss, your card."],[5003,5083,"Thanks."],[5427,5470,"Mia,"],[5515,5612,"what's your story?"]],"18":[[453,617,"Hi, Mr. Dawson."],[617,845,"I'm Chloe, reporter from NY TV."],[937,1154,"About the Hamilton Resort project,"],[1154,1286,"we'd love to set up"],[1286,1469,"an exclusive interview with you."],[1509,1598,"Not interested."],[1643,1715,"Look,"],[1745,1893,"for a new project like this,"],[1893,2182,"you ready need publicity to attract investors."],[2197,2394,"And you need to secure your place as heir"],[2394,2565,"before your two sisters take it."],[2600,2787,"So, the success of this project"],[2787,2894,"means a lot to you."],[2946,3018,"Ah,"],[3048,3123,"seem you know my family"],[3123,3253,"business a little too well."],[3313,3510,"Well, working with NY TV"],[3510,3643,"means having the city's top"],[3643,3777,"media in your corner."],[3782,3917,"It's a win-win."],[3917,4019,"Nice shot!"],[4305,4402,"Miss Jenkins,"],[4402,4569,"you look like a professional athlete."],[4597,4746,"No, it's just a hobby."],[4878,5038,"I think you need more practice."],[5153,5233,"Oh really?"],[5238,5383,"Then, how about we play a game"],[5383,5470,"against each other?"]],"19":[[23,120,"Sure, why not?"],[191,325,"That's bold, Mia."],[335,567,"Henry is skilled and he has status."],[583,775,"He won't play with someone like you."],[805,885,"Oh, really?"],[977,1164,"Then, how about we play a game"],[1164,1247,"against each other?"],[1247,1404,"What kind of competition are you thinking?"],[1421,1626,"And if it's a competition, there"],[1626,1765,"has to be a prize, right?"],[1765,1856,"If I win,"],[1933,2097,"exclusive interview"],[2097,2222,"rights for the resorts are mine."],[2245,2374,"Seriously, Mia?"],[2382,2577,"You're over estimating yourself."],[2580,2777,"Henry's skills are legendary."],[2806,2899,"I'll serve."],[2914,3011,"Score within 10 points,"],[3029,3126,"you win."],[3431,3510,"Wow!"],[3530,3680,"His speed is insane!"],[3705,3802,"But how is she-"],[3813,3990,"Mr. Dawson will probably finish this"],[3990,4140,"in five points."],[4140,4237,"Mia wants to win,"],[4237,4337,"it's gonna be tough."],[4426,4612,"Seriously? You should just give up."],[4858,4933,"Win this point,"],[4933,5025,"and the exclusive interview"],[5025,5141,"rights are yours."]],"20":[[1016,1182,"There's no way she can do that."],[1279,1391,"Henry,"],[1391,1503,"you keeping your word?"],[1539,1693,"Impressive skills, Mia."],[1746,1866,"Interview rights are yours."],[1880,1980,"Thanks."],[2020,2102,"But,"],[2102,2202,"five years from now,"],[2237,2384,"feel free to come back for that interview."],[2427,2507,"Bye."],[2584,2702,"I thought you had it."],[2719,2877,"Guess you got played after all."],[3051,3219,"Just like a little kid."],[3451,3555,"Everyone,"],[3578,3663,"hold up."],[3682,3815,"The Dawson Group just called,"],[3832,4014,"and they want us to do the interview"],[4014,4075,"tomorrow."],[4150,4240,"Mia,"],[4240,4304,"Chloe,"],[4310,4412,"who actually secured it?"],[4471,4536,"It's me!"],[4724,4983,"Chloe, you've got real skills."],[4983,5171,"Your future looks promising."],[5200,5300,"Thanks, Director."],[5462,5532,"Hey,"],[5550,5767,"no surprise she's from a top school."],[5767,6016,"Not like some people who just talk."],[6036,6269,"Looks like the prime-time hosting"],[6277,6403,"is all yours."],[6411,6566,"Seeing me success like this..."],[6566,6695,"does it make you jealous?"]],"21":[[35,190,"Seeing me success like this,"],[190,323,"does it make you jealous?"],[323,422,"Remember that time"],[422,597,"when I was always asking for help?"],[620,814,"Yeah, your whole persona..."],[814,1004,"I barely even recognize you anymore."],[1004,1131,"Well, back then,"],[1131,1319,"you always acted like you were superior."],[1331,1408,"But now?"],[1408,1536,"The tables have turned,"],[1536,1606,"Mia."],[1723,1920,"Oh, so your big win?"],[1935,2143,"Is sleeping with other people's husbands?"],[2167,2270,"That's your secret trick!"],[2308,2380,"Mia."],[2424,2620,"Don't try slandering Chloe"],[2620,2776,"just because you lost."],[2776,2912,"You could get into serious"],[2916,3036,"legal trouble for that."],[3059,3331,"I didn't know there was another Mrs. Ford?"],[3395,3672,"How did you, Mrs. Ford,"],[3720,3883,"end up in the TV station?"],[3990,4082,"Don't worry."],[4082,4194,"Just keep being Mrs. Ford."],[4195,4394,"I won't tell the other Mrs. Ford."],[4412,4556,"But honestly,"],[4642,4879,"she probably couldn't care less about you."]],"22":[[185,265,"Mia!"],[342,485,"Didn't I tell you to stop messing"],[485,550,"with Chloe?"],[553,680,"I'm just using the same tactics"],[680,777,"she used on me."],[1006,1194,"Oh, by the way, Jason."],[1254,1349,"Don't forget"],[1349,1518,"we never got married."],[1624,1738,"Your divorce news is gonna"],[1738,1898,"tank your stock prices,"],[1898,2070,"and I won't keep that secret."],[2150,2293,"So don't push your luck."],[2357,2570,"Once the Ford family goes public,"],[2582,2767,"I'll spill everything,"],[2881,3093,"then you and I will be completely done."],[3645,3733,"Ladies."],[3797,3917,"Oh, hi, I'm Chloe."],[3917,4047,"I have an interview scheduled"],[4047,4169,"with Mr. Dawson."],[4169,4264,"Sorry, Chloe."],[4264,4389,"Mr. Dawson said he'll"],[4389,4481,"only do interviews"],[4481,4592,"if Mia is hosting."],[4693,4781,"Wait, what?"],[4781,4918,"How can it even be possible?"],[4944,5035,"Why Mia?"],[5071,5258,"What if we can't get the interview today?"],[5261,5437,"The director's gonna lose it!"],[5525,5618,"Sorry, my bad."],[5642,5744,"I'll get Mia to host it."],[5867,5980,"Are you kidding me?"],[6036,6142,"If you screw this up,"],[6151,6317,"can you even handle the fallout?"],[6353,6413,"Go!"],[6424,6548,"Get Mia here, now!"],[6866,7017,"Mia, please."],[7043,7163,"I'll do whatever you want."],[7172,7360,"Let's not let personal grudges"],[7360,7462,"mess with work."],[7462,7629,"Let's keep it professional"],[7629,7796,"and focus on the bigger picture,"],[7796,7856,"okay?"],[7876,8128,"Chloe, cut the fake pity act."],[8243,8338,"Mia, please."],[8351,8471,"I'm pregnant."],[8486,8666,"If I don't get this interview,"],[8707,8790,"I'm done."]],"23":[[0,180,"If I don't get this interview,"],[220,303,"I'm done."],[387,485,"Do you really want that"],[485,587,"on your conscience?"],[595,707,"Not my problem."],[812,919,"It's all my fault."],[984,1096,"I shouldn't have fought you"],[1096,1191,"for the interview."],[1196,1391,"I shouldn't have gone after Jason."],[1419,1609,"If you want to blame someone, blame me."],[1626,1753,"Or hit me!"],[1895,1983,"You've lost it."],[2200,2280,"Mia!"],[2347,2554,"Mia, are you seriously gonna hit her?"],[2652,2804,"Chloe, don't worry. I'll stand by you."],[2876,3023,"What are you recording?"],[3048,3228,"Just for asking Mrs. William"],[3246,3388,"if you are the TV station girl"],[3388,3481,"she is looking for. -You've crossed the line."],[3543,3660,"Don't touch me!"],[3707,3852,"You better watch yourself."],[4204,4328,"Hey, Thomas."],[4338,4394,"Mia."],[4410,4566,"The interview location's changed."],[4566,4731,"To where? I'll go now."],[4745,5033,"Henry says at the villa you gave him."],[5163,5372,"The villa I gave him?"]],"24":[[2130,2290,"Thomas, we're about to start."],[2290,2394,"Where is Henry?"],[2510,2590,"Hello, Mia."],[2711,2839,"Do you like this house?"],[2911,2991,"If you do,"],[3066,3166,"maybe I'll give it to you."],[3398,3521,"Mr. Dawson,"],[3521,3666,"stop joking around."],[3687,3800,"It's my first time here."],[3800,3995,"How could I already have an opinion?"],[4054,4170,"Let's go get changed."],[4170,4325,"We're about to start the interview."],[4357,4457,"Get changed?"],[4542,4669,"You don't like how I'm dressed?"],[4914,4994,"Okay."],[5038,5115,"If you're the host,"],[5115,5230,"don't like how I'm dressed then,"],[5230,5303,"I could always change."],[5303,5383,"Wait!"],[5410,5543,"I like it, I like it."],[5642,5717,"Do you know why I chose"],[5717,5839,"this place for the interview?"],[6022,6174,"I'm sure you have your reasons,"],[6174,6326,"Mr. Dawson."],[6398,6609,"Because every corner of this place"],[6629,6798,"is filled with memories,"],[6866,6946,"sweet,"],[6991,7072,"fiery,"],[7202,7282,"warm,"],[7419,7525,"and cruel ones."]],"25":[[270,410,"What are you all waiting for?"],[422,573,"Set up the cameras already."],[622,877,"Mr. Dawson's time is valuable."],[1086,1237,"Thank you again, Mr. Dawson,"],[1237,1389,"for joining this interview."],[1433,1633,"Now it's time for audience questions."],[1685,1768,"First question."],[1768,1976,"Mr. Dawson, do you have a girlfriend?"],[2105,2197,"Not at the moment."],[2222,2297,"Alright."],[2332,2459,"Second question."],[2505,2669,"Is there a person that you like?"],[2714,2794,"Yes."],[2800,2879,"I've been in love with her"],[2879,3022,"for the last seven years."],[3058,3258,"Seven years..."],[3425,3543,"I didn't expect the audience"],[3543,3690,"to be so curious about"],[3690,3810,"Henry's love life."],[3810,4022,"Let's finish with one last question."],[4065,4236,"Does the person that you like"],[4236,4385,"feel the same way?"],[4441,4561,"What do you think, Mia?"],[4637,4798,"I can only say this."],[4858,5096,"The brave ones are the ones"],[5096,5235,"who get to enjoy happiness."],[5347,5527,"Mr. Dawson, if you like her,"],[5555,5707,"why don't you go after her?"],[5739,5874,"You might actually succeed."],[5927,6046,"Alright,"],[6076,6259,"that's it for today's interview."],[6259,6449,"Thanks for watching, everyone."],[6663,6786,"After all that's been said,"],[6786,6955,"and you still don't recognize me?"],[7127,7207,"Mia,"],[7370,7525,"you've really forgotten about me?"],[8418,8528,"What?"],[8528,8630,"You're into me?"],[8655,8835,"Well, lucky for you."]],"26":[[682,775,"What?"],[775,894,"You're into me?"],[919,1099,"Well, lucky for you."],[2742,2859,"You again?"],[3038,3138,"I knew it."],[3138,3286,"You just can't let me go."],[3890,3970,"Mia,"],[4062,4175,"will you be my girlfriend?"],[4319,4459,"Wasn't it you who said"],[4574,4694,"the brave are the ones"],[4694,4771,"who enjoy happiness."],[4783,4923,"Well, I'm ready to be brave."],[4958,5038,"Plus,"],[5123,5278,"I think we have great chemistry together."],[5329,5434,"Mr. Dawson."],[5434,5558,"Stop joking around."],[5710,5819,"I was just talking about"],[5821,5915,"the chemistry in the interview,"],[5915,5968,"Mia."],[6042,6181,"What were you talking about?"],[8133,8275,"You are so funny."],[8423,8543,"We're done here."],[8570,8698,"Time's up."],[8698,8913,"Mr. Dawson's schedule is so busy."],[8930,9027,"Let's wrap this up."]],"27":[[1,146,"Mia, look at how Jason treats you,"],[146,273,"and you're still taking care of us."],[273,435,"Grandpa, what are you talking about?"],[435,508,"We're family."],[508,553,"Mia!"],[585,694,"I was looking for you."],[700,872,"What did you do to Chloe this time?"],[925,1082,"Complained about me again?"],[1106,1214,"Don't play dumb."],[1241,1393,"You took her interview rights,"],[1406,1614,"humiliated her in front of everyone,"],[1644,1770,"and even slapped her."],[1833,2010,"How can you be so cruel?"],[2092,2250,"Jason, what are you saying?"],[2308,2507,"Grandpa, you don't know what she's been doing."],[2662,2746,"Jason,"],[2746,2841,"at this point,"],[2869,2969,"nothing I say"],[2981,3188,"will make you believe me."],[3233,3410,"All you care about is Chloe."],[3508,3606,"So, you know what?"],[3655,3767,"Let's get a divorce."],[3880,3945,"Grandpa,"],[3945,4067,"thank you for taking care of me"],[4067,4225,"for the past three years."],[4242,4334,"I'll leave tonight."],[4351,4527,"Mia, you can't just divorce."],[4577,4662,"Grandpa,"],[4674,5011,"we actually never got a marriage certificate."],[5055,5343,"So technically, it's not even a divorce."],[5350,5400,"What?"],[5400,5547,"How is that possible?"],[5550,5672,"Your marriage certificate"],[5672,5782,"is in my desk drawer."],[5849,6034,"Oh, that's a fake, Grandpa."],[6041,6186,"Jason didn't even show up"],[6196,6389,"on the day we were supposed to get married."],[6399,6526,"This is outrageous!"],[6539,6609,"Jason,"],[6609,6723,"how could you do this?"],[7037,7148,"It's okay, Grandpa."],[7195,7273,"Don't worry."],[7273,7387,"Even if I'm not-"],[7439,7674,"Even if I can't be your daughter-in-law,"],[7686,7817,"I'll still take care of you."],[7831,7947,"Fine, fine."],[7959,8063,"If you want to separate,"],[8074,8138,"go ahead."],[8151,8251,"But I've always said"],[8279,8443,"if you give up being Mia's husband,"],[8455,8580,"you give up your right to inherit"],[8580,8753,"the Ford family fortune."],[8900,9010,"Home."],[9074,9205,"Where is my real home?"]],"28":[[101,181,"Home..."],[245,377,"Where is my real home?"],[570,648,"Mia."],[722,889,"I've called you a million times!"],[889,999,"What are you doing out here alone"],[999,1121,"by yourself at this time?"],[1166,1272,"It's dangerous."],[1329,1438,"Aren't you afraid?"],[1438,1538,"Come home with me."],[1601,1695,"Come here."],[1960,2040,"Hey!"],[2213,2297,"It's okay."],[2385,2465,"Don't cry."],[2686,2797,"Sorry."],[2797,3093,"I'm not exactly good at comforting sad girls."],[4506,4662,"This is my profile."]],"29":[[181,338,"This is my profile."],[957,1034,"Alright,"],[1044,1147,"I'll move back in."],[1378,1561,"But we need to have some ground rules."],[2180,2442,"First, we're not falling in love with each other."],[2514,2597,"Second,"],[2689,2906,"respect each other's privacy and space."],[3186,3284,"Go on."],[3358,3438,"Third,"],[3541,3677,"no other partners."],[3677,3862,"I don't want to share you with anyone else."],[3865,3968,"I only have one partner."],[3993,4085,"Of course."],[4097,4247,"If you have a better choice,"],[4247,4371,"feel free to tell me."],[4477,4612,"I only have one condition."],[4706,4813,"When this ends?"],[4889,4989,"I call the shots."],[5433,5517,"You cook a lot?"],[5762,5835,"Not really."],[5859,5987,"Today's a celebration."],[6057,6229,"What are we celebrating?"],[6281,6378,"Celebrating you."],[6506,6586,"Me?"],[7033,7153,"Coming back to me."],[7308,7494,"I still have a few questions."],[7714,7794,"Go ahead."],[7832,8208,"Why did you hide your personality 3 years ago?"],[8232,8317,"Well..."],[8317,8441,"You never asked."],[8493,8613,"You wanted to take care of me,"],[8613,8765,"so why wouldn't I accept?"],[8957,9125,"Why didn't you just tell me?"],[9346,9494,"My identity is not important."],[9566,9826,"What matters is you're back in my life now."],[10201,10281,"Let's eat."]],"30":[[18,178,"Everyone, listen up."],[198,382,"The prime-time anchor spot"],[382,575,"was supposed to go to Mia."],[585,774,"But this morning,"],[782,1046,"Chloe secured a five-year"],[1046,1254,"ad deal with the Ford family."],[1281,1498,"That's huge for the network."],[1498,1641,"Now the plan is,"],[1678,1870,"you two are going to compete fairly."],[1936,2157,"Let professionalism decide"],[2197,2342,"who earns this spot."],[2417,2482,"Don't worry,"],[2482,2559,"Director."],[2559,2761,"Mia and I will keep it professional."],[2761,2821,"Good."],[2821,2926,"Give it your all."],[2977,3113,"Good morning, everyone."],[3121,3321,"Good morning and welcome to morning news."],[3321,3523,"Let's get started with breaking news."],[3723,3983,"Wait, the teleprompter is down."],[4039,4199,"It's a live broadcast."],[4212,4404,"Let's see how you handle this one."],[4459,4606,"Yesterday, Henry Dawson,"],[4606,4768,"CEO of Dawson Group pledged"],[4768,5135,"$20 million to fund two orphanages in New York."],[5135,5367,"Hundreds of children now have a home."],[5367,5520,"The city is praising Dawson Group"],[5520,5638,"for their generosity."],[5839,5919,"Damn!"],[5919,6131,"Mia is so professional."],[6156,6483,"Teleprompter's dead and she still pulled it off."],[6488,6568,"Wow,"],[6568,6746,"we didn't even get the news"],[6746,6848,"and she got it?"],[6880,7012,"That's impressive."],[7020,7100,"Chloe,"],[7100,7252,"why are you frozen?"],[7263,7424,"It's a live broadcast!"],[7444,7600,"A city-wide safety campaign"],[7600,7696,"kicked off today,"],[7696,7904,"promoting public safety awareness."],[7904,7994,"Director,"],[7994,8283,"Mia's mother just hit the trending list."],[8319,8555,"People saying she's a murderer."],[8560,8646,"What?"],[8720,8793,"Cut the feed!"],[8793,8932,"Switch to entertainment."],[8955,9119,"Get Mia off air, now!"],[9142,9330,"Breaking news,"],[9330,9477,"sources reveal that"],[9477,9731,"New York TV's morning anchor Mia"],[9731,9954,"is the daughter of a convicted murderer."]],"31":[[1161,1241,"What?"],[1332,1431,"Chloe's mother's phone number"],[1431,1526,"and address?"],[1601,1695,"What, you're just gonna sit there"],[1695,1773,"and take it?"],[1881,1973,"That's not like you."],[2474,2534,"Jason,"],[2534,2654,"help me."],[2660,2749,"Help me."],[2841,2917,"Hey, Chloe."],[2917,3009,"Chloe, I'm here."],[3021,3108,"Don't be afraid."],[3108,3238,"Just tell me what happened."],[3261,3358,"It's Mia."],[3433,3596,"She tracked down my mom,"],[3596,3757,"and brought her to the TV station"],[3757,3902,"to humiliate me."],[3913,4182,"She knows my mom is unstable."],[4229,4394,"She's out of control."],[4517,4669,"I could never show my face"],[4669,4818,"at the station again."],[4926,5126,"Why would she do that to me,"],[5126,5283,"and to our baby?"],[5289,5405,"Hey, hey, hey."],[5405,5490,"It's all right,"],[5490,5605,"I'm here, okay?"],[5674,5810,"I'll take care of you"],[5810,5934,"for the rest of your life."],[5985,6087,"Don't be afraid."],[6087,6154,"Okay."],[6369,6578,"The doctor said your baby's fine."],[6669,6798,"Disappointed, aren't you?"],[6810,7005,"You won't stop until she is destroyed."],[7030,7225,"If she hadn't come with me first,"],[7225,7377,"I wouldn't have gone this far."],[7465,7574,"Mia,"],[7574,7841,"you still think I posted that story?"],[7877,8081,"I swear on my baby, I didn't."],[8201,8291,"Careful,"],[8291,8438,"what's coming for you"],[8438,8621,"could end up failing your baby."],[8685,8758,"Mia,"],[8758,8870,"watch your mouth."],[8922,9102,"Whatever happens between you two."],[9102,9262,"Don't drag the baby into it."],[9262,9354,"I'm warning you."],[9376,9486,"Shh."]],"32":[[29,136,"Shh."],[175,483,"It was Chloe! She used me."],[483,638,"I was just her pawn."],[770,914,"No, it's fake."],[914,1082,"The recording is fake."],[1111,1266,"Vivian must have tampered it"],[1266,1374,"to frame me."],[1399,1523,"Mia, how could you?"],[1606,1815,"I processed the recording myself."],[1820,2027,"And that's not Vivian's voice."],[2032,2203,"So, why are you saying it was her?"],[2417,2664,"Chloe, remember this."],[2737,2892,"This is just the beginning."],[2932,3176,"If you try any of your tricks on me again,"],[3201,3316,"I won't hold back."],[3720,3988,"Jason, you have to believe me."],[3992,4197,"You know how much Mia hates me."],[4200,4457,"She wants to ruin me and our baby."],[4457,4549,"Trust me."],[4669,4799,"I do. I-"],[4868,4961,"Always trust you."],[6142,6227,"Mia,"],[6240,6489,"I heard you got fired from the station."],[6681,6788,"Wow, sister,"],[6788,6941,"you really care about me."]],"33":[[11,188,"Don't flatter yourself,"],[255,463,"and stop calling me sister."],[507,695,"This is my house."],[747,1024,"I'm the real Jenkin's daughter."],[1056,1187,"And you're just"],[1259,1368,"a murderer's kid."],[1519,1628,"Murderer?"],[1771,2032,"You should know better than anyone."],[2060,2247,"If she hadn't stepped in"],[2287,2427,"to protect you,"],[2455,2642,"she would have never killed that guy"],[2642,2807,"accidentally."],[2807,2976,"Mia, you're just an outsider"],[2976,3063,"in this house."],[3063,3219,"Don't forget your place."],[3410,3598,"I heard the loudest someone barks,"],[3598,3740,"the guiltier they are."],[3767,3992,"You dare to insult me?"],[4035,4184,"I'll teach you a lesson."],[4295,4424,"What are you doing?"],[4444,4542,"Emma,"],[4562,4661,"I am back."],[4771,4898,"Emma, what the hell?"],[4898,5051,"Why did you push me?"],[5120,5231,"I didn't."]],"34":[[96,221,"I didn't."],[253,390,"She started it."],[390,603,"She insulted me first."],[704,782,"Emma."],[782,975,"I saw everything."],[1036,1244,"You should learn your limits."],[1267,1408,"No matter what,"],[1493,1740,"Mia always will be your sister."],[1828,1928,"Come on."],[2271,2520,"Why Jason didn't come with you?"],[2632,2732,"Jason?"],[2872,2956,"Please,"],[3053,3216,"he can't stand her."],[3248,3396,"He has already got a new lover."],[3476,3720,"There is no way he would come back with her."],[3837,3955,"Don't be cruel,"],[4015,4080,"Emma."],[4080,4376,"Your sister had it hard with her own."],[4421,4511,"You're the one"],[4511,4819,"who's been spoiled with love and comfort."],[4864,5011,"Isn't that enough?"],[5066,5116,"Mom,"],[5116,5311,"I've already paid people off at"],[5311,5407,"Dawson Group."],[5483,5655,"I'm going to be his secretary."],[5715,6036,"Give me three months and I'll have him."]],"35":[[45,95,"Mom,"],[95,290,"I've already paid people off at"],[290,385,"Dawson Group."],[462,633,"I'm going to be his secretary."],[694,1014,"Give me three months and I'll have him."],[1166,1309,"Oh, really?"],[1373,1566,"Let me save you the trouble."],[1601,1838,"He's not someone you can win over."],[1961,2042,"Oh,"],[2042,2288,"now you think you are controlling everything?"],[2322,2522,"Once I'm getting him,"],[2522,2681,"once I'm his woman,"],[2761,2932,"I might even throw you a bone,"],[3053,3233,"just because we're sisters."],[3333,3641,"Good luck with that."],[3780,3853,"You-"],[3910,3983,"Enough."],[3983,4074,"Both of you."],[4177,4361,"Let's go to eat some fruits."],[4539,4698,"Here's some mangoes."],[4698,4764,"Emma,"],[4764,4873,"try one."],[4889,4968,"Mia,"],[4968,5141,"why aren't you eating?"],[5218,5318,"Mango,"],[5318,5513,"but I'm allergic."],[5608,5694,"Mia,"],[5805,5925,"try more."],[6466,6558,"Thanks, Mom."],[6685,6861,"You're welcome, sweetheart."],[6878,7060,"It's so good."],[7060,7242,"Emma, eats more."]],"36":[[338,422,"You're back."],[422,555,"Thought you'd be out all night."],[1074,1157,"What's wrong?"],[1196,1291,"Did you eat mango?"],[1983,2045,"From the first day"],[2045,2218,"I saw you wearing this earring."],[2242,2382,"You've never taken it off."],[2455,2574,"Any story behind it?"],[2711,2791,"That was"],[2834,2917,"nothing special, someone"],[2917,2999,"just gave it to me."],[3211,3291,"A woman?"],[3426,3570,"Why, jealous?"],[3700,3927,"Please, I don't do jealous."],[3947,4062,"Well, that's boring."],[4115,4247,"The day you get jealous,"],[4267,4382,"I'll tell you the story behind it."]],"37":[[362,650,"Oh, this place is too small."],[650,777,"Yeah, it is."],[949,1052,"Well,"],[1052,1249,"isn't this a coincidence?"],[1281,1429,"Sis, you're eating here too?"],[1498,1578,"Mom."],[1633,1878,"This Sunday is Emma's birthday,"],[1960,2262,"so we just checking out venues for her party."],[2337,2537,"Alright, Mom."],[2605,2846,"Doesn't sis have the same birthday?"],[2909,3133,"Why don't we just celebrate together?"],[3138,3333,"I really want to celebrate with her."],[3341,3421,"Fine."],[3518,3673,"But you know the rumors."],[3750,3870,"People said"],[3937,4145,"the treatment between you two"],[4145,4397,"caused Emma a lot of pain."],[4461,4678,"Outsiders even claim"],[4718,4929,"that we mistreated you"],[4933,5193,"because you are not our born daughter."],[5238,5325,"So?"],[5410,5689,"This time, you will come in for Emma's party."],[5729,6101,"And you will play part of loving sister."],[6106,6286,"That's what you owe Emma,"],[6309,6678,"and that's what you owe this family."],[6761,6878,"Alright, I'll be there."],[6950,7097,"Good, let's go."],[8206,8313,"I was waiting for you outside."],[8313,8433,"Why'd you walk in without me?"],[8615,8686,"Hey."],[8692,8862,"You seem upset. What's wrong?"]],"38":[[30,85,"Hey."],[85,265,"You seem upset. What's wrong?"],[290,392,"No, nothing."],[427,512,"Well..."],[562,702,"Your birthday's on Sunday,"],[705,842,"how are you planning on celebrating?"],[885,1101,"I have to go back to the Jenkins'."],[1149,1401,"Emma and I are celebrating together."],[1433,1513,"What?"],[1561,1730,"After everything they put you through,"],[1745,1858,"you're agreeing to that?"],[1925,2117,"They may treat me badly now but,"],[2133,2322,"they raised me for 20 years."],[2485,2677,"Fine, let's eat."],[2809,3061,"Emma, which other place do you want to check out?"],[3061,3247,"Picks as many as you want"],[3247,3413,"until you are satisfied."],[3421,3550,"Thanks, Mom."],[3636,3905,"Oh no, I forgot my purse."],[3905,4025,"I need to go get it."],[4025,4202,"Alright, honey."],[4589,4748,"What the hell is that guy?"],[4748,4949,"That's definitely not Jason."],[4949,5306,"No way. Mia, are you cheating?"],[5350,5433,"Don't blame me"],[5433,5570,"if the truth comes out."],[6179,6346,"Mia, where are you?"],[6351,6466,"Who are you with?"]],"39":[[0,166,"Mia, where are you?"],[171,286,"Who are you with?"],[340,535,"Out for lunch with my boyfriend."],[632,759,"Why? Mr. Ford?"],[819,987,"Everyone knows you're my wife,"],[1004,1271,"and you sneaking around with some guy?"],[1282,1503,"Don't you care it will affect my image?"],[1591,1656,"Oh, please."],[1656,1826,"When you ran off with your side piece,"],[1826,1986,"did you care about me?"],[2063,2168,"We're not married anymore."],[2168,2295,"You can't control my life."],[2707,2831,"Did you like that?"],[2956,3034,"Boyfriend."],[3143,3228,"I like that word."],[4015,4210,"So she's the one texting Jason."],[4330,4445,"Son of a bitch!"],[4445,4502,"Jason,"],[4547,4636,"what's wrong?"],[4636,4848,"Why are you so mad all of a sudden?"],[4899,5148,"Chloe, what are you hiding from me?"],[5196,5388,"Jason, what?"],[5428,5628,"Where is this even coming from?"]],"40":[[78,261,"Ah, you mean that recording."],[298,412,"Mia already told you"],[412,542,"it had nothing to do with me."],[542,694,"Don't lie to me."],[727,910,"You've hated her from day one."],[922,1027,"You're the one who told me"],[1027,1122,"she couldn't stand me."],[1151,1271,"That's why I left her."],[1302,1386,"But now,"],[1503,1594,"tell me the truth."],[1686,1918,"Jason, I love you."],[1961,2198,"How could you even think I'd do that."],[2198,2251,"Ow!"],[2439,2585,"Jason."],[2585,2777,"Have you forgotten everything?"],[2834,3031,"The years that we struggle,"],[3063,3303,"the pain that we went through for this baby..."],[3386,3550,"Even if you don't want me,"],[3586,3813,"don't tell me you don't want our baby."],[4034,4114,"Stand up."],[4517,4597,"Jason."],[4654,4818,"I'll do whatever you want."],[4866,5126,"I'll never do anything to make you sad again."],[5206,5418,"Please don't be mad at me."],[5478,5550,"You're right."],[5550,5697,"I shouldn't have taken my anger"],[5697,5859,"toward Mia on you, but..."],[6026,6194,"She's the one who's cheating on me."],[6317,6503,"I have to know who that man is."],[6583,6861,"Why do you suddenly care about Mia so much?"],[6946,7098,"Don't tell me you still love her."]],"41":[[437,556,"Of course not, okay?"],[556,666,"Don't overthink it."],[804,924,"I will go get you some water."],[2677,2849,"Chloe again."],[2992,3098,"Seriously?"],[3098,3416,"Do you honestly think that somebody like me"],[3416,3633,"would waste time on somebody like you?"],[3688,3777,"Please."],[3805,3915,"Miss Jenkins,"],[3915,4164,"you and I share the same enemy."],[4320,4409,"You mean Mia?"],[4416,4559,"Exactly."],[4559,4662,"Don't you want to see her"],[4662,4844,"completely humiliated?"],[4896,5035,"Jason's cold attitude is"],[5035,5196,"already enough to break her."],[5260,5417,"But together,"],[5485,5789,"we can make her crumble in front of everyone."],[5857,6101,"My birthday party is in a couple of days."],[6104,6261,"Mia will be there."],[6304,6401,"Bring Jason."],[6473,6659,"Let's make sure she'll be humiliated"],[6659,6833,"in front of everybody."],[7360,7489,"Here's your water."]],"42":[[306,468,"Here's your water."],[585,705,"Thank you, Jason."],[809,932,"Don't waste another second"],[932,1074,"being angry at Mia."],[1094,1226,"She's not worth it."],[1321,1408,"By the way,"],[1408,1624,"there's a birthday party coming up."],[1633,1770,"Would you like to come with me?"],[1918,1996,"Alright."],[2457,2579,"Mr. Dawson,"],[2579,2789,"here are the government approved contractors."],[2789,2894,"Please take a look."],[3109,3209,"Anderson Group,"],[3353,3455,"Smith Group,"],[3506,3613,"Ford Group."],[3937,4017,"Go with Ford."],[4094,4174,"But sir,"],[4229,4346,"the Smith's and Anderson's bids"],[4346,4469,"and track records are stronger."],[4504,4652,"They out class Ford in every way."],[4698,4833,"Ford doesn't cut corners."],[4853,5021,"I don't play favorites, I play fair."],[5050,5110,"Proceed."],[5110,5210,"Yes, sir."],[5385,5453,"Hey!"]],"43":[[121,201,"Hey!"],[245,305,"Miss,"],[305,469,"not everyone gets to stroll in"],[469,608,"the CEO's office."],[637,775,"Keep giving me the attitude,"],[775,897,"and when I'm Mrs. Dawson,"],[897,1086,"you'll be the first one fired."],[1209,1329,"Mr. Dawson."],[1441,1521,"Emma."],[1541,1741,"Oh, so you do remember me."],[2002,2120,"Thomas, give us a minute."],[2120,2265,"Sure, boss."],[2629,2766,"What brings you here?"],[2834,3008,"I'm having a big birthday party"],[3008,3203,"at the Golden Top Hotel tomorrow."],[3203,3378,"I would love for you to come."],[4205,4279,"Alright,"],[4279,4369,"I'll be there."],[4441,4521,"Really?"],[4629,4786,"That's perfect."],[4866,4948,"Anything else?"],[4948,5098,"If not, you can head out."],[5170,5268,"Nothing else."],[5268,5397,"Thank you, Mr. Dawson."],[5622,5869,"Tomorrow is my birthday party and"],[5874,6066,"Mr. Dawson will be there."],[6117,6311,"You'll see what a true luxury party"],[6311,6386,"looks like."],[6504,6725,"Wait, Mr. Dawson's actually coming?"],[6725,6886,"Of course."],[6886,7142,"But he never goes to the parties like this."],[7142,7280,"He must be into you."],[7280,7397,"Obviously."],[7492,7749,"This birthday party is my stage."],[7781,8006,"Henry Dawson will be mine, and Mia"],[8086,8321,"won't even get a chance to shine."]],"44":[[488,548,"Mia,"],[548,637,"get over here."],[702,825,"Help me out."],[1026,1281,"Which of this looks the best on me?"],[1326,1448,"How about this one?"],[1574,1654,"And,"],[1735,1946,"what about this one?"],[2040,2193,"Mom actually got it for you."],[2193,2275,"You have to wear it."],[2459,2579,"It's fine. I'll wear it."],[2887,3079,"Mom only got it because"],[3111,3324,"Henry Dawson's coming tonight."],[3420,3585,"She didn't want you showing up in"],[3585,3783,"something cheap and..."],[3883,4007,"embarrassing the family."],[4164,4344,"Henry Dawson's coming?"],[4384,4484,"Of course he's coming."],[4647,4728,"Um,"],[4899,5031,"guess you didn't know."],[5155,5340,"He's totally into me."],[5575,5680,"Really?"],[5703,5887,"Funny, I never noticed."],[5962,6197,"The Henry Dawson you're talking about"],[6249,6429,"doesn't seem like the one I know."],[6514,6594,"Mia,"],[6594,6813,"you've only interviewed him once."],[6858,7013,"You think you know anything about him?"],[7098,7213,"Are you guys ready?"]],"45":[[40,155,"Are you guys ready?"],[211,432,"Yes, Mom. I'm all set."],[462,542,"Great."],[542,610,"Mom."],[758,884,"Oh."],[884,990,"Seriously?"],[1074,1222,"We are running out of time."],[1234,1391,"And you are still not dressed?"],[1571,1663,"Hurry up,"],[1711,1944,"and try to not ruin anything"],[1944,2095,"while you're on it."],[2172,2307,"Let's go, Emma."],[2847,3149,"Now, let's welcome today's birthday girl,"],[3151,3334,"Emma Jenkins!"],[3455,3803,"Wow, Miss Jenkins looks incredible today."],[3815,4090,"For real, so pretty."],[4416,4576,"Who is that?"],[4576,4746,"She's gorgeous."]],"46":[[0,256,"Wow, she's like stunning."],[280,418,"So elegant."],[1229,1371,"Emma, why is she wearing that"],[1371,1516,"old dress you didn't want?"],[1528,1668,"Doesn't she feel embarrassed?"],[1785,2028,"My parents don't acknowledge her anymore,"],[2105,2320,"and she just won't leave our house."],[2380,2480,"So shameless."],[2584,2684,"Wait,"],[2764,2941,"isn't that the Queen's necklace?"],[2961,3193,"The moon eye, the only one in the world?"],[3276,3324,"Yeah,"],[3324,3596,"that emerald's gotta be at least 60 carats."],[3668,3920,"And that thing's worth like $20 million."],[4097,4272,"No way she could afford this."]],"47":[[61,140,"Yeah,"],[140,365,"it can't be the real one, right?"],[417,593,"Because I heard that the"],[593,752,"Queen's necklace was just designed"],[752,825,"for the princess"],[825,914,"by Miss M,"],[969,1094,"the jewelry master."],[1126,1261,"It's gotta be a knockoff,"],[1286,1421,"and she's just wearing that."],[1498,1583,"It's fake."],[1583,1685,"100% fake."],[1685,1775,"Yeah."],[1775,1941,"It's kinda laughable."],[2017,2130,"Mia,"],[2130,2308,"help me grab a glass of wine,"],[2308,2382,"will you?"],[2494,2574,"Sure."],[2726,2977,"So what if she is all about showing off."],[3066,3329,"In front of me, she should act like a puppy,"],[3329,3538,"Of course. -doing whatever I say."],[4122,4202,"Mia,"],[4300,4426,"my shoes are dirty."],[4537,4706,"Will you clean them for me?"],[5342,5422,"Ah!"],[5593,5797,"What are you doing?"],[5869,5949,"Mia Jenkins,"],[5949,6194,"do you have any idea how much they cost?"],[6194,6409,"They are 100 grand."],[6466,6701,"You have any idea what you're doing?"],[6805,6996,"I'm just offering you a drink."],[7098,7367,"Emma, she's insane."],[7402,7607,"She's gone way too far."],[7896,8051,"Mia, stop right there."]],"48":[[63,260,"She actually dares to humiliate you"],[260,388,"at your own birthday?"],[460,612,"She should apologize."],[815,984,"Emma, you really want to test me?"],[1036,1242,"I could make you look even worse,"],[1242,1339,"if you dare."],[1339,1436,"You little-"],[2409,2657,"Let me introduce you to everyone."],[2677,2917,"This is my new sister, Chloe."],[2969,3096,"And her boyfriend?"],[3096,3314,"He is the heir to the Ford family."],[3314,3456,"Jason Ford."],[3470,3688,"Wait, she's Mrs. Ford."],[3705,3842,"Mrs. Ford,"],[3842,3940,"nice to meet you."],[3940,4089,"We work with the Ford family."],[4089,4200,"By the way,"],[4200,4402,"how far along are you? Mrs. Ford?"],[4402,4537,"Almost 3 months."],[4614,4758,"It's so early."],[4774,4914,"Gotta be careful."],[4978,5253,"Everyone will have their eyes on Mrs. Ford."],[5592,5699,"My boyfriend's here."],[6664,6756,"Chloe,"],[6756,6961,"why didn't you tell me Mia would be here?"],[6961,7082,"Jason."],[7137,7240,"Hi, Jason."],[7308,7477,"Today's a special day."],[7477,7632,"I've got an announcement."],[7672,7929,"My mom is going to adopt Chloe."]],"49":[[0,355,"Okay, I've got something I need to announce."],[443,652,"This is my best friend, Chloe."],[752,932,"And on this special day,"],[1004,1084,"Chloe..."],[1187,1331,"The Jenkins family"],[1331,1564,"is officially adopting Chloe."],[1651,1776,"From now on,"],[1843,2115,"Chloe is part of the Jenkins family."],[2215,2504,"Isn't that woman who stole Mia's husband?"],[2699,2839,"How can you possibly"],[2839,2979,"to make her my daughter?"],[2991,3116,"This is insane."],[3383,3576,"There are so many people watching."],[3628,3755,"Please say yes."],[3795,3940,"This is my birthday wish."],[3955,4192,"After, you can ask me whatever or anything."],[4704,4784,"Mom,"],[4796,4918,"when you didn't even know"],[4918,5060,"I wasn't your real daughter,"],[5080,5228,"we were so close."],[5263,5410,"Do you really not feel anything"],[5410,5500,"for me now?"],[5675,5817,"You're seriously going to"],[5817,5927,"make the woman who hurt me"],[5927,6016,"your daughter?"]],"50":[[138,333,"I am your real daughter."],[485,565,"Well,"],[682,980,"Chloe does have good connection with us,"],[1009,1224,"so we decided to adopt her"],[1224,1369,"as our daughter."],[1449,1698,"I can't believe you're being this cold."],[1890,1973,"Thanks, Mom."],[2193,2267,"Wait,"],[2267,2477,"don't you think this is too much?"],[2509,2625,"What's the problem?"],[2717,2869,"Are you happy now? Sister."],[3601,3742,"Yeah, seriously."],[3773,3970,"She'd rather pick a homewrecker"],[3970,4202,"as her daughter than take you in."],[4277,4534,"She obviously doesn't care about you anymore."],[4741,4821,"Chloe,"],[4873,4973,"this is your sister."],[5065,5330,"Sister, from now on, we are family."]],"51":[[0,250,"Happy birthday to you."],[250,510,"Happy birthday to you."],[522,799,"Happy birthday to you."],[839,1181,"Happy birthday, dear Emma."],[1181,1451,"Happy birthday to you."],[2063,2160,"Hi, sister."],[2223,2339,"The Jenkins family"],[2339,2480,"just made me their daughter."],[2495,2647,"You're not upset, right?"],[2904,3126,"Please, cut the innocent act."],[3126,3239,"It's gross."],[3400,3651,"Mia, you don't understand."],[3695,3847,"I grew up with nothing."],[3920,4107,"Abused, beaten,"],[4152,4356,"not a single day of peace."],[4419,4619,"You were the only light in my life."],[4664,4891,"You dragged me out of that chaos,"],[4936,5036,"and you told me:"],[5108,5303,"\"don't worry, I'll protect you.\""],[5487,5652,"And now, this is how you repay me?"],[5772,5927,"After everything I did for you,"],[6036,6184,"you sabotaged my life,"],[6316,6543,"you destroyed my relationship with Jason..."],[6603,6756,"You're stealing from me"],[6796,6935,"with your dirty tricks."],[6971,7052,"Why?"],[7100,7263,"Because I was jealous."]],"52":[[10,180,"Why is that you two always get to be"],[180,293,"the perfect couple"],[301,465,"that everyone adores?"],[510,769,"While I'm just stuck in some filthy slum"],[769,885,"with nothing?"],[920,1049,"Every single day,"],[1101,1217,"it eats me."],[1301,1414,"I'm so jealous."],[1414,1578,"It's driving me insane."],[1770,1850,"Chloe,"],[2005,2273,"everyone can choose how to live their life."],[2465,2706,"Yes, your past was awful, but"],[2776,2992,"so many people have it worse."],[3066,3193,"And they don't go around"],[3233,3493,"betraying the ones who helped them."],[3745,3897,"I know nothing I'm saying"],[4002,4165,"is going to get through to you."],[4222,4300,"But,"],[4389,4566,"I don't regret ever helping you."],[4681,4761,"Losing me,"],[4838,4944,"that's your loss."],[5342,5543,"You will never get rid of me,"],[5543,5653,"not ever."],[6141,6246,"My baby..."],[6246,6401,"Why'd you push me, Mia?"],[6526,6668,"Chloe! Are you okay?"],[6668,6750,"Jason."]],"53":[[38,205,"Chloe! Are you okay?"],[225,323,"Jason."],[333,485,"I'm taking you to the hospital."],[485,593,"I'm fine."],[603,719,"I just don't get why"],[719,802,"Mia pushed me."],[814,917,"She still can't stand"],[917,1094,"the fact that we're having a baby."],[1114,1237,"Mia Jenkins,"],[1317,1481,"I was about to defend you, but"],[1529,1761,"turns out you're so cruel to Chloe."],[1873,2162,"How does a twisted woman do this?"],[2233,2342,"No wonder"],[2342,2509,"you're not my real daughter."],[2509,2729,"Chloe just became part of this family."],[2729,2921,"How could you treat her like that?"],[2957,3166,"Mia, apologize to Chloe."],[3166,3269,"Right now!"],[3269,3565,"I'm not apologizing for something I didn't do."],[3565,3717,"If you don't apologize,"],[3717,3957,"you will be no longer my daughter."]],"54":[[198,363,"From this moment on,"],[373,569,"I'm done with the Jenkins family."],[662,742,"What?"],[814,977,"What are you talking about?"],[1077,1262,"I'm grateful that you took me in,"],[1271,1384,"that you raised me,"],[1426,1569,"that you taught me how to live."],[1653,1810,"This is where it ends."],[1861,2022,"I'm not ungrateful."],[2133,2260,"I just know,"],[2260,2379,"this is the only ending"],[2379,2525,"that makes sense."],[2545,2629,"For me,"],[2649,2732,"for you,"],[2777,2889,"for the Jenkins name."],[3997,4105,"What's going on in here?"]],"55":[[468,577,"What's going on in here?"],[765,949,"Mr. Dawson."],[987,1154,"You finally made it."],[1154,1301,"I've been waiting for you."],[1406,1493,"Oh my,"],[1506,1634,"I didn't know Mr. Dawson"],[1634,1785,"was coming today."],[1785,1891,"I'm so sorry"],[1891,2122,"not welcoming you properly."],[2213,2354,"Mrs. Jenkins,"],[2354,2435,"just call me Henry."],[2497,2607,"Sure, Henry."],[3224,3405,"Mom, I told you,"],[3405,3536,"he must like me."],[3568,3705,"Otherwise,"],[3705,3893,"Why would he be so polite to you?"],[3925,4014,"Emma,"],[4014,4352,"why don't you keep Mr. Dawson company?"],[5884,6029,"It's like I missed out on all the drama."],[6177,6427,"It's all my daughter's fault, Mr. Dawson."],[6427,6556,"Please forgive us."],[6621,6745,"What are you still doing here?"],[6745,6868,"Get out of the way."]],"56":[[874,957,"Mrs. Jenkins,"],[957,1079,"forgive me for intruding, but..."],[1174,1269,"What just happened here?"],[1301,1514,"Mr. Dawson, let me explain."],[1606,1726,"Mia is upset"],[1726,1933,"that Chloe became part of our family"],[1933,2050,"as our sister."],[2073,2212,"She got angry,"],[2212,2397,"and actually pushed Chloe"],[2445,2574,"who's pregnant."],[2577,2747,"She doesn't even consider"],[2747,2826,"who she is."],[2857,3078,"She's just an adopted daughter."],[3181,3291,"Is that true?"],[3291,3363,"Yes."],[3461,3733,"Jason and Chloe are in love,"],[3822,4032,"and Mia is trying to get with Jason"],[4032,4117,"this whole time."],[4366,4486,"She's my girlfriend."],[4537,4614,"There's no way"],[4614,4774,"she'd ever try to get with another guy."],[4821,4901,"What?"]],"57":[[0,80,"What?"],[160,315,"Mr. Dawson."],[353,490,"How could Mia Jenkins"],[490,590,"be your girlfriend?"],[638,719,"What?"],[774,937,"You don't think we make a good match?"],[1144,1307,"Mr. Dawson,"],[1307,1476,"don't let Mia fool you."],[1499,1631,"She's married."],[1631,1760,"And she's been messing around"],[1760,1811,"with other guys."],[1811,1903,"I've seen it myself."],[1903,2043,"She's just a mistress."],[2263,2344,"Oh."],[2565,2677,"She's a married woman."],[2677,2747,"So,"],[2819,2899,"who's her husband?"],[3672,3796,"It wouldn't be this Mr. Ford"],[3796,3892,"sitting here, would it?"],[4039,4130,"Yes,"],[4142,4469,"Mia's husband is Mr. Ford here."],[4539,4657,"But just now,"],[4683,4824,"you called Mia a mistress."],[4844,4951,"Seems like"],[4991,5175,"the real mistress is someone else."],[5320,5607,"No, Mr. Dawson, it's not like that."],[5663,5799,"In a relationship,"],[5830,5982,"the person who isn't in love"],[5982,6067,"is the mistress."],[6067,6254,"Mia just can't stand it."],[6287,6446,"Chloe took Jason's love,"],[6446,6566,"so she hurt her."],[7112,7247,"Did you actually see"],[7307,7420,"Mia push Chloe?"],[7522,7707,"I saw it with my own eyes."],[7779,7964,"They all did."]],"58":[[120,210,"Is that so?"],[503,583,"I swear."],[655,804,"If I'm lying, may my"],[804,957,"whole family go bankrupt"],[957,1084,"and I'll be poor forever."],[1139,1227,"Well,"],[1227,1496,"since Miss Jenkins here is so sincere,"],[1528,1700,"I simply can't ignore this."],[1771,1841,"Thomas."],[1841,1911,"Yes, sir."],[1988,2085,"Give me the footage"],[2085,2180,"from the cameras in here."],[2212,2303,"Right away, sir."],[2584,2655,"Mr. Dawson,"],[2655,2792,"you probably don't know,"],[2792,3016,"but this is private event hall."],[3024,3216,"There are no security cameras."],[3288,3491,"Did I say regular security cameras?"],[3500,3598,"Thomas,"],[3598,3808,"pull the footage from the Eagle Eye system."],[3868,3960,"Okay, sir."],[4114,4182,"Mom,"],[4182,4362,"what's the Eagle Eye system?"],[4446,4671,"It's the most advanced surveillance system."],[4671,4983,"Basically, it can track without any cameras."],[5035,5295,"No limit, anywhere, anytime."],[5301,5507,"It is full HD footage,"],[5507,5734,"and it can track anything."]],"59":[[293,495,"Not a single day of peace."],[869,1024,"Losing me,"],[1024,1176,"that's your loss."],[1736,1980,"...get rid of me, not ever."],[2449,2554,"My baby..."],[2554,2777,"Why'd you push me, Mia?"],[3276,3420,"The truth is right there."],[3508,3697,"Does anyone still got something to say?"],[3863,3985,"And Jason,"],[4004,4124,"your mistress?"],[4376,4576,"What a performance."],[4607,4716,"Jason, please."],[4719,4843,"Please believe me."],[4843,4971,"This is not how it happened."]],"60":[[0,220,"You humiliated me in front of everyone."],[412,672,"I just wanted to be with you openly."],[700,927,"And I wanted you to leave her."],[927,1051,"I wanted our baby"],[1051,1176,"to be born as the heir"],[1176,1299,"of the Ford family."],[1379,1451,"Jason,"],[1473,1604,"I did all this just"],[1604,1736,"because I love you."],[1751,1908,"And I love our baby."],[1991,2103,"Funny thing."],[2135,2243,"Jason and I"],[2243,2455,"never got the marriage certification."],[2487,2664,"We were never legally married."],[2824,2959,"You're joking, right?"],[3019,3194,"Some men don't give you title"],[3194,3348,"not because they can't,"],[3348,3460,"but because"],[3460,3631,"they just don't want to."],[3692,3900,"Jason, tell me she's lying."],[3908,4019,"She's lying, right?"],[4019,4162,"Step aside."],[4621,4709,"Mia,"],[4814,4903,"we grew up together."],[4971,5095,"All these years,"],[5118,5241,"it's always been you."]],"61":[[26,141,"I was blinded before."],[248,321,"Tricked."],[360,500,"I trusted the wrong person."],[500,628,"I was deceived by her."],[700,824,"But now I can see the truth."],[854,987,"You're the one. You always were."],[1057,1204,"Mia, please."],[1216,1363,"Give me one more chance."],[1459,1621,"Get your filthy hands off of her!"],[1649,1788,"You're not even worthy"],[1803,1935,"to touch her."],[2153,2252,"Don't, Jason."],[2252,2444,"Don't go against Mr. Dawson."],[2474,2552,"Don't forget,"],[2562,2711,"the Ford family still needs him."],[2711,2857,"Shut up, Chloe."],[2906,3041,"Oh, I almost forgot."],[3058,3131,"Thomas,"],[3194,3365,"cancel Ford Construction's contract."],[3445,3528,"What?"],[3528,3680,"No, no, no, Mr. Dawson."],[3680,3815,"You can't do that."],[3815,3930,"If you're stupid enough to be swayed"],[3930,4077,"by some woman's lies,"],[4135,4227,"then you're not someone I can do"],[4227,4312,"business with."],[4312,4461,"-Sir. -I can't be with a partner"],[4461,4570,"that I can't trust."],[4570,4743,"Please, Mr. Dawson."],[4744,4908,"My family has invested"],[4909,5055,"everything in this project."],[5055,5235,"The Fords will go bankrupt."],[5328,5450,"And you think I care?"]],"62":[[113,208,"Henry,"],[291,445,"the Ford family has always"],[445,588,"treated me with kindness."],[830,1021,"Mia,"],[1041,1132,"are you asking me to"],[1132,1296,"show Jason mercy?"],[1353,1451,"His parents..."],[1473,1593,"they've treated me like their"],[1593,1706,"own daughter"],[1716,1796,"for years."],[1806,1975,"I can't stand by"],[1975,2095,"and watch them lose everything"],[2108,2242,"in their old age."],[2272,2344,"Fine,"],[2417,2529,"then here is my condition."],[2607,2696,"As of now,"],[2696,2859,"Jason is stripped of his heir status."],[2859,3011,"he doesn't get a single cent."],[3011,3129,"This is the only way"],[3129,3400,"the Ford family can avoid bankruptcy."],[3440,3498,"Jason,"],[3520,3593,"it's over."],[3593,3785,"We're broke."],[4029,4137,"Chole, wake up."],[4192,4356,"Whether it's the Ford's fortune,"],[4356,4509,"or the title of Mrs. Ford,"],[4509,4709,"you are never getting either of them."],[4744,4896,"You say you love Jason,"],[4953,5121,"that you'd do anything for him."],[5188,5405,"Well then, I hope love is enough"],[5405,5545,"to make you start from nothing."],[5677,5769,"Thomas,"],[5792,5947,"kick them out."],[6184,6316,"Mr. Dawson,"],[6316,6401,"why her?"],[6401,6509,"She has no family,"],[6509,6628,"no power,"],[6628,6721,"no status."],[6741,6865,"Why does she have everything"],[6865,6988,"but not me!"],[7025,7112,"Exactly."],[7145,7365,"She wears knock-offs for god's sake."],[7365,7515,"How is she even worthy of you?"],[7527,7625,"Knock-offs?"],[7741,7854,"You mean this one?"],[7854,7934,"Yeah."],[7991,8269,"That's the Queen's Moon Eye necklace."],[8298,8475,"The only one of its kind."],[8543,8722,"Miss M designed it herself"],[8722,8850,"for the royalty."],[8912,9084,"There is no way hers is real."]],"63":[[265,345,"Hmm."],[432,573,"Shows how little you know."],[585,727,"This isn't a fake."],[779,932,"And she's not just Mia."],[992,1109,"She is Miss M,"],[1109,1231,"the designer you just mentioned."],[1232,1312,"What?"],[1404,1548,"This is impossible,"],[1593,1780,"Miss M's pieces, they"],[1800,2041,"all come with a private hallmark."],[2579,2659,"What?"],[2767,2847,"Mia,"],[2944,3211,"when did you even create your own brand?"],[3229,3401,"Ever since I was a kid,"],[3430,3633,"I always wanted to be a jewelry designer."],[3686,3889,"But when your real daughter came back,"],[3893,4089,"you kicked me out of the Jenkins'"],[4125,4304,"design department."],[4304,4489,"So, I decided to try on my own."],[4529,4634,"And turned out,"],[4669,4979,"I didn't need you to succeed."],[5001,5253,"My god, Mia."],[5273,5632,"I never imagined you have this kind of talent."],[5648,5729,"And,"],[5784,6021,"if you end up with Mr. Dawson,"],[6021,6324,"that makes me Henry's mother-in-law."],[6434,6586,"Didn't you already cut ties"],[6586,6683,"as mother and daughter?"],[6698,6811,"Family breaks it,"],[6811,6906,"family fixes it."],[6906,7102,"Man, we can fix it."],[7153,7380,"Emma, apologize to your brother-in-law."],[7425,7514,"I'm sorry."],[7525,7625,"I was just"],[7660,7777,"joking earlier."],[7839,8089,"Emma is a good kid. She's just naive."],[8110,8286,"She's just misled."],[8468,8565,"Naive?"],[8638,8757,"You really believe that?"],[8820,8878,"Fine,"],[8947,9027,"because"],[9039,9150,"I actually brought a little gift here"],[9150,9279,"for everyone tonight."]],"64":[[218,251,"Emma,"],[291,404,"your foster mom accidentally"],[404,473,"killed that man"],[473,577,"because of you."],[582,687,"That's a lie!"],[710,775,"Back then,"],[775,889,"when your foster mom fought back"],[889,1046,"to protect you from those thugs,"],[1056,1234,"she accidentally killed one of them."],[1259,1379,"But you?"],[1409,1578,"You never testified for her in court."],[1578,1770,"And that's what made her a criminal."],[1935,2017,"Oh."],[2017,2137,"That knife she used..."],[2202,2382,"wasn't it you who handed it to her?"],[2402,2482,"What?"],[2557,2637,"Emma,"],[2706,2957,"you're not just ungrateful,"],[3026,3161,"you're a murderer."],[3193,3293,"And why?"],[3378,3650,"Why did you tell us that your foster mother"],[3650,3745,"abused you?"],[3757,4082,"And why did you make me hate Mia"],[4129,4259,"all these years?"],[4259,4446,"Just to cover your lies?"],[4466,4601,"So what if I lied?"],[4673,4766,"You!"],[4853,4984,"Mia stole the life that"],[4984,5125,"was supposed to be mine."],[5125,5263,"I want you to hate her,"],[5276,5415,"to despise her,"],[5450,5582,"to make her pay for"],[5582,5744,"every second of the suffering"],[5744,5882,"that I endure."],[5960,6161,"How could someone like you"],[6214,6321,"be my daughter?"]],"65":[[0,153,"How could someone like you"],[178,305,"be my daughter?"],[477,582,"Why not?"],[794,874,"Yeah,"],[957,1134,"I handed her that knife."],[1297,1406,"So what?"],[1513,1670,"She ruined my life."],[1790,2125,"She made me suffer for 20 years."],[2262,2465,"And you telling me that's wrong?"],[2625,2774,"I am fighting for the life"],[2774,2937,"that should have been mine."],[2992,3086,"For my mother,"],[3198,3313,"for my future."],[3521,3720,"And now I finally have a chance"],[3720,3842,"to have it all back."],[3937,4245,"Now I am where I am belong to be."],[4317,4497,"I am your only daughter."],[4537,4626,"Don't touch me."],[4726,4909,"Mia, I was wrong."],[4918,5093,"I should've never doubted you,"],[5150,5316,"never believe her lies."],[5437,5645,"You've always been the good one."],[5705,5969,"Please forgive me."]],"66":[[106,193,"You know what?"],[286,480,"I may be a TV host now,"],[527,667,"but it was never my dream."],[780,974,"Then why'd you do it?"],[1214,1329,"Because you"],[1329,1593,"always regretted never becoming a TV host."],[1666,1763,"So I thought..."],[1850,1980,"if I got that spot,"],[2043,2173,"maybe you would notice me,"],[2233,2340,"just once."],[2444,2527,"Come home."],[2624,2724,"Forgive the past."],[2754,2951,"Let's be a family again."],[2951,3164,"I will love you like before."],[3393,3480,"Please."],[3640,3720,"No."],[3783,4010,"My ties to the Jenkins family are over."],[4084,4207,"That will never change."],[4300,4381,"Mia."],[4437,4591,"Didm't Emma just swear an oath?"],[4624,4768,"Said that she lied,"],[4784,4894,"then what was it again?"],[4953,5180,"Mr. Dawson, it's all my fault."],[5233,5570,"I fault as a mother. Please spare us."],[5720,5840,"She's your daughter."],[5910,6091,"Deal with the consequences."],[6171,6287,"Jenkins family,"],[6361,6441,"you're done."],[6531,6713,"Please, don't do this."],[6803,6933,"I'm begging you."],[6933,7007,"Please."],[7130,7227,"Bankrupt..."],[7350,7547,"We're completely bankrupt."]],"67":[[18,150,"Mia! Mia!"],[543,637,"Are you okay?"],[729,934,"Look, you don't need to be this upset."],[965,1061,"My sisters..."],[1177,1296,"they're just obsessed with my business"],[1296,1381,"like you said."],[1438,1509,"But"],[1514,1705,"never once have they worried about me."],[1838,1918,"And you,"],[2005,2222,"someone strong and capable..."],[2313,2497,"Fear shouldn't even be in your vocabulary."],[3226,3276,"Damn!"],[3296,3518,"It's fall. The mosquitoes are still this big."],[4137,4280,"Give me back my necklace."],[4506,4589,"What necklace?"],[4647,4788,"You turned my necklace"],[4788,5005,"into that tacky earring."],[5145,5225,"It's hideous."],[5383,5463,"Wait..."],[5642,5755,"So you do remember."],[6096,6176,"Do you love me?"],[6376,6456,"I love you."],[6631,6736,"I've always loved you."],[6855,7020,"What about those \"three rules\" things?"],[7140,7323,"It was for me, not you."],[7432,7664,"I was scared,"],[7764,7851,"scared that"],[7851,8068,"I couldn't control myself and..."],[8123,8311,"Scared that you'd leave me."]],"68":[[173,281,"I'll never leave you."],[465,637,"I'll always be right here, Mia."],[1770,1970,"Seriously, that earring,"],[2013,2190,"put up with it for three years."],[2232,2414,"Take it off. It's ugly."],[2509,2589,"Ugly?"],[2622,2737,"What's ugly about it?"],[2737,2854,"Everything."],[2854,2989,"Take it off!"],[3128,3278,"You think I liked wearing this?"],[3481,3581,"Bet you didn't even know that"],[3581,3642,"I haven't touched"],[3642,3777,"a single mango in 3 years."],[3777,3902,"All because of you."],[4294,4332,"Wait."],[4332,4397,"You didn't even know"],[4397,4521,"I skipped mangoes for you?"]]}