ra,"],[2527,2615,"starting today,"],[2731,2844,"you're the school's new dean."],[3015,3115,"And I want you to root out"],[3115,3203,"every bit of corruption,"],[3203,3261,"every bit,"],[3382,3490,"make no exceptions."],[3666,3787,"Yes, Mr. Conrad."],[3891,3966,"Mr. Conrad,"],[4087,4333,"Mr. Grant wanted me to personally"],[4354,4517,"deliver this invitation to you."],[4617,4700,"Looks like it's time"],[4700,4833,"to wipe out the Crows family"],[4833,4954,"and take back my valley"],[4984,5067,"once and for all."]],"57":[[1013,1142,"It's time Roman finally learned"],[1142,1259,"about my true identity."],[1488,1568,"I'll announce it"],[1622,1776,"at the Crows family banquet."],[2193,2231,"Dad,"],[2310,2381,"what are you doing here?"],[2473,2573,"Came to take you home."],[2660,2736,"I wouldn't miss it."],[2923,2982,"By the way,"],[3119,3232,"a friend of mine gave me this."],[3324,3453,"The Crows family is having a banquet"],[3453,3536,"at their ranch"],[3657,3770,"with their business partners."],[3870,3958,"You should go in my place."],[4617,4658,"Dad,"],[4662,4825,"if this invite was meant for you,"],[4825,5021,"I think it'd be inappropriate"],[5021,5080,"for me to go."],[5105,5209,"I'm getting old."],[5255,5392,"Future is for young people like you."],[5409,5451,"Go."],[5492,5597,"You'll learn something useful."],[5668,5722,"Trust me."],[6973,7148,"Everything's set for tonight, Dad."],[7203,7282,"After our banquet"],[7282,7419,"with our business partners,"],[7453,7565,"we'll finally take down"],[7565,7749,"Yellowstone Ranch once and for all."],[7912,7953,"Make sure"],[7953,8049,"everything is in place,"],[8049,8095,"sonny."],[8224,8287,"You know me."],[8395,8575,"I fucking hate surprises."]],"58":[[367,508,"Here's to you, Mr. Crow."],[538,604,"After today,"],[604,675,"you'll be the heir"],[675,842,"to the biggest ranch in Montana."],[950,1055,"Ain't that the truth?"],[1071,1226,"We're counting on your deals"],[1226,1359,"and the business with your ranch."],[1376,1422,"Gentlemen,"],[1451,1593,"there's no need to flatter me."],[1609,1710,"Who doesn't like money?"],[2193,2323,"Look at this place, Roman."],[2410,2498,"It's so pretty."],[2548,2761,"After we take down Yellowstone Ranch,"],[2811,3011,"we're all gonna be filthy rich."],[3286,3378,"God damn right."],[4158,4312,"Hey, what the fuck?"]],"59":[[0,104,"What the fuck?"],[141,287,"My God, I'm so sorry."],[333,467,"It was an accident, I swear."],[479,638,"Don't touch me, you idiot!"],[684,825,"You're just gonna make it worse."],[905,975,"Who are you?"],[1009,1176,"How'd someone like you get in here?"],[1322,1534,"My dad gave me the invitation."],[1601,1751,"Told me to come here on his behalf."],[1822,1935,"And who's your father?"],[2410,2452,"You."],[2502,2602,"Do any of you know"],[2602,2773,"this clumsy idiot's old man?"],[3353,3574,"This is my family's banquet."],[3595,3695,"Only the richest,"],[3703,3849,"most powerful families"],[3849,3999,"in Montana were invited."],[3999,4079,"Sneaking in here"],[4079,4220,"with your little girlfriend."],[4245,4375,"You think you're clever, don't you?"],[4412,4525,"Well, someone,"],[4546,4671,"run a background check"],[4671,4929,"on this stupid idiot, now!"]],"60":[[187,350,"Mr. Crows, we checked."],[396,538,"His father is a janitor"],[538,713,"at the Yellowstone Maple High."],[950,1046,"A janitor?"],[1092,1334,"A janitor at a high school?"],[1380,1451,"Wow."],[1480,1589,"Oh my God."],[1772,1889,"I guess they really do"],[1889,2027,"just let any pathetic piece"],[2027,2173,"of trash in here, don't they?"],[2227,2373,"Well, looks like I'm gonna have to"],[2373,2464,"discipline those"],[2464,2615,"who work for my family better."],[2673,2744,"Security!"],[3415,3645,"Are you blind or just dumb?"],[3695,3778,"How dare you"],[3778,3953,"let that disgusting parasite"],[3953,4095,"into my family mansion?"],[4166,4250,"But Mr. Crows,"],[4316,4375,"we let them in"],[4375,4479,"because they had an invitation."],[4771,4859,"This invitation"],[4925,5075,"is for the mysterious boss"],[5075,5209,"of the Yellowstone Ranch?"],[5288,5459,"Why does a janitor's son have it?"],[5580,5680,"Drag them outside."],[5705,5830,"Break one leg each"],[5885,6010,"for disrupting my banquet"],[6026,6168,"and ruining my good mood!"],[6202,6293,"No, you can't do this!"],[6293,6427,"We have an invitation."],[6585,6644,"Oops."],[6706,6902,"Not anymore."]],"61":[[204,275,"Mr. Conrad,"],[316,400,"these suits and hats"],[400,492,"were custom made for you."],[538,596,"After all,"],[642,754,"today is your official return"],[754,859,"as the boss of this valley."],[2210,2327,"Has the banquet started yet,"],[2327,2369,"Harrison?"],[2394,2477,"Yes, yes,"],[2477,2598,"and your son has already arrived."],[3224,3370,"Alright, let's go."],[3445,3520,"Can't wait to see"],[3520,3657,"how many people are foolish enough"],[3657,3774,"to follow the Crows family"],[3774,3858,"into their graves."]],"62":[[37,237,"Not anymore."],[1009,1113,"I never expected"],[1113,1247,"the founder of Yellowstone"],[1247,1368,"to be such a coward."],[1434,1584,"Sending in a janitor's son"],[1584,1664,"as tribute"],[1664,1872,"instead of coming to face me himself."],[1922,2010,"Just don't hurt us."],[2052,2156,"If we're not welcome here,"],[2160,2223,"we'll leave."],[2243,2427,"You're on my turf now, boy."],[2485,2623,"You think you can just come in here"],[2669,2794,"and go as you please?"],[2831,2886,"What would your"],[2886,3040,"almighty founder think"],[3073,3224,"if I just killed the both of you"],[3278,3432,"right here, right now?"],[3490,3545,"Get them!"],[3603,3645,"No!"],[3787,3866,"The Crows family"],[3866,3991,"sure has gotten arrogant."],[4767,4921,"Do you have any idea who this is?"]],"63":[[0,137,"Do you have any idea who this is?"],[221,291,"I'll give you a hint."],[362,483,"The last person who messed with him"],[542,654,"was Spencer Lennox."],[784,863,"You know what happened to him,"],[863,900,"don't you?"],[984,1067,"Y'all trying to go down"],[1067,1134,"the same path?"],[1188,1317,"Zach Grant."],[1384,1534,"Your father is the foreman"],[1534,1622,"of Yellowstone."],[1701,1739,"So,"],[1835,1931,"this piece of trash"],[1931,2097,"really is with Yellowstone, huh?"],[2173,2369,"Zach, why are you helping me?"],[2485,2648,"Seems like Roman still doesn't know"],[2648,2811,"his father is the legendary founder"],[2811,2911,"of Yellowstone Ranch."],[2932,3032,"You're holding an invitation"],[3032,3090,"for Yellowstone,"],[3103,3148,"aren't you?"],[3236,3303,"That's a good enough reason"],[3303,3345,"for me."],[3424,3478,"Zach."],[3624,3728,"All my guests here"],[3749,3899,"are rich and powerful,"],[3970,4154,"no less than that crappy"],[4154,4270,"Yellowstone Ranch."],[4312,4383,"So tell me,"],[4546,4604,"why would you send"],[4604,4783,"a janitor's son here, huh?"],[4863,5030,"Are you trying to insult us?"]],"64":[[12,179,"Are you trying to insult us?"],[254,329,"And what if we are?"],[408,458,"Well then,"],[487,617,"I guess you won't mind"],[617,713,"if I have a little fun"],[713,821,"with this gutter trash"],[821,938,"you invited to my house."],[1096,1138,"You!"],[1180,1305,"Get down on the floor"],[1305,1451,"and lick my boots clean,"],[1501,1580,"or else you"],[1618,1701,"and that cupcake"],[1701,1785,"you brought with you"],[1797,1960,"are never going to leave this place."],[1993,2156,"That'll only dirty your boots,"],[2156,2235,"Mr. Crow."],[2235,2402,"I say you break every bone"],[2402,2473,"in his body"],[2502,2590,"and toss him back"],[2590,2811,"to that God damn forsaken ranch"],[2811,2898,"that he came from."],[2932,3061,"You gotta put him in his place."],[3111,3286,"Otherwise who's going to respect us"],[3286,3357,"in the future?"],[3370,3415,"Yeah!"],[3436,3532,"Yeah, good point."],[3645,3745,"Since when did anybody"],[3745,3803,"in this valley"],[3803,3949,"get to touch Yellowstone's men?"]],"65":[[4,79,"You think I don't know"],[116,200,"that your Crows are plotting"],[200,271,"behind our backs?"],[354,496,"What about the rest of you assholes?"],[504,588,"Are you with the Crows?"],[650,696,"Are you?"],[863,963,"Then you better get this."],[1084,1172,"Y'all are snakes,"],[1213,1313,"dreaming of swallowing"],[1313,1418,"an elephant whole."],[1497,1559,"Stupid,"],[1614,1701,"and delusional."],[1743,1835,"I don't give a shit"],[1856,2027,"who he is or who he's with."],[2056,2164,"He's not going to leave here"],[2164,2339,"until he does exactly what I say."],[2552,2627,"What are you doing?"],[2677,2727,"Let me go!"],[2748,2811,"Let her go!"],[2882,2944,"Don't hurt her!"],[3324,3390,"What do you want?"],[3424,3582,"You want to play Yellowstone's hero,"],[3591,3628,"huh?"],[3699,3741,"Fine."],[3807,3903,"I'll give you a chance."],[4963,5234,"Now, kneel like the good boy you are"],[5263,5388,"and eat the whole bowl."],[5447,5547,"Then I'll let her go."],[5626,5714,"Otherwise,"],[5776,5964,"I'm sure my man here won't mind"],[5964,6181,"entertaining a lovely guest."],[6560,6744,"So, Mr. Hero,"],[6806,6902,"what's it gonna be?"]],"66":[[16,158,"Roman, don't listen to him!"],[204,300,"You don't have to do it."],[329,421,"Shut up, bitch!"],[446,592,"You'll regret this, Frank Crows."],[621,709,"Mark my words."],[838,996,"Regret, you said?"],[1030,1113,"I'm a Crows."],[1155,1368,"I've walked this earth for 25 years"],[1368,1522,"and no one has ever made me"],[1522,1601,"regret shit."],[1655,1830,"Now, I'm going to show y'all"],[1830,1914,"what happens"],[1931,2081,"when you mess with my family."],[2185,2227,"You!"],[2281,2477,"My patience is running thin, boy."],[2510,2669,"Are you going to get down on the ground"],[2669,2811,"and eat or not?"],[3294,3336,"Don't."],[3749,3799,"I'll do it."],[4158,4200,"See?"],[4320,4441,"Was that so hard?"],[4475,4517,"Now,"],[4629,4704,"start eating."],[4775,4879,"If you don't finish,"],[4917,5092,"I'm going to shove every last bit of it"],[5092,5184,"down your throat."],[5271,5392,"Take a good look, y'all."],[5430,5530,"This is what happens"],[5530,5676,"when you mess with us Crows."],[5718,5839,"Nobody can save you,"],[5889,6006,"not even the famous"],[6006,6126,"Yellowstone Ranch."]],"67":[[25,221,"It's not my fault your dad's a janitor,"],[221,266,"boy."],[312,396,"If you're mad,"],[412,563,"blame him for being"],[563,713,"such a worthless maggot."],[1017,1280,"Don't talk about my father like that!"],[1868,1951,"I'm warning you."],[2035,2218,"Let her go."],[2719,2769,"It's okay."],[2806,2869,"You're okay."],[2948,2998,"I'm sorry."],[3069,3161,"I should have protected you."],[3299,3370,"Let's get out of here."],[3545,3582,"Hold it"],[3611,3712,"right there."],[3920,3978,"I'm sorry."],[4037,4200,"Did I say you could leave yet?"],[4279,4429,"The fun's just getting started."],[4475,4625,"I'd hate for you to miss it."],[4721,4817,"Break their ankles."],[4875,4963,"All three of them."],[4996,5034,"Yeah."],[5034,5121,"I want to see them"],[5121,5321,"crawl out of this house like roaches."],[5347,5484,"You won't get away with this."],[5530,5576,"Yeah?"],[5622,5676,"Watch me."],[5885,5918,"Stop it!"],[5972,6018,"Frank,"],[6064,6206,"you don't know who he is."],[6264,6352,"He's the son"],[6398,6514,"of Yellowstone's founder,"],[6606,6719,"the boss of Maple Valley"],[6773,6869,"and all Montana."]],"68":[[16,183,"You're telling me that this boy"],[196,266,"is the heir"],[266,400,"to the Yellowstone Ranch?"],[450,521,"That's impossible."],[521,700,"Nobody's seen him for ten years."],[725,842,"No one knows if he's alive."],[867,1026,"How is this little shit his son?"],[1063,1334,"This kid is the son of a janitor"],[1338,1476,"at a local high school."],[1476,1743,"Are you telling me that his father"],[1772,1943,"dominates Yellowstone"],[1943,2068,"and all of Montana?"],[2118,2181,"Exactly."],[2210,2373,"Mr. Conrad's been hiding his identity"],[2373,2444,"for years,"],[2469,2560,"so his son would grow up"],[2560,2644,"humble and kind,"],[2744,2802,"unlike you."],[2857,3023,"Just imagine what Mr. Conrad will do"],[3023,3098,"when he finds out"],[3132,3390,"you humiliated his only son like this."],[3999,4037,"Wait!"],[4095,4183,"Where are y'all going?"],[4208,4237,"Aye!"],[4283,4312,"Aye!"],[4346,4579,"You'd say anything just to save"],[4579,4792,"your precious Yellowstone Ranch,"],[4792,4846,"wouldn't you?"],[4913,4963,"Dad!"],[5334,5505,"You're the son of Harrison,"],[5555,5680,"Yellowstone's foreman?"],[5797,5918,"Tell your father to come"],[5918,6072,"and face me himself."],[6101,6227,"I'm not going to waste my time"],[6227,6293,"with some kid"],[6293,6473,"who's still wet behind his ears."],[6589,6694,"You are awfully impatient,"],[6694,6765,"Mr. Crows."]],"69":[[250,358,"God, that's the foreman."],[437,571,"Why is no one watching the door?"],[1051,1121,"Huh."],[1259,1463,"Ladies and gentlemen,"],[1530,1622,"y'all are aware of"],[1622,1735,"why we're gathered here."],[1818,2081,"For the past ten years,"],[2106,2318,"Yellowstone Ranch has been decaying,"],[2352,2510,"falling apart."],[2577,2627,"It's nothing"],[2627,2798,"but a fucking shithole now,"],[2827,2986,"and they still think"],[2986,3182,"they own Maple Valley."],[3370,3465,"Not anymore."],[3553,3699,"Us Crows are ready"],[3699,3870,"to run Yellowstone Ranch"],[3870,3958,"into the ground"],[3958,4149,"and start a new era."],[4233,4300,"What do y'all say?"],[4350,4441,"Yeah, yep. - Yes."],[4471,4558,"We stand with the Crows."],[4646,4746,"Well, Mr. Crow,"],[4808,5088,"you are the most powerful man here,"],[5138,5234,"and we are so glad"],[5234,5342,"that you returned back here"],[5342,5413,"to Maple Valley."],[5413,5568,"We support you and your family"],[5601,5855,"taking over all of Yellowstone Ranch."]],"70":[[108,162,"That's right."],[187,354,"Yellowstone should have crumbled"],[354,471,"to dust long ago."],[513,650,"We stand with the Crows as well."],[696,921,"Yes, support the Crows."],[1013,1117,"What do we do now, Dad?"],[1514,1922,"Well, if you support us, the Crows,"],[2010,2106,"stay where you are."],[2164,2298,"If you want to follow"],[2298,2527,"Yellowstone Ranch to its demise,"],[2585,2669,"go to Harrison."],[2786,2965,"Now choose wisely, y'all."],[2982,3286,"This is life or death."],[3478,3649,"I got the whole valley behind me."],[3657,3858,"Looks like this is the end"],[3858,4033,"of Yellowstone Ranch."],[4454,4675,"Mr. Henry Conrad has arrived."],[5321,5430,"Mr. Crows,"],[5492,5622,"you're wrong about one thing."],[5880,6068,"Having the whole valley behind you,"],[6110,6202,"that ain't gonna shake me,"],[6285,6381,"because I rule the entire"],[6381,6510,"fucking State of Montana."]],"71":[[45,83,"Dad,"],[129,246,"are you really the boss"],[246,329,"of Yellowstone?"],[617,667,"I am."],[867,1021,"I kept my identity a secret"],[1021,1080,"for all these years"],[1080,1234,"because I wanted to raise you right."],[1347,1493,"I wanted you to be a decent man,"],[1614,1685,"a kind man."],[1818,1897,"I understand, Dad."],[1968,2110,"Looks like I made the right decision."],[2331,2406,"Proud of you, son."],[2748,2827,"And the two of you,"],[2932,3065,"Yellowstone's lucky to have you."],[3140,3178,"Greetings, - Greetings,"],[3178,3249,"Mr. Conrad. - Mr. Conrad."],[3386,3507,"I see the good in you, Zach."],[3695,3737,"Well,"],[3887,4037,"looks like the Crows family"],[4037,4116,"has been plotting"],[4116,4233,"against the Yellowstone,"],[4300,4433,"trying to run us out of the valley."]],"72":[[179,254,"Now, Mr. Conrad,"],[254,442,"I had no idea that you had returned"],[442,533,"to Maple Valley."],[563,613,"Uh,"],[754,867,"It was the Crows, you see, uh,"],[896,1021,"they, they tricked us."],[1067,1138,"Uh, I would never"],[1138,1272,"go behind your back like that."],[1330,1401,"No..."],[1443,1564,"I remember you, Shaw."],[1618,1718,"Your ranch burned down"],[1718,1780,"in that great fire."],[1780,1943,"I was the one that funded you."],[1985,2131,"Got your business going again"],[2131,2235,"so that you could support"],[2252,2356,"and provide for your family,"],[2356,2481,"this is how you repay me?"],[2560,2702,"How you repay the Yellowstone?"],[2936,2977,"And you."],[3103,3174,"Mr. Hall."],[3294,3386,"Yellowstone supported"],[3386,3524,"your three kids through college."],[3599,3707,"Now you're a big man,"],[3745,3853,"this is how you repay"],[3853,3937,"my generosity?"]],"73":[[8,116,"So what if you're the owner"],[116,200,"of Yellowstone,"],[200,275,"you old fart?"],[308,412,"Times have changed."],[442,538,"Take a look around."],[579,725,"Everybody on this side of the room"],[725,863,"is with my family now."],[888,963,"So why don't you take"],[963,1055,"your coward-ass son"],[1055,1234,"and go back to your rundown ranch"],[1234,1297,"of yours?"],[1430,1480,"Fuck!"],[1705,1818,"Watch your mouth, boy."],[1830,1868,"Fuck!"],[1868,1956,"Not even your old man"],[1956,2068,"would talk to me like that."],[2127,2181,"Ow!"],[2323,2548,"You fucking bastard!"],[2781,2932,"Shut your filthy mouth!"],[3123,3207,"Mr. Conrad."],[3407,3486,"Please forgive me."],[3524,3670,"This is all just a misunderstanding."],[3820,3920,"A misunderstanding?"],[4008,4054,"No."],[4166,4212,"No, no."],[4325,4416,"From where I'm standing,"],[4416,4546,"this is a big mistake."],[4625,4688,"It's the last one"],[4688,4783,"you're ever going to make."],[4854,4984,"Because when you make mistakes,"],[5038,5155,"you've got to pay the price."],[5171,5296,"That's the way the world works."],[5488,5534,"Do it."]],"74":[[1618,1764,"Mr. Conrad said it's a go."],[1918,1989,"Get ready."],[2085,2143,"Come here, son."],[2248,2348,"I'm going to show these people"],[2352,2435,"what happens to those"],[2435,2540,"who cross my son,"],[2631,2727,"Roman Conrad,"],[2798,2973,"the sole heir of the Yellowstone Ranch"],[2973,3144,"and the future boss of Montana."],[3186,3336,"Start with the Shaws and Halls."],[3407,3474,"Destroy them."]],"75":[[133,187,"Now listen."],[229,321,"Mr. Conrad,"],[354,442,"you've got to believe us."],[442,529,"Jacob Crows."],[529,688,"He tricked us, he tricked us,"],[688,767,"he tricked us!"],[809,921,"He's right, Mr. Conrad."],[1013,1113,"We've always been grateful"],[1113,1197,"for your kindness."],[1255,1347,"I give you my word."],[1463,1530,"Your word."],[1634,1776,"Your word means nothing to me."],[1868,1939,"It's too late."],[2043,2214,"It's time you reap what you sowed."],[2519,2565,"What?"],[2565,2619,"Mr. Shaw,"],[2665,2819,"our warehouses is on fire!"],[2819,2977,"It's going to destroy the ranch."],[2994,3140,"Everything's ruined."],[3153,3257,"It's the Feds, Mr. Hall!"],[3290,3378,"The FBI is here."],[3399,3486,"And they're turning the place"],[3486,3553,"upside down."],[3586,3641,"And they have"],[3641,3737,"an arrest warrant on you"],[3737,3799,"for bribery."],[3824,4016,"No. No, no, no. - Ugh!"],[4124,4195,"I'm done."],[4241,4366,"I'm done, my ranch,"],[4366,4496,"my money, my business,"],[4496,4562,"it's all gone!"]],"76":[[33,87,"It's all gone."],[87,137,"Mr. Conrad,"],[191,237,"Mr. Conrad,"],[237,396,"I can't go to jail, I can't go to jail."],[396,437,"Please."],[450,588,"Please, you have to help me."],[855,955,"Will you take out this trash?"],[1188,1280,"No! - I can't go to jail!"],[1280,1413,"Wait, wait, hold on!"],[1447,1589,"I can't go to jail. - Wait, wait, wait!"],[1601,1672,"It was him! - No!"],[1697,1793,"No! - It was him!"],[1801,1830,"No!"],[1860,1931,"Get off of me!"],[1931,1972,"No!"],[1981,2056,"Get off of me!"],[2060,2106,"Fuck you!"],[2143,2235,"Fuck you!"],[2268,2331,"Fuck you!"],[2360,2444,"You piece of shit!"],[2652,2840,"It's your turn now, Jacob Crows."],[2948,3123,"You sneaky old snake."],[3136,3253,"This is my ranch."],[3261,3407,"My family's ranch."],[3445,3586,"You're on our territory."],[3628,3812,"All our guards are waiting outside."],[3870,3983,"You can't escape them."],[4041,4095,"Guards!"],[4170,4225,"Guards!"],[4262,4337,"Mr. Conrad."]],"77":[[16,108,"Mr. Conrad,"],[158,308,"we've taken down all the guards"],[308,408,"of the Crow family."],[425,558,"Not a single one escaped."],[596,692,"We're all outside"],[692,796,"awaiting your command, sir."],[863,950,"Well done, gentlemen."],[1084,1188,"Did you hear that, boy?"],[1272,1380,"Your family's finished."],[1455,1584,"You're not going to amount to anything,"],[1593,1676,"not in Montana,"],[1676,1814,"not anywhere in this country."],[2006,2127,"God damn it!"],[2214,2356,"This can't be happening!"],[2731,2815,"Mr. Conrad,"],[2923,3023,"this is all my fault."],[3073,3311,"Beat me, kick me, take my life,"],[3311,3386,"but please"],[3503,3582,"spare my son."],[3745,3858,"If I hadn't shown up,"],[3962,4108,"your son wouldn't have spared mine."],[4145,4262,"And anyone who lays a finger"],[4262,4325,"on my son"],[4425,4562,"gets no mercy from me."],[4746,4888,"Take these two out to the barn."],[4946,5009,"Get them out of here."],[5042,5171,"Make sure they learn their lesson"],[5171,5259,"before you turn them over"],[5259,5326,"to the police."],[5417,5459,"What?"],[5488,5526,"No!"],[5563,5601,"No!"],[5605,5793,"The dog food was a joke!"],[5814,5901,"It was a joke!"],[5930,6060,"It was a joke, I swear!"],[6348,6556,"Mr. Conrad, we were wrong."],[6623,6744,"We're willing to surrender"],[6744,6861,"all of our assets."],[6961,7086,"Please spare our lives."],[7173,7361,"Please spare us, Mr. Conrad."]],"78":[[0,112,"We're willing to surrender"],[112,208,"all of our assets."],[325,454,"Please spare our lives."],[533,750,"Please spare us, Mr. Conrad."],[1330,1501,"I'm going to give you one chance."],[1593,1755,"One chance."],[1793,1939,"Be loyal to the Yellowstone,"],[1968,2085,"the leader in this valley."],[2173,2281,"And we'll take care of you."],[2339,2489,"But if any of you motherfuckers"],[2489,2610,"ever betrays me again,"],[2690,2827,"the only way out is death."],[2969,3053,"Am I clear?"],[3090,3240,"Yes, Mr. Conrad!"],[3315,3428,"From this day forward,"],[3495,3549,"my son,"],[3753,3845,"Roman Conrad,"],[3958,4145,"is the leader of the Yellowstone Ranch."],[4491,4758,"He is the future boss of Montana."],[5405,5534,"Greetings, Mr. Conrad."],[5584,5747,"Greetings, Mr. Conrad."]]}