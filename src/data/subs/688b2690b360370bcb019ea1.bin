{"1":[[1176,1380,"See that's the lowly janitor!"],[1459,1539,"Hey, old man!"],[1626,1730,"Give us some cash."],[2702,2911,"Old man, you better do what we say."],[2982,3036,"Kid,"],[3128,3224,"I suggest you don't play with"],[3224,3336,"knives in front of me."],[3661,3770,"Cut the crap, grandpa."],[3791,3895,"We don't have time for this."],[6719,6873,"Stop!"],[7419,7507,"That's Harrison Grant."],[7745,7903,"He's the foreman of Yellowstone Ranch."],[7974,8033,"Yellowstone?"],[8099,8183,"They own this school."],[8216,8350,"They're the bosses of Montana."],[8429,8479,"Take them."],[8550,8650,"Brand them so they remember"],[8650,8729,"who runs this valley."],[9004,9092,"Hey, wait, wait, wait, wait."],[9138,9225,"No, let go!"],[9238,9284,"No!"],[9288,9417,"Hey, wait, wait, wait, wait!"],[9417,9542,"No, no, no!"],[9551,9638,"Get off of me!"],[9672,9722,"No!"],[10043,10089,"Harrison?"],[10197,10331,"Greetings, Mr. Conrad!"],[10493,10706,"Greetings, Mr. Conrad!"]],"2":[[95,250,"My name is Henry Conrad,"],[400,600,"founder of Yellowstone Ranch."],[988,1180,"I once fought rival ranches."],[1468,1726,"Until we united them all across Montana."],[2039,2223,"Then my son Roman was born."],[2861,2969,"That was when I gave up"],[2969,3132,"that life of blood and battles."],[3687,3824,"Welcome back to Yellowstone,"],[3824,3920,"Mr. Conrad."],[4029,4120,"I've hidden my identity"],[4120,4195,"as the leader of"],[4195,4375,"Yellowstone for all these years."],[4391,4517,"Wanted to raise my only son"],[4517,4608,"Roman right."],[4683,4804,"Now that he's grown,"],[4884,5050,"it's time I come back for my throne."],[5288,5397,"You've worked hard all these years,"],[5397,5447,"Harrison."],[5643,5751,"How's my ranch doing?"],[5847,5935,"I've failed you, sir."],[6001,6051,"Yellowstone was"],[6051,6193,"the most powerful ranch in Montana,"],[6239,6364,"but you've been gone for ten years."],[6427,6506,"And our nemesis,"],[6506,6635,"the Crows family you once crushed,"],[6694,6765,"they're making moves."],[6806,6911,"Especially the Lennox Ranch"],[6911,7002,"in the East Maple Valley."],[7077,7115,"Crows have been"],[7115,7244,"egging them on to provoke us,"],[7319,7386,"to start a war."],[7565,7874,"All these debts after all these years,"],[8091,8199,"it's time I settled them."],[8675,8808,"You're Roman's deadbeat dad?"],[8863,8971,"Your son caused some trouble"],[8971,9025,"at school."],[9075,9159,"You better come quick,"],[9209,9342,"if you ever want to see him again."],[9651,9797,"Wait for my call."],[9893,10010,"I need to get to my son,"],[10085,10139,"right now."]],"3":[[1096,1163,"Yeah, hey!"],[1230,1301,"My boy."],[1322,1401,"Watch it, loser!"],[2056,2160,"My glasses."],[2510,2669,"Leave me alone, please."],[2911,2986,"Oh."],[3065,3203,"But what would be the fun in that?"],[3257,3424,"You're just a dirty janitor's kid."],[3495,3599,"You were born to be stepped on."],[3691,3766,"Like a bug."],[4362,4525,"Look at that little wuss go."],[4642,4750,"You can run, Roman,"],[4821,4917,"but you can't hide."],[5839,6022,"Who's fucking idiot just ruined my fun?"],[6381,6443,"Raine?"]],"4":[[54,208,"You fucking boner killer."],[633,775,"I've got an archery match coming up"],[775,875,"and you fuck up my face?"],[1272,1326,"Spencer?"],[1926,2018,"It was bad enough"],[2064,2210,"you bumped into me in the hallway."],[2235,2285,"Now you've gone"],[2285,2394,"and pissed off the captain"],[2394,2494,"of the Archery team?"],[2794,2857,"But Raine,"],[2927,3040,"why are you doing this?"],[3082,3182,"You're my girlfriend."],[3286,3399,"Never been your girlfriend,"],[3411,3461,"Roman."],[3511,3578,"I've been with Spencer"],[3578,3661,"for three months."],[3741,3832,"Three months?"],[3953,4049,"But that's when I gave you"],[4049,4095,"the necklace"],[4095,4170,"that's..."],[4170,4304,"you said you would be with me."],[5196,5251,"Nerds like you"],[5251,5392,"should at least be smart,"],[5392,5438,"Roman."],[5501,5593,"Look at yourself."],[5622,5726,"You really think I'd be"],[5726,5851,"with a school janitor's son?"],[5880,5972,"That's right, dummy."],[6014,6151,"Your dad cleans the toilets"],[6151,6227,"we shit in!"],[6644,6819,"But why did you accept"],[6819,6894,"the necklace then?"],[6927,7086,"I worked so hard for it."],[7140,7232,"Oh that."],[7261,7444,"Just a silly bet with my girls."],[7511,7603,"I said I'd get you"],[7603,7711,"to give me some bling"],[7720,7824,"and I won."],[7912,8145,"As for that lame necklace,"],[8404,8529,"it's only good enough for a dog."],[8629,8692,"Looks good on him,"],[8692,8750,"don't you think?"]],"5":[[546,709,"Spencer's not only the captain"],[709,800,"of the Archery team,"],[846,984,"he's heir to the Lennox Ranch,"],[1071,1347,"the richest family in East Maple Valley."],[1380,1451,"Even the principal's"],[1451,1526,"gotta listen to him."],[1618,1830,"You're just a janitor's son"],[1864,2018,"and you think you can piss him off"],[2043,2131,"and get away with it?"],[2285,2469,"Stop wasting our time."],[2531,2610,"Be a good boy"],[2648,2798,"and apologize to Spencer."],[2894,3098,"Maybe he'll let you off the hook."],[3257,3353,"Acting tough, huh?"],[3482,3632,"Guess I'll have to cut the apology"],[3632,3682,"outta ya!"],[4062,4108,"Roman!"],[4771,4909,"Why are you doing this to my friend?"],[5021,5271,"You call this loser your friend?"],[5430,5580,"Babe, babe. He's not worth your time."],[5647,5697,"Why don't you"],[5747,5826,"come hang out with us"],[5847,5926,"and make it worth your while?"],[6010,6085,"Don't touch me!"],[6222,6398,"Bitch, did you just hit me?"]],"6":[[8,120,"Did you just hit me, bitch?"],[546,721,"This freak ruined my fun"],[729,825,"and hit me in the face."],[880,984,"That's gonna cost him."],[1055,1213,"I'm not letting you touch him."],[1255,1313,"Look at that."],[1359,1459,"Little Pocahontas here"],[1459,1551,"is trying to protect you"],[1551,1726,"from the big bad wolves."],[2022,2177,"You want money, right?"],[2389,2469,"Name your price."],[2544,2635,"Just leave him alone."],[2686,2844,"Damn, talking big."],[2877,2927,"Alright,"],[2973,3086,"how about"],[3178,3240,"one million?"],[3345,3445,"One million?"],[3549,3599,"No way."],[3699,3816,"We don't have that kind of money."],[3933,4029,"Well, too bad."],[4074,4216,"Since I'm feeling generous today,"],[4291,4421,"how about you two"],[4421,4533,"play a little game with me?"],[4542,4692,"And I won't ask for a cent."],[5109,5176,"What are you doing?"],[5226,5301,"Don't touch her!"],[5347,5392,"Kira!"],[5422,5467,"Kira!"]],"7":[[400,450,"Kira!"],[500,542,"Kira!"],[817,930,"Zach, Spencer,"],[946,1076,"I know you've got a problem with me,"],[1113,1397,"so take it out on me and let her go."],[1505,1755,"Oh, I just, I just love that helpless look"],[1776,2010,"on weak losers like you."],[2189,2331,"I'm gonna frame this one on my wall."],[2665,2790,"The game's easy, Romeo."],[2857,2998,"All you gotta do is shoot an arrow"],[3065,3199,"at the Indian Princess here."],[3299,3511,"Well, I hope you got a good aim."],[3595,3645,"No way."],[3645,3874,"I, I don't know how to shoot an arrow."],[3987,4183,"Well, that makes it even more exciting,"],[4183,4250,"doesn't it?"],[4542,4583,"Aww,"],[4617,4725,"you're shaking like a pussy,"],[4725,4771,"Roman."],[4888,5130,"I guess I could take the shot for you?"],[5201,5251,"But hey,"],[5359,5442,"if I miss..."],[6210,6256,"Hold on."],[6373,6452,"You forgot one thing."],[8103,8187,"If you hit the apple,"],[8216,8299,"we will let you go."],[8479,8554,"Go on, loser."],[8575,8671,"We ain't got all day."],[8796,9563,"Shoot! Shoot! Shoot!"]],"8":[[0,241,"Shoot! Shoot! Shoot!"],[241,300,"Die! - Shoot!"],[1167,1213,"Spencer!"],[1213,1292,"Are you okay, baby?"],[1468,1576,"Get him, now!"],[1889,2039,"You wanna kill me, little maggot?"],[2064,2227,"Too bad, because you missed!"],[2686,2819,"The horse shit tastes nice,"],[2819,2898,"doesn't it, Roman?"],[3553,3849,"Now let me show you how to shoot."],[4112,4149,"No!"],[4208,4245,"No!"],[4700,4742,"No!"],[4800,4838,"No!"],[4913,4950,"No!"],[5951,5997,"No!"]],"9":[[325,367,"No!"],[792,900,"Fuck."],[1172,1313,"Hey, hey, hey, it's okay."],[1347,1388,"It's okay."],[1393,1430,"You're okay."],[1668,1730,"You missed."],[1914,2031,"No, we had a deal."],[2114,2193,"You liars!"],[2439,2631,"You don't make the rules here,"],[2656,2765,"you piece of shit!"],[2790,2952,"This valley's my turf, okay?"],[3032,3211,"I decide how this game ends."],[3812,3933,"You're Roman's deadbeat dad?"],[4054,4175,"Your son caused some trouble"],[4175,4229,"at school."],[4266,4354,"You better come quick,"],[4421,4546,"if you ever wanna see him again."],[4546,4675,"Leave my dad out of this!"],[4775,4921,"I'll fucking kill you, you asshole!"],[4950,5059,"Scums like you"],[5059,5163,"are the bottom of the barrel."],[5226,5334,"No one's gonna miss you"],[5334,5397,"when you're gone,"],[5438,5551,"except your old man."],[5634,5697,"But then again,"],[5768,5918,"he's just a dirty janitor."],[5985,6114,"So what do I care?"],[6381,6498,"Handle this the usual way."],[6544,6619,"I never wanna see"],[6619,6798,"this disgusting mug again!"],[6852,6894,"No!"],[6911,6956,"No!"],[7065,7232,"And get rid of that Indian skank too."],[7269,7353,"Stop! - No, no!"],[7353,7411,"Roman!"],[7549,7603,"Stop!"]],"10":[[54,120,"Stop!"],[283,329,"Dad!"],[621,750,"What do we have here?"],[800,930,"Roman's janitor dad!"],[984,1030,"What?"],[1042,1197,"You here to rescue your son?"],[1380,1501,"Like father, like son."],[1526,1689,"I can smell the dumpster you live in"],[1710,1818,"all the way from here."],[1818,2014,"You reek of poverty."],[2106,2214,"Let my son go."],[2243,2364,"You don't get to tell us what to do,"],[2364,2410,"old man."],[2494,2656,"Spencer here is the King"],[2656,2781,"of Yellowstone Maple High,"],[2781,2923,"and you'll show some respect."],[2977,3098,"I don't give a shit who you are."],[3186,3453,"I said, let my son go."],[3507,3632,"You don't get it, do ya?"],[3691,3749,"Your son,"],[3774,3903,"messed with Spencer Lennox,"],[3920,4095,"the heir to the most powerful family"],[4095,4204,"in the East Maple Valley."],[4258,4350,"He had it coming."],[4583,4683,"Especially the Lennox Ranch"],[4683,4767,"in the East Maple Valley."],[4846,4888,"The Crows have been"],[4888,5017,"egging them on to provoke us,"],[5092,5155,"to start a war."],[5563,5672,"Lennox Ranch, you said?"],[5714,5818,"Get Spencer's family name"],[5818,5939,"out of your filthy mouth,"],[5939,6022,"toilet scrubber."],[6222,6423,"You and your son are in big trouble,"],[6431,6514,"you old fossil."],[6606,6752,"Even if Mr. Conrad,"],[6765,6848,"the legendary boss"],[6848,7019,"of Yellowstone Ranch showed up,"],[7069,7198,"he wouldn't be able to save you."],[7257,7344,"In fact, old man,"],[7361,7578,"your son was playing a little game"],[7578,7624,"with us."],[7816,7907,"My boy's gonna show you"],[7907,7995,"how much fun we're having."],[9192,9234,"Go!"],[9267,9309,"Go!"],[9325,9471,"Dad, please go!"]],"11":[[95,158,"Aww."],[250,404,"You want to save your baby boy?"],[529,617,"You gotta go through me,"],[617,663,"old man."],[880,1017,"Kid, I was playing with knives"],[1017,1084,"when you were swimming"],[1084,1201,"in your daddy's balls."],[1509,1601,"Don't be smart with me."],[1651,1755,"I'm gonna cut your tongue out."],[3386,3503,"Old fart!"],[3641,3716,"You hit me?"],[3757,3803,"Yeah."],[3958,4049,"You're dead!"],[4262,4371,"I'm calling my dad."],[4504,4575,"He's the foreman"],[4600,4771,"at the Yellowstone Ranch."],[4796,4909,"He's gonna slice you up!"],[4963,5021,"Foreman?"],[5067,5217,"Your dad is Harrison Grant,"],[5326,5534,"who works directly under the boss"],[5534,5651,"of Yellowstone Ranch."],[6026,6143,"No, no."]],"12":[[108,183,"So you've heard of him?"],[350,421,"Now you're scared,"],[492,533,"huh?"],[654,788,"You better get down on all fours"],[788,909,"and beg now,"],[963,1121,"before my dad tears you to pieces!"],[1313,1372,"Go ahead."],[1497,1551,"Call him."],[1664,1722,"I'd like to see"],[1722,1805,"what he's gonna do to me."],[1931,2043,"Old bastard,"],[2102,2189,"you asked for it!"],[2623,2665,"Dad,"],[2731,2831,"someone beat me up!"],[2857,2898,"What?"],[2957,3082,"You've got to come to the school"],[3107,3207,"right now."],[3269,3345,"I'm on my way."],[3832,3899,"My dad's coming."],[4029,4141,"Take a good look at your son,"],[4200,4291,"you old boot licker."],[4471,4529,"It's the last time"],[4529,4625,"you're ever gonna see him!"],[4821,4934,"We've got some time to kill"],[4934,5046,"before your dad arrives."],[5075,5117,"Yeah."],[5434,5568,"Didn't know a school janitor"],[5568,5655,"could fight like that."],[5814,5885,"How about this?"],[5976,6147,"You and me, one-on-one."],[6222,6285,"You win,"],[6427,6539,"I'll let your son go."],[7044,7090,"Deal?"]],"13":[[8,50,"Deal?"],[216,358,"Dad, don't do this."],[400,563,"My dad is too old to fight."],[571,633,"Let me go."],[684,767,"I'll, I'll fight - - Someone"],[788,938,"take care of this barking dog."],[955,996,"He's hurting"],[996,1084,"my ears. - No!"],[1101,1226,"No, don't do it!"],[1247,1317,"Don't do it."],[2214,2344,"Ten years ago, I swore"],[2344,2481,"I'd never raise my fist"],[2481,2623,"and engage in a bloody fight."],[2690,2815,"Pick a different game, kid."],[2952,3003,"Nah."],[3128,3207,"My turf."],[3311,3390,"My game."],[4212,4325,"If you don't want to fight me,"],[4650,4888,"it's gonna be two arrows,"],[5013,5100,"two lives."],[6994,7178,"You will not hurt my son,"],[7273,7323,"ever!"],[7474,7515,"Yeah?"],[7678,7770,"We'll see about that."]],"14":[[1689,1839,"You got lucky, old fart."],[2002,2185,"But you wasted that knife on that girl."],[2306,2373,"And now,"],[2448,2565,"I'm gonna kill your son."],[2865,3028,"Let's see what trick you pull now."],[3244,3311,"Three."],[3386,3641,"Shoot! Shoot! Shoot!"],[3641,3695,"Two."],[3728,4049,"Shoot! Shoot! Shoot!"],[4049,4099,"One."],[4158,4195,"Wait!"],[6990,7044,"Alright."],[7244,7323,"I'll fight you."]],"15":[[804,867,"Hold on."],[1096,1297,"Let me deal with him first."],[2264,2389,"You got lucky earlier,"],[2460,2594,"you dusty old fart."],[2802,2869,"But not this time."],[3007,3123,"I heard the Yellowstone"],[3123,3290,"and the Lennox Ranch are rivals."],[3386,3465,"Your dad is the foreman"],[3465,3536,"of Yellowstone."],[3649,3878,"What would he think if he found out"],[3878,3991,"his son was following"],[3991,4162,"the Lennox heir around"],[4162,4279,"like a sad little puppy?"],[4454,4587,"Worry about yourself,"],[4658,4783,"you old geezer!"],[4829,4875,"Fine."],[5000,5046,"Looks like I'll have to"],[5046,5180,"discipline you for your father."],[5246,5313,"That's enough!"],[5955,5993,"Dad!"],[6072,6197,"Who laid a hand on my son?"],[6527,6573,"You're here."],[6852,6898,"Dad."],[7027,7115,"Look what he did!"]],"16":[[533,588,"Dad!"],[629,679,"You're here."],[825,896,"Look what he did!"],[988,1088,"You gotta do something."],[1242,1292,"That's it?"],[1338,1393,"You're whining over"],[1393,1472,"some little scratches?"],[1551,1655,"I've had much worse than that"],[1655,1764,"and never flinched during my years"],[1764,1856,"following Mr. Conrad."],[1910,2089,"Mr. Grant, this wasn't our fault."],[2139,2281,"Someone was bullying us."],[2502,2602,"Spencer Lennox?"],[2669,2827,"Mr. Grant, I swear,"],[2894,3048,"Zach and I were just hanging out."],[3111,3228,"It was that old man over there."],[3290,3415,"He attacked us out of nowhere."],[3461,3532,"You're the foreman"],[3532,3628,"of Yellowstone, right?"],[3699,3832,"You gotta teach him a lesson."],[3887,3941,"Yeah, Dad."],[4045,4129,"What have I told you?"],[4179,4329,"Stay away from the Lennox family."],[4466,4608,"If Mr. Conrad hears about this,"],[4612,4725,"it's the fucking end of us."],[4925,4984,"But still,"],[5155,5255,"no one lays a hand on my son"],[5255,5347,"and lives to tell the tale."],[5593,5651,"Let me meet the man"],[5651,5768,"who had the balls to do this."],[6189,6243,"Harrison?"],[6756,6902,"How do you plan to avenge your son?"],[6986,7048,"Mr. Conrad-"],[7048,7286,"You don't get to call my dad"],[7294,7407,"by his first name."],[7461,7582,"You bag of bones."],[7657,7716,"Shut up!"]],"17":[[79,133,"Shut up!"],[721,909,"Dad, what, what was that for?"],[1468,1580,"Dad, what are you doing?"],[1634,1785,"He's just a nasty janitor."],[1793,1901,"Would you stay out of this?"],[2122,2314,"Sir, please,"],[2369,2460,"let my son go."],[2648,2765,"We don't deserve your forgiveness,"],[2773,2882,"but let me try to right the wrong"],[2882,2961,"my son has made."],[3870,3991,"I'm willing to give my life,"],[4087,4154,"but I beg you,"],[4220,4295,"just let him go."]],"18":[[16,87,"I beg you,"],[116,191,"just let him go."],[742,871,"When a son is lost,"],[984,1121,"the father's to blame, Harrison."],[1284,1405,"We'll settle this later."],[1518,1576,"Right now,"],[1634,1780,"we get my son to the hospital."],[2402,2452,"Yes, sir."],[2773,2819,"Well?"],[2865,2923,"What are you waiting for?"],[2923,2998,"Give me a hand over here."],[3324,3365,"No!"],[3495,3574,"What are you doing?"],[3941,4058,"You old bastard!"],[4108,4200,"I'm not done with you,"],[4245,4371,"and that runt you call son!"],[4829,4904,"Let, let go!"],[4904,4946,"Fuck!"],[5005,5046,"Fuck!"],[5084,5251,"I'm old enough to be your father."],[5338,5438,"You run your mouth again,"],[5438,5563,"and I'm gonna teach you how to speak,"],[5659,5818,"or make sure you never speak again."],[6798,6844,"Thank you."],[6940,7069,"Take my son to the hospital."],[7165,7290,"I gotta handle something here."],[7290,7440,"Dad, don't do this."],[7490,7607,"I don't want you to get hurt."],[7849,7974,"Don't worry about me, son."],[8066,8162,"I'll do whatever it takes"],[8162,8233,"to protect you."],[8308,8404,"Never forget that."],[8508,8546,"Go."],[8708,8758,"Stop!"],[8821,9029,"No one fucking leaves!"],[9330,9388,"Good."],[9492,9626,"I wasn't planning on leaving."],[9909,10035,"Lock this place down."],[10080,10214,"Nobody leaves this rink."],[10314,10381,"Lock it down!"]],"19":[[62,133,"Lock it down!"],[371,521,"You must have lost your marbles,"],[542,617,"both of you!"],[688,746,"Check it."],[829,942,"These guys are with me."],[1017,1159,"You think you can handle all of us,"],[1201,1330,"you old boot licker?"],[1589,1630,"Kid,"],[1718,1814,"I've been following Mr. Conrad"],[1814,1943,"for ten years around this country,"],[1943,2018,"making our names."],[2239,2369,"We've faced much worse than this."],[2527,2831,"Well, Mr. Conrad ain't nothing to me."],[2907,3111,"My family rules this valley."],[3136,3211,"And I say"],[3224,3370,"old sons of bitches like you"],[3382,3553,"should just stay in your coffins."],[3757,3824,"But no."],[3953,4095,"You had to crawl back out,"],[4145,4237,"just to die."],[4308,4421,"These two's got one foot"],[4421,4521,"in their graves anyway."],[4650,4763,"I say let's help them out."],[4909,4963,"Kill them."],[5142,5188,"Now."],[5317,5359,"Spencer!"],[5401,5488,"No, Spencer!"],[5492,5534,"Please."],[5601,5643,"Here."],[5718,5818,"You don't have to do this."],[5947,6018,"That's my dad!"],[6106,6151,"Shut up!"],[6339,6569,"I'm your boss, not your old man."],[6648,6773,"This is why I never told Roman"],[6773,6856,"who I was."],[6986,7069,"If he knew how much power"],[7069,7161,"I had over Montana,"],[7161,7273,"he could've turned out like this,"],[7328,7436,"an obnoxious brat"],[7436,7578,"I'd be ashamed to call my son."],[7620,7678,"You?"],[7778,7945,"Power over Montana?"],[8024,8199,"Y'all are crazier than I thought."],[8266,8404,"You're a school janitor,"],[8433,8566,"a disgusting maggot."],[8566,8687,"That's all you'll ever be."],[9084,9242,"You fucker!"],[9463,9601,"I'm gonna end you."],[10039,10197,"Whoever breaks their arms and legs"],[10210,10343,"get one million per limb."]],"20":[[179,262,"It's been ten years"],[262,412,"since we swore off this bullshit."],[525,671,"You think these old ass bones"],[671,734,"can handle that?"],[779,825,"Oh yeah."],[850,925,"You got this boss."],[1155,1238,"What are you waiting for?"],[1288,1338,"Get them!"],[4020,4095,"If you wanna live!"],[4162,4250,"Get out now!"],[4954,5013,"Grow a pair,"],[5042,5205,"you fucking useless trash!"],[5242,5321,"Come back here!"],[5417,5601,"You got a fire inside you, kid."],[5676,5818,"And I couldn't care less."],[5901,6022,"But you should have never used it"],[6022,6097,"on my son."],[6393,6439,"Shut up,"],[6481,6535,"geezer!"],[7119,7244,"Move a muscle"],[7390,7524,"and I'll blow you out."]],"21":[[125,166,"Sir,"],[237,296,"maybe we-"],[433,492,"What now?"],[554,650,"Cat got your tongue?"],[738,788,"Go on,"],[871,950,"try something."],[996,1113,"I dare you!"],[1643,1710,"Shoot me."],[1860,1931,"You think I won't?"],[1939,1997,"Go ahead."],[2060,2164,"Pull the trigger."],[2239,2527,"One move, and my life is yours."],[2635,2719,"Don't push me."],[2790,2840,"Here!"],[2865,2936,"Point it there."],[3015,3090,"It's faster."],[3215,3269,"What's wrong?"],[3336,3424,"What're you afraid of?"],[3553,3616,"Kill me."],[3712,3782,"Kill me,"],[3832,3949,"and the whole world will know"],[3949,4116,"that the Lennox boy is a murderer."],[4329,4466,"Shoot me!"]],"22":[[50,166,"Shoot me!"],[905,1238,"Using guns on an unarmed old man,"],[1330,1463,"you pathetic coward."],[1522,1647,"What are you gonna do?"],[1714,1885,"All you do is abuse power"],[1885,2006,"that doesn't belong to you."],[2248,2406,"You're a disgrace to your father,"],[2431,2523,"and to yourself."],[2836,2932,"That one's from me,"],[3028,3098,"for my son."],[3303,3361,"And that,"],[3445,3595,"that one's from your parents."],[4058,4162,"You won't get away with this!"],[4229,4383,"Spencer's family will come after you."]],"23":[[838,896,"Spencer!"],[1455,1718,"I got good news and bad news."],[1897,2002,"Good news is,"],[2056,2193,"I just spoke with the hospital."],[2243,2339,"My son's injuries"],[2339,2448,"are not life-threatening."],[2523,2590,"He'll live."],[2756,2848,"So he's okay?"],[2948,3040,"Then we can leave, right?"],[3048,3086,"Yes!"],[3123,3182,"You can."],[3340,3403,"He stays."],[3545,3586,"No!"],[3624,3666,"No!"],[3687,3753,"Raine, no!"],[3770,3866,"Please don't leave me here!"],[3866,3920,"Please!"],[4262,4304,"Fuck!"],[4475,4575,"Bad news is,"],[4721,4925,"my son needs one month to recover."],[5030,5100,"I'll pay you!"],[5117,5163,"I promise."],[5163,5276,"My dad's rich, please!"],[5296,5463,"My dad's fucking rich, I promise!"],[5476,5572,"And he'll write a check, please!"],[5580,5663,"Please, just don't hurt me!"],[5663,5805,"I don't want your money, kid."],[6072,6135,"Please don't hurt me!"],[6135,6210,"I'm a fair man."],[6264,6352,"Let's play the game"],[6352,6468,"you were playing with my son."],[6468,6523,"What do you say?"],[6560,6598,"No."],[6631,6744,"No, please don't hurt me!"],[6777,6810,"Please,"],[6810,6902,"don't hurt me! - Oh, now you beg?"],[7007,7157,"Did my son beg you not to hurt him?"],[7219,7261,"Please!"],[7282,7390,"Not to hurt his friends?"],[7640,7791,"I'm gonna shoot one arrow,"],[7999,8062,"blindfolded."],[9184,9292,"I'll do anything, please!"],[9325,9367,"Please!"],[9367,9530,"I'll never touch your son again, please!"],[9588,9722,"Please, please!"],[9722,9813,"I'll never touch him!"],[9851,9909,"Please, no!"],[9930,10010,"No, please!"]],"24":[[2318,2402,"You said it,"],[2410,2560,"if I lived, you'd let me go."],[2932,3011,"My turf,"],[3082,3140,"my rule."],[3140,3190,"No."],[3249,3411,"But you already know this don't you?"],[3449,3495,"You."],[3495,3670,"Oh, I'm just an old timer."],[3753,3928,"Playing by a young man's rules."],[5359,5438,"Let me go!"],[5463,5572,"Let me go!"],[5609,5718,"Let me go!"],[5751,5814,"No!"],[5851,5914,"No!"],[5955,6018,"No!"],[6056,6110,"Please!"],[6139,6206,"Please!"],[6923,6990,"Fire."],[7040,7107,"Stop!"]],"25":[[784,884,"Let my son go!"],[1584,1626,"Dad."],[1768,1872,"You're all dead now!"],[1906,2002,"My dad's here!"],[2052,2152,"You're finished!"],[2168,2293,"Harrison!"],[2327,2435,"Aren't you still cooped up"],[2435,2506,"in that crumbling"],[2506,2602,"Yellowstone Ranch?"],[2665,2794,"Even your boss Mr. Conrad"],[2794,2902,"has been gone for years."],[3090,3148,"You don't rule"],[3148,3257,"Maple Valley anymore!"],[3349,3440,"And you don't get to lay a hand"],[3440,3511,"on my son!"],[3624,3837,"Mr. Conrad, this is Hunter Lennox."],[3908,3987,"He owns the biggest ranch"],[3987,4083,"in the East Maple Valley."],[4175,4250,"Since you've been gone,"],[4304,4366,"they've been causing"],[4366,4450,"a whole lot of trouble."],[4487,4546,"Good."],[4637,4742,"I've been dying to meet him."],[4859,4909,"Hunter,"],[4959,5084,"the man standing in front of you is-"],[5084,5230,"I don't give a damn who the hell he is!"],[5288,5401,"I'm the king of this valley!"],[5447,5538,"Even if he was the owner"],[5538,5634,"of the Yellowstone Ranch,"],[5634,5739,"he'd have to bow down"],[5764,5876,"and kiss my boots!"],[5951,6010,"Yeah."],[6039,6126,"Is that so?"],[6339,6498,"Hunter, is it?"],[6552,6756,"Get my dad's name out of your mouth,"],[6756,6848,"filthy janitor!"],[6931,7052,"I said don't mess with me!"],[7119,7236,"Now you're all gonna get it!"],[7298,7353,"Dad!"],[7444,7486,"Dad."],[7574,7632,"Kill them."],[7866,7962,"Untie my son, now."],[8458,8562,"He's not going anywhere."]],"26":[[45,116,"You're threatening me?"],[266,379,"What, you think Harrison here"],[379,458,"can protect you?"],[529,667,"I don't need anyone's protection."],[779,871,"You're not taking him."],[884,975,"That's what I said."],[1017,1088,"It's final."],[1167,1242,"You want to test me?"],[1355,1413,"Go for it."],[1488,1589,"I looked into you."],[1622,1755,"You're just a school janitor."],[1789,1818,"Sure,"],[1818,1939,"Yellowstone Ranch still owns"],[1939,2027,"this part of the valley."],[2081,2168,"But I'm a Lennox."],[2185,2369,"If I want to, I can squash you,"],[2423,2585,"like the disgusting bug you are!"],[2640,2798,"Now I'm gonna give you three seconds."],[2882,2973,"Let my son down"],[2973,3107,"and apologize to him"],[3123,3203,"on your knees!"],[3290,3386,"Or I will make sure"],[3420,3557,"you don't walk out of this rink tonight."],[3682,3753,"Alright."],[4033,4179,"Smart choice, janitor."],[4959,5105,"I told you you'd regret it,"],[5105,5171,"old fart!"],[5476,5643,"Now apologize to me real good,"],[5705,5759,"or every time"],[5759,5893,"I see your loser son at school,"],[5922,6060,"I'll beat the shit out of him!"],[6268,6343,"What do you want?"],[6685,6835,"Crawl over on all fours."],[7415,7540,"And lick that clean."],[7620,7741,"Maybe I'll forgive you."],[7874,8070,"You heard my son, toilet scrubber."],[8091,8229,"Get on your knees and clean it!"],[8391,8541,"You are messing with the wrong man."],[8587,8679,"You think I'm scared"],[8679,8875,"of a dirty school janitor, Harrison?"]],"27":[[66,158,"You don't understand."],[308,417,"This man standing in front of you-"],[417,579,"Shut your mouth, Harrison!"],[688,859,"Once I deal with this lowlife,"],[871,946,"I'm coming for you"],[946,1009,"and your precious"],[1009,1130,"Yellowstone Ranch next."],[1159,1313,"You are testing my patience."],[1409,1630,"Kneel and lick it clean,"],[1672,1822,"like my son said."],[1914,2043,"Let me just make one call."],[2143,2206,"One call."],[2293,2389,"Then you can decide"],[2389,2544,"if you still want me on my knees."],[2690,2740,"Sure!"],[2831,3028,"Guys, you got three minutes."],[3061,3224,"Enjoy your last few breaths."],[3345,3386,"What now,"],[3386,3490,"you're gonna call the cops?"],[3545,3645,"You don't know, do you?"],[3699,3866,"All the cops in Maple Valley"],[3895,4054,"take orders from my dad!"],[4099,4225,"Don't flatter yourself, kid."],[4262,4391,"I don't waste the cops' time"],[4391,4512,"on scumbags like you."],[4562,4646,"You're not worth it."],[4746,4879,"You are messing with the wrong man,"],[4879,4929,"Hunter."],[4996,5046,"This guy?"],[5113,5213,"He's a janitor!"],[5251,5426,"More worthless than the worker"],[5426,5663,"on my ranch who cleans horse shit!"],[6114,6156,"So,"],[6235,6398,"how was that last call of your life,"],[6443,6548,"old geezer?"],[6619,6723,"Your three minutes are up."],[6815,6931,"And what did it do, really?"],[7019,7144,"Nothing, thought so."],[7303,7428,"Get him down on his knees,"],[7449,7615,"and make him lick the ground clean"],[7615,7657,"now!"],[8028,8074,"Wait!"],[8345,8408,"What is it?"],[8429,8646,"Mr. Lennox, bad news."],[8683,8867,"Every business partner of the family"],[8867,8954,"just pulled out."],[8992,9092,"The Lennox Ranch"],[9138,9305,"has gone bankrupt, sir!"]],"28":[[20,133,"That's, that's impossible!"],[183,321,"Look, with my lands..."],[329,529,"Lennox Ranch has gone bankrupt, sir."],[554,671,"With all the investors gone,"],[671,792,"we've lost billions."],[804,871,"And your lands"],[871,967,"have been confiscated"],[967,1051,"by the banks."],[1067,1180,"Backed by an unknown-"],[1180,1242,"What are you saying?"],[1297,1405,"All my assets?"],[1451,1609,"Everything I own is gone?"],[1659,1814,"Yes, sir, it's too late."],[1826,1981,"All the workers have walked."],[1989,2131,"There's no one left anymore."],[2298,2339,"Dad!"],[2369,2410,"Dad!"],[2581,2644,"It's over."],[2686,2748,"It's over."],[2748,2865,"Our family's finished!"],[2890,2998,"I warned you, Hunter."],[3340,3395,"Harrison,"],[3495,3553,"please!"],[3561,3628,"You're the foreman"],[3628,3732,"of the Yellowstone Ranch."],[3745,3887,"Only your boss, Mr. Conrad,"],[3887,3949,"can save us now."],[3949,3999,"Please!"],[4212,4429,"You are begging the wrong man."],[4688,4758,"Who are you?"],[4821,4971,"This is the leader"],[4971,5084,"of the Yellowstone Ranch,"],[5134,5230,"the boss of this valley"],[5284,5392,"and the entire Montana."],[5480,5576,"He's Henry Conrad."]],"29":[[54,150,"He's Henry Conrad."],[408,458,"What?"],[492,596,"That's not possible!"],[642,763,"He's, he's just a janitor."],[1076,1117,"Kneel!"],[1259,1397,"No, Dad! - Kneel, everybody!"],[1797,1843,"No!"],[2052,2160,"I warned you, Hunter."],[2231,2352,"Please, Mr. Conrad,"],[2377,2456,"don't do this."],[2506,2648,"My family didn't come this far"],[2648,2815,"just to get destroyed like this."],[2952,3044,"Well, I'm not the one"],[3044,3215,"that destroyed your family, Lennox,"],[3294,3353,"you are."],[3432,3511,"If it wasn't for today,"],[3591,3737,"I'd have no idea"],[3766,3845,"how little you respected"],[3845,3987,"the Yellowstone Ranch,"],[4062,4200,"how little you respected me."],[4266,4412,"It's not like that, Mr. Conrad."],[4412,4521,"Oh, and I should thank you."],[4575,4688,"If not for you and your son-"],[4700,4733,"No!"],[4779,4929,"I wouldn't have decided to return."],[5013,5117,"Starting today,"],[5201,5405,"there's a new world order in Montana."],[5530,5693,"You all can thank the Lennox family"],[5693,5751,"for that."],[5822,5868,"No!"],[5897,6026,"No!"],[6047,6172,"No!"],[6202,6331,"I've given you one hour."],[6427,6498,"After that,"],[6585,6685,"I'll issue a bounty"],[6685,6781,"on the Lennox family"],[6815,6936,"for all of Montana. - Dad."],[6977,7040,"Dad, come on."],[7094,7223,"Now, whether you live or die,"],[7223,7315,"that's not up to me."],[7411,7532,"That's in God's hands now."],[7703,7753,"No."],[7803,7845,"Get!"],[7874,7945,"Dad, come on!"],[8554,8679,"Keep my return quiet."],[8721,8767,"I want to see"],[8767,8863,"what other fucking ranches"],[8863,9004,"dare challenge the Yellowstone."],[9046,9100,"Yes, sir."],[9146,9221,"And one more thing."],[9442,9542,"Being the school janitor"],[9542,9642,"no longer suits me."],[9684,9809,"I need to take over this school"],[9914,9976,"as principal."],[10068,10185,"You make the arrangements."],[10268,10431,"I gotta go visit my son in the hospital."]],"30":[[16,91,"Mr. Conrad."],[462,575,"I failed to raise Zach right."],[721,817,"Wasted your trust."],[1084,1201,"You don't have to hide your face"],[1201,1272,"from me, Harrison."],[1355,1443,"Stand up tall."],[1559,1639,"Talk like men."],[2052,2127,"Would you get over here?"],[2173,2298,"Apologize to him right now."],[2339,2423,"Mr. Conrad,"],[2506,2615,"I was blind before."],[2652,2748,"Please forgive me."],[2907,3011,"Mr. Conrad, please,"],[3048,3111,"for my sake."],[3203,3307,"Could you give him a second chance?"],[3566,3649,"The kid's not rotten,"],[3757,3828,"just lost."],[3866,3978,"You're his father, Harrison."],[4087,4204,"Guide him well from now on."],[4567,4754,"For ten years we fought side by side"],[4754,4829,"to make Yellowstone"],[4829,5025,"the most powerful ranch in Montana."],[5100,5234,"Now people want to challenge it,"],[5246,5367,"maybe even replace it?"],[5426,5472,"No."],[5534,5705,"It's time for these old bones"],[5780,5885,"to show the world"],[5885,6076,"who the real kings are one more time."],[6122,6168,"Yeah?"],[6256,6306,"Yes!"],[6314,6356,"Yeah!"],[6406,6448,"Let's go."],[7444,7494,"Kira?"],[7649,7841,"Roman, you're finally awake!"],[7882,7970,"I'll go get the doctor."]],"31":[[25,83,"Thank you"],[183,287,"for being there for me."],[880,1034,"Mr. Conrad, I-"],[1034,1126,"It's alright, Kira."],[1176,1230,"I get it."],[1534,1643,"I'll leave you two to talk."],[2002,2043,"Dad."],[2139,2243,"Did I cause you trouble again?"],[2281,2410,"No, don't worry about it."],[2452,2531,"It's been handled."],[2544,2573,"I should have"],[2573,2665,"stopped them myself."],[2702,2911,"No, you stood strong against them."],[2973,3040,"Like a man."],[3144,3228,"You did good, son."],[3399,3528,"I gotta take care of something."],[3591,3678,"Get some rest, son."],[4608,4713,"Mr. Conrad. - Mr. Conrad."],[4909,4988,"Mr. Conrad,"],[5030,5146,"this is Principal Quinn Wells."]],"32":[[125,221,"Mr. Conrad."],[425,504,"Mr. Conrad,"],[538,667,"this is Principal Quinn Wells."],[754,842,"Mr. Conrad,"],[946,1059,"I've heard all about your legends"],[1113,1184,"and your ranch."],[1230,1351,"It's an honor to finally meet you."],[1543,1730,"Well, here I am."],[1805,1885,"Quinn here is gonna help you"],[1885,1922,"prep for your time"],[1922,2043,"as school principal, sir."],[2102,2160,"Yes, of course."],[2193,2260,"I've already arranged"],[2260,2344,"a welcoming ceremony."],[2389,2494,"Before the ceremony,"],[2548,2686,"I wanna walk the school tomorrow,"],[2736,2790,"alone,"],[2848,2936,"just by myself."],[3003,3065,"In the meantime,"],[3182,3303,"you sort out the ceremony."],[3340,3386,"Yes, sir."],[3440,3557,"We'll prepare a grand ceremony"],[3557,3653,"fit for your return."]],"33":[[1167,1242,"Mr. Conrad?"],[2331,2419,"You dropped this, Miss."],[2973,3023,"Who told you"],[3023,3182,"you could touch my belongings?"],[3199,3336,"Now I have to clean it."],[3653,3816,"And who let you in here, janitor?"],[3870,4008,"Ah, you reek."],[4045,4133,"It's disgusting."],[4225,4362,"Dean Wayne, is it?"],[4433,4587,"Are you saying that the school janitor"],[4587,4662,"can't eat in here?"],[4788,4863,"Look at yourself."],[4879,5017,"If janitors like yourself ate here,"],[5067,5138,"wouldn't be appetizing,"],[5138,5176,"would it?"],[5734,5764,"Trash like you"],[5764,5855,"should know your place."],[5918,5972,"Now get."]],"34":[[50,100,"You know,"],[175,216,"I never thought"],[216,346,"a high school cafeteria"],[346,475,"would be divided by class."],[517,600,"Is this what you're teaching"],[600,671,"your students?"],[754,842,"Shut up, janitor."],[909,992,"Who do you think you are,"],[1017,1201,"lecturing me in my school?"],[1317,1484,"Oh, it's your school?"],[1547,1601,"That's right."],[1622,1710,"I'm the dean here."],[1747,1843,"And my sister is married"],[1843,1918,"to Principal Wells."],[1964,2068,"So one call from me,"],[2156,2223,"you're out of here."],[2435,2506,"Mr. Conrad,"],[2610,2702,"you need to leave now."],[2748,2798,"He's right."],[2815,2894,"You can't fight him."],[3040,3169,"You know this smelly janitor,"],[3169,3240,"Pocahontas?"],[3274,3399,"What a pair,"],[3436,3582,"a redskin bookworm"],[3582,3724,"and a toilet-scrubbing"],[3724,3791,"corpse."],[3832,3991,"Are you two related or something?"],[4763,4813,"Let me show you"],[4813,4871,"what happens to those"],[4871,5067,"that disrespect me in my school."],[5455,5538,"Eat that off the floor,"],[5597,5663,"or else you"],[5709,5814,"and that little girl right there"],[5860,5943,"are in big trouble."],[5985,6297,"Eat! Eat! Eat!"]],"35":[[12,237,"Eat! Eat! Eat!"],[283,396,"Mr. Conrad, let's go."],[563,742,"You're not going anywhere."],[1071,1155,"What now, old man?"],[1205,1330,"You gonna let a little girl suffer"],[1330,1413,"because of your ego?"],[1459,1522,"Let her go."],[1634,1776,"Ooh, I'm shaking."],[1830,2047,"You know, I'm real sensitive to threats."],[2081,2173,"I'd hate to lose control."],[2648,2802,"Oops, I'm sorry, sweetie."],[2802,2886,"Let me help you back up."],[3103,3203,"Blame your janitor friend."],[3253,3315,"I was scared."],[3370,3445,"Couldn't help myself."],[3766,3824,"Oh, what?"],[3866,3945,"You gonna punch me now?"],[4037,4124,"Your old bones would crack"],[4124,4220,"with one punch from me."],[4262,4320,"Let her go."],[4375,4475,"You got three seconds."],[4500,4542,"Alright."],[4817,4854,"Come on,"],[4913,4984,"show me what you've got."]],"36":[[487,538,"Logan!"],[713,850,"Ah, filthy fucking janitor."],[850,946,"I'm gonna kill you myself."],[1459,1551,"That's impossible."],[2089,2143,"Let go."],[2177,2231,"Get off me."],[2252,2377,"Weren't you trying to make me eat this"],[2377,2489,"off the floor a minute ago?"],[2527,2681,"I've saved it for you, Dean Wayne."],[2815,2965,"You disgusting scumbag!"],[2965,3036,"From now on,"],[3119,3261,"there's new rules around here."]],"37":[[33,120,"I'm gonna kill you, old man."],[129,229,"I'm gonna fuck you up."],[529,629,"Get out of my sight."],[1209,1280,"All students,"],[1297,1451,"please report to the auditorium"],[1451,1547,"for the new principal's"],[1547,1630,"welcome ceremony."],[1889,1964,"Mr. Conrad,"],[2014,2118,"you need to leave now."],[2202,2314,"Once the ceremony ends,"],[2344,2456,"Dean Wayne will come after you."],[2594,2673,"The welcome ceremony"],[2673,2781,"is about to start, huh?"],[2844,3015,"Well, I can't be late."],[3282,3382,"