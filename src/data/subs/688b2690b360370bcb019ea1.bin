nned janitors from places"],[5180,5513,"like auditorium and cafeteria."],[5647,5847,"And he always calls me Pocahontas,"],[5930,6047,"a redskin princess."],[6060,6106,"Shut up!"],[6172,6235,"She's lying."],[6247,6293,"First of all-"],[7215,7290,"Go on, sweetheart."],[7440,7503,"What else did he do?"]],"52":[[45,116,"Go on, sweetheart."],[262,329,"What else did he do?"],[467,617,"Dean Wayne was gonna expel me"],[617,684,"with no cause."],[792,880,"That's why Mr. Conrad"],[880,934,"was pretending"],[934,1034,"to be the new principal,"],[1101,1197,"along with my mother."],[1242,1326,"My sweet girl,"],[1384,1568,"she's trying to protect Mr. Conrad."],[1664,1730,"Mr. Conrad,"],[1830,1906,"this all happened"],[1906,2027,"because of my incompetence."],[2122,2256,"I failed to manage my school"],[2356,2456,"and my subordinates."],[2515,2610,"Please let me make it up to you."],[2719,2811,"Tell me your demands, sir."],[2886,2986,"I promise you they'll be done."],[3065,3153,"My demands?"],[3240,3319,"Principal Wells,"],[3328,3432,"according to your dean,"],[3499,3732,"I'm just a janitor, a nobody."],[3766,3920,"Who am I to make demands"],[3920,4020,"on someone like you?"],[4124,4166,"Quinn,"],[4241,4341,"have you lost your mind?"],[4354,4391,"Why are you treating"],[4391,4446,"this guy like-"]],"53":[[20,70,"Quinn,"],[137,237,"have you lost your mind?"],[621,704,"Please, Mr. Conrad,"],[784,859,"give me a chance"],[859,984,"to right the wrongs that I made."],[1422,1614,"Arrest Logan Wayne right now"],[1630,1805,"for fraud, assault, and harassment."],[1893,2068,"I'll take him to the sheriff myself."],[2143,2185,"Now!"],[3770,3866,"Don't even try it."],[3937,4095,"One step, she's dead."]],"54":[[0,45,"Mom!"],[120,208,"Don't even try it."],[266,446,"One step, she's dead."],[600,738,"She's gonna be ok, I promise."],[809,850,"Logan,"],[905,1030,"let her go before it's too late."],[1046,1142,"She's with the Yellowstone."],[1255,1443,"If their boss or the foreman"],[1443,1534,"finds ou