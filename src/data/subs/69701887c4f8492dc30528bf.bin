hat?"],[5484,5622,"No, Andy! No!"],[5655,5718,"Stop!"],[5818,6072,"Call Bash and tell him you need him,"],[6072,6214,"or your baby dies."],[6973,7036,"Olivia!"],[7182,7328,"I shouldn't answer it."],[7357,7457,"But..."],[7478,7603,"what if she needs me?"],[7791,7845,"Hello?"],[7845,7970,"Bash, don't listen to them-"],[7970,8033,"Bash!"]],"51":[[283,400,"Bash,"],[421,546,"Andy and the loan sharks,"],[546,704,"they kidnapped me."],[704,804,"But you need to run!"],[804,950,"Save yourself, Ba-"],[1051,1176,"Olivia! What? Wait."],[1176,1292,"If you ever want to see your precious,"],[1292,1384,"little whore again,"],[1384,1626,"I suggest you listen very closely to me."],[1697,1910,"Don't you dare fucking hurt her!"],[1993,2193,"If Olivia means anything to you,"],[2193,2331,"you're going to replace her as our"],[2331,2460,"fucking hostage."],[2460,2573,"Because we both know you owe money"],[2573,2652,"to the fucking sharks,"],[2652,2781,"and you don't have shit!"],[2790,2940,"So you're going to be a little fight dog"],[2940,3044,"at the fight club."],[3098,3182,"And you're going to go to the"],[3182,3399,"fucking Blood Pit."],[3399,3499,"That's not boxing,"],[3499,3632,"that's a fight to the death."],[3661,3766,"They use knives and-"],[3766,3941,"And the pot is $1 million."],[3941,4229,"So once you win, we'll release her."],[4229,4362,"So you better find a fucking weapon"],[4362,4487,"if you ever want to see Olivia again."],[4817,4921,"Go upstairs to our fight."],[4921,5100,"I'll watch our pretty, little hostage."],[5655,5872,"I need to find a way out of these restraints."],[5951,6106,"I need to save Bash..."],[6151,6264,"and my baby."],[7244,7328,"There are three men"],[7328,7449,"you have to fight."],[7449,7595,"Fights are going to get more and more"],[7595,7724,"brutal as the night goes on."],[7724,7941,"But, you win them all,"],[7941,8091,"your girl goes free."],[8133,8254,"You don’t..."],[8254,8350,"Then I die."],[8437,8529,"You both do."],[9234,9342,"I'll win this,"],