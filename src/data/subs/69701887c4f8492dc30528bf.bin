he fuck are you doing here?"],[8383,8521,"I need to find your brother."],[8725,8762,"Get in."]],"29":[[487,575,"Thought the infamous Bash"],[575,713,"would be tougher than this."],[900,1038,"You’re weak, kid."],[1418,1522,"So Bash is fighting"],[1522,1651,"at this illegal club again?"],[1651,1818,"Tonight is The Last Breath Brawl."],[1818,1926,"High risk, high reward."],[1926,2002,"It's six figures."],[2002,2102,"But there's no rules."],[2102,2218,"Fighters die in there."],[2218,2348,"He could die?"],[2348,2477,"Why would he do this?"],[2477,2531,"I don't know,"],[2531,2656,"but if we don't find him now,"],[2656,2748,"he's dead."],[4195,4316,"Fight back!"],[4354,4441,"You're weak!"],[4441,4546,"Sebastian, you're weak!"]],"30":[[1234,1330,"This is for you,"],[1330,1455,"Olivia."],[2556,2615,"Olivia."],[2640,2702,"Again?"],[2731,2798,"You promised"],[2798,2952,"you would be there for me."],[2952,3036,"I needed you,"],[3036,3174,"and you just ignored me."],[3174,3265,"I did not ignore you."],[3265,3307,"I was..."],[3307,3507,"Fighting. Yet again."],[3507,3591,"You were what?"],[3632,3816,"Punching some guy for fun?"],[3816,3916,"That's not fair."],[3958,4195,"You know what's not fair, Bash?"],[4195,4333,"These fights."],[4333,4554,"Matty told me how dangerous they are."],[4554,4725,"It could have ended your career"],[4725,4909,"and your life."],[4909,5013,"Okay?"],[5013,5209,"I wouldn't know what to do"],[5209,5334,"if you were gone."],[5334,5459,"So why, Bash?"],[5459,5501,"Why?"],[5501,5584,"For you."],[5584,5834,"Liv, for you."],[6569,6664,"100 grand, right?"],[6731,6840,"To save your mom."],[6873,7023,"To stop you from needing Andy."],[7165,7303,"I keep my promises."],[7378,7511,"I am here for you, Liv."],[7511,7590,"Always."],[7682,7824,"But you shouldn't have."],[7857,7982,"I told you I would."],[7991,8070,"No."],[8099,8337,"You really shouldn't have, Bash."],[8362,8533,"I haven't told you the full truth,"],[8533,8612,"okay?"],[8666,8829,"Andy didn't just threaten my mom,"],[8900,8963,"okay?"],[9034,9125,"If I leave him,"],[9125,9267,"he's going to come after you."],[9267,9484,"He's going to try to ruin your career"],[9484,9680,"and I won't let him."],[9784,9909,"So you"],[9909,10080,"stayed with him to protect me?"],[10377,10489,"Damn it,"],[10489,10535,"Olivia!"]],"31":[[58,145,"I am sorry that I lied."],[145,300,"No, no."],[442,588,"I am not mad at you."],[588,717,"I am mad at myself."],[775,905,"I let you get hurt for me."],[905,1117,"I am supposed to protect you."],[1117,1401,"I never asked you to do that."],[1447,1559,"You didn't ask."],[1559,1739,"I want to be there for you."],[2652,2756,"I want you."],[2836,2948,"You do?"],[3082,3194,"You don't believe me?"],[3340,3495,"Let me convince you."],[5155,5259,"In the ring,"],[5259,5392,"I hit to survive."],[5605,5676,"Here,"],[5797,5922,"I touch"],[5922,6110,"so I can feel alive."],[7570,7682,"God!"],[7682,7828,"His tongue...."],[7828,8066,"I never feel this way."],[8491,8641,"I’ve seen him in the ring."],[8683,8850,"Can I handle him in bed?"]],"32":[[0,104,"Be gentle."],[2840,2919,"How can someone"],[2919,3103,"who fights like a monster"],[3103,3336,"touch me like this?"],[3370,3620,"I need you Bash, now."],[5584,5718,"What the fuck is happening in here?"]],"33":[[254,383,"What the fuck is wrong with you?"],[383,492,"I needed the money,"],[492,563,"and it was good practice"],[563,642,"for the fight."],[642,754,"Not you, Bash."],[754,838,"I'm talking to her!"],[934,1259,"Matty, I didn't ask Bash to do that. I..."],[1259,1434,"I never would ask him to."],[1434,1559,"Maybe you didn't ask him,"],[1559,1664,"but you didn't have to."],[1664,1839,"He would never be in this situation"],[1839,1972,"if it wasn't for you!"],[1972,2131,"Are you serious, Matty?"],[2131,2302,"If caring for Bash is a crime,"],[2302,2427,"then put me in jail"],[2427,2623,"because I will do the time!"],[2623,2756,"If you really cared about him,"],[2756,2923,"you'd leave him the fuck alone!"],[2923,3069,"He's got a real shot at going pro,"],[3069,3174,"and you're fucking with that!"],[3174,3224,"Am I?"],[3224,3340,"Are you just mad"],[3340,3503,"you might lose your golden ticket"],[3503,3624,"out of this town?"],[3624,3787,"Stop being his manager"],[3787,3970,"and start being his fucking brother,"],[3970,4049,"Matty!"],[4049,4154,"Don't talk to us"],[4154,4362,"like you know us, Olivia!"],[4362,4558,"So what, you guys fuck?"],[4558,4804,"He is my little brother!"],[4804,4871,"I’m the one"],[4871,5038,"who took so many beatings for him"],[5038,5221,"that I can't even box anymore!"],[5221,5405,"I'm the one who is working three jobs"],[5405,5547,"just so he can train!"],[5547,5647,"I gave him this shot!"],[5647,5768,"Don’t take it away."],[5768,5847,"Matty, stop!"],[5847,5985,"No, Bash. He's right."],[6056,6293,"I'm the reason you almost died tonight,"],[6293,6544,"and I don't want to be the reason why."],[6977,7032,"Olivia, wait."],[7032,7073,"No."],[7165,7307,"Please just don't follow me."],[7549,7720,"If you walk out that door, I will quit"],[7720,7803,"right now."]],"34":[[150,200,"Because without you,"],[200,266,"there's no reason"],[266,400,"for me to keep going."],[763,955,"So you'd rather fuck her,"],[955,1080,"than go after the dream"],[1080,1217,"that you've always had?"],[1217,1272,"If anything,"],[1272,1351,"she's the reason"],[1351,1422,"I want to"],[1422,1547,"accomplish my dreams."],[1584,1835,"Ever since I found her,"],[1889,1943,"every time"],[1943,2131,"I picked myself up in that ring."],[2131,2298,"Every time I raise my fist"],[2298,2360,"while bleeding,"],[2360,2565,"it's because of her."],[2565,2627,"So no,"],[2627,2752,"I'm not going anywhere"],[2752,2857,"without her."],[3111,3282,"There's nothing you can do"],[3282,3395,"because you're not our dad."],[3395,3503,"No,"],[3503,3624,"because our dad"],[3624,3787,"would be beating your ass right now!"],[4095,4262,"Oh what, so you're Dad now?"],[4287,4441,"Go ahead, Bash, hit me!"],[4441,4554,"I know you've always wanted to."],[4554,4633,"Hit me!"]],"35":[[16,58,"Hit me!"],[58,183,"No! Stop!"],[237,275,"Please."],[400,613,"I'm not our fucking father, Matty!"],[742,900,"I'm only violent in the ring,"],[900,1030,"and I fight to protect"],[1030,1138,"what he destroyed!"],[1180,1259,"And that's not going to change,"],[1259,1397,"no matter how much you try and"],[1397,1472,"piss me off!"],[1580,1726,"Unless you hurt her,"],[1864,2002,"then all bets are off."],[2406,2498,"Let’s go."],[4312,4454,"Sorry about Matty."],[4558,4608,"I'm not going to let"],[4608,4721,"my brother ruin this."],[4763,4963,"And what about you ruining it, huh?"],[5067,5230,"You know, I can't keep wondering"],[5230,5309,"if the next fight"],[5309,5463,"is going to be your last."],[5484,5726,"What if I promise that I'd never"],[5726,5947,"fight an illegal match ever again."],[6039,6097,"Really?"],[6214,6352,"You would do that for me?"],[6427,6502,"I would."],[6727,6827,"I promise."],[7957,8137,"Thank you so much"],[8137,8274,"for getting that money for my mom,"],[8274,8379,"Bash."],[8487,8533,"You know,"],[8533,8712,"every time I visit her in the hospital,"],[8775,8958,"I brush her hair,"],[8958,9188,"just like she did when I was a kid."],[9192,9346,"She would do anything"],[9346,9442,"to protect me,"],[9471,9709,"to take care of me, and I just..."],[9818,9889,"I wish that I could"],[9889,10097,"do the same for her."],[10231,10406,"You do, Liv."],[10406,10602,"You've been doing it all alone."],[10660,10798,"But you don't have to anymore."],[10890,11036,"You have me."],[11903,12028,"But,"],[12187,12278,"there is one thing that"],[12278,12416,"I still need from you."]],"36":[[221,354,"Go get a shower, champ."],[462,713,"You still smell like blood and sweat."],[779,817,"Okay."],[1021,1117,"Only if you come with me."],[2168,2214,"Fine."],[2302,2464,"You win, Mr. Boxer."],[2569,2640,"Take me."],[2773,2865,"Take all of me."],[3007,3207,"Oh my God, he’s so..."],[3219,3307,"I’m so..."],[3307,3420,"fucking hard."],[3486,3578,"I want to see you."],[4387,4604,"I love it when he claims me over and"],[4604,4696,"over again."],[4871,4984,"I’m going to explode."],[5643,5801,"I never thought I would survive Andy,"],[5801,5843,"but,"],[5930,6006,"here I am,"],[6064,6172,"with Bash."],[6940,7140,"It feels like life has given us a second"],[7140,7215,"chance."],[7912,8003,"Stay strong, go!"],[8020,8103,"Dig deep!"],[8158,8249,"- Bash... - Let’s go!"],[8249,8337,"- On his way to his - Come on!"],[8337,8516,"legit boxing dreams."],[8558,8621,"Why are you resting?"],[8704,8767,"And me,"],[8783,8900,"making enough money to"],[8900,9109,"support my mom without Andy's help."],[9922,10101,"But just when things start going well,"],[10147,10389,"your past comes back to haunt you."]],"37":[[412,496,"Thought you're off tonight."],[625,667,"Yes."],[667,855,"Well, I had to pick up an extra shift."],[888,921,"You know..."],[934,1051,"send more money to my mom's"],[1051,1138,"doctors."],[1413,1509,"Oh, shit."],[1509,1609,"I was supposed to drop off my"],[1609,1739,"paycheck at the hospital,"],[1764,1897,"pay for my mom's next treatment."],[1897,1935,"But..."],[2010,2147,"I've just been so busy working,"],[2147,2268,"I haven't had time to visit her and-"],[2268,2314,"Let me go."],[2456,2552,"I can go to hospital."],[2644,2731,"Anything for your mom."],[4437,4521,"Thank you."],[5880,5955,"You know every time I visit her"],[5955,6064,"in the hospital,"],[6064,6193,"I brush her hair."],[6218,6385,"Just like she did when I was a kid."],[8041,8153,"Don’t worry Mrs. Beckett."],[8279,8416,"I'm going to take care of you..."],[8571,8662,"and your daughter."],[9409,9455,"What are you..."],[9609,9730,"what are you doing in my room?"],[9805,9889,"You're not Andy."]],"38":[[20,100,"You're not Andy."],[221,254,"What..."],[283,362,"what are you doing here?"],[450,558,"You probably don't remember me."],[713,804,"I came here a couple of times"],[804,880,"with Olivia."],[1059,1121,"I’m Bash."],[1251,1309,"I’m..."],[1393,1451,"not Andy."],[1743,1835,"And I’m sorry I..."],[1922,2014,"I know I'm not good enough for"],[2014,2097,"your daughter, but-"],[2097,2185,"Not good enough?"],[2435,2469,"You."],[2640,2852,"You've been making my Olivia smile."],[2852,2919,"I can see it."],[3111,3165,"And now"],[3269,3345,"you’re here and"],[3378,3474,"checking up on me."],[3803,3891,"Because you know,"],[3987,4129,"it's important to my daughter."],[4337,4437,"I care about her."],[4658,4771,"I want her to be happy."],[4921,5009,"That's what matters."],[5125,5234,"Take this,"],[5292,5359,"Bash."],[5930,5989,"For you"],[6039,6156,"to give to my daughter"],[6243,6318,"when you're ready."],[6410,6560,"Olivia's mom wants us together."],[6623,6664,"I..."],[6731,6827,"I’m good enough for her?"],[6915,7044,"I need to tell her I love her."]],"39":[[542,650,"Looks like he isn’t here."],[717,817,"Boss is going to be mad if we don't"],[817,888,"make contact."],[1188,1247,"Don't worry."],[1368,1455,"There’s more than one way"],[1455,1564,"we can send a message."],[1639,1710,"Shit."],[1714,1801,"These guys are breaking into"],[1801,1906,"Bash’s boxing gym."],[1931,2097,"I can't let them find him"],[2139,2202,"or me."],[2277,2448,"I've never told a girl I love her before."],[2515,2552,"I..."],[2610,2690,"I love you, Liv."],[2727,2765,"Nope."],[2815,2898,"No, that's wrong."],[3570,3707,"Think I found just the thing."],[3970,4016,"I..."],[4079,4133,"I love you,"],[4158,4225,"Olivia."],[4287,4337,"Better."],[4612,4658,"Please."],[4813,4996,"I don't know what you want,"],[4996,5038,"but,"],[5067,5201,"this gym means a lot to someone"],[5201,5342,"that I care very much about and"],[5413,5568,"I'm begging you. Please, just..."],[5568,5668,"just leave it alone."],[5734,5968,"I won't call the cops or anything."],[6022,6097,"Oh yeah?"],[6185,6243,"And what are you going to give us"],[6243,6306,"in return?"]],"40":[[0,45,"No!"],[66,241,"Don't fucking touch me!"],[296,450,"Don't touch anything in here."],[504,650,"Bash will kick your ass if you hurt me."],[650,729,"Just get out!"],[804,909,"Hold this bitch!"],[925,1013,"No, no!"],[1159,1280,"We’re here to deliver a message"],[1280,1351,"for Bash."],[1363,1426,"And you,"],[1455,1572,"are going to be the messenger."],[1605,1655,"No!"],[1730,1885,"Keep your eyes on me, sweetheart."],[1918,2039,"You're not going to want to miss this."],[2252,2285,"No."],[2427,2498,"No, no, no,"],[2498,2565,"no, no."],[2681,2740,"Stop!"],[2790,2877,"No, that's enough!"],[2877,3028,"Please, please."],[3028,3136,"I don't think that is enough."],[3278,3495,"You seem to be real fond of Bash."],[3495,3553,"So, uh..."],[3641,3828,"I guess there's one last thing I have to"],[3828,3895,"destroy."],[3966,4033,"Fine."],[4074,4204,"Do whatever you want with me, just"],[4254,4362,"leave the gym alone."],[4412,4571,"Aw, aren’t you a tough girl with your"],[4571,4704,"little, pink boxing gloves?"],[4733,4896,"I can do damage with these little, pink"],[4896,4996,"gloves, you asshole!"],[5050,5180,"I have a world renowned trainer."],[5205,5326,"Why not make a deal, princess?"],[5397,5526,"Tell us where your trainer is,"],[5568,5634,"and we’ll leave."],[5684,5839,"If I tell them where Bash is"],[5885,5980,"they'll hurt him."],[6006,6093,"How about this?"],[6156,6302,"I don't tell you shit and you leave,"],[6318,6431,"because if you don't..."],[6443,6569,"he's going to fuck you up."],[6589,6715,"I don't see him anywhere. Do you?"],[6773,6948,"Your little boyfriend is nothing but a"],[6948,7077,"pathetic, fucking loser who can’t"],[7082,7265,"even pay for his family's debts."],[7269,7486,"Those debts aren't his to pay!"],[7536,7691,"And plus, he's not a coward"],[7691,7866,"threatening girls half his size."],[8016,8074,"Hold her."],[8095,8124,"No!"],[8166,8245,"No, please."],[8262,8429,"We’re here to send Bash a message,"],[8487,8583,"and that message..."],[8596,8625,"No!"],[8633,8692,"is you!"]],"41":[[50,91,"Now,"],[162,291,"tell us where he is"],[379,483,"or you can get some more."],[546,721,"I'm not scared of pain."],[784,905,"I’ve survived worse!"],[1134,1180,"Aw, bitch!"],[1226,1397,"That's defense, bitch!"],[2052,2231,"I can't give up."],[2285,2419,"I need to fight."],[2419,2515,"For Bash."],[2552,2635,"Where's Bash?"],[2723,2936,"You can’t take what I’d die to protect."],[2982,3157,"And I’m not giving up just because"],[3157,3236,"you’re beating me up."],[3236,3282,"Because..."],[3374,3536,"because nothing hurts worse than"],[3536,3599,"losing him,"],[3599,3695,"you fucking rats!"],[3774,3845,"That's sweet."],[3978,4054,"I don’t think she’s going to give him"],[4054,4112,"up, Boss."],[4158,4208,"Please."],[4233,4283,"Fine."],[4358,4525,"There is only one thing left to do."],[4554,4617,"No, no, no!"],[4967,5096,"Bet you Bash will get the message"],[5096,5138,"now."],[5651,5705,"Olivia!"],[5743,5864,"I got to tell you something!"],[5893,5939,"I love..."],[6293,6348,"Olivia?"],[6477,6552,"Olivia?"],[6631,6690,"Hey."],[6756,6798,"Oh."],[6819,6911,"No, no, no, no."],[6961,7015,"Look at me!"],[7152,7228,"Oh, come on."],[7478,7574,"Somebody help!"],[8195,8274,"No."]],"42":[[291,454,"I'm so sorry, Olivia."],[738,821,"I love you."],[1113,1197,"Please wake up."],[1639,1701,"Bash,"],[1701,1818,"just hear me out, okay?"],[1818,1851,"No."],[1918,1985,"I mean what are you doing?"],[1985,2110,"You don't give a shit about her!"],[2127,2243,"It's the opposite."],[2256,2364,"If you cared about her,"],[2364,2489,"you wouldn't be here."],[2515,2644,"What the fuck does that even mean?"],[2698,2773,"Just look at her."],[2915,3007,"Before she met you,"],[3007,3236,"she was just a rich college girl"],[3236,3340,"with a perfect life."],[3424,3474,"Now?"],[3536,3707,"She's getting her ass kicked by loan"],[3707,3908,"sharks that our dad owes money to."],[4049,4112,"Now that he's dead,"],[4112,4270,"you know they're never going to stop"],[4270,4375,"coming after us."],[4404,4537,"And they won't just hurt you."],[4579,4667,"They're going to hur