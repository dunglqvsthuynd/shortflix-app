{"1":[[75,204,"They say there's a thin line"],[204,400,"between love and hate."],[962,1100,"I never believed that"],[1216,1550,"until I met Baron Vicious Spencer."],[1566,1741,"The man I almost loved,"],[1800,2020,"even though he ruined me."],[2041,2187,"I finally found you,"],[2275,2366,"Help."],[3512,3566,"Mom?"],[4454,4612,"You're sleeping with our boss?"],[4616,4800,"Honey, this housekeeping job"],[4800,4941,"means that we can finally afford"],[4941,5079,"your sister's treatments."],[5079,5204,"I'm gonna do anything I can"],[5204,5304,"to keep her alive."],[5366,5504,"Promise me that you won't"],[5504,5666,"go near Mr. Spencer's son."],[5704,5816,"Don't let him use you"],[5816,5941,"like his father used me."],[6025,6091,"I won't."],[6091,6241,"Mom, I won't go near him."],[6712,6866,"...with all your bullshit!"],[6912,7125,"Mom's body isn't even cold."],[7179,7312,"And you're over here just, what?"],[7312,7441,"Just fucking the help?"],[7712,7962,"It was a moment of weakness, son."],[7979,8266,"I don't give a fuck about the help,"],[8266,8416,"and neither should you."],[8441,8516,"Fuck you."],[8516,8600,"You need to learn to"],[8600,8779,"address your father with respect."],[8841,9029,"Kneel down."],[11429,11554,"No wonder my mom"],[11554,11675,"warned me about him."],[11754,11979,"He's beautiful."],[12029,12137,"Where did she come from?"],[12175,12341,"She's beautiful."],[12854,12991,"I'm so sorry."],[13150,13350,"I, I saw what your father did to you."],[13379,13616,"I don't know what you think you saw."],[13704,13766,"But you better"],[13766,13941,"keep your fucking mouth shut."],[14016,14216,"Don't walk away from me."]],"2":[[650,925,"Who the fuck do you think you are?"],[937,1062,"Excuse me?"],[1129,1187,"I'm the girl"],[1187,1354,"whose mother you just insulted."],[1429,1491,"The help?"],[1491,1579,"She deserved it."],[1604,1691,"Your mother's a whore."],[1766,1879,"Makes you one too."],[1879,2091,"I can't believe I felt sorry for you."],[2454,2604,"She saw me at my lowest."],[2616,2675,"Letting her go"],[2675,2800,"would break something in me."],[2800,2904,"I don't need your pity."],[3100,3212,"You think you know what you saw?"],[3275,3487,"You think you know who I am?"],[3537,3666,"You haven't seen anything yet,"],[3775,3829,"Help."],[4154,4291,"I wanted to help him,"],[4316,4429,"but he's a bully"],[4462,4579,"just like his father."],[4675,4866,"I refuse to let him torture me."],[6362,6429,"Vicious."],[6879,7016,"That asshole."],[7916,8104,"Ever since that day in his bedroom,"],[8104,8279,"Vicious has been on a mission"],[8279,8441,"to make my life hell."],[9304,9358,"What?"],[9358,9566,"My extra uniform is in my locker."],[9616,9666,"Cool."],[9900,10066,"He's trying to push my buttons,"],[10066,10216,"but I won't let him win."],[10350,10462,"Mr. Spencer,"],[10491,10579,"I need you"],[10579,10729,"to move away from my locker-"],[10729,11029,"What you need to do is go home"],[11029,11325,"and do my fucking laundry,"],[11341,11404,"Help!"],[11416,11566,"Is she a fucking maid?"],[11566,11604,"What?"],[11604,11766,"You're a poor little scholarship student"],[11866,12041,"and Vic's the richest guy in school."],[12104,12212,"He's out of your league."],[12250,12329,"His league?"],[12429,12629,"Yeah, I am not even playing his game."],[12654,12800,"I don't fight dirty to win."],[12829,12891,"You will,"],[13037,13191,"once I push you far enough."],[13229,13375,"Once I've gotten under your skin"],[13375,13512,"the way you've gotten under mine."]],"3":[[20,108,"Move"],[166,254,"away"],[308,420,"from my locker."],[420,483,"What?"],[504,616,"Are you gonna fight me?"],[720,795,"Go for it."],[804,945,"Stand up for yourself."],[945,1145,"And then my mother will pay the price,"],[1170,1304,"and Rosie won't get the treatment"],[1304,1391,"she needs."],[1420,1470,"Why are you"],[1470,1608,"torturing me, Vicious?"],[1879,2033,"Because you saw me at my worst."],[2083,2183,"Because you haven't left my head"],[2183,2341,"since I first laid eyes on you."],[2454,2558,"Because I can."],[2558,2670,"Because it's fun."],[2708,2820,"Because"],[2858,2954,"there is"],[3008,3104,"nothing"],[3220,3354,"you can do about it."],[3541,3616,"Oh!"],[3666,3745,"I hate you!"],[3883,3979,"You're gonna regret that!"],[4516,4679,"Whoa, easy."],[4729,4816,"Who are you running from?"],[5054,5154,"Vicious, huh?"],[5245,5354,"Don't let him get to you."],[5395,5495,"He's my best friend."],[5495,5670,"He's also the biggest asshole I know."],[5816,5870,"Okay."],[6070,6129,"Hey."],[6291,6408,"You wanna skip first period?"]],"4":[[1487,1537,"Fuck."],[1929,2062,"I told you not to bring her here."],[2062,2129,"What the fuck's the matter"],[2129,2216,"with you, man?"],[2262,2416,"We're settling this, now."],[2475,2541,"And try not to cry"],[2541,2654,"when I break your face this time."],[2679,2829,"Back off, Vicious."],[2850,2916,"Didn't I warn you"],[2916,3050,"to stay in the servant's quarters,"],[3100,3154,"Help?"],[3262,3391,"Now Dean has to pay."],[3487,3662,"This is your fault."],[4566,4704,"What the fuck?"],[5137,5275,"Vicious is a bully."],[5304,5416,"He doesn't want me,"],[5416,5616,"he just loves to torture me."],[5925,5991,"What do you want?"],[6029,6125,"Where's Dean?"],[6154,6366,"This shit stops now."],[6366,6504,"Leave me alone."],[6566,6679,"What do you want from me?"],[6966,7162,"I want you to break up with Dean."],[7187,7262,"What?"],[7262,7329,"No."],[7375,7541,"No, he makes me happy."],[7754,7854,"You're a bad liar."],[7979,8091,"Ask me what I want again."],[8137,8216,"What do you want?"],[8216,8454,"I want to hurt you"],[8525,8687,"as bad as it hurts me"],[8704,8900,"to see you kiss my best friend"],[8900,9175,"every God damn day."],[9241,9379,"Don't act like you're jealous."],[9504,9654,"I know you're just punishing me."],[9737,9850,"Because you hate your father."],[9850,9929,"Because"],[9991,10104,"you hate yourself."],[10325,10516,"You don't know the first thing"],[10516,10616,"about me."],[10650,10741,"Ask me what I want."],[10841,11037,"What do you want, Vicious?"],[11216,11287,"I want you"],[11387,11462,"under me,"],[11554,11729,"drowning in me,"],[11812,11925,"screaming my name."],[12129,12225,"I want to kiss you."],[12379,12516,"And I want you to kiss me back."]],"5":[[50,154,"What am I doing?"],[229,404,"Vicious is cruel,"],[441,512,"arrogant,"],[529,616,"dangerous."],[704,791,"He's everything"],[791,916,"I should stay away from."],[1175,1237,"Wait."],[1300,1454,"Vicious, you know I can't do this."],[1575,1779,"Then ask me one more question, Help."],[1941,2179,"Ask me what your sister tasted like"],[2179,2279,"when I kissed her tonight."],[2429,2512,"Just like you."],[2662,2741,"Only sweeter."],[2829,2912,"Fuck you!"],[2991,3037,"You."],[3204,3262,"Why can't you"],[3262,3412,"stay the hell away from her?"],[4466,4625,"Take me back to your place?"],[4691,4775,"Of course."],[5200,5287,"Well, it looks like your little"],[5287,5404,"power play didn't work."],[5491,5587,"She picked me."],[5604,5716,"She's dying for someone"],[5716,5837,"to swipe her v-card."],[5987,6287,"Don't say another word."],[6325,6441,"Chill out, man."],[6441,6587,"That's all I want with her."],[6616,6741,"Maybe after I'm done,"],[6791,6904,"you can have a turn."],[7112,7212,"I wanted her to suffer"],[7212,7316,"for what her mother did."],[7441,7591,"But I can't watch Dean destroy her."],[7775,8062,"I will give you $10,000"],[8062,8179,"to break up with Dean"],[8179,8275,"and disappear."],[8375,8479,"$100,000."],[8541,8600,"No."],[8712,8841,"Why the hell would I do that?"],[8841,9216,"Because I will fire your whore mother."],[9304,9416,"Then who's gonna take care of"],[9416,9591,"poor little Rosie's medical bills?"],[9625,9766,"You can't be serious."],[9816,9987,"Do you really hate me that much?"],[9987,10054,"Do you wanna see me"],[10054,10191,"miserable that bad?"],[10191,10325,"Leave after school ends."],[10416,10516,"You and Dean are done."],[11362,11541,"And if you try to get out of this,"],[11541,11691,"I promise"],[11812,11950,"I won't just fire your mother."],[11966,12000,"I'll make sure"],[12000,12154,"she never finds another job again."],[12204,12291,"Goodbye, Help."]],"6":[[25,158,"Your day job laid you off?"],[175,312,"So McCoy's is all you've got left?"],[337,487,"Don't worry, Rosie."],[550,675,"Look, I have enough saved up"],[675,750,"to buy your medicine,"],[750,858,"and I took out some cash"],[858,987,"to pay rent after work."],[1095,1225,"I'll land something else soon."],[1300,1400,"I have to."],[1425,1612,"Or the money will all run out."],[1683,1775,"Hey, what are you doing?"],[1775,1837,"Stop!"],[1883,1916,"Let..."],[1945,1987,"Stop!"],[2362,2475,"Wait, that's all I have left."],[2475,2575,"Please, please!"],[2625,2700,"Damn it!"],[3258,3383,"You're ten minutes late."],[3383,3562,"I know, Rachel, I was mugged."],[3562,3662,"I, I'm so sorry."],[3662,3800,"He took everything that I had-"],[3800,3887,"Excuses."],[3887,4100,"One more slip, and you're gone."],[4137,4262,"Take this to table two."],[4300,4375,"Of course."],[5258,5458,"Isn't that Baron Spencer,"],[5458,5575,"the billionaire lawyer?"],[5737,5945,"I heard he makes all his girlfriends"],[5945,6050,"sign NDAs."],[6225,6412,"It's been ten years, Emilia LeBlanc."],[6458,6608,"Let's see how you survived without me."]],"7":[[145,195,"Hey!"],[270,345,"Hey, you!"],[420,570,"What is Vicious's asshole friend"],[570,708,"from high school doing here?"],[733,854,"Yeah!"],[920,1058,"Just what I needed today."],[1416,1579,"Hey!"],[1579,1708,"Heard you were slumming it"],[1708,1820,"as a waitress."],[1858,1983,"No surprise there!"],[1983,2158,"Good to see you too, Trent."],[2270,2358,"What can I get you?"],[2358,2416,"What?"],[2458,2658,"You don't wanna know how I'm doing?"],[2658,2766,"Trent, I already know that"],[2766,2929,"you and your friends made billions."],[2933,3133,"You do not have to shove it in my face."],[3170,3241,"So if you're not gonna be"],[3241,3341,"ordering anything,"],[3341,3420,"then goodbye."],[3420,3645,"Hey, relax!"],[3645,3858,"I am a generous tipper."],[4054,4145,"Rumor has it,"],[4145,4304,"you'll do anything for money."],[4354,4520,"What does a hundred bucks give me, huh?"],[4541,4600,"What is it with you"],[4600,4695,"rich guys and money?"],[4729,4883,"Do you really think it makes you cool?"],[4908,5095,"Oh, come on!"],[5120,5216,"Emilia."],[5304,5433,"You've had Vicious."],[5458,5579,"You've had Dean."],[5616,5687,"How about adding"],[5687,5808,"one more HotHole to your"],[5808,5937,"collection? - Let me go, Trent!"],[7433,7629,"Still getting into trouble, Help?"],[8145,8208,"Vicious."]],"8":[[12,200,"Of course he's behind this."],[258,470,"He's always loved to see me squirm."],[470,750,"That little bitch broke my nose!"],[750,900,"Did you forget the rules,"],[912,1037,"or decide they don't apply to you?"],[1037,1208,"She's off limits!"],[1987,2137,"First you show up late,"],[2137,2312,"and then you trash the place?"],[2337,2400,"Do you know"],[2400,2545,"how much this is gonna cost me?"],[2562,2650,"You're fired!"],[2687,2762,"The damages"],[2762,2895,"will come out of your paycheck."],[2912,3050,"No, no, please, please!"],[3050,3175,"I need this job!"],[3433,3500,"Damn it!"],[3712,3912,"You took everything from me once!"],[3962,4075,"Wasn't that enough?"],[4562,4695,"How am I gonna tell Rosie"],[4695,4850,"that I lost the only job"],[4850,4962,"that I had left?"],[5583,5662,"Hello, Help."],[5958,6037,"You don't get to come back"],[6037,6200,"and ruin my life all over again."],[6275,6350,"Leave."],[6375,6437,"Make me."],[6550,6725,"Why did you come back here?"],[6787,6937,"What do you want from me, Vicious?"]],"9":[[766,845,"Ow."],[1062,1220,"After everything he's done,"],[1250,1404,"I'm standing here frozen,"],[1433,1600,"struck by his beauty"],[1600,1775,"just like the first time we met."],[1808,1970,"What is wrong with me?"],[2066,2216,"What do you want from me?"],[2433,2570,"Does that answer your question?"],[2704,2845,"This is what gets you hard?"],[2920,3066,"The idea of ruining my life"],[3066,3166,"so thoroughly"],[3166,3358,"that I finally fuck you?"],[3395,3520,"Yeah, well, I hate to break it to you,"],[3520,3633,"but the idea of"],[3633,3820,"my high school bully torturing me"],[3820,3995,"doesn't exactly turn me on."],[3995,4104,"Are you sure about that?"],[4183,4483,"Because the heat between your legs"],[4483,4595,"tells a different story."],[4670,4833,"You've always wanted me, Emilia."],[5070,5145,"Admit it."],[5245,5679,"What I want is to pay my fucking bills."],[5720,5808,"And now that I'm fired,"],[5808,5920,"I can't even do that."],[5995,6191,"I needed this job, Vicious."],[6241,6358,"When I sent her away,"],[6408,6491,"I knew I was making her"],[6491,6608,"leave everything behind."],[6683,6733,"But I didn't know"],[6733,6883,"how much I was ruining her future."],[6945,7108,"Do you need my help, Help?"],[7233,7333,"Whatever I need,"],[7383,7520,"I don't want it from you."],[7554,7616,"Wait."],[7816,7916,"Don't forget your tip."],[8145,8320,"That money could cover rent"],[8320,8545,"and Rosie's medical bills for months."],[8566,8670,"It's not even signed."],[9154,9220,"It will be..."],[9883,9995,"when you come work for me."]],"10":[[54,229,"Whenever you blow up someone's life,"],[229,366,"they would rather die"],[366,495,"than be on your payroll."],[516,570,"Yeah."],[695,833,"I know your sister's sick."],[908,1016,"$200,000."],[1070,1208,"You won't have to worry about"],[1283,1404,"paying for her meds again."],[1458,1620,"You paid me to disappear."],[1691,1783,"Why force me back"],[1783,1920,"into your life, Vicious?"],[1958,2108,"Because you're still under my skin,"],[2141,2258,"all these years later."],[2295,2545,"Because you look very cold"],[2629,2779,"in this little stripper outfit."],[2908,3045,"Not that I'm complaining."],[3066,3133,"Fuck you!"],[3133,3254,"Do you realize"],[3254,3429,"what you're walking away from?"],[3504,3795,"Then be a good girl and take the money."],[3983,4258,"Consider it a signing bonus."],[4308,4395,"Call me"],[4458,4566,"when you're ready to come work."]],"11":[[279,433,"Millie, I don't feel so good."],[545,620,"Rosie?"],[645,720,"Rosie!"],[783,854,"Oh my God!"],[1266,1333,"Please!"],[1395,1479,"Please, I, I need an"],[1479,1604,"ambulance right now!"],[1966,2095,"Your sister's stable enough"],[2095,2191,"to go home tomorrow."],[2191,2350,"Oh my God. - But she"],[2350,2458,"needs treatment"],[2458,2583,"if she's ever gonna get better."],[2745,2808,"Your bill."],[3654,3795,"Your sister's ongoing treatment"],[3795,4008,"will cost $10,000 per month."],[5379,5545,"Call me when you're ready to come work."],[6379,6495,"I accept your offer."]],"12":[[387,600,"Hi, uh, I'm here to see Vic-"],[737,825,"Mr. Spencer."],[895,1025,"I'm his new PA."],[1045,1200,"I'm Mr. Spencer's PA."],[1220,1308,"What the fuck?"],[1350,1520,"There's no way he'd hire her."],[1520,1575,"Oh."],[1650,1737,"Oh no, that's good."],[1900,1983,"The thing is that,"],[2012,2112,"you're dressed like a hooker"],[2112,2225,"at a clown convention."],[2225,2400,"Mr. Spencer already has a PA."],[2504,2579,"It's me."],[2579,2662,"Is this another one"],[2662,2825,"of Vicious's cruel jokes?"],[2825,2925,"Did he hire me"],[2925,3100,"just to humiliate me again?"],[3120,3258,"Could you call him for me, please?"],[3258,3345,"Oh, honey."],[3362,3512,"You're like the third girl"],[3512,3612,"who's tried to come in here"],[3612,3825,"and slither on into Mr. Spencer's bed"],[3825,4025,"since he made Forbes 30 Under 30."],[4025,4150,"And, uh, well..."],[4187,4300,"You're not his type."],[4300,4445,"Okay, um, I am not here"],[4445,4575,"to sleep with Mr. Spencer."],[4575,4675,"I'm here to do the job"],[4675,4775,"that he offered me."],[4875,4958,"Hey! No!"],[4958,5050,"Security!"],[5225,5350,"What kind of game are you playing?"]],"13":[[25,150,"You already have a PA."],[150,287,"What the hell am I doing here?"],[312,550,"Mr. Spencer, this psycho bitch"],[550,700,"just verbally assaulted me"],[700,837,"and, and just forced her way"],[837,937,"into your office. - Hey."],[970,1025,"Stop."],[1320,1425,"What was your name again?"],[1450,1550,"It's Sue."],[1575,1650,"Sue."],[1733,1833,"You're fired."],[1950,2087,"Get her out of my office"],[2108,2337,"and revoke her access immediately."],[2408,2437,"Come on,"],[2437,2512,"wait, wait!"],[2512,2570,"Hey!"],[2570,2687,"No! Wait!"],[2687,2762,"Come on!"],[2762,2820,"No!"],[5370,5500,"Your employment contract."],[5512,5587,"Sign it."],[5587,5737,"I swore I would never"],[5737,5900,"let Vicious own me again."],[5933,6120,"But as much as I hate to admit it,"],[6175,6337,"I need the money."],[6337,6412,"I need him."],[6808,7020,"That officially makes you mine, Help."],[7187,7383,"I was never yours."],[7412,7483,"Oh, really?"],[7795,7970,"How about you walk up to that door?"],[7970,8133,"You can't tell me what to do."],[8162,8358,"I'm your boss now."],[8375,8483,"Unless you want me to rescind"],[8483,8595,"my offer, Ms. Leblanc."],[8625,8725,"What the hell kind of game"],[8725,8837,"is he playing now?"],[11125,11195,"Careful."],[11429,11562,"Hey, who opened the blinds?"],[11562,11654,"What's happening?"],[11833,11950,"Is somebody in there?"],[11975,12170,"If you move even an inch..."],[12187,12358,"I thought the boss was in there."],[12400,12575,"Everyone in the office will see you."]],"14":[[166,225,"Are you trying to"],[225,404,"humiliate me, Vicious?"],[450,562,"I'm trying to turn you on."],[854,966,"And I think that is working."],[991,1116,"Go fuck yourself."],[1116,1254,"I'd rather fuck you instead."],[1304,1466,"And don't talk back to me again."],[1591,1841,"Unless you'd rather be bussing tables"],[1841,2041,"in that little skimpy outfit again."],[2075,2191,"You won't fire me."],[2329,2487,"You're desperate enough to hire me"],[2487,2750,"then, I feel like I can"],[2750,2900,"bend you a little too."],[3283,3341,"Did you hear that?"],[3375,3437,"What's that sound?"],[3462,3579,"I think there might be somebody"],[3579,3629,"in there."],[3629,3808,"The boss is not gonna like this."],[4137,4287,"Let's get one thing straight."],[4316,4625,"You are my employee."],[4625,4729,"I make the rules."],[4754,4841,"The moment you signed"],[4841,5029,"that fucking contract,"],[5029,5254,"you agreed to serve me,"],[5350,5529,"obey me,"],[5600,5879,"help me, understand?"],[5941,6125,"You won't make me do anything illegal?"],[6262,6366,"Nothing illegal."],[6429,6754,"And nothing sexual?"],[6850,6920,"No."],[6941,7087,"Not until you beg me for it."],[7150,7291,"You ruined my life."],[7366,7516,"So why does my body"],[7516,7716,"still bend to him like this?"],[8204,8404,"I know you liked kissing me before."],[8516,8670,"I know you want to do it again."]],"15":[[1654,1887,"What I want is to do the job"],[1887,2029,"that you hired me for."],[2116,2212,"Sure you do."],[2804,2900,"Review these documents"],[2900,2966,"on the merger."],[3025,3116,"Don't fuck it up."],[3741,3904,"Oh, and Emilia?"],[4008,4116,"Can you get me a coffee?"],[4162,4291,"Two creams, one sugar."],[4354,4429,"Thank you."],[6037,6141,"You kissed me once."],[6204,6341,"I know you want to do it again."],[6541,6616,"I do."],[6791,6937,"I want you all the time."],[7004,7187,"And I hate myself for it."],[7241,7337,"I hate you."],[8829,8979,"I hate you."],[9354,9454,"I hate..."],[12416,12566,"Oh, Vicious."],[13491,13604,"Oh my God."],[13741,13841,"It was just a dream."],[13991,14166,"What is wrong with you?"],[15041,15112,"Hello?"],[15216,15379,"You sound all hot and bothered, Help."],[15475,15579,"Were you dreaming about me?"]],"16":[[166,325,"It is 5am, okay?"],[325,454,"Vicious, what do you want?"],[454,591,"Then you should be up already."],[641,766,"Get bagels on your way in."],[854,950,"Don't forget the poppyseed."],[1566,1766,"He is an asshole who ruined your life."],[1787,1941,"Get yourself together, Emilia."],[2725,2891,"Did you see Mr. Spencer's new PA?"],[2941,3025,"Hell yeah, I did."],[3041,3112,"She's hot."],[3150,3229,"Dressed like a little"],[3229,3316,"desperate whore, though."],[3316,3450,"Because she is one."],[3512,3625,"I heard she'll fuck any guy"],[3625,3791,"with a net worth over a mil."],[3804,3912,"You think if I tapped that,"],[3912,4066,"I'd be the new king of the office?"],[4066,4187,"Unless I do first."],[4391,4504,"Go anywhere near her,"],[4504,4650,"and you're fucking fired."],[4837,4966,"Get back to fucking work!"],[6050,6175,"Hi, uh,"],[6204,6283,"I'm Floyd."],[6329,6458,"You are Mr. Spencer's"],[6458,6566,"new PA, right?"],[6566,6700,"Yeah, unfortunately."],[6762,6879,"Yes, of course."],[6879,7029,"I'll, I'll get my PA right on it."],[7029,7091,"Alright."],[7541,7691,"Emilia, get in here."],[8087,8225,"Where the fuck is she?"],[8550,8650,"I'm Emilia."],[8866,8991,"Oh, uh..."],[9029,9170,"You got a little, uh,"],[9237,9337,"cream cheese."],[10491,10679,"You two, in my office"],[10679,10829,"in the next 60 seconds,"],[10875,11016,"or I am taking it as you resign."]],"17":[[37,150,"Since you wanted cream cheese"],[150,237,"so badly..."],[858,1045,"Why don't you lick it off the ground?"],[1108,1212,"On your knees."],[1275,1333,"Now!"],[1683,1800,"You can't make me do this."],[1800,2050,"I said lick it off the ground."],[3050,3187,"Wait, Vicious, stop."],[3312,3387,"Fine."],[3483,3600,"Tell me who I am."],[3662,3787,"And then you can go back to work."],[3833,3887,"What?"],[3962,4050,"You're the CEO of-"],[4050,4100,"Wrong."],[4287,4500,"Miss LeBlanc, who am I?"],[4562,4712,"A sadistic prick."],[4787,4858,"Wrong."],[4937,5175,"Floyd, who am I?"],[5370,5470,"Baron Spencer."],[5512,5608,"God damn it, Floyd."],[5608,5725,"No, wrong."],[5812,6012,"Miss LeBlanc, one more time."],[6145,6350,"A manipulative asshole."],[6450,6500,"No."],[6550,6612,"Wrong again."],[6762,6950,"Floyd, last chance."],[7062,7262,"You're my boss."],[7262,7450,"That's right!"],[7533,7837,"I have given everything within me"],[7862,7962,"to build this company."],[8025,8212,"And I will not let its reputation"],[8212,8487,"be stained by some little office fling."],[8620,8845,"So Floyd, you're fired."],[8929,9125,"Sir, we were just talking,"],[9125,9175,"Oh? - please."],[9175,9300,"Were you just talking?"],[9350,9512,"Did I not warn you"],[9512,9650,"to stay away from her this morning?"],[9762,9987,"Get the fuck out of my office."],[10058,10133,"Vicious."],[10220,10437,"Floyd, close the door."],[10487,10545,"Okay."],[10637,10912,"You had no right to do that."],[10970,11004,"You're..."],[11066,11212,"You're pissing me off!"],[11262,11395,"And that's turning me on."],[11450,11525,"So you better"],[11525,11687,"cut the little hateful glares"],[11687,11875,"before I bend you over this desk"],[11912,12075,"and let the entire office watch"],[12075,12183,"what I'm gonna do to you."]],"18":[[50,225,"You're disgusting."],[637,745,"That might be true,"],[787,887,"but I know"],[1045,1183,"I'm getting under your skin."],[1420,1562,"And I know there's nothing"],[1562,1670,"you can do about it."],[1845,2008,"I remember what you said to Floyd."],[2112,2300,"No mixing business with pleasure."],[2333,2562,"Floyd is a little boy."],[2733,2800,"He doesn't know"],[2800,3037,"the first thing about pleasure."],[3087,3237,"Floyd is a nice guy."],[3308,3433,"And you ran him away"],[3433,3583,"just like you ran away Dean."],[3583,3695,"Just like Dean?"],[3737,3925,"Do you have any idea"],[3925,4050,"the things he said about you?"],[4050,4395,"The things that he wanted to do to you."],[4437,4612,"They sounded an awful lot"],[4612,4862,"like the same thing Floyd said about you"],[4862,4920,"this morning."],[4920,5025,"They can't be any worse"],[5025,5062,"than the things"],[5062,5150,"that you said to me"],[5150,5312,"the first day you met me."],[5375,5462,"She's a whore."],[5533,5645,"Makes you one too."],[5787,5887,"I was an asshole,"],[5975,6112,"but at least I never hid it"],[6112,6358,"like these so-called nice guys."],[6416,6650,"These cowards and liars."],[6770,6837,"But..."],[6975,7408,"I can assure you of one thing, Help."],[7587,7758,"They can't fuck you like I can."]],"19":[[175,358,"You know what your problem is?"],[400,500,"What's my problem?"],[625,770,"You don't know"],[883,1183,"if you want me or hate me."],[1425,1625,"That's why you freak out"],[1675,1775,"every time another man"],[1775,1900,"looks in my direction."],[1950,2062,"You want to know what I think?"],[2175,2325,"What, Vicious?"],[2350,2475,"I think"],[2558,2758,"you loved"],[2800,2916,"seeing me put that asshole"],[2916,3012,"on his knees."],[3070,3150,"Admit it."],[3225,3287,"You'd rather pick"],[3287,3450,"a hundred fights with me,"],[3475,3650,"than fuck a loser like that."],[3762,3858,"So that's it?"],[4000,4195,"You won't make me fuck you, but"],[4237,4437,"you won't let me fuck anyone else."],[4500,4562,"Huh?"],[4562,4862,"I don't need to make you do anything."],[4912,5083,"I know you liked it when I kissed you."],[5187,5312,"I know you wanted more."],[5400,5595,"Hell, still do."],[5675,5883,"You're dying for me."],[6033,6108,"Admit it."],[6220,6587,"And I will break every single rule"],[6937,7025,"just for you."],[7145,7300,"I know I should say no."],[7312,7550,"I know I should push him away."],[7575,7862,"But why is my body betraying my mind?"],[8187,8387,"What the fuck is happening in here?"],[8487,8537,"Dean."]],"20":[[16,204,"What the fuck is happening in here?"],[316,404,"Ms. LeBlanc,"],[437,504,"that's it."],[1041,1166,"Trent told me you hired my ex."],[1166,1329,"I thought he was fucking with me."],[1354,1404,"What are you trying"],[1404,1529,"to prove here, Vicious?"],[1591,1725,"That she chose the wrong guy."],[1779,1891,"That she wanted me"],[1891,2041,"more than she ever wanted him."],[2091,2391,"I don't need to prove anything to you."],[2429,2650,"You are unbelievable."],[2754,2862,"Did you fuck her yet?"],[2929,3104,"Yeah, that's what I thought."],[3154,3300,"I bet you if you gave her the chance,"],[3300,3466,"she'd pick