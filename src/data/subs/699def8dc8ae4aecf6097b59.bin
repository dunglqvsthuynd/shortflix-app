e."],[1470,1820,"Dean, I'm not interested."],[2000,2108,"Let me ask you something."],[2262,2350,"How much"],[2475,2600,"is it gonna take"],[2925,3037,"for you to be mine"],[3100,3175,"instead?"],[3495,3670,"Mr. Spencer, they're having lunch"],[3670,3758,"at Maple Restaurant."],[3758,3883,"I'm joining Mr. Cole's lunch."],[3925,4025,"Send me the location."]],"23":[[29,133,"Dean, stop."],[220,320,"I don't think..."],[320,495,"You don't think what?"],[595,704,"You don't want this?"],[829,991,"No, of course not."],[991,1133,"It's all about Vicious, right?"],[1229,1379,"Let go of me."],[1379,1458,"You know..."],[1733,1879,"I always thought he was secretly"],[1879,2008,"in love with you in high school."],[2008,2166,"I even told him I'd share you"],[2166,2283,"after I was done with you."],[2604,2691,"He got so jealous"],[2691,2808,"he ran you out of town."],[2833,2941,"You what?"],[3020,3195,"Do you have any idea"],[3195,3408,"the things that he said about you?"],[3466,3733,"The things that he wanted to do to you."],[3804,3954,"Was Vicious right about him?"],[4033,4158,"Was he protecting me?"],[4179,4520,"But hey, the past is in the past, right?"],[4941,5095,"Fucking bitch."],[5333,5495,"You're not running away this time."],[5583,5645,"Hey..."],[5733,5933,"You really wanna piss Vicious off?"],[5966,6079,"Dean, stop."],[6108,6241,"Let me go!"]],"24":[[804,875,"Good boy."],[1054,1179,"Vicious, stop!"],[1179,1312,"You're gonna kill him!"],[1625,1729,"What are you, an idiot?"],[1825,1954,"I'm your business partner."],[1954,2087,"You're gonna kick the shit out of me"],[2087,2254,"over some bitch from high school?"],[2287,2379,"No, no!"],[2441,2491,"Stop!"],[2604,2829,"I'm so sick of your bullshit!"],[3004,3091,"Both of you!"],[3616,3691,"You're right."],[3750,3866,"You are my business partner."],[3929,4041,"And I need you for the merger."],[4087,4291,"But that is the only reason"],[4291,4366,"you're not six feet"],[4366,4512,"in the fucking ground right now."],[4612,4679,"Fuck you!"],[4762,4904,"Glad she got to see that."],[5029,5179,"Angry man in the house."],[5179,5354,"It's like talking to your father again."],[5837,6062,"This is like high school all over again."],[6087,6191,"I can't let Vicious"],[6191,6404,"drag me back into the same mess."],[6791,6975,"Emilia, get in the car."]],"25":[[25,79,"Get in."],[79,241,"Leave me alone, Vicious."],[291,400,"You're gonna freeze out here."],[400,504,"Why do you care?"],[529,654,"Because I don't want my PA"],[654,804,"dropping dead from hypothermia."],[1016,1066,"Fine."],[1129,1191,"Stop the car."],[1487,1541,"Emilia,"],[1691,1825,"I'm not leaving you alone"],[1825,2054,"until you get back into the fucking car."],[2054,2166,"You're insane!"],[2437,2541,"If you get sick,"],[2625,2691,"who's gonna take care"],[2691,2779,"of your little sister?"],[3054,3129,"That's what I thought."],[4229,4312,"I hate you."],[4312,4387,"Don't worry."],[4454,4629,"I am fully aware."],[4704,4762,"Here."],[4912,5029,"Are you proud of yourself?"],[5079,5237,"You almost killed my ex-boyfriend."],[5237,5366,"You don't think he deserved it?"],[5454,5654,"You are no different than he is."],[5691,5779,"You know that, right?"],[5829,5991,"You both throw money at everything."],[6016,6100,"You both think you can get"],[6100,6204,"whatever the fuck you want."],[6204,6350,"I mean, I don't see a difference."],[6375,6491,"The difference?"],[6625,6729,"Dean's never made you feel"],[6729,6850,"the way you feel right now."]],"26":[[150,441,"He's never made you shake"],[566,704,"the way you are right now."],[875,966,"Vicious, I..."],[1104,1187,"That's not..."],[1229,1275,"That's not-"],[1275,1529,"Don't lie to me, Help."],[1612,1716,"I can smell your bullshit"],[1716,1804,"from a mile away."],[1929,2041,"This is what you do."],[2091,2279,"You lie to yourself about this."],[2379,2462,"About us."],[2787,2966,"There is no us, Vicious."],[3266,3325,"Emilia."],[3416,3487,"Emilia!"],[3579,3666,"Emilia!"],[3741,3791,"Come here."],[3816,4054,"Don't you dare walk away from me."],[4104,4275,"You need this job."],[4329,4404,"Don't forget that."],[4404,4512,"How could I forget?"],[4604,4750,"You ruined my life!"],[4841,5004,"You took me away from my family."],[5004,5179,"You, you took everything from me."],[5179,5300,"You made me need you!"],[5300,5529,"I didn't make you do anything, Help."],[5675,5912,"Stop fucking calling me that!"]],"27":[[41,279,"Stop fucking calling me that!"],[625,850,"Vicious, where are you taking me?"],[904,1012,"I'm not done with you yet."],[1791,2029,"You know why I sent you away"],[2029,2154,"ten years ago, Emilia."],[2200,2254,"Shh."],[2750,2812,"Because you're a"],[2812,3004,"cocky, jealous asshole?"],[3087,3204,"He might have protected me"],[3204,3279,"from Dean,"],[3279,3450,"but he hasn't changed."],[3466,3650,"He still loves to torture me."],[3691,3941,"And when he's done, he'll toss me aside,"],[3975,4162,"just like his dad did to my mom."],[4287,4383,"Vicious,"],[4504,4591,"I quit."]],"28":[[8,87,"I quit."],[145,358,"I have always been a toy to you,"],[358,550,"and I am done being played with."],[612,808,"Don't threaten me with my sister"],[808,933,"or my mother because..."],[975,1037,"because I'm not gonna"],[1037,1125,"change my mind."],[1537,1783,"You think all these years"],[1783,1962,"I've just been playing with you,"],[2012,2162,"trying to hurt you?"],[2162,2300,"How can I not?"],[2358,2545,"You threatened to destroy my family"],[2545,2662,"if I didn't leave town."],[2700,2858,"You're a bully, Vicious."],[3625,3725,"What are you doing?"],[3945,4004,"You want to see what a"],[4004,4100,"real bully does?"],[4300,4437,"Oh my God."],[4708,4800,"Look at me."],[5058,5120,"Look at me."],[5300,5412,"Lower, Emilia."],[6208,6412,"Oh my God."],[6558,6695,"Vicious, who did this to you?"]],"29":[[16,141,"You remember back in high school"],[225,291,"when I'd get in fights"],[291,387,"at all those parties?"],[429,504,"It wasn't because I was"],[504,625,"some hotheaded asshole."],[741,804,"You were."],[891,1079,"It wasn't just that."],[1179,1254,"I thought"],[1429,1575,"that if I got in enough fights,"],[1604,1679,"people wouldn't ask"],[1679,1791,"where these really came from."],[2341,2479,"Your dad gave you those?"],[2579,2641,"Yeah."],[2741,3091,"All these years, all this pain."],[3162,3316,"Look, just because you were hurt"],[3375,3554,"doesn't mean that you can hurt others,"],[3554,3604,"Vicious."],[3654,3904,"So, you're going to say I'm the monster"],[3929,4012,"for saying your mother"],[4012,4066,"spread her legs"],[4066,4191,"for that fucking asshole?"],[4291,4441,"For paying you a leave"],[4441,4666,"to get away from all this bullshit?"],[4666,4850,"My mom and I were collateral damage"],[4850,5075,"in the mess that you and your dad made."],[5166,5354,"She slept with him to survive."],[5441,5529,"She slept with him"],[5529,5766,"because she had to, to keep her job, to"],[5866,6037,"to keep Rosie alive."],[6091,6316,"And I had to do the same exact thing,"],[6316,6454,"taking this job with you."],[6475,6750,"But I am done paying for the mess"],[6750,6870,"that you and your dad made."]],"30":[[666,879,"I didn't force you to come work for me."],[929,1037,"No, I'm the idiot"],[1037,1154,"who agreed to work for the guy"],[1154,1341,"who's made my life a living hell"],[1387,1591,"for the past ten years."],[2025,2166,"You think I enjoyed it?"],[2279,2450,"You think it was easy for me?"],[2679,2804,"But I never lied to you."],[2916,3016,"Not even once."],[3129,3366,"So believe me when I say this."],[3550,3687,"I never hated you, Emilia."],[3854,3916,"Vicious."],[4062,4129,"I can't-"]],"31":[[37,112,"I can't-"],[2512,2662,"Wait, wait, wait, somebody's coming."],[2745,2829,"Shh."],[4787,4941,"I hated you all along."],[5837,5937,"You're gonna pay for that."]],"32":[[616,1008,"I'll ruin you all over again."],[1091,1295,"Try your worst, Vicious."],[2933,3133,"I knew you'd play dirty eventually."],[3216,3320,"Everyone has a moment"],[3320,3408,"of we