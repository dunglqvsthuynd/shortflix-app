{"1":[[1072,1151,"Jack!"],[1200,1291,"What is this?"],[1508,1707,"Jack, how- how can you do this to me?"],[1800,1956,"We've been married over ten years."],[1956,2116,"I planned this whole party for you."],[2116,2316,"Stop being so pathetic!"],[2360,2399,"Excuse me,"],[2399,2535,"I'm talking to my husband."],[3083,3307,"Disgusting pig."],[3384,3639,"Your marriage has been over for years."],[3639,3792,"When was the last time you even had"],[3792,3884,"sex, hmm?"],[3915,4052,"No, Jack."],[4052,4132,"Maria,"],[4203,4535,"how fucking hard and difficult."],[4535,4735,"Sign the papers."],[4735,4835,"It is over."],[4835,4984,"It's this shit!"],[5267,5356,"Let's go, babe."],[5479,5635,"Just sign it."],[5703,5864,"No, Jack... Jack!"],[6124,6220,"No, Jack."],[6260,6331,"No."],[6341,6607,"You are fucking dumb, stupid,"],[6607,6704,"fat and lazy."],[6704,6843,"And I just can't handle you"],[6843,6948,"clinging to me like this."],[6948,7143,"Can you just leave me alone?"],[7200,7367,"No, I can't. Jack, stay."],[8140,8335,"I've wasted the best years of my life"],[8335,8392,"on you,"],[8615,8784,"only to end up with this."],[9431,9587,"You don't actually feeling sorry"],[9587,9756,"for that disgusting pig. Are you?"],[9995,10068,"No."],[12171,12287,"Sorry, I'm late."],[13063,13180,"Why is he here?"]],"2":[[383,496,"I don't want to relive anymore."],[496,648,"Richard just kill me too."],[720,883,"We have an important mission to do."],[896,991,"There's a lot of people"],[991,1075,"who want you dead."],[1116,1196,"Follow me."],[1650,1804,"What's going on?"],[1844,1954,"Shh."],[2271,2332,"Richard..."],[3324,3428,"Stay quiet."],[3464,3575,"Stay close to me."],[3756,3835,"Okay?"],[4566,4690,"Shh."],[4732,4911,"Don't move a muscle."]],"3":[[108,227,"Should get some rest."],[327,467,"We're going to Chicago tomorrow."],[571,716,"Chicago? Why?"],[908,1008,"You know, Richard."],[1143,1259,"I used to think you were just"],[1259,1396,"my grandfather's lawyer."],[1464,1503,"But,"],[1503,1703,"now you've turned into James Bond."],[1732,1887,"You owe me an explanation."],[3288,3396,"Tell me the truth."],[3696,3803,"Your grandfather's dead."],[3888,4032,"We need to go to Chicago."],[4211,4292,"What?"],[4396,4543,"How did this happen?"],[4543,4615,"Why?"],[4843,5011,"I'll explain everything at the funeral."],[5128,5247,"You just need to trust me."],[5871,6047,"Get lost, you miserable orphan."],[6047,6124,"Yeah."],[6128,6275,"You're not a part of our family,"],[6275,6428,"and never will be."],[6756,6864,"Stop it!"],[6892,7051,"What is wrong with you two?"],[7068,7251,"Why are you protecting him?"],[7331,7556,"He's a total weirdo. Nobody wants him."],[7556,7848,"His parents just died in a car crash."],[7895,8020,"You're heartless..."],[8048,8192,"Get lost!"],[8271,8448,"That's right."],[8656,8735,"Adria,"],[8815,8904,"Natalie,"],[8940,9059,"you two should be"],[9059,9251,"ashamed of yourselves."],[9571,9764,"I'm so proud of you, Maria."],[9823,9915,"Remember,"],[10012,10264,"never lose that kind heart of yours."],[12464,12607,"Sleep peacefully, Maria."],[12771,12968,"Starting tomorrow, your days of being pushed"],[12968,13071,"will be over."]],"4":[[379,544,"Richard, where are you?"],[544,636,"The thing is about to start..."],[636,759,"I've gotta go, bye."],[759,967,"Well, if it isn't the loser who got"],[967,1132,"dumped by her husband."],[1132,1308,"And bullied by the mistress."],[1323,1559,"If I were you, I would just hang myself,"],[1559,1648,"honestly."],[2019,2180,"You two gold-digging whores"],[2180,2323,"have no right to judge me."],[2819,2960,"You have no idea"],[2960,3064,"what you're talking about?"],[3071,3203,"Your whole life, you've acted like"],[3203,3307,"you're better than us."],[3347,3479,"Where has that got you?"],[3503,3647,"Grandpa is dead."],[3647,3752,"And nobody in this family"],[3752,3847,"loves you now."],[3928,4064,"You have no right to be here."],[4152,4232,"No."],[4279,4407,"I'm his granddaughter too."],[4411,4547,"And I will send him off."],[4600,4735,"Oh..."],[4767,4852,"You wanna do that?"],[4915,5047,"Then beg me for it."],[5092,5243,"If you lick the dirt off my shoes,"],[5243,5435,"I'll let you attend Grandpa's funeral."],[5435,5524,"Oh, Natalie."],[5524,5688,"You know she only came to the family"],[5688,5764,"for the money."],[5784,5888,"She wouldn't do that."],[6092,6188,"No, I'll do it."],[6292,6379,"I will do it."]],"5":[[4,279,"My granddaughters are my only remaining family."],[360,469,"Therefore,"],[512,620,"my wealth and property"],[620,755,"should be bequeathed to them."],[875,1003,"My eldest granddaughter,"],[1040,1119,"Adria."],[1172,1364,"A 1972 Gran Torino."],[1456,1527,"Yes!"],[1527,1655,"My second granddaughter,"],[1655,1723,"Natalie."],[1803,1976,"Their mother's jewelry collection."],[1976,2132,"Wow! It's good."],[2376,2464,"Keep staring and"],[2464,2596,"I'll gouge your eyes out,"],[2619,2696,"fat pig!"],[2723,2876,"Silence! Adria."],[2932,3016,"Settle down."],[3100,3252,"As for my youngest granddaughter,"],[3320,3392,"Maria."],[3460,3596,"I bequeathed to her"],[3632,3871,"my 1,900-acre estate,"],[3903,4075,"as well as all my assets."],[4075,4128,"No!"],[4128,4260,"From now on,"],[4260,4439,"she will become the chairwoman"],[4475,4579,"of my company."],[4579,4684,"No fucking way!"],[4684,4807,"Grandpa would never leave her"],[4807,4892,"all that money."],[4903,4956,"You!"],[4960,5096,"You must have forged the will!"],[5096,5207,"That's enough, you two!"],[5207,5311,"Behave yourselves!"],[5311,5503,"Who the fuck are you to boss us around?"],[5503,5620,"You're just some street kid"],[5620,5820,"Grandpa picked up twenty years ago."],[5875,6039,"Come here!"],[6264,6375,"Hey!"],[6375,6559,"Get your filthy hands off of me!"],[6559,6687,"This isn't over!"],[6779,6984,"Apologies for the interruptions, everyone."],[7064,7220,"Funeral can now continue."],[7356,7478,"Richard, what the hell?"],[7495,7643,"Why did granddad leave me everything?"],[7643,7764,"You deserve it, Maria."],[7784,7979,"Your grandfather is eternal pride."],[8084,8124,"But..."],[8124,8279,"There's one more thing I need to tell you."],[8340,8500,"I can't announce it publicly yet."],[8500,8559,"But,"],[8576,8876,"your grandfather's real surname is"],[8940,9035,"St. Clair."],[9064,9204,"What? St. Clair?"],[9204,9420,"Like the infamous mob family? I don't..."],[9476,9723,"From now on, you are the leader"],[9740,9884,"of the St. Clair family."],[9884,10043,"What? I don't..."],[10043,10259,"Darkness is the eye of the light."],[10464,10631,"St. Clairs belong in heaven."],[10776,10915,"Salute our godmother."]],"6":[[56,216,"This is fucking nonsense!"],[216,448,"Maria is nothing but a clumsy housewife."],[459,659,"I won't let her lead the family."],[728,959,"Maria, now is not the time to be scared."],[967,1151,"Gerard is watching from above."],[1280,1388,"Uncle Paulie,"],[1440,1619,"what's it gonna take for you to accept me?"],[1860,2104,"The Pattinsons are bleeding us dry."],[2139,2376,"The family needs ten billion dollars."],[2412,2580,"If you can put that on the table,"],[2600,2716,"I'll kiss your hand,"],[2792,2876,"godmother."],[2948,3071,"Gerard's safe"],[3071,3267,"contains gold certificates"],[3267,3375,"worth ten billion."],[3375,3520,"Why don't we give Maria a try?"],[3596,3767,"Maybe she knows the combination."],[3775,3935,"Richard, I don't know the combination."],[3988,4207,"Gerard told me before he died"],[4207,4371,"that you knew the combination."],[4420,4496,"Think."],[4575,4692,"When did he tell you?"],[5511,5647,"I planted this tree"],[5647,5856,"with my own hands,"],[5920,6132,"September 18th"],[6156,6279,"2001."],[6339,6592,"It is the most precious thing"],[6592,6695,"on the estate."],[6759,6876,"Why, Hrandpa?"],[7079,7271,"Your grandmother died that day."],[7300,7548,"I believe that this tree"],[7564,7715,"carries her soul,"],[7848,7995,"blessing our family."],[9995,10064,"Get it right,"],[10115,10276,"and I'll accept you as leader."],[10331,10458,"Get it wrong,"],[10458,10628,"I'll blow your fucking brains out."]],"7":[[1755,1916,"Swiss bank black card,"],[2000,2132,"ten billion in gold."],[2339,2416,"Don Maria."],[3100,3196,"You gonna kneel, Paulie,"],[3196,3297,"or you're gonna break your pledge"],[3297,3379,"to the family?"],[3871,3952,"Don Maria."],[5043,5232,"Goodness, Richard. I don't know, I'm just..."],[5279,5432,"not make for this kind of life."],[5432,5496,"No."],[5515,5684,"Maria, trust me,"],[5684,5800,"and trust yourself."],[5811,5928,"Get some rest."],[5935,6039,"Okay, good night."],[6679,6868,"Told you no one would notice us."],[7087,7228,"She drank the poison, now what?"],[7251,7348,"We walk."],[7456,7595,"That poison water will kill her"],[7595,7695,"by midnight."],[7812,7928,"Once she's dead,"],[7968,8164,"all the power and money comes to us."],[8164,8295,"Hahaha..."]],"8":[[1616,1728,"Oh, I'm terribly sorry"],[1728,1816,"to interrupt, sir."],[1816,1951,"But this is urgent news."],[2016,2192,"Maria needs to be at the New York Ball"],[2192,2276,"next week."],[2351,2490,"Call the luxury boutiques,"],[2490,2687,"have them prepare the finest couture."],[2687,2796,"Yes, sir."],[3135,3215,"What?"],[3371,3492,"She's in trouble!"],[5196,5275,"Maria?"],[6143,6224,"Maria."],[6384,6515,"Wake up!"],[7223,7387,"Maria, this is gonna be a little hot."],[7512,7631,"Wake up very soon!"],[8159,8376,"Sorry, Maria. This is the fastest way"],[8376,8504,"to wake you up."],[8679,8784,"Are you okay?"],[8871,8976,"Can you hear me?"],[9031,9115,"Maria?"],[9212,9292,"You okay?"]],"9":[[304,396,"What happened?"],[671,824,"I heard strange noises."],[956,1075,"Someone tried to assassinate"],[1075,1164,"the godmother."],[1191,1343,"Her glass was poisoned."],[1424,1511,"I saved her."],[2383,2519,"Fortunately we caught it early."],[2571,2739,"You're fine now, godmother. But,"],[2780,2912,"this drug has side effects."],[2939,3048,"You need proper rest."],[3071,3164,"Thank you, doctor."],[3164,3296,"You may take your leave."],[3679,3752,"Maria,"],[3752,3900,"I understand after everything"],[3900,4035,"that happened today,"],[4200,4335,"you might still want to give up."],[4411,4492,"No."],[4564,4739,"I'm not giving up anymore, Richard."],[4856,4935,"Really?"],[4992,5060,"Yeah!"],[5060,5132,"My whole life..."],[5132,5235,"and what did that get me?"],[5328,5496,"No, something's gotta change."],[5552,5639,"Well,"],[5803,5892,"I'm proud of you."],[6000,6184,"Well, don't celebrate too soon."],[6260,6364,"There's one condition to me"],[6364,6484,"staying in charge."],[6559,6656,"We can't."],[6764,7023,"Relations between the consigliere are"],[7023,7140,"strictly forbid."],[7240,7320,"Okay."],[7695,7815,"I almost died twice today,"],[7815,7995,"do you really think I care about that?"],[8240,8356,"Don't do this."],[8392,8456,"Maria."],[8504,8715,"We're not just boss and subordinate,"],[8715,8920,"but we're step siblings."],[9000,9140,"Well, as your godmother"],[9140,9284,"I order you to sit down."],[9584,9751,"I've decided to go all in."],[9800,9959,"So why are you holding back?"],[10664,10740,"What happened?"],[10759,10884,"Did I get your weak spot?"]],"10":[[1303,1383,"Oh, hello."],[1500,1703,"What... what is this?"],[1764,1944,"You're the head of the St. Clair family."],[1980,2176,"It's time you start looking like one."],[2264,2355,"Pick whatever you like."],[2464,2548,"Okay."],[2767,2864,"Look at this one."],[3247,3328,"Exquisite."],[3447,3624,"It's stunning, Richard."],[3847,3964,"Four hundred grand?"],[4007,4100,"Holy shit!"],[4107,4239,"None of my clothes cost more than"],[4239,4360,"ten dollars."],[4464,4547,"Maria."],[4628,4732,"There's no dress"],[4732,4888,"you're not worthy of wearing."],[4967,5047,"You got it?"],[5260,5360,"Thank you so much."],[5907,6039,"We need to keep our boundaries."],[6275,6396,"Enjoy the clothes."],[8179,8335,"Ma'am, may I please have your name?"],[8387,8664,"Sure, I'm Maria St. Clair,"],[8679,8876,"I represent the St. Clair family."],[9043,9176,"The St. Clair representative"],[9176,9340,"family already went inside."],[9340,9495,"I cannot let you in."],[9535,9704,"What? No, that's impossible!"],[9704,9892,"I'm the head of the St. Clair family."],[9892,9956,"I just..."],[9956,10028,"Can you check again?"],[10028,10228,"This is an exclusive private club,"],[10228,10343,"not a comedy show."],[10343,10428,"Please leave."],[10507,10604,"She's with me."]],"11":[[12,112,"She's with me."],[391,491,"She's my date."],[824,891,"Please welcome."],[891,1103,"I'm so sorry, Sir Eric."],[1111,1224,"My apologies, ma'am."],[1464,1632,"Shall we, Miss Maria?"],[2167,2255,"Shall we go?"],[3000,3032,"So..."],[3087,3164,"Mr...?"],[3164,3228,"Eric."],[3247,3288,"Oh."],[3339,3403,"Well,"],[3403,3532,"it was lovely to meet you, Eric."],[3532,3711,"But why did you just save me back then?"],[3775,3920,"Someone as beautiful as you..."],[3920,4015,"why wouldn't I?"],[4392,4492,"Anyway I'm gonna"],[4528,4715,"go speak to a few of my colleagues."],[4775,4864,"I'll see you soon."],[5003,5052,"Bye."],[6196,6279,"Remember."],[6332,6396,"We're here to meet"],[6396,6612,"with the mysterious Mr. E."],[6648,6795,"If we can partner with him,"],[6823,6928,"we'll have enough money to pay off"],[6928,7023,"our loan sharks."],[7068,7248,"But will you give us a time of day?"],[7295,7348,"Remember,"],[7348,7543,"Maria is dead from the poison."],[7543,7731,"We're the leaders of the St. Clairs now."],[8315,8468,"Wow! Who is she?"],[8468,8612,"Look at that dress."],[8612,8728,"She must be a dame."],[8764,8992,"Adria, that fat pig is still alive."],[9071,9240,"That Richard must have saved her."],[9240,9312,"No way!"],[9312,9431,"We'll get another chance."],[9431,9548,"She has to die!"]],"12":[[252,335,"Hey, pig."],[491,596,"Adria and Natalie,"],[616,716,"what are you guys doing here?"],[779,975,"This is an event for high society."],[975,1091,"We belong here."],[1091,1164,"Unlike you,"],[1164,1403,"in a rented fancy gown and still,"],[1424,1619,"just a pig in a silk gown."],[1776,1980,"Didn't you get your ass kicked"],[1996,2132,"in front of a hundred guests"],[2132,2223,"two days ago?"],[2303,2435,"I'm surprised you're still here."],[2567,2655,"Help me!"],[2655,2764,"Let me go!"],[2764,2903,"Oh my god, Maria!"],[2907,3080,"Let go of me! Help!"],[3139,3232,"Maria!"],[3232,3460,"How dare you attack your own sister?"],[3511,3679,"I just made a joke about you,"],[3679,3839,"and I got full-on assaulted."],[3839,3932,"No."],[3952,4184,"Oh my god! Are you okay?"],[4400,4492,"No, I didn't."],[4539,4624,"What are you doing?"],[4624,4715,"What do you think?"],[4715,4788,"Absolutely..."],[4788,4924,"She needs get out!"],[4943,5139,"Guys, I promise, it wasn't me."],[5379,5571,"No, really, I didn't touch her."],[5643,5824,"Hey! Hey, ladies."],[5903,6079,"No need to get physical here."],[6111,6220,"Let's talk it out."],[6247,6311,"Wait,"],[6311,6507,"are you Mr. E?"],[6507,6579,"Eric?"],[6612,6795,"He's the Mr. E I was looking for."],[6904,6984,"That's right."],[7095,7251,"Not here to watch a cat fight."],[7359,7501,"I'm here to meet the"],[7501,7704,"boss of the St. Clair family."],[7723,7815,"That's me."],[7815,7948,"I'm Adria,"],[7948,8100,"the head of the St. Clairs."],[8100,8187,"No, no."],[8187,8279,"She's lying."]],"13":[[44,136,"I'm Maria,"],[136,364,"and I'm the head of the St. Clair family."],[364,471,"Bullshit!"],[500,604,"Just look at yourself."],[604,665,"How could you be"],[665,843,"the lead of the St. Clair family?"],[916,1000,"Oh, wow."],[1064,1219,"A real imposter syndrome."],[1291,1375,"How interesting."],[1396,1511,"What's going on?"],[1511,1632,"Three sisters fighting over"],[1632,1732,"who's the new lead"],[1732,1860,"of the St. Clair family."],[1896,2112,"Well, you'll have to prove yourselves."],[2192,2296,"Cause I'm here to meet"],[2296,2512,"the boss of the St. Clair family"],[2530,2719,"for some business."],[2744,2964,"Every corporation and family in the country"],[2964,3119,"is dying to partner with Mr. E."],[3119,3284,"This is a huge opportunity."],[3284,3415,"Ladies and gentlemen,"],[3432,3684,"I am the head of the St. Clair family."],[3735,4003,"She is a housewife in a rented dress"],[4003,4211,"pretending to be high society."],[4211,4332,"I'll prove it to you."],[4892,5020,"Oh my god!"],[5020,5252,"What the hell is that?"],[5252,5343,"That's disgusting!"],[5439,5592,"Absolutely disgusting."],[5675,5811,"-You need to go. -Yeah."],[6024,6103,"See?"],[6160,6352,"Even her own husband ran off."],[6356,6540,"And she couldn't stand up to the homewrecker."],[6579,6795,"How is she supposed to run the St. Clairs?"],[6800,6935,"She's got a point."],[6959,7053,"The St. Clair family"],[7053,7159,"would never let a pushover"],[7159,7292,"like her be their leader."],[7292,7504,"Yeah, get this fraud out of here, leave."],[7504,7576,"You need to leave now."],[7576,7704,"-You need to go. -Get out of here."],[7704,7835,"Right now leave."],[7904,8012,"Seems to be a problem?"],[8012,8095,"Perfect timing."],[8095,8192,"She dares to pose"],[8192,8335,"as the head of the St. Clairs."],[8340,8500,"Toss her out!"],[8500,8623,"Ma'am, you need to come with me."],[8623,8740,"No, no!"],[8840,8907,"Stop!"]],"14":[[12,92,"Stop!"],[528,667,"This is Maria St. Clair,"],[667,891,"the new head of the St. Clair family."],[932,1043,"Adria, what do we do now?"],[1043,1140,"Keep lying."],[1140,1300,"We just have to make it through tonight."],[1311,1451,"He's lying too!"],[1456,1575,"He's just a street rat"],[1575,1780,"Grandpa picked up twenty years ago."],[1780,1892,"The one screwing"],[1892,2051,"that fat pig over there."],[2051,2139,"Trying to use her"],[2139,2319,"to get to our family fortune."],[2380,2571,"Claim to be the head of the St. Cairs."],[2596,2707,"Do you have any proof?"],[2828,3048,"I'm Gerald's eldest granddaughter."],[3155,3239,"Of course I do."],[3515,3815,"This is Gerard's signet ring,"],[3815,4071,"a symbol of family leadership."],[4071,4152,"Tell me,"],[4179,4375,"isn't this enough proof that I'm the heir?"],[4375,4552,"I've seen Gerard wear that ring before,"],[4552,4696,"that's definitely the signet."],[4696,4863,"That proves that she's the real heir"],[4863,4988,"of the St. Clair family."],[4988,5161,"Get these liars and perverts"],[5161,5296,"out of here now!"],[5515,5679,"Good thing I planned ahead."],[6107,6239,"Wait, before we go,"],[6239,6388,"we have to find Grandpa's signet ring."],[7931,8040,"Gerard's signet ring"],[8040,8207,"is made of special materials"],[8207,8300,"which glow green"],[8300,8431,"when exposed to acid."],[8512,8692,"You claimed that's the real ring."],[8756,8971,"Get a test in front of everyone here."],[9195,9292,"Of course."],[9340,9487,"But when I prove it's real,"],[9523,9779,"you and Maria have to get on your knees"],[9779,9879,"and repent."]],"15":[[80,212,"And if it's not,"],[235,352,"we'll have you whipped."],[487,571,"For challenging the"],[571,796,"head of the St. Clair family in public."],[848,1059,"No one has the balls to whip me."],[1839,2019,"But the acid didn't turn green."],[2035,2164,"That ring is a fake!"],[2164,2244,"No!"],[2244,2307,"There's something"],[2307,2432,"wrong with your acid!"],[2460,2623,"Gerard knew someone would covet"],[2623,2728,"his signet ring."],[2760,2883,"Which is why he entrusted the"],[2883,3039,"real ring to me years ago."],[3462,3739,"What you have there is a fake."],[3935,4020,"Observe."],[4471,4692,"Oh my god!"],[4692,4771,"I don't know!"],[4935,5074,"Oh my god!"],[5074,5278,"That's the real ring! Oh my god!"],[5347,5532,"You seeing this?"],[5660,5747,"Oh my god!"],[5747,5835,"-What do we do? -Security!"],[5915,5992,"Take them away."],[5992,6107,"No."],[6107,6184,"No, please!"],[6184,6311,"Don't! Let go of me!"],[6311,6471,"This isn't over, Maria!"]],"16":[[0,119,"Ladies and gentlemen,"],[180,352,"I'm pleased to announce"],[356,624,"the true heir to the St. Clair family"],[655,800,"Don Maria."],[1080,1232,"Congratulations, Maria."],[1327,1496,"Thank you, Eric, and"],[1519,1623,"the St. Clair family will be honored"],[1623,1755,"to do business with you."],[1819,1892,"Oh I think we need"],[1892,2012,"to do more than business."],[2012,2148,"I think we go a bit further."],[2196,2296,"Ladies and gentlemen,"],[2339,2648,"I'd like to announce my proposal to..."],[2648,2812,"Maria of St. Clair."],[4179,4292,"Eric, what the hell?"],[4311,4426,"Why do you just tell everyone"],[4426,4520,"that you're proposing?"],[4564,4775,"Maria, I'm being honest."],[4779,4924,"I'm just speaking from the heart."],[5003,5075,"You have no one else"],[5075,5196,"to blame but yourself."],[5220,5324,"You're the one that stands out"],[5324,5400,"in the room."],[5420,5503,"You know that?"],[5596,5703,"You're so beautiful."],[5779,5888,"It's like fate."],[6135,6243,"Should I take you out for dinner?"],[6320,6380,"I, um..."],[6380,6564,"Why don't I want to turn this guy down?"],[6587,6764,"Am I truly falling for him too?"],[6764,6931,"I actually have plans tonight. So..."],[6931,7056,"You're gorgeous."]],"17":[[108,187,"Maria."],[470,540,"Um..."],[540,616,"Eric and I were just"],[616,736,"talking about business."],[755,835,"Eric."],[956,1124,"Shouldn't you be at the club by now?"],[1132,1343,"Crying over some stripper's shoulder?"],[1343,1456,"No, Richard."],[1551,1676,"Have you ever had a girlfriend?"],[1755,1916,"Are you incompetent or gay?"],[2044,2128,"My job"],[2216,2383,"is to serve the St. Clairs."],[2656,2796,"And if you don't mind."],[3784,3892,"I told you"],[3892,4084,"not to hang out with guys like Eric."],[4132,4292,"I wouldn't need to hang out with anyone"],[4292,4424,"if someone wasn't late."],[4524,4711,"Yes, I shouldn't have been late."],[4728,4852,"But as a godmother,"],[4852,5028,"you look far too loose tonight."],[5052,5207,"Sounds like you're just jealous."],[5396,5543,"Why would I be jealous?"],[5575,5639,"Come on."],[5671,5828,"I've known you over 23 years."],[5828,5992,"And you've never been this on edge."],[6152,6335,"Seeing people get close to me"],[6487,6628,"gets to you, doesn't it?"],[6912,7004,"You want me."],[7143,7228,"Just admit it."],[7395,7504,"And I'm yours."]],"18":[[1583,1764,"Don't do this, Maria. This isn't you."],[2087,2207,"I've changed, Richard."],[2287,2428,"And you'VE made me this way."],[2648,2807,"Need me to stop seeing Eric?"],[2955,3035,"Be my lover."],[3835,3915,"No."],[4088,4228,"And that was a one off thing."],[4292,4407,"If anyone finds out that the"],[4407,4600,"consigliere and the godmother"],[4600,4684,"are having an affair,"],[4684,4807,"we'll both be dead."],[5492,5632,"Please stay out of my private life."],[6215,6296,"Eric?"],[6443,6535,"We need to talk."],[6787,6935,"Oh, well. Hello there, big brother."],[6935,7043,"Came here for beer?"],[7231,7415,"Little games and now."],[7476,7607,"Why are you messing with Maria?"],[7687,7748,"Why?"],[7748,7835,"Did you see her ass?"]],"19":[[0,60,"Why?"],[60,156,"Did you see her ass?"],[156,275,"Oh, Jesus!"],[343,455,"Slow down!"],[544,646,"Someone with your temperament"],[646,776,"is an undercover?"],[843,924,"I'm not undercover."],[924,1072,"I've been working with the St. Clairs"],[1072,1200,"for twenty years."],[1259,1388,"You found out that I'm a"],[1388,1535,"Pattinson two years ago."],[1739,1923,"Well, the medical report came out"],[1923,2071,"perfectly for you, didn't it?"],[2132,2227,"Uncle Hans was about"],[2227,2403,"to crush St. Clairs."],[2476,2583,"Little did we know that"],[2700,2987,"our nephew was a consigliere for"],[3039,3155,"twenty-three years?"],[3296,3464,"You know what Uncle Hands is like."],[3560,3652,"If I go along with him,"],[3652,3796,"it'll be a bloodbath."],[3960,4079,"I had to keep things stable."],[4203,4371,"What, you want me to back down?"],[4415,4496,"That's right."],[4552,4692,"From now on,"],[4692,4896,"you stop seeing Maria."],[4935,5015,"Please,"],[5096,5200,"when my parents were alive,"],[5200,5352,"they didn't even tell me what to do."],[5403,5560,"Now some half brothers"],[5560,5703,"trying to boss me around?"],[5752,5960,"I'm just one phone call away"],[5984,6103,"to St. Clairs."],[6232,6435,"And your body will be chopped up,"],[6435,6564,"and thrown,"],[6564,6692,"and dumped into the river."],[6856,6935,"Say right."],[7004,7156,"Is that right? Party boy."]],"20":[[16,143,"Is that right? Party boy."],[391,571,"You really like her bad, don't you?"],[651,755,"Well, let's be fair."],[856,1024,"Why don't you tell everybody"],[1059,1164,"who you really are?"],[1356,1456,"Marry Maria."],[1755,1844,"And I'll do"],[1916,2000,"what I need to do."],[2960,3039,"What'd you order?"],[3071,3328,"Just some chicken and some vegetables."],[3356,3456,"Delicious."],[3532,3658,"Need some salt and pepper?"],[3670,3735,"No."],[3815,3884,"Hey."],[3884,4015,"Sweetie."],[4092,4171,"You look great."],[4320,4484,"Mom, you finally made it."],[4484,4560,"I did."],[4620,4752,"Although you should see the schedule"],[4752,4900,"Richard had me on today?"],[4935,5043,"I had to ditch his assistant"],[5043,5147,"just to get here."],[5147,5300,"Oh, ignore that robot."],[5400,5535,"You're the boss around here."],[5739,5964,"Eric, are you trying to date my mom?"],[6171,6364,"Honey? Lola!"],[6375,6489,"I'm just saying"],[6489,6679,"you guys would look good together."],[6692,6828,"Sorry. Sorry about that."],[6828,6979,"That's just Lola,"],[6979,7156,"she likes to say whatever in her"],[7164,7307,"twisted little mind."],[7307,7471,"Well, she's got a point."],[7512,7615,"Everyone wants to be"],[7671,7831,"dating the head of the St. Clair family,"],[7831,7914,"Maria."],[7914,8112,"Well, any more comments like that"],[8112,8323,"and don't expect me to go out with you again."],[8371,8515,"Would you like a glass of wine?"],[8556,8700,"Yes, I think I would."],[8700,8779,"Waiter."],[9056,9192,"Glass of wine. Thank you."]],"21":[[0,88,"Wait!"],[1008,1100,"Everything's okay."],[1100,1180,"It's okay."],[3288,3407,"It's okay."],[3547,3615,"Oh my god, it's..."],[3615,3696,"Oh."],[3756,3835,"I'm so sorry."],[3902,3999,"It's okay."],[4243,4407,"Yeah, it was so fun."],[4407,4556,"-So fun? -I'm heading to school."],[4556,4703,"Bye, Mom. Bye, Eric."],[4703,4835,"-See you later. -Bye, honey."],[4867,5064,"So... just now?"],[5064,5160,"Oh yeah."],[5160,5230,"That was nothing,"],[5230,5400,"just some hit man I had to take..."],[5484,5575,"deal with."],[5664,5779,"So, yeah, you might"],[5807,5920,"join me for a party?"],[5975,6047,"What, Eric?"],[6092,6203,"I almost got killed."],[6203,6284,"You're bleeding,"],[6284,6375,"and you want to go to a party?"],[6375,6456,"It's okay."],[6531,6595,"It's okay."],[6820,6984,"You're the godmother of the family"],[7040,7140,"you're the boss."],[7776,7856,"You know what?"],[7915,7995,"You're right."],[8076,8159,"I think I'll go."],[8287,8348,"Great!"],[8371,8464,"I'll see you there."],[8656,8820,"It's a good time to try on"],[8859,9023,"the new wardrobe Richard's got me."]],"22":[[296,424,"Uncle Hans."],[424,608,"What the hell are you doing, Eric?"],[608,764,"I sent men to assassinate Maria"],[764,864,"and you knocked them out!"],[908,1099,"I'm not interested in your gang wars"],[1099,1283,"and I don't owe you any favors."],[1332,1524,"Don't forget, you're a Pattinson, too."],[3607,3700,"You look beautiful."],[3724,3775,"Hey."],[3788,3900,"Shall we?"],[3900,4015,"Oh, but I've never danced"],[4015,4115,"in front of people before."],[4128,4207,"You'll be great."],[4296,4375,"Okay."],[7651,7792,"Where has Maria gone?"],[7807,7892,"Enough!"],[7923,8064,"The dock warehouse situation"],[8064,8168,"must be solved today!"],[8212,8284,"Did you failing"],[8284,8448,"families should pull out of the docks?"],[8451,8528,"Bullshit!"],[8528,8684,"You're the ones that seized the docks"],[8684,8864,"and sabotaged operations!"],[8864,9028,"You're the ones that should pull out!"],[9048,9204,"The real question is,"],[9264,9423,"why is this the St. Clair leader absent?"],[9515,9679,"Is this their way of disrespecting"],[9679,9748,"everyone here?"],[10048,10104,"It's clearly"],[10104,10287,"if he doesn't show up in three minutes,"],[10292,10507,"every one of their men here dies!"]],"23":[[156,216,"It's clearly"],[216,400,"if he doesn't show up in three minutes,"],[404,620,"every one of their men here dies!"],[740,875,"Sorry, I'm late."],[1480,1783,"The St. Clair family leader is a woman?"],[1839,1987,"Has the St. Clair family"],[1987,2128,"completely lost their minds?"],[2167,2248,"Oh, come on."],[2248,2380,"All this killing talk"],[2380,2487,"is just exhausting."],[2487,2623,"Why don't we just all sit down"],[2623,2700,"and have a drink?"],[2928,3187,"You think serving snacks is going to"],[3187,3375,"solve everyone's problems."],[3443,3584,"I was getting hungry."],[3596,3747,"That actually looks pretty good."],[3920,4035,"So now I hear"],[4035,4207,"you two bosses have a disagreement"],[4207,4420,"about dock warehouse authority."],[4447,4615,"What about I have a try at that?"],[4707,4867,"Well... Let you try?"],[5039,5156,"The St. Clair family"],[5156,5307,"manages the dock house."],[5379,5515,"We absorb the losses,"],[5515,5628,"the profits get shared"],[5628,5764,"between the families."],[5764,5971,"Well, isn't that just a better peaceful way"],[5971,6035,"to do it?"],[6364,6443,"Deal."],[6720,6815,"Gentlemen."]],"24":[[636,708,"Maria,"],[724,875,"you were incredible tonight."],[891,1035,"You stopped several families"],[1035,1211,"from escalating their conflict,"],[1251,1475,"and the dessert was a nice touch."],[1575,1683,"How did you think of it?"],[1751,1876,"It's no different than handling"],[1876,2019,"family conflict back home."],[2064,2180,"Gerard was right."],[2216,2348,"You're a natural born leader."],[2387,2484,"There."],[3552,3692,"You were at a party with Eric?"],[3879,3956,"I mean..."],[3988,4147,"Yeah, but don't get mad."],[4147,4252,"Of course..."],[4332,4435,"I'm mad."],[4592,4775,"I told you not to hang around with him."],[4775,4879,"He's dangerous."],[4935,5043,"How's he dangerous?"],[5043,5175,"He saved my life today."],[5175,5256,"What?"],[5320,5439,"He saved your life?"],[5500,5615,"Oh, um..."],[5664,5815,"Nothing. Let's call it a night."],[5815,5935,"What did you say?"],[6064,6171,"Nothing."],[6171,6296,"Don't worry about it."],[6296,6471,"Maria, come back here."]],"25":[[104,152,"What do you mean"],[152,291,"Eric saved your life?"],[308,368,"Tell me."],[368,487,"We were at the restaurant"],[487,620,"and the waiter came at me."],[628,767,"We realized later he had a gun,"],[767,848,"he was probably gonna shoot me."],[848,927,"So just..."],[1088,1203,"From now on,"],[1443,1583,"wherever you go, I go."],[1751,1892,"And I'm telling you no way."],[2032,2192,"You can't restrict my freedom."],[2244,2344,"Unless..."],[2728,2880,"You know exactly what I mean."],[3128,3392,"My job is to protect your life, not to..."],[3600,3728,"invade your freedom."],[3764,3888,"You're just scared of being"],[3888,4007,"shown up by Eric."],[4052,4139,"What did you say?"],[4311,4407,"You're rigid,"],[4452,4547,"and he's free."],[4688,4792,"Women crave that."],[5032,5124,"It's just too bad"],[5124,5252,"it's not in your blood, right?"],[5711,5928,"Not been making you so angry lately?"],[6143,6307,"You gonna teach me a lesson? Big guy."]],"26":[[291,463,"You just don't have what it takes."],[1683,1828,"Don't test my limits."],[1887,2048,"The few I have are stronger"],[2048,2148,"than you can imagine."],[2771,2948,"Allow me to fulfill my duties,"],[3028,3107,"Don Maria."],[3524,3603,"Don Maria."],[3660,3728,"Richard,"],[3760,3867,"my consigliere."],[4264,4360,"From now on,"],[4467,4711,"you follow my counsel."],[6171,6379,"To me, you're the sharpest blade"],[6379,6535,"and the deadliest poison."]],"27":[[227,424,"Thank you for your continued support."],[459,604,"Look forward to doing business"],[700,803,"together in the future."],[840,1024,"Absolutely, likewise."],[1127,1191,"And um,"],[1191,1364,"how your assets going?"],[1400,1564,"My assets, they're going great."],[1583,1703,"Cheers to the future."],[2603,2851,"Do you mind stop grabbing my ass?"],[2851,2948,"Sorry."],[3224,3400,"I'm gonna go talk to some bigwigs."],[3420,3656,"You just stay here and behave yourself."],[3656,3892,"Oh, using words like \"behave\", are we?"],[4667,4779,"Hi, Maria."],[4911,5000,"Why are you here?"],[5000,5100,"What do you want?"]],"28":[[64,143,"Hi, Maria."],[143,304,"Oh, what do you want?"],[352,575,"Come on, we're sisters."],[651,751,"What's wrong with a little"],[796,951,"family reunion."],[1035,1108,"Yeah."],[1143,1316,"Cut the crap. What do you want?"],[1524,1660,"We're in deep trouble."],[1739,1851,"Adria and I..."],[2035,2135,"We're in big time trouble"],[2135,2251,"with the lone sharks."],[2251,2392,"It's snowballed..."],[2435,2535,"two million."],[2544,2667,"Their goons are after us."],[2667,2792,"We're in real danger."],[2860,2976,"Okay, it sounds like"],[2976,3144,"that's your problem, not mine."],[3192,3307,"You've never treated me like"],[3307,3415,"a real sister, so..."],[3443,3615,"Why should I help you? Get lost."],[3652,3768,"Maria,"],[3779,3960,"don't be so cold."],[3971,4160,"It's the anniversary of our mother's..."],[4243,4324,"Yeah."],[4400,4535,"She really want to watch us"],[4535,4732,"crash and burn today?"],[4760,4900,"Don't you remember we promised her"],[4900,5075,"we'd look out for each other?"],[5203,5284,"Please."],[5284,5400,"Please help us."],[5532,5615,"Okay, fine."],[5675,5743,"Fine."],[5943,6115,"There are two million wired to you,"],[6115,6175,"okay?"],[6192,6300,"Thanks, Maria."],[6300,6404,"You're a saint."],[6440,6579,"Oh, by the way,"],[6592,6792,"remember Grandpa left me his jewelry?"],[6792,6980,"I really thought that you deserved a piece."],[6980,7059,"Yeah."],[7059,7184,"Like a keepsake."],[7212,7323,"Why don't you come get it?"],[7323,7415,"Come by my room."],[7415,7531,"Yeah, come on."],[7592,7679,"-It can be fun. -Come on."],[7679,7807,"Sister, it's fun."],[7807,7876,"Okay, okay."],[9231,9315,"Where's the jewelry?"],[9315,9431,"Just over there."]],"29":[[108,260,"Did you really think I'd kneel down"],[260,424,"to someone as disgusting as you?"],[491,628,"Just looking at that chubby mug"],[628,748,"makes me sick."],[748,927,"Don't waste your breath, Adria."],[972,1064,"Kill her."],[1148,1235,"Maria,"],[1280,1435,"tell Grandpa I said hi."],[2635,2764,"What the hell is going on here?"],[2812,2907,"Oh, Richard..."],[2944,3155,"We're just messing around, sis stuff."],[3203,3315,"What's behind your back?"],[3532,3756,"Messing around with poison?"],[3828,3964,"Get on your knees!"],[4203,4332,"Attempt to kill the Don."],[4375,4472,"Family rules state"],[4472,4579,"that you must be executed."],[4660,4847,"No, please don't execute us."],[4871,5007,"You can't execute me."],[5007,5147,"Maria would never allow it."],[5184,5279,"Kill her own sister"],[5279,5465,"and the family would disown her."]],"30":[[80,212,"I don't have to kill you."],[287,440,"But I don't have to help you either."],[479,648,"You... what are you doing?"],[659,767,"I'm sending your photos"],[767,980,"and your location to your loan sharks."],[1032,1167,"-No. Don't. -No, no, no, please."],[1167,1235,"Oh,"],[1235,1343,"and your bank accounts?"],[1343,1408,"They're frozen."],[1408,1580,"-No, no, no. -Maria, you can't do this!"],[1607,1783,"You can't do this, Maria!"],[1807,1892,"Maria!"],[2396,2592,"Adria, Natalie,"],[2592,2732,"where are you running to?"],[2735,2800,"Please!"],[2800,2948,"Please just give us a few more days,"],[2948,2981,"okay?"],[3035,3132,"We can get the money."],[3192,3375,"Rules are rules I'm afraid."],[3484,3547,"Sorry."],[3592,3671,"Slap them."],[3707,3828,"No, no, no."],[3920,4052,"Rule is..."],[4088,4152,"I'm gonna pull out"],[4152,4292,"every one of your teeth"],[4307,4532,"one by one."],[5107,5267,"This is going to take a while."]],"31":[[264,324,"Don't cry."],[851,932,"No."],[1100,1180,"Maria."],[2032,2212,"I know what you did today was hard."],[2371,2519,"You were backed into a corner."],[2603,2744,"You didn't have a choice."],[2903,3064,"I just don't get why they hate me"],[3064,3164,"so much."],[3364,3520,"We can't choose our roots."],[3624,3811,"We can choose how to face them."],[3943,4024,"Okay?"],[4356,4479,"You're not gonna leave, aren't you?"],[4756,4856,"Never."],[5788,6003,"I need to get back with the Pattinsons"],[6003,6196,"and settle the war with the St. Clairs."],[6211,6446,"Only then can I be with Maria officially."]],"32":[[551,683,"Ms. St. Clair..."],[775,924,"Had no heads up you were coming."],[924,1064,"Oh, I'm just passing by,"],[1064,1280,"I thought I'd check on operations, so..."],[1348,1419,"What's that date?"],[1419,1583,"Well, we've reclaimed the warehouse"],[1583,1723,"from Stevenson's crew."],[1723,1912,"Dock profits seem to be creeping back up"],[1912,2028,"but I can go and check"],[2028,2116,"if you give me a moment?"],[2135,2212,"Yeah, do that."],[2212,2267,"Okay."],[3428,3547,"Stop!"],[3575,3656,"Stop... Nikki?"],[3656,3832,"Well, look who it is?"],[3832,4052,"Jack's useless ex."],[4075,4167,"What's the matter?"],[4167,4392,"Lost your man to me and now you're so broke"],[4392,4528,"you had to come work here?"],[4775,4928,"You better get out of this warehouse"],[4928,5067,"before I break your legs."],[5167,5315,"Are you threatening me?"],[5356,5652,"You haven't got the guts! You're nothing!"],[5707,5899,"I don't even fear that pathetic family"],[5899,6015,"that stole this warehouse"],[6015,6107,"from my dad."],[6328,6375,"Well."],[6396,6543,"You better hope my family doesn't"],[6543,6692,"hear about this, or I..."],[6692,6853,"don't think your botox covered face"],[6853,6956,"is gonna handle it."],[7135,7215,"You!"]],"33":[[36,174,"Maria isn't the pushover"],[174,287,"I thought she was."],[287,451,"Since when did she get this tough?"],[467,551,"Nikki!"],[612,716,"What's going on here?"],[716,903,"Jack, she's bullying me!"],[1067,1196,"What are you doing here?"],[1196,1291,"What is this?"],[1472,1680,"You're nothing but a pathetic worm, Jack."],[1719,1848,"Grab that bitch!"],[1867,1960,"Worm Jack."],[1992,2148,"What are you doing here?"],[2319,2492,"Should teach this bitch a lesson."],[2492,2616,"Break her hand!"],[2648,2790,"That St. Clair family"],[2790,2971,"ripped this warehouse from me."],[3039,3220,"I'm taking you down as well."],[3260,3352,"Smash it!"],[3615,3828,"St. Clairs won't let you get away with this."],[3835,3915,"Guess what?"],[4047,4220,"Mr. E's got my back."],[4228,4371,"I'm not afraid of them."],[4415,4711,"And you working for the St. Clairs."],[4835,4915,"Come on."],[4996,5143,"I'll break your arm"],[5143,5307,"and send them a message too."],[5432,5511,"Stop."]],"34":[[28,108,"Stop."],[440,520,"Let her go."],[628,720,"Oh, Mr. E."],[740,819,"Perfect timing,"],[819,951,"I was just teaching this"],[951,1119,"St. Clair lackey a lesson."],[1148,1288,"I've only met you at a conference"],[1288,1443,"I never said I'd team up with you."],[1503,1707,"I never said I was also part of St. Clairs."],[1803,1967,"Now you reckon my name?"],[2712,2792,"What?"],[2832,3003,"Steven's company stock!"],[3028,3167,"Completely wiped!"],[3243,3311,"Mr. E,"],[3311,3488,"no, please forgive me."],[3488,3628,"I... I didn't mean..."],[3679,3767,"I'm sorry."],[3767,3920,"You shouldn't have mercy on me."],[3971,4092,"She's the boss."],[4164,4252,"Her?"],[4284,4520,"She's just a useless housewife!"],[4520,4611,"Her own husband"],[4611,4739,"doesn't even want her."],[4764,4928,"What can she possibly do?"],[4967,5107,"She is Don Maria,"],[5107,5320,"the head of the St. Clair family."],[5403,5552,"And she'll destroy you."],[5607,5743,"That's not possible!"],[5807,5920,"You idiot!"],[6088,6220,"You've ruined us!"],[6364,6520,"Don Maria, please forgive us."],[6520,6704,"I didn't know your true status."],[6771,6904,"Just spare us, please."],[7023,7107,"Don Maria,"],[7259,7384,"what should we do with these two?"]],"35":[[44,167,"What should we do with these two?"],[528,620,"Take them to our friends"],[620,712,"at the police."],[840,924,"You heard her."],[1556,1660,"Get lost, Jack."],[3252,3420,"Okay, can someone break the ice already?"],[3420,3507,"This is painful."],[3556,3784,"I thought I made my point clear."],[3864,4007,"I told you to stay away"],[4007,4103,"from the godmother."],[4147,4384,"I gotta stay away from the godmother?"],[4400,4492,"Oh, please."],[4532,4632,"You've had some fun"],[4632,4775,"with the godmother lately?"],[4775,4852,"Eric!"],[4900,5039,"What the hell are you implying?"],[5039,5147,"Come on, Maria!"],[5184,5271,"Come on."],[5271,5388,"Don't lie to me."],[5443,5639,"You two haven't been doing it."],[5839,6039,"How are the elders going?"],[6039,6252,"I've got some news to tell them."],[6347,6420,"Is that right?"],[6420,6504,"Yeah."],[6620,6785,"My job is to neutralize any threat."],[6785,6951,"and I wouldn't mind starting with you."],[6965,7069,"Oh, really?"],[7331,7395,"Stop it, Richard!"],[7395,7487,"This isn't helping."],[7531,7595,"Come on."],[8235,8307,"Hello?"],[8307,8515,"Mom, Mom, Mom. Where are you?"],[8515,8575,"Please help!"],[8575,8623,"What?"],[8623,8811,"Help, help, Mom. Where are you?"],[8815,8923,"What's going on?"]],"36":[[20,163,"Mom, Mom, Mom. Where are you?"],[163,296,"Why aren't you picking up?"],[296,408,"What's going on?"],[408,536,"Dad didn't pick me up,"],[536,697,"now these two random dudes..."],[697,835,"they are chasing me."],[835,1011,"And I don't know what to do."],[1032,1151,"Tell me where you are?"],[1188,1332,"I'm on the corner of smithy."],[1456,1532,"Please."],[1532,1751,"Please, let me go. Let me go. Let me go!"],[1767,1832,"Mom!"],[1923,2051,"Lola's got thugs over her."],[2051,2151,"We've got to go now."],[2180,2296,"Okay, let's go."],[2351,2439,"I'm coming with you."],[2439,2503,"No, you're not."],[2503,2655,"No, Eric. Thank you."],[2655,2783,"But I just need Richard."],[3016,3096,"What?"],[3660,3911,"Our boss likes you but you hit him."],[3932,4043,"Not a smart move!"],[4043,4160,"Looks like you need a lesson."],[4160,4415,"No, my mom is gonna make you pay!"],[4424,4496,"Oh, you hear?"],[4496,4620,"Her mom is gonna hit us."],[4760,4860,"That scares us up."],[5020,5173,"No. No."],[5752,5832,"What are you doing here?"],[5832,5896,"You old hag."],[5920,6032,"Mind your business..."],[6204,6335,"Lola, are you okay?"],[6384,6476,"Did they hurt you?"],[7100,7179,"Watch out!"],[7320,7400,"Richard!"],[7759,7923,"Richard, you're hurt."],[7923,8015,"It's okay."],[8100,8179,"Come on. Let's go."]],"37":[[1375,1432,"Here,"],[1467,1527,"let me—"],[1860,2000,"Is this part of the job?"],[2307,2500,"Pretty badass yourself,"],[2544,2628,"Don Maria."],[2719,2860,"I couldn't have done it without you."],[2996,3220,"You've changed my life around, Richard."],[3400,3503,"With no Eric today,"],[3567,3667,"could get used to that?"],[3888,4000,"I only need you."],[6396,6543,"Gotta hand it to you, Maria."],[6595,6823,"Your leadership skills, they are unreal."],[6868,7051,"Turn the dock's profits from red to green"],[7051,7219,"in just over one year."],[7287,7459,"Oh, it's good to do some real good"],[7459,7588,"for the family."],[7631,7704,"Cheers."],[8407,8492,"Gentlemen,"],[8523,8620,"excuse me."],[9407,9487,"Eric?"]],"38":[[44,92,"Eric?"],[92,220,"Why don't you want me tonight?"],[220,331,"What the hell are you doing?"],[331,475,"How much have you had to drink?"],[491,563,"What do you mean?"],[563,675,"I want you tonight!"],[712,816,"Can you just let me go?"],[816,948,"I want you... hey!?"],[948,1019,"Ah!"],[1048,1243,"Wait, stop! Stop! Stop, guys!"],[1259,1351,"If anyone walks in,"],[1351,1451,"we're all done for."],[1503,1600,"Who cares?"],[1600,1700,"I wanna see the"],[1764,1887,"Patissons fighting each other"],[1887,2067,"over the St. Clair boss."],[2100,2200,"Pattinsons?"],[2200,2276,"Yeah."],[2276,2371,"What are you talking..."],[2380,2532,"Richard, what is he talking about?"],[2632,2755,"Maria, I was waiting for the right moment"],[2755,2812,"to tell you."],[2823,2955,"He's undercover."],[2980,3176,"He wants to destroy the St. Clairs."],[3292,3532,"That's a lie! Maria, he's lying."],[3592,3700,"You gotta trust me."],[3784,3856,"It's not."],[3896,4011,"Who cares, anyway."],[4043,4152,"I lost."],[4196,4290,"Goodbye, Maria."],[4484,4560,"Listen, Maria,"],[4560,4735,"he doesn't know what he's talking about."],[4735,4815,"He's drunk."],[4843,4992,"I can explain everything."],[5224,5303,"You're hurt."],[5360,5439,"Please."],[7792,7900,"You need to trust me."]],"39":[[279,360,"Hello?"],[712,767,"Maria?"],[819,916,"Jack?"],[1011,1156,"Well, you have some nerve to call me."],[1224,1435,"Look, I got Lola with me and..."],[1500,1635,"she wants us to meet."],[1740,1887,"I'm downstairs. Do you want to come out?"],[1944,2116,"Fine, I'll come out."],[2912,3044,"Yeah, I'm on my way now."],[3103,3315,"You just called me. I'm on my way."],[3471,3575,"Where are you then?"],[5352,5492,"Don Maria come back yet?"],[5515,5567,"No, sir."],[5567,5711,"Wasn't she with you at the event?"],[6795,6892,"My dear nephew,"],[6892,7071,"time to unveil your true self."],[7140,7364,"Won't play your games, Uncle Hans."],[7415,7535,"You don't have a choice."],[7564,7746,"Bring me the St. Clair elders to the factory"],[7746,7891,"or your Maria dies."],[7900,7979,"Howard,"],[8051,8143,"call the elders."],[8223,8384,"Get them together tonight. Go!"]],"40":[[0,104,"Hans!"],[119,216,"What's your play?"],[343,424,"Simple."],[496,575,"A trade."],[675,996,"My nephew Richard for your boss Maria."],[1019,1072,"Yep?"],[1132,1235,"I've told everyone."],[1316,1532,"Richard's my brother's long lost son."],[1572,1732,"Missing twenty-five years."],[1776,1851,"I should have known"],[1851,2055,"that snake was right under our nose."],[2180,2351,"Richard's too honorable to"],[2383,2603,"mesh with St. Clair trash."],[2635,2835,"Gerard's warehouse death?"],[2960,3060,"You framed us,"],[3096,3235,"attacked our turf."],[3296,3407,"We'll never forget!"],[3407,3492,"Enough!"],[3643,3752,"Let's swap."],[7079,7151,"Damn it!"],[7200,7359,"Ambush! Grab them!"]],"41":[[20,224,"We've brought you to the Maria here."],[239,343,"And now what?"],[343,483,"We can't let outsiders"],[483,736,"think the St. Clair family is a joke."],[767,943,"We have to execute Richard."],[1180,1227,"Fine."],[1316,1391,"No one?"],[1427,1583,"Then I'll do it myself."],[1716,1839,"Everyone stand down."],[1907,1980,"What?"],[2063,2135,"You're not..."],[2135,2248,"You're not gonna protect him."],[2319,2376,"No."],[2448,2567,"I'm gonna kill him myself."],[2623,2687,"You?"],[3064,3155,"Betrayer."],[3364,3443,"You know,"],[3443,3533,"you're the one that taught me"],[3533,3638,"how to shoot."],[3707,3860,"Said if I aim right here,"],[3947,4047,"kill with one shot,"],[4047,4167,"there'll be no suffering."],[4243,4379,"You're a damn good teacher."],[4460,4579,"My final exam."],[4667,4788,"Everyone watch!"],[4884,4996,"This is what happens to those"],[4996,5124,"that betray our family."],[6420,6531,"Are you satisfied?"],[6576,6668,"Uncle Paulie."],[6864,6943,"Certainly."],[7040,7135,"I'm too old."],[7215,7328,"I've had enough of this shit."]],"42":[[451,532,"Well."],[640,819,"Suppose I should thank you for"],[872,980,"using a fake bullet."],[1080,1256,"No, you should thank yourself."],[1296,1419,"Everyone's watched you grow up."],[1419,1575,"There's no way they would watch you die."],[1671,1776,"That's why I convinced them to"],[1776,1951,"fake this whole show for uncle Paulie."],[1980,2044,"Yeah, well."],[2171,2355,"I don't think he has much time left."],[2616,2732,"You can't stay here."],[2803,2883,"You've gotta go."],[3012,3129,"Maria, the reason I stayed"],[3129,3264,"with the St. Clairs is..."],[3264,3400,"Because I wanted to put an end to"],[3400,3600,"this war between the two families."],[3700,3811,"I've never betrayed you."],[3892,3971,"No, I know."],[4011,4100,"I know who you are."],[4279,4371,"But you have to go."],[4635,4715,"You go!"],[5935,6064,"Go."],[6160,6275,"Never come back!"]],"43":[[20,126,"We need to settle this fight"],[126,324,"between the Pattisons and the St. Clairs"],[352,462,"That's because the Pattisons"],[462,632,"kept going after our territory."],[632,728,"Lies."],[927,1085,"These conflicts were caused"],[1085,1208,"by the St. Clair family"],[1208,1324,"in the first place."],[1383,1475,"If they hadn't blamed"],[1475,1603,"Gerard's death on us"],[1603,1848,"without cause seeking revenge,"],[2071,2219,"none of this would have happened."],[2276,2348,"So,"],[2392,2555,"what does Don Maria"],[2555,2651,"have to say about that?"],[2983,3064,"Maria?"],[3228,3307,"Maria!"],[3500,3579,"Oh."],[3660,3892,"My grandfather's death was not an accident."],[3920,4000,"It was murder."],[4011,4137,"And I'm going to find the killer"],[4137,4300,"that did it and expose their scheme."],[4400,4484,"Until then,"],[4539,4692,"the St. Clair will make no moves"],[4692,4828,"against the Pattinsons."],[4907,5052,"Unless you give us a reason."],[6712,6843,"Long time no see,"],[6951,7040,"Don Maria."],[7231,7420,"Likewise, Mr. Pattinson."],[7543,7704,"I was hoping we could talk about..."],[7787,7948,"I've been looking everywhere for you."],[7948,8064,"Where have you been?"],[8343,8564,"Nikki? Are you two—"]],"44":[[40,279,"Well, if it isn't the esteemed Don Maria."],[360,528,"Ricky and I are engaged,"],[528,644,"wedding's in July."],[740,900,"Wow, how..."],[983,1088,"unexpected."],[1208,1364,"Daddy's company bounced back,"],[1364,1524,"so uncle Hans"],[1524,1735,"organized my marriage to Richard."],[1780,2003,"What about you, Maria?"],[2039,2235,"How come no man's interested in you?"],[2967,3080,"Who says there isn't?"],[3116,3200,"I am."],[3743,4015,"Well, congratulations."],[4060,4160,"Let's go, Ricky."],[4315,4400,"Maria."],[4500,4584,"I think it's finally time"],[4584,4675,"we got together."],[4839,4920,"Eric!"],[5107,5224,"Maria St. Clair,"],[5379,5479,"will you marry me?"],[5815,5875,"This..."],[5875,6003,"This is too fast, Eric."],[6003,6152,"Can we date first?"],[6292,6375,"Of course, honey."]],"45":[[740,819,"Lola?"],[927,1003,"Yeah, where are you?"],[1003,1088,"I can't see you."],[1164,1267,"Keep walking straight?"],[1296,1340,"Okay."],[1467,1548,"Hold on."],[1671,1751,"Richard?"],[1828,1992,"Lola texted me to wait here."],[2880,3081,"Sorry, look, the kid just thinks that maybe..."],[3081,3247,"You're seriously gonna marry Eric?"],[3324,3424,"You don't love him."],[3500,3620,"Well, do you love Nikki?"],[3703,3784,"I'll marry a woman"],[3784,3975,"who knows her responsibilities, and..."],[3996,4171,"won't bring trouble to the family."],[4288,4484,"You know, maybe I was just fooling myself."],[4532,4628,"Maybe I shouldn't have saved you"],[4628,4739,"that day, anyway,"],[4739,4852,"should've just let you die."],[4952,5052,"You seriously think you have"],[5052,5180,"what it takes to kill me?"],[6728,6843,"Hey, who are you?"],[6848,6951,"What do you want?"],[7059,7095,"Whoa..."],[7095,7179,"Do... I..."],[7387,7504,"Not so fast."],[7548,7664,"On your knees."],[7779,7831,"You okay?"],[7831,7912,"Yeah, I'm fine."],[8051,8131,"What?"],[8292,8404,"How is this possible?"],[8420,8548,"Why? What do you say?"],[8548,8648,"This is the birthmark"],[8648,8887,"from the factory blast that killed Gerard."],[8943,9079,"He supposed to be dead."],[9079,9179,"What that means?"],[9268,9467,"This might be the key to uncovering the truth"],[9467,9651,"behind your grandfather's death."],[9720,9820,"You're coming with me."],[9884,9964,"Get up!"]],"46":[[76,235,"Aren't you Mr. Rule-Follower?"],[256,379,"Since when do we start"],[379,528,"torturing the captives."],[575,654,"When you get to the bottom"],[654,787,"of Gerard's death."],[811,1016,"I might put an end to this family feud."],[1127,1327,"Well, he didn't crack, but..."],[1400,1527,"I'm glad we're on the same page"],[1527,1648,"about some things."],[1928,2019,"Eric?"],[2228,2312,"Hi."],[2735,2816,"Dinner?"],[3247,3433,"Yeah, of course. Um..."],[3839,3960,"That hotel?"],[4032,4179,"Is that the place with the mirrors"],[4179,4347,"on the ceiling and the..."],[4992,5100,"Nothing, I..."],[5175,5335,"I just got scared by a rat, I..."],[5415,5532,"I gotta go. Bye, Eric."],[5631,5839,"What the hell are you doing?"],[5915,6039,"Why does he"],[6107,6250,"get to break the rules all the time"],[6250,6412,"while I have to follow them?"],[7192,7271,"This is so..."]],"47":[[0,108,"Oh my god. What have we just done?"],[108,219,"Can you believe we've just done that?"],[219,335,"Do you believe we've just done that?"],[352,504,"How are we gonna explain this to everyone?"],[504,563,"-This is just such a night -Maria."],[570,687,"I can't believe we've just..."],[724,873,"Shh."],[1064,1180,"We're meant to be together."],[1240,1303,"So..."],[1348,1451,"you and Nikki..."],[1480,1583,"Are you two?"],[1651,1800,"We're just business partners,"],[1800,2019,"but she seems to have gotten the wrong idea."],[2332,2519,"I used to think I was just your..."],[2612,2748,"subordinate, but"],[2819,2928,"now I know I need you."],[3151,3347,"Body and soul."],[3411,3584,"I thought I lost you forever."],[3771,3992,"We're gonna find a way out of this mess and..."],[4100,4224,"And then we can be together"],[4300,4379,"officially."],[4443,4584,"How do you plan doing that?"],[4611,4743,"Do you have any ideas?"],[4803,4884,"Well."],[4984,5103,"With this will,"],[5184,5288,"there's always a way."],[6071,6252,"Oh, the lovebirds are back."],[6404,6535,"What's it gonna be this time?"],[6643,6792,"Acid or pliers?"],[7100,7184,"Your sister,"],[7271,7351,"Annie."],[7751,7931,"She's got a rare blood condition."],[7987,8156,"Treatment started two million."],[8179,8251,"Is that right?"],[8300,8429,"Looks like we're the only people"],[8429,8495,"who can help."],[8912,9048,"Look, we're happy to pay for it"],[9048,9200,"and fund her until college."],[9228,9368,"All you have to do is tell us the truth"],[9368,9471,"about Gerard's death."],[9500,9635,"If you refuse,"],[9664,9843,"you're gambling with her life."],[9931,10020,"It's your call."],[10343,10423,"Okay."],[10592,10704,"I'll talk."]],"48":[[64,308,"Hahahaha!"],[308,475,"Salute!"],[880,959,"Gentlemen."],[1488,1639,"What the hell is this?"],[1639,1860,"Richard, how dare you hold that woman's hand?"],[1860,2060,"Have you completely forgotten our blood feud?"],[2139,2428,"The blood feud that never existed?"],[2660,2748,"What did you say?"],[2844,3015,"There was never a blood feud"],[3015,3360,"between the Pattinsons and the St. Clairs."],[3420,3603,"All these years of bloodshed"],[3603,3828,"was the result of a single conspiracy."],[3939,4128,"I won't let you disrespect"],[4128,4279,"the martyrs of the Pattinson."],[4324,4460,"I'm stripping your concessionary"],[4460,4615,"position right now!"],[4647,4849,"Uncle Hans, I don't think you have the credentials"],[4849,4986,"to do that anymore."],[5047,5200,"And let me show you why."],[5515,5715,"Hans Pattinson hired me to stage"],[5715,5833,"the warehouse explosion"],[5833,6035,"that killed Gerard St. Clair."],[6067,6215,"He did this to destroy"],[6215,6375,"the St. Clair-Pattinson alliance."],[6428,6635,"Throw the whole families into chaos."],[6635,6784,"So he could seize power"],[6795,6964,"and make fortune in the process."],[7140,7235,"This is..."],[7440,7579,"This is slander!"],[7600,7795,"He made this with AI!"],[7823,7923,"He hired an actor."],[7987,8076,"Oh, please."],[8076,8243,"I have all the evidence right here."],[8259,8387,"Transaction records,"],[8387,8595,"meeting records, everything!"],[8700,8822,"All the conflict between"],[8822,9007,"the St. Clairs and the Pattinsons"],[9007,9207,"was instigated by Hans alone."],[9207,9479,"He is our common enemy."],[9635,9715,"Guards."],[9815,9895,"Guards!"],[10248,10307,"Take out this"],[10307,10584,"Pattinson family traitor now!"],[10707,10787,"Ron,"],[10840,10995,"if it wasn't for Hans,"],[10995,11107,"your brothers-in-arms"],[11107,11259,"would still be alive."],[11312,11487,"Let's put an end to this bloodshed"],[11520,11576,"tonight."],[11659,11807,"Why don't you join us?"]],"49":[[391,540,"What are you doing?"],[628,708,"Get him out of here."],[708,787,"Kill him!"],[851,1111,"He'll be judged the family meeting tonight."],[1408,1488,"Richard!"],[1543,1696,"Back-stabbing bastard!"],[1912,1992,"Go!"],[2316,2464,"Richard, what's going on?"],[2528,2783,"Why is Uncle Hans being dragged away?"],[2835,3064,"Hans conspiracy has been exposed."],[3064,3243,"He's no longer the leader"],[3252,3388,"of the Pattinson family."],[3484,3564,"Right, well."],[3652,3811,"He had it coming, I suppose."],[3911,4032,"Listen, I wanted to talk to you"],[4032,4143,"about something."],[4207,4296,"I think it's about time"],[4296,4452,"I picked out my wedding dress."],[4571,4652,"Oh, honey."],[4724,4907,"I hate to break it to you this way, but"],[4907,4971,"I don't think you guys"],[4971,5064,"will be having a wedding."],[5271,5452,"Richard, you better slap this bitch"],[5452,5596,"to wake her the fuck up."],[5643,5728,"She's right."],[5767,6064,"This entire wedding was just a charade"],[6067,6228,"arranged by Hans."],[6307,6564,"And now that we're no longer engaged,"],[6564,6728,"I don't have to be so polite to you."],[6823,6935,"Don't you love me?"],[7043,7248,"Nikki, you are vain,"],[7323,7423,"conceited,"],[7487,7568,"and evil."],[7707,7879,"There is no room for you"],[7879,8015,"in the Pattinson family."],[8215,8351,"I only love one person."],[8564,8751,"How could you do this to me?"],[8764,8835,"Her?"],[8868,8964,"Seriously?"],[9028,9151,"Why does she get everything"],[9151,9231,"she wants?"],[9231,9415,"Drag you away, Nikki."],[9464,9671,"Let go of me!"],[10087,10195,"Alright, everyone."],[10207,10388,"The feud between the Pattinsons"],[10388,10551,"and the St. Clairs"],[10576,10731,"is officially over."]],"50":[[532,636,"So, you're really going?"],[636,851,"What happened today made me realize"],[872,1048,"the family ties are too strong."],[1124,1224,"I'll be leaving now."],[1291,1372,"So,"],[1443,1524,"where are you going?"],[1556,1639,"Oh, I don't know."],[1667,1828,"Anywhere I guess. I got the money."],[1987,2048,"Well,"],[2048,2187,"the St. Clair family wouldn't be"],[2187,2244,"where we are"],[2244,2364,"if it wasn't for you."],[2455,2571,"Oh, no. It's okay."],[2571,2635,"I'm just gonna cry"],[2635,2787,"on some stripper's shoulders tonight."],[2832,2996,"But hey, Richard, I warn you."],[3067,3203,"You treat this woman right,"],[3254,3388,"or else I'll come back and kill you"],[3388,3528,"and marry her myself."],[3667,3756,"Not gonna happen."],[4275,4375,"I'll be off now."],[4443,4628,"Alright, good luck."],[4939,5000,"Eric,"],[5032,5203,"what an interesting guy."],[5203,5292,"Interesting."],[5367,5475,"More importantly,"],[5556,5644,"Maria."],[5680,5784,"Mm-hmm?"],[5871,5967,"Will you marry me?"],[6267,6372,"My childhood dream"],[6372,6507,"will finally come true."],[6615,6715,"And the Pattinsons"],[6715,6823,"and the St. Clairs"],[6823,6943,"will finally tie the knot."],[7015,7151,"It's the perfect ending."],[7251,7384,"It's not gonna be easy, though."],[7468,7612,"Got a lot of challenges ahead."],[7768,7848,"Are you ready?"],[8004,8165,"As long as I've got you,"],[8243,8415,"I'm not afraid of any challenge."],[8504,8728,"Maria, loving you has been the most"],[8915,9020,"beautiful mission,"],[9068,9207,"I've ever undertaken."],[9387,9431,"Well,"],[9431,9707,"this mission has no expiration date, so,"],[9712,9856,"you're never allowed to quit,"],[9856,9951,"Mr. Pattinson."],[10023,10128,"And, um..."],[10351,10448,"I love you too."]]}