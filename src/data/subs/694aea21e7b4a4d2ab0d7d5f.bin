ut"],[5213,5313,"about what she did to you."],[5359,5526,"And you think that humiliating her"],[5526,5651,"in front of hundreds of people,"],[5651,5747,"that that's just going to"],[5747,5905,"make everything okay?"],[5997,6147,"Hurting people, that's,"],[6147,6368,"that's Sabrina, that's not me."],[6410,6556,"So you hurt yourself instead?"],[7023,7140,"Come here."],[7720,7841,"Nobody's perfect, Lennon,"],[7974,8087,"but from where I'm standing,"],[8087,8233,"you're pretty fucking close to it."],[8571,8679,"Four years ago,"],[8787,8950,"the night that we broke up,"],[9096,9309,"did you really have sex with Sabrina?"]],"42":[[20,225,"Did you really have sex with Sabrina?"],[316,450,"After last night you turned around"],[450,596,"and you slept with my bully?"],[633,738,"I hate you,"],[784,963,"and I never wanna see you again!"],[1034,1084,"No."],[1192,1330,"I've never had sex with Sabrina."],[1397,1509,"There's only one girl I've wanted"],[1509,1597,"for the last four years."],[1714,1801,"You, Lennon."],[1839,1906,"And I'm tired of"],[1906,1993,"fucking waiting for you"],[1993,2114,"to admit that you want me, too."],[2665,2957,"So, you made me believe"],[2957,3103,"that you slept with Sabrina"],[3103,3261,"so you could steal my song"],[3261,3353,"behind my back?"],[3353,3436,"I'm sorry, Lennon."],[3532,3678,"I was fucking young and I was scared"],[3678,3737,"and I was selfish"],[3737,3874,"and I know that I stole your song."],[4037,4149,"But you fucking stole my heart."],[4337,4433,"And I've never been in love"],[4433,4508,"with anyone else,"],[4508,4658,"and I can't fucking lose you again."]],"43":[[125,296,"I really loved you, Phoenix."],[437,554,"I know you did, Len."],[717,892,"I never stopped loving you."],[4104,4270,"You're driving me fucking crazy,"],[4270,4341,"you know that?"],[4408,4537,"I want your crazy,"],[4604,4688,"every bit."],[6202,6339,"In my room, or yours?"],[6765,6906,"What about both?"]],"44":[[450,487,"Hey."],[1080,1176,"I was wearing this ring"],[1176,1288,"the day we got signed,"],[1426,1580,"and I've worn it to every show since."],[1580,1860,"It's kind of like a lucky charm for me."],[1889,1997,"I want you to have it."],[2035,2173,"Whoa, really?"],[2173,2298,"You're sure that"],[2298,2423,"you're not gonna need it again?"],[2494,2556,"No,"],[2631,2719,"I have you now."],[7148,7253,"Hey, Phoenix."],[7278,7386,"You miss your old man?"]],"45":[[12,70,"Dad."],[171,271,"You gonna say hi?"],[333,425,"What the fuck are you doing here?"],[575,709,"Can't I just swing by"],[709,855,"and pay my son a visit?"],[1067,1155,"Phoenix, I..."],[1355,1522,"Who's your new girlfriend, Phoenix?"],[1522,1630,"None of your fucking business, dad."],[1680,1776,"Oh, okay."],[1776,1856,"Well, anyway,"],[1901,2027,"I got a little money problem."],[2177,2302,"$10,000 should be good."],[2515,2686,"It means I raised your fucking ass"],[2686,2786,"for eighteen years."],[2794,2873,"Yeah."],[2907,3007,"Eighteen years of beating"],[3007,3111,"the fucking shit out of me."],[3111,3240,"How the fuck could I forget, Dad?"],[3453,3678,"Well, if my fucking son won't help me,"],[3766,3916,"maybe this chick will. Hey, hey chick-"],[3916,4016,"You touch her, and I'll break your"],[4016,4091,"fucking hand."],[4270,4383,"Taught you how, remember?"]],"46":[[183,304,"Taught you how, remember?"],[650,788,"Phoenix, no, he's not worth it."],[1117,1297,"My son is growing to be a man"],[1297,1426,"just like his daddy."],[1522,1693,"You're an abusive piece of shit."],[1730,1918,"Phoenix is nothing like you."],[1918,2006,"So why don't you leave"],[2006,2085,"before I have security"],[2085,2181,"throw your ass out?"],[2264,2369,"You're feisty, aren't you?"],[2477,2552,"Listen, Missy."],[2585,2711,"If you want me to leave, I'll leave."],[2806,2982,"But, uh, tell me this."],[3040,3144,"Aren't you supposed to be"],[3144,3332,"my son's sober companion?"],[3399,3445,"What,"],[3445,3545,"why are you taking a shower"],[3545,3741,"at 8:30 in this hotel room,"],[3741,