"I told you I caught a cold."],[738,896,"I just want to go home and sleep."],[934,1121,"Sit, we are here to talk"],[1121,1272,"to my parents about the wedding."],[1280,1426,"Okay? So don't mess this up."],[1426,1476,"Wait, wait."],[1484,1597,"We're here to meet your parents?"],[1597,1860,"Just smile and behave."],[1897,1976,"We can convince my"],[1976,2177,"dad we're a loving couple, alright?"],[2198,2327,"He might even give us a villa."],[3440,3616,"Dad! Hi."],[3716,3916,"This is Flora Wade."],[3995,4133,"My fiancée."],[4596,4771,"I know you two have met,"],[4779,4917,"but now I can"],[4925,5125,"finally introduce you."],[5288,5442,"Is that true?"],[5501,5568,"Are you really gonna to"],[5568,5668,"marry my son?"]],"44":[[233,375,"Think about your mom."],[633,809,"That's right, Mr. Russo."],[863,1088,"We had a small argument."],[1088,1213,"Now we're back together."],[1634,1701,"Dad."],[1822,1943,"Dad, are you okay?"],[2060,2156,"Yes."],[2231,2381,"I'm just,"],[2448,2623,"so happy for the both of you."],[2811,2873,"Let's discuss"],[2873,2973,"the wedding."],[3399,3482,"Me and Flora"],[3482,3645,"are very excited for our wedding."],[3691,3795,"I already booked a private jet"],[3803,4049,"to fly a thousand premium roses"],[4049,4129,"from Columbia."],[4137,4225,"Yeah,"],[4233,4358,"we got the food all taken care of."],[4358,4537,"Obviously, it's from all over the world."],[4546,4688,"All the finest restaurants."],[4750,4884,"And yes,"],[4884,4938,"we will be"],[4938,4996,"staying in that"],[4996,5121,"hotel I sent you earlier."],[5309,5401,"What do you think, babe?"],[5467,5534,"Sounds great."],[5534,5734,"It's all your call."],[5764,5897,"Now come on."],[5905,6035,"It's our wedding."],[6076,6193,"All right, so I insist"],[6193,6322,"you tell me anything you need."],[6381,6527,"I'm sure my dad wants to."],[6785,7065,"Yes, Miss Wade."],[7132,7219,"Anything you want."],[7469,7603,"Well, there's one thing"],[7603,7682,"I want from you."]],"45":[[116,204,"I'm all ears."],[