"],[3632,3732,"I let everyone down."]],"50":[[3837,3891,"Dude."],[3983,4079,"Tomorrow’s the big day."],[4087,4245,"Oh, don't remind me."],[4254,4408,"Who the thought you"],[4408,4571,"out of all people"],[4579,4675,"would be the first one"],[4675,4767,"to settle down."],[4775,4975,"Oh, shut the fuck up, okay?"],[5009,5205,"It's not like I had a choice."],[5213,5409,"My dad's stupid trust says I get"],[5413,5613,"the inheritance if I'm married."],[5680,5772,"Otherwise, I have to wait"],[5772,5972,"till I'm 35."],[6026,6131,"Like I'd ever marry"],[6131,6214,"that boring bitch"],[6214,6339,"if it wasn't for the money."],[6348,6493,"All right,"],[6502,6544,"All right."],[6556,6660,"Let’s, you know-"],[6664,6777,"Forget about all that."],[6785,6923,"Let's not ruin the fun."],[6931,6961,"Besides,"],[6961,7148,"I’ve got a surprise for you."],[7716,7841,"Hi, baby."],[7849,7941,"I'm Della."],[8016,8128,"Well,"],[8208,8341,"this is a nice surprise."]],"51":[[1201,1317,"So,"],[1463,1668,"how much for, you know?"],[1805,1868,"Aren't you getting"],[1868,1993,"married tomorrow?"],[2147,2348,"What if your fiancee finds out?"],[2435,2635,"She’s not my wife yet."],[2911,3111,"A thousand."],[3311,3511,"Go for it."],[5522,5697,"Oh, shit."],[5705,5905,"Hey, where are you going?"],[6260,6460,"We're just having fun."],[6552,6706,"Tomorrow's your wedding."],[6715,6802,"And you sneak around"],[6802,7002,"behind your bride’s back."],[7015,7215,"What do you even care?"],[7286,7494,"Flora’s never going to find out."],[7524,7661,"I swear to God,"],[7670,7720,"if he weren't"],[7720,7766,"my son,"],[7766,7811,"I would break"],[7811,8012,"every bone in your body."],[8049,8199,"Seriously?"],[8208,8274,"You take that bitch"],[8274,8475,"over your own son."],[8637,8783,"Go ahead."],[8792,8963,"Hit me again."],[9067,9184,"Just remember,"],[9192,9371,"I'm the one getting married."],[9380,9526,"Not you."],[9655,9738,"Or do you wish you were the one"],[9738,9801,"marrying her?"]],"52":[[266,404,"You're 