{"1":[[275,383,"Sold out!"],[638,804,"Get out of the car already!"],[804,900,"Come out!"],[1659,1856,"My name is Casey Reed."],[1881,1947,"No one knows"],[1947,2106,"I'm the heiress of Reed Records,"],[2114,2306,"the billion-dollar music empire."],[2356,2456,"Or that I'm Echo,"],[2498,2623,"the anonymous producer"],[2623,2756,"who swept the Grammys."],[2802,3003,"I chose to stay invisible,"],[3048,3165,"because I fell for the one man"],[3165,3265,"I shouldn't have."],[3307,3403,"Dexter Hayes,"],[3445,3653,"the rock star I secretly built"],[3653,3753,"from the ground up."],[3807,3920,"I'm his assistant,"],[3970,4045,"his lover,"],[4083,4204,"and his ghost writer."],[4229,4354,"We share the same music,"],[4375,4592,"but never the same spotlight."],[4704,4867,"Will you spit in my mouth?"],[5922,6101,"Dex, we're backstage,"],[6101,6243,"someone might see us."],[6502,6698,"I am so done hiding you."],[6840,6977,"You have no idea what you do to me,"],[6977,7040,"Casey."],[7052,7140,"You make me feel,"],[7140,7365,"you are my favorite song."],[7991,8120,"I lose control."],[8179,8299,"My little..."],[8596,8712,"I want you."],[8750,8996,"Dex, I need you."],[9259,9330,"Good."],[9538,9709,"Because you're already mine."],[9876,9947,"I'm gonna call you"],[9947,10060,"on that stage tonight."],[10160,10243,"I'm gonna sing the song"],[10243,10343,"that I wrote to you,"],[10414,10523,"and I'm gonna kiss you"],[10523,10635,"in front of everybody."],[10668,10839,"I'm gonna claim every inch of you,"],[10965,11081,"note by note,"],[11165,11319,"in front of the whole world."]],"2":[[329,454,"Hey Case, um,"],[521,592,"what, what's with"],[592,704,"all the secret phone calls?"],[704,850,"Just, what are you hiding?"],[992,1138,"Nothing, it's just work stuff."],[1347,1393,"Okay."],[1518,1693,"It's time I come clean too."],[1747,1910,"Once he finishes this concert,"],[1943,2102,"the Echo mask will come off,"],[2127,2369,"and I can finally be the real me."],[2406,2485,"His Echo"],[2527,2631,"and his Casey."],[2748,2802,"Thank you."],[2898,3107,"You are gonna be my lucky charm tonight,"],[3107,3211,"like always."],[4462,4654,"I can't wait to make you my wife."],[5530,5701,"He don't call me pretty."],[5701,5955,"He knows better than that."],[5955,6143,"We take a flight to my new city."],[6143,6389,"Bombay Sapphire in his bag."],[6456,6619,"Keep that diamond ring."],[6619,6790,"Tiffany's is not my thing."],[6898,7148,"I need champagne, Miss fame."],[7699,7761,"Yeah!"],[7811,7887,"Scarlett!"],[7887,7957,"And now,"],[7999,8179,"for the star of our show,"],[8237,8479,"the world's hottest pop star,"],[8500,8604,"and my soulmate,"],[8612,8842,"Dexter Hayes!"],[9150,9255,"Wait for me, right here?"],[9613,9763,"Dexter Hayes is my ticket"],[9763,9909,"to the top of the charts."],[9934,10060,"But I'll never lock him down"],[10060,10164,"as long as he's in bed"],[10164,10285,"with his frumpy assistant."],[10472,10668,"Applause for Scarlett Hart everybody!"],[10985,11119,"The fans already love us."],[11144,11232,"Dexter Hayes,"],[11261,11344,"you will be mine."]],"3":[[8,125,"Scarlett Hart,"],[158,262,"Dexter Hayes' groupie"],[262,408,"turned wannabe pop queen."],[429,613,"She's always throwing herself"],[613,713,"at my boyfriend."],[729,930,"Maybe once he puts a ring on it tonight,"],[946,1172,"she'll finally take the hint."],[1205,1347,"I've got a really special one"],[1347,1434,"for y'all tonight."],[1451,1539,"Hope you enjoy."],[1634,1722,"Let's go."],[1805,1893,"Dexter!"],[1943,2031,"Dexter!"],[2485,2581,"Shit!"],[2581,2802,"The backing mix is corrupted."],[2819,3019,"I can't let Dex's show get ruined."],[3040,3169,"Echo can fix this."],[3490,3574,"Are you here?"],[3636,3716,"I need your help."],[3874,4120,"What the hell is she up to?"],[4383,4462,"Well, I guess"],[4462,4608,"the uh, system couldn't handle"],[4608,4779,"all of our energy and good vibes, so."],[4921,5000,"I'll be right back."],[5384,5467,"There,"],[5488,5668,"your gear from the studio!"],[5730,5876,"Or should I say, Echo's gear?"],[5876,6076,"Dad, we've talked about this."],[6097,6268,"In public, I am not your daughter"],[6268,6398,"and I am not Echo."],[6398,6498,"But Dexter should know"],[6498,6635,"how hard you've worked for him."],[6698,6852,"You made him the star he is."],[7061,7186,"I'm telling him tonight."],[7228,7294,"But for now,"],[7374,7528,"I have a track to remix."],[7528,7640,"Oh, that's my girl."],[7953,8083,"When Dexter sees this,"],[8083,8258,"he'll dump that little cheater"],[8258,8495,"and run straight into my arms."],[10247,10335,"Oh my God."],[10335,10435,"These are the arrangements"],[10435,10577,"of all of Dexter's hit songs."],[10593,10798,"Is Casey Echo?"],[11690,11874,"Time to save Dex's concert."],[11891,11995,"Play the song!"],[12037,12157,"Play the song!"],[12195,12291,"God, where is Casey?"],[12291,12399,"She said she'd stay right here."],[12399,12483,"Play the song!"],[12483,12629,"The show is a disaster."],[12629,12725,"The fans are waiting."],[12725,12804,"Can you please find her?"],[12804,12858,"I need her."],[12858,12942,"No, Dexter."],[13096,13175,"I'm the one you need."],[13246,13292,"What?"],[14134,14247,"This is Echo's notebook."],[14552,14639,"Are you her?"]],"4":[[20,100,"Are you her?"],[487,542,"Listen,"],[558,746,"can you please save this song?"],[788,871,"I already did."],[1109,1155,"Thank you."],[1197,1234,"Wait."],[1388,1468,"Dexter, there's"],[1559,1659,"one more thing I should"],[1659,1747,"probably show you."],[1943,2189,"Casey has been hiding another man."],[2731,2907,"All those secret phone calls,"],[2907,3015,"dodged questions."],[3040,3186,"Casey was cheating on me"],[3186,3290,"this whole time?"],[3365,3557,"Dexter, I'm so sorry."],[3557,3745,"I would never, never do this to you."],[4008,4066,"Thanks."],[4867,5134,"Wait, didn't Echo just mix a new track?"],[5184,5330,"Uh, and we're back."],[5363,5492,"Well, I, I wrote this song"],[5492,5622,"for the love of my life."],[5905,6035,"At least I thought so."]],"5":[[171,275,"Get ready, Dex,"],[275,458,"the mix to your next big single"],[458,804,"is coming to you in three, two, one."],[913,1146,"I'm"],[1226,1772,"I'm running out of time."],[2932,3182,"Every time that I look I"],[3228,3499,"remember the time I saw you, I..."],[3541,3782,"one thing to remember you, by"],[3828,4095,"the time I looked into your eye."],[4095,4396,"The secret feeling I get, I"],[4396,4500,"Know it, I"],[4500,4946,"was running out of time."],[7978,8229,"I'm,"],[8308,8675,"I'm running out of time!"],[8675,9059,"Oh!"],[9059,9584,"I'm running out of time!"],[9680,9834,"How could Casey do this to me?"],[10347,10639,"Everyone, give it up for Dexter Hayes!"],[11815,11978,"He promised he'd call me up"],[11978,12120,"on stage to announce"],[12120,12274,"our relationship."],[12337,12454,"I loved her,"],[12491,12616,"and she betrayed me."],[13734,13817,"Oh my God!"],[13859,13943,"Dexxie!"],[13955,14043,"Oh my God!"],[14043,14222,"Is he proposing to Scarlett Hart?"],[14360,14426,"Yes!"]],"6":[[100,154,"Oh my God!"],[204,275,"Dexxie!"],[333,417,"Yes!"],[558,717,"Tonight was supposed to be"],[717,913,"the start of our new life together."],[984,1247,"I thought Dexter loved me,"],[1305,1388,"trusted me."],[1443,1743,"No, I never wanted propose to Scarlett,"],[1743,1922,"but she made my career,"],[1922,2139,"and Casey betrayed me."],[2444,2560,"It was all a lie."],[2777,2973,"Alright, I can play along"],[2973,3086,"with this engagement,"],[3086,3249,"and I can move on from"],[3249,3428,"the woman who broke my heart."],[4167,4508,"Hey, um, Casey."],[5276,5559,"You promised me."],[5726,5834,"That you'd tell the world"],[5834,5943,"about us tonight."],[6010,6106,"But instead,"],[6126,6252,"you propose"],[6252,6356,"and put a ring"],[6356,6527,"on Scarlett Hart's finger?"],[6627,6727,"Casey, you, you, you,"],[6760,6894,"you gave me no choice."],[6952,7211,"I gave you everything."],[7332,7432,"I loved you."],[7432,7511,"Do you love her?"],[7682,7786,"I owe her."],[7849,8045,"Okay, I, I, I, I owe her, alright?"],[8045,8091,"I don't-"],[8174,8254,"You owe her?"],[8337,8558,"Scarlett Hart is just some talentless"],[8612,8717,"industry plant."],[8717,8837,"What has she ever done for you?"],[8913,9084,"Scarlett produced my career."],[9113,9346,"She made me who I am today."],[9371,9542,"Okay, so, so, so that's why."],[9609,9722,"What are you talking about?"],[9897,10097,"Scarlett is Echo."]],"7":[[16,425,"You think Scarlett Hart is Echo?"],[458,563,"Well, I know she is."],[600,658,"You know what?"],[658,900,"I'll never be able to thank her enough"],[900,1046,"for everything she's done for me."],[1096,1263,"And I feel like this is a good start."],[1547,1693,"How could you believe her lies?"],[1751,1906,"Come on, all you do is lie."],[2177,2335,"You know, I don't even know"],[2335,2473,"who you are anymore."],[2510,2681,"Is this what you wanted all along?"],[2706,2777,"To be"],[2790,3078,"a music industry power couple?"],[3115,3299,"To please your adoring fans"],[3299,3415,"to boost your sales?"],[3482,3691,"He could have had that with me."],[3757,3970,"This is all you ever really cared about,"],[4079,4133,"isn't it?"],[4387,4504,"Not loyalty,"],[4542,4792,"just your music."],[4917,4996,"What do you know about"],[4996,5096,"Dexter's music?"],[5363,5601,"This is my notebook,"],[5676,5830,"full of songs that I wrote"],[5872,5955,"for Dexter's first"],[5955,6097,"triple platinum album."],[6135,6252,"That's my notebook."],[6252,6460,"How did Scarlett get her hands on it?"],[6519,6685,"I'm a musical genius."],[6756,7069,"You're just Dexter's little errand girl."],[7102,7194,"Give it back! - Ow!"],[7194,7340,"Dexter, she cut me!"],[7461,7615,"Casey, what has gotten into you?"],[7653,7686,"I don't,"],[7782,7912,"I don't know who you are anymore."],[7945,8053,"Dexxie, baby."],[8133,8395,"I know all about girls like her."],[8395,8533,"They want fame and money,"],[8533,8704,"without really ever have to work for it."],[8729,8913,"She's taking advantage of you."],[9013,9154,"She has been for years."],[9196,9384,"Dexter, you can't seriously"],[9384,9517,"be believing this!"],[9517,9684,"Scarlett is not Echo!"],[9697,9838,"Then tell me why I shouldn't,"],[9884,9914,"okay?"],[9914,10039,"Why, why shouldn't I believe her?"],[10389,10472,"Go wait in the car."],[10489,10535,"Please."],[10689,10735,"No."],[10752,10798,"No."],[11027,11098,"Casey,"],[11586,11636,"look, I know"],[11636,11757,"that you've been hiding things."],[11845,12112,"So please just, just tell me the truth,"],[12124,12216,"okay, right now,"],[12283,12404,"or we'll lose us forever."],[12721,12758,"Please."]],"8":[[304,367,"Please."],[1226,1380,"The truth doesn't matter anymore."],[1451,1584,"You don't trust me anyway."],[2131,2223,"We're over,"],[2373,2448,"Dex."],[2686,2852,"Goodbye forever."],[4808,5030,"The hottest rock star on the planet"],[5030,5196,"is officially off the market."],[5234,5392,"Dexter Hayes popped the question"],[5392,5534,"to up-and-coming singer"],[5534,5643,"Scarlett Hart tonight"],[5643,5768,"and she said yes."],[6348,6389,"Dad,"],[6564,6719,"I gave Dex everything."],[6744,6923,"I made his career, but"],[7019,7140,"he doesn't want me."],[7152,7265,"He never did."],[7307,7428,"What happened, Princess?"],[7482,7599,"Scarlett Hart!"],[7653,7761,"She stole him,"],[7761,7849,"and now she's trying to"],[7849,8008,"steal my identity!"],[8062,8153,"I'll come get you."],[8266,8308,"I-"],[8550,8867,"Casey, Casey, where are you?"]],"9":[[850,1059,"Looks like Dexter's whore is awake."],[1080,1238,"Let's see how his future wife"],[1238,1438,"feels about you seducing her man?"],[1593,1685,"Who are you?"],[1760,1835,"Let me go!"],[1864,2102,"Don't worry, Scarlett, we won't hurt you."],[2147,2293,"We're your fans, too."],[2348,2435,"We've always shipped"],[2435,2660,"Dexter Hayes and Scarlett Hart."],[2698,2819,"We're just trying to teach"],[2819,3053,"this filthy skank a lesson."],[3078,3453,"We saw you kissing Dexter backstage!"],[3490,3653,"You're trying to steal him"],[3661,3812,"from his soulmate!"],[3862,4029,"I wasn't stealing him."],[4054,4154,"We were in love!"],[4166,4441,"Or I thought we were."],[4512,4662,"We'll see about that, won't we?"],[4721,4934,"The only way you'll live tonight"],[5088,5313,"is if Dexter chooses to save you."],[5776,5885,"Where the hell is everybody?"],[6210,6443,"Dressing room, come alone."],[6443,6690,"Choose to save Scarlett Hart,"],[6690,6798,"and we'll spare them."],[6798,6981,"Choose your little assistant"],[6981,7203,"and they both die."],[7269,7394,"You've reached Casey."],[7403,7570,"I can't come to the phone right now."],[7674,7836,"Where the hell is my daughter?"],[8070,8124,"Casey?"],[8158,8316,"Sir, she never left the concert."],[8337,8487,"Get back to the concert hall, now!"]],"10":[[29,183,"Dexter is coming."],[233,483,"We'll see who his true love is."],[513,684,"You psychos!"],[688,917,"Oh, are you hoping that"],[917,1222,"he chooses you over his fiancée?"],[1238,1388,"Obviously not."],[1405,1551,"She's just some nobody"],[1551,1634,"who slept with him"],[1634,1776,"to break into the industry."],[1785,1960,"You fucked him, too?"],[2014,2097,"God."],[2102,2306,"Our precious Dexter,"],[2331,2581,"soiled by a dirty star-fucker."],[2648,2827,"Girls like you don't deserve him."],[2882,3019,"You don't deserve to live."],[3094,3161,"No one knows"],[3161,3328,"what the real Echo looks like."],[3361,3586,"So if Casey dies,"],[3607,3778,"then the truth dies with her."],[3832,3978,"That's not true!"],[4041,4187,"First, you steal my identity,"],[4187,4341,"now you're trying to get me murdered?"],[4371,4483,"You're psychotic!"],[4491,4637,"No, don't worry Casey."],[4696,4792,"If you die today,"],[4792,4959,"Dex and I will make a song about you."],[4984,5100,"And maybe it'll even be"],[5100,5292,"the lead single on our new album."],[5384,5543,"You're crazier than they are."],[5543,5705,"Who are you calling crazy?"],[6189,6239,"Casey!"],[6239,6310,"Dex!"]],"11":[[412,492,"Dex!"],[563,617,"Casey!"],[675,717,"Dex!"],[829,905,"Dexter!"],[913,1017,"Dexter help me!"],[1026,1109,"They hit me,"],[1126,1230,"and then they tied me up,"],[1272,1430,"and now they're trying to kill me!"],[1539,1639,"Okay guys, let's, let's,"],[1739,1960,"let's just put the guns down, okay?"],[1976,2210,"We, we can't do that Dexter."],[2248,2406,"We're your biggest fans."],[2464,2640,"We're doing this for you."],[2673,2806,"Okay, well if you love me,"],[2898,3069,"alright, you'll put the gun down"],[3082,3215,"and let these two go, please."],[3228,3269,"No!"],[3269,3399,"That's not how this works."],[3449,3553,"Dexxie,"],[3607,3841,"you would be nothing without Echo."],[3887,4120,"We're engaged now, you can't let me die."],[4149,4396,"Dex, all the love we ever had,"],[4412,4508,"all the memories,"],[4508,4688,"all the 'I love yous' you told me,"],[4779,4900,"did they mean anything?"],[4971,5159,"You must choose one to live."],[5230,5409,"Will it be your future wife?"],[5551,5701,"Or your mistress?"],[5734,5851,"Who really holds the key"],[5851,6068,"to your heart, Dexter Hayes?"],[6106,6272,"They said if I don't choose Scarlett"],[6272,6435,"then they both die."],[6435,6544,"I can save Casey,"],[6544,6652,"but I,"],[6652,6802,"but I have to break her heart."]],"12":[[0,145,"Which one really holds the key"],[145,379,"to your heart, Dexter Hayes?"],[880,1071,"You never really loved me, did you?"],[1192,1343,"And you loved him?"],[1401,1689,"You leeched off him for half a decade!"],[1747,1897,"If that's what you really think, Dex,"],[1956,2127,"go ahead and make your choice."],[2127,2193,"Choose now!"],[2193,2298,"Or they both die!"],[2306,2364,"Dexter."],[2435,2535,"Dexter, please!"],[2598,2748,"Think of everything I've done for you!"],[2798,2877,"You dumped her,"],[2890,2994,"you chose me!"],[3007,3148,"Don't let them murder me."],[3211,3274,"That's enough!"],[3299,3449,"We're pulling the trigger in three,"],[3591,3678,"two,"],[3732,3791,"one."],[3791,3887,"Okay, okay, okay."],[3924,4149,"I can't risk them killing Casey."],[4195,4308,"Scarlett, alright?"],[4358,4479,"I choose Scarlett."],[4875,5050,"Dexter, I'm gonna faint."],[5163,5284,"I was so scared."],[5326,5476,"He chose Scarlett?"],[5492,5588,"Good choice."],[5609,5814,"Cheating whores deserve to die."],[5814,5914,"What? Now wait a minute."],[5914,6014,"You told me that-"],[6014,6151,"You made your choice,"],[6151,6231,"Dexter Hayes."],[6272,6393,"Now you get to be the one"],[6393,6631,"who saved your soulmate"],[6631,6702,"and we'll take care of"],[6702,6906,"your scandalous side piece."],[6906,6998,"No, no, no, no."],[7607,7912,"I guess this is the end."],[8237,8433,"Goodbye, Dexter."],[8550,8658,"Put the gun down!"]],"13":[[0,91,"Put the gun down!"],[104,283,"Goodbye, Dexter."],[283,392,"Hey! Drop the gun!"],[1413,1472,"Let's go!"],[1472,1522,"Let's go."],[1543,1593,"Go, go."],[1626,1726,"Oh, come on."],[2027,2243,"Hey, hey, hey, come here."],[2406,2485,"Casey, you okay?"],[2485,2544,"Okay?"],[2619,2773,"You left me to die."],[2811,2911,"And for the record,"],[2927,3086,"I never needed your money."],[3157,3315,"I was right to walk away,"],[3315,3415,"staying with you"],[3415,3520,"was the biggest mistake"],[3520,3624,"I've ever made."],[3762,3812,"Look, Casey,"],[3812,3891,"you don't understand, alright?"],[3891,4016,"They were gonna make me-"],[4024,4496,"I'm done living in your shadow, Dex."],[4525,4596,"Goodbye."],[5105,5205,"Casey, Casey!"],[5242,5296,"Hey."]],"14":[[579,633,"Casey!"],[713,775,"Casey, stop!"],[792,855,"Please, stop!"],[855,942,"Please, please."],[971,1067,"Where are you gonna go?"],[1067,1167,"Okay, what are we gonna do"],[1167,1238,"without all this?"],[1288,1443,"You should be asking yourself"],[1443,1559,"that same question."],[1630,1755,"Good luck staying at the top"],[1755,1876,"of the charts once I'm gone."],[1897,2002,"You're delusional."],[2031,2147,"He doesn't need you."],[2147,2293,"He has Echo."],[2314,2531,"Yeah, sure he does."],[2573,2857,"Fame really has changed you,"],[2857,2982,"Dexter Hayes."],[3224,3353,"Fame changed me?"],[3478,3528,"Okay."],[3632,3720,"What about you?"],[3766,3845,"You're the one that's been"],[3845,3978,"sneaking around behind my back"],[3978,4091,"this whole time."],[4166,4433,"I never betrayed you"],[4433,4546,"how you betrayed me"],[4546,4671,"by putting that ring on"],[4671,4779,"Scarlett's finger!"],[4846,4954,"You chose her"],[4954,5125,"and you left me for dead."],[5159,5309,"No, Casey, you don't understand."],[5309,5384,"I was trying to-"],[7878,7995,"Oh my God, that's, that's,"],[7995,8070,"that's Ed Reed!"],[8070,8262,"The CEO of Reed Records!"],[8483,8612,"So sorry I didn't come sooner,"],[8612,8679,"baby girl."],[8875,8929,"What?"],[8950,9059,"You're here now."],[9113,9205,"Take me home."],[10489,10581,"I was trying to-"],[10848,10940,"I was trying-"],[10985,11077,"Casey!"],[11261,11348,"I was trying to say-"],[11411,11486,"Casey!"],[12178,12241,"Casey!"],[12537,12608,"Casey!"],[12679,12750,"Casey!"],[12858,12967,"Let me explain!"]],"15":[[283,375,"Scarlett."],[379,487,"Mrs. Hayes."],[508,617,"You should've seen it."],[629,750,"I almost died."],[779,921,"And that desperate skank"],[921,1026,"cheated on Dexter"],[1026,1151,"with some sugar daddy!"],[1167,1468,"I always knew she was a gold-digger."],[1468,1718,"She tried to trap Dexter first"],[1764,1893,"and when that failed,"],[1893,1989,"she went after the CEO"],[1989,2156,"of the biggest music label"],[2156,2264,"in the world."],[2302,2519,"Dexter, she never cared about you."],[2565,2656,"She's been lying to you"],[2656,2748,"this entire time."],[2748,2857,"All she ever cared about"],[2857,3015,"was money and power."],[3044,3224,"I thought Casey loved me."],[3290,3478,"But the whole time, she was in bed"],[3478,3666,"with the CEO of Reed Records."],[4220,4404,"Forget him, Princess."],[4487,4621,"You are much too talented"],[4621,4850,"to be running some rockstar's errands."],[4896,5059,"How could I be so blind?"],[5347,5451,"Three days from now,"],[5484,5663,"the annual Music Hall of Fame gala"],[5709,5801,"announcing you"],[5864,6064,"as the new CEO of Reed Records."],[6093,6189,"And my daughter,"],[6243,6423,"the heiress to my empire."],[6485,6589,"It's time to show the world"],[6589,6698,"who you really are."],[7578,7853,"My back is pressed."],[8350,8742,"My back is pressed."],[9129,9330,"Not that."],[9330,9609,"Okay, guys, cut the track!"],[9901,10064,"The damn thing is in the wrong key."],[10197,10264,"Look, guys,"],[10264,10506,"we have one week, alright,"],[10531,10710,"to finish this song before the release."],[10723,10923,"The Echo that I know can put together"],[10923,11152,"a perfect studio mix in hours."],[11232,11532,"You can't even fix a simple beat or a key?"],[11561,11657,"What's going on?"],[11774,11966,"Look, Scarlett, I just gotta ask."],[12016,12308,"Are you really Echo?"]],"16":[[12,325,"Are you really Echo?"],[371,450,"Dexxie."],[629,763,"Of course I am."],[880,1117,"It's just your new assistant."],[1151,1230,"He's been messing. - No..."],[1247,1397,"He's messing with my tracks."],[1397,1488,"He's obviously trying to"],[1488,1689,"sabotage our new album."],[1718,1801,"I mean, look, - I'm not."],[1968,2160,"Last saved, by Max."],[2173,2277,"Yeah, that's because"],[2277,2360,"you don't know how to-"],[2360,2473,"Okay, you know what?"],[2473,2631,"Echo would never put her name"],[2631,2773,"on garbage like this."],[2944,3078,"Mr. Hayes, please."],[3078,3144,"Listen-"],[3190,3261,"It's Dexter."],[3278,3415,"And, I'm sorry,"],[3415,3574,"but uh, my last assistant"],[3574,3661,"would've never"],[3661,3791,"screwed me over like that."],[3837,3878,"You're fired."],[4008,4058,"Ugh."],[4583,4683,"Let's do it again."],[6227,6331,"Good luck staying at the top"],[6331,6448,"of the charts when once I'm gone."],[6548,6677,"Writing love songs used to be"],[6677,6852,"so easy with Casey here."]],"17":[[312,379,"We're sorry."],[404,504,"You have reached a number"],[504,633,"that has been disconnected"],[642,800,"or is no longer in service."],[925,1084,"Alright, she broke my heart."],[1109,1213,"And she moved on."],[1267,1505,"So why can't I do the same?"],[2882,2982,"Ee!"],[3265,3357,"Look what we just got."],[3415,3582,"An invitation to the biggest"],[3582,3732,"industry event of the year,"],[3749,3874,"the Reed Records"],[3874,4029,"Music Hall of Fame Gala!"],[4692,4867,"Look, I'm not interested, okay?"],[4867,5030,"We have a song to finish."],[5030,5138,"Dexter,"],[5230,5301,"you said it yourself."],[5301,5476,"They can lay down a track in hours."],[5488,5601,"We have to go."],[5601,5789,"This is a personal invitation"],[5789,5976,"from Mr. Ed Reed himself."],[6131,6197,"Okay."],[6214,6281,"Look,"],[6393,6560,"I know what you're thinking,"],[6573,6652,"but Casey probably"],[6652,6781,"meant nothing to him."],[6794,6969,"He's a billionaire record executive."],[6969,7123,"I'm sure he has a whole roster"],[7123,7273,"of scorned assistants lining up"],[7273,7357,"to get on their knees"],[7357,7515,"and work for a few extra bucks."],[7549,7653,"You have to go."],[7665,7824,"You have to impress him, okay?"],[7824,8041,"He could make or break our careers!"],[8216,8333,"Okay, I guess you're right."],[8404,8508,"Of course I am."],[8629,8900,"We are the industry's it couple."],[8921,9142,"So now forget about that stupid"],[9142,9317,"little assistant of yours."],[9355,9480,"Start getting ready."],[9530,9630,"I mean, what was so special"],[9630,9705,"about her anyway?"],[9755,10135,"Her coarse, tangled hair, or,"],[10239,10510,"her dull, crusty skin?"],[10510,10723,"Or maybe those"],[10764,11011,"hideous, God-awful clothes?"],[11202,11273,"I'm Echo."],[11344,11511,"I'm the Reed Heiress."],[11561,11669,"And I'm taking back"],[11669,11803,"everything that's mine."]],"18":[[4,54,"Dexter!"],[54,133,"Scarlett, over here."],[133,233,"Show me smiling."],[233,337,"Looking good. - Fantastic."],[342,467,"Scarlett! - Dexter."],[471,554,"Over here. - Look here."],[554,596,"Yeah."],[596,679,"Yeah, that's good. - Great."],[679,804,"How does it feel to be at"],[804,917,"the event of the year"],[917,1109,"as the industry's new it couple?"],[1121,1188,"We're honored."],[1188,1347,"And with Reed Records on our side,"],[1355,1459,"our album is sure to be"],[1459,1655,"the number one hit of the decade."],[1655,1839,"Are you excited to meet this"],[1839,2131,"mysterious new CEO of Reed Records?"],[2156,2289,"I hear Ed Reed"],[2289,2444,"is introducing the whole world"],[2444,2531,"to his daughter,"],[2548,2727,"that heirs to the Reed fortune."],[2727,2823,"Do you think she's gonna be"],[2823,2911,"the new CEO?"],[2911,2982,"I don't know, alright,"],[2982,3178,"who, who is this mysterious heiress?"],[3211,3386,"She is Ed Reed's daughter."],[3407,3520,"I bet she'll be making"],[3520,3745,"a very splashy entrance."],[3749,3799,"Whoever she is,"],[3799,3937,"we need to impress her, okay?"],[3937,4016,"She could be our ticket"],[4016,4133,"to a number one album."],[4141,4191,"Look!"],[4191,4308,"Here she is now!"],[5380,5530,"No fucking way!"],[7957,8012,"Casey?"]],"19":[[137,187,"Casey?"],[296,379,"Hey Dex."],[433,542,"Long time no see."],[838,984,"Dex has already moved on"],[984,1067,"with Scarlett."],[1121,1217,"I should be happy"],[1217,1363,"walking away from him."],[1393,1438,"So,"],[1522,1689,"why does my heart still ache?"],[3219,3290,"Ignore her."],[3332,3415,"Instead,"],[3415,3570,"focus on kissing up to Ed Reed"],[3570,3753,"so he introduces us to the new CEO."],[3837,4008,"You should listen to her, Dexter."],[4108,4183,"All we need to do"],[4183,4291,"is get on their good side,"],[4291,4383,"and our album will go"],[4383,4491,"straight to number one."],[4575,4650,"She's right."],[4704,4871,"I have to impress Ed Reed"],[4871,5025,"and this new CEO"],[5025,5213,"if I want our album to be a hit."],[6815,6894,"Scarlett."],[6927,7090,"What a terrible surprise."],[7102,7257,"I should've known you'd sneak in here,"],[7257,7403,"hunting for your next sugar daddy."],[7415,7599,"But this party is for the elite"],[7599,7753,"of the music industry only."],[7753,7903,"I suggest you wait on the street corner"],[7903,8008,"with the other hookers."],[8008,8062,"Hmm."],[8074,8245,"But the party's just getting started"],[8245,8295,"and"],[8316,8458,"I can't miss the big announcement."]],"20":[[141,200,"Why?"],[275,396,"So you can seduce the new"],[396,571,"CEO of Reed Records too?"],[629,759,"I hear he's much"],[759,905,"more selective than Ed Reed,"],[905,996,"so don't expect him"],[996,1138,"to look at you twice."],[1138,1330,"And don't distract Dexter tonight."],[1359,1526,"Leave, or I will have security"],[1526,1639,"escort you out."],[1639,1939,"I'd love to see you try."],[2185,2260,"Jealous?"],[2352,2431,"I loved him,"],[2439,2648,"and those feelings don't just go away."],[2690,2836,"How could she change his mind"],[2836,2948,"so easily?"],[3119,3415,"You can dress up all you want,"],[3486,3699,"but you will always just be"],[3699,3962,"Dexter's lowly little errant girl."],[3987,4195,"I thought she was someone important."],[4195,4412,"She's just a desperate assistant"],[4412,4546,"playing dress up."],[4546,4671,"Imagine getting dragged"],[4671,4838,"by the Scarlett Hart."],[4846,4988,"I would never emotionally recover."],[4988,5096,"Where do you think she got the"],[5096,5176,"jewels, though?"],[5176,5326,"Probably out whoring herself"],[5326,5426,"to old men."],[5438,5593,"Just like all those"],[5593,5739,"desperate social climbers"],[5739,5843,"in our industry."],[5930,6039,"They got that right."],[6231,6318,"Is that so?"],[6377,6635,"Tell me something, Scarlett."],[6656,6756,"Is it really me"],[6794,6952,"who's putting on an act? Or..."],[7207,7332,"is it you?"]],"21":[[20,133,"How dare you!"],[329,417,"Careful."],[458,650,"The new CEO might be watching."],[800,921,"You think you're hot shit"],[921,1076,"just because you're the real Echo."],[1109,1230,"You may have the talent,"],[1230,1372,"but you have no money"],[1372,1463,"and no connections"],[1463,1572,"besides the ones you make"],[1572,1739,"in pay-by-the-hour hotel rooms."],[1747,1818,"But me,"],[1835,1939,"I'm a beloved"],[1939,2114,"up-and-coming pop star."],[2114,2348,"And if you so much as threaten me"],[2369,2519,"or my career ever again,"],[2519,2627,"I will get you canceled"],[2627,2744,"so fucking hard"],[2744,2869,"your grandchildren won't be able to"],[2869,3003,"show their faces in public."],[3240,3315,"Mr. Reed."],[3315,3470,"Uh, hi, uh, Dexter Hayes."],[3490,3678,"Thank you so much for the invite."],[3707,3832,"Uh, you've always"],[3858,4016,"been a true hero of mine."],[4058,4233,"Well, I'd really love to put that, um,"],[4308,4458,"put that incident with my"],[4496,4671,"assistant behind us."],[4700,4821,"Oh, Dexter Hayes."],[4821,4904,"Of course I can."],[4946,5005,"Good."],[5100,5347,"Oh, I can't wait to see the look on his face"],[5347,5534,"when he realizes the assistant"],[5534,5764,"he rejected is my daughter,"],[5764,5893,"and the heiress to the"],[5893,6051,"Reed Records fortune."],[6060,6197,"Well, you know, sir, um,"],[6197,6277,"well, you may"],[6277,6393,"or may not have heard about uh,"],[6393,6548,"the record that Scarlett Hart"],[6548,6723,"and I are working on."],[6723,6936,"I really think that between my lyrics"],[6936,7086,"and, well, her producing, and,"],[7136,7286,"and your musical genius"],[7286,7419,"over the last many decades,"],[7419,7524,"I think we could really make"],[7524,7632,"something special."],[7686,7853,"Well, you make a compelling point."],[7987,8158,"And you know, if it's not too much,"],[8158,8266,"it actually might be helpful"],[8266,8345,"for the record."],[8345,8425,"Well, maybe if you could"],[8425,8700,"put in a good word with the new CEO."],[8712,8775,"I, I,"],[8775,8938,"well, that would make me forever,"],[8938,9034,"forever grateful."],[9121,9180,"Why don't you"],[9180,9338,"put in a good word yourself?"],[9359,9513,"The new CEO is already here."]],"22":[[212,266,"Casey."],[354,400,"Casey."],[425,471,"Casey."],[583,650,"Casey."],[892,959,"I've,"],[1017,1142,"I've been trying to call you"],[1142,1251,"the last few days,"],[1251,1451,"and, well, I guess I'm just surprised"],[1451,1622,"that instead you've just showed up here."],[1655,1818,"I hated myself"],[1864,2010,"for wanting to pick up the phone,"],[2064,2231,"for wanting to hear his voice again."],[2285,2410,"But after what he did to me,"],[2469,2690,"I couldn't give him the satisfaction."],[2711,2877,"Oh, you've been calling me"],[2877,2990,"for the last few days."],[3036,3069,"What?"],[3069,3169,"You missed me already?"],[3194,3445,"Did Ed Reed bring Casey as his date?"],[3524,3728,"This event is invite only."],[4020,4070,"Yeah."],[4145,4262,"Dang, I guess I left my"],[4262,4383,"invite at home, but"],[4471,4567,"I think I'm gonna stay."],[4579,4771,"You know, Scarlett on the other hand,"],[4771,4892,"though, has been throwing around"],[4892,5171,"nothing but vile slander and"],[5171,5355,"empty accusations all night."],[5376,5480,"If anyone needs to go,"],[5480,5576,"it should be her."],[5593,5826,"Unless you want me to expose"],[5826,6026,"your lies to Dexter right here, right now?"],[6106,6193,"Yeah right."],[6193,6356,"The only ones who can remove me"],[6356,6619,"are Mr. Reed himself or the new CEO."],[6652,6760,"You have no power here."],[6873,7073,"Okay, guys, Ed Reed and"],[7073,7282,"this new CEO are about to"],[7282,7411,"announce our new album."],[7411,7661,"Can we have this conversation later?"],[7716,7795,"Dex,"],[7895,8062,"you forgot to say please."],[8366,8500,"Wait, Casey, what are you-"],[9013,9109,"Ladies and gentlemen,"],[9221,9309,"it's time to announce"],[9309,9496,"tonight's special guest."]],"23":[[33,316,"Reed Records is the number one largest"],[316,496,"music label in the world."],[592,679,"But tonight,"],[709,917,"I want to introduce you to someone"],[917,1021,"who's more precious to me"],[1021,1121,"than any company."],[1151,1230,"Someone who grew up"],[1230,1380,"listening to me play piano,"],[1413,1576,"who has written hundreds of songs"],[1614,1743,"and never put her name"],[1743,1839,"on one of them,"],[1901,2077,"because she never wanted to gain fame"],[2214,2306,"through mine."],[2356,2556,"No more secrets, Dexter Hayes."],[2577,2711,"It's time you finally"],[2711,2919,"learned who you really rejected."],[3007,3203,"Mr. Reed is looking right at us!"],[3265,3403,"He's gonna call us on stage."],[3445,3536,"Alright, this is it."],[3578,3666,"He's gonna announce that"],[3666,3799,"he signed us to Reed Records."],[3837,3974,"I want to introduce"],[4074,4158,"the heir to my"],[4158,4320,"billion dollar music empire."],[4396,4567,"The new CEO of Reed Records."],[4692,4800,"My princess"],[4950,5096,"and the light of my life,"],[5142,5213,"my daughter,"],[5296,5380,"Casey Reed!"],[5801,5893,"What?"],[6373,6427,"No."],[7157,7240,"Casey?"]],"24":[[884,1071,"That's the Reed heiress?"],[1096,1184,"Holy shit."],[1197,1309,"She's not a sugar baby."],[1351,1409,"She's the daughter of"],[1409,1580,"billionaire music royalty."],[1626,1822,"Scarlett Hart is delusional."],[1822,1997,"Insulting the new CEO"],[1997,2214,"of Reed Records to her face?"],[2223,2427,"She just committed career suicide."],[2435,2510,"Mr. Reed,"],[2510,2723,"your gift for the lady of the hour."],[2902,3015,"That's millions of"],[3015,3148,"dollars of gold."],[3194,3407,"Dad, this is too much."],[3407,3545,"A little something from your old man."],[3549,3699,"Now Dexter will see that you're worth"],[3699,3849,"more than your weight in gold."],[3908,4029,"This cannot be happening."],[4079,4212,"She's a nobody!"],[4483,4554,"I knew Casey"],[4554,4671,"was keeping secrets from me,"],[4671,4804,"but I, I didn't know"],[4804,4971,"she was hiding who she was."],[4971,5205,"Ed Reed was never her sugar daddy."],[5205,5342,"He was her father."],[5342,5422,"This whole time"],[5422,5663,"she was with me for love, not fame."],[5693,5843,"Oh, she tried to tell me the truth"],[5843,6006,"and instead of trusting her,"],[6006,6172,"I left her for another woman."],[6231,6364,"How could I be so blind?"]],"25":[[567,650,"It suits you."],[775,867,"Uh, the, um,"],[909,1176,"the guitar and CEO title."],[1197,1463,"Why can't you just say you miss me?"],[1463,1622,"Casey, I, I, look, I just-"],[2831,2898,"I just,"],[2969,3057,"I still miss you."],[3995,4124,"Shouldn't you be licking"],[4124,4300,"your fiancée's wounds?"],[4300,4542,"Knowing she just insulted the CEO"],[4542,4750,"of the most powerful music company"],[4771,4942,"has got to hurt, but I mean,"],[4984,5113,"you of all people should know."],[5113,5246,"Please you have to believe me, okay?"],[5246,5401,"If you just let me explain-"],[5401,5526,"Explain what, Dexter? - I promise-"],[5551,5693,"What, you want me back,"],[5693,5905,"after finding out I'm your boss?"],[6097,6252,"Or leaving me for Echo?"]],"26":[[0,154,"No, no, look, that, that's,"],[154,262,"that's not why I'm here."],[262,392,"If you just let me tell you, I, I..."],[538,650,"I mean, come on, Casey."],[650,792,"I mean, you gotta understand, I..."],[846,980,"you're the one who lied to me."],[1001,1046,"I lied?"],[1059,1105,"Yeah."],[1105,1192,"And what would you call"],[1192,1305,"getting engaged to Scarlett"],[1305,1434,"after promising to put a ring"],[1434,1534,"on my finger?"],[1534,1755,"I didn't want any of that to happen!"],[1755,1931,"You have to believe me, please."],[1931,2043,"I was just trying to,"],[2143,2252,"look, I..."],[2344,2456,"just tell me one thing."],[2456,2606,"I guess why, why are you here?"],[2606,2673,"Are you here just..."],[2673,2815,"is this just some royal way"],[2815,2923,"to get revenge?"],[2965,3053,"Tank my career?"]],"27":[[8,166,"Oh, tank your career."],[196,346,"I made his career."],[442,729,"I loved you, Dexter."],[746,838,"You might have found out"],[838,946,"who my father is today,"],[946,1146,"but you still have no idea who I am."],[1242,1301,"Wait."],[1639,1689,"This."],[1735,1918,"This is why you proposed to Scarlett,"],[1918,1985,"isn't it?"],[2043,2381,"Why you left me for dead."],[2473,2640,"Sucked up to my dad."],[2719,2898,"Threw me to the curb."],[2940,3048,"For the fame,"],[3073,3157,"the fortune,"],[3169,3307,"the fans. - No, no,"],[3311,3382,"No, no, no. - Casey."],[3399,3536,"Actually, I think"],[3570,3724,"it's time to make my first decision"],[3724,3878,"as the new CEO."],[4037,4275,"Can I get everyone's attention, please?"],[4508,4679,"I hope everyone is having fun."],[4704,4938,"Reed Records will be ending"],[4938,5176,"its contract with Dexter Hayes"],[5196,5438,"and dropping him as an artist."],[5826,6001,"Effective immediately."],[6018,6227,"Oh my God, oh my God, oh my God."]],"28":[[0,308,"You know, I am so glad"],[342,529,"I never told you who I really was."],[550,621,"Because if I didn't,"],[621,750,"I might not have ever found out"],[750,905,"that you don't really love me for me."],[905,975,"Casey."],[1005,1092,"None of that is true."],[1092,1180,"Okay, none of this."],[1180,1251,"I don't care about that."],[1251,1372,"I, I've always loved you."],[1372,1555,"Don't bother arguing with her"],[1555,1680,"anymore, Dexter."],[1680,1801,"She may be rich,"],[1801,2018,"but she's just an arrogant nepo baby"],[2018,2189,"with no real talent."],[2189,2327,"Scarlett is Echo."],[2339,2452,"She can produce - Wait, wait,"],[2452,2535,"hit songs. - Casey!"],[2544,2602,"Casey! - She can"],[2602,2761,"get you to the top of the charts"],[2761,2952,"with or without Reed Records."],[2952,3123,"Dexter, you don't need her."],[3123,3282,"She doesn't understand you."],[3282,3407,"like Scarlett does."],[3407,3532,"Okay, Mom, Mom. - Listen-"],[3570,3620,"Stop."],[3657,3737,"You're my mom."],[3795,3870,"Not my manager."],[3887,3945,"Alright?"],[4037,4145,"I'm done talking about this."]],"29":[[1668,2114,"I've known you for years."],[2214,2565,"I thought you'd stay the same."],[2565,3061,"All of those years."],[3132,3624,"I broke and then I blamed."],[3912,4358,"Intertwined, lost in time,"],[4404,4800,"I'm still missing you."],[4884,5263,"I'm still, and I'm still,"],[5301,5634,"missing you."],[6214,6477,"I'm still missing you."],[6614,6840,"Intertwined,"],[6861,7098,"heart and mind."],[7111,7378,"I'm still missing you."],[8049,8145,"I thought I was clear"],[8145,8333,"our relationship is over, Mr.Hayes."],[8333,8458,"You're no longer welcome"],[8458,8558,"at Reed Records."],[8558,8796,"I just came to pick up my equipment."],[8921,9038,"Casey's wrong about me."],[9038,9225,"I never gave up on us."],[9225,9351,"She's gotta know the truth."],[9446,9605,"I don't think there's anything"],[9605,9768,"left to talk about, Dex."],[10468,10543,"Fine."],[10656,10785,"Let's not talk."]],"30":[[571,684,"What's wrong?"],[742,850,"Your fiancée not"],[850,959,"keeping you satisfied?"],[1113,1230,"I've been doing too much"],[1230,1422,"thinking about my former assistant."],[2014,2089,"Not anymore."],[2177,2310,"I'm your former boss now."],[2352,2423,"In fact,"],[2464,2736,"here are your termination letters."],[3053,3303,"I don't give a fuck about the contract."],[3319,3474,"I don't give a shit about my career."],[3474,3582,"I just want you."],[3582,3757,"And I know that you want me too."],[3853,3987,"Don't act like you've forgotten,"],[4195,4308,"what we had."],[4408,4533,"I've been trying to."],[4554,4733,"But being this close again,"],[4733,5034,"it feels impossible."],[5063,5217,"You're a lot like an instrument."],[5338,5534,"The way you tremble every time we touch."],[6114,6302,"I don't care about the fans."],[6302,6427,"I don't give a shit about the tabloids."],[6427,6531,"I don't care what the rec labels"],[6531,6602,"have to say."],[6656,6760,"If you tell me"],[6794,6927,"that you want to be with me,"],[7094,7186,"we'll be together."]],"31":[[0,158,"We can tease each other all day."],[354,496,"Until you finally admit,"],[567,633,"you"],[692,