,"Dexter Hayes, huh?"],[196,279,"Are you okay?"],[337,421,"I'm fine."],[829,955,"What the fuck, Hayes?"],[1026,1176,"I could sue you for that."],[1213,1397,"I'd love to see you try, sweetheart."],[1413,1551,"You're just some washed up addict."],[1576,1710,"You do not have a leg"],[1710,1885,"to stand on, okay?"],[2277,2389,"Okay, I'm sorry."],[2439,2527,"Jesus."],[2569,2652,"We could have produced"],[2652,2806,"a sick-ass record together."],[2806,2894,"You hadn't wanted to"],[2894,3161,"defend this used-up slut?"],[3161,3244,"I mean what the fuck-"],[3520,3636,"Her name,"],[3661,3770,"is Casey Reed."],[3770,3995,"And she's the future of the industry"],[3995,4200,"that you want so badly fucking in!"],[4333,4546,"Your career is dead, Sasha."],[4546,4637,"I'll make sure of that."],[4821,4875,"Let's go."],[5609,5663,"Let's go."],[5985,6106,"Give me your hand."]],"35":[[371,479,"Casey, I've been telling you"],[479,554,"for months."],[554,675,"Sasha Silver is literally-"],[675,955,"My business is none of your concern."],[959,1121,"If I didn't show up tonight,"],[1138,1226,"what the hell do you think"],[1226,1292,"would've happened?"],[1292,1363,"Do you have any idea"],[1363,1463,"what he could have done to you?"],[1463,1559,"He could have raped you."],[1559,1668,"Yes, okay! - He could've"],[1693,1768,"I know!"],[1826,1922,"Newsflash,"],[1922,2198,"I'm not your assistant anymore."],[2198,2381,"So, it's not your concern"],[2398,2631,"where I am or what I'm doing, okay?"],[2656,2777,"So stop"],[2923,3053,"following me."],[3407,3561,"The car is still fucking moving."],[3707,3824,"I'll stop following you,"],[3824,4087,"the minute that you stop making stupid,"],[4108,4291,"fucking decisions."],[4366,4462,"And when I've made up for"],[4462,4612,"all the danger I've put her in."]],"36":[[0,104,"You're way"],[216,596,"too interested in my personal life, Dex."],[596,829,"Won't your fiancée be jealous?"],[1255,1493,"I've been trying to tell you for weeks."],[1493,1889,"I did not want to marry Scarlett."],[2014,2147,"But you don't fucking listen."],[2177,2289,"Now you're really starting to"],[2289,2377,"piss me off."],[2444,2606,"Isn't that the point?"],[3536,3595,"So,"],[3695,3862,"what am I supposed to do?"],[3920,4175,"Pretend she doesn't exist"],[4175,4379,"and be the popstar's"],[4416,4629,"secret sidepiece again?"],[4842,4996,"I should push him away, but"],[5017,5105,"I can't deny"],[5105,5263,"how much I miss his touch."],[5288,5442,"You were never the sidepiece."],[5622,5718,"And you know it."]],"37":[[696,838,"Boss, I have news!"],[1026,1313,"Thank you for your help today, Dexter."],[1484,1739,"Please, stop following me."],[2010,2164,"Or else it's gonna get harder"],[2164,2318,"and harder to walk away."],[3249,3315,"Great timing."],[3424,3524,"As always."],[3553,3653,"Why are you even here?"],[3666,3774,"I've done what you asked."],[3774,3899,"News of Sasha Silver's"],[3899,4029,"fraudulence and drug abuse"],[4029,4162,"have been leaked to the press."],[4162,4320,"No label, studio, brand"],[4320,4437,"will go anywhere near him."],[4437,4617,"His net worth plummeted to zero."],[4650,4700,"Good."],[4771,4904,"Buy all the rights to all his music."],[5109,5259,"Give that to Casey as a gift."],[5814,5897,"I heard what happened"],[5897,5993,"with Sasha."],[5997,6197,"And that was way too risky, Casey."],[6197,6418,"Look, I'm far from Dexter's biggest fan."],[6418,6531,"But that could've gotten"],[6531,6723,"real ugly if he hadn't shown up."],[6723,6877,"I could've handled Sasha."],[6877,6990,"There's also a huge leak"],[6990,7098,"in the press."],[7115,7344,"All of Sasha Silver's dirty laundry"],[7344,7499,"aired out for everyone to see."],[7499,7578,"He's been, um,"],[7578,7728,"what do you kids call it, canceled."],[7770,7857,"Who took him down?"],[7987,8095,"Dexter Hayes."]],"38":[[287,396,"He even bought the rights"],[396,513,"to Sasha's music."],[546,771,"He can't sing anything anywhere"],[809,942,"or get sued to hell and back."],[988,1