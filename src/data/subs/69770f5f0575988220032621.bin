one person"],[3745,3874,"who's always been there for me."],[4083,4204,"Please ring up the guitar"],[4204,4308,"for Miss Hart."],[4333,4483,"I knew you would support me."],[4487,4708,"Mr. Hayes, it's, it's not for sale."],[4771,4884,"You know, why don't you ask"],[4884,4992,"the new owner"],[5009,5167,"how much it costs and I'll pay it,"],[5167,5292,"whatever it is, right here and now."],[5459,5543,"Miss Reed,"],[5580,5734,"as the new owner of the store,"],[5734,5839,"how much would you like to"],[5839,5947,"charge the guitar for?"],[5976,6131,"Wait, what? - Excuse me?"],[6439,6635,"I'm sorry, I'm the new owner?"]],"44":[[108,287,"Consider it a late birthday gift."],[308,433,"For my former assistant."],[475,571,"You did this for me?"],[717,896,"You really think I need a music store?"],[1021,1172,"Well, as CEO of Reed Records,"],[1172,1255,"you probably don't."],[1280,1443,"But from someone who"],[1443,1539,"cares about you a lot,"],[1539,1622,"why the hell not?"],[1785,1864,"Dexter!"],[1893,2052,"Are you insane?"],[2093,2327,"She's not even a real musician"],[2344,2581,"and you gave her the entire store?"],[2615,2756,"You're gonna make us"],[2781,3011,"pay her for a guitar?"],[3023,3144,"Oh, it's, it's okay."],[3144,3290,"Scarlett could have it for free."],[3315,3432,"As long as she shows us"],[3432,3611,"the big hit that she's working on."],[3628,3699,"Ah."],[3866,3933,"Casey,"],[4012,4166,"I am not stooping to your level."],[4208,4283,"And besides,"],[4320,4466,"we're late for hair and makeup."],[4483,4704,"I will talk to you about this later."],[4871,5105,"You will regret this."],[5105,5342,"Casey has done nothing but ruin you."],[5367,5555,"She's just a pretty face"],[5555,5743,"with no talent to back it up."],[5776,5843,"Thanks, mom."],[6427,6493,"One."],[6535,6723,"I'm not your assistant anymore."],[6740,6840,"It's Miss Reed"],[6840,7069,"and I'm the CEO of Reed Records."],[7090,7161,"Two,"],[7219,7378,"my birthday was months ago."],[7394,7536,"Actually, the night that you"],[7536,7636,"proposed to Scarlett,"],[7636,7899,"so your gift means nothing."],[8108,8174,"Did you know"],[8174,8279,"I was actually gonna tell you"],[8279,8370,"my secret that night?"],[8370,8450,"What secret?"]],"45":[[0,58,"Secret?"],[58,120,"What?"],[120,200,"What are you talking about?"],[200,275,"What, what secret?"],[575,721,"Should I tell him the truth?"],[846,905,"No."],[925,1013,"That I wanted to spend"],[1013,1109,"every single day"],[1109,1230,"of the rest of my life with you."],[1609,1718,"But not anymore."],[1901,1976,"I don't need you."],[3019,3098,"Don't pay attention to anything"],[3098,3174,"she just said."],[3174,3219,"Yeah."],[3219,3345,"I want you to give the best equipment"],[3345,3457,"and the best instruments"],[3457,3557,"to her collection."],[3603,3653,"Yes, sir."],[3899,4004,"Oh, and one more thing."],[4149,4225,"She's fired."],[4412,4471,"Yes, sir."],[4567,4629,"Thank you."],[4713,4779,"What, but-"],[4813,4934,"Dexter, you can't do this!"],[4934,5034,"I love you!"]],"46":[[1017,1184,"Mr. Hayes, Ms. Hart,"],[1197,1272,"you're on in five."],[1305,1451,"The broadcast will begin live."],[1480,1534,"Thank you."],[1693,1797,"Did you hear that?"],[1797,1943,"Millions of fans"],[1943,2114,"are gonna be hearing your song."],[2114,2273,"It's exactly what you deserve."],[2318,2556,"The world needs to hear your talent."],[2631,2798,"I can't believe I'm about to perform"],[2798,3069,"on the Universal Music Awards stage!"],[3153,3290,"Alright guys, it's time let's go."],[3290,3340,"Oh."],[3370,3490,"Scarlett!"],[4875,5071,"You can't start the show without me."]],"47":[[216,279,"I knew you'd make it."],[312,404,"Of course she did."],[412,483,"Her daddy probably"],[483,638,"got her a ticket after she cried"],[638,763,"about being left out."],[788,842,"Dexter."],[842,905,"Scarlett."],[959,1096,"You know, I'm actually surprised"],[1096,1163,"you showed up."],[1213,1347,"I thought it would be too painful"],[1347,1484,"for you to witness people with"],[1505,1689,"actual talent perform when"],[1743,1881,"you yourself have none."],[1901,1964,"Hmm."],[2039,2114,"I'm getting"],[2143,2356,"a lecture about talent from you."],[2356,2515,"Oh, guess we'll see"],[2515,2694,"who's real and who's fake tonight."],[2761,2882,"Break a leg, Scarlett."],[2986,3178,"Or should I say, Echo?"],[3319,3395,"Don't choke."],[3566,3691,"Hope you don't choke."]],"48":[[1622,1718,"The playback's down."],[1772,1951,"The track's gone, completely wiped."],[2047,2135,"You have another version"],[2135,2218,"of the track, right?"],[2623,2765,"I didn't even make that version."],[2773,2936,"I had to pay Taylor Swift's producer"],[2936,3078,"to send me one of her reject tracks."],[3111,3219,"Go fix this."],[3257,3307,"Now!"],[3524,3620,"This is bad."],[3620,3753,"Alright, everyone's just out there"],[3753,3841,"staring at us."],[3866,4020,"We're gonna ruin the broadcast,"],[4020,4191,"and the label's gonna drop us."],[4208,4316,"What are we gonna do?"],[4416,4533,"I have an idea."],[4629,4921,"You're Echo, right?"]],"49":[[271,325,"Yes."],[387,500,"It's true."],[546,654,"I'm Echo."],[675,842,"The award winning producer"],[842,1001,"at Dexter Hayes' long-time"],[1001,1126,"mystery collaborator."],[1126,1217,"Then prove it."],[1343,1430,"Go ahead!"],[1455,1630,"Why don't you mix us a live track"],[1630,1751,"right here, right now?"],[1772,1822,"Come on!"],[1822,2022,"You're a genius producer, right?"],[2022,2077,"I mean,"],[2135,2264,"this is your chance to show off"],[2264,2323,"your talents."],[2323,2481,"I mean, the whole world is watching."],[2627,2723,"I don't know what any of these"],[2723,2815,"buttons even do."],[2869,3090,"This bitch is trying to sabotage me!"],[3119,3282,"I must have another file I can play."],[3307,3428,"I'll just make it look like"],[3428,3545,"I'm mixing in real time."],[3649,3741,"Of course!"],[3824,3999,"Watch me work my magic."]],"50":[[663,804,"And that's how it's done."],[867,984,"Show must go on."],[1017,1105,"Nice try."],[1155,1334,"Scarlett's proven herself enough."],[1334,1514,"You can stop with the jealous"],[1514,1618,"witch hunt now."],[1689,1847,"Okay, can you boost the treble"],[1847,1947,"on the EQ in the middle?"],[1947,2118,"And can you, uh, pan from, uh,"],[2118,2260,"stage left to stage right real quick?"],[2485,2544,"Yeah."],[3236,3370,"Damn, I guess you're gonna have to"],[3370,3503,"do with the old-fashioned way."],[3503,3566,"That means"],[3566,3728,"recording the instruments live,"],[3728,3791,"looping them-"],[3791,3899,"Don't listen to her!"],[3941,4066,"She doesn't know what it takes"],[4066,4241,"to make a track of my caliber."],[4304,4446,"And this isn't the first time one"],[4446,4542,"of Dexter's tracks"],[4542,4650,"have been corrupted."],[4696,4846,"If I didn't know any better,"],[4846,4975,"I think you were trying to"],[4975,5075,"sabotage him!"],[5075,5167,"Scarlett, Scarlett,"],[5184,5284,"why would Casey do that?"],[5305,5347,"For real."],[5347,5438,"Okay, you're,"],[5459,5618,"you're Echo, okay?"],[5626,5822,"So just fix the track."],[5939,6010,"Yeah."],[6060,6172,"Come on, Echo."],[6172,6197,"What?"],[6197,6247,"You have"],[6247,6339,"performance anxiety?"]],"51":[[296,588,"Scarlett, you are our only hope now."],[588,750,"You have to fix this!"],[750,846,"I could."],[871,1021,"If I had something other than this"],[1021,1163,"shoddy Reed Records"],[1163,1334,"music equipment to work with."],[1334,1480,"Casey, if you're such a genius,"],[1480,1559,"why don't you fix it?"],[1659,1881,"Oh, I, I actually would gladly."],[1881,2043,"But it's actually your big night,"],[2043,2214,"so why don't you show everyone"],[2214,2327,"the brilliant Echo"],[2327,2448,"and how you made Dexter Hayes"],[2448,2531,"a super star. - Echo!"],[2540,3082,"Echo! Echo!"],[3182,3324,"Just, you're Echo, okay?"],[3390,3520,"Record some midi instruments,"],[3520,3645,"lay them down, make a track."],[3645,3703,"It's that simple."],[3703,3799,"You know how to do this."],[3912,4074,"You really think your fiancée"],[4074,4237,"is going to be able to fix this show?"],[4291,4433,"I mean if she goes down,"],[4433,4525,"you go down with her."],[4729,4871,"Casey shouldn't even be here."],[4925,5042,"I can't let her expose me."],[5059,5180,"Not when I'm so close"],[5180,5276,"to marrying Dexter"],[5276,5401,"and becoming a pop legend!"]],"52":[[1005,1163,"Is this part of her process?"],[1163,1297,"It would take a true genius"],[1297,1530,"to make that racket sound like music."],[3382,3449,"Are you gonna-"],[3582,3674,"Oh my God."],[3674,3862,"Is Scarlett Hart tone-deaf?"],[3962,4049,"Come on, Echo."],[4066,4162,"Show them your talent."],[4162,4233,"Keep going."],[4279,4429,"Get off the stage!"],[4441,4654,"You're ruining the UMAs."],[4867,4929,"Alright, look."],[5171,5213,"It's done."],[5301,5367,"You're really gonna"],[5367,5497,"give up that easily, Dex?"],[5622,5730,"You're gonna throw it all away"],[5730,5822,"because of Scarlett?"],[5839,5947,"Yeah, I am."],[5997,6085,"That whole career"],[6131,6260,"that I fought for for however,"],[6260,6348,"how many years?"],[6360,6398,"Yeah."]],"53":[[54,129,"Because you know what?"],[271,417,"Someone that I was close to"],[417,508,"once told me,"],[617,725,"that there's a lot more to life"],[725,842,"than just your career."],[921,967,"And who knows?"],[967,1117,"Maybe I can get a cool new gig"],[1146,1259,"as a personal assistant"],[1259,1413,"for the new CEO of Reed Records?"],[1630,1714,"Dexter!"],[1722,1968,"Stop it with those awful jokes!"],[1968,2239,"Your entire life's work is on the line!"],[2239,2293,"Mom,"],[2410,2519,"you heard the track, okay?"],[2519,2631,"There's no saving this song."],[2731,2802,"Now it's over."],[2811,2877,"It's over."],[4187,4325,"Ugh, well,"],[4416,4487,"I guess it's time"],[4487,4646,"for the next act of this show."],[4788,4900,"No, no!"],[4900,4959,"There's no,"],[4959,5050,"there's, there's no one there."],[5050,5105,"What are you- - Move."],[5105,5155,"Hey!"],[5192,5380,"It's time to let a real musician"],[5380,5501,"take the stage."]],"54":[[29,229,"What the hell do you think you're doing?"],[229,346,"Mom, Mom, stop."],[508,592,"You heard her, Scarlett."],[767,946,"I mean, you can stay"],[946,1055,"unless you wanna go down as"],[1055,1267,"the worst performer in UMA history."],[1288,1459,"If I couldn't mix a whole live track,"],[1459,1597,"what makes you think you could?"],[1676,1830,"For one, I know what I'm doing."],[1926,1997,"And if you don't?"],[2131,2218,"Will you step down"],[2218,2435,"as Reed Records' CEO if you fail?"],[2523,2594,"Happily."],[2952,3161,"Everyone, we're about to watch"],[3161,3370,"Reed Records' CEO dig her own grave."],[3370,3549,"It seems like Echo is having"],[3549,3812,"technical difficulties with her track."],[3858,3924,"Since we're live,"],[3924,4054,"let's make something new."],[4116,4254,"Dexter, sing me the first line"],[4254,4366,"of your song, just your voice."],[4529,4604,"Right now?"],[4654,4700,"Right now."],[5359,5797,"I am not the kind for a show."],[6060,6410,"This is not a one time thing."],[6410,6806,"Lights are low, but I still glow"],[6815,7319,"This moment's got a sting."],[7349,7386,"Good."],[7695,7811,"Now let's make a hit."]],"55":[[646,788,"Let's fucking go!"],[2310,2348,"What?"],[2348,2460,"Wait, what, what is she doing?"],[2656,2827,"I mean, you produced this, right?"],[2827,2977,"So do you wanna go ahead and take over?"],[3019,3107,"I, I, I can't."],[3107,3215,"I don't have my-"],[3253,3399,"You don't need anything"],[3399,3620,"except for a band and raw talent."],[3620,3762,"I mean, you are a musician, right?"],[4208,4329,"Since when is Casey Reed"],[4329,4458,"a musical genius?"],[4487,4754,"That sound, it's familiar."],[4758,5092,"I am not the kind for a show."],[5242,5559,"This is not a one time thing"],[5568,5618,"Stop!"],[5618,5689,"Stop it!"]],"56":[[700,759,"Casey."],[980,1055,"You're Echo."],[1088,1276,"Does this mean Casey Reed"],[1359,1476,"is Echo?"],[1551,1643,"This is my song!"],[1643,1785,"She just ripped it off!"],[1785,1981,"Who's stealing now Scarlett?"],[1997,2177,"Don't listen to her!"],[2281,2389,"I'm Echo!"],[2648,2806,"I didn't even make that version."],[2806,2952,"I had to pay Taylor Swift's producer"],[2952,3090,"to send me one of her reject tracks."],[3107,3236,"Go fix this."],[3561,3732,"Now everyone knows the truth."]],"57":[[179,350,"She's the one that saved the song!"],[367,479,"No, that was me!"],[546,650,"I already did all the work!"],[650,813,"She's just taking the credit!"],[829,1130,"I had to mix the track live, Dexter,"],[1130,1238,"so that makes it my"],[1238,1359,"Intellectual Property."],[1426,1518,"You're welcome to put it on"],[1518,1614,"your next album."],[1614,1801,"But you're gonna have to pay me for it."],[1818,1906,"Where do I sign?"],[1968,2131,"I don't think you could afford my fee."],[2273,2410,"I think you might just be surprised."],[2540,2635,"200 million."],[2635,2840,"200 million?"],[2894,3007,"For one song?"],[3044,3161,"That's more than our entire"],[3161,3215,"album deal,"],[3215,3319,"are you insane?"],[3361,3586,"And I want my name to be credited."],[3787,3916,"You've got a deal, Miss Reed."],[4062,4175,"And one last thing."],[4216,4479,"I want a public apology"],[4479,4746,"from Scarlett Hart and Amelia Hayes."],[4746,4833,"That's ridiculous!"],[4850,5092,"Why should we apologize to you?"],[5100,5196,"I mean, you don't have to."],[5196,5309,"I could just go ahead and leave,"],[5309,5367,"and then"],[5367,5492,"Scarlett could finish the album"],[5492,5626,"and Dexter's career"],[5626,5722,"could crash and burn."],[5722,5943,"So, what will it be?"]],"58":[[16,137,"The clock is ticking."],[358,479,"I was wrong about you."],[521,671,"You saved Dexter's song."],[842,938,"I'm sorry."],[1242,1292,"And you?"],[1376,1434,"Do it."],[1497,1593,"Apologize to her."],[1630,1730,"That bitch!"],[1730,1906,"Why do I have to apologize to her?"],[1939,2093,"She ruined everything!"],[2106,2210,"Come on, let's hear it."],[2256,2352,"Tell the world the truth."],[2356,2427,"Scarlett?"],[2506,2573,"Fine!"],[2623,2736,"I'm not Echo!"],[2736,2886,"I pretended and I never wrote"],[2886,3073,"or produced any of Dexter's songs!"],[3073,3111,"There,"],[3111,3178,"happy?"]],"59":[[4,87,"There, happy?"],[312,358,"Wait,"],[408,588,"that's not what I really meant."],[671,738,"Dexter,"],[792,892,"she manipulated me."],[892,1013,"You're still my fiancé?"],[1026,1109,"You believe- - Scarlett,"],[1109,1355,"you are exactly what we all see you as."],[1355,1551,"A fucking fraud and you're a damn liar."],[1705,1985,"Casey is the one who built my career."],[1985,2047,"Hell, she's the one"],[2047,2185,"who saved the damn song."],[2306,2414,"She's the only one"],[2414,2577,"who ever cared about me"],[2577,2694,"or loved me."],[2827,2986,"Our engagement is off"],[3036,3153,"and so is the record."],[5100,5155,"Oh my God."],[5392,5518,"Please don't cancel the album."],[5518,5601,"The album?"],[5672,5793,"I'm terminating your contract"],[5793,5905,"and blacklisting you"],[5905,5980,"from the industry."],[6047,6122,"Your career is over."],[6690,6873,"You got yourself a deal, Case."]],"60":[[108,162,"Hit it."],[729,1113,"If we're not here for long."],[1255,1726,"Tell me where, would we belong"],[1797,2306,"My back is pressed against the wall."],[2356,2540,"I need you to know,"],[2540,2898,"I'm not afraid to fall."],[2927,3470,"Your name's a fire, in my veins."],[3470,3824,"It's burning through my chains."],[4004,4291,"Who are you to tell me why?"],[4583,4850,"Who am I to live a lie?"],[5063,5467,"This mirror shows a thousand faces,"],[5505,6022,"but none of them can fly."]],"61":[[237,325,"She's so good!"],[325,404,"Oh my God."],[408,513,"Ms. Reed,"],[513,671,"the whole world wants to know,"],[688,813,"are you the award winning,"],[813,1021,"genius music producer, Echo?"],[1051,1251,"I think everyone saw the broadcast."],[1251,1401,"And my work speaks for itself."],[1426,1559,"You are a revolution"],[1559,1643,"in the music industry."],[1643,1743,"And we can't wait to see"],[1743,1889,"what you do next, Echo."],[2227,2523,"You arrogant fucking whore!"],[2540,2681,"You ruined everything!"],[2919,3161,"Dexter was gonna be mine!"],[3232,3349,"I was gonna be the biggest"],[3349,3524,"pop star in the world!"],[4375,4542,"But you had to get in my way."],[4842,4971,"That won't happen again."],[4971,5025,"Casey!"],[5125,5192,"Dex, no!"],[6064,6118,"Oh my!"],[6122,6227,"No, no!"],[6239,6302,"Oh my!"],[6327,6373,"Dex!"],[6406,6527,"Dex, stay with me!"]],"62":[[250,291,"Hey."],[325,367,"Hey."],[400,446,"Hey."],[517,638,"You've been here all night."],[804,934,"You still love him, don't you?"],[1096,1217,"Dexter saved my life, but"],[1397,1514,"as soon as I thank him,"],[1514,1593,"we can move on."],[1710,1826,"You know, if you say so,"],[1851,2043,"but can you stop and ask yourself"],[2043,2173,"why he risked his"],[2173,2293,"own life to save yours?"],[2293,2373,"It doesn't matter now."],[2544,2660,"Things will never return back"],[2660,2761,"to how they were before."],[2869,2927,"Casey,"],[3011,3169,"Dexter was an absolute idiot"],[3169,3324,"for betraying you, okay?"],[3420,3461,"Listen,"],[3470,3566,"but without him,"],[3603,3770,"I would've lost my baby girl."],[3862,3966,"And those two songs"],[3966,4091,"you two produced together,"],[4158,4379,"they made millions believe in love."],[4416,4508,"Your love."],[4567,4700,"Well, they shouldn't have fallen for it."],[4700,4750,"I mean,"],[4842,4959,"a love like that burns bright,"],[4959,5080,"but it doesn't last forever."]],"63":[[4,95,"Clearly Dexter"],[95,262,"never stopped caring about you."],[291,358,"Hm?"],[375,529,"Maybe your love story isn't over."],[554,742,"The other Reed Records executives"],[821,930,"want Dexter to headline"],[930,1017,"the big festival."],[1017,1167,"And sign him to the label again."],[1263,1418,"You know, if our CEO approves."],[1989,2106,"Dexter's sleeping,"],[2131,2214,"but you can see him now."],[2773,2882,"Don't be afraid to tell him"],[2882,3011,"how you feel, Princess."]],"64":[[621,725,"It was a close call."],[800,925,"One centimeter to the right,"],[975,1084,"he could've punctured his lung."],[1180,1355,"If Dex couldn't sing anymore,"],[1368,1547,"his life might as well be over."],[1589,1739,"Oh, I'm hopeful, he, he'll recover."],[1851,2052,"But for now, all he needs is rest."],[2177,2231,"That's it."],[2260,2306,"Okay?"],[2331,2385,"Alright."],[2948,3169,"What is wrong with you, Dexter?"],[3324,3424,"How could you do something"],[3424,3574,"so stupid?"],[3757,3891,"If you don't make it through this,"],[3891,4091,"I will never forgive you."],[4258,4312,"Never!"],[4608,4662,"Hi."]],"65":[[33,179,"I got you, beautiful."],[538,696,"Why are you still mad at me?"],[842,1084,"I think I have every right to be."],[1451,1526,"Casey, I,"],[2014,2085,"I miss you."],[2135,2277,"I miss him too."],[2310,2419,"But everything"],[2419,2548,"we've put each other through,"],[2594,2786,"can we really be together again?"],[2869,3044,"You saved my life and"],[3353,3520,"I will be forever grateful."],[3812,3903,"And in return,"],[3903,4070,"I'll give you your song for free."],[4087,4304,"And um, we can go our separate ways."],[4304,4404,"We can end on a high note."],[4404,4487,"No, listen."],[4542,4587,"No."],[4767,4892,"Is that really what you want?"],[5025,5213,"To walk away from all this forever?"],[5918,6001,"Look, there's something"],[6001,6089,"I have to show you."],[6114,6268,"Something I've been trying to show you."]],"66":[[1159,1238,"That horrible night"],[1238,1368,"when I chose Scarlett."],[1555,1764,"I only did it because I had to."],[1810,1943,"They forced you to choose her."],[1943,2202,"I, I was trying to save your life, okay?"],[2239,2410,"I would never, ever,"],[2410,2519,"ever do that to you."],[2560,2706,"I'd choose you a million times over."],[2786,2915,"And I knew that I'd break your heart."],[2915,3028,"And I knew that I would"],[3082,3194,"lose you and I..."],[3374,3482,"But I'd rather risk that"],[3482,3616,"than losing your life forever."],[4191,4333,"When I said I loved you, Dexter,"],[4333,4412,"I meant it."],[4579,4775,"I don't wanna be with anyone else."],[4838,4929,"Me neither."],[5276,5442,"You're my little muse."],[5739,5868,"My pop star."],[6222,6468,"Which reminds me,"],[6694,6806,"Reed Records"],[6806,7086,"would like to formally invite you"],[7086,7311,"to headline the Wildlight Festival."],[7340,7453,"The Wildlight Festival is the"],[7453,7720,"biggest music stage in the world."],[7766,7899,"You saved their CEO."],[7899,7966,"You deserve it."],[8003,8158,"You're the reason I sing."],[8258,8362,"You're the reason I live."],[8391,8491,"I don't wanna song write"],[8491,8662,"or do any of this if I don't have you."],[8662,8742,"You,"],[8867,9013,"you're my world, Casey."],[9209,9371,"I know I've written a lot of songs,"],[9371,9409,"okay?"],[9409,9480,"I know."],[9551,9651,"But none of them"],[9651,9788,"compare to how I feel."],[9876,9984,"I don't wanna be with you"],[9984,10080,"for just who you are"],[10080,10268,"or what you have or any of that stuff."],[10364,10447,"I don't even wanna sing"],[10447,10510,"or have this crew."],[10510,10627,"I'd give it up in a second"],[10627,10810,"if it meant just being with you."],[10890,10977,"That's all I need."]],"67":[[58,154,"We do it together."],[592,738,"I don't have a sound without you,"],[738,825,"Dexter Hayes."],[875,938,"Okay."],[1234,1405,"I want us to do this together."],[1668,1730,"I love you."],[1951,2027,"I love you too."],[3324,3420,"This is the biggest crowd"],[3420,3545,"I've ever seen in my life."],[3774,3870,"Then you better give them"],[3870,3953,"one hell of a show."],[4195,4262,"Yes, ma'am."]],"68":[[0,275,"I wrote this song with Casey Reed,"],[346,467,"who is my Echo."],[467,667,"But more importantly, she is"],[700,892,"undoubtedly the love of my life."],[1151,1305,"So I hope you enjoy."],[3541,3799,"Just a little."],[3837,4304,"Every time I, remember to smile I"],[4304,4725,"imagine a world we're together."],[5701,6181,"List goes on."],[6181,6423,"We're stuffing the stockings"],[6423,7065,"but I am still walking the road to you."],[7102,7365,"Was the fool who I hated,"],[7365,7628,"now I'm recreated."],[7628,8074,"Every time I, look at the moonfall,"],[8074,8537,"I dream of a night that's lost forever."],[8537,8954,"But soon you'll see,"],[8988,9455,"that it's time for you and me."],[9476,9880,"Cause the best so far"],[9901,10139,"was just a little,"],[10155,10406,"just a little."],[10443,10910,"Every time I, look in your eyes I"],[10910,11290,"forget where I am, just a little."],[11290,11824,"Yeah, yeah, yeah!"],[11861,12241,"I dream of a night that's lost forever."],[12241,12821,"Yeah, yeah."],[12821,13038,"Tickin and Tockin."],[13058,13763,"But I will be watchin the road to you."],[13763,13955,"The mirror to heaven."],[14005,14305,"My heart is still beating."],[14305,14693,"Every time I, remember to smile I"],[14714,15261,"imagine a world we're together."]]}