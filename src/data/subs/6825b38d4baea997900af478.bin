],[496,658,"Psycho, huh?"],[658,804,"I'll show you psycho."],[967,1080,"Please stop!"],[1138,1305,"There's been some kind of mix-up."],[1305,1401,"I know who she is."],[1401,1497,"She's my ex."],[1497,1672,"Why would a man"],[1672,1935,"so as refined and connected as you"],[1935,2173,"pick something like her?"],[2385,2510,"If she got pregnant,"],[2510,2598,"she wouldn't even know"],[2598,2736,"who the father is."],[3324,3503,"All right, fun's over."],[3516,3624,"I'm tired of you lowlifes"],[3624,3803,"insulting my future wife."],[3820,3912,"She was trying to have my kid"],[3912,4091,"just a few days ago."],[4095,4312,"Yeah, I upgraded, Marcus."],[4358,4542,"Turns out I found a real man."],[4650,4829,"Not some loser with limp dick syndrome."],[4842,4909,"Shut the fuck up!"],[4909,5088,"You shut the fuck up!"],[5184,5234,"They're not worth"],[5234,5413,"the trouble, Marcello."],[5597,5772,"Football player, huh?"],[5772,5872,"What? Let me guess."],[5872,6051,"You're his slutty little cheerleader."],[6072,6168,"Classic."],[6218,6360,"Well, I bet you two dream of"],[6360,6560,"going to the NFL one day too, huh?"],[6569,6748,"At least we are who we say we are."],[6827,6977,"Come on, Marcus."],[6977,7157,"There's no way he's really mafia."],[7211,7394,"It's just this bitch Vanessa thinking"],[7394,7603,"we're stupid enough to believe the city's"],[7603,7782,"richest man would even look at her."],[7862,8041,"I don't dream going to the NFL."],[8108,8299,"I am going to the NFL."],[8433,8575,"And I'm taking my beautiful fiancée"],[8575,8612,"with me."],[8612,8792,"So you two losers"],[8825,9009,"you can enjoy pretend to be rich."],[9025,9121,"But I'm actually going to go"],[9121,9300,"make millions."],[9317,9501,"I'm not a real Lavigne?"],[10364,10506,"You,"],[10506,10556,"put me on the phone"],[10556,10610,"with the Dean."],[10623,10802,"Seriously?"],[10810,10890,"Give it up!"],[10890,11061,"It's over!"],[11061,11198,"Stop wasting everyone's time"],[11198,11361,"with your D-list acting."],[11465,11603,"Yes,"],[11603,11711,"Mr. Lavigne."],[11711,11795,"The Dean will be with you"],[11795,11891,"- immediately. - Wait, what?"],[11920,12012,"He's been meaning to thank you"],[12012,12195,"for your generous donation."],[12199,12299,"Hello, Dean."],[12299,12408,"Mr. Lavigne is in your office."],[12725,12867,"What donation?"],[12867,13029,"You can't be serious."],[13029,13179,"Vanessa, call him off."],[13179,13288,"Relax."],[13288,13509,"There's no way a real mafia boss"],[13509,13646,"would choose her."],[13734,13893,"Mr. Lavigne!"],[13893,13997,"Why didn't you let us know"],[13997,14122,"that you'll be on campus today?"],[14122,14310,"I would have given you the tour myself."]],"28":[[12,125,"No need."],[125,254,"But can you please explain to me"],[254,304,"why your"],[304,508,"star quarterback and cheer captain"],[533,679,"assaulted my fiancée."],[679,859,"They what?"],[1197,1347,"Venessa, call them off."],[1347,1518,"We're sorry."],[1518,1668,"We can talk about this."],[1668,1839,"Please."],[1839,1943,"Well,"],[1943,2043,"if you're not going to do anything"],[2043,2139,"about it,"],[2139,2318,"I guess I'll sue the campus."],[2327,2498,"Or, I mean, I'll revoke"],[2498,2677,"my $10 million donation."],[2765,2882,"Why not both?"],[2894,2994,"You two idiots"],[2994,3169,"know who you just messed with?"],[3186,3386,"We were just messing around."],[3424,3603,"Things got out of hand, sir."],[3682,3770,"Vanessa."],[3770,3953,"We're sorry."],[4033,4208,"Please call them off."],[4208,4371,"I'm sorry for cheating on you!"],[4371,4550,"I'm sorry."],[4596,4750,"Leave the Don's fiancée alone,"],[4750,4892,"you clowns."],[4892,5046,"You're both suspended."],[5046,5213,"You, you're off the cheer squad."],[5213,5384,"And you, my star quarterback,"],[5384,5442,"you're benched."],[5442,5588,"Expelled."],[5588,5772,"I want him expelled."],[5822,5947,"Yeah, of course."],[5947,6093,"I'll find a new quarterback."],[6093,6272,"Anything for you, Don Lavigne."],[6277,