{"1":[[925,1126,"Here you go."],[1301,1397,"Hey, limp girl!"],[1488,1597,"Where's my beer?"],[1726,1818,"Coming right up!"],[1885,2027,"The Boston Blizzards, led by"],[2027,2198,"Captain Alexander Vaughn,"],[2198,2360,"crushed the Chicago Wolves"],[2360,2439,"to claim the Stanley Cup!"],[2439,2627,"Vaughn, at only twenty-four,"],[2627,2794,"becomes the youngest player to"],[2794,2857,"win both the Cup"],[2857,3057,"and the league MVP title."],[3282,3319,"Oh!"],[3390,3457,"Oh, oh!"],[3457,3516,"Oh, sir, are you..."],[3516,3578,"Are you okay?"],[3649,3720,"Please..."],[3812,3903,"help."],[4087,4175,"I've been drugged"],[4175,4362,"with an aphrodisiac."],[4362,4562,"I need to control myself,"],[4600,4725,"but I can't."],[5075,5196,"Ah, what are you..."],[5196,5238,"what are you..."],[5238,5280,"what are you doing!"],[5280,5488,"I am not that kind of girl, okay!"],[5488,5568,"I- I'm so sorry."],[5655,5776,"You're just..."],[5776,5868,"so beautiful."],[6185,6297,"Oh, okay."],[6297,6356,"Okay."],[6356,6427,"Here,"],[6427,6489,"let me help you,"],[6489,6552,"okay?"],[6552,6648,"I'll get you some water."],[7211,7340,"You feeling better?"],[7365,7457,"Yeah."],[7640,7686,"Don’t..."],[7695,7761,"go!"],[8220,8375,"Maybe just for tonight."],[11790,11982,"You get pregnant"],[11982,12132,"before marriage?"],[12132,12212,"And you try to"],[12212,12345,"hide it from us."],[12391,12537,"You crippled"],[12537,12670,"little whore."],[12708,12746,"And here"],[12746,12796,"I thought you were"],[12796,12904,"just getting fat."],[12954,13042,"Who's the father"],[13042,13146,"of your bastard?"],[13300,13455,"You fucking tell me, now!"]],"2":[[120,221,"I don't know his name."],[233,433,"You filthy little slut!"],[446,525,"How could you let"],[525,725,"some stranger knock you up?"],[759,867,"And after you got pregnant,"],[867,900,"you've been"],[900,1042,"mooching off of us"],[1042,1251,"and bringing no money back!"],[1263,1368,"You’re getting rid of that"],[1368,1468,"bastard spawn!"],[1493,1568,"Today!"],[1597,1768,"I won’t let you hurt my baby!"],[1768,1860,"And I have given you"],[1860,1931,"every cent"],[1931,1997,"I had over"],[1997,2114,"the last few years!"],[2173,2298,"I'm going to raise this baby"],[2298,2464,"on my own without your help!"],[2665,2794,"With what?"],[2815,2994,"Pennies from heaven?"],[3140,3224,"All the money"],[3224,3461,"you make belongs to us."],[3486,3716,"Your share of the expenses!"],[4133,4233,"That's enough!"],[4525,4575,"Lila,"],[4633,4771,"we brought you in"],[4771,4913,"after your parents died."],[4913,4975,"And gave you"],[4996,5071,"a home."],[5113,5276,"And this is how you repay us?"],[5305,5501,"By getting pregnant before marriage."],[5501,5622,"It’s...it’s shameful!"],[5751,5901,"Dad, she makes me sick."],[5976,6122,"We should throw her out!"],[6122,6243,"Zoe's right!"],[6243,6368,"You let her stay would"],[6368,6552,"only cause more trouble."],[6998,7090,"There's no place"],[7090,7173,"for you here."],[7253,7361,"Get the fuck out,"],[7386,7457,"now!"],[10189,10285,"Ugh...it hurts!"],[10335,10447,"Someone help me!"],[10481,10589,"I'm going into labor!"],[11611,11674,"Oh, my God!"],[11674,11811,"She's in labor!"],[11982,12057,"Call 911!"],[12174,12233,"Are you okay, ma’am?"],[12233,12278,"Are you okay?"],[12337,12383,"Ugh..."],[12395,12499,"God, not now."],[12620,12666,"Oh my God!"],[12666,12766,"The baby is coming!"],[13697,13747,"Please!"],[13813,13876,"It’s him!"],[13968,14064,"My baby’s dad!"],[14268,14314,"Please!"],[14401,14460,"You..."]],"3":[[392,479,"Ms. Cobb,"],[563,738,"your baby was born premature."],[750,809,"He has to stay"],[809,909,"in the incubator."],[975,1051,"Okay."],[1101,1330,"The cost is significant."],[1939,2131,"I'll pay it before we leave."],[2131,2285,"Where is your family?"],[2285,2485,"The baby's father?"],[2506,2577,"Someone should be"],[2577,2656,"here to care for you"],[2656,2777,"during your recovery."],[2815,2986,"There is no one else."],[2986,3128,"It's just us,"],[3140,3307,"me and my baby."],[3858,4137,"I am homeless and broke."],[4141,4262,"How am I supposed to raise you?"],[4262,4337,"Little one..."],[4379,4471,"I haven't even figured out"],[4471,4567,"a name for you."],[4662,4758,"And how on earth"],[4758,4954,"am I going to pay this bill?"],[5201,5305,"Maybe..."],[5367,5505,"Please! - Oh, oh!"],[5505,5613,"Oh, oh, sir..."],[5613,5689,"Are you...are you okay?"],[5689,5772,"Please, just..."],[5805,5935,"take my watch."],[5935,6056,"It's the most valuable thing"],[6056,6101,"that I have."],[6101,6218,"Please, please just..."],[6218,6289,"No, no, no. Please!"],[6289,6343,"Just, just..."],[6343,6418,"just take it."],[6673,6831,"Maybe I can sell it."],[6865,6944,"Well, now you know"],[6944,7061,"how I feel, darling."],[7061,7207,"You nag me to see the doctor,"],[7207,7365,"and I refuse to listen."],[7365,7494,"I nag you to settle down"],[7494,7553,"and marry,"],[7553,7695,"and you refuse to listen."],[7695,7816,"It's a vicious cycle, really."],[7816,8016,"But I guess we're even."],[8041,8099,"Grandma,"],[8099,8199,"I told you"],[8199,8379,"I'm interested in someone."],[8425,8579,"You mean the beer girl?"],[8579,8683,"Please."],[8683,8779,"You're interested in"],[8779,8879,"a faded memory?"],[8904,9025,"It's been eight months"],[9025,9167,"and you haven't found her."],[9167,9263,"I'm beginning to think"],[9263,9405,"this whole story is a"],[9405,9622,"ploy to get me to shut up!"],[9788,9864,"Oh!"],[10210,10322,"I'm so sorry."],[10322,10481,"I didn't see you there, dear."],[10564,10814,"What a pretty girl she is."],[10819,10948,"She'd be a perfect"],[10948,11106,"match for my Alex."],[11115,11156,"It's fine."],[11156,11294,"You don't have to apologize to me."],[11565,11699,"I'm afraid I may have broken"],[11699,11770,"your watch."],[11916,12037,"How odd."],[12037,12124,"This watch..."],[12124,12258,"my grandson has one"],[12258,12358,"just like it."],[12358,12479,"It's a gorgeous watch."],[12479,12591,"Must have cost a fortune."]],"4":[[95,237,"Ms. Cobb,"],[237,308,"our admin team"],[308,412,"is looking for you."],[425,558,"Have you paid your bill yet?"],[821,892,"Her bill?"],[963,1055,"For what?"],[1096,1197,"She gave birth alone"],[1197,1247,"last night."],[1330,1501,"The NICU charges are due today."],[1605,1801,"You've already had a baby?"],[1947,2010,"Well,"],[2085,2160,"I can help."],[2198,2310,"How much do you need?"],[2414,2481,"Oh,"],[2502,2677,"no, I... I could never that..."],[2681,2882,"it's like $10,000."],[3240,3382,"What if I traded you this for it?"],[3557,3724,"Exactly as I thought!"],[3724,3849,"It's a Richard Mille!"],[3887,3999,"My grandson has one"],[3999,4095,"just like it."],[4095,4212,"It's worth millions."],[4366,4458,"Mrs. Vaughn,"],[4458,4554,"with all due respect,"],[4554,4733,"someone of her stature"],[4733,4825,"clearly can't afford"],[4825,4946,"something like this."],[4967,5055,"It must be a fake."],[5055,5176,"Exactly!"],[5196,5372,"She's scamming you."],[5372,5484,"No, I..."],[5543,5714,"I'll take the watch."],[5809,5980,"Give her the money."],[6940,7044,"Thank you."],[7073,7173,"Thank you."],[7319,7436,"You have no idea how much"],[7436,7515,"this means to me."]],"5":[[2314,2506,"Mom is trying, baby."],[2506,2556,"I'm going to give"],[2556,2673,"you a better life."],[3699,3774,"Alex,"],[3774,3974,"It's been eight months."],[4004,4179,"Media week starts tomorrow."],[4220,4295,"If word gets out"],[4295,4346,"you're chasing"],[4346,4446,"some girl from a bar?"],[4496,4608,"It's going to take your image,"],[4654,4758,"scare off sponsors,"],[4758,4863,"and pisses off the team."],[4863,4988,"Okay, I don't care."],[5050,5150,"Keep looking."],[5780,5901,"Pizza!"],[7899,8012,"Wait, it's him!"],[8016,8124,"Please."],[8158,8249,"Help!"],[8291,8404,"He's my baby's father!"],[8404,8525,"Wait! Stop the car!"],[8562,8683,"Stop the car!"],[8942,9029,"Stop the car! Oh!"],[9163,9217,"Oh!"],[10064,10243,"Wait! I have your baby!"],[10260,10318,"Hello?"],[10372,10443,"Grandma?"],[10702,10794,"Alex,"],[10794,11019,"I bought a Richard Mille watch"],[11019,11194,"at the hospital today."],[11232,11348,"Strangest thing,"],[11386,11586,"it looks just like yours!"],[11586,11682,"At the hospital?"],[11682,11757,"How much?"],[11786,11907,"$10,000."],[12003,12062,"I think you got"],[12062,12149,"scammed, grandma."],[12149,12258,"I'll have someone handle it."]],"6":[[504,633,"Hi, sir,"],[633,792,"are you still hiring cleaners?"],[825,930,"We need someone that can"],[930,996,"clean on ice."],[996,1096,"And you can't even stand"],[1096,1230,"straight on carpet."],[1230,1326,"No chance."],[1326,1501,"Look, please!"],[1501,1630,"I can sweep, I can scrub."],[1630,1735,"I can carry things."],[1735,1822,"Just whatever you need."],[1822,1972,"Please, just let me try."],[1972,2072,"Please!"],[2210,2248,"Please,"],[2248,2364,"just let me try!"],[2635,2748,"Fine, fine."],[2748,2873,"Don't make a scene!"],[3069,3103,"You want a chance?"],[3103,3303,"Take these boxes out back."],[3303,3415,"Yeah, anything."],[3415,3499,"Thank you!"],[3561,3670,"Did you find her yet?"],[3670,3753,"No."],[3753,3953,"Still looking."],[4179,4262,"Thank you."],[4917,4967,"Oh!"],[5000,5050,"Sorry."],[5050,5130,"Sorry about that!"],[6823,6898,"He must be a"],[6898,7098,"really good hockey player."],[7257,7307,"Lila!"],[7307,7444,"Why isn't this done yet?"],[7590,7632,"Oh!"],[7661,7778,"Look at this trash!"],[7799,7832,"There better"],[7832,7937,"not be any more trash here"],[7937,8020,"by tomorrow morning,"],[8020,8166,"or you're fired!"],[8166,8199,"Okay, I'm sorry."],[8199,8341,"I'll finish it right now!"],[9184,9321,"Hold on, Lila."],[9321,9471,"You got this."],[9471,9534,"Your baby is"],[9534,9622,"waiting to be fed."],[10030,10214,"What is happening to me?"],[10222,10372,"Oh, oh, oh, oh..."],[11911,12041,"Miss?"],[12041,12132,"Hey!"],[12183,12274,"Is that..."],[12412,12499,"him?"]],"7":[[909,992,"Mr. Vaughn,"],[992,1084,"no need to worry."],[1084,1167,"She's burnt out"],[1167,1267,"and running a high fever,"],[1267,1401,"but she'll wake up soon."],[1455,1547,"Thanks."],[1751,1931,"She looks familiar."],[1931,2131,"Have I met her before?"],[2535,2644,"Hey, grandma."],[2644,2719,"Alex,"],[2719,2811,"remember the watch"],[2811,2944,"you were sure was a scam?"],[2944,3103,"The appraiser just left,"],[3103,3424,"and it's worth $5 million."],[3470,3591,"How is that possible?"],[3741,3774,"Okay, I'm"],[3774,3883,"going to come by right now"],[3883,3983,"and check it out."],[5584,5647,"See?"],[5647,5826,"Still think I got scammed?"],[5826,5943,"You were dead wrong."],[5943,5968,"Okay,"],[5968,6076,"let me see the watch, grandma."],[6118,6318,"Keep your paws off of it."],[6343,6431,"I'm going to find that"],[6431,6489,"poor girl"],[6489,6614,"and give it back to her."],[6614,6685,"She gave birth"],[6685,6744,"in the hospital"],[6744,6827,"all alone!"],[6827,6915,"And couldn't cover her"],[6915,7011,"hospital bill!"],[7044,7140,"Imagine."],[7140,7194,"And she didn't"],[7194,7323,"hesitate to sell it."],[7323,7453,"She obviously had no idea"],[7453,7570,"it was worth millions."],[7570,7599,"Okay,"],[7599,7703,"so she has a watch worth"],[7703,7816,"$5 million,"],[7816,7903,"but she can't even afford"],[7903,8095,"to pay her hospital bills."],[8095,8245,"That doesn't make any sense."],[8245,8329,"Oh, come on,"],[8329,8475,"you're way too paranoid."],[8475,8562,"Maybe I'm paranoid,"],[8562,8621,"but it still doesn't"],[8621,8717,"make any sense."],[8754,8812,"Why she all alone?"],[8812,8971,"Why isn’t the father stepping up?"],[8971,9079,"All I know is"],[9079,9167,"she deserves to"],[9167,9267,"have this watch back."],[9363,9463,"Alright, give me the watch,"],[9463,9517,"I’ll find her."],[9555,9759,"I knew you’d see things my way."],[10752,10898,"This is my watch!"]],"8":[[45,133,"What?"],[367,462,"How is that even"],[462,550,"possible?"],[679,796,"Alex!"],[838,909,"I found her!"],[1017,1201,"Her name is Lila Cobb."],[1201,1272,"Parents died"],[1272,1347,"when she was a kid"],[1347,1409,"and got adopted"],[1409,1484,"by her aunt and uncle,"],[1484,1664,"who've treated her like crap."],[1714,1897,"This is the girl."],[1897,2110,"How did you track her down so fast?"],[2740,2890,"It's her!"],[2890,3032,"I brought her to the hospital"],[3032,3178,"last night."],[3178,3236,"Grandma,"],[3236,3349,"this is the beer girl"],[3349,3407,"that helped me."],[3407,3470,"I gave her"],[3470,3582,"my watch that night."],[3582,3695,"This is the girl"],[3695,3787,"you've been looking for"],[3787,3966,"for the past eight months."],[3966,4054,"Yeah."],[4054,4254,"Could her baby be yours?"],[4800,4938,"Grandma,"],[4938,5138,"I'm going to be a father!"],[5213,5338,"We have to find her now."],[5338,5480,"Come on, let's go!"],[6731,6773,"My baby"],[6773,6898,"needs formula."],[7440,7590,"Alex, as your agent,"],[7590,7749,"I've got to warn you,"],[7749,7824,"if you go public"],[7824,7882,"with this woman"],[7882,8037,"and suddenly have a child"],[8037,8162,"out of nowhere,"],[8162,8262,"it'll ruin your image"],[8262,8362,"and maybe your career."],[8362,8462,"Yeah, well, maybe my career isn't"],[8462,8621,"the only thing that matters."],[8637,8729,"She’s the mother of my child."],[8729,8796,"The least I can do"],[8796,8888,"is be there for them."],[8925,9121,"She has a bad leg."],[9121,9200,"Alex!"],[9213,9342,"You're the youngest M.V.P."],[9342,9505,"and Cup winner in history."],[9505,9647,"The perfect player!"],[9697,9755,"You really think"],[9755,9880,"this is a good look for you?"],[9880,9968,"That's enough!"],[9968,10093,"This is my responsibility,"],[10093,10143,"and I'm going to"],[10143,10222,"take care of them."]],"9":[[62,133,"Mr. Vaughn."],[262,325,"Dr. Lee."],[362,446,"Hi."],[671,742,"This way, please."],[1564,1655,"Where is Lila?"],[1655,1764,"Why isn't she here?"],[1764,1885,"I don't know when she left."],[1885,1972,"I'm sorry."],[2068,2181,"But she'll have to come back."],[2181,2227,"Her baby's"],[2227,2344,"still in the NICU."],[3395,3516,"I can't believe I'm a father."],[3883,3924,"Doctor,"],[3924,3987,"can you transfer"],[3987,4179,"my son to the best private unit,"],[4179,4325,"a round-the-clock care, please?"],[4325,4462,"Of course. Mr. Vaughn."],[4500,4625,"Hey!"],[4692,4838,"Look at you!"],[4854,4913,"Hi!"],[5526,5651,"Nurse, where is my baby?"],[5651,5822,"Oh, don't worry, Ms. Cobb."],[5822,5947,"Your baby’s been picked up."],[6385,6468,"Picked up?"],[6489,6569,"By who?"],[6656,6698,"That is my baby."],[6698,6815,"How could you let someone"],[6815,6931,"take my son?"],[7040,7240,"It's not..."],[7599,7691,"Hello?"],[7691,7778,"Lila,"],[7778,7987,"you need to come home now."],[7987,8095,"It's urgent!"],[8095,8254,"Aunt Martha?"],[8254,8391,"Did Aunt Martha take my baby?"]],"10":[[479,563,"Don't worry."],[563,713,"She'll be back soon."],[1376,1493,"Where is my son?"],[1522,1576,"Do you have him?"],[1576,1685,"Please give him back to me."],[1685,1814,"Your... your son?"],[1918,1985,"Take him?"],[2147,2268,"What's she talking about?"],[2268,2331,"Yes!"],[2364,2431,"That's right!"],[2494,2615,"We took your baby."],[2652,2736,"I called you here"],[2736,2852,"because we need something"],[2852,2919,"from you."],[3157,3278,"What do you want?"],[3315,3532,"This is Evan, Ryan's brother."],[3582,3674,"His wife just died,"],[3674,3837,"and he wants to remarry."],[3837,3928,"We thought you'd be perfect"],[3928,3987,"for him."],[4041,4187,"You just had a baby,"],[4187,4325,"and you're a cripple."],[4325,4479,"No man would want to marry"],[4479,4679,"a woman like you."],[4838,4909,"But Evan doesn't"],[4909,5009,"mind at all."],[5134,5251,"You can have a home."],[5789,5864,"I am not going to"],[5864,5955,"marry him."],[5989,6110,"Just give me my baby"],[6110,6222,"so that I can leave!"],[6289,6327,"Lila,"],[6327,6493,"how do you expect to afford"],[6493,6619,"to raise a child on your own?"],[6748,6823,"You're a cripple."],[6823,6877,"You, you won't"],[6877,7048,"even find decent work."],[7048,7203,"Stop being so stubborn!"],[7211,7265,"Yeah."],[7265,7336,"Evan's had"],[7336,7482,"some addiction issues"],[7482,7599,"since his wife died."],[7649,7695,"And maybe he's"],[7695,7795,"a little old for you,"],[7795,7895,"but he gets a few"],[7895,8037,"hundred dollars in benefits"],[8037,8116,"every month."],[8116,8316,"I don't care!"],[8370,8516,"I'm not going to marry him!"],[8516,8646,"What the fuck?!"],[8833,8933,"Remember our deal."],[9009,9104,"Calm down."],[9104,9238,"Lila,"],[9238,9438,"Evan’s just..."],[9463,9688,"a little off sometimes,"],[9688,9722,"but most times,"],[9722,9884,"he's just fine."],[9972,10047,"That's right."],[10076,10176,"He's just fine."],[10193,10264,"Don't worry."],[10264,10377,"Once you're married,"],[10377,10514,"you'll get used to it."],[10514,10560,"No!"],[10560,10639,"I am not going to"],[10639,10752,"get used to it!"],[10777,10935,"I am not going to marry him!"],[10935,10998,"I am not going to"],[10998,11198,"let you ruin my life!"],[11207,11407,"Ruin your life?"],[11511,11628,"How could it"],[11628,11840,"possibly be any worse"],[11857,11995,"than it already is?"],[11995,12157,"This is for your own good."],[12374,12575,"Don't forget,"],[12608,12737,"we have your baby."],[22555,22710,"Haven't you've done enough?"],[22860,23010,"Please, just give me my baby back."],[23089,23177,"Please!"],[23177,23373,"I'm thinking about you."],[23373,23577,"You need a better life!"],[23577,23744,"Once you marry Evan,"],[23744,23944,"we'll take care of your baby."],[23944,24174,"You'll be happy with Evan, Lila."],[24891,24958,"Alex,"],[25050,25175,"we found Ms. Cobb."],[25175,25266,"She's at her uncle's house."],[25266,25379,"Good. Let's go."],[25379,25446,"Come on."],[25671,25796,"Your uncle already"],[25796,25925,"sold you to us."],[25925,26063,"You're been bought and paid for."],[26217,26338,"You're coming with us,"],[26338,26484,"whether you like it or not!"],[26484,26539,"No!"],[26539,26668,"No, let me go!"],[26668,26793,"I didn't take your money, okay?"],[26793,26922,"Don't touch me!"],[27131,27198,"Fuck!"],[27819,27986,"Didn't get far, did she?"],[28411,28549,"Let's break her other leg."],[28653,28749,"Then she'll never be able"],[28749,28849,"to run again."],[29008,29212,"My baby girl's so clever,"],[29212,29300,"isn't she?"],[29333,29458,"I'd be happy to."],[29487,29558,"No!"],[29558,29654,"No, don't!"],[29888,29917,"Hey!"]],"11":[[29,183,"Haven't you done enough?"],[333,529,"Please, just give me my baby back."],[563,650,"Please!"],[650,846,"I'm thinking about you."],[846,1051,"You need a better life!"],[1051,1217,"Once you marry Evan,"],[1217,1418,"we'll take care of your baby."],[1418,1647,"You'll be happy with Evan, Lila."],[2364,2431,"Alex,"],[2523,2648,"we found Ms. Cobb."],[2648,2740,"She's at her uncle's house."],[2740,2852,"Good. Let's go."],[2852,2919,"Come on."],[3144,3269,"Your uncle already"],[3269,3399,"sold you to us."],[3399,3536,"You're bought and paid for."],[3691,3812,"You're coming with us,"],[3812,3958,"whether you like it or not!"],[3958,4012,"No!"],[4012,4141,"No, let me go!"],[4141,4266,"I didn't take your money, okay?"],[4266,4396,"Don't touch me!"],[4604,4671,"Fuck!"],[5292,5459,"Didn't get far, did she?"],[5885,6022,"Let's break her other leg."],[6126,6222,"Then she'll never be able"],[6222,6322,"to run again."],[6481,6685,"My baby girl's so clever,"],[6685,6773,"isn't she?"],[6806,6931,"I'd be happy to."],[6961,7032,"No!"],[7032,7127,"No, don't!"],[7361,7390,"Hey!"]],"12":[[33,79,"Hey!"],[696,792,"It's him..."],[967,1096,"Why is he here?"],[1163,1309,"What the hell is going on in here?"],[2156,2260,"You okay?"],[2615,2744,"Who the hell is this guy?"],[2877,3011,"Who the hell do you think you are?"],[3011,3178,"Take your hands off my niece"],[3178,3286,"right now!"],[3286,3403,"I'm glad that you told me"],[3403,3490,"you're her uncle."],[3532,3695,"Now you can tell me why you're"],[3695,3782,"abusing her."],[3858,4020,"Nobody's abusing her!"],[4112,4245,"We're trying to help her."],[4245,4446,"She needs a good husband."],[4517,4633,"A good husband?"],[4717,4817,"You mean that piece of shit"],[4817,4900,"who just tried to hit her"],[4900,5017,"with a hockey stick?"],[5017,5080,"No!"],[5080,5180,"No, of course not."],[5271,5447,"Lila was supposed to marry Evan."],[5693,5768,"His brother."],[6289,6406,"Is he on drugs?"],[6452,6539,"Yeah... please save me."],[6539,6677,"I can't marry him, okay?"],[6677,6769,"Please."],[6769,6881,"You're getting married!"],[7090,7253,"Your uncle already took my money!"],[7674,7841,"I knew I recognized you!"],[8028,8170,"You're Alexander Vaughn!"],[8233,8395,"MVP and the youngest Cup"],[8395,8596,"winner in hockey history."],[8596,8704,"This is unreal,"],[8704,8883,"I'm literally your biggest fan!"]],"13":[[41,108,"You..."],[204,396,"you really Alexander Vaughn?"],[588,779,"No way, Lila, not a chance."],[779,925,"Alexander Vaughn"],[925,1092,"is the hottest athlete"],[1092,1192,"in the world."],[1192,1405,"He's worth billions of dollars."],[1405,1518,"What the hell would he be doing"],[1518,1697,"standing in our living room?"],[1697,1860,"Exactly. Save the crap."],[1860,2018,"No one's falling for it."],[2018,2193,"I don't care what you fall for."],[2306,2423,"I'm here for Lila."],[2498,2631,"She just gave birth to my child,"],[2631,2752,"and I'm damn sure not going to let"],[2752,2882,"any of you abuse her."],[2948,3103,"How did he know about the baby?"],[3165,3378,"Are you out of your mind?"],[3378,3461,"Look at her!"],[3545,3595,"She's crippled,"],[3595,3753,"how can she even have your baby?"],[3753,3903,"If it's a child you want,"],[3903,4133,"no need for stories."],[4133,4241,"My daughter Zoe"],[4241,4408,"could give you a child."],[4487,4742,"She's a far better choice, anyway."],[4808,4967,"We'll offer you a great price"],[4967,5121,"for her services."],[5255,5526,"A cool million and you can be a father."],[5668,5797,"A million dollars you said?"],[5860,5943,"Yes!"],[5980,6093,"Pretty hard to pass on"],[6093,6360,"such an amazing opportunity, isn't it?"],[7323,7536,"This is all yours."],[7665,7899,"If you get on your knees"],[7899,8083,"and you apologize to Lila."],[8233,8408,"Are you insane?"]],"14":[[0,158,"We're her family."],[158,300,"How dare she demand anything"],[300,375,"from us?"],[713,771,"Okay."],[850,900,"No, no!"],[900,975,"Stop!"],[1559,1659,"We're so sorry..."],[1659,1839,"Lila, we're so... so sorry."],[1989,2173,"It doesn't sound genuine to me."],[2173,2348,"No, no, you promised!"],[2414,2469,"Yeah,"],[2623,2706,"I lied."],[2911,3032,"After what you did to Lila,"],[3032,3086,"you're not getting"],[3086,3186,"a cent from me."],[3365,3470,"You deserve better than this."],[3470,3653,"You're coming with me, okay?"],[3653,3766,"No, no, no, I can't go."],[3766,3903,"They have my baby."],[3903,3970,"No, no,"],[3970,4099,"we don't have your baby."],[4099,4216,"That was a lie."],[4216,4354,"We don't know where your baby is."],[4433,4554,"You lied to me?"],[4612,4729,"Then where is my baby?"],[4729,4854,"Who has my baby?"],[4854,5000,"Lila, Lila, hey,"],[5000,5096,"the baby is fine."],[5096,5226,"I moved him to get better care."],[5226,5372,"You don't have to worry, okay?"],[5409,5572,"You took him?"],[5693,5809,"Who gave you the right to do that?"],[5809,5930,"You can't, you can't..."],[5930,6014,"Lila... - You can't..."],[6014,6164,"Lila? Lila..."],[6164,6314,"Hey, hey, Lila, Lila..."],[6381,6539,"Hey, hey, hey, hey..."],[6539,6631,"stay with me!"],[6865,6965,"Fuck!"],[7127,7286,"She thinks having Alexander's baby"],[7286,7449,"means she's set for life, huh?"],[7582,7732,"we'll see about that."],[7732,7941,"There are plenty of ways"],[7941,8158,"I can make her life hell!"]],"15":[[583,679,"Ms. Cobb should have stayed"],[679,909,"in our care to rest after she gave birth."],[963,1101,"Unfortunately, she left,"],[1101,1267,"and now she's caught an infection."],[1351,1505,"I don't care what it costs."],[1505,1639,"Get her the best medical treatment"],[1639,1730,"that money can buy."],[1830,1910,"Don't worry."],[1910,2010,"We'll do our best."],[2285,2398,"Poor girl,"],[2398,2531,"she's got no one."],[2573,2781,"She's doing life all alone,"],[2781,2961,"she had a baby all alone,"],[3123,3294,"and now she's worked herself sick."],[3294,3420,"Well, that ends today."],[3749,3795,"From now on,"],[3795,3937,"I'm taking care of them both."],[4062,4170,"You found the girl"],[4170,4312,"you've been dreaming of,"],[4312,4466,"and she's given you the child"],[4466,4592,"you always wanted."],[4704,4859,"You wanted take care of her."],[4954,5150,"Well, then you start by marrying her,"],[5150,5255,"properly."],[5255,5397,"No courthouse wedding."],[5484,5622,"We should celebrate."],[5622,5726,"It's too early to"],[5726,5864,"start talking about all that."],[6056,6197,"No matter what happens,"],[6398,6523,"I'm going to do whatever I can"],[6523,6648,"to take care of both of them."]],"16":[[863,955,"The baby is fine."],[955,1084,"I moved him to get better care."],[1084,1217,"You don't have to worry, okay?"],[1351,1480,"Where's my baby?"],[1914,2018,"No, no, no..."],[2056,2189,"Just because you're rich doesn't mean"],[2189,2273,"you can steal my baby"],[2273,2406,"away from me, okay?"],[2406,2573,"No one's trying to take your baby."],[2573,2631,"I told you."],[2631,2806,"I moved him to get better care."],[2986,3057,"Really?"],[3140,3324,"Yeah, of course."],[3324,3436,"I promise."],[4016,4179,"Don't worry, Mrs. Vaughn."],[4179,4350,"Your husband has been taking"],[4350,4612,"great care of your little one."],[5113,5338,"Oh, he's not my husband..."],[5480,5676,"But I am the baby's father."],[6131,6218,"I'm really sorry."],[6218,6414,"I didn't mean to accuse you."],[6414,6598,"You don't have to apologize."],[6690,6819,"You've been through a lot."],[7223,7386,"Thank you."],[7386,7457,"And..."],[7515,7615,"you know I can pay you back"],[7615,7803,"for the medical bills whenever I can..."],[7803,7941,"I don't want your money."],[8141,8341,"Eight months ago, you saved me."],[8475,8566,"And I've been looking for you"],[8566,8662,"ever since."],[8787,8900,"You've been looking for me?"]],"17":[[8,125,"You've been looking for me?"],[617,817,"Remember this watch?"],[817,1009,"Please, just take my watch."],[1009,1134,"It's the most valuable thing"],[1134,1180,"that I have."],[1180,1255,"Please..."],[1255,1376,"please just take it."],[1651,1726,"I gave it to you"],[1726,1889,"the night that we met."],[1889,1993,"It wasn't for this watch,"],[1993,2173,"I might've never found you."],[2173,2264,"How did you get that?"],[2264,2314,"I gave it to"],[2314,2494,"some old lady days ago."],[2494,2702,"That old lady is my grandma."],[3182,3328,"Lila, I've given this a lot thought,"],[3328,3420,"and I want both of you"],[3420,3541,"to move in with me."],[3620,3687,"What? No, no..."],[3687,3791,"We barely even know each other,"],[3791,3912,"I can't just move in with you."],[3912,3987,"Why not?"],[4020,4149,"You just had my child"],[4149,4383,"and I want to raise our son together."],[4600,4713,"Besides, you're in a bit of"],[4713,4879,"situation right now, aren't you?"],[5046,5134,"Move in with me."],[5134,5305,"It's the easiest, safest way"],[5305,5476,"that I can take care of both of you."],[5547,5680,"He has a point."],[5768,5955,"It's the best thing for the baby."]],"18":[[408,567,"Welcome home, Mr. Vaughn."],[1222,1305,"Wow."],[1534,1647,"This has been our family home"],[1647,1751,"for generations."],[1789,2027,"Yeah, all of this is for you."],[2206,2335,"Oh, no, no, no..."],[2335,2427,"that's... that's..."],[2427,2527,"too much... - Nonsense."],[2527,2706,"There's no such thing, dear."],[2790,2940,"And this is just the beginning."],[2940,3061,"You're family now,"],[3061,3236,"and we take care of our own."],[3236,3303,"We also got you"],[3303,3395,"set up in a guest room"],[3395,3478,"and we built a nursery."],[3478,3586,"You want to come and check it out?"],[3749,3837,"Thank you."],[4024,4141,"Thanks."],[4266,4433,"They already have a baby together,"],[4433,4596,"and yet they play coy."],[4596,4713,"I'm going to have to fix that"],[4713,4775,"and get these two"],[4775,4929,"a little closer together."],[5972,6068,"They really look like"],[6068,6268,"a happy father and son."],[6352,6610,"God, it makes my heart just melt."],[6931,7032,"Damn..."],[7090,7182,"she's..."],[7282,7369,"incredible."]],"19":[[754,942,"It's okay baby, mommy's here."],[942,1084,"Don't cry."],[1267,1451,"So what's wrong with him?"],[1451,1659,"He's probably just hungry."],[1680,1789,"He needs to be fed."],[2948,3078,"What do you know?"],[3078,3140,"Looks like they're going"],[3140,3228,"to be spending the evening"],[3228,3424,"all cuddled up in there after all!"],[3999,4133,"Oh... umm..."],[4133,4287,"Yeah, I'll leave."],[5689,5860,"I'll just..."],[5860,6031,"turn around and..."],[6031,6139,"Okay!"],[6139,6206,"I'm all done,"],[6206,6352,"you can turn around now."],[6352,6452,"Okay."],[6677,6856,"Oh! Umm..."],[7248,7328,"Okay..."],[7607,7665,"You good?"],[7937,8095,"Yeah, sorry..."],[8270,8383,"Turning around."],[8600,8696,"I'm sorry."],[9017,9221,"I guess you're stuck with me tonight."]],"20":[[175,337,"Are... are... are we..."],[337,442,"Oh no, no, no..."],[442,533,"I'm going to..."],[533,663,"umm... take the couch."],[746,821,"Okay."],[855,938,"Cool."],[1338,1438,"Lila..."],[1597,1722,"Alexander?"],[2277,2439,"Are you having a sexy dream"],[2439,2531,"about me?"],[2902,3003,"What?"],[4383,4550,"Cause I was having a sexy dream"],[4550,4654,"about you."],[6252,6306,"Lila..."]],"21":[[1347,1493,"It's just a dream."],[1835,1939,"Hey."],[2027,2206,"Good morning."],[2610,2806,"We need to start the day."],[3261,3340,"You want to come and hang out"],[3340,3432,"with daddy?"],[3470,3557,"Yeah, we don't want to wake up"],[3557,3649,"mommy, huh?"],[3695,3774,"Okay."],[5080,5255,"Where's my baby?"],[5255,5338,"Where is he?"],[6293,6410,"Morning, sunshine."],[6835,6952,"I brought the baby out here"],[6952,7102,"cause I didn't want him to wake you."],[7102,7273,"You two seem like you're having fun."],[7273,7361,"Yeah, we are."],[7361,7465,"Right, little buddy?"],[7665,7753,"You want to try a cookie?"],[7807,8024,"Oh, you need an official taste-tester."],[8083,8179,"Yeah."],[8283,8416,"I'm going to tell you, though."],[8416,8587,"It's a big responsibility."],[8587,8721,"Can we trust you?"],[8721,8829,"Yes, fully."],[8829,9092,"I am a cookie expert actually."],[10035,10101,"So?"],[10210,10326,"How's the cookie?"],[10326,10477,"It's delicious."],[10706,10910,"You got a little something?"],[10910,11094,"Oh, yeah."],[11094,11161,"I got it."]],"22":[[642,842,"Oh, yeah..."],[950,1126,"Okay, baby, daddy has to work."],[1126,1197,"Come on."],[1230,1343,"Oh, I know."],[1447,1547,"Yeah."],[1981,2060,"Hey, Hatt."],[2089,2147,"Morning."],[2147,2248,"No ring today?"],[2248,2277,"Yeah."],[2277,2348,"I took today off."],[2348,2531,"I’m staying at home to take care of"],[2531,2627,"Lila and the baby."],[2627,2686,"Good."],[2686,2798,"I'm glad to hear it."],[2798,2994,"You need a life outside of hockey."],[2994,3157,"And don't let me keep you."],[3157,3240,"Yeah."],[3895,3987,"Need some help?"],[4054,4170,"Yeah, of course."],[4387,4471,"Be careful."],[4471,4667,"He's a little bit of a troublemaker."],[4667,4775,"Oh, yeah?"],[5025,5084,"Here."],[5380,5455,"Let’s drink it."],[5522,5584,"Look at that."],[5584,5689,"You're a natural."],[5960,6056,"Oh."],[6214,6297,"Sorry."],[6297,6368,"No no no no."],[6368,6439,"It's okay."],[6915,7115,"Oh, for your shirt..."],[7549,7628,"Okay."],[8187,8274,"Alex..."],[8516,8616,"Oh."],[8779,8896,"Careful."],[8896,8988,"We're going to get ourselves"],[8988,9096,"into some trouble."],[9367,9567,"I think I can handle some trouble."],[9626,9713,"Oh, yeah?"],[10610,10702,"You have no idea"],[10702,10835,"how long I've been waiting for this."]],"23":[[1247,1343,"Oh."],[1463,1559,"Looks like my timing"],[1559,1664,"could have been better."],[1760,1914,"Good morning, grandma."],[1943,2077,"Good morning, Taylor."],[2135,2285,"It wasn't important."],[2285,2485,"Don't stop on my account."],[2498,2627,"We'll get out of your hair."],[2715,2915,"Looks like my little plan is working."],[2969,3144,"Things are moving fast."],[3636,3687,"Don't."],[4141,4208,"Fuck!"],[4279,4429,"That tramp is nothing"],[4429,4533,"but a cripple."],[4571,4646,"What did Mr. Vaughn"],[4646,4767,"even see in her anyway?"],[4813,4921,"She has his baby,"],[4921,5042,"and shoots straight to the top"],[5063,5180,"while I'm stuck here cleaning"],[5180,5259,"after her!"],[5718,5814,"Look at me."],[5972,6172,"I am way hotter than that bitch."],[6260,6348,"I’ll make Mr. Vaughn"],[6348,6435,"fall for me."],[6560,6756,"One way or another."]],"24":[[2198,2293,"Alex."],[2335,2402,"Sarah?"],[2464,2606,"What the hell are you doing in here?"],[2640,2736,"I like you."],[2811,2919,"I want you."],[3057,3203,"I'm all yours."],[3361,3578,"Hey, you need to leave now."],[3603,3749,"I know you asked Lila to move in"],[3749,3899,"because she gave you a baby."],[3899,4083,"She's nothing but a cripple."],[4245,4421,"You can do better."],[4525,4646,"Okay, that is enough."],[4646,4679,"All right."],[4679,4879,"Don't talk about Lila like that."],[4888,5034,"I'm only telling the truth."],[5109,5267,"I can give you what you need."],[5334,5534,"Whatever you want."],[5634,5772,"Just say the word…"],[6260,6431,"What’s... going on here?"]],"25":[[25,120,"What's going on here?"],[120,246,"Oh, uh."],[246,321,"Mr. Vaughn and I"],[321,479,"are just having some fun."],[554,650,"Okay. I'm..."],[750,800,"sorry."],[800,921,"No, no, no, that's not"],[921,1042,"what's going on at all."],[1042,1142,"She came into the bathroom"],[1142,1197,"out of nowhere"],[1197,1330,"and started hitting on me."],[1551,1676,"You trust me, right?"],[1830,1906,"Of course."],[2139,2206,"Pack your things"],[2206,2348,"and get out of my house."],[2348,2448,"You're fired."],[2448,2531,"What?"],[2569,2644,"No!"],[2644,2844,"Please don't fire me."],[2936,3136,"I need this job."],[3253,3353,"I swear"],[3353,3516,"it'll never happen again."]],"26":[[525,646,"Alexander, I think you should"],[646,771,"really give her another chance."],[771,838,"I mean, she said"],[838,967,"she's never going to do it again."],[1330,1413,"You got a good heart,"],[1413,1501,"you know that?"],[1676,1768,"If anything like this"],[1768,1856,"ever happens again,"],[1856,1897,"you're done."],[1897,1976,"You hear me?"],[1993,2081,"Yes, yes."],[2081,2323,"Please, just don't fire me."],[2348,2460,"Okay, now get out."],[2489,2560,"Thank you."],[3653,3762,"Damn Lila!"],[3820,3995,"If you hadn't come in, he'd be mine."],[4074,4225,"This is all your fault."]],"27":[[796,909,"Hey, have any of you guys"],[909,1009,"seen his pacifier?"],[1009,1130,"I haven't been able to find it"],[1130,1197,"anywhere."],[1197,1259,"Sorry."],[1259,1351,"We're busy."],[1351,1463,"Maybe try keeping an eye"],[1463,1559,"on your belongings."],[1580,1697,"No. Shhh."],[1764,1885,"Don’t cry sweetheart."],[1885,2002,"Mommy’s going to find your binky,"],[2002,2068,"okay?"],[2952,2986,"Okay."],[2986,3123,"Please, could you help me look?"],[3199,3244,"It's just"],[3244,3353,"he is really attached to it,"],[3353,3516,"and I can't get him to stop crying."],[3553,3724,"Are you deaf or what?"],[3745,3924,"I said we're busy."],[4041,4204,"If something is that important to you,"],[4204,4287,"maybe you should have kept"],[4287,4396,"a closer eye on it."],[4533,4671,"What kind of mother does"],[4671,4754,"that make you?"],[4896,4992,"You are really"],[4992,5134,"pushing your luck, Sarah."],[5326,5409,"Mrs. Cobb?"],[5501,5580,"Is that it?"],[5939,5993,"Yes."],[5993,6101,"Thank you so much."],[6289,6414,"Well, get out of my way!"],[7615,7741,"No!"]],"28":[[809,975,"Oops, sorry."],[975,1071,"Are you out of your mind?"],[1071,1167,"You could have hurt him."],[1192,1334,"Watch your attitude."],[1480,1634,"I work for Mr. Vaughn."],[1634,1780,"Not you."],[1943,2102,"He's Alexander’s son."],[2260,2356,"Oh, I get it now."],[2485,2631,"You stole his pacifier,"],[2631,2694,"didn't you?"],[2898,2977,"First you were trying to"],[2977,3011,"seduce him,"],[3011,3211,"and then you put his son at risk?"],[3219,3253,"You know what?"],[3253,3328,"You're sick."],[3457,3557,"Please."],[3557,3616,"Who even knows"],[3616,3799,"if that baby's actually his?"],[3799,3945,"You're just a useless cripple."],[3945,4074,"You probably got knocked up"],[4074,4183,"by some random guy"],[4183,4371,"just so you can pin it on Mr. Vaughn."],[4396,4521,"How dare you?"],[4579,4725,"Everything I said is true."],[4771,4879,"Look at you."],[4879,5080,"A useless cripple."],[5080,5130,"If Mr. Vaughn"],[5130,5292,"didn't take such pity on you."],[5292,5401,"You and your little brat"],[5401,5476,"would still be out there"],[5476,5601,"looking like hobos."],[5809,5905,"You bitch!"],[6006,6118,"How dare you hit me?"]],"29":[[442,592,"What the hell is going on in here?"],[592,654,"Mr. Vaughn."],[775,896,"It's not what it looks like."],[1013,1084,"It's her."],[1138,1259,"She's a terrible mother."],[1309,1443,"She lost her son's pacifier"],[1443,1564,"and tried to blame me!"],[1597,1685,"That's a lie."],[1830,1947,"She stole his pacifier,"],[1947,2106,"and she almost hurt him, Alex."],[2143,2214,"I know."],[2727,2827,"Jane, call security"],[2827,2919,"and have her escorted"],[2919,3119,"from the premises immediately."],[3199,3382,"No, Mr. Vaughn."],[3382,3495,"I'm sorry."],[3495,3753,"I swear it will not happen again."],[3782,3870,"It's too late."],[3903,4045,"Lila gave you a second chance,"],[4045,4179,"and you threw it in her face."],[4287,4408,"No, no."],[4408,4542,"Let me go!"],[4542,4683,"Mr. Vaughn, Lila, please!"],[4683,4796,"I'm sorry!"],[5025,5100,"You okay?"],[5163,5192,"Yeah."],[5192,5259,"We're okay."],[5755,6010,"Lila is the mother of my child."],[6064,6181,"And the lady of this house."],[6181,6356,"And she will be treated as such."],[6439,6564,"If she tells you to do something,"],[6564,6635,"you do it."],[6635,6731,"And if you don't like that,"],[6731,6902,"pack your things and leave right now."],[7282,7344,"I got you."],[7444,7620,"He's such a fierce defender."],[7661,7824,"Is that only because of our son?"]],"30":[[1101,1230,"He looks so much like you."],[1230,1347,"It's crazy."],[1347,1488,"He looks like us."],[1488,1601,"Any thoughts on the name?"],[1672,1730,"Dynamite?"],[1760,1851,"Dynamite?"],[2114,2202,"Okay, no."],[2256,2398,"Alfi, no."],[3165,3332,"Oh, okay."],[3591,3741,"Long day for mama, huh?"],[3770,3908,"Yeah, you can say that."],[3953,4099,"Okay, well,"],[4099,4229,"I know how to help you unwind."],[4379,4471,"Oh, no, that..."],[4471,4583,"Okay, okay, okay."],[4583,4654,"Just relax."],[4654,4742,"I got you."],[5125,5188,"You okay?"],[5288,5334,"You let me know"],[5334,5484,"if the pressure is too much, alright?"],[5563,5634,"Okay."],[7524,7674,"Your skin is so soft."],[8350,8541,"I want you so bad, Lila."],[8954,9067,"Tell me you feel it."],[9801,9989,"I want you so bad, Lila."]],"31":[[529,646,"What if he's only doing this"],[646,796,"because I gave him a baby?"],[855,1030,"Maybe Sarah was right."],[1030,1142,"Men like him..."],[1142,1343,"could never love someone as..."],[1343,1488,"as broken as me."],[1872,2018,"Did I do something wrong?"],[2056,2218,"Why'd she pull away from me?"],[2369,2452,"Sorry."],[2515,2644,"Thank you for everything."],[2673,2756,"You know, if you hadn't"],[2756,2848,"come in there,"],[2848,2886,"I don't know"],[2886,2965,"what could have happened to me"],[2965,3048,"and the baby."],[3520,3591,"Lila,"],[3674,3749,"I will always"],[3749,3887,"protect you and our son."],[3978,4062,"Always."],[4287,4391,"Yeah, I guess I'm just..."],[4491,4646,"not really used to that."],[4708,4779,"In my whole life,"],[4779,4863,"I've never really had"],[4863,5009,"anybody to count on."],[5092,5238,"You know, my parents,"],[5238,5363,"they died in a car crash"],[5363,5438,"when I was little."],[5513,5622,"And then my aunt a