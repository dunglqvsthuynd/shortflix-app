ything wrong,"],[1034,1105,"Mom."],[1847,1989,"You like her, don't you?"],[2072,2335,"That manipulative little whore."],[2398,2623,"She went after both of my babies."],[2740,2869,"Ms. Vance is fine"],[2869,2990,"and so is the baby."],[2990,3107,"At six months, babies"],[3107,3240,"are fairly strong."],[3240,3332,"Six months."],[3770,3862,"Kaitlin and I broke up"],[3862,3937,"eight months ago."],[4758,4842,"Frank."],[4929,5021,"I need you to investigate"],[5021,5096,"something for me."]],"56":[[0,62,"Really?"],[404,475,"Oh!"],[521,596,"Good work."],[1067,1230,"The doctor said that you're fine."],[1338,1430,"Stop faking it!"],[1551,1593,"Kaitlin,"],[1718,1805,"it's over between us."],[1947,1997,"Wait."],[2156,2223,"Fine."],[2356,2565,"Can you just do me one last favor?"],[2652,2786,"Will you take me to dinner"],[2786,2902,"at that place where we went"],[2902,2990,"on our first date?"],[3086,3178,"For the baby's sake?"],[4325,4462,"I like coming to this place when"],[4462,4546,"I'm feeling down."],[4604,4746,"The view usually cheers me up."],[4817,4963,"Thanks for helping me back there"],[4992,5088,"and keeping me company."],[5088,5213,"You didn't have to..."],[5259,5342,"I wanted to."],[5455,5513,"Harper."],[5547,5722,"If you'd give me a chance."],[5722,5943,"I'd like to take care of you and the baby."],[6076,6227,"I’d do my best to be a better father"],[6227,6277,"than Will."],[6352,6410,"What?"],[6460,6510,"But I'm..."],[6510,6785,"I’m pregnant with your brother's baby."],[6994,7098,"I'm not joking."],[7219,7336,"I’d treat her as my own."],[7336,7465,"What the hell do you think you're doing?"],[7494,7728,"Oh, are you two on a date?"],[7728,7857,"Maybe we should join them?"],[8458,8562,"What are you doing with my brother,"],[8562,8600,"Aaron?"],[8737,8917,"What are you doing with your ex-fiancée?"],[8967,9125,"She's recovered, and we're having a talk."],[9125,9234,"It's not like we're having a date."],[9280,9426,"I have to say, Harper."],[9426,9609,"I didn't think you had it in you,"],[9609,9897,"dating your baby daddy's brother."],[10018,10193,"Pathetic move, if you ask me."],[10256,10414,"I was the one who asked her out."],[10518,10689,"Any man that breaks her heart is a fool."],[10760,10910,"She's a wonderful woman and deserves"],[10910,11040,"to be treated as such."],[11177,11286,"When I date someone,"],[11369,11469,"I want there to be no doubt"],[11469,11624,"about my feelings for her."],[11669,11820,"Or have another woman's arms"],[11820,11911,"wrapped around mine."],[11916,12007,"Do I need to remind you"],[12007,12153,"that she's carrying my child?"],[12245,12404,"Take your hands off of her right now."],[12533,12691,"I know, I also know you got another"],[12691,12800,"woman knocked up."],[13346,13542,"Stop doing shit just to piss me off!"],[13542,13684,"This isn't about you!"],[13692,13822,"I'm willing to fight for Harper,"],[13822,13893,"and you're just letting her"],[13893,13963,"slip away!"],[13963,14139,"Enough, both of you!"],[14139,14285,"I'm out of here!"],[14435,14527,"Harper, wait!"]],"57":[[141,212,"Harper, wait!"],[221,266,"Harper!"],[333,442,"Hey! Where are you going?"],[496,583,"Harper, please."],[608,696,"Hey! Listen to me."],[696,729,"Harper!"],[796,900,"You have to believe me."],[1005,1113,"Kaitlin and I are over."],[1113,1280,"I was just worried about her baby."],[1305,1426,"You don't get it, Will."],[1426,1576,"You two have a history together."],[1576,1676,"I mean, God, you were..."],[1676,1801,"You were almost married."],[1801,1901,"Listen to me, Harper."],[2039,2173,"I don't want Kaitlin."],[2193,2314,"It's you that I want!"],[2314,2410,"You and our daughter."],[2444,2598,"That's all that's important to me."],[2873,3053,"Tell me about your plan, Will."],[3053,3211,"I... I need a plan."],[3211,3353,"What about Kaitlin's baby?"],[3516,3611,"I don't have a plan yet."],[3611,3703,"Because there's some things"],[3703,3812,"I still need to figure out."],[3858,4070,"But once I do, I promise you"],[4091,4191,"I will have a plan."],[4396,4554,"I can't do this."],[4717,4875,"I need to stay at a hotel for now"],[4875,4971,"to clear my head."],[5109,5201,"This is about Aaron."],[5363,5463,"Do you have feelings for him?"],[5513,5689,"Is that really what you think of me?"],[6222,6281,"No. It's not."],[6281,6343,"Harper."],[6481,6639,"Hey, this doesn't concern you, man!"],[6660,6835,"You need to stay the hell away from us!"],[6881,7007,"She doesn't want to see you."],[7115,7248,"You're the one who should stay away."],[7369,7524,"Go back to your fiancée, William."],[7607,7691,"Harper has me."],[8233,8383,"Harper Jenkins."],[8383,8604,"I underestimated you."],[8637,8825,"Will Trenton is mine."],[8825,9021,"I won't let you get in my way."]],"58":[[237,321,"Grandpa."],[321,446,"Now that we've settled"],[446,638,"who is the Trenton heir."],[667,754,"When are we going to make"],[754,875,"the official announcement?"],[900,996,"I'll arrange it."],[1084,1263,"And we need to set a date"],[1263,1330,"for the wedding."],[1463,1539,"Will!"],[2018,2202,"When are you going to marry Kaitlin?"],[2202,2394,"You ask like I even care."],[3674,3799,"Mr. Trenton."],[3799,3899,"Talk to me, Frank."],[3899,4141,"Sir, I got the DNA results back."],[4179,4325,"I sent it into your email."],[5876,6110,"Come to the mansion this Friday, please."],[6131,6214,"I love you."],[6239,6314,"Trust me."],[6331,6385,"Will."],[6744,6981,"Our sources say that the Trenton family"],[6981,7077,"is going to make a big announcement"],[7077,7132,"today?"],[7165,7315,"I heard they've decided on their heir."]],"59":[[400,700,"Why are so many people here today?"],[1176,1317,"Today, the Trenton family has some"],[1317,1447,"big announcements to make."],[1609,1814,"Kaitlin, can you come please"],[1814,1889,"stand up next to me?"],[2043,2298,"Hi, I'm Kaitlin Vance."],[2298,2556,"And yes, we do have a big announcement"],[2556,2677,"to make today."],[2698,2998,"My son will be the Trenton heir!"],[3545,3699,"Then who is the girl that Mr. Trenton"],[3699,3791,"was holding hands with?"],[3883,4012,"Ms. Vance, uh when will you"],[4012,4149,"become Mrs. Trenton?"],[4149,4333,"When, when’s the wedding?"],[4333,4662,"She is just a surrogate."],[4700,4913,"And as for the second question,"],[4913,5134,"I will leave that to Will."],[5196,5372,"Will, when's our wedding?"],[5568,5772,"There is no wedding between us."]],"60":[[16,87,"William!"],[162,296,"You stubborn child!"],[296,454,"What are you talking about?"],[483,571,"What do you mean?"],[571,700,"You agreed to the wedding."],[700,863,"I don't want anything to do with you."],[1005,1230,"Because the love of my life is Harper."],[1960,2089,"This is my girlfriend,"],[2177,2394,"and she is carrying my only child."],[2531,2673,"Are you crazy?"],[2702,2877,"My baby is your firstborn."],[2894,3040,"My son is the Trenton heir!"],[3040,3148,"He's not even my child."],[3282,3499,"Harper is carrying my firstborn."],[3499,3649,"The true Trenton heir!"],[3770,3949,"This is your child!"],[3949,4120,"There is nobody else!"],[4183,4229,"Really?"],[4329,4508,"Tell me, why did you run out"],[4508,4596,"on our wedding?"],[4633,4708,"Cold feet?"],[4896,5017,"Or was your other boyfriend"],[5017,5159,"threatening to make a scene?"],[5413,5618,"Um... I have no idea what you're"],[5618,5684,"talking about."],[5684,5918,"There is no such other person."],[6047,6306,"Then who is he?"]],"61":[[0,70,"Kitty?"],[120,225,"Where have you been?"],[279,371,"How's my son?"],[392,504,"I... I..."],[504,696,"I have no idea"],[696,809,"who that is."],[842,925,"But Kaitlin..."],[925,992,"Shut up!"],[1051,1251,"That child that you're carrying is his,"],[1276,1351,"not mine!"],[1351,1626,"No, no, no, no, no, that is not true!"],[1626,1818,"I have no idea who this person is."],[1818,2018,"I have never seen him before in my life."],[2047,2227,"This is your baby."],[2252,2381,"How can you say that, Kitty?"],[2381,2494,"He's my son!"],[2506,2669,"You can't prove it!"],[2669,2852,"So stop lying to everybody."],[2877,3057,"I have never seen him before in my life."],[3148,3328,"As a matter of fact, I can."],[3407,3578,"This is a paternity test"],[3611,3757,"from Trenton Memorial Hospital."],[3782,4045,"It proves that Kaitlin is having my baby!"],[4517,4658,"You've been lying to everybody"],[4658,4763,"this entire time."],[4817,4992,"This baby has nothing"],[4992,5105,"to do with me!"],[5105,5251,"No, no, no, no, no."],[5251,5388,"You faked that test!"],[5409,5543,"Oh, sweetheart,"],[5630,5776,"they're going to find out eventually."],[5826,5930,"Just admit it."],[5960,6156,"You think you can fool everyone"],[6156,6331,"with a fake Trenton heir?"],[6827,6965,"It's over now, Harper."],[7077,7286,"Nothing and no one will ever"],[7286,7407,"get between us again,"],[7453,7524,"I promise."],[7590,7782,"I'll protect you for the rest of my days."]],"62":[[250,275,"Grandpa."],[291,342,"Calm down."],[417,462,"Take a breath."],[529,575,"You!"],[633,754,"You get out of this city."],[796,917,"And don't you ever even think"],[917,996,"coming back here."],[1034,1205,"And if you can't figure out how"],[1205,1368,"then the Trenton Group"],[1368,1501,"will bury your family"],[1501,1568,"for good!"],[1951,2118,"Hey! Baby, wait for me!"],[2510,2635,"Uh, Ms. Jenkins."],[2702,2873,"I'm sorry for what I said at my-"],[2873,2952,"my birthday."],[3069,3249,"I'm sorry too Ms. Jenkins."],[3286,3520,"And, uh, if you would allow me."],[3687,3883,"I'd like to give my blessing"],[3883,3999,"to this union."],[4179,4237,"It's okay."],[4237,4454,"I know it's because you care about Will."],[4550,4754,"Please, call me Harper."],[4896,4938,"Harper."],[5201,5451,"I'm so sorry for everything."],[5563,5755,"I promise you, I won't let anyone hurt you"],[5755,5814,"ever again."]],"63":[[145,241,"I love you, Harper."],[387,496,"It's always been you."],[663,809,"And I'm so sorry if I ever made"],[809,905,"you think otherwise."],[967,1071,"Will, I..."],[1088,1180,"Harper Jenkins,"],[1343,1480,"will you make me the happiest man"],[1480,1522,"alive?"],[1897,2193,"Yes! A thousand times, yes!"],[5125,5280,"One more push, mama!"],[5330,5413,"You’ve got it!"],[5492,5580,"She’s coming!"],[6460,6514,"How is she?"],[6514,6573,"Is she okay?"]],"64":[[0,75,"She's fine."],[116,229,"Both mother and baby are doing"],[229,291,"perfectly well."],[479,542,"Who's the father?"],[558,721,"I am. I'm the father."],[1201,1284,"I’m the..."],[1313,1368,"uncle."],[2448,2544,"Hi, baby girl."],[2594,2748,"She looks just like you."],[2998,3103,"Congratulations."],[3278,3365,"I'll see you guys around."],[3595,3649,"Aaron."],[3795,3862,"Thank you."],[3941,3974,"Yeah."],[4083,4175,"Anything for her."],[4304,4408,"I'm glad you're both happy."],[4525,4567,"We are."],[4679,4833,"Thank you, Aaron."],[5776,5997,"So, Mrs. Trenton."],[6151,6297,"What should we name our baby girl?"]]}