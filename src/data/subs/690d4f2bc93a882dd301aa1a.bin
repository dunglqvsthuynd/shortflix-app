{"1":[[387,454,"The first test"],[454,633,"at Luperiom War College is simple,"],[675,742,"survive."],[800,867,"Get to the gates"],[867,1009,"before the wolves get to you first."],[1493,1601,"Cadets train their whole lives"],[1601,1697,"for this moment."],[1755,1989,"Combat, endurance, strength."],[2022,2189,"And still less than half survive."],[2218,2373,"I was never meant to be here."],[2394,2544,"I don't even have my wolf."],[2556,2740,"I was supposed to be a healer."],[2790,2911,"But after the rebellion,"],[2940,3065,"everything changed."],[3282,3386,"Mom, please."],[3403,3490,"I can't lose you."],[3532,3607,"Enough, daughter."],[3695,3762,"She's gone."],[3845,3958,"Don't cry for your mother."],[3999,4083,"Avenge her."],[4191,4454,"Sear this betrayal into your bones."],[4512,4658,"The only good Blackmoor Wolf"],[4713,4821,"is a dead one."],[4859,5084,"Now my father, the Alpha King,"],[5134,5296,"has sent me here to earn my crown"],[5351,5501,"or die trying."],[5505,5626,"Well, well."],[5668,5784,"You don't belong here,"],[5851,5914,"healer."],[6085,6256,"I just wanna finish the trial."],[6481,6652,"This is the trial, bitch!"],[6827,6931,"If you can't survive us,"],[6931,7057,"you won't survive in there."],[7307,7440,"It's a kindness, really."],[7515,7749,"Ending you before the real pain begins."],[7882,7991,"Let go of me!"],[8037,8258,"Might as well put that tight body to use"],[8258,8375,"before you're dead!"],[11824,11945,"You don't get to touch her."],[12032,12153,"This is a hazing,"],[12241,12374,"not a rape, Cadet."],[12395,12504,"I, I'm sorry, Commander."],[12537,12583,"Please."],[13008,13092,"Not yet you're not."],[13521,13747,"You don't touch any woman"],[13767,13872,"at this college,"],[13913,14026,"or I will end you."],[14164,14293,"Now get this piece of shit"],[14318,14406,"out of my sight."],[16053,16161,"You, you killed him."],[16362,16408,"I did."]],"2":[[508,638,"You lost, beautiful?"],[754,892,"This isn't your part of the woods."],[1005,1146,"The Healer College is that way."],[1230,1326,"I'm not lost."],[1530,1672,"Still headed the wrong direction."],[1722,1893,"Maybe I'm right where I need to be."],[2243,2402,"You don't belong at the War College."],[2489,2602,"Let me walk you back to the gate."],[2686,2802,"There's more than one hunting party"],[2802,2902,"roaming these woods."],[2923,3015,"I thought the War College"],[3015,3203,"was supposed to be kill or be killed."],[3365,3449,"Consider it a warning."],[3595,3670,"Maybe I'm hoping to"],[3670,3778,"convince you to quit."],[4049,4124,"There is"],[4149,4241,"something about her."],[4366,4471,"His eyes."],[4496,4637,"Like, he knows me."],[4688,4900,"Why is my whole body reacting?"],[4975,5096,"I need to calm down."],[5376,5513,"The world needs more healers,"],[5559,5668,"not warriors."],[5834,5985,"You lost someone close to you."],[6114,6247,"I lost a lot of someones."],[6385,6448,"I'm sorry."],[6752,6865,"I know what it feels like."],[8717,8804,"Why are you staring?"],[8992,9104,"You know why."],[9930,10089,"I need you to do something for me."],[10206,10272,"Turn around"],[10414,10552,"and leave this cursed place."],[10760,10839,"When it's safe,"],[11090,11152,"I'll find you."],[11373,11490,"Safe, safe from what?"],[11661,11778,"Get away from the princess,"],[11778,11870,"Blackmoor scum."],[11936,11986,"Blackmoor?"],[12082,12153,"Princess?"],[12237,12345,"You're Maeve Thornevale,"],[12466,12579,"the Alpha King's daughter."],[12637,12829,"You, you're Saxon Blackmoor,"],[12829,12967,"son of the rebel leader?"],[13021,13171,"Your family killed my mother!"]],"3":[[0,104,"Your father slaughtered"],[104,241,"my entire bloodline!"],[279,387,"That's because they were traitors"],[387,479,"and went rogue."],[479,517,"You know what?"],[517,654,"You're lucky my father spared you"],[654,771,"because you were just a boy."],[850,905,"Lucky?"],[1013,1088,"Your father"],[1126,1380,"branded us like animals, Princess."],[1443,1501,"And you,"],[1605,1697,"I'll let you live,"],[1755,1968,"so you can see how lucky we are"],[1968,2106,"at the War College."],[2181,2327,"You're not gonna last a week."],[2327,2469,"I will make sure of it."],[2719,2836,"I'm not scared of you."],[2852,2961,"You will be."],[3340,3461,"Watch yourself, Blackmoor."],[3628,3791,"Fuck you, dog."],[4316,4454,"Looks like I got here just in time."],[4546,4621,"Rory Zion."],[4683,4808,"My childhood sweetheart."],[4850,4967,"He's never let me down."],[5050,5171,"Did that bastard attack you?"],[5246,5367,"No, he,"],[5572,5668,"he actually saved me."],[5797,5855,"What?"],[5930,6035,"That's not like Blackmoor."],[6101,6172,"He only protects his"],[6172,6264,"fellow Marked Ones."],[6548,6669,"I wish you didn't come here, Maeve."],[6723,6819,"It's too dangerous."],[6898,7073,"Rory, you know that every Alpha Heir"],[7073,7253,"has to graduate from the War College."],[7357,7482,"But you can't fight."],[7607,7711,"You can't even kill a bug!"],[7745,7828,"How the hell are you gonna"],[7828,7878,"stay alive in this?"],[7878,7978,"Because I want justice"],[7978,8049,"for my mother."],[8137,8237,"And I'm not leaving"],[8237,8350,"until Saxon Blackmoor"],[8350,8500,"pays for everything he's done."]],"4":[[1242,1355,"Give me my dorm assignment."],[1543,1639,"Strip first."],[1672,1780,"Burn your past."],[1810,1981,"You want me to undress here?"],[2189,2285,"A Healer?"],[2335,2473,"What's she gonna do, hug us to death?"],[2615,2790,"She won't last here a week."],[2827,3015,"Warriors are modest, Princess."],[3090,3178,"Maybe you should crawl back"],[3178,3349,"to the palace where you belong."],[3390,3520,"I'm not going anywhere."],[3641,3757,"Not while my mother's killer"],[3757,3866,"is still alive."],[6685,6773,"Room 16."],[6856,6990,"Training starts at 0500."],[7102,7244,"Cry, sleep,"],[7357,7415,"pray."],[7482,7595,"You're gonna need it."],[8641,8712,"Let's go, Maeve."],[9259,9330,"Hurry and change."],[9417,9496,"I'm getting you out of here and"],[9496,9622,"back to the Healers College."],[9705,9818,"You know I can't do that."],[9872,10001,"There's no going back for me now."],[10001,10143,"Maeve, listen to me."],[10185,10310,"Saxon's not just some rebel"],[10310,10431,"with a chip on his shoulder."],[10477,10556,"He's the strongest wolf"],[10556,10698,"this school's seen in a hundred years."],[10764,10831,"He's vicious."],[10960,11023,"He's dangerous."],[11198,11327,"He definitely wants to kill you."],[11765,11857,"Let him try."],[12032,12116,"I'm not afraid."],[12299,12420,"Run home, Princess,"],[12466,12575,"before I end you."],[12645,12771,"You wanna see me scared?"],[12816,12925,"Keep dreaming."]],"5":[[633,729,"They don't give you a room"],[729,850,"until you pass the Culling."],[942,1009,"Why bother,"],[1084,1205,"when half of the females here"],[1205,1272,"will be dead."],[1618,1730,"I had a simple plan,"],[1764,1835,"survive."],[1872,2002,"Whatever each day brings."],[2318,2502,"Just keep breathing."],[2502,2627,"Well, well."],[2656,2727,"Look who thought"],[2727,2998,"she could strut in and play Alpha."],[3032,3178,"I don't want any trouble."],[3349,3499,"Let me tell you what trouble is."],[3520,3624,"Your King Daddy"],[3624,3737,"didn't just kill our parents."],[3737,3899,"He wiped them from existence."],[3899,4008,"That's because they went rogue"],[4008,4141,"and tried to assassinate him."],[4637,4779,"He scarred us for life."],[4817,4909,"And asshole had the nerve"],[4909,5000,"to call it mercy."],[5042,5138,"It was mercy."],[5230,5380,"You're just too stupid to see it."],[6010,6181,"Right tibial plateau cracked."],[6360,6477,"Retina detached."],[6773,6927,"Third and fifth ribs fractured."],[7107,7169,"Oops."],[7228,7419,"Looks like I broke the Princess."],[7436,7545,"Don't think Saxon will think"],[7545,7636,"you're so pretty now,"],[7703,7778,"slut."],[8266,8445,"Being a healer wasn't just my calling."],[8483,8566,"It's my gift."],[8604,8767,"And right now, it's the only reason"],[8767,8863,"I'm still breathing."],[8992,9209,"Don't ever let your father see you cry."],[9292,9388,"Just remember."],[9438,9617,"You are stronger than you think."],[10043,10168,"It doesn't hurt anymore."],[10201,10281,"Look, Mom!"],[11298,11428,"My mother was the only one"],[11428,11590,"who knew about my healing power."],[11619,11740,"I never told my father."],[11807,11895,"He would have turned me"],[11895,11999,"into a weapon."],[12082,12241,"You're still you, darling."],[12324,12474,"Just more."],[12533,12658,"I love you, Mom."],[12800,12946,"I won't let you down."]],"6":[[396,604,"Did she cry or black out or both?"],[642,759,"Fuck, I wished I'd been there."],[788,917,"You told me that weak little Princess"],[917,1038,"is supposed to be the Alpha Heir?"],[1038,1167,"Entitled bitch had it coming."],[1868,2002,"What the hell did you do, Kaela?"],[2060,2193,"I took care of the problem,"],[2227,2348,"like a good Beta should."],[2389,2598,"So we all don't end up dead, Saxon."],[2640,2731,"You're welcome."],[4016,4066,"What the fuck?"],[4066,4229,"She couldn't stand an hour ago."],[4262,4429,"I guess she's tougher than she looks."],[5388,5476,"It's gonna take more than a"],[5476,5597,"pansy-ass beatdown"],[5597,5714,"to get rid of me, Blackmoor."],[5864,5914,"Next time,"],[5914,5993,"send someone who doesn't"],[5993,6085,"fight like a coward"],[6097,6206,"and gang up three on one."],[6285,6364,"Stand down, Kaela."],[6531,6681,"Stand the fuck down, Lieutenant."],[7269,7353,"I'll get you into my unit."],[7428,7511,"You'll be safe with me."],[7661,7770,"She's not yours to protect."],[7866,7957,"Like hell she isn't."],[8033,8241,"I outrank you, Captain Zion."],[8324,8487,"Cadet Thornevale is under my command."],[8521,8646,"You're fucking nuts, Blackmoor."],[8658,8775,"She's not going into your unit."],[9180,9238,"Follow me."],[9255,9421,"Or I'll slit your little boyfriend's"],[9421,9538,"throat while he sleeps."],[10097,10201,"Hey, it's okay, Rory."],[10201,10251,"I'll be fine."],[10297,10368,"Maeve, don't."],[10510,10573,"What are you doing?"],[11298,11365,"Good girl."]],"7":[[930,980,"Lieutenant Vire."],[1388,1488,"Cadet Thornevale."],[1714,1822,"Your turn, Princess."],[2494,2615,"Don't know how you're still standing."],[2952,3036,"Guess I'll just get to finish"],[3036,3111,"what I started."],[3194,3299,"I cheered when they found"],[3299,3386,"your mother's body."],[3420,3624,"Well, you found it, didn't you?"],[3682,3757,"We've been waiting for"],[3757,3883,"another Thornevale to bleed."],[3924,3999,"Just shut up."],[4120,4237,"You don't get to cheat this time."],[5814,5914,"Right knee misaligned."],[5968,6076,"Tibia deviation."],[6156,6260,"Old ACL tear?"],[6343,6431,"Weak spot."],[7132,7315,"No way she got Lieutenant Vire."],[7353,7424,"Lucky shot,"],[7507,7653,"doubt the princess can repeat it."],[7682,7836,"Every healer takes a vow."],[7903,8012,"Do no harm."],[8062,8179,"I've never broken mine."],[8233,8291,"Until now."],[8454,8608,"I, I'm sorry, here, let me fix it."],[8654,8754,"Here, let me help you."],[8762,8883,"Fuck you, smug bitch."],[9188,9242,"Enough!"],[11845,11936,"That's interesting."],[12095,12195,"It's just a scratch."],[12195,12324,"It's, it's fine."],[12458,12554,"Kaela doesn't miss."],[12787,12879,"Let's try something."],[13526,13601,"You're gonna fight me now."],[13722,13784,"What?"]],"8":[[45,108,"What?"],[200,329,"You're a unit Commander."],[329,400,"That's insane!"],[400,458,"And a senior."],[458,567,"That's not a fair fight."],[625,725,"Welcome to Luperiom."],[4996,5059,"Go on."],[5171,5217,"Kill me."],[5384,5513,"That's what you want, isn't it?"],[6006,6064,"What are you?"],[6227,6335,"You're hiding something."],[6510,6619,"And I'm gonna enjoy"],[6656,6769,"finding out what it is."],[7223,7332,"There's something wrong with me."],[7415,7632,"Saxon Blackmoor is my sworn enemy."],[7674,7782,"Your father slaughtered"],[7782,7916,"my entire bloodline!"],[7945,8033,"I hate him with"],[8033,8170,"everything inside me."],[8258,8391,"So why can't I stop thinking about"],[8391,8495,"the way he looked at me?"],[8537,8641,"Why do I still feel"],[8641,8758,"the heat of his touch?"],[8863,9004,"Tomorrow is the Culling."],[9063,9230,"I can't afford to be distracted."],[9305,9380,"I'll have to stand"],[9380,9513,"before the entire college,"],[9526,9592,"my father,"],[9626,9738,"and find my wolf."]],"9":[[725,888,"Today, we begin the Culling."],[938,1247,"The ancient rite of the bloodline."],[1297,1488,"Only those worthy"],[1530,1722,"will leave alive."],[1743,1843,"Your wolf"],[1897,2010,"is your soul,"],[2089,2198,"your power,"],[2252,2460,"your bond to this pack."],[2485,2577,"You will summon it"],[2660,2877,"or you will die."],[2952,3119,"No mercy shown."],[3182,3399,"The wolves will choose."],[3503,3778,"The rest will fall."],[3991,4079,"Begin!"],[4462,4546,"King's daughter"],[4562,4717,"still doesn't have her wolf."],[4717,4842,"Well, maybe she'll never get one."],[4929,5055,"She's no Alpha."],[5055,5196,"She'll never be wolf heir"],[5196,5321,"to the throne."],[5376,5422,"Get her!"],[6227,6322,"Pathetic."],[6706,6810,"She's so weak."],[7499,7565,"Finish her."],[7582,7716,"I'm gonna claw out your throat,"],[7782,8037,"you weak-ass bitch!"],[8091,8141,"If you're going to"],[8141,8254,"make an appearance, Wolf,"],[8312,8445,"now would be a good time."],[8521,8700,"You are stronger than you think."],[9684,9755,"The White Wolf?"],[9801,9884,"There hasn't been one in"],[9884,9993,"five hundred years."]],"10":[[700,775,"A White Wolf?"],[829,917,"That's impossible!"],[934,1013,"There hasn't been one in"],[1013,1121,"five hundred years."],[7152,7232,"Our wolves"],[7386,7494,"are fated mates."],[7632,7753,"That's, that's,"],[7866,7995,"that's not even possible."],[8245,8341,"Bound for life."],[8416,8529,"What does that even mean?"],[8658,8754,"If you die,"],[8888,8950,"I die."]],"11":[[1021,1176,"Our wolves may be bonded,"],[1205,1301,"but we aren't!"],[1388,1472,"We're enemies."],[1559,1672,"I shouldn't have saved you."],[1768,1897,"Would've been easier than this."],[2014,2097,"I hate you."],[2344,2456,"You can hate me later."],[3249,3365,"What is wrong with me?"],[3440,3561,"My blood is on fire."],[3582,3699,"I'm burning inside."],[3803,3924,"I have to fight this."],[3974,4054,"He's the enemy."],[4567,4646,"Go to hell!"],[5180,5326,"Already there, Princess."],[5459,5622,"So how would you find that?"],[5955,6122,"Did Maeve and Saxon..."],[7194,7390,"The Princess has a White Wolf."],[7390,7507,"There hasn't been one in over"],[7507,7620,"five hundred years."],[7686,7841,"Hail the Alpha Heir."],[7853,7928,"Maeve!"],[8008,8145,"Where did you go after the Culling?"],[8195,8304,"My wolf needed to run."],[8400,8491,"You chose Blackmoor"],[8491,8558,"to run with?"],[8758,8892,"Rory, please."]],"12":[[104,171,"Oh!"],[521,642,"Nice. - Nice."],[829,934,"Let's see you beat that."],[1163,1322,"You're drunk, Zion."],[1413,1484,"Fuck you."],[3136,3319,"Yeah!"],[3357,3511,"Let's go."],[3724,3895,"You lose, Captain Zion."],[3995,5030,"Dead meat!"],[5030,5113,"Wait, what's going on?"],[5213,5301,"Whoever loses"],[5301,5463,"becomes target practice."]],"13":[[934,1034,"Are you out of your mind?"],[1071,1121,"What?"],[1142,1230,"Afraid you'll miss?"],[1472,1609,"Chop, chop, Blackmoor."],[1797,1856,"What?"],[2139,2298,"Yeah!"],[2389,2485,"Yeah!"],[3107,3240,"Does he mean that much to you?"],[3357,3520,"Rory's someone I can trust."],[3920,4087,"You're either incredibly brave"],[4149,4304,"or incredibly stupid,"],[4350,4421,"mate."],[4521,4629,"Don't call me that."],[4817,4954,"I will never be your mate."]],"14":[[517,563,"Get up."],[763,842,"Get up!"],[1013,1121,"Get up!"],[1259,1313,"Stop!"],[1380,1476,"Please, stop!"],[2452,2540,"You can't outrun it."],[2715,2781,"We can't."],[2852,2948,"Whatever our wolves want,"],[2948,3094,"it changes nothing between us."],[3495,3549,"And yet,"],[3728,3799,"here we are."],[4016,4099,"Don't pretend"],[4179,4245,"you don't feel it."],[4466,4571,"I feel nothing."],[4871,4942,"Liar."],[5059,5180,"Look me in the eye"],[5259,5459,"and tell me you don't feel it."],[5634,5764,"I didn't choose this."],[5809,5905,"Neither did I."],[6085,6156,"Walk away."],[6264,6410,"After you, Princess."],[7011,7107,"Tell me to stop."],[7432,7494,"Say it."],[7632,7703,"Say stop."],[7978,8124,"Don't you dare stop."]],"15":[[550,684,"Don't cry for your mother."],[813,884,"Avenge her."],[942,1234,"Sear this betrayal into your bones."],[1330,1384,"No!"],[1522,1605,"You're a monster."],[1605,1659,"A traitor."],[1830,1960,"And you're a naive little princess,"],[1985,2139,"clinging to daddy's lies."],[2156,2285,"You're manipulating the bond."],[2364,2452,"Twisting it to try to"],[2452,2548,"get close enough to me to"],[2548,2677,"finish what your pack started."],[2694,2811,"You think I want this?"],[2857,2961,"That I choose you?"],[3011,3153,"You're no one to me."],[3190,3274,"Not a mate."],[3328,3386,"A curse!"],[3415,3495,"Then break it off."],[3620,3778,"Break the bond and free yourself."],[3803,3866,"Free us both."],[3962,4062,"There is no way out."],[4133,4195,"If I kill you,"],[4195,4400,"even if we don't seal the bond,"],[4421,4546,"my wolf will go feral"],[4546,4646,"over losing his mate."],[4646,4875,"I will spiral into madness."],[4934,5000,"No control."],[5071,5159,"No backing out."],[5196,5255,"What do you mean"],[5255,5342,"by seal the bond?"],[5430,5555,"You know what I mean."],[5697,5818,"The bond isn't set"],[5939,6122,"until we give in,"],[6443,6510,"body"],[6656,6735,"and soul."],[6923,7011,"Don't pretend"],[7061,7165,"you haven't felt it."],[7332,7494,"Claim what is yours."],[7707,7832,"You feel it now."],[8058,8166,"Get away from me."],[8224,8304,"Make me."],[8470,8554,"Claim him!"],[8787,8833,"No."],[9092,9138,"Not him."],[9246,9300,"Not the one"],[9300,9409,"I'm supposed to hate."],[9488,9617,"Not the one who destroyed"],[9638,9718,"everything."],[9772,9843,"Please."],[9922,10001,"He's ours."],[10068,10206,"You can't outrun fate."]],"16":[[404,483,"It's only been a week"],[483,588,"at the War College."],[642,796,"I survived the Culling,"],[825,925,"awakened a White Wolf"],[925,1096,"no one's seen in five hundred years,"],[1126,1251,"and found my fated mate"],[1251,1380,"is my worst enemy."],[1655,1764,"Attention, Cadets."],[1972,2077,"Blackmoor nearly burned this"],[2077,2185,"kingdom to the ground."],[2352,2402,"Who can tell me"],[2402,2506,"what triggered the Rebellion?"],[2606,2731,"Alpha Magnus Blackmoor"],[2744,2865,"accused King Elias"],[2894,3011,"of corrupting the sacred bond"],[3011,3123,"between Alpha and Wolf."],[3211,3311,"He claimed his Majesty"],[3311,3428,"forged a Dominion Link"],[3470,3616,"to steal a wolf's free will."],[3712,3824,"A traitorous lie,"],[3928,4033,"spread to justify"],[4033,4137,"Blackmoor's rebellion!"],[4312,4542,"My father is no fucking liar."],[4850,5030,"Your bastard father spat on the crown."],[5067,5163,"You don't even deserve to"],[5163,5280,"breathe the same air as we do."],[5376,5505,"But the High Council intervened,"],[5572,5689,"against the King's wishes."],[5872,6010,"And they spared children of traitors"],[6031,6085,"like you."],[6314,6431,"You want me dead, Zion?"],[6523,6610,"Challenge me then."],[6819,6865,"No."],[6940,7065,"That'd be too honest"],[7077,7228,"for our King's royal dog."],[7261,7332,"Hey, Rory!"],[7499,7582,"It's not worth it."],[7937,8049,"Children of traitors often"],[8049,8224,"become traitors themselves."],[8329,8462,"You were given a second chance"],[8462,8625,"to enroll here at Luperiom"],[8671,8833,"and prove your loyalty to the crown."],[8858,8983,"Is that what you think this is?"],[9059,9171,"A second chance?"],[9292,9371,"No Marked One"],[9371,9496,"has made it out of here yet."],[9622,9667,"What?"],[9667,9805,"No, that, that's not true."],[9897,9976,"Have you ever"],[10005,10130,"had an original thought,"],[10185,10356,"or does daddy feed you lines"],[10356,10535,"every morning before breakfast?"],[10668,10764,"It's so much nobler"],[10764,10927,"to slit throats in the dark, isn't it?"],[11019,11111,"That's your Pack style."],[11215,11336,"Tell me, Blackmoor, does it"],[11386,11511,"thrill you that my mother"],[11511,11624,"bled out in my arms?"]],"17":[[83,233,"Never reveal a weakness."],[300,396,"My father drilled that"],[396,533,"into my head growing up."],[550,721,"Now all the Marked Ones know mine."],[788,888,"Especially him."],[1059,1155,"You didn't think we'd let you"],[1155,1338,"get away after that little speech?"],[1426,1609,"Poor little Princess,"],[1609,1747,"grieving her dead mother."],[1776,1851,"Just leave me alone."],[1851,1956,"I don't wanna fight you."],[1976,2072,"Tough shit!"],[2118,2243,"You think hiding behind a White Wolf"],[2243,2344,"makes you untouchable?"],[2360,2431,"Power's worthless"],[2431,2573,"if you're too pathetic to wield it."],[2627,2756,"No wonder they kept you locked away."],[2873,2952,"Let me out."],[2994,3107,"I'll rip out her throat"],[3107,3269,"and wear her teeth as a necklace."],[3274,3319,"No!"],[3361,3461,"I'm a healer."],[3507,3624,"I made a vow to do no harm."],[3624,3745,"There must be another way."],[3812,3941,"She's trembling."],[3966,4070,"I thought White Wolves"],[4079,4258,"were supposed to be badasses."],[4270,4350,"Go on."],[4404,4487,"Let's see the monster."],[4537,4621,"Summon her."],[5159,5213,"I knew it."],[5246,5326,"You're scared"],[5351,5455,"of your own wolf."]],"18":[[4,100,"You're scared"],[108,216,"of your own wolf."],[308,400,"Pitiful."],[642,771,"Chosen by the White Wolf,"],[771,959,"but too scared to set her free."],[963,1042,"She should have chosen"],[1042,1142,"someone worthy."],[1167,1238,"Let me go."],[1272,1338,"Or what?"],[1401,1463,"You'll shift?"],[1589,1680,"Didn't think so."],[1739,1914,"Do something or I will."],[1931,1981,"No."],[2156,2227,"I know."],[2318,2402,"Pressure points."],[3094,3249,"What the fuck did you do?"],[3424,3545,"I overwhelmed her nervous system"],[3545,3632,"and shut it down."],[3732,3812,"What are you waiting for?"],[3820,3858,"Grab her!"],[3858,3924,"You grab her."],[3962,4058,"That shit's extra."],[4124,4166,"Fine."],[4337,4542,"Let's see how she feels being branded."],[4567,4704,"You're not the only one with power,"],[4704,4884,"you entitled bitch."],[4884,5030,"This is War College."],[5067,5263,"Here, weakness dies,"],[5342,5463,"or you do."],[5613,5684,"Kill her."],[5751,5876,"I will drag her soul"],[5876,6026,"screaming into the void."],[6051,6106,"No!"],[6352,6431,"Mark her"],[6477,6644,"and I'll show you what real power is."]],"19":[[29,104,"Mark her"],[125,291,"and I'll show you what real power is."],[471,575,"Since when do you care about the"],[575,667,"Alpha King's daughter?"],[667,792,"Stand down."],[934,1051,"She's mine to punish."],[1117,1297,"I have as much right to her as you do."],[1305,1426,"Our parents both died."],[1522,1801,"I said stand down."],[1835,1989,"That's an order, Lieutenant."],[2289,2335,"Good."],[2431,2498,"You can go."],[2681,2811,"This isn't over, Thornevale."],[3499,3570,"You didn't shift."],[3645,3691,"Why?"],[3766,3841,"Why do you care?"],[3908,4037,"Don't think that I like you."],[4154,4316,"I just don't want you dying so easy."],[4316,4429,"My mother was a healer."],[4546,4642,"I'm not gonna let this place"],[4642,4804,"destroy the last thing I have of her."],[5046,5201,"You're full of surprises, Princess."],[5442,5513,"Princess Maeve,"],[5580,5647,"there you are."],[5672,5776,"The King is waiting for you."],[5876,5955,"Come with me."],[6573,6639,"Focus."],[6706,6794,"Stay sharp."],[6894,6990,"Don't think about the way"],[6990,7073,"he looks at you."],[7248,7386,"Like you're already his."]],"20":[[429,479,"Father."],[504,900,"The White Wolf chose you."],[1076,1159,"Of course she did."],[1276,1472,"And how are you finding Luperiom?"],[1501,1647,"It's hard."],[1693,1914,"But I'm learning."],[1922,2060,"Do not fail me, Maeve."],[2260,2431,"You carry your mother's blood,"],[2448,2819,"but you must not carry her softness."],[2877,3073,"There's no peace with rogues."],[3073,3278,"No reasoning with them."],[3278,3474,"Only utter domination."],[3520,3611,"Just remember,"],[3649,3832,"you are stronger than you think."],[3866,3999,"I will be a worthy heir."],[4049,4421,"Saxon Blackmoor is a virus."],[4517,4683,"He charms."],[4683,4838,"He infects."],[4896,4992,"Do they know?"],[5013,5113,"About the bond?"],[5113,5259,"Stay close to Rory."],[5317,5397,"He's loyal."],[5430,5643,"He will keep you clean."],[5701,5876,"Saxon Blackmoor is not a concern."],[5876,5989,"At least he won't be for long."],[6193,6473,"You are my legacy, Maeve."],[6502,6685,"The last true thing"],[6685,6806,"I have in this world."],[6827,6923,"Don't waste"],[6990,7152,"what the White Wolf gave you."],[7152,7273,"I understand, father."],[7365,7453,"You're dismissed."],[7807,7866,"And daughter,"],[8053,8262,"I would burn down"],[8262,8554,"every kingdom on this continent"],[8554,8696,"to keep you safe."],[8762,8817,"So,"],[8979,9184,"don't make me wonder if I need to."]],"21":[[875,967,"What the hell?"],[1618,1697,"Get dressed."],[1735,1797,"We're training."],[1893,2010,"You could knock, you know."],[2010,2118,"You don't trust your wolf."],[2173,2314,"You don't know how to defend yourself."],[2318,2423,"The Rite is in days."],[2456,2635,"And it is savage."],[2677,2823,"If you don't know how to use your wolf,"],[2823,3015,"you will die and I will go feral."],[3186,3249,"Unless..."],[3511,3645,"you wanna seal the bond."],[3645,3816,"We will never seal the bond."],[3849,3895,"Why not?"],[4020,4129,"Afraid you might like it?"],[4137,4200,"Please."],[4304,4562,"I would rather die before I touch you."],[5184,5246,"Liar."],[5388,5538,"I can smell how much you want me."],[5714,5843,"You can't intimidate me."],[5897,6085,"I'm not a Beta like Kaela is."],[6126,6293,"I should slam the door in his face."],[6364,6498,"But if he trains me,"],[6564,6744,"maybe I'd survive and buy more time"],[6744,6898,"to figure out how to end this bond"],[6940,7111,"and get justice for my mother."],[7290,7344,"Fine."],[7457,7536,"One hour."],[7545,7628,"That's it."],[8229,8274,"Wear something"],[8274,8375,"you don't mind bleeding in."],[8508,8579,"Asshole."]],"22":[[425,546,"If you want to survive the Rite"],[546,671,"without killing anybody,"],[1076,1180,"then you need to become the"],[1180,1301,"best defensive fighter"],[1322,1451,"the War College has ever seen."],[1847,1947,"Cheap shot!"],[2081,2160,"But it worked."],[2965,3086,"Stop being a princess."],[3186,3294,"Let's see how your aim is."],[3595,3666,"Close your eyes."],[4425,4529,"Listen to your wolf."],[5063,5113,"Left!"],[5113,5171,"Now!"],[5780,5864,"Behind you!"],[7574,7862,"Not bad, Princess."],[7957,8087,"Looking like a wolf."],[8112,8179,"I'm sorry."],[8291,8412,"Here, I can clean it for you."],[8537,8608,"That's cute."],[8696,8863,"I've gotten bigger cuts shaving."],[8933,9009,"Your turn to hide."]],"23":[[988,1051,"Gotcha."],[1167,1238,"Focus."],[1322,1468,"The Rite will not care that"],[1468,1559,"you are a royal."],[1630,1735,"Listen to your wolf."],[2977,3073,"I should hate him."],[3115,3219,"Rip him apart."],[3282,3386,"But all I want"],[3461,3574,"is his kiss."],[3687,3782,"What are you waiting for?"],[4341,4471,"You might just survive the year,"],[4471,4512,"Princess."],[4512,4604,"Don't call me that."],[4738,4934,"Try not to dream of me tonight."],[5221,5330,"Arrogant bastard."]],"24":[[2156,2323,"What are you gonna do now, Princess?"],[2414,2565,"Let go of me!"],[2765,2886,"Ah, man!"],[3123,3261,"You're gonna pay for that, bitch."],[3374,3440,"Silver."],[3440,3595,"I can't shift with silver."],[3770,3832,"No, no, no, no."],[3832,3966,"I won't die like this."],[3966,4141,"I've survived too much."],[4487,4642,"Get your fucking hands off of her!"]],"25":[[33,191,"Get your fucking hands off of her!"],[308,387,"Oh, shit!"],[412,446,"Hey."],[504,596,"Hey, hey, hey, hey."],[638,729,"Are you hurt?"],[775,880,"They used silver."],[900,1017,"Fucking cowards."],[1067,1146,"You came for me."],[2344,2427,"Saxon."],[2435,2515,"Saxon, this is..."],[2648,2769,"He came for you."],[2798,2940,"He's ours."],[2957,3036,"Ours."],[3174,3236,"Shit."],[3324,3457,"No, wait, wait, wait!"],[3962,4120,"Maybe he'd been there all along,"],[4183,4333,"watching from the shadows."],[4458,4587,"And for the first time,"],[4625,4783,"I really wish he was still here."]],"26":[[216,291,"Are you alright?"],[379,454,"Who did this?"],[596,671,"Rogues."],[692,788,"Of course."],[821,950,"I don't recognize them."],[950,1096,"Blackmoor's dogs, no doubt."],[1142,1405,"Sent to finish what his pack started."],[1405,1551,"No, I don't think it was."],[1664,1918,"And how can you be so sure?"],[1956,2064,"Well, if Saxon,"],[2156,2323,"if, if Blackmoor wanted to kill me,"],[2323,2431,"he would have done it himself."],[2577,2665,"Interesting."],[2769,3073,"And you killed both assassins?"],[3086,3311,"He can't know Saxon was here"],[3311,3411,"and protected me."],[3428,3611,"Yeah, yes, yes, Father."],[3778,3853,"Impressive."],[3928,4004,"Maybe you're Alpha Queen"],[4004,4124,"material after all."],[4200,4287,"Get rid of the bodies."],[4496,4750,"You're stronger than your mother, Maeve."],[4796,5025,"Let's just pray that makes you..."],[5180,5242,"smarter."],[5655,5784,"I lied to my father"],[5851,6035,"for the first time in my life"],[6076,6272,"and I did it for a Blackmoor."],[6327,6452,"If Father finds out,"],[6452,6619,"it won't just break his trust."],[6619,6785,"He'll see me as a traitor."],[6810,6923,"And in our world,"],[6923,7090,"traitors get executed."]],"27":[[337,458,"Oh my God, you're bleeding."],[508,604,"I've had worse."],[967,1034,"Let me see!"],[1326,1409,"You should be dead,"],[1409,1622,"and here I am saving your stubborn ass."],[1705,1801,"Didn't know you cared."],[1818,1864,"I don't."],[1947,2035,"Shut up."],[2356,2498,"No one knows my secret."],[2544,2673,"Not even my father."],[2715,2836,"Only my dead mother."],[2886,3057,"But Saxon saved my life."],[3123,3274,"I can't let him bleed out."],[4295,4387,"You're a healer."],[4512,4596,"A true healer."],[4988,5167,"That's how you take all those hits."],[5376,5476,"No one knows."],[5643,5793,"Okay? No one can know."],[5880,6018,"You patch up every cut,"],[6110,6243,"like they're all worth saving."],[6477,6544,"Even me."],[6690,6835,"You're not what I expected."],[7007,7123,"Neither are you."]],"28":[[179,271,"I want him."],[362,429,"Mine."],[450,546,"You, you saved me."],[546,613,"But was it just"],[613,709,"because you'd go feral?"],[763,850,"I didn't think."],[884,988,"I just ran to you."],[1005,1163,"That's not a real answer."],[1288,1380,"What do you want from me?"],[1380,1472,"Who are you,"],[1547,1668,"Saxon Blackmoor?"],[1726,1830,"I'm your mate."],[1956,2127,"I will always come for you."],[2164,2289,"Stop hiding behind that."],[2289,2485,"That's, that's not who you are."],[2485,2677,"That's a mate bond we didn't choose."],[2740,2848,"Do you think saving me"],[2869,2969,"proves something?"],[2982,3090,"You would've killed me"],[3090,3211,"if we weren't fated."],[3249,3390,"We are still enemies."],[3453,3511,"Tell me."],[3561,3636,"Did you fall for me"],[3636,3741,"because of the mate bond?"],[3995,4154,"I fell for you before the bond."],[4337,4408,"But fate"],[4550,4658,"chose you for me."],[4738,4859,"And I can't deny my wolf"],[4859,4954,"and neither can you."],[5046,5167,"Our lives are bound."],[5188,5242,"You're mine."],[5242,5351,"No, I'm not!"],[5509,5601,"My mother is dead"],[5601,5701,"because of your pack!"],[5701,5764,"Maeve,"],[5764,5868,"we did not kill your mother."],[5868,5985,"Stop lying to me!"],[5985,6076,"They've been feeding you lies"],[6076,6147,"your entire life!"],[6147,6235,"Can't you see?"],[6235,6322,"Who sent the assassin?"],[6322,6564,"My father said it was rogue wolves."],[6564,6744,"That is you Blackmoors."],[6752,6890,"You think my own would stab me?"],[6898,7115,"That I'd kill my entire pack for you?"],[7115,7182,"Then who?"],[7253,7382,"Who killed my mother?"],[7415,7636,"If I tell you, they'll kill us both."]],"29":[[183,271,"The Cadet's Ball,"],[329,496,"held on the night before the Rite."],[571,759,"I'm fated to my mortal enemy"],[809,988,"and I can't stop thinking about him."],[1071,1263,"He says he didn't kill my mother,"],[1309,1476,"didn't send those assassins."],[1576,1659,"But then,"],[1818,1889,"who did?"],[2715,2777,"Wow, Maeve."],[4008,4149,"Can he smell me all over you?"],[4341,4458,"What did he just say to you?"],[4479,4596,"Go after him."],[4642,4721,"Ours."],[4788,4842,"No."],[4867,5125,"Tonight, before the Rite,"],[5155,5380,"tradition calls for a final test."],[5430,5518,"By Rite tradition,"],[5518,5722,"those who cannot control their wolves"],[5722,5926,"must submit to the Collar of Cowards."],[6047,6143,"Don't you dare."],[6322,6393,"Let her go!"],[6414,6531,"This isn't part of the Rite!"],[6639,6723,"Stop it!"],[6723,6781,"Now!"],[6798,6956,"It's for the cowards."],[6956,7123,"A rite of humiliation."],[7182,7290,"Think of it as"],[7349,7444,"character-building."],[7857,7924,"Stop!"],[8012,8208,"Kneel for the court, Princess."]],"30":[[12,212,"Kneel for the court, Princess."],[1021,1167,"Coward Queen!"],[1217,1280,"Coward."],[1280,1447,"Coward Queen!"],[1484,1605,"Coward Queen!"],[1605,1659,"Coward Queen!"],[1659,1747,"Send it to the King."],[1747,1906,"See if he really wants his heir."],[2002,2168,"Let me out."],[2168,2302,"Let me burn them."],[2302,2481,"No, not like this."],[2548,2652,"Recite the oath."],[2694,2827,"Or we'll tighten it."],[2894,2990,"Fuck your oath."],[3490,3607,"No, Maeve!"],[3699,3787,"Let me out."],[3820,3920,"Let me kill them."],[3920,3983,"Let me."],[3983,4220,"Why Saxon gives a fuck about you,"],[4220,4366,"I have no idea."],[4400,4533,"But I'm gonna break you"],[4533,4733,"piece by piece."],[4742,4946,"And when he becomes Alpha King,"],[4946,5130,"I will rule beside him."],[5155,5234,"Ours!"],[5259,5359,"Our mate."],[5359,5467,"I'll end her!"],[6827,6952,"Say that again."]],"31":[[1055,1146,"It's your turn now."],[1372,1459,"Anyone else?"],[2235,2344,"There's my Alpha Heir."],[2427,2519,"What have I done?"],[2665,2786,"Bitch asked for it."],[2802,2890,"Enough games."],[2911,2990,"Come with me."],[4137,4245,"You impressed me tonight."],[4312,4391,"Thank you, Father."],[4404,4533,"Not just strength."],[4658,4738,"Control."],[4833,4921,"Composure."],[4942,5067,"That is the kind of power"],[5067,5221,"the War College respects."],[5230,5330,"And the kind of heir"],[5359,5509,"I can finally trust."],[5547,5680,"The Rebellion grows bolder."],[5718,5847,"Blackmoor's rallying rogues."],[5847,5976,"He's building a rebel pack."],[6056,6181,"We just can't pin it on him yet."],[6485,6848,"So here's your first command as a wolf."],[6990,7244,"Kill Saxon Blackmoor."]],"32":[[8,266,"Kill Saxon Blackmoor."],[321,529,"Strike when his guard is down."],[734,921,"A single wound to the heart"],[921,1051,"with silver."],[1067,1155,"He won't survive."],[1184,1263,"No."],[1276,1418,"He is ours."],[1430,1522,"Our mate."],[1576,1710,"Then tell me what to do."],[1739,1856,"Because if I disobey,"],[1901,2018,"he'll kill us both."],[2077,2198,"The Rite is tomorrow."],[2252,2385,"Kill Saxon Blackmoor"],[2552,2715,"and you avenge your mother"],[2715,2823,"and become"],[2844,2957,"what you were meant to be,"],[2994,3303,"the Alpha King's Heir."],[3516,3682,"He would not hesitate to kill you."],[3716,3845,"Do not falter now."],[4562,4667,"Ah, yes, of course."],[4721,4808,"And when it's done,"],[4909,5050,"your engagement to Rory"],[5075,5180,"will be announced."],[5221,5334,"As was always intended."],[5822,5930,"We'll finally be mates."],[6026,6122,"And you'll be safe with me."]],"33":[[692,804,"You'll be my mate at last."],[880,934,"Weak."],[1030,1113,"Not mate."],[1138,1222,"Get lost."],[1251,1343,"I'm sorry!"],[1430,1622,"I just, um, I need a second."],[2289,2394,"Betray my family"],[2394,2531,"or betray my fated mate."],[2598,2677,"Either way,"],[2677,2823,"there won't be anything left"],[2823,2957,"of me afterwards."],[3003,3115,"Did Zion call you his mate?"],[3361,3440,"You're engaged to him?"],[3449,3545,"It was arranged"],[3561,3674,"when we were children."],[3845,3920,"You are mine."],[4004,4079,"Not his."],[4145,4379,"I will never be yours, Saxon."]],"34":[[41,133,"What are you gonna do?"],[246,371,"Kill me after healing me?"],[442,508,"I should."],[734,800,"Then do it."],[900,1021,"Strike my heart."],[1117,1363,"A nice clean blow."],[2356,2456,"You are mine."],[2927,3115,"How could I keep fighting my wolf?"],[3169,3349,"Nothing has ever felt so great."],[3390,3495,"How can it be wrong?"],[3983,4079,"Do you crave my bite,"],[4200,4279,"my mate?"],[5284,5355,"Say it."],[5467,5518,"Maeve?"],[5618,5718,"Maeve, where are you?"]],"35":[[50,125,"Maeve, where are you?"],[196,296,"This isn't over."],[675,734,"Maeve."],[1209,1276,"There you are."],[1580,1639,"You okay?"],[1739,1797,"Yeah."],[1889,1960,"You should go to bed."],[2056,2156,"The Rite is tomorrow."],[2723,2790,"The Rite."],[2882,2977,"The deadliest mission"],[2977,3103,"at the War College."],[3140,3294,"Half will die here by tomorrow."],[3374,3578,"For me, I've got a second mission,"],[3649,3837,"kill my mate."],[4229,4396,"This year's Rite will test"],[4396,4567,"more than just your strength."],[4608,4767,"You will be split into teams"],[4817,5059,"and sent to claim the sacred relic"],[5084,5201,"atop Mount Vesper."],[5251,5497,"Trust your squad to watch your backs."],[5497,5755,"And do not fail your directives."],[5809,5880,"Team one."],[6081,6197,"Captain Rory Zion,"],[6377,6610,"Cadet Maeve Thornevale,"],[6673,6781,"Cadets Paul"],[6810,7032,"and Peter Edgewood,"],[7032,7265,"Lieutenant Kaela Vire,"],[7294,7674,"and Commander Saxon Blackmoor."],[7878,7949,"Edgewood."],[7987,8137,"A family loyal to my father."],[8199,8425,"If I don't kill Saxon, they will."],[8533,8608,"You've got this."],[8692,8787,"You finish him tonight."]],"36":[[813,880,"Don't look down."],[1555,1672,"We flank left through the ravine."],[1705,1835,"That's where the magic is weakest."],[1835,1922,"You'll lead us straight into"],[1922,2006,"an ambush, Zion."],[2006,2122,"Everyone will take that route."],[2168,2273,"What are you suggesting then?"],[2344,2456,"We climb straight to the summit."],[2573,2644,"That's suicide!"],[2694,2848,"Can't handle a real challenge, Zion?"],[3107,3219,"Mommy General"],[3219,3345,"not here to protect you?"],[3399,3449,"Fuck you."],[3507,3599,"Then we split up."],[3607,3666,"Yes!"],[3707,3853,"Saxon and I will move much faster"],[3853,3928,"just the two of us and"],[3928,4058,"win the fucking relic for you all."],[4058,4149,"We're not splitting up."],[4250,4346,"That's not your decision"],[4346,4483,"to make, Zion."],[4796,4833,"No."],[5071,5167,"Yes, Thornevale?"],[5238,5376,"Stay with mate."],[5438,5601,"But maybe if I move Rory"],[5601,5759,"and the Edgewoods away from Saxon."],[5764,5926,"Stay with mate!"],[6089,6160,"We stay together."],[6998,7152,"I see how he looks at you."],[7190,7436,"But you are nothing to him."],[7507,7611,"Saxon will always remember"],[7611,7786,"where his true loyalty lies."]],"37":[[404,471,"Shh."],[504,579,"Now's our chance."],[667,717,"Let's go."],[888,1030,"You want me to stab him in the back?"],[1059,1159,"Blackmoor can't be beaten"],[1159,1247,"in direct combat."],[1305,1380,"This is the only way."],[1434,1509,"We can make it look like"],[1509,1622,"an ambush from another group."],[1651,1726,"Coward."],[1776,1864,"I'll take out Vire."],[1914,2014,"Fuck you, bro,"],[2027,2135,"she's mine to kill."],[2210,2373,"And I'll let you taste her first."],[2373,2548,"End those bastards."],[2548,2590,"Come on."],[2652,2765,"The Alpha King has spoken."],[3023,3165,"You're distracted."],[3190,3336,"The Blackmoor pack won't survive"],[3336,3461,"if you're distracted."],[3490,3628,"She'll never be yours, you know that."],[3641,3732,"You still hover over her"],[3732,3832,"like a guard dog."],[3832,3958,"And she will always think of you"],[3958,4016,"as the enemy-"],[4016,4066,"Enough!"],[4195,4341,"Just remember who bleeds for you."],[4362,4450,"Now's your chance, Maeve."],[4458,4512,"Go now."]],"38":[[0,91,"Now's your chance Maeve."],[133,200,"Go now."],[241,337,"The boy that I grew up with"],[337,504,"would have never told me to do this."],[558,704,"What has happened to you, Rory?"],[725,838,"Blackmoor was talking about you"],[838,917,"just now, wasn't he?"],[975,1021,"Rory."],[1021,1076,"What did you do with"],[1076,1176,"that rebel scum, Maeve?"],[1213,1292,"Has he touched you?"],[1334,1368,"Kissed you?"],[1368,1488,"No he hasn't, uh,"],[1488,1597,"you don't understand!"],[1597,1710,"You don't understand, Maeve."],[1776,1935,"Saxon Blackmoor dies today"],[1935,2031,"by order of the King."],[2081,2277,"If you won't do it, then I will."],[2406,2473,"Hey."],[2548,2606,"Wait."],[2719,2873,"Get your fucking hands off of her!"],[3933,4004,"My mate."]],"39":[[1126,1230,"What do we have here?"],[1230,1313,"An ambush?"],[1313,1368,"No."],[1368,1526,"You saw how I had Saxon's back."],[1526,1626,"Oh, so you did."],[1643,1805,"Do you love him?"],[1835,1968,"Too bad he's mine."],[2585,2644,"Kill her!"],[3182,3286,"Why did you, what-"],[3286,3395,"Why did you?"],[3440,3595,"Look out there!"],[3603,3641,"Run!"],[4133,4204,"Maeve!"],[4371,4416,"Just go."],[4416,4537,"Just go, just leave me."],[4537,4625,"No, no, no."],[4646,4775,"Just breathe for me, Princess."],[4800,4850,"Breathe."],[4904,5025,"At least you're safe."],[5259,5317,"Maeve."],[5351,5392,"Maeve."],[5447,5530,"Maeve!"]],"40":[[1188,1251,"You're awake."],[1447,1534,"What happened?"],[1534,1634,"Where is everyone?"],[1634,1793,"The King's soldiers ambushed us."],[1897,2043,"You took an arrow for me."],[2131,2256,"My father's army?"],[2352,2477,"They attacked us during the Rite?"],[2477,2556,"They attacked me."],[2602,2773,"And the rest of the Marked Ones."],[2773,2823,"No, no."],[2823,2919,"He, he wouldn't do that."],[2919,2998,"He wouldn't?"],[3048,3165,"Wake up, Maeve!"],[3219,3424,"I watched two of my pack die"],[3424,3541,"as I got you out of there!"],[3611,3812,"An arrow through their necks."],[3828,3887,"And I don't know"],[3887,4016,"how many of them survived."],[4091,4170,"I'm sorry, Saxon."],[4170,4266,"No you're not!"],[4362,4450,"Because you knew!"],[4487,4629,"You knew they were coming."],[4629,4733,"No, I didn't."],[4733,4796,"Liar!"],[4842,4946,"Fucking liar."],[5021,5209,"You saw Rory raise that knife"],[5209,5384,"behind my back like a coward!"],[5384,5492,"And I stopped him!"],[5609,5768,"I saved your life twice today!"],[5768,5897,"You're alive because of me!"],[6126,6206,"What do you want?"],[6218,6297,"To help me"],[6318,6473,"and hate me at the same time?"],[6523,6639,"How do you think this ends?"]],"41":[[0,116,"How do you think this ends?"],[133,279,"I don't know, Saxon."],[342,462,"What kind of choice is this"],[462,650,"between my mate and my family?"],[700,917,"Kill my mate and, and go mad"],[917,1163,"or betray my father and my kingdom?"],[1163,1259,"What does your wolf want?"],[1313,1393,"Ours."],[1430,1493,"Mate."],[1514,1618,"She's got a ridiculously"],[1618,1710,"one track mind."],[2056,2248,"Why did you have to be a Blackmoor?"],[2323,2535,"Why does fate have to be so cruel?"],[2540,2719,"It's not fate that's cruel."],[2727,2857,"It's the fucking world, Princess."],[2857,2952,"Don't call me that."],[3236,3361,"Then I'll call you what you truly are..."],[3578,3649,"my love."],[3866,4033,"The world will brand us traitors."],[4145,4275,"There is no universe"],[4358,4529,"a feeling like this should be wrong."],[4671,4767,"You're right."],[4892,5005,"I'm tired of running"],[5005,5159,"from something I feel in my soul."],[5242,5367,"I am yours, Saxon."],[5543,5651,"And you are mine."],[5676,5789,"Thank fuck."]],"42":[[462,542,"Maeve."],[784,892,"Do you want this?"],[1009,1080,"Yeah."],[4783,4892,"You're mine."],[5622,5697,"Now"],[5814,5897,"and forever."],[5955,6018,"Please."],[6068,6131,"Please."],[6189,6252,"Please."]],"43":[[421,542,"I made my choice."],[667,734,"We are bound."],[834,988,"I don't know what happens next,"],[1084,1263,"but nothing will ever be the same."],[2210,2306,"Your scars are gone."],[2464,2535,"You healed me."],[2660,2761,"If only the past"],[2761,2873,"could be healed so easily."],[3128,3282,"I never thought I'd find my mate."],[3399,3503,"Let alone hold her."],[4016,4212,"Now, I've marked you mine."],[4533,4671,"I will never get enough of you."],[5042,5155,"Never let me go."],[5217,5284,"Never."]],"44":[[346,454,"Even in sleep,"],[475,563,"he protects me."],[679,759,"How did my enemy"],[759,942,"become the only one I can trust?"],[2485,2619,"You scheming bitch!"],[2640,2802,"Oh, you're craftier"],[2802,2932,"than I gave you credit for."],[3003,3148,"A full scale slaughter"],[3148,3286,"of the Blackmoor Pack?"],[3641,3787,"But we survived."],[3845,4041,"And now, you're mine,"],[4041,4266,"you pathetic whore."],[4325,4429,"That's enough, Kaela."],[4817,4984,"I have no ill will towards you."]],"45":[[767,834,"Oh my God!"],[950,1001,"Kaela."],[1101,1172,"She's dying!"],[1213,1292,"Heal her, Maeve."],[1405,1468,"She's Pack."],[1584,1659,"Okay, hold her still."],[2873,2940,"How?"],[3261,3353,"Why? I-"],[3849,4004,"You're fated mates."]],"46":[[37,191,"You're fated mates."],[425,521,"What were you thinking?"],[521,700,"This is so much worse than I thought."],[700,792,"She's my destiny."],[938,1042,"If you found yours,"],[1042,1101,"I'd understand-"],[1101,1205,"You stupid male!"],[1230,1397,"This is bigger than you and her."],[1430,1518,"What about the rebellion?"],[1693,1785,"What rebellion?"],[2097,2289,"Oh, he didn't tell you?"],[2389,2615,"We're gonna kill your daddy, Princess."],[2686,2852,"To crown Saxon Alpha King."],[2865,2994,"Once and for all."]],"47":[[16,112,"You lied to me?"],[129,387,"No, everything I told you is true."],[396,567,"You planned to murder my father."],[846,909,"Hey."],[1084,1209,"He's evil, Maeve."],[1267,1334,"Your mother knew,"],[1334,1434,"she was trying to stop-"],[1434,1497,"Don't you dare"],[1497,1601,"talk about my mother."],[1672,1768,"You used me."],[1801,1901,"You let me fall for you"],[1922,2043,"to try to get close to me."],[2085,2214,"I never lied about us."],[2298,2464,"I swore my loyalty to you."],[2777,2848,"You are my mate."],[2857,3015,"The mate bond means nothing now."],[3057,3186,"Let me finish the Rite by myself."],[3186,3324,"And stay away from me."],[4070,4195,"Go back to mate."],[4212,4262,"Shut up."],[4262,4416,"You're the reason I'm in this mess."],[4416,4517,"Well, well, well,"],[4575,4708,"it's the little Princess."],[4767,4900,"Our friends are dead"],[4900,5017,"because of your father!"],[5055,5113,"And now,"],[5226,5317,"you'll be too."]],"48":[[50,145,"You'll be too."],[171,321,"Hey, I am not the enemy."],[1259,1418,"King's justice is swift."],[1434,1559,"You're safe now, Maeve."],[1626,1826,"The rebellion has been handled."],[1951,2014,"Handled?"],[2022,2122,"The rogues are all dead."],[2210,2452,"I killed Saxon Blackmoor myself."],[2836,3078,"Today signals the end"],[3123,3261,"of the rogue insurgence."],[3386,3499,"Saxon can't be dead."],[3582,3661,"I would feel it"],[3661,3774,"through my mate bond."],[3887,4058,"My father is lying to everyone."],[4116,4225,"They have been dealt with"],[4275,4396,"by the winner of the Rite,"],[4479,4679,"Captain Rory Zion."],[4679,4863,"Wooh!"],[4863,5100,"Yeah!"],[5739,5860,"You saved my daughter"],[5935,6018,"and put down"],[6064,6260,"the remaining Blackmoor rebels."],[6293,6448,"The Rite wasn't a test."],[6477,6602,"It was a purge."],[6623,6702,"Tomorrow,"],[6802,7107,"my daughter and Commander Zion"],[7219,7336,"are to be mated"],[7449,7636,"in a union of strength,"],[7724,7970,"legacy, and loyalty."],[8045,8103,"No!"],[8174,8229,"Fight!"],[8279,8370,"Calm down."],[8425,8591,"They can't force me to mate Rory."],[8641,8746,"I'm already mated."],[8846,8925,"Oh my God."],[8942,9059,"I'm a Blackmoor now."]],"49":[[1368,1480,"My whole life is a lie."],[1522,1626,"I don't know what to do."],[1676,1735,"Yes you do."],[1872,2006,"I shouldn't trust you either."],[2122,2214,"I think I have something"],[2214,2318,"that might help that."],[2723,2827,"I wanted to give you this"],[2827,2919,"the first time we met,"],[2919,2994,"but I didn't think"],[2994,3086,"you'd believe me then."],[3140,3269,"My mother's necklace?"],[3707,3824,"Why do you have this?"]],"50":[[12,141,"Why do you have this?"],[275,350,"Open it."],[638,846,"If you ever find this, Maeve,"],[900,1067,"the Alpha King will stop at nothing"],[1067,1184,"to maintain power."],[1242,1484,"General Zion cannot be trusted."],[1589,1718,"My mother's handwriting."],[1814,1939,"She knew the truth."],[2047,2143,"She and my father,"],[2289,2444,"they were working together to stop"],[2469,2577,"the Alpha King's reign."],[2790,2873,"No, no."],[2873,3028,"My mother loved my father."],[3028,3053,"She-"],[3053,3157,"She suspected him."],[3244,3424,"He thought the Blackmoor Pack"],[3424,3520,"was going to challenge him"],[3520,3599,"for the throne."],[3657,3787,"He used a Dominion Link to"],[3787,3916,"break my father's will"],[3916,3991,"and have him killed."],[4054,4162,"And when your mother"],[4225,4325,"tried to stop him,"],[4416,4542,"the King killed them too."]],"51":[[33,141,"And when your mother"],[200,300,"tried to stop him,"],[517,638,"the King killed her too."],[638,759,"No, don't say that."],[1071,1226,"You know the truth."],[1255,1434,"The Blackmoors didn't kill my mother."],[1522,1580,"Yes."],[1697,1835,"My own father did."],[2122,2277,"I am so sorry, Princess."],[2360,2460,"But there's more."],[2598,2715,"The other half of that letter,"],[2819,2915,"your mother must have"],[2944,3053,"hidden it in her chambers,"],[3053,3136,"before she died."],[3157,3319,"I think she knew how to stop him."],[3432,3524,"Well, I'll find it."],[3728,3878,"I guess I'm a rebel now too."],[4029,4116,"You always were."],[4191,4312,"You just didn't know it yet."],[4396,4529,"If there is any danger,"],[4658,4738,"walk away."],[4796,4896,"Saxon, this"],[4896,5071,"could clear your whole Pack's name."],[5071,5184,"You are more important"],[5184,5296,"than any feud."],[5326,5451,"War made us enemies,"],[5563,5684,"fate made us mates."],[5801,5880,"But in that moment,"],[5980,6122,"love proved to be stronger"],[6122,6297,"than hate and fate combined."],[6339,6514,"You're it for me, Saxon Blackmoor."],[6631,6740,"My wolf knew you,"],[6740,6819,"and now I do too."]],"52":[[629,734,"Oh my God."],[850,955,"My father has a woman"],[955,1059,"secretly stashed"],[1059,1184,"in the Queen's suite?"],[1205,1297,"General Zion?"],[1434,1572,"How long has this been going on?"],[1685,1868,"And where is my mother's things?"],[3632,3695,"Maeve,"],[3737,3837,"if you're reading this,"],[3891,4004,"I wasn't strong enough"],[4004,4091,"to protect you."],[4187,4387,"Your father's wolf is a monster."],[4416,4729,"Sometimes the way to heal is death."],[4775,4871,"You've been busy,"],[4975,5050,"daughter."]],"53":[[100,221,"You've been busy,"],[300,379,"daughter."],[796,963,"What is Kaela doing here?"],[963,1021,"She just-"],[1063,1188,"She just tried to kill me."],[1247,1409,"Lieutenant Vire has seen the truth."],[1430,1539,"She is with us now."],[1559,1722,"So you betray Saxon?"],[1755,1860,"What about the memory of"],[1860,1935,"your parents?"],[1935,1993,"What-"],[2035,2181,"I, I thought you hated my father."],[2231,2344,"She's under my dominion."],[2448,2519,"And now,"],[2665,2761,"you will be too."],[2877,3015,"No, no, no."],[3015,3157,"I don't think so."],[3240,3324,"He wouldn't."],[3399,3490,"He's my father."],[3490,3645,"He, he wouldn't do this."],[3645,3707,"Not to me."],[4350,4412,"You"],[4583,4713,"belong to me now."],[4792,4859,"Wolf!"],[4917,4996,"Where are you?"],[5113,5226,"Where is my wolf?"],[5559,5601,"There."],[5764,5839,"That's better."],[6093,6256,"You'll mate Rory at dawn."],[6322,6581,"And forget every lie"],[6648,6785,"your treacherous mother"],[6852,6952,"ever told you."],[7144,7232,"He's in my head."],[7273,7353,"I can't move."],[7415,7561,"But he doesn't know about Saxon,"],[7653,7757,"or the bond yet."],[8003,8058,"Good girl."],[8174,8216,"Fight."],[8291,8404,"I have to fight."]],"54":[[141,221,"Perfect."],[287,604,"Every inch, a royal bride."],[867,992,"It's funny, isn't it?"],[1046,1230,"Soon you'll marry my son"],[1230,1409,"and I will be your new mother."],[1530,1634,"Mother-in-law."],[2035,2143,"Stepmother."],[2177,2289,"I must get out."],[2364,2510,"Saxon, where are you?"],[2560,2719,"But what you don't know is that"],[2719,2952,"I'm pregnant with Alpha's child."],[3311,3378,"It's time."],[3824,3949,"This can't be happening."],[4275,4400,"I have to stop this."],[4938,5030,"You'll thank me one day."],[5188,5417,"Saxon, please, I need you."],[5463,5605,"I'm giving you the perfect life."],[5726,5818,"He's not coming."],[6085,6210,"I'm here for my fated mate!"]],"55":[[8,158,"I'm here for my fated mate!"],[542,704,"His fated mate?"],[704,800,"That doesn't matter."],[859,975,"No one breaks my hold."],[1067,1121,"Kill him."],[1568,1755,"What a dirty little secret you've held."],[1776,1943,"Spreading your legs for a traitor."],[2540,2615,"Kill him."],[3136,3199,"No!"]],"56":[[129,200,"If they're fated mates,"],[200,300,"she'll die with him!"],[350,425,"So be it."],[592,729,"Good thing I have a spare."],[942,1130,"Kill the Blackmoor rebel wolf!"],[1197,1276,"Maeve."],[1334,1459,"No, please!"],[1459,1618,"Maeve, it's, it's me."],[1647,1735,"Maeve, it's me."],[1847,1926,"It's me."],[2932,3082,"I'd love you without the bond."],[3253,3365,"Kill him"],[3370,3449,"now!"]],"57":[[663,759,"You're mine."],[867,1005,"And I am yours."],[1159,1334,"No bond is as strong as that."],[1618,1680,"Mine."],[1705,1789,"My mate."],[1860,1972,"You came for me."],[2102,2193,"I thought I lost you."],[2193,2293,"I thought I lost me."],[2489,2656,"I will always come for you."],[2681,2781,"That's impossible."],[2831,2907,"No one's ever broken"],[2907,3023,"a dominion link before."],[3624,3745,"I know you killed my mother."],[3916,4079,"Your reign ends today."]],"58":[[41,196,"Your reign ends today."],[287,446,"You will never control me"],[446,642,"or anyone else like that ever again."],[684,859,"You don't have the power to kill me."],[1659,1768,"What are you doing?"],[1972,2139,"No!"],[2227,2381,"Sometimes the best way to heal"],[2419,2485,"is death."],[2590,2690,"I killed your wolf."],[2756,2898,"You're not longer an Alpha."],[3111,3274,"You're a human."],[3445,3616,"You stupid girl!"],[3707,3824,"You doomed us all!"],[3824,3908,"Mother, no!"],[4029,4137,"Oh, hey!"]],"59":[[4,83,"Mother, no!"],[200,308,"Oh, hey!"],[588,688,"Since we were kids,"],[746,796,"I've..."],[909,1005,"dreamed of being your mate."],[1155,1292,"No, no, no, no, no, Rory."],[1376,1451,"I was trying..."],[1626,1664,"Rory."],[1789,1851,"Rory!"],[1972,2143,"You made me do this."],[2168,2381,"You killed my son!"],[2556,2660,"You're weak!"],[2744,2857,"You were never supposed to"],[2857,2994,"survive this year!"],[3028,3261,"Because in my womb is the true heir!"],[3411,3545,"And I'm gonna slit yours!"],[4650,4813,"She needed to shut the fuck up."]],"60":[[116,237,"He got in my head."],[275,446,"The king, I couldn't think."],[446,563,"I couldn't move."],[713,759,"I know."],[809,930,"But you fought him."],[1071,1192,"You're strong, Thornevale."],[1301,1413,"Stronger than us all."],[1630,1710,"Alpha."],[1893,1972,"Maeve..."],[2227,2344,"Please."],[2385,2456,"Please,"],[2481,2648,"give me back my wolf."],[2723,2827,"You're my only daughter."],[2852,2915,"Not anymore."],[3345,3411,"Kill him."],[3470,3541,"End it!"],[3703,3799,"You wanna live?"],[4371,4425,"Fine."]],"61":[[538,650,"Now you're the Marked One."],[1918,2014,"My queen."],[3144,3257,"I thought I lost you."],[3507,3586,"You were the only thing"],[3586,3678,"keeping me here."],[5622,5747,"Alpha Queen Thornevale."],[5872,5926,"From now on,"],[5926,6076,"it's Alpha Queen Blackmoor."],[6189,6306,"I like the sound of that."],[6402,6514,"You're my forever mate,"],[6594,6677,"rebel wolf."]]}