ring."],[3470,3578,"Oh my god, that’s embarrassing."],[3578,3695,"Well then maybe this will be"],[3695,3770,"something that you"],[3770,3849,"actually remember."]],"65":[[779,900,"What are you doing here?"],[921,1059,"I came to see you."],[1101,1188,"See me?"],[1222,1288,"For what?"],[1343,1443,"Is Marcus around?"],[1676,1768,"Then I'll just say it."],[1843,1997,"Me and Mr. Sinclair,"],[1997,2097,"we have history."],[2118,2231,"Our families have been closed"],[2231,2373,"for generations."],[2419,2535,"If you hadn't gotten yourself"],[2535,2640,"knocked up,"],[2660,2769,"I'd be his wife."],[2902,2952,"Yeah?"],[3019,3057,"Yeah."],[3157,3290,"You're the one who came here"],[3290,3474,"and ruined everything for me."],[3557,3699,"I ruined everything for you?"],[3774,3891,"Didn't I tell you this the"],[3891,4020,"first time we met?"],[4095,4270,"You ruined everything for him,"],[4270,4333,"you know."],[4383,4475,"You don't even know the"],[4475,4617,"horrible things people have"],[4617,4696,"been saying about"],[4696,4783,"him behind his back."],[4829,4892,"You're lying."],[4996,5105,"You've been nothing but"],[5105,5188,"trouble ever since"],[5188,5321,"you first showed up."],[5409,5518,"Now the Sinclair group is getting"],[5518,5722,"dragged into your mess."],[5722,5922,"Their stock has been dropping for days,"],[5922,6014,"all because of you."],[6043,6185,"You're gonna drag Marcus into"],[6185,6335,"a life of poverty."]],"66":[[83,275,"Let's say, for the sake of argument,"],[304,433,"you two really are in love."],[462,550,"Do you really think that'll"],[550,692,"last after he loses"],[692,817,"everything he"],[817,930,"has because of you?"],[988,1134,"He's going to hate you."],[1326,1605,"Here's 30 million."],[1776,1893,"If you leave him,"],[1918,2022,"I'll give you"],[2064,2193,"another 50 million."],[2502,2623,"You don't even wanna know"],[2623,2819,"how many enemies Marcus has made"],[2819,2915,"protecting you."],[2957,3061,"And I won't lie,"],[3123,3232,"your romance,"],[3294,3490,"everything you guys have done together,"],[3524,3616,"it's all been part"],[3616,3766,"of a plan hatched up by the"],[3766,3920,"other wealthy families to"],[3920,4045,"take Marcus down."],[4220,4341,"Why are you doing this?"],[4379,4454,"Listen,"],[4504,4596,"I can accept that"],[4596,4738,"despite our history, Marcus"],[4738,4850,"may not wanna marry me."],[4867,4975,"I can also accept if he"],[4975,5159,"decided to move overseas to"],[5159,5317,"marry some wealthy women abroad."],[5422,5634,"But you, a warehouse girl"],[5634,5768,"from the slums,"],[5805,5914,"that's a different story."],[5968,6231,"It's humiliating, that's why."],[6260,6343,"Is that"],[6343,6498,"what you think of me? You're..."],[6510,6639,"embarrassed by me?"],[6748,6840,"Yes!"],[6936,7052,"People like you,"],[7073,7190,"no matter how much you try to"],[7190,7286,"dress it up,"],[7307,7511,"can never belong in our world."],[7511,7649,"I think it's time you drop"],[7649,7795,"the act and quit dreaming."],[8095,8162,"So this is who"],[8162,8245,"you really are, huh?"]],"67":[[62,112,"So this is who"],[112,196,"you really are, huh?"],[567,617,"Marcus?"],[892,1009,"You set me up!"],[1263,1355,"You've been spreading lies"],[1355,1430,"about Daisy,"],[1476,1576,"dragging her background"],[1576,1655,"through the mud."],[1701,1776,"You've even brought her"],[1776,1835,"father here to try"],[1835,1922,"to drag her down."],[2018,2110,"What's your goal?"],[2147,2298,"To destroy her completely?"],[2431,2506,"You know what?"],[2565,2786,"Yes, you saw what she's like."],[2798,2882,"She was more than willing to"],[2882,3011,"accept my 30 million"],[3011,3140,"to leave you forever."],[3194,3257,"I'll admit,"],[3307,3457,"my hands aren't clean here."],[3499,3632,"But a woman like her doesn't"],[3632,3820,"deserve to be Mrs. Sinclair."],[4112,4191,"Get all that?"],[4642,4813,"Oh yeah, I got it."],[5017,5105,"Sarah Palmer,"],[5163,5267,"I'm Officer Richard."],[5305,5347,"You're under arrest for"],[5347,5409,"slander with the"],[5409,5513,"intent to cause harm."],[5538,5597,"Please come with us."],[5597,5701,"No, no!"],[5709,5801,"Marcus, we've known"],[5801,5943,"each other since you were kids!"],[5943,5989,"You can't let"],[5989,6089,"them do this to me!"],[6131,6168,"You tried to"],[6168,6368,"harm my wife, Sarah."],[6443,6544,"From now on, you can"],[6544,6690,"consider us enemies."],[6785,6844,"You think you got"],[6844,6956,"your fairy tale ending?"],[6981,7040,"Dream on!"],[7082,7207,"Marcus has no heart!"],[7228,7319,"He'll get tired of you and"],[7319,7436,"toss you aside too,"],[7436,7561,"just like he's doing to me!"]],"68":[[2552,2773,"Marcus, I think I'm going into labor."],[2890,2940,"Come on."],[2940,3003,"Let's go."],[3670,3716,"Look at me."],[3757,3841,"Look at me, you're okay."],[4124,4237,"You're okay, you're gonna be fine,"],[4237,4291,"all right?"],[4291,4346,"That's it,"],[4366,4454,"that's it, breathe."],[4454,4521,"Breathe."],[5868,6014,"How long has it been?"],[6156,6218,"Why haven't we"],[6218,6356,"heard anything?"],[6477,6606,"It's been 10 minutes."],[6777,6956,"Please let them both be okay."],[8241,8362,"How long now?"],[8379,8508,"How long has it been?"],[8625,8725,"It's been a half an hour."],[8796,8913,"Half an hour and"],[8913,9084,"she's still not out?"],[9334,9480,"Madam, don't worry."],[9559,9693,"Mr. Sinclair has hired the best"],[9693,9784,"doctors in the world."],[9838,9955,"Everything will be fine."],[10598,10723,"That's it, push."],[11190,11315,"Daisy, Daisy."]],"69":[[4,108,"Daisy, are you okay?"],[346,625,"Oh, she's here, she's here."],[667,746,"Is Daisy okay?"],[792,892,"She's still pushing."],[946,1096,"But congratulations,"],[1109,1292,"your first baby is a boy."],[1964,2327,"Congratulations, another boy."],[2560,2627,"What do you think"],[2627,2765,"the last one will be?"],[2886,2969,"Follow me."],[3578,3724,"Congratulations, everyone."],[3741,3845,"It's a girl."],[4896,5005,"Meeting you was the luckiest"],[5005,5059,"thing that ever"],[5059,5117,"happened to me."],[5388,5522,"Whatever happens next,"],[5622,5718,"I'm ready for it."],[5776,5914,"As long as it's with you."]]}