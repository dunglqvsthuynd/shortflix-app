wouldn't be here"],[1459,1580,"if it weren't important."],[1655,1718,"I know."],[1830,1989,"You and Vanessa..."],[2035,2210,"are both getting married."],[2277,2469,"I'm too old to run around twice."],[2552,2623,"So,"],[2748,2923,"you'll both have your weddings"],[3028,3148,"at the same place,"],[3253,3361,"on the same day."],[3486,3611,"And on that day,"],[3670,3899,"I'll be making an announcement."],[3995,4091,"What announcement?"],[4191,4379,"Also, what are you even talking about?"],[4379,4542,"This is the most expensive"],[4542,4683,"wedding venue in town."],[4729,4838,"I can't afford it."],[4863,5080,"Just do as I say."]],"67":[[8,225,"Just do as I say."],[392,450,"Grandma,"],[517,800,"Natalie and her poor farmer husband"],[800,905,"humiliated me"],[905,1030,"in my favorite bridal shop"],[1030,1188,"and they kicked me out!"],[1255,1368,"You have to help me."],[1413,1651,"What do you want me to do?"],[1651,1801,"I want her cut entirely out of the"],[1801,1981,"inheritance in your will."],[1981,2106,"Not a penny left for her."],[2202,2314,"Vanessa."],[2419,2560,"Ever since you were little,"],[2627,2777,"I've given you everything."],[2869,2961,"I've already split the"],[2961,3311,"family inheritance 90-10 in your favor."],[3449,3628,"Natalie's still your sister."],[3787,3949,"Leaving her nothing at all."],[4070,4149,"It would be a bit..."],[4191,4241,"Cruel-"],[4241,4387,"Grandma, you're the one who said"],[4387,4496,"you'd never let me suffer."],[4562,4746,"Look at what she's doing to me!"],[4796,4942,"I can only imagine what she'll do when"],[4942,5000,"she gets her hands"],[5000,5084,"on your money."],[5301,5384,"You'll find out"],[5417,5593,"all about the announcement"],[5655,5734,"at the wedding."]],"68":[[492,650,"She chewed you out, didn't she?"],[704,896,"Vanessa must have tattled on you."],[896,1038,"Don't worry, I'll fix this."],[1038,1113,"You didn't do any-"],[1113,1188,"Don't."],[1188,1359,"She only cares about Vanessa,"],[1388,1451,"not the truth."],[