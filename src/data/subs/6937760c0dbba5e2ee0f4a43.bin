{"1":[[100,241,"So you two will"],[312,475,"draw a slip of paper to see"],[538,663,"who your husband will be."],[767,821,"What?"],[838,946,"Your father"],[984,1163,"has arranged two matches."],[1259,1393,"One is a state senator..."],[1455,1593,"from an old and wealthy"],[1593,1714,"political family."],[1943,2027,"And the other?"],[2072,2168,"A farmer."],[2277,2460,"Lives out in the middle of nowhere"],[2460,2665,"on a run-down farm,"],[2711,2848,"has a mute daughter."],[2952,3073,"That's all I know."],[3382,3507,"Natalie,"],[3620,3887,"you first."],[4108,4312,"Grandma's always favored Vanessa."],[4396,4496,"Is she really gonna be"],[4496,4596,"playing fair?"],[4679,4792,"Hurry up, sis."],[5789,5893,"The farmer?"],[5960,6022,"Oh!"],[6085,6256,"What luck, sis!"],[6343,6514,"How does it feel to be marrying a"],[6514,6619,"bum-ass farmer?"],[6706,6819,"Why are you laughing?"],[6915,7057,"I haven't told you what I drew."],[7328,7378,"Wait,"],[7490,7570,"you set me up?"],[7570,7703,"Don't be ridiculous."],[7749,7845,"You drew it yourself."],[7903,7970,"How could I know?"],[8053,8149,"Besides, I heard that farmer"],[8149,8270,"is a total weirdo,"],[8270,8420,"so good luck with that."],[10068,10293,"Both of these say farmer."],[10402,10502,"Why?"]],"2":[[16,91,"Grandma,"],[108,241,"you've always favored"],[241,400,"Vanessa more, but this?"],[417,650,"Making me marry a farmer in her place?"],[671,788,"Oh, please."],[1059,1209,"I'm prettier and I'm smarter."],[1259,1397,"I deserve the better man."],[1451,1714,"Vanessa has always been sheltered."],[1764,1876,"She wouldn't last a week"],[1876,2014,"in the countryside."],[2118,2318,"I'll make sure you're sent off"],[2360,2594,"with a nice dowry to get started."],[2594,2736,"I don't want your money."],[2811,3011,"All I have ever wanted"],[3036,3219,"is for you to do what's fair,"],[3244,3324,"even once!"],[3324,3445,"In this house,"],[3445,3574,"I decide what's fair."],[3682,3853,"Pack your things and get out."],[3920,4058,"Don't expect"],[4058,4220,"another penny from us."],[4350,4466,"Bye, Nat."],[4466,4600,"Enjoy your little farm life."],[4692,4771,"And don't even think about"],[4771,4859,"coming back."],[5413,5505,"You should have been gone"],[5505,5601,"a long time ago."],[5689,5830,"Everything here is mine now."],[5901,5964,"And you're just a"],[5964,6076,"worthless piece of shit"],[6076,6197,"no one cares about."],[6473,6644,"Vanessa's always been the favorite"],[6644,6802,"ever since we were kids."],[6856,6915,"Fine."],[6956,7127,"If you want me gone, you've got it."],[7152,7290,"You'll never see me again."],[9054,9167,"Thank God I wore this"],[9167,9292,"Musera Sport outfit,"],[9388,9555,"stretchy and actually comfortable,"],[9659,9834,"cause this road is brutal."],[9959,10101,"Where on earth am I?"],[10210,10460,"I've been walking for over an hour"],[10502,10664,"and I haven't seen anyone."],[10752,10844,"You need any help?"],[12525,12687,"Oh my God!"],[12779,12929,"I didn't know guys this"],[12958,13192,"good-looking exist in the countryside."],[13359,13546,"Yes, I'm looking for my husband."],[13546,13684,"His name is Rhett Callahan."],[13801,13863,"Natalie Smith?"],[14034,14122,"Yes?"],[14706,14785,"You're my wife?"]],"3":[[312,396,"Why'd you agree to"],[396,500,"marry a single farmer daddy?"],[829,971,"As long as I can get away from my"],[971,1055,"horrible family,"],[1055,1184,"I don't care who I marry."],[1251,1443,"Besides, I like the countryside."],[1601,1689,"I don't know if I've ever met"],[1689,1780,"a woman from the city who"],[1780,1947,"doesn't complain about country life."],[2106,2235,"Alright, let's get you home."],[2452,2606,"I only got one seat left on the tractor"],[2606,2748,"so you're gonna have to sit with me."],[3219,3307,"What?"],[3370,3445,"Are you serious?"],[3549,3603,"Yeah."],[3645,3753,"It's a three-mile-walk to the house"],[3753,3820,"if you'd like."],[3937,4045,"Just watch out for the cow poo."],[4195,4258,"A hot guy or"],[4258,4429,"stepping in a pile of crap..."],[4475,4608,"Guess it's not a tough call."],[6806,6906,"You're gonna burn a hole through me if"],[6906,7040,"you keep staring like that."],[8829,8913,"What's wrong, Ellie?"],[8954,9050,"Why aren't you talking?"],[9084,9196,"She can't talk, remember?"],[9196,9321,"She's too dumb to."],[9701,9793,"Aww."],[9793,10039,"Is the little mute baby gonna cry now?"],[10806,10881,"Look at her,"],[10881,10960,"always staring like some"],[10960,11044,"creepy weirdo."]],"4":[[896,984,"I bet the reason why"],[984,1163,"your mom left you is because she hate"],[1163,1326,"having a mute daughter."],[1355,1589,"All she got is that weird tough guy dad"],[1589,1743,"who does all the farm work."],[1780,1856,"Hey, you two."],[1885,2014,"Be nice to Ellie, okay?"],[2252,2448,"Mom, let go."],[2460,2560,"Alright, it's almost lunchtime."],[2573,2648,"Let's go back."],[3094,3186,"It's alright, Ellie."],[3265,3374,"They were just playing."],[3424,3482,"You know,"],[3511,3561,"I heard your daddy"],[3561,3670,"got you a new mommy."],[3699,3770,"Let's hope she's"],[3770,3933,"not some hollow pretty face."],[3995,4054,"After all,"],[4116,4170,"you know I'm the"],[4170,4354,"only one that can take care of you."]],"5":[[888,955,"Ellie!"],[1255,1330,"Ellie, come over here."],[1330,1430,"There's someone I want you to meet."],[1822,1968,"Ellie, this is Natalie."],[1968,2035,"She's going to be"],[2035,2114,"living with us from now on."],[2227,2364,"She's so cute."],[2444,2535,"Hi, Ellie."],[2648,2711,"I'm Natalie."],[2781,2886,"It's nice to meet you."],[3499,3720,"Guess she's not really fond of me."],[3845,3933,"She's just sensitive."],[4087,4191,"Ever since her mom left,"],[4275,4354,"she got really sick"],[4354,4475,"and she can't really speak."],[4571,4700,"I'm the only one she'll open up to."],[4821,4909,"Poor thing."],[5025,5196,"That must have been really hard for her."],[5309,5497,"Hopefully I can make her feel better."],[5718,5809,"There's something different"],[5809,5897,"about this woman."],[6322,6498,"I've always wanted Ellie to have a mom."],[6581,6644,"But..."],[6694,6769,"If you don't like it here,"],[6769,6873,"I'm not gonna make you stay-"],[6873,6931,"I'm staying."],[7027,7065,"I don't want to"],[7065,7211,"see my family ever again."],[7515,7595,"Great."],[7749,7903,"You know, life here is not that easy."],[8045,8166,"But we're happy to have you."],[8262,8324,"Let's get your stuff."],[9305,9409,"Rhett's mine!"],[11536,11615,"I'm so sorry."],[11661,11857,"My suitcase is probably too heavy."],[11911,12041,"I can fix the floor later."],[12116,12241,"She's not even bothered by"],[12241,12374,"how rundown this place is."],[12662,12812,"You don't need to worry about it."],[12946,13046,"This place is pretty old."],[13046,13104,"My parents built it"],[13104,13192,"when they got married."],[13234,13304,"Oh."],[13355,13417,"Wow."],[13551,13717,"It must hold a lot of memories then."],[13784,13972,"It feels so warm and homey."],[14043,14264,"Raising a child in a place like this?"],[14330,14481,"He must be exhausted."],[14522,14585,"Um..."],[14785,14906,"So there's only two bedrooms."],[14981,15110,"Here, one for Ellie and one for me."],[15206,15344,"You're going to have to bunk up with me."],[15628,15707,"Wait."],[15853,15920,"You mean..."],[15999,16103,"one room..."],[16274,16358,"one..."],[16358,16445,"bed?"],[17488,17646,"We are married, aren't we?"]],"6":[[12,221,"God, I just met this guy."],[283,392,"Husband or not,"],[479,646,"I'm not ready to sleep with him!"],[917,984,"You can relax."],[1076,1142,"I'm going to take the floor"],[1142,1209,"until you're ready."],[1843,1881,"Oh,"],[1947,2064,"something just came up."],[2064,2147,"I need to head into work."],[2147,2248,"Can you watch Ellie for me?"],[2348,2435,"Oh, of course."],[2477,2540,"Thank you."],[2540,2598,"Ellie?"],[2761,2915,"Ellie, can you come in here please?"],[3232,3315,"So Natalie here"],[3315,3407,"is gonna watch you while"],[3407,3511,"I head to work this afternoon,"],[3511,3582,"alright?"],[3757,3962,"Be good, Ellie. Okay?"],[4129,4200,"I love you."],[4529,4562,"Thank you."],[5209,5367,"Hi, Ellie."],[8008,8120,"Do you like it?"],[8262,8379,"It's for you."],[10110,10243,"It's okay, Ellie."],[10406,10589,"If you change your mind,"],[10748,10981,"you can play with it anytime you want."],[11323,11444,"It's lunch time."],[11515,11703,"I'm gonna see what I can make for us."],[13938,14051,"Not so fast, Ellie."],[14051,14155,"Where'd that woman go?"],[14431,14597,"Ellie, who's at the door?"]],"7":[[12,141,"Ellie, who's at the door?"],[221,350,"So you must be Natalie,"],[367,475,"Rhett's new city wife."],[638,809,"Yeah, that's me."],[863,921,"And..."],[921,1001,"You are?"],[1184,1322,"Slutty little bitch."],[1363,1493,"Acting all innocent while throwing"],[1493,1572,"herself at Rhett?"],[1630,1730,"I'll get her out of here."],[1897,2060,"I'm Callie, Rhett's neighbor."],[2077,2198,"Oh, and Ellie's favorite."],[2218,2344,"Second to her dad, of course."],[2344,2406,"You could say I'm"],[2439,2615,"practically the lady of this house."],[2802,2936,"Ellie always wanted me to be her mom."],[3307,3486,"I'm the only one she'll open up to."],[3645,3799,"Was Rhett lying?"],[3908,4029,"Uh, so..."],[4099,4229,"Why haven't you married Rhett?"],[4350,4437,"Well, you see, my husband,"],[4466,4562,"he only passed a year ago."],[4637,4717,"And raising two kids,"],[4717,4796,"I just..."],[4796,4938,"haven't been ready yet."],[5013,5096,"Hey, you're hungry, right?"],[5234,5317,"It's your favorite."],[5484,5668,"Someone's already bitten into that."],[5814,5855,"So what?"],[5880,5926,"She's little,"],[5926,6051,"she doesn't need a whole slice anyways."],[6135,6235,"Are you kidding me?"],[6264,6402,"This is child abuse."],[6402,6548,"Just give her her own slice."],[6702,6735,"Okay."],[6735,6886,"Don't tell me how to take care of her."],[6886,6986,"You don't even have kids."],[7032,7136,"Just stick with what you're good at,"],[7136,7278,"and go back to your spoiled little life."],[7307,7357,"Here."],[8174,8279,"You bitch!"],[8279,8416,"You just threw out my pizza?"]],"8":[[266,483,"Sir, we finalized and signed the contract"],[483,692,"for the acquisition of all ten major farms."],[729,821,"Congratulations."],[821,963,"You're officially a billion dollar"],[963,1063,"business and landowner."],[1117,1155,"You"],[1176,1247,"own more land than"],[1247,1355,"anyone in the state now."],[1384,1451,"Make sure you keep"],[1451,1576,"a close eye on management."],[1659,1755,"Not just the farms,"],[1755,1856,"but the winery,"],[1856,2039,"the supply chains, the resorts."],[2064,2127,"If there's any problems,"],[2127,2198,"let me know, alright?"],[2223,2273,"Sure, boss."],[2318,2452,"But are you really planning on staying"],[2452,2523,"here at countryside?"],[2602,2731,"You're the richest man in the state."],[2731,2836,"You don't have to"],[2836,2973,"stay in the middle of nowhere."],[3482,3541,"Why not?"],[3616,3699,"Ellie loves it here."],[3862,3995,"My daughter's my whole world."],[4391,4446,"It's getting late."],[4446,4504,"Let's head back."],[4658,4763,"And I heard you see your new wife."],[4833,4900,"What do you think of her?"],[5280,5434,"She's definitely not what I expected."],[5784,5951,"Prepare a gift for her when we land."],[6085,6177,"I want to surprise her."],[6498,6569,"You bitch!"],[6569,6677,"You threw out my pizza?"],[6752,6835,"No."],[6835,6965,"I just tossed the crap"],[6965,7107,"a kid shouldn't be eating."],[7653,7866,"Stop acting like the perfect mom."],[7866,7970,"Okay, we're not weak like you,"],[7970,8058,"city folk."],[8058,8158,"We eat what we got."],[8404,8504,"I respect that."],[8529,8608,"Yeah."],[8846,8958,"If you like it so much,"],[9017,9109,"eat it yourself."],[9146,9380,"Ellie doesn't need leftovers."]],"9":[[62,216,"You think you're so much better than us,"],[216,283,"don't you?"],[425,571,"Rhett hates people like you!"],[571,704,"He'll kick you right out of here."],[1101,1247,"Even if I left,"],[1292,1451,"Rhett would never love a woman who"],[1472,1589,"bullies his kid."],[1747,1856,"Oh, please."],[1876,2043,"You don't know anything about Rhett."],[2043,2173,"I know him better than anyone."],[2173,2431,"Hell, I even know his underwear size."],[2535,2581,"Ew!"],[2581,2706,"What are you doing?"],[2740,2877,"Stay away from my family,"],[2877,2961,"you creep!"],[2961,3103,"No, you stay away!"],[3103,3219,"You're ruining everything!"],[3219,3324,"Ellie, Ellie, Ellie."],[3324,3436,"You hate her too, right?"],[3436,3620,"We can't let this woman stay here,"],[3620,3674,"okay?"],[3699,3774,"Do you understand-"],[4212,4287,"I'm telling Rhett"],[4320,4483,"everything you did to Ellie."],[4517,4571,"Really?"],[4571,4683,"Don't you dare!"],[4829,4967,"Bitch, Rhett is mine!"],[5055,5121,"Okay?"],[5163,5246,"Get off of me!"],[6406,6531,"What's going on?"],[6756,6823,"Come on, come on."],[6948,7002,"I..."],[7036,7173,"I caught her hitting Ellie!"]],"10":[[45,158,"Ellie can't talk."],[158,321,"So if it comes down to me or Natalie,"],[367,513,"Rhett's gonna believe me for sure."],[558,592,"I..."],[600,675,"I didn't."],[746,800,"Look at her hand."],[842,925,"It's bleeding."],[984,1084,"Oh, sweetie."],[1084,1151,"It's okay."],[1205,1255,"It's okay."],[1255,1334,"Daddy's here."],[2815,2948,"I was trying to bring Ellie pizza"],[2990,3090,"when this woman"],[3132,3199,"threw it out."],[3253,3411,"And then she shoved her to the ground."],[3461,3503,"Rhett,"],[3524,3712,"a woman like this is no good for a kid."],[3745,3787,"Look at her."],[3832,3966,"She's already abusing Ellie."],[3999,4091,"She's just picking on her"],[4091,4183,"because she can't speak up."],[4229,4316,"You can't let this woman"],[4316,4404,"near your daughter."],[4496,4637,"I would never hurt Ellie."],[4846,4996,"Ellie, don't be afraid."],[4996,5134,"Daddy and I are here."],[5134,5276,"She hurt you, didn't she?"],[5922,6022,"I thought you wanted to help."],[6093,6227,"Callie's lying."],[6227,6277,"I- -No."],[6677,6740,"Please leave."],[8254,8391,"No."]],"11":[[4,58,"Ellie!"],[150,250,"Ellie, you just spoke!"],[396,471,"Oh, God!"],[521,604,"She isn't mute?"],[663,750,"Oh my God."],[1155,1213,"Wait, wait..."],[1255,1355,"Tell daddy what happened."],[2932,3019,"You're saying Callie's"],[3019,3123,"the one that hurt you?"],[3374,3486,"No, Rhett."],[3566,3724,"I would never hurt your daughter."],[3724,3824,"You shoved Ellie"],[3824,3966,"and tried to pin it on me."],[4300,4396,"You're the one that threw out the pizza"],[4396,4479,"I brought her!"],[4479,4629,"Callie, get out of my house right now."]],"12":[[37,79,"Get out!"],[79,225,"Don't never come back here!"],[600,684,"I'm not letting that bitch"],[684,788,"get away with this."],[2469,2635,"My first day and I'm"],[2635,2769,"already in trouble."],[2769,2882,"I'll have to toughen up"],[2882,3003,"if I'm gonna survive here."],[3319,3574,"Damn, left the towel in the room."],[3628,3845,"I can't exactly walk in there naked."],[4896,4954,"Hello?"],[5021,5092,"Anyone there?"],[5226,5284,"Rhett?"],[5334,5384,"Good."],[5392,5472,"He's not in there."],[5505,5659,"I'll just go grab a towel and"],[5659,5864,"slip back in before anyone sees."]],"13":[[625,704,"Oh, God."],[767,892,"Could it get any worse?"],[942,1092,"Pinned down on the bed."],[1146,1226,"Naked?"],[3103,3244,"I'm so sorry."],[3319,3445,"I just put Ellie to bed"],[3445,3549,"and I didn't want to wake her up."],[3766,3820,"It's fine."],[3862,3991,"I'm decent now."],[4767,4867,"I, uh..."],[4896,5000,"I'm sorry about earlier."],[5067,5150,"For not believing you."],[5259,5355,"It's okay."],[5447,5584,"If I had been watching Ellie"],[5584,5651,"close enough,"],[5651,5772,"she wouldn't have gotten hurt."],[5964,6031,"Will she..."],[6085,6206,"hate me forever now?"],[6297,6373,"Of course not."],[6506,6598,"Natalie, because of you,"],[6598,6677,"I got to hear my daughter"],[6677,6735,"speak today."],[6852,7069,"So she won't hate me?"]],"14":[[70,287,"So she won't hate me?"],[850,984,"Ellie, I've never heard you speak up"],[984,1055,"to defence someone"],[1055,1138,"like that before."],[1297,1422,"Does that mean that you like Natalie?"],[2110,2214,"It's okay if you're not ready"],[2214,2348,"to accept her right now."],[2423,2552,"Let's give her a chance, alright?"],[2811,2869,"Great."],[2961,3040,"We'll take it slow."],[3244,3399,"She doesn't need to know the truth about"],[3399,3516,"our family just yet."],[3707,3837,"You know, I thought I could always do"],[3862,3970,"everything for my daughter,"],[3970,4070,"but as she gets older,"],[4070,4175,"I'm realizing that..."],[4308,4396,"There's just some things"],[4396,4512,"I can't do for her."],[4742,4879,"She deserves a whole family."],[5042,5146,"She deserves a mother"],[5146,5267,"who loves her unconditionally."],[5359,5568,"I want to be that family for her."],[5759,5868,"I like her."],[5960,6051,"I'll love her."],[6093,6193,"Steadily."],[6193,6302,"Wholeheartedly."],[6414,6448,"And..."],[6527,6656,"I really like to get to"],[6656,6752,"know each other better."],[6819,6956,"Listen, I want you to get to know us"],[6956,7036,"both better too."],[7082,7273,"But I know everything"],[7273,7369,"about you."],[7578,7774,"But you don't know anything about me."]],"15":[[37,233,"But you don't know anything about me."],[838,934,"Hey, I'm..."],[996,1176,"trying to have a serious"],[1176,1330,"conversation here."],[1330,1397,"So am I."],[1522,1605,"Okay."],[1680,1718,"Well..."],[1818,1964,"Then how does Callie know"],[1964,2085,"your underwear size?"],[2193,2248,"You two, like..."],[2360,2527,"Hooking up or something?"],[2627,2744,"Why are you laughing?"],[2802,2944,"I'd understand if..."],[2944,3011,"Maybe- -There's nothing"],[3011,3148,"going on between Callie and I."],[3174,3274,"She's just my neighbor."],[3274,3345,"I don't know why she"],[3345,3436,"even said that earlier."],[3803,3870,"Wait a minute."],[3966,4045,"Are you jealous?"],[4479,4575,"This man is..."],[4575,4700,"dangerously charming."],[4767,4904,"No wonder he's got women"],[4904,5071,"going crazy over him."],[5121,5201,"Relax."],[5309,5417,"Relax, okay?"],[5513,5626,"We can have plenty of time to get"],[5626,5693,"to know each other."],[5755,5922,"You're gonna get to know every..."],[6106,6218,"single part of me."]],"16":[[83,208,"No, uh..."],[208,312,"That's not what I-"],[1614,1697,"I guess there's no harm in a"],[1697,1851,"little introduction, right?"],[3561,3657,"You've got my measurements"],[3657,3712,"down now?"]],"17":[[575,617,"I..."],[617,729,"I need to get some sleep."],[767,821,"Which means"],[875,1092,"you should get to bed on the floor."],[1263,1309,"Alright."],[3353,3507,"Breakfast is served."],[3578,3741,"That looks better than I expected."],[4412,4458,"Hey, Ellie."],[4517,4621,"Maybe if you ask Natalie,"],[4621,4738,"she'll help you tie your hair."],[5388,5438,"Alright."],[5555,5626,"I guess I'll do it."],[5726,5780,"Let's go."]],"18":[[554,721,"What on earth?"],[771,946,"Is this how you always do her hair?"],[1055,1109,"Oh.."],[1213,1384,"Is this really how men think it's done?"],[1393,1472,"Yeah."],[1568,1634,"Come on."],[1655,1710,"Let me show you."],[1860,1931,"Come on."],[2031,2135,"Let me show you."],[4062,4179,"Do you like it, Ellie?"],[4383,4462,"From now on,"],[4496,4683,"I'll be in charge of styling your"],[4683,4846,"beautiful hair, okay?"],[5505,5584,"Thank you, Natalie."],[5801,5935,"Alright, I gotta take Ellie to school."],[6018,6072,"See you later."],[6965,7186,"Oh no, Ellie forgot her homework."],[7223,7353,"I'd better go take it to her."]],"19":[[704,855,"Let's give the mute girl"],[855,950,"a little surprise."],[2131,2231,"Looks like she's giving us a"],[2260,2381,"death stare."],[2381,2548,"What are you looking at, dummy?"],[2581,2715,"Want to cuss me out?"],[2715,2869,"Too bad you can't speak."],[2882,3015,"Bet your stepmom hates you."],[3073,3186,"I'll give her a week"],[3186,3290,"before she runs off."],[3361,3549,"You'll always be nothing but a"],[3549,3687,"motherless freak."],[4208,4270,"No."],[4362,4500,"Natalie wouldn't leave me."],[4696,4833,"Let's see what she packed for you."],[4867,5025,"It's probably dog food."],[5025,5071,"Yeah."],[5467,5580,"Either that or half-eaten"],[5580,5693,"pizza slices again."],[5730,5809,"You know what?"],[5851,6001,"You're just like a dog."],[6022,6247,"Always getting the leftover scraps."],[6464,6619,"Drum roll please."],[7636,7941,"Giving normal food to a freak like you?"],[7978,8145,"That's such a waste."],[8458,8612,"Let's add some special seasoning."]],"20":[[367,550,"Let's make sure it's bursting"],[550,663,"with flavor."],[796,930,"Your lunch, mute."],[963,1030,"Eat up!"],[1067,1138,"Eat it!"],[1543,1614,"Come here."],[1630,1697,"Hold her."],[1714,1793,"Watch this."],[2006,2081,"Just missing one"],[2081,2210,"very important ingredient."],[2356,2427,"Bon appétit!"],[6202,6272,"Ellie."],[6331,6481,"Do you understand what you did wrong?"],[7298,7415,"You need to apologize"],[7415,7494,"to these boys."],[7928,8153,"Ellie has nothing to apologize for."]],"21":[[29,75,"Oh."],[75,212,"Thank goodness you're okay."],[212,375,"I've been looking everywhere for you,"],[375,404,"Ellie."],[404,504,"Are you hurt?"],[721,855,"Ma'am, don't you want to hear"],[855,942,"the full story"],[942,1084,"before jumping to conclusions?"],[1172,1297,"Ellie is the culprit here."],[1363,1509,"She inflicted serious harm"],[1509,1609,"on her classmates."],[1664,1826,"How could one little girl"],[1826,2010,"beat up three boys on her own?"],[2064,2110,"Ma'am,"],[2147,2260,"these are honest boys"],[2260,2419,"from good families."],[2419,2619,"Motherless kids cause trouble here"],[2619,2677,"at school."],[2698,2865,"Perhaps she's just jealous because"],[2865,2965,"they got mothers at home."],[3123,3257,"That's ridiculous."],[3315,3499,"You're just making up excuses."],[3499,3620,"Do you have any proof?"],[3636,3720,"Who needs proof"],[3720,3858,"when you've got experience?"],[3924,4045,"I've been teaching at the school"],[4045,4137,"for fifteen years."],[4237,4375,"And one Teacher of the Year,"],[4375,4487,"three of those years."],[4742,4909,"The quiet, withdrawn girl."],[4959,5059,"Only have one parent"],[5059,5171,"coming to the school events."],[5251,5363,"Kids like these are always"],[5405,5551,"deeply troubled."],[5880,5935,"Whoa, whoa."],[6460,6589,"No, no, no..."],[6965,7157,"My trophy!"],[7157,7261,"Teacher of the Year?"],[7332,7428,"A good teacher"],[7444,7624,"wouldn't accuse a child of"],[7653,7824,"bullying without any evidence."],[8174,8350,"What the hell are you doing?"],[8350,8483,"You think violence"],[8483,8621,"is going to make things easier"],[8621,8700,"for Ellie?"],[8721,8979,"All she had to do was apologize"],[8979,9167,"and then we could all move on"],[9167,9309,"from this horrible day."],[9325,9471,"That makes no sense."],[9492,9626,"If she did nothing wrong,"],[9626,9772,"why should she apologize?"]],"22":[[8,125,"If she did nothing wrong,"],[125,275,"why should she apologize?"],[275,446,"You...you-"],[446,642,"You've got nothing to say, huh?"],[1159,1234,"So..."],[1297,1455,"Did she bully you guys?"],[1472,1630,"Or was it the other way around?"],[1664,1705,"We..."],[1743,1851,"We were just trying to"],[1851,1939,"have a little fun."],[2127,2285,"But she's the one who attacked us."],[2414,2610,"Just a little fun, huh?"],[2669,2694,"Okay."],[2723,2773,"Fine."],[2802,2932,"It was a misunderstanding."],[2932,3044,"Just kids horsing around."],[3065,3165,"Okay?"],[3486,3599,"That's not gonna cut it."],[3666,3812,"You knew they were bullying her."],[3812,4004,"You owe Ellie an apology."],[4216,4450,"You want me to apologize to her?"],[4846,5009,"Who the hell is bullying my kids?"],[5109,5163,"You again?"]],"23":[[467,529,"Oh my god."],[642,738,"Toby, Jace,"],[738,846,"tell mommy what happened."],[867,980,"She attacked us!"],[1255,1334,"What?"],[2394,2548,"What the hell are you doing?"],[2548,2669,"Teaching that dirty little stray"],[2669,2773,"some manners, that's what."],[2794,2990,"Callie, your kids are lying."],[2990,3103,"My kids are hurt,"],[3132,3219,"and she's going to pay."],[3332,3465,"I won't let you hurt Ellie,"],[3507,3678,"not now, not ever."],[3678,3874,"You don't even have kids, you bitch."],[3874,3987,"You have no idea what it means"],[3987,4079,"to be a mother."],[4079,4208,"Okay, you're only good at just running"],[4208,4316,"around trying to protect this"],[4316,4433,"troublemaking bastard."],[4596,4671,"Callie's right."],[4704,4825,"Freaks like Ellie can only grow up"],[4825,4913,"to be two things."],[4950,5088,"A criminal or a junkie."],[5159,5292,"Shut your mouths,"],[5326,5405,"both of you."],[5467,5613,"I'm going to report you both"],[5613,5889,"to the principal for assaulting a student."],[5930,6081,"See what happens to your kids then."],[6139,6185,"Go ahead."],[6256,6364,"Once he hears what Ellie did,"],[6364,6468,"he'll have to expel her."],[6598,6735,"Brats like her should never"],[6752,6827,"share a classroom"],[6827,6911,"with good boys like ours."]],"24":[[16,171,"What's that supposed to mean?"],[233,308,"Mr. White!"],[508,684,"Our kids come to school to learn,"],[713,817,"but how can they learn"],[850,984,"if they're fearing for their safety?"],[1126,1184,"Of course, ma'am."],[1184,1338,"We have a zero tolerance policy"],[1338,1480,"when it comes to bullying."],[1480,1605,"Listen, I'm not trying to sound"],[1605,1718,"insensitive, okay?"],[1776,1906,"But how does a mute freak like that"],[1906,2031,"end up in a regular classroom."],[2081,2206,"Especially a mute with serious"],[2239,2331,"anger issues like hers?"],[2515,2665,"I'm just looking out for the safety"],[2665,2723,"of our children,"],[2765,2798,"Okay?"],[2798,2861,"And the well-being"],[2861,2986,"of the school's reputation."],[2998,3061,"Exactly."],[3061,3174,"That girl has to go."],[3199,3328,"For the safety of our kids"],[3328,3449,"and for the school's image."],[3495,3545,"Otherwise,"],[3632,3703,"I don't think"],[3703,3812,"we can in good conscience"],[3812,3937,"let our children keep going here."],[3987,4062,"You're right."],[4062,4220,"This is some of the most despicable"],[4220,4387,"behavior I've seen in all my time"],[4387,4475,"at this school."],[4808,4888,"You're insane."],[4975,5163,"This isn't even about Ellie, is it?"],[5188,5380,"You're just using her to get at me."],[5413,5476,"So?"],[5505,5559,"What if I am?"]],"25":[[4,62,"So?"],[104,158,"What if I am?"],[254,375,"You even admit it."],[433,496,"You all"],[529,734,"are ganging up on a harmless little girl"],[734,859,"who can't even speak"],[859,971,"to defend herself."],[992,1138,"Getting scared now that she's about to"],[1138,1205,"get kicked out?"],[1234,1347,"If that mute had known her place,"],[1347,1484,"none of this would have happened."],[1509,1685,"So you do know they were bullying her?"],[2022,2156,"Okay, look, save the theatrics."],[2185,2248,"It doesn't matter"],[2248,2360,"what really happened."],[2402,2552,"All that matters now is that everyone in"],[2552,2673,"the school is going to turn against you,"],[2719,2873,"and that mute little brat."],[2927,3023,"So why don't you just give up and"],[3023,3103,"admit that you lost?"],[3211,3374,"Everyone's going to turn against us,"],[3374,3445,"are they?"],[3445,3495,"Huh."],[3970,4120,"I've recorded every single thing"],[4120,4204,"you just said."],[4483,4596,"Let's see who they side with"],[4596,4713,"after hearing that."]],"26":[[66,175,"You think that's gonna save you?"],[200,262,"Really?"],[312,462,"You recorded us without our consent."],[492,625,"That would never hold up as evidence."],[750,859,"Don't be so sure."],[913,1046,"I'll send it around,"],[1046,1155,"maybe even to the press."],[1213,1238,"Then,"],[1292,1463,"everyone will see who the real threat"],[1463,1547,"to the school is."],[1945,2030,"Go!"],[2410,2485,"Let me go!"],[2823,2969,"Gotcha, you little snake."],[3011,3078,"Give it back."],[3632,3720,"Oops!"],[3741,3853,"I guess there's no more evidence,"],[3853,3899,"I guess."],[4045,4195,"Don't you get it?"],[4220,4371,"Threatening me on my own turf"],[4371,4533,"is not a mistake you want to make."],[4658,4775,"So here's the deal."],[4775,4884,"You're going to admit that Ellie was"],[4884,5017,"bullying our kids,"],[5163,5242,"and then you're going to give us a"],[5242,5367,"heartfelt apology."],[5405,5530,"Then I'll let her off the hook."],[5530,5618,"There's not that many schools"],[5618,5672,"in this area,"],[5672,5784,"so if Ellie gets suspended,"],[5784,5893,"she'll just be,"],[5893,5989,"what, toiling around"],[5989,6081,"on farms forever?"],[6339,6560,"I can't let them expel Ellie."],[6560,6639,"So what's the deal?"],[6702,6760,"Are you gonna give us"],[6760,6886,"a sincere apology?"],[6948,7069,"Or is there gonna be a life"],[7115,7294,"wasted on farm laboring?"]],"27":[[79,275,"You swear you'll leave Ellie alone?"],[871,975,"Don't worry, Ellie."],[1046,1197,"I don't mind apologizing."],[1255,1451,"All that matters is that you're okay."],[1559,1797,"I chose to join Rhett and Ellie's family"],[1797,1989,"and that means doing whatever I can"],[1989,2047,"to help them."],[2544,2602,"Okay."],[2698,2781,"I'll apologize."],[3286,3370,"Great."],[3465,3553,"Speak, go!"],[3782,3883,"Callie."],[4546,4621,"I'm sorry-"],[4688,4750,"No!"],[4804,4875,"Mommy!"]],"28":[[4,196,"No, Mommy."],[900,1105,"What did you just call me, Ellie?"],[1251,1330,"Mommy."],[1680,1764,"She can talk?"],[1826,2002,"And she's calling that bitch her mom?"],[2081,2314,"Oh, thank you, sweetie."],[2406,2635,"I'll always be your mom, okay?"],[2740,2915,"I'll always be there for you."],[3228,3311,"Enough of this fake"],[3311,3411,"mother-daughter bullshit."],[3449,3528,"If she can speak,"],[3528,3687,"she has to apologize too now."],[3803,3891,"No."],[3983,4425,"They... always bully... lunch box."],[4508,4754,"They ruined your lunch, didn't they?"],[4909,5505,"They... always bully... don't let me eat."],[5543,5801,"They do that all the time, right?"],[5955,6222,"Oh, my poor baby."],[6414,6610,"I wish I could undo everything."],[6656,6806,"The ruined lunches,"],[6806,6915,"the humiliation,"],[6915,7027,"all of it."],[7720,7920,"Raising two bullies and then"],[7920,8128,"painting them as the victims?"],[8128,8329,"Amazing parenting, really."],[8433,8512,"Ellie."],[8637,8762,"We're not apologizing."],[8812,8933,"We're gonna fight back."],[9125,9225,"I promise"],[9225,9384,"I'll be here for you no matter what,"],[9384,9430,"okay?"],[9605,9851,"Now, time to make this right."]],"29":[[54,342,"You owe Ellie an apology."],[396,604,"I have a mommy now."],[629,1021,"She's... beautiful and brave,"],[1021,1201,"and she loves me."],[1276,1413,"Okay, who do you think you are,"],[1413,1539,"yelling at my precious children?"],[1539,1735,"This is all that brat's fault."],[2352,2485,"You hit me?"],[2485,2640,"Want me to do it again?"],[2640,2848,"Keep badmouthing Ellie, and I'll hit you"],[2848,2990,"harder next time."],[3090,3186,"Don't just stand there!"],[3186,3236,"Do something!"],[3236,3319,"This lady is crazy!"],[3319,3516,"She just hit me, for God's sake!"],[3516,3670,"Enough talking!"],[3670,3849,"I'm taking this to the principal."],[3891,4091,"You and your kids need to answer for"],[4091,4204,"their bullying."],[4245,4341,"Please."],[4358,4491,"The principal doesn't have time"],[4491,4604,"to see people like you."],[4654,4846,"You're not even that kid's real mom."],[4921,5105,"Since when did my school become a"],[5105,5246,"reality TV set?"],[5267,5363,"Principal Lee,"],[5363,5480,"what a surprise!"],[5647,5801,"Sir, you're the principal, right?"],[5860,5960,"I need your help."],[6022,6252,"These parents and their kids are all"],[6252,6398,"ganging up on my daughter."],[6452,6614,"They're trying to get her expelled."]],"30":[[29,158,"Ma'am, that's a serious allegation."],[158,279,"Do you have any evidence?"],[300,450,"Well, I did."],[500,579,"I recorded her"],[579,767,"admitting to everything,"],[767,909,"but she stole my recorder"],[909,1055,"and deleted it."],[1096,1234,"Ma'am, it's hard for me to believe"],[1234,1405,"such a claim without any clear"],[1451,1605,"and undeniable proof."],[1605,1851,"Then check the security footage."],[1881,2014,"These gang of brats are"],[2047,2164,"always bullying Ellie."],[2164,2323,"I'm sure we'll find something."],[2423,2552,"Ma'am, that's a good idea."],[2665,2736,"Bruce!"],[2736,2836,"Don't just stand there."],[2923,3057,"Go pull that footage."],[3261,3370,"Wait, this is all just a big"],[3370,3486,"misunderstanding, okay?"],[3561,3632,"What?"],[3632,3858,"Are your feet just glued to the floor?"],[3891,4029,"Go get that footage!"],[4300,4491,"And make sure it's wiped clean."]],"31":[[58,237,"And make sure it's wiped clean."],[604,759,"Clean up those boys, too."],[779,938,"Come on boys, follow me."],[1359,1580,"You're deleting evidence of"],[1580,1772,"them bullying my daughter?"],[2102,2335,"Mr. Lee, this lady hit me."],[2356,2502,"You have to back me up on this."],[2552,2702,"Or at least let me hit her back."],[2815,3019,"You're in on this together, aren't you?"],[3053,3261,"So, to review what happened here."],[3332,3478,"Ellie bullied those boys."],[3570,3837,"And then you assaulted Callie."],[3962,4062,"They're all just"],[4062,4179,"covering for each other."],[4204,4237,"God,"],[4237,4483,"this school is rotten from top to bottom."],[4512,4667,"I can't let Ellie stay at a place"],[4667,4750,"like this."],[4783,5005,"I'm pulling Ellie out of this school."],[5067,5213,"And this bullying..."],[5242,5409,"this covering it up,"],[5463,5730,"I'm going to expose all of it."]],"32":[[4,300,"I'm going to expose all of it."],[525,759,"My daughter deserves better"],[759,905,"than a corrupt school"],[905,1076,"that covers for bullying."],[1151,1284,"Don't you think, Ellie?"],[1518,1751,"Ma'am, I don't think you quite"],[1793,1951,"grasp the situation."],[1993,2118,"Your daughter is accused of"],[2118,2289,"violent bullying,"],[2289,2469,"and you're going to face legal trouble"],[2469,2606,"for the harm you've inflicted."],[2669,2823,"You're not in a position"],[2823,2915,"to make demands."],[2940,3044,"On the contrary,"],[3078,3207,"you should be preparing"],[3207,3324,"to pay damages."],[3353,3420,"Yeah, that's right."],[3465,3566,"My kids are going to need"],[3566,3741,"actual therapy to deal with the trauma"],[3741,3812,"that you've caused them,"],[3828,3970,"and you'll be paying for that."],[3970,4129,"Not to mention the damages you owe"],[4129,4316,"me for what that mute did to my son."],[4462,4567,"In your dreams,"],[4608,4796,"you're not getting a cent from me."],[4846,4959,"If you leave..."],[5009,5092,"The school will"],[5150,5276,"report you to the authorities."],[5359,5513,"And Ellie would have to"],[5513,5751,"appear in juvenile court."]],"33":[[104,329,"She could face severe punishment"],[371,496,"for her actions."],[596,713,"I could care less."],[713,804,"That little mute becomes a"],[804,892,"delinquent dropout."],[934,1009,"But you..."],[1197,1276,"You're going to pay up."],[1501,1651,"I don't have the money to pay them."],[1685,1901,"And if Ellie has to show up in court..."],[1939,2085,"What am I going to do then?"],[2206,2394,"I understand it might be difficult"],[2444,2615,"for you to afford the compensation."],[2723,2852,"You have two options."],[2919,2969,"Pay up"],[3086,3199,"or sign this"],[3269,3407,"and keep your mouth shut."],[3465,3607,"Don't let anybody hear"],[3649,3749,"what happened here."]],"34":[[129,212,"It's one thing"],[266,471,"not to address a bullying problem"],[471,579,"at your school,"],[608,829,"but intentionally covering it up."],[829,917,"The way I see it,"],[946,1067,"I'm just removing the person"],[1067,1205,"causing the problem."],[1247,1426,"That way there's no more problem"],[1426,1509,"to address."],[1601,1680,"I promise"],[1743,1926,"you're not going to get away with this."],[2060,2214,"I've been running this school"],[2214,2323,"for over ten years."],[2369,2548,"It's going to take more than one"],[2548,2811,"angry parent to scare me."],[2982,3036,"Mommy,"],[3194,3294,"we have money."],[3411,3541,"Don't sign..."],[3586,3657,"paper."],[3812,3924,"Oh, please."],[3978,4162,"Your family owns a couple of worthless"],[4162,4258,"patches of land."],[4283,4396,"Who are you trying to fool"],[4396,4592,"you stupid little liar?"]],"35":[[125,333,"Ellie, I know you're trying to help,"],[333,533,"but this is between the grown-ups, okay?"],[554,717,"You don't have to worry."],[875,996,"First things first,"],[996,1188,"I have to get Ellie out of here."],[3053,3161,"That's what you get."],[3465,3632,"What the hell is going on here?"],[4287,4416,"They called me."],[4416,4512,"Something's going on."],[4512,4562,"Are you alright?"],[4804,4846,"Daddy,"],[4963,5188,"they, they bully."],[5226,5367,"It's alright sweetie, daddy's here."],[5367,5426,"You're safe now."]],"36":[[45,221,"Rhett, wait, let me explain."],[271,421,"You don't need to explain anything."],[579,700,"I saw it all with my own eyes."],[700,834,"You just dumped this on my wife!"],[1121,1255,"And where'd those punks go, huh?"],[1255,1393,"They've been bullying my daughter."],[1447,1584,"Thank God for Natalie here,"],[1584,1668,"or else I would have never known"],[1668,1839,"any of this was going on."],[2147,2260,"Ellie, sweetie,"],[2260,2356,"how come you didn't tell me that"],[2356,2523,"you were being bullied at school?"],[2523,2869,"You're always busy and"],[2940,3128,"I didn't want you to worry."],[3307,3386,"Sir,"],[3457,3616,"your wife and daughter,"],[3678,3816,"they started this whole thing."],[3862,4016,"Everybody here saw it."],[4070,4158,"When I enrolled my daughter"],[4158,4212,"at this school,"],[4212,4371,"I trusted that she'd be safe."],[4496,4529,"And you,"],[4667,4788,"you let all of this happen"],[4788,4888,"under your nose."],[4888,5025,"You're a disgrace as a principal,"],[5025,5155,"and I demand that you step down."],[5176,5242,"What?"],[5680,5839,"Gavin, it's me."],[5872,5980,"Call the school board and"],[5980,6114,"have them fire Ellie's principal."],[6143,6218,"If they refuse,"],[6260,6443,"tell them we'll cut off all their funding."],[6535,6614,"Seriously,"],[6673,6823,"you expect me to believe some"],[6861,6981,"dirt poor farmer"],[7015,7211,"has pull with the Board of Education?"],[7691,7778,"Mm-hmm."],[7820,7916,"You're fired."],[8012,8087,"What?"]],"37":[[58,158,"What do you mean I'm fired?"],[204,358,"But what did I do?"],[508,588,"When did I ever"],[588,734,"cross a board member?"],[1009,1126,"What just happened, Mr. Lee?"],[1317,1493,"It seems I've been fired."],[1885,2218,"And you, you're just a poor farmer."],[2218,2364,"How could you possibly"],[2364,2481,"know anyone on the board?"],[2569,2690,"That's none of your business."],[2748,2857,"I believe they told you to do"],[2857,2969,"something else though, right?"],[3265,3445,"Your punks have been suspended."],[3482,3603,"And they have one strike"],[3603,3766,"on their permanent record,"],[3766,3970,"two more and they're expelled."],[3970,4104,"What? What?"],[4104,4279,"No, if Toby and Jace are suspended,"],[4308,4466,"then that could prevent them from"],[4466,4621,"getting into the top private high school."],[4658,4796,"This could ruin their future."],[4854,5009,"No, no, no, you can't do this."],[5009,5109,"You have to help them!"],[5238,5334,"Don't blame me!"],[5372,5534,"Your two troublemaking idiots"],[5534,5726,"brought this on themselves!"],[5989,6206,"Mr. Lee, Mr. White,"],[6252,6435,"you've both been fired for conspiring"],[6435,6544,"to cover up serious cases of"],[6544,6660,"bullying and harassment."],[6698,6835,"The police are waiting outside to"],[6835,6998,"escort you off the premises."],[8020,8078,"Ellie,"],[8158,8412,"no one is going to hurt you ever again."],[8612,8967,"Hey, put a smile on that pretty face."],[9009,9225,"A day like today is worth celebrating."],[9275,9488,"How about the three of us go into town?"]],"38":[[1376,1601,"Hi, welcome to the SHEIN pop-up store."],[1622,1697,"Come over here."],[1868,2052,"Here we have our Cozy Pixies."],[2097,2356,"It's all about cloud soft fabrics and"],[2356,2477,"playful styles for the little ones."],[2560,2706,"Perfect for your sweet pea here."],[2873,3015,"It's so cute."],[3265,3361,"Very cute."],[3461,3553,"And if you like that,"],[3553,3674,"you can come follow me over here."],[3937,4129,"And for the beautiful lady,"],[4129,4241,"we have SHEIN BAE."],[4279,4354,"Its sleek,"],[4354,4533,"glamorous styles truly shine."],[4592,4708,"You should definitely give it a try."],[4788,4950,"You can follow me to these other very"],[4950,5030,"cute items too."],[5313,5405,"And if you love a sweet,"],[5405,5484,"playful vibe,"],[5534,5647,"SHEIN MOD is it."],[5676,5839,"Fashion-forward pieces with the"],[5876,5980,"whimsical twist."],[10814,10890,"Daddy,"],[10977,11115,"can mommy"],[11115,11394,"tell me a bedtime story tonight?"],[11444,11549,"Yeah, of course she can."],[11966,12137,"Wait a minute, what did you just call her?"],[12170,12266,"Mommy."],[12412,12583,"She's my mommy."],[12841,13025,"Natalie's really something."],[13025,13133,"Ellie's never called anyone"],[13133,13242,"mommy before."],[13284,13375,"Not once."],[13526,13630,"Alright, sweetie."],[13688,13863,"How about you ask your mom if she'll"],[13863,14039,"read you a bedtime story tonight?"],[14159,14247,"Will you?"],[14293,14347,"Mommy?"],[14447,14577,"Of course, sweetie."],[14627,14756,"I can't believe this."],[14818,15140,"I really have the best daughter now."],[15198,15344,"You don't just have the best daughter,"],[15398,15507,"you have me too."],[15553,15694,"You have a whole family, Natalie."],[15811,15957,"Family is a great word."],[16020,16124,"We choose family,"],[16124,16257,"we hold family,"],[16295,16554,"and now I finally have my own."],[16758,16858,"After dinner,"],[16896,17058,"you two head home first, okay?"],[17108,17267,"I need to make another stop."],[17329,17496,"We can come with you."],[17496,17688,"No, it's a surprise."]],"39":[[1222,1267,"Mommy,"],[1388,1476,"thank you."],[1522,1710,"I love these new pajamas."],[1747,1993,"Oh, I'm so glad you like them."],[2077,2122,"Mommy,"],[2210,2373,"will I live a happy life"],[2394,2581,"like in the fairy tale?"],[2711,2781,"Of course."],[2852,2948,"All your dad and I"],[2948,3165,"want is for you to be happy."],[3299,3566,"Here, I got you a gift."],[4112,4270,"I love you, Ellie."],[4429,4571,"I love you, Ellie."],[4696,4783,"Wow, Ellie."],[4884,5038,"That's a pretty cool gift that Natalie"],[5038,5113,"got you."],[5180,5359,"I think I'm starting to get jealous."],[5359,5463,"Jealous."],[5876,5993,"All right, kiddo."],[5993,6085,"It's time for bed."],[6477,6573,"Good night."],[6631,6723,"Good night, sweetie."]],"40":[[225,333,"What is it, sweetie?"],[362,442,"Good night kiss."],[1151,1234,"Wait."],[1388,1518,"Daddy didn't give Mommy"],[1518,1630,"a good night kiss."],[1735,1935,"Oh, it's not necessary-"],[3482,3528,"Daddy,"],[3620,3916,"maybe we should tell Mommy the truth"],[3916,4008,"about our family."],[4333,4429,"I agree."],[4483,4633,"I'll tell her when the time is right."],[4758,5142,"But will she be mad that we lied to her?"]],"41":[[196,275,"Oh my God."],[304,571,"I think I'm actually falling for him."],[3236,3299,"Wow."],[3428,3570,"This Shein Musera look..."],[3616,3699,"it's stunning."],[3799,3949,"It's so unique."],[3949,4083,"It suits you perfectly."],[4225,4329,"Thank you"],[4329,4462,"for what you did for Ellie today."],[4604,4750,"She found her voice again and it's all"],[4750,4859,"because of you."],[5217,5372,"We're a family."],[5442,5647,"You two are my safety."],[5764,5830,"My pride."],[5930,6056,"The ones I will cherish"],[6056,6160,"and always guard."],[6210,6377,"You've been such a blessing for us."],[6514,6627,"You have no idea how much"],[6627,6731,"you mean to me."],[6769,6915,"I truly believe the"],[6915,7132,"best moments are holding the hand of"],[7132,7257,"someone who loves you."],[7294,7515,"Letting love guide the way and courage"],[7515,7620,"fill your heart."]],"42":[[229,354,"I need to tell you something."],[487,642,"I have something I have to tell you too."],[746,825,"Ladies first."],[1109,1213,"I just"],[1368,1505,"wanted to thank you for today."],[1555,1701,"If it weren't for your help,"],[1701,1843,"those awful people would have never"],[1843,1968,"left me alone."],[2122,2218,"Well, you know..."],[2740,2986,"I have an idea of how you can thank me."],[5050,5138,"I, um,"],[5201,5326,"got you a gift."],[6122,6189,"Here."],[6448,6502,"What is it?"],[6531,6669,"Uh, honestly, I don't know."],[6702,6865,"The guy at the store said it would be"],[6865,6948,"perfect for you."],[7278,7323,"Hmm."],[7323,7465,"Uh, wait, uh, but..."]],"43":[[75,246,"Wait, but..."],[467,583,"This must be a mistake."],[700,859,"I don't think so."],[1051,1217,"I think my wife"],[1217,1422,"knows exactly what I want."],[2097,2389,"No, I wasn't trying to seduce you."],[2389,2460,"I..."],[2489,2565,"thought it was a"],[2565,2740,"back massager or something."],[2994,3236,"Too bad you weren't trying to seduce me"],[3378,3566,"because that"],[3716,4016,"would be the best gift of all."],[6106,6260,"You like that, don't you?"],[6402,6664,"I... I didn't say that-"],[6664,6844,"Shh..."],[6915,7082,"Let your body do the talking."],[7932,8058,"You want me to keep going?"],[8729,8892,"Then wear that for me."]],"44":[[175,254,"Sure."],[1172,1234,"Nah, uh-uh."],[1459,1555,"Change here."],[5184,5246,"Satisfied?"],[6089,6231,"Not even close."],[9467,9567,"I've never met a woman"],[9567,9697,"like you before."]],"45":[[1117,1167,"Oh,"],[1272,1501,"you look beautiful in that dress."],[1889,2164,"Mommy, if you and daddy are married,"],[2227,2410,"how come you never had a wedding?"],[2498,2548,"Oh,"],[2702,2831,"your daddy's been busy."],[2907,3148,"We haven't had time to plan one yet."],[3148,3278,"Well, well, well."],[3324,3536,"Look at this cute little princess all"],[3536,3707,"dressed up in her Cozy Pixies."],[4408,4525,"I've got time now."],[4587,4733,"Ellie's right."],[4733,4863,"It's time that we have our wedding."],[4921,5084,"I want everyone to meet my kind and"],[5084,5159,"beautiful wife."],[5217,5255,"The woman who"],[5255,5397,"made my family whole."],[5968,6035,"Rhett."],[6202,6364,"Weddings are expensive."],[6406,6489,"I don't think we could"],[6489,6627,"afford one right now."],[6715,6844,"Don't worry about that."],[6844,6977,"I've got it covered."],[6977,7019,"Plus,"],[7065,7253,"I know the best bridal shop in town."],[7253,7344,"You're gonna love it."],[7453,7674,"It's probably a rundown little place."],[7724,7937,"Still, Rhett picked it out for me,"],[7937,8099,"and that means more than"],[8099,8241,"anything fancy ever could."],[8370,8571,"I wanna go to the bridal shop, too."],[8746,8850,"Then it's settled."],[8900,9063,"We'll make it a family outing."]],"46":[[2218,2339,"A new contract?"],[2410,2498,"I'll be there soon."],[2677,2827,"I gotta head out for a bit."],[2827,2907,"Go ahead, go inside"],[2907,3011,"and check everything out, alright?"],[3011,3132,"I'll see you soon."],[3707,3803,"Oh my god."],[3832,3962,"I had no idea it would be"],[3962,4108,"such a high-end shop."],[4149,4362,"Those gowns must cost a fortune."],[4550,4604,"Don't tell me"],[4604,4767,"you're just here to window shop?"],[4984,5088,"Well, don't just stand there,"],[5088,5205,"come on in, look around."]],"47":[[120,262,"These high-end shops"],[262,396,"sometimes look down on"],[396,583,"people who can't afford their stuff."],[713,842,"You've been watching too many"],[842,921,"short dramas."],[967,1117,"Most people can't afford our dresses"],[1117,1213,"and that's just fine."],[1267,1401,"Nothing wrong with looking around."],[1443,1601,"Plus, my boss is out of town today."],[1626,1789,"I'll let you try on anything you'd like."],[2711,2848,"Beautiful, aren't they?"],[2923,3069,"Every woman deserves to look like"],[3069,3240,"a princess on her wedding day."],[3311,3424,"We only sell here,"],[3424,3532,"no rentals, but we do have"],[3532,3682,"a clearance section over there"],[3682,3866,"with much cheaper options."],[3908,4049,"And best of all, they're all designed"],[4049,4204,"by Grace Peters herself."],[4320,4500,"You mean the Grace Peters?"],[4571,4788,"The star designer who makes wedding"],[4788,4929,"gowns for European royalty?"],[4954,5009,"That's right."],[5046,5163,"Most of our customers are"],[5163,5305,"well-to-do brides looking to"],[5305,5501,"make a major fashion statement."],[5530,5626,"Hey!"],[5626,5759,"Is anyone here?"],[5834,6064,"I want to see your best wedding gowns."],[6189,6318,"-Natalie? -Vanessa?"]],"48":[[0,50,"Oh,"],[120,171,"don't tell me"],[171,275,"you're here looking for a"],[275,329,"wedding dress."],[396,508,"Can you even afford this?"],[575,633,"Who's this?"],[692,767,"Natalie Smith."],[804,900,"Oh, wait,"],[930,1059,"it's Natalie Callahan now"],[1059,1197,"though, isn't it?"],[1197,1292,"Used to be my sister,"],[1292,1393,"but she's not part of"],[1393,1488,"the family anymore."],[1514,1568,"Oh,"],[1647,1739,"is this the one that"],[1768,1839,"ran off to the middle"],[1839,1926,"of nowhere and"],[1951,2085,"married some broke farmer"],[2131,2227,"and became a stepmom?"],[2256,2348,"The cheapest dress in here"],[2348,2473,"costs a fortune."],[2481,2619,"You could sell your entire farm and"],[2619,2806,"still never be able to afford it."],[2857,3032,"I didn't take a single cent"],[3032,3140,"when I left home."],[3232,3340,"She's probably right."],[3340,3482,"I can't afford a thing in here."],[3541,3661,"And you're stuck with a kid who's not"],[3661,3766,"even yours."],[3766,3845,"How sad."],[4058,4175,"You should go wedding dress"],[4175,4346,"shopping at a flea market."],[4346,4441,"Might as well save the money."],[4491,4583,"Watch it."],[4583,4763,"Ellie is my daughter."],[4763,4900,"Don't you dare say that again."],[5150,5338,"Cut the noble mom act and get out."],[5338,5455,"This place is only for elites."],[5497,5588,"Like us."],[5930,5980,"I..."],[5980,6168,"can't let them bully my mommy."],[6443,6514,"We have money."],[6548,6648,"We're rich too."]],"49":[[25,246,"My mommy can buy anything she wants."],[246,325,"Wow."],[358,542,"You really are desperate."],[542,704,"You've even got the kid playing pretend."],[729,804,"It's true."],[846,1009,"You're nothing but a broke farmer's kid,"],[1009,1134,"and that's all you'll ever be."],[1134,1259,"Who do you think you're trying to fool"],[1259,1380,"with this fake card?"],[1438,1543,"Country bumpkin."],[2122,2331,"And what makes you think you can insult"],[2356,2435,"my child?"],[2494,2686,"You haven't earned a cent of what you"],[2686,2798,"flash around."],[2857,2982,"Without your family's money,"],[3019,3078,"you're nothing."],[3228,3324,"Oh, well,"],[3324,3511,"I also have a rich husband."],[3511,3582,"What do you have?"],[3632,3741,"My mommy has me."],[3820,3887,"And daddy."],[3966,4120,"We're a real family."],[4120,4183,"You're not."],[4300,4396,"Who would want to be family"],[4396,4537,"with a bunch of broke nobodies?"],[4738,4808,"You're pathetic."],[4850,4909,"Enough."],[4954,5080,"She's probably just here trying on"],[5080,5238,"dresses so she can take pictures"],[5238,5305,"for her social."],[5392,5476,"Ugh!"],[5476,5576,"I can smell the cow manure"],[5576,5651,"on them already."],[5889,5939,"Get them out."],[5980,6043,"Or do you want to ruin"],[6043,6151,"this store's reputation?"],[6594,6694,"That was just a warning."],[6727,6906,"Now kick them out or one call from me"],[6906,6994,"and you're fired."]],"50":[[241,304,"No one's ever even"],[375,471,"raised their voice to me"],[471,575,"and you dare to hit me?"],[754,838,"I'm sorry, ma'am."],[863,988,"I really don't want to kick you out,"],[988,1151,"but I need this job."],[1230,1288,"It's fine."],[1355,1443,"Thanks for today."],[1480,1559,"It was really fun"],[1559,1680,"seeing all the wedding dresses."],[1901,1951,"Come on, Ellie."],[2081,2152,"Let's go."],[2323,2385,"Hey!"],[2464,2610,"You owe me an apology!"],[2952,3107,"You guys are leaving already?"],[3107,3240,"Did you not see anything you liked?"],[3307,3349,"Natalie!"],[3395,3495,"Stop right there!"],[3536,3687,"Where's my apology?"],[4187,4266,"You're the farmer"],[4266,4391,"from that broken down ranch?"],[4450,4521,"Yeah, that's me."],[4562,4642,"Is there a problem here?"],[4800,4833,"I just thought"],[4833,4929,"you'd look much..."],[5034,5084,"worse."],[5430,5522,"But looks aren't everything."],[5559,5726,"Money's what really counts, right?"],[6639,6790,"They just ignored us?"]],"51":[[442,563,"You owe me an apology,"],[563,721,"you little hicks."],[721,838,"You're the one being rude,"],[867,1017,"and now you're just getting a little bit"],[1017,1084,"of payback."],[1105,1151,"The commission"],[1151,1234,"for my wedding dress"],[1234,1434,"alone can pay this clerk's rent for the"],[1434,1518,"next couple of months."],[1568,1689,"What are you bringing to the table,"],[1718,1826,"outside of teaching your kid"],[1826,1885,"to lie?"],[2102,2135,"Daddy,"],[2252,2385,"they don't believe me."],[2456,2540,"Know your place."],[2577,2736,"Flashing around a fake bank card"],[2736,2840,"doesn't make you rich."],[2898,3015,"I'm a state senator."],[3015,3182,"My family has real money"],[3182,3269,"and power."],[3269,3353,"Yours just has dirt."],[3395,3457,"Leon's right."],[3516,3561,"Let us show you"],[3561,3712,"what real wealth looks like."],[3745,3866,"What's the most expensive dress"],[3866,3916,"you have here?"],[3945,4037,"We'll take it."],[4946,5005,"All right, sir."],[5005,5138,"Six million's all set."],[5138,5263,"The dress will be sent to your house."],[5338,5413,"See?"],[5476,5609,"My wife can buy whatever she wants."],[5655,5780,"I doubt the two of you could afford a"],[5780,5880,"single lace on that dress."],[5922,6026,"We're in different leagues."],[6097,6122,"You know,"],[6122,6235,"that dress might be pricey,"],[6235,6327,"but it's mass produced."],[6585,6664,"My wife deserves"],[6664,6902,"something truly unique."],[6969,7040,"Big words,"],[7082,7148,"coming from someone"],[7148,7307,"who could never afford it."],[7323,7407,"I ordered Natalie"],[7407,7478,"a custom dress."],[7582,7707,"Specially made for her."]],"52":[[0,66,"What?"],[141,225,"A custom Grey Scout"],[225,396,"cost ten million dollars."],[396,571,"Are you hearing yourself right now?"],[596,671,"Yeah."],[671,792,"I ordered her a custom dress"],[892,1034,"with diamonds and pearls"],[1034,1113,"and everything."],[1113,1230,"I talked to Grace yesterday."],[1230,1405,"She said it arrived from Italy, right?"],[1463,1539,"One moment."],[1601,1743,"Let me confirm."],[1743,1810,"I can't wait to see"],[1810,1956,"how long you can keep this up."],[2239,2385,"It's here in the VIP lounge."],[2460,2506,"No way."],[2560,2627,"Let me see."],[2627,2673,"I'm sorry."],[2731,2902,"Custom gowns are for the client only."],[2902,3053,"Yeah, right."],[3053,3123,"You're bluffing."],[3219,3390,"There's no custom gown."],[3603,3749,"What's going on?"],[3749,3791,"Ma'am,"],[3791,3908,"what are you doing here today?"],[3966,4066,"I'm here for the client"],[4066,4191,"that ordered my Italian gown."],[4216,4350,"Today's the fitting, isn't it?"],[4375,4429,"What?"],[4466,4546,"No."]],"53":[[0,79,"What?"],[145,266,"No, this can't be real."],[296,458,"There's been a serious mistake."],[458,583,"This broke farmer"],[583,696,"is claiming that he ordered"],[696,813,"a custom gown from you."],[846,967,"He's trying to scam you."],[1476,1659,"Rhett, you're here."],[1805,1876,"Hi, Ellie."],[1876,2010,"It's been so long."],[2085,2189,"Natalie, this is Grace."],[2189,2323,"Her and my mom are best friends."],[2460,2565,"You're Rhett's wife."],[2565,2786,"You're absolutely beautiful."],[2915,3073,"You know, Rhett tortured me"],[3073,3174,"over your dress."],[3207,3365,"Fourteen different designs."],[3420,3607,"He even had me travel to Italy to"],[3607,3737,"personally supervise"],[3737,3820,"the embroidery."],[3845,3974,"Also, his wife could wear the most"],[3974,4170,"beautiful gown in the world."],[4312,4416,"You never mentioned."],[4550,4675,"I wanted it to be a surprise."],[4988,5117,"Why does she get a custom dress?"],[5163,5213,"You didn't think that"],[5213,5313,"I might want one?"],[5313,5447,"What will people say?"],[5447,5497,"I..."],[5630,5759,"Whatever they paid, I'll double it."],[5809,5901,"That custom dress,"],[5901,5989,"we'll take it."],[6051,6160,"Absolutely not."],[6210,6381,"It belongs to my friend."],[6381,6606,"It carries his love and respect"],[6627,6694,"for his wife."],[6727,6844,"If you would like a custom piece"],[6844,6902,"of your own,"],[6981,7148,"you can contact my assistant."],[7219,7328,"I can wire you eight million"],[7357,7482,"right now for it."],[7482,7553,"Eight million?"],[7657,7828,"Is that supposed to be an insult?"],[7874,8191,"This is easily a 20 million dollar gown."],[8412,8558,"There's no way in hell"],[8596,8804,"this broke farmer is buying a 20 million"],[8804,8875,"dollar dress."]],"54":[[33,271,"They're just trying to humiliate us."],[271,400,"Don't let them get to you."],[454,508,"Don't worry."],[508,654,"Daddy, show them."],[1997,2068,"Your $20 million"],[2093,2193,"payment's been approved."],[2323,2398,"What?"],[2398,2431,"No way."],[2469,2531,"How does this guy have"],[2531,2619,"more money than me?"],[2686,2727,"Please leave."],[2786,2973,"This store is booked out for my VIP"],[2973,3057,"clients today."],[3057,3128,"I don't believe it."],[3219,3349,"This has to be some sort of"],[3349,3482,"sick fucking joke."],[3516,3649,"You're trying to make your broke friend"],[3649,3778,"look rich, aren't you?"],[3845,4083,"Security, escort them out."],[4087,4162,"What?"],[4241,4379,"No. Stop. Don't."],[4379,4425,"Stop it."],[4471,4562,"Don't touch me."]],"55":[[45,183,"Let's go have a look at your dress,"],[183,250,"shall we?"],[1317,1376,"Wow."],[1497,1680,"I've never seen a d