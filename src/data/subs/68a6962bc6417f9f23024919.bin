6559,"Tell her to come see me."]],"29":[[76,300,"She thinks she owns the Smith Group!"],[367,580,"At least your brain isn't entirely useless."],[580,653,"Enough!"],[797,967,"I've had enough arguing"],[967,1191,"with a sweet,"],[1191,1334,"insecure,"],[1334,1408,"beautiful,"],[1408,1491,"little,"],[1491,1551,"weak"],[1641,1711,"girl like you."],[1751,1898,"My girlfriend is on her way here."],[2018,2148,"Just apologize."],[2442,2629,"You have a death wish, you bitch!"],[2819,2886,"Mama!"],[3043,3176,"Your girlfriend's on the way, is she?"],[3176,3259,"Yes."],[3259,3450,"Let's see what kind of girl would want a man like you."],[3586,3680,"Here she is."],[3777,3983,"Who here's bullying my boyfriend?"]],"30":[[53,210,"Danni, you're finally here!"],[210,420,"This woman is hitting me and Bobby!"],[420,533,"Yeah, and she's pretending!"],[533,607,"She's pretending"],[607,777,"to be the heiress of the Smith family!"],[814,864,"Let me see..."],[864,940,"Who the hell are..."],[1227,1274,"What?"],[1274,1317,"What's wrong?"],[1775,1885,"Miss Smith, I'm sorry."],[1941,2042,"I didn't know it was you."],[2135,2298,"And who were you expecting?"],[2298,2415,"If it weren't me today,"],[2415,2565,"then would you be using the Smith name"],[2565,2692,"to bully others?"],[2692,2796,"No, no."],[2836,2972,"Why are you calling her Miss Smith?"],[3009,3086,"This is just my..."],[3113,3293,"useless sister's adopted daughter."],[3380,3450,"Shut up!"],[3450,3513,"You idiot!"],[3513,3596,"You're going to ruin me!"],[3660,3747,"What's wrong with you?"],[3813,3863,"Miss Smith,"],[3863,4017,"I've already broken up with this man."],[4067,4277,"And I will never have anything to do"],[4277,4381,"with this family again."],[4451,4557,"Please, just believe me,"],[4587,4758,"and give me one more chance."],[4878,4958,"Who is she?"],[5068,5105,"No."],[5171,5355,"You said that you were gonna marry me."],[5402,5518,"In your dreams!"],[5588,5725,"I was just playing with you."],[5775,5849,"Marry you?"],[5955,6112,"You're not even worthy"],[6112,6269,"of stepping into my house."],[6269,6359,"Don't say that."],[6473,6523,"Are you done?"],[6673,6763,"Weren't you going to make sure"],[6763,6883,"I didn't leave here alive?"],[7020,7140,"Too scared now?"],[7193,7327,"If not, I'm taking her with me."],[7450,7550,"Go back to the company."],[7550,7650,"Start at the bottom."],[7711,7874,"This is your last chance."],[7917,7994,"Thank you, Miss Smith!"],[9686,9803,"You're breaking up with me?"],[10096,10173,"I'm sorry."],[10230,10353,"I should've been there sooner."],[10493,10590,"You're my daughter."],[10663,10877,"I should be protecting you instead."],[11151,11207,"But..."],[11311,11531,"why was Danni so afraid of you?"]],"31":[[190,240,"Well..."],[370,650,"I work with Mr. Smith every day,"],[650,710,"so..."],[780,904,"I know some of the higher-ups."],[1037,1071,"Then..."],[1267,1468,"why did she call you Miss Smith?"],[1648,1698,"Uh..."],[1758,2005,"it's a sign of respect."],[2055,2158,"It's a nickname."],[2339,2525,"I'm worried about affecting your job."],[2672,2822,"What if Danni spreads rumors"],[2822,2986,"that you're abusing your power?"],[3139,3179,"Don't..."],[3219,3279,"worry."],[3453,3633,"They'll face dire consequences."],[3673,3817,"Anyone who hurts you"],[3817,3903,"won't get away with it."],[4050,4107,"Forget it."],[4194,4401,"I won't have anything to do with them anymore."],[4761,4944,"Just don't tell Michael about this."],[4944,5121,"He'll get angry and worry about me."],[5335,5398,"Please,"],[5495,5618,"I don't want to trouble him."],[5618,5769,"He works so hard."],[6042,6106,"Okay,"],[6229,6373,"but please remember,"],[6373,6553,"no matter what happens,"],[6613,6790,"you can rely on me and Dad."],[6960,7073,"We're your family now."],[7180,7362,"I'm so lucky to have you both as family."],[7530,7615,"Thanks, Sophie."]],"32":[[724,784,"Michael!"],[840,947,"I got my salary,"],[974,1097,"and a bonus!"],[1144,1327,"It's $10,000!"],[1508,1741,"My boss is being so kind to me!"],[1741,1821,"Really?"],[1821,1898,"We should celebrate."],[2082,2232,"Let me take you out to dinner."],[2232,2278,"Sure."],[2328,2415,"Pick somewhere nice."],[3299,3446,"It's a really nice thing that we can do."],[3446,3526,"Hi, Boss!"],[3526,3670,"Are you here to inspect our work?"],[3907,4030,"Inspect work?"],[4080,4137,"Boss?"]],"33":[[53,106,"Michael..."],[276,363,"What's going on?"],[423,473,"Well,"],[527,567,"it's just..."],[567,657,"No, don't lie to me."],[717,737,"Okay?"],[737,889,"I can't handle being deceived"],[889,1004,"or cheated on again."],[1004,1087,"It's just a joke."],[1144,1332,"You know, guys like to hype each other up."],[1461,1501,"Right?"],[1591,1765,"Yeah, I was just joking around."],[2072,2172,"Why don't you go on inside?"],[2198,2302,"I'll catch up with my friend."],[2362,2479,"Okay, I'll wait for you."],[3199,3279,"Amy."],[3503,3566,"Harry."]],"34":[[76,253,"Still stubborn as ever, huh?"],[276,423,"Stay away from me!"],[423,647,"Last time, I didn't tell you."],[647,1001,"My wife passed away and left me a fortune."],[1084,1204,"I'm richer than ever now."],[1244,1428,"You could've had all this"],[1428,1538,"if you hadn't left me."],[1538,1715,"I'm not interested in your money."],[1715,1828,"You know I'm married now."],[1855,1955,"To who?"],[1998,2035,"Huh?"],[2198,2262,"Come on."],[2305,2455,"You're better off with me."],[2559,2665,"Be my mistress."],[2699,2822,"I'll take care of you."],[2822,3056,"I'd rather die than be with you again."],[3083,3216,"You're not going anywhere."],[3216,3316,"Take your hands off her!"],[3556,3663,"Who the hell are you?"],[3700,3770,"Her husband."],[3770,3890,"And if you touch her again,"],[3940,4004,"you'll regret it."],[4644,4761,"You're dead!"],[4791,4851,"You hear me?"],[4878,5035,"You're not even in my league."],[6129,6162,"Yeah,"],[6232,6389,"find out everything about Amy."],[6433,6523,"Where she works,"],[6523,6593,"who she's with,"],[6636,6780,"everything we can use to threaten her!"]],"35":[[243,337,"Harry!"],[530,700,"What do you want, Harry?"],[1411,1654,"You can't keep giving me prank calls!"],[1781,1888,"Quit your job."],[1971,2035,"Come back,"],[2112,2268,"and be my mistress."],[2385,2459,"Do that,"],[2505,2632,"and maybe..."],[2676,2919,"I'll let him keep his miserable life."],[2966,3119,"You're disgusting."],[3293,3450,"If you don't,"],[3450,3697,"then I'll take everything from you."],[3820,3870,"Jobs,"],[3903,3983,"stability,"],[4017,4064,"hope."],[4137,4414,"You'll never find out where Nina is."],[4571,4724,"You know where Nina is?"],[4774,4858,"Maybe I do."],[4911,5008,"Maybe I don't."],[5148,5298,"But if you wanna find out,"],[5298,5546,"you'll do exactly what I say."],[5905,5989,"Think about it."],[6086,6246,"But don't take too long."],[6339,6509,"My patience is wearing thin."]],"36":[[370,430,"Michael,"],[570,770,"I think we need to get a divorce."],[814,860,"What?"],[1057,1117,"Why?"],[1224,1364,"Did your ex-husband threaten you?"],[1568,1651,"I'll handle it."],[1818,1908,"He said he might know"],[1908,2042,"something about Nina."],[2125,2172,"I..."],[2332,2499,"I can't risk losing her again."],[2499,2632,"I'll take care of this."],[2632,2716,"I promise."],[2716,2766,"How?"],[2842,2926,"You're a plumber."],[3036,3076,"You can't..."],[3119,3283,"fight somebody like him."],[4354,4534,"Do you have any idea who I am?"],[4534,4611,"You're dead!"],[4611,4674,"All of you!"],[4828,4984,"I know exactly who you are."],[4984,5035,"Ah!"],[5475,5532,"You...?"],[5662,5732,"Now,"],[5815,5945,"let's talk about..."],[5995,6142,"what you know about Nina."],[6282,6463,"And what you are planning to do..."],[6579,6663,"with Amy."]],"37":[[40,156,"Look, look, look."],[156,323,"Let's just be reasonable, okay?"],[350,520,"If you let me go, I'll give you more money"],[520,684,"than you've ever seen in your life, okay?"],[684,740,"Just..."],[740,814,"just let me go."],[860,917,"Money?"],[1081,1224,"Let me enlighten you."],[1311,1388,"This here"],[1438,1538,"is Michael Smith,"],[1611,1849,"as an CEO of Smith Group."],[1901,1988,"Michael Smith."],[2068,2238,"The man owns half of LA"],[2272,2502,"and could buy and sell your pathetic life,"],[2535,2732,"hundred times over before breakfast."],[2732,2842,"Smith... Smith Group?"],[2842,2906,"Hi, look,"],[2906,3119,"I didn't know it was you, okay, Michael?"],[3119,3189,"I didn't know."],[3189,3283,"I swear to God!"],[3456,3560,"Amy is my wife."],[3613,3743,"I don't like seeing her upset."],[3803,3850,"Do you understand?"],[3887,4067,"I'll disappear from LA, okay?"],[4067,4180,"I'll move to another country."],[4180,4320,"You'll never see me again."],[4320,4374,"I swear!"],[4507,4557,"So,"],[4607,4738,"tell me what you know about Nina."],[4738,4831,"I don't know anything!"],[4831,4951,"Her stepmother abandoned her"],[4951,5065,"in the mountains years ago."],[5065,5125,"That's all I know."],[5338,5472,"You made a lot of mistakes, Harry."],[5568,5752,"But lying to Amy about her daughter?"],[5859,6012,"That's the last mistake"],[6012,6099,"you'll ever make."],[6226,6436,"Your assets have been frozen."],[6506,6596,"Your company?"],[6656,6750,"Bankrupt."],[6816,6986,"And you'll be lucky to leave LA"],[6986,7113,"with the clothes on your back,"],[7170,7213,"hmm?"],[7711,7847,"If I ever see you again,"],[8001,8091,"you'll regret it."]],"38":[[80,223,"Michael, have you heard?"],[256,453,"Harry's company's gone bankrupt."],[500,593,"He's left LA."],[697,734,"Just..."],[787,867,"vanished."],[910,967,"Yeah,"],[1031,1201,"guess karma finally caught up with him."],[1267,1331,"Guess so."],[1698,1818,"The universe seems to be"],[1818,1928,"looking out for me."],[1975,2105,"People who hurt me"],[2105,2292,"seem to get what's coming to them."],[2315,2389,"You're blessed."],[2465,2562,"Anyone messes with you?"],[2602,2699,"They're asking for trouble."],[2879,2952,"You always know"],[2952,3083,"how to make me feel better."],[3206,3313,"I have to head to work."],[3313,3380,"I'll see you tonight."],[3436,3483,"Okay?"],[4310,4457,"Always forgetting something."],[5852,6019,"What's Michael doing here?"]],"39":[[0,56,"Really good."],[56,126,"Really appreciate it."],[186,250,"Amy,"],[360,453,"what are you doing here?"],[720,820,"You forgot this."],[1177,1344,"Michael, what's going on?"],[1344,1464,"You said you were a plumber."],[1464,1494,"Wh..."],[1551,1755,"Why are you being fawned over here?"],[1818,2008,"I'm here to fix the pipes, but..."],[2008,2108,"the boss's daughter..."],[2108,2288,"She kind of took a liking to me."],[2555,2742,"Wants to sign me on a long-term contract."],[2779,2842,"That's why..."],[2842,2949,"everyone's being nice to me."],[3089,3186,"What?"],[3273,3456,"You're selling yourself for money?"],[3723,3817,"No!"],[3817,3930,"You're my husband!"],[4170,4277,"Who gives you the right to"],[4277,4424,"pester my husband like this?"],[4491,4631,"You think you can do whatever you want"],[4631,4748,"just because you're rich?"]],"40":[[23,163,"Michael is married to me."],[163,430,"And I won't let him sell himself for money,"],[430,643,"no matter how much you offer him."],[643,677,"Here!"],[867,987,"Here's his \"breakup fee\"."],[1211,1434,"Consider the contract cancelled."],[1828,1888,"You're right."],[1888,1971,"It's my fault."],[2022,2155,"I won't do it again."],[2155,2225,"I'm sorry."],[2409,2482,"Let's go home."],[2529,2699,"I never wanna see this place ever again."],[2699,2802,"It's disgusting!"],[2802,2849,"Yeah."],[2942,3016,"Let's go!"],[3106,3249,"You're promoted."]],"41":[[186,256,"So..."],[300,400,"you're jealous."],[400,512,"You stormed into the building"],[512,663,"like a superhero"],[663,837,"to rescue me from Olivia?"],[837,1004,"Oh, rescue you?"],[1004,1234,"Oh, I was saving Olivia from you."],[1388,1498,"Who knows what kind of trouble"],[1498,1584,"you might've caused"],[1584,1728,"if I didn't keep an eye on you?"],[2018,2075,"Admit it."],[2145,2248,"You were jealous."],[2379,2559,"In your dreams, plumber boy."],[3596,3656,"What?"],[3656,3857,"Why didn't you tell me about Amy's family?"],[3857,4000,"I..."],[4000,4113,"I didn't wanna worry you."],[4113,4180,"I thought I could..."],[4180,4275,"You can't decide"],[4275,4424,"what I need to know about Amy."],[4564,4714,"I'll let those bastards pay!"]],"42":[[220,286,"Watch out!"],[470,530,"Stop!"],[573,680,"What am I being arrested for?"],[680,834,"You're under arrest for sexual assault."],[834,890,"For sexual..."],[890,950,"By who?"],[1034,1161,"You can't do this!"],[1161,1274,"The two of you are being investigated"],[1274,1344,"for child abandonment."],[1344,1468,"You're gonna hear from my lawyer."],[1468,1588,"You'd best tell us what you know."],[1588,1651,"Come on!"],[2459,2595,"Why is she taking so long?"],[2632,2882,"She's probably still at the police station."],[2882,2986,"Anyways, Dad,"],[2986,3083,"it's time."],[3139,3306,"After what happened today with Olivia,"],[3306,3433,"you HAVE to tell her!"],[3486,3570,"Tell her tonight!"],[3613,3817,"I just need ONE more day."],[3817,4050,"I've been meeting with the board and..."],[4584,4744,"What's with the awkward silence?"],[5592,5665,"Amy,"],[5665,5799,"there's something I need to tell you."],[5855,5935,"What is it?"],[6332,6433,"I'm not a plumber."],[6616,6723,"I'm the CEO"],[6810,6876,"of the Smith Group."]],"43":[[93,160,"What?"],[196,283,"You're... what?"],[550,714,"Michael, are you feeling okay?"],[757,927,"CEO of the Smith Group?"],[1027,1167,"Did you hit your head"],[1167,1284,"fixing pipes today?"],[1431,1521,"See for yourself."],[2005,2152,"This could be photoshopped."],[2245,2332,"Amy, it's true."],[2465,2529,"I'm the CEO."],[3286,3346,"Ruby."],[3483,3533,"What?"],[3596,3710,"Daniel's in the hospital?"],[3760,3853,"Okay, I'm coming."],[4117,4207,"I have to go."],[4364,4434,"I'll drive you."],[5205,5348,"Amy, thank God you're here!"],[5348,5412,"What's happened?"],[5488,5548,"Daniel,"],[5642,5752,"he collapsed at home."],[5805,6036,"The doctor said he has a heart condition."],[6136,6266,"He needs a transplant."],[6409,6556,"Heart transplant?"]],"44":[[33,136,"You need to get tested"],[173,256,"right away."],[256,326,"You're his mother."],[326,350,"You..."],[403,513,"You could be a match!"],[1181,1244,"I'll do it."],[1331,1411,"No way!"],[1471,1508,"You'll die!"],[1508,1648,"This is the only way"],[1711,1808,"to save Daniel!"],[1901,1981,"You're..."],[1981,2082,"his mother."],[2155,2243,"Are you just gonna..."],[2243,2435,"just gonna watch him die?"],[2602,2645,"Mom..."],[2956,3053,"We'll figure this out."],[3109,3173,"Trust me."],[5011,5158,"You've still decided to test?"],[5362,5482,"He's my son."],[5632,5699,"I..."],[5699,5825,"I lost Nina."],[5962,6096,"I can't lose him too!"],[6353,6579,"I'll do whatever it takes to save him."],[6643,6796,"I'll pay for the best treatment"],[6796,6916,"and the best doctors."],[6970,7050,"I'll save him."],[7100,7163,"Trust me."],[7250,7333,"Michael,"],[7420,7587,"I need you to understand."],[7684,7817,"This is my decision."]],"45":[[180,393,"You keep your mouth shut."],[527,707,"Amy needs to donate."],[707,764,"It's the only way."],[764,917,"What if something happens to her?"],[917,1024,"Then that's her choice."],[1131,1327,"But you're not gonna say a word."],[1881,1951,"Sir,"],[2025,2175,"we've investigated the hospital."],[2225,2402,"It's not Daniel with the heart condition."],[2545,2655,"It's Ruby's mother."],[2692,2732,"What?"],[2826,2922,"Ruby's been lying."],[2962,3049,"Daniel's fine."],[3136,3223,"Get the car."],[3223,3283,"Now!"],[3590,3807,"Amy, you have to donate."],[3807,3973,"You're the only match."],[3979,4124,"—I... —Enough!"]],"46":[[6,149,"—I... —Enough!"],[153,273,"You're not sick, are you?"],[703,830,"This was all a lie."],[924,994,"I..."],[994,1040,"I didn't mean to..."],[1040,1170,"And you let your mother risk her life"],[1170,1259,"for a lie?"],[1327,1528,"You don't deserve to call yourself her son."],[1618,1751,"This is none of your business!"],[1751,1868,"You manipulated Amy,"],[1868,1968,"lied to her,"],[1968,2078,"and put her through hell."],[2121,2218,"To save your own mother?"],[2398,2535,"It's always been about money,"],[2572,2635,"hasn't it?"],[2685,2896,"How about you keep your mouth shut?"],[3129,3179,"Daniel..."],[3349,3469,"You lied to me."],[4057,4123,"Let's go, Amy."]],"47":[[720,880,"Don't waste your tears on Daniel."],[960,1057,"He's not worth it."],[1111,1274,"Can't believe he lied to me."],[1688,1751,"Amy,"],[1881,1981,"we need to talk."],[2038,2242,"You've got some nerve showing up here."],[2242,2349,"Here's some more money."],[2349,2445,"Agree to the surgery,"],[2445,2589,"and this is yours."],[2932,3119,"You think you can buy me?"],[3199,3253,"Ruby."],[3319,3390,"STOP!"],[3680,3833,"You've gone too far this time!"],[5048,5138,"What..."],[5181,5268,"are you doing?"],[5422,5558,"I am done with your lies."],[5658,5799,"And I'm done with you."],[5835,5901,"We're over."]],"48":[[46,136,"You're leaving me?"],[176,276,"You have hurt me"],[320,437,"too much in this life,"],[437,650,"but I will not allow you to hurt my mom."],[1434,1524,"What's going on?"],[1811,1951,"This is my house,"],[1951,2055,"and you're not welcome."],[2132,2185,"Leave."],[2258,2315,"Now."],[2592,2849,"You think you can just waltz in here and play the hero?"],[2916,3036,"If you don't,"],[3036,3236,"I can't promise the safety"],[3236,3386,"of your entire family."],[3583,3670,"This isn't over!"],[4094,4247,"You got a lot to make up for, kid."],[4778,4821,"Mom..."],[5001,5058,"I am..."],[5145,5235,"so sorry."],[5385,5472,"I know that"],[5472,5618,"I don't deserve your forgiveness,"],[5739,5789,"but..."],[5859,5972,"I wanna make this right."],[6222,6299,"Daniel,"],[6423,6529,"you hurt me."]],"49":[[10,86,"Daniel,"],[210,316,"you hurt me."],[1524,1671,"But you're still my son."],[2405,2499,"With time,"],[2622,2726,"I can forgive you."],[3056,3103,"Mom,"],[3189,3266,"I promise"],[3329,3453,"that I will be a better son."],[4320,4424,"You're signing these."],[4471,4652,"You're giving up custody of your daughter."],[4674,4728,"No."],[4778,4854,"I'm not."],[4898,5011,"She is my daughter."],[5308,5442,"You don't have a choice."],[5492,5762,"You sign it now or you'll never see her again."]],"50":[[93,143,"Daniel!"],[143,220,"This is illegal."],[413,483,"Illegal?"],[680,857,"No one knows the law better than me!"],[890,944,"Is that so?"],[1184,1321,"I need you at Daniel's house."],[1358,1404,"Now."],[1614,1718,"Who are you calling?"],[1718,1838,"You plumber friends again?"],[2302,2359,"Mr. Smith,"],[2409,2462,"you called?"],[2679,2769,"What?"],[2769,2812,"Boss..."],[2856,3006,"how does this plumber know you?"],[3006,3066,"You idiot!"],[3119,3253,"Do you know who you've offended?"],[3253,3333,"You're fired."]],"51":[[6,66,"This"],[66,176,"is the CEO"],[176,250,"of Smith Group."],[393,453,"And you?"],[510,684,"You dare to use your shallow eyes"],[684,794,"to look down on him?"],[1104,1184,"It's true?"],[1254,1451,"You're really the CEO of Smith Group."],[1568,1628,"I told you."],[1675,1765,"You should've trusted me."],[1828,1978,"We're filing a complaint"],[1978,2118,"to the bar of association."],[2192,2295,"Your career as a lawyer"],[2359,2432,"is over."],[2432,2529,"Miss Carter,"],[2529,2615,"please, no."],[2615,2676,"I can..."],[2676,2799,"I can explain this."],[2839,2989,"This... this can't be happening..."],[2989,3076,"Miss Carter,"],[3076,3236,"please, you can't do this."],[3236,3306,"My family..."],[3306,3583,"Family's actions have consequences, Ruby."],[3656,3783,"This is non-negotiable."],[4247,4297,"Daniel."],[4431,4477,"You..."],[4477,4674,"You can't let them do this to my family."],[4754,4944,"We... we can fix this."],[4944,5115,"We can get back together."]],"52":[[86,136,"Ruby."],[283,363,"It's over."],[567,754,"We can co-parent for the baby's sake,"],[794,864,"but we"],[937,1097,"are never, ever"],[1141,1241,"getting back together!"],[2902,3069,"This was your real home?"],[3153,3303,"This is our home."],[3573,3700,"I don't know what to say."],[3737,3847,"You don't need to say anything."],[4087,4210,"Just know that I love you,"],[4304,4481,"and I want to spend the rest of my life with you."],[5301,5342,"Amy."],[5829,5929,"Will you marry me?"],[6196,6276,"Yes!"],[6322,6429,"Michael, yes!"]],"53":[[1571,1651,"Daniel..."],[1651,1771,"where did you get this?"],[2025,2092,"This is Nina."],[2185,2272,"She's my sister."],[2302,2465,"She disappeared when we were very young."],[2699,2759,"This?"],[2889,2976,"This is me."],[3099,3196,"What are you talking about?"],[3246,3323,"This photo..."],[3583,3643,"I think..."],[3690,3807,"I'm Nina."],[3967,4094,"No, that's..."],[4094,4214,"It's impossible."],[4274,4507,"I was abandoned when I was little."],[4664,4811,"I don't remember much, but..."],[4811,4898,"this is me."],[5065,5118,"But..."],[5181,5301,"if that's true,"],[5455,5578,"then you're my sister."],[5668,5789,"I think I am."]],"54":[[63,160,"Sophie?"],[160,263,"What's happened?"],[316,380,"Miss Amy,"],[380,527,"do you recognize this photo?"],[937,1021,"It's Nina!"],[1247,1348,"Where did you get this?"],[1601,1725,"Daniel gave it to me."],[1725,1895,"I have something I need to show you."],[2826,2912,"It's you!"],[3159,3263,"My baby girl!"],[3289,3366,"Mom!"],[3713,3887,"I never stop looking for you."],[3997,4077,"It's a miracle."],[4120,4207,"I can't believe it."],[4324,4514,"Daniel... my brother!"],[4621,4774,"Finally, whole again."]]}