{"1":[[597,674,"I'll head home,"],[747,924,"get things ready, then come pick you up."],[954,1027,"Okay."],[1027,1161,"I'll go pack my stuff, too."],[2148,2268,"Do you know what I mean?"],[2268,2355,"And everyone just needs..."],[2355,2425,"Daniel,"],[2492,2655,"I just got married!"],[2742,3059,"Mom, you got married to who?"],[3156,3236,"You have..."],[3283,3430,"—Yeah! —You got married?"],[3470,3536,"Congrats."],[3626,3807,"Who's the unlucky guy?"],[3850,3990,"Ruby's mom? I..."],[3990,4260,"Oh, did you marry some homeless dude?"],[4324,4511,"I can't imagine anyone wanting you."],[4511,4921,"I mean, no offense, but you're just so average."],[5031,5171,"Don't say that, okay?"],[5171,5331,"He's a really nice guy."],[5331,5488,"Oh, really?"],[5658,5872,"I guess I'll just have to see for myself."],[5919,6007,"We could meet him"],[6007,6262,"at our baby's birthday party."],[8284,8321,"Look!"],[8355,8538,"Mr. Smith is finally here!"]],"2":[[133,288,"I've got to try and make a good impression"],[288,340,"on him."],[353,517,"What if he takes a fancy to me..."],[567,640,"Come on."],[2876,3063,"Now, what are you up to?"],[3163,3203,"Dad!"],[3203,3385,"Why would I be trying to trick you?"],[3420,3533,"I'm your dearest daughter."],[3860,3943,"Surprise!"],[3997,4117,"Let me know who you like"],[4117,4280,"and I'll set up a meeting with anyone"],[4280,4354,"right away."],[4420,4481,"Sophie,"],[4481,4741,"you've been pushing me a million times to get married."],[4768,4904,"Why don't you start dating first?"],[5031,5195,"I'm not dating till you get married."],[5308,5395,"Okay, okay."],[5508,5705,"If I see someone I like, I'll let you know."],[5805,5952,"I'll be waiting for the good news."],[6656,6706,"Mom!"],[6773,6880,"What are you doing here?"],[6913,7053,"I came to see my granddaughter."],[7230,7290,"Daniel,"],[7384,7550,"who are you talking to?"],[7550,7630,"Ruby,"],[7737,7837,"I bought a gift."],[7837,7987,"I want to see the baby."],[7987,8054,"Yeah,"],[8054,8250,"my daughter only plays with real..."],[8250,8365,"cashmere dolls!"],[8475,8709,"Never bring this trash to my house ever again,"],[8709,8872,"you tasteless old nanny!"],[8878,8950,"Ruby,"],[9005,9199,"don't speak to my mother like that."]],"3":[[3,136,"Watch your mouth!"],[383,597,"This is my house."],[657,760,"You've already used up"],[760,904,"all your luck by marrying me."],[904,1041,"You wouldn't even have a job,"],[1041,1131,"if it weren't for me."],[1427,1554,"Look at your ragged clothes."],[1554,1654,"Did you come straight from the"],[1654,1741,"homeless shelter?"],[1851,2112,"Your stench is gonna make my baby cry."],[2202,2302,"Now, get out!"],[2445,2502,"I'll go."],[2592,2686,"I'll go right away."],[2686,2772,"Just..."],[2772,2889,"Please,"],[2889,2996,"don't hit him."],[3636,3790,"Mom, I'm sorry, I..."],[3790,3927,"No, it's my fault."],[4457,4537,"It's..."],[4794,4871,"It's my fault"],[4871,5085,"that I wasn't able to give you a better life."],[5265,5362,"I'm sorry."],[5505,5635,"Just go."],[5635,5755,"Don't annoy her."],[5895,6029,"No, Mom, wait."],[6072,6264,"You sold your house"],[6264,6389,"so that I could get married."],[6389,6569,"Where are you going to stay?"],[6569,6760,"After your sister went missing,"],[6923,7067,"I only have you."],[7187,7454,"I'm willing to give you everything that I have."],[7704,7854,"Don't worry about me."],[7854,7987,"I have a place to stay."]],"4":[[770,817,"Help!"],[910,994,"Somebody!"],[2055,2192,"Miss! What's wrong?"],[3450,3520,"Are you okay?"],[3670,3747,"Do you need me to bring you to"],[3747,3847,"the hospital?"],[3847,3987,"I'm alright."],[4100,4174,"Thank you!"],[4247,4304,"You're lucky."],[4304,4511,"I come from a family of asthmatics."],[4511,4738,"I carry this thing around with me everywhere."],[5091,5185,"Miss..."],[5235,5288,"Amy."],[5318,5405,"Miss Amy,"],[5732,5829,"are you single?"],[6022,6159,"I'd love for you to meet my dad."]],"5":[[16,70,"I'm sorry,"],[70,143,"I'm busy."],[143,316,"I have a job interview with the Smith Group."],[316,387,"Oh, please."],[387,580,"Let me just set up one dinner."],[580,630,"Just one."],[630,767,"He'd love to meet you."],[1521,1815,"Miss Amy, this is my dad."],[1815,1939,"He said he wants to thank you"],[1939,2092,"for saving me!"],[2268,2405,"Mr. Smith,"],[2405,2665,"if you're still going to attend the blind date,"],[2665,2832,"I can cancel the meeting for you."],[2862,3020,"Since she saved Sophie,"],[3020,3169,"I should go and thank her."],[3269,3426,"But... to avoid some trouble..."],[3653,3770,"Go and buy me something."],[4868,4952,"I'm Michael."],[4952,5086,"Sophie's always"],[5086,5298,"pushing me to go on blind dates."],[5298,5412,"I'm Amy."],[5412,5532,"I'm a nanny."],[5532,5692,"Also single."],[5692,5852,"I have a son who's married."],[5949,6169,"Hoping to find someone we can live with."],[6249,6439,"But... in my situation,"],[6506,6706,"I'm on a $2,000 salary."],[6706,6780,"I'm a plumber."],[6893,7000,"Sorry to disappoint you."],[7070,7206,"I'm sure you can find someone"],[7206,7299,"better than me."],[7330,7547,"But you did save Sophie,"],[7547,7654,"so..."],[7654,7921,"I wanted to invite you to a meal to repay you."],[7921,8001,"Thank you."],[8001,8131,"That's very kind of you."],[8988,9179,"No, this is too expensive."],[9179,9409,"I can't let you waste your money like this."],[9462,9592,"Let's go somewhere cheaper."],[9592,9819,"I know a place that makes delicious sandwiches."],[9896,9986,"Let me take you there."],[10326,10380,"Okay."],[10550,10607,"Wait."],[10804,10924,"Now, it's okay."],[11184,11414,"I used to raise my children alone."],[11414,11608,"Daniel was a bit of a germaphobe."],[11695,11815,"You're a very attentive mother."],[11885,12045,"I can tell you love your children very much."],[12045,12187,"I'm sure you feel the same way"],[12187,12292,"about Sophie."],[12452,12519,"It tastes good!"],[12625,12709,"Do you often have this?"],[12832,12952,"Well, I'm busy at work"],[12952,13179,"and I don't have much money for food."],[13179,13430,"This is cheap and filling."],[13430,13505,"I mean, you don't"],[13505,13656,"earn your money easily either."],[13656,13833,"So, it's better to save."],[15442,15648,"I'm so sorry... I..."],[15839,15915,"Let's get married..."],[16119,16196,"if you're willing."],[16643,16823,"I just got married!"],[16823,16926,"I'll head home,"],[16926,17113,"get things ready, then come pick you up."],[17537,17787,"Go buy a small apartment for me."],[17787,17887,"Not downtown,"],[17957,18124,"somewhere cheap-looking."],[18241,18304,"I'm moving in."],[18355,18428,"Yes, Boss."],[18862,18905,"Dad,"],[18962,19132,"you didn't tell Miss Amy who you are?"],[19225,19376,"You're such a liar!"],[19436,19652,"I'm just waiting for the right moment to tell her."],[19699,19859,"But I'm curious..."],[20020,20153,"why do you like her so much?"],[20427,20520,"She seems..."],[20707,20777,"familiar..."],[20840,20894,"to me."]],"6":[[397,443,"Hey!"],[870,1041,"My parents left me this apartment."],[1084,1157,"It's small."],[1261,1354,"I hope you don't mind."],[1441,1534,"Of course not."],[1588,1801,"I'm just happy to have a place to stay."],[2395,2485,"That's Nina,"],[2549,2619,"my daughter."],[2786,2942,"She went missing years ago."],[3169,3363,"I've been searching for her ever since."],[3747,3883,"You're lucky to have Sophie."],[3920,4010,"She's very sweet."],[4087,4234,"Sophie's my adopted daughter."],[4351,4441,"She lost her memory"],[4441,4591,"and couldn't find her family,"],[4591,4711,"so I took her in."],[4791,4881,"You're kind."],[5055,5271,"I hope my Nina finds someone like you."],[5311,5368,"She will."],[5448,5638,"I'll ask my friends to help find her."],[5759,5835,"I promise,"],[6039,6132,"you'll be reunited."]],"7":[[133,323,"Wow, wow!"],[323,530,"Amy, long time no see."],[530,597,"You..."],[690,860,"changed boyfriends again?"],[860,937,"Jessica!"],[1027,1117,"Mind your words."],[1177,1287,"He's my husband."],[1311,1381,"You know her?"],[1421,1553,"Amy was the top student"],[1553,1708,"in our college class."],[1708,1891,"Too bad she ended up getting dumped"],[1891,2048,"and becoming a filthy nanny."],[2162,2335,"And now she's married to a plumber?"],[2379,2452,"Jessica!"],[2602,2756,"Maybe we could go somewhere else."],[2756,2912,"Yeah, get out of here!"],[2959,3213,"Our clothes are designer, top brand!"],[3213,3420,"You couldn't even afford a button here!"],[3420,3636,"So, that's how you treat your guests?"],[3707,3817,"I know your type."],[3893,4047,"All talk, no money."],[4087,4294,"Do you even know how much this dress costs?"],[4374,4694,"It costs $50,000!"],[4694,4911,"You couldn't afford it for as long as you lived."],[4911,5038,"It's too expensive."],[5061,5158,"Let's just go."],[5321,5412,"What if I have this?"]],"8":[[276,347,"Michael,"],[397,517,"where did you get that card?"],[550,740,"I heard it's reserved for billionaires."],[777,1064,"You can't fool me with this fake card."],[1064,1124,"Look at you!"],[1124,1270,"You're just a currish plumber,"],[1270,1511,"just acting to be rich!"],[1538,1701,"Go and call your manager."],[1781,1841,"Now!"],[1861,1968,"Who's asking for me?"],[2098,2195,"Oh, Mr..."],[2572,2839,"Sir and ma'am, how may I assist you today?"],[2866,3079,"Your \"assistant\" thinks we're too..."],[3079,3276,"poor and filthy to shop here."],[3323,3393,"What do you think?"],[3576,3623,"What?"],[3623,3733,"Are you blind?"],[3733,4124,"Sir, I deeply apologize for my employee's behavior."],[4124,4230,"As compensation,"],[4230,4394,"pick any item in the store today."],[4394,4507,"It's yours, free of charge."],[4507,4574,"What?"],[4574,4654,"Why would you do that?"],[4711,4904,"Shut up, or you'll never speak again."],[4958,5135,"So, we'll have her serve us."]],"9":[[2155,2352,"Sir, is everything to your liking?"],[2352,2435,"You,"],[2435,2569,"help my wife with her shoes."],[3400,3480,"Thank you."],[3693,3853,"Let's pack up everything she's wearing."],[4407,4504,"I don't get it."],[4504,4718,"Why are we treating them like royalty?"],[4718,4831,"You idiot!"],[4871,4928,"You're FIRED!"],[4928,5005,"Get out!"],[5412,5492,"Hey, Dad!"],[5528,5618,"Miss Amy!"],[5642,5879,"I got a gift for Daniel and his family,"],[5879,5959,"for the party."],[6279,6563,"This costs more than my entire savings!"],[6846,6966,"And it says..."],[6966,7177,"Smith Family Exclusive?"],[7557,7617,"Oops."]],"10":[[50,150,"Well,"],[150,343,"I have a friend that works there"],[343,573,"and I got a huge discount."],[574,697,"Lucky, right?"],[697,931,"But it still looks so expensive."],[931,1048,"Oh, that's just the..."],[1108,1254,"fancy packaging."],[1315,1428,"Really, it's no big deal."],[1692,1818,"I gotta take this."],[1818,1895,"It's work."],[1955,2042,"Is it urgent?"],[2129,2352,"Shall I head to the restaurant first?"],[2352,2399,"Alright."],[2462,2572,"I'll catch up with you soon."],[2736,2836,"I'll see you there."],[3240,3633,"Give the Los Angeles order to Amy's in-laws."],[3747,3824,"Let's help them out."],[4134,4220,"Our project"],[4220,4371,"with the Smith family's almost done!"],[4371,4551,"Only one signature away."],[4551,4624,"Well,"],[4624,4851,"that means we're finally moving up in the world."],[4851,5135,"So, Daniel, where's your mom?"],[5222,5405,"Is she lost?"],[5405,5629,"I guess she's not used to places like this."],[5629,5782,"She'll be here, just wait."],[5782,6009,"And what about your new \"Dad\","],[6009,6089,"the plumber?"],[6149,6259,"Does he even own a suit"],[6259,6490,"or is he gonna show up in his work boots?"]],"11":[[507,640,"Amy!"],[640,877,"Did you get lost on your way here?"],[877,1021,"Or were you too busy..."],[1101,1307,"picking out this interesting outfit?"],[1344,1554,"More like she couldn't decide which thrift store"],[1554,1715,"to stop at on the way here."],[1921,1958,"Mom,"],[2022,2158,"you, you came alone?"],[2192,2335,"Michael will be here shortly."],[2455,2525,"Hi, sweetheart."],[2605,2645,"Don't..."],[2672,2846,"touch my baby with your dirty hands!"],[2846,2989,"You stay away from her!"],[2996,3039,"Ruby,"],[3086,3176,"stop it."],[3206,3289,"She's my mom."],[3533,3603,"It's okay."],[3963,4030,"Yeah, yeah."],[4077,4197,"Listen to your mom."],[4417,4611,"She's used to being treated like trash,"],[4684,4758,"isn't that right?"],[5031,5125,"Oh, look!"],[5178,5492,"A \"Smith Family Exclusive\" gift."],[5839,5962,"How thoughtful..."],[6056,6200,"Did you think you could get away"],[6200,6393,"with this fake garbage?"],[6566,6703,"Do you think we're idiots?"],[7043,7160,"What is wrong with you?!"],[8948,9182,"Nina's the same age as me..."],[9225,9426,"Does that mean Amy is my...?"]],"12":[[16,123,"What is wrong with you?"],[320,517,"You dare speak up for her?"],[517,777,"Do you think you have a voice in this family?"],[777,874,"She's my mom!"],[874,990,"So what?"],[990,1097,"We're about to become"],[1097,1414,"the biggest partner of the Smith family in LA!"],[1414,1511,"And Ruby..."],[1511,1631,"is our only daughter."],[1631,1811,"So, you better remember that."],[1878,1991,"And that's right."],[1991,2092,"If Ruby's unhappy,"],[2092,2308,"she can kick you and your leech mother"],[2308,2399,"out on the street,"],[2399,2575,"just like the trash you are!"],[2625,2712,"Let it go."],[2712,2856,"Don't fight because of me."],[3323,3403,"You..."],[4110,4240,"Amy's dinner is here."],[4454,4597,"My wife's expenses are on me."],[4641,4698,"Take care of her."],[4721,4784,"Dirty..."],[4811,5015,"small-town simpleton!"],[5078,5281,"My patience is wearing thin"],[5281,5495,"with you and your useless husband"],[5495,5655,"wasting my time!"],[5855,5895,"Boss,"],[5989,6136,"there's a fight at one of the tables."],[6166,6349,"A guest named Amy is getting bullied."],[6383,6436,"What!?"]],"13":[[20,136,"Get away from her!"],[306,663,"You dare push me for this bitch?"],[937,1151,"Does that mean Amy is my...?"],[1277,1501,"How could you be so unreasonable?"],[1795,2012,"You dare touch my daughter!"],[2102,2219,"You think anyone would care"],[2219,2362,"if I killed you right here?"],[2409,2539,"A guest named Amy is getting bullied."],[2539,2615,"What!?"],[2839,2986,"Don't touch my mom!"],[3219,3476,"You think you can save your useless mother?"],[3476,3586,"Let me make this clear."],[3586,3727,"It's never gonna happen."],[3870,4054,"Oh, what's wrong?"],[4054,4194,"Cat got your tongue?"],[4194,4374,"Not so tough now, huh?"],[4584,4657,"Stop!"]],"14":[[106,150,"Stop!"],[397,540,"Are you okay, Miss Amy?"],[540,660,"You'll pay for this!"],[660,877,"Oh, so you're Amy's fling,"],[934,1061,"her cheap plumber?"],[1121,1204,"Pay for it?"],[1327,1454,"Who do you think you are?"],[1561,1634,"Apologize,"],[1661,1841,"otherwise you won't be walking out of here!"],[2035,2245,"I've already caused you so much trouble."],[2245,2350,"No, no..."],[2439,2559,"I'll apologize."],[2602,2746,"Let's just end this."],[2746,2789,"No."],[2896,2939,"I'll do it."],[3016,3146,"You think you have a choice?"],[3276,3319,"YOU!"],[3370,3546,"You get on your knees,"],[3593,3800,"and you lick Karen's shoes clean."],[3800,3867,"Now!"],[3900,4014,"The last person who demanded"],[4014,4147,"an apology from me..."],[4197,4280,"is dead."],[4507,4587,"Did you hear that?"],[4637,4921,"This plumber thinks he's some kind of mob boss!"],[4998,5220,"Oh, is that how poor people dream big?"],[5345,5372,"No."],[5422,5645,"Do you know who we are?"],[5719,5945,"We are about to close a major deal"],[5945,6062,"with the Smith family."],[6139,6509,"It would be an honor for you to apologize to us."],[6576,6764,"You with the Smith family?"],[6813,6925,"That's never happening."],[6960,7047,"Not in this lifetime."]],"15":[[73,173,"You and the Smith Group?"],[236,347,"That's never happening."],[383,500,"Not in this lifetime."],[500,724,"Need I remind you that you're just a..."],[837,990,"cheap, useless plumber?"],[1057,1181,"You have one minute to get here,"],[1224,1428,"or you'll never show up to anything again."],[1494,1531,"What?"],[1594,1791,"You calling your plumber friends for help?"],[1951,2032,"It's too late."],[2075,2162,"You're done for!"],[2412,2562,"David, perfect timing!"],[2642,2866,"This useless, wannabe plumber"],[2866,2952,"is spouting nonsense"],[2952,3099,"about cancelling our deal!"],[3191,3260,"—Oh! —Whoa."],[3329,3380,"Shut up!"],[3420,3563,"Take your people and get out!"],[3563,3693,"I don't wanna see you again."],[3783,3987,"David, what about our project?"],[3987,4142,"Your family's being blacklisted"],[4142,4230,"by the Smith Group"],[4270,4334,"permanently!"],[4344,4417,"No!"],[4417,4531,"You can't do this to us!"],[4577,4718,"You promised us this deal!"],[4894,5068,"Because you don't know who you've messed with."],[5201,5285,"Go home,"],[5285,5485,"and think about what you've done."],[5658,5792,"This is all your fault!"],[5885,6112,"You fucking piece of shit!"],[6146,6316,"You've ruined my family!"],[6383,6498,"I'll kill you!"],[6498,6566,"Be careful!"]],"16":[[30,126,"I'll kill you!"],[126,210,"Be careful!"],[370,420,"Mom!"],[503,590,"You'll regret that!"],[757,860,"Get them out of here!"],[860,1137,"Don't let them step foot in here ever again!"],[1304,1367,"No!"],[1911,2022,"Miss Amy, are you hurt?"],[2105,2222,"I'm sorry I came late."],[2222,2362,"I'll protect you in the future,"],[2405,2499,"I promise."],[2622,2769,"How come you can make decisions"],[2769,2922,"in place of Mr. Smith?"],[3009,3063,"And..."],[3183,3390,"why does David seem to respect you"],[3390,3466,"so much?"],[3586,3626,"Well..."],[3707,3943,"I sometimes fix Mr. Smith's pipes,"],[4027,4124,"so, David knows me."],[4260,4357,"And I also know"],[4424,4607,"that Ruby's family will never work with them."],[4754,4934,"Let's get you home, Miss Amy."],[4934,5035,"You need to rest."],[5769,5835,"Thank you."],[6566,6639,"Miss Amy,"],[6840,7003,"how long have you been"],[7003,7103,"looking for your daughter?"],[7203,7320,"How did she go missing?"],[7384,7486,"Um..."]],"17":[[146,400,"Nina went missing when she was very little."],[563,720,"I went to work that day."],[910,1071,"She went out to look for me."],[1448,1591,"I never saw her again."],[1751,1811,"I'm sorry."],[1811,1908,"I shouldn't have asked."],[2022,2125,"I remember"],[2125,2235,"being taken up"],[2235,2369,"to the mountain by my parents"],[2369,2459,"and abandoned."],[2519,2692,"Amy loves her daughter too much..."],[2749,2849,"She's not my mother."],[2956,3083,"Michael tells me that"],[3083,3296,"you've been looking for your birth mother."],[3426,3523,"I wanna find her."],[3847,4034,"I want to ask her how she could be"],[4034,4184,"so heartless..."],[4184,4287,"as to throw me away."],[4524,4711,"If Dad hadn't been passing by"],[4711,4831,"and found me, I..."],[4991,5156,"No mother would ever wanna"],[5156,5308,"abandon their child."],[5465,5682,"Your mother may have had her reasons."],[5815,5939,"Maybe like me,"],[5939,6172,"she's been searching for you ever since."],[6279,6403,"You know, sometimes I think if..."],[6519,6609,"you were my mom,"],[6780,6906,"I wouldn't be so lonely."],[7130,7237,"I'm here now."],[7354,7557,"And I see you as my daughter."],[8058,8101,"Yeah."],[8221,8321,"I am your daughter."],[8398,8441,"Yeah."],[8495,8635,"And I'll help you find Nina."],[9659,9723,"Michael,"],[9766,9883,"what are you doing here?"]],"18":[[83,143,"And..."],[203,353,"why are you dressed like that?"],[463,603,"Oh, uhm..."],[603,760,"I'm here to fix the pipes."],[827,967,"My clothes got soaked,"],[1011,1194,"and the owner gave me this suit."],[1414,1501,"What are you doing here?"],[1581,1778,"I'm here to trial for the maid position."],[1975,2045,"Mr. Sm..."],[2102,2232,"the clothes fit perfectly."],[2232,2298,"Thank you."],[2342,2402,"Oh..."],[2459,2605,"Well, I'm glad they fit you."],[2892,3036,"Ma'am, please come inside"],[3036,3199,"and the staff will show you what to do."],[3226,3289,"Thank you."],[3750,3940,"Make sure no one reveals my identity."],[4007,4150,"Give her the highest salary"],[4150,4254,"but the easiest job."],[4347,4457,"If anything happens to her,"],[4534,4654,"you know the consequences."],[4714,4801,"Got it, Mr Smith."],[5311,5415,"What's up?"],[5505,5759,"Why are you all giggly all of the sudden?"],[5849,5939,"I'll tell you,"],[6032,6202,"but you can't tell Dad, okay?"],[6309,6426,"It'll be our little secret."]],"19":[[36,136,"I'm seeing someone."],[260,343,"What?"],[403,467,"Who?"],[530,643,"How did you two meet?"],[787,877,"Well,"],[877,970,"we're meeting tonight."],[1077,1241,"He invited me to his place for drinks."],[1344,1458,"What's he like?"],[1458,1644,"I mean, is he trustworthy?"],[1644,1765,"Don't worry."],[1765,1901,"He treats me really well."],[1901,2022,"Do you want me to go with you?"],[2095,2222,"I promise"],[2222,2469,"I'll keep you updated on my location constantly."],[2599,2679,"Okay."],[5191,5255,"That's..."],[5435,5542,"Harry's house!"]],"20":[[70,120,"Harry?"],[413,483,"Are you here?"],[967,1094,"You're finally here."],[1094,1291,"I've been waiting such a long time."],[1324,1504,"Why are you so close to me?"],[1504,1623,"What, you only just got here"],[1623,1745,"and you wanna leave?"],[1745,1868,"It's such a wonderful night."],[1868,2012,"Let's not waste any time."],[2112,2222,"Let go of me!"],[2605,2819,"I didn't expect you to be such a bastard!"],[2832,3093,"Hey, you pretending to be all innocent?"],[3093,3276,"You came here to sleep with me, didn't you?"],[3380,3460,"Don't touch me!"],[3460,3623,"Stop the resistance, okay?"],[3623,3663,"Come on."],[3663,3770,"Let's get the clothes off you."],[3770,3810,"Please."],[3883,3950,"Let me go."],[3960,3997,"Come on."],[4097,4164,"Help!"],[4234,4347,"Somebody, please!"]],"21":[[36,76,"Help!"],[146,260,"Somebody, please!"],[367,423,"Quiet!"],[573,710,"Don't touch my daughter!"],[1384,1448,"Harry,"],[1534,1651,"I knew it was you."],[1698,1768,"You know him?"],[1868,2215,"He's an ex-boyfriend of mine, a compulsive liar!"],[2442,2515,"Don't be afraid."],[2579,2649,"I'm here now."],[2769,2839,"Amy,"],[2906,3023,"so good to see you."],[3023,3159,"You've been doing well recently."],[3159,3236,"Cut the crap!"],[3303,3463,"Stop harassing Sophie,"],[3463,3586,"and stay away from us."],[3586,3640,"How..."],[3720,3863,"dare you kick me?"],[3933,4160,"Is that any way to treat an old boyfriend"],[4160,4337,"after all this time?"],[4664,4871,"I called the police before I came in."],[5141,5268,"You better let us go,"],[5295,5458,"or when the police arrive,"],[5635,5749,"you'll be charged with rape."],[6026,6086,"Amy,"],[6152,6299,"you've gotten smarter."],[6379,6429,"LET"],[6556,6613,"US"],[6756,6813,"GO."],[7947,8124,"Don't think this is the end of it!"]],"22":[[89,155,"It's okay."],[347,443,"We're already home."],[507,620,"And I'm here with you."],[824,917,"It's all my fault."],[1154,1274,"I shouldn't have trusted him."],[1274,1414,"I was so stupid."],[1414,1514,"No, hey, hey, hey."],[1581,1775,"Don't blame yourself, okay?"],[1848,1978,"Women have paid the price"],[1978,2108,"for the world's mistakes"],[2108,2195,"and a..."],[2195,2355,"man's broken promises"],[2355,2482,"far too many times."],[2545,2642,"This is their fault!"],[2912,2992,"You're amazing."],[3149,3263,"You even thought to"],[3263,3416,"call the police in advance."],[3543,3673,"No, I didn't."],[3803,3893,"I was bluffing."],[4734,4868,"There's one more thing."],[5088,5135,"It's okay."],[5291,5405,"I won't tell Michael."],[5508,5608,"It's our secret."],[5699,5859,"You have to promise me that"],[5859,6079,"you'll tell me everything in the future, okay?"],[6079,6206,"You can trust me."],[6363,6509,"You're like a daughter to me."],[6703,6890,"You've saved me twice now."],[6986,7080,"Thank you, you..."],[7243,7430,"You show me what it's like to have a mother."],[8274,8338,"Am I..."],[8445,8545,"interrupting you two?"],[9262,9322,"Bobby..."],[9536,9572,"What?"],[9696,9899,"The house burnt down in a wildfire?"]],"23":[[513,610,"What happened?"],[834,934,"The car broke down."],[1027,1147,"I need to call the insurance company."],[1147,1180,"I need to call the insurance company."],[1210,1321,"Oh, we're..."],[1321,1434,"We're pretty close."],[1468,1664,"My family's house is just down the road."],[1738,1835,"Why don't you go check on them?"],[1881,1991,"I'll catch up with you later."],[1991,2035,"Okay."],[2769,2876,"Hey, Amy!"],[2876,2956,"What brings you back here?"],[2956,3063,"I heard you got married in the city."],[3063,3186,"How's the family house?"],[3186,3313,"Has it completely burned down?"],[3313,3356,"Burned down?"],[3356,3416,"No!"],[3416,3600,"The wildfire never reached this area."],[3600,3690,"Everyone's safe."],[3870,3923,"What?"],[4100,4257,"Bobby said that the house burnt down"],[4257,4414,"and it needed to be rebuilt."],[4484,4604,"Oh, your brother?"],[4644,4898,"He's been lounging around like a slob and..."],[4994,5125,"spending your money."],[5158,5298,"He's even been paying off women."],[5412,5615,"He's recently latched onto some rich girl."],[5615,5773,"He's buying her expensive gifts"],[5773,5839,"and he's..."],[5839,6036,"been bragging about getting married."],[6226,6292,"What!?"]],"24":[[370,550,"Once Danni marries you,"],[550,724,"we can move into her place."],[850,976,"And you need to get her pregnant"],[976,1071,"right away,"],[1071,1257,"so you can take her place at work."],[1361,1474,"She loves me so much."],[1544,1668,"I might marry her next month."],[1918,1965,"Yeah."],[2018,2202,"That stupid dumb bitch sister"],[2202,2375,"will keep sending us money, so..."],[2716,2912,"You were lying to me this whole time?"],[3033,3173,"I trusted you!"],[3173,3363,"And you keep deceiving me like this!?"],[3613,3770,"Give me back my money."],[3997,4157,"You dare to shout at us?"],[4157,4274,"Why don't you reflect on"],[4274,4477,"why you can't deliver the money on time?"],[4477,4665,"Bobby here is dating a senior manager"],[4665,4770,"from the Smith Group."],[4798,4851,"And you?"],[4901,5005,"You're just a nanny."],[5038,5176,"You should be contributing to"],[5176,5275,"his future."],[5395,5672,"I need that money to find my daughter."],[5822,5975,"I need to find her!"],[5999,6140,"Your daughter died"],[6140,6346,"in the mountains long ago."],[6346,6477,"You're better off compensating for"],[6477,6593,"your brother instead."],[6756,6956,"How do you know she was in the mountains?"],[7077,7333,"Was it you who left her there?"]],"25":[[6,90,"Was it you..."],[160,266,"who left her there?"],[507,610,"Watch your tone!"],[633,797,"Everything your stepmother did,"],[797,947,"she did was for you!"],[1004,1214,"A divorced woman with two kids?"],[1244,1411,"And we helped raise them for you."],[1464,1628,"And I left Daniel with you."],[1661,1805,"At least you still have a son."],[1911,2018,"Nina"],[2018,2122,"and Daniel"],[2122,2222,"are both"],[2222,2339,"my children!"],[2429,2672,"I never relied on you to raise them!"],[3149,3236,"She must have been..."],[3306,3423,"so scared."],[3486,3646,"I am a terrible mother."],[3790,4040,"I failed to protect my daughter."],[4818,4908,"I am cutting..."],[4978,5091,"ties with you."],[5165,5468,"I am going to report you for abandonment."],[6416,6636,"Why does this place feel familiar..."],[6826,6896,"Could it be?"],[8271,8431,"Have I really been here before?"]],"26":[[0,280,"I am going to report you for abandonment!"],[373,617,"You dare report us for abandonment"],[617,784,"after all we did for you?"],[830,1037,"You ungrateful brat!"],[1037,1134,"We raised you,"],[1134,1348,"and now it's time for you to pay us back."],[1348,1451,"You want to run?"],[1451,1558,"Forget about it!"],[1558,1761,"Your money should all go to us!"],[1761,1975,"My dear sister, we're family."],[2088,2278,"Once I marry Danni and get her money,"],[2322,2402,"I'll help you..."],[2402,2515,"find a new husband."],[2679,2782,"Maybe a plumber."],[3059,3183,"I'lm gonna tell the police"],[3183,3353,"everything you've done today."],[3406,3626,"You'll get what's coming to you!"],[3680,3943,"You're not leaving this house."],[3943,4107,"Bobby, go get the rope."],[4107,4404,"I'm tying