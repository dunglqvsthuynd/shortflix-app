{"1":[[179,280,"We just got engaged"],[280,472,"and he cheats with my best friend."],[558,754,"How could you betray me like this?"],[1007,1136,"Fuck me!"],[1882,1946,"Hey!"],[2399,2461,"Dad?"],[2505,2656,"Dad. I don't think I'm safe."],[2694,2823,"Look, sweetheart."],[2842,2999,"I can't save you now."],[3110,3303,"But I know someone who can."],[4930,5036,"What's up, David?"],[5066,5146,"Neo!"],[5150,5327,"You owe me a favor."],[5327,5550,"Please save my daughter."],[5555,5634,"Where is she?"],[6646,6743,"You lost."],[6743,6832,"Don't touch me!"],[6833,6967,"Oh, come on. It's okay."],[7060,7160,"Hey, Miss."],[7175,7389,"I bet you're getting it today."],[7417,7517,"Don't touch me!"],[9282,9377,"Back off!"]],"2":[[164,268,"Why do you care?"],[1583,1675,"Motherfucker!"],[3959,4053,"Come with me."],[4061,4193,"Who are you? Don't touch me."],[4202,4316,"Your father sent me."],[4473,4609,"You're under my protection now."],[5819,6060,"I'd say I'm surprised my father sent you around,"],[6061,6114,"but..."],[6314,6425,"of course, he did."],[8161,8237,"Sorry."],[8333,8481,"I... I didn't mean to."],[8828,8897,"Don't"],[8962,9044,"move."],[10107,10237,"No escaping now."],[10614,10749,"You seem like trouble."],[11253,11423,"Why do you even have those?"],[11523,11712,"Maybe these will keep you in line."]],"3":[[186,420,"Why do you even have those?"],[531,652,"Relax."],[910,1109,"I won't use them if you don't move."],[1400,1563,"It's gotta be the alcohol."],[1564,1867,"But I felt under his command."],[1867,2167,"Or like, I wanted to be."],[3093,3199,"Don't test me."],[3329,3570,"But your body is saying otherwise."],[4188,4424,"Cora, get to the bar in 10 minutes."],[4425,4594,"Or that little dance of yours"],[4594,4811,"goes up on the school website."],[5173,5386,"Oh my God."],[5429,5597,"Are you insane?"],[5643,5814,"Please, I need to..."],[5843,6004,"I need you to get me to the bar,"],[6004,6160,"to the university bar right now."],[6160,6250,"To the bar?"],[6261,6297,"Yes."],[6297,6395,"This time of night?"],[6395,6429,"Yes."],[6430,6549,"That's not happening."],[6654,6830,"I'm not a kid. I can handle it."],[6830,6996,"That's exactly what a child would say."],[7796,7872,"Fine."],[7917,7989,"You can go."],[8067,8360,"Just remember, you're under my protection."],[8389,8630,"Everything you do, I'll see."],[8647,8741,"Understood?"],[11038,11156,"I'll park the car."],[11286,11372,"Be good."],[12000,12256,"Who wants free drink all night on me?"],[13265,13336,"Finn!"]],"4":[[30,158,"You piece of shit!"],[159,261,"Turn that off!"],[340,548,"Hey, actually that girl?"],[857,972,"You are trash!"],[1168,1371,"My fiancé and my best friend?"],[1382,1572,"How could you betray me like this?"],[1593,1673,"You know,"],[1845,2056,"you never let me touch you"],[2067,2176,"for three years."],[2237,2363,"And Ava,"],[2437,2605,"she lets me do anything."],[2700,2808,"She is a real woman."],[3035,3251,"And you? You're a pretender."],[3268,3655,"And the family business is gonna be mine."],[3663,3943,"I would never marry a loser like you."],[4176,4387,"Do you really think that taking over the company"],[4387,4506,"makes you better than me?"],[4568,4767,"You're just a fucking nepo baby!"],[5477,5611,"And what do you live on?"],[5650,5771,"Cheap pride?"],[5803,6039,"Or playing your little piano?"],[6153,6238,"Ah!"],[6351,6433,"Oops."],[6477,6689,"Get out, Cora."],[7145,7341,"I have that stored on the cloud."],[7450,7561,"So kneel."],[7610,7742,"Be my secret lover."],[7818,8107,"Otherwise, this little dance..."],[8225,8552,"I'll put it all over the internet."],[10020,10086,"Finn."],[10166,10297,"A Garcia knows better than"],[10297,10446,"to treat a woman like that."],[10473,10539,"Uncle Neo."],[10540,10639,"How... how did you?"],[10640,10769,"You asked her to kneel?"],[10784,10860,"You kneel."],[10937,11160,"Apologize. Now!"],[11185,11400,"Oh my god. That's... that's Neo."],[11408,11551,"He runs the whole Garcia Empire."],[11551,11751,"And the top lawyer in the country."],[11760,11960,"He's back, in person!"],[11970,12192,"Uncle? Lawyer?"],[12210,12454,"He's the Neo Garcia?"]],"5":[[7,306,"So this is the man Dad sent... Neo."],[335,545,"Finn's only weakness."],[739,1081,"If I made Finn think I was with Neo,"],[1085,1309,"he'd never bother me again."],[1442,1645,"He's the one that forced me to..."],[1645,1721,"Shut up!"],[1960,2098,"I'm pulling all my investments"],[2098,2216,"from you from next year."],[2256,2373,"Until you've learned your lesson."],[2373,2543,"No, no, Uncle, please, please!"],[2753,2829,"Does your father know"],[2829,2952,"you're making videos like this?"],[3174,3305,"They're not real!"],[3317,3395,"Finn faked them."],[3396,3637,"I can't trust someone who doesn't keep their word."],[4365,4602,"I knew my uncle wouldn't protect"],[4602,4837,"a cheap piece of trash like you."],[4978,5060,"Be mine."],[5285,5380,"Or I'll make you..."],[5388,5494,"Don't touch me!"]],"6":[[50,107,"No."],[207,273,"Leave."],[330,450,"I will deal with you later."],[1713,1843,"You belong with me now."],[3076,3156,"Little trouble."],[3216,3443,"Am I just supposed to hold you like this all night?"],[3783,4024,"You want me to stay at your place tonight?"],[4143,4306,"Just until your father gets back."],[4982,5159,"Why did he bring me here?"],[5280,5397,"Whatever the reason,"],[5417,5500,"I..."],[5686,5839,"There are glasses"],[5903,5976,"in the kitchen."],[6063,6236,"You're asking for water while you're asleep."],[6823,7011,"I think... I'm thirstier now..."],[7353,7523,"Whatever the reason, Finn,"],[7553,7696,"you pushed me too far."],[7747,7959,"I'll settle this my way."],[10679,10803,"I hear you out there."],[10829,10943,"Did you find the glass?"]],"7":[[5,133,"Did you find the glass?"],[666,976,"I shouldn't be this into a guy I just met..."],[1111,1258,"But I can't help it."],[1368,1437,"Careful."],[2826,3141,"You could have taken me home right away."],[3315,3436,"But you didn't."],[3675,3900,"Is there anything else you want?"],[4567,4748,"And you're not that old."]],"8":[[63,250,"Then take off your clothes."],[317,581,"You want me to take off my clothes?"],[773,912,"I meant your jacket."],[1120,1164,"Oh."],[1377,1436,"Oh?"],[1663,1754,"Disappointed?"],[2018,2072,"No."],[2722,2827,"Not at all."],[3376,3833,"Why are you so eager to please me?"],[3994,4175,"Are you trying to get back at Finn?"],[4381,4581,"How long have the two of you been together?"],[4773,4882,"Three years."],[4976,5177,"And how many times"],[5234,5337,"has he had you?"]],"9":[[0,213,"What? You want... details?"],[213,322,"Position too?"],[323,470,"Don't talk to me like that."],[513,777,"Your father asked you not to see Finn, you did it anyway."],[786,950,"You two just see me like some..."],[997,1093,"reckless"],[1117,1172,"idiot"],[1173,1386,"that can't make her own decisions, don't you?"],[1637,1854,"Cora, I'm here because your father"],[1854,2012,"entrusted me to protect you."],[2012,2138,"I'm 16 years older than you."],[2138,2332,"And I... can't go too far."],[2568,2716,"I'm sorry, did you just say"],[2716,2946,"you're living with the Neo Garcia?"],[2957,3141,"Well, my father sent him."],[3141,3310,"He's like my new guard."],[3312,3638,"Seriously? I mean, this is Neo Garcia"],[3638,3762,"we're talking about here."],[3820,3974,"The guy who won't let any women"],[3974,4140,"within an arm's distance of himself?"],[4225,4536,"I mean, letting you live with him is..."],[4549,4731,"a pretty big deal if you ask me."],[4801,5017,"Maybe you're right, a man like Neo..."],[5017,5081,"He probably has"],[5081,5250,"tons of women swooned over him."],[5251,5403,"Why would he be interested in me?"],[5492,5939,"Smart, talented, and hot."],[7130,7565,"The Garcias are holding their annual charity gala."],[7565,7882,"Finn and Neo are both gonna be there."],[7882,8168,"You know, a dude like Neo"],[8227,8636,"wants a woman who matches him in every way."],[8860,9164,"Okay, if only to keep Finn away,"],[9199,9339,"I'll make Neo mine."]],"10":[[130,220,"Who is that?"],[276,436,"Did somebody forget to lock the door?"],[516,656,"Who let the nobody in?"],[896,1276,"Well, if it isn't Ice Queen Cora, you know you"],[1276,1556,"better keep it loose for the next man."],[1656,1850,"Finny told me everything."],[1973,2283,"Yeah, you were just a pretend girlfriend"],[2396,2563,"until the real one came along."],[2603,2846,"Well, it doesn't really matter because"],[2846,3089,"trash like you belongs in the dumpster."],[3186,3350,"You bitch!"],[3663,3833,"Don't pout, baby."],[3860,4056,"Later tonight, I'm gonna buy you"],[4056,4276,"the Queen's blue collar diamond."],[4463,4846,"You just play the piano, light up this whole room."],[4846,5039,"Don't dirty yourself by touching her."],[5173,5460,"You're right, baby. I don't touch garbage."],[6110,6226,"You're still mine."],[6276,6720,"That AI video made of you was just a little taste."],[6823,6970,"The real thing is yet to come."],[7033,7106,"Finn!"]],"11":[[733,906,"You must have solved your little money problem?"],[936,1076,"You're acting like a big shot."],[1084,1225,"No. Uncle Neo, I..."],[1256,1400,"I still haven't figured things out,"],[1412,1476,"but..."],[1523,1752,"that diamond was promised to Ava."],[1800,1993,"Would you just help me?"],[1994,2153,"You know, just this once."],[2373,2610,"You're in no position to negotiate with me."],[3508,3607,"Where are we going?"],[4360,4470,"You shouldn't be here."],[4660,4786,"You should be in class."],[4936,5090,"But I'm here for you."],[5180,5429,"I thought since we're gonna be living together,"],[5429,5541,"we should get along."],[5769,6220,"I guess it depends on what you mean by get along."],[6716,6886,"You're not wearing any underwear."],[6926,7036,"Is this for me?"],[7153,7220,"Or Finn?"],[8033,8373,"I think you should buy me the blue diamond."],[8657,8944,"So this is about revenge on Finn?"],[9030,9090,"No."],[9233,9404,"You're the only one in my mind."],[9657,9850,"If you buy me the blue diamond,"],[9870,10031,"I promise to be good for you."],[10113,10264,"Until my father comes back."]],"12":[[1647,1760,"100 million!"],[2000,2157,"102 million!"],[2270,2374,"Is that it?"],[2417,2611,"500 million!"],[2750,2839,"You can do it!"],[2997,3242,"This card can buy that necklace ten times."],[3273,3331,"Go."],[3589,3776,"So how much do I have to spend tonight"],[3776,3929,"to get you to behave?"],[3967,4091,"Just a little bit more."],[4143,4333,"But no worries."],[4343,4486,"I'll make it worth your while."],[4683,4884,"This necklace, the most expensive in this room,"],[4884,5050,"has been bought by the Garcia family."],[5097,5266,"Next, we'll have the owner of the Blue Diamond"],[5266,5423,"perform on the Queen's piano."],[6337,6523,"Finn, thank you so much."],[6533,6678,"Not only did you get me this"],[6678,6823,"beautiful, amazing necklace,"],[6823,7013,"but you also gave me a chance"],[7013,7352,"to perform on stage in front of everyone."],[7560,7818,"I... I actually didn't..."],[8053,8276,"So this was never about the necklace."],[8402,8577,"Just to publicly ruin Finn."],[8733,9078,"The stage, the necklace, none of it really matters."],[9100,9228,"What I really want"],[9350,9542,"is for you to keep your eyes on me."]],"13":[[420,688,"This necklace and this stage"],[689,890,"are never going to be yours, Ava."],[906,968,"What?"],[1040,1239,"Finny, what is she talking about?"],[1387,1696,"You and Finn did not buy the necklace."],[1744,1839,"Neo did."],[2033,2248,"If you don't believe me, try to touch it,"],[2249,2344,"see what happens."],[2447,2782,"No, that necklace is mine!"],[2893,3010,"The necklace is Cora's."],[4150,4233,"Come with me."],[5087,5243,"I kept my part in the deal."],[5373,5483,"Now it's your turn."],[7630,8019,"Oh my, this is a classic from the Queen's era"],[8027,8189,"and she's mastering it?"],[8197,8502,"Not just mastering it, she's rewriting it"],[8502,8722,"to match her passion for music."],[17693,17813,"Who did this?"]],"14":[[43,153,"Who did this?"],[643,800,"You should stop playing."],[820,881,"Aw!"],[916,993,"It's okay."],[1476,1723,"Neo looks like he's about to execute someone."],[1734,1933,"No one escapes Neo Garcia's rage."],[1944,2087,"Last time someone crossed him,"],[2087,2276,"they got 20 years in the slammer."],[3333,3449,"What are you hiding?"],[3553,3620,"Nothing."],[3821,3931,"It wasn't me."],[3982,4177,"Confess and I'll give you mercy."],[4177,4363,"If you lie, I will put you away for good."],[4660,4716,"Admit it."],[4716,4920,"You were harassing Cora from the start!"],[5020,5085,"Five..."],[5212,5273,"Four..."],[5443,5498,"Three..."],[5527,5622,"It was me!"],[5688,5780,"I did it."],[5827,5896,"Please."],[5983,6098,"Have mercy!"],[6147,6310,"You have no sincerity."],[6330,6454,"I am sincere."],[6479,6700,"I... promise!"],[6753,6834,"One."],[8219,8313,"Cora,"],[8360,8485,"I seduced, what I do."],[8486,8616,"I'm so sorry, Neo!"],[8617,8787,"Please don't press charges!"],[9108,9211,"Don't touch her."],[9517,9737,"How will you punish her, Neo?"],[10046,10143,"No!"],[10187,10506,"Finn, it's time for you to fear me."],[10597,10698,"Don't worry about it."],[10790,10896,"You're safe with me."]],"15":[[413,607,"Cora, everything you've done"],[607,780,"was just to get my attention, right?"],[880,1059,"Well, you've got it now."],[1387,1446,"What?"],[1446,1593,"Mr. Big-Shot Lawyer..."],[1636,1800,"Have you never seen blood before?"],[1830,2046,"I've never let a woman bleed in front of me."],[2177,2310,"I want to start with you now."],[3620,3773,"You're gonna get blood in your mouth."],[3789,3913,"I don't care about the blood."],[3979,4110,"I only care about you."],[4523,4693,"So you're feeling protective."],[4797,5039,"Have you noticed something has changed?"],[5063,5133,"What?"],[5220,5536,"You didn't call me \"little trouble\" this time."],[5563,5794,"I think you're starting to see me as woman."],[5983,6139,"I can see it in your eyes."],[6846,7083,"Don't tease me like that."],[7603,7766,"There's only one way to find out"],[7767,7985,"what's truly in your heart."],[9142,9317,"If you're gonna give your heart to someone,"],[9520,9683,"give it to someone who deserves it."],[9803,9946,"You're not ready to make that choice"],[9946,10070,"at this point in your life."]],"16":[[133,273,"You rescued me."],[303,535,"You took care of me, but you keep refusing me?"],[570,747,"You were the one who started this."],[766,880,"Miss Trouble..."],[880,1000,"Why do you keep stopping me?"],[1000,1156,"I can't let you fall for me."],[1536,1769,"I'm sick of people making choices for me."],[2353,2478,"One moment he's all in"],[2479,2631,"and the next he goes cold."],[2631,2763,"Men are never satisfied."],[3123,3256,"It's the dress?"],[3710,3789,"Get in the car."],[3970,4074,"We're going back."],[4119,4270,"Has he changed his mind?"],[4306,4363,"No."],[4586,4868,"Hunters only chase what they can catch."],[4876,5037,"They don't play with the food."],[5166,5320,"Still tailing me?"],[5467,5667,"The hunter shows a weakness."],[5853,6072,"Time for the prey to bite back."],[6727,6947,"One moment you want me and the next one you don't."],[6947,7029,"What's your deal?"],[7287,7618,"A hunter likes his prey with a bit of bite."],[8520,8693,"Getting the upper hand of this guy"],[8693,8898,"is gonna to be harder than I thought."]],"17":[[556,616,"Shoot..."],[873,969,"I can't get it."],[2163,2250,"Thanks."],[4313,4589,"You need something more nutritious than jam."],[7000,7070,"Want some?"],[7209,7350,"You underestimate me"],[7350,7500,"if you think that'll tempt me."],[7863,8181,"The more you resist... the deeper you fall."],[9250,9606,"I guess I should start with breakfast"],[9697,9820,"from the bottom."],[10346,10420,"I'm hot."],[10973,11082,"This resistance"],[11082,11235,"just makes you want it more."],[11440,11514,"Maybe."],[12100,12361,"Tell me, what do you really want?"],[12402,12689,"I want you to teach me how to be gentle with you."],[13975,14090,"Gentle, huh?"],[14135,14345,"Then I think you should start"],[14375,14563,"in the most sensitive area."]],"18":[[679,746,"Hello."],[779,1066,"Neo? How's Cora been?"],[1067,1342,"She's... fine."],[1733,1966,"I have to go to work, Miss Trouble."],[1966,2103,"Am I just a kid to you?"],[2147,2230,"Do you think you can just"],[2230,2389,"neglect me whenever you want?"],[2493,2689,"15 years ago, a little girl"],[2689,2830,"lost everything because of me."],[2857,3002,"I won't let that happen again."],[4520,4627,"Cora!"],[4689,4770,"Finally!"],[4816,4928,"We've tuned the piano"],[4928,5127,"and it's ready for you to play."],[5133,5194,"Thanks."],[5337,5597,"Hopefully, it will help me feel better."],[5682,5768,"What's wrong?"],[5947,6037,"Oh, come on."],[6079,6253,"The winner of the competition"],[6253,6590,"gets to perform with the famous Skye Jones."],[6620,6805,"And that's gotta be you, right?"],[7119,7185,"Just..."],[7238,7333,"Careful!"],[7466,7669,"That's the score I wrote with my father."],[7715,7826,"I'll leave you to it then."],[7897,8176,"Just turn your heartache into your music."],[9193,9277,"Well, well."],[9277,9422,"Looks like the sewer rat"],[9423,9615,"came scurrying out of the dumpster."],[9727,9845,"Ava, I thought you were..."],[9845,10146,"Did you really think that Ava would be in jail?"],[10293,10488,"She's the Moore family's only daughter."],[10515,10595,"Be for real."],[10595,10639,"Yeah."],[10658,10748,"And look."],[10783,11122,"You got lucky at the little gala."],[11199,11497,"But here, on this stage,"],[11498,11771,"you will be kneeling at my feet!"],[12262,12367,"With your skill?"],[12439,12531,"Perfect."],[12634,12903,"Can't wait for audiences to see you lose against me"],[12918,12993,"again!"],[12993,13177,"Well, we'll see about that."]],"19":[[1647,1734,"It's impossible!"],[1777,1921,"I put it right here."],[2840,3090,"This worthless crap?"],[3113,3334,"You really think it belongs on stage?"],[3496,3633,"Give it right now, Ava."],[3643,3777,"I wrote that with my father!"],[3777,3856,"Oh, you want it?"],[3913,4000,"Come and get it!"],[4127,4547,"Or I could burn it to a crisp,"],[4547,4731,"and then it will be the only thing you have left"],[4731,4902,"of your damn daddy."],[4907,5077,"No, stop it, please!"],[5190,5304,"What do you really want?"],[5707,5779,"Hmm."],[5810,5872,"Oh."],[9261,9472,"Oh, I've never heard this piece before."],[9475,9640,"Absolutely flawless."],[9657,9843,"Yeah, but does her demeanor"],[9843,9993,"really fit the music?"],[10016,10122,"You don't understand."],[10217,10484,"A true artist thrives on surprise."],[11143,11239,"I'm sorry, boss."],[11244,11396,"It was my mistake, and..."],[11402,11592,"I should have never let Ava on the stage."],[11593,11729,"But where's Cora?"],[11823,12163,"That's Cora's tune, but why don't I see her?"]],"20":[[328,478,"Ava can steal her music."],[483,601,"She can't steal her soul."],[610,792,"I'll make sure Cora gets on stage."],[2087,2400,"Dad, I couldn't even protect your piece."],[2497,2731,"Can I even call myself your daughter?"],[2880,3064,"Maybe this is the last time I play it."],[4051,4218,"Cora, why are you hiding in the dark?"],[4260,4405,"You belong in the spotlight"],[4426,4565,"where everyone can see you."]],"21":[[1547,1767,"Ava, congratulations."],[2200,2278,"Jealous?"],[2293,2507,"Come back to me, and I'll give you"],[2507,2693,"everything you ever wanted."],[3980,4172,"Ava doesn't deserve that trophy."],[4447,4527,"Uncle Neo?"],[4588,4735,"No. It can't be."],[5048,5156,"Mr. Garcia?"],[5213,5383,"The Moores erased your past."],[5407,5569,"And now you have Cora playing in the shadow"],[5569,5744,"so that everyone here thinks"],[5744,5892,"that it's you playing the music."],[6049,6125,"No."],[6163,6623,"Everyone knows that Cora and I are like sisters."],[6623,6978,"And I composed and performed that piece"],[6979,7273,"as a tribute to Cora and her damn father."],[7290,7580,"Mr. Garcia, you are mistaken."],[8323,8470,"People like this took away"],[8470,8697,"Cora's chance to go on stage."],[8737,9040,"That was harassment, you big bully!"],[9120,9353,"You are the only bully here!"]],"22":[[280,543,"My father and I composed this score together."],[544,810,"And you threatened to destroy it if I didn't give in."],[810,947,"If you truly loved music,"],[948,1121,"you would honor it and not flaunt it."],[1122,1247,"And if you were a true pianist,"],[1247,1393,"you wouldn't have those nails on."],[1897,2155,"Uncle Neo, don't believe this foolish story."],[2155,2269,"This score was always Ava's."],[2270,2397,"Cora just snatched it."],[2520,2607,"Exactly!"],[2650,2989,"And she slammed my hand into the piano earlier,"],[2990,3234,"which is why I have these nails in the first place."],[3240,3389,"You stole my score"],[3390,3543,"and now you're trying to frame me?"],[3560,3672,"Cora, you've always been"],[3672,3818,"jealous of Ava since we broke up."],[3837,3897,"Yeah."],[3898,4009,"That's why you orchestrated"],[4010,4179,"this whole fiasco, isn't it?"],[4300,4503,"But you're doing all of this"],[4550,4710,"just to try to get back with me."],[4863,4922,"Right?"],[5129,5424,"Cora, if you really want the piece back,"],[5483,5598,"I'll give it to you."],[5689,6103,"But you must admit that you were wrong."],[6157,6389,"Everything that you're saying is a lie."],[6577,6800,"Neo, you believe me, right?"],[7391,7481,"Do you trust me?"],[8264,8502,"Truth is built on evidence."],[8833,8959,"What are you doing?"],[9213,9367,"Lies have cracks."],[9471,9725,"Cora can play this entire score for memory."],[9733,9985,"If she can, so can you."]],"23":[[0,200,"If she can, so can you."],[263,559,"Yeah, playing from memory shouldn't be hard, right?"],[676,840,"Since the audience wants it,"],[840,1033,"proving your skill is the right path."],[1103,1503,"Cora, Ava, do you accept the challenge?"],[1547,1641,"Of course."],[1707,1971,"Actually, I seem to have forgotten"],[1971,2226,"something at home, so I'm gonna go..."],[2257,2453,"Running away so quickly"],[2453,2626,"seems like you have something to hide."],[2703,2782,"No."],[2782,3006,"She's fake! She was just miming!"],[3006,3160,"Give the trophy to Cora!"],[3187,3257,"Yeah!"],[3620,3707,"No!"],[4280,4687,"This trophy is mine!"],[4847,5174,"Cora, why do you ruin everything?"]],"24":[[1035,1099,"You okay?"],[1275,1532,"I did play for Ava before"],[1532,1696,"and misled the whole audience."],[1750,1912,"I don't deserve this award."],[1988,2456,"Cora, not only have you revealed Ava and Finn's lies,"],[2456,2655,"but you've upheld this school's honor."],[2790,2940,"You deserve this trophy."],[2969,3087,"Congratulations."],[3413,3670,"It's just a shame that the piece was destroyed."],[3780,3861,"No, these"],[3861,4053,"were just handouts from the competition."],[4180,4321,"I kept the real score safe."],[4806,4956,"I told you I would always take care of it."],[5066,5297,"You two are so obvious."],[5342,5461,"Get together, okay?"],[5510,5771,"- Get together! - Get together!"],[7023,7131,"If we don't act now,"],[7131,7313,"Cora's gonna really end up with my uncle."],[7353,7442,"No rush."],[7487,7720,"The real show is just about to start."],[8123,8368,"This is a 100-million-dollars contract"],[8368,8588,"with the World Wide Melody Corporation,"],[8630,8889,"granting the champion a chance to collaborate"],[8929,9176,"with Ms. Skye Jones on a new piece."],[9827,9914,"Cora, watch out!"]],"25":[[583,681,"Mr. Garcia,"],[681,819,"the contract is real."],[819,922,"The gun is fake."],[933,1063,"It's a gift from Skye."],[1280,1365,"A gift?"],[1393,1566,"You should have handcuffs with the gun."],[1600,1722,"It suits you best."],[1723,1930,"You tell your boss I'm tired of her jokes."],[2134,2258,"Do you want this contract?"],[2267,2394,"I can have another one drawn up."],[2394,2533,"There's no reason to have anyone's name"],[2533,2634,"connected to it."],[3170,3520,"Well, the contract doesn't mean much to me, but"],[3520,3789,"I'll take it as a reward since you got it for me."],[3847,4015,"Now if you'll excuse us,"],[4015,4196,"we have a celebration to attend."],[4793,5071,"You've turned me down twice in public,"],[5087,5152,"Miss Trouble."],[5157,5479,"I told you, I don't like being cornered."],[5636,5714,"That's okay."],[5714,5877,"When I get you along,"],[5969,6147,"I will enjoy punishing you."]],"26":[[550,713,"So how are you gonna punish me?"],[713,833,"With your tie?"],[863,971,"Or your handcuffs?"],[1200,1340,"Is that what you want, Cora?"],[1400,1606,"Why do you crumble when Finn's around?"],[1630,1765,"Do you still care about him?"],[1917,2160,"Then tell me first, who's that Ms. Skye?"],[2177,2336,"Miss Trouble, you just"],[2336,2633,"don't know when to stop talking."],[3102,3306,"I never felt this pain."],[3310,3504,"That makes you want to go crazy"],[3533,3759,"because you're terrified of losing that person."],[4357,4669,"15 years ago, I felt that kind of pain."],[4757,4984,"A little girl disappeared because of me."],[5021,5129,"Maybe forever."]],"27":[[226,416,"How can one girl's words,"],[453,793,"one challenge, throw me so completely off balance?"],[1023,1422,"Love is a curse, a poison that softens your edge."],[1463,1649,"I won't make that mistake."],[2466,2693,"He comes here every night,"],[2733,2823,"always alone."],[2843,3013,"If Neo's hiding from something,"],[3013,3186,"then maybe it's hidden here too."],[3266,3453,"Is this his playroom, too?"],[6016,6126,"Who's there?"],[8453,8670,"Are you stalking me, Miss Trouble?"],[8773,8896,"Or did you come to play?"],[9033,9226,"Because this is not a playroom."],[9463,9670,"I'm a very dangerous man."],[9923,10016,"What if I don't care?"],[10243,10500,"Then I will teach you what submission really is."]],"28":[[123,251,"You've been a naughty girl."],[399,537,"You followed me here,"],[710,850,"went through my things."],[897,1096,"Where are your"],[1096,1196,"manners?"],[1463,1553,"Come on, I..."],[1656,1853,"I was just curious."],[1943,2068,"You carry handcuffs!"],[2136,2346,"I like to push my subs to the edge."],[2491,2623,"Try new techniques."],[2763,2910,"That's something you want?"],[3320,3446,"You like this, don't you?"],[3756,3829,"Say it."],[3906,4020,"Please, Neo."],[4243,4513,"I won't touch you again until you beg for it."],[4997,5145,"What if I won't beg?"],[5343,5473,"Then I will teach you to beg."],[5683,6039,"Someone's not having enough fun."],[6456,6570,"Please, Neo."],[6776,6896,"What did you call me?"],[6956,7009,"Neo."],[7183,7236,"Fuck."],[8356,8563,"Temptation and danger"],[8607,8767,"are two sides of the same coin."],[8953,9083,"Be careful who you fall for."],[9083,9209,"Neo, you're the worst!"]],"29":[[509,696,"Neo, I know it's you again."],[779,893,"I won't fall for your trick."],[2000,2203,"When will the party really begin?"],[2270,2404,"Soon as the bride awaits."],[3343,3420,"Where am I?"],[3613,3689,"Welcome"],[3748,3859,"to your wedding night."],[3976,4076,"Dear Cora."]],"30":[[1413,1534,"You bastard!"],[1630,1733,"What are you doing?"],[1937,2013,"Give me your hand."],[2213,2406,"Give me your hands!"],[4189,4236,"Oh, baby."],[4346,4460,"Don't be so dramatic."],[4545,4737,"Ava was just my cash cow."],[4760,4897,"I just drain her dry."],[4926,5056,"And come back to marry you."],[5087,5332,"You are always mine."],[5379,5479,"Let me go!"],[5627,5693,"Wait."],[5776,5916,"Why do I feel so weak?"],[6186,6300,"What's in that candle?"],[6300,6403,"Just something"],[6456,6558,"to set the mood."],[6657,6824,"Not even Neo can save you tonight."],[7456,7647,"Temptation and danger"],[7648,7821,"are two sides of the same coin."],[7887,8014,"Be careful who you fall for."],[8257,8434,"The problem is I already flipped it."],[8917,9088,"Cora should have been here by now."],[9209,9293,"It's weird."],[9553,9735,"Bob, get your phone."],[9735,9820,"Find Cora."],[10494,10552,"Finn!"]],"31":[[183,246,"Neo!"],[277,415,"You're fucking dead!"],[439,489,"Help!"],[531,609,"Uncle Neo?"],[733,864,"You want to see our wedding?"],[1080,1209,"I'll tell you something."],[1250,1433,"Since you love her"],[1463,1530,"so much,"],[1623,1703,"I'll marry her"],[1756,1933,"right in front of you."],[1993,2276,"If you touch her, I'll fucking kill you!"],[3339,3393,"Finn!"]],"32":[[1643,1833,"I didn't know you'd stoop this low, Finn!"],[1869,1966,"You're fucking dead!"],[2043,2302,"Careful, guys. My uncle's an ex-boxing champion."],[2310,2485,"Just hit him below the belt!"],[2556,2683,"Boxing champion?"],[2743,2806,"Too easy."],[5055,5189,"Who puts you up to this?"],[5190,5386,"Because I know you're not smart enough to do that."],[5386,5500,"No one. No one!"],[5553,5653,"I know who it is."],[5713,5850,"Even if you won't say it."],[6273,6342,"Please!"],[6617,6744,"Let me do it this time."],[7032,7167,"You cheated on me,"],[7210,7377,"betrayed me and hurt me."],[7385,7501,"Do you think I'm the same girl"],[7502,7660,"that can be manipulated?"]],"33":[[633,728,"Fuck the wedding!"],[757,882,"This is your funeral!"],[959,1120,"Cora, she's changed."],[1139,1454,"She's no longer the girl who needs my protection."],[1980,2059,"Don't worry."],[2104,2172,"I got you."],[2266,2350,"Miss Trouble."],[2484,2637,"I'm gutted from what happened,"],[2716,2896,"but I've never felt more powerful."],[3386,3573,"I know I should let you go, but I can't."],[3573,3753,"You know I know you'll leave me one day."],[3851,3997,"Uncle Neo. Please, please!"],[4067,4188,"You're the head of the family."],[4227,4357,"Don't bother with Cora."],[4357,4488,"If people knew that you were"],[4488,4596,"breaking off our engagement,"],[4596,4743,"you'd ruin the family."],[4949,5127,"The only reason you're still alive"],[5145,5343,"is because your father was my brother."],[5427,5601,"You're a disgrace for the Garcias."]],"34":[[873,1083,"I won't fall for your tricks again."],[1408,1507,"If I'd been a second later,"],[1507,1653,"I don't know what would have happened."],[1697,1884,"The candle releases that aphrodisiac."],[1969,2126,"I can't stand to see you like this."],[2760,2863,"What are you doing?"],[3203,3363,"You won't look at me, will you?"],[3523,3656,"Because you're scared."],[4147,4410,"You're scared because you can see what we could be."],[7770,7906,"You don't understand."],[7930,8044,"I can't be with you any more"],[8045,8180,"than what we already have been."],[8190,8299,"you could get hurt."],[9013,9252,"You live your life with too much restraint."],[9320,9600,"You keep desire at an arm's line."],[9779,9973,"I kissed you first this time."],[10020,10403,"So whatever rules you have in place,"],[10453,10633,"whatever rules you're following,"],[10660,10830,"you can throw them out the window."]],"35":[[230,429,"Soon, you won't need me anymore."],[933,1068,"You're playing with fire."],[1183,1343,"I don't mind getting burn."],[2810,2976,"You don't quite know me yet."],[3050,3193,"What do you mean?"],[3193,3373,"You bought the wrong size."],[3726,3836,"Lover?"],[3836,3946,"Monster?"],[4013,4120,"Who knows?"],[6700,7009,"Oh, Neo, my darling fiancé."],[7040,7273,"Did you enjoy last time's little surprise?"],[7340,7459,"I'm back, baby."]],"36":[[1516,1686,"Don't bother saying anything."],[1713,1883,"You don't want me. I get it."],[1891,1989,"Cra, I just..."],[2097,2289,"I don't think that right now is a good time."],[2417,2560,"No matter what I do,"],[2561,2747,"you just can't give up, right?"],[2803,2936,"Well, don't worry about it."],[2937,3127,"From now on, we're just gonna be roommates."],[3127,3236,"Nothing more."],[3339,3583,"Cora, the closer I get to you,"],[3623,3763,"the more I want to be with you."],[3786,4083,"But I can't hurt someone else like I did before."],[4745,4820,"Cora Evans?"],[5143,5290,"Skye Jones' label has accused you"],[5290,5496,"of stealing and illegally distributing"],[5496,5626,"her massive recordings."],[5639,5876,"We need you to cooperate with the investigation."],[5890,6043,"No, that's impossible."]],"37":[[577,800,"Ms. Jones, I'm sure there's"],[800,962,"some kind of misunderstanding."],[963,1034,"I mean, Cora,"],[1035,1199,"she's a very responsible student!"],[1199,1350,"No need to worry, Principal."],[1376,1509,"The Jones family wouldn't"],[1510,1683,"bother troubling your school."],[1725,1911,"Merely hand over the little rat"],[1912,2120,"who stole my unreleased song,"],[2149,2263,"and I may even donate"],[2263,2422,"a concert hall in your name."],[2526,2789,"I did not steal your master recordings, Ms. Jones."],[2943,3046,"Just listen to me."],[3770,3834,"Huh,"],[3874,3942,"you know,"],[4013,4436,"I expected some sort of rare prodigy,"],[4437,4506,"but you?"],[4622,4751,"You're just a girl."],[4920,5096,"Finn may find you appealing, of course,"],[5096,5179,"but Neo?"],[5331,5390,"Well,"],[5568,5725,"Neo never loves anyone."],[5969,6083,"He plays with them."],[6301,6517,"What exactly is your relationship to Neo?"]],"38":[[50,206,"Oh, come on."],[406,706,"You're a girl of lesser privilege."],[758,853,"Someone like you,"],[853,1151,"you must find Neo irresistible."],[1216,1393,"You still haven't answered my question."],[1437,1559,"Didn't you hear me?"],[1650,1861,"You come from nothing."],[1903,2107,"You have a useless sick father."],[2107,2333,"You're stealing scraps, using that"],[2382,2677,"pretty little smile just to scrape by."],[2720,3235,"You and people like you are a stain on Neo's world."],[3323,3490,"Neo and I, well..."],[3548,3752,"we're cut from the same cloth."],[4105,4187,"Skye!"],[4457,4547,"Don't push it."],[4793,4852,"Huh."],[4959,5089,"And there's your answer."],[5220,5518,"I am heiress to the Jones family."],[5600,5756,"And I'm Neo's fiancée."],[5867,6087,"Neo Garcia is mine."]],"39":[[30,236,"You are nothing more than a toy."],[333,510,"In fact, you should be thanking me"],[510,710,"for not completely ruining your life."],[767,968,"After you were living with my fiancé,"],[968,1129,"using his help to get you into the"],[1129,1276,"Worldwide Melody Company?"],[1330,1394,"Oh..."],[1500,1714,"But now that you've stolen my music,"],[1833,2096,"I'm gonna send you straight to jail, sweetie."],[2203,2405,"I got into the Worldwide Melody Company"],[2406,2577,"because I won the competition."],[2617,2841,"I did not steal your music tracks!"],[2930,3163,"Cora's innocent until proven otherwise."],[3545,3906,"Neo, are you really taking her side?"],[4003,4216,"Have... have you forgotten what we are?"],[4237,4513,"Don't bring our private relationship into this."],[4700,4813,"What do you mean?"],[5465,5678,"I am Cora's legal representation."],[5753,6095,"As of now, we are only defendant and prosecutor."]],"40":[[323,476,"Oh, well,"],[477,689,"it seems I've underestimated you, Cora."],[690,802,"Nevertheless,"],[802,1026,"I have a whole European legal team"],[1026,1222,"sent straight from the royal family."],[1292,1389,"So, Neo,"],[1523,1807,"are you sure you want to go up against me?"],[2098,2185,"I am sure."],[2577,2800,"Well, well, it's been a while"],[2800,2986,"since we met each other in court."],[3078,3203,"We'll have to save this for"],[3203,3447,"some roleplay inspiration later."],[4167,4470,"After all, you know better than anyone"],[4490,4739,"these lips do far more than just sing."],[5129,5223,"Yeah, later."],[5765,5843,"Cora."],[5888,6044,"The accusation has negatively"],[6044,6256,"impacted both you and the school."],[6373,6617,"Our concern is your graduation and your future."],[6617,6733,"Cora will be fine."],[6743,6867,"I'll make sure she doesn't get blamed"],[6867,6993,"for anything that she didn't do."],[7032,7093,"No."],[7192,7348,"Mr. Garcia, I think"],[7349,7499,"you should go back to your fiancée."],[7597,7786,"I only get hurt when I'm around you."]],"41":[[850,956,"Put me down!"],[956,1126,"You never told me you had a fiancée!"],[1126,1186,"What is it?"],[1186,1426,"An idea of the joke making me your side piece?"],[1430,1559,"I would never do that to you."],[1700,1773,"You're coming with me."],[3276,3443,"Why don't you bring your fiancée here?"],[3486,3610,"Are you afraid she's gonna find out"],[3610,3792,"about your dirty little secrets?"],[3823,4026,"I'm teaching you to defend yourself."],[4027,4156,"Skye is dangerous."],[4193,4334,"More dangerous than you?"],[4340,4467,"Come on, give me a break."],[4467,4700,"You're the worst thing that's ever happened to me."],[4733,4855,"And I'm done with your shit."],[5093,5336,"You're not going anywhere until I say so."],[6131,6449,"Now, open your hips, plant your feet."],[6572,6657,"I'm gonna show you how to"],[6658,6800,"hit your opponent's weak spot."]],"42":[[503,703,"I'm not a doll that you can just manipulate."],[1230,1306,"Tell me,"],[1307,1503,"how did you feel when you saw me with Skye?"],[1663,1719,"Jealous?"],[1866,1923,"No."],[1950,2250,"I was angry because you were taken"],[2250,2400,"and you were still hitting on me."],[2453,2583,"You should have told me the truth."],[2643,2718,"You're right."],[2797,2898,"I should have."],[4203,4343,"When you lose your sight,"],[4453,4723,"all your other senses are heightened."],[5106,5226,"What are you doing?"],[5293,5437,"You're engaged to Skye..."],[6556,6840,"So we are offering half price on our memberships."],[7003,7125,"Sounds like an amazing deal."],[7163,7317,"I'll definitely join that free class."],[7317,7359,"Great."],[7373,7483,"Let's get you guys signed up."],[7595,7747,"I don't want them to see us."],[7941,8104,"Shh,"],[8130,8295,"I know your limits."]],"43":[[36,153,"Be a good girl."],[266,350,"Don't cum."],[1086,1183,"Let's get you signed up."],[2015,2127,"Boxing is not for me."],[2143,2212,"I'm out."],[2253,2377,"Wait, what? No, no, no, no."],[2395,2461,"Don't leave!"],[3423,3536,"Are you insane?"],[3537,3664,"What if someone has seen us?"],[3664,3757,"Don't worry."],[3771,3929,"I made sure no one could see us."],[4097,4224,"A client and her lawyer"],[4224,4431,"shouldn't have a personal relationship."],[4431,4717,"Unless they already had one."],[4717,4813,"But don't worry."],[4813,5000,"I know you just want me to defense you."],[5012,5157,"Business is business."],[5233,5353,"And I'm not your mistress."],[5389,5473,"You never were."],[5593,5727,"And I'll prove that to you."],[5803,6153,"But first, I need you to change your dress."],[6596,6698,"You monster!"],[6800,6950,"I'll wait for you outside."]],"44":[[516,806,"Neo spending so much time on you is a surprise."],[869,1023,"But he'll come back to me."],[1127,1411,"Without me, he'd either be in jail"],[1412,1793,"or probably dead by now, so he knows"],[1800,2133,"I'm the only one who can make him truly happy."],[2303,2492,"I'm not listening to your bullshit."],[2716,2793,"Oh, sweetie."],[2863,3006,"It's not bullshit."],[3060,3336,"Neo needs a masochist."],[3366,3416,"And you?"],[3467,3709,"You're nothing but completely useless,"],[3710,3897,"squeamish little brat!"],[4076,4136,"Skye!"],[4247,4351,"That's enough!"],[5420,5546,"I was only joking."],[5662,5853,"It's just so late."],[5889,6029,"You didn't come to me."],[6123,6339,"So, here I am."],[6347,6565,"The two of you should not be meeting in private."],[6603,6872,"Touch her again, and we will be pressing charges."]],"45":[[0,210,"You would really stand against me"],[210,376,"in court? For her?"],[383,436,"Yes!"],[733,868,"You are not my wife"],[868,1034,"and she was never my mistress."],[1203,1364,"Stop harassing my client."],[1510,1572,"Fine."],[1643,1953,"You've already ruined one Jones heiress."],[1987,2239,"And you seem set on destroying another."],[2988,3063,"Is it hurt?"],[3252,3398,"We can have Bob call the doctor."],[3413,3586,"I didn't run your marriage, did I?"],[3699,3887,"I don't wanna be a homewrecker."],[4020,4144,"You're not a homewrecker."],[4153,4289,"As for the engagement,"],[4289,4489,"the Garcia's are indebted to the Joneses."],[4533,4822,"A century ago, they saved us from collapse."],[4846,5000,"And in return,"],[5000,5173,"instead of business,"],[5173,5346,"they demanded that we..."],[5477,5620,"joining by Union of Blood."],[5620,5806,"Union? You mean..."],[5881,6170,"Once the male and female heirs are of age,"],[6170,6260,"they would marry."],[6263,6590,"And that's why you have to marry Skye?"],[6726,6786,"No."],[6900,6983,"There's someone else."],[7133,7212,"But if I mention them,"],[7212,7366,"the Joneses will come after me."]],"46":[[37,118,"Her name was Abby."],[119,327,"She was the youngest of the Jones family."],[349,504,"15 years ago, she disappeared"],[558,632,"because of me."],[708,800,"Because of you?"],[850,974,"The first time I met Abby,"],[1107,1410,"she grabbed my hand and asked me to buy her a toy."],[1460,1597,"So I walked up to the counter"],[1639,1766,"and I was gonna buy the toy."],[1767,1914,"When I turned around, she was gone."],[1994,2292,"Skye went after her but she was left with a scar."],[2397,2514,"What happened after?"],[2530,2725,"The head of the Jones family was furious."],[2753,2846,"They came after me."],[2885,3230,"If Skye hadn't begged and knelt on my behalf,"],[3327,3471,"I don't know what would have happened."],[3490,3800,"So that's why the Joneses only answers to Skye now..."],[3829,3960,"I can never repay them."],[4180,4374,"No matter how much they hate me,"],[4374,4573,"no matter how much they try to destroy me,"],[4853,5060,"I will never let them take you."],[5323,5449,"No, Neo."],[5589,5850,"Skye said that without her you would be in prison."],[5850,6003,"I'm not gonna let that happen."],[6003,6166,"I can protect you too."],[6273,6356,"With me,"],[6508,6602,"you will be fine."],[6783,6892,"I will crush anyone that"],[6892,7044,"tries to get in touch with you."],[7320,7602,"This isn't just an old grudge."],[7666,7903,"My gut says there's more to the story."],[7940,8064,"More than Neo's saying."]],"47":[[3,80,"I'll go check."],[686,750,"You ready?"],[763,813,"Ready."],[853,1003,"I can't wait to see what tricks that"],[1003,1206,"European legal team has up their sleeves."],[1540,1887,"Neo, once this riffraff is back where she belongs."],[1932,2052,"We're coming after you."],[2140,2347,"As Cora's defense attorney, I demand"],[2348,2539,"that you withdraw all accusations."],[2547,2658,"Well, we object."],[2713,2946,"Finn Garcia, your nephew,"],[2947,3218,"has provided us with this one written testimony."],[3303,3519,"He states the time, the location,"],[3563,3704,"and the method by which,"],[3737,4006,"Cora performed the alleged theft."],[4047,4299,"That can't be real. It's fake."],[4369,4637,"Just like when he forged my dance video."],[4638,4946,"Forged? First, she pretends to be a contestant."],[4983,5191,"Then she steals someone else's creation."],[5191,5311,"Neo, Are you really going to"],[5311,5585,"trust her over your own nephew?"],[5752,5997,"Does this evidence have original material?"],[6216,6343,"Are there other witnesses?"],[6437,6680,"Mr. Garcia, the law relies on fact."],[6709,6878,"Now, Finn's testimony has"],[6879,6982,"officially been recorded."],[6982,7245,"You need stronger evidence to rebut this."],[7277,7364,"What makes you think"],[7364,7528,"I don't have stronger evidence?"],[8097,8323,"I don't trust someone just because of a bloodline."],[8372,8521,"This surveillance footage"],[8564,8717,"shows exactly what happened"],[8773,8851,"and clearly."]],"48":[[600,930,"Skye, you had someone frame her."],[1017,1158,"If you continue to deny this,"],[1158,1332,"I will pull it up in front of a judge."],[1883,1950,"Objection."],[2040,2243,"How do we know that this clip,"],[2247,2569,"this so-called evidence hasn't been tampered with"],[2569,2699,"or altered in some way?"],[2881,3149,"Besides, Miss Evans herself has admitted"],[3149,3284,"that she was a stand-in"],[3323,3576,"and had previously been involved with Finn."],[3597,3747,"Is this evidence strong enough?"],[4087,4239,"Bob, I finally remembered."],[4257,4472,"I think I saw that name in my father's study."],[4486,4623,"It might be linked to Skye."],[4627,4697,"I'll go check."],[5296,5420,"What if we add this?"],[5443,5541,"What is that, Cora?"],[5597,5794,"This reveals the truth about what happened"],[5794,5989,"to Abby Jones 15 years ago."],[6103,6216,"What did you just say?"],[6288,6488,"There was no human trafficker!"],[6537,6889,"Abby was forcibly taken by thugs you hired."],[6917,7125,"Because you were worried she was next in line"],[7125,7323,"to marry Neo, not you."]],"49":[[32,108,"She's lying!"],[162,283,"Abby is my step-niece."],[437,926,"This is a sign confessing by the men you hired,"],[927,1082,"admitting to the kidnapping"],[1082,1319,"and the 15 years of hash money that followed."],[1343,1597,"Shall I remind your lawyers what that means?"],[1900,1996,"Is this true?"],[2231,2325,"You did this to Abby"],[2325,2520,"and you lied to me for 15 years?"],[2520,2693,"It's fake. It's forged, Neo!"],[2693,2860,"She's framing me. She's just playing you!"],[3040,3212,"Skye Jones, you're under arrest"],[3212,3506,"for a child abduction case from 15 years ago."],[3552,3750,"You have the right to remain silent."],[4032,4131,"The real liar,"],[4131,4362,"the one that should be behind bars is you."],[4406,4596,"All your lies end here, Skye."],[4597,4754,"No, Neo, you're mine, okay?"],[4755,4872,"I loved you first! Alright?"],[4872,4878,"Abby already had everyone else's love, I loved you first! Alright?"],[4878,5024,"Abby already had everyone else's love,"],[5024,5210,"but I took the blame for you!"],[5253,5373,"I took it for you!"],[5373,5505,"And now you'd destroy me?"],[5506,5627,"What, what? Because of her?"],[5630,5839,"Abby was six years old, Skye!"],[5902,5977,"Six!"],[6200,6260,"Bob!"],[6382,6453,"Inform everyone that"],[6454,6613,"my engagement to Skye Jones is off."],[6637,6789,"I'll never wanna hear her name again."],[6826,6891,"Understood."],[7001,7114,"Neo, you're mine!"],[7114,7266,"You're always gonna be mine."],[7267,7500,"Take that back, I've suffered for you!"],[7554,7719,"You're mine, Neo!"],[7726,7871,"You're mine!"]],"50":[[146,316,"I'm sorry she did that to you."],[383,480,"And to Abby."],[503,690,"I wouldn't have figured it out without you."],[827,1036,"I can finally get go of some of the pain."],[1563,1701,"Be with me tonight."],[1799,1861,"Please."],[3836,3936,"A piano!"],[4426,4676,"I wanted to get something to celebrate us."],[5673,5785,"I can't accept this."],[5856,5960,"It's too much."],[6800,6902,"For once."],[7013,7231,"Or I'll have to punish you for disobeying."],[7763,8022,"I am in control now."],[10083,10136,"Neo."],[10237,10401,"I can't think."],[10457,10597,"It's all so much."],[10603,10700,"Don't think."],[10934,11074,"Just focus on me."]],"51":[[670,756,"Neo?"],[1126,1276,"Little one, breakfast time."],[1800,1962,"All my favorite foods?"],[2077,2123,"How?"],[2628,2760,"All your preferences are"],[2800,2939,"written down in here."],[3900,4077,"You noticed all these details."],[4109,4340,"I might not be good at guessing, but..."],[4367,4513,"I am good at observing."],[4983,5078,"Neo."],[5106,5273,"And what have you concluded?"],[5677,6143,"That I can't wait to taste you."]],"52":[[309,493,"I must not have done a good job earlier"],[494,674,"if you're still able to make it to class."],[677,823,"Neo, behave!"],[922,1057,"You can try again later."],[1136,1343,"I'll be back as soon as class is over."],[2997,3123,"Ah! No!"],[3703,3820,"Boss! Neo!"],[4276,4339,"Stop it!"],[4483,4726,"Neo took everything from me."],[5000,5476,"Now, I'm about to take everything from him."]],"53":[[925,1158,"200 degrees."],[1228,1407,"I can't wait to see what this will"],[1407,1713,"do to that pretty little face of hers."],[1986,2183,"Miss Jones, the girl's here."],[2247,2346,"Perfect."],[2387,2462,"Bring her in."],[2646,2723,"Who are you?"],[2723,2846,"Where are you taking me?"],[3063,3136,"Skye?"],[3218,3368,"I thought you were in jail."],[3379,3462,"Oh, please."],[3462,3739,"I have more money than half this city combined."],[3772,4015,"Nothing could keep me behind bars."],[4350,4427,"Stop!"],[4428,4518,"Let me go!"],[4794,5146,"You ruined my fiancé"],[5147,5340,"and my future"],[5340,5640,"with that pretty lovely face of yours."],[5693,5987,"So I'm going to make you ugly as hell!"],[6106,6243,"You pathetic!"],[6287,6414,"You go to hell!"],[6465,6522,"Oh."],[6530,6714,"So long as you go right there with me."],[6793,6883,"And you know what?"],[6917,7152,"Even if Neo does choose you,"],[7185,7372,"all he will ever see"],[7372,7670,"is the monster I made out of you!"],[7937,8040,"All ready."],[8150,8228,"Hold her up."],[8373,8479,"Please. Don't!"],[8480,8547,"Please!"]],"54":[[0,122,"No! Please don't."],[146,192,"No..."],[275,327,"Skye!"],[378,438,"Stop!"],[585,638,"What?"],[679,841,"Now you want me to stop?"],[847,1023,"Has she charmed you too?"],[1143,1410,"Disfiguring her won't undo what she did to me."],[2247,2395,"You know, you're right."],[2410,2559,"You're absolutely right,"],[2559,2975,"because I do want to see Neo's lover burned away."],[3017,3232,"Layer by layer!"],[3755,3939,"Where is Cora?"],[7407,7472,"Skye!"],[7676,7896,"Let her go."],[8093,8287,"But you're just in time, darling."],[8343,8528,"Say goodbye to Cora."],[8886,9082,"Skye Jones, Finn Garcia,"],[9082,9170,"you're under arrest for"],[9170,9372,"kidnapping and attempted murder!"],[10693,10791,"Go get Skye."],[10817,10885,"Bring her in."],[10917,10966,"No."],[11048,11144,"I got it."],[11424,11562,"She smeared my name."],[11603,11749,"She stole my dignity"],[11750,11949,"and she humiliated me in public."],[12030,12151,"I'll make her understand that"],[12151,12333,"no one messes with me."]],"55":[[22,170,"Just remember what I taught you."],[226,436,"Use precision, not force."],[555,650,"I remember."],[720,891,"I'll finish her with my own hands."],[2200,2506,"I told you I'd take you to hell with me."],[3822,3903,"I'm gonna show you"],[3903,4061,"how to hit your opponent's weak spot."],[4872,5147,"Cora, you really are my girl."],[5160,5293,"Last chance, Skye!"],[5354,5457,"Where is Abby?"],[6483,6581,"Oh, Neo."],[6587,6867,"You really thought you had everything under control?"],[7109,7283,"You understand nothing!"]],"56":[[76,180,"Where is she?"],[237,530,"I won't tell you anything."],[570,855,"Cause I want you to feel the guilt"],[892,1189,"and the shame for the rest of your life!"],[3066,3125,"Are you hurt?"],[3243,3416,"I always knew you would find me."],[3704,3758,"Neo!"],[4100,4260,"Is this what you call protection?"],[4329,4556,"Drag her into your chaotic past?"],[4610,4689,"Put her down!"],[5176,5343,"Dad, you've been discharged!"],[5400,5525,"Yes, thank god I have."],[5567,5738,"What have you got yourself into?"],[5744,5931,"You shouldn't been mixing with this man."],[5950,6133,"You need to stay away from Neo."],[6190,6431,"I can't. I won't!"]],"57":[[5,133,"My darling daughter,"],[161,339,"just come home with me."],[350,506,"We'll put all this in the past!"],[535,635,"I... I can't."],[2746,2980,"All I wanna do is protect you."],[3032,3160,"I'm your father."],[3178,3235,"Wait."],[3311,3406,"That necklace."],[3406,3516,"I've seen that before."],[3711,3792,"It's Abby's."],[3887,4016,"She was wearing it 15 years ago"],[4017,4117,"when she disappeared."],[4183,4431,"There's initials engraved on the back of it, AJ."],[4466,4563,"For Abby Jones."],[4643,4743,"Just like the photo."],[5023,5081,"What?"],[5324,5384,"Cora."],[5442,5519,"You're the girl I've been"],[5519,5693,"searching for all these years."]],"58":[[3,99,"Cora, you're the girl I've been"],[99,247,"looking for all these years."],[270,401,"I'm Abby Jones?"],[525,642,"Dad, what is he talking about?"],[643,775,"I don't understand."],[775,1000,"Cora, my... my sweetheart."],[1102,1211,"You're adopted."],[1337,1447,"Fifteen years ago,"],[1447,1672,"I rescued you from human traffickers."],[1797,2122,"That necklace is your only clue to your identity."],[2254,2637,"I tried as hard as I could to find your real parents,"],[2638,2983,"but someone, something, resisted."],[2983,3058,"Skye!"],[3180,3257,"She blocked you from"],[3257,3386,"reconnecting with the Jones family."],[3386,3516,"I don't know why I didn't see it before."],[3557,3672,"You're the youngest daughter"],[3673,3809,"of the Jones family."],[3847,3973,"The rightful heiress."],[3989,4213,"I... I don't care who you are."],[4279,4450,"You're my daughter, Cora."],[4760,4803,"Neo."],[4913,5088,"You can't be with her."]],"59":[[36,300,"Neo, you can't be with her."],[337,527,"You will not take her away from me!"],[578,645,"Dad,"],[839,1114,"I really appreciate everything you've given me."],[1160,1435,"But who I love is for me to decide."],[1607,1748,"You've really made your mind up"],[1748,1863,"about this, haven't you?"],[2040,2257,"Do you know what you're getting yourself into?"],[2257,2401,"I will keep her safe."],[2559,2685,"For the rest of my life."],[2750,2864,"She will be happier with me"],[2864,3010,"than she will be with anyone else."],[3150,3346,"Dad, I'm not your little girl anymore."],[3421,3669,"Please, give Neo and I your blessing."],[3693,3933,"It's the best gift you could ever give me."],[4513,4610,"Okay, sweetheart."],[4750,4863,"I'll give you my blessing."],[4973,5243,"Neo, if you ever hurt her,"],[5383,5556,"I will never forgive you."],[7526,7703,"Breaking off the engagement with Skye"],[7796,7911,"lifted the curse."],[8030,8183,"And with your father's blessing,"],[8307,8453,"we can finally move forward"],[8535,8621,"together."],[8887,9193,"This time, I'm the one holding the reins, right?"],[9350,9598,"Do you remember how I told you"],[9598,9786,"I would teach you how to handle me?"],[9951,10137,"Well, truth is, I..."],[10294,10483,"I don't always like things gentle."],[11070,11178,"Is that so?"],[11223,11574,"You'll have to tell me exactly what you want."],[11870,12050,"Will you sleep with me now?"],[12373,12670,"I'm gonna do so much more than that."],[12698,12802,"Miss Trouble."],[13227,13400,"I want to play in that room."],[13773,13909,"You know about that room?"],[14013,14218,"I've known since the day we met."],[14597,14773,"This is what I really want."],[14843,15141,"I want you to teach me how to be in your want."],[16943,17043,"Strip."],[17248,17368,"Panties first."]],"60":[[420,566,"Will you... hurt me?"],[593,793,"Only in ways that'll make you want more."],[3400,3648,"Change when you're finished,"],[3853,4021,"say 'done, master'."],[4200,4320,"Yes, master."],[5160,5258,"Done, master."],[6086,6166,"Good."],[6317,6457,"Now follow my lead."],[6940,7031,"Kneel."],[9964,10209,"Now I can finally have my way with you."],[10288,10390,"Miss Trouble."],[10396,10482,"Finally?"],[10777,10959,"Is that what you really want?"],[11982,12092,"More than anything."],[12216,12416,"It's what I desire most,"],[12553,12763,"than we're falling in love."]],"61":[[629,685,"Weird."],[741,914,"I thought I've put it in here."],[1528,1626,"What are you doing?"],[1728,1814,"It's so early."],[1894,1985,"What are you looking for?"],[2240,2531,"Neo, will you take me to see my real father?"],[2570,2642,"Of course."],[2668,2829,"You've given me back my heart."],[2964,3100,"Just wanna make you happy."],[3471,3539,"And,"],[3807,3960,"I bought Worldwide Company."],[4245,4423,"I'll transfer the ownership over to you."],[4423,4598,"If you wanna continue your studies,"],[4666,4809,"I'll make sure there's a fund for that."],[5151,5352,"Well, you know what I really want."],[6694,6892,"Neo Garcia, from now on,"],[6897,7176,"everything you own is under my control."],[7226,7400,"I wouldn't have it in the other way."],[7453,7531,"Miss Trouble."]]}