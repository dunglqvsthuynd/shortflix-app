{"1":[[0,137,"Ah!"],[212,358,"Come on, Giselle, one last push."],[387,483,"You can do it, go on."],[567,654,"Wait, Jackie."],[654,784,"Is that Mr. Hale's wife in there"],[784,842,"giving birth?"],[850,955,"The, the blind one?"],[963,1101,"Yeah, and I can't talk right now."],[1101,1280,"Mrs. Hale is having a really difficult birth."],[1317,1418,"Have you talked to the father?"],[1418,1534,"He's supposed to be here."],[1547,1659,"We could lose the baby"],[1659,1760,"and the mother."],[1772,1993,"Mr. Hale said the baby's not his."],[2014,2147,"So don't call him again."],[2185,2314,"He said he doesn't care if the baby"],[2314,2448,"lives or dies."],[2464,2515,"What?"],[2673,2823,"My name is Giselle West."],[2877,3094,"I was 21 years old when I met the boy"],[3094,3224,"who changed everything."],[3407,3516,"One year ago,"],[3557,3778,"I met him right outside this hospital."],[3832,3941,"For the last time, I am not going to be"],[3941,4041,"marrying a stranger for money,"],[4091,4158,"Veronica."],[4158,4287,"If you are so desperate for this,"],[4387,4517,"go sell your own daughter."],[4554,4600,"Okay?"],[4771,4942,"Crazy right? The golden boy just got"],[4942,5155,"dumped like trash by his CEO grandpa."],[5171,5321,"Who would've thought the Navy's"],[5321,5447,"hero pilot would lose his sight"],[5447,5526,"in an accident?"],[5526,5593,"Awww, look who's"],[5593,5705,"fallen from grace now?"],[5718,5872,"It's Logan fucking Hale!"],[5880,5972,"You think you're a little"],[5972,6068,"fucking maverick?"],[6081,6310,"Can't fly now that you're blind, can you?"],[6335,6456,"No wonder his grandpa"],[6456,6535,"disowned him."],[6552,6685,"The Hale family needs a real heir."],[6685,6856,"Not some disabled freak."],[6898,7023,"Don't call me again."],[7557,7645,"Hey asshole!"],[7645,7732,"You're all being recorded"],[7732,7857,"and I’ve already called the cops."],[7857,7945,"They're on their way."],[7962,8095,"Fuck. Come on, guys, let's go."],[9330,9396,"Hey."],[10352,10447,"Thank you."],[10827,10910,"And yeah,"],[10973,11073,"I'm blind."],[11286,11436,"Shizzles, I'm sorry."],[11515,11624,"I don't mean to be rude."],[11699,11820,"You didn't actually call the cops,"],[11820,11886,"did you?"],[11970,12016,"No."],[12045,12162,"I was bluffing."],[12195,12487,"Your bullies aren't exactly the brightest."],[12741,12967,"They used to be my friends."],[13117,13221,"That sucks."],[13292,13388,"Alright, well I'm going to put my"],[13388,13517,"my phone number in here."],[13580,13634,"There."],[13667,13734,"Now,"],[13780,13884,"you can be under my protection."],[13884,13984,"If anyone messes with you,"],[13984,14051,"you call me."],[14431,14531,"The name is Gigi."],[14935,15098,"Everybody calls me Archer."],[15231,15340,"And from now on,"],[15390,15544,"let's hold onto each other."],[15578,15736,"And I'll be your eyes."]],"2":[[45,175,"From that day onwards,"],[204,358,"we became inseparable."],[371,496,"Like two peas in a pod."],[575,692,"I told Archer he wouldn’t"],[692,813,"be alone anymore."],[913,1071,"I would be his eyes."],[1180,1388,"We can experience the world together."],[2865,2998,"You play beautifully."],[3098,3219,"My dad composed it."],[3274,3440,"It's too bad he's in a coma."],[3632,3716,"Gigi,"],[3903,4029,"I know we've only known each other"],[4029,4212,"for a few months, but it feels like"],[4212,4387,"I've known you my whole life."],[4671,4725,"Same."],[5363,5484,"When I lost my sight,"],[5530,5651,"I thought to myself,"],[5714,5830,"if by something miracle"],[5868,5968,"I got my sight back."],[5968,6135,"The first thing that I would want to do"],[6214,6314,"is fly again."],[6414,6602,"But now all I want to see is your face."],[6806,6952,"What if I'm ugly?"],[6981,7044,"Oh,"],[7098,7315,"you could never be ugly to me."],[9209,9305,"Oh my God."],[9342,9467,"Something smells so good."],[9501,9576,"Are you hungry?"],[9634,9684,"Yeah."],[9713,10018,"Well, I can get you something."],[10172,10272,"Wait right here."],[10477,10543,"Wait, babe."],[10568,10685,"A man should do these things"],[10685,10769,"for his girlfriend."],[11628,11753,"Archer!"]],"3":[[588,684,"You're his girlfriend?"],[729,796,"Yes."],[813,946,"Doctor, is he going to be okay?"],[946,1080,"You need to call his immediate family"],[1080,1142,"right now."],[1180,1363,"He's got a ruptured liver and a very rare"],[1363,1480,"Rh negative blood type."],[1480,1589,"If we don't get his family to come in"],[1589,1697,"right now for a partial"],[1697,1851,"liver transplant, he's not gonna make it."],[1926,1968,"Hurry."],[2473,2652,"He doesn’t have any family."],[2923,3019,"What am I going to do?"],[3186,3311,"What am I going to do?"],[3628,3695,"Grandpa!"],[3787,3920,"He has a grandpa."],[5188,5342,"This was my military tag."],[5405,5518,"I want you to have it."],[5609,5851,"And, I'll wear yours."],[5955,6285,"It will be my promise to you, Gigi."],[7169,7244,"Thank you for coming."],[7298,7386,"Please save him."],[7428,7599,"I already told you on the phone."],[7636,7716,"In my family,"],[7716,7907,"I can't use anyone useless."],[7970,8108,"Right now, he's useless."],[8128,8249,"How could you just give up on him"],[8249,8354,"because he's blind?"],[8671,8742,"I won't do it"],[8742,8904,"unless I know he can be useful."],[8971,9125,"You said you had a solution?"],[9125,9238,"Yes, save him, please."],[9238,9371,"I will give him my cornea."],[9830,9989,"I will give him my eyes."],[10981,11136,"Archer, I love you."],[11532,11678,"You're my destiny."],[13505,13576,"Archer?"],[13638,13747,"Archer, are you in here?"],[14164,14260,"Archer, is that you?"],[14518,14681,"Here’s $100,000 for your eyes."],[14743,14952,"You are never to see my grandson again."],[14977,15140,"He's getting married to someone else."],[15152,15211,"What?"],[15269,15361,"No, no, no."],[15398,15532,"That wasn't part of our deal."],[15557,15682,"You'll never find him."],[15682,15836,"Trust me, it's all for the best."],[15928,16074,"No, no, no."],[16078,16182,"Please, please, come back."],[16207,16270,"Please."]],"4":[[487,558,"Daddy,"],[658,742,"what do I do?"],[788,955,"I can't find Archer anywhere."],[1188,1347,"His, his phone is disconnected"],[1347,1468,"and the hospital refuses to"],[1468,1572,"tell me anything."],[1685,1851,"Daddy, I need to find him."],[2093,2164,"I have to tell him"],[2164,2331,"I'm pregnant with his child."],[2673,2752,"You're getting married to"],[2752,2852,"Logan Hale next week,"],[2852,2977,"whether you like it or not."],[2998,3107,"For the last time, Veronica,"],[3107,3374,"I told you I'm not marrying anyone."],[3415,3532,"I have a boyfriend."],[3532,3616,"Oh really?"],[3674,3766,"Where is he?"],[3812,3908,"You made yourself blind"],[3908,3995,"and now he's gone."],[4066,4200,"You're dumber than I thought."],[4225,4312,"It’s not like that."],[4333,4441,"I told you that I would find him."],[4441,4537,"Now get out!"],[4750,4867,"This is so much easier now"],[4867,4971,"that you're blind."],[5100,5263,"Listen to me, you little bitch."],[5263,5367,"Your father's been in a coma"],[5367,5463,"for six months."],[5463,5638,"His medical bills are astronomical."],[5663,5751,"If you don't want me to pull the plug"],[5751,5885,"on your father, you better go marry"],[5885,5968,"Logan Hale."],[5968,6126,"You should feel lucky that his family"],[6126,6256,"is honoring the marriage pact"],[6256,6402,"between your grandparents."],[6443,6556,"Do you know how rich they are?"],[6589,6690,"They're paying five million"],[6690,6777,"for someone like you."],[6835,7057,"Now get your fucking ass over there"],[7057,7144,"or your father's deader"],[7144,7240,"than he already is."],[8053,8195,"Archer, where are you?"],[8258,8391,"Please find me."],[8458,8583,"Please save me."]],"5":[[0,233,"Just like that, I was forced"],[233,354,"to marry Logan Hale."],[387,508,"Nine months into our marriage,"],[508,654,"and I've never met him once."],[930,1076,"Archer, I won't give up on our"],[1076,1242,"precious baby."],[1242,1584,"Ah!"],[1651,1751,"Oh my gosh!"],[1810,1893,"It's a girl!"],[1939,2097,"Congrats, Mrs. Hale."],[2231,2406,"It's a healthy baby girl."],[2494,2631,"Did you hear that, Archer?"],[2656,2769,"We have a daughter."],[2811,2965,"You're a father now."],[3078,3253,"It's been nine months."],[3303,3465,"Where have you been, Gigi?"],[3561,3770,"Why can't I find you anywhere?"],[3791,3908,"Why did you leave me?"],[3987,4208,"I can't do this without you."],[4713,4929,"Boss, the hospital called."],[4979,5142,"Mrs. Hale gave birth"],[5142,5380,"to a healthy baby girl."],[5480,5626,"That gold digger has no shame."],[5780,5893,"Take me to the hospital."],[5960,6039,"Yes, sir."],[6110,6318,"Is money not enough for you?"],[6318,6548,"I'm not going to let that bastard kid"],[6594,6698,"tarnish the family name."],[6698,6840,"Please let me hold her."],[7215,7444,"Thank you Archer for this beautiful gift."],[7444,7611,"I'm gonna name her Astra."],[8600,8692,"Mr. Hale,"],[8692,8804,"I thought you weren't coming."],[8908,9059,"Logan Hale never comes home."],[9059,9213,"Why is he suddenly here?"],[9255,9417,"What if he is going to hurt my daughter?"]],"6":[[62,166,"Your family asked me for"],[166,296,"five million dollars."],[358,533,"And you come in to this marriage"],[583,725,"bearing a child."],[817,946,"Do you think I'm stupid?"],[996,1180,"Are you expecting me to announce"],[1180,1430,"to the world that that kid is mine?"],[1493,1580,"I can explain."],[1639,1718,"I had a boyfriend and"],[1718,1951,"he got into a car accident."],[1972,2223,"I don't care who you sleep with."],[2289,2452,"This marriage is a sham."],[2489,2619,"And you are legally"],[2635,2823,"still my wife in name"],[2852,2977,"until we get divorced."],[3032,3182,"You are Mrs. Hale."],[3315,3582,"Do not bring shame to this name."],[3670,3887,"Do not embarrass me."],[3978,4041,"Do you got it?"],[4154,4195,"Yes."],[4262,4400,"Yeah, yeah, yes."],[5864,6031,"This was my military tag."],[6097,6210,"I want you to have it."],[6352,6519,"Archer gave me this, I can't lose it."],[6548,6644,"Otherwise, I won't be able to"],[6644,6752,"find him anymore."],[6806,6977,"She's got a military tag."]],"7":[[25,162,"I must've been too desperate to"],[162,371,"find Gigi. I let my eyes deceive me."],[392,529,"How could this gold digger"],[529,654,"ever be her?"],[671,779,"Boss, what do you want to do"],[779,846,"about the baby?"],[930,1142,"We could take it out to the countryside"],[1142,1242,"where word won't get out."],[1368,1401,"Yes."],[1509,1568,"Take it away."],[1668,1743,"No!"],[2360,2615,"No, no, I'm begging you."],[3399,3611,"Please don’t take my daughter away."],[3611,3741,"Please don’t do that, please."],[3849,4024,"I won't cause any trouble."],[4024,4158,"I'm begging you!"],[4158,4254,"Please!"],[4988,5046,"Boss,"],[5105,5196,"the baby stopped crying"],[5196,5271,"when she looked at you."],[5367,5476,"She's smiling."],[5709,5893,"Why does seeing Giselle's baby"],[5910,6151,"and hearing her cry make my heart ache?"],[6206,6281,"No."],[6297,6448,"You can't feel bad for them."],[6468,6610,"Giselle's the one who married you"],[6610,6731,"for money and gave birth to"],[6731,6869,"another man's daughter."],[6898,6986,"She does not"],[6986,7119,"deserve your sympathy."],[7386,7553,"You can raise the kid under my roof."],[7574,7678,"Under one condition."],[7732,7828,"From now on,"],[7862,8074,"you will work as a maid."],[8141,8254,"And your daughter,"],[8283,8375,"she'll be nothing more than"],[8375,8475,"a maid's kid."],[8625,8700,"Thank you."],[8808,8896,"Thank you."],[8896,8979,"I promise."],[9075,9159,"Promise."],[9355,9434,"Thank you."],[10235,10314,"Cross me again,"],[10393,10481,"see what happens."],[10894,11165,"Archer, I'm sorry our baby has to grow up"],[11165,11319,"in a family like this."],[11365,11536,"When are you coming back?"]],"8":[[950,1046,"Mommy!"],[1117,1192,"Astra."],[1192,1368,"Astra, come here. Give me a hug."],[2214,2352,"Hurry up and clean, Giselle."],[2394,2569,"Logan will be home soon and he can’t"],[2569,2715,"come home to a dirty house."],[2715,2790,"Why did that monster"],[2790,2965,"come back after 5 years?"],[3007,3136,"Mommy can’t see."],[3186,3357,"I could clean more faster."],[3370,3490,"I help you, Mommy."],[3741,3795,"Astra."],[3937,4099,"And did your mommy ever tell you"],[4099,4233,"why you don't have a daddy?"],[4262,4362,"Regina, you can't speak to"],[4362,4479,"my daughter that way."],[4558,4733,"I have a daddy."],[4767,5034,"He's busy flying right now."],[5105,5388,"Mommy told me he'll be back soon."],[5480,5613,"That's right. Daddy will be here"],[5613,5734,"for both of us very soon."],[5826,5943,"Yeah, sure, whatever."],[5989,6093,"Oh, and"],[6118,6197,"after you’ve made sure"],[6197,6381,"that every surface is spotless."],[6435,6614,"I want you to clean Logan's room, too."],[6706,6781,"Uh..."],[6881,6981,"but Logan doesn't let anyone"],[6981,7065,"clean his room."],[7107,7165,"Well,"],[7236,7424,"he called and he said to clean it."],[7486,7628,"You're going to do it or what?"],[7686,7799,"Fine, I'll clean it."],[7816,7870,"Exactly."],[7907,7991,"Do as you're told."],[8028,8112,"And remember,"],[8137,8283,"you're just a maid."],[8883,9096,"You're so dead, Giselle West."],[9142,9396,"I've loved Logan for ten years."],[9417,9626,"How dare you steal him away from me."],[9659,9763,"After today,"],[9763,9914,"he'll divorce you for sure."],[11398,11519,"Everything's dusty."],[11924,12020,"Oh shizzles!"],[12153,12324,"Oh, I hope I didn't break anything."],[13400,13580,"Why does this feel like my flute?"],[13805,14014,"It even has the same scratch on it."]],"9":[[1488,1664,"Logan, it's so good to see you."],[1664,1776,"I missed you so much."],[2214,2335,"Thank you, Regina, for"],[2402,2510,"watching over the house"],[2510,2619,"while I was looking after Grandpa."],[2656,2819,"There's no need to thank me."],[2865,3007,"We've been family friends forever."],[3019,3119,"Your grandpa is practically"],[3119,3190,"my grandpa."],[3691,3753,"Joey,"],[3778,3866,"did Logan find the girl"],[3866,3970,"that he was looking for?"],[4024,4158,"No, there's been no traces"],[4158,4254,"of her anywhere."],[4300,4354,"Good."],[4408,4542,"Then this is my chance."],[6039,6256,"Archer, do you still remember this song?"],[6289,6443,"It's been five years."],[6531,6685,"Do you still remember me?"],[6706,6827,"Logan, Logan!"],[7565,7653,"Who's playing the flute?"],[8033,8149,"Is that you, Gigi?"],[8191,8312,"I've been searching for you"],[8312,8408,"for five years."],[8408,8537,"Did you finally come back?"]],"10":[[1426,1488,"It's you."],[1572,1718,"Who said you could come in my room?"],[1755,1918,"Who said you could touch my things?"],[2502,2598,"I'm sorry."],[2773,2877,"The flute just felt familiar."],[2877,3011,"I had one really similar to it"],[3011,3140,"that had a little- - I told Giselle"],[3140,3253,"to not touch your things,"],[3307,3415,"but she said that she’s the"],[3415,3486,"woman of the house."],[3486,3628,"And everything belongs to her."],[3703,3766,"What?"],[3824,3891,"No,"],[3908,4033,"Regina told me to clean this room-"],[4033,4087,"Becky,"],[4087,4241,"didn't you hear Giselle say that?"],[4316,4429,"Yes, Miss Brown."],[4487,4558,"Giselle insisted on"],[4558,4692,"coming into your room, sir."],[4692,4804,"I couldn't stop her."],[5201,5317,"No, she's lying."],[5388,5484,"She's lying!"],[5509,5593,"Get out!"],[5734,5809,"Don't worry, Logan."],[5809,5918,"I'll help teach her a lesson."],[6823,6956,"I'm sorry, Gigi."],[7061,7169,"I got your flute dirty."],[7782,7945,"Don't worry, I'll clean it for you."],[8437,8650,"I miss you so damn much."],[8938,9117,"No, Regina, you set me up!"],[9259,9346,"So what if I did?"],[9363,9484,"Wanna see what else I can do?"],[10222,10377,"So, you like playing the flute, huh?"],[10510,10602,"I wonder what would happen"],[10631,10764,"if I broke your fingers."],[11061,11131,"Hold her down."]],"11":[[154,316,"Please, please!"],[342,417,"Please, please!"],[417,525,"No, Astra!"],[525,688,"Go back inside, please!"],[750,950,"Please, don't hurt my mommy!"],[975,1188,"Please, please, please!"],[1188,1326,"Astra, go back inside."],[1334,1418,"Don't hurt my mommy!"],[1418,1576,"Don't worry about Mommy, okay?"],[1622,1768,"I was just playing a game. It’s okay."],[1793,1993,"Get your grimy little hands off of me."],[2489,2690,"Mommy is blind."],[2719,2986,"Astra can play with you."],[3036,3319,"Astra is good at playing games."],[3382,3636,"Can you please let Mommy go?"],[3782,3841,"No."],[3895,4008,"I can't."],[4988,5130,"Daddy!"],[5234,5376,"The Mama Bear,"],[5426,5555,"Baby Bear"],[5597,5718,"and Papa Bear"],[5743,5972,"lived happily ever after."],[6006,6197,"The end."],[6385,6485,"Good job."],[6631,6781,"Thank you for reading to Mommy."],[6890,7044,"Mommy, how do we know"],[7073,7223,"we found Daddy?"],[7862,7982,"He'll be wearing this."],[8174,8262,"If you see him with this,"],[8262,8341,"that's how you know."],[8758,8917,"Daddy!"],[9346,9459,"Daddy."],[9530,9822,"Daddy. You are my daddy."],[9872,9964,"What did..."],[9964,10051,"what did you call me?"]],"12":[[12,408,"Mommy and I finally found you!"],[442,596,"Sir, this is the daughter that"],[625,792,"Mrs. Hale gave birth to five years ago."],[913,1063,"Daddy!"],[1146,1284,"She was just a baby"],[1313,1434,"the last time I saw her."],[1918,2081,"What are you thinking, Logan?"],[2089,2323,"She's just the slut's bastard kid."],[2339,2506,"Daddy!"],[2665,2798,"I'm not your daddy."],[2798,2898,"Stop calling me that."],[2927,3178,"But you are my daddy!"],[3249,3478,"Mommy has a necklace too."],[3499,3674,"Mommy says when I see a man"],[3674,3816,"wearing the same one,"],[3816,3945,"he is my daddy."],[4058,4108,"No."],[4137,4191,"What?"],[4366,4450,"Where is she?"],[5230,5267,"Where is she?"],[5267,5355,"Where's your mom?"],[5588,5651,"Cut this out!"],[5651,5709,"Stop it!"],[5868,6047,"Jesus fucking Christ, Regina!"],[6097,6202,"What the hell are you thinking?"],[6202,6285,"She's blind!"],[6339,6493,"Logan, I was just trying to"],[6493,6635,"teach Giselle a lesson"],[6660,6760,"about touching your things."],[6794,6890,"Yeah, this is my house."],[6890,6986,"I don't know who in the hell"],[6986,7111,"gave you the right to do this!"],[7499,7570,"Don't worry."],[7624,7720,"I'm not trying to hurt you."],[7720,7807,"I'm just trying to help."],[9013,9134,"I've been searching for you"],[9134,9271,"for five years,"],[9351,9609,"but you've been here this entire time?"]],"13":[[66,196,"I've been searching for you"],[196,300,"for five years,"],[346,567,"but you've been here this entire time."],[658,754,"Giselle is Gigi."],[804,859,"Gigi."],[892,996,"Giselle is the woman"],[996,1138,"Logan's been looking for?"],[1167,1343,"Crap, what do I do now?"],[1426,1522,"Gigi is Giselle."],[1605,1693,"Oh my God."],[1722,1826,"Joey, get the car ready."],[1826,2002,"We’ve got to get her to the hospital now!"],[3490,3599,"How did this happen?"],[3862,4049,"How did Gigi become blind?"],[4479,4550,"Regina,"],[4625,4783,"what are you doing here?"],[4846,4942,"Oh good."],[4959,5055,"I made it in time."],[5242,5334,"No no no no no."],[5372,5488,"I can't let this happen."],[5572,5709,"Logan belongs to me."],[6790,7002,"Oh no, Giselle is Gigi?"],[7098,7269,"She’s the girl Logan's been looking for."],[7586,7682,"Logan will be mine."],[7845,8058,"As long as I make him believe I'm Gigi."],[8254,8375,"Now he'll never know."],[8466,8533,"Logan,"],[8604,8821,"or should I call you Archer?"]],"14":[[16,100,"I think it's about time"],[100,262,"that I finally told you the truth."],[479,542,"Archer,"],[542,725,"I have a fake necklace ready."],[763,992,"Once I swap Giselle's tag with a fake one,"],[1034,1213,"you'll never believe her again."],[1238,1380,"About who I really am."],[1463,1618,"Regina, what are you talking about?"],[2877,2919,"Giselle"],[2940,3082,"probably just found my tag"],[3082,3157,"while she was cleaning"],[3157,3290,"and got it mixed up with hers."],[3532,3916,"Great, he's buying it. Just one more push."],[4008,4104,"Are you saying..."],[4383,4504,"I still remember"],[4504,4629,"the first day that we met."],[4738,4867,"You were being bullied"],[4867,5025,"by your so-called friends and"],[5025,5184,"I told you my name was Gigi"],[5184,5259,"because you've always"],[5259,5426,"just seen me like a little sister."],[5463,5584,"And I came up with this"],[5584,5764,"entire elaborate backstory."],[5764,5955,"I was so sad because"],[6006,6139,"well, I wanted you to"],[6139,6268,"finally open up to me."],[6431,6498,"I'm sorry."],[6498,6694,"I probably should have told you sooner."],[6931,7165,"You're, you're Gigi?"],[7403,7449,"But..."],[7524,7745,"But what, what about Giselle?"],[7878,8033,"Giselle can't be Gigi."],[8033,8108,"She's blind."],[8241,8308,"That's right."],[8337,8479,"Gigi was never blind."],[8575,8692,"All this time,"],[8692,8871,"I wanted to tell you the truth."],[8942,9042,"But I was scared."],[9067,9180,"And you were already married."],[9234,9388,"I couldn’t bear to think that"],[9388,9522,"you would have me mistaken"],[9522,9622,"for someone else."],[9672,9722,"So,"],[9830,9939,"I finally got up the courage"],[9939,10051,"to tell you the truth."],[10122,10247,"I'm Gigi."]],"15":[[58,200,"I need to get Logan out of here"],[200,337,"before this bitch wakes up."],[408,454,"Logan,"],[533,629,"can we go somewhere"],[629,721,"private to talk?"],[738,871,"I have so much I want to tell you."],[1017,1080,"Regina."],[1213,1263,"Gigi."],[1568,1701,"You have no idea"],[1710,1914,"how long I've waited for this moment."],[2218,2273,"It's you."],[2281,2323,"Yeah."],[2381,2477,"Is this really you?"],[3207,3307,"Daddy!"],[3470,3695,"Daddy, is Mommy okay?"],[3807,3862,"Oh God."],[3895,4012,"This little piece of shit"],[4012,4112,"must be their daughter."],[4145,4346,"I can't let Logan find out, ever."],[4375,4550,"Oh oh, he's not your daddy."],[4575,4679,"Stop calling him that."],[4767,4946,"No one knows who your father is."],[5384,5513,"Why does my heart ache"],[5534,5714,"every time I see Astra cry?"],[6464,6510,"Hey."],[6635,6694,"Astra,"],[6773,6902,"I'm not your dad."],[6952,7065,"Your mommy is asleep"],[7065,7140,"in the other room."],[7190,7340,"I want you to go find her, okay?"],[7378,7474,"And then when she wakes up,"],[7524,7686,"I'll have Joey take you both home."],[7791,8066,"But I think you are my daddy."],[8087,8291,"I already found Gigi. She's going to"],[8291,8466,"be upset if I let someone else's"],[8466,8616,"kid call me dad."],[8696,8787,"I’m not."],[8967,9213,"Daddy, please don't go!"],[9964,10181,"Daddy, don't go."]],"16":[[20,100,"Mommy."],[141,237,"Mommy."],[554,654,"What happened?"],[709,863,"Mommy, you're awake."],[871,996,"Drink some water."],[2323,2452,"This isn't my necklace."],[2535,2673,"I've been wearing this for five years."],[2673,2773,"This isn't what it feels like."],[2861,2982,"I was wearing it before I went"],[2982,3073,"to the hospital."],[3136,3265,"Someone must’ve switched it."],[3328,3411,"Mommy,"],[3411,3661,"Miss Regina was in your room before."],[3749,3941,"Why did you leave, Gigi?"],[4062,4250,"I can say Grandpa Hale forced me."],[4262,4412,"He'll probably never wake up anyway."],[4462,4542,"I was scared."],[4608,4788,"Grandpa Hale told me that"],[4788,4892,"you were getting married to"],[4892,5075,"his old war buddy's granddaughter and"],[5155,5447,"well, I was warned by him"],[5447,5572,"to never tell you the truth."],[6264,6331,"That woman"],[6331,6402,"you forced me to marry"],[6402,6598,"just gave birth to another man's baby!"],[6664,6756,"You're okay with that?"],[6827,6911,"I thought the only thing"],[6911,7015,"you fucking cared about"],[7015,7157,"was the family image!"],[7244,7561,"I've done everything you've asked."],[7620,7699,"Just tell me."],[7761,7937,"Tell me where Gigi is."],[8137,8312,"I can't keep living like this."],[8612,8671,"Grandpa."],[8796,8942,"Grandpa, please!"],[9013,9188,"I've never begged you for anything."],[9188,9388,"I can't tell him the truth yet."],[9388,9626,"l can't tell him he married Gigi until..."],[9747,9893,"Look at yourself."],[10197,10339,"Look at what you've become."],[10418,10677,"You are the Hale family heir."],[10706,10873,"So start acting like it."],[10902,11019,"You want to see Gigi?"],[11136,11290,"Learn the family business"],[11290,11423,"and do your part!"],[11494,11724,"Only then will I tell you where Gigi is."],[11761,11949,"Without me, you'll never find her."],[12070,12216,"Is that all I am to you?"],[12308,12362,"A pawn"],[12508,12650,"in your business Empire?"],[12846,12946,"Do you even have a heart?"],[13042,13175,"Do you have no one?"],[13217,13304,"That when you die,"],[13304,13455,"you're gonna die alone"],[13467,13605,"with no one there to mourn you!"],[14130,14193,"Grandpa?"],[14335,14431,"Okay. Hey."],[14431,14489,"Grandpa!"],[14764,14856,"Grandpa!"]],"17":[[95,154,"No wonder."],[938,988,"Gigi."],[1735,1826,"Take me, Logan."],[1881,1981,"I want you."],[1981,2110,"I've wanted you for so long."],[2327,2398,"Call me Archer"],[2452,2544,"like you used to."],[2777,2844,"Archer."],[3378,3532,"I'll call you whatever you want, baby."],[5196,5238,"We can't."],[5280,5388,"Gigi, we, we, we can't."],[5492,5580,"What do you mean?"],[5638,5734,"Do you not want me?"],[5830,5914,"You didn't fall in love"],[5914,6060,"with Giselle, did you?"],[6185,6335,"Did Logan fall in love with her"],[6335,6439,"without even knowing"],[6439,6556,"who she really is?"],[6631,6740,"That's not possible."],[6898,6973,"Of course not."],[7032,7090,"I'm..."],[7090,7207,"but I'm still married"],[7282,7411,"to Giselle in name."],[7444,7549,"It's not fair to bring you"],[7549,7670,"into a situation like that."],[7741,7816,"Then when?"],[7999,8133,"I'll divorce her right away."],[8208,8437,"And then I'll marry you."]],"18":[[300,487,"Mom, my nose is bleeding."],[567,621,"What?"],[1034,1101,"No."],[1180,1242,"Astra?"],[1397,1468,"Astra?"],[1626,1701,"Oh my God."],[1735,1810,"Astra?"],[1943,2002,"Doctor?"],[2081,2243,"Doctor, please, somebody help!"],[2665,2706,"Astra?"],[2815,2986,"Astra's white blood cell count is"],[3003,3094,"far too high."],[3132,3269,"I'll need to run some more tests, but"],[3336,3470,"at this point I'm suspecting"],[3470,3728,"Acute Myeloid Leukemia."],[3949,4024,"Leukemia?"],[4120,4241,"Are you saying that Astra has"],[4308,4371,"cancer?"],[4454,4558,"This is one of the most"],[4558,4729,"common childhood forms of cancer."],[4754,4867,"She's only five."],[5117,5221,"Doctor, what do we do?"],[5246,5430,"Please, please, you have to save her."],[5480,5613,"I can run some more labs,"],[5613,5776,"but if it is AML,"],[5776,5876,"the only cure"],[5876,5997,"is a bone marrow transplant."],[6064,6189,"I recommend that you and the father"],[6189,6402,"come in ASAP for a test."],[6485,6631,"I will come in for the match right away,"],[6631,6731,"but the father..."],[6844,7007,"Archer, where are you?"],[7052,7219,"Our daughter might have cancer."],[7253,7365,"We need you."],[8045,8103,"Giselle,"],[8187,8295,"I'm calling you a car"],[8354,8445,"to come pick you up."],[8629,8733,"Let's get a divorce."]],"19":[[296,467,"Why do I not feel happy?"],[517,650,"I should be over the moon."],[1426,1551,"Probably just still in shock."],[2264,2385,"Mr. Hale, I'm here to sign"],[2385,2506,"the divorce papers."],[2594,2652,"Joey,"],[2706,2806,"you can leave us now."],[3995,4124,"Are you not going to ask why"],[4175,4250,"I'm divorcing you?"],[4362,4454,"Mr. Hale, I know that"],[4454,4633,"we were forced into a marriage together."],[4683,4796,"A divorce was inevitable."],[4871,5063,"Just tell me where to sign and I’ll sign it."],[5105,5238,"You're not going ask for anything?"],[5317,5405,"Alimony?"],[5447,5543,"Child support?"],[5584,5705,"I appreciate all that you have done"],[5705,5851,"for me for the past five years."],[5918,6076,"You have given me a roof over my head"],[6076,6218,"and you've even given me a job."],[6435,6614,"I know we didn't start off on the right foot."],[6781,6898,"I know that you're"],[6961,7144,"actually a good person."],[7240,7528,"I, I can't take any more from you."],[7682,7836,"Is this woman pretending?"],[7887,8099,"Why does my heart ache?"],[8846,8988,"The papers are on my desk."],[10035,10126,"Oh shizzles."]],"20":[[87,229,"Alright buddy, is this it?"],[250,304,"Is this where you want to"],[304,387,"have our picnic?"],[1814,1864,"Buddy, stop!"],[1864,1939,"What are you doing?"],[3098,3186,"Shizzles, I'm sorry."],[3490,3570,"Shizzles!"],[3649,3991,"Shizzles? Only Gigi uses Shizzles."],[4041,4133,"Sorry, Mr. Hale."],[4229,4287,"I um,"],[4454,4512,"thank you"],[4612,4696,"for catching me."],[4825,5084,"Why does she feel so much like Gigi?"],[5125,5246,"Who's Astra's father?"],[5372,5426,"What?"],[5426,5643,"You never told me who her father was."],[5680,5901,"Yeah, don't I deserve to know?"],[5976,6114,"That's kind of personal."],[6172,6214,"I mean,"],[6214,6343,"we don't really know each other"],[6343,6431,"that well so..."],[6431,6514,"Giselle, come on."],[6514,6765,"I feel like I'm going crazy right now."],[6819,6981,"I can't shake this feeling."],[7057,7119,"I feel..."],[7219,7436,"I feel this connection to Astra."],[7536,7699,"I don't know how else to describe it,"],[7699,7820,"but this feeling,"],[7870,7970,"I feel like we're..."],[8074,8245,"We’re what, Logan?"],[8295,8404,"What are you trying to say?"]],"21":[[342,446,"I just got done telling you"],[446,600,"that you were a good person,"],[600,796,"and you, then you pull this crap on me?"],[880,1038,"I'm sorry, Giselle, I don't know..."],[1126,1267,"I don't know what came over me."],[1380,1493,"Are we going to sign the divorce papers"],[1493,1555,"or not?"],[1626,1722,"Astra's not feeling well."],[1722,1826,"And I would like to go home."],[1843,1918,"Astra's sick?"],[2035,2131,"What's wrong with her?"],[2656,2706,"Boss,"],[2786,2861,"we’ve got to go."],[2902,2957,"What?"],[2998,3086,"The hospital called."],[3136,3261,"Your grandpa."],[3261,3349,"He's awake."],[3841,3958,"We'll sign the papers later."]],"22":[[479,529,"Damn it."],[550,638,"Why is he awake?"],[721,859,"What if Logan asks him about me?"],[875,1021,"Then he'll find out I lied to him."],[1105,1234,"So the doctor said that"],[1234,1418,"it's going to take a few weeks"],[1418,1568,"for him to be able to speak."],[1630,1805,"He's just been in a coma for five years,"],[1805,1951,"so it's, it's going to take a while"],[1951,2064,"for his body to recover."],[3345,3390,"Grandpa,"],[3545,3632,"I found Gigi."],[3883,4016,"Looks like I beat you to it."],[4496,4754,"What? Logan thinks Regina is Gigi?"]],"23":[[108,200,"She tricked him."],[200,325,"I have to tell Logan."],[333,525,"But why can't I speak?"],[550,784,"Wait, Gigi donated her corneas"],[784,880,"to Logan."],[880,1051,"If I he sees the consent form,"],[1088,1180,"he'll know the truth."],[1238,1313,"Grandpa, what's wrong?"],[1480,1530,"Fuck."],[1547,1668,"I can't let that old bastard"],[1668,1760,"ruin everything."],[2039,2110,"Logan,"],[2135,2214,"go get the doctor."],[2214,2306,"He's not feeling well."],[2318,2481,"You know, I'll stay and take care of him."],[2544,2619,"I'll be right back."],[3674,3987,"Giselle sold her cornea to Logan?"],[4033,4208,"I can't let Logan find out about this."],[5113,5201,"Grandpa Allan,"],[5305,5518,"I can't let you tell Logan the truth."],[5576,5793,"I will be Mrs. Hale."]],"24":[[162,312,"Dr. Johnson, hurry!"],[312,404,"Oh."],[955,1042,"Your grandpa, Allan."],[1338,1476,"He, he was recovering just fine."],[1497,1580,"What could have caused him"],[1580,1659,"to faint again?"],[1659,1785,"I, I, I don't know."],[1818,1856,"I don't know."],[1856,1997,"Maybe he was just upset to see me."],[2110,2181,"I should go."],[2223,2344,"No, Gigi."],[2385,2544,"I'm not letting anyone"],[2544,2669,"tear us apart again."],[2694,2744,"Doctor,"],[2769,2932,"I need you to do everything you can"],[2932,3044,"to save my grandpa."],[3315,3382,"I'm sorry."],[3465,3678,"Astra has been diagnosed with AML,"],[3724,3924,"and you are not a bone marrow match."],[4037,4083,"No."],[4191,4325,"We'll search the registries"],[4325,4391,"right away."],[4404,4512,"But you need to know that"],[4512,4621,"if we cannot find a donor"],[4621,4750,"within the next week,"],[4775,5017,"she may have about six months left."],[5138,5230,"Six months?"],[5367,5442,"I'm sorry."],[5584,5701,"Wait, wait."],[6719,6769,"Gigi?"]],"25":[[75,137,"Gigi?"],[521,567,"You are?"],[658,734,"I'm Dr. Smith."],[750,809,"I performed your"],[809,975,"cornea donation surgery years ago."],[1026,1159,"Did you ever find Archer?"],[1397,1438,"No."],[1584,1676,"I've been looking for him"],[1676,1760,"everywhere and I,"],[1843,1931,"no matter what I do,"],[1931,2052,"I still can't find him."],[2102,2164,"Don't lose hope."],[2231,2373,"I believe you'll cross paths again."],[2469,2535,"I gotta go."],[2577,2669,"Stay strong, Gigi."],[3445,3495,"Archer?"],[3741,3820,"Doctor Smith."],[3899,4074,"My boss is Mr. Logan Hale,"],[4108,4225,"not Archer."],[4250,4404,"Archer was my Navy callsign."],[4454,4617,"My real name is Logan Hale."],[4646,4788,"Wait, Logan Hale?"],[4788,4959,"As in the Hale family heir?"],[4988,5050,"Mr. Hale,"],[5050,5176,"it's an honor to see you again."],[5192,5326,"It has been a while."],[5367,5472,"Oh, right, Mr. Hale,"],[5497,5634,"I just ran into Gigi."],[5676,5797,"She's here in the hospital."]],"26":[[33,79,"Yeah."],[158,258,"I finally found Gigi."],[379,471,"She's actually waiting for me"],[471,521,"right now."],[546,600,"Really?"],[663,746,"That's amazing."],[800,880,"Better treat her right."],[896,992,"You wouldn't have your sight back"],[992,1076,"if it wasn't for her."],[1251,1334,"What do you mean?"],[1488,1593,"Wait, you mean you don't know?"],[1680,1755,"Mr. Hale,"],[1818,1922,"your meeting is about to begin."],[1968,2002,"Yeah."],[2014,2106,"Doctor Smith,"],[2118,2248,"I'm throwing a party at my place"],[2248,2323,"in two days."],[2323,2419,"I'm going to be announcing"],[2419,2581,"my engagement to Gigi."],[2627,2706,"I want you there."],[2723,2836,"Come by if you can."],[2844,2936,"I'll send you the invite."],[2977,3044,"Of course."],[3103,3174,"Wouldn't miss it."],[3536,3645,"Mr. Hale doesn't know that"],[3645,3741,"he got his sight back"],[3791,3987,"because of Gigi's cornea donation?"],[4333,4487,"Hey Gigi, just saw Archer again."],[4679,4746,"Where is he?"]],"27":[[108,266,"Hey Gigi, just saw Archer again."],[342,450,"He invited me to your-"],[450,517,"Where is he?"],[571,725,"Uh, he was heading out."],[1172,1251,"Archer?"],[1305,1572,"No, no, no, where are you Archer?"],[1605,1760,"We're gonna miss each other again."],[1822,2014,"Archer, where are you?"],[5042,5100,"Archer?"],[5259,5317,"Archer?"],[5388,5426,"Hey boss,"],[5426,5547,"I'm going to go check on the car."],[5572,5655,"Archer!"],[5839,5968,"Archer, where are you?"],[6031,6264,"Did Giselle just call me Archer?"]],"28":[[975,1080,"Hey boss, the car's here."],[1297,1380,"That's Joey,"],[1413,1522,"Logan's assistant."],[1639,1785,"He's not my Archer."],[2039,2239,"It looks like I heard it wrong."],[2285,2464,"She's not Gigi."],[3507,3628,"Good thing I kept the original"],[3628,3778,"consent form Gigi signed."],[3841,4037,"It'll make the perfect engagement gift."]],"29":[[208,496,"Regina, you look so gorgeous."],[546,613,"Thank you."],[658,796,"I heard Mr. Hale's announcing"],[796,909,"your engagement today."],[942,1088,"You'll be Mrs. Hale soon."],[1772,1881,"Is that..."],[2439,2552,"Astra!"],[2573,2706,"Mommy, I'm here."],[3319,3403,"There you are."],[3536,3670,"I’ve been looking everywhere for you."],[3670,3916,"I just wanted to look at the party."],[4208,4358,"Uh, the party isn't for us."],[4425,4521,"How about..."],[4629,4704,"how about Mommy make you"],[4704,4767,"cake instead?"],[4767,4808,"Yeah."],[4871,4959,"Okay, let's do that."],[5100,5150,"Let's go."],[5326,5522,"Didn't Mr. Hale divorce her already?"],[5588,5647,"Logan's got"],[5647,5768,"the divorce papers all ready."],[5826,5993,"They'll be signing them later today."],[6151,6235,"I got an idea."],[6272,6418,"Let's have a little bit of fun with her."],[6460,6623,"Before she's officially out of the picture."],[6673,6773,"Yes."]],"30":[[83,125,"Waiter,"],[175,250,"bring Giselle in here."],[296,408,"Tell her we need more wine."],[2560,2619,"Giselle!"],[2635,2781,"Did you do that on purpose?"],[2886,3032,"I, I swear I didn't."],[3078,3165,"Watch your tone."],[3228,3357,"Regina's Mrs. Hale now."],[3382,3549,"You can't talk to her like that."],[3607,3687,"Hold her down."],[3978,4058,"No, let me go!"],[4195,4320,"Get your hands off me!"],[4341,4446,"Let go of me,"],[4446,4550,"get your hands off of me!"],[4921,5075,"Well since you like spilling wine"],[5075,5163,"so much."]],"31":[[316,517,"Leave my mommy alone!"],[517,709,"Stop bullying her!"],[767,834,"Astra."],[1197,1238,"No."],[1251,1388,"Mommy!"],[1418,1526,"Mommy! - Astra!"],[1576,1643,"Mommy!"],[1710,1776,"Mommy!"],[1801,1935,"Where is she? - Mommy!"],[1935,2085,"Mommy!"],[2260,2485,"Nana nana boo boo! - Mommy!"],[2519,2752,"Mommy! - Please, please."],[2765,2936,"Mom, mommy! - Boo boo!"],[2990,3069,"Mommy!"],[3111,3199,"She's right here, - Mommy!"],[3199,3278,"Giselle."],[3445,3591,"Giselle."],[3745,3883,"Don’t do this to her!"],[3958,4158,"Please, please. - Let me go!"],[4158,4471,"Daddy's coming and he will save us."],[4479,4546,"Daddy?"],[4604,4721,"You don't have a daddy."],[4725,4929,"Little bastard. - Mommy, Mommy!"],[5025,5092,"Please."],[5321,5534,"What the hell is going on in here?"]],"32":[[33,233,"What the hell is going on in here?"],[258,346,"Daddy!"],[717,863,"Astra, my baby!"],[1013,1113,"Logan, you're here."],[1205,1351,"You stupid little bastard."],[1372,1559,"How dare you call Mr. Hale Daddy."],[1576,1664,"Yeah, you think you're some"],[1664,1789,"Hale princess."],[1810,1926,"You don't belong here."],[1968,2110,"Daddy!"],[2131,2198,"Why?"],[2252,2419,"Why do I wanna go to her"],[2419,2577,"every time she cries?"],[3090,3232,"Why is she calling you daddy?"],[3274,3353,"I don't like it."],[4608,4796,"I told you to stop calling me daddy."],[5046,5130,"It's okay."],[5238,5321,"Come on, let’s home."],[5422,5534,"Yeah? Let's go."],[7019,7186,"Can we get back to the party?"],[7198,7323,"I've been waiting all day for you"],[7323,7478,"to announce our engagement."],[7665,7741,"Of course."]],"33":[[275,400,"Everyone, if I could have a moment"],[400,479,"of your time."],[658,838,"Mr. Hale and Regina,"],[888,1009,"what a perfect match."],[1051,1163,"I have something very important"],[1163,1251,"that I would like to share"],[1251,1322,"with all of you."],[1393,1547,"Giselle, your time is up."],[1580,1730,"I'm about to become Mrs. Hale."],[1730,1876,"Regina and I-"],[1876,1976,"Wait!"],[2302,2464,"Dr. Smith, welcome."],[2535,2619,"You’re just in time."],[2698,2819,"Logan, who's this?"],[2865,3007,"Oh, this is Dr. Smith."],[3007,3094,"He's the specialist"],[3094,3265,"who restored my vision."],[3349,3474,"Nice to meet you, Doctor Smith."],[3507,3574,"Mr. Hale,"],[3595,3707,"you said you’d take care of Gigi."],[3707,3770,"How come you’re marrying"],[3770,3824,"this woman?"],[3953,4008,"Oh?"],[4166,4337,"Listen, Dr. Smith, this is,"],[4354,4487,"this is Gigi?"],[4571,4617,"Her?"],[4637,4704,"Gigi?"],[4800,4942,"You've been fooled, Mr. Hale."],[5038,5184,"She's not Gigi. She's an impostor."],[5609,5797,"You've been mistaken, Dr. Smith."],[5797,5885,"I am Gigi."],[5885,5935,"Liar!"],[5972,6039,"Don't even try it."],[6097,6189,"Mr. Hale, I'm telling you,"],[6189,6277,"she's a fraud."]],"34":[[175,266,"Mr. Hale, I'm telling you,"],[266,350,"she's a fraud."],[617,650,"But,"],[734,900,"look, look I have the tag."],[942,975,"See?"],[992,1080,"I am Gigi."],[1155,1238,"Don't you trust me?"],[1284,1368,"It’s the tag."],[1918,1972,"Gigi?"],[2427,2481,"Where?"],[2515,2577,"Where's Gigi?"],[2644,2761,"No, no, no."],[2761,2886,"Shit, this is it."],[2919,3069,"I'm about to get exposed."],[3094,3169,"Where is she?"],[3253,3457,"Mr. Hale, Gigi is right there."]],"35":[[45,208,"Giselle is Gigi."],[704,888,"No, this can't be."],[1255,1422,"Mr. Hale, you need to trust me on this."],[1518,1701,"Giselle can't be Gigi."],[1747,1897,"Gigi had perfect eyesight."],[1910,2006,"Giselle is blind."],[2135,2210,"Hey, there’s,"],[2218,2298,"there's no way."],[2298,2381,"That just, that doesn’t,"],[2381,2460,"that doesn't make sense"],[2460,2606,"that Giselle is Gigi."],[2677,2869,"You honestly have no clue, do you?"],[2952,3094,"What are you talking about?"],[3178,3236,"I will show you"],[3236,3386,"what happened to Gigi's eyes."]],"36":[[809,950,"Daddy! Help me!"],[1080,1167,"Doctor Smith,"],[1201,1401,"you enjoy playing the hero, don't you?"],[1447,1568,"But what if it costs you"],[1568,1676,"your daughter's life?"],[1714,1801,"No, please don't."],[1872,2060,"Then do exactly as I say."],[2535,2631,"Doctor Smith, you,"],[2681,2790,"you were about to share with me"],[2790,2977,"something very important."],[2998,3078,"What is it?"],[3199,3378,"Mr. Hale, I lied earlier."],[3411,3516,"Giselle isn't Gigi."],[3516,3703,"Regina is Gigi."],[4254,4341,"It was Giselle."],[4412,4512,"She offered me a fortune,"],[4529,4683,"but I just received a call"],[4708,4842,"and the money never came through."],[4842,5050,"She double-crossed me."],[5171,5363,"Giselle was pretending to be Gigi"],[5384,5522,"because she didn't want a divorce."],[5588,5684,"She's been trying to"],[5684,5922,"hold on to her place as Mrs. Hale."],[5980,6035,"Giselle,"],[6147,6439,"that cunning, manipulative woman."],[7374,7486,"How dare you lie to me?"],[7557,7645,"What?"]],"37":[[50,150,"What are you talking about?"],[158,216,"Let me go."],[216,337,"The divorce papers."],[350,508,"They're ready to be signed by you."],[525,571,"Now."],[596,663,"Mommy!"],[663,867,"Let go of my mommy!"],[905,984,"Astra, it's okay."],[984,1067,"Mommy's going to be just fine."],[1067,1134,"I promise."],[1217,1276,"Come on."],[1397,1551,"Mommy!"],[1689,1826,"Mommy!"],[1906,2031,"I did what you asked."],[2060,2164,"Now, let my daughter go."],[2256,2335,"Hand it over."],[3032,3340,"This is it. Logan will never find out Giselle"],[3340,3461,"is his Gigi."],[3574,3691,"Word of advice, Doctor."],[3732,3824,"Don't get in my way."],[3870,3987,"Or else next time,"],[3987,4104,"your precious little girl"],[4104,4237,"won't be so lucky."],[5363,5576,"You're not my daddy!"],[5576,5864,"Daddy would never hurt Mommy!"]],"38":[[404,496,"You're not my dad-"],[496,633,"Sign the divorce papers."],[658,721,"Now."],[1543,1597,"Sign them."],[1730,1797,"Sign them."],[1964,2072,"Okay, I will sign them."],[2298,2373,"Boss,"],[2414,2498,"there's an urgent matter"],[2498,2640,"that needs your attention right now."],[3365,3424,"Logan,"],[3453,3653,"you cold hearted monster."],[3682,3820,"I've been wanting this divorce"],[3820,4058,"for longer than you could ever imagine."],[4316,4504,"Mommy."],[4621,4692,"Astra?"],[5025,5084,"Astra?"],[5205,5321,"Okay, okay."],[5513,5572,"It's okay."],[5793,5935,"I'm going to call 911, okay?"],[6360,6410,"Oh no no!"],[6410,6464,"Where did it go?"],[6464,6569,"Where did my phone go?"],[6685,6735,"Please, please,"],[6735,6852,"somebody help me find my phone."],[6852,7027,"I can't, I can't see!"],[7436,7578,"No one's going to help you."],[7716,7757,"Regina?"],[7811,7920,"Regina, please, please,"],[7920,8045,"you have to help me. My daughter,"],[8045,8170,"she's unconscious."],[8170,8279,"I don't know what to do. I need to,"],[8329,8450,"I think I really need you to"],[8450,8612,"call 911, please."],[8629,8742,"Not a chance."],[8808,8892,"You and your daughter"],[8892,9063,"are a disgrace to Logan."],[9134,9280,"She'd be better off dead."],[9617,9709,"Mommy’s going to take you"],[9709,9813,"to the hospital, okay?"],[9884,10010,"Mommy's going to take care of you."],[10064,10201,"You're going to be just fine."]],"39":[[129,241,"Logan, look."],[266,371,"She didn't sign them."],[2152,2293,"Why is her phone here?"],[2339,2427,"What kind of games"],[2427,2535,"is that woman trying to play?"],[2590,2786,"She's clearly trying to do everything"],[2786,2952,"that she can to avoid divorcing you."],[2973,3128,"That is not her decision."],[3182,3290,"I will drag her back here"],[3290,3432,"and force her to sign the papers."],[3933,4049,"Please!"],[4049,4195,"My baby needs help!"],[4195,4346,"Please!"],[4596,4808,"Please help me, I'm blind."],[4808,4971,"I'm blind."],[5046,5255,"I can't see, I’m blind."],[5255,5380,"Please!"],[5380,5643,"Please, somebody help me."],[6443,6656,"Astra, baby you'll be okay."],[6765,6869,"Astra?"],[7282,7369,"Please."],[7720,7887,"Please help me, someone!"],[7945,8116,"Please, my baby is sick!"],[8220,8262,"Please!"],[8345,8433,"Please!"],[8817,8929,"Is rain hitting your face?"],[9025,9067,"Here,"],[9196,9288,"now it won't."],[9359,9446,"Mommy's got you."],[9617,9680,"Mommy,"],[9730,9780,"Mommy,"],[9809,10001,"now you’re not wet either."],[10414,10552,"Archer, where are you?"],[10552,10727,"Please, we need you."],[11724,11811,"Archer,"],[11857,11961,"is that you?"]],"40":[[980,1034,"Giselle?"],[1172,1276,"Not my Archer,"],[1330,1434,"but the devil."],[1455,1526,"Logan."],[1647,1856,"Please, you have to help us."],[1972,2147,"Astra, she's sick."],[2268,2352,"She needs you."],[2352,2515,"Please, please."],[2523,2652,"You have to take her to the hosiptal,"],[2652,2865,"I can't see, I can't call a cab."],[2902,3103,"Please save Astra!"],[3103,3282,"Please!"],[3282,3457,"What's wrong with Astra?"],[3586,3703,"Don't pay them any attention."],[3807,3899,"My stomach hurts."],[3908,3995,"Take me to the hospital,"],[4062,4095,"now."],[4162,4316,"Please, you have to help us."],[4371,4533,"Please!"],[4909,4954,"Logan."]],"41":[[87,316,"Mommy."],[367,421,"Astra?"],[508,604,"You're awake."],[721,817,"I was so worried."],[950,1046,"How are you feeling?"],[1088,1393,"Mommy, I had a dream about Daddy."],[1426,1714,"I dreamt that Daddy gave me ice cream"],[1714,1881,"and played with me."],[2594,2756,"Why are you like that?"],[3148,3211,"Well,"],[3328,3420,"when you're feeling better,"],[3420,3507,"Mommy's going to get you"],[3507,3599,"all the ice cream"],[3599,3703,"that you could ever want."],[3766,3883,"Yes."],[4049,4091,"Giselle,"],[4183,4258,"it's Dr. Lee."],[4316,4412,"We found a matching"],[4412,4562,"bone marrow donor for Astra."],[4775,4821,"What?"],[4838,4884,"Yeah,"],[4921,5067,"right here in the hospital's database."],[5117,5196,"It's a perfect match."],[5234,5342,"If he agrees to donate"],[5342,5430,"within the next week,"],[5501,5601,"Astra has a real shot."],[5693,5851,"Oh, Dr. Lee, please tell me who it is."],[5914,6001,"I will do anything."],[6001,6089,"I will beg them."],[6172,6239,"It's, uh"],[6318,6443,"Mr. Logan Hale."],[6560,6627,"Logan?"],[6685,6740,"How?"],[6790,6948,"How is this possible?"]],"42":[[467,592,"The papers are on my desk."],[759,829,"Oh, shizzles."],[1514,1685,"Why can't I stop thinking about"],[1685,1805,"Giselle and Astra?"],[1989,2052,"Mr. Hale,"],[2097,2223,"Giselle says your bone marrow is"],[2223,2360,"a perfect match to Astra's."],[2377,2477,"She's here to beg you to donate"],[2477,2573,"and save her life."],[2627,2715,"Well, tell Giselle"],[2731,2827,"to get lost."],[2857,2936,"Yes, ma'am."],[3028,3215,"What the hell are you saying, Regina?"],[3253,3511,"My bone marrow can save Astra."],[3582,3632,"No, Logan."],[3678,3745,"Can't you see?"],[3791,3878,"They're playing you."],[3878,3958,"You can't let them"],[3958,4079,"manipulate you like this."],[4283,4387,"If you save Astra,"],[4441,4525,"you'll lose me."],[4583,4642,"Forever."],[4771,4934,"You will lose Gigi"],[5017,5071,"forever."],[5459,5530,"Regina, come on."],[5530,5689,"It's either me or them."],[5739,5809,"Your choice."]],"43":[[362,421,"You should leave."],[450,546,"Mr. Hale made it clear"],[546,667,"he won't donate his bone marrow"],[667,729,"to Astra."],[917,992,"Becky,"],[1209,1284,"please."],[1309,1455,"My daughter's leukemia."],[1463,1584,"It's in its final stage."],[1584,1680,"And we don't, we don't have"],[1680,1776,"much time left."],[1856,2010,"This transplant is our only hope."],[2143,2268,"It's our only chance."],[2385,2502,"Please, Becky."],[2590,2656,"Just ask him."],[2656,2823,"Just ask him to save her."],[3078,3178,"Giselle, I can't."],[3228,3307,"Just go."],[3707,3770,"No, I won't!"],[3845,4016,"I won’t, I will kneel right here,"],[4054,4216,"until he agrees to help me!"],[4512,4717,"Logan, you're Astra's only hope now."],[4746,4871,"She's still so young."],[4871,5142,"Please save her. I’m begging you."],[5426,5505,"Mr. Hale,"],[5522,5655,"she won't leave until you agree."],[6990,7048,"Giselle!"]],"44":[[41,112,"Giselle!"],[700,767,"Hey."],[1689,1755,"Mr. Hale?"],[2206,2335,"Oh, Mr. Hale."],[2419,2556,"My daughter."],[2556,2744,"Giselle also likes to..."],[3770,4058,"Why does Giselle feel more like"],[4058,4262,"the Gigi I used to know?"]],"45":[[900,1046,"This was my military tag."],[1121,1209,"I want you to have it."],[1576,1630,"And"],[1714,1814,"I'll wear yours."],[1964,2089,"It'll be my promise"],[2139,2268,"to you, Gigi."],[3219,3311,"Archer."],[4733,4846,"Archer, I promise you,"],[4846,4946,"I will be your eyes."],[5000,5105,"Always."],[5217,5384,"We’ll experience the world together."],[5576,5668,"I love you."],[5855,5980,"I love you."],[7457,7620,"She needs this transplant."],[7720,7845,"She's running out of time"],[7845,7978,"and it's her only hope."],[8112,8174,"Please."],[8420,8683,"Please, I will do anything to save her."],[8917,9117,"I will do anything, please."],[9300,9371,"Anything?"],[9572,9638,"Anything."],[9642,9909,"I will do anything to save my baby."],[10060,10139,"I'll do it."],[10310,10427,"I'll do it."],[10785,10856,"Thank you."],[10885,11119,"Thank you, thank you so much, Mr. Hale."],[11152,11261,"Thank you."]],"46":[[216,316,"Okay, Astra."],[367,646,"Transplant begins in five minutes."],[725,779,"You nervous?"],[838,875,"Nope."],[892,1026,"I'm not nervous."],[1055,1188,"That's a brave girl."],[1363,1455,"Mr. Hale is still coming?"],[1559,1693,"Mr. Hale gave me his word."],[1693,1785,"He said he'd be here."],[2327,2473,"Astra, when you're feeling better,"],[2519,2656,"is there anything that you want to do?"],[2790,2915,"I want to take Mommy"],[2915,3061,"to find Daddy."],[3257,3357,"Maybe you, Daddy, and I go"],[3357,3457,"get ice cream."],[3499,3566,"Yeah."],[3807,3916,"Boss, boss, boss!"],[3999,4062,"Miss Regina,"],[4095,4162,"she's on the roof."],[4200,4358,"She says that if you save Astra,"],[4358,4446,"she's gonna jump."]],"47":[[1322,1393,"Giselle,"],[1455,1534,"are you sure"],[1559,1659,"Mr. Logan is coming?"],[1668,1826,"We've been waiting all morning."],[1830,1922,"Mr. Hale said he would be here."],[1922,1997,"He promised."],[2089,2173,"Dr. Lee, could you,"],[2260,2398,"could you please call him for me?"],[2986,3061,"He's answering."],[3182,3240,"Mr. Hale?"],[3324,3374,"Where are you?"],[3374,3511,"Astra's not- - Giselle, give it up."],[3511,3611,"Logan's not coming."],[3653,3712,"Alright?"],[3858,3953,"That's impossible."],[3953,4112,"He promised."],[4162,4270,"You're pathetic, Giselle."],[4308,4466,"Logan's just toying with you."],[4537,4675,"Astra's just a bastard"],[4688,4871,"that you had with another guy."],[4900,5050,"Why the hell would he care about her?"],[5889,5997,"Joey, call the hospital."],[6039,6118,"Have them reschedule"],[6118,6177,"the procedure."],[6177,6322,"I'm going to stay here with Regina"],[6322,6435,"until she calms down."],[6489,6589,"Then head straight there"],[6631,6735,"to do what I promised,"],[6810,6877,"save Astra."],[6948,7011,"Understood."],[7419,7590,"Dr. Lee, Astra just went into shock."],[7791,7928,"Get the O.R. now."],[8254,8324,"Astra."],[8504,8566,"Astra?"],[8629,8717,"Astra!"]],"48":[[62,116,"Giselle,"],[191,383,"Mr. Hale did not show up, okay?"],[396,525,"We have missed the window."],[613,738,"There's really nothing we can do"],[738,800,"at this point."],[800,913,"She is worsening."],[996,1067,"I'm sorry."],[1167,1209,"I'm sorry."],[1234,1343,"No, please."],[1355,1459,"Please, please, there must be something"],[1459,1534,"you can do."],[1559,1651,"I’m begging you. - I wish there was."],[1651,1730,"save my baby- - I wish there was."],[1730,1797,"I really do."],[1822,1876,"At this point,"],[1876,1985,"there's nothing we can do."],[2043,2135,"The best thing I can tell you"],[2135,2252,"is to just be with her."],[3878,4058,"Mommy."],[5196,5317,"Hi baby, Mommy's here."],[5363,5701,"I don't want to stay here."],[5747,5864,"Okay, sweetie."],[5926,6006,"Tell Mommy."],[6051,6126,"What do you want to do?"],[6189,6268,"Where do you want to go?"],[6268,6335,"I'll take you."],[6377,6564,"I want to take Mommy"],[6564,6769,"to find Daddy."],[7678,7724,"Okay."]],"49":[[354,404,"Oh."],[475,558,"Hi, sorry, excuse me."],[558,654,"Can you tell me"],[675,800,"where the man in the gray suit"],[804,863,"is sitting?"],[1005,1151,"Walk straight to the table in the back."],[1234,1297,"Thank you."],[2469,2573,"Hi, I'm Giselle."],[2573,2686,"We spoke on the phone."],[3036,3144,"Here's your payment."],[3557,3732,"You can't see?"],[3782,3845,"No."],[3874,3941,"I'm blind."],[4079,4175,"What do you need me to do?"],[4308,4437,"I need you to pretend to be"],[4437,4537,"my daughter's dad."],[4750,4829,"Make her happy."],[4959,5013,"Boss."],[5188,5246,"No problem."],[5317,5417,"What's your name, sir?"],[5492,5588,"Matthew Sullivan."],[5643,5751,"Alright, Mr. Sullivan."],[5793,5855,"Let's go."],[6293,6385,"Boss, we have a"],[6385,6485,"multinational meeting"],[6485,6594,"in 15 minutes."],[6639,6706,"Cancel it."],[7007,7090,"Damn it,"],[7173,7328,"I got stood up by a blind."]],"50":[[408,450,"Astra,"],[521,567,"look."],[692,771,"We found Daddy."],[850,942,"Daddy,"],[967,1188,"you finally came for me and Mommy."],[1551,1626,"Astra."],[1993,2127,"I'm sorry, Daddy's late."],[2218,2485,"Promise me, you're not going leave"],[2485,2648,"me and Mommy again."],[3236,3303,"I promise."],[3361,3499,"Daddy's never leaving again."]],"51":[[738,905,"Astra, do you want some ice cream?"],[1005,1088,"What flavor do you like?"],[1172,1226,"Vanilla."],[1226,1351,"Mommy loves vanilla."],[1363,1476,"Can we get vanilla?"],[1547,1614,"Vanilla it is."],[1614,1697,"I'll be right back."],[2882,2948,"Thank you."],[3128,3340,"Mmm, Mommy, so tasty."],[3520,3632,"So princess,"],[3674,3774,"what should we ride next?"],[3795,3849,"That one."],[3849,3937,"The carousel."],[3937,4104,"Mommy loves carousels."],[4316,4471,"Alright, let's go."],[5459,5676,"Daddy, I'm a bit tired."],[5676,5851,"You take Mommy first."],[5864,5968,"Astra, are you okay?"],[5989,6247,"Yes, just a little tired."],[6414,6569,"Daddy, Mommy can't see."],[6602,6727,"When you walk with her,"],[6727,6994,"watch out for corners and stairs."],[7065,7157,"Promise me"],[7182,7336,"you will hold her hand tight"],[7336,7457,"like I always do."],[7736,7836,"Okay, I promise."],[8020,8099,"I'm,"],[8153,8233,"I..."],[8345,8491,"need to use the ladies' room."],[8575,8654,"I'll come with you."]],"52":[[642,800,"Daddy where's Mommy?"],[800,909,"She's still in the restroom."],[909,1009,"She’ll be back soon."],[1530,1751,"Mommy loves vanilla ice cream."],[1751,1964,"And she loves carousels."],[1989,2248,"And she's very scared of thunders."],[2281,2515,"And she really don't like bugs."],[2573,2744,"I wrote everything down"],[2744,3007,"that Mommy likes and don't likes."],[3057,3269,"I tried to remember all of it,"],[3269,3461,"but I don't have much time left."],[3461,3570,"I can't help you"],[3570,3778,"take care of Mommy anymore."],[4517,4608,"Astra, is this why"],[4608,4733,"you've been looking for Daddy?"],[4892,5096,"I wanted to find you so I could give"],[5096,5276,"Mommy's hand to you."],[5326,5472,"So you could take care of her"],[5472,5584,"when I can't."],[5613,5676,"Daddy,"],[5676,5839,"there's still so much things"],[5839,6001,"that I wanna tell you."],[6089,6239,"For the past five years,"],[6239,6352,"Mommy did everything"],[6352,6452,"on her own."],[6498,6644,"She gave me all her love"],[6660,6810,"and all her strength."],[6840,7044,"But she still loves Daddy too."],[7157,7319,"Whenever Mommy missed you,"],[7319,7649,"she would cry and hide in secret."],[7682,7803,"But I always knew."],[7853,8020,"Mommy named me Astra."],[8020,8220,"It means star in Latin."],[8237,8329,"Mommy said"],[8350,8662,"that stars help guide people home."],[8712,8867,"Mommy always hoped"],[8867,9121,"that the stars will bring Daddy home."],[9150,9321,"When I leave this world,"],[9321,9588,"I want to become one of those stars."],[9588,9772,"So I can watch over Mommy."],[10210,10377,"Then is there anything else"],[10443,10543,"you want to tell Daddy?"],[10598,10685,"Or anything,"],[10685,10890,"anything you want us to do together?"]],"53":[[4,187,"Anything you want us to do together?"],[392,642,"Daddy, you came a little bit late."],[1096,1176,"Look, Lucy."],[1222,1330,"Father got you a present."],[1418,1530,"Thank you, Daddy!"],[1609,1726,"Yeah, go."],[1751,1801,"Get!"],[1822,1897,"Mine!"],[2277,2556,"Daddy, you came a little bit late,"],[2556,2831,"I wish I could spend more time with you."],[4325,4383,"Astra?"],[4396,4483,"Astra, Astra, Astra!"],[4483,4529,"Hey, hey, hey."],[4533,4583,"No no, no no no."],[4583,4642,"Stay with me."],[4658,4717,"Astra!"],[4742,4829,"Hey, hey, hey."],[4829,4900,"No no, no no no."],[4909,5059,"Stay with me, stay with me."],[5092,5150,"Astra?"],[5330,5401,"Astra!"],[5547,5684,"Astra!"]],"54":[[642,717,"Giselle."],[754,850,"How's Astra? Is she..."],[917,1009,"You lied to me."],[1151,1205,"You said,"],[1284,1388,"you promised me"],[1388,1493,"that you would save her."],[1493,1576,"You said,"],[1680,1860,"you said that you would be there."],[1985,2152,"But you never came!"],[2402,2464,"Giselle."],[2527,2669,"Astra's getting worse."],[2811,2898,"She's getting worse."],[2898,3044,"She doesn't have much time left."],[3165,3294,"Why did you lie to me?"],[3303,3453,"Giselle, I wanted to come."],[3465,3532,"But,"],[3545,3645,"But what, Logan?"],[3770,3853,"You lied!"],[4066,4195,"You lied!"],[4225,4400,"My baby is dying!"],[4537,4838,"You lied! Why did you lie?"],[4917,5050,"Why?"],[5113,5263,"I wanted to be there"],[5313,5413,"to save Astra."],[5472,5588,"But I couldn't just walk away"],[5588,5676,"from Regina."],[5755,5864,"She's my Gigi."]],"55":[[204,312,"Giselle, I'm sorry."],[437,583,"I'm sorry, I truly am."],[838,988,"Have you lost your mind, Giselle?"],[1071,1272,"Logan doesn't owe you any favors,"],[1272,1355,"alright?"],[1355,1501,"Saving Astra was a favor,"],[1501,1593,"not a responsibility."],[1593,1718,"She's not even his child."],[1835,1939,"You had no right"],[1939,2093,"demanding anything from him."],[2093,2214,"Let alone blaming him."],[2569,2740,"What the hell are you doing?"],[3057,3186,"Giselle, are you hurt?"],[3249,3349,"Save your sympathy."],[3449,3528,"It's too late."],[4612,4683,"Giselle."],[5455,5538,"How's Astra?"],[5597,5680,"Mr. Sullivan,"],[5734,5860,"what are you doing here?"],[5964,6039,"I'm here because"],[6039,6177,"I'm Giselle's boyfriend."],[6252,6393,"And Astra's father."],[6765,6869,"So this is the man"],[6869,7015,"Giselle's been holding out for?"],[7119,7244,"Matthew Sullivan."],[7407,7553,"I don't know if she failed to mention,"],[7653,7757,"but I'm her husband."],[7824,8033,"And she's legally still my wife."]],"56":[[54,258,"And she's legally still my wife."],[367,450,"Oh, that's funny."],[487,579,"Because I was under the impression"],[579,692,"that she was Mrs. Hale."],[692,905,"Mr. Hale, it's time to let her go."],[1146,1213,"No."],[1247,1347,"Mr. Sullivan, no."],[1388,1514,"I think it's time for you"],[1547,1647,"to back off."],[2181,2369,"Wait, Giselle hooked up with"],[2369,2623,"Matthew Sullivan, the billionaire?"],[2644,2823,"And now Logan and Matthew are"],[2823,2936,"fighting over her?"],[3778,3883,"The surgery's over."],[3903,4012,"Astra's stable."],[4358,4466,"Astra."],[4846,4950,"Daddy."],[5296,5455,"Daddy's right here, princess."],[5714,5855,"Astra, Mommy's here too."],[5901,5989,"Mommy."],[6614,6956,"So Matthew really is Astra's dad?"],[7453,7565,"Why did Astra call"],[7565,7707,"Matthew Sullivan Daddy?"],[7778,7995,"Whatever. It's better this way."],[8045,8179,"Logan will never know"],[8179,8395,"Astra's actually his daughter."],[8408,8500,"Look at them, Logan."],[8541,8683,"They're such a happy family."],[8758,8904,"They clearly don't need your help."]],"57":[[487,533,"Yeah."],[625,700,"You're right."],[750,905,"Astra's not even my daughter."],[938,1142,"I'm done wasting time on them."],[2102,2147,"Huh?"],[2193,2414,"I looked into it, just like you asked."],[2427,2627,"Giselle and Matthew met at a café."],[2648,2802,"She paid him to pretend to be"],[2802,3090,"Astra’s father. I just sent you the proof."],[3645,3732,"Oh, Giselle."],[3799,3958,"If your precious little girl"],[3958,4079,"ever found out the truth,"],[4133,4266,"would she die even faster?"],[4662,4833,"Daddy bought me this cake."],[4859,5034,"I'll share it with Mommy."],[5705,5809,"Do you really think that"],[5818,5980,"Matthew Sullivan is your daddy?"],[6022,6210,"Yes, he is my daddy!"],[6393,6456,"Look here."],[6493,6635,"Your mom is a liar."],[6690,6769,"She paid him to"],[6769,6911,"pretend to be your dad."]],"58":[[154,383,"No, it's not true."],[425,533,"You're just a bastard."],[608,738,"You're never going to find your dad."],[834,971,"You're never going to find your dad."],[1017,1176,"You're never going to find your dad."],[2394,2452,"Astra?"],[2531,2590,"Astra?"],[2769,2827,"Astra."],[2915,2973,"Astra."],[3349,3407,"Astra."],[3670,3787,"My baby."],[3908,3987,"Astra?"]],"59":[[129,179,"Giselle,"],[342,613,"Astra only has a couple of days left."],[784,855,"I recommend that"],[855,975,"you spend as much time with her"],[975,1034,"as you can."],[2389,2740,"Mommy, uncle Matthew"],[2740,3140,"isn't he my real daddy, is he?"],[3282,3661,"So we never find my real daddy?"],[3774,3874,"I'm so sorry."],[4496,4721,"Astra's still looking for her daddy."],[4750,4954,"God, if only I could find Archer,"],[5009,5163,"so he could be with her, even just for"],[5163,5292,"a little while."],[5397,5651,"But I have no idea where he is."]],"60":[[54,250,"Astra, you look so pretty today."],[300,437,"Are you here to take your birthday photos"],[437,529,"with your mommy?"],[588,863,"No, I’m here to take a family photo."],[921,1021,"Well when’s your daddy coming?"],[1388,1593,"He’s not coming."],[2302,2364,"Ready?"],[2439,2631,"This is Daddy's seat."],[2902,2969,"Alright then."],[3094,3374,"Three, two, one."],[3436,3528,"Cheese."],[3983,4054,"Mommy,"],[4087,4295,"can I record a video for Daddy?"],[4758,4875,"Of course, sweetie."]],"61":[[25,129,"Hi, Daddy."],[141,246,"I'm Astra."],[275,387,"I'm your daughter."],[387,542,"I just turned five."],[567,809,"And I took a family photo with my mom."],[938,1051,"This is your seat,"],[1059,1259,"but you're still not here."],[1534,1739,"Daddy, I really want to see"],[1747,1939,"how you look like."],[1951,2068,"I'm leaving soon"],[2068,2260,"and you're still not here."],[2302,2373,"I just thought"],[2373,2552,"you were just a little late."],[2565,2861,"But now I know you're not coming."],[2915,3098,"I'm giving Mommy to you"],[3098,3349,"and promise you won't let go of her"],[3349,3624,"and never again."],[3807,4137,"Mommy loves you and I love you too."],[4158,4366,"Astra loves Mommy and Daddy"],[4375,4550,"so, so, so much."]],"62":[[50,196,"I already found Gigi,"],[216,362,"and she's right here with me."],[421,642,"But why do I still feel so lost?"],[721,834,"I can't stop thinking"],[834,975,"about Giselle and Astra."],[1393,1576,"Logan, I want to go shopping."],[2077,2277,"Joey, take her to the shopping mall."],[2310,2360,"Yes, sir."],[2364,2448,"Let me off here."],[2485,2590,"I need to get some fresh air."],[3787,3945,"How do I keep ending up here?"],[4404,4462,"I wonder how"],[4462,4567,"Giselle and Astra are doing."],[4754,4808,"Mommy,"],[4808,5025,"the stars are so beautiful tonight."],[5630,5672,"Astra,"],[5809,5951,"Mommy's gonna take you home now, okay?"],[6047,6114,"Mommy,"],[6114,6352,"can we do paper airplanes?"],[6406,6573,"I wanna make one for Daddy."],[6606,6740,"So it flies to him"],[6760,6965,"and tell him I love him."],[7032,7340,"And maybe he'll come home to us."],[7670,7753,"Sure."],[7887,7982,"Let's do it now."]],"63":[[1418,1630,"Daddy, come home!"],[1664,1914,"Daddy, come home!"],[1956,2189,"Daddy, come home!"],[2239,2464,"Daddy, come home!"],[2510,2740,"Daddy, come home!"],[2777,2990,"Daddy, come home!"],[3023,3186,"Did you hear that? - Daddy, come home!"],[3203,3332,"Astra's calling for me!"],[3536,3632,"She is."]],"64":[[12,254,"Daddy, come home!"],[417,542,"Astra, are you tired?"],[621,775,"Mommy, can you hold me?"],[900,1030,"Sure, baby come here."],[1710,1926,"Mommy, don't be sad when I leave."],[2010,2152,"I'll become the brightest"],[2181,2285,"star in the sky."],[2331,2560,"When you miss me, look up."],[2598,2840,"I'll always watch over you."],[2948,3090,"My sweet baby girl."],[3345,3478,"These past five years"],[3586,3749,"have been really hard on you."],[4129,4204,"Thank you"],[4287,4454,"for choosing me to be your mommy"],[4454,4554,"in this life."],[5025,5176,"In my next life,"],[5201,5392,"I'll still choose to be"],[5426,5584,"Mommy's little girl."],[5643,5784,"I love you, Mommy."]],"65":[[538,613,"Astra?"],[1292,1501,"Archer, where are you?"],[1701,1939,"Why aren't you coming home?"],[2077,2289,"Archer, I need you!"],[2410,2623,"Our daughter is gone!"],[5864,6101,"Why does my heart hurt so much?"],[6143,6289,"Why does it feel like"],[6318,6694,"something important just left me forever?"]],"66":[[216,275,"Giselle."],[458,525,"Giselle."],[859,963,"Congratulations."],[1026,1130,"You can see now."],[1672,1805,"How?"],[1906,2027,"How is this possible?"],[2085,2314,"Someone donated her corneas to you."],[2435,2552,"Who?"],[2827,2915,"Giselle."],[2990,3078,"Where's Astra?"],[3111,3161,"Giselle."],[3319,3415,"Where's my daughter?"],[3436,3528,"Giselle, Giselle, wait."],[3549,3616,"Let me go."],[3616,3707,"I need to see her! - Giselle."],[3745,3799,"She's probably"],[3799,3903,"looking for me! - Giselle, Giselle."],[3995,4079,"It was Astra."],[4229,4375,"Astra gave you her corneas."],[4800,4917,"Uncle Matthew,"],[4917,5105,"could you do me a favor?"],[5121,5238,"Anything, sweetheart."],[5267,5363,"When I leave,"],[5388,5605,"I wanna give my eyes to Mommy."],[5638,5805,"Mommy can't see."],[5851,5985,"When I'm not here,"],[6056,6210,"she'll be scared."],[6235,6506,"There are so many bad people out there"],[6548,6756,"and I want to keep her safe."],[6777,6911,"Promise?"],[7082,7186,"I promise."],[7724,7774,"No."],[7937,8124,"I don't want Astra's corneas."],[8187,8445,"Why did you take them from her?"],[8487,8654,"She must have been so"],[8654,8837,"sick and so scared."],[8938,9142,"So much pain!"],[9255,9380,"Giselle, calm down."],[9572,9651,"Please."],[9755,9788,"Giselle."],[9822,9901,"Calm down."],[9968,10047,"Calm down."],[10101,10231,"Giselle, calm down."],[10293,10356,"Calm down."],[10514,10577,"Giselle."]],"67":[[187,350,"Mommy, Mommy!"],[875,930,"Astra?"],[971,1276,"Mommy, you can finally see Astra now!"],[1931,2064,"Baby, why did you give mommy"],[2064,2177,"your corneas?"],[2252,2348,"Mommy, remember?"],[2348,2431,"I promised"],[2464,2715,"I would help you find Daddy."],[2715,2902,"Even if I'm not here anymore,"],[2927,3044,"I still would."],[3482,3653,"Don't be sad, Mommy."],[3716,3958,"I'll be your eyes from now on."],[4083,4137,"Astra."],[4254,4433,"Mommy misses you so much."],[5180,5401,"Mommy, go find Daddy."],[6322,6364,"Astra?"],[6519,6585,"Astra!"],[6677,6802,"Astra!"]],"68":[[225,271,"Giselle,"],[375,521,"Astra gave you her eyes."],[558,696,"You have to stay strong."],[734,825,"Find her father."],[1543,1634,"I know."],[1764,1922,"I miss her so much."],[2193,2352,"I feel like I’m going to die."],[2719,2806,"Logan,"],[2861,3053,"when are you going to divorce Giselle?"],[3111,3219,"I'm Gigi,"],[3219,3311,"I should be your wife."],[3349,3420,"Not her."],[3449,3582,"How could you say that?"],[3653,3874,"Astra just passed."],[3987,4083,"I can't."],[4183,4341,"I just, I just can't."],[4425,4692,"He's actually feeling sorry for her?"],[4692,4867,"No, I can't let this drag on."],[4867,5013,"I need to marry him fast."],[5013,5209,"If you don't divorce Giselle,"],[5230,5413,"I'll kill myself."],[5555,5684,"You know I'd do anything for you."],[5822,5951,"I'll call her right now."]],"69":[[133,175,"Giselle,"],[271,467,"I heard about Astra, I'm sorry."],[479,546,"Save it."],[671,754,"What do you want?"],[975,1113,"I want to talk about the divorce."],[1238,1322,"Tomorrow."],[1451,1559,"I'll be there on time."],[3382,3453,"Giselle."],[3528,3645,"You finally showed up."],[4195,4279,"Giselle,"],[4637,4704,"you're here."],[5013,5067,"Archer,"],[5196,5351,"I finally found you."]],"70":[[33,166,"I finally found you."],[471,650,"Logan, you're here."],[717,809,"Logan?"],[996,1059,"After today,"],[1059,1280,"we'll finally be together forever."],[1409,1530,"Logan is Archer."],[1589,1730,"This was my military tag."],[1797,1906,"I want you to have it."],[1951,2068,"It'll be my promise."],[2127,2202,"I love you."],[2335,2590,"I don't care who you sleep with."],[2610,2769,"This marriage is a sham."],[3140,3307,"Daddy!"],[3420,3528,"Stop calling me daddy."],[3528,3649,"I'm not your father."],[3670,3912,"Daddy, come home!"],[3966,4275,"Daddy, come home!"],[4295,4379,"Astra and I"],[4379,4479,"have been searching for him"],[4479,4633,"for five years and"],[4679,4875,"he was right here the entire time."],[4925,5042,"Giselle, are you..."],[5284,5376,"are you okay?"],[5605,5655,"So,"],[5705,5764,"when are you two"],[5764,5901,"signing the divorce papers?"],[6473,6531,"Let's go."],[6585,6623,"Now."]],"71":[[421,542,"So you've been looking for Gigi"],[542,642,"this whole time?"],[1376,1438,"Yeah."],[1530,1735,"Ever since the day we were separated,"],[1768,1939,"there wasn't a single"],[1939,2181,"day that I stopped looking for her."],[2677,2786,"I looked everywhere,"],[2811,2952,"all different places,"],[2973,3090,"different cities."],[3140,3265,"Honestly, just hoped that one day"],[3265,3382,"I would wake up and"],[3641,3803,"she'd be right there beside me."],[4587,4713,"I miss her so much."],[4825,4954,"I feel like I would go"],[5096,5301,"insane some days."],[5484,5605,"That's why I can't"],[5709,5843,"betray Regina."],[5893,6035,"That's why I have to marry her."],[6410,6614,"Archer, we kept missing each other"],[6694,6856,"over and over."],[6923,7069,"Maybe we were never meant to"],[7069,7190,"find each other."],[7436,7499,"Let's sign."]],"72":[[5976,6039,"Giselle."],[6097,6160,"What about..."],[6256,6356,"what about you?"],[6477,6531,"The man"],[6652,6752,"that you've always missed,"],[6752,6940,"the man that you've always loved?"],[7127,7207,"Is it Matthew?"]],"73":[[183,250,"Giselle,"],[408,496,"is it done?"],[792,850,"Let's go."],[1747,1931,"You should love Gigi, Logan."],[1989,2147,"You can't let yourself waver."],[2231,2369,"Giselle's with Matthew now."],[2423,2506,"Let her go."],[2573,2761,"This marriage was never meant to last."],[2844,3023,"It's time you do the right thing."],[3082,3148,"But why?"],[3211,3345,"Why does it hurt this much"],[3345,3440,"losing Giselle?"],[3536,3632,"Admit it, Logan."],[3724,3832,"You fell for her."],[5000,5146,"Well, look at that,"],[5159,5330,"finally signed the divorce papers, huh?"],[5397,5472,"Logan and I are"],[5472,5559,"getting married soon."],[5559,5630,"You should come."],[5638,5784,"Wouldn't want you to miss it."],[5830,5951,"Congratulations, Regina."],[6101,6289,"You finally got what you always wanted."],[6498,6560,"I'll be there"],[6664,6740,"on time."],[7132,7207,"Regina,"],[7215,7349,"do you know the most brutal way"],[7349,7494,"to destroy someone?"],[7524,7828,"Let them climb all the way to the top"],[7849,8053,"then give them a little push"],[8053,8220,"straight into hell."]],"74":[[367,492,"Grandpa, you chose me"],[492,613,"to be Logan's wife."],[675,813,"But you never told me"],[813,942,"that Logan was Archer."],[1071,1180,"I guess you were just"],[1355,1443,"waiting for him to"],[1468,1605,"prove that he was worthy"],[1605,1743,"before revealing the truth."],[1993,2122,"And now he's capable,"],[2193,2264,"strong,"],[2373,2439,"ready."],[2648,2748,"But did you know?"],[2890,3069,"Our daughter left this world"],[3090,3365,"without ever meeting her father."],[3424,3566,"She never had a dad."],[3870,3987,"She's gone."],[4083,4233,"My baby girl"],[4300,4391,"is gone."]],"75":[[817,975,"Ladies and gentlemen,"],[1009,1117,"welcome to the wedding"],[1117,1259,"of Mr. Logan Hale"],[1267,1388,"and Miss Regina Brown."],[1589,1705,"Before we begin,"],[1755,1951,"please enjoy this special video"],[1993,2127,"featuring some of their"],[2131,2264,"sweetest memories."],[3912,4024,"What a monster."]],"76":[[154,266,"Oh my God!"],[304,458,"Regina tried to smother"],[458,671,"Mr. Hale's grandfather?"],[679,880,"I heard he slipped into another coma"],[884,971,"a few days ago."],[1013,1134,"So it was Regina?"],[1184,1309,"She's a monster."],[1309,1393,"Regina,"],[1443,1622,"you tried to kill my grandfather?"],[1639,1689,"Why?"],[1730,1851,"No, no, no I didn't."],[1926,2035,"No, somone's clearly trying"],[2035,2114,"trying to set me up."],[2185,2293,"Logan, you have to believe me."],[2293,2394,"I would never."],[2660,2731,"Who did this?"],[2769,2848,"Who played this video?"],[2848,2973,"Who's trying to ruin my wedding?"],[3003,3078,"I did."]],"77":[[37,108,"I did."],[1326,1426,"Oh my God."],[1447,1643,"Mr. Allan woke up."],[1668,1730,"Grandpa."],[1805,1985,"The doctor said he'd never wake up."],[2002,2135,"How is this even possible?"],[2156,2293,"Surprised, Regina?"],[2348,2519,"I had surveillance cameras"],[2519,2648,"installed in my ward."],[2786,2973,"Grandpa, what, what is going on?"],[2998,3090,"The day I woke up,"],[3161,3332,"she tried to smother me with a pillow."],[3432,3591,"She didn't want the truth to come out."],[3653,3845,"Regina Brown is a murderer!"]],"78":[[95,271,"No, there's no way."],[467,554,"Why would Regina"],[554,663,"do something like that?"],[696,821,"Grandpa, there's been a mistake."],[963,1126,"Regina is Gigi."],[1184,1238,"Gigi,"],[1288,1393,"Gigi would never do"],[1393,1497,"anything like that."],[1522,1651,"Regina is Gigi?"],[1651,1764,"Yes, Grandpa,"],[1801,1926,"Regina is Gigi."],[1947,2127,"I spent five years looking for her."],[2127,2227,"I finally found her."],[2389,2569,"She's not Gigi."],[2623,2727,"She's just a liar."],[2973,3032,"What?"],[3340,3407,"Regina,"],[3482,3616,"you say you're Gigi."],[3666,3799,"Then answer me this."],[3866,3974,"Five years ago,"],[4008,4241,"Gigi donated her corneas to Archer."],[4291,4471,"Why are your eyes perfectly fine?"]],"79":[[4,108,"Wait, Gigi"],[246,421,"gave her corneas to me?"],[546,671,"See for yourself."],[942,1188,"Archer, this is my fault."],[1226,1338,"I lied to you."],[1614,1710,"Five years ago,"],[1826,2085,"it wasn't Dr. Smith who cured your eyes."],[2189,2298,"It was Gigi."],[2344,2477,"She gave them to you."],[2694,2756,"No, how?"],[2798,2902,"How can that be?"],[2919,3111,"This woman is a fake."],[3186,3328,"I tried to expose her that day,"],[3328,3445,"but she tried to kill me!"],[3486,3545,"No..."],[3824,3887,"I didn't."],[3933,4004,"I swear."],[4066,4187,"I can testify."]],"80":[[54,145,"Dr. Smith?"],[145,200,"Mr. Hale,"],[200,404,"I tried to expose Regina at your party,"],[404,567,"but she had my daughter kidnapped"],[567,658,"and threatened me."],[709,855,"I had no choice but to lie."],[921,984,"No, no, no, no."],[984,1046,"You can't trust them."],[1046,1142,"They're all lying."],[1213,1309,"I'm Gigi."],[1426,1522,"I have the tag."],[1522,1735,"You stole that from Gigi, Regina!"],[1797,1960,"You nasty little thief."],[2072,2252,"If Regina is a fake,"],[2419,2548,"where is my real Gigi?"],[2606,2890,"Logan, you really don't know?"],[2977,3190,"Giselle is Gigi."],[3445,3536,"Five years ago,"],[3620,3778,"she gave you her eyes."],[3778,3974,"That's why she lost her sight."],[4012,4175,"She gave you her world, Mr. Hale."],[4191,4346,"She let you see through her eyes,"],[4346,4525,"so you could live with her vision."],[4917,4971,"Gigi."],[5422,5488,"I was wrong."],[5588,5668,"This whole time,"],[5668,5818,"I thought someone else was you."],[6101,6206,"You,"],[6368,6485,"you’re my Gigi."]],"81":[[1067,1151,"This is mine."],[1272,1388,"Your eyes,"],[1472,1559,"they’re healed?"],[1906,1981,"Yes, they are."],[2043,2231,"That’s, that’s not possible."],[2352,2452,"How do you think,"],[2477,2540,"Regina?"],[2982,3061,"Hey, little brat."],[3090,3211,"Still looking for your daddy?"],[3261,3415,"Well, you're never gonna find him."],[3415,3516,"Oh and your mom,"],[3549,3795,"She'll always be a pathetic, blind fool."],[3978,4104,"Miss Regina."],[4170,4371,"Mommy's going to see again soon."],[4391,4562,"And she's going to find my daddy."]],"82":[[54,200,"Astra gave me her corneas."],[233,304,"Astra?"],[337,504,"She, she was..."],[546,746,"She was your daughter, Logan."],[1413,1534,"Five years ago,"],[1722,1864,"when you left me,"],[2027,2135,"I was pregnant."],[2181,2285,"And I had Astra."],[2327,2506,"And I wanted to tell you in person."],[2598,2686,"Congratulations."],[2873,2965,"You're a father."],[3103,3219,"Astra used to always tell me"],[3219,3378,"that she was my eyes."],[3528,3678,"And now, she really is."],[3741,3903,"She was the greatest gift"],[3903,4004,"you ever gave me."],[4387,4458,"Archer,"],[4746,4888,"the man that I searched for,"],[4942,5042,"that I loved."],[5451,5534,"It's you."],[6035,6202,"Long time no see, Archer."]],"83":[[100,208,"I'm sorry, Gigi."],[262,367,"I didn't know."],[417,613,"I, I didn't know the whole time"],[613,767,"you were right there by my side."],[788,892,"I was this close."],[909,1051,"I was this close."],[1418,1547,"It's too late, Logan."],[1714,1968,"Astra and I waited for you"],[2014,2118,"day after day,"],[2310,2494,"year after year!"],[2560,2640,"I'm sorry."],[2815,2915,"Ans she's gone."],[3315,3470,"You will never,"],[3707,3807,"never,"],[3916,4058,"hear her call you Daddy."],[5372,5430,"Don't go."],[5430,5543,"Today is our wedding day."]],"84":[[70,204,"You lied to me!"],[221,316,"Regina Brown,"],[396,496,"you tricked me."],[563,638,"From now on,"],[675,788,"from this moment forward,"],[804,900,"I'm going to make sure"],[930,1105,"that every single day you live"],[1113,1234,"is like living in hell!"],[1409,1463,"No."],[1505,1664,"I did it because I love you."],[1922,2143,"Your love makes me sick!"],[2577,2702,"I was this close,"],[2761,2848,"this close"],[2890,3053,"to becoming Mrs. Hale."],[3111,3232,"Why?"],[3603,3682,"Gigi, wait."],[3853,3916,"Where are you going?"],[3978,4099,"I just lost Astra."],[4099,4358,"I, I can't lose you too."]],"85":[[421,546,"Mr. Hale, did you forget that"],[546,658,"we are divorced?"],[700,875,"She knew who I was back then,"],[925,1113,"but she still signed the papers."],[1839,1939,"Do you hate me?"],[2168,2252,"Shouldn't I?"],[2373,2560,"I hate myself"],[2627,2698,"too."],[4004,4108,"Astra left you this."],[4625,4808,"Goodbye Logan."],[7620,7736,"Hi, Daddy."],[7749,7874,"I'm Astra,"],[7874,7995,"I'm your daughter."],[8012,8162,"I just turned five."],[8245,8495,"I just took a family photo with my mom."],[8521,8612,"This is your seat,"],[8612,8800,"but you're still not here."],[9109,9230,"My daughter, Astra."],[9505,9693,"My sweet daughter, Astra."],[10447,10539,"I'm sorry."]],"86":[[4,196,"I'm so, so sorry,"],[196,300,"Astra."],[333,588,"If only I had been a good father."],[650,921,"I'd give anything to hear you laugh,"],[963,1134,"to see you smile."],[1209,1380,"But it's all too late."],[1755,1935,"I should have been there."],[2610,2723,"Gigi,"],[2786,2898,"Astra."],[2973,3274,"Will I finally see you two again?"],[3495,3816,"If everything could start over."],[5042,5163,"The divorce papers,"],[5163,5413,"they're ready to be signed by you, now."],[5480,5605,"Stop calling me Daddy."],[5605,5759,"I'm not your father."],[5784,6031,"I don't care who you sleep with."],[6051,6281,"This marriage is a sham."],[6952,7086,"What, wait..."],[7148,7286,"I went back in time."],[7374,7536,"Oh, look who's fallen from grace"],[7536,7753,"now, it's Logan fucking Hale."],[7774,7891,"Oh my God."],[7891,8024,"This is the day when Gigi"],[8024,8195,"and I first met."],[8212,8341,"No, no, no, no, no."],[8391,8504,"I can't let Gigi"],[8504,8650,"meet me in this lifetime."],[8666,8800,"If she never meets me,"],[8800,8954,"then all the unfortunate things"],[8954,9071,"won't happen to her."],[9088,9196,"I just have to get out of here"],[9196,9321,"before Gigi sees."],[10018,10126,"For the last time, I am not going to be"],[10126,10226,"marrying a stranger for money,"],[10276,10343,"Veronica."],[10343,10472,"If you are so desperate for this,"],[10573,10702,"go sell your own daughter."],[10739,10785,"Okay?"],[12132,12258,"Oh shizzles."]]}