{"1":[[1205,1326,"I've got eyes on target."],[1568,1609,"What?"],[1760,2052,"The distance is 4,000 meters."],[2143,2235,"That's too far."],[2339,2423,"Let's abort."],[2469,2560,"I'll make the shot."],[2631,2702,"Wind's light."],[2736,2898,"If I raise by 3.4 mil,"],[2911,3086,"shift MOA by 0.7."],[3086,3232,"Carl, this isn't about the wind."],[3282,3390,"We only get one shot."],[3399,3557,"Miss and you'll give away our position."],[3762,3849,"One shot,"],[3987,4079,"one kill."],[5463,5605,"Holy mother of God."],[5643,5726,"You made it."],[5755,5872,"4,000 meters."],[5943,6122,"You just set a new world record, man."],[6231,6293,"They don't call you the"],[6293,6456,"King of Guns for nothing."],[6473,6602,"K.O.G."],[6681,6781,"Yeah, you know I'm not in it"],[6781,6927,"for the fancy titles."],[7094,7157,"So,"],[7211,7282,"what's next now"],[7282,7411,"that your last mission's over?"],[7444,7486,"Huh?"],[7674,7836,"I spent my entire life in the service."],[7891,8028,"Once this uniform comes off,"],[8066,8224,"I just wanna get back to my gun range,"],[8237,8295,"my daughter,"],[8337,8420,"my grandkid."],[8541,8637,"Just make up for all the time"],[8637,8729,"that we got lost."],[8929,8988,"Don't worry."],[9075,9184,"I'll miss you too, buddy."],[9592,9651,"Carl!"],[12374,12654,"Today, we honor a national hero."],[12704,12787,"A sniper"],[12787,12962,"who has defended our democracy,"],[13017,13188,"saved countless lives,"],[13225,13484,"and struck fear in our enemies."],[13551,13717,"He now holds the record"],[13717,13859,"for the longest confirmed"],[13859,14051,"kill shot in history."],[14101,14431,"The legendary King of Guns."],[14793,14852,"And now,"],[14910,15040,"President Bradford"],[15115,15294,"will present our hero"],[15331,15448,"with the Medal of Honor."],[15990,16045,"Thank you."],[16107,16153,"Thank you."],[16203,16266,"But please,"],[16278,16520,"save your applause for our hero."],[16537,16816,"This is his first public appearance."],[16858,16933,"Please welcome"],[16983,17129,"the legendary marksman,"],[17146,17313,"the King of Guns."]],"2":[[625,788,"All they talk about are the records"],[788,900,"I’ve broken."],[1005,1138,"But no one remembers you,"],[1188,1393,"the man who died to make it happen."],[1447,1564,"I'm done, Lewis."],[1701,1793,"I swear"],[1839,1943,"that my gun will never"],[1943,2047,"draw blood again."],[2206,2285,"From now on, I'll protect"],[2285,2439,"your family with my life."],[2623,2756,"You can rest in peace."],[3011,3111,"Breaking news."],[3136,3294,"Seconds before he is to receive"],[3294,3407,"the Medal of Honor,"],[3407,3628,"the King of Guns has vanished."],[4700,4750,"Carl,"],[4750,4829,"can you take a gun"],[4829,4954,"apart for me again?"],[5017,5109,"Not today, kiddo."],[5155,5213,"I promised your mom"],[5213,5355,"I'd do ammo inventory."],[5422,5530,"I've inspected the new guns."],[5530,5668,"The checklist is on your desk."],[5689,5730,"Thanks."],[5784,5876,"Great work, Carl."],[6327,6410,"What the hell?"],[7161,7298,"Fucking shit!"],[7349,7524,"Why is my ex-husband here?"],[7895,8028,"Why does this dogshit range"],[8028,8103,"not have anything"],[8103,8266,"other than broken down shit?"],[8650,8779,"Benny, what are you doing here?"],[8779,8833,"What?"],[8900,9013,"I can't come by and say hello"],[9013,9150,"to my beautiful wife"],[9150,9263,"and maybe get a little hug"],[9263,9338,"from my daughter?"],[9338,9430,"Hey, Rebecca."],[9592,9726,"Just stop, okay?"],[9772,9855,"We're divorced."],[9855,9997,"We've been divorced for years."],[10039,10206,"And you haven't changed one bit."],[10210,10497,"Still, such a fucking buzzkill."],[10785,10877,"Hey, baby girl."],[10931,11094,"I know that you missed your daddy,"],[11131,11177,"right?"],[11261,11327,"You're okay."],[11874,12016,"Just an ungrateful,"],[12016,12233,"spoiled little frickin' brat."],[12233,12379,"Just like her mother, huh?"]],"3":[[91,191,"Now look at you two."],[221,350,"Only a couple years divorced,"],[350,454,"and you're already shacking it up"],[454,592,"with the local handyman."],[629,746,"God, your standards have"],[746,959,"really hit rock bottom, huh?"],[959,1080,"Carl is my employee."],[1092,1167,"Nothing more."],[1213,1372,"Besides, I've told you a million times,"],[1372,1551,"I, I'm not paying your gambling debts."],[1572,1668,"Now I know you got a little"],[1668,1797,"stash of money hidden."],[1860,2052,"That's why you gave up on the alimony."],[2060,2235,"So just do the right fucking thing"],[2235,2327,"and give me my share."],[2327,2469,"No, actually, I didn't take your money"],[2469,2573,"because I don't want a piece of shit"],[2573,2686,"like you near my daughter."],[2702,2819,"Well, then just pay up!"],[2907,3078,"Or I'll just show up here every day."],[3119,3224,"Hell, maybe call in"],[3224,3357,"for a few safety violations,"],[3357,3420,"get the cops"],[3420,3499,"breathing down your neck,"],[3499,3603,"and we'll see how long you last"],[3603,3674,"in this business."],[3674,3803,"Probably not very fucking long."],[3853,3983,"You're not getting a cent from me."],[4037,4116,"All right, well."],[4204,4304,"Hey, Rebecca, honey."],[4371,4450,"How about Daddy comes"],[4450,4546,"and picks you up from school"],[4546,4617,"every day now?"],[4617,4729,"So we can get a lot more"],[4729,4871,"father-daughter bonding time,"],[4871,4921,"alright?"],[5138,5296,"Touch my daughter, see what happens."],[5593,5663,"Jane, baby,"],[5663,5751,"looks like you got some"],[5751,5855,"boldness to you now."],[5935,6010,"What are you gonna do?"],[6039,6114,"Shoot me in front of your"],[6114,6210,"baby girl here?"],[6289,6398,"Mommy?"],[6448,6514,"Jane,"],[6648,6706,"put the gun down."],[6706,6781,"That's what he wants."],[6781,6856,"Don't let him get to you."],[6890,6981,"Come on, Janie."],[7007,7065,"You know I'm a"],[7065,7240,"B-Class sharpshooter, right?"],[7307,7382,"I can see by the look"],[7382,7507,"in your eyes right now"],[7582,7720,"that you're not gonna pull that trigger."],[7791,7907,"You sure about those odds?"],[8608,8650,"Well,"],[8750,8875,"I am a betting man."],[9125,9167,"Mommy!"],[9205,9255,"Jane!"],[9267,9334,"Hey, guy!"],[9376,9517,"Don't you fucking move, alright?"],[9542,9622,"You stay right there."],[9751,9805,"Mommy!"],[9838,9934,"Now listen, baby girl."],[9964,10226,"Tell Daddy where the stash of money is."],[10226,10372,"I, I don't know."],[10389,10456,"Well, then Daddy will"],[10456,10581,"give you a little push."],[10581,10648,"I want you to think"],[10648,10773,"very clearly now, alright?"],[10794,10935,"Don't hurt my Mommy!"],[10960,11048,"Then just tell me"],[11094,11248,"where the money is, sweetheart."]],"4":[[25,120,"Mommy."],[1322,1455,"Was he aiming for the trigger?"],[1568,1676,"I mean, the precision."],[2281,2318,"Hey,"],[2402,2460,"Come on,"],[2460,2544,"you're okay."],[2673,2740,"Hey."],[2740,2811,"You're okay."],[2848,2907,"I got you."],[3803,3937,"What, what, you just tried to"],[3937,4012,"fucking shoot me?"],[4012,4054,"Well."],[4108,4250,"Well, I got news for you, pal."],[4308,4400,"You fucking missed."],[4416,4537,"If I was trying to shoot you,"],[4629,4692,"you'd be dead."],[4700,4796,"You think you scare me?"],[4875,4971,"Everybody here knows that"],[4971,5146,"I'm a B-Class ranked shooter."],[5167,5280,"You don't scare me at all."],[5367,5501,"What's it gonna take for you to leave?"],[5576,5718,"Let's do this the old school way."],[5764,5826,"See this gun?"],[5868,5955,"I challenge you"],[5993,6118,"to an assembly contest."],[6156,6281,"First one to disassemble"],[6302,6427,"and reassemble this gun"],[6427,6564,"and shoot first wins."],[6598,6744,"If you win, I'll leave."],[6756,6965,"If I win, then you cut off that finger"],[7002,7144,"that you just used to pull the trigger."],[7144,7182,"Deal."],[7182,7278,"No, no."],[7311,7390,"Carl, you, you can't"],[7390,7511,"He's professionally trained."],[7524,7603,"Well, then baby,"],[7603,7757,"just fork over the money, Janie."],[7778,7882,"That's all you gotta do."],[7987,8066,"It's okay, Mommy."],[8066,8212,"Carl's got this."],[9071,9146,"Rules are simple."],[9200,9271,"Disassemble..."],[9480,9563,"then reassemble."],[9667,9772,"First to fire wins."],[10335,10402,"On your mark."],[10523,10589,"Get set."],[10977,11002,"Go."]],"5":[[1013,1130,"Falling behind already, huh?"],[1764,1864,"Shit."],[3666,3870,"Your mag, genius."],[3987,4041,"What are you telling me"],[4041,4120,"that gun's loaded?"],[4124,4170,"You lost."],[4216,4341,"That's impossible, alright?"],[4358,4504,"I'm a B-Class sharpshooter."],[4504,4617,"You're a fucking handyman."],[4617,4675,"You're telling me-"],[5251,5334,"I know that move."],[5380,5534,"My, my dad taught me that trick."],[5601,5680,"Why does he know it?"],[5893,6014,"Carl, you're so cool!"],[6014,6118,"You're my hero!"],[6210,6243,"You know what?"],[6243,6423,"I'm sick of your shit, you little brat."],[6464,6602,"Don't you even think-"],[6902,7011,"Oh, shit."],[7203,7344,"This ain't over yet, you know that?"],[7570,7611,"Hey,"],[7661,7920,"now you listen to me very carefully."],[7987,8095,"You touch them again,"],[8124,8254,"and I'll make you suffer in ways"],[8254,8366,"that you can't imagine."],[8458,8550,"Over and over"],[8550,8746,"until you beg me to end it."],[8938,9021,"You don't want me to step"],[9021,9129,"close to them ever again?"],[9129,9242,"Fine, I won't fucking come"],[9242,9313,"near them again."],[9446,9526,"Get the fuck away from me,"],[9534,9663,"you fucking little freak."]],"6":[[475,592,"Hey, are you hurt?"],[679,817,"Carl, you're awesome!"],[992,1046,"My gosh, I,"],[1105,1176,"I don't even wanna"],[1176,1230,"think about"],[1230,1280,"what would've happened"],[1280,1363,"if you weren't here."],[1534,1601,"You're bleeding."],[1701,1743,"Oh."],[1805,1951,"I'm, I'm fine, seriously."],[1951,2018,"It's okay."],[2027,2135,"I'll get you a bandage."],[2344,2389,"Thank you."],[2577,2648,"Hey, Baby."],[2711,2790,"Why don't you go inside"],[2790,2911,"while Carl helps Mommy, okay?"],[2940,2982,"Okay!"],[2982,3057,"Okay, I love you."],[3086,3144,"I love you!"],[4600,4675,"It's not so bad."],[4746,4783,"Good."],[5605,5647,"Hey,"],[5814,5872,"is there something you're"],[5872,5947,"not telling me?"],[6314,6418,"It, it's just that..."],[6443,6477,"Jane!"],[6589,6706,"Mr. Redford's pulling up."],[6706,6810,"The Chris Redford,"],[6835,6873,"coach of the"],[6873,6931,"National Shooting Team."],[6977,7027,"Come on, Cap,"],[7044,7152,"now's your shot to impress him."],[7161,7261,"This is Chris Redford"],[7261,7374,"we're talking about here."],[7403,7545,"He's an A-Class sharpshooter."],[7570,7686,"And there's only 100 people"],[7686,7824,"in the world on his level."],[7832,7966,"Can you imagine being that good?"],[7995,8108,"There's always someone better."],[8166,8274,"Now, even among all of these"],[8274,8366,"elite sharpshooters,"],[8429,8495,"you won't find a better shot"],[8495,8571,"than the King of Guns."],[8571,8666,"He's the best in the world."],[8666,8754,"There's no competition."],[8804,8888,"Do your best today."],[8942,9021,"Okay, but just remember,"],[9021,9109,"this is a chance to learn"],[9109,9184,"from one of the greats."],[9213,9305,"Chris Redford?"],[9313,9451,"That second rate lieutenant stuck"],[9451,9567,"on gun maintenance duty?"],[9580,9651,"He's coaching the"],[9651,9793,"national shooting team?"]],"7":[[204,246,"Oh, hey!"],[246,287,"Um."],[287,362,"Don't leave yet."],[421,529,"Look, today is huge for us."],[529,658,"If Mr. Redford can endorse us,"],[658,788,"we'll be golden."],[829,884,"So stick around?"],[909,975,"In case."],[1038,1092,"In case of what?"],[1180,1247,"This loser?"],[1247,1363,"Jane, I, I honestly don't understand"],[1363,1493,"why you insist on keeping him around."],[1522,1555,"Jane,"],[1589,1751,"he's only been with us for a year."],[1751,1881,"And today is huge."],[1889,1964,"I mean, we can't afford to"],[1964,2052,"take that risk."],[2072,2106,"Yeah,"],[2135,2268,"he's good at sweeping floors"],[2268,2473,"and cleaning barrels, but that's it."],[2531,2648,"Let's leave it to the professionals."],[2648,2802,"Just stop being condescending,"],[2802,2844,"okay?"],[2902,2961,"Carl's one of us."],[3032,3157,"And plus, he could use the experience,"],[3157,3215,"so be nice."],[3311,3407,"Alright, go get ready."],[3440,3486,"I'm gonna go show"],[3486,3582,"Coach Redford around."],[3616,3674,"And just remember,"],[3674,3766,"if we can impress him,"],[3766,3887,"this will be huge for us."],[3970,4012,"A game."],[4421,4546,"Know your place, handyman."],[4587,4646,"Don't even think about"],[4646,4704,"making a scene."],[4713,4825,"Keep your head on straight,"],[4875,4963,"if you wanna shoot straight."],[4988,5050,"I'm a pro."],[5084,5184,"I don't need tips from a handyman."],[5230,5296,"Stay in your lane."],[5296,5367,"You think you know more"],[5367,5455,"than our captain?"],[5522,5588,"You haven't even taken"],[5588,5676,"a shot around here."],[5705,5930,"A nobody like you might not get it,"],[5930,6101,"but this is a big deal for us."],[6314,6452,"You better not mess it up."]],"8":[[604,713,"This is Alex,"],[754,846,"captain of our shooting club."],[1071,1151,"He's the best shot we got."],[1447,1551,"Watch and learn, handyman."],[5226,5276,"Not bad."],[5330,5392,"Good shot."],[5422,5505,"Great accuracy."],[5530,5613,"Nines all around."],[5668,5755,"You really are our best."],[5801,5872,"I'm a professional."],[5930,6026,"Unlike someone, who"],[6026,6131,"probably can't hit the target."],[6172,6218,"Captain,"],[6264,6368,"show him who's boss."],[6410,6456,"Yeah."],[6519,6610,"Watch and learn, loser."],[7503,7578,"You're up, handyman."],[7653,7741,"Fix this piece of junk."],[7799,7907,"Go on, handyman."],[7957,8041,"It's your time to shine."],[8087,8145,"Shine?"],[8212,8345,"Look at how dirty his hands are."],[8404,8579,"All he's shining are guns these days."],[9430,9601,"Isn't Carl the coolest?"],[9705,9768,"Sure."],[9805,9897,"If you're six."],[10214,10285,"So quickly?"],[10460,10518,"No, there's no way you"],[10518,10585,"even fixed anything."],[10610,10689,"And where's the scope?"],[10748,10802,"Don't be fooled"],[10802,10927,"by his little party tricks, kid."],[10990,11102,"Hey, it'll jam again soon."],[11165,11248,"Give it three shots."],[11294,11344,"Tops."],[11398,11549,"Hey, uh, Carl, maybe just,"],[11565,11707,"like, double check it one more time."],[11707,11840,"I don't want it failing right now."],[11928,12095,"Why don't you take a few shots first?"],[12162,12278,"Get past three and I'll take it."],[12349,12445,"You're not gonna embarrass me."],[13096,13133,"What?"],[13138,13221,"No, no scope?"],[13279,13388,"Point shooting at 50 meters?"],[13488,13567,"You think you'll hit anything?"],[13580,13642,"At this range?"]],"9":[[1418,1497,"What the fuck?"],[1597,1697,"He just hit a bullseye."],[1856,1897,"Whoa."],[3199,3236,"There."],[3290,3349,"No jams."],[3511,3578,"Lucky shot."],[3628,3674,"I mean, you whiffed"],[3674,3774,"the last three anyway."],[3878,3987,"His stance and posture, I"],[4024,4112,"I mean, he's definitely"],[4112,4229,"been professionally trained."],[4275,4446,"He's been here for a whole year now."],[4446,4479,"I..."],[4587,4700,"How come I never noticed?"],[4804,5005,"Was that really just a lucky shot?"],[5096,5271,"God, how dare you waste bullets"],[5271,5451,"and Mr. Redford's precious time."],[5451,5588,"Mr. Redford, he's just a handyman"],[5588,5701,"helping at the range, I mean,"],[5734,5889,"we'd never make a mistake like this."],[6160,6327,"Only a dump like this"],[6327,6506,"would hire such clowns."],[6548,6602,"But hey,"],[6694,6848,"guess that's all you can afford."],[7002,7190,"Oh, Mr. Redford."],[7215,7290,"What a shame."],[7415,7678,"You came all this way for a circus act."],[7791,7953,"Is this really the best your"],[7953,8149,"shooting club has to offer, niece?"]],"10":[[12,137,"You're not welcome here, Matthew."],[333,433,"Wow, Jane."],[483,596,"You've really turned this"],[596,742,"place into a dump."],[784,984,"If my brother Lewis were still around,"],[1034,1159,"he'd be disappointed."],[1272,1463,"My father was a fucking hero."],[1463,1651,"You keep his name out of your mouth."],[1755,1847,"What are you doing here?"],[1947,2185,"I'm here to honor my poor brother,"],[2202,2298,"the fallen hero."],[2377,2548,"And to see what this"],[2569,2744,"scrappy little shooting range"],[2744,2794,"is worth."],[2827,3007,"I'm not selling it, so you can just go."],[3048,3111,"I'm not the one"],[3111,3194,"that's going to be leaving."],[3349,3599,"This is the loan your father took"],[3599,3816,"to build this shooting range,"],[3853,4116,"putting the land up as collateral."],[4116,4200,"You've been making all the"],[4200,4371,"minimum payments for the years,"],[4371,4587,"but the interest just"],[4654,4800,"keeps going up."],[4854,5009,"Well, that's none of your business."],[5063,5417,"I bought out the bank that financed you,"],[5417,5622,"which makes me your new creditor."],[5655,5839,"You fucking asshole."],[5901,6018,"This place was my father's"],[6018,6068,"pride and joy,"],[6068,6172,"and I would go bankrupt"],[6172,6285,"before selling it to you."]],"11":[[8,116,"One word from me,"],[116,229,"and this plot of land"],[229,337,"will be up for auction."],[379,554,"This range will be mine."],[633,834,"You and your nobodies"],[863,1109,"can pack up your things and get lost."],[1142,1197,"Matthew, I mean"],[1197,1309,"how can you do this to us?"],[1309,1384,"You know how hard"],[1384,1463,"my father worked to-"],[1463,1539,"Oh, come on!"],[1568,1689,"Don't say your uncle"],[1689,1818,"never gave you a shot."],[1860,1989,"With Coach Redford here,"],[2014,2097,"what do you say"],[2097,2231,"we settle this with a"],[2310,2398,"little contest?"],[2452,2527,"What do you want?"],[2581,2827,"You win, the range is yours to keep."],[2861,3011,"I'll even fund a renovation."],[3115,3203,"You lose,"],[3269,3407,"the shooting range is mine."],[3482,3545,"Forever."],[4137,4179,"Deal."],[4316,4400,"Then it's settled."],[4475,4571,"If we lose,"],[4571,4733,"are we gonna get kicked out?"],[4804,4929,"Don't worry, sweetie."],[5005,5109,"It's not gonna happen."],[5159,5288,"Don't back down now, Jane."],[5376,5438,"Mr. Redford,"],[5467,5668,"as coach of the National team,"],[5668,5809,"we'd be honored to have you"],[5809,5964,"judge our little contest."],[6673,6906,"Don't worry, Mommy, we've got Carl."],[7077,7211,"He'll just slow us down."],[8717,8842,"Oh, shit."]],"12":[[8,145,"Let's make this a best of three."],[212,350,"First round is trap shooting."],[367,533,"Fifteen clay pigeons total."],[546,684,"Any weapon of your choosing."],[759,917,"We'll provide fifteen bullets."],[996,1167,"First person to hit the most targets"],[1167,1317,"in the least amount of time, wins."],[1338,1426,"Oh!"],[1438,1643,"We got the first round in the bag."],[1701,1797,"Captain Alex here"],[1797,1931,"once held a State record"],[1931,2010,"for trap shoot."],[2022,2160,"Oh shit."],[2173,2260,"That's Nate Foster."],[2260,2410,"He's a B-Class sharpshooter."],[2410,2544,"He's just a cowboy."],[2573,2660,"What's the big deal?"],[2690,2819,"Jane, leave this first round up to me."],[2836,3007,"Yeah, you'll definitely win this."],[3023,3103,"Okay, guys."],[3119,3194,"Even though he's only"],[3194,3299,"a B-Class sharpshooter,"],[3328,3428,"he's beaten A-Class gunmen"],[3428,3566,"in clay pigeon shooting twice."],[3670,3812,"Two A-Class shooters?"],[3849,3937,"He has a specialty,"],[3937,4079,"and it's trap shooting."],[4596,4713,"Maybe we can use him"],[4713,4825,"to test the waters."],[5025,5096,"Round one."],[5171,5242,"Carl, you're up."]],"13":[[0,41,"Handyman?"],[41,145,"He's not even on the team."],[150,229,"Shouldn't we be sending our"],[229,321,"captain out there?"],[329,542,"Jane, he's good at polishing guns,"],[554,642,"not shooting them."],[654,713,"Come on."],[742,859,"Everything's on the line here."],[884,992,"He's probably gonna freak out"],[992,1138,"and piss his pants or something."],[1205,1326,"Jane, are you serious?"],[1351,1526,"Sending a worthless nobody?"],[1543,1597,"What, you got nothing"],[1597,1743,"but losers on your team?"],[1776,1860,"Damn."],[1968,2135,"Nate was just my warm-up."],[2177,2256,"I haven't even shown you"],[2256,2381,"the ace up my sleeve."],[2381,2652,"Nate Foster's just a warm-up?"],[2669,2706,"He's better than"],[2706,2844,"some A-Class shooters."],[2877,2961,"Don't you get it?"],[2977,3119,"When that nobody loses,"],[3119,3203,"Jane will say it's because"],[3203,3370,"her guy's just a handyman."],[3420,3620,"She's already looking for excuses."],[3649,3837,"Good thing your daddy isn't around"],[3837,3987,"to watch you run his"],[3987,4145,"shooting range into the ground."],[4437,4537,"Will you shoot for us?"],[4934,5063,"Jane, let me do this."],[5075,5192,"Look, we need to be careful."],[5221,5317,"You see what Nate's level is,"],[5317,5455,"so just stop complaining."],[5530,5651,"And watch his every move."],[5680,5872,"Oh, that's her plan."],[5901,6026,"Jane thinks I'm too good to go up"],[6026,6143,"against the warm-up guy."],[6218,6352,"That loser really thinks"],[6352,6485,"Jane believes in him."],[6514,6573,"Ha!"]],"14":[[20,166,"I ain't here to waste my time."],[183,246,"Alright?"],[316,462,"Y'all really sending that handyman?"],[487,558,"Hey, handyman."],[588,679,"Not everyone gets a chance"],[679,875,"to lose to a B-Class sharpshooter."],[896,1001,"Consider it an honor."],[1030,1167,"Maybe he'll finally see us"],[1167,1347,"as the real gunslingers we are."],[1355,1543,"And he's just a gun-polishing grunt."],[1564,1609,"Does he really think"],[1609,1714,"he's some kind of hotshot?"],[1743,1885,"Jane, are you sure?"],[1926,2152,"Your opponent is a B-Class shooter."],[2198,2298,"I've made my choice."],[2369,2423,"Alright."],[2485,2544,"Contestants,"],[2615,2694,"choose your weapon."],[2840,2961,"He's actually going up there."],[2986,3090,"I can't tell if he's brave"],[3090,3236,"or just stupid."],[4166,4225,"I ain't coming here to"],[4225,4325,"pick on some newbie,"],[4375,4462,"especially a grunt like you"],[4462,4642,"not even fit enough to polish my guns."],[4779,4884,"So you go ahead, princess."],[4884,4971,"You can pick first."],[5955,6014,"What?"],[6056,6197,"The shotgun is sitting right there,"],[6197,6348,"and he's picking the handguns?"],[6381,6506,"Probably because he doesn't know"],[6506,6635,"how to use a shotgun."],[6639,6806,"That loser's about to embarrass us all,"],[6873,7002,"especially your Mommy."],[7136,7253,"Oh, no."],[7273,7428,"Was I wrong to choose him?"],[7511,7636,"Nice."],[7649,7782,"I thought this was going to be a"],[7782,7916,"boring snooze-fest."],[7928,8124,"Luckily, you brought us a clown"],[8124,8237,"to keep us laughing."],[8454,8558,"Carl, what's going on"],[8558,8683,"in that head of yours?"],[8708,8829,"Say it ain't so."],[8863,8954,"You're really not going to pick that"],[8954,9071,"shotgun there, huh?"],[9104,9288,"Too loud for them fragile ears of yours?"],[9321,9476,"Nah, for something this easy,"],[9517,9626,"shotgun is overkill."]],"15":[[221,271,"Oh."],[333,450,"Don't say I didn't warn you."],[513,654,"And look here, I'm down an eye."],[692,779,"Imagine how ugly"],[779,930,"it'd be if I had both, huh?"],[1130,1217,"Nate Foster,"],[1355,1455,"load and make ready."],[4033,4158,"And that was Nate Foster."],[4179,4295,"15 out of 15."],[4295,4458,"Just under 20 seconds."],[4512,4746,"15 in 20 seconds?"],[4746,4946,"Didn't he forget that bullet?"],[4975,5034,"No."],[5063,5167,"He did it on purpose."],[5217,5338,"He even set aside a bullet"],[5338,5501,"to kill two birds with one shot."],[5543,5668,"He's a B-Class shooter?"],[5668,5734,"No way."],[5747,5880,"That's an A-Class performance"],[5880,5972,"if I've ever seen one."],[5980,6168,"No, he's doing it to mess with Carl."],[6168,6327,"He's trying to, like, frazzle him."],[6339,6393,"Either way,"],[6393,6548,"Carl doesn't stand a fucking chance."],[6589,6648,"Come here."],[6748,6927,"A souvenir for you to remember me by."],[6990,7082,"Something to remember the day"],[7082,7178,"you got destroyed."],[7223,7307,"Or better yet,"],[7407,7511,"blow your brains out,"],[7565,7711,"after you're drowning in shame."],[7728,7766,"Huh?"],[8208,8362,"Carl, you're up."]],"16":[[617,809,"Nate Foster is on another level."],[834,913,"And at this point,"],[967,1063,"all he can do is save himself"],[1063,1163,"the embarrassment."],[1163,1242,"No, no, no."],[1263,1322,"Let him try."],[1368,1480,"Can't wait to see him"],[1480,1568,"shit the bed."],[1618,1722,"He's been acting all high and mighty"],[1722,1801,"for way too long."],[1801,1864,"It's about time someone"],[1864,1964,"cut you down to size."],[2014,2077,"Jane's about to see you"],[2077,2173,"for what you really are,"],[2173,2335,"a worthless handyman."],[2344,2398,"Not too late"],[2398,2544,"to switch guns there, partner."],[2602,2736,"I'll even turn a blind eye."],[2794,2898,"Jane just tell Carl to forfeit."],[2898,2994,"He's done enough already."],[2998,3078,"I'll put the team on my back."],[3078,3178,"We'll win the next round."],[3203,3424,"Maybe I'm asking too much of him."],[3507,3624,"Carl can do it!"],[3628,3770,"I believe in him."],[4208,4308,"Would you look at that?"],[4329,4496,"He has a little fan."],[4529,4679,"Mommy should have taught you to"],[4696,4829,"not trust bad men."],[5005,5176,"Carl wouldn't lie to me!"],[5205,5376,"He's not a bad man."],[5376,5455,"You are!"],[5976,6076,"Seventeen?"],[6126,6239,"What's that supposed to mean?"],[7653,7707,"Look."],[7732,7895,"This loser is out of his mind."],[7970,8016,"Ha."],[8041,8199,"What's he covering his eyes for?"]],"17":[[216,371,"What's he covering his eyes for?"],[421,446,"What?"],[446,529,"Too much of a wimp"],[529,671,"to watch himself fail?"],[679,829,"Shit, he gotta cover his tears."],[834,942,"Fucking crybaby."],[992,1088,"He's just being petty."],[1096,1197,"Nate did it with one eye,"],[1197,1313,"so he's gotta do it with zero."],[1338,1434,"That way, if he gets lucky"],[1434,1555,"and hits a few, he can keep up with"],[1555,1655,"pathetic little act."],[1664,1751,"Exactly."],[1755,1897,"If he loses, he can just blame it on"],[1897,2010,"not being able to see."],[2022,2143,"It's the perfect excuse."],[2168,2331,"Maybe he's not as dumb as he looks."],[2385,2515,"He's got it all planned out."],[2986,3040,"He hit it."],[4191,4316,"15 out of 15..."],[4362,4483,"in 17 seconds."],[4683,4842,"What the fuck did I just see?"],[4875,4996,"17 seconds?"],[5009,5092,"That's what he wrote down there"],[5092,5167,"on the ground."],[5205,5342,"He predicted his own score."],[5384,5522,"And he did it blindfolded."],[5609,5705,"How'd he do that?"],[5805,5943,"Did he do it by ear?"],[6010,6139,"Who is this guy?"]],"18":[[29,212,"And the round one winner is Carl!"],[1009,1217,"17 seconds, just like you asked."],[1217,1355,"I knew you could do it!"],[1388,1639,"You can do it in 17 seconds."],[2097,2181,"Oh, my God."],[2198,2344,"Carl, you actually did it."],[2377,2435,"Big whoop."],[2435,2615,"He, he sets the traps here."],[2652,2744,"He knows the exact path"],[2744,2823,"those pigeons take."],[2823,2973,"I mean, uh, how hard could it be to"],[2973,3174,"memorize trajectory and timing?"],[3186,3240,"Yeah."],[3257,3399,"He just went with a cheap trick,"],[3399,3557,"not actual skill."],[3620,3866,"What the fuck was that just now, huh?"],[3878,4062,"I spent a damn fortune to hire you."],[4070,4187,"Sir, sir, he's, uh-"],[4200,4304,"How did I know that the handyman"],[4304,4462,"was gonna be a damn crack shot?"],[4487,4583,"Alright, hey, how'd you do that?"],[4583,4717,"Save your excuses, alright?"],[4717,4863,"Go back to your fucking ranch"],[4863,5017,"and shovel horse shit."],[5176,5238,"Alright."],[5317,5492,"I'm done playing nice."],[5534,5672,"Time for the big guns."],[6406,6552,"Ms. Fisher."],[6573,6756,"It is an honor."],[6990,7102,"I'll be damned."],[7115,7248,"Ain't that the Black Widow?"],[7311,7436,"Rachel Fisher, right?"],[7478,7557,"Sure looks like it."],[7611,7711,"I heard she shot her first"],[7711,7824,"and second husbands dead,"],[7845,7932,"inherited their fortunes,"],[7978,8083,"and still got a huge insurance"],[8083,8174,"payout to boot."],[8179,8308,"Holy shit."],[8308,8429,"How'd she get away with that?"],[8441,8625,"Both cases were ruled self-defense."],[8637,8779,"Justifiable homicide."],[8837,8946,"Lord knows how she managed"],[8946,9046,"to swing that."],[9109,9305,"So, anyone wanna play?"]],"19":[[0,120,"Alright."],[158,308,"Now that the stakes have been raised,"],[325,383,"it's time to get"],[383,525,"the captain on out there."],[575,642,"Hear that?"],[663,775,"Our captain's gonna win with"],[775,880,"pure talent,"],[917,1155,"not some overplayed carnival trick."],[1197,1334,"True marksman doesn't rely on"],[1343,1422,"flashy stunts like"],[1422,1547,"shooting blindfolded."],[1597,1710,"It's all about keeping a"],[1722,1885,"calm heart and a steady hand."],[1935,2035,"Take notes, bud."],[2068,2248,"That's how the real sharpshooters do it."],[2786,2873,"Damn, girl,"],[2936,3036,"you sure can handle a rifle"],[3036,3174,"with a body like that?"],[3324,3474,"Wouldn't you like to know?"],[3507,3595,"Do you even know"],[3595,3762,"who you're up against, man?"],[3795,3862,"Trust me."],[3933,4045,"I'm not like those"],[4104,4220,"two ex-husbands of hers."],[4266,4400,"This little femme fatale gimmick?"],[4458,4558,"Ain't gonna work on me."],[4612,4675,"Really?"],[4754,4913,"Then what if I told you,"],[4979,5125,"she's the secret partner of"],[5125,5246,"the King of Guns?"],[5759,5968,"Since when did I have a partner?"]],"20":[[41,171,"The King of Guns has a partner?"],[200,275,"A woman?"],[321,396,"Wait, Matthew,"],[471,567,"did she really train with"],[567,650,"the King of Guns?"],[675,750,"Of course she did."],[767,892,"She just about mastered"],[892,1051,"everything he's capable of."],[1067,1146,"Which means,"],[1251,1309,"soon,"],[1343,1664,"the King of Guns title will be hers."],[1705,1768,"Jane,"],[1830,1960,"do you think Matthew's bluffing?"],[2006,2152,"Matthew's a big-time arms dealer."],[2168,2331,"I mean, he has Pentagon contracts"],[2331,2515,"and ties to the black market, but,"],[2531,2640,"even he wouldn't throw around"],[2640,2811,"the King of Guns name recklessly."],[2811,2869,"I don't think."],[2898,3028,"So you're saying it's true?"],[3061,3123,"So what?"],[3157,3261,"She's still just a chick."],[3261,3390,"Hey, watch yourself!"],[3453,3541,"It is an honor to have"],[3541,3657,"the King of Guns ace partner"],[3657,3791,"at our shooting range, okay?"],[4024,4099,"Ms. Fisher,"],[4149,4258,"welcome to my gun range."],[4304,4437,"Now that you know who I am,"],[4454,4571,"don't waste my time."],[4729,4813,"Forfeit."],[5050,5167,"One of the King of Guns'"],[5167,5367,"trademark moves is hitting targets"],[5367,5530,"that are blocked by obstacles."],[5576,5684,"No one's ever figured out"],[5684,5797,"how he's pulled it off."],[5864,5947,"Can you do this?"]],"21":[[37,200,"That's just some dumb urban legend."],[233,350,"How the hell do you hit a target"],[396,508,"blocked by an obstacle?"],[567,692,"I could show you, but,"],[725,909,"I don't think this crowd is ready"],[909,1084,"for such an entertaining show."],[1126,1230,"Well, suit yourself,"],[1230,1397,"but if you really are the ace partner"],[1405,1509,"of the King of Guns,"],[1551,1680,"you're gonna have to prove it."],[1743,1830,"For Round Two,"],[1868,2014,"it'll come down to one shot."],[2043,2185,"The challenge for round two"],[2231,2360,"is to hit that target,"],[2394,2527,"over 500 feet away."],[2556,2677,"Any weapon of your choosing."],[2715,2794,"No scope,"],[2848,2932,"no sights."],[2982,3094,"Highest score wins."],[3128,3190,"I mean, I mean that's"],[3190,3303,"basically a toss-up."],[3357,3420,"How?"],[3440,3528,"Is it even possible"],[3528,3666,"to hit that target from here?"],[3699,3824,"They get one chance"],[3824,3945,"to shoot without a sight."],[3953,4058,"From this far out,"],[4108,4225,"forget a bullseye."],[4279,4458,"There are A-Class sharpshooters"],[4458,4608,"who couldn't get anywhere near that."],[4817,4921,"Looks like you wanna see"],[4921,5092,"the King of Guns' signature shot."],[5125,5192,"There's only two ways"],[5192,5313,"to hit the bullseye."],[5321,5384,"Number one,"],[5438,5601,"choose a high-caliber rifle,"],[5626,5705,"that's so strong"],[5705,5826,"it'll punch through the tires"],[5826,5914,"and hit the bullseye."],[5960,6056,"And number two,"],[6114,6306,"is the King of Guns' signature shot."],[6348,6418,"Well, if you're lucky,"],[6418,6548,"maybe I'll go with number two."],[6635,6785,"If you're gonna forfeit, do it now."],[6848,6881,"Once you see"],[6881,7002,"what I've got up my sleeve,"],[7094,7194,"you'll be out of time."]],"22":[[12,108,"Gimme a break."],[154,183,"You'd be lucky"],[183,287,"to you hit the target at all."],[529,658,"The last person who said that to me"],[658,821,"got a bullet to the head."],[1117,1184,"Mhm, well,"],[1284,1351,"ladies first."],[1418,1580,"Hey, don't underestimate her."],[1580,1726,"We can't afford to lose right now."],[1764,1906,"Come on, look at her."],[1951,2097,"She's gonna snap from the recoil."],[2114,2231,"If I just hit the target,"],[2231,2323,"we'll be golden."],[2936,3015,"Men..."],[3119,3249,"always thinking with their"],[3249,3336,"other head."]],"23":[[1088,1176,"What the fuck?"],[1176,1263,"She hit it?"],[1426,1522,"Looks like she really did learn"],[1522,1639,"from the King of Guns."],[1655,1772,"Holy smokes!"],[1780,1876,"She actually did it!"],[1897,1964,"The bullet ricocheted"],[1964,2072,"in a perfect spot."],[2093,2198,"I mean, that's not luck,"],[2198,2385,"any error in angle or velocity,"],[2385,2473,"she would've missed it."],[2540,2673,"I mean, that's, that's insane."],[2681,2781,"I-I can't believe I just saw"],[2781,2998,"the King of Guns trick shot in person."],[3019,3115,"I thought it was a myth."],[3203,3299,"It's a shame."],[3299,3445,"I really thought she might be the one"],[3445,3641,"to figure out my signature shot."],[3853,4058,"Captain, do we still have a shot?"],[4320,4450,"I could be a good sport"],[4487,4617,"and let you all have a chance."],[4696,4913,"But we all know who's gonna win."]],"24":[[37,112,"Nobody else in this range can"],[112,204,"hit that target."],[287,383,"We should just forfeit."],[408,550,"Look, you're the best shot in town."],[604,667,"If you're gonna go down,"],[667,792,"at least go down swinging."],[804,875,"Don't you get it?"],[925,1071,"This is fucking impossible!"],[1105,1209,"If I use the high-caliber rifle"],[1209,1297,"to pierce the tire,"],[1330,1455,"the accuracy would still be way off."],[1484,1609,"I'd be lucky to land a 9."],[1643,1772,"If you're going to forfeit,"],[1772,1872,"just do it already."],[1897,2035,"I've got a full-body spa session"],[2035,2102,"to go to."],[2218,2273,"Really?"],[2310,2439,"None of you stand a chance"],[2439,2569,"against the Black Widow."],[2594,2698,"Face the facts, Jane,"],[2744,2923,"there's no point in even trying now."],[3148,3261,"Just sign the paper,"],[3290,3453,"and hand the range over to me."],[3470,3570,"Guys, the range is done for."],[3616,3687,"We should see if Matthew"],[3687,3757,"will take us in."],[3782,3908,"Hey man, watch what you're saying."],[3908,4037,"Jane's standing right here."],[4074,4183,"She's about to get kicked out."],[4245,4362,"If we wanna save our own skins,"],[4362,4517,"we have to side with the winning team."]],"25":[[37,162,"I'm sorry, sweetie."],[179,308,"Tried to hold on to grandpa's"],[308,429,"gun range as long as I could."],[517,663,"Guess fate had a different plan."],[746,825,"Carl you should"],[825,959,"probably go with them too."],[975,1134,"Matthew might let you keep your job."],[1205,1263,"No!"],[1305,1363,"Mommy!"],[1401,1643,"You know how that lady said she's the"],[1643,1876,"ace partner to the King of Guns?"],[1897,2006,"Well, I think I know"],[2006,2185,"who the King of Guns is."],[2198,2331,"It's him!"],[2590,2665,"Don't be silly."],[2706,2806,"Why would the King of Guns"],[2806,2927,"be working at our gun range?"],[2994,3190,"But I just know it's Carl!"],[3532,3632,"Don't give up yet."],[3674,3816,"I still haven't taken my shot."],[4346,4425,"Him again?"],[4587,4713,"There's gotta be more to this guy"],[4713,4821,"than meets the eye."]],"26":[[79,196,"Oh, wow."],[196,371,"Look at you, Mr. Handyman,"],[425,492,"you gonna beat me"],[492,592,"with that little pistol?"],[850,946,"That's the plan."],[1009,1167,"Can you even see the target?"],[1205,1326,"We hit a ten."],[1355,1418,"Oh, you think you can"],[1443,1530,"pierce those tires"],[1530,1676,"and hit that bullseye with a"],[1693,1889,"9mm caliber bullet?"],[1926,2006,"Mr. Valentine,"],[2006,2085,"this Handyman's always"],[2085,2277,"strutting around like he's some bigwig."],[2306,2473,"Yeah, he knows a couple flashy tricks,"],[2473,2531,"but that's it."],[2590,2648,"If Jane hadn't give him"],[2648,2756,"the job here out of pity,"],[2756,2898,"he'd be rotting on the streets."],[2911,3023,"Yeah, he won that last round"],[3023,3132,"with a stupid trick."],[3182,3253,"And say, anyone see"],[3253,3403,"how nice he's been to Rebecca?"],[3445,3507,"I bet it's because he's trying to"],[3507,3616,"hit on her mom."],[3636,3724,"That's enough!"],[3762,3883,"Leave him alone!"],[5005,5150,"Something's not right here."],[5630,5839,"Holy mother of God."],[6635,6802,"He must have shot the last three bullets"],[6802,6936,"through the first bullet hole."]],"27":[[29,191,"Looks like it's time for this hero"],[191,333,"to come save the day."],[408,608,"Time to watch this clown"],[608,800,"make an absolute fool of himself."],[813,913,"Hey, someone record this."],[930,1042,"This is gonna make"],[1042,1222,"an amazing blooper reel."],[1272,1384,"What an idiot."],[1451,1526,"Carl,"],[1559,1622,"I, I don't-"],[1672,1710,"No!"],[1768,2031,"Mommy, you have to trust Carl."],[2056,2210,"He's the King of Guns!"],[2869,3019,"That is the funniest thing"],[3032,3132,"I have ever heard."],[3132,3282,"If he's the King of Guns,"],[3290,3520,"then I'm the second coming of Christ."],[3591,3741,"Rebecca, honey, you're being silly."],[3874,3958,"King of Guns?"],[3983,4041,"Kiddo,"],[4062,4179,"you might wanna close your eyes."],[4204,4333,"Your idol's about to go from hero"],[4333,4487,"to zero real quick."],[4600,4750,"Is he really going through with this?"],[4779,4917,"What a fucking weirdo."],[4959,5138,"Seriously, he's just dragging this out"],[5138,5276,"and wasting all our damn time."],[5301,5513,"The Black Widow personally mentored"],[5513,5647,"with the King of Guns."],[5655,5809,"This fool might as well be"],[5809,5897,"shooting from across"],[5897,6026,"the Pacific Ocean."],[6064,6168,"This'll be good."],[6285,6473,"I believe in you, Carl!"],[6852,6944,"Contestant two,"],[7015,7065,"make ready."],[7461,7536,"Pay attention."],[7561,7695,"You're only gonna see this once."],[7728,7836,"What you did, that wasn't"],[7836,8020,"the King of Guns' signature shot."],[8066,8133,"This is."]],"28":[[1547,1705,"What in God's name?"],[1739,1839,"That's impossible!"],[1901,2035,"The extreme momentum and spin"],[2035,2143,"made that bullet curve."],[2143,2331,"This, this is the real deal."],[2389,2510,"A legendary shot like that"],[2510,2744,"could only be made by the King of Guns."],[2748,2861,"In all that you were saying earlier,"],[2861,2923,"it was wrong."],[2969,3107,"He hit every bullseye,"],[3107,3236,"every single time."],[3261,3361,"So perfectly,"],[3378,3536,"that the other three shots went right"],[3536,3691,"through the same hole."],[3728,3828,"Didn't even leave a mark!"],[3891,3974,"A move like that."],[4266,4337,"Could it be?"],[4425,4491,"Are you?"],[4713,4825,"Now that composure."],[4854,4946,"The skill."],[4984,5063,"This man right here."],[5063,5217,"He's the real King of Guns!"],[5242,5351,"Yay, I knew it!"],[5392,5551,"Carl's the King of Guns!"],[5572,5651,"No, it has to be!"],[5668,5822,"This is the King of Guns."],[5851,5997,"The Round Two winner is Carl,"],[6022,6151,"the King of Guns!"],[6160,6281,"He's the real King of Guns?"],[6385,6452,"Oh God,"],[6519,6619,"I just embarrassed myself"],[6619,6748,"in front of the G.O.A.T?"]],"29":[[16,208,"The King of Guns has returned?"],[229,337,"I finally found him."],[375,487,"What would the King of Guns"],[487,658,"be doing here of all places?"],[667,746,"I never would have thought that"],[759,863,"that was him."],[863,1005,"He was just some handyman"],[1005,1096,"a second ago."],[1109,1230,"What if this is just one of his"],[1247,1322,"dirty tricks?"],[1343,1480,"No, but who else"],[1480,1580,"besides the King of Guns"],[1580,1672,"could curve a bullet?"],[1910,2047,"I'm so sorry, sir, I,"],[2085,2181,"I had no idea you were the"],[2181,2310,"real King of Guns."],[2318,2406,"I should have never claimed"],[2406,2489,"to be your partner."],[2523,2631,"All I've dreamed of is"],[2631,2723,"training under you."],[2727,2848,"I'll do anything."],[2873,2998,"That disgusting bitch."],[3028,3224,"How dare she use his reputation"],[3224,3365,"for her own personal gain!"],[3611,3757,"Useless fraud!"],[3787,3970,"I can't believe I fell for your lies."],[3983,4283,"Mark my words, you will pay the price."],[4291,4429,"Mr. King of Guns,"],[4475,4667,"I have been looking for you for ages."]],"30":[[8,241,"I'm not the King of Guns."],[254,333,"You're not?"],[371,496,"Then how the hell did you do that?"],[596,717,"It's a lucky shot I guess."],[725,784,"Hey you-"],[796,996,"uh, sir, uh, Mr. King of Guns."],[1059,1159,"Please, work with me."],[1197,1430,"I'll agree to whatever terms you set."],[1509,1793,"I told you, I'm not the King of Guns."],[1805,1914,"We won both rounds,"],[1914,2027,"it's time for you to leave."],[2056,2214,"Yes, yes, yes, of course."],[2243,2498,"Um, call me anytime."],[2510,2648,"And as we agreed,"],[2665,2927,"I will never touch this range."],[4571,4637,"So you and my dad"],[4637,4767,"were army buddies, huh?"],[4796,5063,"And uh, you're saying that he died,"],[5142,5251,"because of you?"]],"31":[[50,150,"Yeah, it's true."],[191,308,"If I'd have listened to him,"],[308,367,"our position"],[367,513,"might not have been exposed."],[579,746,"Why are you telling me this now?"],[813,996,"Do you expect me to be like grateful,"],[1034,1109,"for everything you've done"],[1109,1230,"around here since he died?"],[1247,1418,"Or are you asking for,"],[1418,1597,"I don't know, like forgiveness?"],[1647,1710,"I just thought that"],[1710,1822,"you should know the truth."],[1822,1956,"Oh, the truth?"],[2239,2348,"Well, the truth..."],[2481,2740,"is that my dad died saving you."],[2798,2865,"Look at you,"],[2948,3098,"hiding from your whole like"],[3098,3257,"King of Guns identity,"],[3290,3549,"wasting away at my gun range."],[3570,3678,"Are you just helping me"],[3678,3787,"to make yourself feel like"],[3787,3962,"less guilty to try and fulfill"],[3962,4029,"some sort of like"],[4029,4241,"sick twisted savior-complex?"],[4241,4320,"Look, Jane,"],[4346,4412,"I'm sorry- - No!"],[4412,4537,"Apologizing isn't gonna"],[4537,4642,"bring him back!"],[4642,4758,"If I could choose,"],[4888,5038,"it would be me instead of him."],[5080,5259,"Do you really think that saying that"],[5259,5472,"is gonna make me feel any better?"],[5505,5722,"Carl, my dad is dead and nothing"],[5739,5926,"you can do is gonna change that."],[5926,6085,"Jane, Jane, listen to me."],[6114,6235,"I know I'm not him."],[6335,6493,"He's a better man than I will ever be."],[6493,6631,"But supporting you and Rebecca,"],[6631,6731,"protecting the shooting range,"],[6731,6902,"it is everything to me."],[6919,7032,"It's what Lewis wanted."],[7032,7161,"Oh, just shut up!"],[7169,7282,"Stop fucking talking! - Okay,"],[7282,7436,"Okay, okay, fine."],[7595,7720,"Look, I'm sorry."],[7928,8124,"I never wanna see you again."]],"32":[[471,629,"So, what's next"],[629,779,"now that your last mission's over?"],[1059,1230,"I spent my entire life in the service."],[1280,1422,"Once this uniform comes off,"],[1459,1622,"I just wanna get back to my gun range,"],[1626,1697,"my daughter,"],[1735,1818,"my grandkid."],[1885,2039,"You just set a new world record, man."],[2168,2235,"They don't call you"],[2235,2398,"the King of Guns for nothing."],[2410,2531,"K.O.G."],[2665,2798,"I will treasure this pistol"],[2798,2944,"as a token of our friendship."],[3803,3949,"I love you guys, but,"],[3970,4104,"if you ever try and leave me again,"],[4158,4283,"I'm not gonna be so nice."],[4746,4863,"Hey Carl, check it out, man!"],[4896,4988,"Your video of your trick shot"],[4988,5059,"went viral."],[5080,5125,"It's got over a"],[5125,5221,"hundred-million views."],[5363,5538,"Carl, where are you going?"],[5559,5714,"I'm just taking a vacation"],[5714,5834,"for a little while, okay?"],[5935,6156,"Carl, when are you gonna come back?"],[6435,6639,"I, I just wanted to say thank you,"],[6685,6810,"for helping us keep our range."],[6865,6965,"It's the least I could do."],[7015,7119,"Mommy and I will be"],[7119,7315,"waiting for you while you're gone."],[7315,7444,"And when you come back,"],[7503,7682,"please, be my daddy."]],"33":[[0,125,"And when you come back,"],[154,337,"please, be my daddy."],[513,675,"Um, don't say that."],[684,800,"But Carl's the daddy"],[800,980,"that I've always wanted."],[992,1080,"Hey, hey, you."],[1201,1263,"Okay."],[1347,1476,"You gotta pinky promise me"],[1476,1580,"that you'll listen to your mommy"],[1580,1701,"while I'm gone, okay?"],[3307,3453,"So where's this famous handyman"],[3453,3557,"sharpshooter at?"]],"34":[[37,116,"You're Carl?"],[171,283,"I'm Hank."],[287,404,"And I'm here to invite you"],[417,533,"to join our organization,"],[588,654,"The One."],[692,767,"The One?"],[788,955,"Like, the deadliest team"],[955,1080,"of assassins in the world?"],[1096,1155,"Huh."],[1167,1280,"So you've heard of us."],[1297,1413,"Listen, my people can get you"],[1413,1514,"anything you need."],[1559,1655,"Resources,"],[1655,1743,"connections,"],[1743,1826,"weapons."],[1889,2014,"And not to mention,"],[2239,2360,"cold hard cash."],[2452,2598,"Think of this as an appetizer,"],[2669,2815,"a little show of sincerity."],[2844,2961,"Once you're one of us,"],[2986,3078,"you'll make a fortune off"],[3078,3203,"of every shot you take."],[3249,3315,"I'm talking more money"],[3315,3415,"than you can count."],[3532,3586,"Thanks."],[3687,3745,"But my days of"],[3745,3862,"shooting to kill are over."],[4145,4229,"What's the point of guns"],[4229,4325,"if not to kill?"],[4346,4479,"Are you gonna waste your talent,"],[4496,4662,"plinking steel at some back-ash"],[4662,4742,"shooting range?"],[4796,4954,"I made myself clear."],[5017,5163,"Years ago, I swore my gun"],[5163,5271,"would never draw blood again,"],[5271,5522,"and that is a promise I intend to keep."],[5547,5693,"Now, please, leave."],[5734,5776,"And what is it?"],[5776,5843,"Not enough money?"],[5960,6039,"Don't be shy, my man."],[6039,6143,"Name your price."],[6172,6272,"It's always about the money."]],"35":[[45,104,"You want more?"],[116,204,"Still not enough?"],[354,421,"Hey, stop!"],[458,604,"Leave my property immediately."],[604,642,"This is a"],[642,742,"stand-your-ground state"],[742,829,"and I swear to God"],[829,992,"I will fucking shoot you!"],[1013,1080,"Hey, good-looking,"],[1080,1226,"This handyman your boyfriend or what?"],[1226,1355,"You looking out for your sweetheart?"],[1488,1584,"Don't test me."],[1872,1939,"Not bad,"],[1997,2097,"decent reflexes."],[2118,2173,"But there's something"],[2173,2243,"you should know."],[2277,2394,"I've got five snipers"],[2394,2494,"stationed in the area."],[2523,2627,"You pull that trigger,"],[2644,2894,"you, your boyfriend, your little girl,"],[2894,3040,"everybody at this range is dead"],[3040,3153,"before you can even blink."],[3203,3265,"Jane,"],[3345,3432,"take it easy."],[3474,3616,"Come on, show me what you're made of."],[3682,3795,"You think you can protect them?"],[4154,4187,"Jane."],[4959,5050,"Alright, alright,"],[5050,5176,"enough with the joking."],[5196,5355,"You thought I brought snipers?"],[5367,5501,"I was bluffing, you idiot."],[5530,5622,"You said your gun would never"],[5622,5726,"shed blood again?"],[5860,5910,"Fine."],[5972,6093,"I guess you just have to watch"],[6093,6264,"while the people you love most suffer."]],"36":[[25,70,"Listen,"],[179,254,"I just work here,"],[254,362,"this has nothing to do with them."],[362,487,"You think I don't know that?"],[521,667,"I'm just showing you what happens"],[688,850,"when people get in my way."],[1805,1881,"Mommy!"],[1943,1997,"Damn it!"],[2052,2152,"Ah, fuck."],[2223,2277,"It's okay."],[2352,2435,"Mommy's okay."],[2469,2556,"Carl, just accept his offer."],[2556,2660,"You're gonna get us all killed."],[2690,2844,"Oh, just shut up!"],[2873,3019,"Carl, please, just say yes."],[3053,3123,"What's the point of your whole"],[3123,3265,"pacifist act if it's gonna end with us"],[3265,3403,"lying in a pool of our own blood?"],[3461,3570,"Good point, don't you think?"],[3616,3728,"I'll count it down for you."],[3745,3824,"Let's see how many shots"],[3824,3908,"it takes for you to crack."],[3908,3987,"That's enough!"],[4033,4216,"Looks like you finally got the message."],[4233,4270,"Except wait,"],[4270,4375,"aren't you just some guy"],[4375,4450,"who works here?"],[4483,4558,"Don't these people"],[4558,4646,"mean nothing to you?"],[4721,4788,"I'll start with the one"],[4788,4888,"who's already bleeding out."],[4892,4967,"And this time,"],[5005,5109,"I'm not aiming at her leg."],[5188,5313,"I said enough!"],[5359,5467,"Let them go."],[5530,5726,"I'll join your organization."]],"37":[[0,216,"Aw, how sweet."],[262,404,"Our noble hero can't bear"],[404,542,"to see his lover in pain."],[558,688,"It didn't hit any major arteries."],[688,809,"Let's get you bandaged up, okay?"],[838,921,"Hey, whoa, whoa, whoa."],[921,1026,"Not so fast."],[1076,1222,"Did I say you could join yet?"],[1272,1388,"What more do you want?"],[1426,1580,"You see, now it's your turn to beg me."],[1618,1797,"I might consider letting you in."],[1830,1939,"You had your chance to say yes"],[1939,2093,"when I was still asking nicely."],[2106,2168,"But now,"],[2168,2331,"I'm gonna make you get on your knees"],[2356,2573,"and beg me like a little bitch."],[2594,2648,"You do that"],[2648,2773,"and I might consider letting you in."],[2840,2973,"Look, you're way out of line."],[2990,3078,"Do you have any idea"],[3078,3144,"who you're threatening"],[3144,3199,"right now?"],[3240,3294,"What's that?"],[3357,3511,"Oh, please, tell me, by all means."],[3545,3707,"He's the best shot in the world."],[3728,3816,"He's the King of Guns!"],[3816,3908,"Do you think anybody else"],[3908,4008,"would be able to curve a bullet"],[4008,4124,"like you saw in that video?"]],"38":[[196,437,"Boss, this bitch seems serious."],[471,583,"Maybe we should check the intel."],[679,850,"Look at these ignorant clowns"],[871,930,"floating around"],[930,1071,"their silly conspiracy theories,"],[1071,1197,"not a fucking clue"],[1197,1330,"how the world really works."],[1372,1476,"Let me let you dummies in"],[1476,1576,"on a little secret."],[1605,1722,"The King of Guns"],[1730,1872,"dropped off the map a year ago"],[1872,1989,"because he was killed."],[2052,2089,"What?"],[2089,2147,"Yup."],[2206,2419,"Shot in the head, one year ago,"],[2444,2619,"during opetarion Maple Leaf."],[2752,2823,"Carl!"],[2961,3107,"Operation Maple Leaf?"],[3107,3282,"That sniper, it was one of them?"],[3282,3345,"I knew it."],[3361,3465,"There was no way Carl was actually"],[3465,3520,"the King of Guns,"],[3520,3641,"it was all some big lie."],[3653,3737,"Now we're all gonna die"],[3737,3799,"because this loser"],[3799,3878,"messed with the wrong guy."],[3878,4041,"Would you shut up?"],[4058,4233,"Now is not time for your whining."],[4245,4391,"Fuck, we're all gonna die."],[4425,4542,"Carl, think about us,"],[4583,4658,"about Rebecca."],[4692,4750,"You can't"],[4750,4896,"drag us down with you like this."]],"39":[[75,266,"Please, I'm begging you."],[316,392,"I'll join The One."],[392,492,"Just let them go."],[542,621,"What was that?"],[688,750,"I, I don't know,"],[750,888,"didn't really sound like you mean it."],[1251,1301,"Mom!"],[1317,1438,"Hey, hey, it's okay."],[1501,1634,"Everything's gonna be okay."],[1797,1847,"No!"],[2110,2156,"Come on,"],[2156,2310,"put some real feeling into it."],[2352,2439,"Say it louder!"],[2439,2585,"Don't hurt my daddy!"],[2598,2752,"He's the King of Guns!"],[2761,2831,"Listen, kid,"],[2831,2977,"whoever the fuck your daddy is,"],[2982,3094,"right now, he's nothing but the"],[3107,3228,"dirt beneath my shoes."],[3274,3357,"Better get to begging,"],[3382,3520,"or make sure that annoying little brat"],[3520,3628,"never speaks again."],[3657,3903,"Please, I'm begging you!"],[3933,4175,"Please let me join your organization!"],[4183,4379,"This is your King of Guns?"],[4404,4575,"This is the noble hero"],[4575,4738,"who swore to never shed blood?"],[4763,4896,"All I see in front of me"],[4896,5109,"is a spineless coward."]],"40":[[429,538,"Come on, round of applause"],[538,650,"for our newest recruit."],[809,1038,"You fucking bastard!"],[1393,1547,"Now it's time for your initiation."],[1868,1910,"Hey, you know,"],[1910,2039,"we spent a fortune on you."],[2060,2177,"What's wrong with a little trial run?"],[2177,2223,"I mean, I don't know"],[2223,2431,"if that video was real or AI bullshit."],[2448,2556,"What the hell do you want?"],[2577,2686,"Hey, don't be a baby."],[2744,2915,"This is the last test, I promise."],[2927,3073,"We'll be working together real soon."],[3207,3324,"Seeing is believing."],[3361,3495,"I wanna watch you curve the bullet"],[3495,3603,"with my own eyes."],[3653,3803,"One shot and you'll let them go?"],[3816,3845,"Yup!"],[3874,3966,"That's all it takes."],[4116,4179,"I wanna make things"],[4179,4279,"a little bit more exciting."],[4295,4487,"I wanna see you curve the bullet"],[4529,4625,"around your woman,"],[4658,4746,"and hit him."]],"41":[[104,179,"What the fuck?"],[179,266,"Why me?"],[442,496,"No!"],[496,646,"Get off of me!"],[654,763,"I could tell you hate his guts."],[763,980,"Just think of it as a sign-on bonus."],[984,1059,"Carl, don't do this."],[1184,1338,"Bro, have you lost your mind?"],[1359,1434,"A human life"],[1434,1576,"for your silly little game?"],[1597,1747,"I mean, aren't you the King of Guns?"],[1764,1885,"It should be easy to land a shot"],[1885,2006,"that won't even kill him."],[2039,2106,"Although I wouldn't mind"],[2106,2193,"seeing his head get blown off,"],[2193,2302,"I don't give a fuck."],[3645,3695,"Carl!"],[3858,3995,"Lewis!"],[4079,4216,"Lewis!"]],"42":[[504,588,"I can't."],[729,821,"I knew it."],[838,900,"I knew that video"],[900,1055,"was just some AI bullshit."],[1176,1226,"No!"],[1363,1447,"Well, what are you waiting for?"],[1447,1505,"Beat him up."],[1647,1701,"Daddy!"],[1722,1789,"Daddy!"],[2531,2581,"Oh."],[2690,2777,"Check this out."],[2902,2977,"Fancy revolver."],[3023,3098,"Oh."],[3269,3415,"Look at this fucking thing."],[3482,3595,"Jesus."],[3649,3712,"Boss."],[3899,3978,"What is this?"],[4291,4429,"What are you, a washed-up vet?"],[4462,4554,"Is that why you're too chicken shit"],[4554,4629,"to pull the trigger?"],[4629,4783,"You got PTSD or something?"],[4817,4846,"Stop!"],[4846,4942,"Give that back!"],[4950,5088,"That's my Daddy's!"],[5138,5305,"Oh, so it's important, huh?"],[5372,5405,"You know what?"],[5405,5534,"That gives me an idea."]],"43":[[608,654,"Hey."],[930,1009,"Rebecca!"],[1034,1142,"Baby, hey."],[1330,1501,"I'll fucking kill you!"],[1526,1589,"You bit me?"],[1626,1730,"You little bitch."],[1743,1851,"Baby, wake up."],[1956,2102,"Hey, you know, I like this gun."],[2160,2227,"It's not bad."],[2227,2323,"I think I'll be keeping it."],[2373,2427,"You know everybody"],[2427,2590,"who's tried to fool me is dead, right?"],[3061,3211,"I think I'll take it easy on you."],[3278,3395,"So you have time to regret"],[3395,3511,"your silly little oath."]],"44":[[696,804,"What did the doctor say?"],[934,1038,"She has a concussion"],[1080,1259,"and a broken rib from the hit."],[1305,1380,"God, how could somebody"],[1380,1493,"do this to a kid?"],[2102,2227,"Hey, baby."],[2268,2356,"Daddy?"],[2460,2686,"Mommy, is that you?"],[2698,2769,"Yeah, yeah."],[2769,2898,"Daddy and Mommy are here."],[2982,3057,"How are you feeling?"],[3123,3253,"Hurts."],[3274,3395,"Daddy hurts."],[3461,3641,"Mommy hurts, too."],[3720,3933,"I have to protect them."],[3991,4149,"We're okay, Rebecca."],[4237,4295,"Rebecca?"],[4400,4475,"It's just the painkillers"],[4475,4554,"kicking in."],[4637,4692,"She's okay."],[4692,4808,"Just let her get some rest."],[4821,4875,"Okay."]],"45":[[909,992,"Mr. Smith."],[1117,1176,"Welcome."],[1188,1297,"What brings you in today?"],[1351,1451,"I had heard you were"],[1451,1593,"scouting out a new recruit."],[2756,2932,"Picked up this sweet little piece today."],[2961,3082,"I wanna get it personalized,"],[3082,3224,"scrubbed clean of any old marks."],[3570,3674,"Uh."],[3778,3870,"This gun..."],[3974,4099,"Get rid of the numbers,"],[4120,4320,"insignia, new grip."],[4504,4587,"You know the drill."],[4746,4879,"Now you make sure my name"],[4879,5000,"is the only one that's left on there."],[5000,5071,"Got it?"],[5184,5330,"Yes, I understand."],[5330,5651,"It's just, this gun appears to be..."],[5730,5814,"unique."],[5880,5997,"For a special case like this,"],[5997,6135,"I'd have to talk to my boss,"],[6135,6231,"Mr. Valentine."],[6277,6468,"Well, get to it."],[6498,6602,"Don't waste my time."]],"46":[[25,100,"You heard me!"],[141,271,"Make sure Jane's gun range"],[271,358,"is renovated with top of"],[358,450,"the line equipment!"],[492,592,"Don't worry about cost."],[608,742,"I'll cover everything."],[1046,1126,"Mr. Valentine,"],[1197,1347,"Hank brought in an"],[1347,1505,"antique revolver just now."],[1530,1705,"And he wants to have it"],[1730,1864,"scrubbed clean and"],[1918,2022,"personalized."],[2268,2348,"This revolver?"],[2435,2540,"Did he say where he got this?"],[2540,2585,"No."],[2673,2865,"But, you know how Hank is."],[2877,2965,"Definitely mugged some"],[2965,3073,"poor sucker for it."],[3691,3757,"Carl Oliver."],[3770,3832,"Jesus."],[3874,4054,"This is, good God,"],[4195,4270,"this revolver"],[4354,4646,"belongs to the King of Guns!"]],"47":[[746,934,"There's some place that I need to be."],[950,1067,"Stay here with Rebecca."],[1601,1659,"You said your gun"],[1659,1785,"would never draw blood again."],[1939,2043,"Yeah, I tried to walk away"],[2043,2168,"from all that bloodshed."],[2193,2344,"They brought this on themselves."],[2715,2827,"My family's collection of guns"],[2827,2940,"is in the back of the range."],[2957,3032,"Take your pick."],[3148,3190,"No."],[3332,3449,"I've got my own collection."],[3566,3691,"Take care of Rebecca."],[3816,3874,"And you're sure these are"],[3874,3970,"the guys that did it?"],[4124,4170,"Yeah."],[4354,4437,"Make them pay for"],[4437,4583,"what they did to my dad."],[4671,4771,"I will."],[5009,5088,"Hey, wait."],[5601,5680,"Just promise me"],[5680,5839,"you'll make it out of this alive."],[7253,7332,"I promise."]],"48":[[250,362,"What took you so long?"],[392,542,"It's no good for business, old man."],[579,700,"Where did you get this gun?"],[721,809,"You're in no position"],[809,917,"to be asking me questions."],[917,975,"Now, get to work-"],[975,1242,"I said, where did you get this gun?"],[1451,1534,"Who gives a shit?"],[1576,1630,"Very well."],[1643,1789,"Get the fuck out of my shop!"],[1814,1972,"And take your shit with you!"],[1997,2052,"Now!"],[2131,2206,"Are you crazy?"],[2323,2410,"Don't forget, Matthew."],[2410,2565,"You made a fortune off of us."],[2727,2761,"What?"],[2961,3015,"Say that again."],[3228,3303,"I mean, for years,"],[3303,3470,"you've, you've, you've been working for us."],[3470,3645,"I don't work for you, kid."],[3682,3978,"I work with your father."],[4037,4245,"I'll ask you one last time."],[4308,4454,"Where did you get the gun?"]],"49":[[112,196,"Did you kill the owner?"],[221,304,"No."],[412,483,"I sure made his life"],[483,571,"a living hell, though."],[963,1013,"Wow."],[1092,1255,"You couldn't even finish the job?"],[1343,1451,"He's still alive?"],[1505,1572,"Good job."],[1614,1793,"You've sure gone and done it."],[1805,1843,"Yeah."],[2264,2352,"Of course you did."],[2694,2740,"Oh?"],[2827,2965,"You're pointing a gun at me now?"],[3019,3153,"In my gun shop?"],[3199,3524,"Just as reckless as your master."],[3607,3745,"If Mr. Sergei Smith"],[3762,3895,"saw what you did to his son,"],[3908,4037,"he'll come for you."],[4241,4517,"Then shoot now and finish it off,"],[4517,4700,"or get the fuck out of here!"]],"50":[[204,346,"You think you can scare me, huh?"],[417,550,"Because you work with my old man?"],[583,667,"You're dead!"],[750,813,"Call my father,"],[813,867,"tell him that Matthew"],[867,946,"turned on us."],[1055,1126,"While you're at it,"],[1163,1343,"give Mr. Smith a message from me."],[1438,1505,"Tell him I found"],[1505,1655,"who he's been looking for."],[1810,2006,"You take me for an idiot?"],[2081,2248,"I know where you got that gun."],[2281,2423,"You stole it from a run-down"],[2423,2644,"shooting range on the East Side."],[2690,2748,"Right?"],[2873,2952,"How'd you know?"],[3007,3294,"Ever hear the name, Carl Oliver?"],[3390,3495,"The King of Guns."],[3661,3737,"That's right."],[4233,4325,"Now look at the writing"],[4325,4454,"on the bottom of this grip."],[4821,4884,"No way."],[4971,5092,"That guy at the shooting range"],[5092,5209,"is the King of Guns?"],[6790,6906,"Daddy!"]],"51":[[41,125,"Are you kidding me?"],[162,283,"You think the King of Guns"],[283,358,"is working at some"],[358,525,"rinky-dink ass shooting range?"],[546,638,"You mean this loser?"],[859,959,"The video's a fake."],[975,1042,"It's AI!"],[1092,1151,"That's him."],[1197,1330,"He's the King of Guns."],[1397,1480,"Don't believe everything"],[1480,1630,"you see online, old man."],[1655,1780,"He's not the King of Guns."],[1793,1926,"I saw it with my own eyes."],[1960,2039,"He's doing chicken shit"],[2039,2122,"to pull the trigger."],[2173,2281,"I had him begging for his life"],[2281,2373,"under my foot."],[2373,2444,"Couldn't do shit."],[2456,2619,"Not even after I hit his little girl."],[2706,2752,"What?"],[2827,2965,"You hit Rebecca?"],[2973,3019,"Yeah."],[3048,3207,"She was crying for her daddy."],[3420,3566,"You've doomed us all."]],"52":[[29,216,"I even saw it with my own eyes."],[225,504,"That bullet really did curve around."],[504,617,"Shut up."],[650,754,"You know what I saw?"],[796,867,"I saw a coward"],[867,975,"watch his wife get shot,"],[1009,1117,"buddies about to die,"],[1201,1351,"still couldn't pull the trigger."],[1388,1476,"You really think a wimp like"],[1476,1584,"that's the King of Guns?"],[1639,1718,"Bullshit."],[1751,1835,"Relax."],[1872,2002,"When my dad gets here,"],[2002,2243,"we'll go back to the range, burn it down,"],[2243,2344,"and keep him groveling"],[2344,2519,"like the worthless trash that he is."],[2594,2644,"No."],[2715,2794,"That's not it."],[2827,2998,"This has nothing to do with fear."],[3115,3261,"He swore to himself,"],[3340,3516,"he would never shoot to kill again."],[3516,3641,"Oh, not this again."],[3641,3699,"Listen, the only thing"],[3699,3807,"you should be worried about"],[3816,3924,"is what you're gonna say to my dad"],[3924,3999,"when he gets here."],[4029,4162,"You idiots!"],[4183,4300,"You attacked a man"],[4300,4487,"who washed his hands clean."],[4554,4804,"You pushed him to take his gun"],[4804,4929,"and return!"]],"53":[[229,271,"Dad."],[325,421,"You're finally here."],[492,621,"Matthew turned on us."],[642,746,"He even hit me."],[834,909,"Leave us."],[1001,1167,"I need to have a word with Matthew."],[1238,1297,"Dad."],[1338,1493,"Get the fuck out."],[2102,2235,"I heard you have found"],[2235,2381,"the man I was looking for."],[2431,2590,"Yes, Mr. Smith."],[2660,2806,"But you struck my son."],[2882,3098,"Yes, I did."],[3148,3203,"Oh?"],[3365,3516,"Care to explain why?"],[3541,3611,"Your son"],[3661,3937,"stole a gun from the King of Guns."],[4129,4179,"And he-"],[4346,4408,"And?"],[4592,4817,"Beat his little girl."]],"54":[[37,237,"Are you sure it's the King of Guns?"],[283,417,"I'm sure of all people."],[513,625,"You would recognize him."],[1030,1188,"You fucking missed."],[1226,1359,"And you have the audacity"],[1359,1493,"to report back to me?"],[1551,1797,"Wait, you, you, you didn't say that"],[1797,1964,"the hit was on the King of Guns."],[1985,2110,"I watched him blow somebody's head off"],[2110,2268,"from 4,000 meters away."],[2323,2485,"But I did take out his spotter."],[2519,2573,"That's,"],[2619,2669,"that's gotta be worth"],[2669,2773,"a bit of the bounty, right?"],[3119,3174,"Yeah."],[3228,3274,"Okay."],[5347,5447,"Bring my son in."]],"55":[[754,867,"You were sent to scout"],[867,1063,"a new recruit today, correct?"],[1109,1305,"Yes, he just didn't measure up."],[1330,1476,"You're so fucked, Matthew."],[2102,2189,"Clean yourself."],[2273,2377,"You want me to step out?"],[2523,2619,"Dad, what'd I do?"],[2665,2840,"You failed your task today."],[2977,3144,"I followed protocol."],[3144,3232,"I offered him money."],[3232,3319,"He didn't measure up."],[3345,3524,"That is not the problem!"],[3566,3611,"What?"],[3611,3682,"I don't get it."],[3920,4070,"Because you didn't kill him,"],[4070,4137,"you idiot!"]],"56":[[946,1017,"What, all because I didn't"],[1017,1113,"kill that loser?"],[1155,1284,"That's what's got you so mad?"],[1372,1559,"It's not about what you did."],[1593,1768,"It's about who you did it to."],[1918,2027,"Isn't he just some nobody"],[2027,2164,"who works at a shooting range?"],[2306,2444,"You should be glad you're my son."],[2444,2535,"Or I would've killed you"],[2535,2660,"with my own hands."],[2686,2915,"But my anger is nothing compared to"],[2915,3057,"who we have provoked!"],[3157,3269,"What's the big deal?"],[3294,3407,"I thought he was just some nobody"],[3407,3532,"working at a shooting range."],[3891,3987,"That nobody"],[4049,4204,"is the King of Guns,"],[4258,4521,"Carl Oliver."]],"57":[[262,433,"A year ago, he disappeared."],[454,550,"The word on the street is"],[550,663,"that we took him out,"],[696,967,"and that rumor made The One"],[975,1184,"a legend among assassins."],[1209,1426,"But I'm the only one who knew the truth."],[1572,1747,"The King of Guns is still alive."],[2093,2268,"For a year now, I have enjoyed"],[2298,2423,"the glory and fame that"],[2423,2590,"that lie has brought."],[2652,2840,"But the truth kept me up at night,"],[2873,3028,"knowing that my worst nightmare"],[3028,3128,"was still out there."],[3261,3332,"And now,"],[3374,3461,"my son,"],[3524,3611,"you have called"],[3611,3774,"my worst nightmare to me."]],"58":[[25,75,"Dad,"],[141,266,"I'll clean up my own mess."],[304,350,"Oh?"],[417,604,"And how do you plan to do that?"],[654,859,"I'll take my men and I'll kill him now."],[859,988,"Are you fucking..."],[1021,1126,"You weren't listening"],[1126,1351,"to a single word I said, were you?"],[1589,1701,"It's too late."],[1776,1893,"He's the King of Guns,"],[1893,2035,"and he's coming for you."],[2202,2389,"And you will do nothing,"],[2410,2635,"because there's nothing you can do."],[3073,3203,"He's really the King of Guns?"],[3224,3336,"And I humiliated him?"],[3420,3478,"Fuck!"],[4571,4667,"This is Matthew Valentine."],[4742,4821,"Is it with you?"],[5071,5167,"Yes, it is."],[5213,5305,"See you in five."],[5342,5426,"Mr. Oliver."],[5797,5864,"Mr. Oliver."]],"59":[[246,325,"What did he say?"],[404,496,"He's on his way."],[604,667,"Fuck."],[721,779,"I gotta get out of here."],[779,825,"I gotta hide."],[825,892,"Don't move."],[984,1113,"You stay right where you are,"],[1113,1251,"you fucking idiot."],[1514,1597,"Give me your phone."],[2369,2502,"Hello, Mr. Oliver."],[2560,2686,"I am the leader of The One,"],[2686,2861,"and I heard about the incident"],[2861,3019,"at the shooting range, and"],[3019,3107,"would like to extend"],[3107,3269,"my sincerest apologies."]],"60":[[70,183,"I understand my son"],[183,304,"has offended you and"],[304,421,"if it will resolve the matter,"],[421,600,"I will have his legs cut off"],[600,842,"and I will deliver them to you"],[859,909,"along with"],[909,1126,"fifty million in compensation."],[1334,1497,"We, we, we can settle this"],[1497,1647,"like civilized men."],[1685,1847,"Don't let hate drag you back"],[1847,2018,"into the life you left behind."],[2052,2177,"You swore your gun"],[2177,2360,"would never draw blood again."],[2857,2915,"What did he say?"],[2990,3028,"Huh?"],[3090,3165,"Everything alright?"],[3228,3361,"He wants you dead."],[3595,3799,"Have your men guard you"],[3828,3899,"around the clock."],[4141,4191,"Of course."],[4354,4471,"All my men are A-class shooters."],[4471,4587,"This, this, this won't be easy."],[6460,6539,"You called me a"],[6539,6677,"nobody handyman."],[6923,7065,"But here I am."],[7136,7315,"The King of Guns."]],"61":[[1447,1547,"Mr. Oliver."],[1605,1689,"Please."],[1730,1864,"It's all a misunderstanding,"],[1864,2047,"we, we can talk this out."],[2615,2698,"On your right!"],[3611,3703,"What the fuck?"],[3703,3812,"He shot the bullet."]],"62":[[1789,1926,"The bullet curved."],[1947,2139,"You really are the King of Guns."],[2185,2298,"You said it yourself,"],[2377,2502,"seeing is believing."],[4208,4275,"Mr. Oliver,"],[4337,4450,"you got what you wanted."],[4500,4571,"Let me go."],[4662,4758,"Thanks to your son,"],[4796,4917,"I finally found the man"],[4917,5038,"who killed my friend."],[5109,5238,"This is for Lewis."]],"63":[[959,996,"Jane,"],[1030,1159,"your shooting range"],[1159,1347,"has passed all inspections,"],[1347,1509,"and is ready for business."],[1626,1689,"Thank you."],[1755,1906,"This is so amazing."],[1968,2114,"Hey, and just in time for the National"],[2114,2218,"Sharpshooter Competition."],[2306,2423,"And it's all"],[2423,2619,"brand new equipment and guns."],[2677,2781,"I even extended your range"],[2781,2894,"a few hundred yards."],[3140,3294,"I wish Carl were here."],[3324,3386,"I know."],[3528,3645,"Still no news from Carl?"],[3824,3987,"After he got his revenge,"],[4008,4108,"he disappeared again."],[4162,4337,"I've had my men looking for him, but..."],[4667,4859,"His reappearance"],[4879,5075,"shook up the world of assassins"],[5088,5176,"and the military."],[5221,5338,"As for The One,"],[5372,5572,"the FBI has wiped them out."],[5618,5701,"You don't have to worry about them"],[5701,5780,"coming after you."],[5851,5955,"All thanks to Carl."],[6001,6143,"He'll be back, right?"],[6514,6585,"Hey."],[6886,7019,"Heard you got an opening."]]}