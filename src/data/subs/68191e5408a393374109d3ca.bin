{"1":[[855,896,"Josh,"],[980,1055,"what's going on?"],[1055,1146,"What is this mess?"],[1146,1359,"You are a little early, but..."],[1384,1659,"I am glad you're here, because..."],[1659,1764,"Well, Miss Layla Gray,"],[1764,1847,"I was wondering-"],[1847,2035,"It doesn't matter anyways."],[2060,2360,"There's not gonna be an opening."],[2723,2790,"Here."],[2848,2969,"That's all the money that you've"],[2969,3148,"invested in the restaurant."],[3265,3361,"Josh, I don't wanna to open"],[3361,3482,"this restaurant with you."],[3524,3599,"What?"],[3645,3862,"I want us to break up."],[3862,4062,"I’ve sold the restaurant already."],[4133,4266,"You're joking, right?"],[4266,4458,"No offense babe, but this is really"],[4458,4567,"not that funny."],[4571,4658,"I mean"],[4658,4825,"I love you, and you love me-"],[4825,4979,"You’re the Master Chef champion."],[4979,5280,"You're the future of culinary arts."],[5305,5526,"I don't want to be the chef's"],[5526,5684,"supportive assistant."],[5684,5768,"Okay, well, don't be"],[5768,5868,"the supportive assistant."],[5922,6110,"Let's make you the head chef."],[6151,6235,"Okay?"],[6235,6393,"And I can be your assistant, I-"],[6452,6614,"Are you ready, babe?"],[6869,7011,"Who's this?"],[7011,7157,"This is Benny."],[7203,7353,"He's super supportive"],[7353,7461,"of my dreams,"],[7461,7603,"and that's what I need right now."],[7603,7732,"Why are you doing this to us?"],[7803,7978,"I won't be coming back."],[8070,8153,"Wait, Layla."],[8354,8516,"I just, I don't think you actually love"],[8516,8579,"this guy."],[8579,8671,"I don’t buy it."],[8671,8712,"In fact,"],[8712,8892,"I would bet everything"],[8892,9000,"that you still love me."],[9167,9401,"That is a bet you would lose."],[9530,9693,"Let's sign a contract then."],[9693,9901,"That in five years time,"],[9901,10155,"if you and I are both single,"],[10293,10427,"we get married."],[10427,10543,"What do you say?"],[10639,10752,"I, Layla Gray,"],[10752,10885,"am breaking up"],[10885,11002,"with Joshua Reed."],[11015,11353,"If in five years we are both single,"],[11378,11599,"we will marry each other."],[12053,12157,"Wait, Layla!"],[13584,13726,"I’m sorry Josh."],[13759,13884,"I’m doing this for you."]],"2":[[112,221,"We discovered a malignant"],[221,329,"tumor in your brain."],[329,467,"We need to get you into chemotherapy"],[467,558,"as soon as possible."],[592,692,"There's a program in Los Angeles"],[692,825,"that's been showing some promise."],[867,1034,"If the treatment is successful,"],[1105,1255,"will I be cancer free?"],[1422,1543,"There's no guarantee."],[1564,1697,"I'm sorry, Miss Gray."],[2193,2289,"Mrs. Reed? I-"],[2289,2419,"What have you been doing?"],[2456,2623,"I've been knocking for ten minutes."],[2623,2781,"Sorry, Josh isn't home."],[2936,3069,"How long do you intend"],[3069,3203,"on holding my son back?"],[3207,3294,"He just won the"],[3294,3461,"Master Chef Championship."],[3461,3586,"And his next gig is"],[3586,3695,"supposed to be working at"],[3695,3832,"Gordon Ramsay's restaurant"],[3832,4008,"in Paris as the head chef."],[4008,4145,"But all he can talk about"],[4145,4250,"is coming back here,"],[4250,4346,"to open some"],[4346,4529,"rundown spot with you."],[4587,4738,"You just want to use his success"],[4738,4884,"to attract customers."],[4884,5046,"It's not like that."],[5046,5205,"It's our shared dream"],[5205,5426,"to reopen my mom's restaurant."],[5426,5563,"His dream has always been"],[5563,5701,"to move to Paris."],[5772,5893,"And be the head chef"],[5893,6060,"in its best restaurant."],[6089,6247,"But now, he's stuck here"],[6247,6343,"because of you."],[6410,6644,"He's never shown me any of this."],[6644,6785,"Did you also not know that he"],[6785,7002,"has put his life's savings and prizes"],[7002,7203,"into opening a restaurant for you?"],[7907,8041,"You have cancer?"],[8112,8254,"Does Joshua know?"],[8312,8416,"I haven't had a chance-"],[8416,8512,"You may be dying,"],[8512,8633,"and my son doesn't know?"],[8967,9113,"You're just trying to trick him"],[9113,9263,"into marriage so that"],[9263,9355,"he'll pay for your treatments."],[9355,9401,"No."],[9401,9617,"You insatiable gold digger."],[9617,9847,"You better break up with my son now,"],[9847,10072,"or you will not like what happens next."],[10510,10727,"I can't keep dragging you down,"],[10727,10781,"Josh."],[11186,11302,"Mark my words, Layla."],[11511,11674,"I’m gonna win that bet."]],"3":[[1071,1159,"I need these chopped"],[1159,1276,"in ten minutes."],[1313,1393,"Great!"],[1413,1593,"Just what I needed."],[1659,1780,"Oh, I'm jealous of everyone"],[1780,1860,"in that room."],[1860,2089,"He is my icon, Joshua Reed,"],[2089,2360,"live streaming with Julia Swift."],[2394,2531,"The hottest chef in the world,"],[2531,2665,"and the hottest singer?"],[2736,2877,"This year you made the"],[2877,3115,"Forbes 30 Under 30 List"],[3115,3415,"and were voted Most Famous Chef"],[3415,3557,"in the World."],[3611,3753,"How does that feel?"],[3753,3962,"Well, I can tell you, it definitely was the"],[3962,4049,"perfect time to open up a"],[4049,4120,"restaurant."],[4200,4421,"And your accolades don't stop there."],[4421,4692,"Your brand just earned its 20th"],[4692,4842,"Michelin Star."],[4867,4934,"Thank you."],[4984,5050,"Tell me."],[5100,5230,"What’s your secret?"],[5451,5563,"You know what?"],[5580,5743,"You want the whole truth?"],[5889,6156,"I actually started all this"],[6156,6318,"because of, some silly"],[6318,6481,"bet that I had with an ex."],[6510,6602,"Believe it or not."],[6806,6923,"Thank you, Chef Reed,"],[6923,7094,"for sharing your talents with us."],[7219,7369,"Happy cooking!"],[7678,7774,"And cut!"],[7836,7912,"Thank you."],[7995,8095,"Of course."],[8220,8479,"So, is this ex of yours the"],[8479,8654,"reason you keep turning me down?"],[8654,8796,"Oh, Julia,"],[8896,9034,"you're a star."],[9034,9121,"Okay, you can do so much"],[9121,9213,"better than me."],[9342,9496,"It's just it's like the third or fourth time"],[9496,9601,"you've said that to me."],[9676,9730,"Miss Swift,"],[9730,9889,"it’s time to go to makeup now."],[9889,9964,"See ya."],[10130,10335,"Sir, Crazy Maple restaurant manager"],[10335,10502,"was very excited to hear about your"],[10502,10618,"plans to purchase the restaurant"],[10618,10735,"and become the new head chef."],[10735,10789,"Good."],[10789,10948,"But, are you sure about this, sir?"],[10981,11106,"They lost the star recently."],[11106,11269,"And the previous head chef just quit."],[11298,11423,"If this is about purchasing,"],[11423,11536,"there are plenty of better options out-"],[11536,11636,"No, Ted."],[11636,11828,"It's not about purchasing, okay?"],[11828,11907,"It's our only option."],[12003,12082,"You know best, sir."],[12124,12220,"Thank you."],[12220,12391,"It's been five years,"],[12391,12491,"Layla Gray."]],"4":[[104,279,"Actually started all of this because,"],[279,392,"of some silly bet"],[392,538,"that I had with an ex."],[638,771,"Sorry."],[771,1001,"Josh's interview went viral today."],[1063,1297,"I can't stop thinking about that contract"],[1297,1401,"you two signed."],[1426,1647,"Hey, it's been, what, five years now?"],[1647,1760,"Maybe he'll show up"],[1760,1847,"and wanna get married."],[1847,1997,"Don't be delusional, Benny."],[1997,2189,"He wasn't actually serious."],[2189,2448,"Besides, now he is a"],[2448,2610,"world-famous chef."],[2610,2727,"And I"],[2777,3003,"am chopping garlic in a kitchen."],[3111,3224,"These last five years have"],[3224,3345,"been really rough on you."],[3390,3591,"Balancing cancer treatment with work"],[3591,3666,"and whatnot."],[3720,3966,"Plus, if you hadn't made that sacrifice,"],[3966,4124,"Josh might not even be"],[4124,4200,"who he is today."],[4325,4379,"No."],[4379,4542,"Everything that Josh has achieved,"],[4542,4679,"he has done so himself."],[4717,4942,"I just hope that my cancer doesn't"],[4942,5088,"come back and"],[5171,5347,"I can finally achieve my dream"],[5347,5622,"of being a Michelin star chef."],[5684,5797,"Hey,"],[5822,5922,"your results are going to come back"],[5922,6151,"normal, I'm sure of it."],[6181,6306,"I love you, Laylay."],[6352,6464,"And I love you, too."],[6635,6694,"Oh my God, oh my God."],[6694,6798,"Oh my God."],[6902,6998,"He's here today."],[6998,7073,"He's here?"],[7094,7278,"Oh my God, he’s here. Oh my God."],[7353,7453,"Oh my God. -Whoa!"],[7657,7770,"We don’t need garlic today."],[7770,7895,"Chop these onions up ASAP."],[7895,8028,"Blake, Chef Lee said"],[8028,8220,"that I'd be promoted to line cook."],[8241,8387,"Chef Lee quit, and"],[8387,8571,"there’s no shortage of line cooks."],[8571,8616,"And we need you"],[8616,8717,"as the kitchen assistant."],[8717,8979,"So do as you're asked, or get out."],[9017,9117,"Yeah, chop, chop."],[9300,9421,"Oh, and while you're at it,"],[9421,9488,"clean the kitchen."],[9488,9642,"The new head chef is here today, and"],[9642,9797,"we need it looking spick and span."],[9905,10130,"The new head chef?"]],"5":[[37,241,"Welcome to Crazy Maple, Chef Reed."],[275,342,"It's a pleasure."],[342,517,"Thank you, Mr. Anderson."],[538,784,"So are these all of our chefs?"],[784,955,"Well, sir, we do have a kitchen"],[955,1209,"assistant, but she can barely cook."],[1255,1326,"We can fix that."],[1593,1789,"Geez, onions usually don’t"],[1789,1972,"make me cry this much."],[2369,2448,"Oh."],[2448,2773,"And this is our dining room area."],[2773,2907,"Ah, stupid."],[3103,3353,"Oh, shoot!"],[3353,3449,"Great."],[3449,3553,"Can I see the kitchen?"],[3586,3678,"Right this way."],[4579,4713,"Miss Gray,"],[4713,4833,"what the hell are you doing?"],[4904,4913,"What?"],[4913,5117,"Oh, I'm so sorry. I don't-"]],"6":[[70,141,"Josh?"],[162,279,"That can't be you."],[321,437,"Am I dreaming?"],[579,684,"Sorry about that, Chef Reed."],[684,800,"This is our kitchen assistant."],[800,909,"She handles the basics"],[909,1005,"like washing and peeling."],[1046,1167,"Joshua Reed."],[1209,1317,"Miss Gray,"],[1317,1418,"I assume?"],[1555,1655,"Yes."],[1710,1818,"Nice to meet you, Josh-"],[1885,1964,"Chef Reed."],[1964,2077,"I need you to keep your stinking onion"],[2077,2189,"hands off of Chef Reed."],[2823,2998,"Miss Gray, is this your station?"],[3048,3303,"Uh, yes, Chef."],[3370,3478,"Sorry, Chef Reed."],[3507,3616,"The kitchen is usually"],[3616,3703,"much cleaner."],[4358,4542,"These onions are cut perfectly."],[4608,4688,"Hey, Alex?"],[4746,4838,"I'm gonna need a sous chef."],[4838,4975,"And I think that Miss Gray"],[4988,5125,"would be a great choice."],[5242,5351,"Wait, no, no, no, she's"],[5351,5492,"just a kitchen assistant."],[5492,5555,"She's not like,"],[5555,5705,"she’s not qualified as a sous chef."],[5705,5834,"I’ve been here for three years..."],[5876,6006,"Please explain to Chef Reed that this-"],[6026,6131,"Hey, chefs,"],[6131,6222,"if you look,"],[6222,6456,"Miss Gray's station is perfectly clean."],[6456,6619,"Her garlic is in the right spot."],[6619,6760,"Onions perfectly chopped."],[6835,6977,"You've clearly got some restaurant"],[6977,7086,"experience, don't you?"],[7290,7599,"Yes, my family had a restaurant."],[7691,7853,"I was a chef there."],[7920,8128,"And what happened to your restaurant?"],[8128,8208,"That was your dream,"],[8208,8308,"I’m presuming?"],[8324,8420,"Josh, I don't wanna open"],[8420,8541,"this restaurant with you."],[8583,8658,"What?"],[8779,8950,"I won't be coming back."]],"7":[[37,246,"And what happened to your restaurant?"],[246,333,"That was your dream,"],[333,433,"I'm presuming?"],[492,688,"It was shut down due to Covid,"],[763,863,"And,"],[863,1038,"it wasn't because of any deadline"],[1038,1113,"or anything else"],[1113,1234,"that you had going on?"],[1730,1889,"Chef Reed, if you're looking for a sous"],[1889,2047,"chef, I can provide assistance."],[2064,2185,"Alex, I think Miss Gray would make"],[2185,2327,"a great candidate for sous chef."],[2327,2460,"I think we should give her a shot."],[2494,2556,"Wait-"],[2556,2644,"Alright, then!"],[2644,2731,"Layla."],[2781,2944,"Try not to mess up this opportunity."],[3094,3203,"Could you show me your inventory?"],[3253,3353,"I thought you never ask."],[3353,3420,"We just got this"],[3420,3553,"Wagyu steak burger."],[3841,4091,"The sous chef was supposed to be me."],[4162,4279,"You're going down, Layla."]],"8":[[200,275,"Josh?"],[354,500,"What are you still doing here?"],[563,767,"It's good to see you too, Miss Gray."],[909,1005,"Although, uh..."],[1192,1305,"I would have hoped for a spot"],[1305,1418,"that was more fitting."],[1430,1659,"Can we stop with the small talk?"],[1659,1793,"I mean, how is it that you're"],[1793,1910,"randomly at the restaurant"],[1910,1981,"I work at?"],[1981,2135,"Oh, well, I'm new head chef."],[2327,2515,"You’re the most sought after chef"],[2515,2640,"in the country right now."],[2640,2740,"How are you at just this"],[2740,2848,"hole in the wall?"],[2848,2961,"And then you promote me to be"],[2961,3103,"your sous chef?"],[3119,3257,"Are you trying to take your revenge"],[3257,3319,"out on me?"],[3340,3436,"Are you going to make my life"],[3436,3499,"a living hell?"],[3499,3682,"Are you going to try to push me to quit?"],[3682,3803,"No, no, no, listen..."],[3803,3920,"Okay."],[4170,4241,"Look, I hate to be the one"],[4241,4312,"to burst your bubble,"],[4312,4491,"but the universe does not rotate"],[4491,4579,"around you."],[4612,4875,"Okay, I did not come here for just you."],[4996,5055,"Why?"],[5092,5192,"Are you worried?"],[5192,5326,"Are you scared of us falling"],[5326,5430,"in love again or something?"],[5430,5609,"Falling in love?"],[5647,5809,"I don't know, you just said that-"],[5809,5989,"Um, okay, that,"],[5989,6114,"that is kind of an asshole"],[6114,6193,"thing to say."],[6193,6352,"Ah, the truth comes out."],[6502,6635,"You have always thought"],[6635,6769,"that I was a conceited asshole."],[6823,6990,"No, that's not what I meant."],[7165,7203,"Wait."],[8591,8662,"Josh!"]],"9":[[513,583,"Josh!"],[692,834,"Oh my God, are you okay?"],[963,1134,"No, I'm fine. It's just my shoulder."],[1134,1238,"Let me look, come here."],[1238,1363,"Okay."],[1393,1509,"Can you rotate it?"],[1509,1547,"Yeah."],[1647,1714,"Does it hurt?"],[1714,1801,"And then this way."],[1801,1943,"Ooof, no, it’s okay."],[1964,2093,"Where does it hurt?"],[2750,2944,"Layla,"],[3000,3123,"if you think that I'm such an asshole"],[3123,3211,"then why are you concerned"],[3211,3353,"about me?"],[3499,3624,"Stop talking."],[3624,3774,"I need to see if you have a bruise."],[3774,3899,"Five years ago,"],[3974,4158,"you and I made a bet."],[4179,4312,"In our restaurant."],[4312,4446,"In front of a picture of your mom."],[4738,4954,"And the bet was that in five years"],[4954,5171,"time, if we were still single,"],[5242,5384,"we would get married."],[5730,6085,"And I do not see a ring on this finger."]],"10":[[0,208,"I can't get involved with him right now."],[208,362,"I don't even know the results"],[362,554,"of the cancer screening yet."],[554,709,"Josh..."],[855,996,"I'm engaged."],[1101,1226,"I'm sorry."],[1226,1401,"You're engaged?"],[1476,1730,"Wow. Okay."],[2043,2156,"Great."],[2156,2302,"Who's the fiancé?"],[2385,2602,"That's none of your concern."],[2602,2727,"And the ring didn't fit,"],[2727,2882,"so he's going to get it resized."],[2898,3007,"Is that Layla?"],[3044,3190,"Is that why you came here?"],[3190,3353,"She’s probably on the phone in there..."],[3353,3461,"Because of some contract"],[3461,3574,"from five years ago?"],[3574,3766,"How about you freeze to death."],[3766,3933,"I was just messing with you, okay?"],[3933,4108,"I was kidding, I was kidding..."],[4183,4308,"But you should have seen your face."],[4375,4425,"Priceless."],[4475,4633,"See, asshole."],[4633,4792,"You're just playing games with me."],[4792,4963,"Can you please just be straight with me?"],[4963,5046,"Because this whole time"],[5046,5142,"I thought that you-"],[5142,5205,"Wait, wait, wait. -I thought-"],[5205,5226,"You thought?"],[5226,5313,"What did you think?"],[5313,5455,"That I did all of this?"],[5472,5538,"That I..."],[5538,5668,"thought of you day and night"],[5668,5818,"for the last five years."],[5818,5960,"And I came here to work at this"],[5960,6097,"restaurant to find you"],[6097,6239,"so I could marry you?"],[6381,6452,"Are you pretending to be"],[6452,6560,"engaged just to mess with me?"],[6585,6748,"No, I,"],[6748,6956,"I'm, I told you the truth."],[7002,7265,"And, actually, you know what?"],[7265,7394,"I'm gonna get going."],[7449,7561,"So, she's really in love"],[7561,7674,"with someone else."],[7878,7974,"What's wrong?"],[7974,8254,"The door's stuck. Hello?"],[8254,8458,"Hello? Is anyone out there?"],[8458,8512,"Wait!"],[8512,8671,"Has this happened to you before?"],[8671,8767,"Never!"],[8800,9000,"Help! Is anyone there?"],[9000,9184,"Open the door!"],[9284,9355,"Fuck!"],[9459,9555,"I don't have my phone."],[9555,9667,"Do you have yours?"],[9667,9768,"Yeah, hold on."],[9793,9876,"Okay."],[9959,10114,"It's dead."],[10114,10193,"Fuck."]],"11":[[0,91,"Fuck."],[91,229,"Yeah."],[513,592,"Is it..."],[658,821,"Does it feel like it’s getting colder?"],[834,950,"Oh, no. Josh what are you doing?"],[950,1034,"Here, look, you’re cold."],[1034,1092,"Stop, okay?"],[1092,1276,"Oh, no, Josh, please you, I-"],[1276,1438,"Just let me."],[1472,1589,"You’re freezing."],[1589,1722,"I'm used to it."],[2327,2519,"No, Jesus, Josh,"],[2519,2623,"what are you doing?"],[2623,2740,"Look, you’re shivering."],[2740,2927,"You’re gonna be cold too! I don’t--"],[4625,4708,"Here, just put your hands in here."],[4708,4800,"You're shivering."],[4800,4942,"Come on."],[4942,5134,"Is that better?"],[6010,6218,"God he’s even more fit than he"],[6218,6402,"used to be."],[8412,8629,"Did you miss these hugs."],[8700,8867,"Shh!"],[8867,9134,"But he’s also turned into a cocky jerk."],[9134,9275,"Didn’t expect it to happen again"],[9275,9421,"in this environment."],[9446,9613,"Shirtless in a fridge."],[9847,10014,"Have you guys seen Chef Reed?"],[10014,10201,"Nope."],[10694,10856,"Thank you."],[10856,11144,"You know, I actually feel a little better."],[11144,11261,"Let’s keep figuring out how to get"],[11261,11336,"out of here."],[11336,11444,"Chef Reed?"],[11490,11590,"Somebodies out there."]],"12":[[12,83,"Oh, hey!"],[83,171,"Shh!"],[371,500,"That's strange."],[500,642,"Just wait because..."],[642,813,"Guys, we’re on the inside."],[813,859,"Shh!"],[859,1001,"That sounds like Chef Reed’s voice."],[1001,1209,"If they come in here and see us like this."],[1209,1368,"Ah, here, put this back on."],[1368,1434,"Quick!"],[1434,1572,"Did one of you do this?"],[1572,1634,"As quick as you can."],[1830,1943,"It's stuck."],[1960,2014,"We’re coming."],[2014,2156,"I can't get dressed that fast."],[2156,2344,"Help me get it open!"],[2519,2660,"Oh my God, get dressed."],[2686,2727,"Shut- - Hold on."],[2727,2802,"Use this."],[3094,3144,"No!"],[3144,3395,"Jesus Christ, what the hell is going on?"],[4241,4354,"I think she has hypothermia."],[4354,4500,"Here. Help me."],[4500,4621,"Call an ambulance."]],"13":[[229,458,"Looks like you're just fine after all."],[1380,1484,"They’re gone now,"],[1484,1609,"you can stop pretending."],[1947,2068,"Are you sure you're okay, though?"],[2068,2356,"Yeah. Yeah. No, I just, um..."],[2356,2515,"I didn't want everybody walking"],[2515,2731,"in on us huddled in the corner like that"],[2731,2948,"because, that's how rumors start."],[2948,3103,"But I'm glad you"],[3157,3257,"remember."],[3549,3737,"You spent a fortune on this place"],[3737,3862,"and didn’t even think to tell me?"],[4112,4383,"Layla, I know your parents aren’t"],[4383,4512,"around but"],[4512,4667,"I would have thought that you would-"],[4667,4813,"Josh! - Oh, sorry."],[4813,5055,"Hey, hold on, hold on."],[5201,5330,"Let me just sit down for a second"],[5330,5422,"What happened?"],[5422,5538,"I, um."],[5805,6076,"Sorry Mom, I just, I haven’t slept..."],[6076,6160,"I’ve been pulling all-nighters working"],[6160,6377,"on all the things that you hate."],[6377,6531,"So I just need to get some sleep, I think."],[6569,6644,"Okay. - But"],[6644,6760,"thanks so much for coming, Mom."],[6911,7290,"Sure, well, congrats, I guess?"],[7298,7436,"Oh, thank you so much!"],[7711,7849,"Go and be safe!"],[8099,8237,"Faker!"],[8304,8596,"I should be an actor."],[8696,8929,"I guess some things are just, hard"],[8929,9063,"to forget."],[9063,9104,"Yeah."],[9321,9434,"Yeah. But you have to forget"],[9434,9534,"about them."],[9559,9667,"There’s no guarantee."],[9667,9955,"Even if the chemo is successful,"],[9955,10089,"there’s a chance that it could return"],[10089,10164,"in a few years."],[10556,10806,"Um, you know, it is late, so you should"],[10806,10915,"probably get going."],[11102,11298,"All right can we just be honest here?"],[11448,11536,"You still have feelings for me,"],[11536,11582,"don’t you?"],[11582,11703,"Look, look,"],[11703,11982,"I’m sorry but I can tell."]],"14":[[145,375,"Uh, my fiance is on his way here,"],[375,617,"so you should probably leave"],[617,713,"before he gets here."],[713,800,"I mean, I've got to meet him at some"],[800,905,"point, don't I?"],[905,1046,"Okay, If you're not gonna leave,"],[1046,1096,"I will."],[1096,1301,"Okay. Rock star."],[1438,1605,"We both know that's not going to happen"],[1685,1814,"Have a good night."],[2243,2352,"We should probably talk about"],[2352,2506,"the fact that I am technically"],[2506,2648,"your boss at the restaurant."],[2648,2752,"Which means you and I are going to"],[2752,2907,"be seeing a whole lot of each other."],[3086,3240,"Just something I thought that you"],[3240,3386,"and your fiance should"],[3465,3603,"talk about."],[3699,3774,"Have a good night."],[4091,4250,"Joshua, what am I gonna do"],[4250,4341,"with you?"],[5301,5413,"I'm sorry."],[5568,5705,"Is that her fiancé?"],[5789,5930,"Layla you scared me half to death!"],[5930,6039,"I thought it was the cancer."],[6039,6110,"Shhh!"],[6260,6393,"I pretended to faint so that"],[6393,6485,"people wouldn't gossip."],[6485,6581,"And then Josh brought me to"],[6581,6656,"the hospital,"],[6656,6844,"and he asked me to confess that I"],[6844,6944,"still have feelings for him."],[6944,7044,"What did you say? -Shh."],[7949,8003,"Hello?"],[8003,8058,"Boss,"],[8058,8149,"The security cameras"],[8149,8304,"in the kitchen are broken, so"],[8324,8395,"we don’t know who locked the"],[8395,8466,"cold room."],[8466,8616,"It was. We were just- we were"],[8616,8700,"stuck in the cooler. Okay."],[8700,8837,"He was just trying to keep me"],[8837,8967,"from getting hypothermia."],[8967,9150,"Oh, sure. Whatever you say."],[9192,9363,"Okay, just see if you can"],[9363,9455,"get that camera fixed."],[9455,9588,"And, Ted, listen,"],[9768,9851,"I need you to do another"],[9851,10064,"deep dive on Layla Gray."],[10130,10218,"Yeah."],[10218,10360,"Listen, I need to find out"],[10360,10527,"if she's actually engaged or not."],[10593,10727,"Why did you tell him"],[10727,10835,"that you're engaged?"],[10835,10906,"Layla,"],[10906,11102,"It sounds to me like he has not forgotten"],[11102,11236,"about that contract you two signed."]],"15":[[37,108,"Layla?"],[108,266,"It sounds to me like he has not"],[266,392,"forgotten about that contract"],[392,450,"you two signed."],[554,804,"That was five years ago, Benny."],[804,938,"I mean, he's a completely"],[938,1059,"different person now."],[1059,1192,"It doesn't make sense that he would"],[1192,1359,"still care about the contract. He was,"],[1418,1514,"he was just messing with me."],[1514,1655,"But what if he wasn't?"],[1655,1918,"What if he's serious? Layla."],[1918,2089,"I really think he still likes you."],[2089,2364,"No, no, there's no chance."],[2364,2439,"Okay."],[2569,2681,"Benny, you know how I left"],[2681,2794,"things with him."],[2794,2944,"And now I told him that I'm engaged."],[2944,3107,"So, if anything, he..."],[3107,3303,"He probably hates me."],[3303,3503,"Just take the sous chef position."],[3503,3582,"Okay?"],[3582,3753,"Then you can slowly get to know"],[3753,3891,"this new version of Joshua"],[3924,4179,"and it'll help your career."],[4179,4308,"Yeah. You're right."],[4308,4483,"This is the best thing to possibly"],[4483,4550,"come out of this."],[4667,4783,"Hallelujah."],[4909,5046,"I am never,"],[5046,5226,"ever gonna chop onions"],[5226,5347,"for a living again."],[5447,5538,"All right, Chef."],[5538,5643,"I need these onions chopped"],[5643,5734,"by 12:00 sharp."],[5734,5876,"Make them nice and thin."],[5968,6172,"Why is this still my job, Chef?"],[6172,6289,"Because you're the only chef who"],[6289,6473,"can chop onions up to my standard."],[6606,6748,"Don’t question my orders."],[6810,6919,"Yes, Chef."]],"16":[[804,1026,"Chef, you call these pancakes?"],[1026,1326,"I need them thicker and fluffier."],[1363,1526,"I expected more from you."],[1576,1872,"Start over."],[2911,2982,"What's this mess, Chef?"],[2982,3178,"Counter should be clean at all times."],[3445,3674,"Yes, Chef."],[3895,4066,"Did you throw up on this?"],[4066,4233,"Roll your sleeves up."],[4533,4746,"My sleeves are dirty because you give"],[4746,4888,"me all the dirty jobs."],[4917,5025,"Do not turn your back on me."],[5025,5142,"That is no attitude"],[5142,5263,"to have as a sous chef!"],[5263,5442,"Okay, cut the bullshit, Josh!"]],"17":[[20,254,"What kind of sous chef chops onions"],[254,383,"and sweeps the floor"],[383,496,"and washes dishes?"],[504,729,"And where the fuck is everybody else?"],[729,855,"Why don't you play your games"],[855,900,"with them?"],[900,992,"Because I'm sure they would"],[992,1230,"just be so grateful for all of your help"],[1230,1376,"because they worship you."],[1380,1534,"But that is not me."],[1534,1693,"I just want to do my job"],[1693,1835,"and be left in peace."],[2122,2256,"Damn."],[2256,2439,"Did I take that too far?"],[4183,4329,"What are you doing?"],[4329,4454,"You’re off work already?"],[4454,4612,"No, I'm just changing into some"],[4612,4754,"clean clothes."],[5714,5968,"God, you reek."],[6460,6664,"Changing isn't enough."],[6664,6844,"You need to take a shower."],[7490,7607,"Thanks."],[9501,9663,"I'm supposed to be Chef Reed's"],[9663,9801,"second in command."],[9818,9964,"Time to knock her down"],[9964,10097,"from her high horse."]],"18":[[567,821,"She's totally freaking out."],[821,950,"Get your phones out."],[950,1109,"Record this shit show."],[1167,1288,"Okay."],[2256,2427,"Oh, my God."],[3674,3753,"Is this legal?"],[3753,3916,"Should I have footage of this?"],[3916,4120,"So stupid. -Yeah."],[4212,4379,"What the fuck are you doing?"],[4433,4521,"Ah, Chef Reed."],[4521,4604,"Give me your phone."],[4604,4725,"Now!"],[4954,5109,"Are you taking pictures of her?"],[5167,5259,"Answer me!"],[5259,5347,"I'm talking to you!"],[5347,5543,"I didn't, I didn't I didn't do anything."],[5543,5676,"It was Blake. It was Blake's idea."]],"19":[[29,87,"You don't know who you're"],[87,162,"messing with."],[204,329,"Why?"],[329,579,"Layla Gray is just a nobody."],[579,721,"Who threw herself at you"],[721,863,"and took my position!"],[863,1071,"Ted, call the cops and get this"],[1071,1130,"footage deleted."],[1130,1163,"Yes, sir."],[1180,1326,"You're fired."],[1326,1480,"You can't do that."],[1505,1685,"This is a harmless joke,"],[1685,1780,"and it's not even"],[1780,1960,"her fucking restaurant."],[2077,2193,"Yes it is."],[2193,2419,"Layla is my future wife."],[2419,2602,"This restaurant is a wedding gift to her."],[2602,2756,"Do you understand me?"],[3048,3140,"Yeah."],[3140,3253,"Your career's over. Get out"],[3253,3386,"of my restaurant."],[3386,3478,"NO!"],[3478,3678,"What are you fucking doing?"],[3678,3787,"How dare you?"],[3787,3983,"How fucking dare you!"],[4133,4237,"We didn't know this was happening."],[4237,4333,"We didn’t know anything about this!"],[4333,4437,"One more chance."],[4437,4525,"Yes. Thank you."],[4525,4583,"Go get ready for dinner."],[4583,4625,"Yes."],[4625,4717,"Thank you Chef Reed."]],"20":[[642,771,"Hey, Layla."],[871,917,"It's me."],[917,1138,"I brought you some, um, clothes."],[1547,1676,"Don't come in."],[1722,1893,"Relax. It's, it's just me."],[1893,2022,"It's just me."],[2464,2623,"Hey."],[2815,3011,"It was Blake, wasn't it?"],[3069,3215,"Did you see anything?"],[3215,3345,"No. No, in fact,"],[3345,3478,"the curtain blocked everything."],[3478,3645,"No one saw anything, I swear."],[3645,3791,"I did already let the police know."],[3791,3966,"And they, they're gonna find"],[3966,4087,"and they're gonna delete that footage."],[4087,4145,"Okay?"],[4592,4850,"I just wanted to be a good chef."],[4850,4984,"Is that so much to ask?"],[4984,5230,"Hey, don't say that."],[5230,5530,"Look, you did nothing wrong."],[5543,5680,"Those guys, look, they’re just jerks,"],[5680,5784,"they’re just..."],[5784,5910,"They bullied you, okay?"],[5910,6056,"And they deserve to pay for it."],[6118,6277,"Thanks."],[6439,6610,"Would you like your towel?"],[6610,6731,"Oh, um..."],[6765,6936,"I mean, or we could, you know, we could"],[6936,7052,"keep talking like this if you want."],[7115,7198,"Okay."],[7240,7411,"I’m gonna help you up, okay?"],[7411,7661,"All right. Ready? One. Two. Three."],[7716,7820,"Here we are."],[8045,8141,"Turn around, please."],[8183,8270,"Yeah."],[8637,8725,"Okay."],[8963,9046,"Whoa, whoa, whoa, hey..."],[9046,9230,"Hey, are you okay? Is your leg okay?"]],"21":[[37,62,"God!"],[62,212,"What happened to your ankle?"],[212,316,"It's..."],[717,859,"Nothing, I'm..."],[996,1146,"Josh, I'm fine."],[1146,1305,"Just take a seat."],[1564,1705,"Can I have those?"],[1705,1776,"Oh, yeah."],[1776,1814,"Sure."],[1814,1893,"Sorry."],[2423,2460,"Oh."],[2652,2769,"Of course."],[2769,2902,"I’ll wait outside."],[3345,3461,"Seafood fork always"],[3461,3557,"goes on the outside."],[3557,3595,"Okay."],[3595,3787,"All of our consistent customers-"],[4262,4379,"Hey, Layla."],[4517,4629,"I just want to apologize"],[4629,4733,"for what happened."],[4733,4821,"We're not usually like that."],[4821,5000,"We're very sweet people."],[5000,5067,"It was Blake."],[5067,5134,"Yeah, it was Blake."],[5280,5426,"Why do they suddenly look"],[5426,5576,"scared of me?"],[5576,5739,"All right, chefs, let's conclude"],[5739,5876,"your culinary lesson for now."],[5955,6114,"Please go prep for dinner."],[6114,6231,"Yes, chef."],[7507,7565,"Why don't you take"],[7565,7670,"the rest of the day off?"],[7720,7949,"I'm fine, I don't need to go home."],[7995,8183,"I'm not suggesting that you go home."],[8254,8370,"I actually have a very important task"],[8370,8454,"I’d like you to do for me."]],"22":[[654,750,"Damn!"],[800,921,"Joshua sent you to"],[921,1046,"his nicest restaurant,"],[1046,1163,"and you still don't think"],[1163,1292,"that guy likes you?"],[1292,1372,"No, he doesn't."],[1372,1501,"He just thinks that"],[1501,1726,"I don't have refined enough taste."],[1726,1910,"So...he's sending me here"],[1910,2039,"to learn from the chefs."],[2097,2185,"I'd like you to go to a"],[2185,2327,"Michelin star restaurant,"],[2327,2448,"and for the first time, experience"],[2448,2598,"world class food."],[3094,3224,"In order to be the best, you have to"],[3224,3311,"learn from the best."],[3311,3424,"So here, chef, take this."],[3541,3603,"Go."],[3603,3732,"Order as much as you want."],[3732,3874,"Spend as much as you want."],[3949,4029,"Yes, chef?"],[4145,4279,"Yes, chef."],[4783,4859,"It sounds to me"],[4859,5005,"like he's just looking for an excuse"],[5005,5201,"to treat you to some fine dining."],[5342,5438,"I'm sorry."],[5476,5676,"Did you two have a reservation?"],[5676,5764,"No."],[5764,5889,"Well, you can't get in without one."],[5889,6022,"We're typically booked out at least"],[6022,6164,"five months in advance."],[6164,6506,"But your sign says walk ins welcome."],[6506,6639,"That's an old sign, ma'am."],[6639,6810,"Plus, we're full right now."],[6810,6998,"Why don't you try the fast food place"],[6998,7111,"across the street?"],[7119,7286,"It's practically empty."],[7286,7323,"Wait."],[7323,7511,"Are you saying we're not good enough"],[7511,7620,"to eat at your restaurant?"],[7624,7691,"Sir..."],[7736,7970,"Let's be real, have you seen our menu?"],[7970,8208,"We are the most exclusive restaurant"],[8208,8320,"owned by Joshua Reed."],[8375,8433,"So you're..."],[8612,8771,"Dollar store outfits"],[8771,8883,"aren't going to cut it in here."],[8883,9025,"We have a dress code."],[9025,9159,"If I let people like you in"],[9159,9305,"we could lose our Michelin star."],[9305,9563,"Excuse me, that is not a real reason."]],"23":[[0,154,"That is not a real reason."],[479,713,"I would like your most expensive"],[713,821,"private room, please."],[821,955,"A VIP card?"],[955,1026,"Yes."],[1026,1242,"Oh, but you did say you're all full."],[1242,1413,"Let's eat at a different restaurant"],[1413,1534,"with better service."],[1534,1634,"No, ma'am."],[1634,1826,"We always have space for our VIP"],[1826,1935,"customers in the lounge."],[2018,2173,"Right this way, please."],[2548,2840,"Well, Josh, you did say I could order"],[2840,2998,"as much as I want."],[5518,5705,"Unbelievable."],[5705,5772,"Wonderful! Was everything"],[5772,5960,"to your liking this evening?"],[5960,6001,"Yes."],[6001,6056,"Delicious."],[6056,6114,"Splendid."],[6114,6214,"I will be right back"],[6214,6352,"with your check, then."],[6352,6464,"Oh, my God,"],[6464,6581,"I have to go to the gym tomorrow."],[6581,6702,"Oh, I'm so sleepy."],[6752,6831,"Right, and who will be taking"],[6831,6940,"care of this, this evening?"],[6940,7036,"I will."],[7111,7411,"Your total today will be $5,025."],[7595,7749,"How would you like to pay for that?"],[7749,7836,"Holy shit."],[7836,8003,"I'm putting five grand"],[8003,8241,"on Joshua's card just for one meal?"],[8266,8633,"But, I mean, it's his restaurant."],[8633,8796,"It's probably fine."],[8821,8883,"Thank you."],[8988,9117,"Ma'am, what are you doing with"],[9117,9250,"Chef Reed's VIP card?"],[9250,9417,"I work for him."],[9417,9567,"Chef Reed has thousands"],[9567,9676,"of employees."],[9676,9768,"Why would he give his card"],[9768,9934,"to you, of all people?"],[9934,10097,"Oh, my God, you stole it."],[10097,10160,"Whoa!"],[10160,10293,"You stole this card, you’re a thief!"],[10293,10477,"Hey, I would watch my mouth"],[10477,10560,"if I were you."],[10581,10881,"This is Joshua Reed's wife."],[10881,10977,"Jesus, Benny."],[10977,11090,"What are you saying?"],[11090,11169,"Good one!"],[11169,11252,"If she's his wife,"],[11252,11319,"then who am I?"],[11319,11440,"His sister?"],[11440,11557,"You're not getting away with this!"],[11557,11636,"Paul!"],[11636,11753,"Guard the door!"],[11753,11878,"I'm calling the police."],[11878,11941,"No, no, no, no..."],[11941,12116,"Don’t call, you don’t have to do anything."],[12116,12295,"There's been a misunderstanding."]],"24":[[8,66,"Benny! Benny!"],[66,196,"This has gone too far."],[196,304,"I don't know what to do."],[304,496,"Officer, this woman here"],[496,667,"stole Chef Reed’s card."],[671,829,"I knew they were trouble the second I"],[829,971,"saw them trying to sneak in."],[996,1151,"Are you telling me this card belongs"],[1151,1230,"to your husband?"],[1230,1351,"Yes, it does."],[1351,1451,"Why don't we just call him up, have"],[1451,1605,"him come here to confirm it's his."],[1605,1755,"No, no, we shouldn't bother him"],[1755,1976,"because he's a busy man"],[1976,2085,"and he shouldn't be bothered"],[2085,2210,"for such a trivial matter."],[2210,2381,"Well, I have already contacted him,"],[2381,2594,"and he'll be here shortly."],[2648,2731,"Benny..."],[2769,2915,"He can't come here and see you"],[2915,3148,"like this, or else he's gonna realize"],[3148,3319,"we tricked him those years ago."],[3319,3432,"Yeah. Fair."],[3432,3516,"I'll get out of here."],[3516,3586,"Okay."],[3757,3866,"Stop right there."],[3916,3953,"Stop!"],[3953,4062,"Where do you think you’re going?"],[4062,4137,"No, please."],[4137,4341,"This is all a misunderstanding."],[4341,4629,"Please, you have to understand, this is-"],[4629,4738,"Uh uh, no way."],[4804,4850,"Ow!"],[4854,5046,"I promise you I..."],[5050,5242,"You have to let go of me..."],[5259,5534,"Hey, I am a law abiding citizen..."],[5534,5651,"This is a mistake!"],[5651,5860,"Just let me explain..."],[5905,6031,"Just let me explain."],[6031,6122,"Hey!"],[6335,6569,"What the hell is going on here?"]],"25":[[342,425,"Chef Reed,"],[425,571,"I'm so glad that you came in."],[571,930,"This woman here stole your VIP card,"],[930,1080,"and now she’s claiming your"],[1080,1155,"her husband."],[1155,1309,"Oh, fuck me."],[1309,1463,"Chef Reed, it is an honor."],[1463,1630,"I see you on TV all the time."],[1630,1801,"Anyway, sir, I need to ask you,"],[1801,2014,"is this woman your wife?"],[2035,2081,"Wait a minute."],[2081,2210,"So you're saying that she's"],[2210,2373,"pretending to be my wife?"],[2373,2510,"Now, see, that's confusing,"],[2606,2744,"because she is my wife."],[2969,3053,"Honey, are you okay?"],[3053,3119,"You shouldn't have to deal"],[3119,3178,"with this at all."],[3178,3261,"I understand why you'd"],[3261,3324,"make that mistake."],[3324,3528,"You see, we haven't gone public, yet."],[3528,3699,"Our wedding is later this year."],[3699,3803,"We've kept it under wraps."],[3803,3924,"I see."],[3924,4024,"Congratulations."],[4024,4216,"As an apology, I'd love to offer you"],[4216,4421,"a free meal at any of our restaurants"],[4421,4596,"across the nation, free of charge."],[4596,4654,"On me."],[4700,4888,"Mr. Reed, thank you very much."],[4888,5046,"My wife is gonna love that."],[5046,5142,"Absolutely."],[5142,5234,"You go to tell her."],[5234,5347,"We hope to see ya!"],[5459,5538,"Now,"],[5668,5805,"about harassing my wife."]],"26":[[20,150,"Have a seat."],[471,600,"Okay."],[1134,1368,"Mrs. Reid, please forgive me"],[1368,1497,"for my behavior earlier."],[1497,1718,"I was just way out of line."],[1718,1931,"Now, was there anything else at all"],[1931,2031,"that I can bring for you?"],[2052,2156,"Would you like anything else,"],[2156,2206,"honey?"],[2206,2331,"No, I'm..."],[2331,2523,"I'm full, but you can order"],[2523,2619,"whatever you want."],[2619,2781,"We'll take whatever the finest bottle of"],[2781,2873,"wine is from the cellar."],[2877,3061,"Yes, sir, right away."],[3190,3244,"Well..."],[3244,3403,"I understand why you're not hungry."],[3403,3495,"You've been feasting tonight,"],[3495,3636,"haven't you?"],[3741,3845,"You're the one that told me"],[3845,4033,"I needed to learn from the chefs here."],[4033,4108,"So,"],[4204,4421,"in that case... Your takeaways?"],[4425,4604,"The food is no better"],[4604,4721,"than any of the other"],[4721,4808,"restaurants you own."],[4917,5246,"But these plates are very nice."],[5305,5405,"I would hope so."],[5480,5655,"These are porcelain plates that"],[5655,5876,"the King of Spain gave to us."],[5876,6072,"About $1,000 each, I think."],[6072,6185,"And the Japanese cutlery,"],[6185,6289,"I love these."],[6310,6493,"$2,000 each, I think."],[6498,6652,"Rich snob."],[6898,7048,"I'm glad you're trying the wine."],[7048,7127,"The wine is actually"],[7127,7232,"my personal favorite."],[7232,7515,"So, this wine is the personal select"],[7515,7657,"of the Royal British Family."],[7674,7974,"They call it the Rolls-Royce of wine."],[8003,8174,"$5,000 a bottle."],[8287,8408,"So I,"],[8516,8662,"I bought this place,"],[8775,8875,"for about five million."],[8942,9079,"And then I put another"],[9079,9296,"million into it to get it up to snuff."],[9355,9655,"I also built a wine cellar downstairs."],[9655,9743,"It's about two-thousand"],[9743,9809,"square feet,"],[9809,10093,"just to hold all the world's finest wines."],[10231,10335,"I'll show you before we go."],[10335,10481,"I think you’ll really love it."]],"27":[[137,383,"So, what do you think of the place?"],[383,571,"You don't have to show off to me,"],[571,650,"Chef Reed."],[650,817,"I know that you're loaded."],[896,1046,"Mr. and Mrs. Reed,"],[1046,1197,"is this bottle to your liking?"],[1197,1438,"It's a Lafite from 1997."],[1497,1647,"That must be the year you were born."],[1647,1755,"You know, your husband has a"],[1755,1976,"whole collection of bottles from ‘97."],[1976,2131,"So romantic."],[2243,2339,"Cheers."],[2398,2606,"To the restaurant opening up"],[2606,2698,"in one week."],[2794,2944,"I'm so proud of you."],[3040,3345,"Oh, I had never had wine"],[3345,3549,"from the year I was born before."],[3549,3691,"I wondered what it would taste like."],[3691,3958,"One day, I'm going to travel the world."],[3958,4099,"I'm going to collect all the best"],[4099,4300,"and finest wines from the year 1997,"],[4300,4354,"just for you."],[4354,4654,"And we'll put it on a shelf right here."],[4792,4950,"And I'll drink them all in one night."],[5067,5163,"No, no, no."],[5555,5676,"A spider..."],[5676,5722,"Well..."],[5722,5905,"Good think I'm not afraid of spiders."],[6147,6285,"Oops."],[6348,6552,"You're so cute when you're drunk."],[6694,6806,"Just cute?"],[6806,6919,"Beautiful."],[6919,7032,"I'm sorry."],[7161,7240,"Okay."],[7315,7486,"Oh, are we done?"],[7486,7699,"No, we're just getting started."],[8541,8800,"Joshua, I have spent five years"],[8800,8971,"trying to forget you."],[8971,9129,"Why are you making me remember"],[9129,9313,"everything all over again?"],[9313,9442,"It's all starting to come back now,"],[9442,9538,"isn't it?"]],"28":[[129,166,"Ma'am,"],[166,375,"if this bottle isn't to your liking, we have"],[375,567,"plenty of other options from ‘97."],[588,721,"All personally selected"],[721,821,"by Chef Reed."],[821,909,"Oh, no."],[959,1051,"That's fine."],[1051,1117,"Of course."],[1117,1288,"Allow me."],[1576,1685,"Thank you."],[2131,2352,"Don’t worry, that's normal for us."],[2948,3082,"So, Layla..."],[3228,3399,"You might remember our"],[3399,3578,"reunion for culinary school"],[3578,3657,"is coming up,"],[3695,3887,"and I was wondering"],[3887,3995,"if you would go with me."],[4024,4179,"Because, I don't know if you"],[4179,4325,"remember what you said,"],[4325,4625,"five years ago, but you said..."],[4717,4871,"I think that..."],[5071,5205,"It would be great."],[5301,5426,"Josh!"],[5530,5576,"Please!"],[5676,5793,"I don't know what game"],[5793,5918,"you're playing or..."],[6010,6122,"what you want."],[6122,6356,"I mean, is it just to show me"],[6356,6464,"how successful you are?"],[6464,6548,"Because, you've done that."],[6548,6827,"So...I think I'm going to leave."],[6827,6936,"Wait, wait, wait. Layla."]],"29":[[12,204,"You told me five years ago"],[204,346,"that you didn't want to be with me"],[358,583,"because you hated the restaurant,"],[583,763,"and you hated all the cheap wine"],[763,905,"and then you left me to go pursue"],[905,1063,"all of your dreams."],[1222,1455,"I mean, do you not regret any of that?"],[1651,1922,"Now, I've done all of this."],[1968,2168,"I did everything that you would like."],[2239,2444,"And why can't we just get back"],[2444,2540,"together now?"],[4871,5171,"Josh, I don't regret anything."],[5288,5543,"If I could do it all again,"],[5543,5784,"I would make the same choice."],[6206,6335,"I'm sorry."],[6731,6848,"I'm never going to be good enough"],[6848,6940,"for you, am I?"]],"30":[[104,200,"I, um..."],[350,588,"I should go because my"],[588,750,"fiancé is waiting for me."],[771,984,"Layla, listen..."],[1092,1288,"If you're so head over heels for this"],[1288,1401,"guy, then tell me about him."],[1484,1626,"What do you like about him?"],[1689,1881,"That's none of your business."],[1881,1972,"Fine."],[1972,2077,"Bring him to the reunion."],[2077,2239,"I'd love to meet him."],[2335,2519,"Would you let me go, please?"],[2615,2719,"Sorry."],[2961,3053,"Okay."],[3165,3345,"I'll bring him tomorrow."],[3345,3436,"Great."],[3474,3566,"I can't wait."],[3620,3749,"Great."],[4079,4279,"Thank you for dinner."],[5401,5488,"Hello?"],[5501,5588,"Boss,"],[5647,5826,"I got some new intel."],[5826,6043,"Miss Gray is not engaged."],[6043,6131,"Wow..."],[6197,6352,"Thank you, Ted."],[6352,6493,"Great work."],[6556,6694,"Alright. Bye."],[6723,6835,"If she’s not engaged,"],[6835,7073,"then why won't she let me near her?"],[7444,7603,"Layla, you can keep lying to me all you"],[7603,7795,"want, but this time..."],[7832,8083,"I'm not going to let you leave me."],[9271,9396,"Hey, Josh. What’s up?"],[9413,9609,"Hey, Julia."],[9609,9747,"I'm wondering if you could do"],[9747,9901,"a favor for me."],[9901,10051,"Your good old buddy, Josh."],[10201,10381,"Are you free tomorrow night?"]],"31":[[283,450,"Oh, my god!"],[679,742,"You got to stop"],[742,821,"making me do this shit."],[825,963,"One of these days, Joshua is going"],[963,1084,"to beat my ass."],[1084,1188,"This is the last time I'm going"],[1188,1317,"to ask you to do this."],[1317,1534,"I need you to bring your A-game, okay?"],[1534,1614,"That her?"],[1614,1881,"Oh, it's... Oh, my God."],[1881,1968,"What is she wearing?"],[1972,2060,"What is that?"],[2106,2410,"Oh. That's a... Yeah, that's a choice."],[2481,2669,"Alright, give me your ring."],[2673,2740,"Huh?"],[2756,2902,"Please, just give it."],[2902,2990,"We're engaged."],[2990,3169,"I can't be engaged without a ring."],[3365,3432,"Thank you."],[3599,3853,"Here comes Serena and her cronies."],[3974,4275,"Wow. You look great."],[4333,4475,"Didn't expect to see you here."],[4475,4700,"Especially what you did to Joshua Reed."],[4700,4796,"I mean, are you kidding me?"],[4796,4925,"Now that he's a billionaire, you just"],[4925,5067,"want to crawl back into his sheets?"],[5067,5109,"Or what?"],[5155,5242,"Excuse me."],[5351,5618,"Actually, I found someone better."],[5618,5914,"This is my fiancé, Benny."],[5914,6093,"But, you know, it does sound like"],[6093,6260,"you're kind of obsessed with our"],[6260,6443,"most successful classmate."],[6460,6610,"You're welcome to him."],[6610,6769,"I don't want anything to do"],[6769,6911,"with Joshua Reed."],[7098,7336,"Hi, Josh."],[7369,7511,"Oh, my God."],[7549,7599,"Well, thanks for"],[7599,7695,"telling everyone that."]],"32":[[66,367,"I wasn't trying to, you know."],[383,508,"Wait. I'm so sorry."],[508,633,"Is this your fiancé?"],[696,813,"Hey man, I'm Josh."],[813,913,"It's nice to meet you."],[967,1101,"Hi, nice to meet you."],[1101,1263,"I'm Benedict."],[1263,1480,"It's nice to meet you, Benedict."],[1659,1760,"Benny."],[1876,1993,"This is Benny."],[1993,2143,"He's super supportive"],[2143,2293,"of my dreams, and..."],[2439,2660,"That's what I need right now."],[2723,2865,"Dude, we've met before."],[2865,2982,"Let’s go sit down."],[3069,3261,"Holy shit. I'm- I'm sorry."],[3261,3428,"Is that Julia Swift?"],[3453,3582,"It's really her."],[3666,3766,"Babe, I've missed you"],[3766,3862,"so much."]],"33":[[0,87,"You look beautiful."],[87,287,"Babe, I've missed you so much."],[417,588,"You owe me."],[642,846,"I know, thank you so much."],[846,1076,"Are you free tomorrow night..."],[1130,1376,"to pretend to be my fiancée?"],[1409,1526,"Let me get this straight."],[1526,1672,"The world famous chef,"],[1672,1910,"Joshua Reed wants me to pretend"],[1910,2072,"to be his fiancée"],[2072,2231,"to make another woman jealous."],[2268,2444,"Yes, that's correct."],[2444,2606,"I’ll owe you a big one."],[2723,2806,"Sure."],[2806,2923,"Thank you so much."],[2927,3019,"Bye, bye."],[3199,3365,"You look so beautiful."],[3557,3828,"Guys, I want you all to meet Julia."],[3828,4012,"So, Josh, are you and Julia, like,"],[4012,4162,"together?"],[4179,4316,"Yes, we're a couple."],[4412,4537,"Oh, did you guys meet on"],[4537,4696,"that TV show that you filmed?"],[4713,4808,"No, we've known each other"],[4808,4934,"for years."],[4934,5088,"I haven't seen him in a long time, but"],[5088,5176,"doing the show"],[5176,5263,"brought us back together."],[5267,5351,"That's right."],[5351,5488,"As soon as we reunited,"],[5488,5651,"we were inseparable."],[5701,5826,"Just like true love."],[5826,5947,"We shouldn't have spent all"],[5947,6093,"those years apart."],[6093,6181,"I know."],[6202,6322,"We have so much in common, too."],[6373,6485,"We even have the same taste"],[6485,6606,"in food and wine."],[6606,6740,"And I love that."],[6752,6965,"You know, I read the tabloids every day."],[6965,7115,"I had no idea."],[7144,7282,"Well, we're keeping it on the"],[7282,7399,"down low for right now."],[7399,7453,"That's why you haven't"],[7453,7570,"seen it in the tabloids."],[7570,7782,"But, please don't tell anyone."],[7782,7937,"No problem, no problem."],[7937,8124,"But congratulations."],[8124,8274,"And I almost forgot..."],[8425,8508,"My name is Ron."],[8508,8666,"It’s very nice to meet you!"],[8846,9009,"I'm a huge fan."],[9009,9284,"Benedict, enchanté."],[9284,9376,"Oh, yeah."],[9376,9559,"Nice to meet you all."],[9680,9793,"I didn't get your name."],[9880,9939,"Huh?"]],"34":[[50,137,"I'm Layla Gray."],[137,254,"It's a pleasure to meet you,"],[254,342,"Miss Swift."],[342,475,"Please, call me Julia."],[554,667,"Well, enough chit chat."],[667,913,"How about we, go play a game?"],[996,1247,"How about we play Truth or Dare?"],[1247,1368,"Like the old days!"],[1368,1455,"Oh, yeah."],[1455,1622,"Oh, challenge accepted."],[1622,1851,"Let's go, let's go."],[2085,2243,"Hey, come on, play with us."],[2243,2498,"It'll be fun, like old times."],[2498,2627,"Don't be a buzzkill."],[2631,2761,"Come on..."],[2765,2890,"Unless you have..."],[2890,3028,"Things you don't want exposed?"]],"35":[[216,271,"Cheers!"],[312,471,"To new friends!"],[487,625,"Alright, if you had to date another"],[625,963,"player at this table who would it be?"],[963,1247,"It's easy. Obviously. Beautiful girl."],[1247,1313,"Oh my God."],[1313,1468,"Yeah, okay. Right,"],[1468,1534,"but, that doesn't count."],[1534,1659,"Let me pick somebody else."],[1693,1789,"Oh, Serena."],[1789,1918,"Oh!"],[1918,2031,"It's a joke."],[2031,2252,"I’ll pass. I’ll pass."],[2252,2335,"It’s okay. I’ll pass."],[2335,2544,"That was lightning fast."],[2544,2640,"She’s chill."],[2640,2836,"Try this. You’ll love it!"],[2836,2932,"I would love to."],[2977,3232,"Benny, babe, can I taste your wine?"],[3520,3770,"Oh, that ring is so pretty."],[3770,3895,"Is it an engagement ring?"],[3895,3995,"It is!"],[3995,4225,"Nothing but the best for my Layla."],[4350,4621,"Good luck, she’s very hard to please."],[4708,4779,"Sorry, it's true."],[4779,4996,"I love everything my Benny gets me."],[5084,5155,"Yeah."],[5159,5263,"Alright, whose turn is it?"],[5893,5997,"Alright, Layla..."],[6072,6164,"Truth or dare?"],[6164,6218,"Oh..."]],"36":[[462,621,"Dare."],[621,675,"Alright, so..."],[675,829,"You're gonna pick a card from the top"],[829,892,"and read it so"],[892,975,"the whole group can hear."],[1005,1184,"Look at the two players sitting"],[1184,1363,"on either side of you..."],[1605,1668,"Give me that."],[1668,1751,"Here, if you need help, I can help."],[1751,1881,"Here, if you need help, I can help."],[1881,2189,"And pick one to kiss for 10 seconds."],[2264,2327,"Oh!"],[2702,2977,"Shit! Shit, shit, shit!"],[2977,3048,"No, guys, come on."],[3048,3174,"That one's a cop out, too."],[3174,3269,"She's obviously going to pick"],[3269,3353,"her fiancé."],[3353,3541,"Oh, yeah."],[3599,3707,"Fine, just do it so we can"],[3707,3858,"get it over with already."],[3858,4029,"Yeah. Come on."],[4029,4145,"Fuck it!"],[4525,4629,"Oh my God, hurry up."],[4629,4821,"Stop acting like it's your first kiss."],[5013,5259,"Seriously, come on guys!"]],"37":[[1897,2072,"I'm sorry. It’s..."],[2072,2181,"It was just a game."],[3845,3949,"Layla?"],[4412,4567,"He’s done?"],[4996,5221,"Like you said, it's just a game."],[5221,5467,"I really don't care."],[5505,5743,"Layla, wait!"],[5743,5880,"Hey, are you okay?"],[6006,6168,"He has a girlfriend, Benny."],[6168,6364,"What was he thinking?"],[6385,6531,"He has a girlfriend."],[6535,6673,"I know..."],[6952,7186,"Why can’t I quit you, Layla?"]],"38":[[233,387,"Thanks."],[504,725,"I feel a little better now."],[800,938,"I know Joshua has a new"],[938,1080,"girlfriend and everything, but..."],[1685,1881,"What if he still has feelings for you?"],[1881,2077,"Very funny."],[2077,2327,"Why else would he kiss you otherwise?"],[2327,2452,"What if him and Julia are doing"],[2452,2585,"the exact same thing that we are?"],[2585,2715,"They're coming."],[2844,2948,"You know, how like,"],[2948,3128,"two blades of grass are close?"],[3153,3303,"How close are we?"],[3353,3490,"Josh!"],[3941,4083,"Am I dreaming?"],[4083,4245,"I'm dreaming. I've got to be dreaming."],[4245,4450,"I'm dreaming, because it's you."],[4450,4683,"Every time I dream, it's you."],[4929,5088,"All right, look, guys, I'm gonna..."],[5088,5347,"I'm gonna go sit in the car."],[5447,5672,"Passenger, because I can't drive."]],"39":[[4,158,"I'm sorry, Layla."],[158,266,"He drank himself silly."],[266,358,"I tried to stop him."],[358,496,"It's- It's fine."],[567,684,"It's okay."],[684,825,"Why don't we all hang out tomorrow"],[825,942,"and just forget about"],[942,1059,"everything that happened."],[1142,1338,"Actually, I think we have something..."],[1338,1543,"Is there some reason"],[1543,1680,"you don't wanna hang out with us?"],[1726,1872,"What? No."],[1872,2006,"Layla, I feel like we were"],[2006,2135,"meant to be friends."],[2135,2318,"Okay, we can go downtown,"],[2318,2519,"go for a walk, get a coffee,"],[2519,2648,"check out some cute shops."],[2648,2748,"We'd love to."],[2748,2794,"Great."],[2798,2844,"What?"],[2844,2969,"Then it's settled."],[2998,3144,"We will see you tomorrow."],[3144,3244,"Good night."],[3257,3378,"Good night."],[3378,3657,"See you tomorrow, Julia."],[3782,3828,"Benny!"],[3828,3920,"What?"],[5380,5563,"Oh, no, no, no. I can never wear this one."],[5563,5684,"I look terrible in white."],[5684,5809,"I think you’d look beautiful."],[5851,5947,"Josh, what do you think?"],[5951,6097,"You look great in white, babe."],[6281,6473,"You look great in white, babe."],[6506,6631,"Good answer."],[6631,6790,"Why don't you try that on?"],[6931,7136,"Ah... No, I..."],[7136,7328,"This is way too expensive."],[7369,7557,"Well, why don't you try it on for Julia?"],[7557,7857,"Because lord knows she has plenty."],[7895,8045,"And I think you guys have similar body"],[8045,8191,"types, too. So..."],[8224,8429,"I'd really appreciate it, Layla."],[9050,9121,"Oh, okay."],[9121,9346,"Yeah, sure. I'll try it on."]],"40":[[37,212,"Well, I am going to"],[212,346,"try these on real quick."],[350,475,"Go for it."],[621,921,"Do you think Benny is, you know..."],[1092,1234,"Oh, definitely."],[1334,1480,"So, what do you think?"],[1480,1685,"Have we made her jealous enough yet?"],[1685,1856,"Not yet, but I think"],[1856,1947,"it's getting there, though."],[1947,2027,"Right?"],[2114,2435,"Well, then we can still do this."],[3165,3361,"How do I look?"],[3807,4054,"Oh. Does it look bad on me?"],[4054,4208,"No, no, no, it looks..."],[4208,4354,"It looks great."],[4421,4667,"Yes. I just adore that dress, Layla."],[4667,4763,"Thank you so much"],[4763,4892,"for trying it on for me."],[5013,5109,"Should I wear this"],[5109,5267,"to our engagement party tomorrow?"],[5359,5543,"You two are getting married?"],[5584,5680,"We sure are."]],"41":[[0,83,"You know, it took us so long to"],[83,208,"start dating, so we figured"],[208,383,"we'd just make up for lost time."],[458,704,"Really, thank you so much for helping"],[704,838,"me find the perfect dress."],[875,971,"Don't you think I would look"],[971,1084,"so much better in that?"],[1084,1384,"I think I just need it in a smaller size."],[1430,1618,"I'm going to go get changed."],[1897,2102,"Stupid dress."],[2252,2431,"What were you thinking?"],[2581,2698,"Julia Swift is a"],[2698,2882,"much better fit for him."],[3428,3620,"You can't be in here, Josh!"],[3620,3778,"Your fiancée is outside."]],"42":[[37,208,"You can't be in here, Josh!"],[208,392,"Your fiancée is outside."],[392,483,"Okay, listen."],[538,746,"I can tell something's up."],[746,817,"Talk to me."],[817,955,"What's going on?"],[1021,1313,"It’s the zipper, it's stuck."],[1313,1388,"It’s the zipper?"],[1397,1472,"Mm-hmm."],[1547,1764,"Okay, well, here, let me help you."],[1789,1968,"Get your hands off."],[1968,2110,"Josh..."],[2110,2369,"Your fiancée is less than ten feet away."],[2464,2577,"Wait a minute..."],[2660,2802,"Are you jealous?"],[3057,3123,"Because,"],[3161,3353,"it's okay if you're a little jealous."],[3353,3599,"All right. It's natural."],[3599,3753,"Hell, I'll admit it's hard for me"],[3753,3899,"to see you with another man."],[4029,4295,"But, I mean, you made it very clear"],[4295,4462,"in your contract years ago."],[4462,4521,"So..."],[4658,4813,"Josh..."],[4963,5105,"Can you please stop playing"],[5105,5255,"games with me?"],[5321,5476,"You have a bright future."],[5476,5638,"You have a perfect fiancée."],[5638,5764,"Can you just forget"],[5764,5939,"about the contract and let me go?"],[6151,6264,"Just..."],[6373,6527,"Just let me go."]],"43":[[33,241,"Just let me go."],[296,442,"But I can't."],[604,796,"I can't just let you go."],[796,942,"Let me just tell you the truth, all right?"],[942,1242,"Julia and I, we're not even dating."],[1247,1359,"We're not engaged."],[1359,1551,"We're not even an item."],[1551,1672,"Okay."],[1726,2002,"We just did that to make you jealous."],[2248,2356,"You did all that?"],[2414,2598,"That is the stupidest thing"],[2598,2715,"I have ever-"],[2715,2781,"Hey,"],[2781,3028,"we only did that because I know"],[3028,3219,"that you're doing the same thing."],[3219,3336,"You're not with Benny."],[3336,3499,"Okay. I know, because, first of all,"],[3499,3616,"Benny's gay."],[3616,3757,"Okay, second of all,"],[3757,3845,"we know you're faking the"],[3845,3887,"engagement."],[3887,3983,"What?"],[3983,4154,"I am marrying Benny."],[4154,4341,"Why do you think I have this ring?"],[4454,4512,"This ring?"],[4512,4571,"Yes."],[4571,4713,"What? Will-"],[4792,4838,"That's not-"],[4838,5138,"You're not marrying Benny."],[5142,5284,"You're lying."],[5518,5634,"Maybe."],[6944,7119,"I'm sorry."],[8033,8216,"I'm sorry I did that. I-"],[8400,8600,"Look, I understand that five years"],[8600,8692,"can be a long time,"],[8692,8796,"and a lot can change."],[8800,9100,"I recognize that, and maybe..."],[9225,9288,"Maybe you don't have"],[9288,9405,"the same feelings."],[9405,9534,"But I can't go out there"],[9534,9663,"without telling you the truth."],[9663,9801,"The whole truth."],[9901,10039,"I still love you."],[10260,10381,"All I ask is that,"],[10381,10652,"please, just tell me the truth."],[10773,10956,"Do you still love me?"]],"44":[[33,333,"Do you still love me?"],[2748,2973,"So it looks like my job is done here."],[2973,3199,"Yeah, I think so."],[3307,3403,"She hasn't really given me"],[3403,3516,"a solid answer, but..."],[3553,3678,"I think there's hope."],[3866,4004,"Hey, listen,"],[4004,4104,"thank you"],[4104,4212,"for everything you've done."],[4212,4320,"It really means a lot."],[4446,4592,"Well, I’d need time too, if I was her."],[4592,4688,"Especially after this"],[4688,4788,"stupid stunt you pulled."],[4788,4975,"Okay, I know."],[5205,5376,"Layla, I'm sorry I made you"],[5376,5518,"try on this dress."],[5518,5622,"The truth is,"],[5622,5818,"Joshua wanted to buy it for you."],[5922,5980,"What? - He already"],[5980,6089,"paid for it."],[6126,6352,"Josh, you-"],[6352,6539,"I- The dress is expensive."],[6539,6660,"I don't need it."],[6669,6790,"Too late."],[6827,6994,"Sorry. You deserve it."],[7161,7286,"He's Joshua Reed,"],[7286,7449,"it won’t break his bank."],[7636,7832,"So I heard that your restaurant"],[7832,7995,"is having a welcome party"],[7995,8133,"for Joshua tomorrow?"],[8179,8366,"My guess is he’ll use it as a chance"],[8366,8454,"to make some"],[8454,8604,"special announcement."],[8629,8817,"So you better show up looking nice."]],"45":[[33,171,"Josh could not stop looking at you."],[183,462,"Oh my gosh, you should see yourself."],[462,579,"You're like a middle schooler"],[579,746,"in love for the first time."],[746,880,"Benny!"],[996,1092,"Hey..."],[1184,1326,"Thanks for everything you've done."],[1326,1630,"Because honestly, if it wasn't for you,"],[1630,1889,"I would have quit my job as soon as"],[1889,2014,"Josh started at the restaurant."],[2014,2314,"I told you, he still loves you."],[2385,2485,"So what?"],[2485,2706,"You tell him how you feel."],[2706,2990,"Oh, Joshy, I've never stopped loving you."],[2990,3307,"It's been five years and nothing has changed!"],[3307,3532,"I am not that sappy, okay?"],[3611,3737,"That's fair."],[3762,3920,"And the way he played you,"],[3920,4012,"it's only right that you"],[4012,4108,"left him hanging today."],[4166,4333,"Save your answer for tomorrow."],[4333,4579,"Oh. Speaking of tomorrow..."],[4596,4692,"Um..."],[4796,5125,"Julia hinted that Josh was planning"],[5125,5367,"a special announcement"],[5367,5463,"for the party."],[5530,5638,"What?"],[5638,5730,"Oh, he is totally"],[5730,5834,"about to propose to you."],[5834,5989,"Yes he is!"],[5989,6151,"Oh, it's too exciting!"],[6151,6285,"Don’t put that idea in my head."],[6285,6398,"We need to try the dress on."],[6423,6514,"It's time."],[6514,6598,"Oh my God, Benny,"],[6602,6677,"- calm down. - You know you"],[6677,6781,"- calm down. - want to..."],[6781,6919,"You have no choice."],[7403,7453,"What's wrong?"],[7453,7686,"You okay? What's going on."],[7770,7949,"Layla!"],[7949,8108,"Layla!"]],"46":[[279,425,"I’ll be back to check on you."],[650,925,"The cancer's back, isn't it?"],[1017,1184,"Layla."],[1372,1589,"You're going to be okay."],[1935,2235,"Can I please call Joshua and tell him?"],[2252,2452,"He deserves to know."],[2560,2861,"No, no, don't tell him."],[2957,3078,"It's a good thing I haven't"],[3078,3265,"told him how I feel yet."],[3645,3762,"Layla, you've been suffering"],[3762,3866,"on your own for the last"],[3866,3978,"five years."],[4095,4191,"You've got to stop"],[4191,4371,"doing that to yourself."],[4371,4567,"I don't want him to watch me"],[4567,4679,"go through chemo..."],[4767,4954,"And lose all my hair."],[4988,5138,"Get weaker and weaker,"],[5138,5380,"and all to not even survive."],[5438,5739,"I think that would be the cruelest thing."],[5739,5868,"I would much rather him"],[5868,6039,"not know at all, then..."],[6197,6443,"Hate me forever."],[6502,6727,"But that's cruel too."],[6890,7082,"It's cruel to you."],[7444,7657,"I know you disagree, but"],[7657,7761,"just promise me"],[7761,7907,"that you won't tell him?"],[8541,8625,"Fine."],[8963,9021,"Thank you."]],"47":[[579,779,"What do you want me to do?"],[1021,1280,"Make me look pretty today."],[1388,1488,"Oh, honey."],[1689,1830,"You always look pretty."],[2394,2635,"Josh, I hope there's a parallel universe"],[2635,2786,"where I am wearing this dress"],[2786,2936,"at our engagement."],[4959,5096,"Where are you, Layla?"],[5096,5317,"I can't wait to give this to you."],[5559,5709,"Layla, you made it."],[6272,6418,"Sorry I'm late."]],"48":[[116,275,"Sorry, I'm late."],[383,629,"No, it's fine, you..."],[629,871,"You look wonderful."],[934,1096,"Your dress is stunning."],[1096,1267,"It is, and I love your makeup too."],[1267,1388,"Thanks to me!"],[1726,1843,"Attention!"],[1881,2018,"I’d like to make a toast"],[2018,2202,"to our new head chef,"],[2256,2360,"Josh Reed."],[2444,2548,"Here, here!"],[2548,2644,"Cheers!"],[2777,2836,"Thank you."],[2836,2915,"Thank you everybody."],[2915,3040,"Thank you so much."],[3807,3899,"Josh... - So..."],[3899,3962,"we should talk - we should talk"],[3962,4079,"about... - about..."],[4158,4229,"Okay."],[4254,4425,"Outside?"],[5209,5342,"Okay."],[5488,5609,"Look at that moon."],[5822,6001,"It's like I put it there for you."],[6001,6118,"Josh, I have an answer"],[6118,6197,"to your question."]],"49":[[467,663,"I'm going to break our contract."],[821,1051,"What? You can't be serious."],[1343,1609,"I don't want us to get back together."],[1760,1935,"Is this because of Julia?"],[2010,2260,"Because, listen, that..."],[2260,2427,"That was just a one time thing, okay?"],[2427,2652,"That was me just being an idiot."],[2652,2882,"It's not that."],[2969,3203,"I just needed time to think about it."],[3461,3574,"And everything I've done"],[3574,3712,"the last five years has"],[3849,4062,"has been for you."],[4325,4458,"I..."],[5422,5505,"Look,"],[5605,5709,"I don't know what you need, but"],[5709,5905,"I can find a way to make it happen."],[6010,6172,"You just tell me, I, I,"],[6172,6277,"I can get it for you."],[6277,6427,"Or if you need me to change-"],[6427,6514,"Stop."],[6560,6740,"Please stop."],[6915,7136,"There is nothing you can do"],[7136,7349,"that will change my mind."],[7661,7820,"I don't love you."],[8871,9034,"Are you sure?"],[9280,9388,"Yes."],[9759,9959,"Then, I hate you."],[10260,10460,"I’m sorry, Joshua."],[10548,10865,"Forgive me, this one last time."],[11457,11540,"Layla?"],[11611,11736,"Oh, my God!"],[11736,11815,"Layla."],[12149,12241,"Layla."],[12328,12470,"I’ve got you. You're okay."],[12470,12641,"You're okay. Here."],[12716,12854,"Come on. Let's get out of here."],[12854,12937,"Come here."],[12975,13058,"You’re okay."],[14172,14264,"Layla."],[14326,14447,"What happened to you?"],[14543,14664,"What are you keeping from me?"]],"50":[[592,788,"After today,"],[788,988,"it'll all be over."],[988,1226,"I can have a fresh start."],[2285,2477,"Good morning, Chef Reed."],[2477,2548,"Morning."],[2627,2811,"Here's my letter of resignation."],[3065,3153,"Quitting?"],[3207,3357,"I mean, you probably don't"],[3357,3478,"want me around here either,"],[3478,3616,"at this point."],[3737,3841,"What about your dream about"],[3841,3987,"being a Michelin star chef"],[3987,4175,"and having your own restaurant?"],[4362,4625,"I'll just go work for another restaurant."],[4683,4817,"Well, today can be your last day."],[4879,4971,"Come on in."],[5313,5467,"And can I please not chop"],[5467,5551,"any more onions?"],[5551,5759,"The smell is making me sick."],[6544,6702,"Josh,"],[6702,6831,"what is this?"]],"51":[[91,291,"This is what I was going to do"],[291,387,"five years ago."],[583,754,"That was a long time ago."],[959,1042,"Benny!"],[1159,1217,"Laylay..."],[1217,1301,"What are you doing here?"],[1330,1434,"If you want to hit me,"],[1434,1551,"go on right ahead."],[1618,1718,"But I think he has something"],[1718,1843,"important to say."],[1939,2060,"Take it away, my friend."],[2285,2469,"I was going to make your favorite food,"],[2469,2585,"that day."],[3065,3224,"And I was going to give you this."]],"52":[[0,404,"I... I already told you. I don't want-"],[404,625,"No, listen, Benny told me everything."],[742,909,"Okay?"],[1026,1209,"Hey, Julia."],[1209,1363,"Why did you invite me here?"],[1363,1472,"Well..."],[2085,2231,"But it's okay."],[2556,2606,"And he told me"],[2606,2715,"about your sickness."],[2919,3023,"He told me about"],[3082,3219,"everything you went through,"],[3374,3557,"and how you did it all alone."],[3941,4066,"I'm sorry."],[4191,4333,"But I love you."],[4466,4579,"He also told me"],[4708,4875,"about how you tried every"],[4875,5009,"single one of my restaurants."],[5167,5342,"And you tried all my food,"],[5434,5509,"which I'm going to need a"],[5509,5630,"full review on that later."],[5630,5768,"If you don't mind."],[6101,6243,"Listen, I"],[6381,6660,"I should have never let you go."],[6660,6810,"Not five years ago,"],[6810,6923,"not now,"],[7019,7132,"never again"],[7132,7344,"am I going to let that ever happen."],[7344,7565,"You don't have to do life alone anymore."],[8800,8963,"Well,"],[8963,9150,"are you going to marry him or not?"],[9530,9705,"That's my cue."],[10076,10247,"Layla Gray..."],[10435,10585,"Would you marry me?"],[10910,11036,"Please."],[11102,11340,"Yes. Yes."],[11636,11795,"Oh, finally!"],[11941,12112,"Get out of here!"],[12112,12245,"Say cheese."]],"53":[[3244,3432,"You have no idea how much I've"],[3432,3616,"missed you the last five years."],[3707,3883,"You didn't hate me?"],[3995,4295,"For leaving so suddenly and..."],[4350,4537,"hiding the reason why."],[4537,4604,"No."],[4654,4725,"Trust me,"],[4725,4946,"I tried to get myself to hate you."],[5055,5259,"I tried so hard to hate you."],[5430,5526,"But I couldn't do it."],[5526,5693,"I just, I couldn't."],[5693,5880,"Look, I love you way too much,"],[5880,6118,"so better just get used to it."],[6293,6402,"But..."],[6539,6623,"Why didn’t you tell me"],[6623,6765,"that you were sick?"],[6915,7082,"I mean,"],[7082,7207,"is that why you left?"]],"54":[[70,171,"Hey, look,"],[254,396,"you got to be able to talk about this,"],[404,525,"Okay? Because I"],[613,738,"I don't want to see anything like that"],[738,855,"happen ever again."],[855,950,"Okay?"],[1226,1343,"Josh..."],[1559,1726,"I felt like I couldn't tell you"],[1726,1881,"I was sick because..."],[2085,2239,"I was afraid that"],[2364,2460,"you would give everything up"],[2569,2665,"to help me."],[2844,3144,"And I didn't want you to do that."],[3157,3294,"I didn't want you to sacrifice"],[3294,3390,"your dreams."],[3432,3699,"I didn't want you to sacrifice your life"],[3787,3903,"for someone who"],[3962,4083,"might not even survive."],[4083,4149,"Hey."],[4195,4291,"What about your life?"],[4291,4450,"What about your dreams?"],[4546,4650,"I need you to know"],[4721,4913,"that your life and your dreams,"],[4913,5105,"they mean more to me than my own."],[5105,5234,"Do you understand?"],[5605,5751,"Josh, I realize that"],[5751,5905,"you and I are the same."],[5930,6302,"We both put others before ourselves."],[6414,6556,"The thought of"],[6677,6894,"you going through chemotherapy"],[6894,7057,"and surgery all by yourself,"],[7057,7228,"that I wasn't there."],[7228,7273,"Like, I..."],[7323,7486,"I can't forgive myself."],[7691,7824,"But you know what?"],[7987,8204,"When I was going through chemo and,"],[8204,8387,"whenever it was"],[8387,8608,"too much for me to bear,"],[8721,8938,"I would look up one of your reviews,"],[9046,9242,"or I would go to one of your restaurants"],[9242,9351,"and dine there."],[9488,9584,"Yeah?"],[9647,9801,"You don't realize it, but"],[9897,10097,"it wasn’t just your dream."],[10256,10556,"It was my dream for you."],[10873,11040,"Well, you got one thing wrong."],[11040,11140,"What?"],[11177,11340,"That's not my greatest dream."],[11423,11540,"It's not?"],[11594,11845,"My greatest dream is you."]],"55":[[3019,3065,"Hi."],[3065,3182,"Good morning."],[3290,3361,"Question."],[3436,3578,"Are you hungry?"],[3903,4066,"Oh my gosh."],[4066,4300,"Those look amazing."],[4300,4429,"You know..."],[4679,4817,"You look amazing."],[4963,5092,"Chef Reed..."],[5217,5518,"I am very particular about my pancakes."],[5534,5643,"This I know."],[6193,6256,"Hm."],[6644,6731,"Mm-hmm."],[6923,7086,"No, no, no."],[7136,7261,"They're too sweet."],[7261,7474,"And, they need to be"],[7511,7795,"thicker and fluffier."],[7895,8141,"I expected more from you, Chef Reed."],[8266,8404,"Is that so?"],[8479,8575,"Okay."],[8775,8904,"Fine."],[8938,9046,"Well, if the pancakes aren't"],[9046,9200,"going to be satisfactory..."],[9371,9551,"I can think of something else."],[9584,9722,"I'm sorry."],[9805,10005,"Actually, your pancakes"],[10005,10155,"are immaculate."],[10231,10314,"Too late."]],"56":[[275,367,"Alright, honey."],[433,583,"I promise I’m going to be right"],[583,729,"outside here the entire time."],[759,813,"Okay?"],[925,1092,"This is going to go by so fast,"],[1092,1255,"faster than you can even know it."],[1313,1405,"And I promise"],[1405,1547,"I’ll be the first person you see"],[1547,1685,"when you wake up, okay?"],[1868,2031,"I love you, Josh."],[2177,2339,"I love you more."],[2660,2823,"I love you."],[3812,3974,"She’s going to be okay."],[3999,4062,"Yeah."],[4095,4229,"That’s right, Layla."],[4229,4391,"You're going to be okay."],[4391,4533,"You have to."],[5647,5939,"Hey, how about you get out of here"],[5939,6047,"and get some sleep?"],[6047,6322,"You haven't slept in over 24 hours."],[6322,6427,"I can't, man,"],[6427,6623,"I want to be here when she wakes up."],[6660,6744,"But thanks."]],"57":[[171,367,"I think she's waking up."],[408,504,"Layla."],[575,700,"She's awake!"],[913,1213,"I'm here, I'm here,"],[1222,1397,"and I'm always going to be."],[1459,1593,"Josh."],[1876,2081,"By the way,"],[2081,2239,"look what I found."],[2285,2427,"What's this?"],[2527,2635,"It's the break up bet"],[2635,2773,"you signed five years ago."],[2773,3011,"It says right here..."],[3011,3282,"If we are still single in five years,"],[3282,3403,"we will get married."],[3432,3566,"Well."],[3787,3891,"So what do you say?"],[3891,4137,"You already know the answer."]],"58":[[387,617,"We are getting married."],[721,850,"I've been waiting for this day"],[850,988,"for five years."],[1447,1593,"We are gathered here today"],[1593,1839,"to finally unite Joshua Reed"],[1872,2173,"and Layla Gray in holy matrimony."],[2231,2435,"A love story five years in the making,"],[2435,2598,"filled with many roadblocks"],[2598,2677,"and hurdles."],[2740,2940,"But here we are today."],[2940,3103,"Now for the exchanging"],[3103,3240,"of the rings."],[3261,3411,"I did not forget..."],[3553,3661,"this beautiful ring."],[3661,3824,"I never doubted you."],[3874,3999,"Gorgeous."],[4095,4204,"I didn't forget either."],[4225,4350,"Wow."],[4996,5180,"Mom, what are you doing here?"],[5180,5276,"Why didn't you tell me"],[5276,5430,"you were getting married?"],[5488,5634,"Why did you keep this from me?"],[5634,5772,"Well, Mom,"],[5814,5951,"you know, Layla has never told me,"],[5951,6160,"but I assume you did something"],[6160,6423,"if she left me five years ago."],[6423,6594,"So if you could please just leave."]],"59":[[0,83,"Layla."],[141,308,"I always thought that Joshua’s greatest"],[308,446,"greatest dream was to"],[446,588,"move to Paris and become a"],[588,671,"world class chef."],[696,796,"And I hated you"],[796,896,"for standing in the way"],[896,992,"of his success."],[1055,1167,"Until..."],[1326,1476,"I found this."],[1643,1785,"The last page."],[2268,2364,"I realized that"],[2364,2569,"Josh's greatest dream is"],[2719,2873,"to be with you."],[2927,3148,"Always has been and always will be."],[3720,3983,"Thank you for showing me this,"],[3983,4141,"Mrs. Reed."],[4204,4504,"Please, call me mom."],[4592,4892,"If Josh gave up his dreams"],[4896,5005,"because of me,"],[5005,5196,"I would be mad at myself, too."],[5259,5376,"I owe you an apology"],[5376,5534,"for the way that I treated you."],[5534,5655,"Thank you."],[6006,6143,"Mom."],[6306,6443,"Thanks, Mom."],[6498,6644,"We need to finish getting married."],[6644,6765,"So if..."],[6769,6890,"Please continue."],[6944,7065,"Now..."],[7123,7269,"Where were we?"],[7853,7995,"I now pronounce you,"],[7995,8279,"Mr. and Mrs. Joshua Reed."],[8279,8370,"You may kiss the bride!"],[9084,9225,"Whoo!"]]}