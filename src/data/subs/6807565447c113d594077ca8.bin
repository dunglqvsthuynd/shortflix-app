fucking luck."],[7820,7970,"Alice!"],[8062,8212,"Alice!"],[8308,8458,"James..."],[8846,8971,"James..."]],"44":[[250,408,"Alice... Alice..."],[408,558,"Are you okay?"],[688,792,"Fuck."],[792,1059,"I thought... I thought I lost you."],[1063,1209,"James, I can’t do it."],[1263,1443,"I can't be your sister."],[1539,1689,"I love you."],[2052,2202,"I love you too, Alice."],[2573,2681,"James, I can't believe"],[2681,2815,"my mom said that."],[2852,3007,"She actually hates me."],[3157,3307,"I'll get her back right now."],[3732,3807,"Listen,"],[3807,3953,"I don't care what you have tonight,"],[3953,4058,"but Alice needs you back"],[4058,4208,"right now."],[4333,4483,"James, I feel awful."],[4954,5192,"Bottoms up, let's get that fever down."],[6252,6368,"I’m burning..."],[6710,6827,"Here."],[6873,6990,"I’ve got you."]],"45":[[133,283,"Come on,"],[308,458,"let's get you to bed."],[767,925,"What about my birthday present?"],[925,1076,"I thought you didn't want anything."],[1372,1522,"I want you."],[2848,2994,"Feeling any better?"],[3194,3345,"Almost..."],[3470,3620,"But I still want you."],[5434,5584,"Happy birthday, Bunny."]],"46":[[283,396,"Mom?"],[3178,3365,"Sleep tight, Bunny."]],"47":[[337,492,"You should have told us sooner."],[517,667,"That's so cool."],[742,892,"I wish I could live with James."],[1063,1330,"I don't know, Anna, I don't really care."],[1388,1539,"I just didn't want..."],[1864,2014,"I got you something"],[2077,2235,"for ruining your uniform last time."],[2890,2948,"Okay, but"],[2948,3061,"can you please, like,"],[3061,3174,"talk to James or something?"],[3244,3415,"He isn't responding to my texts, like,"],[3440,3591,"at all."],[3874,4020,"Kim Samuels"],[4020,4158,"I thought I told you I never wanted to"],[4158,4295,"see you again."],[4295,4391,"And you did much more"],[4391,4487,"than ruin her uniform."],[4575,4725,"Do you need a demonstration?"],[4829,4979,"Damn..."],[5025,5176,"I'm sorry."],[5205,5355,"I'm really sorry."],[5576,5726,"Well, what did she get you?"]],"48":[[667,725,"Hey."],[725,880,"Are you coming to school today?"],[2369,2515,"Spill the beans, Alice."],[2527,2623,"Who’s the guy?"],[2948,3053,"Oh my God!"],[3053,3203,"I'm done for."],[3261,3457,"Let me re-introduce you to everyone."],[3862,4012,"Alice Bell,"],[4024,4237,"the step daughter of the richest family,"],[4287,4525,"is hiding a big secret."],[4592,4771,"Kim will expose my secret."],[4804,4942,"Everyone will know I'm in love"],[4942,5092,"with my stepbrother."],[5092,5292,"The man she's been hooking up with is."],[5292,5367,"is..."],[5447,5668,"The guy she's been seducing"],[5668,5734,"is..."]],"49":[[4,262,"Alice Hawthorne seduced James"],[262,454,"Hawthorne, her stepbrother."],[554,642,"Disgusting"],[642,792,"shameless rat."],[809,925,"How filthy."],[925,1071,"That's just how poor people are."],[1071,1222,"Can't wait to latch onto anything good."],[1284,1434,"A bitch is a bitch."],[1605,1755,"So girls..."],[1776,1926,"Should we teach her a lesson?"],[2014,2164,"What are you going to do?"],[2252,2644,"Slut, slut, slut, slut."],[2673,2932,"Slut slut slut"],[2994,3232,"slut slut slut"],[3261,3411,"slut slut."],[3532,3636,"Help!"],[3832,3983,"Stop! Let go!"],[4020,4170,"Stop!"],[4946,5113,"Don't you think she's still missing"],[5113,5242,"something?"],[7148,7248,"Admit it."],[7248,7357,"You seduced James"],[7386,7494,"your stepbrother."],[7494,7653,"If I admit it, not"],[7653,7807,"only will I be done for,"],[7836,7987,"but James will be, too."],[8020,8166,"You're hilarious."],[8166,8241,"Okay, the person in"],[8241,8391,"that video wasn't even James."]],"50":[[54,204,"You say it's not true."],[233,346,"A born slut like"],[346,458,"you can only disgrace"],[458,571,"this school's reputation."],[579,725,"Drop out and get out of here"],[725,792,"right now!"],[792,992,"You have no right to order me around."],[1184,1334,"Oh, really?"],[1372,1447,"Strip her"],[1447,1568,"And let her crawl out of this school"],[1568,1689,"naked back to"],[1689,1860,"where she belongs."],[1872,2072,"No, don't touch me. Stop!"],[2077,2227,"Don't touch me!"],[2406,2515,"Stop!"],[2969,3269,"James is mine."],[3424,3561,"Oh, stop!"],[3561,3712,"Kim, get off!"],[3720,3787,"Stop it!"],[3845,3903,"Everybody."],[3903,4054,"Cut it out!"],[4371,4483,"Miss Keene."],[4483,4604,"We're doing this for the sake of"],[4604,4775,"Saint Mary's reputation."],[4904,4996,"Alice."],[4996,5105,"This video."],[5105,5242,"That's serious."],[5242,5392,"You need to tell me."],[5401,5488,"Is that James?"]],"51":[[12,183,"Who exactly is that person?"],[216,437,"If you don't tell us, you'll be expelled."],[604,754,"If I tell the truth,"],[754,905,"James will be toast."],[1167,1317,"It's me."],[2077,2227,"Sorry I'm late."],[4642,4792,"You mess with my girlfriend."],[4821,4971,"It's what you deserve."],[4988,5134,"James. Be honest."],[5134,5334,"Did your stepsister, Alice, seduce you?"],[5409,5559,"You really want to know?"],[5651,5726,"I'm the one who"],[5726,5847,"seduced my stepsister."]],"52":[[45,129,"I'm the one who"],[129,233,"seduced my stepsister."],[233,333,"James, don't..."],[425,571,"This will ruin you."],[592,742,"I'm not afraid."],[1730,1881,"Miss Keene."],[1889,2022,"Kim has violated"],[2022,2156,"Alice's and my privacy."],[2173,2298,"She's a delusional,"],[2298,2477,"creepy, stalker,"],[2581,2652,"who's secretly"],[2652,2811,"filming and posting private moments"],[2811,2961,"without my permission."],[2994,3144,"Expel her."],[3265,3332,"It wasn't me,"],[3332,3436,"I swear."],[3470,3574,"Kim."],[3628,3774,"I never liked you."],[3832,4012,"And I sent the FBI all the videos of you"],[4012,4162,"bullying everyone."],[5067,5192,"Are you out of your mind?"],[5192,5267,"How dare you mess"],[5267,5342,"with the Hawthornes?"],[5342,5459,"Do you have any idea"],[5459,5576,"how much money you cost us?"],[5597,5751,"Starting today, all your bank cards"],[5751,5851,"are frozen."],[5851,6001,"Now you are kicked out of our family."],[6143,6393,"But dad, where will I sleep?"],[6393,6535,"In the doghouse..."],[6535,6619,"And as for food..."],[6619,6752,"you can only eat dog food!"],[7520,7665,"If your dad finds out"],[7665,7791,"you’ve have been messing around"],[7791,7920,"with your step sister,"],[7978,8108,"You're done too."],[8108,8266,"Then stick a fork in me."],[8266,8370,"Because I'm done."],[8400,8537,"I don’t care anymore."]],"53":[[1338,1401,"Hello?"],[1401,1534,"Mrs. Hawthorne speaking."],[1534,1651,"Sorry to bother you,"],[1651,1818,"Mrs. Hawthorne, this is Ruby..."],[1818,1985,"Alice and James's homeroom teacher."],[1985,2081,"I need to talk to you about something."],[2081,2206,"It's urgent."],[2206,2293,"What is it?"],[2293,2444,"Has something happened?"],[2485,2560,"Alice and James..."],[2560,2719,"They were caught kissing each other"],[2719,2806,"at school."],[4149,4258,"You better not be doing"],[4258,4396,"what I think you are doing!"],[4909,5100,"What do you think you're doing?"],[5351,5501,"Mom, I can explain."],[5751,5860,"Wait, Mrs. Hawthorne."],[5860,5976,"Shut up."],[5976,6106,"I'm dealing with her first."]],"54":[[37,196,"Mom, please, you don't get it."],[208,437,"What exactly am I not getting?"],[625,775,"That it's incest?"],[779,930,"That it's gross?"],[988,1138,"You said you would stop."],[1188,1338,"Liar."],[1363,1501,"Let me remind you."],[1501,1593,"You're sleeping with your"],[1593,1685,"stepbrother!"],[1685,1839,"But I love him, Mom..."],[1872,1968,"I really do."],[1968,2185,"It's not my fault you married his dad."],[2298,2515,"Shut up, you disgusting whore!"],[2569,2719,"You better break up with James,"],[2736,2886,"or I'm kicking you out."],[3211,3361,"Don't tell her what to do."],[3595,3745,"James..."],[3887,4124,"Think about your future for a second."],[4237,4371,"How do you think Robert's gonna"],[4371,4562,"react when he finds out."],[4667,4817,"He’ll disown you."],[4846,4967,"Aren't you afraid he will"],[4967,5088,"write you out of his will?"],[5125,5276,"No, actually."],[5292,5442,"But funny you say that."],[5459,5609,"That's what you're scared of, isn't it?"],[5634,5784,"You're scared he's going to turn on you"],[5864,5964,"You never cared about Alice"],[5964,6093,"did you Eva?"],[6168,6293,"Alice."],[6293,6506,"Do you still care about your dad?"],[6690,6827,"Do you still want to disappoint him"],[6827,6965,"in heaven?"]],"55":[[29,283,"My dad would never be ashamed"],[283,446,"of me staying true to my heart."],[563,750,"He taught me to be honest."],[750,950,"He taught me what it means"],[950,1142,"to really love someone."],[1322,1543,"What you call love, Mom."],[1755,2006,"It is not real."],[2093,2210,"Alright..."],[2431,2619,"Guess you're okay with James"],[2673,2882,"getting bullied for it?"],[2932,3194,"With James getting abandoned"],[3253,3403,"by everyone who loves him?"],[3603,3716,"You know something about"],[3716,3912,"that, don't you?"],[4012,4162,"I don't care."],[4212,4362,"I don't care anymore."],[4458,4587,"I love you, Alice."],[4587,4738,"And I'm staying."],[4779,4863,"I'm not letting anything"],[4863,4971,"get in the way of us."],[5063,5284,"Not my family or anyone else."],[5559,5826,"It is my choice, Mom."],[6006,6277,"I am ready to face the consequences."],[6694,6906,"I can't let them get away."],[7019,7169,"I'll be ruined."],[8053,8162,"Hi..."],[8162,8354,"Ms. Keene."],[8354,8504,"It's Alice's mom."],[8646,8779,"Listen."],[8779,9054,"I would like to arrange something"],[9238,9317,"privately."]],"56":[[29,204,"I'm so sorry, James."],[412,567,"This can't be right."],[917,980,"Sorry..."],[980,1142,"I need to be alone for a second."],[1359,1430,"Ms. Keene"],[1430,1576,"This can't be right."],[1605,1780,"We talked after every test."],[1801,1968,"We went over all the problems."],[2014,2214,"He definitely did better than an F."],[2214,2377,"Can you double check or..."],[2473,2756,"Huh? the school seal isn't on there now."],[2781,2961,"Now, Alice..."],[3103,3199,"I understand that"],[3199,3345,"you're very concerned about"],[3345,3445,