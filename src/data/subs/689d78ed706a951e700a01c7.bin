{"1":[[1326,1422,"Hello, Mr. Hawke."],[1422,1522,"Right on time."],[1522,1597,"Please."],[2114,2227,"This, your youngest son?"],[2806,3036,"Seems like making me CEO of Evertron Tech"],[3036,3174,"comes with strings attached."],[3194,3357,"My youngest son is a mess."],[3365,3511,"He spends most of his time"],[3511,3618,"fighting and chasing women."],[3618,3757,"Has no respect for me either."],[3774,3991,"Ryder Hawke! Ryder Hawke!"],[3991,4170,"I need you to straighten him out."],[4208,4333,"If you help me with this,"],[4371,4542,"the CEO spot is yours."],[4567,4725,"What about you eldest son Vincent?"],[4725,4817,"Why not use him?"],[4817,5067,"Vincent earned his success through me."],[5088,5171,"But you,"],[5238,5355,"Despite your humble upbringing"],[5355,5559,"and losing your parents at an early age,"],[5609,5743,"you managed to get into Harvard,"],[5743,6026,"and then become a top executive within a year."],[6373,6468,"Vincent,"],[6468,6748,"you used your family to hide your crimes."],[6994,7136,"But that gave me my opening."],[7136,7278,"Getting close to your brother..."],[7278,7507,"That's the first step of my revenge."],[7620,7732,"Besides..."],[7732,7832,"My two sons"],[7832,7970,"notoriously hate each other."],[9063,9225,"We got this one coming up too."],[9843,9968,"Where's Ryder Hawke?"],[9972,10168,"Uh, still..."],[10201,10393,"Sleeping at the bar."],[10577,10723,"I want him here in 30 minutes,"],[10723,10885,"or you're all fired!"]],"2":[[145,262,"Mr. Hawke."],[846,955,"What the fuck!"],[1126,1247,"What are you looking at?"],[1247,1384,"Get out!"],[1407,1449,"Alright, sir."],[1897,1968,"It was you?"],[2006,2077,"Yep."],[2122,2394,"Work starts at 9, so I expect you to wake up."],[2577,2669,"Are you"],[2669,2819,"really lecturing me"],[2819,2986,"about my family's business?"],[2986,3036,"Well, right now,"],[3036,3244,"I'm your boss, so I expect you to follow-"],[3244,3332,"If it's about money,"],[3332,3532,"I can give you 10 times your salary."],[3532,3728,"Now, get lost!"],[3774,3870,"We have a meeting"],[3870,4041,"with the Brooks family in an hour."],[4771,4954,"Women like you put on an act all the time."],[4954,5184,"But I know you'd really do anything for money,"],[5184,5321,"so drop it!"],[5559,5751,"You can keep strangling me."],[5784,5980,"Or get up and go to work."],[6227,6389,"Or we could just have some fun right here."]],"3":[[521,646,"Three minutes enough?"],[700,792,"What?"],[838,1038,"How long you'd last in bed."],[1159,1226,"Aren't you scared"],[1226,1363,"I'll really do it right here?"],[1376,1568,"I know you don't care about your reputation."],[1568,1605,"But,"],[1605,1664,"think about"],[1664,1772,"what assaulting me"],[1772,1957,"will do to the company's stock prices."],[2494,2523,"You know,"],[2523,2606,"even if you were naked,"],[2606,2777,"I wouldn't look at you twice."],[2948,3207,"Only 50 minutes until the meeting."],[3211,3370,"So, I suggest you get ready."],[3370,3582,"Shut up!"],[3674,3795,"You're not gonna control me"],[3795,3966,"just because of that old man!"],[4012,4154,"I'm just here to serve Everon."],[4479,4533,"You..."],[4575,4729,"You are just like Vincent."],[4813,4959,"Fake as fuck!"],[5150,5213,"Ryder,"],[5246,5355,"hating Vincent"],[5355,5609,"really makes you the perfect tool for me...."],[6322,6439,"Mr. Brooks."],[6439,6635,"Hey, buddy."],[6723,6790,"Come here."],[6927,7223,"You really want me to mess with her?"],[7236,7390,"I mean, this is your family business."],[7390,7444,"Okay..."],[7532,7674,"Really mess with her."]],"4":[[158,262,"Damn, Ryder."],[279,350,"Is this your first time"],[350,487,"doing business with a woman?"],[487,738,"What, going soft on our CEO already?"],[840,991,"Of course not."],[991,1067,"Miss Stone,"],[1067,1288,"This is where I generally do business."],[1301,1409,"I hope you don't mind."],[1497,1605,"Of course not."],[1672,1805,"Let's get started."],[1805,2006,"This collab is primarily about integrating"],[2006,2151,"Everon's new AI algorithm"],[2151,