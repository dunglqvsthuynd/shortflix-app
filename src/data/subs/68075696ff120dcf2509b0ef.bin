ng"],[4325,4487,"your scholarship for this semester."],[4725,4800,"No..."],[4842,4959,"no, Dean Smith, please,"],[4959,5075,"you know I need the money."],[5100,5184,"Without my job"],[5184,5292,"and my scholarship money,"],[5292,5434,"I'll have to pick up extra hours"],[5434,5513,"at the strip club,"],[5555,5643,"or there's no way"],[5643,5801,"I can pay for Wendy's surgery."],[5947,6097,"Make her get on her knees,"],[6168,6318,"and apologize to me."]],"29":[[108,262,"I'm afraid my decision is final,"],[262,316,"Ms. Lane."],[467,638,"And if you do not apologize"],[638,709,"to Ms. Hills,"],[750,809,"I might have to"],[809,955,"consider expulsion as well."],[1034,1163,"I guess I have no other choice then."],[1226,1447,"You've never had a choice, Jenna."],[1564,1685,"Some people are just"],[1685,2085,"born worthless and pathetic like you,"],[2147,2356,"always wanting what people like me have."],[2489,2627,"But it will never happen."],[2769,3048,"Now, hurry up and apologize."],[3048,3182,"I have a nail appointment"],[3182,3240,"to get to."],[4129,4204,"I'm sorry."],[4362,4429,"What?"],[4508,4738,"Well, that didn't sound"],[4738,4846,"very convincing."],[5000,5105,"On your knees."],[5442,5501,"Katie!"],[5534,5655,"Let's show her how it's done."],[6619,6756,"Get your hands off her!"]],"30":[[83,196,"Get your hands off her!"],[383,483,"What the hell are you doing here,"],[483,579,"Mr. Atkinson?"],[713,871,"I'm here to report Serena Hills"],[871,1059,"and her sidekicks for assaulting Jenna."],[1480,1614,"As captain and star player"],[1614,1680,"on the Ice Wolves,"],[1680,1851,"I demand their immediate expulsion."],[2002,2110,"You can't do that."],[2110,2202,"My father he-"],[2260,2402,"I'm sorry, Mr. Atkinson."],[2439,2631,"Ms. Hills is a very important student"],[2631,2719,"at this university."],[2719,2886,"I can't just be throwing expulsion"],[2886,3086,"around willy-nilly to suit your whims."],[3086,3186,"Okay, fine."],[3186,3311,"Then how about suspension?"],[3311,3357,