42,5372,"all the investors will line up."],[5513,5597,"And after that,"],[5618,5780,"you'll never see me again."],[6452,6652,"It's not our company."],[6706,6881,"It's my company."],[7261,7478,"And I'll be at Mateo Rossi's wedding."],[7540,7636,"On time."],[7899,8116,"Jackson, at that wedding,"],[8145,8312,"I'll make every elite see you"],[8312,8429,"as my fiancé."],[8458,8550,"And once the company"],[8550,8775,"goes public, don't even dream"],[8775,8958,"of kicking me aside."]],"45":[[884,1080,"I...I can't."],[1142,1317,"These are your family heirlooms."],[1338,1455,"All of this would have been yours"],[1455,1547,"years ago."],[1622,1764,"If only I'd had the courage to admit"],[1764,1943,"how I felt about you back then."],[2464,2590,"As my wife,"],[2623,2815,"it will all rightfully be yours at last."],[6485,6648,"The pearls are beautiful."],[6919,7007,"But this is..."],[7073,7194,"It's too much."],[7503,7628,"You deserve this."],[7661,7791,"And so much more."],[7878,7957,"And I promise you,"],[7957,8120,"I'm going to make sure you have it."]],"46":[[942,1167,"Trina, I can't wait to tell you this."],[1167,1305,"Our company's going public."],[1334,1447,"Enough of the tantrums."],[1472,1526,"Come home."],[1559,1639,"You're my wife."],[1664,1814,"Your place will always be here"],[1814,1939,"with me and Zane."],[2064,2177,"Everything all right?"],[2289,2356,"Yeah."],[2923,3128,"Jackson, you haven't changed."],[3153,3336,"You are still the same arrogant man."],[3365,3432,"But I have."],[3461,3578,"I am no longer the woman"],[3578,3678,"trailing after you,"],[3678,3816,"begging for scraps of love."],[3845,4037,"I have my own happiness now."]],"47":[[1076,1192,"Hey, don't be mad."],[1217,1380,"I'm gonna help you make some really big"],[1380,1472,"connections tonight."],[1572,1689,"I promise."],[1714,1793,"After today,"],[1889,1981,"you'll be a success"],[1981,2110,"everyone's talking about."],[2127,2210,"Fine."],[2252,2335,"Just go,"],[2373,2510,"and don't cause me any trouble."],[3299,3482,"Hello, your Majesties."],[3611,3778,"I've been admiring your crowns."],[3778,3812,"They're so..."],[3866,4024,"My fiancé over there"],[4024,4187,"is Jackson Dela Torre,"],[4233,4454,"CEO of Dela Torre"],[4575,4721,"Enterprises..."],[4771,5017,"Who is this low-class peasant?"],[5075,5171,"I don't know."],[5413,5526,"Why would Mateo invite someone like"],[5526,5659,"her to his wedding?"],[6018,6114,"You seem lost."],[6139,6289,"The bar is that way."]],"48":[[0,79,"You seem lost."],[104,233,"The bar is that way."],[329,462,"Oh, actually, I'm,"],[462,638,"I'm here to speak with you all."],[638,742,"You see, my fiancé,"],[767,905,"he's Jackson Dela Torre,"],[905,950,"and he's..."],[950,1167,"Oh, um, and he really just..."],[1167,1343,"I guess I will see you later."],[1559,1701,"Oh, good God."],[1710,1901,"Donna's making so much of a scene."],[1926,2006,"I won't be surprised"],[2006,2152,"if they kick me out next."],[3365,3432,"My God,"],[3453,3649,"you're everything I've dreamed of."],[3712,3895,"I've waited so long for this day."],[3895,4024,"I can't believe in an hour we're going"],[4024,4112,"to be married."],[4225,4341,"God, this is the happiest day"],[4341,4412,"of my life."],[4487,4575,"I mean, truly,"],[4575,4700,"you've given me everything"],[4700,4875,"that I've given up hoping for."]],"49":[[350,504,"You look more like a princess than the"],[504,654,"princesses who are here."],[880,1134,"There're princesses here?"],[1263,1351,"A few."],[1418,1559,"Just some old family friends."],[1593,1697,"And trust me, love."],[1697,1872,"None of them can hold a candle to you."],[1926,2014,"Royalty,"],[2047,2206,"at our wedding?"],[2456,2577,"Everything all right?"],[2702,2836,"Yeah, yeah, absolutely."],[2927,3044,"Um, I just..."],[3215,3415,"I think I just need a few minutes."],[3461,3632,"Maybe get some fresh air."],[3666,3774,"Um, I'm fine, though."],[3799,3858,"I'm fine."],[3858,3916,"I just..."],[4024,4162,"It's just a little overwhelming."],[5839,5922,"Trina!"]],"50":[[829,905,"Trina!"],[1026,1201,"Where the hell have you been hiding?"],[1267,1488,"I'm, I'm not hiding from you."],[1488,1584,"I just don't want to see you."],[1618,1676,"Come home."],[1676,1743,"Stop."],[1743,1856,"You know damn well, without me,"],[1856,1972,"you've got nowhere to go."],[2056,2227,"Okay, don't kid yourself, Jackson."],[2323,2473,"Why are you clinging to me anyway?"],[2473,2540,"We're divorced."],[2698,2777,"Divorced?"],[2865,2952,"Since when?"],[3073,3232,"Well, you're already engaged to Donna,"],[3232,3274,"right?"],[3328,3495,"So why are you bothering me?"],[3820,3916,"Alright."],[3962,4058,"I get it."],[4145,4358,"You came here looking for me."],[4487,4558,"How did you even"],[4558,4679,"sneak in here anyway?"],[4679,4867,"This is Mr. Rossi's wedding."],[4871,5071,"It's crawling with society people."],[5130,5217,"No invitation?"],[5242,5392,"Security could kick you out."],[5663,5751,"Fine."],[5751,5843,"Stay with me."],[5843,6035,"I'll smooth things over with Rossi."],[6131,6352,"Mr. Dela Torre,"],[6377,6631,"I don't need you to fix anything for me."],[6698,6969,"Just leave me alone."],[7127,7311,"You followed me all the way here,"],[7344,7440,"and now you're putting on a"],[7440,7561,"holier-than-thou act?"],[7599,7682,"What the hell for?"],[7711,7928,"When did I ever say I came here for you?"],[8008,8095,"If not for me,"],[8120,8216,"then for who?"]],"51":[[100,187,"Trina,"],[221,421,"who do you know here other than me?"],[442,684,"No friends, no family, nobody."],[717,842,"Unless you're telling me that you"],[842,1005,"actually know Mr. Rossi."],[1076,1121,"Hey."],[1180,1284,"Let me go."],[1347,1484,"You left for days."],[1505,1705,"Ignored my phone calls."],[1739,1956,"What else could that be other than"],[1956,2139,"trying to get my attention?"],[2173,2364,"Fine, I'll admit it."],[2394,2531,"I haven't treated you right"],[2531,2635,"all these years."],[2915,3123,"Do you even hear yourself right now?"],[3178,3386,"Or is this just a little too hard for"],[3386,3474,"you to understand?"],[3524,3816,"We are divorced."],[3945,4141,"I am done with you."],[4170,4379,"So leave me alone!"],[4466,4671,"I've seen what you've done for me"],[4671,4792,"all of these years."],[4804,4988,"Everything that you've given without"],[4988,5142,"asking for in return."],[5226,5347,"And now you're telling me that you"],[5347,5492,"didn't come here for me?"],[5555,5701,"You expect me to believe that?"],[5730,5930,"See, that is exactly the problem,"],[5930,6001,"Jackson."],[6035,6202,"I have given you everything and I have"],[6202,6297,"asked for nothing."],[6331,6443,"And in turn, you have become this"],[6443,6523,"arrogant man who doesn't"],[6523,6664,"even know who he is."],[6835,6965,"Stop making a scene."],[6986,7194,"Don't make me lose my temper."],[7219,7349,"I'm causing the scene?"],[7444,7532,"Who else?"],[7561,7786,"You crashed Rossi's wedding just to tell"],[7786,7916,"everyone that you're my wife."],[7949,8133,"Fine, let's tell them."],[8162,8229,"Let me go!"],[8229,8291,"Are you insane?"],[8316,8404,"God Jackson,"],[8404,8558,"this is my wedding with Mateo!"]],"52":[[0,179,"This is my wedding with Mateo!"],[291,408,"Ridiculous."],[513,571,"You,"],[600,692,"a housewife"],[692,867,"that just cleans and cooks."],[875,1121,"Mr. Rossi would never choose you."],[1155,1393,"This little act of yours was just to get"],[1393,1459,"my attention,"],[1480,1601,"to get me to come home"],[1601,1714,"and leave Donna."],[1747,1864,"I already said it."],[1897,2068,"Let's go home for now"],[2068,2160,"and then afterwards,"],[2160,2318,"I'll do everything that you say."],[2464,2594,"Oh my god."],[2635,2698,"Jackson,"],[2723,3015,"I just realized how truly shameless"],[3015,3123,"you really are."],[3153,3324,"I have told you already."],[3415,3528,"We're divorced."],[3624,3978,"So stop interfering with my life."],[4137,4208,"Trina,"],[4275,4425,"why did you turn into this?"],[4425,4537,"You've never been like this."],[4562,4658,"You used to do everything"],[4658,4733,"that I said."],[5000,5075,"Ten years."],[5105,5296,"Ten years I have held back."],[5321,5459,"And of course I have changed,"],[5459,5538,"but you haven't."],[5568,5739,"You are still the same arrogant,"],[5739,5839,"self-absorbed man"],[5839,5943,"you have always been."],[6218,6289,"Trina,"],[6343,6502,"you walk away now?"],[6610,6731,"Don't come home."],[6827,6986,"Why do you not understand,"],[6986,7048,"Jackson?"],[7144,7298,"We are divorced."],[7328,7469,"I am never, never,"],[7507,7636,"coming back to your house."],[7953,8112,"I have a home now."],[8199,8416,"One filled with appreciation"],[8441,8687,"and warmth and love."]],"53":[[571,658,"Oh, my dear,"],[692,867,"I am so, so happy that"],[867,1059,"I can finally call you daughter."],[1322,1501,"Welcome to the family."],[3411,3490,"Where were you?"]],"54":[[4,150,"Dearly beloved,"],[183,392,"family, and friends,"],[425,608,"we gathered here to witness and"],[608,821,"celebrate the holy matrimony"],[821,984,"between Mateo and Trina."],[1021,1071,"I can't believe"],[1071,1209,"Trina insulted me like that."],[1238,1430,"Why couldn't she see how I've changed?"],[1463,1559,"All for her."],[1614,1768,"Did I go too far just now?"],[1814,1893,"I was only trying to"],[1893,2022,"make things right with her."],[2152,2239,"That's fine."],[2264,2369,"Trina's back now."],[2389,2519,"Proof she's forgiven me."],[2552,2615,"After the wedding,"],[2615,2736,"I'll just charm her a little"],[2736,2873,"and everything will be okay."],[3111,3345,"I can't believe we're finally married."],[3374,3582,"I'm never taking this off."],[3611,3728,"Oh, Jackson."],[4358,4429,"But,"],[4429,4625,"if you ever leave me for someone else,"],[4625,4779,"I will never forgive you."],[4879,5009,"Never going to happen."],[5280,5401,"And now I pronounced you"],[5430,5618,"husband and wife."],[6952,7173,"You may now kiss the bride."],[8792,8892,"No!"]],"55":[[8,100,"No!"],[437,517,"I object."],[567,667,"I fucking object."],[834,971,"That is my wife."],[1017,1151,"What is he still doing here?"],[1151,1305,"What the hell is going on here?"],[1305,1451,"You are still my wife."],[1451,1597,"You can't marry someone else."],[2360,2640,"Jackson, we are already divorced."],[2815,3065,"No, I never signed that agreement."],[3115,3265,"You are still my wife."],[3378,3511,"He cannot have you."],[3586,3799,"Security, get him out of here."],[3799,3874,"No, Trina,"],[3874,3991,"this is illegal."],[3991,4116,"I never signed that paper."],[4141,4262,"You are my wife."],[4421,4512,"Who is this guy?"],[4558,4646,"And why is he claiming"],[4646,4854,"Mr. Ross's bride to be his wife?"],[4888,4954,"Wait."],[5138,5296,"Trina, tell them,"],[5376,5522,"we're not divorced."],[6202,6331,"Here are the divorce papers."],[6377,6514,"Signed and sealed."],[6552,6769,"I am not your wife anymore, Jackson."],[6898,7073,"No, no, no, that's impossible."],[7123,7240,"I never signed that."]],"56":[[12,196,"I never signed those papers."],[196,321,"Yes, you did."],[321,400,"The truth is,"],[400,563,"you were too busy planning a trip to"],[563,688,"Finland with Donna"],[742,905,"to realize that what you were signing"],[905,1021,"were divorce papers."],[1201,1272,"No, it..."],[1301,1409,"That's impossible."],[1509,1672,"I have some insurance papers"],[1672,1835,"for Zane that I need you to sign."],[2398,2485,"Where do I sign?"],[3415,3503,"You tricked me?"],[3536,3599,"Yeah."],[3737,3803,"I did."],[3903,4020,"To free myself from you."],[4020,4149,"To free myself from a house"],[4149,4241,"run by Donna."],[4391,4500,"God, it's funny, isn't it?"],[4571,4838,"That every time she hurt me and lied,"],[4863,4946,"you believed her."],[5234,5355,"Donna, you bitch."],[5417,5680,"I never did, okay?"],[5826,5914,"She's the liar."],[5985,6039,"Trina"],[6056,6256,"has been cheating on Jackson for years"],[6285,6389,"with Mateo Rossi."],[6715,6877,"I'm sorry, weren't you guys just caught"],[6877,7027,"on a kiss cam at a concert?"],[7082,7194,"I can't believe this."],[7194,7253,"It's insane."],[7253,7424,"I knew I recognized her from somewhere."],[7461,7545,"They were cheating."],[7912,7991,"We were basically"],[7991,8095,"at a celebrity wedding."]],"57":[[246,308,"Jackson,"],[492,567,"we were married."],[688,850,"But it is over."],[1038,1113,"Jackson,"],[1180,1301,"Trina moved on."],[1301,1422,"She doesn't love you anymore,"],[1422,1551,"but I'm still here."],[1856,2018,"Who the hell do you think you are?"],[2064,2235,"She is my wife!"],[2702,2798,"Jackson, enough!"],[3103,3199,"Looks like the mistress didn't"],[3199,3303,"make it to the town."],[3303,3407,"Yeah, no wonder"],[3407,3528,"Mr. Rossi picked Trina."],[3528,3703,"Completely different class."],[3824,3928,"Take him out of here!"]],"58":[[1551,1647,"Trina!"],[1822,1960,"Trina!"],[2448,2640,"I need to speak with Trina, please."],[2819,2982,"She won't see you, leave now."],[3094,3219,"Trina!"],[3528,3670,"Trina!"],[3970,4099,"Trina!"],[4337,4466,"Trina!"],[7027,7136,"Trina!"],[7428,7611,"Hey, have some water."],[9138,9250,"I knew you'd come out."],[9367,9471,"You still care about me,"],[9484,9563,"don't you?"]],"59":[[358,479,"Get out."],[563,709,"Do not ever come back here."],[855,1038,"Why did you become so heartless?"],[1393,1459,"For years,"],[1501,1634,"I thought that if I could just be the"],[1634,1810,"perfect wife that you would treat me"],[1810,1893,"like I deserved."],[2085,2152,"But now,"],[2227,2323,"When I look at you,"],[2356,2515,"all I feel is..."],[2698,2819,"Disgust."],[2923,3048,"You're pathetic."],[3174,3407,"Looking at you turns my stomach."],[3407,3670,"Talking to you exhausts me."],[3712,3903,"So please, get out"],[3958,4195,"and do not ever come back."],[4308,4366,"Please,"],[4450,4587,"give me another chance."],[4662,4829,"I can change, I promise."],[4946,5050,"I will give you everything"],[5050,5150,"you ever wanted."],[5317,5397,"You used to say,"],[5534,5709,"life was like a hamster wheel"],[5780,5926,"and the only way to get through it was"],[5926,6076,"if we rolled in it together."],[6790,6844,"Jackson,"],[7073,7278,"roll out of my world."],[8875,8979,"I finally lost you."]],"60":[[900,1026,"If you're looking for Donna,"],[1026,1101,"she's gone."],[1426,1484,"Gone?"],[1526,1659,"Gone, that's what I said."],[1659,1755,"The second she heard that"],[1755,1810,"you were sick"],[1810,1893,"and in the hospital,"],[1935,2081,"she packed up and disappeared"],[2122,2306,"without even as much as a goodbye."],[2519,2623,"She was supposed to-"],[2623,2715,"Yes, well,"],[2748,2869,"I suppose she didn't want to"],[2869,2969,"turn out like Trina,"],[2994,3219,"working tirelessly for you like a maid."],[3294,3374,"Enough!"],[3507,3611,"Trina was not,"],[3682,3820,"she was never a maid."],[3966,4116,"She was Zane's mother."]],"61":[[329,450,"Mom was never a maid."],[487,533,"She..."],[613,721,"She made me this,"],[721,867,"and now it's all broken."],[892,984,"Is that why she"],[984,1084,"won't come back anymore?"],[1142,1343,"But can you fix him, Daddy, please?"],[1355,1438,"If you fix him,"],[1468,1580,"maybe Mommy will come back."],[1780,1818,"That's it."],[1997,2068,"That's it."],[2127,2235,"She was Zane's mother."],[2252,2335,"She can't leave him."],[2335,2410,"She never would."],[2410,2515,"If he asks her,"],[2515,2635,"she'll come back for sure."],[2736,2831,"What are you doing?"],[2865,2957,"Get back in bed."],[2957,3157,"I'm taking Zane to find his mother."],[3787,3866,"Enough."],[3928,4145,"You have ruined that woman's life"],[4183,4233,"already."],[4316,4608,"You will not continue to harass her"],[4671,4729,"ever."]],"62":[[1180,1259,"What's wrong, love?"],[1409,1518,"Something's been on your mind,"],[1518,1593,"I can tell."],[2356,2431,"It's my son."],[3958,4074,"I never wanted..."],[4104,4225,"to abandon my son."],[4237,4270,"But,"],[4295,4412,"Jackson and Donna,"],[4412,4529,"and his mom, they just,"],[4625,4779,"they all turned him against me, I..."],[4817,4867,"Hey,"],[5005,5109,"it's not your fault, Trina."],[5155,5309,"No, you're wrong, it is my fault."],[5309,5442,"He's just a little boy,"],[5442,5513,"and I'm..."],[5701,5784,"I'm his mother."],[5939,6051,"No matter how he acts,"],[6051,6156,"no matter what he says,"],[6272,6452,"he's always gonna be my son."],[7478,7624,"You haven't abandoned him yet."],[7724,7795,"You just..."],[7849,7974,"stepped away for a while,"],[8008,8112,"but not forever."],[8266,8312,"What?"],[8400,8516,"What, what are you saying?"]],"63":[[33,75,"What?"],[150,287,"What, what are you saying?"],[496,563,"I'm saying,"],[625,838,"we'll have Zane move here with us."],[1322,1388,"Are you sure?"],[1505,1614,"He can't live with Jackson."],[1672,1835,"The man isn't fit to raise a child."],[1889,1993,"Your son belongs with you."],[2139,2273,"And I'm sure once he's here with us,"],[2273,2414,"things will be different."],[2414,2498,"We'll be a family."],[3720,3912,"With Mateo and my son both here,"],[3912,4066,"it truly will be the family"],[4066,4187,"I have always wanted."]],"64":[[187,300,"Mommy!"],[571,729,"Mom, I fixed it for you."],[867,955,"I see that."],[1134,1330,"I am so happy that you're home, Zane."],[1476,1576,"I love you, Mommy,"],[1576,1747,"and I missed you so much."],[1747,1856,"I'm sorry for all the times that"],[1856,1968,"I was bad before."],[1993,2106,"I promise I won't be like that"],[2106,2223,"ever, ever again."],[2831,2907,"I don't have to tell you"],[2907,3007,"how lucky you are."],[3299,3440,"No, you don't."],[3674,3878,"I know I've lost her forever,"],[3945,4133,"and it's my own damn fault."],[4245,4337,"But promise me"],[4337,4441,"you'll take care of her."],[4546,4617,"Of course."],[4863,5017,"Don't make the same mistake I did."],[5484,5559,"Never."],[6539,6610,"Buddy?"],[7394,7486,"So cute."],[7561,7661,"Did you learn this from your mom?"],[7707,7770,"Yes."],[7924,7999,"So cute."]]}