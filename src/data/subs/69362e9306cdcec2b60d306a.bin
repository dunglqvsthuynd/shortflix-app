{"1":[[187,271,"I never imagined"],[271,350,"there would come a day"],[350,487,"when my husband I gave up"],[487,588,"everything for..."],[621,834,"would slap me for another woman."],[905,1080,"And as the sting of his slap"],[1080,1217,"burns on my cheek,"],[1301,1514,"I feel something inside me snap."],[1659,1876,"That was the last of my love for him,"],[1918,2068,"gone in an instant."],[2181,2373,"From this moment on,"],[2373,2656,"my ex-husband can roll out of my life."],[2952,3090,"It's my birthday today."],[3161,3253,"I don't want any gifts,"],[3286,3524,"just a simple meal together as a family"],[3524,3607,"- Defence! - would mean the"],[3607,3678,"world to me."],[3678,3828,"Defence! What the heck!"],[3858,3974,"That right there,"],[3974,4108,"is my husband Jackson."],[4158,4329,"We've been married for ten years and we"],[4329,4554,"have an adorable son together, Zane."],[5584,5701,"Uh, wait, where are you going?"],[5701,5868,"I'm almost done with the dinner I made."],[5897,6047,"Something urgent came up at work."],[6047,6110,"I gotta go."],[6135,6222,"Wait, but Jackson,"],[6222,6393,"it's my birthday!"],[7340,7415,"Tania!"],[7465,7503,"Hi!"],[7515,7586,"Yeah, I was just wondering"],[7586,7661,"when you're planning on"],[7661,7770,"bringing Zane home."],[7770,7928,"And there's no rush to leave either."],[7928,7999,"You guys could stay."],[7999,8145,"I made some really great casserole."],[8145,8262,"We're not coming back tonight."],[8262,8345,"Zane is having a sleepover"],[8345,8416,"at my place."],[8416,8529,"But it's my birthday!"],[9734,9838,"It's late."],[9838,9922,"Where are you?"],[12016,12137,"What? What is it?"],[12137,12253,"It's getting late."],[12253,12354,"When are you coming home?"],[12354,12441,"Work's busy."],[12512,12600,"I'm gonna be late."],[12600,12675,"Don't wait up."],[12917,13046,"You know, if you want,"],[13075,13175,"you don't have to keep this"],[13175,13263,"a secret anymore."],[13288,13430,"I'd make a pretty good wife."],[13475,13534,"Come on."],[13571,13780,"We like what this is, don't we?"],[13780,13943,"We're best business partners"],[13943,14134,"and friends with benefits."],[14218,14368,"Yeah, you're right."],[15148,15340,"Whoa! Either they're having an affair"],[15340,15553,"or they're just very shy."],[16720,16904,"Happy birthday to me, I guess."],[17625,17830,"Whoa! Either they're having an affair"],[17830,18043,"or they're just very shy."],[18526,18622,"My husband..."],[18693,18885,"and his secretary, Donna?"]],"2":[[588,717,"I saw you with Donna."],[763,892,"It was all over the internet."],[917,1113,"I know we've grown distant, but..."],[1230,1422,"I never thought that you would cheat."],[1605,1830,"It's just business, Trina."],[1830,1960,"We had to entertain clients"],[1960,2035,"at the concert."],[2035,2273,"That video is obviously AI."],[2273,2373,"If you trusted me,"],[2419,2573,"you wouldn't believe that garbage."],[2573,2777,"Jackson, you humiliated me."],[2890,3078,"That was all over the internet."],[3078,3194,"I don't have time for this."],[3265,3390,"I need to get ready for work."],[3924,4058,"Is this for me?"],[4145,4300,"Maybe he does remember."],[4879,5084,"Where are my clean shirts?"],[5305,5455,"Why did you cut the cake?"],[5455,5601,"I thought it was for me."],[5634,5739,"For you?"],[5789,5910,"That's for Donna."],[5910,6056,"Her birthday is tomorrow."],[6760,6886,"But yesterday was mine."]],"3":[[300,471,"Before Donna came into our lives,"],[513,642,"I felt seen."],[642,846,"Birthdays meant something."],[1134,1259,"Somewhere along the way,"],[1259,1426,"she took my place."],[1714,1797,"Sorry,"],[1856,2018,"I've just been so slammed at work,"],[2052,2181,"I forgot your birthday."],[2181,2414,"But you could have at least asked me."],[2414,2565,"Now I have to buy her a new one."],[2681,2882,"Whatever, you can have that one."],[2882,2982,"So you can remember"],[2982,3148,"Donna's birthday, but not mine?"],[3148,3490,"Can you stop talking about Donna?"],[3490,3616,"How many times do I have to tell you"],[3616,3782,"it's just business."],[3782,4033,"She closed a billion dollar deal"],[4033,4137,"for me yesterday."],[4154,4312,"That cake was just a"],[4312,4496,"tiny appreciation for"],[4496,4692,"everything she's done for me."],[4692,4859,"and for this family."],[4859,4975,"What about what I have done"],[4975,5088,"for this family?"],[5088,5309,"This house runs because of me."],[5309,5405,"All you do"],[5438,5634,"is ask for money and things."],[5634,5776,"Like this cake."],[5889,6076,"But Jackson…"],[6076,6322,"I became a housewife for you."],[6364,6439,"Trina,"],[6439,6560,"after today's launch,"],[6560,6848,"I'll officially hand the company over to you."],[6848,6977,"But that doesn't mean"],[6977,7148,"I approve of your relationship"],[7148,7248,"with Jackson."],[7369,7599,"Dad, Jackson loves me."],[7657,7799,"Just please, trust my judgment"],[7799,7853,"on people"],[7853,8074,"like you trust my judgment on stocks."],[8099,8224,"Besides, he doesn't even know"],[8224,8279,"who I really am."],[8279,8350,"Trina?"],[8375,8470,"You here for me?"],[8737,8875,"This must be a sign."],[9034,9163,"I had planned a surprise."],[9351,9480,"But since you found me,"],[9622,9730,"will you marry me?"],[9859,10101,"Trina, don't be foolish."],[10139,10281,"The first thing you need to do"],[10281,10431,"is take over-"],[10848,10969,"Yes."],[11770,11949,"All I do is ask for things."],[11986,12157,"The only thing that I want"],[12208,12328,"is for you to keep your promise"],[12328,12533,"that you made when we got engaged."],[12683,12821,"To take me to Finland and see"],[12821,12937,"the Northern Lights."],[12971,13054,"Finland?"],[13125,13246,"Northern Lights?"],[13275,13563,"Do you have any idea how busy I am?"],[13563,13663,"When was the last time"],[13663,13859,"we took a vacation together as a family?"],[13859,13976,"Because I'm here."],[13976,14093,"I'm doing the dishes"],[14093,14189,"and I'm doing the"],[14189,14356,"laundry and I'm raising"],[14356,14531,"our son and you treat me like"],[14531,14760,"the help and not your wife."],[14760,14956,"Do you even hear yourself?"],[15048,15148,"This is why"],[15148,15331,"I don't even want to come home"],[15331,15427,"anymore."],[15427,15603,"All you do is complain."],[15603,15732,"No wonder Donna says you're a"],[15732,15853,"desperate housewife."],[16328,16408,"Okay."],[16583,16708,"Just take it to her."],[16708,16837,"Forget I asked you for anything."],[16837,16946,"What am I supposed to do"],[16946,17029,"with a used cake?"],[17029,17133,"I can't give that to someone"],[17133,17221,"who's important."],[18072,18222,"Try contributing for once."],[18272,18439,"Start by making a new cake."]],"4":[[191,316,"You're so ugly."],[316,433,"You're so dumb."],[433,496,"Look at you."],[504,625,"Sweetie, I didn't know grandma"],[625,721,"brought you home."],[721,817,"Okay, can you stop"],[817,905,"with the camera please."],[938,1063,"Okay, and take your shoes off saying"],[1063,1121,"they're dirty."],[1121,1251,"I'm busy taking pictures."],[1251,1397,"You took off my shoes for me."],[1397,1514,"Grandma says you're the maid,"],[1514,1593,"and you have to do everything"],[1593,1714,"for me anyway."],[1714,1881,"Okay, I am not the maid."],[1881,1964,"I am your mother."],[1964,2072,"So shoes off."],[2106,2189,"Now!"],[2189,2256,"Maid!"],[2256,2314,"Maid!"],[2314,2464,"Mommy is the maid."],[2869,3011,"Mommy is the maid."],[3011,3094,"Zane, that is enough."],[3094,3261,"Just stop with the camera, please."],[3261,3353,"Stop it."],[3353,3453,"- Just not- - Give me-"],[3453,3582,"Why are you screaming at"],[3582,3695,"my grandson?"],[4095,4250,"He came in here with dirty shoes,"],[4250,4396,"and I already have a huge mess."],[4396,4450,"and I-"],[4450,4587,"This kitchen was a"],[4662,4846,"wreck before we even got in here."],[4867,5059,"You are a terrible housekeeper."],[5059,5242,"How can you blame your failure"],[5242,5338,"on a child?"],[5338,5405,"Well, I'm, I'm not,"],[5405,5530,"I'm not blaming him."],[5530,5630,"He's my son,"],[5630,5722,"and I'm trying to teach him"],[5722,5801,"some manners."],[5922,6156,"How dare you raise your voice at me?"],[6156,6364,"You're just a glorified maid"],[6364,6652,"living under my son's roof for free."],[6760,6998,"You're mean and ugly and dumb."],[6998,7111,"Aunt Donna's better."],[7111,7315,"She gives me candy and she's pretty."],[7315,7394,"I want her!"],[7407,7515,"I hate you!"],[7553,7665,"I hate you!"],[8158,8466,"Even your own son prefers Donna."],[8466,8616,"Maybe you should take some time and"],[8616,8796,"reflect on what kind of a mother"],[8829,8921,"you really are."],[8983,9125,"Zane, honey, let Grandma make you"],[9125,9217,"a bath, okay?"],[9275,9442,"Oh, and I need some things"],[9442,9555,"from the supermarket."],[9555,9663,"I sent you a list."],[9697,9872,"Go fetch them for me."],[9872,9955,"Now."],[10018,10110,"Come on, honey."],[10318,10481,"If even my own son,"],[10527,10673,"my flesh and blood,"],[10673,10831,"prefers Donna over me,"],[10981,11102,"what is the point of staying"],[11102,11190,"in this cage?"],[12203,12303,"Jackson?"],[12433,12537,"Jackson, wait!"],[15544,15657,"This marriage."],[15961,16161,"I think I made a terrible mistake."]],"5":[[66,137,"Hi."],[166,279,"Happy birthday."],[429,500,"Thank you."],[638,750,"Happy birthday, darling."],[963,1205,"Trina, there you are."],[1205,1313,"You look..."],[1413,1518,"worn out."],[1664,1797,"What are you waiting for?"],[1797,1910,"Bring the cake."],[3057,3307,"Why do you have to ruin everything?"],[3307,3465,"Every single time?"],[3520,3707,"You are so clumsy."],[3732,3832,"Look at Donna."],[3832,4020,"She's poised and confident"],[4020,4104,"while you're trying to make a"],[4104,4195,"fool of her."],[4195,4396,"You are careless, Trina."],[4396,4550,"Apologize to Donna."],[4550,4617,"Right now."],[4617,4763,"Oh, no, no."],[4763,4959,"She just slipped."],[4959,5046,"Probably."],[5046,5125,"It's just-"],[5125,5330,"this is a limited edition dress,"],[5330,5472,"and you just bought it for me,"],[5472,5772,"and I just wore it for the first time."],[5772,5951,"It's now just ruined."],[5951,6035,"You..."],[6076,6297,"You bought her that dress?"],[6335,6448,"What kind of a husband"],[6448,6648,"buys another woman an expensive,"],[6648,6748,"beautiful dress?"],[6748,6881,"There you go again."],[6881,7069,"Making something out of nothing."],[7069,7269,"I am so sick of it."],[7303,7490,"Let's go eat outside instead."],[7490,7636,"Wait, Jackson, no."],[7636,7728,"I'm not making"],[7728,7820,"something out of nothing."],[7820,7953,"Please, I am your wife and you're"],[7953,8074,"choosing Donna over me."],[8074,8258,"Please, she pushed me on purpose."],[8658,8800,"I didn't mean to do that."],[8833,9017,"But you shouldn't have accused Donna."],[9063,9238,"Oh, it's okay, Jackson."],[9238,9451,"Really, let's not ruin the mood."],[9496,9559,"I mean,"],[9559,9772,"we're celebrating my birthday"],[9772,9864,"and big win."],[10331,10431,"Wait, wait."],[10431,10527,"Wait, just..."],[10527,10673,"please don't take my son."],[10698,10781,"You can do whatever you want,"],[10781,10877,"just don't drag my son"],[10877,10994,"into your love affair."],[11069,11148,"Come on, Zane."],[11307,11344,"No!"],[11344,11407,"Zane!"],[11895,12078,"I want Aunt Donna to be my new mom."],[12153,12249,"I don't want you!"],[12249,12349,"I don't want you!"],[12979,13063,"Enough!"],[13100,13213,"He's my son too."],[13250,13392,"I can take them wherever I want."],[13621,13717,"So in the end..."],[13776,14014,"My son, and my husband..."],[14076,14210,"They all chose Donna."],[14364,14727,"In my own home, I am the outsider."],[16383,16462,"Dad?"],[16483,16599,"Hi, sweety."],[16800,16887,"Book the flight."],[17167,17283,"I'm coming home."]],"6":[[321,483,"Day after day,"],[483,696,"I poured everything I had"],[696,829,"into this family."],[913,1080,"Something urgent came up at work."],[1080,1155,"I gotta go."],[1155,1259,"I waited."],[1259,1355,"I stayed."],[1355,1459,"I kept believing things"],[1459,1522,"would get better,"],[1522,1705,"And what did I get in return?"],[2002,2198,"A birthday no one cared about."],[2448,2615,"A husband who betrayed me"],[2615,2756,"for the whole world to see."],[2932,3119,"A son who acts like he wants nothing"],[3119,3228,"to do with me."],[3290,3486,"I want Aunt Donna to be my new mom."],[3524,3641,"I don't want you."],[3983,4162,"I'm done living for people"],[4162,4262,"who don't see me."],[4554,4679,"From today on,"],[4800,4963,"my life is mine again."],[5063,5142,"What now?"],[5226,5422,"I just have some insurance papers"],[5422,5580,"for Zane that I need you to sign."],[6206,6322,"Where do I sign?"],[8116,8291,"You don't have to bother me with this"],[8291,8462,"trivial stuff, you know."],[8462,8587,"You're Zane's mother."],[8604,8767,"You can sign it yourself."],[8883,8979,"You're right."],[9159,9267,"I won't bother you with"],[9267,9430,"this stuff anymore."],[10381,10610,"You finally have what you want, Jackson."],[10702,10906,"You finally free."]],"7":[[266,429,"This family used to mean everything"],[429,709,"to me. It deserves a proper goodbye."],[771,1080,"One last dinner together, then it's"],[1080,1276,"time to let go off the last ten years."],[1751,1847,"Oh, honey,"],[1881,2014,"cooking dinner again?"],[2081,2273,"You look exhausted."],[2344,2494,"You look like crap."],[2560,2694,"You finally showed your true colors,"],[2694,2744,"Donna."],[2848,3015,"I always knew you were a snake."],[3040,3282,"It's not my fault that you're dumb."],[3303,3407,"So you admit it?"],[3440,3574,"You betrayed me."],[3574,3695,"You know, I always used to think of you"],[3695,3799,"as a friend."],[3832,3970,"I invite you into my home."],[3970,4120,"I take care of you when you're sick."],[4120,4233,"I trusted you."],[4262,4375,"Yes, you idiot."],[4408,4558,"Let me be clear."],[4592,4904,"I'm going to take everything from you."],[4904,5021,"Your husband,"],[5021,5134,"your son,"],[5134,5305,"your whole family,"],[5305,5526,"and your place in this house."],[5526,5626,"As long as I haven't"],[5626,5768,"divorced Jackson,"],[5901,6081,"you will always just be the mistress"],[6081,6214,"hiding in the shadows."],[6247,6318,"So what?"],[6414,6581,"The whole world has already seen our"],[6581,6669,"kiss cam."],[6690,6919,"Jackson's company is about to go public"],[6919,7152,"and he can't have any scandal"],[7152,7236,"right now."],[7294,7599,"He'll divorce you and marry me."],[8575,8687,"One last thing."],[9196,9334,"That kiss cam..."],[9421,9642,"was my plan too."],[9734,9784,"What are you..."],[10648,10719,"Trina!"],[10810,10910,"Please don't be mad."],[10910,11015,"Let me explain."],[11077,11198,"What's going on here?"],[11582,11715,"Are you crazy?"],[11774,11966,"Jackson, I was so scared."],[12041,12183,"Forget about Finland, okay?"],[12241,12441,"I told Trina about our trip and..."],[12512,12741,"she just snapped and tried to kill me."],[12741,12875,"No, no, no,"],[12875,12958,"I didn't."]],"8":[[0,262,"Trina, how could you be so evil?"],[312,492,"If I told you this was Donna's plan"],[492,583,"and she cut herself,"],[583,721,"would you even believe me?"],[721,925,"The Trina I knew would never do"],[925,1017,"something like this."],[1034,1134,"You've become somebody"],[1134,1276,"I don't even recognize."],[1305,1388,"I'm evil?"],[1480,1609,"I've changed?"],[1689,1822,"Jackson, you choose Donna"],[1822,2097,"over me again and again, and again."],[2152,2293,"Do you even remember that"],[2293,2439,"I am your wife?"],[2439,2535,"Of course not."],[2602,2944,"Because you are a liar and a cheat."],[3770,3953,"You went too far this time."],[5251,5338,"I just wanted"],[5338,5501,"one last meal with my family."],[5705,5809,"But I guess there's no need"],[5809,5926,"for that anymore."],[5951,6135,"See what happens when you push me."],[7090,7336,"This is the last time you will ever"],[7336,7511,"raise a hand towards me."],[8475,8792,"Ten years, of love and damage."],[8792,8913,"Ten years of trying to"],[8913,9063,"hold this family together."],[9134,9367,"But the second he raised his hand"],[9367,9630,"at me, it all turned to ash."],[9718,9930,"Once you cross that line,"],[9930,10118,"there is no going back."],[11248,11503,"Trina, we're finally married."],[11569,11845,"I promise I will love you forever."],[11882,12053,"He promised me forever."],[12137,12395,"But I guess forever doesn't last once"],[12395,12608,"a man's heart starts to wander."],[13359,13496,"You've made me the happiest man"],[13496,13580,"in the world."],[13680,13897,"Look at our beautiful family."],[13930,14080,"You, Trina,"],[14143,14255,"and Zane"],[14351,14493,"are the most important thing"],[14493,14602,"in the world to me."],[14789,15044,"Now those perfect vows he gave me..."],[15044,15290,"feel like the biggest lie of all."],[17671,17801,"Just two more days."],[17863,18022,"You could survive anything"],[18022,18130,"for two days,"],[18393,18476,"and then you get to"],[18476,18631,"leave this family forever."]],"9":[[1001,1209,"All the gifts Jackson got me."],[1297,1447,"So you can buy another woman"],[1447,1639,"expensive pretty dresses,"],[1639,1989,"but your wife gets the stingiest gifts."],[7328,7745,"Finally, I can leave this place."],[8687,8871,"Are you burning something out there?"],[9017,9159,"Just some trash."],[9455,9617,"Don't be mad, okay?"],[9663,9847,"Me and my temper, right?"],[9880,10026,"I shouldn't have hit you."],[10055,10143,"Trina,"],[10143,10264,"you really shouldn't have"],[10264,10393,"provoked Jackson."],[10418,10497,"You should be"],[10527,10710,"grateful for everything that"],[10710,10810,"he does for you,"],[10810,10915,"for this family."],[10944,11111,"Well, if that's all,"],[11177,11348,"I won't disturb you two any longer."],[11373,11411,"Hey,"],[11457,11644,"you did remember to finish packing"],[11644,11745,"for us all, right?"],[11778,11849,"And you packed"],[11849,11957,"Donna's favorite scarf?"],[11978,12070,"Well, don't worry."],[12087,12157,"I made sure"],[12157,12303,"you didn't forget anything."],[12362,12512,"I was even gonna make you a special"],[12512,12616,"going away cake."],[12625,12725,"We don't have time to"],[12725,12858,"eat your stupid cake."],[12858,13021,"We have to get to the airport."],[13071,13209,"It's too bad."],[13242,13359,"See you later."],[13425,13676,"Trina, don't be mad."],[13705,13859,"I will get you something back"],[13859,13947,"from Finland, okay?"],[13947,14114,"Maybe one of those"],[14114,14297,"little chocolates you really like."],[14385,14556,"Donna, don't waste your money"],[14556,14668,"buying her chocolates."],[14672,14856,"That's the last thing Trina needs."],[14889,15060,"Besides, if she wants chocolate,"],[15081,15202,"she can buy it herself."],[15231,15394,"Not that she can afford it."],[15682,15878,"Bye-bye, Maid."]],"10":[[1030,1176,"No, I want oat milk."],[1197,1401,"This, um, it's oat milk."],[1438,1530,"Drink it now."],[1664,1826,"Have patience with the child."],[1856,2085,"He's only ever had the oat milk that his"],[2085,2277,"sorry excuse for a mother makes."],[2289,2356,"Try it."],[2356,2414,"Here."],[2907,3165,"Jackson, did the call go through yet?"],[3236,3365,"What is oat milk?"],[3365,3470,"She's not answering."],[8550,8717,"Fuck you, Jackson."],[10039,10155,"Grandma, Emma,"],[10181,10356,"I wanted to tell you that I'm leaving."],[10377,10485,"Oh, you..."],[10518,10648,"Oh, Trina."],[10677,10869,"All these years he treated you"],[10869,11002,"so horribly."],[11040,11240,"I don't blame you for wanting to go."],[11240,11432,"I just want you to be happy."],[11448,11574,"I sure will be sad to see you go,"],[11574,11619,"Trina."],[11619,11790,"But don't worry about Emma."],[11815,11891,"I'll make sure to"],[11891,12007,"take good care of her."],[12007,12116,"You two are the only ones"],[12116,12178,"in the family that"],[12178,12324,"ever treated me like I mattered."],[12458,12633,"Please take care of yourselves."],[14335,14493,"Trina, finally,"],[14493,14677,"can't do anything right."],[14677,14760,"Our suitcases"],[14760,14902,"only have summer clothes."],[14927,15244,"Summer clothes for Finland in October,"],[15269,15565,"one of the coldest places in the world."],[15590,15757,"Jackson, I'm done being treated like a"],[15757,15957,"servant instead of your spouse."],[16070,16195,"We're getting a divorce."],[16445,16591,"Divorce me?"],[16629,16808,"That is not happening, Trina."],[16808,16887,"You hear me?"],[16887,16950,"I won't."],[17183,17359,"Happy divorce, Trina."],[17392,17538,"Here's to your new beginning,"],[17538,17650,"and your return to the life"],[17650,17838,"you should've always had."]],"11":[[742,888,"Your call has been automatically"],[888,1071,"forwarded to a voice messaging system."],[1071,1180,"Damn it, Trina!"],[1180,1280,"Answer me!"],[1455,1601,"What did she just say?"],[1622,1705,"Divorce?"],[1797,1968,"No, I must have heard it wrong."],[2010,2085,"She wouldn't dare."],[2135,2223,"She won't leave."],[2318,2402,"What's wrong, Jackson?"],[2427,2502,"I mean,"],[2502,2581,"she didn't answer."],[2581,2686,"It's no big deal."],[2736,2831,"Why are you panicking?"],[2877,2990,"You look like a fool."],[3123,3178,"Here."],[3453,3641,"You're supposed to be watching him."],[3641,3933,"I'm doing the best I can."],[3978,4208,"You can't even handle the basics."],[4258,4379,"If Trina were here,"],[4441,4671,"she'd have Zane all taken care of."],[4963,5209,"I want my mommy!"],[5209,5309,"Mommy!"],[5351,5476,"Mommy!"],[5488,5613,"Mommy!"],[6068,6214,"I think I heard Trina say..."],[6306,6443,"She said divorce."],[6443,6589,"She wouldn't really leave me, would she?"],[6690,6969,"Trina can't handle a parking ticket,"],[7027,7182,"let alone a divorce."],[7257,7424,"If she leaves you,"],[7486,7724,"she'll end up starving to death in a ditch."],[7799,7870,"I guess you're right."],[7928,8016,"Attention, please."],[8041,8274,"Flight AA281 is now boarding."],[8333,8500,"We kindly invite passengers traveling"],[8500,8692,"in first class, or business class..."]],"12":[[421,508,"I knew you'd come."],[583,654,"Did you bring the clothes"],[654,750,"I asked you to?"],[1743,1868,"Where do you think you're going?"],[1901,1960,"Let me go."],[1989,2089,"I'm not here for you."],[2089,2235,"I'm going on my own trip."],[2394,2510,"Your own trip?"],[2556,2652,"That's a laugh."],[2694,2890,"Oh, and this is the VIP lounge,"],[2890,3023,"in case you didn't see the sign."],[3078,3311,"Economy is over there."],[3382,3465,"Enough."],[3545,3678,"Stop making a scene."],[3728,4008,"Playing hard to get won't work on me."],[4108,4325,"I'm not playing at anything."],[4325,4554,"I meant every word that I said."],[4617,4750,"I'll let this one slide."],[4879,4959,"But if you want to keep your"],[4959,5071,"comfortable life,"],[5071,5180,"you'd better behave."]],"13":[[100,229,"Comfortable life?"],[387,604,"Do you really think the life that I live"],[604,696,"is comfortable?"],[921,1101,"Okay, well you can take that"],[1101,1242,"so-called life"],[1242,1434,"and give it to anybody else."],[1826,1976,"You know, I bet she'd enjoy it"],[1976,2106,"much more than me."],[2243,2302,"Mommy!"],[2302,2398,"I want Mommy!"],[2494,2590,"Here's your coffee."],[2932,3040,"Careful!"],[3199,3269,"Watch out!"],[4387,4483,"Watch your kid."],[4508,4583,"Oh my God."],[4583,4654,"Are you crazy?"],[4654,4842,"You nearly threw him into that hot coffee."],[5309,5497,"Trina, how could you push me?"],[5576,5676,"I was just trying to"],[5676,5897,"catch Zane so he wouldn't get hurt."],[5964,6151,"No, I didn't."],[6151,6277,"I get that you're mad at me,"],[6277,6414,"but don't risk your son."]],"14":[[287,538,"You can do whatever you want to me,"],[538,671,"but my son is off limits."],[704,771,"Always."],[880,1009,"You're the one who pushed me."],[1009,1130,"Why are you blaming me?"],[1163,1276,"Okay, enough."],[1326,1534,"Donna has been watching Zane"],[1534,1680,"all day."],[1680,1826,"She's done nothing wrong."],[1826,2031,"Apologize to her now,"],[2031,2160,"or I will divorce you."],[2323,2431,"Zane, can you please just"],[2431,2594,"tell your daddy the truth?"],[2723,2844,"When mommy gets mad,"],[2869,3048,"she won't let me have candy."],[3048,3244,"But Auntie Donna always does."],[3503,3657,"It was mommy."],[3657,3849,"She pushed me into the hot coffee."],[3849,3908,"It was her."],[3995,4079,"No, Zane."],[4079,4204,"Zane, no, no, no, no, Zane."],[4204,4300,"You know it is not nice"],[4300,4437,"to tell fake stories."],[4625,4859,"Stop being such a bitch, Trina."],[4859,4963,"You already scared your son"],[4963,5080,"and now you accuse him?"],[5125,5330,"For God's sakes, he's just a child."],[5472,5714,"Now boarding flight 398 to Helsinki."],[5780,5860,"All passengers,"],[5860,5997,"please line up according to your"],[5997,6056,"boarding number."],[6110,6360,"You went too far this time, Trina."],[6360,6443,"When we get home..."],[6493,6610,"We're gonna have a little talk."],[8370,8454,"Trina!"],[9822,9905,"Mateo?"],[10001,10089,"it's me."],[10176,10272,"I'm sorry I'm late."]],"15":[[504,742,"Hey, isn't that Mateo Rossi?"],[775,888,"Oh my god, the guy on the"],[888,1026,"Forbes most powerful list?"],[1071,1192,"How did you get hurt?"],[1509,1643,"It was an accident."],[1876,1956,"But from now on,"],[2039,2214,"there will be no more accidents."],[2302,2590,"Only a final goodbye to my husband,"],[2681,2769,"my son,"],[2882,2990,"my family."],[3958,4083,"Trina hit her head pretty hard."],[4145,4262,"Is she okay?"],[4354,4546,"Why do I feel like if I leave now,"],[4579,4738,"I'll never see her again?"],[4738,4829,"Where are you going?"],[4975,5117,"I just want to check on Trina,"],[5117,5255,"make sure she's alright."],[5255,5467,"But the plane is about to take off."],[5526,5743,"And if you go running back to her now,"],[5743,5918,"she'll know exactly how to keep you"],[5918,6202,"feeling sorry for her every single time."],[6277,6548,"Last call for flight 398 to Helsinki."],[6577,6715,"All remaining passengers"],[6715,6798,"please board now."],[6823,6952,"Yeah, Donna's right."],[7032,7194,"Trina's always putting on an act to"],[7194,7282,"reel me back in."],[7328,7465,"I'm not falling for it again."],[8137,8183,"Is that..."],[8212,8320,"Trina he's carrying?"]],"16":[[16,271,"Wait, is that Trina?"],[442,542,"That's impossible."],[542,688,"You're seeing things."],[688,817,"Trina couldn't possibly know"],[817,984,"someone who owns a jet like that."],[1046,1159,"Come on, let's go."],[1201,1276,"I promise you,"],[1347,1522,"your useless wife will be waiting for"],[1522,1760,"you at home where she belongs."],[2781,2898,"What's wrong."],[3182,3244,"Nothing."],[3399,3482,"Let's go home."],[5138,5313,"She didn't even text me?"],[5376,5522,"Clearly I've been spoiling her"],[5522,5609,"too much lately."],[5651,5743,"A silent treatment"],[5743,5872,"should get her back on track."],[5939,6026,"It always does."]],"17":[[446,583,"I cannot believe this."],[583,796,"There's not a single sweater"],[796,1017,"nor a raincoat. Nothing."],[1113,1276,"How am I supposed to go out there"],[1276,1343,"in this?"],[1401,1501,"In other news,"],[1501,1718,"what top 10 Forbes Rich List star was"],[1718,1776,"spotted with the"],[1776,1964,"mysterious new lady friend?"],[2498,2577,"No."],[2752,2907,"There's no way that's Trina."],[2957,3090,"She's a boring housewife."],[3178,3315,"Nobody would want her but me."]],"18":[[325,387,"Dammit!"],[454,554,"Still no reply?"],[688,946,"I can't wait to see the aurora tonight,"],[946,1013,"babe."],[1071,1126,"With you."],[1488,1601,"Okay, where are we going?"],[1710,1860,"I promised you the Northern Lights."],[1964,2122,"I'm taking you to the Northern Lights."],[2289,2527,"Okay, that's way too expensive, love."],[2581,2827,"Look, until Dela Torre Enterprises takes off,"],[2827,2940,"we should spend the money"],[2940,3044,"on things that matter,"],[3044,3299,"not my frivolous daydreams."],[4738,4813,"Huh huh."],[4959,5088,"You deserve all your dreams"],[5088,5196,"to come true."],[5230,5351,"Right now it feels like"],[5351,5451,"they already have."],[6197,6268,"Babe,"],[6339,6552,"you're not still worried about her."],[6669,6760,"Of course not."],[7007,7111,"Ooh, that could be Trina."],[7603,7766,"What did you spend now?"],[7795,7949,"You spent $100,000."],[7982,8241,"Trina didn't pack any of my clothes."],[8279,8441,"I just bought myself a little something"],[8441,8525,"like I always do."],[8571,8679,"What's your problem?"],[8783,8900,"Trina"],[8900,9092,"would never blow my money like this."]],"19":[[713,875,"Oh my gosh,"],[905,1055,"I love this designer."],[1539,1618,"Let's go in."],[3257,3482,"This is the longest Trina's ever gone"],[3482,3632,"without answering me."],[3632,3757,"I think she might really be mad"],[3757,3845,"this time."],[5568,5647,"Forgive me?"],[6744,6831,"I love it."],[7032,7107,"I love you."],[7148,7219,"I love you."],[7682,7832,"Trina would never leave me."],[7903,8008,"She loves me too much."],[8074,8262,"But I'd better make it up to her."],[8262,8395,"She always loved when I surprised her"],[8395,8487,"with presents."],[8550,8737,"I would like this one wrapped up."]],"20":[[87,246,"I'd like this one to be wrapped up."],[563,713,"Oh babe, that's exactly"],[713,834,"what I've been looking for."],[992,1084,"This is for Trina."],[1217,1384,"You can pick out a different one."],[2214,2360,"I love my new dress."],[2990,3086,"I'm gonna take a shower."],[4608,4704,"I have your change of clothes"],[4704,4783,"laid out for you."],[6006,6126,"Trina would have had everything"],[6126,6256,"set out for me just right."],[6427,6498,"Damn it."],[6539,6715,"Why am I thinking about her again?"],[7440,7553,"What the hell are you doing?"]],"21":[[4,116,"What the hell are you doing?"],[784,946,"Why are you so mad?"],[1021,1292,"You always let me have anything I liked,"],[1292,1388,"even if it was Trina's."],[1388,1526,"It's just a silly necklace."],[1564,1735,"I give you plenty of gifts."],[1780,1951,"Why do you have to take Trina's too?"],[2052,2260,"This is all I have for her."],[2260,2373,"Why do you care?"],[2523,2602,"Do you still..."],[2731,2882,"Do you still love her?"],[2952,3036,"Of course not."],[3757,3908,"You promised me"],[3941,4216,"that you will leave her to be with me."],[4592,4825,"I'm here and she's not."],[4975,5050,"So be here"],[5171,5376,"with me, Jackson."],[5376,5417,"You..."],[5609,5739,"You love me, right."],[6468,6602,"Why did I never notice how sharp"],[6602,6744,"Donna's perfume is?"],[6744,6852,"Trina would never wear something"],[6852,6927,"this strong."],[6927,7027,"She always carries that"],[7027,7157,"comforting citrus scent."],[7244,7273,"Damn it!"],[7307,7432,"Why am I thinking about her again?"],[7494,7628,"Jackson, what's wrong?"],[7778,7928,"I'm not feeling well."]],"22":[[279,404,"Your call has been automatically-"],[579,704,"It's been four fucking days!"],[759,875,"She's never done this!"],[946,1055,"As soon as I have the chance"],[1055,1130,"to speak to her,"],[1172,1313,"all of this will blow over."],[1388,1443,"It has to."],[1539,1714,"Daddy, does Mommy"],[1714,1826,"not love me anymore?"],[1868,2068,"She never even calls to check on me."],[2114,2173,"Yeah."],[2239,2419,"How long has it been since Trina checked"],[2419,2464,"in on Zane?"],[2565,2669,"Back when I took him abroad,"],[2669,2806,"she used to call in every day."],[3807,3912,"Oh, there it is."],[4074,4120,"Is it Mom?"],[4466,4542,"Jackson."],[4583,4704,"Mom, why are you so annoying?"],[4746,4859,"Stop bothering me."],[5071,5163,"You call every day."],[5209,5280,"I'm sorry."],[5296,5351,"I thought you guys"],[5351,5467,"would be at the hotel."],[5467,5497,"I didn't..."],[5563,5718,"I didn't realize I'd be interrupting."],[5876,5939,"Sorry."],[6197,6310,"Was it because of something"],[6310,6398,"I did before?"],[6443,6523,"Is that why mommy"],[6523,6681,"doesn't love us anymore?"],[6844,6931,"What do you mean?"],[7349,7440,"In the airport,"],[7474,7607,"Mommy didn't push Aunt Donna."],[7661,7774,"Aunt Donna stuck out her leg"],[7774,7849,"and tripped her."],[7949,8008,"I saw it."],[8187,8262,"You're lying!"]],"23":[[70,137,"Let him finish."],[262,538,"Zane, did you really see Donna trip Mom?"],[742,888,"Why didn't you tell me the truth before?"],[930,975,"Because"],[1013,1138,"I thought Mom was trying to"],[1138,1213,"cancel our flight."],[1309,1468,"And so I lied."],[1534,1584,"But"],[1584,1747,"I did see Aunt Donna stick out her leg."],[1785,1943,"You're lying! Okay?"],[1943,2006,"He's... Jackson."],[2006,2097,"He's just a kid."],[2097,2206,"You're not going to believe him"],[2206,2281,"actually, are you?"],[2310,2456,"I mean, it was Trina,"],[2456,2585,"the one who pushed me."],[2585,2706,"You're going to believe me, right?"],[2865,2948,"Yes, Jackson."],[2965,3040,"I mean,"],[3040,3207,"he just remembered it wrong."],[3244,3395,"He's so young."],[3395,3616,"Or maybe he missed his mom so much,"],[3616,3774,"he just made it up."],[3774,3853,"Yes."],[4083,4275,"Could Donna really have tripped Trina?"],[4383,4517,"Or did Zane just imagine it?"],[4950,5059,"If this rain doesn't stop,"],[5059,5196,"we're never going to see the Aurora."],[5242,5434,"We're going back to New York tonight."],[6614,6673,"Trina,"],[6765,6810,"I'm home."],[6810,6898,"Where are you?"],[7115,7232,"Trina, I'm home."],[7265,7328,"Where are you?"],[7661,7749,"What the fuck?"]],"24":[[75,258,"Trina, we're back."],[291,433,"I brought you a gift."],[500,600,"Trina!"],[1334,1468,"Where are her things?"],[1493,1651,"How did they all dispear!"],[2602,2794,"Are you burning something out there?"],[2827,2932,"Just some trash."],[3274,3361,"No."],[3415,3520,"She couldn't have."],[4258,4412,"Your call has been automatically"],[4412,4500,"forwarded to a voice message..."],[4500,4542,"No."],[4642,4783,"No, no, no!"],[4788,5017,"Jackson, Trina left another one of her"],[5017,5209,"pathetic cakes down here."],[5467,5751,"Trina, I know you still love me."],[5797,5910,"Every time I went away,"],[5910,6051,"you always had a baked cake"],[6051,6218,"and a gourmet meal waiting for me."]],"25":[[437,625,"He hasn't realized that she's truly gone."],[779,967,"My foolish grandson..."],[1084,1247,"Expects Trina to forgive him,"],[1247,1468,"unconditionally, and forever."],[1655,1797,"Just how much heartbreak"],[1797,1997,"is one woman expected to bear?"],[2452,2540,"What's this?"],[2540,2702,"Just a cake, nothing else?"],[4108,4325,"I can't believe we're finally married!"],[4371,4554,"I'm never taking this off."],[4650,4788,"Oh, Jackson!"],[5180,5238,"But..."],[5267,5372,"If you ever leave me for"],[5372,5430,"someone else,"],[5430,5609,"I'll never forgive you."],[5718,5843,"Never gonna happen."]],"26":[[83,262,"I'm hungry, I'm starving!"],[842,1051,"Why didn't you keep an eye on him?"],[1076,1138,"I um..."],[1580,1789,"Jackson, I am done being treated like a"],[1789,1951,"servant instead of a spouse."],[1964,2122,"I'm divorcing you."],[2285,2364,"Divorce?"],[2548,2756,"A divorce paper without my signature"],[2756,2857,"is trash."],[3086,3299,"No, this isn't real."],[3420,3557,"She's just mad at me."],[4625,4700,"No!"]],"27":[[158,241,"Oh, dad."],[433,588,"Dad, I'm so sorry."],[650,792,"I was young and I was immature,"],[792,892,"I should have never left the family"],[892,1001,"behind for Jackson."],[1001,1051,"Shh, shh, shh."],[1051,1197,"It's all in the past now."],[1234,1359,"All that matters"],[1418,1564,"is that you're here now."],[1593,1714,"You should be resting."],[1785,1972,"You took quite a tumble."],[2235,2419,"I missed you so much."],[2769,2886,"Let me just think I'll look at you"],[2886,2986,"for a minute."],[3019,3119,"So beautiful."],[3244,3390,"So like your mother."],[3753,3782,"Oh."],[3899,4058,"Trina, you know, Mateo."],[4145,4225,"He's been..."],[4279,4525,"invaluable to me these past few years,"],[4546,4708,"like the son I never had."],[4804,4867,"And you know,"],[5013,5117,"he's never married."],[5292,5347,"So,"],[5355,5467,"why don't I just..."],[5505,5709,"leave you two alone for a minute,"],[5755,5839,"so you can..."],[5893,5972,"to talk."],[6556,6631,"About what your father-"],[6631,6706,"Thank you for..."],[7265,7369,"You...you first."]],"28":[[212,350,"About what your father just said."],[358,429,"It's true."],[467,558,"I haven't married."],[654,688,"But..."],[784,909,"I don't want you to think that means"],[909,967,"that I..."],[1172,1230,"What?"],[1230,1347,"Should I think it means?"],[1355,1447,"You know I've always loved you,"],[1447,1488,"Trina."],[1514,1664,"I don't want you to feel pressured"],[1664,1739,"or anything."],[1776,1906,"I'm not even divorced yet."],[1906,2068,"I can't possibly get involved with"],[2068,2160,"anyone else..."],[2177,2318,"Not even Mateo."],[2615,2723,"Friends?"],[2986,3069,"Friends."],[3899,4029,"Miss Trina, please,"],[4029,4124,"let me help you with that."],[4124,4266,"Your father wants you to rest."],[4266,4446,"I'm fine, I love to bake."],[4487,4637,"Plus, it's nice to bake for people who"],[4637,4800,"are actually going to appreciate it."],[5221,5284,"Hey."],[5367,5430,"Sit."],[5484,5538,"Rest."],[5964,6026,"Rest."],[6861,6981,"I'll finish this."],[7069,7269,"Since when do you know how to bake?"],[7365,7515,"I was a chef in the Navy."],[7549,7749,"You'd be surprised at what I can cook."],[7753,7874,"Did I hit my head harder"],[7874,7978,"than I thought?"],[8062,8158,"Because this feels like"],[8158,8316,"it has to be a dream."]],"29":[[1455,1547,"Mateo,"],[1618,1760,"what are you doing here so late?"],[1789,1922,"You love the Aurora, right?"],[1993,2110,"Yes, but I-"],[2110,2227,"According to the tracker,"],[2327,2423,"there's a 99%"],[2423,2606,"chance we'll see it tonight."],[2640,2719,"Come on."],[2936,3015,"Okay, wait."],[3015,3061,"I'll hurry."],[3061,3148,"I'll change."],[3207,3253,"I'm serious."],[3253,3345,"I'll be fast."],[3390,3445,"I promise."],[3445,3561,"Let me change."],[4341,4446,"Fancy a late-night picnic"],[4446,4587,"under the Northern Lights?"],[4863,4934,"Wow, you really"],[4934,5038,"thought of everything."],[5125,5288,"You know, I'm normally the one that"],[5288,5388,"plans everything."],[5551,5709,"Not really used to this."]],"30":[[20,158,"Being taken care of?"],[246,371,"It's nothing."],[475,592,"It's all in the past."],[629,721,"You deserve someone who"],[721,850,"takes care of you, Trina."],[884,984,"That's not the line."],[2435,2656,"You finally came back."],[2702,3023,"I've waited for this day for so long."],[3541,3732,"Gosh, how long was I asleep?"],[3828,3983,"Why didn't you wake me?"],[5630,5789,"Oh, it's beautiful."],[5955,6114,"Just like you."]],"31":[[1547,1705,"How long has it been since I've given"],[1705,1839,"Trina a gift?"],[1872,1968,"When I had nothing,"],[1968,2135,"I gave her so much more."],[2515,2715,"I knew you'd regret this."],[2865,3169,"How many years did I watch Trina try and"],[3169,3378,"hold this family together?"],[3666,3883,"She did everything she could"],[3912,4083,"to make this house a home."],[4112,4241,"I know, I know."],[4275,4458,"She's the only one who didn't treat me"],[4458,4562,"like a burden."],[4592,4792,"She treated me better than Tania,"],[4921,5009,"my own daughter."],[5042,5251,"Grandma, she used to bassage your legs"],[5251,5338,"when they ached."],[5338,5434,"I remember."],[5497,5593,"You remember it now,"],[5618,5830,"but it never seemed like you did then."],[5855,6060,"And now I'm afraid it's too late."],[6206,6260,"No."],[6481,6577,"No, it's not."],[6635,6756,"Trina still loves me."],[6823,7015,"She's just...she's just mad at me."],[7086,7178,"That's all."]],"32":[[350,504,"Your call has been automatically"],[504,650,"forwarded to a voice message..."],[671,750,"Come on."],[784,1001,"Trina, listen to me, okay?"],[1038,1222,"Come on, just talk to me."],[1447,1547,"Please."],[2185,2239,"I need to file a"],[2239,2360,"missing persons report."],[2786,2894,"How long have they been missing?"],[2919,3023,"It's my wife."],[3057,3136,"She's been missing,"],[3136,3249,"I don't know, a week now."],[3249,3319,"I don't know."],[3319,3395,"She got pissed off"],[3395,3545,"because we planned a trip without her."],[3603,3749,"And then she filed for divorce."],[3766,3928,"Filed for divorce?"]],"33":[[0,116,"I found the papers when I got home."],[116,179,"Hold up."],[208,329,"Your wife left you."],[367,471,"Yes."],[471,617,"Filed for divorce?"],[692,784,"Yes."],[850,1017,"And she actually did it."],[1055,1197,"I told her if you don't shape up,"],[1217,1351,"I'm going to file for divorce."],[1351,1418,"And then she-"],[1418,1505,"Give me that."],[1539,1768,"If my husband ever told me to shape up,"],[1801,1922,"I'd probably leave him too."],[1951,2152,"Your wife isn't missing."],[2185,2306,"She left you."],[2464,2602,"No, I need to find her."],[2623,2690,"You don't understand."],[2719,2819,"You need to find her"],[2819,3007,"and make her come back."],[3136,3353,"Your wife is an adult"],[3353,3420,"who doesn't want to"],[3420,3511,"be married to you anymore."],[3511,3566,"We're not going to"],[3566,3666,"make her do anything."],[3687,3782,"Now get out of here"],[3782,3858,"before I make you"],[3858,4041,"sit in a cell to cool off."],[5000,5309,"Trina, you've gone too far this time."],[5342,5401,"This is it."],[5434,5584,"If you don't come back tomorrow"],[5584,5655,"immediately,"],[5730,5885,"never come back."]],"34":[[325,412,"Where were you?"],[437,513,"Never mind."],[542,629,"Let's just eat."],[1238,1280,"Oh!"],[1493,1597,"This tastes like something"],[1597,1764,"I'd pour out on a hobo's boot."],[1785,1881,"Get the maid in here."],[1960,2022,"Maid!"],[2097,2223,"Get this away from me!"],[2373,2448,"You're fired."],[2506,2548,"Get out."],[2590,2740,"And take this disgusting soup"],[2740,2794,"with you."],[2823,2994,"Sir, Ms. Donna made dinner tonight."],[3795,4066,"Trina would spend hours on every meal"],[4104,4320,"to make sure that we all were happy."],[4320,4404,"He's right."],[4529,4667,"I'm going to have the maid make us"],[4667,4738,"something else."],[4846,4921,"I want mommy."],[4942,5092,"I hate your disgusting soup."],[5192,5259,"I'm sorry."],[5955,6051,"Here we go."],[6068,6185,"I've been cooking it all day."],[6185,6272,"I hope you love it."],[6923,6973,"Not bad."],[7382,7499,"I'm such an asshole."],[7707,7853,"Trina did so much."],[7907,8124,"How could I ignore everything she did?"]],"35":[[379,546,"Tonight, Jackson had another of his"],[546,642,"infamous parties."],[767,871,"I'm always so proud of him."],[946,1126,"So many people love him and want to be"],[1126,1226,"around him, but..."],[1305,1501,"He just always drinks too much."],[1689,1760,"None of them ever"],[1760,1906,"gave a damn about me."],[1926,2068,"I tried to tell him drinking so much"],[2068,2152,"was bad for him."],[2231,2323,"I want him to be around"],[2323,2398,"for a long time,"],[2398,2548,"but he just gets so mad."],[2602,2719,"So I stopped bothering him."],[2998,3094,"I should never have been"],[3094,3174,"such a jerk."],[3224,3269,"I know I'm not the"],[3269,3399,"wife he deserves."],[3399,3532,"I, I can try harder to be"],[3532,3620,"the wife he wants."],[3757,3887,"I should have appreciated you"],[3887,3962,"when I had you."],[4008,4112,"I know he doesn't mean it"],[4112,4245,"when he calls me names."],[4245,4383,"And I know I embarrass him"],[4383,4441,"at parties,"],[4441,4621,"but I just love him so much and I just"],[4621,4708,"want him to be happy."],[4788,4900,"I'm gonna be the best mother"],[4929,5080,"and wife I can be for Jackson"],[5105,5163,"and for Zane."],[5480,5605,"I know you love me, Trina."],[5693,5818,"You just love me too much."],[5926,6022,"You'd die for me,"],[6135,6202,"wouldn't you?"]],"36":[[913,1055,"So what are you gonna do now?"],[1313,1363,"I..."],[1447,1659,"am going to finish this bottle."],[2648,2748,"She left me."],[2840,2894,"She"],[2990,3032,"left"],[3082,3157,"me!"],[3182,3336,"Hey man, now you can,"],[3336,3432,"you know, like,"],[3532,3699,"get rid of her like you wanted, right?"],[3878,3953,"What does that mean?"],[4020,4095,"Like I wanted?"],[4137,4325,"I mean, you got that hot piece of ass."],[4325,4396,"What's her name?"],[4475,4550,"Debbie."],[4575,4637,"No!"],[4696,4775,"Donna."],[4842,4975,"Yeah, you're gonna marry Donna,"],[4975,5025,"aren't you?"],[5071,5226,"Shut your face"],[5226,5351,"before I shut it for you."],[5417,5459,"Got it?"],[5543,5693,"I never want..."],[5764,5822,"Bartender!"],[5864,5935,"Another bottle!"],[6101,6352,"I never wanted to lose Trina."],[6393,6610,"Yeah, I got it."],[7332,7444,"She used to take care of me"],[7444,7532,"when I drank too much."],[7586,7720,"If I needed her, she was there."],[7816,7970,"She's gotta come back."],[7970,8091,"She's gonna feel sorry for me."],[8149,8204,"She'll come back."],[8270,8362,"She has to."]],"37":[[2577,2719,"Good thing I bought two."],[5163,5217,"There."],[5313,5367,"All better."],[5409,5534,"See, Trina?"],[5588,5651,"That's better."],[5689,5780,"It's gonna be all..."],[6289,6356,"Trina."],[6356,6427,"Shh."],[6523,6569,"I'm here."],[6698,6815,"I'll take care of you."],[7027,7115,"Trina."],[7340,7474,"Just come home, Trina."],[8408,8541,"When is he going to dump"],[8579,8696,"that bitch for good?"],[8983,9192,"Jackson is mine."],[9263,9380,"I'm going to make sure"],[9380,9517,"he stays that way."]],"38":[[95,225,"Dad, I want to take over the company."],[321,517,"I turned my back on your advice and left"],[517,646,"everything behind for Jackson,"],[646,709,"and I regret it."],[809,934,"So please, if you have any faith"],[934,1009,"left in me, just..."],[1151,1226,"Let me back in."],[1372,1505,"I've always wanted you to"],[1505,1630,"follow in my footsteps."],[1735,1785,"But if you're going to"],[1785,1881,"take over the company,"],[1956,2047,"there's one condition."],[2260,2314,"What is it?"],[2456,2531,"Mateo."],[2711,2773,"What about him?"],[2794,2940,"I want you to marry him."],[2994,3128,"Dad, what are you talking about?"],[3128,3274,"You've been gone too long."],[3274,3390,"I trust you."],[3390,3528,"But the board won't."],[3566,3674,"If you're going to come back,"],[3674,3766,"you need someone to help you"],[3766,3883,"stand your ground."],[3941,4195,"Mateo is already a rising star in tech,"],[4220,4346,"with him at your side."],[4487,4587,"Those old men at the board,"],[4587,4708,"well, they won't know what to do."],[4742,4917,"But Dad, I just got divorced."],[4917,5038,"You really expect me to just"],[5038,5159,"jump into another marriage?"],[5196,5347,"What are you hesitating for?"],[5417,5555,"Is it because of Jackson?"],[5772,5818,"I think"],[5851,6081,"you may want to see today's news."],[6081,6239,"In business news today,"],[6239,6352,"Jackson De La Torre,"],[6352,6552,"CEO of De La Torre Enterprises,"],[6552,6698,"has announced his engagement"],[6719,6852,"to longtime business partner"],[6852,6923,"Donna Reed."]],"39":[[12,179,"Trina, you okay?"],[387,538,"Trina, where are you?"],[550,688,"I've been looking for you."],[688,779,"Please come home."],[829,955,"So this is what you meant by"],[955,1055,"looking for me?"],[1117,1192,"Desperate to find me"],[1192,1376,"yet planning another wedding all along."],[1484,1539,"Trina."],[1693,1768,"Are you okay?"],[2185,2352,"I'm better than I've ever been."],[2352,2448,"Trust me,"],[2448,2690,"Mateo is a good man."],[2690,2798,"He's been by my side"],[2798,2936,"all these years, just"],[3007,3140,"waiting for you."],[3253,3411,"He'll treat you well."],[3582,3611,"Dad,"],[3749,3816,"I'm fine."],[4004,4225,"Please make your old man happy."],[4408,4479,"Take your time,"],[4579,4842,"but at least consider the possibility of"],[4842,4975,"marrying Mateo."],[4975,5121,"I don't need time to consider it."],[5309,5384,"I'll marry him."],[5668,5818,"Finally, I'm reborn."],[5922,5955,"Trina,"],[6022,6168,"this time do whatever you want"],[6218,6281,"for yourself."]],"40":[[25,83,"I'll marry him."],[529,663,"I will start making arrangements"],[663,771,"right away."],[771,959,"Mateo's business is headquartered"],[959,1046,"in New York."],[1046,1172,"You'll have the wedding there."],[1226,1309,"Yeah."],[1655,1772,"Jackson De La Torre,"],[1772,1972,"CEO of De La Torre Enterprises,"],[1972,2102,"has announced his engagement."],[2214,2369,"Donna, what the fuck?"],[2423,2556,"Did you leak that story"],[2556,2635,"to the gossip sites?"],[2686,2777,"I, um..."],[2802,2973,"We are not engaged."],[3140,3182,"Babe,"],[3294,3349,"you're just"],[3420,3595,"so worried about Trina being missing"],[3595,3753,"for so long, right? And..."],[3782,3941,"I made the engagement public"],[4016,4099,"to make her jealous."],[4183,4329,"To force her to come home."],[4358,4433,"Make her jealous?"],[4521,4629,"Force her to come back?"],[4792,4938,"She's not even answering my calls."],[5038,5146,"Maybe..."],[5192,5321,"try calling her again."]],"41":[[221,387,"I married Jackson at the courthouse in a"],[387,471,"thrift store dress."],[525,684,"No reception, no honeymoon,"],[742,884,"just a marriage certificate."],[950,1009,"And now..."],[1046,1205,"Mateo has given me everything"],[1205,1326,"I used to dream about."],[2127,2293,"Jackson, what do you want?"],[2435,2506,"You, you answered."],[2673,2765,"When are you coming home?"],[2786,2948,"I'll be back at the end of the week."],[3211,3257,"It's working."],[3357,3436,"She's really jealous."],[3570,3632,"I knew"],[3632,3737,"Trina would come back to me."],[3824,3970,"She didn't really want a divorce."]],"42":[[20,141,"I knew she didn't want a divorce."],[204,275,"When she gets back,"],[304,421,"I'm making big changes"],[421,471,"around here."],[521,608,"I'm going to treat her much,"],[650,713,"much better."],[742,796,"Zane!"],[829,934,"Mom's coming back."],[971,1042,"Wait, I've got something-"],[1292,1518,"I'm going to take everything from you."],[1626,1710,"Your husband,"],[1772,1847,"your son."],[1885,2039,"Zane, what are you up to?"],[2147,2248,"Mommy's coming home