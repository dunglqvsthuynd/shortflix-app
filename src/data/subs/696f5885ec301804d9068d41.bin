{"1":[[0,141,"The top courtesan, Valerie,"],[160,318,"is about to perform in the palace."],[318,459,"Once she catches a nobleman's eye,"],[470,686,"we'll be in different worlds."],[721,890,"This drum dance will be her final performance"],[890,1006,"for you."],[1019,1159,"Bravo!"],[2076,2226,"This is the top courtesan's final drum dance"],[2251,2394,"outside the palace."],[2426,2560,"Even if it costs a fortune,"],[2578,2633,"it's worth it!"],[2772,2862,"Bravo!"],[2907,2998,"Bravo!"],[3092,3180,"What a beautiful dance!"],[3332,3538,"To feast our eyes before His Majesty does,"],[3547,3805,"this opportunity is once in a lifetime!"],[4042,4107,"Mother,"],[4132,4357,"why did we leave in such a hurry?"],[4384,4542,"We didn't even bring a single servant."],[4603,4885,"Did we make some enemies?"],[4947,5097,"What nonsense are you talking about?"],[5347,5393,"Hubby!"],[5471,5560,"Father!"],[5646,5796,"Hubby!"],[5847,5982,"Father!"],[6271,6352,"Take this."],[6407,6618,"Run!"],[6645,6728,"Now!"],[6728,6804,"My Lord!"],[6835,7043,"Run! Go, quickly!"],[7151,7300,"Run!"],[7979,8057,"Get inside."],[8428,8501,"Clara,"],[8568,8750,"survive on your own."],[8802,9102,"Never try to avenge us."],[9164,9335,"Live a good life!"],[9625,9725,"Why?"],[9725,9851,"The David family's wealth rivals the nation."],[9875,10062,"My parents have always been loyal."],[10204,10316,"Boss, she jumped into the river."],[10332,10442,"It doesn't matter if she's dead,"],[10442,10542,"fish her out!"],[10543,10643,"The Imperial Guard?"],[10692,10792,"It was the Emperor."],[10897,11042,"Every time the court needed emergency funds,"],[11061,11195,"we gave everything we had"],[11202,11276,"without a second thought."],[11279,11330,"Why?"],[11377,11554,"Why did he kill my family?"],[12222,12322,"To hell with the Emperor!"],[12355,12497,"I'll make you pay with blood!"]],"2":[[1233,1330,"Quiet."],[1330,1446,"I won't hurt you."],[2587,2663,"You're injured."],[2730,2789,"Yes."],[2789,2935,"Luckily, it didn't hit any vital organs."],[5950,6102,"I saw him run into this courtyard."],[6121,6246,"He's around."],[6270,6385,"Search every room."],[7385,7426,"Let's go."],[7854,7940,"What's wrong?"],[8790,8881,"Oh no."],[8915,9173,"The women in this building are jealous of me."],[9198,9376,"Making me lose my virginity before the performance."]],"3":[[3865,4000,"My ankle."],[4079,4325,"They really spared no expense."],[4361,4542,"Where did they find such a potent drug?"],[4797,4906,"My virginity mark is gone."],[5129,5228,"No matter what,"],[5264,5434,"I can't let this opportunity slip away."],[6987,7051,"Just great."],[7076,7359,"You just slept with the Emperor and ghost!"],[7535,7604,"Come in."],[7684,7740,"Your Majesty,"],[7740,7807,"I had a lead."],[7815,7864,"Eight years ago,"],[7864,7981,"someone found"],[7987,8101,"Mr. and Mrs. David's bodies by the river."],[8109,8270,"But Miss David is still missing."],[8295,8365,"Find her."],[8439,8466,"Yes, Your Majesty."],[8565,8618,"Wait."],[8879,9148,"Find the woman in this room last night."],[9206,9231,"Yes."]],"4":[[264,454,"Your features are good."],[498,590,"Pass."],[1159,1343,"This mole is unlucky."],[1408,1503,"Madam."],[1671,1744,"Please look again."],[1760,1930,"A master checked this mole."],[1987,2092,"It brings luck."],[2226,2371,"I made a mistake."],[2387,2528,"It's a lucky mole."],[2571,2646,"Pass."],[2767,3017,"I spent all my savings to enter the palace."],[3039,3267,"But I still have so many tests to go through."],[3638,3792,"Your appearance is proper,"],[3810,3964,"neither good nor bad."],[4057,4138,"Pass."],[4165,4225,"Alright."],[4260,4547,"Those who didn't pass leave."],[4600,4750,"Everyone else, stay."],[5075,5160,"Strip."],[5675,5800,"You, out."],[5979,6082,"Out."],[7028,7201,"This virginity mark…"],[7359,7468,"It's fake."],[7620,7714,"Madam, please look again."],[7723,7835,"I wouldn't fake it."],[7906,8057,"I painted it with waterproof dye."],[8093,8215,"She shouldn't be able to tell."],[8271,8601,"It lacks something, you know?"],[8837,9051,"His Majesty has arrived."],[9106,9287,"Greetings, Your Majesty."],[9872,9972,"I've finally found you."]],"5":[[225,362,"They all look fine."],[383,601,"Skip the final test."],[740,816,"Keep them all."],[882,938,"Yes, Your Majesty."],[1048,1306,"This woman has a well-proportioned figure."],[1330,1477,"I assume she could dance."],[1503,1721,"Appoint her as a dancer,"],[1737,1942,"and make her the lead."],[2019,2098,"Thank you, Your Majesty."],[2628,2819,"I bet he's a lustful tyrant!"],[2871,3155,"He killed my parents back then!"],[3406,3475,"What?"],[3507,3667,"His Majesty personally selected a dancer?"],[3679,3825,"Yes, that's right."],[3839,4129,"That woman looks like a total vixen."],[4134,4296,"I wanted to eliminate her."],[4314,4542,"But His Majesty asked her to stay."],[4552,4970,"He even appointed her as the lead dancer."],[5411,5520,"His Majesty is kind."],[5550,5810,"He takes pity for everything."],[5828,5965,"Watch her closely."],[5978,6243,"Don't let her forget her place."],[6267,6409,"Rest assured, my ladies."],[6409,6581,"I have the situation under control."],[7579,7657,"Are we"],[7698,7801,"staying here?"],[7870,8065,"The Grace Pavilion"],[8079,8226,"has always been the lead dancers' home."],[8258,8514,"They lived within these walls until their death."],[8514,8657,"Death?"],[8678,8837,"Is this place haunted?"],[8898,8948,"Afraid of ghosts?"],[8962,9129,"I guess the palace is not your place."],[9290,9406,"We have a tyrant on the throne."],[9457,9778,"Who knows how many innocent lives have been lost?"]],"6":[[580,746,"Are you done crying?"],[1169,1248,"Get to work."],[1269,1382,"You won't be scared if you keep busy."],[2466,2535,"Bravo!"],[2616,2719,"Right on target!"],[2721,2837,"She's interesting."],[2837,2978,"I like her."],[2992,3092,"Reward her."],[3114,3189,"Your Majesty,"],[3211,3400,"what reward do you have in mind?"],[3401,3490,"How about"],[3503,3702,"that pair of tribute Luminous Pearls?"],[3713,3833,"They should be worthy of her."],[3955,4027,"Your Majesty,"],[4043,4217,"I know you are generous,"],[4221,4489,"but the Luminous Pearls"],[4489,4714,"are reserved for Consorts or higher."],[4742,4929,"Giving them to her is against the rules."],[5067,5182,"What's the difficulty?"],[5266,5430,"After the All-Nations Banquet,"],[5442,5746,"I'll make her a Consort, then reward her."],[5975,6039,"Go arrange it."],[6071,6125,"Yes."],[6274,6435,"We've already slept together."],[6449,6609,"I'm entitled to compensate her, right?"],[6707,6987,"People always send gifts to each other."],[7026,7165,"Now that she's received my reward,"],[7181,7293,"she must be planning"],[7328,7511,"to give me something in return."],[7616,7704,"Oh my god,"],[7721,7883,"these Luminous Pearls are huge!"],[7887,7976,"Valerie,"],[7976,8120,"do you think the Emperor wants to"],[8154,8245,"make you a Consort?"],[8264,8359,"I bet he is."],[8454,8534,"Who cares?"],[8754,8965,"I only entered the palace to take his life."],[8965,9095,"If he makes me a Consort…"],[9095,9207,"Bast*rd."],[9207,9351,"The day I serve him in bed"],[9387,9518,"will be the day he dies."]],"7":[[0,124,"The Grace Pavilion is small."],[124,296,"I couldn't practice without"],[296,413,"Beryl and Sylvie watching me,"],[413,591,"so I had to practice outside."],[916,1066,"I didn't mean to bump into you, sir."],[1075,1188,"Please forgive me."],[1409,1524,"It's you."],[1642,1832,"You're a palace guard?"],[1928,2117,"She doesn't know who I am?"],[2128,2176,"What?"],[2183,2316,"Do I not look like one?"],[2355,2751,"You've clearly slept with me."],[2769,2914,"How did you enter the palace?"],[2983,3238,"Both palace maids and dancers"],[3252,3435,"are required to be virgins."],[3435,3532,"That virginity rule"],[3552,3806,"is to provide His Majesty with exclusive playthings."],[3834,3974,"But why?"],[3982,4192,"His Majesty has a massive harem"],[4207,4291,"and sleeps around."],[4297,4414,"Is he a virgin?"],[4620,4743,"Who says I sleep around?"],[4824,5064,"I've never slept with any Consort."],[5260,5370,"I'm warning you,"],[5371,5447,"stay away from me."],[5452,5602,"You'd better pretend we're strangers."],[5615,5735,"This is for your own good."],[5756,5893,"For my own good?"],[5900,5978,"What do you mean?"],[6011,6207,"Do you want to be a Consort that badly?"],[6207,6315,"Who cares?"],[6324,6443,"You don't care?"],[6551,6684,"That's odd"],[6707,7054,"Then why did you enter the palace?"],[7201,7311,"Could it be…"],[7958,8008,"Are you here"],[8095,8154,"for me?"],[8514,8648,"You're insane."],[8665,8865,"Why on earth should I meet you?"],[8878,8992,"I'm warning you,"],[9002,9126,"stay away from me."],[9235,9287,"You!"],[9776,9876,"That was close."],[9940,10055,"I almost got caught."]],"8":[[846,906,"Done."],[906,1033,"On the day of the performance,"],[1083,1325,"this dart will land right in that Emperor's neck."],[1325,1396,"Your Majesty."],[1778,1844,"Your Majesty."],[1844,1921,"Have you forgotten?"],[1932,2001,"Back then,"],[2001,2183,"we pledged our love right under this tree."],[2312,2482,"You were a Prince in the Cold Palace,"],[2482,2569,"and I was just a palace maid."],[2569,2778,"But we still beat all odds to be together."],[2798,2962,"All the vows we made…"],[2971,3209,"Now you won't even come back for it."],[3228,3315,"His back"],[3338,3434,"looks so familiar."],[3797,3889,"I don't come here often"],[3907,4046,"because I'm busy with state affairs."],[4064,4234,"You seem idle enough."],[4253,4475,"But I don't think you've come back often."],[4557,4656,"This tree looks like"],[4674,4765,"it's about to die."],[4821,4915,"Not at all!"],[4928,5052,"I come here all the time."],[5052,5239,"Your Majesty no longer loves me"],[5247,5382,"and the tree lost its vitality."],[5382,5585,"Once you've lost all your love for me,"],[5585,5788,"I'm afraid I'll wither away"],[5875,6043,"just like this tree."],[6271,6367,"I see."],[6401,6640,"I'll visit you more often in the future."],[6650,6701,"Okay?"],[7257,7362,"So heartless!"],[7392,7528,"If he could be this ruthless to his Consort,"],[7557,7818,"no he had the heart to kill my parents."],[7834,7920,"No one is around."],[7920,8006,"I should kill him now!"],[8006,8159,"This is my chance for revenge!"]],"9":[[100,162,"Your Majesty!"],[176,312,"I've finally found you."],[432,491,"What?"],[583,632,"My love,"],[640,748,"I have state affairs to attend to."],[759,858,"Get yourself busy"],[864,980,"and water this tree sometimes."],[980,1201,"Hopefully, it'll be healthy next time."],[2037,2128,"Derrick."],[2187,2271,"Yes."],[2380,2555,"Can you come earlier next time?"],[2594,2714,"I just thought"],[2733,2873,"you haven't seen each other in a while."],[2907,3114,"You might have some intimate words to share."],[3126,3302,"What if I had interrupted you?"],[3303,3397,"Shut up."],[3397,3578,"Back then, she deliberately came to the Cold Palace,"],[3578,3703,"showing some fake care for me."],[3710,3860,"If I didn't marry her after I took the throne,"],[3860,3997,"I would look like a disloyal Emperor."],[4011,4147,"She's so scheming,"],[4189,4342,"what would I have to say to her?"],[4364,4425,"Understood."],[4434,4564,"I'm sorry."],[4593,4647,"Your Majesty,"],[4682,4765,"where are we going next?"],[5056,5224,"Grace Pavilion."],[5303,5378,"Yes."],[5834,6138,"That Noble Consort might really water this tree"],[6138,6260,"like that Emperor said."],[6274,6400,"This place isn't safe anymore."],[7276,7326,"Greetings, Mr. Cury."],[7331,7421,"Please don't."],[7479,7609,"You should show him…"],[8112,8301,"How come I meet him every time I carry a weapon?"],[8356,8478,"The Emp…"],[8787,8876,"I mean, what a coincidence."],[8914,9035,"I was looking for you."],[9062,9143,"Why?"],[9365,9395,"Here."],[9421,9540,"You injured your foot because of me."],[9545,9697,"This works well. It's an imperial medicine."],[9730,9852,"I don't need it."],[9997,10065,"Keep it."],[10074,10298,"You're dancing in front of the Emperor,"],[10298,10449,"there can't be any mistakes."],[10458,10594,"Find me the best gardener."],[10611,10735,"And go to the Cold Palace every day."],[10748,10804,"Yes."]],"10":[[171,255,"I'll take it."],[356,448,"Are you..."],[466,516,"I'm available."],[533,575,"Huh?"],[828,999,"I know you want to thank me."],[1016,1179,"I'm always available."],[1183,1433,"You've been slacking off as a palace guard."],[1437,1562,"You should get back to work."],[1583,1695,"Duties are waiting."],[1712,1845,"Thanks for the medicine."],[2562,2637,"Your Highness,"],[2654,2804,"that's the little hussy"],[2816,2975,"who seduced His Majesty the other day!"],[2979,3070,"Her?"],[3091,3187,"I see."],[3200,3579,"So this is His Masjesty's urgent state affairs, huh?"],[3608,3666,"Should I"],[3683,3941,"hire a couple of guys to get rid of her?"],[4029,4100,"Not so fast."],[4150,4366,"She is a lead dancer at the All-Nations Banquet."],[4400,4675,"If she missed a few moves at such an occasion,"],[4695,4900,"no one could save her *ss!"],[6320,6512,"Xialand is a vast nation,"],[6521,6770,"with peerless beauties and graceful dancers."],[6791,7158,"Why don't they compete dancers from our Westland?"],[7162,7387,"I don't mind a little competition."],[7400,7687,"What's the wager, Mr. Envoy?"],[7700,7945,"We'll wager on one year's tribute."],[7958,8112,"Betting tribute on dancers?"],[8162,8320,"That's simply ridiculous."],[8337,8404,"What?"],[8408,8655,"Are you scared of losing to Westland?"],[8679,8737,"Nonsense!"],[8766,8854,"Andrew,"],[8883,8966,"no need for this."],[9012,9104,"It's a banquet,"],[9116,9266,"let's liven it up."],[9295,9400,"However,"],[9407,9679,"one year's tribute is indeed a bit too much."],[9762,9850,"Are you scared?"],[9862,9920,"Let's say"],[9979,10154,"ten years' tribute!"],[10187,10308,"If you win,"],[10334,10500,"you'll be exempt for ten years."],[10550,10670,"Otherwise,"],[10708,11004,"the tribute doubles for the next ten years."],[11653,11722,"Good!"],[12066,12187,"I'm Princess Laila of Westland."],[12203,12337,"I'll do a Goblet Dance."],[12683,12812,"In that case,"],[12845,12966,"let the battle begin."],[13033,13183,"The Emperor's voice..."]],"11":[[16,166,"The Emperor's voice..."],[170,275,"Wasn't it just a performance?"],[279,391,"Why a sudden bet?"],[406,485,"If we lose,"],[496,642,"I'm afraid we'll all lose our heads."],[688,759,"Don't panic."],[813,945,"We won't lose."],[982,1103,"What a tyrant!"],[1136,1224,"He bets state affairs"],[1236,1454,"on a simple dance competition!"],[1466,1570,"This is absurd."],[1587,1808,"Only his death can atone to the people."],[3291,3391,"I've never seen"],[3415,3695,"someone so light and graceful in this world."],[3715,3937,"Dancing on a tiny goblet."],[4271,4496,"Can anyone accept the challenge?"],[4675,4925,"I think the people of Xialand are bluffing."],[4929,5145,"Your dance can't measure up to Westland."],[5154,5312,"Not only will the annual tribute stop,"],[5316,5645,"but Xialand should be the one tribute to us!"],[5650,5725,"That's right!"],[5750,5845,"Just admit defeat!"],[5978,6044,"I'll dance."],[6216,6362,"Just as I thought."],[6370,6504,"Dear Envoys,"],[6516,6604,"you speak too soon."],[6629,6925,"Just watch the grace of Xialand's premier dancer."],[8558,8633,"Oh no,"],[8637,8758,"my shoes have been tampered with."],[10716,10841,"Conquering strength with softness,"],[10899,11020,"her movements are exquisite."],[11079,11341,"This is the majesty of our great Xialand!"]],"12":[[175,229,"Bravo!"],[233,491,"As expected of our number one dancer!"],[495,541,"How dare you!"],[554,683,"Do you know how precious this jade goblet is?"],[700,795,"It's just a goblet."],[800,979,"Xialand is full of treasures like that."],[983,1237,"Take some back if you want. You're welcome."],[1266,1329,"Yeah."],[1374,1428,"Karim,"],[1446,1537,"it's just a goblet."],[1563,1621,"Right now,"],[1628,1908,"your focus should be on the tribute, not that."],[1920,2024,"You lost."],[2287,2383,"Wait."],[2641,2712,"Look."],[3181,3227,"Your Majesty,"],[3236,3429,"blood is an ominous sign at the banquet."],[3433,3533,"Emperor of Xialand,"],[3537,3691,"this dance has stained the All-Nations Banquet."],[3695,3858,"She risks angering the gods."],[3866,3950,"It's a terrible omen!"],[3954,4037,"Yes, Your Majesty."],[4041,4216,"For the sake of our nation,"],[4220,4445,"you have to execute her!"],[4508,4816,"Your Majesty, please execute Valerie!"],[4999,5131,"Somebody draft the decree."],[5283,5329,"Your Majesty,"],[5345,5483,"to display the might of Xialand,"],[5504,5754,"I used my blood to paint the map of our nation."],[5800,5912,"Please don't punish me."],[5920,5991,"Good!"],[5995,6328,"Valerie, you're a talented and loyal woman."],[6332,6469,"You deserve a reward."],[6704,6770,"You tyrant."],[6787,6991,"Once I can get close to him,"],[6995,7125,"I'll have the chance to slay him."],[7154,7285,"Dancer Valerie,"],[7293,7481,"step forward to receive your title."],[7508,7579,"No way!"],[7637,7729,"I succeeded."],[8037,8172,"Father, Mother,"],[8175,8279,"you won't have died in vain."],[8287,8462,"I'm going to avenge!"]],"13":[[667,742,"Our country is in peril,"],[758,895,"thank you for donating food, Mr. David."],[904,1000,"You're welcome, sir."],[1004,1212,"Nothing matters more than our country."],[1266,1491,"The Emperor does deserve to die,"],[1495,1704,"but not in front of the troublemaking envoys."],[1900,2012,"Thank you, Your Majesty."],[2058,2162,"Dancer Valerie,"],[2195,2400,"known for your grace, good character,"],[2466,2741,"exquisite dance and courage,"],[2745,2887,"is appointed as Lady Valerie, a Consort."],[2916,3183,"Flora Palace is yours."],[3187,3291,"It's disgusting."],[3295,3466,"But at least I have a chance to slay the Emperor."],[3500,3593,"Thank you, Your Majesty."],[3700,3783,"Alright."],[3787,4058,"This banquet is about done."],[4062,4145,"Envoys,"],[4150,4433,"looking forward to ten years of your double tribute."],[4912,5029,"Please show mercy!"],[5037,5100,"What?"],[5104,5237,"You're backing out?"],[5250,5341,"With double tribute,"],[5345,5475,"I'll be dead when I return."],[5479,5604,"Please show mercy."],[5620,5795,"I'll marry you"],[5800,5966,"if you reduce the tribute."],[6012,6129,"You wish!"],[6150,6320,"You can't have all the benefits, you know?"],[6600,6862,"But for the sake of our friendship,"],[6866,6975,"I have an idea."],[7020,7175,"There's no need to marry me."],[7179,7329,"You can stay and replace Valerie"],[7329,7516,"as the lead dancer."],[7525,7700,"Then I won't double the tribute."],[7800,7854,"What do you say?"],[7862,7970,"Thank you!"],[7983,8070,"Thank you, Your Majesty."]],"14":[[300,516,"You're a Consort now, huh?"],[608,737,"Why are you always in my place?"],[766,850,"Aren't you on duty now?"],[966,1079,"Why are you so nervous?"],[1262,1458,"Trying to distance yourself from me already?"],[1614,1718,"You're sulking."],[1750,1933,"Aren't you happy to be a Consort?"],[2191,2366,"How could I not be happy?"],[2417,2612,"In fact, I'm dying of joy."],[2623,2714,"Are you truly happy?"],[2741,2795,"Of course."],[2858,3016,"I'm the one who's really dying."],[3037,3112,"What?"],[3129,3200,"Nothing."],[3229,3333,"Get back to work."],[3345,3425,"I need a bath."],[3516,3541,"Alright."],[3783,3850,"She's happy about it."],[5891,5979,"I'm Lena, your maid."],[5987,6125,"Congrats on serving His Majesty tonight."],[7641,7725,"Sister,"],[7729,7870,"well played, huh?"],[7875,8033,"Sister, what do you mean?"],[8037,8141,"Some people"],[8154,8295,"are born lowly."],[8309,8529,"They lack some luck to serve His Masjesty."]],"15":[[0,175,"The harem is so treacherous."],[233,475,"Someone's already murdering me before I serve him."],[516,754,"If I don't make a comeback, they'll keep pushing me!"],[773,894,"I might fail to get my revenge"],[904,1129,"and end up becoming a Consort in the Cold Palace."],[1150,1241,"It's very likely."],[1283,1358,"My Lady."],[1512,1620,"Don't be afraid."],[1625,1716,"It's not your fault."],[1870,2098,"I promise I'll protect you in the future."],[2191,2486,"A dancer's room is much larger than my home."],[2670,2766,"Why are you here?"],[2850,2975,"I'm the new lead dancer now,"],[2979,3154,"which means this place is mine."],[3166,3400,"You've become a new Consort."],[3429,3520,"Why haven't you moved out yet?"],[3537,3616,"She's ill."],[3620,3733,"We're just staying temporarily."],[3870,4183,"I guess it's not easy to be a Consort in Xialand."],[4198,4422,"Might as well be a dancer, it's free."],[4433,4645,"You're a Princess in a foreign land,"],[4650,4704,"serving as a dancer."],[4725,4816,"Doesn't that upset you?"],[4825,4920,"In Westland,"],[4941,5100,"be it a princess or a beggar,"],[5108,5245,"marriage is the only way out."],[5262,5516,"Who knows when you'll be married off"],[5558,5708,"to build a political alliance?"],[5762,5862,"But in Xialand,"],[5866,6079,"the climate is mild and life is stable."],[6116,6220,"Under His Majesty's rule,"],[6254,6370,"people are living a peaceful life."],[6404,6512,"This is already"],[6542,6762,"the best way out for me."],[6775,6900,"Peaceful life?"],[6925,7279,"Then why did he murder my whole family?"],[7458,7541,"What's that smell?"],[7862,8008,"Why do you have camel wood powder?"],[8062,8141,"Camel wood powder?"],[8258,8629,"It's ground from a plant that grows in the desert."],[8675,8787,"It's used to repel insects,"],[8825,8987,"but if it gets on your face,"],[9066,9166,"you'll get rashes."],[9374,9466,"The desert…"],[9503,9678,"That's where Iris's brother is stationed."],[9837,9929,"It was her."],[9966,10029,"Valerie."],[10033,10112,"I heard you…"]],"16":[[358,433,"What happened to you?"],[494,728,"Xialand is supposed to be conservative."],[779,1033,"Men and women should keep their distance."],[1387,1512,"He called you by your first name."],[1525,1658,"Is he your lover?"],[1708,1791,"Nonsense!"],[1797,2000,"Lady Valerie was personally appointed by His Majesty."],[2196,2404,"We're just acquaintances."],[2581,2644,"Lady Valerie,"],[2712,2841,"His Majesty heard you can't serve him"],[2862,2966,"and was worried."],[2970,3045,"He wanted me to visit you."],[3179,3266,"If he does care,"],[3304,3562,"will he avenge Lady Valerie?"],[3612,3695,"Someone is murdering her!"],[3766,3816,"Lady Valerie,"],[3891,3991,"who could be so evil?"],[4037,4133,"Who ruined my night?"],[4175,4295,"I think I know who it is."],[4370,4495,"Since she came to provoke me,"],[4512,4687,"I'm not gonna suck it up like a coward."],[4691,4858,"She's feisty. I like that."],[4862,4937,"Who is it?"],[5116,5162,"Lady Iris."],[5508,5712,"Lady Iris is gentle and kind."],[5729,5870,"How could she murder Valerie?"],[5908,6062,"Was it a misunderstanding?"],[6976,7066,"Come help me"],[7079,7195,"put on this hairpin."],[7287,7525,"Let me help you touch up your makeup first."],[7785,7873,"Palace guards!"]],"17":[[100,208,"Palace guards!"],[250,325,"My Lady!"],[391,483,"She's so feisty."],[529,658,"No matter how gentle Iris is,"],[712,829,"she won't swallow this insult."],[1070,1137,"How dare you?"],[1175,1337,"What did you use on me?"],[1408,1670,"The power you gave me."],[1741,1862,"It's good."],[1866,1987,"I want to share it with you."],[2029,2095,"What?"],[2125,2287,"That's poison!"],[2408,2470,"What?"],[2520,2629,"Iris did poison her!"],[2770,2904,"My Lady, your face!"],[3104,3175,"You b*tch!"],[3212,3308,"How dare you poison me?"],[3332,3400,"Hold her down."],[3416,3545,"Beat her until I see flesh!"],[3554,3675,"So shrewish!"],[3700,3862,"Is this still the Iris I know?"],[3891,4162,"Was all her gentleness a fake act?"],[4241,4416,"We are both Consorts of equal rank."],[4420,4541,"I'd like to see you try!"],[4554,4654,"So what if we hold the same rank?"],[4658,4841,"You're nothing but a lowly dancer,"],[4854,5012,"whereas I'm the daughter of the Minister of Rites."],[5070,5120,"What?"],[5191,5333,"The daughter of the Minister of Rites"],[5337,5433,"murdering an imperial Consort?"],[5441,5558,"Lady Iris,"],[5562,5633,"are you trying to"],[5700,5841,"drag your father down with you?"],[6008,6058,"You!"],[6133,6187,"What are you waiting for?"],[6220,6312,"Tear her mouth to shreds!"],[6370,6433,"If anything happens,"],[6437,6525,"I'll take full responsibility!"],[6762,6866,"I'd like to see who dares!"],[6933,7000,"Who are you?"],[7420,7533,"No wonder you're so bold."],[7558,7766,"You're already sleeping with a palace guard."],[7787,8004,"Defiling the harem with such audacity!"],[8020,8166,"I'll let His Majesty know!"],[8600,8712,"Save it, Lady Iris."],[8733,8879,"His Majesty ordered me"],[8886,9036,"to protect Lady Valerie."],[9195,9250,"But she…"],[9379,9483,"No way."],[9504,9600,"She hasn't served him yet."],[9633,9891,"Why would he protect her?"],[10208,10287,"I know."],[10312,10562,"You've been having an affair"],[10600,10683,"and lying to His Masjesty!"],[10704,10870,"You need to be executed right here, right now!"],[10879,10945,"Palace guards!"]],"18":[[75,145,"Lady Iris."],[220,445,"These two have been cheating on His Masjesty."],[466,579,"Execute them, now!"],[629,762,"I'll tell His Majesty later."],[829,870,"Yes!"],[941,1020,"Yes?"],[1123,1212,"Luke."],[1245,1387,"Lady Iris may not know the rules,"],[1403,1508,"but you sure do, right?"],[1566,1787,"Who says you can execute someone without reporting?"],[1839,1991,"It's His Majesty's voice."],[2372,2462,"- Your Maj… - Mind your business!"],[2687,2775,"Open your eyes"],[2779,2862,"and look closely."],[2866,3050,"This is the newly appointed Consort, Lady Valerie."],[3054,3166,"Is she someone you can execute?"],[3250,3362,"Greetings, Lady Valerie."],[3633,3729,"Take your guys out."],[3800,3854,"Yes, yes."],[3920,3983,"Stop!"],[4045,4204,"Are you ignoring my orders?"],[4554,4641,"Lady Iris,"],[4704,4816,"you poisoned Lady Valerie,"],[4820,4933,"which is already a capital crime."],[4979,5129,"If you turn in the remedy now,"],[5179,5395,"I can put in a good word for you."],[5437,5585,"But if you refuse,"],[5629,5779,"your punishment will be worse."],[6250,6304,"I…"],[6341,6391,"Lady Iris,"],[6450,6612,"considering your service in the palace,"],[6637,6812,"I'll give you one last chance."],[6958,7125,"Think of your family."],[7587,7747,"It has nothing to do with Lady Iris!"],[7800,8004,"I was jealous of Lady Valerie."],[8062,8270,"We are both servants,"],[8287,8390,"yet she gets to be a Consort."],[8416,8520,"This is the truth."],[8554,8662,"I have nothing else to say."],[8666,8804,"I'll kill myself for my sins."],[9237,9391,"How could you be so foolish?"],[10237,10341,"That d*mn bitch"],[10387,10541,"she ruins my plans every time!"]],"19":[[400,516,"Iris harmed a Consort."],[591,695,"His Majesty will punish her."],[966,1045,"Apply the medicine,"],[1095,1187,"so you can serve the Emperor."],[1260,1404,"This is your first summon"],[1408,1495,"since becoming a Consort."],[1587,1850,"It's your wedding night with His Majesty."],[2691,2858,"You want me to serve him that bad?"],[2879,3062,"How loyal you are to him."],[3103,3366,"That night felt like heaven to me,"],[3441,3608,"but it was just a fleeting fling to him."],[3687,3754,"Clara,"],[3800,3883,"wake up."],[3937,4073,"Remember why you entered the palace."],[4262,4362,"I'm no longer a virgin."],[4370,4525,"If I serve him in bed, I'll be exposed."],[4554,4708,"This is my only chance."],[4768,4816,"No."],[4891,4975,"You tyrant."],[5000,5158,"Tonight is the night I end your life."],[5645,5700,"Your Majesty."],[5766,5854,"Issue the decree."],[5983,6037,"Yes."],[6145,6300,"His Majesty's edict."],[6728,6933,"Lady Iris is known for her malicious intentions,"],[6979,7141,"poisoning a Consort."],[7166,7279,"Her conduct is abominable."],[7323,7525,"Effective immediately, she is demoted to Noble Lady."],[7558,7996,"It'll be a warning to the rest of the harem."],[8021,8221,"The palace maid set me up!"],[8279,8416,"I'm innocent!"],[8475,8550,"Mr. Cury,"],[8583,8762,"please beg His Majesty for me."],[8854,8929,"Lady Iris,"],[8987,9112,"just accept the edict."],[9287,9358,"I…"],[9633,9820,"Thank you, Your Masjesty."],[10364,10691,"She's nothing but a vixen from the gutters."],[10741,10929,"To think the Emperor is so biased to her."],[11087,11279,"Even with a scapegoat, he still punished me."],[11604,11679,"Valerie,"],[11779,11991,"even if I fell into your trap this time,"],[12054,12320,"there are plenty of others in this harem"],[12352,12464,"with ruthless means."],[12545,12637,"Just wait."],[12691,12770,"I'll see"],[12820,12987,"if you can have the last laugh!"]],"20":[[183,427,"She's talented, beautiful,"],[470,745,"compassionate, and smart."],[904,1070,"I have finally found"],[1104,1220,"such a peerless woman."],[1262,1391,"I wonder how she will react"],[1437,1587,"when she discovers who I really am."],[1613,1758,"Father, Mother,"],[1825,1908,"today's the day"],[1941,2087,"I'll avenge you."],[3191,3325,"The blood debt of the David family"],[3358,3537,"will be paid with your life."],[3579,3879,"Then I can face my parents in the afterlife."],[4858,5004,"Lady Valerie."],[5266,5325,"Mr. Cury."],[5345,5425,"Lady Valerie,"],[5458,5587,"you're serving tonight,"],[5591,5758,"please sign here."],[5828,5937,"You're new to the palace."],[5958,6154,"There are many rules you might not know."],[6170,6258,"This is the Bedchamber Registry."],[6270,6587,"When a Consort serves the Emperor,"],[6616,6733,"she must sign for the records."],[6966,7133,"He must have committed so many sins"],[7137,7287,"to be this paranoid."],[7320,7379,"Lady Valerie,"],[7400,7529,"I'll take my leave."],[7725,7912,"Unfortunately, you met me."],[9295,9358,"Lady Valerie,"],[9433,9550,"you finally came."],[9754,9908,"Sorry, I've kept you waiting."],[10029,10070,"It's fine."],[10108,10220,"You're worth the wait."],[10225,10420,"I have a surprise for you."],[10425,10491,"What a coincidence."],[10545,10883,"I have a surprise for you too."]],"21":[[929,1016,"Palace guards!"],[1037,1104,"He found out."],[1108,1187,"Yes."],[1191,1337,"What are your orders?"],[1402,1506,"I'm suddenly feeling unwell."],[1550,1641,"Escort Lady Valerie"],[1642,1746,"back to Flora Palace."],[1900,1983,"Your Majesty."],[1991,2070,"Lady Valerie,"],[2108,2183,"please leave."],[2845,2945,"I'll take my leave."],[3625,3737,"She wants to assassinate me."],[3825,3895,"But,"],[3914,3977,"why?"],[4041,4162,"Why does she want to kill me?"],[4516,4579,"Wait."],[4612,4825,"Did he find out, or didn't he?"],[4850,4950,"If he did,"],[4966,5137,"why would he let me go?"],[5158,5295,"But if he didn't,"],[5300,5441,"why did he stop so suddenly?"],[5800,5855,"My Lady,"],[5883,5979,"today is the first of the month."],[6050,6195,"You need to pay respects to the Noble Consort."],[6300,6354,"Let's change your clothes."],[6604,6683,"My Lady,"],[6687,6762,"why don't you call in sick"],[6766,6958,"and skip the ceremony?"],[6966,7041,"Why?"],[7175,7237,"My Lady,"],[7241,7595,"every concubine relies on His Majesty's favor."],[7616,7750,"But you didn't serve him last night."],[7754,7833,"If you go,"],[7841,8091,"the other concubines might laugh at you."],[8116,8258,"I don't want you to be upset."],[8283,8425,"I'm here for revenge,"],[8445,8612,"not for some favor fight."],[8904,9032,"But if I stay away,"],[9045,9229,"they'll think I'm a pushover."],[9254,9358,"I'm going to meet them."]],"22":[[66,141,"Did you hear?"],[191,308,"The Emperor's new Consort"],[341,441,"was kicked out last night"],[487,633,"without serving him."],[710,802,"Some people"],[824,1087,"just don't have the luck to serve His Masjesty."],[1129,1183,"Just look at her."],[1212,1304,"Before she even won favor,"],[1320,1441,"she already lost face."],[1470,1654,"How can she show her face now?"],[1675,1882,"I bet His Majesty found her too low-class"],[1912,2037,"to touch."],[2054,2258,"She's just a dancer who got lucky"],[2262,2333,"at the All-Nations Banquet."],[2354,2545,"Did she think she could become a Noble Consort?"],[2566,2758,"My background doesn't matter."],[2837,3004,"What matters is that I'm lucky."],[3025,3216,"It's certainly better than someone"],[3233,3366,"who got demoted to a Noble Lady."],[3404,3566,"As long as I have His Majesty's love,"],[3583,3762,"what's the difference between Noble Lady and Consort?"],[3803,4025,"We're just feeling sorry for you."],[4066,4275,"Sent right back to your palace last night."],[4279,4391,"He wouldn't touch you."],[4875,5062,"A Noble Lady is no different from a Consort?"],[5066,5166,"I'm curious."],[5204,5308,"What is the punishment"],[5320,5441,"for a Noble Lady"],[5454,5570,"offending a Consort?"],[5600,5716,"Please calm down, Your Highness."],[5720,5866,"I spoke without thinking."],[5875,6000,"Please forgive me."],[6166,6233,"Enough."],[6266,6412,"I have always been lenient,"],[6429,6537,"I will let it slide this time."],[6541,6658,"Thank you, Your Highness."],[6733,6816,"As for you,"],[6883,6995,"I'm merciful,"],[7000,7100,"I'll spare you too."],[7145,7220,"B*tch."],[7233,7304,"What makes her so smug?"],[7316,7512,"Just wait for the Noble Consort!"],[7554,7708,"The Noble Consort has arrived!"],[7928,8095,"Greetings, Noble Consort."],[8120,8233,"You may all rise, sisters."],[8262,8366,"Except for Lady Valerie."],[8654,8754,"I'm unaware,"],[8779,8887,"what crime have I committed?"],[8916,9145,"You used a private punishment,"],[9166,9304,"and caused discord among the sisters."],[9329,9454,"This is a major taboo."],[9479,9579,"Do you admit your guilt?"],[9591,9704,"The Noble Consort is truly generous."],[9750,9875,"No wonder these sisters"],[9883,10025,"show such disrespect."],[10029,10187,"I'm ignorant,"],[10208,10304,"I didn't realize"],[10333,10520,"that this is your usual style."],[10529,10591,"How dare you!"],[10608,10720,"Are you accusing me"],[10725,10845,"of being lax in my discipline?"],[10870,11104,"Somebody slap her face!"]],"23":[[82,129,"Your Majesty,"],[132,220,"news has arrived from the front."],[223,360,"The day after the Davids were murdered,"],[369,545,"Prince Richard's top fighter, Logan,"],[554,733,"went to their main grain store in Penturn."],[949,1216,"Why would the top fighter of Prince Richard"],[1220,1350,"purchase grain?"],[1370,1500,"Look into it."],[1537,1612,"Yes."],[1950,2050,"Dealing with politics is easy,"],[2138,2242,"but matters of the heart are hard."],[2562,2766,"Why does Valerie want to assassinate me?"],[2832,2974,"How should I deal with her?"],[3245,3320,"If all else fails,"],[3341,3450,"I'll just reveal my identity"],[3454,3587,"and ask her for the truth."],[4015,4058,"You!"],[4212,4254,"Your Highness,"],[4279,4345,"you can't strike me."],[4350,4420,"What a joke."],[4445,4562,"The Empress's seat is vacant."],[4566,4750,"The Noble Consort manages the harem."],[4791,4908,"She can punish whomever she wants,"],[4912,5000,"and kill whomever she wants."],[5104,5383,"Lady Iris, you have forgotten your lesson."],[5429,5529,"Your Highness,"],[5566,5779,"I'm a Consort personally appointed by His Majesty."],[5841,6070,"Just now, Lady Iris spoke insolently to me."],[6129,6279,"That's disrespect toward His Majesty."],[6308,6466,"I punished her for it,"],[6529,6641,"what did I do wrong?"],[6645,6820,"How can that be considered abuse of power?"],[6829,6870,"You!"],[7037,7145,"Lady Valerie, your eloquence"],[7150,7254,"is truly impressive."],[7295,7391,"I have finally experienced"],[7395,7587,"what a glib tongue really is!"],[7633,7708,"Your Highness,"],[7712,7841,"you have always been fair"],[7866,7954,"and perceptive."],[7966,8075,"Just now, you simply"],[8079,8258,"didn't know the full story"],[8262,8433,"and had a misunderstanding with me."],[8437,8504,"But now,"],[8525,8641,"that Your Highness knows"],[8645,8775,"everything Lady Iris has done,"],[8833,9050,"surely you won't go easy"],[9054,9170,"on someone so insubordinate."],[9216,9262,"You!"],[9375,9450,"Your Highness,"],[9512,9695,"I did it all for you!"],[9700,9829,"Lady Iris was insubordinate."],[9854,9912,"Give her twenty strokes"],[9916,9991,"as a warning to others!"],[10025,10087,"You b*tch,"],[10091,10225,"this is all your fault!"],[10350,10466,"The Emperor has arrived!"],[10470,10608,"Valerie!!"]],"24":[[16,87,"Your Majesty,"],[116,333,"my eyes hurt so much I can't open them."],[370,454,"Summon the imperial physician!"],[491,562,"Yes, Your Majesty."],[629,766,"Iris, how dare you!"],[804,991,"You usually pretend to be kind,"],[1016,1075,"but I never expected"],[1095,1229,"you could be so vicious!"],[1283,1341,"Your Majesty,"],[1408,1566,"I only hurt her"],[1570,1670,"by accident!"],[1716,1842,"The Noble Consort has already punished me"],[1850,1991,"with twenty strokes of the plank."],[2000,2166,"I truly know I was wrong."],[2233,2300,"Get off me!"],[2362,2462,"You vicious woman."],[2466,2566,"Twenty strokes"],[2583,2700,"were indeed too few."],[2764,2889,"Hear my decree."],[2920,3154,"Lady Iris is immediately demoted to a commoner"],[3175,3295,"and banished to the Cold Palace."],[3300,3412,"Without my permission,"],[3416,3570,"she is not to step foot outside!"],[4352,4473,"If anything happens"],[4491,4608,"to Lady Valerie's eyes,"],[4641,4941,"I will ensure you pay an eye for an eye."],[5462,5533,"How is she?"],[5537,5637,"Lady Valerie's eyes"],[5641,5750,"were scalded by hot tea,"],[5770,5866,"she's temporarily blind."],[5908,6012,"If she keeps them covered and rests"],[6025,6125,"and uses the warm medicinal compresses,"],[6129,6191,"she will regain her sight."],[6250,6358,"However, during her recovery,"],[6370,6483,"she must remain calm."],[6510,6585,"Any emotional agitation"],[6600,6754,"will hinder the healing process."],[6808,6841,"Good."],[6895,6966,"I understand."],[7020,7116,"Go prepare the medicine."],[7604,7758,"It's just the Emperor and me now."],[7783,7904,"Such a perfect opportunity to kill him,"],[7933,8037,"but I can't see."],[8250,8429,"I don't have a weapon at hand."],[8491,8550,"Valerie,"],[8554,8645,"do you want some water?"],[8670,8737,"Let me help you."],[10441,10504,"Valerie,"],[10516,10600,"there is something"],[10604,10741,"I want to ask you."],[10754,10854,"What is it, Your Majesty?"],[10904,10962,"Last night..."]],"25":[[25,66,"Last night..."],[70,112,"Your Majesty,"],[141,220,"Mr. Sloane heard that Iris"],[225,341,"was banished to the Cold Palace."],[370,475,"He is kneeling outside the Imperial Study"],[491,579,"begging to see you."],[600,704,"He's banging his head to the ground."],[758,837,"Got it."],[946,992,"Valerie,"],[1020,1129,"I have work to do."],[1162,1241,"Since your vision is impaired,"],[1281,1369,"I will send Edward"],[1379,1462,"to protect you."],[1683,1775,"Edward?"],[1829,1912,"Is that him?"],[3133,3241,"You're here."],[3683,3812,"Your name is Edward."],[3837,3962,"How did you know it was me?"],[3979,4062,"Because"],[4079,4212,"you have a distinctive scent."],[4245,4351,"Scent?"],[4450,4612,"It's the incense from the training grounds."],[5279,5408,"Where could it be?"],[5800,5945,"What are you looking for?"],[6116,6212,"I knew I saw it."],[6229,6350,"Did His Majesty"],[6354,6520,"send you to find a knife?"],[6666,6795,"That tyrant really did see it."],[6845,6891,"Now,"],[6962,7100,"I have to take a gamble."],[7608,7708,"Why did you have this dagger"],[7770,7908,"when you served last night?"],[8074,8387,"Don't you know why I brought it?"],[8479,8512,"Huh?"],[8545,8637,"I'm no longer a virgin."],[8645,8816,"If I didn't bleed when I served him,"],[8858,8995,"I would be deceiving the Emperor."],[9016,9137,"If His Majesty investigates,"],[9175,9254,"neither of us"],[9262,9354,"would survive."],[9374,9479,"You did this for me?"],[9541,9645,"I didn't want to lie to you,"],[9691,9850,"but I had no other choice."],[9925,9987,"Ed,"],[10004,10116,"take me to His Majesty quickly"],[10125,10220,"and turn me in."],[10245,10345,"Why are you so silly?"],[10366,10462,"Actually, I'm..."]],"26":[[25,129,"Why are you so silly?"],[170,250,"Actually, I'm..."],[287,395,"During her recovery,"],[400,508,"she must remain calm."],[512,600,"Any emotional agitation"],[604,700,"will hinder the healing process."],[758,916,"Since I know how she feels,"],[945,1083,"I should wait for her to fully recover"],[1100,1245,"before finding a chance to confess."],[1259,1350,"That would be better."],[1429,1512,"You are what?"],[1666,1712,"Actually,"],[1758,1912,"looking for the dagger was just a formality."],[1929,2045,"I will protect you."],[2050,2166,"You can't see right now,"],[2183,2295,"so don't push yourself."],[2316,2412,"If there's anything you need,"],[2429,2579,"just order me to do it."],[4257,4329,"Lady Valerie,"],[4333,4441,"I'm here for your follow-up exam."],[4979,5108,"His Majesty and Lady Valerie"],[5129,5258,"are quite playful."],[6430,6554,"I can see again."],[6641,6720,"Congratulations, My Lady."],[6726,6780,"Lena,"],[6816,7025,"tell Ed the good news immediately."],[7125,7300,"I actually thought of Ed first."],[7366,7441,"I can't drag him down."],[7570,7650,"Go prepare some soup."],[7669,7849,"I want to give His Majesty a surprise."]],"27":[[0,62,"My Lady,"],[90,228,"you should go another day."],[272,388,"Why another day?"],[429,654,"Ten years ago today,"],[658,831,"His Majesty left the Cold Palace."],[839,997,"Every year, Lady Eva asks him"],[1005,1180,"to visit their pledge tree"],[1204,1262,"and reminisce about the days"],[1266,1441,"they supported each other in the Cold Palace."],[1445,1662,"They never let anyone disturb them."],[1679,1891,"Won't let anyone disturb them…"],[1931,2135,"Then it's a perfect opportunity."],[2420,2504,"Lady Eva"],[2533,2680,"comes to that d*mn tree every year."],[2712,2862,"She just wants to humiliate me"],[2870,3004,"and constantly remind me"],[3025,3195,"of those days."],[3207,3346,"I'll only stay here for a moment."],[3400,3516,"Find an excuse"],[3520,3629,"to come and pull me away."],[3633,3700,"Yes, Your Majesty."],[3816,3879,"Oh, right."],[3887,3962,"The imperial physician said"],[3982,4132,"Valerie's eyes have healed."],[4166,4275,"Go visit her on my behalf."],[4492,4579,"Lady Valerie!"],[5129,5233,"Who's there?"],[5337,5500,"Did I hear wrong?"],[5575,5629,"Your Majesty,"],[5650,5754,"are you and Lady Valerie"],[5758,5883,"still playing the palace guard game?"],[6000,6095,"What do you know?"],[6150,6283,"I can't let her know"],[6287,6383,"I'm the Emperor."],[6387,6491,"I want to formally"],[6495,6579,"tell her the truth,"],[6595,6754,"rather than letting her find out."],[6779,6908,"That would cause her to misunderstand"],[6912,7033,"and think I'm toying with her."],[7091,7220,"Who is there?"],[7362,7529,"Who dares trespass in the forbidden area?"]],"28":[[0,225,"Who dares trespass in the forbidden area?"],[381,445,"Lady Valerie."],[520,608,"Your eyes have healed?"],[718,872,"Greetings, Noble Consort."],[904,1041,"That my eyes have recovered"],[1062,1183,"is all thanks to your blessing."],[1212,1295,"What are you doing here?"],[1350,1483,"Don't you know this is a forbidden area?"],[1533,1662,"I have been blind for several days,"],[1675,1779,"I just came out for a walk."],[1837,1970,"I think you came here on purpose"],[1987,2120,"to pretend to bump into His Majesty."],[2166,2208,"Oh?"],[2252,2352,"Is His Majesty here?"],[2370,2479,"Drop the act."],[2504,2629,"Everyone in the palace knows that"],[2654,2762,"on this day every year,"],[2795,3004,"His Majesty and I meet right here."],[3150,3254,"You want to seduce His Majesty,"],[3279,3371,"but you picked the wrong time."],[3416,3500,"No, that's not it."],[3537,3608,"I didn't"],[3650,3725,"I will leave immediately."],[3799,3861,"Wait."],[3877,4054,"You've landed right in front of me;"],[4066,4200,"how can I just let you walk away?"],[4229,4350,"Since your eyes have just healed,"],[4379,4479,"you really should walk around."],[4520,4666,"What does this woman want?"],[4720,4841,"What trick is she playing now?"],[4958,5162,"This is the tree where we pledged our love."],[5178,5445,"Every year on this day, we meet here to reminisce."],[5520,5629,"It's growing so well."],[5778,5916,"His Majesty will be here any minute."],[5941,6083,"Didn't you want to bump into His Majesty?"],[6133,6304,"Then stay here to help me loosen the soil"],[6321,6405,"for my tree"],[6429,6537,"and add some fertilizer."],[6654,6720,"I have absolutely no intention of disturbing"],[6725,6858,"you and His Majesty."],[6900,7100,"I really just happened to walk by here."],[7358,7445,"Don't just stand there."],[7450,7545,"Get to work."],[8637,8725,"B*tch."],[8729,8833,"Just watch how I make you a laughingstock"],[8837,8929,"in front of His Majesty."]],"29":[[595,725,"A verbal decree from His Majesty!"],[1491,1654,"Get lost, you useless trash."],[1927,2095,"In all my years in the palace,"],[2100,2187,"this is the first time I've seen"],[2200,2420,"someone pouring manure all over themselves."],[2466,2545,"It reeks!"],[2629,2700,"Mr. Cury."],[2811,2979,"Lady Valerie is here, too."],[2995,3091,"Congratulations"],[3095,3212,"on regaining your sight."],[3220,3304,"Mr. Cury,"],[3308,3379,"where is His Majesty?"],[3400,3508,"Noble Consort,"],[3512,3645,"there are urgent matters at court,"],[3666,3808,"His Majesty cannot get away."],[3820,3983,"He sent me to deliver a verbal decree,"],[3987,4137,"asking you not to wait."],[4150,4283,"He isn't coming."],[4299,4506,"Noble Consort, please receive the decree."],[4662,4750,"The Love Tree"],[4762,5025,"is a testament to the past affection"],[5045,5154,"and holds extraordinary significance."],[5175,5354,"The Noble Consort has tended the tree with care."],[5358,5633,"Two luminous pearls will be rewarded for her merit."],[5675,5766,"From this day forth,"],[5816,5991,"only the Noble Consort may approach"],[5995,6091,"and care for the Love Tree."],[6095,6266,"No one else is allowed to touch it."],[6291,6400,"Any violation"],[6404,6529,"shall be punished without mercy."],[6566,6725,"Please continue the work"],[6758,6875,"and tend to it with the utmost care."],[6958,7095,"Is His Majesty telling me to…"],[7100,7183,"His Majesty is simply"],[7187,7345,"showing his absolute trust in Your Highness."],[7350,7445,"I suppose"],[7450,7608,"I won't be worthy to touch this tree anymore."],[7637,7725,"The Emperor is clearly"],[7729,7862,"trying to make a fool of the Noble Consort."],[7870,7975,"She deserves it, though."],[7998,8139,"The Noble Consort seems to be reconnecting,"],[8166,8295,"but in reality, she is constantly"],[8300,8366,"reminding the Emperor"],[8387,8554,"of those unbearable days in the past."],[8562,8679,"Isn't that just rubbing salt"],[8683,8816,"into the wound over and over again?"],[8916,9016,"I accept the decree."],[9020,9120,"My thanks to His Majesty."],[9175,9345,"I will take my leave then."],[9489,9666,"Your bond with His Majesty is truly wonderful."],[9679,9783,"It's the envy of everyone."],[9828,9903,"Of course."],[9925,10074,"The bond between His Majesty and me"],[10091,10220,"is naturally one of a kind."]],"30":[[41,308,"You know the Noble Consort well."],[312,395,"Now she has to"],[400,483,"tend to that tree"],[487,620,"all by herself."],[855,995,"Since the Noble Consort"],[1000,1150,"has so much energy to burn,"],[1154,1325,"let her put it to good use with more work."],[1466,1606,"Father, Mother."],[1695,1850,"Am I useless?"],[1854,2012,"I've been in the palace for so long,"],[2076,2212,"yet I've failed time and again."],[2412,2574,"Private rituals are forbidden in the palace."],[2733,2850,"Aren't you afraid of being seen?"],[3069,3144,"Don't cry."],[3433,3558,"I won't tell anyone."],[3566,3691,"No one will punish you."],[3721,3800,"Please, wipe your tears."],[3804,3850,"Okay?"],[4159,4377,"Today is the anniversary of my parents' death."],[4429,4570,"I didn't mean to break the rules."],[4575,4691,"It's just that…"],[4866,5000,"I can empathize"],[5033,5145,"with your sorrow."],[5171,5300,"But life and death"],[5304,5429,"are everyone's destiny."],[5454,5533,"They cannot be undone."],[5579,5687,"All you can do now"],[5691,5791,"is to live well."],[5829,5950,"Only then will your parents"],[5970,6070,"rest in peace."],[6104,6237,"Live well?"],[6250,6354,"I live for one purpose only:"],[6358,6466,"to avenge my parents."],[7950,8145,"Are you a David, the royal purveyors?"]],"31":[[12,119,"What are you talking about?"],[139,256,"I don't understand."],[402,489,"The token in your hand"],[529,600,"is clearly the pass used by a royal purveyor"],[604,733,"to enter and exit the palace."],[912,1108,"You said today is your parents' anniversary."],[1216,1312,"The only ones that match that date"],[1346,1433,"are"],[1454,1537,"the Chief Royal Purveyor,"],[1557,1612,"the David family."],[1692,1837,"Are you their daughter?"],[1870,1954,"Clara."],[1991,2079,"I'm not."],[2095,2216,"I don't know what you're talking about!"],[2433,2513,"You have the token."],[2523,2643,"Why didn't you go to the palace for help?"],[2653,2762,"Do you know that all these years,"],[2770,2812,"I've been"],[2995,3108,"do you know His Majesty"],[3116,3220,"has been looking for you?"],[3275,3354,"Looking for me?"],[3412,3462,"Yes."],[3533,3633,"Regarding the murder of the David family,"],[3695,3862,"His Majesty has been secretly investigating."],[4021,4080,"Investigating?"],[4103,4245,"He found nothing."],[4262,4433,"Because the person who killed my parents"],[4470,4594,"was His Majesty himself!"],[4691,4741,"What?"],[4991,5087,"Why are you doing this?"],[5125,5287,"Now that you know who I am,"],[5304,5433,"I have no choice but to kill you,"],[5462,5525,"or"],[5600,5737,"be killed by you."],[5741,5933,"No, but why?"],[6675,6741,"Valerie,"],[6766,6875,"you took a knife to the royal bed for me."],[6900,7000,"You were so devoted to me."],[7020,7070,"Why turn your sword"],[7075,7150,"against me today?"],[7200,7254,"Is it"],[7308,7366,"just because I"],[7370,7470,"found out who you are?"],[7500,7616,"Stop pretending."],[7633,7745,"The Emperor is looking for me"],[7754,7812,"just to"],[7816,7941,"kill me to silence me?"],[7954,8070,"You can help me hide"],[8075,8212,"what happened in the bedchamber,"],[8216,8337,"but as for the David family,"],[8341,8445,"can you hide that too?"],[8462,8558,"Why would His Majesty"],[8562,8658,"want to silence you?"],[8687,8770,"Why?"],[8820,8958,"I saw it with my own eyes."],[8983,9162,"The killer who murdered my parents"],[9237,9337,"was wearing the badge"],[9341,9437,"of the Imperial Guard."],[9441,9495,"How can you say"],[9500,9670,"it wasn't the Emperor's order?"]],"32":[[54,216,"Impossible!"],[220,283,"Are you sure"],[287,408,"it was the Imperial Guard?"],[566,662,"I once went with my father"],[666,779,"through the second palace gate."],[808,950,"I have seen the Imperial Guards patrolling."],[966,1116,"I recognize their badges."],[1125,1250,"I couldn't be mistaken!"],[1341,1437,"If His Majesty really wanted"],[1441,1545,"to kill your parents,"],[1566,1700,"why would he order someone"],[1704,1908,"to secretly investigate the matter?"],[1945,2041,"Valerie"],[2104,2162,"No,"],[2225,2312,"Clara."],[2366,2550,"That doesn't add up."],[2575,2662,"Trust me,"],[2677,2810,"I will find out the truth."],[2841,2933,"Until then,"],[3012,3133,"stop trying to assassinate His Majesty."],[3137,3195,"Okay?"],[3220,3337,"I won't reveal your identity"],[3341,3441,"to anyone."],[3537,3654,"Promise me,"],[3750,3812,"okay?"],[3845,4037,"He probably doesn't know the truth"],[4041,4141,"about my parents' murder."],[4145,4300,"But as the Emperor's Shadow Guard,"],[4316,4379,"can I trust"],[4412,4541,"what he says?"],[4545,4670,"Let go of me first."],[4682,4753,"Promise me first"],[4779,4904,"you won't be rash again,"],[4958,5029,"okay?"],[5145,5258,"Okay."],[5587,5700,"Since it's come to this,"],[5733,5870,"I just have to keep him calm for now."],[5891,5979,"Regarding the Emperor,"],[6000,6112,"I need to speed up my plans."],[6345,6412,"Your Majesty,"],[6429,6558,"there's a new development regarding the David family."],[7679,7812,"So she really did want to kill me"],[7862,8004,"that night she served in my bedchamber."],[8095,8162,"No."],[8200,8279,"I must find out the truth"],[8283,8416,"immediately."],[8662,8745,"Your Majesty,"],[8746,8854,"Prince Richard once visited the David residence."],[8879,9020,"The day after the couple was murdered,"],[9037,9116,"Prince Richard's"],[9120,9212,"top enforcer, Logan,"],[9220,9312,"visited the David family's"],[9316,9433,"main grain store in Penturn."],[9495,9641,"All the evidence here"],[9700,9825,"points to Prince Richard."],[9866,10012,"But why would he kill"],[10016,10129,"the Chief Royal Purveyor?"],[10216,10370,"I saw it with my own eyes."],[10416,10583,"The man who killed my parents"],[10587,10650,"had an Imperial Guard badge"],[10683,10770,"hanging from"],[10775,10912,"his waist!"],[11112,11208,"Then how did all of this"],[11212,11295,"get pinned on me?"],[11358,11387,"Chu,"],[11462,11595,"send more men to watch Prince Richard."],[11610,11712,"Investigate all properties"],[11716,11766,"under his name,"],[11770,11854,"as well as where he's been"],[11858,11900,"and who he's met"],[11916,12012,"in recent years."],[12037,12112,"And who"],[12116,12208,"he has been corresponding with."],[12295,12370,"Yes, Your Majesty."],[12437,12612,"Richard, oh Richard"],[12633,12816,"my dear brother,"],[12887,13166,"what exactly are you planning?"]],"33":[[125,170,"My Lady,"],[220,312,"the soup is ready."],[809,912,"I'll go to the Imperial Study"],[933,1029,"to deliver it to His Majesty."],[1075,1170,"You go to the Clothing Bureau"],[1205,1351,"and pick up the clothes made last month."],[1400,1575,"Let me escort you to the study first,"],[1579,1658,"then I'll go."],[1690,1737,"No need."],[1783,1879,"I can go by myself."],[1954,2079,"Poisoning the Emperor is a capital crime."],[2160,2341,"I won't let you get dragged into this."],[2362,2487,"To avenge my parents,"],[2529,2666,"everything depends on this move."],[2845,2904,"Your Majesty,"],[2913,2987,"Lady Valerie"],[2991,3087,"is here with soup to see you."],[3150,3212,"Your Majesty,"],[3216,3320,"Lady Valerie"],[3336,3458,"she's finally come around."],[3475,3566,"Come to think of it,"],[3583,3737,"this is the first time she's sought you out."],[3770,3954,"You think she's come around?"],[3975,4162,"She's here to confront me."],[4179,4245,"But right now,"],[4250,4375,"the matter hasn't been fully investigated."],[4379,4512,"If I give vague answers,"],[4516,4675,"she'll definitely think I'm lying to her."],[4741,4881,"Just say I'm busy with state affairs"],[4891,4965,"and will see her another day."],[5095,5212,"Just do as you're told."],[5316,5395,"Yes."],[5416,5533,"Lady Valerie!"],[5537,5670,"His Majesty hasn't summoned you yet."],[5675,5837,"You can't go in there."],[5885,5985,"She's forcing her way in."],[6070,6111,"Your Majesty."],[6114,6234,"I'll go take a look."],[6541,6595,"Your Majesty."],[6633,6733,"I saw Lady Valerie"],[6758,6825,"pour a whole bottle of poison"],[6837,6937,"into the soup."],[6966,7062,"What?"],[7120,7304,"She really doesn't trust me."],[7308,7475,"She never planned to wait for my investigation,"],[7479,7620,"and wants to kill me directly instead."],[7683,7841,"His Majesty is suddenly feeling unwell."],[7845,8033,"Why don't you come back another day?"],[8037,8150,"Since His Majesty is unwell,"],[8154,8300,"I simply must go visit him."],[8329,8429,"Your Highness."],[8441,8650,"It's not a good time. Really."],[8684,8795,"I miss His Majesty."],[8800,8845,"I miss him dearly."],[8870,8983,"If I don't see His Majesty for a single day,"],[9012,9141,"I cannot eat or sleep in peace."],[9162,9233,"- Let me in! - You can't."],[9254,9283,"You can't go inside!"],[9287,9387,"Your Highness, really, you can't."],[9391,9533,"Please don't make this difficult for me."],[9537,9720,"Your Highness! Oh, Your Highness!"],[9754,9812,"Your Majesty!"],[9816,10002,"Lady Valerie is here to see you!"]],"34":[[729,879,"Greetings, Your Majesty."],[908,1000,"Lady Valerie."],[1025,1183,"I'm suddenly not feeling well."],[1204,1329,"You should head back."],[1375,1458,"Your Majesty,"],[1475,1566,"ever since I recovered"],[1570,1654,"my eyesight,"],[1700,1820,"I have been hoping"],[1848,1993,"that you would come to visit me,"],[2041,2162,"but my wish has not been granted."],[2183,2354,"So I have come here myself today."],[2358,2425,"Your Majesty,"],[2429,2545,"are you unwilling to grant me"],[2550,2662,"even a single glance?"],[3354,3454,"Your Majesty,"],[3458,3591,"with this screen between us,"],[3600,3750,"it feels like a wall of mist."],[3779,3870,"Could it be that"],[3895,4033,"you do not wish to see me?"],[4066,4162,"Lady Valerie,"],[4179,4300,"His Majesty has internal heat."],[4304,4538,"The imperial physician ordered him to rest."],[4549,4653,"That is quite a coincidence."],[4691,4833,"I made some green bean soup."],[4841,4916,"It clears internal heat and detoxifies."],[4962,5175,"It's soothing. Would you like to taste it?"],[5558,5637,"Your Highness,"],[7170,7262,"Lady Valerie,"],[7312,7420,"this is against protocol."],[7554,7700,"It's rare for Lady Valerie to show such care."],[7716,7783,"Pike,"],[7800,7920,"bring the soup in."],[7983,8058,"Yes, Your Majesty."]],"35":[[133,241,"This is for His Majesty."],[279,412,"All food served to His Majesty"],[433,541,"must be tested for poison."],[583,691,"That is the rule."],[1175,1337,"The Dreamfall Pill is instantly fatal."],[1341,1443,"If this guard drinks it,"],[1470,1620,"an innocent man will die."],[1675,1787,"What should I do?"],[1862,1937,"That won't be necessary."],[1987,2045,"I,"],[2087,2208,"naturally, trust Lady Valerie."],[2241,2341,"Bring it in."],[2377,2423,"Yes, Your Majesty."],[4125,4229,"In an hour,"],[4233,4391,"the Emperor will be dead."],[4395,4504,"Father, Mother,"],[4508,4683,"I have avenged you."],[4741,4825,"The taste seems"],[4829,4966,"different from other soups."],[4987,5183,"But it is sweet and refreshing."],[5187,5291,"Lady Valerie, your culinary skills are superb."],[5320,5408,"You flatter me, Your Majesty."],[5445,5579,"I still have state affairs to attend to,"],[5591,5699,"so I will visit you another day."],[5729,5812,"You may leave now."],[5925,6000,"Yes."],[6033,6145,"I shall take my leave."],[6650,6745,"What game are His Majesty and Her Ladyship"],[6750,6933,"playing this time?"],[6937,7091,"Is this a new script?"],[7279,7395,"My Lady, bad news!"],[7462,7533,"What is it?"],[7537,7612,"His Majesty"],[7618,7712,"His Majesty, he"],[7754,7883,"Has His Majesty died suddenly?"],[7900,7987,"Regicide is"],[7991,8083,"a capital crime."],[8100,8170,"I won't need the Royal Guards"],[8175,8254,"to come arrest me."],[8304,8466,"Father, Mother, you are avenged."],[8500,8712,"I'm coming to join you now."]],"36":[[54,133,"His Majesty has fallen ill."],[154,279,"They say he has a high fever that won't break."],[325,383,"What?"],[462,558,"How is that possible?"],[579,741,"I clearly used the Dreamfall Pill,"],[762,875,"which should rot the intestines"],[879,962,"within half an hour."],[1241,1304,"Ed,"],[1320,1416,"is His Majesty sick?"],[2891,3045,"If I don't find out the truth soon,"],[3058,3216,"let alone winning the beauty's heart,"],[3241,3308,"who knows when"],[3312,3395,"I might lose my life,"],[3429,3633,"and she will die for regicide."],[3700,3887,"Ed, say something."],[3925,4058,"Why is His Majesty merely sick?"],[4087,4229,"You probably want to ask"],[4270,4412,"why His Majesty isn't dead yet."],[4416,4516,"It's actually quite strange."],[4550,4679,"His Majesty was reviewing memorials,"],[4708,4858,"when he suddenly coughed up blood."],[4862,4954,"He has been unconscious ever since,"],[4958,5045,"and his high fever won't break."],[5087,5183,"Maybe"],[5204,5320,"the Dreamfall Pill has taken effect."],[5362,5454,"He might be hanging on"],[5458,5529,"by a thread right now."],[5566,5708,"Those rumors must be false."],[5729,5850,"But if His Majesty is that sick,"],[5854,5991,"I must go see him."],[5995,6125,"Your Highness, wait for me."],[6129,6220,"Don't go!"],[7033,7150,"It's rare for His Majesty to fall ill."],[7154,7233,"I have to make sure"],[7237,7350,"I put on a good show."],[7391,7512,"Hey, Lady Valerie."],[7516,7658,"We're all here to tend to his illness."],[7662,7812,"Don't even think about cutting in line."],[7816,7962,"Just get in the back."],[7975,8129,"There is an order of arrival, you know."],[8195,8333,"That's right, Lady Valerie."],[8370,8491,"You arrived last,"],[8587,8712,"so know your place and go to the back."]],"37":[[229,362,"Line up however you want."],[412,562,"As long as I can see His Majesty,"],[591,733,"I'll make sure to deal the final blow."],[850,954,"His Majesty originally just"],[958,1079,"wanted to keep Lady Valerie in check."],[1116,1200,"Now look what happened."],[1233,1362,"Everyone has flocked here."],[1445,1525,"Find a way"],[1541,1662,"to send them all away."],[1683,1766,"If you botch this,"],[1770,1883,"I'll hold you responsible."],[2179,2291,"Your Highnesses."],[2295,2491,"His Majesty knows your devotion,"],[2520,2639,"but his illness"],[2652,2798,"makes it unsuitable for visits."],[2858,2987,"It's contagious."],[3654,3720,"Mr. Cury,"],[3738,3863,"is it my turn now?"],[3902,4018,"Lady Valerie,"],[4042,4254,"His Majesty has smallpox."],[4298,4409,"It's highly contagious."],[4451,4680,"It's fine, I'm not afraid of smallpox."],[4683,4812,"I had it when I was a child,"],[4839,4964,"so I'm immune."],[5108,5187,"Lady Valerie,"],[5300,5408,"look at you."],[5428,5544,"Once you go in to care for him,"],[5549,5640,"you'll be there for many days."],[5683,5808,"You haven't brought anything."],[5850,6008,"Why don't you go back and prepare?"],[6150,6254,"That will also give His Majesty"],[6258,6362,"time to prepare."],[6366,6420,"True."],[6433,6512,"I'll go back,"],[6518,6608,"pack my things, and return."],[6620,6708,"Good, good."],[7137,7333,"Alright, ladies,"],[7337,7483,"please head back as well."],[8800,8879,"My Lady,"],[8909,9097,"I've packed the mugwort and realgar."],[9170,9250,"Make sure you"],[9254,9370,"burn them to disinfect the room."],[9429,9508,"Or"],[9552,9689,"let me go with you."],[9754,9837,"I'm afraid"],[9841,9958,"it will be too hard for you alone."],[9995,10050,"No need."],[10091,10200,"You're still young."],[10225,10337,"You shouldn't have to suffer with me."],[10412,10470,"My Lady,"],[10512,10704,"you are so good to me."],[10795,10891,"Silly girl."],[10945,11058,"If you get dragged into this,"],[11104,11175,"I want to apologize in advance."],[11179,11233,"Please forgive me."],[11437,11583,"That dog of an Emperor"],[11612,11779,"won't escape this time."]],"38":[[262,345,"Lady Valerie,"],[381,454,"just a moment ago,"],[458,566,"His Majesty's condition took a turn for the worse,"],[595,712,"and complications have arisen."],[745,820,"It seems His Majesty"],[825,958,"is critically ill."],[1066,1208,"Let me see him immediately!"],[1308,1370,"Lady Valerie,"],[1375,1425,"what is the meaning of this?"],[1483,1579,"I am here to tend to His Majesty,"],[1583,1720,"yet you block my way."],[1725,1808,"What are you trying to do?"],[2127,2248,"Your Majesty!"],[2400,2495,"Lady Valerie,"],[2529,2620,"I appreciate your concern."],[2645,2766,"But this illness came on suddenly"],[2770,2837,"and is highly contagious."],[2883,2937,"I cannot bear"],[3012,3158,"to put you at risk."],[3229,3285,"Your Majesty,"],[3375,3575,"as your concubine,"],[3600,3700,"it is my duty"],[3704,3850,"to come and care for you."],[3861,3982,"Your devotion, Lady Valerie,"],[4016,4112,"is noted."],[4129,4229,"In the future,"],[4235,4356,"I will reward you generously."],[4404,4662,"Derrick, escort Lady Valerie back."],[4666,4733,"Yes, Your Majesty."],[4758,4895,"Wait, Your Majesty!"],[4900,5075,"Please let me see you just once."],[5079,5179,"If I cannot see you,"],[5183,5279,"I really"],[5283,5436,"I really cannot be at ease!"],[5437,5600,"Stop her! Hold her back!"],[5996,6121,"Oh, Your Majesty!"],[6391,6500,"It seems that dog of an Emperor"],[6504,6670,"really won't live much longer."]],"39":[[775,925,"Your Majesty! Your Majesty!"],[987,1150,"Lady Valerie has left."],[1866,1991,"You handled this well."],[2020,2112,"You all did well, too."],[2133,2193,"Reward them."],[2270,2370,"Thank you, Your Majesty."],[2395,2566,"All right, you may leave."],[3079,3208,"This watermelon juice is good."],[3229,3295,"Is there more?"],[3341,3425,"Yes."],[3629,3745,"However,"],[3750,3958,"I still have to pretend to be sick."],[4000,4079,"Your Majesty,"],[4445,4562,"when I go out,"],[4579,4625,"you and Pike"],[4629,4716,"must cover for me here."],[4741,4795,"Understood?"],[4829,4954,"Yes, Your Majesty."],[5089,5139,"My Lady,"],[5163,5280,"I had someone investigate."],[5325,5491,"The imperial physician never prescribed medicine for His Majesty."],[5679,5775,"No medicine?"],[5779,5841,"Right."],[5900,6020,"Lady Valerie said she went to tend to him,"],[6062,6183,"but she was only in there for an hour"],[6200,6312,"before being sent back to Flora Palace."],[6391,6470,"I suspect"],[6537,6633,"that His Majesty isn't sick at all."],[7025,7189,"What is His Majesty's intention?"],[7416,7541,"I understand now."],[7570,7745,"The Directorate of Astronomy read the stars"],[7750,7987,"and said a candidate for Empress has appeared."],[8008,8141,"His Majesty feigning illness"],[8166,8229,"is surely meant to"],[8233,8362,"test us concubines."],[8404,8470,"In that case,"],[8504,8662,"doesn't it mean only Lady Valerie"],[8666,8766,"passed the test?"],[8791,8881,"I absolutely will not let"],[8883,8983,"that bitch take the position."]],"40":[[1604,1691,"The Emperor is ill."],[1725,1845,"Shouldn't you be on duty?"],[1887,2012,"Why are you staying here with me all day?"],[2112,2241,"I have to keep an eye on you,"],[2275,2429,"in case you get impatient waiting for news of his death"],[2437,2579,"and decide to try poisoning him again."],[2649,2736,"Since Your Ladyship"],[2745,2895,"went to tend to him with such deep devotion,"],[2939,3060,"His Majesty was touched beyond measure"],[3100,3300,"and specifically assigned me to protect you."],[3875,3958,"Speaking of which,"],[3962,4045,"I have a question."],[4066,4204,"Does His Majesty assign"],[4233,4308,"bodyguards to protect"],[4312,4445,"all the concubines?"],[4508,4620,"Of course not."],[4658,4804,"Of all the concubines filling the palace,"],[4825,4925,"you are the only one"],[4945,5070,"with this special honor."],[5716,5862,"You're a guard,"],[5866,5941,"yet instead of practicing martial arts,"],[5970,6150,"you're here playing with calligraphy?"],[6214,6322,"I was just thinking,"],[6370,6562,"I should find some common interests with you."],[6632,6716,"At the All-Nations Banquet,"],[6754,6854,"when you danced"],[6858,6958,"and painted with your blood,"],[6975,7129,"creating a landscape painting,"],[7233,7362,"I thought to myself back then:"],[7395,7533,"if you were to paint in the future"],[7575,7725,"and I added an inscription to your work,"],[7750,7879,"it would surely be a masterpiece"],[7891,8025,"handed down for the ages."],[8116,8291,"Then you'd better practice your handwriting."],[8295,8454,"After all, my painting skills"],[8458,8541,"are top-notch."],[8591,8670,"We don't want"],[8675,8770,"your ugly handwriting"],[8791,8875,"to make us a laughingstock for future generations."],[9304,9437,"You underestimate me."],[9441,9629,"You... You're terrible!"],[10066,10258,"You... You're terrible"],[10474,10628,"So adorable."],[11060,11277,"How dare you! Who let you barge in here?"],[11316,11429,"You are the audacious one."],[11558,11620,"Noble Consort,"],[11625,11712,"what is the meaning of this?"],[11733,11900,"Someone reported to me"],[11904,12033,"that His Majesty's prolonged illness"],[12050,12145,"is because you cast"],[12150,12212,"a voodoo hex on him."],[12237,12318,"What?"]],"41":[[16,106,"Search the place!"],[194,270,"Hold on."],[289,421,"Searching a palace is a serious matter."],[440,544,"Do you have a decree?"],[562,690,"I assist in managing the Inner Court."],[708,809,"You harbor evil intentions"],[809,896,"and have committed treason."],[908,1053,"I will act first and report later."],[1127,1217,"What are you staring at?"],[1217,1298,"Search immediately!"],[1332,1411,"You"],[2410,2582,"The schemes in this Inner Court"],[2582,2753,"really are endless."],[2789,2966,"Let me go! You insolent slaves!"],[2966,3076,"I am His Majesty's Lady Valerie!"],[3076,3133,"Let go of me!"],[3150,3229,"Hmph."],[3264,3392,"You won't be for long."],[3392,3620,"Once I find the voodoo doll,"],[3620,3806,"your time will be up."],[3806,3925,"For daring to harm His Majesty,"],[3937,4123,"even death by a thousand cuts would be too lenient."],[4865,4910,"Your Highness,"],[4910,5002,"we didn't find any voodoo dolls."],[5002,5096,"Nothing outside, either."],[5121,5242,"Useless bunch of idiots."],[5393,5621,"You haven't searched in there yet, have you?"],[5665,5810,"No! Don't!"],[5810,5920,"Why so nervous?"],[5943,6043,"It seems"],[6043,6192,"the item is hidden right inside."],[6320,6468,"Ed"]],"42":[[92,214,"Found it."],[659,754,"Your Highness, look."],[874,988,"Good."],[988,1119,"Let's see how you talk your way out of this."],[1211,1333,"Valerie Ian,"],[1333,1548,"for using witchcraft to harm His Majesty,"],[1596,1678,"I order"],[1721,1817,"you be beaten to death immediately."],[1851,1967,"You're framing me!"],[2000,2105,"I want to see His Majesty!"],[2112,2198,"His Majesty is ill."],[2246,2400,"Didn't you just attend to him?"],[2430,2519,"Have you forgotten already?"],[2946,3046,"If you have grievances,"],[3046,3215,"save them for the King of Hell."],[3934,4006,"Do it."],[4548,4738,"Your Highness! Your Highness!"],[5263,5466,"A lowborn b*tch of a dancer,"],[5466,5634,"daring to dream of the Empress's throne."],[5688,5732,"Hmph."],[5732,5824,"Maybe in your next life."],[5947,6035,"Stop!"],[6685,6826,"Are you His Majesty's Shadow Guard?"],[6837,6948,"I was sent by His Majesty"],[6948,7073,"to protect Lady Valerie."],[7757,7857,"Noble Consort,"],[7926,7986,"from now on,"],[7988,8104,"every word you say,"],[8109,8259,"I will report verbatim"],[8259,8348,"to His Majesty."],[8370,8501,"To think His Majesty sent a Shadow Guard"],[8503,8598,"to protect this b*tch."],[8764,8923,"Lady Valerie used witchcraft"],[8923,9004,"to harm His Majesty."],[9004,9126,"The evidence is irrefutable."],[9140,9204,"Oh?"],[9284,9393,"The evidence is right here."],[9587,9774,"This isn't a voodoo doll."],[9776,9962,"It's clearly a blessing doll,"],[10284,10478,"praying for Valerie's longevity."],[10541,10692,"No, that's not right."],[10757,10868,"The note has been swapped."],[11548,11690,"You were the one who found the doll,"],[11690,11856,"and it's been in your hands the whole time."],[11898,12028,"No, that's not it!"],[12040,12140,"I clearly"],[12438,12533,"This is a misunderstanding."],[12581,12727,"I let my concern cloud my judgment."],[12728,12853,"It's a relief that Lady Valerie is innocent."],[12931,13009,"Well then, I"],[13009,13146,"will go search the other concubines."],[13218,13297,"Wait!"]],"43":[[0,76,"Lady Eva,"],[76,210,"I am, after all,"],[210,304,"a Consort of this palace."],[331,474,"Your maid framed me."],[483,616,"Don't you think you owe me an explanation?"],[1166,1246,"Lady Valerie,"],[1274,1390,"I was reckless."],[1559,1676,"It really was just a misunderstanding."],[1767,1830,"Lady Valerie,"],[1830,1926,"please be magnanimous."],[1966,2094,"Please spare me this time."],[2260,2330,"A misunderstanding?"],[2382,2514,"Just now, the Noble Consort"],[2514,2615,"was ready to have me"],[2617,2723,"beaten to death right here."],[2723,2860,"If word gets out,"],[2933,3066,"will people say a servant like you"],[3066,3169,"had the audacity to act on your own,"],[3234,3347,"or will they say"],[3347,3560,"Lady Eva ordered you to frame me?"],[3943,4029,"It really is a misunderstanding!"],[4029,4114,"Lady Valerie,"],[4179,4307,"it has nothing to do with the Noble Consort!"],[4371,4400,"Oh."],[4506,4700,"The Noble Consort just said that"],[4700,4856,"there were both witnesses and physical evidence."],[4967,5039,"The physical evidence"],[5056,5106,"is this"],[5106,5238,"so-called doll."],[5250,5334,"And the witness"],[5371,5510,"must be you."],[5629,5753,"Even if it was a misunderstanding,"],[5803,5889,"I am the master"],[5889,5989,"and you are the servant."],[6024,6106,"How dare a servant"],[6106,6225,"falsely accuse her master?"],[6250,6388,"I wonder, according to palace rules,"],[6426,6545,"what the punishment should be?"],[6579,6623,"Oh, right."],[6709,6829,"According to the rules,"],[6835,6956,"a wicked servant who insults a master"],[6984,7142,"should be beaten to death!"],[7273,7335,"No!"],[7423,7500,"Noble Consort,"],[7507,7598,"please save me!"],[7601,7701,"I know I was wrong,"],[7821,7926,"Noble Consort!"],[7957,8070,"What do you say?"],[8434,8518,"Noble Consort,"],[8529,8634,"I beg you!"],[8643,8756,"I really know I made a mistake!"],[8809,8890,"Lady Valerie,"],[8950,9014,"please forgive me"],[9014,9101,"just this once!"],[9162,9243,"Noble Consort,"],[9250,9385,"if this matter is left unsettled,"],[9415,9526,"I will definitely report"],[9526,9601,"what happened today"],[9606,9712,"to His Majesty in detail."],[9845,10043,"When His Majesty investigates,"]],"44":[[20,66,"since only Camille"],[66,235,"and I know about this,"],[252,381,"if it traces back to me"],[401,508,"then your position as Noble Consort"],[943,1009,"You insolent slave!"],[1009,1108,"How dare you slander Lady Valerie!"],[1127,1309,"Beat her to death at once!"],[3300,3447,"I never expected Lady Eva"],[3485,3584,"to be so vicious,"],[3606,3796,"killing her own maid just like that."],[3852,3921,"However,"],[3961,4115,"you certainly moved fast."],[4161,4357,"Not only did you find the doll,"],[4357,4496,"but you also swapped the note."],[4566,4621,"Well?"],[4703,4852,"When you saw the note,"],[4888,4943,"were you moved?"],[5193,5360,"In such a dangerous situation,"],[5364,5462,"I was still only wishing for"],[5462,5571,"you to live a long life."],[5606,5714,"Aren't you touched?"],[6058,6222,"I saved your life before,"],[6234,6356,"and now you've saved mine."],[6378,6548,"We're even now."],[6564,6734,"We can never be even."],[6779,6876,"We're destined"],[6954,7090,"to be entangled for a lifetime."],[7276,7356,"Nonsense."],[7865,7926,"My Lord,"],[8007,8178,"the Emperor's reply to the memorial is here."]],"45":[[554,621,"It's over."],[633,713,"I'm done for. Totally done for."],[729,811,"His Majesty surely"],[811,953,"knows about my private weapon manufacturing."],[953,1100,"He's giving me a warning."],[1296,1335,"But,"],[1425,1548,"since he wasn't explicit,"],[1600,1739,"there's still a chance."],[1762,1803,"Right."],[1848,1948,"If I hand over the weapons"],[1948,2016,"to the national treasury immediately,"],[2028,2069,"then"],[2085,2205,"it should be enough to save me."],[2464,2583,"Prince, a secret letter from the capital."],[3338,3429,"That bastard!"],[3467,3553,"Gordon actually handed the weapons"],[3553,3653,"intended for me over"],[3653,3756,"to the national treasury!"],[4028,4152,"Does this mean the Emperor already knows?"],[4184,4250,"Why didn't Eva Lynn"],[4250,4315,"report this back?"],[4338,4375,"That bitch."],[4417,4511,"She's lived the high life for too long"],[4546,4624,"and has completely forgotten"],[4624,4732,"who her true master is."],[4884,4979,"His Majesty's birthday is approaching."],[5025,5082,"Prepare a birthday gift,"],[5101,5197,"and come with me to the capital for the celebration."],[5938,6010,"Guard,"],[6010,6096,"don't you need to be on duty?"],[6157,6332,"I am on my duty right now."],[6401,6542,"It's really strange."],[6698,6770,"How are you still in the mood"],[6770,6864,"to be reading here?"],[6868,6945,"The concubines in the harem"],[6945,7007,"are all going to learn"],[7007,7101,"the Blessing Dance."],[7114,7301,"The other concubines are learning"],[7309,7450,"a Blessing Dance?"],[7487,7531,"Oh,"],[7654,7740,"Lady Eva organized it,"],[7762,7879,"claiming it's to pray for His Majesty."],[7909,8028,"Did she deliberately leave you out"],[8062,8162,"because you two don't get along?"],[8209,8340,"The Emperor is sick but won't die."],[8385,8512,"I was just worrying about how to get close to him."],[8540,8654,"Isn't this the perfect opportunity?"],[8663,8754,"In that case,"],[8787,8920,"I need to hurry and learn it too."],[8942,9012,"I can't let His Majesty"],[9012,9098,"accuse me later"],[9128,9228,"of being disrespectful."],[9473,9507,"Let's go."],[9540,9643,"Teach me the blessing dance."],[9643,9718,"Let's go."],[9929,9990,"That slut."],[10031,10112,"She must be sleeping"],[10112,10168,"with that Shadow Guard."],[10184,10285,"That's why they didn't"],[10285,10359,"dare to report"],[10359,10473,"the voodoo doll incident."],[10498,10585,"Otherwise, His Majesty"],[10585,10714,"would have issued a decree by now."],[10837,10906,"They played me"],[10906,10957,"for a fool."],[10984,11037,"My Lady,"],[11059,11185,"just as you predicted,"],[11251,11365,"Laila told Lady Valerie"],[11365,11490,"about the blessing banquet."],[11531,11585,"Good."],[11673,11784,"The fish has taken the bait."],[11795,11901,"Let's let her"],[11950,12085,"put on a good show."],[12121,12198,"Joanna,"],[12257,12364,"remember this."],[12378,12512,"For this blessing banquet,"],[12534,12600,"I certainly didn't"],[12600,12701,"invite Lady Valerie."],[12701,12869,"If anything happens to her,"],[12962,13024,"it has nothing to do"],[13024,13140,"with me."]],"46":[[511,579,"Oh my,"],[612,698,"I seem to recall"],[698,774,"that we didn't"],[774,883,"invite Lady Valerie."],[901,1083,"Praying for His Majesty is a major event."],[1100,1264,"Even Lady Iris from the Cold Palace"],[1269,1425,"was granted special permission"],[1440,1566,"by Lady Eva to attend."],[1600,1744,"How could I be absent?"],[1778,1883,"Unless,"],[1896,2137,"you sisters don't want to see me?"],[2171,2257,"Since you're already here"],[2257,2403,"who would dare to drive you away?"],[2428,2567,"Lady Eva, you are most generous."],[2750,2869,"But where is His Majesty?"],[2896,3037,"Don't tell me this prayer banquet"],[3080,3135,"is really just for"],[3135,3221,"us concubines?"],[3975,4056,"Sisters,"],[4056,4175,"drink this prayer wine."],[4246,4361,"Let the prayer banquet begin."],[5374,5561,"Is Lady Eva a drunkard?"],[5620,5753,"Why use such a big cup?"],[8064,8223,"We are going to pray to the heavens."],[8293,8448,"Lady Valerie came specially,"],[8476,8600,"so why does she refuse to get up?"],[8745,8884,"This wine is strong."],[8937,9048,"You shamelessly insisted on coming,"],[9070,9181,"and now you won't move."],[9245,9371,"If you aren't sincere,"],[9393,9493,"go back to your Flora Palace."],[10434,10476,"Your Highness,"],[10528,10607,"let me help you"],[10607,10723,"to the side hall to rest."],[10750,10806,"The prayer dance"],[10806,10945,"doesn't start for another two hours."],[13441,13580,"I'm thirsty. Is there water?"],[13669,13758,"I'll go get some right away."],[14986,15050,"Lady Valerie,"],[15074,15156,"your water is here."]],"47":[[128,191,"Speak."],[281,428,"Who told you to bring water"],[428,516,"to Lady Valerie?"],[582,609,"It was"],[651,751,"it was Lady Eva's"],[751,811,"personal maid,"],[861,903,"Joanna."],[1177,1250,"Leave the water."],[1282,1364,"Go back and report."],[1433,1591,"Do you know what to say?"],[1714,1805,"I know, I know."],[4242,4334,"You idiot."],[4417,4538,"So you've fallen right into her trap."],[4879,4914,"You"],[5000,5093,"I knew Eva Lynn"],[5093,5156,"was up to no good."],[5179,5246,"How could I possibly drink"],[5246,5343,"anything that they prepared?"],[6698,6781,"I just didn't know"],[6781,6914,"what they were planning to do next."],[9387,9595,"You're not thinking straight right now."],[10868,10942,"I'll let it slide for today,"],[10990,11156,"but I'll settle the score with you later."],[12251,12473,"The show is starting."],[13809,13856,"Slut!"],[13924,14034,"Caught in the act!"],[14106,14184,"This time,"],[14262,14350,"I don't believe His Majesty"],[14350,14441,"will spare you."]],"48":[[174,229,"You slut!"],[237,354,"How dare you defile the harem!"],[362,441,"Turn around at once!"],[450,533,"Today,"],[559,648,"I will use the blood of"],[648,762,"this adulterous pair"],[778,850,"to cleanse the harem!"],[950,1025,"Incredible."],[1117,1219,"You pair of dogs."],[1232,1341,"Right in front of me,"],[1341,1430,"you still dare to flirt?"],[1493,1593,"Truly shameless."],[1660,1696,"Guards!"],[1780,1883,"Seize them for me!"],[2050,2176,"Let's see who dares."],[2480,2521,"Your Majesty?"],[2573,2669,"Your Majesty, why is it you?"],[2769,2814,"It was clearly"],[2814,2901,"Clearly what?"],[2982,3126,"Clearly you arranged it,"],[3126,3293,"so how did it suddenly become Me?"],[3338,3435,"Is that it?"],[3528,3579,"No, no"],[3646,3688,"No"],[3789,3896,"How is it Your Majesty?"],[3920,4024,"Where exactly did things go wrong?"],[4185,4325,"When I was gravely ill in bed,"],[4396,4511,"Lady Valerie was the only one"],[4511,4578,"who dared to care for me."],[4710,4817,"But every single one of you"],[4852,5035,"actually conspired to harm me."],[5153,5338,"I think you all have too much time on your hands."],[5528,5578,"Your Majesty,"],[5688,5810,"the sisters of the harem"],[5857,5974,"were only doing this for your sake."],[6175,6370,"You certainly know how to absolve yourself."],[6509,6640,"Get out of my sight, all of you!"],[6714,6834,"You are confined to your quarters to copy scriptures."],[6937,7057,"Once Lady Valerie wakes up,"],[7120,7271,"I will decide your punishments."],[7376,7562,"Your Majesty, we're innocent!"],[7562,7650,"Shut up!"],[7821,7918,"Get out!"],[8228,8354,"Your Majesty"]],"49":[[156,345,"Lady Valerie, you're awake."],[874,977,"You tyrant!"],[983,1061,"Lady Valerie"],[1072,1227,"I'm going to kill you"],[1227,1458,"and avenge my parents!"],[2122,2185,"Lady Valerie,"],[2261,2338,"you've been drugged."],[2382,2473,"I'll take you to the bath."],[4258,4444,"Your Majesty, it's time to rise."],[4646,4696,"Your Majesty?"],[4882,4971,"I heard you."],[6270,6415,"You must suppress news of last night."],[6476,6523,"Remember,"],[6570,6695,"I am supposed to be ill right now."],[6835,6881,"Yes."],[6985,7037,"Also,"],[7134,7254,"withdraw everyone from here."],[7312,7415,"Do not wake Lady Valerie."],[7576,7693,"Rest assured, Your Majesty."],[7751,7915,"I have arranged everything."]],"50":[[433,497,"Didn't you say"],[499,613,"everyone had left?"],[694,771,"How did you miss one?"],[1124,1248,"Gr... Greetings, Your Majesty."],[1403,1477,"Rise."],[1714,1798,"This is just a little game"],[1798,1966,"between His Majesty and Lady Valerie."],[2003,2051,"You saw nothing,"],[2073,2230,"and you heard nothing."],[2282,2416,"If you can't keep your mouth shut,"],[2455,2582,"you'll lose your head!"],[2660,2764,"This game is"],[2764,2876,"a bit too intense."],[2892,2939,"Yes,"],[2998,3076,"I understand."],[3678,3789,"Goodbye, Your Majesty."],[3967,4046,"Your Majesty?"],[4265,4342,"Where is His Majesty?"],[4374,4429,"Lady Valerie,"],[4470,4561,"His Majesty just left."],[5032,5093,"Did I"],[5093,5215,"serve him in bed last night?"],[5235,5334,"Yes, Lady Valerie."],[5404,5455,"Then"],[5488,5603,"where is Ed?"],[5630,5722,"Did you see him?"],[5774,5982,"Lady Valerie, you're really committed to the act."],[5982,6121,"Ed"],[6189,6311,"left together with His Majesty."],[6490,6659,"We can never call it even."],[6678,6800,"Because we are destined to be"],[6862,7007,"entangled for a lifetime."],[7118,7264,"If he saw me serve the Emperor,"],[7323,7473,"he must be heartbroken."],[7526,7593,"It's just that"],[7625,7716,"how could I have missed"],[7718,7900,"such a perfect chance to kill him last night?"],[8021,8068,"Your Majesty,"],[8118,8243,"Prince Richard left his fief two days ago."],[8298,8381,"He is already heading to the capital."],[8414,8534,"He is returning without a decree."],[8751,8831,"Let him come."],[8909,9064,"I happen to have a score"],[9078,9165,"to settle with him."],[9312,9395,"A few days ago,"],[9395,9478,"the Vice Minister of Works"],[9478,9670,"handed over 50,000 weapons to the treasury."],[9706,9885,"I don't believe in mere coincidences."]],"51":[[636,754,"Ed?"],[758,840,"He just left"],[840,903,"with His Majesty."],[1901,1996,"You're here?"],[2005,2078,"What,"],[2078,2180,"am I not welcome?"],[2282,2387,"No,"],[2387,2562,"I just thought you'd never come back."],[2632,2728,"You're in the mood,"],[2780,2892,"drinking all by yourself."],[2939,3060,"You seem quite at ease."],[3178,3257,"Care to join me?"],[3334,3389,"Sure."],[4443,4524,"Good wine."],[6462,6679,"Am I really useless?"],[6679,6904,"My parents spoiled me growing up,"],[6914,7137,"but now that I'm alone in the palace,"],[7156,7329,"I can't seem to do anything right."],[7409,7579,"I couldn't even grasp the chance for revenge"],[7579,7695,"when it was right within my reach."],[7831,7904,"Don't say that."],[7956,8109,"I'm isolated and helpless,"],[8128,8235,"and have accomplished nothing."],[8271,8393,"Those concubines"],[8421,8581,"envy and hate me."],[8734,8918,"I really miss my parents."],[9381,9448,"His Majesty"],[9448,9581,"has revoked Lady Eva's authority"],[9581,9750,"to manage the harem."],[9764,9904,"He also punished the other concubines"],[9915,9987,"and issued an order."],[9987,10126,"From now on,"],[10128,10245,"no one is allowed to disturb you."],[10259,10426,"He can protect you in your parents' stead."],[10448,10537,"Please don't be sad."],[10668,10850,"Who cares?"],[10907,11109,"I just want my parents."],[11459,11657,"He killed them."],[11929,12065,"Actually, many things"],[12093,12171,"are not exactly"],[12171,12268,"as they appear to be."],[12345,12478,"If you still have doubts,"],[12506,12606,"I can take you out of the palace"],[12607,12701,"to find the truth."],[14147,14290,"We're actually out of the palace!"],[14386,14486,"How did you do that?"]],"52":[[24,104,"You"],[148,274,"How did you manage this?"],[458,637,"I am the Commander of the Imperial Guard,"],[667,801,"and His Majesty's most trusted aide."],[1109,1177,"Then"],[1214,1309,"His Majesty"],[1322,1424,"how is his illness?"],[1816,1948,"He is out of danger."],[1973,2094,"It seems"],[2105,2273,"I really did buy fake poison."],[2349,2528,"So where are you taking me?"],[2637,2907,"Does His Majesty know?"],[3082,3185,"He does."],[3306,3407,"By His Majesty's verbal order,"],[3461,3761,"I am to take you to uncover the truth."],[4302,4406,"This is the David family's"],[4406,4497,"main grain store."],[4625,4711,"I have reliable news"],[4787,4870,"that at the David family shops,"],[4911,5053,"every manager and clerk"],[5085,5164,"has been replaced."],[5217,5335,"This main store,"],[5388,5467,"I'm afraid,"],[5492,5652,"no longer belongs to the David family."],[5660,5793,"What?"],[5834,5950,"Has even the general manager, Fred,"],[5950,6017,"been replaced?"],[6075,6139,"Fred watched"],[6139,6250,"my father grow up."],[6295,6405,"He's getting on in years."],[6453,6525,"If he's not here,"],[6527,6637,"where else could he go?"],[7137,7218,"Hey there, customer."],[7278,7365,"What can I get for you?"],[7590,7768,"Are you the manager here?"],[7948,8028,"Is something the matter?"],[8125,8205,"Hey,"],[8451,8542,"Boss."],[8570,8678,"My brother and I"],[8678,8807,"are looking for a job here."],[8850,8920,"Are you hiring?"],[9029,9190,"You're tall and brawny,"],[9192,9321,"so you can handle hard labor."],[9392,9548,"But as for your brother,"],[9593,9756,"he's so scrawny,"],[9764,9949,"he'd be crushed to death carrying a log."],[10371,10542,"I want 1.2 pounds of millet,"],[10585,10728,"4.4 pounds of white rice,"],[10768,10937,"and 3.6 pounds of aged rice."],[10956,11098,"Calculate how much that costs."],[11132,11215,"Hold on a second."],[11507,11609,"Say that one more time."],[11718,11887,"1.2 pounds of millet,"],[11914,12062,"4.4 pounds of white rice,"],[12123,12293,"3.6 pounds of aged rice."],[12348,12492,"Figure out the total price."]],"53":[[184,372,"1.2 pounds of millet is"],[372,462,"78 copper coins."],[520,716,"4.4 pounds of white rice is"],[737,910,"1,232 copper coins."],[1001,1183,"3.6 pounds of aged rice is"],[1338,1477,"756 copper coins."],[1488,1591,"The total is"],[1612,1798,"2,066 copper coins."],[1962,2128,"Wow, impressive."],[2142,2278,"I didn't expect a little pipsqueak like you"],[2278,2416,"to be so good at mental math."],[2511,2629,"My brother here"],[2637,2883,"has always been sharp."],[2903,3009,"Hmm."],[3261,3325,"Fine."],[3325,3434,"You can stay"],[3443,3560,"and work as a clerk."],[3657,3774,"Thank you, Manager."],[5039,5152,"Even with that scar on his face,"],[5192,5296,"he's quite handsome."],[5421,5546,"Strong arms,"],[5574,5706,"and a tall, fit build."],[5706,5796,"He's a real catch."],[5897,5960,"What are you doing?"],[5960,6039,"Let go of me!"],[6232,6371,"This is the manager's wife."],[6485,6584,"Lady Boone, are you alright?"],[6662,6784,"Is this the new laborer?"],[6865,6909,"Yes."],[7106,7206,"Hello, Lady Boone."],[7235,7321,"I'm Dave."],[7343,7443,"Just Dave is fine."],[7609,7662,"Alright, alright."],[7662,7742,"Get to work."],[7871,7929,"Lady Boone,"],[7937,8054,"the manager is in the counting house at the back."],[8056,8123,"I'll take you there."],[9228,9351,"Are you a woman?"]],"54":[[82,279,"Lady Boone, you're joking."],[455,601,"He's just short and skinny,"],[601,737,"and acts like a sissy."],[1655,1732,"The staff here"],[1732,1842,"really have all been replaced."],[1842,1971,"I don't recognize anyone."],[2210,2316,"Hey, new guys."],[2419,2496,"Yes?"],[2514,2630,"Brothers,"],[2635,2710,"show them some hospitality."],[2710,2779,"We two brothers"],[2800,2900,"I'm Dave."],[2905,2987,"Just call me Dave, that's fine."],[3073,3211,"This is my cousin,"],[3232,3346,"Steven."],[3356,3467,"From now on,"],[3467,3617,"you can just call him Steven."],[3617,3706,"Good to know."],[3721,3811,"I'm Frank."],[3817,3884,"You can call me Frank."],[3957,4038,"- Frank. - Frank."],[4139,4278,"You two are from out of town."],[4329,4475,"But looking at this cousin of yours,"],[4475,4561,"why is he so"],[4561,4652,"soft and delicate?"],[4671,4785,"He looks just like a woman."],[4785,4902,"Really? Let me see."],[5146,5228,"Don't be shy."],[5232,5328,"Let me have a look too."],[5328,5614,"Hahaha."],[5742,5814,"Madam."],[5829,5902,"Madam."],[5975,6060,"You."],[6088,6207,"Come to my room,"],[6225,6325,"I need help moving a chest."],[6342,6400,"Me?"],[6442,6521,"Hey, Madam."],[6521,6607,"I just ate and have plenty of energy."],[6615,6721,"I'll help you move it."],[6764,6837,"Yeah, exactly."],[6837,6928,"Madam, me too."],[6928,6995,"No need."],[7112,7204,"Let the new guy do it."],[7234,7335,"It's just moving a shelf."],[7540,7593,"Let's go."],[8065,8145,"Steven,"],[8221,8368,"go get a bowl of rice,"],[8437,8579,"and take it to the woodshed over there."],[8691,8754,"Huh?"],[8800,8895,"Do as you're told."],[8895,8965,"Hurry up."],[9269,9634,"Hahahaha!"],[10351,10450,"Get lost!"],[10693,10912,"You're all bad guys!"],[10964,11090,"Fred."]],"55":[[239,277,"Get lost!"],[454,536,"That old lunatic hits people."],[536,644,"He strikes to kill."],[671,750,"Be careful."],[750,803,"Hey, you."],[843,924,"Put the food on the ground,"],[924,985,"and make a run for it."],[985,1120,"Hahaha!"],[1130,1238,"Fred,"],[1238,1330,"it's me, Clara."],[1332,1396,"Fred?"],[1546,1657,"Miss,"],[1705,1801,"you're back?"],[1812,1926,"Fred,"],[1935,2087,"what exactly happened?"],[2087,2178,"Someone"],[2198,2351,"suddenly showed up with the Master's seal,"],[2369,2519,"dismissed all the staff,"],[2569,2776,"and forcibly took over the grain shop."],[3578,3734,"These seals of the David family,"],[3734,3920,"you can take them back to the Master now."],[3938,4160,"Put in a good word for me."],[4237,4324,"Once the David family"],[4342,4433,"collects all of"],[4433,4497,"this year's grain,"],[4546,4615,"you must arrange"],[4642,4753,"for it all to be sent to Dinturn."],[4761,4824,"Yes, sir."],[5093,5229,"Who exactly are you people?"],[5229,5360,"You can't take the grain away!"],[5379,5520,"Let me go! Let me go!"],[5807,5889,"The David family's eldest miss"],[5889,5964,"hasn't been found yet."],[5964,6078,"Let go! Release me!"],[6078,6161,"Keep this old thing,"],[6161,6221,"he can still serve as bait."],[6252,6356,"Let me go!"],[7140,7218,"Lock him up."],[7420,7529,"Since that day,"],[7685,7854,"I feigned madness to survive,"],[8004,8159,"just to wait for your return."],[8537,8665,"This is something I ripped"],[8665,8754,"off of them."],[8851,8919,"This"]],"56":[[250,333,"This is"],[620,803,"This is a Royal Guard's badge."],[835,969,"The dog Emperor."],[1015,1215,"Let's see how he denies it now."],[1253,1349,"His Majesty?"],[1356,1472,"But they want to transport the grain"],[1474,1664,"to Dinturn for storage."],[1664,1832,"That is Prince Richard's territory."],[1880,1957,"Prince Richard?"],[2087,2187,"His Majesty"],[2203,2326,"Those two brothers,"],[2326,2464,"what exactly are they up to?"],[3089,3180,"Boss,"],[3185,3279,"that new guy, Steven,"],[3279,3424,"was talking to that crazy old man."],[3542,3619,"What?"],[3703,3888,"I knew there was something off about him."],[4234,4339,"Capture him alive."],[4361,4488,"I want to see"],[4524,4720,"who he really is."],[4803,4835,"Understood."],[5624,5720,"You old thing,"],[5784,5875,"did the David family's eldest miss"],[5875,5957,"come around here?"],[6038,6175,"You are dog sh*t."],[6210,6274,"No,"],[6288,6388,"you eat dog sh*t."],[6388,6492,"You all eat dog sh*t."],[6687,6931,"Still pretending to be crazy?"],[7134,7215,"Let me tell you,"],[7251,7334,"when I find her,"],[7378,7518,"I'll make her wish she were dead."],[8445,8631,"Run!"],[8785,8979,"You reckless old fool."],[9131,9226,"Why are you just standing there?"],[9233,9297,"Go find them!"],[9309,9426,"Yes! Let's go! Hurry!"],[9557,9635,"Dave!"],[9707,9843,"Edward, where are you?"],[10587,10759,"Dave, be gentle."],[10787,10943,"I can't take it anymore."]],"57":[[743,906,"You slut!"],[1111,1183,"Husband!"],[1183,1356,"L-Listen to me explain!"],[1356,1403,"No"],[1411,1535,"He blindfolded me,"],[1550,1585,"he"],[1603,1714,"he tricked me saying it was you."],[1746,1926,"Do you take me for a fool?"],[1967,2094,"You dare to cheat on me"],[2094,2189,"right under my nose?"],[2282,2417,"I'll kill this adulterer first."],[2773,2876,"Frank."],[2930,3076,"Why is it you?"],[3323,3464,"You double-crossing traitor."],[3491,3603,"I'll kill you!"],[4009,4147,"You promiscuous tramp."],[4147,4271,"You can die too!"],[4771,4828,"Go,"],[4910,4997,"search!"],[5052,5142,"Find Dave and Steven"],[5142,5214,"for me right now!"],[5232,5307,"Yes!"],[5971,6025,"It's me."],[6303,6418,"Over here, Boss."],[6418,6465,"Chase!"],[7507,7626,"Boss, they're here."],[7768,7868,"Boss, look."],[7931,7981,"After them!"],[7998,8128,"Kill them for me!"],[8128,8193,"Yes!"],[10207,10279,"Spare me, sir!"],[10293,10423,"I'm just a manure hauler."]],"58":[[165,341,"Boss, it's all liquid manure. Pfft!"],[548,636,"After them!"],[835,907,"Wait for me!"],[2351,2500,"I'm so glad you're okay."],[2711,2800,"But"],[2832,2996,"why did Lady Boone"],[3096,3329,"think it was you"],[3356,3429,"in bed with her?"],[3429,3600,"That's impossible."],[3721,3850,"She tried to seduce me,"],[3879,4035,"so I tricked her into wearing a blindfold,"],[4052,4156,"and then"],[4202,4361,"I lured Frank in there instead."],[4389,4458,"Huh?"],[4492,4635,"I originally planned"],[4635,4739,"to tell Harold"],[4739,4825,"about their affair"],[4882,5017,"to lure him away,"],[5047,5167,"so I could sneak into the accounting room"],[5182,5284,"and steal the ledger."],[5378,5457,"But surprisingly,"],[5484,5610,"Harold wasn't even in the accounting room."],[5660,5807,"I guessed you might be in trouble,"],[5828,5952,"so I rushed over to save you."],[6125,6215,"So that's what happened."],[6356,6435,"Sadly,"],[6523,6706,"Fred was killed."],[6965,7143,"He was used as bait to lure me back."],[7170,7309,"He endured humiliation to survive"],[7409,7512,"just for the chance"],[7512,7606,"to see me again."],[7656,7735,"He told me"],[7790,7881,"that my parents' death"],[8004,8095,"is linked to His Majesty"],[8187,8301,"and Prince Richard."],[8301,8442,"They are both involved."],[8442,8504,"Huh?"],[8504,8620,"How am I involved?"],[8745,8806,"I mean"],[8835,8992,"What does His Majesty have to do with this?"],[9490,9543,"Look,"],[9554,9670,"it's all recorded in this ledger."],[9670,9798,"Most of the grain"],[9812,9968,"was transported to Prince Richard's fief,"],[9993,10065,"Dinturn."],[10231,10320,"I see now."],[10531,10651,"His Majesty and Prince Richard—"],[10681,10829,"neither of them is any good."],[10829,10993,"I will definitely avenge"],[11006,11065,"my father, mother,"],[11065,11168,"and Fred."],[11171,11270,"I'll make them pay."],[11507,11645,"My dear royal brother,"],[11645,11728,"you really don't"],[11728,11862,"look out for me at all."],[11988,12088,"Pick up the pace."],[12092,12222,"We must reach the capital within three days."],[12235,12304,"Yes, sir!"]],"59":[[439,555,"Greetings, Noble Consort."],[608,736,"I wasn't aware of your arrival,"],[758,877,"so please forgive my poor welcome."],[911,1041,"Where is Lady Valerie?"],[1130,1290,"I may no longer manage the harem,"],[1322,1507,"but I am still the only Noble Consort."],[1604,1710,"His Majesty said"],[1710,1794,"that the concubines"],[1796,1894,"should not disturb Lady Valerie,"],[1969,2054,"but he didn't say"],[2064,2166,"she was exempt from paying"],[2166,2296,"her respects to me."],[2393,2516,"Please forgive us, Noble Consort."],[2603,2739,"My Lady"],[2769,2855,"is ill."],[2897,2965,"Oh?"],[3021,3123,"Ill?"],[3220,3442,"My spies have been watching for days."],[3493,3633,"Valerie Ian hasn't set foot outside,"],[3652,3742,"nor has she summoned an imperial physician."],[3797,3865,"There must be"],[3878,3961,"something suspicious going on."],[4170,4264,"You insolent servant,"],[4292,4470,"how dare you lie to the Noble Consort!"],[4538,4600,"I"],[4625,4693,"I wouldn't dare"],[4693,4800,"lie to you, Noble Consort."],[4825,4906,"Oh?"],[4975,5206,"So Lady Valerie is truly ill?"],[5225,5311,"Then I shall"],[5311,5443,"pay her a visit right now."],[5679,5810,"Noble Consort, please don't!"],[5810,5964,"My Lady is very sick,"],[5964,6120,"and she might infect you."],[6132,6284,"You wretched maid, still lying!"],[6288,6360,"The Imperial Academy of Medicine"],[6360,6473,"has no record of such a condition."],[6476,6606,"What sort of illness is she claiming to have?"],[6690,6759,"She is deceiving me."],[6759,6814,"It's obvious she just"],[6814,6934,"has no respect for me."],[6942,7031,"The palace rules clearly state"],[7042,7143,"that concubines cannot"],[7143,7240,"miss morning greetings without cause."],[7240,7368,"She clearly has no respect"],[7372,7471,"for the palace rules either."],[7751,7837,"Noble Consort, please stop!"],[7852,7950,"Noble Consort!"],[8021,8254,"My Lady is truly ill!"],[8254,8378,"Then I must see for myself"],[8462,8614,"just how sick she really is."]],"60":[[237,345,"But"],[385,494,"Noble Consort"],[641,696,"You"],[724,808,"Don't tell me"],[1182,1333,"that you have tuberculosis?"],[1985,2164,"Noble Consort,"],[2226,2403,"I am indeed gravely ill,"],[2450,2771,"which is why I failed to pay my respects."],[2873,2919,"If you are ill,"],[2919,3064,"why didn't you summon an imperial physician?"],[3133,3243,"Noble Consort,"],[3264,3352,"My Lady"],[3352,3464,"started feeling unwell last night."],[3482,3620,"She thought sleeping it off would help,"],[3652,3784,"but it suddenly worsened,"],[3815,3978,"so we haven't had time to summon an imperial physician."],[4552,4597,"If she's sick,"],[4599,4693,"go summon an imperial physician immediately!"],[4720,4775,"I"],[4815,4911,"I'll be leaving now."],[5374,5543,"That must have scared them to death."],[5802,5870,"Lena,"],[5896,5974,"I'm sorry."],[6014,6129,"I'm sorry for putting you through this."],[6364,6454,"My Lady,"],[6479,6628,"you're finally back."],[6628,6746,"It's good to have you back."],[6814,6912,"You have no idea"],[6931,7092,"I was terrified these past few days."],[7831,7992,"I was the one who took your Lady away."],[8378,8493,"Here,"],[8531,8712,"take this as compensation."],[9057,9137,"Go on, take it."],[9237,9318,"Thank you, My Lady."],[9392,9534,"I'll go fetch some water for you to wash your hands."],[9821,9884,"I always thought"],[9884,9987,"Lady Eva was just stupid."],[10026,10148,"I didn't expect that in front of you,"],[10159,10272,"she'd be both stupid and malicious."],[10272,10421,"Shh!"],[10421,10498,"How can you say such things"],[10498,10548,"inside the palace?"],[10548,10642,"You can't just speak so recklessly."],[10678,10798,"This is the Imperial Palace."],[10840,10943,"I've noticed"],[10943,11128,"you always speak without restraint."],[11184,11287,"How on earth have you"],[11287,11401,"survived in the palace?"],[11518,11631,"I've already told you,"],[11671,11750,"I am the Emperor."],[11750,11873,"'s current favorite."],[11951,12031,"But you still don't believe me."],[12629,12697,"What's wrong?"],[12743,12843,"You're helping me investigate"],[12843,12919,"my family's case,"],[12959,13103,"but the Emperor is involved."],[13128,13256,"So if you had to choose"],[13256,13337,"between me and the Emperor,"],[13387,13493,"whose side"],[13493,13671,"would you be on?"]],"61":[[155,320,"Naturally, I'm on your side."],[407,552,"But since Prince Richard is involved,"],[625,729,"you and the Emperor"],[729,814,"might not be enemies."],[848,1006,"We still need to investigate thoroughly."],[1069,1203,"Just promise you won't be impulsive"],[1232,1359,"and try to assassinate him again."],[1421,1475,"Okay."],[1503,1698,"I will wait for the results,"],[1821,1923,"then I'll bring the people"],[1923,2017,"who murdered my parents"],[2017,2100,"to justice."],[2273,2366,"But"],[2383,2478,"Prince Richard"],[2500,2617,"is far away in Dinturn."],[2653,2801,"How can I investigate him?"],[2944,3037,"Well"],[3153,3193,"Your Maj"],[3193,3289,"Shut your mouth!"],[3300,3388,"Mr. Cury,"],[3589,3710,"you're disturbing the Noble Consort."],[3965,4096,"I was out of line."],[4114,4229,"My apologies, Noble Consort."],[4243,4335,"Please forgive me."],[4356,4443,"It's alright, Mr. Cury."],[4502,4638,"What brings you here?"],[4743,4846,"Mr... Mr. Edward,"],[5103,5210,"Prince Richard is here."],[5389,5524,"Prince Richard is here?"],[5622,5688,"Yes."],[5760,5956,"Prince Richard is here."],[5979,6125,"Prince Richard is here"],[6217,6365,"What business is it of his?"],[6365,6467,"- Uh... - Um"],[6565,6712,"His Majesty is still ill."],[6731,6829,"Now that Prince Richard has arrived,"],[6871,7043,"His Majesty must be summoning me back to protect him."],[7151,7224,"Yes."],[7340,7565,"He needs Mr. Edward's protection."],[7787,7940,"Then you'd better go attend to your duties."],[8326,8440,"His Majesty is ill,"],[8526,8621,"and Prince Richard is here."],[8656,8878,"Ed went over to protect His Majesty."],[8959,9045,"That means"],[9078,9185,"His Majesty and Prince Richard"],[9204,9329,"are on bad terms."],[9340,9479,"Which implies that"],[9479,9607,"my parents were not killed"],[9607,9718,"by their conspiracy."],[10271,10451,"The clues are all on this token."],[10528,10618,"Prince Richard"],[10684,10850,"Since you've delivered yourself to my doorstep,"],[10884,11043,"I have no choice but to investigate you."],[11179,11350,"Father, Mother,"],[11426,11559,"are you helping me?"],[12293,12365,"Lena,"],[12392,12515,"help me get ready, quickly."],[12554,12657,"Are you going out, My Lady?"],[12781,12915,"Aren't you feigning illness?"],[13018,13097,"Prince Richard is here."],[13137,13243,"I going to meet him."]],"62":[[227,308,"Lady Valerie,"],[356,478,"His Majesty has summoned the Prince."],[544,662,"Please return to your quarters."],[737,903,"I haven't seen His Majesty in a long time,"],[916,1051,"and I am truly worried about him."],[1091,1201,"I just want to go in for a look."],[1230,1309,"Just one look."],[1382,1466,"My Lady,"],[1540,1650,"you know the rules."],[1653,1762,"His Majesty"],[1778,1917,"is still ill."],[2021,2178,"Please come back when"],[2178,2269,"he summons you."],[2726,2796,"Is Lady Valerie"],[2835,3012,"a concubine appointed by His Majesty?"],[3044,3123,"Yes."],[3621,3792,"Greetings, Your Majesty."],[3925,3978,"Rise."],[4189,4270,"Your Majesty,"],[4314,4471,"Mr. Cury was just outside,"],[4471,4630,"turning Lady Valerie away"],[4633,4792,"claiming you were gravely ill."],[4817,4915,"But I can see"],[4929,5092,"that Your Majesty is in good health,"],[5097,5211,"with no sign of illness."],[5235,5350,"Did you travel all this way, Richard,"],[5350,5478,"returning to the capital without a decree,"],[5547,5670,"just to see"],[5747,5870,"if I was sick?"],[5910,6129,"Oh, surely not."],[6129,6300,"The rule about returning without a decree"],[6317,6459,"does not apply to me."],[6468,6581,"Because I possess"],[6765,6820,"the Immunity Medallion"],[6850,6968,"gifted by our Imperial Grandfather."],[6973,7065,"According to ancestral rules,"],[7065,7245,"it exempts me"],[7254,7462,"from all punishment."],[7693,7754,"Does that mean"],[7835,7940,"you can do whatever you want,"],[7940,8073,"Richard?"],[8134,8265,"You exaggerate, Your Majesty."],[8285,8387,"I wouldn't dare."],[8468,8595,"My loyalty to you"],[8595,8743,"is absolute."],[8795,8920,"I returned this time"],[8926,9043,"to celebrate your birthday"],[9087,9276,"at the Thousand Autumn Feast next month."],[9315,9487,"How thoughtful of you, Richard."],[9487,9654,"To still worry about my health."],[9654,9779,"You have traveled hard day and night,"],[9834,9959,"so go back to the manor and rest for now."],[10006,10065,"Your Majesty,"],[10200,10364,"I haven't returned to the capital for years."],[10398,10521,"I would like to visit my mother's"],[10521,10598,"Solar Palace first."],[10614,10714,"I hope Your Majesty"],[10759,10845,"will grant permission."],[10954,11034,"Very well."],[11121,11200,"It just so happens that"],[11200,11328,"we have a new group of dancers this year."],[11393,11493,"Later,"],[11531,11659,"I will send them to your manor"],[11715,11834,"to perform for you"],[11834,11979,"as a welcome reception."],[12006,12092,"I thank"],[12193,12340,"Your Majesty."],[15062,15150,"Long time no see,"],[15156,15231,"Noble Consort."]],"63":[[32,113,"Greetings, Prince."],[113,254,"You've taken good care of this tree."],[254,381,"You planted it with your own hands,"],[381,520,"so naturally, I would tend to it with care."],[520,698,"You haven't written to me in quite a while."],[698,801,"I was starting to think"],[835,1022,"you had forgotten who your master is."],[1141,1225,"Eva wouldn't dare."],[1259,1350,"Heaven is my witness."],[1358,1432,"I was regularly"],[1432,1527,"dosing His Majesty before."],[1533,1619,"The fact that no one in the harem"],[1619,1680,"has produced an heir"],[1692,1766,"is proof enough."],[1807,1910,"That was before."],[2012,2114,"What about now?"],[2144,2219,"Now,"],[2403,2542,"a newcomer has seduced His Majesty."],[2542,2687,"I haven't been able to get near him for ages."],[2701,2823,"It's that Lady Valerie."],[2846,2894,"Yes."],[2907,3057,"She is the Emperor's favorite now."],[3101,3169,"In the harem,"],[3211,3324,"she stands unrivaled."],[3324,3417,"His sole favorite?"],[3725,3870,"Your good days"],[3870,3984,"are over."],[4007,4134,"Oh, Lady Valerie."],[4184,4356,"Prince Richard possesses immense power."],[4356,4506,"I'm using him to kill you."],[4534,4639,"Let's see if you can escape this time."],[4725,4828,"Although Ed said"],[4839,4924,"he would stand by me,"],[4924,5057,"this matter"],[5057,5250,"involves Prince Richard and the Emperor,"],[5250,5417,"two men with absolute power."],[5424,5521,"It's best not to drag Ed"],[5521,5602,"into this."],[5603,5702,"The David family's seal was sent"],[5702,5820,"to their master."],[5828,5942,"If I can find the seal"],[5942,6024,"at Prince Richard's place,"],[6024,6146,"it will prove that he is"],[6148,6274,"the murderer of my parents."],[6335,6468,"Greetings, Lady Valerie."],[6468,6542,"Rise."],[6556,6665,"Where are you all going?"],[6692,6759,"His Majesty ordered us"],[6790,6935,"to perform at Prince Richard's Manor."],[7992,8200,"I've finally found you, Prince Richard."]],"64":[[1088,1135,"You."],[1406,1494,"Come here."],[2446,2548,"You smell so good."],[2568,2728,"He's truly the Emperor's brother;"],[2807,2948,"just as lecherous."],[3046,3126,"Oh, stop it."],[3638,3679,"Here,"],[3718,3800,"have a drink, Your Highness."],[4138,4188,"I'm sorry."],[4234,4321,"I'm sorry, Your Highness."],[4332,4397,"It's fine."],[4467,4565,"You're just in time, beauty."],[4565,4710,"Help me change my clothes."],[5820,5860,"Your Majesty,"],[5924,6024,"Lady Valerie disguised herself as a dancer"],[6043,6106,"and went to Prince Richard's Manor."],[6247,6310,"What?"],[6623,6784,"I see you are naturally enchanting"],[6864,6984,"and seductive to the bone."],[7062,7095,"Come here."],[7185,7287,"Let me see just what kind of"],[7345,7526,"peerless beauty you are."],[8484,8609,"My deployment token"],[8768,8793,"You"]],"65":[[12,82,"How do you have the token"],[82,163,"of one of my subordinates?"],[178,256,"Who are you?"],[296,396,"I am the Princess of Westland,"],[421,474,"Laila."],[850,1053,"The Emperor of Westland really went all out,"],[1053,1167,"sending a Princess"],[1167,1253,"to be a sleeper agent."],[1258,1327,"A sleeper agent?"],[1343,1446,"Prince Richard is actually"],[1446,1564,"secretly colluding with Westland."],[1644,1714,"However,"],[1735,1821,"for a grand Princess,"],[1846,1945,"you've only managed to become"],[1947,2067,"a lowly dancer."],[2076,2151,"You can't even get close enough"],[2151,2233,"to serve the Emperor."],[2267,2364,"What use are you?"],[2380,2537,"Your Highness is mistaken."],[2544,2723,"Although I am just a lowly dancer,"],[2739,2853,"I have my freedom,"],[2853,3028,"which makes it easy to gather intel."],[3050,3210,"If what Your Highness needs"],[3210,3328,"is a temptress to ruin the nation,"],[3328,3484,"I can also"],[3484,3579,"seduce the Emperor."],[3925,3996,"Richard,"],[4052,4174,"I've come to welcome you back."],[4303,4421,"Here is your chance."],[4452,4511,"Tonight,"],[4534,4638,"I will give you"],[4638,4696,"a helping hand."],[5371,5484,"Your Majesty, you arrived so suddenly,"],[5510,5650,"please forgive me for not welcoming you properly."],[5678,5784,"I saw that the moon is lovely tonight,"],[5784,5888,"and coincidentally,"],[5888,5928,"Westland sent tribute"],[5934,5997,"of some fine wine,"],[5997,6070,"so I thought"],[6085,6165,"that us two brothers,"],[6165,6274,"should drink to our hearts' content"],[6300,6492,"tonight."],[6514,6584,"Thank you, Your Highness."],[6642,6690,"Have a seat."],[7906,7957,"Miss,"],[7970,8107,"the Prince orders you to change"],[8109,8245,"and dance for His Majesty."],[8265,8301,"His Majesty?"],[8323,8423,"If I do that, the fact that I sneaked out"],[8423,8528,"will be exposed."],[8579,8618,"Okay."],[8642,8701,"Just a moment."],[9219,9301,"Didn't I say"],[9301,9391,"to wait a moment?"],[9541,9591,"Miss,"],[9591,9691,"please hurry."]],"66":[[352,394,"Great."],[440,483,"This way, the Emperor"],[483,571,"won't rely be able to see my face."],[1183,1230,"Come."],[2533,2626,"I recently titled"],[2626,2707,"a new consort, Lady Valerie."],[2707,2851,"She dances just like her"],[2873,2978,"Stunning."],[3003,3121,"Speaking of which,"],[3121,3347,"I really do miss Lady Valerie."],[3365,3438,"Derrick."],[3467,3556,"I'm here."],[3607,3657,"Let's go."],[3725,3800,"Back to the palace."],[3960,4029,"Whoa, slow down."],[4029,4114,"- Your Majesty! - Your Majesty!"],[4247,4302,"Your Majesty,"],[4329,4397,"you've had too much to drink."],[4415,4470,"Why not stay"],[4485,4574,"at the Manor tonight?"],[4640,4742,"No, no."],[4742,4942,"I want to go see Lady Valerie."],[4942,5125,"I want her to serve me."],[5292,5375,"Your Majesty,"],[5402,5500,"I will send someone"],[5515,5620,"to take good care of you."],[6828,6884,"Don't scream."],[6926,6976,"It's me."],[7326,7440,"Why are you here?"],[7481,7621,"Don't even ask."],[7629,7737,"When I heard you snuck into"],[7737,7787,"Prince Richard's Manor,"],[7787,7884,"I was worried sick."],[7892,7956,"So I urged The Emperor"],[7956,8051,"to hold a reception for Prince Richard."],[8165,8220,"By the way,"],[8257,8318,"where is The Emperor?"],[8370,8454,"Why didn't he come?"],[8468,8571,"The Emperor went back to the palace."],[8615,8671,"What's wrong?"],[8768,8878,"Prince Richard"],[8920,9020,"is colluding with Westland."]],"67":[[0,84,"How do you know that?"],[187,260,"I have to start"],[281,405,"from the beginning."],[563,654,"This waist token"],[654,737,"is what Fred"],[755,843,"tore off one of the thieves"],[843,967,"who was smuggling grain"],[967,1040,"back then."],[1146,1259,"Why didn't you tell me"],[1285,1406,"about this sooner?"],[1511,1553,"Because"],[1642,1771,"avenging my parents"],[1844,1946,"involves His Majesty"],[1985,2055,"and Prince Richard—"],[2094,2182,"the two most powerful men"],[2182,2289,"in Xialand."],[2309,2423,"I didn't want to get you involved."],[2576,2682,"Even so, you shouldn't"],[2687,2821,"put yourself in danger."],[2826,2887,"Do you have any idea"],[2887,2962,"how worried I was about you?"],[3109,3208,"It won't happen again."],[3429,3506,"I'm just glad you're okay."],[3807,3925,"But how did Prince Richard send you"],[3925,4010,"to serve His Majesty?"],[4200,4278,"I disguised myself"],[4285,4411,"as Laila"],[4411,4482,"to sneak in."],[4496,4618,"I originally planned"],[4618,4803,"to drug Prince Richard,"],[4850,4979,"then search his palace"],[4989,5132,"to see if my family's signet"],[5132,5228,"was still there."],[5242,5368,"But I was clumsy,"],[5378,5478,"and by sheer accident,"],[5514,5629,"I dropped the waist token."],[5650,5760,"So I lied to him"],[5760,5846,"and claimed I was"],[5874,5964,"a spy sent by Westland"],[5964,6065,"to make contact with him."],[6197,6279,"It's a good thing"],[6279,6448,"that luck was on your side."],[6506,6581,"Otherwise, if anything"],[6581,6643,"had happened to you,"],[6643,6768,"what would I have done?"],[6935,7149,"Alright, I'm sorry."],[7160,7235,"It won't happen again."],[7243,7370,"We have to tell His Majesty about this."],[7395,7493,"I'll go tell him right now."],[7700,7795,"Prince Richard has a Gold Medal of Immunity."],[7815,7962,"Even if he commits a heinous crime,"],[7962,8009,"His Majesty cannot"],[8009,8079,"punish him for it."],[8098,8209,"A Gold Medal of Immunity?"],[8262,8329,"Emperor Ted"],[8335,8418,"bestowed it upon him."],[8423,8492,"Then we'll go"],[8542,8726,"and steal it."],[10364,10450,"- Master! - Run!"],[10452,10620,"Run! Hurry!"],[10644,10770,"It really was you."],[10792,10954,"You killed my parents"],[10954,11182,"and seized the David family's fortune."]],"68":[[20,117,"So what?"],[121,225,"Thank you for your help, Prince Richard."],[247,301,"The deed is done."],[326,384,"I have something"],[402,479,"to present to you."],[516,545,"Oh?"],[583,654,"What is it?"],[1654,1713,"Father,"],[1725,1783,"Mother,"],[1787,1825,"I swear,"],[1829,2033,"I will avenge you."],[5408,5529,"Was that a dream?"],[5820,5962,"Greetings, Your Majesty."],[6160,6248,"Lady Valerie,"],[6287,6366,"what brings you here?"],[6541,6654,"I have come here"],[6679,6833,"to confess my crimes to Your Majesty."],[6867,6921,"Oh?"],[7070,7225,"What do you have to confess?"],[7345,7458,"I deserve to die."],[7483,7554,"I have committed the crimes"],[7558,7625,"of deceiving the Emperor"],[7633,7787,"and attempted regicide."],[7883,7954,"Oh."],[7985,8139,"How exactly did you deceive me?"],[8158,8262,"And how exactly"],[8279,8387,"did you attempt to assassinate me?"],[8410,8472,"I"],[8483,8637,"am not the dancer Valerie Ian."],[8641,8766,"My true identity is"],[8770,8929,"the daughter of the royal purveyor, Joseph,"],[8937,9008,"Clara."],[9012,9112,"That was my deception."],[9120,9216,"My parents"],[9229,9325,"were murdered by villains."],[9329,9425,"I mistakenly believed"],[9437,9554,"that it was on your orders,"],[9566,9662,"so I entered the palace"],[9687,9808,"to seek revenge for them."],[9812,10041,"Your Majesty's prolonged illness"],[10062,10091,"was"],[10112,10358,"was caused by the poison I administered."],[10391,10612,"That was the attempted regicide."],[11137,11316,"I know my sins are grave."],[11350,11512,"But I have come today"],[11516,11658,"to report an urgent matter."],[11666,11787,"I do not presume"],[11791,11875,"to atone for my crimes."],[11887,12012,"I only hope Your Majesty"],[12016,12158,"will punish the wicked"],[12162,12287,"and bring justice to my parents."],[12425,12550,"Lift your head."],[12637,12733,"Look at me."]],"69":[[170,266,"Ed?"],[1289,1397,"You are the Emperor."],[1870,1920,"Clara."],[1976,2038,"Derrick."],[2116,2229,"Yes, Your Majesty."],[2450,2508,"Oh my!"],[2608,2729,"What's wrong with Lady Valerie?"],[2741,2816,"Hurry, hurry!"],[2841,2887,"Your Majesty!"],[3369,3423,"My Lady!"],[3470,3570,"Derrick,"],[3604,3712,"do something quickly!"],[3825,3866,"Your Majesty,"],[3891,3970,"pardon my offense."],[4574,4622,"She's awake."],[4625,4716,"She's awake, Your Majesty!"],[4900,4937,"Clara"],[5171,5212,"You"],[5325,5412,"You really are the Emperor?"],[5975,6059,"Lady Valerie,"],[6083,6137,"Ed"],[6141,6204,"is His Majesty."],[6225,6275,"And His Majesty"],[6279,6362,"is Ed."],[6406,6565,"That first time"],[6637,6704,"we met in the palace,"],[6779,6912,"you mistook me for a guard."],[7025,7091,"I just thought"],[7141,7212,"I'd tease you a bit."],[7275,7312,"But I never expected"],[7316,7438,"the misunderstanding to grow so big."],[7579,7708,"I didn't mean to deceive you."],[7791,7887,"If anything,"],[7966,8087,"it's a good thing you lied."],[8204,8279,"Otherwise, I fear"],[8366,8466,"I truly would have committed"],[8470,8575,"regicide."],[8841,8929,"So you knew all along"],[8933,9036,"that I wanted to kill you,"],[9125,9250,"yet you still helped me find"],[9250,9391,"my parents' murderer?"],[9550,9637,"Since I was framed,"],[9754,9829,"I had to prove"],[9833,9916,"my innocence to you."],[10525,10641,"Why are you crying?"],[11210,11287,"It was the least I could do."],[11403,11460,"Oh my!"],[11520,11695,"Congratulations, Your Majesty, My Lady."],[11708,11783,"This misunderstanding"],[11808,11929,"is finally cleared up."],[12025,12120,"Lady Valerie,"],[12154,12241,"His Majesty treats you"],[12245,12323,"with"],[12337,12525,"genuine affection."],[12687,12750,"Your Highness,"],[12783,12887,"news from the palace."],[12912,13021,"Princess Laila of Westland"],[13050,13133,"has been titled a Noble Lady"],[13152,13225,"and granted residence"],[13245,13362,"in Lady Valerie's Flora Palace."],[13587,13712,"She is a clever one."],[13837,13950,"I just happen to need someone"],[13954,14058,"to deal with Lady Valerie."],[14116,14270,"She will be a useful weapon."]],"70":[[0,170,"What exactly did you do?"],[195,241,"Why is it that"],[244,366,"after returning from Prince Richard's Manor,"],[394,445,"I was immediately made"],[450,544,"the Emperor's consort?"],[650,783,"I used your name."],[825,983,"Now Prince Richard thinks"],[985,1091,"I am his secret agent."],[1141,1308,"I have to keep you safe."],[1366,1433,"Why?"],[1494,1679,"Don't you want to be the Emperor's consort?"],[1725,1775,"No."],[1875,1983,"Ever since I was born,"],[2025,2129,"I have been raised"],[2133,2200,"to be nothing but a pawn."],[2262,2377,"I finally escaped"],[2377,2491,"the cage of"],[2495,2554,"the Westland royal family."],[2587,2642,"Why would I want to"],[2642,2787,"enter another cage?"],[2966,3104,"If you don't want to,"],[3145,3204,"I will plead with His Majesty"],[3208,3291,"in the future"],[3325,3487,"to let you leave the palace, alright?"],[3616,3683,"Really?"],[3713,3779,"Of course."],[3845,3925,"After all,"],[3970,4079,"I am His Majesty's"],[4129,4220,"favorite concubine."],[4335,4491,"His Majesty's oral edict!"],[5229,5375,"Lady Valerie, Clara David,"],[5408,5512,"spoke inappropriately"],[5541,5662,"in the Imperial Study"],[5679,5808,"and offended His Majesty."],[5833,5945,"You are hereby ordered"],[5979,6208,"to be confined to Flora Palace"],[6210,6307,"to reflect on your actions."],[6312,6424,"If you transgress again,"],[6426,6635,"you will be severely punished."],[6638,6728,"\"Favorite concubine,\" huh?"],[6729,6845,"What did you do this time"],[7320,7412,"to get yourself grounded?"],[7441,7545,"Yes, My Lady."],[7575,7654,"I heard that"],[7658,7820,"yesterday at Prince Richard's Manor,"],[7825,7937,"His Majesty graced Laila with his favor."],[7975,8054,"Then Laila"],[8058,8200,"asked to live in Flora Palace."],[8254,8350,"So Lady Valerie"],[8354,8454,"went to the Imperial Study"],[8458,8566,"and made a scene."],[8612,8708,"If you ask me,"],[8745,8937,"His Majesty must be tired of her."],[9021,9062,"Serves her right."],[9116,9266,"Let's see how arrogant she can be now."],[9304,9420,"Prince Richard is truly impressive."],[9458,9583,"With just a small trick,"],[9620,9704,"he made that wench"],[9733,9841,"fall from grace."],[9970,10087,"I told you before,"],[10104,10212,"if you give me a chance,"],[10241,10408,"I can certainly seduce the Emperor."],[10416,10537,"Lady Valerie was"],[10558,10637,"so favored before,"],[10704,10770,"but isn't she"],[10775,10837,"grounded now?"],[11216,11362,"The Emperor is suspicious and cunning."],[11437,11558,"However, I think"],[11604,11745,"he is actually protecting Lady Valerie"],[11829,11954,"and using you as a target."],[11991,12045,"What do you mean?"],[12145,12266,"The Emperor has been on the throne for years"],[12304,12412,"but has no heirs."],[12441,12545,"I suspect that"],[12629,12804,"Lady Valerie is pregnant,"],[12879,12941,"so the Emperor has"],[13062,13150,"hidden her away."],[13225,13354,"Prince Richard"],[13375,13433,"really has"],[13437,13587,"a wild imagination."],[14287,14387,"I absolutely cannot"],[14391,14529,"let him have an heir."],[14844,14933,"Just to be safe."]],"71":[[195,375,"Is Prince Richard crazy?"],[400,504,"He just inexplicably"],[508,650,"decided that I'm pregnant."],[895,966,"Shopkeeper,"],[995,1070,"I heard that"],[1075,1187,"matching couplets gets a discount."],[1233,1325,"Joanna?"],[1466,1552,"So she is the"],[1554,1662,"real sleeper agent."],[2125,2154,"Yes,"],[2187,2220,"that's right."],[2300,2350,"Please go ahead."],[2416,2608,"Leaving Baidi at dawn amidst the colorful clouds."],[2687,2879,"One day of marriage, a hundred days of grace."],[3150,3269,"Sky Room Three."],[3629,3696,"Okay."],[4470,4537,"I'm here."],[4600,4662,"Follow me."],[5540,5616,"Who are you?"],[5654,5687,"Why did you bring me"],[5691,5758,"here?"],[5804,5966,"I'm your contact."],[5983,6037,"Really?"],[6175,6283,"Then verify the code with me."],[6387,6600,"The inlaid zither has fifty strings."],[6620,6658,"Wait, isn't it"],[6683,6912,"'Departing from Baidi in the morning clouds'?"],[6983,7247,"One night of marriage, a hundred days of grace."],[7379,7458,"It really is you."],[7537,7612,"But"],[7691,7841,"weren't we supposed to meet at the restaurant?"],[7891,8054,"Why did you bring me here?"],[8112,8179,"Because"],[8725,9008,"Are you going to talk?"],[9091,9200,"I'll talk."],[9204,9337,"I'll tell you everything."],[9412,9462,"Good."],[9587,9662,"Then,"],[9708,9825,"start from the beginning."],[9891,9945,"At"],[9966,10083,"At the All-Nations Banquet,"],[10116,10187,"Karim from Westland"],[10191,10262,"approached me."],[10312,10404,"He said he'd give my family"],[10408,10537,"ten taels of gold every month"],[10604,10662,"if I became"],[10666,10770,"their mole"],[10895,11087,"to secretly monitor Lady Eva"],[11091,11225,"and send them messages."],[11853,11920,"So"],[11920,11983,"Don't!"],[12025,12141,"What information did you send"],[12145,12200,"to them?"],[12204,12341,"I only sent"],[12345,12470,"one message to them."],[12475,12537,"I just reported"],[12541,12662,"on the situation in the harem."],[12666,12762,"That Lady Valerie is favored,"],[12766,12916,"and Lady Eva is making things difficult for her."],[13016,13095,"And also"],[13116,13150,"that Lady Eva"],[13154,13237,"she has been"],[13241,13341,"poisoning His Majesty."],[13354,13429,"What?"],[13691,13866,"She has been poisoning me?"]],"72":[[62,141,"Your Majesty,"],[187,337,"Lady Eva has planted spies"],[350,458,"in every palace."],[541,637,"Whenever"],[650,791,"a concubine spends the night,"],[866,979,"they burn a special incense"],[1004,1095,"that renders men"],[1116,1318,"infertile."],[1491,1575,"Lady Eva"],[1579,1691,"she works for Prince Richard."],[2020,2075,"She"],[2191,2362,"What else has she done?"],[2477,2522,"Speak!"],[2633,2670,"She"],[2729,2883,"She broke Lady Eleanor's legs,"],[2904,3012,"and drugged Lady Helen,"],[3016,3116,"causing her to go blind."],[3300,3458,"How dare you, Eva Lynn."],[3604,3808,"I will not spare you."],[4391,4449,"Your Majesty."],[4741,4841,"Your Majesty, look at this tree."],[4845,4925,"It's growing so beautifully,"],[4975,5033,"just like the affection"],[5037,5120,"between us."],[5154,5266,"You were sent by Prince Richard"],[5270,5366,"to get close to me."],[5433,5583,"What affection do you have for me?"],[5750,5812,"Your Majesty,"],[5887,5995,"what are you saying?"],[6020,6100,"I"],[6166,6262,"My devotion to you"],[6266,6362,"is attested by Heaven and Earth."],[6404,6545,"Breaking Lady Eleanor's legs,"],[6641,6762,"blinding Lady Helen,"],[6795,6966,"and secretly poisoning me."],[7016,7083,"Is this the devotion"],[7087,7229,"that Heaven and Earth attest to?"],[7358,7412,"Your Majesty,"],[7445,7495,"this"],[7575,7666,"someone must have"],[7670,7762,"framed me."],[8458,8545,"It was you!"],[8570,8758,"This wretch framed me!"],[8958,9020,"Your Majesty,"],[9092,9279,"Prince Richard forced me to do it!"],[9533,9670,"I was coerced by Prince Richard!"],[9779,9883,"I can see clearly that you are the one"],[9887,9987,"with a vicious heart."],[10100,10179,"It's a pity,"],[10233,10283,"I"],[10404,10512,"have never stepped foot in the harem."],[10594,10666,"What?"],[11000,11075,"There are just"],[11079,11183,"too many women in the harem."],[11288,11434,"I was just insecure."],[11591,11683,"I truly love you!"],[11687,11770,"Your Majesty,"]],"73":[[42,200,"such a poisonous woman"],[220,358,"should not be left"],[504,612,"alive in this world."],[2183,2237,"Your Majesty,"],[2254,2350,"the grain shipped to Dinturn"],[2386,2511,"was secretly sent to Westland"],[2545,2650,"in exchange for iron ore."],[2704,2770,"Iron ore"],[2816,2883,"Weapons."],[3329,3462,"This is the sterilization drug Prince Richard had Laila"],[3466,3600,"give to Lady Valerie."],[4183,4333,"To ensure I have no heirs."],[4529,4608,"He"],[4679,4800,"he wants to sit"],[4804,4933,"on this throne himself."],[5333,5470,"The Late Emperor said he was ruthless"],[5541,5716,"and would stop at nothing to achieve his ends."],[5804,5941,"Turns out it was all true."],[6054,6212,"When Hugh drowned years ago,"],[6283,6400,"and Stephen was crippled falling from a horse"],[6533,6600,"come to think of it,"],[6725,6891,"it must have all been his handiwork."],[7029,7104,"A man like that"],[7129,7270,"hardly deserves to be of royal blood."],[7275,7387,"Indeed."],[7475,7608,"The Late Emperor saw through him,"],[7675,7808,"so he gave him a title early on"],[7837,7929,"and sent him away to his fief."],[7983,8154,"I actually felt sorry for him,"],[8162,8404,"and begged the Late Emperor to let him return."],[8704,8816,"What a joke."],[9345,9433,"It's time for this brother of mine"],[9491,9566,"to atone"],[9570,9687,"for the atrocities"],[9691,9758,"he has committed."],[9879,10020,"Oh, Prince Richard."],[10054,10141,"Please wait a moment."],[10166,10408,"I will go in and announce you."],[11287,11462,"He really is a charmer."],[11525,11612,"What a pity."],[11662,11766,"His carefree days"],[11770,11829,"won't last much longer."],[11954,12016,"Greetings,"],[12062,12145,"Your Majesty."],[12204,12292,"Rise."],[12391,12558,"What brings you here, Richard?"],[12604,12666,"Your Majesty,"],[12677,12794,"the birthday banquet is approaching."],[12837,12950,"I have prepared"],[12964,13120,"a precious bow as a gift for you."],[13127,13187,"Oh?"],[14129,14275,"That is a fine bow."],[14312,14408,"I was thinking,"],[14441,14595,"after celebrating your birthday,"],[14625,14691,"I will return to Dinturn."],[14775,14862,"So I propose"],[14875,15012,"that for this year's banquet,"],[15045,15137,"we try something different."],[15158,15225,"Oh?"],[15275,15462,"What do you have in mind, Richard?"],[15579,15670,"A hunt."]],"74":[[25,104,"A hunt?"],[196,350,"The prey in the royal hunting grounds"],[362,433,"are nothing more than"],[435,587,"pheasants, hares, and deer."],[591,708,"It's hardly exciting."],[712,787,"Besides,"],[791,937,"I am burdened by state affairs"],[941,1025,"and busy every single day."],[1045,1325,"I have no leisure time for hunting."],[1359,1463,"The prey is not an issue."],[1516,1687,"I have spent a fortune"],[1691,1791,"sending men to Souturn"],[1816,2004,"to buy leopards and bears."],[2116,2229,"Your Majesty,"],[2266,2387,"leopards are fierce beasts"],[2391,2512,"unique to Souturn."],[2534,2650,"I'm quite curious"],[2687,2799,"and would love to see them."],[2844,2996,"You exhaust yourself working"],[2998,3079,"for the realm every day."],[3083,3141,"It's truly hard work."],[3145,3245,"Riding and archery"],[3270,3391,"would help you relax."],[3408,3475,"Besides,"],[3520,3616,"I really want to witness"],[3645,3912,"your heroic prowess in the hunt."],[3954,4025,"Very well."],[4095,4216,"I shall grant your wish."],[4279,4466,"Then I leave the arrangements"],[4537,4729,"for the birthday hunt to you, Richard."],[4858,4912,"Yes, Your Majesty."],[5137,5275,"You certainly know how to"],[5304,5417,"seize an opportunity."],[5483,5633,"The Emperor favors you so much"],[5712,5800,"that Lady Valerie"],[5841,6012,"can't even compare."],[6079,6154,"Her?"],[6212,6404,"She's just yesterday's news."],[6445,6500,"Excellent."],[6566,6616,"I have to admit,"],[6675,6791,"even I'm starting to"],[6816,6908,"like you a little."],[7258,7387,"The potion in here"],[7425,7529,"has a unique scent."],[7583,7712,"Is it for the leopards to smell?"],[7833,7950,"Leopards are just beasts."],[7979,8062,"What can they do?"],[8100,8183,"I have made"],[8187,8258,"other arrangements."],[8287,8362,"On the day of the hunt,"],[8395,8508,"you just need to put a few drops"],[8512,8587,"on his clothes."],[8683,8862,"The assassins I hired"],[8912,9008,"have noses like hounds."],[9041,9183,"The scent will provoke them"],[9187,9262,"to attack."],[9329,9450,"They won't stop"],[9454,9562,"until the target is dead."],[10050,10150,"In the future,"],[10154,10245,"when I ascend the throne,"],[10291,10437,"I'll make you a Consort,"],[10479,10591,"and you'll enjoy endless"],[10595,10712,"wealth and glory."],[10812,10875,"How does that sound?"],[10920,10979,"That sounds good."],[11037,11191,"But I want to be the Imperial Noble Consort."],[11237,11345,"Hahaha."],[11425,11587,"You really are a charmer."],[11633,11812,"I hope you feel the same"],[11829,11929,"when you die."]],"75":[[8,95,"This scenery"],[125,295,"reminds me of the fun bets we made"],[300,475,"when we were young, Brother."],[525,670,"Why don't we make another bet?"],[729,804,"Back then,"],[829,966,"you lost a precious horse to me."],[992,1096,"What do you want to bet this time?"],[1137,1220,"Let's bet on"],[1254,1462,"who can hunt a leopard or bear first."],[1479,1591,"The winner can make"],[1650,1750,"one request of the other."],[1841,2020,"The whole world belongs to me."],[2112,2191,"Richard,"],[2241,2308,"you don't have anything"],[2312,2437,"that interests me."],[2816,2891,"What about this?"],[3175,3350,"A gift from our Royal Grandfather."],[3402,3540,"You're actually betting that?"],[3570,3750,"Just tell me if you'll take the bet, Brother."],[3825,3937,"If you win"],[3941,4083,"my Gold Medal of Immunity,"],[4108,4266,"then I really won't be able"],[4283,4420,"to return to the capital without a summons."],[4512,4570,"Good."],[4633,4687,"I"],[4733,4841,"accept your wager."],[6123,6283,"But Your Majesty,"],[6441,6620,"I wanted you"],[6641,6733,"to lift me onto the horse."],[6879,6954,"Lady Laila,"],[7045,7180,"let me help you up."],[7184,7287,"In that case,"],[7291,7412,"I'll trouble you then, Prince."],[8766,8875,"What's wrong, Prince?"]],"76":[[27,108,"Nothing."],[162,212,"I just find"],[216,391,"Lady Laila's scent"],[445,587,"quite captivating."],[667,796,"I was out of line."],[833,954,"Please forgive me, Lady Laila."],[1069,1169,"After you administer the poison"],[1229,1375,"to the Emperor,"],[1479,1625,"remember to get far away."],[1758,1875,"You're so amusing."],[1920,2016,"One day,"],[2050,2275,"I'll make you the sole Imperial Noble Consort."],[2945,3029,"Your Majesty,"],[3037,3162,"wait for me!"],[3854,3996,"He's every bit as sly"],[4008,4129,"as you said."],[4150,4245,"Good thing I didn't coat my hands"],[4250,4408,"in poison to strike him directly."],[4450,4608,"You really are the smartest."],[4612,4712,"That goes without saying."],[4737,4783,"Let's go."],[4820,4887,"We'll find a place"],[4954,5036,"to wait for the news"],[5038,5125,"of the leopard attack."],[5125,5178,"Wait,"],[5220,5329,"since we're already here,"],[5387,5525,"watch me show you my skills."],[5575,5712,"I'll hunt a few more rabbits"],[5733,5837,"to make you a hand warmer"],[5862,6037,"and fur boots for the winter."],[6041,6091,"Great."]],"77":[[75,116,"Prince,"],[175,283,"the assassin squad is a hundred strong."],[287,325,"Moreover,"],[329,441,"our forces and the Emperor of Westland's men"],[445,579,"are lying in ambush around the hunting grounds."],[616,712,"Once the Emperor is dead,"],[739,903,"we'll storm the palace and kill the guards,"],[925,1004,"then crown you Emperor."],[1245,1412,"The bow was soaked in poison,"],[1491,1650,"and Lady Laila drugged him too."],[1850,1995,"With this double assurance,"],[2016,2166,"even a god couldn't save him."],[2170,2333,"Congratulations, Your Majesty, on your success."],[2400,2666,"Long live the Emperor! Long live!"],[3262,3312,"You"],[3337,3458,"Why are you here?"],[3545,3620,"I don't know."],[4641,4683,"Where is the Emperor?"],[4725,4804,"What happened to the Emperor?"],[4850,4937,"Is he dead?"],[4946,5012,"Where is the Emperor?"],[5675,5850,"You... You all"]],"78":[[354,487,"You have great skills, Prince."],[491,650,"To be able to escape alive"],[654,737,"from so many assassins."],[766,837,"It's you."],[904,976,"When did you switch the drug"],[976,1070,"and use it on me?"],[2133,2258,"You're the Princess of Westland."],[2308,2468,"How dare you betray your father?"],[2483,2608,"With that donkey brain of yours,"],[2612,2666,"you dare to rebel together"],[2670,2770,"with those brainless Westland brutes?"],[2812,2975,"Don't drag this Princess down with you."],[2995,3044,"Who are you?"],[3046,3088,"I am"],[3104,3204,"Laila."],[3250,3343,"Then who are you?"],[3779,3920,"I am Joseph's daughter,"],[3975,4087,"Clara."],[4091,4125,"You"],[4184,4229,"You"],[4291,4441,"I knew you were trouble."],[4475,4566,"I searched everywhere for you,"],[4583,4644,"only to find you hiding in a gutter."],[4644,4712,"At this point,"],[4716,4829,"do you still not repent?"],[4858,4925,"Are human lives"],[4929,4983,"nothing but worthless weeds"],[5004,5112,"in your eyes?"],[5137,5204,"Repent?"],[5258,5304,"What a joke."],[5333,5471,"I am of noble royal blood."],[5474,5562,"That I use scum like you"],[5566,5712,"is an honor for your family."],[5733,5875,"Pity your father was so stubborn."],[5900,6029,"So death was his only path."],[6037,6133,"You will face retribution."],[6233,6300,"Retribution?"],[6387,6520,"I entered the capital without a decree,"],[6570,6729,"and even the Emperor can't touch me."],[6750,6833,"To tell you the truth,"],[6916,6970,"he can no longer"],[6975,7087,"protect you."],[7116,7195,"Before long,"],[7225,7304,"you will all be"],[7308,7408,"crawling at my feet."],[7437,7537,"Hailing me as King!"],[8004,8079,"Very well."],[8158,8233,"Then allow me"],[8237,8412,"to present you with a grand gift."]],"79":[[0,108,"The moment we entered the besieged city,"],[116,304,"we encountered the Xialand army."],[541,658,"The ten thousand troops from Westland"],[662,700,"along with your"],[704,787,"five thousand private soldiers"],[812,883,"have all been captured."],[904,971,"Richard,"],[1066,1245,"are you satisfied with this grand gift"],[1320,1441,"that I have given you?"],[1475,1641,"It had to be you,"],[1712,1815,"my Imperial Brother."],[1875,1937,"Fine."],[2070,2150,"Since it has come to this,"],[2254,2354,"winner takes all."],[2508,2608,"I have nothing to say."],[2621,2695,"Good."],[2920,2995,"Guards!"],[3058,3208,"Throw Prince Richard into the dungeon."],[3212,3316,"Select a day for his execution."],[3335,3408,"No, no!"],[3445,3533,"You can't kill me!"],[3541,3612,"I have the Gold Medal of Immunity!"],[3620,3754,"You have to send me back to Dinturn!"],[3758,3854,"The Gold Medal of Immunity?"],[3921,3983,"What?"],[4037,4162,"It's the Ancestral Emperor's decree."],[4175,4262,"Do you dare to disobey?"],[4279,4366,"Do you dare defy our ancestors?"],[4408,4545,"Why don't you take a good look"],[4596,4648,"at what is in your hand,"],[4648,4816,"and see if it truly is the Gold Medal?"],[6804,6929,"It was you!"],[6995,7125,"You harmed the people,"],[7150,7229,"persecuted your brothers,"],[7270,7350,"and plotted rebellion."],[7379,7512,"Even if Emperor Ted"],[7516,7633,"would also think you deserve to die."],[7691,7854,"Throw Prince Richard into the dungeon"],[7858,7979,"and schedule his execution."],[8016,8095,"Brother!"],[8116,8195,"You can't kill me!"],[8237,8383,"It's our ancestors' will"],[8387,8487,"You cannot kill me!"],[8491,8579,"Richard,"],[8670,8875,"if you returned to the capital without orders,"],[8958,9054,"I might have considered"],[9058,9229,"our last shred of brotherhood"],[9262,9370,"and spared you."],[9445,9583,"But you trampled on human lives,"],[9587,9700,"disregarded the law,"],[9704,9779,"colluded with foreign enemies,"],[9783,9904,"and betrayed the nation."],[10000,10129,"If I do not bring you to justice,"],[10240,10375,"I will fail our ancestors"],[10379,10554,"and the common people!"],[10683,10766,"Guards!"],[11520,11616,"What are you doing?"],[11841,11904,"Now that my parents'"],[11908,11991,"deaths have been avenged,"],[12041,12158,"I must thank Your Majesty."],[12775,12850,"Between you and me,"],[12916,12991,"there is no need for thanks."],[13054,13191,"However, I have a request"],[13225,13333,"I need your help with."],[13429,13504,"What is it?"],[13604,13708,"I need an Empress"],[13737,13862,"who is virtuous, wise,"],[13879,14112,"brave, and resourceful."]],"80":[[575,662,"The Ministry's proposal"],[666,758,"for the Empress's coronation"],[841,925,"I am very satisfied with it."],[1104,1183,"Let's proceed as planned."],[1316,1400,"Yes, Your Majesty."],[1683,1729,"Your Majesty,"],[1758,1841,"Lady Valerie"],[1858,1932,"has snuck out of the palace again."],[1975,2045,"She snuck out again?"],[2145,2259,"Millet costs"],[2259,2366,"510 copper coins a peck."],[2387,2437,"Rice costs"],[2441,2600,"2,100 copper coins a peck."],[2645,2704,"Question:"],[2725,2833,"If you want to buy"],[2866,3041,"one sheng and three ge of millet,"],[3083,3237,"and three sheng and four ge of rice,"],[3275,3441,"how many copper coins do you need in total?"],[3620,3701,"The total is"],[3704,3841,"817 copper coins."],[3866,3920,"Incorrect."],[3954,4133,"It's 793 copper coins."],[4208,4312,"Wrong, wrong, wrong."],[4362,4437,"You're wrong too."],[4520,4595,"I really think"],[4600,4750,"my calculation is correct."],[5016,5091,"Actually,"],[5237,5350,"one sheng and three ge of millet"],[5370,5445,"is about 66 copper coins."],[5495,5608,"Three sheng and four ge of rice"],[5637,5750,"is about 710 copper coins."],[5766,5825,"That makes a total of"],[5866,5937,"780 copper coins."],[5941,6033,"You two need to"],[6058,6158,"learn from Pike."],[6216,6358,"He's good at both martial arts and math."],[6408,6508,"If you keep being unable"],[6512,6633,"to master the abacus"],[6637,6750,"or keep the accounts straight,"],[6770,6887,"how can I trust you"],[6891,7000,"with my business?"],[7183,7245,"Pike,"],[7283,7362,"why don't you"],[7387,7479,"teach them for me?"],[7483,7550,"Me?"],[7554,7612,"I"],[7612,7695,"Um"],[7695,7791,"I think it's a good idea."],[7795,7879,"Teach them well."],[7896,7983,"Clara and I have"],[7995,8104,"more important things to do."],[8104,8229,"What could be more important?"],[8545,8758,"Continuing the family line, of course."]]}