 moment"],[4266,4379,"to tell her that I'm the Alpha"],[4379,4487,"of the Red Moon Pack."],[4517,4579,"Yeah."],[4617,4704,"Let's get you home."],[4808,4884,"You look like you could use"],[4884,5005,"a nice, hot shower."],[5226,5351,"So, I'm married!"],[5397,5538,"It doesn't feel real."],[5784,5839,"Hi, Mom."],[5876,6014,"Hi, baby girl."],[6022,6202,"Now I just need to meet"],[6202,6348,"my new son-in-law"],[6348,6502,"and introduce him to the family."],[6623,6685,"Mom..."],[7390,7515,"By the way,"],[7540,7603,"what does my"],[7603,7791,"son-in-law look like?"],[7807,8183,"Well, actually, he-"],[8183,8366,"Oh my God."]],"7":[[479,646,"Oh my God."],[646,692,"Is this"],[692,880,"really the homeless man I took in?"],[880,975,"He's so"],[996,1063,"different,"],[1088,1142,"handsome."],[1142,1317,"Elara, is that"],[1343,1584,"gorgeous man my son-in-law?"],[1630,1710,"Oh, um."],[1710,1822,"Mom, I have to go."],[1822,1931,"I'll talk to you later, bye."],[1989,2097,"Wait, that was your mom?"],[2143,2235,"Oh God, I hope I made,"],[2235,2356,"a good first impression."],[2356,2410,"I mean -"],[2423,2485,"Right."],[2485,2573,"I, I'm so sorry."],[2573,2627,"I,"],[2731,2802,"I should have just-"],[2815,2894,"Oh!"],[3657,3712,"I'm sorry."],[3774,3845,"Oh, no, it's,"],[3899,3966,"it's fine."],[4054,4166,"I mean, if you wanted to,"],[4200,4329,"you know, fall into me again,"],[4329,4400,"I wouldn't mind."],[4441,4512,"I mean, after all, I"],[4579,4708,"am your husband now."],[4808,4867,"Yeah?"]],"8":[[150,200,"Elara?"],[266,387,"We don't have to do that."],[437,542,"I'm sorry, I mean..."],[750,821,"We just met."],[1034,1242,"And we should take it slow."],[1267,1338,"Of course."],[1630,1768,"Anyway, so, uh,"],[1901,2118,"where do you think I'll be sleeping?"],[2131,2289,"Is it rude if I offer the couch?"],[2318,2406,"No, that's,"],[2477,2585,"that's completely fine."],[2748,2852,"Actually,"],[3007,3203,"I believe this is yours?"],[3278,3370,"I don't need that anymore."],[3561,3716,"I just feel bad for my,"],[3753,3824,"my family,"],[3824,3991,"they were so excited for the wedding."],[4049,4216,"Well, Elara, I can"],[4216,4379,"give you the wedding you deserve."],[4429,4621,"Something amazing."],[4671,4771,"Thank you, Liam."],[4771,4825,"But,"],[4921,4992,"it's not about"],[4992,5130,"an extravagant ceremony."],[5130,5205,"It's,"],[5380,5451,"about being with"],[5451,5563,"the person that you love."],[5668,5872,"Anyway, enough of this depressing talk."],[5939,6064,"We should probably get some rest."],[6177,6239,"Goodnight."],[6272,6339,"Goodnight."],[6627,6710,"Size 6."],[7102,7165,"Alpha?"],[7207,7432,"Get me a size 6 diamond ring."],[7482,7574,"A diamond ring?"],[7603,7657,"Why?"],[7716,7786,"I'm married now."],[7862,7945,"It's for our Luna."],[7962,8020,"What?"],[8037,8137,"Alpha, did you actually"],[8137,8254,"marry that human girl?"],[8254,8350,"The pack won't accept"],[8350,8470,"a human as our Luna."],[8483,8583,"Are you questioning me?"],[8650,8729,"I'm your Alpha."],[8804,8896,"Forgive me, Alpha."]],"9":[[433,546,"Oh my God."],[855,905,"I got it."],[2652,2711,"You know,"],[2781,2911,"I am your husband now."],[2932,3007,"You can,"],[3065,3186,"ogle me all you want."],[3611,3753,"Before you meet my parents,"],[3791,3837,"we're gonna have to"],[3837,3953,"get you some new clothes, so,"],[4087,4200,"we're going shopping."],[4320,4391,"Sounds good."],[5267,5372,"Oh my God."]],"10":[[542,608,"Try it on."],[700,742,"What?"],[809,846,"No."],[959,1130,"Liam, it's insanely expensive."],[1130,1180,"I-"],[1180,1263,"Excuse me, ma'am."],[1263,1322,"Uh,"],[1322,1493,"my wife would like to try on that dress."],[1676,1822,"This dress is mine!"],[1931,1997,"Helena?"],[2047,2114,"Victor?"],[2152,2231,"Hey look,"],[2231,2406,"it's my heartbroken ex, Elara."],[2439,2544,"Did you follow me here?"],[2544,2740,"That is so sad."],[2869,2994,"Elara is married now."],[3032,3161,"And I'm her husband."],[3186,3294,"Have you been enjoying"],[3294,3465,"my loser leftovers then?"],[3503,3599,"Victor, stop it."],[3607,3699,"Relax,"],[3741,3812,"we're just having a little"],[3812,3924,"man-to-man talk."],[3987,4158,"There's absolutely nothing"],[4216,4329,"about you that I would ever"],[4329,4400,"be jealous of."],[4508,4700,"You know, honestly? It's a good thing"],[4700,4825,"you're not with him anymore."],[4850,4963,"You deserve better."],[5025,5146,"I'll take that wedding dress."],[5146,5330,"Wait, we saw it first."],[5330,5472,"If it's a delivery girl"],[5484,5551,"and a nobody"],[5551,5680,"buying a wedding dress,"],[5709,5809,"try a thrift store."],[5851,5968,"Wrap it up for me."],[5980,6097,"Of course, right away."],[6118,6160,"Hold on."],[6227,6373,"You two broke losers"],[6373,6510,"don't actually think you can buy it,"],[6510,6631,"do you?"],[6890,7027,"Wait, is that the"],[7027,7261,"inner-circle VIP Black Card?"],[7273,7332,"Charge it."]],"11":[[37,75,"Wait."],[254,425,"Liam, we don't have that kind of money."],[529,579,"You'll see."],[604,738,"You expect us to believe"],[738,892,"that is a real card?"],[900,946,"Yeah."],[946,1092,"It looks like a cheap knockoff."],[1176,1255,"It's a fake."],[1267,1372,"Absolutely not."],[1526,1768,"I know what an inner-circle"],[1789,2022,"VIP black card is."],[2060,2243,"And only one person gets them."],[2302,2444,"And I would recognize them."],[2485,2702,"We wait on them hand and foot."],[2723,2811,"He's not some"],[2852,3019,"little nobody off the street."],[3136,3244,"Well, it seems like"],[3244,3353,"you don't have the knowledge"],[3374,3478,"nor standing"],[3482,3603,"to know that that card is real."],[3624,3716,"Drop the act."],[3741,3953,"I have real Gold status here."],[4045,4229,"This is what a real card looks like."],[4262,4475,"That is a VIP gold card."],[4475,4571,"And it's real."],[4642,4742,"So get your fake little"],[4742,4833,"fraudy card out of here."],[4875,5013,"Oh, Elara."],[5113,5267,"Just look at the useless trash"],[5267,5392,"you ended up with after me."],[5438,5576,"Liam, I, I appreciate"],[5576,5689,"that you're doing this for me,"],[5689,5784,"but let's just go."],[5809,5851,"Trust me."],[5935,6068,"I'll give you everything you want."],[6310,6389,"Why don't we test"],[6418,6514,"if the card is real or not?"],[6548,6606,"Fine."],[6694,6802,"Then maybe,"],[6802,7007,"you could stop wasting our time."]],"12":[[133,250,"Possible fraud alert."],[250,417,"Inner-circle VIP Black card"],[417,492,"has been used."],[525,575,"What?"],[650,754,"The card doesn't work."],[813,921,"Get the hell out of here,"],[921,1001,"with your fake card"],[1001,1092,"and your fake story."],[1443,1668,"Security, kick these losers out."],[1897,1956,"Stop,"],[1956,1997,"stop."],[2118,2264,"Nobody touches my top VIP."],[2556,2652,"Adam, hi."],[2698,2911,"So, this man over here"],[2911,2994,"is pretending to be"],[2994,3249,"our top VIP black client."],[3278,3453,"It's a fake card, he's lying."],[3507,3549,"Where is he?"],[3591,3632,"Him."],[3787,3920,"He's the one causing trouble."],[4066,4087,"Sir, you're"],[4087,4200,"interrupting operations"],[4200,4245,"of the store."],[4250,4333,"I need to ask you to leave."],[4371,4421,"What?"],[4462,4529,"Are you with him?"],[4575,4662,"Yeah, yes."],[4696,4846,"We are gold VIP clients."],[4913,5009,"Escort them both out."],[5134,5167,"What?"],[5171,5234,"You, you, - What?"],[5246,5342,"You can't do that!"],[5342,5459,"Hey, I'll sue you!"],[5459,5534,"Ah!"],[5534,5576,"Get-"],[5705,5784,"This can't be right."],[5793,5860,"They're the ones that-"],[5860,6006,"Karen, you have no idea"],[6006,6101,"who you're insulting."],[6126,6235,"This is Mr. Blackwood."],[6235,6402,"He's our most esteemed guest."],[6431,6560,"You are fired."],[6598,6715,"No, no, please."]],"13":[[0,204,"No, no, please, Adam, I-"],[204,337,"Get the fuck out of my store."],[346,421,"Ah!"],[604,729,"My most sincere apologies"],[729,867,"to our most esteemed guests."],[875,967,"Let me make it up to you."],[984,1109,"I'll show you our exclusive line."],[1109,1242,"These are pieces that we never show."],[1447,1601,"A private collection? - Yes."],[1614,1664,"Sound good?"],[1664,1780,"Thank you so much."],[1780,1881,"That's amazing!"],[1906,2002,"Liam, did you hear that?"],[2097,2189,"Private collection."],[2402,2615,"Victor, do something."],[2740,2852,"I know Elara's boss has"],[2852,3015,"been eyeing her for a while now."],[3182,3244,"Hey, Dylan."],[3340,3470,"Elara's all yours, man."],[3661,3849,"Welcome to hell, Elara."]],"14":[[629,713,"How do I look?"],[913,1021,"You look,"],[1051,1130,"amazing."],[1167,1297,"The dress is yours,"],[1372,1430,"for free."],[1459,1514,"What do you mean?"],[1514,1693,"This dress is like five figures."],[1693,1822,"You are our hundredth bride."],[1826,1931,"As part of our promotion,"],[1931,2014,"the hundredth bride"],[2014,2156,"gets her dress for free."],[2168,2335,"Oh my God, Liam, did you hear that?"],[2460,2573,"A free dress,"],[2573,2677,"that's amazing!"],[3199,3257,"You know,"],[3345,3486,"I am starting to think"],[3486,3703,"that you're not just some random guy."]],"15":[[87,200,"You're my lucky charm."],[300,458,"Ever since I met you, my,"],[563,813,"my life has turned around so fast."],[1034,1197,"Look Elara, I-"],[1197,1326,"But what was the deal with that whole"],[1326,1514,"VIP black card thing?"],[1689,1918,"Uh, actually, I just found it."],[2056,2168,"When I was on the streets,"],[2168,2223,"it was just,"],[2277,2394,"there one day in front of me."],[2502,2560,"Wow."],[2681,2752,"That's crazy."],[2865,3123,"But it makes sense, for my lucky charm."],[3378,3566,"Our bride is so beautiful."],[3582,3728,"You want her, don't you?"],[3945,4008,"No!"],[4008,4104,"We can't!"],[4104,4195,"You'll scare her."],[4608,4679,"I should-"],[4783,4850,"Wolf!"]],"16":[[212,279,"Wolf!"],[813,863,"Elara."],[1038,1109,"Elara."],[1518,1659,"Are you, are you okay?"],[1701,1760,"Uh."],[1860,2022,"Did, did I imagine that, I,"],[2147,2264,"I thought I saw, a, a wolf"],[2264,2406,"Liam, did you see that?"],[2464,2590,"If I come clean now,"],[2660,2736,"she'll just freak out."],[2736,2836,"It's not the right time."],[3040,3165,"Elara, you're probably just"],[3207,3294,"seeing things."],[3353,3549,"There wasn't any wolf."],[3724,3862,"But, I promise,"],[3862,4020,"if there were, I'd protect you."],[4133,4175,"All right."],[4270,4337,"I think,"],[4408,4617,"Victor just threw me off earlier."],[4717,4804,"Let's go home."],[5159,5259,"Where the hell are you?"],[5259,5397,"You're supposed to be working!"],[5413,5568,"Get your ass over here, now!"],[6047,6156,"I'm sorry, Liam."],[6202,6364,"I have to go to the pizza shop."],[6414,6514,"I'll see you in a bit."]],"17":[[279,342,"Elara!"],[417,492,"It's about time."],[492,658,"You just fucking skip work all day?"],[671,721,"I-"],[775,842,"I'm sorry, sir!"],[842,946,"I, I told the owner"],[946,1092,"that I needed some time off and-"],[1092,1176,"and he said that he"],[1176,1230,"told you- - Shut up!"],[1292,1468,"Alright, I don't wanna hear excuses."],[1480,1555,"You know how many orders"],[1555,1626,"we had tonight?"],[1726,1893,"You do know who your boss is, right?"],[2273,2335,"What are you doing?"],[2335,2406,"Let go of me."],[2473,2560,"I am the only one"],[2560,2648,"that can give you approval"],[2648,2777,"for time off."],[2861,2919,"I heard you and your"],[2919,3073,"little werewolf boyfriend broke up."],[3082,3178,"That's none of your business,"],[3178,3319,"let go of me, or I'll scream!"],[3319,3428,"Relax, relax."],[3511,3645,"You don't wanna lose your job, do you?"],[3741,3799,"No."],[3962,4079,"You know where I'm going with this."]],"18":[[433,538,"Don't worry, princess."],[558,625,"We'll help you."],[750,809,"Please."],[1505,1672,"Oh, you are fast, girl,"],[1672,1847,"but you can't outrun me."],[2068,2110,"Help!"],[2110,2198,"Somebody help!"],[2869,2977,"Stop fighting back."],[2977,3132,"No one's coming to save you."],[3303,3399,"No!"],[3611,3837,"How dare you touch my wife!"]],"19":[[0,241,"How dare you touch my wife!"],[367,471,"Who the hell are you?"],[542,613,"Liam?"],[629,679,"Shut up!"],[1559,1614,"Please."],[1634,1676,"Don't."],[1676,1739,"Don't. - Please don't."],[1739,1801,"Please don't. - No."],[1801,1843,"Don't hurt us. - We'll leave and"],[1843,1906,"Don't hurt us. - never come back!"],[1960,2043,"Apologize."],[2068,2118,"We're sorry. - Yeah."],[2118,2181,"I'm sorry. - Sorry."],[2181,2210,"Sorry."],[2210,2298,"We'll never come back."],[2298,2431,"It'll never happen again."],[2452,2527,"Get lost!"],[2998,3132,"I'm so sorry I was late."]],"20":[[25,154,"I'm so sorry I was late."],[191,396,"No, I'm just, glad you're here."],[738,796,"Don't worry."],[825,875,"You're all right."],[946,1046,"You're safe."],[1092,1188,"Everything is gonna be okay."],[1810,1997,"Sweetheart, you're home!"],[1997,2243,"It's so good to see you."],[2243,2427,"I've missed you so much!"],[2477,2719,"Mom, Dad, I've missed you too."],[2844,3090,"And you must be my son-in-law."],[3157,3353,"Oh, I like you already."],[3837,3870,"Well,"],[3916,3999,"pleasure to meet you,"],[4020,4162,"uh, Mr. and Mrs. Stone."],[4212,4304,"I'm Liam Blackwood."],[4387,4587,"Welcome to the family, Liam."],[4637,4700,"Liam,"],[4942,5000,"I like the name."],[5071,5121,"It's solid."],[5338,5501,"Uh, tomorrow we are throwing"],[5501,5626,"a welcome dinner party."],[5701,5897,"Margaret is dying to introduce you to"],[5980,6047,"everyone."],[6210,6285,"Well, come on in."],[6285,6373,"Let's chat inside."],[6389,6460,"Come on!"],[6660,6723,"Nice work."],[6735,6790,"Keep it up."]],"21":[[79,212,"So,"],[212,346,"how did you two meet?"],[479,558,"At a restaurant. - On the street."],[984,1084,"We met on the street"],[1084,1426,"and Liam fell for me immediately,"],[1447,1618,"and so he took me to a restaurant."],[1643,1830,"And that's where it all began."],[1860,1939,"Exactly."],[1939,2064,"Uh, it was,"],[2168,2231,"fate."],[2285,2452,"Well, that's um,"],[2552,2623,"fast."],[2660,2869,"Uh, but when it's the right person,"],[2890,3069,"it just happens naturally."],[3140,3207,"Remember us?"],[3495,3716,"Elara, where's your wedding ring?"],[4149,4229,"Did you not get one?"]],"22":[[54,262,"Elara, where's your wedding ring?"],[496,700,"Oh, my little scatterbrain."],[771,821,"She took it off"],[821,921,"when she was washing her hands"],[921,1030,"and forgot all about it."],[1059,1330,"Luckily, I was here to uh, take care of it."],[1401,1480,"Oh, right!"],[1501,1589,"Silly me."],[2481,2627,"Where did you get a fake"],[2660,2773,"diamond ring?"],[2861,2936,"It's real."],[3019,3186,"This moment calls for a toast?"],[3186,3299,"Oh yes."],[3319,3382,"Cheers."],[3436,3557,"Yes, cheers. - Cheers."],[3983,4058,"It's late."],[4083,4275,"Uh, how about we turn in early?"],[4320,4437,"You are gonna bunk with me"],[4446,4512,"and Elara,"],[4512,4750,"you are gonna- - Oh, shut it old man."],[4896,4959,"Elara,"],[4975,5109,"come see the honeymoon suite"],[5109,5263,"I set up for you two."]],"23":[[596,746,"Enjoy your night."],[1005,1205,"Our luna is beautiful."],[1205,1488,"You want her, don't you?"],[1488,1785,"No, Xander, we can't. You'll scare her."],[2143,2210,"You had, like,"],[2264,2402,"half a glass of sparkling wine."],[2460,2540,"I'm fine."],[3028,3203,"Stop fighting it, Liam."],[3203,3332,"You know you want her."],[3461,3545,"You know, I never,"],[3720,3862,"really believed in fate."],[4004,4175,"Until I met you."],[4400,4462,"You don't even know"],[4462,4625,"who you're talking to right now, Liam."],[4704,4775,"Elara,"],[4913,5042,"my wife."]],"24":[[704,825,"You taste so good."],[2060,2177,"Take me, Liam."],[3532,3670,"You're so wet."],[3916,4041,"Tell me that you want me."],[4250,4316,"I want you."],[4408,4491,"Liam."],[5276,5463,"Elara, I'm sorry."],[5705,5780,"Wait Liam!"],[6131,6348,"Liam, how long can you"],[6348,6485,"keep me from her?"],[6548,6731,"Can't, lose her."],[6806,6965,"Can't scare her away."],[6994,7040,"Liam?"],[7127,7186,"Are you okay?"],[7186,7257,"Let me see."]],"25":[[54,104,"Don't!"],[350,417,"I'm fine."],[504,583,"Are you sure, you don't,"],[621,742,"you don't sound fine."],[775,1005,"I'm just uh, too much to drink, so uh,"],[1163,1267,"feeling a little sick."],[1413,1509,"Well, just let me know"],[1509,1618,"if you need anything."],[1639,1730,"I can help you."],[1797,1843,"Okay."],[2198,2419,"You can't hide forever."],[2419,2569,"She deserves the truth."],[2623,2698,"I know."],[2819,2873,"I will."]],"26":[[116,196,"Good morning, Mom."],[196,258,"Hi, sweetie."],[296,367,"Have you seen Liam?"],[454,525,"Out there."],[1172,1263,"Wow."],[1301,1564,"Where did he come from?"],[1659,1793,"Hey, handsome."],[1897,2047,"Never seen you around before."],[2072,2235,"We have some bushes"],[2235,2373,"that could use trimming."],[2448,2660,"Maybe you could lend a hand."],[2706,2790,"Hey,"],[2819,2886,"is there something that"],[2886,2994,"you needed to discuss"],[2994,3136,"with my husband?"],[3253,3365,"Husband? - Yeah."],[3365,3482,"Absolutely."],[3516,3603,"Newlyweds."],[3628,3691,"Can't you tell?"],[3916,4066,"Guess it's not my lucky day."],[4158,4250,"Congrats, Elara."],[4796,4867,"What's so funny?"],[4925,5005,"Are you enjoying being"],[5005,5105,"hit on by other women?"],[5130,5292,"Actually, no."],[5292,5372,"I just,"],[5401,5513,"really enjoy you calling me"],[5513,5593,"your husband."],[5663,5714,"You do?"],[5797,5843,"Totally."],[5930,6014,"Now say it again."],[6110,6227,"Cut it out, Liam."],[6264,6343,"Mom's calling."],[6544,6644,"Hope you're ready."],[6681,6815,"Tonight's welcome dinner is"],[6815,6940,"all about you two."],[6973,7207,"The entire town gets to meet"],[7207,7474,"my daughter's handsome husband."]],"27":[[29,187,"Ladies and gentlemen,"],[200,396,"please help me welcome"],[412,588,"my wonderful daughter"],[588,692,"Elara Stone,"],[692,846,"and her wonderful,"],[863,1092,"extremely handsome husband."],[1105,1272,"Liam Blackwood."],[1401,1543,"Wow, look at those two."],[1601,1747,"Absolute perfection."],[1764,1972,"Well, good evening, everyone."],[1997,2139,"I am Liam Blackwood,"],[2152,2385,"and I am the very lucky man"],[2406,2552,"who gets to marry Elara."],[2598,2727,"Elara, she truly is one of a kind,"],[2727,2819,"and the reason I wake up"],[2819,3003,"smiling every morning."],[3107,3236,"Thank you all for coming tonight"],[3265,3407,"to celebrate this special"],[3424,3528,"occasion with us."],[3582,3699,"Cheers, everyone."],[3699,3824,"Cheers."],[4233,4446,"What a spectacular gathering!"],[4550,4637,"Margaret,"],[4667,4813,"how could you throw a party"],[4813,4904,"without inviting your"],[4904,5030,"dear old neighbor?"],[5046,5251,"Fiona, what are you doing here?"]],"28":[[33,183,"Oh, just stopping by"],[183,329,"to celebrate Elara's big day,"],[329,392,"of course."],[400,621,"Do not start any trouble."],[638,700,"Trouble?"],[759,975,"I'm here to bless the happy couple."],[1080,1155,"Elara,"],[1176,1393,"I heard you're still delivering pizzas."],[1447,1572,"It must be draining making"],[1572,1639,"ends meet."],[1639,1835,"That is enough, Fiona."],[1864,2027,"I am very proud of my daughter"],[2027,2127,"and how hard she works."],[2127,2198,"So you can take your"],[2198,2302,"backhanded pettiness"],[2302,2385,"somewhere else."],[2398,2502,"Helena's fiancé"],[2502,2665,"isn't just some average guy."],[2665,2882,"Are Helen and Victor here tonight?"],[2882,3053,"he's a real, hardcore,"],[3053,3203,"tough-as-nails werewolf,"],[3224,3374,"making millions a year."],[3557,3661,"You see this?"],[3778,3870,"A little gift"],[3870,4012,"from my future son-in-law."],[4041,4149,"Over ten grand."],[4170,4320,"What about your son-in-law?"],[4329,4408,"What does he do?"],[4441,4504,"Waiter?"],[4504,4575,"Mechanic?"],[4592,4767,"Hey, enough."],[4779,4904,"Get out of my house."],[4934,5100,"Well, you'll be pleased to know"],[5125,5259,"my future son-in-law"],[5259,5467,"bought me a beautiful new car."],[5910,6139,"Let's show these country pumpkins"],[6160,6360,"what a real class looks like."]],"29":[[0,291,"My son-in-law gave me a luxury car."],[367,571,"Looks like your poor son-in-law"],[571,746,"didn't get you anything at all."],[759,1034,"Elara, I heard you got married,"],[1051,1159,"so I came all the way here,"],[1159,1292,"just to laugh at you."],[1326,1493,"Victor, how does it feel"],[1493,1705,"to see your sad ex-fiancée?"],[1797,1843,"Wait,"],[1972,2081,"ex-fiancée?"],[2318,2448,"Her fiancé dumped her,"],[2448,2640,"and now Victor is my fiancé."],[2665,2823,"We're getting married soon!"],[2919,2990,"That's right."],[3032,3244,"You know Victor is quite a catch."],[3244,3420,"Good thing he's finally moved on"],[3420,3541,"from the pizza girl."],[3574,3737,"My daughter is simply better."],[3737,3878,"Mom I'll explain every-"],[3878,3999,"No, I can explain right now."],[4091,4316,"Elara is like a leftover pizza."],[4346,4742,"Forgotten, sad, and left behind."],[4775,4963,"Broke, with nothing."]],"30":[[25,204,"I'm so sorry, Elara."],[225,404,"Must be hard watching Victor"],[404,692,"fall for me while tossing you aside."],[704,884,"So Elara got dumped,"],[896,1076,"and then ran off to marry some"],[1076,1280,"random guy to fool everyone?"],[1309,1472,"Elara and I are married for real."],[1555,1793,"There's nothing fake about us."],[1914,2060,"We're husband and wife."],[2131,2348,"Now whether she's human or wolf,"],[2348,2435,"it doesn't matter."],[2477,2644,"She deserves the best."],[2644,2719,"That's right."],[2744,2898,"Liam is my husband."],[3115,3286,"And he's a thousand times the man"],[3286,3386,"that you'll ever be."],[3432,3632,"So what if I deliver pizza?"],[3766,4037,"I, I work hard, and I earn my way."],[4108,4283,"I'm not going to be ashamed of that."],[4346,4416,"And you,"],[4446,4646,"stealing your best friend's fiancé."],[4767,4884,"Are you not ashamed?"],[4946,5055,"Oh my god,"],[5055,5301,"she stole her best friend's fiancé?"],[5334,5467,"That is so shitty."],[5476,5559,"Seriously."],[5588,5730,"And now Fiona wants to crash"],[5730,5876,"the party to rub that in?"],[5964,6068,"That's messed up."],[6072,6214,"It wasn't stealing."],[6247,6398,"We simply fell in love."],[6431,6523,"The unwanted woman"],[6523,6677,"is a real home wrecker."],[6744,6831,"Right, Victor?"],[6835,6898,"Of course."],[6965,7157,"A high-value woman like Helena"],[7157,7298,"deserves to be loved."],[7328,7424,"Please."],[7507,7682,"Everyone deserves love."],[7736,7811,"But you?"],[7832,7999,"You cheated on me with my best friend."],[7999,8083,"You're disgusting."],[8112,8283,"You're nothing like Helena."],[8329,8437,"You were never good enough"],[8437,8571,"to be with someone like me."],[8583,8646,"Enough!"],[8671,8783,"Don't you dare talk-"],[8783,8896,"Get the hell out of my house!"],[8896,8963,"Victor!"],[8979,9109,"He's going to hit me."],[9154,9296,"You dare threaten me?"],[9417,9567,"You pathetic little worm!"],[9697,9868,"Don't even think about"],[9868,9993,"touching my family."],[10060,10206,"Get out of our party."],[10214,10272,"Now!"]],"31":[[29,187,"Get out of our party."],[191,266,"Now!"],[479,579,"You got lucky once,"],[638,763,"you think you can take me on?"],[817,959,"Dream big, little loser."],[1063,1159,"Try me."],[1376,1505,"Top werewolf like me"],[1564,1651,"doesn't waste his time"],[1651,1751,"on street trash."],[2077,2264,"I came here today to show you"],[2293,2423,"the differences between us"],[2423,2519,"and people like you."],[2523,2652,"Nothing in your lives will ever"],[2652,2861,"compare to our status or wealth."],[2915,3078,"You're all just bottom-feeders."],[3103,3207,"We may not be rich,"],[3311,3424,"but we have dignity,"],[3536,3624,"and we're happy."],[3712,3807,"Since when was being"],[3807,3933,"part of the wolf pack"],[4058,4183,"about showing off?"],[4225,4266,"And honestly,"],[4266,4387,"if you're gonna show off."],[4416,4483,"Mrs. Stone,"],[4521,4683,"the gift I've gotten you is"],[4708,4804,"worth millions."],[5063,5196,"Go ahead and bring in the Ferrari."],[5292,5451,"Yeah, the F80."],[5526,5584,"Ferrari?"],[5643,5743,"Did I hear that right?"],[5789,5985,"Does this idiot even know what that is?"],[6531,6623,"What's that sound?"]],"32":[[0,79,"What's that sound?"],[137,216,"You won't be laughing"],[216,308,"much longer."],[421,542,"Liam, a Ferrari?"],[596,709,"I'll explain later."],[892,1021,"You know, I thought before I came"],[1021,1151,"I might prepare a little..."],[1305,1426,"limited edition gift."],[1480,1672,"Ferrari F80?"],[1714,1793,"Please."],[1818,1960,"If you were any good at lying,"],[1960,2106,"you wouldn't pick a car that starts with"],[2118,2281,"three million dollars?"],[2306,2377,"Look buddy,"],[2423,2669,"if that car is out of my price range,"],[2690,2840,"it's definitely not in yours."],[2840,2948,"Give it up, Margaret."],[2994,3057,"You're all just"],[3057,3203,"embarrassing yourselves."],[3232,3307,"And your daughter is"],[3307,3490,"embarrassing enough on her own."],[3503,3799,"You will not insult my daughter."],[3799,3891,"We love our daughter,"],[3891,3974,"and you are a,"],[4054,4204,"hateful, deceitful person."],[4229,4333,"Oh, please."],[4366,4496,"A broke girl like her?"],[4529,4688,"She belongs with a homeless man"],[4721,4854,"off the street."],[4938,5226,"See for yourself, he's a hobo!"]],"33":[[0,246,"Elara, did you find a homeless man"],[246,425,"to pretend to be your husband?"],[429,604,"Elara, is this true?"],[713,892,"Is Liam really a homeless man?"],[971,1134,"And you're just pretending?"],[1163,1297,"Mom, Dad, I- - Elara,"],[1347,1468,"I was really the best"],[1468,1576,"you could ever have, huh?"],[1622,1872,"A pizza girl and a hobo."],[1918,2077,"What a perfect match."],[2135,2281,"I guess we don't have to worry about"],[2281,2406,"a Ferrari being a lie."],[2498,2631,"I can't believe I have to live"],[2631,2748,"near you people."],[2786,3003,"Elara, were you really just married"],[3003,3094,"to a homeless man"],[3094,3332,"to cover up a failed relationship?"],[3436,3603,"I can't believe it."],[3720,3828,"It, it's all my fault."],[3828,4024,"Liam had nothing to do with this."],[4062,4149,"No, ma'am."],[4220,4379,"I may have been homeless once,"],[4450,4700,"but, my marriage to Elara is real."],[4896,4992,"And so is the Ferrari."]],"34":[[116,233,"Is that a Ferrari?"],[287,408,"Am I hallucinating?"],[600,667,"Oh, my God!"],[734,834,"It's real."],[859,1001,"God, Liam, you..."],[1046,1151,"How did you do this?"],[1309,1422,"I'll tell you later."],[1463,1584,"How the hell could Elara's"],[1597,1793,"broke husband have a Ferrari?"],[1810,1876,"A Ferrari?"],[1939,2156,"No way a hobo like you bought this."],[2181,2227,"Wait,"],[2298,2423,"my rich banker friend"],[2435,2598,"said he had a big wedding gift for us."],[2648,2777,"This must be from him."],[2806,2923,"A gift for me."],[2948,3023,"Oh yes."],[3053,3140,"That makes sense."],[3224,3407,"Oh gosh, what a wonderful gift"],[3407,3570,"for my wonderful son-in-law."],[3645,3858,"Are you sure this car is yours?"],[3878,3983,"Who else's could it be?"],[4045,4108,"Yours?"],[4137,4241,"You expect us to believe"],[4241,4421,"a homeless guy has a Ferrari?"],[5355,5492,"Sir, as requested,"],[5547,5618,"we have loaded"],[5643,5759,"the gifts for your in-laws"],[5809,5876,"in the trunk."]],"35":[[20,225,"Not just the car, but more gifts, too?"],[279,400,"That's gotta be the most generous"],[400,483,"son-in-law ever."],[508,621,"Liam's goodies in the trunk"],[621,704,"are worth more than"],[704,821,"Victor's entire car."],[1113,1188,"Who is this guy?"],[1238,1334,"How is he this rich?"],[1397,1447,"Sir,"],[1497,1672,"I have the car keys to your Ferrari."],[1730,1835,"Who should I give them to?"],[2585,2660,"Mr. Stone."],[2736,2844,"I'd like to congratulate you"],[2844,2986,"on your brand new car."],[3053,3098,"What?"],[3144,3386,"No, this, this is too expensive."],[3386,3549,"Liam, we can't accept this."],[3574,3782,"Please, accept my gift"],[3858,3970,"as your new son-in-law."],[4041,4124,"I insist."],[4137,4366,"A luxury car and a trunk full of gifts."],[4387,4504,"Everyone in this neighborhood"],[4504,4642,"is gonna be so jealous."],[4667,4725,"It's crazy,"],[4725,4867,"the Mini Cooper can't even compare"],[4867,5067,"to a single tire on this Ferrari."],[5088,5176,"Impossible."],[5205,5326,"He's just a homeless man."],[5338,5426,"There is no way"],[5426,5593,"he could buy this Ferrari."],[5626,5693,"Victor."],[5730,5780,"Yeah,"],[5801,5830,"babe."],[5830,6014,"Well, there you go, Fiona."],[6043,6156,"I guess your daughter"],[6156,6364,"and son-in-law aren't the only"],[6364,6464,"impressive ones here."],[6498,6702,"Mine aren't too bad either."],[6806,6906,"You idiot!"],[7044,7161,"Embarrassing us like this!"],[7232,7290,"We're leaving."],[7315,7457,"Let's wait until the wedding."],[7499,7657,"Let's see who shines brighter."],[7945,7999,"Wait."],[8199,8312,"Party's over, Liam."],[8345,8541,"Elara, tell me the truth."],[8558,8812,"What the hell is going on?"]],"36":[[358,454,"How dare you to"],[454,617,"embarrass me like that."],[663,771,"All right, Elara."],[792,905,"let's see if your little stray"],[905,988,"can handle it."],[1534,1676,"So, that's the truth."],[1747,1943,"I'm sorry I shouldn't have misled you."],[1943,1997,"I,"],[2060,2223,"I just didn't wanna disappoint you."],[2277,2419,"Look, I'm sorry I didn't tell you"],[2419,2648,"that I used to live on the street."],[2665,2715,"But,"],[2823,2961,"the moment Elara entered my life"],[2961,3023,"I knew."],[3057,3232,"She's kind,"],[3290,3403,"and beautiful"],[3403,3495,"and sincere."],[3549,3616,"She's the one."],[3724,3807,"Liam-"],[3807,3874,"I mean it."],[4045,4154,"Mr. and Mrs. Stone."],[4200,4391,"I'd like to ask you for your blessing."]],"37":[[25,208,"I'd like to ask you for your blessing."],[546,621,"Mom?"],[875,942,"They love each other."],[1230,1284,"Alright."],[1418,1514,"You have our blessing."],[1564,1614,"Really?"],[1672,1847,"Elara, I should be apologizing."],[1868,1943,"No, Mom."],[1972,2081,"You're my daughter."],[2102,2273,"And I know you're strong."],[2323,2473,"But I should have been there for you,"],[2581,2681,"to support you"],[2715,2790,"while you were out there"],[2790,2911,"fighting for yourself."],[2952,3123,"And we may not be as wealthy"],[3123,3336,"as those elite werewolves,"],[3382,3532,"but we have dignity,"],[3616,3720,"and we try."],[3745,3887,"And you have to promise me"],[3887,3983,"if you ever"],[3983,4179,"run into any hardship again,"],[4275,4408,"you will come to me."],[4450,4575,"I am your mother."],[4612,4733,"Do you understand?"],[4779,4875,"I promise, Mom."]],"38":[[208,379,"I've still got my eye on you, young man."],[500,646,"Don't think you're off the hook"],[646,713,"this easy."],[846,934,"Of course, ma'am."],[946,1146,"Liam, I'm, I was upset"],[1155,1209,"when I found out"],[1209,1326,"you hid your past from us,"],[1326,1476,"but you stood up for Elara"],[1476,1618,"when she needed you the most,"],[1659,1793,"and I respect that"],[1843,1918,"more than anything."],[1931,2085,"I would like to sincerely"],[2114,2273,"welcome you into this family."],[2565,2606,"Thank you."],[2777,2877,"I promise"],[2907,3048,"I'll always stand beside"],[3082,3261,"and protect Elara."],[3432,3486,"Good."],[3611,3774,"That is all I need to hear."]],"39":[[517,638,"Maybe the time is right to"],[638,796,"tell Elara who I really am."],[1363,1426,"Elara,"],[1543,1605,"there's"],[1789,1931,"there's something I need to tell you--"],[2206,2318,"Oh my god, the power went out."],[2527,2652,"Liam, are you are you there?"],[2973,3144,"Did I scare you?"],[4183,4270,"Thank you, Liam."],[4462,4733,"Well one kiss won't be enough."]],"40":[[1735,1856,"It's time to tell Elara--"],[1939,2039,"I'm an Alpha wolf."],[2202,2264,"Damn it!"],[2306,2398,"I've been poisoned."],[2406,2469,"Are you okay?"],[2485,2577,"I'm losing control"],[2577,2765,"and I can't risk hurting Elara."],[2781,2919,"Just close your eyes."],[3883,3953,"Werewolves?"],[4104,4154,"No."],[4300,4408,"No, did they take Liam?"],[4612,4662,"Victor."],[4796,4938,"He must be out for revenge."]],"41":[[0,66,"Liam!"],[120,175,"Liam!"],[216,266,"Liam."],[617,809,"Please please just let him go."],[809,880,"Don't hurt him."],[1063,1188,"Alpha, you've been poisoned."],[1188,1305,"You're already in bad shape."],[1305,1422,"Don't hurt yourself even more."],[1459,1505,"Drive."],[3607,3707,"Stop the car."],[4329,4396,"No, Elara."],[4396,4446,"Stop."],[4446,4562,"Don't come any closer."],[4792,4863,"Why? Liam?"],[4875,4988,"I just want to see"],[5055,5171,"that you're okay."],[5301,5376,"Don't cry."],[5388,5522,"I, I, I'm fine."],[5659,5789,"Look, I just had something"],[5789,5947,"urgent come up and,"],[6072,6197,"there's a charity auction tomorrow."],[6197,6264,"Meet me there."],[6327,6539,"I'll tell you everything."],[6848,6906,"Liam."],[7207,7269,"Liam."]],"42":[[204,387,"Alpha, the wolfsbane is spreading, here"],[404,529,"drink this now."],[1451,1659,"I will find out who poisoned you."],[1664,1789,"Keep it together, Alpha."],[1789,1947,"Your old wounds haven't healed yet."],[1947,2097,"Which means you cannot let yourself"],[2097,2252,"shift into wolf form."],[2268,2452,"It will tear you apart."],[2506,2585,"It's almost dawn,"],[2669,2781,"the auction's gonna start soon."],[3028,3174,"Alpha, you have led"],[3194,3336,"the Red Moon Wolf Pack to victory."],[3336,3482,"You are the king of our kind,"],[3482,3591,"the most feared name"],[3591,3720,"of all the werewolves."],[3753,3958,"Are you really willing to go this far"],[3958,4200,"for a human woman?"],[4241,4379,"I know the pack needs me."],[4466,4562,"But so does my wife."],[4567,4729,"It's time to tell her the truth."],[4846,4988,"That's the Alpha Liam I know."]],"43":[[116,241,"Liam are you safe?"],[404,525,"Are you really gonna be there?"],[788,896,"Will we be okay?"],[2131,2260,"You gotta be kidding me."],[2331,2410,"What would you attend"],[2410,2519,"a charity auction for?"],[2527,2690,"Is there even a single thing in here"],[2690,2781,"that you could afford?"],[2857,3098,"Besides, this is an invite-only event."],[3115,3253,"Only those on the guest list"],[3253,3357,"are allowed in."],[3674,3841,"Access denied, not on guestlist."],[3870,4029,"What did I just tell you?"],[4058,4141,"Are you here to"],[4141,4300,"embarrass yourself again?"],[4354,4446,"I'm here to see Liam--"],[4821,4913,"Don't worry, Elara."]],"44":[[0,83,"I'm back."],[100,171,"Liam."],[196,271,"Thank God you're okay."],[279,346,"I thought"],[400,513,"I thought you were hurt."],[517,617,"No, no no no, I"],[667,729,"I'm fine."],[863,1017,"I only left, uh,"],[1055,1163,"because I didn't want to hurt you."],[1338,1543,"And after tonight,"],[1543,1647,"you'll understand everything."],[1697,1814,"Elara, once you know the truth,"],[1814,1956,"just please don't hate me."],[1985,2106,"I don't think I could handle that."],[2106,2164,"Let's go inside."],[2973,3073,"What are you trying to pull?"],[3073,3203,"Let me guess,"],[3236,3311,"you're here to beg"],[3311,3474,"for charity donations?"],[3474,3553,"Maybe hoping for"],[3553,3687,"some leftover scraps?"],[3695,3749,"You know what?"],[3849,4049,"I have a spare guest invite."],[4087,4254,"Maybe if you two bark"],[4279,4379,"like little dogs,"],[4412,4500,"maybe I'll tell security"],[4500,4600,"you're my pets,"],[4600,4692,"and they'll let you in."],[4717,4792,"How about that?"],[4850,4934,"I'd rather die."],[5150,5284,"This invitation is legit."],[5484,5547,"Welcome."]],"45":[[4,104,"This is ridiculous."],[116,196,"Who the hell would invite"],[196,300,"two nobodies?"],[321,458,"You must have made a mistake."],[517,692,"Please, go ahead and tell them"],[692,846,"what type of invitation that is."],[888,1055,"You two are prime VIP guests,"],[1059,1238,"personally invited with top priority."],[1238,1343,"That's why you weren't on the"],[1343,1405,"guest list."],[1413,1505,"My apologies."],[1547,1676,"Please, come inside."],[1818,1885,"What?"],[1993,2127,"How can they be VIPs?"],[2143,2323,"Didn't we have to pay for these tickets?"],[2327,2444,"They must have stolen it."],[2477,2581,"Or lied somehow."],[2594,2648,"Don't worry--"],[2648,2744,"once the auction starts,"],[2744,2852,"they'll regret showing up."]],"46":[[1601,1664,"Excuse me."],[1672,1872,"Does everyone here feel comfortable"],[1872,1989,"sharing this room with the"],[2022,2193,"homeless couple of the street?"],[2264,2377,"This two snuck in"],[2377,2560,"with a stolen invitation."],[2594,2694,"A pizza girl"],[2694,2898,"and a filthy homeless man."],[2965,3128,"Are we gonna let a couple of losers"],[3157,3357,"invade our prestigious event?"],[3415,3507,"Don't forget."],[3557,3737,"Tonight, we're auctioning the relics"],[3753,3928,"of Alpha Queen Athena."],[3987,4062,"The legendary"],[4062,4208,"former Blackstone ruler."],[4266,4421,"Are we really gonna allow her"],[4421,4512,"hallowed possessions"],[4512,4629,"to be tarnished by these"],[4654,4813,"stray rats?"],[4821,5059,"Baby, trash sticks to trash."],[5092,5234,"They will find out pretty soon"],[5234,5317,"that they can't afford"],[5317,5434,"a single item here."],[5655,5714,"You know,"],[5714,5797,"you're right about one thing."],[5847,6010,"Trash does stick to trash."]],"47":[[8,95,"How about this?"],[162,275,"I propose a bet."],[321,462,"Whoever can place the highest bid"],[462,592,"on Alpha Athena's"],[592,759,"most expensive piece,"],[821,892,"wins."],[1009,1076,"What do you think?"],[1267,1322,"You?"],[1393,1522,"Competing against me?"],[1584,1685,"A homeless bum?"],[1826,1885,"Fine."],[1985,2168,"If you can not only outbid me,"],[2185,2327,"but you can win the auction,"],[2364,2527,"I, Victor Blake,"],[2548,2644,"will strip naked"],[2644,2827,"and run all around this hall."],[2940,2994,"What?"]],"48":[[4,70,"Victor?"],[79,171,"Relax, baby."],[221,308,"He's broke."],[371,500,"He doesn't stand a chance."],[513,633,"I'm not gonna lose."],[650,963,"But if you lose, you strip and run."],[1034,1088,"Deal."],[1155,1217,"The proceeds"],[1217,1355,"from today's charity auction"],[1355,1505,"will go to organizations"],[1505,1672,"supporting women, children,"],[1672,1856,"and underserved communities."],[1897,2027,"All items up for bid"],[2027,2106,"once belonged to"],[2106,2327,"the late Alpha Queen Athena"],[2331,2498,"of the Blackstone Wolf Pack."],[2573,2802,"Alpha Athena is such a legend."],[2823,2998,"She sacrificed herself for her pack."],[3007,3086,"It's so tragic"],[3086,3219,"her only daughter went missing"],[3219,3307,"in the chaos."],[3336,3457,"No one knows where she is."],[3532,3641,"Queen Athena?"],[3703,3870,"Why does that sound familiar?"],[3987,4058,"And now,"],[4083,4266,"for the highlight of today's auction,"],[4275,4583,"the coronation crown of Alpha Athena."],[4608,4721,"It's beautiful. - It's so good."],[4733,4808,"Is it real?"],[4838,4938,"Oh!"],[5847,5968,"Run, child, run."],[5997,6068,"Don't look back."],[6135,6285,"No one must ever know"],[6285,6393,"that you are my daughter."],[6510,6581,"Mom?"]],"49":[[37,208,"Elara, are you okay?"],[275,446,"But I'm Human."],[446,492,"Not,"],[525,608,"a werewolf."],[809,905,"Yeah, I'm fine."],[1130,1297,"Maybe she likes that crown."],[1384,1589,"This crown was Alpha Athena's"],[1589,1810,"most prized possession."],[1847,2014,"She wore it every day."],[2160,2406,"Let's start the bidding at 10 million."],[2406,2498,"Oh my god. - 10 million?"],[2502,2594,"My god, it's alright."],[2819,3069,"Holy-- 10 million dollars?"],[3111,3315,"That is an insane starting price."],[3549,3687,"Looks like people are ducking out"],[3687,3807,"after the first round."],[3841,3903,"Victor--"],[3958,4049,"10 million dollars."],[4162,4333,"10 million dollars, going once."],[4379,4483,"15 million."]],"50":[[12,75,"Oh, God."],[75,196,"Do you two even know"],[196,312,"if you win this insane bid"],[312,483,"that you will have to pay for it?"],[492,588,"You'd be broke."],[650,746,"Liam, we don't have the money."],[746,905,"Don't bother trying to outbid them."],[1046,1092,"Elara,"],[1092,1292,"I'm just getting you what you want."],[1401,1726,"15 million and 10,000 dollars."],[2064,2139,"20 million."],[2610,2786,"20 million dollars."],[2802,2969,"Well, our distinguished guest"],[2969,3203,"has just doubled the starting bid."],[3228,3507,"No way he has 20 million dollars."],[3507,3741,"20 million going once?"],[3778,3832,"Beat him."],[3908,4074,"I don't have unlimited budget."],[4141,4291,"I can only go for another million."],[4329,4408,"Then do it."],[4562,4675,"21 million."],[4733,4829,"30 million."],[5351,5426,"What?"]],"51":[[0,91,"You idiots."],[91,279,"Do you even know what bidding"],[279,458,"30 million dollars means?"],[458,654,"You'll never be able to pay for it."],[654,834,"30 million going once?"],[834,963,"Get ready to run around"],[963,1105,"naked and in shame."],[1226,1405,"30 million twice."],[1463,1647,"30 million three times."],[1943,2027,"Sold."],[2206,2323,"I'm sorry, but-"],[2394,2506,"Can we rescind our bid?"],[2698,2836,"The audacity."],[2844,3023,"It's already been paid for."],[3053,3132,"By who?"],[3182,3282,"Liam Blackwood."],[3670,3874,"That Liam Blackwood?"],[3937,4004,"Yeah."],[4062,4141,"It's me."],[4170,4254,"I paid for it."],[4717,4783,"Thank you."],[4909,4992,"And now,"],[5121,5221,"the crown is yours."]],"52":[[483,517,"Wait,"],[517,600,"Liam Blackwood?"],[738,834,"The Alpha of the"],[834,1009,"Red Moon Wolf Pack, Liam?"],[1326,1459,"No no no!"],[1468,1605,"This is a homeless man!"],[1605,1785,"This is a dirty tramp."],[1785,1860,"This is..."],[1864,2097,"there's something very wrong here."],[2156,2289,"There's no way you're Alpha Liam."],[2335,2444,"We saw him before,"],[2444,2623,"he's literally homeless."],[2631,2769,"I'll find out where he got the money"],[2769,2965,"to pretend to buy all this."],[3032,3190,"Victor, that's enough."],[3257,3378,"Alright, the crown"],[3378,3486,"has been handed to us."],[3486,3674,"It's ours, and we won."],[3799,3908,"And if I remember correctly,"],[4116,4208,"according to our bet,"],[4208,4408,"you're supposed to run around naked"],[4408,4587,"in front of everyone, right?"],[4746,4821,"Go ahead."],[4829,4884,"No."],[5284,5397,"Everyone shut up."],[5672,5784,"Do you know who I am?"]],"53":[[4,129,"I am an elite wolf"],[129,287,"of the Red Moon Wolf Pack."],[362,429,"And you?"],[462,633,"You are a pathetic bum."],[700,859,"You'll never replace Alpha Liam."],[930,988,"Elite?"],[1238,1480,"Stop talking like you know Alpha Liam."],[1568,1772,"Keep my name out of your mouth."],[1822,1939,"You don't even deserve"],[1939,2027,"to know my Beta,"],[2072,2139,"Ethan."],[2185,2256,"What do you mean?"],[2669,2815,"Oh my God, it's Ethan."],[2815,2961,"He is the highest ranking Beta,"],[2961,3161,"he answers only to Alpha Liam."],[3186,3440,"Ethan, kick this parasite"],[3440,3561,"out of the Red Moon Wolf Pack."],[3561,3628,"He must be here"],[3628,3741,"to deal with this imposter."],[3799,4024,"Ethan, this street trash"],[4041,4237,"dares to impersonate Alpha Liam."],[4295,4421,"We gotta teach him a lesson."],[4437,4533,"Let's take him away."],[4617,4667,"Really?"],[4800,4950,"Alright. Ethan,"],[5146,5347,"are you here to accost me?"],[5693,5747,"No?"],[5980,6035,"Well then,"],[6076,6310,"tell Victor who you're here to serve."],[6381,6656,"We are honored to serve you,"],[6715,6777,"Alpha Liam."]],"54":[[12,171,"No, uh, please."],[171,316,"Alpha, please, I'm sorry."],[329,425,"It is all my fault."],[425,529,"Have mercy."],[567,700,"Don't exile us from the pack,"],[700,884,"we need your protection."],[917,1055,"I-I am sorry, Alpha."],[1055,1105,"Please!"],[1163,1338,"I didn't know you were Alpha Liam."],[1388,1451,"Please, Alpha."],[1451,1572,"It's all his fault."],[1572,1689,"It's his fault!"],[1705,1897,"Please, exile him. - No no."],[1897,1964,"Spare me. - What?"],[1968,1997,"No."],[1997,2031,"What?"],[2031,2139,"You said you loved me."],[2143,2310,"Get away from me, I don't know you."],[2335,2414,"Please, Liam."],[2448,2498,"Bitch."],[2594,2694,"That's crazy."],[2902,3048,"How dare you slap me?"],[3048,3378,"Helena, you poisoned our Alpha."],[3378,3457,"Do you honestly think"],[3457,3553,"we would expect you"],[3553,3653,"to get away with this?"],[3653,3741,"You? You- how do you"],[3741,3828,"know about this?"],[3828,3928,"I didn't mean to."],[3928,4029,"It was an accident!"],[4029,4187,"It- I didn't mean to."],[4200,4412,"Exile them from the pack."],[4441,4554,"Kick them out,"],[4571,4633,"now."],[4662,4775,"No, no no no. - Please, Alpha."],[4775,4846,"Alpha, please."],[4846,4938,"No no, what are you doing?"],[4938,5125,"No no."],[5146,5276,"You fucking bitch."],[5276,5438,"You won't get away with this!"],[6239,6343,"Are you a werewolf?"]],"55":[[4,145,"Are you Alpha Liam of"],[145,246,"the Red Moon Pack?"],[254,325,"Elara,"],[325,446,"Don't touch me."],[508,617,"Tell me the truth."],[633,809,"Who is the man sitting in front of me?"],[959,1105,"The man that I married?"],[1138,1330,"The man that I fell in love with?"],[1418,1509,"Who are you?"],[1614,1760,"Look Elara, I-I'm sorry."],[1760,2060,"I-I tried so hard to find the right time"],[2114,2248,"to tell you who I really am."],[2285,2464,"I-I just, I couldn't but"],[2606,2756,"I'm coming clean now."],[2769,2907,"I don't want to hide anything"],[2907,2977,"from you anymore."],[3019,3090,"The truth is"],[3228,3340,"I really am"],[3415,3661,"Alpha Liam of the Red Moon Wolf Pack."],[3749,3874,"I'm a werewolf,"],[3874,3924,"Elara."],[3924,3999,"So the werewolf"],[3999,4133,"that I saw jumping out the window"],[4133,4237,"last night, that was you?"],[4404,4592,"And you just let me stand there,"],[4654,4884,"crying, foolishly worried about you?"],[5038,5271,"Elara, I'm so sorry. - I hate you."],[5555,5626,"Elara."]],"56":[[62,125,"Kill her!"],[208,358,"And I'll make you all rich."],[400,446,"Hey."],[467,558,"Let go of me."],[592,759,"Did you think you could win, you bitch?"],[759,905,"You're gonna fucking die now!"],[905,971,"Kill her!"],[1197,1272,"Liam!"],[1601,1701,"Keep it together, Alpha."],[1701,1876,"Your old wounds haven't healed yet,"],[1876,1976,"which means you cannot"],[1976,2181,"let yourself shift into wolf form."],[2181,2373,"It will tear you apart."],[2573,2631,"Kill him!"],[2631,2781,"If you don't kill him, we're fucked!"],[2781,2852,"No!"],[2957,3019,"No!"],[3395,3516,"You'll pay for this."]],"57":[[396,579,"So, Elara is a werewolf too?"],[1242,1326,"My Luna."],[1455,1539,"Deal with them."],[1568,1668,"At your command, Luna."],[2210,2344,"The last thing I wanted to do"],[2402,2464,"was hurt you."],[2619,2769,"But that's exactly what I've done."],[3069,3140,"No, Liam."],[3286,3340,"Liam."],[3499,3574,"Liam, it's okay."],[3603,3657,"We'll get you help."],[3657,3732,"Just hold on."],[5910,6068,"He'll pull through, sweetheart."],[6156,6218,"Mom?"],[6310,6348,"Dad?"],[6348,6473,"How am I a werewolf?"]],"58":[[20,216,"Elara, my dear,"],[333,533,"you're not our biological daughter."],[742,838,"What? What do you mean?"],[913,1096,"Your mother and I couldn't conceive"],[1176,1305,"after years of trying."],[1459,1743,"And one day we found you,"],[1835,1993,"unconscious in the forest."],[2093,2210,"We thought you were human."],[2360,2423,"And"],[2469,2610,"when we couldn't find your family,"],[2615,2769,"we decided to adopt you."],[2923,3140,"You had amnesia from a fever,"],[3244,3482,"and we took you in as our own."],[3511,3645,"We never said anything"],[3645,3837,"because, well, it just-"],[3837,4004,"didn't ever seem like"],[4004,4124,"the right time."],[4200,4358,"But we could have never"],[4387,4637,"imagined that you were a werewolf,"],[4704,4817,"let alone the daughter"],[4817,5009,"of Alpha Athena."],[5196,5280,"If you hate me,"],[5422,5513,"I won't blame you."]],"59":[[25,75,"But"],[133,250,"you'll always be welcome"],[250,329,"to come home."],[408,513,"I-I just"],[592,696,"I just"],[813,971,"I just hope you can forgive us."],[1092,1146,"Oh."],[1343,1584,"My baby! - Mom..."],[1939,2010,"He's awake."],[3365,3557,"Don't, don't cry, okay?"],[3561,3691,"It's not your fault."],[3891,4008,"I'll go get the doctor."],[4012,4187,"Oh, no. Don't go."],[4596,4679,"Please, just"],[4821,4888,"stay."]],"60":[[4,50,"Okay."],[233,358,"I'll stay by your side."],[396,638,"I didn't scare you, did I?"],[721,834,"I was scared to death."],[909,1071,"Liam, I didn't know"],[1071,1188,"what I would do without you."],[1355,1589,"Well, I-I wouldn't go anywhere."],[1659,1714,"I'm just"],[1822,2093,"so happy with how everything is going."],[2260,2381,"Are you out of your mind?"],[2423,2510,"You're injured,"],[2510,2665,"what is there to be happy about?"],[2773,3069,"Because it wasn't you who was hurt."],[3203,3357,"I saw how you protected me,"],[3420,3645,"and how much you care for me."],[3799,3966,"Well, I'm not happy that you're hurt."],[4083,4200,"Are you still mad at me?"],[4291,4529,"I didn't tell you that I was Alpha Liam?"],[4529,4608,"I was,"],[4934,5021,"but I'm not anymore."]],"61":[[187,367,"Ethan told me everything."],[454,575,"I said I didn't want"],[575,742,"anything to do with werewolves"],[742,975,"because of Victor, not you."],[996,1238,"Your greasy scent makes me sick."],[1443,1639,"I never meant you, Liam."],[1893,2106,"I don't feel resentful anymore."],[2106,2206,"I don't blame you."],[2264,2327,"Well,"],[2394,2523,"werewolves and humans"],[2523,2623,"are better off together."],[2769,2936,"Neither one better than the other."],[2986,3090,"You know, I have"],[3132,3278,"another secret to tell you."],[3465,3616,"That that day when I was talking"],[3616,3724,"with your parents,"],[3749,3845,"I wasn't lying."],[3966,4166,"I fell in love with you"],[4216,4358,"the moment you saved me."],[4483,4546,"Do you remember that day"],[4546,4658,"that you were delivering pizza"],[4658,4859,"and you saved a wolf?"],[4938,5017,"You poor thing,"],[5017,5184,"don't worry, we'll get you help."],[5217,5330,"That was you?"],[5476,5668,"I thought I was saving a husky."],[5797,5889,"A husky?"],[6060,6260,"No wonder you took me to the vet."],[6398,6552,"I'm such an idiot."],[6869,7036,"I love you so much,"],[7173,7353,"my beautiful idiot."]],"62":[[487,550,"Alpha,"],[754,909,"the Blackstone Wolf Pack heard that"],[909,1101,"our Luna is Alpha Athena's daughter."],[1167,1363,"They're demanding that she return"],[1363,1497,"and lead as their Alpha."],[1680,1718,"Me?"],[1897,1997,"Well, it makes sense."],[2052,2164,"I've seen how strong you are."],[2310,2373,"Don't worry."],[2439,2502,"I'll help you."],[2548,2773,"There's one more thing, Alpha."],[2848,3111,"Your wedding with our Luna is ready."],[3224,3382,"We're all ready for the ceremony."],[5255,5518,"Mr. Groom, it is time to turn around"],[5518,5655,"and see your bride."]],"63":[[629,788,"Beautiful entrance."],[821,950,"And what chemistry."],[1005,1059,"Wow."],[1201,1397,"Alpha, it's time to see your bride."],[2944,3040,"Will you marry me?"],[3378,3490,"I give to you"],[3520,3670,"my most precious daughter."],[3816,3937,"I will stand by her,"],[3937,4170,"through every storm and every dawn."]]}