{"1":[[216,300,"Alex!"],[304,400,"Alex!"],[404,500,"Man down! I repeat,"],[504,633,"we have a man down."],[633,759,"We need backup now."],[888,971,"Cole."],[975,1013,"Yeah?"],[1017,1155,"I got surrounded, man."],[1159,1272,"Just get out of here."],[1276,1547,"Looks like you won the bet."],[1551,1584,"All right,"],[1589,1851,"we're getting out of here together."],[1935,2181,"Take this."],[2185,2423,"You are the best of the best."],[2427,2565,"Promise me."],[2569,2811,"Get back home"],[2815,3082,"and protect my sister, Victoria."],[3086,3307,"The Kingsley family is a snake pit."],[3311,3516,"You have to protect her."],[3520,3682,"It was an honor serving with you."],[3816,3933,"Go!"],[4337,4425,"Alex!"],[5038,5217,"Alex saved my life that day."],[5221,5409,"And I never looked back since."],[5413,5584,"I left the bloodshed behind"],[5588,5714,"and built the Shadow Alliance,"],[5743,5993,"the country's largest veterans network."],[5997,6126,"The Shadow Alliance quickly"],[6131,6227,"rose to power."],[6231,6389,"Feared and respected across"],[6393,6489,"the world."],[6598,6802,"But I chose a much simpler post."],[6810,6956,"Content to live in the shadows"],[6961,7165,"as the Kingsleys’ security guard,"],[7178,7278,"keeping one promise"],[7278,7382,"to a fallen friend."],[7486,7649,"To protect Victoria."],[9663,9826,"Good morning, boss!"],[11361,11524,"After Victoria gets married today,"],[11524,11628,"my job is done."],[11728,11886,"No more hiding my identity."],[12220,12291,"Yo, Cole."],[12303,12408,"Looking sharp as ever."],[12466,12550,"You think we'll get a slice"],[12554,12620,"of that wedding cake?"],[12721,12850,"Heard Ms. Kingsley's marrying"],[12854,12929,"some rich bastard"],[12933,13046,"with trust fund money."],[13050,13158,"The least they can do is give us some"],[13163,13267,"good food and booze."],[13409,13630,"Less talk, more work."],[13634,13776,"What work? It's not our fault"],[13776,13922,"they sent us to do some patrol"],[13926,14072,"to some empty church."],[14118,14201,"Look around, man."],[14260,14497,"Not a soul in sight."],[14501,14618,"Even the stray cats around here"],[14622,14802,"have better things to do."],[15052,15206,"I take that back."],[15211,15344,"Our bride is rolling up."],[15348,15486,"Showtime, baby."],[17826,17926,"Skip the speeches."],[17926,18118,"No pictures. No champagne tower."],[18163,18330,"I want this wrapped up in 30 minutes."],[18518,18585,"Boss."],[18693,18785,"Nobody's here."],[18839,18935,"Not even the groom."]],"2":[[0,166,"Where is everyone?"],[171,321,"I just got word"],[325,446,"the groom's backed out."],[450,567,"He said..."],[571,796,"Said what?"],[800,909,"He said that"],[913,1055,"if you're the one that Triston Van"],[1059,1184,"wants, no man in the city"],[1188,1363,"will dare to marry you."],[1455,1755,"Tell Tristan to leave me the hell alone."],[1772,1926,"That idiot doesn't get to decide"],[1931,2047,"how I live my life."],[2052,2214,"But, boss, the deadline for"],[2218,2306,"your marriage is coming up."],[2310,2431,"If you don't get married soon,"],[2435,2485,"then they’ll–"],[2489,2640,"Take back my parent's company,"],[2652,2823,"right?"],[2827,3032,"My parents might be dead"],[3036,3132,"and my brother might have"],[3136,3190,"gone missing,"],[3199,3319,"but no one's touching"],[3324,3499,"our family business!"],[4504,4625,"Congratulations on the wedding,"],[4625,4925,"Ms. Kingsley."],[5092,5192,"Who are you?"],[5196,5334,"Cole Slade."],[5338,5451,"You married?"],[5455,5522,"No."],[5526,5609,"Girlfriend?"],[5613,5772,"Also no."],[5776,5901,"Good."],[5905,6093,"Then you can marry me."]],"3":[[108,216,"Sorry, no can do."],[558,738,"It's purely transactional."],[742,846,"I'll pay you a salary"],[850,1038,"for every month that you're my husband."],[1076,1205,"20k?"],[1209,1397,"How does that sound?"],[1401,1614,"After a year, we can get divorced."],[1618,1881,"Still no."],[1885,2072,"Do you know who I am?"],[2077,2260,"I'm Victoria Kingsley,"],[2264,2452,"CEO of Kingsley Tech."],[2773,2894,"Fine."],[2898,3036,"Name your price."],[3040,3199,"I know who you are, Ms. Kingsley."],[3203,3411,"That's exactly why I can't marry you."],[3415,3582,"You're the sister of my best friend."],[3586,3770,"Someone I swore to protect."],[3774,3920,"Not everything is about money."],[3924,4008,"Seriously?"],[4012,4187,"You're a goddamn security guard."],[4191,4441,"You have no right to turn down my boss."],[4446,4733,"No, no. It's fine."],[4738,4863,"I'll handle this."],[4867,4979,"You try to put out the fires"],[4984,5167,"with my family."],[6969,7173,"Tristan Van."],[7178,7478,"Kingsley's arch-nemesis."],[7816,8116,"What is he doing here?"],[8875,9175,"Move it, guard dog."],[9459,9513,"Alex,"],[9659,9959,"I can't do this anymore."],[10035,10326,"Where are you?"],[10331,10523,"Oh, Vicky!"],[10527,10610,"I heard you were in the market"],[10614,10785,"for a groom."],[10952,11048,"Alex,"],[11052,11194,"looks like your sister's in trouble."]],"4":[[16,179,"Who the hell let you in here?"],[183,458,"Victoria Kingsley,"],[462,759,"you know how much I love you."],[763,863,"Marry me."],[867,1005,"And you know I'd rather die"],[1009,1167,"than marry you."],[1259,1501,"Oh, baby, but then,"],[1509,1651,"you lose Kingsley Corp."],[1735,1931,"News flash, every man in the city"],[1935,2064,"knows you’re mine."],[2223,2289,"No one's gonna"],[2293,2431,"marry you, sweet cheeks."],[2544,2844,"It's either me or nothing."],[2919,3211,"Your ass is mine."],[3215,3340,"Not in a million years,"],[3345,3511,"you scumbag."],[3516,3682,"You think I don't know?"],[3687,3853,"You're just after the quantum chip tech"],[3858,3987,"my parents left behind."],[3991,4137,"And marrying me happens to be the"],[4141,4250,"fastest, cleanest way"],[4254,4341,"to get your hands on it."],[4383,4637,"Fine."],[4642,4850,"You caught me."],[4854,4971,"Well, then,"],[4975,5155,"let’s make this marriage official."],[5230,5530,"Get off me!"],[5613,5910,"Go ahead. Scream your little heart out."],[6669,6827,"No! Where the hell you going?"],[6831,7077,"I’m going in."],[7082,7282,"No man is brave enough to"],[7286,7407,"play savior for Ms. Kingsley."],[9184,9225,"I am."]],"5":[[4,166,"Who the fuck are you?"],[171,237,"Leave him alone."],[241,454,"He has nothing to do with this."],[483,779,"This guy must have a death wish!"],[796,975,"You think you can come in here"],[980,1092,"and play hero?"],[1209,1451,"Do you know who the fuck I am?"],[1468,1676,"I don't give a shit who you are."],[1680,1981,"Victoria is my fiancée."],[2202,2502,"You? Marry Victoria Kingsley?"],[2619,2740,"Don't make me laugh."],[2744,2852,"That's right."],[2857,2936,"We're getting married,"],[2940,3061,"and there's nothing you can do to"],[3065,3207,"change that, Tristan."],[3211,3319,"Sorry, buddy."],[3324,3541,"Then you're going out in a body bag."],[3545,3778,"Victoria is mine."],[3858,4045,"Kill this cocky piece of shit."],[4070,4137,"Let's go."],[4154,4216,"No!"],[6694,6865,"You can't just be a security guard."],[7182,7261,"But I am."]],"6":[[0,300,"Woah, easy there, bud."],[312,475,"Don’t get too trigger-happy!"],[479,604,"Laying your hands on a woman"],[608,767,"doesn't make you a man."],[771,925,"You want to fight?"],[930,1080,"Try someone your own size."],[1084,1297,"Pretty tough for a guard dog,"],[1301,1484,"I'll give you that."],[1488,1789,"Do you think this shit scares me?"],[1897,2089,"The Kingsley banquet’s tonight."],[2093,2202,"I'm going to make sure everyone"],[2206,2298,"hears that you married"],[2302,2439,"a security guard."],[2773,2902,"Let's see how long it takes your family"],[2907,2952,"to disown you."],[2957,3069,"Is that a threat?"],[3073,3365,"No, just the truth."],[3370,3670,"The Kingsleys are broke, Vicky!"],[3991,4099,"You think this rent-a-cop’s"],[4104,4287,"going to fix that?"],[4391,4679,"Well, if I can't fix it,"],[4683,4871,"maybe this will."],[4875,4959,"No, no, no."],[4963,5176,"If you kill me,"],[5180,5480,"the Kingsleys are finished."],[5518,5689,"We'll see about that."],[5693,5797,"Fine, fine fine, fine."],[5801,5980,"We'll have a civilized discussion"],[5985,6101,"at the banquet."],[6118,6168,"Please,"],[6289,6585,"don't kill me."],[6790,7090,"Get the fuck out!"],[7436,7620,"Thanks for saving me just now."],[7624,7924,"You okay?"],[7941,8241,"Cole,"],[9451,9680,"did you mean what you said earlier?"],[9684,9797,"Will you marry me?"]],"7":[[8,162,"Marry you?"],[166,304,"You’ve got the city's"],[308,487,"biggest crime boss, Tristan Van,"],[492,563,"breathing down your neck"],[567,721,"and you want me to marry you?"],[725,846,"Is this supposed to be a thank you"],[850,1001,"or a death sentence?"],[1005,1151,"You're right."],[1155,1455,"It's too much to ask."],[2452,2752,"But I happen to like a good challenge."],[3090,3257,"So, yeah, Victoria."],[3261,3411,"I'll marry you."],[3415,3549,"Really?"],[3553,3703,"Let's go make it official."],[3707,3924,"Alex, if marrying your sister is the"],[3928,4029,"only way to protect her,"],[4054,4245,"then I got to do what I got to do."],[4250,4429,"Hope you're not mad at me, brother."],[4433,4733,"Let's go."],[4921,5075,"Oh my God, boss, you did it!"],[5080,5226,"You really did it!"],[5230,5305,"This means you saved"],[5309,5413,"your parents’ company!"],[5417,5714,"Yes, yes. Keep your voice down, Emily."],[5718,5905,"By the way, husband,"],[5910,6060,"tomorrow's our family banquet."],[6122,6264,"You're coming with me."],[6268,6318,"Your call."],[6435,6502,"And..."],[6852,6961,"Here's 100 grand."],[7090,7198,"I need you to get a"],[7203,7386,"gift for the banquet."],[7411,7561,"Call it a wedding gift"],[7565,7761,"from my husband to the Kingsleys,"],[7761,7824,"got it?"],[7832,8066,"But, boss, a 100 grand gift isn't"],[8070,8124,"going to make them"],[8128,8437,"forget you married a security guard."],[8445,8621,"Let's just hope it works."],[8625,8792,"I've got to get back to the office."],[9046,9159,"Wow, Alex,"],[9163,9355,"you were right!"],[9359,9659,"Kingsley family really is a snake pit."],[9705,9855,"Yeah, it's me."],[9859,9955,"Have the Shadow Alliance"],[9959,10160,"prepare a gift for the Kingsley family."],[10164,10318,"Oh!"],[10326,10377,"Make it big."]],"8":[[642,813,"Mr. Conrad Kingsley."],[817,938,"I heard you just closed the"],[942,1092,"East Coast port deal at the"],[1096,1276,"insistence of your father, Alistair."],[1330,1463,"It's very impressive."],[1468,1597,"It's just another small win"],[1601,1659,"for the family."],[1664,1843,"Nothing to brag about."],[3795,3912,"Mr. Kingsley!"],[3916,4020,"To many more years of"],[4024,4116,"good health and fortune."],[4145,4396,"How's father Alistair?"],[4400,4542,"I've been..."],[4546,4617,"praying for him."],[4621,4842,"I have been"],[4846,5013,"planning on leading the Kingsley legacy"],[5017,5059,"for years."],[5100,5367,"He's fine."],[5372,5663,"Just a little something."],[5668,5864,"Keep the Kingsley family"],[5868,5943,"shining."],[5947,6047,"What is it?"],[6051,6197,"Jesus!"],[6202,6356,"That's the legendary revolver"],[6360,6594,"from Elvis Presley's private collection."],[6664,6902,"Last I heard, it was going for 3 million."],[6906,7065,"That is a very generous gift."],[7069,7136,"3 million?"],[7140,7323,"That's got to be worth at least five."],[7328,7436,"The Van family certainly knows how"],[7440,7553,"to make an entrance."],[7557,7703,"A little bird told me that you've been"],[7707,7857,"courting my niece, Victoria."],[7878,7941,"That's too bad,"],[8041,8270,"because... Ms. Victoria’s"],[8295,8425,"given her heart to someone else."],[8479,8533,"Has she?"]],"9":[[0,191,"Who is that with Victoria?"],[237,467,"Her security guard."],[471,625,"Wow."],[625,775,"The mighty Kingsleys really"],[784,992,"have fallen since their grandfather,"],[996,1142,"Alistair Kingsley, is sick."],[1146,1376,"I heard they're barely hanging on"],[1380,1547,"under Conrad's leadership."],[1593,1705,"Tristan was supposed to"],[1710,1780,"bail them out."],[1785,2056,"Guess Victoria's lost it."],[2060,2223,"Victoria, who is this?"],[2235,2310,"Uncle,"],[2314,2556,"this is Cole Slade."],[2560,2669,"My husband."],[2673,2957,"Husband?"],[2961,3161,"Are you trying to kill your grandfather?"],[3165,3257,"You're young, you know—"],[3261,3332,"throw tantrums,"],[3332,3486,"but marriage is not a game."],[3490,3678,"This isn't a tantrum."],[3682,3949,"And it's not about money either."],[3953,4104,"I love Cole, and"],[4108,4270,"that's why I chose him."],[4279,4304,"Well!"],[4466,4683,"Now that you're married, niece,"],[4688,4846,"Tristan, maybe our families can join"],[4850,5050,"together through my daughter, Serena."],[5221,5442,"You know, this is a family banquet."],[5447,5584,"You didn't come empty-handed,"],[5588,5705,"did you?"],[5709,5918,"Tristan brought a five mil revolver"],[5922,6010,"for grandpa."],[6022,6189,"What about you, Vicky?"],[6193,6306,"What did you bring?"],[6310,6406,"Oh, shoot."],[6410,6598,"I only gave Cole 100 grand."],[6602,6827,"Tristan dropped five mil?"],[6831,6944,"We're screwed."],[6952,7019,"Of course we did."]],"10":[[4,304,"Cole, you actually brought something?"],[358,500,"Of course we brought a gift."],[504,663,"Well, let's see what he's got."],[667,709,"Perhaps"],[713,1055,"Mr. Slade is a secret billionaire."],[2364,2435,"What is this?"],[2439,2623,"Seriously?"],[2627,2748,"That's the gift?"],[2752,2944,"It looks like some toy from the"],[2948,3082,"dollar store’s clearance bin."],[3403,3440,"Victoria,"],[3445,3507,"not to lecture you,"],[3511,3611,"but this is a family banquet."],[3616,3766,"You can't just phone it in."],[3770,3895,"But a security guard"],[3899,4120,"is a security guard."],[4220,4254,"Cole!"],[4258,4458,"I thought I gave you 100 grand."],[4462,4554,"How is this–"],[4604,4850,"Are you sure you don't want to know"],[4854,5005,"what that badge is actually worth?"],[5105,5251,"Go on."],[5255,5363,"I'm listening."],[5367,5472,"Let's see what kind of crap"],[5476,5613,"this security guard can spin."],[5618,5793,"Let me guess..."],[5797,5951,"my dear cousin-in-law is"],[5955,6160,"going to tell us that this is some sort of"],[6164,6339,"secret society emblem."],[6343,6589,"Let the kid talk!"],[6594,6748,"This is a Shadow Alliance badge."],[7044,7132,"Whoever holds it"],[7136,7361,"can move capital and access assets"],[7365,7428,"at will."],[7432,7691,"Oh my God."],[7695,7845,"The Shadow Alliance holds sway"],[7849,7924,"over governments"],[7928,8045,"and the criminal underworld."],[8095,8249,"They practically run the whole globe."],[8254,8375,"With this badge,"],[8379,8533,"the Kingsleys can finally get their"],[8537,8725,"hands on that transpacific trade"],[8729,8817,"route permit they've been"],[8821,8971,"dreaming about for years."],[9013,9146,"Wait,"],[9159,9325,"did you just say the Shadow Alliance?"],[9405,9517,"You mean the infamous"],[9522,9672,"league of military veterans?"]],"11":[[16,87,"Who are you?"],[91,166,"And what are you doing with the"],[171,287,"Shadow Alliance's badge?"],[291,362,"I'm the founder"],[367,558,"of the Shadow Alliance."],[563,859,"This badge is my ID."],[863,1038,"It carries my authority."],[1042,1213,"This rent-a-cop,"],[1217,1426,"the founder of the Shadow Alliance?"],[1434,1630,"Don't make me laugh."],[1634,1735,"Vicky,"],[1743,2027,"your man got a PhD in bullshit or what?"],[2031,2173,"Yo, security guy,"],[2177,2477,"do you need us to call you a shrink?"],[2602,2723,"Hey, did you just pocket that"],[2727,2831,"hundred grand I gave you,"],[2836,2932,"and now you're..."],[2936,3090,"spinning these lies to cover it up?"],[3094,3303,"Of course not, Victoria."],[3307,3603,"Everything I'm telling them is true."],[3628,3803,"Get out!"],[3816,3933,"And don’t show your face around"],[3937,4054,"here again."],[4058,4191,"Especially in front of your grandfather."],[4525,4792,"This badge was a gift for Alistair,"],[4796,5055,"given out of respect for Victoria."],[5059,5121,"You know, it’s a shame,"],[5121,5267,"none of you can recognize value"],[5271,5422,"when it's right in front of you."],[5559,5626,"But luckily,"],[5751,6051,"I brought backup."],[6064,6239,"Victoria said her grandfather was a"],[6243,6373,"collector of Renaissance art,"],[6431,6552,"so I had my people send this over"],[6556,6731,"right away."],[7323,7453,"The original..."],[7457,7624,"Mona Lisa."],[7720,7920,"So, what do you think?"],[7924,8033,"A little more to your liking?"]],"12":[[58,175,"This can't be real."],[179,479,"That painting is worth 10 billion."],[779,1080,"Mission accomplished."],[1176,1351,"But boss, didn't you just give him"],[1355,1451,"100 grand?"],[1455,1693,"Where did the 10 billion come from?"],[1697,1876,"I have no idea."],[1881,2027,"This is one of the nicest gifts"],[2031,2106,"we've ever received."],[2243,2389,"It might actually get your grandfather"],[2394,2460,"out of bed."],[2523,2673,"What's the point?"],[2677,2957,"You ran him off."],[2961,3261,"Mr. Slade is a very generous man."],[3349,3490,"What are you waiting for?"],[3495,3695,"Go chase after him."],[3699,3778,"Bring him back here"],[3782,3916,"so your grandfather can meet him."],[3920,4204,"Having gold diggers as family..."],[4375,4575,"is humiliating."]],"13":[[525,738,"10 billion blown."],[742,880,"Couldn't even get a decent meal"],[884,1013,"out of it."],[1034,1163,"Bunch of money-hungry"],[1167,1334,"jackasses."],[1393,1693,"Couldn't even cover a burger."],[1810,1922,"Really?"],[1926,2085,"A guy who could pull out 10 billion"],[2089,2298,"without blinking is eating this."],[2364,2510,"Well, it beats hanging out"],[2515,2619,"with someone who wouldn't even"],[2623,2861,"buy me one of these."],[2969,3269,"Get in."],[4175,4437,"So where are we going?"],[4441,4596,"Home."],[4604,4742,"Whoa!"],[4746,4971,"Moving a little quick, aren't we?"],[4975,5130,"I'm cooking."],[5134,5376,"Just figured I'd thank you properly."],[5513,5630,"Hold on. Okay."],[5634,5976,"Victoria Kingsley... in the kitchen. Wow."],[6022,6101,"Okay, you know what,"],[6106,6202,"I'm gonna have to record this"],[6206,6314,"just so we can have it as"],[6318,6523,"part of our family history."],[6527,6598,"Let me find my phone."],[6715,6856,"Shut up."],[6861,7036,"Buckle up."],[7315,7494,"This used to be my parents’ place."],[7499,7711,"Security’s solid."],[7716,7845,"Make yourself comfortable."],[7849,7920,"I'm gonna go change."]],"14":[[383,583,"How’s steak sound?"],[588,788,"Wow. You actually cook?"],[792,1055,"I thought you just signed checks."],[1059,1113,"There's a lot"],[1117,1297,"you don't know about me."],[1301,1484,"That 10 billion..."],[1488,1789,"where did it actually come from?"],[1981,2281,"Well, you gave it to me, remember?"],[2419,2719,"Me? No, it was–"],[3286,3582,"Are you crazy?"],[5359,5584,"Security’s solid, huh?"],[5613,5689,"How did you know this"],[5693,5860,"place was bugged?"],[5935,6147,"Occupational hazard."],[6151,6277,"Security guard’s supposed to keep"],[6281,6414,"things secure, right?"],[6418,6627,"A security guard who throws around"],[6631,6827,"10 billion like it's pocket change?"]],"15":[[16,183,"I'll pay you back soon."],[187,271,"Three days from now,"],[275,404,"the Shadow Alliance is hosting"],[408,517,"the Golden Coast Summit"],[521,663,"at the Maple Hotel,"],[667,779,"to decide on the next big"],[784,829,"partnership."],[1672,1755,"That'll put your family"],[1760,1972,"at the top of the list."],[2006,2110,"Smoother it goes for you,"],[2114,2398,"the faster I get my money back, right?"],[2452,2556,"You're telling me,"],[2560,2752,"this little thing’s that powerful?"],[2802,2923,"You'll see."],[2927,3057,"Fine."],[3061,3249,"I owe you"],[3253,3424,"Twice."],[3436,3586,"Yeah, yeah, the gift."],[3616,3912,"And our marriage, which, by the way..."],[3941,4116,"What?"],[4129,4437,"...is a contract. So we need rules."],[4675,4863,"I'm listening."],[4867,4988,"Rule number one–"],[4992,5163,"stay out of each other’s love lives."],[5284,5434,"Fair."],[5438,5534,"Rule number two–"],[5538,5743,"My place isn’t safe anymore."],[5747,5855,"My grandpa and uncle will just keep"],[5860,5951,"spying on us. So-"],[5960,6256,"So we act like the perfect couple."],[6573,6690,"Luckily for you,"],[6694,7065,"I am really good at faking it."],[7157,7457,"Rule three–"],[7511,7770,"My bedroom is off limits."],[7774,7920,"To everyone..."],[8033,8162,"but me?"]],"16":[[20,196,"Especially you."],[196,375,"No kissing, no sex."],[404,583,"No kissing, no sex?"],[592,725,"Yeah."],[725,905,"Really, we'll be the perfect couple."],[1001,1180,"Not my problem."],[2156,2335,"No eggs tonight."],[2377,2556,"You're allergic."],[2640,2819,"How did you know that?"],[2894,3073,"You're spying on me too?"],[3178,3286,"Relax."],[3286,3465,"Just break room gossip, that's all."],[3561,3678,"Victoria Kingsley"],[3678,3887,"breaks out in hives when she has eggs."],[3924,4104,"What is that worth, like a million bucks?"],[4187,4300,"My allergies"],[4300,4483,"are none of your business."],[4567,4721,"Just sit down and wait."],[4721,4900,"Dinner will be ready soon."],[8199,8379,"Surveillance too."],[8466,8650,"Just like I thought."],[12504,12683,"I told him no kissing!"],[12762,12912,"But we did it again."],[12912,13050,"Why can't I resist him?"]],"17":[[621,771,"Damn, wifey."],[771,955,"That was Oscar-worthy."],[975,1155,"It was an accident."],[1255,1463,"Honey, the steak's burning."],[2339,2489,"You did that on purpose!"],[2506,2686,"Just another day in married life."],[2756,2915,"Now about that"],[2915,3073,"accidental kissing fee..."],[3073,3190,"Shut up!"],[3274,3395,"Need a hand, wifey?"],[3445,3553,"Call me that again"],[3553,3636,"and I'll knock you out"],[3636,3745,"with this frying pan."],[3753,3858,"Feisty."],[3908,3999,"I like it."]],"18":[[187,271,"Looks like these two"],[271,450,"are getting along"],[496,675,"better than we expected."],[700,804,"Dad,"],[846,1046,"doesn't this seem off?"],[1205,1276,"That Cole guy"],[1276,1480,"just casually drops 10 billion,"],[1480,1685,"but he's working as a security guard?"],[1768,1885,"All the bugs are dead?"],[1893,2031,"Every single one."],[2052,2160,"And whoever did it"],[2185,2385,"knows exactly what they were doing."],[2469,2615,"Interesting."],[2631,2740,"Seems our little niece"],[2740,2844,"and this rent-a-cop"],[2844,3023,"are just full of surprises."],[3165,3315,"And did you run all the usual checks?"],[3315,3415,"I went through all the contacts"],[3415,3499,"we have."],[3541,3724,"Still nothing."],[3770,3949,"No bank accounts,"],[3958,4137,"no credit history."],[4141,4391,"Not even a parking ticket."],[4408,4466,"There's only three"],[4466,4575,"kinds of people in this world"],[4575,4754,"that stay this clean."],[4813,4921,"Spies,"],[5063,5171,"the dead,"],[5467,5647,"and those richer than us."],[5709,5893,"So which one is he?"],[5943,6110,"Excuse me, miss! You can't enter!"],[6114,6227,"Get out of my way!"],[6318,6393,"I'm so sorry,"],[6393,6477,"Mr. Kingsley."],[6785,6919,"So it was you!"],[7082,7219,"You planted the bugs!"]],"19":[[33,70,"Victoria,"],[70,141,"I did this to protect"],[141,258,"my brother's company."],[271,404,"Protect it?"],[412,525,"You mean steal it"],[525,646,"from his only daughter?"],[654,784,"Enough!"],[1155,1263,"Victoria,"],[1263,1447,"who is this Cole?"],[1530,1685,"Some hot shot?"],[1697,1797,"Why can't we"],[1797,1926,"dig anything up on him?"],[1964,2118,"A hot shot?"],[2118,2218,"He's just our company's"],[2218,2314,"security guard."],[2577,2652,"You really think"],[2652,2831,"we're going to fall for that?"],[2877,2973,"You're embarrassing"],[2973,3157,"our whole family."],[3207,3386,"Explain the $10 billion gift."],[3424,3603,"There's only two options here."],[3620,3766,"One, you funneled"],[3766,3945,"company funds."],[4124,4304,"Or two,"],[4333,4512,"the gifts are fakes."],[4875,4971,"All of them."]],"20":[[54,183,"There's no $10 billion in"],[183,300,"your company accounts."],[308,487,"So that only leaves one option."],[563,742,"The gifts are all knockoffs."],[813,988,"Knockoffs?"],[988,1113,"Don't you even know how bad"],[1113,1297,"this makes our family look?"],[1363,1459,"I told you, dad,"],[1468,1659,"she's always been a stain"],[1659,1843,"on this family."],[1868,2002,"Stop making assumptions."],[2027,2118,"Just because you don't know"],[2118,2202,"who Cole is"],[2202,2335,"doesn't mean the gifts are fake."],[2339,2414,"Shut up!"],[2423,2556,"The Kingsley legacy is not yours"],[2556,2677,"to sell off to some rent-a-cop!"],[2681,2786,"No, you shut up!"],[2794,2911,"Even if the gifts are fake,"],[2911,3069,"I would still never marry Tristan!"],[3069,3161,"Ever!"],[3624,3774,"Serena, from now on,"],[3774,3874,"I want you to spend more time"],[3874,4054,"with Tristan Van."],[4175,4320,"The Kingsleys need the"],[4320,4412,"Van family's support"],[4412,4529,"now more than ever."],[4654,4804,"Yes, dad."],[4825,4975,"I'll give him a call."]],"21":[[41,179,"The Van family has a real pull"],[179,312,"with the Shadow Alliance."],[358,475,"We'll secure their deal"],[475,563,"in three days time"],[563,717,"with the Van family's support"],[729,884,"by our side."],[1117,1205,"Three days from now,"],[1205,1330,"the Shadow Alliance is hosting"],[1330,1447,"the Golden Coast Summit"],[1447,1580,"at the Maple Hotel"],[1601,1676,"to decide on"],[1676,1826,"the next big partnership."],[2047,2122,"That'll put your family"],[2122,2256,"at the top of the list."],[2289,2385,"Smoother it goes for you,"],[2385,2565,"the faster I get my money back, right?"],[2898,2982,"The Vans"],[2982,3182,"have the power to open the door."],[3236,3415,"We just have to follow their lead"],[3428,3607,"and take our cut."],[3649,3774,"Victoria, when everything ends,"],[3774,3953,"I want you to resign!"],[4041,4250,"It's time to rethink"],[4262,4441,"who runs the family business."],[4558,4738,"Dearest cousin."],[4900,5067,"What do we do with this pile of junk"],[5067,5146,"from your rent-a-cop"],[5146,5246,"boyfriend?"],[5305,5426,"Burn it."],[5463,5576,"All of it."],[5689,5818,"The Kingsley house has no"],[5851,6056,"place for a cheap print."],[6510,6652,"No, wait."],[6660,6840,"Just wait! It's not..."],[6861,6973,"Wait!"],[7841,7874,"Miss Kingsley,"],[7874,7957,"- you can't come in. - No!"],[7957,8003,"No, stop!"],[8003,8099,"What are you doing?"],[8116,8295,"It's the real Mona Lisa!"],[8712,8787,"No!"],[8787,8863,"Stop!"],[8954,9088,"No!"]],"22":[[4,95,"Stop!"],[133,204,"They were real!"],[208,354,"Oh, little princess,"],[354,579,"living in your fairytale."],[859,1038,"Let this be a warning to you."],[1051,1180,"You'll regret this!"],[1180,1272,"No,"],[1309,1455,"you will regret this."],[1547,1726,"Once I marry Tristan,"],[1755,1889,"you won't even be able to afford"],[1889,2068,"your rent-a-cop husband."],[3382,3415,"You know,"],[3415,3603,"it takes a lot of guts for you"],[3603,3782,"to show up at my place like this."],[4366,4508,"Could get yourself killed."],[5084,5176,"Still have my cousin"],[5176,5309,"on your mind?"],[5430,5609,"You're miles above her."],[6085,6126,"You know why"],[6126,6352,"the Van family gets an invite?"],[6502,6719,"Because we'll do anything"],[6798,6977,"for the Shadow Alliance."],[7015,7132,"Anything."],[7240,7303,"That's something"],[7303,7482,"you and I have in common."],[7665,7786,"If you can get my family"],[7786,7966,"into the Shadow Alliance."],[8245,8458,"I may be willing to relieve"],[8458,8637,"some of your frustrations."],[9167,9346,"See, you're not"],[9476,9655,"in a position"],[9688,9834,"to negotiate."],[10281,10381,"You're right."],[10518,10623,"There are many positions"],[10623,10802,"we can negotiate in."],[11065,11215,"Which one's your favorite?"],[11498,11678,"The one where you're"],[11682,11824,"on your knees."],[11974,12099,"Now we're talking."]],"23":[[271,371,"Since I realized"],[371,521,"your talents,"],[554,675,"I believe I can get the Kingsleys"],[675,796,"to the summit."],[867,1034,"Oh, Mr. Van!"],[1084,1263,"I knew you'd come to your senses."],[1330,1509,"A man of your talents,"],[1551,1730,"nothing's impossible."],[1747,1926,"You haven't heard the cost yet."],[2097,2310,"You have a lot of work"],[2335,2419,"to do."],[2648,2827,"To earn"],[2919,3069,"the privilege of an invite."],[3123,3274,"That was only a taste"],[3274,3411,"of what I'm capable of."],[3457,3649,"Well, I guess I have to find out that"],[3728,3820,"later."],[3849,4029,"But now"],[4070,4254,"I want something from Kingsley Tech."],[4379,4546,"Victoria's company?"],[4600,4696,"It's been falling apart"],[4696,4875,"ever since her parents died."],[4954,5134,"I'm serious."],[5167,5234,"If it didn't have"],[5234,5376,"the Kingsley name on it"],[5417,5505,"nobody in my family"],[5505,5634,"would even care about it."],[5638,5772,"That's not your problem."],[5855,6106,"Do what I say"],[6193,6352,"or you'll be left with nothing."],[6573,6702,"All right."],[6810,6886,"Good thing we still have"],[6886,7065,"an insider in her company."],[7269,7378,"That's better."]],"24":[[350,542,"Three days until the summit."],[583,821,"I have to lock priority access."],[1142,1322,"Power outage?"],[3336,3516,"Cole?"],[3616,3799,"Mike?"],[3832,4012,"Anybody?"],[5455,5576,"Who's there?"],[5968,6135,"Was I just hearing things?"],[8287,8379,"Interesting."]],"25":[[454,663,"Breaker room should be..."],[759,955,"Tech department, now!"],[1038,1142,"Who are you?"],[1201,1380,"You really can't tell?"],[1455,1634,"It's you?"],[2281,2373,"Emily!"],[2389,2485,"It's you?"],[2494,2665,"Surprise!"],[2669,2815,"Emily, since the day you've joined"],[2815,2902,"this company,"],[2927,3123,"vacations, bonuses, raises,"],[3123,3232,"you've had everything!"],[3307,3428,"Why'd you turn your back on me?"],[3428,3607,"Quit whining!"],[3712,3874,"You've been good to me, Victoria."],[3874,4091,"But the Van family's offering more."],[4266,4429,"Why wouldn't I take it?"]],"26":[[100,266,"I am your employee,"],[266,417,"not your slave."],[462,592,"I've got a better deal now."],[592,775,"And you should be happy for me!"],[809,1038,"Emily, you've let money blind you."],[1076,1217,"- And now... - Shut up!"],[1313,1384,"You're taking me"],[1384,1580,"to the tech department now!"],[2114,2223,"Move it!"],[3315,3436,"Finally,"],[3445,3616,"Tristan gets what he wants!"],[3720,3870,"Not so fast."],[3912,4037,"What is that supposed to mean?"],[4041,4283,"This tech is split into three parts."],[4391,4546,"You've only got one of them."],[4583,4729,"Where's the rest?"],[4800,4896,"Tell me!"],[4913,5092,"You wish."],[5125,5284,"Then die!"]],"27":[[412,525,"It's a cute toy."],[538,675,"Barely even stings,"],[679,859,"but enough to make you feel every volt."],[1509,1647,"You good?"],[3870,3916,"Yeah."],[3916,4095,"I'm fine."],[4170,4287,"Just never thought Emily"],[4287,4441,"would back set me like that."],[4629,4804,"What's Tristan after anyway?"],[4813,4967,"That's worth going this far?"],[5092,5271,"The quantum chip tech."],[5347,5551,"My parents' last research."],[5630,5789,"From the sham engagement"],[5797,5893,"to buying off my uncle,"],[5893,6072,"every move led to this."],[6126,6272,"Just never thought my own assistant"],[6272,6418,"would sell me out."],[6489,6602,"Say the word now"],[6602,6785,"and I'll make them all disappear."],[6877,6977,"No."],[6990,7111,"It's fine."],[7161,7303,"I'll figure something out."],[7303,7382,"How?"],[7403,7582,"As long as we land new deals,"],[7691,7895,"he won't have any hold over us."]],"28":[[45,225,"You motherfucker!"],[542,621,"It's Cole again!"],[621,800,"He's fucked it all up!"],[855,1034,"Little fucking mutt!"],[1167,1347,"Easy, babe."],[1405,1576,"I know how to deal with Cole."],[1576,1718,"I have an idea."],[1760,1872,"Oh, yeah?"],[1906,1997,"What?"],[2198,2252,"No matter"],[2252,2431,"how tough you are,"],[2548,2615,"if a woman's"],[2615,2794,"got your interest,"],[2861,2998,"you're done for her."],[3044,3165,"I like that."],[3190,3370,"I feel like that a lot."],[5125,5234,"Who is this?"],[5280,5401,"Come on, Cole."],[5401,5509,"Don't be so mean."],[5509,5655,"I'm just trying to help."],[5676,5847,"Listen, the van family's"],[5847,6026,"been looking into Victoria."],[6081,6193,"What's your point?"],[6193,6373,"All right, all right."],[6410,6556,"My point is,"],[6556,6777,"they've got a file on Victoria's company,"],[6810,7065,"and if it leaks, she's screwed."],[7178,7282,"Who the hell are you?"],[7282,7353,"What do you want?"],[7361,7486,"Relax."],[7486,7665,"I'm not trying to threaten you."],[7736,7978,"Just meet me at the bar tonight at 8:00."],[8008,8220,"And maybe I'll take care of this for you."]],"29":[[154,333,"Cole, what's going on, man?"],[342,467,"We've got to head out for a bit."],[525,633,"Keep an eye on Victoria."],[633,850,"If anything happens, call me."],[4250,4362,"Hey, handsome."],[4383,4562,"You want to have some fun?"],[4738,4917,"I've been waiting for you."],[5251,5434,"Take it easy, big guy."],[11465,11603,"You're lucky I don't hit women."],[11753,11932,"But if you keep pushing me,"],[12153,12262,"I will."],[12408,12570,"Just join me for a drink"],[12787,12975,"for Victoria and her company."],[13355,13450,"I knew that name would"],[13450,13580,"get you back."],[14255,14393,"Cut the crap."],[14426,14514,"You're not getting anywhere"],[14514,14627,"near Victoria."],[14639,14777,"I'm not going to let that happen."],[14977,15115,"Have your drink,"],[15202,15323,"and then,"],[15482,15673,"I'll tell you all my secrets."]],"30":[[1213,1401,"Cole, you asshole!"],[2494,2640,"Tell me now."],[3319,3461,"You..."],[3549,3649,"You drugged me?"],[3657,3766,"No."],[3862,3970,"Better."],[3970,4149,"It's my own special blend."],[4225,4404,"It's an aphrodisiac."],[4758,4942,"You got two options."],[5005,5130,"One,"],[5130,5380,"you hand me Victoria's research,"],[5380,5559,"and I give you that antidote."],[5634,5776,"Or two."],[5893,6072,"We skip the business."],[6093,6277,"We have a little bit of fun,"],[6327,6493,"and she can find out the messy way."],[6519,6577,"No, no."],[6577,6664,"Don't move."],[6810,6961,"Don't move."]],"31":[[258,304,"Thanks for"],[304,467,"watching over my husband."],[483,613,"He's coming home with me now."],[617,688,"Oh, no."],[688,867,"Sweetheart, I don't think so."],[880,1051,"He's here, and he's mine."],[1163,1292,"Victoria,"],[1368,1459,"nothing happened between us,"],[1459,1547,"I swear."],[1551,1676,"I know."],[1676,1856,"You have better taste than this."],[1897,2010,"Excuse me?"],[2160,2239,"Come on, Cole,"],[2239,2360,"let's go home."],[3265,3378,"It's too hot!"],[3411,3511,"I can't breath."],[4491,4629,"Cole Slade."],[4629,4967,"Serial number 092-414."],[5121,5246,"My brother's number was just"],[5246,5384,"one digit off!"],[5634,5818,"Who are you?"],[6202,6247,"Cole!"]],"32":[[241,367,"Cole!"],[462,583,"Did you just kiss me?"],[2681,2865,"How the hell did I end up here?"],[3240,3340,"Cole!"],[5522,5638,"Morning."],[5955,6047,"Morning."],[6502,6635,"Last night, did we..."],[6635,6698,"Nope!"],[6898,7015,"Nothing happened."],[7645,7916,"You seem almost happy about that."],[8345,8479,"You were in the military?"],[8708,8796,"No."],[8863,8933,"No."]],"33":[[175,262,"What are you looking at?"],[408,538,"Profile on the Shadow Alliance's"],[538,684,"new U.S. director."],[838,946,"What?"],[980,1096,"It's a woman."],[1155,1334,"Yeah, I know Amber's a woman."],[1534,1609,"How did you know"],[1609,1730,"her name is Amber?"],[2118,2227,"Why are you still digging"],[2227,2364,"into the Shadow Alliance?"],[2448,2548,"Well,"],[2556,2802,"Amber is picking a new partner tonight."],[2852,3032,"Odds are, it'll be the Van family."],[3157,3282,"If that happens,"],[3294,3403,"they'll take over my parent's"],[3403,3528,"quantum chip tech."],[3586,3641,"So you want to use"],[3641,3707,"the Shadow Alliance"],[3707,3807,"to protect it?"],[3937,4016,"Problem is,"],[4016,4195,"I can't even get an invite."],[4295,4441,"Doesn't your family already have one?"],[4462,4642,"Yeah, but they're not taking me."],[4738,4771,"Why?"],[4771,4917,"I thought I gave your grandpa"],[4917,5030,"that painting."],[5046,5226,"They burned it."],[5409,5588,"Said it was a knockoff."],[5613,5793,"I'll pay you back."],[6322,6502,"If I get you that invite,"],[7236,7453,"can we forget about that deal we made?"]],"34":[[458,600,"Come again?"],[825,884,"Nothing."],[1514,1680,"If you can really get me"],[1680,1797,"that invite,"],[2056,2235,"I'll do..."],[2444,2623,"anything you want."],[2948,3119,"Just carry that badge with you."],[3182,3370,"I'll take care of the rest."],[4241,4362,"Go on ahead."],[4579,4721,"You're not coming in with me?"],[4758,4859,"I'll catch up."],[5067,5167,"Okay."],[6001,6164,"Give me an invite to the summit."],[6264,6414,"The best one you got."],[6473,6564,"Now."],[7545,7590,"Cole,"],[7607,7678,"they've already kicked out"],[7678,7828,"two execs for not having invites."],[7916,8053,"- If we can't... - Hey."],[8070,8174,"Don't worry."],[8254,8433,"Not only are you getting in,"],[8445,8625,"you're also walking out with the deal."],[8687,8854,"Yeah, right."],[8854,9000,"If I can just get the Shadow Alliance"],[9000,9075,"to protect me"],[9075,9163,"and keep my parent's"],[9163,9359,"research safe, that's all I need."],[9376,9580,"Victoria, you have to trust me."],[9722,9843,"See, I..."],[9872,9959,"Ha!"],[9959,10076,"Got you, Cole!"]],"35":[[70,250,"Oh, come on, Cole."],[258,362,"Don't you miss me?"],[362,571,"I missed you so much."],[600,850,"Okay, you have got to knock it off."],[871,1051,"I'm just friends with your dad."],[1092,1188,"That's it!"],[1188,1372,"Who cares?"],[1426,1605,"I like you, and I'm not letting go."],[1780,1856,"Amber!"],[2002,2097,"Victoria!"],[2644,2777,"Ms. Cross,"],[2873,3111,"my wife does not like that."],[3178,3286,"Now,"],[3390,3495,"the invite."],[3553,3745,"Here, the Shadow Alliance's"],[3745,3941,"most exclusive invite."],[4058,4116,"Thanks."],[4204,4266,"Hold up."],[4295,4366,"You really going"],[4366,4512,"to give out this invite?"],[4525,4704,"This invite is worth a fortune."],[4721,4888,"No one else has ever gotten one."],[4888,5067,"This is the first and the only."],[5280,5459,"I know,"],[5497,5680,"but it's for my wife."],[5939,6022,"Don't say that"],[6022,6143,"in front of my wife again."],[6456,6581,"I got to see what kind of woman"],[6581,6765,"has got Cole all hung up."],[6898,6981,"Victoria!"],[7002,7102,"Wait."],[7140,7290,"Look, she's just a friend."],[7290,7361,"That's all."],[7369,7461,"Don't touch me!"],[7474,7549,"Go away!"],[7653,7703,"Come."]],"36":[[241,429,"Trust me,"],[437,642,"she is just a friend."],[646,896,"She came to drop off the invite."],[900,1042,"That's all."],[1051,1226,"Yeah, right."],[1234,1393,"Mr. Slade's got a girl on the left,"],[1397,1559,"another on the right."],[1564,1643,"Looks like you're having the"],[1647,1789,"time of your life."],[2193,2394,"You feel that?"],[2402,2702,"It only beats for you."],[2802,3103,"Just you."],[3570,3707,"Here."],[3937,4029,"The invite?"],[4033,4124,"Yeah."],[4129,4429,"The summit’s about to begin."],[4433,4629,"Let’s head in."],[4667,4967,"I'll deal with you when we get home."],[6427,6489,"Hello?"]],"37":[[446,658,"Hello!"],[663,855,"Grandpa,"],[859,1088,"Tristan's cousin is the host tonight."],[1092,1280,"Without him, our family wouldn't"],[1284,1488,"have even made it to an event like this."],[1601,1735,"Well, we do owe a lot to Tristan."],[1830,1947,"And to you!"],[1960,2131,"You're the reason he's helping us."],[2135,2423,"Oh, Grandpa. It’s the least I can do."],[2431,2631,"You know, Victoria isn't your"],[2635,2769,"only granddaughter."],[2882,3023,"Well, after the summit,"],[3028,3199,"I'm going to take Victoria's"],[3203,3365,"title and positions away."],[3424,3724,"She is not fit to be the CEO."],[3933,4099,"Victoria."],[4108,4250,"I told you marrying me"],[4254,4396,"is your best option."],[4396,4562,"But you didn't listen."],[4567,4808,"Once Serena takes over as CEO,"],[4813,4917,"your parents’ research will"],[4921,5113,"still end up in my hands."],[5155,5338,"And when that day comes,"],[5342,5451,"you'll be mine."],[5455,5588,"Just something to use"],[5593,5814,"however I want."],[6126,6427,"Isn’t that Victoria and Cole?"],[6702,6823,"What the hell are they doing here?"],[7582,7665,"Mr. Kingsley."]],"38":[[37,137,"Grandpa."],[141,287,"Victoria."],[291,446,"Coming in under Tristan's name"],[450,492,"is one thing."],[496,667,"But to bring this!"],[684,900,"This guy who tried to pass off a fake."],[984,1180,"I didn't think you'd sink this low."],[1184,1355,"Grandpa, I don't understand."],[1359,1609,"I'm still the CEO of our family company,"],[1614,1760,"which means I have every right"],[1764,1914,"to be here."],[1922,2006,"And it's my call"],[2010,2160,"to bring whoever I want."],[2181,2460,"Sure, if you got that invite yourself."],[2469,2548,"But you're only here"],[2552,2752,"because of Serena and Tristan."],[2756,3015,"And showing up with this"],[3019,3190,"security guard husband of yours"],[3194,3319,"is not helping at all."],[3353,3470,"I'm here because I got"],[3474,3653,"the invite myself."],[3670,3753,"Serena and Tristan"],[3757,3908,"had nothing to do with it."],[3912,4116,"Oh, come on, Vicky."],[4133,4371,"This is a business event,"],[4375,4491,"not a beauty pageant."],[4571,4779,"No one's looking for eye candy."],[4783,4938,"If I was you,"],[4942,5138,"I'd walk out of here right now."],[5255,5484,"You come in over here,"],[5488,5622,"trying to steal the spotlight—"],[5626,5789,"it’s embarrassing."],[5885,6185,"Why don't you take a good look?"],[6252,6389,"You really think you got"],[6393,6552,"that on your own?"],[6585,6744,"More like a host handed it off"],[6748,6919,"because you're still riding on"],[6923,7102,"Tristan's coattails."],[7244,7424,"That's weird."],[7432,7674,"I never told the host to let her in."],[7678,7932,"There's only one way that's possible."],[7937,8053,"It's fake!"]],"39":[[8,141,"Can you believe it?"],[145,358,"Someone actually faked"],[362,525,"a Shadow Alliance invite!"],[571,725,"That's insane."],[729,834,"If people were to find out,"],[838,1026,"the entire Kingsley empire’s done."],[1084,1205,"No–"],[1209,1509,"no, you've got it wrong. I–"],[1568,1639,"It doesn't matter if"],[1643,1751,"this invite is real or not."],[1935,2093,"That's not your call to make."],[2097,2227,"Shut up!"],[2260,2344,"Are you trying to drag"],[2348,2540,"this family down?"],[2544,2706,"Victoria, you need to get this"],[2711,2957,"useless man out of here now!"],[3161,3244,"Vicky!"],[3253,3378,"Look what you've done to Grandpa."],[3382,3516,"Apologize now!"],[3528,3741,"Could this invite actually be fake?"],[3807,4066,"Cole, let's go."],[4087,4208,"Wait."],[4216,4466,"Why are you guys running?"],[4483,4592,"You were so confident"],[4596,4779,"that invite was real."],[4934,5234,"Well, if my invite is fake,"],[5347,5526,"well then, this entire event is a sham,"],[5530,5780,"and we can go home."],[5855,6056,"Prove it."],[6072,6360,"Open it up and show us."],[6489,6552,"Yeah, yeah."],[6556,6639,"Let us see it."],[6644,6765,"Open it up. Open it up!"],[6769,7077,"Open it! Open it!"],[7111,7394,"Open it! Open it!"],[7399,7507,"Open it!"]],"40":[[187,321,"Come on, bud."],[325,625,"Stop wasting everybody's time."],[842,1222,"Now you are absolutely sure"],[1226,1380,"this invite is fake?"],[1393,1593,"Damn right."],[1626,1659,"You know what?"],[1664,1839,"Let's make it interesting."],[1843,2081,"If that invite is forged,"],[2093,2318,"I'll break your leg."],[2323,2623,"And she hands over the quantum chip."],[2698,2911,"And if it's real?"],[2915,3073,"Then I'll kneel down and"],[3078,3211,"kiss your shoes."],[3324,3624,"And I'll get the hell out of here."],[3628,3666,"Deal."]],"41":[[321,621,"You call that an invitation?"],[642,867,"Oh, you have got to be kidding me."],[1359,1455,"You seeing this?"],[1463,1872,"This is the sloppiest fake I've ever seen."],[1910,2122,"Listen up, genius."],[2127,2285,"Shadow Alliance invites come in"],[2289,2444,"black, for standard,"],[2498,2781,"and blue, for VIPs."],[2790,3069,"Vicky, if you're going to fake one,"],[3069,3370,"at least do your research first."],[3432,3607,"Grandpa was right."],[3611,3741,"You don't deserve"],[3745,3912,"to lead the Kingsley family."],[4129,4270,"Victoria, you have brought this"],[4275,4337,"on yourself."],[4341,4450,"You're turning this family"],[4454,4637,"into a complete joke!"],[4779,4975,"Who said it's fake?"],[4975,5163,"Cut the crap."],[5163,5317,"Like I said,"],[5321,5434,"this is the Shadow Alliance's"],[5438,5597,"most exclusive invite."],[5668,5797,"Only one's ever been sent out"],[5801,5968,"since it’s been founded."],[6006,6056,"Makes sense"],[6060,6310,"they've never seen it before,"],[6318,6456,"but that doesn't mean it's fake."],[6560,6756,"Enough, Cole."],[6760,6848,"Everyone here doesn’t"],[6852,7107,"believe a word you say."],[7111,7269,"And I'm about to make you regret"],[7273,7374,"running your mouth."],[7382,7590,"Grab him."],[7686,7811,"I'll break his leg myself."]],"42":[[58,421,"That is the Lester Duvall."],[471,771,"He is from the– the Shadow Alliance."],[784,980,"I heard he handles everything."],[984,1101,"All the Shadow Alliance’s"],[1105,1238,"outside business."],[1242,1368,"I can't believe we're actually getting"],[1368,1472,"to see him in person."],[1476,1630,"If I could work with him,"],[1634,1839,"I'd be on Wall Street in no time."],[1851,1951,"You wish."],[1960,2097,"The Shadow Alliance is definitely"],[2102,2181,"going to pick Tristan"],[2185,2331,"as their new partner, for sure."],[2360,2473,"The Kingsley family's already"],[2477,2660,"hanging on them."],[2677,2769,"Tristan,"],[2773,2894,"sounds like you're going to be the"],[2898,3073,"star tonight."],[3115,3244,"Lucky you, Vicky."],[3249,3365,"Even with a fake invite,"],[3370,3528,"you still get to meet Mr. Duvall."],[3728,3820,"Once you become the"],[3820,3908,"Shadow Alliance's new leader,"],[3912,4095,"you'll introduce me to Mr. Duvall, right?"],[4099,4233,"Of course."],[4291,4592,"My family is counting on you."],[4683,4896,"Don’t worry. I got it."],[4988,5171,"But from now on,"],[5188,5305,"Serena Kingsley"],[5313,5484,"runs the family company."],[5568,5651,"Yes. Of course."],[5655,5801,"Of course."],[5834,5955,"Don't worry."],[5964,6006,"You're going to be the"],[6010,6264,"Shadow Alliance’s new partner."],[6410,6531,"Nobody’s changing that."],[6552,6765,"Yeah. We'll see how long that lasts."]],"43":[[158,275,"Mr. Duvall."],[279,533,"This is Tristan Van, heir to the Vans,"],[538,671,"richest family in the state."],[796,917,"And he's my cousin."],[930,1001,"It's an honor to meet you,"],[1005,1109,"Mr. Duvall."],[1463,1714,"Oh, this is Serena Kingsley,"],[1714,1897,"the new appointed CEO"],[1901,2014,"of the Kingsley company."],[2064,2364,"Mr. Duvall, it's a pleasure."],[2456,2581,"Tristan,"],[2585,2702,"Mr. Duvall is picking the"],[2706,2890,"Shadow Alliance's new partner tonight."],[2982,3086,"Don't mess it up."],[3128,3207,"Got it."],[3228,3340,"Mr. Duvall."],[3349,3465,"If you pick me,"],[3470,3553,"I will not"],[3557,3770,"let the Shadow Alliance down."],[3828,4029,"Which one of them did Ms. Cross"],[4033,4300,"tell me to look after?"],[4320,4446,"Didn't you say Victoria"],[4450,4533,"would be the new partner"],[4537,4621,"for the Shadow Alliance?"],[4679,4796,"Looks like she couldn’t even get a"],[4800,4934,"nod from Mr. Duvall."],[4963,5167,"He's probably just scared Mr. Duvall’s"],[5171,5292,"going to find out the invite’s fake."],[5530,5659,"That's why he's keeping his mouth"],[5663,5776,"shut."],[5951,6197,"The event’s just started."],[6210,6281,"Nobody knows yet."],[6285,6377,"who the Shadow Alliance"],[6381,6443,"is going to pick."]],"44":[[4,150,"Ladies and gentlemen,"],[154,208,"welcome to the"],[212,342,"Shadow Alliance summit."],[358,475,"And please welcome"],[479,621,"Mr. Lester Duvall"],[625,796,"from the Shadow Alliance."],[1317,1501,"Tonight's agenda is simple."],[1509,1672,"Mr. Duvall will be selecting the"],[1676,1835,"Shadow Alliance's new partner."],[1872,2185,"And donating $50 billion"],[2218,2410,"to the quantum chip research."],[2635,2819,"This is our shot!"],[2840,3032,"If you would like to be considered,"],[3036,3236,"step forward now."],[3328,3511,"Get back there."],[3607,3841,"The Van family is ready to partner"],[3845,3903,"with the Shadow Alliance."],[3983,4262,"Mr. Duvall, the Vans are, frankly,"],[4266,4391,"the strongest candidate"],[4396,4567,"in the room."],[4629,4800,"Nice job, Tristan!"],[4884,4996,"Congrats!"],[5025,5209,"If there are no other candidates,"],[5213,5359,"I'll now announce the Shadow"],[5363,5488,"Alliance's new partner–"],[5492,5676,"I'm in."],[5830,6006,"I want that partnership too."]],"45":[[0,150,"Victoria, stop it!"],[154,342,"Tristan is the Shadow Alliance’s"],[346,496,"new partner. Quit embarrassing us!"],[575,875,"Vicky, I know you want the spotlight,"],[892,1021,"but don't embarrass"],[1026,1192,"our family for your ego."],[1363,1564,"Aren't you a Kingsley too?"],[1626,1718,"Mr. Duvall,"],[1722,1860,"you can forget about her."],[1864,2022,"Serena is our new CEO."],[2022,2206,"That is all you need to know."],[2248,2369,"Victoria never said she wanted to"],[2373,2494,"become the Shadow Alliance’s"],[2498,2677,"partner as part of the Kingsley family."],[2756,2898,"And what does that mean?"],[2902,3119,"She's starting her own company."],[3153,3294,"Under her name."],[3461,3620,"Are you serious?"],[3624,3732,"A shell company?"],[3737,3912,"Partnering with the Shadow Alliance?"],[3924,4033,"Do you think everyone's"],[4037,4183,"dumb enough to believe that?"],[4187,4404,"You got in here on a fake invite."],[4408,4537,"Don't push your luck."],[4542,4717,"Someone forged"],[4721,4900,"a Shadow Alliance invite?"]],"46":[[33,187,"You know,"],[187,412,"since the Shadow Alliance started,"],[421,592,"there were two people"],[596,767,"that forged an invite."],[809,1071,"And they paid the price."],[1209,1509,"Didn't think I'll see such a fool today."],[1547,1668,"What's the matter?"],[1672,1780,"Didn't think Mr. Duvall"],[1785,1956,"would show up in person?"],[2002,2243,"When I show him this fake invite,"],[2540,2840,"your cover’s blown, and you're done."],[2877,3007,"Cool."],[3165,3374,"I’ll wait."],[3440,3536,"Mr. Duvall!"],[3541,3666,"Here it is."],[3866,3945,"That's..."],[3949,4237,"the most exclusive invite to the summit!"],[4250,4500,"This is the cheapest fake I've ever seen,"],[4508,4808,"and an outright insult to you."],[4846,5142,"Let me take this garbage out for you!"],[5155,5309,"Stop!"]],"47":[[0,241,"Mr. Duvall, why are you..."],[250,325,"That's right."],[333,542,"This really is the Shadow Alliance's"],[546,742,"most exclusive invite."],[775,905,"Mr. Duvall, it’s just a fake—"],[909,996,"Shut up!"],[1001,1101,"Oh my god!"],[1438,1634,"Mr. Slade,"],[1639,1760,"this is a Shadow Alliance"],[1764,1935,"exclusive invitation."],[1943,2043,"You’ll have access to all of our"],[2052,2289,"properties–no interference."],[2339,2435,"What?"],[2439,2540,"He doesn't have the authority to get"],[2544,2631,"something like this."],[2635,2781,"Are you going to question"],[2786,2932,"my judgment?"],[2982,3178,"Not now."],[3211,3470,"Focus on securing the partnership first."],[3482,3582,"We'll deal with the rest"],[3586,3782,"once this is over."],[3895,4020,"Vicky,"],[4029,4346,"partnerships run on resources."],[4354,4487,"Without the Kingsleys,"],[4487,4788,"what can you even do?"],[4817,5000,"Victoria, if you are"],[5005,5096,"bound and determined to"],[5100,5267,"start your own company,"],[5309,5447,"the Kingsley family will"],[5451,5609,"give you nothing."],[5759,5847,"Well, sure,"],[5851,6068,"Victoria's company is new."],[6072,6218,"It doesn't have all the resources"],[6222,6352,"it needs yet."],[6356,6460,"But we have something you"],[6464,6589,"can't say no to."]],"48":[[4,196,"If you make Victoria your new partner,"],[204,283,"you're going to make someone"],[287,354,"really happy."],[392,550,"Are you nuts?"],[563,863,"$50 billion to make one person happy?"],[880,1038,"You think the Shadow Alliance"],[1042,1217,"is that stupid to believe that?"],[1288,1430,"Victoria, shut him up"],[1434,1589,"before he drags us all down."],[1643,1697,"Victoria,"],[1701,1914,"get him out of here now!"],[1918,2235,"Exactly who is going to be happy?"],[2306,2464,"Well, you're not here to"],[2469,2606,"make money or do business."],[2731,2944,"You're just here to please someone."],[2957,3086,"Enough!"],[3090,3315,"Know what? Save this for your funeral."],[3319,3432,"Get him out of here!"],[3436,3720,"All you have to do is pick Victoria,"],[3728,3895,"and you will get exactly"],[3899,4029,"what you want."],[4149,4333,"Trust me."],[4437,4646,"The badge I gave you–"],[4654,4696,"where is it?"],[5434,5522,"Hold it!"]],"49":[[41,129,"Victoria,"],[133,304,"if this family takes a hit,"],[308,454,"we're going to sever ties with you"],[454,517,"for good."],[579,633,"Oh,"],[638,871,"Mr. Duvall's coming right for you!"],[875,1155,"Looks pretty pissed too."],[1163,1372,"Ms. Kingsley,"],[1393,1693,"may I have that badge, please?"],[2318,2381,"That..."],[2394,2656,"that's it. It's the real thing!"],[2665,2781,"Ms. Kingsley,"],[2786,2894,"do you intend to start a new"],[2898,3086,"company and form a partnership"],[3090,3303,"with the Shadow Alliance?"],[3311,3482,"Mr. Duvall, no reason to get upset."],[3486,3641,"I'll get these two out of here."],[3645,3912,"What's the holdup? Move it!"],[4179,4350,"You think you can just interrupt me?"],[4496,4600,"You see this?"],[4608,4692,"I'm in hot water because"],[4696,4838,"you two pissed him off!"],[4913,5038,"When this summit is over,"],[5042,5125,"you two are getting what's"],[5125,5209,"coming to you!"],[5213,5342,"Don't worry, Tristan."],[5347,5472,"The moment we step out of this"],[5476,5647,"room, Victoria is no longer a member"],[5651,5722,"of this family."],[5860,6031,"Ladies and gentlemen,"],[6035,6197,"the Shadow Alliance"],[6202,6297,"has made a decision."],[6448,6702,"Our new partner is..."]],"50":[[133,316,"Once you land Shadow Alliance,"],[321,487,"taking down Victoria and Cole is going to"],[492,679,"be child's play."],[838,950,"The new partner"],[955,1126,"of the Shadow Alliance is..."],[1443,1743,"Ms. Victoria Kingsley!"],[2081,2214,"Ms. Kingsley,"],[2218,2323,"please have your paperwork"],[2327,2469,"ready by tomorrow."],[2469,2719,"I'll come by and sign it myself."],[2727,2911,"No way!"],[2919,3107,"How is it her?"],[3228,3449,"This has to all be a bad dream."],[3465,3661,"The $50 billion is yours."],[3670,3920,"You can use it as you see fit."],[3928,4054,"If you need any resources"],[4058,4200,"from then on,"],[4208,4466,"give the word and I'll make it happen."],[4471,4725,"What is the deal with Victoria?"],[4729,4913,"I mean, who is she?"],[4917,5030,"The Shadow Alliance doesn’t"],[5034,5292,"just partner with random people."],[5301,5422,"That deal is basically"],[5426,5568,"free money!"],[5597,5776,"Cole said that Lester"],[5780,5989,"was just trying to make people happy,"],[5993,6106,"right?"],[6181,6239,"Who do we think the"],[6243,6377,"elephant in the room is?"],[6381,6506,"He flipped like a switch the second"],[6510,6656,"he saw that badge in her hand."],[6744,6877,"He was going to give the partnership"],[6881,6965,"to Tristan!"]],"51":[[0,162,"No!"],[171,417,"This is impossible!"],[437,604,"I never lose!"],[613,738,"Cole,"],[742,925,"am I dreaming?"],[984,1159,"What’d I tell you?"],[1172,1463,"Carry that badge and they’ll pick you."],[1480,1580,"Period."],[1584,1881,"But $50 billion?"],[1968,2177,"All off one tiny badge?"],[2181,2335,"Ms. Kingsley,"],[2339,2481,"I look forward to working with you."],[2548,2781,"Have the paperwork ready by tomorrow,"],[2781,2932,"I'll come by to sign it,"],[2936,3011,"and if you need anything"],[3011,3073,"in the meantime,"],[3078,3128,"you say the word"],[3128,3232,"and I'll make it happen."],[3253,3407,"You're serious?"],[3428,3582,"All of this is real?"],[3586,3878,"Of course it's not real. Wake up!"],[3883,3970,"He only picked you because"],[3970,4124,"he assumed you were"],[4129,4245,"running the Kingsley family."],[4341,4500,"Mr. Duvall, she–"],[4512,4671,"she's just a pretty face."],[4683,4917,"She is unfit to partner with"],[4921,5046,"the Shadow Alliance, okay?"],[5050,5196,"She has no resources!"],[5234,5380,"Mr. Duvall."],[5455,5659,"If we're talking about"],[5663,5855,"power and influence,"],[5897,6177,"Tristan is the only logical choice."],[6339,6460,"That's right, Victoria."],[6464,6585,"As of today,"],[6589,6710,"you are no longer a member"],[6715,6777,"of this family."],[6827,6986,"And without the Kingsley name,"],[6990,7286,"you have absolutely nothing to offer"],[7290,7461,"the Shadow Alliance!"],[7978,8137,"You Kingsleys sure you want to cut"],[8141,8229,"Victoria loose?"]],"52":[[45,291,"That's that friend of yours."],[304,450,"What's she doing here?"],[454,596,"I almost thought she was someone"],[600,692,"important."],[721,867,"But if she's Cole's friend,"],[871,1005,"she's probably just a gutter rat."],[1009,1142,"Keep talking like that,"],[1146,1251,"and the Van family is going to be"],[1255,1430,"six feet under by midnight."],[1768,2035,"Go on, Lester, tell the distinguished"],[2039,2248,"Mr. Van who I am."],[2335,2419,"Tristan!"],[2452,2569,"Oh god."],[2677,2882,"This is Ms. Amber Cross,"],[2886,3011,"the U.S. Director"],[3015,3182,"of the Shadow Alliance."],[3190,3370,"And if I remember,"],[3374,3666,"you just referred to Ms. Cross"],[3670,3749,"as a gutter rat."],[3753,3945,"I didn’t know who she was!"],[3949,4083,"Mr. Duvall, please!"],[4087,4325,"Tristan's just young and ignorant."],[4396,4546,"Give him another chance to"],[4554,4696,"prove himself!"],[4796,4917,"What the fuck, man?"],[4921,5150,"This is– this is my turf!"],[5171,5417,"I'm the one who owns this! No one"],[5426,5576,"comes in here and pushes me around,"],[5797,5951,"not even the Shadow Alliance!"],[5955,6026,"You hear me?"]],"53":[[16,137,"If all you had done was"],[141,291,"cross the Shadow Alliance,"],[296,496,"I may have given you a free pass."],[525,709,"But what's really unforgivable"],[713,859,"is that you disrespected"],[863,984,"Ms. Victoria Kingsley,"],[1009,1234,"the woman with the badge."],[1326,1543,"Cole, what is this thing?"],[1559,1689,"Even Amber’s acting like it's"],[1693,1876,"the most valuable thing in the world."],[1947,2139,"Dad, isn't that the same badge Cole"],[2143,2281,"tried to give you at the family dinner?"],[2427,2560,"No way that thing"],[2565,2715,"actually has any real pull."],[2727,2936,"Well, I tried to tell you."],[2940,3115,"This badge could single-handedly"],[3119,3415,"make your family crisis disappear"],[3420,3628,"and turn you into financial giants."],[3670,3933,"You Kingsleys lit"],[3937,4200,"the golden ticket on fire."],[4329,4692,"Seeing this badge is seeing the owner."],[4713,4950,"No one disrespects it."],[4959,5071,"No one."],[5080,5230,"Forget 50 billion."],[5238,5438,"Make it 100. 200. Hell,"],[5442,5609,"make it the entire Shadow Alliance."],[5613,5855,"If it was the badge owner's orders,"],[5860,5985,"we'd have to give it over."],[5989,6097,"No questions asked."],[6106,6272,"Then Cole wasn't bluffing!"],[6277,6398,"That means that was the"],[6402,6598,"actual Mona Lisa."],[6673,6785,"Oh my God!"],[6794,6940,"I’ve crushed our entire family’s"],[6944,7094,"fortune with my own hands!"],[7165,7536,"You! You said that ID was yours."],[7716,7874,"Who the hell are you, Mr. Slade?"]],"54":[[0,196,"I'm sorry,"],[204,371,"what?"],[500,734,"This badge is your ID?"],[742,955,"You've all heard the legend, right?"],[988,1226,"How there's a phantom tycoon"],[1234,1434,"lurking in the shadows?"],[1438,1697,"A mystery billionaire who holds the entire"],[1697,1997,"economy in the palm of his hand."],[2043,2252,"One word from him,"],[2260,2510,"and blue chip stocks cater."],[2515,2748,"One word, and he turns a deadbeat"],[2752,2957,"into a star of high society."],[3048,3244,"And the only way to identify"],[3249,3365,"this mystery man,"],[3411,3632,"the man who has the power to"],[3636,3807,"tilt the world on its axis,"],[3899,4145,"is that badge right there."],[4149,4396,"And he is the owner."],[4400,4508,"Cole Slade,"],[4542,4671,"the man behind the mask,"],[4675,4971,"the real mystery billionaire!"],[5009,5284,"Mr. Slade, I am sorry"],[5288,5417,"for speaking out of turn."],[5668,5918,"Please accept my apologies."],[5922,6047,"Lester, really."],[6051,6327,"Please. Let's cut the formalities."],[6360,6443,"It's a fake!"],[6448,6614,"Okay? It has to be a fake!"],[6619,6664,"Lester,"],[6802,6998,"I want you to bankrupt"],[7002,7152,"the Van family"],[7157,7298,"in three minutes or less."],[7323,7578,"Yes, sir."],[7699,7862,"I'm sorry, Mr. Slade!"],[7916,8187,"Please, please."],[8212,8416,"Mr. Slade."],[8425,8600,"The Van group stock has just"],[8608,8725,"tanked."],[8829,8992,"They are now bankrupt."],[9150,9325,"No!"],[10039,10226,"Get off of me!"],[10785,11081,"Well, since you love him so much,"],[11086,11261,"you can go keep him company."],[11265,11444,"Let's go!"],[11448,11649,"Vicky!"],[11653,11790,"We're family!"],[11795,11945,"I'm your cousin!"],[11949,12078,"Please don't do this."],[12082,12224,"Family?"],[12228,12529,"My days as a Kingsley are over."],[12658,12837,"I can walk myself!"]],"55":[[25,196,"Well, now that you Kingsleys are"],[200,329,"nothing to Victoria,"],[442,583,"why don't you do yourselves a favor"],[588,813,"and get out of our sight?"],[838,988,"If I were to so much as"],[988,1138,"see your faces again,"],[1192,1368,"it'll be as if the Kingsley name"],[1372,1493,"never existed."],[1826,1897,"So,"],[1901,1989,"Victoria has the"],[1989,2110,"Shadow Alliance deal,"],[2114,2327,"and her parents’ research is safe."],[2410,2498,"You've accomplished your"],[2498,2644,"mission, right?"],[2648,2831,"All there's left for you to do"],[2836,2936,"is leave her,"],[2940,3078,"and marry me."],[3678,3791,"Victoria– don’t–"],[3895,3974,"Cole."],[3978,4279,"I know you knew my brother."],[4291,4421,"I'm safe now, okay?"],[4546,4654,"You should go."],[4954,5255,"Thank you for everything."],[5634,5747,"Victoria."],[5751,5914,"Cole, stop!"],[6026,6106,"You've already done"],[6106,6235,"so much for me."],[6343,6635,"I can't keep weighing you down."],[6923,7052,"Remember when you asked if"],[7052,7219,"I ever served in the military?"],[7265,7565,"So, you're finally ready to tell me?"],[7603,7749,"I served with your brother, Alex."],[7757,7878,"You knew my brother?"],[7899,8020,"We were brothers in arms."],[8179,8366,"His last words were to keep you safe."],[8370,8671,"He's dead?"],[8683,8896,"The mission failed."],[8900,9192,"He didn't make it back."],[9200,9309,"He didn't want you to know because"],[9313,9501,"he was afraid it was going to break you."],[9534,9834,"Why didn't you tell me?"],[9855,9980,"Why didn't you let me see him"],[9984,10064,"one last time?"],[10264,10535,"Come. I’ll take you to him."]],"56":[[4,137,"Alex."],[141,421,"You're such a jerk."],[425,583,"Do you know how hard it's been"],[592,738,"all on my own?"],[900,1109,"Everyone tried to tear me apart."],[1113,1413,"But now I have Cole."],[1488,1676,"I think..."],[1680,1981,"I think I'm in love with him."],[1997,2093,"But..."],[2139,2273,"he’s the most powerful man"],[2277,2439,"in the Federation."],[2481,2698,"I'm not good enough, am I?"],[2702,3003,"I'm sure you'd call me stupid again."],[3787,4087,"What the hell?"],[4262,4508,"Alex."],[4512,4813,"Hey, man."],[5134,5401,"I know you remember our pact."],[5405,5547,"Whoever dies first, the other has to"],[5551,5705,"wear a wedding dress."],[5801,6101,"And as for the bride."],[6427,6669,"Well, that's your sister."],[6673,6994,"What? Have you lost your mind?"],[7032,7319,"Victoria Kingsley."],[7323,7478,"Your brother asked me to guard you for"],[7482,7795,"life if he didn't make it back."],[7803,7891,"But I don't want to just be a"],[7895,8103,"guard to you."],[8170,8262,"Is this your idea"],[8266,8566,"of a proposal? In a wedding dress?"],[8662,8762,"Just keeping my promise,"],[8863,9104,"and marrying you."],[9109,9401,"Unless you have a problem with that."],[9409,9542,"Idiot."],[10744,10910,"Rest easy, my brother."],[10915,11015,"I'll protect Victoria"],[11019,11119,"for the rest of my life."]]}