{"1":[[1772,1843,"Hey hey, Mia Mia."],[2439,2585,"Hey, hey, hey, hey."],[2923,3028,"Hang in there, little sis, OK?"],[3028,3178,"Just, just 10% more."],[4959,5017,"Jen,"],[5230,5392,"if I die, it's OK."],[5534,5638,"You've done everything."],[5755,6010,"Mia, you're not going to die."],[6231,6377,"The treatment's going to work."],[6731,6877,"I don't want you to be alone if I go,"],[6994,7140,"especially with mom and dad gone."],[7478,7570,"You and Roman deserve"],[7570,7645,"to be together."],[7795,7882,"Mia, he's..."],[7937,8058,"he's just a friend."],[8133,8229,"Just friends, huh?"],[8308,8375,"What about that night"],[8375,8470,"you two spent together?"]],"2":[[342,421,"You did it."],[487,688,"You finally found the cure."],[725,892,"You are incredible."],[3958,4133,"It was just one night."],[4225,4379,"Okay, I haven't even"],[4379,4504,"thought about it since."],[4800,4900,"Pack it up, nerd."],[4959,5050,"Playtime's over."],[5434,5605,"This is a restricted area."],[5626,5714,"You need to leave."],[5780,5935,"It's not restricted for me."],[6339,6556,"Roman, the man who pays for your lab"],[6556,6648,"and I are getting married,"],[6648,6748,"which means all of this is going away."],[6748,6894,"which means all of this is going away."],[6956,7119,"Jen, what's she talking about?"],[7319,7515,"I am sick of hearing"],[7515,7640,"your irritating name."],[7691,7970,"Jen's so smart and Jen's saving lives"],[7970,8078,"and being more like Jen."],[8112,8270,"By the time I'm done with you,"],[8270,8437,"Roman won't even remember you exist."],[8587,8692,"Kiss your lab goodbye,"],[8692,8821,"you manipulating leech!"],[9505,9617,"No, stop."],[9617,9734,"Stop, you're going to kill her."],[9784,9880,"No one wants you or"],[9880,10001,"your pathetic charity case"],[10001,10064,"sister around."],[10848,10944,"Roman, stop her."],[10969,11044,"Shut up."],[11052,11236,"He's not gonna save you over me."],[11236,11319,"I'm his fiancée."],[11569,11695,"And you smell like"],[11695,11832,"disgusting sick people."],[12575,12691,"Is that true?"],[12837,12958,"Are you engaged?"]],"3":[[108,246,"Jen, I..."],[321,387,"Oh my god."],[500,571,"It's true."],[642,796,"I'm supposed to be your best friend"],[796,913,"and you didn't tell me?"],[971,1046,"No."],[2064,2202,"We are not getting married."],[2289,2423,"Alright, this was all my new"],[2423,2602,"stepmother's insane idea."],[2602,2765,"I marry her daughter and we all become"],[2765,2902,"some happy little family"],[2902,3023,"or something like that."],[3053,3174,"But I refused."],[3403,3549,"Then why is she wearing your"],[3549,3649,"grandmother's ring?"],[3795,3837,"What?"],[4387,4441,"Give me that."],[4738,4871,"You have no right to this."],[5380,5463,"It's time for you to leave."],[5709,5960,"You’ll regret this. Both of you."],[6881,7107,"So, how is she?"],[7607,7703,"Um..."],[7870,7941,"She's okay."],[8379,8504,"I gave her something to help her rest"],[8504,8641,"and restarted the procedure."],[9134,9196,"Roman..."],[9421,9563,"Roman, what is going on with you?"],[9676,9780,"I've been your best friend"],[9780,9864,"since college, okay?"],[9864,10022,"You can tell me anything."]],"4":[[37,191,"Look, my father's lost it."],[225,321,"Okay? He,"],[354,504,"he's decided that if I don't marry Kim"],[504,713,"or some other socialite,"],[792,967,"he's gonna sell the lab to some"],[967,1146,"slumlord condo developer."],[1480,1659,"Look I care about what you're doing here,"],[1659,1822,"and the lives we could save."],[2464,2556,"That's it."],[2781,2886,"I'll do it about that."],[2944,3061,"What? No."],[3061,3123,"Roman you,"],[3199,3328,"you can't do that."],[3349,3536,"She tried to kill my little sister."],[3682,3866,"If you hadn't shown up, I don't know what..."],[3916,4237,"Look, I care about this lab and"],[4237,4396,"finding the cure more than I"],[4396,4537,"care about my own businesses."],[4671,4750,"And..."],[4838,4921,"Getting married is"],[4921,5042,"the only way to save it."],[5613,5693,"Well"],[5768,5847,"Uh..."],[5914,6014,"What if,"],[6101,6268,"what if I marry you instead?"],[6485,6535,"What?"]],"5":[[125,250,"Wait, you're..."],[316,458,"you're serious, aren't you?"],[546,759,"I mean, you're about to"],[759,988,"agree to marry that monster, Kim,"],[1021,1267,"to save my lab and my little sister."],[1363,1539,"If we get married, then"],[1622,1797,"all of our troubles go away."],[1797,2022,"So, yeah."],[2102,2344,"Yeah, I'm serious."],[4517,4617,"Jennifer Connor."],[4817,4971,"Will you be my fake wife?"],[5321,5359,"Yes."],[6798,6865,"I,"],[6969,7052,"I'll be right back."],[8133,8174,"You're going to get"],[8174,8299,"your wish, little sis."],[8400,8571,"Roman and I are going to get married."],[8650,8783,"Even if it's not real,"],[8875,9038,"everything's going to be okay."],[9638,9772,"Destroy the lab and"],[9772,9893,"get rid of Jen Connor."],[9918,9997,"She's interfered in"],[9997,10114,"my life for too long."],[10602,10819,"With Jen gone, Roman"],[10819,10960,"and his inheritance"],[10960,11219,"and his businesses will be mine."]],"6":[[1042,1138,"Stay away from her."],[1705,1830,"Whoa, whoa, whoa,"],[1968,2022,"Fiesty."],[2077,2152,"I like it."],[2198,2402,"I said stay away from her."],[2423,2590,"Oh, baby, we're just getting started."],[3332,3482,"You'll pay for this bitch."],[3553,3611,"No."],[4170,4279,"Mia Mia."],[4279,4333,"No."],[4475,4512,"No."],[4671,4788,"Get your hands off her."],[4813,4888,"Back away."],[4917,5004,"Or you are next."],[5050,5134,"You heard me."],[5155,5238,"Let her go."],[5276,5359,"I warned you."],[7791,7870,"Jen."],[7937,8024,"Roman."]],"7":[[20,95,"Roman!"],[2068,2135,"Mia."],[2193,2335,"Mia Mia."],[2385,2473,"Take Mia to the private"],[2473,2594,"clinic on my family's estate."],[2627,2727,"Make sure she lives."],[2761,2819,"Yes, sir."],[2877,3002,"Mia Mia."],[3207,3265,"Oh, my God."],[3265,3378,"It's Roman Johnson."],[3486,3549,"Damn."],[3549,3678,"He could carry me any time."],[3928,3991,"My research."],[4012,4104,"I need to go back."],[4104,4175,"I need to go back."],[4191,4220,"No."],[4333,4358,"No."],[4387,4454,"It's too dangerous."],[4471,4617,"It's everything I've ever worked for."],[4617,4700,"I need to go back."],[4817,4859,"No."],[4904,4938,"No."],[4971,5059,"No, my research."],[5059,5142,"I need to go back."],[5171,5251,"No!"],[5422,5476,"It's too late."],[5509,5563,"No!"],[5638,5701,"No!"],[5726,5805,"No!"]],"8":[[529,633,"No, no, no!"],[684,767,"I can still go get"],[767,896,"my notes, please, no!"],[921,1038,"No, no, I won't have my"],[1038,1138,"new fiancée dying on me"],[1138,1242,"before I get a chance to"],[1242,1326,"announce an engagement."],[1326,1447,"I'm getting you to safety."],[1584,1639,"Oh, my God."],[1639,1743,"Did Roman Johnson just"],[1743,1885,"say that he has a fiancée?"],[1885,2043,"Do you have any idea how rich he is?"],[2106,2268,"Some girls have all the luck."],[2277,2448,"No, no, no!"],[2786,2852,"Oh no!"],[5305,5513,"I wonder if she'll ever forgive me."]],"9":[[208,375,"Okay great, I'll let the doctor know."],[963,1263,"All my research, it's all gone."],[1739,1801,"Hey,"],[1935,2135,"look, I know you're upset."],[2210,2323,"Okay, but,"],[2377,2498,"you've got this."],[2565,2723,"You're smart and you've"],[2723,2873,"got everything you need"],[2936,3065,"to recreate that cure tucked away"],[3065,3236,"in that beautiful brain of yours."],[3486,3636,"Well, then I guess"],[3636,3762,"the real question is,"],[3828,3949,"how I'm going to convince your father"],[3949,4166,"that I'm the perfect socialite wife"],[4166,4295,"that he wants for you."],[4508,4533,"Huh."],[4662,4800,"God, your stepmother"],[4800,4975,"is going to tear me apart."],[6147,6256,"Yes, okay, great."],[6314,6435,"Perfect, I can see here you're"],[6435,6560,"scheduled in for next week."],[6785,6906,"Yes, that sounds perfect."],[7244,7349,"You think what I'm thinking?"],[7436,7561,"100%."],[7941,8108,"Okay, thank you, bye-bye."],[8562,8650,"What are you doing?"],[8687,8796,"Stealing your life."]],"10":[[45,175,"My God."],[442,642,"Jen, you look..."],[779,1213,"Wow, I hardly recognize you."],[4721,4967,"We're just friends. That night wasn't"],[4967,5046,"supposed to happen."],[5113,5242,"You think a pair of heels and some"],[5242,5409,"bleach makes you high society?"],[5463,5584,"They'll eat you alive."],[5705,5893,"That is my fiancée you're talking to."],[5947,6110,"Watch your tone."],[6110,6260,"Unless you'd like to find a new job."],[6698,6873,"She actually looks incredible."],[7799,7916,"Honestly,"],[8058,8212,"I think this might just work."],[8400,8604,"Well, it better."],[9117,9492,"Oh, no. They're here. I'm not ready."],[9551,9693,"You've got one last chance to smooth"],[9693,9780,"things over with Roman."],[9780,9889,"Make it happen."]],"11":[[16,300,"Son, why are you using my facilities"],[300,487,"for your ridiculous charity work?"],[513,688,"This is exactly why you"],[688,846,"need a good, proper wife,"],[905,1063,"who comes from a proper family."],[1146,1322,"Someone that will stop"],[1322,1572,"you from being so reckless."],[1676,1760,"Finding the cure is"],[1760,1893,"not reckless, Father."],[1947,2010,"It is."],[2060,2256,"That so-called doctor is wasting all"],[2256,2410,"our money on failed treatments."],[2423,2560,"And don't forget,"],[2560,2769,"her incompetence blew up the lab."],[2882,2998,"That's right."],[2998,3107,"Genevieve,"],[3144,3265,"you're so smart to have"],[3265,3503,"the police investigate her."],[3799,3958,"Oh my god."],[3987,4154,"This is a bad idea."],[4220,4391,"Alright, Jen is an excellent doctor."],[4483,4596,"She's a parasite."],[4667,4771,"It was probably her idea"],[4771,4875,"to bring that patient here."],[4967,5271,"It was my idea to bring Mia here."],[5271,5555,"Look, I don't care whose idea it was."],[5643,5860,"Now more than ever, I'm convinced that"],[5860,6056,"it's long past time that you found"],[6056,6197,"yourself a proper woman."],[6531,6698,"Yeah, so Genevieve and I,"],[6698,6931,"we've talked about it, and we agreed."],[6969,7094,"You and Kim should"],[7094,7207,"get married immediately!"],[7691,7766,"But,"],[7766,7862,"Dad actually, I"],[7982,8116,"I already am getting married."],[8433,8675,"I'd like you to meet my fiancée,"],[8725,8804,"Emily Walker."],[8829,9013,"She's a fashion designer and"],[9067,9180,"the love of my life."],[9784,10093,"My absolutely gorgeous fiancée."],[10155,10352,"Please don't recognize me."],[10435,10548,"Fiancée huh?"],[10610,10819,"Well, I'll just see about that."],[10944,11390,"So, who exactly are you, and are you"],[11390,11569,"cut out to be part of this family?"],[11615,11845,"We don't let just anyone in."],[12908,13163,"Please don't say anything."]],"12":[[258,429,"She looks so familiar."],[721,1067,"Darling, there are so many snakes"],[1067,1134,"trying to weasel"],[1134,1251,"their way into our family."],[1251,1330,"How can you be sure"],[1330,1459,"that she can be trusted?"],[1605,1735,"It's a good question."],[2068,2122,"I mean..."],[2227,2502,"Are you a well refined, well cultured"],[2502,2715,"woman worthy of my son?"],[2952,3053,"Mr. Johnson,"],[3169,3299,"there's something you should know."],[3908,4070,"There's something you need"],[4070,4229,"to know about this woman."]],"13":[[2748,2865,"I'm so sorry."],[2865,3007,"Let me help you get cleaned up."],[3098,3244,"No, she..."],[3428,3532,"So, um,"],[3649,3732,"what kind of a family"],[3732,3824,"do you come from?"],[3895,4012,"Who are your parents?"],[4012,4158,"And, uh, have you even"],[4158,4362,"learned any of your manners?"],[4671,4742,"Uh,"],[4817,4879,"well,"],[4879,5080,"I, um, actually..."],[5267,5413,"Wrong answer, sweetheart."],[5530,5638,"Look, send her away,"],[5638,5805,"Roman, and marry Kim right away."],[5805,5922,"Otherwise, I'm cutting"],[5922,6085,"all funding to this lab."],[6122,6197,"You may control all the"],[6197,6322,"family businesses,"],[6322,6456,"but I still have final"],[6456,6589,"say on the charities."],[6656,6902,"Father, just let Emily stay at the"],[6902,7011,"estate for the weekend."],[7048,7090,"All right, then you'll"],[7090,7215,"see that she is the perfect"],[7215,7294,"daughter-in-law"],[7294,7407,"you've always wanted."],[7570,7741,"And once she's finally proven herself,"],[7778,7891,"then you can just sign over"],[7891,8012,"all the charities to me"],[8012,8195,"and finally retire."],[8871,8996,"Well, do you think"],[8996,9113,"you have what it takes"],[9113,9338,"to pass all my tests?"],[9838,9889,"I do."],[10051,10155,"I want nothing more than"],[10155,10281,"to make your son happy."],[10452,10535,"Very well, then."],[10823,10894,"Let's go."],[10981,11036,"Right now."],[11123,11190,"Come on, darling."],[12787,12883,"What about Mia?"],[12942,13063,"She's so weak."],[13409,13555,"I've hired the best"],[13555,13717,"doctors I could find for her."],[13801,13851,"All right, she'll be"],[13851,13934,"well-cared for."],[14981,15077,"Hold on, Mia."],[15165,15256,"I'll be back soon,"],[15256,15361,"just a few more days."],[15386,15482,"Everything will be better."]],"14":[[796,909,"You see those?"],[950,1205,"Those are the import offices and"],[1326,1589,"that is the compliance wing."],[1739,1872,"I modernized the whole place"],[1872,2010,"when I took over as CEO."],[2143,2502,"Wow, this place, it's incredible."],[2731,2831,"I knew you were well off"],[2831,2948,"but this is..."],[3086,3324,"Wow, I really don't belong here."],[3407,3486,"Jen,"],[3532,3620,"look,"],[3620,3787,"you belong here if I say you do"],[3820,3937,"and that's all that matters."],[3991,4104,"Alright, we've got this."],[4946,5180,"Find out who the hell that woman really is"],[5180,5313,"and how to get rid of her."],[5380,5513,"There's only room in Roman's life for"],[5513,5605,"one woman,"],[5689,5772,"and that's me."],[7032,7278,"Ready to go in and convince my father"],[7278,7461,"that we're a happily engaged couple?"],[7753,7928,"Yeah, let's do this."],[9834,9893,"Welcome."],[10030,10151,"Mr. Johnson,"],[10285,10472,"is there anything I can do for you, sir?"]],"15":[[37,525,"Um, yes, this is Emily Walker."],[713,880,"She's my fiancée."],[1101,1172,"And she's to be treated"],[1172,1322,"with the utmost respect."],[2110,2277,"Welcome, Miss Walker."],[2540,2602,"This way?"],[5409,5522,"Your room, sir?"],[5709,5860,"Enjoy your stay."],[7186,7278,"Well,"],[7374,7490,"make yourself at home."],[7645,7803,"I'm gonna go take a shower."],[8863,9063,"Um, where's my suitcase?"],[9509,9638,"I'll bring it up to you."],[10326,10485,"Remember what we discussed."],[10789,10969,"I don't care who she is"],[10969,11115,"or where she came from."],[11140,11248,"She doesn't belong here."],[11398,11482,"Don't worry."],[11524,11669,"She won't last that night."]],"16":[[713,834,"Don't get comfortable."],[980,1180,"Clingy nobodies like you"],[1213,1326,"aren't welcome."],[1497,1651,"Roman and I are getting married."],[1710,1860,"I'm not going anywhere."],[2018,2131,"We'll see about that."],[3036,3190,"One bed with Roman."],[3244,3349,"He's my best friend."],[3390,3520,"That's all he'll ever be."],[3570,3670,"Remember that."],[5430,5538,"What the hell?"],[5559,5680,"None of this is mine."],[5714,5851,"All my clothes are gone."],[6043,6126,"I bet Kim has"],[6126,6252,"something to do with this."],[6406,6564,"But I won't let her get the best of me."]],"17":[[16,279,"Oh my god."],[1443,1593,"Whoa."],[1868,1972,"Remember, she's your"],[1972,2127,"best friend, nothing more."],[2598,2656,"Um,"],[2773,2882,"Um, Mrs. Weatherby"],[2882,3028,"lost my clothes, so..."],[3123,3253,"What? Seriously?"],[3353,3536,"Ok, I'll go down and get them right now."],[3566,3703,"No, it's okay, we can just"],[3841,3945,"get them in the morning."],[4183,4237,"Okay."],[4754,4946,"Um, there's only one bed."],[5234,5292,"So..."],[5513,5743,"Just relax, I'm sleeping on the floor."],[6143,6193,"No."],[6335,6477,"No, it's okay."],[6493,6556,"We're both adults,"],[6556,6706,"I'm sure we can share a bed."],[6994,7107,"If you insist..."],[10085,10293,"Um, I'm sorry, I didn't mean to..."],[10456,10564,"It's okay."],[10831,10944,"Lie down and go to sleep."],[11077,11119,"Yeah."],[11895,12137,"It's kind of hard to relax"],[12354,12516,"when you're sitting here so close."],[12896,13104,"Roman, just..."],[13309,13538,"Don't, okay? It's too complicated."],[13676,13876,"And why does it feel so simple?"]],"18":[[16,212,"Forgive the intrusion, sir."],[212,383,"There's a problem in the wine cellar"],[383,521,"and your father insists that"],[521,633,"you see to it personally."],[942,1021,"Right now."],[1059,1351,"Immediately. He was most insistent."],[1559,1685,"Go, I'll be fine."],[1789,1847,"Thank you."],[2435,2544,"With Roman gone,"],[2565,2715,"we can work on destroying Emily."],[2915,3103,"And I'll get another big fat bonus."],[3182,3290,"One night."],[3290,3582,"Just survive one night."],[3799,4033,"Well, well. If it isn't the slut trying"],[4033,4095,"to weasel her way"],[4095,4225,"into being Roman's wife."]],"19":[[500,621,"What are you doing here?"],[671,763,"Just get out."],[909,1026,"Show some respect."],[1163,1259,"Kim is the daughter of"],[1259,1397,"Mr. Johnson's new wife."],[1584,1710,"She belongs here."],[2394,2485,"Put that down."],[2523,2686,"I wanna see who you really are."],[2786,2907,"Give me your password."],[3086,3161,"Now!"],[3224,3390,"Give me my phone back."],[3420,3486,"Forget it."],[3557,3616,"We all know you're"],[3616,3791,"actually a low class dirt bag."],[4066,4241,"I mean, it's obvious."],[4279,4521,"Oh, look at that cheap nightgown."],[4554,4642,"You're a fake."],[4708,4850,"And once I look into your phone,"],[4850,4954,"I'll be able to prove it."],[5125,5292,"And then Roman and his"],[5292,5518,"fortune will be all mine."],[6018,6143,"No, no."]],"20":[[25,171,"Sweet dreams, Emily."],[900,1059,"If Bill sees her like this?"],[1059,1146,"Oh, he'll have her thrown out"],[1146,1251,"on the spot."],[1251,1363,"But then Roman can marry Kim."],[1363,1413,"That's actually what"],[1413,1505,"the family wants anyway."],[1568,1630,"It's Bill."],[2043,2131,"Quiet!"],[2202,2360,"Or you'll be fired!"],[2414,2681,"I expect people in my house to know how"],[2681,2852,"to behave properly!"],[2902,3023,"So sorry, sir."]],"21":[[1347,1584,"I'm supposed to be the perfect fiancée."],[1639,1793,"And instead, I'm hiding"],[1793,1931,"half naked like a thief."],[2077,2223,"I should just leave and figure out"],[2223,2352,"another way to help Mia."],[2769,2815,"Jen!"],[2898,2965,"Roman!"],[3048,3174,"Kim tried to destroy my"],[3174,3495,"lab, me, and my sister."],[3574,3724,"I can't quit."],[5976,6093,"Good night."]],"22":[[1313,1372,"What?"],[2114,2273,"I swear this is not what it looks like."],[2456,2565,"Baby, you don't mean that."],[2890,3186,"I, I thought she was you."],[3403,3616,"Oh, she looks so jealous."],[3657,3745,"Yeah, you should be."],[3933,4008,"Look at you."],[4158,4329,"That tacky nightgown makes you look"],[4329,4441,"like a filthy maid."],[4612,4846,"I'd rather be a maid than a snake"],[4979,5171,"who lies and crawls for attention."],[5442,5580,"You'll regret saying that."],[6081,6335,"The only thing I regret is my father"],[6335,6443,"ever letting you anywhere"],[6443,6527,"near us."],[6585,6752,"And soon, he's going to"],[6752,6919,"know that you and your mother"],[6948,7019,"are nothing but a"],[7019,7127,"disease for this family."],[7136,7182,"Well."],[7365,7561,"Isn't this interesting?"],[7836,8037,"Roman, you say you want to marry"],[8070,8174,"this woman, Emily."],[8370,8621,"Are you sure she's who you say she is?"]],"23":[[0,79,"I spoke to my"],[79,467,"acquaintances abroad and strange thing."],[575,725,"No one has ever heard of a fashion"],[725,850,"designer named Emily Walker."],[1130,1184,"So it's true!"],[1376,1522,"She's nothing but a fraud in heels."],[1735,1914,"Roman, you can't be serious about her!"],[1914,2231,"Enough! Gossip is not proof."],[2464,2627,"Alright, and she is my fiancée, and if"],[2627,2873,"you lay another hand on her, I swear"],[2873,3011,"I will make you regret it."],[3299,3361,"See?"],[4533,4575,"What..."],[4621,4696,"What are you doing?"],[4808,4871,"Get out!"],[4971,5084,"You don't mean that?"],[5392,5472,"Boss,"],[5601,5730,"would you like to remove her?"],[5759,5889,"Yes, please."],[6110,6151,"No."],[6206,6281,"Oh,"],[6406,6606,"and Emily is the only woman"],[6606,6744,"I will ever trust."],[7073,7152,"And the only one"],[7152,7307,"I will ever want to be with."]],"24":[[29,158,"I’m going to call Bill!"],[158,279,"He'll make you come to your senses."],[392,483,"Roman."],[538,625,"Roman."],[909,988,"Thank you..."],[1146,1313,"for throwing her out. She's,"],[1359,1434,"awful."],[1776,1818,"Yeah."],[1989,2047,"Hey."],[2156,2268,"Hey, you're safe now."],[2481,2644,"Alright, you will,"],[2644,2861,"you will always be safe with me."],[3545,3645,"You're making it"],[3645,3799,"really hard to stay guarded."],[3999,4262,"Be careful, Jen. Don't fall for him."],[4337,4421,"You'll never recover"],[4421,4562,"from the heartbreak."],[5134,5171,"Jen."],[5430,5547,"You're my best friend, I,"],[5730,5868,"I don't want to ruin that."],[6126,6227,"We should probably,"],[6510,6664,"probably go to bed before we do"],[6664,6785,"something we might"],[6998,7069,"regret."]],"25":[[316,375,"Um,"],[508,642,"we should go to sleep because it's"],[642,829,"going to be morning soon."],[1151,1192,"Yeah."],[1576,1622,"Em..."],[1622,1680,"Yeah..."],[2610,2736,"Mr. Johnson,"],[2773,2869,"your father requests your"],[2869,2977,"presence at brunch,"],[3019,3140,"with your fiancée."],[3332,3470,"Mr. Johnson, the brunch."],[3520,3586,"Coming."],[4366,4441,"Well,"],[4500,4587,"looks like it's time to"],[4587,4683,"finally introduce you"],[4683,4779,"to high society."],[4913,4992,"And,"],[4992,5263,"oh, I took the liberty of having the"],[5263,5522,"housemate replace your wardrobe,"],[5709,5784,"and upgrade it."],[6026,6126,"Hope you enjoy it."],[6898,7086,"This is beautiful."],[9075,9159,"She needs to keep"],[9159,9296,"going with her treatments."],[9334,9509,"This brunch better convince Roman's dad"],[9509,9588,"we're a happy couple,"],[9647,9747,"or I don't know how my"],[9747,9880,"sister is going to survive."]],"26":[[825,917,"Hey."],[1305,1447,"You look incredible."],[1668,1747,"All right, don't let"],[1747,1872,"anyone here rattle you."],[2027,2260,"You belong here with me, okay?"],[2569,2819,"Yeah, don't let anyone rattle you."],[2819,3023,"Well, that's really easy for you to say."],[3057,3215,"Hey, I've got just as"],[3215,3386,"much stake in this as you do."],[3566,3636,"If this fake"],[3636,3895,"relationship doesn't fool them,"],[4070,4200,"Kim and her evil mother"],[4200,4354,"are going to take my businesses."],[4433,4546,"I mean, the charities?"],[4621,4688,"I know."],[4717,4909,"You're right."],[5447,5605,"You are the only person I would ever"],[5605,5697,"want to do this with."],[5980,6051,"We've got this."],[6110,6202,"Trust me."],[6464,6556,"Trust us."],[6606,6669,"All right?"],[7724,7811,"I'll be right back."],[7878,7937,"Okay."],[9138,9275,"You must tell us."],[9371,9663,"Where exactly did my stepson find you?"],[9968,10168,"I always thought my sloppy seconds"],[10168,10256,"would at least have"],[10256,10468,"some sense of fashion."],[10639,10865,"That dress is so drab."],[10898,11077,"It's a crime against humanity."],[11423,11644,"Oh, did you thrift that"],[11644,11782,"at the garbage disposal?"],[12291,12445,"I know you're jealous, Kim."],[12575,12712,"But get this through your head."],[12771,12992,"Roman is with me, not you."]],"27":[[12,246,"Roman is with me, not you."],[1597,1676,"You should leave while"],[1676,1818,"you still have the chance."],[2318,2477,"What a mutt."],[2515,2598,"I bet she has never been to"],[2598,2711,"a breakfast like this."],[2806,2915,"You're going to do nothing but"],[2915,3036,"embarrass yourself."],[3148,3286,"It's only a matter of time before"],[3286,3490,"everyone realizes what trash you are."],[3657,3782,"Then Roman will end up with me."],[4062,4149,"Where he belongs."],[4441,4692,"Roman can't even stand you."],[4767,4938,"You don't know him as well as I do."],[5084,5263,"He'll come to his senses and then"],[5263,5388,"you'll end up where you belong."],[5426,5572,"In the gutter with the"],[5572,5759,"homeless bums who live there."],[6001,6106,"Breathe Jen."],[6106,6260,"If you let them get to you,"],[6302,6385,"they win."],[6423,6506,"Oh,"],[6627,6831,"you look so nervous."],[6969,7102,"Let's see how you handle this."],[7186,7336,"You think you belong here?"],[7449,7611,"Let's just see."],[8012,8166,"Tell us, dear."],[8287,8500,"Which fork do you use for the fruit?"],[8779,8854,"Are you too much of a"],[8854,9013,"country bumpkin to know?"],[9968,10235,"Did Roman really bring in nobody here?"],[10268,10414,"Ew, I'm not sitting at"],[10414,10614,"the same table as her."],[10694,10894,"My husband sees everything."],[10948,11061,"Slip up once."],[11098,11223,"He'll send you back to the"],[11223,11432,"manure patch where you belong."],[11895,11978,"How pathetic."],[12062,12174,"She doesn't even know."]],"28":[[646,838,"Oh, what's wrong, Emily?"],[950,1105,"Don't tell me you don't know."],[1455,1580,"What's going on here?"],[1714,1922,"Oh, Roman's new plaything"],[1922,2110,"is confused about the forks."],[2139,2189,"Oh?"],[2227,2381,"I'm trying to help her, but"],[2381,2581,"she just doesn't get it."],[2681,2869,"She's had a terrible upbringing."],[2948,3040,"Is that true?"],[3190,3319,"Have you been lying to"],[3319,3541,"Roman about who you really are?"],[3749,3891,"Think, Jen."],[4191,4262,"Don't panic."],[4337,4521,"Show them you belong."],[5555,5634,"Hmm."],[5714,5793,"Correct."],[6297,6368,"And,"],[6423,6498,"with grace,"],[6748,6861,"which I'm afraid can't be said"],[6861,6994,"about all present company."],[7207,7353,"It's very proper indeed."],[7478,7532,"Well,"],[7615,7720,"I guess she just"],[7720,7862,"passed test number one."],[8379,8579,"Anyone can memorize a goddamn fork."],[10085,10181,"Put that down."],[10181,10297,"You're embarrassing me."],[10297,10431,"I don't care who they are."],[10777,10931,"I don't let anyone at my"],[10931,11115,"table who eats like a pig."],[11182,11298,"It's not my fault."],[11486,11582,"She's a bad influence."],[11657,11786,"Emily's rubbing off on me."],[12028,12103,"Tell us, Emily, who"],[12103,12237,"exactly is your family?"],[12462,12604,"Her family taught her"],[12604,12754,"intelligence and grace."],[13075,13146,"Look, if you still need"],[13146,13275,"names, feel free to ask her."],[13338,13417,"But,"],[13496,13576,"if you really want to know"],[13576,13680,"the woman at my side,"],[13722,13784,"just,"],[13918,14072,"watch how she handles herself."],[14118,14185,"Then you'll see"],[14185,14330,"everything you need to know."]],"29":[[16,166,"One wrong word and"],[166,300,"they'll tear me apart."],[880,971,"Think, Jen."],[988,1121,"Think like them."],[1213,1497,"Well, don't you see she's stalling?"],[1580,1710,"Her family is likely"],[1772,1964,"a total embarrassment."],[1964,2118,"They're probably complete invalids"],[2118,2210,"leeching off each other"],[2210,2298,"to survive."],[2565,2848,"My family taught me something far more"],[2848,3028,"important than forks."],[3128,3382,"They taught me that refinement is more"],[3382,3657,"composure, loyalty,"],[3766,3891,"and grace under pressure."],[4291,4383,"And that is something that"],[4383,4604,"no amount of wealth can fake."],[4896,4971,"I agree."],[5059,5142,"Well, everybody."],[5238,5313,"Let's eat."],[5434,5543,"How quaint."],[5889,5997,"I am impressed."],[6097,6210,"You handled that well."],[6519,6756,"She's making us look like fools."],[6790,6940,"If she marries Roman instead of you,"],[6940,7082,"we will never get the full inheritance."],[7161,7265,"Leave it to me."],[7315,7549,"I'll humiliate her so bad she'll run."],[7720,7882,"And then Roman will be mine."]],"30":[[225,350,"Such elegance."],[379,458,"She'll make a perfect"],[458,588,"addition to the family."],[617,775,"Roman chose well."],[775,1000,"She has so much dignity and grace."],[1088,1280,"See, you're a natural."],[1317,1564,"One of them, you're doing great."],[2360,2489,"End her now."],[2811,2969,"What is she doing?"],[3023,3194,"No, she wouldn't dare."],[3899,3991,"What do I do?"],[4037,4170,"How do I stop this?"],[5301,5442,"Is that a..."],[5530,5634,"Wow."],[5668,5780,"It can't be."],[5780,5922,"How humiliating."],[6010,6064,"Kim,"],[6139,6260,"what is this?"],[6293,6473,"It's not what it looks like."],[6644,6773,"No, I think it's"],[6773,6915,"exactly what it looks like."],[7077,7194,"And it's proof"],[7194,7365,"who truly belongs here."],[7424,7553,"It's pathetic."],[7732,7786,"This family"],[7786,7945,"deserves better than this."],[8124,8270,"Truly disappointing."],[8933,9117,"Miss Walker, Mia's stable for now."],[9171,9238,"But she needs"],[9238,9363,"those treatments soon."],[9438,9517,"I know."],[9547,9655,"I'm doing everything I can."],[9655,9809,"Just please keep her safe"],[9809,9893,"until I get back."],[9964,10035,"We'll try."],[10064,10214,"But time's running short."],[10581,10681,"If I fail here,"],[10752,10852,"Mia doesn't make it."],[10894,11044,"I can't let that happen."]],"31":[[271,379,"You are brilliant."],[454,521,"I mean,"],[554,638,"you fought them off"],[638,754,"better than I could have."],[846,925,"I mean at this rate my father"],[925,1084,"will not only accept you,"],[1084,1230,"but Kim will never walk back"],[1230,1288,"through that door."],[1451,1643,"I truly cannot repay you for"],[1643,1760,"everything you've done for me."],[2544,2723,"Roman, what are you doing?"],[2794,2852,"We have to keep up"],[2852,2944,"appearances, right?"],[3069,3390,"Oh, is that all that was?"],[3674,3728,"Emily,"],[3824,3899,"Roman,"],[3899,3995,"come with me."],[3995,4099,"I'm hosting some"],[4099,4295,"people at poolside at noon."],[4387,4479,"Would you join me?"],[4738,4783,"Oh,"],[4817,4984,"private poolside gathering."],[5030,5155,"That's his inner circle."],[5301,5409,"Hey, don't worry."],[5488,5568,"You'll be great."],[6214,6393,"I can't do this, okay?"],[6393,6531,"I can't be here with"],[6531,6610,"all these billionaires"],[6610,6677,"and pretend that"],[6677,6744,"I'm someone I'm not"],[6744,6852,"with all these socialites."],[6861,6931,"I'm supposed to be"],[6931,7069,"in a science lab."],[7119,7244,"This isn't,"],[7244,7378,"this isn't who I am."]],"32":[[29,158,"This isn't who I am."],[221,279,"Hey."],[567,709,"You literally have them eating out of"],[709,834,"the palm of your hand."],[1063,1209,"I wish that I believed in"],[1209,1372,"myself as much as you do."],[2681,2777,"Is Mia okay?"],[2861,3090,"She's stable for now."],[3257,3340,"Everyone!"],[3549,3682,"This is Emily Walker."],[3816,4012,"And if Roman has anything to say"],[4012,4266,"about it, she's going to be his bride."],[4362,4462,"But the jury's still"],[4462,4600,"out on that for now."],[5063,5238,"Hey, breathe."],[5334,5509,"Alright, you look stunning."],[5634,5772,"Why does it feel like you're not"],[5772,5901,"pretending anymore?"],[6135,6218,"I mean,"],[6335,6506,"would it be so bad if I wasn't?"],[6756,6810,"Roman,"],[6948,7111,"how did you and Emily meet?"],[7286,7486,"University, actually."],[7532,7728,"You know, I've gone nose to nose"],[7728,7870,"with billion dollar sharks."],[7916,8095,"I have never met anyone as"],[8095,8233,"intelligent as her."],[8650,8775,"To Emily!"],[9096,9238,"May she prove herself"],[9238,9446,"worthy of this family."],[9638,9793,"A toast isn't enough."],[9843,10009,"Let's see a real kiss"],[10009,10181,"from the happy couple."]],"33":[[400,738,"Kiss! Kiss! Kiss!"],[738,900,"Roman, we're just friends."],[959,1071,"Trust me."],[1272,1347,"Okay."],[3140,3269,"God help me."],[3395,3507,"I want him."],[4437,4525,"If only someone"],[4525,4654,"would kiss me like that."],[4692,4879,"They're perfect together."],[5751,5851,"Well, um,"],[5930,6172,"after that performance,"],[6252,6377,"I find it hard to believe anyone"],[6377,6502,"could imagine you were just a doctor"],[6502,6660,"spending most of your time in a lab."],[7077,7152,"Peter?"],[7328,7394,"He can't breathe!"],[7444,7490,"Please!"],[7582,7661,"Oh my God."],[7770,7816,"Oh."],[7836,7941,"He's choking!"],[8033,8116,"Is there a doctor?"],[8116,8224,"Please, somebody help!"]],"34":[[25,125,"Is there a doctor?"],[125,250,"Please, somebody help!"],[279,437,"He's dying. Somebody help him."],[471,633,"He's dying. Somebody save him!"],[633,700,"Just go help, go help."],[700,796,"Okay, okay."],[796,855,"Help."],[1009,1092,"It's okay."],[1234,1384,"Ok everyone, give him some space."],[1530,1643,"You, go get him water"],[1643,1768,"and you call 911."],[1972,2052,"Do you have any allergies?"],[2072,2139,"Yeah? Okay."],[2156,2252,"He's not choking."],[2252,2389,"He's having an allergic reaction."],[2389,2469,"It's anaphylaxis."],[2635,2711,"Oh my gosh."],[2731,2865,"There must be shrimp in the hors d'oeuvres."],[2865,2944,"He's allergic!"],[2961,3053,"Does he have an EpiPen?"],[3078,3153,"Yeah yeah. Okay."],[3315,3403,"I don't know how to use this."],[3457,3553,"How do you know how to use this?"],[3553,3653,"Aren't you a fashion designer?"],[3678,3741,"I..."],[3828,3945,"Just give it to her, alright?"],[3945,4024,"She knows what she's doing."],[4024,4091,"You have to trust her."],[4371,4471,"Okay."]],"35":[[379,521,"Oh my gosh."],[642,767,"He's gonna be okay."],[1017,1146,"How'd she know how to do that?"],[1146,1313,"We may have just blown our cover, but"],[1438,1543,"I've never been more proud of"],[1543,1639,"anyone in my life."],[1714,1801,"You're amazing."],[1943,2093,"You saved my husband's life."],[2135,2202,"Thank you."],[2306,2435,"How did you know how to do that?"],[2548,2702,"It's what anyone would have done."],[2723,2877,"It's just basic first aid."],[2944,3057,"Basic first aid?"],[3215,3370,"That's textbook medicine."],[3720,3862,"Emily, I thought you said you were"],[3862,3995,"a fashion designer."],[4037,4104,"Are you sure you're"],[4104,4250,"not secretly a doctor?"],[4521,4637,"Enough, all right."],[4671,4717,"Look, she just"],[4717,4833,"saved this man's life."],[4875,4975,"while the rest of us froze."],[5071,5188,"That's all that matters."],[5326,5518,"It's okay, Roman."],[5663,5814,"I'm just kind of a"],[5814,6018,"bookworm in my free time."],[6018,6206,"I read a lot when I'm not on"],[6206,6327,"the runway in Italy."],[6506,6706,"She didn't hesitate."],[6744,7057,"She knew exactly what to do."],[7157,7340,"That is super suspicious."],[7440,7586,"She's hiding something."],[7678,7899,"And I will prove it."],[8204,8324,"Plant this in her room"],[8324,8591,"and make sure she gets caught."]],"36":[[1263,1463,"Let's see her explain this."],[1730,1997,"Emily, you've proven yourself."],[2072,2306,"Few would act with such courage."],[2731,2790,"Roman?"],[2936,3040,"Introductions?"],[3132,3249,"I'll be right back."],[3353,3440,"Okay."],[3958,4008,"My purse!"],[4112,4204,"It's gone!"],[4283,4512,"Now it begins."]],"37":[[29,108,"It was right here!"],[162,275,"My purse is missing!"],[467,613,"What a shame!"],[613,900,"Maybe it's misplaced somewhere."],[1038,1113,"Or..."],[1276,1376,"perhaps someone"],[1376,1609,"decided to help themselves."],[1768,1843,"Why are you"],[1843,1951,"looking at me like that?"],[2377,2444,"What is it?"],[2602,2752,"I saw Emily carrying a purse"],[2752,2857,"upstairs earlier,"],[3174,3236,"toward her room."],[3691,3858,"My necklace is in that purse."],[3941,4099,"Search her room right now!"],[4124,4325,"Every inch of it until we find it!"],[4779,4942,"Now, where to hide Mia's"],[4942,5067,"treatment files?"],[5184,5330,"If anyone finds them, they'll"],[5330,5480,"figure out my true identity."],[6231,6473,"I, I didn't take it!"],[6581,6723,"Only one way to be sure."],[6752,6986,"Yes! Let's go check."],[7077,7165,"Right now."]],"38":[[2565,2669,"You're not going to find anything."],[2694,2836,"I didn't steal your purse."],[4020,4091,"That's mine."],[4279,4391,"You stole it."],[4421,4491,"You thief!"],[4929,5067,"The necklace is missing."],[5176,5405,"You're going to pay for being a"],[5405,5534,"dirty little thief."],[6339,6573,"Ah, here it is."],[6740,6848,"Someone call the police."],[6919,7069,"She stole it."],[7069,7144,"What?"],[7173,7253,"No, I didn't."],[7253,7328,"I promise."],[7328,7415,"You have to believe me."],[7457,7570,"I knew something was off."],[7595,7803,"So she saved a man, and"],[7803,7962,"then she stole from us."],[8237,8441,"She probably slipped shrimp into"],[8441,8537,"that poor man's food."],[8629,8746,"A distraction so she"],[8746,8863,"could steal the purse."],[8925,9071,"No, I would never do that."],[9071,9221,"The evidence speaks for itself."],[9221,9463,"And lying, manipulative thieves"],[9463,9609,"do not belong in this family."],[9663,9780,"Such a shame."],[9914,10105,"Roman will be devastated when he"],[10105,10226,"learns his fiancée is a"],[10226,10456,"lying, despicable thief."]],"39":[[25,216,"You can't deny it, Emily."],[271,371,"We caught you."],[421,475,"Oh, and don't"],[475,583,"forget about the shrimp."],[650,721,"The perfect"],[721,955,"distraction so she could rob us."],[1067,1172,"She risked a man's"],[1172,1334,"life just to get this."],[1488,1605,"She's evil."],[1739,1818,"When this is over."],[1843,1976,"I will have you charged with"],[1976,2093,"attempted murder."],[2139,2168,"What?"],[2298,2494,"No, that's a lie."],[2510,2706,"I saved him in front of everyone."],[2761,2852,"How could I even be"],[2852,2990,"in two places at once?"],[3299,3365,"Exactly."],[3474,3586,"Look, you all saw her."],[3695,3799,"She was at the pool the entire"],[3799,3958,"time, saving a man's life."],[4237,4441,"Then someone here is lying."],[4567,4617,"And I won't"],[4617,4842,"tolerate liars in my house!"],[5180,5230,"Oh!"],[5497,5659,"This isn't yours, is it?"],[5901,5972,"No."],[6089,6210,"That's not mine."],[6427,6548,"Where did it come from?"],[6798,6894,"It was,"],[7032,7211,"an engagement gift for my fiancée."],[7603,7720,"But you ruined that."],[7928,7970,"Sir,"],[8141,8249,"I've gone through the footage."],[8354,8445,"Mrs. Weatherby,"],[8500,8608,"put the purse in here."],[8779,8883,"We've got all the evidence."]],"40":[[79,283,"No, I'd never."],[2481,2736,"Mrs. Weatherby, I should fire you."],[2736,2944,"But instead, you'll learn your"],[2944,3107,"lesson being demoted to"],[3107,3311,"junior scullery maid."],[3311,3503,"Now go report to the kitchen."],[3578,3703,"You can't do that."],[3753,3924,"Really? Well, it's that"],[3924,4195,"or jail, so take your pick."],[5142,5259,"Is this yours?"],[5330,5384,"Yes."],[5655,5876,"Okay, enough of this circus."],[5989,6072,"Emily,"],[6206,6368,"you'll join us on the lawn"],[6368,6552,"for a family photo."],[6698,6919,"It's time the world sees you"],[6944,7061,"as one of us."],[8433,8708,"You were incredible in there."],[8708,8875,"I mean, they could have torn you"],[8875,8979,"apart, but you,"],[9129,9292,"you sure stood your ground."],[9442,9642,"Well, I couldn't have done it"],[9642,9776,"without you, Roman."],[10326,10460,"This is for you."],[10673,10869,"I was going to give it to you"],[10869,10977,"this evening, but"],[11023,11140,"you should have it now."],[11282,11378,"What do you..."],[11465,11532,"You didn't need to"],[11532,11678,"get me anything, Roman."],[11832,11966,"You're my fiancée now."],[12174,12437,"You deserve a little sparkle."],[14456,14547,"It's,"],[14827,14935,"it's beautiful."],[15060,15144,"Just like you."],[15377,15548,"Don't tease me, Roman, okay?"],[15548,15619,"Don't say"],[15619,15736,"things that you don't mean."]],"41":[[25,137,"Don't tease me, Roman, okay?"],[137,208,"Don't say"],[208,325,"things that you don't mean."],[442,596,"I do mean it."],[688,871,"Jen, you are the only thing"],[871,996,"holding me together."],[1034,1172,"I couldn't do this without you."],[1280,1530,"No. No, don't be silly Roman."],[1593,1801,"You are Roman Johnson."],[