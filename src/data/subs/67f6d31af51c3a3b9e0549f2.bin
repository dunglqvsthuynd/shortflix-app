{"1":[[546,621,"Who is that?"],[667,759,"That's Troy Poe."],[930,1063,"Singlehandedly took out"],[1063,1172,"an entire terrorist cell."],[1205,1334,"Survived three months behind"],[1334,1459,"enemy lines, stranded."],[1463,1609,"Rescued 50 Americans"],[1609,1760,"from the Sub Rosa Siege."],[1897,2006,"I thought he was a legend."],[2043,2127,"He is."],[2398,2448,"Son,"],[2494,2631,"you have singlehandedly"],[2631,2844,"made the country a safer place,"],[2890,3011,"even if most of its citizens"],[3011,3161,"will never know what you've done."],[3628,3883,"I've served my country for years."],[3883,4041,"Now it's time for my next mission."],[4099,4216,"Clean up my own house."],[4287,4421,"I'm about to get the son"],[4421,4558,"to sign over everything."],[4604,4742,"Yeah, he didn't even make it"],[4742,4821,"to the funeral."],[4925,5159,"He's just a trust fund brat."],[5213,5480,"I guarantee he's a drugged-out hipster."],[5543,5701,"Yeah, actually I'm doing him a favor"],[5701,5826,"by taking all his money."],[5826,5939,"He'd probably blow it all"],[5939,6106,"on coke and strippers."],[6293,6398,"Who the hell are you"],[6398,6506,"and what are you doing here?"],[6564,6660,"I'm Troy Poe."],[6798,6948,"You're in my father's chair."],[7361,7474,"Troy,"],[7474,7557,"welcome home."],[7791,7945,"I worked with the board"],[7945,8195,"to secure an amazing offer"],[8195,8283,"for the company."],[8308,8404,"Just, uh,"],[8404,8504,"sign right here"],[8504,8587,"and then the only thing"],[8587,8737,"you have to worry about is"],[8737,8792,"how are you gonna"],[8792,8896,"spend all that money."],[9129,9280,"Sign it, dumbass."],[9280,9547,"Sign away your fortune to me."],[9930,10064,"You sure this is a good deal?"],[10160,10326,"Oh, definitely."],[10623,10739,"What's he waiting for?"],[10739,10865,"There's no way he found out."]],"2":[[16,108,"It's a shit deal."],[150,266,"What do we call that, John?"],[517,600,"It's called"],[658,779,"a conflict of interest"],[817,913,"and fraud."],[1017,1159,"Mr. Parker..."],[1159,1255,"You're fired."],[1664,1818,"Now get the fuck out of my house."],[1856,1947,"What is this?"],[1968,2122,"You can't do this to me."],[2185,2285,"Sorry about your dad."],[2439,2540,"This is my company now"],[2540,2598,"and I'm gonna start"],[2598,2740,"by making some improvements."],[2823,2965,"Starting with Southgate Prison."],[3036,3199,"Improve Southgate?"],[3282,3390,"You hate Southgate."],[3390,3461,"I do."],[3520,3687,"I hate that the prison I now own"],[3687,3782,"is one of the worst."],[3807,3937,"Look, inmates are staying in longer"],[3937,4033,"than they're supposed to,"],[4033,4175,"paroles are being denied"],[4175,4254,"left and right."],[4295,4358,"And the death rates"],[4358,4454,"are through the roof."],[4521,4758,"This is my responsibility now"],[4813,4888,"and I'm gonna find out"],[4888,4959,"what's happening."],[5030,5130,"How are you gonna do that?"],[5705,5768,"No."],[5789,5872,"No!"],[5922,6047,"You going undercover"],[6047,6139,"as a prisoner"],[6139,6239,"is too risky."],[6239,6322,"Relax."],[6348,6531,"I'll have safeguards in place."],[6585,6715,"The Head Guard, Butch Roberts,"],[6715,6877,"will know about me and have my back."],[6877,7019,"My father trusted him."],[7073,7269,"Plus, I'm the only living person"],[7269,7399,"that knows the override code"],[7399,7549,"for all the locks within the building."],[7632,7720,"Most importantly,"],[7720,7866,"I'm gonna have you on the outside."],[7866,8020,"If I run into any problems,"],[8037,8153,"I still don't like it."],[8153,8262,"Well, that's too bad."],[8329,8454,"Cause I think I hear my ride."],[8967,9050,"Troy Poe?"],[9175,9330,"You're under arrest for murder."],[9380,9438,"Wait."],[9509,9580,"Murder?"],[9613,9705,"Might as well give myself"],[9705,9780,"some street cred."]],"3":[[33,100,"Come on, inmate."],[216,271,"Breakfast."],[2894,3044,"Best pick your jaw up, son."],[3995,4108,"I'll tell you what, though."],[4179,4291,"Thirty years ago,"],[4366,4479,"I wouldn't stand a chance"],[4479,4587,"of getting that."],[4888,4975,"Name's Miles."],[5042,5084,"Troy."],[5109,5188,"Hey, Troy."],[5288,5405,"I'll give you some advice."],[5492,5701,"Learn to be invisible."],[5830,5910,"Or what?"],[5976,6135,"Or they'll hand your ass to you."],[6177,6272,"Well, the other inmates"],[6272,6373,"don't seem that bad."],[6393,6564,"I'm not talking about the inmates."],[6781,6856,"It's these guys."],[7165,7265,"What the fuck?"],[7265,7369,"I'm so sorry."],[7695,7770,"Please!"],[7828,7949,"Please don't kill me."]],"4":[[408,513,"Go to the infirmary."],[633,709,"Tell them you slipped."],[1514,1726,"Miles."],[1830,1901,"Yes, sir?"],[1956,2131,"Don't you fucking sir me."],[2210,2302,"What's this I hear about"],[2302,2423,"you filing complaints"],[2423,2515,"about your surgery? - I..."],[2581,2719,"I think I found my corruption."],[2765,2840,"I didn't do that."],[2869,2915,"I didn't do."],[2923,2969,"I didn't do."],[2969,3057,"I didn't do that."],[3094,3140,"Shut up!"],[3203,3328,"You already had your surgery."],[3328,3478,"I filed the paperwork myself."],[3557,3712,"Made a lot of money off it, too."],[4083,4275,"So he's falsifying medical records"],[4275,4400,"and keeping the money."],[4433,4496,"I..."],[4496,4646,"I really need that surgery."],[4671,4808,"Oh, you really need that surgery?"],[4817,4879,"I-"],[4879,4946,"Oh yeah?"],[4975,5125,"I can fix your stomach right now,"],[5125,5171,"old man."],[5171,5259,"Stand up."],[5347,5405,"Let's go!"],[5405,5476,"Stand up!"],[5951,6118,"I don't want to give away my identity"],[6118,6197,"so soon."],[6239,6389,"But I can't let this happen."],[6981,7073,"I'm sorry."],[7207,7319,"Not sorry enough."],[7957,8028,"He's old."],[8224,8308,"Leave him alone."],[8554,8666,"You're so fucking dead."],[8742,8867,"Yeah, I don't think so."],[8892,9113,"Look at this brave motherfucker."],[9401,9496,"Everybody out!"],[9901,10014,"I haven't seen you around here."],[10151,10243,"Who the fuck are you?"],[10314,10364,"I'm the guy"],[10364,10527,"who's about to destroy your life."]],"5":[[20,70,"I'm the guy"],[70,233,"who's about to destroy your life."],[513,567,"Oh yeah?"],[859,955,"Let's see what you got."],[1864,2014,"If I hurt him in any way,"],[2047,2231,"it will give him an excuse to shoot me."],[2277,2339,"Nah."],[2502,2619,"I'm not hitting a guard."],[2827,2911,"Smart move."],[2969,3090,"Now get the fuck out of here."],[3299,3399,"Just like that?"],[3453,3541,"Just like that."]],"6":[[333,417,"Don't fight back."],[504,638,"Don't fight back."],[713,813,"You're new here."],[884,1021,"So let me tell you how it works."],[1334,1472,"This ain't the goddamn subway."],[1472,1564,"If you see something,"],[1564,1710,"you don't say shit."],[1751,1897,"You need to learn the rules."],[1956,2027,"Rule one."],[2147,2410,"I can kick your ass anytime I want."],[2452,2548,"Rule two."],[2702,2777,"In here,"],[2819,2907,"I'm a god."],[2969,3061,"Rule three."],[3207,3378,"You're nothing but a little..."],[3407,3499,"prisoner..."],[3557,3607,"bitch."],[4300,4375,"It's over."],[4404,4491,"Just be quiet."],[4529,4629,"Just be quiet."],[4629,4688,"Just be--"],[4688,4842,"None of which you said is true, bitch."],[5209,5301,"What the fuck you just say?"],[5451,5518,"One."],[5609,5768,"You can't kick my ass at anytime."],[5843,5935,"And if you touch me again,"],[5935,6039,"I'm gonna hurt you,"],[6039,6114,"bad."],[6114,6235,"You're so fucking dead."],[6414,6464,"Two."],[6523,6627,"You're not a god in here."],[6627,6731,"You're just a sad little man"],[6731,6886,"who's about to lose his job."],[6927,7011,"And three."],[7115,7244,"I'm not a little prisoner, bitch."],[7244,7328,"Kill him!"]],"7":[[4,75,"Kill him!"],[1622,1730,"Drop the weapon."],[2218,2331,"What the hell's going on?"],[2719,2823,"This prisoner"],[2823,2882,"went crazy."],[2882,3015,"He started attacking us"],[3015,3115,"before we could do anything."],[3115,3228,"What the hell are you talking about?"],[3240,3407,"Started reaching for a guard's gun."],[3428,3490,"He's lying."],[3524,3636,"Unfortunately,"],[3716,3908,"we'll have to resort to lethal force."],[3995,4124,"Any last words?"]],"8":[[37,150,"Any last words?"],[629,684,"Go ahead."],[717,784,"Shoot me."],[842,892,"What?"],[892,1030,"Something you should know, though."],[1167,1251,"I'm not a prisoner."],[1359,1518,"And if that bullet ends my life,"],[1518,1589,"yours becomes"],[1589,1722,"a hell of a lot worse."],[1772,1906,"What the fuck are you on about?"],[1926,2002,"I'm here..."],[2060,2202,"to clean up the shit."],[2681,2773,"Any last words?"],[3086,3157,"See?"],[3194,3299,"I told you."],[3340,3449,"This guy is nuts."],[3541,3620,"Look at you."],[3687,3803,"Pretending to be different."],[3849,3924,"Special."],[4008,4175,"We've seen enough delusional prisoners"],[4175,4262,"to know better."],[4320,4371,"Guards!"],[4612,4704,"No one moves until"],[4704,4829,"Butch Roberts gets here."],[4971,5038,"Butch?"],[5038,5117,"How does he know"],[5117,5205,"the head guard's name?"],[5221,5288,"Who cares?"],[5288,5384,"He's got a gun on me."],[5384,5492,"Oh, you should care."],[5534,5593,"Cause you're gonna spend"],[5593,5709,"the rest of your life in here."],[5709,5834,"Remind me, how do uh..."],[5880,5960,"how do prisoners"],[5960,6135,"treat incarcerated guards, hmm?"],[6177,6243,"Colton."]],"9":[[784,867,"I'm not gonna shoot you."],[963,1105,"We wait until Butch gets here."],[1172,1284,"Shut up about Butch."],[1351,1459,"Everyone turn around."],[1522,1584,"Now!"],[2235,2348,"Are you gonna shoot me?"],[2414,2606,"An unarmed inmate in cold blood."],[2711,2773,"Oh no."],[2865,2948,"He's got a weapon."],[3048,3136,"He's gonna shoot."],[3157,3303,"I have no choice but to-"],[3303,3486,"What the hell is going on in here?"],[3749,3837,"Shit."]],"10":[[496,600,"I said,"],[600,746,"what the hell is going on in here?"],[746,967,"This prisoner just attacked a guard."],[1071,1188,"It's good to see you, Butch."],[1359,1472,"I found our problem."],[1539,1647,"Did you now?"],[1772,1960,"Why am I getting alarms in my office?"],[1997,2081,"Warden Johnson,"],[2127,2185,"don't worry,"],[2185,2327,"the situation has been handled."],[2373,2477,"Was there a fight?"],[2623,2681,"Who's this?"],[2698,2773,"Warden,"],[2773,2915,"I'll explain everything in your office,"],[2915,3069,"but right now, I want this man arrested."],[3169,3328,"He's been involved in serious corruption"],[3328,3440,"and I've got the proof."],[3532,3641,"Butch can back me up."],[3895,3958,"Butch?"],[4191,4283,"Warden,"],[4696,4913,"I have no idea what this lunatic"],[4913,5050,"is talking about."]],"11":[[237,275,"Yeah."],[316,437,"Yeah, I'm bringing him in now."],[571,679,"No, he's got no idea"],[679,850,"I'm the one running the whole operation."],[1092,1267,"No, he's not gonna find anything."],[1438,1522,"But if he does,"],[1743,1881,"I'll just kill him."],[2135,2214,"But he did just get"],[2214,2373,"released from an insane asylum,"],[2373,2427,"so..."],[2498,2723,"He probably thinks he owns the place."],[2798,3003,"What the fuck are you talking about?"],[3036,3199,"That's enough, prisoner."],[3219,3374,"He just attacked me out of nowhere,"],[3374,3411,"Dad."],[3453,3503,"Dad?"],[3636,3716,"He's your son?"],[3757,3933,"I said that's enough, prisoner."],[3933,4033,"Motherfucker!"]],"12":[[258,396,"Wasn't supposed to happen like this,"],[396,454,"Troy."],[479,629,"I gave specific instructions"],[629,809,"that nothing was supposed to happen"],[809,900,"in front of you."],[1101,1255,"It wasn't my fault, Dad."],[1272,1413,"I was looking for some rich kid,"],[1413,1555,"not some tatted up,"],[1580,1622,"jacked-"],[1622,1726,"Oh, shut up."],[1726,1885,"You know, if you weren't my son,"],[1910,2064,"I would feed you to the prisoners."],[2118,2252,"My father trusted you."],[2598,2656,"Yeah,"],[2656,2756,"I don't know why."],[2756,2865,"He must have been a fool."],[2886,2969,"Hell, I've been running"],[2969,3128,"this operation for years."],[3128,3324,"I falsify the disciplinary reports"],[3324,3457,"of the sick and elderly,"],[3482,3591,"to keep them in here,"],[3603,3678,"and then I embezzle"],[3678,3828,"the hell out of their medical funds"],[3828,3912,"until they die."],[3928,4033,"I get rich."],[4066,4229,"The world gets one less criminal."],[4354,4483,"It's a win-win, Troy."],[4512,4646,"You're killing people."],[4863,5000,"You're not listening to me."],[5000,5121,"I'm not killing people,"],[5184,5292,"I'm killing criminals."],[5334,5447,"There's a difference."],[5509,5618,"You're gonna kill me too?"],[5880,5951,"No."],[6089,6202,"I'm not gonna kill you."],[6431,6594,"I'm gonna leave that to the inmates."],[6631,6719,"Everybody out."],[7123,7261,"Heads up, you lowlifes!"],[7261,7428,"Got a special treat in the house!"],[7428,7707,"We got a snitch in cell five!"],[7828,8008,"Snitch in cell five!"],[8216,8345,"Fresh meat in the house."],[8345,8425,"You hungry?"],[8454,8629,"Snitch in cell five."],[8708,8829,"Have at it, boys."]],"13":[[704,817,"Well, you know what they say."],[971,1088,"Snitches get cut."],[1138,1322,"It's actually snitches get stitches."],[1426,1530,"And I'm not a snitch."],[1797,1868,"Sure you are."],[1868,2014,"Look, I'm not here to fight you."],[2072,2168,"I don't want to hurt you."],[2193,2239,"Oh."],[2473,2619,"You don't need to worry about that."],[2773,2861,"Don't react."],[2902,3044,"You're here to help these guys."],[3123,3207,"Not hurt them."],[3403,3478,"Okay,"],[3507,3591,"you got me."],[3766,3820,"Ow."],[4154,4250,"Nice punch."],[4346,4391,"We good?"],[4500,4667,"Haven't even started yet."],[4738,4792,"What?"],[4859,4992,"Snitch is too scared to fight?"],[5017,5096,"I would just hate to"],[5096,5184,"damage a face as"],[5184,5288,"beautiful as yours."],[5288,5351,"Oh,"],[5388,5480,"thanks for noticing."],[5860,6060,"So, who wants to see me"],[6093,6314,"humiliate this bitch right here?"]],"14":[[20,83,"Hey."],[271,333,"Ah."],[379,483,"You look thirsty."],[542,675,"Let me prep you a drink."],[1622,1697,"There we go."],[2060,2177,"I had a few lattes, so"],[2177,2273,"it's gonna be tasty."],[2556,2619,"The little rat's"],[2619,2790,"not even trying to fight back."],[2790,2940,"He wants to drink the piss."],[3015,3174,"Drink the piss!"],[3207,3324,"Drink the piss!"],[3357,3461,"Drink the piss!"],[3490,3549,"Drink the piss!"],[3549,3632,"Drink the piss! - Drink the piss."],[3632,3737,"Drink the piss!"],[3762,3883,"Drink the piss!"],[3908,3978,"Come on, come on."],[3978,4087,"Come on, what are you doing?"],[4362,4462,"It's okay, Miles."],[4621,4725,"Get out of here, old man."],[4775,4863,"Leave him alone."],[4863,4904,"Will you just-"],[4904,4971,"Ah!"],[5580,5701,"You shouldn't have done that."]],"15":[[33,175,"You shouldn't have done that."],[1710,1822,"Who the fuck are you?"],[1939,2027,"Think about it."],[2152,2198,"Why do you think"],[2198,2302,"Butch and his little bitches"],[2302,2394,"were so eager to feed me"],[2394,2498,"to the wolves, huh?"],[3078,3148,"It's because I'm a threat"],[3148,3290,"to their whole operation."],[3411,3561,"I'm here to help you guys."],[3887,4029,"Unless you hurt someone else."],[4245,4333,"Any questions?"],[4571,4637,"Get him."],[4700,4754,"Fuck."]],"16":[[104,171,"Get him."],[233,287,"Fuck."],[1368,1472,"Damn it!"],[1472,1597,"I don't wanna hurt you guys."],[2452,2548,"Who wants some?"],[2577,2665,"What the fuck?"],[2665,2815,"What fucking gang are you in?"],[2819,2857,"Wait!"],[2873,2915,"Wait."],[3286,3374,"Alright, here's the deal."],[3445,3553,"I can't take all of you at once,"],[3553,3628,"but I sure as hell"],[3628,3791,"will take a bunch of you down with me."],[3803,3874,"Or..."],[3987,4070,"you let me prove to you"],[4070,4220,"who I am and why I'm here."],[4758,4817,"Alright."],[5159,5238,"Who's hungry?"]],"17":[[12,83,"Alright."],[179,241,"Who's hungry?"],[554,650,"So, you're tellin' us"],[650,804,"you can open this door?"],[1113,1317,"That son of a bitch Butch was right."],[1347,1526,"You're fucked in the head."],[1572,1680,"There's an override code"],[1680,1835,"to most of the locks in the building."],[1893,1976,"Can't get you outside,"],[1976,2139,"but buffet and the kitchen, no problem."],[2177,2373,"And how would you know those codes?"],[2573,2702,"Because I own the place."],[2894,3003,"If you're lying to us"],[3003,3165,"and you can't open this door,"],[3215,3332,"you're fucking dead."],[3495,3611,"This better work, Dad."],[5847,5943,"Lunch is on me."]],"18":[[316,412,"Lunch is on me."],[938,1151,"This only proved one thing."],[1230,1317,"And it ain't"],[1338,1484,"that you're the owner"],[1484,1605,"of this hell hole."],[1693,1835,"What the fuck are you talking about?"],[2060,2248,"It proved Butch right."],[2327,2469,"You're a snitch."],[2519,2694,"How did you get that code?"],[2765,2898,"Who sent you?"],[2911,3082,"Who'd you narc on?"],[3082,3236,"You rat-ass bitch."],[3486,3549,"Kill him!"],[5864,5910,"Hey,"],[5930,5985,"Jimmy."],[6072,6193,"Let's fucking go!"],[7528,7590,"Who are you?"],[7770,7820,"I'm..."],[8045,8091,"Ah."]],"19":[[58,108,"I'm..."],[225,296,"Oh no."],[475,517,"Hey."],[583,633,"Damn it."],[684,754,"Nadia!"],[775,875,"I need help in here."],[988,1042,"Oh my god."],[1067,1151,"Get him up, please."],[1514,1630,"He's losing a lot of blood."],[1647,1789,"We're gonna need to do a transfusion."],[1872,1918,"Hey."],[1964,2077,"Hey, stay with me."],[2122,2293,"Two units of O Negative, stat."],[2293,2364,"Yes, doctor."],[4358,4433,"Well, hi there."],[4517,4658,"You sure did give us quite a scare."],[4683,4725,"Uh."],[4783,4821,"Thank you."],[4821,4909,"How long have I been up?"],[4942,5038,"A couple hours."],[5038,5146,"Dr. Reyes stitched you back up"],[5146,5226,"when she left."],[5267,5380,"Hi, I'm Nadia."],[5397,5501,"I'm the night shift nurse."],[5755,5855,"I need an operation,"],[5855,5989,"but it keeps getting cancelled."],[6089,6151,"Does Dr. Reyes"],[6151,6272,"always work in this prison?"],[6314,6506,"Yeah, she's the doctor in residence."],[6506,6573,"Why?"],[6694,6840,"Could the doctor be in on it?"],[6856,6969,"You ever notice anything weird"],[6969,7044,"going on here?"],[7102,7219,"Like inmates not getting the help"],[7219,7294,"that they need?"],[7403,7474,"Actually,"],[7511,7557,"yeah."],[7557,7691,"Something kind of shady"],[7691,7811,"has been going on recently."],[7811,7895,"Dr. Reyes has-"],[7895,7966,"Search the room."],[8149,8195,"I gotta hide."],[8195,8316,"You can't tell them that I'm here."],[8341,8379,"Why?"],[8400,8491,"They're trying to kill me."],[8512,8596,"What did you do?"],[8679,8754,"Look Nadia, I know that"],[8754,8863,"this is hard to believe,"],[8863,8988,"but I'm not a prisoner."],[9096,9242,"I'm the owner of this prison."]],"20":[[0,145,"I'm the owner of this prison."],[321,442,"Okay, you lost a lot of blood."],[442,508,"You're not making sense."],[508,571,"Think about it."],[588,709,"How do you think I got in here?"],[759,855,"An inmate just shows up"],[855,996,"to a restricted part of the prison."],[996,1163,"No guard, no escort, no paperwork?"],[1163,1272,"Check the infirmary!"],[1272,1334,"Nadia,"],[1334,1438,"people are dying."],[1438,1597,"People who are on your watch."],[1659,1722,"Look, I don't know"],[1722,1822,"what deal Dr. Reyes has"],[1822,1868,"with the Roberts,"],[1868,1960,"but if I don't stop this,"],[1960,2077,"more people are gonna die."],[2210,2252,"Come with me."],[2281,2331,"Quick."],[2469,2506,"Hurry."],[2540,2623,"Quick, get behind here"],[2623,2719,"and don't make a sound"],[2719,2806,"no matter what."],[2827,2994,"No matter what."],[3019,3053,"Go."],[3420,3495,"Where is he?"],[3599,3636,"Who?"],[3636,3791,"I don't know what you're talking about."],[3849,3978,"The escaped prisoner."],[4008,4137,"Where is he?"],[4137,4241,"I don't..."],[4295,4346,"know!"],[4346,4425,"Tell me where he is!"],[4425,4508,"You're lying! - Let"],[4508,4587,"go of me!"],[4625,4725,"If I go out there,"],[4783,4888,"I'll get her in more trouble,"],[4888,4929,"but..."],[5017,5155,"I can't just let him hurt her."]],"21":[[45,112,"Tell me where he is!"],[112,183,"You're lying!"],[204,300,"Get off me!"],[688,759,"You're lying."],[759,834,"I'm not."],[2268,2431,"Colton, we need help in Cell Block B."],[2489,2565,"I'm on my way."],[3332,3386,"I..."],[3520,3595,"I, I..."],[3636,3737,"I thought he was going to-"],[3737,3803,"Shh."],[3853,3908,"I know."],[3995,4041,"It's okay."],[4104,4295,"If you're really the owner,"],[4295,4504,"then why are you here?"],[4562,4675,"It's a long story."],[4717,4775,"Well."],[4884,5105,"In that case, I think"],[5105,5280,"I'm going to need some medicine."],[5326,5380,"Medicine?"],[5426,5484,"For what?"]],"22":[[425,458,"Shh..."],[575,667,"It's contraband."],[1134,1217,"So you're saying the guards"],[1217,1347,"are keeping the prisoners in here"],[1347,1455,"longer than they need,"],[1476,1597,"denying them health care,"],[1597,1668,"and keeping the money"],[1668,1764,"for themselves?"],[1814,1868,"Yeah."],[1943,2085,"And you think Dr. Reyes"],[2085,2177,"might be in on it?"],[2256,2327,"Makes sense."],[2389,2444,"It's gotta be someone"],[2444,2577,"helping them fix the numbers."],[2773,2907,"I gotta put a stop to this."],[3157,3253,"So you really care about"],[3253,3365,"the inmates, huh?"],[3557,3737,"They're just humans who made mistakes."],[3841,3949,"They don't deserve this."],[4124,4208,"Sounds like something"],[4208,4295,"the owner would say."],[4558,4633,"A good one."],[4713,4754,"I mean..."],[4800,4896,"I just can't believe it."],[5013,5150,"You got all this money, and yet"],[5192,5342,"you're the one risking your life."],[5476,5593,"Yeah, well, it won't mean anything"],[5593,5722,"until I can get out of here."],[5805,5876,"Well..."],[5989,6231,"You're not going anywhere tonight."],[6439,6569,"Nurse's orders."]],"23":[[200,321,"Nurse's orders."],[575,642,"So..."],[688,834,"what should we do until the morning?"],[2035,2152,"They can come back."],[2173,2223,"Well,"],[2223,2348,"so we'll have to be quick then,"],[2348,2394,"won't we?"],[6664,6731,"Nadia."]],"24":[[446,496,"Hey."],[1142,1205,"Hi."],[1551,1651,"So did he buy it?"],[1697,1760,"Yeah."],[1760,1835,"He thinks I'm gonna help him"],[1835,1947,"break out tomorrow."],[2135,2260,"Get him outside the gates."],[2306,2427,"The camera is gonna record us"],[2427,2506,"shooting a prisoner"],[2506,2594,"trying to escape."],[2640,2727,"And..."],[2727,2961,"He's not really the owner, right?"],[3032,3128,"She'll probably freak out"],[3128,3269,"if she knows the truth."],[3395,3486,"Don't be stupid."],[3486,3591,"Of course he isn't."],[3628,3741,"He's just some stupid snitch"],[3741,3870,"who thinks we'll get a reduced sentence,"],[3870,3953,"if he turns us in."],[3974,4070,"Now go rest up."],[4091,4166,"Also..."],[4287,4337,"Dr. Reyes"],[4337,4475,"is beginning to get suspicious about"],[4475,4629,"how quiet the infirmary has been."],[4688,4825,"We may need to deal with her soon."],[4909,5042,"One problem at a time."],[5067,5150,"You sure he'll come?"],[5192,5280,"Oh, he'll come."],[5326,5534,"I have him in the palm of my hand."],[5618,5801,"How'd you get him to trust you so fast?"],[5847,5901,"Oh,"],[5947,6047,"are you jealous?"],[6235,6335,"Did you fuck him?"],[6356,6464,"Don't be crazy."],[6552,6660,"I'd never do that."],[6710,6848,"No matter how hot he is."],[7540,7774,"I can't wait to kill that son of bitch."]],"25":[[70,104,"Come on,"],[104,179,"wake up, wake up."],[225,346,"We gotta go before Reyes gets here."],[442,487,"Okay,"],[546,650,"here's how we do this."],[763,834,"I'll hide you"],[834,988,"in outgoing medical supplies."],[1568,1655,"When we stop moving,"],[1701,1776,"that means we've reached"],[1776,1885,"the parking structure."],[1947,2110,"It'll be a totally safe space."],[2281,2439,"Free of guards and cameras."],[2602,2711,"You can come out at that moment,"],[2711,2811,"and I'll pull the car around."],[3053,3103,"Sound good?"],[3449,3507,"I like it."],[4091,4145,"Let's go."]],"26":[[1522,1618,"Come on, now."],[17