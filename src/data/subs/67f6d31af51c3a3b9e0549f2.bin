,"Yeah, I'm just a snitch, Colton."],[3165,3215,"Shoot me."],[3278,3524,"Then erase all three cameras."],[3737,3862,"Start walking outside."],[3895,3962,"Now!"],[4024,4116,"He lied to you."],[4116,4258,"I am the owner of this prison."],[4383,4429,"Colton!"],[4479,4562,"Is he serious?"],[4562,4600,"What-"],[4600,4738,"I'd recommend getting out of town."],[4800,4904,"What did you get me into?"],[4904,5005,"Shut the fuck up!"],[5263,5359,"You stupid..."],[5509,5551,"Damn it!"],[5563,5643,"You stupid, worthless"],[5643,5722,"piece of shit!"],[5947,6031,"And by the way..."],[6081,6206,"I did fuck him."],[6206,6306,"And he's so,"],[6339,6398,"so..."],[6423,6548,"much better than you."],[6906,7007,"You fucking bitch!"]],"29":[[1334,1401,"Look, I..."],[1401,1505,"I told you. I..."],[1505,1597,"I have not"],[1597,1726,"contacted my lawyer."],[1726,1856,"I haven't done anything."],[1926,1985,"I told you."],[1985,2081,"I, I haven't"],[2143,2231,"talked to anyone."],[2460,2498,"Ah!"],[3003,3094,"Attention,"],[3094,3278,"Inmate 326."],[3299,3490,"Someone wants to tell you something."],[3528,3591,"Please stop,"],[3591,3657,"just stop!"],[3678,3770,"God, stop!"],[3770,3849,"Stop!"],[3878,3937,"Stop!"],[4012,4108,"Leave me alone."],[4179,4275,"You have ten minutes"],[4275,4387,"to return to your cell."],[4387,4458,"The next message"],[4458,4650,"will be much, much worse."]],"30":[[316,454,"Looks like it's been ten minutes."],[600,696,"Sorry, Miles."],[859,988,"Not your lucky day."],[1176,1230,"Wait!"],[1518,1589,"I'm here."],[1751,1822,"Let him go."],[2243,2327,"You okay?"],[4454,4592,"This doesn't end well for you."],[4592,4679,"Oh, yeah?"],[4817,4917,"You're the one handcuffed"],[4917,4984,"to a chair."],[5071,5138,"See,"],[5171,5267,"we have a problem."],[5321,5434,"You fucked my girl."],[5597,5726,"So I'm gonna make this hurt."],[6289,6385,"It should be..."],[6685,6856,"electrifying."]],"31":[[1146,1351,"Normally, when you torture someone,"],[1376,1526,"you're trying to get information."],[1609,1718,"But for you,"],[1793,1964,"I just wanna make you scream."],[2302,2373,"Focus."],[2406,2510,"There's a way out of here."],[2577,2690,"I just need to find it."],[2790,2936,"I'm handcuffed to the chair,"],[2936,3057,"but my legs are free."],[3103,3265,"Even if I could somehow break free,"],[3290,3386,"Colton is armed."],[3549,3649,"Stop it!"],[4233,4295,"You're were supposed"],[4295,4400,"to let him go."],[4466,4512,"Yeah,"],[4650,4742,"not gonna happen."],[4879,5088,"Wrong fucking answer."]],"32":[[112,300,"Wrong fucking answer."],[529,617,"Hey, dumb fuck."],[671,779,"Those are carbon steel."],[800,1021,"Yeah, but the chair is cheap wood."],[4029,4141,"Relax, princess."],[4191,4320,"I didn't puncture any organs."],[4512,4612,"I'm gonna kill you."],[4688,4846,"Save your energy for the crawl."],[5100,5171,"You okay?"],[5342,5476,"Come on, let's get you to a doctor."],[5659,5755,"Come on!"]],"33":[[150,229,"You got this."],[304,429,"I, I, I need a break."],[429,538,"Okay, okay, okay."],[1021,1180,"You really own this place?"],[1255,1326,"Yeah."],[1363,1526,"Yeah, ever since my father passed."],[1785,1881,"Sorry about that."],[1926,2039,"Yeah, we..."],[2122,2177,"we had a"],[2177,2302,"complicated relationship."],[2302,2385,"We didn't talk much"],[2385,2510,"the last couple years."],[2761,2840,"That happens."],[3028,3136,"Can you do me a favor?"],[3236,3324,"When you get out of here,"],[3324,3495,"can you check up on my son?"],[3645,3766,"His name is Charlie."],[3949,4058,"He's about your age."],[4058,4120,"Um..."],[4254,4396,"He stopped coming to see me"],[4396,4487,"a couple years ago."],[4575,4738,"It's not his fault, though, because..."],[4909,5025,"I kept telling him"],[5025,5163,"I'd be out soon,"],[5226,5326,"but the, um."],[5538,5730,"Yeah, but the parole never came."],[5922,6064,"What are you in here for, Miles?"]],"34":[[241,450,"I used to have a problem"],[529,658,"with the drink."],[784,975,"I hit a father of three."],[1146,1280,"Vehicular manslaughter,"],[1305,1384,"and, uh..."],[1505,1693,"My God, that was thirty years ago."],[1897,2093,"I haven't touched a drop since, so..."],[2268,2406,"So do me a favor, will you?"],[2585,2731,"You go check up on my son?"],[2882,3003,"You can check up on him yourself."],[3003,3115,"I'm gonna get you out of here."],[3190,3274,"Come on, let's go."],[3274,3349,"We're almost there."],[3465,3553,"Come on, you got this."],[3824,3937,"Come on, you got this."],[3991,4041,"Here we go."],[4320,4412,"How rich are you?"],[4471,4575,"Rich enough to get you"],[4575,4675,"an expensive wheelchair"],[4675,4758,"when we get out of here."],[4758,4800,"Ah."],[4800,4850,"Ah! - Oh."],[4875,4988,"Shit, that was dumb, sorry."],[5030,5105,"Hang in there, come on."]],"35":[[112,225,"I need some help over here."],[342,417,"Put him on the bed."],[646,754,"Easy, easy."],[754,804,"Fuck."],[804,850,"Easy."],[892,971,"What happened?"],[1013,1084,"He was beaten..."],[1121,1172,"bad."],[1322,1488,"Go, wait over there, please."],[1651,1747,"Wait over there."],[1747,1789,"Okay."],[1789,1901,"It will be okay. - Okay."],[1972,2114,"Lower, lower, lower. - Sir,"],[2114,2214,"it hurts if I press here?"],[2214,2268,"Mmm."],[2268,2360,"And what about here?"],[3015,3069,"How is he?"],[3123,3253,"He's bruised up pretty badly."],[3307,3457,"Major contusion to the skull."],[3524,3620,"No internal bleeding."],[3670,3707,"So,"],[3774,3853,"he's gonna be okay."],[3920,3987,"Good."],[3987,4116,"I'm glad you brought him when you did."],[4262,4329,"Also, he was supposed to"],[4329,4533,"have surgery for a perforated ulcer."],[4550,4612,"What?"],[4771,4892,"His file indicated"],[4892,5034,"he already had the procedure done."],[5288,5342,"Poor man."],[5480,5613,"He must be in a lot of pain."],[5759,5943,"So she's not in on the scam."],[6131,6335,"How did you just walk in here?"]],"36":[[25,200,"Well, the owner of the prison"],[200,316,"has an override code"],[316,462,"for all the doors within the building."],[475,550,"Right."],[583,729,"So how did you get that code?"],[804,925,"I know you're not the owner."],[1030,1117,"Well, actually-"],[1117,1205,"Heartless bastard."],[1359,1476,"The owner is responsible"],[1476,1668,"for everything that is going wrong here."],[1735,1810,"Do you see him?"],[2252,2335,"What the fuck?"],[2348,2444,"I'm so sorry."],[2485,2656,"He has his parole hearing today."],[2740,2886,"Almost guaranteed release."],[3053,3261,"The guards beat him up so badly,"],[3557,3678,"that he won't be able to make it."],[3895,4074,"He's worth too much money on the inside."],[4212,4312,"And you're sure that the owner"],[4312,4450,"is the one responsible for this?"],[4487,4646,"It always starts at the top."],[4754,4892,"I've been compiling evidence"],[4892,4988,"against them to..."],[5184,5309,"I should not be telling you this."],[5347,5451,"If I tell her the truth,"],[5451,5605,"there's no way she'll trust me."],[5647,5772,"How did you get the code?"],[5855,5930,"Who are you?"]],"37":[[20,100,"Who are you?"],[200,279,"Look, I'm just someone"],[279,425,"that's trying to make things right."],[813,930,"Look, I have an idea."],[930,1005,"But if you help me,"],[1005,1117,"you could be in danger."],[2210,2431,"We're here to pick up Inmate 392"],[2431,2594,"and take him to his parole hearing."],[2748,2781,"But,"],[2836,2965,"if he's not well enough to atte-"],[2965,3036,"No."],[3036,3219,"He made a miraculous recovery."],[3261,3319,"What?"],[3395,3482,"He's all good to go."],[3670,3732,"Okay."],[3812,3899,"All right, get him up."],[4104,4233,"Let's get this over with."],[4350,4425,"Be careful."]],"38":[[1655,1739,"If I can get in front of"],[1739,1830,"that parole board,"],[1830,2002,"I can end all of this right now."],[2002,2056,"How?"],[2135,2268,"You're just gonna have to trust me."],[2398,2460,"Listen."],[2540,2644,"If you know something,"],[2644,2761,"you need to tell me."],[2819,2948,"I can get the U.S. Marshals here-"],[2948,3069,"By the time that they get here,"],[306