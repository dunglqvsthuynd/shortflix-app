ell."],[3874,4016,"Just contact John Parker,"],[4016,4145,"CEO of Poe Industries,"],[4145,4250,"he'll explain everything."],[4291,4346,"We'll do that."],[4400,4466,"Right now."]],"41":[[12,83,"We'll do that."],[137,208,"Right now."],[271,337,"Or..."],[442,608,"There is a much easier way"],[608,842,"to find out if this is really Troy Poe"],[888,1063,"without making us look like fools"],[1063,1155,"if he's lying."],[1355,1576,"We just look up Troy Poe online"],[1622,1730,"and see who pops up."],[1793,1943,"Look, you're not gonna find anything."],[1989,2122,"I spent the last ten years"],[2122,2231,"in the Marine Special Ops,"],[2231,2327,"I've been scrubbed clean"],[2327,2389,"from the internet."],[2389,2615,"But if you call John Parker, then..."],[2777,3023,"I, I think Mr. Navy Seal"],[3048,3199,"Government Secret Agent here"],[3199,3328,"is just proving my point."],[3353,3532,"Just call John Parker."],[3557,3699,"He'll explain everything, just-"],[3699,3795,"Guards, grab him."],[4233,4291,"Call him!"],[4429,4475,"Go."]],"42":[[1447,1618,"They had to take my son out of here"],[1618,1755,"using a helicopter."],[1755,1872,"Oh no, what happened?"],[1976,2077,"You son of a bitch!"],[2193,2306,"You know, the only reason"],[2306,2473,"why you're still alive, Poe,"],[2473,2556,"is because the board"],[2556,2744,"might want to call you back inside."],[2790,2890,"But when they're gone,"],[2952,3036,"you're dead!"],[3073,3219,"And I'm not gonna lie to you, Poe."],[3332,3524,"It's really gonna hurt."]],"43":[[367,429,"This is it,"],[471,525,"they're coming."],[625,734,"Go out strong,"],[746,842,"and take as many down"],[842,942,"with you as you can."],[1822,1856,"Just-"],[1956,2072,"I know what you did."],[2093,2210,"You dumb bitch."],[2310,2389,"Be careful."],[2498,2619,"If you ever"],[2673,2823,"pull a trick like that again,"],[3011,3103,"you're dead."],[3253,3307,"Come on."],[3357,3453,"We don't have much time."],[4033,4216,"I couldn't let them just kill you."],[4304,4391,"Though you still won't tell me"],[4391,4487,"who you really are."],[4567,4654,"Tell you what, I'll tell you"],[4654,4779,"when we're safely out of here."],[4808,4884,"Why not now?"],[4884,4942,"Because right now,"],[4942,5034,"I need you to trust me."],[5034,5155,"And I won't if you tell me?"],[5196,5301,"What are you, mafia?"],[5301,5438,"Some cartel hitman?"],[5480,5559,"Hands up!"]],"44":[[0,100,"What are you, mafia?"],[100,233,"Some cartel hitman?"],[266,350,"Hands up!"],[796,842,"All good."],[896,967,"I'm the doctor."],[992,1142,"I know who you are, bitch."],[1176,1343,"Now shut the fuck up before I shoot."],[1376,1455,"Leave her out of this,"],[1455,1526,"or I'm gonna break your fu-"],[1526,1634,"Or what?"],[1747,1939,"You think I give a fuck about you?"],[1985,2139,"Just because you own the prison?"],[2385,2502,"Guess who I found."],[2556,2677,"You own the prison?"],[2902,3028,"I said shut the fuck up!"],[3632,3691,"Stop!"],[3732,3782,"Stop!"],[3799,3841,"Stop."],[3903,3962,"Stop."],[4091,4170,"You will kill him."]],"45":[[91,137,"Stop!"],[179,229,"Stop!"],[246,287,"Stop."],[412,479,"You're gonna kill him."],[804,905,"We need to go now."],[967,1046,"Go to the infirmary,"],[1046,1130,"lock yourself in there,"],[1130,1284,"and don't open the door for anyone."],[1326,1455,"I'll come get you when it's safe."],[1522,1680,"So you're responsible for this place."],[1743,1839,"This is your fault."],[1860,1914,"Um..."],[2060,2223,"I'm trying to make things right, okay?"],[2377,2448,"Now go."],[2656,2715,"What about you?"],[2786,2886,"I'll be fine."],[2998,3082,"You'll need this."],[3482,3574,"Dr. Reyes."],[3737,3841,"Thank you for saving me."],[3962,4004,"Go."],[4200,4258,"Okay."],[4258,4375,"What do I do now?"],[4725,4850,"You look about my size."],[5438,5547,"You know..."],[5726,5901,"stealing a guard's remote"],[5964,6060,"is a crime."],[6435,6510,"No!"],[6535,6644,"Ah!"]],"46":[[8,116,"I'm on my way, I'm on my way."],[1488,1564,"So..."],[1672,1739,"Are you crooked too,"],[1739,1881,"or just completely incompetent?"],[1951,2006,"What?"],[2031,2093,"You heard me."],[2127,2256,"Are they cutting you in on all this?"],[2431,2527,"Who the hell are you?"],[2932,3019,"I'm your boss."],[4091,4137,"Hey, you know,"],[4137,4312,"I got a real busy day, Warden."],[4354,4458,"What can I help you..."]],"47":[[8,158,"What the hell is he doing here?"],[271,471,"Butch, this young man claims"],[471,625,"he's the owner of this prison."],[684,838,"This young man is insane."],[875,950,"He's dangerous."],[963,1005,"He's..."],[1005,1138,"he's responsible for the riots"],[1138,1317,"that nearly killed my son, Colton."],[1334,1484,"He doesn't seem insane to me."],[1564,1730,"He's manipulating you."],[1810,1964,"Let me take him back to his cell."],[1981,2014,"Try."],[2031,2147,"That's not necessary."],[2302,2431,"This man more than likely"],[2431,2606,"killed a guard and took his uniform."],[2606,2698,"No, I didn't kill him."],[2761,2852,"I just knocked him out."],[2894,2944,"You see?"],[2965,3119,"He's a violent criminal."],[3144,3215,"Take two more steps,"],[3215,3395,"and let me show you how violent I am."],[3511,3574,"Enough."],[3632,3732,"There's only one person"],[3732,3858,"that can tell me what's going on here,"],[3858,3987,"and it's not either of you."],[4041,4129,"Warden, there's someone at"],[4129,4208,"the door for you."],[4383,4441,"Perfect."],[4471,4533,"Send him in."]],"48":[[688,779,"Hey, Troy, man..."],[888,996,"Sorry about your dad."],[1051,1142,"He was a good guy."],[1226,1280,"Yeah."],[1468,1580,"You know, my dad and I"],[1580,1751,"didn't always see eye to eye, but..."],[1801,1910,"This is my company now,"],[1910,1964,"and I'm gonna start"],[1964,2093,"by making some improvements."],[2139,2277,"Starting with Southgate Prison."],[2335,2477,"Improve Southgate?"],[2502,2573,"Yeah."],[2590,2723,"But you and your dad didn't"],[2723,2848,"talk for a year..."],[2873,3011,"when you found out that he was investing"],[3011,3140,"in the private prison industry."],[3157,3257,"You hate Southgate."],[3274,3336,"I do."],[3390,3470,"I hate the idea of"],[3470,3586,"getting government contracts"],[3586,3691,"to house prisoners."],[3753,3920,"And I hate how easy it is to turn a,"],[3920,4070,"what's supposed to be a rehabilitation"],[4070,4187,"into a cash grab."],[4233,4354,"But most importantly,"],[4387,4562,"I hate that the prison I now own"],[4562,4658,"is one of the worst."],[4688,4813,"Look, inmates are staying in longer"],[4813,4900,"than they're supposed to."],[4900,5055,"Paroles are being denied"],[5055,5130,"left and right."],[5159,5234,"And the death rates"],[5234,5330,"are through the roof."],[5447,5559,"So why not just sell?"],[5630,5843,"So the next owner can turn a blind eye?"],[5939,6185,"Come on, this is my responsibility now."],[6247,6327,"And I'm gonna find out"],[6327,6393,"what's happening."],[6464,6560,"How are you gonna do that?"]],"49":[[41,125,"How are you gonna do that?"],[792,855,"No."],[884,930,"No!"],[1001,1134,"You going undercover"],[1134,1226,"as a prisoner"],[1226,1334,"is too risky."],[1334,1438,"Well, that's too bad."],[1518,1643,"Cause I think I hear my ride."],[2139,2218,"Troy Poe?"],[2352,2494,"You're under arrest for murder."],[2548,2606,"Wait."],[2673,2748,"Murder?"],[2786,2857,"Might as well give"],[2857,2969,"myself some street cred."],[3190,3303,"And you're okay with this?"],[3324,3424,"Well, hey, I already told him"],[3424,3582,"I thought this was a bad idea."],[3645,3774,"But he's the boss."],[3866,3966,"I sure hope you know"],[3966,4062,"what you're doing, son."],[4137,4250,"Just give us a sec, okay?"],[4475,4529,"Hey."],[4729,4838,"It's just a couple of weeks."],[4984,5071,"What could go wrong?"],[5288,5367,"Wait, wait."]],"50":[[250,387,"How do I check up on you"],[412,529,"without blowing your cover?"],[600,675,"If you do feel the need"],[675,750,"to check in on me,"],[750,905,"just ask me what I'm in for."],[959,1021,"If I say murder,"],[1021,1146,"that means I need to get out."],[1180,1259,"If I say"],[1355,1472,"something I didn't do,"],[1472,1559,"that means I'm okay,"],[1559,1664,"and I need more time."],[1901,2018,"Hi, Mr. Parker."],[2068,2193,"I'm so glad you're here."],[2214,2373,"How was your transport"],[2373,2448,"to the prison?"],[2515,2590,"Slept the whole way."],[2615,2648,"Huh?"],[2648,2731,"Ask my chauffeur."],[2731,2769,"Hm."],[2806,2886,"As well as you could."],[3094,3328,"You call him off, or the girl dies."],[3403,3532,"It won't be painless."],[3999,4066,"Is this him?"],[4099,4133,"Yeah."],[4429,4521,"So the warden tells me"],[4521,4721,"that you're actually a prisoner."],[4842,4954,"What are you in for?"],[5092,5196,"Something I didn't do."]],"51":[[158,279,"Something I didn't do."],[412,492,"Are you sure?"],[538,583,"Yeah."],[734,817,"I'm in here for"],[817,913,"something I didn't do."],[1071,1130,"Warden,"],[1272,1368,"I've never seen this man"],[1368,1476,"before in my life."],[1526,1630,"I figured so."],[1722,1780,"I just wanted to make sure"],[1780,1876,"to double-check."],[1931,2014,"I'm glad you did."],[2264,2348,"Be safe in here."],[3007,3057,"Well?"],[3128,3282,"What do you gotta say for yourself?"],[3445,3578,"Don't worry about it, Warden."],[3641,3749,"I'll make sure he never"],[3749,3953,"pulls a stunt like this again."],[4041,4162,"Get him out of my sight."],[4479,4529,"Butch."],[4629,4713,"I'm not stupid."],[4767,4913,"I know you have businesses in here."],[5000,5109,"And if he's any part of it,"],[5134,5259,"he needs to disappear."],[5259,5334,"Now."],[5889,6047,"Are you ready to die?"]],"52":[[930,1084,"Twenty meters to the end of the hall."],[1109,1226,"On the other side of that door"],[1226,1284,"will be guards."],[1284,1368,"That gives me roughly"],[1368,1526,"twenty five steps to escape."],[1714,1860,"His hand is resting on his gun holster,"],[1860,2027,"leaving the left side of his head open."],[2081,2239,"A shot to the temple would drop him."],[2469,2548,"But then what?"],[2648,2727,"Freeze!"],[2727,2873,"Put your hands on your head!"],[2977,3148,"A gunfight would lead to deaths,"],[3148,3286,"including, most likely, mine."],[3353,3470,"Mace would be insufficient"],[3470,3574,"against firearms."],[3611,3707,"Leaving..."],[3883,3937,"Perfect."],[3978,4024,"What?"],[4621,4742,"Five steps to the door."],[4758,4854,"And then another ten meters"],[4854,5000,"to get out of the blast radius."]],"54":[[913,959,"Butch?"],[1026,1176,"I heard a gunshot, you okay?"],[1438,1543,"Shut the hell up."],[1655,1730,"Butch?"],[1760,1851,"Butch, you there?"],[1889,2031,"Butch is taking a nap."],[2414,2510,"Come on out, buddy."],[2961,3069,"Be a man."],[3261,3432,"Maybe then we'll let the girl go."],[3987,4120,"You came all the way back down here"],[4120,4204,"just to die."],[4254,4437,"Well, actually, I came back to free her."],[4792,4884,"Looks like I'm too late."]],"55":[[196,262,"You okay?"],[375,446,"Yeah."],[446,508,"Here."],[750,825,"Okay, look."],[825,950,"I'm sorry that I didn't tell you"],[950,1030,"who I really was."],[1030,1076,"But right now,"],[1076,1217,"I need you to trust me, because..."],[1255,1438,"What we're about to do is crazy."],[1530,1593,"So,"],[1659,1739,"where is he?"],[1797,1951,"My men are hunting him down now."],[1985,2164,"We've turned off all the remote locks."],[2185,2335,"Now each door has to be opened"],[2335,2444,"physically with a key."],[2444,2548,"We need to take this one"],[2548,2719,"to the hospital for observation."],[2898,3032,"Escort them down to Steven,"],[3032,3148,"have Steven let them out."],[3148,3199,"Yes, Sir."],[3261,3382,"Where is Dr. Reyes?"],[3415,3586,"She should be assisting in all this."],[3616,3732,"She's in the infirmary,"],[3770,3874,"but I believe she's feeling"],[3874,3995,"a bit under the weather, Sir."],[4033,4158,"Great day to be sick."],[4183,4421,"I'm glad you brought in outside EMTs."],[4508,4554,"What?"],[4604,4779,"I thought you brought in the EMTs."],[5080,5142,"Mother f-"],[5196,5296,"Stop them!"]],"56":[[166,321,"It's good that you got here so quickly."],[367,575,"Yeah, well, the hospital's nearby."],[638,754,"Ah, well..."],[829,925,"What hospital is that?"],[1017,1151,"Come on, hurry up! - Come on!"],[1159,1247,"The other..."],[1288,1430,"set of keys are..."],[1430,1564,"gotta be here somewhere."],[1564,1693,"They're getting away!"],[1693,1793,"I'm looking for them,"],[1793,1885,"I'm looking for them!"],[1885,1989,"Hurry up! - God damn it..."],[2022,2106,"I got them!"],[2118,2306,"Oh, it's relatively close."],[2352,2489,"Oh, okay, gotcha."],[2852,2902,"Come on, go."],[2902,2952,"Come on!"],[2952,3048,"Shut up!"],[3123,3157,"Go."],[3632,3687,"Uh."],[3724,3858,"Property of Southgate Prison?"],[3912,4041,"Yeah, we..."],[4041,4133,"we bought a bunch of stuff"],[4133,4250,"from you guys a couple of years ago."],[4279,4421,"I still need to get it rebranded."],[4425,4504,"Oh."],[4504,4550,"Yeah."],[5142,5271,"I bet that'll scare the life"],[5271,5376,"into some of your patients."],[5497,5559,"Steven!"],[5593,5638,"Stop them!"],[5638,5809,"They're not real EMTs!"],[5939,5993,"What's that?"]],"57":[[4,79,"What's that?"],[79,133,"Huh?"],[133,229,"Hey, Steven?"],[296,362,"I'm sorry."],[375,433,"Oh!"],[442,533,"Come on, come on, come on, come on."],[704,759,"Which car is yours?"],[759,838,"It's on the right."],[871,1021,"Hurry it up, they're getting away."],[1021,1088,"Shut up!"],[1088,1209,"I need to concentrate!"],[1297,1376,"Come on, Butch."],[1376,1426,"Ow."],[1751,1893,"Hey, stop them!"],[2181,2260,"There they are!"],[2260,2339,"They're right there!"],[2761,2902,"Cease fire!"]],"58":[[187,275,"Spread out, fellas."],[308,362,"Spread out."],[1201,1267,"Oh, no."],[1334,1409,"Oh, no."],[1639,1705,"Damn it!"],[1772,1906,"They're still here!"],[2006,2064,"Okay men,"],[2064,2110,"Dammit!"],[2110,2198,"we're gonna follow strict"],[2198,2273,"protocol on this."],[2273,2364,"Oh, can that."],[2364,2477,"Listen, I need you to search"],[2477,2598,"every inch of this place."],[2598,2798,"Austin, go get your dogs."],[2798,2865,"Roger,"],[2865,3065,"you go get your snipers into position."],[3103,3261,"Kill them on sight!"],[3286,3424,"Go, go, go!"],[3499,3616,"They can't get away."],[3653,3757,"Everybody go!"],[3870,3941,"Let's go!"],[4104,4191,"All right, gentlemen."],[4191,4300,"Fan out."],[4300,4433,"I want you to check each and every room"],[4433,4529,"in this place."],[4529,4642,"No stone unturned."],[4671,4779,"Jackson, look in that vent"],[4779,4879,"when you get to the end."],[4921,5021,"This is important."],[5096,5171,"Find them."]],"59":[[950,1009,"Hey."],[1105,1167,"How'd you sleep?"],[1388,1497,"Surprisingly good."],[1847,1968,"I need to get home."],[1968,2193,"It's not safe for us to go out."],[2231,2293,"Not yet."],[2293,2448,"Just give me a couple more days."],[2569,2640,"Do you think that they"],[2640,2765,"figured out how we escaped?"],[2811,2873,"No."],[2969,3057,"I don't think they will."],[3478,3603,"So this is, uh..."],[3724,3828,"This is all yours?"],[3887,3987,"You're like a..."],[4087,4266,"multi-multi- millionaire?"],[4350,4466,"Switch the M with a B."]],"60":[[58,108,"Wow."],[191,233,"And..."],[291,408,"You voluntarily"],[442,575,"threw yourself in a prison cell?"],[613,721,"Look, what's happening there"],[721,784,"right now-"],[784,892,"It's not your fault."],[1030,1163,"But it's my responsibility"],[1163,1251,"to clean it up."],[1505,1630,"That's really noble of you."],[3353,3536,"You realize I just got out of prison, right?"],[3591,3641,"And?"],[3641,3837,"And you're currently driving me crazy."],[4225,4295,"Good."]],"61":[[1034,1130,"Get out of here."],[1313,1426,"I gotta change."],[1760,1814,"Go."],[2210,2281,"Keep walking."],[2635,2715,"Dinner tonight?"],[3140,3199,"Yeah."]],"62":[[137,233,"We've looked everywhere."],[283,454,"Searched every car, coming or going."],[483,617,"We've examined every camera."],[667,717,"Nothing."],[900,1063,"It's been almost twenty four hours."],[1151,1217,"Find them."],[1947,1997,"Warden,"],[2031,2127,"I need more men."],[2152,2260,"The bastard is still-"],[2260,2394,"Lead Guard Roberts,"],[2506,2631,"you remember our CEO?"],[2660,2740,"John Parker."],[2773,2865,"Of course."],[3003,3111,"It's good to see you."],[3136,3215,"Mr. Parker."],[3328,3449,"Always a pleasure, Butch."],[3553,3707,"Mr. Parker was just telling me"],[3707,3862,"about this year's Benefit Gala."],[3887,3941,"He wants to take"],[3941,4099,"a few model prisoners to it."],[4241,4304,"Prisoners..."],[4358,4487,"to a gala, sir?"],[4521,4633,"We're renewing our focus"],[4633,4767,"on rehabilitation."],[4846,4938,"I thought it'd be nice to"],[4971,5063,"show it in action."],[5096,5196,"Don't you agree, Warden?"],[5251,5317,"Of course."],[5422,5480,"That way,"],[5547,5718,"our benefactors can hear firsthand"],[5772,5918,"just how much we are helping"],[5972,6060,"our inmates."]],"63":[[354,412,"Hey."],[487,725,"Oh my God, you..."],[846,975,"You look great."],[1242,1372,"Oh, I'm gonna be so"],[1372,1476,"underdressed for dinner."],[1476,1655,"No, you won't."],[2002,2093,"Troy,"],[2168,2289,"this is gorgeous."],[2318,2394,"How did you-"],[2414,2556,"I sent a staff member out"],[2556,2635,"for it today."],[2961,3078,"Look, I'm sorry that our dinner"],[3078,3194,"is just gonna be here tonight,"],[3194,3361,"but it's still not safe to go out."],[3495,3616,"When will it be safe?"],[3653,3787,"Well, I put a plan in motion."],[3895,3987,"Just need you to trust me"],[3987,4104,"for a few more days."],[4412,4491,"Do you know..."],[4646,4717,"Do you know why"],[4717,4854,"I provide treatment at a prison?"]],"64":[[62,141,"It's because"],[141,287,"I believe that every person"],[362,508,"deserves the help they need."],[621,784,"Even the least of us."],[825,1021,"Even the ones that society"],[1021,1151,"thinks don't deserve it."],[1284,1468,"So whatever it is you're planning,"],[1605,1693,"I'm with you."],[1810,1864,"Okay."],[1985,2089,"Go get ready for dinner."],[2494,2602,"I like my dessert..."],[2802,2865,"before dinner."]],"65":[[120,271,"My personal best men"],[271,417,"will be escorting the prisoners"],[417,479,"to the Gala,"],[529,784,"including my recently recovered son."],[838,946,"How can you be so sure"],[946,1088,"the escapee won't show up?"],[1230,1363,"Because they never left the building."],[1434,1572,"There's just no way."],[1626,1718,"He's still in here."],[1785,1851,"Hiding."],[1926,2022,"My men will find him."],[2047,2127,"I hope you're right."],[2264,2427,"For the sake of both of our jobs."],[2744,2836,"Sir, sir."],[2882,2957,"We found him."],[2986,3094,"We found the escapee."],[3136,3207,"Where is he?"],[3407,3545,"Well, where is he?"],[3607,3770,"He's in a cell."],[3824,3891,"Just sitting there."]],"66":[[296,404,"Well, well."],[487,588,"Look who's back."],[633,742,"Where were you hiding?"],[742,934,"In some sewer drain someplace?"],[1026,1188,"I can't do it anymore, Butch."],[1368,1422,"You win."],[1472,1676,"I just want to know how you did it."],[1701,1785,"How'd you funnel away"],[1785,1922,"the prison's medical funds?"],[2060,2114,"Well,"],[2164,2302,"since you're gonna be dead soon,"],[2323,2435,"I don't mind telling you."],[2519,2598,"It was easy."],[2669,2848,"The warden turned a blind eye."],[2907,3019,"Nadia falsified"],[3019,3169,"all the medical documents."],[3224,3440,"And my team, led by my son,"],[3482,3678,"intimidated any of the prisoners"],[3678,3799,"that complained."],[3837,3970,"It was easy."]],"67":[[208,333,"You must have made hundreds of"],[333,454,"thousands of dollars."],[617,704,"Don't insult me."],[738,880,"Try millions, Troy."],[905,984,"Millions."],[1026,1117,"Enough money that,"],[1117,1272,"after I'm done killing you,"],[1326,1418,"I can retire"],[1418,1614,"to some nice tropical island"],[1614,1760,"for the rest of my life."],[1972,2102,"Any last words?"],[2243,2289,"Yeah."],[2965,3040,"You're not interested in"],[3040,3119,"where I've been?"],[3224,3361,"To be honest with you, Troy,"],[3432,3557,"I don't really give a shit."],[3632,3699,"Because I know"],[3699,3837,"you never left this prison."],[3933,4074,"And that's all that really matters."],[4108,4187,"And, how do you know that?"],[4187,4300,"Cause you never appeared on"],[4300,4371,"any of our"],[4371,4487,"surveillance cameras."],[4533,4683,"And every vehicle that left"],[4683,4829,"was thoroughly searched."],[5034,5150,"Not every vehicle."]],"68":[[342,450,"Not every vehicle."],[2243,2377,"I mean, who would dare search"],[2377,2502,"the Head Guard's vehicle?"],[2965,3090,"Thanks for the ride, by the way."],[3174,3290,"Son of a bitch!"]],"69":[[29,129,"Son of a bitch!"],[433,667,"Come on, this is the high security cell."],[738,825,"You know this glass is"],[825,913,"bulletproof, Butch."],[913,1051,"You think that's gonna save you?"],[1518,1597,"Code not working?"],[1639,1730,"What did you do?"],[1789,1901,"What did you do?"],[1931,2077,"While I was out, I took the time"],[2077,2248,"to reprogram our security system."],[2327,2435,"Including the cameras."],[2498,2602,"Smile, Butch."],[2602,2736,"I just got every single"],[2736,2857,"dirty word you said."],[2857,2907,"No."],[2965,3015,"No."],[3123,3186,"No."],[3261,3370,"Thanks for confessing."],[3370,3470,"You son of a bitch!"],[3470,3578,"I'm want to kill you!"],[3732,3878,"I'm gonna fucking kill you."],[3878,3995,"You're not gonna do anything."],[4066,4141,"It's over."],[4191,4312,"No, no."],[4362,4408,"No."],[4959,5125,"Put the gun down! Put the gun down!"],[5759,5897,"See you on the other side, kid."]],"70":[[204,333,"Alright, Maggots."],[358,450,"Listen up."],[492,654,"You're all gonna go out there"],[700,867,"and tell everyone"],[867,984,"what a wonderful place"],[984,1113,"Southgate Prison is."],[1151,1280,"If we hear..."],[1330,1426,"anything..."],[1501,1593,"different,"],[1697,1789,"I promise,"],[1897,2093,"they'll never find your bodies."],[2152,2318,"And that especially"],[2318,2464,"goes for you,"],[2510,2615,"old man."],[3061,3132,"Alright."],[3224,3349,"Move out, cattle."],[4804,4888,"Keep it moving."]],"71":[[1205,1301,"Ladies and gentlemen."],[1388,1426,"Please."],[1580,1651,"Welcome."],[1693,1818,"Thank you so much"],[1818,1981,"for attending this fundraiser"],[2014,2089,"to benefit"],[2089,2252,"our rehabilitation program."],[2356,2394,"Just-"],[2540,2585,"Thank you."],[2736,2823,"And thank you,"],[2894,3003,"to Warden Johnson,"],[3044,3128,"for joining us,"],[3165,3374,"and a special thank you,"],[3445,3628,"to the Southgate Prison doctor,"],[3628,3766,"Melissa Reyes."],[3883,3937,"Woo!"],[4029,4112,"Come on up here."],[4391,4496,"I thought she was sick."],[4700,4888,"I am very pleased to announce,"],[4904,5121,"that we are starting a brand new program,"],[5196,5292,"led by Melissa,"],[5392,5538,"to rehabilitate"],[5538,5764,"and improve prisoner medical conditions"],[5809,5910,"at Southgate,"],[6018,6210,"and all across the United States."],[6210,6272,"Yes!"],[6748,6906,"I had no idea this was happening-"],[6906,7007,"What a joke!"],[7032,7073,"Huh."],[7098,7228,"She's a con artist!"],[7240,7390,"She's been stealing from the prison"],[7390,7549,"and letting the prisoners die!"]],"72":[[8,158,"She's been stealing from the prison"],[158,287,"and letting the prisoners die!"],[287,337,"No."],[563,675,"What are you doing?"],[700,821,"Your dad paid me to come here,"],[821,959,"just in case she showed up."],[1309,1426,"This woman"],[1426,1664,"has been falsifying medical documents"],[1664,1776,"and embezzling money."],[1810,1856,"No."],[1889,2031,"No, it's, it's a lie!"],[2064,2110,"I..."],[2110,2239,"I would never do anything like that."],[2268,2394,"She's the con artist."],[2435,2510,"Please."],[2510,2673,"How could you watch them suffer"],[2673,2765,"and do nothing?"],[2765,2819,"Shut up!"],[2819,2982,"I have the entire prison management"],[2982,3090,"behind me as proof."],[3090,3161,"What do you have?"],[3207,3274,"Hm!"],[3274,3340,"Warden Johnson"],[3340,3553,"has been running an entire sting operation"],[3553,3666,"against you for months!"],[3695,3766,"Haven't you, Warden?"],[3795,3845,"Yes."],[3845,3949,"Guards, arrest her."],[3949,3995,"No."],[4079,4191,"No, I'm innocent!"],[4216,4291,"Troy will prove it"],[4291,4387,"when he gets here. - Troy?"],[4387,4466,"You mean the inmate"],[4466,4587,"who ran like a pussy?"],[4654,4742,"What's he gonna do?"],[5351,5463,"Touch her..."],[5463,5638,"and it's the last thing you'll do."],[5680,5755,"Who said that?"]],"73":[[742,909,"They shouldn't have let in criminals."],[938,1009,"Oh my God."],[1034,1105,"We're in danger."],[1155,1263,"Calm down, everybody."],[1451,1539,"I'm not a prisoner."],[1572,1655,"He's dangerous!"],[1693,1789,"I'm taking him out."],[1814,1906,"You're gonna have to go"],[1906,1997,"through this old man,"],[2039,2139,"and all these guys,"],[2139,2314,"in front of all these witnesses."],[2494,2598,"You're gonna have to shoot through me."],[2640,2702,"And me."],[2748,2794,"And me."],[2882,2998,"Even the prison guards won't"],[2998,3128,"start shooting the inmates."],[3128,3199,"That would be wrong."],[3199,3294,"There's no way!"],[3382,3495,"Ladies and gentlemen,"],[3536,3620,"I, I assure you,"],[3620,3691,"this is a..."],[3691,3858,"a sick stunt, orchestrated by"],[3912,3999,"Dr. Reyes,"],[4029,4091,"to cover up."],[4116,4225,"No one's gonna get shot."],[4225,4325,"Move or I'll shoot"],[4325,4429,"through you, old man."],[4429,4487,"Enough!"]],"74":[[8,75,"Enough!"]],"75":[[1322,1363,"Move!"],[1626,1668,"Move!"],[1668,1785,"Weapons on the ground!"],[3003,3169,"How, how is this..."],[3169,3257,"What's going on?"],[3307,3424,"I can't believe the amount of times"],[3424,3520,"I've had to say this."],[3620,3791,"But let me introduce myself."],[3895,4045,"My name is Troy Poe,"],[4045,4241,"and I am the owner of Southgate Prison."]],"76":[[100,283,"But let me introduce myself."],[375,525,"My name is Troy Poe,"],[525,725,"and I am the owner of Southgate Prison."],[1021,1117,"I went undercover to"],[1117,1284,"get to the bottom of its corruption."],[1363,1543,"And I've come to bring you to justice."],[1647,1726,"He's lying!"],[1780,1872,"Everything we've done"],[1872,1964,"has been for the,"],[1964,2072,"the good of our inmates."],[2072,2110,"Yeah."],[2110,2198,"Just because your daddy"],[2198,2268,"started this place"],[2268,2373,"doesn't mean you know exactly"],[2373,2435,"how it's run."],[2435,2510,"How did you funnel away"],[2510,2644,"the prison's medical funds?"],[2681,2798,"It was easy, Troy."],[2923,3098,"The warden took a blind eye."],[3186,3261,"We had Nadia"],[3261,3436,"falsify all the medical records."],[3520,3741,"And my own team, led by my son,"],[3832,3978,"intimidated any of the prisoners"],[3978,4066,"that complained."]],"77":[[16,91,"No way."],[129,254,"That's Butch Roberts."],[296,400,"He's the Head Guard."],[446,538,"He's corrupt?"],[558,700,"Isn't Colton his son?"],[763,829,"Then he's..."],[884,984,"He's a criminal!"],[1059,1176,"Someone arrest him."],[1330,1413,"It's over, Son."],[1518,1639,"That's what you think."],[2127,2264,"Someone get him out of my sight."],[3311,3390,"Hey, Warden."],[3424,3524,"Are you familiar with the term"],[3524,3591,"criminal negligence?"],[3591,3695,"Get your hands off me!"],[3695,3745,"Huh?"],[4141,4245,"Going somewhere?"]],"78":[[675,800,"Clean up nice."],[1167,1247,"Thank you for that."],[1276,1430,"You risked your life for me, Miles."],[1493,1593,"More than makes up for it."],[1922,2077,"You did a good thing here, Troy."],[2235,2419,"I know you guys disagreed, but he..."],[2527,2656,"Your dad, he'd be proud."],[2744,2811,"Come on."],[2902,3094,"I'm sorry he's not here to see all this."],[3194,3340,"Yeah, fathers aren't perfect."],[3908,4016,"Fathers never are."],[4254,4346,"But I am..."],[4437,4617,"I am pretty sure your dad loved you."]],"79":[[91,196,"But I am..."],[279,458,"I am pretty sure your dad loved you."],[892,984,"I had your, uh..."],[1026,1142,"your parole hearing moved up"],[1142,1226,"to next Tuesday."],[1326,1422,"It's gonna be fair this time."],[1422,1526,"You should be out within a week."],[1910,1964,"Thank you."],[2302,2348,"Hey."],[2452,2565,"Sons aren't perfect either."],[3353,3403,"Hey, Dad."],[3903,3983,"Charlie."],[5042,5096,"Thank you."]],"80":[[29,95,"Ow."],[308,383,"I saw that."],[450,521,"Nice punch."],[600,692,"Yeah, well..."],[692,742,"That's what she gets"],[742,855,"for sleeping with my man."],[905,955,"Oh."],[1021,1105,"I'm your man now?"],[1705,1897,"You really are something, Troy Poe."],[1972,2052,"Billionaire."],[2106,2198,"Ex-marine."],[2248,2364,"Sexy prisoner."],[2385,2606,"Sexy prisoner with a sexy sidekick."],[2673,2786,"I really have it all, huh?"],[2915,2994,"So what's next?"],[3065,3111,"Next?"],[3207,3294,"I make things right."],[3541,3636,"Hello, everybody."],[3903,3974,"Like I said,"],[4037,4158,"my name is Troy Poe."],[4241,4358,"And I'm here to apologize"],[4358,4454,"to every inmate,"],[4454,4658,"past and present, of Southgate Prison."],[4746,4842,"We failed you."],[4909,4967,"Horribly."],[5059,5176,"But that ends now."],[5284,5342,"As of today,"],[5342,5484,"our new mission will not only be"],[5484,5622,"to rehabilitate our prisoners,"],[5622,5830,"but the entire prison system as a whole."],[5922,5997,"And to prove this,"],[5997,6164,"I've acquired three more prisons."],[6243,6373,"Three of the worst,"],[6406,6581,"most corrupt private prisons"],[6581,6660,"in the country."],[7082,7198,"Our work has just begun."]]}