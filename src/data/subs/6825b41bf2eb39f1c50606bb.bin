{"1":[[3853,3958,"So"],[3995,4154,"you're the legendary Phoenix."],[4245,4337,"Rumor has it"],[4337,4508,"you're the greatest fighter of all time."],[4621,4721,"Personally,"],[4721,4846,"I just don't see it."],[4863,4971,"Let’s light them up, Admiral!"],[4971,5125,"Stand down."],[5125,5221,"We don't want to shoot up."],[5221,5292,"There's an innocent."],[5292,5405,"That's right."],[5405,5613,"You can't bring a gun to a knife fight."],[6260,6364,"I don’t need either."],[8174,8354,"The Navarro Cartel will rise,"],[8354,8470,"stronger than ever."],[8541,8733,"We will come for you."],[8733,8846,"We will come for all of you."],[9476,9592,"What?"],[9684,9797,"He was going on too long."],[10010,10143,"Secure the perimeter."],[10143,10256,"Check for hostiles."],[11031,11173,"Conrad, no!"]],"2":[[642,742,"Hang in there, Con."],[742,825,"Hang in there for me."],[825,921,"Okay?"],[963,1042,"I..."],[1126,1197,"love you."],[1409,1530,"Don't you dare say goodbye, okay?"],[1693,1780,"You can't leave me."],[1830,1956,"You can't leave us."],[1956,2106,"Can you tell our daughter..."],[2185,2344,"I really wanted to meet her..."],[2456,2573,"to see her face..."],[2644,2844,"You're going to tell her yourself, okay?"],[2844,2965,"You're going to tell her yourself."],[3040,3261,"I can't live without you."],[3261,3399,"But you can..."],[3428,3561,"you will."],[3649,3958,"You’re the strongest person I know."],[3958,4108,"You will keep our daughter..."],[4220,4371,"safe..."],[4458,4550,"No..."],[4550,4733,"no...no..."],[4733,4867,"No!"],[5184,5451,"For our great nation, Conrad Ford"],[5451,5622,"gave most precious thing,"],[5622,5759,"his life."],[6164,6402,"Admiral Ryan..."],[6402,6510,"Phoenix."],[6752,6948,"There are no words"],[6948,7061,"I can express..."],[7194,7386,"Thank you."],[7386,7474,"Rikshaw."],[8566,8687,"Admiral Ryan."],[8687,8938,"It's just Phoenix now."],[9017,9109,"I understand"],[9109,9413,"you are suffering a great loss right now,"],[9522,9822,"but please reconsider."],[9905,10118,"You are the strongest warrior"],[10118,10218,"we have ever seen."],[10372,10464,"We"],[10464,10543,"need"],[10543,10627,"you."],[10727,10819,"Admiral Mayhew."],[10935,11202,"You know I would live and die for this country."],[11257,11549,"You will keep our daughter..."],[11549,11665,"safe..."],[11815,11932,"No!"],[11932,12132,"No no no."],[12345,12483,"But my daughter is what I have to live"],[12483,12570,"for now."],[12812,13092,"And I'm leaving this country in good hands."]],"3":[[229,333,"So here's to us,"],[333,504,"the Class of 2025."],[504,692,"We came, we saw, we conquered,"],[692,900,"and occasionally, we napped."],[900,1088,"May our futures shine as brightly"],[1088,1276,"as our freshly polished diplomas."],[1384,1543,"As your class valedictorian,"],[1543,1639,"I salute you."],[1705,1901,"Cheers to us. Congratulations."],[1901,1960,"We did it!"],[2077,2223,"That's perfect, baby."],[2223,2310,"Just like you."],[2327,2456,"Mom, I'm an adult."],[2456,2648,"Who will always be my baby."],[2877,3153,"Conrad, you would be so proud of our girl."],[4754,4867,"Mom?"],[4950,5042,"Leave us."],[5326,5422,"Amy,"],[5593,5718,"you're late for school."],[5759,5864,"But...mom..."],[5914,5972,"Go."],[6848,7011,"Surprise someone was foolish enough"],[7011,7094,"to make you captain,"],[7094,7157,"Rikshaw."],[8625,8717,"Damn! Phoenix."],[8792,8950,"I guess it's safe to say you still got it."],[8950,9225,"Why you'd ever doubt that is beyond me."],[9225,9388,"We missed you, Admiral."],[9442,9647,"Whatever offer you have, Rikshaw."],[9647,9772,"You can leave with it."],[9772,9893,"I'm retired."],[10051,10168,"Yeah."],[10168,10297,"I figured you'd say that."],[10414,10502,"I also figured you'd"],[10502,10689,"probably want to see this."],[11156,11240,"We may have cut off the head"],[11240,11357,"of Navarro Cartel,"],[11407,11565,"but it appears they've grown another."],[11611,11782,"Meet Simone Navarro,"],[11782,11932,"Viktor Navarro’s daughter."],[12041,12233,"Conrad, no."],[12741,12900,"I never forget the face of Conrad's killer."]],"4":[[4,183,"Simone Navarro's recently expanded her"],[183,421,"operations to include black market organs"],[421,563,"and sex trafficking."],[563,721,"They target teens,"],[721,834,"especially those that grow up"],[834,938,"in small towns,"],[992,1067,"like this one."],[1126,1263,"That doesn't sound good."],[1343,1463,"No,"],[1463,1643,"your name's on top of the hit list."],[1722,1868,"Simon Navarro holds you personally"],[1868,2006,"responsible for her father's death."],[2006,2139,"I know what you're doing, Rikshaw,"],[2139,2289,"and it's not going to work."],[2289,2452,"My days of service are over."],[2548,2857,"I just want a quiet life with my daughter."],[2857,2961,"Phoenix,"],[2961,3128,"a quiet, peaceful life might be put at risk"],[3128,3274,"risk if you don't put down Simone-"],[3274,3411,"Rikshaw."],[3411,3516,"I said no."],[4099,4191,"Look,"],[4283,4425,"I'll be in town for a few days"],[4517,4696,"in case you change your mind."],[4996,5267,"You and the boys are welcome."],[5321,5501,"Any time"],[5501,5605,"to stop by for a meal."],[5914,6010,"Sir."],[6010,6085,"At ease."],[6085,6214,"Permission to ask question?"],[6293,6356,"This woman."],[6548,6619,"Who is she?"],[6639,6831,"Someone you never want to piss off."],[6831,6940,"That's who."],[8775,8904,"Where's the owner?"],[8967,9046,"Get over here!"],[9376,9567,"What can I do for you?"],[9634,9751,"Cockroach in this dish."],[9834,10080,"Oh, gentlemen, that shouldn't be there."],[10151,10331,"Why don't I have the kitchen whip you up"],[10331,10464,"something fresh and we can comp your"],[10464,10518,"meal."],[10518,10639,"Who you calling broke, bitch!"],[10789,10935,"I got money."],[11336,11465,"Tell you what."],[11465,11569,"Send that little peach over here"],[11569,11649,"to have a drink with us,"],[11695,11795,"and we’ll call it even."],[12145,12237,"She's..."],[12237,12358,"She's just a high school student,"],[12358,12545,"and she's not of legal drinking age."],[12658,12766,"Don't care."],[12766,12846,"She's what I want."]],"5":[[83,241,"How about this?"],[241,500,"I'll grab a drink with you on her behalf."],[571,754,"She's a MILF for sure."],[1063,1230,"I see where your girl gets her looks."],[1447,1572,"Mom, there wasn't a roach"],[1572,1664,"when I served it."],[1664,1751,"They planted it."],[2035,2152,"Why don't you go check on that table"],[2152,2256,"see if they need anything."],[2256,2369,"Okay?"],[2452,2606,"There's so many of them."],[2606,2690,"Just go."],[3078,3199,"Did I say she could leave?"],[3199,3286,"Let go of me!"],[3286,3390,"You're going to join us whether"],[3390,3549,"you like it or not."],[3603,3682,"I'm going to give you one last"],[3682,3774,"chance."],[3853,4045,"Leave my establishment."],[4045,4145,"Now."],[4287,4400,"Who's going to make us?"],[4491,4633,"You don't know what's good for you."],[4633,4846,"Our boss is tight with Mr. Carlisle."],[4846,4992,"He runs this town."],[5071,5180,"I don't care"],[5180,5372,"who your boss is tight with."],[5451,5588,"We follow the law around here."],[6014,6185,"The law?"],[6289,6481,"I am the fucking law."],[6481,6594,"Smash everything."],[6731,6856,"Except this one."],[7036,7123,"She's mine."],[7123,7265,"Don't you dare!"],[7465,7595,"Let's do it, boys!"],[7595,7678,"Stop right there!"]],"6":[[75,208,"Well, well..."],[271,387,"SEAL Team 6."],[387,529,"No fucking way."],[571,684,"You soldier boys can't do nothing"],[684,800,"on American soil."],[829,980,"This town belongs to Mr. Carlisle."],[1080,1280,"Mr. Carlisle can kiss my ass."],[1338,1484,"The President stationed us here."],[1572,1735,"This is our jurisdiction now."],[1947,2060,"You good?"],[2289,2452,"That's why you're so fearless."],[2452,2590,"Banging a Navy SEAL."],[2635,2802,"Probably the whole fucking team, huh?"],[3482,3670,"Apologize to the lady"],[3670,3749,"and her daughter."],[3970,4066,"And what if we don't?"],[4717,4808,"You think your measly little"],[4808,4967,"gang is ready to fight with our boys?"],[5113,5188,"Why?"],[5263,5376,"Why is the military defending this"],[5376,5480,"stupid nobody woman?"]],"7":[[625,767,"Apologize!"],[796,925,"Sorry. I'm sorry. Okay."],[950,1030,"Sorry."],[1030,1109,"We're sorry."],[1359,1539,"I apologize."],[1605,1685,"We didn't know she was under your"],[1685,1760,"protection."],[1760,1851,"Get out."],[1968,2177,"Do not come back!"],[3516,3595,"Don't worry, Amy."],[3595,3670,"They're gone."],[3670,3774,"It's okay."],[3791,4016,"You guys okay?"],[4016,4183,"You really think they could hurt me?"],[4854,4975,"Fuck!"],[5230,5388,"Boss, you going to take this?"],[5388,5518,"Fuck no!"],[5630,5797,"Those SEALs might think they're tough,"],[5797,5855,"but they're just Admiral"],[5855,5980,"Mayhew's dogs."],[6006,6139,"Admiral Mayhew is..."],[6222,6368,"Mr. Carlisle's new ally."],[6468,6627,"Which means..."],[6677,6777,"the SEALs will be under"],[6777,6915,"our control now,"],[6990,7140,"which means..."],[7140,7232,"Like I said,"],[7319,7499,"those ladies were fine."],[7553,7670,"I get what I want, when I want."]],"8":[[471,571,"Help me!"],[571,742,"Help!"],[742,859,"Let me go!"],[1714,1856,"Let me go!"],[1885,2018,"You and your mom think some SEAL"],[2018,2139,"can save you?"],[2298,2485,"This is my town, Peach."],[2744,2836,"You..."],[2986,3115,"what do you want?"],[3720,3924,"You're soft little thing, aren't you?"],[4575,4675,"God!"],[4675,4984,"Fucking bitch!"],[5025,5096,"Looks like Peach wants"],[5096,5180,"to have a party."],[5242,5347,"Come on, boys."],[5522,5822,"Let's get this started."],[5935,6085,"Don't touch me!"],[6485,6556,"Yeah."],[7048,7178,"Go again."],[7178,7282,"Scream!"],[7570,7686,"No one will hear you."],[7686,7820,"You're going to pay for this."],[7849,7974,"My mom's going to call her friends"],[7974,8145,"and they're going to put you to justice."],[8145,8245,"Oh, yeah?"],[8245,8458,"Those dumb, stupid"],[8458,8558,"military boys"],[8558,8725,"ain't got no shit"],[8725,8846,"on me or my people."],[8892,9092,"If she comes for you,"],[9092,9221,"we'll do more than cut her."]],"9":[[342,425,"You!"],[425,579,"Make me look like a star."],[579,775,"You got it, boss."],[938,1151,"Shit!"],[1564,1693,"Mom!"],[1697,1939,"Mom! Help me please!"],[1939,2147,"Please!"],[2794,2994,"This is going to be fun."],[2994,3132,"No!"],[3490,3595,"Please!"],[3966,4137,"Help me!"],[4137,4241,"Please!"],[4600,4704,"Where's Amy?"],[4704,4904,"She should be back by now."],[5847,6051,"Hey, sweetie."],[6051,6177,"You okay?"],[6177,6256,"I can"],[6256,6389,"come pick you up from school if..."],[6389,6506,"Oh ma."],[6506,6639,"Picking her up is a great idea."],[6702,6802,"I don't think she's in a state"],[6802,6931,"to go anywhere."],[6998,7132,"Who is this?"],[7132,7298,"I'm one of the men who..."],[7298,7449,"well you know..."],[7449,7607,"with your beautiful daughter."]],"10":[[20,91,"Amy!"],[158,229,"Amy!"],[262,316,"Amy!"],[316,425,"Amy, where are you?!"],[2214,2352,"Amy!"],[2352,2573,"Oh my God!"],[2761,2923,"My God. What have they done to you?"],[3082,3228,"Oh no."],[3228,3436,"I'm so sorry."],[3611,3845,"I'm so sorry."],[3916,4012,"I failed you."],[4225,4304,"I'm so sorry."]],"11":[[671,850,"Amy,"],[850,967,"you're safe now."],[967,1134,"Mom."],[1284,1409,"Those men really did"],[1409,1551,"horrible things to me."],[1822,1968,"I feel so broken"],[2018,2231,"and I feel so shattered."],[2231,2327,"No, no, no, no!"],[2515,2635,"You're not, baby. Okay?"],[2698,2769,"You're not."],[3353,3457,"What?"],[3666,3812,"What men, baby?"],[3883,4041,"Who did this to you?"],[4141,4354,"I tried to stop them."],[4354,4554,"I tried to fight, but I couldn't fight."],[4554,4633,"I tried!"],[4633,4842,"It's not your fault."],[5096,5192,"But I'm going to need to know"],[5192,5359,"who did this to you, okay?"],[5447,5584,"So I can make them pay."],[5739,5876,"She comes for you,"],[5939,6114,"we'll do more than cut her."],[7282,7399,"You're sure that it's Earl Wyatt"],[7399,7549,"and his thugs that did this, right?"],[7724,7845,"Hundred percent."],[8170,8304,"But Phoenix,"],[8304,8437,"please listen to me."],[8554,8692,"Wyatt works for Carlisle,"],[8692,8846,"who just swore allegiance"],[8846,8938,"to the government."],[8938,9050,"Let us handle."],[9050,9154,"No."],[9192,9309,"Earl Wyatt's head is mine."],[9522,9613,"At least take some of the SEALs"],[9613,9713,"with you."],[9713,9805,"There's heavy fire power"],[9805,9889,"at the Carlisle's today"],[9889,9997,"because"],[9997,10097,"Sheriff Larson is visiting."],[10097,10193,"I don't care, Rikshaw."],[10251,10356,"I'll take them all down"],[10356,10422,"with my own hands."],[11327,11482,"I will get justice for our daughter."],[11482,11745,"No matter the cost."],[12812,13083,"Admiral Mayhew..."],[13083,13242,"we've got a situation."]],"12":[[905,1130,"You have my diner deed, Wyatt?"],[1209,1434,"It is sitting right in the middle of my"],[1434,1584,"future shopping mall."],[1659,1785,"I'll have it soon enough."],[1910,1997,"We fucked up the daughter"],[1997,2135,"pretty good, Mr. Carlisle."],[2160,2302,"Mom will fold in no time."],[2335,2452,"Good."],[2569,2736,"I need something to"],[2736,2882,"impress Sheriff Larson with."],[3065,3219,"Listen up, you fools!"],[3303,3395,"We have"],[3436,3657,"been on the wrong side of the law"],[3737,3912,"and that gave us more trouble"],[3912,4037,"than we needed."],[4066,4358,"Now, we have one chance to"],[4358,4621,"bend the law in our favor."],[4658,4950,"We get Sheriff Larson to like us,"],[4950,5146,"and we become the law."],[5251,5384,"Understood?"],[5384,5505,"Understood."],[5876,6172,"Stop."],[6172,6335,"This is a private party."],[6448,6594,"Well, I've got my invite right here."],[6840,6944,"Damn, Wyatt."],[6944,7111,"You really can get away with anything,"],[7111,7182,"can't you?"],[7236,7378,"Sure can..."],[7507,7590,"Can't wait to get a piece of"],[7590,7670,"her mother."],[7982,8045,"Shit!"],[9713,9859,"Earl Wyatt?"],[9909,10030,"Come on out."],[10030,10110,"Prepare to die."]],"13":[[29,162,"Who is this woman?"],[162,329,"Sh...She blew my door off!"],[358,471,"That's the diner owner,"],[471,579,"Jane Reagan."],[579,750,"I thought you took care of her?"],[750,871,"What the hell are you doing here?"],[934,1063,"Shouldn't you be..."],[1063,1155,"checking on your daughter after"],[1155,1280,"the little games we played with her?"],[1476,1651,"I'm here to deliver ten thousandfold"],[1651,1818,"of the pain that you put Amy through."],[1943,2068,"Listen, you stupid bitch."],[2068,2168,"If you don't get out of here,"],[2168,2335,"the only thing you're going to feel is pain."],[2410,2598,"No, Earl Wyatt."],[2598,2769,"I'm not going anywhere."],[2769,2902,"Not until I can make certain that you"],[2902,3028,"never put your hands on a"],[3028,3128,"defenselessly young lady"],[3128,3249,"ever again."],[3474,3645,"In fact,"],[3645,3749,"I think I should take something"],[3749,3858,"from you."],[3858,4049,"You know, since you don't deserve it."],[4104,4204,"And what's that, bitch?"],[4325,4404,"Your manhood."]],"14":[[45,175,"My fucking manhood?"],[283,379,"You're going to take it in that little"],[379,504,"Halloween costume?"],[596,667,"Sure, bitch."],[667,775,"I dare you to try."],[900,1030,"I'm going to enjoy this."],[1030,1109,"You and your daughter are going"],[1109,1247,"to remember me for the rest of your life."],[1488,1626,"And I'll be your last."],[1626,1810,"You'll die, of course."],[1810,1981,"But I'll be the final thing you see."],[2202,2293,"Bring it."],[2427,2548,"I'm shivering in my boots."],[2660,2769,"You heard her, boys."],[2769,2857,"She wants it."],[2857,2952,"Give it to her."],[4871,4963,"You know,"],[4963,5171,"gut wounds like this can be pretty fatal."],[5192,5430,"The only promise is a slow, painful"],[5430,5484,"death."],[5484,5643,"Please."],[5643,5730,"I'm going to show you the same"],[5730,5814,"mercy that you showed"],[5814,5893,"my daughter."]],"15":[[45,125,"Get up."],[125,271,"Attack her or die!"],[1397,1497,"Enough!"],[1543,1618,"Now,"],[1618,1743,"Sheriff Larson's going to be here"],[1743,1847,"any second,"],[1885,2077,"and you won't be able to handle"],[2077,2185,"the consequences."],[2235,2348,"Sheriff Larson?"],[2473,2656,"Even if Satan himself came here,"],[2656,2786,"he wouldn't be able to save you pigs"],[2786,2898,"from me."],[2898,3107,"I don't need Satan, bitch."],[3174,3378,"All I need is my glock."],[4425,4587,"That..."],[4587,4888,"That's impossible."],[6047,6147,"Now."],[6289,6398,"Where were we?"],[6489,6589,"A bunch of useless fucks."],[6589,6673,"Get up!"],[6727,6873,"Oh, you can't raise the dead."],[7002,7119,"You killed them."],[7132,7236,"And you delighted in my daughter's"],[7236,7336,"suffering."],[7515,7611,"Don't come any closer."],[7711,7799,"You know..."],[7878,8016,"it wasn't enough"],[8016,8137,"for a piece of shit"],[8137,8320,"like you just to assault her."],[8320,8391,"No."],[8450,8591,"You had to break her spirit."],[8671,8767,"That very light that"],[8767,8904,"shines within her."],[8983,9117,"Stay away from me."],[9242,9309,"Mr..."],[9309,9388,"Mr. Carlisle!"],[9567,9705,"No, he can't help you now."],[9759,10047,"Stay the fuck away from me!"],[10047,10231,"Who do you think you are?"]],"16":[[600,725,"I'm a mother."],[1468,1551,"You."],[1714,1793,"You are now permanently"],[1793,1897,"paralyzed."],[2156,2327,"You are just going to rot"],[2327,2523,"in your useless body,"],[2523,2652,"watching time pass by,"],[2756,2961,"too helpless to even end"],[2961,3128,"your own miserable life."],[3282,3628,"And if by some medical miracle,"],[3657,3862,"you regain use of that dick of yours..."],[3862,3958,"Freeze!"],[4225,4479,"Checkmate, whore!"],[4479,4621,"Step away from Mr. Wyatt,"],[4621,4713,"now!"],[4792,4946,"Do not make me hurt you!"],[5380,5463,"Amy!"],[5463,5584,"What have they done to you?"],[5613,5709,"I'm so sorry."],[5751,5847,"I failed you."],[6026,6156,"This is for my daughter!"],[6360,6468,"Oh."],[6852,6973,"Oh, no!"],[7545,7624,"Now,"],[7741,7866,"how can you hurt me?"]],"17":[[25,145,"I will not stand for violence"],[145,304,"right in front of my eyes!"],[304,500,"Get down on the ground, now!"],[696,775,"Miss,"],[775,963,"get on the ground or I'll shoot!"],[1034,1138,"I'd like to see you try."],[2377,2485,"What the..."],[2652,2777,"Your'e a woman."],[2894,3019,"You look familiar."],[3065,3174,"Who are you?"],[3307,3395,"If you have to ask,"],[3395,3516,"then you don't deserve to know."],[3557,3695,"You told me a lunatic was here."],[3695,3899,"She is a lunatic, Sheriff Larson!"],[3899,4091,"She barged in here and killed my men."],[4091,4320,"She castrated Mr. Wyatt!"],[4320,4596,"I mean, she's absolutely insane!"],[4596,4688,"Now,"],[4688,4763,"arrest her,"],[4763,4929,"kill her, do something!"],[5113,5276,"Bastard probably deserved it."],[5513,5647,"We're not going to let violence like this"],[5647,5722,"slide."],[5864,5976,"Arrest her!"],[5976,6076,"Hold your fire!"],[7178,7253,"Ma'am."],[7595,7703,"Sorry I came late."]],"18":[[33,91,"Whatever you planned"],[91,175,"to do to her,"],[175,312,"I'd advise against it."],[333,513,"How does she know Captain Rikshaw?"],[513,650,"Wyatt said the bitch is fucking him!"],[650,775,"That's how! Who cares?"],[775,955,"This is the Navy's jurisdiction."],[955,1109,"I'm ordering you to stand down."],[1146,1255,"I was appointed Sheriff"],[1255,1372,"and given power directly by"],[1372,1497,"Admiral Mayhew."],[1497,1580,"So,"],[1580,1743,"why should I listen to a Captain?"],[1768,1856,"I'm warning you."],[1889,1951,"This woman..."],[1951,2106,"This woman killed!"],[2139,2302,"I represent the law,"],[2302,2481,"which obviously you abandoned for"],[2481,2677,"lust or whatever this is."],[2677,2827,"You fool."],[2827,3028,"This is a matter of national security."],[3215,3328,"Comply"],[3386,3478,"or face the consequences"],[3478,3586,"of the law."],[3586,3703,"Hooyah!"],[5159,5392,"Who are you"],[5392,5751,"to declare a matter of national security?"],[6310,6418,"Admiral Mayhew."],[6418,6710,"Admiral, sir, it is an honor to meet you."],[6773,6915,"That's Admiral Mayhew!"],[6952,7102,"I never thought I'd see him in person."],[7269,7428,"This woman shot up the place!"],[7465,7611,"She defies all laws"],[7611,7753,"and acts like she's above us."],[7753,7941,"Admiral, all Wyatt and I were trying"],[7941,8170,"to do was improve your jurisdiction,"],[8183,8454,"and this psychotic woman"],[8454,8621,"came here and punished us for it!"],[9317,9617,"Admiral Ryan,"],[9693,9893,"it is an honor to see you again."],[10643,10848,"What did the Admiral call you?"]],"19":[[2089,2231,"All of you..."],[2686,2761,"Admiral,"],[2761,2857,"I didn't know..."],[2911,3015,"Larson."],[3061,3324,"I appointed you sheriff of this town,"],[3324,3432,"thinking"],[3432,3624,"you could control these imbeciles."],[3682,3824,"But it seems"],[3824,3987,"they've controlled you instead."],[4137,4229,"No!"],[4229,4304,"Admiral,"],[4333,4496,"it's not true."],[4533,4675,"I didn't know, like..."],[4675,4800,"They manipulated me!"],[4825,4871,"I..."],[4871,4971,"You didn't know"],[5059,5201,"that they kidnapped"],[5201,5347,"my 17 year old daughter,"],[5572,5668,"beat her,"],[5847,5939,"raped her,"],[6356,6552,"and then left her in a basement to die,"],[6552,6639,"so that"],[6710,6810,"they could take my diner"],[6810,6898,"to impress you?"],[7011,7152,"No, Sheriff, listen!"],[7152,7215,"Listen, Sheriff."],[8404,8625,"Please accept my sincere apologies"],[8625,8787,"and my resignation."]],"20":[[66,183,"People commit injustices"],[183,300,"by doing nothing."],[354,479,"They'll watch the world burn"],[479,567,"and let it,"],[604,704,"just as long as the fire doesn't"],[704,800,"reach their own."],[900,1030,"But you say you didn't know."],[1226,1397,"And I believe you were deceived."],[1480,1651,"And that suggests incompetence,"],[1651,1826,"which is something that I can forgive."],[1993,2122,"But keep your hat, Sheriff."],[2223,2356,"This town needs good men."],[2540,2619,"Ma'am."],[3119,3182,"Sir."],[3269,3490,"Whatever Phoenix says, goes."],[3561,3624,"Thank you."],[3787,3883,"And as for you..."],[4129,4308,"You were the man that gave Wyatt"],[4308,4425,"the orders to take my diner,"],[4425,4512,"were you not?"],[4512,4608,"Ma'am."],[4650,4717,"Admiral,"],[4717,4900,"I didn't know who I was dealing with."],[4938,5030,"So you..."],[5134,5255,"You were the monster"],[5255,5351,"who's responsible"],[5351,5434,"for my daughter's pain."],[5522,5626,"Please!"],[5626,5809,"Have mercy! I am begging you!"],[5855,5993,"Oh, I'm going to show you the same mercy"],[5993,6110,"that you showed"],[6110,6210,"my daughter when you were laughing"],[6210,6322,"with her rapists."],[6348,6443,"Please."],[6443,6677,"Nothing is going to change the fact"],[6677,6785,"that my daughter has been"],[6785,6969,"traumatized for life."],[7077,7198,"But I'm going to make certain"],[7323,7428,"that you never"],[7428,7632,"harm another girl ever again."],[7795,7907,"Please."],[7907,8066,"Please don't cut it off!"],[8120,8195,"Please!"],[8249,8420,"Please don't cut it off!"],[8437,8504,"Please!"],[8767,8933,"Please!"]],"21":[[346,525,"It's a pleasure to see you again,"],[525,579,"Phoenix."],[579,633,"Phoenix."],[633,784,"You were sorely missed."],[955,1109,"Most of these SEALs"],[1138,1226,"are too young."],[1267,1539,"They think you're just a legend."],[1685,1764,"What happened?"],[1885,1943,"Well,"],[2014,2110,"They're not a good of a fighter"],[2110,2198,"as you were."],[2218,2389,"Took some serious hits."],[2510,2598,"I'm sorry."],[2702,2769,"Also,"],[2844,2998,"thank you for coming today."],[3107,3345,"I understand that what I did to"],[3345,3478,"these men,"],[3528,3624,"if you can call them that,"],[3712,3841,"will have consequences."],[3958,4149,"I've already secured you"],[4187,4450,"the Presidential Service Badge."],[4500,4592,"It allows you to work on"],[4592,4696,"American soil"],[4696,4954,"on behest of the Presidency."],[5188,5376,"The entire incident with Wyatt,"],[5438,5709,"will be classified as national security."],[5776,5897,"He has known ties with"],[5897,5993,"human traffickers,"],[5993,6202,"including the Navarro Cartel."],[6414,6715,"You did our nation a favor."],[6802,6881,"Again."],[7044,7165,"I see."],[7344,7469,"So what's the catch?"],[7611,7682,"Well,"],[7716,7878,"now that your cover is blown,"],[7974,8070,"I want you back,"],[8070,8179,"Phoenix."],[8445,8562,"Thank you,"],[8654,8758,"Admiral."],[8837,8971,"As much as I would love to serve my"],[8971,9138,"country, I..."],[9159,9321,"I need to be there for my daughter."],[9672,9768,"I understand."],[10226,10402,"I just got a call from hospital security."],[10568,10664,"Amy's missing."]],"22":[[550,704,"Has anyone else been in this room?"],[704,880,"No one but me, Captain Rikshaw."],[1251,1426,"She's already been through so much."],[1426,1564,"We'll get her back, Phoenix."],[1564,1664,"Whatever it takes."],[2010,2118,"Thanks, Rikshaw."],[2277,2389,"I needed to hear that."],[3340,3445,"Ketamine."],[3524,3666,"They planned the whole kidnapping."],[6869,6994,"This kind of crack,"],[6994,7161,"the kidnapper broke it deliberately"],[7161,7269,"when Amy fought them."]],"23":[[266,362,"The kidnappers have done this"],[362,429,"before."],[467,567,"Many times."],[1146,1234,"Doctor!"],[1355,1443,"There was a teen girl"],[1443,1514,"in that bed over there."],[1514,1593,"What happened to her?"],[1630,1789,"She's just a junkie."],[1789,1851,"I mean,"],[1851,2014,"they sneak out of here all the time."],[2060,2181,"Right after we save their lives"],[2181,2381,"just to avoid paying a bill."],[2381,2485,"So,"],[2485,2769,"two teen girls disappeared,"],[2769,2944,"but only one was taken?"],[2944,3015,"Phoenix."],[3532,3661,"Keira Davis."],[3661,3807,"Admitted for drug overdose."],[3870,4054,"No known addresses or family."],[4187,4325,"Didn't you say the Navarro Cartel"],[4325,4479,"was targeting at-risk teens?"],[4508,4604,"The ones that nobody would"],[4604,4742,"notice if they go missing?"],[4788,4921,"Yeah. Where are you going with this,"],[4921,5009,"Phoenix?"],[5050,5180,"These two girls,"],[5180,5326,"they were taken by sex traffickers."],[5538,5676,"I don't think the Navarro Cartel"],[5676,5847,"knows who Amy is..."],[5847,5935,"yet."],[5935,6093,"But if they find out that I'm her mother,"],[6210,6322,"they're going to try to hurt me"],[6389,6489,"through her."],[6698,6760,"Let's go."]],"24":[[988,1088,"Lunch is served."],[1121,1205,"Eat up."],[1301,1376,"Don't!"],[1668,1814,"I watched him spit in it."],[2168,2298,"What are you going to do about it,"],[2548,2656,"puta?"],[2761,2919,"Just because you force us like dogs"],[2919,3048,"doesn't mean we are dogs."],[3153,3286,"¿Hablas español?"],[3353,3532,"I got an A+ in AP Spanish."],[3674,3753,"Don't know and don't care"],[3753,3824,"what that is."],[3916,4024,"Looks like we got a firecracker"],[4024,4158,"on our hands, boys."],[4283,4408,"Let's see how fiery you are"],[4408,4529,"when we get to the brothel."],[4792,5017,"All you little putas break then."]],"25":[[266,450,"My mom will never stop looking for me."],[450,596,"Your freaking mami?"],[1159,1305,"You know my nickname, puta?"],[1472,1580,"They call me..."],[1639,1864,"Devorador de Esperanza."],[2064,2173,"The Hope Eater."],[2635,2711,"Those three."],[2815,2944,"Hose them down."],[2944,3053,"Get them ready."],[3328,3432,"Make them pretty."],[3586,3632,"You."],[3749,3795,"Go."],[4633,4742,"Where is he taking them?"],[4813,4984,"To the brothel to be sold."],[5138,5238,"You're up next, firecracker."],[5238,5359,"You're up next, firecracker."]],"26":[[221,329,"The cartel must have eyes"],[329,442,"inside this hospital."],[608,734,"Yeah, someone who scouts the girls"],[734,829,"to grab."],[829,959,"Look, once we find the inside man,"],[959,1046,"then we can find out where they're"],[1046,1142,"keeping Amy."],[1184,1292,"Most of my men are still doing work"],[1292,1384,"at Carlisle's."],[1480,1589,"Let me make a few calls."],[1639,1760,"Pheonix Ryan!"],[1926,2085,"Not her."],[2085,2181,"Not now."],[2836,3028,"This is all your fault!"],[3090,3224,"I knew you would ruin"],[3224,3357,"my granddaughter!"],[3357,3482,"Who the fuck are you?"],[3482,3695,"I'm Conrad Ford's mother."],[3695,3912,"Amy's grandmother."],[3912,4079,"She was mine..."],[4079,4287,"until Phoenix stole her from me."],[4287,4554,"Amy is not yours!"],[4554,4683,"You didn't want anything to do with"],[4683,4846,"her until after Conrad died."],[4867,4984,"The only reason why you care now"],[4984,5096,"is because his blood flows"],[5096,5184,"through her."],[5226,5347,"But Amy is not a replacement"],[5347,5459,"for him, Lydia."],[5459,5576,"She's my baby."],[5605,5714,"Oh, your baby?"],[5730,5880,"And where is your baby now,"],[5880,5960,"may I ask?"],[6101,6181,"She was taken."],[6235,6556,"Because you're unfit to be a mother!"],[6556,6694,"I will find her no matter..."],[6694,6869,"You are the one that lost her"],[6869,6973,"in the first place!"],[7194,7344,"A billion dollar reward"],[7344,7436,"will solve this."],[7561,7720,"Lydia, when are you going to realize"],[7720,7878,"that money doesn't solve everything?"],[7932,8041,"You will attract the attention"],[8041,8103,"of the cartel."],[8137,8254,"I agree with Phoenix."],[8254,8320,"That's just going to bring out the"],[8320,8412,"crazies."],[8412,8533,"You need to stay out of this."],[8616,8712,"You're a civilian."],[8762,8888,"Careful, Captain."],[8925,9088,"She is sucking you in,"],[9196,9346,"just like she did my Conrad."],[9455,9584,"It ended badly for him."],[9701,9818,"All because this woman,"],[9818,9889,"couldn't"],[9889,9993,"protect him."]],"27":[[25,104,"Lydia,"],[141,304,"the people that are keeping Amy"],[304,408,"are very dangerous."],[492,563,"Right now,"],[604,709,"they don't know who she is."],[775,884,"But you throw a billion dollars"],[884,955,"into the mix,"],[955,1067,"that all changes."],[1180,1330,"I had to find out from a"],[1330,1447,"private investigator"],[1447,1576,"that my granddaughter"],[1576,1701,"is a genius."],[1739,1856,"Valedictorian,"],[1918,2152,"Ivy League schools clamoring for her."],[2218,2381,"Do you know who else was a genius?"],[2602,2756,"My boy, Conrad."],[2911,3073,"Before you let him die."],[3824,3912,"So,"],[3912,4149,"I will use my wealth and my power"],[4149,4287,"to ransom back"],[4287,4421,"my only heir."],[4496,4625,"And after I do,"],[4704,4913,"I will keep her from you, Phoenix Ryan."],[4913,5013,"Forever."],[5013,5188,"You're suing me for custody of Amy?"],[5188,5330,"And I will win."]],"28":[[141,258,"Sue me all you want."],[316,500,"Try to disqualify me as a mother."],[563,696,"All I'm asking you is this..."],[784,934,"do not"],[934,1071,"put out a reward for her."],[1159,1280,"You are only putting her"],[1280,1401,"in much more danger."],[1401,1472,"Danger?"],[1534,1680,"You're the only danger,"],[1680,1785,"Phoenix Ryan."],[1835,1922,"I knew it from the moment"],[1922,2160,"Conrad fell for you, and I know it now."],[2268,2348,"Lydia,"],[2402,2519,"I am begging you,"],[2665,2836,"do not do this."],[2911,3098,"Amy is my everything."],[3115,3307,"Conrad was my everything!"],[3390,3545,"And you took him from me."],[3616,3737,"So now you will know"],[3737,3999,"finally what it feels like to lose a child."],[4896,5071,"I will see you in court."],[5071,5330,"After I get my heir back."],[6373,6452,"I save my daughter"],[6452,6564,"just to lose her again?"],[6664,6781,"She can't be that powerful."],[6931,7077,"Lydia Ford is the"],[7077,7248,"richest woman in the country."],[7399,7557,"Her wealth is unimaginable."]],"29":[[70,183,"But what I can't understand is"],[183,312,"how she was able to find us."],[383,579,"The Navy gave us our new identities."],[579,721,"They erased us from all of the"],[721,813,"systems."],[888,992,"You think there's a mole in the Navy"],[992,1113,"feeding Lydia information."],[1180,1351,"With that much money?"],[1351,1509,"You can buy practically anybody."],[2610,2748,"Conrad, no!"],[3370,3495,"Is the Navarro gang symbol"],[3495,3624,"still a scorpion?"],[3624,3803,"Yeah, same ugly ass tattoo."],[4391,4508,"Son of a bitch!"],[4508,4675,"The orderly's the inside man."],[4675,4746,"Let's go."],[4892,5005,"Try not to kill him."]],"30":[[62,171,"Where is my daughter?"],[171,346,"Suck my dick!"],[346,392,"I know that"],[392,517,"you take girls for them."],[517,621,"Where is she?"],[621,734,"They'll kill me."],[734,871,"You think the Navarro Cartel is what"],[871,1005,"you should be afraid of?"],[1005,1113,"It's me."],[1113,1159,"You ever watch"],[1159,1313,"any nature documentaries?"],[1313,1359,"They say there's"],[1359,1443,"nothing more dangerous"],[1443,1543,"than a mama grizzly bear"],[1543,1689,"defending her cubs."],[1689,1801,"I'm going to rip you to shreds until"],[1801,1939,"there's nothing left."],[1939,2093,"I don't know where they"],[2093,2218,"take the girls."],[2218,2419,"All I know is where they end up."],[2469,2652,"The Gentleman's Club."],[2652,2777,"Isn't that a social club?"],[2777,2852,"There's a secret"],[2852,3053,"brothel in the back."],[3774,3874,"Did you get what you need?"],[4888,5046,"Admiral Mayhew,"],[5046,5246,"I will accept your offer."],[5246,5359,"I will be your special agent"],[5359,5409,"in taking down"],[5409,5597,"the Navarro Cartel."],[5597,5797,"But this ends here."],[5809,5893,"Excellent news,"],[5893,6026,"Special Agent Ryan."],[6026,6348,"Captain Rikshaw will be a point of contact."],[6348,6527,"I hear they've got your daughter."],[6527,6648,"I wish you had accepted"],[6648,6848,"under better circumstances."],[6865,7015,"I'm going to get her back."],[7015,7194,"Well, if anyone can,"],[7194,7265,"it's you."],[7357,7557,"Good luck and good hunting."],[7574,7711,"Oh, and"],[7711,7882,"finish off the Navarro"],[7882,8166,"Cartel once and for all."]],"31":[[300,400,"I bet nobody"],[400,550,"knows I'm missing."],[1334,1509,"There has to be someone."],[1509,1735,"My own mother"],[1735,1893,"kicked me out after one of her"],[1893,2277,"disgusting boyfriends hit on me."],[2323,2510,"That was six months ago."],[2585,2786,"I have no home,"],[2786,3036,"no family;"],[3073,3294,"I have nothing."],[3457,3636,"I'm so sorry."],[3636,3895,"If I die here, it'll be like"],[3895,4141,"I never existed at all."],[4225,4379,"Look, I know you're scared..."],[4379,4608,"and I'm really scared too,"],[4608,4717,"but my mom always says that"],[4717,5034,"fear can be a fuel to make you stronger."],[5180,5326,"So we can't give up."],[5326,5572,"Who cares what your housewife mom says?"],[5572,5701,"Shut up and stop giving us"],[5701,5843,"false hope already!"],[5843,6085,"She's not a housewife."],[6085,6293,"She owns a diner."],[6527,6619,"Do you really think"],[6619,6810,"she'll come find us, Amy?"],[6948,7165,"I know she will."],[7165,7311,"She'll never stop looking for me."],[7411,7520,"For any of us."]],"32":[[145,271,"Sold!"],[271,337,"Chica,"],[408,521,"dungeon them in."],[521,696,"Next up for your viewing pleasure,"],[709,905,"item number two."],[905,1092,"Hispanic,"],[1092,1259,"5'4\","],[1259,1509,"115 pounds."],[1543,1664,"Appendix scar."],[1664,1897,"Starting at 25,000."],[1897,2043,"What are her measurements?"],[2043,2168,"Gentlemen, please"],[2168,2293,"check your buyer's card."],[2381,2473,"$30,000"],[2540,2669,"$35,000"],[2794,2961,"$40,000 says she's mine!"],[3044,3186,"$40,000 going once,"],[3249,3361,"going twice..."],[3386,3574,"sold."],[3574,3670,"Chica."],[3787,3962,"Item number 3!"],[3962,4074,"¡Ándale!"],[4137,4337,"This is a prime property."],[4337,4567,"Half-White, Half-Black"],[4658,4929,"5'6\", 120 lbs."],[5013,5213,"A clean record."],[5213,5372,"Starting at $100,000."]],"33":[[262,454,"This is a private room."],[454,613,"Get the fuck out!"],[729,1017,"Did you kidnap those girls?"],[1017,1188,"I've taken many ladies."],[1188,1330,"What's it to you?"],[1330,1468,"I'm looking for my daughter,"],[1468,1626,"Amy Reagan."],[1626,1926,"Holy shit."],[1964,2060,"You're that little firecracker's"],[2060,2227,"mami."],[2227,2469,"Muy estúpido chica."],[2469,2677,"Your daughter's lost to you."],[2677,2919,"Accept it and move on."],[2919,3144,"You will tell me where she is"],[3144,3274,"or you will die."],[3328,3566,"Es loco."],[3566,3803,"You dare threaten a cartel lieutenant?"],[3803,3974,"I am Diego Navarro,"],[4037,4262,"cousin to Drug Lord Simone Navarro!"],[4329,4491,"It is you who will not be walking"],[4491,4604,"out of here alive."],[4742,4863,"Dispose of her."]],"34":[[16,154,"It is you who will not be"],[154,271,"walking out of here alive."],[442,592,"Dispose of her."],[638,771,"How do you want it, boss?"],[771,909,"I don't care."],[909,1096,"Just make her scream."],[1096,1251,"You got it."],[2193,2339,"Who the hell are you?"],[2406,2552,"I am every woman"],[2552,2727,"that you have ever violated,"],[2740,2815,"sold,"],[2815,3015,"and discarded like trash."],[3086,3282,"I am vengeance"],[3282,3440,"and I am coming for you."],[3520,3586,"Don't just stand there."],[3586,3670,"Kill her!"],[4867,4954,"Girls!"],[4954,5034,"Take cover."],[5034,5117,"And don't come back out"],[5117,5226,"until I tell you to."],[5538,5630,"Now..."],[5809,5918,"where were we?"],[6076,6252,"What do you want?"],[6252,6427,"Well,"],[6427,6677,"you can bring me back my daughter,"],[6723,6848,"and I'll make your death quick."],[7111,7219,"Who the fuck is"],[7219,7424,"making all this ruckus in my club?"],[7424,7482,"Huh?"],[7482,7745,"Well, that would be me."]],"35":[[196,400,"What have you done?"],[400,613,"Do you know who this is?"],[613,917,"He's a fucking Navarro and a cartel lieutenant!"],[992,1180,"Diego is untouchable."],[1180,1443,"Oh, not so untouchable now."],[1639,1701,"Bitch!"],[1701,1876,"You are so dead."],[1876,2131,"Simone Navarro will have your head."],[2131,2348,"I'd like to see her try."],[2348,2423,"And you can make sure"],[2423,2665,"to tell her that Phoenix Ryan says hello."],[2665,2836,"Oh, Phoenix"],[2836,2986,"Ryan..."],[2986,3094,"the Navy SEAL"],[3094,3328,"who can catch bullets?"],[3328,3499,"What the fuck you say?"],[3649,3812,"The Navarro Cartel has a"],[3812,3891,"$10 million"],[3891,4149,"bounty for your capture."],[5071,5251,"Drop it!"],[5880,5960,"Not so tough now"],[5960,6068,"are you?"],[6810,6902,"Now,"],[6952,7127,"where is my daughter?"]],"36":[[58,250,"If you kill me,"],[250,325,"you'll be picking up"],[325,429,"your daughter's corpse."],[429,671,"Oh, wrong answer."],[1026,1113,"Try again!"],[1564,1693,"Where is she?"],[1956,2168,"You think a puta like you"],[2168,2256,"can break me?"],[2394,2619,"I am Devorador de Esperanza!"],[2619,2773,"Oh, The Hope Eater, huh?"],[2836,2969,"Let's see you eat this!"],[3119,3228,"After I kill you,"],[3228,3365,"I'm going to burn down this whole"],[3365,3536,"building if I have to."],[3536,3687,"I will find Amy."],[4066,4229,"I talk! I talk!"],[4229,4325,"¡Por favor!"],[4325,4412,"¡Por favor!"],[4450,4642,"Where is she?"],[4642,4842,"Warehouse."],[4842,4963,"Global shipping."],[4963,5100,"And you're going to take me to her."],[6206,6373,"Arrest this loco bitch!"],[6373,6569,"Look what she did to me!"],[6681,6856,"She tore up my place,"],[6856,7023,"killed my security,"],[7023,7219,"and tortured my business partner."],[7219,7332,"I want her in jail."]],"37":[[187,437,"Was this much force necessary?"],[525,583,"Paperwork is going to"],[583,775,"be a bitch!"],[1009,1222,"You desk jockey."],[1222,1309,"You've been out of the field"],[1309,1472,"for too long."],[1576,1822,"You can come out now, girls."],[2314,2502,"This is the captain."],[2502,2577,"He's going to make sure"],[2577,2719,"that you all get home safe."],[2798,2848,"You're going down"],[2848,3015,"for sex trafficking."],[3061,3186,"Round them up."],[3186,3340,"Except for this one."],[3553,3691,"This one's mine."],[3691,3862,"Phoenix,"],[3862,4066,"bring Amy home."],[4066,4154,"Hooyah."],[4454,4596,"Call!"],[4704,4846,"Fold."],[4846,4942,"Call."],[4942,5080,"It's my lucky day, boys."],[5080,5205,"Full house."],[5455,5613,"Shit! Diego!"],[5705,5843,"Who the hell are you?"],[5905,5980,"Let him go!"],[5980,6177,"Before we gut you like a pig!"],[6177,6310,"Not until you bring me back"],[6310,6402,"my daughter,"],[6402,6527,"Amy Reagan."],[6702,6802,"Where is she?"],[7728,7824,"Amy?"]],"38":[[187,229,"End this bitch"],[229,329,"once and for all!"],[1522,1605,"You think a stick"],[1605,1864,"is going to save you?"],[2690,2806,"Idiotas!"],[2806,2915,"Puta!"],[3353,3611,"Let go of my brother."],[4074,4141,"Not until you bring me"],[4141,4283,"back my daughter."]],"39":[[221,287,"You're in no place"],[287,462,"to negotiate."],[462,588,"I brought in a champion"],[588,725,"to finish you off."],[771,1030,"Daga has never lost a fight."],[1872,2022,"If that beast gets a hold of you,"],[2022,2160,"it's all over."],[2681,2940,"Well, he's a frickin’ tank."],[3678,3941,"I can't breathe, I can't breathe."],[3991,4187,"Mom, I'm an adult."],[4187,4275,"M-mom..."],[4416,4679,"Those men did horrible things to me."],[4679,4771,"Amy..."],[4854,4942,"Don't pass out!"],[4942,5071,"You were so close."],[5071,5234,"You have to save Amy."],[6790,6848,"Holy shit."],[6919,7111,"She took out Daga!"],[7111,7236,"Go! ¡Ándale!"],[7236,7340,"Go!"],[7374,7478,"Idiota, why you push me?"],[7478,7565,"Go!"],[8062,8149,"Amy!"]],"40":[[158,287,"Amy."],[287,467,"Thank god I found you."],[467,658,"I'm going to take you home, sweetheart."],[1780,1864,"Why are you wearing"],[1864,2014,"my daughter's jacket?"],[2014,2193,"I'm...Amy gave it to me"],[2193,2285,"I was cold..."],[2344,2473,"She said you were coming,"],[2473,2594,"and now you're really here!"],[2594,2640,"But..."],[2798,2865,"but.."],[2948,3011,"Amy, she..."],[3011,3082,"Kiera!"],[3315,3465,"Where is my daughter?"],[3465,3632,"You know my name?"],[3712,3770,"It's because I've been"],[3770,3853,"looking for you too."],[3870,4024,"I-I'm so sorry!"],[4058,4287,"The evil woman took her!"]],"41":[[275,437,"Now, which one of you"],[437,613,"is Amy Reagan?"],[838,980,"Impressive."],[980,1167,"So loyal to the Phoenix's daughter"],[1167,1418,"in such a short time."],[2243,2277,"Stop hurting her!"],[2281,2356,"Stop!"],[2494,2619,"I'm Amy Reagan."],[2640,2723,"Finally."],[2761,2898,"The daughter of the legendary"],[2898,3065,"Phoenix in my grasp."],[3128,3224,"Did you know I was your age"],[3224,3328,"when I watched your parents"],[3328,3474,"kill my father?"],[3541,3703,"Then he must have deserved it."],[3978,4195,"Where is your mother now, huh?"],[4266,4504,"You know, I could break you."],[4504,4642,"I could break every bone"],[4642,4750,"in your body..."],[4754,4942,"and nobody would stop me."],[5055,5238,"Or, I could give you to"],[5238,5459,"my soldiers to play with"],[5459,5547,"and watch them break"],[5547,5676,"you like a toy?"],[5676,5768,"My mother really scares"],[5768,5943,"the shit out of you, doesn't she?"],[6118,6293,"You're not dead yet"],[6293,6544,"because I allow you to live."],[6598,6748,"I do have my eyes on a"],[6748,6848,"much bigger prize."],[6898,7036,"Yet, turns out your grandmother"],[7036,7194,"thinks you're worth $1 billion."],[7311,7444,"I don't have a grandmother."],[7444,7607,"Oh, yeah you do."],[7607,7786,"Your deceitful warrior mother"],[7786,7982,"kept her from you."],[7982,8233,"And I think it's time for a family reunion."],[8320,8441,"Take her!"],[8771,8929,"This can't be happening."],[8929,9180,"Simone Navarro has my daughter."],[9217,9267,"Lydia,"],[9267,9455,"you meddling, arrogant fool."],[9455,9584,"You have made a deal with the devil."]],"42":[[604,654,"Yeah..."],[709,880,"You got three broken ribs."],[880,980,"Come on Rikshaw."],[980,1046,"Come on."],[1172,1309,"Ah, just wrap them."],[1355,1472,"Oh, we don't do that anymore."],[1472,1593,"You can get pneumonia."],[1593,1697,"We actually recommend three"],[1697,1881,"to six weeks, no movement,"],[1881,1964,"minimum."],[1981,2189,"Oh, that's, that's not going to happen."],[2469,2548,"You're running on fumes,"],[2548,2677,"Admiral."],[2706,2848,"I mean, Phoenix."],[2957,3044,"Eat this."],[3194,3307,"Thanks, Sheriff."],[3424,3482,"You're alright."],[3482,3661,"Glad you think so, missy."],[3661,3774,"Just hope my favorite diner will"],[3774,3920,"still welcome me when all this nasty"],[3920,4029,"business is over."],[4216,4366,"Deal."],[4671,4725,"Rikshaw!"],[4725,4850,"What do you got for me?"],[4871,5121,"Lydia Ford booked a flight to Tijuana."],[5121,5351,"Viktor Navarro's old hacienda is there."],[5555,5613,"I-I need a way"],[5613,5751,"to get inside."],[5751,5910,"And we will find it, Phoenix."],[5910,6064,"I got your back."],[6064,6243,"For Conrad's daughter."],[6243,6343,"For Amy."],[6727,6894,"Excellent, Rikshaw."],[6894,7065,"You'll be handsomely rewarded."]],"43":[[379,550,"Excellent, Rikshaw."],[550,592,"You'll be"],[592,717,"handsomely rewarded"],[717,913,"once Phoenix is out of the picture"],[913,1176,"and I get my heir back."],[1251,1509,"Thank you, Mrs. Ford."],[1680,1864,"Miss Navarro."],[1864,1997,"Señora Ford."],[1997,2110,"What's that saying?"],[2110,2273,"The enemy of my enemy"],[2273,2377,"is my friend?"],[2448,2615,"It's all been arranged."],[2615,2811,"Phoenix doesn't have a clue."],[2811,2907,"Great."],[2907,3103,"We'll make the trade when you get here."],[3103,3257,"I'm not coming."],[3257,3315,"My men-"],[3315,3578,"No, no, not your men."],[3653,3803,"You, in person,"],[3803,4054,"Señora Ford."],[4054,4266,"That's unnecessary."],[4266,4508,"But, fine."],[4508,4725,"Just have my granddaughter ready."],[4725,4984,"What about poor Amy's mother?"],[5092,5255,"She's all yours."],[5338,5392,"Of course,"],[5392,5655,"Señora Ford."],[5872,6131,"It's quite a family you got there."],[6202,6297,"Doesn't it make"],[6297,6406,"you even more eager"],[6406,6548,"to meet your dear grandmother?"]],"44":[[842,942,"When your mind is telling"],[942,1113,"you that you're done,"],[1138,1409,"you're only 40% done."],[2239,2423,"As your class valedictorian,"],[2423,2560,"I salute you."],[2560,2665,"Cheers to us!"],[2665,2731,"Congratulations!"],[2731,2852,"We made it."],[4066,4195,"Soon your mother will be"],[4195,4283,"joining you."],[4283,4533,"I've got a spot all ready for her."],[4909,5013,"Stay away, Mom!"],[5013,5130,"It's a trap!"],[5130,5280,"Please don't come for me!"]],"45":[[517,775,"Hurry up!"],[892,1155,"Got another one here to sell."],[1201,1355,"I've never had a redhead before."],[1355,1388,"Yeah."],[1388,1584,"Get in line, buddy."],[2494,2635,"The old Don converted the basement"],[2635,2727,"into a dungeon."],[2727,2802,"That's where they're going to be"],[2802,2923,"keeping Amy."],[3007,3265,"Lock and load, Admiral."],[4191,4266,"Rikshaw!"],[4266,4525,"Retreat! I think they know we're here."],[4571,4729,"It's because I told them."],[5125,5276,"Sorry, Phoenix."],[5276,5384,"The money was too good"],[5384,5497,"to resist."],[5543,5634,"You're.."],[5634,5772,"working for..."],[5843,5943,"cartel?"],[6297,6406,"No..."],[6481,6652,"he works for me."],[6881,7165,"Simone and I have an understanding."],[7165,7386,"You can't trust Navarros..."],[7795,7916,"That's better."],[7916,8108,"Now I can see your face."],[8429,8571,"Now don't be a sore loser,"],[8571,8692,"Phoenix."],[8733,8913,"Remember me, Puta?"],[9079,9255,"Because I sure as hell remember you."],[10005,10097,"Payback's a bitch."]],"46":[[0,171,"That's right."],[171,442,"Daga got you good in that fight."],[867,1071,"Now that our business is complete,"],[1071,1209,"I'll take my granddaughter"],[1209,1338,"and go."],[1351,1518,"You can leave."],[1789,1989,"but Baby Phoenix stays."],[1989,2202,"That's not what we agreed on."],[2202,2310,"Did you know that your son"],[2310,2419,"was the one who dealt"],[2419,2577,"my father his final blow?"],[2602,2773,"What? My s-"],[2773,2952,"My Conrad?"],[2952,3069,"And then I stabbed him right"],[3069,3199,"in the heart."],[3315,3586,"You...you-"],[3603,3891,"You killed my precious son?"],[3891,3945,"As he died,"],[3945,4158,"my father promised that the Navarro"],[4158,4383,"Cartel would rise stronger than ever."],[4383,4487,"And that I would be the"],[4487,4654,"sword for his vengeance."],[4733,4934,"That has nothing to do with me."],[4934,5100,"But it does."],[5100,5226,"I believe my family's"],[5226,5372,"due compensation for"],[5372,5426,"our loss."],[5530,5797,"The entire Ford fortune will do nicely."],[5872,6202,"I have already paid you $1 billion."],[6243,6343,"That's more than enough"],[6343,6439,"for the likes of you."]],"47":[[54,325,"How the mighty have fallen."],[329,483,"You will be joining Phoenix"],[483,579,"and your granddaughter"],[579,754,"in the dungeon."],[767,967,"I have a weak heart."],[967,1067,"Don't worry."],[1067,1338,"My cousins are expert at torture."],[1426,1564,"They will make sure you stay alive"],[1564,1643,"long enough"],[1643,1839,"to watch Phoenix break"],[1839,1981,"under excruciating pain."],[2052,2264,"Then your beloved granddaughter."],[2264,2377,"And once you're the last"],[2377,2535,"one of your family alive,"],[2569,2736,"you will sign over everything"],[2736,2836,"you own to me."],[2869,3136,"Or you will suffer their same fate."],[3286,3557,"Enjoy your family reunion."],[3795,3937,"Rikshaw."],[3937,4062,"Do something!"],[4062,4320,"I paid you millions!"],[5025,5142,"You don't seem too choked up"],[5142,5326,"over the fate of your former employer."],[5326,5459,"Lydia Ford is a rich cunt who"],[5459,5626,"treats everyone like shit."],[5626,5701,"No wonder Conrad"],[5701,5922,"joined the military to get escape from her."],[5997,6172,"Now, I've been trying to infiltrate"],[6172,6414,"the Special Forces for quite some time."],[6414,6473,"They've proven..."],[6569,6840,"difficult...until you."],[6902,7065,"How did she persuade you?"],[7444,7657,"Mucho dinero."],[7707,7870,"That can be arranged."]],"48":[[0,125,"Mom! No!"],[312,579,"Let her go."],[1451,1609,"There you are, sweetheart."],[1609,1710,"Just hold on..."],[1755,1876,"I'm here..."],[1968,2127,"Move, you old cunt!"],[2894,3078,"I'll give you..."],[3123,3390,"I'll give you $10 million"],[3390,3545,"to release me."],[3670,3807,"$50 million"],[3807,3916,"to release my granddaughter"],[3916,3966,"and me."],[4208,4479,"$100 million."],[4550,4667,"Your money..."],[4667,4896,"It's no good here, bitch."],[5630,5901,"You have Conrad's eyes..."],[5989,6068,"Okay."],[6068,6235,"Don't worry, Amy."],[6235,6460,"Everyone has their price."],[6460,6631,"I'll buy our way out of here,"],[6631,6802,"and then you'll live as you should"],[6802,6856,"with me."],[6911,7182,"Sole heir of the Ford estate."],[7361,7411,"Your money's"],[7411,7682,"no good here, bitch."]],"49":[[542,642,"Hmm..."],[754,942,"She's already half dead."],[988,1076,"We can keep it that way"],[1076,1205,"a little longer."],[1288,1380,"No, no, no, please."],[1380,1518,"Please stop."],[1518,1655,"I don't know who you think she is, but"],[1655,1776,"you've got it all wrong, okay?"],[1776,1864,"She's just my mom."],[1864,1951,"Please."],[2268,2494,"Is that what she told you?"],[3674,3774,"You gonna scream for us"],[3774,3916,"good, Mami? Huh?"],[3916,4183,"My brother likes it when bitches get loud."],[4245,4479,"I do."],[4621,4813,"Gets me excited."],[5234,5296,"Gotta wake this"],[5296,5392,"Puta up."],[5605,5676,"I want to see the hope"],[5676,5839,"die in her eyes."],[6418,6506,"Five."],[6506,6610,"Four."],[6610,6677,"Three."],[6677,6752,"Two."],[6823,6886,"One."]],"50":[[2740,2932,"See you in hell, cock sucker."],[3841,3983,"You want to be excited?"],[4133,4287,"Try this."],[4371,4450,"Puta!"],[5472,5530,"Hon!"],[5593,5755,"Mom, is that really you?"],[5755,5893,"It's me, Amy."],[5976,6101,"I don't understand."],[6485,6685,"I'm a Navy SEAL Admiral,"],[6685,6748,"and my real name is"],[6748,6815,"Phoenix Ryan."]],"51":[[79,283,"I'm a Navy SEAL Admiral,"],[283,483,"and my real name is Phoenix Ryan."],[483,588,"I'm sorry that I didn't tell you"],[588,671,"about this earlier,"],[671,975,"and I hope you can forgive me."],[1001,1046,"Forgive you?"],[1046,1071,"Mom,"],[1071,1155,"You saved my life."],[1155,1380,"You're a badass."],[1380,1493,"Thank heavens."],[1493,1605,"Now let's get out of here."],[1605,1726,"No! Leave her."],[1726,1826,"I overheard her earlier."],[1826,1964,"She wanted you dead."],[2114,2318,"We don't do that, Amy."],[2318,2498,"That's not who we are."],[2706,2965,"We leave no man behind."],[3232,3407,"No matter what."],[3574,3674,"Alright, let's go."],[3674,3782,"Come on."],[3782,3937,"Let's go."],[4287,4391,"I hope you boys saved a"],[4391,4512,"little blood for me to spill..."]],"52":[[429,588,"It's about time."],[692,796,"You make a pretty convincing"],[796,984,"double agent there, Rikshaw."],[1159,1322,"I don't understand."],[1447,1518,"Think your mom came in here"],[1518,1626,"without a plan?"],[1705,1830,"Phoenix always has a plan."],[1926,2164,"But I paid you millions to betray her."],[2239,2352,"And the Wounded Warrior Project"],[2352,2565,"is very grateful for the large donations"],[2565,2740,"you've made over the years."],[3336,3424,"Chopper's on the way."],[3424,3553,"15 minutes."],[3553,3695,"Alright, move out."],[4279,4408,"Get them to the extraction point."],[4408,4529,"It'll buy you some time."],[4529,4592,"You sure?"],[4671,4708,"No Mom,"],[4708,4863,"I'm not going to leave you."],[4917,5063,"Get Amy out of here now!"],[5063,5159,"Rikshaw!"],[5367,5484,"Now I know what Conrad"],[5484,5597,"saw in you."],[5705,5776,"Protect Amy."]],"53":[[1868,2039,"It's all over for you, Phoenix"],[2039,2135,"Ryan."],[2135,2394,"You may have helped the old bitch escape,"],[2394,2627,"but I still have a billion of her dollars."],[2627,2781,"A billion dollars"],[2781,2936,"to expand the Navarro empire."],[2969,3098,"I will realize my"],[3098,3219,"father's dream and"],[3219,3382,"become the most powerful cartel"],[3382,3541,"the world has ever known."],[3611,3849,"Then I will hunt down your weak daughter"],[3891,4133,"and skin her alive."],[4133,4404,"But you'll be too dead to see it."],[4450,4637,"Say hello to Conrad Ford for me."]],"54":[[525,704,"Say hello yourself, bitch."],[1259,1343,"What?"],[1343,1614,"She's going on for too long."],[1614,1839,"You sound just like your father."],[2886,2977,"Let's go home."],[3028,3094,"Let's go home."],[3094,3161,"Okay."],[3207,3265,"Let's go."],[3628,3741,"Hi!"],[3741,3978,"I'm Kiera, your waitress."],[3999,4241,"Can I get you started with some drinks?"],[4354,4554,"Now, are you sure about this?"],[4554,4779,"Harvard will still take you."],[4779,5005,"Your grandmother did pay them $50 million"],[5005,5213,"to hold your spot forever."],[5880,6035,"I'm sure. I want to follow"],[6035,6160,"in my parents' footsteps."],[6268,6343,"I'm so proud of you"],[6343,6381,"sweetheart."],[7695,7849,"Watch out, bad guys."],[7857,7937,"Here I come."],[7995,8066,"Hooyah!"]]}