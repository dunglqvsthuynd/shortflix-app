{"1":[[25,187,"Congratulations, Miss Parker."],[187,487,"You're eight weeks pregnant."],[521,579,"What?"],[633,934,"I can't even afford to feed myself."],[946,1213,"How can I be pregnant?"],[1213,1312,"Just to remind you"],[1312,1693,"our state doesn't allow abortions."],[2523,2823,"I'm sorry."],[2836,2907,"I'm sorry."],[2907,3207,"I have to finish university."],[3274,3370,"I need to escape this"],[3370,3464,"hellhole of a home,"],[3464,3670,"I can't–"],[3774,4074,"I can't keep you."],[4888,4999,"Dad!"],[4999,5188,"Did you take my money?"],[5201,5392,"Shut up!"],[5392,5672,"You're nothing but a damn stepdaughter."],[5672,5867,"If I hadn't taken you in,"],[5867,5980,"you'd be dead."],[6093,6393,"If anything, you owe me that money."],[6402,6610,"Exactly."],[6610,6856,"Fuck off! I'm on a kill streak."],[6856,7036,"Stop bothering us while we're gaming."],[7036,7132,"That money"],[7132,7216,"is for my tuition"],[7216,7369,"and all of my living expenses."],[7369,7447,"What am I supposed to do"],[7447,7615,"to survive without that?"],[7615,7778,"Who the hell cares?"],[7778,7953,"If you're short on cash,"],[7953,8254,"go sell yourself."]],"2":[[0,188,"Now my only hope is that man"],[188,421,"from that night..."],[2289,2473,"Hi."],[2473,2635,"May I sit here?"],[2831,3107,"Leave."],[3107,3378,"Oh my God!"],[3378,3511,"Come on, Edward."],[3511,3807,"You just let a pretty girl go again man."],[3807,3999,"Dude, there's more to life than just work."],[3999,4154,"I mean, you're 29 years old"],[4154,4346,"and you haven't had a relationship."],[4425,4554,"Seriously?"],[4554,4829,"What kind of girl do you actually want?"],[4829,4971,"Where ya going?"],[4971,5156,"You said I could leave if I finished the drink."],[5156,5192,"Hey!"],[5192,5330,"Let go of me!"],[5330,5376,"What the fuck?"],[5376,5676,"- Let go! - Hey!"],[5839,6139,"So that's the kind of girl you like."],[6147,6181,"Got it."]],"3":[[0,141,"Hey!"],[241,300,"Fuck off!"],[342,408,"Fuck off!"],[408,496,"You know her?"],[496,657,"Unless you want to fucking die."],[657,709,"Go!"],[1188,1468,"You okay?"],[1468,1747,"Yeah."],[1747,1851,"Thank you."],[1851,1957,"Oh!"],[1957,2168,"My friend's just quite drunk."],[2248,2506,"I have to have a meeting I have to attend to,"],[2506,2625,"but I need some help"],[2625,2802,"bringing him up to his hotel room."],[2836,2969,"Here's his key card"],[2969,3183,"and I will make sure I give you"],[3183,3320,"some payment for this. Okay?"],[3320,3588,"Thank you so much."]],"4":[[1322,1480,"Don't be afraid."],[1480,1776,"I won't hurt you."],[1810,1956,"I want to give you this."],[1976,2052,"Why?"],[2193,2364,"Oh, no."],[2364,2665,"I'm not here to sell myself."],[2677,2852,"Look."],[2852,3090,"Everything that happened was"],[3090,3324,"my fault. So"],[3324,3624,"consider compensation."],[3699,3766,"Really? It's okay."],[3766,3937,"I don't need it."],[3937,4162,"This whole night was just a mistake."],[4162,4462,"We can forget this ever happened."],[4662,4817,"Alright"],[4817,5117,"then..."],[5226,5526,"Take my card."],[5705,5855,"Call me anytime."],[6664,6781,"I'll see ya."],[7161,7399,"Oh right, he left a business card!!"],[7728,7850,"Maybe it's fate"],[7850,8024,"wanting to keep you by my side."],[8024,8237,"You are my only family now."],[8237,8299,"No matter what,"],[8299,8457,"I will do everything I can"],[8457,8608,"to take care of you."],[8800,8908,"You're coming with us!"],[8908,9059,"Get off of me! What are you doing?"]],"5":[[41,120,"Get off!"],[120,258,"Just want to talk, okay?"],[258,325,"We're just–"],[1334,1484,"Open the door!"],[1622,1910,"Please pick up!"],[1910,1989,"El!"],[2406,2527,"Hello?"],[2527,2752,"Hi."],[2752,2877,"It's me."],[2877,3178,"I'm in the storage room at the bar."],[3178,3311,"Please help me..."],[3311,3495,"They're coming after me."],[3549,3667,"Where's the storage room?"],[3667,3710,"Hey!"],[3710,3807,"Where's the storage room?"],[3807,3970,"What's going on?"],[4713,4833,"No no no no!"],[4833,5067,"You fucking bitch!"],[5067,5334,"Finally found you!"],[5334,5447,"You're coming with us."],[5447,5672,"Get off of me! What do you want?"],[5672,5914,"El, you hit the jackpot."],[5914,6214,"A casino boss really likes you."],[6247,6452,"No, you can't sell me to the casino Dad."],[6452,6669,"No, you can't do that."],[6785,6890,"Shut up!"],[6890,7169,"I raised you all these years."],[7169,7449,"Now it's time for you to repay me."],[7449,7570,"Take her."],[7570,7736,"No! No! Get off of me!"],[7736,7991,"Get off me! No! No!"],[7991,8174,"Help me! Somebody help me! Please!"],[8174,8337,"I'm pregnant!"],[8337,8625,"I'm pregnant."],[8625,8654,"What?"]],"6":[[0,154,"I'm pregnant!"],[154,446,"I'm pregnant."],[446,575,"What?"],[575,729,"The fuck?"],[729,955,"I'm pregnant..."],[955,1101,"You can't sell me."],[1101,1205,"You can't sell me"],[1205,1401,"because nobody's gonna want a pregnant woman."],[1505,1797,"You shameless slut!"],[1797,2097,"You just cost me $10,000."],[2139,2439,"You ruined everything!"],[2606,2752,"Dad! Dad! Dad!"],[2752,2973,"Come on. We can take care of this."],[2973,3061,"No one will know."],[3061,3361,"No, no, you can't do that."],[3374,3486,"No, no."],[3486,3641,"This is family to you now."],[3641,3791,"No you... Dad, please."],[3791,3970,"I promise, I'll give you anything."],[3970,4166,"I'll give you all of my money."],[4166,4375,"Please don't hurt my baby. Please!"],[4375,4579,"Please don't hurt my baby. Please!"],[4579,4642,"Hurry up."],[4642,4717,"Get up!"],[4717,4917,"And come with us and get this abortion,"],[4917,5134,"or I will beat you until you miscarry."],[5426,5547,"Step aside, Dad."],[5547,5780,"Let me handle this one."]],"7":[[517,596,"Is that bastard?"],[596,771,"She's carrying yours?"],[917,1076,"You actually came."],[1438,1626,"You're pregnant?"],[1626,1839,"It's your baby, I'm sorry."],[2181,2323,"Make them pay."],[2510,2598,"What? No, no, no, no!"],[2986,3140,"Her mother passed away."],[3140,3343,"Those two bastards are her stepfather"],[3343,3486,"and stepbrother."],[3486,3616,"She must have had a hard life."],[3616,3757,"Hey, relax."],[3757,3912,"You're safe."],[3912,4166,"It's just me."],[4166,4291,"Look, your baby's fine."],[4291,4421,"Okay?"],[4421,4700,"So just chill out."],[4700,4875,"It's mine, right?"],[5042,5255,"I'm so sorry."],[5255,5288,"I'm so sorry."],[5288,5426,"I know it was an accident, but please don't"],[5426,5534,"make me get rid of the baby."],[5534,5647,"Calm down."],[5647,5943,"Look, I'm not going to get rid of the baby."],[5943,6197,"Nobody can, okay?"],[6197,6423,"Really?"],[6423,6673,"Of course."],[6673,6861,"Look, you can keep the baby."],[6861,7165,"But under one condition."],[7311,7419,"You have to live with me."]],"8":[[29,600,"Obviously, you can't go back home, right?"],[600,796,"No."],[796,938,"I know that."],[938,1217,"I don't wanna go back there."],[1217,1351,"Then it's settled."],[1351,1651,"I'll get your things and you'll come with me."],[1810,2110,"Mr. Johnson."],[2781,3082,"I have one favor to ask you."],[3211,3355,"I really want to"],[3355,3536,"finish my studies as fast as possible."],[3591,3699,"Can I please,"],[3699,4108,"please go to school still during this?"],[4195,4437,"Of course."],[4437,4662,"Is that all you want?"],[4662,4817,"Yeah. That's it."],[4817,4942,"Thank you,"],[4942,5184,"Mr. Johnson."],[5184,5484,"I'll see you."],[7036,7240,"This is your house?"],[7240,7474,"This is our house now."],[7474,7640,"Remember what I told you?"],[7640,7857,"Yes, I am your girlfriend."],[7857,8034,"We've been dating for six months,"],[8034,8233,"and we met at a bar."],[8233,8433,"Good. Now come on. They're waiting."]],"9":[[533,746,"Oh my goodness!"],[746,909,"You must be Ella!"],[909,1263,"Oh, I am Victoria, Edward's mother."],[1322,1626,"I've been waiting so long to meet you."],[1659,1848,"Oh, I never thought I'd be alive"],[1848,2014,"to meet my grandchild."],[2018,2243,"Mom, don't get too excited."],[2243,2506,"We need to make sure the kid is Edward's."],[2506,2656,"Who knows if she's a liar?"],[2656,2827,"Candy!"],[2827,2915,"What?"],[2915,3123,"I mean she's obviously a gold digger."],[3123,3212,"And people like that"],[3212,3296,"will do anything"],[3296,3445,"to steal our family's money."],[3445,3582,"Candy Johnson!"],[3582,3724,"Where are your manners?"],[3724,3995,"Edward, I don't want someone like her"],[3995,4162,"as my sister-in-law."],[4162,4225,"She's not–"],[4225,4322,"Candy!"],[4332,4525,"You're being incredibly rude."],[4608,4763,"Don't mind her, dear."],[4763,5055,"Let's go shopping."],[5167,5326,"You"],[5326,5476,"stay here."],[5476,5672,"Reflect on your behavior."],[5780,5895,"What– I–"],[6610,6744,"Five thousand dollars?"],[6777,7011,"That's enough for me to live on for months!"],[7011,7177,"I am indeed,"],[7177,7353,"not in the same social class as them."],[7382,7661,"This dress would look great on you."],[7661,7757,"You should try it on."],[7857,7949,"No, it's too expensive."],[7949,8224,"It's fine, it's fine."],[8224,8512,"Do you know how happy you've made me?"],[8512,8725,"Do you know?"],[8725,8950,"You're my son's first girlfriend."]],"10":[[12,312,"I think you're my son's first girlfriend."],[412,729,"Such a rich and handsome man."],[729,967,"He's never been in love before?"],[967,1192,"Don't look so surprised."],[1192,1493,"He's had that poker face since childhood."],[1509,1685,"Way too serious."],[1685,1830,"Never any fun."],[1830,2089,"Never dated any girls."],[2089,2360,"Actually used to think he was gay."],[2360,2423,"Mom!"],[2652,2877,"Oh, sweetheart."],[2877,3086,"Do you know how precious you are?"],[3086,3390,"You're the first girl that he let close."],[3432,3732,"And now you're even having his baby."],[3799,3970,"Look."],[3970,4108,"Don't worry."],[4108,4408,"She spends a lot of money on whoever she likes."],[4412,4646,"Oh, look, about this baby."],[4646,4808,"I swear it is yours."],[4808,5050,"I'm not trying to trick you into giving me money"],[5050,5251,"or anything."],[5251,5413,"I know."],[5413,5663,"You had my number and didn't misuse it."],[5663,5864,"I trust you."],[5864,6164,"We'll take all of these."],[6172,6510,"That'll be $1,070,000 please."],[6510,6810,"That is way too much money!"],[7966,8029,"Sir,"],[8029,8261,"should I put these clothes in your bedroom?"],[8383,8500,"His room?"]],"11":[[8,63,"Sir,"],[63,308,"should I put these clothes in your bedroom?"],[408,709,"His room?"],[738,875,"Guest room."],[875,1038,"Oh. Guest room?"],[1038,1167,"Yeah."],[1167,1317,"There's"],[1317,1547,"reasons."],[1547,1768,"Okay."],[1768,2064,"She'll show you to your room."],[2114,2248,"Have a good night."],[2248,2548,"You too."],[3541,3883,"Five thousand dollars!"],[5826,6035,"What happened?"]],"12":[[4,133,"What happened?"],[596,725,"Um..."],[909,1034,"Don't look!"],[1034,1134,"I didn't see anything."],[1134,1322,"I didn't see a thing."],[1322,1559,"I didn't look at anything. I missed it."],[1559,1655,"Everything that happened."],[1655,1714,"I'm sorry."],[1714,2014,"Wait! Stay there."],[2106,2318,"Okay."],[2318,2464,"You're decent?"],[2464,2494,"Yeah."],[2494,2794,"What's up?"],[3019,3319,"I brought this for you."],[3474,3749,"Why? I don't need that."],[3749,3903,"I know you don't need it."],[3903,4120,"But look"],[4120,4279,"having money"],[4279,4458,"makes things easier."],[4458,4721,"Besides, you're pregnant, okay?"],[4721,5021,"Do it for the sake of the baby."],[5447,5668,"Okay."],[5668,5830,"For the sake of the baby."],[6156,6297,"Good morning."],[6297,6531,"Is there any breakfast left?"],[6531,6690,"Of course there is."],[6690,6990,"But could you get me a cup of coffee first?"],[7278,7578,"Sure."],[8525,8671,"Thanks."]],"13":[[492,742,"Oh."],[742,946,"Why did you do that?"],[946,1146,"You shameless bitch!"],[1146,1447,"Do you really think you belong in this house?"],[1459,1579,"If you weren't pregnant,"],[1579,1864,"there's no way you could have moved in."],[1864,2118,"Know your place. Gold digger."],[2118,2469,"Once you have the baby, you have to fuck off!"],[2510,2676,"In a way, she's right."],[2676,2923,"Everything I got is because of this kid."],[3199,3424,"Professor Wilson,"],[3424,3724,"about the internship with SnackAI."],[3753,4024,"When can I go?"],[4024,4141,"Well, there have been"],[4141,4437,"some changes in the arrangement."],[4546,4646,"Ella."],[4646,4708,"Actually, you're not"],[4708,5009,"the person intended for the internship."],[5009,5309,"What? But I–"],[5376,5626,"I have the highest GPA."],[5626,5851,"Considering more than just grades."],[5851,6035,"There are other factors."],[6035,6135,"Professor."],[6135,6435,"You don't need to explain that much to this poor,"],[6523,6777,"whatever she is."],[6777,7027,"That internship slot"],[7027,7144,"is mine."]],"14":[[112,241,"You can go now."],[241,400,"- I'll talk to her. - I'm so sorry, Ella."],[400,517,"There's always next year."],[517,679,"Sure."],[1159,1443,"Are you serious?"],[1443,1751,"Penny you failed, like, three classes last semester."],[1751,1914,"How did you get this spot?"],[1914,2177,"The president's my dad."],[2177,2356,"He rules."],[2356,2485,"I'm reporting you."],[2485,2681,"Oh please."],[2681,2861,"Do you really think"],[2861,3015,"anybody's going to listen to you?"],[3174,3390,"They chose me over you"],[3390,3691,"because you are a nobody."],[3749,3883,"Oh my God."],[3883,4020,"Look at her clothes."],[4020,4320,"This loser finally bought fakes."],[4375,4587,"Ew, seriously?"],[4587,4842,"You really have no shame."],[4842,5009,"They're not fake."],[5009,5113,"Please."],[5113,5207,"Do you even know"],[5207,5401,"how much the real one costs?"],[5401,5655,"You can't even afford a bottle of water."],[5655,5839,"This can't be real."],[5839,6106,"Wait, I think this is real."],[6106,6202,"What? Wait."],[6202,6464,"This is, this is real."],[6464,6752,"This is the designer's latest piece."],[6752,6927,"I can't even get that!"],[6927,7086,"How do you have this?"]],"15":[[4,145,"Mr. Johnson."],[145,325,"Thanks to our collaboration,"],[325,588,"our school has grown exponentially."],[588,838,"There are so many changes happening on a daily basis,"],[838,1013,"I can't even keep track of them all."],[1013,1209,"We now have a music program."],[1209,1326,"I never thought we would have a music program..."],[1326,1564,"Ella should be in school at this time..."],[1564,1793,"How did you get this dress?"],[1793,1885,"None of your business!"],[1889,2102,"Okay, just let go of me."],[2102,2323,"I see how this is."],[2323,2598,"You are making money from OnlyFans."],[2598,2686,"Or"],[2686,2861,"do you have a sugar daddy?"],[2861,3082,"That makes sense."],[3082,3282,"I can't believe our school has someone as"],[3282,3520,"shameless as you."],[3520,3661,"You think just because I'm poor,"],[3661,3912,"you can slander me like this?"],[3912,4111,"Absolutely I can."],[4131,4340,"See, we all know"],[4361,4554,"that you are nothing"],[4617,4917,"but a low life girl."],[5180,5405,"Strip her."],[5405,5593,"See, trash like you"],[5593,5860,"doesn't get to wear expensive things like that!"],[5860,6047,"Get your hands off of me! What are you doing?"],[6047,6310,"I am helping you advertise for yourself."],[6310,6552,"I am a great photographer."],[6552,6715,"Wait! Look at me."],[6715,6769,"Smile!"],[6769,6969,"This is going to be your new profile picture."],[6969,7023,"Hey!"],[7119,7215,"Get off of her!"],[7215,7515,"Give me that! Get off!"],[7841,7953,"Are you okay?"],[8124,8420,"Who the hell are you?"],[8420,8583,"And who the hell are you?"]],"16":[[20,171,"Who the hell are you?"],[171,404,"Her sugar daddy?"],[404,517,"Shut up!"],[517,743,"How dare you speak to Mr. Johnson that way?"],[743,888,"Mr.–"],[888,994,"Johnson?"],[994,1188,"Isn't he one of our school's board members?"],[1255,1384,"No way."],[1384,1481,"You really think"],[1481,1725,"they would give the SnackAI internship"],[1725,1881,"to me if he was?"],[1918,2248,"So, it was you who took her spot."],[2356,2498,"So what?"],[2498,2623,"What are you going to do about it?"],[2623,2894,"Hey! What is going on in here?"],[2894,3019,"Daddy?"],[3019,3332,"This shameless woman has been bullying me"],[3332,3632,"and she brought her sugar daddy to school."],[3699,3999,"You must kick her out."],[4137,4396,"Shut up! Oh!"],[4396,4537,"Don't embarrass me like this."],[4537,4633,"Now listen."],[4633,5075,"Mr. Johnson is the chairman of the school board."],[5121,5367,"Now, you need to apologize to him right now."],[5367,5484,"- Really? I can not believe. - You are embarrassing me."],[5484,5588,"Now do it now!"],[5855,5899,"Mr–"],[6139,6222,"Mr. Johnson."],[6418,6719,"I am so sorry."],[6777,7018,"I didn't know that this was you. Or you were you."],[7018,7132,"and I–"],[7132,7207,"Mr. Swift."],[7207,7419,"Your daughter has taken internship opportunities"],[7419,7537,"away from others,"],[7537,7645,"bullied students,"],[7645,7945,"and disrespected my girlfriend and myself."],[7974,8078,"What do you have to say about all this?"]],"17":[[0,225,"I, I, I know–"],[225,337,"All three of you are expelled."],[358,475,"Oh, no. You can't."],[475,669,"This university deserves a competent"],[669,804,"and fair president."],[804,842,"Daddy!"],[859,1159,"Wait. No, no. I apologize."],[1159,1288,"You're fired."],[1288,1659,"-No. No no... -No no..."],[1680,1797,"Listen. I'm sorry."],[1797,2173,"Listen, I'll get back what's yours."],[2173,2469,"Thank you."],[2469,2769,"They bully you often?"],[2819,2952,"For people like me"],[2952,3265,"who don't have money and connections,"],[3445,3602,"this kind of thing just happens a lot."],[3602,3816,"And if I fight back, it just"],[3816,3924,"gets worse."],[3924,4087,"Ella,"],[4087,4270,"listen to me."],[4270,4571,"Next time they bully you, fight back."],[4629,4921,"No matter the consequence."],[4921,5080,"Hey."],[5080,5284,"I never thought being poor was a reason to be bullied."],[5296,5359,"Okay?"],[5359,5655,"Your wealth doesn't define your worth."],[5764,6064,"Next time they bully you, fight back."],[6147,6331,"You'll have my support."],[6331,6531,"Okay."],[6531,6831,"Thank you."],[7215,7286,"Oh, look."],[7315,7615,"A shameless little rat trying to steal food."],[7628,7882,"- What? - You're just a freeloader."],[7882,8124,"If you want food, clean the house and earn it."],[8400,8571,"You're the shameless one."],[8575,8733,"What the fuck?"],[8733,8850,"What did you just say?"]],"18":[[20,145,"What the fuck?"],[145,337,"What did you just say?"],[337,474,"You're bullying me,"],[474,652,"and you're trying to get me to do"],[652,875,"all of your work too."],[1134,1338,"I see you're just playing the victim."],[1338,1618,"That's your usual trick, huh?"],[1618,1793,"You can't fool me."],[1793,2093,"I know you're a shameless bitch."],[2164,2277,"Well, dirty heart will see"],[2277,2456,"dirt everywhere."],[2456,2577,"You!"],[3778,3891,"Oh my God,"],[3891,4191,"how could you do that?"],[4304,4525,"What the hell is going on here?"],[4525,4650,"Oh, Miss!"],[4650,4896,"Ella smashed your favorite cup on purpose."],[4946,5238,"No, no, I didn't do that."],[5238,5538,"She's lying."],[5618,5868,"- Oh! - I know what happened."],[5868,6064,"Molly told you not to touch my stuff."],[6064,6243,"But you said that you're practically"],[6243,6348,"the owner of this house,"],[6348,6610,"so you could do whatever you want."],[6610,6756,"Oh, right."],[6756,6986,"And you insulted me, too."],[6986,7186,"Miss, we need to teach this bitch a lesson!"],[7186,7319,"Uh-huh!"]],"19":[[41,183,"Molly, what do you want?"],[183,250,"Let go of me!"],[250,412,"I want you to get the hell out of my face!"],[1426,1651,"Who did it?"],[1651,1772,"It was you,"],[1772,1922,"wasn't it?"],[1922,2043,"So what?"],[2043,2198,"She deserved it."],[2198,2364,"You have two options."],[2364,2683,"One, slap yourself in the face"],[2683,2777,"and apologize."],[2848,2932,"Or–"],[2932,3007,"What?"],[3007,3119,"I'm your sister."],[3119,3420,"And you're asking me to slap myself for that bitch?"],[3574,3741,"Fine."],[3741,4016,"Then leave."],[4016,4300,"And you."],[4300,4379,"You're fired."],[4379,4525,"What?"],[4525,4767,"You're kicking me out for her?"],[4767,4913,"I'll tell mom."],[4913,5096,"Go ahead."],[5096,5284,"Won't make a difference."],[5284,5397,"Come on."],[5689,5926,"You know I will never accept her."],[5926,6051,"Never!"],[6297,6598,"Poor thing."],[6952,7061,"You okay?"],[7253,7486,"Sir, the ice pack."],[7486,7665,"Tell those two to leave now."],[7665,7966,"Right away, sir."],[8187,8370,"What did I tell you?"],[8370,8537,"If someone hits you,"],[8537,8743,"you hit them back."]],"20":[[66,358,"Hit them back?"],[358,538,"I did"],[538,642,"kind of fight back."],[642,942,"I mean, I yelled at Molly."],[1096,1255,"Good,"],[1255,1455,"but not good enough."],[1455,1639,"Listen to me."],[1639,1851,"If someone disrespects you,"],[1851,2000,"you make them pay."],[2000,2152,"Got it?"],[2252,2469,"What, I should be"],[2469,2836,"cold and serious and intimidating, like you?"],[2869,3011,"Yeah."],[3011,3169,"But"],[3261,3550,"I'm not that way to you, am I?"],[3561,3753,"No, no,"],[3753,4054,"you've always been kind to me."],[4333,4558,"Thank you, I can–"],[4558,4754,"I can hold it."],[4754,5025,"You're welcome. Hey."],[5025,5326,"I'll always have your back, okay?"],[6010,6239,"Sorry."],[6239,6531,"A call."],[6531,6694,"Hello?"],[6694,6909,"Got it."],[6934,6994,"Bye."],[7127,7248,"I, uh,"],[7248,7424,"have a meeting."],[7424,7549,"Okay."],[8362,8558,"I have something serious I want to ask both of you."]],"21":[[0,258,"Okay."],[258,421,"What's going on?"],[421,563,"Why are you here so early?"],[563,625,"Oh, well,"],[625,812,"of course, it's because you kicked me out"],[812,925,"for that woman."],[942,1038,"And that's just too–"],[1038,1134,"Candy!"],[1134,1341,"That is not the reason."],[1341,1434,"Edward."],[1509,1626,"Why are you and Ella"],[1626,1810,"sleeping in separate rooms at night?"],[1901,2064,"Did you do something to upset her?"],[2064,2164,"That's the point?"],[2164,2364,"Because we're not a real couple."],[2364,2623,"Okay."],[2623,2865,"Ella's pregnant."],[2865,2940,"I didn't want to bother her."],[2940,3186,"Good God, she's pregnant."],[3186,3449,"All the more reason to be in the room with her."],[3449,3670,"Taking care of her."],[3670,4029,"Edward, you have no common sense at all."],[4170,4318,"I'm going to set an appointment"],[4318,4446,"with a doctor"],[4446,4746,"for pregnancy class for both of you."],[4817,5071,"Right now."],[5071,5255,"Now!"],[5255,5372,"Go!"],[5580,5680,"We have to go."],[5847,6060,"Mom, what about me?"],[6060,6285,"You're not here to stand up for me?"],[6285,6481,"Candy,"],[6481,6568,"if you would just"],[6568,6798,"show a little bit more respect to Ella,"],[6798,6940,"I would let you move in."],[7061,7260,"Seriously? Mom."],[7260,7400,"That woman doesn't deserve"],[7400,7603,"to be a part of our family."],[7603,7857,"Charlotte is the perfect sister-in-law for me, Mom."],[7857,8020,"Mom, she's back from abroad now."]],"22":[[171,254,"Candy."],[254,442,"Do you know what you need?"],[442,548,"You need a class"],[548,930,"in how to respect other people."],[1005,1146,"I won't give up."],[1146,1263,"I only accept Charlotte."],[1263,1564,"I'm not taking that woman."],[1835,2135,"It's nothing serious, just a little malnutrition."],[2160,2531,"Are you experiencing frequent morning sickness?"],[2531,2594,"Yeah."],[2594,2798,"It's really uncomfortable."],[2798,3078,"Hey, you didn't tell me that."],[3078,3361,"Well, I didn't want to bother you."],[3361,3440,"No, no, no."],[3440,3741,"Pregnancy just isn't the woman's responsibility."],[3803,4004,"The husband plays a role, too."],[4004,4254,"Doctor, tell me everything"],[4254,4542,"I should be worried about."],[4542,4646,"Oh, and I know you young couples"],[4646,4821,"are probably curious."],[4821,5121,"Sex during pregnancy is completely fine."],[5246,5488,"But it should be based on the mother's comfort."],[5488,5789,"Don't be too rough."],[5801,6101,"Avoid the stomach."],[6118,6310,"The side positions"],[6310,6468,"are the best."]],"23":[[229,529,"So I'll just go to my room."],[596,704,"Sounds good."],[704,825,"Sorry, sir."],[825,1076,"Your mother instructed that from tonight on,"],[1076,1292,"you two must sleep in the same room together."],[1292,1443,"Oh."],[2439,2715,"So we have to share the same bed."],[2715,2865,"I mean, no, if you feel uncomfortable,"],[2865,3078,"just wait for Emma to fall asleep."],[3078,3378,"No, no, I want to."],[3507,3807,"I mean, it's fine."],[3899,4004,"Are you sure?"],[4004,4095,"Yeah."],[4095,4120,"Yeah."],[4120,4416,"I mean, at least the bed is big enough,"],[4416,4512,"Thankfully."],[4512,4717,"and nothing's gonna"],[4717,4821,"happen,"],[4821,4867,"right?"],[5038,5163,"She trusts me too much."],[5163,5463,"- What? - Nothing."],[5476,5776,"Nothing's gonna happen."],[7082,7236,"Goodnight."],[7236,7265,"Goodnight."]],"24":[[1805,2173,"Oh my God, waking up to such a handsome face."],[2173,2431,"It's dangerous for my heart."],[2460,2694,"Mr. Johnson, are you awake?"],[3065,3365,"Morning."],[3411,3712,"I have class."],[4800,4959,"Thank you for the ride,"],[4959,4996,"Mr. Johnson."],[5426,5726,"Ella?"],[5784,5880,"So she rejects me"],[5880,6181,"to cling to some rich guy."],[6343,6685,"Hey, don't call me Mr. Johnson."],[6685,6798,"Real couples,"],[6798,6961,"they don't do that."],[6961,7244,"Call me Edward."],[7244,7407,"Edward."],[7536,7682,"Good girl."],[7682,7828,"Come on."],[7828,8008,"Don't be late."],[8158,8341,"Shameless gold digger."]],"25":[[120,354,"Oh, everyone look!"],[354,546,"The bitch has arrived."],[546,613,"Hey, take a look."],[613,913,"What's wrong?"],[1317,1618,"Fealin' a little guilty?"],[1772,1939,"Good."],[1939,2027,"Not good enough."],[2027,2239,"If someone disrespects you,"],[2239,2398,"you make them pay."],[2398,2610,"What, I should be"],[2610,3023,"cold and serious and intimidating, like you?"],[3023,3082,"Yeah."],[3770,3891,"Did you do this?"],[3891,4029,"So what if I did?"],[4029,4308,"I'm just showing everyone your life with your geezer."],[4308,4483,"Shut up!"],[4483,4742,"He's my boyfriend. He's not just–"],[4742,4892,"You admit it."],[4892,5238,"You turned me down for some old dude."],[5255,5338,"Hop into bed."],[5338,5503,"You really know how to put up with a lot,"],[5503,5638,"don't you?"],[5722,5939,"Tell us, what's it like to have slept–"],[6306,6452,"Bitch!"],[6452,6752,"How dare you?"],[6756,6944,"You know, with what you've done."],[6944,7244,"I could easily sue you for defamation."],[7248,7545,"Okay, that's exactly what you are doing."],[7545,7671,"You want to try it?"],[7686,7720,"Do it."],[7903,8133,"Apologize to me, right now!"]],"26":[[70,187,"Fine."],[187,458,"Sorry."],[458,483,"Yeah!"],[483,784,"Watch your mouth! Idiot!"],[1276,1522,"Good job, Ella."],[1522,1822,"When did she get so tough?"],[1868,1904,"Sir,"],[1904,2116,"someone was spreading rumors about Miss Ella"],[2116,2199,"at school today,"],[2199,2410,"but it seems she took care of it herself."],[2410,2660,"Thank you."],[2740,3040,"So,"],[3040,3257,"did something happen today?"],[3257,3361,"You seem happy."],[3361,3657,"Is it that obvious?"],[3799,4099,"Okay."],[4170,4329,"Today at school"],[4329,4629,"someone was bullying me,"],[4650,4950,"but I took your advice,"],[4954,5255,"and I made them shut up."],[5367,5513,"That's good."],[5513,5709,"I'm proud of you."],[5709,6010,"No, seriously, though, it felt really good."],[6046,6122,"So I don't think you have to"],[6122,6290,"worry about me anymore."],[6331,6414,"I'm not going to get bullied."],[6414,6723,"I think I can take care of myself now."],[6765,7036,"Why do I feel a little upset?"],[7057,7323,"Look, tonight"],[7323,7607,"I have some business"],[7607,7862,"to tend to, so"],[7862,8045,"you should go to bed early."]],"27":[[29,279,"Oh, man,"],[279,346,"I can't believe you"],[346,592,"let Ella scare you like that."],[592,763,"That bitch."],[763,871,"I'm not letting this go."],[871,1092,"Ella is such a fake."],[1092,1251,"She acts all pure,"],[1251,1468,"but in the meantime, she's a freak in the bed."],[1468,1730,"Wait till I get the drugs man."],[1730,1780,"Whoa!"],[1780,1989,"Whoa whoa whoa."],[1989,2081,"So,"],[2181,2394,"you're Mark."],[2394,2602,"Mr. Johnson? Yes, I am,"],[2602,2644,"but why?"],[2644,2756,"Did I do something wrong?"],[2756,2919,"You were so tough in front of Ella."],[2919,3144,"What happened?"],[3144,3336,"She's your girlfriend?"],[3336,3428,"I had no idea."],[3428,3628,"I swear, I, I didn't know."],[3628,3870,"Please, please! Please! Wait!"],[3870,4020,"No, no, no, no!"],[4020,4062,"Get him!"],[4062,4362,"Please."]],"28":[[120,487,"You want me to go to the banquet with you?"],[554,725,"Of course."],[725,871,"You're my girlfriend."],[871,1172,"That's what couples do."],[1438,1680,"Unless, of course, you"],[1680,1818,"don't want to go."],[1818,2118,"No, no, I want to."],[2131,2402,"I just, I've never been"],[2402,2702,"to a banquet before."],[2719,2869,"Don't worry."],[2869,2973,"I'll handle it, but"],[2973,3274,"I should probably get you a dress first."],[4575,4750,"I mean, I've tried on so many."],[4750,4921,"Can't we just pick one?"],[4921,5176,"Well, I think they all look great."],[5176,5274,"Let's buy em'all."],[5274,5442,"Oh, no. What? No!"],[5442,5538,"No, that's too wasteful."],[5538,5709,"Let's just choose one."],[5709,5926,"Okay."],[5926,6015,"I'll choose the one"],[6015,6377,"that suits you best."],[6523,6652,"Try this one."],[6652,6952,"I think it'll be perfect."],[7574,7874,"Could you zip me up, please?"],[7891,7912,"Yeah."]],"29":[[1972,2127,"How do I look?"],[2127,2423,"Wow, you look,"],[2423,2723,"even more beautiful than I've ever imagined."],[3174,3365,"Your phone."],[4104,4149,"Sorry,"],[4149,4341,"I uh,"],[4341,4642,"I couldn't stop thinking about kissing you."],[4717,4929,"It's okay."],[4929,5080,"You should"],[5080,5296,"probably check that, though."],[5296,5405,"Yeah."],[5405,5647,"Something to deal with, I'll uh,"],[5647,5872,"have someone drive you home."],[5872,5947,"Bye."],[5947,6143,"Bye."],[7123,7294,"Candy, what are you doing here?"],[7294,7574,"Oh, you have no right to question me."],[7574,7782,"Oh, you shameless gold digger."],[7782,8016,"Showing your true colors now, huh?"],[8016,8270,"Using my brother's money on yourself."],[8662,8925,"Oh, beautiful."],[8925,9063,"I think I want this."]],"30":[[79,287,"No! That's my dress."],[287,588,"No. It's mine."],[638,938,"You sneaky little bitch."],[992,1192,"You know, don't think you've won."],[1192,1388,"Charlotte's back."],[1388,1488,"Charlotte?"],[1488,1543,"Yeah."],[1543,1864,"Charlotte Smith, the Smith family heir."],[1914,2106,"She's noble and elegant."],[2106,2394,"Edward's closest friend and working partner."],[2394,2594,"She's his perfect match."],[2594,2894,"You'll never be in her league."],[3015,3207,"Okay, well, that has nothing to do with me."],[3207,3336,"Well, once you give birth,"],[3336,3529,"my brother will kick you out of his house"],[3529,3687,"and then marry Charlotte."],[3699,3806,"Now you better get the hint"],[3806,4045,"and bail before you embarrass yourself,"],[4045,4191,"bottom feeder."],[4191,4417,"He really hasn't said what will happen to us"],[4417,4571,"after the baby's born."],[4592,4629,"Please,"],[4629,4783,"you're in no position to speak on this."],[4783,4988,"You've been kicked out already, so."],[4988,5137,"Oh, well,"],[5137,5288,"we'll wait and see about that."],[6147,6560,"Charlotte Smith, should I ask him?"],[6806,6940,"What's the matter?"],[6940,7015,"Can't sleep?"]],"31":[[100,400,"Can't sleep?"],[729,775,"Sorry,"],[775,1071,"did I wake you?"],[1071,1197,"Come on,"],[1197,1497,"what's the matter?"],[1872,2085,"Actually, I–"],[2085,2352,"Who is Charlotte?"],[2419,2719,"Is it about tomorrow's dinner?"],[3015,3219,"Yeah."],[3219,3428,"Hey, it's going to be"],[3428,3728,"a casual gathering, okay?"],[3741,3937,"Don't be worried."],[3937,4026,"I'll be there for you,"],[4026,4245,"alright?"],[4245,4350,"Okay."],[4350,4546,"Okay."],[4550,4683,"Goodnight."],[4683,4934,"Goodnight."],[4996,5130,"Yeah, Candy hates me."],[5130,5338,"I can't trust anything she says."],[5338,5588,"Edward would never do that."],[6402,6544,"Ah! Charlotte,"],[6544,6739,"you're finally here!"],[6844,6995,"Thank you bestie,"],[6995,7119,"is Edward here yet?"],[7119,7407,"Oh, well, he's always late, but don't worry."],[7407,7565,"You look stunning tonight."],[7565,7795,"He'll be all over you."],[7795,8095,"Hey. Edward's here."],[8116,8237,"Wait."],[8237,8537,"Doesn't he usually show up alone?"],[8541,8662,"Who is that girl?"]],"32":[[1301,1601,"Oh my God!"],[1601,1760,"Is Edward insane?"],[1760,2060,"Can't belive he brought that bitch here."],[2293,2594,"Come on, let's go over there."],[2977,3032,"Edward!"],[3032,3211,"Long time no see."],[3211,3332,"Charlotte,"],[3336,3636,"it's been a while."],[3645,3820,"Ella, this is Charlotte."],[3820,3978,"Charlotte, this is Ella,"],[3978,4066,"my girlfriend."],[4341,4458,"I'm Ella."],[4458,4688,"Oh, Ella."],[4688,4867,"I've never heard of you."],[4867,5038,"What family are you from?"],[5038,5380,"Oh, I'm just an ordinary girl."],[5384,5643,"I'm not from a rich family or anything."],[5751,5955,"Oh, you must have other talents, then."],[5955,6056,"What's your major?"],[6056,6318,"Charlotte. Enough!"],[6318,6594,"What are you trying to do, huh?"],[6594,6702,"What? I'm just trying to get"],[6702,6927,"to know your new girlfriend."],[7036,7298,"I'm studying computer science."],[7298,7436,"Oh, computer science."],[7436,7574,"Just the same as me and Edward."]],"33":[[204,504,"A lot of women try to use"],[521,732,"certain advantages to try"],[732,931,"and make their resume look better,"],[931,1117,"but I'm sure that's not you."],[1180,1280,"By the way,"],[1280,1580,"have you read the recent famous paper?"],[1597,1789,"On the ethical advantages"],[1789,2089,"of AI development for humanity?"],[2097,2352,"Was something wrong with it?"],[2352,2581,"Oh, it's very well written."],[2581,2669,"You should read it."],[2669,2969,"It might help you be more professional."],[3007,3307,"Well, actually."],[3495,3716,"I wrote it."],[3716,3862,"I'm really happy that you enjoyed it."],[3862,4162,"I'll definitely keep at it."],[4233,4367,"Yeah, well,"],[4367,4508,"we have business to tend to."],[4508,4808,"So, if you need any more advice from Ella,"],[4846,4945,"next time."],[5006,5146,"Goodnight."],[6873,7007,"Can I help you?"],[7007,7244,"Did you know that I'm Edward's ex?"]],"34":[[100,232,"No, Victoria told me–"],[232,379,"Oh,"],[379,588,"girls like you are the worst."],[588,942,"Always running to mommy for everything."],[1005,1115,"You know, Edward and I"],[1115,1276,"just had a little argument."],[1276,1435,"But we were supposed to be engaged,"],[1435,1576,"and then you–"],[1776,2010,"You sly little tramp."],[2010,2348,"You went and got pregnant, and stole my place."],[2627,2812,"You know, the only reason why he's been nice to you"],[2812,3028,"is because of the baby."],[3132,3361,"I'm not buying it unless he tells me himself."],[3361,3657,"Oh, stop avoiding reality."],[3691,3862,"Why do you think nobody's told you?"],[3862,4068,"It's because a pregnant woman's emotions"],[4068,4258,"affect the baby."],[4262,4412,"Let go of me!"],[4412,4471,"Ow!"],[4767,5063,"Yes. Fall!"],[5063,5363,"Take that bastard with you."],[5530,5830,"Are you okay?"],[6056,6356,"Thank you so much."],[6931,7048,"Owen!"],[7048,7119,"Ella!"],[7119,7374,"I can't believe it's you."]],"35":[[158,396,"I didn't expect to see you here."],[396,617,"It's been so long."],[617,728,"Owen Carter!"],[748,1038,"What are you doing with my girlfriend?"],[1038,1197,"Girlfriend?"],[1197,1351,"Is that true? Are you his girlfriend?"],[1351,1465,"You heard her,"],[1465,1580,"now"],[1580,1739,"we have business to tend to."],[1739,2081,"So, excuse us."],[2081,2110,"Ella,"],[2110,2410,"let's grab lunch sometime."],[2852,2990,"You don't seem to like"],[2990,3290,"Owen very much."],[3311,3611,"Owen? Are you two close?"],[3745,3953,"Ella,"],[3953,4254,"Owen is our company's largest competitor."],[4312,4416,"He's ruthless."],[4416,4517,"Ruthless?"],[4517,4804,"You shouldn't talk to him."],[4804,5267,"He's a senior in my major."],[5292,5492,"I mean, he's always been supportive,"],[5492,5714,"and he's kind, he paid my tuition."],[5714,5793,"Ella,"],[5864,6164,"you haven't seen the other side to him."],[6239,6506,"But he just saved me."],[6506,6698,"Saved you?"],[6698,6869,"Should I tell him?"],[6869,7032,"What if Charlotte was right?"],[7032,7244,"What if he's only with me because of the baby?"]],"36":[[216,429,"Charlotte pushed me."],[429,704,"Pushed you?"],[704,884,"Ella, listen."],[884,1017,"I'll take care of it."],[1017,1234,"I promise"],[1234,1534,"Charlotte will not bother you anymore."],[1572,1768,"But you have to tell me something."],[1768,2006,"You'll never"],[2006,2097,"talk to Owen again."],[2097,2310,"Okay?"],[2310,2335,"Come on."],[2335,2635,"Let's go home."],[4062,4308,"Ella!"],[4308,4475,"Owen."],[4475,4650,"Hey, what are you doing here?"],[4650,4763,"I was just passing by."],[4763,4934,"Thought I'd drop in and see ya."],[4934,5063,"You got time for lunch?"],[6051,6289,"I'm glad to see you kept up with your studies."],[6289,6460,"Thank you."],[6460,6631,"You know, if it hadn't been for you,"],[6631,6927,"I might have dropped out of school entirely."],[6948,7107,"Well, you've got talent."],[7107,7169,"I didn't want to see"],[7169,7494,"the AI industry lose a big shot in the future."],[7853,8134,"Well Ella, now that it's just the two of us,"],[8134,8337,"you can be honest."],[8425,8575,"What's really going on between you and Edward?"]],"37":[[75,375,"What do you mean?"],[375,638,"If Edward is forcing you into anything,"],[651,792,"you can tell me."],[813,1113,"I'll help."],[1126,1313,"No, no, it's not like that at all."],[1313,1572,"He's been really good to me."],[1572,1755,"Really?"],[1755,1906,"Well, I heard Edward was supposed to marry"],[1906,2206,"with the Kensington family."],[2385,2623,"Well, a lot of people think that."],[2623,2731,"Of course,"],[2731,2994,"their families have known each other for years."],[2994,3103,"Business partners,"],[3103,3231,"plenty of ties between them,"],[3231,3403,"and those two–"],[3578,3645,"Sorry,"],[3645,3924,"I should not have brought that up."],[3924,4204,"Anyway, as long as you're happy,"],[4204,4479,"that's all that matters."],[4934,5234,"Gotcha, sneaky little rat."],[5851,6051,"A new partnership contract for next year."],[6051,6210,"Take a look."],[6210,6393,"I'll take a look at it later."],[6393,6560,"Anything else?"],[6560,6698,"Actually, yes."],[6698,6873,"It's about your little girlfriend."],[6873,7005,"I already told you."],[7009,7148,"Stay away from her."],[7261,7545,"I know, I know."],[7545,7791,"I just happened to see her"],[7791,7932,"with Owen."],[7932,8091,"What kind of nonsense is this?"],[8274,8420,"To be honest,"],[8420,8662,"I think she might be a spy sent by Owen's company."]],"38":[[4,208,"Look closer, Edward."],[208,421,"She's obviously close with Owen."],[421,508,"With so many women"],[508,692,"deliberately trying to get close to you,"],[692,800,"how do you know she's not one of them?"],[800,975,"Shut up."],[975,1201,"All of this is made up in your head."],[1201,1501,"Don't accuse her unless you have proof."],[1622,1751,"Get out."],[1751,1951,"You've only known her for a short amount of time,"],[1951,2252,"and you already trust her this much?"],[2302,2419,"I bet you didn't even know"],[2419,2652,"that she was close with Owen before."],[2652,2952,"I said get out."],[3061,3169,"Fine."],[3169,3274,"But I'm warning you."],[3274,3449,"You better be cautious of her."],[3449,3529,"If not,"],[3529,3782,"everything we work for could be ruined by Owen."],[3883,3983,"Go!"],[4116,4145,"And look,"],[4145,4279,"take this shit with you!"],[4884,5146,"Hey, you're home early."],[5146,5380,"Yeah."],[5380,5663,"Not much going on at work."],[5663,5843,"Look, about earlier,"],[5843,6081,"I had lunch with Owen,"],[6091,6264,"and I think you should know."],[6473,6556,"Why?"],[6601,6702,"Ella, you told me"],[6702,6802,"you were going to stay away from him."],[6852,7086,"I know, but"],[7086,7228,"he's been so nice to me."],[7228,7361,"He's done so much for me."],[7361,7507,"And it was just lunch."],[7507,7661,"Look."],[7670,7916,"He's our company's biggest competitor."],[7916,8124,"I'm afraid he's gonna take advantage of you."],[8124,8379,"What are you saying?"],[8379,8512,"Do you think I'm a spy?"]],"39":[[221,446,"I don't even know anything about your company."],[446,742,"You know that."],[742,1038,"Ella, you're still so naive."],[1101,1351,"Look, you have no idea what he's capable of."],[1514,1680,"Whatever's going on"],[1680,1939,"between you and Owen,"],[1939,2214,"that has nothing to do with me."],[2214,2314,"And you said it yourself,"],[2314,2510,"I'm an independent woman, so"],[2510,2811,"I think I should be able to choose my own friends."],[2831,3090,"Ella!"],[3090,3211,"I think I want some space"],[3211,3436,"so I'm going to sleep in the guest room tonight."],[3436,3513,"Ella."],[3533,3737,"Ella!"],[3778,4070,"Ella just–"],[4070,4225,"Wait a minute."],[4266,4546,"God! Edward."],[4546,4696,"Look, I never thought I'd see the day"],[4696,4846,"where you got rejected."],[4846,4911,"I mean, just–"],[4911,5059,"Just let me ask,"],[5059,5196,"how does it feel to get rejected"],[5196,5380,"after you teach her how to stand up for herself?"],[5380,5680,"Shut up."],[5989,6147,"Seriously, though."],[6147,6373,"When are you gonna tell her that you're jealous?"],[6373,6552,"I mean you're making up all these excuses."],[6552,6802,"And look, now she's actually mad at you."],[6973,7190,"Jealous?"],[7190,7407,"You think I'm jealous of Owen?"],[7407,7636,"That's ridiculous."],[7636,7665,"Come on."],[7665,7966,"It's not about the other guy."],[8049,8345,"The point is–"],[8345,8508,"Bro,"],[8508,8737,"you're in love."],[8737,8954,"Face it, you've fallen hard man."]],"40":[[0,300,"What? Did I say something wrong?"],[467,700,"Maybe not, maybe not."],[700,880,"Listen."],[880,1017,"I know what it feels like to fall in love"],[1017,1276,"for first time."],[1276,1530,"When are you gonna be honest with Ella?"],[1530,1618,"I don't know."],[2110,2389,"Hey, what's going on?"],[2389,2439,"Got it."],[2439,2677,"I'll be right there."],[2677,2882,"The database, it crashed again."],[2882,3090,"We got to go."],[3090,3390,"Come on."],[3782,4083,"Good morning."],[4095,4337,"Thank you."],[4337,4562,"Did Edward already eat?"],[4562,4850,"No, he didn't come home last night."],[4850,4975,"He's probably still at the office"],[4975,5276,"working late."],[5313,5501,"You look like you didn't sleep well."],[5501,5734,"What happened?"],[5734,5993,"Emma, have you ever really"],[5993,6099,"wanted to know something?"],[6126,6390,"But you were too scared to ask"],[6390,6556,"because you were afraid that"],[6556,6652,"the answer would disappoint–"],[6652,6906,"Oh, dear. Of course."],[6906,7073,"But facing the problem head on"],[7073,7374,"is the best way to solve it."],[7590,7807,"Why don't you make a nice homemade breakfast,"],[7807,7941,"and have a heart-to-heart talk?"],[8383,8546,"No matter how this ends,"],[8556,8888,"let's clear up all the doubts this moment."]],"41":[[971,1272,"Hi, I'm here to see Edward."],[1297,1493,"Sorry, you mean Mr. Johnson?"],[1493,1793,"My boss?"],[1897,1989,"I'm sorry,"],[1989,2256,"do you have an appointment?"],[2256,2435,"No?"],[2435,2515,"Then I'm sorry,"],[2515,2648,"I can't let you in."],[2678,2744,"But–"],[2744,2927,"Hey, maybe you can give him a call,"],[2927,3148,"and he'll come down to get you."],[3148,3249,"Okay."],[3249,3549,"Thank you so much."],[5163,5271,"Hey, Edward."],[5271,5472,"I'm downstairs at your company."],[5472,5551,"Could you?"],[5551,5772,"He's not here."],[5784,5947,"Charlotte?"],[5947,6210,"Why do you have Edward's phone?"],[6210,6393,"He spent the night with me last night."],[6393,6694,"What's the problem?"],[6819,6961,"Where is Edward?"],[6961,7219,"Could you tell him to pick up the phone?"],[7219,7453,"He's in the shower."],[7453,7707,"Enjoy your last few good days."],[7707,7920,"Because soon enough, I might just have his baby."]],"42":[[83,383,"Because soon enough, I might just have his baby."],[513,663,"What do you mean?"],[663,921,"It's exactly what you think."],[921,1112,"Once my child is born,"],[1112,1368,"your child will be worth nothing."],[1368,1626,"But before that, you'll be kicked out."],[1626,1801,"Loser."],[2531,2831,"Take your stuff with you."],[2986,3286,"Sorry."],[3445,3778,"Damn, another gold digger."],[3937,4016,"What are you doing?"],[4016,4208,"Oh, you scared me."],[4208,4320,"I told you"],[4320,4512,"don't come into my office without permission."],[4642,4783,"You worked late last night,"],[4783,4904,"so I brought you breakfast."],[4904,5205,"I told you, I have a girlfriend."],[5518,5614,"Are you seriously treating"],[5614,5889,"that poor woman as your actual girlfriend?"]],"43":[[33,112,"Are you seriously"],[112,412,"treating that poor woman as your actual girlfriend?"],[487,692,"If you insult my future wife again,"],[692,796,"I will terminate"],[796,996,"our collaboration immediately."],[996,1188,"Have you lost your mind?"],[1188,1276,"That woman–"],[1276,1418,"Hey!"],[1418,1593,"Oh, thank God. Charlotte."],[1593,1701,"There you are."],[1701,1887,"I've been looking all over for you."],[1887,2002,"Oh."],[2156,2398,"Yeah."],[2398,2602,"What are you doing, Brandon?"],[2602,2698,"Charlotte."],[2698,2802,"Let it go."],[2802,3103,"Seriously, you can't force someone to love you."],[3128,3428,"He doesn't even like you."],[3436,3657,"Love can change."],[3657,4012,"One day, he'll realize that we are the perfect match."],[4012,4312,"Just wait and see."],[4483,4783,"Crazy."],[5347,5626,"Enjoy your last few good days."],[5680,5930,"Because soon enough, I might just have his baby."],[5930,6118,"Is there even any need to ask Edward?"],[6118,6356,"Wouldn't it just be humiliating myself?"]],"44":[[50,204,"Are you okay?"],[204,400,"I'm fine."],[400,504,"I'm fine"],[592,725,"Ella!"],[1530,1701,"What happened?"],[1701,1951,"Let's talk outside."],[3215,3299,"What happened?"],[4354,4654,"Damnit, do you even know she's pregnant?"],[4725,4946,"She fainted at school because of the pregnancy."],[4946,5176,"Doctor said it was because of emotional distress."],[5176,5476,"What did you do?"],[5638,5809,"Whatever is going on"],[5809,5990,"between you and Owen,"],[5990,6139,"that has nothing to do with me."],[6156,6256,"And you've said it yourself."],[6256,6452,"I'm an independent woman, so"],[6452,6731,"I think I should be able to choose my own friends."],[6731,6844,"I think I want some space,"],[6844,7057,"so I'm going to sleep in the guest room tonight."]],"45":[[0,233,"What did you do?"],[233,339,"Look, if you don't cherish her,"],[339,467,"leave her."],[467,558,"Someone that actually cares for her"],[558,675,"will take better care of her."],[675,771,"Shut up!"],[771,1071,"Don't ever fucking talk to me like that again."],[1105,1405,"You're in no place."],[1764,2064,"You all right?"],[2227,2473,"Thank you,"],[2473,2702,"Owen, for bringing me to the hospital."],[2702,2794,"It's nothing."],[2794,3094,"Anytime you need anything, you can call me."],[3103,3261,"She won't need to."],[3261,3365,"I'll take care of everything."],[3365,3503,"Yeah, you better."],[3503,3724,"I'll see you around."],[4141,4441,"Don't look at him."],[4587,4650,"I'm sorry."],[4650,4950,"I didn't know I was gonna faint."],[5050,5201,"Is the baby okay?"],[5201,5426,"Forget about the baby."],[5426,5545,"How are you feeling?"],[5565,5726,"Are you in any pain?"],[5805,6022,"I'm just really tired."],[6022,6318,"I think I want to sleep some more."],[6435,6577,"Okay."],[6577,6727,"Get some rest."],[6727,6873,"I'll be here."],[6873,7065,"When you wake up, I'll take you home."],[7703,7807,"Home?"],[7868,8029,"Once the baby's born,"],[8029,8270,"that won't be my home anymore."]],"46":[[79,432,"Hey, about what I said earlier to you,"],[432,667,"about staying away from Owen."],[746,925,"Just forget it."],[925,1242,"Look, any issues I have between Owen and myself"],[1242,1543,"doesn't concern you."],[1614,1914,"I want to make you happy."],[2189,2489,"Thank you."],[2527,2794,"I should probably get some rest."],[2794,2923,"I'm gonna head back to the room."],[2923,3115,"Ella,"],[3115,3230,"why don't you consider moving back"],[3230,3390,"to the master bedroom?"],[3390,3691,"It'll be easier for me to take care of you."],[3774,3858,"Okay."],[3858,4053,"Ella, you know he's only being kind"],[4053,4145,"for the baby's sake."],[4145,4309,"Don't fool yourself into thinking"],[4309,4387,"that he loves you."],[4387,4441,"Bye."],[6956,7073,"What happened?"],[7073,7257,"Why didn't you wake me up?"],[7257,7290,"I"],[7399,7557,"I didn't want to disturb your sleep."],[7578,7682,"Look, I, I'm fine."],[7682,7753,"I feel better now, I–"]],"47":[[0,183,"Are you hungry?"],[312,633,"It's not me, it's the baby."],[896,1159,"Well,"],[1159,1334,"what do you want to eat?"],[1334,1543,"I'll make it for you."],[1543,1776,"You cook?"],[1776,2077,"A little."],[2147,2298,"Cheese quesa-dilla?"],[2373,2494,"What?"],[2915,2990,"Try it."],[3757,3953,"Oh my God."],[3953,4112,"I didn't think you'd be good at cooking."],[4112,4379,"Do you even have any flaws?"],[4379,4571,"Well, I'm"],[4571,4804,"flattered you think that, but–"],[4804,4963,"I have flaws."],[4963,5230,"Is your flaw being too perfect?"],[5230,5476,"I wish."],[5476,5680,"It's jealousy."],[5680,5939,"I get jealous a lot."],[5939,6239,"Like, when I told you not to see Owen."],[6385,6664,"It's because I was jealous and–"],[6664,6844,"Look, I'm sorry"],[6844,7144,"for making up an excuse that would hurt you."],[7307,7378,"It's okay,"],[7378,7615,"I didn't take it personally."],[7795,8266,"How do I stop myself from falling for him?"],[8387,8547,"Only reason why he's being nice to you"],[8547,8758,"is because of the baby."]],"48":[[304,450,"I need to know that"],[450,671,"you're gonna be good to this baby."],[671,842,"Even if you have other kids,"],[842,1026,"you're gonna be good to it."],[1026,1172,"Take care of it."],[1172,1428,"Wait, is she already thinking about us"],[1428,1568,"having a second child?"],[1568,1793,"Does this mean she likes me too?"],[1830,2097,"Ella, of course, I will."],[2097,2335,"This is my first baby."],[2335,2635,"And it's precious."],[2681,2799,"That's great."],[2820,2982,"Now I feel reassured."],[3820,3941,"Doctor."],[3941,4241,"Her morning sickness is getting worse."],[4241,4475,"She even fainted at school again."],[4475,4754,"Is there anything we can do?"],[4754,5005,"I'm sorry."],[5005,5110,"There are many medications"],[5110,5359,"that pregnant women cannot take."],[5359,5647,"Eat smaller, more frequent meals."],[5647,5947,"Ensure adequate rest."],[6748,7044,"I can't believe I passed out."],[7111,7269,"Ella,"],[7269,7344,"maybe it's better"],[7344,7499,"to take some time off school."]],"49":[[83,333,"No, no, I don't want to."],[333,596,"Ella please, with how sick you've been,"],[596,867,"maybe, maybe you're pushing it too hard"],[867,1167,"Look, once you have the baby,"],[1217,1518,"you can go back to school."],[1655,1730,"It is really hard"],[1730,2031,"to study like this, so–"],[2035,2168,"I guess that's okay."],[2168,2348,"Look,"],[2348,2523,"get some rest."],[2523,2802,"I'll take care of the paperwork, okay?"],[3078,3378,"And Ella,"],[3424,3724,"I don't want to have any more babies."],[3732,4033,"One's enough."],[5296,5388,"What?"],[5388,5689,"Edward's not even going to the office anymore?"],[5743,5876,"What the hell?"],[5876,6001,"He's a workaholic."],[6001,6193,"I mean, what did that slut do to him?"],[6193,6334,"Honestly, I thought that Ella"],[6334,6502,"was a spy sent by Owen."],[6502,6727,"I'm even more concerned"],[6727,6894,"with Edward being at home all the time,"],[6894,7140,"she has more time to steal confidential information."],[7140,7219,"Shit!"],[7265,7565,"We should do something."],[7720,7828,"Easy!"],[7828,7931,"We steal the files"],[7931,8103,"before she can get her hands on them."]],"50":[[325,400,"Ella,"],[400,633,"you're looking so much better these days."],[633,875,"Mr. Johnson's been a huge help, hasn't he?"],[875,1138,"It's all thanks to him."],[1138,1330,"Where is Edward?"],[1330,1438,"He's in his study."],[1438,1722,"I'm bringing him some coffee."],[1722,2022,"Was he up all night again?"],[2122,2302,"Could you bring me some milk?"],[2302,2602,"I could take that to him instead."],[2765,2944,"Of course."],[2944,3240,"Thank you."],[3353,3633,"Sir, the project is set to launch next month."],[3633,3787,"Everything's on track."],[3787,3991,"That's all I have to report for now."],[3991,4087,"Okay."],[4087,4341,"That's, good for today."],[4341,4642,"See you later."],[4779,5005,"What? Did you invent"],[5005,5305,"some new kind of white coffee?"],[5363,5584,"No, but"],[5584,5693,"you're working so hard."],[5693,5964,"I mean, you're taking care of me and all this."],[5964,6114,"You're going to burn yourself out."],[6114,6398,"Well."],[6398,6694,"If you're so concerned about me."],[6698,6794,"How about you stay with me?"],[6794,7148,"I can't seem to fall asleep alone anymore."],[7399,7524,"Your heart's pounding."]],"51":[[137,437,"Your heart's pounding."],[437,738,"I won't deny it."],[829,1051,"Edward, you–"],[1238,1451,"Okay, look, just relax!"],[1451,1593,"Oh my God!"],[1593,1730,"How can you two be doing this"],[1730,1830,"in our study room?"],[1830,1922,"What do you want?"],[1922,1981,"I–"],[1981,2102,"I was just passing by,"],[2102,2331,"and I want your computer to send my assignment."],[2331,2498,"Do it at your house."],[2498,2569,"Hey."],[2569,2727,"I'm still your sister."],[2727,3028,"Don't be so mean to me, okay?"],[3178,3349,"Okay, fine."],[3349,3528,"Don't go through any files."],[3528,3828,"When you're done, leave."],[3978,4279,"Come on."],[4621,4817,"So cold to me now."],[4817,4949,"Well, once I help you out,"],[4949,5117,"you'll be grateful."],[6644,6831,"Seriously, Edward?"],[6831,7069,"You're reading parenting books?"],[7069,7223,"You know, you've really fallen."]],"52":[[62,250,"You used to read science magazines!"],[250,471,"This bitch is bringing you down."],[471,487,"You know,"],[487,709,"I told you you should have been with Charlotte."],[709,892,"Okay, listen,"],[892,1155,"you're in no place to tell me who I can and can't love."],[1155,1455,"And if you're so obsessed with arranged marriages,"],[1472,1641,"how about I arrange you one?"],[1651,1752,"Oh,"],[1830,2110,"how about Louis, the guy you hate the most?"],[2110,2206,"No way!"],[2206,2273,"Why?"],[2273,2377,"Never."],[2377,2531,"Why not?"],[2531,2756,"I think you two would be a really cute couple."],[2756,2923,"You're not actually thinking about me"],[2923,3094,"marrying Louis, are you?"],[3094,3215,"I don't know, I haven't gave it much thought,"],[3215,3395,"but I think so, yeah."],[4446,4746,"Later."],[5609,5851,"So, did you install the security stuff?"],[5851,6139,"Of course."],[6139,6239,"I'm done with it."],[6239,6510,"That bitch can't steal any data now."],[6510,6706,"I knew I could count on you."],[6706,6865,"Charlotte, maybe"],[7047,7077,"you should just give up on my brother."],[7440,7486,"What?"]],"53":[[25,135,"Why would you say that?"],[135,296,"What happened?"],[296,533,"Well, he's completely"],[533,834,"smitten with that bitch."],[850,1013,"Charlotte, I'm serious."],[1013,1184,"You should just let them be."],[1184,1468,"Edward is blind and doesn't appreciate you."],[1468,1768,"You deserve better."],[1810,2127,"Charlotte?"],[2127,2169,"Oh."],[2381,2548,"You're right."],[2548,2786,"Maybe I should just let him go."],[2786,3019,"After all, you can't force a relationship."],[3019,3094,"Exactly."],[3094,3294,"That is what I'm saying."],[3294,3495,"I know you'd understand."],[3495,3795,"We'll talk soon."],[4654,4954,"Is the program running?"],[5030,5230,"Good."],[5230,5530,"Let's send this bitch a big surprise."],[6427,6681,"How's that feel?"],[6681,6881,"I'll give you another one later on."],[6881,6948,"It's okay."],[6948,7098,"They really don't hurt that bad anymore."],[7098,7261,"Oh, come on."],[7261,7340,"Doctor's orders."],[7340,7640,"You need two massages a day or else you won't sleep well."],[7749,7832,"Just relax, okay?"],[8074,8309,"Even I know this is all temporary,"],[8328,8583,"I don't want to break it."],[8583,8883,"Just let me hold on to him a little longer."]],"54":[[638,821,"Have the chef change the menu."],[821,1042,"Ella's tried everything. But,"],[1042,1205,"keep the pancakes."],[1205,1272,"She liked those."],[1272,1526,"They tasted good."],[1526,1609,"That's the same thing"],[1609,1776,"Ella brought to you last time."],[1776,2047,"I'm glad you both like them."],[2047,2314,"When did she bring me breakfast?"],[2314,2615,"You didn't get it?"],[2656,3061,"Miss Ella!"],[3061,3115,"Hey!"],[3340,3553,"How come you didn't tell me?"],[3553,3762,"It wasn't a big deal."],[3762,4191,"And I didn't want to bother you, and–"],[4275,4575,"Did the receptionist let you in?"],[4621,4796,"Come on, let's go for a walk."]],"55":[[771,996,"This is where we're going for a walk?"],[996,1105,"Oh, don't worry."],[1105,1309,"There's plenty of space for you to walk here."],[1309,1413,"That's not the point."],[1413,1509,"Hey!"],[2052,2206,"Good morning, Mr. Johnson."],[2206,2293,"Good morning."],[2293,2452,"This is my girlfriend, Ella Parker."],[2452,2748,"Whenever she comes here, let her through."],[2748,2940,"Under any circumstance."],[2940,3103,"Got it?"],[3103,3290,"Yes, sir."],[3290,3407,"Good."],[3407,3591,"Come on."],[3966,3995,"Wait."],[3995,4230,"If she's Mr. Johnson's girlfriend,"],[4230,4429,"then what about Charlotte?"],[5830,5961,"For someone who's supposed to"],[5961,6068,"leave in a few months,"],[6068,6331,"he really doesn't need to do all this."],[6331,6606,"Could he actually have feelings for me?"],[6606,6827,"There, now everyone at the company"],[6827,6929,"knows your name,"],[6929,7127,"and they won't stop you when you come."],[7186,7486,"Why are you doing all this for me?"],[7532,7574,"Really,"],[7574,7795,"I want to know,"],[7795,8003,"how do you feel about me?"]],"56":[[79,229,"Edward!"],[229,412,"Something happened."],[412,617,"Our project got leaked."],[617,917,"What?"],[1313,1543,"What's going on?"],[1622,1814,"How did Owen get our key project data?"],[1814,1910,"We're still investigating."],[1910,2089,"But the worst part is,"],[2089,2389,"Owen already used our demo to make an announcement."],[2406,2511,"Owen!"],[2531,2706,"Must be him who stole our data."],[2915,3095,"Is it really him?"],[3095,3345,"I mean, are you sure?"],[3858,3958,"Why is she even here?"],[3958,4029,"She's probably the one"],[4029,4183,"that leaked the information to Owen."],[4183,4304,"Charlotte."],[4304,4604,"Stop framing her."],[4662,4796,"You know, she's close with Owen,"],[4796,4917,"and you've been home lately."],[4917,5096,"She's had plenty of chances."],[5096,5209,"I didn't do it."],[5209,5455,"I don't even know anything about the project."],[5455,5651,"I swear. It wasn't me."],[5651,5889,"Of course, you would say that."],[5889,6043,"Enough!"],[6043,6218,"Look,"],[6218,6468,"meet in my office in ten minutes."],[6468,6519,"Go!"],[7228,7469,"I didn't do it, I swear it wasn't me."],[7469,7703,"I know, but I'm busy right now."],[7807,7957,"I'll have a car bring you home."]],"57":[[120,233,"We checked everything."],[233,475,"Nothing seems to be unusual."],[475,602,"But we did find a Trojan horse"],[602,775,"on your computer."],[784,907,"Edward, this project"],[907,1138,"represents the hard work for the entire company."],[1138,1355,"You can't be soft now."],[1355,1509,"You have to sue Ella."],[1509,1672,"No."],[1672,1893,"There's not enough evidence to prove it was her."],[1893,2047,"Oh, come on, get real."],[2047,2164,"Who else could it be?"],[2164,2243,"Listen."],[2243,2344,"Do you know what time the malware"],[2344,2544,"was downloaded to the computer?"],[2577,2794,"No!"],[2794,2977,"Okay, trace the malware."],[3048,3253,"As for the suspect,"],[3253,3553,"I have someone else in mind."],[3916,4204,"Ella, how come you're not asleep?"],[4204,4446,"Morning sickness?"],[4446,4579,"How's everything going?"],[4579,4796,"Hey, don't worry about that."],[4796,4904,"Look,"],[4904,5142,"it's important you get some rest right now."],[5142,5355,"Don't worry about anything else, okay?"],[5355,5605,"I know people are suspecting me."],[5605,5647,"Ella."],[5647,5780,"I know you're under a lot of pressure."],[5780,5980,"I could go under investigation."],[5980,6051,"Hey Ella listen."],[6151,6414,"Everybody knows it wasn't you."],[6414,6673,"You don't have to do this."],[6673,6840,"I just want to help."],[6840,7007,"I could talk to Owen."],[7007,7140,"Listen."],[7173,7336,"Let me handle it."],[7336,7599,"Okay?"],[7599,7741,"Now get some rest."],[8308,8696,"Is part of this worrying because of Owen?"]],"58":[[304,462,"Ella, so glad you came in."],[462,671,"What's going on?"],[671,842,"Owen, about that project"],[842,996,"that your company just teased."],[1071,1142,"Oh yeah, you saw it?"],[1142,1251,"What did you think?"],[1488,1755,"Well,"],[1755,2056,"that project actually belongs to Edward."],[2077,2189,"What?"],[2189,2489,"Yeah, you probably didn't know that."],[2606,2711,"He's been working on it"],[2711,2896,"for a really, really long time,"],[2896,3219,"but somehow, I don't know it got leaked?"],[3382,3432,"But, Ella,"],[3432,3732,"the teaser is already out."],[3807,4058,"You serious?"],[4058,4183,"You're not going to do anything about it."],[4183,4458,"Owen, that's plagiarism."],[4458,4642,"I mean, look, I acquired the project"],[4642,4768,"through legitimate business dealings."],[4768,5059,"I'm not the one who stole it."],[5305,5338,"You know,"],[5338,5634,"I looked up to you for a lot of years."],[5672,5972,"I never thought you'd be this kind of person."],[5972,6268,"Maybe I just never even knew you at all."],[7036,7186,"What the fuck?"],[7186,7349,"You think I leaked the data?"]],"59":[[120,337,"That's a fact."],[337,579,"How could I possibly betray you?"],[579,863,"Are you out of your mind?"],[863,913,"Well,"],[975,1134,"video surveillance shows"],[1134,1291,"the day you submitted you're assignment,"],[1291,1497,"you installed a software on my computer."],[1539,1634,"That's,"],[1634,1926,"that's the Trojan horse."],[1993,2081,"What?"],[2081,2214,"That's impossible."],[2214,2510,"It was a file protection program."],[2510,2702,"It must have been Ella who–"],[2702,2957,"Stop lying to yourself."],[2957,3257,"Look, I know you didn't do it on purpose, so"],[3311,3595,"who put you up to it?"],[3595,3753,"Candy,"],[3753,3924,"this is serious."],[3924,4078,"If you don't tell the truth,"],[4078,4225,"you're the one going to jail."],[4225,4437,"It was Charlotte!"],[4437,4654,"But it doesn't make sense."],[4654,4750,"Why would she do this?"],[4750,4975,"Why would she want to hurt us?"],[4975,5188,"Maybe,"],[5188,5409,"maybe you didn't know her."],[5409,5588,"But Candy,"],[5588,5889,"you have to grow up."],[6715,6841,"They've terminated all contracts"],[6841,7036,"with the Kensington family."],[7036,7332,"Charlotte will be prosecuted."],[7332,7516,"Charlotte did all that?"],[7516,7678,"He must be so disappointed."],[7816,7878,"And by the way,"],[7991,8191,"we're suing Owen for plagiarism."],[8191,8320,"His company will take a big hit."]],"60":[[95,396,"Do you think I should take him off the hook?"],[588,850,"No, no."],[850,1151,"He needs to get what he deserves."],[1151,1309,"Yeah."],[1309,1609,"I just never thought he'd be this kind of person."],[1797,2097,"What do you mean?"],[2131,2160,"I mean,"],[2160,2460,"you must be pretty upset too?"],[2477,2548,"Honestly, Ella,"],[2548,3003,"my entire family has known she's little"],[3003,3194,"crazy."],[3461,3682,"Well,"],[3682,3958,"you must have really liked her."],[4116,4350,"What are you talking about?"],[4350,4533,"I just mean,"],[4533,4656,"you knew she was like that,"],[4656,4833,"and you still liked her."],[4896,5005,"Ella what are you talking about?"],[5005,5301,"That's ridiculous."],[5301,5558,"When I brought you breakfast to your office,"],[5558,5776,"and I called you."],[5776,5843,"She answered."],[5843,6010,"She told me you guys spent the night together."],[6010,6310,"She what?"],[6322,6531,"Crazy woman."],[6531,6690,"She should be held accountable for this, Ella!"],[6819,6909,"Oh my God."],[6909,7190,"Have I been miserable all this time for no reason?"],[7190,7524,"Maybe, maybe he really likes me?"]],"61":[[16,296,"Do you have feelings"],[296,533,"for anyone else?"],[533,596,"Ella."],[675,975,"You're driving me crazy."],[1001,1301,"Can I not make it any more obvious?"],[1472,1589,"Ella,"],[1589,1889,"I only have feelings for one girl."],[1939,2239,"And that's you."],[2268,2569,"What's the matter?"],[2569,2844,"Sorry, I'm just stupid."],[2844,2861,"No."],[2861,3044,"Should have just talked to you."],[3044,3161,"Hey,"],[3445,3528,"I should have done this"],[3528,3703,"a long time ago."],[4808,4992,"Ella,"],[4992,5192,"I am so thankful"],[5192,5526,"for that one night we spent together."],[5526,5780,"I learned how brave"],[5780,6081,"and smart and enduring you are."],[6101,6310,"And every day you continue"],[6310,6606,"to surprise and impress me."],[6694,6990,"Ella, I never want to live without you."],[6990,7173,"Will you marry me, Ella?"],[7173,7440,"And spend the rest of your lifewith me?"],[7440,7520,"Oh my God!"],[7520,7820,"Yes, yes, I will!"],[8229,8441,"It's beautiful."],[8925,9038,"What's the matter?"],[9038,9255,"Are you in pain?"]],"62":[[66,316,"No, no wait."],[316,617,"I think the baby just kicked."],[734,1034,"- Really? - Yeah!"],[1042,1343,"It looks like our little one's excited too."],[1493,1593,"I love you."],[1593,1718,"I love you."],[2398,2635,"That damn bitch!"],[2635,2786,"She hooked up with a rich guy?"],[2786,3019,"Yeah, you're father and brother,"],[3019,3294,"but she still can't help you two."],[3294,3595,"But I know where that cold hearted bitch is."],[3724,3826,"Why are you helping us?"],[3846,4062,"What do you want?"],[4108,4383,"That bitch made me lose my inheritance."],[4383,4642,"And I had to leave the U.S."],[4642,4683,"Of course."],[4683,4984,"I'm happy to give her some trouble before I leave."],[5050,5213,"Okay,"],[5213,5399,"you tell us where she is,"],[5437,5620,"and we have to figure out a way"],[5620,5860,"to get her to cough up that money."],[6197,6285,"Congratulations."],[6285,6585,"It's a healthy baby girl."],[6614,6790,"Well, it's not showing yet, but"],[6790,7090,"you should start applying stretch mark oil for her."],[7094,7194,"Stretch mark oil?"]],"63":[[54,258,"Stretch mark oil?"],[258,312,"Yes dear,"],[312,613,"to prevent stretch marks."],[650,950,"Can't I just do it myself?"],[967,1151,"Honey, when your belly gets bigger,"],[1151,1426,"it's going to be harder for you to do on your own."],[1426,1726,"Why not let your husband get involved early?"],[2052,2221,"Rub a little bit on your little belly,"],[2231,2360,"your little mooka belly."],[3582,3853,"Ella!"],[3853,4029,"Jasper, what,"],[4029,4124,"what are you doing here?"],[4124,4300,"Don't be afraid."],[4300,4600,"I'm not going to hurt you."],[4600,4900,"You look like you're doing well."],[5063,5313,"Could you lend us some money?"],[5313,5563,"Dad has cancer."],[5563,5734,"What?"],[5734,5893,"Is he okay?"],[5893,6193,"He's bedridden now."],[6243,6498,"I'm sorry."],[6498,6610,"We're in so much debt."],[6610,6877,"we can't even afford the doctors."],[6877,6990,"Ella,"],[6990,7290,"please, I'm begging you."],[7357,7440,"Anything will help."],[7440,7603,"After everything he did to raise you."],[7603,7795,"Please."],[7795,8041,"- Ella? - Hey!"],[8041,8158,"Stop talking to her."],[8266,8308,"I'm sorry."],[8308,8608,"I'll leave you alone."],[8825,8867,"Wait!"]],"64":[[362,425,"Oh Ella."],[608,717,"I never thought"],[717,1017,"that I'd see you again."],[1067,1384,"I must look so pathetic to you right now."],[1455,1680,"I guess this is karma"],[1680,1951,"for the way I treated you."],[4033,4216,"Damn it!"],[4216,4291,"Why'd she leave?"],[4291,4383,"Is she ignoring us?"],[4383,4542,"Don't worry."],[4542,4788,"I know her."],[4788,5088,"She'll give us the money."],[5359,5405,"You're thinking"],[5405,5705,"about your dad, aren't you?"],[5868,5960,"He did all that,"],[5960,6156,"and I still had sympathy for him."],[6156,6485,"Oh, Ella, you're just too kind."],[6544,6644,"Look,"],[6644,6919,"I'll have Michael take care of the medical bills, okay?"],[6919,7069,"I mean,"],[7069,7369,"after all he did raise you."],[7428,7620,"Thank you."],[7620,7874,"Of course. Oh!"],[7874,7995,"The stretch oil!"],[8383,8483,"- Can't I just..."],[8483,8646,"- Nope. - Do it myself?"],[8646,8796,"Nope, doctor's orders."],[8796,8900,"Let me see the little mooka belly!"]],"65":[[83,187,"Ella."],[354,688,"We've been sharing a bed for so long"],[721,1009,"and so shy."],[1009,1309,"I think I know why."],[1326,1626,"You just have to"],[1626,1926,"get used to my touch."],[3962,4091,"Edward!"],[4688,4829,"Hey,"],[4921,5125,"I made you something."],[5125,5367,"Oh, baby, you didn't have to do this."],[5367,5638,"- Your belly's so big. - Well, I wanted to."],[5638,5818,"And I'm so bored."],[5818,5939,"Plus I'm not that fragile,"],[5939,6089,"okay?"],[6089,6239,"Try it!"],[6706,6781,"How does it taste?"],[6781,7082,"Oh, wow, it's um–"],[7215,7361,"It's, um–"],[7361,7424,"It's ah–"]],"66":[[154,316,"It's um–"],[316,454,"It's ah–"],[742,967,"It's really good."],[967,1188,"I'm just,"],[1188,1488,"not that hungry right now."],[1793,1947,"Yeah,"],[1947,2248,"come on in."],[2352,2706,"Sir, this is a medical bill sent over by Jasper Parker."],[2790,3040,"But something seems off."],[3040,3207,"Wait, Ivan's still in the hospital?"],[3207,3378,"He's not better? It's been five months?"],[3378,3475,"Not only that,"],[3475,3649,"but the amounts on the medical bill"],[3649,3945,"have been increasing every time."],[3945,4245,"So I did a little digging and found out"],[4287,4558,"Ivan isn't even sick."],[4558,4796,"What did you just say?"],[4796,5096,"Michael, stop."],[5259,5367,"We'll handle it, okay?"],[5367,5597,"No, I want the truth."],[5597,5618,"What?"],[5618,5922,"He's been faking it this entire time?"],[5922,5976,"Oh my God!"],[5976,6227,"He's using the money for gambling, isn't he?"],[6460,6673,"Damn it!"],[6673,6973,"I've been used again."],[7232,7344,"Ella!"],[7344,7440,"Hang on, we're going to the hospital."]],"67":[[0,275,"Thank God the doctor said it was a false alarm."],[275,387,"Hey,"],[425,725,"you should stay home for the rest of the week."],[742,1042,"I'm never going to believe them again."],[1146,1188,"I can't believe"],[1188,1488,"they keep using me like this."],[1509,1810,"I'll make sure they give back everything they took, okay?"],[1901,2102,"But Ella, you have to promise me,"],[2132,2277,"you'll stop getting upset."],[2281,2519,"Look, they're not worth it."],[2519,2819,"The baby doesn't want you upset either."],[2977,3278,"Okay."],[3349,3507,"I'm going to be a good mom."],[3507,3653,"Yeah."],[3653,3820,"And I'ma make sure she never gets hurt."],[3849,4012,"Yeah."],[4012,4254,"You're going to be a great mom."],[4254,4554,"I'm going to be a great dad."],[4700,4779,"I think"],[4779,5080,"probably time we should pick out a name for her."],[5213,5513,"I was thinking Isabella."],[5659,5880,"It sounds like a princess."],[5880,6122,"I think that's a lovely name."],[6122,6297,"I think little Isabella will love it."],[6477,6727,"Isabella."],[6727,6886,"So excited to meet you."],[6886,7027,"Little baby."],[7315,7407,"Damn it."],[7407,7707,"That bitch isn't answering her phone."],[7724,7803,"If you don't have the money"],[7803,8095,"by 8 PM tonight, you're all dead."],[8095,8229,"Dad, what are we going to do?"],[8229,8466,"Ella won't give us any money anymore."],[8466,8754,"I don't wanna die."],[8754,9013,"We'll just grab it."],[9013,9305,"Ella is the one forcing us to do this."]],"68":[[633,729,"Ella!"],[729,980,"You're really hard to find."],[980,1005,"Somebody help!"],[1005,1192,"No, no, no you bitch."],[1192,1355,"Oh, no."],[1355,1633,"I want that $50 million."],[1633,1776,"Or I kill this baby."],[1860,2131,"Looks like you're done pretending to be sick."],[2131,2344,"You forced me into this,"],[2344,2598,"and I owe a huge gambling debt."],[2598,2773,"And the people at the casino"],[2773,2919,"are ready to cut off my hands."],[2919,3082,"You take the money back now?"],[3082,3157,"You wouldn't have this problem"],[3157,3303,"if you hadn't stopped gambling that–"],[3470,3578,"Oh my God!"],[3578,3670,"Here she goes."],[3670,3962,"Stop pretending, Ella!"],[3962,4162,"You're not gonna fool us like we did."],[4162,4275,"Stop!"],[4275,4400,"Let her go!"],[4579,4738,"Well, look who it is."],[4738,4900,"Mr. Perfect husband."],[4900,4975,"Come on."],[4975,5142,"What do you want?"],[5142,5284,"It's easy."],[5284,5497,"I just want the money."],[5497,5730,"You pay me $50 million,"],[5730,5855,"and when we get her out of state,"],[5922,5993,"I'll let her go."],[6114,6147,"Come on, man."],[6147,6260,"She's pregnant."],[6260,6423,"She can't handle the stress."],[6423,6619,"Look,"],[6619,6869,"I'll give you a blank check for any amount you want."],[6869,6919,"Let her go."],[6990,7194,"Do you think we're idiots?"],[7194,7323,"Stop wasting time!"],[7323,7465,"Just do what he says."]],"69":[[4,304,"We're gonna be rich."],[329,629,"Here's the money."],[996,1121,"This is real."],[1121,1409,"Where's the car?"],[1409,1614,"It's outside."],[1614,1726,"Now back off!"],[1726,1989,"We're out of here."],[1989,2110,"Oh, No!"],[2110,2231,"Wait, whoa whoa whoa!"],[2231,2302,"Hey!"],[2369,2506,"Are you okay?"],[2619,2769,"I think I'm gonna give birth!"],[2769,2865,"Hold on."],[2865,2990,"Hold on, Ella!"],[3090,3261,"You're gonna be okay!"],[4016,4191,"It's okay Ella, it's okay."],[4216,4320,"It hurts so bad!"],[4320,4542,"I'm here for you."],[4542,4713,"It really hurts so much!"],[4713,5013,"I'm here for you, I'm here for you."],[5017,5134,"Doctor."],[5134,5213,"She's passing out!"]],"70":[[45,221,"We need to prep for a C-section."],[221,483,"Oh God. Hang in there, Ella."],[483,545,"Doctor, please."],[545,721,"You have to save both of them."],[721,834,"Hang in there, Ella!"],[834,996,"- Sir! - I'll be here!"],[996,1138,"- Just hang on! - Sir!"],[1138,1192,"You're going to get–"],[1192,1263,"Fuck!"],[1901,2088,"God, I beg you."],[2195,2425,"As long as they are safe,"],[2491,2736,"I would trade anything for it..."],[2882,2977,"Miss Parker."],[2977,3129,"Congratulations on winning"],[3129,3374,"the National Medal of Technology."],[3374,3482,"Thank you."],[3482,3916,"So we know you faced a lot of challenges along the way."],[4033,4220,"What do you think is key"],[4220,4521,"to overcoming those?"],[4550,4671,"Well,"],[4671,4900,"aside from my own determination,"],[4900,5271,"I would have to say the support of my family."],[5442,5709,"I would especially like to thank my husband"],[5709,6010,"for always supporting me."],[6018,6285,"I love him."],[6285,6581,"Congratulations, babe."],[6581,6798,"Thank you."],[6798,6902,"Where's Isabella?"],[6902,6986,"With my mom."],[6986,7090,"So,"],[7090,7253,"how was the interview?"],[7253,7411,"It was good."],[7411,7549,"I said something about you."],[7549,7720,"Oh, what's that?"],[7720,7916,"Just what I say everyday."],[7916,8020,"That I love you."],[8241,8379,"I love you too."]]}