{"1":[[778,894,"Welcome, Ms. Cooper."],[956,1056,"Thank you."],[1519,1712,"I can't believe it's been five years"],[1721,1950,"since I've been to our American office."],[1981,2147,"Time to reintroduce myself"],[2156,2388,"as the chairwoman of the Cooper Group."],[2788,2888,"Hi, baby."],[2943,3149,"Honey, I'm near the elevator."],[3171,3272,"Come get me."],[3281,3393,"I'll be right there."],[4160,4261,"Mr. Duke."],[4270,4480,"Here's the attendance list for the board meeting."],[4488,4596,"Could you take a look?"],[4636,4746,"Sure."],[5024,5092,"Looks fine. Just add"],[5102,5245,"my wife's name in it."],[5283,5383,"She'll be attending."],[5416,5541,"She's the chairwoman after all."],[5550,5650,"Yes, sir."],[6330,6548,"Ms. Thornfield, I'm married."],[6566,6672,"I love my wife."],[6717,6883,"I'd appreciate if you could respect that."],[7117,7217,"Thank you."],[7442,7575,"Everyone knows his wife is"],[7583,7763,"some washed-up woman in her 40s,"],[7771,7907,"clinging to a title."],[7915,8080,"There's no way he's not tempted"],[8088,8454,"by someone young, fresh, someone like me."],[10495,10613,"Oh my God, you're finally home."],[10622,10750,"I missed you so much."],[10966,11106,"I missed you too, babe."],[11115,11249,"But you've been handling things"],[11268,11349,"so well here,"],[11357,11571,"so I thought to enjoy myself a little bit longer."],[11580,11724,"You absolutely deserved it."],[11773,11943,"I think it's about time that everybody in the company"],[11952,12117,"really got to meet who the real boss is."],[12125,12292,"Okay? I'll introduce you"],[12301,12518,"to the chief company secretary soon."],[12682,12882,"Who the hell is this bitch?"],[13288,13575,"Let's not talk about the business now."],[13592,13705,"I have something"],[13713,13822,"really important to tell you."],[13830,14013,"-Okay. -I'm pregnant."],[14083,14268,"-Really? -Yes."],[14276,14404,"Oh my God!"],[14412,14535,"Amazing!"],[15499,15744,"No, I won't let this slide."],[15784,15993,"I'll tear them apart if I have to."],[16038,16371,"Dalton's fortune belongs to me."]],"2":[[2,110,"God!"],[389,516,"Two months along."],[525,691,"Remember when you came to Paris?"],[700,918,"Yeah. I can't believe after all these years"],[926,1030,"we're finally going to have a baby."],[1050,1171,"We've got to celebrate tonight, okay?"],[1179,1279,"Yeah."],[1290,1510,"Oh, get back to work already."],[1546,1799,"I'm going for a little walk around the offices."],[1820,1947,"Got to make sure you haven't stashed"],[1955,2105,"any mistresses around here."],[2119,2263,"You better check every corner then, babe,"],[2272,2374,"okay?"],[2411,2511,"Okay."],[2542,2682,"Okay, I'll go back to work now."],[2690,2793,"Sure."],[2942,3050,"Take care, okay?"],[3060,3156,"If you need anything, just give me a call."],[3160,3208,"Sure."],[3211,3330,"Or when you're getting lost."],[4643,4756,"Stop right there!"],[4977,5077,"What?"],[5114,5216,"Who are you?"],[5225,5385,"What's your relationship to Mr. Duke?"],[5393,5493,"What's it to you?"],[5505,5665,"You're his little mistress, aren't you?"],[5787,5913,"Excuse me?"],[5962,6054,"What? You're scared"],[6066,6188,"to admit it now?"],[6218,6320,"You're mistaken."],[6672,6854,"I saw you outside with him."],[6892,7229,"You were kissing, hugging, so you can't deny it."],[7291,7419,"You're his side chick."],[7489,7649,"You're crossing the line."],[7662,7790,"Say one more word"],[7799,7969,"and I'll sue you for slander."],[7982,8082,"Oh, please."],[8105,8297,"Everyone knows Mr. Duke is married"],[8305,8449,"to a global powerhouse."],[8508,8715,"And you, you're just some washed-up,"],[8763,8965,"gold-digging skank."],[9088,9561,"Why do you care who I am to Dalton, dear?"],[9596,9770,"It's none of your business."],[9852,9956,"Go back to work."],[10011,10111,"Mm-hmm?"],[10181,10351,"Oh, no, you're not going anywhere."],[10381,10557,"Security, detain her now."],[10689,10877,"Don't you dare do that."],[10989,11129,"What are you standing there for?"],[11160,11339,"I'm Mr. Duke's chief secretary."],[11371,11568,"You either grab her or you're fired."],[11844,11944,"What? No."],[11965,12065,"Let me go."],[12135,12323,"Stop. Don't touch me."],[12344,12689,"Everyone, come take a good look at this woman."],[12726,12972,"She came in here today, flashing skin"],[12981,13267,"and fake smiles, trying to worm her way"],[13276,13617,"into a rich man's life and to ruin his family."],[13632,13932,"So you're my husband's secretary now."],[13944,14059,"Am I right?"],[14193,14309,"Husband?"],[14358,14651,"Oh, that's sweet of you to wishfully call him that."],[14763,15006,"Yeah, I'm his secretary. Why?"],[15026,15250,"Because I'm about to make him fire you."],[15284,15384,"Fire me?"],[15426,15556,"Over you?"]],"3":[[755,934,"If you don't let go of me,"],[962,1333,"right this second, I'll make you fired."],[1496,1679,"You really think Mr. Duke's going to vouch"],[1687,1887,"for some little homewrecker like you?"],[2061,2395,"Let's call him, and you'll find out."],[2416,2521,"Or what?"],[2533,2647,"Are you afraid?"],[3208,3428,"Someone's bitten off more than they can chew."],[3438,3590,"What are you good for, huh?"],[3608,3793,"Besides latching on to rich men."],[3806,3963,"I'm going to remember this."],[3979,4234,"Believe me, you're going to regret it."],[4268,4393,"Stupid bitch."],[4401,4581,"You couldn't even touch me if you tried."],[4617,4755,"Strip her down."],[4904,5053,"Let's teach this bitch what happens"],[5061,5131,"when you're snooping"],[5140,5299,"around other people's men."],[5359,5599,"No, no, no, you can't do that."],[5673,5807,"Please stop."],[5834,5936,"No."],[6107,6215,"Let me go."],[6645,6802,"You'll pay for this."],[6997,7149,"Oh, what, you're scared now?"],[7271,7399,"You should have thought about it before"],[7408,7655,"you seduced Mr. Duke, who's a married man."],[7769,7948,"Everyone, pay attention."],[8000,8105,"This is what happens"],[8114,8314,"when you try to wreck people's families."],[8372,8548,"A whore like you stole my husband."],[8556,8706,"You deserve to die."],[9273,9396,"You can't."],[9409,9548,"I'm not... Why—You can't"],[9554,9654,"do this to me."],[9749,9926,"Keep talking. No one's listening,"],[9934,10074,"and no one's going to come save you."],[10108,10240,"You'll pay for this."],[10270,10642,"Oh, sweetie, not even Mr. Duke can fire me."],[10679,11029,"Why? You're just a secretary."],[11126,11296,"Why he can't fire you?"],[11344,11538,"Because I am much more than that."],[11564,11732,"I was personally handpicked"],[11732,11816,"by the chairwoman,"],[11816,12046,"his wife, to stand by his side."],[12074,12234,"I'm not going anywhere."],[12266,12581,"Oh, this psycho really thinks"],[12590,12722,"that her place is"],[12730,12955,"so much important in this company."],[12963,13172,"What the fuck did you just say?"],[13205,13328,"Listen to me."],[13360,13552,"I'm Mr. Duke's wife."],[13585,13900,"I'm the chairwoman of this damn company."],[13920,14021,"What?"]],"4":[[182,499,"I said, I'm Mr. Duke's wife"],[508,746,"and chairwoman of this company."],[773,927,"Was it clear?"],[1780,1926,"Let me go!"],[2005,2147,"Let me go!"],[2255,2590,"Oh, honey, I work beside him every single day."],[2608,2746,"If you were the chairwoman,"],[2755,2918,"I would have been the first to know."],[2927,3045,"What are you waiting for?"],[3106,3206,"Slap her."],[3261,3363,"No."],[3371,3551,"No. Please stop it."],[3611,3721,"I have to film this."],[3774,3934,"This will be the drama of the year."],[4426,4526,"Oh!"],[4672,4851,"Jesus, you're, you're doing a mistake."],[4859,4959,"Stop it."],[6277,6379,"Let me go."],[6388,6569,"Let go of me now!"],[6614,6752,"Don't touch me."],[6858,6984,"Take your clothes off, too."],[7453,7575,"Oh, actually, wait."],[7584,7690,"Never mind."],[7808,7990,"Let's save her for the boardroom."],[8006,8271,"You don't even know what you're doing..."],[8285,8385,"Yeah?"],[8542,8761,"I'm protecting this company's image"],[8779,8979,"from parasites like you."],[9107,9263,"Let's take her to the boardroom."],[9282,9428,"I want to show the board"],[9445,9667,"this homewrecking mistress myself."],[10930,11083,"Let's keep things sharp today."],[11092,11290,"The chairwoman rarely joins in person."],[11336,11526,"No room for sloppiness, okay?"],[11552,11652,"Absolutely."],[11692,11901,"People underestimate her because she's quiet"],[11910,12088,"but without her strategies,"],[12097,12297,"we wouldn't be half as successful."],[12327,12548,"She's a powerhouse behind the curtain."],[12563,12666,"That's true."],[12675,12889,"She built this place together with Mr. Duke."],[13002,13149,"Anyone who disrespects him"],[13149,13291,"disrespects all of us."],[13384,13512,"We can't allow that."],[14154,14360,"What the hell is going on here?"]],"5":[[171,403,"Ladies and gentlemen of the board,"],[418,649,"allow me to introduce this woman."],[702,950,"She is Mr. Duke's mistress."],[1013,1115,"What?"],[1124,1325,"And she decided to show up today,"],[1335,1471,"of all days,"],[1491,1687,"to disgrace our chairwoman"],[1696,1868,"and wreak havoc in our company."],[1928,2145,"Flora, are you sure about this?"],[2163,2401,"Mr. Duke's never struck me as a cheating type."],[2431,2603,"Well, this bitch"],[2612,2861,"has repeatedly seduced Mr. Duke"],[2887,3133,"and derailed his focus from our company."],[3166,3421,"I, as a secretary, assure you all"],[3438,3776,"that everything I'm saying is the absolute truth."],[3803,4015,"We may not know the chairwoman personally,"],[4024,4149,"but we have seen her visions"],[4149,4288,"shape this company."],[4315,4582,"Anyone who dares to insult her name"],[4639,4851,"or dares to harm this company"],[4858,5001,"is an enemy of ours."],[5024,5239,"Yeah, then let's put this homewrecker"],[5247,5503,"in her place for the chairwoman."],[5519,5890,"Please, please, you're all being lied to."],[5910,6144,"She's twisting everything."],[6153,6256,"Board members,"],[6265,6555,"think about the damage this scandal could do."],[6582,6725,"If word got out,"],[6765,6877,"the chairwoman's name"],[6885,7035,"will be dragged through the mud,"],[7069,7382,"and so will your stock portfolios."],[7402,7571,"If you want to protect everything"],[7579,7735,"you've built so far,"],[7753,8098,"then deal with her right now!"],[8502,8700,"I don't care about getting my hands dirty."],[8773,9050,"But some women need to be taught a lesson."],[10325,10426,"You like it, huh?"],[10434,10534,"Huh?"],[11151,11305,"Let me go, please!"],[13127,13260,"Whoever hits her hardest,"],[13295,13439,"I'll make sure the chairwoman"],[13448,13559,"hears only good things"],[13559,13681,"about you when she arrives."],[13864,13968,"No!"],[13977,14077,"No!"],[14393,14593,"No! Let me go!"],[15788,16010,"Honey, help me!"]],"6":[[245,375,"You still bothering Mr. Duke?"],[545,681,"Stupid bitch!"],[1335,1489,"That's odd. Why does she hang up?"],[2775,2892,"Shh."],[3993,4122,"Mr. Duke, is there something"],[4122,4219,"I can help you with?"],[4236,4369,"Yeah, my wife is at HQ today"],[4369,4475,"doing some inspections."],[4488,4632,"Have you seen her around at all?"],[4646,4833,"Has anyone seen the chairwoman today?"],[4921,5089,"No, no, Ms. Flora."],[5114,5270,"-Please help me. -We haven't seen her."],[5592,5710,"What was that noise?"],[5778,5878,"No one."],[5900,6055,"You're just hearing things, sir."],[6063,6164,"Okay, well, look,"],[6173,6286,"the board meeting is about to start."],[6295,6402,"Could you go check the meeting room?"],[6411,6511,"I need to talk to her."],[6519,6641,"You got it, Mr. Duke."],[6787,6916,"-Continue. -Please!"],[6936,7128,"Wait, wait, wait, wait."],[7136,7249,"Listen to me."],[7257,7440,"I am the chairwoman you are talking about."],[7448,7572,"I am Dalton's wife!"],[7737,7907,"You? The chairwoman?"],[7945,8045,"Oh, please."],[8085,8205,"If that's the case,"],[8217,8385,"then I'm her long-lost mother."],[8395,8652,"And as her mother, I order you to go harder."],[8669,8769,"Get her up!"],[8812,8912,"Why is..."],[9245,9353,"Elena?"],[9361,9503,"Why is her phone off?"],[9584,9702,"Something's wrong."],[9791,9982,"I mean, she's pregnant, I can't let anything..."],[10163,10243,"Oh, God."]],"7":[[78,192,"Hey, have you seen Flora?"],[200,407,"-No, Mr. Duke. -How about my wife?"],[425,584,"-Your wife? -Yeah, her."],[593,693,"Elena."],[704,890,"No, sir. I haven't seen her neither."],[902,1091,"-Sorry. -Okay, thank you."],[1100,1200,"You're welcome, sir."],[2393,2525,"Oh, please!"],[2610,2741,"Not my stomach!"],[2763,2914,"I'm pregnant!"],[3003,3165,"She's pregnant?"],[3192,3326,"Who is the father, huh?"],[3335,3460,"Dalton, of course."],[3663,3781,"So you knew the chairwoman"],[3781,3911,"couldn't get pregnant."],[3959,4171,"And you decided to rub it in her face?"],[4229,4422,"You're beyond disgusting!"],[4437,4645,"Please, I'm the chairwoman."],[4653,4803,"Why don't you believe me?"],[4836,4975,"Believe you?"],[5095,5334,"Just because you're carrying his bastard child"],[5343,5532,"doesn't mean you deserve to be his wife."],[5624,5732,"What are we going to do?"],[5803,5975,"She's claiming to carry Dalton's kid."],[6047,6208,"If the chairwoman hears about this,"],[6220,6420,"she's going to kill us all."],[6837,6943,"Stop! Stop!"],[6951,7051,"Stop!"],[7113,7225,"I have a solution."],[7299,7400,"It's somewhat harsh,"],[7408,7608,"but it is also highly effective."],[8608,8867,"She's using that baby to try and trap Mr. Duke."],[8883,9044,"Just think about it for a moment."],[9053,9249,"If she actually gives birth, she'll definitely"],[9258,9437,"be after his money, his power,"],[9445,9548,"and absolutely everything"],[9557,9673,"that he has."],[9681,9785,"Then we have to stop her."],[9793,9957,"I'll immediately call the hospital."],[9986,10062,"and permanently"],[10070,10244,"get rid of that unwanted baby."],[10258,10430,"Who says we need a hospital?"],[10455,10632,"We can take care of the abortion right here."],[10655,10778,"Here? How?"],[11187,11359,"Hospitals don't have to be the only ones"],[11368,11508,"getting rid of mistakes."],[12284,12469,"No, my baby!"],[12514,12653,"No, my baby!"],[13393,13601,"You think your bastard child is going to destroy"],[13610,13764,"our chairwoman's family?"],[13865,13969,"Help!"],[13978,14191,"Someone help me, please!"],[14201,14306,"Quit it."],[14314,14414,"Mr. Duke isn't coming."],[14473,14608,"I'm the one who's in charge."]],"8":[[775,879,"Aren't we supposed to be having"],[887,1067,"-the board meeting in here? -Yes, Ms. Flora changed"],[1076,1200,"the location of the meeting."],[1207,1330,"They are in another building."],[1334,1461,"-Another building, okay. -Mm-hmm."],[2034,2179,"This feels wrong."],[2186,2330,"What are you so scared of?"],[2362,2532,"If she was fucking somebody's husband,"],[2536,2649,"then she should have known"],[2653,2790,"that there would be consequences."],[2807,2925,"What if something goes wrong?"],[2929,3043,"I said I'll take the blame."],[3057,3261,"Now shut up and watch how it's done."],[3901,4036,"-Have you seen Flora? -Yes, she was with"],[4036,4280,"a few security guards and a young woman."],[4290,4454,"-Young woman? -She's pretty."],[4458,4600,"I haven't seen her around before."],[4606,4711,"She must be new."],[4722,4887,"-Was it her? -Yes, yes, that's her."],[4918,5011,"Okay."],[5013,5187,"-Where did they go? -Meeting room."],[5205,5325,"Okay, thank you."],[5350,5586,"Please, Dalton and I just got pregnant."],[5661,5809,"Please don't hurt our baby."],[5870,5980,"All right, then."],[5989,6122,"Just kneel and clean my shoes"],[6131,6295,"and maybe I'll spare you."],[6374,6639,"You're... You're insane."],[6692,6842,"Are you going to clean them or not?"],[6880,7044,"You heard her. Hurry up."],[7086,7232,"Fine, fine."],[7236,7444,"Just don't hurt my baby."],[9708,9856,"What a pathetic little bitch."],[9889,10025,"She'll do anything to save"],[10029,10195,"that little bastard child of hers."],[10234,10366,"You really thought that's enough for me"],[10370,10539,"-to let you off the hook? -Why?"],[10572,10704,"Why are you doing this?"],[10795,10841,"Because I want"],[10849,11017,"to make sure you never forget."],[11055,11332,"I'm ending this pregnancy today."],[13246,13394,"Get her clothes off."],[15161,15450,"No, no, no, no, no."],[15487,15593,"No."]],"9":[[100,252,"Please, please."],[268,436,"No, no, no, no, no."],[2964,3084,"Flora?"],[3128,3360,"Are you sure that wasn't a little much?"],[3436,3556,"Come on."],[3568,3760,"You think the chairwoman wants a bunch of pussies"],[3764,3884,"on her board?"],[3924,4160,"I need this child out of her right now."],[4180,4296,"Please."],[4316,4536,"Please, I'm begging you."],[4596,4744,"Don't hurt my child."],[4760,4944,"I'll do whatever you want."],[4956,5068,"Please."],[5100,5212,"Anything, huh?"],[5296,5432,"Why do you care so much about"],[5436,5588,"some filthy bastard child"],[5588,5712,"that you're having out of wedlock?"],[5784,5884,"Please."],[5932,6232,"Dalton and I, we've been trying for so many years."],[6280,6492,"It's our only child."],[6800,6984,"Oh, you must be on something,"],[7028,7136,"if you think"],[7136,7308,"that your filthy bastard kid"],[7316,7516,"deserves our sympathy."],[8832,8960,"Who's there?"]],"10":[[143,257,"Who's there?"],[812,1007,"Flora, Mr. Duke is asking about you."],[1020,1136,"You should be on your way."],[1186,1381,"The board meeting doesn't start for a while."],[1396,1503,"Why is he looking for me?"],[1518,1618,"I'm not sure."],[1630,1730,"Okay, thanks."],[1746,1943,"If you see him again, make sure you let me know."],[2264,2389,"You filthy rat."],[2398,2544,"You tipped him off, didn't you?"],[2553,2727,"No, no, no, no, I didn't."],[2761,2970,"-I didn't. -Even if you did,"],[3166,3266,"I'm not scared."],[3299,3492,"An executive's whore like you"],[3562,3818,"isn't worth the dirt beneath my feet."],[4614,4903,"Mr. Duke, the meeting hasn't started yet."],[4981,5159,"-Why are you here so early? -Where is she?"],[5690,5790,"Who?"],[5876,6040,"Somebody saw you bring her in this room."],[6067,6167,"Oh."],[6210,6310,"That lady."],[6386,6577,"Yeah, she really is gorgeous."],[6684,6810,"What's your relationship with her?"],[6819,6944,"Cut the crap. Where is she?"],[6952,7216,"Oh, I just saw her in the lobby earlier."],[7248,7442,"-Are you sure? -One hundred percent."],[7451,7649,"I literally just saw her before I came up here."],[7658,7861,"Okay, everybody prepare for the meeting."],[7961,8148,"The chairwoman will be here any minute."],[9549,9727,"What was that noise?"]],"11":[[28,128,"What was that noise?"],[381,481,"What noise?"],[533,681,"-Did anyone hear anything? -No."],[746,913,"-No. -No, nothing at all,"],[921,1020,"Mr. Duke."],[1029,1185,"Maybe you just imagined it."],[1264,1403,"You're telling me nobody heard that?"],[1416,1583,"No. Sorry, sir."],[1647,1969,"Mr. Duke, you must be hearing things."],[2046,2263,"Are you sure you're getting enough sleep lately?"],[2310,2388,"Weird."],[2400,2524,"Prepare for the meeting, okay?"],[2565,2711,"I'm going to get the chairwoman now."],[3631,3811,"You thought I couldn't find you here, huh?"],[3997,4103,"Hello, Mr. Duke."],[4187,4292,"Have you seen this woman?"],[4399,4520,"No, sir, certainly."],[4846,4982,"Where are you, sweetheart?"],[4990,5184,"I can't let anything happen to you now."],[5193,5332,"Not with you pregnant."],[5665,5914,"I bet you thought Mr. Duke was going to find you here."],[6065,6219,"Not with me around."],[6273,6373,"Hold her down."],[6391,6658,"We're not stopping until this bitch miscarries."],[6745,6845,"Please."],[6961,7217,"Please. Don't hurt my baby."],[7235,7477,"I'll give you money for whatever you want."],[7486,7843,"Just... Just please leave him out of this."],[7866,8156,"You think I want your dirty, stinking money?"],[9258,9401,"Now that's more like it."],[9485,9701,"A dirty skank like you has no right to"],[9710,9890,"carry Mr. Duke's child."],[10021,10120,"No."],[10147,10446,"My baby is gone."],[10551,10697,"I'll kill you."],[11235,11339,"Hold her back."],[11479,11579,"Get up."],[11717,11817,"No."],[12083,12183,"No."],[13442,13634,"You killed my baby."],[13650,13837,"You're going to pay for it."]],"12":[[1,177,"You're going to pay for it."],[234,520,"What? So you're going to take me down?"],[543,826,"A two-bit slut whose only path to success"],[834,1004,"is fucking the CEO?"],[1025,1137,"Get a hold of yourself."],[1351,1544,"All right. The baby's toast."],[1613,1740,"Now that we've had our fun,"],[1749,1949,"let's get this bitch to the hospital."],[1981,2227,"The last thing we need is a death in the workplace."],[4489,4589,"Dalton."],[4609,4811,"Dalton!"],[4820,5002,"-Dalton! -Stand still, bitch."]],"13":[[3333,3442,"Sir."],[3451,3595,"How's the baby?"],[3627,3831,"It's not looking good."],[3930,4060,"But it's still too soon to say"],[4068,4253,"if the fetus is going to make it."],[4367,4603,"For now, it's best for you to stay here and rest."],[5508,5765,"I'm not done with you, Flora."],[5795,6097,"Not one bit."]],"14":[[2314,2417,"Dalton."],[2425,2567,"Something bad happened."],[2576,2850,"Come to the hospital as soon as you can."],[3842,3950,"Oh, no."],[3965,4112,"The chairwoman is in trouble."],[4144,4316,"I have to go tell Mr. Duke."],[5079,5257,"What if I don't tell Mr. Duke"],[5265,5465,"and find the chairwoman myself?"],[5551,5698,"That'll be the perfect way"],[5702,5902,"to make a good first impression."],[6293,6521,"Mr. Duke, why is the chairwoman so late?"],[6558,6679,"Is the meeting still on?"],[6743,6864,"You know what? The meeting's canceled."],[6872,6986,"I'm going to find her now."],[6998,7288,"Mr. Duke, you worked so hard for this meeting."],[7312,7458,"We can't just cancel it."],[7587,7813,"Why don't you let me find the chairwoman for you?"],[8369,8473,"That's true."],[8481,8665,"We all took time out of our busy schedules"],[8674,8790,"-to come here. -Yeah,"],[8798,9095,"and haven't we had all our other meetings"],[9104,9204,"without her?"],[9230,9405,"Why is this one any different?"],[9430,9545,"Exactly."],[95