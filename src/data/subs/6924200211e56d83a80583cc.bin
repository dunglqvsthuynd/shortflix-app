{"1":[[392,446,"Hey,"],[487,550,"Sofia."],[621,725,"They called you here too?"],[792,909,"Maybe I wanted to see somebody."],[3762,3878,"So, I..."],[3920,4183,"hear your ex is also in LA."],[4546,4614,"Wait."],[4650,4704,"What?"],[4746,4868,"Shouldn't we wait for"],[4868,4954,"Terry and Selena?"],[4996,5218,"This isn't the best part of town?"],[5267,5405,"No, I think"],[5405,5636,"Terry wanted to catch up with us."],[5672,5801,"Give us some alone time."],[5843,5901,"Oh."],[5972,6072,"I thought I had it all."],[6147,6431,"Love. A future. Until..."],[6569,6781,"You know, I was thinking..."],[6820,6908,"Mm-hmm?"],[6994,7115,"You're the light in my life."],[7173,7256,"And..."],[7365,7499,"I honestly don't think"],[7499,7621,"I can do it without you, so..."],[7866,7968,"I wanted to ask..."],[8208,8333,"if you would marry me."],[8541,8735,"Until a moment that shattered everything."],[8908,8982,"Yes!"],[9013,9094,"Yes!"],[9100,9138,"I..."],[9150,9304,"Ah!"],[9743,9821,"Selena?"],[9955,10009,"Oh, God."],[10035,10126,"Justin,"],[10155,10239,"help me..."],[10272,10356,"I got her."],[10356,10385,"I got her."],[10385,10458,"Go, go."],[10606,10655,"Terry!"],[10706,10813,"Terry, get down!"],[10844,10877,"Ugh!"],[10906,10975,"No!"],[11106,11161,"No!"],[11498,11553,"Justin!"],[11986,12028,"Oh, God."],[12087,12145,"Oh, God."],[12377,12477,"No!"],[12530,12644,"Help..."],[13100,13300,"Oh my God! Hi!"],[13300,13392,"That was a long time ago."]],"2":[[233,361,"Sofia, are you alright?"],[462,538,"Yeah."],[596,692,"Yeah, I'm fine."],[704,809,"Just tired."],[950,1031,"Probably jet lag."],[1255,1409,"Then get some rest."],[3520,3645,"Five years..."],[3703,3953,"He's a famous baseball star now."],[4091,4291,"And he probably doesn't even remember me"],[4346,4542,"after everything that happened that day..."],[5276,5423,"Oh ma'am, I'm so sorry."],[5472,5526,"Sorry?"],[5622,5833,"You think sorry can fix this?"],[5935,6131,"My son, he is a rising star"],[6131,6289,"and you almost ruined him!"],[6923,7044,"You don't deserve him."],[7186,7261,"You take this!"],[7286,7407,"And you get out of his life"],[7407,7532,"and don't you ever come back!"],[7532,7640,"Do you hear me?"],[7691,7977,"Wait, let me see him, please..."],[9601,9751,"Ah, there she is."]],"3":[[108,213,"Why are you here?"],[300,395,"Why can't I be here?"],[404,478,"Didn't you just pretend"],[478,558,"like you didn't know me?"],[817,913,"You have to get out."],[913,1014,"You're trespassing."],[1014,1130,"I can call the police."],[1401,1505,"You won't."],[1689,1772,"Sofia, it's me."],[1818,1935,"I brought you some fruit."],[2118,2243,"You have to get off me."],[2243,2327,"What is your relationship"],[2327,2385,"with this guy?"],[2409,2456,"Huh?"],[2573,2698,"Who do you think you are to ask?"],[2748,2831,"What do you think you'd do"],[2831,2907,"if he saw me here?"],[3019,3134,"Are you insane?"],[3194,3251,"Yeah."],[3299,3353,"Alright."],[3415,3536,"I'm leaving the fruit at the door."],[3599,3707,"Text me when you're awake."],[3774,3828,"Huh."],[3891,4029,"You guys don't live together?"],[4083,4297,"Just a game between us."],[4316,4437,"It's none of your business."],[4450,4537,"Well, you know what?"],[4579,4859,"I was crazy to come looking after you."],[5618,5763,"Why did you come after me?"]],"4":[[179,300,"Just a game between us."],[308,417,"None of your business."],[496,625,"Hey, a sports program wants to"],[625,704,"interview you."],[742,817,"Interested?"],[946,1021,"No..."],[1067,1247,"I don't see. I kinda want to take a break."],[1338,1476,"The show's got top ratings."],[1476,1547,"Their lead journalist"],[1547,1653,"just got back from Europe."],[1701,1800,"It could be great for your image."],[2060,2173,"At least just take a look, alright?"],[2248,2335,"Wait. Wait."],[2577,2648,"I'll do it."],[2731,2848,"Schedule it for tomorrow."],[2911,2986,"Tomorrow,"],[2986,3130,"we already have an event scheduled for you, though,"],[3130,3303,"so if I can push it back to-"],[3303,3382,"Cancel it."],[3403,3506,"Tell them I want to"],[3506,3766,"speak to the lead journalist."],[3966,4017,"Alright."],[4108,4196,"If you insist."],[4959,5059,"Sofia..."],[5184,5267,"Sofia."],[5309,5347,"Hey."],[5638,5751,"Really giving up on me?"],[5851,5935,"On us?"],[6014,6126,"Five years and"],[6126,6264,"you never came back to me."]],"5":[[308,333,"Oh."],[688,738,"Here."],[779,829,"Thanks."],[1055,1309,"The interviewee today is a bit..."],[1359,1418,"unique."],[1493,1595,"Could be a challenge."],[1726,1785,"Who is it?"],[1826,1963,"I'll prepare the outline later."],[2022,2099,"Oh, well."],[2369,2554,"Sorry, I don't think we ordered these."],[2582,2640,"Oh!"],[2652,2799,"Compliment to that gentleman over there."],[2994,3196,"Oh, a friend of yours?"],[5196,5347,"Oh my gosh, come on."],[5472,5534,"My little nerd."],[5784,5847,"It's your favorite."],[6051,6118,"Thanks."],[6539,6623,"Justin..."],[6690,6810,"Could it really be you?"]],"6":[[307,369,"Oh."],[542,617,"Hello?"],[746,788,"What?"],[855,925,"An emergency?"],[992,1063,"Okay, sure,"],[1063,1188,"I'll head right in."],[1309,1385,"I'm so sorry,"],[1385,1518,"something came up with yesterday's report"],[1518,1663,"and I've gotta head into the office."],[1664,1730,"It's okay."],[2802,2877,"Hey there,"],[2902,2974,"I'm Eric."],[3002,3048,"Chief editor."],[3123,3215,"And this is Sofia,"],[3282,3374,"our lead journalist."],[3641,3699,"Justin."],[3916,4045,"Long time no see,"],[4112,4199,"old friend."],[4270,4396,"Oh, you two know each other?"],[4554,4592,"Yeah."],[4592,4662,"Yes,"],[4683,4849,"Justin and I went to college together."],[4884,4946,"Ouch."],[4946,5162,"It's very nice to see you again."],[5392,5526,"This is Eric,"],[5526,5722,"my colleague and..."],[5793,5901,"husband."],[6414,6448,"Cool."],[6564,6643,"Small world."],[6694,6832,"Very small."],[6994,7069,"Well,"],[7069,7155,"maybe we should just"],[7155,7248,"start the interview,"],[7248,7303,"right?"],[7499,7582,"No,"],[7607,7775,"I'm not really feeling so good anymore."],[7891,7955,"Sorry."]],"7":[[133,273,"You seem perfectly fine."],[273,460,"How exactly are you not feeling good?"],[479,644,"No, I'm going through a little"],[644,784,"bit of a heartbreak right now."],[784,825,"So..."],[1088,1205,"You're being childish?"],[1209,1393,"Well, I'm not as composed and"],[1393,1605,"reliable as your husband here."],[1680,1853,"If Justin isn't feeling well,"],[1868,1987,"then we can always reschedule."],[2001,2052,"Reschedule?"],[2143,2272,"Ooh, no, I'm pretty packed"],[2272,2419,"for the next few weeks too, so..."],[2489,2510,"Sorry."],[2865,2929,"Let's go."],[3065,3253,"Yeah, thank you."],[3370,3420,"Hey-"],[3883,4074,"Hey, Justin..."],[4208,4349,"He's your ex, right?"],[4483,4531,"Yes."],[4637,4867,"But that's ancient history."],[4979,5297,"I'm sorry for dragging you into this."],[5321,5520,"You know, it was an honor."],[5588,5693,"In fact,"],[5693,5819,"I wouldn't mind"],[5819,5986,"playing this role a bit longer."]],"8":[[0,104,"Sofia Macaulay?"],[104,250,"After five years,"],[250,376,"what's she doing back?"],[462,537,"Married, huh?"],[1021,1252,"Justin, guess who I just saw?"],[1301,1483,"Sofia with her husband."],[1559,1628,"What a heartless bitch."],[1628,1701,"I mean, she dumped you"],[1701,1776,"back then and now..."],[1776,1897,"What? She's happy and married?"],[1897,1951,"Enough!"],[2035,2268,"That's none of your business."],[2369,2431,"Fine,"],[2464,2598,"then we'll talk about us."],[2598,2719,"Today is my birthday,"],[2719,2865,"so spend it with me."],[2986,3048,"Happy birthday."],[3182,3240,"Like it or not,"],[3240,3363,"your mom invited me to dinner, so"],[3363,3478,"you'll celebrate with me."]],"9":[[571,642,"Yeah, Mom."],[684,763,"Justin,"],[763,938,"tonight is Esther's birthday,"],[938,1109,"and you are coming home for dinner."],[1130,1230,"No excuses."],[1347,1413,"I can't."],[1443,1526,"I have plans tonight."],[1559,1639,"Plans?"],[1685,1876,"Oh, let me guess."],[1901,2147,"Those plans have to include Sofia."],[2235,2302,"You know what?"],[2302,2498,"I don't understand how you can"],[2498,2675,"even be near that woman"],[2675,2836,"after everything she's done to our family."],[2877,3015,"You know, Justin, she is the"],[3015,3174,"reason for your sister's death, right?"],[3349,3513,"Let me guess. Esther told you this?"],[3561,3675,"It doesn't matter."],[3695,3795,"You know what matters?"],[3795,3903,"What matters is that"],[3903,4012,"Esther is patient,"],[4012,4133,"she's loyal, and"],[4133,4279,"frankly, she's good for you."],[4354,4450,"And she's waited for you-"],[4450,4608,"I don't love her."],[4608,4802,"I've told you this countless times."],[4850,4950,"I don't care."],[4950,5130,"If you can't make it to dinner tonight,"],[5130,5280,"I've booked a reservation at a"],[5280,5392,"restaurant for you two tomorrow."],[5413,5654,"So there's no excuses this time, Justin."]],"10":[[229,271,"Sofia,"],[271,422,"thank you so much for the invite."],[487,617,"I should thank you"],[617,734,"for all your help lately."],[850,944,"Here's a menu."],[992,1175,"This is my favorite spot in LA."],[1234,1314,"-Amazing. Yeah. -I know."],[1314,1413,"Okay. Let's take a look."],[1780,1914,"OMG, not him again."],[2006,2168,"So he's with Esther now."],[2264,2381,"What a coincidence."],[2381,2510,"And who's this?"],[2719,2848,"This is..."],[2877,2961,"Eric."],[3007,3112,"My husband."],[3142,3257,"Alright."],[3257,3467,"Okay. Ran off for five years"],[3467,3641,"and now you got married, huh?"],[3782,3888,"I'm not like you."],[3937,4136,"Desperately holding on to one person."],[4441,4533,"You bitch!"],[4533,4579,"Hey!"],[4625,4792,"You better choose your words more carefully."],[4921,5009,"My wife..."],[5067,5142,"is not someone"],[5142,5301,"who can be insulted at will."],[5363,5413,"You..."],[5413,5616,"Esther, chill."],[5743,5819,"Are you gonna eat"],[5819,5904,"or you gonna leave?"],[6005,6080,"Eat."],[6322,6448,"Thank you, Eric."],[6485,6581,"That's why I'm here for."],[6886,6969,"Justin,"],[6969,7065,"yesterday is my birthday."],[7065,7107,"Don't you think"],[7107,7248,"you owe me something special?"],[7248,7440,"Can you please"],[7461,7665,"cut it out with that sickening voice!?"],[7699,8040,"Just order and eat."],[8040,8115,"Can you do that?"]],"11":[[429,513,"Oh my..."],[513,672,"I am so sorry, I tripped."],[730,917,"You know what, if you can't afford to pay for that,"],[917,1019,"I'll do it, because I know that"],[1019,1172,"you don't make a lot as a journalist."],[1422,1512,"What the hell are you doing?"],[1614,1847,"Thank you for the gesture, Justin."],[2060,2269,"Esther, you can stop"],[2269,2401,"pretending that we're rivals."],[2489,2786,"I didn't choose Justin five years ago,"],[2882,3059,"and I don't choose him today."],[3274,3319,"Are we clear?"],[3411,3478,"Are you serious?"],[3978,4008,"Let's go."]],"12":[[513,600,"Selena,"],[696,885,"I'm sorry I'm so late this year."],[967,1323,"Usually I come early to avoid Justin, but..."],[1396,1569,"life has been so busy."],[1743,1986,"I ran into your brother recently."],[2122,2198,"Without me,"],[2198,2365,"he seems to be doing just fine."],[3349,3536,"How dare you show up here?"],[3586,3737,"My daughter is dead"],[3737,3828,"because of your brother"],[3828,4008,"and you have that nerve to show up here!"],[4074,4175,"Shame on you."],[4175,4325,"Mom, stop it!"],[4617,4796,"Why are you still protecting her?"],[4842,4898,"Why?"],[5088,5283,"Ma'am, I'll just go."]],"13":[[362,454,"Hi, Terry."],[1405,1630,"I never wanted things to end up like this."],[2677,2836,"Thought I would find you here."],[3253,3403,"We lost a lot that night."],[3599,3653,"Your brother."],[3858,3928,"My sister."],[4204,4275,"Each other."],[5130,5237,"Come on. No."],[5372,5507,"-Just go. -Okay."],[6723,6869,"Wait, don't go."],[7432,7515,"Do you even know who I am?"],[7678,7801,"You're Justin."],[8871,8975,"You always seem to mess up at the"],[8975,9132,"most crucial moments, don't you?"],[9255,9480,"Guess things aren't going very well between them."],[9559,9627,"Great."]],"14":[[645,794,"Oh..."],[833,947,"God."],[1288,1447,"Never again with the drinking."],[1956,1993,"Hello?"],[2047,2233,"Justin Miller agreed to the interview,"],[2255,2515,"but he insisted that you conduct it."],[2552,2711,"It's okay, though, if you don't want to go."],[2761,2952,"No. I'll do it."],[2973,3269,"I won't let my personal life affect my work."],[3941,4237,"Can I speak to... Sofia alone?"],[4542,4725,"It's fine. I'll handle it."],[5251,5326,"First question."],[5480,5618,"Mr. Miller, your family"],[5618,5818,"oversees numerous enterprises."],[5868,6070,"What made you pursue a career in baseball?"],[6185,6252,"For someone."],[6443,6610,"She once said she wanted to see me"],[6610,6715,"hit a home run."],[7490,7649,"Yes! Yes!"],[7716,7807,"Did you see that?"],[7807,7991,"You are gonna be amazing like that one day."],[8058,8119,"You think so?"],[8141,8179,"Yes!"],[8266,8350,"Whoo!"],[8921,8998,"Do you still think"],[8998,9156,"she wants to see me hit home runs?"]],"15":[[504,671,"I'm sure it wasn't just for her."],[750,937,"Your fans want to see you make a comeback."],[1284,1317,"Okay."],[1463,1524,"Next question."],[1547,1661,"Five years ago during the Yankees game,"],[1661,1789,"you made a critical error."],[1789,1885,"Can you explain what happened?"],[1885,1936,"Yeah."],[1951,2145,"You have no right asking that question."],[2185,2344,"Justin was stabbed protecting you."],[2344,2452,"It ruined his season."],[2485,2620,"It's all your fault."],[2642,2717,"Hey."],[2990,3142,"Looks like you have other commitments today."],[3186,3228,"I'll go."]],"16":[[0,178,"Looks like you have other commitments today."],[178,256,"I'll go."],[671,838,"Mr. Miller, your girlfriend is here."],[1005,1090,"Watch your manners."],[1851,2056,"Sofia, you've never chosen me."],[2056,2218,"Not five years ago, not now."],[2335,2439,"Sofia, stop right there!"],[2610,2740,"Why are you still chasing after Justin?"],[2861,2966,"Oh, honey."],[3065,3169,"You've lost your mind."],[3244,3403,"Interviewing him is my job."],[3465,3597,"Don't play innocent."],[3597,3808,"You're using your job to get close to Justin."],[4012,4432,"Hey! Don't touch my wife."],[4462,4529,"How dare you!"],[4713,4779,"Let's go."],[5367,5426,"Esther."],[5684,5997,"Justin, I will no longer"],[5997,6149,"tolerate you being with Sofia."],[6218,6323,"No, no."],[6352,6523,"You continue to pursue this woman,"],[6523,6815,"you and I, we are done as mother and son."],[7782,7912,"Esther,"],[7949,8206,"I am so sorry"],[8230,8376,"for what Justin has done to you."],[8512,8688,"This is the ring that"],[8750,8973,"I got for my future daughter-in-law."],[9029,9129,"I wanna give it to you."],[9267,9386,"Thank you, Mrs. Miller."]],"17":[[813,1037,"I can't wait see you on the big stage one day"],[1037,1316,"as a professional athlete."],[1426,1531,"And what's your dream?"],[1534,1664,"I'm going to be the best"],[1664,1810,"sports journalist out there."],[1856,1956,"And promise me."],[1985,2097,"I'll be the first one you interview."],[2218,2252,"Deal."],[2948,3136,"We had so many beautiful memories."],[3253,3420,"How could you just move on, Sofia?"],[4521,4757,"Justin, what are you doing here?"],[4959,5024,"I miss you."],[5142,5249,"I miss you so much."],[5818,5965,"I miss you too."],[6414,6632,"I- I love you."],[6756,6880,"I'm never gonna stop loving you."]],"18":[[50,287,"Your family ruined Selena's life."],[312,487,"Justin doesn't want to see you again."],[704,889,"No, we can't. We can't do this."],[967,1051,"But"],[1051,1247,"I don't want anyone"],[1247,1341,"but you."],[1341,1388,"If none of this ever happened,"],[1433,1598,"if things like went a different way,"],[1627,1739,"wouldn't everything be different?"],[2348,2506,"If only everything had been different."],[2794,3069,"If only this had never happened."],[3541,3670,"Justin,"],[3782,3985,"you gotta leave."],[3990,4065,"Please."],[4241,4464,"Don't you have a game"],[4540,4710,"to prepare for? Day after tomorrow."],[4729,4867,"Yeah, here."],[4984,5105,"Actually, I got you a ticket."],[5163,5271,"I really want you to be there."],[5797,5876,"How about this?"],[5901,5990,"If you don't come to my game,"],[5990,6121,"I won't let you publish my interviews."],[6206,6256,"So..."],[6322,6410,"See you there."]],"19":[[663,825,"She won't even bother to show up now."],[1251,1381,"He is such an idiot."],[1518,1797,"I could take a few photos for the article."],[3495,3661,"He hasn't changed at all."],[3757,3953,"Sofia, seriously, you again?"],[3970,4056,"Don't you dare pretend that"],[4056,4205,"you're not clinging to Justin."],[4207,4329,"Stay away from him."],[4391,4495,"Who do you think you are"],[4495,4597,"to talk to me about that?"],[4646,4737,"His Fiancé?"]],"20":[[108,248,"Congratulations."],[260,425,"I hope that works out for you both."],[1096,1180,"Justin,"],[1238,1434,"you're the king of the field, unstoppable."],[1482,1672,"Whoa, who gave you that?"],[1722,1835,"Um, your mom, I thought..."],[1835,1995,"Take it off, now!"],[2106,2181,"Okay."],[2193,2263,"Give it to me."],[2356,2482,"Don't ever cross that line again."],[3023,3177,"This is all Sofia's fault!"],[3186,3263,"If it weren't for her,"],[3263,3385,"Justin would have been mine."]],"21":[[558,678,"It's all lies."],[763,913,"I have to move on this time."],[1026,1149,"Why did I believe him"],[1149,1247,"when he said he'd never"],[1247,1388,"stop loving me that day?"],[1493,1610,"I'm such an idiot."],[2218,2284,"Hey."],[2640,2865,"I was worried when you didn't answer my call."],[2944,3011,"I'm fine."],[3144,3371,"I'm sorry, Eric, but I just need time alone."],[3449,3724,"I know that you still care about Justin,"],[3782,4079,"but please, give me a chance to win you over."],[4604,4833,"And no pressure, but I brought"],[4833,4967,"your favorite blueberry pancakes."],[5000,5238,"A sweet treat can always help sweeten things up."],[5380,5506,"Come on, I'll make you some coffee."],[5523,5607,"Okay."],[7023,7123,"What are you doing here?"],[7198,7244,"So,"],[7307,7421,"you really think if I weren't here,"],[7421,7579,"it would be you instead."],[7645,7730,"What are you doing here?"],[7849,7915,"Thanks, babe."]],"22":[[241,354,"Oh, here. Let me get you a refill."],[367,500,"Oh, thank you."],[1063,1222,"Mr. Davis!"],[1222,1421,"I'm Sofia Macaulay from Frontline Today."],[1421,1573,"It's such a pleasure to meet you, sir."],[1639,1801,"Whoa, there he is!"],[1890,1985,"Just in time."],[2001,2264,"Let me introduce you to our brand ambassador."],[2277,2492,"Justin is an all-star baseball player whose team"],[2492,2656,"just won International Baseball League."],[2706,2921,"Sofia, if you want to"],[2921,3214,"get the full story on our brand's soul,"],[3241,3490,"Justin is our perfect match."],[4112,4212,"You know what?"],[4637,4779,"Justin! Put me down!"],[4779,4903,"Let's turn this party into a headline."],[4903,5021,"Tomorrow, we're gonna be front pages."],[5113,5217,"Here's your fresh glass"],[5217,5309,"of Milwaukee's fun-"],[5497,5551,"Sofia?"]],"23":[[608,667,"Don't move!"],[804,917,"Justin, what are you doing?"],[917,980,"I got it."],[1166,1225,"Ow!"],[1418,1543,"You know, you're in this condition"],[1543,1701,"and you're still pushing for an interview?"],[1747,1918,"That interview matters to me."],[3524,3611,"Perfect."],[3641,3827,"He still remembers my size."],[4033,4316,"You know, you're injured and your husband"],[4316,4545,"is nowhere to be seen."],[4738,4969,"You taste in men has really gone downhill."],[5150,5370,"That's really none of your business, so..."]],"24":[[254,508,"Eric is so much better than you."],[671,733,"Better than me?"],[771,956,"Yeah, in every way."],[996,1063,"Better than me."],[1247,1382,"I love to prove you're wrong."],[2815,3135,"Justin, I'm married and you're engaged."],[3135,3153,"Wh-"],[3153,3253,"What do you think this is?"],[3253,3414,"Whoa, engaged?"],[3436,3528,"No, no, no, no."],[3566,3649,"The ring that Esther had,"],[3649,3771,"that was a misunderstanding."],[3858,4075,"I even tried to go to your place and explain."],[4200,4271,"Enough!"],[4346,4663,"I am done listening to your lies."]],"25":[[617,852,"Mom, what are you still doing up?"],[917,1032,"How was I supposed to sleep?"],[1080,1229,"Knowing that you were with Sofia."],[1422,1521,"It was a coincidence."],[1584,1779,"Oh, a coincidence."],[1835,1964,"It was a coincidence you"],[1964,2077,"carrying her out of the room."],[2077,2192,"That's a coincidence?"],[2769,3023,"You are not to see this woman again."],[3032,3103,"Oh, you and I?"],[3136,3331,"We are over as mother and son."],[3490,3554,"You had me followed?"],[3554,3771,"Yes, I had you followed."],[3862,4200,"Have you forgotten how your sister Selena died?"],[4225,4396,"It is because of Sofia and"],[4396,4592,"her useless brother Justin."],[4833,4925,"We all love Selena."],[4925,4969,"Yeah."],[5017,5181,"But Sofia had nothing"],[5181,5359,"to do with her death, okay?"],[5359,5555,"I get your grieving, but"],[5660,5812,"it's not gonna bring her back!"],[5868,5940,"It's not."],[6081,6302,"So you, you are defending her?"],[6335,6554,"You're defending her after everything?"],[6690,6968,"Justin, you are not to see this woman again."],[7036,7298,"Not as long as I'm alive. You got it!"],[8658,8921,"No matter what, I cannot let you go, Sofia."]],"26":[[613,650,"Hello?"],[729,1059,"Sofia! Don't forget about the reunion tonight!"],[1105,1188,"Everyone is here!"],[1276,1556,"Uh, Annie, I don't know. I'm a little tired."],[1597,1860,"Come on! I really miss you!"],[1860,2022,"I haven't seen you in such a long time."],[2160,2312,"Fine. Okay, I just-"],[2312,2453,"I gotta go home and change first, alright?"],[2453,2510,"But I'll be there."],[2552,2594,"Okay."],[2740,2798,"Bye."],[3616,3666,"Okay."],[3766,3828,"Sofia!"],[4008,4080,"You are late,"],[4080,4192,"which means you have to drink"],[4192,4270,"as your punishment."],[4592,4637,"Alright."],[4742,4929,"Oh, that's Justin's glass. He just drank from it."],[5426,5509,"Sorry."],[5538,5697,"All right, so let's continue to play."],[7207,7332,"What are you running from?"]],"27":[[0,91,"What are you running from?"],[216,287,"I'm not running."],[367,513,"Sofia, we'll start with you."],[579,617,"Uh, truth."],[721,997,"Do you still have feelings for your first love?"],[1609,1714,"Okay."],[1714,1743,"Wow."],[1906,2014,"Must be a touchy subject!"],[2118,2339,"Uh, Justin, we'll do you next."],[2414,2561,"All right, I'll take a dare."],[2765,2969,"Kiss one of the women here."],[3461,3589,"He's definitely kissing Esther."],[3620,3678,"Of course,"],[3678,3852,"Esther has been by his side for years."],[3852,4047,"Not to mention they're perfect for each other."],[4066,4353,"Of course. She's his fiancé now."],[4373,4508,"Why does this bother me?"]],"28":[[412,542,"Okay,"],[654,846,"let's keep playing the game."],[1276,1555,"Didn't Esther say Sofia's married?"],[1705,1972,"Justin, aren't you afraid that her husband's"],[1972,2277,"going to come after you for kissing his wife?"],[2494,2715,"Sofia, it's just a game."],[2715,2849,"Don't take it so seriously."],[2894,2936,"Sofia,"],[3069,3161,"back in college, eveyone"],[3207,3361,"called you the Queen's charm."],[3524,3641,"I guess they were right."],[3770,3927,"Having a killer brother and all,"],[3927,4029,"and you must have some special charm"],[4029,4154,"to even dare show up here."],[4836,5050,"Shut your filthy mouth."],[5096,5385,"If I hear one more word against Terry,"],[5400,5575,"I'm going to sue you for slander."],[5939,6050,"You bitch!"],[6064,6122,"Hey."],[6281,6410,"Never talk to a woman like that."]],"29":[[16,191,"I'll catch you messing with Sofia one more time."],[254,412,"It's not gonna end so easy for you."],[625,850,"Yeah, I won't. I won't, I swear!"],[1096,1153,"Hey."],[1370,1440,"You're hurt."],[1601,1815,"Let's go. I'm sorry."],[1860,1927,"Yeah."],[2077,2181,"She still cares about me."],[2719,2761,"Ouch."],[2848,2894,"Sorry."],[3224,3315,"You know,"],[3315,3503,"you shouldn't have lost it like that."],[3578,3766,"You're a celebrity now."],[3841,4079,"And your every move is being watched."],[4158,4258,"Yeah, but he hurt you."],[4433,4546,"No one's allowed to hurt you."],[4571,4648,"Never."]],"30":[[759,867,"Ow."],[867,954,"Ouch."],[971,1121,"I'm sorry, I'm sorry."],[1305,1601,"But now that you are all patched up,"],[1780,1958,"you can see yourself out."],[2052,2135,"You're still kicking me out?"],[2273,2587,"You're this big hot shot star athlete."],[2673,2773,"You really want us to be on"],[2773,2883,"the front headlines tomorrow?"],[2961,3090,"I don't care about the headlines."],[3178,3346,"I do. Go."],[3415,3470,"Bye."],[4325,4480,"What the hell were you thinking, Justin?"],[4583,4723,"You know, you've got a reputation to uphold!"],[4779,5004,"Every move you make is under scrutiny."],[5009,5068,"Do you have an idea how much"],[5068,5211,"it costs me to bury this news?"],[5476,5513,"Hey."],[5851,5958,"Am I interrupting?"],[5980,6156,"No, you're not interrupting."],[6281,6427,"Hey Mark, we're done here."],[6664,6748,"Unbelievable."]],"31":[[120,150,"Hi, Mark."],[450,521,"Hey."],[542,777,"I thought maybe you hadn't eaten yet."],[988,1092,"Is that how you repaying me"],[1092,1252,"for taking that bunch yesterday?"],[1280,1597,"Yeah, I saw the news reports about that."],[2056,2252,"You are a curse!"],[2252,2439,"And ever since you've shown up,"],[2460,2715,"Justin's life has been in shambles. Justin!"],[2819,2973,"One husband isn't enough for you?"],[3011,3144,"You're here to ruin Justin again?"],[3165,3324,"Mom, stop it."],[3324,3499,"No, no, you, get out!"],[4062,4162,"I'm sorry."],[4225,4441,"No, I shouldn't have come."],[4500,4593,"It's my fault."],[4692,4813,"I won't come again."],[5196,5296,"Ugh."]],"32":[[175,279,"How are you feeling, Mom?"],[304,433,"It's Sofia's fault."],[517,913,"Every time she shows up, disaster follows."],[1205,1368,"Mrs. Miller, how are you feeling?"],[1368,1482,"I made you some cookies."],[1572,1889,"Esther, you are such a thoughtful girl."],[2018,2168,"You know, why don't you"],[2168,2334,"come and stay at the house for a while?"],[2334,2511,"I mean, you could keep me company"],[2511,2660,"during my recovery."],[2660,2719,"Of course,"],[2719,2836,"I would love to."],[3028,3165,"Becoming Justin's fiance is just"],[3165,3265,"around the corner."],[3265,3486,"Sophia, let's see what you have left to fight me for."],[3566,3887,"Hey Mom, we already have caretakers."],[3916,4133,"Esther doesn't need to stay with us."],[4133,4304,"Justin? No!"],[4341,4556,"This is not up for discussion."],[4612,4788,"I have made up my mind."],[5063,5367,"Alright, yeah, do whatever you want."],[5463,5605,"Look at these cookies."]],"33":[[746,859,"What are you still doing here?"],[917,1013,"You haven't had dinner yet."],[1138,1201,"Have you?"],[1326,1426,"Come on, let me take you home."],[1789,2010,"Alright, I will eat it in the car."],[2060,2089,"Yes."],[2681,2756,"This is for you."],[3169,3278,"Thank you."],[4245,4308,"Sofia."],[4612,4642,"Don't."]],"34":[[250,312,"Don't."],[542,617,"Eric,"],[667,859,"we should stay colleagues."],[1009,1426,"I know it's silly, but I still have feelings for Justin."],[1580,1814,"And honestly, I can't"],[1814,2001,"fall for anyone else right now."],[2010,2202,"But he treats you in a way that..."],[2202,2419,"Good night, Eric."],[3820,4200,"You are a curse and ever since you've shown up,"],[4225,4500,"Justin's life has been in shambles. Justin!"],[4583,4650,"Justin,"],[4742,4962,"can we ever get back to where we were?"]],"35":[[312,575,"So what is so special about Sofia Macaulay?"],[658,863,"She's married and you still can't let her go."],[971,1409,"For five long years, every day, every second."],[1534,1610,"She's in my head."],[1755,2008,"Five years, you're still stuck."],[2093,2293,"But she, she's moved on."],[2344,2469,"She doesn't care about you anymore, man."],[2473,2646,"No, she cares."],[2756,3053,"No, you're just lying to yourself, pretending."],[3128,3224,"This isn't healthy, man."],[3378,3420,"You know what?"],[3499,3672,"You just don't get it, okay?"],[3707,3732,"You don't."],[3903,4141,"She's married, alright?"],[4187,4307,"What are you gonna be, a side dude?"],[4379,4441,"To hell with it all."],[4517,4621,"I don't care about the ethics..."],[4692,4833,"I don't care about anything,"],[4929,5000,"but her."]],"36":[[379,429,"Hey."],[742,838,"Justin, what are you doing here?"],[880,970,"Can I just come inside?"],[1080,1113,"Please."],[1222,1376,"Haven't you and your mother done enough?"],[1572,1780,"Or do you think I need another round of insults"],[1780,1881,"to complete my day?"],[1881,2137,"Look, I'm sorry about yesterday."],[2181,2239,"I really am."],[2360,2494,"Can you let me stay?"],[2602,2748,"I don't care how, I'll be your... like..."],[2831,2977,"I'll be your secret, I'll be your mistake,"],[2977,3299,"I'll be your lover, anything."],[3728,3970,"Justin, I promised your mother..."],[4187,4266,"We can't."],[5734,5975,"No, Justin, we can't."],[6222,6548,"Listen, every time I look at you,"],[6581,6906,"I see Selena and Terry"],[7027,7222,"and everything we lost."],[7361,7540,"I can't move forward with you"],[7540,7707,"because I'm stuck in the past."],[7791,8099,"So, no, we can't."],[8329,8451,"Please, leave."],[8775,9122,"I get your concerns, but I am not going anywhere."],[9221,9317,"I'm gonna wait for you,"],[9317,9583,"because the world without you"],[9650,9782,"means nothing to me."]],"37":[[200,538,"So this is where you work. Not very impressive."],[658,835,"If you're here to waste my time,"],[880,1021,"the door is right where you came in."],[1113,1370,"Don't be so defensive. I came with a little tip."],[1380,1528,"Brooks Swift, the football star,"],[1528,1636,"he'll be at West Hollywood Park"],[1636,1735,"with this boxing group."],[1764,1919,"Could make for a pretty good story."],[2097,2209,"Why would you tell me this?"],[2327,2465,"Let's just say I'm feeling generous."],[2465,2627,"I mean, after all, I am marrying Justin,"],[2627,2778,"so no hard feelings, right?"],[3207,3450,"If that's true, where's your engagement ring?"],[3524,3664,"That's none of your business."],[3703,3798,"But I will say"],[3798,3909,"that if you don't act fast,"],[3909,4073,"your competitor Star-shine Time,"],[4073,4179,"they'll be circling it."],[4241,4377,"Consider it my goodwill gesture"],[4377,4494,"for old time's sake."],[4717,4863,"Let's see what kind of"],[4863,5077,"tricks you're pulling, Esther."]],"38":[[568,650,"Well."],[692,878,"No sign of Brooks Swift."],[934,1051,"Maybe he's running late."],[1092,1209,"Let's take a seat over there."],[1230,1255,"Yeah."],[1755,1801,"Hot day."],[2810,3069,"What a coincidence."],[3424,3520,"What's up?"],[3682,3824,"Justin, couldn't you wait for me?"],[3841,3891,"No."],[4145,4291,"Well, too bad for you, Sofia."],[4325,4472,"Brooke Swift isn't coming today."],[4487,4562,"Such a pity."],[4692,4733,"That's okay."],[4867,4929,"Justin's here."],[4992,5180,"And who's a bigger name in sports than him?"],[5388,5499,"Always happy to help."],[5626,5922,"Well, since you're here, why not a match?"],[5955,6065,"Do you have the guts?"],[6076,6207,"Sofia, you've always told me"],[6207,6327,"you're a world-class boxer."],[6393,6502,"I've forgotten to see you in action."],[6569,6748,"How come I didn't know Sofia could box?"],[6802,6865,"I can't believe this guy"],[6865,6961,"knows her better than I do."],[6986,7040,"Damn it."],[7077,7219,"Now that you mention it,"],[7311,7453,"I'll take you on."],[7832,8109,"But don't say I didn't warn you."]],"39":[[154,251,"Sofia, you should save yourself"],[251,315,"the embarrassment."],[315,433,"Just quit while you still can."],[658,725,"Alright."],[850,952,"Are you guys ready?"],[1117,1178,"Box!"],[2156,2218,"If you need me to take it"],[2218,2339,"easy on you, just say so."],[2339,2419,"I hate wasting time."],[2798,2894,"You should know your limits."],[3542,3593,"Yeah!"],[3728,3920,"You hit me! You actually hit me!"],[4003,4263,"Not all of us waste five years not improving."],[4771,4869,"Sofia!"]],"40":[[658,696,"You okay?"],[788,842,"Sofia, are you alright?"],[842,913,"Please tell me you're alright."],[1026,1248,"I'm fine. I think."],[1529,1758,"Justin. Your hand."],[1801,1885,"You're hurt."],[2018,2177,"Eric, call the ambulance."],[2189,2214,"Okay."],[2452,2609,"Why wasn't Sofia who got hurt?"],[3019,3271,"Tony, I'll pay you a fortune. A huge sum."],[3328,3553,"Just make sure that Sofia Macaulay is ruined."],[3737,3874,"Mr. Miller's"],[3874,4096,"right wrist was dislocated,"],[4096,4231,"but it's been successfully set."],[4238,4358,"He'll need rest and should"],[4358,4510,"avoid intense activity for now."],[4550,4646,"Thank you, Doctor."],[4992,5072,"Sofia."],[5296,5377,"Can we talk?"],[5555,5755,"I am stepping aside."],[5855,5941,"What are you saying?"]],"41":[[45,251,"Justin... his right hand"],[251,450,"means everything as a baseball player."],[504,713,"And he didn't hesitate for a second"],[721,879,"to risk it all for you."],[975,1330,"That kind of love, I just can't compete with."],[1459,1536,"Eric, I..."],[1536,1760,"You don't have to say anything, okay?"],[1901,2007,"Just be happy."],[3294,3428,"You should probably get going."],[3436,3511,"Don't want to ruin your"],[3511,3704,"perfect Sunday with your husband."],[4275,4454,"I took it too far. I'm sorry."],[4517,4630,"Are you insane?"],[4758,4912,"Do you understand how important"],[4912,5064,"your right hand is to your career?"],[5255,5535,"Your season, your future."],[5605,5847,"Baseball is everything to you."],[5908,6089,"What were you thinking?"],[6218,6430,"What if your hand was permanently damaged?"],[6430,6489,"What if-"],[6627,6950,"I never would have forgiven myself. Never!"],[7094,7275,"I would have risked my entire career,"],[7275,7399,"my whole future, everything."],[7528,7719,"Just to know you're kept safe."],[7928,8053,"Do you even"],[8053,8345,"understand how much you mean to me?"],[8854,8996,"I'm not married."],[9117,9291,"Eric is just my colleague."],[9597,9690,"I knew it."],[9872,10047,"Just know why your taste could be that bad."],[10143,10264,"Okay, don't be mean."],[10752,11047,"You know you drive me crazy, right?"],[11398,11565,"We've got a problem. Big one."]],"42":[[0,90,"Hi, Mark."],[91,273,"Baseball Star Justin Miller,"],[273,437,"homewrecker for love,"],[437,615,"caught in a passionate kiss!"],[629,744,"What the hell were you thinking?"],[988,1167,"Hey, they actually got my good side at that time."],[1201,1357,"Justin, this isn't funny."],[1368,1456,"This is serious."],[1463,1586,"It can get worse."],[1589,1753,"Okay, that guy you punched, Tony?"],[1772,1901,"He's been making the rounds with the media"],[1901,2102,"claiming that you assaulted him without cause."],[2147,2264,"The internet is loving it."],[2264,2335,"They're eating it up."],[2335,2459,"These posts I'm seeing"],[2459,2606,"do not put you in a good light, buddy."],[2686,2957,"The sponsors are threatening to drop you."],[3002,3152,"The team's board is debating"],[3152,3257,"whether to bench you."],[3332,3574,"Justin, this could ruin everything."],[3728,3872,"Just let them talk."],[3983,4075,"I love Sofia."],[4175,4292,"That's all that matters."],[4383,4491,"You serious right now?"],[4562,4604,"Yeah."],[4604,4722,"You're letting your love life"],[4722,4848,"destroy your career."],[4929,5297,"You are a complete romantic idiot."],[5647,5731,"Unbelievable!"],[5793,5980,"You two are unbelievable."],[6243,6468,"This is the last time I'm cleaning up your mess."],[6623,6744,"Next time you're on your own."]],"43":[[183,321,"This is insane, hold on."],[346,367,"Justin!"],[396,433,"Bitch!"],[433,646,"Your fans are mobbing Sofia."],[646,804,"You need to get down here! Now!"],[834,884,"I'm on my way."],[1472,1530,"Enough!"]],"44":[[392,429,"Enough!"],[654,884,"Sofia is the love of my life."],[950,1080,"And for the past five years without her,"],[1080,1332,"I have thought of nothing but her."],[1401,1543,"So if you truly support me,"],[1543,1705,"just stop attacking her."],[1705,1797,"But she's married."],[1797,1963,"She's been playing both sides."],[2081,2160,"No, that is not true."],[2293,2389,"Sofia and I..."],[2481,2591,"We're not married."],[2623,2752,"It was all just a"],[2752,3060,"misunderstanding spread by your vicious rumors."],[3060,3132,"No, please."],[3132,3282,"You actually think we're gonna believe that?"],[3282,3415,"You're just covering for her."],[3415,3482,"It's the truth."],[3528,3620,"And whether you believe it or not,"],[3620,3683,"I have already"],[3683,3858,"called the cops about the disturbance"],[3858,3994,"you were making in this office."],[4095,4262,"Do you think you can handle the consequences?"],[5196,5247,"Justin."],[5388,5482,"Take care of her."],[6377,6521,"I wasn't gonna let them hurt you."],[6598,6652,"Not now."],[6715,6798,"Not ever."],[7323,7400,"Oh."],[7553,7642,"It's you again."]],"45":[[55,195,"Five years!"],[195,404,"Five years, and you are still"],[404,555,"haunting us like a ghost?"],[570,663,"You leave!"],[663,855,"You leave and you get out of our lives"],[855,942,"forever!"],[1013,1269,"No, not this time."],[1380,1502,"I will stand with Justin."],[1502,1609,"I won't let him face it alone."],[1926,2077,"Mom, stop it!"],[2210,2407,"Sofia had nothing to do with Selena's death."],[2407,2512,"And you know it!"],[2585,2705,"Selena's choices were her own."],[2705,2824,"You know what? And if someone had"],[2824,3069,"guided her better and stopped her from"],[3069,3189,"hanging out with the wrong crowd"],[3189,3312,"and making the wrong decisions,"],[3312,3666,"and bringing Terry down with her, then maybe,"],[3699,3890,"maybe none of this would have happened."],[3924,4054,"Saying this right now?"],[4054,4204,"Saying this right now"],[4204,4469,"will not bring Selena back and you know it!"],[4575,4785,"I lost my daughter!"],[4829,5099,"Doris, you weren't the only one"],[5126,5276,"who lost a child that day."],[5710,5944,"Let me see him! Please!"],[6784,6865,"Mom?"],[6865,6950,"Hey!"]],"46":[[179,291,"The doctor said your mom should"],[291,508,"wake up soon, so..."],[509,646,"I will go now."],[721,767,"Wait."],[1034,1172,"What do you mean by lost a child?"],[1359,1505,"Let's not talk about that now."],[1572,1707,"Your mom would be so upset"],[1707,1860,"if she woke up and saw me, so..."],[1976,2202,"But you should stay with her."],[3390,3640,"Is that the baseball star, Justin Miller?"],[3657,3807,"He's all over the news for the"],[3807,3945,"scandal with a journalist."],[3945,4125,"That journalist? She just left, right?"],[4227,4315,"I remember her."],[4315,4428,"She was here five years ago."],[4428,4630,"She had a miscarriage."],[4675,4821,"The poor thing was so shattered,"],[4821,4938,"she almost took her own life."],[5000,5180,"The director had to step in and stop it."],[5422,5535,"I'm sorry. What did you just say?"]],"47":[[108,212,"I'm sorry. What did you just say?"],[479,600,"Are you certain about that?"],[804,995,"Yes, I remember it vividly."],[1092,1284,"She was pushed by an older woman,"],[1359,1484,"hit the counter pretty hard."],[1484,1654,"That's what caused her to miscarry."],[1860,1964,"And you're absolutely sure"],[1964,2035,"about what you just said?"],[3015,3082,"Hey, Mark."],[3144,3253,"Yeah, can you get me"],[3253,3408,"Sofia's medical records, please?"],[3520,3628,"Yeah, no, immediately."],[5638,5873,"There you are. Sofia's medical record."],[6064,6193,"The report confirms it."],[6239,6343,"Sofia's miscarriage was"],[6343,6629,"caused by the shove and overwhelming grief."],[7620,7732,"Oh, Justin."],[7732,7803,"Mom, hey."],[7932,7991,"You're awake."],[8304,8375,"Justin."],[8521,8641,"I remember now."],[8783,8960,"Five years ago, I..."],[8960,9109,"I did push Sofia."],[9159,9246,"But Justin..."],[9309,9548,"Justin, I didn't know she was pregnant."],[9634,9820,"I think I made a mistake."],[10064,10126,"Oh, God."],[10197,10443,"If I hadn't indulged Selena so much,"],[10443,10617,"if I had kept her from losing herself,"],[10702,10847,"could everything have been different?"],[10915,11169,"Mom, you can still make everything right"],[11169,11435,"if you just forget about the past."],[11661,11780,"I already lost a child."],[11953,12099,"I'm not going to lose Sofia this time."],[12124,12175,"Yeah."],[12328,12698,"Then, Justin, you got to go to her."],[12750,12905,"You got to go find Sofia."],[13008,13058,"Please."],[13217,13480,"Don't let- Look at me."],[13526,13799,"Don't let what's left of us slip away, okay?"],[13897,13983,"Find her."]],"48":[[654,696,"Justin?"],[779,827,"I'm sorry."],[938,1061,"I'm so sorry."],[1076,1228,"Well, hey."],[1288,1525,"What... why are you apologizing?"],[1564,1734,"Because I failed you."],[1772,1972,"I failed to protect you and our child."],[1972,2072,"That's why you left me, isn't it?"],[2143,2383,"No, no, I left you because you said"],[2383,2548,"you never wanted to see me again."],[2702,2800,"I was in a coma."],[2865,3066,"When I woke up, my mom said you left me and..."],[3110,3230,"it was a misunderstanding."],[3253,3481,"She was the reason we're bot together."],[3549,3794,"I know, I would never want to leave you."],[3816,4025,"You were the love of my life."],[4166,4308,"This time we'll never be apart again."],[4441,4525,"I'm back."],[4625,4724,"We're back."],[4761,4842,"Yeah."],[4875,4920,"Yeah."],[6031,6126,"Hi, partner."],[6346,6472,"-Hi. -Hi."],[7018,7109,"Oh."],[7407,7528,"I don't think I need that."],[9823,9922,"-Hi. -Hi."],[10122,10245,"Come home early today, okay?"],[10335,10378,"Okay."]],"49":[[50,221,"Today's our anniversary."],[304,512,"I hope Justin will like my surprise."],[662,848,"It's your fault I lost everything."],[848,946,"I'm gonna kill you."],[946,1117,"Once I do, Justin will be mine."],[1138,1225,"Esther, you're-"],[1501,1693,"Told you I'd protect you the rest of my life."],[2164,2353,"Yeah, hello? Police?"],[2353,2571,"Yeah, I'd blike to report an attempted murder."],[2585,2649,"What?"],[2698,2887,"You're going to jail, Esther."],[2923,3009,"You're never gonna be able to hurt"],[3009,3199,"the one I love ever again."],[3286,3348,"Pathetic."]],"50":[[442,512,"Mr. Miller."],[528,583,"Hi."],[583,735,"How does the big win feel?"],[871,1013,"-Sofia Macaulay. -Mm-hmm."],[1130,1272,"No matter where I stand in this life,"],[1372,1505,"I want you by my side."],[1664,1800,"You are my luck."],[2652,2781,"Will you marry me?"],[3061,3288,"This is being broadcast to millions."],[3299,3404,"Just say yes."],[3440,3703,"It's so romantic. Yes, yes, I will!"],[3732,3912,"Of course. Come here."],[5317,5442,"Nice catch."]]}