{"1":[[1071,1217,"I should never have let you go"],[1217,1493,"undercover on that damn business deal."],[1526,1697,"I never even got to say goodbye!"],[1739,1935,"Marco, my brother..."],[1935,2118,"I will protect your legacy."],[2118,2218,"And I will protect our family."],[2218,2281,"And I will protect our family."],[2957,3057,"Hey, hey!"],[3057,3169,"Who are you!?"],[3240,3353,"Which family do you work for?"],[3353,3507,"I just came to drop off the flowers."],[3507,3691,"I didn't mean to intrude."],[3691,3753,"Luca."],[3753,3824,"Look at her."],[3958,4079,"She's hardly a threat."],[4654,4754,"For the flowers."],[4867,5063,"And for the interruption."],[5121,5221,"My apologies."],[6206,6310,"Signora Mancini!"],[6364,6485,"Master Marco had a widow"],[6485,6581,"named Ava Johnson,"],[6614,6744,"and she was carrying his child."],[6956,7027,"Get the car!"],[7144,7344,"I'm bringing my daughter-in-law home..."],[7390,7507,"where she belongs!"],[8216,8324,"Don't worry, little one."],[8454,8596,"We'll get through this together..."],[8717,8804,"somehow."],[9084,9209,"Well, look at here!"],[9342,9580,"The family Jinx is finally six feet under!"]],"2":[[120,179,"Derek!"],[204,321,"Have you lost your mind?!"],[321,408,"What the hell was that?"],[558,684,"Don't tell me that you're actually"],[684,896,"plan on keeping that little parasite?"],[925,1217,"This is Marco's baby!"],[1217,1334,"This is our child!"],[1388,1530,"Of course I'm keeping it."],[1576,1747,"Ever since you got knocked up,"],[1747,1989,"you've done nothing to help this family."],[2056,2177,"We've been struggling"],[2177,2252,"while you've been out here"],[2252,2406,"playing the grieving widow!"],[2435,2702,"Give me one good reason."],[2702,2898,"Why I should get rid of this baby?"],[3036,3219,"Because you owe me."],[3303,3520,"This is your fault."],[3628,3845,"I dropped out of college for this family."],[3845,3978,"I took five jobs!"],[3978,4095,"What more could you possibly want?!"],[4095,4250,"It'll never be enough, Ava."],[4279,4458,"You'll owe us till the day you die."],[4546,4871,"Oh, please, sweetheart."],[4938,5084,"Think of your brother."],[5392,5492,"I'm going to stomp out"],[5492,5647,"that little bastard right now."],[5684,5834,"Send him straight to hell..."],[5864,6164,"so he can say hello to his deadbeat dad."],[6389,6427,"Hey!"]],"3":[[1301,1343,"What?"],[1343,1480,"What the hell's going on here?"],[1480,1605,"Who the hell are you people?"],[1718,1810,"Ava, right?"],[1931,2052,"You were here this morning."],[2135,2227,"Enough, Luca."],[2302,2414,"She's hardly a threat."],[2731,2773,"Ma'am?"],[2840,2990,"I'm Helena Mancini."],[3036,3132,"Marco's mother."],[3490,3770,"That means I'm your baby's grandmother."],[3891,4045,"The most powerful mafia family"],[4045,4137,"in the country?"],[4346,4471,"Marco was my oldest."],[4521,4688,"He was my golden boy."],[4763,4909,"I am so sorry..."],[4934,5138,"that he concealed his identity from you."],[5192,5492,"You have endured far too much suffering"],[5492,5580,"because of it."],[5910,6114,"Playing make-believe Mancini?"],[6164,6214,"Seriously,"],[6214,6310,"like, is anybody here actually"],[6310,6406,"buying this?"],[6439,6610,"Question my identity again,"],[6648,6727,"and my men"],[6760,6902,"will make sure your other leg..."],[6902,7015,"looks like your first one."],[7190,7269,"Permanently."],[7390,7465,"What are you doing?!"],[7465,7574,"Derek, run!"],[7678,7799,"Maybe we should just go."],[7974,8103,"One moment, dear."],[8145,8224,"Anyone..."],[8224,8458,"who raises a hand to my daughter-in-law"],[8470,8754,"deserves to have their fingers snapped."],[8858,9192,"One by one."],[9371,9480,"Come along, my dear."],[9584,9713,"Let's get you home."],[9776,9916,"To your real home."],[10220,10335,"One moment."],[12128,12224,"Welcome home."],[12224,12412,"Signora Ava Mancini!"],[12441,12612,"This is where Marco lived?"],[12812,13088,"And now it's your home too."]],"4":[[312,513,"Allow me to introduce you to your..."],[513,592,"personal staff,"],[592,704,"Mrs. Mancini."],[704,917,"Your nutritionist, nanny, maternity nurse."],[917,1042,"Each of the finest specialists"],[1042,1130,"money can acquire."],[1155,1297,"We pledge your absolute dedication"],[1297,1409,"to your health and well-being,"],[1409,1468,"Signora."],[1818,2052,"Your days of working multiple jobs..."],[2072,2173,"are over, my dear."],[2223,2410,"10 million dollars for a little spending money."],[2540,2624,"Well..."],[2673,2894,"Thank you, but I can't accept this."],[3007,3399,"I married Marco for love, not for his fortune."],[3474,3670,"Practical and principled."],[3691,3962,"My Marco truly had an eye for quality."],[3995,4262,"There is one more member of the family..."],[4262,4487,"that you need to properly meet."],[4517,4792,"That would be Luca, Marco's younger brother."],[4829,4925,"The brooding iceberg..."],[4925,5017,"that you encountered this morning."],[5109,5226,"Well, well, well."],[5376,5605,"It's the flower girl from the cemetery."],[5676,5747,"Luca."],[5789,6001,"Come meet Ava, your brother's wife."],[6031,6218,"Please, show her proper..."]],"5":[[116,196,"Respect!"],[342,617,"You walk back into a Mancini household?"],[688,875,"You're either incredibly stupid..."],[909,1034,"or incredibly brave."],[1180,1242,"Luca!"],[1276,1455,"Open this door immediately!"],[1714,1943,"Everyone, around back! Now!"],[2181,2285,"Who are you really?"],[2464,2756,"I'll be watching your every move,"],[2798,2927,"your every breath."],[2952,3032,"So tell me,"],[3219,3303,"who are you..."],[3303,3386,"really?"],[3436,3553,"My brother's dead,"],[3553,3687,"and you appear suddenly?"],[3745,3928,"Was this your endgame all along?"],[3958,4049,"Our fortune?"],[4095,4308,"I didn't know Marco was a Macini."],[4308,4379,"And now?!"],[4379,4508,"I don't need this."],[4508,4633,"I can walk right out through those doors!"],[4633,4746,"You can't walk anywhere!"],[4746,4921,"She's not going anywhere."],[5288,5488,"And get your hands off of her."],[5559,5768,"She is carrying Marco's child."],[5801,5880,"Oh. Is she?"],[5964,6135,"How do we even know it is Marco's child?"],[6135,6222,"Convenient timing."],[6222,6310,"Wouldn't you say?"]],"6":[[162,279,"Question me all you want,"],[279,479,"but don't you dare question my child."],[596,709,"That's my girl."],[725,888,"Backbone of steel."],[992,1080,"Are you hurt?"],[1226,1426,"Luca! You are too rude."],[1426,1589,"Ava is a good girl."],[1601,1789,"You are falsely accusing her."],[1814,1926,"Come on, sweetie."],[1926,2102,"Mom's gonna take you to get some clothes."],[2122,2281,"Pay no attention to this fool."],[2690,2823,"You may be fooling them."],[2898,3032,"But I will find out about you,"],[3032,3186,"and I will expose you."],[4675,4959,"These are all the latest European styles."],[4996,5075,"Take your pick."],[5134,5284,"I have plenty to wear."],[5284,5480,"These are much too expensive."],[5480,5605,"Oh, not to worry."],[5672,5776,"It's all on Luca's card."],[5910,6064,"Treat my dear daughter-in-law well!"]],"7":[[1643,1714,"Oh..."],[1751,1960,"Isn't she gorgeous?"],[2248,2318,"She's..."],[2419,2506,"adequate."],[2748,2923,"Always the tough guy act with you."],[2977,3140,"Your eyes tell a different story,"],[3140,3224,"my son."],[3340,3407,"Oh, yes."],[3407,3586,"This is just perfect."],[3666,3858,"We will take one of everything"],[3858,3949,"in her size."],[4104,4204,"Mom."],[4325,4391,"Mom..."],[4487,4629,"that's too generous."],[4662,4758,"Nonsense."],[4775,4888,"We're family now."],[5050,5280,"I am putting Luca's contact info..."],[5280,5401,"into your phone."],[5434,5693,"Reach out to him for whatever you need."],[5730,5864,"And don't worry."],[5905,6122,"He's actually quite a softie."],[6227,6464,"Now, shall we continue shopping?"],[6464,6523,"Yes."],[6890,6944,"Sir?"],[6944,7036,"Yes."],[7036,7248,"Your mother has spent approximately"],[7248,7424,"fifteen million dollars"],[7424,7636,"on Ms. Jackson in the last week alone."],[7661,7728,"God."],[7770,7849,"In mere days,"],[7849,8012,"she has swindled our family out of"],[8012,8124,"millions of dollars."],[8266,8404,"She's clearly not an amateur."],[8416,8554,"She's also been spending"],[8554,8689,"a substantial amount"],[8689,8818,"since marrying your brother"],[8818,8983,"to pay off her brother's debts."],[9025,9234,"I want everything on her."],[9300,9376,"Everything!"],[9421,9601,"If she is playing us for fools,"],[9672,9805,"then I will personally ensure"],[9805,9893,"that she regrets"],[9893,10118,"ever hearing the name Mancini."],[10890,10990,"I'm sorry, ma'am."],[11069,11344,"I hate to put extra stress on your shoulders,"],[11344,11624,"but we need to discuss the incredible cost"],[11624,11790,"of your husband's care,"],[11832,12012,"and how the bill will be paid."],[12045,12354,"Limited edition is perfect for you."],[12746,12821,"Marco,"],[12887,13092,"you just focus on getting better, okay?"],[13146,13296,"Don't worry about the bills."],[13338,13430,"I've got it covered."],[14230,14389,"Your brother married Ms. Jackson..."],[14389,14518,"under false pretenses."],[14560,14768,"She worked several jobs to make that money."],[14793,14956,"And when your brother got sick,"],[14956,15160,"she worked to pay off his medical bills."],[15202,15377,"And then day and night for his funeral."],[15511,15665,"Did I get her all wrong?"],[16875,16929,"Hello?"],[16929,17046,"Mother is unwell."],[17046,17204,"You need to return home immediately."]],"8":[[125,225,"What's wrong with Mom? Is..."],[379,487,"Is she hurt?"],[759,813,"Mom?"],[959,1059,"What's going on?"],[1559,1630,"Ava,"],[1705,1839,"please don't be angry."],[1914,2068,"We just had to get you here."],[2565,2644,"What are you doing?"],[2673,2848,"Since you won't help us financially,"],[2894,3040,"we had to find another solution."],[3061,3169,"Victor Fang,"],[3215,3353,"that old loan shark's willing to give us"],[3353,3482,"eighty thousand dollars,"],[3482,3616,"just to marry you."],[4112,4270,"Are you insane?!"],[4387,4487,"I'm pregnant!"],[4504,4650,"Your husband is dead, Ava."],[4696,4817,"Why keep his baby?"],[4817,4917,"Think about your family."],[4917,5025,"Mr. Fang is waiting."],[5155,5326,"Don't make this harder than it needs to be."],[5501,5743,"You are not selling me off to Victor Fang!"],[6010,6093,"If she dies,"],[6093,6256,"how will you provide for this child?"],[6606,6715,"She's calling someone."],[7507,7570,"Hello?"],[7570,7661,"Help!"]],"9":[[304,371,"Ava is in danger."],[371,429,"We need to move!"],[429,513,"Go, go, go!"],[2402,2610,"You think someone's going to save you?"],[3119,3440,"Who dares manhandle my future bride?"],[3440,3524,"Mr. Fang!"],[3557,3678,"Oh, it's such a pleasure."],[3703,4000,"This is Ava, my sister, whom we discussed."],[4008,4300,"Oh, two for the price of one, I see."],[4300,4504,"Oh, it's just some dead guy's kid."],[4504,4600,"If you want,"],[4600,4754,"I can take care of it right now."],[4754,4929,"We can offer you a discount, I think."],[4929,5080,"$60,000 would be more than fair!"],[5080,5171,"Pennies..."],[5171,5292,"for a man of your wealth!"],[5292,5438,"Derek! You're sick!"],[5438,5530,"I'm your sister!"],[5530,5626,"This is your nephew!"],[5626,5922,"My son's future is more important to me..."],[5922,6143,"than that stupid little bastard of yours!"],[6143,6252,"Hey, hey!"],[6252,6627,"No need to be so rough with such a beautiful lady."],[6702,6802,"Now, dear..."],[6852,7023,"just take this right here."],[7023,7286,"And it'll make things easier for everybody."],[7457,7536,"Okay."],[7565,7741,"You're a little feisty. I see."],[7995,8237,"Maybe you just need a little personal attention."]],"10":[[1722,1805,"Get out of my way!"],[1805,1935,"I always knew Ava was trouble."],[1964,2072,"Her husband's barely cold,"],[2072,2193,"and she already got another."],[2414,2560,"Who the hell do you think you are?!"],[2869,3011,"I'm Luca Mancini."],[3011,3203,"Mancini? You idiot."],[3278,3386,"You've killed me!"],[3395,3513,"How did my sister get caught up"],[3513,3617,"with the likes of you?"],[3641,3849,"Ava is my brother's widow."],[3849,4120,"And her baby is his only child."],[4212,4316,"So it's true?"],[4354,4559,"Her baby is the heir to the Mancini family?!"],[4671,4846,"Looks like your wife is pregnant, too."],[4904,5063,"Yes, yes, yes. It's true."],[5086,5236,"I swear, we didn't know."],[5236,5327,"Please, please!"],[5363,5484,"You will be dealt with"],[5584,5697,"tenfold"],[5728,5855,"for what you did to Ava."],[6122,6172,"Get a doctor!"],[6206,6260,"Get a doctor."],[6260,6431,"Get a car and deal with him."]],"11":[[829,930,"Mom, hey."],[1101,1184,"How's Ava?"],[1201,1288,"How's the baby?"],[1326,1476,"The doctors are examining her now."],[1964,2068,"Doctor, how is she?"],[2081,2327,"Mrs. Mancini has a severe ankle fracture."],[2327,2531,"It needs immediate surgery."],[2565,2836,"The medication could cause a miscarriage."],[2873,3069,"So, we need to have consent"],[3069,3207,"before we can proceed."],[3207,3244,"Do it!"],[3269,3361,"Whatever it takes."],[3361,3428,"No!"],[3737,3795,"Doctor,"],[3824,3908,"is there any way"],[3908,4095,"to do the surgery without anesthesia?"],[4120,4279,"That's not medically advisable."],[4300,4496,"The pain would be too excruciating."],[4767,5063,"But this baby is Marco's only child."],[5063,5171,"His only heir."],[5192,5338,"I can't risk losing him."],[5455,5593,"I can handle the pain."],[5630,5789,"Oh, my brave girl."],[5930,6026,"God bless you."],[6100,6138,"You know,"],[6138,6302,"I think somebody should be with her"],[6302,6418,"during the operation."],[6481,6723,"The pain would be just too intense."],[6769,6873,"I'll stay with her."],[9225,9305,"How did it go, doctor?"],[9338,9455,"It's a success."],[9613,9693,"You're a real trooper"],[9693,9830,"if you don't mind me saying."],[9959,10118,"I guess my brother had good reason..."],[10118,10222,"to fall for her."]],"12":[[1718,1843,"Signora Ava, please."],[1843,1951,"Let me help you."],[2360,2419,"Okay."],[2419,2531,"Right this way, alright."],[2990,3169,"I know your stay at the hospital"],[3169,3353,"could not have been easy for you."],[3395,3482,"That's why"],[3541,3845,"I'm having 30% of Mancini Group shares"],[3845,3937,"put into your name."],[3987,4154,"No, Mom, I..."],[4154,4304,"cannot accept that."],[4437,4562,"We're family."],[4629,4758,"It's what you deserve."],[4775,4875,"Actually,"],[5000,5109,"I've been thinking about"],[5109,5246,"doing something else."],[5260,5313,"Oh?"],[5313,5476,"I'd like to go back to work."],[5563,5643,"Work?!"],[5689,5876,"But you're pregnant."],[5889,5990,"Oh, honey, if you need money,"],[5990,6122,"I'll just transfer some into your account."],[6122,6302,"No, no, it's not about money."],[6385,6623,"Marco always said that..."],[6685,6869,"we should make our own way."],[6952,7298,"And I want our child to know his father"],[7369,7536,"and know what he valued."],[7707,7907,"You are as stubborn as he was."],[8128,8295,"Well, you're going to need protection."],[8458,8558,"You'll accompany her."],[8850,8942,"No, no, no, no, no."],[8942,9113,"That I can manage on my own."],[9434,9542,"In the morning,"],[9542,9617,"10:00 A.M."],[9651,9763,"I'll be at the entrance."]],"13":[[241,467,"You know that I can talk to your manager for you."],[479,579,"Make sure that they accommodate"],[579,675,"every need."],[675,750,"No need."],[750,955,"I don't want any special treatment."],[1021,1180,"But thank you for the ride."],[1397,1501,"You know,"],[1509,1755,"Ava, you do not need to be afraid of me."],[1772,1843,"I can help you..."],[1926,2031,"whenever you need."],[3874,4024,"Why is she even back?"],[4054,4266,"That pregnant belly ruins the store's aesthetic."],[4266,4433,"These pregnant women know exactly"],[4433,4537,"what they're doing."],[4554,4825,"Hiding behind maternity protections."],[4863,5030,"We can't legally fire her."],[5046,5238,"Could you reassign her to the warehouse?"],[5246,5384,"Maybe move some stock around."],[5413,5593,"And if something happens to her and the baby,"],[5593,5739,"you want that liability?"],[5901,6076,"We can't fire her, but..."],[6076,6306,"we certainly can make her life difficult enough"],[6306,6577,"that she decides to quit on her own."],[8491,8621,"And that concludes our"],[8621,8804,"quarterly revenue projections."],[9054,9330,"Sir, forgive my directness,"],[9330,9384,"but..."],[9442,9501,"are we here"],[9501,9630,"because you're concerned about"],[9630,9730,"your sister-in-law?"],[10276,10414,"Should I have the car brought around"],[10414,10518,"for your next meeting?"],[10648,10739,"Cancel the meeting."]],"14":[[225,392,"I've been meaning to talk to you."],[425,663,"Given your condition,"],[688,992,"I've been worried about potential liability issues."],[992,1247,"My pregnancy will not affect my performance."],[1280,1372,"I do not"],[1372,1595,"intend to take advantage of company policy."],[1595,1692,"Oh."],[1702,1885,"I'm glad to hear that."],[1956,2164,"Then you won't mind proving your commitment."],[2164,2452,"Sell one million dollars' worth of merchandise"],[2452,2556,"by today,"],[2556,2811,"and I'll put all of my concerns to rest."],[2844,2998,"I've seen your sales record."],[3040,3153,"I know you can do it."],[7102,7173,"Sir,"],[7228,7382,"half an hour until closing,"],[7382,7499,"and Mrs. Mancini"],[7499,7682,"has already surpassed the store's"],[7682,7887,"average monthly sales in a single day."],[8008,8158,"But she's still a great deal"],[8158,8370,"short of the manager's impossible target."],[8733,8833,"She did make it clear"],[8833,9034,"that she doesn't want any special treatment."],[9071,9213,"But I have been neglecting"],[9213,9342,"my own wardrobe."],[9376,9567,"The Rossi family event will require"],[9567,9672,"several new suits."],[9709,9838,"Now that you mention it, sir,"],[9838,10005,"your formal collection is missing"],[10005,10172,"quite a few essential items."],[10235,10435,"And I should do some personal shopping."],[10435,10489,"Shouldn't I?"]],"15":[[291,412,"Sir, may I assist you?"],[492,583,"Sir!"],[583,813,"This limited edition silk tie would go perfect"],[813,900,"with your complexion."],[917,1180,"Sir, I'd be happy to take your measurements..."],[1180,1247,"personally."],[1255,1330,"Sir!"],[1330,1605,"As store manager, I would be honored"],[1605,1747,"to assist you with your needs"],[1747,1872,"myself."],[1956,2202,"I'd actually like Ms. Jackson to assist me."],[2202,2485,"I hear her taste in men's fashion is exceptional."],[2944,3069,"Shall we begin?"],[3069,3190,"This way, sir."],[3778,3966,"I just need to take your measurements."],[4112,4170,"Whoa..."],[4170,4287,"what are you doing?"],[4352,4458,"You measure me like this."],[4600,4821,"I just needed you to take the jacket off."],[4859,4921,"Well..."],[4984,5146,"we don't have much time."],[6268,6373,"Now..."],[6514,6639,"Measure me like this."]],"16":[[91,166,"Ava!"],[166,346,"Time is almost up."],[645,698,"Mm-hmm."],[2106,2189,"I did it!"],[2210,2331,"I saved my job,"],[2331,2540,"and I made a new sales record."],[2669,2748,"Thank you."],[2777,2894,"It's no reason to thank me."],[2957,3169,"I'm here to help whenever you need it."],[3340,3570,"I hate to do this, but..."],[3603,3716,"Ava Jackson,"],[3812,3933,"you're fired."],[4066,4133,"What?"],[4250,4329,"No."],[4396,4558,"I met your target, and then some—"],[4558,4633,"Oh!"],[4696,4792,"That last sale?"],[4792,4954,"The one that put you over the top?"],[4975,5109,"That was actually mine."],[5188,5330,"You're trying to steal my commission?"],[5351,5430,"Well, that won't work,"],[5430,5613,"because everyone in the store"],[5613,5747,"saw me make that sale."],[6281,6364,"I get it."],[6418,6573,"You threaten them into silence,"],[6573,6710,"but that won't work either."],[6731,6877,"Because the security cameras"],[6877,7011,"caught everything."],[7102,7311,"Security cameras."],[8020,8199,"What a horrible timing."],[8229,8420,"Unfortunately, the security cameras are down"],[8420,8562,"for maintenance today."],[8637,9009,"But fortunately, everyone here saw you destroyed"],[9009,9217,"thousands of dollars worth of merchandise."],[9255,9463,"You all saw Ava, didn't you?"],[9513,9638,"Yeah, we... we all saw it."],[9793,9951,"So, someone should call security."],[9951,10126,"Better yet, call the police."]],"17":[[0,95,"I'm sorry, sir,"],[95,229,"but we're closed for the day."],[229,371,"I heard this store gets trashed."],[392,521,"I'm going to ask you to leave,"],[521,671,"or I'll have to call the police."],[709,850,"The police work for me."],[938,1059,"Are you..."],[1059,1176,"Luca Mancini?"],[1735,1822,"Put this on."],[6523,6619,"Please stop!"],[6644,6824,"I admit it, I was wrong."],[6831,7027,"Who really damaged the merchandise at the store?"],[7052,7186,"The items you've destroyed"],[7186,7365,"are worth over several million of dollars!"],[7365,7494,"That's five years in prison!"],[7970,8070,"Luca, what happened?"],[8070,8170,"There was nothing worth talking about."],[8170,8254,"We need to go."],[8254,8370,"By the way, you're fired."],[8500,8704,"Let's go. Come on. It's dinner."]],"18":[[279,508,"I will kill this bitch!"],[521,838,"How dare that woman mess with my family?!"],[859,1005,"I will make sure..."],[1005,1244,"personally that she suffers for it."],[1255,1493,"You don't have to worry about that anymore."],[1493,1743,"It's all taken care of, thanks to Luca."],[1743,1914,"The store looks like a tornado hit it."],[1947,2189,"Mandy will be serving time in a jail cell."],[2227,2385,"Justice is served."],[2419,2544,"That's my boy."],[2840,2911,"Sweetheart,"],[2944,3161,"I would like you to concentrate full-time"],[3161,3332,"on your pregnancy right now."],[3357,3657,"All of this work drama can wait until after..."],[3657,3845,"my grandchild is born safely."],[3887,3999,"Yes, Mom."],[4024,4195,"I transferred 5 million dollars"],[4195,4312,"into your personal account"],[4312,4525,"for prenatal care."],[4579,4871,"I worried about the baby's well-being."],[4921,4984,"Luca."],[5038,5238,"I'd like you to take her to the doctor tomorrow"],[5238,5326,"for an exam."],[5392,5538,"No, that's..."],[5555,5693,"that's really not necessary."],[5968,6197,"I have those meetings in Europe,"],[6197,6314,"so possibly I could have someone..."],[6314,6514,"Yeah! And I'm perfectly capable..."],[6514,6677,"of going by myself."],[6690,6763,"Mm."],[6773,6835,"I..."],[6906,7090,"I don't want to trouble Luca"],[7090,7211,"with something so routine."],[7378,7507,"It's decided."],[7536,7732,"Cancel whatever meetings you have."],[7749,7920,"I want you to take her."],[7953,8258,"I will not stand for any more incidents."],[8274,8366,"Yes, Mother."]],"19":[[863,955,"Ava Jackson?"],[967,1076,"We're ready for you now."],[1155,1259,"Dad should come too."],[1259,1447,"We encourage partner participation."],[1584,1797,"Oh, no, he's not."],[2102,2239,"Would you prefer that I explaine..."],[2239,2419,"that I'm your dead husband's brother?"],[2473,2602,"That might be a bit awkward."],[2602,2723,"Mr. and Mrs. Jackson,"],[2723,2836,"please come in when you're ready."],[2836,2948,"Coming!"],[3628,3883,"If you could lift your top up slightly"],[3883,4058,"and lower your skirt band just a bit,"],[4058,4179,"we'll get started."],[4938,5180,"First prenatal check-up together, I'm guessing?"],[5718,5980,"The baby looks perfectly healthy."],[6035,6331,"Current length is about three inches..."],[6331,6466,"with a strong heart rate."],[6514,6635,"Is the baby moving?"],[6656,6873,"Yes, indeed."],[6898,6984,"Look there."],[7040,7294,"The little one's making faces."],[7361,7706,"Quite the expressive child already."],[8053,8120,"Dad,"],[8191,8329,"don't you wanna come take a look?"]],"20":[[362,471,"The baby's at"],[471,821,"18 weeks now, developing beautifully."],[875,1222,"For home care, I recommend plenty of rest,"],[1259,1438,"nutrient-rich foods,"],[1438,1761,"and tactile bonding when possible."],[1826,1931,"Tactile bonding?"],[1943,2006,"Yes,"],[2060,2329,"it's quite beneficial for fetal development."],[2356,2439,"Come over here and"],[2439,2565,"place your hands on her belly."],[2715,2936,"Doctors, is that really appropriate?"],[3011,3169,"What's inappropriate about it?"],[3194,3357,"This is what husbands do."],[3703,3766,"Okay."],[5075,5234,"I'm sorry. Did I hurt you?"],[5234,5338,"No, no, no..."],[5338,5547,"I just feel strange."],[5650,5780,"Yeah... Like this."],[5830,6081,"Top to bottom, left to right,"],[6140,6293,"gentle strokes."],[6602,6669,"Got it?"],[6785,6869,"Got it."],[6936,7261,"Do this once daily, five to ten minutes each."],[7478,7570,"You can sit up now."]],"21":[[158,337,"So, everything good with the baby?"],[375,625,"Any special instructions I should know about?"],[746,880,"—Nothing. —Nothing. No."],[917,1030,"The doctor did say that"],[1030,1209,"the baby is developing beautifully,"],[1209,1451,"and there's nothing to worry about."],[1568,1672,"Good news then."],[1851,1972,"Before I forget,"],[2035,2185,"the Rossi family's daughter"],[2185,2369,"is having her birthday celebration"],[2369,2481,"next weekend."],[2510,2715,"And we should all attend."],[2756,2877,"The Rossi family?"],[2898,3153,"Technically, they're our business rivals,"],[3153,3190,"but..."],[3311,3578,"social niceties must be maintained."],[3670,3903,"And she has had an embarrassing"],[3903,3999,"crush on Luca"],[3999,4124,"since they were little children."],[4179,4262,"Mom, please."],[4316,4689,"Miss Sofia Rossi has arrived unannounced."],[4717,4938,"She shows up without calling?"],[4996,5105,"How gauche."],[5138,5276,"Should we send Ava upstairs?"],[5284,5438,"No, no, no. It's fine. I'm here."],[5438,5526,"We can just..."],[5880,6068,"Good evening, Mrs. Mancini."],[6068,6143,"Luca!"],[6143,6377,"I came personally to deliver my birthday invitation."],[6377,6452,"Okay."],[6806,6844,"Luca!"],[6844,6940,"Who is this woman?!"]],"22":[[29,166,"Luca! Who is this woman?!"],[166,225,"Hey, hey."],[225,471,"The Rossi family's lack of manners..."],[471,613,"never disappoints me."],[650,742,"Luca Mancini!"],[742,938,"How dare you speak to me like that?"],[938,1063,"Miss Rossi, right?"],[1113,1405,"I've heard so much about your family."],[1512,1597,"I'm Ava."],[1639,1743,"Marco's wife."],[1743,1935,"Marco was Luca's brother."],[2243,2352,"Oh, okay."],[2423,2631,"I thought you were carrying Luca's baby."],[2677,2848,"That's good, because Luca is mine."],[2936,3103,"I came all this way to bring you that."],[3103,3244,"And this is how you welcome me?"],[3324,3503,"Don't disappoint me at the party, darling."],[3520,3624,"Wear something sharp."],[3841,3928,"Yes."],[4884,4992,"See if there's any connection"],[4992,5155,"between that pregnant woman and Luca."],[5167,5355,"I'm not buying this whole sister-in-law act"],[5355,5442,"for one second."],[5484,5563,"You got it."],[6012,6188,"Oh, you look so handsome."],[6188,6285,"Thanks, Mom."],[6548,6673,"Well, well, well,"],[6681,6831,"it looks like my stubborn son"],[6831,7019,"has good taste after all."],[7123,7365,"Luca did an excellent job selecting this gown."],[7374,7528,"It is perfect for you."],[7561,7686,"Luca picked this?"],[7882,7953,"Thank you."],[8045,8324,"I've never been anywhere this fancy before."],[8354,8546,"I might embarrass you guys."],[8562,8854,"Oh, don't even worry about it."],[8896,9117,"You are my pride and joy."],[9117,9409,"Besides, Luca will be with us the whole time,"],[9426,9663,"and he'll make sure everything runs smoothly."],[9943,10005,"Luca?"],[10072,10189,"What about her shoes?"],[10189,10368,"How could you forget something so basic?"]],"23":[[2765,2861,"Right there."],[3148,3236,"Thank you."],[3307,3386,"No problem."],[3465,3611,"Just don't want you to fall."],[5055,5196,"Who's that with Mr. Mancini?"],[5251,5401,"She's clearly pregnant."],[5459,5630,"Do you think that's Mr. Mancini's baby?"],[5651,5814,"I had no idea he was even married."],[5855,5980,"Must be his mistress."],[5980,6093,"How shameless."],[6093,6197,"Everyone,"],[6197,6481,"I would like to introduce Ava Mancini,"],[6573,6765,"my eldest son Marco's wife."],[6794,6923,"Marco's wife!"],[6923,7069,"She's stunning."],[7319,7511,"This is my birthday party!"],[7511,7678,"I'm supposed to be the center of attention,"],[7678,7836,"not some pregnant woman."],[8078,8340,"Mom, maybe we shouldn't cause a scene here."],[8341,8450,"It's fine."],[8483,8616,"She's always like this."],[8758,9025,"We didn't mean to steal your spotlight."],[9109,9300,"An apology simply isn't enough."],[9330,9534,"Since you're Luca's sister-in-law,"],[9534,9672,"why don't you entertain us all"],[9672,9859,"with a performance of some kind?"],[9968,10014,"Look,"],[10080,10222,"she used to deliver food for a living."],[10239,10527,"Waitress, retail clerk, cleaning lady..."],[10548,10677,"What could someone with her background"],[10677,10819,"possibly perform for this crowd?"],[11978,12212,"Ava, how does this piece go again?"],[12241,12387,"I'm completely lost here."],[12387,12537,"I've forgotten everything that you taught me."]],"24":[[20,233,"There's no way she could actually play."],[233,421,"She's just a nobody from nowhere."],[467,600,"He has to be setting her up!"],[600,834,"Even Ms. Mancini is smiling."],[863,1067,"Just waiting for her to crash and burn."],[2973,3144,"I was just playing for the baby."],[3269,3520,"I think he recognized the music"],[3520,3661,"you were playing for us earlier."],[3745,3845,"Or maybe you should..."],[3899,4112,"teach me sometime properly."],[4175,4325,"I'd like to play for you both."],[4621,4829,"Because Mom did tell me to look after you."],[4829,5075,"So, it's the least that I can do."],[5317,5380,"Okay."]],"25":[[592,771,"They're definitely more than in-laws."],[804,955,"Look at the way they play together."],[1051,1167,"If I can't have him,"],[1255,1380,"I'll destroy them both."],[1976,2064,"Yeah, I always enjoy"],[2064,2152,"this type of event."],[2177,2235,"Me too."],[2406,2502,"From Miss Rossi."],[2560,2690,"With her compliments."],[2690,2756,"Cheers."],[3157,3194,"Sir,"],[3249,3424,"that drink is almost certainly drugged."],[3465,3545,"Obviously."],[3545,3624,"Is the Rossi family"],[3624,3766,"making a move against us?"],[3807,3907,"These tensions have been"],[3907,4020,"simmering for years."],[4058,4204,"Should we respond preemptively?"],[4675,4754,"Do nothing."],[4792,4984,"You just need to focus on protecting Ava."],[5130,5284,"We'll see what they have planned."],[5768,5860,"Oh..."],[5910,6126,"Darling, you look tired."],[6160,6310,"I don't think all this excitement"],[6310,6423,"is good for your condition."],[6477,6585,"Why don't you try to find Luca?"],[6585,6673,"Let's get you home."],[6875,6958,"Okay."],[9196,9330,"Sophia's bedroom."],[9426,9563,"Why is Luca's phone in there?"],[9626,9748,"And why am I jealous?"]],"26":[[942,1126,"I've wanted Luca for years."],[1163,1259,"And then you waltz in"],[1259,1413,"and get his attention in weeks."],[1814,1927,"You won't look so innocent"],[1927,2072,"when everyone sees you in bed,"],[2072,2293,"next to your dead husband's brother."],[2335,2585,"Miss, is this exactly how you wanted it?"],[2585,2648,"Not at all."],[2677,2781,"This isn't convincing."],[2806,2911,"Unbutton their clothes."],[3653,3849,"Sal, position them closer together."],[3849,3974,"Make it look more intimate."],[4517,4583,"Perfect."],[4600,4668,"Let's go."],[4679,4825,"Our masterpiece is complete."],[4896,5067,"Now we just have to bring in the audience."],[6043,6231,"I expected much more than this..."],[6231,6435,"juvenile prank from a business rival."],[7599,7707,"Ava, wake up!"],[7862,7932,"Ava!"]],"27":[[25,66,"Ava!"],[934,1005,"Luca?"],[1247,1359,"Oh my God."],[1572,1689,"What happened to us?"],[2135,2285,"This is bad."],[3244,3386,"If anyone sees us like this,"],[3386,3524,"they'll immediately assume the worst."],[3958,4031,"Luca!"],[4031,4083,"Wake up!"],[4487,4546,"Okay."],[5109,5188,"Jesus!"],[5321,5388,"People are coming!"],[5413,5588,"You're acting like we had some torrid affair."],[5643,5734,"We didn't do anything wrong."],[5734,5822,"So, why are you worried?"],[5872,5989,"I'm your late brother's widow,"],[5989,6149,"and I'm carrying his child."],[6185,6330,"If anyone sees us like this, they'll..."],[6368,6570,"The Mancini family name will be destroyed."],[6610,6673,"Okay."],[6977,7220,"So, Mancini's name is what you're concerned about."],[7220,7265,"Is that it?"],[7374,7432,"Hey, hey, hey!"],[7490,7655,"You haven't answered me."]],"28":[[104,362,"Thank you all so much for coming today"],[362,529,"to celebrate me."],[563,796,"But I do have some rather important"],[796,962,"information to share with you all."],[1021,1317,"I have just discovered Luca Mancini"],[1317,1393,"in a rather..."],[1463,1668,"compromising position"],[1668,1939,"with his brother's pregnant widow..."],[2052,2210,"in my bedroom."],[2973,3073,"Can you let go?"],[3399,3482,"They're coming."],[3899,3987,"Yeah, I got this. Watch out!"],[4033,4229,"Wait! Stop! They're right there."],[4283,4379,"If we walk through that door,"],[4379,4529,"we'll walk right into their trap."],[4529,4696,"Okay. Then what's your brilliant idea?"],[4696,4758,"Yes, ma'am?"],[4758,4927,"Um... We could..."],[5025,5105,"Let's go through the window."],[5105,5180,"We can climb down."],[5246,5436,"No, no, no. I... I'm..."],[5436,5530,"I'm afraid of heights."],[5530,5622,"You're what?"],[5855,5914,"Sorry!"],[5914,6085,"I just didn't realize the great"],[6085,6339,"Luca Mancini had fears like the rest of us."],[6348,6389,"Yeah."],[6406,6560,"You know, that's one of my fears."],[6560,6715,"And I don't advertise it, so..."],[6785,6848,"deal with it."],[6915,7036,"What else do you..."],[7203,7261,"Ms. Rossi!"],[7261,7499,"Where are these cheaters you promised to expose?"],[7574,7691,"Keep it down, you idiot!"],[7691,7807,"You don't want to wake them!"],[7845,8074,"I mean, we don't want to alert them"],[8074,8220,"to give them a chance to escape."],[8299,8445,"They are coming. Let's go."],[8616,8666,"Okay."],[8733,8817,"Hurry, hurry."]],"29":[[129,266,"No, no, don't. Don't run."],[266,400,"We have to catch them in the act first."],[400,517,"Are you insane?"],[517,658,"Your house is on fire."],[658,809,"Who cares about the gossip?"],[809,905,"Let's get out of here."],[905,950,"No. No. No."],[950,1151,"No. I'll help everyone leave afterwards."],[1151,1255,"But first, let's get a look at them."],[1255,1309,"Come!"],[3432,3507,"Oh, hi."],[3678,3812,"What the hell do you think you're doing?"],[3812,3928,"I am so sorry."],[3928,4108,"It was an accident. Please."],[4245,4304,"You okay?"],[4304,4362,"Yeah."],[4554,4704,"The staff prepared everything for you,"],[4704,4846,"and there's hot water in there."],[5317,5447,"And what about you?"],[5488,5784,"I'll just be out here, taking guard for you."],[5864,5935,"Now go on."],[5935,6018,"It's warm."],[6202,6260,"Thanks."]],"30":[[1010,1087,"Damn it!"],[1397,1443,"What is it?"],[1576,1768,"Miss Rossi's demanding to see you, sir."],[1814,1976,"She's quite insistent."],[2031,2114,"Okay. Let her in."],[2535,2671,"You set off the fire alarms,"],[2671,2840,"and completely scared away my guests."],[2840,3028,"You ruined my birthday celebration."],[4074,4108,"Hey!"],[4170,4379,"You will take full responsibility"],[4379,4466,"for what you did."],[4500,4704,"The drugging, the setup, all of it."],[4746,5005,"And if you ever threaten Ava again,"],[5005,5208,"directly or indirectly,"],[5226,5388,"I will end the Rossi family"],[5422,5613,"from this city permanently."],[5626,5722,"You're a monster."],[5801,5908,"That's her in there, isn't it?"],[5908,6210,"Ava? Your dead brother's wife?"],[6210,6293,"How dare you!"],[6293,6373,"Take her away."],[6468,6602,"Get your hands off of me!"],[6602,6723,"Do you know who I am?"]],"31":[[1488,1551,"Luca?"],[2569,2635,"Luca!"],[2694,2798,"It's me! Wake up!"],[2798,2940,"Ava, you're so close."],[3048,3153,"Is this a dream?"],[3778,3820,"Luca!"],[3903,4020,"I'm your brother's wife."],[4087,4233,"So, this isn't a dream."],[4233,4300,"I am..."],[4450,4500,"Ava."],[4612,4733,"I've had feelings for you"],[4733,4850,"for so long."],[4954,5117,"I tried to keep them a secret, but I..."],[5196,5380,"I can't keep them any longer."],[5497,5588,"And now you know"],[5588,5891,"my two secrets in my family code."],[6022,6147,"I have to silence"],[6210,6431,"the person who discovers my weaknesses."],[6539,6669,"Luca, let me go."],[6669,6727,"No, no, no."],[6727,6865,"But I can't silence you..."],[6865,7161,"because Ava, I have fallen in love with you."],[7248,7411,"Luca, that's not funny."],[7611,7820,"Look, I've never been more serious."],[7974,8028,"Okay, Ava."],[8028,8283,"Every time I come around you, I..."],[8391,8537,"I felt myself slipping..."],[8662,8773,"And my feelings had crossed"],[8773,8879,"that line months ago."],[9146,9392,"Stop. Stop. Just stop."],[9438,9588,"I'll forget this ever happened."],[9588,9667,"No, Ava!"],[9809,10005,"I want to take care of you..."],[10076,10285,"and the baby for the rest of my life."],[11127,11240,"Luca, I..."]],"32":[[25,141,"Luca, what's going on?"],[141,229,"Why isn't Ava home?"],[471,583,"What's going on here?"],[625,671,"Mom."],[709,742,"I..."],[742,796,"Nothing."],[935,1053,"My clothes were dirty,"],[1053,1226,"so Luca prepared for me"],[1226,1388,"a shower and clean clothes."],[1422,1622,"Oh, thank goodness."],[1685,1776,"The last thing we need"],[1776,1926,"is for you to catch pneumonia."],[1926,2043,"Yeah, I know."],[2089,2301,"Ava, I think that we should probably..."],[2348,2394,"Luca!"],[2635,2789,"It's almost Marco's birthday."],[2898,3003,"Let's visit his grave."],[3215,3445,"He's your brother and my husband."],[3516,3830,"And we don't want to betray his memory."],[3853,3949,"Oh, you poor thing."],[3949,4133,"You must be utterly exhausted."],[4200,4325,"Let's get you home."],[4404,4625,"These Rossis are nothing but trouble."],[4646,4792,"We need to accelerate our plans"],[4792,4879,"against them."],[5947,6043,"Marco..."],[6289,6393,"I miss you."],[6681,6923,"I feel so lost without you."],[7328,7453,"Would you hate me"],[7607,7828,"if you knew I had feelings for your brother?"],[8216,8320,"Ava, are you in there?"]],"33":[[191,279,"Ava? Are you there?"],[450,684,"I meant everything that I said today."],[821,971,"And I wanna help you get through this."],[971,1101,"And I want to protect you."],[1230,1317,"Marco and Mom."],[1438,1564,"They would both understand."],[1776,1897,"Ava, I love you."],[3395,3589,"I understand how difficult this is."],[3762,3928,"Your loyalty to Marco"],[4016,4141,"and your concern for my mother."],[4141,4250,"That is the compassion that..."],[4425,4600,"that's the reason I fell in love with you."],[4929,5117,"There's $30 million on this credit card,"],[5271,5405,"and the PIN number is your birthday."],[8237,8333,"Wait for me."]],"34":[[487,789,"The baby's development is right on track."],[834,1009,"Perfect, actually."],[1163,1292,"How's your husband been doing those"],[1292,1514,"tactile bonding exercises I showed you?"],[1580,1643,"Doctor..."],[1776,1977,"Actually, he's not exactly my—"],[1977,2169,"Oh, no need to be embarrassed."],[2206,2352,"The way that man looks at you"],[2352,2464,"is something special."],[2936,3069,"Now, face each other."],[3190,3319,"Helena, take her hands."],[3432,3528,"Deep inhale,"],[3649,3803,"and lean into each other,"],[3895,4124,"using each other's way to support you."],[4325,4408,"Come up."],[4888,5125,"On the exhale, do a gentle squat."],[5472,5751,"And then share an embrace."],[6089,6189,"You are finally home."],[6760,6873,"Who exactly are you"],[6873,7082,"welcoming home, dear daughter-in-law?"],[7223,7515,"I was just talking nonsense."],[8471,8571,"I'll get it."],[9054,9300,"Miss, flowers from Mr. Mancini."],[9501,9551,"Thank you."],[12662,12875,"I wonder if he's doing well out there."],[14385,14431,"Hello?"],[14447,14489,"Ava."],[14547,14656,"I'm outside at the gate."],[14777,14889,"Security won't let me in."]],"35":[[316,433,"Mom, what are you doing here?"],[467,667,"I missed you terribly, sweetheart."],[684,838,"I just wanted to check on you..."],[900,975,"and the baby."],[1330,1380,"Look!"],[1476,1722,"Fresh oranges, just picked today."],[1785,1893,"You need the vitamin C..."],[1893,2043,"for the baby's development."],[2043,2243,"I'm on a very carefully monitored diet."],[2389,2502,"You wasted a trip."],[2844,2898,"Look,"],[2969,3146,"I know that you haven't forgiven me,"],[3186,3335,"but you have to understand."],[3395,3589,"Derek and Sarah..."],[3589,3695,"I mean, they would've"],[3724,3866,"thrown me out on the street"],[3866,3999,"if I didn't go along with them."],[4054,4191,"And what choice did I have?"],[4404,4561,"That's not rehash the past."],[4587,4653,"Of course."],[4788,5042,"I picked these up for my grandchild."],[5071,5184,"Aren't they precious?"],[5380,5476,"That baby..."],[5476,5714,"that you're carrying is my family too."],[5839,6014,"I love him so much already."],[6072,6348,"Look, I stood up for you to Derek,"],[6389,6506,"and he threw me out."],[6573,6756,"I had absolutely nothing left."],[7724,7873,"This card contains all the money"],[7873,7953,"I've saved."],[7987,8076,"It's yours."],[8141,8233,"But you have to promise me"],[8233,8381,"that you'll use it for yourself."],[8400,8583,"Not a penny goes to Derek."],[8583,8641,"Okay."],[8692,8756,"I swear it."],[8817,8908,"Not a cent to him."],[9013,9142,"How much money are we talking about?"],[9188,9309,"Ten thousand dollars."],[9484,9622,"Ten thousand?!"],[9709,9762,"That's it."],[9789,9865,"Mm."],[9872,10028,"You're carrying the Mancini heir,"],[10028,10300,"and all they've given you is $10,000."],[10352,10573,"That is my personal savings."],[10598,10809,"I haven't asked the Mancinis for a cent."],[10809,11123,"Okay, this is completely unacceptable."]],"36":[[0,191,"Everyone in the city knows that"],[191,434,"the Mancini's are loaded beyond belief."],[475,742,"Come on, you need to milk this situation"],[742,863,"for all it's worth."],[1401,1559,"Honey, I'm..."],[1776,1984,"I'm only thinking about your future..."],[2022,2114,"and your security."],[2114,2156,"I mean,"],[2281,2431,"what happens if they throw you out"],[2431,2569,"once the baby arrives?"],[2569,2740,"I didn't marry into"],[2740,2944,"the Mancini family for their fortune."],[3028,3286,"And you mention their money one more time,"],[3286,3536,"you'll never see me again. Understand?"],[3591,3724,"I understand, sweetheart."],[3787,3930,"I won't say another word about it."],[4405,4498,"Psst."],[4542,4671,"$10,000?"],[4671,4765,"That's it?"],[4784,4920,"That's pocket change for them!"],[5005,5138,"She must be holding out on us."],[5338,5597,"That ungrateful little brat!"],[5609,5751,"I tried everything."],[5847,5905,"I couldn't squeeze"],[5905,6001,"another penny out of her."],[6018,6222,"She's swimming in Mancini money."],[6222,6381,"And we're here struggling?"],[6381,6502,"After what they did to my leg,"],[6539,6685,"I should be getting millions."],[6685,6748,"Yes."],[6769,6835,"A few million"],[6915,6998,"is just the beginning."],[7098,7203,"We've been thinking too small."],[8379,8445,"I have good reason"],[8445,8621,"to believe that we have a common enemy."],[8692,8813,"I think we should work together."]],"37":[[125,308,"Ms. Mancini has been sleeping well, sir."],[387,532,"She got the prenatal vitamins"],[532,605,"you sent her,"],[608,775,"and may have effectively reduced"],[775,863,"her morning sickness."],[913,992,"And this morning,"],[1017,1251,"she ate half a slice of French toast,"],[1288,1459,"a half portion of scrambled eggs,"],[1459,1667,"two cherry tomatoes and a glass of milk."],[1722,1885,"And after some gentle persuasion"],[1885,1964,"from your mother,"],[2002,2139,"she also had a piece of steak"],[2139,2223,"for the iron content."],[2223,2402,"Oh, that's good to hear that"],[2402,2489,"she's eating healthy."],[2498,2635,"And then she finally attended"],[2635,2857,"the prenatal concert you arranged."],[2877,3051,"And afterwards, she spoke with"],[3051,3328,"one of the pianists about the compositions."],[3328,3420,"Is it a man or woman?"],[3436,3570,"Sir, per your instructions,"],[3570,3716,"they were all talented women."],[3732,3826,"No exceptions."],[3928,4133,"And she actually mentioned you today."],[4133,4275,"While making hot chocolate,"],[4275,4433,"she said to the chef:"],[4466,4645,"It's never quite as good as Luca's."],[4733,4870,"She always knows what to say."],[5080,5225,"I'll make her a batch right now,"],[5225,5347,"and we can have a delivery."],[5347,5413,"Great."],[5413,5576,"I'll arrange a private courier right away."],[5605,5643,"Alright."],[5676,5709,"Thank you."],[6177,6435,"Luca is almost finished with his business."],[6435,6589,"Hopefully, he will make it home"],[6589,6698,"in time for the birth."],[6931,7119,"Mrs. Mancini, the terrible news."],[7152,7290,"Luca's jet has been destroyed mid-flight."],[7290,7369,"He..."],[7369,7439,"he's missing."],[7490,7553,"What?"]],"38":[[0,145,"I want every detail immediately."],[145,200,"Yes, ma'am."],[429,496,"Ava, breathe."],[513,592,"Breathe."],[613,688,"Don't panic."],[717,763,"Don't panic."],[763,963,"Luca has always been lucky."],[963,1059,"He's going to be fine."],[1092,1155,"He will."],[1676,1739,"Hello?"],[1739,1893,"I have Luca Mancini."],[1893,2147,"$20 million cash for his safe return."],[2185,2544,"No police, no family, no security team."],[2602,2815,"You come alone, or he dies."],[2873,3011,"You have 24 hours."],[3482,3624,"Oh, Ava, are you okay?"],[3682,3749,"Who was that?"],[3749,3891,"It's nothing. Nothing."],[3891,4083,"I am just dizzy."],[4175,4287,"The... the baby..."],[4325,4529,"So, I'm gonna go upstairs and lie down."],[4992,5066,"Here."],[6235,6302,"Luca!"],[6443,6585,"Money first."],[7966,8049,"Are you okay?"],[8279,8345,"Derek."],[8466,8529,"Where's Luca?"],[8629,8687,"Where's he?"],[8775,8888,"Don't worry about Luca."],[8975,9080,"Worry about yourself."]],"39":[[1422,1522,"Yeah."],[1522,1710,"With her as a bargaining chip,"],[1743,2064,"we can demand 100 million dollars"],[2064,2223,"from the Mancinis."],[2323,2394,"Easy."],[2423,2521,"No..."],[2570,2729,"Mom, why are you doing this?"],[2752,2857,"We're family."],[2857,3078,"Why are you always treating me so terribly?"],[3495,3561,"Family?"],[3653,3912,"You are so pathetic!"],[3987,4154,"You just don't get it, do you?"],[4179,4371,"You're just some brat that Mom found"],[4371,4421,"on the street,"],[4421,4717,"that she brought home to be our living servant."],[4717,4817,"What are you talking about?"],[4817,5025,"You're an orphan!"],[5109,5392,"Not even your birth mother wanted you."],[5455,5584,"Yeah, we brought you in."],[5651,5870,"We fed you. We clothed you."],[5943,6309,"And in return, your life belongs to us."],[6410,6556,"Oh, and..."],[6556,6606,"by the way,"],[6606,6744,"since we're being honest"],[6744,6869,"with each other right now..."],[6869,6961,"My whole leg injury?"],[7019,7148,"It's kind of my fault,"],[7278,7424,"but it was a great excuse"],[7424,7651,"to get you to basically give up your life."],[7670,7937,"And be our slave all these years."],[8316,8399,"You know what..."],[8687,8765,"Even though you're nothing"],[8765,8999,"but a bunch of orphan trash,"],[9129,9250,"you're actually very beautiful."],[9396,9547,"So, since we're giving up this whole..."],[9605,9718,"brother-sister"],[9788,9901,"role-playing thing,"],[10051,10155,"why don't we do something"],[10260,10443,"that I've wanted to do"],[10523,10814,"for a very, very long time?"],[10877,10969,"Stop!"],[10969,11061,"Derek! You're sick!"],[11061,11177,"Shh!"],[11423,11634,"Now, let's just keep that"],[11634,11830,"pretty little mouth of yours quiet,"],[11830,11899,"shall we?"],[12404,12570,"You fucking bitch!"]],"40":[[1672,1812,"Luca, you are alive."],[1812,1903,"You're okay..."],[2777,2882,"My plane blew up."],[2915,3021,"Ava gets kidnapped."],[3022,3119,"This isn't a coincidence!"],[3119,3228,"Who are you working for?"],[3307,3382,"Answer me!"],[3870,3978,"Make them stop!"],[4058,4162,"He is your brother."],[4195,4300,"You'll kill him!"],[4300,4458,"You just told me I'm an orphan."],[4458,4617,"So he's not my real brother."],[4667,4750,"You better tell me"],[4750,4884,"who your accomplices are,"],[4884,5046,"or he stops breathing."],[5046,5280,"You two should be ashamed of yourselves."],[5334,5521,"See the way that you look at each other?"],[5538,5839,"He's your dead husband's brother."],[5860,6126,"You're betraying Marco and his mother."]],"41":[[179,258,"Are you alright?"],[258,329,"Hey, hey, hey!"],[329,383,"Are you okay?"],[383,467,"Yeah."],[617,850,"Your mom has been so kind to me,"],[850,1007,"and I dragged her into this mess."],[1042,1142,"It's all my fault."],[1297,1497,"Your mother-in-law took you in."],[1497,1626,"She treated you like a daughter."],[1626,1822,"She gave you everything that you could ever want."],[1822,1989,"And this is how you repay her?"],[2018,2198,"By falling for her younger son?"],[2293,2502,"Have you already forgotten Marco"],[2502,2623,"in his grave?"],[2660,2811,"What is wrong with you?"],[3144,3299,"I want her as my daughter-in-law."],[3436,3628,"First, my eldest son's wife,"],[3712,3853,"and now my youngest."],[4012,4124,"Object again,"],[4191,4358,"and you'll lose your tongue."],[5397,5578,"You couldn't have Luca."],[5663,5944,"So you decided to try and kill him?"],[6072,6268,"Good thing he changed his flight plan"],[6268,6393,"at the last minute. Hmm?"],[6531,6925,"Cross the Mancinis, and you cease to exist."],[6931,7037,"Release me!"],[7077,7186,"My father will burn"],[7186,7349,"your empire to the ground."],[7632,7874,"Don't you wonder why my son was gone"],[7874,8012,"all that time?"],[8266,8437,"Your family's power?"],[8629,8750,"Already gone."],[9993,10127,"You two have risked"],[10127,10346,"everything to be together."],[10464,10976,"I can see that Luca's devotion is absolute."],[11115,11439,"You have endured far too much pain."],[11540,11632,"It's time to let him"],[11632,11728,"take care of you."],[11749,11778,"But..."],[11911,12024,"Marco."],[12024,12162,"I made a promise to him."],[12291,12395,"And Marco..."],[12479,12872,"would want your happiness above all else."],[12962,13142,"He will rest easier..."],[13279,13459,"knowing that we are protecting you"],[13546,13655,"and your child."],[14051,14155,"From this moment forward,"],[14226,14305,"I swear to you,"],[14305,14464,"nobody will ever hurt you again."],[14927,15115,"Luca! You're bleeding."]],"42":[[87,212,"You gotta keep this clean."],[258,296,"Yeah."],[329,546,"Infections can get nasty."],[942,1013,"So, you're saying that"],[1013,1114,"you care about me then."],[1180,1288,"Shut up!"],[1355,1463,"Of course I care."],[1772,1822,"Thank you."],[1868,1935,"Alright."],[2060,2102,"Wait."],[4750,4867,"I think he likes you."],[4867,4900,"Yeah?"],[5330,5392,"Ava."],[5505,5622,"I will take care of you,"],[5734,5818,"care of baby,"],[5918,6043,"just like my brother would have."],[6085,6214,"I brought some fruit for you and..."],[6456,6535,"Luca."],[6664,6773,"She's pregnant."],[6852,6940,"Be gentle with her."],[7323,7486,"I think maybe you should get some rest."],[7574,7620,"Okay."],[8020,8143,"Oh, wait!"]],"43":[[33,66,"What is it?"],[91,212,"I think I'm in labor."],[296,367,"Oh my God."],[427,531,"Come on."],[592,695,"Okay. Breathe in slowly."],[1207,1371,"What is taking so long?"],[1371,1483,"Is something wrong?"],[1487,1630,"She's gone into labor early."],[1668,1843,"Have you two been intimate recently?"],[1926,2164,"Well, we didn't exactly."],[2206,2398,"I mean, not completely."],[2419,2577,"I warned you to be careful with her."],[2577,2656,"Mom, I'm sorry."],[2719,2817,"What can we do now?"],[2823,2951,"The medication isn't working"],[2951,3038,"as we'd hoped."],[3111,3361,"There's another approach we could try..."],[3445,3553,"Yes, yes, we'll do anything."],[3553,3627,"Money's no object."],[3627,3714,"Just help her."],[3812,4185,"Some intimate touches can help her relax,"],[4185,4312,"and feel better."],[4629,4679,"Right here?"]],"44":[[33,105,"Right here?"],[125,194,"Yes."],[542,604,"What? Mom!"],[604,853,"I can't, I can't. Just whip it out."],[1076,1138,"Hurry it up."],[4200,4391,"I hope things are going smoothly in there."],[4433,4500,"They've never..."],[4571,4738,"been together before."],[4771,4901,"Never been together?"],[4971,5130,"Then how could she be..."],[5188,5251,"The child"],[5251,5551,"is my late son's. Luca's brother."],[5922,5972,"You okay?"],[6110,6210,"Doctor, please..."],[6210,6302,"Doctor, please!"],[7007,7186,"One. Two. Three. Push."],[7236,7415,"One. Two. Three. Push."],[7578,7728,"One. Two. Three. Push."],[7728,7912,"Push! Push! Push!"],[8287,8391,"It's your baby."]],"45":[[175,332,"—Hey. —Hey."],[333,404,"How you feeling?"],[487,533,"Good."],[579,654,"You want something to eat?"],[742,813,"I'm okay."],[825,867,"Okay."],[1343,1484,"I thought this hospital was the best"],[1484,1573,"that money could buy."],[1618,1818,"I guess I was misinformed."],[1893,1931,"Luca,"],[2097,2206,"they're doing the best they can."],[2206,2389,"That's not terrorizing the stuff."],[2419,2485,"Thank you."],[2631,2652,"Look,"],[2761,2936,"I just don't want to see you"],[2936,3036,"in any more pain."],[3107,3207,"It would tear me apart."],[3987,4066,"Luca."],[4295,4500,"Remember to control yourself, son."],[4596,4771,"Let her recover first."],[5759,5866,"And have you decided"],[5866,6047,"what to name this little prince?"],[6214,6293,"Marco..."],[6573,6698,"I want to name him Marco."],[8996,9084,"Look, little one."],[9234,9338,"It's your daddy."],[9492,9607,"Your real daddy."],[10122,10326,"It's remarkable how much he looks like you."],[10377,10418,"Marco."],[10614,10758,"I thought you had all the answers."],[10940,11044,"And that you'd handle everything."],[11190,11390,"And I promise to protect Mom,"],[11557,11628,"the business,"],[11786,11874,"and your family..."],[12120,12199,"our family."],[12554,12687,"You know, Marco used to say"],[12766,12850,"that..."],[12896,13045,"if you want to think about somebody,"],[13063,13267,"you would watch the dandelion."],[13267,13413,"And if the seeds blew out easily,"],[13413,13563,"then they were thinking of you, too."]],"46":[[1455,1518,"Miss."],[1551,1772,"Mrs. Mancini's wedding gifts."],[1772,1918,"The finest villas,"],[1918,2164,"the Mancini family jewelry,"],[2164,2281,"and finally,"],[2281,2687,"30% ownership of Mancini Group Holdings."],[2706,2923,"Effective immediately."],[3411,3720,"This ring has been in the Mancini family"],[3774,3962,"for seven generations."],[4033,4320,"Passed from mother to daughter-in-law."],[4742,4825,"Thank you, Mom."],[5447,5568,"A perfect fit."],[6777,7017,"Now I need the two of you"],[7057,7278,"to focus on your top priority."],[7356,7428,"Mom..."],[7428,7540,"Top priority?"],[7549,7724,"Giving me a granddaughter"],[7791,7988,"to play with little Marco Junior."],[8153,8425,"Mom, we're at a church..."],[8425,8600,"and there are witnesses."]]}