hat are you doing here?"],[934,980,"Alec."],[1213,1259,"Umm..."],[1376,1526,"Is there any chance that"],[1589,1701,"you could lend me"],[1789,1918,"half a million dollars?"],[2077,2273,"It's to pay for my dad’s surgery."],[2377,2544,"If I don’t do it by tonight."],[2610,2786,"They will transfer him to"],[2786,2882,"end-of-life care."],[2982,3028,"Please."],[3073,3215,"I promise I’ll you back."],[3812,3866,"Okay."],[3916,3974,"Come inside."],[3974,4137,"My card is upstairs."],[4458,4596,"Amelia Matthews."],[4596,4850,"You crafty little slut."],[4946,5067,"I sure hope you’re prepared"],[5067,5138,"for what’s coming."],[5230,5359,"Because soon,"],[5409,5513,"I will have you"],[5518,5680,"begging on your knees."],[6272,6348,"Take the card."],[6364,6452,"Go save your dad."],[6477,6577,"Thank you, Alec."],[6648,6785,"Really, I mean it."],[6890,6981,"I promise"],[6981,7069,"I’ll pay you back."],[7273,7499,"Dad and I owe you everything."],[7953,8008,"Amelia!"],[8245,8412,"Is Sam your biological father?"]],"51":[[137,175,"No."],[287,383,"I was adopted."],[513,575,"Do you know your"],[600,704,"biological parents?"],[909,1101,"Sam found me when I was six."],[1155,1297,"Something must have happened,"],[1297,1372,"because..."],[1447,1605,"I don’t have any memories"],[1605,1680,"before that."],[2031,2114,"We lost Annabella"],[2118,2227,"when she was six, too."],[2314,2502,"This can’t just be a coincidence..."],[2610,2665,"Amelia."],[2702,2752,"Do you know where"],[2752,2844,"Sam found you?"],[2998,3107,"No, I don’t.."],[3224,3390,"It’s been so long..."],[3607,3661,"Okay, I see."],[3757,3866,"Might be a little bit personal,"],[3866,3895,"but"],[3962,4029,"do you happen to have"],[4029,4116,"a birthmark on your..."],[4233,4262,"Wait."],[4788,4929,"You have the DNA results?"],[5117,5238,"You’re checking them right now?"],[5434,5509,"I’ll be there soon."],[5755,5818,"I have to run."],[5960,6039,"Go save your dad."],[6085,6197,"I hope the surgery goes well."],[8258,8495,"Why does this place feel so"],[8533,8616,"familiar?"],[10164,10322,"Why is there a picture of me"],[10439,10602,"with the Walton family?"]],"52":[[316,433,"I don’t have time for this."],[521,658,"I have to go and save Dad."],[1096,1242,"That's finally in surgery."],[1297,1447,"Now back to that picture..."],[1480,1551,"why was I"],[1551,1714,"in the Walton family picture?"],[1764,1918,"And why did that room"],[1918,2064,"feel so familiar?"],[2102,2185,"Maybe,"],[2214,2318,"could I be..."],[4404,4587,"Then use Annabella!"],[4633,4767,"She’s his twin,"],[4800,4896,"take her in there!"],[5326,5401,"Ashton."],[5513,5693,"I promised Mommy"],[5768,5914,"I would keep you safe."],[6014,6172,"You’re going to be okay."],[6256,6360,"Amelia?"],[6431,6569,"It's my grandma’s name."],[6598,6740,"It’s a pretty name?"],[7011,7182,"I remember everything."],[7311,7344,"I'm..."],[7478,7611,"I’m Annabella Walton."]],"53":[[1780,1901,"So the person"],[1901,2047,"who’s been bullying Dad"],[2081,2143,"and I"],[2210,2352,"was my own brother."],[2469,2831,"To our favorite loser!"],[3186,3328,"What are you guys doing here?"],[3445,3532,"Let me go!"],[4429,4567,"Would you look at that, huh?"],[4667,4763,"Ashton was right."],[4779,4938,"You did steal their card."],[4971,5125,"Alec lent it to me."],[5184,5301,"I’ll pay him back."],[5330,5484,"You seem to have a lot of friends"],[5488,5676,"in high places, Amelia."],[5755,5864,"First, the dean,"],[5893,6014,"now Alec?"],[6072,6193,"Why are they so nice"],[6197,6335,"to you anyways?"],[6373,6506,"Is it just out of pity?"],[6715,6869,"Or are you giving them a little..."],[6965,7052,"\"something something\""],[7057,7123,"in return?"],[7144,7215,"Don’t lie,"],[7332,7449,"we know exactly"],[7449,7603,"how you’re paying Alec back."],[7782,7903,"By selling your bod"],[7903,8003,"like a whore!"],[8078,8128,"No."],[8279,8433,"I’ll get a part time job."],[8491,8742,"I’ll wait tables if I have to."],[8804,9004,"I’ll even use a portion"],[9004,9209,"of my college scholarship"],[9217,9325,"to pay it off."],[9488,9588,"You think you’re so cool"],[9592,9667,"with your little"],[9672,9818,"collage scholarships,"],[9818,9901,"don’t you?"],[9905,9972,"You don’t have to wait"],[9972,10047,"for college."],[10155,10231,"We’re just going to film"],[10231,10339,"a few videos,"],[10339,10414,"send them to"],[10414,10577,"everyone at school."],[10614,10702,"And then boom!"],[10852,10973,"The money will come flowing"],[10973,11061,"back in!"],[11073,11156,"Strip her."],[11248,11386,"And be sure to get a clear shot."]],"54":[[563,642,"Please."],[709,850,"You don’t have to do this!"],[859,984,"You need to learn something"],[984,1146,"about your retard dad."],[1192,1288,"People like him"],[1347,1472,"will never do anything"],[1476,1618,"except take up space."],[1680,1876,"I hope this fucker eats shit"],[1897,1968,"and dies."],[2331,2398,"Hey,"],[2519,2594,"if you’re lucky,"],[2594,2681,"they might offer"],[2702,2806,"low-income discount"],[2811,2865,"at the morgue."],[2998,3057,"Shut up!"],[3194,3411,"My dad is braver"],[3449,3528,"and stronger"],[3532,3678,"than all of you combined!"],[3970,4175,"Hold still, you stupid slut!"],[4658,4771,"Eww..."],[4850,4975,"Is that a birthmark?"],[5025,5213,"It's so fucking ugly."],[6202,6243,"No!"],[6606,6677,"Please..."],[6690,6831,"let me go."],[6986,7148,"I need to go to the hospital."],[7178,7223,"I..."],[7553,7699,"Who needs the hospital"],[7741,7853,"when I can disinfect"],[7862,7953,"the wound for you"],[7966,8037,"right now!"],[9079,9246,"Just give up, Amelia."],[9367,9442,"If you keep"],[9442,9551,"putting up a fight,"],[9630,9780,"it’ll only make these psychos"],[9784,9880,"more crazy."]],"55":[[116,246,"I know why you’re doing this."],[387,458,"It’s because"],[563,696,"I refused to give up,"],[792,875,"to bow down"],[921,1005,"in front of you"],[1009,1121,"like everyone else."],[1234,1280,"You’re all"],[1280,1368,"cowards,"],[1501,1647,"and you just feel threatened"],[1680,1726,"by me"],[1876,1947,"because"],[2056,2293,"I just show how useless"],[2394,2527,"and weak you really are."],[2548,2694,"Did you just say \"useless\"?"],[2711,2936,"And you are calling us"],[2936,3019,"cowards?"],[3032,3098,"Am I wrong?"],[3257,3470,"You contribute less to society"],[3503,3570,"than my dad."],[3749,3837,"You’re nothing"],[3916,4062,"without your parents’ money."],[4170,4279,"Without their wealth,"],[4375,4525,"you’d be just fuck-ups"],[4583,4692,"within a single year"],[4692,4800,"of graduating."],[4900,5042,"Say that one more time!"],[5417,5480,"Don’t you dare"],[5484,5609,"talk about my sister, okay?"],[6644,6752,"How is that for a taste"],[6752,6886,"of your own medicine, huh?"],[6969,7107,"Sorry, I can't breathe..."],[7140,7236,"You think I’m scared?"],[7428,7536,"I would say it again."],[7674,7753,"You’re nothing"],[7811,7949,"without your parent's money."],[8083,8170,"And still with it,"],[8308,8379,"you’re just"],[8462,8521,"sad,"],[8571,8612,"weak"],[8708,8842,"and insecure bully."],[9059,9196,"Congratulations,"],[9230,9267,"Ashton."],[9430,9667,"Your sister is never coming back."]],"56":[[95,158,"Shut up!"],[216,350,"Don’t you ever bring Annabella"],[354,404,"into this!"],[592,625,"You don’t know"],[625,713,"how close we were!"],[796,875,"You don’t know what she did"],[875,930,"for me."],[1226,1267,"Whatever."],[1309,1409,"A broke-ass whore like you"],[1409,1484,"would never get it."],[1526,1622,"I promise you,"],[1751,1839,"she would never"],[1868,2047,"accept the person you became."],[2252,2444,"You'll never get your sister back!"],[2477,2652,"I’ll fucking kill you!"],[4525,4596,"Lock the door."],[4642,4708,"Let's see how long"],[4708,4792,"she lasts in here."],[6131,6231,"Let me out!"],[7157,7240,"Save it!"],[7244,7361,"No one will hear you there."],[7432,7490,"Who knows, maybe they will"],[7490,7649,"find you after Spring break."]],"57":[[1172,1222,"Help me!"],[1351,1384,"Please!"],[1493,1580,"Help me!"],[1976,2010,"Ashton!"],[2118,2189,"Have you seen Amelia"],[2256,2310,"anywhere?"],[2381,2460,"Tell me where she is!"],[2481,2548,"What, I look like her"],[2548,2656,"fucking bodyguard?"],[2681,2790,"I haven’t seen her all day!"],[2827,2882,"Ashton,"],[2923,3023,"Amelia is our sister,"],[3028,3111,"she’s Annabella!"],[3374,3420,"What?"],[3561,3595,"No..."],[3628,3661,"No!"],[3707,3745,"She’s..."],[4604,4708,"What happened in that room?"],[4783,4859,"It’s on fire!"],[5226,5355,"Somebody, please..."],[5434,5530,"Help me..."],[5568,5668,"Annabella is still in there!"],[5684,5759,"We have to go get her!"]],"58":[[95,150,"Please..."],[296,371,"Help me..."],[750,800,"Annabella!"],[846,938,"We will get you out of there!"],[984,1055,"It's an emergency!"],[1209,1305,"There’s a fire in a classroom"],[1305,1376,"at St. Peter’s."],[1497,1593,"Someone’s trapped inside!"],[1605,1676,"Just hold on!"],[1701,1739,"Hold on!"],[2598,2665,"Annabella,"],[2819,2932,"I’m never leaving you"],[2932,3007,"behind again."]],"59":[[429,504,"Dr. Martin..."],[554,646,"Are my boys okay?"],[671,796,"Alec and the girl"],[796,925,"they came in with are fine."],[955,1113,"Just some mild smoke inhalation."],[1222,1301,"But Ashton..."],[1388,1434,"I’m afraid"],[1434,1559,"his leukemia is back."],[1626,1726,"He'll need another"],[1726,1868,"bone marrow transplant,"],[1947,2039,"but we don’t have"],[2039,2173,"any matching donors."],[2198,2352,"Well then go and find one!"],[2410,2544,"I’ll pay a million dollars,"],[2544,2627,"ten million,"],[2665,2731,"anything!"],[2786,2927,"Whatever it takes to save"],[2927,2986,"my son!"],[3561,3657,"Mrs. Walton,"],[3691,3812,"are they doing alright in there?"],[3941,4233,"There was a fire in your school!"],[4283,4429,"My son got hurt"],[4429,4579,"due to your negligence!"],[4683,4859,"Anything else happens to him,"],[4896,5021,"you can forget"],[5034,5096,"about getting"],[5096,5205,"any more funding"],[5209,5351,"from our family!"],[5568,5680,"Mrs. Walton,"],[5768,5855,"cigarettes and"],[5889,5976,"empty wine bottles"],[5980,6064,"were found at the scene."],[6139,6302,"We believe that the fire started"],[6302,6431,"from a lit cigarette and"],[6506,6552,"just..."],[6560,6681,"onto all the dust"],[6681,6815,"and the wood in the room."],[6848,6940,"Wine bottles..."],[7061,7148,"a cigarette?"],[7219,7261,"No,"],[7340,7599,"Alec and Ashton are good boys."],[7649,7707,"What would they have been"],[7711,7757,"doing there?"],[7791,7974,"We also found a debit card"],[8033,8128,"on the floor in the room"],[8224,8291,"in your name."],[8454,8512,"We traced back"],[8512,8637,"the transaction history,"],[8717,8858,"and the card was recently used"],[8863,9013,"to pay a half-million-dollar"],[9088,9159,"medical bill"],[9221,9305,"for Sam Matthews."],[9505,9709,"So it’s Amelia’s fault."],[9872,10051,"She stole my credit card"],[10114,10264,"and she trapped my boys"],[10289,10414,"just to get back at me?"],[10472,10573,"She’s a cold-blooded"],[10573,10627,"killer!"],[10781,10873,"See if Amelia"],[10877,10944,"is a bone marrow"],[10944,11031,"match to Ashton."],[11061,11161,"And if she is,"],[11194,11286,"tell the doctor"],[11307,11440,"to use her marrow on him!"],[11540,11774,"I don’t care if she dies."],[11853,11945,"That’s what she gets"],[11945,12132,"for setting fire to my sons!"]],"60":[[4383,4433,"Alec!"],[4558,4671,"Alec, are you okay?"],[4867,4904,"Mom..."],[5005,5096,"It's Amelia..."],[5251,5367,"She's Anabella."],[5455,5530,"She’s our..."],[5655,5734,"sister."]],"61":[[33,129,"No, no..."],[262,283,"That..."],[350,471,"that’s preposterous."],[533,617,"It’s true."],[742,863,"We did a DNA test."],[934,992,"No."],[1301,1401,"Annabella!"],[1463,1630,"Stop the surgery!"],[1689,1843,"That’s my daughter!"],[1856,1968,"That’s Annabella!"]],"62":[[304,408,"Dr. Martin."],[496,600,"When will she wake up?"],[679,829,"Her condition is stable."],[917,1021,"It's possible"],[1026,1151,"she's not waking up"],[1163,1230,"because"],[1297,1380,"deep down,"],[1459,1589,"she just doesn’t want to face"],[1589,1697,"her current reality."],[1793,1914,"Why did you do this to her?"],[1960,2064,"You idiot!"],[2093,2173,"You’ve been torturing"],[2173,2310,"our sister all this time!"],[3261,3340,"Oh God,"],[3445,3611,"it’s all my fault!"],[4517,4612,"I’m the worst brother"],[4612,4675,"in the world!"],[4792,4900,"I humiliated you,"],[4900,5009,"I bullied you."],[5142,5238,"I left you behind"],[5238,5405,"when you most needed me."],[5655,5726,"Please, Annabella,"],[5726,5822,"just wake up!"],[5834,5985,"Please, just wake up!"],[6177,6277,"I’ll do anything,"],[6310,6423,"I swear, anything!"],[6423,6560,"Just, please, wake up!"],[6573,6648,"Please..."],[6760,6856,"Please..."]],"63":[[33,95,"Ashton."],[750,867,"It’s my fault too."],[980,1138,"If I’d just kept the closer eye"],[1138,1247,"on her that day."],[1359,1409,"Or..."],[1443,1580,"or if I hadn’t showed up late"],[1580,1672,"to the hospital,"],[1789,1926,"maybe everything would still"],[1926,2018,"be okay."],[2097,2198,"Oh God,"],[2464,2619,"if there’s someone to punish,"],[2627,2660,"just"],[2731,2819,"let it be me."],[2990,3123,"Please not my kids!"],[3353,3490,"She’ll wake up eventually, Mom."],[3674,3766,"But let’s give her some"],[3832,3958,"peace and quiet for now,"],[3987,4045,"okay?"],[4250,4312,"You’re right,"],[4400,4508,"she needs to rest."],[4700,4825,"I’ll be quiet now."],[5309,5472,"What if she never forgives us?"],[6101,6172,"You wanted to see me,"],[6172,6231,"Mrs. Walton?"],[7695,7745,"You"],[7816,7916,"abandoned"],[7941,8028,"Annabella"],[8033,8128,"at the hospital"],[8137,8237,"ten years ago."],[8333,8391,"And"],[8441,8566,"you even burned"],[8566,8729,"her DNA results"],[8775,8954,"to cover for your crimes."],[9305,9509,"Break his limbs."],[9605,9843,"Make him disappear."],[10005,10168,"I don’t want him ever"],[10168,10256,"stepping foot"],[10260,10427,"in this city again."],[10493,10589,"Mrs. Walton, please!"],[10602,10744,"Have mercy, Ms. Walton!"],[10756,11015,"I’ll punish every single person"],[11015,11131,"who hurt you, Annabella."]],"64":[[863,934,"Amelia."],[1105,1151,"Dad?"],[1251,1372,"I thought I’d lost you."],[2239,2331,"We’ve brought her nothing but"],[2356,2464,"pain and suffering."],[2644,2727,"Maybe it’s time"],[2727,2836,"to take a step back."],[4262,4329,"Annabella!"],[4350,4400,"Dad!"],[4562,4625,"Amelia!"],[4959,5201,"I got a full ride into Yale!"],[5814,5872,"Annabella!"],[5968,6118,"I’m so proud of you!"],[6206,6289,"Why don’t we get dinner"],[6289,6368,"and celebrate?"],[6427,6606,"It’s been so long, darling..."],[6673,6715,"Please."],[6777,6848,"We just want to spend"],[6848,6931,"a little time with you."],[7019,7077,"We’ve been waiting"],[7077,7148,"for ten years."],[7194,7303,"Please forgive me, Annabella."],[7444,7515,"I know everything that"],[7515,7624,"happened was my fault."],[7774,7882,"Yell at me, hit me"],[7882,7941,"if you want."],[8028,8095,"Please, forgive me."]],"65":[[33,141,"Not a day goes by"],[141,191,"that we don’t"],[191,312,"think about you, Annabella."],[462,583,"I want to give you these gifts."],[684,825,"as an apology for everything"],[825,938,"that we put you through."],[975,1088,"These are all the"],[1213,1388,"birthday and Christmas presents"],[1388,1422,"you've missed"],[1422,1530,"for the past ten years."],[1710,1797,"This was supposed to be"],[1797,1885,"for your prom night."],[1939,1981,"Listen,"],[2164,2339,"I’m not your Annabella anymore."],[2452,2498,"I’m"],[2819,2969,"Amelia Matthews,"],[3090,3169,"and my dad"],[3194,3365,"is my only family here."],[3495,3536,"So"],[3716,3878,"if you excuse us,"],[3887,3949,"Mrs. Walton."],[4441,4542,"Oh, Annabella!"],[4621,4717,"Wait, please."],[4813,4879,"Annabella!"],[4879,4909,"Oh!"],[5100,5201,"Annabella, please."],[5380,5484,"It’s all your fault,"],[5484,5593,"Amelia Matthews!"],[5668,5759,"Because of you,"],[5814,5897,"I broke an arm,"],[6001,6085,"broke a leg,"],[6147,6227,"got fired"],[6289,6356,"and I lost"],[6402,6481,"everything!"],[9496,9563,"Let go off me!"],[9626,9701,"Let go!"],[9822,9859,"Oh my God!"],[9922,9980,"Ashton!"],[10130,10247,"You saved my life twice."],[10310,10385,"Now it’s my turn."]],"66":[[1267,1322,"Annabella?"],[1459,1501,"Ashton!"],[1543,1626,"You need to rest."],[1751,1822,"No, I need to"],[1822,1885,"go find Annabella."],[1885,1947,"Where is she?"],[2177,2231,"Ashton,"],[2302,2381,"she's gone."],[2515,2660,"But she left you this letter."],[3699,3812,"Dear Ashton,"],[3878,4037,"if you want me to forgive you,"],[4062,4291,"it has to start with your actions."],[4333,4433,"I want you to go"],[4454,4596,"and help people like me,"],[4671,4850,"the same people you bullied."],[4900,5017,"If you truly open"],[5021,5121,"your heart to them,"],[5159,5317,"you can become a better person,"],[5388,5463,"and that"],[5484,5538,"would mean"],[5538,5651,"so much more to me"],[5655,5830,"than any kind of apology."],[5922,6001,"But Ashton,"],[6131,6239,"don’t do it for me."],[6327,6398,"Do it"],[6410,6460,"because"],[6477,6639,"it’s the right thing to do."],[7874,7970,"I promise you Annabella."],[8128,8237,"I’ll become a better person."],[8708,8821,"I'll never let you down again."]]}