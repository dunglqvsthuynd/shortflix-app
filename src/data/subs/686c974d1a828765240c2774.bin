 need it"],[1989,2031,"right now."],[2077,2127,"Please."],[2156,2289,"Yo Ashton,"],[2377,2485,"you think she’s going to use"],[2485,2698,"your cash to help her retard dad?"],[2865,3103,"That idiot is a full-grown adult"],[3157,3345,"with the IQ of a four-year-old."],[3436,3566,"What a goddamn waste."],[3732,3895,"I totally forgot about that."],[3924,4104,"You need funds to save"],[4104,4266,"your vegetable of a father..."],[4416,4521,"But fuck if I care,"],[4521,4575,"am I right?"],[4800,4946,"Fucking douche."],[5080,5213,"Get lost."],[5255,5355,"You’re killing our vibe."],[5935,6010,"Hold on."],[6185,6302,"I changed my mind."],[6418,6468,"Tell you what,"],[6544,6594,"if you do"],[6594,6744,"one little thing for me,"],[6790,6919,"I will pay you more than"],[6919,7040,"what I already promised you."],[7232,7315,"I want you to take"],[7315,7540,"the SAT for me next week."],[7595,7682,"In exchange,"],[7720,8066,"I’ll give you half a million dollars,"],[8274,8500,"on top of what I already owe you."],[8746,8850,"Are you crazy?"],[8917,9059,"It’s the SATs!"],[9138,9242,"If I get caught,"],[9259,9409,"I’m never going to college!"],[9413,9480,"Come on."],[9480,9622,"Don’t worry about getting caught."],[9667,9801,"Our family’s word is"],[9801,9884,"law around here."],[9947,10105,"But if you don’t do it,"],[10160,10326,"your daddy won’t live to see you"],[10326,10422,"graduate high school."],[10523,10577,"Your call."]],"48":[[133,262,"How much is it per day"],[266,358,"for the ICU?"],[404,529,"Is it seven thousand?"],[592,688,"Or maybe eight"],[725,875,"with the extra retard fee?"],[1259,1301,"I…"],[1380,1459,"Give me some time."],[1555,1685,"I need to think that through."],[1701,1914,"Clock is ticking, Amelia."],[2035,2135,"I wonder how long"],[2135,2252,"your dad will last if..."],[2306,2381,"I just tell the doctor"],[2381,2531,"to turn off his respirator."],[2698,2761,"Here’s the deal."],[2865,3211,"You get a 1600 for the SAT."],[3324,3645,"But if you miss one single point,