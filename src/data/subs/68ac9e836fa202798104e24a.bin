{"1":[[304,354,"Okay."],[354,500,"Milk and eggs."],[500,558,"Right,"],[558,803,"milk, eggs."],[803,884,"Mm-hmm."],[884,1001,"And what else, babe?"],[1084,1217,"Oh, what if we get pasta?"],[1217,1413,"Oh, we can make fettuccine alfredo?"],[1413,1530,"Yes!"],[1530,1685,"Pasta."],[1685,1893,"Babe, please be careful."],[2002,2143,"Why, because I'd fall?"],[2143,2210,"Yes."],[2210,2268,"Oh!"],[2268,2381,"Oops."],[2610,2806,"Yes, in case you fall..."],[2902,3065,"in love with me?"],[3065,3228,"Well, Luke Cattaneol."],[3228,3390,"It's too late for that."],[3390,3474,"I know."],[4095,4275,"Groceries first."],[4275,4400,"You're not getting out of it."],[4400,4471,"But..."],[4471,4578,"No, man."],[4702,4833,"Come on, mister."],[4950,5037,"You shouldn't dress like this"],[5037,5196,"and make a grocery list."],[5400,5613,"What if I get frozen grapes as a snack?"],[5613,5793,"Is that really replacing ice cream"],[5793,5904,"or am I getting kicked out again"],[5904,6056,"at 2 a.m. to go get it for us?"],[6056,6139,"Mm."],[6227,6431,"Babe, you have a little-"],[7303,7404,"Ouch!"],[7660,7741,"Ah!"],[7741,7811,"Who are you?"],[9238,9455,"Hi Emily, how are you?"],[9663,9751,"Wait, Luke."],[9751,9897,"Luke, where is my Luke?"],[9897,9953,"He should be-"],[9953,10035,"Ma'am,"],[10035,10287,"you've been in a severe accident, okay?"],[10287,10455,"Multiple surgeries. Please."],[10480,10643,"Where's my husband?"],[10643,10748,"He should be right there."],[10748,10844,"—He should be here. —He's..."],[11428,11669,"No, no, no."],[11669,11757,"Is he dead?"],[11757,11878,"He's fine. He's fine."],[11878,11986,"He's fine, okay?"],[12049,12135,"He just..."],[12170,12316,"He just left you something."],[12383,12474,"What?"],[12474,12683,"What, what did he, what-"],[12683,12808,"What's going on?"],[13442,13538,"Divorce?"],[13722,13813,"What? What?"],[13813,13892,"No, he wouldn't."],[13970,14072,"He wouldn't."],[14485,14552,"Code blue!"],[14593,14677,"Code blue!"]],"2":[[342,502,"Welcome back, Emily."],[663,717,"My phone!"],[717,850,"Give me my phone!"],[850,976,"He wouldn't do this to me."],[976,1051,"He wouldn't..."],[1051,1151,"Luke."],[1313,1509,"Luke."],[1509,1597,"Hey, it's Luke."],[1597,1814,"Leave it after the beep."],[1814,1905,"No..."],[2047,2208,"No, this isn't real!"],[2208,2340,"This isn't him."],[3445,3657,"You know I love you, but..."],[3657,3920,"Seriously, how do you feel about this?"],[4225,4347,"Well..."],[4521,4648,"The old Emily..."],[4871,5090,"The one whose husband vanished"],[5105,5442,"and divorced her after a car crash."],[5442,5693,"Well, she flatlined for three minutes anyway."],[5818,5915,"This Emily..."],[6089,6232,"She doesn't feel a thing."],[6356,6584,"Nope. I'm single."],[6681,6799,"I can walk."],[7011,7180,"And I've got a plane to catch."],[7344,7550,"I'm writing that travel piece, Boss Lady."],[7550,7674,"Aren't you thrilled?"],[7795,7896,"Thrilled?"],[8003,8135,"Terrified?"],[8241,8355,"It's hard to tell the difference"],[8355,8449,"these days."],[8521,8596,"Yeah."],[10105,10260,"I am going to write."],[10281,10487,"But I'm also going to find him."],[10514,10650,"I deserve closure."],[11703,11943,"I don't see a ring on her finger."],[12120,12275,"Hey, beautiful."],[12474,12583,"A beauty like you,"],[12583,12830,"belongs in a beautiful place like this."],[13054,13184,"Would you do us the honor of"],[13184,13388,"coming to our feast?"],[13682,13788,"Sorry."]],"3":[[165,277,"Luke! Is that you?"],[600,867,"Let's meet at the fortress."],[867,1071,"Alright."],[1205,1359,"What fortress?"],[1359,1443,"Excuse me."],[1443,1512,"—Oh. —It's okay."],[1512,1609,"I am American."],[1609,1751,"Oh, fantastic."],[1751,1816,"Do you know anything of"],[1816,1892,"a fortress?"],[1892,2168,"Like is it a restaurant or a bar?"],[2168,2293,"Or...?"],[2293,2419,"You look like a nice girl."],[2506,2660,"It's best to stay away, miss."]],"4":[[530,658,"American girl."],[775,1029,"You blew me off for the dungeon, huh?"],[1103,1220,"I know what it is."],[2018,2190,"Spicy, huh?"],[2300,2480,"It's hard to get in, though."],[2681,2927,"Why, is it like invite only or something?"],[2927,3001,"Do you know where it is?"],[3001,3036,"Can you take me-"],[3036,3241,"Sure, I'll tell you more, but..."],[3257,3399,"You've got to..."],[3425,3514,"Hah."],[3549,3764,"American money is very good."],[3768,3840,"Come on."],[3913,4046,"I'm not giving you money."],[4208,4312,"What about a kiss?"],[4529,4646,"What the hell!"],[4708,4775,"Bitch!"]],"5":[[304,817,"Okay, wow, this place is..."],[817,979,"something else."],[1463,1685,"It's hard to get in, though."],[1839,1950,"Greasy asshole,"],[1950,2128,"at least he was good for one thing."],[3620,3762,"There's a new recruit?"],[4066,4200,"Seems like it."],[4250,4357,"But it's the off season,"],[4357,4533,"and she hasn't been invited."],[4888,5023,"Mario, clean up the basement."],[5238,5430,"Dead body involving, or-"],[5601,5714,"What do you think?"],[6402,6535,"I'm sorry, Master."],[6631,6781,"I was just checking on the feed."],[6856,6952,"Looks like a new recruit"],[6952,7178,"has shown up at the gate."],[7178,7292,"I'll handle it."],[7328,7557,"Good, you know what to do."],[10462,10560,"Is anybody there?"],[10791,10893,"Ciao."]],"6":[[66,288,"#Oh, Jesus. You scared me.#"],[370,530,"So, where did you just come?"],[579,750,"You should know that"],[829,1046,"bad things happen to good girls"],[1046,1188,"who come uninvited."],[1384,1697,"Lucky for you, I like good girls"],[1697,1972,"and I am feeling generous tonight."],[1972,2135,"Okay, okay."],[2135,2270,"What the fuck?"],[2270,2419,"Did you just put a leash on me?"],[2640,2894,"I'm going to take you to the master now."],[3032,3234,"Maybe you'll become one of us soon."]],"7":[[287,410,"This is the girl who broke in."],[482,606,"She has potential."],[633,779,"I'd like to give her a trial."],[812,945,"Why do you think I'm here?"],[1005,1076,"Do it."],[1121,1251,"Don't waste my time."],[1459,1643,"Is that really replacing ice cream?"],[1643,1801,"Babe, you have a little-"],[3357,3436,"Emily?"],[3436,3495,"Fuck!"],[3495,3595,"You shouldn't be here."],[3595,3707,"Why the hell did you come here?"]],"8":[[37,104,"Emily?"],[104,208,"Fuck!"],[208,342,"You shouldn't be here."],[342,538,"Why the hell did you come here?"],[738,840,"Let's go."],[1151,1247,"Wait, wait."],[1247,1334,"Get her out of here."],[1334,1466,"She's not suited for the trials."],[1466,1598,"What, because she slapped you?"],[1738,1960,"Did you just fucking lock me in?"],[2027,2179,"She doesn't belong here."],[2179,2336,"No, I would argue that that's exactly"],[2336,2404,"why she does."],[2404,2579,"I said no."],[2627,2866,"This is my dungeon, remember?"],[2982,3090,"Yes, of course, Master."],[3090,3182,"And so you should know"],[3182,3286,"better than anyone"],[3286,3521,"that rules are rules."],[3607,3736,"She found us."],[3795,3980,"She's seen what's been going on here."],[3980,4081,"And so if we don't put her"],[4081,4227,"through the trials, we'll have to..."],[4558,4688,"Am I right, Mario?"],[4697,4854,"Would be a shame to lose"],[4854,5009,"a pretty one like that."],[5080,5180,"Let me out!"],[5251,5421,"Did you lock the door?"],[5459,5640,"Please, get back here"],[5826,5885,"Just..."],[6131,6227,"Fine."],[6293,6436,"I'll conduct the trials."],[6450,6624,"You two, back to the office."],[6769,6861,"Go."],[7107,7157,"Hey!"],[7157,7337,"Open this damn-"]],"9":[[54,141,"Hey!"],[141,296,"Open this damn-"],[1818,2060,"What the hell, Luke?"],[2193,2312,"So, you really are here,"],[2312,2460,"in some remote town"],[2460,2652,"in fucking Italy right now,"],[2652,2806,"running a goddamn dungeon"],[2806,2898,"of all things?"],[2898,3161,"What, what, what is this?"],[3161,3289,"What are these fucking trials?"],[3289,3367,"What is this place?"],[3367,3495,"What-"],[3670,3782,"No, fuck that."],[3782,3966,"Why did you leave me?"],[4220,4455,"I almost died."],[4475,4594,"And you left me there"],[4594,4700,"in that hospital bed"],[4700,4917,"when I could barely fucking breathe."],[4917,5138,"How could you do that to me?"],[5313,5480,"Now! Say something!"],[5951,6062,"You must've mistaken me"],[6062,6169,"for someone else."],[6318,6523,"Congratulations on getting in here."],[6635,6752,"In order to be accepted"],[6752,6822,"into the dungeon,"],[6822,7008,"you have to pass a series of tests."],[7057,7186,"The trials of desire."],[7323,7525,"What kind of sick joke is this, Luke?"],[7716,7827,"Luke?"],[7907,8044,"I don't know who that is."],[8103,8358,"I'm Lucien, the master."],[8546,8712,"I don't believe this."],[8904,9072,"There's no turning back now."],[9576,9674,"Fine."],[9674,9738,"You know what?"],[9738,9797,"I'll call you whatever"],[9797,9900,"you want me to call you."],[9918,10052,"Lucien? Yeah, sure."],[10052,10173,"Master?"],[10201,10343,"Sure."],[10467,10583,"You wanna play?"],[10585,10723,"Let's fucking play."],[10723,10840,"What's the first trial?"],[10877,10994,"No more talking."],[11051,11154,"May I?"]],"10":[[70,415,"The first trial is blind devotion."],[746,1202,"This trial tests your restraint."],[1242,1373,"No sight."],[1472,1613,"Only sound."],[1730,1855,"Only touch."],[3150,3251,"Where are you?"],[3294,3403,"Shh."],[5905,6018,"What are you doing?"],[6018,6127,"Don't move."],[6214,6343,"Just feel."],[7111,7411,"This trial tests your ability to stay still."],[7766,7933,"To stay silent."],[8120,8525,"Even when your body, your mind,"],[8525,8748,"and your heart wanna betray you."],[8903,9044,"No matter what."]],"11":[[50,153,"Good."],[333,501,"Keep staying still."],[838,1155,"Keep restraining."],[2165,2235,"Luke-"],[2235,2340,"Lucian, did I..."],[2969,3319,"What in the actual fuck?"],[3923,4025,"I told you."],[4048,4169,"She doesn't belong here."],[4245,4375,"Get her out of here."],[4387,4471,"Now."],[5980,6136,"You moved."],[6250,6402,"It means you failed the trial."],[6490,6639,"But I was right about you."],[6735,6898,"The Master sees it too now."],[6998,7123,"You have real potential."]],"12":[[40,149,"Hey, it's okay."],[162,313,"You held up longer than most."],[396,533,"You'll get it next time."],[580,798,"Why would I want to get it?"],[900,1057,"For what? A trophy?"],[1126,1341,"What are you freaks doing in here?"],[1488,1601,"I like you."],[1668,1776,"Yeah, you've said that before."],[1776,1856,"Right before you put"],[1856,1953,"a fucking leash on me."],[1953,2056,"We should be friends."],[2056,2177,"What?"],[2235,2469,"You're so weird. Why?"],[2656,2781,"God, why would I even ask?"],[2781,2936,"This place is insane."],[3411,3509,"Okay."],[3607,3738,"You wanna be friends?"],[3870,4009,"Then tell me what the hell"],[4009,4165,"is going on here."],[4833,4932,"Better?"],[5092,5209,"Not even close."],[5209,5285,"For what it's worth,"],[5285,5458,"you sought us out. You came here."],[5463,5630,"I was trying to..."],[5960,6112,"I don't even know what I was trying to do."],[6385,6526,"What is this place?"],[6560,6625,"These trials,"],[6625,6843,"what are they for? And..."],[6945,7055,"Lucian,"],[7190,7275,"Who is he?"],[7275,7407,"What's his last name?"],[7407,7537,"Do you work for him?"],[7537,7653,"How long has he been here?"],[7832,8013,"Even more reason for you to stay..."],[8083,8287,"But hey, as your friend,"],[8370,8541,"I just want you to know that"],[8541,8632,"you are free"],[8632,8876,"to leave at any time."],[8958,9143,"That's not what I asked."],[9154,9315,"It's all I can answer."],[9701,9843,"Hey. It's okay."],[9947,10039,"I'm not going to do anything."],[10039,10154,"I just want help you up."],[10477,10589,"It's late."],[10685,10922,"So, if you'd like to stay for the retrial,"],[11111,11330,"and learn more about the master,"],[11461,11639,"you can follow me to your chambers."],[11778,11839,"Come on."],[11878,11970,"We've prepared a fresh"],[11970,12092,"changes of clothes for you."],[15390,15506,"Good night, Emily."],[15615,15757,"Maybe I'll see you tomorrow."],[15920,16125,"You can also exit out that door."],[16370,16533,"Wait, how do you know me name?"]],"13":[[20,175,"Secret Fortress,"],[175,422,"weird underground trials,"],[462,1084,"cryptic messages, and you, my friend."],[1167,1522,"Jonah, with a name so unbashfully biblical,"],[1522,1784,"showing me a secret garden"],[1835,1923,"and pool."],[2093,2227,"Well, you make it sound weirder"],[2227,2369,"than it actually is."],[2452,2610,"Yeah, I don't think that's possible."],[2727,2895,"Okay, so I know you can't"],[2895,3136,"outright answer me my questions."],[3136,3424,"So, what about"],[3424,3528,"a game of yes or no?"],[3528,3654,"You know that game, right?"],[3958,4162,"Okay."],[4162,4321,"Is this a sex cult?"],[4340,4513,"And is Lucian your leader?"],[4921,5017,"Oh, come on!"],[5017,5176,"You totally look like you're here"],[5176,5287,"against your will."],[5380,5509,"Fake smiles"],[5509,5680,"never actually reach your eyes."],[5970,6113,"Unfortunately, not."],[6256,6377,"Would you like to try again?"],[6460,6564,"Yeah."],[6981,7082,"Wait."],[7269,7369,"Is that a..."],[7369,7494,"gunshot wound?"],[7640,7702,"Yes."],[7807,7955,"I got it here a while ago."],[8149,8233,"Here?"],[8350,8438,"Here."],[8596,8717,"Was it him?"],[10164,10305,"It's time for your retrial."]],"14":[[258,367,"Yeah, yeah, I know,"],[367,546,"no moving, no talking."],[546,717,"Right?"],[717,929,"What do I get when I pass the trials?"],[959,1071,"Candy? A trophy?"],[1071,1255,"A chance to be your god?"],[1255,1451,"More trials."],[1451,1690,"Until you're accepted by the dungeon."],[1710,1874,"Yeah, except I don't particularly care"],[1874,2002,"about the dungeon."],[2189,2369,"How about I name my price, yeah?"],[2448,2610,"How about your life story?"],[2777,2857,"While we're at it,"],[2857,3019,"why does Jonah has a gunshot wound"],[3019,3120,"at his abdoment?"],[3286,3490,"Sorry, Master."],[3490,3641,"I talked too much."],[3653,3770,"Open."],[7182,7340,"Much stronger than yesterday."],[8808,8979,"Tough."],[8979,9128,"As you've always been."]],"15":[[129,262,"What did you just say?"],[579,800,"I said you've passed the trials."],[800,907,"No, no, you just said"],[907,1055,"as you've always been."],[1055,1164,"I meant the royal,"],[1164,1305,"you as in people like you"],[1305,1380,"—No. —who come here."],[1380,1499,"No, you did not."],[1499,1693,"That was not generic. That was..."],[1693,1897,"That was personal."],[1897,2093,"Many women come here"],[2093,2260,"to learn, to train."],[2298,2439,"You're not special."],[2473,2619,"Great, so this is what gets you off?"],[2619,2777,"How many women have you brought here?"],[2777,2855,"Are you bragging about"],[2855,2940,"that right now?"],[3078,3194,"This turn you on?"],[3235,3308,"Hmm?"],[3328,3582,"Watching us squirm? Hearing us beg?"],[3699,3978,"God! I'm so stupid. You're not my Luke."],[3978,4063,"You're nothing like him."],[4063,4166,"You're just some S&M"],[4166,4308,"fanatic playing god."],[4308,4408,"I'm such an idiot,"],[4408,4583,"This is a cult, I knew it."],[5434,5680,"How did you handle the heat so well?"],[6085,6235,"I was in a car crash."],[6385,6504,"Flipped twice in a mountain road."],[6504,6715,"Do you have any idea how hot"],[6715,6873,"a recked car gets?"]],"16":[[0,191,"I was in a car crash."],[296,429,"Flipped twice in a mountain road."],[429,631,"Do you have any idea how hot"],[631,767,"a recked car gets?"],[2652,2749,"Sir?"],[2811,3011,"How is her trial going?"],[3144,3294,"Don't you have work to do?"],[3399,3575,"Also, since when does one recruit"],[3575,3703,"matters so much?"],[4191,4378,"It's going fine, Mario!"],[5551,5661,"Sign it."],[5663,5809,"Sever the tie."],[5809,5943,"Come with us to Italy,"],[6022,6206,"or she dies."],[6206,6402,"One way or another."]],"17":[[95,166,"Maya!"],[166,529,"Hey, you are never going to believe"],[529,704,"where I am right now."],[788,1101,"I am in a literal fortress."],[1101,1205,"Like, I mean there's"],[1205,1359,"stone walls everywhere."],[1359,1555,"Cryptic codes, everything,"],[1555,1659,"the whole thing."],[1659,1972,"It's a sex cult, I think."],[2064,2206,"Maybe."],[2206,2337,"Oh!"],[2460,2736,"Cults are very topical."],[2794,2894,"I mean, hey,"],[2894,3103,"I'm just glad Italy’s inspiring you."],[3103,3328,"I mean, these pages you sent over?"],[3328,3424,"Fire!"],[3424,3586,"Yeah. Fire."],[3586,3699,"Ropes."],[3699,3782,"Torture."],[3782,3899,"Well, whatever it is,"],[3899,4037,"keep channeling it."],[4133,4362,"And hey, I'm really proud of you."],[4388,4458,"Sounds like"],[4458,4692,"you're finally getting over Luke."],[4884,5009,"I'm not over him,"],[5009,5150,"not even close."],[5326,5463,"Day..."],[5463,5584,"Whatever,"],[5584,5860,"this so-called dungeon is beautiful,"],[5860,6093,"and terrifying."],[6093,6258,"Like, the sun never touches"],[6258,6456,"the truth here."],[6456,6681,"The master, Lucian."],[6744,6898,"He wears Luke's face."],[6898,7108,"But he's not my Luke."],[7123,7261,"My Luke made me laugh with"],[7261,7574,"cold kisses and hot pad Thai."],[7574,7873,"He burns you on purpose."],[8012,8149,"As if the car crash,"],[8149,8307,"the ICU,"],[8337,8483,"the signed divorce papers"],[8483,8650,"weren't enough."],[8650,8913,"My life just wants to play a joke on me."],[9142,9334,"What did I do to deserve this?"],[10860,10950,"Hi."],[10985,11069,"Hey."],[11148,11282,"I brought you some clothes."],[11586,11740,"Thank you."],[11870,11997,"Jonah, wait."],[12149,12395,"Thank you so much for being so kind."],[12395,12466,"It's nice to have a"],[12466,12629,"good friendly face here."],[12658,12796,"Sure."],[12796,12942,"Of course."]],"18":[[1051,1168,"What the hell were you doing"],[1168,1299,"in her room at this hour?"],[1334,1492,"I was delivering clothes to her."],[1492,1600,"Because you burned holes"],[1600,1726,"in the last set."],[1931,2097,"She's mine to handle,"],[2097,2348,"did I not make myself clear?"],[2348,2456,"You did."],[2494,2690,"You're always unclear."],[2690,2863,"Stay the fuck away from her."],[2907,3032,"She's mine."]],"19":[[79,229,"She's mine..."],[325,475,"to train."],[475,700,"You and everyone else stay away,"],[700,840,"that includes Mario and every other"],[840,1024,"asshole with a gun strapped to them."],[1051,1223,"I will not repeat myself."],[1280,1434,"Understood, Master."],[1497,1597,"Good."],[5935,6147,"I had it under control."],[6385,6548,"I buried it."]],"20":[[83,179,"You cry every full moon,"],[179,371,"or is this just a one time thing?"],[771,975,"You speak when you're spoken to."],[1121,1222,"You know what?"],[1309,1409,"You want answers?"],[1443,1551,"Fine."],[1609,1785,"Pass the next trial."],[1785,1943,"I'll give you one question,"],[1943,2131,"and one real answer."],[5951,6114,"The trial of honesty."],[6335,6544,"Strip away the exterior"],[6719,6881,"and reveal what's hidden"],[6948,7107,"layer"],[7107,7203,"by layer."],[7361,7428,"But, with each one"],[7428,7536,"you remove..."],[7753,7899,"I'll take one from you."],[8199,8405,"The naked truth"],[8425,8583,"isn't for the weak."]],"21":[[1117,1207,"Good."],[1526,1609,"Now let's see"],[1609,1826,"if you'll let me take one from you."],[4525,4708,"Revealing"],[4708,4929,"is easier said than done,"],[5125,5271,"isn't that right, Emily?"]],"22":[[2952,3180,"Honesty goes both ways."],[3278,3397,"Remember that."],[7260,7383,"One more."]],"23":[[137,271,"No."],[435,581,"Well then."],[700,888,"You failed the trial."],[888,1118,"No question and no answer for you."],[1180,1338,"Give me another one."],[1465,1582,"Excuse me."],[1639,1757,"Test me again."],[2006,2077,"You said it yourself."],[2077,2223,"Honesty goes both ways."],[2223,2339,"So, give me a trial"],[2339,2519,"or you have to participate too."],[2656,2771,"It's only fair considering"],[2771,2919,"the reward at the end."],[3062,3155,"Mm."],[3261,3345,"Alright."],[3453,3566,"Tomorrow."],[3636,3757,"Game on."],[3845,3940,"Great."],[3999,4125,"Turn around."]],"24":[[1153,1246,"See?"],[1413,1550,"I'm not afraid."],[6740,6851,"Alright."],[7006,7136,"There's one rule."],[7248,7378,"Stay afloat."],[7436,7523,"That's it?"],[7523,7653,"Like I can't swim?"]],"25":[[212,258,"Wow."],[258,337,"Okay."],[400,487,"Harsh."],[734,812,"Your turn."],[1572,1672,"You want more?"],[1776,1876,"More?"]],"26":[[604,759,"—More? —Mm-hmm."],[804,871,"Wow."],[871,950,"You don't quit."],[1021,1142,"Damn right I don't."],[1176,1267,"This time it's not going to be"],[1267,1413,"the woman who gets in first."],[3545,3624,"Oh, shit."],[3624,3712,"Ems?"],[3712,3791,"Ems!"],[3791,3853,"Hey."],[3991,4074,"Stay with me."],[4074,4116,"Hey."],[4145,4229,"You're okay."],[4229,4341,"You're okay."]],"27":[[54,108,"Hey!"],[108,205,"Babe! Hey!"],[266,371,"Wake up!"],[371,448,"Wake up!"],[871,934,"Hey!"],[934,1050,"Hey, baby."],[1376,1468,"You're the reason I breathe."],[1468,1543,"Come on."],[1543,1730,"You need to wake up right now."],[1730,1835,"Please."],[2478,2677,"Oh, Lucien, you're really psycho."],[2731,2823,"You—"],[2940,3133,"You just tried to kill me?"],[3203,3299,"No."],[3457,3591,"You—"],[3591,3749,"You pass the trial."],[3853,4024,"You can now ask me one question,"],[4024,4262,"and I'll give you one truthful answer,"],[4262,4396,"as promised."],[4396,4604,"What is this place?"],[4657,4772,"Lucian."]],"28":[[508,755,"You have to tell me the truth."],[775,888,"Everything."],[888,959,"Now."],[959,1243,"No one leaves here, Emily."],[1263,1368,"Not really."],[1422,1534,"What are you talking about?"],[1534,1664,"This fortress,"],[1664,1730,"the Dungeon,"],[1730,1872,"the trails,"],[1872,1964,"the estate."],[1964,2097,"It's all a front."],[2097,2227,"Run by the gang."],[2348,2531,"I'm a part of it although I..."],[2531,2656,"I didn't want to be."],[2656,2846,"But I have no other choice."],[2932,3107,"Lucian's in charge now."],[3211,3307,"And he took over"],[3307,3428,"when the old boss got too sick."],[3428,3566,"But the system?"],[3566,3724,"that's been in place for years."],[3795,4108,"What is this system?"],[4108,4196,"Conditioning."],[4266,4409,"They don't call it that of course."],[4409,4504,"They call it"],[4504,4604,"initiation,"],[4604,4721,"transformation,"],[4721,4813,"enlightenment."],[4813,4909,"But it's training."],[4909,5042,"To break it down,"],[5042,5192,"To mold you into what they need."],[5292,5434,"Which is?"],[5434,5601,"High end escorts."],[5601,5730,"Emily, you are not"],[5730,5843,"playing a game here."],[5843,5993,"You were being broken down."],[5993,6093,"You're being measured."],[6093,6181,"Shaped."],[6181,6256,"Tested."],[6384,6564,"Eventually, you will be for sale."]],"29":[[91,175,"You're lying."],[175,282,"I wish I was."],[740,835,"Come with me."],[2040,2187,"Eat something, please."],[2619,2802,"Lucian hasn't always been here,"],[2802,2882,"right?"],[2882,3040,"You said he just took over."],[3069,3250,"He didn't build this."],[3303,3420,"Maybe he hates it, too."],[3420,3511,"Emily."],[3628,3716,"Look,"],[3716,3903,"I don't know his history."],[3903,3980,"I wasn't here long"],[3980,4154,"before he was, but..."],[4154,4271,"He owns it."],[4291,4400,"He runs it now."],[4400,4475,"Even Mario,"],[4475,4571,"the second in command,"],[4571,4708,"answers to him."]],"30":[[429,492,"Maya?"],[492,638,"Hey, this is not"],[638,834,"that weird sex cult story"],[834,914,"that I told you before."],[914,1034,"This is real"],[1034,1126,"shit"],[1126,1288,"going on here."],[1288,1355,"When,"],[1355,1476,"When,"],[1476,1618,"and when he said the season,"],[1618,1734,"whatever that means, starts,"],[1734,2002,"there will be real girls here."],[2002,2143,"They're going to be trained,"],[2143,2377,"and they're going to be priced."],[2523,2615,"They're going to be sold."],[2615,2719,"Maya, this is..."],[2719,2961,"this is a sex trafficking ring."],[3812,3974,"What the hell is wrong with me?"]],"31":[[5970,6075,"Emily."],[6218,6383,"Being a little curious now."],[6383,6467,"Are we?"],[6564,6668,"Sorry."],[6706,6817,"We've got to go back."],[6877,6994,"So, everybody just knows"],[6994,7099,"my name around here, huh?"],[7127,7298,"Well,"],[7298,7478,"you're the master's favorite."],[7582,7643,"Let's go."],[7778,7893,"Was the gun necessary?"],[7893,8012,"—Go! —Okay."],[9791,9892,"Where were you?"],[10072,10250,"I was just..."],[10335,10485,"Just walking around."],[10485,10553,"That's all."],[10604,10713,"Well, it's time."],[10774,10969,"Your final trial."]],"32":[[467,596,"Are you afraid of me?"],[596,717,"Emily?"],[717,796,"What changed?"],[796,938,"You weren't afraid of me last night."],[1101,1238,"You know, I saw you."],[1384,1514,"You were with Jonah."],[1668,1785,"What did he tell you?"],[1993,2077,"Nothing."],[2181,2310,"I'm still not afraid of you."],[2310,2385,"Final trial."],[2385,2444,"Right?"],[2598,2681,"Let's do it!"],[2777,2871,"I'll get some more answers"],[2871,2939,"by the time I'm done..."],[2939,3003,"Won't I?"],[3111,3213,"You certainly will."],[6389,6539,"This trial test..."],[6594,6774,"When you're under the influence,"],[6774,6956,"when you're under pressure,"],[6956,7084,"and when even your eye"],[7084,7185,"may deceives you."],[7194,7385,"You still find yourself."]],"33":[[83,262,"I get it now."],[262,540,"The goal is to turn us into party girls."],[608,742,"Makes sense that the final trial"],[742,1015,"is to have a party for two."],[1088,1201,"How romantic."],[1776,1826,"No!"],[2131,2248,"No."],[2248,2306,"Nope."],[2306,2398,"No."],[2398,2531,"He's not Luke."],[2531,2666,"He's a criminal,"],[2666,2763,"a liar,"],[2763,2905,"a trafficker!"],[2969,3082,"No."],[3770,3899,"What are you doing?"],[5655,5764,"What was that?"],[7453,7607,"Let's party."]],"34":[[75,187,"Why are you participating"],[187,304,"in this with me?"],[454,583,"Do you have something to prove?"],[621,704,"Master."],[763,867,"You said it."],[867,1117,"This trial should be for both of us."],[1117,1397,"You are my last test."],[2610,2784,"If I fail the trial,"],[2894,3019,"where will you sell me?"],[3628,3739,"Am I failing right now..."],[3739,3853,"Or am I passing?"],[3853,3958,"Shhh."]],"35":[[5286,5409,"Emily."],[5651,5951,"I tried to kill him."],[6006,6060,"To kill"],[6060,6265,"the best version of myself."],[6318,6443,"What are you saying?"],[6631,6773,"What is that version of you?"],[6998,7269,"I'm so sorry. Ems."],[7628,7686,"Luke!?"]],"36":[[33,133,"Don't you touch me!"],[166,233,"Of course,"],[233,384,"of course I was drawn to you."],[384,521,"You were him. My husband."],[521,579,"And you lied."],[579,842,"Pretending to be this perfect stranger."],[871,992,"—Ems, please- —Fuck!"],[992,1167,"Do not call me that right now."],[1167,1310,"You knew who I was this whole time."],[1310,1355,"You fucking..."],[1355,1485,"You left me there to die."],[1485,1600,"—I could- —No, you don't even-"],[1600,1666,"Just leave me."],[1666,1789,"You became this,"],[1789,1938,"this trafficker."],[1938,2189,"Criminal, fucking mafia leader."],[2189,2302,"God! Why did you-"],[2302,2418,"Why would you do that to me?"],[2418,2484,"Why?"],[2484,2553,"Why would you move to"],[2553,2637,"America with me?"],[2637,2754,"Why started a family with me?"],[2754,2928,"Why would you make me love you"],[2928,3095,"and then just leave me there?"],[3186,3403,"I meant it do not touch me!"],[3403,3516,"—Ems. —Stop!"],[3516,3611,"Ems!"],[3657,3737,"Ems!"]],"37":[[187,246,"Whoa!"],[246,307,"Oh, hey!"],[307,433,"Hey, Emily!"],[487,575,"Emily, is everything okay?"],[775,911,"The other girls being trained here."],[911,996,"Are they still alive?"],[1030,1172,"Yes, they're alive, but..."],[1280,1355,"they're not here anymore."],[1355,1468,"Emily, are you okay?"],[1580,1703,"Did Lucian do something to you?"],[1747,1910,"I gotta get out of here."],[2214,2327,"Look at me."],[2327,2523,"We'll try. We will try, okay?"],[2523,2619,"There's a back way."],[2702,2777,"Mario and the guard"],[2777,2852,"won't be looking there."],[2898,3007,"We'll try"],[3007,3121,"tomorrow morning, 5:30."],[3121,3165,"Okay?"],[3336,3382,"Okay."],[3470,3526,"Let's go."]],"38":[[4567,4729,"I'm sorry, Emily."],[5042,5183,"So sorry."],[5250,5389,"So sorry."],[5458,5581,"So sorry."]],"39":[[742,838,"Emily."],[2047,2135,"Hey!"],[2318,2375,"I know"],[2375,2473,"you two had history,"],[2473,2615,"but you did the right thing."],[2615,2773,"Leaving there."],[2773,2902,"Leaving him."],[2902,3069,"Tell me everything you know about him."],[3190,3269,"Please."],[3349,3700,"No lies, no leaving anything out."],[3766,3924,"Lucian wasn't always in charge."],[3991,4222,"My father used to run the network."],[4316,4462,"I know, I"],[4462,4621,"should've told you before,"],[4621,4744,"but you know, the dungeon"],[4744,4896,"wasn't what it is now."],[5055,5217,"It was brutal."],[5217,5392,"It was sort of like a torture chamber,"],[5392,5455,"as you put it."],[5455,5613,"But it had rules"],[5693,5839,"like a purpose."],[5839,6014,"We punished traffickers"],[6014,6131,"and smugglers here."],[6131,6448,"That's how my father made money."],[6448,6719,"Justice, twisted maybe,"],[6719,6881,"but we had a code."],[6881,6967,"But everything changed"],[6967,7057,"when Lucian took over."],[7057,7165,"When my father fell ill."],[7165,7340,"I mean, he changed everything"],[7340,7620,"and twisted the system into-"],[7620,7741,"and everybody"],[7741,7874,"who was trained by my father,"],[7874,8083,"we hate what it's become,"],[8083,8197,"but we can't change it."],[8197,8327,"We can't tell him to do anything"],[8327,8429,"about that because he..."],[8558,8637,"he kills."],[8904,9025,"We've all seen it."],[9288,9401,"I married him."],[9597,9711,"I slept by him."],[9711,9939,"I loved him, and I just never-"],[9939,10033,"I never knew him at all."],[10033,10122,"So..."],[10281,10357,"Fuck!"],[10390,10453,"Emily."],[10502,10689,"You can't put that on yourself, okay?"],[10689,10831,"I mean, he's..."],[10831,10981,"He's a good pretender, okay?"],[10981,11127,"He fooled everybody."],[11277,11382,"Emily, look,"],[11382,11665,"I didn't wanna tell you this"],[11665,11832,"like this, but..."],[11953,12124,"I've been falling for you."],[12295,12420,"And I have since the moment"],[12420,12541,"you entered this room."],[13717,13809,"Of course you did."],[14260,14397,"That's the thing about traitors,"],[14397,14460,"Jonah."],[14560,14696,"They fall hard."]],"40":[[140,214,"No. No!"],[362,446,"Really?"],[508,571,"What? You think"],[571,742,"you're the fucking hero now, Jonah?"],[1017,1159,"Ems, you were gonna leave without..."],[1267,1418,"Without saying goodbye to me at all?"],[1418,1493,"Did you?"],[1589,1678,"When you left?"],[1780,1893,"Just give me five minutes"],[1893,1939,"and I'll explain-"],[1939,2018,"No, no."],[2018,2178,"I don't need you to explain anything."],[2178,2293,"You've explained enough."],[2323,2469,"Every lie that you've told me"],[2469,2654,"explained pretty well who you are."],[2654,2815,"Every time that you locked"],[2815,2892,"a woman away"],[2892,3080,"and you priced her like meat."],[3090,3186,"That explained things"],[3186,3270,"pretty damn clear."],[3282,3332,"No, Ems, please!"],[3332,3592,"Lucian, do not call her that."],[3616,3666,"Fuck!"],[3666,3733,"Whoa, whoa!"],[3733,3795,"Hey! Hey!"],[3835,3900,"What-"],[3958,4100,"Seriously?"],[4112,4160,"All of this."],[4160,4320,"Now you're a murderer of our two?"],[4320,4496,"That's you are gonna be."],[4496,4651,"Murderer?"],[4671,4870,"What? Is that way he told you?"],[4957,5040,"Oh."],[5083,5234,"Emily,"],[5234,5292,"please!"],[5292,5414,"I was goinna save you."],[5414,5529,"I was never going to hurt you!"],[5529,5599,"No, you weren't."],[5599,5723,"You were just gonna make it harder"],[5723,5889,"and harder for me to leave, right?"],[6031,6118,"Right."],[6306,6408,"Fine. Yeah."],[6408,6468,"You know,"],[6523,6631,"you love her."],[6631,6861,"You care about her just a little bit."],[6861,6986,"Protect her."],[6986,7102,"You both know what I mean."],[7223,7340,"If you keep her safe,"],[7440,7620,"I'll leave all of this behind."],[7620,7703,"The fortress,"],[7703,7862,"everything."],[7862,7962,"Deal?"]],"41":[[583,696,"Deal."],[1247,1468,"I don't expect you to"],[1468,1576,"forgive me,"],[1576,1744,"talk to me or even look at me."],[1935,2102,"But if you want my"],[2102,2268,"side of the story,"],[2268,2402,"my truth,"],[2402,2565,"you know where to find me."],[4416,4521,"Thank you for giving me"],[4521,4637,"the window to escape."],[4704,4925,"Anything for the real prince."],[4946,5040,"And now?"],[5155,5297,"We take the dungeon back"],[5359,5422,"and"],[5422,5601,"we'll him."],[5601,5739,"As you should, boy."],[6694,6790,"Sign it."]],"42":[[425,529,"Emily."],[600,654,"You came back."],[654,685,"No."],[685,763,"No, please."],[763,817,"Hey!"],[817,880,"Please."],[1201,1317,"Luke, I came here to warn you."],[1343,1409,"Okay?"],[1459,1534,"And that's it."],[1534,1659,"And then we're done."],[1659,1768,"I'm getting the hell out of this"],[1768,1881,"fucking country."],[1881,1918,"And you,"],[1918,2068,"I never want to see you again."],[2068,2156,"Got it?"],[2193,2268,"Yeah."],[2352,2548,"Jonah's not keeping his end of the deal."],[2548,2619,"Helping me escape"],[2619,2744,"was some sort of stage thing,"],[2744,2806,"I guess."],[2806,2865,"I don't know,"],[2865,3019,"I don't really care about your bullshit"],[3019,3153,"game politics,"],[3182,3328,"but I thought you should know."],[3328,3428,"He's coming"],[3553,3653,"to kill you."],[4479,4583,"Jonah was there"],[4583,4646,"at the crash."],[4646,4746,"Wh-"],[4746,4859,"What's going on?"],[4900,4950,"I'll tell you,"],[4950,5009,"come on."]],"43":[[563,740,"Thought I saw something move."],[819,950,"Maybe just an animal."],[1096,1183,"Doesn't matter."],[1534,1624,"Let's go."],[3224,3296,"Wow."],[3545,3677,"What is this place?"],[3737,3862,"It's..."],[3862,4183,"a hidden part of the forteresce."],[6448,6548,"Jonah said that they were"],[6548,6720,"just a vigilante gang."],[6781,6873,"And you turned it into"],[6873,7061,"a human sex trafficking ring."],[7061,7127,"Why?"],[7127,7232,"Why would he say that?"],[7232,7419,"And also, why was he at the crash?"],[7419,7570,"I don't..."]],"44":[[315,418,"Hey, Dad."],[546,690,"I think we might be fucked."],[746,829,"There's a reporter."],[829,971,"Whatever he is, he's on to us."],[971,1130,"And we need to act quickly."],[1251,1363,"Calm down."],[1685,1820,"Could be a story."],[1837,1967,"They can't trace it to us."],[1967,2093,"Yes, I think they can."],[2093,2199,"Just listen to this."],[2331,2419,"Three shell companies,"],[2419,2498,"all routed through"],[2498,2644,"arts foundation in Rome."],[2669,2765,"Fake scholarships,"],[2765,2886,"fake modeling contracts."],[2886,2982,"But,"],[2982,3061,"none of these women"],[3061,3215,"ever show up in the States again."],[3307,3407,"It's a mafia operation."],[3407,3506,"I'm sure of it."],[3516,3566,"This gang had"],[3566,3657,"the women trafficked,"],[3657,3774,"rebranded and auctioned off"],[3774,3864,"through a training center"],[3864,4016,"in Bomarzo, Italy."],[4283,4421,"Think we're the only ones?"],[4433,4569,"There are thousands!"],[4688,4833,"They'd be chasing their tails for-"],[4833,4929,"Dad, just listen."],[4971,5159,"You got any leads on who's behind it?"],[5159,5288,"Jonah De Luca."],[5288,5376,"He's the face."],[5376,5450,"But"],[5450,5630,"it's his daddy's empire."],[5630,5797,"He's publishing tomorrow."],[5897,6014,"It is a problem."],[6222,6464,"But it's the easiest kind of problem."],[6773,6954,"We kill him before he prints."],[7048,7186,"He's married. His-"],[7328,7458,"His wife will be with him."],[7699,7816,"Collateral."],[8470,8592,"Hi, can I help you?"],[8633,8767,"I'm here to see your husband,"],[8767,8963,"Mr. Cattaneo."],[8963,9067,"Is it Luke?"],[9067,9163,"Right?"],[9163,9250,"Yeah."],[9250,9409,"Yeah. He's not home right now."],[9488,9642,"Do you wanna come inside and wait?"],[9642,9755,"Or should I give him a message?"],[9755,9834,"Mr..."],[9834,9943,"No need."],[10001,10268,"I'm sure we'll meet again very soon."],[10915,11020,"Change of plan."],[11040,11115,"What?"],[11115,11271,"We don't just kill him."],[11271,11390,"We take her,"],[11390,11507,"ship her to the dungeon."],[11628,11761,"She's beautiful."],[11849,12032,"I got a good feeling."],[12145,12241,"She'll fetch a fortune"],[12241,12370,"after we break her in."]],"45":[[8,45,"So..."],[100,246,"So, he wanted to kill you"],[387,525,"and traffic me. But..."],[638,759,"How did you become-"],[759,801,"Do you wanna know"],[801,917,"the whole truth?"],[917,1026,"Yeah."],[1109,1185,"Come with me."],[1255,1384,"When their plan of killing me"],[1384,1514,"and taking you didn't work,"],[1580,1718,"he said he saw something in me."],[1839,1968,"He gave me a choice."],[2027,2185,"Between having you sold,"],[2235,2331,"or giving my story"],[2331,2435,"and my life to them."],[2552,2665,"I chose"],[2665,2786,"you."],[2819,2948,"I became Lucian."],[3123,3278,"I played along."],[3420,3607,"Faked my loyalty."],[3824,3975,"I memorized every route,"],[4079,4233,"every buyer, every name."],[4379,4490,"And I waited."],[4696,4950,"Until your body began to rot."],[5059,5189,"And I saw an opening."],[5434,5546,"You once"],[5593,5826,"ripped the air from my life."],[5905,6064,"Now you get to feel it."],[6352,6423,"Sign it."],[6556,6677,"Name me the heir."],[6702,6773,"Or die"],[6861,6898,"today"],[6898,6994,"or in a few weeks."],[7132,7211,"One way"],[7369,7486,"or another."]],"46":[[9,161,"Jonah was full of shit."],[175,324,"That's what you took over."],[354,553,"It was pretty rotten to begin with."],[742,880,"I couldn't trust anyone."],[938,1132,"Not Jonah, not Mario."],[1132,1213,"None of them."],[1251,1301,"Why didn't you"],[1301,1447,"just blow the whole thing up?"],[1447,1525,"I couldn't,"],[1680,1889,"not with the girls still inside, so I..."],[2014,2145,"I had to find a way to dismantle it"],[2145,2255,"from within."],[2348,2456,"So,"],[2527,2640,"Lucian,"],[2690,2781,"Dungeon Master,"],[2869,2982,"was all fake?"],[3094,3180,"And trials."],[3311,3510,"The props."],[3661,3724,"Coldness."],[3724,3831,"For the most part."],[4012,4142,"And then you showed up."],[4383,4493,"From the second you got there,"],[4493,4612,"I just wanted to yell at you"],[4612,4736,"and tell you to run."],[4929,5034,"But I couldn't."],[5117,5276,"Jonah knew who you were."],[5276,5413,"Mario did too."],[5472,5618,"You were..."],[5618,5843,"kind of my crack in the wall."],[5843,6031,"Only chance, I had to break."],[6110,6210,"But I promise you,"],[6210,6452,"every second that we were there,"],[6481,6594,"we were never safe"],[6594,6686,"in the dungeon."],[6810,7018,"That's why I had to play that character."],[7157,7263,"Emily, I..."],[7465,7620,"I never wanted to lie to you."],[7670,7810,"I never left you."],[8220,8455,"I sacrificed my life to save yours."],[8516,8621,"Ems."],[9509,9563,"Shit."]],"47":[[29,108,"Go, check up there."],[742,796,"Anything?"],[875,975,"I'm sure that's all."],[1017,1092,"There is nobody."],[1222,1280,"Okay."],[1376,1514,"Whoa!"],[1514,1555,"Hey!"],[1601,1701,"Hey!"],[1760,1810,"Hey, Luke."],[1810,1920,"How about you get down here?"],[1989,2022,"Right here."],[2022,2106,"Come on. I won't bite."],[2198,2326,"Stop. Stop..."],[2326,2489,"Lovers reunited, huh?"],[2598,2736,"I got to say, Lucian,"],[2736,2830,"you"],[2915,3057,"are always"],[3057,3250,"so unpredictable."],[3311,3411,"Jonah,"],[3528,3624,"we both know you're not gonna"],[3624,3724,"shoot that gun."],[3778,3866,"You don't think so?"],[4083,4158,"Whoa, whoa, whoa."],[4158,4245,"Hey, hey."],[4629,4708,"Hell boy."],[4875,4963,"Really?"],[5034,5158,"That's everything you're gonna say"],[5158,5262,"with us?"],[5321,5457,"After all the lies?"],[5492,5728,"Oh, like you weren't lying to me"],[5728,5813,"every single day?"],[5918,6082,"Oh, my fake guardian angel"],[6082,6247,"with a smile that never reaches his eyes."],[6448,6552,"You know the deal, Luke."],[6552,6685,"You can't shoot me."],[6748,6931,"Don't do anything fucking stupid."],[7061,7133,"Let's go."],[7655,7720,"Go."],[7761,7805,"Go!"]],"48":[[279,329,"Lucian!"],[412,458,"Lucian!"],[850,955,"Let's go."],[1309,1410,"No! Not there."],[2256,2330,"Oh!"],[3083,3218,"You can't escape."],[3432,3595,"This is my dungeon."],[4012,4102,"Jonah!"],[4629,4788,"For the last fucking time."],[4788,4976,"This is my dungeon!"]],"49":[[25,153,"I'm so sorry to put you through"],[153,271,"all of this."],[383,571,"I grieved you."],[658,763,"I tried with everything"],[763,867,"that I had to forget"],[867,1084,"what it felt like to be yours."],[1096,1192,"Even when I thought that"],[1192,1322,"you were the only."],[1493,1705,"I thought you were a monster."],[1755,1943,"Sadist."],[2068,2264,"My body still craved you."],[2284,2375,"And..."],[2573,2699,"Somehow,"],[2815,3007,"so did my heart."],[3165,3228,"You know,"],[3228,3329,"I thought I could protect you"],[3329,3425,"from all this."],[3624,3823,"Even if it meant you hating me."],[4012,4146,"I still want you to have a chance"],[4146,4270,"at a life."],[4304,4476,"But as soon as you entered,"],[4633,4799,"my walls came down."],[4896,5063,"I tried to hide as much as I could."],[5063,5221,"But no matter how hard I tried,"],[5334,5539,"all I could focus on or"],[5580,5768,"all that I wanted"],[5864,5971,"was you."],[6881,7090,"So, Master,"],[7165,7311,"what are we gonna do"],[7311,7437,"with your new dungeon?"]],"50":[[275,424,"The dungeon was never the enemy."],[437,620,"It was the people who poisoned it."],[675,809,"Now it's ours."],[829,935,"All of it."],[1188,1305,"And don't worry."],[1305,1453,"It's still a dungeon."],[1484,1634,"Still dangerous."],[1634,1814,"Still about surrender."],[1814,1881,"Control."],[1968,2072,"Power."],[2310,2425,"But now,"],[2492,2733,"it's the best kind of danger."],[3880,4014,"So..."],[4304,4445,"Are you ready"],[4507,4663,"for your next trial?"],[4888,5000,"Always."]]}