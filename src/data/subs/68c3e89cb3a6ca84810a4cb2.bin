{"1":[[262,383,"Clara."],[513,817,"I will be paying the medical bills of $100,000"],[817,917,"within half an hour."],[999,1217,"I will literally do anything"],[1217,1338,"to save my dad's life."],[3578,3783,"Boss, I got that loser in Philly."],[3795,3837,"Kill him."],[3945,4066,"The ones who betray Hell Gang"],[4066,4145,"could go to hell itself."],[4170,4225,"Right away."],[4429,4656,"Vesper, did you enjoy your time in college?"],[4842,4921,"Thank you."],[4921,5068,"It's a pleasure to make your acquaintance."],[5125,5191,"I'm Vesper."],[5780,5926,"Also, boss, Miss Brown is here."],[5997,6047,"Let her in."],[6840,7068,"It's been a long time, Mr. Ronald."],[7073,7244,"I told you, call me Raymond."],[7374,7470,"How've you been, Vesper?"],[7515,7686,"Um, a bit stressed out"],[7686,7871,"actually, Raymond."],[7970,8066,"I'm here because"],[8066,8298,"I wanted to ask you."],[8500,8659,"Could you please lend me $100,000?"],[8871,8985,"I knew you'd react this way."],[9038,9096,"If I were you,"],[9096,9285,"I might have reacted the same way."],[9363,9522,"I want to say,"],[9522,9680,"I can do anything for you."],[9730,9951,"What do you mean by anything?"],[10039,10155,"I..."],[10222,10418,"can be your contract lover."]],"2":[[33,254,"What do you mean by anything?"],[342,458,"I..."],[525,721,"can be your contract lover."],[721,846,"as long as you give me the money."],[1000,1143,"You excel in your studies."],[1180,1357,"module yourself down like this."],[1413,1488,"Because Raymond,"],[1534,1622,"I need the money."],[1622,1705,"The money is the most important"],[1705,1785,"thing right now."],[1822,2005,"So you want to be my contract lover?"],[2147,2252,"Tell me, Vesper Brown,"],[2252,2360,"how much do you like me?"],[2419,2439,"I..."],[2606,2681,"Answer me."],[2790,2932,"Even if my tuition was funded"],[2932,3065,"by your philanthropic support,"],[3311,3378,"I'm too humble."],[3490,3561,"Okay, don't worry."],[3561,3717,"I don't dare to have feelings"],[3717,3799,"for someone like you."],[3908,4087,"It is strictly a business deal for me."],[4179,4258,"I didn't realize you were"],[4258,4375,"so money-oriented as well."],[4504,4604,"What if I reject you?"],[4729,4829,"Would you go to another rich man"],[4829,4884,"right away?"],[4929,5163,"Yes, I need this $100,000 today."],[5417,5518,"Can you swim?"],[5701,5764,"No."],[5843,5939,"If you jump, I'll say yes."]],"3":[[2748,2823,"Vesper."],[2861,2999,"Frank, call the doctor!"],[3386,3478,"Boss."],[3524,3608,"the doctor said Miss Brown"],[3608,3670,"is out of danger."],[3703,3832,"She's definitely gonna wake up tonight."],[4020,4254,"She's actually willing to sell herself for money."],[4337,4571,"This is the girl I've always had my mind on."],[4708,4842,"God, I feel so stupid."],[4925,4988,"Boss."],[5055,5238,"Is she really just your contract lover?"],[5263,5442,"The only thing that she cares about is money."],[5551,5755,"She doesn't respect me, so..."],[5755,5905,"I won't respect her."],[5972,6126,"For now, she'll be my contract lover"],[6126,6277,"and I'll do with her whatever I please..."],[6302,6511,"And need you to draft me a contract, Frank."],[6656,6794,"She likes money?"],[6815,6981,"Well, I'll let her know the"],[6981,7119,"bitter consequences of money."],[7340,7430,"Yes, sir."],[8166,8340,"Thank you, Mr. Ronald."],[8350,8521,"I received the money."],[9371,9493,"Are you drunk?"],[9634,9759,"Afraid of drunkards, are you?"],[9847,10022,"Do you even know my true identity?"],[10122,10239,"I'm more than just a company president."],[10427,10719,"You're the boss of Hell Gang,"],[10785,10940,"known as the Mafia King."],[11119,11382,"People say you're the devil of Chicago."],[11624,11682,"That's right."],[11774,12024,"Yet you still dare be my contract lover."],[12166,12328,"Are you aware of the consequences?"],[13367,13475,"I get it now."],[13613,13735,"It's because I'm the richest man around."],[13735,13929,"I'm the only one that can satisfy you."],[13929,14022,"Vesper Brown."]],"4":[[884,996,"What are you doing?"],[996,1071,"Hey, hey, easy."],[1142,1226,"Just love your dress."],[1251,1470,"I can't help but touch."],[1584,1705,"How can you say that?"],[1705,1822,"Raymond's gonna hear about this."],[1843,2116,"Miss Brown, you're acting like Mrs. Ronald, right?"],[2116,2333,"You're nothing more than Mr. Ronald's mistress."],[2356,2460,"A toy."],[2556,2773,"Besides, I'm his most valuable business partner."],[2806,2933,"I don't think he'll mind"],[2933,3081,"whatever I decide to do next."],[3178,3379,"Frank, take him away."],[3415,3528,"If anyone else want to touched my woman,"],[3528,3611,"feed him a bullet."],[3611,3674,"Yes, sir."],[3741,3899,"Thank you, Raymond. I knew you were gonna-"],[3899,3978,"Let me guess,"],[4020,4179,"you try to seduce him just because he's rich."],[4208,4329,"What? No, I..."],[5651,5805,"No! Raymond!"],[5881,6031,"We have to make it clear."],[6031,6164,"It wasn't my fault today!"],[6289,6560,"You really don't love me at all, Raymond."],[6652,6949,"The contract is expiring, so I'm gonna leave!"],[7065,7111,"Leave?"],[7169,7486,"Yeah. It'd be three years in a month."],[7540,7728,"There's no reason for me to stay, is there?"],[7832,7920,"After all,"],[7991,8106,"you don't love me."],[8158,8291,"I'm not letting you go."],[8366,8600,"No one can escape Hell Gang that easily."],[9054,9284,"Why? Is it so necessary"],[9284,9373,"for you to wear me down"],[9373,9601,"day after day with your coldness?"],[9651,9843,"Coldness? You're rejecting my"],[9843,9964,"passion now, are you not?"],[12900,12983,"Be brave, Vesper."],[12983,13117,"Tell him you really love him."],[13117,13288,"Tell him you're pregnant now."],[13300,13434,"He might love you too."],[13434,13581,"Are you going to get engaged?"],[13663,13742,"What?"],[13742,13830,"That is..."],[13830,13905,"Engaged?"],[13905,14005,"...yet to be decided."]],"5":[[16,75,"Frank."],[1355,1405,"Why are you here?"],[1480,1569,"What have you heard?"],[1614,1750,"You're getting engaged?"],[1881,2243,"Yes, but a contract lover shouldn't eavesdrop."],[2419,2512,"What, you worried that you will lose"],[2512,2616,"your financial source?"],[2673,2826,"God, no, Raymond."],[2882,2982,"Don't look down on me."],[3194,3299,"Congratulations."],[3299,3401,"Finally have your women..."],[3557,3729,"Oh, it seems like you're happy about this,"],[3729,3830,"aren't you?"],[3983,4050,"Tell me you don't want me"],[4050,4120,"to marry another woman."],[4120,4179,"Just say it."],[4179,4362,"Vesper Brown. See how I would react."],[4562,4796,"Who am I to stand in your way?"],[4929,5190,"A contract lover shouldn't meddle in your affairs."],[5280,5363,"I won't embarrass myself."],[5722,5846,"No, Raymond!"],[5926,6137,"You can't do that!"],[6164,6256,"Reject me, huh?"],[6256,6364,"Why? Are you short of cash?"],[6535,6631,"Is this enough?"],[6952,7172,"You asshole, Raymond."]],"6":[[200,237,"What?"],[596,696,"Clara."],[742,896,"I knew you would react this way."],[1030,1344,"To be honest, I never expected"],[1344,1578,"that I would ever become a single mother."],[1755,1968,"But, but you have to let him know."],[1968,2191,"He's the father of a child."],[2214,2352,"And he has to take responsibility."],[2360,2435,"He doesn't love me."],[2673,2994,"I'm afraid that if I tell him,he..."],[3032,3226,"He might ask me to abort the baby."],[3290,3403,"I could raise the child on my own."],[3403,3507,"I believe in myself."],[3591,3695,"Listen, Vesper,"],[3695,3957,"it's his right to know. Do you understand?"],[4016,4149,"Vesper Brown,"],[4496,4667,"top student at my school."],[4667,4750,"And yet,"],[4750,4946,"being number one doesn't always give you"],[4946,5071,"what you want in life."],[5071,5276,"Still poor since the day I met you,"],[5276,5601,"drinking cheap juice in a cheap dress."],[5709,5818,"Bonnie Lockwood."],[5951,6101,"I may be poor now,"],[6101,6267,"but just wait until I graduate."],[6267,6410,"And I'm gonna show you what a real"],[6410,6569,"great designer looks like."],[6698,6891,"Somebody needs a reality check."],[7006,7173,"I can go to study abroad at any"],[7173,7369,"university of the arts at any time,"],[7369,7482,"and work at any top"],[7482,7653,"company after graduation."],[7728,7807,"But you,"],[7807,7942,"you're always going to be"],[7942,8116,"struggling at the bottom of the ladder."],[8183,8329,"My starting point is way ahead of"],[8329,8450,"any place you can land."],[8462,8562,"How could you say that?"],[8637,8879,"Oh, because it's the truth."],[8879,8958,"And,"],[8958,9228,"by the way, on top of that,"],[9228,9396,"the boss of the Hell Gang,"],[9396,9647,"the company president of the RR Group,"],[9647,9876,"Mr. Raymond Ronald is my fiancé now."],[9980,10118,"Together, our two families"],[10118,10322,"will be more powerful than ever."],[10410,10600,"But you'll never marry someone like that."],[10660,10773,"Number one at school,"],[10773,11044,"but not in real life."]],"7":[[1572,1685,"No, no, Miss Brown,"],[1685,1780,"you can't go."],[1814,1942,"The boss will kill me."],[1981,2064,"Please, Frank."],[2143,2331,"I'll go crazy if I stay here any longer, okay?"],[2331,2469,"I have to get out of here today."],[2894,3157,"Boss, Miss Brown just left with her suitcase."],[3269,3374,"She seemed a little off."],[3720,3814,"Don't worry, baby."],[3899,3999,"We'll get through this."],[4137,4420,"Hey, such a pretty girl. Come here, come on."],[4429,4589,"I'm in a hurry, leave me alone."],[4600,4692,"Come here."],[4729,4863,"Look at the body, huh?"],[4946,5104,"Stop it, don't touch me!"],[5105,5221,"Or what? What you gonna do?"]],"8":[[87,246,"Which one of you bastards touched her?"],[400,500,"Hell, Hell Gang!"],[517,654,"You, he's the devil of Chicago."],[654,704,"Come on."],[754,801,"Raymond?"],[1184,1322,"Sorry, let us go."],[1363,1551,"Please, Raymond, don't kill anyone, okay?"],[1551,1622,"I just wanna go home."],[2577,2706,"You left without my permission."],[2723,2868,"Put yourself in a dangerous situation."],[2868,3007,"What are you trying to do? Die?"],[4129,4250,"Don't do that again."],[4425,4550,"You come back with me."],[4904,5063,"Because it's the truth."],[5063,5255,"The boss of the Hell Gang,"],[5255,5480,"the company president of the RR Group,"],[5509,5730,"Mr. Raymond Ronald, is my fiancé now."],[5764,5943,"But you'll never marry someone like that."],[5989,6322,"Number one at school, but not in real life."],[7649,7803,"Is there anything you wanna tell me?"],[7916,8104,"Anything important?"],[8249,8418,"Did you ever love me, Raymond?"]],"9":[[20,91,"Even for a second?"],[91,283,"I do not love women like you."],[529,717,"You always put money before your man."],[825,1005,"Use any tactic you want, Vesper Brown,"],[1005,1284,"but never run away from home again."],[1505,1591,"That is my warning."],[2031,2206,"Jesus, you scared me."],[2210,2385,"What are you doing here? Hiding like a ghost."],[2385,2609,"Everyone should be at the ceremony right now."],[2644,2927,"You're Mr. Ronald's son."],[2990,3082,"The one who's been funding us"],[3082,3165,"to go to school here?"],[3199,3447,"Yes, but you haven't answered my question."],[3486,3690,"I just- I don't really like crowds."],[3720,3799,"Me too."],[4262,4487,"Thank you. It's a pleasure to meet you."],[4487,4571,"I'm Vesper."],[5046,5205,"You hungry?"],[5205,5272,"Let me make some"],[5272,5421,"black truffle pasta for you."],[6594,6631,"Who's there?"],[6702,6760,"Come on out!"],[8087,8212,"It was all your fault, Vesper."],[8266,8370,"You made me hate you."],[8437,8551,"You better not try to escape."],[9872,10047,"The baby is healthy."],[10301,10510,"And you should be getting plenty of rest."],[10643,10742,"Thank you, doctor."],[10798,10956,"I'll make sure to take good care of my baby."],[11615,11649,"Hello?"],[11707,11770,"Where are you?"],[11811,11866,"Come back now."],[11907,12053,"I have something to give you."],[12775,12829,"Put on this gown"],[12879,12958,"and come with me"],[12958,13054,"to the charity banquet tonight."],[13146,13338,"No, that's gonna be way too tight."],[13338,13380,"I..."],[13384,13659,"Don't push my buttons, Vesper."],[13868,14047,"I can't wear anything too tight right now,"],[14047,14101,"because I-"],[14101,14172,"You know, you've been really"],[14172,14280,"out of line recently."],[14393,14487,"This is my order,"],[14514,14602,"Do not waste my time."],[14660,14818,"I'm not one of your Gang members."],[14881,15035,"I'm sorry for wasting your time."],[15115,15194,"Don't worry."],[15219,15323,"I'm leaving tonight."],[15323,15457,"Oh, you want to leave again, do you?"],[15949,16111,"I bought a million dollar check."],[16612,16654,"Still leaving?"],[16862,16971,"Put on the gown."],[16971,17096,"I don't want to hear another word."],[17454,17659,"Am I such a gold-digger to you, Raymond?"],[17892,17980,"Don't worry."],[17980,18151,"The baby and I won't put up with you any longer."],[18209,18422,"I'm definitely leaving after this banquet's over."],[19627,19715,"Thank you."],[20007,20295,"Why not? What's changed?"],[20303,20666,"I'm just fighting alcohol right now because..."]],"10":[[154,241,"Boss."],[241,367,"Secret Gang meeting."],[367,479,"Just like last time."],[2102,2281,"Hi, Raymond. It's been a long time."],[2281,2389,"When are you free?"],[2389,2585,"We can have the engagement ceremony."],[2915,2965,"Miss Wood."],[3190,3415,"Hasn't your father already told you?"],[3478,3720,"I rejected the offer of marriage."],[3770,3887,"I already have a woman."],[4237,4371,"By the way,"],[4408,4517,"I don't even think your father"],[4517,4625,"would interrupt this for you."],[4692,4788,"I think it's wise you leave."],[6043,6277,"It's Lockwood, Not Wood."],[6293,6445,"I've liked him for years, but he can't even"],[6445,6562,"remember my last name."],[6735,6802,"It's you."],[6877,7006,"How come you're here?"],[7040,7136,"Good grades at school"],[7136,7279,"don't get you into exclusive places"],[7279,7411,"like this, unfortunately."],[7478,7590,"It's none of your business."],[7620,7726,"Why are you here?"],[7782,7982,"My fiancé Raymond asked me to come."],[8108,8187,"You're lying."],[8204,8304,"I'm not."],[8350,8470,"He's gonna marry me."],[8571,8717,"End of story."],[9321,9505,"No. The baby."],[9505,9580,"Raymond!"]],"11":[[0,241,"Raymond."],[241,362,"Where are you?"],[483,838,"Miss! Miss! Are you okay?"],[988,1172,"I'm gonna call an ambulance."],[1530,1614,"Thank you, John."],[1614,1690,"I appreciate the business."],[1797,1818,"Thanks."],[1843,1938,"Boss, bad news."],[2018,2169,"Miss Brown isn't answering our calls"],[2169,2255,"and she's gone missing."],[2270,2342,"Again?"],[2660,2777,"Cancel the banquet."],[2777,2890,"We're going home to look for her right now."],[2982,3032,"Yes, sir."],[3244,3328,"Did she really leave?"],[3528,3591,"Boss."],[3649,3806,"Is Miss Brown really in it for the money?"],[3866,3937,"What do you mean?"],[3953,4191,"I mean, if she was,"],[4191,4312,"she should have taken the check."],[4692,4863,"Again the black truffle pasta."],[4913,5017,"Why not try something new?"],[5017,5139,"Too much truffle pasta."],[5139,5254,"I mean, boring sometimes."],[5342,5422,"Then don't eat it."],[5488,5659,"No, it's fine. It'll do."],[6047,6164,"Frank,"],[6218,6331,"put all our men on high alert."],[6331,6439,"We need to find her."],[6519,6573,"Roger."],[7223,7344,"Boss,"],[7344,7444,"they found Miss Brown."],[7444,7558,"She's at St. Thomas Hospital."],[7599,7657,"They say somebody"],[7657,7732,"pushed her down the stairs."],[7741,7795,"She's badly hurt."],[8578,8754,"Vesper, please, stay strong."],[8754,8938,"I'll kill the bastard who hurt you."],[9421,9501,"Please."],[9505,9648,"Doctor, save my baby."],[9688,9847,"Calm down."],[9847,10022,"We'll do our best."],[10097,10210,"Prepare for surgery."],[10435,10698,"Raymond, if I have a miscarriage,"],[10698,10819,"would you be sad?"],[14572,14647,"Doctor."],[14731,14908,"Is my child still alive?"]],"12":[[145,171,"Vesper?"],[433,462,"You okay?"],[538,658,"The procedure isn't over yet."],[658,734,"You can't be in here."],[750,871,"No, what happened to her?"],[1197,1405,"You and your baby are out of danger for now."],[1505,1597,"The surgery worked."],[1805,1978,"I'm gonna go talk to your family now."],[2001,2110,"No, Doctor..."],[2164,2369,"please keep my secret."],[2494,2767,"Don't tell anyone that my baby is still alive."],[2831,2887,"Why?"],[2969,3130,"No, your family deserves to know"],[3130,3268,"that this baby is safe."],[3378,3432,"No."],[3478,3656,"He's not my husband."],[3703,3960,"Okay? But he is a powerful man."],[4049,4170,"So if someone finds out,"],[4170,4337,"they will hurt my child."],[4491,4732,"Please, trust a mother's instinct."],[4934,5068,"Doctor, please."],[6214,6373,"Doctor, is she okay?"],[6373,6443,"What happened to her?"],[6477,6569,"So you didn't know that"],[6569,6706,"she was 14 weeks pregnant."],[6902,6977,"What? No..."],[7073,7205,"She was pushed down the stairs"],[7205,7316,"and seriously hurt,"],[7428,7550,"so she had a miscarriage."]],"13":[[1351,1576,"Who am I to stand in your way?"],[1705,1914,"A contract lover shouldn't meddle in your affairs."],[1981,2085,"I won't embarrass myself."],[2435,2485,"No, Raymond!"],[2544,2690,"Is there anything you wanna tell me?"],[2831,3030,"Anything important?"],[3153,3348,"Did you ever love me, Raymond?"],[3378,3449,"Even for a second?"],[3449,3639,"I do not love women like you."],[5121,5213,"Frank."],[5213,5394,"Who exactly pushed her down the stairs?"],[5426,5568,"Only Miss Brown knows that, boss."],[5701,5834,"I've got my people looking into it."],[5914,5993,"That murderer will"],[5993,6111,"die with my child."],[7891,8116,"Hey."],[8308,8429,"You okay?"],[8533,8654,"Yeah."],[8692,8812,"Thanks."],[8892,9013,"Vesper."],[9138,9338,"Why didn't you tell me about the pregnancy?"],[9505,9663,"Is this your way of revenge?"]],"14":[[145,264,"Is this your way of revenge?"],[275,337,"Revenge?"],[496,775,"Raymond, if I told you, you would have thought"],[775,921,"I was asking for more money."],[971,1063,"What? No!"],[1163,1276,"No, I wouldn't have."],[1501,1804,"Tell me. Who pushed you down the stairs?"],[1972,2114,"Okay, boss, I got it."],[2143,2293,"The perpetrator was Bonnie Lockwood."],[2293,2431,"Somebody saw her."],[2619,2686,"Exactly."],[2806,3011,"It's your fiancée from the good family."],[3311,3361,"Let's go."],[3699,3803,"Don't worry, Miss Brown."],[3803,3928,"The boss said he'll take care of her."],[3945,4045,"He'll take revenge for the baby,"],[4045,4154,"giving her the same treatment."],[4179,4266,"Oh no."],[4300,4392,"Would he kill her?"],[4458,4521,"No, no."],[5125,5209,"I'm sorry, Vesper."],[5251,5321,"It's not my fault."],[5363,5534,"If you knew how much I love you,"],[5534,5639,"even you would be scared..."],[5730,5940,"Boss, we got Bonnie Lockwood."],[6735,6861,"Bonnie Lockwood."],[7027,7178,"You hurt my woman,"],[7278,7444,"causing her to lose my baby."],[7649,7937,"For this, you'll beg for mercy,"],[7995,8120,"and if it is good enough,"],[8120,8438,"I'll consider sparing you suffering death."],[8867,9013,"You..."],[9042,9230,"How could it be you?"],[9230,9394,"How could a poor little bitch"],[9394,9536,"like you be his girlfriend?"],[9551,9718,"I don't think you've understood."],[9747,9826,"Say sorry"],[9826,10022,"for a lost baby NOW!"],[10068,10251,"Raymond, don't..."]],"15":[[95,125,"Don't."],[166,255,"Why?"],[279,412,"Don't you want to avenge our child?"],[588,675,"I do, but..."],[679,742,"Vesper,"],[742,888,"you humiliate me like this."],[930,1113,"Jesus won't be able to save you, I swear."],[1267,1374,"You're gonna kill Bonnie"],[1374,1475,"for a mistress?"],[1505,1584,"Grandma, help."],[1626,1897,"Grandma, why did you come back?"],[1897,1993,"If I didn't come back,"],[1993,2221,"you'd turn the Hell Gang into a Hell show."],[2417,2483,"No."],[2523,2615,"No, don't, Grandma,"],[2615,2744,"this... this is-"],[2744,3023,"I have no interest in knowing your mistress."],[3073,3208,"Bonnie is important."],[3215,3419,"The Lockwoods helped the Hell Gang"],[3419,3533,"30 years ago."],[3620,3738,"So we arranged a marriage"],[3738,3853,"between you and Bonnie."],[3853,3887,"No."],[3887,4116,"And there is nothing you can do about it."],[4116,4308,"No, I'm not gonna marry this woman."],[4450,4554,"Frank,"],[4554,4813,"take this mistress back to the hospital now."],[4925,5080,"The families need to talk."],[5301,5422,"Bonnie, tell him."],[5526,5647,"Tell him what you told me."],[5709,5794,"Yes, Grandma."],[5922,5980,"Raymond."],[5980,6206,"I don't blame you for being mesmerized by her."],[6297,6428,"Do you want to know a secret?"],[6506,6682,"Vesper is an old classmate of mine,"],[6682,6751,"and"],[6751,6956,"years ago she sold herself to her sugar daddy"],[6956,7130,"to pay for her father's medical bills."],[7253,7407,"You're not the only man in her picture."]],"16":[[87,179,"What?"],[179,379,"You told my dad I was here?"],[454,692,"Clara, my dad can't find out"],[692,905,"that I'm being a contract lover"],[921,1084,"to the boss of Hell Gang,"],[1117,1263,"Or that I'm pregnant."],[1272,1378,"Are you crazy?"],[1413,1463,"Don't worry."],[1463,1601,"Of course I didn't say anything."],[1651,1793,"But he was in a rush"],[1793,1897,"after he"],[1897,2072,"heard that you fell down the stairs."],[2122,2348,"How could I stop a father from visiting"],[2348,2552,"his daughter in the hospital? Hmm?"],[2590,2696,"I just hope my dad"],[2696,2919,"doesn't run into Raymond or his grandma."],[3040,3224,"It'll all be over otherwise."],[3349,3436,"My dad might even"],[3436,3616,"get humiliated by Raymond's grandma."],[3870,3991,"Oh, sweetheart."],[3991,4049,"Dad!"],[4049,4133,"How are you?"],[4320,4554,"Boss, the old lady went back to villa."],[4554,4754,"I'll make sure you get everything she needs."],[4788,4959,"Maybe Grandma's right, Frank."],[5163,5313,"Maybe she didn't take the check"],[5313,5401,"because she's"],[5401,5567,"getting more checks from someone else."],[5593,5730,"Probably that old sugar daddy."],[6076,6193,"Let her go."]],"17":[[508,567,"Who is he?"],[604,658,"Tell me!"],[696,788,"Who am I?"],[817,855,"I'm her-"],[859,959,"Stop! Both of you!"],[1017,1167,"Raymond, I can't introduce you yet."],[1167,1209,"Get out!"],[1238,1272,"Oh yeah?"],[1347,1401,"Restrain him!"],[1468,1497,"Roger."],[1589,1685,"No."],[1735,1822,"What the hell are you doing?"],[1860,1964,"No! Let go of him!"],[2185,2304,"I catch you both red-handed"],[2304,2476,"and you're still making excuses."],[2540,2686,"You really are a brave woman, Vesper."],[2706,2890,"What the hell are you talking about?"],[2948,3144,"Raymond, let's just go and I can explain."],[3144,3246,"You care about him so much"],[3246,3474,"and you're protecting him. Just tell me who he is."],[3511,3561,"Vesper."],[3566,3611,"Shut up!"],[3641,3661,"Please."],[3745,3828,"Raymond, this is"],[3828,3903,"your last chance."],[3945,4158,"Okay? Let's get out and talk."],[4158,4230,"Oh yeah?"],[4250,4383,"Let's see how much you love your sugar daddy."],[4383,4482,"Cut off his hands!"],[4483,4579,"No! Dad!"],[4667,4725,"What?"]],"18":[[25,208,"This is my dad, Jake."],[296,492,"Not some old sugar daddy."],[492,625,"You asshole!"],[629,925,"Uh, uh, excuse me."],[925,1046,"Mr. Brown, I'm..."],[1055,1209,"Dad, don't be mad."],[1255,1355,"These are"],[1355,1626,"just my friends."],[1735,2035,"Friends? Would your friends do this to you?"],[2122,2189,"Do you really"],[2189,2469,"believe that I think these are your friends?"],[2540,2731,"Please, can you just give me a minute?"],[3607,3745,"Look, I'm sorry."],[3745,3828,"Okay? I'm sorry."],[3828,4020,"I didn't know that was your real father."],[4070,4475,"Look, I can forgive you,"],[4475,4786,"but you have to do me a favor."],[4900,5167,"Okay. What is it?"],[5234,5668,"Never let my dad find out that"],[5668,5870,"I'm being your contract lover,"],[5893,6068,"or that you're the"],[6068,6243,"boss of Hell Gang."],[6398,6847,"Raymond, I need you to pretend"],[6847,7013,"to be my boyfriend in front of him."],[7190,7279,"Boyfriend?"],[7344,7634,"God, yeah, it's like... a normal"],[7634,7780,"kind of relationship."],[7837,7911,"Raymond,"],[8074,8341,"pretend that you love me."],[8491,8888,"Pretend that we love each other."],[9109,9200,"Okay."]],"19":[[120,196,"Okay, I can do that,"],[196,325,"but are you gonna pretend to love me?"],[454,629,"You're sure enough good at acting as it is already."],[629,688,"Vesper."],[896,1099,"Same goes for you, Raymond."],[1167,1381,"What? You're engaged to Bonnie Lockwood,"],[1381,1455,"but you're gonna kill-"],[1455,1605,"How about your other sugar daddy, huh?"],[1672,1818,"Are you engaged with him?"],[1818,1876,"Where is he?"],[1901,2068,"Why hasn't he come to visit you yet?"],[2285,2369,"You're psycho!"],[2540,2673,"Vesper, Jake just left."],[2794,2848,"Why?"],[2848,3046,"He said it doesn't matter"],[3046,3249,"what type of relationship you have with Raymond."],[3328,3575,"If he loves you, he has to pay"],[3575,3772,"an official visit to his house."],[3828,4048,"But if he doesn't, you're never"],[4048,4264,"ever allowed to see him ever again."],[4320,4493,"Yeah, that's Dad's style."],[4621,4754,"All right."],[4754,4984,"We don't have to pretend to be a couple anymore."],[5451,5655,"Find out the location of Mr. Brown's house."],[5759,5832,"Let's get some gifts."]],"20":[[238,301,"There you go."],[301,438,"Tea, no sugar."],[500,656,"Thank you, Mr. Brown."],[796,1117,"So, tell me, Mr. Ronald,"],[1117,1318,"what exactly do you do for work?"],[1388,1514,"Well, I..."],[1572,1712,"- Why are you here? - Why are you here?"],[1889,2147,"I... sorry, uh, Jake"],[2147,2262,"left his watch at Frank's"],[2262,2406,"and I came by to"],[2406,2510,"give it back to him."],[2686,2883,"How were you out of the hospital so soon?"],[2883,3007,"Did the doctor let you out?"],[3090,3315,"Yeah, yeah. I just came back to"],[3315,3399,"grab a few things."],[3511,3732,"But you guys,"],[3732,3854,"what are you talking about?"],[3903,3985,"Oh well, sweetheart."],[3999,4149,"I was just telling your boyfriend"],[4149,4275,"how wonderful you are."],[4379,4500,"Yeah, yeah."],[4500,4710,"My girlfriend is not only really good at her studies,"],[4710,4943,"but also very, very caring for her father."],[4959,5058,"Yeah, she does."],[5146,5285,"You know, three years ago,"],[5285,5419,"I was very sick."],[5467,5663,"I needed $100,000 for surgery."],[5722,5860,"We didn't have the money,"],[5860,6088,"so Vesper went out, begging for it."],[6088,6174,"Stop, Dad."],[6181,6373,"Wait, wait, wait. $100,000..."],[6373,6572,"That was for your dad's medical bills?"]],"21":[[0,154,"Medical bills?"],[154,241,"Let's go."],[479,625,"So her sugar daddy is me?"],[688,800,"I'm sorry, what did you say?"],[1000,1055,"Dad."],[1055,1284,"This was supposed to a secret between you and me."],[1284,1380,"Why'd you tell him?"],[2168,2350,"The $100,000 is for his surgery?"],[2394,2489,"Why didn't you just tell me?"],[2489,2590,"I sure would've helped you."],[2594,2728,"Tell you what, Raymond?"],[2765,2882,"Since you've been funding my tuition,"],[2882,3065,"so please pay my father's medical bills as well?"],[3082,3280,"Oh, so you're embarrassed then?"],[3374,3528,"Is being my contract lover much better?"],[3724,3858,"You'd better pray"],[3858,4010,"that you will never be desperate."],[4010,4070,"Raymond."],[4258,4316,"Here."],[4316,4429,"It's everything I've saved up"],[4429,4578,"over the past three years as a designer."],[4608,4730,"It's up to $80,000."],[4767,4884,"I'll pay the remaining 20,000"],[4884,4984,"after I graduate."]],"22":[[221,307,"You've been saving up money"],[307,429,"for the past three years."],[492,755,"Just to pay me back the $100,000."],[767,830,"That's right."],[896,1040,"I haven't cashed a single check"],[1040,1173,"or cash of yours."],[1222,1345,"I will give you the remaining"],[1345,1585,"$20,000 after I graduate."],[1722,1782,"I see."],[1805,1956,"So you're planning on leaving me then?"],[2147,2217,"You've never really thought of"],[2217,2349,"yourself as my woman, have you?"],[2427,2590,"The way you talk about me, Raymond,"],[2590,2698,"like you care."],[2761,2969,"The contract is expiring."],[2982,3182,"Grandma's back and you have to"],[3182,3320,"get engaged to Bonnie."],[3395,3490,"I'll go where I belong."],[3511,3607,"No, you won't."],[3678,3757,"Take this."],[3812,3930,"Where do you think you're going to?"],[4008,4097,"Another man?"],[4175,4303,"You can't get away from me, Vesper."],[4303,4383,"It's too late."],[4475,4615,"Raymond, I..."],[4679,4746,"What? What's wrong?"],[4746,4925,"I don't feel good."],[4925,5036,"What?"],[5036,5148,"Vesper!"]],"23":[[296,346,"Don't worry, boss."],[387,475,"She's just malnourished."],[558,662,"Get her a cook,"],[662,855,"and perhaps someone to monitor her."],[905,946,"Yes."],[946,1042,"She can't disappear again."],[1142,1212,"Yes."],[1242,1354,"And also we found the man"],[1354,1460,"who saved her at the stairs."],[1460,1563,"I gotta meet him."],[4187,4348,"If I were you, I would find a peaceful place"],[4348,4477,"to give birth to that child."],[4637,4732,"Who are you?"],[4800,5075,"Oh, Mr. Ronald didn't tell you who saved you?"],[5167,5447,"Are you the one that"],[5447,5579,"called the ambulance for me?"]],"24":[[66,145,"That's right."],[258,399,"I didn't receive a thank you,"],[399,579,"so I thought I would come and inquire."],[592,777,"- Thank you, Mr... - Oakley."],[863,934,"Colton Oakley."],[971,1088,"Thank you, Mr. Oakley."],[1159,1313,"But it's seemed to be a misunderstanding."],[1434,1530,"What child?"],[1530,1631,"I've had a miscarriage."],[1643,1739,"Is that right?"],[1793,1939,"You must be hungry then because you keep"],[1939,2054,"touching your stomach."],[2302,2392,"Don't worry, Vesper."],[2510,2623,"I'll keep your secret."],[2686,2890,"Desperate mother protecting her child"],[2890,3065,"deserves to be protected."],[3103,3426,"Thank you, Colton."],[3570,3759,"Please keep my secret."],[3941,4058,"You just said peaceful place."],[4095,4204,"But someone that isn't"],[4204,4300,"controlled by the Hell Gang?"],[4408,4479,"Of course."],[4479,4605,"You're awake."],[5017,5159,"Mr. Oakley."],[5159,5367,"seems you've become well acquainted with my woman."],[5417,5480,"And I don't think you've been"],[5480,5676,"invited to join us for dinner."],[7061,7218,"I think I've made myself pretty clear."],[7218,7279,"Raymond."],[7286,7432,"Do you really want to break the contract,"],[7432,7503,"Vesper?"],[7555,7641,"What?"],[7670,7918,"It expires in three weeks."],[7920,8096,"Until then, you belong to me."],[8329,8554,"The hospital is a bit of a mess right now."],[8621,8821,"You move to the Orante Estate tomorrow."],[8921,9025,"Orante Estate?"]],"25":[[342,517,"Is this estate owned by Hell Gang?"],[546,673,"Why have I never heard of it?"],[709,846,"This estate's owned by the old lady."],[905,1030,"The boss thinks it's quiet enough"],[1030,1154,"to start your rehabilitation."],[1338,1443,"I'm going for a stroll."],[2139,2255,"We have orders from the boss."],[2277,2423,"You're not allowed to go out, Mrs. Brown."],[2644,2778,"This isn't rehabilitation."],[2898,3035,"This is house arrest."],[3148,3421,"Frank, let me out."],[4417,4618,"Vesper, are you giving my men"],[4618,4721,"a hard time again?"],[4780,4871,"You're putting me"],[4871,5063,"under house arrest?"],[5150,5414,"Let me out, Raymond, you drunk!"],[5659,5722,"Why?"],[5784,5882,"So that Oakley guy"],[5882,6068,"or another man could be all over you?"],[6168,6302,"Let me refresh you on something."],[6773,6961,"Article 6:"],[6961,7190,"party A can take party B"],[7205,7361,"anywhere, at any time,"],[7361,7591,"as long as it doesn't interfere with her studies."],[7707,8001,"Article 7: party B must"],[8001,8216,"keep party A's property all confidential."],[8408,8504,"Do you remember that, Vesper,"],[8504,8575,"from the contract?"],[8750,8792,"Oh!"],[8942,9125,"Article 11:"],[9205,9755,"Party A can, at any time, do this."],[9910,9968,"No."],[9968,10126,"Raymond, we can't! I'm serious!"],[10130,10214,"Why not?"],[10247,10363,"You've always loved it, Vesper."],[10363,10465,"And I know you have."],[10465,10699,"You can only be mine, Vesper."]],"26":[[367,514,"Back off, or I'll pull it."],[550,717,"Okay, easy, easy now."],[975,1196,"Look, I'll leave."],[1248,1459,"I'll come back and see you tomorrow, okay?"],[1534,1822,"Tell my dad I'm going on a trip with Clara,"],[1881,2001,"and have Clara"],[2001,2131,"bring me my diploma."],[2131,2352,"Do you hate me so much? Vesper."],[2381,2636,"Okay, understood."],[3566,3669,"Don't be afraid."],[4033,4165,"We'll get us out of here."],[5922,6115,"Miss Brown, we have a visitor."],[6748,6865,"What are you doing in here?"],[6936,7011,"Did they let you in?"],[7069,7304,"Of course, I'm omnipotent."],[7411,7513,"Stop kidding, Colton."],[7545,7643,"Who the hell are you?"],[7849,8000,"Where is this place exactly?"],[8000,8116,"Isn't it controlled by Hell Gang?"],[8149,8296,"Look, I'm just a man who fell"],[8296,8435,"in love with you at first sight."],[8479,8573,"Come with me, Vesper."],[8616,8710,"I'll take you away."]],"27":[[287,475,"I said to stop joking, Colton."],[596,684,"Who would like a..."],[684,754,"Look,"],[800,939,"I know you can't trust me right now."],[939,1013,"It doesn't matter."],[1013,1205,"You have plenty of time to think about it."],[1238,1317,"Here."],[1317,1473,"I bought you this gift."],[1551,1643,"When I first saw it,"],[1643,1697,"I thought it would"],[1697,1876,"fit well with the gown you wore that day."],[1876,1997,"Thank you very much, Mr. Oakley."],[2127,2398,"But that gown of hers was chosen by me."],[2431,2582,"I didn't know you knew my grandmother."],[2677,2823,"Perhaps we should get her a gift"],[2823,2957,"for letting you into the Orante Estate?"],[3098,3182,"Something like this."],[3336,3549,"Oh, come on, Mr. Ronald."],[3549,3741,"You already knew I was on your property."],[3741,3856,"And the reason why you have men"],[3856,3947,"surrounding the area"],[3947,4091,"is to keep an eye out on Vesper."],[4216,4321,"Raymond, we..."]],"28":[[279,367,"Why'd you do that?"],[437,567,"You see, Mr. Oakley,"],[606,759,"my woman always acts like this,"],[759,904,"so I have to have my men around"],[904,1114,"to prevent her from getting into fights."],[1146,1305,"Well, if you really are in love,"],[1305,1459,"then why is Vesper keeping an"],[1459,1576,"important secret from you?"],[1680,1758,"Colton."],[1820,1892,"What secret?"],[1914,2047,"And she begged me not to tell you."],[2090,2162,"What?"],[2180,2326,"Colton, that's enough."],[2360,2502,"It's time for you to leave."],[2573,2665,"Vesper."],[2748,2902,"Frank, kick him out."],[2982,3178,"As you wish, Miss Brown."],[3540,3649,"Vesper, come on!"],[4671,4857,"Vesper, what secret?"],[4867,5004,"God, I don't know!"],[5004,5105,"Just leave me alone!"],[5105,5288,"What is it that he can know but I can't?"]],"29":[[87,252,"And when did you get to know him so well?"],[308,478,"He's bullshitting!"],[478,602,"Get off the estate,"],[602,688,"you asshole!"],[688,888,"He likes you, I know he does."],[888,980,"When did things start, huh?"],[1255,1347,"Don't tell me you wanna leave Hell Gang"],[1347,1450,"so badly,"],[1450,1553,"just because of him!"],[1601,1800,"No! Get the hell out!"],[3762,3803,"Vesper!"],[4179,4314,"The reason why I invited myself"],[4314,4456,"to dinner this evening"],[4456,4664,"is because I owe you an apology"],[4664,4799,"for making up the story."],[4900,5003,"Please, don't be offended."],[5003,5046,"Colton."],[5171,5265,"Call her Miss Brown."],[5455,5559,"Miss Brown."],[5572,5710,"Why would I do that, Raymond?"],[5734,5822,"She calls me Colton."],[5826,5959,"Please, enough!"],[6177,6370,"Mr. Oakley, I forgive you"],[6370,6504,"and I really hope you stop talking"],[6504,6664,"nonsense from now on."],[6664,6906,"But please, if you guys are gonna argue,"],[6906,7009,"can you just go?"],[7111,7213,"I just want a quiet dinner."],[8102,8171,"What's wrong?"],[8281,8376,"Frank?"],[8735,8815,"Call the doctor."],[8824,8888,"- No! - No!"],[9160,9285,"Why?"],[9285,9438,"You both know why this is happening, right?"],[9526,9672,"Miss Brown, are you alright?"],[9859,9984,"Oh my God, please don't tell me"],[9984,10058,"you're pregnant."]],"30":[[204,279,"No."],[279,421,"I just had a miscarriage, okay?"],[421,618,"It's the aftermath of the miscarriage."],[618,698,"Frank."],[698,880,"bring Vesper to Dr. Smith for an ultrasound."],[880,1092,"No! I told you it's just a miscarriage!"],[1092,1184,"I'm not going!"],[1184,1404,"Raymond, please. respect Vesper's decision."],[1651,1760,"You come with me."],[1935,2035,"Raymond, no!"],[2081,2285,"You're making the bad decision!"],[3040,3119,"What do you want to do?"],[3157,3265,"You never had a miscarriage."],[3315,3462,"Your actions speak the truth."],[3549,3689,"Why did you conspire with the doctor"],[3689,3750,"to lie to me?"],[3750,3901,"Do you know how I feel right now?"],[3928,4003,"Because Raymond..."],[4003,4154,"Don't leave me, Vesper."],[4233,4387,"We have our baby now."],[4466,4771,"I'll protect all of us for the rest of our lives."],[5693,5872,"If I were you, I would find a peaceful place to"],[5872,5982,"give birth to that child."],[6047,6189,"He's gonna marry me."],[6297,6368,"End of story."],[6915,7140,"Because... you are not"],[7140,7271,"the father, Raymond."]],"31":[[112,225,"What did you say?"],[246,371,"I said you're not the father."],[437,539,"Now leave us alone."],[567,821,"I'm sorry, Raymond, I have to get out of here."],[867,953,"I mean, sooner or later,"],[953,1047,"you're gonna marry Bonnie."],[1047,1121,"And I can't let her"],[1121,1297,"hurt our baby a second time."],[1434,1513,"No."],[1675,1778,"No, you're lying."],[1810,1901,"I'm not lying."],[1981,2097,"Whether you forgive me or not,"],[2097,2225,"I have to get out of here"],[2225,2403,"and give birth to my child."],[2477,2606,"Who's the father, then?"],[2606,2782,"Is it that jerk outside?"],[2861,3007,"Obviously, he knows you didn't"],[3007,3123,"have a miscarriage."],[3123,3261,"No, I swear it's not him."],[3261,3399,"Please don't hurt him."],[3399,3559,"He's the one that saved the baby."],[3591,3686,"Then who is it?"],[3762,3895,"Is the businessman I work with?"],[3895,4062,"Is it one of your classmates?"],[4149,4304,"Huh? How did you meet?"],[4304,4457,"Tell me everything."],[4462,4604,"Let me go!"],[4604,4813,"I'll tell you after I get out of here."],[5046,5106,"Vesper Brown."],[5363,5488,"You're still playing tricks on me."],[5672,5901,"You will pay for this, I swear to God."],[6005,6410,"No. I know you won't do anything."],[6410,6631,"I know you."],[6806,6898,"I'm sorry."],[7027,7203,"I won't put up to your cruelty anymore."],[7507,7620,"But it doesn't matter now."],[7803,7924,"I'll find out who he is,"],[7924,8072,"and I will catch him myself."]],"32":[[30,95,"Vesper."],[233,433,"Vesper, did you lie to him?"],[433,627,"He ran out with his men like a maniac."],[767,980,"Vesper, let me make up for my fault."],[992,1205,"I can take you away from here."],[1226,1334,"Away from Hell Gang."],[1363,1472,"They'll never find you."],[1547,1659,"How can you make up for it?"],[1705,1826,"Who the hell are you?"],[1900,1951,"Ever heard of"],[1951,2127,"the Oakley family from Canada?"],[2147,2360,"The family that got into a firefight with Sicily?"],[2456,2698,"Oh god, tell me you're not involved with them."],[3065,3204,"I'm the heir of the Oakley family."],[3724,3911,"Grandma, news flash."],[3933,4056,"That bitch betrayed Raymond,"],[4056,4244,"and got pregnant with someone else's baby."],[4252,4363,"Asshole!"],[4458,4538,"How is Raymond?"],[4546,4611,"Is he okay?"],[4650,4841,"He's looking around for the adultery."],[4904,5063,"As I see it, that slut should"],[5063,5239,"be tied to a cross and burned."],[5242,5442,"Find out where that bitch is."],[5442,5626,"I'll make sure she suffers enough."],[5693,5757,"Got it."],[6135,6218,"Grandma."],[6431,6556,"I have a new plan."]],"33":[[375,462,"Miss Brown."],[462,655,"Transfer site is on the other side of the property."],[709,875,"What? Transfer?"],[888,1030,"The boss is taking you to the countryside."],[1034,1115,"We're running out of time."],[1134,1205,"We'll meet you there."],[1251,1347,"Wait, Frank, what-"],[1384,1509,"Just trust the boss, Miss Brown."],[1989,2160,"The situation has changed."],[2160,2289,"We can't wait until tomorrow."],[2289,2454,"We must escape tonight as planned."],[2715,2865,"I do not need your help."],[2865,3023,"I'm gonna find a way to abort that child"],[3023,3119,"and drive her away for good."],[3178,3253,"Great, Raymond."],[3253,3384,"You'll finally be sober."],[3411,3607,"Don't lie to me, Raymond."],[3607,3778,"I know you're deeply obsessed"],[3778,3845,"with that bitch."],[3870,4003,"I'm not lying to you."],[4003,4195,"I've never loved her. She's just my plaything."],[4212,4254,"She betrayed me."],[4254,4446,"Now I'm gonna get my revenge on her."],[4446,4558,"If she resists me..."],[4688,4746,"I will kill her."]],"34":[[279,513,"I'll meet you at the back of the property."],[1034,1151,"Raymond,"],[1151,1455,"I thought this child would help me get your love."],[1584,1797,"But we can't escape hating each other."],[2043,2114,"Vesper?"],[2752,2844,"Miss Brown hasn't been out."],[2869,3028,"Maybe the old lady come and got her."],[3261,3328,"If that's the case,"],[3328,3418,"she wouldn't have made it in time"],[3418,3516,"to take her suitcase."],[3720,3864,"And her bank card's still here."],[4258,4371,"She got away again."],[4462,4631,"We cannot let Bonnie or Grandma get her."],[4631,4723,"They're gonna kill her."],[4963,5104,"- Find her! - Roger."]],"35":[[400,658,"Look, I know that video hurt, Vesper."],[679,842,"You might as well forget about him."],[842,963,"You deserve better."],[1030,1180,"I can't."],[1234,1547,"Just think of the baby and your father Jake."],[1639,1847,"I've managed to bring him to a safe place."],[2014,2189,"We can finally start a new life together."],[3073,3199,"No."],[3832,3999,"The baby is healthy."],[4062,4171,"Thank you, doctor."],[4216,4366,"I'll make sure to take good care of my baby."],[4454,4571,"Frank,"],[4571,4763,"my grandmother's trying to hurt Vesper."],[4804,4946,"I am lying to her about my plan,"],[4946,5034,"but we need to transfer her to"],[5034,5138,"a safer place right away."],[6227,6345,"I don't wanna learn to swim."],[6389,6602,"I wanna go to the cinema with Uncle Colton."]],"36":[[279,405,"I don't wanna learn to swim."],[442,654,"I wanna go to the cinema with Uncle Colton."],[717,917,"There are other showings at the cinema,"],[917,1107,"but swimming lessons only start at three,"],[1107,1184,"okay, Hugo?"],[1238,1317,"And by the way,"],[1388,1579,"don't keep making movie dates with Uncle Colton."],[1579,1689,"We've already bothered him enough."],[1768,1820,"Why?"],[1820,1947,"I wanna pretend he's my dad"],[1947,2079,"in front of all my classmates."],[2652,2731,"Hey, Hugo,"],[2748,2836,"give me a hug."],[3236,3328,"This is for you, buddy."],[3474,3567,"Is it really a bother"],[3567,3703,"if you go to the movies with him again?"],[3707,3826,"No, I've been taking care of him"],[3826,3926,"for nine years."],[3949,4088,"A few movie dates is not a problem."],[4208,4414,"I know, you've always been so nice to us."],[4466,4612,"But I can earn money myself."],[4671,4721,"Look,"],[4721,4842,"I've done a great job with Hugo."],[4867,4946,"Of course."],[5017,5234,"Hey, I heard that you got another award"],[5234,5355,"for one of your designs"],[5355,5530,"and got an offer from a big company."],[5551,5663,"You deserve it, Vesper."],[5776,5868,"Jake must be proud."],[5893,5960,"He is."],[6001,6093,"I went and visited him"],[6093,6235,"at the nursing home the other day."],[6268,6343,"He was glad."],[6393,6481,"What are you waiting for?"],[6481,6573,"Let's go."],[6744,6827,"It's good to see you."],[8629,8687,"Oh,"],[8721,8892,"I'll go search for her on my own next week."],[8988,9110,"But boss, you have an important trip"],[9110,9193,"next week."],[9205,9363,"We're supposed to inspect our branch in Miami."],[9467,9628,"We'll schedule the inspection for tomorrow."],[9709,9855,"I'll search for her along the East Coast"],[9855,9961,"as soon as I'm done."],[9997,10080,"Yes, sir."]],"37":[[684,742,"Hi,"],[742,863,"I'm Vesper Brown."],[863,980,"I'm the new designer here."],[1034,1096,"Uh,"],[1096,1159,"check it over there."],[1272,1330,"Uh..."],[1851,1976,"Fill out the form inside."],[2569,2635,"Yes."],[2686,2819,"Grandma, we just arrived."],[3032,3205,"No, I'm not here to find her,"],[3205,3328,"I'm here to inspect your company."],[3503,3536,"What?"],[3611,3716,"The engagement to Bonnie?"],[3778,3966,"No, no, no, I can't hear you right now."],[3966,4033,"I'm gonna hang up."],[4450,4504,"Boss,"],[4546,4679,"why did you hide your true identity"],[4679,4763,"for the company inspection?"],[4808,4929,"Do you not want them to give you a tour?"],[4992,5176,"River is a large company which is acquired,"],[5176,5309,"and I must get a feel"],[5309,5442,"for how they've been operating this."],[5480,5534,"I see."],[6114,6218,"From Mr. Ronald."],[6264,6406,"Investment and operation?"],[6435,6507,"Yes."],[6527,6610,"Follow me."]],"38":[[216,300,"Hey, baby,"],[300,483,"can you wait a bit longer in the lobby for me?"],[504,583,"I'll be out in a bit."],[1101,1134,"Hey!"],[1230,1291,"Stop!"],[1390,1498,"Why are you guys picking on him?"],[1530,1622,"He's a freak!"],[1655,1747,"Has no dad!"],[1747,1818,"Who are you?"],[1843,1897,"Oh yeah?"],[1968,2035,"I'm his dad."],[2260,2356,"And this is my thug."],[2569,2706,"We catch you two picking on him again,"],[2731,2864,"he will put you in your place."],[3169,3244,"Look, there's a bird."],[3311,3364,"No!"],[3716,3766,"Thank you."],[3795,3972,"It's a pleasure to make your acquaintance."],[4008,4109,"I'm Hugo."]],"39":[[45,91,"Thank you."],[137,299,"It's a pleasure to make your acquaintance."],[350,451,"I'm Hugo."],[729,792,"Thank you."],[846,993,"It's a pleasure to make your acquaintance."],[1017,1088,"I'm Vesper."],[1897,1935,"Sir?"],[2072,2139,"Yeah, yeah,"],[2139,2198,"great to meet you."],[2281,2360,"I'm Raymond,"],[2398,2506,"and this is Frank."],[2865,3040,"What are you doing here, Hugo?"],[3119,3310,"My mom works in that office."],[3386,3520,"I'm waiting for her."],[3799,3862,"Raymond,"],[3912,4166,"is it okay if I introduce you guys to my mom?"],[4254,4471,"It would be a pleasure for her to meet my friends."],[4533,4592,"Sure."],[4704,4758,"Yeah?"],[4788,4864,"Yeah, no problem."],[4938,5038,"Your mom sounds great."],[5113,5159,"I mean,"],[5159,5251,"moms are great people."],[5326,5372,"She is."],[5451,5499,"Fist bump."],[5834,5901,"Come on."],[5901,5976,"All right."],[7011,7109,"Are you Vesper Brown?"],[7157,7396,"The girl who won first place in the Sun Awards?"],[7428,7474,"Yes,"],[7486,7557,"nice to meet you."],[7720,7778,"Sorry,"],[7816,7891,"I didn't mean it."],[7978,8259,"I guess your reflexes aren't as good as your drawings."],[8345,8493,"You know, good design skills are"],[8493,8654,"not everything here at River."],[8867,9017,"Don't bully my mom."],[9129,9218,"It's okay, baby."],[9263,9473,"So what? Am I not qualified to work here?"],[9559,9843,"You're just like many of the poor girls coming here,"],[9897,10001,"looking for glory."],[10080,10155,"Just another"],[10155,10285,"shameless slut."]],"40":[[462,588,"Let go of me!"],[588,700,"Who the hell are you?"],[729,913,"Did you get a place in the Sun Awards too?"],[1009,1080,"Frank,"],[1151,1205,"get Bill."],[1205,1380,"Let's see exactly what's going on here."],[1418,1472,"Got it."],[1509,1559,"Bill?"],[1593,1705,"Our CEO?"],[1772,1860,"You're bluffing."],[1872,2022,"Why did you stand up for her?"],[2122,2231,"She's my wife."],[2556,2602,"Bill."],[2623,2752,"Ah, President Ronald."],[2786,2911,"I just sent the forms over your way."],[2915,3002,"Well,"],[3053,3207,"this is my wife"],[3207,3361,"and it appears that she is being bullied"],[3361,3530,"by one of my employees."],[3603,3799,"Is this the company culture here,"],[3812,3858,"Bill?"],[3970,4112,"Madam, I apologize."],[4112,4208,"Mr. President, I'm so sorry."],[4283,4333,"Cora,"],[4341,4500,"effective immediately, you're fired."],[4558,4688,"You pack your things."],[4842,4892,"No, no, no."]],"41":[[100,154,"No, no, no."],[212,286,"Please."],[433,613,"Vesper, I am so sorry."],[675,844,"Please, give me another chance."],[863,967,"I can't lose my job."],[2777,2840,"Raymond,"],[2890,2969,"it's been a while."],[3028,3086,"I mean,"],[3136,3199,"thanks."],[3240,3278,"You know,"],[3278,3470,"I really didn't realize this was your company."],[3516,3595,"Yeah,"],[3611,3774,"yeah, it's been a long time."],[3883,4129,"I didn't really expect to meet you here."],[4158,4208,"Mom,"],[4225,4373,"this is my new best buddy."],[4446,4533,"How is that?"],[4604,4729,"Isn't he awesome?"],[4825,5084,"It's best to call people by their names, Hugo."],[5196,5256,"Frank,"],[5288,5393,"can you take Hugo outside?"],[5401,5563,"I want to talk to Raymond alone."],[6331,6456,"When you left all that time ago,"],[6456,6588,"why didn't you say anything?"],[6631,6865,"Do you know how desperate I was?"],[7019,7127,"I've been looking for you"],[7157,7236,"for the last"],[7236,7357,"nine"],[7357,7461,"years."],[7520,7595,"Why?"],[7636,7766,"What do you still want of me?"],[7811,7876,"Hmm?"],[7978,8164,"Do you hate me that much?"],[8191,8283,"What the hell"],[8283,8414,"are you talking about?"],[8558,8666,"You mean your child?"]],"42":[[29,108,"Please, don't ever"],[108,208,"think about hurting Hugo."],[266,375,"How do you even know each other?"],[375,529,"I've never think to do that."],[671,742,"Look,"],[846,1000,"we just happened to meet."],[1184,1263,"Then thanks."],[1388,1564,"So he's the kid from nine years ago."],[1714,1776,"Vesper,"],[1922,1972,"who"],[2014,2072,"is"],[2122,2224,"the father?"],[2302,2445,"This is none of your business."],[2445,2561,"Okay, Mr. Ronald?"],[2590,2652,"Look,"],[2736,2869,"thanks for today,"],[2894,2982,"but please"],[2994,3149,"just leave me and Hugo alone."],[3178,3374,"I promise I'll quit my job at your company."],[3374,3485,"In your dreams,"],[3485,3557,"Vesper Brown."],[3641,3791,"When you left nine years ago,"],[3824,4032,"you forgot that the contract never expired."],[4112,4195,"That means"],[4204,4391,"you're in breach of the contract."],[4396,4548,"And when you're in breach of the contract,"],[4548,4813,"you have to work for me the rest of your life."],[4913,5042,"You can't escape me."],[5342,5472,"When are we going?"],[5526,5684,"I'm starting to get really hungry."],[6026,6072,"Alright,"],[6143,6231,"I'll work for you."],[6289,6339,"But"],[6410,6456,"we"],[6498,6606,"we have to go home now."],[7795,7853,"Let's follow them."],[7970,8053,"See where they're going."],[8103,8162,"Alright."],[9651,9855,"Vesper, Hugo!"]],"43":[[342,487,"Congratulations on the induction,"],[487,533,"Vesper."],[550,625,"Thank you."],[704,763,"Shall we?"],[784,821,"Yeah."],[1839,1925,"Who's the father, then?"],[1997,2135,"Is it that jerk outside?"],[2235,2360,"Obviously, he knows you didn't"],[2360,2456,"have a miscarriage."],[2456,2615,"No, I swear it's not him."],[2615,2706,"Please don't hurt him."],[2765,2924,"He's the one that saved the baby."],[2927,3040,"Then who is it?"],[3107,3249,"She's been lying to me."],[3328,3503,"Oakley is actually the child's father."],[3716,3793,"He took her away."],[3841,3952,"No wonder I couldn't find her."],[3966,4121,"The Oakleys has been protecting her."],[4245,4320,"But boss,"],[4446,4558,"I had Bill send over a copy of"],[4558,4661,"Miss Brown's resume."],[4783,4900,"It says she's unmarried."],[5038,5125,"I don't need this."],[5226,5376,"Married or not, she'll be mine."],[5480,5613,"Even if she didn't marry that bastard"],[5613,5788,"in secret, I'll kill him and get her back."],[5876,5943,"What do you need?"],[6047,6147,"Go back to the office,"],[6147,6202,"Frank."],[6281,6373,"I've got a new plan."],[6481,6556,"Roger that."],[6973,7044,"Vesper,"],[7044,7294,"you will regret choosing Colton Oakley."],[8058,8174,"Good morning, Mrs. Ronald."],[8237,8354,"No, no, I'm not."],[8383,8441,"Just"],[8441,8516,"call me Vesper."],[8604,8732,"Okay, Vesper."],[8754,8812,"Here's the deal."],[8850,8961,"You have a new office"],[8961,9056,"and a station,"],[9075,9254,"and I'll walk you over to it."],[9317,9432,"Wait, what are you mean?"],[9480,9584,"Um."],[9584,9703,"You're President Ronald's"],[9703,9800,"new secretary."]],"44":[[412,471,"President,"],[500,625,"Miss Brown is here."],[1096,1284,"You want me to be"],[1284,1413,"your secretary?"],[1472,1530,"Right."],[1605,1822,"The office closest to mine will be yours from now on."],[1885,1972,"How could you,"],[1972,2047,"Raymond?"],[2093,2277,"I struggled for eight years"],[2277,2381,"to become a good designer,"],[2431,2489,"and you just"],[2489,2652,"changed everything so easily."],[2656,2798,"Okay, okay, take it easy."],[2882,3023,"I know your talent."],[3061,3244,"My secretary can be a designer, too."],[3653,3787,"I just came to Miami"],[3787,3995,"and I don't have any trusted subordinates here."],[4108,4291,"So you are the only one I can trust."],[4358,4458,"Besides,"],[4458,4658,"you also happen to be my new friend's mother."],[4938,5096,"I'd like you to help me design this collection."],[5292,5476,"Part of your duties as being my new secretary"],[5501,5576,"is every month"],[5576,5718,"I'd like you to give me proposals."],[5780,5851,"Nothing too hard,"],[5851,6010,"just simple ideas."],[6114,6213,"I know in your eyes"],[6213,6363,"I'm still just a poor student,"],[6381,6475,"but I've worked hard"],[6475,6677,"over the past years to be a great designer."],[6744,6840,"And I will"],[6865,7006,"prove my ability to you."],[7215,7344,"You always surprise me,"],[7394,7469,"Vesper."],[7582,7632,"Raymond,"],[7632,7828,"Grandma said you were going to be based in Miami,"],[7828,7998,"so I rushed over to be with you."]],"45":[[204,254,"Bonnie?"],[392,479,"Can't you knock?"],[479,588,"This isn't the Wood Group."],[654,738,"What the hell"],[738,848,"are you doing here?"],[880,988,"Didn't you disappear,"],[988,1038,"you bitch?"],[1059,1188,"I said, get out,"],[1188,1330,"leave my office, now."],[1397,1539,"After all these years,"],[1593,1701,"you haven't changed a bit."],[1768,1868,"You, too."],[1893,2078,"Still so seductive."],[2135,2252,"Raymond and I are"],[2252,2376,"getting married next month."],[2385,2531,"You poor slob"],[2531,2715,"better stay away from him."],[3653,3770,"You're getting married?"],[3920,3974,"Well,"],[4012,4145,"congratulations, President."],[4237,4317,"If necessary,"],[4317,4458,"I'll step down from my position here"],[4458,4583,"so as to not distract you."],[4596,4708,"You wouldn't dare."],[4771,4884,"Don't make me take you to court"],[4884,4996,"with the contract."],[5021,5138,"Let go of me!"],[5209,5355,"You're gonna be a married man."],[5413,5534,"Best not to get too close"],[5534,5630,"to a single mom."],[5705,5818,"What, are you jealous?"],[6060,6227,"What if I have to be close to you?"],[6381,6423,"No,"],[6456,6498,"don't."],[6652,6710,"Why?"],[6819,6944,"Because you're in a relationship with"],[6944,7036,"Colton Oakley."],[7115,7232,"Every time"],[7232,7319,"I remind myself"],[7319,7439,"that he's the reason you left,"],[7439,7515,"I want to kill"],[7545,7648,"that bastard."]],"46":[[100,196,"But you can't,"],[216,271,"can you?"],[300,433,"Are you provoking me?"],[517,567,"Yes."],[646,754,"Colton is the heir"],[775,896,"to the Oakley family."],[984,1092,"He is just"],[1134,1276,"as powerful"],[1309,1397,"as you."],[1493,1547,"But,"],[1584,1659,"unlike you,"],[1659,1760,"he has shown me"],[1772,1872,"how much he's cared for me"],[1872,2001,"many times."],[2243,2339,"You're in love with him."],[2506,2660,"That's the reason you betrayed me."],[2794,2911,"He's Hugo's father too,"],[2911,2992,"isn't he?"],[3053,3119,"Right,"],[3211,3386,"hence don't bother us outside of work."],[3620,3687,"Thank you."],[3703,3837,"I'll get to work on this right away,"],[3858,3928,"President."],[5659,5747,"Colton,"],[5768,5955,"I saw Vesper at Raymond's company."],[5989,6160,"Raymond made her his secretary."],[6197,6260,"What?"],[6364,6431,"No way."],[6510,6690,"Vesper never told me she met Raymond."],[6752,6861,"How could she tell you?"],[6902,7052,"If you hadn't promised to marry her"],[7052,7140,"nine years ago,"],[7152,7294,"I wouldve killed her in secret."],[7328,7478,"After all this time, you still didn't make that"],[7478,7609,"bitch fall in love with you."],[7636,7724,"You're useless!"],[7895,8037,"You, too President Lockwood."]],"47":[[217,291,"Who are you?"],[325,467,"What is she telling you to do with Vesper?"],[675,771,"Give it back to me."],[1213,1409,"I just knew you'd try to do something."],[1447,1597,"You better not be trying to hurt her again."],[1701,1872,"Are you cheating on me again, Raymond?"],[1926,2039,"I'm your fiancée."],[2068,2177,"You're out of your mind!"],[2231,2385,"How many times do I have to tell you"],[2394,2481,"I am not"],[2489,2569,"marrying you?"],[2652,2781,"I'm going to tell Grandma."],[2969,3028,"You know,"],[3028,3240,"I am far from Raymond of nine years ago."],[3282,3461,"I have more power, not only in Miami,"],[3461,3670,"but all over the East Coast, so just try telling her"],[3691,3824,"and see what she can do for you."],[4158,4223,"Then let's bet on it"],[4223,4379,"and see whose side God is on!"],[5689,5776,"What's going on?"],[6097,6185,"How did I"],[6185,6272,"get here?"],[6694,6756,"God,"],[6756,6873,"why do I feel so hot?"],[7286,7353,"Go ahead."],[7399,7503,"If you can get her pregnant,"],[7503,7725,"I'll give you another half a million dollars."]],"48":[[846,930,"Look at you,"],[1000,1105,"so beautiful."],[1180,1246,"Who are you?"],[1288,1385,"Who sent you?"],[1488,1534,"Don't"],[1555,1618,"touch me."],[1751,1793,"God,"],[1814,1969,"why is my face so hot?"],[2047,2160,"You've been drugged, sweetie."],[2310,2431,"Relax and let's have some fun."],[2460,2560,"Quick and easy, come on."],[2652,2744,"Do you want money?"],[2790,2877,"I've saved up some money."],[2882,2973,"I can give you everything."],[2994,3161,"I don't need your money, I need you."],[3224,3282,"Come on."],[3566,3670,"Piss off, okay?"],[3670,3778,"Don't touch me."],[3858,4049,"Let's see how I'll make you beg for mercy?"],[4412,4504,"My boss said"],[4529,4675,"that if you don't obey to me,"],[4717,4925,"it'll be a tough night for this little kid."],[5384,5463,"Raymond,"],[5509,5593,"help me."],[6014,6072,"Vesper."]],"49":[[191,250,"Vesper."],[754,863,"Pick a way to die."],[905,1013,"Who the hell are you?"],[1021,1126,"We're having fun."],[1230,1317,"Boss, I'm here."],[1388,1543,"Give him back to our man, Frank."],[1664,1757,"Find out who sent him."],[1785,1860,"Yes, boss."],[2780,2852,"Vesper,"],[2911,2973,"are you okay?"],[3219,3319,"What brings you here?"],[3511,3578,"The men I have"],[3636,3728,"protecting you."],[3757,3849,"They told me that someone drugged you"],[3849,3945,"and carried you here."],[4016,4162,"I came with Frank as soon as I could."],[4275,4346,"Thanks."],[4379,4437,"You should"],[4479,4521,"go."],[4537,4621,"I have to sleep."],[4821,4884,"Listen to me."],[4892,5009,"I'm going to kill"],[5009,5138,"the bastard that drugged you."],[5534,5730,"Hey, I think hospital is a better place"],[5730,5809,"for you right now."],[5830,6056,"No. No, you need- You need to leave."],[6330,6422,"Vesper..."],[7595,7714,"Kiss me, Raymond."],[7832,7882,"No."],[7916,8016,"No, you're not sober right now."],[8016,8112,"You're gonna regret it."],[8308,8345,"I..."],[8575,8679,"I love you, Raymond."]],"50":[[4233,4316,"What did you do to me?"],[4550,4596,"What?"],[4754,4917,"Don't tell me you forget."],[5159,5301,"Did you bring me here?"],[5338,5401,"No."],[5538,5659,"You took the initiative for this,"],[5659,5722,"don't you remember?"],[6022,6131,"I love you, Raymond."],[6577,6639,"Vesper,"],[6656,6769,"you were so stupid."],[6815,6852,"No,"],[6927,7015,"I can't recall."],[7111,7207,"Why are we here again?"],[7394,7440,"Really?"],[7578,7678,"You don't remember anything?"],[7820,7920,"You told me you loved me."],[7966,8058,"No, I didn't."],[8133,8274,"This is so ungentlemanly."],[8462,8587,"I guess it's all my fault."],[8704,8846,"Can I be responsible for you?"]],"51":[[75,212,"No, I'm going home."],[291,346,"No."],[433,546,"Look, just let me drive you back."],[654,813,"Besides, I miss my friend Hugo."],[938,1147,"How did you two become friends?"],[1288,1434,"Hugo needs a new daddy, Vesper."],[2998,3094,"What are you showing me?"],[3165,3269,"Why do you have a camera?"],[3357,3457,"A surprise."],[3524,3749,"From now on, all the trouble will be over."],[4838,4925,"Raymond?"],[5021,5134,"It's you?"],[5401,5518,"What are you doing with her/him?"],[5939,6005,"Frank,"],[6022,6135,"no need for a trial."],[6177,6322,"Bonnie's planned everything."],[6398,6585,"Oh, and buy out the Wood Group shares."],[6673,6777,"No, no, Raymond,"],[6777,6848,"please."],[6890,6952,"Let's go."],[6994,7182,"I see, you know her well, Colton."]],"52":[[379,533,"It's not what you think, Vesper."],[550,771,"It was my first time seeing her in nine years."],[800,855,"Yeah?"],[884,1038,"But you showed up with her and her camera."],[1063,1138,"So you've been in touch."],[1159,1363,"Even if I did, I was doing it for your safety."],[1388,1559,"I don't know why she brought me here today."],[1559,1630,"She drugged her."],[1668,1789,"Why do you think she had a camera?"],[1851,1926,"You heard him."],[1985,2093,"If it weren't for Raymond,"],[2093,2218,"I would have been dead by now."],[2273,2356,"So you two..."],[2373,2548,"You were together last night, weren't you?"],[2590,2723,"You know, whatever implying,"],[2723,2781,"Mr. Oakley,"],[2781,2878,"I really don't care."],[2927,2994,"Leave us alone."],[3065,3132,"So it's true."],[3153,3319,"I guess saving Vesper nine years ago"],[3319,3449,"is the right thing to do, huh?"],[3490,3625,"You know, I hear you're not actually"],[3625,3699,"her husband."],[3728,3853,"You have no right to interfere with"],[3853,3958,"my relationship with her."],[3991,4033,"Oh yeah?"],[4070,4200,"And what are you, Mr. Raymond?"],[4308,4487,"I hear 7th Street has been infighting lately."],[4562,4633,"Why is that,"],[4633,4683,"Mr. Oakley?"]],"53":[[12,116,"Stop it, you two."],[211,315,"I have to hurry home."],[315,479,"Hugo has been alone for way too long."],[671,738,"Let's go."],[763,896,"I want to see Hugo, too."],[950,1071,"He likes me better, anyways."],[1176,1388,"Has he been using this lie for nine years?"],[1388,1497,"It's not a lie."],[1497,1572,"It's the truth."],[1622,1785,"Oh, and by the way, Mr. Raymond,"],[1810,1935,"the reason for the recent drop"],[1947,2077,"in the RR group share price"],[2118,2193,"I have the answers,"],[2193,2310,"in case you're interested."],[3349,3507,"Mom, you're finally home."],[3607,3691,"Sorry, baby."],[3699,3849,"Mommy was a little busy yesterday."],[3874,3987,"Hugo, how you been?"],[3999,4179,"I'm fine, Uncle Colton."],[4212,4295,"Uncle?"]],"54":[[246,417,"Raymond, you finally came to visit."],[467,567,"Welcome."],[684,871,"It's... just a little game"],[871,963,"between the two of them."],[996,1130,"People like you wouldn't understand."],[1388,1567,"I've missed you so much."],[1580,1726,"I've even learned how to swim."],[1785,1860,"When are you gonna take me to"],[1860,1947,"the movies again?"],[2010,2127,"Anytime you want, Champ."],[2560,2795,"Hey, Hugo, do you like basketball?"],[2831,3031,"I know a NBA star in Miami."],[3098,3207,"Raymond, you're the"],[3207,3278,"best!"],[3374,3436,"Hugo,"],[3486,3595,"Raymond has things to do."],[3595,3661,"Say goodbye."],[3699,3782,"You're leaving?"],[3853,4026,"No, no, I'm not busy."],[4026,4162,"I'll help you cook dinner."],[4233,4329,"I'm not busy either."],[4358,4441,"I'll help out."],[4884,4979,"Where's Raymond?"],[5013,5150,"At Vesper Brown's house."],[5171,5246,"For lunch."],[5309,5420,"With Brown, her son"],[5420,5538,"and Mr. Oakley."],[6544,6681,"Bad news, President."],[6756,7040,"RR group has taken away all our shares."],[7115,7223,"The shareholders"],[7223,7436,"are all on the side of Hell Gang."],[7549,7762,"I've waited nine years for him."],[7841,7924,"For Raymond."],[7924,8112,"And this is how he treats me."],[9146,9242,"This boy"],[9338,9497,"and Raymond, what a look-alike."],[9605,9684,"Mark,"],[9713,9857,"find a way to get the hair of these two"],[9868,10006,"and do a paternity test."],[10155,10250,"Yes, President."]],"55":[[517,613,"What the hell?"],[2765,2973,"Why are they not here yet?"],[3190,3265,"Where are they?"],[3449,3553,"Don't talk to me like that."],[3687,3837,"I'm not your assistant, big boy."],[4458,4504,"Yes?"],[4892,4938,"What?"],[5818,5914,"You again."],[5985,6072,"Where's my son?"],[6072,6235,"I'll kill you if you hurt my son."],[6306,6418,"What a great mom."],[6523,6606,"Vesper."],[6652,6823,"Raymond and your son don't even know"],[6823,6961,"their relationship, do they?"],[6977,7082,"You gave them"],[7107,7265,"a paternity test?"],[7311,7394,"Exactly."],[7557,7873,"You really are a very cheap bitch, Vesper."],[7916,8112,"You took my first place in school,"],[8112,8295,"seduced Raymond to be his mistress"],[8308,8441,"and had his baby."],[8658,8875,"Shall I tell your son that his mother was once a"],[8875,9054,"mistress who sold herself for money?"],[9113,9342,"If you say anything to my son,"],[9342,9551,"I'll tear you to pieces!"],[9659,9955,"You really have a sense of humor, Vesper."],[10005,10147,"You're threatening me when your life is"],[10147,10275,"in my hands?"],[10331,10377,"Or"],[10435,10652,"let me scratch your face first."],[13396,13455,"President,"],[13517,13724,"the Oakley family and the Hell Gang are here."],[13788,13902,"Don't be afraid."],[13963,14122,"We've got the bitch, so"],[14172,14360,"they dare not do anything."],[14410,14614,"Transfer the bitch and that little bastard"],[14614,14731,"to the second floor."],[14789,14964,"Strap them to the bombs."],[14973,15023,"Got it."],[15023,15081,"Bombs?"],[15123,15186,"Hugo."],[15252,15298,"No."],[15340,15457,"Please let my son go."],[15486,15628,"I'll do anything, please!"],[15970,16082,"- Let her go! - Let her go!"]],"56":[[16,200,"You guys really love her."],[233,425,"You came much faster than I thought."],[425,496,"Bonnie,"],[513,700,"let go of Vesper and Hugo now."],[742,875,"Both of our men are already here."],[875,1034,"You will be riddled with bullets."],[1146,1334,"You think I'd be afraid to die?"],[1372,1543,"I've loved this asshole for 20 years."],[1543,1707,"I can't even compete with a bitch."],[1730,1960,"The company my father left me is taken away."],[1968,2098,"Bonnie, calm down."],[2098,2210,"I'll give you back all the equity."],[2348,2435,"What do you want"],[2464,2581,"and where are you taking Vesper?"],[2623,2698,"It's too late."],[2756,2994,"Now I just want to die with her."],[3061,3144,"See this?"],[3207,3331,"The bitch and little bastard are"],[3331,3449,"strapped to bombs."]],"57":[[45,237,"With a bang, they can go to God!"],[421,475,"Hey,"],[521,642,"Bonnie, don't be impulsive."],[729,875,"Look, tell me what you want."],[875,1005,"Just say I'll give you anything."],[1067,1226,"I don't trust you anymore, Raymond."],[1305,1530,"Even if you did marry me instead of her,"],[1530,1685,"you'd still be very cold to me,"],[1685,1922,"just like the past nine years."],[2031,2248,"Okay, please don't touch it."],[2402,2481,"Please."],[2569,2806,"Really, I can promise you anything."],[2932,3115,"I know more than you think, Raymond."],[3157,3299,"Secrets, I'll take to the grave,"],[3299,3611,"while you'll be left poor and desperate."],[3657,3770,"Bonnie, listen to me."],[3803,3916,"This is my offer."],[3941,4208,"Let go of Vesper and Hugo and I will give you access"],[4208,4371,"to all of the men from the Oakley family"],[4371,4433,"from now on."],[4466,4558,"Think about it, Bonnie."]],"58":[[150,221,"Hell Gang,"],[354,454,"Oakley family."],[592,646,"Yeah,"],[713,859,"I've got a new idea."],[967,1194,"Bosses, you must have the gang's private seals"],[1194,1272,"with you, right?"],[1376,1597,"I know the underbosses of all districts"],[1597,1846,"only listen to whoever holds a private seal."],[1939,2077,"Give me your personal seals,"],[2110,2277,"then I'll let them go."],[2318,2535,"I'll swallow up the Oakley family and the Hell Gang,"],[2544,2794,"even Sicily will listen to me from now on."],[3165,3319,"If this personal seal to you."],[3319,3374,"Okay."],[3453,3545,"I promise."],[3670,3962,"But only if you let Vesper and Hugo go."],[4179,4333,"Give me the seals first."],[4387,4550,"I'll tell after I get them."],[4850,4929,"Raymond, no,"],[4929,5146,"she's lying to you. Don't fall for her trap."],[5238,5397,"I've been looking for Vesper for nine years."],[5397,5538,"I can't let her go a second time."],[5634,5772,"I'll do anything for her."],[5868,5980,"Aren't you the same?"],[6156,6193,"Yeah."],[6377,6439,"Hurry up."],[6477,6664,"I don't have a lot of patience."],[6827,6906,"Very well."],[6965,7140,"I'll count three, two, one,"],[7140,7344,"and you both throw them to me"],[7344,7449,"at the same time."],[7515,7678,"But if one of you two doesn't,"],[7707,7836,"I'll press the control."],[8024,8204,"Three."],[8229,8441,"Two."],[8466,8692,"One."],[9071,9121,"Colton?"],[9138,9200,"Sorry."]],"59":[[141,333,"Not everyone loves that bitch."],[479,554,"I'm sorry."],[788,892,"That's great."],[909,1092,"We can finally get rid of her."],[1359,1443,"Boss, I'm here to help."],[1493,1605,"And our men are on the way."],[1668,1755,"Well done, Frank."],[1985,2089,"Search the facility."],[2122,2235,"The hostages are still here."],[2235,2344,"We have to defuse the bomb."],[2377,2444,"Yes! Boss."],[2498,2686,"Frank, the seal belongs to me now."],[2686,2806,"You have to listen to me."],[2806,2915,"Let go of me now!"],[2944,3032,"Fuck your seal."],[3032,3178,"I only listen to the boss."],[4291,4362,"Boss,"],[4437,4600,"we've found them and defuse all the bombs."],[4633,4721,"They're fine."]],"60":[[141,333,"Bitch, do you know who saved your ass?"],[362,575,"I told the two men I'd let you go if they both"],[575,767,"threw their seals to me at the same time."],[813,950,"Colton gave me his right away,"],[950,1088,"while Raymond hesitated."],[1113,1284,"He doesn't love you at all."],[1822,1935,"Thank you, Colton."],[2022,2152,"You saved me and Hugo again."],[2285,2389,"You're welcome, Vesper."],[2519,2581,"Boss,"],[2598,2702,"tell her the truth."],[2848,2911,"It's fine."],[3103,3228,"Let's just pack up and go, Frank."],[3357,3470,"I'm sorry, baby."],[3541,3712,"Mom mustn't protect you so well."],[3828,3978,"Say thank you to Uncle Colton."],[3995,4049,"You know,"],[4049,4166,"the day we met him,"],[4175,4350,"he saved you when you were just in my tummy."],[4542,4667,"Thanks, Uncle Colton."],[4692,4842,"I'm really grateful for having you."],[4921,5030,"Don't worry, Hugo."],[5663,5789,"The first day you met him..."],[5943,6031,"At the banquet?"],[6172,6310,"And you're already pregnant."],[6418,6594,"So Colton's not the father?"]],"61":[[16,191,"Raymond, you're scaring him."],[342,458,"You two know something."],[504,600,"Why aren't you tell me?"],[600,725,"Why have you been lying to me?"],[875,1126,"Alright, I did lie, okay, Raymond?"],[1176,1351,"But it's getting late. Let's just get out of here first."],[1388,1451,"No."],[1534,1685,"No, no, no, something's wrong."],[1822,2068,"Mom, can I have mangoes after dinner?"],[2185,2310,"No way."],[2369,2493,"You're allergic to mangoes,"],[2493,2640,"but still love the taste the most."],[2677,2761,"It's not happening."],[2823,2911,"Really?"],[2927,3078,"Me too, actually."],[3465,3649,"I know more than you think, Raymond."],[3695,3849,"Secrets, I'll take to the grave,"],[3849,4141,"while you'll be left poor and desperate."]],"62":[[175,250,"Frank,"],[296,450,"can you take Hugo back to the car?"],[508,700,"I have to talk to Raymond alone about something."],[788,850,"Take her."],[1034,1121,"You okay, Hugo?"],[1188,1255,"Let's go."],[1876,1935,"You are not"],[1964,2064,"the father, Raymond."],[2177,2218,"Hey!"],[2298,2360,"Stop!"],[2464,2556,"Why are you guys picking on him?"],[2644,2836,"So he's the kid from nine years ago."],[2965,3040,"Vesper,"],[3174,3253,"who"],[3265,3353,"is"],[3378,3490,"the father?"],[3566,3816,"It's none of your business. Okay, Mr. Ronald?"],[3858,3908,"Look,"],[3999,4158,"thanks for today,"],[4160,4256,"but please,"],[4256,4412,"just leave me and Hugo alone."],[4450,4637,"I promise I'll quit my job at your company."],[4725,4842,"Raymond, let me explain."],[5100,5205,"You've always lied to me."],[5342,5426,"But you know the truth."],[5526,5649,"I have my reasons."],[5793,5905,"I thought you betrayed me."],[5980,6131,"Nine years and"],[6131,6285,"I've never fulfilled my duties as a father"],[6285,6377,"for even one day!"],[6519,6685,"My son almost just died today."],[6706,6817,"Easy, Raymond."],[6844,7061,"You really need to calm down and listen to Vesper."],[7132,7269,"You knew about this, didn't you?"],[7353,7532,"Nine years and you ran away with my woman"],[7532,7628,"and my son!"]],"63":[[100,296,"Raymond, don't act like that."],[342,525,"I asked him to take me away."],[571,704,"Lockwood had already been threatening"],[704,821,"Vesper with Jake back then,"],[838,992,"and you could only listen to your grandma."],[1059,1113,"Yeah,"],[1163,1238,"you remember?"],[1393,1476,"No, Grandma,"],[1509,1626,"I don't need your help."],[1672,1976,"I'll abort the child in the bitch's belly"],[1976,2160,"and drive her away."],[2268,2373,"No, Grandma,"],[2398,2540,"I'm not lying to you."],[2577,2857,"I have never been obsessed with her."],[2936,3044,"She's just"],[3086,3199,"my plaything."],[3307,3516,"If she dares to betray me,"],[3603,3774,"I'll take my revenge."],[3824,3941,"And if she resists,"],[4079,4204,"I will"],[4204,4316,"kill her."],[4450,4542,"These are your words."],[4583,4667,"Aren't they?"],[4746,4896,"Don't even try to deny it, Raymond."],[4913,5004,"I have the proof,"],[5025,5146,"all recorded."],[5226,5385,"How do you expect me to stay with you"],[5385,5484,"after hearing that?"],[5492,5672,"That was a strategy to steer her away from you,"],[5672,5722,"Vesper."],[5784,5955,"If I didn't say any of that,"],[5955,6056,"she would've killed you"],[6081,6165,"herself."],[6193,6393,"But no one knows what the truth really is."],[6443,6557,"After all, you didn't even know"],[6557,6698,"that was your baby back then."],[6973,7069,"It's you, wasn't it?"],[7123,7232,"How dare you call me"],[7232,7336,"a fucking asshole!"]],"64":[[58,166,"I'm sorry, Colton."],[246,404,"Please, can you just let me and Raymond talk alone?"],[450,517,"You're serious?"],[558,696,"Please, Colton!"],[1451,1696,"I won't apologize to you, Raymond."],[1776,1876,"Whether those words came from your"],[1876,1980,"heart or not,"],[2014,2160,"it still hurt me"],[2160,2317,"for those nine years."],[2373,2530,"You know, I suddenly realized, Vesper,"],[2530,2665,"why you've never really believed in me."],[2798,2940,"If I were you,"],[2940,3090,"nine years ago, and I heard those words,"],[3115,3173,"I would have known"],[3173,3294,"it was a measure of protection."],[3407,3570,"What the hell are you talking about?"],[3645,3824,"Raymond, you were supposed to be furious"],[3824,3987,"at me for carrying another man's baby."],[4029,4120,"You said"],[4120,4237,"you would make me pay!"],[4237,4354,"How am I supposed to trust that"],[4354,4450,"you'd protect me?"],[4466,4621,"But I was giving you all the best."],[4683,4813,"I've always protected you."],[4925,5063,"Why have I ever hurt you?"],[5184,5284,"You hurt me"],[5309,5522,"with your words every day"],[5563,5650,"for those years."],[5651,5910,"You thought I was just a shameless gold digger!"]],"65":[[41,275,"That's because you never told me the $100,000"],[275,458,"was for your father's medical bills."],[529,583,"You know,"],[621,763,"I don't have to tell you everything."],[763,821,"I know,"],[821,880,"I know, I know."],[938,1055,"It's about your self-esteem"],[1080,1188,"and the fact that you've been leaving off the"],[1188,1313,"Ronald family's charity grants."],[1355,1463,"Oh please,"],[1493,1576,"Mr. Ronald."],[1622,1739,"Stop talking"],[1760,1931,"to me so condescendingly."],[1964,2277,"I am not your contract lover anymore."],[2314,2398,"Okay, look."],[2398,2548,"whether it was nine years ago or now,"],[2548,2727,"what makes you think I've always been like that?"],[2765,2865,"These questions"],[2865,2977,"are very boring."],[3002,3086,"Mr. Ronald."],[3135,3212,"You keep asking them"],[3212,3339,"while knowing damn all the answer."],[3386,3513,"I'm gonna go see my son."],[3513,3572,"No."],[3603,3757,"Just because I'm the boss of Hell Gang,"],[3757,3866,"the president of RR Group,"],[3866,4029,"doesn't mean I boss everyone around."],[4200,4312,"I've never treated you like that."],[4466,4554,"Never like that?"],[4637,4796,"Raymond, have you lost your memory?"],[4900,5042,"You tortured me"],[5063,5176,"for those three years."],[5192,5288,"Whether it was"],[5288,5509,"indifference or sarcasm"],[5518,5597,"or in bed,"],[5672,5754,"wasn't it just because you thought"],[5754,5860,"I was a poor student?"],[5860,5976,"It's because I'm deeply"],[5976,6110,"in love with you, okay?"]],"66":[[25,200,"But you sold your body to me for money."],[354,504,"I fucking fell in love with you"],[550,696,"when we were teenagers."],[875,971,"You're deceiving me."],[1009,1059,"I'm not."],[1192,1255,"Stop."],[1284,1380,"Raymond."],[1380,1484,"It won't work."],[1484,1589,"No matter what you say,"],[1589,1768,"can't change my mind"],[1768,1947,"or take away my disappointment."],[2122,2185,"No."],[2243,2394,"Come back to Chicago with me."],[2452,2523,"You and Hugo."],[2569,2681,"I'll give you the best protection."],[2681,2819,"I'll offer him the best education."],[2848,2919,"No."],[2986,3123,"Just look what happened today."],[3249,3470,"Hugo almost died"],[3486,3586,"because of you!"],[3649,3791,"Look what you did"],[3791,3916,"brings him."],[3916,4133,"You only bring him danger."],[4245,4425,"You don't know what life"],[4425,4547,"and responsibilities are,"],[4547,4763,"but I have to teach Hugo these things."],[4925,5038,"Raymond,"],[5255,5384,"I don't want to see you"],[5426,5509,"anymore."],[6085,6202,"This is our fate."],[6314,6519,"Just let it be."],[8179,8241,"Boss,"],[8270,8454,"are we really just heading back to Chicago?"],[8483,8533,"Yes."],[8587,8650,"Why?"],[8988,9060,"Actually, boss,"],[9060,9180,"I have a lot of questions."],[9492,9680,"No questions right now, Frank."],[9680,9843,"It's best to keep everything to yourself."]],"67":[[633,767,"Don't be sad, Vesper."],[825,925,"It's over now."],[1000,1138,"You can go back to your normal life."],[1159,1259,"I don't need this."],[1601,1743,"I'm sorry, Colton."],[1847,1960,"You saved me yesterday,"],[1960,2158,"and I didn't get a chance to say thank you."],[2206,2277,"Please."],[2381,2448,"Don't bring it up."],[2619,2794,"It makes me feel guilty in a way."],[2915,2965,"Why?"],[3157,3303,"Because I didn't give up the seal for you."],[3461,3532,"Raymond did."],[3653,3753,"Bonnie lied to you."],[3791,3924,"If Frank hadn't shown up"],[3983,4145,"on time, you would‘’ve been in danger"],[4145,4225,"because of me."],[4471,4587,"Oh, my God."],[4679,4756,"Raymond."],[4788,4884,"I'm sorry, Vesper."],[5059,5196,"I should have mentioned it sooner."],[5376,5422,"In fact,"],[5422,5480,"in the moment,"],[5480,5692,"I realized that he loved you more than I did."],[5855,5992,"I just didn't want to admit it."],[6164,6339,"He loves you so much that he's"],[6373,6527,"willing to give up everything for you."],[6706,6777,"Where is he?"],[8049,8137,"Wait for me, Raymond."],[8158,8278,"I really shouldn't have said those words"],[8278,8344,"to hurt you."],[8395,8479,"I love you, too."],[8516,8587,"Raymond!"],[9059,9138,"Raymond!"]],"68":[[37,95,"Raymond!"],[396,454,"Please,"],[550,617,"don't go."],[671,792,"Stay with me and Hugo."],[884,938,"Raymond."],[1051,1101,"I love you."],[1201,1305,"I love you so much."],[4725,4817,"Raymond?"],[5826,5889,"Frank!"],[5989,6076,"Where's Raymond?"],[6247,6385,"Boss went out on an emergency."],[6385,6431,"He..."],[6443,6560,"didn't say where he was going."],[7148,7211,"Hello?"],[7261,7311,"Dad."],[7511,7628,"Yeah, no problem."],[7628,7741,"I'll come and meet you."],[7949,7995,"Frank,"],[7995,8128,"let me know as soon as you reach Raymond."],[8345,8467,"As you wish, Miss Ronald."],[10026,10105,"Hey,"],[10135,10218,"Dad."],[10276,10431,"Sorry I'm late, but..."],[10510,10677,"What are all these、 rose petals for?"],[10706,10851,"Vesper, sweetheart."],[10923,11065,"He did this all for you."]],"69":[[16,91,"Sweetheart,"],[162,296,"he did this all for you."],[967,1096,"I've been waiting long and hard,"],[1197,1351,"thinking how I should do this,"],[1455,1630,"until I finally decided to come and ask Jake"],[1630,1751,"if he might give you to me."],[2039,2189,"I've heard about it all."],[2381,2448,"Raymond"],[2485,2577,"is a good man."],[2698,2915,"I'm very happy he can be with you."],[3007,3082,"Thank you, Jake."],[3207,3257,"Raymond."],[3661,3757,"I've been waiting too long."],[3807,3924,"I might be in too much of a hurry,"],[3924,4038,"but I've been waiting 18 years,"],[4038,4179,"and now I can't wait a day longer."],[4446,4537,"Will you marry me,"],[4612,4708,"Vesper Brown?"],[4800,4900,"I will, Raymond."],[7040,7468,"Happy birthday to you."],[7490,7891,"Happy birthday to you."],[7932,8391,"Happy birthday, dear Hugo."],[8437,8825,"Happy birthday to you."]],"70":[[600,771,"Hey, you scared me."],[804,934,"Why don't you keep lying down?"],[934,1051,"We're waiting for you."],[1117,1167,"What's going on?"],[1167,1336,"You get enough sun yet or do you wanna go back?"],[4045,4162,"Did you ever tell Hugo?"],[4308,4512,"I told him that you're his father."],[4583,4694,"Guess what he said?"],[4750,4826,"What?"],[4900,5060,"He said that his birthday wish"],[5060,5235,"actually came true."],[5321,5485,"Turns out he's wanted us to be together"],[5485,5595,"for a long time."],[5776,5864,"My good son."],[6160,6430,"I'm glad he's choosing me instead of his Uncle Colton."],[6473,6631,"Come on, Raymond."],[6819,6944,"Moreover,"],[6973,7186,"Colton said he's not coming to our wedding tomorrow."],[7278,7386,"He has"],[7444,7671,"gang-related business to take care of."],[7753,7828,"Whatever."],[8145,8245,"Hey, um,"],[8283,8466,"Grandma is gonna fly in for our wedding."],[8508,8633,"She wants to meet you."],[8754,8834,"Meet you as well,"],[8834,8958,"and apologize to you."]],"71":[[120,237,"She wants to meet you."],[350,450,"Meet you as well,"],[450,563,"and apologize to you."],[688,754,"So-so."],[984,1038,"But hey,"],[1038,1076,"look,"],[1101,1172,"don't worry."],[1288,1430,"She sent Lockwood to jail herself"],[1430,1551,"after she found out everything."],[1768,1875,"I'm not worried."],[1956,2122,"As long as I have you by my side"],[2122,2210,"and Hugo,"],[2264,2435,"there's nothing to fear with you around."],[8892,8946,"Raymond."],[8954,9013,"Vesper."],[9029,9209,"Thank god for bringing you back to me."],[9234,9446,"I will love you devoutly for the rest of my life."]]}