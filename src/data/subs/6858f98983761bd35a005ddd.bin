hing."],[3695,3812,"The Morgan Corporation"],[3812,4062,"should fire unethical employees like you."],[4066,4212,"We don't have time for this."],[4216,4354,"Give me the medication."],[4354,4546,"I am marrying Hayden today."],[4571,4821,"Everything he owns is about to be mine."],[4838,4967,"You think he's going to pick you"],[4967,5021,"over me?"],[5196,5330,"Cover for his mistress"],[5330,5618,"and I swear I will ruin you."],[5618,5693,"Trust me,"],[5693,5889,"he's not going to save you by then."],[5918,6039,"And you really think"],[6039,6101,"that you're gonna"],[6101,6231,"become Mrs. Morgan."],[6343,6464,"if you let his sister die?"],[6635,6773,"Who cares if she dies?"],[6777,6973,"She's just a dirty little slut."],[7011,7132,"I'll cry a little,"],[7132,7278,"bat my lashes,"],[7278,7419,"and Hayden will be over it."],[7453,7549,"She's nothing"],[7549,7661,"to the Morgan Corporation"],[7661,7770,"compared to me."],[7770,7945,"Give me the pills now,"],[7966,8087,"or you're going to regret it."]],"29":[[387,558,"Don't you ever threaten my sister."],[579,679,"She said not to save her."],[679,800,"Who the hell do you think you are?"],[825,946,"What are you doing? Let me go."],[1017,1084,"Oh."],[1405,1526,"You're just an assistant, Kevin."],[1530,1651,"My sister's your boss."],[1651,1772,"She owns you."],[1814,1931,"I'm just trying to save her life."],[1931,2097,"She's really Mr. Morgan's sister."],[2110,2181,"You're still siding"],[2181,2302,"with this home wrecking bitch?"],[2335,2473,"If my sister says she's a tramp,"],[2473,2594,"then she's a fucking tramp."],[2719,2836,"You're just an errand boy."],[2844,2965,"Know your place?"],[3824,3903,"You hear me?"],[3903,4020,"Answer me."],[4083,4270,"Mr. Morgan is going to be here soon,"],[4270,4387,"and you're all going to pay"],[4387,4508,"for hurting Ms. Eve."],[4533,4688,"Give up or die."],[4733,4909,"You're going to...regret this..."],[5221,5359,"Eve, where are you?"],[5914,6122,"Hayden, save me."]],"30":[[29,125,"Fuck."],[125,262,"It's your fiancé's voice."],[308,429,"Why is he here?"],[462,558,"Shut up!"],[558,675,"Hide them. Now!"],[696,771,"Get them out of sight"],[771,880,"before Hayden sees anything."],[880,1030,"This wedding is still happening."],[1059,1138,"Right."],[1138,1309,"Drag him out of here now."],[2577,2698,"Listen up!"],[2873,2982,"Everyone of you"],[2982,3132,"don’t say a single word,"],[3132,3240,"or else your families"],[3240,3361,"will disappear from L.A.."],[3499,3566,"Eve!"],[3595,3737,"Eve, where are you?"],[3870,3999,"Hey, babe."],[4129,4245,"What are you doing here?"],[4279,4396,"Clara, wha—"],[4396,4466,"Aren’t you supposed to be"],[4466,4542,"in Hawaii?"],[4562,4683,"Getting ready for our wedding?"],[4779,4846,"What are you doing here?"]],"31":[[91,187,"Well,"],[187,279,"my sister"],[279,412,"and nephew were on this plane,"],[412,487,"so I just thought I'd come"],[487,608,"and make sure they landed safe."],[617,775,"Oh, Mr. Morgan."],[775,934,"I'm Clara's older sister."],[1038,1180,"She's the baby of the family."],[1184,1418,"My one and only sister."],[1418,1601,"Please take good care of her."],[1630,1689,"Of course."],[1689,1764,"The guests are probably"],[1764,1830,"waiting for us."],[1835,1939,"We should head back."],[1939,2056,"We can't be late. Come on."],[2064,2160,"We'll miss our first dance."],[2160,2248,"I'm sorry."],[2248,2364,"Has anyone seen this girl?"],[2552,2656,"Is this photo too blurry?"],[2656,2744,"Mr. Morgan, please,"],[2744,2811,"I'm sure you have"],[2811,2919,"more important things to focus on."],[2919,3053,"Let me take care of this for you."],[3061,3098,"Can I have"],[3098,3211,"everybody's attention, please?"],[3249,3370,"Has anyone seen this girl?"],[3691,3799,"This is my sister,"],[3845,3895,"all right?"],[3895,4079,"She has a serious heart condition,"],[4079,4216,"and she's in trouble right now."],[4270,4375,"If you can please"],[4375,4479,"just help me find her."]],"32":[[45,166,"That bitch was actually"],[166,254,"Eve Morg