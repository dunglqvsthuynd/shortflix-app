,2540,"But I would."],[3257,3353,"I thought you"],[3390,3599,"were a sweet, gentle soul."],[3599,3749,"But now I see that"],[3749,3866,"that was all an act."],[3903,4008,"Now I see you for what"],[4008,4108,"you really are."],[4312,4504,"An evil, vile woman."],[4529,4600,"Please."],[4600,4725,"Hayden, forgive me."],[4725,4817,"I didn't mean it."],[4817,4904,"I was wrong."],[4996,5063,"Please."],[5105,5251,"We're going to get married today."],[5388,5559,"Please, next time I promise..."],[5559,5605,"Oh!"],[5747,5818,"Wedding?"],[5872,5960,"You're still dreaming"],[5960,6031,"of a wedding?"],[6064,6126,"You almost killed"],[6126,6214,"my baby sister."],[6214,6360,"The wedding is off!"],[6639,6756,"Mr. Morgan,"],[6756,6819,"you and Clara"],[6819,6940,"have been through so much."],[6940,7015,"I would hate to see"],[7015,7148,"you just throw away..."],[7148,7240,"Fuck off!"],[7261,7336,"We're done."],[7378,7461,"We're all done."],[7461,7557,"It's all over."],[7741,7832,"Eve, are you okay?"],[7887,7970,"I’m so sorry."],[7970,8049,"This is all my fault."],[8120,8220,"She's young."],[8308,8433,"You should try begging her."],[8525,8579,"Eve."],[8612,8717,"Eve, please."],[8783,8854,"Please."],[8904,8963,"Tell your brother"],[8963,9042,"to forgive me."],[9109,9200,"We’re family!"],[9250,9376,"I’ll be the best sister in law,"],[9376,9467,"I promise, just..."],[9467,9534,"Please!"],[9559,9688,"Please forgive me."],[9801,9930,"Hayden, I'm sorry."],[10047,10093,"I couldn't"],[10093,10210,"protect the necklace"],[10210,10331,"that our mom gave me."],[10339,10389,"It's okay."],[10389,10502,"It wasn't your fault."],[10556,10727,"Necklace, necklace..."],[11094,11219,"I, I found the necklace."],[11265,11436,"I will have the best jeweler"],[11436,11532,"in the world to fix it."],[11532,11569,"Just..."],[11607,11699,"Please, I would be"],[11699,11795,"honored to wear it."],[11840,11895,"Oh."],[11957,12070,"I told you"],[12178,12262,"that I would never"],[12262,12470,"let an evil, vile wom