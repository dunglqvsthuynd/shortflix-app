{"1":[[646,717,"Hayden,"],[721,925,"I'm already on a plane to Hawaii."],[930,980,"You think"],[980,1151,"I’d miss my big brother's wedding?"],[1192,1301,"Not a chance."],[1305,1401,"Eve,"],[1401,1530,"I told you I’d send the jet."],[1551,1730,"Why are you flying economy?"],[1735,1906,"You know flying private is horrible"],[1906,1997,"for the environment."],[2002,2052,"Besides,"],[2052,2127,"you should be focused"],[2127,2277,"on your wedding with Clara."],[2310,2460,"I'm not a kid anymore."],[2494,2644,"I can take care of myself."],[2665,2761,"I'll have somebody pick you up"],[2761,2907,"as soon as you arrive."],[2911,2944,"All right."],[2948,3098,"See you later."],[3103,3253,"Bye."],[3294,3403,"Mom,"],[3403,3582,"Hayden is finally getting married."],[3595,3720,"Can you believe it?"],[3724,3827,"This necklace has been"],[3827,3958,"passed down to every Morgan bride"],[3958,4095,"for generations."],[4099,4230,"And now,"],[4230,4454,"I get to give it to his wife,"],[4462,4612,"for you."],[5117,5193,"I could have sent"],[5193,5271,"Hayden's private plane"],[5271,5434,"to pick you and Ivan up."],[5472,5550,"Why are you flying commercial"],[5550,5701,"like some peasant?"],[5739,5826,"Who knows what germs"],[5826,6031,"you could catch from those bums?"],[6031,6222,"Hey, I got this flight on points."],[6243,6402,"Didn't pay a penny."],[6448,6535,"What kind of sucker"],[6535,6694,"turns down something for free?"],[7507,7657,"Oh my God."],[7686,7799,"Don't fly"],[7803,7937,"if you can’t afford"],[7937,8174,"to check your bag."],[9263,9413,"What's her problem?"],[9413,9517,"I don’t know man."],[9788,9889,"Ladies and gentlemen,"],[9889,9947,"thank you"],[9947,10097,"for flying with us today."],[10105,10306,"We've reached our cruising altitude."],[10322,10403,"We'll now begin"],[10403,10539,"our in-cabin service."],[10539,10798,"It’s a breezy 61 degrees in Dallas."],[10810,10948,"We’ll be touching down shortly."],[10948,11098,"Oh my god."],[11115,11248,"There's no room to breathe"],[11248,11415,"in this damn seat."],[11603,11745,"Let alone, stretch my legs."],[11861,12037,"Stupid cheap airlines."],[12316,12466,"Ivan, baby."],[12495,12700,"Go find mommy a better seat"],[12716,12892,"that’s not so tight."],[13421,13467,"Mommy!"],[13471,13596,"This cripple is taking up"],[13596,13722,"two huge spots."],[13726,13876,"You can have her seat."],[14406,14527,"Get up!"],[14531,14681,"Go to the back."],[14689,14735,"I'm sorry."],[14739,14906,"This is my assigned seat."],[14969,15085,"My leg’s in a cast,"],[15085,15186,"so I need the extra space."],[15190,15352,"I wish I could help, but..."],[15436,15540,"I can’t switch."],[15544,15599,"You're really"],[15599,15828,"gonna make a mother stand,"],[15828,15928,"with her child?"],[15982,16203,"That is unbelievable."]],"2":[[162,246,"Oh!"],[454,613,"Get up or you'll never walk again!"],[875,988,"Oh!"],[992,1080,"Oh, ma'am can you"],[1084,1205,"please get your kid to stop."],[1297,1434,"Boys will be boys."],[1480,1643,"Besides, he's just a kid."],[1676,1822,"How much damage can he do?"],[1830,1943,"Your cast looks like it could"],[1960,2077,"stop a bullet."],[2106,2444,"Stop being so dramatic."],[2448,2585,"What is wrong with you?"],[2890,3028,"Ma’am, we’re about to hit turbulence."],[3028,3157,"If you’ll please return to your seat"],[3157,3278,"and fasten your seatbelt."],[3278,3470,"Oh, look, a loser"],[3499,3670,"trying to play a hero."],[3757,3878,"Well, I didn't peg you for the type,"],[3878,3999,"sweetheart."],[4054,4175,"But let me guess."],[4191,4312,"Someone broke your legs"],[4350,4441,"because she caught"],[4441,4717,"you spreading them for her husband."],[4796,4917,"What?"],[4934,5055,"No, I, I—"],[5071,5192,"Ma'am, I'll have to ask you"],[5192,5321,"to watch your words very carefully,"],[5321,5472,"as baseless accusations"],[5476,5605,"can be considered harassment."],[5634,5755,"Now, will you—"],[5797,6097,"Don't make me report you."],[6118,6189,"Haven't you ever heard of"],[6189,6368,"the cu