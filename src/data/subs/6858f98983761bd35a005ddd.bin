2439,2594,"My child wouldn’t lie."],[2977,3123,"Ma'am, that’s enough!"],[3123,3253,"Please step away from her."],[3265,3428,"She assaulted my son."],[3490,3603,"Am I not allowed to defend"],[3603,3724,"my kid now?"],[3816,3937,"It's not true."],[3941,4066,"I was trying to help."],[4066,4137,"My son."],[4158,4295,"He needs a full medical exam."],[4300,4427,"And you are going to"],[4431,4571,"cover all his medical bills."],[4654,4693,"Tell the captain"],[4693,4884,"to turn this plane around now."],[4888,5034,"My son needs the hospital!"],[5075,5171,"Contact the ground crew."],[5176,5284,"There'll be a full medical team"],[5284,5363,"when we land."],[5367,5455,"But turning the plane around"],[5455,5513,"requires the"],[5513,5622,"captain's authorization"],[5622,5676,"and a verified—"],[5676,5814,"I don't give a damn"],[5834,5976,"about your protocols."],[6035,6202,"My son needs the hospital."],[6243,6539,"Turn this god damn plane around!"],[6573,6694,"Hey, Lucas,"],[6698,6810,"could you top off my coffee?"],[6948,7069,"What is going on here?"],[7182,7303,"Sir."],[7774,7903,"My son needs the hospital."],[7924,8133,"Turn this plane around now!"]],"4":[[0,112,"What the fuck?"],[116,237,"How did you get in here?"],[262,367,"Get out!"],[371,500,"You can't be in here."],[617,742,"Turn the plane around!"],[784,905,"If my son dies,"],[934,1184,"his blood is on all of your hands!"],[1188,1276,"Let go!"],[1276,1397,"You’re putting everyone’s lives"],[1397,1480,"in danger!"],[1480,1597,"Let go of me!"],[3741,3799,"Stop!"],[3799,3978,"Mayday, mayday, mayday!"],[3995,4325,"AD350 requesting emergency landing!"],[4354,4446,"I repeat!"],[4450,4596,"AD350"],[4654,4896,"requests immediate return to origin."]],"5":[[1088,1201,"My head hurts."],[1205,1326,"Mommy, do something."],[1368,1472,"You and your damn kid"],[1472,1593,"almost got us killed."],[1764,1881,"You're the pilot!"],[1947,2127,"This is all your fault."],[2143,2264,"What were you on, huh?"],[2314,2464,"If you’d just turn this plane around"],[2469,2590,"when I told you to."],[2627,2865,"Hey, you broke into the cockpit."],[2902,3094,"Almost killing everyone on board."],[3119,3244,"Now you're trying to pin the blame"],[3244,3328,"on me?"],[3328,3403,"The black box"],[3403,3516,"recorded everything."],[3541,3741,"You're not walking away from this."],[3807,3987,"I have to speak to air traffic control."],[4041,4162,"Keep them here."],[4325,4450,"I need all the passengers"],[4454,4575,"to remain calm."],[4592,4825,"The FAA and the police"],[4867,4988,"are on their way."],[5184,5251,"Bitch!"],[5255,5438,"This is all your fault."],[5451,5584,"How is this my fault?"],[5593,5734,"If you'd have moved your ass"],[5739,5864,"when I told you to,"],[5868,6018,"then my son never would have fallen."],[6022,6089,"And we wouldn't have had to"],[6089,6210,"turned this plane around."],[6260,6402,"This is because of you."],[6435,6560,"We are the victims."],[6577,6673,"Bullshit!"],[6677,6790,"We all saw you work your way"],[6790,6877,"into the cockpit."],[6881,6981,"Don't you dare try to"],[6981,7044,"pin this on her."],[7148,7240,"Lady."],[7244,7382,"You're lucky this ain't Texas."],[7415,7578,"Where I'm from, we take maniacs"],[7582,7695,"like you outback,"],[7695,7786,"and we put them down."],[7791,7891,"I'm not scared of you."],[7895,8016,"I'll kick your butt!"],[8037,8091,"Don't worry."],[8091,8216,"I got it all on video."],[8400,8479,"You've got proof."],[8483,8583,"We're with you."],[8687,8800,"You two are done."],[8804,8925,"Count on it."],[8946,9104,"Don't touch me!"],[9146,9263,"You think this is over?"],[9342,9463,"I’m calling my sister."],[9496,9588,"When she gets here,"],[9592,9734,"you all are screwed."],[9797,9943,"Yeah, when my aunt gets here,"],[9943,10047,"you’re all doomed."],[10214,10335,"Clara."],[10377,10497,"You have to come."],[10523,10623,"The people at the airport"],[10623,10752,"are ganging up on Ivan and me."],[10756,10877,"And Ivan is hurt."],[10952,11106,"You have to come, please!"],[11169,11244,"What?"],[11248,11415,"No one touches my family."],[11453,11561,"No one."],[11565,11686,"I'll be right there."],[11707,11815,"Call security."],[11820,11945,"Have them meet me at LAX."],[11974,12078,"I want them in position"],[12078,12174,"while I land."]],"6":[[12,133,"Eve should have landed by now."],[175,392,"Flight AD350 was forced to"],[392,563,"make an emergency landing"],[563,667,"back in Los Angeles."],[667,704,"Oh my god."],[704,821,"The FAA has launched"],[821,896,"an immediate..."],[896,950,"Eve."],[1005,1084,"Get the chopper ready."],[1084,1192,"We got to go to L.A. right now."],[1230,1292,"Come on."],[1351,1443,"You bitch."],[1443,1626,"You think crying is going to help you?"],[1634,1710,"Better start rehearsing"],[1710,1780,"your confession."],[1797,1918,"Cops are coming."],[1947,2068,"Enough!"],[2085,2218,"You're the criminal here."],[2310,2502,"Stop trying to blame the poor girl."],[2552,2711,"I'm more than ready to tell the cops"],[2715,2857,"how you broke into the cockpit"],[2894,3015,"and broke the console."],[3019,3128,"More than enough to get you"],[3128,3249,"locked up for life."],[3524,3653,"Ow, you hit me."],[3691,3807,"He hit a kid."],[3878,3995,"You know,"],[3999,4149,"I was raised not to lift a hand"],[4154,4275,"on a woman or a child."],[4300,4429,"With monsters like you two,"],[4496,4596,"I'll make an exception."],[4650,4700,"Yup."],[4704,4825,"Like mother, like son."],[4867,4959,"Someone needs to teach"],[4959,5046,"both of ya’ll a lesson."],[5080,5234,"Don't come any closer."],[5409,5530,"I'm warning you."],[5634,5718,"Mommy!"],[5722,5793,"I'm scared."],[5797,5914,"What do we do?"],[9067,9150,"Who do you think you are,"],[9150,9371,"laying hands on my sister and nephew?"],[9371,9480,"Do you have a death wish?"]],"7":[[0,79,"Baby sis."],[83,241,"Thank god you're here."],[1593,1726,"Lay a finger on me,"],[1730,1914,"and I'll have your entire bloodline"],[1918,2052,"scraped from L.A."],[2210,2360,"Lock L.A.X. down."],[2377,2460,"Before this is settled,"],[2460,2640,"I need all flights grounded."],[2648,2848,"No one leaves until I say so."],[3061,3169,"All outgoing flights"],[3169,3382,"are now suspended until further notice."],[3424,3545,"You."],[3561,3703,"Why is air traffic control"],[3707,3883,"taking orders from you?"],[3933,4041,"Oh honey."],[4045,4141,"One word from me,"],[4141,4262,"and you're fired."],[4446,4604,"Still feel like playing the hero?"],[4763,4859,"Well, who else?"],[4863,5083,"Who else dared laid hands"],[5087,5280,"on my sister and nephew?"],[5434,5530,"Speak up now."],[5547,5668,"I won't ask again."],[6068,6189,"You're all guilty."],[6210,6331,"Especially you."],[6339,6452,"You wouldn't give up your seat"],[6452,6577,"and you made me fall."],[6648,6735,"Aunty Clara,"],[6740,6840,"she's the one."],[6844,6952,"She’s the meanie who was"],[6952,7040,"bullying us."],[7073,7194,"It's you."],[7282,7357,"What?"],[7361,7482,"You know her?"],[7486,7620,"She's the gold digger"],[7624,7791,"that seduced my fiancé."],[8053,8145,"What?"],[8412,8537,"You whore!"],[8583,8733,"You've been seducing"],[8733,8900,"my brother-in-law?"],[9154,9275,"So when you coming back?"],[9467,9555,"Of course I'll pick you up."],[9555,9676,"You're my sister."],[9697,9813,"All right."],[9818,9889,"I'll talk to you soon."],[9893,10001,"I love you."],[10005,10126,"Bye."],[10151,10310,"Why is he hiding here"],[10314,10460,"just to make a call?"],[10739,10910,"Hey, what are you doing out here?"],[10915,11036,"Everyone's asking for you."],[11131,11290,"Isn't it bad luck to see the bride"],[11290,11357,"on the wedding day?"],[11361,11436,"Let me get back inside"],[11436,11557,"before people see us."],[12508,12629,"I have been hunting"],[12633,12754,"you down for weeks."],[12796,12971,"Never thought I'd find you here."]],"8":[[0,120,"No way."],[141,325,"She doesn't seem like that kind of girl."],[342,458,"Right?"],[513,629,"She seems so sweet."],[696,817,"Oh, you don't believe me?"],[884,1005,"Well."],[1438,1526,"Open your eyes"],[1526,1647,"and get a good look."],[1672,1776,"You see that?"],[1780,1914,"That's my fiancé."],[1964,2243,"And that tramp on his shoulder,"],[2344,2464,"that's her."],[2489,2610,"That's the bitch."],[2640,2727,"Holy shit."],[2727,2848,"It's really her."],[2877,2998,"If that were my wife,"],[3044,3161,"I'd never let that slide."],[3303,3424,"She played us all."],[3453,3541,"I can't believe I defended"],[3541,3607,"a homewrecker."],[3620,3699,"That’s not true!"],[3699,3816,"I'm not home wrecker."],[3895,4004,"Let me see the picture"],[4004,4066,"of your fiancé."],[4087,4175,"Wait you-"],[4175,4204,"No."],[4233,4262,"No!"],[4283,4325,"What, no!"],[4713,4846,"How dare you!"]],"9":[[95,154,"I'm sorry,"],[154,262,"I didn't mean to."],[266,517,"An apology is not gonna fix this."],[550,658,"That limited-edition"],[658,713,"diamond studded Vertu"],[717,938,"was a gift from my fiancé."],[942,1030,"There's only three of them"],[1030,1109,"in the world."],[1868,1989,"I'm sorry."],[2006,2106,"I didn't mean to."],[2110,2218,"I'll pay for it, I swear."],[2223,2323,"With what?"],[2327,2473,"Money from your sugar daddy?"],[2485,2652,"My fiancé's money?"],[2681,2773,"Or maybe you’ve just been"],[2773,2965,"selling yourself on the side!"],[3265,3482,"You probably broke it on purpose,"],[3486,3578,"didn't you?"],[3582,3661,"Didn’t you?"],[3661,3699,"No!"],[3699,3782,"Thought if you could"],[3782,3870,"erase the evidence,"],[3874,3933,"you could keep playing"],[3933,4016,"mistress in peace?"],[4079,4112,"No, no."],[4112,4191,"No, that's not it."],[4195,4350,"I just wanted to see a picture of you"],[4371,4491,"and your fiancé."],[4579,4721,"You don't even remember the man"],[4725,4846,"you seduced?"],[4896,5017,"Or maybe."],[5025,5163,"Maybe you've been sleeping"],[5167,5417,"with so many that you can't remember"],[5422,5601,"which one my fiancé is."],[5818,5939,"Slut."],[6239,6364,"As of spreading your legs"],[6368,6560,"for strangers wasn't enough."],[6644,6702,"Now you're going"],[6702,6823,"after my brother-in-law?"],[6873,7015,"You’ve got nerve."],[7069,7178,"That’s not it,"],[7178,7361,"I don't know what you're talking about."],[7424,7678,"She is still denying it!"],[8191,8316,"How many men have you tricked"],[8316,8483,"with this sad little act of yours?"],[8541,8712,"We are going to"],[8712,8892,"show the entire world"],[8896,9129,"exactly the kind of trash you are."],[9175,9338,"We’re going to strip you down"],[9342,9492,"and stream it live,"],[9542,9590,"and show everyone"],[9590,9763,"how much of a slut you are."],[9776,9905,"And no one will fall"],[9909,10105,"for your pathetic little act again."],[10189,10268,"No, no."],[10272,10418,"Please, I beg you!"],[10422,10543,"Don't!"],[10606,10723,"Take her inside."],[10764,10881,"Please! Stop!"],[11011,11065,"Stop!"],[11069,11190,"No!"],[11586,11628,"Please!"],[11632,11857,"I am hurt. My leg. Please!"],[11899,12053,"Still whoring around"],[12057,12208,"on a broken leg."],[12345,12466,"Well, let's fix that."],[12533,12654,"Let's see how many men"],[12654,12733,"you can seduce,"],[12754,12896,"when you’re a cripple."],[13363,13500,"And here’s a little tip, Sweetheart."],[13559,13709,"You should have seen this day coming"],[13713,13976,"the second you laid hands on my man."],[13984,14064,"I'm begging you."],[14068,14239,"I didn’t seduce anyone."],[14239,14364,"I don't know what you're talking about."],[14368,14481,"I don’t know him!"],[14485,14627,"Shut up whore!"],[15586,15644,"Stop!"]],"10":[[0,116,"Stop!"],[867,967,"Officer!"],[971,1067,"That's the passenger"],[1067,1188,"that broke into the cockpit,"],[1213,1343,"forcing us to return."],[1388,1543,"According to airline regulations—"],[1547,1718,"This mean lady hit me"],[1843,1964,"and she wouldn't move."],[2006,2152,"Yes. That's right."],[2168,2398,"She attacked my son"],[2477,2610,"and she has been seducing"],[2610,2719,"my brother-in-law."],[2719,2982,"She is a gold-digging tramp."],[3032,3148,"Arrest her."],[3153,3370,"I don't even know who they are."],[3403,3495,"I'm not a home-wrecker,"],[3495,3616,"I swear."],[4346,4466,"We have video evidence"],[4466,4633,"of the girl going into the cockpit,"],[4637,4742,"and starting an altercation"],[4742,4796,"with the captain."],[4833,4954,"You're under arrest."],[5055,5176,"You wouldn’t dare."],[5180,5267,"Ma'am,"],[5271,5351,"you’re also being charged with"],[5351,5430,"aggravated assault."],[5459,5526,"Turn around."],[5530,5647,"You sure about that?"],[5689,5826,"Call Senator Thompson."],[5880,5997,"His personal number."],[6060,6135,"Now."],[7140,7244,"Senator Thompson requests"],[7244,7369,"that we move on to urgent matters."],[7419,7536,"Let's move."],[7741,7836,"Sir!"],[7841,7962,"That's it?"],[7966,8120,"This was an attempted hijacking."],[8137,8274,"You can start by arresting"],[8279,8400,"the real problem."],[8416,8550,"This gold-digger tried"],[8554,8712,"to destroy my family"],[8717,8871,"and nearly caused a disaster"],[8875,8992,"in the process."],[9004,9125,"Arrest her."],[9129,9246,"And the rest of you."],[9259,9342,"Every one of you"],[9342,9505,"who harassed my sister."],[9530,9647,"Apologize."],[9726,9784,"Now."],[9784,9838,"No, no."],[9843,9984,"This is total bullshit."],[10139,10260,"What are you waiting for?"],[10264,10368,"Arrest her!"],[10372,10481,"Stop!"],[10485,10539,"Let go of me!"],[10539,10689,"How can you lie about this?"],[10735,10856,"Ma'am, we're just following orders."],[10890,11002,"Orders?"],[11006,11161,"Where is your sense of justice?"],[11165,11277,"You can't just arrest me"],[11277,11394,"without evidence."],[11394,11544,"Oh, evidence."],[11586,11707,"Sure."],[11970,12199,"See I pulled this off her earlier."],[12237,12458,"The slut’s also a drug dealer."],[12545,12666,"So I demand"],[12666,12816,"you arrest her at once."],[12987,13146,"You're framing me."],[13163,13284,"I want my lawyer."],[13400,13509,"I recommend you put her"],[13509,13630,"in max security."],[13663,13747,"Drug addicts"],[13747,13868,"going through withdrawals?"],[13905,14047,"Very dangerous."],[14097,14197,"And I wouldn't be surprised"],[14197,14318,"if she's tied to some drug ring."],[14322,14510,"So make sure you press"],[14531,14768,"every possible charge."],[15361,15536,"You see, in this society,"],[15586,15744,"money buys justice."],[15836,15999,"And it’s too late for you, but..."],[15999,16061,"don’t worry"],[16066,16187,"I'll make sure they take"],[16216,16395,"very good care of you in prison."],[16612,16683,"Take her away."]],"11":[[0,66,"No, no..."],[66,208,"You can't just take me away!"],[208,346,"I have rights!"],[346,446,"There's video evidence,"],[446,646,"check the cockpit footage!"],[1568,1768,"Who are you?"],[1801,1906,"Why did the police"],[1906,2022,"listen to you?"],[2022,2122,"How are you even allowed"],[2122,2173,"to get away"],[2173,2298,"with all that you do?"],[2298,2398,"You break"],[2398,2498,"laws and walk away"],[2498,2686,"like none of it matters."],[2686,2806,"You're right."],[2806,3015,"I am above the law."],[3069,3411,"I tell you, it feels amazing."],[3545,3599,"And granted that you're"],[3599,3657,"never going to see"],[3657,3757,"daylight again."],[3757,3958,"I suppose we could tell her."],[3958,4137,"So, go on,"],[4145,4250,"tell her."],[4942,5034,"This is Claire Brown,"],[5034,5121,"vice president of the"],[5121,5321,"Morgan Corporation."],[5530,5613,"The VP of the"],[5613,5718,"Morgan Corporation."],[5818,5922,"No wonder."],[5922,6010,"The Morgan Corporation"],[6010,6097,"owns everything."],[6097,6297,"Finance, tech, media..."],[6364,6435,"They could bankrupt"],[6435,6477,"a country"],[6477,6614,"with one press release."],[6614,6664,"Morgan,"],[6664,6810,"the CEO, is the richest man"],[6810,6906,"in California."],[6906,7048,"Maybe even the world."],[7048,7132,"Even the president"],[7132,7240,"listens to him."],[7240,7436,"Now it all makes sense."],[7436,7570,"No wonder the cops wouldn't"],[7570,7624,"touch her."],[7741,7916,"Told you!"],[7945,8103,"That's my sister"],[8103,8304,"you're messing with."],[8304,8404,"You people"],[8404,8591,"are nothing but bugs"],[8591,8792,"under our heels."],[8858,8925,"Now I want"],[8925,9084,"every one of you..."],[9129,9321,"to beg for my sister's"],[9321,9522,"forgiveness."],[9522,9622,"You’re really the VP of"],[9622,9784,"the Morgan Corporation?"]],"12":[[16,87,"You're really the"],[87,287,"VP of the Morgan Corporation?"],[342,483,"In the flesh."],[483,684,"And soon, I won’t just be VP."],[721,888,"No, today, I marry"],[888,1080,"Hayden Morgan."],[1080,1326,"The CEO himself."],[1326,1468,"And once we’re married,"],[1468,1572,"everything he owns"],[1572,1659,"will be mine."],[1714,1947,"And you will never be able"],[1947,2147,"to crawl back into his bed"],[2185,2318,"ever again."],[2318,2477,"You pathetic"],[2527,2635,"bitch."],[3061,3219,"Look, you need to go faster."],[3219,3345,"My sister is in danger."],[3345,3445,"I need to get to the airport"],[3445,3511,"right now."],[3511,3570,"We'll be landing"],[3570,3770,"in three minutes, sir."],[4066,4258,"I don't believe this."],[4258,4358,"Why would my brother"],[4358,4537,"choose a woman like you?"],[4537,4738,"This is impossible!"],[4800,5000,"Please, I am VP of Morgan Corp."],[5025,5113,"Why the hell would Hayden"],[5113,5188,"throw me away"],[5188,5388,"for some street rat like you?"],[5518,5626,"I can't believe that"],[5626,5718,"my brother’s fiancée"],[5718,5864,"is a vile,"],[5864,6064,"evil bitch like you."],[6064,6193,"Your brother?"],[6193,6264,"What do you mean?"],[6364,6389,"That's a"],[6389,6589,"family photo."],[6598,6673,"Hayden"],[6673,6760,"is my brother."],[6865,6994,"I'm Eve Morgan!"],[7082,7161,"What!?"],[7161,7344,"You're Hayden’s sister?"],[7432,7520,"Wait..."],[7520,7607,"Is she really"],[7607,7766,"Mr. Morgan's sister?"]],"13":[[175,271,"What?"],[271,342,"No..."],[342,508,"What is Hayden doing here?"],[550,613,"Yeah. She doesn't seem"],[613,734,"like a home wrecker."],[834,963,"Guess the truth will come out."],[963,1009,"After going"],[1009,1151,"after a sister like that?"],[1167,1255,"You think she still has a shot"],[1255,1288,"at marrying into"],[1288,1418,"the Morgan family?"],[1522,1609,"Sweetie,"],[1722,1931,"this is all just a"],[1931,2114,"silly little misunderstanding."],[2114,2314,"We are family."],[2335,2402,"Your brother doesn't"],[2402,2581,"have to hear about any of this."],[2581,2723,"Yeah, I was being silly."],[2723,2831,"I didn't mean it."],[2831,2882,"Really."],[2882,3015,"You’ll forgive your sister-in-law,"],[3015,3086,"won’t you?"],[3111,3211,"There is..."],[3286,3390,"no way,"],[3436,3570,"that I’m letting something"],[3570,3712,"like you into this family."],[3712,3807,"Especially"],[3820,4079,"after everything you’ve done."],[6448,6506,"I've heard someone's"],[6506,6598,"been messing with my sister"],[6598,6777,"and baby nephew."],[6777,6886,"Who's dumb enough to start shit"],[6886,7086,"in my territory?"],[7186,7290,"Neil, what are you doing here?"]],"14":[[717,804,"Mr. Morgan,"],[804,855,"I can't"],[855,1009,"land in restricted airspace"],[1009,1163,"without ATC clearance."],[1163,1330,"We're running out of time."],[1330,1488,"Just drop me off anywhere."],[1488,1622,"Alright? Just try to reconnect"],[1622,1710,"with the land."],[1710,1835,"Look, my sister needs me,"],[1835,1860,"all right?"],[1860,1972,"She has a heart condition."],[1972,2035,"If she's hurt"],[2035,2122,"or having a heart attack,"],[2122,2210,"I can't just sit here."],[2210,2323,"I've got to get to her."],[2323,2523,"I understand, sir."],[2677,2727,"That's Hayden’s"],[2727,2857,"helicopter!"],[2857,2965,"Why are you here?"],[2965,3044,"Where is he?"],[3194,3240,"I was bored,"],[3240,3290,"so I just took it"],[3290,3465,"for a little joyride."],[3465,3561,"Didn't your fiancé already"],[3561,3632,"pick up Eve up from"],[3632,3787,"the ski resort this morning?"],[3787,3903,"Why would he be here?"],[3903,4108,"The ski resort... to pick up Eve?"],[4166,4258,"Yeah, I ran into him"],[4258,4371,"when he was heading out."],[4375,4433,"Why?"],[4533,4592,"Mr. Morgan,"],[4592,4683,"security is all set."],[4683,4733,"You and my sister"],[4733,4804,"are good to go."],[4804,4854,"Don't worry."],[4854,4892,"I won’t let anything"],[4892,4971,"happen to the wedding."],[4971,5109,"Let's talk later."],[5109,5221,"Eve cleared her whole schedule"],[5221,5326,"just to be here."],[5326,5363,"Let's go get her"],[5363,5426,"from the ski resort."],[5730,5901,"You bitch!"],[5901,5989,"I knew you were"],[5989,6106,"after my fiancé."],[6106,6210,"You're even pretending to be his"],[6210,6402,"little sister to mess with me?!"],[6594,6798,"Too bad I didn't fall for it."]],"15":[[12,108,"What?"],[108,154,"She was messing"],[154,296,"around with Hayden?"],[296,346,"Yeah,"],[346,429,"this tramp’s been trying to"],[429,533,"get with him!"],[533,621,"She even had the nerve"],[621,667,"to pretend"],[667,809,"she was Hayden's sister!"],[2281,2352,"Bitch!"],[2456,2540,"How dare you go"],[2540,2665,"after my brother-in-law!"],[2744,2882,"I'm...I'm Eve,"],[2882,2965,"I'm not lying!"],[2965,3048,"I'm Hayden’s sister..."],[3086,3328,"Still lying, huh?"],[3553,3695,"You really did"],[3695,3849,"your research, didn't you?"],[3849,4020,"Thought you could fake your way"],[4020,4220,"into the Morgan family?"],[4229,4312,"Who do you think you are"],[4312,4375,"pretending to be"],[4391,4579,"my fiancé’s sister?"],[5092,5209,"Seems like"],[5209,5284,"you still haven't"],[5284,5484,"learned your lesson."],[5672,5855,"Ow!"],[7549,7686,"I'm... not lying."],[7686,7778,"Shut up!"],[7778,7841,"I saw Mr. Morgan"],[7841,7987,"leave to pick Eve up from the ski resort"],[7987,8087,"with my own eyes."],[8087,8174,"So if you're her,"],[8174,8270,"what the hell are you doing here?"],[8270,8366,"It's his wedding."],[8366,8462,"I didn't want to ruin his"],[8462,8662,"big day, so I came back"],[8662,8792,"by myself."]],"16":[[16,150,"Still not giving up huh?"],[404,483,"My brother-in-law"],[483,554,"is the richest man"],[554,646,"in California."],[646,734,"The only person good enough"],[734,771,"for him"],[771,867,"is a beautiful heiress"],[867,955,"like my sister."],[988,1055,"You?"],[1084,1205,"You're just a gutter rat,"],[1205,1272,"desperately wanting"],[1272,1413,"to become Mrs. CEO."],[1413,1659,"I said I'm not lying!"],[1726,1814,"she doesn't seem"],[1814,1939,"like she's lying."],[1939,2102,"Maybe there's more to this?"],[2173,2323,"Shut up and stay out of it!"],[2439,2544,"That's enough."],[2631,2827,"You say you're Mr. Morgan’s sister."],[2844,2969,"Can you prove it?"],[3691,3841,"I wanna see!"],[4083,4187,"No! Give it back!"],[4575,4671,"Give it..."],[5021,5138,"Good job, son."],[5163,5271,"All right, “Ms. Morgan.”"],[5292,5330,"Let's see"],[5330,5405,"what you’re hiding in here."],[5459,5563,"Give it back!"],[5572,5659,"Whoa! Relax."],[5659,5759,"What's the rush?"],[5789,5951,"Actually hiding something or what?"],[6527,6614,"Don't touch that."],[6614,6735,"Give it back!"],[6823,6869,"Nope!"],[7328,7453,"No...no!"],[8187,8254,"That's"],[8254,8425,"the Morgan family necklace!"]],"17":[[229,367,"Wait, isn't this the necklace"],[367,546,"Hayden was going to give me?"],[859,946,"This necklace..."],[1055,1138,"It must be Hayden's"],[1138,1317,"wedding gift to me."],[1317,1455,"He hasn't mentioned it, so"],[1455,1676,"it's probably a surprise."],[1947,2118,"This necklace..."],[2118,2235,"Hayden gave it to you?"],[2423,2527,"It was supposed to be mine!"],[2527,2673,"How could he give it to you?"],[2836,2894,"No!"],[3674,3807,"That's the Morgan family"],[3807,3878,"heirloom."],[4008,4087,"It's always given"],[4087,4250,"to the wife of the family head."],[4320,4396,"It's a symbol of the"],[4396,4612,"matriarch’s status!"],[4662,4788,"When our mom died,"],[4800,4929,"Hayden wasn’t married yet."],[4929,5038,"So I've been holding on to it"],[5038,5176,"until the day that he is."],[5209,5484,"Oh, what a sweet little story..."],[5534,5605,"For something"],[5605,5743,"you just made up."],[5743,5805,"Come on."],[5805,5880,"How could someone like"],[5880,5985,"you ever get their hands on"],[5985,6206,"something that important?"],[6222,6381,"I was going to give it to you"],[6381,6539,"on your wedding."],[6577,6664,"But now I see..."],[6773,6823,"you do not"],[6823,6927,"deserve to wear a"],[6927,6994,"symbol of our"],[6994,7069,"family's honor."]],"18":[[342,433,"Shut up!"],[433,538,"Family heirloom?"],[538,679,"Come on."],[679,880,"If I can't have it,"],[913,1076,"no one can!"],[2018,2102,"It’s Hayden!"],[2193,2248,"He'll tell you"],[2248,2310,"everything."],[2736,2886,"“Big Bro”?"],[2886,3007,"What kind of freak saves their"],[3007,3169,"real brother under a name"],[3169,3219,"like that?"],[3219,3420,"That's disgusting."],[3616,3816,"You want him to come save you?"],[4270,4408,"Not a chance!"],[4408,4496,"Yeah. Don't answer it."],[4496,4629,"What if Mr. Morgan actually sides"],[4629,4763,"with this skank?"],[4763,4875,"Too late to call for backup,"],[4875,4971,"sweetheart."],[5013,5084,"Smash it!"],[5155,5263,"Teach her a lesson"],[5263,5455,"she'll never forget."]],"19":[[66,104,"No!"],[104,275,"That’s a Morgan family heirloom."],[279,346,"If you break it,"],[346,538,"my brother will never forgive you."],[538,625,"I'm sure it's the most"],[625,692,"expensive thing"],[692,784,"you've ever touched,"],[784,917,"but I am not buying"],[917,1117,"your little sob story."],[1126,1326,"If I can’t have it,"],[1401,1601,"no one can!"],[1634,1697,"No, no,"],[1697,1931,"it’s not just an heirloom."],[1960,2022,"It was my mother's."],[2022,2223,"She wore it before she died."],[2289,2435,"Ugh, you'll say anything"],[2435,2527,"to save this necklace,"],[2527,2615,"won’t you?"],[2777,2827,"I’ll... I’ll do"],[2827,2973,"whatever you want."],[2973,3069,"Just give it back!"],[3186,3294,"I want you"],[3407,3511,"to beg"],[3545,3770,"on your knee and apologize."],[3803,3928,"Show the world"],[3928,4016,"exactly"],[4016,4054,"the kind of"],[4054,4183,"homewrecker you are."],[4183,4354,"That you tried to steal Hayden!"],[4354,4454,"Smile for the camera,"],[4454,4579,"sweetheart."],[4579,4708,"You're live."],[4708,4779,"Now everyone’s"],[4779,4921,"gonna see exactly"],[4921,5038,"what kind of tramp"],[5046,5217,"you really are."],[5271,5409,"I’m not his mistress!"],[5409,5538,"Stop making things up!"],[5538,5655,"Three..."],[5689,5814,"Two..."],[5814,5930,"No, no, no..."],[5930,6018,"Please!"],[6343,6418,"Mom,"],[6531,6606,"I miss you"],[6606,6806,"so much."],[6810,6894,"You always dreamed"],[6894,7094,"of seeing Hayden get married."],[7970,8170,"Don't worry."],[8170,8395,"I’ll protect this necklace."],[8395,8437,"And give it to"],[8437,8633,"the woman he marries myself."],[8904,9104,"I promise."],[9188,9388,"No, no!"],[9538,9738,"I'll do it."],[9763,9805,"I’ll kneel."],[9939,10139,"I’ll apologize."]],"20":[[66,137,"I admit it."],[258,458,"I seduced Hayden..."],[496,617,"Please... just give it back."],[633,813,"I...It’s my mother’s..."],[813,884,"Louder!"],[1284,1484,"Let everyone hear it."],[1488,1680,"Tell them all how you seduced him."],[1680,1822,"I was desperate,"],[1822,1960,"and I went after him."],[2014,2110,"Please!"],[2110,2202,"Just give give it back!"],[2202,2389,"It was my mother’s..."],[2389,2556,"It was my mother’s,"],[2556,2727,"before she died."],[2761,2873,"You all heard her!"],[2873,2982,"She admitted it,"],[2982,3090,"straight from her mouth."],[3186,3294,"Pathetic."],[3374,3436,"Here,"],[3495,3595,"take it."],[5397,5430,"No!"],[5430,5580,"Mom, I’m so sorry."],[5718,5834,"I couldn’t keep"],[5868,6072,"your final wish..."],[6919,6998,"Oops."],[6998,7090,"Didn't think it’d break"],[7090,7186,"that easy."],[7186,7286,"I kneeled,"],[7499,7649,"I did what you said."],[7649,7836,"Why... why did you break it?"]],"21":[[45,187,"Oh, you're trying to negotiate"],[187,312,"with me?"],[312,379,"You?"],[517,692,"Look at yourself."],[713,888,"Filthy, pathetic —"],[888,971,"like you crawled straight"],[971,1059,"out of the gutter."],[1121,1284,"I can do whatever"],[1284,1497,"I want to you."],[1580,1735,"I’ll be honest."],[1735,1943,"I just want to watch you beg."],[1981,2189,"On your knees."],[2277,2598,"I'm not a home wrecker."],[3194,3261,"This wasn't"],[3261,3474,"just a family heirloom."],[3499,3591,"It was a gift"],[3591,3657,"from my mother!"],[3657,3866,"I hate all of you!"],[3887,4049,"Keep this in mind."],[4049,4166,"That's just what happens"],[4166,4375,"when you mess with me."],[5005,5146,"You are"],[5146,5292,"a monster!"],[5292,5530,"And you do not deserve to marry"],[5530,5743,"my brother!"],[5764,5893,"I promise you,"],[5893,6043,"for as long as I'm breathing,"],[6043,6160,"I will never"],[6160,6331,"let you into this family."]],"22":[[266,304,"You don't know"],[304,437,"when to back down, do you?"],[563,646,"Fine."],[700,775,"Beat her."],[900,1013,"Show what happens"],[1013,1134,"when she messes with me."],[1301,1422,"Don't you dare!"],[1597,1818,"I am Eve Morgan."],[1843,2077,"Hayden Morgan's only sister."],[2143,2235,"Bullshit!"],[2264,2331,"There's no way"],[2331,2464,"this bitch is Mr. Morgan's sister."],[2727,2848,"Don't touch me!"],[2986,3215,"My brother will make you all pay"],[3215,3336,"if you hurt me again."],[3424,3545,"Beat her!"],[3553,3674,"And don't hold back."],[5743,5855,"Stop!"],[5855,5976,"All you, stop!"],[6385,6502,"She's barely breathing."],[6531,6606,"There was nothing."],[6606,6727,"She's faking it."],[6948,7136,"No, she's having a heart attack."],[7465,7582,"Oh. What's this?"],[8024,8145,"Is this candy?"],[8220,8341,"It's mine now."],[8391,8458,"That's her medicine."],[8458,8579,"Give it back now."],[8975,9104,"And it sticks the landing."]],"23":[[0,246,"Help...help me."],[283,404,"Are y'all crazy?"],[588,700,"Give her medicine back!"],[821,1026,"How dare you yell at my son?"],[1146,1263,"She needs help right now,"],[1313,1434,"or she won't make it."],[1789,1906,"She's faking it."],[1931,2010,"And besides..."],[2010,2089,"one less homewrecker's"],[2089,2160,"for the better good."],[2160,2243,"Don't you think?"],[2369,2523,"What would it cost to clean this up?"],[2556,2756,"Less than a purse. I bet."],[2773,2923,"I took an oath to protect lives."],[2961,3082,"I won't let her die."],[3303,3399,"Give me your medicine now."],[3399,3520,"Don't you dare."],[3611,3732,"I can call the governor"],[3732,3778,"right now."],[3778,3874,"And have your job gone"],[3874,3995,"by morning."],[3999,4120,"It doesn't matter."],[4162,4287,"I need to do what it takes to save her."],[4325,4487,"Fine. Fine."],[4525,4646,"You wanna be the hero?"],[4696,4904,"Hey, you want to be the hero?"],[4942,5021,"Do it."],[5021,5192,"But tomorrow you will be broke,"],[5217,5392,"jobless and back in the ghetto"],[5392,5476,"where you came from."]],"24":[[4,133,"I don't care if I lose my badge."],[350,471,"I need to save her."],[1447,1543,"No, no."],[1797,1935,"No one's saving you today."],[2064,2110,"Try it."],[2110,2260,"And I'm coming after you next."],[2419,2540,"Call 911 right now. Tell them—"],[2540,2660,"Don't you dare!"],[2927,2994,"Think again."],[2994,3115,"Officer."],[3144,3236,"Take that call"],[3236,3336,"and I will make sure"],[3336,3591,"that the governor himself fires you."],[3616,3820,"And no one in your family"],[3820,4012,"will ever work in L.A."],[4041,4166,"ever again."],[4233,4341,"I don't care."],[4341,4429,"I need to do what it takes"],[4429,4550,"to save her."],[4550,4658,"This is Officer Alec."],[4658,4733,"We need an ambulance"],[4733,4867,"at the L.A. airport."],[4867,4946,"Female passenger"],[4946,5059,"possible heart attack."],[5059,5155,"We need medics."],[5155,5217,"Now."],[5217,5288,"Are you kidding?"],[5301,5422,"That's my fiancee's mistress."],[5422,5555,"I will not let you save her."]],"25":[[0,83,"Hold him down."],[83,187,"If any of you let go,"],[187,254,"I'll make sure"],[254,375,"you all lose your badges too."],[375,442,"Let me go!"],[442,542,"Cap. Please. Please."],[542,617,"Don't do this."],[633,750,"Think of your family."],[892,988,"None of us can afford"],[988,1117,"to go against the Morgans."],[1130,1251,"Aren't you having a heart attack?"],[1380,1530,"Shouldn't you be dead by now?"],[1793,2039,"Yeah, let me help speed it up for you."],[2944,3048,"She's faking it."],[3048,3132,"If it were real,"],[3132,3257,"she'd be dead by now."],[3294,3411,"This is fun."],[3411,3532,"Keep going."],[3561,3678,"What are you waiting for?"],[3778,3899,"Beat her!"],[4033,4149,"Did you not hear?"],[4216,4362,"Beat her till she can't move."],[5021,5138,"Stop!"],[5438,5630,"Kevin, what are you doing here?"],[5818,5893,"Eve."],[6135,6256,"No way."],[6389,6564,"Is she really Mr. Morgan's sister?"]],"26":[[4,116,"If Mr. Morgan finds out"],[116,237,"what we did to his sister,"],[321,375,"what do you think"],[375,496,"he'll do to us?"],[688,829,"Miss, you're Eve Morgan right?"],[829,900,"Mr. Morgan's sister."],[925,1071,"I'm Kevi, I'm his assistant."],[1080,1142,"What?"],[1167,1263,"Kevin's never met her?"],[1422,1497,"Maybe."],[1497,1622,"Maybe she's not Eve."],[1680,1860,"Maybe that bitch is still faking it."],[2010,2164,"Where's my brother?"],[2202,2335,"Our helicopter lost communication"],[2335,2456,"with air traffic control."],[2489,2598,"We couldn't land here, but..."],[2656,2765,"your brother wouldn't wait."],[2777,2911,"He ordered an emergency drop"],[2911,3032,"in a clearing nearby."],[3211,3357,"Mr. Morgan, we've lost contact."],[3361,3528,"I can't land in restricted airspace"],[3528,3649,"without ATC clearance."],[3661,3782,"We're running out of time."],[3803,3945,"Just drop me off anywhere."],[3999,4145,"Just reconnect and land."],[4145,4212,"All right?"],[4212,4308,"I understand, sir."],[4308,4433,"Look, I have to get to Eve."],[4462,4621,"My sister has a heart condition."],[4629,4704,"If she's hurt"],[4704,4779,"or having a heart attack,"],[4779,4867,"I can't just sit here."],[4984,5100,"After we landed,"],[5125,5230,"the signal came back."],[5230,5347,