2,"Sir,"],[3132,3249,"on top of beating your sister"],[3249,3353,"and breaking into the cockpit"],[3353,3436,"and framing Ms. Eve"],[3436,3553,"for drug trafficking."],[3553,3636,"I think these crimes"],[3636,3716,"would be enough"],[3716,3849,"to put them away for life."],[3937,4033,"Don't worry."],[4095,4191,"I'm going to have the best"],[4191,4329,"attorneys in the country."],[4391,4446,"I promise"],[4446,4537,"you'll never walk free"],[4537,4600,"ever again."],[4629,4725,"No, Clara!"],[4742,4838,"Do something."],[4859,4946,"Think of Ivan."],[4984,5176,"He can't go without his mommy."],[5238,5313,"Hayden."],[5367,5447,"I wasn't going to tell you"],[5447,5518,"this until after"],[5518,5588,"the wedding,"],[5593,5622,"but..."],[5755,5914,"Are you really going to send"],[5922,5993,"the mother"],[5993,6168,"of your child to prison?"],[6468,6619,"I am carrying"],[6619,6781,"the Morgan family heir."],[6815,7040,"Do you really want your baby"],[7065,7198,"to be born in prison?"]],"38":[[50,175,"Think of what happens."],[175,312,"When he's all grown up"],[312,387,"and he realizes"],[387,575,"what you did to his mommy,"],[579,704,"auntie and uncle?"],[771,859,"Poor baby."],[934,1055,"What a hard life,"],[1055,1159,"right Hayden?"],[1242,1363,"The baby's innocent."],[1393,1463,"Would you really want"],[1463,1601,"this silly little"],[1601,1801,"misunderstanding"],[1818,1993,"to ruin your baby's life?"],[2035,2102,"Eve."],[2164,2227,"Would you really want"],[2227,2285,"your nephew"],[2285,2477,"to grow up without his mommy?"],[2506,2569,"Whoa whoa whoa."],[2585,2652,"Are they really going"],[2652,2756,"to get away with this?"],[2907,2948,"Who could bear"],[2948,3073,"to hurt their own baby?"],[3165,3253,"I want to see them"],[3253,3332,"rot in prison."],[3332,3482,"They've gone too far."],[3482,3507,"You know,"],[3507,3632,"the judge could be lenient"],[3632,3724,"on a pregnant mother."],[3724,3870,"Besides, she's carrying"],[3870,4037,"the Morgans family’s heir."],[4108,4216,"This might be it."],[4346,4421,"Darling,"],[4450,4537,"if you drop this"],[4537,4658,"and help us go free,"],[4717,4804,"I’m willing"],[4833,4959,"to call off the wedding."],[5009,5150,"Oh, honey,"],[5171,5405,"there is no need for that."],[5451,5522,"Eve,"],[5551,5709,"for the sake of your unborn nephew,"],[5709,5809,"you'll forgive Clara,"],[5809,5880,"right?"],[5918,6126,"And we will just all be one"],[6172,6435,"big happy, loving family."],[6656,6798,"My unborn nephew?"],[7882,7978,"Does he know"],[8070,8153,"that his mommy"],[8153,8295,"has been taking this?"],[8362,8445,"That's not mine."],[8896,9050,"Says your name right here."],[9109,9255,"Clara Brown."],[9438,9559,"Shameless."],[9826,9993,"Clara, you use"],[9993,10151,"a baby to save your own skin?"],[10318,10427,"You're pathetic."],[10564,10702,"You would do anything"],[10744,10885,"to save yourself."],[10906,10998,"You'd even lie"],[10998,11161,"and pretend to be pregnant."],[11332,11503,"You need to be locked up forever"],[11503,11657,"before you hurt anybody else."]],"39":[[4,141,"Fine, Hayden Morgan."],[141,291,"You leave me no choice."],[517,608,"Do it."],[1121,1167,"Hey!"],[1572,1614,"You're all"],[1614,1689,"Morgan Corporation"],[1689,1747,"bodyguards."],[1747,1856,"What are you doing?"],[1856,1901,"Why do you think"],[1901,2022,"I begged to be head of security"],[2022,2135,"for Morgan Corporation."],[2177,2260,"They're on your payroll."],[2260,2306,"Sure,"],[2331,2448,"but they're all gang members"],[2456,2552,"loyal to me."],[2615,2723,"It took a lot of work,"],[2723,2811,"for placing all your guards"],[2811,2877,"with my men."],[2907,3023,"It all makes sense now."],[3090,3132,"No wonder"],[3132,3236,"the Morgan Corporation's been"],[3236,3386,"having security issues."],[3461,3545,"I trusted you,"],[3545,3695,"and you turned your back on me?"],[3766,3920,"To the victor goes the spoils."],[3962,4058,"Your family gave"],[4058,4137,"you everything you have."],[4137,4191,"But you're nothing"],[4191,4266,"compared to me."],[4350,4429,"Now give my sister"],[4429,4550,"$100 billion."],[4625,4725,"Consider it alimony."],[4758,4838,"And maybe"],[4900,5071,"I'll even consider sparing you."],[5134,5213,"Mr. Morgan."],[5230,5359,"$100 billion"],[5359,5472,"is like a drop"],[5472,5622,"in the bucket for you."],[5659,5780,"You wouldn’t want to die"],[5780,5864,"over this, right?"],[6026,6097,"You're right."],[6448,6610,"100 billion is nothing to me."],[6610,6677,"But you're not worth it."],[6702,6760,"You're not worth a"],[6760,6877,"penny off the floor."]],"40":[[16,112,"I'll kill you."],[429,492,"Ah!"],[1138,1209,"Go get them."],[1518,1597,"Mr. Morgan."],[1618,1739,"I hope I'm not too late."],[2164,2223,"Ethan."],[2243,2323,"I need you to bring your men"],[2323,2477,"to the LA airport right now."],[2594,2702,"Please drive faster."],[2932,3019,"Disarm these men"],[3019,3090,"and send them to jail"],[3090,3161,"right now."],[3482,3586,"Mr. Morgan, please."],[3611,3674,"It was all a prank."],[3674,3778,"The gun's not even real."],[3791,3887,"Just let me go."],[3958,4079,"Oh Mr. Morgan, please."],[4099,4220,"Please forgive me."],[4279,4466,"Clara, I'm your big sister."],[4466,4625,"You better do something."],[4625,4746,"What do you expect me to do?"],[4825,4942,"A whole plane of passengers"],[4942,5125,"and you had to pick his own sister?"],[5472,5597,"I'm so close,"],[5613,5839,"so close to being the head of"],[5839,5926,"the Morgan family."],[5947,6126,"We could have been untouchable."],[6222,6385,"You just had to ruin everything!"]],"41":[[16,262,"We were only on that plane"],[262,429,"to go to your wedding."],[613,734,"We would be safe at home"],[734,855,"if it weren't for you!"],[892,1051,"And now you're blaming me?"],[1101,1167,"You're the one who"],[1167,1259,"called his baby sister"],[1259,1363,"his mistress."],[1447,1530,"And you slapped Eve"],[1530,1718,"way more than I did."],[1718,1901,"You deserve to rot."],[1960,2010,"Oh!"],[2260,2381,"Mr. Morgan, please."],[2473,2585,"It was Clara's fault."],[2585,2715,"She's the bitch"],[2715,2798,"who told me that"],[2811,2965,"Eve was the gold digger,"],[2994,3098,"and I believed her."],[3098,3307,"Please let me and my son go."],[3349,3499,"We really didn't mean to."],[3499,3541,"That's right."],[3541,3591,"The whole thing"],[3591,3670,"was Clara's idea."],[3670,3749,"Like me, my men,"],[3749,3849,"we were just following orders."],[3858,3916,"Shut up!"],[3924,3999,"Both of you."],[4016,4104,"Useless."],[4133,4191,"Who's the one"],[4191,4312,"who almost crashed a plane?"],[4329,4458,"And who's the one has been"],[4458,4629,"using the Morgan corporation"],[4633,4833,"to smuggle drugs?"],[4900,5059,"I’m always cleaning up after you,"],[5059,5180,"and now you want me"],[5180,5276,"to take the fall?"],[5301,5401,"Not a chance."],[5401,5497,"I'll kill you both!"],[5809,5914,"Well, just all you know."],[5935,6051,"Anything you just said"],[6051,6214,"can and will be used against you."],[6443,6481,"Go!"],[6623,6660,"No."],[6731,6769,"No."],[6986,7061,"Yes!"],[7082,7186,"Finally."],[7215,7332,"After being untouchable"],[7332,7407,"for so long,"],[7436,7574,"they're finally going to face"],[7595,7686,"justice."],[7695,7741,"Let's hope"],[7741,7832,"prison teaches them"],[7832,7912,"how to behave."],[8045,8179,"Eve, I'm so sorry."],[8254,8299,"I'm so sorry."],[8299,8391,"This is all my fault."],[8420,8462,"None of this"],[8462,8516,"would have happened"],[8516,8608,"if it wasn't for me."],[8641,8800,"It's not your fault, big bro."],[8975,9038,"You just wanted"],[9038,9188,"to see the best in people."],[9342,9413,"At least we saw"],[9413,9492,"their true colors"],[9492,9601,"before it was too late."],[10064,10155,"Let's go home."],[10235,10343,"Let's get out of here."],[10389,10427,"Come on."],[10568,10652,"Watch your step."]]}