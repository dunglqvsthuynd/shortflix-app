{"1":[[1351,1509,"We love you Daisy!"],[1643,1839,"Daisy! Daisy!"],[1856,1926,"Daisy Tucker!"],[1926,2022,"No one's ever managed to"],[2022,2181,"ride Eagle Rock in under an hour."],[2202,2285,"That's a new record!"],[2323,2381,"How'd you do it?"],[2464,2644,"Oh, I just told old Lightning here,"],[2644,2744,"we were in a hurry."],[2932,3107,"Speaking of being in a hurry,"],[3228,3265,"crap."],[3378,3432,"I'm gonna be late"],[3432,3591,"for my first day of work in the city."],[3624,3749,"The last train's already left."],[3766,3845,"How are you gonna get there?"],[4383,4421,"Hey,"],[4454,4567,"you got one more race in you, boy?"],[4708,4763,"Alright."],[4984,5038,"Catch you later."],[6272,6322,"Alright."],[6560,6660,"Good job, boy."],[7711,7811,"I've finally made it."],[7899,8028,"Big city, here I come!"],[8354,8416,"Oh!"],[8483,8604,"What the hell is that?"],[8767,8800,"Um."],[8854,8921,"It's a horse?"],[8996,9063,"How else was I"],[9063,9134,"supposed to get here?"],[9709,9734,"Oh."],[9868,9926,"Oh my God!"],[9984,10055,"Somebody help!"],[10089,10214,"I think he's having a heat stroke!"],[10318,10368,"One sec."],[10593,10623,"Here."],[10643,10789,"Oh my God."],[10798,10985,"Don't touch homeless people."],[11040,11161,"Get these two out of here."],[11165,11327,"Our CEO is about to arrive."],[11390,11461,"Just keep drinking."],[11465,11511,"It's okay."],[11553,11586,"Hey!"],[11753,11882,"Get them out of here, now!"],[11916,12037,"You're not gonna touch him!"],[14293,14368,"Mr. Smith!"],[15223,15273,"Grandpa?"],[15673,15807,"That’s your grandfather?"],[15870,15911,"Are you okay?"],[16091,16232,"This girl saved me,"],[16278,16445,"and they knocked her out for it."],[16579,16737,"Who is that?"]],"2":[[225,287,"Sir,"],[321,517,"it's just a misunderstanding!"],[525,688,"You assaulted an innocent woman"],[696,800,"for helping my grandfather."],[834,950,"It was a mistake."],[984,1030,"You're fired."],[1113,1263,"I want you off my property"],[1276,1409,"in three seconds."],[1438,1614,"But, but, but - - Three."],[1647,1743,"Two."],[2552,2619,"What,"],[2719,2819,"what happened?"],[2902,3015,"You saved me!"],[3094,3194,"Just doing my job."],[6389,6485,"You okay there, Cowgirl?"],[6865,6981,"Who are you?"],[7119,7282,"I'll tell you who he is."],[7424,7561,"Your new husband."]],"3":[[125,208,"Grandpa, I can't,"],[241,350,"I can't just go and marry"],[350,450,"a complete stranger."],[513,775,"Even one as captivating as her."],[867,1121,"This young lady saved my life."],[1155,1263,"You're gonna marry her!"],[1309,1351,"Oh."],[1405,1463,"Mister,"],[1501,1680,"I'm not ready for a husband yet."],[1739,1860,"We just moved to the city."],[1939,1997,"Wait, who's we?"],[2147,2210,"Me and Lightning."],[2869,2927,"Who are you?"],[3078,3169,"I'm Daisy Tucker."],[3399,3549,"I'm from Hot Springs, Wyoming."],[3670,3720,"And..."],[3841,3941,"Just because you're about"],[3945,4124,"the dreamiest man I've ever met,"],[4220,4358,"doesn't mean I'm gonna marry you."],[4416,4671,"Even if it means all the money"],[4671,4821,"you could ever need?"],[5447,5522,"Just uhm,"],[5697,5772,"give me a second."],[6172,6206,"Well,"],[6293,6393,"what do you think, Lightning?"],[6464,6489,"I mean,"],[6489,6560,"I don't wanna marry"],[6560,6685,"a total stranger, but"],[6744,6856,"they seem like they could"],[6856,7007,"have money for Dad's surgery."],[7336,7520,"I think you should stop being selfish,"],[7520,7570,"Daisy,"],[7595,7699,"and save your dad."],[7845,7903,"Damn it."],[7970,8028,"You're right."],[8229,8354,"But no carrots for you tonight."],[8379,8541,"Either marry her,"],[8591,8829,"or you have to marry the heiress"],[8833,8979,"of the Anders family,"],[9017,9084,"Bianca."],[9284,9392,"Neither of us want that."],[9492,9563,"Besides,"],[9605,9763,"Daisy is perfect."],[9809,9947,"We don't know anything about her"],[9984,10068,"other than the fact that"],[10068,10168,"she's currently"],[10222,10356,"talking to a horse."],[10372,10493,"She's probably just trying to scam us"],[10493,10564,"for our money."],[10681,10714,"I,"],[10823,10898,"I will marry you."],[10998,11031,"But,"],[11190,11290,"I need $100,000."],[11378,11403,"See!"],[11415,11453,"I knew it!"],[11519,11565,"Done!"],[11619,11674,"Grandpa!"],[11699,11749,"What?"],[11782,11966,"It's a small price to pay"],[11966,12024,"for such a"],[12062,12166,"perfect wife!"],[12224,12366,"Now come on you two,"],[12404,12566,"let's go get you married!"],[12620,12687,"Now? -Now?"],[12779,12837,"Yes."]],"4":[[621,754,"I've only been in the big city"],[754,834,"for a few hours,"],[834,930,"and I'm already married to"],[930,1026,"a stranger."],[1484,1626,"Well, Husband."],[1705,1847,"Today has been crazy."],[1926,1960,"But,"],[2122,2181,"I'm gonna be late"],[2181,2277,"for my first day of work."],[2277,2335,"No problem."],[2556,2594,"Wife."],[2715,2802,"You can board your horse"],[2802,2877,"at my stables."],[2894,2936,"No problem."],[2940,3240,"You have your own stables?"],[3474,3566,"Holy Pete!"],[3678,3791,"Do you own this town?"],[3895,4162,"Did I just marry Mr. NYC?"],[4287,4437,"There's something about you,"],[4512,4604,"Cowgirl."],[5221,5263,"Well,"],[5372,5447,"this is where I work."],[5555,5663,"You work at Smith Records?"],[5768,5914,"Yeah, as a cleaner."],[5976,6031,"But don't worry,"],[6060,6156,"even though it might take me a bit"],[6156,6218,"to pay you back."],[6256,6331,"I promise."],[6418,6464,"I'll give you back"],[6473,6573,"all the money you loaned me."],[6681,6715,"Pay back?"],[6823,7002,"But you're my wife."],[7007,7057,"That doesn't mean"],[7057,7190,"I'm just gonna take your money."],[7278,7382,"That's not how we do things"],[7382,7449,"in Wyoming."],[7882,7982,"So she's not into me"],[7982,8083,"just for my money?"],[8112,8158,"Sir,"],[8233,8324,"does your wife need any"],[8324,8462,"special treatment at your company?"],[8842,8883,"I don't think"],[8883,9063,"my girl needs any help at all."],[9392,9613,"Hi, um, I'm Daisy Tucker."],[9672,9772,"I'm here to start as a cleaner."],[9780,9859,"You're late."],[9901,9930,"I don't know"],[9930,10072,"what methed-out trailer park"],[10072,10147,"you worked in before."],[10147,10243,"But here in the city,"],[10272,10381,"we show up on time."],[10460,10514,"I..."],[11040,11136,"Ham is arriving soon,"],[11198,11298,"all lower-level staff"],[11298,11394,"need to clear the floor."],[11469,11515,"Ham?"],[11599,11724,"Yes, Ham."],[11732,11878,"As in Hamilton Smith,"],[11891,12095,"founder and CEO of Smith Media."],[12099,12191,"How do you not know"],[12191,12287,"our CEO's name?"],[12942,13075,"Hamilton Smith."],[13392,13538,"That's my new husband's name!"]],"5":[[145,283,"Are you really saying that"],[291,550,"you're married to our CEO?"],[596,746,"Well, I, I mean,"],[746,975,"I'm married to a Hamilton Smith."],[1317,1422,"Why did you hit me?"],[1459,1576,"You need to know your place."],[1593,1826,"No one disrespect my Ham"],[1826,1972,"by lying about him like that!"],[1993,2093,"Your Ham?"],[2102,2289,"This is Bianca Anders,"],[2310,2494,"heiress to the Anders Family Group."],[2540,2631,"She and Hamilton"],[2631,2723,"have been sweethearts"],[2723,2827,"since they were children."],[2836,2923,"Sweethearts?"],[2965,3028,"Candace,"],[3078,3224,"don't you think the floor is looking"],[3257,3449,"just a little dirty?"],[3878,3953,"Well,"],[3978,4058,"clean it up!"],[4091,4212,"Or is white trash Wendy"],[4212,4366,"too good to do her job now?"],[4446,4600,"I still have to pay back the money."],[4675,4792,"I can't lose this job."],[6293,6356,"Get in there!"],[6594,6760,"What is wrong with y’all?"],[6948,7002,"Y’all."],[9346,9459,"Mr. Smith is here!"]],"6":[[1526,1630,"You okay there, Cowgirl?"],[1935,1997,"Ham!"],[2056,2102,"Mr. Smith,"],[2102,2293,"it is so wonderful to see you!"],[2498,2640,"Are you really the CEO"],[2669,2802,"of Smith Media?"],[2998,3186,"Mr. Smith, I am so sorry that"],[3194,3324,"this cleaning lady thinks that"],[3324,3436,"she can talk to you."],[3482,3682,"We will fire her immediately."],[3703,3883,"We don't need a scum like this"],[3883,3974,"working here."],[4179,4262,"You would really fire her"],[4262,4350,"for just talking to me?"],[4408,4496,"And why did you just call her"],[4496,4554,"a scum?"],[4625,4662,"You’re the one"],[4662,4763,"who doesn't need to work here."],[4783,4833,"You're fired."],[4850,4942,"What? - Security!"],[5021,5142,"Wait, wait, wait, wait, wait."],[5150,5301,"Oh, no, no, no. You don't understand."],[5309,5384,"Ms. Anders,"],[5392,5543,"can you back me up here, please?"],[5547,5638,"Tell them what happened!"],[5643,5718,"You really shouldn't"],[5718,5885,"talk to people like that, Candace."],[5939,6018,"Take her away. - What?"],[6022,6093,"No!"],[6106,6222,"No, I, I made a mistake."],[6222,6322,"I'm sorry!"],[6360,6423,"Ham,"],[6489,6619,"we have a meeting in 10 minutes."],[6623,6685,"And you know"],[6685,6823,"I don't like being called Ham!"],[7336,7457,"Come to my office later."],[9342,9496,"So, you're really the CEO"],[9496,9597,"of this place?"],[9926,10014,"Why did you pretend"],[10014,10089,"you didn't know me?"],[10135,10276,"Are you embarrassed to be married"],[10276,10410,"to one of your cleaning ladies?"],[10427,10673,"Whoa, whoa, no, no!"],[10752,10777,"I'm..."],[10865,11011,"I wanted to keep it a secret because"],[11169,11252,"I want to make a big,"],[11298,11386,"grand announcement."],[11461,11586,"How could I ever be"],[11586,11703,"embarrassed of you?"],[11832,11886,"I mean,"],[12132,12241,"you're incredible."]],"7":[[458,583,"If the wrong people find out"],[583,667,"I'm married to him,"],[675,771,"they'll expose my past"],[771,863,"and there's no way"],[863,967,"he'll want to be with me."],[1026,1172,"Um, I think we should"],[1172,1263,"keep our marriage a secret."],[1380,1409,"Why?"],[1551,1776,"So it doesn't affect either of our jobs."],[2047,2214,"You want to keep this job?"],[2398,2485,"Well, of course!"],[2577,2723,"I was raised to pull my own weight."],[2731,2773,"And,"],[2840,2990,"I know I'm just a cleaning lady, but"],[3069,3182,"I promise, I'll do my best,"],[3190,3286,"and I'll never ask you"],[3286,3370,"for special treatment"],[3370,3486,"just because we're married."],[3553,3716,"I can't believe I thought my wife"],[3716,3837,"was just in it for the money."],[3878,4074,"You're even a more amazing woman"],[4074,4112,"than I thought,"],[4154,4225,"Daisy Tucker."]],"8":[[942,1034,"I should get back to work."],[1805,1906,"Marrying her was probably"],[1906,2035,"the best accident in my life."],[2414,2523,"So yeah, just get the briefs ready"],[2527,2594,"and then the meeting starts"],[2594,2665,"in three minutes, okay?"],[2857,2915,"Ham, wait!"],[2973,3061,"Let me fix your collar."],[3169,3207,"Yeah."],[3440,3607,"Only two hours in the big city,"],[3624,3741,"and I've already got myself"],[3753,3924,"a pretty amazing husband."],[4804,4896,"Oh my God."],[5246,5284,"Bianca."],[5455,5501,"I don't care that"],[5501,5622,"our families want us to be together."],[5680,5751,"I'm your boss."],[5755,5930,"Please, just keep it professional."],[6018,6181,"And don't call me Ham."],[7144,7265,"Hey, um,"],[7336,7486,"do you know what the deal is"],[7486,7686,"with Bianca and Mr. Smith?"],[7766,7949,"Oh, she's totally in love with him."],[8153,8245,"That's why she works here,"],[8245,8395,"so she can be close to him."],[8500,8537,"And,"],[8650,8817,"how does he feel about her?"],[8842,9034,"I mean, he's never explicitly said,"],[9096,9351,"but he has publicly mentioned that"],[9351,9534,"he's been in love with someone"],[9547,9634,"for three years."],[9659,9993,"And that someone is Bianca?"],[10022,10164,"It has to be, right?"],[10214,10256,"I mean,"],[10318,10414,"I've never seen him with"],[10427,10560,"any other women."],[10618,10789,"Why does he act like he cares,"],[10902,11052,"if he's in love with someone else?"]],"9":[[166,196,"Hey."],[337,417,"Be careful."],[462,671,"Ms. Anders is crazy jealous."],[700,859,"She can make your life a living hell."],[1096,1205,"Bye. - Bye."],[1818,1976,"I really want my marriage to be"],[2152,2252,"confidential for now."],[2464,2515,"Ham?"],[2556,2631,"You're married?"],[2761,2861,"When did you get married?"],[2882,2932,"To who?"],[2940,3098,"I joined this company for you!"],[3107,3132,"Ham!"],[3148,3190,"Bianca,"],[3311,3374,"I've told you,"],[3395,3478,"you're like a sister to me."],[3495,3591,"How could you do this to me?"],[3611,3687,"I love you!"],[3691,3782,"We belong together!"],[3787,3912,"Jesus Christ, Bianca!"],[3912,4020,"Don't say things like that!"],[4120,4191,"No!"],[5155,5234,"Yeah, Godmother."],[5280,5376,"You’re married!"],[5538,5743,"I just spoke with your grandfather,"],[5789,5993,"and I am so excited."],[6031,6193,"I'm coming over to your office later"],[6193,6272,"to meet her."],[6289,6448,"Great, I'll send you a car."],[6473,6614,"Oh no, no need."],[6677,6902,"I can make my way there myself."],[6915,6998,"I'll see you later."],[8958,9125,"Hello, Ms. Wallace!"]],"10":[[613,688,"Ms. Wallace,"],[725,784,"you look"],[896,946,"different."],[988,1017,"Oh,"],[1105,1163,"I'm meeting my"],[1213,1368,"Godson's wife today."],[1455,1572,"She's from a small town,"],[1572,1593,"so,"],[1634,1710,"I don't know, I wanted to"],[1710,1851,"appear more approachable."],[2014,2122,"Will you be taking the limousine,"],[2143,2235,"or the helicopter?"],[2369,2419,"You know what?"],[2431,2552,"It's such a beautiful day."],[2619,2698,"I think I'll walk."],[3611,3691,"Come on people!"],[3724,3883,"Everything needs to look perfect!"],[3899,4016,"Meredith Wallace is coming in!"],[4020,4137,"She's the most powerful"],[4137,4233,"businesswoman in the world,"],[4258,4462,"and our CEO's own Godmother!"],[4579,4646,"Look alive."],[4679,4804,"If I can impress her,"],[4829,4971,"she'll help me get closer to Hamilton."],[5376,5422,"Oh,"],[5467,5555,"that was a longer walk"],[5555,5659,"than I expected."],[5705,5814,"I need some water,"],[5814,5864,"before I meet"],[5864,5985,"Hamilton's new wife."],[6652,6873,"Oh, I am sorry, young lady."],[6873,7007,"Ew, this trailer trash"],[7007,7119,"just got her goopy sweat"],[7119,7169,"all over my"],[7169,7290,"thousand dollar blouse!"]],"11":[[50,237,"Excuse me?"],[279,412,"Yes, you're excused,"],[437,492,"out the door!"],[496,608,"You don't belong here!"],[1297,1347,"Hey!"],[1463,1564,"What are you doing?"],[1680,1739,"Daisy,"],[1755,1935,"is this an inbred relative of yours?"],[1968,2022,"Daisy?"],[2089,2260,"She's Hamilton's new wife!"],[2298,2394,"Are you okay, ma'am?"],[2448,2573,"Here, let me get you a chair."],[2715,2806,"Come on, let's sit down."],[2957,3061,"Here, let me get you some water."],[3319,3436,"What are you doing?"],[3782,3928,"This is not a soup kitchen!"],[3941,4033,"Get her out!"],[4137,4266,"She just fell!"],[4270,4412,"She needs to rest!"],[4421,4525,"She needs to leave!"],[4571,4758,"Meredith Wallace is about to arrive."],[4833,4913,"She doesn't realize"],[4925,5071,"I'm Meredith Wallace."],[5117,5242,"Probably because I’m not in"],[5242,5376,"a thousand-dollar blouse."],[5413,5534,"And we can't have our image"],[5534,5726,"ruined by dirty charity cases."],[5743,5864,"How can you speak"],[5864,6018,"to another human being like that?"],[6018,6151,"What is wrong with you?"]],"12":[[16,120,"How dare you!"],[120,325,"Do you have any idea who I am,"],[325,437,"you miserable little redneck?"],[458,525,"You’re fired!"],[533,625,"Okay."],[692,742,"That's it."],[829,1059,"Now, I don't know who you are,"],[1117,1297,"but I do know the Smith Family"],[1322,1609,"would never ever fire an employee"],[1664,1780,"for helping someone."],[1926,2056,"Oh, shut up, you old bag."],[2102,2214,"Shouldn't you be at the pharmacy,"],[2214,2293,"getting your OxyContin"],[2293,2398,"prescription refilled?"],[2673,2765,"Is this"],[2802,3094,"how Smith Record's managers act?"],[3190,3361,"As long as I'm here today,"],[3445,3582,"Daisy's job is safe."],[3703,3891,"But as for you, young lady,"],[3970,4074,"you will be fired"],[4133,4258,"by the time the day's over."],[4421,4496,"Oh really?"],[4533,4621,"And who's gonna do that?"],[4688,4721,"You?"],[4796,5109,"You are talking to Bianca Anders,"],[5167,5363,"as in heiress of"],[5363,5459,"Anders Entertainment,"],[5501,5605,"and one of our CEO's"],[5605,5722,"closest advisors?"],[5730,5793,"Ham and I are"],[5922,6172,"very very close."],[6322,6481,"If you know what I mean."]],"13":[[41,204,"Ms. Wallace will be here any second"],[225,354,"and I need these two gone"],[354,450,"before she arrives."],[500,604,"Drag them out!"],[654,679,"Wait!"],[709,742,"Stop."],[880,942,"Hey, stop!"],[946,1105,"This is, this is my fault."],[1117,1272,"Okay, she needs a moment to rest!"],[1284,1338,"Enough!"],[1459,1609,"If anyone else"],[1639,1889,"touches either myself or Daisy,"],[1935,2031,"I will see to it"],[2081,2268,"that Hamilton Smith himself"],[2289,2419,"personally fires you!"],[2423,2585,"Take his name out of your mouth!"],[2594,2669,"Child."],[2740,2923,"You have no idea"],[2952,3128,"just how absolutely"],[3153,3420,"and completely screwed you are."],[3636,3682,"Oh!"],[3916,4062,"Did you just assault me?"],[4104,4262,"Hold her until the police arrive!"],[4325,4350,"Aw."],[4391,4491,"Bianca, stop!"],[4533,4721,"Just please, go get Mr. Smith,"],[4733,4821,"he'll sort this out!"],[4892,4938,"Oh right."],[4979,5188,"I'm going to waste our CEO's time"],[5209,5409,"with two bumpkins from the sticks?"],[5643,5705,"Listen here."],[5755,5889,"Ever since you got here today,"],[5889,5964,"you have been nothing"],[5964,6156,"but a pain in my ass."],[6206,6368,"And that is it!"],[6493,6602,"Mr. Smith is here!"]],"14":[[104,221,"Take your hands off them!"],[246,312,"Hamilton, uh,"],[342,513,"please, uh, please, uh, don't worry."],[513,583,"I have this"],[583,725,"completely under control."],[825,988,"Godmother, are you okay?"],[1363,1497,"Uh, uh."],[1568,1647,"Godmother?"],[1664,1897,"You’re Meredith Wallace?"],[1897,2118,"Uh, I, I'm so sorry!"],[2135,2231,"I didn't recognize you."],[2231,2306,"I, I'm so sorry."],[2389,2548,"Don't apologize to me."],[2623,2777,"Apologize to Daisy."],[2815,2877,"Bianca."],[2923,3048,"What did you do to Daisy?"],[3061,3319,"Uh, Ham, uh, we can't have some"],[3328,3465,"rude, disrespectful cleaning lady"],[3474,3578,"contradicting me like this"],[3578,3620,"all the time."],[3632,3732,"She needs to go."],[3745,3787,"Enough!"],[3841,3891,"Enough!"],[3937,4008,"From now on,"],[4008,4141,"Daisy's under my protection."],[4191,4320,"Anytime you yell at her,"],[4329,4475,"anytime that you attack her,"],[4483,4587,"that's an attack on me."],[4608,4746,"And I will react accordingly."],[5109,5321,"You're not going anywhere, Cowgirl."],[5584,5751,"Ham, uh, what's gotten into you?"],[5751,5860,"Why do you care so much about this"],[5885,5955,"cleaning lady?"],[6156,6218,"Because,"],[6660,6710,"because"],[6773,7011,"this cleaning lady is..."]],"15":[[87,216,"Because this cleaning lady"],[216,266,"is my-"],[383,496,"If the wrong people find out"],[496,579,"we're married,"],[596,738,"they'll expose my past to Hamilton,"],[738,867,"and he'll divorce me!"],[963,1026,"Mr. Smith."],[1084,1247,"I don't need any special treatment"],[1247,1388,"because I saved Ms. Wallace."],[1455,1551,"If I make mistakes,"],[1564,1710,"I'll take responsibility."],[1764,1805,"Hmm."],[1856,2039,"Got yourself a great"],[2052,2210,"cleaning lady there, Hamilton."],[2648,2740,"And as for you,"],[2756,2861,"out of respect"],[2919,3082,"for your long relationship"],[3082,3190,"with my Godson,"],[3232,3374,"I'm gonna let this slide."],[3461,3591,"But if I ever"],[3653,3878,"ever see you treat someone"],[3878,3962,"like that again,"],[4016,4187,"I will crush you."],[4316,4362,"Come on."],[4450,4567,"We have a lot to talk about."],[4909,5088,"Ham, I, I screwed up."],[5088,5251,"I, if I would have recognized her-"],[5255,5355,"You still don't get it, do you?"],[5384,5526,"You don't treat anyone like that,"],[5526,5647,"no matter what they look like."],[5676,5780,"You are so lucky"],[5780,5847,"that my Godmother"],[5847,5914,"is forgiving,"],[5926,6072,"or else you'd be out on your ass"],[6072,6114,"right now!"],[6181,6381,"I, I, I'm sorry."],[6489,6589,"Mr. Smith,"],[6631,6810,"the ring you had custom made,"],[6877,6990,"it arrived."],[7240,7365,"Oh my God!"],[7649,7707,"Thank you."],[8128,8212,"That thing"],[8212,8395,"cost more than my house."],[8429,8554,"Who do you think it's for?"],[8575,8717,"Isn't it obvious?"],[8737,8837,"Bianca!"],[8879,8992,"Their families have wanted them"],[8992,9138,"to get together for years."],[9146,9346,"That's why he was so mad!"],[9355,9463,"If that whole situation"],[9463,9547,"hadn't happened,"],[9609,9788,"he was going to propose to you!"],[10093,10239,"I knew he had feelings for me!"]],"16":[[145,246,"Oh, Ham,"],[321,450,"you've found yourself"],[450,608,"an amazing wife."],[650,784,"Welcome to the family."],[859,971,"Do you wanna grab lunch?"],[992,1184,"I'd love to, but my driver's here."],[1238,1347,"I think I'll give you two"],[1347,1509,"a little alone time."],[2027,2168,"Do you wanna grab lunch?"],[2223,2306,"It could be a little"],[2410,2489,"afternoon date."],[2727,2786,"Um."],[2919,2961,"I..."],[3078,3253,"I think I should get back to work."],[3286,3315,"Wait."],[3795,3874,"Now that we're"],[3941,4020,"husband and wife."],[4237,4279,"Um."],[4371,4587,"Hamilton, I'm, I'm not ready to-"],[4788,4879,"I got you this."],[5284,5376,"I know it usually comes"],[5376,5484,"before the wedding, but"],[5697,5776,"I wanted you to have a ring."],[6285,6531,"Oh, Hamilton, it's so beautiful."],[6664,6702,"But,"],[6881,7015,"I can't wear this at work,"],[7015,7094,"it's too much."],[7240,7328,"You can wear it"],[7386,7494,"underneath your uniform."],[8654,8700,"Now,"],[8854,9071,"it'll just be our little secret."]],"17":[[75,125,"Ham!"],[333,425,"What's going on in here?"],[492,763,"Um, it's, um, nothing."],[813,1013,"I was just fixing my ID badge."],[1055,1222,"Uh, Ham was,"],[1222,1426,"Hamilton was helping me, um,"],[1576,1634,"fix it."],[1764,1989,"I should get back to work."],[3303,3415,"Look who it is."],[3415,3674,"The scandalous Daisy Tucker!"],[3762,3870,"Long time no see!"],[3870,3920,"Huh?"],[3953,3987,"Greg."],[4170,4258,"What are you doing here?"],[4258,4412,"I could ask you the same question."],[4412,4525,"I thought you ran away home"],[4525,4646,"to the farm for good."],[4696,4763,"So,"],[4838,5013,"you're the cleaning lady here, huh?"],[5050,5188,"Living the dream."],[5201,5321,"How about you go take a nap"],[5321,5492,"in front of a moving tractor?"],[5534,5572,"Come on,"],[5572,5759,"that's no way to talk to an old friend?"],[5759,5943,"We're a long way from friends."],[6064,6139,"What do you want?"],[6164,6222,"From you?"],[6264,6327,"Nothing!"],[6360,6456,"I'm now the right hand man"],[6456,6544,"to Meredith Wallace."],[6544,6623,"Do you have any idea"],[6623,6748,"how powerful that makes me?"],[6915,6969,"And yet,"],[7032,7236,"you're still a total piece of cowshit."],[7482,7515,"Hey!"],[7570,7703,"This suit costs more than your life!"],[7703,7749,"Slut!"],[8049,8145,"Oh, Ms. Anders."],[8145,8245,"Hey, good to see you!"],[8366,8450,"Greg."],[8575,8671,"Didn't my family"],[8671,8796,"fire you for stealing?"],[8796,8917,"No, that's all in the past."],[8917,9046,"Please don't tell, uh."],[9046,9100,"I won't."],[9175,9401,"If you do something for me."],[9430,9492,"Anything!"],[9713,9830,"I want you to destroy"],[9830,10010,"that prissy bitch Daisy."],[10214,10381,"With pleasure."]],"18":[[417,508,"Missed a spot!"],[880,1063,"Leave me alone, Greg."],[1063,1155,"Oh, come on,"],[1155,1280,"I'm just playing around!"],[1363,1405,"You see,"],[1405,1518,"me and Daisy go way back."],[1580,1614,"I knew her"],[1614,1760,"when she first moved to the big city."],[1797,1935,"Greg, no."],[2047,2160,"If they find out my past,"],[2160,2252,"they'll tell Hamilton,"],[2252,2373,"and he'll divorce me!"],[2373,2560,"Wait, Daisy, you were here before?"],[2648,2694,"Stop."],[2794,2836,"Please."],[2911,2944,"What?"],[2969,3048,"She didn't tell you?"],[3048,3165,"I’m begging you!"],[3307,3503,"Daisy is a music prodigy."],[3570,3645,"She came here to be on"],[3645,3807,"America's Next Popstar."],[3807,3953,"I love that show."],[3999,4158,"I can't believe you were on it, Daisy!"],[4195,4383,"Oh, no, she wasn't."],[4475,4554,"You wanna tell them why?"],[4633,4738,"You bastard."],[4763,4871,"She was kicked off,"],[4946,5092,"and all her footage was cut before it"],[5092,5163,"made it to air"],[5163,5288,"because she tried to seduce"],[5288,5392,"one of the judges."],[5442,5480,"What!"],[5518,5613,"Oh my God!"],[5613,5714,"That is horrible!"],[5739,5768,"Yep."],[5818,5951,"And she went home in disgrace."],[6022,6151,"Just another small town whore"],[6151,6289,"who couldn't make it in the big city."]],"19":[[45,166,"I didn't expect to see you back"],[166,296,"only after a couple years,"],[308,446,"after such a big scandal."],[504,650,"That story's not true."],[675,792,"And he knows it!"],[804,909,"So you weren’t on"],[909,1030,"America's Next Popstar?"],[1063,1197,"And you weren’t disqualified?"],[1197,1251,"That's not-"],[1251,1451,"I was interning at the show,"],[1451,1551,"and everyone knew"],[1551,1672,"she was trying to sleep her way"],[1672,1735,"to the top!"],[1772,1918,"I bet she's doing the same thing here,"],[1918,2068,"trying to seduce Hamilton Smith"],[2093,2243,"and sleep her way to success!"],[2243,2402,"Oh my God, she totally is!"],[2435,2523,"She has been trying to"],[2523,2727,"get close to Mr. Smith all day!"],[2740,2815,"I knew it!"],[2869,3115,"Okay, yes, I was on the show."],[3132,3265,"But I never tried to seduce"],[3265,3361,"any of the judges."],[3403,3536,"He made up that rumor"],[3566,3707,"to try to get me kicked off the show,"],[3707,3853,"once I wouldn't sleep with him!"],[3891,3966,"Why would I ever wanna"],[3966,4112,"sleep with a nobody like you?"],[4270,4366,"Do you 