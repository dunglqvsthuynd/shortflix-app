s"],[5063,5292,"from messing with an Anders."]],"66":[[675,796,"Ms. Anders,"],[838,967,"I was surprised you called."],[988,1163,"You mean after my family fired you"],[1163,1226,"because you tried to"],[1226,1326,"assault our maid?"],[1447,1501,"What do you want?"],[1639,1780,"How'd you like to make five grand?"],[1868,1939,"I'm listening."],[2060,2131,"See that girl?"],[2181,2277,"I need you to destroy"],[2277,2377,"her reputation."],[2510,2606,"How am I supposed to do that?"],[2610,2723,"I want you to sleep with her,"],[2765,2840,"and film it."],[2911,2977,"I'll make sure"],[2977,3119,"the video gets in the right hands."],[3161,3349,"I know I'm pretty and all,"],[3349,3420,"but"],[3420,3574,"what if she won't sleep with me?"],[3582,3666,"Oh please."],[3703,3770,"You're a creep."],[3824,3933,"You can figure it out."],[3991,4145,"Oh."],[4333,4471,"This will be fun."],[4767,4829,"Oh Daisy."],[4859,4913,"Pretty soon,"],[4963,5067,"Hamilton will never"],[5067,5242,"want to even look at you again."]],"67":[[4037,4112,"Scream,"],[4279,4446,"and I get real nasty."],[4984,5176,"Who, who, who are you?"],[5355,5447,"What do you want?"],[5576,5697,"I just wanna have some fun,"],[5889,5943,"on camera."],[6247,6318,"What are you gonna do?"],[6406,6452,"Well,"],[6552,6681,"that depends on you."],[6827,6944,"Do you wanna do this"],[7019,7190,"the easy way, or"],[7461,7565,"the hard way?"]],"68":[[496,563,"It's been a while."],[654,738,"Have you seen Daisy?"],[784,888,"I believe she was at the spa."],[1038,1084,"Still?"],[1572,1626,"What is that?"],[2043,2223,"Oh my God, it's Daisy's ring."],[2431,2502,"She's in trouble."],[2556,2631,"Check all the rooms."],[2677,2802,"Check all the security cameras."],[3119,3294,"Why, why are you doing this?"],[3340,3516,"Because you tried to"],[3516,3687,"reach above your position."],[3782,3937,"You messed with your betters."],[4041,4275,"What, what are you talking about?"],[4275,4362,"I'm talking about you marrying"],[4362,4458,"Hamilton Smith."],[4562,4754,"Hamilton and I"],[4804,4925,"aren't married. - Oh."],[5150,5271,"Don't lie to me."],[5317,5447,"I don't like liars."],[5672,5855,"Why do you care so much"],[5880,6043,"if I'm married to Hamilton?"],[6156,6247,"Who sent you?"],[6602,6710,"Was it Bianca?"],[6819,7007,"Oh, look at the country bumpkin,"],[7015,7207,"putting the pieces together."],[7290,7361,"What does she want you"],[7361,7465,"to do to me?"],[7824,7945,"It's better if I show you."]],"69":[[8,137,"It's better if I show you."],[567,721,"This is gonna go a lot easier for you"],[721,825,"if you pretend to like it."],[871,925,"Help!"],[996,1071,"Help!"],[1092,1172,"Help!"],[1343,1380,"Fine."],[1422,1514,"Have it your way."],[2419,2477,"Daisy."],[2544,2590,"You!"],[3599,3636,"Daisy!"],[3724,3774,"Daisy."],[3845,3924,"It's gonna be okay."],[3974,4175,"Go call a doctor, now!"],[4825,4925,"Doctor, is she okay?"],[4988,5130,"Uh, just a slight injury."],[5134,5321,"But they're both gonna be fine."],[5543,5593,"Both?"],[5693,5893,"Yes, your wife is pregnant."]],"70":[[54,216,"Yes, your wife is pregnant."],[538,633,"Was it from that night?"],[788,917,"Daisy, why didn't you tell me?"],[946,1034,"Because..."],[1297,1438,"I can't have a child"],[1438,1584,"with a father who doesn't want them."],[1685,1835,"Why on earth would make you think"],[1835,1931,"that I wouldn't wanna have a child"],[1931,1964,"with you?"],[1964,2081,"Because you told me."],[2177,2364,"You said you only want a family"],[2381,2510,"with the woman you love."],[2794,2840,"Daisy, I,"],[2919,3007,"I have no interest"],[3007,3107,"in starting a family,"],[3182,3319,"unless it's the woman I love."],[3399,3503,"I need you to know that."],[3670,3828,"I know I'm not the woman you love."],[3908,4012,"I know it's Bianca."],[4087,4220,"I've told you a million times-"],[4220,4316,"News flash,"],[4416,4500,"about your lover."],[4550,4696,"The bastard that just attacked me"],[4696,4871,"was sent by Bianca."],[4950,5005,"What?"]],"71":[[29,175,"The bastard that just attacked me"],[175,346,"was sent by Bianca."],[371,446,"What?"],[571,613,"Well,"],[684,813,"it didn't take much for him to talk."],[875,971,"He was hired by Bianca."],[992,1046,"See?"],[1105,1276,"The love of your life, Bianca,"],[1317,1438,"is a psychopath."],[1505,1551,"What?"],[1580,1747,"Bianca's not the love of my life."],[1826,1889,"You are."],[2010,2056,"Me?"],[2235,2402,"But that, that can't be true."],[2464,2569,"You announced that"],[2569,2711,"you were in love with someone else"],[2727,2836,"before we ever met."],[2894,3032,"I was always in love with you."],[3078,3182,"I just didn't know it then."],[3244,3424,"Three years ago I was hit by a car."],[3478,3574,"And I would have died,"],[3574,3649,"but a woman,"],[3724,3832,"a complete stranger,"],[3874,3953,"she saved my life."],[4020,4095,"The guy I brought to"],[4095,4183,"the hospital,"],[4379,4450,"that was you?"]],"72":[[4,100,"The guy I had brought to"],[100,175,"the hospital,"],[379,475,"that was you?"],[588,663,"I was in love with you"],[663,825,"when you were a complete stranger."],[917,1026,"And now that I know you more,"],[1096,1230,"I'm more in love with you."],[1305,1426,"I wanna start a family with you,"],[1426,1501,"Daisy Tucker."],[1622,1676,"Smith."],[1830,1918,"Daisy Smith."],[2006,2118,"Tucker's my maiden name."],[2273,2427,"I'm sorry I was so cold to you."],[2481,2656,"I thought you were in love with Bianca."],[2727,2831,"Well, you know,"],[2844,3007,"situations like this would be avoided"],[3007,3165,"if you two just went public"],[3165,3290,"with your marriage."],[3357,3415,"You know he's right."],[3499,3553,"We're not gonna be able to"],[3553,3636,"hide it much longer."],[3703,3774,"We should announce it"],[3774,3916,"the final evening of the retreat."],[4004,4104,"And I promise you."],[4129,4229,"Bianca's not gonna get away"],[4229,4304,"with what she's done."],[4421,4500,"I have something special"],[4558,4621,"planned for her."]],"73":[[721,767,"Well?"],[825,1005,"I did exactly what you told me."],[1071,1213,"He saw a video of me"],[1213,1351,"having my way with her"],[1351,1438,"and sent her ass"],[1438,1651,"on the first bus back to Wyoming."],[1705,1893,"They're finalizing the divorce now."],[1926,2106,"Oh, you brilliant scumbag."],[2177,2223,"Well done."],[2314,2373,"Money's there."],[3236,3415,"Pleasure doing business with you."],[4496,4579,"All here."],[4783,4917,"Evidence that Bianca hired me."]],"74":[[29,70,"So,"],[191,266,"you talk to the judge"],[266,358,"and ask for leniency?"],[392,554,"Yeah, I'll talk to the judge."],[633,817,"But I won't ask for leniency."],[905,1063,"You tried to rape my wife."],[1092,1234,"You're going to rot in prison."],[1376,1413,"What?"],[1459,1514,"What?"],[1539,1593,"Wait!"],[1626,1722,"You tricked me!"],[2969,3061,"Oh, Ham."],[3111,3224,"What a surprise."],[3278,3399,"My arm is so much better,"],[3399,3524,"I, I get out of here tomorrow."],[3541,3653,"That's so great to hear."],[3741,3803,"Look, I don't think,"],[3883,3995,"I don't think I treated you fairly"],[3995,4095,"when I fired you."],[4162,4275,"I want you to come back."],[4316,4354,"Really?"],[4383,4416,"Yeah."],[4475,4617,"We're having our end of year retreat"],[4633,4717,"gala tomorrow night,"],[4729,4829,"and I want you there."],[4925,5063,"I have a special surprise for you."]],"75":[[12,171,"I have a special surprise for you."],[291,421,"What kind of surprise?"],[500,592,"I've been through so much"],[592,692,"these past few months,"],[792,888,"and I've realized something."],[975,1017,"I've realized"],[1017,1201,"we belong together forever."],[1251,1313,"Oh my God,"],[1326,1455,"are, are you proposing to me?"],[1459,1647,"No, no, not in this hospital."],[1647,1801,"That's, that's not romantic."],[1906,1985,"Oh my god, oh my god"],[1985,2047,"oh my god, oh my god!"],[2047,2164,"Alright, Bianca."],[2202,2302,"I'll see you tomorrow night."],[2373,2439,"And be sure"],[2477,2590,"to wear something memorable."],[2911,2982,"Oh my god,"],[3044,3182,"I'm getting married!"],[3332,3386,"Suck on that,"],[3407,3687,"Daisy, you stupid redneck slut."],[4333,4500,"So Mr. Smith brought you back,"],[4500,4567,"and is going to"],[4567,4696,"propose to you tonight?"],[4713,4746,"Wait,"],[4767,4871,"I thought Mr. Smith"],[4888,5005,"was already married?"],[5034,5084,"No."],[5121,5213,"He was never married."],[5255,5338,"That was just a diversion"],[5338,5426,"we created"],[5426,5513,"so that people wouldn't know"],[5513,5580,"we were together."],[5626,5939,"But it was always, always just me."],[5976,6072,"I'm his one true love."],[6214,6343,"Look, here he comes!"],[7328,7382,"Ham."],[7419,7528,"The surprise should be coming"],[7528,7603,"in just one second."],[7640,7703,"Oh my God,"],[7728,7845,"he's about to propose!"],[7949,8149,"Oh my God, look at Daisy!"]],"76":[[120,329,"Oh my God, look at Daisy!"],[329,483,"She looks like a princess."],[946,1034,"Ladies and gentlemen,"],[1071,1242,"it has been such an amazing retreat."],[1292,1355,"And to end it,"],[1401,1493,"I wanted to share"],[1505,1680,"a special personal announcement."],[1830,1918,"I thought you went back"],[1918,2010,"to your shit farm."],[2068,2131,"I would like to"],[2131,2227,"formally introduce you"],[2227,2293,"to the woman I'm gonna"],[2293,2435,"spend the rest of my life with."],[2523,2598,"But it doesn't matter,"],[2610,2752,"because in about three seconds,"],[2790,2919,"all of this will be mine."],[2932,3032,"The love of my life."],[3866,3945,"I would like to formally"],[3945,4045,"introduce you to"],[4095,4220,"my wife, Daisy."],[4275,4354,"Surprise!"],[4366,4421,"She was- - Oh my God!"],[4483,4542,"I knew it!"],[4550,4637,"I Knew it! - Daisy!"],[4813,4950,"Sorry we kept it a secret."],[4950,5134,"We wanted to keep it low-profile"],[5150,5217,"for a while."],[5221,5342,"But you brought me here"],[5342,5426,"because you were going to"],[5426,5526,"propose to me!"],[5805,5864,"Jesus."],[5885,5980,"I brought you here"],[5997,6072,"so the police knew"],[6081,6156,"exactly where you were"],[6156,6281,"when they come to arrest you."],[6606,6664,"What?"]],"77":[[4,108,"Your henchman, Trevor,"],[120,237,"confessed to everything."],[250,333,"You're going to jail."],[429,492,"I sacrificed"],[500,579,"everything for you!"],[596,658,"You belong with me!"],[658,709,"Not with this"],[721,842,"stupid piece of trailer trash!"],[880,1005,"I have everything you need,"],[1005,1155,"and she has nothing!"],[1230,1351,"She may not have your last name"],[1355,1468,"or your life of privilege,"],[1468,1593,"but I don't need any of that."],[1814,1881,"Get your hand"],[1893,1926,"off of me!"],[1926,2060,"Don't you even know who I am?"],[2444,2548,"All I need is you, Daisy."],[2698,2777,"And we have one last"],[2777,2873,"special announcement."],[2957,3036,"I'm gonna be a father."],[3641,3712,"How does it feel now"],[3712,3782,"that everyone knows about"],[3782,3853,"our marriage?"],[3908,3978,"Not everybody."],[4058,4158,"I still need to take you back"],[4158,4208,"to the farm"],[4208,4346,"to introduce you to my parents."],[4437,4529,"And Lightning's mad that"],[4529,4637,"he hasn't seen you in a while."],[4754,4884,"We need a proper country wedding"],[4884,4988,"before the baby comes."],[5113,5205,"We can discuss that."],[5401,5509,"Woo!"],[5509,5659,"Go, Daisy!"],[5659,5801,"Aww!"]]}