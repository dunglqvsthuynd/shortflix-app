nouncement"],[8758,8883,"that you were in love with someone?"],[8883,9071,"Yeah, that mysterious woman"],[9071,9246,"who saved my life three years ago."],[9325,9463,"I was in a car crash."],[9496,9584,"I almost died."],[9622,9759,"If she hadn't taken me to the E.R."],[9759,9822,"I would have."],[9864,9984,"Well, we were able to make"],[9984,10126,"a positive ID on her."],[10239,10347,"Mysterious woman"],[10402,10548,"who you professed your love for."],[10648,10744,"None other than..."],[11048,11119,"Daisy Tucker."]],"24":[[175,304,"You mean that mysterious woman,"],[346,442,"the woman who I publicly"],[450,571,"professed my love for,"],[658,759,"is actually my wife?"],[817,888,"It appears so."],[975,1092,"God, how did I get so lucky?"],[1146,1180,"Chauncey,"],[1226,1343,"I need you to prepare something."],[1363,1443,"A special gift"],[1522,1584,"for Daisy."],[2047,2168,"That bastard Greg"],[2177,2293,"better not have ratted me out."],[2473,2565,"Why didn't you tell me that"],[2565,2669,"you and Mr. Smith got married?"],[2786,2819,"What!"],[2848,2944,"Oh, stop pretending!"],[2948,3082,"Mr. Smith just admitted to me"],[3082,3174,"that he's married."],[3194,3336,"And I'm not stupid,"],[3365,3591,"I know how close you two are."],[3603,3803,"So why aren't you making it public?"],[3841,4037,"So, the staff think"],[4062,4220,"I’m the mystery wife."],[4366,4542,"This could work to my advantage."],[4625,4846,"Donna, I'm a manager here."],[4859,4971,"It'll look unprofessional,"],[5034,5209,"so keep our marriage under wraps."],[5372,5568,"I am so excited for you!"],[5626,5718,"Mrs. Smith."],[5726,5955,"Yes, there's only one thing."],[5976,6139,"Ever since cleaner Daisy got here,"],[6139,6264,"Ham's been so cold to me."],[6414,6556,"What should I do to get his attention?"],[6664,6706,"I know!"],[6735,6802,"He wants to buy"],[6802,6915,"Platinum Music Group."],[6923,7107,"So, if you set up a broker deal."],[7286,7461,"I know exactly how to do that."]],"25":[[0,29,"Hey."],[87,191,"Keep your eyes closed."],[204,271,"They are."],[400,513,"So you gotta turn."],[621,667,"Surprise."],[713,850,"Hamilton, what is this?"],[905,984,"I got you a gift."],[1101,1188,"It's behind you."],[1226,1330,"But I need to tell you something."],[1397,1505,"I did some digging on you,"],[1505,1593,"Daisy Tucker."],[1614,1676,"And, um."],[1780,1872,"I heard what happened"],[1872,2014,"at America's Next Pop Star."],[2035,2106,"Look, I'm,"],[2193,2352,"I'm sorry I didn't tell you right away."],[2398,2494,"Okay, I, I was going to"],[2494,2623,"but you have to believe me."],[2652,2736,"I didn’t try to"],[2736,2823,"seduce that judge."],[2877,2965,"And you can believe"],[2965,3069,"whatever you want,"],[3086,3178,"but you just have to know that"],[3182,3303,"I would never do that, okay?"],[3303,3390,"It was all a lie."],[3395,3445,"I know."],[3645,3678,"What?"],[3749,3787,"I know."],[3787,3849,"You got screwed over"],[3849,3928,"by some assholes."],[4124,4241,"That's why I got you this."],[4863,5009,"You got me a guitar."],[5067,5234,"That's not just any guitar."],[5284,5417,"That's the guitar"],[5447,5593,"that Dolly Parton used the night"],[5593,5789,"that she wrote the song, Jolene"],[5864,5985,"and I Will Always Love You."],[6072,6139,"Daisy, there's,"],[6189,6343,"there's magic in that guitar."],[6506,6552,"Why?"],[6915,7011,"Why are you giving me this?"],[7082,7161,"I heard you can play."],[7223,7248,"And,"],[7361,7545,"you deserve a guitar that's worthy,"],[7578,7632,"worthy of you."],[7774,7816,"Come on."],[7924,7978,"Play me something."],[7982,8058,"Oh, I,"],[8216,8379,"I haven't played since that day,"],[8400,8475,"three years ago."],[8521,8616,"Wait, you really don't think"],[8616,8754,"I tried to seduce that judge?"],[8775,8837,"No."],[8888,9034,"I know what kind of person you are."]],"26":[[221,387,"Boss, we have a situation."],[433,533,"Ms. Anders just set up"],[533,617,"a music competition"],[617,742,"with The Platinum Music Group."],[775,905,"The winner ge