{"1":[[2521,2654,"Miss Jennings?"],[3833,3962,"You stopped my car?"],[4037,4133,"What do you want?"],[4166,4283,"I want to marry you."],[4666,4812,"Do you know who I am?"],[4866,4945,"I do."],[5016,5170,"Mr. Shepherd from Riverton."],[5258,5387,"Then you must also know"],[5525,5720,"that I'm a cripple."],[5725,5804,"I don't mind."],[6556,6641,"Give me a reason."],[6708,6812,"You need a wife"],[6816,6958,"to put your mother at ease,"],[6991,7112,"and I need your family's power."],[7379,7483,"We each get what we need."],[7562,7725,"What makes you think I'll help you?"],[7820,7966,"If you weren't interested in me,"],[8025,8112,"you wouldn't have"],[8116,8208,"stopped to hear me out."],[8666,8741,"Very well."],[8879,9004,"I'll pick you up this weekend."],[9745,9866,"On the eve of my wedding,"],[9912,10066,"the fiancé I'd loved for ten years"],[10070,10208,"cheated on me with my stepsister."],[10270,10462,"Everyone thought I'd live with that,"],[10475,10591,"but I won't."],[10625,10741,"My mother's shares,"],[10745,10862,"everything my family owns?"],[10875,11025,"I'll take them back personally,"],[11029,11162,"one by one."]],"2":[[108,183,"Mr. Shepherd,"],[250,504,"after all, Esther is Channing's fiancée."],[516,704,"If you agree to her terms,"],[766,895,"won't it cause complications?"],[925,1033,"Besides, after you get married"],[1037,1145,"and live together,"],[1187,1433,"she will find out about your legs."],[1508,1583,"It doesn't matter."],[1737,1833,"Bringing her back"],[1837,1975,"will put Mother at ease."],[2087,2208,"And it's worth seeing"],[2291,2483,"just how far she can go."],[3162,3254,"This is"],[3283,3425,"my future home."],[4000,4112,"Mrs. Shepherd is here."],[4150,4229,"She and Mr. Lewis"],[4233,4387,"are truly a match made in heaven."],[4450,4508,"Of course."],[4512,4695,"Mr. Lewis's devotion to Mrs. Shepherd"],[4700,4808,"is known by everyone in Riverton."],[4829,5012,"I heard every detail of the wedding"],[5016,5175,"was personally finalized by Mr. Lewis."],[5200,5404,"The media calls it the wedding of the century."],[5412,5516,"It's not just the wedding."],[5520,5595,"This Esther Manor"],[5600,5804,"was bought by Mr. Lewis for Mrs. Shepherd."],[5808,5904,"He even set a rule:"],[5912,6087,"except for Mrs. Shepherd and her sister,"],[6091,6291,"no woman may enter the main house."],[6300,6404,"This kind of exclusive affection"],[6408,6516,"is truly one of a kind."],[6575,6654,"Mrs. Shepherd."],[6741,6887,"-Hello, Mrs. Shepherd. -Hello, Mrs. Shepherd."],[7179,7275,"Teddy,"],[7279,7470,"did you come out to welcome me?"],[7550,7645,"Where's Daddy?"],[7975,8045,"Channing,"],[8050,8245,"tell us the best thing that'd happened to you."],[8250,8337,"Do you even have to ask?"],[8341,8429,"It's definitely the fact"],[8433,8562,"that he's about to marry Riverton's"],[8566,8795,"number one beauty, Miss Jennings!"],[8800,8895,"No, no."],[8900,9029,"Let's ask something spicier."],[9050,9129,"Channing,"],[9133,9237,"come clean."],[9250,9550,"Have you done anything to betray Esther?"],[9566,9645,"Yeah."],[10458,10650,"Does lying on her sister's belly"],[10691,10962,"to listen to my son move count?"],[12141,12212,"Channing,"],[12216,12412,"aren't you afraid Esther will get heartbroken"],[12416,12533,"and call off the wedding?"],[12633,12729,"Oh, Cynthia,"],[12754,12862,"Esther and your brother"],[12866,12975,"have been together for ten years."],[12979,13091,"They've weathered"],[13095,13187,"every kind of storm."],[13191,13395,"That's a love she risked her life for."],[13420,13575,"How could she possibly leave Channing"],[13579,13704,"over such a small thing?"],[13720,13883,"Channing, don't forget."],[13920,14066,"When you fell into the river,"],[14070,14366,"Esther saved you and can never be a mother."],[14375,14458,"What you're doing"],[14462,14604,"is no different from stabbing her"],[14608,14670,"straight in the heart."],[14675,14795,"Don't be ridiculous."],[14854,14975,"Esther can't conceive,"],[14979,15104,"but she wants a child."],[15154,15250,"I'm doing this"],[15254,15412,"to help take the pressure off her."],[15716,15850,"As for calling off the wedding,"],[15920,16045,"she would never leave me."],[16050,16250,"She can be a mother without the labor."],[16262,16395,"She should count herself lucky."],[16508,16633,"You really are deluded."],[16687,16812,"Get this straight."],[16816,16954,"It's you who can't live without her,"],[16958,17125,"not the other way around."],[18054,18158,"Esther."],[18266,18345,"Esther."],[18350,18537,"Why did you come without telling me?"],[18666,18795,"Think I came too early,"],[18866,19037,"interrupting your family of three?"],[19083,19187,"Uh, Channing,"],[19191,19287,"we've got something to do,"],[19291,19479,"so we're gotta go."],[19550,19658,"We're leaving too."],[19754,19837,"I got something too."],[19841,19941,"I'm taking off."],[20341,20441,"Esther,"],[20470,20658,"please don't blame Channy."],[20741,20841,"A few months ago,"],[20845,21016,"he was accidentally drugged,"],[21029,21187,"so he mistook me for you."],[21191,21279,"Ember Jennings!"],[21354,21487,"This isn't your place to speak."],[21604,21687,"Esther,"],[21691,21829,"Ember only ended up like this"],[21833,21975,"because of me."],[22041,22187,"Don't take it out on her."],[22587,22704,"Fine."],[22779,22858,"Channing Lewis,"],[22970,23116,"I have just one question for you."],[23291,23458,"Do you choose the baby in her belly,"],[23804,23879,"or me?"]],"3":[[25,108,"Esther,"],[158,329,"please don't blame Channy."],[416,545,"This is all my fault."],[629,670,"If..."],[750,933,"If you really hate this baby,"],[1079,1225,"I'll go get an abortion now."],[1325,1358,"Hey."],[1650,1700,"Esther,"],[1741,1875,"can't you have some compassion?"],[1916,2062,"The baby has already taken shape."],[2133,2208,"You can't have children."],[2237,2408,"Do you want your sister to end up like you?"],[3000,3062,"Esther."],[3454,3625,"If you hadn't saved me"],[3641,3862,"and stayed in that freezing water so long,"],[3883,4087,"you wouldn't be suffering so much now."],[4204,4300,"Channing,"],[4345,4566,"Dr. Jacobs said that I can get pregnant now."],[4625,4750,"I don't know why I still can't"],[4754,4858,"after trying for so long."],[4866,4904,"Esther,"],[4970,5037,"it's okay."],[5091,5245,"Even if we never have children,"],[5258,5379,"it's fine."],[5408,5575,"In this life,"],[5608,5766,"I only want you, Esther."],[6116,6287,"So, you've made your choice?"],[6412,6495,"Ember promised"],[6516,6662,"that it'll be your child once born."],[6695,6812,"She won't take anything from you."],[6850,7170,"You'll still be my lawfully wedded wife."],[7200,7279,"Isn't a good thing?"],[7716,7770,"Mr. Shepherd."],[7820,7945,"We've moved Miss Ember's luggage"],[8000,8095,"into the master bedroom."],[8479,8558,"The master bedroom?"],[8716,8783,"What master bedroom?"],[8858,8991,"I didn't get a chance to tell you."],[9016,9125,"The master bedroom gets good sunlight,"],[9154,9195,"and it's quiet."],[9266,9370,"Perfect for Ember's pregnancy."],[9458,9566,"You take the guest room for now."],[9654,9837,"I only want you, Esther."],[9954,10033,"Channing,"],[10150,10329,"you let a mistress into our home"],[10333,10420,"to sleep in my bed."],[11200,11245,"Esther,"],[11308,11412,"after we get married,"],[11445,11595,"I'll move into the guest room with you."],[11637,11679,"Okay?"],[12000,12112,"Don't be angry,"],[12204,12329,"my bride."],[15741,15779,"Dad,"],[15879,16025,"I'm not marrying Channing."]],"4":[[70,100,"Dad,"],[133,279,"I'm not marrying Channing."],[358,437,"Have you lost your mind?"],[466,554,"We've taken the betrothal gifts."],[637,783,"You have more than one daughter."],[875,954,"Besides,"],[1008,1133,"Ember is already pregnant"],[1137,1254,"with Channing's child."],[1333,1587,"She's the perfect one to marry him."],[2325,2379,"Esther,"],[2429,2545,"there's a project"],[2562,2687,"that needs the Watsons' help."],[2716,2937,"Catherine suggested you marry Mr. Watson."],[2966,3058,"Jason Watson?"],[3108,3200,"That old man"],[3204,3316,"is even older than you."],[3437,3612,"Catherine sure knows how to plan my future."],[3750,3812,"That's not necessary."],[3895,4041,"I've decided to marry Carl Shepherd."],[4066,4112,"What?"],[4154,4216,"Carl Shepherd?"],[4275,4350,"That cripple?"],[4387,4645,"Esther has terrible taste."],[4666,4954,"Carl is infamous for his ruthlessness."],[4970,5045,"If she marries him,"],[5066,5258,"he might torture her to death."],[5291,5375,"But that's good."],[5400,5567,"The worse the man she marries,"],[5567,5662,"the happier I am."],[5729,5841,"Relax."],[5925,6137,"Although Carl is impotent,"],[6191,6400,"Esther is infertile."],[6437,6529,"So if she marries him,"],[6587,6700,"it's a perfect match."],[6812,6841,"Hey."],[6891,6941,"Esther,"],[6991,7220,"you can decide your own marriage."],[7266,7512,"We won't interfere. Alright?"],[8429,8500,"Channing Lewis,"],[8583,8833,"you think I can't live without you?"],[8904,9066,"I'll make you watch"],[9141,9395,"as I walk out of the quagmire you created."],[9487,9604,"You and Ember"],[9645,9862,"can tear each other apart in the mud."]],"5":[[783,883,"Hello, Mom."],[958,1104,"This can't go on."],[1150,1291,"My belly is getting too big to hide."],[1337,1491,"Channy thinks it's only been 7 months."],[1529,1641,"Don't panic."],[1679,1879,"I've already paved the way for you."],[1925,2075,"Once Esther leaves,"],[2220,2562,"the position of Mrs. Lewis will be yours."],[2708,2783,"You're right."],[2837,2983,"I wonder if Esther"],[2987,3133,"has lost her mind because of me."],[3175,3304,"She actually wants to marry"],[3304,3395,"that cripple, Carl."],[3425,3533,"The Shepherds would never"],[3537,3695,"take her seriously."],[3720,3908,"She's just a decoration"],[3937,4054,"for their crippled son."],[4083,4166,"Once she's over there,"],[4204,4487,"she'll suffer a fate worse than death."],[4545,4650,"I hope so."],[4795,4912,"But the priority right now"],[4958,5100,"is not letting the baby be born full-term."],[5145,5308,"Otherwise, I'll get found out."],[5375,5650,"Don't worry, I have a plan."],[6308,6354,"What?"],[6383,6475,"The eldest daughter"],[6529,6679,"of the Jenningses will marry Carl?"],[6895,7033,"Thank heavens."],[7083,7304,"I've been waiting for this day."],[7400,7525,"Quick! Get the car ready."],[7562,7704,"I'm going to see my daughter-in-law."],[7725,7775,"Wait."],[7866,7941,"She has a condition."],[8016,8266,"This must be kept secret for now."],[8329,8420,"It's enough that you know."],[8479,8554,"We must keep it simple."],[8600,8666,"Don't worry."],[8725,8941,"Do you think I don't know what's appropriate?"],[9416,9458,"Go."],[9512,9670,"Prepare the grandest betrothal gifts."],[9729,9912,"I want everyone in Riverton to see"],[9945,10191,"how the Shepherds are welcoming Mrs. Shepherd"],[10204,10316,"with such grandeur!"],[10379,10483,"Yes, ma'am."]],"6":[[12,187,"I want everyone in Riverton to see"],[237,466,"how the Shepherds welcome Mrs. Shepherd"],[487,600,"with such grandeur."],[654,758,"Yes, ma'am."],[3495,3570,"Betrothal gifts."],[3633,3845,"108 of Pearl of the Eastern Seas."],[3875,4016,"A pair of 100-year-old wild ginsengs."],[4045,4216,"A pair of Imperial Green jade bracelets."],[4245,4512,"A 10% stake in Riverton's Global Hub."],[4525,4662,"A ruby necklace."],[4691,4841,"A \"Spirit of the Ocean\" blue diamond set."],[4891,5025,"Carl"],[5062,5270,"actually takes this marriage so seriously."],[5416,5495,"Hello, Miss Jennings."],[5512,5583,"This is the handmade"],[5625,5766,"wedding dress Mr. Shepherd specially"],[5770,5862,"from Italy for you."],[5950,6125,"Though Mr. Shepherd couldn't come in person,"],[6166,6250,"the Shepherds wouldn't"],[6279,6379,"show the slightest disrespect."],[6425,6508,"Mr. Shepherd also instructed"],[6566,6662,"that if you don't like it,"],[6700,6775,"we get you a new one."],[6866,6929,"Okay."],[7350,7441,"Channy."],[7516,7633,"Is this the fleet Mom and Dad"],[7637,7795,"sent for my sister's dowry?"],[7937,8062,"Looks like she's come around."],[8137,8283,"I knew she couldn't bear to leave me."]],"7":[[208,258,"Esther."],[325,575,"Did you prepare these things?"],[658,733,"This wedding dress"],[770,875,"is really beautiful."],[904,1083,"Esther, you put your heart into this."],[1225,1354,"I really envy her."],[1400,1491,"Channy."],[1545,1629,"If I could wear"],[1633,1754,"a wedding dress for you even just once,"],[1812,1895,"I'd be so happy."],[2037,2116,"Of course you can."],[2308,2358,"Esther,"],[2412,2508,"why are you just standing there?"],[2566,2679,"Take off the dress now."],[2716,2787,"I wanna try it on."],[3166,3295,"Hands off my things."],[3583,3733,"Esther, I won't take it!"],[3762,3825,"I beg you,"],[3845,4004,"don't make Teddy hurt my baby!"],[4062,4200,"Ember barely touched it."],[4208,4308,"Don't overreact!"],[4312,4416,"Just let her try it,"],[4445,4550,"and this never happened."],[4608,4695,"It's my wedding dress"],[4766,4837,"and my wedding."],[4908,5012,"Why should I give it up for her?"],[5054,5220,"I know you take our wedding very seriously,"],[5295,5437,"but it's just a dress."],[5495,5583,"Let her try it on."],[5625,5750,"It's not like I won't marry you."],[6041,6108,"Dad."],[6200,6362,"Esther has already won awards."],[6404,6545,"So for this piano competition,"],[6583,6687,"just let me go instead."],[6758,6800,"Esther,"],[6862,6991,"your sister needs the experience."],[7025,7145,"It's just one competition slot."],[7191,7375,"You're the older sister. So let her go."],[7991,8083,"Mr. Jennings,"],[8112,8366,"Esther earned this spot on her own merit."],[8441,8545,"Why should she give it to her?"],[8600,8650,"Besides,"],[8741,8962,"she's the future Mrs. Lewis."],[9483,9570,"She doesn't need to"],[9629,9741,"compromise on anything."],[10108,10154,"Channing,"],[10262,10362,"you're defending her so much."],[10412,10512,"Is it because you want"],[10570,10700,"to have fun with both of us?"],[10729,10808,"Nonsense."],[10912,11054,"Ember will leave as soon as she gives birth."],[11112,11200,"Look at yourself."],[11220,11341,"Have no grace of the future Mrs. Lewis."],[11400,11495,"Mrs. Lewis?"],[12216,12420,"I don't want to be Mrs. Lewis anymore."]],"8":[[54,150,"I don't want to be Mrs. Lewis anymore."],[350,416,"What did you say?"],[495,550,"I said,"],[620,683,"I don't want it."],[2283,2370,"Hey, Channy!"],[2416,2575,"She is just throwing a tantrum."],[2608,2743,"She's always wanted everything for herself"],[2743,2779,"growing up."],[2850,2950,"Once she cools down,"],[2975,3091,"she'll come around."],[4750,4816,"Channy,"],[4858,5037,"do I look good in this wedding dress?"],[5070,5141,"Do I look like Esther?"],[5200,5245,"You do."],[5370,5491,"But it was custom-made"],[5495,5637,"for your sister's figure"],[5675,5795,"and temperament, after all."],[5816,5912,"So on you,"],[5916,6125,"the shoulders and waist don't fit right."],[6162,6245,"You should take it off."],[6291,6375,"Your sister"],[6433,6612,"will look good in it on our wedding day."],[7391,7487,"Oops!"],[7650,7704,"Esther,"],[7754,7820,"I'm sorry."],[7891,8004,"I was careless. I ripped it."],[8016,8175,"This dress is way too complicated."],[8241,8354,"I'll pay for it."],[8433,8487,"No need."],[8545,8612,"Unlike you,"],[8662,8829,"I don't like taking what others don't want."],[8870,8920,"Esther,"],[8962,9066,"Ember already apologized."],[9083,9195,"Stop being so snarky."],[10183,10233,"Hello?"],[10320,10437,"Contact Vera Wang immediately."],[10470,10612,"Tailor another brand-new wedding gown"],[10666,10833,"based on Mrs. Shepherd's figure and style."],[10862,11050,"Use only the best materials and design."],[11116,11200,"Price isn't an issue."],[11233,11345,"Make sure it arrives before the wedding."],[11775,11912,"Teddy, good boy."],[11966,12037,"Hold on a little longer."],[12079,12262,"I'm gonna take you away from here soon."],[12716,12787,"You're not welcome here."],[12837,12987,"You think I want to be here?"],[13041,13175,"I just came to remind you"],[13233,13345,"that Channy said"],[13366,13516,"to keep this dog locked up."],[13579,13804,"If it hurts the baby in my belly,"],[13879,13991,"your dog will be..."],[14245,14320,"Get away from him!"],[14462,14604,"It's just a dumb animal."],[14625,14779,"Don't treat it like a treasure."],[15233,15308,"Don't bite me!"],[15400,15462,"Help!"]],"9":[[29,104,"Help!"],[770,1000,"Esther, how could you set the dog on her!"],[1362,1470,"She fell on her own."],[1529,1645,"Teddy was locked in the pen."],[1687,1762,"He can't reach her."],[1829,1891,"If he didn't,"],[1937,2050,"then why was the dog barking?"],[2083,2133,"Esther,"],[2183,2362,"you're just making excuses now."],[2470,2537,"Channy,"],[2591,2700,"don't blame my sister."],[2766,2929,"I fell by accident."],[2954,3095,"And she's still defending you."],[3191,3237,"Esther,"],[3283,3412,"all you do is shirk responsibility."],[3462,3512,"Channing,"],[3558,3679,"when did you become blind?"],[3787,3920,"I only trust what I see."],[3966,4091,"If anything happens to Ember"],[4095,4208,"or the baby in her belly,"],[4229,4325,"you'll regret it."],[4366,4420,"Someone!"],[4495,4612,"This animal cannot stay."],[4662,4754,"Throw it out now!"],[4766,4820,"No!"],[4945,5000,"Channing,"],[5062,5187,"you brought Teddy home."],[5229,5350,"You said he was our first family member."],[5387,5483,"How can you throw him out now?"],[5612,5741,"He hurt her, so he's in the wrong."],[5991,6062,"Let go!"],[6233,6279,"Come on!"],[6283,6345,"Get away!"]],"10":[[116,262,"E-Esther."],[394,483,"Get out."],[720,833,"You idiot."],[900,987,"Esther,"],[1016,1179,"how many times do I have to tell you"],[1183,1333,"that Ember and her unborn child"],[1337,1520,"will never pose a threat to you."],[1537,1679,"If you still want to be Mrs. Lewis,"],[1683,1779,"stop making a scene."],[2062,2258,"I can't believe he let her off so easily."],[2270,2350,"No."],[2370,2520,"I need to add fuel to the fire."],[4137,4183,"Hello?"],[4187,4304,"Esther,"],[4320,4433,"Carl is getting ready"],[4437,4612,"to pick you up for the fitting."],[4641,4708,"Auntie."],[4712,4895,"I didn't want to draw attention,"],[4925,5187,"or I would've run over to see you myself!"],[5208,5516,"Carl might seem a bit cold,"],[5520,5616,"but when it comes to you,"],[5637,5775,"he's actually quite caring."],[5779,6020,"As soon as he heard your dress was ruined,"],[6045,6100,"oh my,"],[6116,6250,"he immediately sent someone"],[6254,6345,"to make the finest..."],[6504,6579,"It's me."],[6612,6708,"I'll be there in half an hour."],[6737,6795,"Be ready."],[6816,6966,"I don't like people being late."],[6970,7037,"Okay."],[7091,7166,"What is it?"],[7237,7437,"You sound as if I'm giving you a hard time."],[7529,7654,"Seriously?"],[7658,7750,"Mr. Shepherd has never"],[7754,7937,"spoken to anyone in that tone!"],[7995,8079,"No."],[8095,8250,"I just got a little emotional."],[8279,8466,"She clearly doesn't sound right."],[8512,8650,"The wedding will be in Ireland."],[8679,8800,"I'll send you the flight info later."],[9166,9325,"You know her so well, huh?"],[9329,9462,"You could even tell"],[9466,9591,"that her voice sounded off."],[9612,9779,"You're overthinking it. Let's go."],[9804,9870,"Yes, sir."],[10195,10350,"Don't worry, Teddy."],[10358,10458,"Before I leave,"],[10462,10620,"I'll make sure you're taken care of."],[10716,10787,"Leave?"],[10791,10870,"Where are you going?"]],"11":[[16,95,"Where are you going?"],[658,762,"Ireland?"],[1966,2020,"Channing,"],[2025,2216,"I wrote a piece of music for you."],[2250,2375,"When we go on our honeymoon,"],[2379,2512,"can we go to Ireland?"],[2537,2716,"I want to play it there, just for you."],[2737,2841,"Of course we can."],[2879,3025,"Wherever you want to go,"],[3029,3141,"that's where we'll go."],[3441,3537,"I get it."],[3620,3675,"You want me"],[3679,3816,"to take you to Ireland for our honeymoon."],[3845,4033,"But I'm busy taking care of Ember right now."],[4062,4187,"Cancel the tickets."],[4237,4304,"Okay."],[4483,4579,"What are you doing here?"],[4791,4929,"I watched the surveillance video."],[4941,5112,"It's true that Ember fell on her own."],[5137,5270,"But if you hadn't indulged him,"],[5300,5416,"Ember wouldn't have gotten scared."],[5483,5616,"But Ember said,"],[5633,5787,"for the sake of your sisterhood,"],[5791,5904,"she won't pursue this."],[5937,6016,"Really?"],[6066,6183,"Then I really must thank her"],[6187,6320,"for her generosity."],[6354,6500,"Ember's pregnancy is unstable."],[6512,6645,"Your dowry happens to have"],[6650,6787,"quite a few rare herbs."],[6791,6904,"Go brew some soothing tonic"],[6908,7012,"and apologize to her."],[7016,7137,"Then we'll consider this matter closed."],[7537,7662,"He's sick in the head."],[8462,8745,"Esther is truly a jinx!"],[8820,8962,"Just because she can't conceive,"],[8991,9112,"she can't stand seeing your baby."],[9179,9458,"If anything happens to my precious grandson,"],[9475,9595,"I'll make her pay!"],[9645,9812,"Mom, Dad,"],[9854,9991,"it's all my fault."],[10020,10370,"If I wasn't pregnant with Channy's child,"],[10408,10729,"she wouldn't hate me this much."],[11241,11304,"Ember,"],[11308,11408,"don't overthink it."],[11445,11575,"The most important thing right now"],[11579,11704,"is to focus on the baby."],[11729,11804,"Take the medicine."],[12320,12425,"This..."],[12429,12662,"tastes a bit off."],[13000,13079,"Channing!"],[13083,13254,"My stomach hurts so much!"],[13308,13383,"What's wrong?"]],"12":[[0,112,"What's wrong?"],[120,316,"Could it be poison?"],[320,429,"What?"],[775,866,"Esther!"],[1045,1116,"You were"],[1120,1329,"the only one in the kitchen."],[1354,1458,"Did you put something"],[1462,1554,"in the medicine?"],[1608,1691,"Esther,"],[1766,1962,"if you have a problem, take it out on me."],[1970,2191,"Why would you try to hurt my baby?"],[2216,2375,"The baby is innocent!"],[2408,2512,"Esther,"],[2550,2716,"I need an explanation!"],[2733,2833,"I didn't do it."],[2904,3041,"I've never even seen that stuff."],[3070,3233,"Don't you dare deny it!"],[3370,3533,"I brewed this medicine myself."],[3579,3800,"You were the only one who went to the kitchen."],[3820,3900,"Do you think"],[3904,4112,"I'd hurt my own grandson?"],[4116,4191,"Esther,"],[4195,4370,"I am so disappointed in you!"],[4391,4583,"It's one thing to be jealous,"],[4587,4723,"but to do something so vicious"],[4723,4795,"is unforgivable!"],[4800,4875,"Do you have proof?"],[4916,5029,"Show me the proof."],[5137,5212,"Enough!"],[5216,5308,"Esther,"],[5329,5512,"apologize to Ember right now."],[5541,5758,"I won't apologize for something I didn't do."],[5783,5850,"Channing,"],[5866,5937,"tell me,"],[5950,6062,"what did I do wrong?"],[6066,6245,"Was I wrong to trust you for ten years,"],[6287,6366,"or was I wrong to stand"],[6370,6512,"in the way of your family of three?"],[6541,6650,"Insolence!"],[6675,6795,"You've really gone too far!"],[6800,7000,"Guards, bring the rod!"],[7512,7658,"I must teach you a lesson today."],[7662,7829,"You unrepentant disgrace!"],[7875,7979,"Esther,"],[7983,8137,"hurry up and apologize!"],[8141,8304,"Maybe you can still avoid a beating."],[8341,8433,"No gonna happen!"],[8512,8683,"I won't apologize for your stupidity."],[9033,9145,"Hold her down!"],[9275,9445,"What are you doing? Let go!"],[9516,9616,"You stubborn fool!"],[9637,9762,"Today, on behalf of"],[9766,9912,"the ancestors of the Jenningses,"],[9916,10058,"I'm going to teach you a lesson!"]],"13":[[266,379,"Esther."],[383,462,"I told you,"],[466,645,"once I give birth to the baby,"],[650,779,"I'll leave this place."],[800,962,"Why did you still try to hurt me?"],[1045,1150,"Channing,"],[1220,1395,"we've known each other for ten years."],[1462,1604,"Is this really how you see me?"],[1637,1804,"She's been putting on an act."],[1850,2000,"I used to believe that too."],[2004,2141,"But people change."],[2175,2300,"You're the one who's changed."],[2379,2479,"Channing Lewis."],[2733,2870,"You still dare to argue?"],[2883,3016,"Esther, today,"],[3020,3191,"on behalf of my late sister,"],[3195,3345,"I'm going to teach you a lesson,"],[3350,3525,"you lying b**ch!"],[3762,3975,"In this lifetime,"],[3987,4141,"I only want you, Esther."],[4450,4587,"She doesn't need to"],[4591,4729,"compromise on anything."],[4737,4916,"She's the future Mrs. Lewis."],[4933,5075,"Wherever my wife wants to go,"],[5079,5191,"that's where we'll go."],[5333,5420,"Esther,"],[5437,5566,"just admit you're wrong."],[5587,5700,"Don't be so stubborn."],[6108,6183,"Esther,"],[6187,6312,"just apologize,"],[6341,6504,"and let's end this!"],[6512,6633,"I won't!"],[6654,6750,"Zander Jennings."],[6770,7016,"You sanctimonious hypocrite."],[7066,7275,"You cheated on my mother"],[7300,7470,"and stole all her shares!"],[7520,7666,"Now you're letting a homewrecker's daughter"],[7670,7895,"torment your own biological daughter."],[7900,8037,"You don't deserve to be a father!"],[8104,8241,"You still dare to talk back?"],[8283,8362,"Today,"],[8366,8516,"you're no longer my daughter!"],[9798,9850,"Who is there?"],[11466,11616,"Mrs. Shepherd"],[11625,11787,"isn't someone you can mess with."]],"14":[[58,112,"Who is there?"],[881,945,"Miss Jennings,"],[962,1070,"we're here to take you home."],[1245,1341,"Home?"],[1345,1504,"Besides the Jenningses' and the Lewises',"],[1508,1654,"where else can she call home?"],[1658,1762,"Exactly."],[1808,1933,"Who are you people?"],[1945,2120,"It's our family matter."],[2125,2233,"It's none of your business!"],[2662,2695,"Mom!"],[2700,2979,"My arm!"],[2979,3112,"We work for Miss Jennings, of course."],[3175,3254,"You're abusing your own kin."],[3270,3391,"If word of this gets out,"],[3395,3491,"I wonder what will happen"],[3491,3579,"to Lewis Group's stock."],[3583,3704,"And as for the Jennings Group's projects,"],[3708,3883,"who knows if you'll keep them."],[3887,4058,"Quit playing tricks."],[4062,4262,"Do you really think I get scared that easily?"],[4300,4379,"Guards!"],[4412,4516,"Seize them!"],[4533,4666,"Mr. Jennings, bad news!"],[4670,4783,"Mr. Watson just announced that he's"],[4787,4879,"terminating all cooperation."],[4883,5045,"Our funding is about to be cut off!"],[5050,5120,"What?"],[5158,5287,"How is that possible?"],[5300,5404,"Is there a mistake?"],[5408,5487,"It's true!"],[5491,5566,"They said"],[5570,5650,"that we offended"],[5654,5754,"someone we shouldn't have."],[5762,5862,"Could it be..."],[5929,6083,"No, impossible."],[6087,6241,"How could the Shepherds possibly go to"],[6245,6325,"such lengths for her?"],[6329,6466,"It must be a coincidence."],[6487,6570,"What's with the panic?"],[6587,6750,"It's just a minor hiccup."],[6754,6816,"The Jenningses"],[6820,6958,"have weathered much bigger storms than this."],[6962,7162,"Go find out exactly what's going on."],[7187,7262,"Yes, sir."],[7550,7625,"Stop right there."],[7808,7945,"Did I say you could take my fiancée away?"]],"15":[[70,212,"Did I say you could take my fiancée away?"],[504,654,"When I was getting beaten,"],[691,850,"why didn't you call me your fiancée?"],[1016,1083,"Channing,"],[1104,1225,"can't you see?"],[1241,1379,"She hired these people on purpose"],[1383,1516,"to put on this show"],[1525,1641,"to force you to give in!"],[1875,1966,"Esther,"],[2045,2250,"this is all my fault."],[2287,2375,"I'm begging you,"],[2437,2633,"stop using these childish tricks"],[2679,2829,"to keep pressuring Channy."],[3350,3429,"Ember!"],[3495,3729,"My belly hurts so much."],[3750,3854,"Oh no, she..."],[3883,4029,"She's going into labor!"],[4054,4100,"Channing,"],[4104,4295,"hurry, get her to the hospital!"],[4300,4420,"Don't waste time!"],[4837,4937,"Esther,"],[4941,5075,"I know you're upset,"],[5095,5283,"but staging this drama right now"],[5287,5408,"is going way too far."],[5433,5550,"Lives are at stake."],[5587,5750,"I have to take Ember to the hospital first."],[6854,7012,"I knew it."],[7016,7162,"It's always like this."],[8441,8562,"You are..."],[8616,8725,"Carl."]],"16":[[1016,1120,"Mom,, don't leave."],[1212,1329,"Mom, don't go."],[1408,1466,"Mom"],[1658,1716,"We're done for."],[1762,1941,"Mr. Shepherd hates women touching him."],[2558,2633,"I won't leave."],[3812,3866,"Sorry."],[3904,3970,"When you stopped my car,"],[3975,4087,"you were all tooth and claw,"],[4133,4304,"vowing to make the Lus and Jenningses"],[4308,4404,"pay the price."],[4512,4566,"Where did that fire go?"],[4941,5191,"I need time to plan."],[5233,5304,"Plan?"],[5375,5479,"Your \"plan\""],[5504,5637,"is just delivering yourself"],[5654,5745,"to be whipped?"],[6475,6637,"Since you chose the Shepherds,"],[6662,6854,"you must learn to use my name"],[6904,7041,"as a shield,"],[7216,7379,"instead of meaningless bravado."],[7483,7629,"Isn't this the butterfly knife"],[7633,7766,"he's carried for years?"],[7879,8045,"This is too valuable."],[8579,8712,"I never take back"],[8766,8904,"what I've given away."],[8937,9000,"From now on,"],[9016,9166,"if anyone dares to bully you,"],[9220,9316,"use it."],[9366,9475,"Return the pain"],[9479,9591,"they inflicted on you"],[9629,9708,"hundreds,"],[9737,9858,"even thousands of times over."],[9966,10029,"Do you understand?"],[10116,10270,"Everyone calls him the Devil,"],[10341,10470,"but he is the only one"],[10475,10616,"willing to stand by my side."],[10829,10908,"I understand."],[10987,11062,"Thank you."],[11462,11516,"No need."],[11545,11720,"Since you carry the title of Mrs. Shepherd,"],[11808,11866,"if your face gets ruined,"],[11962,12050,"it's my reputation that suffers."],[13158,13220,"By the way,"],[13254,13295,"I"],[13316,13525,"right before I passed out, it looked like"],[13562,13745,"your legs were moving."],[14162,14187,"You"],[14237,14312,"You were seeing things."],[14445,14491,"Oh."],[14575,14779,"So, it must have been a hallucination?"],[14808,14875,"Makes sense."],[14908,15037,"If you could actually stand,"],[15041,15241,"who'd want to be stuck in a wheelchair all day?"],[15283,15500,"Mr. Lewis treats Miss Jennings so well."],[15525,15745,"He waited outside her ward all night."],[15754,15812,"Yeah,"],[15837,15954,"it's the first time I've seen Mr. Lewis"],[15958,16083,"so anxious and out of control."],[16104,16245,"It must be true love."],[16366,16495,"What a \"true love.\""],[16575,16666,"If you want to leave,"],[16725,16862,"I can take you away right now."],[16883,17062,"Let me finish one last thing."],[17145,17220,"Once it's done,"],[17420,17504,"I'll go with you."],[17629,17762,"You did well, Ember."],[17854,17962,"It was the least I could do."],[18083,18154,"Mr. Lewis,"],[18170,18345,"the checkup is done. The baby is healthy."],[19091,19366,"Why doesn't this child look like me?"]],"17":[[212,341,"Well, Channy,"],[358,541,"the baby was just born."],[570,708,"How can you tell anything yet?"],[800,900,"Yes, Channing."],[916,983,"You"],[987,1150,"it's your first time being a dad."],[1158,1262,"You're too nervous."],[1312,1462,"As long as mother and child are safe,"],[1475,1583,"that matters more than anything."],[1695,1787,"You're right, Auntie."],[2020,2066,"Mr. Lewis,"],[2087,2237,"the discharge paperwork is done."],[2279,2316,"Mm."],[2554,2662,"Well, Ember,"],[2708,2791,"let's go home."],[3333,3491,"Mom, are you sure this medicine"],[3520,3645,"will make the baby in my belly"],[3679,3770,"be born early?"],[3866,3929,"Of course."],[3966,4075,"I did the same thing back then"],[4187,4320,"Anyway, don't worry."],[4370,4504,"Nothing will go wrong."],[4583,4662,"It's just"],[4704,4825,"it might hurt a little."],[4937,5154,"Ember, you must hold on."],[5179,5254,"I'm not afraid."],[5316,5429,"As long as I can make Esther,"],[5433,5575,"that b**ch, miserable,"],[5604,5762,"this pain is nothing."],[6345,6420,"Channing,"],[6466,6654,"is this the person you'd die to protect?"],[7008,7100,"Esther,"],[7616,7791,"can you really bear to leave"],[7812,7904,"Channy?"],[8033,8145,"I was willing to,"],[8170,8308,"but seeing you scheming so hard"],[8312,8412,"to push me out,"],[8475,8595,"I suddenly feel that"],[8600,8737,"the position of Mrs. Lewis"],[8812,8916,"is quite comfortable."],[9125,9191,"Otherwise,"],[9262,9333,"I'm not leaving."],[9400,9425,"You"]],"18":[[87,166,"What do you mean?"],[620,737,"Sign this agreement,"],[779,887,"and give me back the Jennings Group shares"],[891,1016,"that my mother held."],[1183,1258,"You're crazy."],[1283,1387,"Why should I give them to you?"],[1595,1729,"If you want to step over me to get to the top,"],[1770,1891,"you have to pay the price."],[1950,2129,"Using these shares to buy peace of mind"],[2200,2279,"is a bargain."],[2366,2458,"Are you threatening me?"],[2533,2654,"What if I don't sign?"],[3329,3508,"If you don't want to lose everything,"],[3654,3787,"you're welcome to try."],[3983,4037,"Fine, I'll sign!"],[4083,4204,"Anyway, after tonight,"],[4208,4320,"I'll be Mrs. Lewis."],[4354,4516,"What do these shares matter to me?"],[4737,4912,"I'll just treat it as paying for peace."],[5825,5937,"Esther,"],[5958,6058,"let me tell you,"],[6087,6233,"between you and me,"],[6250,6400,"I will always be the winner."],[6425,6554,"But you're not doing too badly."],[6620,6737,"That Mr. Shepherd of the Shepherds,"],[6741,6879,"although he is a cripple,"],[6916,6987,"but to be with a hen like you"],[6991,7112,"that can't lay eggs,"],[7150,7262,"he is more than enough."],[7429,7545,"At least unlike you,"],[7608,7787,"I don't pick up the trash others threw away."],[7800,7841,"You—"],[7870,8016,"Enjoy your wedding of the century."],[8058,8170,"Just don't give yourself away."],[8287,8362,"Esther,"],[8462,8591,"you'd better keep your word."],[8612,8833,"Don't you dare regret it later."],[8850,8933,"I promise."],[8995,9062,"I'll make sure"],[9066,9208,"you marry him in grand style."],[9487,9704,"And right when you think you've won,"],[9758,9941,"I'll rip off your mask with my own hands,"],[9987,10125,"and leave you with nothing."]],"19":[[29,100,"Esther."],[291,354,"What did you say?"],[537,633,"Who is Ember going to marry?"],[804,891,"Channy."],[912,995,"Esther is just apologizing"],[1000,1112,"for what happened yesterday."],[1154,1216,"She said"],[1250,1387,"she's accepted our baby."],[1550,1591,"Esther,"],[1616,1775,"I knew you'd understand."],[1804,1837,"By the way,"],[1866,1954,"Ember accidentally"],[1958,2083,"ruined that wedding dress,"],[2095,2137,"so I've had someone"],[2141,2262,"custom-make the latest style for you."],[3345,3404,"Esther,"],[3483,3658,"tomorrow you will definitely be"],[3662,3804,"the most beautiful bride in the world."],[3991,4070,"It truly is beautiful."],[4083,4191,"To thank you,"],[4237,4420,"I've also prepared a surprise for you."],[4454,4504,"Really?"],[4554,4620,"What is it?"],[4712,4870,"You'll find out at the wedding tomorrow."],[5008,5112,"It's been a long day."],[5254,5354,"You should go back and rest."],[5558,5662,"Yeah, Channy,"],[5720,5808,"you should get some rest."],[5812,5958,"Tomorrow will be exhausting."],[6025,6075,"True."],[6141,6233,"Esther is right."],[6300,6362,"See you tomorrow."],[7541,7695,"Make sure that when the ceremony starts,"],[7704,7829,"you hand this directly to Channing."],[7845,7937,"Yes, Miss Jennings."],[8216,8329,"Also, this is what Mr. Lewis's assistant"],[8333,8425,"asked me to bring. It's the pre-marital"],[8429,8654,"checkup report for you and Mr. Lewis."],[8779,8870,"I once thought this was"],[8875,9012,"the ticket to happiness."],[9033,9283,"It seems none of this concerns me anymore."],[11054,11129,"Goodbye,"],[11183,11258,"Channing."],[11350,11441,"My ten years"],[11495,11595,"end here."],[13170,13287,"You must be Esther."],[13475,13583,"I'm Carl's mother."],[13600,13745,"I'm here to take you home."]],"20":[[16,104,"Madam Shepherd,"],[145,241,"thank you."],[400,520,"That Mr. Shepherd from the Shepherds,"],[525,650,"even though he is a cripple,"],[695,887,"is still too good for a hen like you"],[929,1037,"that can't lay eggs."],[1183,1241,"Madam Shepherd,"],[1258,1516,"there is something I must tell you."],[1650,1704,"Go ahead."],[1850,1983,"Because of an old injury,"],[2016,2116,"I may never be able to"],[2120,2245,"have children of my own."],[2308,2441,"Do you mind?"],[2458,2537,"What?"],[2583,2662,"I knew it."],[2695,2808,"She won't accept a woman"],[2812,2929,"who can't bear children"],[2933,3054,"as her daughter-in-law."],[3541,3654,"My silly child,"],[3687,3787,"what are you thinking?"],[3845,3916,"You"],[3954,4041,"You don't mind?"],[4112,4204,"To me,"],[4250,4462,"you are, first and foremost, yourself."],[4483,4583,"What the Shepherds want"],[4612,4758,"has always been a complete"],[4766,4837,"and happy you,"],[4858,4995,"not a baby-making machine."],[5033,5245,"So this is what real respect feels like."],[5300,5487,"Compared to the little Channing gave me,"],[5550,5695,"it is a world of difference."],[5829,5904,"Silly child,"],[5966,6104,"from now on, cry if you want to cry,"],[6195,6287,"laugh if you want to laugh."],[6329,6525,"You don't need to hold back with Mom."],[6783,6845,"Okay."],[6920,7000,"Thank you, Mom."],[7066,7133,"Let's go home."],[7166,7200,"Yeah."],[7591,7662,"This time"],[7716,7858,"It really is goodbye."],[8729,8858,"The day has finally come."],[8900,8958,"Esther,"],[8991,9087,"today, I'll put this ring"],[9091,9233,"on your finger myself,"],[9283,9404,"so everyone knows"],[9450,9558,"that you are Channing's"],[9570,9675,"one and only bride."],[9962,10141,"Why do I feel so uneasy?"],[12333,12375,"Esther?"],[12400,12445,"How is this possible?"]],"21":[[554,604,"Mr. Lewis,"],[616,758,"can't wait to see your bride?"],[766,820,"Don't worry."],[841,987,"Miss Jennings is ready at the hall,"],[991,1104,"just waiting for her groom."],[1129,1175,"Yeah."],[1216,1320,"Of course she's waiting for me."],[1366,1416,"Drive faster."],[1454,1579,"Don't keep my bride waiting."],[1591,1625,"Yes, sir."],[1900,1954,"My dear,"],[2020,2104,"you have to look forward."],[2145,2212,"The good days"],[2241,2325,"are yet to come."],[2595,2664,"Let's go home."],[2700,2786,"Okay."],[3629,3754,"Mr. Lewis's love for Esther"],[3758,3895,"truly runs deep."],[3916,4045,"This wedding"],[4058,4212,"could practically be called"],[4216,4325,"the wedding of the century."],[4358,4520,"The betrothal gifts alone are priceless."],[4529,4725,"Such devotion is truly rare."],[5145,5304,"Channing, aren't you nervous?"],[5329,5450,"After waiting so long,"],[5479,5562,"you're finally marrying"],[5566,5700,"the most beautiful woman in the capital."],[5729,5783,"It sure is."],[5816,5929,"A wedding of the century."],[5970,6083,"Esther must have"],[6108,6150,"spent a long time"],[6170,6304,"preparing for this day."],[6491,6625,"She really put a lot of effort"],[6662,6825,"into this wedding."],[7004,7112,"To thank you,"],[7158,7341,"I've also prepared a surprise for you."],[7537,7612,"I'm looking forward to it."],[7816,7962,"Distinguished guests,"],[7979,8062,"friends,"],[8120,8175,"today,"],[8208,8333,"We are gathered here today"],[8354,8504,"to witness the union"],[8508,8691,"between the Lewises and the Jenningses"],[8704,8879,"as they join in holy matrimony."],[8895,9120,"Now, please welcome the groom"],[9166,9225,"as he makes his entrance."],[9529,9591,"And now,"],[9625,9854,"with your warmest applause,"],[9870,10100,"please welcome the beautiful bride"],[10141,10216,"as she walks down the aisle."],[10820,10912,"She's so beautiful."],[11645,11695,"Esther,"],[11741,11841,"from this day forward,"],[11908,11995,"I will never let you"],[12000,12125,"suffer even the slightest grievance."],[12700,12800,"Mr. Channing Lewis,"],[12820,12925,"do you take this woman"],[12929,13158,"standing before you to be your wife,"],[13179,13362,"for better or for worse?"],[13387,13441,"I do."],[13479,13541,"And you, the bride,"],[13600,13725,"do you take this man?"],[13754,13829,"I do."],[15708,15854,"Now, the groom"],[15875,16075,"may kiss the bride."],[18325,18379,"What?"],[18416,18504,"Why is it you?"],[18691,18762,"Where's Esther?"]],"22":[[1054,1154,"Why is it you?"],[1212,1295,"Where's Esther?"],[1429,1504,"What?"],[1533,1691,"Why is there a different bride?"],[1695,1791,"Wasn't it supposed to be"],[1795,1895,"Miss Jennings?"],[1916,2012,"How did it become"],[2016,2116,"Miss Ember?"],[2466,2600,"Channy"],[2633,2716,"It's"],[2745,2916,"Esther forced me into this."],[2958,3050,"She said"],[3083,3225,"she didn't want to marry you."],[3637,3750,"Impossible."],[3887,3962,"Where's Esther?"],[3987,4112,"Where is she?"],[4337,4416,"Channing,"],[4454,4687,"do you want to embarrass Ember here?"],[4716,4825,"Everyone is watching."],[4975,5066,"Yes, Channing."],[5162,5254,"Esther"],[5258,5408,"ran off irresponsibly."],[5425,5591,"You should cherish the one in front of you."],[5620,5708,"Besides,"],[5716,5808,"Ember"],[5820,6025,"is the mother of your child."],[6041,6270,"So it was Miss Ember."],[6275,6408,"She really delivered."],[6412,6533,"She gave the Lewises"],[6537,6704,"a son long ago."],[6708,6883,"Poor Miss Jennings."],[6887,7012,"After ten years together,"],[7016,7141,"she was betrayed by her sister"],[7145,7325,"and her fiancé."],[7329,7395,"The Lewises"],[7400,7570,"are acting so shamefully."],[7587,7675,"Miss Jennings"],[7679,7791,"saved Mr. Lewis back then,"],[7804,7941,"and almost lost her life."],[7962,8050,"Is that true?"],[8054,8112,"And now,"],[8116,8250,"she's ended up like this."],[8262,8325,"Oh, dear."],[8558,8658,"Mr. Channing Lewis?"],[8666,8779,"I have an urgent delivery for you."],[8804,8904,"Miss Jennings instructed"],[8908,9070,"that I deliver this to you personally"],[9075,9183,"before the ceremony begins."],[9520,9616,"It's from Esther."],[10783,10858,"Bro,"],[10862,11041,"Esther must have left this."],[11066,11191,"Maybe it contains"],[11195,11329,"something she wants you to know."],[11466,11562,"Channy,"],[11600,11670,"but"],[11675,11879,"what if this is just a prank"],[11908,12054,"meant to sabotage us?"],[12095,12208,"Today"],[12212,12404,"is our big day, after all."],[12441,12541,"Yes, Channing."],[12566,12675,"Whatever it is,"],[12679,12779,"can't we go home"],[12783,12904,"and discuss it behind closed doors?"],[12929,13050,"Must we do it here"],[13054,13170,"and let everyone laugh at us?"],[13250,13325,"Ember,"],[13345,13429,"Miss Cole,"],[13450,13558,"why are you two so panicked?"],[13575,13720,"We'll know if it's a prank"],[13725,13829,"as soon as we see it."],[14133,14225,"Someone."],[14229,14412,"Play this on the screen."],[14416,14466,"Right now."]],"23":[[145,237,"Someone!"],[241,425,"Put this on the screen."],[429,508,"Right now."],[1333,1495,"What's going on?"],[1508,1608,"Is there a new scandal?"],[3443,3523,"Oh"],[3523,3607,"This"]],"24":[[795,891,"What's going on?"],[895,979,"Who did this?"],[1100,1183,"I'm sorry, Mr. Lewis."],[1191,1279,"The computer crashed."],[1283,1404,"We're restarting it."],[2070,2150,"Well,"],[2154,2225,"Channing,"],[2270,2387,"since things have come to this,"],[2416,2550,"we won't hide it from you anymore."],[2604,2754,"Deep down, the one Esther"],[2758,2925,"has actually always wanted to marry"],[2966,3112,"is Carl."],[3204,3266,"She said"],[3270,3420,"that even though Carl"],[3425,3525,"has trouble walking,"],[3529,3679,"what the Shepherds can offer her"],[3779,3883,"is something you can't."],[4908,5087,"This is the Shepherds' betrothal gift list,"],[5091,5216,"signed by Esther herself."],[5758,6004,"It really is her handwriting."],[7437,7550,"Good."],[7633,7716,"Very good."],[7770,8045,"Just for the Shepherds' status and wealth,"],[8120,8312,"you'd actually stoop this low."]],"25":[[87,133,"Brother,"],[175,341,"Esther isn't that kind of person."],[541,683,"She kept you in the dark"],[745,875,"and had Ember take her place,"],[1004,1112,"yet you still defend her?"],[1183,1266,"I"],[1308,1529,"I really didn't know about this."],[1820,1895,"But she"],[1950,2062,"knew the truth all along."],[2083,2258,"Why didn't she tell us sooner?"],[2625,2733,"Channy,"],[2791,2933,"my sister has always been bossy."],[3000,3154,"She wouldn't let me say anything."],[3225,3337,"I had no choice."],[3454,3537,"I admit,"],[3591,3754,"I had selfish motives regarding you."],[3845,3908,"So,"],[4000,4158,"I don't dare ask for your forgiveness."],[4229,4308,"As long as you"],[4358,4475,"As long as you let me and the baby"],[4479,4608,"have a place to stay,"],[4720,4912,"I'll be content."],[5533,5612,"Fine."],[5695,5795,"The wedding is done,"],[5908,6004,"and the whole city knows about it."],[6120,6229,"You"],[6329,6516,"can stay at Esther Manor for now."],[7154,7308,"Bobby is an outsider's seed after all."],[7366,7558,"I must carry a true Lewis heir soon"],[7591,7733,"to eliminate any future threats."]],"26":[[95,250,"After all, Bobby is an outsider's child."],[312,500,"I need to carry a true Lewis heir soon,"],[533,675,"to eliminate any future threats."],[1229,1350,"Channy?"],[1362,1466,"You're back."],[1832,1933,"Esther."],[2020,2162,"Esther, you're back... Esther."],[2275,2358,"Channy,"],[2383,2504,"you've got the wrong person."],[2529,2641,"I'm Ember."],[2712,2804,"Not Esther."],[3300,3391,"Ember?"],[4008,4104,"Channing."],[4587,4662,"Esther."],[4716,4791,"Esther"],[5112,5250,"You're not Esther."],[5412,5558,"Esther wouldn't act like this."],[5854,5929,"Esther."],[6004,6162,"Esther."],[6229,6341,"Esther."]],"27":[[620,900,"Welcome home, Mrs. Shepherd."],[962,1041,"Esther,"],[1045,1258,"this is your home now."],[1262,1366,"Make yourself at home."],[1475,1566,"Thank you, Mom."],[1666,1820,"No need to thank me."],[1937,2033,"Seeing Carl"],[2037,2137,"with someone"],[2141,2287,"so caring by his side,"],[2304,2404,"I can finally rest easy."],[2529,2687,"I'm not drinking it. Take it away."],[2908,3004,"Ever since"],[3008,3175,"that incident,"],[3200,3345,"Carl has been like this."],[3400,3512,"He refuses to take his medicine"],[3550,3704,"or do his physical therapy."],[3712,3808,"And his temper"],[3812,3991,"has become increasingly erratic."],[4045,4208,"Don't worry, Mom."],[4220,4295,"I'll handle it."],[4533,4608,"But"],[4683,4762,"Mrs. Shepherd,"],[4787,4991,"Mr. Shepherd doesn't like people getting close."],[4995,5125,"You have to be careful."],[5609,5725,"I've got this."],[6254,6354,"Carl,"],[6391,6470,"it's time for your medicine."],[6591,6695,"What is the meaning of this?"],[6754,6908,"This isn't in our contract."],[7150,7354,"I agreed to act like a loving couple,"],[7408,7562,"but if a husband refuses treatment"],[7566,7729,"and his wife ignores it,"],[7758,7841,"would that look convincing?"],[8291,8420,"Falling for me already?"]],"28":[[16,145,"Falling for me already?"],[579,675,"Not exactly."],[783,858,"You've helped me,"],[900,983,"and you're a good man."],[1087,1241,"I truly want to see you walk again."],[1754,1895,"This is just a business deal."],[1945,2058,"I won't fall in love with you."],[2137,2287,"So don't get your hopes up."],[2379,2479,"Don't worry."],[2537,2675,"I know better than you"],[2679,2808,"why we got married."],[3204,3308,"However,"],[3312,3508,"if you refuse to take this,"],[3820,4050,"I don't mind using a more intimate method"],[4108,4312,"to fulfill my duties as your wife."],[4616,4712,"Mrs. Shepherd,"],[4716,4912,"how dare she get so close?"],[5000,5162,"Isn't she afraid Mr. Shepherd will lose it?"],[5191,5266,"Shh!"],[5316,5404,"Keep it down."],[5425,5533,"What if"],[5545,5666,"that's exactly what he likes?"],[5841,5979,"What a hassle."],[7016,7270,"Mr. Shepherd actually drank it."],[7308,7416,"Taking medicine when he's not sick"],[7420,7487,"that"],[7491,7662,"won't that be dangerous?"]],"29":[[104,195,"Wonderful!"],[212,291,"Carl"],[295,441,"has finally agreed to take his medicine."],[508,583,"Oh,"],[691,783,"Esther,"],[787,916,"you're amazing."],[920,1000,"Hahaha."],[1091,1258,"If only he'd been this obedient sooner."],[1262,1408,"It would've saved Esther"],[1412,1487,"the trouble of dealing with you."],[1612,1683,"Esther,"],[1687,1770,"come with me,"],[1775,1858,"let me show you"],[1862,1987,"the room you share with Carl."],[2033,2087,"Let's go."],[2566,2687,"Why didn't you stop her just now?"],[2783,2812,"Uh,"],[2950,3104,"I assumed that with your temper,"],[3108,3262,"you wouldn't let Mrs. Shepherd get close."],[3312,3404,"I didn't expect"],[3408,3529,"that you wouldn't resist at all."],[3558,3645,"By the way, Mr. Shepherd,"],[3666,3866,"what did Mrs. Shepherd say to you?"],[4158,4304,"She said I'm a good person."],[4383,4545,"What do you suppose that means?"],[4629,4741,"\"A good person\"?"],[4854,4966,"Oh, Mr. Shepherd,"],[5000,5179,"that's typically known as"],[5183,5287,"getting the \"Nice Guy\" card."],[5300,5458,"It's what people say when they want"],[5462,5562,"to distance themselves"],[5566,5737,"and draw a clear line."]],"30":[[1870,2008,"Esther,"],[2012,2187,"you finally answered my call."],[2258,2408,"Tell me,"],[2412,2558,"why did you call off the wedding?"],[2587,2662,"How am I inferior to"],[2666,2787,"that cripple Shepherd?"],[2958,3079,"Mr. Lewis,"],[3083,3304,"leaving your bride alone on your wedding night"],[3350,3470,"don't you love her?"],[3558,3708,"We were just about to take a shower."],[3745,3900,"The night is short, and"],[3933,4104,"I really don't have time"],[4141,4316,"to listen to you reminisce."],[4383,4458,"Have some self-respect."],[4516,4637,"What shower?"],[4716,4850,"Explain yourself!"],[5387,5470,"How dare a cripple"],[5475,5616,"talk to me like that?"],[5737,5837,"Esther,"],[5966,6150,"ten years of love,"],[6229,6445,"and you just walked away?"],[7083,7295,"Is the reason she wants to distance herself from me"],[7366,7541,"because she still has him in her heart?"]],"31":[[1320,1441,"Pressing this acupoint"],[1445,1583,"helps clear the meridians."],[1612,1825,"Did you learn it, baby?"],[2283,2462,"How many men do you think about in a day?"],[2554,2629,"Esther,"],[2995,3195,"remember your status as Mrs. Shepherd."],[3375,3504,"With my status,"],[3508,3729,"isn't it only natural to watch this?"],[3933,4012,"Fine."],[4050,4129,"Very good."],[4175,4250,"Then let's do something"],[4254,4412,"even more natural."],[4858,4950,"Help me shower."],[4954,5016,"Ah."]],"32":[[108,200,"Help me shower."],[258,320,"Huh?"],[441,550,"But that's not in the agreement."],[554,612,"What?"],[733,808,"Scared?"],[904,1012,"Why would I be scared?"],[1050,1162,"You can't move anyway,"],[1166,1283,"so you can't do anything to me."],[1400,1470,"Just you wait."],[1475,1608,"I'll serve you right now."],[3770,3950,"You were staring so hard just now."],[4058,4166,"Why are you blushing now?"],[4170,4383,"I'm not blushing."],[4479,4566,"I don't care how developed"],[4570,4783,"your pecs, abs, and calves are."],[4829,4987,"To me,"],[4991,5116,"you're just a piece of meat."],[5183,5329,"Others call me a feast for the eyes,"],[5350,5508,"yet I'm just a piece of meat?"],[6666,7004,"Why does the atmosphere feel so weird?"],[8429,8508,"You"],[8537,8583,"Aren't you"],[8587,8691,"Who told you"],[8762,8910,"I couldn't move at all?"]],"33":[[0,112,"Who told you"],[187,291,"I couldn't move at all?"],[491,562,"Carl,"],[566,637,"Esther,"],[641,729,"is everything all right?"],[758,841,"Mom."],[845,1045,"We're fine. Just fooling around."],[1666,1770,"It must be a hallucination."],[1775,1941,"He's supposed to be paralyzed from the waist down."],[1991,2066,"Right,"],[2070,2162,"it must be my imagination."],[2387,2491,"Coward."],[2945,3104,"Regretting it now?"],[3175,3258,"Serves you right."],[3508,3583,"Ember."],[3645,3754,"What did you say?"],[3975,4083,"Channy,"],[4120,4241,"I said,"],[4245,4433,"Esther is truly so heartless."],[4491,4629,"Seeing you like this"],[4666,4791,"really breaks my heart."],[4916,5041,"Don't mention her to me."],[5300,5400,"Channy,"],[5445,5662,"since Esther left so ruthlessly,"],[5687,5854,"you should let everyone know"],[5875,6020,"that you don't care about her at all."],[6266,6345,"Right."],[6475,6583,"You're right."],[6695,6862,"I should let her know"],[6954,7070,"that without her,"],[7120,7237,"I, Channing, can still"],[7241,7350,"live a glorious life."],[7466,7633,"I'll make her regret it."],[7779,7866,"Channy,"],[7875,7941,"in a few days,"],[7945,8054,"it's the homecoming banquet."],[8075,8187,"Esther will definitely be there."],[8208,8358,"It's the perfect opportunity."],[8391,8466,"At the banquet,"],[8470,8575,"you just let her know."],[8604,8695,"Leaving you"],[8700,8891,"was such a terrible mistake."],[9820,9920,"And I"],[9975,10137,"will always stand by you."]],"34":[[137,320,"Just so you know,"],[362,483,"I'm a pretty restless sleeper."],[616,716,"You're just a girl."],[791,900,"How bad could it be?"],[2475,2591,"Why are you so far away?"],[3045,3229,"Come closer. We don't want to raise suspicion."],[4862,5054,"You call this \"restless\"?"],[5316,5541,"Mom... Mom"],[5545,5662,"Don't go."],[5783,5908,"Zander!"],[5912,6116,"Do you choose us, or do you choose them?"],[6187,6375,"Enough! You're being unreasonable."],[6412,6579,"If you can't accept your sister,"],[6583,6670,"then this home,"],[6675,6800,"there's no point in me coming back."],[6991,7015,"Hmph!"],[7015,7061,"Let's go."],[7087,7612,"- Esther, Esther... - Mom... Mom, I want my mom"],[7616,7870,"Please, Zander"],[7875,8152,"- Mom, I want my mom... - Esther."],[8152,8320,"Mom... I want my mom"],[8320,8450,"Esther."],[8454,8676,"Mom... I want my mom"],[8676,8875,"- Mom, I want my mom... - Esther."],[8875,9012,"I want my mom."],[9050,9245,"Mom"],[9425,9529,"You're having a nightmare."],[9608,9758,"It's okay. I'm here."],[10154,10320,"To think the Devil"],[10325,10558,"actually has such a gentle side."],[11054,11170,"Carl,"],[11295,11462,"is this also in the agreement,"],[11537,11712,"one of your required duties?"]],"35":[[391,512,"Carl,"],[633,800,"is this also in the agreement,"],[875,1050,"one of your required duties?"],[1166,1254,"You talk too much."],[1358,1395,"Shut up."],[1454,1512,"Go to sleep."],[2083,2166,"Carl,"],[2225,2366,"you've helped me so much,"],[2462,2616,"so I want to do something for you."],[2900,3045,"W-What?"],[3537,3704,"Although I've been preparing"],[3708,3875,"for a long time,"],[3879,4112,"I'm still a little nervous."],[4116,4241,"After all,"],[4245,4504,"it's my first time doing this."],[4633,4800,"What do you mean, \"first time\"?"],[4837,4904,"You"],[4908,5000,"what are you trying to do?"],[5025,5291,"Something beneficial for you, of course."],[5329,5537,"Don't worry. Just lie down."],[5558,5645,"It won't hurt."],[5770,5937,"Is she trying to"]],"36":[[166,333,"Mr. Shepherd,"],[416,570,"didn't you sleep well last night?"],[575,691,"You look terrible."],[4016,4291,"Well? Any sensation at all?"],[4416,4554,"Uh"],[4729,4862,"No sensation."],[4908,4958,"Then"],[4962,5150,"why are you sweating so much?"],[5354,5487,"The heat's turned up too high."],[5491,5683,"Oh, I see."],[5800,5895,"Don't worry."],[5900,6025,"I spent a fortune"],[6029,6150,"hiring doctors from all over."],[6187,6283,"We'll try once a day."],[6287,6441,"We'll get you cured eventually."],[6483,6529,"Well"],[6612,6791,"you don't have to go to such trouble."],[6795,6879,"Oh, come on."],[6883,7070,"I have plenty of strength and means."],[7075,7112,"Come here."],[7116,7333,"Uh... hey... wait"],[7895,8083,"Hey! I felt that!"],[8258,8454,"Ah... hey"],[8487,8608,"Listen, Carl,"],[8916,9029,"it's all because someone"],[9033,9166,"has too much energy."],[9541,9666,"Don't tell me"],[9691,9808,"you blew your cover last night?"],[9929,10020,"Don't be ridiculous."],[10191,10341,"I asked you to check Zane's whereabouts."],[10341,10421,"Find anything?"],[10423,10512,"Yes."],[10558,10654,"Zane secretly returned"],[10658,10762,"a few days ago."],[10812,10891,"He seems to have"],[10895,11012,"dealings with the Jenningses."],[11029,11125,"The Jenningses"],[11333,11450,"That reminds me."],[11504,11700,"Investigate Ember's background."],[11741,11941,"Especially that child of hers."],[11995,12062,"Yes."]],"37":[[37,141,"Mr. Shepherd,"],[245,391,"do we have any dresses"],[395,620,"that are bold and striking,"],[625,687,"the kind that makes people"],[691,812,"unable to look away?"],[816,954,"I want to wear one the day after tomorrow."],[975,1070,"Yes, Mrs. Shepherd."],[1100,1216,"I'll have a few prepared right away"],[1220,1308,"and brought over for you to choose."],[1312,1366,"Okay."],[1595,1795,"Why does she suddenly want to dress up?"],[1900,2012,"What is she planning to do?"],[2241,2362,"It seems she's going to the Jenningses'."],[2412,2533,"On that day,"],[2537,2716,"Channing and Ember will be there, too."],[2720,2866,"So Channing will be there."],[3620,3720,"Esther,"],[3725,3912,"you finally picked up."],[4266,4387,"Just to see him,"],[4391,4591,"do you really need to dress up like that?"],[4616,4670,"Mr. Shepherd,"],[4720,4816,"don't you think"],[4820,5033,"Mrs. Shepherd's sudden trip to the Jenningses"],[5066,5175,"is a bit too coincidental?"],[5254,5362,"Is it possible"],[5400,5508,"that Zane sent her"],[5512,5641,"to test your condition?"],[5954,6175,"Mom,"],[6179,6300,"don't go."],[6470,6562,"No, she isn't."],[6654,6858,"She just wants to see a certain someone."],[6916,7108,"Will you go back with Mrs. Shepherd?"]],"38":[[279,416,"Haha."],[420,541,"Channing, Ember,"],[545,662,"you're finally here."],[666,704,"Hey,"],[737,829,"come, sit down."],[833,1029,"Mom, Dad, are we late?"],[1033,1150,"Not at all."],[1154,1329,"Channing, your presence is enough."],[1333,1500,"You shouldn't have brought so many gifts."],[1562,1637,"Just a small token."],[1883,2058,"Here, sit, sit."],[2616,2670,"Ember,"],[2716,2770,"how is it going?"],[2850,2945,"Any news on the baby?"],[3037,3200,"Channing refuses to even touch me."],[3216,3408,"Esther tried for so long before."],[3412,3566,"If we didn't know she was the problem,"],[3600,3662,"I would've suspected"],[3666,3791,"it was Channing's issue."],[3841,3966,"Besides, I can tell"],[3970,4025,"that Channing is still"],[4029,4166,"obsessed with that b**ch."],[4204,4262,"He came back this time"],[4283,4416,"just to see her."],[4554,4683,"To see Esther,"],[4687,4887,"tortured beyond recognition by the Shepherds?"],[4954,5225,"I heard the Shepherds hired doctors for days."],[5254,5504,"Looks like Esther suffered quite a bit."],[5575,5641,"It's true."],[5729,5845,"Carl is skilled with knives."],[5900,6045,"It seems that Esther,"],[6050,6170,"must have been tortured so badly,"],[6175,6266,"she doesn't have a patch of good skin left."],[6308,6454,"When Channing sees her later,"],[6504,6662,"he'll surely be disgusted."],[7354,7495,"Channing, in the future,"],[7500,7579,"as for the Jenningses' business,"],[7583,7766,"please look out for it."],[7787,7879,"Of course."],[8175,8350,"I'm afraid you two will be disappointed."],[8379,8500,"My husband's blade"],[8504,8650,"is only pointed at outsiders."],[8679,8850,"As for how I'm doing,"],[8891,9016,"there's no need for you to worry."]],"39":[[0,141,"He didn't even accompany you for the homecoming."],[179,258,"It seems Carl"],[262,354,"doesn't give a d*mn about her."],[370,470,"That phone call the other night,"],[504,645,"she surely staged it to spite me."],[675,779,"It was just an act."],[908,975,"Sis,"],[1012,1141,"where's Carl?"],[1162,1283,"Don't tell me you came back"],[1341,1454,"all by yourself?"],[1562,1641,"Ember,"],[1670,1737,"why are you so"],[1741,1837,"obsessed with your brother-in-law?"],[1858,1929,"Don't tell me"],[1954,2025,"Channing alone"],[2029,2133,"isn't enough to satisfy you?"],[2195,2245,"Esther,"],[2266,2383,"watch your mouth."],[2387,2508,"Ember is just looking out for you."],[2533,2591,"Save it."],[3166,3254,"Why is he leaning in so close?"],[3312,3412,"What is he up to?"],[3495,3550,"Esther,"],[3612,3729,"this homecoming is a big deal."],[3741,3816,"Carl,"],[3833,3954,"even with his bad legs,"],[3970,4070,"should have at least shown his face."],[4087,4225,"You coming back alone like this"],[4254,4304,"if word gets out,"],[4308,4425,"what will people think of the Jenningses?"],[4441,4537,"How outsiders view"],[4541,4645,"your family is none of my business."],[4683,4754,"I didn't come back"],[4758,4841,"to play along with your"],[4845,4962,"\"happy family\" charade."],[4983,5112,"Then why are you here?"],[5129,5229,"Don't tell me you couldn't"],[5233,5337,"hack it at the Shepherds',"],[5345,5470,"so you're back to beg Dad for help?"],[5508,5629,"I came back today simply to"],[5633,5762,"I'm here to take back my mother's belongings."],[5791,5866,"I'll leave once I have them."],[6030,6075,"You"],[9350,9487,"the belonging you mentioned,"],[9504,9637,"don't tell me it's this."],[9691,9745,"This zither,"],[9750,9891,"Dad already promised it to me."],[9908,10012,"There is no way I'll let you"],[10016,10112,"take it away today."]],"40":[[16,83,"This is what my mother"],[87,187,"left for me."],[233,308,"Why should I give it to you?"],[425,612,"Your dead mother's things"],[616,766,"caught the eye of a lady like me."],[770,912,"That is her blessing."],[958,1095,"Instead of thanking me,"],[1112,1191,"you're trying to fight me for it."],[1279,1383,"You don't deserve to touch it."],[1741,1795,"What?"],[1820,1895,"Do you really think"],[1900,2016,"marrying into the Shepherds"],[2020,2150,"gives you someone to rely on?"],[2183,2270,"You came back"],[2275,2408,"all by yourself this time."],[2441,2587,"Even if we really started fighting,"],[2604,2720,"that crippled husband of yours"],[2741,2879,"probably couldn't even crawl over here."],[2900,3033,"Watch your mouth."],[3054,3095,"Why?"],[3162,3233,"You married a cripple,"],[3237,3366,"and you won't admit it?"],[3375,3437,"But you know what?"],[3470,3583,"You two are actually a perfect match."],[3604,3716,"One has a broken hand,"],[3720,3829,"the other has crippled legs."],[3891,4170,"Made for each other."],[4316,4383,"Esther!"],[4400,4462,"What are you doing?"],[4483,4587,"Channy!"],[4612,4704,"My sister is trying to steal the gift"],[4708,4795,"that Dad gave to me."],[4816,4862,"I wouldn't let her,"],[4883,4979,"so she tried to hit me."],[4995,5058,"Esther,"],[5112,5162,"since when did you"],[5166,5258,"become so vicious?"],[5275,5358,"At home, you always"],[5362,5441,"bullied Ember."],[5462,5587,"Now you've got what you wanted."],[5591,5675,"Even after marrying into the Shepherds,"],[5725,5825,"why are you still so vicious?"],[5837,5904,"Channing,"],[5966,6108,"you never fail to redefine"],[6112,6241,"what it means to be blind."],[6270,6333,"you'd better let go."],[6400,6470,"look at yourself now"],[6475,6545,"and everything you've done."],[6558,6716,"Do you not have a shred of regret?"],[6745,6820,"For Ember?"],[6850,6979,"Or for our ten years of love?"],[7004,7045,"My only regret is"],[7050,7162,"not seeing your true colors sooner."],[7529,7579,"Channing,"],[7595,7687,"let go of me."],[7716,7762,"Stop pulling and tugging"],[7766,7845,"at me here."],[7875,8029,"If word gets out,"],[8037,8183,"I'm afraid my husband might get jealous."],[8208,8295,"\"Husband\"?"],[8366,8483,"That rolls off the tongue so easily."],[8495,8554,"Esther,"],[8608,8716,"I never realized before"],[8720,8820,"that you were so good at aggravating people."],[8850,8904,"What?"],[9004,9062,"Mr. Lewis is allowed to"],[9066,9162,"sleep around"],[9166,9250,"and get someone pregnant,"],[9266,9350,"but I'm not allowed to find"],[9354,9445,"someone who treats me with sincerity?"],[9545,9666,"Someone who treats you with sincerity"],[9687,9766,"wouldn't refuse to join you"],[9770,9879,"for your homecoming banquet."],[9900,10029,"Is this the \"good man\" you picked?"],[10041,10183,"He is better than you."],[10187,10276,"A thousand times,"],[10350,10443,"ten thousand times better."],[10500,10595,"Aside from Carl having"],[10600,10666,"some filthy money,"],[10670,10787,"what else can he give you?"],[10808,10925,"He's so crippled,"],[10950,11112,"I bet he can't even perform in bed."]],"41":[[4,66,"Channing,"],[100,220,"you're seriously sick."],[241,325,"Channy,"],[362,454,"are you okay?"],[629,758,"How dare you, Esther."],[800,883,"Over a man you've known"],[887,958,"only a few months,"],[962,1083,"you actually hit me!"],[1091,1170,"Don't you deserve it?"],[1216,1262,"Channing,"],[1279,1362,"I'm warning you,"],[1383,1504,"watch your mouth."],[1570,1658,"I'm going to say it."],[1725,1804,"Esther,"],[1841,1979,"whatever Carl can give you,"],[2012,2120,"I can give you just the same!"],[2708,2750,"You!"],[2879,2941,"Channing,"],[2958,3041,"are you crazy?"],[3091,3162,"Ember is the Mrs. Lewis"],[3166,3283,"you lawfully married,"],[3320,3408,"who just gave birth"],[3412,3512,"to your son."],[3529,3612,"We've been over"],[3616,3704,"for a long time!"],[3758,3816,"Esther,"],[3837,3908,"please don't go on"],[3912,3991,"like this."],[4045,4150,"All the mistakes"],[4170,4304,"are my fault alone."],[4316,4362,"If you want to hit someone,"],[4408,4508,"then just hit me."],[4599,4666,"As you wish."],[4679,4733,"You!"],[5045,5108,"Buy one, get one free."]],"42":[[25,100,"Buy one, get one free."],[479,545,"If hitting me"],[600,766,"will help you cool off, Esther,"],[787,891,"I really don't mind."],[925,1020,"Ember,"],[1025,1112,"drop the act."],[1145,1258,"These two slaps don't even"],[1262,1362,"begin to make up for"],[1366,1520,"the pain of your slander"],[1525,1633,"and your schemes against me!"],[1666,1712,"Esther,"],[1800,1891,"what slander? What schemes?"],[1895,1962,"Explain yourself!"],[2008,2083,"Channy,"],[2125,2233,"don't listen to her nonsense."],[2245,2370,"She's just trying to tear us apart."],[2737,2816,"You"],[2833,2941,"Ember,"],[2945,3050,"this slap is because"],[3054,3166,"a leopard never changes its spots."],[3208,3433,"You're still trying to lie your way out."],[3725,3887,"I'm taking this piano."],[3891,4020,"It's going to my home with Carl."],[4045,4095,"From now on,"],[4108,4204,"I'll play for whoever I want,"],[4208,4329,"whenever I want."],[4733,4804,"You can move it now."],[5095,5166,"I won't allow it!"],[5183,5283,"Are you crazy?"],[5316,5500,"Yes, I am crazy."],[5516,5591,"You clearly told me,"],[5595,5654,"you said explicitly,"],[5675,5775,"that you'd only play for me,"],[5779,5845,"for the rest of your life."],[5887,6025,"I won't let you take it away,"],[6029,6145,"and I certainly won't let you"],[6150,6212,"play it for anyone else!"],[6458,6520,"What?"],[6775,6945,"Does my closeness with Mrs. Shepherd"],[7075,7200,"bother you, Mr. Lewis?"]],"43":[[79,250,"Does my closeness with Mrs. Shepherd"],[337,504,"bother you, Mr. Lewis?"],[733,804,"Why are you here?"],[873,933,"I was worried,"],[975,1062,"so I came to check on you."],[1127,1187,"Men,"],[1270,1416,"move Mrs. Shepherd's piano"],[1429,1612,"and load it carefully onto the truck."],[2181,2262,"I'd like to see who dares!"],[2288,2380,"Esther,"],[2425,2545,"he speaks of deep affection,"],[2550,2620,"and you just believe him?"],[2641,2737,"Wake up."],[2790,2870,"Look at him—"],[2887,3070,"a cripple who can't even stand up."],[3088,3183,"How can he give you"],[3187,3291,"any deep affection?"],[3300,3362,"If it weren't"],[3366,3454,"for the fact that he's a cripple,"],[3470,3616,"would the Shepherds let him marry you"],[3658,3741,"and choose the Jenningses?"],[3745,3870,"Don't be naive."],[3925,4079,"You really think he'd marry you?"],[4112,4229,"Let me tell you,"],[4237,4345,"if he were a"],[4350,4462,"normal man,"],[4466,4662,"he wouldn't choose to marry you."],[4687,4800,"A woman like you who can't bear"],[4804,4916,"children,"],[4941,5041,"is only fit to"],[5045,5112,"marry a crip"],[6250,6316,"If you don't"],[6329,6412,"watch your filthy mouth,"],[6445,6612,"I won't mind making sure"],[6616,6712,"you never speak again."]],"44":[[0,83,"If you don't"],[87,166,"watch your filthy mouth,"],[191,295,"I won't mind making sure"],[300,433,"you never speak again."],[446,521,"You"],[579,616,"How can you"],[679,787,"Sometimes, sheer rage"],[791,866,"is enough to make me stand."],[875,929,"However,"],[945,1037,"what angers me most"],[1041,1100,"isn't that."],[1120,1233,"It's that some idiots"],[1266,1400,"treat a true treasure"],[1450,1562,"like it's trash,"],[1645,1850,"yet treat a cheap fake like a pearl."],[1875,1920,"You"],[1925,2016,"Actually, I should thank you."],[2045,2275,"If you weren't so incredibly blind,"],[2387,2462,"I never would have had the chance"],[2466,2537,"to meet Esther."],[2704,2825,"You're just posturing!"],[2841,3000,"The Shepherds are a powerful family."],[3004,3091,"I don't believe"],[3133,3250,"you'd ever really marry"],[3254,3420,"a woman who can't bear children."],[3425,3525,"From beginning to end,"],[3554,3627,"what I have loved"],[3629,3712,"is who she is."],[3741,3925,"It has nothing to do with her health."],[3975,4054,"In this lifetime,"],[4087,4266,"once I, Carl, choose a woman,"],[4279,4433,"I will never let her go."],[5467,5532,"Mr. Shepherd,"],[5675,5704,"you"],[5745,5808,"your legs"],[5841,5962,"Thanks to your daughter,"],[6004,6125,"they have healed completely."],[6133,6204,"To show my gratitude,"],[6212,6333,"I went ahead and moved her beloved piano"],[6337,6512,"back to the Shepherds."],[6575,6650,"You have no objections, do you?"],[6695,6845,"N-no, none at all."],[6848,6908,"Also,"],[6941,7033,"for how the Jenningses"],[7037,7154,"have treated her all these years,"],[7191,7245,"I will make them pay,"],[7265,7483,"debt by debt."],[7550,7616,"From today on,"],[7637,7829,"if the Jenningses and the Lewises"],[7841,7979,"dare to covet anything in Riverton,"],[7983,8062,"any piece of land,"],[8066,8212,"or any project,"],[8233,8279,"the Chamber of Commerce,"],[8337,8387,"the banks,"],[8433,8562,"and all our partners"],[8583,8654,"will know the consequences"],[8658,8845,"of crossing the Shepherds."]],"45":[[0,79,"will know the consequences"],[83,266,"of crossing the Shepherds."],[270,362,"Carl,"],[408,454,"just to stand up"],[458,575,"for a woman,"],[608,754,"you're acting so recklessly."],[787,870,"Using"],[875,970,"family resources"],[975,1070,"to crush your rivals?"],[1075,1179,"You're treating this like a game."],[1238,1312,"All I know is,"],[1412,1475,"if a man can't give"],[1479,1580,"his wife"],[1612,1708,"enough respect"],[1712,1804,"and support,"],[1833,1991,"he's not fit to lead the family."],[2102,2168,"Mr. Shepherd,"],[2192,2244,"you can't"],[2258,2387,"You absolutely cannot do this."],[2398,2483,"If you put out that word,"],[2508,2662,"the Jenningses in Riverton"],[2666,2808,"will be completely finished."],[2812,2895,"Esther,"],[2900,2995,"hurry and explain"],[3000,3112,"to Mr. Shepherd!"],[3154,3258,"Yes, Esther."],[3287,3391,"He's your father."],[3408,3488,"How can you"],[3504,3579,"not reason with"],[3583,3641,"Carl?"],[3650,3795,"From the moment the three of you"],[3800,3925,"drove my mother to her death,"],[3983,4062,"I stopped acknowledging him"],[4066,4150,"as my father."],[4187,4250,"Esther,"],[4275,4345,"you"],[4358,4495,"You ungrateful wretch!"],[4654,4835,"Dad! Sir! Dad!"],[4915,4978,"Father!"],[5020,5125,"Channy!"],[5138,5262,"Think of something, quick!"],[5267,5375,"The Jenningses can't fall."],[5377,5466,"I'm begging you,"],[5470,5575,"please help our family."],[5595,5696,"Call an ambulance first."],[5850,5929,"I know."],[5933,6004,"I'll figure something out."]],"46":[[191,312,"So your leg healed a long time ago?"],[354,479,"Actually,"],[554,737,"my leg was never injured to begin with."],[929,987,"Carl,"],[991,1066,"you really are quite the actor."],[1116,1200,"You play every part to perfection."],[1216,1291,"Even just now,"],[1295,1416,"that act of deep affection"],[1454,1562,"came so naturally to you."],[1770,1841,"Mr. Shepherd."],[1882,1933,"Mr. Shepherd,"],[1983,2070,"regarding the investigation"],[2075,2195,"into Ember and Channing,"],[2212,2279,"we have results."],[2283,2362,"Speak."],[2441,2495,"We discovered that"],[2604,2750,"the timing of Ember's pregnancy"],[2779,2895,"doesn't seem to add up."],[2916,2983,"We dug deeper and found"],[3016,3112,"that the child's biological father"],[3116,3250,"isn't Channing at all."],[3254,3325,"Back then,"],[3341,3429,"Channing was"],[3433,3504,"drugged by Ember,"],[3525,3691,"and tricked into becoming the father."],[3722,3783,"Here,"],[3820,3904,"is the surveillance footage from that time."],[4129,4170,"Excellent."],[4182,4266,"Arrange for a"],[4270,4350,"paternity test immediately."],[4375,4404,"Also,"],[4416,4554,"leak the news about Ember drugging him"],[4558,4675,"to the Lewises."],[4679,4783,"Let that idiot Channing"],[4798,4891,"see clearly"],[4916,5033,"just how ridiculously stupid he is."],[5129,5183,"Yes, Mr. Shepherd."],[5275,5341,"Dismissed."],[5350,5400,"Yes, sir."]],"47":[[320,500,"Thousands of dollars a sip, huh?"],[758,891,"That's for lying to me."],[904,1083,"I'll drink you dry."],[1920,2033,"What cr*ppy wine."],[2066,2220,"It doesn't drown my sorrows at all."],[2225,2395,"It's clearly just a contract marriage,"],[2400,2645,"so isn't it natural for him to keep secrets?"],[2650,2795,"Why am I taking this so seriously?"],[2816,2962,"It's ridiculous!"],[3566,3679,"Why did you drink so much?"],[3904,3995,"Still mad at me?"],[4158,4242,"I wouldn't dare."],[4262,4358,"What right do I have"],[4362,4491,"to be angry at Carl?"]],"48":[[42,191,"Of course you do."],[226,366,"In all of Riverton,"],[409,541,"you're the only one"],[567,700,"who dares to steal my wine"],[783,941,"and give me an attitude."],[1024,1208,"I'm not mad at all."],[1283,1450,"We're just partners."],[1492,1650,"You have your own plans."],[1711,1887,"You don't need to report everything to me,"],[1891,1929,"right?"],[1944,2062,"Who says I don't need to?"],[2154,2300,"I think it's very necessary."],[2338,2450,"I pretended to be crippled"],[2525,2687,"to lure someone out."],[2723,2825,"His name is Zane."],[2881,3015,"He's the one who caused that car accident"],[3100,3229,"trying to get rid of me."],[3383,3479,"So,"],[3594,3837,"you laid low all these years"],[3908,4079,"just to lure him out?"],[4295,4370,"Besides,"],[4425,4529,"all these years,"],[4595,4683,"he never gave up"],[4687,4829,"on trying to kill me."],[4877,5041,"I've been waiting for him to show up."],[5102,5162,"Then,"],[5233,5387,"why reveal such a big secret"],[5476,5758,"today just for me?"],[5816,5950,"Because I can always make another plan,"],[6020,6137,"but Esther,"],[6166,6320,"there's only one of you in this world."],[6649,6728,"You"],[6820,6916,"You stayed hidden for years,"],[7079,7362,"but blew your cover on impulse for me."],[7500,7550,"Was it worth it?"],[7554,7625,"It was."],[7891,8037,"Who was it that said,"],[8104,8197,"\"I don't love you,\""],[8201,8358,"\"so don't expect anything from me\"?"],[8566,8662,"Was that you?"],[8766,8962,"Mr. \"I-Don't-Love-You\"."],[9187,9279,"So,"],[9491,9562,"isn't this me coming here personally"],[9566,9704,"to eat my own words?"],[9858,9933,"Esther,"],[10066,10187,"from the moment you appeared in my world,"],[10191,10295,"right from that instant,"],[10362,10500,"my principles haven't meant a thing."],[10600,10708,"Do you think"],[10766,10920,"that piece of paper"],[11058,11245,"can still hold me back?"],[11641,11733,"What if I say,"],[11737,11837,"I'm not willing?"],[11937,12012,"Fine."],[12079,12262,"Then go ahead and try."],[12420,12554,"See if I'll"],[12687,12783,"actually leave."]],"49":[[50,125,"Wait."],[470,608,"I-I'm sorry."],[666,783,"I was impulsive."],[787,854,"I shouldn't have,"],[870,1029,"while you've been drinking."],[1079,1162,"I"],[1183,1312,"just wanted to ask,"],[1416,1575,"after being in a wheelchair for so long,"],[1662,1758,"are you really capable?"],[2161,2250,"I am."],[2494,2632,"Very much so."],[4412,4487,"Esther,"],[4633,4837,"I need you to personally verify"],[4962,5095,"whether I'm capable or not."]],"50":[[3875,4029,"Who said this man wasn't capable?"],[4104,4237,"He's way too capable."],[5250,5370,"As long as Mrs. Shepherd is satisfied."],[5520,5645,"But are you seriously"],[5783,5945,"trying to bail"],[5991,6070,"after having your way with me?"],[6075,6162,"Of course not!"],[6166,6250,"Then what is it?"],[6333,6400,"I"],[6441,6620,"I'll take responsibility for you."],[6695,6870,"You can take responsibility right now."],[7150,7250,"No."],[7600,7662,"Carl."],[7666,7816,"I heard people outside saying"],[7820,8066,"that you can suddenly stand up."],[8070,8162,"Mom."],[8266,8450,"Um, I didn't see anything."],[8454,8525,"You two carry on."],[8529,8595,"Carry on."],[8954,9050,"That Esther,"],[9054,9229,"is truly our family's lucky star."],[9241,9429,"They haven't been married long,"],[9450,9529,"but our Carl"],[9554,9754,"is really starting to look like a human being."],[9758,9945,"He even stood up."],[9950,10137,"Oh my, he's even capable now."],[10141,10279,"Hahaha."],[10283,10408,"For the Shepherds,"],[10412,10495,"our ancestors"],[10508,10650,"must be smiling down on us!"],[10737,10783,"Let's go."]],"51":[[141,220,"Mr. Lewis,"],[229,350,"the Shepherds are dead set"],[354,500,"on crushing both us and the Jennings Group."],[516,704,"They've hijacked several of our core projects,"],[708,845,"and the banks are putting the squeeze on us."],[904,1004,"We can barely save ourselves."],[1008,1187,"Do we really have to keep bailing out the Jenningses?"],[1242,1329,"Yes."],[1396,1550,"I owe this to Ember."],[1554,1704,"After all, she had my child."],[2450,2704,"Brother, please reconsider."],[2708,2845,"It's what I owe Ember."],[2866,3029,"Why do you have it out for her?"],[3095,3229,"I don't have it out for her."],[3233,3379,"She has bad intentions."],[3383,3458,"She approached you"],[3462,3600,"with ulterior motives from the start."],[4570,4662,"What is this?"],[4666,4745,"It's from a year ago,"],[4750,4929,"surveillance footage from the Summit Hotel."],[4991,5183,"Brother, when you were drugged back then,"],[5187,5345,"it was Ember all along."],[5350,5429,"She staged the whole thing."]],"52":[[91,208,"Enough, Cynthia!"],[266,437,"Ember is innocent and fragile."],[441,516,"She's carrying my child,"],[520,637,"and she's suffered so much!"],[691,908,"Yet you, my own sister,"],[912,1012,"time and again,"],[1016,1237,"slander her with baseless accusations."],[1270,1350,"Cynthia,"],[1370,1537,"I'm so disappointed in you!"],[1562,1816,"Brother, I'm your own sister."],[1820,1987,"Why would I ever hurt you?"],[2041,2208,"It's precisely because you're my sister"],[2220,2304,"that I have"],[2308,2516,"tolerated you time and again."],[2600,2687,"From now on, I don't want to hear"],[2691,2825,"another bad word"],[2829,2912,"about Ember."],[2937,3004,"Get out."],[4304,4408,"That idiot."],[4425,4587,"He sees the proof and still won't believe it."],[4700,4804,"He's hopeless."],[4929,5066,"However,"],[5150,5300,"we lost Zane."],[5344,5495,"He's cunning."],[5512,5608,"He slipped into the Lewises' home,"],[5636,5787,"and our men can't get inside."],[5829,5925,"The Lewises?"],[6112,6337,"So his visit to the Jenningses earlier"],[6362,6545,"was to meet Ember."],[6591,6766,"Are you saying Ember's child"],[6770,6866,"It's just a theory."],[6908,7000,"We can't be sure yet."],[7037,7162,"But it's better if Channing"],[7233,7441,"uncovers the truth himself."],[7510,7603,"Understood."],[7834,7925,"You're dismissed."],[8066,8154,"I just heard"],[8158,8291,"you mention Channing."],[8320,8454,"Did something happen to him again?"],[8508,8608,"Mrs. Shepherd."],[8729,8820,"The first thing you say walking in"],[8825,8995,"is about your ex?"],[9129,9275,"I'm just curious"],[9279,9437,"how he's connected to Zane."],[9683,9795,"You want to know?"],[10153,10491,"Then shouldn't you show some appreciation?"]],"53":[[58,137,"Suit yourself."],[191,270,"Okay, okay."],[300,370,"My bad."],[408,583,"I was the one begging you to ask."],[679,854,"So, exactly what is going on?"],[933,1187,"Zane is very likely the biological father"],[1191,1354,"of Ember's child."],[1444,1579,"Channing is being played,"],[1687,1850,"rushing to raise another man's child."],[2062,2158,"What?"],[2220,2366,"The child isn't actually Channing's?"],[2687,2837,"It's both laughable and pathetic."],[3033,3158,"So, what do you plan to do next?"],[3220,3525,"He ignores everyone's warnings."],[3595,3716,"Since he refuses to wake up,"],[3820,3979,"I'll let him find out the hard way."],[4166,4312,"You've got some nerve,"],[4358,4508,"bringing me here."],[4537,4595,"Lately,"],[4600,4737,"Channing has been busy fixing"],[4741,4895,"the mess with the Jenningses and the Shus."],[4929,5083,"He has no time to come back here."],[5504,5629,"That b**ch,"],[5683,5879,"she dares to cheat right under my nose!"]],"54":[[29,104,"Are you scared?"],[191,275,"Besides,"],[279,566,"don't you think this is even more exciting?"],[608,841,"Anyway, you've been hiding abroad for so long,"],[887,1062,"didn't you miss me?"],[1083,1308,"Oh, I missed you to death."],[1312,1458,"It's been hard on you all these years,"],[1475,1620,"having to deal with that idiot."],[1641,1704,"Hahaha."],[1808,1979,"I get p*ssed just mentioning that moron."],[2062,2187,"He finally got me but doesn't cherish me."],[2225,2387,"He even threw up on me on our wedding night."],[2454,2612,"He deserves to be played for a fool."],[2825,2900,"Babe,"],[2920,3000,"aren't we doing this for"],[3004,3120,"the Lewises' fortune?"],[3154,3325,"For the sake of our future,"],[3345,3420,"just bear with it a little longer."],[3425,3579,"Whatever you do, don't blow our cover."],[3620,3750,"But honestly, he's so easy to trick."],[3783,3904,"From that drink at the Summit,"],[3945,4129,"to framing Esther for drugging me,"],[4166,4304,"I just had to play the victim,"],[4308,4450,"and he fell for it."],[4504,4600,"Framed for drugging?"],[4666,4750,"What does that mean?"],[4804,4887,"Could it be"],[5450,5525,"What is this?"],[5550,5704,"This is the surveillance footage"],[5708,5783,"from the Summit Hotel a year ago."]],"55":[[450,512,"Who's there?"],[554,666,"What are you afraid of?"],[716,870,"The servants aren't in the main house."],[3008,3200,"Mom, are you sure this medicine"],[3212,3316,"will make the baby"],[3379,3458,"be born early?"],[3525,3604,"Of course."],[3695,4004,"So Cynthia was right."],[4116,4254,"It was me."],[4441,4675,"I was the one who wronged Esther."],[4808,4933,"Esther!"],[4966,5083,"You actually set a dog on her!"],[5575,5729,"Let go!"],[5820,5983,"What are you doing!"],[6264,6495,"And yet, I treated her like that."],[6983,7137,"Carl was right."],[7282,7525,"I mistook a pebble for a pearl."],[7663,7816,"I was blind!"],[8013,8237,"I can't believe I treated her that way."],[8470,8550,"No."],[8678,8995,"Esther... I... I have to find Esther!"]],"56":[[370,466,"Mr. Shepherd, Mrs. Shepherd,"],[470,558,"there is a gentleman named"],[562,662,"Channing outside,"],[665,763,"who wants to see you."],[812,875,"We can't stop him."],[966,1062,"He sure knows how to pick a time."],[1184,1254,"Send him away."],[1263,1341,"No."],[1422,1533,"I'll go out to see him."],[1958,2033,"Esther!"],[2179,2258,"Esther!"],[2401,2516,"I know I was wrong."],[2612,2795,"Will you come out and see me?"],[2886,2987,"Esther,"],[3065,3241,"I know everything now."],[3325,3458,"It's my fault."],[4200,4275,"Esther,"],[4370,4475,"I knew"],[4647,4795,"you wouldn't be so heartless."]],"57":[[29,266,"Go home. Stop making a scene here!"],[275,450,"No, I'm not leaving."],[483,529,"Esther,"],[591,691,"I know I messed up."],[754,879,"I know everything now."],[929,1129,"It was Ember and her mom who framed you."],[1242,1350,"I was blind."],[1366,1508,"You were indeed blind and heartless."],[1566,1683,"The evidence was right in front of you,"],[1687,1762,"and you didn't even look at it."],[1812,1870,"Esther,"],[1925,2050,"I really know I was wrong."],[2095,2216,"I failed you."],[2329,2479,"Can you give me another chance?"],[2512,2620,"Let's start over."],[2691,2758,"I promise"],[2779,2891,"I'm living a good life now,"],[2987,3141,"and I have no plans to divorce Carl."],[3216,3350,"I came out just to make things clear."],[3433,3533,"There is no chance for us anymore."],[3608,3754,"No, I don't believe you."],[3816,4075,"You loved me for ten years!"],[4116,4204,"Yes."],[4300,4516,"Ten years is a long time."],[4658,4937,"Long enough to see who you are and leave."],[5015,5112,"Channing,"],[5170,5304,"your regret comes too late."],[5354,5433,"It means nothing now."],[5679,5812,"The person I'm willing to have"],[5816,5900,"stand by my side now"],[6029,6112,"is Carl."],[6437,6670,"Channing, you have to understand,"],[6720,6829,"some mistakes"],[6879,7062,"can't be fixed with an apology."],[7162,7237,"Please leave."],[7345,7420,"Stop disturbing"],[7425,7512,"our peace."],[8766,8937,"Using me to drive your fiancé away,"],[9100,9200,"how did it feel?"],[9329,9383,"Hey!"],[9387,9533,"So, Carl still gets jealous"],[9537,9770,"over ancient history?"],[9828,9925,"Don't change the subject."],[10012,10245,"Fine, I won't."],[10320,10416,"Then I'll tell you,"],[10444,10625,"it felt amazing."],[10694,10783,"[Chuckles]"]],"58":[[1025,1125,"Not jealous anymore, are you?"],[1655,1745,"Trying to leave already?"],[1871,2104,"What else? Trying to take advantage of me?"],[2166,2345,"That'll cost you extra."],[2787,2858,"What are you doing?"],[2862,2941,"Put me down!"],[3058,3175,"Didn't you ask for that extra fee?"],[3291,3358,"I'm giving it to you right now!"],[3420,3512,"You pervert!"],[4125,4195,"You have no idea."],[4200,4437,"Ever since Esther married into the Shepherds,"],[4441,4525,"she's been so cocky."],[4583,4670,"At her homecoming banquet,"],[4695,4795,"you should've seen how smug she was!"],[4925,5066,"What support"],[5070,5166,"can that cripple from the Shepherds"],[5170,5270,"possibly give her?"],[5362,5450,"Cripple?"],[5512,5654,"Carl recovered ages ago."],[5691,5779,"Otherwise,"],[5854,5945,"how could Esther's life"],[5950,6045,"be going so smoothly?"],[6249,6366,"What did you say?"],[6370,6700,"Carl can actually walk?"],[6708,6804,"Is that confirmed?"],[6808,6908,"Absolutely."],[6983,7104,"I saw it with my own eyes."],[7187,7229,"What's wrong?"],[7370,7608,"He can actually walk"],[7612,7708,"I didn't take his life,"],[7712,7908,"but taking his legs should've been enough."],[7995,8150,"How could he have recovered?"],[8170,8308,"It seems"],[8312,8547,"I'll have to find a way to strike again."],[9155,9212,"Cr*p."],[9253,9347,"Why is Channing back"],[9349,9411,"so soon?"]],"59":[[124,183,"Cr*p."],[262,325,"Why is Channing back"],[329,395,"so soon?"],[455,554,"Quick, hide!"],[1512,1612,"Channy,"],[1616,1720,"you're back."],[1753,1991,"Look at you. Why are you such a mess?"],[2058,2175,"Let me run you a hot bath."],[2341,2450,"What a performance."],[2479,2541,"Ember,"],[2620,2736,"you ruined my happiness,"],[2799,3054,"and I'll make you suffer for it."],[3108,3154,"No need."],[3191,3312,"I'll do it myself."],[3483,3662,"By the way,"],[3666,3766,"for Bobby's hundred-day celebration,"],[3800,3966,"I've already picked the venue."],[3970,4062,"It's at Rosewood Manor."],[4229,4375,"I plan to give you"],[4379,4609,"the respect and status you deserve."],[4621,4784,"Respect and status?"],[4862,4966,"Could it be,"],[4970,5162,"in front of all of Riverton's elite,"],[5220,5325,"he's going to officially acknowledge"],[5329,5437,"my status as Mrs. Lewis?"],[5475,5658,"Oh, Channing"],[5670,5920,"Just keep being the sucker."],[6204,6337,"Just wait and see."],[6341,6425,"Ember,"],[6429,6566,"the respect you crave,"],[6570,6770,"in front of everyone,"],[6816,6958,"I'll give it to you myself!"]],"60":[[1408,1454,"Cynnie,"],[1529,1645,"for Bobby's hundred-day banquet next month,"],[1679,1816,"could you invite Esther for me?"],[1862,1970,"I have something very important"],[1975,2058,"to tell her."],[2358,2466,"Come out, quick."],[3416,3537,"See you at our son's banquet."],[4329,4391,"Mom."],[4425,4504,"Channing"],[4508,4658,"he plans to use Bobby's banquet"],[4675,4733,"to officially acknowledge"],[4737,4825,"my status as Mrs. Lewis."]],"61":[[169,225,"Mr. Shepherd."],[266,358,"In here"],[387,533,"are the paternity test results"],[537,620,"for Channing and Ember's child."],[1403,1608,"Channing, oh, Channing."],[1691,1837,"You brought this entirely on yourself."],[1900,2129,"Should we leak this information"],[2133,2200,"to the Lewises beforehand?"],[2287,2395,"Right now, Channing"],[2400,2566,"is preparing his child's hundred-day banquet."],[2616,2754,"He says that at the banquet,"],[2775,2912,"he'll give the birth mother a proper title."],[2995,3075,"No need."],[3187,3416,"I have my own way to make Ember"],[3420,3591,"utterly humiliated!"],[4045,4237,"Esther,"],[4241,4412,"Esther."],[4416,4587,"I was thinking, since Carl's health"],[4591,4708,"has recovered,"],[4733,4883,"regarding your wedding with Carl,"],[4887,5037,"shouldn't we hurry up and hold it?"],[5100,5283,"I really can't wait"],[5287,5408,"to tell the whole world"],[5454,5562,"that I"],[5566,5770,"have a wonderful daughter-in-law like you!"],[5875,5970,"I'm fine with whatever, Mom."],[6054,6108,"Really?"],[6145,6283,"Oh, wonderful!"],[6329,6450,"For the venue and dates,"],[6470,6600,"I've already picked them."],[6616,6704,"Last night,"],[6720,6845,"I stayed up thinking about it."],[6883,7041,"Let's have two weddings."],[7070,7262,"One in Ireland, one in Riverton."],[7316,7454,"If I wasn't worried"],[7462,7579,"that your health couldn't handle it,"],[7608,7733,"I'd honestly love to"],[7737,7862,"host a world tour!"],[8583,8716,"Esther, what's wrong?"],[8766,8925,"Did I scare you just now?"],[9020,9054,"I'm fine."],[9058,9079,"Mom,"],[9145,9279,"I'm really not feeling well."],[9291,9412,"I'm going to my room to rest."],[9470,9538,"Alright."],[9795,9901,"Hey!"],[9916,9958,"Esther!"],[10002,10066,"Hurry,"],[10070,10145,"call a doctor!"],[10441,10508,"Congratulations, Mrs. Shepherd."],[10512,10591,"Congratulations, Mr. Shepherd."],[10600,10687,"Mrs. Shepherd is already"],[10691,10783,"over a month pregnant."],[11066,11187,"I'm going to be a grandma!"]],"62":[[20,104,"Is this true?"],[181,329,"I'm going to have a baby."],[373,495,"It's our baby."],[667,891,"Carl. Mom."],[1084,1197,"Oh, my sweet child."],[1212,1433,"This is joyous news. Don't cry now."],[2045,2129,"Okay, stop crying."],[2166,2300,"You'll soak your clothes if you keep at it."],[2312,2370,"You little crybaby."],[2462,2608,"I am not!"],[2729,2762,"Okay."],[2883,2954,"Then dry your tears."],[3195,3437,"I still can't quite believe it."],[3441,3683,"Could it be a mistake?"],[3725,3895,"I was sure I couldn't"],[3898,3995,"How could it be a mistake?"],[4000,4180,"Look, you are pregnant."],[4354,4470,"Why would it be impossible?"],[4532,4640,"Dr. Jacobs said ages ago"],[4708,4895,"that the damage from the freezing water"],[4900,4987,"had already healed."],[5033,5175,"If I was already healed,"],[5225,5320,"then why, with Channing,"],[5325,5487,"after being together for so long,"],[5491,5620,"did I never get pregnant?"],[5650,5729,"Mr. Lewis's assistant"],[5733,5850,"asked me to bring this."],[5854,6050,"It's the pre-marital exam report for you and Mr. Lewis."],[6418,6505,"Esther."],[6537,6616,"What's wrong?"],[7620,7704,"So,"],[7708,7804,"Ember's child"],[7808,7945,"isn't Channing's at all."],[7979,8083,"But that scumbag"],[8133,8333,"treats another man's child like a treasure,"],[8337,8495,"and hurt me just to protect it."],[8925,9079,"Carl,"],[9083,9222,"do you remember our agreement?"],[9345,9487,"I have to find a chance"],[9492,9628,"to make them pay."]],"63":[[66,133,"What do you plan to do?"],[196,362,"Of course, I'll make him taste"],[425,520,"what it's like to be betrayed by family"],[571,816,"and become the laughingstock of the city!"],[820,887,"Good."],[990,1183,"Mr. Shepherd, Mrs. Shepherd,"],[1208,1316,"Miss Cynthia is here to see you."],[1825,1937,"Esther,"],[1941,2008,"what's wrong?"],[2095,2245,"Did someone bully you?"],[2382,2458,"No,"],[2550,2804,"I just got some sand in my eye."],[2845,2958,"What brings you here?"],[3054,3175,"It's... it's my brother."],[3266,3358,"He asked me to invite you"],[3362,3458,"to Bobby's hundred-day celebration,"],[3475,3620,"saying he has important news for you."],[4141,4175,"Okay."],[4250,4316,"Tell him,"],[4320,4550,"I'll definitely be at the celebration!"]],"64":[[187,362,"Mrs. Lewis, congratulations!"],[387,504,"Mr. Lewis is holding such a grand"],[508,641,"birthday party for your child."],[644,841,"It shows how much he loves you both."],[858,933,"Yes, absolutely."],[937,1133,"Rosewood Manor is a famous proposal spot."],[1137,1312,"Mr. Lewis choosing this specific place"],[1323,1462,"must have a deeper meaning."],[1466,1525,"Mrs. Jennings,"],[1529,1725,"you're set for a life of leisure now."],[1729,2020,"Oh, not at all!"],[2037,2354,"It's all our Ember's good fortune!"],[2358,2441,"Hahaha."],[2848,2923,"Mr. Watson,"],[3129,3245,"we're honored"],[3250,3408,"by your presence."],[3437,3529,"See?"],[3533,3633,"I told you,"],[3637,3820,"the Jenningses wouldn't collapse!"],[3825,4083,"The Lewises still value Ember highly."],[4179,4254,"Look,"],[4258,4475,"you were so anxious to withdraw your capital,"],[4537,4612,"but look at the situation now."],[4733,4833,"I thought I could take the opportunity"],[4837,5000,"while the Shepherds were crushing the Jenningses"],[5004,5125,"to demand payment,"],[5154,5395,"but Zander, that old b*stard,"],[5400,5504,"latched onto the Lewises again!"],[5583,5641,"Hmph."],[5658,5812,"Talk about dumb luck!"],[5954,6158,"Since the Lewises are backing you,"],[6170,6345,"I won't say anything more."],[6387,6554,"Here's to a pleasant partnership."],[6558,6812,"Hahaha, likewise."],[7662,7720,"Channing,"],[7737,7854,"I have to say,"],[7879,8066,"it's good I was decisive back then,"],[8070,8208,"having Ember take her sister's place."],[8220,8341,"That's the only way we could tie"],[8345,8520,"the Jenningses and the Lewises so tightly together."],[8537,8662,"That's a true win-win."],[9398,9504,"When it comes down to it,"],[9517,9637,"that girl Esther"],[9641,9783,"is just like her mother."],[9804,9920,"She's unpresentable."],[9962,10095,"Unlike Ember,"],[10100,10241,"who knows how to seize an opportunity."],[10254,10450,"That's how the lady of the house should be."],[10457,10566,"From now on,"],[10570,10679,"you must cherish her."],[10841,10929,"That goes without saying."]],"65":[[216,270,"Look!"],[333,445,"It's Mr. Shepherd."],[475,600,"He's actually standing!"],[625,887,"I heard it's all thanks to Miss Jennings."],[908,1029,"She's a real lucky charm."],[1041,1183,"They're a match made in heaven."],[1195,1287,"So perfect together."],[1509,1641,"Isn't that Jason?"],[1679,1787,"Thinking back,"],[1812,1995,"to when Zander almost set you up with"],[2000,2062,"trash like him,"],[2079,2145,"it makes me sick."],[2195,2270,"But never mind."],[2329,2420,"He still has his uses."],[2491,2612,"Just wait for the show."],[2638,2729,"The show?"],[2791,2950,"Besides the report you arranged,"],[2958,3062,"is there something else?"],[3104,3191,"It's a secret."],[3195,3279,"Anyway,"],[3345,3458,"you won't be disappointed."],[3708,3804,"That lunatic."],[3829,3937,"What is he up to?"],[3991,4175,"Mom, excuse me a moment."],[4237,4316,"Go ahead."],[4750,4804,"If you want revenge,"],[4808,4912,"you can wait a little longer."],[4929,5083,"Today is important to me."],[5112,5212,"Don't ruin it."],[5333,5433,"What are you afraid of?"],[5445,5612,"I'm just here to see our son."],[5650,5762,"You'd better be."],[6237,6391,"I waited so long for him to come out."],[6395,6504,"If I miss this chance,"],[6508,6708,"how will I avenge my brother?"],[7300,7545,"Mr. Fowler has been waiting."],[7554,7645,"Take him away!"]],"66":[[116,345,"Why the sudden visit, sister?"],[366,504,"Did you hear Channy"],[508,641,"is making things official with me today,"],[666,795,"so you got worried"],[800,895,"and came to check?"],[1145,1362,"Mr. Shepherd, please don't get the wrong idea."],[1395,1620,"My sister is just... sentimental."],[1662,1745,"I really hope you don't"],[1750,1879,"let this little thing"],[1890,2058,"ruin your marriage."],[2084,2216,"You're worrying for nothing."],[2257,2416,"My husband and I are doing great."],[2454,2662,"But you shouldn't be so confident."],[2712,2858,"What if what awaits you"],[2916,3150,"is a shock, not a surprise?"],[3183,3329,"Then keep your eyes peeled later"],[3333,3458,"and watch closely"],[3475,3666,"to see who gets down on one knee for me."],[3700,3904,"Don't have a breakdown then!"],[3945,4029,"Ember,"],[4058,4162,"instead of constantly"],[4166,4287,"targeting Esther,"],[4300,4512,"you should worry about yourself."],[4591,4716,"Cynthia, dear,"],[4750,4912,"why are you always picking on me?"],[4917,5046,"After today,"],[5083,5229,"I'll be your sister-in-law."],[5291,5370,"We really should"],[5404,5566,"try to get along!"],[5937,6016,"Rest assured,"],[6037,6200,"that will never happen!"],[6362,6420,"Esther,"],[6462,6529,"let's go."],[6566,6762,"Standing too close to *some people*"],[6766,6929,"is just bad luck!"],[7312,7420,"The audacity!"],[7479,7554,"Cynthia"],[7616,7750,"Once I officially secure the title"],[7754,7879,"of Mrs. Lewis today,"],[7916,8100,"we'll see if you still dare treat me this way!"]],"67":[[204,329,"Just seeing her face"],[333,412,"makes me so angry."],[477,648,"Esther, I'm glad you're here."],[675,813,"You're just in time for the show."],[838,942,"Cynnie, never mind her."],[1092,1179,"This is for you."],[1320,1450,"A wedding invitation?"],[1454,1662,"Esther, you're getting married?"],[1666,1750,"Yes."],[1785,1920,"It's set for next month."],[1929,2091,"You have to come to the wedding!"],[2167,2258,"I'll definitely be there."],[2279,2412,"Seeing you happy"],[2413,2583,"makes me truly happy for you!"],[2612,2704,"Thanks, Cynnie."],[2800,2925,"I hope you'll always be happy, too."],[3279,3429,"Distinguished guests,"],[3433,3604,"ladies and gentlemen,"],[3612,3812,"thank you for joining us tonight for"],[3816,4083,"Mr. Channing Lewis and Miss Ember Jennings'"],[4087,4225,"beloved son's 100-Day Celebration."],[4233,4300,"At this"],[4304,4508,"moment filled with love and blessings,"],[4520,4679,"we believe Mr. Lewis"],[4695,4858,"has some heartfelt words"],[4862,5154,"he'd like to share with"],[5158,5245,"the most beautiful leading lady tonight."],[5266,5325,"So,"],[5345,5554,"with the warmest round of applause,"],[5583,5850,"please welcome Mr. Channing Lewis to the stage!"],[6254,6337,"Today"],[6362,6508,"is Bobby's 100-Day Celebration."],[6533,6691,"Thank you all for being here."],[6704,6812,"I'd like to take this opportunity,"],[6816,7016,"with you all as witnesses,"],[7062,7212,"to give the mother of my child,"],[7241,7475,"Miss Ember Jennings,"],[7483,7579,"a proper status."],[7750,8004,"Ember is innocent and kind."],[8045,8137,"Meeting her"],[8200,8345,"I'm the lucky one."],[9054,9120,"Ember,"],[9154,9304,"since the wedding,"],[9354,9466,"I've kept you waiting too long."],[9495,9608,"I want to ask you something."],[9633,9733,"Will you"],[9775,9862,"will you officially become"],[9866,10016,"my wife?"],[10054,10150,"Channy,"],[10191,10320,"I don't care about any of that."],[10362,10491,"I'm willing."],[11154,11237,"You're willing?"],[11312,11454,"You've got a lot of nerve!"]],"68":[[87,195,"Channy,"],[275,316,"why?"],[454,608,"Channing, have you lost your mind?"],[612,762,"Why did you hit Ember?"],[775,933,"Why did I hit her?"],[1012,1212,"I'll give you an explanation right now."],[2079,2262,"Yeah, how can someone be like that?"],[2266,2533,"That's just wicked. Yeah, exactly."],[4015,4103,"Ember."],[4170,4354,"At the business summit a year ago,"],[4387,4525,"you were the one who drugged me."],[4650,4775,"Your pregnancy,"],[4825,4962,"the poisoning, the miscarriage"],[5050,5200,"you staged it all yourself."],[5254,5429,"And you even framed Esther,"],[5520,5754,"making her suffer endless humiliation,"],[5858,6066,"and she was even whipped for it."],[6087,6191,"Exactly, exactly."],[6195,6320,"How can someone be so awful?"],[6325,6437,"You used me"],[6479,6704,"to fill the financial hole for the Jenningses,"],[6775,6875,"and then turned around and ran"],[6879,6966,"into another man's arms."],[6991,7079,"Ember,"],[7129,7270,"you ask why I hit you?"],[7304,7520,"Of all these things you've done,"],[7533,7737,"did I wrongly accuse you of a single one?"]],"69":[[29,116,"Ember,"],[162,304,"you ask why I hit you?"],[341,558,"Of all these things you've done,"],[570,775,"did I wrongly accuse you of a single one?"],[804,995,"Yeah, how can someone be like that?"],[1000,1287,"Exactly! She's unbelievable!"],[1288,1358,"Oh my God."],[1362,1416,"Drugging,"],[1420,1466,"framing,"],[1470,1545,"and cheating"],[1550,1700,"This woman is terrifying!"],[1871,1933,"Ah!"],[2016,2108,"Channy,"],[2112,2225,"let me explain!"],[2245,2345,"It's not like that."],[2350,2466,"This video is fake."],[2470,2608,"Someone is trying to frame me!"],[2641,2729,"Is that so?"],[2787,2904,"You might deny the video,"],[2908,3087,"but surely you recognize the person in it?"]],"70":[[0,100,"Zane."],[141,245,"Didn't I tell you to be careful?"],[250,379,"How did you still get caught?"],[445,529,"Ember,"],[545,691,"you always make me wait."],[695,804,"If I keep waiting,"],[808,991,"when will I avenge my brother?"],[1012,1191,"If I don't kill him,"],[1195,1437,"I'll have to hide like a rat forever!"],[1516,1670,"Back then, your brother"],[1675,1804,"cut corners on the project"],[1812,1933,"and embezzled public funds,"],[1937,2095,"causing the Cross-Sea Bridge to collapse."],[2100,2354,"Over a dozen innocent people died."],[2358,2483,"Your brother was sentenced to death,"],[2545,2654,"and he deserved it!"],[2754,2916,"You're the one who deserves it!"],[2920,3029,"Carl!"],[3033,3283,"If I'd known during the car crash,"],[3287,3454,"I should've been more ruthless"],[3458,3620,"and sent you and your dad to hell!"],[3637,3750,"So Ember"],[3754,3920,"was conspiring with this desperado."],[3925,4008,"He's even the one behind"],[4012,4154,"Mr. Shepherd's car accident back then."],[4204,4337,"The Jenningses are truly disgraced."],[4341,4437,"Luckily, Mr. Lewis"],[4441,4600,"saw her true colors in time."],[4609,4664,"Take him away."],[5070,5162,"Ember,"],[5204,5462,"now that the witnesses and evidence are here,"],[5516,5712,"do you have any more excuses?"],[5733,5808,"Channing,"],[5925,6133,"Ember is your son's mother."],[6141,6345,"For the sake of the child,"],[6433,6575,"please spare Ember this once!"],[6587,6725,"A woman this vicious"],[6729,6870,"doesn't deserve to be my child's mother."],[6895,7058,"I will raise the child myself."],[7066,7175,"Ember."],[7187,7479,"I'll have no ties to the child from now on!"],[7483,7616,"As for the Jenningses,"],[7645,7766,"from now on,"],[7787,7945,"don't even think about getting"],[7954,8175,"a single cent of help from me!"]],"71":[[12,87,"Channing."],[137,270,"No... no, it's not like that."],[291,429,"We're all family."],[462,558,"Ember was just ignorant."],[562,700,"I failed to raise her right."],[729,870,"For the sake of our past relationship,"],[912,1000,"Relationship?"],[1100,1341,"When you all conspired to trick me,"],[1408,1554,"did you care about our relationship then?"],[2287,2466,"It's all on this ungrateful daughter."],[2470,2583,"She's shameless."],[2587,2770,"You've completely ruined the Jenningses!"],[2787,2895,"Dad."],[2904,2979,"Channing,"],[2995,3062,"look,"],[3091,3229,"I've disciplined her for you."],[3300,3395,"She deserves it."],[3470,3583,"Please have mercy,"],[3612,3820,"and spare the Jenningses."],[3900,4058,"Channing, it's all my fault."],[4062,4158,"I know I was wrong."],[4162,4270,"Don't abandon me."],[4275,4400,"Don't abandon the Jenningses."],[4420,4566,"Hit me, scold me, whatever you want."],[4616,4783,"I really know I was wrong."],[4787,4858,"Channy."],[4862,5033,"Now you're begging for mercy?"],[5037,5125,"Huh?"],[5141,5354,"When you framed Esther back then,"],[5387,5650,"did you ever think you'd be exposed?"],[5800,6000,"What a joke."],[6004,6154,"You used to dote on her so much."],[6250,6337,"Now that you don't love her,"],[6341,6516,"you hurt her without hesitation."],[6583,6654,"Channing,"],[6691,6820,"your love and your hate"],[6850,7083,"are equally disgusting."],[7479,7575,"Ember."],[7679,7741,"Channy,"],[7812,7962,"I really know I was wrong."],[7979,8129,"I'm begging you, please let me go."],[8145,8224,"It's too late."],[8279,8395,"For every bit of harm"],[8400,8595,"you inflicted on Esther,"],[8600,8704,"I'll make you pay tenfold,"],[8711,8840,"a hundredfold!"],[8920,8991,"Ah!"]],"72":[[120,204,"Channing!"],[208,375,"If you insist on beating my daughter,"],[379,537,"you'll have to kill me first!"],[550,637,"Guards!"],[645,783,"Drag this crazy woman out of here!"],[787,925,"Mom!"],[929,1000,"What are you doing?"],[1004,1087,"- Mom! - Let me go!"],[1091,1150,"Ember!"],[1158,1225,"Ember,"],[1304,1483,"everything you've done today,"],[1487,1637,"you brought upon yourself."],[1641,1829,"It's what you owe Esther."],[2000,2066,"Channing!"],[2095,2170,"Stop it!"],[2566,2641,"Esther."],[2658,2775,"I'm avenging you!"],[2795,2845,"Channing,"],[2866,3029,"don't use my name as an excuse"],[3033,3204,"to hurt others."],[3208,3345,"It only makes me despise you."],[3350,3420,"Esther"],[3525,3595,"Everything I've done,"],[3600,3683,"was all for you."],[3758,3866,"How can you say that to me?"],[4245,4341,"Esther,"],[4416,4512,"I know,"],[4520,4679,"my actions have hurt you."],[4683,4829,"But I've gotten revenge."],[4833,4875,"There are no obstacles"],[4879,4975,"between us anymore."],[4979,5087,"Will you please forgive me?"],[5091,5195,"Let's start over."],[5200,5391,"If you don't like Esther Manor,"],[5395,5508,"we can move somewhere else."],[5566,5712,"Anywhere you like,"],[5716,5954,"as long as you come back to me."],[5958,6116,"That's never going to happen."],[6366,6466,"Esther"],[6575,6670,"Was everything I did"],[6675,6779,"Is it all for nothing?"],[7115,7225,"Because,"],[7317,7425,"I'm pregnant."]],"73":[[575,670,"Pregnant?"],[720,800,"Impossible."],[866,945,"Esther,"],[987,1087,"just to trick me,"],[1091,1258,"you'd tell any lie."],[1262,1425,"You know perfectly well you can't have kids."],[1429,1533,"Channing,"],[1537,1670,"you're always like this."],[1675,1745,"You only believe"],[1750,1854,"what you want to believe."],[1858,2008,"In the ten years we were together,"],[2025,2154,"was there a single doctor in Riverton"],[2158,2250,"that I didn't take you to see?"],[2262,2362,"You took so much medicine"],[2395,2500,"and underwent treatment for so long,"],[2504,2662,"but there was never any news."],[2687,2770,"And now you're telling me"],[2775,2879,"that you're pregnant?"],[2916,3012,"That's absolutely impossible!"],[3037,3112,"Channing,"],[3150,3270,"the one who can't have children"],[3308,3387,"is you!"],[3429,3566,"But the doctors clearly told me"],[3595,3725,"that Esther was the one who couldn't conceive."],[3787,3829,"Oh,"],[3862,3945,"could it be that"],[3950,4079,"you have some kind of problem,"],[4112,4275,"keeping Esther from being happy?"],[4316,4400,"You're standing here right now,"],[4404,4529,"putting on a show to fool me."],[4558,4750,"You really won't give up until it's too late!"]],"74":[[25,75,"Look."],[116,170,"Aggh!"],[187,308,"He isn't my son either!"],[675,708,"No!"],[737,829,"That's not true!"],[875,937,"No!"],[1158,1216,"Ember,"],[1279,1345,"tell me right now,"],[1370,1441,"tell me it's not true!"],[1861,2050,"What goes around comes around."],[2066,2220,"Now Channing finally knows"],[2225,2375,"what betrayal tastes like."],[2400,2483,"However,"],[2500,2654,"this has nothing to do with me anymore."],[2787,2895,"Mrs. Shepherd, the way you strategize"],[2916,3020,"and deliver that fatal blow"],[3050,3125,"is truly charming."],[3162,3232,"Well?"],[3266,3400,"Feel better now?"],[3450,3629,"It does feel better than I imagined."],[3670,3737,"Since"],[3800,3900,"you're so happy,"],[3933,4020,"Commander Jennings,"],[4075,4216,"don't you think you should give me,"],[4266,4350,"your number one contributor,"],[4390,4492,"a small reward? - We'll"],[4496,4583,"talk about that at home."],[4679,4850,"That all belongs to me!"],[4854,5012,"If it weren't for Ember,"],[5029,5158,"how could Esther"],[5162,5287,"have married someone else?"],[5412,5475,"Ember!"],[5512,5591,"I'm going to kill you!"],[5620,5712,"You poisonous viper!"],[5750,5912,"You ruined my life!"],[5937,6091,"For the sake of a b**tard,"],[6100,6245,"I drove Esther away!"],[6262,6387,"You b**ch!"]],"75":[[62,154,"You b**ch!"],[195,220,"Bro,"],[245,283,"let go!"],[300,437,"Killing her isn't worth it!"],[854,904,"Ember!"],[925,991,"Zander!"],[1020,1125,"Are you just going to stand by"],[1129,1195,"and watch Ember"],[1212,1325,"get bullied like this?"],[1375,1550,"Her father is no good, either."],[1600,1762,"The whole family is a nest of vipers."],[1783,1908,"How do you expect me to help her?"],[1945,2062,"With the Lewises pulling out,"],[2071,2245,"the debt to the Watsons is crushing me."],[2270,2370,"I can barely save myself right now."],[2379,2454,"The more I help her,"],[2483,2591,"the faster the Jenningses will fall."],[2608,2691,"Commander Jennings,"],[2700,2850,"at least you have some self-awareness."],[2865,2920,"But,"],[2981,3095,"whether you protect her or not,"],[3133,3250,"the Jenningses are going down."],[3408,3445,"Mr. Watson,"],[3462,3529,"didn't you"],[3531,3662,"help the Jenningses out a lot before?"],[3691,3795,"If you don't get your money back now,"],[3820,3950,"are you running a charity?"],[3955,4066,"Of course not."],[4079,4154,"Zander,"],[4166,4279,"seeing the mess you're in,"],[4291,4400,"I won't beat around the bush."],[4416,4520,"The money you owe me,"],[4533,4616,"you must settle it"],[4631,4712,"tonight!"]],"76":[[142,287,"Esther, Esther,"],[298,408,"did you hear all that?"],[410,554,"You can't just stand by and do nothing."],[560,744,"I really have nowhere else to turn."],[748,920,"Please, plead with Carl"],[933,1041,"and help your father, okay?"],[1058,1170,"I have no reason to help you."],[1183,1220,"You"],[1225,1404,"Are you really going to watch"],[1408,1529,"the legacy Grandpa left behind"],[1533,1647,"collapse just like that?"],[1652,1762,"Don't forget,"],[1787,2001,"the blood of the Jenningses runs in you!"],[2116,2204,"The blood of the Jenningses?"],[2241,2295,"Zander,"],[2316,2437,"you killed my mother."],[2458,2550,"And now,"],[2570,2754,"you want to play the loving father?"],[2775,2820,"You!"],[2920,3025,"What are you talking about?"],[3041,3145,"You don't dare admit it?"],[3158,3329,"Back when Catherine forced her way in,"],[3337,3512,"you let her lock the door,"],[3533,3629,"leaving my mother"],[3633,3716,"to miscarry and die."],[3720,3800,"She had no way to call for help,"],[3816,3945,"and two lives were lost."],[3975,4037,"Zander,"],[4050,4137,"if it weren't for you,"],[4145,4320,"Mom wouldn't have died so miserably!"],[4350,4462,"Now that the Jenningses have fallen,"],[4487,4629,"didn't you bring this on yourself?"]],"77":[[16,83,"Zander,"],[133,287,"stop acting like you're so remorseful."],[295,354,"Either"],[379,454,"pay back the money now,"],[470,545,"or"],[566,729,"marry your daughter to me to cover the debt!"],[745,808,"Two choices."],[858,920,"It's up to you."],[1079,1112,"Mr. Watson,"],[1137,1220,"are you serious?"],[1237,1316,"If it really settles the debt,"],[1325,1412,"then I totally agree"],[1454,1562,"to marry Ember off to you!"],[1687,1783,"I won't allow it!"],[1816,1883,"Zander!"],[1925,2041,"Do you have a heart?"],[2058,2245,"He looks even older than you!"],[2287,2370,"How could you bear"],[2395,2437,"to push Ember"],[2466,2570,"into such a living hell?"],[2591,2683,"You jinx,"],[2687,2804,"you have the nerve to object?"],[2816,3000,"If you hadn't been so ruthless back then"],[3029,3141,"and caused Esther's mom's death,"],[3158,3308,"she wouldn't be refusing to help us!"],[3329,3437,"And I wouldn't have"],[3445,3583,"to sell Ember off to pay the debt!"],[3600,3712,"What do you mean I killed her?"],[3750,3783,"Back then,"],[3791,3875,"it was clearly you"],[3900,4066,"who told me to poison her tonic."],[4075,4120,"Now,"],[4129,4291,"you attempt to pin it all on me."],[4325,4375,"I won't take the blame!"],[4391,4437,"That's right."],[4495,4541,"Otherwise,"],[4579,4720,"why would your healthy mother"],[4750,4854,"suddenly die in childbirth?"],[4929,5000,"It was your father!"],[5025,5170,"He wanted her dead!"]],"78":[[54,141,"Zander!"],[350,520,"How could you be so heartless?"],[544,587,"No,"],[630,679,"it's not true."],[684,741,"Esther,"],[791,887,"let me explain!"],[912,983,"Save your excuses"],[1000,1129,"for the judge!"],[1379,1461,"I'm not going!"],[1466,1550,"I'm innocent!"],[1575,1620,"Ember!"],[1633,1700,"My Ember!"],[1704,1750,"Mom!"],[1787,1870,"Let go of me!"],[2091,2104,"Move!"],[2200,2275,"Finally,"],[2341,2458,"we got them all."],[2612,2666,"Honey,"],[2686,2766,"let's go."],[2783,2854,"Mom is waiting for us at home"],[2858,2962,"to plan the wedding!"],[2983,3037,"Okay."],[3041,3145,"Esther!"],[3150,3291,"You destroyed my family,"],[3295,3412,"and you think you can just walk away?"],[3416,3483,"I won't let you!"],[3487,3566,"I'll never let you!"],[3583,3654,"Esther!"],[3704,3841,"Go to hell with me!"]],"79":[[20,154,"Come die with me!"],[291,358,"Look out!"],[900,958,"Are you alright?"],[966,1037,"I'm fine."],[1341,1404,"Esther,"],[1454,1583,"watching my parents go to prison,"],[1608,1733,"watching me lose everything"],[1750,1850,"Are you happy now?"],[1862,1995,"This is all because of you."],[2008,2108,"You're nothing but a jinx."],[2112,2195,"I curse you"],[2200,2320,"to die a horrible death!"],[2337,2429,"Shut your mouth!"],[2445,2500,"Channing,"],[2508,2629,"drop the act."],[2641,2766,"You're just trying to win sympathy"],[2770,2854,"from her, aren't you?"],[2866,3045,"To think you'd go this far for her."],[3104,3204,"You really are a fool."],[3245,3295,"No"],[3320,3420,"It's not like that, Esther."],[3445,3537,"I know you didn't."],[3541,3708,"But even if you did,"],[3716,3837,"I won't turn back."],[3840,3916,"Channing,"],[3937,4054,"it all started with you,"],[4104,4212,"and it ends with you."],[4250,4329,"I won't love you anymore,"],[4366,4454,"and I won't hate you either."],[4483,4595,"Hahaha!"],[4667,4762,"Channing,"],[4783,4904,"did you hear that?"],[4920,5037,"You're pathetic."],[5045,5141,"You're a joke!"],[5158,5295,"You risked your life for her,"],[5300,5387,"was it worth it?"],[5416,5562,"You're just a fool who paved the way"],[5566,5679,"for someone else."],[5691,5754,"Loser!"],[5937,6008,"Trash!"],[6054,6141,"Idiot!"],[6408,6475,"It's okay now."],[6541,6637,"It's all over."],[6670,6737,"Yeah,"],[6841,6916,"it's over."],[7250,7308,"Brother,"],[7354,7466,"you have to look forward."],[7487,7679,"Clinging to a lost love"],[7700,7879,"will only torture you."],[8204,8320,"Esther"],[8358,8550,"has found her own happiness."]],"80":[[12,83,"Esther,"],[104,166,"congratulations!"],[216,379,"You look absolutely stunning today!"],[458,554,"Thank you, Cynnie."],[627,695,"By the way,"],[733,812,"how is your brother's"],[829,912,"injury coming along?"],[927,1008,"Don't worry,"],[1025,1175,"my brother is recovering really well."],[1191,1325,"He'll be back on his feet in two weeks."],[1425,1491,"That's good to hear."],[1604,1637,"Mrs. Shepherd,"],[1640,1725,"the ceremony is about to begin."],[1750,1808,"Go on, go on."],[1821,1954,"I want to see you at your most beautiful!"],[2075,2133,"Let's go."],[2375,2479,"I once thought,"],[2491,2679,"after being betrayed and hurt like that,"],[2737,2945,"I'd never wear a wedding dress again"],[2950,3104,"or walk down this sacred aisle."],[3216,3345,"I even believed"],[3350,3458,"I wouldn't have the strength"],[3462,3595,"to love anyone ever again."],[4200,4379,"Until I met"],[4383,4483,"him."],[5312,5408,"Mr. Carl Lewis,"],[5433,5575,"do you take"],[5595,5720,"Esther"],[5733,5833,"to be your lawfully wedded wife?"],[5837,6070,"For better, for worse,"],[6083,6225,"for richer, for poorer,"],[6241,6408,"in sickness and in health,"],[6412,6604,"will you unreservedly"],[6608,6650,"love her,"],[6662,6754,"be faithful to her,"],[6758,6820,"forever?"],[6858,6925,"I do."],[6941,7070,"Esther,"],[7075,7225,"do you take"],[7229,7345,"Mr. Carl Lewis"],[7350,7462,"Become husband and wife?"],[7466,7529,"I'm willing."]],"81":[[1836,1912,"Miss Jennings,"],[1945,2037,"a gentleman asked me"],[2041,2145,"to give this to you."],[2825,2904,"Who sent it?"],[2979,3079,"An old acquaintance."],[3128,3266,"What kind of old acquaintance"],[3279,3441,"could make my wife look like that?"],[3487,3658,"That's all in the past."],[3700,3775,"Now,"],[3820,3950,"we need to look forward."],[3975,4008,"Alright."],[4066,4129,"Then let's"],[4158,4250,"look forward!"]]}