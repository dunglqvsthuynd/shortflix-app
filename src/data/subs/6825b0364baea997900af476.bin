{"1":[[1172,1363,"Till death do us part."],[1363,1547,"I love you so much!"],[1547,1722,"Ah!"],[1960,2131,"Jesus!"],[2131,2210,"Couldn't you have knocked"],[2210,2289,"her out faster?"],[2289,2423,"You know I hate it when they go"],[2423,2640,"all limp and lifeless."],[2640,2823,"Shit turns me off!"],[2882,3036,"We still need this one alive for"],[3036,3178,"the real ceremony, idiot."],[3365,3486,"She opened up her legs"],[3486,3620,"for me so quick."],[3682,3845,"I didn't even have to ask."],[3845,4079,"She just wanted to be a bride so bad."],[4079,4208,"Fucking pathetic!"],[4208,4383,"They're hardly brides."],[4416,4604,"More like livestock."],[4683,4842,"Is it done then?"],[4934,5055,"Yes, ma'am."],[5538,5647,"Good."],[5647,5876,"We can't afford any more delays."],[5876,6014,"There's only two more weeks"],[6014,6156,"until the Crimson Moon."],[6156,6339,"And we still need one more bride."],[6343,6456,"Yeah, we know."],[6531,6760,"We need our precious baby boy, Nicky."],[6806,6877,"Don't worry,"],[6877,6990,"I got him."],[7115,7223,"New York..."],[7223,7444,"The real ceremony will begin soon."],[8266,8375,"Okay, here."],[8491,8575,"Ha!"],[8587,8712,"I'm off!"],[8712,8854,"See you guys on Friday!"],[8942,9034,"Oh my God!"],[9034,9171,"You made me spill my drink!"],[9171,9267,"You stupid little-"],[9267,9342,"Wait..."],[9342,9463,"Mare!"],[9488,9613,"What a surprise."],[9613,9880,"We haven't seen you in forever!"],[9880,10060,"Yeah, where were you?"],[10060,10193,"Here."],[10193,10326,"At the same coffee shop"],[10326,10506,"you've worked since college?"],[10506,10719,"There's one thing that's different."],[10719,10810,"I'm engaged!"],[10810,10935,"OMG!"],[10935,11073,"No way! Congrats!"],[11073,11319,"Anyway, I will go get you a new latte."],[11319,11428,"I cannot believe"],[11428,11611,"she's still making coffee."],[11611,11853,"Well, if her husband is real,"],[11853,11978,"he's probably some gamer"],[11978,12128,"living in his mom's basement."],[12128,12258,"You really think, Mare"],[12258,12374,"could find someone better?"],[12374,12474,"Oh my God!"],[12474,12683,"You're such a bitch!"],[12758,12841,"Here you go,"],[12841,12967,"one new chai latte."],[12967,13117,"Oh, thanks. Wait,"],[13117,13229,"where's your ring?"],[13229,13400,"You said you were engaged, right?"],[13400,13626,"Or did we hear that wrong?"],[13984,14064,"So, I-"],[14364,14539,"How'd you get this number, Theo?"],[14539,14672,"No, we're not brothers!"],[14672,14727,"Not anymore!"],[14727,14877,"Now, leave me the fuck alone!"],[15181,15327,"You know, if you want to do a little"],[15327,15507,"play run of our honeymoon"],[15507,15586,"you shouldn't let the bride"],[15586,15669,"wake up alone."],[16024,16128,"Um..."],[16245,16408,"We'll figure it out, okay?"],[16466,16612,"We always do."],[16691,16858,"You've done so much for me, Mare."],[16912,17058,"And I couldn't even get you a ring."],[17058,17162,"I don't want a ring."],[17162,17425,"I just want to be married to you."],[17425,17596,"I want to be a part of your family."],[17688,17867,"Mare, you know how I feel about them,"],[17867,17917,"babe. - But,"],[17917,18051,"don't you want them to be a part of this?"],[18051,18118,"Mare, I-"],[18118,18214,"I want to be your wife"],[18214,18289,"more than anything, but"],[18289,18368,"Can you just-"],[18368,18526,"I want your family to accept me"],[18526,18610,"as a Thornwood-"],[18610,18718,"Mare, just stop!"],[18839,18935,"I'm sorry."],[18935,19027,"I'm sorry, I didn't mean to yell."],[19060,19131,"I..."],[19152,19373,"I know your family is a..."],[19427,19665,"sensitive subject."],[19782,19986,"I've just never been a part of one."],[20040,20216,"We can be a family."],[20245,20362,"You and me."],[21721,21963,"My name is Gloria Thornwood."],[22051,22230,"I'm Nick's mother."]],"2":[[37,400,"Wow, so Nick has older brothers."],[400,533,"He never told me that."],[533,667,"Oh, they don't have the"],[667,867,"best relationship, sadly."],[867,1009,"Even so, the Thornwood family"],[1009,1121,"still misses Nick."],[1121,1267,"The Thornwood family."],[1267,1476,"Sounds like royalty."],[1476,1630,"I had no idea about any of this."],[1630,1789,"Nick never mentioned it."],[1789,1889,"We've been living"],[1889,2010,"paycheck to paycheck"],[2010,2114,"since we met."],[2139,2314,"We can't even afford a real wedding."],[2314,2402,"Let's have the wedding"],[2402,2560,"at the family estate."],[2560,2765,"It will be very small and intimate,"],[2765,2932,"and I'll take care of all the details."],[2932,3053,"And you just relax."],[3053,3178,"Mom?"],[3261,3411,"What... what are you doing here?"],[3411,3532,"How did you find me?"],[3532,3703,"Is that any way to greet your mother"],[3703,3903,"after all these years?"],[3945,4045,"I..."],[4045,4250,"Please forgive Nick."],[4450,4650,"He's just been a little stressed lately."],[4879,5038,"Family is meant"],[5038,5196,"to take care of each other"],[5196,5380,"during times of need."],[5417,5584,"Surely you haven't forgotten that."],[5584,5734,"Yeah! Your mom said that"],[5734,5926,"we can get married at your house."],[6139,6360,"It's settled then."],[6915,7102,"Your mom is so generous."],[7102,7294,"And I can't wait to meet your brothers!"],[7382,7461,"Oh my God!"],[7499,7645,"Is that your house?"],[7736,7786,"Yeah."],[7841,7941,"Yeah, this is-"],[7941,8078,"This is home, all right."],[8550,8687,"Wow!"],[8762,9034,"Welcome home, my darlings!"],[9526,9642,"Servants."]],"3":[[934,1130,"Ah, I thought you said this would be"],[1130,1347,"small and intimate."],[1347,1443,"Madam,"],[1443,1597,"apologies for the slight delay,"],[1597,1818,"we are currently short a maid."],[1872,2143,"But preparations will proceed as planned."],[2227,2352,"One of our new girls,"],[2352,2469,"suddenly had to leave."],[2489,2565,"But"],[2565,2756,"don't worry, you're pretty head about it."],[2911,3174,"Uh- is that one of your ancestors?"],[3332,3503,"You look just like them."],[3503,3570,"Yeah."],[3632,3778,"Yeah, the Thornwood genes"],[3778,3978,"are strong, you know."],[4054,4095,"Ah!"],[4095,4245,"There you two are."],[4245,4450,"Nice of you to finally show up."],[4491,4683,"Where are your manners?"],[4713,4808,"Mare,"],[4808,4979,"these are Nick's older brothers,"],[4979,5130,"Rhys and Theo."],[5171,5334,"And you must be our new"],[5334,5484,"sister-in-law."],[5484,5722,"Well, I guess by tomorrow I will be!"],[5722,5880,"But you can just call me, Mare."],[5880,6068,"Look at you."],[6114,6256,"Wow, you're too gorgeous"],[6256,6406,"for my boring little brother, Mare!"],[6406,6527,"Maybe you and I should run off"],[6527,6644,"together instead."],[6827,6986,"You know, you have beautiful hair."],[6990,7107,"Watch it, Theo!"],[7107,7307,"Yeah, it's good to see you too, Nicky boy."],[7311,7449,"Still an insecure little brat?"],[7449,7611,"Still an insufferable dick"],[7611,7707,"with middle child syndrome?"],[7707,7782,"Oh..."],[7899,8024,"Welcome to the family."],[8083,8241,"We're going to take great care of you."],[8241,8450,"All right, boys, let's not"],[8450,8650,"overwhelm her all at once."],[8717,8812,"Come, dear."],[8812,8996,"Let me show you around."],[9346,9496,"She seems like a sweetie."],[9496,9626,"You know, it really is too bad-"],[9626,9747,"Shut up!"],[9768,9918,"You knew this was coming, Nick."],[9980,10189,"It'd be a lot easier if you would quit"],[10189,10360,"running and accept it."],[10447,10577,"Get out of my way."]],"4":[[312,575,"Family looks after one another."],[575,809,"You're part of our family too."],[1422,1568,"Hey, where've you been-"],[1835,1918,"Something wrong?"],[1931,2047,"Nothing."],[2047,2243,"Okay, I need to ask you something."],[2243,2318,"Why didn't you"],[2318,2510,"tell me about your family?"],[2590,2752,"I mean, I thought at first was because"],[2752,3003,"you had a crazy childhood."],[3003,3194,"But I'm a foster kid,"],[3194,3411,"and you're basically royalty."],[3474,3699,"So what, were you ashamed of me?"],[3699,3732,"Or-"],[3732,3862,"Baby, no!"],[3862,4099,"My family is different, Mare."],[4124,4283,"It's okay."],[4300,4358,"I get it."],[4358,4533,"Some families are"],[4637,4854,"fucked up in their own ways."],[5234,5413,"It's okay if you're overwhelmed."],[5476,5584,"I am too."],[5584,5680,"We've been talking"],[5680,5860,"about getting married for months,"],[5860,6010,"and now we're finally doing it."],[6081,6147,"I just..."],[6147,6222,"I've wanted to be"],[6222,6389,"a part of a family forever."],[6406,6606,"And I finally can."],[6648,6756,"I'm just excited."],[6835,7023,"I love you,"],[7023,7136,"and you know I'd do"],[7136,7278,"anything to be with you."],[7440,7570,"I love you too."]],"5":[[241,396,"I used to help Mrs. Thornwood"],[396,592,"get ready in the mornings, with Lily."],[592,813,"Is that the maid who Gloria said left?"],[863,992,"Did she get a new job or?"],[992,1159,"They said she packed her things"],[1159,1255,"and left in the night."],[1338,1484,"But I don't know."],[1926,2035,"Her name is Lily."],[3032,3161,"The last time I saw her,"],[3161,3319,"she was so excited to tell me"],[3319,3449,"some big secret."],[3524,3603,"And then the next day,"],[3603,3774,"she was just gone."],[3858,4024,"What do you think happened to her?"],[4099,4225,"I think-"],[4537,4642,"Rhys!"],[4642,4758,"I wasn't expecting to see you"],[4758,4863,"until the ceremony."],[4863,5000,"I'm just going around making sure"],[5000,5201,"everyone's on schedule."],[5626,5780,"Something on your mind, Sonya?"],[5780,5943,"No, Mr. Thornwood."],[5943,6039,"I was just-"],[6039,6206,"Making idle chatter with our guest?"],[6206,6402,"No, sir, I wouldn't."],[6531,6656,"You're right."],[6706,6840,"You wouldn't."],[7044,7232,"Loyalty is everything"],[7232,7386,"to our family."],[7449,7561,"You understand?"],[7661,7803,"Yes, sir."],[7803,7895,"Of course."],[7895,7991,"Good."],[8028,8162,"Now get back to work."],[8199,8333,"We have a wedding to prepare for."],[9209,9380,"See you at the altar."]],"6":[[542,759,"I've been dreaming of this day"],[759,955,"for a long, long time, Nick."],[955,1046,"Your brothers said"],[1046,1263,"you'd never come back."],[1322,1393,"But I always knew"],[1393,1559,"we'd be together again."],[1559,1768,"This is for the good of our family."],[1768,1889,"I never asked to be part of this"],[1889,1981,"fucked up family."],[1981,2122,"There's no more time for your"],[2122,2285,"childish tantrums."],[2285,2448,"The Crimson Moon is tonight."],[2673,2798,"I vow to love you through all"],[2798,2948,"the good times and..."],[3440,3545,"I need a place"],[3545,3749,"to practice my wedding vows."],[4333,4571,"Finally, some peace and quiet."],[4571,4633,"Uh!"],[4729,4913,"Smells awful in here."],[5413,5651,"All right, just practice and leave."],[5722,5885,"Nick,"],[5885,6085,"I have loved you since the moment"],[6085,6185,"I met you."],[6235,6352,"I know it hasn't been that long,"],[6352,6460,"and some people might think"],[6460,6577,"it's dumb to marry someone you’ve"],[6577,6715,"known less than a year, but"],[6794,6965,"I know you and I are meant to be."],[7032,7161,"I vow to love you through all"],[7161,7282,"the good times,"],[7282,7399,"and the bad."],[7399,7665,"And I can't wait to finally call myself"],[7665,7857,"Mrs. Mary Thornwood."],[8078,8391,"What the hell?"],[8546,8662,"Oh my God!"],[8875,8983,"Okay."],[8983,9121,"Not real!"],[9171,9367,"Aah!"]],"7":[[191,296,"Oh my God! Sonya,"],[296,437,"there's someone in..."],[437,517,"in there- - Ms. Mary,"],[517,567,"what's wrong?"],[567,658,"Someone in the stables,"],[658,763,"I... I think it's Lily. And she's..."],[763,842,"She's dead."],[842,967,"Lily?"],[967,1109,"She's... she's under the hay"],[1109,1288,"and she's wearing a wedding dress."],[1288,1384,"Oh my God!"],[1384,1480,"I think it's the same wedding"],[1480,1564,"dress as me! And I thought"],[1564,1714,"she left the estate."],[1714,1910,"We need to tell someone now, okay?"],[1910,2006,"I need to tell Nick."],[2006,2097,"I need to cancel the wedding."],[2097,2168,"No, no!"],[2210,2348,"Listen to me, you cannot"],[2348,2519,"tell anyone what you saw."],[2540,2648,"Do you understand?"],[2648,2719,"What?"],[2719,2948,"The Thornwoods cannot be trusted."],[2948,3073,"What are you talking about?"],[3073,3249,"If you cancel the wedding,"],[3249,3374,"they'll know."],[3407,3549,"They'll know that, you know."],[3549,3641,"Know what?"],[3641,3757,"What are you talking about?"],[3757,3887,"There isn't any time."],[3887,4049,"Right now you need to find a way"],[4049,4187,"to get out of here, before they-"],[4187,4329,"Ah! There she is."],[4433,4558,"Here's our beautiful bride."],[4579,4750,"I've been looking all over for you, Mare!"],[4750,4904,"The ceremony is about to begin,"],[4904,5013,"and I don't want you to have to"],[5013,5238,"walk down the aisle alone, so"],[5422,5509,"I would be honored"],[5509,5659,"if you let me escort you."],[5739,5851,"Thanks, Theo, but-"],[5851,5968,"I insist."],[6085,6172,"I mean, we're family"],[6172,6306,"after all, aren't we?"],[6381,6460,"Hm."],[7870,8016,"Good luck, sweetheart."],[8504,8616,"Dearly beloved,"],[8687,8825,"we are gathered here today"],[8825,9113,"to join this man and this woman"],[9113,9346,"in holy matrimony."],[9346,9488,"Nicholas Thornwood,"],[9488,9688,"do you take Mary Mitchell"],[9688,9951,"to be your lawfully wedded wife?"],[10185,10377,"You know, don't you?"],[10602,10881,"Begin your vows, Master Nicholas."],[11657,11774,"Run!"]],"8":[[12,91,"Run!"],[258,333,"Take him!"],[513,642,"She's headed for the gates."],[642,754,"Mare! Go!"],[754,934,"I love it when they run."],[3111,3290,"Lock the house down now!"],[3290,3420,"Seal every entrance."],[3420,3578,"Do not let her leave the estate"],[3578,3753,"until the ceremony is complete."],[3799,3895,"Oh shit! This can’t be real!"],[3895,3974,"This can't be real!"],[4120,4212,"Aah!"]],"9":[[145,212,"What the-"],[262,358,"Sonya?"],[358,475,"What... what?"],[475,642,"Quiet! They'll hear you."],[642,859,"What the hell is happening?"],[859,1001,"We don't have much time,"],[1001,1205,"but for starters, I'm not a maid."],[1205,1263,"What?"],[1263,1376,"I'm a private investigator."],[1376,1543,"I've been undercover here for months."],[1543,1743,"I was hired by the family of a young girl"],[1743,1843,"who went missing last year."],[1843,2035,"Last seen with this man."],[2072,2256,"Theo, wh... what..."],[2256,2410,"So the whole family is in on this?"],[2431,2610,"Something evil"],[2610,2761,"is happening here, Mare."],[2815,2994,"You are lucky to have escaped the altar."],[3061,3190,"I got these from your room."],[3386,3599,"When you find a way out of the estate,"],[3599,3712,"call for help."],[3712,3874,"They sealed off all the exits."],[3874,3953,"What about you?"],[3953,4149,"I still have to gather all of my evidence"],[4149,4300,"on the family's crimes before"],[4300,4383,"I can leave."],[4383,4512,"I'm not leaving Nick, okay?"],[4512,4646,"What if his psycho family"],[4646,4746,"does something to him?"],[4771,4938,"You don't have a choice."],[4938,5096,"If they catch you, you'll end up"],[5096,5284,"just like Lily and the others."],[5376,5472,"Others? Wait-"],[5472,5593,"It doesn't matter."],[5593,5764,"I'm not leaving Nick!"],[6006,6068,"Fine."],[6147,6214,"Listen,"],[6214,6468,"this will take you to the servants tunnel."],[6468,6644,"It takes you through the whole estate."],[6644,6706,"Aah!"],[6790,6931,"When you reach Nick,"],[6986,7077,"leave."],[7077,7269,"You just have to listen to me, okay?"],[7757,7916,"You'll be okay."],[8028,8208,"I'll lead them away!"],[8500,8800,"Holy shit, holy shit, holy shit. Oh my God!"]],"10":[[1889,2056,"Fuck, fuck, fuck."],[2873,3028,"We need to find her soon."],[3028,3228,"The Crimson Moon is tonight."],[3315,3474,"Don't hurt yourself, Nicky."],[3474,3611,"Untie me, asshole."],[3611,3766,"No can do, baby bro,"],[3766,3945,"unless you want to tell us where your"],[3945,4074,"little runaway bride is hiding-"],[4074,4141,"Fuck you!"],[4141,4258,"Come on, what are you so goddamn"],[4258,4362,"attached for? Huh?"],[4362,4466,"You can go play poor with"],[4466,4608,"any other girl you want."],[4846,5034,"What's so special about her, huh?"],[5138,5372,"She got a magic pussy or something?"],[5605,5655,"It's too bad"],[5655,5793,"I didn't get a taste for myself."],[6064,6135,"You little fuck-"],[6135,6281,"That's enough, Theo."],[6427,6544,"Go cool off."],[6777,6952,"You can't force her into this."],[6952,7011,"Oh!"],[7011,7190,"Nicholas."],[7190,7428,"You still think this is about choice?"],[7469,7778,"Mare belongs to the Thornwood's now."],[7807,8033,"We're giving her a higher purpose."],[8033,8208,"More than someone like her could have"],[8208,8379,"ever accomplished in her life."],[8425,8625,"You'll understand soon enough."],[8692,8879,"She'll never go through with this."],[8879,9017,"Not after she knows the truth"],[9017,9079,"about us."],[9180,9384,"Knowing the truth never helped"],[9384,9513,"any of the others, did it?"]],"11":[[0,50,"Mom, please."],[50,166,"This isn't right."],[166,283,"It's not about what's right."],[321,529,"It's about preserving our family."],[604,713,"After all these years, you should"],[713,825,"know that by now."],[825,905,"Precisely."],[905,1184,"And after tonight, all our work"],[1184,1317,"will be worth it."],[1451,1722,"Don't you want to be free, Nick?"],[1722,1889,"No! No,"],[1889,2077,"not if it means giving up Mare!"],[2077,2264,"You really do love her, don't you?"],[2369,2598,"My poor, sweet boy."],[2598,2815,"I promise it'll be painless for her then."],[3144,3311,"We've lost the signal"],[3311,3470,"to her tracker, madam."],[3511,3678,"She may have found a way into"],[3678,3870,"the underground passages."],[3937,4074,"Only the servants are supposed"],[4074,4220,"to know about those."],[4320,4542,"That maid, Sonya!"],[4542,4813,"I always had my suspicions about her."],[4854,5050,"Rhys, come with me."],[5050,5267,"Theo, go find Mare."],[5317,5522,"And remember, we need her alive!"],[5559,5805,"If you see that maid, eliminate her."],[5976,6168,"Continue preparing for the ceremony"],[6168,6239,"this evening."],[6239,6356,"We cannot afford to waste"],[6356,6489,"any more time."],[6489,6752,"The Crimson Moon is almost here."],[7057,7178,"Nick,"],[7178,7307,"I'll be back soon."],[7411,7582,"Please don't leave another mess"],[7582,7761,"for mommy to clean up."]],"12":[[1401,1564,"What the hell is going on?"],[3053,3123,"Hey!"],[5150,5280,"Come on, come on, come on, Mare!"],[5280,5363,"Pick up!"],[5718,5876,"Fuck! Fuck! Fuck!"],[5876,5968,"What was that?"],[6014,6089,"Over there!"],[6177,6272,"It's the bride!"],[6272,6373,"After her!"]],"13":[[759,896,"After them!"],[3136,3211,"Gone!"],[3211,3328,"How could this happen?"],[3328,3445,"He was secure!"],[3661,3803,"We underestimated him, mother."],[3866,3941,"He's obviously learned"],[3941,4004,"some new tricks"],[4004,4154,"while he's been away all these years."],[4237,4416,"Well, he's still my baby."],[4471,4621,"I can't lose him, Rhys!"],[4642,4779,"You won't."],[4779,4867,"I'll make sure of it."],[4917,5030,"After tonight,"],[5067,5217,"it'll all be over, mother."],[5442,5522,"Not now!"],[5647,5705,"Shh!"],[5814,5897,"Someone's here!"]],"14":[[2206,2302,"Hello?"],[2318,2410,"Mare!"],[2410,2506,"Oh, thank God!"],[2506,2594,"Are you okay?"],[2610,2865,"Okay? No, Nick, I'm not okay!"],[2865,2998,"What the hell is happening?"],[2998,3078,"Why are there robed"],[3078,3186,"psychos chasing after me?"],[3186,3307,"And what is this curse?"],[3307,3461,"Meet me in the gardens"],[3461,3516,"by the fountain."],[3516,3628,"I'll explain everything,"],[3628,3716,"I promise!"],[3774,3841,"Nick."],[3883,3953,"I love you!"],[4083,4170,"I love you too."],[4479,4779,"Well, isn't this touching!"],[4808,5109,"Star crossed lovers,"],[5163,5380,"in a house of horrors."],[5380,5643,"Mare! Mare, what's going on?"],[5643,5801,"Ah, you should've ran away with me"],[5801,5947,"when I gave you the chance, Mare."],[6001,6114,"Stay the hell away from me."],[6114,6231,"Oh, come on,"],[6231,6414,"you don't even know the rules of the game"],[6414,6506,"that we're playing yet."],[6548,6656,"But I'll tell you what."],[6685,6798,"Since I'm feeling generous,"],[6798,6969,"I'm going to give you a five second"],[6969,7069,"head start!"]],"15":[[70,162,"Five!"],[342,446,"Four!"],[446,600,"Thr- Whoa!"],[600,767,"Okay! Playing dirty."],[767,950,"I like it, Mare!"],[980,1042,"Whoa!"],[1084,1163,"Mare?"],[1226,1301,"Mare!"],[1368,1572,"God fucking damn it!"],[1918,2097,"Running won't save you!"],[2243,2494,"It's too late to leave our family now!"],[3328,3403,"Stay back!"],[3432,3545,"Ah!"],[3591,3749,"Going on offense now, huh?"],[3803,3883,"Good!"],[3883,4091,"It's more fun when a girl fights back."],[4129,4208,"Argh!"],[4354,4517,"You got a mean swing, sweetie."],[4517,4654,"I'll give you that."],[4746,4817,"Shit!"],[4971,5117,"See, now you made me ruin"],[5117,5242,"your pretty dress."],[5259,5351,"Wonder what it would look like"],[5351,5451,"covered in red!"]],"16":[[250,383,"Stay back!"],[383,608,"Oh, but we're having so much fun!"],[608,738,"You're insane, okay?"],[738,846,"I know you killed Lily!"],[846,921,"You and Rhys!"],[921,1055,"Ah, Lily."],[1055,1238,"Yeah, it's too bad, really."],[1259,1368,"She was a pretty thing."],[1368,1505,"And such a good lay!"],[1906,1981,"All right."],[1981,2122,"No more playing around."],[2544,2727,"You don't have to do this, okay?"],[2727,2902,"It's not what Nick would want!"],[2902,3007,"It's not what Nick would want."],[3007,3128,"You think you're the first bride"],[3128,3290,"my little brother fell for?"],[3365,3486,"One thing about Nicky,"],[3486,3724,"he falls in love, oh so easily."],[3762,3912,"I know Nick, okay?"],[3912,4049,"He wouldn't do any of this."],[4049,4154,"No no no, no, not,"],[4154,4262,"not by his own choice."],[4262,4433,"You guys forced him to!"],[4571,4713,"I know he loves me."],[4713,4788,"Eh."],[4813,5000,"He'll get over it."],[5000,5138,"It's nothing personal, Mare,"],[5138,5296,"but it's either you or us."],[5296,5417,"And in the Thornwood family,"],[5417,5605,"we always come out on top!"],[5734,5851,"Get off me!"],[6126,6227,"No!"],[6377,6506,"Don't worry, Mare,"],[6506,6652,"it's normal to get choked up"],[6652,6794,"on your wedding day."],[6794,6894,"No, no!"]],"17":[[596,717,"That was for Lily!"],[1046,1184,"You're just full of surprises,"],[1184,1263,"aren't you?"],[1301,1518,"Still trying to act tough?"],[1551,1672,"You rich folk all think"],[1672,1751,"you're invincible,"],[1751,1943,"but you're just like the rest of us."],[1956,2039,"Breakable!"],[2310,2502,"Trust me,"],[2502,2694,"I'm nothing like you."],[2973,3153,"You have no idea"],[3153,3274,"what you're in for, Mare."],[3649,3791,"When the Crimson Moon is here,"],[3791,3908,"you're done!"],[4020,4154,"Not even death can keep us"],[4154,4304,"from rising again."],[4304,4429,"Crimson moon?"],[4429,4508,"What?"],[4508,4583,"Argh!"],[4583,4654,"No!"],[5192,5259,"Shit!"],[5463,5543,"Let's go!"]],"18":[[934,1051,"Huh!"],[1109,1292,"The Thornwoods are onto me, now."],[1292,1451,"We need to find a way out."],[1451,1643,"I'm not leaving without Nick."],[1643,1797,"If you haven't found Nick by now,"],[1797,1943,"he doesn't want to be found."],[1943,2014,"Leave him!"],[2014,2127,"He's a Thornwood!"],[2127,2277,"He's not like them, okay?"],[2277,2335,"He's different."],[2335,2485,"You don't know him, Sonya!"],[2485,2523,"No!"],[2523,2702,"But I know his family."],[2702,2819,"This goes deeper"],[2819,2902,"than you could even"],[2902,3003,"imagine, Mare."],[3023,3115,"It took me months"],[3115,3199,"to get the evidence,"],[3199,3403,"but their crimes go back the last century."],[3470,3549,"What?"],[3549,3632,"Wait... what?"],[3632,3816,"So they've been doing this for years?"],[3816,3949,"They've been killing off"],[3949,4116,"brides for years?"],[4133,4275,"You get it now."],[4275,4575,"The whole family tree is rotten."],[4637,4767,"You're better off forgetting you ever-"],[4859,4934,"Sonya?"]],"19":[[0,129,"You're better off forgetting you ever-"],[221,308,"Sonya!"],[642,742,"Wait, wait!"],[742,888,"Hey, hey! It's okay! It's okay!"],[1051,1109,"Oh my God!"],[1434,1551,"Never liked that maid."],[1668,1818,"She asked too many questions."],[2006,2097,"Rhys, just..."],[2143,2235,"Please!"],[2298,2506,"Begging won't help."],[2506,2777,"See, you've spilt our blood."],[2886,3015,"Theo,"],[3015,3215,"he was a fool,"],[3215,3424,"but he was still my brother."],[3749,3858,"You really thought"],[3858,4049,"you could sneak around our house,"],[4099,4233,"without us knowing?"]],"20":[[54,200,"I hope you didn't think"],[200,329,"our mother would give you an actual"],[329,483,"family heirloom."],[567,721,"It's a tracking device."],[792,909,"You're sick!"],[963,1030,"Yeah."],[1084,1192,"Maybe so."],[1401,1689,"But I do what needs to be done,"],[1689,2027,"for the sake of my family."],[2052,2177,"Someone like you"],[2264,2410,"wouldn't understand."],[2456,2648,"No friends,"],[2648,2798,"no family."],[2952,3207,"You're nothing."],[3303,3478,"Just like the rest of them."],[3636,3778,"And I'm sure no one's going to miss"],[3778,3878,"you when you're gone."],[4008,4145,"Don't worry,"],[4145,4279,"this won't kill you."],[4320,4441,"We still need you breathing"],[4441,4604,"when the Crimson Moon arrives."]],"21":[[37,104,"Don't worry,"],[104,241,"this won't kill you."],[362,404,"Come on!"],[404,462,"It's okay."],[462,554,"You're going to be okay!"],[571,750,"God you little-"],[996,1059,"Ahh!"],[1117,1230,"Oh my God! Oh my God, oh my God!"],[1230,1284,"Holy shit!"],[1284,1409,"The basement!"],[1647,1814,"This isn't over!"],[1814,2022,"You can't hide forever!"],[2540,2660,"Servants have recovered"],[2660,2869,"Master Theodore's body, madam."],[2927,3069,"I see."],[3178,3286,"What about Rhys?"],[3286,3482,"He's gone after the bride."],[3924,4091,"We're running out of time."],[4396,4696,"If Rhys doesn't find her, then I will."],[4896,5130,"That little wretch took my journal."],[5130,5334,"What about Master Nicholas, madam?"],[5597,5772,"Nick will be fine."],[5847,5951,"When the time comes,"],[5951,6076,"he'll do the right thing."],[6076,6218,"Are you certain?"],[6327,6506,"Of course."],[6552,6852,"Mother always knows best."]],"22":[[75,171,"It's okay, it's okay!"],[171,271,"Just stay with me."],[271,358,"Okay?"],[529,633,"It's okay!"],[900,1051,"Stay with me, it's okay! It's okay!"],[1297,1343,"Sonya?"],[1343,1547,"Ok. Stay with me, okay?"],[1547,1664,"It's gonna be okay."],[1664,1818,"We're gonna get through this, okay?"],[1818,1931,"Mare."],[1989,2093,"E... Evidence,"],[2093,2318,"in the basement."],[2318,2435,"It's in a bag,"],[2435,2606,"in the wall."],[2606,2761,"Take it, and go!"],[2761,2994,"I'm not leaving you here, okay?"],[2994,3057,"Come on."],[3057,3211,"You have to."],[3365,3478,"No."],[3566,3670,"Survive."],[3703,3908,"End this family!"],[3962,4087,"Please, promise me!"],[4504,4654,"I promise."]],"23":[[1672,1835,"Fuck!"],[2131,2260,"Ah!"],[2281,2410,"Agh!"],[2431,2560,"Ah!"],[2882,2990,"Holy shit, holy shit!"],[4500,4654,"This ends tonight."]],"24":[[371,671,"Where is this, Sonya?"],[1084,1201,"The wall?"]],"25":[[667,804,"What?"],[1622,1830,"Bride number four."],[1830,2002,"Sophia."],[2118,2302,"Theo nearly ruined the ceremony,"],[2302,2556,"but still we succeeded."],[2623,2756,"Her sacrifice will sustain us"],[2756,3057,"until the next Crimson Moon."],[3253,3403,"This can't be real."],[3607,3770,"Bride number eight."],[3862,4058,"Abigail."],[4058,4237,"She put up quite a fight, but"],[4237,4537,"still the ceremony proceeded as usual."],[4579,4683,"Nicholas resists,"],[4683,4859,"as always."],[4859,5130,"He's still so young and rebellious."],[5130,5409,"Love is a luxury we cannot afford."],[5409,5618,"He'll learn that soon enough."],[5801,6056,"So it wasn't his ancestors."],[6172,6381,"It was Nick."],[6381,6681,"His brothers, his mom."],[6765,6961,"All of them."]],"26":[[16,316,"So it wasn't his ancestors."],[387,596,"It was Nick."],[596,896,"His brothers, his mom."],[980,1176,"All of them."],[1234,1426,"Holy!"],[1901,2072,"She must have gone down here!"],[4116,4250,"Meet me in the gardens"],[4250,4337,"by the fountain."],[4375,4458,"I love you."]],"27":[[25,141,"Mare!"],[1138,1251,"I know, Nick."],[1297,1438,"The portrait in the foyer."],[1597,1810,"That was you, wasn't it?"],[1810,1956,"Wasn't your ancestor?"],[2164,2327,"Yeah,"],[2327,2406,"it was me."],[2577,2702,"I was so young"],[2702,2873,"when the curse started, so..."],[2940,3032,"I don't remember much of"],[3032,3157,"how it happened, but"],[3182,3290,"at a certain point,"],[3290,3415,"I just stopped getting older."],[3545,3678,"My family and I have been alive"],[3678,3820,"for over 100 years."],[3895,4004,"Why didn't you tell me?"],[4004,4062,"Wha.."],[4062,4245,"I, I thought I could protect you."],[4245,4471,"I, I'd spent so long following this"],[4471,4612,"fucked up tradition."],[4683,4859,"All the suffering, all the betrayal,"],[4859,5000,"I was sick of it!"],[5046,5159,"Look, I just wanted to know"],[5159,5301,"what it was like to be normal."],[5476,5663,"To just be with you."]],"28":[[54,283,"I should've known better, I..."],[283,350,"I'm sorry."],[350,479,"I, I never should have gotten you"],[479,575,"into this, Mare."],[608,734,"Twelve brides"],[734,909,"have been sacrificed so far."],[1013,1092,"We need one more"],[1092,1184,"to pay back our debt."],[1184,1359,"If a Thornwood bride isn't"],[1359,1514,"sacrificed at the altar,"],[1514,1643,"by the time the Crimson Moon"],[1643,1860,"passes, my whole family dies."],[1897,2031,"And I know that they're crazy,"],[2031,2231,"but I still love them, Mare!"],[2302,2423,"I don't want them to die."],[2423,2531,"So I'm the last one?"],[2640,2769,"The last bride?"],[2769,2915,"And, and you can't break the curse"],[2915,3032,"without killing me?"],[3032,3082,"No!"],[3123,3307,"No, baby. No!"],[3307,3474,"I will find another way."],[3474,3599,"All right, I'll figure this out."],[3599,3795,"I, I won't let anybody take you from me."],[4533,4646,"It'll be okay."],[4742,4796,"Okay,"],[4796,4900,"after this is over,"],[4900,5088,"I'll take you far away from here."],[5201,5326,"We don't ever have to come back,"],[5326,5372,"alright?"],[5372,5547,"It'll just be me and you."],[5572,5668,"Forever."],[5805,5926,"Okay?"],[6118,6277,"I just need to find"],[6335,6489,"someone else to take your place."],[6694,6777,"What?"]],"29":[[12,191,"I just need to find"],[225,400,"someone else to take your place."],[496,596,"What?"],[663,792,"I'll find another girl,"],[792,934,"a maid or something."],[1009,1213,"She'll get sacrificed instead,"],[1213,1326,"and then everything will be okay."],[1326,1626,"So your solution is more killing?"],[1659,1910,"Baby, it's the only way."],[1910,2089,"How many others, Nick?"],[2089,2189,"How many other brides"],[2189,2302,"did you marry before me"],[2302,2464,"before they were sacrificed too?"],[3036,3165,"Five."],[3503,3599,"Five."],[3699,3895,"Did you tell them you love them too?"],[3912,4016,"Did you tell them that"],[4016,4154,"you were going to protect them"],[4154,4279,"before you sacrificed them?"],[4279,4404,"Before you killed them?"],[4404,4554,"It's different with you, baby."],[4554,4625,"Oh!"],[4625,4733,"You're different."],[4733,4921,"And you're exactly like your family."],[4971,5167,"Mare! Wait!"],[5167,5334,"Mare, please don't leave!"],[5334,5480,"I love you!"],[5701,5893,"I've warned you before, Nick."],[6010,6106,"You should’ve never let your"],[6106,6302,"feelings get involved in this mess."],[6352,6610,"It isn't wrong to fall in love, Rhys."],[6656,6802,"I used to think the same thing."],[7540,7741,"No more games."]],"30":[[1313,1547,"There's gotta be a way out of this!"],[1701,1893,"There's got to be something in this."],[2039,2152,"Eliza."],[2152,2452,"She's such a kind young woman."],[2515,2702,"It pained me to see her die,"],[2702,2944,"but it needed to be done."],[3015,3144,"I feel mostly"],[3144,3357,"for my dear, Rhys."],[3395,3578,"My eldest boy."],[3632,3762,"He never would have agreed"],[3762,3937,"if I didn't forge those letters."],[4016,4262,"But our survival had to come first."],[4262,4491,"Must always come first."],[4491,4637,"Eliza was"],[4637,4829,"a necessary sacrifice."],[4829,5071,"And she won't be the last."],[5180,5426,"So she tricked Rhys."],[6206,6406,"The Crimson Moon."],[7436,7532,"Found you."]],"31":[[1922,2060,"You aren't the first bride who's"],[2060,2181,"tried to run."],[2327,2419,"You know, they always think"],[2419,2565,"they can win."],[2627,2798,"But they never do."],[2857,2927,"But I'm the first to know"],[2927,3073,"your dirty little secret."],[3357,3545,"So you figured it out by now?"],[3682,3853,"My family's curse."],[3908,4087,"My mother's bargain."],[4279,4621,"Nick was, uh... still a child."],[4746,4863,"Theo was"],[4863,5046,"conscious for most of it, but..."],[5259,5417,"I still remember."],[5622,5726,"I remember the fever"],[5726,5880,"burning in my bones."],[5922,6056,"The shivers."],[6056,6181,"The darkness."],[6285,6548,"My father had abandoned us,"],[6548,6710,"leaving nothing but a letter"],[6710,6902,"and an empty family safe."],[7111,7303,"We were going to die."],[7474,7590,"All of us."]],"32":[[83,179,"But my mother"],[179,404,"wasn't going to let that happen."],[404,671,"And so, she did the unthinkable."],[734,829,"To sit in solemn silence."],[829,967,"She made a bargain."],[967,1134,"In a pestilential prison, with"],[1134,1226,"a lifelong lock."],[1226,1334,"Awaiting the sensation"],[1334,1463,"of a short sharp shock!"],[1618,1760,"A deal with the devil."],[1801,1997,"A deal that cannot be undone."],[2068,2223,"Believe me, we've tried."],[2335,2544,"13 Thornwood brides."],[2598,2857,"One upon each Crimson Moon."],[2944,3274,"A Thornwood bride must be sacrificed."],[3378,3603,"That is the price we must pay"],[3603,3791,"to keep our lives."],[3883,4095,"So you see, Mare."],[4095,4233,"You aren't the first bride"],[4233,4425,"I've had to hunt down."],[4446,4629,"But thankfully,"],[4729,4875,"you'll be the last."],[4975,5146,"All these years."],[5196,5296,"All these killings."],[5296,5472,"Is this really a life worth living?"],[5472,5605,"Rhys."],[5784,5893,"I'll let you know"],[5893,6010,"when I'm finally free from this"],[6010,6143,"damn curse."],[6231,6431,"So, you killed them all."],[6464,6598,"Sofia."],[6664,6765,"Abigail."],[6827,6944,"Lily,"],[6990,7140,"even Eliza?"],[7670,7836,"How do you know that name?"]],"33":[[8,129,"Even Eliza?"],[221,329,"How do you know that name?"],[371,671,"She was your first bride, wasn't she?"],[804,1030,"She was your first-"],[1030,1230,"My first wife."],[1309,1530,"My only wife."],[1593,1830,"She was my only joy."],[1947,2202,"I thought if I was destined to die,"],[2293,2573,"at least I'd had this small life with her."],[2656,2773,"At least I would die"],[2773,3032,"knowing what real love felt like."],[3336,3503,"But in the end,"],[3570,3803,"that love was a curse too."],[4049,4208,"I found out that Eliza,"],[4250,4450,"my Eliza,"],[4512,4633,"betrayed me."],[4750,5050,"With my own father."]],"34":[[20,204,"And you believe that?"],[325,479,"There were several letters"],[479,629,"between them."],[688,863,"Going back months."],[863,1034,"My bastard father,"],[1034,1255,"always loved to stare at her."],[1309,1672,"And Eliza, of course, never admitted it."],[1776,2018,"Always defiant to the end."],[2389,2510,"You and her"],[2581,2802,"are alike that way."],[2948,3165,"I buried Eliza,"],[3249,3511,"and my love for her."],[3511,3670,"Now I bury every bride"],[3670,3883,"who follows."],[4183,4320,"You and Nick,"],[4425,4633,"I envy you two."],[4633,4746,"I wish"],[4746,4859,"I didn't have to do this,"],[4859,5021,"I truly do."],[5338,5484,"But family must come first."],[5484,5834,"Family must always come first."],[5834,5935,"You...you're wrong!"],[5935,5980,"Okay?"],[5980,6189,"Eliza didn't betray you."]],"35":[[8,95,"You, you're wrong!"],[95,350,"Okay? Eliza didn't betray you."],[383,554,"Gloria set you up."],[554,646,"She set you all up."],[646,721,"She made a bargain,"],[721,813,"she knew you wouldn't"],[813,992,"sacrifice Eliza otherwise."],[1130,1217,"You're lying."],[2848,2957,"That's..."],[3053,3174,"That's not possible."],[3194,3386,"She played you, Rhys."],[3461,3636,"She played all of you."],[3732,3883,"But you can end this, okay?"],[4049,4291,"You're not a part of this anymore."],[4291,4462,"You can break the curse."],[4462,4567,"No more deaths,"],[4567,4700,"no more sacrifices."],[4854,4950,"Do you really think"],[4950,5063,"this is what Eliza"],[5063,5230,"would have wanted?"]],"36":[[930,1071,"What a shame."],[1459,1543,"He always was"],[1543,1801,"too sentimental for his own good."],[1951,2114,"Gloria."],[2114,2293,"What have you done?"],[2352,2473,"My Rhys."],[2581,2840,"He always acted so strong."],[2911,3073,"I should have known"],[3073,3249,"he'd crack eventually."],[3453,3641,"You killed him."],[3691,3845,"You actually killed him."],[3845,4129,"If it weren't for you, he'd still be alive."],[4387,4596,"I'm not surprised."],[4596,4775,"Nick always had terrible"],[4775,4896,"taste in girls."],[5059,5242,"You're insane."]],"37":[[183,296,"No, no!"],[350,421,"Ah!"],[521,750,"Let go of me, you vile bitch!"],[1026,1159,"I'll kill you."],[1326,1468,"I'll do it!"],[1609,1726,"Go ahead."],[1764,1897,"Pull it."],[2006,2289,"You think you're better than me?"],[2289,2389,"Pull the trigger,"],[2389,2515,"little girl."],[2681,2781,"Face it."],[2886,3107,"You don't have the guts for it."],[3107,3219,"That's the difference"],[3219,3353,"between you and me."],[3353,3499,"You don't have the courage"],[3499,3661,"to lie, to cheat,"],[3661,3920,"to do everything it takes to survive,"],[3920,4020,"but I do!"],[4099,4266,"What are you talking about?"],[4325,4425,"You'll see."]],"38":[[58,133,"Nick!"],[133,283,"Aah!"],[283,371,"Nick!"],[371,458,"Help me!"],[458,542,"Rhys!"],[542,617,"Oh!"],[754,871,"Rhys!"],[871,1013,"Oh, God!"],[1013,1113,"Brother!"],[1735,1860,"She was trying to kill me,"],[1860,2035,"and he tried to save me, but..."],[2035,2147,"No, no, no, no."],[2147,2314,"She's lying, ok? She did it-"],[2314,2364,"Hey!"],[2364,2410,"Give me that!"],[2410,2523,"Let go of me! No!"],[2523,2665,"It was her! Gloria did it!"],[2686,2794,"How dare you?"],[2823,3048,"You killed my son in cold blood!"],[3073,3194,"First Theo and"],[3194,3315,"now Rhys."],[3399,3516,"Theo?"],[3516,3674,"No!"],[3674,3799,"Wilkins, let her go."],[3824,3920,"But Master Nicholas-"],[3920,4066,"I said let her go."],[4512,4742,"You killed my brothers?"],[4775,4975,"No, no, no!"],[4975,5096,"She set me up."],[5096,5263,"I, I didn't kill Rhys."],[5280,5413,"What about Theo?"],[5472,5572,"Nick, I, I"],[5601,5722,"I had no choice."],[5743,5901,"Now, you see."],[5964,6101,"She's dangerous."],[6135,6343,"She's not even worth saving!"],[6343,6585,"No, no no. Don't listen to her, okay?"],[6585,6702,"We can get out of this."],[6702,6911,"No one else has to die."],[7011,7228,"She killed your brothers Nick,"],[7228,7411,"and now she's trying to turn you"],[7411,7620,"against your own blood."],[7732,7932,"I'm the only family"],[7932,7987,"you have left,"],[7987,8179,"and if you side with her,"],[8204,8450,"you'll end up just like Rhys and Theo."],[8696,8787,"What are you doing?"],[8787,8854,"No."],[8879,9004,"Nick."]],"39":[[66,158,"What are you doing?"],[254,350,"Nick."],[421,546,"What are you doing?"],[546,696,"Forgive me, Mare."],[696,821,"What?"],[859,963,"Wilkins, take her."],[980,1071,"No! Nick!"],[1071,1217,"No no no no no!"],[1267,1401,"Finish it, Nicholas!"],[1568,1705,"Nick, please don't!"],[1705,1864,"No no!"],[1864,2064,"Don't! Oh!"],[2394,2606,"You made the right choice, Nicholas."],[2869,2986,"Perhaps when we're freed"],[2986,3086,"from this curse,"],[3086,3382,"you can find another bride."],[3470,3687,"Maybe the next one you bring home"],[3770,4016,"won't be this much trouble."]],"40":[[1063,1155,"Oh my God!"],[1155,1305,"Oh my God! Oh! Please, please."],[1305,1380,"Let me go! Let me go!"],[1380,1564,"Tonight, under the Crimson Moon,"],[1564,1805,"our blood shall be freed from its curse,"],[1805,2043,"and we shall begin anew."],[2831,2994,"What the fuck is that?"],[2994,3128,"Is that poison?"],[3128,3395,"A small sacrifice to begin the ritual."],[3445,3666,"But once the ceremony is done,"],[3666,3828,"they shall be reborn."],[3828,3937,"Nick! This is insane, ok?"],[3937,4029,"Can you please just-"],[4029,4204,"just tell them to stop this!"],[4204,4254,"Nick-"],[4254,4487,"It's time to finish what you started,"],[4487,4579,"my dear."],[4579,4708,"You've disrupted"],[4708,4921,"the order long enough."],[4921,5130,"It is time for you and my son"],[5130,5288,"to say your vows,"],[5397,5643,"properly, this time."],[5739,5822,"Never."],[6227,6460,"Then her blood will take your place."]],"41":[[16,262,"Then her blood will take your place."],[296,467,"Fine, fine fine fine, fine."],[467,517,"I'll do it."],[517,721,"Just let her go."],[1263,1384,"Go on, Nicholas."],[1747,2047,"Show her what true devotion is."],[2114,2223,"Mare,"],[2373,2585,"when I first saw you,"],[2585,2794,"I thought you were too good for me."],[2852,3053,"Too clever,"],[3053,3203,"too brave."],[3278,3482,"But you taught me that love"],[3536,3691,"can overcome anything."],[3791,3899,"Family,"],[4012,4162,"curses,"],[4216,4341,"even death."],[4383,4600,"Nicholas Thornwood,"],[4600,4804,"Do you take this woman to be"],[4804,4975,"our wedded wife?"]],"42":[[54,271,"Nicholas Thornwood,"],[271,475,"do you take this woman to be"],[475,638,"our wedded wife?"],[750,838,"I,"],[1188,1263,"I do."],[1497,1622,"Your turn."],[1735,1851,"Nick."],[1926,2135,"I used to think that you were perfect."],[2335,2473,"But now I realize you were never"],[2473,2610,"the strong,"],[2610,2723,"kind"],[2761,2911,"person I thought you were."],[3019,3157,"You're just a coward,"],[3228,3436,"hiding behind your mother's shadow."],[3528,3657,"Mary Mitchell."],[3724,3853,"Do you take this man"],[3853,4041,"to be your wedded husband?"],[4258,4329,"I do."],[4804,4904,"Till death do us part."],[5025,5105,"Oh!"]],"43":[[62,191,"Till death do us part."],[304,383,"Oh!"],[417,546,"Take her now."],[667,721,"Oh!"],[759,867,"Go find help!"],[867,1105,"Forget the girl! Kill the bride!"],[1126,1234,"The ceremony is not complete"],[1234,1443,"until the bitch is dead."],[1451,1626,"Under the light of the Crimson Moon,"],[1626,1835,"bind her soul to the circle."],[1985,2231,"You are not leaving this wedding"],[2231,2318,"alive!"],[2452,2552,"You should have stayed in the"],[2552,2656,"kitchen, Wilkins."],[2656,2773,"Nick! Do something!"],[2915,3148,"The Crimson Moon is almost gone."],[3244,3399,"Oh, God!"],[3553,3678,"Oh!"],[3774,3845,"Uh!"],[3916,3978,"Nick!"],[3978,4233,"If she doesn't die, we die."],[4396,4550,"What is taking so long?"],[4859,5021,"Kill her!"],[5743,5960,"I'm sorry."]],"44":[[70,179,"I'm sorry."],[613,700,"Huh!"],[763,829,"I..."],[1263,1534,"You fucking idiot!"],[1534,1735,"You can't do anything right!"],[1935,2060,"Please."],[2060,2127,"Mare!"],[2127,2331,"Please! Mare, please don't-"],[2331,2477,"I don't want to die. Please, just put-"],[2477,2652,"Enough of these games!"],[2748,3019,"A Thornwood bride must"],[3019,3219,"die!"],[3332,3499,"I'm not the only one."]],"45":[[191,316,"Aah!"],[621,713,"Mom!"],[867,959,"Mom!"],[1138,1372,"The debt has been paid."],[1664,1797,"The curse!"],[1797,1918,"The curse is over!"],[1918,2039,"I'm free!"],[2089,2252,"Name your prize,"],[2252,2348,"Thornwood."],[2439,2706,"I...I wish to never die!"],[2706,2957,"It is not your prize."],[3003,3094,"What?"],[3132,3240,"But I..."],[3357,3470,"It's you."],[3528,3653,"Mary!"],[3653,3803,"You ended the curse. It's over."],[3803,3966,"We can have any wish!"],[3966,4012,"Anything."],[4012,4162,"Money, power, eternal life,"],[4162,4300,"anything that we want!"],[4300,4454,"Just say the words."],[4675,4775,"Mare?"],[5034,5146,"I want to go home."],[5176,5263,"What?"]],"46":[[241,312,"Mare, please!"],[312,492,"Look, I know I made mistakes!"],[492,721,"You tried to kill me, asshole."],[721,838,"I know, but, Mare,"],[838,959,"but we don't have to worry about that"],[959,1055,"now, right?"],[1280,1397,"I'm free!"],[1397,1459,"Eugh!"],[1459,1559,"We can be together"],[1559,1693,"like we always wanted."],[1693,1922,"Just, just you and me. Forever."],[1951,2077,"Your mom never mentioned a"],[2077,2214,"prenup, did she?"],[2323,2389,"No."],[2565,2635,"Good!"],[3019,3136,"That's him, Officer!"],[3269,3386,"Mare. Please don't leave me!"],[3386,3499,"Where are you going?"],[3499,3628,"On the ground, now!"],[3628,3741,"No no no no! Fuck you!"],[3741,3795,"What are you talking about?"],[3795,3928,"Get your fucking hands off me!"],[3928,3999,"What the-"],[3999,4079,"Argh!"],[4166,4333,"This is everything you need,"],[4387,4466,"from Sonya."],[4525,4662,"Ma'am, are you okay?"],[4662,4779,"Do you need medical attention?"],[4854,4950,"No."],[4950,5105,"Just a divorce."],[5347,5480,"This is bullshit, man."],[5480,5568,"You're never gonna get away"],[5568,5684,"with this shit."],[5759,5843,"I'm a Thornwood!"],[5843,6018,"Any idea who you're fucking with, huh?"]],"47":[[183,312,"Where the hell is she?"],[312,446,"It's been, like, 30 minutes."],[446,508,"Eugh!"],[508,617,"Why did we have to come back"],[617,729,"here to this dump?"],[729,892,"She doesn't even work here, anymore."],[892,1046,"She probably got fired."],[1046,1205,"Last I heard, she went AWOL"],[1205,1409,"with her mysterious husband months ago."],[1409,1618,"Probably eloped in Vegas."],[1618,1814,"It's all the luxury she could afford."],[2060,2164,"Whoa!"],[2164,2385,"Who's the hot shot driving that?"],[2631,2698,"Oh my God."],[2698,2752,"Wait!"],[2752,2902,"Is that Mare?"],[3553,3695,"Hey girls!"],[3695,3824,"Long time no see."],[3824,3941,"Jesus, Mare!"],[3941,4066,"Where the hell have you been?"],[4066,4187,"I mean, no calls or texts"],[4187,4262,"for six months,"],[4262,4362,"and you show up looking like"],[4362,4479,"The Devil Wears Prada."],[4479,4713,"I know, long story."],[4713,4788,"Sorry I'm late."],[4788,4971,"I was at the lawyer's office."],[4971,5271,"Unfortunately, I can't stay long, though."],[5271,5405,"I have a hot date."],[5405,5547,"With your hot, rich hubby?"],[5547,5726,"Or did he call it quits?"],[5726,5968,"Ladies, didn't you hear?"],[6635,6769,"I got a divorce."]]}