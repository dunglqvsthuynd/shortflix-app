{"1":[[458,609,"My mom died of a serious illness"],[609,696,"three years ago."],[825,952,"Under her will,"],[1047,1322,"I was married to Aunt Nina's son, Charles."],[1472,1580,"Oh good, you're here."],[1659,1909,"Jenny, Charles had to go abroad for work,"],[1909,2060,"but he promises when he returns,"],[2060,2302,"he's going to get you a grand wedding."],[2531,2657,"Relax!"],[2657,2905,"You two have known each other since childhood."],[2965,3221,"He's gonna be a really good husband."],[3353,3478,"Charles is coming back to me."],[3536,3665,"We've only met as kids."],[3749,3862,"Will he recognize me?"],[4390,4469,"How's it going?"],[4469,4600,"Has Jenny found you yet?"],[4642,4871,"Mom, how am I supposed to recognize her?"],[4871,5009,"You never told me what she looks like."],[5050,5118,"She's supposed to wear"],[5118,5326,"a red fishtail dress I bought her."],[5359,5559,"She must be the sexiest one there."],[5772,5989,"Anyway, lucky that he can marry me."],[6047,6143,"Surprise, Charles."],[6168,6264,"I'm running late."],[6627,6763,"Oh no..."],[6794,7019,"Oh no, I am so very sorry."],[7019,7182,"Is there anything I can do?"],[7182,7313,"No, don't worry about it."],[7313,7382,"Don't worry."],[7440,7578,"No, surprise will never happen."],[7630,7750,"Hi, Charles."],[7750,7945,"I am your wife, Jenny."],[7945,8133,"Or you can call me Detective J."],[8133,8279,"I know I'm only an intern right now,"],[8279,8519,"but soon I'll be the next Charlotte Holmes."],[8546,8730,"No, that's too much."],[8730,8817,"I'm gonna scare him away."],[10523,10606,"Is that..."],[10635,10714,"Charles?"],[10802,10935,"She's way too perfect..."],[11428,11469,"It's him!"],[11511,11589,"My love!"],[11678,11832,"He's coming toward me."],[11916,11990,"My love!"],[12445,12625,"But if only she's wearing red dress,"],[12658,12796,"she's not the one I'm looking for."],[12896,12957,"No..."],[13075,13192,"It's... not him."],[13634,13722,"- Let's go back to the - My wife..."],[13722,13813,"- detective agency. - My wife..."],[13813,14013,"Didn't you say you had a case assigned for me?"],[14155,14318,"...Is some kind of slutty woman?"]],"2":[[354,498,"Why won't Charles meet with me?"],[663,798,"Does he regret our marriage?"],[875,1121,"Wayne, find me the best detective"],[1121,1270,"for investigating the infidelity."],[1326,1470,"Keep my identity hidden."],[1470,1735,"I do not need this affecting the company."],[1981,2200,"Weren't you gonna give me the big case?"],[3174,3281,"So you'll give me a billion"],[3281,3449,"if I can get CV's asset proofs?"],[3532,3713,"That land in downtown New York"],[3713,3870,"is going up for auction in a week."],[3870,3963,"Without the asset proofs,"],[3963,4057,"Charles won't have the rights"],[4057,4132,"to bid on it."],[4132,4291,"He'll be forced to give it to me."],[4487,4587,"Oh gosh!"],[4646,4744,"I heard CV has already"],[4744,4983,"invested half of its assets into the construction."],[4983,5062,"Mm-hmm."],[5062,5154,"So if you can get it,"],[5154,5314,"that would be a fatal blow to CV."],[5350,5597,"So darling, whether or not I can crush Charles..."],[5989,6180,"It's time to call Johnson."],[6390,6473,"Yes!"],[6589,6748,"I'll get back what I lost in love."],[6794,6996,"Where can I find work as a rookie?"],[7015,7223,"I should go find some missing cat now."],[7549,7674,"I got a billion already."],[7682,7895,"No need for these low-profit cases."],[8662,8829,"Investigating his wife's infidelity?"],[8888,9007,"This sounds exciting."],[9071,9170,"You wanna take this crap?"],[9286,9382,"Take it."],[9382,9496,"I got a big case."],[9557,9651,"Really?"],[9730,9893,"Finally something challenging."]],"3":[[12,187,"Mr. Charles, are you sure"],[187,350,"you're ready to divorce your wife?"],[492,601,"It's been three years."],[640,807,"It's time to finally end this thing."],[829,921,"What about Mrs. Mina?"],[1055,1326,"When she finds out Jenny cheated first,"],[1359,1472,"she'll support me."],[1472,1630,"Speaking of, how is the"],[1630,1819,"detective thing coming along?"],[1851,1953,"She should be here now."],[2407,2531,"Okay."],[2711,2788,"Let's go."],[3160,3293,"Not way!"],[3293,3430,"CV Group?"],[3499,3689,"Why did Jennifer giv me this case?"],[3840,3968,"I have to be great."],[3968,4150,"I can't let my client down."],[4170,4275,"The client's email said"],[4275,4416,"I should wait at the reception."],[4512,4654,"Someone will take me upstairs."],[4764,4916,"What a mysterious client."],[4916,5050,"Definitely a big shot."],[5513,5582,"Hi."],[5597,5695,"Get lost!"],[5695,5770,"Who do you think you are"],[5770,5906,"walking in here dressed like that?"],[5930,6067,"You're gonna dirty our floor."],[6080,6221,"I have an important client."],[6221,6355,"He told me to wait here."],[6358,6469,"Important client?"],[6469,6639,"Like who? The janitor?"],[6669,6757,"Do you want me to show you"],[6757,6820,"where the bathroom is,"],[6820,6915,"so you can get ready?"],[6919,6987,"You!"],[6987,7089,"Hey, someone just reported"],[7089,7287,"a missing diamond bracelet in a locker room."],[7298,7349,"Have you seen it?"],[7703,7830,"Bracelet? I don't know."],[7982,8067,"It's her!"],[8080,8266,"I saw her walking that way."],[8345,8510,"She was here looking for sugar daddies"],[8510,8597,"and now she's stealing."],[8666,8823,"I didn't steal anything."],[8823,8906,"We'll figure it out."],[8942,8988,"You're gonna have to come with me."],[8996,9075,"No, no, no. Wait!"],[9309,9540,"This missing bracelet..."],[9540,9765,"Is it the one with a square cut diamond"],[9765,9905,"and a horse bit clasp?"],[9939,10020,"Yeah, that's the one."],[10190,10311,"How do you know that?"],[10311,10414,"You must have stolen it."],[10581,10738,"Maybe because it looks exactly like"],[10738,10882,"the one you have on your wrist."],[10960,11029,"Bullshit!"],[11029,11232,"I happen to have one of the same style."],[11298,11340,"Oh, yeah?"],[11511,11577,"Then how do you know"],[11577,11794,"it's exactly the same style as yours?"],[12066,12294,"I am the face of CV."],[12362,12608,"Slandering me is like slandering CV!"],[12633,12707,"Stop!"],[12908,13045,"Mr. Charles!"],[13125,13189,"It's her?"],[13288,13375,"You're Charles?"]],"4":[[20,147,"Mr. Charles!"],[458,625,"How dare you call our CEO by name?"],[667,717,"No way!"],[888,1176,"My husband Charles is also a CEO."],[1197,1284,"Could it be..."],[1697,1764,"It's her?"],[1864,2114,"My Charles couldn't possibly be this handsome."],[2260,2389,"This woman is plotting against me."],[2389,2631,"She's trying to slander me!"],[2660,2747,"I'm gonna kick her out now."],[2747,2823,"Enough!"],[3257,3347,"Show me your hand."],[3511,3641,"You can't do that."],[3641,3895,"You're gonna show it to me or I can call the police."],[4220,4295,"You're fired!"],[4295,4426,"What! Why?"],[4426,4567,"No, please, give me a chance..."],[4567,4805,"A thief cannot represent us."],[4942,5226,"Mr. Charles, this is the best detective."],[5317,5611,"Miss detective, that was quite impressive."],[5611,5789,"I'm sure you can help me out,"],[5797,6014,"but it seems you lack self-defense skills."],[6097,6370,"Mr. Charles, you can't be a detective"],[6370,6483,"in our line of work"],[6483,6708,"without self-defense skills."],[7003,7203,"Do real detectives carry these?"],[7474,7679,"Detective, why don't we head upstairs"],[7679,7794,"to discuss our cooperation?"],[7978,8033,"Right this way."],[8095,8237,"I need to confirm it."],[8295,8529,"If I've mistaken him for the wrong person,"],[8529,8658,"this deal is done."],[8896,9100,"Your wife cheated on you?"],[9296,9534,"Why do you sound so excited about that?"],[9557,9635,"Well..."],[9635,9756,"I'm not cheating."],[9770,9847,"Thank God..."],[9847,10085,"He's not my husband."],[10090,10234,"I'm just, I..."],[10247,10414,"I really hate cheaters."],[10414,10539,"I mean, if you're not gonna be loyal,"],[10539,10719,"why then bother getting married?"],[11244,11448,"Only if she thought like that..."],[11891,11978,"Don't worry."],[11978,12174,"If what you said is true,"],[12174,12399,"I'll get the evidence we need and..."],[12399,12591,"throw her to the cleaners."],[12591,12662,"No."],[13012,13300,"It's my fault that she's been alone all these years."],[13329,13609,"If she agrees to the divorce,"],[13617,13805,"I wanna give her 5 million in compensation."],[13805,13893,"If only my husband"],[13893,14114,"could take responsibility like this guy..."],[14250,14390,"That's really generous."],[14511,14706,"I'm sure she'll accept the offer."],[14851,15127,"Okay, we got what we need"],[15137,15354,"and I'll keep in touch with you."],[15410,15480,"Oh, um..."],[15568,15680,"I didn't catch your name."],[15732,15861,"Oh, I'm..."]],"5":[[25,99,"I'm J-"],[183,304,"Sorry."],[513,637,"Sweetheart,"],[637,796,"come home for dinner tonight."],[800,898,"Charles is coming."],[915,1059,"It's time for you two to meet."],[1092,1330,"I really don't think he wants to see me right now."],[1363,1551,"He asked so much about you before."],[1551,1657,"He does care."],[1657,1810,"Anyway, see you tonight."],[1810,1888,"But..."],[1926,2089,"Could it be that he hates me?"],[2089,2247,"Maybe it was a misunderstanding."],[2252,2411,"I'm sorry, I really have to go, but..."],[2411,2601,"I'll keep in touch with your assistant."],[3111,3257,"#This is my fault, sir.#"],[3257,3406,"#She doesn't seem# #very professional.#"],[3474,3621,"She didn't ask about your wife"],[3621,3744,"or even the fees,"],[3766,3927,"but I will find someone else."],[4020,4295,"No. I trust her."],[4437,4528,"She can handle it."],[4592,4767,"Miss J? Interesting."],[4792,4896,"By the way, sir,"],[4896,5050,"the CV asset proof has been prepared."],[5117,5174,"Excellent."],[5174,5297,"Make sure to keep it safe."],[5472,5802,"That document is critical to us acquiring that land."],[5914,5947,"Yes, sir."],[5947,6118,"I will credit to the financial manager,"],[6118,6318,"Mr. Johnson, for safekeeping."],[6381,6473,"Thanks, Mike."],[7207,7407,"Jennifer, thank you so much."],[7407,7579,"This is my first major case ever!"],[7591,7643,"What?"],[7643,7866,"Yeah. It's the CEO of CV Group."],[7916,8114,"I'll definitely treat you once I get this case done."],[8340,8443,"Oh!"],[8528,8721,"The CV CEO?"],[8879,9029,"He's the richest man in New York."],[9113,9284,"That idiot got this gig!"],[9747,9870,"- Hey, Mom. - Hi."],[10160,10259,"Just you?"],[10259,10362,"Where's Jenny?"],[10460,10670,"Can't wait even a second to see her, huh?"],[10969,11280,"I just don't understand why she'd want to marry me."],[11478,11628,"Why would you say something like that?"],[11840,12001,"You know what she was doing at the airport?"],[12045,12186,"She was kissing another man"],[12186,12308,"right there in public."],[12383,12453,"I saw it."],[12474,12621,"Jenny cheated on you?"],[12942,13013,"Mina..."],[13033,13161,"You're my best friend."],[13213,13477,"When I go, take care of Jenny for me."],[13477,13684,"Dont worry, I promise,"],[13755,13943,"Charles and I will take good care of her."],[14260,14506,"Mom, I promise I'll listen to Aunt Mina"],[14506,14714,"and I will never disappoint Charles."],[14768,15082,"No, Jenny would never do something like that!"],[15436,15523,"She's here."],[15529,15619,"Ask her yourself."]],"6":[[95,129,"Hi!"],[183,392,"Hi, I have an order for Mr. Charles."],[425,487,"I didn't order those."],[525,621,"You've got the wrong person."],[629,679,"I ordered them."],[750,984,"You can't meet Jenny for the first time without flowers."],[1021,1042,"Awesome."],[1076,1167,"Could you please sign right here?"],[1313,1368,"Thank you so much."],[1376,1451,"Thank you so much."],[1459,1509,"Have a great night."],[1993,2073,"Mom,"],[2094,2223,"you ordered flowers."],[2239,2331,"You arranged the wedding."],[2439,2598,"Why not spend the rest of your life with her?"],[2627,2777,"What the hell are you talking about?"],[2777,2839,"Stay here."],[2869,3040,"Jenny will be here any minute now."],[3086,3236,"I have a meeting about the auction."],[3374,3528,"It's going to be fine."],[4120,4314,"I'll have her meet you at the HS Club."],[4350,4466,"You have to sort this out."],[4608,4701,"Don't forget."],[4713,4802,"I won't."],[4917,5100,"Aunt Mina, I'm so sorry I'm late."],[5100,5190,"Sweetheart."],[5280,5386,"Okay, so..."],[5386,5527,"Charles is back already."],[5527,5662,"Don't call me aunt anymore."],[5860,5939,"Mom?"],[5968,6035,"That's right."],[6642,6877,"Is Charles not here yet?"],[6930,7017,"He's..."],[7062,7209,"He's busy planning your wedding."],[7228,7334,"He couldn't make it tonight."],[7382,7500,"He feels bad for not giving you"],[7500,7667,"a proper wedding the first time."],[7741,7891,"I guess I misunderstood him."],[7970,8124,"He's been busy planning the wedding"],[8124,8329,"and I thought he was regretting it."],[8437,8583,"Jenny would never be unfaithful."],[8612,8956,"I need to find a way to clear up the misunderstanding."],[8975,9162,"He's going to meet you at the HS tonight."],[9175,9284,"He can't wait to see you."],[9292,9451,"He'll be there as soon as he can."],[10464,10673,"Miss J, I need your help."],[10760,10916,"I have my wife's location."],[10940,11001,"Follow her."],[11040,11174,"Get evidence on her affair."],[11202,11330,"The boss trusts me."],[11340,11540,"I have to prove myself with this opportunity."],[11580,11678,"But..."],[11684,11830,"what about my husband?"],[11857,12037,"Alright, just send me her location."],[12070,12254,"The HS Club on Baker Street."],[12283,12326,"What?"],[12358,12420,"What's wrong?"],[12470,12535,"Is there a problem?"],[12608,12695,"No problem."],[12746,12850,"I'll be there soon."],[12858,12975,"What a coincidence."],[13004,13167,"It's also HS."],[13192,13436,"Sorry, I have to go with this work thing."],[13467,13517,"Okay, go."],[13546,13608,"Go."],[14406,14693,"Kinda nervous for my very first real mission."],[14823,15140,"Sweetheart, I got the CV assets proof."],[15219,15376,"What can you offer in exchange?"],[15390,15499,"As long as you help me,"],[15499,15632,"you can have whatever you want."],[15694,15865,"Mr. Allen won't leave you hanging either."],[15899,16163,"Then tonight, come to room 506."],[16850,17084,"Isn't that... CV's briefcase?"],[17442,17530,"Shit!"],[17613,17813,"This man is going to betray the CV Group."]],"7":[[240,311,"Oh!"],[311,446,"- Uh... - Uh, Jenny!"],[495,620,"Why are you here?"],[658,974,"I came to meet my husband."],[1028,1135,"Why are you here?"],[1234,1317,"I..."],[1317,1434,"I came here to meet a friend."],[1526,1603,"Aren't you supposed to be"],[1603,1764,"helping the CEO of CV investigate?"],[1805,1916,"Stop slacking off!"],[1916,1993,"Go on, leave!"],[2001,2290,"No, yeah, I saw a man enter with a CV briefcase."],[2290,2469,"I think he's trying to sell out CV."],[2498,2692,"Damn! She found out."],[2701,2830,"I may lose all my money."],[2852,3032,"Maybe I should just let Johnson..."],[3090,3170,"Yeah."],[3170,3372,"Oh, you better investigate carefully then"],[3372,3432,"if that's the case."],[3432,3603,"This is a good chance for you to prove yourself,"],[3603,3654,"huh?"],[3674,3802,"Okay, don't worry."],[4260,4329,"Hey!"],[4332,4432,"Give me that!"],[4487,4517,"No..."],[5296,5474,"If you wanna prove yourself, you won't need this."],[5521,5570,"Wait-"],[5570,5772,"A professional detective doesn't need this."],[5960,6039,"Go on, I'll wait outside."],[6039,6099,"You're fine."],[6781,6975,"The sweet little detective from CV Group"],[6975,7061,"is in your room now."],[7115,7194,"Treat her well."],[7232,7328,"If this gets exposed,"],[7378,7453,"you know what will happen."],[7494,7690,"It really is a CV briefcase."],[7690,7863,"It must have something important inside."],[7870,8068,"I need to help Mr. Charles get it back."],[8208,8427,"Hi. I can take them in. And..."],[8427,8609,"can you lend me your shirt?"],[8779,8850,"I'll pay for it."],[9167,9342,"Here are your drinks, sir."],[9482,9601,"Make sure to decant it."],[9667,9906,"I'm expecting a very important guest."],[10702,10833,"I heard you're Charles new girl,"],[10833,10963,"little cupcake."]],"8":[[0,109,"Let go of me!"],[155,237,"What a beauty!"],[371,667,"Why stick to a CEO when you can come with me?"],[700,784,"I'll treat you right."],[792,995,"I'm a hired detective by your CEO."],[1026,1130,"You're just a detective."],[1188,1359,"If you sleep with me, he wouldn't care."],[1443,1543,"Come on, baby, let's do it."],[1560,1612,"No!"],[2660,2852,"Who dares to interrupt my fun?"],[3015,3079,"Where is it?"],[3860,3981,"One girl is not enough."],[4050,4195,"Remember what Allen promised me."],[5038,5171,"Why isn't J answering me?"],[5251,5384,"Something must've happened to her."],[5455,5672,"Wayne, take me to the HS Club."],[5672,5947,"Sorry, Boss, the traffic is too bad."],[6264,6477,"You filthy bitch!"],[6477,6648,"You slut!"],[6648,6715,"Who are you calling?"],[6777,6877,"Help!"],[6881,6957,"J?"],[7002,7057,"J!"],[7140,7233,"Are you okay?"]],"9":[[12,60,"J?"],[120,170,"J!"],[258,342,"Are you okay?"],[392,550,"If Charles finds out that I am"],[550,757,"stealing documents from his company"],[757,926,"and trying to sleep with his detective,"],[971,1067,"I'm done."],[1126,1234,"You filthy bitch!"],[1372,1583,"You worked for a CEO as his detective,"],[1590,1817,"just so you could steal secrets from CV"],[1817,2054,"that you can sell to Allen's company."],[2122,2264,"If I wouldn't have caught you,"],[2270,2402,"you would've ruined CV!"],[2402,2501,"What are you talking about?"],[2501,2612,"It's you!"],[2965,3090,"J? J!"],[3282,3395,"So what?"],[3395,3575,"You think he'll believe you or me?"],[3582,3728,"Who's worked with him for years?"],[3778,3935,"I'll tell him that you tried to seduce me"],[3935,3982,"because you were"],[3982,4140,"afraid of getting figured out."],[4171,4346,"He'll kill you for it."],[4346,4435,"Get away from me!"],[4435,4592,"You fucking monster!"],[4607,4654,"Oh, yeah?"],[4673,4745,"Yell louder."],[4745,4871,"No one's here to save you!"],[5125,5413,"Boss, Johnson's worked for us for years."],[5470,5591,"If he was gonna betray us,"],[5591,5714,"he would've done it by now."],[5809,5989,"Do you really think the new detective sold us out?"],[6035,6256,"No, I don't believe J would do that."],[6635,6760,"Fucking monster!"],[6760,6810,"Oh, yeah?"],[6845,6895,"Yell louder."],[6895,7027,"No one's here to save you!"],[7090,7125,"Huh?"],[7190,7296,"Charles, help!"]],"10":[[12,120,"Charles! Help!"],[120,191,"Louder!"],[212,454,"The more you struggle, the more excited I get!"],[454,500,"Maybe..."],[992,1042,"Are you okay?"],[1255,1309,"Mr. Charles..."],[1434,1697,"Mr. Charles, this detective you hired..."],[1697,1780,"Shut up!"],[1864,2135,"We barely know each other, and Johnson works for him."],[2139,2318,"There's no way he'd trust me."],[2481,2527,"She's mine."],[2880,2955,"What makes you think"],[2955,3100,"she would do something like this?"],[3257,3430,"I had no idea she was yours."],[3545,3745,"If I had known, I would've never touched her."],[3874,4003,"Thank God nothing happened."],[4175,4292,"Nothing happened?"],[4650,4761,"Here's evidence..."],[4875,5071,"of Johnson's stealing your company."],[5321,5402,"You-"],[6243,6365,"Mr. Charles, please!"],[6460,6665,"Please, give me another chance."],[6792,7127,"Mr. Charles, this bitch tried to seduce me."],[7157,7329,"I'll have her meet you at the HS Club."],[7361,7480,"You have to sort this out."],[7536,7736,"So my wife works for Allen."],[7824,8068,"She married me to take CV down?"],[8153,8341,"She said she would take down CV."],[8708,8825,"Take this traitor out of here."],[9109,9240,"Get out of my sight!"],[9930,10018,"Charles! Help!"],[10139,10301,"Which Charles was I calling?"],[10450,10568,"What did you mean by..."],[10623,10717,"I'm yours?"]],"11":[[208,533,"So, you still haven't answered my question."],[829,1051,"I mean..."],[1593,1668,"You work for me."],[1705,1964,"It's my responsibility to protect you."],[2227,2431,"Thanks for saving me."],[2490,2680,"No, I should be thanking you"],[2680,2789,"for your footage."],[2894,3091,"I wouldn't have been able to get Johnson done so easily."],[3169,3345,"He knew Johnson is traitor before?"],[3345,3518,"Oh Jenny, stop overthinking."],[3687,3866,"It's late. Let me drive you."],[3866,4258,"Thanks. I'll just get a taxi."],[6401,6670,"Boss, Allen's company have spread the word that"],[6670,6821,"they are confident they can completely"],[6821,6944,"take us down at the auction"],[6944,7041,"in one week."],[7041,7175,"If they're so sure,"],[7196,7248,"could it have something"],[7248,7378,"to do with what Johnson has stolen?"],[7515,7632,"I'll have Miss J investigate."],[7703,7899,"She witnessed Johnson's betrayal."],[7899,8003,"She must be at the auction."],[8094,8261,"It's so dangerous last night."],[8261,8423,"You should stop taking such"],[8423,8554,"dangerous cases from now on."],[8578,8700,"None of this would've happened"],[8700,8938,"if you didn't take away my self-defense tools."],[9013,9159,"You're the one who is incapable."],[9159,9242,"Don't blame me."],[9325,9492,"You should return the CV case to me."],[9505,9638,"Just stay home and be a good wife."],[9667,9840,"No, you didn't want the case."],[9880,9980,"I got the case."],[10060,10143,"And I'm not a quitter."],[10251,10381,"And about my husband, Charles?"],[10431,10493,"It's none of your business."],[10564,10648,"What did you say?"],[11070,11170,"Answer me."],[11204,11260,"Charles?"]],"12":[[37,133,"Answer me."],[179,220,"I..."],[379,640,"My husband's name is Charles, too."],[640,723,"Same as yours."],[825,967,"He couldn't make it yesterday because"],[975,1134,"he was too busy planning our wedding."],[1651,1730,"Sorry."],[1835,1951,"I just got too excited."],[2039,2152,"So, she's married."],[2314,2421,"I understand."],[2577,2766,"When I first heard your name, I..."],[2848,2968,"thought it might be you too."],[3274,3299,"But what..."],[3399,3528,"What are you really here for?"],[3661,3780,"I'm here to talk business."],[3928,4191,"I need you to attend an auction with me."],[4200,4579,"To be honest, CV has a relentless enemy, Allen."],[4633,4838,"And he will be competing against me"],[4900,5155,"for a major land acquisition downtown."],[5167,5401,"Allen? Could it be the same Allen I know?"],[5480,5647,"You cheated on me when my mom was dying?"],[5893,5996,"We're over!"],[6252,6485,"I suspect my wife will be attending as well."],[6577,6815,"She might be a spy set up for him."],[6940,6981,"Understood."],[7350,7411,"You know,"],[7477,7564,"I've worked so hard"],[7564,7749,"to get CV's asset proof for you."],[7845,7920,"How will you thank me?"],[7982,8160,"Don't you worry. I get this land today."],[8191,8338,"I will repay you."],[8338,8740,"CV's financial chain is dependent on his land."],[8740,8829,"So when I get it,"],[8888,8980,"CV is done."],[9042,9248,"They have nothing to come at me anymore."],[9300,9482,"After putting up with all these men,"],[9501,9648,"I'm finally getting rich!"]],"13":[[538,629,"Allen's here too."],[638,825,"He really is the one Charles warned me about."],[855,909,"CV's enemy."],[1050,1124,"Jenny!"],[1218,1301,"What are you doing here?"],[1301,1488,"Someone like you doesn't belong in a place like this."],[1597,1747,"Jenny, damn!"],[1785,1960,"Is this how you ended up after you left me?"],[2022,2060,"That's rough."],[2127,2281,"Jennifer, what are you doing here with him?"],[2356,2673,"Wait, did Allen cheat on me with you?"],[2982,3144,"Well, as a talented detective,"],[3153,3390,"I'm here to help Alan bid for the property, obviously."],[3449,3509,"Unlike you,"],[3509,3698,"who can't even do anything for herself."],[3762,3864,"I guess your husband couldn't"],[3864,4009,"even buy you a decent dress."],[4341,4583,"So she's been working for Allen all this time?"],[4592,4642,"No wonder!"],[4679,4829,"Jenny, look at me now."],[4838,5004,"I bet you regret leaving me, don't you?"],[5046,5130,"But, how about this?"],[5138,5188,"I got an idea."],[5226,5513,"If you just apologize to me in front of everybody"],[5555,5733,"and admit to being wrong,"],[5760,5955,"I don't know, maybe I'll forgive you."],[6085,6167,"Are you kidding?"],[6185,6258,"No."],[6373,6559,"I don't need your forgiveness."],[6715,6869,"After all, it was you who was"],[6869,7065,"cheating on me with her all along."],[7152,7399,"Well, Allen is the big client here today at the auction."],[7407,7494,"So if you don't apologize,"],[7503,7640,"we'll have the organizers throw you out."],[7649,7711,"You wanna try it?"],[7745,7795,"Go ahead."],[7845,8112,"Jenny, how important is this bidding to you?"],[8237,8291,"What do you mean?"],[8337,8450,"Well, I just thought the whole thing"],[8458,8608,"was about you finding a sugar daddy."],[8654,8772,"If I were you,"],[8794,8967,"I would be down on my knees begging."],[9013,9189,"Maybe I could introduce you to somebody."],[9292,9437,"Well, I'm not like her."],[9484,9601,"Who do anything for money."],[9638,9805,"You're a disgrace to us detectives."],[9876,10005,"You fucking bitch!"],[10005,10106,"What did you just say?"]],"14":[[25,98,"Are you okay?"],[600,633,"Charles?"],[759,957,"So this is the CEO of CV."],[1000,1238,"Handsome and rich, just like the rumors say."],[1301,1405,"How could Jenny know him?"],[1726,1962,"You just said she's a detective?"],[2660,2794,"She really is my wife?"],[2923,3157,"How could my mom arrange such a woman for me?"],[3215,3381,"Mr. Charles, the one who should be"],[3381,3535,"standing by your side is me."],[3678,3736,"Disgusting."],[4029,4200,"Who do you think you are talking to my girl like that?"],[4266,4456,"Allen, your taste in people"],[4456,4662,"is just as terrible as your business skills."],[4787,4917,"Attention, everyone."],[4917,5139,"The bidding will begin soon."],[5176,5488,"Mmm. Charles, I wouldn't get too cocky."],[5513,5589,"Pretty soon you're gonna be"],[5589,5754,"down on your knees begging."],[5822,5985,"Hm. We'll see about that."],[6026,6213,"Yeah. We'll see how the bidding goes"],[6213,6339,"without a proof of asset."],[6348,6553,"Once your cash flow is done,"],[6571,6665,"it wouldn't be nothing but a joke."],[6665,6731,"Come on, babe."],[7077,7175,"You saved me again."],[7311,7376,"Thank you."],[7503,7651,"You're my date tonight."],[7732,7982,"It's my duty to protect you."]],"15":[[25,266,"Welcome everyone to tonight's bidding event."],[538,849,"The first item up for bid is a prime plot of land"],[849,1063,"in New York's most bustling district."],[1580,1885,"The opening bid? 50 million."],[2020,2136,"60 million."],[2179,2255,"Thank you."],[2337,2429,"60 million."],[2434,2540,"Quite embarrassing yourselves."],[2565,2681,"How about 100 million right here?"],[2952,3132,"Oh, what's wrong?"],[3132,3411,"Can't the great CV CEO even afford this?"],[3541,3749,"I bet they don't even try to compete with us."],[3791,4037,"Does CV even have the liquid funds for this bid?"],[4057,4133,"I don't think so."],[4729,4877,"500 million."],[5180,5552,"Mr. Charles has just bid 500 million."],[5588,5803,"It seems he's truly determined to win."],[5901,6139,"Would anybody else like to make a higher bid?"],[6185,6287,"Didn't you just say he couldn't bid?"],[6287,6435,"We don't have 500 million."],[6579,6776,"500 million going once."],[7037,7223,"500 million going twice?"],[7444,7549,"500-"],[7766,7887,"Objection!"]],"16":[[12,100,"Objection!"],[250,479,"Mr. Allen, why are you objecting?"],[496,593,"I would like to report that"],[593,851,"this man does not have proof of assets"],[851,1065,"and he is not allowed to make that bid."],[1065,1135,"That's right."],[1180,1367,"That is a major violation of bidding."],[1373,1644,"Getting expelled from the venue is one thing,"],[1644,1884,"but publicly bidding without asset proof?"],[1927,2018,"That's illegal."],[2077,2353,"Mr. Charles, is this true?"],[2398,2519,"Absolutely not."],[2615,2849,"Then show us the proof. You would mind, right?"],[2969,3040,"Bad news, sir."],[3153,3411,"The safe containing the assets is missing."],[3636,3793,"Missing! Missing!"],[3828,3919,"Or is it that your company's"],[3919,4110,"cash flow has totally collapsed"],[4110,4237,"and you never had proof?"],[4429,4589,"He should be immediately expelled"],[4589,4703,"for lacking qualification"],[4703,4836,"and held legally accountable."],[4879,5004,"Yeah. Get him out of here!"],[5013,5113,"Get him out! He's... hes's a liar!"],[5113,5183,"Get him out!"],[5392,5609,"Charles, you've lost!"],[5676,5814,"The land is mine."],[5814,5989,"Who says its yours?"],[6106,6406,"CV's asset proof is right here."],[7353,7603,"That's impossible!"],[7603,7745,"It's... it's... it's real?"]],"17":[[988,1292,"CV's asset proof is valid!"],[1301,1601,"Mr. Charles is eligible to participate in the bidding!"],[1626,2014,"Mr. Allen, if you're not going to continue to bid,"],[2014,2200,"please, stop disrupting!"],[2480,2629,"You worthless idiot!"],[2629,2769,"You said that this was full proof!"],[2769,2894,"How could you let this happen!"],[2927,3073,"I... I... I don't know!"],[3257,3492,"500 million, going once..."],[3666,3724,"going twice..."],[4049,4135,"Sold!"],[4160,4418,"Congratulations to Mr. and Mrs. Charles"],[4418,4526,"for winning the land."],[4537,4667,"FUCK!"],[4984,5271,"I've seen this host before at one of Mina's parties."],[5271,5417,"Could he recognize me?"],[5417,5576,"Mr. and Mrs. Charles,"],[5576,5716,"congratulations again on winning"],[5716,5868,"this wonderful plot of land."],[5907,6110,"Wait... what did... no..."],[6110,6285,"what did you just call her?"],[6343,6458,"Mrs. Charles."],[6488,6677,"We've met before, Jenny."],[6752,6931,"No, wait, you are..."]],"18":[[12,251,"Mr. Downton, I think you're mistaken."],[300,610,"He's my boss, not my husband."],[717,903,"Boss? That's impossible."],[942,1049,"That's right."],[1092,1225,"We're business partners."],[1263,1409,"Mr. Downton, you've been to more"],[1418,1550,"than one of my mother's galas."],[1605,1830,"Surely you wouldn't have mistaken my wife."],[1935,2201,"But Mrs. Mina always brings this woman to the gala."],[2298,2370,"Could it be?"],[2515,2694,"Is it because of the crowd?"],[2802,2960,"Are they playing some kind of game?"],[3111,3381,"I apologize. My mistake."],[4808,5196,"As far as I know, your company is collapsing."],[5196,5321,"You needed this land, didn't you?"],[5550,5840,"Mr. Charles, we're both in the same business."],[5890,6076,"Please, show me some mercy."],[6076,6238,"Give me a chance to redeem myself."],[6272,6656,"You had someone steal confidential files from me."],[6656,6802,"Save it for court."],[6915,7119,"I swear to you, if you do this..."],[7119,7310,"You do not want to do this!"],[7310,7377,"I'm telling you,"],[7377,7516,"you tell them to go back right now."],[7516,7652,"You do not want to do this!"],[7653,7739,"Come on!"],[7763,7904,"This is bullshit!"],[8379,8523,"Couldn't find this without you."],[8600,8825,"You're just a shameless mistress, Jenny."],[8833,8997,"Don't think for a second that you've won!"]],"19":[[29,191,"Still denying you're here for a sugar daddy?"],[262,446,"Who do you think you are seducing the CV CEO?"],[446,550,"Don't you know he's married?"],[558,667,"What are you talking about?"],[717,923,"From what I remember, Allen is married too."],[1057,1129,"Look at you,"],[1129,1271,"throwing around accusations."],[1376,1445,"You!"],[1470,1587,"I had him thrown out."],[1599,1721,"I can do the same with you."],[1768,2052,"If you think humiliating her will get you anywhere,"],[2052,2364,"I will share and expose all of your dirty little secrets"],[2364,2469,"to the entire world."],[2485,2759,"CV's president is actually defending this woman?"],[2781,3007,"Charles' wife just bid 10 million on him."],[3119,3391,"Yet, he's openly protecting another woman?"],[3436,3537,"That's crazy."],[3606,3762,"Shame on her."],[3762,3999,"She's trying to seduce Charles."],[3999,4220,"So he can abandon his wife."],[4228,4328,"Wow!"],[4330,4490,"Is she refusing to acknowledge me"],[4490,4725,"just to turn public opinion against Jenny?"],[4771,4835,"I shouldn't have come."],[4892,4950,"What?"],[5004,5096,"I'm sorry, Mr. Charles."],[5096,5280,"I shouldn't have accepted your invitation."],[5342,5405,"Wait, wait..."]],"20":[[271,396,"I'm sorry, Miss J."],[532,766,"I mean, I never expected inviting you tonight"],[766,910,"would cause you such distress."],[1088,1259,"I should be the one apologizing."],[1430,1514,"I failed you."],[1514,1730,"I didn't even get you enough information"],[1730,1860,"about your wife's betrayal."],[1885,1922,"I'm just..."],[2031,2093,"I'm sorry."],[2135,2218,"It's not your fault."],[2298,2331,"Just..."],[2448,2569,"let me make it up to you."],[2690,2911,"Why don't you join me for dinner at Eden Garden?"],[3257,3449,"You're inviting me to Eden Garden too?"],[3549,3604,"Who else?"],[3850,3944,"Oh, sorry about this."],[3979,4100,"I gotta take this."],[4391,4512,"I heard about what happened at the bidding."],[4540,4627,"How could you let Jenny"],[4627,4774,"go through all that humiliation?"],[4829,4888,"She was there?"],[4918,5070,"Don't be ridiculous, Charles."],[5085,5245,"You are her husband."],[5280,5480,"How could you let her get humiliated like that?"],[5538,5638,"She told you?"],[5784,5989,"Jenny is not like what you thought."],[5989,6222,"I've told her to go to Eden Garden."],[6222,6414,"Go there and talk about it face to face."],[6485,6588,"But I..."],[6634,6742,"He- Hello?"],[7040,7168,"She must have misunderstood"],[7168,7307,"when she saw Miss J."],[7361,7529,"Mr. Charles, unfortunately, I..."],[7529,7751,"can't go to dinner with you."],[7836,8039,"My husband is actually taking me out tonight."],[8557,8705,"It's alright. I actually..."],[8705,8833,"have to leave too."],[9004,9254,"But I can drive you if you want."],[9363,9693,"Thank you, but I want to go buy some stuff for him."],[9830,9891,"Okay."],[10564,10818,"Compared to her husband, I'm just nobody."],[11753,12149,"Lucky man, he's got such an integrated wife"],[12149,12341,"and she only loves him."]],"21":[[0,296,"This time, he'll recognize me at first glance."],[321,487,"Madam, thank you for all your help"],[490,600,"managing the restaurant"],[600,726,"for the past three years."],[820,1056,"Don't worry, it's thanks to you guys,"],[1056,1294,"otherwise, I wouldn't have made it this far."],[1334,1547,"Three years ago, Mom Mina worried"],[1547,1703,"I had no money to rely on."],[1714,1890,"So she gifted me the Eden Garden."],[1915,2094,"Madam, your VIP room is ready."],[2130,2269,"Would you want to wait in there?"],[2270,2354,"No, it's fine."],[2354,2562,"I wanna see Charles as soon as possible."],[2631,2815,"So, your guest is Mr. Charles?"],[4900,4960,"Stop!"],[5321,5483,"You were with Allen yesterday,"],[5500,5701,"and now you're kissing Johnson's ass?"]],"22":[[79,116,"Shameless!"],[130,249,"So you figured it out."],[278,533,"There's nothing left to hide now."],[542,692,"So what? What are you gonna do about it?"],[738,814,"He's a loser!"],[814,956,"Why are you even with this man?"],[960,1072,"Just so you know,"],[1072,1221,"Mr. Allen promised me"],[1221,1409,"an executive position at his company."],[1480,1598,"I'm gonna be rich again."],[1622,1912,"I take it you don't know Allen is in jail already."],[1940,1994,"What?"],[2064,2252,"Honey, don't listen to her."],[2318,2530,"Allen just got taken away to help investigate"],[2530,2620,"but he'll be back soon."],[2627,2780,"You think you can mess with me"],[2803,3039,"because Mr. Charles has your back."],[3046,3144,"But he's married."],[3194,3475,"And when he's tired of you, I'm gonna make you pay."],[3712,3776,"Call security."],[4170,4300,"You don't have any proof now."],[4335,4550,"This is the biggest restaurant in downtown."],[4569,4779,"The owner is powerful and mysterious."],[4788,4975,"You think you can command their security?"],[4975,5103,"Are you serious?"],[5130,5499,"I wonder when I became powerful and mysterious."]],"23":[[12,362,"I wonder when I became powerful and mysterious."],[421,462,"Huh?"],[542,667,"What do you mean? You own this place?"],[1276,1514,"Come on, CV owns this place."],[1564,1684,"Who the fuck are you?"],[1737,1792,"Hmm?"],[1843,2064,"You deserve bad luck."],[2173,2329,"You know, she's been married for three years"],[2329,2496,"and she's never even met her husband."],[2581,2786,"Why are you here, looking for a sugar daddy?"],[2786,2907,"Sorry to disappoint you,"],[2915,3027,"but I'm actually here"],[3027,3178,"to meet my husband."],[3461,3499,"Wait, wait."],[3578,3669,"Where did you book?"],[3724,3782,"The bathroom?"],[3824,3902,"Oh, wait, wait."],[4029,4160,"The trash can in the kitchen."],[4383,4537,"Maybe if you beg,"],[4587,4779,"I'll let you serve me in the VIP room."],[4779,4929,"I bet you've never been here, huh?"],[4967,5131,"Don't flatter yourself, Jennifer."],[5176,5326,"The VIP room..."],[5326,5571,"is actually already booked for me and my husband."],[5897,6085,"I thought you knew your shit."],[6172,6328,"But this is... this is bullshit!"],[6382,6500,"If you book the VIP room,"],[6500,6598,"why don't you go in there"],[6598,6706,"instead of standing here?"],[6740,6785,"You know what?"],[6894,7177,"Keep standing here like the prostitute you are."]],"24":[[116,182,"I'm going."],[614,744,"Yeah, just go."],[792,1010,"Hope you don't get kicked out while eating."],[2198,2255,"Miss J?"],[2427,2498,"What're you doing here?"],[2556,2683,"Weren't you supposed to be with your husband?"],[2848,2965,"Mr. Charles?"],[3036,3300,"I didn't expect him to be here with his wife."],[3374,3499,"Dining at my restaurant."],[3532,3678,"Why don't you go inside?"],[3728,3827,"Do you need a reservation?"],[3849,4165,"No, no, I'm just waiting for my husband."],[4348,4445,"Why not wait inside?"],[4445,4571,"My wife is here."],[4592,4738,"You could gather more evidence."],[4745,4882,"Oh, but..."],[4892,4970,"Sir,"],[4980,5082,"and Mrs. Charles."],[5089,5191,"The food is ready."],[5191,5272,"Shall we begin?"],[5372,5468,"- What did you just call me? - What did you just call her?"]],"25":[[10,104,"Mrs. Charles."],[129,216,"What's the problem?"],[271,376,"- You can't call me that. - You can't call her that."],[490,638,"What should I call you then?"],[658,730,"Enough."],[814,1148,"This is Miss J. My... friend."],[1242,1476,"Please be sure to see that she gets a better room."],[1518,1705,"Oh, that's... I already booked-"],[1714,2006,"No, come on. I insist. I have to meet someone,"],[2006,2158,"otherwise, I would show you to your room."],[2158,2298,"But please take care of her."],[2298,2385,"It's good to see you."],[2439,2628,"I told you not to call me that."],[2643,2783,"Now, look at this mess."],[2840,2898,"Miss J..."],[3837,3934,"Thank you, honey."],[3966,4131,"You must've paid quite a bit for this."],[4245,4462,"Luckily, I got a friend working here."],[4529,4692,"He told me this is the boss's room."],[4775,4829,"It's nothing, babe."],[4925,5025,"Just a meal."],[5130,5213,"Nothing big."],[5572,5702,"I gotta go use the restroom."],[6001,6060,"I'll be right back."],[6110,6189,"Wait for me here, babe."],[6936,7131,"Honey, why are you back so soon?"],[7257,7679,"So this is the good wife my mom keeps talking about."],[7726,7955,"Again, hanging out with another man"],[7955,8087,"even before dating me."],[8216,8408,"Mr... Mr. Charles?"],[8500,8718,"Is he coming to ask me about the asset proofs?"]],"26":[[75,367,"Charles, we had a misunderstanding"],[367,571,"about Allen and the asset proofs."],[608,728,"There's no misunderstanding."],[804,856,"There's none of that."],[1076,1126,"Okay then..."],[1250,1447,"Then why'd you come here for?"],[1517,1635,"To put me in jail?"],[1689,1782,"No."],[1820,1981,"If I put my wife in jail,"],[1981,2102,"that would be a humiliation."],[2108,2198,"I'm here to divorce you."],[2310,2549,"What? A divorce?"],[2588,2763,"I agreed to meet you here"],[2763,2928,"because I need to divorce you."],[3015,3211,"Maybe if you beg,"],[3224,3420,"I'll let you serve me in the VIP room."],[3458,3591,"I bet you've never been here, huh?"],[3627,3712,"No way."],[3742,3972,"Is Charles really Jenny's husband?"],[4079,4366,"Right! I wanted to meet you!"],[4854,4951,"Darling..."],[5023,5246,"You have no idea how much I missed you."],[5317,5464,"I have been living alone"],[5464,5699,"these past three years without you."]],"27":[[8,59,"I admit."],[196,340,"I feel guilty for leaving"],[340,503,"without saying a word after our marriage."],[1172,1283,"There's no love between us."],[1330,1426,"Like this wine."],[1547,1620,"One swirl."],[1705,1792,"And it will dry out."],[1910,2072,"Our divorce is best for both of us."],[2377,2741,"If you agree, there will be compensation."],[2811,2867,"Compensate?"],[2952,3027,"How?"],[3319,3550,"It's already this late and he's still not here."],[3599,3840,"Have we missed each other? Is he already inside?"],[5246,5340,"He's already here."],[5618,5689,"Darling, I..."]],"28":[[19,144,"What is she doing here?"],[181,291,"Did she notice anything?"],[367,600,"How could Charles be in the room my husband booked?"],[633,830,"Did the manager give our room to him?"],[859,1085,"How did this little cunt find this place?"],[1126,1263,"She can't ruin my plans."],[1280,1472,"No way! Jennifer is his wife?"],[1493,1835,"I'm so sorry, I'm really drunk."],[1868,2114,"So, I must have walked into the wrong room."],[2335,2475,"Honey, come back here!"],[2686,2814,"I'll give you five million. Now."],[2861,3093,"Oh, darling."],[3190,3495,"CV is worth a hundred billion dollars a year."],[3553,3663,"Five million is nothing!"],[3770,3846,"What do you want then?"],[3908,4153,"Now that I've got a rich husband,"],[4183,4352,"I'm not letting him go so easily."],[4408,4533,"I don't want a divorce."],[4710,4849,"You may not love me now,"],[4849,5015,"but love develops over time,"],[5015,5173,"and one day, you will love me."],[5173,5238,"Enough!"],[5330,5559,"I will never love someone like you."],[5622,5790,"If you don't agree to the deal,"],[5840,6068,"then I'll do whatever is necessary to divorce you."],[6385,6570,"Oh, honey, you don't have to be so harsh."],[6681,6883,"I'll agree. On one condition."],[6969,7155,"You give me half of CV's assets."],[7304,7381,"No way."],[7475,7621,"So much for wanting to talk with me."],[7728,7864,"I'm done wasting my time with you."]],"29":[[283,440,"So, Charles' wife is Jennifer."],[638,930,"Look, I thought you knew your shit."],[963,1213,"Keep standing here like the prostitute you are."],[1317,1529,"I guess he's really better off getting a divorce."],[1634,1774,"But Jennifer's with Johnson."],[1789,1959,"If I can get proof of the affair,"],[1959,2142,"I can help Charles."],[5155,5334,"Come on, hurry up."],[5922,6043,"What did you... Fucking thief!"],[6060,6140,"Hi, J."],[6202,6396,"I need you to gather some more evidence"],[6396,6516,"on my wife's affair."],[6544,6573,"I need..."],[6690,6923,"Hey, wait, wait, you can't leave."],[7178,7259,"What happened?"],[7278,7349,"Where are you?"],[7465,7565,"J... J!"]],"30":[[358,446,"Hey, you, Janitor."],[475,604,"Did you see a woman run past here?"],[742,815,"Where did she go?"],[1071,1229,"Bitch, you're dead."],[1704,1810,"Good luck with that."],[1810,2051,"This building has 38 floors."],[2240,2430,"Okay, I've got all the evidence"],[2430,2573,"of Jennifer and Johnson's affair."],[2677,2781,"I need to get it to Charles."],[2865,3005,"Oh my God, my husband."],[3135,3324,"He must think I stood him up."],[3663,3796,"J! J!"],[3909,3995,"Miss J!"],[4120,4280,"Why haven't you been returning my calls?"],[4379,4479,"You had me worried sick!"],[4819,4876,"You..."],[4999,5159,"You were worried about me?"],[5171,5400,"Yeah, you're my detective."],[5424,5638,"And you're still investigating my wife."],[5722,5809,"Something happened to you,"],[5905,6021,"I'd have to get another detective,"],[6060,6154,"and that would be a waste of my time."],[6252,6306,"I get it."],[6375,6424,"But don't worry,"],[6424,6589,"everything is done now."],[6664,6773,"Jennifer is your wife."],[6784,6957,"Why didn't you mention that before?"]],"31":[[16,125,"This is the first time we met."],[221,379,"But there won't be a second time."],[425,521,"And don't mention her again."],[596,767,"I don't give a shit about Jennifer."],[1000,1184,"And why are you out here risking getting a cold?"],[1226,1267,"It's freezing."],[1488,1597,"You don't understand."],[1772,1864,"Yeah, I don't."],[1997,2086,"I don't understand"],[2086,2191,"why your stupid husband"],[2191,2289,"would let you stand around,"],[2289,2485,"waiting for nothing!"],[2485,2619,"Come with me. Come on."],[2619,2731,"No! I'm waiting for him."],[2731,2919,"No. You gotta go. It's too cold."],[2919,2953,"No!"],[2953,3085,"Come on. You're gonna get to..."],[3085,3232,"J!"],[3232,3899,"J! J! J! J..."]],"32":[[809,1055,"Is it worth it for someone like him"],[1055,1317,"who doesn't even care about you?"],[2043,2293,"Sorry. You fainted."],[2293,2430,"And I brought you back to my place"],[2430,2579,"without your permission."],[2740,3028,"Thank you, Mr. Charles."],[3028,3365,"Thank you for taking care of me."],[3365,3682,"He's right. If my husband really cared about me,"],[3682,3891,"he wouldn't keep standing me up."],[3920,4142,"Every time I was in danger,"],[4190,4416,"Mr. Charles was always by my side."],[4416,4641,"If only he were my husband."]],"33":[[175,346,"Who would be here this late?"],[546,614,"Is it Jennifer?"],[654,829,"If Jennifer sees me with her husband,"],[829,997,"she'll definitely misunderstand."],[1026,1076,"I'll go check."],[2052,2089,"Mom?"],[2089,2177,"What took you so long?"],[2235,2398,"Are you hiding someone in there?"],[2448,2495,"Yeah..."],[2527,2560,"What?"],[2644,2765,"I mean, I'm..."],[2802,2915,"Glad that was close."],[2940,3078,"I definitely would be misunderstood"],[3078,3157,"if I were there."],[3236,3325,"What a bitch!"],[3465,3624,"Charles, you think this is funny?"],[3824,3970,"You're lucky this is just a joke."],[4054,4203,"If you're cheating on your wife,"],[4203,4379,"I swear you'll regret it."],[4412,4673,"Mom, what are you doing here at this hour?"],[4733,4825,"Well, if either one of you"],[4825,4950,"would've answered your phones,"],[4950,5072,"I wouldn't have bothered to come."],[5488,5715,"So, what happened after the dinner?"],[6744,6835,"We're getting a divorce."],[6894,6962,"No way!"],[7048,7240,"Jenny's been waiting for you for three years."],[7298,7415,"You cannot divorce her."],[7424,7520,"She's cheating on me."],[7774,7828,"What was that?"],[7937,8039,"Stop, Mom."],[8039,8087,"Mom!"]],"34":[[16,246,"Mom, stop! Please, stop!"],[280,421,"Nothing is set in stone."],[421,563,"Haven't been any decisions made."],[592,828,"She doesn't want to be found if she's in there."],[875,980,"I should respect that."],[1213,1442,"You swear you won't get divorced?"],[1458,1607,"You haven't given me her number,"],[1607,1710,"so how am I supposed to"],[1710,1810,"keep in touch with her?"],[1881,2077,"Well, I haven't really considered all this."],[2085,2299,"I thought you'd be strangers for three years"],[2299,2458,"and I'd be the go-between person."],[2469,2903,"I didn't think it would really make this worse."],[2940,3293,"Oh, but I do have her card. She's a great detective."],[3545,3642,"No way."],[3642,3878,"I've been wrong this whole time."],[3878,3987,"She's actually my wife."],[4029,4179,"You should go there"],[4179,4348,"and clear out this misunderstanding."],[4608,4773,"It's late. I should leave."],[5893,5982,"Are you okay?"],[6113,6249,"You're burning up. Come here."],[6477,6535,"Be careful."],[6729,6806,"Okay."],[8635,8796,"No, I'm married."],[9638,9778,"I have to figure this out today."]],"35":[[834,1053,"Oh no, I didn't answer my phone last night."],[1096,1218,"She must be so worried."],[1222,1351,"I need to go see her."],[1472,1885,"Aunt Mina, your food is still the best."],[1985,2212,"So one thing I miss the most over the years abroad."],[2285,2432,"Enjoy it, have more if you want."],[2498,2641,"What's going on with Jenny?"],[2694,2854,"I've been trying to call her since last night,"],[2854,2973,"but she's not answering."],[3028,3207,"Is she mad at Charles?"],[3319,3520,"You haven't reached out in years,"],[3520,3705,"and now you're here just for my food?"],[3750,4033,"Aunt, I heard Charles is back."],[4033,4151,"I just came to say hi."],[4208,4362,"He's always been my role model."],[4396,4477,"True."],[4477,4579,"You should take the opportunity"],[4579,4750,"to learn management from him."],[4750,4900,"Why should I learn from him?"],[4959,5138,"He's just got a better background."],[5138,5285,"I'm the one who should be the heir."],[5342,5528,"So Aunt, where is Charles?"],[5555,5757,"You won't be seeing him today."],[5757,6005,"He's busy dealing with his wife."],[6005,6210,"The wife he married three years ago?"],[6272,6527,"They were married, but they haven't..."],[6527,6748,"seen each other in three years."],[6790,6939,"They've never even met?"],[6976,7133,"Maybe that's a good opportunity."]],"36":[[12,283,"Well, you gotta be patient, Aunt."],[329,513,"Roman wasn't built in a day."],[1084,1292,"Mrs. Mina, the company is holding"],[1292,1434,"an emergency board meeting."],[1434,1518,"We may need you here."],[1668,1889,"I have to go to the company for something urgent."],[1901,2041,"That's okay. Don't worry about me."],[2052,2205,"I'll just wait for Charles to come back."],[2252,2481,"I'll call Charles and have him come back sooner."],[3878,4016,"Mom, I'm so sorry, I..."],[4775,4820,"You're..."],[4984,5160,"You don't... know me?"],[5346,5435,"Are you my..."],[5435,5568,"my husband Charles?"]],"37":[[45,258,"She really doesn't know what Charles looks like."],[312,441,"Three years of marriage..."],[483,664,"And he hasn't even sent her a photo."],[688,888,"Yes, I'm Charles."],[942,1120,"Mina loves this girl so much."],[1167,1359,"If I take Charles' place and use her,"],[1455,1653,"I could get a nice share of CV."],[1705,1893,"I'm so sorry, I..."],[2056,2213,"I've never met you before, and"],[2213,2451,"you didn't show up so many times, so I just..."],[2460,2567,"It's okay."],[2595,2811,"As you said, we've never met before."],[2877,3062,"It's no surprise you don't recognize me."],[3140,3437,"But I've been noticing you for a long time."],[3540,3753,"I recognize you the first time I saw you."]],"38":[[350,725,"Hello, I am looking for the detective on this card."],[934,1024,"Oh, J, she's..."],[1030,1315,"Hey! What's the matter?"],[1760,1986,"Darling, why didn't you let me know you were coming?"],[2077,2200,"You're J, too?"],[2310,2529,"J's for Jennifer and here I am."],[2573,2657,"Is there a problem?"],[2719,3132,"Jennifer? But mom told me her name was Jenny."],[3194,3286,"Did I mishear her?"],[3390,3481,"What's wrong?"],[3493,3649,"You don't seem too happy that I'm J."],[3678,3813,"If it's not Miss J,"],[3813,4028,"then maybe this marriage should end soon."],[4070,4160,"You came all the way here"],[4160,4289,"just to ask me if I'm J?"],[4332,4407,"Of course not."],[4407,4609,"I came to invite you on a date."],[4688,4762,"A date?"],[4800,5019,"Sure. To do my job as a good husband."],[5672,5885,"This is the only way for J to meet with her"],[5885,6256,"and make it easier for her to investigate."]],"39":[[12,147,"How did you know it was me?"],[204,305,"You look stunning."],[458,692,"As soon as I saw you, my heart started racing."],[692,916,"I couldn't focus on anyone else."],[916,1180,"Am I really that special to you?"],[1397,1616,"Why did you stand me up so many times?"],[1651,1780,"It's a long story."],[1822,1982,"Let's go inside and talk about it."],[3199,3433,"I missed our last few dates"],[3433,3682,"because I had to go back to work."],[3712,3895,"Oh, it's because of work."],[3999,4091,"I thought..."],[4175,4271,"What?"],[4354,4567,"I thought you were unhappy with our marriage"],[4567,4790,"and wanted to end things."],[4867,5013,"That's my fault."],[5013,5171,"I've left without saying anything,"],[5230,5463,"I'm sorry I made you overthink."],[5476,5789,"Don't worry, I'll make up for everything I owe you,"],[5893,5964,"from now on."],[6039,6118,"This is my number,"],[6264,6435,"If you need anything, just call me."],[6544,6748,"I'll be there whenever you need me."],[7353,7574,"Why do I resist his touch so much?"],[7626,7828,"I feel nothing when it's Charles."],[8382,8452,"Come on."],[8512,8597,"We're married."],[8660,8767,"Why are you still shy?"],[8820,8939,"I'm married."],[8939,9145,"This man is my husband."],[9170,9450,"I can't let any thoughts of cheating cross my mind."],[9580,9768,"I'm not shy, I just..."],[9880,9976,"need some time."],[10305,10384,"Let me help you."]],"40":[[554,689,"It's a client."],[1465,1541,"Hello?"],[1568,1664,"You got a minute?"],[1751,1883,"Is this about work?"],[1906,2143,"Yeah, I'm at the mall with my wife."],[2198,2483,"I need you to follow her and gather more evidence."],[2502,2751,"Honey, do you like this one?"],[2802,3009,"I can't stand this woman for a second."],[3039,3299,"Once Miss J gets here, I'm out of here."],[3348,3515,"Okay, I'll be right there."],[3566,3681,"Keep it low key."],[3719,3798,"Don't blow it."],[4104,4338,"You heard that? Duty calls."],[4433,4673,"It's okay. I'll be waiting for you."],[5163,5325,"Acting like everyone cares."],[5380,5595,"You're just a girl Charles dumped."],[6068,6228,"No, no!"],[6240,6372,"Jennifer was just my hookup."],[6464,6558,"Jennifer?"],[6627,6895,"Jenny and Jennifer."],[7057,7209,"Interesting."]],"41":[[387,625,"I'll give Mr. Charles the memory card this time."],[2603,2700,"What are you doing here?"],[2760,2994,"I, I-"],[2994,3101,"Are you following me?"],[3107,3511,"Actually, I was here to buy you a ring."],[3616,3818,"Looks like everything Mina said is true."],[3870,4074,"He really is preparing our wedding."],[4074,4194,"Why are you here?"],[4249,4495,"You told me you were leaving for work."],[4554,4667,"So, why are you here?"],[4704,4800,"Are you lying to me?"],[4800,4850,"No!"],[4850,4996,"No, no, no, of course not."],[4996,5071,"I-"],[5080,5361,"If he sees Charles, he'll definitely misunderstand"],[5361,5580,"and think there's something between us."],[5593,5701,"I-"],[5719,5947,"I finish work early"],[5947,6241,"and I thought I'd come get you a gift."],[6585,6706,"What a coincidence."],[6802,6938,"Let's go see what you like, then."],[8420,8470,"Oh!"]],"42":[[83,266,"Cousin, what a coincidence."],[404,596,"I didn't expect to run into you here."],[596,806,"This must be your wife, right?"],[1113,1187,"No way!"],[1218,1452,"My client is actually my husband's cousin?"],[1739,1822,"You two?"],[1888,2036,"Oh, I almost forgot."],[2036,2230,"This is my wife."],[2957,3081,"How could she be your wife?"],[3232,3369,"You never told me you got married."],[3435,3549,"It was three years ago."],[3581,3674,"Which we've never held the wedding,"],[3674,3807,"so I never mentioned it."],[3807,3993,"I was wanting to invite you before the wedding."],[4029,4137,"That makes sense now."],[4208,4385,"Jonathan's last name is Charles too."],[4740,4931,"Whoa! Hey! What's going on?"],[4931,5024,"Hey, stop!"],[5213,5334,"Why did you do that?"],[5354,5484,"You are loyal to him,"],[5493,5605,"but you don't know what he did."],[5630,5731,"You're married!"],[5769,5847,"You were posting"],[5847,5990,"with another woman six months ago!"],[6168,6344,"What other girl?"]],"43":[[9,222,"He's been cheating while he was abroad?"],[250,407,"Woman? That was just a friend!"],[437,546,"Yeah, it didn't look like it."],[588,641,"How come?"],[696,923,"And also, why are you defending my wife?"],[946,1163,"Like there's something going on between you two."],[1194,1238,"Hmm?"],[1410,1668,"Okay, just enough with the accusations."],[1705,1784,"Hey, I..."],[1856,1989,"I trust my husband."],[2010,2139,"He's not that kind of person."],[2419,2448,"You misunderstood me, cousin."],[2448,2568,"You misunderstood me, cousin."],[2619,2762,"But since we're all here,"],[2836,2994,"how about we grab dinner together?"],[3040,3144,"Clear the air."],[3153,3293,"- Maybe not. - Why not?"],[4679,4821,"What an idiot!"],[4860,5080,"Can't even recognize her own husband?"],[5146,5450,"Looks like I'm definitely going to be CEO's wife."],[5714,5839,"Darling, what do you wanna eat?"],[5880,5995,"Oh, are you okay?"],[5995,6151,"Um, wait."],[6227,6316,"I'll just- I'm fine."],[6316,6433,"I'll clean up myself."],[6831,6923,"I'm gonna use the restroom."],[7194,7309,"He's my husband."],[7309,7476,"Why do I feel so uncomfortable"],[7476,7560,"with his touch?"],[7732,7849,"Mr. Charles?"],[7907,7982,"What are you-"]],"44":[[230,313,"Mr. Charles?"],[413,530,"What are you doing here?"],[530,658,"Won't Jennifer find out?"],[704,877,"Jennifer knows this Mall well."],[925,1111,"Clearly, she's been here before."],[1142,1357,"I agreed to dinner so that you could investigate"],[1357,1489,"who she came with earlier."],[1564,1768,"Oh, that's it?"],[1789,1895,"I thought-"],[1935,1951,"What?"],[2140,2316,"You wanna walk out with these stains?"],[2515,2679,"Why don't I resist his touch?"],[2894,3151,"Jenny, you've waited for Charles for three years."],[3257,3382,"You can't betray him."],[3575,3742,"I can't believe you two are married."],[3791,3962,"You know he's a notorious playboy."],[3978,4049,"Don't you know that?"],[4137,4316,"My mom chose him for me."],[4375,4604,"My mom would never do anything to hurt me."],[4675,4879,"And I won't let anyone slander him,"],[4913,5060,"including you, Mr. Charles."],[5459,5712,"I found evidence from Johnson of Jennifer's affair."],[5726,5809,"I recorded it."],[5860,6007,"Once this case is settled,"],[6097,6297,"we will not have to see each other anymore."]],"45":[[91,208,"Where is it?"],[241,408,"I swear, I put it in my pocket."],[408,554,"I don't know where it could've gone."],[1111,1219,"Looks like you're the hookup"],[1219,1363,"Johnson was talking about,"],[1363,1477,"dear Mrs. Charles."],[1655,1858,"I don't know what you're talking about."],[1858,1985,"I need to see my husband."],[1985,2216,"Don't you worry that this recorder"],[2224,2439,"might end up on Charles's desk?"],[2827,2942,"What do you want?"],[3070,3266,"Cooperation, Mrs. Charles."],[3294,3455,"So to get what we both want."],[3702,3782,"Deal."],[3923,4135,"Fake will always be a fake,"],[4208,4366,"and Charles is not stupid."],[4483,4581,"He won't be fooled for long."],[4688,4963,"You can trade anything with this certificate."],[5972,6082,"Jonathan!"]],"46":[[12,325,"Um, this is my girlfriend."],[402,444,"Yeah."],[444,513,"Yeah?"],[620,780,"Charles is here too with his wife."],[800,904,"They just went to the bathroom."],[967,1146,"Charles brought his wife to meet you?"],[1201,1364,"Looks like he's finally accepted Jenny."],[1390,1518,"Mom, why are you here?"],[1706,1794,"Let me guess."],[1840,1956,"Someone complained."],[1976,2117,"Nothing to do with your wife."],[2135,2456,"I own this mall, so I take her here all the time."],[2464,2617,"I just happened to have time today"],[2617,2737,"and thought why not come by."],[2748,2972,"I didn't think I'd run into you all."],[2990,3210,"It's Mom who brought her here all this time."],[3265,3360,"Did I get her wrong?"],[3538,3632,"Charles,"],[3651,3889,"were you bullying her while I wasn't around?"],[4045,4250,"Oh, Charles is so concerned."],[4291,4474,"How could he ever bully anyone? Don't worry."],[4775,5042,"I'm so glad you're all getting along so well."],[5188,5301,"I'm not worried now."],[5472,5640,"Charles, these are for your wife."],[5645,5824,"Make sure you give them to her for me."],[5826,5951,"And treat her well."],[5976,6081,"Take good care of her."],[6118,6168,"I'm leaving."],[6252,6331,"Bye."],[7148,7357,"Honey, something came up and I have to leave."],[7399,7656,"Sorry about that. Please apologize to them for me."],[7742,7811,"Okay."],[7874,8065,"Well, you heard that."],[8119,8195,"I should probably leave."],[9106,9223,"These are for your wife."],[9269,9382,"Give these to her for me."],[9551,9767,"Your mom just told you to treat me well,"],[9767,9841,"and now that she's left,"],[9841,9983,"you're gonna leave me here all alone?"],[10005,10264,"My mom said to give these to my wife."],[10443,10596,"You are not my wife."]],"47":[[4,105,"I'm not your wife?"],[215,309,"Okay, you want a divorce?"],[309,361,"Fine."],[361,562,"But accusing me of my identity?"],[567,700,"Okay, that's quite unnecessary."],[1105,1284,"Everything lies, but..."],[1422,1564,"this is written on paper."],[2265,2399,"Did I overthink again?"],[2444,2573,"Why does Mom say that?"],[3107,3260,"Let's make this clear, honey."],[3359,3586,"I'm the one who can choose a divorce, not you."],[3660,3761,"Waste of time."],[3778,3870,"Fine."],[3910,4045,"Hay, you want a divorce?"],[4104,4278,"We'll hold a press conference tonight,"],[4308,4637,"as CV CEO and publicly annouce me as your wife."],[4637,4800,"And..."],[4800,4956,"Acquire our detective agency"],[4971,5121,"and make me in charge."],[5128,5235,"We're divorcing."],[5280,5530,"What's the point of announcing you as my wife?"],[5538,5672,"You don't understand."],[5701,5893,"The title of Mrs Charles"],[5893,6164,"holds immense benefits and respect."],[6314,6409,"So, honey,"],[6502,6639,"will you agree?"],[6744,6829,"Fine."],[6952,7207,"Miss J, I hope you won't let me down."],[7240,7386,"Find the evidence of her affair."],[7803,7862,"No way."],[7870,7995,"I came in from here."],[8003,8137,"The memory card should've been here."],[8158,8224,"Where is it?"],[8324,8370,"Finally."],[8400,8462,"Where'd you go?"],[8516,8641,"I'm starving."],[8641,8812,"You've gotta make it up to me for that."],[8871,9048,"Oh, why don't we go back to my apartment"],[9048,9230,"and I'll cook for you as compensation."],[9365,9446,"Sounds perfect."]],"48":[[700,975,"You own CV's billion-dollar empire, Charles,"],[996,1084,"but soon,"],[1084,1259,"you will lose what matters the most to you."],[1711,1887,"I didn't know you could cook this well."],[1911,2043,"I'm so lucky."],[2143,2281,"Well, enjoy then."],[2727,2821,"It's work."],[3061,3190,"You got any time tonight?"],[3440,3589,"Perhaps not."],[3678,3871,"Jennifer asked me to hold a press conference"],[3871,3993,"to admit she's my wife."],[4076,4216,"You have to do something,"],[4216,4312,"or I could do nothing"],[4312,4446,"but give what she wants."],[4654,4790,"I'm sorry, I have to..."],[4840,4963,"It's fine."],[4996,5190,"You've been working all afternoon."],[5213,5418,"Haven't even had a sip of water, at least..."],[5497,5604,"drink this first."]],"49":[[870,1080,"Alright, you, enjoy the food"],[1080,1231,"and I promise I'll be back soon."],[1600,1662,"Three."],[1800,1885,"Two."],[2052,2095,"One!"],[2223,2383,"Jenny, what's wrong?"],[2674,2770,"Are you feeling sick?"],[3007,3130,"Let me help you to bed."],[3728,3995,"Charles, soon your woman will be mine."],[4066,4224,"And then everything you own"],[4224,4329,"will belong to me."],[4387,4671,"No, no, stay away from me."],[4737,4840,"Don't touch me."]],"50":[[5,87,"You belong to me."],[87,132,"No!"],[150,210,"STOP!"],[279,343,"Damn it!"],[362,471,"Why is he here now?"],[555,617,"J!"],[1070,1164,"What are you doing here?"],[1172,1258,"We're married."],[1264,1381,"Why can't I be here?"],[1430,1670,"You, barged into my wife's apartment"],[1670,1776,"in the middle of the night,"],[1795,1917,"What are you trying to do?"],[1917,2038,"She's my client."],[2058,2180,"She wasn't answering my calls,"],[2180,2281,"so I came to check on her."],[2296,2389,"What's wrong with her?"],[2389,2544,"She wasn't feeling well tonight."],[2544,2681,"Why didn't you bring her to the hospital?"],[2681,2840,"I'll take care of it."],[2840,2994,"You should leave, Charles."],[2994,3184,"When she gets better, she'll let you know."],[3184,3302,"I'm so hot..."],[3840,3937,"You drugged her?"],[3937,4074,"She's my wife!"],[4074,4206,"Whatever happens between us"],[4206,4399,"is perfectly justified, isn't it?"],[4682,4762,"Come on."],[4765,4907,"I'm taking you with me."],[5030,5138,"You can't take her!"]],"51":[[10,122,"Who knows what you're gonna do"],[122,240,"to her in this state?"],[240,365,"I'm not that despicable!"],[390,573,"Yes, I have feelings for her."],[590,809,"But I would never take advantage of her"],[809,1063,"or confess my feelings while I'm still married!"],[1125,1191,"Come on."],[1870,1976,"You'll be okay."],[2520,2612,"Charles?"],[2627,2684,"Yeah."],[2698,2752,"You okay?"],[2752,2852,"No, no, no, no."],[2852,2911,"Stop."],[2911,2967,"Stop."],[2985,3313,"That Charles she's calling must be Jonathan."],[3353,3524,"If I take advantage of her like this,"],[3561,3698,"how am I any different from him?"],[3760,3873,"I'm not Jonathan."],[3930,4014,"You'd regret this."],[4144,4347,"I know you're not Jonathan."]],"52":[[1362,1439,"What's going-"],[1451,1572,"You're a good detective."],[1652,1734,"You were drugged."],[1860,1960,"Didn't you know that?"],[2000,2066,"What?"],[2150,2217,"Drugged?"],[2265,2351,"No, no-"],[2380,2458,"That can't be."],[2458,2684,"I was at home with my husband. He-"],[2902,2983,"No!"],[3012,3140,"Stay away from me."],[3140,3244,"Don't touch me."],[3307,3478,"Are you saying he drugged me?"],[3862,4200,"- No, no. That's impossible. - Stop lying to yourself!"],[4250,4334,"He's my cousin."],[4334,4485,"I know what he's capable of."],[4500,4714,"No, I don't believe he would do this, okay?"],[4714,4860,"So, just stop saying that."],[4860,5132,"Or I have to terminate our contract immediately."],[5180,5261,"For him?"],[5451,5664,"You would be willing to throw everything away?"],[5714,5833,"What about me?"],[5975,6132,"Mr. Charles, you're just..."],[6151,6345,"You're just my employer."],[6740,6918,"Then there's no need for cooperation."],[7210,7282,"You're-"],[7421,7568,"You're firing me?"],[8290,8384,"You know what?"],[8580,8750,"I should've never taken your case."]],"53":[[107,307,"Really? That's it?"],[327,427,"After all that I did,"],[427,594,"not even a thanks..."],[1160,1250,"What?"],[1270,1466,"Is Charles under Jennifer's threat?"],[2072,2268,"Look, that's the CEO and his wife."],[2302,2500,"Well, look at her dress."],[2539,2696,"This season's couture"],[2696,2970,"is worth tens of thousands of dollars."],[2985,3114,"He loves her so much."],[3120,3246,"Johnson bought it."],[3275,3416,"That's a lot of money."],[3422,3555,"You got what you want."],[3620,3722,"Now keep your promise"],[3722,3899,"and sign the divorce paper."],[3920,4191,"Darling, what's the hurry?"],[4223,4363,"Once the press conference is over,"],[4363,4579,"I'll agree and sign the divorce."],[4883,5011,"Ladies and gentlemen,"],[5011,5223,"esteemed members of the press,"],[5321,5613,"tonight I want to introduce you all to my wife."],[5993,6131,"Good evening, everyone."],[6150,6363,"I am Jennifer, Charles's wife."],[6389,6619,"During my husband's three years abroad,"],[6619,6865,"I managed the company in his absence."],[6936,7111,"CV has reached its full"],[7111,7406,"success and potential because of me."]],"54":[[32,251,"Wow, what a hell of a woman!"],[305,487,"Charles is incredibly lucky to have her."],[487,625,"Three years of management"],[625,825,"and she's never taken credit."],[909,1050,"Mrs. Charles is remarkable."],[1070,1280,"The management Mrs. Charles speaks of?"],[1286,1661,"Does that include your affair with CV's former executive?"],[1850,2148,"Security, security! Get this maniac bitch out of here!"],[2190,2265,"Hey, stop!"],[2307,2384,"Don't touch her."],[2580,2786,"Defamation will land you in jail."],[3002,3140,"Jonathan's destroyed the memory card."],[3194,3324,"Show me what you got, bitch."],[3399,3513,"Look at the screen."],[4340,4619,"Baby, this dress is so expensive."],[4683,4850,"You know I just got fired from CV."],[4938,5125,"I'll be there as Mrs. Charles tonight."],[5238,5382,"Getting you back into CV?"],[5402,5509,"Totally a piece of cake."],[5790,5853,"Come on."],[5853,6010,"I'll make it up to you after the press."],[6289,6448,"Uh, that's- that's fake!"],[6485,6575,"That's fake!"],[6833,6975,"Uh, turn it off!"],[7474,7545,"You bitch!"],[7603,7756,"You're just jealous because I'm better than you"],[7756,7836,"at detective work."]],"55":[[12,130,"Touch her again"],[130,308,"and you will regret it."],[360,439,"Look!"],[465,650,"Look, she's seducing my husband."],[650,842,"So now she slanders me out of spite?"],[946,1167,"I don't care what others think of me."],[1334,1475,"But you, Charles."],[1597,1881,"I helped manage your company and..."],[1889,2036,"and this is how you repay me?"],[2344,2641,"Jennifer, you keep claiming you've been managing CV."],[2715,2937,"So, let me ask you one thing."],[3002,3144,"How come you said you were"],[3144,3349,"better at detective work than me?"],[3420,3661,"Does that mean you can be in two places at once?"],[3708,4017,"Managing CV while also being a detective?"],[4217,4296,"Sure!"],[4296,4442,"Sure I can."],[4442,4549,"What is this?"],[4604,4708,"Attendant sheet."],[4821,5049,"You're welcome to verify it at the agency."],[5125,5413,"So, how come you've been managing CV"],[5413,5703,"while also being at the agency full time?"],[5949,6178,"I was admiring her as a capable woman."],[6239,6447,"What an unfaithful liar!"],[6491,6695,"She betrayed Mr. Charles!"],[6720,6856,"She doesn't deserve to stay."],[6986,7164,"Get out. Get out of CV!"],[7178,7350,"Get out! Get out! Get out!"],[7482,7670,"- Get out! - No, I'm Mrs Charles."],[7670,7832,"You can't do this to me!"]],"56":[[304,558,"I didn't think you'd help me."],[700,798,"I'm not a quitter."],[859,1081,"Once I take the case, I'll make sure"],[1081,1269,"it goes through to the end."],[1310,1567,"J, I'm sorry"],[1581,1839,"for what I said in the car."],[1852,1935,"I didn't mean it."],[2027,2266,"I never wanted to end our cooperation."],[2419,2649,"Well, even if you didn't want it to end,"],[2694,3014,"our cooperation needs to come to an end."],[3044,3311,"J, I know this is my fault,"],[3474,3675,"but let me make things right."],[3802,4104,"I can't afford to lose you or our partnership."],[4149,4379,"Mr. Charles, I think you misunderstand me."],[4525,4693,"I found the evidence of Jennifer"],[4693,4921,"and Johnson's affair at the TX Mall."],[4975,5115,"This case is closed."],[5406,5521,"This is the proof."],[5618,5845,"It'll help your divorce process be easier."],[5860,5992,"I don't want to end this."],[6156,6383,"I need you, please."],[6862,7273,"I mean, my company still has other issues."],[7273,7523,"We could use a talented detective like yourself."],[7523,7632,"No, Mr. Charles."],[7640,8159,"You're my husband's cousin, and I wouldn't want people"],[8159,8313,"gossiping about it."],[8541,8990,"Thank you, Mr. Charles, for these days,"],[8990,9449,"but I don't think we should see each other again."]],"57":[[130,230,"Honey, I'm home."],[242,452,"Why don't you turn on the lights?"],[640,829,"Went to see Charles, huh?"],[860,1072,"What? No, I can explain."],[1072,1160,"He's my cousin!"],[1205,1356,"What, do you wanna fuck him?"],[1393,1509,"What are you talking about?"],[1509,1655,"I worked for him, that's all."],[2344,2494,"Aphrodisiac?"],[2627,2752,"You drugged me?"],[2802,2882,"So what?"],[2957,3006,"We're married."],[3053,3311,"I stood up for you and argued with him,"],[3311,3500,"and this is how you repay my trust?"],[3520,3801,"Charles, Charles, Charles!"],[3811,3963,"I am your husband!"],[4042,4134,"Yeah, I drugged you."],[4134,4239,"So what?"],[4241,4404,"Don't act so innocent."],[4404,4583,"What, you haven't done anything to betray me?"],[4592,4729,"What are you accusing me of?"],[4783,4890,"What did you do tonight?"],[4984,5130,"Haven't you fallen for Charles"],[5130,5259,"or given yourself to him?"],[5271,5386,"You're disgusting!"],[5588,5772,"I could be way more disgusting."],[5840,5968,"No! Let go of me!"],[6159,6255,"Ah!"]],"58":[[45,204,"Ah!"],[307,485,"I didn't want to do this to you!"],[498,684,"You made me!"],[1668,1798,"Why are you still here?"],[1810,1957,"You think you can get rid of me?"],[2013,2201,"As long as I refuse to divorce you,"],[2201,2361,"I'll always be Mrs. Charles."],[2370,2511,"Don't forget your promise."],[2551,2735,"You said after the press,"],[2757,2877,"you would agree to the divorce."],[2877,2995,"That press was a disaster."],[2995,3182,"You and that bitch humiliated me"],[3182,3270,"in front of everyone."],[3270,3384,"I'll never divorce."],[3411,3838,"Come on. I have proof of your affair with Johnson."],[3971,4186,"And you think that I have no evidence?"],[4580,4778,"Kissing one's cousin-in-law?"],[4789,4944,"If I leak this,"],[4944,5112,"your precious little detective"],[5112,5288,"will be torn apart by the media."],[5434,5664,"Yeah? Go ahead."],[5736,5822,"Oh."],[5822,6068,"What a romantic, forbidden love."],[6122,6253,"Now you tell me,"],[6263,6474,"if your precious, dear little detective"],[6474,6639,"finds out how much you love her,"],[6685,6965,"will she be moved or disgusted?"],[6969,7123,"Say that shit to her,"],[7123,7478,"and I will make you disappear from this world."],[7478,7687,"Sure. I won't say anything."],[7706,7948,"But either you commit to our marriage,"],[7948,8175,"or you divorce me and give me half your property."],[8306,8398,"Good luck to you."]],"59":[[800,875,"Why?"],[883,956,"Why!?"],[956,1150,"Why did she have to marry Johnathan?"],[1730,1906,"Whoa!"],[1951,2001,"J?"],[2243,2335,"Are you drunk?"],[2406,2496,"Why are you so drunk?"],[2640,2785,"So are you."],[2798,2932,"You were coming home with me."],[2986,3107,"Come on. Let's go."],[3107,3169,"Let's go."],[3169,3267,"Come on. Come on."],[3267,3374,"Nope. Give me that."],[3983,4054,"Where's Jonathan?"],[4107,4154,"J."],[4360,4508,"Did he leave you drunk and alone?"],[4650,4761,"That's not what a husband should do."],[5230,5322,"You were right!"],[5460,5582,"He's a total scum."],[5582,5748,"I should've listened to you."]],"60":[[50,129,"Are you okay?"],[272,334,"You know, just-"],[334,588,"I waited for him for three years."],[609,740,"What do I get?"],[790,1028,"Betrayal and humiliation."],[1063,1247,"Where's that bastard? I'm gonna deal with him."],[1718,1897,"He's not worth your tears, J."],[1985,2114,"You deserve someone better."],[2410,2544,"I don't even care."],[2627,2860,"Afyer years of hoping..."],[2965,3070,"...for nothing."],[3641,3716,"You know what?"],[3841,3974,"I am ready to divorce him."],[4112,4172,"Really?"],[4283,4366,"Yeah, I mean..."],[4487,4592,"my mom is the one"],[4592,4775,"that arranged the marriage and..."],[4859,5052,"I know that if she knew what was going on,"],[5052,5189,"she would understand."],[5242,5263,"Well..."],[5334,5417,"if you need any help,"],[5593,5692,"I can help you out."],[5901,6056,"You are family after all."],[6286,6412,"Are you sure you're not gonna..."],[6510,6664,"help him scheme against me?"],[6698,6840,"Well, if I were to do that,"],[6852,6965,"I wouldn't have invited you"],[6965,7126,"to the press conference."],[7390,7611,"Could you..."],[7649,7761,"give me a chance..."],[7803,7872,"if..."],[7920,8004,"we both..."]],"61":[[383,650,"Sweetheart, did Charles give you the gift I asked him to?"],[809,1155,"Wait, he didn't tell you what happened between us?"],[1201,1459,"What is it? Did that rascal upset you again?"],[1564,1922,"There's... something I need to tell you in person."],[2501,2681,"My mother-in-law has always been"],[2681,2794,"really kind to me."],[2990,3213,"I need to tell her about the divorce in person."],[3294,3475,"My aunt is a nice person,"],[3522,3743,"but she's always been way too easy on Jonathan."],[3937,4319,"By the way, what... What were you saying?"],[4600,4936,"Uh... It can wait."],[5006,5283,"I think you should take care of this first."],[5313,5382,"Are you sure?"],[5522,5614,"Yeah."],[5700,5835,"Let me take you home."],[6605,6890,"Jenny, why are you coming over so late?"],[7190,7398,"Mom, I'm sorry."],[7470,7624,"We were doing great all these years."],[7624,7761,"Why apologize?"],[7799,7996,"I'm afraid I can't be your daughter anymore."],[8050,8182,"I'm getting a divorce."],[8281,8364,"Why?"],[8411,8662,"You were always so excited to have him come back."],[8683,8831,"I knew you two were having"],[8831,8954,"your misunderstandings, but..."],[8954,9171,"you were having lunch together today."],[9171,9251,"What happened?"],[9305,9672,"I just... I won't be able to forgive what he did."]],"62":[[4,83,"What?"],[215,273,"Mom?"],[273,384,"What took you so long?"],[425,606,"Are you hiding someone in there?"],[700,942,"So he was hiding someone that night."],[1013,1167,"Mom, what are you talking about?"],[1501,1622,"I'm calling that bastard back"],[1622,1735,"right now to apologize."],[1743,1843,"No, please, please don't."],[1851,2072,"I really don't want to see him right now."],[2270,2310,"Just..."],[2560,2889,"Please, send the message of the divorce for me."],[2992,3089,"Jenny, I..."],[3179,3345,"I betrayed Anna's trust."],[3425,3467,"No."],[3467,3639,"I... I was supposed to take care of you."],[3641,3725,"No, no, you-"],[3899,4045,"You did a great job."],[4166,4254,"Sweetheart."],[4312,4615,"Even if you and Charles get divorced,"],[4800,5065,"I will always be your mom."],[5125,5209,"Thank you."],[6120,6165,"Mom."],[6244,6387,"Did she agree to a divorce?"],[7223,7336,"Why did you do that?"],[7336,7496,"You had a wonderful wife."],[7515,7636,"And you cheated on her."],[7636,7815,"You're lucky all I did was slap you."],[8007,8095,"I knew it."],[8116,8333,"She must've shown you those fake photographs."],[8333,8433,"Those pictures were..."],[8441,8562,"What pic- Charles, be like a man!"],[8608,8762,"If you messed up, just admit it."],[8762,9008,"I did fall for someone else."],[9017,9365,"But I've never cross the line during the marriage."],[9365,9494,"She is the one."],[9505,9638,"Enough! I don't wanna hear it."],[9638,9731,"You're the one at fault"],[9818,10027,"You need to split half of your assets"],[10027,10204,"as compensation for the divorce."]],"63":[[0,307,"Mom, what kind of nonsense has she fed you"],[307,433,"to take her side so blindly?"],[480,652,"Jenny never asked you for a dime."],[652,808,"You owe her that much!"],[884,1159,"Great actress, showing you one face sand me another."],[1184,1272,"I don't care what you say."],[1380,1531,"It'll be the third anniversary"],[1531,1738,"of her mother's passing in one week."],[1770,1905,"You need to go to that grave,"],[1905,2156,"apologize sincerely,"],[2156,2337,"and provide her the compensation."],[2744,2867,"I don't care about the money."],[2936,3232,"I would rather donate half of it to some charity"],[3232,3365,"than give her one cent."],[3365,3508,"To such a manipulative woman!"],[3641,3700,"You!"],[3799,3829,"Mom?"],[3829,3971,"Mom! Mom! Mom!"],[3978,4120,"Mom... Mom."],[4376,4453,"Mom."],[4650,4900,"Is this worth it for someone like her?"],[5017,5184,"She is not someone."],[5303,5444,"Her mother saved my life."],[5647,5848,"And I promise to take care of her daughter."],[6014,6152,"Just do what I said."],[6225,6444,"And don't make me feel guilty."],[6669,6749,"Fine."],[7011,7111,"I'm sorry, Mom."]],"64":[[0,165,"Let me take you to hospital, okay?"],[187,368,"Come on. Come on. Come here."],[426,562,"Come on. Come on."],[579,668,"I got you."],[1818,2160,"Aunt Mina, you've always been so healthy."],[2209,2301,"What happened?"],[2440,2612,"It's all Charles' fault."],[2641,2856,"He betrayed his wife and refuses"],[2856,3094,"to provide her the compensation she deserves."],[3154,3372,"So Jenny pinned what I did on Charles."],[3457,3578,"Maybe I should use this to"],[3578,3720,"actually push their divorce forward."],[3791,3889,"It's our fault."],[3924,4196,"So, when Jenny arrives, don't let her down."],[4300,4483,"What? She's coming here?"],[4750,4910,"If she shows up, I'm done then."]],"65":[[120,171,"Come in."],[563,642,"What are you doing here?"],[713,909,"Charles! What kind of question is that?"],[940,1116,"Isn't it normal for your cousin"],[1116,1205,"to come visit me?"],[1301,1388,"Um, Aunt Mina,"],[1388,1659,"I think Charles might have misunderstood me."],[1835,2052,"Why don't we step outside and sort this out?"],[2844,3006,"She waited three years!"],[3006,3171,"And this is how you treat her?"],[3222,3332,"Are you even a man?"],[3770,3959,"Charles, I know I was wrong."],[3991,4204,"I've been regretting it."],[4212,4453,"Whatever it takes to make it up to her,"],[4453,4564,"I'll do it."],[4708,4798,"Really?"],[4798,4888,"Right."],[5055,5227,"I just... I just got back."],[5227,5416,"I'm not as successful as you are."],[5430,5649,"I have nothing to offer her."],[5889,6239,"Why don't you transfer me some shares of CV?"]],"66":[[25,212,"To make me less guilty,"],[212,500,"I'll give them to her as compensation."],[792,857,"Fine."],[917,1168,"But if you break this promise,"],[1240,1372,"and if you hurt her,"],[1402,1555,"I swear..."],[1602,1702,"Understand?"],[2669,2841,"Mom, this is all my fault."],[2841,2926,"No."],[2930,3164,"If anyone's to blame, it's Charles."],[3282,3559,"Jenny, the anniversary"],[3559,3832,"of your mother's passing is in one week, and..."],[3885,3990,"I've always been there for you"],[3990,4245,"but I'm afraid this year I..."],[4450,4751,"Bitch! Still trying to manipulate my mom."],[4821,4974,"Excuse me, sir?"]],"67":[[16,136,"Are you in this family?"],[170,222,"Yeah."],[367,526,"Why don't you come with me to sign this form?"],[664,734,"Okay."],[996,1204,"It's fine.. Don't worry."],[1380,1647,"I don't want any unrelated people there this year."],[1818,1885,"I get it."],[1942,2231,"Charles won't go and Jenny doesn't want to see him."],[2314,2484,"I might have to choose another day"],[2484,2590,"to compensate her."],[3007,3170,"Her mother saved my life."],[3194,3399,"And I promised to take care of her daughter."],[3561,3709,"Just do what I said."],[3770,4012,"And don't make me feel guilty."],[4354,4412,"Fine."],[4480,4580,"This is for my mom."],[4984,5138,"You finally agree to my terms."]],"68":[[20,254,"Stop trying to manipulate my mom."],[358,596,"I'll attend your mother's memorial next week."],[625,739,"And I'll give you the money."],[800,1076,"But you'll have to sign the divorce papers."],[1150,1202,"Deal."],[1747,1910,"I didn't expect running into you here."],[2115,2272,"Your divorce is almost settled."],[2272,2440,"Why do you still look so upset?"],[2510,2635,"I underestimated her."],[2756,3034,"She's using my mom, forcing me"],[3034,3269,"to sign over half of my assets."],[3340,3471,"How greedy can she get!?"],[3557,3636,"Honestly, it's..."],[3745,3958,"I can't go so easy on someone like that."],[3960,4003,"Right."],[4278,4516,"It'll be all over this weekend."]],"69":[[316,395,"Mom..."],[460,600,"sorry to disappoint you but..."],[767,932,"I've decided to leave Charles."],[2200,2424,"Jenny, I know I don't deserve to see your mom,"],[2424,2635,"but I left a bouquet at the entrance."],[2702,2857,"Could you take it to her for me?"],[2900,2950,"No!"],[3040,3187,"It won't take much of your time."],[3211,3470,"If you don't come, I'll wait here until you to do."],[4145,4265,"I'll be back soon, Mom."],[4821,4965,"There's already a bouquet here..."],[5045,5171,"Oh. Um."],[5171,5396,"One of my mom's friends probably came."],[5634,5843,"From your daughter, Jenny?"]],"70":[[166,416,"Oh, I forgot I had the florist deliver this."],[609,1039,"I've had the asset division agreement drawn up."],[1041,1376,"Once you sign, half of CV will be yours."],[1550,1617,"Charles?"],[1739,1885,"Jennifer, what are you doing here?"],[2398,2527,"I appreciate it,"],[2565,2873,"but my mom may not accept your flowers."],[2873,3361,"Jenny, I know I was wrong, so I prepared this"],[3361,3620,"to compensate you in front of your mom."],[4854,5001,"Ten percent shares of CV."],[5086,5267,"And it's your cousin's company?"],[5309,5509,"If you really want to apologize,"],[5509,5710,"show some sincerity."],[5720,5953,"This? I don't need it."],[6005,6385,"Jenny, the contract already has your name on it."],[6398,6798,"If you don't want it, you can transfer it to me."]],"71":[[40,162,"So that's all you want, huh?"],[233,322,"Compensation?"],[379,521,"All you want is shares?"],[829,950,"You'll never get it."],[1000,1275,"And I won't let you use me to hurt your cousin."],[1901,2152,"I've worked so hard for this."],[2227,2349,"It was all for this contract."],[2635,2769,"Protecting Charles?"],[3010,3098,"Die with him!"],[3278,3352,"Charles?"],[3451,3595,"Jennifer, what are you doing here?"],[3933,4093,"Jennifer, what are you up to now?"],[4149,4312,"I won't let anyone hurt my mom."],[4425,4525,"What... what did you say?"],[4733,4907,"Honey, don't listen to her."]],"72":[[12,116,"What, you want a divorce, right?"],[116,204,"Well, give me the agreement,"],[204,297,"I'll sign it. Then you could-"],[297,345,"Shut up!"],[610,665,"Sorry."],[721,843,"Please say that again."],[921,995,"Who is she to you?"],[1076,1162,"My mom."],[1418,1497,"Your name is?"],[1593,1668,"Jenny Keller."],[1751,1901,"And Mina is?"],[2014,2167,"My mother-in-law."],[2293,2686,"Wait, your Mina's son, Charles Rosent?"],[2727,2942,"Yes, and I'm your husband."],[2990,3073,"No, no!"],[3215,3332,"I'm Mrs. Charles!"],[3350,3516,"You can't steal anything from me!"],[3670,3841,"Stop! Why did you do this to me?"]],"73":[[10,120,"I'm Mrs. Charles!"],[120,292,"You can't steal anything from me!"],[346,392,"Get off!"],[400,467,"Die! You!"],[475,550,"Die!"],[604,633,"Stop!"],[675,800,"- Die, die! - Get off of her!"],[1067,1288,"- Die! You! Die! - Get off!"],[1600,1656,"Jenny."],[1780,1913,"Jenny, are you okay?"],[1922,2064,"Yeah... yeah..."],[2560,2783,"It's been you all along..."],[3001,3128,"I was trying to..."],[3128,3280,"suppress my feelings for you"],[3280,3451,"from my other marriage, but..."],[3490,3682,"I've been missing you all along."],[3762,3843,"It's not your fault."],[3966,4197,"You were standing right in front of me and I..."],[4275,4450,"I mistook you for someone else."],[4546,4696,"I thought I've lost you forever."],[5272,5460,"Jenny, you stole everything from me!"],[5501,5619,"My reputation."],[5651,5751,"My life..."],[5918,5997,"I'll kill you!"]],"74":[[108,206,"Charles!"],[295,457,"Charles! Are you okay?"],[509,582,"Charles..."],[670,743,"Charles!"],[874,983,"Charles! Are you okay?"],[1001,1234,"You may have won Jenny, but what does it matter?"],[1234,1423,"Your newfound love is dying now!"],[1506,1674,"Jennifer, if anything happens to him,"],[1674,1758,"I'll kill you!"],[1785,1984,"Someone call an ambulance, please!"],[2273,2490,"I thought you two had already reunited."],[2554,2820,"I didn't expect such a big misunderstanding."],[2955,3182,"Jonathan is under arrest."],[3274,3618,"He admitted he gave the knife to Jennifer."],[3807,3883,"And he was trying to"],[3891,4067,"impersonate Charles to get close to you,"],[4133,4386,"and trying to get Charles' shares of the company."],[4441,4628,"He'll probably spend the rest of his life in prison."],[4758,4925,"And Jennifer has gone crazy."],[4984,5252,"She was admitted into a psychiatric hospital"],[5252,5347,"for murder."],[5505,5697,"And Johnson is drowning in debt"],[5772,6001,"from buying her too many designer brands."]],"75":[[19,143,"You hear that, Charles?"],[191,347,"They all got what they deserve."],[450,550,"So please, just..."],[651,814,"come back to me, please!"],[1401,1476,"Charles..."],[1872,2173,"My wife is calling out to me so sincerely."],[2249,2430,"How could I possibly ignore that?"],[2430,2478,"Charles."],[2812,2969,"You're finally awake."],[2982,3133,"I gave you my word."],[3170,3317,"I'd never break it."],[3317,3432,"My dear detective."],[3595,3710,"Oh, Charles."],[4070,4181,"Ladies and gentlemen,"],[4301,4450,"we are gathered here today"],[4533,4630,"in the sight of God"],[4630,4822,"to witness the joining together of"],[4843,4976,"Mr. Charles Rosent"],[5057,5315,"and Ms. Jenny Keller in holy matrimony."],[5551,5776,"Now please, repeat after me."],[5818,5901,"I, Charles Rosent-"],[5960,6452,"I, Charles Rosent, take you, Jenny Kelly, to be my wife."],[6598,6926,"And I promise that in days of wealth or poverty..."],[6973,7164,"In sickness or in health..."],[7215,7494,"I will always honor you and cherish you."],[7536,7708,"And I will love you forever,"],[7827,7965,"till death do us apart."],[9880,10006,"This wedding..."],[10006,10205,"I've been planning since I left the country."],[10281,10427,"I never thought it would happen."],[10481,10628,"I'm so glad you're the one."],[10731,10894,"I love you, Charles..."],[10915,11028,"I love you, too."]]}