{"1":[[12,137,"Once upon a time,"],[175,383,"the Kingdom of Mercia is at war."],[437,721,"Every man must stand and fight."],[829,1071,"No, no."],[1088,1201,"Please, please."],[1317,1418,"I don't want to go to war."],[1472,1539,"Spare me!"],[1889,2010,"I'm scared, Arthur."],[2064,2264,"Will they take you and Papa away too?"],[2414,2552,"No, they won't."],[2606,2656,"Okay?"],[2736,3023,"I got something for both of you."],[3069,3307,"I had these blessed by the Church today."],[3428,3732,"This one is for you, Arthur."],[3978,4183,"And this one, Anna, is for you."],[4250,4537,"May God bless us and guide us"],[4600,4808,"and keep us together as one family."],[4934,5000,"Thank you, Mom."],[5242,5313,"I love you."],[5551,5609,"Mama?"],[5634,5680,"Yes?"],[5680,5797,"My belly hurts."],[5855,6026,"I think I need to go potty."],[6093,6143,"I see."],[6293,6348,"Yes."],[6373,6410,"Wait."],[6443,6489,"Mama."],[6556,6698,"It's Papa's birthday today."],[6760,6852,"I was wondering if"],[6877,7027,"I could have some coins so"],[7052,7157,"I could get a little,"],[7157,7311,"little bit of beef."],[7323,7415,"Just a little bit."],[8112,8337,"I'm sorry sweetie, we can't afford beef."],[8466,8662,"Maybe we could have chicken."],[8742,8871,"Your favorite chicken pie?"],[8913,8971,"Huzzah!"],[9025,9092,"Thank you, Mom."],[9117,9171,"I love you."],[9334,9405,"I love you."],[9834,9926,"Bye."],[11649,11828,"Every man must stand and fight."],[11949,12007,"Take him."],[12062,12107,"Stop."],[12170,12316,"No, I'm only 13!"],[12349,12420,"Let me go."],[12449,12562,"Mama!"],[13042,13113,"Arthur."],[13338,13471,"Arthur should be here by now."],[13559,13638,"Where is he?"],[13905,13972,"Arthur."],[15069,15273,"Mama!"]],"2":[[133,187,"Where?"],[321,375,"But-"],[479,546,"Oh God."],[617,679,"Oh."],[784,905,"Have you seen my son?"],[971,1076,"Have you seen Arthur?"],[1121,1226,"The Baron's men took him."],[1322,1368,"What?"],[1368,1497,"They're marching him to the border."],[1497,1618,"They're sending him to war."],[1622,1676,"No."],[1776,1835,"No."],[1931,1993,"No."],[3123,3165,"Jane!"],[3303,3386,"You're hurt."],[3432,3495,"Carl."],[3524,3616,"They took him."],[3695,3812,"What? - We have to get him."],[3870,3974,"He's only 13,"],[3974,4187,"he won't survive, on, on the battlefield."],[4187,4283,"We..."],[4283,4416,"Let's, go, he..."],[4458,4662,"No? Have you seen a boy, you seen Arthur?"],[4662,4729,"Have you seen our son?"],[4738,4829,"Right here with,"],[4829,4979,"with, with soldiers."],[5038,5192,"Hey, are you soldiers of the Baron?"],[5255,5326,"Have you seen a boy?"],[5367,5547,"A strong lad, brown hair,"],[5580,5659,"about this tall?"],[5693,5805,"The boy we took from the market,"],[5805,5860,"is it?"],[5872,5918,"Yes."],[5918,5985,"Yes. - Yes."],[5985,6081,"Yes, that's him."],[6118,6164,"Where is he?"],[6227,6335,"Your boy is either dead,"],[6335,6414,"or going to be, soon."],[6435,6531,"He, he can't be."],[6531,6606,"You're lying."],[6619,6698,"Away with you, woman."],[6710,6852,"Give me back my son."],[6894,6981,"The law says that"],[6981,7115,"no boy should be conscripted"],[7115,7411,"unless he's 16 years old, Arthur's 13."],[7419,7478,"Please!"],[7995,8095,"If you didn't want him gone,"],[8095,8212,"you should have kept him at home!"],[8224,8379,"You have no one to blame but yourself!"],[8546,8641,"It's all my fault."],[8641,8721,"I killed him."],[8796,8917,"I should never have let him go"],[8917,9046,"to the butchers by himself."],[9054,9096,"It's-"],[9096,9200,"Shut up, wench!"],[9234,9405,"Or I'll make you join him real soon!"]],"3":[[20,104,"Calm it, now."],[133,254,"Foolish as they are,"],[271,496,"we can't just kill as we wish."],[608,809,"A common boy from filth like you?"],[838,892,"He was doomed"],[892,1017,"from the moment he met us."],[1576,1651,"He’s right."],[1793,1885,"It's all my fault."],[1885,2014,"I shouldn’t have let him go."],[2064,2210,"You musn’t do this to yourself."],[2277,2419,"We will bring our boy home."],[2590,2715,"Arthur."],[2940,3019,"Where are you?"],[6598,6731,"I have a feeling I know"],[6731,6802,"why you're here."],[6927,6998,"Your Majesty."],[7098,7165,"Nothing escapes you."],[7248,7357,"Nothing does escape me."],[7415,7557,"Which is why I've already"],[7557,7753,"sent word out to Stamford."],[7786,7874,"You'll oversee the"],[7874,8028,"building of a new fort"],[8045,8237,"to strengthen our borders."],[8258,8383,"The Baron of Stamford"],[8383,8454,"will host you"],[8454,8646,"until the completion of the project."],[8654,8725,"But your Majesty,"],[8725,8854,"my duty as a Duke is to protect-"],[8854,8958,"Come, come."],[9196,9396,"Go, my boy."],[9438,9588,"You've fought enough battles"],[9588,9655,"for me."],[9697,9843,"And did a great service"],[9843,10051,"to the Kingdom of Mercia."],[10164,10293,"This is why"],[10314,10560,"I gave you the title of Duke."],[10618,10814,"Go back to Stamford."],[10814,10985,"Find your family."],[11036,11198,"They would be so proud"],[11198,11407,"to see the man you've become."],[11490,11590,"And while you're at it,"],[11661,11849,"build me that castle, eh?"],[12128,12245,"I won't let you down, sir."],[12883,12992,"I miss you."],[13179,13250,"Oh,"],[13292,13500,"Robert, my sweet nephew, here."],[13563,13676,"All my wages."],[13909,14018,"I'm depending on you."],[14089,14243,"You work for the Baron now,"],[14243,14476,"so please help me find your cousin."],[14481,14560,"I beg of you."],[14781,14848,"Aunt Jane,"],[14894,15069,"my connections are expensive."],[15098,15302,"I'll look into it, but not today."],[15352,15548,"The Duke is coming to Stamford."],[15561,15749,"Everything has to be perfect."],[15786,15886,"The Duke is coming?"]],"4":[[0,50,"Robert,"],[100,237,"maybe you can ask the Duke, if, if..."],[258,408,"to help me find my son?"],[417,517,"I've heard that the Duke is"],[517,621,"a great knight in battle,"],[621,800,"so perhaps you could ask him"],[800,980,"to see if he recognizes this boy"],[980,1055,"with this necklace."],[1055,1184,"Maybe he knows my Arthur."],[1238,1468,"Have you lost your wits?"],[1509,1685,"Ask the Duke for help?"],[1697,1818,"Who do you think you are?"],[1876,2018,"Even the Baron wouldn't dare"],[2018,2260,"trouble the Duke for such trifles."],[2335,2419,"Robert, please."],[2419,2552,"Just have him take a look."],[2581,2635,"He-"],[3703,3941,"It's your own fault you lost your son."],[3991,4170,"Don't blame other people"],[4170,4262,"for your own negligence."],[4262,4341,"It is my fault."],[4358,4450,"I should've never let him"],[4450,4533,"out of my sight."],[4533,4767,"I regret it every single day."],[4788,4917,"But you promised that"],[4917,5171,"if I gave you all of my wages,"],[5171,5359,"you would help me find my son."],[5405,5588,"I told you."],[5605,5684,"Not today."],[5734,5989,"The Duke could be here any second."],[6039,6247,"Get lost before he sees"],[6247,6385,"your ugly face."],[6677,6769,"The Duke is here."],[6781,6911,"Go, git!"],[7957,8045,"That's the Duke."],[8112,8179,"He's the one"],[8179,8366,"that defeated the Five Kingdoms."],[8454,8696,"The King treats him like a son."]],"5":[[2189,2314,"Presenting His Grace,"],[2335,2481,"the Duke of Mercia."],[2852,2961,"Welcome, Your Grace."],[3032,3103,"Lord Benjamin,"],[3132,3315,"there's no need for such formalities."],[3345,3399,"We've known each other"],[3399,3474,"for a decade now,"],[3474,3553,"have we not?"],[3595,3787,"Your Grace, it was I"],[3787,3858,"who was sending you"],[3858,3953,"to the battlefield, I,"],[3995,4175,"I beg for your forgiveness."],[4195,4325,"It was on the battlefield"],[4325,4458,"that I earned my honor."],[4496,4642,"You are too kind, Your Grace."],[4696,4838,"I've returned to find my family."],[4896,5071,"Well, please tell me who they are"],[5071,5176,"and where they reside, I,"],[5205,5355,"I shall have them brought here at once."],[5367,5472,"My memories are faint,"],[5522,5609,"clouded by the injury"],[5609,5705,"I sustained during the war."],[5910,5976,"But my mother,"],[6051,6177,"she wore a pendant like this."],[6631,6902,"May God bless us and guide us"],[6981,7173,"and keep us together as one family."],[8045,8204,"Could this be me?"],[8249,8362,"Find who this belongs to."],[8462,8596,"I will see to this personally."],[8933,8988,"Mom."],[9163,9213,"Where are you?"],[9451,9626,"The Duke of Mercia"],[9647,9843,"has come to the Baron's manor."],[9855,10126,"The King must hold him in high regard."],[10147,10247,"They say he's looking"],[10247,10331,"for his family."],[10360,10506,"Who could be so lucky as"],[10506,10719,"to be the Duke's relative?"],[10744,10869,"Pardon to interrupt, but,"],[10944,11069,"Well, if he's here"],[11069,11232,"visiting his family, then"],[11265,11323,"there's a chance that"],[11323,11369,"there's a chance that"],[11407,11649,"possibly the Duke is my Arthur?"],[11949,12095,"Don't be stupid."],[12120,12262,"This is the Duke,"],[12274,12520,"second in authority only to the King."],[12554,12771,"How could a man like that be your son?"],[12804,12929,"Your son probably"],[12929,13071,"died on the battlefield."],[13092,13338,"Stop being delusional."],[13505,13576,"No."],[13688,13772,"I must see the Duke."],[13959,14093,"Have you lost your mind?"]],"6":[[233,300,"Arthur."],[558,821,"I just want make sure he's my Arthur."],[1885,2022,"Did someone call my name just now?"],[2052,2193,"Your Grace, it's probably just"],[2193,2339,"the wind playing tricks."],[2389,2469,"No one here would"],[2469,2686,"dare to speak your name so boldly."],[3161,3319,"What were you thinking?"],[3345,3574,"Your actions will bring my family"],[3574,3674,"down with you."],[3695,3841,"Robert just became Butler."],[3849,4029,"I won't have you"],[4029,4179,"ruining things for him."],[4179,4404,"No, I swear, that was my son."],[4404,4508,"That was Arthur."],[4521,4725,"You have truly gone mad."],[4758,4904,"That was the Duke,"],[4904,5113,"the second most important man"],[5113,5276,"in the entire Kingdom."],[5305,5492,"How could a man of such standing"],[5551,5714,"be your son?"],[5730,5951,"He looked just like him."],[6014,6118,"I swear that..."],[6393,6589,"Do you mean to get us all hung?"],[6648,6802,"Calling the Duke your son."],[6877,7165,"What an insult to that fine gentleman."],[7219,7482,"Please, just let me speak to him."],[7486,7645,"Let me show him this."],[8863,8908,"Robert."]],"7":[[16,133,"Robert, don't."],[179,308,"Not while the Duke is here."],[437,500,"Robert!"],[633,771,"What are you doing to my mother?"],[834,917,"Anna."],[1088,1159,"Give me that back."],[1159,1292,"I need it to find Arthur."],[1338,1501,"Worthless piece of junk."],[1543,1726,"Robert, we're family,"],[1735,1906,"we're supposed to help each other."],[1976,2085,"Look what you've done."],[2122,2202,"Family?"],[2289,2398,"It's bad enough"],[2398,2573,"that we share the same blood."],[2602,2911,"My son has risen up through the ranks"],[2948,3115,"while yours only grows"],[3115,3286,"poorer and poorer."],[3303,3499,"It's pathetic, really."],[3524,3628,"No, no, no, but I,"],[3628,3824,"I gave all of my wages"],[3824,4016,"so that you could find Arthur"],[4016,4087,"and you..."],[4304,4412,"You never even"],[4412,4600,"planned to find Arthur."],[4629,4746,"You never even thought"],[4746,4838,"to look for him."],[4842,5142,"You, you liar, you cheat."],[5163,5334,"Give me back my coin!"],[5334,5634,"Don't touch me with your filthy hands."],[5651,5722,"And this?"],[5809,5964,"Say goodbye to your son."],[6402,6485,"No!"],[6535,6581,"No."],[6806,6886,"Mother, no!"]],"8":[[387,454,"Mother, no!"],[567,596,"No!"],[842,988,"Come, mother, let's go."],[1234,1413,"Oh, Anna, what have I done."],[1472,1634,"We'll never be able to find Arthur,"],[1634,1747,"not with this. - It's alright."],[1760,1835,"It's alright, mother,"],[1835,1926,"have you forgotten?"],[1964,2068,"I carry one too."],[2235,2323,"Oh Anna."],[2410,2540,"Now if you truly believe"],[2540,2690,"the Duke might be our Arthur,"],[2773,2869,"I'll see what I can do."],[3945,4104,"Arthur, my brother,"],[4137,4254,"could it really be you?"],[4738,4821,"Your Grace."],[4950,5021,"My Lord."]],"9":[[483,579,"Forgive me, Your Grace."],[579,629,"Ah..."],[880,1009,"Useless girl."],[1130,1301,"Your Grace, are you alright?"],[1359,1484,"I'm fine, Lord Benjamin."],[1605,1693,"No need to punish her"],[1693,1797,"for a simple mistake."],[1835,2022,"Your kindness humbles us all."],[2193,2252,"Well?"],[2285,2373,"Don't just sit there."],[2427,2506,"Clean yourself up."],[2907,3069,"Why does she seem so familiar?"],[3190,3382,"It seems that I have someone"],[3382,3561,"the Duke might want."],[3799,3966,"How could Robert do this to you?"],[4225,4354,"He beat you."],[4437,4654,"You're his aunt, for crying out loud."],[4654,4729,"Oh, Carl."],[4875,4967,"You know your family"],[4967,5134,"has always been cruel to us."],[5205,5367,"It's only gonna get worse"],[5401,5714,"now that Robert is butler to the Baron."],[5864,5914,"Mother."],[5993,6047,"Father."]],"10":[[175,325,"This place is so familiar to me."],[433,517,"And it's strategic."],[750,838,"I'll build the new fort here."],[925,1034,"See to it that all the families"],[1034,1188,"along this road are asked to leave,"],[1222,1343,"and compensate them well."],[1384,1539,"I will start the process right away."],[2252,2306,"Father."],[2444,2556,"What did the Duke say?"],[2556,2606,"Did he?"],[2990,3044,"Mother."],[3044,3098,"What?"],[3203,3424,"I don't think the Duke is our Arthur."],[3516,3578,"No."],[3670,3858,"He does, he does resemble him,"],[3858,3945,"yes, but."],[3995,4162,"He didn't recognize the necklace."],[4212,4262,"No."],[4475,4596,"I'm so sorry."],[4700,4817,"I thought it was him."],[4913,5009,"I wanted to come back"],[5009,5117,"and give you the necklace."],[5226,5422,"I know at least you'll sleep easier"],[5442,5568,"knowing this is by your side."],[5834,5951,"Thank you, Anna."],[6619,6798,"Oh, Your Grace."],[6806,7077,"I daresay you look as handsome as ever."],[7140,7215,"These clothes are much more"],[7215,7273,"comfortable."],[7528,7574,"Thank you."],[7916,7962,"Leave me,"],[8012,8166,"I wish to explore the city by myself."],[8233,8383,"See if anything can jog my memory."],[8433,8533,"Yes, Your Grace. - Yes, Your Grace."]],"11":[[613,688,"That must be Anna,"],[688,846,"she must’ve forgot something."],[963,1092,"Anna?"],[1755,1847,"Ugh."],[1993,2085,"What are you all doing here?"],[2110,2185,"Especially after what you did"],[2185,2239,"to my wife."],[2268,2410,"Long time no see, brother."],[2469,2627,"Still living in this hovel, huh?"],[2656,2840,"Would, would you like some,"],[2873,2965,"some bread? We,"],[2990,3078,"we were just about"],[3078,3182,"to sit down for lunch,"],[3190,3365,"so I can offer you a fresh loaf."],[3403,3603,"You call this food?"],[3628,3903,"The Baron's dogs wouldn't eat this."],[4433,4754,"But fortune favors the undeserving."],[4775,4909,"Now you'll be able to"],[4909,5105,"buy some real food."],[5150,5251,"What do you mean, Laura?"],[5309,5409,"Tell them, Robert."]],"12":[[29,225,"It really is a shack,"],[254,533,"but luckily, it'll be gone soon."],[550,688,"Your land has been seized."],[700,896,"This entire street will be dug up"],[896,1017,"to make way for the new fort."],[1017,1055,"No."],[1059,1267,"To bolster our defenses."],[1288,1409,"The order came directly"],[1409,1530,"from the Duke himself."],[1559,1626,"No. - But."],[1626,1868,"you will be well compensated"],[1868,1935,"for the trouble."],[2035,2089,"What?"],[2089,2298,"Just sign here"],[2298,2577,"and you'll receive 20 gold pieces."],[2640,2727,"As your brother,"],[2777,2940,"I should be entitled to half."],[2965,3094,"But as you have no son"],[3123,3232,"and I have a son,"],[3294,3428,"I ought to take two thirds."],[3436,3482,"What?"],[3482,3653,"No, this is our family home."],[3657,3741,"What would-"],[3766,3820,"No."],[3858,3983,"If, if Arthur returns,"],[3983,4124,"how will he find his way home?"],[4137,4200,"She's right."],[4216,4312,"We won't give up our land,"],[4337,4521,"not for 20 gold coins, not for nothing."],[4542,4729,"Then you are dafter than I thought."],[4729,4871,"Let me remind you,"],[4888,5176,"your son is not coming back"],[5201,5384,"because he's dead."],[5467,5576,"No. - No, no, no."],[5593,5684,"You hold your tongue."],[5709,5809,"Arthur will return."],[5822,5935,"And we will remain here"],[5955,6060,"until he does. - Yes."],[6060,6135,"We won't give up hope,"],[6156,6277,"not for any petty coin."],[6297,6493,"You don't get a say!"],[6523,6648,"The order comes from above."],[6652,6777,"Enough of this insolence!"],[6785,6898,"Leave my house at once!"],[6898,6986,"Leave my house!"],[6998,7065,"Carl."],[7323,7394,"Carl."],[7394,7465,"Oh!"],[7511,7628,"Carl, are you all right?"],[7791,7962,"We are family!"],[7991,8162,"We are supposed to support each other."],[8162,8316,"If you can't do that, then leave."],[8358,8475,"Then you've chosen death."],[8495,8566,"So be it!"]],"13":[[120,212,"This place"],[237,412,"really does feel so familiar."],[763,813,"What?"],[992,1063,"What are you doing-"],[1105,1155,"Ah!"],[1497,1655,"I'll tell you this one last time."],[1705,1839,"Sign the damn contract,"],[1856,1968,"or I'll beat you to death."],[1972,2097,"You are his brother."],[2097,2235,"How can you do this to him?"],[2273,2402,"No man as useless as him"],[2402,2535,"deserves to be my brother."],[2690,2740,"Ah!"],[2773,2973,"You're a monster."],[2973,3019,"Sign it."],[3028,3094,"Now."],[3136,3228,"No."],[3303,3440,"No."],[3624,3728,"Ah!"],[3820,3995,"Ah!"],[4425,4475,"Stop it!"]],"14":[[29,79,"Stop it!"],[162,233,"That's an order."],[504,675,"What's a peasant like you doing here?"],[729,955,"Cross me and I'll beat you up too."],[963,1105,"You know who my son works for?"],[1121,1180,"The Baron."],[1197,1322,"We're here to seize this land on"],[1322,1388,"his orders,"],[1413,1601,"so you better stay out of our affairs."],[1622,1764,"So you're the Baron's henchmen?"],[1839,1951,"I told them to see that"],[1951,2189,"every family is compensated fairly."],[2281,2419,"And this is how you choose to do it?"],[3140,3319,"Good folks, you have my word."],[3374,3478,"I will make this matter right."],[3536,3666,"Lord Benjamin requests your land"],[3666,3762,"to build a new fort,"],[3824,3945,"but we will provide whatever"],[3987,4083,"is necessary for you."],[4104,4191,"Do you know the Baron?"],[4304,4396,"Could you plead to him"],[4396,4471,"on our behalf?"],[4471,4537,"Please to,"],[4571,4721,"all we ask is that we remain here."],[4721,4900,"We cannot leave our home, please."],[4938,5005,"Rest assured,"],[5067,5255,"you'll be well compensated"],[5284,5380,"if you choose to depart."],[5422,5609,"No, we don't want coin."],[5643,5809,"This is my son's home."],[5839,5930,"If it's torn down,"],[5930,6093,"he will never find his way home."],[6177,6293,"Your son was taken, you say?"],[6306,6364,"Yes."],[6443,6594,"He was only 13 years old,"],[6648,6781,"taken far too young,"],[6781,6977,"conscripted by the Baron's soldiers."],[7102,7169,"If we leave,"],[7169,7340,"he'll never find his way back."],[7415,7507,"Please."],[7649,7791,"Please, I beg of you."],[8145,8224,"This pendant."],[8266,8316,"Yes."],[8362,8550,"It was a token, a promise that"],[8629,8712,"my children and I"],[8712,8913,"would always be family together."]],"15":[[91,408,"This one is for you, Arthur."],[771,825,"What?"],[1922,1976,"Mother."],[2031,2085,"Arthur!"],[2318,2448,"Oh, is it you?"],[2535,2627,"It's me, Mom."],[2744,2819,"I've come home."],[2886,2961,"My boy."],[3011,3286,"Ten long years we searched for you,"],[3365,3616,"and finally, you've come back to us."],[3791,3841,"I'm sorry."],[3949,4062,"I've been a bad son."],[4108,4195,"But I promise,"],[4212,4437,"I will give you the life you deserve"],[4437,4512,"from here on out."],[4562,4692,"Please forgive me."]],"16":[[112,258,"Can we stop with the theatrics?"],[325,450,"Ten years have passed,"],[450,638,"and cousin Arthur returns"],[654,734,"as a peasant."],[784,959,"I'd cry too if this were my son."],[1009,1080,"Laura and George,"],[1080,1288,"do you see Arthur has come home?"],[1372,1476,"What's there to cheer for,"],[1476,1597,"a beggar for a son?"],[1626,1830,"Or a thief, more likely."],[1872,1926,"Look at him,"],[1947,2114,"wandering around,"],[2131,2373,"starving and desperate."],[2385,2535,"I don't care what you say,"],[2569,2727,"but my son has come home,"],[2740,2948,"and he is everything to me."],[2965,3048,"Let's go inside"],[3048,3244,"and I will make your favorite roast."],[3349,3440,"And George and Laura."],[3490,3616,"I would prefer if you left."],[3712,3874,"We would like to celebrate alone"],[3874,3949,"as a family."],[3966,4049,"We're not leaving"],[4049,4183,"until you sign the contract,"],[4183,4371,"you useless fool."]],"17":[[29,175,"No, Robert, surely you understand,"],[175,287,"you're family."],[312,433,"We'd like to celebrate."],[458,804,"This low life doesn't deserve anything."],[1030,1209,"I'm done arguing with you"],[1209,1347,"in this pigsty."],[1363,1572,"Don't you point your finger at me."],[1580,1755,"I could do much worse."],[1797,1997,"Or do you want me to get my fiancée,"],[2002,2093,"so you can beg for her"],[2093,2189,"forgiveness instead?"],[2231,2419,"Remember, I'm engaged"],[2419,2652,"to the prestigious Lady Edith."],[2694,2831,"If she finds out about this,"],[2831,3015,"you're all get a good beaten."],[3053,3132,"Go away!"],[3157,3219,"Carl."],[3949,4154,"This is a joyous day,"],[4204,4308,"and I do not wish to spend it"],[4308,4483,"squabbling with you ilk."],[4512,4625,"Kneel before us,"],[4675,4913,"apologize, and be gone."]],"18":[[25,104,"You,"],[104,229,"son of a whore."],[246,408,"I'm the Baron's butler,"],[408,638,"the highest on his staff."],[646,992,"You think I'd kneel to a common maid?"],[1034,1234,"You better show your respect."],[1760,1851,"Now will you go?"],[1906,2018,"You scum!"],[2072,2143,"I'll have you know"],[2143,2281,"just how much I am worth."],[2306,2464,"Inform Lady Edith."],[2481,2598,"Ask her to come, won't you?"],[2619,2740,"Yes, Mr. Wellesley."],[2794,2957,"Well, well, well."],[2957,3073,"You fools have chosen not"],[3073,3148,"to take the gold,"],[3161,3349,"but it was the Baron's orders."],[3395,3591,"Your hovel must come down."],[3678,3816,"Lord Benjamin's orders, was it?"],[3853,4070,"That's Baron Stamford to you."],[4099,4183,"On the contrary,"],[4216,4341,"I think I can call him Benjamin"],[4341,4421,"just fine."],[4654,4721,"Are you mad?"],[4779,4996,"Who do you think you are?"],[5013,5075,"The Duke?"],[5109,5226,"Pulling rank like you're,"],[5267,5426,"anything special."],[5442,5580,"I dare say I'm special enough"],[5580,5709,"that even Lord Benjamin"],[5739,5868,"would kneel before me."],[5910,6085,"What's that I hear about the Baron?"]],"19":[[221,337,"Lord Benjamin, sir."],[375,496,"The Duke has dismissed his guards"],[496,592,"and gone on a stroll."],[654,734,"Where to?"],[767,850,"Around where the families"],[850,984,"are being asked to relocate, sir."],[1030,1088,"What?"],[1138,1263,"Well, I hope he doesn't run into"],[1263,1351,"the Wellesleys."],[1405,1468,"Guards."],[1476,1539,"Come with me."],[1751,1951,"What's that I hear about the Baron?"],[2619,2719,"Did I just hear someone"],[2719,2940,"disrespecting my cousin,"],[2952,3065,"the Baron of Stamford?"],[3123,3249,"I, I tried"],[3249,3499,"to pay these lowlifes with gold,"],[3524,3782,"but they refused to leave their pigsty,"],[3803,4066,"and their son even hit me."],[4295,4446,"You scumbag."],[4479,4625,"How dare you lay your dirty hands"],[4625,4742,"on my fiancé?"],[4792,4934,"Do you know who I am?"],[4984,5125,"Why would I care who you are?"],[5192,5422,"He hit my parents, so I hit him back."],[5472,5568,"Sounds fair to me."],[5609,5784,"You are in the town of Stamford,"],[5809,5985,"my cousin's jurisdiction,"],[6014,6206,"and Robert is his head butler."],[6247,6414,"You'll pay for what you've done."],[6481,6660,"Bring him to the dungeons."],[6681,6727,"No."],[6744,6844,"I'll teach him a lesson."],[6873,6994,"No, no, no, please don't."],[7007,7132,"Please don't. - No, please don't."]],"20":[[8,133,"Lord Benjamin's cousin."],[204,362,"Is this how he taught you to behave?"],[379,437,"Oh."],[571,725,"I didn't expect a lowly peasant"],[725,896,"like you to know who my cousin is."],[925,1001,"Don't tell me"],[1001,1113,"he's spoken to you before."],[1180,1251,"Of course."],[1288,1551,"In fact, why don't you ask him who I am?"],[1551,1630,"That's enough."],[1680,1730,"Guards."],[1730,1789,"Seize him."],[1835,2002,"No, no, no, no, no."],[2010,2106,"Don't take Arthur."],[2106,2143,"Please, - No."],[2143,2256,"he just came back. - No, no."],[2260,2389,"Please don't."],[2419,2494,"Let go of me."],[2552,2602,"Please. - This is your"],[2602,2690,"last chance."],[2719,2786,"Seize me,"],[2836,2902,"and you'll have to face"],[2902,3044,"the consequences of your crime."],[3078,3219,"As if I'd fear anything"],[3219,3336,"from a runt like you."],[3336,3482,"I could kill you right now"],[3482,3578,"if I wanted to."],[3649,3858,"Kill me, is that right?"],[3903,3966,"Fine."],[3991,4058,"I'll go with you."],[4129,4237,"But don't say I didn't warn you."],[4245,4329,"Watch your tongue."],[4391,4466,"But don't worry."],[4517,4704,"Soon, you'll be too busy screaming"],[4704,4913,"in my dungeon to talk back."],[4967,5130,"Please, please don't hurt him."],[5130,5251,"No, Arthur. - Father,"],[5292,5447,"Mother, don't worry."],[5480,5588,"I'll be back very soon."],[5638,5747,"You think you're coming back?"],[5789,5876,"Take him away."],[5926,6056,"No, don't! - Arthur!"],[6072,6139,"Arthur! - Wait,"],[6156,6306,"take your hands off my son!"],[6381,6477,"Well, well."],[6548,6744,"I didn't expect that runt to hit me."],[6748,6802,"Just wait,"],[6835,6965,"the two of you will join him soon."],[7052,7123,"Let's go, father."],[7211,7328,"Serves you right, brother."],[7836,7957,"Arthur, no."]],"21":[[271,367,"What happened here?"],[396,517,"Lord Benjamin,"],[533,734,"it was all your butler's doing."],[788,996,"And your cousin, Lady Edith."],[1038,1192,"They even took my son to the dungeon."],[1230,1351,"Your, your son?"],[1593,1760,"Tall and with dark hair?"],[2035,2081,"Oh!"],[2339,2506,"We need to go, now!"],[2736,2861,"God, Carl, what are we gonna do"],[2861,2986,"with Arthur's gone?"],[3061,3115,"Anna..."],[3165,3324,"Anna is engaged to John Moore."],[3324,3424,"The Moores can help."],[3436,3482,"They're engaged,"],[3482,3599,"yes, but that was years ago."],[3603,3732,"John Moore's a rich man now."],[3732,3816,"They surely cant- - Yes but..."],[3828,4029,"We have to try Carl, please."],[4091,4158,"You're right."],[4200,4258,"We have to do - You're right."],[4258,4320,"something. - We have to try."],[4329,4408,"We have to find our son."]],"22":[[350,483,"What happened to that fire?"],[508,617,"That rage?"],[654,700,"Scared of"],[700,867,"the consequences now, runt?"],[900,967,"Consequences?"],[1034,1167,"For giving you what you deserve?"],[1760,1822,"Watch"],[1835,1897,"your"],[1910,1985,"mouth."],[2052,2235,"Your family is done for"],[2235,2456,"and you're still talking back."],[2569,2656,"No, my lady."],[2706,2857,"It's your family that's done for."],[2923,3023,"I've made up my mind."],[3053,3161,"I will not spare you."],[3357,3432,"Me?"],[3440,3603,"Needing sparing from you?"],[3649,3866,"You've gone mad."],[4229,4320,"It seems like"],[4320,4454,"you've gotten it in your head"],[4454,4637,"that you could do something to us."],[4708,5096,"Let me remind you of your place."],[6039,6227,"You insolent brat."],[6423,6598,"What are you doing?"],[6639,6790,"Reminding you of your place."]],"23":[[87,187,"Ah, stop it"],[187,296,"or I'll have you killed!"],[321,508,"You, have me killed?"],[575,729,"You've got the wrong man."],[2022,2173,"Consider it your warning, cousin."],[2348,2498,"The gall of you."],[2565,2673,"Threatening me and then"],[2673,2840,"calling yourself my cousin."],[2886,3015,"I won't let you off easy."],[3161,3240,"You want another go?"],[3253,3403,"Still trying to act tough?"],[3453,3578,"It seems like we'll need"],[3578,3695,"to teach you a lesson."],[3745,3828,"Guards."],[3878,3966,"Flog him."],[4200,4275,"Hold it!"],[4521,4742,"You're not flogging anyone."]],"24":[[37,120,"Hold it!"],[834,975,"Oh cousin, you don't understand."],[1001,1138,"This lowly scum"],[1138,1263,"had disregarded your orders"],[1263,1384,"and impeded the Duke's"],[1384,1509,"relocation efforts and,"],[1543,1705,"and he even tried to punch me."],[1726,1797,"Cousin Benjamin,"],[1797,2022,"you must see to it that he is punished."],[2052,2164,"Stopped oinking"],[2164,2423,"once the Baron showed up, hmm?"],[2439,2581,"Your side of the Wellesley family"],[2581,2690,"is going to be dinner."],[2719,3015,"Sir, this lowly villain is"],[3015,3182,"unfortunately my cousin"],[3232,3349,"just like his parents,"],[3349,3553,"they've no regard for your authority."],[3561,3670,"That's right, Benjamin."],[3682,3787,"What happened, again?"],[3812,3920,"We had gone to the less"],[3920,4120,"fortunate Wellesleys to evict them,"],[4120,4266,"but he tried to stop us."],[4279,4500,"So Edith had him brought here"],[4500,4642,"to teach him a lesson, but it"],[4671,4879,"looks like he hasn't learned anything."],[4900,5000,"Oh, oh sir,"],[5000,5121,"you don't know the half of it."],[5121,5251,"He hit us"],[5251,5430,"and ordered us to kneel to him."],[5480,5618,"He even said that you"],[5630,5764,"were lowlier than he."],[5784,6035,"You must punish him accordingly."],[6089,6206,"As I was saying,"],[6239,6510,"the consequences of your actions."],[6715,6819,"You fool."],[6848,6890,"There'll be"],[6890,7048,"consequences alright."],[7069,7144,"For you!"],[7165,7315,"What for, sir?"],[7486,7536,"Have I done"],[7536,7636,"something wrong, sir?"],[7645,7716,"I don't-"],[7799,8016,"Cousin, you misunderstand."],[8174,8383,"There is no misunderstanding."],[8429,8558,"You've lost your mind?"],[8600,8754,"Do you know who this man is?"]],"25":[[58,216,"Do you know who this man is?"],[262,404,"He's nothing but a beggar,"],[412,583,"the son of peasants."],[880,1117,"Get out of my sight, you pathetic woman."],[1463,1697,"Duke of Mercia, Your Grace."],[1814,1956,"Pardon my tardiness."],[2202,2256,"Duke?"],[2360,2502,"What do you mean Duke?"],[2531,2752,"Sir, you must be mistaken."],[2773,2861,"Rightly so."],[2873,3069,"He's a peasant, a beggar."],[3069,3219,"How could he be the Duke?"],[3478,3666,"Don't question me."],[3682,3741,"No."],[3795,3887,"No, no, no, no, no."],[3887,4074,"This is impossible."],[4074,4270,"How can you say you're the Duke?"],[4270,4329,"You're-"],[4454,4571,"Shut it, Wellesley."],[4637,4813,"You have no right to speak."],[4854,4975,"That low-life’s the Duke?"],[5055,5201,"Carl's son is the Duke?"],[5242,5409,"Oh no, no."],[5426,5584,"George, what have we done?"]],"26":[[325,425,"Lord Benjamin."],[529,592,"It seems that"],[592,759,"you've neglected your duties as Baron."],[909,1030,"Your people have shown me nothing"],[1030,1126,"but disdain."],[1234,1343,"They take from the poor,"],[1372,1497,"torture your innocent,"],[1539,1664,"pillage, and kill."],[1705,1910,"Have you no order in Stamford?"],[2014,2097,"I'll have them punished"],[2097,2202,"for their wrongdoings."],[2235,2348,"Their wrongdoings?"],[2427,2648,"I imagine then it was you"],[2681,2827,"who have allowed them to do this."],[2844,3036,"And it is you who must be punished."],[3148,3299,"Mercy, Your Grace."],[3382,3507,"I will have them flogged!"],[3524,3595,"Exiled!"],[3616,3820,"Punished, to the extent of the law."],[3832,4083,"Please, Your Grace, spare us."],[4187,4241,"Cousin."],[4521,4625,"It's my fault."],[4654,4708,"See?"],[4708,4779,"Your Grace."],[4779,4963,"I, I, I've been a fool."],[5013,5292,"Punish me, flog me as you will."],[5292,5484,"But, let me live."],[5534,5764,"We are from the same family,"],[5780,5868,"Duke Arthur."],[5918,6131,"I don't want to die!"],[6189,6293,"Young Arthur,"],[6293,6477,"my son had just become butler."],[6489,6673,"He's only just delivered us"],[6673,6827,"from the clutches of poverty."],[6886,7077,"Please we adore him so,"],[7115,7449,"you mustn't kill him or exile him."],[7490,7745,"Please I beg you, as your uncle,"],[7774,7953,"as your father's own brother."],[8016,8299,"Oh, you're too cruel, Arthur."],[8375,8504,"How could you do this"],[8504,8666,"to another Wellesley?"]],"27":[[62,150,"Cruelty?"],[204,333,"Have you forgotten your cruelty"],[333,442,"to mother and father?"],[450,596,"Threatening to leave them homeless,"],[596,713,"and laughing in their face"],[713,829,"when they begged you!"],[917,1030,"Have you forgotten what you've done"],[1030,1126,"to my parents?"],[1188,1297,"Your own brother?"],[1539,1634,"And cousin Robert."],[1705,1814,"What happened to making me see"],[1814,1993,"the consequences of my actions?"],[2014,2193,"Did you pity your poor cousin then?"],[2281,2419,"I've seen you for what you are."],[2510,2798,"Shameless and wretched scum."],[2865,3069,"You are unfit to live."],[3257,3382,"Have them dealt with,"],[3403,3545,"and think about what you've done."],[3591,3703,"You're meant to be noble,"],[3749,3841,"not only in your actions"],[3841,3945,"but in your name."],[4037,4175,"See that your people behave,"],[4225,4387,"or I'll have your title removed."],[4458,4600,"I will see to them personally."],[4746,4821,"Oh,"],[4821,4892,"please."],[4892,5042,"Oh sir, please."],[5100,5246,"Robert deceived me."],[5246,5417,"It's, it's all his fault."],[5434,5668,"Please, Duke Arthur, spare me."],[5709,5893,"I'll do anything, for you."],[5964,6018,"Edith."],[6072,6172,"What are you doing?"]],"28":[[0,83,"You villain."],[166,241,"If it weren't for you,"],[241,354,"I never would have gotten involved"],[354,437,"with this mess."],[492,621,"I'm calling off our engagement."],[658,775,"From this moment onward,"],[775,934,"I'll have nothing to do with you."],[996,1051,"I beg of you,"],[1051,1201,"oh great and honorable Duke."],[1259,1343,"Forgive me."],[1468,1539,"Don't you want to see"],[1539,1659,"what I have to offer?"],[1856,1989,"Save it for the brothel."],[2027,2102,"Lord Benjamin."],[2193,2298,"Make sure these vermin"],[2298,2448,"never cross my path again."],[2698,2819,"They make me sick."],[3236,3328,"Guards!"],[3361,3432,"Lock them up."],[3470,3578,"Cousin, please."],[3599,3737,"Won't you speak to him?"],[3791,3891,"Just let me go,"],[3912,4070,"I won't ever do it again."],[4262,4320,"No!"],[4379,4441,"No!"],[4446,4537,"Sir. - Cousin."],[4567,4667,"Please. - Please."],[4717,4783,"Please."],[4783,4863,"No."]],"29":[[362,471,"In good news, Benjamin,"],[550,638,"I found my parents."],[692,817,"Why, that is wonderful,"],[817,900,"Your Grace."],[950,1117,"What a blessed day it is."],[1142,1280,"I wish to host a banquet tonight."],[1317,1618,"Introduce my parents to upper society."],[1730,1843,"Life has been cruel to them,"],[1864,2110,"and, I wish for them to live happily."],[2206,2464,"Oh, and my sister, too. Anna."],[2498,2590,"I want to do something special"],[2590,2677,"for her as well."],[2740,2857,"Did you just say... Anna?"],[2857,2907,"Uh..."],[2998,3115,"As in the maid, Anna?"],[3128,3186,"Right."],[3215,3269,"Anna."],[3315,3415,"She works here, doesn't she?"],[3415,3490,"Uh..."],[3620,3828,"It seems that I have someone"],[3828,3991,"that the Duke might want."],[4183,4266,"Mr. Wellesley,"],[4300,4412,"Lord Benjamin says"],[4412,4562,"Anna is to attend to the Duke"],[4575,4758,"personally for the next few days."]],"30":[[29,150,"Did you just say Anna?"],[291,404,"As in the maid, Anna?"],[412,471,"Right."],[508,554,"Anna."],[613,713,"She works here, doesn't she?"],[713,775,"Uh..."],[784,842,"Bring me to her."],[850,1021,"Uh, no, Your Grace."],[1038,1096,"What?"],[1146,1222,"I thought, uh..."],[1305,1455,"I thought that you fancied her, so I..."],[1484,1593,"What have you done?"],[1609,1722,"Bring me to her, right now."],[2936,3098,"You have fine features"],[3148,3286,"for a scullery maid."],[3340,3520,"I can see why he likes you."],[3636,3791,"Mr. Crowley, did,"],[3837,3953,"did you need something?"],[3958,4083,"Yes, pet."],[4154,4300,"You have been chosen."]],"31":[[104,221,"Take off your clothes."],[283,412,"What are you going to do to me?"],[475,546,"Oh, don't worry."],[567,738,"I have no interest in you."],[817,917,"I wouldn't dare."],[1184,1280,"Put this on."],[1931,1997,"Perfect."],[2089,2252,"I can see why he chose you"],[2252,2335,"in particular."],[2385,2494,"Mr. Crowley,"],[2494,2602,"what's all this about?"],[2665,2798,"The Baron has ordered you"],[2798,2940,"to meet another client."],[2994,3082,"A big man."],[3148,3336,"You are to be his mistress."],[3349,3611,"To satisfy his physical needs,"],[3611,3682,"of course."],[3703,3762,"An honor,"],[3762,3924,"for a common whore like you."],[3974,4116,"No, I refuse."],[4237,4450,"You don't have a choice!"],[4504,4596,"Baron's orders."]],"32":[[262,425,"Do you even know who you are serving?"],[437,558,"It is the Duke."],[579,746,"The one you poured tea on."],[759,917,"What the, the Duke?"],[925,1105,"Dumb already, are you?"],[1163,1343,"Still think you can say no, whore?"],[1351,1405,"Please."],[1405,1509,"I don't want to."],[1509,1572,"No!"],[1972,2310,"It's a good opportunity, dammit."],[2373,2565,"Mr. Crowley, I'm betrothed."],[2573,2761,"I, I don't want"],[2761,2923,"to be another man's mistress."],[2961,3140,"Hadn't your father just fallen ill?"],[3186,3282,"Weren't you complaining"],[3282,3361,"about money?"],[3386,3474,"Don't you even want to"],[3474,3653,"help your family, you ingrate?"],[4896,5171,"Serve the Duke, and the money's yours."],[5192,5338,"You'll have no short supply"],[5338,5551,"of expensive little trinkets."],[6260,6564,"I would never sell my body."],[6614,6773,"Not for a few coppers,"],[6773,6881,"not for anything."],[7086,7215,"I am a woman of honor."],[7286,7557,"Honor is for people who deserve it."],[7557,7749,"Not a lowly whore like you."],[8783,8837,"No!"],[8879,8942,"Oh no."],[8942,9079,"You don't get to say no!"],[9079,9288,"No, let me go, please!"],[9321,9388,"Hands off of her!"]],"33":[[8,79,"Oh no."],[79,216,"You don't get to say no!"],[216,404,"No, let me go, please!"],[421,471,"Stop."],[613,684,"Hands off of her!"],[921,1009,"He didn't hurt you, did he?"],[1021,1226,"Uh, are you the Duke, sir?"],[1393,1547,"Sir, what is the meaning of this?"],[1672,1785,"You imbecile."],[1872,2031,"But sir, you said-"],[2210,2323,"Have you no shame?"],[2335,2552,"Acting like this in my manor."],[2590,2936,"Sir, this bitch refused your orders."],[2977,3161,"It is my right as house steward,"],[3161,3345,"to, to teach her a lesson."],[3632,3757,"Apologize to her,"],[3774,3928,"or I'll have you fired."],[3995,4129,"Apologize, sir,"],[4129,4346,"but she's the lowly scullery maid."],[4391,4521,"She was out of line."],[4854,4979,"A lowly maid?"],[5017,5134,"Mark my words."],[5134,5317,"She's Duke Arthur's sister."]],"34":[[12,221,"She's his sister?"],[254,358,"The lowly maid is"],[417,504,"his sister?"],[588,779,"Are you, really my brother?"],[867,950,"My Arthur?"],[1059,1121,"Yes, Anna."],[1188,1317,"I've come back to protect you,"],[1368,1497,"and mother and father."],[1547,1768,"Oh, Arthur."],[1826,1972,"Where have you been all these years?"],[1972,2102,"We missed you terribly."],[2193,2285,"There, there."],[2469,2594,"Let me deal with this man first."],[3094,3290,"Once again, Lord Benjamin,"],[3370,3420,"your men have"],[3420,3516,"shown their true colors."],[3603,3791,"Disgusting and vile."],[3832,4091,"Sir, I failed to discipline them,"],[4204,4270,"but yes."],[4375,4475,"Sir, Duke."],[4600,4688,"I was wrong,"],[4729,4817,"I would never"],[4817,4909,"have treated her like that,"],[4909,4971,"had I have known that"],[4971,5071,"she was your sister."]],"35":[[20,162,"Yet you see no issue"],[162,346,"in treating her this way if she wasn't."],[362,483,"Isn't that so?"],[629,750,"Lowly servants."],[800,905,"They're worthless in your eyes,"],[905,959,"aren't they?"],[1013,1101,"Well, Mr. Steward,"],[1163,1255,"you're worthless to me."],[1272,1480,"No, it was Benjamin, the Baron."],[1493,1589,"He asked me to. - Lies!"],[1609,1730,"No, I didn't."],[1797,1868,"Guards!"],[1922,2022,"Throw him into the dungeon."],[2022,2081,"No!"],[2102,2289,"No, please. No, sir. - Have him caned."],[2369,2489,"No, no."],[2531,2585,"No."],[2823,3007,"Anna, tell me truly,"],[3107,3190,"are you alright?"],[3219,3457,"Yes, I am now"],[3482,3591,"because you're back."],[3624,3858,"And I can't believe it, you're the Duke."],[3916,4116,"Oh, let's go see mother and father."],[4116,4287,"They'll be overjoyed, I just know it."],[4308,4517,"Anna, I've already met them."],[4587,4808,"Oh, then you must know"],[4808,4992,"the years have been quite hard on them."],[5080,5180,"But it's all worth it"],[5213,5338,"because you're back."],[5409,5530,"Anna, stay here."],[5626,5755,"I'll bring them here, okay?"]],"36":[[0,58,"Duke Arthur,"],[58,183,"I believe that your parents"],[183,346,"are currently at the Moore's."],[392,550,"John Moore has been engaged"],[550,738,"to your sister for some time."],[838,1138,"Yes, John and I are engaged, but-"],[1184,1326,"He's your fiancé, Anna,"],[1380,1480,"so I'll love him like a brother."],[1572,1651,"Lord Benjamin."],[1680,1776,"Arrange a feast for tonight."],[1868,1972,"I want to show our parents"],[1972,2052,"high society."],[2173,2302,"And invite John Moore."],[2402,2506,"I'll speak to the King,"],[2544,2765,"see if he can grant him a noble title."],[3011,3119,"As you wish, Duke Arthur."],[3928,4024,"Is that the Moore's home?"],[4079,4220,"A fine place for a merchant family,"],[4220,4283,"but,"],[4375,4462,"they'll be able to afford better,"],[4462,4533,"very soon."],[4888,5021,"Well, we're here."],[5092,5288,"The home of our supposed son-in-law."],[5296,5363,"Yeah."],[6131,6285,"You tottering fool."],[6439,6594,"Why have you come back?"]],"37":[[4,229,"John, this is your fiancée's father."],[371,583,"You will call me Mr. Moore."],[784,917,"And you are nothing to me."],[942,1009,"John?"],[1017,1226,"That's Mr. Moore."],[1230,1297,"John..."],[1393,1459,"I'm sorry."],[1530,1609,"Mr. Moore."],[1672,1801,"Please, let's talk-"],[1801,1910,"And what is this"],[1910,2102,"about me being your daughter's fiancé?"],[2235,2364,"You've always been poor,"],[2364,2527,"but now you're liars, too."],[2556,2606,"Mr. Moore."],[2606,2740,"You know as well as I do."],[2781,2840,"You've been"],[2840,3065,"betrothed to Anna for years."],[3115,3169,"Your father and I,"],[3169,3249,"we had an arrangement."],[3249,3374,"That may be so,"],[3424,3620,"but circumstances have changed."],[3670,3866,"Do you think my father"],[3887,4033,"would want me marrying someone"],[4033,4216,"that comes from you filthy swine?"],[4233,4429,"That's not why we're here today."],[4521,4629,"We're here because-"],[4650,4708,"Oh, I know."],[4779,4934,"Money, isn't that right?"],[5221,5359,"Alms for the poor."],[5451,5555,"Now away with you."],[5655,5751,"Mr. Moore,"],[5789,5935,"we didn't come here today for money."],[5943,6081,"That's enough."],[6114,6302,"Your breath reeks."],[6427,6585,"Beat some sense into the old codger,"],[6585,6681,"and take him out of here."],[6769,6823,"No."],[6856,6998,"I'd like to see you try."]],"38":[[100,229,"I'd like to see you try."],[613,792,"Arthur, my boy."],[850,946,"They set you free."],[1001,1121,"Rightfully so, father."],[1130,1401,"Arthur, it's so good to see you"],[1401,1543,"alive and well."],[1589,1639,"Father."],[1714,1764,"Mother."],[1856,1931,"Robert's been punished"],[1931,2027,"for what he did to you."],[2118,2218,"You must be the son"],[2218,2369,"I keep hearing so much about."],[2456,2552,"Weren't you kidnapped"],[2552,2660,"to join the army?"],[2727,2840,"Run away, did you?"],[2940,3011,"And now you've come here"],[3011,3128,"to leech off me."],[3157,3249,"You're John Moore."],[3436,3653,"Now, did I hear you say"],[3682,3849,"you wanted to have my father beaten?"],[3878,4012,"So what if I did?"],[4154,4304,"What's a runt like you"],[4304,4425,"going to do about it anyway?"],[4471,4537,"Cry?"],[4571,4675,"Piss your pants?"],[4763,4854,"Say that again."]],"39":[[554,625,"If you think I’m gonna"],[625,721,"take it easy on you"],[734,880,"because you're engaged to my sister,"],[996,1076,"then you'd be wrong."],[1126,1355,"Let go of me, you dirty dog."],[1835,2039,"Resorting to violence now, are we?"],[2102,2273,"Like the lowlife you are."],[2377,2569,"Come on, then, hit me,"],[2644,2811,"and you’ll regret ever being born."],[2811,2932,"You think that can stop me?"],[3119,3253,"Who do you think you are?"],[4083,4225,"Oh, just a peasant."],[4295,4441,"John, my darling,"],[4441,4562,"I come bearing good news."],[4608,4758,"Father says the Duke has arranged"],[4758,4888,"for a banquet at the manor,"],[4888,4988,"and you're invited."],[5009,5113,"And the Duke is going to"],[5113,5292,"ask the King to grant you a title."],[5305,5367,"Finally, you can be"],[5367,5476,"part of upper society"],[5476,5572,"and we can marry."],[5593,5663,"A title?"],[5684,5834,"Adela, tell me it's true."],[5860,5955,"I'll finally have a name"],[5955,6072,"to match my wealth."],[6227,6318,"No one will be able to tell us"],[6318,6373,"what to do."],[6418,6589,"No one will be able to say no to us."]],"40":[[0,187,"Of course it's true, John darling."],[187,312,"The Duke adores my father,"],[312,454,"he's the Baron, after all."],[471,513,"In fact,"],[513,667,"the Duke is at the manor right now."],[938,1005,"Don't waste your time"],[1005,1084,"with these peasants."],[1084,1159,"Let's go, John."],[1188,1238,"Lady Adela,"],[1238,1326,"I'm afraid we must deal"],[1326,1443,"with these peasants first."],[1493,1609,"As dirty as they are,"],[1609,1835,"this is Arthur, Anna's brother."],[1926,2039,"And now that I'm rich,"],[2052,2131,"he wants to force me"],[2131,2243,"to marry his sister."],[2298,2381,"What did you say?"],[2615,2690,"Oh, I see."],[2761,2827,"You're that boy"],[2827,2957,"that was kidnapped as a child."],[3073,3186,"Well then,"],[3186,3261,"be gone."],[3299,3370,"We've nothing to give,"],[3370,3453,"shameless beggar."],[3707,3924,"Oh, don't touch me, you disgusting man."],[3924,4099,"Don't you know who my father is?"],[4099,4216,"Lord Benjamin, evidently."],[4337,4416,"Don't you know?"],[4479,4554,"Even your father"],[4554,4683,"watches his tongue around me."],[4842,4892,"Adela."],[4971,5080,"Oh, I can't believe"],[5080,5355,"I've been touched by a dirty beggar."],[5392,5492,"Have you no manners"],[5492,5584,"around the rich?"],[5634,5709,"You scum."],[5751,5926,"You better beg for forgiveness,"],[5926,5997,"if you want to live."],[6010,6097,"And what authority"],[6097,6193,"do you have over me?"]],"41":[[0,75,"And what authority"],[75,162,"do you have over me?"],[179,371,"Every authority, peasant scum."],[500,738,"My father is the Baron of Stamford."],[763,896,"And now that you're all here,"],[896,1009,"let it be known,"],[1084,1305,"I am not going to marry Anna."],[1380,1488,"I am to be a noble,"],[1522,1630,"so do not let me catch sight of"],[1630,1697,"you all again."],[1864,2010,"Going back on your word, John?"],[2064,2164,"That's unbecoming"],[2164,2277,"of your future title."],[2277,2381,"I think John has made himself"],[2381,2489,"clear enough."],[2531,2727,"Get lost, you blood-sucking leech."],[2756,2865,"Leaching off of him?"],[3032,3098,"I would never."],[3190,3415,"His money is as vile as his word."],[3566,3628,"No matter,"],[3787,3874,"a man like you"],[3874,4091,"doesn't deserve my sister anyway."],[4208,4341,"Men, get him."],[4512,4608,"No!"]],"42":[[0,116,"Men, get him."],[183,283,"No!"],[492,692,"Arthur, we will tell Anna."],[771,950,"But, please,"],[1051,1226,"we cannot anger Mr. Moore,"],[1226,1430,"he's going to be a noble man."],[1472,1526,"At least"],[1526,1680,"your chambermaid of a mother"],[1680,1760,"knows how to act"],[1760,1876,"in front of men like me."],[1931,2218,"Drop the matter, and I'll let you leave."],[2318,2369,"Please."],[2598,2648,"We'll go."],[2723,2836,"But best you remember,"],[2965,3111,"it is the Wellesleys"],[3128,3269,"who called off this engagement,"],[3407,3595,"because you, John Moore,"],[3691,3858,"are unfit for my sister."]],"43":[[4,337,"John Moore, are unfit for my sister."],[354,533,"My word."],[533,713,"Unfit, for you?"],[792,871,"Let's see,"],[896,1172,"servant, servant, beggar."],[1213,1343,"Oh, you're too funny."],[1413,1472,"Take this as"],[1472,1601,"a friendly warning, John."],[1701,1864,"Lest you regret your decision later."],[1881,2018,"I have no mind to regret"],[2018,2198,"anything regarding you lot."],[2218,2394,"Now that that's settled,"],[2469,2656,"if you ever speak to us again,"],[2698,2857,"I will have your legs cut off."],[3028,3098,"Come now,"],[3115,3236,"we have a banquet to attend."]],"44":[[225,450,"Well, that's the Moores for you,"],[483,575,"some coin and,"],[638,696,"and they forget everything that"],[696,779,"we've ever done for them."],[834,909,"Oh, Arthur,"],[996,1088,"I wish we had"],[1109,1297,"a better reception for you."],[1297,1497,"Oh mother, don't say that, please."],[1534,1639,"I've already arranged something"],[1639,1701,"for you."],[1735,1847,"I finally found you."],[1868,1993,"That's cause for celebration."],[2006,2181,"You've arranged something? No."],[2256,2352,"No, I..."],[2406,2569,"Please, I hope you"],[2569,2723,"haven't spent any coin on us."],[2723,2865,"Arthur, what have you arranged?"],[2882,2969,"Just something small"],[2969,3057,"at the Baron's Manor."],[3136,3228,"Don't worry, mother."],[3307,3378,"It's been paid for."],[3420,3511,"At the Baron's Manor?"],[3511,3674,"Arthur, we-"],[3674,3757,"haven't you heard"],[3757,3858,"the Duke will be there."],[3895,4120,"We can't possibly impose, it's..."],[4208,4466,"Like I said, Mother, don't worry."],[4496,4575,"You'll see."],[4625,4729,"Oh."]],"45":[[446,750,"Lady Adela, this is all very splendid."],[800,1009,"You must introduce us to the Duke"],[1009,1113,"when he arrives."],[1113,1322,"Oh, Mrs. Moore, of course."],[1347,1468,"As the Baron of Stamford,"],[1468,1705,"my father is very close to the Duke."],[1764,1885,"It's likely he was the one"],[1885,2077,"to recommend John in the first place."],[2185,2235,"Of course,"],[2235,2394,"the Duke would love to meet you."],[2394,2489,"I cannot believe it."],[2489,2673,"A noble title."],[2673,2761,"Lady Adela,"],[2761,2982,"you are simply full of surprises."],[2994,3178,"You are the best match for John,"],[3178,3311,"no doubt about it."],[3432,3557,"I’ve been meaning to ask, Adela."],[3620,3762,"Why would someone like the Duke"],[3762,3928,"come to Stamford in the first place?"],[3953,4166,"Why, Stamford is his hometown."],[4212,4362,"The King dispatched him here"],[4362,4483,"to oversee the building"],[4483,4562,"of a new fort."],[4675,4863,"The real reason is his parents."],[4888,4992,"He was separated from them"],[4992,5109,"when he was a child."],[5155,5292,"Even this banquet, I hear,"],[5292,5372,"is all for them."],[5480,5630,"Must be good, noble people,"],[5672,5905,"to rear such a fine man like the Duke."],[5905,6131,"We must make a good impression."],[8103,8258,"How did those peasants get in?"]],"46":[[258,329,"This banquet,"],[417,533,"I've arranged it all for you."],[650,800,"I'll introduce you to everyone shortly."],[888,1117,"Arthur, don't jest."],[1117,1255,"What do you mean, for us?"],[1343,1547,"Mother, I'm serious."],[1659,1747,"This is all for you."],[1797,2014,"But, how could you have arranged"],[2014,2085,"all this?"],[2131,2256,"How much money did you spend?"],[2323,2502,"Money has nothing to do with it, Father."],[2565,2686,"I just want to see you happy."],[2711,2794,"We are happy,"],[2873,2969,"truly happy."],[3082,3249,"We're finally all together again."],[3691,3787,"John, I thought"],[3787,3924,"you told them to get lost."],[3924,4020,"Why are they back?"]],"47":[[183,283,"John, I thought"],[283,417,"you told them to get lost."],[417,521,"Why are they back?"],[538,658,"Damn lowlives."],[729,855,"They must have tailed us in."],[963,1163,"I knew those ill-bred dogs"],[1163,1292,"wouldn't go away that easily."],[1322,1480,"Scoundrels, all."],[1497,1630,"Mrs. Moore."],[1664,1818,"Rest easy,"],[1839,1972,"this banquet is held"],[1972,2122,"on the Duke's orders."],[2122,2277,"And father asked me to see"],[2277,2489,"that our guests enjoy themselves."],[2556,2669,"I have every authority"],[2669,2781,"to throw them out."],[3153,3219,"Come."],[4225,4316,"Who let you in?"]],"48":[[45,137,"Who let you in?"],[221,358,"You must be lost, peasant."],[371,554,"This is the Duke's banquet,"],[579,746,"not the gruel kitchen."],[784,900,"I suggest you turn around"],[900,975,"immediately."],[975,1155,"And I suggest you shut your mouth."],[1297,1434,"This is my manor."],[1468,1643,"My father is hosting it"],[1655,1856,"under direct orders of the Duke."],[1872,2085,"You have no place to speak here."],[2252,2314,"And you."],[2427,2544,"You must be the bitch"],[2544,2686,"that John was engaged to."],[2761,2877,"I'll have you know,"],[2877,3132,"John is going to be a noble."],[3224,3395,"You'll have no way into his home,"],[3440,3616,"unless you'd like to be our maid"],[3616,3753,"once we marry."],[3849,3983,"Low-born as I may be,"],[4037,4158,"I'm still more noble than"],[4158,4287,"a harlot like you."],[4287,4421,"You wench."],[4454,4562,"I will not let you talk"],[4562,4708,"to Lady Adela like this."],[4763,4950,"Apologize, right now."],[4950,5117,"I owe her nothing of the sort."],[5138,5230,"She is the one who's"],[5230,5372,"courting an engaged man."],[5405,5638,"I told your parents,"],[5638,5768,"and your disgusting"],[5768,5885,"beggar of a brother,"],[5885,6143,"I called off the engagement."],[6210,6368,"You're not good enough for me."],[6406,6473,"You're wrong."],[6523,6598,"It's you who isn't"],[6598,6681,"good enough for me."],[6752,6873,"I would never marry a man"],[6873,7019,"with such a fickle heart,"],[7065,7211,"who would abandon his fiancée"],[7211,7428,"just to chase after some harlot's coin."],[7832,7962,"You dirty bitch."],[7962,8049,"That's what you get"],[8049,8245,"for talking to my son like that."]],"49":[[29,200,"How dare you raise your hands"],[200,283,"to my daughter?"],[283,504,"How dare she insult my son?"],[554,679,"You're right, Mother."],[679,746,"We ought to slap"],[746,855,"some sense into them."],[900,1080,"Anna, look at yourself,"],[1101,1188,"you're nothing"],[1217,1347,"compared to Lady Adela."],[1393,1551,"It's no wonder I chose her."],[1622,1743,"Lady Adela"],[1743,1931,"is Lord Benjamin's daughter."],[2060,2185,"What do you have"],[2185,2360,"that Lady Adela doesn't?"],[2406,2565,"Besides this useless"],[2590,2740,"beggar of a brother?"],[2840,2982,"Do not insult my brother,"],[3007,3169,"he is more noble than any of you."],[3978,4079,"All this dirty work"],[4079,4191,"must have done you in."],[4325,4433,"A beggar?"],[4433,4517,"Like him?"],[4546,4713,"You lowly peasants."],[4729,4950,"None of you deserve to talk to us."],[4950,5067,"Get out,"],[5067,5255,"or we'll throw you out with force."]],"50":[[0,91,"Get out,"],[91,308,"or we'll throw you out with force."],[308,462,"It is you who ought to be thrown out!"],[1067,1159,"What a pretty,"],[1205,1455,"money-sucking leech."],[1601,1764,"Oh, Adela,"],[1764,1985,"I'm disgusted by the implication."],[2135,2344,"Despite her features,"],[2344,2410,"a maid that"],[2410,2577,"cleans chamber pots all day"],[2577,2777,"is more fit to marry a stable boy."],[2802,3028,"Say that again, and I'll make you pay."],[3132,3211,"Oh no,"],[3265,3390,"what are you going to do?"],[3474,3528,"Hit me?"],[3666,3899,"Well, come on then, have at it."],[4245,4295,"Well,"],[4416,4575,"I do say I think this was the first time"],[4575,4696,"I heard someone ask for it."],[4758,4817,"But,"],[4921,5088,"I think we all heard him clearly enough."],[5263,5376,"You villain."],[5417,5476,"You actually-"],[5476,5593,"You asked for it."],[5663,5743,"I obliged."]],"51":[[221,296,"Lord Benjamin,"],[371,467,"the Duke has arrived."],[521,642,"He's here already?"],[671,763,"We have to go."],[817,917,"You asked for it."],[955,1151,"I am to be a noble,"],[1151,1368,"and you will not offend me again."],[1384,1476,"Why should I care?"],[1505,1593,"I'm sure Lord Benjamin"],[1593,1668,"would understand."],[1701,1893,"Do not speak my father's name."],[1947,2056,"You're dead,"],[2056,2164,"my father will see to it"],[2164,2256,"when he arrives."],[2285,2402,"On your knees."],[2448,2519,"And I demand you"],[2519,2686,"apologize to John now!"],[2773,2957,"And your filthy parents too."],[2973,3032,"Down!"],[3032,3119,"Who do you think you are,"],[3119,3207,"barking orders at me?"],[3224,3386,"Don't think you're so high and mighty"],[3386,3586,"just because you followed us in."],[3586,3770,"You have no right to speak to my son"],[3770,3941,"or Lady Adela like this."],[3941,4041,"Don't you know"],[4041,4250,"how much I suffered being betrothed"],[4250,4437,"to your dirty whore of a sister?"],[4512,4775,"I will not let you embarrass me again."]],"52":[[8,133,"We've been gracious enough"],[133,250,"letting the matter go,"],[250,425,"yet you shameless rats"],[425,575,"won't stop bothering us."],[592,754,"Away, off with you."],[771,871,"Oh Mrs. Moore,"],[871,1067,"I have a much better idea."],[1167,1292,"Let's add a few tears"],[1292,1434,"to their teary reunion."],[1459,1526,"Guards!"],[1876,1956,"Execute him."],[1956,2031,"No!"],[2085,2168,"I want to watch"],[2168,2339,"as they lose their precious son,"],[2402,2460,"again."],[2565,2702,"Oh, Lady Adela."],[2702,2823,"I think if that's the case,"],[2823,2977,"we ought to keep him alive."],[3007,3203,"He's already a useless beggar,"],[3249,3365,"we ought to break his legs,"],[3365,3499,"and keep him that way."],[3511,3632,"Lisa, uh,"],[3632,3707,"Lady Moore."],[3728,3953,"Please, I apologize."],[3991,4170,"I'll have Arthur repent, right away."],[4170,4279,"Yes, please."],[4291,4441,"Pardon us, but Arthur."],[4454,4675,"Please, I beg of you, apologize."],[4704,4783,"Please."],[4850,5025,"You have enough wit to be scared,"],[5025,5171,"but it's too late."],[5184,5288,"It's not my fault"],[5288,5455,"you've been grating on my nerves."],[5467,5630,"I've nothing left for pity."],[5651,5855,"Seems like you have quite a loud bark"],[5855,5964,"with no bite, ma'am."]],"53":[[0,162,"What did you just say to me?"],[296,471,"Mother, Father,"],[508,583,"I already told you,"],[608,734,"this banquet is for you."],[792,846,"In honor of us"],[846,959,"all being together again."],[1009,1130,"You have every right"],[1130,1217,"to enjoy yourself."],[1272,1401,"And my sister was correct."],[1430,1530,"You ought to apologize"],[1530,1634,"for your poor behavior,"],[1647,1772,"and I ought to have you thrown out."],[1843,2089,"Soon, you'll be kneeling before us,"],[2089,2185,"begging for the forgiveness"],[2185,2344,"we have every right to withhold!"],[2377,2677,"A pity, to have a son like him."],[2677,2740,"Imagine,"],[2740,2965,"spending ten years to find your son,"],[2965,3153,"just to have him turn out like this."],[3194,3307,"The real pity is what will be happening"],[3307,3403,"to you soon,"],[3486,3574,"I think I'll be quite happy"],[3574,3641,"in the future."],[3807,4012,"Oh, yes, happy."],[4033,4158,"Very happy, I imagine,"],[4158,4295,"with your legs mangled,"],[4295,4450,"crawling on the ground."],[4504,4575,"Aw,"],[4575,4733,"and your poor parents,"],[4733,4892,"I'm sure they'll be very joyous"],[4892,5021,"over such a sight."],[5088,5159,"Seize him!"],[5184,5301,"No, no."],[5342,5447,"Please, no."],[5447,5543,"Presenting,"],[5543,5730,"The Honorable Lord Benjamin,"],[5730,5872,"Baron of Stamford."]],"54":[[0,208,"Oh, you're in for it now."],[241,325,"Lord Benjamin"],[325,558,"is the most powerful man in Stamford."],[604,767,"And he's backed by the Duke,"],[788,867,"whose authority"],[867,1009,"is second only to the King."],[1051,1242,"You poor, poor souls,"],[1272,1434,"we'll see what the Duke has to say"],[1434,1580,"when he hears about this."],[1580,1772,"I reckon you'll all be beaten to death"],[1772,1847,"in the dungeons."],[1847,2027,"Don't waste your breath, madam."],[2060,2168,"A commoner like him"],[2168,2339,"can't even fathom the great power"],[2339,2439,"the Duke has."],[2469,2615,"Of course, Lady Adela."],[2615,2744,"It'd be an honor for him"],[2744,2902,"to lay eyes on the gentlemen,"],[2948,3078,"before he crushes them"],[3078,3257,"like the rats they are."],[3361,3620,"Oh, I can't wait."],[3620,3703,"How unfortunate,"],[3703,3820,"it had to come to this."],[3820,3958,"Oh yes."],[3958,4187,"How unfortunate it is for you."],[4237,4462,"Lord Benjamin is my father."],[4491,4654,"And once I tell him what you've done"],[4654,4888,"to me and my dear John,"],[4921,5088,"he'll have you all beheaded."],[5121,5176,"No."],[5276,5409,"Oh, how lucky it is"],[5409,5593,"to be so simple minded."],[5659,5893,"You, half-dead codgers,"],[5922,6122,"and you, harlot."],[6289,6423,"Any last words?"],[6473,6660,"No teary goodbyes?"],[6706,6944,"Or, do you wish to die with him?"],[6973,7094,"John, please,"],[7123,7253,"Arthur was just impulsive."],[7261,7415,"Please, put in a good word for him."],[7419,7636,"Get your dirty hands off of me."],[7661,7766,"You scoundrel!"],[7766,7849,"I'll do it again."]],"55":[[0,129,"You scoundrel!"],[129,208,"I'll do it again."],[417,475,"John! - No!"],[529,667,"My darling boy."],[667,800,"How dare you."],[800,934,"Touch my parents again,"],[934,1051,"and your family will pay."],[1130,1222,"Let it be known,"],[1238,1334,"this night was meant to be"],[1334,1401,"a joyous one,"],[1422,1555,"and I did not wish to taint it"],[1555,1722,"with strife and bloodshed."],[1797,1889,"I would have let you go,"],[1931,2102,"as awful as your behavior was to me."],[2102,2331,"But you insulted my virtuous sister,"],[2331,2427,"and raised your hand"],[2427,2577,"to my saintly mother and father."],[2690,2852,"Your actions beg for punishment,"],[2852,2998,"and I am happy to see to it."],[3199,3294,"Let it be known,"],[3336,3499,"I plan to exile the Moore family"],[3499,3628,"from the good town of Stamford."],[4083,4379,"Oh, you've gone mad, truly mad."],[4425,4504,"Lady Adela,"],[4504,4646,"have your men restrain him"],[4646,4800,"for the safety of your guests."],[4838,4929,"And have him flogged"],[4929,5021,"in the dungeon."],[5296,5551,"What's this again about the dungeons?"],[5839,5939,"Lord Benjamin."],[5939,6039,"You've finally come."],[6043,6097,"My Lord,"],[6097,6218,"We've been troubled so"],[6218,6389,"by these lowly peasants."],[6389,6502,"Father, it's them,"],[6502,6690,"I say, we take them to the dungeons."]],"56":[[41,254,"This is the Duke's banquet, Adela,"],[308,500,"I will not tolerate your antics."],[567,692,"Pardon me, Father."],[692,834,"It seems I have been lax,"],[859,1042,"for these lowly, dirty servants"],[1042,1138,"have snuck in."],[1217,1443,"Lowly, dirty servants?"],[1718,1830,"Yes, Father."],[1856,2027,"The mister and misses are servants,"],[2027,2164,"and so is the daughter."],[2202,2356,"And he's a beggar."],[2394,2606,"A vile, disgusting man."],[2648,2786,"Perhaps we could send them away"],[2786,2965,"with some scraps from the kitchens."],[2965,3090,"I daresay they'd be better than"],[3090,3219,"anything they've ever tasted."],[3253,3478,"Oh, Father, please allow me to see it,"],[3478,3632,"I'll have their bones broken"],[3632,3774,"and left out for the dogs,"],[3774,3995,"for disturbing the Duke's banquet."],[4033,4104,"Ah!"],[4104,4200,"Silence!"],[4291,4425,"But, Lord Benjamin, why?"],[4592,4934,"Duke of Mercia, Arthur, Your Grace."],[5025,5138,"At your service."],[5238,5492,"Hail to His Grace, the Duke Arthur."],[6456,6510,"What?"],[6585,6685,"That's him?"],[6752,6869,"He's Duke Arthur?"]],"57":[[0,104,"That's him?"],[162,266,"He's Duke Arthur?"],[487,596,"Lord Benjamin."],[679,838,"I was promised a warm welcome."],[838,963,"What is all of this?"],[1017,1238,"I'll see to it, your Grace."],[1238,1297,"My boy."],[1426,1568,"What did the Baron say?"],[1568,1659,"Is it Duke Arthur"],[1659,1772,"that he just called you?"],[1872,1926,"What?"],[2002,2068,"Sir."],[2147,2206,"Madam."],[2289,2360,"Please,"],[2485,2731,"Benjamin, at your service."],[2752,2861,"I don't understand."],[2940,3040,"Are you really-"],[3040,3111,"Yes, Father."],[3432,3507,"I'm the Duke."],[3595,3795,"My boy, the Duke?"],[3916,3999,"That's my son."],[4041,4133,"That's my son!"],[4204,4287,"He's a Duke!"],[4316,4429,"What did I say?"],[4462,4692,"My brother is more noble than anyone."],[4813,4884,"Lord Benjamin,"],[4925,5075,"are, are you certain he's the Duke?"]],"58":[[0,58,"Father,"],[158,329,"you said the Duke was a great man,"],[350,462,"you must be mistaken."],[646,796,"You stupid girl."],[825,955,"How could I be wrong?"],[1038,1172,"And you,"],[1172,1309,"you ought to be ashamed."],[1359,1576,"How dare you do this to his Grace,"],[1576,1685,"Duke Arthur?"],[1685,1889,"No, it can't be."],[1922,2085,"Father, tell me it's a joke."],[2085,2198,"It simply can't be."],[2252,2402,"Get on your knees, girl!"],[2444,2590,"And maybe he'll forgive you."],[2827,2886,"No."],[2927,3023,"You said that the Duke"],[3023,3161,"was going to give John a title,"],[3161,3269,"why would John call off"],[3269,3420,"the engagement to his sister?"],[3645,3757,"Maybe this will get through"],[3757,3883,"your thick skull,"],[3941,4220,"he is the Duke, the one and only."],[4312,4504,"Guards, take her away"],[4504,4696,"until she's learned her lesson."]],"59":[[100,296,"Guards, take her away"],[296,458,"until she's learned her lesson."],[513,592,"No."],[646,746,"Father, no."],[746,800,"He can't be!"],[800,909,"He can't be the Duke!"],[925,1076,"He simply can't be!"],[1384,1643,"Your Grace, I must apologize."],[1643,1710,"That's enough."],[1780,1835,"Your family"],[1835,1981,"has played your hand for you."],[2010,2122,"Duke Arthur, sir."],[2252,2348,"Why, certainly,"],[2402,2548,"my son is still engaged"],[2548,2686,"to the Wellesley's daughter."],[2686,2932,"Our connection is nothing to scoff at."],[2969,3023,"Mother,"],[3061,3269,"my brother-in-law, a Duke?"],[3303,3399,"we'll be even richer."]],"60":[[8,212,"My brother-in-law, a Duke?"],[250,354,"we'll be even richer."],[387,525,"We’ll be set for life."],[579,784,"Oh, married to the sister of the Duke,"],[821,909,"oh, goodness."],[942,1038,"That must be why"],[1038,1192,"he wanted to give me a noble title,"],[1247,1372,"so I can marry Anna."],[1430,1664,"Anna, can you believe it?"],[1664,1826,"Your brother, a Duke."],[1826,1989,"What does that have to do with you?"],[1989,2152,"It has everything to do with me,"],[2152,2214,"darling."],[2256,2448,"You're my fiancée, remember?"],[2485,2577,"Don't forget about me"],[2577,2623,"just because your"],[2623,2748,"brother's a Duke, now."],[2748,2982,"You are truly shameless, John."],[3032,3107,"Don't be like that,"],[3107,3269,"my dear, darling fiancée."],[3269,3340,"Fiancée?"],[3399,3474,"Have you forgotten"],[3474,3599,"what you just called me?"],[3649,3799,"A dirty whore?"],[3862,4049,"Only fit to wed a stableboy."],[4049,4145,"Isn't that right?"],[4170,4416,"Oh, Anna, forgive him, would you?"],[4479,4600,"Pettiness doesn't suit"],[4600,4788,"a pretty face like yours."],[4817,4913,"Women like us,"],[4913,5009,"we ought to understand"],[5009,5167,"our husband's temperaments."]],"61":[[0,79,"My sister?"],[158,208,"Petty?"],[258,392,"That's rich coming from you."],[454,604,"Oh, Duke Arthur."],[646,750,"Uh, my brother."],[771,938,"I must apologize for what I said."],[992,1138,"I'll apologize to Anna."],[1138,1251,"There is no need."],[1301,1384,"I have no wish to hear"],[1384,1526,"anything further from you."],[1584,1718,"The woman has spoken, John."],[1785,1981,"It seems my sister disdains"],[1981,2072,"your vile habits."],[2118,2344,"Anna, this is all my fault."],[2373,2560,"We grew up together, didn't we?"],[2594,2698,"I loved you."],[2761,2840,"I did."],[2877,2936,"This has all been"],[2936,3032,"a big misunderstanding,"],[3032,3123,"of course."],[3140,3303,"I'm sure you can forgive me."],[3349,3549,"Please, give me another chance."],[3591,3958,"Yes, dear, just a misunderstanding."],[3958,4145,"Let's put it all behind us now,"],[4145,4220,"shall we?"],[4320,4362,"Yeah."],[4487,4579,"Forgive you?"],[4637,4750,"I don't think I will."],[4792,4934,"It would be a sin to forget"],[4934,4992,"what you've done"],[4992,5142,"to my mother and father."],[5142,5263,"My brother's title"],[5263,5409,"has nothing to do with you."],[5442,5588,"I wish for you to be gone"],[5618,5747,"and to never come back."],[5830,5889,"Anna."],[6202,6289,"Forgive me,"],[6423,6527,"you're better than this."]],"62":[[16,216,"Please, forgive me,"],[246,367,"you're better than this."],[671,813,"Leave my sister alone, scum."],[813,980,"Your apology means nothing."],[980,1292,"Please, your Grace, Duke Arthur,"],[1292,1438,"It's all my fault."],[1438,1630,"I've wronged you, I admit it."],[1630,1760,"I beg your pardon."],[1860,2118,"Mr. Wellesley, madam."],[2168,2385,"Please ask Arthur to show us mercy."],[2448,2610,"I was betrothed to Anna,"],[2610,2857,"I, I, I've shown her much kindness."],[2894,3203,"Mother, please ask him to forgive me."],[3203,3378,"I cannot live without Anna."],[3490,3641,"Jane, please,"],[3666,3787,"I even got you the job"],[3787,3883,"at the Baron's Manor."],[3908,4054,"Are you going to be so cruel"],[4054,4175,"as to forget everything"],[4175,4279,"I've done for you?"],[4279,4450,"That John's done for you?"],[4496,4817,"A bit of compassion, for an old friend."],[4854,5075,"Yes, Mr. Wellesley, please."],[5100,5246,"I'll do anything for her."],[5246,5409,"I'll give her whatever she wants."],[5430,5530,"If you'd just,"],[5559,5755,"please forgive my one transgression."],[5872,6131,"How dare you ask for compassion?"]],"63":[[20,262,"How dare you ask for compassion?"],[287,412,"Have you shown any compassion"],[412,600,"to my father, to my mother?"],[646,888,"Those ten long years I was gone,"],[917,1009,"did you help them at all?"],[1059,1247,"Did you give them any aid?"],[1276,1438,"You speak of them as an old friend,"],[1480,1630,"as if they have ever forsaken you."],[1726,1772,"But you..."],[1847,1889,"Had I not"],[1889,1993,"been announced as the Duke,"],[2014,2143,"you would've kicked them to the ground"],[2152,2318,"and spit on their bodies."],[2381,2544,"You called off my sister's engagement"],[2544,2731,"for the first noble lady you saw,"],[2781,2944,"you do not deserve my mercy."],[2998,3136,"Duke,"],[3136,3290,"Arthur, I-"],[3290,3357,"Silence."],[3386,3511,"I've seen you at your worst,"],[3607,3732,"I've seen how you treated me,"],[3787,4029,"my father, my mother, Anna."],[4108,4425,"You are a shameless, filthy villain."],[4487,4562,"Begone."],[4779,4854,"Lord Benjamin."],[4879,4938,"Yes, sir."],[4992,5050,"Have the Moores"],[5050,5150,"removed from the manor."]],"64":[[41,112,"Lord Benjamin."],[141,200,"Yes, sir."],[250,312,"Have the Moores"],[312,437,"removed from the manor."],[471,633,"And forbid anyone"],[679,771,"from doing business with them"],[771,859,"in the town of Stamford."],[913,959,"Yes, sir."],[1493,1568,"Much better."],[1718,1885,"Father, Mother,"],[2072,2131,"Anna,"],[2252,2410,"let us enjoy this banquet in peace."],[2527,2598,"Arthur,"],[2665,2994,"this banquet is lovely, thank you."],[3086,3315,"But nothing is better than us"],[3324,3553,"being reunited as a family."],[3616,3753,"And together we'll be,"],[3803,3878,"forever."]]}