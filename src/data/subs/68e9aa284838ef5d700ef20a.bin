{"1":[[604,663,"Coming!"],[1743,1881,"What happened to my parents?"],[1881,2027,"Something changed before I came"],[2027,2131,"home for Thanksgiving."],[2131,2314,"Can things ever be normal again?"],[2719,2823,"Hope you're ready for a"],[2823,3007,"Crazy Coleman Thanksgiving!"],[3036,3153,"Even Uncle Sean"],[3153,3311,"and your cousins are coming."],[3407,3495,"Be there soon!"],[4136,4208,"I should've known something"],[4208,4337,"was wrong when I saw the"],[4337,4437,"windows papered over."],[4637,4750,"But I thought I was home."],[4804,4888,"I thought I was safe."],[4959,5046,"I couldn't have imagined"],[5046,5159,"how wrong I was."],[5442,5505,"Hello?"],[5864,5980,"Mom, Dad?"],[6268,6364,"I'm home."],[7344,7461,"Are you guys in the basement?"],[7932,7982,"Mom?"],[9242,9292,"Mom?"],[9359,9405,"Dad?"],[9951,10114,"Happy Thanksgiving, Erin."],[10214,10314,"I hope you're hungry."]],"2":[[91,187,"What's wrong, honey?"],[533,667,"Why were you guys sitting alone"],[667,738,"in the dark?"],[784,900,"Where's Grandma and Grandpa?"],[934,1009,"And Uncle Sean"],[1009,1105,"and all the cousins and stuff."],[1105,1230,"You said they were coming, right?"],[1872,1964,"Are they in the basement?"],[1976,2177,"No one is down there, Erin."],[2281,2323,"Come."],[2469,2531,"Sit."],[3595,3649,"It sounds like"],[3649,3749,"something's down there."],[3795,3908,"Am I hearing things?"],[3945,4058,"Are you guys feeling okay?"],[4133,4270,"Do you want me to call someone or-"],[4270,4387,"We feel just fine."],[4487,4592,"And you will too."],[5480,5626,"After you have some..."],[5818,5943,"cranberry sauce."],[8350,8470,"Where did this come from?"],[8521,8583,"It tastes..."],[8754,8833,"strange."],[9050,9217,"It came from the basement."]],"3":[[842,992,"What happened last night?"],[1351,1430,"It was a nightmare."],[1447,1555,"My parents are fine."],[1576,1659,"Everything's fine."],[1939,2072,"Where did these bruises come from?"],[2310,2419,"What the fuck?"],[4091,4216,"Did that really happen?"],[4917,4959,"I know"],[4959,5096,"I heard something down there."],[6227,6377,"Don't go in the basement, honey."],[6452,6493,"Why not?"],[6573,6648,"What are you hiding?"],[6852,6990,"What happened last night?"],[6998,7240,"Yesterday was a long day."],[7361,7482,"You were exhausted."],[7545,7703,"Dad carried you upstairs."],[7707,7841,"Have you seen my phone?"],[7882,8041,"You must have left it in the cab."],[8128,8420,"You're always losing things."]],"4":[[66,237,"Something's wrong with Mom and Dad."],[383,550,"Mom's phone."],[579,679,"I should call Grandma."],[738,775,"Yeah."],[884,988,"You're probably right."],[996,1130,"Of course I am, honey."],[1201,1284,"I'm your mom."],[2840,2898,"Grandma?"],[3003,3065,"Where are you?"],[3065,3199,"Why didn't you come to Thanksgiving?"],[3207,3365,"What do you mean, sweetie?"],[3386,3470,"Your mom told me"],[3470,3595,"you weren't feeling well"],[3595,3703,"and not to come."],[4166,4354,"Is everything alright, sweetheart?"],[4658,4758,"Everything's fine."],[5330,5384,"Hey."],[5505,5663,"We only wanna protect you."],[5809,5885,"You're safe here"],[5935,6006,"with me"],[6156,6247,"and your mom."]],"5":[[412,517,"You look hungry."],[859,938,"Leftovers?"],[1826,1901,"I passed out,"],[1901,2064,"and then someone or something"],[2064,2164,"dragged me down there."],[2565,2719,"Did my parents drug me?"],[2882,3069,"Did we eat all the cranberry sauce?"],[3098,3215,"What cranberry sauce?"],[3345,3424,"The cranberry sauce"],[3424,3566,"Dad practically forced me to eat"],[3566,3632,"last night."],[3632,3741,"You're an adult."],[3820,3937,"I can't force you"],[4004,4108,"to do anything."],[4308,4383,"You're lying."],[4884,4967,"What was that?"],[5046,5167,"I didn't hear anything."],[5359,5455,"There it was again!"],[5484,5584,"I know there's something"],[5584,5630,"down there."],[5630,5755,"What are you hiding from me?"],[6231,6339,"Oh my god!"],[6368,6410,"Stop!"],[6410,6535,"What are you doing?"]],"6":[[29,66,"Stop!"],[66,196,"Oh my God, why did you-"],[196,250,"Why did you?"],[250,350,"We're fine, honey."],[446,558,"It's just a scratch."],[638,717,"You're not fine."],[742,880,"This isn't fine."],[967,1071,"I'm calling 911."],[1071,1201,"Cell service"],[1284,1380,"just went out."],[1476,1601,"You're gonna bleed out."],[1647,1743,"Oh my God."],[1797,1918,"I can hardly feel it."],[2185,2293,"This is what happens"],[2293,2452,"when you ask too many questions,"],[2485,2544,"Erin."],[2698,2773,"We get hurt."],[2982,3128,"Who's doing this to you?"],[3178,3307,"Who's trying to hurt you?"]],"7":[[1739,1864,"I know I heard something."],[1872,2014,"You're imagining things."],[2014,2118,"It sounded like some kind of"],[2118,2210,"monster or-"],[2210,2627,"Monsters aren't real, honey."],[2702,2886,"What if someone broke in and-"],[4275,4391,"That's enough questions."],[4971,5334,"I don't want you getting hurt, too."]],"8":[[0,79,"I'm sorry."],[204,408,"I think I'm just really tired."],[542,792,"I'm probably imagining things."],[896,971,"I should go to bed."],[2256,2389,"No, no, no, no, no."],[2427,2602,"It's locked from the outside!"],[2673,2852,"Why would they be locking me in?"],[2998,3107,"This is a nightmare."],[3136,3244,"What do I do?"],[3691,3795,"Good night, Erin. -Good night, Erin."],[4049,4108,"Good night."],[4658,4796,"Something's making my parents"],[4796,4896,"act like this."],[4979,5088,"I'll find my phone."],[5146,5226,"I'll call for help."],[9171,9238,"Shit!"],[11115,11177,"Shit."],[11223,11319,"They're cutting me off"],[11319,11444,"from the outside world."],[11469,11565,"I'm trapped."]],"9":[[867,959,"What the hell?"],[1438,1630,"Oh my God, is this my basement?"],[2761,2890,"Oh my god!"],[3211,3261,"Erin."],[3832,3899,"Mom?"]],"10":[[0,54,"Mom?"],[87,191,"Mom, that thing."],[191,358,"That thing did that to you, right?"],[809,955,"I thought you were going to bed."],[1205,1430,"You look tired, honey."],[3970,4058,"What happened?"],[4191,4320,"How did I end up in my bed?"],[4783,4854,"The basement."],[5092,5380,"That footage was of the basement."],[5380,5647,"What was that?"],[6877,7032,"But they're just my parents."],[7219,7369,"I'm not afraid of my parents."],[8416,8537,"They're standing guard."],[8641,8742,"Whatever's down there,"],[8742,8863,"it wants me to stay out."]],"11":[[421,546,"We told you"],[608,829,"not to go into the basement."],[2202,2339,"I need to get into the basement."],[2706,2827,"I need those keys."],[3691,3858,"Come on, please work."],[4521,4600,"Oh my God."],[4671,4729,"It's gone."],[4788,4884,"Everything's gone."]],"12":[[70,296,"No, no, no, no, no, no."],[592,775,"The desk, the keys, it's all gone."],[829,896,"Fuck!"],[1188,1230,"Okay."],[2373,2452,"Erin?"],[3353,3436,"Honey?"]],"13":[[479,746,"I have to jump. It's the only way."],[2498,2623,"It was broken from the inside."],[2765,2952,"Something escaped from the basement."]],"14":[[116,175,"Who are you?"],[212,362,"What have you done to my parents?"],[1601,1722,"Why did you jump out your window,"],[1722,1776,"honey?"],[1847,1989,"Mom, that,"],[1997,2181,"that thing is after you and Dad, right?"],[2181,2273,"We have to go after it."],[2273,2344,"We have to kill it."],[2844,2919,"You just..."],[3103,3203,"stay where you are..."],[3319,3386,"honey."],[3440,3507,"Why?"],[3549,3757,"Because that's not part of the plan,"],[3816,3878,"Erin."],[4220,4350,"No, no."],[4437,4608,"Please, please."],[4688,4779,"What are you doing?"],[4846,4946,"You're my parents."],[5201,5288,"No, no!"]],"15":[[4437,4521,"There you are."],[5063,5196,"No, let me go!"]],"16":[[221,412,"That thing, that monster,"],[504,625,"did it protect me?"],[1981,2122,"Don't be scared, honey."],[2489,2677,"We just need you to come home."],[2786,2882,"Need me for what?"]],"17":[[1121,1263,"Why am I in the kitchen?"],[1851,2010,"Did my parents save me?"],[3290,3403,"But where are they?"],[3636,3770,"I have to find them."],[6181,6260,"Erin,"],[6327,6506,"come down to the basement."]],"18":[[83,141,"Mom?"],[221,275,"Dad?"],[346,396,"Honey?"],[471,575,"We're down here."],[1885,1993,"It's so dark."],[2173,2331,"But I want my parents back,"],[2352,2502,"and there's nowhere else to go."],[5793,5830,"Hello?"],[6956,7019,"Who are you?"],[7019,7077,"I..."],[7261,7311,"Miss..."],[8012,8116,"I'm gonna miss you, Erin."],[8266,8337,"Me too, Mom."],[8971,9025,"Mom?"],[9150,9263,"What happened to you?"],[9405,9459,"Don't..."],[9713,9813,"touch her."]],"19":[[41,221,"I'm disappointed in you, Erin."],[308,500,"She's a monster."],[638,784,"I'm your mom."],[825,971,"We told you"],[1009,1351,"not to go down into the basement,"],[1418,1647,"and now you know why."],[2281,2327,"Dad?"],[2481,2660,"No, no."],[2719,2882,"Sweetie, I'm your dad."],[2957,3132,"These imposters"],[3132,3328,"tried to steal our lives."],[3345,3553,"They tried to hurt you,"],[3641,3766,"so we handled it."],[3816,3974,"We're just protecting you,"],[4016,4154,"like we've always done."],[4262,4404,"We're your parents. -We’re your parents."],[4404,4608,"No, no!"],[4729,4992,"No, the... lies... no!"],[4992,5109,"Imposters?"],[5130,5288,"That woman"],[5409,5580,"tried to kidnap you."],[5609,5968,"She tried to beat you with a branch."],[5997,6114,"She drugged you."],[6164,6402,"I'm protecting you."],[6477,6527,"I..."],[6581,6656,"I don't-"]],"20":[[16,304,"So, so they're your evil clones?"],[450,546,"No, but then why would you"],[546,658,"keep them in the basement?"],[688,767,"We have to."],[817,963,"Whatever happens to them,"],[1067,1205,"happens to us."],[1267,1372,"If they die,"],[1493,1580,"we die."],[1751,1889,"If they bleed..."],[2273,2381,"Look at your dad."],[2915,2973,"Dad!"],[3870,4004,"No, no!"],[4166,4316,"Now do you understand?"],[4587,4713,"It's okay, honey."],[4804,4896,"You don't need him."],[5238,5342,"You have your mom."],[5530,5576,"Mom?"]],"21":[[0,154,"You tortured my mom!"],[271,379,"You did that to her!"],[379,500,"You took her from me!"],[533,654,"Die!"],[1067,1209,"Careful."],[1363,1459,"You're not my mom."],[1480,1584,"You never were."],[1609,1743,"You're not my mom."],[1918,2168,"She was nothing."],[2298,2431,"She was bait."],[2485,2711,"She led me to you."],[2773,2948,"She tried to stop me,"],[3036,3286,"but I was too strong."],[3420,3553,"This whole time I thought"],[3553,3703,"there was a monster in the basement..."],[3887,4029,"but it was really my real mom..."],[4133,4208,"protecting me."],[4329,4646,"You ate right out of my hands."],[4692,4913,"You wanted to trust me."],[5013,5226,"You wanted me to be your mom."],[5459,5747,"But you are not my child."],[5797,5935,"You are just a tool, too."],[6289,6448,"You gave me my baby."],[6694,6823,"What baby?"],[7424,7524,"She's awake."]],"22":[[16,204,"She can't wait to meet you."],[279,433,"Your DNA created her."],[487,596,"You're sisters."],[759,930,"Please, just let us go."],[942,1155,"Oh, I can't do that."],[1242,1372,"I need to keep you safe."],[1472,1572,"If you die..."],[2006,2127,"my baby dies."],[2327,2477,"And I can't let that happen."],[2819,2907,"My poor baby."],[2957,3040,"Mom's coming."],[3044,3236,"Please, you have what you want,"],[3236,3357,"so just let me go."],[3682,3832,"I can't do that, honey."]],"23":[[20,66,"No!"],[617,721,"Let me out of here!"],[959,1301,"Your daughter is so naive."],[1384,1634,"It's a shame she never prepared you"],[1634,1843,"for the real world."],[1897,2043,"Don't talk about my mother."],[2143,2419,"You will not hurt yourself."],[2469,2781,"You will not hurt my daughter."],[2786,3023,"You will stay safe right here."],[3307,3440,"Coming, my baby!"],[3586,3720,"Hi, hi."],[3841,3937,"No, shh..."],[4070,4124,"Okay."],[4308,4454,"Breathe, breathe."],[4483,4667,"Think, think, think, think, think, think."]],"24":[[1076,1134,"Come on."],[1413,1468,"Mom."],[1597,1639,"Mom."],[1735,1789,"Paula!"],[1872,1951,"Paula, wake up!"],[2731,2948,"Ugh, come on."],[3682,3741,"Erin."],[3953,4087,"Meet your sister."],[4270,4387,"She's beautiful."],[4671,4871,"I knew you would love her."],[5192,5342,"Let me the fuck out of here."],[5367,5605,"You wouldn't kill your own mom."],[5659,5822,"Or did you forget?"],[5851,5964,"If I die..."],[6118,6218,"so does she."]],"25":[[16,162,"Why can't you"],[196,354,"just listen?"],[646,696,"Oh my God."],[725,775,"My baby."],[859,921,"I'm sorry."],[938,996,"I'm so sorry."],[1046,1109,"It's okay."],[1159,1222,"Mom's here."],[1405,1468,"It's okay."],[1501,1564,"It's okay."],[1664,1714,"It's okay."],[2439,2489,"Don't."],[2577,2665,"You've already been through"],[2665,2765,"too much pain."]],"26":[[1259,1380,"What have you done?"],[2369,2419,"No!"],[2460,2485,"No!"],[2656,2748,"No!"],[2748,2852,"My baby!"],[3574,3712,"My baby..."],[4058,4220,"Mom, I'm so sorry."],[6285,6348,"If you ever"],[6348,6468,"wanna see your daughter again,"],[6468,6606,"we have to stop the bleeding."]],"27":[[1856,1989,"What do you think, Mom?"],[2085,2177,"Smells good."],[2932,2998,"Where am I?"],[3307,3399,"Where's my baby girl?"],[3453,3595,"Right here, Mom."],[4166,4312,"My baby girl."]]}