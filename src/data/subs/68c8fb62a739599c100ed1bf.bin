{"1":[[1584,1705,"This place is cool."],[1747,1893,"Oh, I'm happy you love it."],[2606,2711,"Sorry, one second."],[2786,3002,"Daddy, it's so hot in here."],[3061,3232,"When are you gonna come back?"],[3249,3428,"Esther, what did I tell you?"],[3478,3595,"Alright, just stay in the car."],[3595,3657,"Daddy's busy."],[3678,3745,"Stop calling."],[3987,4054,"What's up, buddy?"],[4099,4162,"You tired?"],[4195,4354,"No, I'm just a bit hot."],[4391,4462,"You're hot?"],[4521,4650,"Well, let daddy take"],[4650,4721,"care of that for you."],[4788,4892,"All right, ready?"],[4925,5034,"Here comes the fan."],[6548,6594,"Ah!"],[6894,6952,"All right, team."],[6952,7098,"So today I would like to go over"],[7098,7261,"our quarter's key metrics."],[7394,7444,"Starting off."],[7678,7770,"Sorry, I have to take this."],[7824,7966,"Mommy, save me!"],[7995,8245,"It's so hot, I can't open the door."],[8287,8358,"Esther, where are you?"],[8383,8558,"I don't know where I'm at."],[8604,8679,"Stay awake for me, okay?"],[8679,8754,"Stay awake for Mommy."],[8754,8796,"Just tell Mommy"],[8796,8863,"where you are, okay?"],[8900,9034,"Mommy, save-"]],"2":[[12,45,"No."],[95,216,"No, no, no, pick up."],[271,483,"Claire's daughter trapped in a car."],[483,608,"On a day like this?"],[646,775,"Oh my god, that poor kid."],[775,842,"He's supposed to"],[842,909,"be with her today."],[909,1017,"I don't understand why she would be"],[1017,1092,"locked in the car."],[1334,1418,"Is there anything I can"],[1418,1501,"do for you guys?"],[1568,1643,"Anything at all?"],[1676,1764,"You being here is"],[1764,1881,"more than enough already."],[1922,2139,"If only the"],[2139,2289,"three of us were a family."],[2448,2686,"Claire, she's a control freak."],[2773,2877,"It would be nice if she were even"],[2877,3040,"half as considerate as you are."],[3078,3144,"For once in your life"],[3144,3194,"once in your life"],[3194,3299,"just pick up the phone, please."],[3299,3395,"Just pick up the phone."],[3624,3707,"Ms. Serrano?"],[3749,3787,"Claire?"],[3807,3866,"Just breathe."],[3895,3953,"We're all going to help"],[3953,4066,"you find Esther, alright?"],[4066,4124,"You're not alone."],[4154,4275,"Tell us what you need us to do."],[4366,4533,"Jarvis, can you go to the school to"],[4533,4625,"just see if she just"],[4625,4700,"wandered off somewhere?"],[4700,4750,"I'm on it."],[4750,4863,"I'll check around the school."],[4863,4946,"I'll check the nearby"],[4946,5071,"parks and playgrounds."],[5071,5188,"Alright, team, let's go."],[5697,5885,"Mommy, help!"]],"3":[[225,296,"Where's Adrian?"],[316,462,"Mrs. Serrano, what brings you here?"],[462,517,"Is he inside?"],[600,750,"Mrs. Serrano, please calm down."],[779,917,"Mr. Serrano is in a meeting."],[946,1042,"Please have a seat, and"],[1042,1101,"I'll let him know you're here."],[1101,1155,"I don't have time for this,"],[1155,1217,"get out of the way."],[1313,1359,"Adrian."],[1655,1705,"Where is he?"],[1710,1747,"I thought you said"],[1747,1801,"he had a meeting."],[1818,1939,"About that, he is"],[1939,2085,"just not in the building."],[2114,2289,"He went to meet a client off-site."],[2289,2394,"Signal's probably bad."],[2394,2452,"I haven't been able"],[2452,2519,"to reach him either,"],[2519,2723,"but I can pass along your message"],[2723,2857,"and have him call you back."],[2890,2977,"My daughter is missing."],[3424,3511,"Jarvis, did you find her?"],[3511,3570,"The kindergarten"],[3570,3682,"teacher said your husband"],[3682,3812,"picked her up before noon today."],[3920,3966,"Before noon?"],[4091,4162,"Do you mean my daughter's been"],[4162,4212,"locked in the car"],[4212,4295,"this whole afternoon?"],[4325,4362,"We've already"],[4362,4529,"notified local shops, parks,"],[4546,4650,"anyone nearby to look"],[4650,4779,"for a child alone in a car."],[4829,4888,"We'll find her."],[4892,4979,"I'm going to give you"],[4979,5096,"Adrian's license plate,"],[5146,5334,"and you're going to track that car."],[5359,5680,"I do not care how, you find it."],[5968,6072,"Pick up the phone, Adrian."],[6081,6172,"Pick up, pick up, pick up,"],[6172,6264,"pick up, pick up."],[6389,6519,"In an in an alley-"],[6519,6585,"Hey, buddy."],[6606,6681,"Do you want to go play?"],[7006,7086,"Adrian, where are you?"]],"4":[[12,100,"Adrian, where are you?"],[120,166,"I'm having lunch"],[166,275,"with Stacy, Claire."],[342,392,"Do you really need to"],[392,487,"blow up my phone like this?"],[487,600,"I need you to tell me"],[600,738,"where Esther is right now."],[779,871,"This is exactly why I"],[871,942,"didn't want to tell you."],[988,1117,"You always overreact."],[1209,1292,"I'll be home when I'm done."],[1372,1413,"Adrian?"],[1664,1714,"Adrian."],[1772,1860,"Hey, what's wrong?"],[1885,1943,"It's Claire."],[1993,2097,"She's gone completely insane."],[2097,2248,"Called me like fifteen times now."],[2285,2369,"I'm sorry."],[2414,2498,"Claire probably has"],[2498,2606,"the wrong idea now."],[2606,2665,"You should go home and"],[2665,2748,"explain it to her."],[2769,2861,"I mean, why should I?"],[2944,3069,"Nothing going on between us."],[3103,3224,"She could think whatever she wants."],[3244,3357,"If only you were my husband."],[3449,3632,"I'd give you space, not treat you"],[3632,3774,"like a dog on the leash."],[3820,4029,"If only Claire was as kind and"],[4029,4129,"considerate as you are."],[4537,4642,"Hey, you should answer."],[4692,4808,"It's my fault anyway."],[4921,5084,"Lucas just got so attached to you"],[5084,5209,"after his dad died and he got"],[5209,5351,"diagnosed with liver cancer."],[5680,5772,"Adrian, you tell me"],[5772,5901,"where Esther is right now."],[5955,6143,"I'm out having lunch, Claire."],[6202,6252,"I mean, do I really"],[6252,6335,"need to report back to you"],[6335,6489,"with every little thing that I do?"],[6489,6548,"And stop dragging"],[6548,6635,"our daughter into this"],[6635,6735,"to try to guilt trip me."],[6777,6852,"You're supposed to be a strong,"],[6852,6931,"independent woman, right?"],[6986,7086,"Why don't you go find her yourself?"],[7148,7290,"Adrian, I swear to God, if"],[7290,7386,"something happens to Esther,"],[7386,7524,"I swear I will never--"],[7887,8066,"I'll never forgive you."],[8304,8479,"Hey, little man."],[8587,8658,"Hey, don't worry."],[8692,8812,"Today is Daddy son day."],[8867,8904,"We're going to do"],[8904,9004,"whatever you want."],[9092,9154,"You want some pizza?"],[9205,9622,"Daddy, where are you?"]],"5":[[141,258,"Amanda, is Esther home?"],[258,342,"Did she come back yet?"],[400,496,"Now you care?"],[542,692,"Maybe if you spent more time"],[692,804,"actually being a mother,"],[829,980,"we wouldn't be in this mess."],[980,1113,"Would you just answer the question?"],[1113,1222,"Is she home yet or not?"],[1242,1368,"Watch your tone."],[1393,1555,"I cook, clean, and"],[1555,1697,"raise your child,"],[1730,1839,"while you're caring for your"],[1839,1993,"little stupid company."],[2077,2135,"Now you have the nerve"],[2135,2202,"to come in here"],[2202,2369,"and raise your voice at me?"],[2369,2489,"I do not have time for this?"],[2527,2627,"I need you to call Adrian"],[2627,2736,"and I need you to"],[2736,2877,"find out where he is."],[2886,3028,"Why would I know where he is?"],[3073,3224,"It's not like he reports to me."],[3265,3324,"Because my daughter"],[3324,3428,"is locked in a car."],[3465,3541,"If I do not get to"],[3541,3649,"her soon, she will die."],[3770,3795,"That's my"],[3795,3978,"granddaughter we're talking about."],[4024,4279,"And I am sure Adrian would never do"],[4279,4408,"something so careless."],[4450,4575,"Amanda, I saw her."],[4683,4884,"She is locked in a car and she is"],[4884,4979,"barely conscious."],[5084,5217,"And she is burning up and I just,"],[5242,5359,"I need you to please"],[5359,5651,"just, just call Adrian"],[5739,5784,"because if"],[5784,5918,"something happens to her,"],[5960,6151,"it will be on the both of you."],[6151,6252,"That's enough, Claire."],[6306,6456,"I'm sure she's fine."],[6510,6685,"The AC's probably on and Adrian"],[6685,6798,"always keeps snacks"],[6815,6927,"and water in the car."],[7006,7232,"Adrian would never put his own"],[7232,7357,"daughter in danger."]],"6":[[83,325,"Just look at you, calculating,"],[358,604,"pathetic woman, always fussing and"],[604,884,"caring about every little thing."],[938,1138,"No wonder my son's heart is still"],[1138,1201,"with his high school"],[1201,1326,"sweetheart, Stacy."],[1359,1584,"Fine! Blame me for everything!"],[1647,1868,"But if he hates me so much, then"],[1868,2002,"why did he marry me?"],[2047,2139,"Because she got"],[2139,2285,"married first, that's why."],[2464,2702,"I need to know where Adrian is, and"],[2702,2894,"I need you to call him."],[2898,3182,"Why would I do that? I'm not like"],[3182,3470,"you always nagging and blowing up"],[3470,3762,"his phone over every little thing."],[3762,3899,"My daughter is in a boiling car"],[3899,3995,"right now and you"],[3995,4141,"just call it a little thing."],[4141,4233,"She is your"],[4233,4421,"granddaughter for God's sake!"],[4521,4583,"You know if you're not"],[4583,4708,"going to do it, I will."],[4733,4854,"She's with her father,"],[4854,4992,"how bad could that be?"],[5046,5192,"And if something does happen to"],[5192,5384,"her, good riddance, you can just"],[5384,5518,"pop out another one."],[5588,5668,"What did you just say?"],[5797,6101,"I said good riddance."],[6147,6389,"That brat Esther is always causing"],[6389,6510,"some kind of trouble."],[6585,6765,"Unlike Lucas, who's"],[6765,6986,"sweet and perfect."],[7036,7257,"If she dies, just"],[7257,7419,"have another child!"]],"7":[[33,175,"Did you just hit me?"],[175,321,"You're damn right I did."],[383,529,"And if you ever insult Esther ever"],[529,638,"again, I will do it again"],[638,859,"and again over and over"],[921,1251,"until you shut your heartless mouth!"],[1284,1443,"You're insane!"],[1480,1614,"I'm gonna make sure the second"],[1614,1826,"Adrian gets home, he divorces you"],[1826,1906,"on the spot."],[1922,1985,"Perfect."],[1997,2072,"I look forward to"],[2072,2156,"seeing the papers."],[2660,2844,"It's hot out there."],[2844,2982,"Drink this, it'll cool you down."],[2998,3140,"Adrian, you are the best."],[3174,3282,"You know, if I had a husband like"],[3282,3486,"you, I'd trust you completely."],[3486,3661,"Not like Claire, who's always"],[3661,3803,"calling and checking in like you're"],[3803,3916,"some sort of criminal."],[4833,5059,"It's almost Esther's birthday!"],[5063,5192,"Oh God, I forgot it was"],[5192,5280,"your birthday today."],[5305,5472,"I'm gonna go to the amusement park"],[5472,5626,"with mommy and daddy."],[5672,5789,"I swear mommy's coming."],[5860,6097,"Daddy, it's so hot!"],[6168,6373,"Mommy, I can't wait anymore!"],[7294,7424,"Mommy!"],[7857,8153,"Mommy! Mommy, save me!"],[8712,8762,"Esther."],[8871,8913,"Esther."],[9025,9084,"Mommy's here."]],"8":[[1130,1180,"Hey!"],[1226,1305,"Hey, get out of there!"],[1305,1368,"What are you doing?"],[1451,1559,"Get out!"],[1655,1760,"Hey, it's okay sweetie."],[1760,1881,"Okay, stay in the car, okay?"],[1881,1951,"Stay in the car."],[2043,2127,"What the hell are you doing?"],[2127,2231,"Are you trying to rob our"],[2231,2339,"car in broad daylight?"],[2356,2498,"I'm not trying to rob you. There was a"],[2498,2581,"child in the car and I"],[2581,2665,"thought it was my daughter."],[2690,2815,"So you weren't trying to rob us."],[2852,2994,"But you're trying to kidnap our daughter?"],[2994,3136,"Someone help!"],[3186,3303,"There's a kidnapper here!"],[3328,3532,"I'm not trying to kidnap your kid."],[3532,3791,"I saw a child in the car and I just... I..."],[3791,3924,"I thought I should save her."],[3924,4120,"I don't know what your sick motives are"],[4120,4233,"but I'll give you a chance."],[4258,4350,"Hurry up and get the hell out of"],[4350,4466,"here before I call the police."],[4466,4667,"You left your kid in a car unattended"],[4667,4808,"with the windows up and..."],[4888,4950,"We..."],[4992,5163,"It is a hundred and ten degrees outside"],[5163,5422,"and your kid is just in this car."],[5422,5551,"You're crazy!"],[5618,5714,"We just went to the restroom"],[5714,5797,"for five minutes."],[5797,5976,"We left the AC on and everything!"],[6018,6214,"Also, if anything happened,"],[6214,6327,"it's none of your business."],[6327,6435,"Wait, what if... what if your car"],[6435,6577,"just accidentally shut off, huh?"],[6577,6773,"Did you, did you even think of that?"],[6773,6835,"Did you, you-"],[6835,6873,"Okay, look-"],[6873,7023,"You could get her a heatstroke!"],[7044,7102,"Did you even - You see, it doesn’t"],[7102,7203,"think about that? - make any sense"],[7203,7307,"for us to arguing with this psycho."],[7307,7440,"Let's get out, okay? Let's get out of here."],[7482,7561,"You need help."],[7653,7770,"I'm so sorry."],[8074,8220,"Where's my baby?"],[8350,8450,"Where is my Esther?"],[8450,8571,"Where is my daughter?"],[8996,9050,"What?"],[9109,9280,"Mrs. Serrano, we found it."]],"9":[[0,162,"You... you found Esther?"],[191,291,"Sorry, Mrs. Serrano,"],[291,412,"we didn't find Esther."],[437,575,"We got the security footage from"],[575,675,"Esther's kindergarten."],[729,821,"It shows your husband"],[821,913,"did show up."],[959,1109,"And we thought we had a lead, but"],[1109,1201,"we didn't expect..."],[1222,1343,"Okay, just send me"],[1343,1459,"the footage first, okay?"],[1814,1976,"Hey, there he is! - Hi!"],[1976,2102,"How you doing, kiddo?"],[2102,2177,"That's my little man."],[2243,2331,"Hey, why don't we go"],[2331,2410,"to the amusement park?"],[2410,2552,"Oh, you spoil him too much."],[2581,2698,"Of course I spoil him."],[2748,2827,"My fun little guy."],[2902,2969,"Hey, you hungry?"],[2994,3057,"What do you want to eat today?"],[3082,3136,"I don't care."],[3136,3319,"As long as I'm with my daddy,"],[3319,3511,"I'm happy eating anything."],[3582,3707,"Oh, buddy, the best."],[3728,3832,"Oh, I haven't seen"],[3832,3974,"Lucas this happy in so long."],[4008,4220,"Is Esther this happy with you?"],[4237,4275,"You know what?"],[4300,4496,"Today is Lucas's day."],[4562,4654,"There's no need to mention"],[4654,4779,"irrelevant people."],[4833,4929,"Irrelevant?"],[4984,5046,"You think"],[5046,5163,"our daughter is irrelevant?"],[5267,5388,"Congratulations on your"],[5388,5597,"happy, perfect family."],[6272,6335,"Adrian, how"],[6335,6443,"could you be so heartless?"],[6706,6790,"How could you just leave"],[6790,6931,"my kid in the car alone"],[6931,7023,"while you just go play"],[7023,7161,"father to someone else?"]],"10":[[417,496,"Jarvis, did you find her?"],[533,592,"The police were able"],[592,679,"to track the location"],[679,746,"of Adrian's car"],[746,846,"using his license plate."],[880,946,"I'm sending you the"],[946,1030,"address right now."],[1030,1084,"I'll meet you there."],[1134,1297,"Okay, I will be"],[1297,1351,"there immediately."],[1397,1447,"Thanks Jarvis."],[1551,1609,"Esther mommy's"],[1609,1701,"coming to save you."],[2431,2594,"It's almost my birthday."],[2706,2961,"And I get to go to an amusement park"],[2961,3078,"with mommy and daddy."],[3107,3236,"Esther, please hang on for mommy."],[3236,3361,"And we can go to the amusement park"],[3378,3516,"like you always wanted."],[3620,3770,"We can play as long as you like."],[3832,3933,"I will buy you all"],[3933,4054,"the toys that you want."],[4245,4350,"I will never break a"],[4350,4500,"promise to you ever again."],[5105,5196,"Hey, Mrs. Serrano."],[5296,5397,"Hey, the car should be"],[5397,5476,"around here somewhere,"],[5480,5580,"so we gotta check every one."],[5647,5751,"I'll start over here."],[5789,5843,"Go on that side."],[6081,6118,"Not here."],[6197,6260,"Let's check that one."],[6485,6602,"Is that mommy?"],[7040,7119,"Mommy!"]],"11":[[471,542,"Mrs. Serrano!"],[629,729,"Hey, the car should be"],[729,809,"around here somewhere,"],[809,913,"so we gotta check every one."],[980,1076,"I'll start over here."],[1113,1280,"Mommy, help me!"],[1651,1843,"No. Could you check that one."],[1860,2097,"Mommy, I'm here, it's me!"],[2369,2469,"Okay, I'll get the next one."],[2602,2665,"No."],[2869,3019,"Hey, over here. This one, this one."],[3370,3436,"This is his car."],[3728,3791,"Mommy!"]],"12":[[325,392,"Where is she?"],[842,930,"Okay, I'll be right there."],[959,1101,"Mommy, you're finally here!"],[1301,1368,"What was that?"],[1384,1476,"Mommy, Mommy!"],[1514,1593,"It sounded like a"],[1593,1722,"little girl's voice."],[1776,1872,"Wait, what did you say?"],[1906,1956,"I don't know,"],[1956,2056,"I just heard this voice."],[2110,2293,"Mommy, where are you going!"],[2344,2448,"I swear someone's"],[2448,2527,"asking for their mom."],[2656,2752,"This is Adrian's car."],[2752,2840,"Where's my daughter?"],[3345,3607,"She should be in the car, and"],[3607,3670,"I don't understand why"],[3670,3787,"she's not in the car!"],[3841,4003,"What do we do?"],[4079,4137,"What do I do?"],[4158,4216,"What do I do?"],[4320,4454,"Hey, we're gonna find her."],[4662,4713,"Mommy!"],[5088,5213,"Is this that mommy?"]],"13":[[4,104,"Mommy!"],[412,479,"Hold on."],[792,834,"Nothing."],[946,1046,"I must have misheard it."],[1101,1343,"She should be in the car."],[1343,1409,"I don't understand why"],[1409,1509,"she's not in the car."],[1634,1747,"What do we do?"],[1826,1872,"What do I do?"],[1885,1922,"What do I do?"],[1922,2106,"Mommy, everything hurts."],[2177,2323,"Esther wanted to spend"],[2323,2406,"her birthday"],[2406,2569,"with Mommy and Daddy."],[2606,2702,"I wanted to go to the"],[2702,2890,"amusement park together."],[2923,3148,"I wanted to eat the big cake together."],[3224,3299,"Thank you."],[3503,3628,"One of the best I've ever had."],[3812,3916,"It's hot in here, isn't it?"],[4204,4354,"It's so hot."],[4587,4738,"Mrs. Serrano, take a seat."],[4763,4867,"You gotta sit down."],[5088,5155,"Hey."],[5201,5342,"Mrs. Serrano, don't worry."],[5392,5551,"I reported it to the police."],[5580,5684,"They're looking for her already."],[5818,5914,"Plus, a lot of people go through"],[5914,5985,"that parking lot."],[5985,6081,"Maybe they found her already."],[6256,6373,"It's all my fault."],[6623,6702,"I should have never"],[6702,6815,"let Adrian take her."],[6840,7023,"How could I be so stupid."],[7082,7207,"What if something actually happens to"],[7207,7323,"her, I mean, all I do,"],[7323,7465,"all I do is I work,"],[7515,7590,"and work."],[7661,7836,"I just... I just leave her at home"],[7903,8003,"all alone and..."],[8058,8199,"What kind of mother am I?"]],"14":[[12,321,"Mrs. Serrano, it's precisely"],[321,396,"because you are her"],[396,554,"mother that you can't give up."],[759,867,"But we've got a lot of"],[867,967,"people looking for her."],[1096,1205,"Alright, we're gonna find her,"],[1205,1297,"she's gonna be okay."],[1384,1438,"Trust me."],[1760,1868,"I need to call Adrian and"],[1868,1951,"figure this out."],[2110,2252,"Will he only comes to his senses"],[2252,2373,"after costing Esther her life."],[3516,3582,"I gotta take it."],[3641,3724,"What? Seriously?"],[3832,3949,"Lucas, just stay right here, we'll"],[3949,4054,"be right back, okay sweetie?"],[4149,4346,"Claire, enough with this nonsense."]],"15":[[33,125,"Adrian, where are you?"],[171,275,"It's none of your business."],[296,333,"Alright."],[350,458,"You know it's hard enough for me to"],[458,596,"take time off of work and maybe"],[613,725,"have a little bit of fun without"],[725,809,"you calling me a hundred"],[809,955,"times like a psychopath"],[967,1080,"try to ruin my day!"],[1092,1159,"Adrian, Esther is"],[1159,1259,"in danger right now."],[1288,1518,"Stop lying, Claire. I know exactly"],[1518,1672,"where Esther is and she's fine."],[1693,1776,"I've had enough."],[1822,1935,"When I get home,"],[2039,2156,"I want a divorce."],[2214,2419,"Oh, hey Adrian, you can't throw the"],[2419,2598,"word divorce around so casually."],[2652,2761,"Claire's only acting this"],[2761,2844,"controlling because"],[2844,3028,"she loves you so much."],[3082,3123,"Here."],[3269,3541,"Claire, I think it's best if you"],[3541,3737,"apologize to Adrian first."],[3762,3908,"You want me to apologize?"],[3999,4149,"Stacy, I thought that you would be"],[4149,4283,"thrilled if Adrian and I got a divorce,"],[4283,4387,"so why, why would you"],[4387,4525,"even want us to make up?"],[4592,4754,"Claire, I am genuinely trying to"],[4754,4871,"help you right now. Why would you"],[4871,5059,"accuse me of being the other woman?"],[5105,5292,"Yeah, Claire, don't speak to Stacy"],[5292,5397,"like that, alright?"],[5451,5555,"And who I hang out with"],[5555,5697,"isn't a concern to you."],[5743,6026,"Fine, I don't care who you spend time"],[6026,6122,"with, Adrian."],[6139,6281,"She is in serious danger."],[6281,6431,"She is locked in your car."],[6531,6560,"What?"],[6690,6810,"Esther is locked in a car and I'm"],[6810,6977,"worried she's having a heat stroke or"],[6977,7219,"suffocate to death, so I need you to"],[7219,7444,"tell me where she is, Adrian!"],[7615,7949,"Oh. Hang on. I'll go check."],[8016,8120,"He's gonna check where she is."],[8199,8258,"Okay, good."],[8341,8583,"Wait, wait, Adrian. Hey, I know"],[8583,8787,"Claire wants you to hurry home, but"],[8787,8867,"don't you think"],[8867,8992,"she's crossed the line?"],[9050,9188,"I mean, she's practically cursing"],[9188,9334,"Esther by making up all the stuff about"],[9334,9517,"her suffocating and dying?"],[9613,9809,"Seriously, what if something like"],[9809,9934,"this happens in the future?"],[9964,10101,"And even if it doesn't, if you give"],[10101,10193,"in today, who knows"],[10193,10289,"what she will do to Esther?"]],"16":[[20,58,"Claire, you know what?"],[58,154,"You've gone too far."],[246,316,"You're Esther's mother"],[316,408,"for Christ's sakes,"],[408,517,"and how dare you curse our"],[517,688,"own child with this excuse?"],[771,875,"Curse my daughter?"],[988,1188,"Adrian, she is in real danger!"],[1188,1355,"So I need you to tell me where her"],[1355,1505,"location is right now,"],[1551,1768,"or I swear to God,"],[1768,1976,"you will never live this down."],[2068,2223,"How did I marry a woman like you?"],[2243,2369,"You're completely irrational."],[2406,2552,"Hey, don't be mad."],[2652,2765,"Look, she's only acting this"],[2765,2865,"irrational because of"],[2865,3019,"her hormones, you know?"],[3036,3161,"What if you just tell her Esther's"],[3161,3332,"location so she stops worrying?"],[3390,3511,"Adrian, I'm begging you,"],[3511,3666,"you tell me where her location is!"],[3707,3903,"Fine. You want to know where she is?"],[3933,3991,"I'll tell you."],[4037,4120,"She's at the intersection"],[4120,4283,"of Peach Grove Lane and Dogwood Road."],[4400,4504,"She's at the intersection"],[4504,4600,"of Peach Grove Lane and Dogwood Road."],[5847,6085,"Okay, I got it, I got it."],[6189,6268,"Alright, Mrs. Serrano."],[6302,6414,"Not far from here."],[6473,6556,"I'm going to talk to Adrian's friend"],[6556,6631,"to see if I can find out"],[6631,6694,"anything else."],[6765,6806,"Understood."]],"17":[[166,354,"Esther, please hold for mommy."],[446,492,"It's OK."],[492,621,"The address is not too far."],[621,750,"So, I'll get us there."],[750,809,"Don't worry."],[850,1026,"I was always so busy with work."],[1188,1284,"That's why she made me"],[1284,1393,"this special bracelet."],[1497,1539,"OK."],[1710,1881,"She told me that if I was ever busy"],[1881,2039,"working, and I missed her..."],[2143,2206,"Do you like it?"],[2419,2581,"As if this bracelet was her."],[2898,2986,"It's all my fault."],[3086,3282,"I spent so much time at work"],[3403,3566,"and not enough time with Esther."],[3674,3737,"God, if anything"],[3737,3862,"happens to her, if anything,"],[3862,4124,"I would never forgive myself."],[4145,4250,"Hey, hey, don't worry."],[4450,4504,"God."],[4587,4692,"We'll be there soon, OK?"],[4854,4946,"I'm going as fast as I can."],[5009,5096,"Hey, don't worry."],[5176,5280,"She is going to be fine."],[6010,6064,"Mrs. Serrano."],[6752,6881,"Mrs. Serrano, we've arrived."]],"18":[[492,563,"Jarvis, what is this?"],[742,859,"I can't believe you told"],[859,980,"Claire another address."],[1042,1172,"If she finds out you're gonna be in"],[1172,1267,"big trouble, mister."],[1363,1480,"Look, Claire, she's gonna have a"],[1480,1572,"tantrum either way."],[1643,1701,"Figured she should do it"],[1701,1822,"far, far away from us."],[1935,2001,"But look, you really"],[2001,2093,"don't have to stay."],[2152,2277,"I mean, I won't blame you."],[2356,2473,"Plus, Lucas is used"],[2473,2556,"to not having a dad."],[2673,2798,"I'm not gonna abandon you guys."],[2840,2907,"I told you I'd"],[2907,2965,"spend the day with you,"],[2965,3011,"and that's exactly"],[3011,3090,"what I'm gonna do."],[3153,3294,"And be the best, most reliable dad"],[3294,3403,"to Lucas there is."],[3841,3924,"I love daddy."],[3945,4049,"Daddy's the best."],[4070,4099,"Oh."],[4208,4270,"What's up, buddy?"],[4466,4612,"But what happens if"],[4612,4729,"Claire starts to call again?"],[4863,4909,"Don't worry."],[5071,5167,"I'll make sure she can't."],[5226,5367,"There, it's off."],[5597,5701,"There's nothing here."],[5701,5768,"There's absolutely"],[5768,5885,"nothing here, Jarvis."],[5885,5972,"Where is my daughter?"],[5972,6060,"Where is Esther?"],[6064,6193,"Mrs. Serrano, calm down."],[6193,6339,"We'll find her another way,"],[6352,6385,"okay?"],[7791,7945,"Adrian why are you always lying to me?"],[7945,8204,"Why are you lying to me?"],[8212,8354,"I just want my baby."],[8425,8641,"Ahh!"]],"19":[[100,246,"Well, look, since Claire"],[246,329,"wants to use our daughter"],[329,533,"to try to find me, she can take her"],[533,679,"sweet time looking for me."],[771,971,"Besides, we could spend a little"],[971,1084,"bit more time together too."],[1363,1488,"I know for a fact that"],[1488,1597,"Esther is safe and sound."],[1722,1805,"If there's a real problem,"],[1805,1868,"she could just call me."],[1989,2147,"Adrian, don't be mad at Claire."],[2235,2314,"It's only because"],[2314,2431,"she loves me so much"],[2431,2590,"that she's making up these lies to"],[2590,2677,"get your attention."],[2752,2886,"Hey, Lucas, listen up."],[2965,3036,"When you grow up"],[3065,3128,"make sure you don't marry"],[3128,3244,"a crazy woman like her."],[3311,3370,"Okay."],[3424,3539,"When I grow up,"],[3539,3712,"I want to be just like you, Dad."],[3799,3908,"And then I'll marry"],[3908,4083,"someone just like Mommy."],[4441,4558,"It's so hot."],[5205,5305,"Why does my heart suddenly"],[5305,5392,"hurt so much?"],[5426,5651,"Mommy, I can't wait anymore."],[5697,5943,"When are you coming back?"],[6047,6131,"Oh my God, why does"],[6131,6231,"my heart hurt so much?"],[6398,6485,"I'm a little worried."],[6577,6685,"I'm gonna go check on Esther."]],"20":[[50,137,"I'm gonna go check on Esther."],[1192,1380,"Ah! God, Adrian!"],[1443,1580,"Are you okay, Mommy?"],[1847,2022,"Hey, you okay?"],[2072,2177,"Yeah, no I'm alright. Just go,"],[2177,2344,"go check on Esther."],[2344,2444,"It's fine."],[2523,2652,"Ahhh!"],[3048,3165,"Esther really has been in the car"],[3165,3253,"for a long time."],[3253,3453,"I should go check on her."],[3453,3616,"Plus it'll get Claire off my back."],[3616,3878,"Daddy, are you gonna abandon me too?"],[4024,4149,"Hey,"],[4149,4341,"how could Daddy ever abandon you?"],[4404,4512,"Alright? Mommy and Daddy"],[4512,4671,"aren't going anywhere."],[4704,4838,"The three of us,"],[4838,4984,"we're gonna have a great day."]],"21":[[296,425,"Daddy, you're the best."],[425,608,"I like you the bestest, Daddy."],[884,1076,"Look, Esther's in the car."],[1076,1226,"She's probably sleeping just fine."],[1263,1322,"There's waters,"],[1343,1459,"there's snacks, there's AC."],[1488,1593,"She is fine."],[1630,1768,"This is Claire's fault."],[1768,1889,"She's blowing it out of proportion"],[1889,2027,"and getting worried like this."],[2093,2139,"You know what?"],[2181,2202,"Yeah."],[2227,2298,"How often do we get to"],[2298,2394,"share a meal like this, huh?"],[2464,2590,"Let's enjoy the day."],[2686,2861,"God, I can't believe our day was"],[2861,2961,"almost ruined by that."],[2994,3140,"Don't be mad, okay?"],[3140,3249,"It's not your fault."],[3332,3495,"Claire is just too controlling."],[3532,3607,"You've only been out,"],[3607,3703,"what, a couple of hours"],[3703,3762,"and she's got you"],[3762,3858,"chained up like a dog."],[3924,4012,"It's just not right."],[4074,4208,"Mommy, who's Claire?"],[5059,5246,"Okay, I can't give up."],[5259,5313,"We can't give up."],[5472,5543,"Esther's waiting on us,"],[5543,5626,"we need to find her."],[5718,5797,"What can we..."],[5797,5855,"What can we do?"],[5860,6068,"We could, I don't know, look up-"],[7019,7136,"You know what I was thinking?"],[7136,7169,"What?"],[7169,7286,"We can go to an amusement park."],[7353,7432,"Sound good?"],[7432,7478,"Yeah."],[7503,7636,"Oh, you spoil him too much."],[7665,7753,"I'm gonna spoil him,"],[7753,7836,"he's my little man."],[7941,8041,"Hey, you hungry?"],[8041,8195,"You can get anything you want to eat."],[8245,8312,"I don't care."],[8312,8500,"As long as I'm with my daddy,"],[8500,8666,"I'm happy eating anything."],[8929,9084,"Oh, I haven't seen Lucas this happy"],[9084,9209,"in such a long time."],[9305,9526,"Is Esther this happy with you?"],[9584,9734,"I think I know where Esther is."]],"22":[[0,141,"I think I know where Esther is."],[225,316,"Stacy and Adrian are childhood"],[316,354,"sweethearts."],[467,542,"Whenever they're together he"],[542,663,"doesn't drive, so that means that"],[663,880,"she has to be in Stacy's car."],[942,1005,"Okay."],[1046,1163,"Jarvis I need you to call the police,"],[1163,1263,"I need you to tell them to"],[1263,1413,"look for Stacy's car immediately."],[1422,1509,"We're gonna split up. I'm gonna"],[1509,1589,"talk to Adrian's friends"],[1589,1659,"and we're gonna find out if"],[1659,1768,"there's anything else. Okay?"],[1780,1826,"Got it."],[1826,1897,"Thank you."],[2206,2352,"Kevin? Kevin?"],[2477,2623,"Claire, why are you here?"],[2644,2694,"I need you to"],[2694,2794,"contact Adrian, please."],[2823,3098,"I'm begging you. I, I need you to"],[3098,3261,"reach him. I can't contact him."],[3261,3378,"I have no way to reach him."],[3445,3657,"I can't contact Adrian and I need to..."],[3657,3687,"Can I,"],[3687,3782,"I need you to call,"],[3782,3895,"I need you to call someone."],[3895,3999,"I need just..."],[4195,4270,"Whoa there."],[4287,4421,"Just slow down, and tell"],[4421,4517,"me what's going on."],[4542,4708,"Adrian took Esther. I have no way"],[4708,4821,"to contact him. She is in danger,"],[4821,5021,"and I just need you to call him."],[5063,5109,"Claire,"],[5109,5301,"Adrian's Esther's father,"],[5309,5405,"he would never put"],[5405,5492,"her in any danger."],[5526,5647,"She is locked in a car. It is a"],[5647,5780,"hundred degrees outside and I am"],[5780,5834,"worried about her"],[5834,5914,"getting heat stroke."],[5947,6031,"We are running out of time and I"],[6031,6260,"just... I need you to call him."]],"23":[[20,216,"I need you to call him."],[258,375,"Adrian told me how"],[375,479,"controlling you are."],[504,567,"You think I don't see"],[567,650,"through your little act?"],[729,880,"I know this is one crazy lie just"],[880,975,"to get him to come home."],[1005,1117,"I am not lying. I am"],[1117,1197,"telling you the truth."],[1222,1422,"My daughter, Esther, is in danger."],[1476,1676,"Your story's full of holes. Okay."],[1755,1906,"All cars have ACs now."],[1964,2064,"There is nothing bad"],[2064,2143,"that's gonna happen."],[2189,2489,"Also, Adrian would never leave"],[2489,2594,"Esther in a car alone."],[2594,2857,"Well he did, and he is with Stacy,"],[2869,3032,"his childhood sweetheart."],[3069,3228,"And he has neglected"],[3228,3319,"Esther, and"],[3319,3486,"she is in the car by herself."],[3574,3753,"And I have no way to"],[3753,3883,"contact him, and I..."],[3937,4066,"I need you to call him, and if you,"],[4066,4162,"if you really cannot do that, I"],[4162,4270,"need you to call Stacy."],[4325,4483,"And I need you to help me find"],[4483,4604,"where my daughter is."],[4625,4692,"Claire,"],[4792,4954,"you are way too paranoid."],[5021,5196,"Yes, Adrian and"],[5196,5317,"Stacy did date before."],[5372,5584,"But that's in the past. Why are you"],[5584,5693,"clinging on to this?"],[5784,5972,"It's because you're so paranoid and"],[5972,6197,"controlling that Adrian is"],[6197,6339,"distancing himself from you."],[6385,6598,"I do not care what"],[6598,6694,"happens between them."],[6694,6806,"All I care about is where my"],[6806,6881,"daughter is. I just,"],[6898,7015,"I need to just find"],[7015,7169,"where my daughter is."],[7228,7382,"Esther is old enough to be on her own."],[7478,7640,"If anything were to happen, she"],[7640,7711,"would also be able"],[7711,7832,"to contact Adrian."],[7899,8033,"Just go home and"],[8033,8145,"stop causing a scene."],[8149,8320,"My daughter is in serious danger."],[8445,8608,"I need you to"],[8608,8883,"believe me. Just this once."],[9013,9117,"Please call Adrian."],[9288,9467,"Okay, fine."],[9513,9688,"I'll help you call Adrian."],[9738,9809,"Thank you."]],"24":[[8,108,"Okay, I'll call him."],[108,141,"Thank you."],[204,279,"But you should go first."],[316,383,"You've already caused"],[383,479,"enough of a disturbance."],[575,692,"Okay, and once I get a hold of him,"],[696,775,"I'll let you know."],[850,950,"Thank you, Kevin."],[1005,1105,"Just let me know when you get in"],[1105,1213,"touch with him as soon as possible."],[1226,1618,"Yes, I will definitely contact you"],[1618,1755,"once I get a hold of him."],[1789,1860,"Thank you, Kevin."],[2373,2419,"Definately."],[2940,2977,"Come on."],[2994,3032,"Wow."],[3053,3178,"Can you believe that psycho?"],[3415,3624,"My friend's wife, he went out to"],[3624,3816,"have lunch with his ex and she's"],[3816,3928,"running around like a mad woman"],[3928,4020,"trying to find him."],[4083,4337,"But just now didn't you agree to"],[4337,4412,"help her find him?"],[4466,4646,"Me? Help her? No. I just had that"],[4646,4717,"to get her out of here."],[4829,4950,"I know my boy wouldn't do anything"],[4950,5071,"to harm his own daughter."],[5088,5242,"Of course, no one would put their"],[5242,5351,"own child in danger."],[5367,5409,"Yeah."],[5434,5497,"Clearly, Claire is just"],[5497,5626,"like overly psychotic."],[5672,5780,"Yeah, I mean, she really looks like"],[5780,5922,"she's going off her rocker."],[5943,5993,"Why isn't Adrian"],[5993,6101,"doing anything about it?"],[6118,6189,"Did you see how she"],[6189,6297,"barged into our company?"],[6335,6460,"No wonder why Adrian's"],[6460,6602,"chasing after Stacy."],[6631,6702,"Who wants to be with a"],[6702,6798,"psycho like Claire."],[6981,7132,"Kevin, you promised you would help"],[7132,7203,"me find my daughter."],[7282,7353,"Look at you."],[7382,7478,"Your hair's a mess."],[7528,7553,"Dirty."],[7611,7695,"You're sweating like a pig."],[7753,7878,"Who would believe anyone that"],[7878,8008,"looked like a crackhead like you?"],[8087,8166,"No wonder why"],[8166,8350,"Adrian's chasing after Stacy."],[8404,8491,"If he"],[8491,8808,"really loved Stacy, then why didn't"],[8808,9021,"he just divorce me and be a"],[9021,9163,"good father to her kid?"],[9234,9321,"Why did he have to"],[9321,9430,"take my daughter?"]],"25":[[12,108,"Why did he have to"],[108,225,"take my daughter?"],[367,550,"Are you serious? Look at yourself."],[646,759,"I bet after you married him you"],[759,909,"made his life a living hell."],[967,1092,"It'd be weirder if he didn't cheat."],[1172,1380,"He's right. You're, you're suffocating."],[1443,1526,"If you want to throw a"],[1526,1701,"tantrum, do it somewhere else."],[1701,1901,"Don't barge into our company acting"],[1901,2002,"like a psycho."],[2068,2114,"If you don't leave"],[2114,2218,"right now, we're gonna"],[2218,2293,"have to call security."],[2560,2731,"You are going to call Adrian and"],[2731,2890,"tell him to bring me my daughter"],[2890,3019,"and I will grant him"],[3019,3161,"his wish and divorce him."],[3411,3574,"Look at yourself. You've only lost"],[3574,3753,"contact with him for a few hours,"],[3753,3912,"and you're already gone off the"],[3912,3970,"deep end."],[4012,4087,"That's right."],[4158,4320,"I'm crazy."],[4408,4546,"But Adrian is the one that is"],[4546,4675,"making me insane."],[4729,4850,"I am telling you."],[4942,5109,"I have not been able"],[5109,5234,"to locate my daughter."],[5313,5522,"I'll take anything. Anything!"],[5622,5943,"If anything happens to my daughter,"],[5943,6197,"you, and all of you will be"],[6197,6393,"complicit! You got that?"]],"26":[[125,275,"You're making me die!"],[492,692,"Why does my heart hurt so much?"],[759,855,"Esther?"],[913,1034,"Could something have happened"],[1034,1109,"to Esther?"],[1514,1647,"Jarvis? - Mrs. Serrano,"],[1647,1755,"we found Esther's location."],[1797,1947,"One of Stacy's co-workers said she"],[1947,2010,"took her son to the"],[2010,2106,"amusement park today."],[2131,2260,"I already contacted the police."],[2260,2323,"They'll search the"],[2323,2398,"parking lot first."],[2423,2531,"Let's quickly head over there too."],[2556,2723,"Okay, yeah, I'll drive her over."],[2940,2994,"Esther, Mommy's"],[2994,3086,"gonna get there soon."],[3165,3386,"Okay, just... Please just hold on a"],[3386,3474,"little bit longer."],[3511,3649,"You have to wait for Mommy."],[3728,3858,"Mommy's gonna celebrate your"],[3858,3991,"birthday with you."],[4012,4200,"Buy you the biggest cake"],[4200,4300,"and take you to the best"],[4300,4433,"amusement park."],[4592,4721,"Lucas, you gotta try this cake."],[4825,4888,"Here."],[5046,5121,"Like it?"],[5201,5292,"Yeah!"],[5676,5851,"I want Mommy and Daddy to be"],[5851,5976,"together forever."],[6043,6231,"Lucas, don't be greedy."],[6277,6385,"We only have Daddy for today."],[6418,6514,"I'm gonna eat all"],[6514,6614,"this cake now."],[6614,6681,"Okay."],[6890,7077,"I'm gonna treasure this day forever."],[7140,7315,"Hey Lucas, I'll tell you what."],[7411,7482,"Anytime you feel like you"],[7482,7582,"miss your dad,"],[7645,7799,"just give me a call."],[7799,7891,"And I'll be there."],[7953,8124,"Daddy, Mommy!"],[8124,8312,"I can't hold on any longer!"],[8408,8637,"I'll wait for you guys in heaven!"]],"27":[[346,429,"Esther."],[1330,1501,"Double check those tinted windows!"],[1951,2018,"Found her!"],[2127,2231,"Found her, over here!"],[2260,2377,"Found her. Hey!"],[2635,2694,"Negative."],[2898,2957,"Oh my God!"],[3003,3107,"We need an ambulance."],[3128,3186,"Esther!"],[3349,3407,"Esther!"],[3436,3495,"My baby!"],[3499,3595,"Please open! Open!"]],"28":[[0,95,"I got it, I got it!"],[2698,2857,"Esther please wake up."],[2894,3015,"Please wake up."],[3015,3161,"Please, my baby."]],"29":[[191,346,"You went in the bounce house?"],[479,550,"You know the way?"],[592,633,"Okay."],[1659,1730,"Come here."],[1760,1864,"Oh my gosh."],[2064,2156,"Alright, let's go."],[2990,3107,"They're gonna take care of her."],[3490,3603,"They don't have laces,"],[3603,3632,"so I think"],[3632,3720,"we already established"],[3720,3791,"that, so you're good."],[4158,4241,"Mommy's coming, okay,"],[4241,4350,"okay, I'm coming with you."],[4562,4650,"Sorry, ma'am, but you can't"],[4650,4713,"board the ambulance"],[4713,4800,"in your current state."],[4800,4917,"We can't have any distractions"],[4917,5038,"while treating the patient."],[5050,5142,"Please meet us at"],[5142,5242,"the hospital, okay?"],[5584,5684,"I'm still here."],[5730,6056,"No, no please don't leave me!"],[6076,6277,"I want my baby!"]],"30":[[429,579,"Mom, hey, what are you calling for?"],[667,759,"Obviously, because"],[759,917,"that crazy wife of yours,"],[950,1030,"she burst in the house"],[1030,1138,"and started yelling at me"],[1138,1226,"out of nowhere."],[1238,1347,"That woman has no"],[1347,1455,"respect for me at all."],[1484,1530,"Can't believe she'd"],[1530,1614,"disrespect her mother"],[1614,1680,"in law like that."],[1705,1785,"That's not all."],[1785,1935,"On top of yelling at me,"],[1935,2068,"she even had the audacity"],[2068,2248,"to slap me and threaten me."],[2277,2489,"I refuse to be her mother-in-law."],[2761,2806,"I'll call you back."],[3032,3119,"Hey, Kevin, what's up?"],[3186,3294,"Adrian, your wife just"],[3294,3420,"barged into my office"],[3420,3557,"like a psychopath and"],[3557,3687,"caused such a disturbance"],[3687,3878,"that we can't get any work done."],[3916,4091,"Adrian, you really have"],[4091,4183,"to get a better handle"],[4183,4291,"on that wife of yours."],[4329,4350,"What?"],[4387,4483,"She went to your office?"],[4554,4683,"All right, I'll set it straight."],[4829,4917,"Hey, what's going on?"],[4917,4946,"What happened?"],[4975,5013,"It's Claire."],[5075,5117,"She's gone"],[5117,5226,"completely off the deep end."],[5292,5384,"She yelled at my mom."],[5384,5422,"She showed up at"],[5422,5497,"my friend's office."],[5547,5613,"She's lost it."],[5634,5793,"How did I marry such a psychopath?"],[5839,5997,"Oh, Adrian, it's not your fault."],[6039,6101,"Don't be mad."],[6147,6202,"God, I honestly"],[6202,6335,"feel sorry for Claire."],[6364,6406,"I mean, her"],[6406,6577,"possessiveness, it's out of control."],[6577,6669,"And I feel like someone really"],[6669,6740,"needs to start talking"],[6740,6852,"to her about that. I..."],[6890,6969,"Oh my God, someone"],[6969,7107,"broke into my car?"],[7228,7253,"What?"],[7294,7369,"Yeah, look, I have"],[7369,7490,"this car security app"],[7490,7615,"and it says that someone broke the"],[7615,7716,"passenger side window."],[7820,7928,"It's so annoying."],[7928,7982,"I thought this was"],[7982,8112,"supposed to be a secure lot."],[8145,8212,"Why are people"],[8212,8320,"breaking my window?"],[8320,8383,"What the heck?"],[8466,8491,"It's Claire."],[8508,8562,"You think?"],[8587,8658,"It's gotta be Claire."],[8725,8771,"God, this woman is gonna"],[8771,8863,"be the death of me."],[8896,8983,"Oh my God."],[9004,9075,"Okay, come on, Lucas,"],[9075,9121,"let's go."],[9163,9225,"Come on, bud."],[9321,9580,"but, I mean, the app could be lying."]],"31":[[392,467,"I'll take you to the hospital."],[583,613,"Okay?"],[646,688,"Right."],[796,900,"The hospital."],[1263,1280,"Claire."],[1497,1576,"Adrian."],[1751,1818,"You've really gone"],[1818,1914,"too far this time."],[1947,2081,"Look, I can forgive you for barging"],[2081,2185,"into Kevin's office, but breaking"],[2185,2268,"into Stacy's car!"],[2298,2356,"Well, you found me."],[2414,2469,"Happy now?"],[2502,2535,"Happy?"],[2565,2744,"No, I'm not happy!"],[2761,3023,"Do you even understand what"],[3023,3132,"Esther's... your..."],[3132,3199,"she's already..."],[3224,3311,"You want to hit me now?"],[3340,3445,"Do you know that this car was the"],[3445,3520,"last thing that Stacy's"],[3520,3607,"husband left her?"],[3607,3628,"Huh?"],[3661,3803,"Look, I get you have a bad temper,"],[3803,3883,"alright, and you're always"],[3883,4033,"paranoid, but I will not forgive"],[4033,4170,"you for breaking into Stacy's car."],[4195,4291,"And now you try to attack me."],[4291,4325,"I mean, how could"],[4325,4400,"you be so heartless?"],[4454,4612,"You're calling me heartless?"],[4696,4817,"Adrian, our daughter is in the"],[4817,4975,"hospital fighting for her life"],[4975,5096,"right now because of you!"],[5196,5380,"You are the one that is heartless!"]],"32":[[8,262,"You are the one that is heartless!"],[342,479,"Claire, hey, you've misunderstood"],[479,621,"our relationship."],[642,779,"Look, I can forgive you for"],[779,930,"breaking the car window, but as a"],[930,1092,"mother myself, I can't just stand"],[1092,1180,"by while you joke"],[1180,1280,"about your daughter's life."],[1322,1480,"Listen to yourselves."],[1480,1618,"Mrs. Serrano's telling the truth."],[1618,1685,"Esther's on her way to the"],[1685,1776,"hospital right now."],[1776,1889,"If you had any conscience, you'd"],[1889,1960,"get out of our way so"],[1960,2060,"we can get there as well."],[2060,2248,"I see how it is, Claire. It's not"],[2248,2339,"enough that you're running around"],[2339,2464,"town spreading lies, but I see"],[2464,2502,"you've got your"],[2502,2640,"secretary in on the joke too."],[2660,2811,"Claire, how could you take advantage of"],[2811,2907,"your daughter like this?"],[2986,3115,"Esther was in my car asleep the"],[3115,3265,"entire time. How could anything"],[3265,3361,"have happened to her?"],[3445,3628,"But are you saying that Adrian"],[3628,3812,"doesn't love his own daughter?"],[3866,4041,"That he's not fit to be her father?"],[4083,4250,"Do either of you even know"],[4250,4412,"how hot it was this afternoon?"],[4412,4542,"It was a hundred degrees."],[4600,4854,"And you locked our daughter in the"],[4854,5021,"car! I mean what kind"],[5021,5150,"of father even are you?"],[5234,5376,"It was a little bit of sunshine."],[5376,5426,"Stop blowing things"],[5426,5488,"out of proportion."],[5492,5697,"A little bit of sunshine? A little"],[5697,5864,"bit? Do you even know how long"],[5864,5976,"Esther was in the car for?"],[6001,6168,"Oh come on, I had the AC on, I had"],[6168,6339,"food and snacks in the car. What's"],[6339,6431,"wrong with letting her sleep in"],[6431,6498,"there for a little bit?"],[6531,6585,"Then why didn't you"],[6585,6669,"leave him in the car?"],[6690,6848,"How could she compare to Lucas?"]],"33":[[12,100,"Claire that's..."],[212,362,"not what I meant. Lucas's daddy"],[362,483,"passed away, alright?"],[483,579,"So I just wanted to spend the day"],[579,734,"with him as a father figure."],[734,779,"That's all."],[825,971,"Look, I know that I haven't been"],[971,1096,"spending a lot of time with Esther."],[1113,1280,"Why don't you bring Esther out from"],[1280,1388,"wherever you're hiding her,"],[1388,1530,"and I will take her to the"],[1530,1614,"amusement park tomorrow."],[1693,1785,"That should be enough, right?"],[1893,2193,"Adrian, you better hope to God"],[2260,2356,"that you can take her"],[2356,2502,"to the amusement park."],[2544,2648,"What is that supposed to mean?"],[2686,2765,"You threatening me?"],[2790,2848,"Claire, how could"],[2848,2982,"you be so selfish?"],[3007,3211,"Esther has a lifetime with Adrian."],[3311,3486,"Why can't my son just have one day?"],[3511,3657,"That's enough. Just hurry up and"],[3657,3753,"bring Esther out, alright?"],[3753,3858,"I'll take her home, and tomorrow"],[3858,3978,"I'll do whatever she wants."],[4008,4083,"You're unbelievable."],[4083,4237,"What kind of a father are you?"],[4237,4350,"Hey, you stay out of this, alright?"],[4371,4433,"You're a real piece"],[4433,4525,"of work, you know that?"],[4525,4629,"Oh come on, you're just a secretary."],[4629,4713,"What are you gonna- - That's enough."],[4733,4892,"Adrian, you go be a good husband"],[4892,5100,"and a good father to someone else."],[5125,5359,"You do not deserve to see Esther."],[5563,5626,"Come on, let's go."],[5797,5864,"Mrs. Serrano?"],[5901,5964,"Hey, Claire."]],"34":[[596,654,"Oh my God!"],[729,750,"Lucas!"],[884,942,"Adrian!"],[946,1080,"Adrian, please help Lucas fainted!"],[1105,1192,"Adrian, are you not"],[1192,1322,"gonna help your own wife?"],[1322,1459,"Adrian, please, please,"],[1459,1572,"Lucas fainted, I can't lose him."],[1572,1622,"Please help me get"],[1622,1685,"him to the hospital."],[1726,1797,"Adrian!"],[1797,1901,"The ones you should be helping is"],[1901,2027,"your own wife and child!"],[2110,2248,"Adrian, please, I"],[2248,2352,"can't pick him up on my own."],[2406,2460,"Adrian!"],[2548,2652,"I can't... Adrian!"],[3194,3244,"Are you serious?"],[3328,3365,"Come on."],[3445,3482,"Alright."],[3695,3841,"You're gonna regret this!"],[3941,4058,"Forget about him."],[4166,4208,"I got you."],[4208,4287,"Go to the hospital."],[4287,4404,"Okay, come on, stand up."],[4404,4508,"I need to see Esther."],[4592,4675,"We have to find her."],[4692,4717,"Alright."],[4833,4917,"My beads."],[5088,5105,"Okay."],[5105,5180,"Hold on, hold on."],[5597,5764,"Today I lost my marriage."],[5926,6026,"And what's worse is..."],[6151,6260,"I don't even know if"],[6260,6377,"I'll lose my daughter too."]],"35":[[58,200,"You know, I realized a long time"],[200,417,"ago that Adrian"],[417,538,"wasn't a good husband."],[754,842,"Nor a good father."],[884,1076,"I knew for a long time."],[1151,1172,"Yeah."],[2360,2439,"You said that you would"],[2439,2489,"watch her today."],[2489,2560,"Where are you?"],[2806,2977,"No, Adrien, it is getting late and"],[2977,3107,"she hasn't even had dinner yet."],[3153,3299,"Stacy's light bulb broke, so I'm at"],[3299,3440,"her place helping her fix it."],[3474,3566,"You know her husband"],[3566,3674,"already passed away."],[3703,3803,"She needs me to help her with"],[3803,3878,"these kinds of things."],[5025,5213,"It's okay, Mommy. I'm not hungry."],[5630,5747,"Esther has a fever."],[5747,5809,"When are you coming home?"],[5868,5976,"I'm at the hospital right now for"],[5976,6189,"Lucas' check-up. Stop worrying."],[6256,6348,"Esther's usually pretty"],[6348,6473,"healthy, so she'll be fine."],[6552,6673,"Lucas, on the other hand, has a weak"],[6673,6815,"constitution, so his"],[6815,6931,"situation is more urgent."],[7032,7102,"Did you forget who"],[7102,7194,"your actual child is?"]],"36":[[104,191,"Fine, if you're gonna be like"],[191,304,"that then don't come home."],[496,596,"Was that daddy?"],[625,738,"Is he coming home?"],[963,1034,"I don't know."],[1697,1876,"When Esther's out of the hospital,"],[2093,2173,"I'm gonna get a divorce."],[2310,2348,"Yeah?"],[2794,2836,"Just..."],[3023,3207,"I just can't let anyone around my"],[3207,3349,"daughter who caused her harm."],[3478,3703,"And you shouldn't have to."],[3795,3874,"It's gonna be okay."],[4329,4471,"I think we are doing good here."],[4596,4854,"Get some rest, Lucas, sweetie."],[5171,5209,"Hi."],[5372,5505,"Am I okay, Mommy?"],[5568,5709,"Yes, of course you are."],[5768,5972,"Daddy, I'm happy you're here."],[6026,6202,"Thank you so much for coming and"],[6202,6285,"helping us get Lucas"],[6285,6393,"to the hospital today."],[6443,6606,"Maybe you should go check on Claire"],[6606,6781,"though, before she wakes up."],[6781,6856,"Otherwise she could lash"],[6856,6998,"out and go crazy on you."],[7490,7574,"No, no."]],"37":[[45,204,"Claire, she's healthy enough."],[237,379,"Alright, if she has the energy to go around"],[379,471,"town and wreak havoc."],[508,567,"She'll be fine."],[709,946,"Besides, Lucas is"],[946,1071,"so fragile, you know?"],[1146,1251,"She had to scare him with"],[1251,1330,"all of her yelling."],[1330,1380,"I mean, she could at"],[1380,1476,"least consider the child."],[2010,2068,"I'm going to pour this"],[2068,2160,"before I finish, so..."],[2314,2381,"With Lucas now in"],[2381,2598,"the hospital, I'm sorry."],[2598,2648,"I feel like we caused"],[2648,2723,"you a lot of suffering."],[2802,2948,"Hey, no, don't say that."],[2982,3090,"With you here with us,"],[3090,3274,"it's not a struggle at all."],[4763,4850,"Try not to worry."],[5000,5088,"Esther is gonna be okay."],[5196,5267,"We're here now."]],"38":[[183,275,"It's all my fault."],[400,454,"I mean I should have"],[454,554,"spent more time with her."],[625,734,"I mean, she's still so young,"],[734,838,"and she got locked in a car."],[1051,1242,"God, she must have been so scared."],[1401,1655,"And it's all my fault, it's all my fault!"],[1668,1801,"Claire, here."],[1818,1914,"It's all my fault. - Hey."],[1914,1981,"Come on, don't be this,"],[2010,2072,"don't be this way."],[2235,2385,"Esther wouldn't want to see you"],[2385,2477,"heartbroken like this."],[2577,2656,"Just try and stay"],[2656,2744,"strong, alright?"],[2990,3048,"We're gonna be okay."],[3553,3674,"She's just so little."],[3812,3949,"She's still so young."],[4191,4300,"She's still so young."],[4412,4525,"And she's such a good girl."],[4600,4746,"And now she's fighting for her life"],[4746,4879,"in an operating room."],[4950,5113,"If she gets out of this safe and sound,"],[5221,5347,"I'm never gonna leave her side,"],[5367,5551,"I'm always gonna be there."],[5701,5839,"I'm never gonna leave her again."],[5943,5976,"Claire."],[6302,6406,"Now you show up?"],[6439,6544,"Do you know that Esther's already-"],[6656,6769,"What the hell are you doing?"]],"39":[[141,279,"What the hell are you doing?"],[350,462,"You hit me."],[462,550,"That's right, I hit you."],[583,692,"And now, I want you"],[692,850,"to apologize to Stacy."],[1000,1242,"You want me to apologize to her."],[1272,1363,"Yes I do."],[1388,1459,"Did you know that your little"],[1459,1547,"tantrum..."],[1547,1697,"caused Lucas to go into shock?"],[1697,1835,"Now he has to be hospitalized?"],[1843,1906,"Don't you think you should"],[1906,2035,"apologize to Stacy for that?"],[2068,2152,"Her side isn't shocking."],[2152,2394,"You want me to apologize to her?"],[2444,2681,"She should be begging me"],[2681,2840,"for my forgiveness for what"],[2840,3002,"she did to our daughter!"],[3028,3199,"Look, if Claire doesn't want to"],[3199,3353,"apologize it's fine."],[3440,3582,"Lucas is only in the hospital"],[3582,3745,"because he has a weak constitution."],[3745,3883,"We shouldn't blame other people."],[3949,4029,"Claire you see that?"],[4099,4216,"Stacy is so nice."],[4270,4337,"Then why can't you be more"],[4337,4408,"like her?"],[4408,4458,"Huh?"],[4471,4608,"You, you're just so selfish and"],[4608,4675,"irrational."],[4713,4821,"Just apologize."],[4846,4979,"You called me selfish?"],[5080,5363,"I mean, have you even considered"],[5363,5492,"your own daughter?"],[5492,5576,"Have you even thought about"],[5576,5638,"Esther?"],[5659,5764,"Will you stop using our"],[5764,5876,"daughter as an excuse?"],[5939,6064,"Why is it that every time we argue,"],[6064,6135,"you say something ominous"],[6135,6227,"about our daughter, huh?"],[6264,6393,"I mean, what kind of mother does that?"]],"40":[[0,133,"You don't deserve"],[133,275,"to be Esther's father."],[337,475,"You're gonna regret how you treated"],[475,579,"your wife and child today."],[625,809,"No my biggest regret..."],[809,905,"is marrying Claire."],[967,1076,"Lucas is in the hospital"],[1076,1142,"because of her."],[1163,1276,"And instead of having an ounce"],[1276,1393,"of remorse..."],[1393,1505,"she's still bullying Stacy."],[1534,1618,"If Claire doesn't want to"],[1618,1780,"apologize I'm not gonna force her."],[1864,2047,"Okay, look, I..."],[2047,2152,"I'm widow and a single mom."],[2152,2227,"I'm used to this kind"],[2227,2314,"of treatment, it's okay."],[2385,2448,"Don't worry."],[2556,2723,"I'll make sure you get justice."],[2798,2869,"No more, I'm not gonna"],[2869,3011,"let anybody insult you."],[3094,3199,"How admirable."],[3545,3611,"Do you hear me?"],[3611,3712,"I asked Adrian to go."],[3712,3841,"I wouldn't even..."],[3841,4004,"even I forget that I'm your wife."],[4104,4245,"Claire, enough with the nonsense"],[4245,4354,"and just apologize"],[4354,4479,"to Stacy right now."]],"41":[[66,237,"Claire, I think you've really"],[237,350,"misunderstood my"],[350,483,"relationship with Adrian."],[583,817,"I think we both know crystal clear"],[817,950,"what kind of relationship"],[950,1067,"you two have."],[1301,1459,"Look, you can insult my son and I"],[1459,1564,"all you want, but you don't get to"],[1564,1693,"accuse me of being a mistress."],[1793,1960,"I do my best to raise my son with"],[1960,2185,"integrity. And that is taking it"],[2185,2277,"way too far Claire."],[2310,2381,"Integrity?"],[2481,2565,"I think you need to look up"],[2565,2648,"what the word integrity"],[2648,2765,"actually means."],[2798,2902,"Hey, you watch your mouth."],[2902,3015,"And you can shut up too!"],[3082,3165,"You don't get to have it"],[3165,3232,"both ways."],[3378,3495,"You two may look civilized, but"],[3495,3636,"you're no better than animals."],[3745,3824,"You left your daughter in a"],[3824,3949,"boiling old car."],[3991,4079,"All day!"],[4099,4175,"And now what?"],[4175,4291,"You don't give a damn about her,"],[4291,4437,"you're busy fooling around,"],[4437,4550,"drooling over your ex"],[4550,4642,"playing daddy to"],[4642,4779,"some spoiled little brat!"]],"42":[[12,91,"Dare you accuse"],[91,187,"Lucas and I of that."],[216,296,"Tell me it's not true."],[350,500,"Claire, all I did was go out to"],[500,596,"lunch with Stacy."],[633,713,"And not only do you use our"],[713,775,"daughter as an"],[775,888,"excuse to try to find me,"],[959,1051,"now you're paranoid about my"],[1051,1134,"relationship with her?"],[1176,1263,"You're going crazy."],[1297,1393,"You're the crazy one!"],[1426,1572,"You left your own daughter in a"],[1572,1714,"boiling hot car all day."],[1760,1910,"And now you want your wife to"],[1910,2018,"apologize to your mistress?"],[2056,2235,"Look, you're just some secretary."],[2248,2414,"This is a private family affair"],[2414,2531,"between Claire and Adrian."],[2531,2635,"How dare you interfere?"],[2635,2744,"So you do know"],[2744,2865,"what a family matter looks like,"],[2865,3002,"so why are you getting involved?"],[3111,3203,"Pretty mistress"],[3203,3340,"thing to do, if you ask me."],[3361,3511,"Hey, not one more word to Stacy!"],[3511,3632,"Hey, it's okay."],[3691,3782,"Look, I shouldn't have asked you"],[3782,3845,"to come today."],[3866,3941,"I shouldn't have asked you"],[3941,4029,"to be a dad to Lucas."],[4029,4162,"I just think you should go home and"],[4162,4287,"explain the situation to Claire"],[4287,4383,"because this is a big"],[4383,4454,"misunderstanding."],[4475,4546,"Okay I need you to just"],[4546,4671,"get the hell out already"],[4671,4763,"because I cannot look at either"],[4763,4859,"of you right now!"],[4896,5063,"Hey, watch it, Claire."],[5125,5251,"Stacy's letting you off easy for"],[5251,5338,"damaging her car."],[5380,5447,"Did you know that Lucas"],[5447,5543,"has acute liver failure?"],[5593,5772,"You made his condition worse."],[5809,5868,"Don't you think you should"],[5868,5997,"apologize to Stacy for that?"],[6064,6197,"Her son is only sick, and our"],[6197,6314,"daughter's life is on the line."],[6352,6410,"God, you're still"],[6410,6493,"going on about that?"],[6577,6719,"No one here believes you."],[6881,7015,"Come on, Stacy, let's go."],[7136,7207,"Adrian."],[7269,7424,"Adrian, you stop right there!"],[7449,7624,"If you have a conscience, you will"],[7624,7803,"wait until your daughter gets out!"],[8066,8137,"Gets out?"],[8254,8366,"The operating room?"],[8429,8546,"Could Esther really be?"]],"43":[[20,112,"The guardians of the"],[112,225,"patient in room 385?"],[304,404,"Please return to the room."],[404,483,"The patient's woken up."],[508,604,"He's asking for his mother."],[692,763,"Lucas is awake!"],[813,913,"Come on, we have to go!"],[1109,1322,"Claire, Lucas needs me. Just..."],[1322,1468,"enough with the nonsense, alright?"],[1518,1593,"Take Esther home."],[2435,2527,"Mrs. Serrano?"],[2748,2840,"Doctor, how is she?"],[2957,3065,"The patient was delivered to the"],[3065,3174,"hospital too late."],[3282,3516,"I'm sorry, we couldn't save her."],[3545,3616,"What?"],[3699,3782,"No, no, no, that"],[3782,3883,"doesn't make any sense."],[3978,4095,"I mean, and..."],[4141,4270,"She was breathing"],[4270,4337,"before we brought her"],[4337,4421,"to the hospital."],[4608,4821,"Doctor, please, please I'm begging you..."],[4821,4934,"just, just look again."],[4934,5055,"This can't happen to my daughter!"],[5176,5363,"You're lying! You're lying to me!"],[5376,5476,"I'm sorry ma'am,"],[5476,5626,"but we've already done our best."],[5651,5809,"When the patient was sent here..."],[5834,5935,"it was too late."],[6022,6118,"She was left in"],[6118,6247,"the car for too long."],[6272,6406,"And on such a hot day..."],[6431,6602,"there was no hope of saving her."],[6656,6731,"Please..."],[6731,6827,"Please, just, just look,"],[6827,6927,"just look, just look."],[6927,7015,"She can't be dead,"],[7015,7169,"there's no way she can be dead!"],[7215,7415,"There's no way she's gone!"],[7444,7540,"I think you should begin"],[7540,7657,"final preparations."],[7874,7978,"I'm sorry."],[8737,8850,"My baby..."],[9004,9184,"My baby!"],[9597,9751,"No!"]],"44":[[16,171,"Daddy, I am cold."],[233,275,"Are you?"],[315,362,"Here."],[563,633,"There's no way!"],[667,759,"There's no way!"],[1180,1284,"Who's out there crying?"],[1351,1434,"Why does that voice sound"],[1434,1509,"so familiar?"],[1680,1764,"Hey, I'm, uh..."],[1785,1843,"I'm just gonna go sit out there"],[1843,1906,"for a minute."],[2706,2798,"You feeling okay buddy?"],[2852,3007,"Heaven's gained another angel."],[3065,3236,"What a shame, that little girl was"],[3236,3386,"only five years old!"],[3386,3507,"It's really such a shame."],[3507,3653,"And I can't believe her father either."],[3682,3853,"His daughter's already passed away,"],[3853,4012,"and he still hasn't shown up."],[4012,4175,"What kind of a father is he?"],[4229,4416,"I know. I can't believe him."],[4487,4633,"Could they be talking about Esther?"],[5000,5092,"Excuse me."],[5184,5347,"Did you just say that a child died?"],[5568,5663,"What was her name?"]],"45":[[16,154,"What was the child's name?"],[171,233,"Um,"],[291,383,"I think it was..."],[404,550,"Oh! Right, her name was-"],[550,608,"Adrian?"],[646,754,"Lucas fainted again."],[1197,1347,"Now he's what I call a good dad."],[1359,1443,"Look how much he cares about"],[1443,1505,"his kid."],[1580,1722,"Unlike that poor girl."],[1768,1885,"Even in her final moment, she"],[1885,2031,"wasn't able to see her dad."],[2110,2273,"The only people who were by her side,"],[2273,2406,"were a secretary, and her"],[2406,2523,"mother fainted from crying."],[2627,2786,"There's no rules to being a parent,"],[2811,2982,"but to lock one's daughter in their"],[2982,3140,"car on such a hot day- I mean,"],[3140,3257,"how could someone"],[3257,3428,"be so irresponsible?"],[3853,3958,"Locked in a hot car..."],[4237,4366,"I should go check on Esther."],[4708,4838,"Lucas just fainted again."],[4838,4954,"What am I supposed to do?"],[4954,5084,"Stacy, we're in a hospital. There's"],[5084,5188,"a bunch of doctors around."],[5221,5334,"I'm doing no good just sitting around"],[5334,5401,"anyways."],[5547,5626,"Plus..."],[5655,5759,"I'm actually really worried about"],[5759,5830,"Esther."],[6035,6093,"Adrian!"],[6181,6289,"What about Lucas?"]],"46":[[500,563,"Esther?"],[575,742,"Mommy, I'm right here."],[829,1000,"Hi Mommy, you're finally awake."],[1000,1155,"I waited so long for you!"],[1259,1309,"Esther."],[1710,1793,"Hi."],[1943,2064,"I thought I lost you. I'm never gonna"],[2064,2181,"leave your side ever again."],[2498,2677,"Mommy, I made this for you."],[2836,3028,"Mommy, I worked so hard on this."],[3040,3232,"Mommy, you're too careless."],[3319,3449,"I'm so sorry."],[3486,3595,"I shouldn't be so careless."],[3695,3749,"Can you..."],[3749,3870,"Can you ever forgive Mom?"],[3924,4041,"Of course, Mommy."]],"47":[[12,171,"Mommy, why are you crying?"],[392,492,"I had a dream."],[692,896,"I had a dream that I lost you."],[1017,1126,"I had a dream that I"],[1126,1292,"would never see you again."],[1397,1493,"I just thank God it was only"],[1493,1584,"a dream."],[1643,1789,"It was only a dream."],[2064,2218,"It's okay, Mommy. I still wait for"],[2218,2281,"you in heaven,"],[2281,2456,"after a long time passes."],[2523,2706,"Hey mommy, we can eat lots and lots"],[2706,2836,"of cake together and"],[2836,2977,"stay together forever!"],[3057,3153,"What do you mean?"],[3153,3299,"We could have cake and you could"],[3299,3415,"have everything right now."],[3474,3678,"It's too hard. It's too late."],[3745,3895,"Mommy, everything hurts."],[3966,4208,"I can't hold on anymore."],[5038,5142,"Esther!"],[5559,5634,"Esther!"]],"48":[[8,158,"Hey, Mrs. Serrano, lay down."],[158,241,"Lay down, lay down."],[300,354,"The nurse just said"],[354,425,"you need to rest."],[684,792,"No, I don't need rest."],[792,900,"I need, I need to see my baby I..."],[917,946,"No, no."],[955,1046,"She's waiting for me, she-"],[1046,1142,"Mrs. Serrano. - She must be scared!"],[1176,1238,"Here."],[1376,1459,"She's already..."],[1547,1659,"Esther's passed away."],[1976,2135,"I'm sorry. She's gone."],[2256,2369,"No, you're lying."],[2523,2681,"But, there's no way."],[2844,2915,"I'm sorry."],[2915,2994,"No, you're lying."],[3011,3148,"It doesn't make any sense, she-"],[3224,3274,"Claire."],[3274,3378,"You're lying to me,"],[3378,3566,"No. You're, you're lying to me!"],[3566,3586,"Claire..."],[3603,3741,"You're lying to me!"],[3866,4074,"Pull yourself together..."],[4120,4258,"She's behind that curtain."],[4375,4466,"Okay, you still have a"],[4466,4587,"chance to say goodbye."],[4637,4713,"I'm so sorry."],[5042,5130,"Claire."],[5372,5522,"Hey, where's Esther?"],[5597,5684,"Where's Esther?"]],"49":[[154,308,"Okay, I get it."],[350,421,"You're mad..."],[421,500,"mad because I spent the day"],[500,658,"with Stacy and Lucas, I get it."],[658,775,"I'll... I don't know, I'll make it up to"],[775,863,"you when I get home."],[905,1080,"Alright? Just let me see Esther."],[1180,1338,"Now you're worried about Esther."],[1459,1559,"And here I thought,"],[1559,1705,"that Stacy and Lucas"],[1705,1818,"were the only ones who"],[1818,1968,"had a place in your heart."],[1968,2056,"Oh, come on."],[2102,2156,"How many times do"],[2156,2223,"I have to tell you?"],[2285,2394,"Stacy and I were just friends."],[2435,2544,"All right, can you stop being so"],[2544,2677,"possessive for once?"],[2823,2919,"I'm possessive?"],[2973,3194,"Fine, I will be generous and I will"],[3194,3328,"let Stacy have you."],[3395,3499,"Does that sound right?"],[3536,3737,"Whatever, just uh..."],[3828,3916,"bring Esther out so I can"],[3916,4008,"apologize in person."],[4166,4250,"No need."],[4316,4441,"She doesn't need your apology"],[4441,4600,"now that she can't hear it anyway."],[4629,4721,"Claire, what are you talking about?"],[4721,4800,"Just bring Esther out, all right?"],[4800,4884,"I'm in a rush right now."],[4909,4959,"Please?"],[4992,5113,"Come on, I, I need to talk to her."],[5138,5251,"Oh, so now you're in a rush?"],[5380,5484,"Now you're in a rush?"],[5513,5709,"Where were you in a rush when,"],[5709,5918,"when Esther was locked in a car?"],[6010,6143,"Where were you in a rush"],[6143,6277,"when I was calling you"],[6277,6393,"dozens of times,"],[6393,6523,"I mean, God, I mean,"],[6610,6710,"why do you need her so"],[6710,6869,"bad now all of a sudden?"],[6881,6994,"Look, Lucas's condition is"],[6994,7152,"deteriorating, all right? I-"],[7152,7269,"Just let me talk to her!"],[7303,7444,"The doctors are saying that Lucas,"],[7444,7490,"he..."],[7549,7657,"he needs a liver donor."],[7695,7774,"Immediately."],[7799,7966,"Now, a while back I"],[7966,8099,"took Esther for some tests"],[8149,8204,"and..."],[8233,8337,"she's a perfect match."],[8408,8554,"So I wanna ask her if"],[8554,8650,"she could help out Lucas"],[8650,8737,"and be his donor."]],"50":[[0,141,"What did you just..."],[279,371,"Say that again?"],[412,567,"I want to ask Esther if she'll"],[567,713,"donate her liver to Lucas."],[788,1038,"You want to trade our daughter's"],[1038,1263,"life for your mistress's son?"],[1301,1447,"Lucas is in a life-threatening"],[1447,1643,"situation. If Esther doesn't donate"],[1643,1760,"her liver, Lucas could die."],[1860,1910,"I mean, Claire, come on"],[1910,2001,"don't be so selfish."],[2064,2147,"I'm selfish?"],[2239,2318,"Oh, God, because you were"],[2318,2581,"so generous and, and noble."],[2698,2769,"You want to trade our"],[2769,2911,"daughter's life for"],[2911,3032,"someone else's son!"],[3090,3161,"Claire, I already"],[3161,3294,"asked the nurse. All right?"],[3294,3428,"Esther only has to donate part of"],[3428,3507,"her liver and it won't"],[3507,3653,"affect her life in any way."],[3699,3787,"You're right. It's not going to"],[3787,3920,"affect her life at all and I still"],[3920,4020,"don't give consent!"],[4099,4379,"Claire, if you give consent to have"],[4379,4537,"Esther donate her liver, I will do"],[4537,4688,"anything you want in"],[4688,4817,"the future. All right?"],[4859,4979,"Come on, I just can't sit back and"],[4979,5096,"watch a child die."],[5146,5205,"Adrian do you have"],[5205,5292,"no conscience?"],[5342,5413,"Watch it, Jarvis."],[5413,5501,"Don't cross the line here."],[5501,5609,"I'm crossing the line."],[5626,5755,"Do you hear yourself? Do you know"],[5755,5905,"what you're asking for right now?"],[5997,6151,"You abandoned your daughter to go"],[6151,6310,"play house with some other woman,"],[6310,6544,"and now you want Esther to donate"],[6544,6702,"her liver to save"],[6702,6856,"your mistress's child?"],[6936,6990,"You're a bastard."],[7107,7161,"Bastard!"]],"51":[[304,404,"I'm gonna tickle you now!"],[442,538,"No! Don't touch the"],[538,642,"floor! Don't touch the floor!"],[900,950,"Bastard!"],[950,1000,"Son of a..."],[1622,1897,"If you had any conscience, you'd get"],[1897,2052,"the hell out of here and leave"],[2052,2173,"Mrs. Serrano and Esther!"],[2268,2364,"Leave them in peace!"],[2506,2627,"It's between me and my wife."],[2694,2765,"Back off."],[2840,3011,"You trying to slide in and shoot your shot."],[3094,3224,"You're the cheater."],[3294,3428,"And now you want to accuse me?"],[3520,3716,"You don't deserve to be a father."],[3820,4066,"If you had any shred of conscience,"],[4108,4254,"you'd be down onto your knees begging"],[4254,4383,"for forgiveness right now!"],[4421,4517,"Don't you know that"],[4517,4604,"Esther's in there-"],[4604,4696,"Okay, enough!"],[4754,4813,"Enough!"]],"52":[[16,208,"You are bothering us right, just-"],[208,275,"I need you both to"],[275,425,"just get the hell out!"],[671,875,"Claire, hey look, I know you don't"],[875,1151,"like me, but Lucas is innocent."],[1159,1305,"The doctor just said that if he can"],[1305,1455,"get this liver transplant quickly"],[1455,1526,"enough, that he can"],[1526,1630,"live until he's 18!"],[1668,1847,"Please, Claire, I am begging you to"],[1847,1964,"save my son's life."],[2031,2168,"Live until he's 18?"],[2264,2335,"Stacy?"],[2398,2619,"Did you even consider my"],[2619,2815,"daughter turning 18 when you"],[2815,2973,"locked her in a car?"],[3065,3182,"Claire, come on, enough with that."],[3236,3336,"Why are you still bringing that up?"],[3445,3591,"Why do I keep bringing this up?"],[3757,3928,"Because I will not live this down"],[3928,4029,"and you will not be"],[4029,4170,"getting Esther's liver."],[4250,4379,"How can you be so goddamn"],[4379,4471,"heartless, woman?"],[4471,4587,"What are you, gonna hit me?"],[4625,4754,"So what if I do?"],[4829,4946,"Esther was under the sun for a"],[4946,5105,"little bit. You want an innocent"],[5105,5230,"child to die in revenge."]],"53":[[538,617,"You've gone crazy."],[950,1096,"That's right! Yeah!"],[1151,1343,"I have gone crazy!"],[1501,1818,"Can I ask you one last question?"],[1960,2031,"Go for it."],[2131,2256,"Do you know what today is?"],[2298,2402,"What does it have to do with esther"],[2402,2485,"donating her liver?"],[2598,2686,"Just answer the"],[2686,2919,"question, or get the hell out."],[2986,3073,"Today's Esther's birthday."],[3328,3511,"Finally remembers."],[3799,4129,"Now, her father left her locked in"],[4129,4262,"a car while he went off with"],[4262,4396,"someone else's kid."],[4491,4754,"I get it. I forgot. Alright? I'm"],[4754,4963,"sorry. I'll make it up to her."],[5017,5050,"Do you remember"],[5050,5130,"what you promised her?"],[5159,5326,"Yeah. I told her I'd take"],[5326,5417,"her to an amusement park."],[5605,5672,"I've been busy."],[5784,5889,"Busy. Ah, of"],[5889,5989,"course you've been busy."],[6101,6264,"So busy that you go to an amusement"],[6264,6427,"park with your ex and her son."],[6464,6648,"I mean, did you even consider that"],[6648,6744,"Esther may have wanted to"],[6744,6840,"to go with you?"],[6856,6961,"Hey, Claire, that's enough!"],[7044,7144,"Alright, I told you there's nothing"],[7144,7244,"between us. Why do you keep"],[7244,7307,"bringing this up?"],[7374,7670,"Fine. I won't bring it up again,"],[7670,7799,"but I want a divorce."]],"54":[[29,425,"Claire, there is nothing going on"],[425,625,"between me and Adrian."],[625,896,"I mean, if there was, do you really"],[896,1051,"think you'd have a chance with him?"],[1105,1222,"Stacy, have you got no shame?"],[1300,1380,"Okay, you guys are"],[1380,1497,"misunderstanding me again."],[1630,1814,"Please, Claire, hate me all you"],[1814,1918,"want, yell at me all you want, but"],[1918,2001,"please, I am begging"],[2001,2193,"you to save Lucas's life."],[2239,2335,"I already talked to the doctors,"],[2360,2519,"alright? Esther is healthy enough,"],[2540,2669,"she won't have any problem donating"],[2669,2736,"part of her liver."],[2798,2961,"Be mad at me all you want, but just"],[2961,3036,"consider the child."],[3111,3174,"Consider the child?"],[3249,3365,"You know from where I'm standing"],[3365,3687,"it sounds like you only"],[3687,3807,"care about her son."],[3807,3962,"I mean, where was this worry about"],[3962,4170,"Esther when she was locked in a car"],[4170,4312,"and I was calling you repeatedly to"],[4312,4408,"find out her location?"],[4462,4646,"I mean, where was you"],[4646,4754,"concerned about her?"],[4804,4879,"Would you stop"],[4879,5030,"being so unreasonable?"],[5109,5221,"Claire, Claire,"],[5221,5363,"please, I am begging you."],[5417,5527,"I've already lost my husband, I've"],[5527,5624,"already lost Adrian,"],[5624,5739,"I can't lose Lucas too."],[5816,5936,"Fine, you both want her liver?"],[6106,6468,"Then you will meet me tomorrow, at the"],[6468,6539,"church on Peach"],[6539,6827,"Grove Lane, at noon."],[6827,6886,"There, Esther will"],[6886,6986,"give you her consent."]],"55":[[0,125,"You mean it?"],[204,312,"You're giving consent?"],[329,392,"Yeah, as long as"],[392,508,"she gives it to you."],[567,633,"And so will I."],[684,988,"This is great. Thank you, Claire."],[988,1092,"I mean, Esther's a good kid."],[1092,1313,"She'll say yes. Thank you."],[1401,1468,"Oh my God, we should"],[1468,1601,"go tell Lucas right now."],[1601,1639,"Yeah."],[1664,1761,"Come on. - Lucas."],[2039,2302,"Oh, and uh, Claire. If you don't"],[2302,2448,"mind, would you help me apologize"],[2448,2648,"to Esther? For missing her birthday?"],[2648,2815,"Tell her I'll buy her"],[2815,2927,"something nice, you know."],[3011,3061,"We'll throw a birthday"],[3061,3178,"party for her,"],[3178,3224,"maybe even take"],[3224,3328,"her to amusement park, so um."],[3370,3495,"Yeah. Anything she wants."],[3603,3687,"Adrian, don't forget."],[3770,3816,"Noon."],[3891,4029,"Church at Peach Grove Lane. It's"],[4029,4137,"your last chance to see Esther."],[4254,4283,"Got it."],[4325,4604,"Um, actually Lucas has a follow-up"],[4604,4746,"appointment tomorrow? I don't"],[4746,4817,"think I can do it alone."],[4875,4979,"Oh. Well, we'll have time."],[5017,5117,"Yeah. I'll be able to do that."],[5188,5255,"We'll go see Esther after."],[5301,5480,"Alright. Thanks."]],"56":[[137,316,"Mrs. Serrano, are you okay?"],[1209,1351,"I'm fine, just..."],[1413,1505,"You think you could um,"],[1572,1718,"call the church on Peach Grove Lane"],[1718,2131,"and just let them know to get"],[2131,2235,"Esther out of the morgue"],[2235,2364,"as soon as possible?"],[2419,2656,"She's always hated hospitals, so."],[3290,3440,"Of course, Mrs. Serrano."],[4295,4521,"Adrian, do you really think"],[4521,4592,"Claire will let"],[4592,4688,"Esther donate her liver"],[4688,4800,"to Lucas that easily?"],[4913,5125,"Don't worry, I talked to Claire."],[5188,5309,"She'll definitely give her consent."],[6468,6740,"You know, I really envy you three."]],"57":[[50,112,"I already lost my"],[112,421,"husband, I- I can't lose Lucas, too."],[488,554,"Hey."],[625,700,"Don't worry."],[817,921,"Okay? I'll do whatever"],[921,1117,"it takes to make sure that Esther"],[1117,1222,"donates her liver to Lucas."],[1301,1380,"You mean that?"],[1434,1568,"Yeah. Have I ever"],[1568,1676,"broken a promise to you?"],[1730,1810,"I'm gonna make sure that Lucas"],[1810,1939,"grows up to be a healthy adult."],[2081,2193,"Grows up into a healthy"],[2193,2452,"adult? That was my wish, too."],[2498,2625,"I wanted my daughter to"],[2625,2823,"become a wonderful woman."],[2860,3098,"Adrian, maybe I'm wrong. Maybe"],[3098,3215,"you're not a bad father."],[3269,3336,"You just"],[3411,3603,"didn't give your best to me."],[3649,3866,"Or to Esther. Instead, you gave"],[3866,3991,"it all to your first love."],[4400,4729,"Why do I feel so unsettled? I feel"],[4729,4796,"like I've lost"],[4796,4896,"something really important."],[5100,5180,"Adrian, I'm giving"],[5180,5326,"you one last chance."],[5397,5613,"If you come, you'll get to see"],[5613,5768,"Esther one last time."],[5868,5993,"If you don't come..."]],"58":[[1501,1589,"Hi baby."],[1639,1856,"Yesterday was your fifth birthday"],[1856,2060,"and I completely forgot."],[2310,2519,"I brought you your favorite toy."],[2615,2727,"Happy birthday, baby."],[3286,3332,"You're gonna be"],[3332,3503,"fine, okay? Just rest."],[3812,3895,"How is he, Doctor?"],[4049,4170,"You used to always beg"],[4170,4433,"me for a princess dress."],[4512,4654,"I bet you would look absolutely"],[4654,4792,"beautiful in this."],[4867,4971,"But I will never get"],[4971,5105,"to see you wear it."],[5134,5238,"This is mommy's gift"],[5238,5359,"for your 10th birthday."],[5476,5676,"The boy's fine. He just fainted"],[5676,5772,"from a sudden shock."],[5926,6031,"His liver disease is"],[6031,6214,"chronic, but not acute."],[6289,6389,"So no need for a liver"],[6389,6519,"transplant right now."]],"59":[[25,154,"Gonna let him rest for a few"],[154,221,"days, and then I'll"],[221,358,"be discharging him."],[404,538,"Wow, thank you doctor."],[567,625,"Thank you."],[950,1076,"You used to always fuss about"],[1076,1180,"wanting to eat cake."],[1297,1447,"And I would always tell you how it"],[1447,1568,"would ruin your teeth."],[1718,1793,"Well you don't have to"],[1793,1901,"worry about that anymore."],[2022,2173,"You can have all the cake you want."],[2281,2519,"This is mommy's gift to you for"],[2519,2619,"your 12th birthday."],[2711,2802,"Oh my gosh."],[2802,3044,"You know, we should have all"],[3044,3303,"parents take an exam before they"],[3303,3495,"have kids, because just looking"],[3495,3624,"at you two the way you love this"],[3624,3737,"child is just great."],[3778,3941,"Too bad everybody's not like that."],[4029,4204,"Yesterday, I had a little girl who"],[4204,4295,"died from heat stroke."],[4408,4567,"Father didn't visit her once."],[4637,4700,"Not once."],[4783,4896,"Not even after she died!"],[4954,5063,"And worse of all, today's her"],[5063,5184,"funeral, and, and I heard he"],[5184,5317,"still hasn't even shown up."]],"60":[[33,133,"You know what?"],[133,221,"I thought I heard two nurses"],[221,333,"talking about that."],[375,433,"What kind of father would"],[433,538,"do something like that?"],[538,771,"Yeah, exactly. We would never"],[771,905,"do that to our Lucas."],[963,1026,"Hi."],[1113,1301,"I like Daddy the best!"],[1301,1468,"Daddy's the bestest."],[1618,1797,"And Daddy likes you the bestest."],[2018,2177,"This is a wedding dress."],[2285,2452,"This is your mommy's gift to you"],[2452,2644,"for your 20th birthday."],[2694,2802,"Once you're older,"],[2852,2932,"you may even have a"],[2932,3053,"family of your own."],[3174,3332,"Don't be like your mother."],[3332,3490,"Don't be like mommy."],[3586,3891,"You are going to be the happiest,"],[3891,4245,"most beautiful bride."],[4450,4713,"I'll talk to you guys in a bit."],[5055,5226,"Oh Adrian, you're the best."],[5601,5747,"Adrian..."],[5780,5943,"where have I heard that name before?"]],"61":[[980,1280,"Mrs. Serrano, it's time."],[1931,2014,"...that was the name of"],[2014,2160,"the little girl's father."],[2494,2577,"You didn't show up"],[2577,2731,"to your little girl's funeral."],[2731,2840,"Not once!"],[2882,3090,"Instead, you're playing daddy,"],[3090,3324,"a good father, to some other child?"],[3361,3507,"You're scum, pal."],[3595,3712,"Doctor, what did you just say?"],[3712,3795,"I said"],[3795,4041,"the little girl who died yesterday"],[4041,4191,"that was your daughter!"]],"62":[[45,179,"What do you mean by that?"],[196,271,"I've got nothing"],[271,421,"else to say to you, pal."],[462,533,"Nothing."],[1626,1826,"That was weird."],[2298,2419,"It, It's 1:30."],[2540,2669,"We gotta meet Esther at the church."],[2702,2790,"Come on."],[2790,3107,"Oh, hey Adrian, wait, wait! Um!"],[3411,3536,"Esther's gonna be buried soon."],[3536,3695,"Why hasn't her dad showed up yet?"],[3741,3870,"I heard that he didn't even go"],[3870,4008,"visit her when she was in the hospital."],[4049,4137,"It's awful."],[4183,4366,"I know, right? If only he didn't"],[4366,4537,"leave her all alone locked up in the car"],[4537,4658,"none of this would have happened."],[4704,4833,"How horrible of him."],[4850,5013,"So incredibly heartless."]],"63":[[583,663,"There's no one here."],[817,946,"Must be some sort of mistake."],[1172,1222,"Claire"],[1222,1363,"probably gave you a fake address"],[1363,1459,"to get back at you for"],[1459,1547,"the one you gave her."],[1789,1935,"She's really gone too far this time,"],[1989,2089,"using Esther like that?"],[2139,2177,"But-"],[2231,2293,"Yeah, I'm done."],[2293,2377,"I'm done playing her games."],[3207,3311,"Are you two family members"],[3311,3445,"of the little girl who passed away?"],[3570,3603,"What?"],[3670,3753,"What are you talking about?"],[3820,3937,"No one in my family has died."],[4045,4183,"Come on Stacy, let's get out of here."],[4279,4425,"We need to hurry up and find Claire,"],[4466,4604,"the mother of the deceased."],[4763,5063,"She forgot her daughter's memorial photo."],[5363,5417,"Sorry,"],[5447,5584,"what'd you say the mother's name was?"],[5668,5860,"Oh, well it's Claire Serrano."],[5905,6001,"She left behind her daughter's"],[6001,6110,"memorial photo."],[6460,6552,"There's no way."],[6731,6806,"Can't be."],[7686,7866,"That's not her, that's not my Esther."],[7891,7953,"That's not her."]],"64":[[20,229,"That's not her, that's not my Esther."],[229,346,"That's not her."],[442,663,"Did you even consider"],[663,829,"my daughter turning eighteen"],[829,1026,"when you locked her in a car?"],[1117,1347,"Ah, there's no rules to being a parent."],[1347,1572,"But to lock one's daughter in their car"],[1572,1718,"on such a hot day, I mean,"],[1718,1951,"how could someone be so irresponsible?"],[2256,2302,"Sir."],[2585,2752,"I'm sorry sir, but, uh"],[2765,2923,"strangers aren't allowed to touch the"],[2923,3094,"belongings of the deceased."],[3311,3603,"I'm not a stranger, I'm uh. I'm her father."],[3782,3899,"You're her father?"],[3941,4041,"Then why didn't we see you"],[4041,4145,"during the funeral?"],[4400,4612,"I, um. I..."],[4713,4863,"Where were you?"],[4896,5080,"Your daughter has already been buried!"],[5359,5434,"Let's, um,"],[5434,5551,"hang on to the photo"],[5551,5676,"and wait for the child's mother to"],[5676,5772,"come and get it."],[7315,7394,"Hey."],[8350,8458,"I do."],[8604,8771,"Oh, I did this to her."],[9146,9338,"Uh-oh, Esther, I'm so sorry..."]],"65":[[225,417,"Uh-oh Esther, I'm so sorry."],[638,788,"Come on out guys."],[971,1109,"Here we go."],[1251,1309,"Come on, Esther."],[1380,1447,"Now watch yourself."],[1476,1555,"Where's...?"],[1680,1826,"You can't come with us."],[1901,2018,"Well, Daddy, I don't"],[2018,2181,"want her to come with us!"],[2389,2464,"Well, Daddy..."],[2540,2806,"You can't call him Daddy, only I can."],[2869,3061,"Oh Daddy, can I please come?"],[3107,3307,"Daddy, I don't want someone else to"],[3307,3457,"take you away today."],[3499,3628,"Didn't you promise to"],[3628,3757,"stay with me, Daddy?"],[3820,3941,"Daddy, can't I come?"],[4012,4116,"Daddy, please!"]],"66":[[41,162,"Daddy, can't I come?"],[266,400,"Daddy, please!"],[980,1034,"Yeah."],[1363,1514,"Yeah, fine."],[1547,1597,"Esther, come on,"],[1597,1730,"let's sit back in the car, okay?"],[1780,1839,"Fine."],[1851,1906,"Come on in."],[2102,2206,"Okay, just sit right there."],[2252,2431,"Fine, can I please come?"],[2506,2694,"Remember, today's Lucas' day, okay?"],[2711,2786,"Stay in the car."],[2786,2957,"We got snacks. The AC's on."],[3023,3232,"You'll be all right. All right."],[3407,3520,"Bye, sweetie."],[4041,4124,"Daddy!"],[4592,4788,"Daddy, come back!"],[4813,5017,"Daddy!"],[5409,5563,"It was just an accident."],[6427,6589,"I need to see her again."],[6702,6827,"I need to find Esther."],[7144,7290,"Wait, Adrian!"]],"67":[[713,938,"Claire. Claire!"],[1230,1297,"Tell me..."],[1297,1401,"Tell me it's just a lie."],[1514,1584,"Tell me that Esther is just"],[1584,1680,"playing a prank because I was out"],[1680,1772,"with Stacy and Lucas."],[1847,1951,"It's just a prank, right?"],[1964,2056,"Don't touch me."],[2348,2423,"A prank."],[2523,2623,"It's too late for Esther"],[2623,2744,"to play any pranks."],[2823,2848,"Just..."],[3261,3411,"sign the divorce papers, and be with"],[3411,3574,"Stacy like you always wanted."],[3670,3866,"Claire, I... I was wrong."],[3953,4062,"Okay, I, I know that now."],[4116,4158,"All right?"],[4208,4241,"Just"],[4358,4521,"tell me where Esther's buried."],[4592,4717,"Let me see her, please."],[4771,4896,"I gave you a chance."],[5034,5167,"And you blew it."],[5184,5301,"When I was in the hospital"],[5301,5417,"when you came to visit,"],[5526,5734,"and you asked me if Esther"],[5734,5947,"could donate her liver to Lucas."],[5989,6185,"She was lying in the hospital bed"],[6185,6293,"next to me."],[6468,6544,"No."]],"68":[[70,108,"No."],[333,400,"Did you know?"],[817,1000,"That moments after someone dies,"],[1000,1142,"they can still hear the voices of"],[1142,1330,"the people around them?"],[1601,1810,"Esther was lying next to me."],[1901,2102,"And she heard her precious daddy"],[2102,2406,"ask if he could give her liver to"],[2406,2590,"some other woman's child."],[2690,2848,"I had no idea. I..."],[3028,3303,"Oh my God. I killed Esther."],[3478,3570,"I'm so sorry."],[3624,3716,"On her birthday..."],[3862,4079,"she wanted to go to the amusement park."],[4158,4421,"If you had just taken her with you,"],[4504,4783,"she would have been over joyed."],[4875,5167,"But instead, you left her behind"],[5184,5422,"and you locked the car."],[5547,5693,"And she watched you"],[5730,5889,"as you walked away."],[6010,6135,"with another kid."]],"69":[[79,250,"And she watched you"],[250,408,"as you walked away"],[529,658,"with another kid."],[988,1205,"Stop! Just stop talking."],[1334,1493,"When she finally managed to call"],[1493,1614,"you and beg you for help,"],[1614,1751,"and you hung up on her,"],[1751,1822,"what do you think was"],[1822,1972,"going through her mind?"],[2064,2218,"Does he like Mrs. Stacy's kid"],[2218,2310,"more than me?"],[2510,2669,"Does he not want me anymore"],[2669,2815,"because I'm not a good girl,"],[2815,2936,"is that why he left me to die?"],[2961,3069,"Claire, I'm begging you"],[3069,3219,"please stop talking."],[3299,3374,"Please, I'm begging"],[3374,3532,"you please, please!"],[3574,3712,"Just let me see her, and let me say"],[3712,3866,"my final goodbye, please."],[3883,4179,"You do not deserve to see her."]],"70":[[25,137,"Esther!"],[175,362,"Esther, what happened to my"],[362,513,"precious granddaughter?"],[533,679,"She was alive and well yesterday"],[679,788,"and how could"],[788,950,"something like this happen?"],[1042,1201,"Didn't I already tell you?"],[1284,1443,"Esther was locked in a car, she was"],[1443,1680,"in serious danger, and I asked you"],[1680,1997,"to call your son to save Esther."],[2164,2435,"Mom, what really happened?"],[2435,2673,"I don't know, I thought she was lying."],[2711,2844,"I didn't realize that Esther"],[2844,3007,"was really in danger!"],[3036,3203,"If I would have known, of course I"],[3203,3332,"would have saved her."],[3345,3516,"She's my own granddaughter!"],[3853,3995,"You hated Esther because"],[3995,4266,"she caused so much trouble."],[4379,4558,"You said that you had hoped that"],[4558,4671,"this would happen to her."],[4721,4925,"Congratulations, you got your wish."],[4988,5142,"What exactly did you say?"],[5226,5380,"I didn't mean to."],[5509,5643,"I just said it"],[5643,5797,"in the heat of the moment."]],"71":[[104,442,"Claire, I'm begging you, let me see Esther."],[487,675,"I'm her father for Christ's sakes."],[704,896,"You do not deserve to see Esther."],[917,1138,"And you do not say you are her"],[1138,1338,"father with your filthy mouth!"],[1434,1555,"I'm begging you."],[1576,1634,"Please."],[1872,2006,"I need to say goodbye."],[2131,2289,"I need to apologize to her in person."],[2318,2356,"Please."],[2986,3128,"Esther is a victim."],[3186,3370,"You caused her death"],[3370,3536,"by doing everything you"],[3536,3682,"could to please Stacy."],[3820,3949,"So stop pretending that"],[3949,4095,"you are a good father."],[4354,4675,"And if you really want to see her,"],[5100,5213,"look inside this."],[5726,5872,"Tomorrow at 9 o'clock..."],[6005,6252,"you will meet me outside city hall."],[6435,6619,"I hope you're not late this time."]],"72":[[2377,2581,"Daddy, did you get off work yet?"],[2581,2727,"I really missed you."],[2923,3044,"Daddy, can I come now?"],[3065,3190,"Are you still in a meeting?"],[3340,3478,"I haven't had dinner with you"],[3478,3636,"in a long time."],[3908,4149,"Daddy, tomorrow is my birthday."],[4175,4287,"Can you and mommy"],[4287,4491,"take me to an amusement park?"],[4829,4917,"Please."]],"73":[[262,316,"Are you telling me"],[316,400,"that that's a lava chair?"],[454,546,"That's a lava chair?"],[588,650,"Yeah. - No."],[700,800,"That's a floor, no,"],[821,884,"no, don't touch the floor."],[913,975,"Don't touch the floor."],[1297,1384,"No, no."],[1509,1659,"You got me."],[1664,1768,"High five, hug."],[1793,1839,"Yeah."],[1951,2056,"Spin, spin."],[2189,2410,"My son, hurry up and"],[2410,2544,"go plead with Claire"],[2544,2681,"so we can at least find"],[2681,2840,"out where she's buried."],[2873,3119,"Please, please."],[3194,3449,"Mom, what did you say to Claire?"],[3495,3591,"I said it in the"],[3591,3670,"heat of the moment."],[3757,3828,"Why are you"],[3828,4008,"shifting the blame on me now?"],[4074,4220,"I'm not blaming you."],[4387,4462,"I blame myself"],[4550,4650,"for not being a good"],[4650,4733,"father to Esther."],[5530,5593,"Mommy and daddy."],[5872,6072,"Can you please stop messaging me?"],[6118,6185,"Stacy's sick and"],[6185,6268,"she's trying to sleep."],[6268,6402,"If the phone keeps buzzing, you're"],[6402,6506,"gonna wake her up."],[6560,6690,"Just text your mom"],[6690,6777,"if you need anything"],[6777,6961,"and stop bothering me."],[7152,7365,"Daddy, it's so hot in here."],[7411,7515,"When will you come back?"],[7582,7753,"Esther, what did I tell you?"],[7816,7878,"You have to stay in"],[7878,7978,"the car, daddy's busy."],[8033,8149,"Where are you, daddy?"],[8224,8395,"Stop calling, okay?"],[8925,9096,"I really miss you daddy."],[9480,9605,"I did this."],[9884,9972,"I'm responsible for"],[9972,10026,"my daughter's death."]],"74":[[563,717,"Esther, it's all your dad's fault."],[804,917,"I didn't take care of you."],[1000,1080,"I didn't spend"],[1080,1230,"enough time with you."],[2681,2752,"It's okay."],[2802,2948,"Daddy's coming, Esther."],[3061,3186,"I won't let you be lonely anymore."],[3324,3436,"I'm gonna stay by your side."],[3524,3586,"Forever."],[4429,4646,"Adrian, where are you going?"],[4788,4888,"Adrian!"],[5004,5155,"Adrian!"],[5221,5447,"Adrian, can't you see?"]],"75":[[475,571,"Adrian?"],[1534,1689,"Hello, Adrian?"],[1810,1906,"Adrian?"],[2973,3044,"Adrian?"],[3098,3215,"Are you out here?"]]}