{"1":[[75,233,"They say when a chef can carve"],[233,412,"the Chrysanthemum Tofu Flower,"],[492,638,"he's not just holding a knife,"],[696,792,"he's mastered it."],[3253,3328,"I've done it."],[4074,4124,"Sit."],[4229,4320,"Oh, good boy."],[4517,4567,"Okay."],[4662,4829,"I'm gonna tell him."],[4975,5030,"Leon."],[5125,5188,"You didn't come home"],[5188,5267,"and I knew you'd be here,"],[5267,5384,"and I couldn't wait to tell you-"],[5392,5455,"Sarah."],[5472,5513,"Hey."],[5543,5647,"Hey, come on."],[5793,5847,"Sarah."],[5980,6051,"I've done it."],[6151,6272,"I've mastered the knife."],[6352,6402,"I'm gonna win us"],[6402,6535,"the World Culinary Championship."],[6581,6669,"I'm gonna take us to"],[6669,6823,"Paris, Tokyo, Rome."],[6848,6923,"I'm going to show the world"],[6923,6986,"what I can do."],[7132,7307,"Should I tell him that I'm pregnant?"],[7782,7928,"He seems so focused"],[7928,8012,"on his cooking."],[8145,8266,"That is amazing, Leon."],[8817,8892,"I'm so proud of you-"],[8892,9029,"I've got to talk to the restaurant manager."],[9117,9192,"You should get home."],[9221,9305,"It's snowing hard."],[9363,9430,"Don't wait for me."],[9492,9551,"I'll be late."],[9693,9759,"Okay, honey."],[10001,10176,"When will he have time for a family?"]],"2":[[295,458,"Alright folks, this is it."],[458,683,"The moment we've all been waiting for."],[700,916,"Your undisputed King of Cooking,"],[916,1170,"Chef Leon Kennedy!"],[1404,1558,"In honor of Chef Kennedy's"],[1558,1700,"historic milestone,"],[1700,1854,"Mr. Birkins has pledged"],[1854,2016,"an additional cash prize"],[2016,2245,"on top of Chef Kennedy's winnings."],[2250,2379,"That's right, Iris."],[2379,2479,"As the owner"],[2479,2791,"of over twenty Michelin restaurants,"],[2804,3033,"it has been the joy of a lifetime"],[3033,3183,"to witness Chef Kennedy"],[3183,3345,"wielding his legendary"],[3345,3579,"Damascus knife in person."],[3595,3958,"Leon! Leon! Leon! Leon!"],[3958,4183,"And now we invite to the stage"],[4195,4616,"your King of Cooking, Leon Kennedy!"],[5845,5895,"He's gone!"],[5895,5975,"Where is he?"],[6012,6058,"He's not there."],[6058,6150,"Where's Leon?"],[6150,6337,"We want the King of Cooking!"],[7345,7416,"Mr. Kennedy,"],[7445,7600,"your wife was in a car accident"],[7600,7741,"on her way to your award ceremony."],[7787,7920,"She's in critical condition."],[7950,8033,"You have to hurry."],[8066,8237,"We don't know how much time she has."],[8258,8375,"I must inform you, sir."],[8429,8495,"Your wife."],[8520,8629,"She's eight weeks pregnant."],[9512,9583,"Sarah?"],[9675,9804,"We did everything we could."],[11095,11295,"Your King of Cooking,"],[11295,11570,"Leon Kennedy! - Leon!"],[11570,11741,"Leon! Leon!"],[11770,11895,"Sarah!"],[12708,12879,"Sarah, you gave me this knife"],[12879,13033,"when I won my first competition."],[13633,13766,"I don't want to be King of Cooking"],[13879,14008,"if it means losing you."],[15333,15470,"Two days and you still haven't eaten."],[15545,15658,"You trying to leave me too, buddy?"],[16145,16270,"It is widely believed"],[16270,16366,"that the disappearance"],[16366,16495,"of the King of Cooking"],[16495,16633,"was due to the sudden death"],[16633,16783,"of his wife, Sarah."],[16820,16995,"He's not been seen for several months."],[16995,17204,"And it's a topic of raging debate,"],[17204,17366,"who will inherit his crown"],[17366,17500,"if he does not return?"],[17500,17741,"Wherever you are Leon, we miss you."]],"3":[[988,1167,"Hey, want some snacks?"],[1192,1272,"Yeah."],[1418,1484,"Hey, Leon."],[1551,1722,"I brought some snacks for Dante"],[1722,1964,"and some leftover risotto for you."],[1993,2064,"Thanks, Ada."],[2218,2285,"The last few months"],[2285,2381,"you've been nothing but kind,"],[2419,2548,"and we'll have nothing"],[2548,2644,"to repay you with."],[2748,2802,"So,"],[3011,3090,"how about a rose?"],[3365,3553,"Wow, your knife skills."],[3553,3599,"It's,"],[3728,3862,"actually quite impressive."],[3878,3945,"Have you ever considered"],[3945,4029,"becoming a chef?"],[4458,4583,"Hey, good luck with your bid today."],[4646,4754,"Hope you get what you came for."],[4838,4971,"Wait, how did you know?"],[4996,5121,"Every Tuesday you come by"],[5121,5238,"at exactly 9 a.m."],[5259,5351,"for a produce restock"],[5351,5430,"for your restaurant."],[5543,5718,"Today you are here at 7:45,"],[5718,5809,"which tells me"],[5809,5968,"something expensive shipped in"],[5968,6101,"and you want first pick."],[6139,6281,"You have your van parked there with"],[6448,6519,"two stock boys,"],[6519,6648,"which means it's big."],[6756,6877,"I can only think of one thing."],[7011,7102,"Bluefin tuna."],[7294,7374,"You are here to bid"],[7374,7549,"on the prized jewel of the Pacific."],[7549,7611,"Am I right?"],[7991,8070,"And truffles."],[8183,8249,"Delicious."],[8600,8796,"Leon, who exactly are you?"],[9192,9246,"Nobody."],[9342,9555,"Just a bum who likes good food."],[9805,9876,"You should go inside."],[9909,9997,"Don't let me hold you up."],[10060,10105,"Okay."],[11056,11156,"Whoever cooked this risotto"],[11156,11340,"needs to go back to culinary school."],[11699,11740,"Yeah,"],[11807,11916,"I'm gonna give you the whole thing."]],"4":[[479,521,"Hey, Bob."],[625,704,"Is there anyone here"],[704,796,"to bid for the tuna?"],[829,1013,"If not, I'd like to take it."],[1017,1088,"Sorry, Ada."],[1130,1230,"It's already been sold."],[1338,1388,"What?"],[1397,1459,"Sold?"],[1472,1526,"Who took it?"],[1589,1739,"Pack up my fish, boys."],[2097,2210,"And my truffles."],[2289,2515,"You sold my truffles, too?"],[2552,2677,"I thought I had first pick."],[3036,3190,"Great ass, like always."],[3199,3361,"Leave me alone, Joey."],[3395,3470,"What's the deal, Bob?"],[3474,3574,"We had an agreement."],[3595,3703,"Don't blame Bob."],[3774,3912,"Everyone knows your restaurant"],[3912,4054,"isn't what it used to be."],[4083,4166,"I pay more."],[4283,4383,"I buy more."],[4396,4496,"That sounds fair."],[4583,4637,"Right?"],[5271,5376,"Oh, sweetheart,"],[5376,5509,"don't look at me like that."],[5601,5714,"Business is business."],[5797,5930,"You know what's actually fair?"],[5947,6206,"If I actually had a chance"],[6206,6306,"to bid what I"],[6306,6393,"came here for. - Fine."],[6423,6493,"You want fair?"],[6639,6727,"I challenge you"],[6752,6936,"to a lobster de-shelling contest."],[7278,7353,"If you win,"],[7474,7570,"I'll give you first pick"],[7570,7686,"for the rest of the season."],[7878,7957,"And the tuna."],[8033,8149,"Wasn't Joey a chef"],[8149,8312,"before he was a restaurant manager?"],[8329,8366,"How would Ada"],[8366,8479,"ever compete with that?"],[8504,8621,"She's gonna lose for sure."],[8650,8817,"Joey's just trying to embarrass her."],[8837,8917,"But if you lose,"],[8942,9034,"I get to kiss you"],[9034,9221,"for however long I want."],[9359,9430,"Are you in game?"],[9918,10076,"I say bring it on,"],[10118,10189,"asshole."]],"5":[[433,529,"Who is that guy?"],[529,679,"She's been in there a long time."],[788,892,"Something's wrong."],[980,1092,"I'll be right back, okay?"],[1847,1901,"All right."],[1964,2052,"Let's start,"],[2122,2185,"now!"],[6752,6815,"Time!"],[6873,6956,"Joey wins,"],[6990,7173,"at 5 minutes and 49 seconds."],[7198,7290,"Why did she even bother?"],[7328,7486,"She knew she was gonna lose."],[7486,7603,"Maybe she wanted to kiss Joey"],[7603,7724,"but needs the excuse."],[7736,7820,"You know how women are."],[7845,7974,"They never mean it when they say no."],[8354,8454,"Get off of me,"],[8454,8546,"you creep! - Nu-uh."],[8550,8641,"We had a deal."],[8687,8762,"You lost."],[8779,8883,"You're gonna kiss me"],[8900,9046,"in front of everyone"],[9071,9230,"for however long I want."],[9271,10318,"Kiss! Kiss! Kiss!"],[10347,10431,"Let her go."]],"6":[[54,145,"You call this shit"],[145,279,"de-shelling a lobster?"],[446,538,"Who the hell are you?"],[558,621,"What, are you just gonna let"],[621,775,"a fucking bum walk in here?"],[800,975,"He is my friend, Leon."],[975,1059,"Leave him alone."],[1701,1801,"Your lobster is rubbery"],[1801,1881,"and overcooked."],[1885,2035,"Not even my dog would eat this."],[2052,2218,"What the fuck did you just say to me?"],[2235,2389,"You're missing the claws and the legs."],[2402,2569,"This de-shelling is incomplete."],[2606,2727,"The competition isn't over."],[2736,2840,"He is kind of right."],[2861,2911,"Yeah."],[2932,3069,"You can't skip the claws"],[3069,3290,"in a lobster de-shelling contest."],[3290,3415,"But not the legs too right?"],[3432,3553,"Those suckers are tiny."],[3553,3620,"So what?"],[3666,3853,"I could de-shell the claws right now."],[3891,4024,"Ada still loses."],[4041,4145,"It don't change nothing."],[4354,4433,"Then I will finish"],[4433,4575,"the competition for her"],[4612,4750,"and beat your time by half."],[4758,4888,"You think you can de-shell"],[4904,5096,"an entire lobster in under five minutes?"],[5113,5159,"Three,"],[5238,5309,"to be exact."],[5739,5910,"This fucking hobo is a funny one."],[5926,6093,"Leon, it's okay."],[6101,6139,"I lost-"],[6139,6193,"Trust me."],[6281,6339,"This guy doesn't know"],[6339,6410,"what he's doing."],[6556,6627,"I won't lose."],[6694,6781,"Who do you think you are,"],[6785,6915,"the missing master chef?"],[7065,7236,"Are you up for the competition or not?"],[7265,7332,"Are you too scared"],[7332,7415,"that I might beat you?"],[7428,7465,"Me?"],[7494,7599,"Scared of a hobo?"],[7628,7778,"When you lose, which you will,"],[7836,8028,"you have to lick my fucking shoes."],[8324,8416,"Leon, don't-"],[8416,8454,"Deal."],[9067,9446,"Three, two, one,"],[9446,9522,"start!"]],"7":[[5914,5976,"Time!"],[6039,6089,"Fuck!"],[6110,6360,"That was 2 minutes and 57 seconds."],[6610,6702,"Under three minutes."],[7023,7123,"Who is this guy?"],[7136,7248,"He reminds me of somebody."],[7261,7415,"Just can't put my finger on it."],[7432,7528,"Whoever he is,"],[7540,7682,"he beat Joey, hands down."],[7853,7912,"You lost."],[8012,8083,"Now it's time for you"],[8083,8245,"to honor your end of the bargain"],[8295,8483,"and to lick my shoes"],[8508,8679,"for however long I want."]],"8":[[33,187,"You want me to give up the fish"],[196,342,"and give her first pick?"],[346,446,"That's not going to happen."],[483,567,"So you are a liar."],[604,713,"You do business with a man"],[713,834,"who goes back on his word?"],[855,1030,"Who knew he would be such a sore loser?"],[1038,1234,"Yeah, man up, dude."],[1309,1422,"Shut the fuck up!"],[1468,1564,"Whoa, whoa, whoa."],[1697,1830,"Let's all calm ourselves."],[1918,2056,"I wouldn't have fucking lost"],[2077,2168,"if you hadn't butt in."],[3728,3820,"I'd highly suggest you"],[3820,3962,"don't play with knives around me."],[4012,4149,"It will not end well for you."],[4149,4212,"Ms. Anderson,"],[4266,4350,"everything okay here?"],[4462,4537,"Do we have a problem?"],[4838,4946,"Yeah, whatever, man."],[4946,5088,"Take the fucking fish,"],[5113,5234,"and she's going to have first pick"],[5234,5334,"for the rest of the season."],[5359,5459,"No problem at all."],[5509,5618,"Pack up my fish, boys."],[5634,5701,"Yes, ma'am."],[6185,6264,"Thank you, Leon."],[6435,6510,"You saved me."],[7311,7399,"You need to come with me."],[7428,7615,"You are in dire need of a shower."]],"9":[[867,1055,"Dad, I swear, his knife skills,"],[1126,1251,"I cannot describe it, okay?"],[1251,1397,"It's nothing I've ever seen before."],[1476,1568,"I want to hire him. -Ada,"],[1568,1668,"what did I tell you about"],[1668,1747,"that guy? -Yeah, okay."],[1747,1818,"Okay, I know."],[1868,2010,"Well, he's homeless for now."],[2031,2202,"Once we give him a gig,"],[2202,2348,"then he won't be homeless anymore."],[2481,2640,"I will clean him up"],[2640,2723,"and bring him to you."],[2798,2848,"Okay."],[2902,2990,"I'll give him a chance."],[2990,3040,"Alright."],[3065,3169,"Thanks, Dad."],[3211,3311,"Love you, Dad."],[4108,4291,"Oh, my goodness."],[5009,5063,"Careful."],[5472,5509,"Oh,"],[5538,5576,"umm."],[5722,5780,"You look,"],[6056,6110,"clean."],[6322,6389,"You look clean."],[6585,6769,"I grabbed some of my dad's old clothes."],[6769,6861,"They should fit you."],[6861,6931,"They're on the chair."],[7286,7336,"Thanks."],[7378,7428,"Mhm."],[8850,9129,"Do you want something to drink?"],[9230,9280,"Beer?"],[9288,9355,"Wine?"],[9451,9501,"Soda?"],[9634,9730,"No, it's okay."],[10010,10097,"Thanks for the shower."],[10352,10502,"I should be getting out of your hair."],[10556,10627,"Come on, Dante."],[10652,10706,"Wait."],[10852,10944,"Can we talk for a sec?"]],"10":[[487,542,"So that's why"],[542,642,"you roam the streets, huh?"],[759,863,"Because you feel guilty"],[863,971,"about the death of your wife"],[971,1088,"and your unborn child."],[1288,1334,"Yeah."],[1605,1730,"What did you do for work?"],[1985,2085,"I was um..."],[2369,2427,"a fisherman."],[2623,2706,"That makes sense."],[2877,3015,"No wonder you were so good"],[3015,3165,"at de-shelling those lobsters."],[3378,3449,"You know, for a second"],[3449,3541,"I thought you were a chef."],[3924,3991,"It's late."],[4220,4308,"I should probably go."],[4466,4550,"Wait, Leon."],[4842,4946,"You have a talent."],[5009,5105,"And my restaurant"],[5105,5255,"could use someone with your skills."],[5288,5497,"And I think that it's time"],[5497,5701,"to move on with your life."],[5809,5918,"Your wife wouldn't want you"],[5918,6047,"to keep going on like this."],[6377,6431,"I think,"],[6727,6802,"I think I'm good."],[7077,7390,"I, I know that your wife"],[7390,7499,"was your whole world."],[7599,7903,"I just think that maybe you shouldn't"],[7903,8045,"stay frozen in hers."],[8108,8237,"She should be your memory,"],[8320,8408,"not your prison."],[11302,11365,"We shouldn't."],[11949,12062,"You're still here."]],"11":[[1242,1388,"Tell me you'll think about my offer."],[1564,1618,"Okay."],[1893,1981,"He needs a home."],[2210,2281,"If not for you,"],[2414,2481,"for your dog."],[2581,2698,"Oh, Jesus."],[4225,4341,"You're so beautiful."],[6352,6456,"Seriously?"],[6527,6723,"He just slept with me and left?"],[8003,8087,"Yes!"],[8733,8829,"You got a little bit of a-"],[8829,8879,"Nu-uh."],[8992,9113,"No flirting at work."],[9284,9384,"Here at the restaurant,"],[9384,9463,"I'm the manager,"],[9501,9638,"and you're the line cook."],[9726,9893,"Now outside of the restaurant,"],[9905,10014,"that's a different story."],[10089,10185,"You got it, boss."],[10314,10422,"Now go have a banging"],[10422,10506,"first day of work."]],"12":[[1329,1441,"Where's your digital scale, man?"],[1520,1583,"Are you telling me"],[1583,1691,"that you know how to portion out"],[1691,1883,"exactly 250 grams of salmon"],[1933,2208,"with your magical hobo sixth sense?"],[2379,2479,"If you think Ada"],[2520,2654,"gave your bum ass a job"],[2695,2833,"so that you could be useless in here"],[2833,2954,"instead of out on the street,"],[2995,3083,"you're fucking wrong."],[3154,3229,"I'm watching you."],[3370,3533,"You're big-dogging us already, huh?"],[3533,3612,"Who do you think you are?"],[3654,3758,"The goddamn King of Cooking?"],[3787,3887,"If Ada didn't let you in,"],[3887,3995,"the only thing you'd be cooking for"],[3995,4112,"is your fucking dog."],[4708,4866,"Chef Anderson, you're right on time."],[4883,5016,"I was reprimanding Leon here"],[5016,5116,"for skipping steps."],[5137,5308,"When we cut salmon,"],[5308,5491,"we use the scale."],[5554,5654,"That's how we get exactly"],[5654,5791,"250 gram portions."],[5812,6029,"Leon, your cuts are sloppy as shit."],[6041,6166,"Why don't you throw them on the scale"],[6187,6291,"so that everyone can see?"],[6300,6491,"Put the fish aside for right now, Bryant."],[6491,6579,"I have important news,"],[6579,6666,"so everyone listen up!"],[6741,6941,"Our building's owner, Mr. Cato,"],[6962,7170,"is bringing Steven Gordon here today"],[7170,7241,"for a meal."],[7254,7412,"If we want to keep our respect,"],[7487,7712,"our jobs, and our business,"],[7737,7841,"we need to impress him."],[7841,7954,"So get ready to deliver"],[7954,8079,"some flawless service."],[8104,8179,"Yes, Chef!"],[8200,8404,"Steven Gordon, the celebrity chef?"],[8462,8504,"Yeah."],[8541,8687,"The influencer guy launched"],[8687,8862,"a Food Report with Steven Gordon."],[8904,8995,"And his reviews can"],[8995,9104,"make or break a place."],[9166,9266,"Steven Gordon?"],[9300,9416,"Even he's a hard-hitting"],[9416,9512,"food critic now?"],[9550,9620,"Let's get started."],[9641,9687,"Come on!"],[10112,10266,"These are some highly-skilled cuts."],[10291,10479,"Long, steady strokes,"],[10541,10666,"and all with a single cut."],[10945,11175,"Exactly 250 grams."],[11191,11379,"I guess anyone can get lucky once."],[11758,11929,"That's incredible."]],"13":[[50,204,"Steven Gordon is at table nine."],[204,254,"He ordered the"],[254,375,"chicken apple risotto."],[425,466,"Okay."],[541,625,"That's my specialty."],[704,800,"Allow me, Chef Anderson."],[1004,1041,"Leon,"],[1291,1391,"you go assist Bryant."],[1766,1808,"Him?"],[1808,1950,"No, Chef, please."],[1950,2033,"He'll only get in the way."],[2033,2162,"Yes, him."],[2216,2275,"Now move."],[2275,2450,"Ada and I have to go give Mr. Gordon"],[2450,2529,"a proper greeting."],[3141,3254,"Don't let Chef's charity"],[3254,3325,"get to your head."],[3325,3416,"You're roadside garbage"],[3416,3525,"and that's all you'll ever be."],[3579,3637,"And by the way,"],[3679,3812,"this doesn't make you my assistant."],[3841,3925,"Now let me do all the work"],[3925,4070,"and you don't fuck anything up."],[4216,4304,"What the hell?"],[4375,4504,"How's the homeless line cook"],[4504,4666,"supposed to keep up with this sous chef?"],[4679,4741,"I know, right?"],[4754,4887,"He's gonna get Bryant in trouble."],[4929,5050,"If you fuck this up,"],[5075,5116,"I will do more"],[5116,5229,"than put you out on the streets."],[5270,5554,"I will gut you in front of everyone."],[5604,5762,"I will evenly portion you out into"],[5787,6025,"into 250 gram slices of hobo meat."],[6429,6504,"Let's get started."],[6920,7029,"You're cutting onions,"],[7029,7125,"apples, and chicken"],[7125,7250,"into quarter-inch cubes,"],[7250,7366,"all the same size."],[7375,7504,"If they're not all the same size,"],[7504,7695,"I am going to cut a quarter-inch cube"],[7695,7791,"out of you."],[7829,7900,"Understood?"],[8687,8725,"Alright,"],[8741,8841,"don't just stand there"],[8841,8929,"congratulating yourself."],[8941,9054,"Get started on the salad."],[9441,9504,"No, stop."],[9741,9804,"Start over."],[9854,10050,"I need the best salad."],[12125,12229,"Check this out,"],[12237,12425,"you stinking piece of street meat."],[12491,12654,"This is how a real chef does it."],[12912,13116,"Make sure you're on your A game, people."],[13125,13229,"This is Steven Gordon"],[13229,13325,"we're talking about."],[13429,13554,"Is our risotto ready to go?"],[13837,14016,"It smells wonderful, Bryant."],[14050,14091,"Good job."],[14125,14241,"How long is it gonna take that loser"],[14241,14366,"to finish a simple salad?"],[14404,14454,"Chef Anderson,"],[14454,14591,"I told you that involving him"],[14591,14675,"would slow us down."],[14991,15100,"You might be right, Bryant."],[15200,15316,"Looks like I misread the guy."]],"14":[[1591,1741,"Mr. Gordon, Mr. Cato,"],[1766,1816,"how are we doing?"],[1816,2041,"I expected better from a restaurant"],[2041,2162,"in my own building."],[2212,2404,"I bring a distinguished guest,"],[2412,2600,"hoping to showcase excellence,"],[2600,2829,"and this is what you serve?"],[2866,2962,"How is this possible?"],[3016,3291,"I purposefullly increased the aroma"],[3291,3391,"and the taste of the chicken."],[3391,3550,"The chicken tastes like dirt."],[3729,3829,"However,"],[3929,4004,"I will admit"],[4083,4229,"that your knife work"],[4229,4391,"is quite superb."],[5950,6066,"Oh, Mr. Gordon,"],[6066,6254,"what a surprise to see you here."],[6279,6404,"You know, you ought to come by"],[6404,6470,"some of our"],[6470,6579,"restaurants sometime."],[6587,6737,"I'd hate to see you have to suffer"],[6737,6870,"through yet another of these"],[6870,7029,"stale meals here."],[7050,7216,"How many times do we have to tell you"],[7254,7354,"that we will never"],[7387,7537,"sell you our restaurant?"],[7583,7825,"Who said you need to sell, sweetheart?"],[7891,8037,"I'm gonna buy the lease"],[8054,8141,"to your building."],[8241,8275,"Yeah."],[8337,8412,"Mr. Cato,"],[8475,8725,"I'm willing to pay double the rent"],[8725,8804,"that they're paying"],[8841,9154,"and cover any early termination fees"],[9154,9329,"that may occur thereof, huh?"],[9366,9462,"What the hell's wrong with you?"],[9520,9645,"You're really stooping this low?"],[9687,9950,"My friend, in the restaurant business,"],[9966,10150,"it's a dog-eat-dog world."],[10150,10304,"And if you ain't ahead of the pack,"],[10366,10475,"you get left for dead."],[10579,10708,"Am I right, Mr. Cato?"],[10725,10775,"Huh?"],[11879,12091,"What the hell is this crap?"]],"15":[[0,129,"You're not gonna serve this"],[129,325,"to Mr. Gordon, are you?"],[454,558,"What the fuck"],[558,725,"is wrong with you, Leon?"],[745,875,"Why on earth would you bring out"],[875,962,"a salad now?"],[1237,1420,"Mr. Gordon, our apologies."],[1420,1541,"I believe the salad belongs"],[1541,1625,"to a different table-"],[1625,1754,"Different table?"],[1883,1975,"You're trying to tell me"],[1975,2187,"that somebody else ordered"],[2212,2341,"a generic"],[2341,2554,"run-of-the-mill house salad?"],[2579,2666,"Come on."],[2704,2812,"Would you eat this?"],[2825,2891,"Would you?"],[2966,3041,"Would you?"],[3112,3191,"Would you?"],[3229,3275,"Yeah."],[3341,3416,"That's what I thought."],[3791,3916,"You're not even gonna try it?"],[3916,4016,"Just a nibble?"],[4279,4325,"Really?"],[4462,4662,"Eat it. Eat it."],[4662,4729,"Eat it. - Eat it."],[4750,4975,"Eat it! Eat it! Eat it! - Eat it! Eat it! Eat it!"],[5000,5191,"Eat it! Eat it! Eat it! - Eat it! Eat it! Eat it!"],[5191,5291,"Alright, alright."],[5487,5541,"I'll eat it."],[5941,6095,"Dad, you don't have to."],[6116,6187,"Chef Anderson,"],[6233,6329,"are you serious?"],[6379,6500,"Are you really gonna subject"],[6500,6591,"your taste buds"],[6620,6712,"to this torture?"],[6941,7029,"Mr. Gordon,"],[7066,7295,"just look at this clown show."],[7295,7500,"And they try to impress you"],[7500,7737,"with a mediocre house salad"],[7791,8141,"made by their lowest ranking chef."],[8150,8220,"And then"],[8237,8329,"they fight over"],[8329,8500,"who has to eat it as punishment."],[8512,8550,"I mean,"],[8591,8779,"is this place a shithole or what?"],[8937,9125,"Well, Mr. Anderson,"],[9125,9216,"it does seem like"],[9216,9391,"you have some explaining to do."],[9429,9500,"Mr. Gordon,"],[9541,9737,"I stand by everything we make here."],[9766,9904,"Even a humble salad"],[9904,10066,"made by our most humble chef."],[10104,10237,"I'll gladly eat anything"],[10266,10375,"that comes from our kitchen."],[11145,11204,"Dad."],[12579,12666,"Bon appétit."],[14512,14595,"This tastes"],[15325,15391,"delicious."]],"16":[[41,145,"It's delectable."],[616,704,"Just enough dressing."],[829,1045,"The beets are perfectly portioned"],[1045,1108,"and seasoned."],[1108,1433,"The avocado is rich and smooth."],[1545,1641,"This salad."],[1766,1833,"I'm in heaven!"],[2745,3016,"It's a very good job of acting, Hank."],[3016,3254,"You just made a simple house salad"],[3283,3383,"sound like a"],[3383,3625,"goddamn work of art, huh?"],[3908,4083,"You've made your point, William."],[4112,4191,"Mr. Cato,"],[4233,4470,"I'd expect you to wanna maintain"],[4470,4683,"a certain level of quality,"],[4683,4929,"lest your property value plummet."],[4945,5420,"You can't still want to rent to them"],[5454,5633,"after this catastrophe"],[5633,5729,"of a meal,"],[5800,5841,"huh?"],[7033,7070,"Hold on."],[7133,7233,"Mr. Cato, hold on."],[7887,7933,"William,"],[7995,8116,"I propose a contest."],[8154,8391,"If I lose, I will straight up give you"],[8391,8495,"the entire restaurant."],[8508,8570,"Woah."],[8608,8683,"Woah, Dad,"],[8683,8895,"let's think this over first."],[8904,8958,"Ada's right."],[9045,9179,"Let's not do anything rash."],[9708,9787,"Here are the terms."],[9825,9933,"The winner gets the restaurant."],[10008,10066,"The loser"],[10145,10275,"is gone from the industry"],[10320,10370,"forever."],[10645,10804,"Alright, you got a deal."],[10804,10891,"I love it!"],[10920,10975,"A cooking - Yeah!"],[10975,11029,"competition."],[11058,11170,"Things are getting interesting."],[11212,11295,"Mr. Gordon and I"],[11345,11445,"will serve as the judges."]],"17":[[1512,1687,"I love chef cooking competitions."],[1687,1762,"I can't believe"],[1762,1875,"I get to watch one in person."],[1895,1995,"Yeah, it's crazy"],[1995,2120,"how much they're risking, though."],[2120,2220,"Like, the loser"],[2220,2370,"leaves the industry forever?"],[2400,2533,"At least it adds to the drama."],[2595,2745,"That's Chef Jamie Dawson."],[2758,3000,"The guy's got seven Michelin stars"],[3000,3108,"among all his restaurants."],[3108,3179,"Seven?"],[3262,3300,"Yeah."],[3404,3520,"Chef Dawson is a force"],[3520,3608,"to be reckoned with."],[3666,3833,"I don't know if I can keep up with him."],[3858,4012,"So we're fucked then?"],[4037,4150,"If Chef can't beat him,"],[4150,4245,"which of us can?"],[4412,4537,"Okay, everyone."],[4537,4695,"We're gonna have a competition."],[4695,4870,"We're gonna do best out of three."],[4870,5025,"We're gonna start with knife skills,"],[5025,5333,"and each team gets to pick one chef"],[5333,5400,"for each round."],[5662,5879,"I'm gonna crush these losers."],[5900,6050,"Hey, that's good at least."],[6050,6175,"Bryant's a total wizard with the knife."],[6183,6300,"Yeah, Chef's always complimenting"],[6300,6400,"Bryant's knife work."],[6420,6558,"Got Round One in the bag."],[6658,6720,"Okay."],[6825,6870,"Chef,"],[6925,6987,"I think I got this."],[7262,7300,"Leon."],[7508,7562,"You're up."],[7637,7670,"Dad."]],"18":[[37,87,"Dad,"],[112,245,"you can't send a line cook"],[245,350,"for the first round."],[350,433,"Chef, please."],[450,545,"We should send Bryant up."],[562,662,"You really think"],[700,850,"that I'm not as good as a line cook?"],[1225,1295,"Are you sure?"],[2262,2350,"Why are we putting"],[2350,2458,"the fate of our restaurant"],[2458,2570,"in his hands?"],[2595,2700,"I know what Chef's doing."],[2745,2850,"He's putting Leon up"],[2850,2975,"to test Jamie's skills,"],[2995,3158,"and then we'll have Bryant take over."],[3975,4125,"They sent a line cook up here?"],[4212,4262,"Damn."],[4287,4387,"Didn't think they'd be waving"],[4387,4508,"the white flag already."],[4529,4708,"I'm sorry you're being offered up"],[4708,4908,"as the sacrificial lamb."],[4908,5108,"But hey, at least you're competing"],[5108,5308,"against a seven-star chef, right?"],[5337,5425,"It feels kind of shitty"],[5425,5558,"to put a poor line chef"],[5558,5679,"out on the front line."],[5679,5812,"Yeah, this is gonna be ugly."],[5858,6000,"At least this homeless prick"],[6000,6150,"is gonna get put in his place."],[6208,6275,"Chef Anderson,"],[6325,6475,"you are aware that you are pitting"],[6475,6670,"a line cook against a chef who has won"],[6670,6833,"seven Michelin stars, yeah?"],[6870,6908,"Yup."],[6945,7025,"I've made up my mind."],[7237,7375,"Okay then, Round One."],[7400,7525,"This is gonna be knife skills."],[7537,7712,"And for this, you are going to prepare"],[7712,7912,"a traditional sashimi dish."],[7925,8050,"And your time starts"],[8275,8308,"now."]],"19":[[1975,2150,"I have not seen this in a long time."],[2150,2325,"He's doing the King of Cooking's"],[2358,2600,"double blade icicle slice."],[3375,3550,"It looks just like Mt. Fuji."],[3550,3662,"How's that even possible?"],[5720,5762,"No way."],[5762,5925,"And without popping the balloon."],[5937,6075,"And with a knife that sharp."],[6108,6212,"He's on a whole other level."],[6270,6358,"I mean, the artisty"],[6358,6433,"is just"],[6487,6662,"unparalleled."],[6662,6862,"We are getting a real show from him."],[7670,7762,"Jesus, that's it?"],[7783,7887,"Looks like we're going down."],[8808,9050,"Some chefs put a cloth over the fish"],[9050,9137,"to calm it down."],[9137,9300,"It's such a novice move,"],[9300,9475,"and definitely not anything"],[9475,9712,"that is gonna win a knife competition."],[9733,9800,"Hmm,"],[9837,9970,"I wonder who's gonna win."],[10016,10170,"A seven-star chef"],[10170,10412,"carving Mt. Fuji out of ice,"],[10412,10533,"or a guy who needs to bring"],[10533,10612,"an extra towel"],[10612,10737,"just to hold his fish down?"],[10833,10970,"He must be covering his hand"],[10970,11025,"with that cloth"],[11025,11145,"out of embarrassment."],[11166,11312,"If only he had a bigger cloth"],[11312,11387,"to hide behind"],[11387,11495,"until this round is over."],[11495,11570,"Chef,"],[11570,11620,"we can't even see"],[11620,11737,"what he's doing with the knife."],[11770,11837,"His hands are probably"],[11837,11887,"shaking too much"],[11887,11987,"to make a single cut. - Oh God,"],[11987,12212,"this is so, so bad."],[12400,12441,"Chef,"],[12466,12625,"this rookie's doing a sad magic trick"],[12625,12708,"under a wet rag,"],[12729,12862,"while Chef Dawson is giving him"],[12862,13008,"a seven-star ass-whooping."],[13062,13183,"It should be me out there."]],"20":[[37,154,"It should be me out there."],[183,329,"Did I really screw this up?"],[354,416,"Oh wow,"],[479,629,"he can cut blind, good for him."],[654,716,"Does he really think"],[716,779,"that's going to cut it"],[779,879,"against the King of Cooking"],[879,941,"reincarnate?"],[970,1037,"What do you expect?"],[1075,1166,"The guy's a scrub."],[1166,1216,"It's a miracle"],[1216,1341,"he didn't cut his finger off."],[1354,1429,"Oh, look,"],[1429,1741,"I'm draping a white cloth over my arm,"],[1741,1812,"yeah?"],[1812,1941,"You see what I did there?"],[1991,2129,"Dad, can't you just call him back"],[2129,2175,"or something?"],[2175,2279,"This is embarrassing."],[3825,3991,"That's just insane."],[3991,4108,"That line cook is"],[4108,4212,"dead in the water now."],[4212,4387,"Chef Dawson's definitely gonna win"],[4387,4454,"at this rate."],[6491,6654,"I, I still can't believe"],[6654,6875,"you sent your salad guy"],[6904,7129,"to compete with a Michelin chef."],[7216,7316,"Yeah, you patsy."],[7479,7587,"I was thinking the same."],[7654,7779,"Why the salad guy?"],[7854,7904,"But still,"],[7904,8104,"it seemed like Hank did genuinely"],[8104,8200,"love that salad."],[8350,8379,"So,"],[8504,8562,"Mr. Gordon,"],[8637,8775,"not a bad show I put on there, huh?"],[9133,9179,"Goodness."],[9229,9337,"Mr. Gordon, look!"],[9550,9604,"That..."],[9775,9820,"That's..."],[10104,10229,"impossible!"]],"21":[[416,487,"That fish,"],[487,545,"it's alive."],[595,729,"Impossible!"],[758,1029,"The lost art of Ikizukuri."],[1045,1208,"They serve the sashimi,"],[1233,1395,"without killing the fish."],[1420,1683,"The knife has to be so precise"],[1695,1929,"that the fish's nervous system"],[1929,2154,"doesn't even register the knife."],[2229,2458,"I haven't seen knife skills like that"],[2458,2516,"since..."],[2791,3016,"the King of Cooking."],[3308,3358,"No way."],[3433,3533,"No fucking way!"],[4179,4333,"Who the hell is this guy?"],[4470,4741,"The winner of this round is Leon!"],[6366,6508,"Knife skills are useless"],[6508,6658,"if the food doesn't taste good."],[6658,6804,"If he tries to be a showman,"],[6858,6958,"and not a chef,"],[7004,7183,"he won't even make it as a line cook."],[7245,7316,"Jamie,"],[7416,7520,"what the hell was that?"],[7570,7779,"Do you have any idea how much I paid"],[7779,7879,"to bring you out here?"],[7995,8108,"Alright, Mr. Line Chef."],[8141,8208,"Are you gonna tell us"],[8208,8291,"who you really are?"]],"22":[[16,91,"Mr. Birkins,"],[145,266,"I, I don't have any idea"],[266,341,"what the hell that was."],[341,479,"I swear, I did my best, but-"],[479,633,"I didn't pay you to do your best."],[633,770,"I paid you to win."],[808,904,"And now look at you."],[920,1116,"You got showed up by a nobody!"],[1370,1479,"You lose again,"],[1541,1616,"and you're done."],[1658,1770,"Watch it, William."],[1791,1879,"It's not my fault"],[1895,2045,"that this guy is pulling"],[2045,2108,"some crazy shit"],[2108,2266,"that we haven't seen in years."],[2283,2350,"Trust me,"],[2387,2508,"the next round's all mine."],[2795,2862,"Alright."],[2895,3041,"Welcome to Round Two,"],[3104,3333,"in which we will be doing soups."],[3358,3570,"Again, each team brings one chef,"],[3620,3820,"and you will have 45 minutes"],[3854,3958,"to complete this round."],[3991,4141,"You won't be so lucky this time!"],[4579,4666,"Leon did his job."],[4695,4833,"Now it's time for some real cooking,"],[4845,4966,"and that's where Bryant comes in."],[5004,5045,"Yeah,"],[5045,5254,"those knife tricks were cute and all,"],[5254,5408,"but it's time to bring in"],[5408,5533,"the big guns now."],[5545,5704,"That knife work was foreplay."],[5720,5904,"Cooking is what they all came to see,"],[5920,5979,"and I'm gonna make"],[5979,6141,"the most mouth-watering soup"],[6141,6295,"these idiots have ever tasted."],[6320,6395,"Don't forget."],[6395,6604,"You're facing a seven-star chef,"],[6604,6645,"Bryant."],[6704,6766,"Focus."],[6816,6941,"Chef Anderson, I got this."],[6983,7116,"This is gonna be a walk in the park."],[7204,7404,"As long as I mix perilla oil"],[7404,7491,"with these mushrooms,"],[7516,7645,"their tongues will be coated"],[7645,7741,"with a thin layer,"],[7758,7858,"and no matter what soup"],[7858,7966,"the judges try next,"],[7983,8133,"it'll all taste bland."],[8170,8370,"By the time they try Bryant's soup,"],[8383,8491,"their sense of taste"],[8491,8620,"will be completely shot."],[8783,8820,"Bryant,"],[8879,9008,"I think he's trying something sneaky."]],"23":[[0,120,"I think he's trying something sneaky."],[158,445,"Did I ask for advice from a hobo coach?"],[479,637,"Get back over there and watch me"],[637,820,"whoop some seven-star chef ass."],[1133,1245,"Don't worry, Dad."],[1258,1329,"Bryant's soups"],[1329,1520,"are the creme of the crop."],[1533,1645,"They're what people always mention"],[1645,1783,"in their five-star Yelp reviews."],[4229,4408,"This potato and mushroom soup,"],[4408,4633,"it's so creamy and savory,"],[4633,4770,"and that burst of umami."],[4795,5041,"The the, the oil just covers the palate,"],[5041,5170,"but it doesn't feel greasy."],[5195,5308,"Mm, delicious."],[5308,5366,"Good job."],[5670,5766,"I'm disappointed."],[5845,6066,"A chef of your talent rushing?"],[6179,6295,"You know, good soups take time."],[6370,6608,"You just threw all those oil"],[6608,6708,"and flavors together"],[6708,6833,"without letting them marry."],[8016,8183,"No, no, no, that's not good."],[8412,8554,"Too late, old man."],[8554,8670,"They won't be able to taste a thing"],[8670,8845,"after eating my Unami Bomb."],[9533,9595,"Mr. Gordon."],[9629,9691,"Mr. Cato."],[9745,9875,"Before you try the soup, let me offer"],[9875,10029,"you a lemon water palate cleanser"],[10029,10141,"to refresh your taste buds"],[10141,10220,"between dishes."],[10645,10766,"This fucking pest"],[10766,10883,"knows that lemon acid"],[10883,11016,"will cut through the richness"],[11016,11108,"of my mushroom oil."],[11133,11241,"Who the fuck is he?"],[11258,11458,"What kind of line cook knows that?"],[11466,11620,"Get the fuck out of here,"],[11620,11720,"you street meat."],[11745,11858,"If my soup gets cold,"],[11870,12058,"I'm gonna throw that fucking lemon water"],[12058,12120,"in your eyes."],[12170,12208,"Please,"],[12208,12408,"you can't win this round if they can't -"],[12408,12620,"I can't win this round"],[12654,12770,"if my soup gets cold"],[12770,12891,"while you're interrupting us."],[12891,13020,"Now get the fuck off my stage."],[14570,14629,"Fuck!"],[14708,14745,"Do you know"],[14745,14895,"how badly you just fucked us?"]],"24":[[0,54,"Fuck!"],[83,154,"God, do you know"],[154,308,"how badly you just fucked us?"],[345,395,"Stop!"],[583,745,"Leon is trying to help."],[779,841,"Cut the shit!"],[870,1070,"I am this close to giving this round"],[1070,1154,"to Chef Dawson."],[1904,1945,"Fuck."],[2633,2741,"God, this is sour."],[2970,3075,"Okay, you know what? Forget it."],[3120,3270,"Round Two goes to Chef Dawson."],[3554,3608,"Fuck!"],[3687,3779,"God damnit."],[3829,3920,"You're fucking dead."],[3945,4020,"You're roadkill."],[4066,4354,"You are a rotting homeless corpse!"],[4370,4533,"You fucking asshole!"],[4570,4770,"I had that win fucking locked up."],[4808,4970,"You cost us a win, you dumbass!"],[4983,5120,"He was doing fine without your help."],[5145,5295,"You couldn't just be happy that you won?"],[5295,5445,"You had to sabotage Bryant?"],[5466,5541,"I guess you want us"],[5541,5670,"to lose the restaurant, huh?"],[6133,6320,"I can't believe you did this, Leon."],[6395,6508,"You ruined us."]],"25":[[4,100,"I swear to God."],[100,266,"If we lose this restaurant over you."],[291,441,"Ada should have just let you"],[441,604,"rot on the street."],[1091,1137,"Hey,"],[1250,1404,"I know that was rough just now,"],[1662,1775,"but I saw what you did."],[1816,1916,"Thanks for trying to salvage"],[1916,2041,"that round for us, alright?"],[2504,2604,"Don't think you're so high"],[2604,2687,"and mighty now."],[2775,2941,"Some saw through your tricks."],[2966,3112,"They just couldn't prove it in time."],[3141,3254,"If you'd have lost,"],[3341,3500,"you'd never work in this town again."],[3529,3608,"Yeah, well, I didn't know"],[3608,3691,"they'd have some secret"],[3725,3925,"master chef on their side today, did I?"],[3954,4016,"I'm telling you,"],[4016,4212,"that line cook is not who he says he is."],[4266,4516,"I don't give a shit who he is."],[4529,4712,"We're taking this restaurant today."],[4725,4937,"No mysterious superstar chef"],[4937,5041,"is gonna stop us."],[5129,5316,"The umami bomb oil."],[5354,5454,"That line cook"],[5454,5604,"knew something was going on."],[5675,5866,"How does he always seem to know?"],[6175,6225,"Wait."],[6704,6816,"I gotta try that salad."]],"26":[[0,87,"It's time for Round Three,"],[162,420,"in which we will be doing cold dishes."],[420,600,"Again, each team brings up one chef,"],[625,812,"and you have exactly one hour."],[970,1083,"Will you take care of this for me?"],[1087,1133,"Okay."],[1145,1270,"I have to go get that salad."],[2395,2450,"That's..."],[2512,2620,"Davy Simmons?"],[2637,2808,"The new World Culinary Champion?"],[2837,3000,"Mr. Simmons,"],[3012,3233,"I've been waiting for you."],[3595,3775,"Crowned just last week."],[3900,4025,"He got the perfect score"],[4037,4125,"in the final round."],[4316,4425,"And that's not all."],[4470,4612,"Mr. Simmons"],[4625,4787,"is the King of Cooking's"],[4787,4883,"apprentice."],[5495,5662,"Since when did I have an apprentice?"]],"27":[[29,204,"The King of Cooking has a disciple?"],[233,325,"Mr. Birkins,"],[350,470,"is, is this true?"],[470,554,"Not only that,"],[554,808,"but he has mastered over 90%"],[841,983,"of the King of Cooking's"],[983,1054,"techniques."],[1070,1170,"He's going to be"],[1229,1433,"the next King of Cooking."],[1508,1591,"So what?"],[1620,1670,"I've been working in"],[1670,1779,"kitchens for decades."],[1829,1983,"Experience beats raw talent"],[1983,2108,"every time, kid."],[2291,2408,"Watch it, Bryant."],[2525,2695,"I've always admired the King of Cooking."],[2758,3008,"Facing his successor is an honor,"],[3008,3083,"win or lose."],[3345,3466,"That's very nice."],[3545,3683,"You want to respect me?"],[3766,3945,"Don't make me waste my time competing"],[3945,4129,"against your third-rate chefs."],[4370,4420,"Chefs,"],[4508,4575,"let me give him a"],[4575,4658,"proper ass-whooping."],[5533,5591,"Leon,"],[5662,5804,"this round will decide"],[5804,5920,"our restaurant's future."],[6070,6166,"I want you to fight for us"],[6166,6258,"one last time."],[6304,6395,"Are you serious?"]],"28":[[29,229,"Dad, you're going with Leon again?"],[229,379,"This is the final round."],[404,470,"Chef!"],[504,600,"Bryant's the sous chef."],[629,750,"It should be either you or him."],[766,929,"Leon is just a line cook."],[929,1150,"You have plenty of more qualified chefs"],[1150,1225,"to choose from."],[1241,1479,"Davy is not just a champion."],[1516,1725,"He's the King of Cooking's disciple."],[1754,1954,"Experience alone is not gonna be enough"],[1954,2066,"against someone like him."],[2087,2116,"Dad,"],[2212,2354,"Leon may have knife skills,"],[2354,2541,"but he's not even a real chef."],[2566,2691,"Plus, we lost the last round"],[2691,2754,"because of him."],[3129,3300,"Chef, think this through."],[4216,4325,"So Leon, what do you say?"],[5341,5504,"This line cook's salad"],[5504,5629,"has got to be somewhere."],[6025,6162,"Don't leave me hanging, Leon."],[6179,6350,"I'm putting all my faith in you."],[6554,6600,"Alright."],[6741,6804,"Leave it to me."]],"29":[[350,458,"That Chef Anderson guy"],[458,604,"must have a screw or two loose,"],[604,708,"putting his restaurant"],[708,837,"in the hands of a line cook."],[879,958,"Insane."],[1041,1087,"Chef,"],[1112,1262,"it's not too late to change your mind."],[1283,1420,"Leon might've gotten lucky"],[1420,1616,"against Chef Dawson, but this is"],[1616,1800,"Davy Simmons we're talking about here."],[1841,1958,"My decision is final."],[2233,2475,"Man, this is gonna be such a breeze."],[2487,2608,"Let's spice things up!"],[2670,2737,"Put a little something"],[2737,2800,"on the line."],[2825,3008,"The loser has to lose a finger."],[3533,3587,"Okay."],[3683,3741,"You're on."],[3950,4220,"Does he even know who his opponent is?"],[4220,4325,"When he loses a finger,"],[4325,4450,"he'll never work in a kitchen again."],[4462,4658,"Like it or not, Chef Leon here is"],[4658,4812,"representing our team."],[4845,4962,"He agreed to do this,"],[4987,5145,"so he's got to see it through."],[5183,5358,"What a reckless fool."],[5379,5512,"Let's see if Chef Anderson"],[5512,5595,"still favors him"],[5595,5770,"once he's a four-fingered fuck."],[5845,6033,"This is gonna feel so good"],[6033,6162,"to watch you suffer."],[6183,6400,"I'm gonna teach you not to challenge"],[6400,6604,"the great Davy Simmons!"]],"30":[[562,675,"He's like a machine."],[691,875,"Every move is total perfection!"],[875,1062,"I'm starving just looking at this."],[1187,1287,"Asparagus,"],[1400,1487,"cucumber,"],[1562,1637,"okra."],[1712,1875,"Is he making a French aspic?"],[1900,2112,"Yeah, in the final round?"],[2137,2300,"Might as well hand Davy"],[2300,2400,"the win right now."],[2950,3037,"A cold pasta?"],[3100,3250,"That's the King of Cooking's"],[3250,3337,"signature dish."],[3512,3562,"That's it?"],[3687,3775,"You think you're gonna beat me"],[3775,3912,"with a pile of veggies?"],[4000,4062,"What a fool."],[4212,4375,"Don't tell me he's trying to recreate"],[4375,4600,"the King's White Wolf Heart aspic."],[4629,4700,"Pathetic."],[4762,4950,"If he thinks that he can pull off"],[4950,5175,"the legendary King of Cooking's"],[5175,5275,"masterpiece,"],[5325,5475,"he needs some serious help."],[6837,6950,"That line cook's salad"],[6950,7062,"has gotta be somewhere."],[8100,8187,"That smell."],[8287,8412,"This dressing."],[8425,8537,"Oh, goodness."],[9712,9783,"Oh"],[9866,9950,"my"],[10037,10112,"goodness."]],"31":[[266,341,"Where's Mr. Gordon?"],[1566,1691,"Alright, time's up!"],[3529,3616,"This salad."],[3741,3854,"This dressing."],[3991,4191,"It speaks to my soul!"],[4616,4679,"Mr. Gordon,"],[4741,4804,"Mr. Gordon,"],[4891,4954,"what are you doing?"],[4991,5104,"It's time to go judge the dishes."],[5104,5154,"Let's go."],[5225,5270,"Come on."]],"32":[[312,450,"This chilled pasta."],[1975,2162,"The aroma is so delicate"],[2162,2325,"and the pasta is soft"],[2362,2475,"and springy."],[2662,2887,"This guy is definitely a master."],[2962,3075,"Unbelievably good."],[3237,3450,"I'd pay ten grand for a single bite!"]],"33":[[0,133,"You see this chilled pasta?"],[158,383,"This is my master's signature dish,"],[420,645,"his culinary magnum opus."],[858,1083,"This knockoff French aspic,"],[1095,1283,"it is a joke in comparison."],[1308,1533,"And it's not even a decent knockoff."],[1595,1733,"He over-froze it!"],[1770,1908,"It would be an insult"],[1912,2070,"to the King of Cooking, huh?"],[2108,2158,"Seriously?"],[2158,2295,"This is the best he can do?"],[2345,2420,"Looks less like"],[2420,2545,"a White Wolf Heart aspic,"],[2558,2595,"and more like"],[2595,2745,"a frozen lump of garbage."],[2795,2970,"See, this is what happens"],[2970,3108,"when you treat a homeless scrub"],[3133,3270,"like a head chef."],[3433,3558,"Cut off your own finger."],[3658,3883,"I don't want getting blood on my hands."],[3920,4008,"Pathetic."],[4037,4095,"If I was him,"],[4095,4183,"I'd skip the finger"],[4183,4270,"and just"],[4270,4370,"slit my throat."],[4433,4508,"At least I wouldn't have to"],[4508,4620,"live with the embarrassment."],[4633,4720,"Chef Anderson,"],[4720,4920,"you really are quite the dealmaker."],[4995,5233,"First, you're about to give me the keys"],[5233,5370,"to your very own restaurant,"],[5370,5495,"hand it all over to me."],[5533,5683,"And then you offer"],[5683,5845,"as a free added bonus"],[5870,6058,"your line cook's finger?"]],"34":[[20,66,"Do it."],[125,233,"Cut it off!"],[270,408,"Cut it off!"],[433,558,"Cut it off!"],[570,670,"Cut it off!"],[687,808,"Cut it off!"],[833,933,"Cut it off!"],[933,1033,"Cut it off!"],[1058,1158,"Cut it off!"],[1195,1295,"Cut it off!"],[1320,1420,"Cut it off!"],[1508,1545,"Cut it off!"],[1545,1633,"Cut it off!"],[1658,1745,"Cut it off!"],[1758,1845,"Cut it off!"]],"35":[[645,708,"That's it?"],[750,945,"All that for a cheap party trick?"],[983,1145,"Just a homely little line cook"],[1145,1258,"imitating a legend."],[1333,1433,"Seems like this idiot"],[1445,1570,"peaked in round one."],[1608,1720,"This is so embarrassing."],[1733,1920,"I can't believe I'm in the same kitchen"],[1920,2020,"with this schmuck."],[2033,2108,"He should just quit"],[2108,2245,"before this gets any uglier."],[2245,2295,"Yeah."],[2295,2420,"This fool's running high off of"],[2420,2508,"that first win."],[2545,2708,"He actually thinks he belongs up there."],[2745,2883,"Dad, just call it."],[2895,3070,"Okay, there's no reason to bring down"],[3070,3320,"our restaurant's name with this guy."],[3370,3583,"Look, it is no big shocker"],[3620,3820,"that a line cook cannot recreate"],[3820,4020,"the White Wolf Heart aspic."],[4033,4183,"So, it looks like"],[4183,4395,"I'm gonna have to give round three"],[4483,4558,"to Davy!"],[5308,5358,"Hold on."],[5483,5545,"You still haven't seen"],[5545,5670,"the real White Wolf Heart yet."]],"36":[[2208,2320,"What the hell?"],[2470,2633,"No goddamn way!"],[2733,3020,"The White Wolf Heart aspic."],[3062,3220,"That is the signature dish"],[3245,3408,"of the King of Cooking!"],[3720,3770,"Are you..."],[4058,4383,"Are you the Leon Kennedy,"],[4470,4608,"the King of Cooking?"]],"37":[[41,216,"I really challenged the King of Cooking?"],[279,391,"There is no doubt!"],[429,691,"No one, no one else could do"],[691,891,"the White Wolf Heart aspic!"],[941,1291,"You are the missing King of Cooking!"],[1404,1541,"Leon's the King of Cooking?"],[1654,1804,"No, it's impossible."],[1820,2066,"The Leon Kennedy?"],[2066,2166,"So, the King of Cooking"],[2166,2241,"has been working"],[2241,2404,"in our kitchen all this time?"],[2416,2579,"I never suspected it at all."],[2604,2779,"But who else could make that dish?"],[3116,3166,"Chef Kennedy,"],[3216,3291,"I should have never said"],[3291,3391,"that I was your apprentice."],[3429,3716,"I will cut off one of my fingers, two!"],[3791,4054,"Please, I will do anything!"],[4066,4129,"Please,"],[4154,4212,"just take me"],[4212,4304,"underneath your wing!"],[4341,4466,"Damn phony."],[4479,4741,"You really had me there for a second."],[5079,5179,"Mr. Kennedy,"],[5341,5466,"I've been looking for you"],[5479,5616,"for quite some time."],[5766,5904,"Do you still remember me?"]],"38":[[779,904,"I'm not the King of Cooking."],[1083,1141,"He's dead."],[1291,1329,"What?"],[1354,1379,"What?"],[1466,1504,"Dead?"],[1566,1616,"When?"],[1704,1766,"How?"],[1841,1929,"He's really dead?"],[1991,2079,"It makes sense."],[2079,2279,"He's been MIA for a while now."],[2354,2604,"I've spent my entire fortune"],[2604,2791,"looking for the King of Cooking."],[3116,3354,"And now I'll never get to meet him."]],"39":[[370,425,"Here you go."],[645,908,"And now, we invite to the stage,"],[933,1095,"your King of Cooking,"],[1133,1370,"Chef Leon Kennedy!"],[1433,1495,"Mr. Kennedy,"],[1520,1633,"your wife was in a car accident"],[1633,1758,"on her way to your award ceremony."],[1787,1904,"She's in critical condition."],[1958,2095,"I'm not the King of Cooking."],[2145,2195,"He's dead."],[3508,3558,"Leon?"],[3845,3904,"Leon?"],[4333,4379,"Ada."]],"40":[[45,220,"I wanted to apologize for today."],[383,445,"It's fine."],[500,645,"You took me in off the streets."],[725,808,"Helping the restaurant out"],[808,908,"is the least I can do."],[1366,1425,"What are these?"],[1470,1595,"My father wants you to have them."],[1645,1866,"From now on, you'll be head chef."],[2833,2954,"I look forward to working with you,"],[2991,3062,"Chef Leon."],[4187,4283,"Thank you."],[4308,4395,"How long's the line?"],[4425,4500,"Oh, we have about"],[4500,4650,"twenty parties waiting."],[4650,4775,"Sheesh!"],[4808,4887,"Business is booming."],[4900,5008,"All thanks to Chef Leon."],[5008,5141,"We've never been this booked before."],[5583,5812,"Enjoy it while you can, filthy bum."],[5841,5975,"Your fifteen minutes of fame"],[5975,6079,"is almost up."],[6120,6191,"Bad news, guys."],[6191,6291,"The customers are walking out"],[6291,6350,"mid-meal."]],"41":[[4,100,"Customers are walking out"],[100,158,"mid-meal."],[158,279,"Walking out mid-meal?"],[279,333,"Why?"],[333,383,"I don't know."],[408,470,"Leon,"],[470,612,"someone just leaked a story about you."],[612,683,"It says that you were"],[683,787,"deported from France"],[787,958,"for using illegal ingredients?"],[1333,1370,"What?"],[1583,1745,"Care to explain?"],[1745,1795,"That's me."],[1845,2020,"But I never use illegal ingredients."],[2058,2158,"And I was never deported."],[2191,2295,"So the picture is real,"],[2295,2395,"but the story is fake?"],[2395,2466,"You really expect us"],[2466,2570,"to buy that load of crap?"],[2620,2870,"This is just a misunderstanding."],[2895,3020,"Yeah, let's stay calm."],[3020,3245,"We need to get the full story first."],[3245,3445,"Chef Anderson, he's a homeless drifter."],[3475,3570,"If news gets out"],[3570,3795,"that we let a bum into our kitchen,"],[3820,3941,"customers are gonna start to complain"],[3941,4033,"about food safety."],[4150,4195,"Leon,"],[4295,4420,"at least tell us this."],[4495,4633,"Why were you homeless back then?"],[4812,4883,"I, uh..."]],"42":[[120,183,"I, uh..."],[687,816,"Look, I don't want to talk about it."],[979,1045,"But you have to believe me,"],[1045,1133,"the report is fake."],[1233,1295,"Look at him."],[1383,1520,"He won't even tell us what happened."],[1545,1670,"That should be enough for all of us,"],[1670,1695,"okay?"],[1708,1850,"No wonder he kept his past hidden."],[1883,1945,"And who knows"],[1945,2083,"what other kind of shit he's got up to."],[2112,2170,"He's no better"],[2170,2295,"than that fool Davy Simmons"],[2295,2358,"who pretended to be"],[2358,2458,"the King's apprentice."],[2470,2558,"He's a fraud."],[2570,2683,"Okay, guys,"],[2720,2883,"Leon saved this restaurant."],[2945,3020,"We owe him."],[3045,3145,"We owe him?"],[3225,3345,"He's not the King of Cooking."],[3370,3520,"If this scandal gains traction,"],[3545,3695,"we are all finished."],[3770,3820,"Leon,"],[3933,3983,"I'm sorry."],[4116,4233,"For the restaurant's sake,"],[4233,4333,"I'm going to have to ask you"],[4333,4470,"to take a leave of absence."],[4470,4583,"Whoa, whoa, Dad,"],[4583,4658,"we haven't even"],[4658,4758,"fact-checked this story,"],[4758,4795,"okay?"],[4795,4920,"It's probably just a hit piece."],[4933,5145,"Ada, we know what happened here."],[5162,5320,"Leon got kicked out of France,"],[5345,5433,"and on his way home,"],[5433,5545,"he ended up on the streets."],[5570,5645,"Chef Anderson,"],[5683,5845,"a leave of absence is not enough."],[5845,6008,"If you continue to let him work here,"],[6054,6129,"I quit."],[6162,6204,"What?"],[6233,6320,"Yeah, me too."],[6320,6433,"I'm not gonna let my career"],[6433,6504,"go down the drain"],[6504,6570,"for this place."],[6600,6658,"Damn straight."],[6683,6733,"I'm out."],[6770,6845,"You guys are..."],[6979,7054,"You're quitting?"]],"43":[[33,95,"You're quitting?"],[1095,1145,"I get it."],[1358,1408,"I'll go."],[1558,1608,"Wait."],[1720,1770,"Leon."],[2170,2275,"What a sucker."],[2312,2429,"Good thing we caught that"],[2429,2570,"before it ruined all of us."],[2620,2662,"Ada,"],[2712,2770,"put out a statement"],[2770,2933,"so people know that Leon's gone."],[3029,3166,"That'll stop all the rumors."],[3195,3345,"You'll serve as interim head chef"],[3345,3395,"for now."],[3620,3658,"Okay."],[4345,4420,"I've got a deal"],[4420,4608,"I wanna discuss with you."]],"44":[[45,195,"I've done some digging"],[195,470,"on this so-called line cook."],[883,1016,"Aside from a few"],[1016,1133,"cooking competitions"],[1133,1233,"in France,"],[1320,1445,"he's a complete nobody."],[1512,1595,"I knew it."],[1658,1750,"Urgh! I knew it."],[1795,1945,"There's no way he's the King of Cooking."],[1970,2095,"The real King is long gone."],[2158,2241,"The King"],[2312,2495,"always had a knife at his side."],[2520,2783,"Emerald hilt, Damascus steel."],[2804,2958,"You ever see anything like that?"],[3083,3145,"Hell no."],[3208,3295,"When Ada found him,"],[3320,3375,"he had nothing"],[3375,3550,"but a flea-bitten mutt with him."],[3570,3791,"Just your typical dirty hobo."],[3833,4083,"Then make sure he disappears."],[4591,4654,"Mr. Birkins,"],[4675,4779,"thank you for all your help."],[4820,4970,"Ever need anything in the future?"],[5170,5233,"I'm your guy."],[5283,5595,"You got it, Mr. New Head Chef."],[6070,6195,"Did you really think"],[6195,6320,"that I'd let you walk?"],[6383,6583,"After destroying both my bid"],[6583,6695,"for the new restaurant"],[6695,6808,"and the reputation"],[6808,7008,"of the seven-star chef"],[7008,7258,"that I spent years investing in?"],[7670,7783,"Take care of him."]],"45":[[787,900,"I brought your favorite flowers,"],[900,941,"Sarah."],[2112,2150,"Hey."],[2337,2537,"You know, I thought I could start over,"],[2787,2887,"live a quiet life."],[3083,3275,"That King of Cooking shadow"],[3275,3387,"just keeps following me."],[3712,3837,"If only I could've shed that,"],[3950,4050,"before it was too late..."],[4350,4475,"maybe you'd still be here."],[4687,4791,"Without you here,"],[4866,4987,"Dante's all I've got."],[6095,6216,"Well, well, well."],[6216,6337,"Like he's in the right place,"],[6337,6387,"isn't he?"],[7025,7087,"What do you want?"],[7137,7275,"It's time for you to go to night night."],[7475,7554,"Sleep tight."]],"46":[[66,154,"Dante, run!"],[400,445,"Hey."],[1175,1225,"God."],[1500,1775,"Mr. Birkins sends his regards."],[1979,2075,"Hey, you're gonna die."],[2241,2308,"You motherfucker."],[2429,2487,"My hand!"],[2729,2779,"Dante."],[3012,3104,"You motherfucker."],[3125,3266,"You made me do this."],[3325,3387,"Go to hell!"]],"47":[[208,262,"Let's go guys,"],[262,325,"let's go."],[3104,3216,"Mr. Miller,"],[3358,3629,"all of your obstacles have been removed."],[3654,3908,"You are now on track"],[3954,4179,"to be the next King of Cooking."],[4737,4916,"The King of Cooking's throne is"],[4916,5108,"finally within my grasp."]],"48":[[3233,3383,"I just wanted a simple life."],[3895,3983,"Me and my dog,"],[3983,4083,"free from the kitchen's"],[4083,4220,"power grabs and politics."],[4829,4979,"But they took Dante,"],[5620,5783,"my only companion,"],[6166,6333,"the only thing I had left."],[6850,7083,"And I'm gonna make them pay for it."]],"49":[[1079,1291,"It was at this very competition"],[1291,1416,"that the world witnessed"],[1416,1637,"the greatness of Leon Kennedy,"],[1654,1804,"the five-time champion,"],[1804,1979,"the King of Cooking."],[1979,2104,"His sudden disappearance"],[2104,2329,"left a void in the hearts of his fans"],[2350,2591,"and across the entire culinary world."],[2608,2791,"Ladies and gentlemen,"],[2791,3004,"as the host of this event,"],[3016,3404,"it is my regrettable duty to inform you,"],[3575,3812,"the King of Cooking is dead."],[4220,4479,"His legendary Damascus knife"],[4479,4641,"may be lost to us in time,"],[4666,4841,"but our culinary world"],[4866,5066,"must push forward."],[5137,5466,"Therefore, we revive this competition"],[5504,5733,"as The King of Cooking"],[5733,5845,"Championship,"],[5845,5979,"the winner of which"],[5979,6116,"shall claim the crown"],[6129,6341,"and lead this industry"],[6354,6579,"into a brighter future."],[6679,6804,"Yeah, that all sounds great,"],[6804,7016,"but replacing the King of Cooking?"],[7083,7216,"It's easier said than done."]],"50":[[12,266,"I am proud to introduce"],[266,333,"this year's"],[333,500,"front-running contestant,"],[562,775,"Monsieur Jake Miller,"],[800,1112,"the most formidable chef of our time."],[1137,1200,"Move."],[1700,1804,"The former King of Cooking,"],[1804,1920,"Leon Kennedy's death"],[1920,2087,"is immeasurable."],[2087,2150,"However,"],[2175,2325,"it could be a blessing in disguise"],[2325,2512,"because if he were still here,"],[2512,2650,"it might upset everyone"],[2650,2737,"to watch me beat him."],[3225,3337,"Who do you think you are?"],[3375,3537,"Throwing dirt on the King's name"],[3562,3716,"right as we're paying our respect?"],[3716,3762,"That's right,"],[3762,3912,"you'd better watch your damn mouth."],[4087,4175,"Don't get it twisted."],[4200,4375,"I'm not just after Mr. Kennedy."],[4375,4487,"No, I'm saying that"],[4504,4787,"all of you are nothing but trash."]],"51":[[1979,2033,"Mm."],[2108,2395,"Simply magnificent."],[2408,2508,"This is the winner."],[2533,2658,"Spectacular."],[3045,3200,"Are we sure that Bryant's got this?"],[3220,3283,"That masked man"],[3283,3483,"hasn't lost a single match."],[3483,3595,"Bryant's made it this far."],[3620,3733,"He'll take care of business."],[3745,3845,"That masked chef,"],[3870,4025,"he's not just some amateur."],[4083,4183,"I mean, he's taken down"],[4183,4337,"multiple top-ranked chefs"],[4337,4445,"like it was nothing."],[4470,4541,"Dad, do you think"],[4541,4633,"anyone can beat him?"],[4658,4762,"He's impressive."],[4775,4858,"Even Jake Miller"],[4858,4970,"might not stand a chance."],[5033,5120,"Wearing a mask"],[5191,5295,"like the old King of Cooking?"],[5412,5608,"Must be some Leon fanboy."],[5858,5950,"Well, good for you,"],[5987,6095,"but those days are over."],[6120,6283,"There's a new King of Cooking."],[6445,6541,"Oh,"],[6612,6683,"the last guy who gave me"],[6683,6758,"the silent treatment,"],[6758,6833,"well,"],[6833,6920,"let's just say that things"],[6920,7125,"didn't end up so great for him."],[7408,7483,"Let's get started."]],"52":[[0,225,"This round's key ingredients is"],[354,425,"eggs."],[491,620,"You have 30 minutes."],[650,687,"Go."],[987,1066,"A wok?"],[1125,1158,"Aw."],[1208,1387,"You really starting a street cart"],[1387,1437,"in here?"],[1458,1537,"Doing some street food?"],[1787,1895,"Fried rice?"],[1983,2062,"Seriously?"],[2087,2287,"In a fine dining competition?"],[2300,2375,"Let me just tell you"],[2375,2525,"that my recipes belong"],[2525,2712,"in a Michelin star restaurant."],[2762,2862,"Sevruga caviar."],[2925,3191,"Great ingredients make great chefs."],[3191,3287,"Trashy chefs,"],[3350,3400,"well,"],[3550,3675,"we all know how that goes."],[3900,3995,"Is this guy insane?"],[4029,4137,"He's wasting all of his time."],[4137,4237,"just heating his wok."],[4266,4537,"Chinese fried rice needs a lot of heat."],[4562,4775,"The hot wok crisps the rice perfectly,"],[4800,4887,"keeps it from sticking."],[4887,4975,"He's doing it right."],[4987,5237,"So this masked man is also an expert"],[5237,5337,"in Chinese cuisine?"],[5375,5550,"Bryant, don't underestimate him."],[5575,5683,"Relax,"],[5708,5800,"this guy's an amateur."]],"53":[[12,200,"Flashy tricks don't make a real chef."],[225,337,"Even your fire-breathing"],[337,433,"magical dragon"],[433,525,"can't breathe any life"],[525,712,"into that weak-ass fried rice."],[712,775,"Bryant's right."],[787,895,"He's gonna lose tonight"],[912,1100,"and be back at his street food stall"],[1100,1150,"tomorrow."],[1150,1225,"Exactly."],[1229,1337,"His fried rice can't go"],[1337,1450,"for more than ten bucks,"],[1475,1662,"but Chef Bryant's ingredients alone"],[1662,1775,"cost two grand."],[1837,1975,"Guess my bills are too big."],[2025,2187,"I don't have any pocket change"],[2187,2312,"for your fried rice."],[4550,4612,"Mm,"],[4750,4862,"delicious."],[4937,4987,"Mm."],[5050,5125,"Go back to your little"],[5125,5250,"mom-and-pop food stall."],[5937,6050,"If you fry rice for three years,"],[6050,6200,"you might be able to afford-"],[6200,6291,"Oh my God."],[6887,7012,"This is next level."],[7175,7225,"Mm."]],"54":[[54,116,"Really?"],[116,212,"It's just fried rice."],[212,316,"How good can it be?"],[333,491,"Not the reaction I was expecting."],[516,591,"That's bullshit."],[629,791,"It's just some cheap fried rice."],[887,941,"Let me try some."],[1383,1550,"The aroma, it's..."],[1637,1675,"What?"],[1716,1766,"How?"],[1829,2054,"That rich, eggy flavor."],[2070,2220,"It goes perfectly with the rice."],[2241,2479,"An absolute delicacy."],[2991,3329,"You are the winner of this round."],[3366,3529,"Congratulations."],[4062,4216,"People are like ingredients,"],[4241,4366,"no matter what they're worth,"],[4504,4629,"as long as you give them a chance,"],[4666,4729,"they can shine."],[4808,4904,"Shut the fuck up."],[4954,5091,"Who the fuck do you think you are?"],[5179,5304,"Well, it's funny you should ask."],[5929,6066,"Wait, that's..."],[6116,6166,"Oh..."],[6308,6354,"My God."],[6391,6554,"What the hell are you doing here?"]],"55":[[504,641,"Wait, that's..."],[691,729,"Leon."],[816,891,"I'll be damned."],[1054,1104,"You again?"],[1179,1366,"You filthy street rat!"],[1391,1429,"Hey."],[1479,1579,"Isn't that that chef"],[1579,1629,"who got caught"],[1629,1791,"using illegal ingredients?"],[1816,1966,"Yeah, I thought he got canceled."],[1966,2079,"What's he doing here?"],[2441,2579,"I protest this result."],[2629,2791,"He was banned from our restaurant"],[2791,2904,"from using illegal foods."],[3004,3041,"What's to say"],[3041,3141,"he wouldn't do that today?"]],"56":[[20,145,"I see why you wore that mask."],[170,320,"It's to hide yourself from everyone"],[320,370,"knowing you're that"],[370,508,"disgraced infamous chef."],[533,570,"Yeah."],[633,808,"Don't be fooled by his calm demeanor."],[845,1133,"This guy is a cold, calculated cheater!"],[1133,1170,"Yeah."],[1245,1445,"His presence here is an insult"],[1470,1645,"to real chefs everywhere."],[2345,2570,"We've conducted an official inspection"],[2570,2708,"of Chef Leon's rice,"],[3187,3433,"and it contains no illegal elements"],[3433,3533,"or ingredients."],[3570,3795,"I officially declare Chef Leon"],[3795,3983,"the winner of the semifinal round."],[4070,4295,"He will now move on to the finals."],[4708,4833,"You fucking street meat."]],"57":[[629,679,"Congrats."],[954,1204,"Chef Jake has won his semifinal match"],[1216,1416,"and will advance to the finals."],[1466,1579,"Jake is no joke, man."],[1579,1754,"He's probably one of the toughest chefs"],[1754,1841,"in the game right now."],[1916,2054,"You got your work cut out for you."],[2108,2279,"Be careful in the finals, Leon."],[2333,2504,"William created this whole competition"],[2504,2654,"to push Jake to the top."],[2691,2866,"And now that William knows you're here,"],[3054,3254,"he will do anything possible"],[3254,3366,"to keep you from winning."],[3416,3479,"Let him try."],[3558,3766,"Either way, I'm coming for his head."],[4491,4716,"Useless imbeciles!"],[4741,5041,"I told you to take him out,"],[5079,5316,"not his fucking dog!"],[5391,5716,"Are you even listening to me?"],[5966,6091,"Motherfuckers."],[6416,6704,"That dirtbag wants to come back"],[6704,6829,"and cause trouble?"],[6979,7179,"I'll make him wish that he died"],[7179,7454,"right next to his wife in the graveyard!"]],"58":[[287,450,"After three intense days,"],[450,687,"we're finally at the King of Cooking"],[687,825,"Championship finals."],[875,1112,"It is my great pleasure to introduce"],[1125,1325,"the legendary Japanese chef,"],[1337,1525,"Mr. Mikami Shinji."],[1575,1650,"The famous"],[1650,1812,"chef-turned-food critic,"],[1825,1975,"Steven Gordon."],[2025,2362,"The beloved actress, Maya Swinton."],[2462,2712,"Now let's welcome our first finalist,"],[2725,2900,"the up and coming star"],[2900,3062,"everyone's talking about,"],[3100,3212,"Chef Jake."],[3491,3575,"My boy."],[3925,4050,"And now let's welcome"],[4050,4125,"his opponent,"],[4162,4475,"our second finalist, Chef Leon."],[7062,7150,"Go Leon!"],[7225,7383,"We don't want you here!"]],"59":[[37,237,"So you're that disgraced chef, huh?"],[325,475,"I've seen a few of your competitions."],[487,612,"I'll admit, you got some skill,"],[612,737,"but let's be honest,"],[737,812,"you're never gonna be crowned"],[812,887,"the King of Cooking."],[904,1112,"I could care less what people crown me."],[1112,1175,"Bullshit."],[1237,1387,"Everyone wants to be the best,"],[1437,1537,"and you're no different."],[1575,1662,"The last King of Cooking"],[1662,1775,"was a true God among men."],[1837,1987,"Even the President of the United States"],[1987,2087,"had to beg for his food."],[2225,2312,"In this world,"],[2312,2512,"power brings nothing but suffering."],[4250,4416,"Your King of Cooking,"],[4416,4700,"Leon Kennedy."],[4750,4887,"Sarah!"],[5025,5175,"I just wanted a simple life."],[5275,5350,"Go to hell!"],[5450,5537,"Me and my dog,"],[5537,5637,"free from the kitchen's"],[5637,5700,"power-grabs"],[5700,5787,"and politics."],[5925,6075,"But they took Dante,"],[6287,6512,"and I'm gonna make them pay for it."],[6687,6737,"Suffering?"],[6800,6962,"What the fuck are you talking about?"]],"60":[[12,100,"True mastery is about"],[100,225,"absolute control."],[262,375,"Control over your ingredients,"],[375,550,"over the craft, over your entire life."],[650,925,"True master, feels no pain."],[1037,1250,"To truly test the worthiness"],[1250,1387,"of our two contestants,"],[1412,1575,"today's finals will be tougher"],[1575,1800,"than any round that came before."],[1862,1962,"As we all know,"],[1962,2150,"to be the King of Cooking,"],[2175,2375,"a chef must master cuisines"],[2400,2525,"from all over."],[2525,2750,"So today's final showdown"],[2750,2850,"will be decided"],[2887,3075,"by a single delicacy"],[3075,3312,"from ancient Eastern cuisine!"]],"61":[[29,154,"Tonight's final dish,"],[391,479,"monkey brain."],[966,1041,"Awesome."],[1479,1745,"Ew, that's nasty."],[1775,1904,"Brain? That's horrid."],[1958,2083,"What monsters want to see this?"],[2233,2325,"How about that?"],[2325,2550,"Spare no expense."],[3504,3704,"Let's see what you do with that, Leon."]],"62":[[100,200,"For the finals,"],[325,425,"you're going to be"],[425,650,"cooking monkey's brain."],[1012,1100,"But don't worry."],[1187,1425,"I'll make sure everything goes"],[1425,1537,"according to plan."],[1600,1825,"And the plan is to ruin"],[1825,2162,"Leon's reputation completely."],[2600,2662,"Capisce?"],[2912,2987,"Capisce."],[3241,3312,"Monkey brain?"],[3325,3450,"People actually eat that?"],[3475,3537,"Who cares?"],[3537,3637,"This is great."],[3662,3762,"They're pushing the limits,"],[3787,3887,"testing the chefs,"],[3912,4000,"breaking the rules."],[4037,4162,"This is what being King of Cooking"],[4162,4262,"is all about!"],[4375,4512,"I'm gonna stream the final round,"],[4512,4687,"this shit's about to go viral as fuck."],[4787,4875,"Monkey brain?"],[4912,4987,"That's horrible."],[5050,5150,"What kind of monsters"],[5150,5250,"want to see this?"],[5287,5475,"They're just doing it for publicity."],[5491,5712,"It's shocking, controversial."],[5750,5837,"Makes me sick."],[6100,6162,"Seriously,"],[6162,6337,"what is wrong with people these days?"],[6362,6525,"The internet is destroying"],[6525,6625,"people's morals."],[6700,6762,"That's right."],[6812,6975,"You're a dog parent, aren't you?"],[7012,7112,"Aw, geez."],[7158,7250,"An animal parent like you"],[7250,7325,"could never go through"],[7325,7412,"with something like that."],[7504,7612,"You want me to handle it for you?"],[7700,7800,"That's a living being."],[8025,8137,"Not an ingredient."]],"63":[[16,125,"A living being?"],[175,375,"What a load of horse shit."],[437,475,"Okay,"],[475,662,"a true chef should cook fearlessly"],[662,762,"and push boundaries."],[800,887,"Anything can be turned into a"],[887,987,"delicacy these days,"],[991,1100,"including that monkey."],[1437,1525,"This isn't cooking."],[1525,1625,"This is cruelty."],[1750,1837,"Well, by your standards,"],[1837,2062,"practically all cooking is cruelty."],[2150,2350,"Humans kill animals every day."],[2375,2475,"What makes that any different?"],[2550,2712,"It's not the same."],[2779,2975,"Well, then why don't you"],[2975,3125,"drop out of the competition"],[3125,3300,"and adopt this living being?"],[3300,3437,"Oh my God!"],[3525,3587,"Look at this."],[3675,3775,"It's adoption papers"],[3775,3962,"for the fucking monkey."],[4312,4450,"Need a new pet after what happened"],[4450,4575,"to your little doggie, right?"],[4962,5100,"The people who murdered my dog"],[5212,5387,"are going to pay one hundred times over."],[5437,5512,"Alright then."],[5562,5725,"That's the type of passion I wanna see."],[5887,5950,"Well, Leon,"],[6000,6112,"may the best man win, huh?"],[6783,6945,"It's time to show 'em who's King."],[8350,8512,"Hook, line, and sinker."],[8550,8762,"Welcome to the hell I've built for you,"],[8775,8825,"Leon."]],"64":[[183,333,"Animals' internal organs"],[333,570,"often have strong, unusual smells,"],[608,795,"and monkey brain is no different."],[845,1058,"But Jake has smartly balanced it"],[1058,1383,"with a rich, savory shark fin soup."],[1458,1645,"A tremendous move indeed."],[1695,1833,"In East Asian cuisine,"],[1883,2120,"every part of an animal is utilized."],[2158,2283,"We can make anything"],[2320,2433,"into a delicacy."],[2470,2570,"That's what I admire"],[2570,2708,"about master chefs so much."],[2733,2870,"They take the craziest stuff"],[2870,3045,"and turn it into fine dining."],[3295,3470,"Wait, where's Chef Leon?"],[3533,3633,"Time's running out."]],"65":[[2537,2650,"Fire and ice!"],[2712,2862,"The frozen brain remains"],[2862,2950,"are fresh inside,"],[2987,3125,"while the seared exterior"],[3162,3462,"enhances flavor and cuts gaminess."],[3600,3775,"An old but underused technique"],[3775,3862,"by Chef Jake."],[3912,4037,"Impressive execution."],[4237,4325,"Where's Chef Leon?"],[4550,4637,"Time's running out."]],"66":[[1075,1312,"Chef Jake has now completed his dish,"],[1325,1587,"while Chef Leon has yet to even return"],[1587,1687,"to the stage."],[2475,2587,"I'll just serve you all now."],[2612,2725,"No need to wait for the slowpoke."]],"67":[[458,533,"Immaculate."],[558,620,"Beautifully done."],[620,720,"It's heavenly."],[858,958,"Is there more?"],[995,1133,"I might need another bowl!"],[1683,1820,"Well, it looks like it's a one-man show,"],[1820,1883,"folks."],[1895,2108,"I mean, even if Leon came back now,"],[2108,2183,"there's no way"],[2183,2320,"he can pull off a dish in time."],[2333,2495,"Congratulations, Mr. Birkins."],[2495,2583,"I look forward"],[2583,2683,"to working with you again"],[2683,2745,"in the future."],[2770,2908,"From this night on,"],[2958,3270,"the restaurant industry is mine."],[6470,6583,"Oh my God."],[6758,6858,"Jesus fuck."]],"68":[[1508,1566,"Chef Leon,"],[1641,1708,"what were you doing"],[1708,1816,"screwing around back there"],[1816,1879,"for so long?"],[1879,2066,"You hardly have any time left at all."],[2129,2266,"The key to serving monkey brain"],[2416,2591,"is preserving its natural flavor."],[2945,3041,"No fancy cooking."],[3225,3283,"What?"],[3316,3454,"Just basting it in hot oil"],[3479,3554,"for three minutes."],[4216,4266,"Oh!"],[5654,5904,"Looks like Chef Leon is well-versed"],[5904,6179,"in the ancient art of Eastern cuisine."],[6245,6404,"I can handle raw fish,"],[6454,6591,"but raw monkey brain?"],[6666,6779,"This feels barbaric."],[7629,7879,"The aroma is, is, is primal."],[8254,8329,"What?"],[8354,8483,"That is so crazy."]],"69":[[966,1004,"Oh,"],[1129,1254,"it's fantastic."],[1404,1654,"Not even the finest Japanese sashimi"],[1654,1754,"can compare to this."],[1791,2004,"It is fresh, daring,"],[2054,2179,"and most importantly,"],[2279,2354,"delicious."],[3229,3329,"This feeling,"],[3429,3654,"I'm bursting with electricity!"],[4641,4704,"Did I just,"],[4841,4954,"did I just orgasm?"],[5666,5754,"I have to say,"],[5954,6066,"Chef Leon's dish"],[6091,6241,"definitely takes the cake."],[6629,6741,"Wouldn't you guys agree?"],[6979,7266,"So, by unanimous vote,"],[7316,7379,"the winner is-"],[7379,7466,"Nobody move!"]],"70":[[16,241,"You're all under arrest."],[654,779,"We've received reports"],[779,1029,"of animal cruelty from this location,"],[1229,1404,"as well as the illegal cooking"],[1404,1504,"of bushmeat."],[1529,1729,"I need everyone to cooperate"],[1741,1904,"with our investigation."],[1979,2129,"I have nothing to hide, officers."],[2154,2379,"I am a law-abiding citizen."],[2404,2529,"That's not even a monkey brain."],[2529,2629,"That's lamb brain!"],[2829,2966,"Last I checked,"],[3054,3354,"eating lamb's brain is perfectly legal."],[3729,3779,"However,"],[3841,3954,"as for my opponent, though,"],[3979,4075,"he actually butchered"],[4075,4166,"a live monkey!"],[4191,4266,"What a monster."],[4391,4579,"This ruthless criminal"],[4579,4779,"has no right to be the King of Cooking."],[4779,4954,"Hey, this was a setup."],[4991,5154,"You're just trying to frame Leon."],[5204,5391,"Did I hold a gun to his head"],[5391,5529,"and force him to execute"],[5529,5604,"that monkey?"],[5654,5904,"We all saw what he did, including you."],[6041,6141,"You're under arrest"],[6179,6279,"for the illegal cooking"],[6279,6404,"of wild animals"],[6429,6554,"and for animal abuse."],[6966,7016,"Nice try,"],[7104,7191,"but I saw this coming."],[7529,7654,"I didn't use monkey brain either."]],"71":[[16,166,"Don't try and talk your way out of this,"],[166,204,"okay?"],[216,329,"We all heard that monkey scream."],[954,1091,"That doesn't prove anything."],[1108,1166,"What you cooked"],[1166,1341,"looked exactly like monkey brain."],[1366,1416,"That's right."],[1466,1591,"You slaughtered that monkey."],[1629,1691,"Just admit it."],[1741,1854,"You really are an idiot."],[1891,1991,"That's not monkey brain."],[2129,2204,"It's tofu."],[2279,2329,"What?"],[4241,4404,"I slow-braised the tofu"],[4404,4504,"with a mix of vegetables"],[4504,4679,"and spices to infuse the flavor."],[4991,5079,"Then I sculpted it"],[5079,5191,"to look like a monkey brain."]],"72":[[20,170,"Cooking is about creation,"],[245,320,"not destruction."],[395,458,"And this?"],[595,683,"Not monkey skull."],[833,895,"Coconut shell."],[941,1095,"Oh my God."],[1095,1145,"What?"],[1233,1333,"It's crazy."],[2670,2708,"No."],[2833,2870,"No."],[2933,3045,"No, no, no!"],[3083,3158,"This can't be tofu"],[3158,3258,"because this tastes like"],[3283,3508,"so much more than tofu."],[3587,3658,"You're lying."],[3670,3808,"Sir, we inspected the dish."],[3837,4020,"There's no trace of monkey brains."],[4020,4183,"Both monkeys have been located"],[4183,4308,"in the slaughtering area,"],[4333,4483,"alive and unharmed."],[4545,4708,"That means you broke the rules,"],[4708,4770,"Leon."],[4770,4945,"You didn't use monkey brains,"],[4958,5145,"so you lose, eh?"]],"73":[[0,125,"Give me a break, William."],[150,300,"Your guy broke the rules too."],[300,412,"He used lamb brain."],[450,512,"Okay, well,"],[512,712,"at least I actually used a brain."],[741,866,"Tofu's not even real meat!"],[887,950,"This is a disgrace"],[950,1050,"to the entire competition!"],[1075,1237,"You guys are unbelievable."],[1237,1362,"Rules are rules."],[1362,1495,"And the rules say"],[1495,1708,"that Leon is the loser."],[2137,2300,"Okay, well, technically,"],[2350,2512,"neither of you followed the rules"],[2512,2625,"because neither of you"],[2625,2725,"used a monkey brain."],[2750,2862,"It's interesting though, however,"],[2862,3062,"that you both were able to somehow"],[3100,3350,"find the essence of the theme."],[5212,5375,"We wanted to be very sure here,"],[5462,5612,"so we agreed that the champion"],[5612,5787,"must win by unanimous vote."],[5875,5937,"And now,"],[6050,6150,"we have our decision."],[6975,7137,"The winner of the King of Cooking"],[7137,7312,"Championship is..."]],"74":[[20,183,"The winner of the King of Cooking"],[183,358,"Championship is..."],[1108,1245,"Chef Leon!"],[2595,2645,"No!"],[2795,2933,"This is fucking bullshit!"],[3070,3170,"You guys seeing this thing?"],[3220,3295,"Literally just chose"],[3295,3420,"a piece of flavored tofu"],[3420,3558,"over my perfect dish!"],[3595,3820,"This is a complete travesty."],[3833,4083,"The judges owe us an explanation!"],[4212,4383,"Yeah, this is a real head-scratcher."],[4420,4645,"How does tofu beat real lamb's brain?"],[4970,5083,"The answer is simple."],[5208,5508,"Chef Leon's dish was more masterful."],[5620,5895,"Chef Leon did not just cook tofu."],[5933,6045,"He shaped it,"],[6070,6283,"sculpted into a monkey's brain."],[6345,6508,"And the nooks and crannies"],[6508,6608,"that he created,"],[6645,6820,"perfectly absorbed the flavor"],[6820,6933,"that he introduced."],[7045,7120,"Chef Leon,"],[7233,7320,"how did you do it?"],[7445,7533,"Oh, come on!"],[7620,7695,"He cheated."],[7720,7883,"There is no way"],[7895,7983,"that he was able to do that"],[7983,8095,"in such a short amount of time!"],[8150,8220,"I didn't cheat."],[8345,8458,"I used my own knife."],[9470,9533,"That's..."],[9700,9808,"That's the legendary"],[9820,10008,"King of Cooking's Damascus knife."]],"75":[[50,175,"That's the legendary"],[175,362,"King of Cooking's Damascus knife."],[425,487,"How?"],[525,612,"The, the emerald"],[625,950,"handle, the crystal clear blade?"],[962,1075,"There's only one person"],[1075,1175,"who could have this knife."],[1287,1575,"Are you the Leon Kennedy?"],[2175,2225,"That's right."],[2412,2512,"I am Leon Kennedy."],[2566,2637,"To some of you,"],[2725,2812,"I was just a drifter."],[2925,2987,"To others,"],[3075,3262,"just a washed-out line cook."],[3400,3512,"But who I truly am,"],[3562,3800,"is the long lost King of Cooking,"],[3887,4037,"Leon Kennedy."],[4300,4387,"Oh my God."],[4937,5000,"No!"],[5187,5350,"That's impossible!"],[5462,5537,"Oh God,"],[5575,5737,"all those things I said earlier."],[5779,5862,"I disrespected"],[5862,6125,"the one and only King of Cooking?"],[6262,6400,"We were right to believe in Leon."],[6450,6537,"He's the King."],[6612,6725,"King of Cooking!"],[6750,6875,"King of Cooking!"],[6912,7050,"King of Cooking!"],[7075,7225,"King of Cooking!"],[7241,7387,"King of Cooking!"],[7412,7550,"King of Cooking!"],[7562,7712,"King of Cooking!"],[7737,7862,"King of Cooking!"],[7900,8050,"King of Cooking!"],[8066,8212,"King of Cooking!"],[8237,8412,"King of Cooking!"],[8437,8529,"King of Cooking!"],[8529,8625,"His knife is a fake!"],[8687,8800,"His knife is a fake."]],"76":[[0,125,"His knife is a fake,"],[150,475,"because the King of Cooking is dead."],[525,562,"There's no way"],[562,650,"you could have got your hands"],[650,712,"on his knife."],[725,837,"Where did you get this shit from, huh?"],[850,900,"eBay?"],[912,962,"Paymo?"],[975,1025,"Groupon?"],[1062,1175,"Facebook Marketplace?"],[1187,1250,"For a counterfeit?"],[1366,1500,"Maybe I'll get one myself."],[1712,1812,"What's this we have here,"],[1812,1975,"a King of Cooking imposter?"],[2000,2054,"The King of Cooking's"],[2054,2125,"been missing"],[2125,2212,"for years."],[2225,2325,"You sure you wanna keep up"],[2325,2400,"with this act?"],[2416,2525,"Identity theft is a"],[2525,2612,"federal offense, you know."],[2612,2825,"I could arrest you right here."],[3225,3312,"It's no act."],[3425,3537,"I am the King of Cooking."],[3562,3675,"Only a handful of people"],[3675,3775,"have ever even seen"],[3800,3937,"the King of Cooking's face."],[3987,4050,"Seems to me that"],[4050,4162,"you're trying to take advantage"],[4162,4262,"of his mystery"],[4275,4437,"to try and steal his identity."],[4487,4537,"That's right."],[4537,4775,"And these dirtbags are all in on it too."],[4795,4891,"Arrest them all!"],[5800,5900,"This is Leon Kennedy."],[5912,5975,"Does the President"],[5975,6075,"still want me to cook for him?"],[6562,6687,"Well then, you better send someone here"],[6687,6787,"within the next five minutes"],[6787,6912,"or my offer's off the table."]],"77":[[0,112,"Well then, you better send someone here"],[112,212,"within the next five minutes"],[212,337,"or my offer's off the table."],[600,775,"You really think one little phone call"],[775,825,"is gonna bring"],[825,962,"the White House running?"],[1162,1275,"Who do you think you are,"],[1300,1400,"a world leader?"],[1437,1550,"What a knee-slapper."],[1600,1762,"This guy keeps one-upping himself."],[1800,1912,"You should lock this guy up."],[1912,2037,"He's gonna be the funniest dude"],[2037,2100,"in your prison."],[2225,2325,"Or maybe I should just call"],[2325,2412,"the mental institution."],[2462,2587,"Nutcases might be a little"],[2587,2700,"out of my jurisdiction."],[2837,3012,"I suggest picking that knife back up."],[3937,4050,"This is your last chance."]],"78":[[175,337,"Oh my God, I'll tell you what."],[387,525,"Since you've given us such a good laugh,"],[612,675,"I'll be nice."],[762,862,"Just admit to all these people"],[862,937,"that you're a fraud,"],[937,1275,"and maybe we'll let you walk out of here"],[1275,1387,"with some dignity."],[1437,1550,"Enough of this chitchat."],[1575,1662,"This arrogant fool"],[1662,1762,"isn't gonna admit to shit."],[1775,1850,"Take him away."],[2050,2087,"Three,"],[2137,2225,"Take him away."],[2250,2287,"two,"],[2400,2437,"one."],[2525,2587,"Stop!"],[2841,2904,"What?"],[3912,4187,"I'm Maria Hicks, Chief of Personnel"],[4187,4275,"and Record Management"],[4275,4362,"for the White House."]],"79":[[204,466,"I'm Maria Hicks, Chief of Personnel"],[466,566,"and Record Management"],[566,641,"for the White House."],[904,1054,"A member of the White House staff?"],[1129,1279,"The White House is tuning in?"],[1316,1441,"What an ultimate honor."],[1454,1541,"Ms. Hicks,"],[1616,1716,"what a surprise."],[1741,1791,"Welcome."],[1816,1954,"What the hell is going on here?"],[2016,2141,"Apologies, Ms. Hicks."],[2154,2329,"Apparently we have a fraud in our midst."],[2354,2491,"This homeless drifter"],[2504,2616,"snuck into the competition"],[2616,2729,"and now is claiming"],[2729,2954,"to be the King of Cooking."],[2966,3266,"And who exactly do you think that is?"],[3291,3391,"This clown!"],[3429,3541,"He keeps on claiming"],[3541,3704,"to be the King of Cooking."],[3729,3866,"He's really some drifter"],[3866,4129,"just waving around his fake knife!"],[4154,4241,"But don't worry,"],[4241,4404,"we're just about to arrest him."],[4404,4454,"Him?"],[4891,5129,"Do you have any idea who that is,"],[5129,5204,"you idiot?"]],"80":[[50,162,"Ms. Hicks, please,"],[187,387,"don't take your anger out on us, okay?"],[412,537,"I mean, this is all this dude's fault."],[575,837,"He's just some bum stirring up trouble."],[850,900,"Look at this."],[1037,1162,"He's using the King of Cooking's"],[1162,1262,"Damascus knife,"],[1262,1350,"but it's a knockoff"],[1375,1462,"because he's trying to steal"],[1475,1550,"his identity."],[1575,1679,"Fucking pathetic."],[1712,1970,"Yeah, you waving around that toy knife"],[1970,2037,"knife of yours,"],[2037,2225,"and it fooled everybody, huh?"],[2262,2512,"You fucking line cook, Leon."],[2700,2925,"This dude is not even a cook."],[3050,3137,"Why don't you cuff him"],[3137,3237,"and get him out of here, boys?"],[3262,3525,"Don't you dare!"],[4325,4787,"Do you have any idea what you just did?"]],"81":[[54,179,"You know, if I were you,"],[304,491,"I would shut my goddamn mouth"],[491,616,"from here on out."],[654,854,"Ms. Hicks, what's this all about?"],[1316,1366,"God."],[1454,1491,"Don't."],[1554,1679,"That goes for you too."],[2112,2187,"Why?"],[2229,2304,"Mr. Kennedy,"],[2454,2725,"I am sorry I didn't arrive soon enough."],[2737,2879,"Please, take this back"],[2904,3041,"where it rightfully belongs."]],"82":[[254,366,"Wait, Ms. Hicks,"],[366,554,"did you just call him Mr. Kennedy?"],[591,641,"Are you saying"],[641,879,"this is actually Leon Kennedy,"],[891,1004,"the King of Cooking?"],[1016,1116,"You are clueless."],[1191,1329,"I told you from the start."],[1391,1579,"This guy is the real deal."],[1645,1704,"No, no."],[1754,1816,"This has gotta be"],[1816,1904,"some kind of mistake, okay?"],[1904,2016,"Ms. Hicks, you can't be serious."],[2029,2216,"This dude, he's a total joke!"],[3054,3341,"No one doubts the King of Cooking."],[3716,3795,"William."],[3866,4129,"As for those three assassins you hired,"],[4354,4454,"they've been arrested."],[4541,4779,"Oddly enough, they all named you"],[4816,5004,"as the one who paid them to do it."],[5166,5316,"No, no, no, Mr. Kennedy."],[5354,5404,"She doesn't know"],[5404,5479,"what she's talking about."],[5479,5716,"I never hired anyone to try to kill you."],[5716,5875,"They, they've got no proof."],[5954,6054,"I'm being framed!"],[6166,6254,"This isn't a courtroom."],[6333,6404,"I don't need proof."],[6491,6604,"What I've seen and experienced"],[6604,6716,"is all the evidence I need."]],"83":[[41,141,"What I've seen and experienced"],[154,266,"is all the evidence I need."],[545,616,"Mr. Kennedy."],[787,841,"Mr. Kennedy,"],[866,991,"I was wrong, I was wrong."],[1029,1091,"Fuck, I was wrong."],[1104,1179,"It was all him."],[1204,1279,"It was all him."],[1304,1379,"He did everything."],[1391,1516,"I will testify against him."],[1516,1704,"Let me help you, please."],[1741,2004,"You spineless coward."],[2029,2216,"Don't you ever call yourself"],[2216,2366,"my sous chef again."],[2404,2491,"You're a disgrace"],[2491,2616,"to the entire industry."],[2666,2754,"I'm so embarrassed"],[2754,2879,"to have ever worked with you."],[2954,3204,"Mr. Kennedy, I was set up too, okay?"],[3216,3304,"I didn't mean to offend you."],[3325,3458,"I was forced into this by William,"],[3466,3504,"okay?"],[3516,3579,"He was the one,"],[3579,3716,"he changed the final round's dish"],[3716,3854,"into monkey brain at the last minute."],[3866,3970,"And then he tipped off the cops"],[3970,4054,"because he was trying to bust you"],[4054,4116,"red-handed."],[4141,4304,"I will testify on your behalf,"],[4304,4391,"I swear to God."],[4516,4570,"Alright."],[4641,4804,"William, you're under arrest."],[4916,4979,"Lies!"],[5029,5129,"These are all lies."],[5141,5241,"I'm being framed."],[5258,5416,"If it weren't for you,"],[5470,5629,"I would be the king"],[5629,5779,"of the cooking world!"]],"84":[[0,141,"I would be the king"],[141,304,"of the cooking world!"],[504,554,"Oh, William."],[691,841,"You killed your dream"],[841,954,"of ruling the cooking world"],[954,1116,"when you murdered my dog, Dante."],[1566,1654,"And I was gonna make sure"],[1654,1741,"you were gonna pay for that,"],[1804,1941,"more than you've paid for anything."],[2054,2129,"You have no one left to blame"],[2129,2191,"but yourself."],[2429,2491,"No."],[2520,2629,"Fuck you!"],[2645,3016,"Captain, as for you and your officers"],[3016,3154,"and their treatment"],[3154,3329,"of the King of Cooking tonight,"],[3366,3491,"you'll be reported directly"],[3491,3579,"to the President."],[3666,3704,"What?"],[3766,3841,"Damn it, William."],[3854,4004,"Why did you have to do that to me?"],[4004,4079,"Why are you dragging me"],[4079,4129,"down with you,"],[4129,4216,"you bastard?"],[4291,4354,"Come with me."],[4629,4804,"No, no."],[4841,4975,"No!"],[5416,5591,"So, Leon, what's next?"]],"85":[[279,316,"Well,"],[754,966,"Sarah and Dante are gone."],[1241,1366,"I don't know what to do with myself."],[1479,1516,"Well,"],[1629,1741,"you know, Mr. Kennedy,"],[1879,2104,"the President's previous offer"],[2104,2216,"to make you executive chef"],[2216,2366,"at the White House still stands."],[2604,2754,"Whatever you want, you name it."],[2841,3141,"Salary, benefits, anything."],[3241,3379,"You just talk to me"],[3379,3466,"and we'll work it out."],[3866,4029,"You know, he's not"],[4029,4154,"the King of Cooking anymore."],[4216,4316,"He's our head chef."],[4754,4854,"Tell the President I'm busy."],[4941,5045,"Got salmon to prep."]],"86":[[967,1080,"I'm starved."],[1272,1393,"Thank you for making breakfast."],[1443,1526,"You're welcome, honey."],[2202,2293,"Oh my God."],[2414,2515,"That smells awful."],[2640,2702,"Awful?"],[3111,3211,"Smells fine to me."],[4137,4200,"I think,"],[4379,4529,"I think you're going to be a father."]]}