2,362,"yeah, I"],[379,604,"ruined your jacket in the wash,"],[608,855,"but I'm going to get you a new one."],[909,1030,"That's,"],[1030,1330,"that's actually not why I'm here."],[1413,1526,"Ethan and I"],[1526,1693,"are getting married in 10 days."],[1805,1885,"Married?"],[2114,2235,"I'm pretty sure it's against the law to"],[2235,2352,"marry two men at the same time."],[2352,2464,"We're actually"],[2464,2619,"not getting married."],[2619,2665,"I,"],[2744,3040,"I have this plan for that day, but first, I"],[3044,3174,"need to get back the money that he stole"],[3178,3307,"from our accounts from seven years ago."],[3311,3420,"I just, I can't,"],[3470,3578,"I can't do it alone."],[3628,3791,"Okay, I need you."],[4008,4200,"Look, Moore Enterprises has the"],[4208,4412,"best attorneys in LA, and I want to walk"],[4412,4537,"away from E.M. Company"],[4537,4608,"with everything that"],[4608,4738,"it's taken from me, so,"],[4829,4959,"please."],[5388,5568,"You and Ethan started E.M. Company from the"],[5572,5618,"ground up."],[5797,5960,"I thought it was a labor of love."],[6164,6189,"It..."],[6402,6548,"Not anymore, okay?"],[6623,6806,"Seven years spent with a man who said he"],[6815,6944,"loved me while he siphoned"],[6944,7032,"my assets and"],[7032,7198,"got another woman pregnant."],[7236,7386,"I've been so stupid."],[7444,7586,"She may agree to marry me,"],[7624,7778,"but he clearly still has her heart."],[8216,8320,"What makes you so sure"],[8320,8387,"I would help you after"],[8387,8475,"what you've done to me?"],[8483,8646,"Because you said it yourself, it would be"],[8654,8792,"beneficial for both of us."],[8892,9096,"There is no reason to hold this petty grudge"],[9096,9125,"and..."],[9175,9259,"Petty grudge?"],[9755,9847,"Let me tell you something."],[9851,9980,"Do you know what the three offenses in a"],[9984,10060,"man's life are?"],[10335,10452,"Killing his father,"],[10472,10623,"taking his child,"],[10677,10769,"and stealing his wife."],[10990,11144,"We were never actually married."],[11232,11390,"Well, he stole the promise of a wife."]],"20":[[237,350,"I'm sorry that I bothered you."],[350,458,"I should go."],[462,575,"Maria Carter."],[759,896,"What happened to the Maria Carter that I"],[896,963,"used to know?"],[996,1180,"The one that rejected me seven years ago."],[1192,1322,"The one that said she was going to conquer"],[1326,1388,"Los Angeles."],[1393,1497,"She was fierce like a shark."],[1534,1647,"She wouldn't take no for an answer."],[1651,1864,"Okay, I may have made some bad choices in"],[1868,1968,"love, and it was"],[1968,2106,"stupid of me."],[2131,2264,"But that doesn't mean that you get to"],[2273,2352,"humiliate me."],[2677,2831,"Look, I'm sorry for bothering you."],[2890,2948,"I'm leaving."],[3023,3048,"No."],[3632,3712,"Ethan fired me."],[3762,3799,"Happy now?"],[3920,4087,"Quits acting like you don't care."],[4149,4229,"You've known about me and Ethan"],[4229,4283,"for a while,"],[4283,4346,"haven't you?"],[4450,4521,"Well, yes."],[4546,4617,"Actually,"],[4617,4750,"I am pregnant"],[4775,4884,"with his baby,"],[4884,5105,"and Ethan says that he wants to keep it."],[5138,5280,"I knew that this was coming,"],[5292,5342,"but the way"],[5347,5576,"she shoves her thing with Ethan in my face"],[5584,5701,"is sickening."],[5860,5964,"Tell me,"],[5964,6181,"does it taste good chewing my chewed"],[6185,6385,"up gum, and then bragging about blowing"],[6385,6427,"bubbles?"],[6427,6560,"How pathetic."],[6614,6694,"Ethan denied you"],[6694,6785,"right in front of me, and he"],[6798,6894,"always will."],[6931,7157,"He is never going to choose you over me."],[7157,7232,"Now,"],[7240,7424,"tell me, why did you feel the need to"],[7428,7515,"come and confront me?"],[7532,7595,"Is it"],[7595,7707,"because he's not giving you what you"],[7707,7766,"wanted?"],[7982,8137,"Maria's not going to accept a betrayal"],[8137,8229,"like this."],[8270,8450,"She can't know about us."],[8541,8779,"And you can never talk to her face-to-face,"],[8779,8821,"got it?"],[9225,9484,"Hang tight until the wedding day, and then"],[9505,9663,"you can destroy them both, but for now,"],[9676,9751,"bide your time."],[9872,9939,"Have a great day."],[10239,10364,"She just reminded me."],[10397,10568,"I have to move out of Ethan's house."],[10614,10673,"ASAP."],[11469,11561,"Mrs. Lewis,"],[11599,11749,"hi, it's Grace."],[11782,11932,"Ethan didn't tell you that I'm pregnant with"],[11932,12003,"his baby."],[12157,12312,"The doctor says that I might miscarry."],[12316,12499,"I'm just so scared, and he's always busy."],[12499,12633,"I, I really need your help."],[12708,12921,"That unreliable son of mine hasn't said a"],[12921,12958,"word."],[13025,13175,"I'll be there first thing in the morning."],[13413,13571,"Just you wait, Maria Carter."],[13601,13717,"I'm not letting go that easily."]],"21":[[4925,4984,"Yes."],[5067,5125,"Yes."],[8754,8854,"Where's Maria?"],[8871,9059,"She took everything she kept here."],[9059,9150,"Did she move out?"],[9184,9342,"Mr. Lewis, I don't know."],[9384,9430,"Find her."],[9509,9588,"Now!"]],"22":[[517,604,"I'll help you,"],[633,767,"but there is one condition."],[804,925,"I'll name it later."],[992,1163,"I thought for sure he was going to leave me"],[1163,1247,"high and dry."],[1292,1543,"I wonder what his condition is."],[1705,1826,"This is Moore Enterprise's lead"],[1826,1868,"attorney."],[1901,2043,"Contact him for whatever you need."],[2318,2377,"God."],[2377,2715,"He is so stubborn and confusing."],[2723,3002,"I'm starting to wonder if he actually likes"],[3007,3098,"me, or"],[3157,3315,"is this all just because"],[3315,3495,"of the arranged marriage?"],[3495,3670,"Oh, Maria."],[3849,4049,"Time to move, Maria."],[4087,4337,"The wedding's only days away, and you"],[4341,4471,"need legal advice,now."],[5075,5167,"Let me in, Maria."],[5201,5309,"Or I swear to God,"],[5309,5509,"I'll kick this door in."],[5580,5672,"God, he's gonna wake"],[5672,5768,"the whole neighborhood."],[63