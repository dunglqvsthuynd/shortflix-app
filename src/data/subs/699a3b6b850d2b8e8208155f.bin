uture wife"],[187,475,"is very, very much my business."],[583,675,"No, no."],[792,855,"No, Maria."],[1026,1172,"Come, please, Maria."],[1968,2052,"Wait, wait."],[2106,2273,"Remember what I told you yesterday?"],[2364,2469,"You really meant that?"],[2535,2656,"I was kidding earlier,"],[2686,2848,"but now I'm not."],[2882,3082,"Did you really forget who you belong to?"],[3303,3465,"Or did Ethan really just win you back with"],[3465,3578,"that display just now?"],[3661,3916,"No, he couldn't possibly do that."],[3916,3970,"I-"],[4379,4491,"Maria, where are you?"],[4738,4838,"Come on, Maria!"],[4971,5063,"Maria."],[5125,5288,"He has already won you away from me once."],[5392,5505,"I'm afraid he'll do it again."],[5968,6068,"Maria!"],[6097,6227,"I know you're in there!"]],"67":[[0,112,"Come on, just open this door!"],[112,233,"I need to talk to you!"],[241,379,"Maria, please!"],[1013,1172,"You have no idea what I wanted to do to that"],[1176,1330,"guy every time he put his hands on you."],[1418,1593,"What were you thinking?"],[1614,1747,"I was thinking how I wanted to rip"],[1747,1851,"his arms off."],[1947,2164,"Now I wanted to be the lonely man that"],[2164,2273,"ever touched you."],[2339,2531,"Oh, Alec."],[2602,2777,"And how fucking terrified I am of"],[2777,2865,"losing you again."],[3136,3294,"What am I to you, Maria?"],[3428,3528,"Come on, goddammit."],[3545,3657,"Maria, open this door."],[3661,3832,"I know you're in there with him."],[3832,3903,"I know,"],[3903,3987,"I know he's in there."],[4016,4070,"Come on."],[4149,4191,"Hey."],[4362,4512,"I know you're only in this marriage because"],[4512,4662,"of a family agreement, and I think I've"],[4662,4892,"selfishly used that to bind myself to you."],[4946,5017,"And I regret that you..."],[5017,5226,"Oh, my God, Alec."],[5267,5355,"I want to spend"],[5384,5534,"the rest of my life with you, okay?"],[5534,5697,"I want you to be my husband."],[5697,5730,"I..."],[6026,6181,"I love you."]],"68":[[25,154,"Seven years ago,"],[196,408,"I made the biggest mistake of my life."],[475,650,"But now I got a second chance with you."],[742,975,"Thank you for waiting for me."],[975,1105,"I promise you, I am never"],[1126,1234,"gonna leave you again."],[1889,2022,"Maria, come on!"],[2056,2281,"Please, I just need to talk to you!"],[2302,2348,"No, no!"],[2348,2419,"Maria!"],[2919,3007,"Maria!"],[3086,3148,"Please!"],[3574,3666,"How dare you"],[3666,3741,"come back here!"]],"69":[[291,383,"Careful, sweetheart."],[421,517,"You better be quiet or everyone's gonna hear"],[517,613,"or everyone's gonna hear you."],[654,938,"I cannot believe that you were serious"],[988,1101,"about this."],[1134,1326,"Are you serious that you've never had sex"],[1330,1463,"in a boardroom before?"],[1534,1743,"Never, but I have fantasized about it."],[2064,2160,"What are you doing?"],[2731,2919,"I'm going to make sure all those fantasies"],[2923,2990,"come true."]],"70":[[4,91,"Maria,"],[171,308,"the only thing I want to hear you say"],[308,538,"is my name over and over"],[554,709,"until you fucking scream."],[988,1063,"Alec, I've never..."],[1063,1113,"Shh."],[1213,1326,"Let me be your first."],[2560,2723,"Right there."],[3015,3178,"When you told me to come to your office"],[3182,3382,"yesterday, I thought that you meant you"],[3382,3561,"would actually get some work done."],[3616,3753,"Maria,"],[3774,3987,"I want to make all your dreams come true,"],[4029,4191,"and build new ones with you every"],[4250,4387,"single day."],[4900,4934,"What?"],[4996,5084,"Are you serious?"]],"71":[[517,567,"Well."],[688,825,"Welcome home, Mrs. Moore."],[1297,1547,"Are you sorry that we just eloped and didn't"],[1547,1726,"have some big and fancy wedding?"],[1810,2001,"Haven't you had enough of big, fancy,"],[2001,2102,"crazy weddings?"],[2273,2344,"You're right."],[2982,3036,"Look!"],[4517,4583,"You know,"],[4604,4800,"this always reminded me of the day we met,"],[4817,5013,"and I cannot believe it was seven"],[5013,5084,"years ago."],[5138,5213,"Me either."],[5234,5321,"Why do you think I kept it all"],[5321,5380,"these years?"],[5638,5776,"Because the first time I saw the woman"],[5776,5818,"I loved,"],[5818,5935,"she was playing Pac-Man."],[6147,6206,"So,"],[6231,6410,"you remembered all of those years ago?"],[6564,6702,"You're the only woman I've ever loved,"],[6702,6744,"Maria."],[7574,7699,"Maria Carter, from seven years ago until"],[7699,7832,"Maria Carter, from seven years ago until"],[7836,7999,"this moment, every second,"],[8062,8237,"every minute, every month,"],[8237,8408,"every year, for the rest of our lives,"],[8483,8629,"I'm always gonna love you."],[9050,9280,"I love you, Alec, forever."]]}