"],[3458,3637,"You're a strong, sexy woman."],[3683,3783,"Whatever you do,"],[3783,3912,"just don't go over there"],[3912,4012,"dressed in one of your"],[4012,4141,"church girl outfits."],[4141,4266,"Then what do I wear?"],[4291,4479,"The sexiest lingerie you've got."],[4525,4587,"Gotta go."],[4587,4695,"But text me a pic"],[4695,4816,"if you need a hype man."],[7083,7175,"Too much?"],[7462,7520,"Oh, what?"],[7520,7725,"With your chubby little cheeks"],[7725,7975,"and your cheap-ass dress,"],[7975,8550,"and that, oh, wolfless human stench?"],[8604,8741,"Definitely too much."],[8787,8937,"God, I look like a little kid"],[8937,9029,"playing dress-up,"],[9066,9212,"not an Alpha's fantasy."],[9900,10075,"Oh my God!"],[10125,10412,"I just sexted my ex's Alpha brother!"]],"35":[[83,191,"I need to get to Liam's phone"],[191,295,"before he sees that photo."],[333,379,"Okay."],[1254,1408,"Maybe he hasn't seen the photo yet."],[1429,1554,"Maybe I can sneak in there and-"],[1791,1879,"Oh, Ella..."],[2012,2104,"Ella..."],[2275,2337,"Oh..."],[2358,2429,"Liam?"],[2641,2729,"Oh,"],[2758,2820,"Ella..."],[3208,3362,"Oh, Ella."],[5995,6066,"You know,"],[6191,6283,"you could've knocked."],[6566,6691,"Unless you're enjoying the show."]],"36":[[741,875,"That photo you sent me."],[875,979,"I didn't mean to."],[1108,1204,"So it was meant for someone else?"],[1204,1320,"No, I, it's just,"],[1404,1491,"it's silly."],[1525,1666,"I'm not the type of person,"],[1704,1933,"I mean, I'm not sexy enough to..."],[2462,2629,"In case it wasn't obvious,"],[2687,2816,"it drove me crazy"],[2816,2916,"to think about you coming here"],[2916,2991,"dressed like that."],[3358,3475,"Are you wearing that dress right now?"],[3583,3645,"Yes."],[4862,5091,"How could you ever say you're not sexy?"]],"37":[[562,645,"You have no idea"],[645,775,"how bad I want you, Ella."],[850,970,"The things I want to do to you."],[1429,1495,"Tell me."],[1666,1779,"Admit you want me too."],[1883,2058,"I want you, Liam, please."],[2779,2837,"God,"],[2900,3054,"my brother was the biggest fucking idiot"],[3054,3150,"for rejecting you."],[3187,3287,"I'm gonna do what he never could"],[3287,3395,"and claim you right here."],[3420,3500,"Claim me?"],[3545,3695,"Liam, what are you talking about?"],[3933,4029,"Close your eyes."],[6512,6591,"Ella Wilson,"],[6666,6770,"you are my mate."]],"38":[[120,358,"Liam, is this real?"],[429,550,"As real as you and me."],[900,1004,"You feel it too."],[1100,1166,"Don't you?"],[1291,1379,"I feel"],[1500,1616,"like I want him."],[1641,1804,"Like I need him."],[1829,2054,"But I felt that way about Noah too."],[2104,2250,"And it blew up in my face."],[2350,2454,"I feel scared."],[2491,2604,"I trusted your brother"],[2604,2737,"when he said our bond was real."],[2737,2887,"And he shattered my heart."],[2941,3154,"I won't survive another rejection."],[3187,3425,"Ella, you can trust me."],[3425,3529,"I want to, Liam,"],[3529,3662,"but I still haven't shifted."],[3662,3804,"The whole pack thinks I'm a wolf-"],[4075,4179,"Don't ever"],[4179,4337,"call yourself wolfless, Ella."],[4366,4462,"What the rest of the pack thinks"],[4462,4537,"is irrelevant."],[4562,4654,"It's who you are inside"],[4654,4737,"that matters most."],[4916,5041,"There's still time to shift."],[5116,5166,"But..."],[5329,5479,"even if you never get your wolf,"],[5579,5704,"I'll still choose you."]],"39":[[29,204,"The Crescent Ball, it's in two days."],[241,366,"My official Alpha coronation."],[429,587,"The entire pack is gonna be there."],[629,754,"I'll announce you as my mate."],[791,979,"And I'll prove to you and everyone"],[1004,1191,"that I want Ella Wilson"],[1266,1341,"as my Luna."],[1641,1779,"And then I'll mark you as mine."],[1937,2054,"Remember what I promised?"],[2091,2237,"On the night of Flower Moon,"],[2262,2429,"I'll finally mark you as my mate."],[2691,2841,"Well, let's keep it between us for now."],[2950,3075,"I don't want to ruin the surprise."],[3104,3279,"Noah made the same promise."],[3550,3654,"I would be honored"],[3691,3879,"to be your Luna, Liam Gravens."],[4504,4629,"This time will be different."],[4654,4791,"I prayed to the Moon Goddess"],[4791,4900,"for a mate like Liam."],[4925,5104,"He is not his brother."]],"40":[[1229,1291,"Ella."],[1329,1391,"Get in."],[1429,1533,"I'm driving you to school."],[2870,2933,"Buckle up."],[4483,4708,"Yesterday, I was Ella Wilson,"],[4804,4958,"freshman freak."],[4991,5233,"But today, I'm Ella Wilson,"],[5283,5408,"the Alpha's mate."],[5983,6058,"Are those two"],[6058,6183,"actually together now?"],[6183,6358,"Of course they're not together."],[6358,6545,"Liam wouldn't mate with a wolfless."],[6558,6708,"He would lose his Alpha title."],[6745,6970,"He would never do that for her."],[7108,7191,"You should have kenneled"],[7191,7308,"that little lap dog!"],[7366,7604,"You are so useless, Noah."],[8341,8404,"Sabrina."],[8445,8541,"Liam needs you."],[8608,8691,"Now."],[8716,8808,"Already on my way."]],"41":[[1583,1779,"She's from the oldest, purest"],[1779,1870,"witch bloodline."],[1891,2095,"She's basically like a princess."],[2108,2195,"Hey, baby."],[2258,2354,"Did you miss me?"],[2408,2495,"Sabrina, I"],[2633,2779,"didn't expect you back so soon."],[2808,2970,"She's probably just an old friend."],[3008,3191,"If she was anything more,"],[3191,3308,"Liam would have told me."],[3358,3420,"Wouldn't he?"],[3495,3683,"As if I'd miss the Crescent Ball."],[3729,3795,"If I wasn't here,"],[3795,3895,"who would go as your date?"],[4308,4416,"Noah was right."],[4445,4545,"Liam's throwing away"],[4545,4720,"his legacy for a wolfless."],[4733,4858,"Remember your promise"],[4883,5054,"that we'd rule this pack together?"],[5108,5220,"I'm late, I have to go."],[5270,5320,"Liam!"],[5370,5558,"I have to talk to you about something."],[5570,5695,"It's important."],[5808,5958,"Just make it fast."],[6020,6145,"He might have his sights set"],[6145,6270,"on that defect now,"],[6295,6354,"but that's nothing"],[6354,6529,"a little witchcraft can't fix."]],"42":[[0,133,"Just make it fast."],[770,950,"Oh, watch where you're going,"],[950,1025,"wolfless."],[1025,1162,"Ava, leave me alone."],[1183,1250,"Or what?"],[1320,1495,"Now that Alpha Liam's new girlfriend"],[1495,1562,"is back,"],[1562,1737,"I doubt he'll waste another minute"],[1737,1912,"on a whiny mutt like you."],[1941,2025,"Girlfriend?"],[3012,3162,"I know what you're trying to do here."],[3195,3250,"And I won't let you"],[3250,3345,"sabotage me and Liam"],[3345,3487,"just because you're both jealous."],[3737,3800,"Jealous?"],[3887,4145,"Our family has a no wolfless rule."],[4187,4487,"Us Gravens brothers can't mate defects."],[4600,4745,"We can fuck them, no problem."],[4762,4883,"But if you have dreams"],[4883,5095,"of being Liam's mate, his Luna,"],[5137,5270,"you might as well give up now"],[5270,5454,"and save yourself the embarrassment."]],"43":[[158,341,"The Crescent Ball, it's in two days."],[370,495,"I'll announce you as my mate."],[616,754,"And then I'll mark you as mine."],[808,954,"Just because you're his brother"],[983,1120,"doesn't mean you understand Liam"],[1120,1195,"like I do."],[1195,1354,"You don't know what he promised me."],[1391,1566,"And you don't know"],[1566,1695,"what he promised Sabrina."],[1779,1833,"Do you?"],[1920,2004,"Him and Sabrina"],[2004,2195,"have been a thing for years."],[2245,2391,"And they made a vow to each other."],[2445,2620,"If they both don't mark their mate"],[2620,2795,"by tonight's Crescent Ball,"],[2920,3179,"then he's gonna take her as his Luna."],[3179,3316,"You and Liam could play"],[3316,3470,"boyfriend-girlfriend all you want,"],[3508,3766,"but everyone knows he won't mark you."],[3816,3966,"He's just stringing you along"],[3966,4129,"until he finds someone better."],[4579,4783,"It's what us Gravens Brothers do best."]],"44":[[4,200,"Oh, you really thought"],[200,450,"Liam wanted you, didn't you?"],[512,679,"Why would an Alpha like him"],[679,954,"choose a pathetic defect"],[991,1079,"over one of the most"],[1079,1316,"powerful wolves alive?"],[1341,1600,"Liam is playing you."],[1637,1841,"Just like his brother did."],[2087,2291,"You're nothing to him."],[2391,2516,"He's not playing me, he's-"],[2516,2666,"He's, he's what?"],[2691,2750,"Huh?"],[2854,2987,"Where is he now?"],[3112,3400,"If he's so into you?"],[4187,4316,"I never should have let myself"],[4316,4416,"fall for Liam."],[4416,4550,"He's made it clear all along"],[4550,4779,"that I was never a real option."],[5100,5229,"What did you want to talk about?"],[5437,5562,"Isn't it obvious?"],[5629,5741,"Now that we're both back,"],[5741,5904,"we can finally be together."]],"45":[[991,1183,"I'm not dating anyone"],[1241,1383,"who's not my fated mate."],[1629,1783,"Ugh, why does he have to"],[1783,1945,"make everything so difficult?"],[2508,2691,"That spell will bring him back to me."],[2904,2958,"Sabrina,"],[3083,3241,"I've missed you so much."],[3829,3970,"I've missed you too, baby."],[4033,4195,"I've been so naive."],[4233,4416,"Of course he never wanted me."],[5129,5308,"Noah, she's on her way."],[5329,5383,"Good."],[5445,5533,"I'll be waiting."]],"46":[[216,350,"Maybe Sabrina's return"],[350,500,"was the wake-up call I needed."],[541,666,"To see that Liam and I"],[666,791,"can never be together."],[1654,1825,"You lying little slut."],[1841,1945,"Pretending to be innocent"],[1945,2075,"all these years?"],[2091,2279,"How dare you reject me?"],[2691,2816,"I tried to play nice,"],[2816,2941,"but I could smell my brother"],[2941,3066,"all over you."],[3100,3362,"His scent inside you."],[3537,3654,"Did you enjoy"],[3654,3841,"having both Gravens want you?"],[3866,4079,"Was this your plan all along?"],[4116,4329,"To have me crazy with jealousy?"],[4366,4487,"Get off of me!"],[4487,4562,"You're sick."],[4750,4829,"I bet you've been"],[4829,4979,"with over half the campus."],[4991,5112,"How many besides my brother?"],[5112,5179,"How many?"],[5225,5300,"None."],[5325,5479,"But having never been with you"],[5491,5641,"is the one I'm most proud of."],[5904,6025,"He hasn't marked you yet."],[6054,6100,"Good."],[6116,6241,"Because that's what I'm gonna do."],[6266,6350,"Mark you!"],[6350,6437,"Ruin you!"],[6450,6629,"Make sure no wolf ever touches you!"],[7216,7412,"Liam, help me!"]],"47":[[258,433,"Liam, help me!"],[595,733,"What the hell are you doing?"],[858,920,"Ella."],[1020,1141,"Forget about her."],[1183,1341,"You and I belong together."],[1379,1654,"A strong Alpha and a powerful witch."],[1758,1954,"We broke up, Sabrina."],[1983,2129,"I'll never be with you."],[2245,2408,"Sleeping with that defect mutt?"],[2429,2483,"Fine."],[2508,2641,"But you know better than anyone"],[2641,2808,"that your pack would never accept"],[2808,3020,"a lowly wolfless as Luna."],[3070,3233,"Never call her wolfless again."],[3266,3383,"She has a name."],[3408,3604,"It's Ella Wilson."]],"48":[[345,433,"Get off of me!"],[462,612,"I said get off!"],[1279,1379,"My wolf!"],[1904,2054,"You're too weak to shift."],[2116,2287,"Too weak to fight me."],[3408,3516,"Get your fucking hands"],[3516,3604,"off of Ella!"],[4062,4216,"You are no brother of mine."],[4237,4341,"How can you defend her?"],[4366,4491,"She's been playing us all along."],[4512,4587,"She's nothing."],[4587,4650,"Look at her!"],[4716,4791,"One more word"],[4791,4891,"and they won't find enough of you"],[4891,4979,"to bury!"],[5225,5316,"Enough, Liam."],[5354,5441,"I'm fine."],[5791,5900,"Ella's not nothing."],[6091,6187,"She's my mate."]],"49":[[16,104,"She's my mate."],[716,841,"I started to shift"],[875,991,"and the Moon Goddess"],[991,1104,"gave me another mate."],[1104,1216,"That's impossible."],[1216,1329,"She was my mate."],[1337,1487,"Liam, think about what you're doing."],[1525,1616,"You'd throw it all away"],[1616,1750,"just for one night with her?"],[1750,1904,"You could have every wolf you want!"],[1941,2079,"It was never just one night."],[2312,2387,"Not for me."],[2516,2704,"No one's ever chosen me before."],[2766,2866,"Not once."],[2937,3079,"I will choose you over everything."],[3291,3366,"Every time."],[4329,4454,"If you touch her again,"],[4454,4666,"if you so much as look in her direction,"],[4666,4787,"I won't stop at a few cuts"],[4787,4904,"and bruises next time."],[4929,5212,"Brother or not, I will end you."],[5254,5375,"Oh, no."],[5375,5429,"Please!"],[6237,6350,"You are no longer a part"],[6350,6454,"of the Crescent Pack."],[7079,7137,"Ella."]],"50":[[629,729,"This keeps happening"],[729,879,"every time I almost shift."],[1004,1129,"It means your wolf is powerful."],[1404,1579,"Or it means I'm not strong enough."],[1891,2004,"Ella, you're my mate."],[2116,2229,"And you're the strongest person"],[2229,2287,"I know."],[2379,2554,"Do you really want me to be your mate?"],[2654,2791,"Because it looked like"],[2791,2916,"Sabrina and you were kissing"],[2916,3050,"right after you were kissing me."],[3129,3212,"No, I didn't kiss her."],[3212,3279,"I swear on my life."],[3279,3466,"I was under her spell"],[3466,3625,"and your voice broke it"],[3625,3729,"before she could touch me."],[3887,4016,"Liam, I was there."],[4054,4204,"Your lips were on hers."],[4237,4341,"I'm not stupid."],[4375,4512,"Just be honest with me."],[4512,4629,"If you'd rather take Sabrina"],[4629,4716,"as your Luna,"],[4741,4841,"then tell me."],[4866,5004,"Ella, you know what you mean to me."],[5004,5154,"And Sabrina was never my mate."],[5325,5387,"I know you thought"],[5387,5491,"I was as bad as my brother and..."],[5650,5741,"I don't blame you."],[5791,5941,"But I know how badly he hurt you,"],[5941,6054,"and I would never betray you"],[6054,6125,"like he did."],[6300,6466,"I'm sorry I let Sabrina get between us."],[6529,6654,"I won't make that mistake again."],[6716,6825,"She means nothing to me."],[6825,6912,"She never has."],[6962,7066,"But you, Ella,"],[7404,7504,"you're my world."]],"51":[[491,591,"The whole pack already"],[591,654,"loves Sabrina"],[654,870,"and I'm still fighting to find my wolf."],[879,908,"Do you-"],[929,1054,"Do you really think that"],[1054,1166,"the pack will accept me"],[1166,1241,"as your Luna?"],[1354,1495,"Do you hear what I'm saying, Ella?"],[1570,1708,"I don't love Sabrina."],[1795,1870,"And you,"],[1933,2083,"you're getting stronger every day."],[2116,2279,"Who cares what anyone else thinks?"],[2333,2429,"I would give it all up."],[2579,2783,"My name, my bloodline,"],[2858,2958,"just to be with you."],[3120,3291,"Even if we were rogues, we'd survive."],[3370,3458,"As long as we're together."],[3608,3666,"Liam,"],[3741,3866,"if you step away from the pack,"],[3866,4054,"I don't know if I'd ever forgive myself."],[4133,4258,"The wolfless who led you"],[4258,4358,"to lose everything."],[4358,4545,"Hey, don't ever call yourself that again."],[4608,4795,"You are mine, Ella."],[4895,4991,"And I'm yours."],[5158,5279,"But if you don't want this,"],[5383,5495,"if this scares you,"],[5616,5683,"tell me now."],[5920,6045,"I am scared, but..."],[6166,6383,"I want to be with you no matter what."],[6458,6558,"I'm the Alpha."],[6666,6845,"And the pack will accept my mate."],[7016,7083,"Tomorrow night"],[7108,7220,"at the Coronation Ball,"],[7308,7408,"I'll mark you as mine."],[7508,7591,"But for now..."]],"52":[[466,616,"Do you know how badly I want you?"],[812,1091,"I love your smell, and taste."],[1179,1316,"I need more of you, Ella."],[1366,1504,"I need you all over me."],[1675,1766,"You can have me."],[1804,1891,"All of me."],[1925,2037,"Take me, Liam."],[2079,2154,"Please."]],"53":[[1875,1937,"Remember you said"],[1937,2062,"this would never happen again."],[2187,2308,"I didn't mean it."],[2362,2475,"I've wanted this to happen"],[2475,2595,"since the other night."],[2637,2800,"I was just afraid you didn't want me."],[3383,3462,"I want you, Ella."],[3562,3637,"Forever."],[4708,4800,"The closer we get,"],[4800,4937,"the stronger you become."],[4987,5095,"I want you."],[5095,5208,"All of you, please."],[5208,5295,"Don't hold back."],[5395,5450,"Never."],[6600,6675,"Liam."]],"54":[[591,816,"She's not wolfless after all."],[887,962,"Ella's..."],[1012,1116,"the Enigma Wolf."],[1154,1266,"She's too powerful."],[1325,1450,"It's time to take that bitch down."],[1641,1716,"Ew."],[2454,2604,"Your pack mark is darkening."],[2766,2912,"That means your wolf is rising."],[3279,3404,"Thank goddess the Crescent Ball"],[3404,3466,"is tonight."],[3779,3941,"I can't wait another day to mark you."],[4279,4375,"I can't believe"],[4375,4525,"that just a few days ago"],[4541,4716,"your brother was rejecting me, and,"],[4716,4941,"and now I'm becoming"],[4941,5050,"your Luna tonight."],[5162,5279,"I'm nervous."],[5379,5491,"This is where you were always"],[5491,5566,"meant to be, Ella."],[5729,5791,"With me."],[5954,6087,"Nothing can break our bond now."],[6562,6600,"Son,"],[6600,6691,"get down here now!"],[6787,6916,"What is my father doing here?"]],"55":[[33,170,"What is my father doing here?"],[233,370,"He retired to the outer woods"],[370,483,"like a month ago."],[533,666,"That's why he left the pack to me."],[683,816,"Is everything okay?"],[829,1016,"Yeah, I'm sure it's fine."],[1058,1108,"Here."],[1254,1370,"You start getting ready for the ball."],[1466,1566,"I'll see you later, okay?"],[2558,2683,"According to a witch's prophecy,"],[2683,2795,"the Enigma Wolf has risen"],[2795,2883,"in the Crescent Pack."],[2916,3008,"Enigma Wolf?"],[3054,3283,"From the stories we used to scare pups?"],[3304,3420,"When I was 13."],[3420,3633,"one tore through Pine Ridge Pack."],[3716,3858,"Ripped their Alpha in half"],[3858,4020,"before anyone could even howl for it."],[4145,4341,"We must end her before she shifts."],[4383,4629,"Once she becomes the blue giant wolf,"],[4708,5041,"all we can do is beg for mercy."],[5233,5283,"Her?"],[5420,5533,"How do we identify her?"],[5591,5666,"Blue birthmark."],[5804,5920,"Crescent shaped."],[6133,6258,"Hidden somewhere on her body."],[6404,6570,"Ella is a killer wolf?"],[6683,6795,"That's impossible."],[6841,6916,"What witch has told you"],[6916,7004,"about this prophecy?"]],"56":[[183,262,"You can't trust her, Dad."],[262,337,"She's a liar!"],[337,475,"And I can trust you?"],[520,625,"Liam, you kicked your own brother"],[625,708,"out of the pack."],[708,825,"He assaulted an innocent woman."],[825,937,"He deserved worse!"],[945,1095,"I trusted you with this pack."],[1137,1245,"But I'm starting to think that"],[1245,1345,"that was a mistake."],[1383,1533,"You need to remove the threat or-"],[1575,1708,"Or what?"],[1712,1900,"Or I'm re-initiating your brother."],[1925,2050,"And make him the Alpha."],[2083,2150,"My brother?"],[2208,2362,"The wolf who broke my mate's heart,"],[2387,2500,"who tried to kill her."],[2537,2650,"I can't let that happen."],[2708,2825,"How do we stop the Enigma Wolf"],[2825,2895,"from shifting?"],[3125,3225,"Find her mate."],[3275,3412,"And break their bond."],[3470,3633,"Before they can mark each other."],[3787,3862,"The Enigma Wolf"],[3862,4075,"only shifts after they've been marked."],[4087,4183,"Once this happens,"],[4225,4425,"their power becomes unstoppable."],[4450,4633,"Not even the strongest Alpha"],[4633,4737,"or the most powerful witch"],[4737,4820,"could kill her."],[4987,5220,"If I mark Ella, I lose her forever?"]],"57":[[733,845,"You need to break your bond"],[845,933,"with Ella, Liam."],[958,1066,"Don't touch me!"],[1066,1166,"You're lying!"],[1183,1295,"You're wrong about her."],[1366,1433,"Am I?"],[1529,1637,"You saw her birthmark,"],[1645,1737,"didn't you?"],[1879,2008,"Sleeping with that pathetic girl?"],[2070,2129,"Fine."],[2179,2333,"But is marking her really worth"],[2333,2483,"the lives of your whole pack?"],[2583,2729,"That's why I came back here, Liam."],[2866,2958,"To warn you."],[3033,3141,"Break up with her."],[3195,3433,"Choose me as your Luna tonight instead."]],"58":[[600,687,"Oh my god."],[725,837,"Sabrina's here."],[870,945,"Rumor has it"],[945,1150,"Alpha Liam's gonna make her Luna"],[1150,1250,"of the Crescent Pack."],[1325,1495,"I thought he was with Ella Wilson."],[1512,1612,"The wolfless?"],[1645,1775,"There's no way she shows up"],[1775,1887,"looking more like a Luna than..."],[3362,3525,"Which Alpha's daughter is that?"],[3562,3683,"I don't recognize her."],[3775,3920,"Must be one of the royal packs."],[3950,4075,"She's even more beautiful"],[4075,4137,"than Sabrina."],[4700,4779,"You look..."],[4870,4925,"stunning."],[5187,5295,"She's so sweet."],[5295,5400,"So perfect."],[5425,5500,"There's no way"],[5500,5662,"she's the deadly wolf Sabrina claims."],[5825,5970,"Am I imagining things"],[5970,6150,"or does Liam look"],[6212,6308,"distracted?"],[6933,7000,"You said my brother"],[7000,7145,"was gonna dump that bitch."],[7183,7300,"I'm working on it."],[7412,7495,"Don't worry."],[7537,7612,"By the end of the night"],[7612,7775,"I will be his mate,"],[7845,8012,"and you can have your way with Ella."]],"59":[[50,229,"Ladies and gentlemen,"],[254,516,"it is time to officially crown"],[516,725,"our new Alpha."],[979,1129,"If you don't reject Ella"],[1129,1279,"and announce me as your Luna,"],[1279,1391,"I will tell everyone here"],[1391,1491,"what she really is."],[1491,1579,"A killer."],[1612,1729,"She won't make it out of here alive."],[2216,2387,"I thought he was done with Sabrina."],[3779,3991,"I'm honored to serve this pack as Alpha."],[4104,4266,"But I won't be a truly great leader"],[4350,4604,"until I have a strong, worthy Luna"],[4641,4716,"by my side."],[5104,5204,"Ella Wilson,"],[5350,5454,"will you please join me on stage?"],[5979,6079,"There's no fucking way"],[6079,6279,"I'm gonna let her be Liam's Luna."]],"60":[[1150,1279,"I refuse to let Sabrina"],[1279,1400,"and her stupid prophecy"],[1400,1479,"decide for me."],[1479,1587,"Ella's my mate."],[1629,1729,"Whatever happens next,"],[1729,1812,"we'll get through it"],[1812,1866,"together."],[1866,1954,"I present to you"],[2025,2166,"the Luna of the Crescent Pack."],[2166,2216,"Speech!"],[2216,2266,"Speech!"],[2275,2329,"Speech!"],[2329,2379,"Speech!"],[2379,2429,"Speech!"],[2437,2491,"Speech!"],[2787,2916,"Remember how strong you are."],[2941,3025,"You've got this."],[3904,4066,"Thank you for this honor."],[4129,4266,"I know I'm not the girl"],[4266,4416,"you expected to see up here."],[4479,4641,"I'm probably the first wolfless"],[4641,4750,"to become Luna."],[4825,4891,"Wolfless?"],[4941,5062,"Did she say wolfless?"],[5575,5754,"For too long, I've been pushed aside"],[5754,5929,"and made to believe I'm nothing."],[6016,6166,"But I'm standing here today"],[6166,6391,"not because of what I lack,"],[6537,6687,"but because of who I am."],[6991,7212,"A great Alpha once told me,"],[7304,7504,"it's who you are that matters most."],[7812,7929,"Thank you for helping me"],[7929,8116,"become the person I am today."],[8337,8412,"Stop!"],[8504,8600,"She's lying!"],[8600,8741,"She's not wolfless!"],[8791,8916,"She's the Enigma Wolf"],[8916,9075,"and she'll kill all of us!"]],"61":[[33,220,"She's a disaster waiting to happen."],[295,408,"For the good of the pack,"],[408,495,"we must kill her!"],[658,725,"Ella!"],[762,825,"Stop him!"],[875,1000,"He can't mark her."],[1020,1150,"If they complete the bond,"],[1150,1283,"she'll become unstoppable."],[1283,1437,"She'll be unstoppable."],[1437,1512,"No!"],[1895,1975,"No!"]],"62":[[675,729,"Liam!"],[787,837,"No."],[879,937,"No."],[1004,1050,"No."],[1104,1154,"No."],[1304,1466,"Please, wake up, please."],[4558,4662,"A Witch's wound"],[4662,4812,"should be deadly for wolves."],[5179,5241,"Mom?"],[5600,5766,"Stop spreading lies!"],[5829,5979,"The Enigma Wolf's power"],[5979,6125,"becomes uncontrollable"],[6125,6229,"when they are forced"],[6229,6416,"to separate from their mate."],[6466,6654,"But when the Enigma Wolf"],[6654,6804,"finds their mate,"],[6854,7150,"they gain immense power together."],[7250,7450,"Your bond healed him."],[7554,7641,"You saved me."],[7766,7829,"My mate."],[7954,8012,"My Luna."],[8266,8416,"I'm sorry I ever doubted you, son."],[8466,8566,"You have good instincts"],[8579,8679,"and you'll make a great Alpha."],[8754,8966,"And you, you've got spirit, girl."],[9004,9162,"Exactly what our pact needs."],[9566,9679,"It is my great pleasure"],[9679,9916,"to toast to my son, Liam Gravens."],[9950,10125,"The Alpha of Crescent Pack."],[10237,10379,"I couldn't lead you all without Ella."],[10554,10641,"My Luna."]],"63":[[162,250,"And you two..."],[512,641,"Drop them in rogue territory."],[654,841,"What happens next is up to our enemies."],[841,991,"But Dad, I'm your son!"],[1054,1212,"You are no child of mine."],[1691,1766,"Ella, please!"],[1791,1887,"I'm sorry for everything"],[1887,1954,"I did to you!"],[1954,2087,"I never should have rejected you!"],[2116,2266,"It's too late for that now, Noah."],[2379,2529,"And thank you, really."],[2566,2729,"If you hadn't rejected me,"],[2825,3000,"I would have never found my true mate."],[3016,3154,"Ella, please, please."],[3154,3266,"That's Luna to you!"],[3308,3412,"And don't ever think about"],[3412,3491,"coming back here."],[3516,3666,"If you ever say another word to Ella,"],[3666,3879,"if you so much as look in her direction,"],[3879,4150,"I will rip you apart."],[4200,4379,"No, no, no, no."],[5129,5216,"Now, where were we?"]],"64":[[162,237,"Mark me."],[287,508,"Make me yours, Liam Gravens."],[525,595,"Mine."],[675,758,"Forever."],[862,995,"I love you, Ella Wilson."],[1150,1237,"I love you, too."],[1612,1712,"I feel you."],[1750,1975,"I feel you inside of me."],[4208,4262,"Ella..."],[4325,4466,"I want to feel all of you."]]}