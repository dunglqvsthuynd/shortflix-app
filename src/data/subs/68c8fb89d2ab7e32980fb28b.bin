{"1":[[154,304,"Big day at Shifters Academy."],[325,516,"The return of Alpha Liam Gravens."],[525,700,"A god among mortals,"],[729,866,"every girl's dream."],[3816,3991,"But, I only have eyes"],[3991,4166,"for Beta Noah Gravens."],[4204,4291,"His brother."],[4362,4441,"Noah saved me"],[4441,4550,"when we were nine years old"],[4550,4725,"and he's been my crush ever since."],[4750,4879,"Now he's my mate."],[4916,5079,"We just haven't made things official yet."],[5741,5879,"Those shoulders."],[5912,6029,"Oh my Goddess."],[6029,6154,"I heard he's still mateless."],[6170,6391,"Yeah, because he's a total playboy."],[6425,6537,"If you're not Luna material,"],[6537,6679,"he'll use you and lose you."],[6725,6958,"Good thing I was born to be Luna."],[7666,7891,"Oh my God!"],[7891,8079,"I knew you were a wolfless defect,"],[8079,8291,"but I didn't know you were a creep, too."],[8291,8379,"Give that back!"],[8441,8591,"I was taking pictures of Noah,"],[8641,8725,"my mate."],[8870,9087,"Noah's your mate?"],[9125,9304,"Then why hasn't he claimed you yet?"],[9387,9529,"If he claimed her,"],[9529,9687,"he would lose his Beta title."],[9704,9854,"A powerful mate like him"],[9854,10075,"would never claim a reject"],[10075,10300,"who can't even shift."],[10300,10416,"Wolfless."],[10437,10525,"Wolfless!"],[10529,10612,"Wolfless!"],[11029,11137,"You could never"],[11137,11275,"mate a Gravens brother."],[11316,11637,"You're just a poor, yappy mutt in heat."],[12741,12816,"Noah!"],[12962,13050,"Please,"],[13066,13154,"help me."],[13375,13441,"Please,"],[13479,13550,"help me."],[13662,13725,"Is that"],[13766,13841,"my mate?"]],"2":[[316,500,"My mate should have felt my pain."],[566,741,"How could Noah walk away from me?"],[1154,1354,"Aww, don't be sad, Ella."],[1387,1495,"If you're so desperate"],[1495,1591,"to score a mate,"],[1591,1800,"then why don't you try this?"],[2150,2379,"Wow, Ella, did you steal this bra"],[2379,2512,"from your grandma?"],[2512,2737,"That screams never been touched."],[2737,2766,"Wow."],[2812,3016,"Wolfless and a virgin?"],[3029,3175,"You're even more pathetic"],[3175,3275,"than I thought."],[3275,3454,"No wonder Noah won't mark you."],[3454,3662,"Any decent wolf would die of shame"],[3662,3850,"before mating someone like you."],[3962,4066,"Stay away from"],[4066,4237,"the Gravens brothers, freak."],[4237,4362,"Look at my mate again,"],[4362,4537,"and I'll rip you to shreds."],[5891,6100,"Ella, it's you."]],"3":[[254,341,"I saved Ella Wilson"],[341,462,"when she was nine years old."],[475,591,"I fell for her that day,"],[591,816,"but she only ever wanted my brother."],[875,975,"All these years later,"],[1004,1141,"why is her voice in my head?"],[1379,1529,"Alpha Liam remembers me?"],[1575,1729,"He was my crush's big brother,"],[1729,1879,"but he's always ignored me."],[1975,2091,"Who did this to her?"],[2229,2554,"Baby, you're an Alpha now."],[2566,2629,"You don't have to"],[2629,2787,"waste your precious time"],[2787,2904,"worrying about her"],[2904,3041,"when I'm right here."],[3087,3279,"I've missed you so much."],[3279,3354,"Missed me?"],[3429,3591,"I don't even know who you are."],[3612,3754,"My family is one of"],[3754,3929,"the most powerful in this pack."],[3929,4191,"And she is a wolfless nobody."],[4191,4287,"A nobody?"],[4491,4654,"This is Ella Wilson."],[4712,4850,"Funny how I remember her name"],[4850,5079,"and can't even think of yours."],[5816,5954,"Is this a photo of me?"],[6150,6325,"It looks like you're the delusional one."],[6325,6454,"No wonder you don't have a mate."],[7150,7341,"I am the Alpha."],[7404,7679,"Touch her again, and I'll do much worse."],[8158,8229,"Are you okay?"],[8566,8612,"I'm fine."],[8612,8729,"Just leave me alone."]],"4":[[104,166,"Noah."],[441,504,"Noah!"],[1237,1287,"Why the hell are you"],[1287,1400,"wearing my brother's jacket?"],[1429,1504,"I'm your mate."],[1550,1604,"Really?"],[1650,1766,"Because Ava was practically"],[1766,1866,"torturing me back there"],[1866,1991,"and you didn't even look twice."],[2112,2229,"I know what people would say"],[2229,2316,"if you marked me."],[2416,2600,"Are you ashamed of me?"],[2775,2862,"Of course not."],[3100,3204,"I'll make it up to you tonight."],[3254,3366,"Remember what I promised?"],[3416,3541,"On the night of Flower Moon,"],[3662,3825,"I'll finally mark you as my mate."],[4266,4450,"Wolfless Ella is more popular"],[4450,4562,"with the Gravens Brothers"],[4562,4650,"than you, Ava."],[4679,4816,"Not for long, freak."],[4854,5041,"I'm the queen of Shifters Academy."],[5066,5262,"The Gravens Brothers are mine."],[7145,7241,"This is Noah."],[7241,7350,"You know what to do."],[7529,7679,"Maybe he's still getting ready."],[7679,7891,"Tonight's a big deal for both of us."],[7891,8104,"He's finally claiming me as his mate."],[8354,8500,"Looking for Noah?"],[8541,8604,"Come on."],[8629,8725,"We'll take you to him."]],"5":[[66,204,"Go ahead, defect."],[216,450,"See how bad your mate wants you."],[1391,1525,"What the hell, Noah?"],[1554,1704,"You're cheating on me with Ava?"],[1787,1966,"She's the one who humiliated me."],[2029,2179,"You were supposed to stick up for me."],[2179,2341,"You were supposed to be my mate."],[3162,3270,"Did you really even think"],[3270,3479,"a Beta would mate with you?"],[3529,3575,"Oh, what?"],[3575,3779,"With your chubby little cheeks"],[3779,3991,"and your cheap-ass dress,"],[3991,4404,"and that, oh, wolfless human stench?"],[4566,4741,"Oh, you're even more delusional"],[4741,4837,"than I thought."],[4966,5129,"Noah, you said you would"],[5129,5212,"claim me tonight"],[5212,5341,"in front of everyone."],[5391,5691,"Oh, poor baby wolfless."],[5691,5904,"Making up pathetic little stories"],[5904,6012,"just to fit in."],[6012,6166,"Why would Noah ever"],[6191,6329,"give up his Beta title"],[6341,6541,"for a defect mutt?"],[6562,6687,"Noah, tell them, please."],[6687,6762,"Tell them that you were"],[6762,6891,"meant to claim me tonight."],[6975,7225,"Ella, I don't love you."],[7291,7537,"Why would I throw my life away for you?"],[7641,7787,"I don't want you to be my mate."],[7866,7966,"I never did."]],"6":[[808,1095,"Ella, this was a bet from the guys."],[1116,1258,"How long can you string along"],[1258,1408,"the virgin wolfless?"],[1441,1558,"But I got bored."],[1608,1758,"I want a real mate now."],[1945,2033,"I want Ava."],[2404,2558,"So it's all just a game to you?"],[2570,2716,"I meant nothing to you?"],[2983,3166,"Me, the Alpha's brother,"],[3220,3395,"the Beta of the Crescent pack,"],[3395,3479,"with you,"],[3508,3695,"the unwanted wolfless?"],[3695,3904,"My father would disown me."],[3920,4054,"The pack would banish me"],[4054,4158,"to the rogues."],[4504,4608,"You bastard!"],[4620,4741,"Ava doesn't even like you."],[4741,4908,"She's obsessed with your Alpha brother."],[4929,5133,"You're just a consolation prize."],[5133,5233,"How dare you?"],[5345,5458,"Slapping a Beta,"],[5458,5695,"using my brother to insult me?"],[5720,5858,"You don't even know Liam."],[5858,5970,"He wouldn't look twice"],[5970,6191,"at a pitiful mutt like you."],[6208,6383,"You should have kept your mouth shut."],[6529,6616,"So sad."],[6616,6720,"You asked for it."],[7008,7270,"I, Noah Gravens,"],[7320,7520,"reject you as my mate."],[8779,8858,"That's what you get"],[8858,9041,"for disrespecting a Beta."],[9183,9320,"Once our bond breaks,"],[9320,9479,"I'll never mate again."],[9508,9808,"My one shot, ruined by the boy I loved."],[10120,10370,"I, Ella Wilson,"],[10479,10616,"accept your rejection."]],"7":[[383,487,"Come back, freak."],[525,725,"The party's just getting started."],[887,1120,"I can smell you."],[1662,1700,"Boo."],[1912,2012,"A little nobody like you"],[2012,2145,"doesn't deserve a Gravens."],[2150,2387,"You'll never take what's mine again."],[2437,2612,"Get rid of this defective loser."],[2733,2875,"I want her in the supply closet."],[3000,3037,"No."],[3150,3200,"No!"],[3250,3300,"No!"],[3762,3875,"Sleep tight, Ella."],[3908,4025,"If you were a real wolf,"],[4025,4112,"you'd be able to shift"],[4112,4258,"and break down these doors."],[4320,4408,"But I guess you're just gonna"],[4408,4462,"have to wait"],[4462,4650,"until the janitor gets here in the morning."],[4675,4700,"No!"],[4700,4812,"You can't leave me in here!"],[4883,4970,"You can't leave me in here!"],[4970,5033,"No!"],[5175,5225,"Please!"],[5225,5320,"Let me out!"],[5370,5420,"Stop!"],[5420,5470,"Please."],[5483,5533,"No."],[5745,5958,"Wolfless in the closet."],[5962,6170,"Wolfless in the closet."],[6170,6237,"Please!"],[7220,7462,"Someone, please save me!"]],"8":[[1545,1600,"Noah,"],[1625,1825,"you saved me nine years ago."],[1862,2070,"Why did you abandon me tonight?"],[2112,2195,"Help!"],[2833,2912,"Help!"],[2970,3025,"It's Ella."],[3058,3145,"She's in trouble again."],[3537,3637,"Noah, help me."],[5033,5120,"Liam?"]],"9":[[895,1045,"How did he find me here?"],[1133,1258,"Her voice was in my head again."],[1308,1370,"I always knew"],[1370,1454,"there was something special"],[1454,1512,"about her..."],[1529,1604,"but-"],[2279,2408,"Did you do this to her?"],[2483,2554,"We were just"],[2554,2708,"having a little fun with her,"],[2708,2795,"Alpha Liam."],[2945,3033,"Oh, come on."],[3058,3233,"Just because Ella's a defect"],[3233,3270,"doesn't mean"],[3270,3408,"that she can't take a joke."],[3441,3545,"Isn't that right, Ella?"],[3545,3658,"What did you call her?"],[3783,3854,"Leave."],[3891,3962,"Before I show you"],[3962,4083,"how I like to have fun."],[4545,4695,"You're banned from my dormitory."],[4695,4816,"This is the last party"],[4816,4933,"you'll ever attend in this academy"],[4933,4991,"and the last time"],[4991,5129,"you'll ever speak about Ella."],[5983,6054,"Are you okay?"],[6191,6283,"I thought I was gonna be"],[6283,6383,"stuck in there all night."],[6545,6704,"I would never let that happen."],[7495,7770,"Is Liam the one who saved me"],[7770,7908,"all those years ago?"],[8420,8495,"Thank you."]],"10":[[954,1050,"What am I doing?"],[1066,1291,"His brother, his Beta just rejected me."],[1329,1391,"There's no way"],[1391,1516,"an Alpha would want me."],[1566,1616,"Oh my God."],[1616,1741,"I'm so sorry."],[1766,1891,"You're an Alpha and I'm,"],[1916,2029,"I don't know what I was-"],[4079,4216,"Are you sure you want to do this?"],[4216,4362,"I mean, you're the pack Alpha"],[4362,4579,"and I'm a wolfless and a nobody."],[4579,4750,"Don't ever say that again, Ella Wilson."],[5391,5529,"You are so much more than that."],[6416,6487,"She's..."],[6641,6741,"my mate."]],"11":[[758,958,"Your smell, your taste,"],[958,1083,"it's intoxicating."],[1220,1379,"If you want me to stop, tell me now,"],[1433,1554,"before I can't hold back."],[1616,1670,"Don't."],[1758,1845,"Don't hold back."],[5420,5495,"Oh my God,"],[5508,5608,"I had a one night stand"],[5608,5729,"with Liam Gravens?"],[5770,5904,"I lost my virginity"],[5904,6104,"to my ex's Alpha brother?"],[6183,6295,"What was I thinking?"],[6320,6470,"I have to get out of here before he-"],[7720,7783,"Good morning."]],"12":[[129,279,"Liam, what are you,"],[279,329,"I, I..."],[416,620,"Oh my goodness, what have I done?"],[1333,1533,"You felt it too, didn't you?"],[1612,1791,"I wish Ella could see our mate bond,"],[1791,1845,"but..."],[1962,2120,"she doesn't have her wolf yet."],[2254,2520,"I thought I felt, but it's impossible."],[2520,2704,"I can never be Liam's mate."],[2704,2908,"An Alpha can't mark a wolfless,"],[2908,3095,"not without losing everything."],[3158,3204,"I don't."],[3204,3291,"I, I..."],[3304,3350,"We shouldn't have."],[3350,3404,"We shouldn't-"],[3454,3620,"Liam, I know you're in there."],[3633,3758,"Open the damn door."],[3945,4016,"Noah."],[4045,4116,"It's bad enough"],[4116,4208,"I slept with the Alpha,"],[4208,4383,"but if my ex finds me naked"],[4383,4529,"in his brother's bedroom..."],[4608,4741,"Liam, I-"],[4783,4916,"You can't let Noah in."],[4954,5095,"Please, him and I-"],[5095,5220,"Ella, it's okay."],[5295,5391,"If you really don't want to see him,"],[5391,5466,"I'll protect you."],[5716,5770,"Liam!"],[5833,5929,"I left my laptop in there."],[5929,6083,"Class starts in five minutes."],[6958,7029,"Stay here."],[7158,7254,"Don't make a sound."],[7370,7441,"Coming."],[8220,8283,"Took you long enough"],[8283,8370,"to open the door."],[8916,9041,"Are you hiding a girl in there?"],[9254,9316,"Yeah."],[9433,9604,"The most beautiful girl in school."],[9695,9833,"Does he really mean that?"],[9920,10058,"When are you going to mark her bro?"],[10258,10383,"I'm gonna make her my Luna."]],"13":[[41,166,"I'm gonna make her my Luna."],[541,704,"He's a total playboy."],[729,866,"If you're not Luna material,"],[866,1004,"he'll use you and lose you."],[1041,1179,"Of course he didn't mean it."],[1179,1366,"I can never be the Alpha's Luna."],[1375,1525,"He's probably leading me on"],[1525,1691,"so he can humiliate me later."],[2304,2491,"Whoever it is, I can't wait to meet her."],[2654,2966,"Ella, this was a game from the guys."],[2987,3125,"How long can you string along"],[3125,3275,"the virgin wolfless?"],[3991,4254,"Ella, is Noah the reason"],[4254,4375,"you were so upset last night?"],[4441,4579,"The happiest day of my life"],[4579,4687,"was when Noah told me"],[4687,4804,"that we would be mates."],[4954,5062,"It was all a lie."],[5154,5266,"You probably already knew that."],[5366,5450,"No, Ella, I-"],[5512,5600,"I didn't."],[5616,5750,"So there wasn't a bet to see"],[5750,5841,"how long it would take you"],[5841,6025,"to bag the rejected wolfless?"],[6062,6116,"Because that's what"],[6116,6216,"your brother would do."],[6262,6379,"I'm not my brother."],[6441,6541,"I mean, why would you"],[6541,6604,"want someone like him"],[6604,6675,"as your mate anyway?"],[6675,6854,"I wouldn't expect you to understand."],[6900,7091,"I'm wolfless and unmateable."],[7166,7262,"Good for one night,"],[7262,7466,"but not Luna material."],[7491,7666,"Ella, that's not true."],[7666,7775,"I know what would happen"],[7775,7916,"to someone like you or your brother"],[7916,8079,"if you mated with someone like me."],[8191,8341,"You would lose your Alpha title"],[8341,8466,"and the whole pack"],[8466,8579,"would turn against you."],[8637,8737,"Tell me I'm wrong."],[8854,8916,"You're not."],[9225,9266,"But Ella-"],[9266,9325,"Save it."],[9387,9516,"This won't happen again."],[10079,10241,"Why does leaving him hurt"],[10241,10354,"worse than being dumped"],[10354,10466,"by his brother?"],[11066,11191,"If the Moon Goddess gave me Ella,"],[11191,11341,"then she must be special."],[11404,11537,"If I can help her find her wolf,"],[11537,11679,"then I will mark her as mine."]],"14":[[279,525,"Last night, I lost my virginity"],[525,687,"to my ex's Alpha brother."],[691,841,"It just sort of happened"],[841,929,"and honestly,"],[929,1062,"it was amazing."],[1062,1329,"But Liam's an Alpha and I'm a reject."],[1366,1516,"No one can ever know."],[2070,2116,"Oh."],[2141,2183,"That's mine!"],[2183,2287,"Oh, you want it? - Give it back!"],[2350,2416,"Oh, come get it."],[2725,2804,"Noah, get her."],[2925,3066,"Noah, what are you doing?"],[3087,3150,"Feisty."],[3191,3241,"If I would have known,"],[3241,3379,"I would have kept you one more night."],[3437,3650,"Who wants to hear Wolfless Ella's"],[3650,3866,"deepest, darkest secrets?"],[3954,4004,"Me!"],[4129,4216,"No, please!"],[4354,4637,"Dear diary, sometimes I practice"],[4637,4875,"writing Mrs. Ella Gravens"],[4875,5004,"during class."],[5066,5366,"Our pups would be so beautiful."],[5429,5604,"You really liked me that much?"],[5679,5779,"Pathetic."],[6004,6241,"My family runs this pack."],[6241,6387,"No Gravens would ever"],[6387,6525,"mate with someone like you."]],"15":[[162,362,"Your pups, Ella,"],[362,587,"would be wolfless weirdos."],[587,700,"Just like you."],[725,970,"She has to find a mate to have pups,"],[970,1045,"doesn't she?"],[1058,1170,"What wolf is gonna"],[1170,1308,"let a freak like her"],[1308,1395,"drag him down?"],[1458,1550,"You're not worth it."],[1550,1687,"I hate you!"],[1825,1900,"Oh, really?"],[1900,2187,"Because according to your diary..."],[2250,2412,"Dear diary,"],[2412,2675,"some stupid part of me still loves Noah-"],[2675,2750,"No, stop it!"],[2750,2850,"Despite"],[2916,3100,"losing my virginity last night?"],[3312,3387,"What the hell?"],[3387,3508,"Who would stoop low enough"],[3508,3600,"to sleep with you?"],[3683,3870,"Babe, obviously she's lying."],[3908,4025,"I mean, you're pathetic enough"],[4025,4220,"to create an entire fantasy life"],[4220,4425,"in your own diary?"],[4450,4637,"That's so sad."],[4687,4825,"I wonder what else you're lying about."],[4825,4870,"Stop it!"],[5900,6020,"That must have hurt."],[6020,6137,"A weak wolfless"],[6137,6337,"can't heal like us werewolves."],[6375,6512,"Stay down, freak."],[6512,6700,"Wolves hunt the weak, not date them."],[6725,6820,"Think about that next time"],[6820,6870,"you write about"],[6870,7050,"your delusional little fantasies."],[7675,7925,"Touch her and you're dead."]],"16":[[829,879,"Liam?"],[1079,1179,"Who did this to you?"],[1591,1700,"She tripped and fell."],[1737,1941,"She can't hang with the real wolves."],[1966,2141,"Do you ever tell the truth, Noah?"],[2166,2391,"Or is bullshit the only language you speak?"],[2391,2491,"Seriously, bro?"],[2491,2566,"You're gonna defend her"],[2566,2679,"over your own blood?"],[2754,2850,"Her name"],[2941,3016,"is Ella."],[3216,3416,"Noah's not the one lying, Liam."],[3425,3529,"Look at Ella's diary"],[3529,3691,"and you'll see all the pathetic lies"],[3691,3775,"she's made up."],[3775,3854,"No, don't!"],[3854,3991,"You fell for her innocent act,"],[3991,4062,"didn't you?"],[4125,4262,"You're acting as if she's"],[4304,4379,"your mate."]],"17":[[4,154,"I can't claim Ella as my mate."],[191,279,"If I lose my title,"],[279,416,"if the pack turns against me,"],[466,554,"who will protect her?"],[941,1091,"She deserves so much better"],[1091,1241,"than an asshole like you."],[1300,1504,"Call her wolfless one more time,"],[1537,1654,"and those will be the last words"],[1654,1829,"that you ever speak to this pack."],[2304,2487,"Noah always told me I was nothing,"],[2541,2766,"but Alpha Liam defended me"],[2766,2900,"against his own brother."],[2950,3075,"What does he see in me?"],[3079,3225,"Don't you boys have anything better"],[3225,3287,"to fight about"],[3287,3479,"other than some little freshman freak"],[3479,3616,"who can't even shift?"],[3854,3950,"Ava's right!"],[3950,4137,"I've finally come to my senses, Noah."],[4154,4379,"Thank the Goddess you've rejected me."],[4454,4566,"You know what they say,"],[4604,4904,"Big egos, tiny you-know-whats."],[6250,6491,"The way Alpha Liam stuck up for Ella"],[6491,6729,"was so sexy."],[6729,6779,"Damn!"],[6779,7025,"I didn't know Ella was chill like that."],[7025,7116,"She's not!"],[7175,7329,"Your brother's just being nice."],[7366,7516,"Ella's a nobody."],[7666,7837,"Oh my god, what did I just do?"],[7854,7991,"I should've kept my mouth shut."],[7991,8033,"I should've just-"],[8033,8204,"That was pretty badass, Ella Wilson."],[8341,8466,"What are you doing in here?"],[8741,8812,"You know,"],[8866,8954,"I kinda like"],[8954,9266,"how Ella Gravens sounds."],[9541,9741,"Oh no, Liam's gonna realize that"],[9741,10004,"I am just a pathetic, wolfless freak."]],"18":[[395,475,"You're not supposed to be"],[475,562,"in the girls' restroom."],[883,975,"I’m the Alpha."],[1037,1162,"What are you gonna do about it?"],[1195,1258,"Um..."],[1425,1575,"How much did you read in there?"],[1687,1812,"You seem nervous, Ella."],[1850,1920,"What kinds of dirty things"],[1920,2025,"are you writing about me?"],[2075,2187,"Nothing, it's just..."],[2300,2395,"All those things,"],[2395,2525,"it's, it's not about you."],[2562,2637,"It's not?"],[3262,3358,"What are you doing?"],[3500,3625,"I'm just giving you something"],[3625,3675,"to write about"],[3675,3837,"in that little diary of yours."],[3950,4120,"The next time those boys read it,"],[4175,4350,"you can tell them it's all about me"],[4437,4587,"and not my asshole brother."],[4925,5183,"And I, the Alpha,"],[5275,5375,"will make sure that they know"],[5375,5725,"every word is true."]],"19":[[650,741,"What am I doing?"],[766,916,"I can't fall under Liam's spell."],[954,1091,"He'll use me to get what he wants"],[1091,1216,"just like Noah did,"],[1216,1404,"but I'll never really be his."],[1575,1725,"Liam, what are you doing?"],[1766,1816,"I told you"],[1816,1941,"this wouldn't happen again."],[1954,2025,"Why?"],[2054,2150,"You don't want this?"],[2237,2329,"I can't."],[2491,2591,"You don't trust me."],[2641,2704,"I get it."],[2750,2854,"But you don't have to lie."],[2912,3012,"I know you want me."],[3037,3154,"I can smell it all over you."],[3725,3904,"Liam, you're the Alpha."],[3904,4079,"And I don't even have my wolf yet."],[4175,4354,"But I'm not some weak side piece"],[4354,4487,"you can just use and lose"],[4487,4629,"once you find your true Luna."],[4675,4779,"You don't know me, Ella."],[7379,7450,"It was you."],[7487,7587,"You saved me."],[7841,7966,"Uh, yeah."],[7966,8129,"That was totally me."],[8641,8750,"After that day,"],[8766,8925,"I prayed to the Moon Goddess"],[8925,9004,"every night."],[9029,9254,"I begged for Noah to be my fated mate."],[9304,9491,"All this time, I thought it was Noah"],[9491,9616,"who saved me, but-"],[9637,9812,"You were the one who saved me."],[9879,10091,"Is Liam, the Gravens brother"],[10091,10304,"I was in love with all those years?"]],"20":[[12,116,"So now you remember?"],[387,566,"I always thought it was Noah."],[687,816,"It was my tenth birthday."],[879,954,"I remember it was like"],[954,1066,"right before cake."],[1129,1216,"I wasn't sure where you went."],[1316,1454,"I ended up looking over the entire house"],[1454,1541,"until I found you."],[1591,1666,"But you were"],[1666,1841,"the most popular kid in school,"],[1841,1966,"the future Alpha."],[1987,2166,"The playboy every girl wanted."],[2237,2379,"Why would you care about me?"],[2404,2454,"You can think"],[2454,2579,"what you want about me, Ella."],[2629,2766,"But I did care about you."],[2891,3016,"I never forgot about you either."],[3079,3254,"You're more than just a wolfless."],[3391,3479,"You always have been."],[3629,3725,"Liam, I..."],[4104,4279,"Thank you for saving me today,"],[4279,4487,"but that was a long time ago."],[4491,4625,"Things are different now."],[4679,4766,"He's an Alpha."],[4787,4954,"His fated mate will be strong,"],[4966,5041,"powerful."],[5091,5162,"Not like me."],[5229,5391,"It's no use falling for him now"],[5391,5537,"when I'll never be good enough."],[5566,5762,"I appreciate you sticking up for me."],[5762,5950,"But I don't want to ruin things"],[5950,6054,"between you and your brother."],[6175,6275,"Noah crossed lines"],[6275,6404,"that a Beta never should."],[6429,6529,"He had that coming."],[6554,6766,"Ella, I can't let anyone"],[6766,6854,"treat you like that."],[6941,7037,"Not even my brother."],[7179,7254,"Not when we're..."],[7891,8004,"But, I can’t claim her."],[8066,8200,"Not until she gets her wolf."],[8337,8412,"My mate."]],"21":[[587,783,"Aww, Ella!"],[820,958,"You tripped again."],[1012,1150,"You're so clumsy."],[1258,1337,"Oh, by the way,"],[1337,1537,"I forgot to tell you how sorry I am"],[1537,1700,"about your mate rejecting you"],[1770,1833,"for me."],[1937,2200,"To be honest, Noah's not really my type."],[2250,2587,"So if you want him back, he's all yours."],[2920,3008,"Are you kidding?"],[3025,3133,"I wouldn't touch Noah again,"],[3133,3237,"even if you paid me."],[3325,3483,"Oh, Ella."],[3500,3645,"Get over yourself."],[3645,3925,"Noah is a weak, second-rate Beta."],[3937,4150,"He belongs with a wolfless freak"],[4150,4225,"like you."],[4287,4412,"Me, on the other hand,"],[4412,4512,"I'm the perfect"],[4512,4695,"match for his brother."],[4695,4775,"It's no secret"],[4775,4933,"you're obsessed with Alpha Liam."],[4995,5137,"So how did it feel when he saved me"],[5137,5225,"in front of the whole class"],[5225,5300,"instead of you?"],[5375,5475,"You poor thing."],[5512,5650,"You must have been howling"],[5650,5750,"with jealousy."],[5870,6166,"Oh, you filthy, wolfless, bitch!"]],"22":[[537,704,"A weak little nobody like you"],[704,900,"really thinks she can step to me?"],[929,970,"What?"],[995,1070,"Alpha Liam's gonna"],[1070,1216,"come save you again?"],[1245,1545,"You can play Alpha's pet all you want,"],[1562,1766,"but you will never satisfy him"],[1766,1858,"like I can."],[1887,2208,"And you will certainly never be his Luna."],[2320,2495,"You're more than just a wolfless."],[2533,2633,"You always have been."],[2783,2970,"I've always been so scared of Ava,"],[3000,3116,"but I can't keep letting her"],[3116,3216,"push me around."],[3362,3475,"And neither will you."],[3525,3570,"You jumped to"],[3570,3733,"second-rate Beta's bones all"],[3733,3800,"so you could prove"],[3800,3900,"you were hotter shit"],[3900,4058,"than a weak wolfless like me?"],[4083,4183,"Congrats,"],[4204,4316,"but I should tell you,"],[4395,4533,"Alpha Liam is way better"],[4533,4641,"than Noah in bed."],[4658,4808,"The things he can do with his tongue"],[4870,4991,"should be illegal."],[5162,5270,"Damn, Ella."],[5283,5445,"Wolfless better work."],[5445,5720,"What the hell are you smoking, Ella?"],[5741,5887,"As if Alpha Liam"],[5887,6054,"would ever touch you."],[6079,6158,"Did you forget that"],[6158,6320,"my family is one of these packs'"],[6320,6470,"most powerful"],[6470,6758,"and you can't even shift?"],[6787,6933,"Let me remind you..."]],"23":[[37,125,"Is this it?"],[166,325,"Am I finally shifting?"],[433,545,"How can a wolfless"],[545,695,"block Ava's wolf strength?"],[695,870,"She's got pure Alpha blood!"],[1095,1245,"Why is everything spinning?"],[1350,1500,"She thought she could fight me."],[1575,1687,"For a second I thought that"],[1687,1883,"you just might shift, wolfless."],[1900,2154,"But you're still just a stray."],[2375,2425,"She thinks"],[2425,2587,"being Alpha Liam's new lap dog"],[2587,2712,"gives her power."],[2725,2945,"That's so cute."],[3104,3354,"I'm not done playing with you yet, freak."]],"24":[[204,379,"Ella, are you okay?"],[379,491,"Liam, you're bleeding."],[579,783,"Alpha Liam, I'm so sorry."],[795,908,"I didn't mean to hurt you."],[937,1070,"But you meant to hurt Ella."],[1337,1595,"Liam, I don't feel too good."],[2016,2195,"You're lucky it was me and not her."],[2254,2320,"Touch her again,"],[2320,2458,"I'll banish you from the pack."],[3579,3729,"Hey, easy, easy."],[3795,3870,"How do you feel?"],[4070,4154,"You passed out."],[4208,4295,"The Alpha of our pack"],[4295,4416,"took a hit for me,"],[4433,4570,"saved me again?"],[4633,4850,"He really cared about me once,"],[4858,4970,"back when we were kids."],[5020,5187,"Maybe he still does."],[5250,5337,"I'm fine."],[5383,5454,"But you-"],[5470,5616,"Ava's scratches were deep."],[6133,6220,"You could help me."],[6341,6400,"How?"],[6520,6591,"Kiss me."]],"25":[[83,154,"Kiss me."],[875,1070,"You seem pretty healed to me."],[1254,1495,"Maybe the pain is something else."],[1916,2004,"Something deeper."],[2337,2400,"Harder."],[2504,2654,"Liam, not at school."],[2679,2791,"Anyone can walk in."],[2841,2937,"I'm the Alpha."],[3000,3087,"I'll send them away."],[3304,3587,"What you said about Ava drove me crazy."],[3641,3704,"You enjoyed our night"],[3704,3779,"enough together"],[3779,3937,"to brag about my tongue."],[4083,4283,"It was alright."],[4370,4433,"Alright?"],[4516,4566,"Are you saying"],[4566,4704,"I wasn't better than my brother?"],[4854,4937,"I wouldn't know."],[5095,5220,"You never slept with Noah?"],[5525,5575,"No."],[5716,5854,"Liam, you were my first."],[5979,6120,"Ella gave me her first time."],[6187,6266,"She trusted me"],[6266,6416,"like she never trusted my brother."],[6945,7091,"Goddess, I want her."],[7108,7220,"I need her."],[7262,7441,"You can't say things like that to me, Ella."],[7470,7625,"The way he's looking at me..."],[7687,7754,"I don't know"],[7754,8079,"if he wants to kiss me or kill me."],[8112,8241,"Are you mad at me?"],[8316,8391,"I was nervous"],[8391,8500,"and I didn't know if you would, um-"]],"26":[[383,545,"It's impossible to stay away from her."],[554,712,"The closer I get, the more I feel like"],[712,862,"I'd risk everything to have her."],[950,1100,"Why can't I resist him?"],[1145,1325,"Why is it that every time we touch,"],[1325,1458,"I lose control?"],[1500,1583,"I want him."],[1637,1733,"I need him."],[1795,1912,"But I can't have him."],[2429,2504,"I'm sorry."],[2504,2562,"It's too much."],[2562,2629,"I can't."],[2716,2804,"Damn, Ella."],[2825,2875,"Are you sure"],[2875,3008,"you don't have your wolf yet?"],[3170,3250,"Actually,"],[3325,3470,"I think I felt my wolf"],[3470,3587,"for the first time today."],[3770,3945,"You think I'm crazy, don't you?"],[3950,4025,"I'm a reject."],[4025,4100,"I'm already 18."],[4100,4212,"Why would the Moon Goddess"],[4237,4358,"give me any powers?"],[4458,4520,"I don't know."],[4645,4695,"The Moon Goddess"],[4695,4825,"works in mysterious ways."],[5304,5525,"You really think I could shift one day?"],[5545,5662,"I mean, I've heard that"],[5662,5758,"finding your fated mate"],[5758,5900,"could awaken a wolf's powers,"],[5900,6095,"but I was with Noah for three years"],[6095,6233,"and I felt nothing."],[6308,6375,"Well, maybe he wasn't"],[6375,6462,"your true mate."],[6733,6866,"If I could awaken her wolf,"],[6900,6983,"then I could mark her"],[6983,7087,"and still be the Alpha."],[7120,7237,"She could be my Luna,"],[7262,7395,"and I could be the mate"],[7395,7487,"that she deserves."],[7500,7637,"The mate my brother never was."]],"27":[[441,570,"Alpha Liam."],[654,804,"She needs to rest."],[1441,1541,"I'll see you in class."],[1729,1916,"Liam always says the right things,"],[1916,2087,"but does he really mean it?"],[2141,2291,"I trusted his brother enough"],[2291,2437,"to give my heart away."],[2483,2645,"If I did the same to Liam,"],[2700,2900,"would he break it all over again?"],[4062,4162,"Would you give this to Ella"],[4162,4237,"when she wakes up?"],[4237,4350,"I don't want to bother her."],[5866,5991,"Meet me in the library."],[5991,6141,"Let's finish what we started."]],"28":[[229,404,"Yesterday, I thought Noah Gravens"],[404,516,"was my fated mate."],[554,745,"I thought we would be together forever."],[800,875,"And now..."],[1391,1562,"I can't stop thinking about"],[1562,1729,"his Alpha brother."],[2116,2162,"Boo."],[2366,2445,"Hey, stalker."],[2829,2941,"Trying to win me back,"],[2941,3029,"butterfingers?"],[3066,3212,"I'm not that desperate, Noah."],[3225,3375,"And who are you calling stalker?"],[3375,3491,"I've literally never seen you"],[3491,3591,"in the library before."],[3654,3800,"I'm not even sure you can read."],[3987,4062,"Since when did you"],[4062,4179,"have such a big mouth?"],[4216,4387,"Too bad you're all bark and no bite."],[4466,4550,"Perfect."],[4866,5016,"Once Alpha Liam sees Ella"],[5016,5154,"sniffing all over his brother,"],[5154,5400,"he'll see how pathetic she really is."]],"29":[[12,95,"Let me go."],[225,445,"But Ella, I thought you wanted me."],[479,595,"I thought you loved me."],[900,1104,"You sure do smell like desperation."],[1187,1325,"Were you following me around"],[1325,1516,"hoping to bump into your ex-mate?"],[1554,1687,"To have something to think about"],[1687,1816,"when you're all by yourself?"],[1816,1887,"Something to write"],[1887,2041,"in your smutty little diary?"],[2150,2241,"Fuck you!"],[2404,2491,"Gladly."],[3100,3175,"I'll tell you what."],[3283,3375,"I'll throw you a bone."],[3408,3625,"I'll let you kiss me one more time."],[3700,3945,"Right here, right now."],[4012,4095,"It'll be everything"],[4095,4200,"you've ever dreamed of."]],"30":[[191,329,"I don't want to kiss you."],[329,466,"You disgust me."],[479,604,"Don't lie to yourself."],[641,691,"I know you've been"],[691,891,"dreaming of this moment, Ella."],[1305,1418,"You don't need this."],[1545,1695,"Finally becoming a real wolf"],[1695,1795,"like one of us."],[1862,1987,"Your mate, claiming you"],[1987,2137,"in front of everyone."],[2291,2333,"Now,"],[2358,2541,"who wants to see me give wolfless"],[2541,2658,"something to howl about?"],[2962,3050,"Kiss her!"],[3054,3150,"Kiss her!"],[3154,3225,"Kiss her!"],[3233,3308,"Kiss her!"],[3312,3383,"Kiss her!"],[3395,3479,"Kiss her!"],[3516,3604,"Noah, please."],[3604,3729,"We're not mates anymore."],[3791,3866,"Sure,"],[3883,3962,"but those feelings"],[3962,4129,"don't just go away overnight."]],"31":[[0,79,"I can still make your"],[79,237,"wildest fantasy come true."],[275,345,"Fantasy?"],[400,575,"You're my worst nightmare."],[575,720,"Noah, I've moved on."],[770,875,"To who?"],[920,1133,"Noah is the Beta of this pack."],[1133,1287,"Besides, you'll never get"],[1287,1375,"another opportunity"],[1375,1662,"to kiss anyone as powerful as him."],[1750,1950,"And we've all read your diary, babe."],[1975,2141,"We know you've lusted after him"],[2141,2229,"for years."],[2379,2504,"Let me go!"],[2704,2887,"I knew you secretly liked it rough."],[2891,3016,"Please, Noah."],[3087,3250,"I love it when you beg."],[3258,3391,"Somebody help."],[3445,3533,"Anyone."],[4308,4391,"Alpha Liam."],[4583,4895,"Back the fuck away from Ella."]],"32":[[604,704,"Are you okay?"],[808,908,"Relax, dude."],[920,1033,"She came onto me."],[1104,1254,"Are you really so stupid"],[1254,1329,"and self-involved"],[1329,1491,"that you can't see she's over you?"],[1512,1704,"She'll never be over me."],[1733,1916,"She's been panting over me for years"],[1916,2104,"like a bitch begging for my pups."],[2108,2241,"I'm all she's ever wanted,"],[2254,2420,"and I'm the best she'll ever have."],[5195,5295,"What do you think of that?"],[5420,5695,"Liam just kissed me in front of everyone."],[5754,6004,"He claimed me like Noah never would."],[6129,6212,"I'd say,"],[6345,6525,"it was the best I've ever had."]],"33":[[37,158,"I'm ashamed to call you