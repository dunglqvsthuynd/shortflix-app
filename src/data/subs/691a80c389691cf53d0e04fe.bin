{"1":[[675,750,"Rashida."],[1071,1217,"I think I’m getting sick."],[1426,1559,"My joints feel all weird"],[1559,1847,"and everything tastes like... chalk?"],[1947,2102,"You're not sick,"],[2102,2210,"Luna Ally."],[2377,2473,"You are with child."],[3048,3207,"Oh my Moon Goddess!"],[3407,3687,"That’s... that’s wonderful!"],[3945,4141,"Maybe with this baby,"],[4141,4337,"Cyrus will finally love me."],[4425,4596,"Maybe this will change everything."],[4725,4788,"Yes."],[5046,5171,"This will change everything."],[5363,5492,"If I were being honest,"],[5530,5672,"this is worse than being sick."],[5672,5839,"Oh, come on, Rashida."],[5897,6085,"Being a mother can't be that bad."],[6118,6227,"I know I'll probably blow up"],[6227,6289,"like a balloon"],[6289,6493,"and gain 25 pounds,"],[6493,6548,"but—"],[6548,6598,"Ally."],[6785,6927,"This baby will kill you."],[7015,7140,"Wait, what do you mean?"],[7394,7532,"Ever since the peace treaty,"],[7532,7670,"humans and werewolves"],[7670,7816,"have children all the time."],[7816,7937,"I'll be fine."],[7995,8058,"No."],[8179,8299,"Not Alpha's."],[8362,8562,"No human has ever survived"],[8562,8762,"carrying an Alpha's baby."],[8933,9146,"A normal werewolf...yes,"],[9163,9442,"but Alphas are too strong."],[9480,9638,"This pregnancy will kill you"],[9638,9755,"if you go through with it."],[9972,10185,"My mentor tracked down 11 cases"],[10185,10281,"of human women pregnant"],[10281,10393,"with Alpha babies."],[10410,10610,"From the past five centuries,"],[10610,10827,"seven died during pregnancies,"],[10827,10990,"two died during childbirth,"],[10990,11198,"and two from botched abortions."],[11286,11507,"That’s a 100% mortality rate, Ally."],[11657,11720,"No, no, no,"],[11720,11853,"there has to be a way."],[12362,12566,"This is my baby with Cyrus."],[12729,12804,"No, I won't."],[12804,12937,"I can try to find a way."],[13071,13221,"Maybe the fruit of Arbor Vitae!"],[13313,13463,"But that is only a legend."],[14343,14552,"The human body can't handle"],[14552,14685,"the growth of the fetus."],[14752,14881,"It's already starting."],[14881,15035,"The nosebleeds proves it."],[15148,15219,"Ally,"],[15273,15448,"let’s get rid of it while we still can."],[15498,15653,"I'm not getting rid of my baby,"],[15653,15715,"Rashida!"],[15757,15911,"There has to be a way!"],[16174,16257,"Does Cyrus know that"],[16257,16399,"this baby could kill me?"],[16453,16595,"Only this book holds the truth."],[16750,16871,"My mentor never published it."],[16996,17079,"Then no one knows,"],[17079,17167,"not even him."],[17392,17496,"Rashida,"],[17496,17663,"you can't tell anyone, okay?"],[17663,17742,"Promise me!"],[17767,17859,"Swear it!"],[17997,18063,"I swear."],[18138,18272,"I will do everything I can"],[18272,18343,"to save you, Ally."]],"2":[[2427,2594,"Welcome back, Alpha."],[3203,3370,"Ally, I looked into the fruit of"],[3370,3465,"Arbor Vitae!"],[3465,3670,"It’s a rare legendary fruit that"],[3670,3837,"only Alphas can harvest."],[3837,4020,"We might have a chance if Cyrus"],[4020,4133,"can find it for you!"],[4133,4341,"You have to tell him ASAP!"],[4683,4758,"Cyrus."],[4813,4892,"Dinner's ready."],[5092,5167,"Not hungry."],[5367,5547,"I spent two hours making dinner."],[5676,5805,"He won't even look at it."],[5939,6056,"Not even a little?"],[6101,6256,"I mean, I made all your favorites."],[6381,6468,"We have chefs and maids"],[6468,6552,"for these things."],[7857,8058,"Three years of marriage."],[8074,8274,"Even if his heart was an icebox,"],[8324,8404,"I thought I could have"],[8404,8512,"thawed it by now."],[8566,8637,"I told you."],[8721,8854,"Don't touch me unless we're in bed."],[8954,9088,"But who am I kidding?"],[9125,9284,"This is Cyrus Blackstone,"],[9338,9501,"Alpha of the Blackstone Pack."],[9551,9701,"And he doesn't have a heart,"],[9701,9830,"at least not for me."],[9868,10010,"Cyrus, can we talk?"],[10197,10256,"I have something"],[10256,10377,"I really want to tell you."],[11086,11156,"What?"],[11307,11378,"Emma's hurt?"],[11436,11511,"I'll be right there."],[11657,11740,"Wait, Cyrus!"],[11740,11899,"I really need to tell you something."],[11899,11970,"It's urgent."],[12116,12241,"You’re a fucking housewife!"],[12283,12358,"What urgent things"],[12358,12445,"could you possibly have?"],[12612,12696,"I'm pregnant!"],[12987,13092,"With our pup."],[13684,13830,"Then just stay home and rest."],[13988,14089,"Take care of the baby."],[14134,14235,"It's not that big of a deal."],[14393,14510,"And I'm dying."]],"3":[[859,925,"What happened?"],[1059,1226,"We were ambushed by witches."],[1309,1401,"The Stormborn Coven"],[1401,1514,"down by Pasadena."],[1609,1776,"They cursed me in battle..."],[2022,2177,"I lost my wolf."],[2369,2435,"Josh."],[2577,2652,"Organize an attack"],[2652,2765,"on the Stormborn Coven."],[2798,2882,"Ravage them."],[2973,3094,"Don't stop until they hand over"],[3094,3169,"the antidote."],[3199,3374,"Yes, Alpha Cyrus."],[3415,3490,"No, no, it’s..."],[3616,3699,"it’s no use."],[3912,3999,"The elder witch"],[3999,4137,"who captured me said that..."],[4466,4550,"Said what?"],[5067,5347,"That only the fruit of the Arbor Vitae"],[5347,5442,"will heal me."],[5663,5734,"Without it,"],[5943,6093,"I won't survive the winter."],[6193,6302,"The fruit of the Arbor Vitae"],[6302,6377,"is just a myth."],[6485,6560,"No one's ever actually"],[6560,6639,"found one before."],[6890,7173,"So he really doesn’t know where it is?"],[8037,8162,"If death be my fate,"],[8287,8358,"so be it."],[8466,8558,"It's a good death."],[8637,8933,"Knowing I died to protect my pack..."],[9221,9325,"and my Alpha."],[10635,10748,"I won't let you die."],[10935,11040,"I gave your father my word."],[11169,11298,"I'll find the fruit and save you."]],"4":[[471,617,"I'm the one dying,"],[617,792,"but my husband is embracing"],[792,884,"another woman."],[909,1109,"That's Alpha Cyrus in there."],[1192,1388,"He rushed right over"],[1388,1480,"when we notify him that"],[1480,1555,"Emma was hurt."],[1593,1780,"Oh, who's the lucky she-wolf?"],[1780,1931,"You don't know?"],[1947,2106,"Oh, Emma"],[2106,2293,"is the Alpha’s first love."],[2435,2648,"That is exactly why he will never"],[2648,2773,"love his human wife."],[2836,3015,"He was forced to marry her."],[3174,3278,"They are right."],[3278,3465,"Cyrus was forced to marry me."],[3524,3728,"And that's why I live to pay the price."],[4029,4212,"But all I wanted was to love him."],[4266,4391,"Is that so wrong?"],[4683,4796,"Are you okay, human girl?"]],"5":[[1176,1267,"Are you okay, human girl?"],[1388,1463,"Come with me."],[1997,2089,"You shouldn't be here."],[2147,2231,"The werewolves and humans"],[2231,2285,"are at war."],[3832,4020,"I met him when I was at my lowest."],[4108,4208,"He saved me."],[4337,4416,"And with one look,"],[4416,4567,"I knew he was the one for me."],[4700,4892,"I felt it in my soul."],[4963,5067,"In the werewolf world,"],[5067,5226,"this was known as the mate bond."],[5505,5668,"But I was a human."],[5697,5889,"How could I feel it so intensely?"],[6139,6302,"There's no point in telling him now,"],[6302,6360,"is there?"],[6393,6598,"Will he even care if I die?"],[6685,6798,"Don't worry baby."],[6902,7032,"No matter what, I will protect you"],[7032,7119,"with my life."],[8333,8425,"Was that Ally?"],[8512,8566,"Alpha."],[8591,8658,"You said you needed"],[8658,8746,"something earlier."],[8808,8871,"I need you to hire"],[8871,8967,"the best construction crew"],[8967,9113,"and prepare a baby room for me."],[9213,9300,"Ally's pregnant."],[9738,9818,"And make the room pink."],[9930,10022,"That's her favorite color."],[11836,12012,"He didn't come home last night."],[12012,12099,"That means he spent"],[12099,12291,"the entire night with Emma."],[12416,12508,"Goddess."],[12541,12737,"Why does my heart hurt so bad?"],[13580,13638,"Ally?"]],"6":[[70,125,"Ally?"],[1626,1735,"Is everything okay?"],[1785,1985,"Is he concerned about me?"],[1993,2110,"I’m...I'm fine."],[2352,2427,"Cyrus."],[2694,2844,"The baby is making me sick."],[3036,3090,"I know."],[3457,3549,"Morning sickness?"],[3666,3728,"It's fairly common"],[3728,3816,"in all pregnant women."],[3895,3999,"Take a Zofran, you'll be fine."],[4079,4133,"No."],[4162,4237,"Cyrus..."],[4237,4300,"I need you to prep"],[4300,4396,"the guest room for Emma."],[4679,4742,"She's hurt."],[4842,4900,"She's going to move in"],[4900,4950,"for a few days"],[4950,5059,"so I can take care of her."],[5238,5347,"You are bringing another woman"],[5347,5447,"into our home?"],[5530,5663,"But you're my husband."],[5801,5847,"Why?"],[5847,6001,"Why are you taking care of her?"],[6043,6189,"No, I refuse!"],[6443,6581,"Don't you walk away from me!"],[6644,6719,"We both know damn well"],[6719,6835,"this marriage is a sham!"],[7115,7315,"Three years ago, I saved your life."],[7403,7528,"And how do you repay me?"],[7611,7711,"By lying to me."],[7891,8020,"There it is again."],[8020,8145,"My original sin."],[8216,8337,"Something that Cyrus"],[8337,8458,"will never forgive me for."],[8562,8683,"You know more than anything."],[8733,8837,"I wanted to end the war"],[8837,8921,"with the humans."],[8963,9079,"So you used my weakness"],[9079,9163,"against me."],[9225,9426,"You tricked me into marrying you."],[9572,9684,"My father is the leader"],[9684,9784,"of the human world."],[9830,9947,"He was ready to make peace"],[9947,10055,"with the werewolves."],[10085,10243,"No marriage pact was needed."],[10293,10397,"But I was desperate."],[10435,10556,"Desperate to escape"],[10556,10681,"the prison of my family."],[10777,10960,"So I lied to both sides"],[10960,11161,"and tricked Cyrus into marrying me."],[11340,11423,"How long do you plan"],[11423,11544,"to hold that over my head?"],[11661,11790,"Three years,"],[11790,11957,"Cyrus, has it not been enough?"],[12070,12191,"Am I not trying my best"],[12191,12287,"to be your love,"],[12287,12441,"your...your mate, your wife?"],[12495,12537,"No!"],[12712,12812,"It's not enough!"],[12862,12983,"It will never be enough!"],[13117,13259,"Then why don't we get a divorce?"],[13450,13638,"Break the mate bond,"],[13638,13780,"and just go be with Emma."],[13888,14009,"You know if I break the mate bond,"],[14009,14114,"you little human body"],[14114,14193,"won't be able to handle it."],[14506,14572,"Not to mention,"],[14706,14798,"you're carrying my pup."],[15131,15190,"Now,"],[15281,15398,"go prep the guest room."],[15828,15949,"Don't make me ask twice."]],"7":[[975,1055,"My legs..."],[1155,1259,"They feel so weak."],[1372,1476,"Can you take her upstairs?"],[1514,1584,"Of course, Alpha."],[1680,1789,"Cyrus, I—"],[1789,1939,"I don't feel comfortable"],[1939,2068,"with random men touching me."],[2160,2260,"Can you carry me?"],[2331,2398,"Of course."],[3611,3682,"Is her room ready?"],[3920,3953,"Yes."],[4124,4220,"Hello, Luna Ally."],[4220,4471,"I’m... I'm so sorry for the trouble."],[4546,4683,"You're no trouble at all, Emma."],[5759,5893,"Soon Ally,"],[5905,6076,"your husband will be mine."],[6089,6239,"I will take..."],[6239,6381,"everything from you."],[7378,7520,"This feeling again."],[7574,7782,"Why does it hurt so much?"],[9280,9376,"What are you two doing?"]],"8":[[629,709,"Ally,"],[709,838,"it's not what it looks like."],[959,1146,"Alpha has healing powers."],[1184,1405,"His kiss will help me heal."],[1589,1701,"Is this what you’re doing now?"],[1956,2160,"Kissing other women in our home"],[2160,2239,"in the name of..."],[2239,2327,"of..."],[2327,2444,"of healing?"],[2498,2602,"Do you have any respect"],[2602,2690,"for our marriage?"],[2752,2923,"Emma got hurt protecting the pack."],[2965,3073,"She's in a lot of pain."],[3169,3286,"That kiss was not romantic"],[3286,3374,"in any sense."],[3995,4095,"Luna Ally,"],[4141,4320,"the Alpha is telling the truth."],[4371,4454,"The Alpha’s kiss has"],[4454,4571,"special healing properties."],[5005,5138,"But I'm your Luna."],[5255,5509,"I can feel the pain of you kissing another woman,"],[5509,5626,"through the mate bond."],[6047,6160,"I'm so sorry that..."],[6235,6343,"this is my fault, I..."],[6427,6527,"I should go."],[6569,6635,"No."],[6777,6869,"You need to rest."],[7223,7319,"You know what you should be doing"],[7319,7507,"instead of getting mad like a crazy woman?"],[7636,7816,"You should be helping me take care of Emma!"],[7974,8166,"She got hurt fighting bravely against"],[8166,8258,"the Stormborn coven."],[8571,8687,"While she’s protecting our borders,"],[8687,8800,"you're living the carefree life"],[8800,8892,"of a housewife."],[9417,9584,"So that's how he really thinks of me."],[9651,9855,"All those chores around the house,"],[9855,10018,"all those dinners cooked,"],[10018,10210,"clothes pressed and cleaned,"],[10310,10422,"they mean nothing to him."],[10468,10523,"Alpha,"],[10556,10731,"I just got a text from the elders and Josh."],[10769,10835,"We have a lead"],[10835,10969,"on the fruit of the Arbor Vitae."],[11140,11190,"Really?"],[11332,11569,"Why is Cyrus looking for the Arbor Vitae?"],[11644,11711,"You hear that?"],[11757,11849,"We got a lead."],[11991,12120,"I'll go talk to the elders now."],[12241,12328,"Don't worry, Emma."],[12370,12429,"No matter what,"],[12429,12587,"I'll find that sacred fruit and heal you."],[12641,12766,"Thank you, Cyrus."],[12858,12954,"I don't know what I would do"],[12954,13038,"without you."],[13133,13321,"He's looking for the fruit?"],[13338,13475,"To heal Emma?"],[13584,13734,"But I need it to survive."],[13830,13909,"Pull the car around."],[13930,13980,"Let's go."],[14610,14760,"Get Emma anything she needs."],[14856,15002,"Make yourself useful for once."],[15732,15924,"Well, well, well."],[16061,16249,"Didn't expect that, did you, Ally?"]],"9":[[66,216,"You know about my condition?"],[408,442,"How?"],[583,671,"Of course I know."],[775,934,"That's how I came up with this"],[934,1046,"brilliant plan."],[1255,1418,"With a little help, of course."],[1739,1835,"My devination shows that"],[1835,2056,"the Luna of Blackstone Pack is pregnant."],[2077,2223,"That bitch is pregnant?"],[2260,2385,"Luck is not on her side."],[2435,2573,"The baby's slowly killing her."],[2702,2836,"If you wish to take back Cyrus,"],[2836,2998,"you must do exactly as I say."],[3457,3570,"Here's what's going to happen, Ally."],[3691,3816,"You're going to die either way."],[3891,4133,"If Cyrus doesn't find the fruit,"],[4133,4208,"you die."],[4358,4512,"If he does,"],[4512,4675,"he'll give it to me,"],[4675,4808,"and you'll still die."],[4917,5030,"Win win for me."],[5100,5259,"So you're not even sick?"],[5338,5492,"You lied about all of this."],[5593,5864,"So the dumb bitch has a brain."],[5947,6076,"I want you to feel..."],[6147,6427,"what it's like to lose everything."],[6481,6648,"To fall into despair."],[6831,7027,"To have your hope shattered."],[7090,7382,"To watch me take everything"],[7382,7486,"you have."],[7582,7665,"Your home,"],[7836,7916,"your husband,"],[8170,8249,"your baby."],[8316,8391,"Don't you dare"],[8391,8487,"come near my baby!"],[9188,9367,"You weak, pathetic human!"],[9409,9476,"You think you can put"],[9476,9630,"your filthy hands on me?"],[9784,9909,"Ally, where's my briefcase?"],[10043,10172,"I can't find it downstairs."],[10764,10885,"What the hell are you doing?"],[11190,11294,"You are not seriously"],[11294,11369,"going to fall for that."],[11369,11478,"She just pushed herself!"],[11599,11811,"Cyrus, I was just trying to"],[11811,11978,"thank Ally for her hospitality."],[11978,12149,"I don't know why she got so upset"],[12149,12245,"and pushed me."],[12262,12454,"Apologize to Emma right now."],[12604,12758,"She's, she's lying."],[12758,12879,"She's not even sick!"],[13279,13484,"I said apologize."],[13588,13755,"I am not apologizing."],[13934,14059,"I haven't done anything wrong."],[14059,14180,"You're just too blind to see"],[14180,14330,"what's right in front of your eyes!"],[14806,14877,"Then get out!"],[15098,15202,"I don't want to see your face!"]],"10":[[2385,2515,"Am I dying?"],[3190,3349,"It hurts so much."],[3440,3791,"Cyrus, my whole body hurts."],[5672,5951,"Cyrus, it hurts..."],[6514,6594,"What is it?"],[6656,6719,"Nothing."],[6794,6881,"Cyrus."],[7340,7444,"When you're here, I..."],[7565,7695,"I feel so safe."],[8074,8208,"We should have been mates."],[8425,8562,"I wish I was your Luna."],[9042,9142,"It's all in the past."],[9346,9471,"Ally is my mate now."],[9605,9667,"Once I cure you"],[9667,9813,"with the fruit of the Arbor Vitae,"],[9813,9897,"you'll be healed."],[10110,10264,"You can find your own happiness."],[10326,10472,"Settle down with a mate,"],[10472,10618,"have a pup, start a family."],[10881,10994,"I promise your father to always"],[10994,11094,"keep watch over you."],[11215,11294,"Are you..."],[11486,11586,"in love with her?"],[11795,11845,"No."],[12095,12316,"But she is my wife, carrying my pup."],[12399,12554,"I have a duty to protect and provide"],[12554,12595,"for her."],[13317,13471,"Cyrus."],[13471,13571,"It hurts..."],[13655,13759,"I have to go see the elders."],[13759,13822,"Get some rest."],[13943,14051,"Oh, and I'll find the"],[14051,14134,"best pain medication"],[14134,14210,"for your condition."],[14251,14393,"But don't kiss me like that again."],[14447,14564,"I don't want Ally suffering"],[14564,14664,"while carrying my pup."],[14948,15102,"He does care about her?"],[15127,15244,"That bitch!"],[15715,15932,"No, my baby..."],[16016,16207,"I can't die tonight."],[16245,16345,"Cyrus..."],[16466,16520,"Ally?"],[16662,16700,"Ally?"],[18618,18672,"Ally?!"]],"11":[[1151,1238,"Cyrus."],[1418,1526,"You came for me."],[1680,1760,"Maybe there's a place"],[1760,1893,"for me in his heart."],[1893,2047,"Even if it's only a little bit."],[2373,2469,"Doctor said you are fine."],[2556,2694,"Slightly anemic, but fine."],[2761,2852,"So why did you summon me"],[2852,2932,"with the mate bond?"],[2990,3040,"What?"],[3174,3274,"No I didn't."],[3290,3424,"I heard you loud and clear."],[3499,3607,"Don't summon me for such"],[3607,3691,"trivial matters."],[3745,3832,"I had important things"],[3832,3949,"to discuss with the elders."],[4154,4208,"Right."],[4308,4567,"Like finding the fruit of Arbor Vitae"],[4567,4729,"for your precious Emma."],[4875,4975,"For the last time,"],[5038,5171,"Emma and I have nothing going on"],[5171,5242,"between us."],[5768,5839,"Whatever."],[5976,6035,"There's no point"],[6035,6110,"in explaining to you."],[6247,6339,"Look,"],[6339,6435,"just don't use the mate bond"],[6435,6510,"to summon me unless"],[6510,6635,"it's absolutely necessary."],[7144,7303,"Once upon a time,"],[7303,7428,"I really thought I had a chance"],[7428,7515,"with him."],[7515,7645,"To be loved."],[7645,7799,"To be heard."],[7799,7887,"To be seen."],[8963,9038,"Cyrus."],[9513,9592,"Thank you."],[9676,9813,"You humans can't do anything right."],[10201,10326,"Next time you're in danger,"],[10326,10410,"you can try calling me through"],[10410,10464,"the mate bond."],[10981,11169,"He's cold on the outside,"],[11169,11357,"but warm on the inside."],[11515,11607,"Cyrus, let's just"],[11607,11699,"break the mate bond."],[11936,12012,"Then you'll never hear me"],[12012,12078,"call again."],[12545,12670,"Let's just end this."],[12670,12812,"Whatever this is."],[13309,13463,"You don't get to say that, Ally."],[13500,13621,"You lied to me first,"],[13621,13730,"forced me to marry you,"],[13730,13834,"and now you're carrying my baby"],[13834,13901,"and you want out?"],[14214,14347,"Who do you think you are?"],[14451,14518,"Yes,"],[14647,14760,"I lied to you."],[14869,15056,"And for that, I will pay with my life."],[15156,15344,"What more do you want from me?"]],"12":[[29,154,"What is that supposed to mean?"],[325,408,"Did something happen to you"],[408,504,"and you're not telling me?"],[658,834,"No, no, nothing."],[834,892,"I'm just..."],[992,1101,"I'm just tired."],[1251,1326,"Why don't you go"],[1326,1447,"so I can get some sleep?"],[1797,1918,"I see what this is about."],[2110,2189,"What are you doing?"],[2656,2777,"Giving you what you want."],[3553,3624,"Get off."],[4116,4225,"Isn't this what you like?"],[4341,4404,"Me kissing you?"],[5501,5672,"You know you can't fight the mate bond."],[5743,5822,"Neither of us can."],[6093,6227,"You want me to fuck you right here?"],[6227,6302,"Huh?"],[6452,6556,"Is that what you want?"],[6556,6660,"Will that make you feel better?"],[8174,8266,"Cyrus..."],[8529,8650,"You're already wet for me."],[14677,14760,"Say you want me."]],"13":[[0,83,"Say you want me."],[241,421,"I don't love you anymore, Cyrus."],[617,721,"What did you say?"],[1055,1172,"I gave you everything."],[1247,1338,"The clothes on your back,"],[1338,1438,"the roof above your head."],[1718,1935,"You married me for money and power."],[2068,2147,"And now you want out?"],[2277,2469,"You'll be nothing without me!"],[2523,2736,"It was never about money or power."],[2969,3065,"You don't have a place"],[3065,3319,"in my heart anymore, Cyrus."],[3707,3757,"Besides,"],[3757,3908,"shouldn't you go sleep with Emma?"],[4054,4183,"What's the point of sleeping with"],[4183,4308,"a woman that you don't even love?"],[5251,5417,"You want me gone?"],[5476,5530,"Fine."],[5789,5901,"Don't act so rightious."],[6026,6222,"You're just a liar and a fraud."],[6569,6694,"It's all you'll ever be."],[8008,8070,"Ally?"],[8867,8967,"Drink this."],[9563,9743,"Your condition is getting worse."],[9826,9918,"Did you tell Cyrus"],[9918,10064,"you need the fruit of Arbor Vitae?"],[10264,10456,"You can't put this off any longer."],[10623,10727,"Ally, I'm going to tell him."],[10910,11006,"if he doesn't find the fruit,"],[11006,11081,"you're going to die."],[11206,11251,"Wait."]],"14":[[75,137,"Hey."],[179,241,"Wait."],[542,646,"Cyrus is never going to"],[646,788,"choose me over Emma."],[959,1063,"I rather save myself"],[1063,1251,"the humiliation of being rejected."],[1343,1455,"Don't say that."],[1514,1572,"Listen."],[1597,1701,"You're his Luna."],[1743,1901,"You're carrying his child."],[1964,2131,"He won't just let you die."],[2698,2769,"While she is protecting"],[2769,2861,"our borders, you're living in"],[2861,3015,"a carefree life of a housewife."],[3061,3203,"Make yourself useful for once."],[3495,3670,"He thinks so lowly of me."],[3770,3895,"I want to prove him wrong."],[4016,4187,"The Solstice Ceremony is coming up."],[4504,4637,"Maybe if I do a perfect job,"],[4637,4721,"then he'll owe it to me"],[4721,4813,"to find the fruit."],[4879,5000,"So I'll tell him then."],[5167,5259,"I promise."],[9626,9743,"Chris wants to talk?"],[9813,9947,"Him and Rashida."],[10014,10172,"They're the only ones who never"],[10172,10214,"hated me."]],"15":[[1267,1330,"Chris."],[1543,1697,"I made some fresh pastries for you."],[1810,1910,"Thank you, Ally, but..."],[1976,2093,"Are you okay?"],[2181,2268,"You look exhausted."],[2327,2481,"Yeah, I've just been busy"],[2481,2669,"prepping for the solstice ceremony."],[2865,2977,"Oh, and..."],[3111,3303,"I'm also pregnant."],[3549,3757,"Wow, I'm so happy for you."],[3757,3845,"That's..."],[4041,4129,"Why do you look miserable?"],[4254,4366,"I guess it doesn't hurt to tell you"],[4366,4433,"the truth."],[4575,4742,"You are one of my only friends."],[5146,5213,"This pregnancy"],[5213,5351,"is probably going to kill me."],[5522,5643,"Did you know that a human's body"],[5643,5722,"can't handle carrying"],[5722,5830,"an Alpha’s child?"],[5901,6001,"What?"],[6001,6085,"What are you going to do?"],[6143,6222,"Well, there is a chance"],[6222,6297,"that I can live."],[6297,6489,"But only if Cyrus finds"],[6489,6585,"the fruit of Arbor Vitae"],[6585,6681,"and gives it to me."],[6948,7052,"But the problem is"],[7052,7190,"that Emma also needs it."],[7248,7365,"He’s going to pick Emma over you?"],[7482,7561,"That's horrible!"],[7649,7732,"We'll see."],[7920,8066,"If he does, I'm leaving the pack."],[8345,8458,"I can take you away now."],[8537,8629,"We can go anywhere."],[8775,8913,"Thank you, Chris,"],[8971,9159,"but I think I need to try one more time."],[9376,9538,"For my life and my baby’s."],[9897,10055,"I should probably get going, but..."],[10130,10235,"talk again soon？"],[12637,12804,"You have any idea what time it is?"],[12908,12971,"Where were you?"],[13496,13559,"What's that smell?"]],"16":[[20,158,"Cyrus hates rogues."],[221,392,"If he finds out I was talking to Chris,"],[417,521,"he'll go after him."],[629,709,"I was,"],[709,842,"I was out late planning"],[842,959,"for the solstice ceremony."],[1568,1714,"I smell another wolf’s scent on you."],[1835,1931,"Are you lying to me?"],[2035,2193,"No, I ran into a couple people"],[2210,2285,"while I was out,"],[2364,2427,"so I must have just"],[2427,2535,"picked the scent up from them."],[2840,3032,"Is he jealous?"],[3065,3211,"Does that mean he cares?"],[3353,3407,"Listen."],[3541,3670,"The solstice is the most important"],[3670,3770,"ceremony of the year."],[3858,3916,"You are the Luna."],[3995,4133,"Remember, you represent me"],[4133,4187,"and the pack."],[4241,4354,"Don't do or say"],[4354,4483,"anything that will embarrass me."],[4571,4633,"That includes"],[4633,4767,"being too close to random men."],[4829,4913,"Is that clear?"],[5951,6131,"My hope has turned to dust."],[6164,6410,"How many times must I be shattered"],[6410,6527,"before I learn to stop"],[6527,6623,"hoping for a love"],[6623,6731,"that will never be mine?"],[8888,8963,"Finally."],[9004,9171,"I've been waiting two damn hours."]],"17":[[342,458,"Is my dress okay?"],[658,709,"It’s fine."],[809,859,"Let’s go."],[2840,2890,"You are pregnent."],[3032,3082,"Be careful."],[5326,5459,"This whole “faking being sick” thing"],[5459,5534,"is getting old, you know?"],[5826,5939,"Cyrus, I have something"],[5939,6006,"to tell you."],[6114,6134,"I have something"],[6134,6227,"I need to tell you, too."],[6418,6481,"This is your first"],[6481,6577,"Blackstone ceremony."],[6723,6781,"Follow my lead"],[6781,6873,"and don’t screw anything up."],[8958,9125,"Cyrus."],[9180,9321,"I didn't know you two"],[9321,9442,"are showing up together."],[9763,9947,"You...didn’t tell Ally?"],[10314,10389,"Today's ceremony"],[10389,10506,"will be hosted by Emma."],[10919,11019,"As acting Luna."],[11273,11311,"What?"]],"18":[[237,312,"Emma's always dreamed of"],[312,487,"presiding over the Solstice as Luna."],[646,850,"And...you said yes"],[850,1021,"without even talking to me first?"],[1284,1405,"Why would you ever approve"],[1405,1564,"such an absurd request?"],[1647,1743,"We still don't have any leads"],[1743,1843,"on the Arbor Vitae."],[1956,2097,"Emma hasn't got much time left."],[2277,2394,"Fulfilling this dream of hers"],[2394,2481,"is the least I can do."],[2610,2769,"She's lying."],[2769,2961,"She's not even sick or dying."],[3128,3261,"This is all part of her scheme"],[3261,3370,"to become Luna."],[4546,4708,"Cyrus, she's..."],[4742,4979,"she's saying such hurtful things."],[6869,7027,"Don't talk to Emma like that."],[7474,7628,"She's manipulating you."],[7724,7916,"You're blinded by your love for her."],[8133,8233,"There's nothing going on"],[8233,8341,"between me and Emma."],[8470,8621,"This is her only chance to be happy."],[8942,9029,"Can you just give her this"],[9029,9088,"one moment?"],[9576,9701,"Just this one moment?"],[9976,10043,"No."],[10164,10272,"Whatever she wants,"],[10272,10368,"you give it to her."],[10643,10831,"Even if it's my spot as Luna."],[10973,11115,"Even if it costs me my life."],[11394,11519,"Stop being so dramatic."],[11795,11986,"You're always thinking about her."],[12203,12391,"What about me, Cyrus?"],[12554,12641,"What do you want?"],[13025,13138,"It's not what I want."],[13246,13355,"It's what I need."],[14001,14159,"I need the fruit of Arbor Vitae."]],"19":[[112,237,"What are you talking about?"],[387,588,"Cyrus,"],[613,704,"the truth is that—"],[704,821,"Forget it, Cyrus."],[917,1026,"If..."],[1159,1372,"If Ally doesn't approve,"],[1472,1589,"I won't be Luna."],[1868,2097,"No way in hell"],[2110,2277,"am I gonna let you tell Cyrus"],[2277,2369,"you're dying."],[2473,2523,"No."],[2815,2986,"Ally will do as I say."],[3094,3169,"I'm not putting up"],[3169,3328,"with her childish behavior anymore."],[3370,3470,"Shocker."],[3561,3649,"All you ever do"],[3649,3816,"is order me around."],[3816,3903,"I'm done."],[3983,4108,"Oh, sorry, Ally, I..."],[4108,4195,"I didn't mean"],[4195,4350,"to come between you and Cyrus."],[4350,4396,"Oww!"],[4625,4700,"Liar."],[4758,4959,"Stop faking your innocence."],[5084,5192,"She hurt me, Cyrus."],[5192,5259,"I..."],[5317,5492,"I don't know why Ally hates me"],[5492,5559,"this much."],[5822,6022,"Emma is a Blackstone hero."],[6210,6368,"You have no right to attack her."],[6452,6652,"You call that attacking?"],[6681,6740,"I'll show you what a"],[6740,6852,"real attack looks like."],[7353,7507,"Ally, are you insane?"],[7999,8145,"You feel bad for her?"],[8470,8633,"Fine."],[8633,8804,"Just..."],[8804,8917,"hit me back then."]],"20":[[1572,1726,"We'll talk after the ceremony."],[2147,2260,"No one in the Blackstone Pack"],[2260,2369,"has ever defied"],[2369,2527,"Alpha Cyrus like that."],[2581,2706,"Ally needs to be punished."],[2794,2902,"Exactly."],[2932,3132,"She's unworthy of being Luna."],[3174,3349,"Should’ve been Emma from the start."],[3399,3528,"Everyone knows Alpha"],[3528,3699,"plans to ask the Moon Goddess"],[3699,3870,"where to find the Arbor Vitae’s"],[3870,4099,"sacred fruits to save Emma."],[4362,4504,"So that's why you care so much"],[4504,4629,"about the ceremony..."],[4667,4904,"It's all so you can save her."],[5518,5609,"Silence!"],[5755,5947,"Anyone who speaks ill of the Luna"],[5985,6147,"will face serious consequences."],[6172,6343,"Wasn’t Alpha Cyrus just super pissed at"],[6343,6456,"Luna Ally?"],[6456,6635,"Why’s he defending her now?"],[6898,7098,"As if he'd ever actually defend me."]],"21":[[116,254,"Quit stirring up trouble."],[350,471,"Three years ago,"],[521,721,"I fell madly in love with Cyrus"],[746,913,"and asked him to marry me."],[984,1034,"I thought that"],[1034,1167,"if I just loved him enough,"],[1213,1363,"one day he'd accept me."],[1484,1576,"But now,"],[1614,1814,"I realize how wrong I was."],[1868,2102,"Enough chatter!"],[3232,3457,"It's time."],[3457,3707,"The solstice begins now."],[4562,4654,"Cyrus,"],[4771,4867,"if you won't give me"],[4867,5088,"even a sliver of hope..."],[5088,5276,"then we're done."],[5355,5551,"As Alpha of the Blackstone Pack,"],[5576,5680,"I grant Emma the right"],[5680,5834,"to stand as our Luna"],[5834,5939,"and offer our loyalty"],[5939,6147,"to the moon goddess."],[6147,6393,"We humbly ask her to bless our pack"],[6393,6569,"and reveal the Arbor Vitae’s sacred fruit."],[6760,6873,"That mysterious man said that"],[6873,7132,"if I host the ritual as Luna,"],[7165,7349,"Ally would be forced to leave."],[7369,7640,"It’s finally time for me to take"],[7649,7816,"everything from her."],[9134,9363,"Oh, Moon Goddess,"],[9363,9647,"please shine your light upon our path."],[10865,11094,"Oh, Great Moon Goddess,"],[11094,11365,"please shine your light upon our path."]],"22":[[258,442,"The crystal has to glow"],[442,554,"for the Goddess to hear us."],[554,729,"Why isn't anything happening?"],[750,829,"Did the Moon Goddess"],[829,963,"reject Emma's call?"],[1322,1426,"Let me try again."],[1568,1745,"Great moon goddess,"],[1745,1985,"please shine your light upon our path."],[2356,2481,"I finally got the chance"],[2481,2581,"to stand here as Luna."],[2648,2773,"Why is the Moon Goddess"],[2773,2873,"ignoring me?"],[3111,3215,"Emma,"],[3282,3453,"the Moon Goddess has rejected"],[3453,3566,"your call."],[3624,3778,"If the Moon Goddess rejects us"],[3778,3908,"during the ceremony,"],[3920,4074,"our whole pack could be cursed,"],[4074,4204,"and Alpha won't get any clue"],[4204,4312,"to the sacred fruit."],[4533,4833,"Ally is Alpha Cyrus’s mate,"],[4850,5055,"our true Luna."],[5055,5305,"Maybe we should let her try."]],"23":[[433,633,"Everyone's watching."],[650,775,"Don't screw this up."],[2402,2510,"(For Emma.)"],[3078,3278,"Moon Goddess..."],[3561,3782,"I knew it, Alpha Cyrus should have"],[3782,3924,"severed the mate bond."],[3962,4170,"The Goddess doesn't want a human with us."],[4175,4270,"Exactly!"],[4270,4512,"Werewolves and humans are enemies!"],[4550,4694,"Maybe she's why the Goddess"],[4694,4900,"denied us our blessing."],[5880,6081,"Please shine your light..."],[6139,6339,"upon our path."],[8408,8512,"Please show us..."]],"24":[[696,784,"By the Goddess..."],[821,938,"Does that count as receiving the"],[938,1088,"Moon Goddess’s blessing?"],[1622,1676,"Ally!"],[1718,1818,"Are you okay?"],[1872,1910,"Alpha,"],[1910,1985,"I... I don't think"],[1985,2102,"the ritual is complete yet."],[2127,2223,"It's complete!"],[3678,3770,"She's in V-tach,"],[3774,3853,"no pulse!"],[3866,4066,"Prep the defibrillator."],[5784,5964,"I love you, Cyrus."],[6060,6114,"I'm going to do"],[6114,6189,"everything I can"],[6189,6318,"to be good to you."],[6435,6552,"And even if you fall for me"],[6552,6698,"just a little,"],[6698,6894,"that will be enough."],[7866,7945,"What's happening to her?"]],"25":[[58,145,"What’s happening to her?"],[204,300,"Alpha Cyrus,"],[300,521,"Luna Ally is in critical condition."],[579,675,"We’re still waiting for details"],[675,750,"from the doctor."],[3599,3682,"Cyrus,"],[3691,3778,"I made your favorite."],[3778,3874,"Pan-seared salmon."],[3966,4033,"Come try it!"],[4291,4391,"Just because you know what I like"],[4391,4529,"doesn’t mean I’ll be impressed."],[5463,5693,"I love you, Cyrus."],[5734,5939,"Even if you don't love me back,"],[5989,6147,"I still keep trying."],[6343,6519,"Just hoping one day"],[6519,6598,"you'll like me."],[7457,7590,"Not happening."],[10251,10318,"Ally..."],[10377,10460,"you'll be okay, right?"],[10673,10760,"How is Ally?"],[10777,10944,"She’s in critical condition."],[10990,11131,"The baby is taking a real toll"],[11131,11215,"on her body."],[11332,11411,"If this keeps up..."],[11469,11599,"she might not make it."],[11619,11703,"What?"],[11815,11911,"She’s dying?"]],"26":[[304,525,"No no no... that can't be."],[525,675,"She's always been healthy."],[675,867,"I'm so sorry."],[913,1009,"She's been sick,"],[1105,1238,"and you never even cared."],[1317,1468,"Do you know something?"],[1468,1564,"It's the baby."],[1693,1830,"The human body can't handle"],[1830,1972,"giving birth to a werewolf."],[1972,2027,"What?"],[2085,2206,"I've never heard of that."],[2298,2360,"It's here,"],[2402,2527,"and on my notes."],[2706,2756,"From the moment"],[2756,2823,"she's been pregnant,"],[2823,2965,"she's been hanging on by a thread."],[3161,3294,"I never knew any of this..."],[3732,3862,"Well, then maybe ask yourself..."],[4004,4124,"why she didn't tell you."],[4316,4462,"Did you actually care about her?"],[4462,4546,"Of course I do!"],[4587,4696,"She's my Luna."],[4859,4963,"Why didn't you notice she..."],[4963,5075,"she wasn't okay?"],[5117,5163,"Where were you"],[5163,5309,"when she needed you?"],[5363,5447,"You were with Emma."],[5580,5714,"She's the one you care about."],[5905,6060,"Honestly, I've..."],[6060,6181,"never seen you show Ally"],[6181,6343,"any concern at all."],[6418,6594,"Oh my Moon Goddess."],[6594,6715,"So when Alpha Cyrus"],[6715,6794,"healed Emma..."],[6794,6906,"Ally must’ve been in"],[6906,6977,"so much pain!"],[6977,7077,"I mean, she's the one"],[7077,7186,"who mate-bonded with him."],[7386,7465,"Alpha Cyrus,"],[7474,7545,"she still might"],[7545,7640,"have a chance to live,"],[7640,7803,"but only if you save her."],[7845,7924,"What do you mean?"],[7987,8128,"She needs the sacred fruit of"],[8128,8245,"the Arbor Vitae."],[8391,8454,"What?"]],"27":[[79,262,"She wanted to tell you herself."],[417,546,"She never told me anything."],[546,613,"Or maybe you just"],[613,688,"didn't listen."],[930,1034,"I'll be right there."],[1155,1242,"Wait, wait."],[1242,1292,"Cyrus,"],[1292,1451,"I really need to tell you something."],[1451,1551,"It's urgent."],[1714,1776,"Cyrus,"],[1776,1926,"I have something to tell you."],[2043,2185,"Ally..."],[2185,2268,"is this what you were trying"],[2268,2394,"to tell me all along?"],[2506,2669,"You were so cold to her."],[2815,2982,"No wonder she was so hurt."],[3019,3161,"She even thought about leaving."],[3249,3328,"What are you saying?"],[3353,3411,"She's my Luna."],[3411,3528,"She's supposed to be with me."],[3616,3732,"Stay by your side,"],[3803,3883,"only to watch you"],[3883,4016,"give everything to Emma?"],[4087,4149,"There's nothing"],[4149,4295,"going on between me and Emma."],[4491,4612,"I’m not leaving Ally."],[4708,4821,"She'll always be my Luna."],[5134,5176,"Josh!"]],"28":[[1038,1130,"Ally,"],[1272,1388,"I never knew a human could die"],[1388,1609,"from carrying a werewolf's child."],[1776,1931,"Why didn't you say anything?"],[2164,2323,"You must've been in so much pain..."],[3144,3244,"I'm sorry."],[3503,3570,"I should have noticed"],[3570,3666,"something was wrong."],[4104,4250,"Ally, please wake up."],[4896,5017,"I'm not giving up on you."],[5442,5572,"Luna Ally's condition has"],[5572,5697,"finally stabilized,"],[5743,5864,"but the next 24 hours"],[5864,6001,"will be critical as to whether"],[6001,6106,"she'll ever wake up."],[6227,6406,"I'll stay with her and keep watch."],[6794,6919,"Alpha Cyrus,"],[6944,7086,"you've been here two days."],[7115,7236,"You need some rest."],[7520,7582,"No."],[7649,7691,"I'll wait here"],[7691,7782,"until she wakes up."],[7957,8087,"Is there any other way to save her?"],[8133,8233,"Besides the Sacred Fruit?"],[8254,8320,"No."],[8395,8491,"The fruit is the only thing"],[8491,8566,"that can heal her."],[8646,8800,"She has to eat the whole thing"],[8800,8888,"for it to work."],[8954,9071,"I know Emma needs it to."],[9250,9342,"So who are you going to save?"]],"29":[[4,83,"I know this isn't an"],[83,191,"easy decision to make."],[417,567,"But please think of Ally,"],[654,767,"for once."],[867,1030,"She loves you so much..."],[1167,1317,"and she's carrying your child."],[2364,2452,"Josh,"],[2485,2627,"reach out to all the elders."],[2736,2798,"No matter what,"],[2798,2886,"within a week,"],[2911,3061,"we need a lead on that Sacred Fruit."],[3507,3603,"You’re going to be okay, Ally."],[4850,4967,"What am I doing?"],[5030,5155,"I'm supposed to hate her."],[5267,5317,"She's the one"],[5317,5463,"who insisted on marrying me."],[5543,5680,"She tricked me."],[5776,5864,"That's the only reason"],[5864,5964,"she ended up like this!"],[6151,6247,"This is all on her."],[6402,6473,"I'm just worried that"],[6473,6594,"if something happens to her,"],[6660,6752,"the humans might use it to"],[6752,6902,"come after our pack again."],[6940,7027,"That's all."],[7094,7223,"That's the only reason I care."],[8053,8299,"This gown must feel awful on you."],[8408,8470,"Ally,"],[8654,8712,"wake up."],[8712,8779,"Let's go home."],[9434,9476,"You're awake?"]],"30":[[125,296,"Ally! You’re awake?"],[1055,1197,"Cyrus?"],[1234,1338,"It's me."],[1393,1468,"I'm here."],[1526,1634,"I'll go get the doctor."],[1893,1972,"Doctor!"],[2256,2331,"Ally!"],[2448,2565,"Finally you're awake!"],[2610,2748,"You scared me so bad."],[2773,2844,"Be careful."],[2915,2982,"She's weak."],[3282,3415,"Will you just..."],[3470,3582,"give us a moment?"],[5351,5447,"Don't worry."],[5447,5626,"The baby's fine."],[5626,5730,"How do you feel?"],[5947,6060,"Tired."],[6160,6268,"Weak."],[6306,6423,"That's normal."],[6489,6639,"The baby's drawing from you."],[6673,6777,"Your body gave out."],[6819,6902,"You've been in a coma"],[6902,7052,"for 34 hours."],[7173,7244,"Rashida…"],[7444,7578,"Cyrus knows I’m dying,"],[7578,7657,"doesn't he?"],[7820,7966,"And he knows the fruit is the only thing"],[7966,8053,"that can save you."],[8124,8254,"Let me guess, he already chose to"],[8254,8354,"give it to Emma."],[8400,8533,"He didn't say anything."],[8646,8712,"Of all I can tell"],[8712,8888,"he's conflicted."],[9013,9113,"It doesn't matter."],[9376,9451,"Emma is always"],[9451,9617,"the right choice in his eyes."],[10026,10189,"Rashida, would you do me a favor?"]],"31":[[4,54,"Rashida,"],[54,166,"would you do me a favor?"],[212,300,"Of course."],[333,400,"What do you need?"],[429,521,"Would you tell Cyrus"],[521,704,"that I told you to exaggerate"],[767,984,"how bad my sickness is?"],[1126,1205,"Don't let him know"],[1205,1272,"that my werewolf"],[1272,1355,"baby's killing me."],[1380,1468,"Why?"],[1522,1634,"He's your mate!"],[1885,2114,"He deserves to know the truth."],[2122,2298,"His true love is Emma."],[2456,2648,"I don't want to make it harder on him."],[2727,2827,"I don't..."],[2848,2994,"want to make him feel guilty."],[2994,3128,"Don't say that."],[3232,3378,"Maybe if he knew the truth,"],[3378,3432,"he'd realize"],[3432,3574,"how much you matter to him."],[3678,3803,"I've stopped fighting."],[3895,4066,"His heart isn't belong to me,"],[4108,4291,"and mine is tired of yearning."],[4437,4579,"I find peace in letting go."],[4742,4833,"I just..."],[4833,4909,"want to leave."],[4909,5067,"I want freedom!"],[5117,5280,"Don't say that."],[5280,5388,"Be strong."],[5388,5497,"For the baby."],[5943,6051,"If I make it far enough"],[6051,6181,"to have this child."],[6210,6360,"I'll reach out to you, oaky?"],[6694,6802,"Rashida,"],[6890,7173,"will you raise my child for me?"],[7261,7369,"Of course."],[7753,7970,"Please promise me."],[7970,8062,"You were the only one"],[8062,8153,"I have left."]],"32":[[450,579,"Is she okay?"],[688,792,"She'll be fine."],[913,1046,"She'll be discharged soon."],[1134,1230,"Alpha Cyrus,"],[1313,1476,"please treat her kindly."],[1555,1676,"She really does love you."],[2202,2248,"Emma,"],[2327,2410,"what are you doing here?"],[2414,2527,"Cyrus, I..."],[2527,2615,"I heard about Ally."],[2673,2794,"She needs the Sacred Fruit too,"],[2794,2902,"doesn't she?"],[2919,3023,"Don't worry."],[3053,3194,"I won't let either of you get hurt."],[3374,3486,"It's okay, Cyrus."],[3586,3707,"Ally is your Luna,"],[3791,3949,"it makes perfect sense"],[3949,4074,"why you would save her first."],[4162,4250,"But..."],[4300,4437,"I have to tell you something."],[4612,4683,"You've been tricked."]],"33":[[133,216,"What do you mean?"],[304,429,"I got this from one of my friends"],[429,496,"at the hospital."],[496,558,"It's..."],[642,767,"Ally’s test results."],[1309,1451,"Anemia?"],[1484,1580,"That's it?"],[1651,1730,"But the doctor said"],[1730,1856,"she's dying!"],[2089,2202,"Dr. Artemis!"],[2423,2540,"Tell me the truth."],[2598,2673,"Is Ally dying,"],[2673,2802,"or does she just have anemia?"],[3115,3224,"Rashida said Luna Ally"],[3224,3307,"wants to keep her"],[3307,3428,"condition confidential."],[3720,3862,"From her report..."],[3862,4133,"she seems to be just anemic."],[4617,4771,"You lied to me, Ally."],[4771,4884,"Again!"],[5146,5305,"She never needed the fruit!"],[5326,5472,"She tricked me again!"],[5530,5689,"Don't be angry, Cyrus."],[5776,5997,"She only did it because..."],[6043,6122,"she loves you"],[6122,6310,"so much."],[6452,6752,"She just wanted you to care."],[6944,7052,"Where are you going?"],[7148,7278,"To figure out the truth."],[7703,7795,"Ally,"],[7870,8020,"enjoy the surprise I’ve"],[8020,8241,"prepared for you."]],"34":[[538,692,"You really are something else."],[729,855,"I almost fell for your act again."],[1034,1163,"But the truth is clear."],[1251,1330,"You haven’t changed."],[1488,1618,"You're still just a liar."],[1793,2010,"Ally, this is not okay!"],[2056,2235,"Cyrus was worried sick about you."],[3174,3328,"Where did you get this?"],[3432,3495,"Emma,"],[3570,3653,"I'm assuming?"],[3891,3978,"What did she tell you?"],[3978,4116,"That I was lying?"],[4329,4500,"Don't put this on Emma."],[4688,4821,"You're the one who’s at fault here!"],[4871,5021,"Lying about dying"],[5055,5163,"to get me to pity you."],[5184,5355,"That's low, even for you."],[5747,5964,"So that's it, then?"],[5972,6022,"You'd believe"],[6022,6189,"a paper over your wife?"],[6277,6373,"You'd believe"],[6373,6473,"another woman,"],[6473,6594,"choose another woman,"],[6594,6748,"love another woman over me"],[6748,6886,"any day, wouldn't you?"],[6886,6986,"Cyrus."],[7036,7082,"I believe what’s"],[7082,7248,"in front of my eyes."],[7315,7411,"Fine."],[7565,7691,"Then I did lie."],[7691,7791,"Is that what you want?"],[7791,7945,"Does that make you happy?"],[8003,8128,"I'm just so..."],[8128,8229,"sick of all of this!"],[8249,8350,"Give the fruit to Emma."],[8350,8462,"I don't need it!"],[8571,8679,"I don't need you!"]],"35":[[550,654,"Did you just..."],[792,913,"slap me?"],[1067,1226,"In sickness and in health..."],[1226,1397,"for rich or for poor..."],[1397,1555,"To love and cherish,"],[1555,1776,"till death do you part."],[1793,2014,"Now we exchange the rings."],[3136,3219,"Even though you tricked me"],[3219,3361,"into marrying you,"],[3361,3486,"you're still my wife."],[3545,3632,"I'll protect you"],[3632,3762,"and respect our marriage."],[3828,4045,"I hope you'll do the same."],[4087,4233,"I will, husband."],[4295,4429,"One day,"],[4429,4508,"I'll melt the ice"],[4508,4683,"around your heart, Cyrus."],[4763,4821,"You'll see that"],[4821,4979,"my love was never lie."],[5067,5163,"Just give me the chance"],[5163,5263,"to prove it."],[5905,5943,"Ally,"],[5985,6010,"I..."],[6101,6264,"No, let’s end this."],[6443,6598,"I want to sever our mate bond."],[6598,6752,"I want a divorce."],[9038,9213,"You have no right to even suggest that!"],[9284,9438,"You dragged me into this marriage"],[9442,9526,"three years ago."],[9572,9676,"If anyone’s ending it,"],[9701,9747,"it’s me!"],[10147,10193,"Fine!"],[10289,10435,"End it then!"],[10468,10581,"Go be with Emma!"],[10585,10694,"Do whatever you want."],[10702,10810,"Let’s never see each other"],[10819,10894,"ever again!"],[11544,11711,"I’m never giving you what you want."],[11978,12141,"Keeping this going is only gonna"],[12141,12308,"make us suffer longer!"],[12520,12670,"You should be used to this by now."],[12733,12825,"Don’t"],[12879,13025,"even think about leaving me."],[13184,13292,"You still need to make up"],[13292,13396,"for what you’ve done."],[14572,14731,"Emma’s coming over for dinner."],[14881,15031,"Since you’re not actually dying,"],[15298,15444,"go home now..."],[15582,15728,"and prepare the food."],[16925,17117,"Cyrus,"],[17117,17238,"one last dinner."],[17350,17513,"This is where it ends."],[17530,17721,"I finally learned my lesson."],[17780,17992,"Now I know this is the price"],[17997,18093,"of loving you."]],"36":[[304,513,"Thank you Cyrus for inviting me over."],[563,621,"No problem."],[921,950,"Oh,"],[1026,1096,"this looks..."],[1163,1213,"interesting."],[1430,1501,"I agree."],[1805,1881,"Cyrus,"],[1968,2106,"I miss living here."],[2377,2515,"I should come by more often."],[2836,2919,"Whatever."],[3023,3115,"This won't be my home"],[3115,3215,"for much longer."],[3837,3945,"Good news."],[4033,4166,"We got a lead on the Sacred Fruit."],[4441,4612,"Josh is already out verifying it."],[4792,4867,"That's amazing,"],[4867,4938,"Cyrus."],[4975,5130,"I'm going to be saved!"],[5184,5263,"Let's eat!"],[5568,5701,"You know Cyrus hates zucchini?"],[5830,5905,"Ally, are..."],[5972,6047,"are you doing this"],[6047,6264,"as a petty form of revenge?"],[6314,6489,"Because Cyrus is giving the fruit"],[6489,6552,"to me?"],[6748,6852,"If he doesn't like it,"],[6852,6973,"he doesn't have to eat it."],[7048,7111,"Ally,"],[7161,7298,"you know you were in the wrong for"],[7298,7453,"trying to steal the Sacred Fruit."],[7586,7665,"Why are you playing"],[7665,7882,"the victim now?"],[8375,8479,"Where are you going?"],[8504,8562,"You still haven't"],[8562,8783,"apologized to Emma."],[8958,9100,"I'm not apologizing."],[9192,9305,"I don't owe her anything."]],"37":[[100,262,"It's okay, Cyrus."],[350,508,"Ally’s your Luna, I..."],[575,721,"I won't hold the Sacred Fruit"],[721,846,"thing against her."],[913,1038,"Let me go talk to her."],[4625,4842,"Ally, I am genuinely trying to make"],[4842,4913,"peace with you!"],[4913,5109,"Why are you being so mean to me?"],[5309,5405,"What... what are you talking about?"],[5405,5555,"You just poured wine on yourself."],[5613,5684,"Really?"],[5972,6168,"You really hate me this much?"],[6202,6327,"Stop slandering me."],[6327,6439,"She's lying."],[6439,6560,"How long are you going"],[6560,6727,"to throw this hissy fit for?"],[7328,7444,"You're never going to believe me,"],[7444,7515,"are you?"],[7999,8149,"I've got something to take care of."],[8149,8229,"Feel free to eat and head out"],[8229,8287,"once you’re done."],[9401,9601,"You promised to get rid of Ally."],[9647,9793,"Hurry up."],[9880,10093,"I can’t stand seeing her face any longer."]],"38":[[546,667,"Come on baby."],[675,925,"We are leaving this house of lies."],[1130,1205,"Oh shit."],[1881,1997,"You're leaving?"],[2043,2152,"No, just..."],[2152,2264,"sorting through some clothes."],[2473,2560,"I know what you're thinking,"],[2560,2744,"so stop pushing my limits."],[2907,3040,"You brought her home."],[3140,3315,"I figured I'd help make space,"],[3340,3461,"to save you the hassle."],[3465,3620,"I never said she could move in."],[3649,3741,"Well, everything you're doing"],[3741,3862,"points otherwise."],[4133,4295,"Who do you think you are?"],[4295,4391,"Making assumptions"],[4391,4512,"about what I'm thinking."],[4571,4692,"I'm nothing to you."],[4729,4829,"And that's why leaving"],[4829,5030,"is the best thing I can do for myself."],[5372,5488,"So you admit it."],[5559,5693,"You’re trying to leave me."],[6197,6318,"Not happening."],[6406,6556,"I won't let you."],[7816,8008,"You’re not taking my child anywhere."],[8170,8291,"From now on,"],[8304,8521,"you don't leave this room until I say so!"],[9255,9351,"Hey!"],[9505,9622,"You can’t imprison me!"]],"39":[[29,150,"You can’t imprison me!"],[204,250,"Cyrus!"],[308,354,"Cyrus!"],[437,483,"Hey!"],[592,663,"Cyrus!"],[867,963,"Cyrus!"],[1067,1255,"Cyrus, let me out of here!"],[1359,1480,"I'm gonna die."],[1543,1714,"I’m going to die in here."],[1764,1876,"Don’t be ridiculous!"],[1876,1989,"You're not gonna die."],[1989,2106,"You'll be just fine."],[3023,3144,"Pretending to be sick again"],[3144,3261,"to get my attention."],[3261,3386,"I'm not falling for it."],[4654,4704,"Ally."],[4704,4804,"Rashida."],[4838,4996,"I need help, please come!"],[5005,5125,"What happened?"],[5334,5405,"Ally?"],[5543,5663,"Hello?"],[5864,5985,"Are you okay?"],[6489,6610,"Ally?"],[6610,6731,"Are you okay?"],[6810,6927,"Rashida!"],[6927,7052,"Come here now."]],"40":[[100,229,"Rashida, I can’t take this"],[229,321,"much longer."],[517,621,"I need to get out of here."],[621,742,"Can you help me?"],[896,1017,"What do you need me to do?"],[1167,1234,"I need a map"],[1234,1351,"to the human world."],[1443,1564,"I can get it."],[1789,1906,"But you're pregnant."],[1906,2010,"Traveling alone is"],[2010,2131,"way too dangerous."],[2444,2565,"Here, take this."],[2932,3065,"Blow it at the edge of the forest,"],[3065,3232,"and my rogue friend will come for you."],[3415,3516,"He promised me"],[3516,3636,"to help me get out of here."],[3661,3782,"You know a rogue?"],[3832,3953,"Are you out of your mind?"],[3953,4074,"You can't trust a rogue!"],[4179,4279,"No, do not worry."],[4279,4375,"Chris has been my friend"],[4375,4458,"a very long time."],[4458,4579,"He treats me well."],[4838,4959,"All right."],[5205,5326,"When do you plan on leaving?"],[5413,5534,"As soon as I can."],[5538,5697,"As soon as you can, what?"]],"41":[[16,133,"As soon as you can, what?"],[763,900,"What are you scheming now?"],[1051,1172,"Ally..."],[1222,1380,"needs a special kind of tonic"],[1380,1459,"to recover."],[1559,1710,"She asked me to go fetch it for her."],[1793,1926,"What exactly is wrong with her?"],[2285,2439,"It's not so good for her to be stressed"],[2460,2581,"when she's pregnant."],[2727,2836,"Please..."],[2836,2977,"stop fighting with her."],[3470,3670,"I don't trust Rashida's practice."],[3874,3978,"I'll get you the best doctors"],[3978,4183,"in wolf territory, to check on you."],[4233,4354,"No need."],[4366,4525,"I'm handling this myself."],[5492,5613,"You can go."],[5618,5772,"I don't want to see you anymore."],[8254,8400,"Chris is ready to meet you."],[8979,9100,"How do you plan to get out?"],[9451,9572,"I have a plan."],[9630,9730,"But you should go before"],[9730,9847,"Cyrus gets suspicious."],[10906,11015,"This is going to be risky"],[11015,11111,"for you and your baby."],[11111,11302,"Are you sure about this?"],[11369,11507,"I've made up my mind."],[11507,11619,"Go!"],[12800,12887,"I have to get out of here"],[12887,13008,"before Cyrus comes back."]],"42":[[371,550,"We have a lead on the Sacred Fruit."],[550,667,"Send every warrior out now,"],[667,779,"we can't delay saving Emma"],[779,871,"any longer."],[925,1046,"Understood, Alpha."],[1322,1418,"Hold on."],[1564,1664,"What’s that?"],[1755,1889,"Luna Ally asked me not to"],[1889,1997,"bring her food today."],[2043,2147,"I was worried she might get hungry,"],[2147,2293,"so I made her something small."],[2823,2961,"I’ll take it up to her."],[3107,3228,"Wait here."]],"43":[[1830,1951,"Cyrus."],[2089,2193,"I had these rings made"],[2193,2377,"for our three-year anniversary."],[2594,2706,"Now I'll never get the chance"],[2706,2827,"to give them to you."],[4166,4287,"My baby..."],[4408,4575,"we're leaving to start a new life."],[4746,4896,"Do you think Cyrus will even..."],[4975,5096,"miss me?"],[5834,6010,"She’s probably still mad."],[6072,6247,"Maybe I shouldn't have locked her in."],[6519,6656,"He’ll probably forget all about me"],[6656,6760,"within a week."],[7294,7382,"Shoot."],[7761,7849,"Okay."]],"44":[[454,571,"Ally?"],[1885,2002,"Damn it."],[2444,2560,"Josh!"],[2840,2948,"Summon all the warriors and"],[2948,3048,"search for Ally!"],[3048,3165,"She ran away."],[3165,3299,"Well, we just sent out all of our"],[3299,3478,"warriors to search for the Sacred Fruit."],[3490,3670,"Find Ally first."],[3745,3866,"Got it, Alpha."],[4387,4500,"Ally."],[4512,4675,"How dare you leave me."]],"45":[[1009,1117,"Oh, Chris."],[1810,1922,"You look..."],[1922,2010,"different."],[2022,2227,"Uh, yeah. Well we’re fugitives now."],[2410,2544,"Come on, let's get you out of here."],[2544,2665,"This way."],[3290,3378,"Ally."],[3436,3545,"My oracle says"],[3545,3699,"your child and I are fated enemies."],[3757,3949,"I can only live if it dies."],[3991,4112,"Time to end this."],[4704,4825,"Chris?"],[4833,4988,"What happened? Are you okay?"],[4992,5055,"Yeah. I'm fine."],[5055,5196,"I just tripped on a rock."],[5284,5384,"That baby must"],[5384,5530,"really be my nemesis."],[5613,5776,"I can't kill it directly."],[5776,5893,"I’ll have to try something else."],[6523,6639,"It's okay."],[6769,6890,"Let's go."],[8083,8233,"This is the edge of wolf territory."],[8233,8375,"Once you cross the barrier,"],[8375,8537,"you’ll be in the human world."]],"46":[[33,133,"But ever since the truce"],[133,237,"between humans and wolves,"],[237,358,"no one can cross the border."],[408,471,"How are we supposed"],[471,592,"to get through?"],[679,800,"This."],[859,942,"It's a special potion"],[942,1063,"I got from a witch doctor."],[1105,1222,"Drink it..."],[1222,1334,"and the barrier can't detect you."],[1397,1584,"But would it hurt the baby?"],[1735,1856,"I don’t know."],[2022,2147,"But Ally, we’re only one step away"],[2147,2231,"from making it."],[2736,2857,"Come on, Ally."],[2857,2952,"Drink it."],[3011,3186,"Drink the poison."],[3211,3390,"Your baby will die in an instant."],[4079,4170,"What are you waiting for?"],[4204,4325,"I'm just nervous."],[4379,4475,"I can risk my own life."],[4475,4592,"But my baby..."],[4592,4746,"means everything to me."],[4813,4900,"This might be you’re only chance,"],[4900,4975,"Ally."],[5288,5384,"Ally!"],[5638,5805,"What do you think you're doing?"]],"47":[[25,133,"How dare you leave me without"],[133,237,"my permission?"],[750,1005,"You left me for him?"],[1034,1247,"No, I asked him to help me leave."],[1447,1564,"Defending him."],[1593,1735,"What touching loyalty."],[2039,2160,"If you can’t make Ally happy,"],[2206,2289,"you should let her go."],[3424,3599,"Don't hurt him, he’s my friend!"],[3599,3716,"I'm your mate."],[3716,3832,"And I've never seen this friend"],[3832,3916,"of yours."],[4041,4145,"What other secrets are you"],[4145,4245,"keeping from me?"],[4650,4721,"Josh!"],[4900,4984,"Take her away."],[5075,5109,"No."],[5142,5196,"No."],[5196,5259,"Get off of me!"],[5259,5380,"I'm not going back."]],"48":[[16,154,"No, I'm not going home."],[154,321,"Luna Ally, you can't cross."],[375,496,"Just come home."],[533,717,"Don't make Alpha any angrier."],[754,959,"I said, I'm not going back."],[1105,1209,"Show her what happens to those"],[1209,1355,"who disobey my orders."],[1430,1493,"Hey!"],[1555,1659,"Get off of me!"],[1730,1847,"Let go!"],[2744,2919,"Time to deal with you, rogue."],[3119,3240,"Now tell me."],[3340,3461,"How do you know my wife?"],[3724,3883,"Why, jealous?"],[4116,4341,"I mean, she is beautiful, gentle..."],[4479,4662,"always smells amazing."],[4929,5084,"Are you thinking about my Luna?"],[5276,5422,"Do you want me to kill you right now?"],[5426,5563,"Cyrus, please don't hurt him!"],[5605,5668,"Please!"],[5755,5864,"You hear that?"],[5880,6010,"Your Luna’s worried about me."]],"49":[[29,116,"Honestly, I do love"],[116,208,"the sound of her voice."],[208,329,"It's so..."],[333,517,"sultry and magnetic."],[663,784,"Especially in bed."],[917,992,"Come to think of it."],[992,1055,"Do we even know"],[1055,1146,"who the father of the baby"],[1146,1263,"in her belly really is?"],[1292,1393,"You want to bet?"],[1393,1514,"Shut up!"],[1534,1597,"She'd never fall"],[1597,1718,"for screw up like you."],[1839,1956,"You sure about that?"],[1956,2043,"She picked leaving with me"],[2043,2164,"rather than staying with you."],[2448,2569,"What do you even want?"],[2902,2965,"I want you..."],[2965,3082,"to go to hell!"],[4129,4250,"Chris."],[4437,4558,"Chris, no!"]],"50":[[709,825,"Luna Ally."],[955,1180,"You haven’t eaten in three days."],[1234,1334,"Your body can't take"],[1334,1463,"much more of this."],[1501,1584,"Leave."],[1584,1705,"I'll take care of her."],[3553,3716,"I'm running out of patience."],[4208,4312,"What are you going to do?"],[4441,4550,"Kill me?"],[4888,5009,"I'm not killing you."],[5413,5492,"Bring her in."],[6072,6193,"I'm killing her!"]],"51":[[116,200,"Wait!"],[200,237,"Oh!"],[1455,1647,"No. Cyrus, please!"],[1647,1818,"Rashida’s innocent, please!"],[2060,2181,"Let her go."],[2243,2364,"Innocent?"],[2394,2515,"She helped you escape!"],[2535,2686,"She deserves to be punished!"],[3036,3140,"No, no!"],[3140,3207,"No."],[3324,3478,"No, no, no, no, please!"],[3478,3545,"I'll do anything."],[3545,3720,"I will do anything you say."],[3795,3912,"Anything?"],[4112,4200,"No matter my orders,"],[4200,4287,"you’ll obey them?"],[4295,4354,"Yes."],[4441,4500,"Yes."],[4954,5075,"Fine."],[5388,5551,"I'll keep her locked away next door."],[5647,5843,"But if you defy my orders..."],[5864,5980,"even once..."],[6093,6227,"I'll kill her."],[7353,7469,"Now, will you eat?"],[7661,7766,"I will!"],[9609,9680,"Must you insist"],[9680,9838,"on hurting yourself like this?"],[10226,10360,"You wanna kill yourself,"],[10360,10481,"so be it."],[10814,10894,"But have you even thought"],[10894,11052,"about how it'll hurt the baby?"],[11307,11428,"Would you even care?"]],"52":[[58,179,"That’s my child too."],[2235,2306,"You should be thankful"],[2306,2427,"you're carrying my child."],[2594,2681,"Otherwise you could die"],[2681,2802,"and I could care less."],[3520,3641,"I know."],[3828,3991,"You never cared about me."],[5092,5176,"Stop whining"],[5176,5317,"like you're at death's door."],[5555,5751,"You want Rashida to live,"],[5751,5930,"you'll take care of your body."],[9054,9230,"What does Ally's medical report say?"],[9263,9384,"It's strange."],[9463,9622,"Her health markers aren't indicative"],[9622,9738,"of someone young and..."],[9772,9893,"full of life."],[9909,10026,"She looks drained,"],[10101,10218,"lifeless."],[10251,10360,"I suspect"],[10360,10535,"the baby inside her"],[10535,10777,"is feeding off her life force."],[10885,10998,"What?"]],"53":[[41,162,"I could be wrong."],[175,271,"But..."],[300,437,"I've never seen anything like this."],[517,658,"The doctors have taken blood"],[658,850,"for further testing, and..."],[950,1096,"we'll have the results soon."],[1217,1330,"Give her the best medicine"],[1330,1484,"our pack can find."],[1580,1697,"She looks even more worn out"],[1697,1818,"than before."],[1906,2027,"Cyrus."],[2210,2348,"I've never seen you care about"],[2348,2515,"someone this much."],[2581,2740,"You really love her, don't you?"],[2815,2932,"I don't know."],[3082,3228,"The moment she tried to leave me."],[3361,3478,"I felt awful."],[3574,3707,"All I could think about..."],[3741,3858,"was doing whatever it takes"],[3858,3970,"to keep her here."],[4120,4275,"Don't let a misunderstanding"],[4275,4400,"ruin your relationship."],[4483,4604,"Talk to her."],[5296,5413,"Alpha."],[5538,5659,"The rogue's body is missing."],[5705,5826,"This is all I found."],[6389,6506,"Josh."],[6589,6748,"Something's not right about this."]],"54":[[12,133,"What do you mean?"],[133,254,"I never meant to kill him."],[350,454,"He grabbed my hand and forced"],[454,596,"the blade into his own chest."],[596,817,"But me and Ally, we both saw and,"],[817,934,"you stabbed him."],[934,1121,"That's what he wanted you to see."],[1121,1242,"He kept taunting me."],[1263,1426,"Flaunting how close he is to Ally."],[1455,1530,"Even made me question"],[1530,1693,"whether the baby was really mine."],[1693,1780,"What?"],[1876,1997,"That asshole."],[2014,2118,"I thought him and Ally"],[2118,2214,"were really friends."],[2281,2398,"He must have tricked her."],[2469,2544,"He wanted to drive"],[2544,2665,"a wedge between us"],[2686,2806,"and make her hate me."],[2848,2969,"That's insane."],[3011,3136,"What is he really after?"],[3215,3324,"He must have got close to Ally"],[3324,3445,"for a reason."],[3470,3595,"Find out who he really is,"],[3595,3728,"and who he's been in contact with."],[3770,3837,"I'm going to ask Ally"],[3837,3953,"a few questions myself."],[4562,4625,"How can I trust"],[4625,4775,"Cyrus will care about the baby?"],[4959,5100,"He killed Chris."],[7098,7161,"What's going on?"],[7307,7403,"Nothing."],[7578,7665,"Just..."],[7665,7807,"uh, pregnancy things."]],"55":[[1005,1222,"Tell me how you knew that rogue."],[1288,1388,"I want everything that happened"],[1388,1472,"between you two."],[1530,1655,"Are you accusing me"],[1655,1847,"of having an affair with him?"],[1910,2093,"To humiliate me more?"],[2177,2314,"I’m not. I’m just—"],[2640,2823,"Wait. Are you crying over him?"],[2948,3036,"Besides Rashida,"],[3036,3153,"Chris was the only werewolf"],[3153,3319,"that cared about me."],[3345,3461,"Are you dumb?"],[3653,3724,"He approached you"],[3724,3849,"with ulterior motives."],[3849,4004,"Don't say that about him!"],[4087,4245,"Chris always treated me right."],[4437,4525,"Unlike you."],[5038,5209,"You're mad at me over that rogue?"],[5234,5330,"He really was your lover,"],[5330,5401,"wasn't he?"],[5401,5543,"Chris was just a friend!"],[5705,5843,"He was trying to help me leave,"],[5843,5922,"and you killed him."],[5922,6031,"You're a murderer!"],[6031,6135,"You don't even know him,"],[6135,6222,"and you left with him."],[6410,6560,"You trust him more than me?"]],"56":[[0,75,"That's right."],[75,216,"I'd rather leave with him"],[216,350,"than be stuck here with you!"],[542,646,"Say that again."],[809,1046,"I said I regret ever being with you."],[1280,1397,"I just want to leave."],[1488,1647,"You fell for that rogue, didn't you?"],[1735,1914,"This has nothing to do with him."],[1914,2097,"I'm just done with you."],[2323,2427,"Shut up!"],[2427,2519,"You're mine."],[2540,2681,"You said you'd love me forever."],[3395,3578,"Don't ever touch me like that again."],[3858,4087,"You love Emma. Go be with her!"],[4145,4208,"You're pushing me"],[4208,4320,"towards another woman now?"],[4475,4550,"You choose her"],[4550,4658,"time and time again."],[4658,4846,"What more do you want from me?"]],"57":[[66,279,"Alpha Cyrus, Emma's here."],[713,817,"If that's what you want,"],[817,913,"I'll give it to you."],[1126,1276,"Let Emma in."],[1276,1413,"I'm giving her the sacred fruit."],[1555,1639,"You found it?"],[1901,2002,"Isn't this what you wanted?"],[2060,2152,"Me to choose?"],[2348,2494,"Well, you've made my choice easy."],[2560,2590,"Wait—"],[2590,2665,"Cyrus."],[2690,2815,"I heard you found it."],[3136,3244,"It's amazing."],[3324,3395,"Of course."],[3461,3570,"Anything you want..."],[3661,3753,"I'll give it to you."],[4066,4262,"So you really chose her over me,"],[4300,4454,"with no hesitation?"]],"58":[[1151,1280,"Thank you, Cyrus."],[1438,1551,"You really went out there yourself"],[1551,1693,"to get it for me."],[1755,1893,"You're too good to me."],[2635,2723,"You deserve it."],[6202,6381,"It's incredible. I..."],[6381,6577,"I can feel it. It..."],[6577,6702,"It's healing me."],[7011,7132,"All thanks to you."],[7190,7315,"You're important to this pack."],[7382,7528,"It's only right I save you."],[7874,8012,"Can..."],[8012,8187,"I talk to Ally, alone?"],[8362,8454,"Girl talk."],[9471,9634,"I just swallowed your last chance"],[9634,9726,"at survival."],[9889,10097,"You must be on the brink of despair."],[10168,10306,"You really went through all of that"],[10306,10439,"just to see me die?"],[10560,10702,"You must be so proud."],[10752,10860,"If it means stripping you"],[10860,11040,"of everything you have,"],[11148,11290,"it was all worth it."],[11544,11653,"But I probably should"],[11653,11799,"thank the mystery man"],[11799,11982,"for helping me"],[11982,12157,"every step of the way."],[12253,12337,"You had help?"],[12504,12550,"From who?"]],"59":[[33,108,"I don't know,"],[237,350,"but I guess I'm not the only one"],[350,475,"in the pack that wants you dead."],[688,1109,"That sacred fruit was...amazing."],[1159,1242,"Enough!"],[1422,1589,"You got what you wanted."],[1589,1701,"Now leave."],[1981,2139,"Poor Ally..."],[2235,2473,"weak and useless."],[2581,2756,"All that's left for you to do..."],[2961,3123,"is die with your baby."],[3465,3670,"Let go of me! Are you insane?"],[3682,3820,"I am not the pathetic human"],[3820,3953,"that you think I am."],[4079,4275,"Say that one more time about my child,"],[4275,4483,"and I won't spare you my wrath!"],[4483,4583,"Now go!"],[4942,5113,"I will make you pay for this."],[5943,6110,"I'm so sorry, baby."],[6389,6473,"I don't think mommy's"],[6473,6598,"going to make it this time."]],"60":[[325,450,"Is Ally okay?"],[654,788,"Tell Alpha Cyrus."],[788,988,"He can't push her buttons anymore."],[988,1096,"She's in danger."],[1151,1263,"Ally's fine."],[1368,1559,"Alpha Cyrus just got the sacred fruit"],[1559,1622,"to Emma."],[1822,1939,"He gave it to Emma?"],[2018,2064,"Yeah,"],[2064,2185,"she already ate it."],[2581,2686,"It's over."],[2723,2811,"That was the only thing"],[2811,2927,"that could've saved Ally."],[3003,3115,"What do you mean?"],[3115,3249,"Wasn't that just a lie"],[3249,3353,"Luna Ally came up with"],[3353,3516,"because she's jealous of Emma?"],[3516,3607,"No!"],[3607,3799,"What kind of curse does Emma have?"],[3820,3974,"I...I don't know."],[4129,4175,"I heard that"],[4175,4337,"she has a purple mark on her arm."],[4571,4646,"Like this."],[5059,5155,"She lied."],[5155,5255,"That wasn't a curse."],[5255,5463,"We have to get to Alpha Cyrus, now!"]],"61":[[667,788,"Thank you, Cyrus."],[829,909,"You've given me"],[909,1059,"a second chance at life."],[2135,2289,"I've seen this pendant before."],[2610,2711,"I can't let him know it came from"],[2711,2802,"the mystery man."],[2873,3178,"It was a gift from..."],[3178,3257,"a friend."],[3415,3616,"I was thinking about throwing a party"],[3616,3816,"to celebrate this fresh start."],[3858,3941,"What do you think?"],[4062,4133,"Up to you."],[4333,4400,"Well."],[4491,4571,"You better be there."],[5063,5138,"That pendant..."],[5242,5376,"It's exactly like Ally's."],[5714,5805,"Can Emma be connected"],[5805,5855,"to the rogue?"]],"62":[[329,437,"Alpha Cyrus,"],[437,575,"Emma lied to everyone."],[625,792,"This is from my mentor's notes."],[792,909,"It's a rare sigil"],[909,1009,"from the witches' tribe."],[1034,1222,"Meant to enhance wolf powers."],[1305,1426,"Emma wasn't cursed."],[1618,1714,"Why would she do that?"],[1743,1972,"She's jealous that Ally's your mate."],[2147,2289,"She wanted to destroy her."],[2477,2590,"It all makes sense now."],[2652,2773,"Emma and that rogue Chris."],[2844,2936,"They're working together."],[3065,3215,"It was all a setup to drive a wedge"],[3215,3324,"between you and Ally."],[3424,3536,"Bring her back now!"],[4291,4366,"My baby."],[4562,4688,"Will you let mommy stay with you"],[4688,4804,"just a little bit longer?"],[7123,7332,"Chris, you're alive?"]],"63":[[91,212,"What are you doing?"],[212,362,"Let go of me!"],[608,721,"Pretending to be sick"],[721,813,"to get the Sacred Fruit?"],[1138,1251,"Emma, they should give you an award"],[1251,1347,"for that performance."],[1422,1534,"What are you talking about?"],[1534,1651,"Cyrus, I..."],[1651,1918,"I really was cursed. The..."],[1918,2114,"The Sacred Fruit cured me."],[2114,2314,"The sigil bolsters your wolf powers."],[2394,2535,"It makes you stronger."],[2573,2694,"You were never hurt."],[2719,2840,"I hate liars."],[2977,3090,"You’ve done a lot for this pack,"],[3090,3194,"so I'll spare your life."],[3365,3520,"But from today on,"],[3520,3603,"you’re exiled"],[3603,3720,"from Blackstone Pack!"],[3858,3958,"No."],[4120,4308,"This isn't supposed to happen!"],[4341,4508,"I'm supposed to take Ally's place"],[4508,4575,"as Luna!"]],"64":[[0,137,"You'll never replace Ally!"],[321,421,"She's my Luna,"],[558,671,"now and forever."],[884,1013,"Well, you're about to lose her,"],[1084,1255,"and it's all your fault."],[1493,1564,"What do you mean?"],[1659,1739,"She’s dying."],[1906,2118,"The Sacred Fruit was the only thing"],[2118,2210,"that could’ve saved her."],[2414,2464,"No..."],[2719,2823,"that was a story she made up"],[2823,2894,"to get my attention."],[3115,3253,"Well, ask Rashida the truth."],[3745,3991,"You gave the Sacred Fruit to me."],[4108,4316,"You love me,"],[4316,4391,"not her."],[4654,4792,"Bad news, Cyrus."],[5230,5405,"Ally’s test results are back."]],"65":[[37,120,"The baby"],[120,337,"is draining her life force."],[483,700,"Her organs are shutting down."],[855,996,"She could die at any time."],[1338,1468,"She was telling the truth..."],[1601,1768,"Why did she lie and say she was fine?"],[2498,2615,"What have I done to her?"],[2706,2919,"Oh, poor Ally."],[2990,3119,"She tried to tell you the truth,"],[3119,3240,"and you didn’t believe her."],[3507,3724,"This is all your fault."],[3724,3816,"Shut up!"],[3891,4037,"I should have never trusted you."],[4062,4170,"Get this lunatic out."],[4195,4291,"Alpha Cyrus."],[4416,4537,"Luna Ally is gone."],[4942,5084,"The mystery man must have been"],[5084,5163,"helping me."],[5334,5518,"He did promise he would kill Ally."],[5601,5705,"Chris is alive?"],[6006,6110,"Ally's in danger."]],"66":[[750,859,"Where am I?"],[888,980,"You're awake."],[980,1038,"Ally."],[1117,1238,"Sorry, I..."],[1238,1305,"I had to get you out"],[1305,1405,"without the guards noticing."],[1405,1501,"This was the only way."],[1547,1626,"Chris?"],[1789,1889,"What are you doing here? How..."],[1889,1951,"What happened?"],[1951,2047,"I thought you were dead."],[2218,2318,"Guess I was lucky."],[2364,2469,"Barely made it out alive."],[2602,2748,"You shouldn't have came back."],[2890,3015,"If Cyrus finds out—"],[3015,3107,"It’s okay."],[3107,3219,"He still thinks I'm dead."],[3219,3353,"He's not going to catch on that fast."],[3670,3828,"I promised I'd get you out."],[4241,4350,"This might be your last chance"],[4350,4479,"to escape the pack for good."],[4683,4825,"What if it hurts the baby?"],[4917,5105,"You've seen what Cyrus is capable of."],[5138,5184,"You really think"],[5184,5292,"your baby's safe with him?"],[5355,5467,"Chris is right."],[5547,5697,"I have to be brave..."],[5797,5935,"for my baby."],[6548,6748,"Why can't I kill that damn baby?"],[6835,6877,"What?"]],"67":[[8,100,"What did you just say?"],[100,254,"You're trying to kill my baby?"],[342,400,"Yeah."],[442,517,"That's right."],[554,592,"It wasn't"],[592,696,"a barrier-piercing potion."],[696,809,"It was a potion made especially"],[809,888,"to kill your child."],[1030,1159,"Why would you do that?"],[1197,1326,"Because my divinations told me"],[1326,1438,"that your child would destroy me"],[1438,1488,"one day."],[1672,1810,"Only one of us can survive."],[1914,2043,"So everything that you did"],[2043,2206,"was just try to get close to me"],[2206,2344,"to kill my child?"],[2344,2414,"Exactly."],[2556,2652,"From the beginning,"],[2711,2790,"I just never had the chance"],[2790,2857,"until now."],[2952,3128,"I thought you were my friend."],[3432,3520,"Cyrus was right."],[3520,3678,"I never should have trusted you!"],[3787,3895,"I'm just trying to survive."],[3966,4029,"Now—"],[4029,4087,"What are you doing?"],[4087,4158,"-Everything ends. -Stop!"],[4158,4250,"Stop!"],[4396,4450,"Chris."],[4521,4600,"- It's okay. - Chris!"],[4954,5038,"Chris."],[5121,5209,"Chris."],[5238,5384,"Hey! What are you doing?"],[5384,5459,"Stop!"],[5509,5576,"Ally!"],[5784,5843,"Cyrus!"]],"68":[[1159,1238,"You're safe."],[1297,1376,"I've got you."],[1480,1626,"Why did you come for me?"],[2027,2110,"You're my Luna."],[2227,2364,"Of course I came for you."],[2364,2502,"I'd never put you in danger."],[3390,3490,"Hey hey, hey, watch out!"],[3490,3574,"Behind you! Behind you!"],[4875,5042,"Cyrus, I think I'm dying."],[5150,5251,"No...no."],[5280,5388,"I won't let that happen."],[5480,5588,"I know everything now."],[5668,5860,"I'll save you even if it costs my life."],[6056,6185,"Don't say that."],[6473,6589,"Just promise me,"],[6752,6881,"you'll take care of my baby."],[7040,7144,"I promise."],[7332,7444,"Anything you ask."],[7745,7866,"Ally, I'm so sorry."],[8095,8237,"This is all my fault."],[10064,10122,"Ally!"],[10197,10239,"Hey!"]],"69":[[779,900,"Alpha, the baby is fine."],[963,1084,"But, Luna Ally..."],[1126,1280,"We administered lifesaving medicine,"],[1280,1351,"but..."],[1397,1480,"I'm not sure if"],[1480,1589,"she'll ever wake up."],[1910,2022,"Is there nothing you can do?"],[2110,2206,"I don't care about the baby."],[2206,2298,"I just want her back."],[2364,2464,"I'm sorry, Alpha."],[2531,2615,"As for Luna Ally..."],[2711,2811,"We've done all we can."],[3945,4033,"Has to be something else"],[4033,4149,"we can do to save her, right?"],[4454,4621,"That was the only way to save her."],[5021,5096,"She didn't want to put you"],[5096,5188,"in that position,"],[5188,5288,"so she gave up."],[6719,6852,"What have I done to her?"],[7211,7282,"Please."],[7474,7545,"Please."],[7803,7874,"Sorry."],[8412,8462,"Give me a chance"],[8462,8566,"to make things right."],[8775,8913,"She wanted to leave."],[9013,9171,"To go live in the human world."],[9492,9592,"Then I'll take her there."],[9763,9951,"The werewolf world has the sacred fruit."],[9951,10001,"The human world"],[10001,10089,"must have something else."]],"70":[[54,283,"Wait, Alpha Cyrus, you can't."],[316,375,"The humans,"],[375,521,"they created an electric barrier"],[521,608,"at the border."],[608,663,"If you cross,"],[663,779,"you could lose your wolf."],[955,1038,"That won't stop me."],[2456,2527,"I owe it to Ally"],[2527,2677,"to give everything I have."],[4133,4225,"Alpha!"],[4337,4433,"Are you sure you want to"],[4433,4600,"take Luna Ally to the human world?"],[4654,4763,"My decision is final."],[4829,4934,"I've already entrusted the pact"],[4934,5013,"to Elder Akiva."],[5251,5338,"From now on,"],[5338,5451,"you'll follow his orders"],[5563,5680,"and protect the pact together."],[9300,9380,"Ally,"],[9597,9751,"I brought you back to the human world."]],"71":[[563,750,"I heard this is the best view in the city."],[921,996,"I thought you want to see it,"],[996,1096,"so I brought you here."],[1589,1755,"The sunset is beautiful today."],[2047,2214,"I know you can feel its warmth too."],[2402,2481,"I've been thinking of"],[2481,2602,"our three years together."],[2840,3007,"The memories keep coming back."],[3203,3311,"And I realized..."],[3403,3607,"I made all your favorites."],[3649,3749,"Not hungry."],[3795,3966,"It was always you loving me."],[4120,4329,"I never did anything for you in return."],[4567,4675,"I want to make it up to you."],[4963,5092,"When you wake up,"],[5092,5217,"we'll go anywhere you want."],[5217,5363,"We'll do anything you want."],[5426,5488,"Okay?"],[6093,6281,"I have so many regrets."],[6281,6398,"I was so cold to you."],[6656,6790,"I never even said..."],[7198,7278,"I love you,"],[7645,7720,"Ally."],[7836,7903,"Please..."],[7970,8191,"please, please wake up."],[8733,8904,"You heard me, didn't you?"],[9075,9238,"I swear..."],[9238,9371,"this time..."],[9371,9434,"I'll love you right."]]}