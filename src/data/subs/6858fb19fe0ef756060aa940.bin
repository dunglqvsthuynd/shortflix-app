{"1":[[1433,1529,"What's this?"],[1741,1808,"Warren."],[1808,1950,"Happy 10th anniversary."],[2004,2125,"They're gorgeous."],[2258,2320,"Daddy,"],[2325,2437,"I want one too!"],[2545,2679,"This one's for Mommy, kiddo."],[2766,2945,"You'll get yours when you turn 25."],[2991,3083,"I promise."],[3108,3229,"Now go have fun with your sister."],[3412,3512,"I had our initials"],[3512,3612,"engraved on the back."],[3837,3912,"It's beautiful."],[3995,4183,"Here is to ten amazing years,"],[4254,4366,"ten more after that."],[4437,4566,"I like ten more."],[4912,4954,"Daddy!"],[4966,5037,"Bob, Bob,"],[5045,5100,"he, he..."],[5100,5266,"We were playing soccer, and..."],[5579,5616,"Bob!"],[5845,5895,"Bob!"],[5937,5991,"Bob!"],[6500,6541,"Bob!"],[8591,8650,"Take him!"],[9725,9804,"Warren?"],[10408,10541,"Warren!"],[10691,10779,"Breaking news,"],[10845,11004,"CEO of the globally renowned"],[11004,11120,"Skyland Hotels,"],[11120,11245,"Warren Davis, has gone missing"],[11245,11391,"after a drowning incident."],[11433,11612,"Search and rescue efforts are underway,"],[11612,11695,"but experts say that"],[11695,11883,"his chances of survival are slim."],[12158,12237,"Are you okay?"],[13270,13404,"Where am I?"],[13475,13620,"And who am I?"]],"2":[[691,754,"Sorry."],[1800,1912,"We have you on the top floor."],[1991,2075,"Do you have our employee card"],[2075,2116,"with us?"],[2116,2266,"I should sign up for one."],[3041,3108,"I did it."],[3175,3358,"I officially passed the test."],[3391,3470,"Starting tomorrow,"],[3470,3650,"I am the lobby supervisor."],[3650,3758,"That is amazing!"],[3775,3920,"That's amazing, sweetheart."],[3966,4133,"I, I knew you would do it."],[4179,4279,"I'm so proud of you."],[4441,4595,"Maybe just don't, don't tell anybody"],[4595,4704,"that I'm your father."],[4729,4762,"Okay?"],[4762,4816,"Because I-"],[4845,4995,"I don't want to ruin things for you."],[4995,5058,"Dad,"],[5120,5225,"why would you say that?"],[5300,5454,"I mean, this job is important to me,"],[54