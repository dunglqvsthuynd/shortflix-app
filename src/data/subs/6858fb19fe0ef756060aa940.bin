3191,3279,"That's just a fancy way of"],[3279,3408,"saying he's shoving me out."],[3429,3545,"It's worse than that."],[3575,3758,"He's not just filling a position."],[3775,3912,"He's making a power move."],[4016,4062,"You know,"],[4095,4254,"Tim used to run errands for Dad"],[4254,4395,"when Skyland was first started."],[4470,4595,"And then Dad gave him shares"],[4595,4691,"out of loyalty."],[4729,4875,"And now he's turning against us?"],[4887,5020,"Let them plot all they want."],[5083,5245,"Your dad built this empire."],[5283,5379,"And as long as I'm around,"],[5379,5545,"no one is taking it from us."],[6020,6116,"All right."],[6133,6329,"If there are no further objections,"],[6350,6420,"I would like to"],[6420,6641,"officially introduce Steve Wilson"],[6641,6875,"as our new Vice President of Skyland,"],[6891,7033,"effective immediately."],[7287,7395,"Thank you, everyone."],[7445,7579,"I appreciate your trust."],[7579,7758,"My father and I will be working together"],[7758,8037,"to take Skyland to even greater heights."],[8037,8208,"You're celebrating a little too soon."]],"32":[[158,312,"You're celebrating too soon."],[358,525,"Board meetings are scheduled under"],[525,612,"my authority."],[625,741,"Whatever this is,"],[762,858,"it's unsanctioned."],[858,987,"And as such,"],[1012,1187,"any decisions made here today will be"],[1187,1295,"considered invalid."],[1450,1529,"Come on, Donna."],[1583,1700,"You're only the chairwomen"],[1700,1841,"because the chairman is missing."],[1900,1991,"But let's be real."],[2029,2100,"You don't know anything"],[2100,2225,"about running a business."],[2225,2337,"I mean, what could you even offer"],[2337,2404,"this company?"],[2500,2591,"My position."],[2841,2995,"Your husband went missing"],[2995,3150,"twenty years ago."],[3150,3304,"He isn't coming back."],[3304,3470,"This board is going to change."],[3470,3554,"Do you really think"],[3554,3675,"they're going to keep you around?"],[3712,3866,"Who says my husband is dead?"],[4108,42