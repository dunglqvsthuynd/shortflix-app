d,"],[3758,4070,"Madam Davis should still reasonably be"],[4070,4216,"our vice chairperson."],[4254,4429,"That old bat still holds prestige"],[4429,4520,"on the board,"],[4520,4716,"and influence on the public sphere."],[4741,4987,"Now is not the time to mess with her."],[5116,5333,"There's no need for mutual destruction."],[5366,5570,"Let's see if we can't talk about this."],[5620,5770,"There's nothing to discuss."],[5770,5937,"Your son is not becoming"],[5937,6041,"vice president."],[6133,6266,"If he wants to work at Skyland,"],[6266,6429,"he can work his way up from the bottom."],[6437,6758,"My son is a rare, skilled talent."],[6758,6945,"He's in a league all his own."],[6983,7175,"Under his leadership as VP,"],[7175,7425,"Skyland will rise to new heights."],[7441,7516,"Don't you want"],[7516,7675,"what's best for Skyland?"],[7741,7820,"Skill?"],[7908,7979,"Talent?"],[8079,8283,"And I'm supposed to take your word for it?"],[8350,8412,"I'll believe that"],[8412,8587,"when I see it with my own two eyes."],[8608,8745,"The position belongs to someone"],[8745,8850,"truly capable."],[8879,9045,"Bob and I will have a competition."]],"35":[[12,187,"Bob and I will have a competition."],[254,304,"We'll see who's"],[304,429,"better at stock trading."],[583,658,"The winner"],[670,808,"will get the VP position."],[820,912,"What do you say?"],[1070,1170,"I'll take you on."],[1195,1387,"Are the men in your family all useless?"],[1404,1558,"Why are you the one stepping up again?"],[1558,1700,"What the hell did you just say?"],[1720,1895,"Aw, did I hurt your feelings?"],[1945,2025,"How about this?"],[2033,2229,"Each of us start with 30 million."],[2258,2383,"Let's see who makes more."],[2420,2508,"You wanna take me on?"],[2716,2804,"What, cold feet?"],[2820,2979,"Who the hell said I was scared?"],[3045,3133,"You wanna compete?"],[3166,3237,"Let's go!"],[3295,3354,"Great."],[3391,3466,"It's settled then."],[3483,3633,"Everyone here will be a witness."],[3641,3733,"Oh, by the way,"],[3754,3854,"whoever loses"],[3854,4083,"will not only lose the VP position,"],[4108,4304,"they will also lose everything they own."],[4366,4470,"Are you ready for that?"],[4554,4762,"This is a board meeting, Steve."],[4762,4925,"Not your personal playground."],[4991,5254,"Madam Davis, are you backing down?"],[5254,5400,"Is your son not capable?"],[5458,5604,"Perhaps it's time for both of you to"],[5604,5662,"step down."]],"36":[[8,154,"Who said I wasn't up for it?"],[216,320,"I already agreed."],[345,512,"Bob, he knows more about"],[512,645,"the stock market than you."],[683,808,"What are you so worried about?"],[870,1008,"Are you really sure I'm gonna lose?"],[1320,1379,"Great."],[1416,1495,"Then it's settled."],[2166,2383,"Mom, the odds are not in Bob's favor"],[2383,2479,"against Steve."],[2541,2695,"I need to get a legal team ready,"],[2695,2800,"just in case."],[2933,3033,"You must be busy then."],[3129,3287,"Go ahead and focus on your own work."],[3370,3466,"But what about you?"],[3570,3637,"I'll be fine."],[4425,4545,"Are you home, Warren?"],[4675,4816,"I can't hold on much longer."],[5216,5441,"Madam Davis, I have received news"],[5441,5587,"from the private investigator."],[5604,5720,"He has a lead"],[5720,5920,"on Chairman Davis' whereabouts."],[5970,6041,"What?"]],"37":[[20,166,"After interviewing people who were"],[166,445,"at the resort around the time of accident,"],[458,683,"the investigator spoke to a local"],[683,837,"who claims that"],[837,958,"on the day"],[958,1170,"of Chairman Davis' accident,"],[1195,1458,"a man matching his age and description"],[1458,1616,"was found washed up"],[1616,1762,"on a neighboring beach."],[1845,2008,"According to other eyewitnesses,"],[2020,2150,"he was saved"],[2170,2366,"by a homeless orphan girl."],[2391,2508,"Go investigate that girl's"],[2508,2629,"whereabouts immediately."],[2658,2800,"Find her at any cost."],[2858,2933,"Yes, ma'am."],[3900,4066,"This fucking Steve!"],[4079,4204,"I'm gonna fucking show him!"],[4270,4437,"Bob, you need to calm down."],[4495,4645,"You need to come up with a solution."],[4695,4854,"Steve has his MBA,"],[4854,4979,"and worked on Wall Street."],[5183,5291,"He's gonna be a tough opponent."]],"38":[[12,125,"He's gonna be a tough opponent."],[125,200,"Of course."],[200,375,"I fucking know that, Linda."],[1312,1387,"Hey, Gloria."],[1395,1495,"What's going on?"],[1666,1800,"Steve challenged Mr. Davis"],[1800,1950,"to a stock trading contest."],[1995,2112,"Not only will the loser have"],[2112,2200,"to leave Skyland,"],[2200,2250,"but..."],[2350,2475,"they'll lose everything."],[3200,3304,"The stakes are high."],[3312,3437,"If Mr. Davis loses,"],[3437,3525,"we're gonna be kicked out of"],[3525,3654,"the hotel, and lose our jobs."],[3679,3754,"Steve won't keep"],[3754,3912,"Davis' old staff around."],[3929,4045,"What are we going to do then?"],[4500,4562,"Dad?"],[4600,4725,"Oh my god, Dad, are you okay?"],[4779,4929,"Yeah, no, I'm, I'm fine."],[5137,5233,"They're right, though."],[5350,5483,"If Mr. Davis loses,"],[5550,5683,"we're all gonna be out of a job."],[5862,5970,"But what can we do?"],[6183,6283,"I wish I knew."]],"39":[[1658,1812,"Since we're betting everything,"],[1833,1983,"let's sign the asset transfer now"],[1983,2154,"to avoid any future disputes."],[2708,2820,"Having second thoughts?"],[2912,2979,"Are all the men"],[2979,3120,"in your family spineless?"],[3637,3745,"What a fool."],[3783,3958,"Get ready to pack your shit and leave."],[4129,4175,"Here."],[4933,5025,"Hey, buy that one."],[5291,5366,"And that one."],[5475,5600,"All in."],[5625,5812,"Oh, Steve is a stock genius."],[5812,6016,"Bob will be bankrupt in minutes."],[6075,6166,"Exactly, right?"],[6166,6329,"I mean, you can tell by his picks."],[6350,6508,"Steve is an expert at this."],[6679,6770,"I'll buy that one."],[7004,7104,"Wait, wait, wait, no."],[7166,7233,"You're gonna lose"],[7233,7358,"if you drag this out, you know."],[7700,7745,"These."],[7770,7845,"These over here."],[7975,8066,"Not good."],[8129,8320,"Those stocks are all flimsy and weak."],[8370,8479,"No room for growth."],[8616,8770,"James, you know about stocks?"]],"40":[[58,129,"Not much."],[208,345,"He's just a bellboy."],[362,491,"Why does he know so much about"],[491,595,"the stock market?"],[612,737,"And why does he feel"],[816,970,"so familiar to me?"],[995,1229,"Ms. Davis, Steve's stocks are surging."],[1312,1358,"Oh."],[1383,1508,"Yeah!"],[1508,1629,"Oh, it's no surprise."],[1629,1820,"He survived Wall Street."],[1820,2000,"His stocks just went up 40%"],[2000,2166,"in a matter of minutes."],[2166,2270,"It's a miracle."],[2270,2375,"At this rate,"],[2379,2562,"his profits might just even double."],[2629,2733,"As I expected."],[2745,2950,"40% is a bit below my target,"],[2950,3150,"but good enough to beat Bob, I'm sure."],[3295,3370,"Sell them all."],[3441,3645,"Congrats, you've earned a profit"],[3645,3820,"of three million dollars."],[4358,4425,"It's over."],[4495,4600,"Bob's gonna lose."],[4670,4812,"It's starting to nosedive."],[4829,4958,"How can this be happening?"]],"41":[[104,283,"Bob, those three stocks are weak."],[291,358,"Hurry up and sell them"],[358,445,"before it's too late."],[541,625,"They're dropping."],[625,754,"What are you waiting for?"],[858,908,"Fine."],[1008,1075,"Fine, sell."],[1333,1445,"Mr. Davis, you've lost"],[1445,1591,"half of your initial capital."],[1612,1654,"What?"],[1666,1779,"Half of it is gone?"],[1958,2058,"What a loser."],[2079,2233,"He'll never beat my son."],[2241,2416,"I thought it would last at least an hour."],[2416,2670,"At this rate, he'll be dead in 20 minutes."],[2833,3016,"Don't be so sure of yourself, Steve."],[3095,3220,"Oh, why shouldn't I be?"],[3233,3483,"I've got 33 million and he's down 15."],[3512,3595,"How could he possibly"],[3595,3704,"turn this around?"],[3945,4029,"How about this?"],[4045,4212,"Spend the night with me at the hotel."],[4237,4408,"Make me as happy as I can be."],[4429,4633,"Then maybe, just maybe,"],[4666,4737,"I'll let your brother"],[4737,4845,"lose with some dignity."],[4862,5020,"You sick fuck."],[5204,5354,"Still a stuck up bitch even when you're"],[5354,5458,"about to lose everything."],[5533,5595,"You'll be begging"],[5595,5733,"between my legs soon enough."],[6054,6270,"Although Mr. Davis is a difficult person,"],[6270,6395,"Ms. Davis has always"],[6395,6479,"been kind to me."],[6491,6595,"I can't stand by"],[6595,6745,"and watch her get treated like this."],[6754,6837,"Besides,"],[6845,6950,"this is about the future"],[6950,7120,"for me and my daughter too."],[7420,7495,"Mr. Davis,"],[7616,7745,"you haven't lost yet, sir."]],"42":[[16,108,"Mr. Davis,"],[129,254,"you haven't lost yet, sir."],[337,387,"Dad?"],[466,583,"Stay in your lane."],[591,679,"You're nothing but a"],[679,804,"luggage handler."],[825,908,"Who do you think you are even"],[908,1054,"speaking up like this?"],[1216,1287,"Mr. Davis,"],[1400,1504,"I can help you win."],[1570,1745,"You probably never traded a day"],[1745,1841,"in your life."],[1841,2150,"How dare you speak in front of us?"],[2150,2279,"Have you lost your mind?"],[2287,2416,"He's just trying to cause trouble."],[2416,2512,"Somebody get him out of here"],[2512,2679,"before he distracts Steve."],[3004,3162,"Please, Mr. Davis, trust me."],[3200,3325,"I can help you win."],[3550,3616,"Let him go."],[3833,3958,"You're this pathetic?"],[3995,4175,"You'll ask anyone for help, huh?"],[4241,4316,"Whatever."],[4333,4437,"The result will be the same."],[4483,4575,"You'll lose."],[5045,5120,"Just go for it."],[5158,5312,"Dad, this isn't a joke."],[5329,5370,"Please-"],[5370,5429,"Shut up!"],[5441,5545,"Just make your fucking move,"],[5545,5604,"old man."],[5787,5841,"Don't worry."],[5925,6008,"I have a plan."],[7025,7079,"That one."],[7216,7283,"Buy that one."],[7604,7662,"All in."]],"43":[[37,112,"Buy that one."],[175,237,"All in."],[454,512,"Dad,"],[554,700,"Mr. Davis already bought that one."],[700,841,"That one tanked the hardest."],[920,1120,"You've got to be joking, old man."],[1154,1291,"He's crazy."],[1304,1495,"Mr. Davis agreed to this?"],[1495,1595,"He must be even crazier."],[1729,1825,"Mr. Davis,"],[1858,1920,"please,"],[1983,2058,"sometimes"],[2058,2220,"you just have to trust your gut,"],[2287,2400,"and take a leap of faith."],[2425,2612,"Why did you buy this in the first place?"],[2625,2741,"Maybe you weren't wrong."],[2962,3070,"All right, do as he says."],[3104,3183,"That stock."],[3212,3275,"All in."],[3458,3545,"A leap of faith."],[3645,3737,"Maybe he's right."],[3929,4008,"It's over."],[4070,4200,"We should go pack our stuff,"],[4200,4320,"and look for a new job."],[4366,4437,"Yeah,"],[4462,4583,"we're done for."],[4666,4762,"I'll buy those three."],[6000,6087,"Mr. Davis,"],[6437,6533,"we bought the right one."],[7304,7445,"How is that even possible?"],[8112,8250,"His backside,"],[8250,8395,"he looks so familiar."],[8416,8529,"But he has a daughter,"],[8554,8700,"and he must have a family too."],[8725,8887,"How could he be my husband?"]],"44":[[70,200,"What the fuck is going on?"],[233,341,"Did you fucking do this?"],[341,537,"No, I, I just did what you told me to do."],[695,779,"Oh my god."],[870,1033,"It must be the new tariff policy."],[1033,1191,"Domestic goods are surging,"],[1191,1416,"and international company stocks"],[1416,1504,"are tanking."],[1566,1641,"Mr. Davis bought"],[1641,1800,"domestic industrial stock."],[1883,1954,"You old fuck."],[1954,2037,"Did you cheat?"],[2054,2150,"Explain yourself,"],[2150,2270,"or I'll fucking break your legs"],[2270,2370,"for insider trading."],[2370,2454,"Get off him!"],[3025,3183,"You've been on Wall Street long enough."],[3308,3479,"You think insider trading is easy?"],[3504,3583,"I'm a nobody,"],[3595,3679,"like you said."],[3725,3795,"You think anybody"],[3795,3895,"would tell me anything?"],[3966,4083,"Besides, it's illegal."],[4170,4300,"I'd never do such a thing."],[4350,4529,"Then how did you fucking do it?"],[4558,4812,"All you look at is the financial reports."],[4850,4945,"That can only tell you about"],[4945,5066,"what's already happened."],[5083,5154,"When I look at"],[5154,5300,"the international policies,"],[5320,5516,"look at where things will be."],[5545,5737,"The stock market is about the future."],[5745,5887,"It's all about perception."],[5908,6075,"Is that so hard to understand?"],[6108,6191,"You're a nobody."],[6191,6358,"How can you predict the policies?"],[6720,6879,"I work at a five-star hotel."],[6941,7070,"Important people come and go"],[7070,7145,"all day long."],[7166,7287,"I overhear what they're talking about,"],[7287,7341,"that's all."],[7362,7475,"It's not that hard."],[7600,7716,"You want to play smart with me, huh?"]],"45":[[8,62,"Sir!"],[200,395,"Your stocks have now fallen over 80%."],[450,541,"Do you want me to sell?"],[541,616,"What?"],[654,762,"Fuck!"],[770,858,"Yes!"],[866,941,"Sell!"],[1116,1270,"Your capital is down 4 million."],[1341,1637,"Mr. Davis now has 35 million and climbing."],[1787,1866,"Steve."],[1933,2016,"You lost."],[2083,2208,"And according to our bet,"],[2237,2437,"I now own all your assets."],[2962,3037,"Dad, we're not gonna"],[3037,3162,"let them get away with this."],[3358,3445,"A bet is a bet."],[3520,3579,"Let's go."],[3645,3687,"Dad."],[3708,3854,"Do you want to embarrass me more?"],[3987,4079,"I said, we're going."],[5275,5350,"I won!"],[5387,5475,"I won!"],[5554,5725,"I'm going to be the owner of Skyland"],[5725,5820,"forever!"]],"46":[[700,762,"James!"],[875,1020,"I will never forget your help today."],[1058,1333,"Thank you for your hospitality, Mr. Davis."],[1420,1516,"It's, it's just..."],[1554,1704,"It's an honor to be of service."],[2137,2200,"Linda,"],[2208,2341,"stop daydreaming over there,"],[2358,2462,"and pour James and Gloria"],[2462,2533,"some more wine."],[3762,3862,"Dad, are you alright?"],[3875,3916,"Yeah."],[4095,4191,"It's okay."],[4191,4312,"What the hell are you doing?"],[4625,4812,"Is this how you treat honored guests?"],[4875,4995,"Help them wipe it up right now."],[5304,5387,"It, it,"],[5387,5441,"it's alright."],[5441,5500,"I'll just,"],[5500,5650,"I'll just do it myself."],[5741,5833,"Kneel down,"],[5866,5937,"and wipe."],[5983,6033,"Now."],[6087,6162,"Bob."],[6162,6295,"God damn it, did you not understand"],[6295,6366,"what I just said?"]],"47":[[408,520,"Dad, are we really just gonna"],[520,691,"accept the loss like this?"],[812,900,"Have you considered that"],[900,1141,"whoever's helping Bob isn't ordinary?"],[1179,1241,"Who?"],[1262,1345,"You mean that nobody"],[1345,1429,"James Miller?"],[1483,1625,"I have my suspicions."],[1708,1800,"I think"],[1837,1916,"that James Miller"],[1916,2054,"might be Warren Davis,"],[2054,2175,"Bob's missing father."],[2212,2350,"He just doesn't know it yet."],[2366,2429,"What?"],[2487,2620,"He's just a hotel porter."],[2745,2845,"I don't know for sure."],[2929,3050,"But even if he's Warren,"],[3087,3195,"we have an opportunity"],[3195,3391,"to get ourselves out of this situation."],[3487,3529,"Alright?"],[3566,3733,"We just have to get rid of James,"],[3775,3983,"and then reel Bob in with some bait."],[4000,4125,"So what you're saying is"],[4125,4291,"we don't have to pack up and leave?"],[4312,4404,"Precisely."],[4462,4612,"To paralyze your enemy,"],[4654,4870,"you blind him with false victory."],[5300,5429,"Hello there, boys."]],"48":[[37,158,"Hello there, boys."],[266,362,"Don't look so afraid."],[470,575,"I'm here to give you an answer."],[933,1020,"I'll accept your offer."],[1262,1387,"I'll form an alliance with you."],[1737,1804,"Bob,"],[1804,1895,"back then,"],[1925,2112,"I devoted myself to you."],[2112,2187,"But then you just had"],[2187,2325,"to go and humiliate me for"],[2325,2500,"that old bastard James."],[2508,2700,"You were the one who was cruel first."],[2700,2783,"So don't blame me"],[2783,2912,"for not playing nice anymore."],[3912,3941,"Oh."],[4012,4175,"Mr. Wilson, you dropped this."],[4858,4950,"You played your cards beautifully"],[4950,5012,"this time."],[5025,5158,"Share me your tricks in the future."],[5212,5275,"Bye now."],[5520,5558,"Bye."],[6608,6762,"Did those losers finally hit the road?"],[6800,6875,"Yes, sir."],[6912,7145,"I personally watched them leave."],[7175,7379,"And I also found"],[7379,7612,"something huge."]],"49":[[29,166,"I found something"],[241,358,"huge."],[845,1070,"This is a super secret document"],[1070,1229,"that I found in Steve's office."],[1308,1375,"I snatched it"],[1375,1508,"when he wasn't paying attention."],[1925,2050,"This is amazing!"],[2116,2304,"I can't believe that old dog Steve"],[2304,2404,"was secretly working"],[2404,2537,"on an investment project."],[2616,2712,"He was probably waiting for me"],[2712,2812,"to get kicked out."],[2812,2875,"And then he was going to"],[2875,3029,"make a fortune off of this."],[3037,3183,"And if you hadn't sent me"],[3183,3275,"to watch over them,"],[3279,3412,"this investment proposal"],[3412,3600,"could have left the company's hands."],[3762,3841,"This is fate."],[3954,4075,"With a project this promising"],[4075,4154,"in my hands,"],[4291,4441,"I can finally prove myself."],[4475,4612,"Under these circumstances,"],[4637,4825,"Skyland won't just be the leader"],[4825,4975,"in the hospitality industry,"],[4991,5129,"but it'll also be"],[5129,5254,"the major player"],[5254,5400,"in the financial sector."],[5495,5562,"You're right."],[5591,5641,"You're right."],[5641,5770,"You've done an excellent job"],[5770,5854,"with this, Linda."],[5866,5950,"Now go get someone"],[5950,6058,"from the marketing team."],[6058,6112,"We need-"],[6154,6233,"Actually, wait."],[6241,6283,"Hold on."],[6541,6691,"With a trade secret this important,"],[6691,6829,"we need someone we can trust."],[6966,7054,"Call Gloria over."],[7237,7366,"Of course, Mr. Davis."]],"50":[[483,637,"You wanted to see me, Mr. Davis?"],[637,800,"This is a proposal for an investment"],[800,916,"in the financial sector."],[975,1075,"You and Linda are gonna be in"],[1075,1220,"charge of implementing it."],[1375,1562,"Maintain strict confidentiality"],[1562,1650,"and be quick."],[1812,1875,"But..."],[1954,2079,"Skyland Hotels has always been a"],[2079,2216,"brick and mortar business."],[2300,2470,"If we suddenly change directions,"],[2470,2650,"we'll face substantial risks."],[2770,2904,"On, on top of that,"],[2933,3041,"this proposal hasn't even undergone a"],[3041,3162,"background check."],[3212,3337,"If we blindly jump in,"],[3350,3504,"we are gonna be setting ourselves up"],[3504,3608,"for a world of trouble."],[3608,3758,"You seem like a smart cookie,"],[3770,3958,"but clearly you have no idea"],[3958,4083,"how the real world works."],[4150,4295,"In order to beat our competitors,"],[4295,4475,"especially with a project of this size,"],[4504,4650,"we need insider info."],[4712,4920,"An opportunity like this is long gone"],[4920,5025,"if we waste all that time"],[5025,5133,"on a background check."],[5208,5287,"Exactly."],[5358,5466,"Do you really not know"],[5466,5541,"where you stand?"],[5654,5825,"If Mr. Davis hadn't given you a chance,"],[5825,6025,"do you really think you'd be qualified"],[6025,6162,"to participate in this project?"],[6229,6395,"Enough of this nonsense."],[6466,6600,"Just carry out the project"],[6600,6700,"according to my order."],[7737,7970,"Just wait till I expand Skyland business."],[8012,8087,"When Dad returns,"],[8087,8237,"I know he'll be proud of me."],[8308,8350,"This time,"],[8350,8466,"I'm going to prove to the whole world"],[8466,8558,"that I'm not just some"],[8558,8691,"good-for-nothing playboy."]],"51":[[529,629,"Hey, hey, kiddo."],[683,791,"Oh, hey, Dad."],[812,879,"What's wrong?"],[925,1008,"You seem upset."],[1037,1162,"Mr. Davis wants to invest"],[1162,1275,"in the financial sector,"],[1291,1350,"but..."],[1404,1541,"there's something seriously wrong"],[1541,1629,"with this project."],[1700,1825,"I just don't know what it is."],[1837,1933,"Let me take a look."],[2875,2979,"Your instincts are correct."],[2979,3079,"With this rate of return,"],[3079,3212,"it's completely unfounded."],[3258,3395,"No, somebody must be trying to trap"],[3395,3479,"Mr. Davis."],[3479,3608,"I need to go speak with him right now."],[3608,3633,"What-"],[3733,3800,"Dad!"],[3808,3895,"It's gonna be okay."]],"52":[[275,366,"Mr. Davis?"],[3625,3904,"You old bastard."],[3916,4079,"What the hell are you doing?"],[4079,4225,"You're really asking for it this time."],[4225,4400,"I, I was looking for Mr. Davis."],[4491,4612,"There's something very important"],[4612,4745,"I need to talk to him about."],[4820,4870,"What?"],[4916,5041,"What do you need to talk to me about?"],[5041,5250,"Mr. Davis, everyone at Skyland"],[5250,5333,"knows the rule."],[5341,5445,"No one's allowed in your office"],[5445,5529,"without permission."],[5600,5700,"But this old geezer"],[5700,5854,"not only barged right in,"],[5854,5925,"but he broke your"],[5925,6100,"precious family photo."]],"53":[[54,175,"I, I , I'm sorry, Mr. Davis."],[175,254,"I didn't, I, I,"],[254,295,"I didn't,"],[295,420,"I didn't mean to do that."],[1345,1562,"James, just because you helped me once"],[1562,1625,"doesn't mean you can"],[1625,1737,"cross the line like this"],[1737,1908,"and barge into my office again."],[2204,2287,"Don't blame me"],[2295,2470,"for acting ruthless to you."],[2712,2779,"Of course."],[2795,2862,"Of course, Mr. Davis."],[2862,2945,"And I, I promise"],[2945,3008,"I'll, I'll,"],[3029,3187,"I will be more careful in the future."],[3187,3300,"But there was,"],[3300,3441,"there was truly a very important reason"],[3441,3550,"why I came in here."],[3645,3779,"I came here to tell you,"],[3779,4037,"do not take"],[4075,4233,"the investment project on."],[4308,4429,"There's something wrong with it."],[4429,4516,"There's a problem."],[4516,4575,"A problem?"],[4633,4700,"What problem?"],[5175,5312,"I haven't figured it out yet."],[5312,5445,"Just because you're good at stocks"],[5445,5650,"doesn't make you a business genius."],[5658,5829,"This project is bigger than anything"],[5829,5962,"you've ever seen in your entire life."],[5962,6045,"What makes you think you"],[6045,6104,"can figure it out?"],[6104,6262,"Mr. Davis, I promise you,"],[6291,6475,"my instincts are sound."],[6512,6608,"For, for example,"],[6645,6795,"that high of a ROI?"],[6837,6966,"I mean, it's unheard of."],[7012,7175,"And it's obviously a ploy."],[7212,7420,"You can't be suckered in by it."],[7712,7787,"Mr. Davis,"],[7787,8000,"don't listen to this bastard's nonsense."],[8033,8100,"In fact,"],[8120,8375,"I think he's trying so hard to stop you"],[8375,8541,"that he's actually a spy."],[8583,8658,"I bet he's here to"],[8658,8783,"steal the project back for Steve."],[8783,8962,"Linda, you, you can't accuse me of"],[8962,9041,"stuff like that."],[9041,9125,"Oh,"],[9125,9350,"these aren't baseless accusations."],[9475,9575,"I have proof."]],"54":[[37,133,"I have proof."],[237,370,"On the day the Wilsons left,"],[383,633,"Steve gave James a special goodbye."],[716,800,"I thought it was strange,"],[800,883,"so I took a photo."],[941,1091,"Now everything makes sense."],[1145,1295,"Turns out James has betrayed you"],[1295,1429,"and is working for Steve."],[1450,1512,"Mr. Davis,"],[1529,1691,"it's not what it looks like, okay?"],[1691,1820,"I did not betray you."],[1820,1916,"Shut up!"],[2191,2325,"You'd be fucking dead"],[2325,2458,"if it weren't for that one time"],[2458,2545,"that you helped me."],[2862,2991,"But I'm not someone who forgets"],[2991,3091,"a good deed."],[3241,3333,"But after today,"],[3333,3491,"you better get the fuck out of Skyland."],[3812,3908,"Mr. Davis, please."],[3950,4037,"You can't go through"],[4037,4166,"with this investment project."],[4220,4383,"There's a serious problem with it."],[4575,4741,"This is my last warning!"],[4762,4929,"Get the hell out!"],[6345,6470,"That Steve is more shrewd"],[6470,6566,"than he lets on."],[6612,6845,"He really predicted all of this."],[6845,7075,"Well, now that James has been fired,"],[7075,7279,"Bob just lost his right-hand man."],[7308,7545,"Now, only judgment day awaits him."]],"55":[[300,375,"How'd it go?"],[541,650,"Mr. Davis"],[770,908,"remains so stubborn."],[937,1029,"Well, maybe we just shouldn't"],[1029,1120,"worry about it then."],[1208,1350,"I mean, we did everything we could."],[1350,1441,"It's up to Mr. Davis"],[1441,1570,"to make his own decision now."],[1608,1683,"And the results"],[1683,1875,"don't affect us anyway, so."],[1887,1966,"Gloria,"],[2025,2137,"how can you say that?"],[2179,2275,"Ms. Evelyn,"],[2329,2458,"who always treated us so well,"],[2458,2587,"she will be affected."],[2687,2766,"More importantly,"],[2766,3025,"Skyland, they gave us a chance."],[3033,3137,"Remember back then?"],[3137,3345,"They looked past my background,"],[3375,3516,"and they gave me a job."],[3616,3754,"So I'm gonna put you through school."],[3754,3800,"No."],[3875,3991,"No, we cannot just"],[4012,4191,"watch ungratefully"],[4270,4483,"while Skyland faces this crisis."],[4854,5000,"So then what do we do?"],[5033,5162,"Mr. Davis,"],[5245,5395,"he won't believe me now."],[5508,5587,"You..."],[5729,5875,"you're the only one that can help."],[6237,6325,"How about this?"]],"56":[[1945,2054,"What are you guys doing?"],[2154,2262,"Someone made a report."],[2270,2433,"They claimed that a dismissed employee"],[2433,2533,"was trying to steal"],[2533,2679,"Skyland Hotel property."],[2766,2866,"We're here to investigate."],[2908,2983,"I already put"],[2983,3220,"the company porter uniform in there,"],[3220,3433,"and I don't have anything else on me."],[3495,3604,"Who, who"],[3637,3691,"made this-"],[3691,3841,"It's not up to you to say whether you"],[3841,3954,"stole something or not."],[4029,4175,"And as for the accusation,"],[4220,4320,"don't worry about it."]],"57":[[8,112,"Mr. Davis,"],[112,387,"soon all of Skyland's shareholders"],[387,495,"and board of directors"],[495,741,"will be deeply impressed with you."],[862,958,"Well, for a project this good,"],[958,1029,"Steve must have really"],[1029,1095,"gone out of his way"],[1095,1216,"to find some channels."],[1245,1383,"And it's a good thing that the proposal"],[1383,1504,"ended up in your hands."],[1525,1662,"If it had ended up in Steve's,"],[1662,1791,"and the success had gone to him,"],[1808,1962,"Skyland would look totally different."],[2129,2270,"Shivered just thinking about it."],[2270,2450,"No, Mr. Davis."],[2450,2700,"You owe this to your natural good luck."],[2745,2895,"Now is the best time"],[2895,3062,"to prove your abilities,"],[3062,3250,"and your talents to everyone."],[3462,3529,"What's wrong?"],[3695,3750,"Great."],[3787,3891,"The Wi-Fi is down."],[3983,4133,"Come on, I gotta get to some good stuff."],[4133,4258,"I'll go see what's going on."],[5075,5158,"Mr. Davis?"],[5545,5612,"This document"],[5612,5708,"needs your signature."],[5720,5845,"What freaking document?"],[5866,5958,"Can't you tell that I'm busy?"],[5958,6087,"I don't have time for that right now."]],"58":[[37,158,"What freaking document?"],[179,275,"Can't you tell that I'm busy?"],[275,404,"I don't have time for that right now."],[429,541,"I'm trying to help you delay some"],[541,645,"payments to suppliers"],[645,762,"so that you can put more money into"],[762,850,"the investment fund."],[916,1045,"And then you can reimburse everybody"],[1045,1158,"once you earn your money back."],[1158,1266,"All you need to do is"],[1266,1466,"sign this payment deferral agreement,"],[1554,1654,"and"],[1725,1841,"the money is yours."],[2629,2691,"Not bad."],[2800,2979,"They do say with greater investment"],[2979,3087,"comes greater return."],[3608,3704,"You did good this time."],[4791,4945,"Is something wrong with your computer?"],[5137,5233,"The Wi-Fi is down,"],[5233,5304,"the IT department"],[5304,5412,"is full of shitheads."],[5487,5616,"Let me help you take a look."],[5666,5791,"You know how to fix computers?"]],"59":[[354,454,"Okay,"],[487,591,"you're back online."],[675,741,"What?"],[820,929,"Nice!"],[954,1016,"Wow!"],[1091,1287,"Gloria, go to the storage closet,"],[1287,1470,"grab the nicest bottle of champagne."],[1470,1641,"We are going to celebrate later."],[2062,2141,"Okay,"],[2141,2295,"so the router had no problem"],[2295,2454,"but they said there's a faulty wire."],[2508,2666,"I already spoke with the IT department,"],[2666,2787,"and they're gonna fix it."],[2979,3045,"No need."],[3104,3245,"The Wi-Fi is already fixed."],[3275,3466,"And I just made a major investment."],[3550,3629,"Yes!"],[3654,3741,"Finally!"],[3962,4033,"Wow."],[4041,4179,"Gloria is really fast."],[4179,4312,"Let's pop some champagne,"],[4312,4470,"and celebrate this momentous day."]],"60":[[312,466,"Who let these two back in Skyland?"],[466,533,"Oh."],[533,758,"So threatening, Mr. Vice President."],[795,933,"Did you want to pop some champagne"],[933,1020,"and celebrate?"],[1066,1245,"We came here to help fulfill your wish."],[1295,1458,"Dad, I think what you're trying to say is"],[1470,1550,"we should be the ones"],[1550,1691,"celebrating with champagne."],[1737,1841,"Remember, when you're speaking"],[1841,1958,"with a dumbass like him,"],[1966,2045,"you've got to be more"],[2045,2137,"straightforward."],[2162,2241,"Otherwise,"],[2241,2358,"he's not gonna catch your point."],[2358,2458,"I'll explain it to him"],[2458,2658,"in a language he understands."],[2725,2891,"So the investment fund"],[2891,2970,"that you transferred"],[2970,3083,"all your money into?"],[3125,3300,"That was Steve's bank account."],[3320,3404,"All this nonsense"],[3404,3629,"about a financial investment project"],[3629,3837,"was all a grand scheme all along."],[3954,4012,"I guess this is"],[4012,4120,"how you pay your respects"],[4120,4212,"to your father,"],[4233,4433,"by draining his entire fortune."],[4529,4616,"That's right."],[4645,4745,"Now you're just a penniless,"],[4745,4841,"destitute wretch."],[4850,4941,"And now that Skyland"],[4941,5058,"has no liquid assets,"],[5091,5183,"you're running straight"],[5183,5279,"into bankruptcy."],[5320,5366,"No,"],[5387,5487,"this is impossible."],[5520,5616,"There was nothing wrong"],[5616,5708,"with that proposal."],[5895,5991,"I mean, how could all the money be"],[5991,6162,"transferred into your account?"],[6179,6279,"I mean where,"],[6279,6379,"where's my money?"],[6379,6529,"What about all the money I invested?"]],"61":[[154,254,"There was nothing wrong"],[254,316,"with the proposal."],[316,475,"There can't be anything wrong"],[475,554,"with the proposal."],[554,729,"This is why we call you a dumbass."],[741,845,"Did you really forget"],[845,987,"where the document is?"],[1020,1150,"How do you know it's such a problem?"],[1300,1383,"Bob,"],[1458,1608,"I really should thank you."],[1708,1837,"You saved me a lot of time."],[1937,2008,"You know, I thought it would"],[2008,2150,"take much longer"],[2150,2291,"to complete the task from Steve."],[2316,2437,"But who would have thought?"],[2450,2583,"You'd be in such a rush to"],[2583,2650,"prove yourself"],[2650,2854,"that I'd succeed so quickly."],[3000,3137,"You fucking bitch."],[3245,3358,"How could you betray me"],[3358,3475,"with this scheme?"],[3791,3929,"Right now, she's my woman."],[3958,4112,"I dare you to lay a finger on her."],[4329,4433,"Don't believe me, do you?"],[4470,4600,"How about I beat you till you do."],[4829,4925,"That's the consequence"],[4925,5020,"for embarrassing me."],[5079,5183,"You deserve this."],[5250,5354,"Hold it right there."],[5462,5562,"Steve,"],[5562,5716,"Skyland will not permit you to"],[5716,5829,"behave so savagely."],[5854,5908,"Sis,"],[5929,6008,"we're ruined."],[6041,6120,"They used a scheme"],[6120,6229,"to take all of our money."],[6245,6304,"Please, hurry."],[6304,6362,"Think of something."],[6412,6458,"Mom and I"],[6458,6558,"have already been informed"],[6558,6770,"about the abnormal transactions."],[6829,7062,"Bob, how could you be so impulsive?"],[7083,7179,"Why didn't you discuss this"],[7179,7304,"with us beforehand?"],[7333,7425,"We have no way of"],[7425,7533,"getting the money back."]],"62":[[8,116,"Bob, you really have made a"],[116,245,"catastrophic mistake."],[425,554,"Our family is doomed."],[729,845,"How am I ever to face"],[845,958,"your father again?"],[1112,1216,"Not only was I unable"],[1216,1320,"to protect his legacy,"],[1320,1387,"but..."],[1433,1612,"I haven't taken good care of you."],[1808,1958,"Oh, Warren, I'm so sorry."],[1970,2125,"Mom, this isn't your fault."],[2233,2316,"This is all because of"],[2316,2591,"the Wilson family's despicable plot."],[2633,2712,"I promise that"],[2712,2916,"they will suffer the consequences."],[2925,3041,"Aw, think your little threat is"],[3041,3108,"gonna scare me?"],[3108,3212,"Do you really believe you're still"],[3212,3445,"the high and mighty princess of Skyland?"],[3616,3716,"You bitch."],[3716,3829,"I'm gonna fucking kill you."],[4383,4595,"Get your hands off of her!"],[4650,4716,"Great."],[4716,4845,"Who let another ignorant bitch"],[4845,4933,"in this place?"],[4954,5087,"Steve, do you really believe you have"],[5087,5216,"all that money in your possession?"],[5216,5375,"Because I have Mr. Davis' shares"],[5383,5458,"right here."],[5520,5704,"You didn't take a single cent."],[6058,6091,"What?"],[6091,6250,"When did I transfer the shares to you?"],[6370,6458,"Do you remember that document"],[6458,6616,"I had you sign a little while ago?"],[6654,6770,"It wasn't a payment deferral."],[6883,7029,"It was a share transfer agreement."],[7075,7129,"Wait."],[7158,7287,"Wait, so we get to keep our money."],[7287,7429,"We're not gonna be kicked to the streets."],[7583,7700,"Since we couldn't convince you"],[7700,7895,"to back out of the investment project,"],[7925,8058,"we had no choice but to redirect"],[8058,8175,"your transfer recipient."],[8250,8300,"It's the only way"],[8300,8441,"we could save your assets."],[8508,8675,"How did you predict even this?"],[8675,8733,"I didn't."],[8829,8895,"It was my dad."],[8941,9041,"He saw all the problems with"],[9041,9120,"that proposal,"],[9120,9179,"and..."],[9258,9383,"he made preparations"],[9383,9487,"in advance."],[9670,9820,"So it was James all along."],[10070,10120,"Once again,"],[10120,10245,"he was the one who helped me."]],"63":[[125,250,"I haven't stolen anything."],[308,470,"Why are you treating me like this?"],[587,662,"Sir."],[725,804,"I found something."],[837,883,"No."],[929,1054,"No, you can't have that."],[1062,1179,"That watch is extremely"],[1179,1233,"important to me."],[1233,1308,"Give it back."],[1308,1412,"Give it back?"],[1487,1641,"What use do you have for it?"],[1687,1850,"Gonna pawn it for bail money?"],[2054,2154,"Do you think that we're here"],[2154,2312,"just to catch some petty thief?"],[2366,2408,"We're here"],[2408,2508,"because someone's paying us"],[2508,2658,"good money to get rid of you."],[2904,3079,"Do you understand your situation now?"],[3250,3354,"Beat him up, boys."],[3420,3450,"No."],[3866,3929,"Sir."],[3987,4141,"The old bastard's out cold."],[4233,4341,"Throw him in the dumpster."],[4412,4495,"Let him rot there"],[4495,4608,"with the other garbage."],[4633,4708,"Make sure"],[4758,4870,"that you do it cleanly."],[5058,5125,"Yes, sir."]],"64":[[16,175,"Don't get so excited, Bob."],[183,358,"Skyland shares might be safe."],[379,550,"But we still have all your assets."],[583,704,"With no liquidity,"],[708,895,"once Skyland can't operate anymore,"],[933,1116,"we'll buy it at bargain prices,"],[1133,1366,"and rename it Wilson's Hotels."],[1375,1445,"Then,"],[1458,1608,"we'll throw you into the street like"],[1608,1754,"the stray dog you are."],[1829,2004,"Mr. Wilson, I think you're the one"],[2004,2204,"who's celebrating a little bit too early."],[2254,2429,"My dad saw your first plot."],[2433,2504,"You really think he"],[2504,2637,"couldn't see this coming too?"],[2658,2762,"What did you say?"],[3000,3091,"Mr. Davis."],[3208,3291,"Ms. Davis."],[3354,3454,"Madam Davis."],[3495,3695,"My father never forgot the kindness"],[3695,3812,"that Skyland Group showed him all"],[3812,3904,"those years ago."],[3925,4045,"And now that the company is"],[4045,4158,"going through a crisis,"],[4158,4316,"he has done nothing but try to help."],[4337,4391,"But..."],[4454,4600,"I will let him explain"],[4600,4750,"that to you himself."],[5695,5779,"That's weird."],[5854,5920,"Why isn't my dad"],[5920,6016,"answering his phone?"],[7270,7333,"Help."],[7412,7470,"Help."],[7741,7854,"He's still not answering."]],"65":[[41,145,"He's still not answering."],[162,245,"Or..."],[245,345,"he can't pick up."],[462,633,"Unless you can place a call to heaven."],[687,816,"What did you do to my father?"],[866,1041,"I see you're more clever than Bob."],[1141,1245,"You got it right away."],[1337,1500,"Your old man liked to meddle."],[1562,1654,"And so I couldn't keep"],[1654,1787,"letting him get in my way."],[1800,1887,"Where is he?"],[1887,1991,"What did you do?"],[2108,2250,"Don't be in such a rush, little missy."],[2279,2383,"I bet you must be sad after"],[2383,2479,"losing your daddy."],[2566,2658,"How about I comfort you?"],[2658,2708,"No!"],[2708,2841,"Let go of her, you animal!"],[3479,3629,"You ungrateful bitch!"],[3650,3720,"Guards!"],[3720,3895,"Capture every single one of them!"],[4066,4125,"Damn it!"],[4225,4333,"What are you doing?"],[4429,4562,"Before any of the shareholders"],[4562,4716,"or directors can react,"],[4775,4837,"I'm going to take"],[4837,5029,"full control of Skyland."],[5029,5262,"Then I'm going to reunite you all"],[5262,5445,"with that old bastard James."],[5466,5562,"In your dreams."],[5591,5745,"I'll never let you get away with this."],[5754,5854,"You won't have a say."],[5866,6012,"I'm gonna force them all"],[6020,6179,"to sign everything over to me,"],[6179,6262,"and then I will have"],[6262,6495,"full control of Skyland."],[6966,7054,"That watch!"],[7104,7229,"Why are you wearing it?"],[7241,7312,"Mom,"],[7345,7487,"that's Dad's watch!"],[7487,7545,"Dad?"],[7608,7704,"He's alive?"],[7762,7862,"Dad's back!"],[7933,8037,"Where did you get that?"],[8037,8216,"Sir, I got it from that porter James."],[8287,8358,"What?"],[8379,8500,"That's my dad's watch."],[8775,8841,"He's been wearing it"],[8841,8937,"ever since he adopted me"],[8937,9029,"20 years ago."]],"66":[[150,262,"I knew it was him."],[350,491,"I knew I recognized him."],[533,608,"Well,"],[620,729,"if James really was"],[729,866,"Warren Davis all along,"],[916,1079,"it's a good thing we got rid of him."],[1108,1291,"James has been my dad all along?"],[1350,1533,"He was by my side this whole time,"],[1533,1725,"and I was so horrible to him."],[1741,1904,"I mean, I even fired him!"],[1975,2225,"Oh god, how could I be such a bastard?"],[2462,2537,"Dad."],[2579,2766,"Ugh, stop being such a crybaby."],[2804,2900,"How about this?"],[2916,3000,"Since your family couldn't"],[3000,3129,"reunite in this life,"],[3129,3350,"I'll have them meet in the afterlife."],[3404,3529,"That won't be necessary."]],"67":[[183,320,"That won't be necessary."],[562,683,"Twenty years ago,"],[691,883,"even the sea couldn't take my life."],[900,1012,"And now you two think you"],[1012,1104,"can have mine"],[1154,1345,"through some amateur tricks?"],[1525,1587,"Dad!"],[1825,1945,"Is it really you, Warren?"],[2233,2375,"I couldn't remember a single thing"],[2375,2475,"after the accident."],[2733,2800,"But now..."],[3033,3200,"now I have all my memories back."],[3491,3620,"Are you not gonna hurry up"],[3620,3758,"and release my family?"],[4091,4154,"Dad."],[5137,5212,"Warren."],[6716,6779,"Dad."],[6795,6929,"Dad, I'm sorry, okay?"],[6954,6991,"I'm sorry,"],[6991,7116,"I didn't know it was you, okay?"],[7162,7291,"I treated you horribly,"],[7291,7379,"and I hurt you,"],[7379,7579,"and I let you down, and I'm sorry, okay?"],[7579,7654,"I'm sorry!"],[7666,7791,"I'm sorry, Dad!"],[8095,8137,"Dad."],[8275,8329,"Here,"],[8354,8408,"here, Dad,"],[8433,8512,"punish me!"],[8562,8766,"Please, please, just punish me, Dad!"],[8795,8933,"Okay, I know I was wrong, okay?"],[8933,9012,"I'm sorry!"],[9012,9220,"Just, just don't ignore me, Dad!"],[9291,9412,"Please don't ignore me."],[9412,9570,"I've missed you so much!"],[9762,9820,"Please."]],"68":[[70,175,"You should be beaten."],[508,579,"But..."],[1204,1337,"I was absent"],[1441,1554,"when you were growing up."],[1779,1912,"And I didn't have the chance"],[1983,2087,"to teach you better."],[2304,2475,"So I can't blame you, son."],[2950,3029,"However,"],[3129,3212,"in the future,"],[3383,3504,"if you ever"],[3545,3695,"misbehave like that again,"],[3858,4025,"I'm gonna teach you a real lesson."],[4200,4250,"Yes, sir."]],"69":[[41,283,"You useless sack of shit!"],[354,529,"I pay you a fortune,"],[529,733,"and this is how you take care of things."],[766,854,"I didn't know."],[879,1004,"He was dead to the world,"],[1004,1229,"and we buried him in the dumpster."],[1279,1479,"I, I didn't know anything about this."],[1483,1583,"The chairman woke up in the"],[1583,1679,"disposal room."],[1700,1866,"He was found by the janitor"],[1866,2004,"who then contacted me."],[2062,2212,"I knew my dad would be alright."],[3087,3212,"I'm so proud of you, kiddo."],[3325,3475,"Let me handle it from here, okay?"],[3529,3579,"Okay."],[3866,4000,"Even though your return means"],[4000,4208,"I can't have control of Skyland,"],[4254,4437,"I still own all of your assets."],[4479,4658,"Skyland is nothing more than a shell."],[4845,4958,"We're not afraid of you."],[5016,5108,"That's right, Dad."],[5179,5279,"We're the ones in control of the"],[5279,5383,"company's cash flow."],[5433,5600,"He should be the one fearing us."],[5625,5691,"Is that right?"],[5841,5895,"Gloria,"],[6016,6091,"would you please bring"],[6091,6187,"Bob's computer here?"],[6666,6829,"Take a look at the investment page."],[6858,7062,"Specifically, the transfer receipts."],[7291,7345,"Dad,"],[7387,7516,"this isn't the right setup."],[7562,7612,"The money didn't"],[7612,7708,"transfer to my account."],[7762,7812,"This,"],[7858,7983,"this is a mirror page!"]],"70":[[20,87,"What?"],[150,283,"A mirror page?"],[291,366,"That's right."],[400,512,"It's a mirror page."],[520,616,"In other words,"],[662,741,"it's fake."],[962,1050,"Before Mr. Davis"],[1050,1195,"could complete the transfer,"],[1237,1345,"and then when I was pretending to"],[1345,1450,"fix his Wi-Fi,"],[1450,1583,"I inserted a hidden program"],[1583,1754,"that would create the perfect mirror"],[1779,1987,"of Wilson's investment interface."],[2029,2241,"I can't believe you predicted even this."],[2370,2495,"I really underestimated you,"],[2495,2554,"Gloria."],[2608,2675,"I should have had you"],[2675,2775,"eliminate as well."],[2808,2862,"It's too bad"],[2862,2991,"you couldn't predict any of this,"],[3054,3216,"some talented genius you are."],[3233,3395,"You useless piece of shit!"],[3395,3533,"She could change the interface"],[3533,3591,"all along"],[3591,3716,"and you didn't even tell?"],[3733,3870,"You goddamn imbecile."],[4037,4116,"Chairman Davis,"],[4141,4254,"please have mercy."],[4300,4429,"I don't know what came over me."],[4466,4529,"Steve,"],[4550,4662,"he was using me."],[4679,4875,"I'm so deeply, deeply sorry."],[4875,4950,"I'm begging of you."],[4950,5079,"Please have mercy."],[5279,5370,"Mr. Davis,"],[5404,5491,"I stood by your side"],[5491,5604,"for so many years."],[5633,5754,"Consider our history,"],[5775,5908,"please let me go just this once."],[6125,6195,"Traitor,"],[6220,6362,"I never want to see you again."],[6454,6545,"Get her out of my sight."],[6566,6608,"No."],[6625,6700,"Mr. Davis."],[6716,6766,"Bob."],[6787,6837,"Please."],[6854,6983,"You said you loved me!"],[7012,7170,"We were going to get a lake house!"],[7170,7262,"No, please."]],"71":[[87,195,"The important thing is that"],[195,262,"all of the money"],[262,450,"that Mr. Davis tried to invest"],[450,720,"was intercepted and put into this card,"],[741,916,"and not your account."],[958,1058,"You two"],[1083,1183,"have nothing."],[1362,1416,"Dad,"],[1433,1575,"we're really truly finished."],[1675,1745,"Chairman,"],[1779,1883,"we were wrong."],[1920,2000,"Please,"],[2000,2133,"have mercy on us."],[2208,2354,"Didn't you hold me as a baby?"],[2400,2504,"Didn't you and my father"],[2504,2629,"get through thick and thin?"],[2641,2683,"You guys still"],[2683,2820,"care about us a little bit, right?"],[2858,2945,"So please,"],[2962,3108,"let me and my father go."],[3141,3216,"Okay?"],[3241,3333,"Please."],[3362,3416,"Yes."],[3454,3525,"Please."],[3533,3762,"I followed your leadership for years."],[3770,3937,"And you watched Steve grow up."],[3945,3970,"Please,"],[3970,4129,"I'm not asking for your forgiveness."],[4129,4200,"But please,"],[4200,4345,"at least let us go."],[4362,4495,"It's far too late now."],[4558,4725,"You tried to steal my company,"],[4745,4875,"take my life,"],[4891,5008,"hurt my family."],[5075,5204,"While you were doing all that,"],[5316,5470,"did you ever consider our friendship?"],[5520,5645,"These are clearly nothing more than"],[5645,5762,"crocodile tears."],[6158,6233,"Guards."],[6308,6437,"Get them out of my sight."]],"72":[[100,254,"I can't believe you're back, Dad."],[316,437,"I've missed you so much."],[437,579,"Please don't ever leave again."],[1583,1633,"Hey."],[1708,1816,"Get in here, kiddo."],[1929,2033,"You're my daughter, too."],[2091,2175,"You always will be."]]}