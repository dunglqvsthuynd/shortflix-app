,6120,"who works here,"],[6120,6287,"not just the people at the top."],[6337,6416,"Did you forget that?"],[6416,6537,"Yeah, and if it weren't for him,"],[6562,6729,"they would be living on the streets."],[6800,6941,"You really don't get it, do you?"],[7112,7283,"You are going to invite them over,"],[7304,7466,"and you are going to apologize."],[7616,7733,"Are you kidding me?"],[7795,7900,"Invite them over?"],[7908,7962,"No!"],[7966,8020,"No!"],[8020,8150,"They are nobodies!"],[8150,8300,"Why would I invite them into our house?"],[8300,8454,"This is not up for discussion."],[8516,8650,"You either fix this,"],[8712,8841,"or don't come back to work tomorrow."],[9379,9429,"Fine."],[9541,9675,"And as for the rest of you,"],[9704,9962,"if I catch anyone bullying a co-worker"],[9962,10087,"or looking down on someone"],[10087,10204,"because of their job,"],[10212,10337,"you will be out."],[10341,10450,"No warnings."],[11200,11287,"Fuck!"],[11391,11616,"That old man got me told off like that."],[11629,11845,"Are you seriously gonna apologize?"],[11850,11966,"You know my sister."],[12004,12104,"Once she makes a decision,"],[12104,12208,"there's no way around it."],[12916,13041,"Dad,"],[13041,13175,"I miss you."]],"9":[[8,141,"You found something."],[175,237,"Okay."],[291,408,"Okay, I'm coming now."],[437,495,"Mom,"],[554,637,"the private investigator"],[637,700,"just called."],[762,945,"He's got a new lead on Dad."],[1054,1212,"Oh God, please let this be real."],[1312,1391,"Let's go."],[2300,2383,"This is it."],[2566,2629,"Dad,"],[2654,2800,"I don't think Mr. Davis is actually"],[2800,2870,"gonna apologize."],[2870,2995,"Maybe we should just go."],[3133,3266,"Gloria, that's not the point."],[3333,3491,"Whether he apologizes or not,"],[3570,3662,"he invited us,"],[3662,3733,"and it would,"],[3733,3891,"it would be rude not to show up."],[4133,4229,"This will be fine."],[5695,5783,"Who are they?"]],"10":[[112,195,"Who are they?"],[366,554,"Just a bellhop from the hotel."],[612,