ive her"],[11398,11632,"Mr. Lawrence’s sperm."],[11632,11824,"Okay. Okay. Yeah."]],"4":[[567,734,"You must be Miss Gray."],[779,867,"Jerry's already explained"],[867,955,"your situation to me."],[996,1117,"My job is to make sure"],[1117,1213,"this whole process"],[1213,1359,"goes smoothly for you."],[1547,1710,"So these are our most"],[1710,1835,"highly coveted donors."],[1922,2039,"I personally recommend"],[2039,2185,"this one in the middle."],[2210,2298,"Take a look."],[2573,2719,"Brown eyes."],[2719,2898,"Six foot two."],[2898,3073,"Harvard Business School graduate."],[3073,3282,"Collegiate basketball player."],[3282,3382,"Why does this sound"],[3382,3511,"like my boss?"],[3745,3883,"Is something not to your liking?"],[3883,3924,"Oh, no."],[3924,4070,"No, I just want to see"],[4070,4225,"if any of the others catch my eye."],[4266,4508,"Ma'am, as a future mother,"],[4542,4637,"don't you want what's best"],[4637,4729,"for your child?"],[4729,4884,"It's clear just from a"],[4884,5025,"quick glance that this donor"],[5084,5217,"is head and shoulders"],[5217,5284,"above the others."],[5338,5484,"Of course I want what's best"],[5484,5609,"but a man that perfect..."],[5609,5772,"I mean, he must be expensive."],[5860,6039,"Don't worry about the price,"],[6039,6277,"we're having a sale right now."],[6277,6552,"And seeing as you're Jerry's friend,"],[6552,6831,"we can give you a double discount."],[6831,6927,"Oh, wow."],[6927,7157,"That's actually not that bad."],[7215,7386,"In that case, I'll take him."],[7453,7603,"When can we do the procedure?"],[7603,7745,"Today, if you're ready."],[7745,7907,"We just ask that you"],[7907,8049,"rest 15 minutes afterwards,"],[8083,8237,"and we recommend you get a"],[8237,8383,"pregnancy test in about two weeks."],[8479,8696,"I'm ready. Let's do it today."]],"5":[[0,150,"So we plan to open"],[150,300,"the resort just next month."],[325,596,"My team is extremely excited."],[596,767,"Hey Boss..."],[767,855,"We hope that everything goes"],[