{"1":[[838,921,"So,"],[1021,1201,"you're the guy my father"],[1259,1359,"set me up with?"],[1359,1443,"Yeah."],[1472,1614,"I'm quite a catch."],[1676,1843,"I've been married three times."],[1868,2056,"You've been married three times?"],[2056,2168,"Don't worry."],[2168,2285,"They're all dead."],[2610,2819,"You know, your parents,"],[2819,2973,"they told me you were a virgin."],[3169,3328,"Well, clearly..."],[3353,3541,"they are working with some"],[3541,3782,"outdated information."],[3858,3953,"I mean,"],[3999,4200,"if you want to marry me and"],[4250,4416,"raise another man's baby."],[4416,4533,"Normally,"],[4533,4662,"that'd be a dealbreaker for me,"],[4662,4742,"but…"],[4829,4921,"I've never scored with"],[4921,5050,"a pregnant chick before,"],[5050,5230,"so I think we can have a lot of fun."],[5230,5321,"Let go of me!"],[5321,5543,"Just shut up, you little slut!"],[5593,5734,"Look at what you're wearing."],[5759,5876,"You should feel thankful"],[5876,6047,"that I'm even interested in you."],[6093,6310,"Women like you don't have the right"],[6310,6418,"to be a prude."],[6431,6602,"I am not marrying you."],[6602,6723,"Oh,"],[6723,6877,"your father already took my money,"],[6877,6986,"so your opinion"],[6986,7182,"doesn't really matter here, sweetheart."],[7699,7795,"Bitch!"],[7862,7962,"Once you belong to me,"],[7962,8099,"I'm gonna teach you some hard lessons"],[8099,8262,"on how to respect a man!"],[8875,8963,"This guy,"],[9000,9221,"he's my way out of this."],[9221,9280,"Look,"],[9376,9501,"my baby daddy's here."],[10110,10210,"Hey, handsome,"],[10214,10293,"kiss me."]],"2":[[362,471,"Who the hell is this guy?"],[471,596,"What's going on here?"],[621,992,"I forgot to mention that I told my"],[992,1238,"baby daddy to meet me here."],[1326,1388,"Honey,"],[1388,1493,"I'm so glad you're"],[1493,1601,"back from your"],[1622,1764,"boxing training session."],[1764,1989,"This creep was harassing me."],[2077,2206,"Well, honey,"],[2277,2406,"I'd love to show you"],[2406,2544,"the results of my training."],[2640,2723,"No."],[2802,2932,"There's no need for that, I..."],[3003,3103,"I was just leaving."],[3345,3465,"You'll regret this."],[3841,3978,"Thank you for that."],[3978,4162,"You really saved me."],[4279,4362,"I gotta go."],[4437,4575,"That was a"],[4575,4688,"fine little performance"],[4688,4821,"we put on right there."],[4925,5084,"So, is it a boy?"],[5150,5363,"Or a girl, or..."],[5426,5526,"a stuffed animal?"],[5822,5955,"A pillow, actually."],[5955,6051,"Clever."],[6051,6151,"Clever girl."],[6289,6464,"Boss, bad news."],[6489,6598,"The contract bride,"],[6598,6694,"she can't make it to the"],[6694,6790,"engagement party."],[6844,6948,"Should we call it off?"],[7082,7182,"No need."],[7182,7265,"I've got a replacement"],[7265,7332,"right here."],[7390,7540,"Wait..."],[7866,8124,"Mr. Vega is every girl's dream man."],[8137,8345,"I wonder who the lucky girl is?"],[8383,8562,"Can't be anything serious."]],"3":[[633,888,"Hey, this is way over the top."],[967,1067,"I mean, we're not actually"],[1067,1146,"getting married after"],[1146,1267,"one stupid kiss..."],[1426,1509,"Right?"],[1564,1685,"Just play along."],[1714,1835,"This engagement party"],[1835,1939,"is important to me."],[2014,2110,"Well, you did save me,"],[2110,2268,"so I owe you."],[2323,2402,"Besides,"],[2469,2660,"you know I'm good at playing pretend."],[3182,3307,"Who is she?"],[3374,3532,"What makes her good enough"],[3532,3674,"for Grant Vega?"],[3720,3807,"Everyone,"],[3862,3983,"meet my fiancée..."],[4124,4275,"Alice Breslin."],[4295,4396,"Hi everyone,"],[4396,4533,"thank you all so much"],[4533,4704,"for coming to our engagement party."],[4917,4992,"Good girl."],[6243,6381,"You've earned this."],[6435,6564,"Are you serious?"],[6727,6894,"We have to make it look real."],[6973,7073,"Just trust me."]],"4":[[150,429,"Why is it so hot when I'm near him?"],[508,654,"I need to stay away from this man."],[654,917,"This, this is dangerous."],[1317,1447,"Don't forget,"],[1509,1626,"you started this."],[1672,1810,"Yeah, yeah, I just um..."],[1885,1964,"thirsty."],[2060,2198,"I'm going to grab a drink."],[3007,3132,"Let's see..."],[3207,3424,"Grant Vega."],[3503,3707,"CEO of Vireo Group,"],[3707,3924,"America's No.1 conglomerate."],[3924,4195,"Known for his cold demeanor,"],[4195,4387,"ruthless business strategies,"],[4387,4746,"and aversion to relationships."],[4825,4984,"Oh god!"],[5030,5130,"I'm basically tangled up"],[5130,5284,"with a cold-hearted movie villain."],[5568,5684,"I gotta get out of here."],[6047,6231,"I can't believe someone like you"],[6231,6443,"is engaged to Mr. Vega."],[6485,6677,"You're just a sewer rat"],[6677,6861,"who crawled into his bed!"],[6911,7069,"We know women like you."],[7152,7278,"You'd do anything."],[7344,7532,"You'd spread your legs for anything."],[7632,7774,"Take a look in the mirror."],[7774,7941,"You don't deserve Mr. Vega."],[8058,8153,"Okay,"],[8153,8341,"I don't have time for your barking."],[8404,8504,"Get out of my way."],[8608,8854,"Don't you walk away from us, you bitch!"]],"5":[[33,150,"Are you crazy?"],[191,296,"How dare you hit us!"],[296,408,"Hold it right there."],[525,913,"You know, you are much prettier"],[913,1001,"when you're not shouting"],[1001,1092,"like a maniac."],[1092,1284,"You're out of your mind!"],[1284,1505,"Do you know who we are?"],[1551,1810,"I don't care who you are, okay?"],[1810,2052,"I'm not the kind of girl who stays quiet"],[2052,2214,"when she's being pushed around."],[2256,2448,"I knew I chose the right woman."],[2577,2706,"So please,"],[2748,2831,"leave me alone."],[2948,3073,"Where do you think you're going?"],[3153,3232,"I have to go."],[3511,3616,"Mr. Vega,"],[3716,3866,"your fiancée is a bully."],[3866,4070,"Look what she did to us."],[4108,4270,"You were the ones bullying her."],[4295,4454,"Fending you off must have really"],[4454,4571,"hurt her hands."],[4625,4792,"Now listen to me carefully."],[4825,4938,"Alice is mine."],[4938,5088,"Stay away from her,"],[5088,5217,"or I'll make you."],[5217,5347,"Understood?"],[5347,5455,"Now get out."],[5955,6160,"Boss, your fiancée..."],[6548,6765,"Grandma, I'm engaged now."],[6781,7040,"Please go ahead and get the surgery."],[7107,7332,"An engagement isn't enough."],[7332,7686,"I need to see you married, or I swear"],[7724,7991,"I'm not walking into that hospital."],[8108,8241,"Get everything ready."],[8241,8350,"Alice and I are getting married"],[8350,8412,"tomorrow."]],"6":[[734,938,"You ungrateful brat!"],[1092,1188,"How dare you"],[1188,1368,"ruin the arrangement we set up?"],[1401,1568,"I am not marrying you."],[1568,1626,"Oh,"],[1685,1839,"your father already took my money,"],[1839,2002,"so your opinion doesn't really"],[2002,2143,"matter here, sweetheart."],[2168,2264,"You wanted me to marry"],[2264,2464,"that sleazy, middle-aged man?"],[2510,2615,"He's abusive!"],[2615,2848,"All three of his ex-wives died."],[2848,3032,"Well, what do you expect?"],[3065,3199,"Look at yourself."],[3228,3353,"You should be glad that man"],[3353,3470,"even wants you."],[3553,3657,"Oh,"],[3678,3812,"women like you"],[3858,3962,"are all the same,"],[4033,4220,"ungrateful bitches!"],[4546,4662,"Careful, Eddy."],[4704,4859,"She won't be able to land a husband"],[4859,4979,"if she has scars."],[5013,5105,"Remember?"],[5105,5221,"This is your idea."],[5267,5426,"We need you to bring in the money."],[5426,5538,"Don't think I don't know what you're"],[5538,5697,"scheming about, Jessica."],[5697,5843,"You manipulated my father,"],[5843,6022,"and you drove my mother to her death."],[6022,6264,"Don't speak to your stepmother like that!"],[6268,6664,"Alice, you don't get to be picky."],[6664,6790,"Decent men,"],[6790,7023,"they want to marry refined women,"],[7023,7207,"like your sister, Tiffany."],[7248,7328,"In fact,"],[7328,7515,"you should be on your knees right now"],[7515,7670,"thanking God that any man"],[7670,7782,"even wants you!"],[7824,8012,"Delivery from the Vireo Corp."]],"7":[[1964,2135,"These gifts, I-"],[2135,2227,"I can't imagine"],[2227,2344,"how much they must have cost."],[2344,2460,"Vireo Corporation."],[2460,2648,"Are these all from the famous CEO,"],[2648,2744,"Mr. Vega?"],[2744,2865,"That's right."],[2957,3036,"Tomorrow,"],[3086,3324,"Mr. Vega will come pick up his bride."],[3324,3574,"Please be prepared."],[3574,3749,"\"Pick up his bride?\""],[3795,3878,"Wait,"],[3878,4070,"he's actually serious about me?"],[4116,4220,"Yes, sir!"],[4220,4337,"Absolutely!"],[5113,5209,"Tiffany,"],[5209,5413,"when did you start seeing Mr. Vega?"],[5455,5559,"Look at this gift!"],[5559,5722,"Mr. Vega?"],[5722,6006,"I may have met him last month"],[6006,6210,"at the Vireo offices."],[6210,6460,"He must have fallen for me at first sight!"],[6614,6865,"What's so funny, Alice?"],[6865,6986,"Jealous?"],[6986,7073,"It's not my fault that"],[7073,7132,"no one wants"],[7132,7315,"a computer freak like you."],[7315,7461,"Mark my words,"],[7461,7632,"you're gonna die alone."],[7632,7803,"Don't worry about me, sis."],[7853,7995,"I'll be just fine."],[8083,8270,"Congratulations, Tiffany."],[8304,8550,"Don't listen to your loser sister."],[8550,8733,"We have to get ready for tomorrow."],[8733,8971,"This has to be a grand affair!"],[8971,9171,"They think Grant Vega is coming to"],[9171,9296,"marry Tiffany?"],[9396,9551,"Looks like tomorrow is gonna be"],[9551,9688,"quite the show!"]],"8":[[166,266,"Bad news, boss."],[308,367,"We've been hit by another"],[367,479,"cyber-attack!"],[517,667,"We have to find the legendary hacker,"],[667,759,"Glitch."],[775,963,"He's the only one who can help us."],[988,1101,"We've been trying,"],[1101,1247,"but so far we've got nothing."],[1284,1409,"Glitch is like a ghost."],[1480,1601,"We don't know even"],[1601,1764,"if we're looking for a man or a woman."],[1968,2085,"Keep searching."],[2122,2302,"No matter what it takes,"],[2302,2485,"we need to find Glitch."],[2502,2694,"Tiffany, you are a beautiful bride."],[2740,2840,"You and Mr. Vega will be"],[2840,2961,"the perfect couple."],[3061,3219,"Unlike this little rat,"],[3303,3478,"no man will ever take her!"],[3524,3682,"Don't worry, Alice."],[3682,3899,"After I become Mrs. Vega,"],[3899,4108,"I'll try to find you a husband."],[4129,4233,"Perhaps..."],[4233,4429,"a janitor at his company?"],[4646,4859,"Worry about yourself, Tiffany."],[4929,5084,"You haven't even tied the knot yet."],[5084,5201,"Listen to her!"],[5201,5338,"So petty,"],[5338,5522,"jealous of her own sister."],[5547,5739,"Yeah, know your place, Alice."],[5780,5885,"I have a neighbor."],[5918,6039,"His wife just died."],[6110,6256,"I can connect you two, huh?"],[6297,6414,"That's right!"],[6414,6548,"I also know a guy who just"],[6548,6648,"got out of jail."],[6677,6848,"He can be your perfect match."],[6886,7065,"Well, aren't you all just so sweet"],[7065,7203,"to worry about me?"],[7203,7403,"Watch your attitude, Alice."],[7428,7674,"Tiffany is about to become Mrs. Vega."],[7703,7891,"She could squash you like a bug."],[7928,8028,"You know, not everyone"],[8028,8237,"wants to marry rich, Tiffany."],[8291,8487,"I create my own fortunes."],[8487,8625,"Fortunes?"],[8625,8783,"You're just an IT nerd."],[8783,8996,"What fortunes could you have?"],[9038,9196,"Joke's on you, sis."],[9234,9313,"Truth is,"],[9313,9517,"I'm the legendary hacker,"],[9542,9663,"Glitch."],[9684,9801,"I have skills,"],[9905,10243,"and a brain, unlike you trophy wife."],[10243,10435,"What did you say, bitch?"],[10748,10944,"Good luck with your wedding."],[10944,11148,"I'm sure everything is..."],[11165,11244,"totally gonna work out"],[11244,11332,"the way you planned."],[11353,11448,"Shut up!"],[11490,11649,"Mr. Vega will be here any minute"],[11649,11736,"and you"],[11736,11874,"will regret mistreating"],[11874,12053,"the future Mrs. Vega,"],[12124,12241,"little brat!"]],"9":[[1142,1288,"We're here, boss."],[1288,1447,"I'm coming, Alice."],[1455,1697,"Today is the day I make you my wife."],[1985,2089,"Mr. Vega!"],[2089,2164,"He's here!"],[2223,2377,"See that, Alice?"],[2394,2577,"Once I become Mrs. Vega,"],[2577,2852,"I'll use his fortune and his fame to"],[2852,3023,"toss you in the sewer,"],[3023,3261,"like the dirty little rat you are."],[3261,3370,"Is that so?"],[3440,3582,"Your crazy daughter won't try to"],[3582,3712,"play any games, will she?"],[3803,4020,"What if she ruins Tiffany's big day?"],[4099,4220,"We should lock her up before"],[4220,4329,"Mr. Vega arrives."],[4446,4542,"You two,"],[4604,4700,"tie Alice up,"],[4721,4871,"lock her in her room."],[4967,5013,"Dad!"],[5013,5134,"What are you doing?"],[5134,5255,"I'm your daughter, too."],[5347,5505,"What are you waiting for, Eddy?"],[5513,5601,"Shut up!"],[5663,5764,"I'm not gonna let you ruin"],[5764,5947,"Tiffany's chance with Mr. Vega."],[6006,6177,"Tiffany's the only daughter for me."],[6460,6560,"Hey!"],[8233,8358,"Look at him."],[8358,8483,"He's perfect!"],[8483,8591,"I know."],[8612,8796,"Tiffany is so lucky."],[8917,9171,"Mr. Vega really came to marry me."],[9171,9371,"It's like a dream come true!"],[9547,9684,"Where is she?"]],"10":[[25,208,"Mr. Vega, here's your bride."],[312,525,"I'm right here, Mr. Vega."],[567,642,"What?"],[642,804,"I'm not here to marry you."],[938,1155,"I, I'm sorry, Mr. Vega..."],[1155,1251,"then"],[1251,1463,"who are you looking to marry today?"],[1463,1659,"I'm here to marry Alice."],[1697,1881,"How could he be here for her?"],[1951,2147,"Guards, find her,"],[2147,2273,"even if you have to turn this place"],[2273,2356,"upside down."],[2402,2481,"What?"],[2481,2619,"When did Alice get involved"],[2619,2794,"with someone like Mr. Vega?"],[2794,2952,"We can't let that little bitch"],[2952,3057,"marry Mr. Vega."],[3057,3178,"She'll ruin us!"],[3257,3436,"I'm sorry, Mr. Vega."],[3453,3641,"There's no one named Alice here."],[3661,3803,"When your assistant delivered the gifts,"],[3803,3903,"we all thought you were here to marry"],[3903,4020,"my daughter, Tiffany."],[4162,4245,"Boss,"],[4270,4391,"according to my information,"],[4391,4533,"Miss Alice does live here."],[4575,4725,"There must be some mistake."],[4754,4988,"We've never met anyone named Alice."],[4988,5138,"We would never deceive you."],[5155,5221,"Yes, sir."],[5221,5380,"We wouldn't lie to you."],[6064,6268,"It seems like we made a mistake."],[6268,6331,"Let's go."]],"11":[[8,154,"What are we going to do?"],[154,383,"Alice knows the Mr. Vega, and..."],[383,592,"we've been bullying her for years."],[592,675,"Don't worry."],[675,825,"We just have to marry her quick."],[855,950,"Mr. Vega will not want"],[950,1096,"a hand-me-down wife."],[1172,1301,"Good idea, Mom."],[1814,1981,"Boss, great news!"],[2052,2248,"I've got a lead on the top hacker, Glitch."],[2460,2540,"Wait..."],[2590,2740,"Glitch is in this house?"],[3315,3395,"Mr. Vega, I, I,"],[3395,3653,"I told you Alice isn't here."],[3674,3807,"She might not be,"],[3807,4012,"but someone else I'm looking for is!"],[4045,4212,"Boss, right there,"],[4250,4329,"in that room."],[4542,4750,"Move aside, or I'll do it for you,"],[4750,4867,"and it won't be pretty."]],"12":[[162,283,"Alice?"],[283,417,"Could she be Glitch?"],[446,592,"The world's best hacker?"],[1776,1864,"Boss, the-"],[1897,2102,"the signal for Glitch just vanished."],[2102,2277,"The system must be malfunctioning."],[2318,2473,"At least we found Alice."],[2494,2619,"Get someone to fix the bug."],[2619,2702,"Now!"],[2702,2765,"Yeah."],[4491,4629,"Let's get you out of here."],[4658,4817,"Grant, you saved me."],[4867,5059,"Mr. Vega, please let me explain."],[5088,5251,"Alice is mentally unstable."],[5251,5417,"She's not fit to be your wife."],[5451,5526,"We didn't mean"],[5526,5672,"to keep her away from you, but..."],[5739,5905,"it's for your own good."],[5905,6022,"Is that so?"],[6035,6260,"And since when have you had the right"],[6260,6435,"to make decisions for me?"],[6460,6531,"No, no, no."],[6531,6656,"That's, that's not at all"],[6656,6748,"what we meant, sir."],[6748,6919,"Alice is my fiancée."],[6961,7048,"Harm her,"],[7061,7211,"and I'm coming for you."],[7269,7415,"Now get out,"],[7415,7536,"and never show your face"],[7536,7674,"in front of us again."],[8187,8287,"What are you doing?"],[8295,8433,"Taking my bride home."]],"13":[[412,554,"Take care of her injuries,"],[554,759,"and dress her nicely in the gown."],[859,1042,"Thank you for rescuing me earlier,"],[1042,1126,"Grant, but"],[1155,1355,"I think maybe you should reconsider."],[1355,1584,"I mean, I'm sure you could find someone"],[1584,1772,"much more suitable for you..."],[2139,2252,"Great."],[2252,2423,"From one prison to another..."],[4045,4124,"Wow."],[4179,4412,"Listen, Grant."],[4475,4650,"Do you think we could maybe"],[4746,5000,"talk about this marriage thing?"],[6314,6485,"What is there to discuss?"],[6544,6831,"Do you think you can find someone richer,"],[6894,7032,"more handsome,"],[7065,7203,"better than me?"],[7294,7411,"Probably not..."],[7699,7887,"And I did saved you."],[7937,8116,"So if you think about it,"],[8170,8291,"you owe me."],[8475,8541,"But..."],[8600,8779,"I mean, we don't have any"],[8779,8983,"real feelings for each other."],[9421,9542,"Is that so?"]],"14":[[592,759,"Does that count as feelings?"],[1055,1272,"I'll take that as a yes."],[1272,1539,"God, he makes me feel so alive."],[1601,1851,"No one has ever made me feel so..."],[1851,1997,"out of control."],[2135,2389,"Grant, this is too fast."],[2389,2494,"Maybe,"],[2540,2731,"but judging by your reaction,"],[2831,3015,"I can tell that you can handle it."],[3415,3582,"And you like it."],[5993,6135,"Already overwhelmed?"],[6197,6464,"How will you ever handle what's next?"],[6727,6890,"Are you scared?"],[7065,7219,"I'm never scared."],[7219,7344,"And you, Grant?"],[7494,7595,"Are you scared?"]],"15":[[817,967,"It's already nine o'clock!"],[1351,1501,"How did this happen?"],[1814,1931,"He's charming,"],[2010,2114,"and he has protected me"],[2114,2243,"time and time again."],[2360,2552,"I guess I could do a lot worse..."],[3607,3832,"Look who's finally up."],[3866,3912,"You know,"],[3912,4137,"a conniving little nobody like you"],[4137,4346,"doesn't deserve my brother."],[4408,4521,"Excuse me?"],[4592,4850,"You weaseled your way into my family,"],[4850,5050,"and I'm gonna spend every day,"],[5050,5263,"making sure that you regret it."]],"16":[[16,296,"You think you can stroll into my family,"],[321,567,"marry Grant, and play queen?"],[600,717,"Not happening."],[734,875,"What are you talking about?"],[875,950,"Grant married me"],[950,1080,"because he wanted to."],[1096,1192,"Please!"],[1217,1463,"You are just a charity case"],[1463,1576,"with a ring."],[1605,1722,"Let's be real."],[1722,1822,"You're not even fit to"],[1822,2056,"scrub the floors in a house like this."],[2064,2189,"But since my brother"],[2189,2402,"wants you around for..."],[2460,2648,"some reason!"],[2690,2986,"I guess we can pity you with this job."],[2986,3086,"You can"],[3086,3257,"start by scrubbing the toilets."],[3257,3453,"I married Grant to be his wife,"],[3495,3641,"not the help."],[3641,3720,"And,"],[3799,3966,"as the lady of the house,"],[3966,4049,"you might want to watch"],[4049,4162,"how you speak to me."],[4229,4312,"You little..."],[4967,5201,"Seems like you need a lesson in manners."],[5213,5301,"Wait-"],[6118,6247,"You're crazy!"],[6247,6398,"I'm not the one making messes"],[6398,6498,"that I can't clean up."],[6523,6694,"Just wait until my brother"],[6694,6823,"hears about this."],[6961,7069,"Then tell him."],[7098,7323,"Alice, Grant doesn't even like you!"],[7323,7524,"He loves someone else."]],"17":[[8,279,"Grant loves Samara."],[279,429,"Always has."],[429,608,"His childhood sweetheart,"],[625,796,"a wealthy heiress,"],[796,1009,"and his perfect match."],[1009,1292,"Women like you are just a sad,"],[1292,1539,"pathetic joke"],[1539,1672,"compared to her."],[1714,1872,"And if it weren't for Grandma"],[1872,2039,"forcing him into this sham marriage"],[2039,2256,"so she'd agree to the surgery,"],[2256,2464,"he'd still be waiting for Samara."],[2506,2598,"And now that"],[2598,2848,"Grandma's surgery is done,"],[2848,3011,"you'll be out of here"],[3011,3136,"in no time."],[3219,3395,"You say that like I want to stay."],[3395,3728,"So he was forced into marrying me."],[3728,3887,"And he doesn't love me at all..."],[3974,4216,"What were you thinking, Alice?"],[4479,4646,"So good to see you again."],[4871,5000,"I missed you."],[5155,5376,"That must be Samara,"],[5376,5601,"the heiress Grant is really in love with."],[5955,6214,"Samara, what are you doing?"],[6214,6389,"We're not kids anymore."],[6389,6552,"I'm married now."],[6552,6748,"You can't be hanging all over me."],[6831,6961,"You only married her"],[6961,7090,"because of your grandmother."],[7123,7257,"You don't really love her."],[7323,7553,"I mean, look at me..."],[7586,7707,"and look at her."],[7728,7878,"It's an easy choice."],[7878,8091,"You don't know Alice, Samara,"],[8091,8233,"and you don't know me."],[8249,8362,"I'm married."],[8441,8596,"And I'm warning you..."],[8596,8796,"stay away from me and my wife."],[9271,9471,"That desperate little bitch."],[9530,9688,"How dare you steal my man?"],[9709,9901,"Enjoy it while it lasts, sweetheart."],[9951,10118,"He'll be mine again soon."]],"18":[[308,425,"What happened to you?"],[425,592,"What happened?"],[613,880,"Your so-called wife happened."],[880,1030,"Look at what she did to me!"],[1046,1347,"She's completely unhinged, Grant."],[1347,1534,"You need to get rid of her!"],[1639,1726,"Divorce her,"],[1801,2002,"and marry Samara instead."],[2102,2231,"I know Alice,"],[2231,2477,"and I know she'd never do this to you,"],[2477,2669,"if you didn't give her a reason to."],[2669,2886,"She's a kind person, Elodie,"],[2886,3078,"and she's earned my respect,"],[3094,3203,"something you and Samara"],[3203,3303,"could learn from her."],[3908,4016,"Grant!"],[4079,4204,"Ever heard of knocking?"],[4279,4404,"This is my home."],[4458,4621,"I go where I please."],[4646,4821,"Well, I'm trying to take a shower,"],[4821,5042,"thanks to your charming sister."],[5096,5255,"So could I please get a moment"],[5255,5430,"of privacy and peace?"],[5472,5551,"Oh,"],[5572,5739,"you need privacy now?"],[5939,6097,"Nothing I haven't seen already."],[6114,6197,"Ah, you..."]],"19":[[79,312,"Looks like I saved you again, Alice."],[446,525,"Look..."],[592,938,"my sister was way out of line earlier."],[1042,1242,"I apologize for her."],[1351,1564,"And that's your way of apologizing?"],[1618,1714,"No."],[3086,3332,"That's my way of apologizing."],[3478,3636,"Do you believe I'm sorry?"],[3803,4049,"I think I could be further convinced."],[4779,4950,"We're soaking wet."],[4992,5188,"You definitely will be."],[5605,5772,"What about Samara?"],[5805,5905,"What about everything"],[5905,6031,"Elodie said?"],[6068,6164,"Grant,"],[6185,6339,"should we be doing this?"],[6381,6556,"The only thing I care about"],[6556,6815,"is making you feel comfortable."],[7949,8237,"I need to taste you."]],"20":[[905,1113,"I cannot believe he got me again."],[1547,1685,"Alice, Alice,"],[1685,1922,"what have you got yourself into?"],[3103,3178,"Alice."],[3186,3349,"One second! I'm one line away from"],[3349,3478,"finishing this code!"],[3762,3987,"Are you deaf, nerd?"],[3987,4104,"I'm talking to you."],[4154,4245,"We have an important client"],[4245,4320,"visiting today."],[4333,4458,"So go get him some coffee."],[4562,4779,"Isn't getting coffee your job?"],[4800,5017,"I'm literally keeping this place running."],[5184,5259,"Well,"],[5305,5392,"Michael said that"],[5392,5463,"because you were late,"],[5463,5601,"this is your punishment."],[5601,5755,"Unless you want to lose your bonus."],[6569,6715,"Oh, Alice."],[6802,6944,"How do you even justify"],[6944,7073,"that fat paycheck"],[7073,7294,"when you barely lift a finger?"],[7374,7578,"It's about time I got you fired."],[7607,7745,"Did you see that client"],[7745,7866,"in the meeting room?"],[7866,8033,"He's so hot."],[8045,8304,"I wonder what type of woman he likes."],[8420,8508,"Am I the only one"],[8508,8662,"who can take my job seriously"],[8662,8771,"instead of spending my day"],[8771,8925,"lusting over clients?"],[9075,9142,"Wait."],[9209,9434,"What is Grant doing at this company?"]],"21":[[191,429,"Isn't this Alice, the biggest nerd"],[429,554,"from tech support?"],[592,713,"What are you doing here?"],[763,1001,"I was told to bring coffee."],[1092,1234,"Drop the act."],[1263,1534,"You're here trying to seduce Mr. Vega,"],[1534,1609,"aren't you?"],[1659,1810,"You can forget about it."],[1860,2093,"He's way above your pay-grade."],[2114,2306,"He will never be interested in"],[2306,2410,"someone like you."],[2556,2677,"Alice,"],[2690,2831,"why aren't you at your workstation?"],[2952,3011,"Oh,"],[3065,3136,"wow!"],[3186,3319,"Are you trying to impress Mr, Vega by"],[3319,3465,"bringing him coffee?"],[3490,3570,"Pathetic."],[3632,3845,"You are a waste of time and space"],[3845,3949,"for this company."],[3958,4112,"Waste of time and space?"],[4120,4179,"Without me,"],[4179,4400,"this company's antiquated system"],[4400,4533,"would have crashed ages ago."],[4629,4792,"Please, as if we believe that."],[4817,5030,"Just wait until we tell Mr. Vega"],[5030,5184,"that you're trying to sleep your way"],[5184,5280,"to the top."],[5313,5413,"Who knows how many men"],[5413,5497,"she's been with."],[5551,5701,"You're probably riddled with diseases."],[5935,5976,"Alice,"],[5976,6160,"have you lost your mind?"],[6281,6373,"Don't just stand there."],[6373,6456,"Grab her!"],[6998,7157,"Well, both of our legal teams"],[7157,7282,"have agreed to the terms."],[7282,7520,"And I'm very excited to say"],[7561,7732,"that we are going to be in business"],[7732,7824,"together, Mr. Vega."],[8212,8358,"What's happening out there?"],[8395,8591,"Why does it sound so much like Alice?"]],"22":[[546,825,"What on earth is going on here?"],[909,996,"Alice!"],[1038,1159,"Michael, Alice attacked us."],[1159,1259,"She's gone crazy."],[1359,1438,"Crazy?"],[1472,1659,"You're the one trying to sabotage me,"],[1659,1830,"because you're jealous of my skills,"],[1830,1947,"and my love life."],[2002,2081,"Love?"],[2097,2235,"Being a whore for a sugar daddy doesn't"],[2235,2323,"equate to love."],[2344,2423,"Slut!"],[2840,2977,"Call me whatever you want,"],[2982,3203,"but don't you dare insult my husband."],[3240,3365,"She stood up for me."],[3440,3582,"You just saw that, Michael."],[3603,3753,"She's completely out of control."],[3753,3966,"Keeping someone like her here is a liability."],[4108,4225,"What do you have to say for yourself,"],[4225,4300,"Alice?"],[4350,4450,"Nothing."],[4763,4863,"Except..."],[5113,5201,"I quit."],[5254,5300,"Good luck when your"],[5300,5459,"company's system crashes."],[5684,5851,"You arrogant bitch."],[5901,6031,"You think this company can't"],[6031,6118,"survive without you."],[6122,6243,"I've heard enough."],[6306,6473,"It seems like there's no point in us"],[6473,6589,"proceeding with this deal."],[6644,6806,"Wait, Mr. Vega, please,"],[6806,7019,"we are eager to work with you."],[7023,7136,"But Alice is fired."],[7136,7265,"She has nothing to do with this"],[7265,7328,"company anymore."],[7369,7469,"Well, that's a shame,"],[7507,7620,"because if she did,"],[7720,7870,"maybe I would reconsider."],[7920,8108,"Mr. Vega, you know Alice?"]],"23":[[25,108,"No."],[208,342,"No, we don't know each other."],[600,771,"The company system crashed."],[788,942,"We are losing everything."],[1121,1297,"Do something, Alice."],[1401,1526,"I'm sorry,"],[1564,1747,"I thought I was fired."],[1785,1951,"I don't have any obligation to"],[1951,2018,"your company."],[2198,2344,"Looks like you fired the wrong girl,"],[2344,2452,"Michael."],[2594,2723,"You stupid girl."],[2723,2819,"Look at what you did."],[2877,3036,"Apologize to Alice."],[3044,3186,"Get on your knees."],[3440,3745,"Alice, I am so sorry."],[3812,3974,"I'm sure Regina is as well."],[3974,4250,"If you could just accept our apology"],[4250,4371,"and find it in your heart to"],[4371,4529,"convince Mr. Vega"],[4529,4679,"to sign the contract."],[4704,4879,"It's our company's only hope."],[6264,6427,"It's too late to apologies."],[6656,6744,"Once again,"],[6744,6931,"looks like you fired the wrong girl."]],"24":[[617,788,"Why did you say you didn't know"],[788,867,"me back there?"],[1063,1192,"Is there a problem with that?"],[1384,1497,"What do you think,"],[1622,1701,"wife?"],[1985,2110,"I know I'm just your wife"],[2110,2231,"because you're desperate."],[2310,2389,"Oh..."],[2410,2548,"you think a man like me"],[2548,2677,"doesn't have options?"],[2794,2969,"Then why did you choose me?"],[3169,3249,"Well,"],[3340,3532,"because when we first met,"],[3707,3841,"you kissed me first"],[3987,4233,"which was very sexy."],[4387,4483,"Because"],[4546,4688,"you're a hard worker,"],[4829,4929,"smart."],[4984,5263,"You've never been handed anything."],[5347,5597,"You've worked for your success,"],[5634,5718,"and"],[5822,6031,"you put me in place like"],[6068,6306,"no woman has ever dared to do..."],[6427,6548,"and you're just"],[6810,6894,"wonderful!"]],"25":[[875,1034,"But I'm not your first choice."],[1034,1255,"You would rather be with Samara..."],[1351,1530,"Alice, what are you talking about?"],[1830,1964,"What is that supposed to mean?"],[2152,2210,"It means,"],[2210,2381,"I'm not going home with you, Grant."],[2494,2665,"Get in the car, Alice."],[2665,2890,"You can't just walk away from me like this."],[2890,2969,"No."],[3132,3349,"Be a good girl, and get in the car."],[3357,3436,"No."],[3703,3791,"Hey, what are you-"],[3803,4008,"Grant Vega, put me down!"],[4696,4758,"Shh,"],[4800,4900,"Alice,"],[4954,5096,"keep fighting me,"],[5134,5276,"and I'm gonna have to kiss you again."]],"26":[[2164,2268,"Are you calm now?"],[2385,2677,"Why is it so hard to stay mad at him?"],[2727,2840,"Now, back there,"],[2861,3007,"why did you pretend you didn't even"],[3007,3065,"know me?"],[3082,3224,"Like we're not even married?"],[3265,3507,"I know that you only married me"],[3507,3591,"so that your grandma"],[3591,3691,"would get the surgery."],[3695,3870,"And of course,"],[3870,4054,"because the beautiful Samara"],[4054,4237,"that I could never compete with,"],[4237,4446,"was unavailable..."],[4496,4688,"And now that your grandma's had surgery,"],[4750,4867,"why should I stick around?"],[5130,5271,"You should stay"],[5271,5397,"because you're my wife."],[5584,5730,"And what if I don't want to?"],[5939,6043,"If you want me to make"],[6043,6185,"my sister apologize-"],[6185,6314,"It's not about her."],[6802,6969,"If you don't want to be my wife,"],[6969,7061,"you're free to go."],[7228,7311,"Really?"]],"27":[[8,162,"I can leave as I please?"],[241,333,"Yes."],[354,454,"But not now!"],[533,734,"Grandma still needs time to recover."],[1134,1255,"So, after she's better"],[1347,1443,"then I can leave?"],[1685,1856,"We can discuss this over dinner."],[1868,2006,"It's time for you to eat."],[3144,3236,"You are not gonna eat?"],[3286,3407,"I'm not hungry yet."],[3436,3591,"I ate plenty last night."],[4629,4692,"Well."],[4783,4884,"If you're not hungry,"],[4884,5025,"then why did you bring me here?"],[5138,5246,"Because you are."],[5409,5522,"Just because you're right,"],[5522,5630,"doesn't mean you know me."],[5784,5880,"Maybe,"],[5880,6068,"I want to keep getting to know you."]],"28":[[125,417,"Maybe I want to keep getting to know you."],[871,980,"This is my card."],[1080,1188,"Use it as you'd like."],[1426,1601,"You think that just because"],[1601,1697,"I'm unemployed,"],[1697,1810,"you can buy me off?"],[1876,2031,"I'm not that kind of girl."],[2089,2248,"Besides, I don't need the money."],[2281,2452,"I could hack his bank account"],[2452,2619,"before he finishes his drink."],[2656,2865,"It's only natural for a husband"],[2865,3032,"to want to spend on his wife."],[3094,3178,"Well, thank you."],[3265,3345,"But"],[3395,3632,"what I need is a job,"],[3632,3724,"not money."],[3770,3853,"A job?"],[3941,4200,"Vireo Group's tech department could"],[4250,4371,"use someone like you."],[4437,4500,"Okay,"],[4500,4700,"what I don't need is a pity job."],[4733,4867,"It's not pity."],[4896,5146,"At your last company you were clearly"],[5146,5321,"the only person capable of"],[5321,5447,"keeping them afloat."],[5497,5718,"But a big company like Vireo Group,"],[5885,6039,"you would trust me to work there?"],[6177,6281,"You don't want the job?"],[6331,6552,"Oh, you don't think I can do it?"],[6594,6740,"I didn't say that."],[6748,6848,"I'll take it."],[6915,7086,"I want to start tomorrow."],[7620,7870,"Alright, got it."],[8291,8441,"We need to go shopping."],[8537,8616,"Tomorrow,"],[8725,8871,"you're meeting my grandmother."]],"29":[[1121,1292,"Grandma will be coming home"],[1292,1409,"soon to recover."],[1422,1614,"And if she's going to believe"],[1614,1747,"our marriage is real,"],[1768,1989,"then you need to look like my wife."],[1989,2235,"So let's not make her feel like"],[2285,2469,"our marriage is just for show."],[2498,2577,"Don't worry,"],[2610,2852,"I'll make sure to act the part."],[2852,2973,"Buy whatever you like."],[3040,3199,"I'll handle the bill."],[3236,3370,"If you insist."],[3403,3516,"I insist!"],[4191,4358,"These are our newest styles."],[4358,4537,"Very popular choices."],[4579,4692,"They're lovely."],[4700,4996,"Is this cashmere and silk?"],[4996,5271,"Clearly he likes Samara's rich-girl style."],[5309,5497,"He wants me to act the part?"],[5509,5676,"Say less, Grant."],[5689,5855,"I'll take them all!"],[5855,6031,"All our new arrivals?"],[6060,6164,"What, you don't think my husband"],[6164,6252,"can afford it?"],[6281,6377,"I just want to make sure that"],[6377,6481,"you saw the price."],[6790,7048,"I didn't think it would cost that much!"],[7073,7211,"What did I just do..."]],"30":[[16,95,"Oh!"],[250,521,"Yeah, actually..."],[596,738,"You heard the lady,"],[738,996,"her husband will take care of this."],[1288,1409,"I'll take care of it."],[1409,1659,"$200,000 on this card?"],[1735,1814,"Okay."],[1901,2060,"Sometimes with purchases this big"],[2060,2122,"you may need to"],[2122,2273,"contact your bank and..."],[2344,2377,"Oh!"],[2473,2610,"Transaction is approved."],[3040,3148,"Grant, that is"],[3240,3340,"way too much money"],[3340,3440,"to spend on clothes."],[3440,3616,"You do not have to buy me all that."],[3699,3899,"Say husband like that again,"],[3912,4066,"and I'll buy you the whole store."],[4120,4254,"Thank you, husband."],[4679,4779,"Hi!"],[4821,4971,"I'd like to see your latest arrivals."]],"31":[[183,279,"Hi!"],[321,479,"I'd like to see your latest arrivals."],[479,583,"Apologies,"],[608,746,"that gentleman just purchased"],[746,900,"all our new arrivals for her."],[1338,1447,"Samara,"],[1484,1605,"all of these clothes"],[1605,1830,"were bought by my brother."],[1830,2022,"So, if you see a dress that you like,"],[2022,2369,"just tell him to give it to you."],[2369,2694,"Besides, you are his first love."],[3098,3265,"Since you're so generous,"],[3265,3449,"I'm sure you wouldn't mind gifting me"],[3449,3582,"one of these dresses, Grant?"],[3632,3845,"I'm looking for something"],[3845,3987,"short and tight"],[3987,4112,"for my birthday."],[4137,4446,"He probably won't refuse his first love."],[4483,4667,"Might as well give them all to her."],[5025,5105,"I'm sure that Grant"],[5105,5259,"would prefer you have these."],[5288,5380,"Take them all."],[5868,6022,"You two have fun shopping here."],[6072,6214,"I gotta get ready for work tomorrow."],[6493,6573,"Wait!"],[7027,7282,"I didn't want her leftovers, Elodie!"],[7294,7394,"That makes me no much better"],[7394,7628,"than that desperate little snake!"]],"32":[[196,383,"Those clothes were way too expensive."],[525,558,"I'm glad"],[558,663,"I didn't keep anything."],[663,846,"I don't want to owe that man any favors."],[921,967,"Alice!"],[1001,1130,"Stop right there."],[1368,1497,"You just gave away everything"],[1497,1601,"I bought for you!"],[1647,1876,"Is my gesture that worthless to you?"],[1901,2106,"I didn't give them away to just anyone."],[2168,2335,"I gave them away to your true lover."],[2335,2398,"Samara, I mean,"],[2398,2535,"isn't that what you wanted?"],[2602,2702,"Is that what you've been"],[2702,2836,"so upset about all day?"],[2965,3211,"My true love, Samara?"],[3211,3303,"Come on."],[3457,3674,"Between Samara and your grandmother..."],[3782,3978,"I know this marriage is a sham."],[4020,4183,"And the worst part is..."],[4183,4400,"I really have feelings for him."],[4400,4583,"No matter how hard I fight it."],[4583,4808,"From the moment he rescued me I-"],[4817,5075,"Stop being pathetic, Alice!"],[5088,5342,"Alice, stop."],[5422,5622,"You've been running from me all day."],[5697,5801,"And it seems like"],[5876,5997,"you've been running from me"],[5997,6081,"since we first met."],[6114,6247,"You've only been chasing me"],[6247,6431,"so your grandmother sees you"],[6431,6560,"in a happy marriage."],[6606,6760,"Unbelievable!"],[6806,6927,"From now on,"],[6927,7057,"you're not allowed to give away"],[7057,7207,"anything that I give to you."],[7257,7419,"And if you choose to ignore me,"],[7503,7686,"there will be consequences."],[7757,7841,"Oh, yeah?"],[7949,8083,"And what are you gonna do to me,"],[8083,8170,"Mr. Vega?"],[8825,9000,"I'm not easily intimidated."],[9104,9376,"It didn't seem that way in the shower"],[9376,9526,"or the storage closet."],[9655,9851,"So hear me when I say"],[9930,10114,"that those gifts were for you."],[10201,10347,"So are you gonna be a good girl"],[10347,10468,"and start listening to me."],[10577,10652,"Or am I gonna have to"],[10652,10756,"teach you a lesson?"],[10994,11077,"I'll be good."],[11240,11319,"For now."]],"33":[[50,171,"And you're home early."],[487,613,"Is nine o'clock early?"],[734,946,"Did you expect me to be a workaholic?"],[1013,1134,"I didn't say that."],[1155,1338,"Don't put words into my mouth."],[1388,1572,"What can I put in your mouth?"],[2173,2252,"Come here."],[2494,2619,"Let me dry your hair."],[2731,2844,"It's cold in here"],[2844,3061,"and I don't want you getting sick."],[3169,3253,"Oh, I,"],[3361,3574,"I can do it myself."],[3574,3678,"Sit still."],[5121,5359,"Who knew he could be so gentle?"],[6452,6531,"Well,"],[6556,6673,"I'm gonna go to bed."],[6956,7098,"Not even a thank you?"],[7269,7457,"How do you want me to thank you?"],[8683,8921,"I need to step out."],[9096,9213,"I'm gonna take this."],[10281,10535,"He says Samara's not important to him."],[10535,10827,"Yet he runs to her the second she calls."],[11340,11536,"Harry, what's up?"],[11561,11732,"Somebody's on to you, boss,"],[11807,12053,"or should I say, Glitch."]],"34":[[275,462,"You said you had a lead"],[462,663,"on the top hacker, Glitch."],[742,834,"Where?"],[896,984,"I'm sorry."],[984,1201,"I caught a signal and told you right away."],[1201,1384,"But it disappeared."],[1384,1780,"Next time, make sure before you bother me"],[1780,1901,"with a late night call."],[2377,2560,"You know I would do anything for you,"],[2569,2660,"don't you Grant?"],[2702,2861,"What do you mean by that?"],[2936,3065,"I mean..."],[3115,3440,"I can do things for you that Alice can't,"],[3578,3666,"or won't."],[3803,4187,"I don't need or want anything from you,"],[4208,4295,"Samara."],[4617,4788,"We'll see about that, Grant."]],"35":[[337,567,"So this is your workstation."],[592,759,"If you need anything, just let me know."],[1543,1780,"Jake is personally showing you around?"],[1826,1939,"No interview process"],[1939,2085,"and straight to onboarding?"],[2110,2323,"Are you connected to Mr. Vega somehow?"],[2431,2644,"Mr. Vega?"],[2798,3023,"No, no connection."],[3061,3203,"With all this chatter,"],[3203,3324,"how can I expect any work"],[3324,3428,"to get done around here."],[3528,3649,"Mr. Vega."],[3712,3974,"Did he hear what I just said?"],[4012,4129,"New employee,"],[4129,4354,"to my office, now!"]],"36":[[425,529,"Can I help you?"],[704,788,"Come here."],[1785,1872,"What are you doing?"],[1939,2118,"Why are you so eager"],[2135,2285,"to keep your distance from me?"],[2360,2560,"It's for your own good."],[2577,2706,"For my own good?"],[2756,2848,"What do you know about"],[2848,2948,"what's good for me?"],[3011,3123,"Well, it doesn't look good"],[3123,3253,"for people to think that you're"],[3253,3390,"dating your employees."],[3511,3695,"And it doesn't look good for me, either."],[3732,3828,"people are gonna think"],[3828,3962,"I'm sleeping my way to the top."],[4062,4200,"But you're not."],[4275,4487,"You're just the best at what you do."],[4771,4896,"That's really kind."],[5038,5288,"But it still looks bad."],[5321,5472,"Especially because most people think"],[5472,5597,"you're with Samara."],[6089,6289,"Do you think I'm with Samara?"],[6510,6706,"Well you two sure do look good together."],[6790,6952,"How could I be with her"],[6981,7148,"if you're sitting on my lap?"],[9638,9718,"Grant, I..."]],"37":[[20,104,"Hi!"],[120,200,"Samara."],[588,734,"I should get back to work."],[925,1092,"Swallow your pride and"],[1092,1242,"play nice, Samara."],[1242,1388,"You need him back."],[2006,2198,"I made your favorite for lunch"],[2198,2314,"and thought I'd bring it over."],[2327,2515,"Steak and potatoes."],[2686,2894,"That was my favorite in high school."],[3078,3374,"My taste has since changed."],[3649,3795,"I heard your grandmother"],[3795,3987,"is being discharged from the hospital soon."],[4108,4291,"And I know that you only married Alice"],[4291,4487,"so that she would get the surgery."],[4567,4950,"So, now that it's over,"],[4950,5188,"isn't it time to end the charade?"],[5543,5872,"Samara, I loved you very much"],[5872,5980,"when we were children."],[6031,6260,"But now that we're not kids anymore,"],[6260,6439,"I need to focus on my future."],[6443,6610,"I need a strong,"],[6610,6765,"self-sufficient woman."],[6948,7069,"You know what people are saying"],[7069,7286,"about you and that strong woman?"],[7298,7482,"They're laughing at you."],[7557,7686,"Why are you settling?"],[7695,7945,"People like us hire the help,"],[7945,8066,"we don't marry them."],[8066,8233,"Samara, I'm warning you."],[8241,8420,"Not another word about-"],[8420,8666,"Just answer one question."],[8704,8888,"How do you really feel about Alice?"],[8958,9004,"I-"],[9034,9213,"Mr. Vega, we've been hacked."],[9213,9376,"The entire system is down."],[9480,9567,"We've been hacked?"],[9567,9651,"Yeah."]],"38":[[258,437,"This hacker is from the world's largest"],[437,608,"multinational organization."],[608,775,"We can't match their skill."],[809,975,"I'm about to lose our firewall."],[1526,1697,"If I counter this attack,"],[1768,1906,"they'll know I'm Glitch."],[2097,2198,"How long will it take to get"],[2198,2302,"the system back online?"],[2369,2502,"Against a hacker of this caliber?"],[2510,2656,"At least 24 hours."],[2669,2786,"Amateurs."],[2819,3044,"I could fix this in 60 seconds."],[3044,3186,"Do you understand a 24 hour shutdown"],[3186,3319,"will cost us millions?"],[3357,3574,"Isn't there any other solution?"],[3624,3716,"Don't worry Grant,"],[3716,3858,"I'll find someone who can help."],[3958,4120,"Only one who could counter"],[4120,4295,"an attack like this is Glitch."],[4312,4412,"He's the number one hacker"],[4412,4496,"on the scene right now."],[4988,5159,"I can't just sit by and watch"],[5159,5305,"his company lose millions."],[6381,6519,"First day on the job"],[6531,6735,"and I'm already putting out fires."],[6998,7173,"Let's show them what I've got."],[8229,8437,"Glitch, someone needs our help."],[8441,8562,"The Vireo Group is under attack"],[8562,8700,"by a top international hacker."]],"39":[[554,633,"Mr. Vega."],[696,804,"They are only a few lines of code"],[804,875,"away from our most"],[875,1030,"confidential client's files."],[1030,1213,"If we don't fix this immediately,"],[1213,1368,"we could lose all their accounts!"],[1514,1701,"Still no word from Glitch?"],[2189,2281,"Okay, thank you."],[2410,2540,"Our system is back online."],[2552,2677,"Someone fixed it and launched"],[2677,2790,"a counter attack."],[2790,2940,"The hackers' website is down!"],[2998,3148,"It must be Glitch."],[3174,3353,"How could he know so quickly?"],[3370,3553,"Could he be in our company?"],[4692,4788,"You thought you could leak"],[4788,4959,"our confidential information?"],[5000,5351,"Watch me wipe your system clean..."],[5413,5501,"Alice?"],[5501,5651,"What are you doing in here?"],[5797,6031,"Could she be...Glitch?"]],"40":[[50,166,"What are you doing here?"],[308,446,"Oh, um..."],[471,613,"Grant, the company's system"],[613,696,"is back online!"],[696,759,"I told you"],[759,909,"Glitch will come through for me."],[980,1134,"You contacted Glitch?"],[1134,1242,"Yes, Grant."],[1242,1368,"Like I said..."],[1372,1488,"I've always been there for you,"],[1488,1689,"so that's not stopping now."],[1776,1931,"Well, thank you."],[1989,2139,"I really appreciate it."],[2231,2402,"Wow, so, uhm.."],[2469,2606,"You know Glitch?"],[2694,2781,"Of course."],[2811,2873,"Otherwise,"],[2873,3069,"why would Glitch help Vireo Group?"],[3319,3399,"You know, I've"],[3399,3570,"always been really curious."],[3570,3812,"Is Glitch a man or a woman?"],[3858,4020,"A man of course."],[4137,4383,"Crazy that my idol is a man."],[4450,4750,"Alice, what were you doing in this room?"],[4779,5050,"It's strictly off limits to your department."],[5209,5326,"Oh, uh..."],[5326,5451,"Well, uh..."]],"41":[[4,300,"Alice, what were you doing in this room?"],[325,600,"It's strictly off limits to your department."],[646,767,"Oh, uh..."],[767,892,"Well, um..."],[1067,1146,"You know,"],[1146,1330,"she was probably just trying to"],[1330,1463,"help fix the problem."],[1463,1805,"You know, but her abilities are limited."],[1851,2043,"But don't be too hard on her, Grant."],[2110,2193,"It's kind of cute that"],[2193,2344,"she's always trying to impress you,"],[2369,2498,"like a school girl"],[2498,2731,"with a crush on her teacher."],[2744,2911,"The only thing limited here is"],[2911,3053,"your intelligence."],[3061,3140,"You know, it's..."],[3148,3228,"It's actually funny that"],[3228,3432,"you would call me a school girl."],[3440,3545,"How would you know?"],[3574,3770,"Didn't you fail out of university?"],[3791,3866,"So why were you"],[3866,4020,"in an off limits room again?"],[4020,4433,"Well, I was actually in here because-"],[4433,4537,"Okay, boss."],[4600,4700,"We're secure again."],[4750,4817,"Would you like me to"],[4817,4950,"get people back to their station?"],[5017,5063,"Okay."],[5684,5818,"Where do you think you're going?"],[5818,6006,"Back to work, like everyone else."],[6006,6222,"You're not everyone else."],[6222,6368,"We're going to lunch."],[6368,6531,"We have things to discuss."],[6531,6660,"But I have work to do."],[6702,6827,"You work for me."],[6869,6998,"And this is mandatory"],[6998,7165,"for all new employees."],[7173,7253,"Grant,"],[7307,7465,"if you don't want to eat alone,"],[7490,7603,"I'll have lunch with you."],[7720,7824,"Great idea!"],[7903,8003,"You two go ahead."],[8012,8279,"Why is this bitch being so generous?"],[8329,8500,"Is she trying to play hard to get?"],[8554,8712,"Alice is coming to lunch."],[8712,8800,"Great!"],[8917,9017,"Then we'll all go."]],"42":[[108,212,"Grant, it's been ages"],[212,437,"since we've shared a meal like this."],[667,838,"I'm heading to the restroom."],[855,1146,"Can I trust you two ladies to behave?"],[1192,1372,"Of course you can, Granty."],[3712,3828,"What is this?"],[3991,4208,"I know why you're really here, Alice."],[4208,4258,"So,"],[4354,4517,"let's stop lying to each other now."],[4550,4662,"What do you mean?"],[4704,4871,"I know all about you."],[4959,5188,"Your father cheated on your mother"],[5188,5397,"with a woman who spent all his money."],[5397,5492,"And then your mother died"],[5492,5672,"from a broken heart and left behind"],[5672,5926,"a mountain of medical debt."],[5935,6026,"And then you got"],[6026,6177,"yourself into your own debt,"],[6177,6314,"when you went to tech school."],[6377,6477,"So I take it,"],[6477,6706,"you've been talking to my sister."],[6848,6969,"Family is the"],[6969,7148,"most important thing to Grant."],[7190,7365,"Too bad yours is a disaster."],[7549,7674,"I also know"],[7674,7853,"that your father tried to marry you off"],[7853,8087,"with a man who was going to"],[8087,8199,"get rid of all your debt."],[8224,8375,"That's why you're with Grant,"],[8375,8483,"for his money."],[8550,8637,"What?"],[8704,8767,"No."],[8783,8938,"I got a job at a tech company"],[8938,9084,"and worked my way to the top."],[9184,9313,"I cleared my own debts."],[9313,9459,"Drop the act."],[9496,9647,"I've seen people like you."],[9688,9934,"You're clearly using Grant,"],[9934,10206,"he's nothing to you but a cash cow."],[10260,10339,"You know,"],[10339,10639,"I may be able to take care of myself,"],[10694,10802,"but that doesn't mean that"],[10802,10981,"I don't love love, Samara."],[11190,11357,"I guess you wouldn't understand."],[11615,11774,"So, do you love Grant?"],[11924,11999,"I..."]],"43":[[8,296,"Do you Love Grant?"],[325,483,"It's hard for me to say it,"],[483,654,"and believe he loves me because"],[654,788,"I've never had anything"],[788,905,"like this before,"],[921,1201,"but I do love him, don't I?"],[1409,1505,"I..."],[2239,2318,"So,"],[2435,2556,"what did I miss?"],[2598,2748,"My birthday is coming up."],[2806,2894,"And I know that"],[2894,3048,"you're eager to meet Glitch."],[3048,3128,"So,"],[3165,3286,"I'll invite him to my party."],[3357,3561,"Since he's already willing to help me,"],[3561,3757,"I'm sure he won't refuse my invitation."],[3966,4045,"Done."],[4124,4225,"Samara,"],[4308,4441,"this was a huge help."],[4504,4804,"If you can introduce me to Glitch,"],[4850,5017,"I'll reward you generously."],[5605,5739,"Glitch, do you know"],[5739,5880,"someone named Samara?"],[5939,6068,"Harry, give me a second."],[6081,6181,"I gotta take this."],[7040,7161,"Yeah, I've met her."],[7269,7478,"I wouldn't exactly say we're close."],[7536,7607,"She seems to think"],[7607,7695,"you helped Vireo Group"],[7695,7749,"because of her."],[7791,7970,"She's inviting you to her birthday party."],[8020,8208,"Accept the invitation for me."],[8295,8504,"All these companies are closing in on me."],[8508,8600,"It's only a matter of time"],[8600,8721,"before they figure me out."],[8846,8929,"I might as well seize"],[8929,9109,"this opportunity to go public"],[9109,9230,"on my own terms."]],"44":[[859,1051,"You don't really think that"],[1084,1255,"someone like you could be"],[1255,1484,"by Grant's side forever, do you?"],[1689,1772,"I mean..."],[1835,1968,"do you really think that Grant"],[1968,2168,"would marry a nobody like you?"],[2256,2419,"You're just a stand-in for me."],[2485,2686,"Well, you might be richer,"],[2748,2857,"sexier,"],[2902,3040,"have a better family,"],[3111,3249,"but Grant chose me."],[3824,3970,"It's time for you to let him go."],[3987,4166,"You're the one that needs to let go."],[4245,4425,"Once I introduce him to Glitch,"],[4425,4596,"I'll make sure that he divorces you."],[4675,4892,"You'll be tossed aside like garbage."],[4950,5105,"I guess we'll just have to see."],[5221,5426,"I hope this birthday's one for the books."],[6706,6806,"Who were you talking to"],[6806,6965,"on the phone for so long?"],[7023,7261,"Was it a guy or was it a girl?"]],"45":[[41,321,"Alice, tell me who you were talking to."],[362,546,"It's just an old co-worker."],[646,784,"Was it a girl co-worker"],[784,950,"or was it a guy co-worker?"],[1380,1514,"Is it possible"],[1564,1797,"that there's a man in America,"],[1847,2018,"who's more handsome,"],[2072,2327,"rich or charming than I?"],[2406,2527,"Well, I'm sure I could"],[2527,2694,"find someone more humble."],[2844,2944,"Very funny."],[3094,3240,"Let me take a look at this guy."],[3257,3340,"Nope."],[3474,3574,"Just one look."],[3574,3666,"No way."],[3666,3791,"Come on."],[5676,5797,"How could he?"],[5885,5997,"Alice Breslin,"],[6001,6139,"you're going down."]],"46":[[254,367,"Grandma."],[412,492,"What?"],[525,721,"Alice is evil."],[746,855,"My brother only married her"],[855,980,"to appease you."],[1046,1163,"You have to get rid of her."],[1188,1330,"Don't worry, dear."],[1372,1488,"I have ways to"],[1488,1676,"handle people like her."],[1801,1881,"Okay?"],[2306,2398,"Did all the housekeepers"],[2398,2540,"take the day off?"],[2556,2656,"It's so quiet."],[3461,3566,"Hi."],[3645,3874,"I don't think I've seen you before."],[4074,4216,"At your age, you're still"],[4216,4383,"doing this back breaking work?"],[4471,4679,"Are you saying I'm too old?"],[4679,4771,"No, no, no."],[4771,4863,"I just..."],[4900,5184,"I think you're working too hard."],[5184,5296,"I feel bad."],[5305,5430,"Quite pretty."],[5434,5680,"But her character needs testing."],[5743,5926,"It's not that hard."],[5960,6210,"I am old, and my hands,"],[6268,6439,"they're not as steady anymore."],[6448,6744,"But hard to keep up with the young folks."],[6744,6869,"Well, is there something"],[6869,6981,"I can help you with?"],[7023,7194,"No, um..."],[7240,7336,"I'm fine, ma'am."],[7336,7494,"You should just go to bed."],[7540,7620,"Okay."],[7674,7753,"Night."],[7811,7962,"Oh, and there's no need"],[7962,8128,"for you to call me ma'am."],[8133,8254,"My name is Alice."],[8312,8391,"Okay."]],"47":[[429,500,"Oh..."],[508,633,"I'm so sorry."],[633,850,"I didn't mean to do it."],[942,1142,"Everything in this house is so valuable."],[1201,1372,"This porcelain vase probably worth a lot."],[1418,1572,"It's all my fault."],[1618,1868,"I, I wasn't holding it properly."],[1906,2085,"You can punish me, ma'am."],[2168,2339,"What did I just say?"],[2519,2694,"It's Alice, not ma'am."],[2694,2848,"There's no need to be so formal."],[2961,3103,"Are your hands...okay?"],[3148,3253,"Yes, you mean,"],[3253,3528,"you're not mad that I broke something?"],[3620,3741,"It's already broken."],[3741,3858,"Why would I blame you for that?"],[3858,4020,"You were just trying to do your job."],[4020,4162,"Punishing you wasn't gonna"],[4162,4320,"un-break the vase."],[4433,4537,"Although, if they find out that"],[4537,4633,"you broke it,"],[4725,4888,"they'll probably give you a hard time."],[5000,5092,"How about this..."],[5188,5426,"you just tell them that I broke the vase."],[5534,5772,"You want to take the blame for me?"],[5818,5947,"Aren't you afraid that"],[5947,6110,"they'll be upset with you?"],[6139,6239,"I can handle it."],[6281,6364,"Apparently, I'm..."],[6435,6548,"lady of the house."],[6548,6835,"She's so kind and funny?"],[6835,7107,"Not at all like Elodie described."],[7344,7478,"Who broke this vase?"],[7549,7628,"I did."]],"48":[[116,216,"Do you know how much"],[216,358,"that vase costs?"],[408,525,"I can't believe my brother"],[525,596,"would marry some..."],[596,763,"such a careless freak!"],[825,925,"How much was it?"],[984,1163,"If it's a big deal, I'll just pay for it."],[1163,1359,"Oh, you'll pay?"],[1409,1626,"That is easy for you to say."],[1672,1906,"Everything we own is antique."],[1910,2198,"It's worth hundreds of thousands."],[2223,2410,"Someone from a family like yours."],[2439,2610,"Couldn't possibly afford it."],[3111,3257,"Would three hundred thousand cover it?"],[3365,3507,"You're using my brother's money,"],[3507,3591,"right?"],[3620,3787,"You know using his money"],[3803,3995,"to compensate for our family"],[3995,4124,"is pointless."],[4129,4237,"No, this money is mine."],[4237,4358,"It has nothing to do with Grant."],[4358,4608,"Oh, I don't believe you."],[4633,4700,"Someone like you"],[4700,4829,"couldn't afford three hundred,"],[4867,5030,"let alone three hundred thousand."],[5030,5092,"Enough!"],[5213,5380,"I broke the vase!"],[5526,5651,"What are you doing?"],[5693,6026,"Do not try to cover for Alice."],[6026,6214,"It's obvious that she broke it,"],[6272,6377,"and threatening people"],[6377,6677,"until they lie for you?"],[6806,7036,"You have no shame, Alice."],[7119,7198,"Oh,"],[7490,7695,"There, I broke the vase."],[7695,7870,"Do you believe me now?"],[8124,8291,"That was my favorite piece."],[8324,8445,"How could you break it?"],[8445,8583,"She's elderly."],[8583,8812,"Her hands aren't steady"],[8812,8996,"Just... I will pay for this vase too."],[8996,9113,"Just leave her alone."],[9146,9309,"Thank you for your kindness."],[9309,9392,"And you,"],[9417,9709,"you get over here and...apologize..."],[9709,9843,"to your sister-in-law!"],[9843,9897,"Ms!"],[9897,10035,"Please do not hurt Elodie."],[10035,10193,"She's just gonna punish you more."],[10272,10427,"Don't call me Ms."],[10447,10714,"Call me Grandma Rose, sweetie..."],[10769,10856,"This"],[10885,11086,"is Grandma Rose?"],[11148,11286,"Now you get over there"],[11286,11536,"and apologize to your sister-in-law!"],[11590,11782,"Or I'm gonna have Grant cut off"],[11782,11953,"all your credit cards."],[11970,12066,"Do you understand me?"],[12066,12316,"Why are you siding with this outsider?"],[12316,12537,"I am your real granddaughter."],[12616,12750,"No, you... Outsider?"],[12750,12933,"She's your sister-in-law!"],[12958,13113,"Elodie, are you gonna get over there"],[13113,13209,"and apologize?"],[13209,13325,"Get over there now!"],[13325,13430,"Okay! Ow!"],[13430,13646,"Okay, okay, I'll apologize."],[13659,13738,"Get over there."],[14026,14093,"I'm"],[14314,14418,"sorry."],[14543,14622,"It's..."],[14689,14789,"It's okay."],[15423,15661,"Alice, come sit down."],[15661,15803,"We gotta talk."]],"49":[[16,137,"You know, Alice,"],[171,462,"you have a kind sweet heart."],[525,688,"My grandson is lucky"],[688,875,"to have you marry him."],[959,1142,"Thank you, Grandma Rose."],[1322,1409,"How are you recovering"],[1409,1543,"from your procedure?"],[1543,1889,"If Grant married her just to appease me,"],[1889,2106,"then she'll leave once I'm better."],[2114,2331,"I can't let that happen."],[2373,2640,"You know, recovery is gonna take..."],[2694,2902,"a number of months."],[2936,3244,"I had a heart bypass surgery,"],[3274,3749,"and it's gonna take a while for it to heal."],[3883,3995,"You know, Alice,"],[4024,4412,"Grant is harsh on the outside,"],[4441,4763,"but he was raised to be that way."],[4800,4888,"So was I."],[4909,5159,"Maybe we're not too dissimilar after all."],[5176,5480,"But inside, he's kind and caring"],[5480,5739,"and has a gentle soul,"],[5772,5930,"just like you."],[6031,6256,"And I want you to know, Alice,"],[6277,6548,"my grandson would not do anything,"],[6548,6723,"if he didn't want to do it."],[6769,7236,"So he must really like you very, very much"],[7265,7482,"for him to brought you into the family"],[7482,7595,"like this."],[7645,7774,"Why doesn't he show me"],[7774,7916,"that side of himself?"],[7966,8045,"Well..."],[8112,8212,"I guess I don't show"],[8212,8362,"that side of me either."],[8379,8583,"We're gonna have a long time"],[8583,8762,"to get to know each other."],[8796,9154,"But now, I really have to rest."],[9196,9376,"Is there anything that I can"],[9376,9513,"help you do to recover?"],[9630,9776,"What would make you happiest?"],[9784,9939,"For you to go out"],[9939,10135,"with my grandson tonight,"],[10139,10335,"and have a good night."],[10393,10531,"Good night, Alice."],[10589,10723,"Good night, Grandma Rose."]],"50":[[400,504,"You're still up?"],[588,704,"Waiting for you."],[863,963,"Waiting for what?"],[1013,1055,"You think that"],[1055,1146,"just because we're married,"],[1146,1284,"I owe you sex every night?"],[1480,1643,"That's not what I'm thinking."],[1689,1906,"But I like the way your mind works."],[2022,2127,"I just thought..."],[2202,2456,"Maybe you'd care to join me for a drink?"],[2861,3036,"Sorry, I was so defensive."],[3269,3378,"Peace offering?"],[3632,3770,"How about we play a little game?"],[3841,3999,"I get to ask you a question."],[4066,4233,"And if you answer,"],[4266,4546,"I drink, and if you don't,"],[4658,4825,"you take off a piece of clothing."],[4959,5038,"Fine."],[5146,5263,"But I get to go first."]],"51":[[8,183,"Do you have feelings for anyone?"],[321,400,"I do."],[592,679,"Yes."],[729,821,"Now drink."],[946,1159,"He's probably talking about"],[1159,1343,"his feelings for Samara."],[1605,1685,"My turn."],[1785,1922,"Tell me something about you"],[1922,2047,"that I don't know."],[2811,3082,"When my mom first started getting sick,"],[3207,3332,"I used my coding skills"],[3332,3482,"to hack into the hospital database"],[3482,3703,"and clear any bills she owed."],[3812,3949,"I know that that makes me"],[3949,4033,"a terrible person."],[4183,4371,"I've never told anyone that before."],[4604,4775,"Do you think that I'm a bad person?"],[4904,4984,"No."],[5121,5251,"Absolutely not."],[5405,5522,"I think you're..."],[5643,5855,"You're special, Alice."],[5989,6114,"But unfortunately,"],[6322,6510,"that question does count as your turn."],[6627,6773,"My turn to ask you a question."],[7394,7511,"Does this turn you on?"],[7549,7749,"I'm not answering that."],[7949,8053,"Then strip."],[9467,9547,"My turn."],[9667,9884,"How many women have you bedded?"],[11332,11415,"My turn."],[11649,11849,"Have you fallen in love with me yet?"]],"52":[[62,141,"Have you?"],[316,429,"Fallen in love?"],[1397,1459,"Screw the game."],[1459,1614,"I need you now."],[4354,4583,"That man is such a beast."],[4600,4763,"I'm still sore."],[5267,5430,"Glitch, downstairs."],[5430,5501,"I'm here."],[5797,5864,"Harry."],[5901,5997,"What are you doing here?"],[5997,6147,"I'm here to deliver an invitation."],[7057,7136,"Thank you."],[7198,7328,"I'll take care of the rest."],[7340,7424,"You should go."]],"53":[[70,212,"Why didn't you answer your phone?"],[233,358,"I stepped out for a second,"],[358,408,"and you're already"],[408,525,"checking up on me?"],[642,738,"I thought last night"],[738,880,"would have built some trust."],[925,1046,"You want trust?"],[1121,1205,"Then I'm trusting you"],[1205,1338,"to impress a big client."],[1405,1614,"We're going to a meeting, now."],[2560,2648,"Mr. Vega,"],[2723,2815,"welcome."],[2961,3082,"Please, have a seat."],[3370,3841,"I can't lie, a strong man at work is so"],[3849,3933,"sexy."],[3962,4149,"Mr. Vega, we are honored"],[4149,4279,"to have you here."],[4308,4462,"Do you have any questions"],[4462,4633,"or concerns before we start?"],[4650,4804,"I wouldn't call it a concern."],[4821,4950,"I've done my research,"],[4950,5109,"and I know exactly what I want."],[5155,5259,"An additional 10%"],[5259,5413,"ownership of the project,"],[5447,5638,"and I'll sign the contract right here,"],[5638,5701,"right now."],[5726,5822,"10%?"],[5905,6047,"Mr. Vega, please."],[6047,6239,"We have to have some revenue to-"],[6239,6431,"Since I founded this company,"],[6431,6648,"each and every one of my partners"],[6648,6765,"has grown bigger"],[6798,6969,"richer, and better."],[6990,7111,"Surely you're not doubting"],[7111,7211,"my capability?"],[7332,7432,"This explains why"],[7432,7632,"Grant is the leader in this business."],[7711,8149,"He's so confident and so powerful."],[8179,8329,"No, no."],[8345,8429,"Of course not."],[8445,8491,"Of course not."],[8491,8725,"We have the utmost faith in you"],[8725,8850,"and your company."],[8850,8958,"In fact, we've... we've even"],[8958,9084,"prepared some additional materials"],[9084,9150,"for you to review"],[9150,9330,"before you sign this."],[9805,9893,"What's going on?"],[9993,10097,"Why are all the computers"],[10097,10172,"turning off?"],[10568,10727,"Your system's been hacked."],[10760,10844,"Call the tech department"],[10844,10906,"immediately."],[10906,10985,"We can't afford to"],[10985,11119,"lose this presentation!"],[11144,11261,"Ordinary tech support"],[11261,11390,"might not be able to fix this."]],"54":[[16,100,"Mr. Vega,"],[100,166,"I..."],[166,342,"I didn't know you had a new assistant."],[387,546,"This is Alice."],[546,642,"She's my..."],[875,1013,"The system's been attacked"],[1013,1130,"by a group of hackers."],[1222,1317,"It... It'll take time."],[1317,1422,"How much time?"],[1488,1655,"We can't keep Mr. Vega waiting."],[1701,2002,"Could be tomorrow or the next day."],[2077,2227,"We might lose some files."],[2243,2306,"We're..."],[2402,2506,"This is a disaster."],[2506,2556,"We're..."],[2623,2711,"We're doomed."],[2815,2894,"Finished."],[3015,3090,"How about"],[3090,3207,"I try to fix it?"],[3311,3557,"But you're just Mr. Vega's assistant?"],[3574,3812,"You know how to fix this?"],[3853,4062,"Well, not just anyone can be"],[4062,4200,"Mr. Vega's assistant."],[4250,4379,"She's right."],[4379,4450,"Let her try."],[5872,6081,"It's... it's fixed!"],[6160,6335,"How is that possible?"],[6393,6535,"The system's been restored."],[6589,6694,"You can get back to work."],[6798,6956,"Who are you, Miss?"],[6956,7148,"Only top hackers like Glitch"],[7148,7328,"can fend off such an attack."],[7328,7407,"Could she be..."],[7511,7691,"I'm just Mr. Vega's assistant."],[7828,7928,"I see,"],[7928,8041,"Mr. Vega's got Glitch"],[8041,8170,"working as his assistant."],[8183,8274,"That's what makes"],[8274,8416,"his company so powerful."]],"55":[[16,100,"Well,"],[162,321,"it seems we need to train our IT"],[321,533,"department a bit better, don't we?"],[696,838,"You can leave now."],[884,934,"Go!"],[1030,1276,"Miss, you saved our company."],[1276,1505,"I cannot thank you enough."],[1526,1659,"It was nothing, really."],[1680,1810,"Well, to you it was nothing,"],[1810,1956,"but to all of us..."],[2089,2223,"We could have lost so much money"],[2223,2373,"and time."],[2502,2690,"I'd like to go ahead and modify"],[2719,2769,"the arrangement"],[2769,2873,"we've already given you."],[2965,3157,"We would like to give you an additional"],[3224,3303,"fifteen"],[3357,3436,"percent,"],[3545,3657,"on one condition,"],[3787,3895,"that you allow"],[3895,4083,"this talented young woman"],[4124,4245,"to come work for us."],[4300,4537,"Are you trying to poach my employee?"],[4550,4667,"Oh, no, no, no, no."],[4667,4817,"I am sincere."],[4929,5075,"I would negotiate a six-"],[5075,5134,"No,"],[5242,5338,"a seven"],[5401,5505,"figure deal"],[5576,5714,"for young talent like this."],[5730,5960,"This businessman is pretty stubborn."],[6022,6147,"I'm telling you,"],[6156,6297,"I would give up 50% of"],[6297,6385,"my company share"],[6385,6544,"before letting go Alice."],[6556,6656,"Do you understand me?"],[6835,6936,"Fifty percent?"],[6969,7194,"That's billions of dollars."],[7223,7357,"Since when did I become"],[7357,7515,"so important to him?"],[7586,7703,"It looks like we're not signing"],[7703,7807,"any contracts today."],[7807,7928,"Wait, Mr. Vega..."],[8195,8316,"We'll give you the 10%"],[8316,8416,"that you asked for."]],"56":[[225,304,"Miss."],[417,546,"If you come work for us,"],[550,684,"you can name your salary."],[709,892,"I appreciate the offer, but"],[963,1096,"I have no intention of"],[1096,1297,"leaving Vireo, or Mr. Vega."],[1539,1776,"Alright, well, if you do decide"],[1776,1889,"to change your mind,"],[1914,2072,"our door is always open for you."],[2364,2519,"Consider this your warning."],[2569,2694,"Stay away from her."],[3032,3115,"I guess she's more than"],[3115,3253,"just his assistant."],[3403,3520,"Just my luck."],[3878,3958,"What?"],[4008,4187,"Why are you looking at me."],[4562,4788,"Next time you look at another man,"],[4817,4988,"it won't end with just a kiss."],[4988,5096,"It's over that?"],[5130,5288,"Niles Corp was hacked,"],[5292,5392,"and their tech team"],[5392,5538,"was completely helpless."],[5547,5776,"But you fixed it in a matter of moments."],[5789,6031,"Does he know about my alter ego?"],[6047,6122,"They couldn't fix it"],[6122,6293,"because they're incompetent."],[6368,6544,"Anyone from our tech department"],[6544,6656,"could have handled it."],[6656,6735,"Anyway,"],[6856,7032,"you did good."],[7032,7152,"To reward you,"],[7152,7386,"I'll kiss you 99 times a day."],[7469,7565,"How does that sound?"],[7657,7828,"Grant, people are watching."],[8379,8454,"Looks like it's time"],[8454,8666,"for Samara's birthday party."],[8675,8850,"I would say we could skip it,"],[8917,9113,"but I'm dying to meet Glitch."],[9134,9175,"You know,"],[9175,9463,"you seem very impressed by Glitch."],[9471,9730,"I wonder if you were to meet and..."],[9813,9976,"Glitch was a woman."],[10026,10214,"An attractive one at that."],[10272,10314,"Would you"],[10314,10493,"rather be with someone like her?"],[10531,10635,"Probably not."],[10710,11031,"Being with a hacker means no secrets."],[11519,11724,"I'm excited to see Samara's reaction"],[11724,11924,"when I reveal myself as Glitch."],[11945,12037,"But I wonder,"],[12037,12266,"what would his reaction be?"]],"57":[[337,496,"Thank you so much for being here."],[980,1038,"Damn it!"],[1038,1151,"Why do they still look like"],[1151,1284,"such a real couple?"],[1301,1363,"Samara,"],[1363,1630,"didn't you say Glitch would be here?"],[1630,1743,"I'm excited to meet"],[1743,1851,"the world's greatest hacker."],[1851,1910,"Yes."],[1910,2035,"We've all been waiting."],[2047,2164,"When is Glitch gonna show up?"],[2164,2348,"He'll be here any minute."],[2590,2756,"It's getting late."],[2756,2873,"Where's Glitch?"],[3190,3332,"I'm not sure, Ms."],[3361,3482,"Glitch is the most mysterious"],[3482,3574,"person in the world"],[3574,3649,"after all."],[3649,3816,"But I already told everyone."],[3816,3891,"And now you're telling me"],[3891,3995,"that Glitch isn't coming?"],[4012,4054,"Wait,"],[4108,4229,"Glitch isn't coming?"],[4237,4416,"Hello, hold on a second here."],[4433,4571,"I skipped a very important meeting"],[4571,4688,"to come all the way down here"],[4688,4838,"just to see Glitch."],[4838,5000,"Are you messing with us, Samara?"],[5397,5593,"What do you know, you gold digger?"],[5634,5734,"Glitch will be here,"],[5826,6010,"really, really soon."],[6056,6135,"Sure,"],[6197,6289,"if you say so."],[7094,7182,"Oops,"],[7182,7340,"I am so sorry."],[7432,7545,"My hand slipped."],[7628,7870,"My location will be exposed in no time."],[8208,8370,"They found Glitch's location!"],[8412,8491,"Boss!"],[8516,8612,"We found Glitch!"]],"58":[[225,316,"It's Alice."],[412,600,"Alice is the legendary Glitch!"],[930,1130,"Oh, please!"],[1130,1292,"She's lying!"],[1313,1426,"Don't believe her."],[1447,1664,"I sent an one-and-only"],[1664,1793,"invitation to Glitch, so"],[1793,1947,"if you're really Glitch"],[1947,2143,"then prove it and show it to us."],[2235,2344,"Well, uh..."],[2602,2873,"That you sent to the ever-elusive..."],[3436,3536,"It's fake,"],[3641,3837,"just like that little bitch, Alice,"],[3874,4074,"faking her way into Grant's life."],[4270,4433,"I can vouch that she is indeed"],[4433,4650,"the top hacker, Glitch."],[4696,4938,"What is he doing here?"],[4971,5096,"Isn't that the co-worker"],[5096,5242,"I saw Alice canoodling with?"],[5334,5476,"I'm Glitch's assistant,"],[5476,5834,"and she is the real deal, my boss."]],"59":[[871,955,"Samara..."],[996,1176,"I'll make sure you're sent abroad"],[1176,1259,"never to return."],[1276,1468,"Oh, Grant, I'm sorry."],[1468,1609,"Please forgive me."],[1655,1743,"I'm not the one you"],[1743,1881,"should be apologizing to."],[1951,2210,"Alice, I'm so, so sorry."],[2419,2502,"Samara..."],[2615,2781,"Why did you lie to everyone?"],[2844,2923,"I mean,"],[3003,3215,"why did you try to deceive everyone?"],[3332,3415,"Because..."],[3470,3674,"Because I wanted to impress Grant,"],[3674,3778,"and now I see that..."],[3837,3916,"that I would never"],[3916,4074,"do that with you in the picture."],[4074,4283,"I'm so humiliated."],[4341,4592,"You can punish her however you like."],[4592,4654,"No,"],[4717,4867,"I think crying on her own birthday"],[4867,5000,"is punishment enough."],[5159,5413,"That, and losing you."],[5576,5705,"That would be the worst punishment"],[5705,5772,"of all."],[5922,5985,"Please..."],[5985,6072,"Please forgive me."],[6072,6318,"I... I'll do anything!"],[6435,6535,"Please, just leave"],[6602,6790,"and never bother us again."]],"60":[[229,308,"Oh my God."],[308,379,"Glitch,"],[412,558,"it's an honor to meet you."],[592,679,"What would it take"],[679,896,"to get you to join my company?"],[896,934,"Don't..."],[1038,1163,"Name your price."],[1163,1251,"Well, I-"],[1301,1455,"Alice is my wife."],[1497,1655,"And she's not for sale."],[1751,1901,"She never has been"],[1901,2031,"and she never will be."],[2469,2765,"I've been looking for Glitch for years,"],[2765,2940,"and never would I've thought"],[2940,3115,"that you were right here all this time."],[3161,3303,"Why didn't you tell me sooner?"],[3449,3574,"You didn't ask."],[3920,3966,"I have an"],[3966,4087,"announcement to make."],[4187,4387,"Not only is Alice Glitch"],[4387,4542,"the world renowned hacker,"],[4567,4829,"but she's also my wife."],[4942,5021,"My wife"],[5021,5263,"who I truly love with all my heart."],[5317,5501,"You're a lucky man, Mr. Vega."],[5672,5801,"Don't I remember"],[5801,5980,"you saying something about"],[5989,6177,"not wanting to be with a hacker."],[6272,6468,"Something about too many secrets?"],[6673,6731,"I don't want to"],[6731,6877,"keep any secrets from you."],[6940,7111,"I don't care who you are."],[7169,7261,"I want you."],[7340,7424,"And..."],[7469,7599,"I love you."],[7774,7853,"Yeah."],[8012,8116,"And how exactly"],[8116,8258,"are you gonna prove that to me?"],[8312,8521,"I'll kiss you 99 times a day."],[8612,8696,"From now,"],[8792,8929,"as long as you have me."],[9217,9421,"How about the rest of our lives?"],[9847,9930,"Deal."],[10018,10197,"I love you too, Grant."],[11494,11649,"Why have I been so sensitive"],[11649,11874,"to smells, the last couple days."],[12020,12137,"You don't think..."],[12270,12370,"you're pregnant?"]],"61":[[200,300,"I'm pregnant."],[400,521,"Alice,"],[579,717,"that's amazing!"],[838,971,"It is, isn't it?"],[1080,1217,"I love you."],[1363,1497,"And I love you too."],[1676,1785,"We love you."],[1910,2089,"Do you think it's a boy or a girl?"],[2160,2273,"I don't care."],[2339,2469,"It's our baby,"],[2540,2711,"and we'll love it so much."],[3240,3357,"Besides,"],[3420,3611,"this is just our first baby."],[3645,3787,"We're gonna have five more."],[3807,4049,"Keep dreaming, Mr. Vega."],[4112,4200,"You know what?"],[4283,4408,"I think I am."],[4846,5005,"Only 98 more for today."],[5100,5196,"98 more."]]}