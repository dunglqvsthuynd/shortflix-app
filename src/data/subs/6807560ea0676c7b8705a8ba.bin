rough so"],[3724,3782,"much."],[4245,4312,"I can..."],[4366,4487,"I can hear your heart."],[4683,4888,"And I'm so happy that you're alive."]],"80":[[8,133,"It's a happy occasion,"],[133,250,"so let's stop crying"],[258,417,"and actually celebrate."],[554,750,"We can have some cookies or"],[842,917,"play some music."],[1021,1071,"Yeah."],[1071,1255,"Yeah, that is a great idea."],[1255,1301,"Yeah."],[1401,1443,"Let's go."],[3878,4033,"We made this for you."],[4133,4241,"Happy Mother's Day."],[4371,4529,"You too, Kathleen."],[5063,5125,"Bravo!"],[5201,5263,"Bravo!"],[5426,5547,"Bravo, Faith!"],[5547,5609,"Bravo!"],[6235,6306,"So amazing."],[6902,7011,"Happy Mother's Day,"],[7123,7198,"moms."]]}