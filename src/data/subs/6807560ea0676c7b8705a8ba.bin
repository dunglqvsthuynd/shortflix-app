 that"],[1488,1618,"all the patients get an invitation."],[1643,1697,"Great."],[1722,1780,"Thank you."],[2064,2131,"This is too much!"],[2131,2173,"My heart!"],[2218,2306,"I need my medicine!"],[2594,2694,"I’ll go look over here."],[3073,3215,"If that's the number one thing"],[3215,3399,"the Caraways can recognize you by,"],[3428,3599,"then I will burn it right off of you."],[3636,3770,"Then I could be rich forever!"],[3983,4062,"I found something!"],[4162,4258,"Okay, Faith, lay still."]],"16":[[0,95,"Okay, Faith, lay still."],[408,479,"What are you doing with that"],[479,563,"bottle of acid?"],[721,779,"Damn it!"],[821,896,"That hurts like hell!"],[896,959,"Fuck you!"],[1176,1217,"Mom?"],[1363,1418,"Mom?"],[1447,1505,"I'm so sorry."],[1505,1634,"I didn’t mean to say that to you."],[1689,1797,"It burns!"],[1835,1901,"Ashley,"],[1931,2031,"is that acid?"],[2031,2118,"We were about to witness"],[2118,2227,"her commit a crime."],[2381,2444,"No!"],[2444,2615,"This was only a big misunderstanding,"],[2615,2660,"okay?"],[2677,2786,"I just thought this was like"],[2786,2927,"Faith's meds or something!"],[2944,3098,"Get out before I have you arrested!"],[3161,3219,"Mason,"],[3265,3507,"we've only just reunited with Ashley."],[3516,3670,"Don't be so harsh with her."],[3687,3816,"This is all Faith's fault!"],[3816,3970,"And her stupid disease!"],[4024,4137,"Ashley, sweetheart,"],[4149,4325,"don't listen to a word"],[4329,4521,"this brat has to say."],[4662,4729,"Come on, darling."],[5434,5472,"Faith,"],[5480,5588,"I kept my promise."],[5622,5705,"I got you"],[5739,5847,"a brand"],[5872,5930,"new"],[5976,6051,"violin."],[6260,6339,"Thank you."],[6385,6481,"Sister Mary said"],[6481,6602,"you're a musical genius,"],[6602,6631,"right?"],[6652,6690,"That,"],[6723,6902,"if your mother hears your music,"],[6919,7036,"she'd recognize you"],[7073,7165,"in an instant."],[7298,7353,"Thank you."],[7411,7436,"Here,"],[7515,7599,"it's an invitation"],[7599,7711,"to the Caraway Daughter's"]