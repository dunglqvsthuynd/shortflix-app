{"1":[[133,196,"I'm sorry,"],[196,421,"but $400 is the most I can offer you"],[421,508,"for this instrument."],[542,592,"Please."],[667,796,"$400?"],[888,1034,"It's a Stradivarius."],[1034,1067,"I mean,"],[1067,1238,"it has to be worth more than that."],[1297,1376,"I'm sorry."],[1409,1459,"Mommy,"],[1459,1568,"why are you selling"],[1568,1743,"your favorite violin?"],[1768,1830,"Sweetheart,"],[1893,1997,"don't worry, okay?"],[2027,2052,"Look,"],[2052,2256,"Mommy is going to do whatever it takes"],[2256,2373,"to make sure that you're..."],[2414,2477,"you're okay."],[2535,2581,"Okay?"],[2994,3057,"Please,"],[3153,3278,"just take another look."],[3449,3482,"Okay?"],[3482,3628,"I... I need the money"],[3649,3695,"to pay for"],[3695,3812,"my daughter's medication."],[3812,3887,"She's ill."],[4008,4079,"You know, I'm sorry."],[4262,4491,"I have an idea to cheer Mommy up."],[4917,4963,"Seth?"],[5046,5109,"Annabelle?"],[5184,5288,"Where are you guys?"],[5359,5397,"Hi!"],[5409,5467,"Oh my gosh,"],[5467,5568,"quick, get under the umbrella."],[5593,5663,"We got you flowers."],[5663,5830,"Oh, thank you so much!"],[5834,5951,"They're beautiful!"],[6010,6093,"We plucked these out"],[6093,6189,"from the park for you."],[6193,6268,"Aww,"],[6339,6389,"thank you."],[6389,6468,"Here, actually,"],[6519,6564,"Annabelle,"],[6602,6731,"take your medication, okay?"],[6752,6827,"You'll feel better."],[6873,7002,"It's going to help with the pain, okay?"],[7123,7303,"You'll always be my hero, Mommy."],[7303,7357,"Aww!"],[7382,7515,"What's wrong with Sis, Mom?"],[7811,7866,"Howard."],[7974,8070,"You're drunk!"],[8149,8262,"I... I need some money."],[8316,8345,"Okay?"],[8345,8387,"Annabelle,"],[8387,8537,"she has congenital heart disease."],[8537,8591,"Money?"],[8650,8712,"You three"],[8729,8821,"blood-sucking leeches"],[8821,8938,"need more money from me?"],[8967,9079,"The company's bankrupt!"],[9134,9246,"There is no more money!"],[9280,9346,"I need money"],[9346,9467,"for Annabelle's medication,"],[9467,9534,"and she's gonna need"],[9534,9630,"a heart transplant!"],[9630,9718,"She needs this, she needs that!"],[9784,9909,"What about what I need?"],[9943,10060,"I need money right now!"],[10139,10247,"If you're going to die anyway,"],[10289,10356,"why don't you"],[10381,10472,"help Daddy"],[10485,10564,"make some money back?"],[10564,10593,"Come on."],[10627,10660,"Howard,"],[10660,10723,"what are you doing?"],[10752,10814,"Hey, honey. - No!"],[10844,10906,"No! Howard,"],[10906,10985,"what are you doing?"],[11006,11115,"Dad, stop!"]],"2":[[0,75,"What are you doing?"],[95,187,"I'm taking her,"],[204,333,"and we're going to sell her organs"],[333,421,"on the black market,"],[446,487,"and then I’m gonna"],[487,563,"make some money back,"],[575,734,"because what's the point of raising her?"],[754,867,"It's going to cost too much money."],[867,942,"Come on, honey!"],[967,1046,"You're going to help me."],[1067,1117,"You're going to help me"],[1117,1197,"make my money back,"],[1197,1251,"because you're gonna"],[1251,1338,"die anyway. - Dad, stop!"],[1372,1455,"Are you crazy?"],[1455,1530,"This is your daughter!"],[1530,1564,"Dad!"],[1622,1697,"Get off me!"],[1922,1976,"Mommy!"],[1993,2122,"If she's gonna die anyway,"],[2122,2277,"it would just be a waste of money"],[2277,2348,"to raise her."],[2348,2469,"Let go of my sis!"],[2652,2731,"You little twerp!"],[2857,2927,"No!"],[3265,3299,"Please,"],[3340,3390,"stop!"],[3411,3495,"I'll do anything!"],[3528,3561,"Please,"],[3599,3653,"stop!"],[3707,3757,"Please!"],[3866,3916,"Ow!"],[4024,4070,"No!"],[4108,4154,"Mom!"],[4170,4266,"Leave her alone!"],[4421,4458,"Hand"],[4471,4521,"the kid"],[4554,4600,"over!"],[4629,4763,"Over my dead body!"],[4804,4954,"Be careful what you wish for!"],[5113,5209,"Mom!"],[5238,5338,"No!"],[5367,5455,"Mommy!"],[5509,5568,"Mom!"],[5709,5776,"Don't worry, honey."],[5814,5922,"Mommy will protect you."],[5947,6110,"I promise I will protect you"],[6110,6189,"no matter what!"],[6552,6644,"No!"],[7494,7540,"No!"],[7691,7799,"Annabelle!"],[7882,7966,"Mommy!"]],"3":[[191,241,"No,"],[250,291,"please!"],[362,475,"Annabelle!"],[513,613,"Don't take my daughter"],[613,688,"away from me."],[713,884,"She has heart disease."],[992,1067,"Mommy!"],[1092,1163,"No!"],[1230,1301,"No!"],[1326,1418,"Mommy!"],[1618,1722,"Annabelle!"],[2064,2114,"Mom?"],[2177,2235,"Thank God."],[2235,2364,"You've survived, child."],[2423,2623,"I found you after the car crash."],[2694,2736,"Mom,"],[2790,2882,"where are you?"],[2965,3036,"Where's dad?"],[3053,3165,"He's with the Lord now."],[3215,3340,"I'll help you find your mom."],[4921,4967,"Mom!"]],"4":[[100,137,"Mom!"],[229,283,"God Mom!"],[316,479,"Happy advent, Faith."],[521,738,"Are you ready for your audition?"],[754,896,"Yes, I'm ready, but..."],[955,1067,"don't jinx it."],[1163,1280,"Beautiful little Faith,"],[1297,1413,"soon to be professional"],[1413,1493,"violinist."],[1680,1868,"I know my real family is out there"],[1868,1943,"looking for me."],[2147,2260,"Wish me luck, brother."],[2377,2498,"You still haven't given up hope?"],[2565,2606,"Look,"],[2681,2840,"your family probably dumped you"],[2840,2973,"because they don't want you anymore."],[3065,3136,"I just"],[3136,3253,"know in my heart"],[3261,3303,"that"],[3361,3482,"my family are good people."],[3482,3561,"You should be grateful"],[3561,3682,"I even adopted you."],[3737,3832,"So, instead of wasting"],[3832,3912,"all this energy"],[3912,4058,"on these stupid auditions,"],[4087,4270,"maybe you should pick up a second job"],[4279,4446,"and help support this family."],[4688,4775,"And here I am,"],[4775,4971,"picking up after rich people all day."],[4971,5021,"Just..."],[5059,5188,"do your part, okay?"],[5221,5501,"I already have two part time jobs."],[5513,5584,"Well, you should."],[5613,5789,"The only reason I adopted you was for"],[5789,5918,"the government kickbacks."],[6068,6293,"If I hadn't lost my memories,"],[6348,6448,"I would've already found"],[6448,6560,"my birth family by now."],[6673,6756,"Where are they?"],[6819,6973,"Did something happen to them?"],[7328,7449,"Kathleen Caraway,"],[7478,7595,"you're the comeback story"],[7595,7665,"of the century!"],[7937,7995,"Thank you."],[8133,8366,"I'm really just here"],[8366,8470,"to find my daughter."]],"5":[[0,191,"I am just here looking"],[191,266,"for my daughter."],[513,608,"All Roy ever does"],[608,775,"is gamble and watch TV."],[975,1046,"Annabelle,"],[1176,1284,"wherever you are,"],[1347,1409,"I vow"],[1488,1601,"I will find you."],[1714,1793,"I love you."],[1876,1951,"Please,"],[2043,2131,"wait for me."],[2377,2444,"Ready, God Mom?"],[2448,2598,"Now you're a real estate tycoon"],[2598,2790,"and even bought LA Philharmonic."],[2823,2948,"What do you have to say about that?"],[2982,3044,"Hey, Ash."],[3115,3157,"What?"],[3269,3428,"Isn't this your new boss lady?"],[3570,3653,"My daughter,"],[3699,3753,"Annabelle,"],[3753,3828,"she has"],[3895,4029,"congenital heart disease."],[4029,4108,"And your daughter was"],[4108,4200,"a musical genius"],[4200,4312,"who plays the violin?"],[4346,4387,"Yes."],[4483,4700,"I believe that music"],[4859,4988,"will bring us back together."],[5088,5230,"Any distinguishing traits?"],[5334,5413,"She has"],[5413,5559,"a heart-shaped birthmark"],[5622,5743,"on her right shoulder."],[5830,6101,"If anyone has any leads,"],[6164,6289,"I will pay"],[6343,6414,"handsomely."],[6427,6539,"Wait, doesn't that sound like Faith?"],[6581,6731,"Does that brat have a rich mom?"],[6740,6873,"Maybe we can get that money."],[6919,7048,"Faith doesn't have any memories"],[7048,7132,"of her real family."],[7319,7394,"What if..."],[7649,7720,"I take her place"],[7720,7841,"as the Caraway heiress?"],[7966,8008,"Shoot!"],[8062,8145,"I can't let them meet."],[8145,8216,"She's about to audition"],[8216,8295,"for her real mom!"]],"6":[[959,1042,"This woman..."],[1084,1234,"She feels so familiar."],[3365,3553,"Happy Mother's Day, Mommy."],[3599,3803,"That is just so sweet."],[4429,4491,"Don't worry, Mom."],[4533,4637,"We're going to find Annabelle soon."],[5080,5188,"I know it's not much,"],[5217,5276,"but"],[5296,5488,"I got you a present."],[5672,5743,"The heart on it"],[5743,5880,"reminded me of your birthmark."],[5897,6043,"So, I knew it was for you."],[6139,6285,"Oh my gosh!"],[6435,6506,"Wow."],[6560,6690,"This is beautiful."],[6790,6894,"Let me play you a song."],[7736,7795,"Don't worry, Mom."],[7841,7941,"We're going to find Annabelle soon."],[8020,8208,"She has congenital heart disease."],[8375,8437,"What if she..."],[8483,8546,"before..."],[9004,9067,"That's her!"],[9163,9305,"That's... That's my baby girl!"],[9355,9467,"She made that song for me"],[9467,9517,"for Mother's Day,"],[9517,9567,"remember?"],[9588,9697,"Quick, we have to find her!"],[9743,9838,"Come on! - Go, go, go, go!"],[10314,10460,"That was so beautiful."],[10506,10627,"Where did you learn it?"],[11094,11165,"I'm not"],[11182,11257,"sure."],[11298,11465,"Feels like I've known it forever."],[11494,11544,"You know,"],[11649,11778,"fuzzy memories."]],"7":[[404,458,"There you are!"],[483,567,"Ashley."],[675,850,"Well, there are so many of them."],[921,1051,"Which one is my daughter?"],[1101,1155,"Ashley,"],[1180,1247,"I thought your shift"],[1247,1351,"didn't start until later."],[1376,1480,"Emergency shift."],[1509,1534,"Look,"],[1534,1651,"my boss lady doesn't like you"],[1651,1835,"disturbing the other girls, so..."],[1835,1889,"Um,"],[1931,2060,"let's go somewhere quiet, okay?"],[2198,2239,"Mila,"],[2327,2456,"go and see if anybody"],[2456,2577,"has a heart-shaped birthmark"],[2577,2681,"on their right shoulder."],[2723,2769,"Yes, ma'am."],[2961,3111,"Excuse me, may I check your shoulder?"],[3445,3536,"I need to prevent her"],[3536,3607,"from auditioning."],[3670,3762,"What if I break her violin?"],[3903,4087,"I know my family's looking for me."],[4625,4775,"I guess I'll just..."],[4821,4996,"practice in a quiet corner."],[5121,5163,"Ow."],[5180,5280,"That hurt."],[5292,5484,"I can't let her realize who she is!"],[5488,5526,"Faith,"],[5526,5643,"I'm just so swamped"],[5643,5718,"with work and everything."],[5718,5755,"Um..."],[5847,5872,"here!"],[5960,6039,"Hold this for me."],[6614,6648,"No."],[6719,6835,"Maybe she walked off somewhere."],[6865,6927,"I'll go look around."],[7069,7127,"We'll find her."],[7336,7515,"Ashley, I have an audition."],[7515,7549,"I..."],[8979,9038,"Sis?"]],"8":[[342,471,"What have you done to my sister?"],[538,746,"Do you have any idea"],[788,871,"how much time I spent"],[871,992,"painting that portrait of her?"],[1005,1222,"I'm... I'm so, so sorry."],[1222,1376,"I... I really... I didn't mean to."],[1376,1484,"It was an accident."],[1547,1630,"Don't mind her."],[1630,1776,"She's always been so clumsy."],[1910,2077,"You've sullied my sister's memories."],[2093,2173,"Faith is ill."],[2218,2285,"Her heart-"],[2339,2498,"She can die for all I care!"],[2544,2644,"She's always wanted to play"],[2644,2744,"in your orchestra."],[2869,3098,"Everything here is for my sister."],[3144,3228,"This portrait,"],[3236,3294,"this orchestra,"],[3294,3461,"this fucking violin scholarship."],[3482,3553,"And you dare"],[3607,3732,"try to stand where she stands"],[3753,3870,"when you're just filth!"],[3883,4041,"It was just an accident."],[4041,4070,"I..."],[4095,4279,"You don't deserve to be here."],[4429,4504,"And you're never playing"],[4504,4596,"violin again! - No!"]],"9":[[33,104,"And you're never playing"],[104,183,"violin again! - No!"],[183,254,"No, no!"],[262,296,"Please,"],[296,446,"my god mom worked so hard"],[446,525,"to get that for me!"],[538,588,"Get your - Please!"],[592,700,"filthy hands off of me!"],[855,1117,"I bought that used at a pawn shop."],[1176,1330,"It's... It's cheap anyways."],[1343,1434,"You... You don't have to"],[1434,1572,"dirty your... your hands"],[1572,1664,"with our things."],[1705,1814,"You disgust me!"],[1860,1976,"You poor people should never play"],[1976,2056,"if you can't afford it."],[2114,2252,"Just because you have money,"],[2260,2360,"doesn't give you the right"],[2360,2519,"to treat people like this!"],[2723,2890,"Violins are for classy people."],[2957,3078,"And you're just dirt!"],[3294,3453,"I've turned them against each other."],[3486,3545,"Perfect."],[3636,3674,"No."],[3724,3770,"Listen,"],[3874,3933,"I can tell"],[3933,4129,"that you care a lot about family."],[4137,4212,"Get off of me!"],[4212,4341,"God Mom, are you... are you okay?"],[4391,4500,"And... And this violin,"],[4500,4679,"it... it means the same to Faith."],[4700,4867,"The heart that's etched on it,"],[4875,5171,"it's almost identical to her birthmark."],[5180,5263,"I don't care!"],[5430,5476,"Stop!"],[5555,5655,"Stop, please!"]],"10":[[120,191,"This woman..."],[279,433,"She feels so familiar..."],[821,934,"You don't want to catch a cold."],[934,1001,"You're ill."],[1580,1626,"This..."],[1722,1872,"This is the same violin"],[1922,1985,"that I pawned"],[1985,2168,"to pay for your sister's medication."],[2836,2923,"It is the same."],[2957,3061,"And these low-lives were putting"],[3061,3178,"their dirty fingerprints on it!"],[3178,3357,"No, my godmom bought that for me"],[3365,3528,"fair and square from the pawn shop."],[3545,3570,"Mom,"],[3586,3616,"look,"],[3616,3745,"she even destroyed sister's portrait."],[3991,4024,"You..."],[4091,4216,"You imbecile!"],[4283,4383,"Didn't your mother"],[4383,4533,"teach you proper etiquette?"],[4604,4850,"And, and you come into my opera house,"],[4863,5092,"and you ruin my property!"],[5113,5267,"And what kind of mother are you?"],[5296,5484,"Letting your son treat people like that"],[5484,5601,"over a painting."],[5618,5780,"I can paint you a new one, really."],[5780,5814,"I..."],[5814,5922,"Oh, shut up!"],[5980,6118,"I would be ashamed"],[6135,6385,"if I had a loudmouth daughter like you."],[6423,6523,"I mean, really,"],[6585,6785,"what kind of a hole"],[6802,6981,"did you crawl out of?"],[7002,7115,"Oh, please!"],[7165,7328,"Faith is just an orphan."],[7374,7507,"Have mercy on us!"],[7649,7803,"You... You're an orphan?"]],"11":[[0,104,"You're an orphan?"],[187,279,"No, she's not."],[279,392,"She has a family."],[396,542,"Don't be ungrateful to me and Dad,"],[542,608,"Faith."],[608,767,"Lying to get sympathy now?"],[792,838,"Too bad for you,"],[838,959,"the only person's life I care about"],[959,1046,"is my sister's!"],[1071,1163,"Look at this painting!"],[1213,1330,"Oh, let me go!"],[1372,1472,"How would you like to have your whole"],[1472,1622,"being melted away like that, huh?"],[1651,1797,"Why do you have to be such a jerk?"],[1885,2052,"I bet your sister hates you."],[2214,2298,"You little twerp!"],[2439,2535,"Mommy!"],[2615,2773,"Don't take my sister!"],[2886,2919,"No,"],[2965,3098,"I didn't fail to protect my sister."],[3132,3265,"I was just too little and weak then..."],[3403,3486,"You asked for this."],[5142,5192,"Stop!"],[5780,5830,"You okay?"],[6006,6056,"This girl..."],[6097,6227,"I remember her from the hospital."],[6260,6418,"She has congenital heart disease,"],[6460,6594,"just like our lost sister."]],"12":[[8,50,"Seth!"],[91,129,"Brother,"],[179,300,"I know you're territorial with"],[300,454,"anything having to do with Annabelle,"],[454,517,"but this is"],[517,604,"crossing a line- - Are you"],[604,709,"defending them, Mason?"],[746,867,"You just don't understand the love"],[867,1038,"that Mom and I have for our lost sister,"],[1071,1167,"because you're adopted."],[1167,1284,"That's ridiculous."],[1284,1388,"Our sister would want you"],[1388,1559,"to treat everyone with respect."],[1643,1760,"I apologize for them."],[1826,1864,"Fine,"],[1910,2010,"I'll let her off this time"],[2010,2143,"as long as she stays out of my sight."],[2218,2410,"I never want to see you ever again"],[2410,2489,"in this concert hall."],[2494,2644,"You don't have to worry about that."],[2690,2840,"I would never want to be around"],[2840,3090,"such a despicable family like yours."],[3324,3440,"We're taking this violin then."],[3520,3620,"It was our family heirloom"],[3620,3687,"to begin with."],[4859,4896,"No!"],[4929,4954,"No!"],[4959,5075,"That was my godmom's"],[5075,5142,"gift to me!"],[5217,5305,"You can't take it."],[5305,5376,"It's mine!"],[5459,5530,"Give it to me!"],[5588,5634,"Faith,"],[5693,5885,"you've always been a musical genius."],[5901,6056,"Once your mom hears you play,"],[6056,6243,"she'll recognize you in an instant!"],[6247,6360,"Oh, I'm so sorry."],[6360,6573,"I'll get you a much better violin."],[6573,6669,"A brand new one."],[6798,6952,"Oh, Faith, your heart!"],[7027,7190,"We need to get you to the hospital."],[7311,7357,"Faith?"],[7444,7486,"Faith?"],[7903,8083,"I only have 30 days to live?"],[8625,8762,"Will I see my family again"],[8833,8925,"before I die?"]],"13":[[154,254,"I can't believe it."],[287,471,"We found you, Annabelle."],[533,650,"We looked everywhere."],[667,792,"It's really you!"],[792,888,"We finally found you"],[888,1013,"after thirteen years. - We..."],[1030,1213,"need to make up for the lost time."],[1280,1388,"Tell me, child,"],[1405,1493,"what is it you want?"],[1543,1743,"We can get you the world."],[1872,1981,"Just as I planned."],[2022,2097,"Look, Sis."],[2127,2206,"I made another one."],[2214,2348,"I blew up our old family photo."],[2548,2606,"Isn't this a great"],[2606,2690,"welcome home present?"],[2736,2869,"That's little Faith again."],[2907,2990,"What an eyesore."],[3098,3186,"It's lovely."],[3303,3424,"Don't you remember this, Sis?"],[3774,3887,"Don't cry, Sis."],[3920,4024,"I'm your big brother!"],[4037,4212,"I'll protect you and Mom."],[4254,4404,"Look what I made you for Christmas."],[4808,4946,"It's beautiful, Seth."],[4967,5150,"I'll keep it safe no matter what."],[5209,5422,"I spent all my birthday money on it."],[5459,5547,"I knew you'd like it."],[5563,5755,"You're the bestest big brother."],[6285,6314,"You know,"],[6314,6477,"I was expecting something"],[6481,6581,"a little more..."],[6581,6669,