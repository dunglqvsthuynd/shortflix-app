{"1":[[1483,1650,"You wanted a virgin?"],[1687,1829,"My daughter is all yours."],[1875,2029,"Where is my $100,000?"],[2075,2212,"Selling your little girl for"],[2212,2366,"gambling money."],[2366,2525,"I like your style."],[2804,3012,"But she is damaged, Jedd."],[3050,3175,"I wanted her perfect."],[3212,3395,"I am not for sale."],[3750,3875,"$25K."],[3916,4112,"Final offer."],[4325,4408,"Dad?"],[4775,4887,"Dad!"],[5012,5137,"From now on..."],[5275,5437,"If anyone asks..."],[5479,5566,"You are my wife."],[5575,5837,"I will never be your wife."],[5837,6062,"You are not an heiress anymore."],[6104,6312,"Your father gambled away"],[6312,6437,"all of your family fortune"],[6487,6737,"and sold your future"],[6787,6866,"right to me."],[6912,7087,"My father may have sold me to Mason"],[7112,7279,"to settle his debt,"],[7325,7550,"but I will find a way out of this."],[7591,7762,"I have to."],[7800,7900,"You need me."],[8037,8279,"I want nothing to do with you."],[8287,8579,"Behave before I beat you"],[8587,8791,"until you bleed."],[8837,9212,"And fuck you until I break that spirit."],[9525,9737,"God damn it, Lily."],[9900,10166,"Run, run as fast as you can."],[11250,11454,"I got you."]],"2":[[387,637,"Your heart's beating so fast."],[887,962,"It's all right."],[1000,1125,"Just breathe."],[1166,1391,"No I need to-"],[1437,1687,"Hey. I'm not going to hurt you."],[1800,1900,"Can I trust him?"],[1941,2087,"He seems kind, but..."],[2100,2279,"what if he's violent and cruel"],[2279,2404,"like Mason?"],[2487,2600,"What's your name?"],[2641,2737,"Why do you need to know?"],[2779,2891,"Are you always this stubborn?"],[2937,3075,"I'm not stubborn."],[3112,3262,"I'm careful,"],[3300,3466,"especially around strangers."],[3512,3654,"Then let's not be strangers."],[3779,3950,"I’m Cal."],[3991,4200,"And you are?"],[4241,4450,"Lily."],[4487,4612,"What's wrong, Lily?"],[4787,4887,"Hey! Hey!"],[4966,5066,"Talk to me."],[5112,5262,"What's going on? Lily!"]],"3":[[525,750,"Lily! What's going on?"],[791,1000,"Open the door, Foster!"],[1041,1237,"No, no, please don't let him find me."],[1237,1312,"Please."],[1354,1566,"If Mason catches me, he will drag me"],[1566,1666,"back to his house and"],[1666,1816,"punish me for running away."],[1900,2075,"Mason did this to you?"],[2116,2200,"Stay quiet."],[2241,2316,"I’m not letting anything"],[2316,2512,"happen to you."],[2654,2775,"I think you have something that"],[2775,2900,"belongs to me."]],"4":[[50,191,"I don't remember inviting you in."],[200,341,"I don't remember needing permission."],[350,437,"Why are you here?"],[466,650,"I know Lily's in here."],[691,875,"Bring her to me before things get"],[875,937,"bad for you."],[941,1112,"Is that supposed to be a threat?"],[1154,1250,"Hey!"],[1250,1437,"Look at me when I'm talking to you."],[1437,1537,"I don't remember"],[1537,1645,"you being able to give the"],[1645,1787,"orders around here, farm boy."],[1900,2087,"I do."],[2129,2250,"Now bring the girl to me."],[2287,2387,"Why?"],[2412,2537,"Is there a problem?"],[2637,2787,"That's none of your business."],[2825,3125,"Then get out of my house."],[3691,3829,"If I find out..."],[3875,4079,"that you're hiding anything from me."],[4116,4275,"I’ll take everything from you."],[4312,4454,"The house."],[4516,4637,"The farm."],[4712,5000,"Everything I own."],[5054,5400,"You don't own me."],[5479,5729,"Get out!"],[6712,6875,"If you try to make me go back..."],[6912,7050,"I'll shoot."]],"5":[[37,154,"If you shoot me,"],[154,295,"you will have much bigger problems"],[295,412,"to deal with than my boss."],[466,654,"Mason’s your boss?"],[700,837,"I rent from him."],[875,991,"The farm."],[1012,1125,"The house, the land."],[1237,1341,"Just until I earn enough to"],[1341,1487,"buy it all back."],[1575,1645,"I never should have"],[1645,1754,"came to your house."],[1800,1941,"Mason's going to punish you for"],[1941,2012,"hiding me."],[2029,2225,"Lily! I want to help you..."],[2225,2412,"but you have to put down the gun first."],[2412,2462,"Why?"],[2479,2612,"So you can take me back?"],[2612,2779,"So he can hurt me again?"],[2825,2941,"If I was going to do that,"],[2941,3075,"I would have let Mason take you."],[3179,3316,"I'm not going to hurt you, Lily."],[3362,3479,"I promise."],[3525,3829,"I want to believe you, but I can't."],[3841,3937,"I'm scared."],[3937,4025,"Then talk to me."],[4066,4216,"I'm standing right here."],[4262,4354,"Tell me what you need."],[4354,4475,"Tell me what you need to feel safe."],[4487,4679,"I have nowhere else to go."],[4787,4937,"Then stay here tonight."],[4975,5087,"Call your family tomorrow."],[5087,5162,"Family?"],[5200,5387,"My dad sold me."],[5416,5512,"I don't-"],[5791,5887,"Lily!"],[6087,6250,"Hey! Hey! Look at me. Look at me."],[6412,6525,"Hey, what's wrong, Lily?"],[6529,6687,"Mason did this."],[7175,7391,"This is going to sting."],[7866,7975,"Lily?"],[8016,8083,"Lily!"]],"6":[[725,925,"Oh! What the hell are you doing?"],[950,1100,"Taking out the trash."],[1129,1266,"Who the hell are you?"],[1287,1387,"I’m Sadie."],[1400,1516,"I’m Cal's second in command"],[1516,1662,"on this farm, and he trusts me"],[1662,1741,"more than anyone."],[1787,1912,"But I don't trust you."],[1954,2037,"So get out."],[2312,2391,"Oh..."],[2550,2704,"Cal is gonna flip when he finds out"],[2704,2912,"a stranger like you broke his picture."],[2954,3104,"His mom means more to him"],[3104,3229,"than anyone."],[3229,3387,"I'm not a stranger."],[3429,3650,"My name is Lily, and Cal is letting"],[3650,3750,"me stay for-"],[3812,3912,"Wait."],[3937,4125,"You're that girl Mason's looking for,"],[4125,4191,"aren't you?"],[4212,4400,"That is none of your business."],[4441,4600,"It is now."],[5087,5200,"This is going to be fun."]],"7":[[175,325,"Touch me again and I will-"],[325,387,"You’ll what?"],[387,525,"Run and tell Cal?"],[562,675,"I wonder whose side he will take,"],[675,862,"a girl he grew up with, or a thief?"],[866,1012,"Who are you calling a thief?"],[1050,1179,"The girl who robbed you and refuses"],[1179,1300,"to admit it."],[1754,1833,"Cal, isn’t that the"],[1833,1962,"picture of you and your mom"],[1962,2041,"before she-"],[2041,2100,"Got sick."],[2166,2275,"Yeah."],[2312,2416,"She loved this one."],[2462,2566,"And Lily ruined it."],[2612,2716,"First she swiped your money"],[2716,2787,"and now this."],[2787,2875,"Get rid of her, Cal."],[2875,2979,"She doesn't belong here."],[2987,3216,"I swear to you, I did not take these."],[3237,3391,"I would never do that to you."],[3412,3529,"My mom needs this money for"],[3529,3591,"her treatments."],[3591,3662,"Why do you have it?"],[3679,3795,"Because she's a lying,"],[3795,3929,"stealing whore."],[4004,4204,"Time to go back where you belong."]],"8":[[12,129,"Lily!"],[225,300,"Are you okay?"],[337,416,"I'm fine."],[416,712,"But, Cal, I didn't take those"],[712,804,"things from you."],[866,1100,"Not after you have been so kind to me."],[1141,1354,"Look, I want to stay."],[1400,1600,"I want to work to earn my keep, but I-"],[1637,1837,"I didn't do those things."],[1875,1979,"I would never."],[2000,2075,"I believe you."],[2116,2212,"You do?"],[2254,2366,"I do."],[2462,2712,"Let me take care of this."],[2812,2862,"Sadie,"],[2866,3037,"what the hell is wrong with you? What?"],[3054,3112,"What?"],[3112,3354,"She tripped. We all saw her right?"],[3400,3512,"You pushed me."],[3554,3616,"No."],[3637,3729,"You must be confused,"],[3729,3787,"sweetheart."],[3829,3991,"Especially about Cal."],[4054,4179,"What are you talking about?"],[4225,4337,"Oh, you haven't heard."],[4375,4508,"Cal and I are getting married."]],"9":[[62,179,"Us? Married?"],[225,362,"I'm never marrying you, Sadie."],[391,525,"What the hell is wrong with you?"],[525,687,"You know she's Lily Holt, right?"],[725,975,"The girl Mason's looking for."],[1012,1112,"Hiding her here could hurt"],[1112,1266,"all of us, Cal. Not just you."],[1304,1404,"What are you talking about?"],[1437,1562,"If Mason finds out you're hiding her"],[1562,1704,"here on the farm behind his back,"],[1750,1954,"we could all lose our jobs."],[2000,2229,"I hate this, but she's right."],[2250,2491,"Being with me could cost Cal everything."],[2537,2787,"Everybody get back to work."],[2825,2987,"Especially you, Sadie."],[3012,3225,"You have a lot to take care of."],[3262,3358,"So do I."],[3358,3462,"Cal."],[3462,3662,"You don't have to take care of me."],[3700,3825,"I know,"],[3866,4116,"but I want to."],[4350,4475,"Where are we going?"],[4516,4650,"You just have to trust me."],[4687,4875,"Isn't your family bankrupt?"],[4916,5062,"Why else would a has-been heiress"],[5062,5225,"come snooping around a farm?"],[5237,5341,"Enough, Sadie."],[5387,5500,"If she needs work,"],[5541,5612,"I'll give it to her."],[5654,5775,"I get you want to sleep your way"],[5775,5879,"off the streets, but keep your"],[5879,6050,"slutty little hands off of Cal."],[6050,6229,"Touch Lily again, and you're fired."],[6262,6362,"Get off my farm."],[6375,6500,"It's not your farm, Cal."],[6516,6616,"It's Mason's."],[6662,6779,"Go home, Sadie."],[6825,7000,"Big mistake, Cal."],[7329,7475,"Mr. Black."],[7516,7716,"That girl you are looking for..."],[7762,7825,"I found her."]],"10":[[512,762,"Let's get you cleaned up."],[1179,1241,"Sorry."],[1287,1504,"This is the smallest thing I got."],[1550,1650,"It’s okay."],[1687,1875,"I will wear it like a dress."],[2554,2662,"Oh, could you."],[2687,2779,"Oh, sorry."],[2825,2937,"Yeah."],[3450,3679,"I'm sorry about Sadie."],[3725,3829,"I only keep her around because"],[3829,3925,"she's the best at managing the"],[3925,4062,"farmhands, but..."],[4216,4329,"her temper can-"],[4425,4600,"It's okay, Cal."],[4637,4762,"It's not like what she said"],[4762,4950,"was wrong about me, so..."],[4979,5125,"She was all wrong about you."],[6000,6179,"Cal, what are you-"],[6225,6462,"The shirt’s not as long on you as I thought."],[6625,6687,"Yeah."],[6687,7025,"Yeah, I guess it's on the shorter side."],[7175,7316,"Looks good on you."],[7362,7612,"But the farmhands will stare."],[7925,8116,"And what about you?"]],"11":[[225,291,"Cal..."],[337,437,"the seeds you ordered are here."],[437,500,"It's ready."],[537,637,"Go ahead and get back to work."],[675,841,"I'll be out in a minute."],[887,1012,"Hey, speaking of jobs."],[1050,1300,"I'm serious, Cal."],[1362,1562,"I want to work here"],[1600,1787,"with you."],[1825,1950,"I would love to have you, Lily."],[1966,2100,"I would..."],[2141,2391,"but I can't pay you that much."],[2441,2575,"Not as much as what you're used to."],[2575,2625,"Cal..."],[2662,2845,"I used to get"],[2845,3062,"everything handed to me."],[3212,3450,"But I'm not that girl anymore."],[3487,3737,"I need this job"],[3800,4025,"so I can earn my freedom."],[4066,4254,"I can get away from Mason,"],[4254,4366,"go back to school,"],[4366,4616,"get a place of my own."],[4741,4991,"I want to fight for my choice."],[5050,5300,"To do what I want to do."],[5437,5687,"Love who I want to love."],[5775,5912,"You have got grit, Lily."],[5950,6125,"More than people give you credit for."],[6162,6362,"Well then put me to work already."],[6375,6462,"How can I help?"],[6825,6950,"Your hands are soft."],[6991,7129,"Farming work is tough, you know."],[7150,7233,"It's going to hurt until you"],[7233,7354,"get used to it."],[7400,7650,"I'm not a princess, Cal."],[7741,7879,"I can handle getting my hands"],[7879,7991,"a little dirty."],[8075,8237,"Good."],[8329,8400,"Prove it."]],"12":[[312,562,"Farming takes a delicate touch."],[754,841,"You have got to be patient"],[841,975,"from start to finish."],[1075,1266,"How did you learn how to do all this?"],[1312,1400,"My mom."],[1412,1562,"She taught me before she got sick."],[1600,1737,"I need to keep this farm going to pay"],[1737,1837,"for her treatments."],[1879,2037,"What happens if you lose the farm?"],[2079,2275,"I'll lose her."],[2375,2512,"But I'm not going to let that happen."],[2554,2704,"I'll go however far I need to for the"],[2704,2804,"people I care about."],[2912,2987,"Like you."],[2987,3225,"He couldn't mean me, right?"],[3237,3362,"Would Cal feel the same way"],[3362,3512,"if he found out that Mason's"],[3512,3691,"trying to claim me as his wife?"],[3750,4000,"You’ve got something on your.."],[4550,4662,"I won't let him anywhere near you."],[4704,4800,"Cal, there's something I have"],[4800,4879,"to tell you."],[4887,5054,"Well, well, well."],[5100,5225,"Look what we have here."],[5266,5462,"I see you found what belongs to me."],[5741,5975,"I owe you one, Foster."],[6012,6112,"For what?"],[6150,6308,"For bringing me back my wife."]],"13":[[87,212,"You're married?"],[250,412,"No, Cal, I am not."],[454,675,"My dad sold me. And Mason-"],[687,937,"I thought I told you to keep quiet."],[1029,1279,"Don't ever handle her like that again."],[1337,1475,"Or what?"],[1512,1650,"I have enough money and power"],[1650,1816,"to ruin your life, Cal."],[1900,2116,"So keep your opinions to yourself."],[2325,2391,"Cal!"],[2912,2962,"Are you okay?"],[2962,3025,"Did he hurt you?"],[3025,3137,"I’m fine, I’m okay."],[3162,3229,"You're not fine."],[3250,3479,"No! Mason, stop!"],[3525,3662,"I will do whatever you want."],[3662,3862,"Just leave Cal and his farm alone."],[3900,4162,"Stay the fuck away from my wife."],[4212,4350,"Just let me go, Cal."],[4400,4466,"Please!"],[4675,4800,"It's for his own good."],[4837,5141,"If I stay, he'll lose everything."],[5187,5291,"Leave it, Cal."],[5300,5429,"This isn't your problem."],[5475,5579,"I'm going after her."]],"14":[[487,662,"Now that you are back home,"],[700,791,"let’s celebrate."],[825,987,"As future husband and wife."],[1050,1375,"I will never be your wife, Mason."],[1441,1612,"Well, you say that now, but..."],[1629,1762,"you might agree to marry me"],[1762,1900,"sooner than you think."],[1950,2087,"Take it."],[2804,2937,"Good girl."],[3775,4025,"Once we are legally married."],[4137,4237,"I will kill Cal"],[4237,4375,"if he comes anywhere near you."],[4400,4508,"I need this marriage to"],[4508,4637,"clean up my image. And Cal’s not"],[4637,4741,"going to fuck that up."],[4741,4816,"And neither are you."],[4850,5029,"This is bullshit."],[5075,5158,"You can lie to"],[5158,5262,"tabloids all you want,"],[5262,5491,"but I am not marrying you."],[5537,5687,"I still have a choice, Mason."],[5712,5908,"Then I'm going to make you"],[5908,6012,"choose me."],[6100,6304,"No matter what I have to do"],[6350,6600,"or how far I have to go."],[6654,6800,"Got it?"],[6841,6975,"To your future."],[7012,7350,"As my loyal, obedient wife."],[7600,7850,"I will never love you, Mason."],[8016,8250,"But you are going to fuck me."]],"15":[[12,229,"You are going to fuck me."],[300,429,"Over my dead body."],[800,950,"Newsflash!"],[991,1241,"I always get what I want."],[1287,1362,"Not today."],[1804,1900,"Mason?"],[1941,2037,"Mason!"],[2125,2191,"Mason..."],[2200,2450,"Cal, I can’t find a pulse, help!"],[2562,2704,"It's all right."],[2704,2866,"I will check on Mason, okay?"],[2875,3000,"It's all right, just breathe."],[3000,3250,"Just breathe."],[3925,4125,"9-1-1, what's your emergency?"],[4216,4379,"Sadie! What the hell are you doing?"],[4425,4566,"I'd like to report a murder."]],"16":[[62,304,"I'd like to report a murder."],[350,541,"No cops. Go to the truck."],[587,687,"She did it to herself."],[687,779,"She deserves to"],[779,900,"suffer the consequences."],[900,1162,"Sadie! I said go to the truck."],[1204,1350,"His life is going to fall apart"],[1350,1454,"because of you."],[1675,1775,"Cal, she's right."],[1779,1875,"You should go."],[1887,2016,"I'm not going anywhere."],[2062,2225,"Everything's going to be fine."],[2262,2412,"Trust me."],[2587,2700,"He's breathing."],[2950,3037,"We'll be fine."],[3075,3200,"Let's go someplace safe,"],[3200,3325,"and then we can call for help."],[3750,3950,"What the hell did you do to me?"],[4237,4412,"If you handle her like an animal."],[4454,4583,"I’ll treat you like one."]],"17":[[79,137,"Let’s get out of here"],[137,250,"before Sadie calls the cops."],[250,337,"What about your farm?"],[350,525,"He's going to start a war for what we did."],[529,687,"I'm not leaving here without you."],[1487,1591,"What are you doing, Sadie?"],[1591,1675,"Start the truck."],[1712,1825,"You can leave with me"],[1825,1929,"or walk home with her."],[1975,2075,"Your choice, Cal."],[2412,2562,"Then I’m walking home with Lily."],[2566,2629,"Fine."],[2675,2800,"Enjoy the trek."],[2950,3116,"Well, what are we going to do now?"],[3325,3437,"Walk the five miles home."]],"18":[[175,375,"Who the hell does Sadie think she is?"],[387,562,"Stealing my truck because I chose"],[562,637,"Lily over her."],[641,737,"Big mistake."],[775,837,"Ow!"],[954,1175,"Cal, I can’t walk 5 miles that fast."],[1175,1275,"Then let me carry you."],[1987,2091,"You're going to be the end of me,"],[2091,2187,"you know that."],[2279,2504,"I'm losing it because of you."],[2550,2675,"Well if I’m that much trouble"],[2675,2791,"let me go."],[3516,3616,"I can't let anything go"],[3616,3725,"when it comes to you."],[3854,3950,"Why didn't you tell me that"],[3950,4112,"Mason was married to you?"],[4150,4316,"Cal, he bought me."],[4450,4550,"I'm his prisoner."],[4550,4687,"I'm not his wife."],[4725,4887,"Then let's go tell the cops-"],[4912,5029,"the press- let’s expose him."],[5029,5187,"He bought them all off."],[5229,5412,"No one would believe us."],[5416,5604,"Why the hell did it have to be you?"],[5750,5929,"Mason could have any girl he wants."],[5929,6154,"Why did he take you?"],[6287,6450,"I was in the wrong place at the wrong time"],[6450,6500,"that day."],[6637,6787,"Not when you met me."],[6900,7012,"Are you serious?"],[7054,7275,"I crashed into you like a crazy person."],[7316,7566,"And I fell for you right then."],[7612,7733,"Like I am right now."]],"19":[[112,279,"What?"],[325,487,"You don't believe me?"],[529,650,"No!"],[750,1000,"I just don't understand, Cal."],[1100,1225,"I'm complicated."],[1266,1454,"And my situation"],[1500,1625,"is complicated."],[1662,1912,"But liking you isn't."],[2100,2312,"I just do."],[2350,2512,"It's that simple."],[2554,2637,"Are you sure?"],[2679,2929,"I'm sure about you."],[3075,3175,"But I have to know that you feel"],[3175,3425,"the same way about me."],[3766,3991,"I'll race you back to the house."],[4037,4287,"And if you catch me,"],[4387,4637,"I might kiss and tell."],[5725,6050,"Oh, Cal! What are you doing?"],[6300,6412,"I beat you by a mile."],[6454,6625,"You owe me some answers, Lily."],[6979,7125,"Well come and get ‘em."],[7341,7537,"Wait until Mason sees this."]],"20":[[179,275,"What are you doing, Sadie?"],[275,425,"I want my phone back."],[437,475,"Why?"],[500,570,"So you can send the"],[570,675,"picture to Mason?"],[675,829,"He’ll ruin me and take my farm."],[875,954,"Is that what you want?"],[954,1016,"No!"],[1016,1137,"I want you to wake up and realize"],[1137,1237,"she's ruining you."],[1266,1395,"She's good for me."],[1395,1500,"You don't understand."],[1537,1775,"Why are you so obsessed with her?"],[1812,1883,"You’ve never looked at"],[1883,1987,"me like that."],[1987,2150,"I don't want you like that, Sadie."],[2191,2316,"And I never will."],[2450,2545,"Cal! Look out!"],[2900,2945,"Lily!"],[3004,3100,"Stay with me."],[3120,3245,"Quit the act, sweetheart. Get up."],[3279,3379,"Get out of my house!"]],"21":[[1041,1291,"Cal?"],[1487,1666,"You are too handsome for your"],[1666,1912,"own good, Cal Foster."],[2137,2262,"Lily?"],[2287,2387,"Cal?"],[2629,2804,"Lily!"],[3200,3312,"We should..."],[3312,3450,"We should what?"],[3700,3950,"We should get started with the day."],[4350,4600,"What's wrong with starting it like this?"],[6429,6679,"Tell me if you want me to stop."],[6737,6841,"No."],[6862,7062,"No, don't stop."],[7129,7379,"Nobody's ever done this before."],[7725,7850,"I want you to remember what it"],[7850,8012,"felt like with me."],[8662,8850,"I'm going to go see what's going on."],[8962,9158,"Stay over there and be quiet."]],"22":[[250,450,"I can't leave him to handle all this"],[450,512,"on his own."],[525,779,"Cal saved me after my father sold me."],[787,920,"Protected me."],[920,1104,"It's my turn to protect him."],[1104,1337,"I'm sorry, Cal, we can't have outsiders"],[1337,1479,"threatening our livelihood."],[1500,1679,"I'm not threatening anyone."],[1725,1925,"I want to save the farm, just like you."],[1937,1966,"Leave."],[2000,2129,"The adults are talking."],[2129,2200,"No."],[2250,2325,"She should hear what we"],[2325,2395,"have to say since"],[2395,2500,"she's the problem."],[2537,2662,"What are you talking about?"],[2704,2816,"We all quit, Cal."],[2875,3050,"Mason offered us triple our salary"],[3050,3175,"to go work for him."],[3304,3566,"After everything Cal has done for you."],[3625,3737,"This is what he gets?"],[3775,3987,"Where is your loyalty, Sadie?"],[4029,4241,"He will lose the farm without you."],[4287,4454,"Don't do this to him because of me."],[4500,4600,"You still giving orders"],[4600,4729,"Ms. Has-Been Heiress?"],[4775,4925,"Time to step off the throne."],[4966,5087,"No! Stop!"],[5129,5212,"Get off of me!"],[5212,5287,"That’s enough!"],[5500,5637,"Oh, I'm just getting started."]],"23":[[362,566,"Kick and scream all you want, Sadie."],[612,812,"I'll always pick Lily over you."],[850,925,"You hear that?"],[966,1191,"Cal’s got a thing for his boss's wife."],[1237,1525,"But he's not just his boss now, is he?"],[1575,1700,"What is she talking about?"],[1741,1975,"Listen, Lily, I can explain."],[2037,2225,"Mason and Cal are family,"],[2250,2437,"and they're fighting because of you."],[2479,2612,"That's not true."],[2650,2900,"Cal would have told me, right?"],[3016,3087,"Oops."],[3129,3275,"Did I ruin the honeymoon?"],[3316,3454,"You owe her the truth, Cal."],[3479,3587,"Stay out of this, Sadie."],[3629,3716,"If you're not man enough"],[3716,3787,"to be honest,"],[3787,3850,"I will."],[3925,4075,"Mason and Cal are brothers."],[4129,4304,"Enjoy your first fight."],[4712,4854,"Cal, is it true?"],[4900,5162,"Is the man who bought me"],[5162,5366,"and abused me"],[5366,5475,"your brother?"]],"24":[[137,200,"Cal."],[200,325,"I'm not having this conversation"],[325,379,"right now."],[425,637,"You owe it to me."],[679,866,"You know, if you're related to Mason,"],[866,979,"that changes everything."],[979,1150,"You don't think I know that?"],[1191,1350,"That's why I didn't say anything."],[1387,1537,"So it's true."],[1575,1700,"I can't trust you"],[1700,1837,"if you keep secrets from me."],[1887,2116,"I had my reasons."],[2162,2337,"Listen,"],[2379,2479,"I didn't tell you because-"],[2479,2629,"Did Mason put you up to this?"],[2687,2841,"Were both of you planning on using me"],[2841,3012,"me this entire time?"],[3012,3100,"No!"],[3150,3279,"I didn't tell you because I didn't"],[3279,3400,"want to lose you."],[3441,3525,"That you would leave."],[3562,3800,"You lied to me, Cal."],[3841,3954,"You know, maybe you're no different"],[3954,4091,"from Mason after all."],[4237,4312,"I'm sorry you don’t think"],[4312,4412,"I'm better than that."],[4454,4600,"I tried to be."],[4641,4837,"No, Cal, I didn't mean it."],[4837,4891,"No."],[4987,5075,"I need a minute to think."],[5250,5462,"I'll be outside if you decide to stay."],[5500,5720,"Cal, wait. Cal."]],"25":[[87,337,"Who the heck does she think she is?"],[400,650,"Who the heck does he think he is?"],[837,991,"Look, you lost your farmhands"],[1000,1087,"so here I am."],[1112,1262,"Okay, we can talk while we work."],[1287,1425,"If you farm as good as you argue,"],[1425,1495,"we might have a chance"],[1495,1575,"save this place."],[1625,1775,"Will you shut up and"],[1775,1875,"tell me what to do?"],[1925,2087,"Go get some gloves, Princess."],[3054,3175,"You like what you see?"],[3300,3375,"I told you you shouldn’t"],[3375,3437,"touch the wire."],[3437,3504,"And you should have"],[3504,3604,"me about Mason."],[3637,3737,"You're right."],[3775,3875,"I'm sorry, Lily."],[3916,4154,"Don't hide things from me."],[4200,4450,"If you hide things, I can't trust you."],[4504,4737,"And, Cal,"],[4737,4925,"if I can't trust you, then how are you"],[4925,5029,"different from Mason?"],[5041,5137,"There's no blood between"],[5137,5225,"me and Mason, Lily."],[5254,5387,"But Sadie said that-"],[5387,5487,"Sadie was wrong."],[5529,5775,"Cal, you should have told me."],[5816,5950,"I deserve to know."],[5987,6112,"I didn't want the truth about"],[6112,6229,"my family to scare you off."],[6454,6562,"But you're right."],[6600,6741,"I owe you the whole story."]],"26":[[12,129,"I didn't want the truth about my"],[129,262,"family to scare you off."],[366,512,"But you're right."],[550,737,"I owe you the whole story."],[766,1025,"Mason’s dad left his wife for my mom."],[1150,1304,"He’s hated me ever since."],[1654,1750,"So dad didn't leave"],[1750,1875,"me or mom anything?"],[1912,2087,"He wouldn't do that to us."],[2087,2154,"Cal..."],[2237,2491,"the thief steals the keys to the castle."],[2637,2887,"Does he deserve the throne?"],[3137,3250,"Now that you're cut off..."],[3291,3429,"I’m evicting you, Cal."],[3475,3562,"You want to stay on my land?"],[3562,3737,"You got to pay up like everyone else."],[3779,3837,"What?"],[3950,4137,"You can't do this to us, Mason."],[4216,4450,"I own the Black family estate now."],[4500,4704,"I can do whatever the hell I want."],[4775,4862,"Mason's punished"],[4862,5000,"me and my mom for years."],[5066,5200,"He knows I can't pay her hospital"],[5200,5316,"bills without the farm."],[5362,5704,"I am so sorry I doubted you, Cal."],[5779,5837,"It's all right."],[5975,6225,"I just want to earn your trust back."],[6475,6712,"It's already done."],[6754,7004,"Now let's go save that farm together."],[7066,7150,"How?"],[7175,7312,"I know how to get you the money."]],"27":[[29,112,"Please tell me it doesn't"],[112,229,"involve Mason."],[229,325,"I can't tell him"],[325,429,"I'm going to sneak the money"],[429,541,"out of Mason’s safe."],[587,741,"Or he'll lose it."],[900,1000,"Well, I-"],[1000,1137,"Sorry."],[1325,1500,"This might be a while."],[1666,1800,"Sorry, Cal."],[1837,2025,"If I'm going to save your farm,"],[2062,2241,"I have to go back to Mason's."],[2287,2475,"Just this once."],[3229,3391,"Well, look who came crawling back."],[3425,3650,"If she says anything to Cal or Mason,"],[3650,3729,"I'm screwed."],[3775,3891,"Sadie, don't."],[3891,3950,"Oops."],[3991,4125,"Too late."],[4162,4262,"I'm going to tell Cal"],[4262,4412,"he's going to love these."],[4825,4912,"Forget her."],[4912,5129,"Lily, you're doing this for Cal."],[5162,5250,"He’ll understand."],[5262,5416,"He has to."],[6525,6704,"This money will save the farm."],[6704,6850,"And Cal's mom."],[6891,7050,"This will fix everything."]],"28":[[100,225,"What are you doing, Lily?"],[262,504,"I'll explain later, but I'm doing this"],[504,550,"for you."],[550,754,"What you're doing is driving me crazy."],[800,937,"What if Mason caught you?"],[979,1212,"I am not that careless, Cal."],[1237,1379,"What if he tried to hurt you"],[1379,1516,"and I wasn't there to stop him?"],[1600,1691,"I don't know."],[1737,1912,"Okay, I wasn't thinking."],[1954,2137,"I was just trying to help you."],[2137,2387,"Even if it means getting you hurt."],[2450,2650,"If Mason put his hands on you, Lily..."],[2662,2762,"What the hell are you two"],[2762,2912,"doing in my safe?"],[3079,3212,"Do you know what happens to people"],[3212,3329,"who try to steal from me, Cal?"],[3425,3666,"I destroy everything they love."],[3712,4025,"I know because I've lived through it."],[4112,4200,"And look at me, Mason."],[4241,4404,"Still going strong."],[4450,4600,"Let’s see how long you last"],[4625,4750,"when I fuck over your life."],[4812,4925,"And I fuck her."],[5375,5454,"Get out of here, Lily!"],[5629,5812,"I'm not leaving without the money."],[6625,6741,"Let's get out of here."],[6754,6825,"Let’s go."],[7066,7150,"Look..."],[7150,7316,"I know I should have been safer"],[7316,7466,"about going to Mason's, but-"],[7466,7579,"You shouldn’t have gone at all."],[7675,7762,"And for what?"],[7804,7975,"To save the farm?"],[8016,8266,"How, Lily?"],[8504,8604,"This is how."],[8604,8754,"Take it, Cal."],[8812,8966,"The only reason I went back to"],[8966,9062,"that place is-"],[9162,9412,"is to get this money for you."],[9525,9616,"I don't want your money."]],"29":[[12,137,"I don't want your money."],[162,216,"Why?"],[262,379,"Mason doesn't need it."],[387,466,"You do."],[475,662,"Lily, if you take what belongs to Mason,"],[662,754,"he'll come after you."],[800,1000,"We have to take it back now."],[1037,1262,"Mason thinks I belong to him."],[1300,1437,"Are you going to give me away, too?"],[1441,1600,"No. How could you say that?"],[1625,1875,"I would never."],[2012,2175,"I will never send you back."],[2216,2325,"Lily."],[2362,2541,"You belong right here"],[2587,2679,"with me."],[2725,2929,"I won’t let anything bad happen to you"],[2929,3066,"because of me."],[3204,3291,"Cal, what's happening?"],[3337,3516,"There's a storm coming."],[3562,3679,"You're safe with me."],[3725,3850,"Come on."],[3887,4025,"Lily, look at me."],[4066,4204,"I got you."],[4250,4375,"Do you trust me?"],[4537,4629,"I do."],[4725,4866,"Let’s get to the storm cellar, now."]],"30":[[150,300,"We’ll be safe in here."],[641,775,"You’re freezing."],[950,1041,"Let me go get you a heater."],[1075,1154,"Wait, Cal..."],[1200,1387,"that’s not what I want."],[1429,1575,"Then tell me what you want."],[3175,3387,"Everything's going to be fine."],[3429,3541,"I got you."],[3679,3887,"My heart’s beating out of my chest."],[3979,4112,"Then focus on mine."],[4291,4525,"Your heart's racing."],[4687,4812,"Not because of the storm."],[5041,5191,"Oh my God, are you okay?"],[5191,5362,"You're drenched."],[5400,5554,"I’ll go get you a towel."],[5954,6275,"I'm not losing Cal to a whore like you."],[6329,6462,"No!"],[6500,6612,"Sadie!"],[6766,6895,"So do me a favor"],[6895,7025,"and die in the storm."],[7025,7133,"Cal!"]],"31":[[350,487,"Please, Cal!"],[754,966,"Sadie! What the hell is wrong with you?"],[1012,1112,"Lily could have been hurt."],[1129,1225,"She deserves it"],[1225,1350,"for cheating on her husband."],[1354,1575,"He’s not my husband, Sadie."],[1579,1816,"Wow. A liar and a cheat."],[1837,2087,"I'm telling Mason. Right now."],[2129,2262,"Damn it, Sadie."],[2350,2579,"She hates the idea of us together."],[2625,2725,"Everyone does."],[2725,2916,"I don't care what anyone thinks"],[2916,2991,"or wants."],[3104,3250,"I want you."],[3287,3512,"Yeah, well, maybe you shouldn't."],[3550,3775,"You keep fighting for me."],[3775,3900,"But every time you do,"],[3900,4025,"you risk losing the farm."],[4050,4275,"I'm not losing anything."],[4316,4441,"I'm not losing the farm."],[4487,4600,"Or you."],[4775,4925,"We'll figure this out."],[5025,5187,"I promise."],[5387,5554,"You just rest for now."],[5975,6166,"What if Mason tries taking you away"],[6166,6225,"from me?"],[6454,6637,"I'm not going anywhere."],[7737,7850,"Cal?"],[8262,8387,"Cal!"]],"32":[[112,350,"Come on, Ma, pick up."],[725,900,"You've reached the voicemail of-"],[1387,1637,"Hey. Is everything okay?"],[1679,1762,"Couldn't sleep."],[1762,1891,"The storm kept you up?"],[1941,2012,"No."],[2125,2275,"You did."],[2579,2737,"What do you mean?"],[2779,2912,"I keep thinking about all the things"],[2912,3137,"that Mason can do to hurt you."],[3179,3300,"And I can't take it."],[3341,3700,"Look, I know, but if we’re together-"],[3725,3912,"Are we?"],[3954,4100,"What are we doing, Lily?"],[4137,4262,"You tell me."],[4300,4437,"I don't know."],[4479,4587,"Because I keep hoping"],[4587,4729,"for things that I shouldn't."],[4850,5100,"I want to give you the world, but"],[5191,5300,"Mason can give you"],[5300,5441,"everything that I can't."],[5500,5616,"Cal."],[5900,6125,"Not everything."],[6616,6866,"Tell me to kiss you."],[7075,7187,"Kiss me."]],"33":[[1962,2100,"Get back here."],[2425,2550,"Wait."],[2587,2687,"What about Mason?"],[2729,2950,"He's going to keep coming after us."],[2987,3187,"Then let's fight back."],[4016,4250,"How did you do that?"],[4287,4454,"I'll teach you."],[4950,5200,"Straighten out."],[5362,5500,"Focus on your target."],[5625,5766,"Square your shoulders."],[5912,6050,"Breathe..."],[6212,6350,"and let go."],[6650,6779,"I hit it."],[6825,7012,"That's my girl."],[7829,7983,"Take this with you."],[8075,8145,"You never know when you might"],[8145,8262,"need it."],[9075,9300,"Let me handle this."],[9341,9537,"If Mason ever touches you again..."],[9575,9641,"fight back."]],"34":[[41,212,"Easy. I just want to talk."],[262,375,"Boss isn’t in the mood for talking."],[375,525,"If he was we wouldn’t be here."],[525,625,"Hold him down, boys."],[675,925,"I want to speak to Lily uninterrupted."],[1050,1212,"You don’t know when to quit."],[1237,1312,"Cal!"],[1450,1512,"Cal!"],[1612,1762,"You’re running to the wrong man,"],[1762,1850,"sweetheart."],[1879,2000,"You’ll pay the price for that."],[2091,2162,"What’s the matter?"],[2175,2312,"You’re not happy to see me?"],[2425,2512,"Any closer..."],[2541,2650,"and I’ll snap her neck."],[2800,2925,"Where the hell are you taking her?"],[2966,3079,"To fuck in your bed."],[3100,3175,"Cal!"]],"35":[[775,916,"I’m only going to ask you"],[962,1175,"this once."],[1312,1487,"Did you sleep"],[1516,1675,"with that farm boy?"],[1691,1837,"Mason, you’re hurting me."],[1850,1991,"Fight back, Lily."],[2000,2187,"You can do this."],[2212,2337,"Answer the question."],[2391,2662,"Did you fuck him?"],[2837,3091,"I didn't sleep with anyone."],[3300,3654,"And I will never sleep with you."],[3791,4012,"You're gonna regret that."],[4766,4850,"No."],[5025,5104,"Where's Lily?"],[5162,5266,"What the hell did you do to her?"],[5304,5475,"Go see for yourself."],[6100,6212,"If you hurt her..."],[6300,6400,"I'll kill you!"],[6475,6604,"Not if you die first."]],"36":[[25,150,"Somebody, please!"],[287,329,"Lily!"],[329,391,"Cal!"],[475,600,"I got you!"],[1362,1429,"Stay right here."],[1466,1525,"I'll handle this."],[1541,1625,"No! Stop!"],[1629,1729,"We have to call for help."],[1737,1891,"There's no time."],[1991,2200,"This barn is all I have left."],[2279,2441,"I have to be the one to save it."],[2487,2608,"You better come back to me,"],[2608,2737,"Cal Foster."],[2812,2987,"I will always come back to you."],[3491,3562,"Cal, wait."]],"37":[[16,129,"What are you doing?"],[162,225,"Helping."],[262,441,"Whether you like it or not."],[541,725,"Then let’s do it together."],[1400,1500,"Hey."],[1687,1787,"It's all right."],[1837,1950,"Just breathe."],[1991,2116,"Just breathe."],[2266,2325,"Stay put."],[2362,2450,"I'm going to go get you some water."],[2450,2537,"Okay?"],[2800,2875,"Cal?"],[2916,2962,"Cal,"],[2962,3162,"you need to lay down."],[3325,3475,"I will if you will."],[4512,4675,"This is going to sting a little."],[5429,5575,"It's fine."],[5687,5912,"Cal, you’re hurt. You need-"],[5929,6179,"That's not what I want right now."],[6404,6587,"What do you need?"],[7737,7800,"Just you."]],"38":[[2166,2312,"Cal, what’s wrong?"],[2491,2650,"Nothing."],[2787,2987,"You're just perfect."],[3800,3904,"Lily,"],[3950,4125,"I need to know if-"],[4200,4466,"Yes. Yes, please."],[6841,7091,"You're still staring."],[7429,7600,"And you're still beautiful."],[7854,7962,"Cal..."],[8104,8250,"you know, you were my first."],[8291,8404,"I'll happily be your last"],[8404,8537,"if the position’s open."],[8616,8791,"Stop messing with me,"],[8791,8916,"Cal Foster."],[8916,9062,"Who said I was?"],[9229,9387,"Ready to meet my mom?"],[9425,9562,"Now is as good a time as any."],[9879,10075,"Hi, sweetheart."],[10116,10287,"I'm so sorry I missed your calls"],[10287,10400,"during the storm."],[10462,10562,"I'm just glad you're okay."],[10591,10762,"I hope you're okay, baby."],[10804,10966,"You sound happy."],[11116,11212,"I am."],[11312,11412,"Actually,"],[11466,11650,"there's someone I want you to meet."],[11750,11850,"Can we come by?"],[11887,12029,"I'd love you to."],[12075,12225,"I'll tell your stepbrother"],[12225,12337,"to wait here until you come"],[12337,12475,"so he can meet her too."],[12541,12641,"Mason’s there with you?"],[12712,12891,"He's been right here next to me the whole-"]],"39":[[375,437,"Mom?"],[462,541,"Whoa, whoa."],[587,679,"Who the hell are you?"],[712,1000,"Her new doctor. My personal choice."],[1012,1237,"I don't want him anywhere near her."],[1525,1620,"Well that wasn't very"],[1620,1700,"nice of you, Cal."],[1729,1808,"Doctor Wright saved your"],[1808,1929,"mom's life."],[1929,2029,"She nearly died"],[2029,2150,"on the way from the hospital."],[2162,2300,"She shouldn't even be here."],[2325,2416,"Why did you bring her here"],[2416,2479,"without my permission?"],[2479,2575,"Because I can."],[2612,2712,"Because there's nothing"],[2712,2816,"you can do about it."],[2862,2975,"I’m going to get you out of here, Ma."],[2975,3087,"No you won’t."],[3179,3354,"Since you can't pay for the bills,"],[3400,3504,"I've taken over."],[3529,3662,"She’s under my care now."],[3704,3775,"If you keep"],[3775,3954,"screwing around with Lily."],[4062,4254,"It will cost you your mom’s life."],[4437,4629,"You keep threatening me,"],[4675,4808,"it will cost you yours."]],"40":[[237,425,"I don’t want to choose Mason."],[479,725,"But I have to save Cal and his mom."],[750,950,"Get your hands off Mason."],[1304,1500,"At least she knows her place."],[1525,1725,"Cal isn’t worth our time."],[1766,1875,"Why do you keep sneaking off"],[1875,1966,"with him?"],[2037,2158,"To see if you actually"],[2158,2287,"cared about me."],[2362,2554,"Jealousy is a turn on."],[2600,2850,"And now I know how far you will go."],[3000,3250,"I'll be the wife you want me to be."],[3504,3712,"Do you mean that?"],[3754,3937,"It's me or your mom."],[3979,4116,"And I won't make you decide that."],[4116,4329,"So I'll decide for you."],[4691,4862,"Hey, babe..."],[4900,5012,"promise me you guys"],[5012,5150,"will stop fighting."],[5237,5491,"I want all of your attention on me."],[5550,5716,"You got it."],[5762,5812,"Cal,"],[5812,5950,"get out."],[6162,6316,"Tell me you don’t want me."],[6362,6450,"Say it!"]],"41":[[25,137,"Say it!"],[187,262,"Go!"],[300,416,"Just go."],[1016,1187,"Damn it, Lily!"],[1466,1537,"Get out!"],[1579,1666,"I don't want you here."],[1712,1829,"Either of you."],[1875,1962,"Relax."],[2000,2250,"I come bearing gifts."],[2300,2425,"Consider that a thank you"],[2462,2641,"for helping Lily during the storm."],[2687,2829,"I don't want it."],[2875,3012,"Too bad."],[3050,3216,"I've already had Lily and the farmhands"],[3216,3337,"feed it to the animals."],[3350,3425,"Mason!"],[3441,3537,"Not now, Sadie."],[3575,3662,"I need to talk to you."],[3662,3791,"It's urgent."],[4379,4462,"Tell me you want him,"],[4475,4650,"and I'll leave you alone."],[4729,4937,"I want you."],[5100,5287,"Only you."],[6279,6529,"I hate seeing him touch you."],[6575,6825,"I want you all to myself."],[6916,7158,"The animal feed’s been poisoned!"]],"42":[[87,325,"Cal, I'm so sorry."],[366,450,"Don't."],[741,975,"What the hell did you do?"],[1016,1191,"Finally put you in your place."],[1191,1450,"Why would you go this far to hurt him?"],[1512,1666,"I didn’t hurt Cal."],[1712,1825,"You did."],[1950,2216,"If I ever catch you with him again,"],[2216,2337,"there will be hell to pay."],[2375,2512,"Maybe it would be better if he was"],[2512,2662,"dead and gone."],[2687,2916,"Speak for yourself."],[3316,3412,"I warned you."],[3491,3625,"This is what happens when you"],[3625,3700,"touch her."]],"43":[[437,562,"I shouldn't have hit him like that."],[575,754,"Was it worth it, Cal?"],[800,925,"Is she worth it?"],[966,1087,"You're going to lose the farm"],[1087,1200,"because of her."],[1237,1350,"Just drop it, Sadie."],[1350,1425,"No."],[1437,1600,"We need to talk."],[1650,1816,"Just you and me."],[2062,2150,"It's fine."],[2191,2266,"Go."],[2704,2779,"Look."],[2912,3050,"If you have any"],[3050,3200,"genuine feelings for Cal,"],[3279,3466,"you'll leave him alone."],[3512,3637,"You're not good for him."],[3679,3787,"And you"],[3787,3937,"don't know what you're talking about."],[4004,4120,"I know that if"],[4120,4275,"Mason arrests him for assault"],[4304,4525,"he'll lose everything."],[4566,4791,"Is that what you want?"],[4837,4941,"No, and I'm not"],[4941,5075,"going to let that happen."],[5116,5250,"You already have."],[5291,5491,"If Cal keeps choosing you..."],[5537,5716,"the farm won't survive."],[5762,5950,"And neither will his mom."],[5950,6187,"I don't want to hurt him, Sadie."],[6191,6437,"Then forget about him."],[6479,6716,"There is no version of this story"],[6754,6975,"where you and Cal end up together."],[7091,7200,"Got it?"],[7350,7516,"You stay with your man,"],[7562,7679,"and I'll leave with mine."]],"44":[[412,587,"Hey! Slow down."],[779,900,"We can figure this out."],[925,1041,"I can talk to Mason."],[1041,1191,"Like you did during the storm?"],[1216,1375,"He came after us because of you."],[1462,1612,"Lily's his wife, Cal."],[1737,1900,"It's not that simple."],[1937,2062,"She's in trouble."],[2116,2262,"So are you."],[2300,2391,"What do you think is going to happen"],[2391,2450,"to the farm,"],[2450,2525,"to your mom,"],[2525,2687,"when Mason wakes up?"],[2750,2954,"You need to forget about Lily."],[3000,3112,"Put yourself first."],[3154,3329,"I can't do that. I won't."],[3375,3612,"What if I told you that I've been"],[3612,3825,"saving up for us?"],[3862,3937,"For our future."],[3979,4150,"What are you talking about?"],[4241,4462,"If I told you that I had enough money"],[4462,4700,"to save the farm and help your mom,"],[4741,4950,"would you start a life with me?"],[5100,5300,"Cal, what's going on?"],[5387,5479,"Oh, you're just in time"],[5479,5587,"for the good news."],[5629,5733,"We're engaged."]],"45":[[0,125,"You're marrying her?!"],[162,250,"No!"],[266,387,"I would never give her my"],[387,466,"mother's ring."],[466,562,"She stole it."],[587,762,"The ring belongs to me."],[829,975,"I'm the only one that can help"],[975,1154,"save the farm and get Lily away"],[1154,1304,"from Mason for good."],[1379,1491,"What are you talking about?"],[1504,1712,"I have videos of everything."],[1754,1912,"Mason poisoning the animals,"],[1912,2050,"setting the house on fire."],[2075,2179,"Beating up on Lily."],[2212,2329,"I’ll only give them to her"],[2329,2437,"once we're married."],[2437,2587,"Where did you get all these?"],[2625,2775,"Sweetie, I manage the farmhands."],[2779,2900,"I have eyes everywhere."],[2929,3091,"Yeah, especially on Cal."],[3091,3175,"Right?"],[3212,3362,"Sadie, why are you doing this?"],[3379,3487,"Why are you helping Lily?"],[3525,3641,"I'm giving Lily a chance to"],[3641,3800,"blackmail her way to freedom."],[3925,4162,"Unless you have any better ideas."],[4204,4379,"You don't have to do this, Cal."],[4425,4558,"There has to be another way."],[4666,4816,"You derserve to be happy Lily,"],[4858,4962,"with..."],[4962,5158,"or without me."]],"46":[[275,391,"Screw this."],[437,554,"I got to see her."],[1787,1887,"What are you doing here?"],[1925,2062,"Stealing you away."],[2191,2354,"Aren't you almost a married man?"],[2400,2566,"Aren't you almost a married woman?"],[2612,2779,"You shouldn't be here, Cal."],[2825,2937,"We could get caught."],[2950,3000,"You’re right."],[3075,3191,"But if tonight is all we have left,"],[3191,3312,"would you rather spend it in here?"],[3350,3454,"Or with me?"],[3662,3766,"The jury’s still out."],[3812,3975,"Quit arguing and come out with me."],[4012,4179,"If you want me to come out so bad..."],[4225,4341,"then give me your hand."],[4812,5062,"You better catch me, Cal Foster."],[5125,5187,"We'll see."],[5212,5362,"Jury's still out."],[5437,5537,"Where are you taking me?"],[5575,5637,"Don't ask."],[5662,5758,"Just trust me."]],"47":[[100,262,"I couldn't sleep, so I figured"],[262,437,"I'd make this for you."],[741,837,"It's beautiful."],[875,975,"Thank you."],[1025,1125,"Don't thank me just yet."],[1162,1291,"The night's just getting started."],[2737,2925,"Tonight's our last night together."],[3000,3066,"I want to spend it"],[3066,3212,"slow dancing with you."],[3712,3900,"Now that you're almost free."],[4212,4350,"I want you to have this."],[4625,4741,"Take my truck"],[4787,5000,"and drive the hell out of here."],[5041,5200,"I can't accept this."],[5337,5425,"Take the money"],[5425,5562,"and start your new life."],[5625,5787,"It's everything I've saved."],[5879,6041,"I hope it saves you."],[6100,6329,"I don’t want to lose you, Cal."],[6487,6675,"I'll find my way back."],[6754,6912,"I always do."],[7800,7904,"You really think you can"],[7904,8050,"let me go, Cal Foster?"],[8187,8362,"I have to."],[8537,8687,"But I don’t want to."],[12312,12520,"Where the hell were you?"]],"48":[[0,200,"Answer the question."],[237,437,"You owe me the truth."],[462,616,"I don't owe you anything."],[662,745,"Now that Cal doesn't"],[745,866,"need me anymore."],[904,1029,"I'm getting away from you."],[1075,1250,"No you're not, sweetheart."],[1325,1575,"I own you."],[1637,1775,"I don't belong to you."],[1800,1950,"Without me, you wouldn't survive."],[1950,2000,"See?"],[2341,2479,"I wouldn't let you."],[2487,2600,"Let go of me, Mason."],[2629,2737,"Know what I like more"],[2779,2875,"than watching you beg?"],[3079,3229,"Owning things."],[3366,3562,"People like you."],[3600,3750,"Farms like Cal’s."],[4016,4087,"Sadie said"],[4087,4191,"she was going to buy the farm"],[4191,4337,"after her and Cal got married."],[4375,4550,"Sadie's an excellent liar, isn't she?"],[4591,4695,"She only said that ‘cause I"],[4695,4787,"paid her to."],[4787,4950,"Now Cal is all hers."],[4975,5054,"And you..."],[5100,5262,"you are all mine."],[5404,5516,"Cal is going to suffer"],[5516,5641,"for failing to understand that."],[5687,5925,"And so are you."],[6070,6229,"C’mon! Let me go, Mason!"]],"49":[[437,591,"Last chance to tell the truth, Lily."],[637,775,"I'm not telling you anything."],[791,900,"Maybe you will."],[912,1004,"When I force you to"],[1004,1104,"in front of an audience."],[1141,1237,"If I find out"],[1266,1379,"that you’ve been whoring around"],[1379,1466,"with Cal,"],[1525,1625,"I’ll torture him"],[1666,1800,"until he fucking breaks."],[1837,1966,"And I’ll let each of my farmhands"],[1966,2150,"get a piece of you."],[2237,2354,"I brought you here"],[2354,2454,"to answer one"],[2491,2625,"simple question."],[2637,2720,"Hush!"],[2750,2937,"Who here knows"],[2937,3100,"if Lily here’s been unfaithful?"],[3241,3379,"Answer the question!"],[3425,3587,"Did you fuck Cal?"],[3754,3912,"Let's play a game, boys."],[3966,4150,"For every question she dodges"],[4212,4341,"I'll strip off a piece of clothing."],[4341,4454,"Get off of me!"],[4454,4650,"Hey, don’t fight it. Don’t fight it!"],[4687,4916,"Since you like men’s eyes on you."],[4962,5083,"Let's put you on display."]],"50":[[37,179,"Let go of her, Mason."],[200,300,"Cal!"],[325,462,"Lily was just about to tell us"],[462,600,"if you had screwed around or not."],[629,787,"Since Cal called off our wedding"],[804,862,"I’ll tell you"],[862,1012,"everything you want to know, Mason."],[1012,1075,"Sadie..."],[1075,1141,"don’t!"],[1154,1279,"Hold him back, boys."],[1450,1541,"They slept together."],[1575,1737,"I saw them right after."],[1779,1954,"Good work as always, Sadie."],[2000,2166,"It is time that Cal saw you"],[2166,2275,"for the snake"],[2275,2412,"that you really are!"],[2412,2579,"Better a snake than a whore."],[2737,2812,"So..."],[2979,3075,"tell me, Cal."],[3200,3362,"How'd you touch her?"],[3487,3612,"Like this?"],[3650,3725,"Let her go."],[3762,3862,"Fine by me."],[4416,4454,"I got you."],[4500,4562,"Let's get out of here."],[4575,4712,"You're not going anywhere."],[4887,4987,"That's enough, Sadie!"],[4987,5112,"Get out of my way!"],[5112,5150,"No!"],[5525,5579,"Oh my God."],[5600,5737,"Cal, I’m so sorry"],[5737,5866,"I didn’t mean to hurt her."],[5912,6054,"Somebody help!"],[6070,6141,"Help!"]],"51":[[91,212,"Get her off my property."],[250,387,"No, we can help her."],[387,512,"We can save her."],[775,941,"Mason, what the hell are you doing?"],[975,1225,"Dealing with things my way."],[1266,1354,"Oh, Cal!"],[1387,1412,"Hey-"],[1412,1566,"Another step and I'll slice."],[1575,1687,"Cut the heroics."],[1725,1875,"The three of us need to talk."],[2012,2141,"Let's cut to the chase, Cal."],[2187,2312,"Since you violated Lily,"],[2312,2375,"I'm evicting you"],[2375,2441,"by the end of the day."],[2491,2600,"Do what you want to me,"],[2600,2737,"but let Lily and my mom go."],[2779,2879,"Why would I do that?"],[2925,3016,"They’re the easiest ways"],[3016,3141,"to make you suffer."],[3304,3375,"Easy."],[3416,3575,"Touch me again,"],[3675,3841,"and I’ll kill her right in front of you."]],"52":[[4,175,"Touch me again"],[250,437,"and I'll kill her right in front of you."],[691,804,"Good boy."],[829,950,"You learn fast."],[1000,1129,"I'm not going to let you hurt her."],[1162,1262,"Tell you what."],[1329,1425,"I'll let you have Lily."],[1425,1587,"The farm, and your mom back."],[1629,1750,"If you do"],[1775,1904,"whatever I ask"],[1925,2037,"for the next week."],[2037,2254,"Do what I say without question."],[2287,2412,"I'll let you have everything."],[2437,2512,"Deal?"],[2587,2775,"If it will keep Lily and my mom safe"],[2850,3012,"I'll do whatever you ask."],[3091,3250,"I can handle a week."],[3350,3541,"Cal can handle anything."],[3587,3637,"How do we know"],[3637,3775,"you will keep your word?"],[3929,4129,"Cancel Cal's eviction notice,"],[4175,4379,"effective immediately."],[4516,4741,"I will honor my end of the deal."],[4787,4866,"Because I want to see"],[4866,4987,"if you're still going to choose him"],[4987,5150,"after I drag him through hell."],[5150,5341,"I'll choose him no matter what you do."],[5354,5500,"You sure about that?"],[5729,5900,"Storms coming, Cal."],[6000,6079,"So why don't you go"],[6079,6329,"sleep outside like the dog you are?"],[6450,6516,"Wait."],[6754,6941,"Be careful out there."],[7050,7254,"And whatever you do,"],[7300,7550,"don't let him win."],[7604,7816,"If I'm doing this for you,"],[7862,7991,"I'm not losing to anyone."]],"53":[[16,179,"I do admire his confidence."],[225,475,"It will be a miracle if he lasts a week."],[562,700,"Tell me the truth."],[741,916,"Does Cal really have the chance"],[916,1025,"to save the farm?"],[1125,1250,"Of course not."],[1287,1412,"Do you really think I'd play games"],[1412,1479,"I can't win?"],[1491,1679,"This is his life, Mason!"],[1679,1850,"This is power, Lily."],[1891,2041,"It's time for both of you to understand"],[2041,2162,"who is in control."],[2462,2537,"Where are you going?"],[2537,2712,"To tell Cal everything."],[2754,2875,"If you do that..."],[2900,3004,"I'll kill Cal's mom."],[3154,3233,"You understand how this"],[3233,3325,"works now?"],[3366,3579,"You are a monster!"],[3675,3812,"I'd rather sleep in the barn"],[3812,3975,"than stay with you."],[4000,4112,"Fine by me."],[4454,4520,"Help!"]],"54":[[325,454,"You're making life"],[500,616,"so much harder than"],[616,750,"it has to be, Lily."],[791,900,"Life would have been so much easier"],[900,1075,"easier if you'd just chosen me."],[1141,1387,"If you had behaved when I bought you,"],[1429,1641,"I would have given you everything."],[1687,1804,"You were an heiress."],[2000,2200,"Your family is very powerful..."],[2200,2312,"is very wealthy."],[2362,2500,"I would have brought you back in"],[2541,2625,"with the elite."],[2650,2837,"None of that matters, Mason."],[2879,3037,"I'm not that girl anymore."],[3387,3487,"Yes you are."],[3512,3637,"It’s in your blood."],[3762,3950,"Just like it's in mine."],[4050,4300,"I want nothing to do with you."],[4787,4925,"Sooner or later,"],[4962,5175,"you'll come crawling back to me."],[5591,5766,"Enjoy the cold, Lily."],[6479,6687,"Somebody help!"],[6729,6854,"Please!"],[7200,7279,"Cal!"],[7425,7479,"Lily!"],[7500,7562,"What happened?"],[7562,7650,"You shouldn't be here."],[7662,7812,"I need to warn Cal that"],[7812,7966,"Mason’s setting him up to lose."],[8062,8237,"But it will put his mom in danger."],[8554,8616,"I told Mason"],[8616,8737,"I wanted to be with you,"],[8737,8950,"but he punished me for it."],[9237,9291,"I’m always the reason"],[9291,9404,"he’s hurting you."],[9475,9625,"This has to stop."],[9837,9966,"I can't be with you anymore."]],"55":[[50,175,"Why would you say that?"],[200,325,"After everything."],[329,400,"Why?"],[400,579,"Look, you have the keys to my truck."],[604,729,"I want you to get out of here,"],[729,912,"away from Mason and me."],[937,1075,"So that's it?"],[1141,1291,"You're just giving up on us"],[1291,1362,"just like that?"],[1366,1537,"Look, I'm giving you the chance to leave."],[1537,1666,"while Mason's not here to stop you."],[1666,1916,"I don't care about Mason."],[2016,2179,"I care about you"],[2191,2266,"and your mom"],[2266,2350,"and the farm."],[2362,2550,"Look, I'll find a way to get everything"],[2550,2712,"back without getting you hurt."],[2716,2879,"So just please go."],[2912,3075,"Why the hell would you fight for me"],[3075,3212,"if you were just going to let me go?"],[3225,3462,"This is me fighting for you, Lily."],[3500,3750,"You wanted your freedom, so take it."],[3787,3925,"My truck's parked around back."],[3937,4087,"Take this to stay warm on the way."],[4087,4237,"I'm not leaving!"],[4237,4379,"Why the hell won’t you listen to me?"],[4379,4612,"Because I am in love with you."]],"56":[[16,191,"I’m sorry, Lily. I can't."],[225,400,"I can't believe that a girl like you"],[437,529,"would love a guy like me."],[679,775,"I’m nothing special."],[779,941,"You don't see what I see."],[950,1125,"I see a girl who's out of her mind"],[1125,1225,"for loving me."],[1391,1612,"But I love her right back."],[1654,1841,"More than she knows."],[2591,2729,"We got to get you back to the house."],[2775,2837,"You're burning up."],[2850,2929,"We can stay here and"],[2929,3004,"keep each other warm."],[3004,3125,"No, I'm not letting you do that."],[3137,3225,"You're not getting sick"],[3225,3287,"because of me."],[4487,4579,"I thought I told you to"],[4579,4704,"sleep outside, Cal."],[4704,4862,"You broke our agreement."],[4900,5012,"That’s going to cost you."],[5012,5091,"Cost me what?"],[5116,5262,"I'm going back out there, Mason."],[5300,5412,"Your mom's awake."],[5450,5562,"Let's go see her."],[5600,5737,"We have a lot to discuss."],[5800,5875,"Mom!"],[6062,6137,"You’re okay, right?"],[6187,6312,"Mason didn't hurt you?"],[6337,6437,"Mason is..."],[6512,6666,"taking good care of me."],[6704,6904,"Unfortunately, I will no longer be paying"],[6904,7000,"for your private care."],[7150,7204,"From now on,"],[7204,7437,"Cal will be taking over all the costs."],[7479,7658,"Effective immediately."]],"57":[[391,554,"Where's Cal?"],[600,800,"He should be back by now."],[912,1079,"What did you do to him?"],[1287,1537,"I can't wait to show you."],[2362,2475,"My farmhands could"],[2475,2554,"move all these"],[2554,2625,"but Cal..."],[2629,2766,"Cal’s strong enough to do the work of"],[2766,2862,"ten men."],[2962,3062,"Cal, stop!"],[3062,3162,"Is it worth it?"],[3200,3337,"Mason’s punishing me and my mom"],[3362,3487,"for letting you inside last night."],[3562,3687,"I have to do this, Lily."],[3729,3850,"You don't understand."],[3887,4000,"Okay, the deal is-"],[4000,4150,"One more word about the deal"],[4212,4366,"and his mom dies."],[4412,4550,"And you’ll be all to blame."],[4550,4687,"Fine! Mason..."],[4750,4891,"But at least give him some water,"],[4891,5025,"this is insane."],[5087,5200,"Of course."],[5450,5675,"But you have to bring it to him."],[6491,6600,"Thank you, Lily."],[6775,6991,"This will all be over soon, I promise."],[7054,7187,"Keep watching, Lily."],[7262,7450,"This is the best part."],[7600,7687,"Cal?"],[7725,7800,"Cal!"]],"58":[[391,487,"Please!"],[525,637,"Mason, call your doctor,"],[637,787,"there's no time for an ambulance."],[787,1029,"Only if you leave Cal"],[1075,1187,"and marry me."],[1225,1312,"No!"],[1350,1437,"I'm not doing that."],[1437,1500,"I won't!"],[1516,1737,"Then Cal dies and it's on you."],[1812,1950,"Please don't make me do this."],[1950,2200,"I'm not making you do anything."],[2262,2341,"It's your choice."],[2387,2475,"Me or Cal."],[2550,2700,"Will you give everything back"],[2716,2912,"and finally leave him alone?"],[2950,3079,"I will leave enough"],[3125,3400,"for Cal, the farm and his mom."],[3525,3775,"But only after you marry me."],[4487,4729,"If you try to hurt him again,"],[4775,4987,"I swear I will expose you"],[4987,5237,"for the monster that you are."],[5287,5404,"Those are my terms."],[5437,5541,"Fine."],[5616,5804,"Any word about our little agreement"],[5850,6066,"and the deal is off."],[6325,6500,"Tick fucking tock, Lily."],[6562,6662,"Decide now"],[6662,6800,"or Cal dies!"],[6987,7050,"Alright."],[7516,7650,"Oh, this is fun."],[7691,7804,"You should try it some time."]],"59":[[225,425,"I'm so sorry, Cal."],[925,1025,"You're all clear, young man."],[1062,1204,"Just be more careful."],[1250,1312,"Thanks, doc."],[1337,1412,"Will do."],[1825,1916,"Hey."],[2412,2475,"Hey."],[2516,2600,"You okay?"],[2641,2712,"What's going on?"],[2712,2962,"Do I tell him I'm marrying Mason?"],[3016,3212,"Or lie for a little while"],[3212,3312,"to keep him happy?"],[3375,3445,"Cal, there's something"],[3445,3591,"I have to tell you."],[3591,3662,"You’re shaking."],[3662,3729,"What's wrong?"],[3775,4025,"Cal! You're up."],[4066,4225,"Have you talked to Lily yet?"],[4250,4316,"Talk about what?"],[4375,4487,"Tell him the truth, Lily."]],"60":[[29,187,"Leave, Mason."],[229,354,"I need to do this alone."],[354,466,"Ooooh."],[512,641,"I like this side of you."],[687,766,"I wonder if you fuck"],[766,850,"as well as you fight?"],[862,1037,"What the hell did you just say?"],[1150,1312,"Get out!"],[1512,1600,"What was he talking about?"],[1625,1800,"I have to marry Mason."],[1837,2062,"It's the price I paid to save you."],[2104,2350,"No, there has to be another way."],[2375,2575,"No, Cal, there isn't one."],[2675,2800,"There's always another way,"],[2800,2850,"sweetheart."],[2887,3004,"Even if you can't see it."],[3025,3175,"Mom, what are you doing here?"],[3200,3325,"I heard you were hurt."],[3366,3491,"I had to come see you, honey."],[3529,3675,"So this is the beautiful girl"],[3675,3779,"you told me about."],[3900,4075,"It's so nice to finally meet you."],[4075,4225,"And it is so nice"],[4225,4329,"to meet you."],[4387,4516,"I am so sorry you are"],[4516,4637,"seeing us like this."],[4641,4750,"What I see"],[4775,4925,"are two people in love"],[4925,5137,"and I raised Cal to fight for it."],[5250,5337,"I don't deserve you."],[5379,5512,"If I'm not willing to put everything"],[5512,5629,"on the line for us, Lily."],[5691,5816,"I'm going to face Mason."],[5862,5954,"Man to man."],[6000,6262,"One last fight. Winner takes all."]],"61":[[150,225,"Mason."],[362,491,"Let's settle this thing"],[537,625,"once and for all."],[687,800,"What do you have in mind?"],[837,1050,"One fight for everything."],[1091,1250,"I win..."],[1287,1412,"I get my farm back"],[1454,1562,"and Lily goes free."],[1654,1750,"If I lose..."],[1787,1904,"Lily and the farm are yours."],[2179,2337,"You have yourself a deal."],[3512,3637,"Come on, Mason."],[3650,3750,"That's it for round one."],[3825,4037,"Put up more of a fight next time."],[5116,5350,"Don't get cocky, brother."],[5800,5904,"Tap out, Mason!"],[5950,6016,"Tap out!"],[7141,7225,"You're going to pay for that,"],[7225,7325,"Foster."],[7387,7550,"I never lose."],[7775,7866,"I did that for you, Lily."]],"62":[[191,291,"Hey, Cal."],[337,404,"Think fast."],[404,462,"Ma’am..."],[462,562,"I'm going to need you to put your"],[562,712,"hands where I can see them."],[1025,1129,"Cal Foster"],[1129,1266,"don't you dare."],[2554,2637,"Come here."],[3125,3300,"Sorry to interrupt."],[3337,3441,"I just wanted to congratulate"],[3441,3512,"you both."],[3550,3612,"From now on"],[3700,3787,"you deserve whatever you are"],[3787,3875,"going to get."],[3875,3975,"I got Lily."],[4029,4150,"And I beat the hell out of you."],[4166,4354,"So you're right. I do."],[4400,4541,"Speaking of Lily,"],[4591,4737,"I'm going to take you out tonight,"],[4737,4862,"so bring your cowgirl boots."],[4900,5087,"That sounds fun, but..."],[5129,5216,"don't you think we should"],[5216,5379,"celebrate at home first?"],[6675,6800,"Boys,"],[6841,6975,"I need a favor."],[7112,7216,"Let's raise hell tonight."]],"63":[[229,325,"You're asking for trouble"],[325,416,"in that dress, Lily."],[429,679,"I could get used to your kind of trouble."],[1137,1241,"Show me what you got."],[1287,1537,"Well, don’t say I didn’t warn you."],[2129,2262,"Why don't you go get us some drinks"],[2262,2362,"so we can keep dancing?"],[2404,2537,"I'll be right back."],[2575,2754,"Don't go anywhere."],[3204,3312,"You look thirsty, sweetheart."],[3350,3400,"Don't worry,"],[3404,3550,"hubby’s got something special"],[3550,3654,"for you tonight."],[3700,3775,"Mason!"],[3825,3954,"A toast"],[3979,4100,"to you"],[4100,4212,"and Cal."],[4262,4329,"Now..."],[4362,4450,"be a good girl"],[4479,4604,"and open up for me."],[4604,4662,"Mason!"],[4837,4891,"Hey!"]],"64":[[800,1050,"You’re going to regret that, Foster."],[1316,1400,"Are you alright?"],[1441,1550,"Let’s get you back to my place."],[1562,1737,"No, we have to go to Mason’s."],[1737,1862,"Your mom isn’t safe there."],[1900,2062,"Then let's get there before he does."],[2912,3037,"Cal, what’s wrong?"],[3037,3200,"Mom, we have got to leave right now."],[3200,3325,"Honey, what’s happening?"],[3325,3437,"Mason and Cal fought"],[3437,3600,"and now Mason’s on his way over"],[3600,3662,"to retaliate."],[3662,3791,"Mason knows the best way to hurt"],[3791,3875,"me is to get you."],[3900,3991,"So we have got to leave."],[3991,4091,"Oh, what about the farm?"],[4137,4287,"You fought so hard for it, baby."],[4300,4429,"You deserve that land!"],[4429,4591,"I don't care about the farm"],[4591,4787,"if I'm going to lose you two."],[5066,5200,"Cal Foster."],[5237,5316,"You're under arrest."]],"65":[[0,125,"This must be a mistake, officer."],[125,237,"I didn't do anything."],[425,550,"You have the right to remain silent."],[562,679,"Get off my son!"],[962,1100,"You ran to the police?"],[1137,1237,"You are the one that"],[1237,1325,"should be arrested"],[1325,1391,"not Cal!"],[1412,1587,"Cal has no legal right"],[1587,1704,"to be on my property."],[1750,2000,"And he's going to jail for trespassing."],[2075,2212,"And when we put him in the station"],[2237,2391,"I'll have him thrown in prison for"],[2391,2479,"20 years."],[2525,2737,"And I will leave his mom to die."],[2741,3200,"Unless you marry me right now."],[3575,3725,"I won't tell you what to decide."],[3766,3887,"You're free to do what you want"],[3887,4016,"and love who you want."],[4104,4229,"But you're it for me."],[4275,4562,"You're my first and my last, Lily Holt."],[5150,5287,"Please don’t do this to him, Mason."],[5329,5625,"Make your choice, or Cal rots in prison."],[5791,5975,"Then yes."],[6150,6258,"I'll marry you."]],"66":[[475,612,"Fight all you want, Lily."],[650,862,"This is the end of the line."],[962,1175,"Stop staring, start celebrating."],[1216,1525,"Finally, my guest of honor arrives."],[1525,1612,"I brought him just for you."],[1637,1775,"Why is he still in handcuffs?"],[1816,1904,"Don’t worry..."],[1937,2054,"they’ll come off as soon as"],[2054,2154,"the wedding’s over."],[2200,2354,"No backing out now."],[2450,2637,"Hey, get to the part to where she's mine"],[2637,2700,"okay?"],[2737,2891,"Lily, do you take Mason to be"],[2891,3012,"your lawfully wedded husband?"],[3075,3125,"I-"],[3125,3200,"Don’t, Lily!"],[3237,3375,"That man's a liar."],[3637,3750,"Uncuff my son."],[3787,3987,"The only man guilty of trespassing"],[3987,4129,"is Mason."],[5425,5675,"Mason didn't inherit the estate."],[5787,5875,"I did."]],"67":[[4,154,"Where the hell did you get that?"],[200,287,"I thought I destroyed this"],[287,400,"with all of dad’s copies."],[416,479,"Not all."],[525,704,"I had one of Cal's old farmhands"],[704,875,"search the property for this."],[962,1237,"When I said I would never marry you."],[1425,1504,"I meant it."],[1550,1712,"Now that I have my girl back,"],[1862,2112,"it's time I put you in your damn place."],[3054,3229,"The estate is mine!"],[3337,3454,"And nobody"],[3454,3600,"is going to take it away from me."],[4579,4729,"I could ruin your life"],[4729,4950,"like you did mine."],[5137,5362,"We both could."],[5404,5537,"Then do it."],[5729,5829,"No."],[5937,6112,"Because we're not you."],[6229,6337,"Officer,"],[6466,6591,"get this man out of here."],[6637,6712,"Come on."],[6904,6954,"There’s a girl"],[6954,7125,"that I’ve been meaning to marry."],[7204,7304,"And this time..."],[7375,7508,"nobody is getting in my way."]],"68":[[387,600,"You are way too beautiful right now."],[716,925,"I don't know if I can get through this."],[962,1162,"We can get through this."],[1204,1341,"We can get through anything."],[1387,1500,"I don't know if getting married in"],[1500,1637,"an old barn is what you hoped for"],[1637,1750,"on your wedding day."],[1841,1979,"But you’re exactly what I hoped for"],[1979,2041,"on mine."],[2054,2179,"I’m amazed by you, Lily."],[2262,2329,"And I love you."],[2375,2529,"And I can't wait to love you"],[2529,2675,"for the rest of my life."],[2829,2875,"And I-"],[2887,3075,"Just shut up and kiss me already"],[3075,3183,"Cal Foster."]]}