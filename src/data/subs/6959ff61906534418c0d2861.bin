{"1":[[266,471,"He picked her up in a car beforehand,"],[471,546,"they did it in the car."],[546,625,"With a teacher?"],[625,688,"before they even—"],[688,813,"Oh, there she is!"],[1071,1280,"Everyone thinks I slept with my teacher"],[1280,1393,"to make Valedictorian,"],[1393,1539,"but it’s a stupid rumor that"],[1539,1659,"cost my Mom her job"],[1659,1797,"and me my reputation."],[1797,1972,"Teacher fucker."],[2615,2790,"Like my art project?"],[2790,2948,"I call it \"Ugly Inside,"],[2948,3094,"Ugly Outside.\""],[3244,3424,"Felix Barnes, my arch nemesis."],[3424,3536,"I should have known."],[3536,3611,"Tell me, when will you"],[3611,3741,"get bored of bullying me?"],[3741,3824,"You slept your way to the top"],[3824,4024,"of Camden Prep's academic pyramid."],[4079,4379,"I get you needed the scholarship..."],[4446,4579,"...but the whole sleeping with the"],[4579,4746,"teacher thing is a bit played out now."],[5075,5305,"I didn't."],[5305,5422,"You probably made up that rumor"],[5422,5605,"because you couldn't keep up with me."],[5780,5847,"You're so cute"],[5847,5935,"when you're angry."],[5935,6093,"You're ugly when you're an arse."],[6531,6690,"You know what your problem is?"],[7403,7586,"You think you can beat me."],[7586,7749,"But this is my school, Abbi Moore."],[8020,8237,"Kiss my ass, Felix Barnes."],[8270,8387,"I thought you only let the teachers"],[8387,8512,"do that."],[8717,8837,"Get out of my way."],[8837,9021,"I'm late for my new job."],[10139,10414,"Where are you? Dad said you’re taking me to therapy."],[10414,10518,"Shit!"],[11828,12070,"Oh my God, are you okay?"],[12070,12245,"Oh, it just looks like you grazed it."],[12245,12491,"Let's see, I have a plaster in my bag."],[12641,12716,"Bailey?"],[13204,13322,"There we go."],[13372,13583,"Oh my God! Watch out!"]],"2":[[1322,1388,"Felix."],[1451,1584,"You saved me."],[1668,1764,"It wasn't for you."],[1764,1885,"This is my little sister."],[1972,2143,"I don't care whether you live or die."],[2164,2260,"That's the nicest thing"],[2260,2344,"you've ever done for me and"],[2344,2506,"you're still being a bum about it."],[2756,2877,"Thank you."],[2877,2986,"It’s okay."],[2986,3182,"How did such a sweet little girl"],[3182,3357,"end up with such a"],[3357,3499,"horrible older brother?"],[3499,3691,"It's no point in talking to Bailey."],[3691,3770,"She hasn't spoken"],[3770,3862,"since our mum died."],[3903,4054,"That's okay, I understand."],[4054,4149,"My dad passed away"],[4149,4287,"a couple of years ago."],[4287,4404,"It kind of feels like a club"],[4404,4558,"that no one wants to be apart of."],[4821,4929,"Oh my boss is wondering"],[4929,5017,"where I am."],[5075,5234,"Will you be okay if I leave you with"],[5234,5392,"this big, scary man?"],[5409,5551,"Stop acting like a saint."],[5597,5676,"No one's buying it."],[6314,6443,"Why were you so mean?"],[6443,6523,"She's nice."],[6873,7023,"Yeah, maybe she is."],[7098,7203,"Let's go."],[7807,7937,"You must be the new live-in nanny."],[7962,8041,"Yes, sir."],[8041,8149,"I'm really sorry I'm late."],[8149,8270,"Well, you're lucky because"],[8270,8362,"children haven't returned home"],[8362,8450,"from school yet."],[8558,8708,"Otherwise you’d be fired."],[9067,9184,"You'll be nannying my daughter."],[9184,9280,"She's 11."],[9338,9605,"And my teenage troublemaking son."],[9605,9813,"I was only told about a little girl."],[9813,9943,"What do you mean, a teenage son?"],[9943,10085,"You'll be in charge of making sure"],[10085,10243,"my children are up for school."],[10276,10493,"Their homework is completed"],[10493,10673,"and they're fed a healthy dinner."],[10731,10852,"And if they misbehave?"],[10852,10931,"Punish them."],[10931,11123,"This says your son is 17."],[11123,11211,"How am I supposed to"],[11211,11298,"punish a boy that’s my age?"],[11298,11386,"The agency said you're the best"],[11386,11507,"in your class."],[11507,11594,"Figure it out."],[11594,11770,"I need this job."],[11770,11895,"If this kid is such a loser"],[11895,12028,"he needs a nanny to feed him"],[12028,12170,"and help him with his homework,"],[12170,12308,"how bad could he be?"],[12308,12416,"Bailey and I are home."],[12691,12821,"What are you doing here?"],[12821,13013,"Son, meet your new nanny."],[13063,13163,"Oh god."],[13163,13359,"I was just hired as my bully’s nanny."]],"3":[[33,116,"I'm really sorry"],[116,237,"but I can't work for you."],[237,375,"You're contracted by the nannying agency"],[375,638,"agency to take any job they see fit"],[638,788,"to put you forward for."],[788,871,"I know, but I'm."],[871,1001,"I'm really sorry but I can't."],[1001,1151,"If you walk away now"],[1151,1251,"I'll make sure you never"],[1251,1368,"get another job again."],[1368,1484,"Dad, I know that I was late"],[1484,1618,"picking Bailey up a couple of times"],[1618,1780,"but we do not need a nanny."],[1780,2043,"Don't try to bargain with me, Felix."],[2043,2198,"You've made a right mess of yourself."],[2198,2364,"You've got a bad attitude."],[2364,2544,"You're sleeping in late"],[2544,2715,"and your grades are dropping."],[2715,2873,"And since your mum isn't around"],[2873,3015,"to keep you in line"],[3015,3144,"I've got you the next best thing."],[3190,3286,"Bailey's on board."],[3286,3374,"Are you going to get in line?"],[3374,3511,"Or shall I take back the key"],[3511,3645,"to your fancy sports car?"],[3645,3778,"Fine."],[3778,3908,"Don't blame me when she quits."],[3908,4054,"You already know I'm not a quitter."],[4120,4312,"Show her to the guestroom."],[4312,4408,"The agency have already"],[4408,4504,"dropped off her belongings."],[4662,4850,"Look I know the situation is weird"],[4850,4942,"but, I’ll stay out of your way."],[4942,5021,"If you stay out of mine."],[5376,5492,"Look."],[5492,5626,"I want you out of my school"],[5626,5826,"out of my house, and out of my life."],[5864,5980,"And I'm going to make your life"],[5980,6118,"a living hell until you quit."],[6239,6360,"Fine."],[6423,6589,"I'll make yours ten times worse."],[6589,6715,"Your dad gave me full permission to punish me."],[6715,6785,"to punish you."],[6977,7119,"Bring it on."]],"4":[[1730,1901,"Felix may bully me in school,"],[1901,2031,"but as his live-in nanny,"],[2031,2243,"I'm in charge at home."],[2243,2310,"Wakey, wakey!"],[2310,2610,"Eggs and bakey!"],[2756,2882,"What the fuck?"],[3132,3253,"Language."],[3253,3482,"You don't want another punishment, do you?"],[5413,5455,"You know,"],[5455,5609,"if you wanted to get me wet"],[5609,5739,"there’s better ways to do that."],[5864,5926,"Dry off."],[5926,6118,"You have homework to do."],[6164,6235,"No."],[6318,6460,"I'm going to the beach, Nanny."],[6510,6614,"I don't think so."],[7882,8183,"You’ll go once you do your work."],[8550,8604,"Good job."],[8604,8717,"You only got a couple wrong"],[8717,8800,"this time."],[8829,9021,"Study these ones next time"],[9021,9129,"so you get them right."],[9171,9267,"I'm finished, too."],[9555,9622,"What the hell."],[9622,9713,"You're marking it up more than"],[9713,9788,"the teachers do."],[9788,9934,"Your dad expects your grades to go"],[9934,10080,"up under my supervision."],[10101,10201,"So no subpar work."],[10689,10906,"Well, I don't take notes from a slag."],[11023,11161,"You are so immature."],[11161,11323,"Oh no."],[11382,11544,"Does my nanny need to punish me?"],[11544,11678,"Do you think I won't?"],[11678,11811,"What are you going to do,"],[11916,12082,"spank me?"],[12153,12249,"Ground me?"],[12249,12441,"I'd like to see you try."],[12729,12887,"I have just the punishment for you."]],"5":[[133,275,"Time to feast."],[546,658,"What the fuck?"],[1309,1463,"Dad, where’s my door?"],[1843,1935,"You."],[2160,2264,"Come on, RetroFit."],[2264,2406,"We've got them cornered."],[2406,2519,"Let's win this match."],[2944,3107,"What the hell? I was about to win."],[3816,3903,"We need to talk."],[3903,4041,"Whatever you have to say to me"],[4041,4162,"you can say in front of Bailey."],[4162,4229,"Oh really?"],[4229,4333,"Okay, cool well"],[4333,4491,"I was going to say that the rumors"],[4491,4617,"about you and the teachers."],[4617,4779,"You know. I do just really think."],[4867,4988,"Okay fine, we can talk."],[5530,5689,"You have five minutes."],[5776,5955,"You're kind of scary, you know that?"],[5976,6131,"Me? You’re the one that's been torturing"],[6131,6243,"me in school all year."],[6264,6335,"No, no no."],[6752,6861,"After today, I’ve realized"],[6861,6965,"that was child's play."],[7015,7094,"You."],[7111,7228,"You’re an evil genius."],[7298,7520,"You did tell me to punish you."],[7624,7691,"Is this what you wanted"],[7691,7761,"to talk to me about?"],[7807,7920,"Are you finally ready to take"],[7920,8037,"me seriously as your nanny?"],[8074,8124,"No."],[8237,8358,"I will never take you seriously"],[8358,8483,"as my nanny."],[8541,8746,"But, I do want to make a deal."]],"6":[[100,212,"What kind of deal?"],[212,333,"The kind where"],[333,513,"I stay out of your way."],[734,892,"So you're free to nanny Bailey."],[892,1051,"And I won't cause any problems."],[1272,1505,"And in return, you stay out of my way"],[1614,1680,"and tell my dad"],[1680,1843,"I've been a good little boy."],[2118,2356,"And, why would I agree to that?"],[2356,2489,"Because if you don't"],[2489,2577,"when I tell my dad"],[2577,2706,"I've got the hots for my nanny."],[2781,2952,"You'll be out on your ass by dinner."],[3065,3169,"Okay."],[3244,3328,"But this only works"],[3328,3457,"if you actually behave."],[3478,3582,"Don't skip school"],[3582,3682,"and don't let your grades drop."],[3682,3816,"I'll behave."],[3883,3953,"Scout's honor."],[4391,4646,"But first, some ground rules."],[4646,4746,"Fair enough."],[4746,4842,"What are they?"],[4842,5034,"Rule one, you already agreed to."],[5096,5205,"You won't be my nanny in name"],[5205,5305,"or action."],[5305,5467,"Only if you behave."],[5467,5526,"If your dad thinks"],[5526,5609,"I'm not doing my job."],[5609,5734,"Uh yeah, don't worry about that."],[5734,5830,"Okay?"],[5830,5914,"Rule two."],[5947,6106,"No one at school finds out"],[6106,6197,"that you're my nanny"],[6197,6356,"or that you live in my house."],[6356,6519,"Deal."],[6519,6664,"I have a rule too."],[6727,6852,"Stop bullying me in school."],[6994,7157,"I'll try to control myself."],[7228,7311,"Though I've not been very good"],[7311,7403,"at that around you."],[7565,7691,"What are you doing?"],[7707,7816,"Sealing our deal."],[7895,7966,"With a kiss."]],"7":[[112,258,"Are you kidding?"],[258,392,"We hate each other."],[417,504,"Guess we'll have to do it"],[504,621,"the old fashioned way then."],[2214,2327,"Wait in the car, yeah?"],[2327,2398,"I don't want anyone"],[2398,2469,"knowing we’re together."],[2544,2644,"Fine."],[2773,2890,"Oh! Bailey's lunchbox."],[2890,2957,"We need to go–"],[2957,3069,"I don't care."],[3136,3282,"Maybe I can have a delivery service"],[3282,3411,"take this to her."],[3807,4033,"Still showing your face at school."],[4033,4179,"Haven't you got the message?"],[4179,4325,"What? That you hate me?"],[4325,4433,"I think that’s pretty clear."],[4504,4688,"Then I guess using words"],[4688,4796,"isn't enough."],[4821,4888,"Aw, are you going to"],[4888,5005,"pour your drink on me?"],[5005,5113,"How original."],[5113,5280,"You already look chuffed."],[5280,5355,"Dumping this on"],[5355,5492,"you won't make a difference."],[5584,5855,"I know the right way to hurt a desperate"],[5855,5997,"try hard like you."],[6160,6277,"Don't we have a history essay"],[6277,6352,"due today?"],[6352,6481,"No, I spent two weeks on that."],[6481,6585,"Too bad I don't care."],[6765,6806,"Felix!"],[6806,6877,"Stop them!"]],"8":[[0,171,"Felix! Stop them!"],[171,354,"Did you just ask Felix for help?"],[354,538,"Don't tell me this pick me is throwing"],[538,679,"herself at you now."],[679,921,"If I stop Skye, she'll just go after Abbi"],[921,1013,"even harder."],[1013,1142,"Next time you want to say my name,"],[1142,1284,"take me to the bedroom first."],[2773,2944,"See you in class,"],[2944,3148,"bottom feeder."],[3749,3878,"What happened to our deal?"],[3878,4116,"I promised I wouldn't bully you."],[4116,4216,"I didn't say I’d promise"],[4216,4337,"to protect you from other bullies."],[4337,4416,"Yeah, but why are they"],[4416,4504,"bullying me Felix?"],[4504,4646,"Because you started it."],[4646,4779,"They're just following your lead."],[4779,4850,"Abbi, wait!"],[4850,4975,"No."],[4975,5080,"Our deal’s off."],[5638,5734,"The delivery guy"],[5734,5918,"said he'd meet me here."],[6493,6798,"Oh my God. What is that?"],[7044,7173,"Damn, I knew she was a freak"],[7173,7332,"but I didn’t realise she was that kinky."],[7332,7390,"Jack!"],[7515,7620,"What do you reckon she's got in there?"],[7620,7711,"Sex toys?"],[7816,7882,"Hey!"],[7882,7962,"Jack, shut the..."],[7962,8070,"Come over here, baby."],[8070,8229,"Show me what's in that lunch box."],[8708,8871,"Felix, you left your lunch at home."],[8871,8979,"What the hell?"],[8996,9117,"That's not Felix's."],[9117,9213,"Yes it is."],[9213,9376,"See? Felix"],[9376,9476,"Barnes."],[9509,9788,"Abbi. Fucking. Moore."]],"9":[[200,279,"Why is your last name on"],[279,404,"that lunch box Felix?"],[404,567,"I'm not the only one with that last name."],[567,754,"Why do you look so nervous, man?"],[754,867,"Is that actually yours?"],[930,996,"It's not."],[996,1088,"It's not mine. It's–"],[1088,1242,"Pick up for"],[1242,1359,"Bailey Barnes?"],[1359,1493,"Yes, thank you."],[1493,1647,"Bailey Barnes?"],[1647,1810,"Isn't that your little sister?"],[1876,2014,"Why does scholarship slut"],[2014,2077,"have it?"],[2077,2256,"I'm actually the nanny for Bailey"],[2398,2540,"and Felix."],[2915,2990,"No."],[3115,3336,"Are you secretly a little baby?"],[3461,3524,"Do you need me to change"],[3524,3578,"your diaper?"],[3578,3636,"You want me to"],[3636,3799,"ooh little bubba."],[3799,3945,"Do you need a goodgie goodgie goodgie?"],[3945,4079,"That's enough. Okay."],[4079,4212,"And you're not my nanny."],[4346,4529,"No, get off me. Get off me."],[4633,4817,"How dare you carry me like that?"],[4817,4913,"How dare you tell everyone"],[4913,4996,"that you're my nanny?"],[4996,5150,"Our deal included you not bullying me"],[5150,5230,"in school, remember?"],[5230,5367,"Yeah, I didn't. My friends did."],[5367,5463,"Yeah. Your friends."],[5463,5543,"One word from you"],[5543,5613,"and they would have stopped."],[5613,5718,"But you didn’t."],[5751,5939,"I can't control other people."],[5980,6076,"Funny, I seem to remember"],[6076,6172,"you trying to control me"],[6172,6277,"when I became your nanny."],[6277,6385,"So what? That's just it, then."],[6385,6573,"Not even one day and our deal's off."],[6573,6723,"You drive me crazy."],[6723,6831,"The feeling's mutual."],[6831,6969,"Look, I'll see you at home."],[6969,7123,"Where you’ll have a list of chores to do."],[7257,7490,"I can't have you as my nanny anymore."],[7490,7561,"Time to get you"],[7561,7716,"out of my house for good."],[7941,8028,"Listen up."],[8028,8179,"End of the world pool party"],[8179,8329,"tonight at House Barnes."],[8329,8475,"Bring the chaos, we’re partying"],[8475,8604,"till the sun rises."]],"10":[[2665,2965,"Oh, here she is."],[2994,3274,"What the hell is this?"],[3274,3486,"First annual Felix Barnes end of the"],[3486,3603,"world party!"],[3858,3958,"Shut it down now."],[4037,4250,"Or what?"],[4250,4383,"I'll call your dad."],[4383,4487,"Call him"],[4487,4637,"and tell him you have no control"],[4637,4683,"over me."],[4704,4779,"And he'll drop"],[4779,4921,"you as my nanny like that."],[5509,5580,"Do you not care"],[5580,5759,"that this is scaring your sister?"],[5759,5839,"You’re the nanny."],[5839,6139,"It's your job to take care of her."],[6648,6823,"Oh, Bailey."],[6823,6923,"It's okay."],[6923,7077,"I'm going to go get rid of everyone."],[7077,7378,"You stay here and try to rest."],[8425,8600,"Abbi!"],[8600,8708,"I’d offer you a beer,"],[8708,8825,"but you're on the clock."],[8825,8992,"You’re getting absolutely pissed."],[8992,9171,"And what if your dad sees?"],[9171,9346,"He’d probably fire the"],[9346,9421,"irresponsible nanny?"],[9488,9584,"Bailey is scared."],[9584,9713,"Your house is getting trashed."],[9713,9797,"And your dad is going to be home"],[9797,9864,"early in the morning,"],[9864,9993,"so please shut this down."],[10093,10310,"Quit the job, and the party ends."]],"11":[[141,392,"You want this party to end?"],[392,613,"Easy, you just got to say two words."],[613,771,"I quit."],[771,900,"How about these two words?"],[900,1055,"Fuck off."],[1055,1222,"Why do I think she's hot"],[1222,1334,"even when she's telling me"],[1334,1418,"to fuck off?"],[1459,1564,"I should hate her."],[1651,1747,"Anyways,"],[1747,2039,"I'm going to go enjoy my party."],[2039,2210,"And when you’re ready to quit."],[2210,2314,"Come find me to learn."],[2348,2464,"Till then"],[2464,2623,"leave me the fuck alone."],[2623,2827,"I don’t want you to kill my vibe."],[2994,3148,"Yo, Skye."],[3148,3265,"Want to come play strip poker"],[3265,3370,"with the lads?"],[3370,3507,"I'm busy, Jack."],[3595,3732,"Why is Abbi Moore here?"],[3732,3920,"She has to know everyone hates her."],[3920,4112,"Maybe she's trying to get with Felix."],[4112,4279,"This is a party for the most popular"],[4279,4412,"people at school."],[4425,4587,"Clearly, she's forgotten her"],[4587,4725,"place at Camden"],[4821,4996,"Lets go remind her."],[5130,5359,"Hey Abbi,"],[5359,5605,"what are you doing at Felix's party?"],[5605,5730,"Trying to give all the guys"],[5730,5868,"erectile dysfunction."],[5868,5968,"Harsh Skye."],[6022,6147,"I'd still fuck her."],[6202,6310,"Just put a bag on her head."],[6452,6594,"You'd fuck anything Jack."],[6631,6760,"Look see your insults"],[6760,6906,"don't bother me any more"],[6906,7061,"because I know you're just insecure."],[7069,7269,"See, you're trying so hard and Felix"],[7269,7415,"still hasn't noticed you."],[7528,7670,"What did you just say?"],[7670,7916,"I'm just saying it must be hard