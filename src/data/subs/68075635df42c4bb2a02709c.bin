{"1":[[104,233,"Congratulations!"],[233,433,"To our social media manager"],[433,754,"for getting ten million followers."],[788,1017,"Finally, I can ask for a promotion."],[1384,1493,"Olivia."],[1493,1593,"I just wanted to let you know"],[1593,1797,"that we’ve crossed 10 million followers."],[1847,1985,"Wow that's great."],[2143,2239,"Come here."],[2594,2711,"Come here."],[3190,3286,"Seem a little tense."],[3286,3520,"Why is he so touchy?"],[3520,3712,"Ten million followers huh?"],[3712,3803,"Creep."],[3803,3949,"You know, when I first hired you,"],[3949,3999,"I knew you're going to"],[3999,4095,"make this business"],[4095,4250,"a little prettier."],[4283,4404,"You..."],[4550,4683,"and your skirts."],[4683,4750,"Mr. Payne!"],[5067,5184,"Olivia..."],[5184,5409,"come here."],[5409,5488,"I just need to know"],[5488,5555,"that you're committed"],[5555,5663,"to this company."],[5768,5901,"Why don't you"],[5901,6022,"open up to me?"],[6022,6101,"Mr. Payne!"],[6101,6281,"Stop it!"],[6281,6381,"What are you doing"],[6381,6489,"with my boyfriend"],[6489,6602,"you whore?"],[6706,6794,"Isn't that Camila Green,"],[6794,6902,"the influencer?"],[6927,7048,"I didn't do anything."],[7048,7157,"He was- - Don't you dare"],[7157,7298,"try to put this on, Mason."],[7298,7390,"He told me you've been"],[7390,7528,"angling for a promotion."],[7528,7624,"So what?"],[7624,7899,"You thought you'd seduce him to get it?"],[7899,8099,"Oh, of course not. - Mason,"],[8099,8291,"either you fire the slut,"],[8291,8408,"or I’m going live to tell"],[8408,8558,"my millions of followers"],[8558,8712,"to boycott LP skincare."],[8942,9054,"You're fired!"],[9054,9129,"Go!"],[9530,9738,"I want you to have fun tonight,"],[9738,9880,"so all your drinks"],[9880,9972,"are on me and my"],[9972,10064,"bartender boyfriend."],[10235,10397,"All of these bosses are assholes,"],[10397,10560,"they should never be trusted."],[11461,11632,"I need to have some fun tonight."],[11632,11711,"Oh my gosh."],[11711,11836,"I'm s