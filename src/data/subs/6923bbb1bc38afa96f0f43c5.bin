"],[3232,3470,"You know, just to keep up the show."],[3632,3741,"I saved up to get you that."],[3928,4175,"And I know the rings aren't great."],[4191,4304,"You have expensive taste."],[4304,4425,"So if you really hate them,"],[4425,4496,"we can always-"],[7536,7636,"The gift is perfect."],[7987,8087,"And so are the rings."],[9109,9267,"Why did you kiss me all of a sudden?"],[9559,9634,"Why do you think?"],[9805,9922,"I thought you said our marriage"],[9922,10018,"was just for show."],[10105,10297,"What if I want it to be real?"]],"16":[[291,358,"Sorry."],[1447,1514,"What's wrong?"],[1543,1659,"It's just my friend."],[1722,1843,"She's at this big frat party and"],[1843,1947,"she really needs me."],[1981,2089,"It's a girl emergency."],[2147,2214,"I'll drive you."],[2460,2581,"After I put on a shirt."],[2686,2877,"I think the shirt can stay off."],[4421,4504,"Thanks for the ride."],[4529,4621,"I can get an Uber back."],[4692,4779,"I can wait for you."],[4850,4934,"Or I can come with."],[4934,4996,"You need help?"],[4996,5063,"Oh, no."],[5063,5134,"No, no, no."],[5134,5205,"I don't know how long"],[5205,5284,"this is gonna take"],[5284,5359,"and I've already taken"],[5359,5455,"so much of your time."],[5492,5605,"I'll be fine, I promise."],[5747,5784,"Okay."],[6293,6385,"Is there someone here"],[6385,6519,"she doesn't want me to see?"],[8742,8863,"I thought you two were broken up?"],[9205,9346,"We got back together."],[9471,9555,"I owe you one."],[9705,9818,"Lord have mercy."],[10318,10393,"Excuse you."],[10393,10539,"You're not going anywhere."]],"17":[[108,216,"You came here to find me?"],[216,342,"No, I came here to find Kayla."],[342,437,"Now let go of me."],[437,525,"Hi."],[729,855,"Why are you even bothering me"],[855,959,"when you came here with her?"],[959,1055,"Yeah, Mia, can't you see"],[1055,1180,"Aiden is busy?"],[1201,1301,"We're on a date."],[1501,1589,"I wouldn't call hooking up"],[1589,1701,"at a frat house a date."],[1710,1805,"Alright, that's enough, M