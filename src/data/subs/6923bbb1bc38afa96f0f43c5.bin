],[2385,2485,"Right this way, ma'am."],[3090,3203,"Oh my god."],[4024,4104,"Carson?"],[4237,4283,"Mia."],[5096,5167,"You made it."],[5288,5372,"It was the only way to get you"],[5372,5442,"to talk to me."]],"38":[[54,158,"You were the one"],[158,254,"who sent me the message"],[254,350,"from Kayla's phone?"],[371,467,"Please don't be mad-"],[467,554,"Where is she?"],[575,679,"I, I, I sent that text"],[679,775,"cause I knew it's the only way"],[775,867,"I could talk to you."],[900,934,"And,"],[980,1051,"Kayla's fine."],[1163,1242,"I'm leaving."],[1305,1413,"Mia, wait."],[1584,1739,"I want to make up for your birthday."],[1868,1981,"I want to do this right."],[2068,2202,"I know you're still mad, but"],[2260,2348,"look around."],[2665,2773,"It's the romantic proposal"],[2773,2882,"you always wanted."],[2990,3165,"We are broken up, Aiden."],[3182,3315,"That doesn't matter anymore!"],[3574,3687,"Please, Mia."],[3732,3899,"Give me one last chance"],[3995,4162,"to love you the way you deserve."],[4354,4596,"Aiden has never been like this before."],[5075,5130,"Okay."],[5442,5572,"I accept your apology."],[5705,5801,"And I think we should just put"],[5801,5926,"all of this behind us."],[6081,6151,"But let me be"],[6197,6272,"very clear."],[6385,6544,"I do not love you anymore."],[6831,6986,"So there's nothing to go back to."],[7036,7073,"Okay?"]],"39":[[5046,5130,"Hello?"],[5188,5263,"That's weird."],[5263,5363,"Carson said he was gonna"],[5363,5467,"be home early today."],[5947,6043,"Hey Joey, what's up?"],[6089,6143,"Ma'am!"],[6181,6364,"Mr. Moretti has been in a car accident."],[6368,6514,"He's at the hospital right now."],[6519,6594,"Oh my God."],[6652,6769,"Okay, I'm on my way."]],"40":[[521,638,"I'm looking for my husband,"],[638,700,"Carson Moretti."],[700,738,"Where is he?"],[738,796,"Is he okay?"],[892,959,"He's fine."],[959,1088,"There was a pileup on the highway"],[1088,1213,"but it was mostly minor injuries"],[1213,1326,"for everyone involved."],[1326,1484,"He should be right down the hall."],[1484,1551,"Thank you."],[2181,2277,"Jason must have told Mia"],[2277,2377,"about my accident."],[2398,2469,"And she came running"],[2469,2556,"straight here."],[2815,2911,"She still loves me."],[2973,3094,"Don't worry, Mia, I'm fine."],[3094,3169,"It's just a-"],[4475,4533,"Carson."],[4813,4954,"Carson, are you okay?"],[5063,5121,"I'm fine."],[5672,5876,"What the hell are you two doing?"]],"41":[[87,250,"So you don't love me anymore,"],[250,433,"but now you're gonna love that loser?"],[442,538,"He's not a loser."],[538,646,"He's my husband."],[654,850,"What does he have that I don't have?"],[863,1034,"I'm young, I'm rich."],[1034,1146,"I can give anything you want"],[1146,1222,"in this world."],[1222,1363,"None of that matters, Aiden,"],[1363,1514,"when I don't love you anymore."],[1651,1797,"I don't want anything from you."],[1968,2043,"You see this?"],[2131,2223,"We're married."],[2273,2394,"Go take a hike."],[2840,3019,"Get your hand off her!"],[3211,3328,"You think this is funny?"],[3424,3603,"You think this shit's funny, Mia?"],[3699,3912,"We were together for three years,"],[4016,4120,"and now you decide to run off"],[4120,4262,"and cheat with this rando."]],"42":[[16,100,"And now you decided to run off"],[100,212,"and cheat with this rando?"],[275,450,"Watch your mouth, you little shit."],[508,600,"I might be in this chair,"],[600,667,"but that won't stop me"],[667,825,"from putting you in a casket."],[855,930,"Hey, come on, Carson."],[930,1063,"Let's not waste our breath on him."],[1146,1288,"No, we're not done here!"],[1313,1480,"Tantrum time is over."],[1568,1659,"Step aside."],[1730,1864,"How dare you speak to me?"],[1901,2035,"You're just a nobody's side-piece."],[2035,2185,"What are you calling a side-piece?"],[2727,2911,"Don't disrespect my husband."],[2965,3103,"And I didn't cheat on you."],[3111,3244,"I asked Carson to marry me"],[3244,3370,"after I broke up with you."],[3395,3524,"I don't believe you."],[3553,3666,"We 