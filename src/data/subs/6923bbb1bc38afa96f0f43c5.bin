ow."],[6206,6302,"Get out of here!"],[6698,6752,"Mia."],[6752,6902,"It's Mrs. Moretti now."],[6927,7090,"I'm doing this for your own good, Mia!"],[7111,7203,"How can you be with a man"],[7203,7323,"like Carson Moretti?"],[7323,7449,"He's a criminal!"],[7461,7561,"A murderer!"]],"54":[[0,108,"He's a criminal!"],[129,258,"A murderer!"],[1822,2027,"Everyone loves to judge Carson,"],[2043,2152,"but he's no criminal."],[2185,2306,"He's the man that turned the"],[2306,2448,"Moretti family around."],[2481,2652,"He's stronger, braver,"],[2652,2836,"and more of a man than you'll ever be."],[2961,3040,"He loves me."],[3061,3148,"He protects me."],[3186,3332,"He makes me feel seen and heard,"],[3332,3465,"which is more than what you've done!"],[4012,4145,"Mia, wait!"],[4229,4362,"I'll take it you took care of him?"],[4371,4458,"Of course."],[4458,4542,"It's like squashing"],[4542,4683,"an annoying little bug."],[4750,4854,"Let's get out of here."],[5980,6081,"Mia, wait!"],[6364,6448,"Mia, please!"],[6448,6619,"Please don't fucking leave me!"],[6744,6827,"Don't go!"],[6865,6965,"Don't leave me here!"],[6965,7098,"Please, Mia!"],[7098,7207,"Come back!"]],"55":[[608,654,"Dude,"],[867,1009,"you're taking this whole Mia thing"],[1009,1096,"way too far."],[1163,1222,"No."],[1251,1388,"I haven't taken it far enough."],[1651,1772,"Her wedding's today."],[2077,2147,"It's over."],[2273,2318,"What?"],[2481,2569,"I have to go stop him."],[2610,2819,"Yo, what the hell are you doing?"],[2848,3019,"Just relax."],[3203,3307,"This is my last chance"],[3307,3420,"to get Mia back,"],[3474,3595,"I have to try."]],"56":[[367,504,"Now, before we conclude"],[504,621,"today's ceremony"],[621,829,"and send this happy couple off"],[829,955,"into the sunset."],[984,1105,"I must ask,"],[1130,1384,"does anyone here have reason why"],[1384,1555,"these two should not be joined"],[1555,1685,"in holy matrimony?"],[1801,2047,"Speak now or forever hold your peace."],[2344,2414,"I do!"],[2786,2869,"Please, Mia,"],[2919,3023,"don't do this."],[3073,3169,"You don't love him."],[3465,3586,"Oh God."],[3586,3766,"This is so cringe."],[3766,3887,"I know, I can't watch."],[3887,3966,"Aiden, can you save"],[3966,4154,"whatever dignity you have left and go?"],[4312,4479,"No, no, no."],[4529,4596,"This all happened"],[4596,4746,"because I left you on your birthday."],[4917,5038,"But that was one mistake."],[5159,5271,"And I can change."],[5501,5618,"Please take me back."]],"57":[[654,721,"Guards!"],[1017,1080,"No!"],[1368,1534,"Get the fuck away from me!"],[1914,2010,"You're ruining my"],[2010,2135,"best friend's wedding!"],[2135,2223,"What's wrong with you?"],[2223,2302,"I told you!"],[2348,2477,"I told all of you!"],[2515,2619,"I want Mia."],[2811,2927,"And if I can't have you,"],[3670,3816,"I'm gonna kill myself."]],"58":[[87,212,"If I can't have you, Mia,"],[212,387,"there's no reason for me to live."],[425,550,"Take me back."],[550,667,"You can stop this."],[875,975,"What makes you think I care"],[975,1092,"what happens to you?"],[1092,1213,"Don't lie to yourself."],[1213,1276,"Of course."],[1276,1376,"Of course you love me."],[1376,1539,"I can see it in the way you look at me."],[1793,1931,"Don't make me do this, Mia."],[2506,2602,"If you leave,"],[2615,2740,"I will break up with you."],[2777,2831,"No."],[3028,3123,"No, you won't."],[3232,3336,"If you're gonna kill yourself,"],[3336,3445,"can you do it somewhere else?"],[3445,3507,"What?"],[3528,3661,"Look, you heard me, okay?"],[3716,3841,"This is my wedding day."],[3841,3995,"I'm happy, Aiden."],[3995,4124,"You can't ruin this!"],[4124,4371,"So if you wanna die, then go ahead."],[4408,4483,"I can't bring myself"],[4483,4583,"to give a shit anymore."],[5192,5296,"I blew it."],[5351,5497,"I had the girl of my dreams"],[5497,5609,"and I blew it."]],"59":[[221,316,"Take him to his father."],[425,613,"Show Senator Scott what a son he raised."],[721,829,"Wait, no!"],[896,1076,"Wait, not my dad, please!"],[1209,1409,"Alright, alright everyone!"],[1443,1547,"Now that we've taken care of"],[1547,1722,"that little interruption,"],[1755,2010,"let's get back to what really matters."],[2072,2218,"Mia, Carson,"],[2218,2419,"by the power vested in me,"],[2419,2740,"I now pronounce you husband and wife."],[2831,3019,"Carson, you may kiss your bride."]],"60":[[950,1046,"I'll bring this out, boss."],[1159,1292,"Not the boss anymore, Joey."],[1551,1605,"Mia is."],[1689,1797,"Yes, Chef Carson."],[2139,2206,"Coward."],[2214,2306,"Stupid!"],[2506,2585,"Stop that,"],[2585,2648,"please."],[2677,2752,"Mia."],[2786,2848,"No, no."],[2848,2969,"Please, please don't kill me."],[3011,3094,"Please don't."],[3182,3261,"Please..."],[3365,3470,"please don't kill me."],[3649,3716,"No."],[4058,4191,"Listen, you little shit."],[4212,4291,"I don't care about your"],[4291,4408,"fucking Miami rules,"],[4408,4633,"but here in LA, on the Moretti turf,"],[4679,4838,"we have a zero drugs policy."],[4863,5067,"So if I catch you moving dope, fent,"],[5084,5221,"or even a fucking cough drop"],[5221,5321,"on my turf again,"],[5388,5534,"I'll put a bullet through your skull."],[5593,5680,"Do you understand me?"],[5734,5876,"Yes, I'm so sorry, ma'am."],[5876,6018,"It'll never happen again!"],[6018,6147,"Now get the fuck out of my face."],[6147,6252,"You're ruining date night."],[7374,7449,"You're so sexy"],[7449,7561,"when you're holding a gun,"],[7561,7632,"you know that?"],[7695,7878,"And you look so sexy in this outfit."],[7957,8141,"Can't wait to take it off of you."]]}