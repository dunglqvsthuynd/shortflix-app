arson?"],[2635,2761,"Carson, are you okay?"]],"46":[[4,108,"Carson, are you okay?"],[225,358,"I, I'm just a little lightheaded."],[404,454,"Okay."],[479,583,"Here, let's lay back down."],[658,754,"There we go."],[1159,1276,"What did you do to him?"],[1422,1530,"When are you gonna leave us alone?"],[1530,1626,"What?"],[1685,1764,"He's faking!"],[1764,1901,"He's the one who knocked me down!"],[1931,2114,"Why are you even in his room?"],[2164,2235,"If he pushed you down,"],[2235,2377,"it was probably for a good reason."],[2410,2515,"Besides, if I saw you"],[2515,2606,"put a hand on my husband,"],[2606,2702,"I would've knocked you off"],[2702,2811,"your crutches myself."],[2827,2915,"Are you serious, Mia?"],[2965,3028,"You really don't care"],[3028,3148,"if I'm in pain or not?"],[3332,3465,"If you're looking for sympathy,"],[3536,3620,"go find your mommy."],[3745,3866,"Mia's not here for you."],[4079,4162,"You're not the victim here."],[4162,4241,"I am!"],[4546,4612,"Aiden!"],[4642,4758,"What happened?"]],"47":[[54,237,"Mia, what is wrong with you?"],[237,375,"Obviously, he needs help"],[375,483,"but you're just standing there"],[483,579,"ignoring him?"],[713,796,"I got this."],[1280,1330,"Nurse?"],[1330,1455,"Can you come in here, please?"],[1701,1793,"I need these people"],[1793,1981,"out of my husband's room immediately."],[1981,2102,"He needs his rest."],[2164,2223,"Yes, ma'am."],[2235,2298,"Thank you."],[2469,2519,"What?"],[2602,2715,"Get the fuck off me!"],[2765,2886,"I can stand on my own."],[4850,4934,"No offense, but"],[4942,5067,"you're a terrible actor."],[5355,5438,"Fuck you."]],"48":[[91,145,"Jessica,"],[183,321,"stop showing up"],[321,442,"when I'm around Mia."],[525,671,"You're ruining everything."],[671,800,"Okay well, I'm sorry."],[800,938,"But I heard about the accident"],[938,1101,"so I wanted to come in and check on you."],[1101,1142,"Get out!"],[1142,1276,"I know you need somebody"],[1276,1380,"here to take care of you."],[1380,1493,"Just let me stay."],[2093,2185,"Actually Jessica,"],[2510,2602,"I change my mind."],[3215,3390,"You're the most annoying woman"],[3390,3503,"I've ever met."],[3507,3745,"Stop showing up in front of me, period!"],[3778,3899,"I never wanna see your face again."],[3908,4049,"But I love you."],[4049,4291,"Mia is the only person I love."],[4491,4617,"If you come near me again,"],[4625,4692,"I'm gonna take back"],[4692,4838,"everything I ever bought you."],[4871,4963,"I'm gonna get you kicked off"],[4963,5055,"the cheer team."],[5055,5267,"You'll be canceled, do you understand?"],[5305,5455,"Now get the fuck out!"]],"49":[[800,967,"Dude, I've got the proof."],[1080,1226,"Mia's marriage is real."],[1276,1359,"Give me that."],[1760,1889,"She's seriously married to that"],[1889,2022,"low-life nobody?"],[2102,2202,"About that."],[2260,2377,"He's not a nobody, bro."],[2448,2560,"That's Carson Moretti,"],[2686,2865,"heir to the Moretti crime family."],[3053,3111,"What?"],[3395,3482,"Mia married"],[3482,3661,"Carson-fucking- Moretti?"],[3687,3820,"The Mafia King?"]],"50":[[554,696,"Isn't it nice to get some fresh air"],[696,809,"after being cooped up inside"],[809,888,"for so long?"],[2761,2911,"Thanks for taking care of me."],[2911,3015,"I don't know what I would've done"],[3015,3090,"without you."],[3274,3349,"Of course."],[3390,3536,"I'm your wife, Carson."],[3536,3657,"Not gonna let you go through this"],[3657,3732,"by yourself."],[3870,3987,"Okay, I hope you're hungry."],[4058,4166,"I made lunch."],[4900,5013,"Smells amazing."],[5634,5697,"I remember when"],[5697,5805,"she used to do that for me."],[6264,6385,"I made us lunch."],[6498,6610,"Go ahead, try it."],[6694,6773,"What the hell is that?"],[6773,6915,"You think I'm eating that shit?"],[7570,7728,"How could I've been such an asshole?"],[7766,7887,"If only I would've shown my love"],[7887,7991,"to Mia sooner."]],"51":[[287,437,"Welcome back, Mrs. Moretti."],[462,554,"Hey guys."],[604,692,"How's your last final?"],[713,888,"I aced it 