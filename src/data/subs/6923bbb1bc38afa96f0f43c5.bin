king asshole"],[700,759,"out of here."],[788,855,"Try me!"],[950,1021,"I dare you."],[1488,1555,"Cowards."],[1655,1856,"I'll take care of this asshole myself."],[2640,2727,"You have any idea"],[2727,2823,"what you did to Mia?"],[2823,2957,"You ditched her on her birthday."],[3040,3136,"She was almost assaulted"],[3136,3236,"by your friend."],[3236,3332,"Didn't you see her hand"],[3332,3420,"in the hospital?"],[3424,3553,"Now I'm gonna make you feel"],[3553,3641,"what she felt."]],"34":[[1184,1322,"Carson, wait."],[1438,1505,"Don't."],[1530,1584,"Okay?"],[1626,1760,"Look, he, he's not even worth"],[1760,1851,"the bullets, okay?"],[1851,1901,"Just..."],[2314,2423,"please put the gun down."],[3169,3219,"Okay."],[3536,3624,"Are you okay?"],[3837,3908,"I'm fine."],[4216,4379,"He's the one you need to worry about."],[4629,4833,"Mia, is it, is it true what he said?"],[5063,5171,"Did that really happen-"],[5171,5255,"What do you care?"],[5409,5551,"I, I would have never left you"],[5551,5676,"if I, if I'd known."],[5743,5868,"It's too late for that now."],[6118,6227,"At the hospital,"],[6272,6360,"with your hand."],[6448,6510,"You weren't just trying to"],[6510,6589,"get my attention?"],[6589,6706,"You were actually hurt?"],[6906,7023,"I'm so sorry, Mia."],[7119,7265,"No, please, Mia."],[7515,7699,"We are done, okay?"],[7745,7820,"My life,"],[7836,8008,"my safety, my happiness."],[8008,8149,"It doesn't mean anything to you!"],[8187,8312,"And your stupid apology"],[8312,8462,"doesn't mean anything to me."],[8462,8646,"So just stay out of my life."],[8975,9017,"Let's go."],[9046,9134,"No, Mia, no."],[9134,9271,"Please, Mia, Mia."],[9280,9371,"Look, I said sorry."],[9371,9484,"Don't leave me, please."]],"35":[[8,108,"Don't leave me, please."],[108,208,"You blew it, bro."],[763,829,"It's over."],[1101,1238,"It's time for you to move on."],[1322,1451,"I need you to find out if that"],[1451,1593,"bullshit marriage is real."],[1639,1739,"I'm not letting my girl"],[1739,1835,"go wi