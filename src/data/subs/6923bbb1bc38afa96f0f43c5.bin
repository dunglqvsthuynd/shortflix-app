{"1":[[621,771,"Tonight's my 21st birthday,"],[771,867,"and my boyfriend Aiden"],[867,1046,"promised me a night I'd never forget."],[1463,1651,"Aiden, it's almost midnight."],[1685,1801,"Let's blow out the candle together."],[1801,2043,"Chug, chug, chug, chug! Oh!"],[2068,2156,"Chug, chug, chug!"],[2156,2293,"Chug, chug, chug, chug!"],[2335,2394,"Does he even"],[2394,2523,"remember my birthday?"],[2560,2781,"Okay, everybody has to do one."],[2781,2890,"I got more shots."],[2890,2990,"Shots!"],[2990,3086,"Yes!"],[3140,3211,"Hey, another one."],[3211,3282,"Aiden."],[3340,3395,"Hold on, hold on."],[3420,3553,"I gotta do this real quick, watch me."],[3695,3778,"I'm not gonna let"],[3778,3912,"you have your moment, Mia."],[3924,4066,"Aiden is mine."],[4216,4366,"But it's already midnight."],[4416,4512,"Oh my gosh!"],[4512,4604,"Jessica. - Ow!"],[4604,4679,"Jessica, are you okay?"],[4679,4788,"Oh, I, I,"],[4788,4871,"I, I think I sprained"],[4871,4946,"my ankle or something."],[4946,5009,"I'll take you to the hospital."],[5009,5100,"It's fine, it's fine. - Okay."],[5100,5134,"It's okay."],[5134,5305,"Wait, why can't Nick take her?"],[5317,5451,"Or one of the other guys?"],[5451,5563,"Yeah, yeah, I can take her."],[5584,5689,"My car's the fastest."],[5772,5872,"But it's my-"],[5872,6014,"Birthday, I know."],[6285,6418,"You'll have another one next year."],[6443,6585,"Wait, you promised me"],[6585,6715,"a special birthday."],[6744,6881,"You dragged me out into the woods"],[6881,7002,"with all of your friends."],[7032,7178,"And now you're just gonna abandon me."],[7323,7557,"If you leave, I will break up with you."],[8091,8158,"No."],[8212,8308,"No, you won't."],[8416,8541,"Now go back to our tent,"],[8571,8646,"and wait for me."],[8646,8754,"I'll pick you up in the morning."],[8754,8829,"Jessica, let's go."],[8829,8883,"Okay."],[10952,11027,"Boss!"],[11056,11152,"There's a group of college students"],[11152,11236,"maybe a few"],[11236,11323,"hundred meters up ahead"],[11323,11419,"and they're having a party."],[11419,11515,"You think we should do this"],[11515,11574,"another night?"],[11603,11674,"Keep digging."],[11703,11849,"They'll be too drunk to notice anything."],[11878,11932,"Yes, sir."],[12162,12379,"I can't believe my boyfriend left me"],[12379,12658,"for his highshcool ex on my 21st birthday."],[12883,12971,"Aiden, you came-"],[13067,13184,"No, it's me, Nick."],[13267,13367,"Came to check up on you."],[14230,14360,"You know they're fucking, right?"],[14414,14535,"Aiden wouldn't do that to me."],[14556,14635,"He loves me."],[14664,14760,"You, you tell yourself"],[14760,14856,"whatever you want, Mia."],[14910,15023,"But you know I'm right."],[15085,15327,"Since Aiden is fucking Jessica,"],[15348,15419,"how about..."],[15448,15598,"What are you doing, Nick?"],[15628,15715,"You're Aiden's friend."],[15753,15819,"He thinks he's the"],[15819,15895,"hottest shit in school"],[15895,16074,"just because his Daddy is a Senator."],[16161,16287,"He's got nothing on me."],[16466,16516,"Ugh!"],[16629,16812,"Get off me, you sick fuck."],[18806,18873,"Help,"],[18873,18960,"someone help."],[19598,19673,"It's you,"],[19803,19919,"Mia Collins."],[19982,20103,"I've been looking for you"],[20145,20249,"all my life."]],"2":[[250,350,"Mr. Moretti, your"],[375,550,"reputation certainly precedes you."],[550,675,"While I greatly"],[675,880,"appreciate your kindness,"],[880,1059,"I'm just not sure the school"],[1084,1234,"is going to be able to accept your"],[1234,1372,"generous donation."],[1409,1505,"I guarantee you, Mr. Hill,"],[1505,1593,"the money's clean."],[1772,1868,"Believe it or not,"],[1893,1951,"I plan to turn"],[1951,2052,"the Moretti name around."],[2239,2427,"So, what moves the viewer"],[2427,2585,"isn't the structure itself,"],[2610,2673,"but it's the way"],[2673,2777,"that it lets in the light."],[2852,2948,"It's Mia Collins."],[2982,3169,"She's one of our brightest students."],[3432,3553,"Let's just say I want a future"],[3553,3724,"where I can finally stand under the sun."],[3903,4099,"I still remember her name, Mia Collins."],[4233,4404,"Come back here, you fucking bitch!"],[4913,5075,"Oh no, it's a real gun."],[5121,5159,"Look sir,"],[5159,5342,"it was just a misunderstanding."],[5363,5476,"Mia and I are friends."],[5476,5638,"We were, we were just fooling around."],[5638,5772,"We're not friends!"],[5784,5901,"You assaulted me!"],[6189,6293,"But maybe,"],[6302,6414,"don't shoot him."],[6527,6656,"Could we lower the gun?"],[7007,7123,"Come on, Mia, let's go."],[7123,7232,"I'm not going anywhere with you,"],[7232,7298,"you perv."],[7315,7482,"Fine, stay here with him."],[7520,7632,"Just in case you didn't notice"],[7632,7741,"the ring on his finger."],[7753,7874,"He's in the Mafia."],[8016,8229,"Oh my God, that's the Moretti ring!"],[8245,8412,"How did I not notice it before?"],[8491,8600,"If that's the case,"],[8908,9000,"you should learn to keep"],[9000,9088,"your mouth shut."],[9334,9413,"My leg!"],[9622,9776,"Joey, get a clean up crew over here."],[9797,9851,"Yes, sir."],[9872,9926,"No."],[10502,10681,"Please, please don't kill me."],[11090,11202,"Come in the car with me,"],[11232,11348,"I'll get your hand cleaned up."],[11461,11636,"No, no, no, no, no."],[11636,11790,"He's gonna lure me into his car"],[11790,11982,"and probably harvest my organs."],[12074,12187,"It's a deep cut."],[12283,12379,"It will get infected."],[12433,12495,"Boss,"],[12575,12666,"we heard a gunshot."],[12666,12758,"Is everything okay?"],[12775,12862,"Everything's fine,"],[12946,13013,"just some prick"],[13013,13142,"that needed to be taught a lesson."],[13150,13234,"Are you guys finished?"],[13234,13309,"Yes, boss."],[13309,13392,"It's done."],[13450,13621,"May his soul rest in peace."],[13697,13947,"Oh my God, he's burying a dead body."],[14097,14180,"Don't move."],[14727,14843,"Is he going to kill me?"]],"3":[[1839,1943,"You're finally awake."],[2686,2773,"Where am I?"],[2852,2940,"This is my home."],[3073,3186,"You passed out last night."],[3219,3274,"That's right."],[3274,3411,"I saw him shooting Nick."],[3474,3570,"And then his henchmen were"],[3570,3674,"burying a body."],[3699,3828,"What's he gonna do with me?"],[4033,4204,"Look, uh, Mr.-"],[4204,4275,"Moretti."],[4287,4446,"My name is Carson Moretti."],[4487,4671,"Like the Carson Moretti?"],[4700,4829,"Of the Moretti crime family?"],[4913,4971,"Great."],[5021,5159,"Let's talk over breakfast."],[5242,5376,"There's toiletries and fresh clothes"],[5376,5455,"in the bathroom."],[5509,5576,"Help yourself."],[5697,5764,"Oh."],[5851,5943,"Wait!"],[6035,6222,"What if I'm not hungry?"],[6268,6364,"Can I just go?"],[6402,6552,"Since you already know who I am,"],[6644,6748,"what do you think?"],[6819,6894,"Okay, quick,"],[6894,6965,"think Mia,"],[6965,7161,"how do you plan to survive this?"],[8099,8245,"Holy guacamole."],[8245,8425,"This place is huge."],[9146,9263,"She's even more gorgeous"],[9263,9401,"than the first time I saw her."],[9471,9526,"Like a"],[9580,9672,"ray of sunlight."]],"4":[[500,675,"Why is he looking at me like that?"],[734,813,"Is he thinking about"],[813,942,"where he's gonna dump my body?"],[1226,1338,"She's even more gorgeous"],[1338,1455,"than the first time I saw her."],[1764,1876,"Have anything you like."],[2594,2652,"Why are you looking at"],[2652,2740,"your coffee like that?"],[3211,3382,"The coffee is poisoned, isn't it?"],[3561,3678,"Look, Mr. Moretti,"],[3703,3782,"is there any way"],[3782,3912,"you could spare my life?"],[3953,4070,"She's scared of me."],[4116,4208,"They all are."],[4237,4354,"Why do you think I wanna kill you?"],[4391,4587,"I saw you shooting a man last night."],[4617,4725,"He assaulted you!"],[4771,4896,"And I only shot him in the leg."],[4896,4975,"He'll live."],[4984,5105,"And then I caught you"],[5105,5221,"burying a dead body."],[5280,5405,"She thinks I was burying"],[5405,5484,"a dead body?"],[5505,5705,"I buried Enzo, my dog."],[5743,5955,"And then you tried to shoot me."],[6014,6197,"I just shot the snake to protect her."],[6293,6523,"So, is this my final meal?"],[6635,6748,"Before you end my life?"],[6765,6810,"Huh?"],[6835,7011,"She totally misunderstands me."],[7178,7328,"I know how these things work,"],[7328,7415,"Mr. Moretti."],[7549,7661,"No matter what I do,"],[7678,7828,"people only see my last name,"],[7857,7970,"not who I really am."],[8008,8124,"Two can keep a secret"],[8124,8216,"if one of them is dead."],[8299,8420,"She assumes I could take a life"],[8420,8583,"so easily without even knowing me."],[8804,8867,"But..."],[8971,9109,"You have to seduce him, Mia."],[9280,9451,"It's the only way he'll let you live."]],"5":[[329,479,"Is she trying to seduce me?"],[1309,1393,"Damn,"],[1447,1514,"I can't."],[2010,2202,"She is so sexy."],[2414,2481,"I..."],[2686,2773,"Her legs are,"],[2852,2940,"so pefect."],[2957,3073,"Have a proposal."],[3144,3224,"Proposal?"],[5159,5305,"Let me be your woman."],[5513,5618,"Let's get married."],[5826,5885,"What?"],[5980,6051,"Oh no,"],[6051,6247,"he's not even remotely interested."],[6268,6314,"Why?"],[6339,6418,"Well,"],[6460,6577,"I took a law class once."],[6635,6698,"Just for fun."],[6698,6869,"And turns out you can't"],[6869,7073,"testify against your husband, so..."],[7228,7340,"I know what you're thinking."],[7353,7432,"Why would you marry me"],[7432,7540,"if you could just kill me?"],[7540,7595,"But,"],[7657,7761,"look, I actually think I would"],[7761,7841,"be a pretty good wife."],[7841,7995,"I can cook, I can clean, and-"],[7995,8062,"Deal."]],"6":[[208,296,"Wait, really?"],[358,471,"My family's been bugging me about"],[471,592,"getting married anyways."],[696,796,"Any woman will do."],[834,917,"Might as well be you."],[1901,2031,"Go eat your birthday cake."],[2077,2198,"And then we'll get married."],[2223,2377,"He knows it's my birthday?"],[2423,2594,"How could he possibly know that,"],[2635,2794,"when even my boyfriend didn't care?"],[3053,3169,"Carson Moretti."],[3224,3315,"Is there more to you"],[3315,3428,"than what meets the eye?"],[4233,4337,"Miss Collins,"],[4396,4550,"are you willingly marrying"],[4550,4667,"Mr. Moretti?"],[4792,4917,"What's that supposed to mean?"],[5188,5301,"We are so in love."],[5317,5405,"I love him."],[5476,5601,"In fact, I love him so much"],[5601,5772,"that I asked him to marry me."],[5772,5905,"Not the other way around."],[5905,6010,"Isn't that right, honey?"],[6056,6106,"Yes."],[6360,6502,"Well, alright then, lovebirds."],[6523,6673,"Show me a kiss."],[6694,6765,"A kiss?"],[6790,6848,"Here?"],[6915,6990,"Right now?"],[7023,7198,"I've been doing this for over 30 years,"],[7198,7323,"and I know a forced marriage"],[7323,7403,"when I see one."]],"7":[[158,229,"Carson,"],[271,358,"honey, come here."],[5680,5826,"Alright, alright, alright."],[5868,5964,"Congrats."],[6264,6506,"And happy birthday, I guess."],[6844,6994,"So, now that we're married,"],[6994,7111,"your secret's safe with me."],[7157,7240,"Uh, about that..."],[7361,7474,"I wasn't actually"],[7499,7665,"doing what you think I was-"],[8233,8433,"Look, I really have to go to class today"],[8433,8604,"but just like I promised,"],[8604,8696,"if you need me to play wife"],[8696,8787,"in front of your family,"],[8787,8933,"need me to cook, clean,"],[8946,9092,"any wifey duties, just"],[9146,9246,"call me, okay?"],[10439,10543,"I can't believe"],[10543,10677,"I'm actually married,"],[10764,10902,"to the Mafia King."]],"8":[[225,354,"Why do you keep calling?"],[396,446,"What do you want?"],[446,579,"So you finally decided to pick up."],[604,671,"Where are you?"],[671,775,"I've been searching for you"],[775,946,"all morning around the campgrounds."],[946,1096,"I thought you were busy with Jessica."],[1138,1351,"Oh my God, Mia."],[1393,1459,"All I did was take her to"],[1459,1564,"the fucking hospital."],[1564,1701,"Why does it have to be so dramatic?"],[1760,1835,"Do you have any idea"],[1835,1964,"what you put me through last night?"],[2010,2077,"I'm so sick of you"],[2077,2239,"choosing her over me, Aiden."],[2256,2364,"If you care about your ex so much,"],[2364,2456,"then just go be with her."],[2464,2519,"I'm done."],[2715,2794,"We're done."],[3199,3290,"Goodbye, Aiden."],[3386,3503,"This time it's forever."],[4041,4237,"I'm the one who proposed to Carson."],[4300,4491,"The least I can do is get him a present."],[4808,4913,"And a ring"],[4975,5150,"to keep up our front to his family."],[5188,5347,"The devil is in the details."],[5372,5426,"Mia?"],[5534,5601,"Oh crap,"],[5630,5751,"that's Jason."],[5755,5889,"Aiden's best friend."],[6177,6331,"Is that what I think it is?"],[6352,6556,"No, it is not what you think."],[6881,7032,"Mia's gonna propose to Aiden."],[7386,7528,"It's been 3 days and Mia hasn't answered"],[7528,7649,"any of my texts."],[7745,7903,"I'll butter her up with a fancy dinner."],[7928,7995,"She can't resist"],[7995,8124,"romantic shit like that."],[8708,8754,"Bro."],[8792,8863,"Get this."],[8871,9096,"I was at the cafe and I saw that Mia"],[9192,9330,"bought wedding rings."],[9421,9588,"I think she's gonna propose to you."],[9588,9659,"Really?"],[9701,9805,"She wants you back."],[9805,9930,"Why else would she have the rings?"],[10018,10206,"Yeah, you're probably right."],[10272,10435,"I knew she loved me too much."],[10485,10618,"It's probably one of her tricks to"],[10639,10773,"get my attention or whatnot."],[11036,11194,"I knew she'd come crawling back."],[11319,11415,"All I have to do is wait."]],"9":[[54,237,"Carson, do I really need a tetanus shot?"],[262,342,"I mean, I'm pretty sure"],[342,467,"it was just glass, and"],[467,596,"my hand's feeling fine already."],[650,725,"I called the doctor,"],[725,842,"he said it's the best precaution."],[942,1067,"We're not taking any chances."],[1180,1313,"How can a cold-blooded"],[1313,1455,"mafioso be so..."],[1576,1639,"caring?"],[1805,1951,"I'll park the car and meet you inside."],[3090,3282,"What the hell is Mia doing here?"],[3319,3490,"I bet that thirsty little drama queen"],[3490,3670,"is already planning some sob story"],[3670,3845,"to try and win Aiden back."],[3945,4024,"Mia?"],[4058,4237,"So good to see you."],[4258,4366,"I'm not doing this with you."],[4383,4429,"What's wrong?"],[4429,4521,"Are you still upset about"],[4521,4612,"your birthday party?"],[4642,4750,"Cut the act, Jessica."],[4750,4829,"I know what you're doing"],[4829,4909,"and I don't care anymore."],[5117,5255,"Mia, please, I'm so sorry."],[5255,5351,"I never should've-"],[5922,6114,"Jessica, are you okay?"],[6239,6393,"Mia, what the hell are you doing?"]],"10":[[20,108,"You seriously just come up here"],[108,200,"attack Jessica like that?"],[200,329,"She's got a busted ankle!"],[425,554,"I didn't attack anyone."],[813,859,"I see."],[946,1071,"Jason told you I was here, huh?"],[1155,1238,"So now you show up with a"],[1238,1309,"fake-ass injury"],[1309,1509,"trying to one-up her, get my attention?"],[1534,1622,"Seriously?"],[1668,1751,"This happened to me"],[1751,1906,"when you abandoned me for Jessica"],[1906,2002,"at my birthday,"],[2002,2127,"and you left me with some perv."],[2127,2268,"Do you even know what he did to me?"],[2673,2781,"Ow, ow."],[2781,2865,"Jessica, are you okay?"],[2923,3123,"I, I tried to make things right with her."],[3123,3282,"I don't know why she won't forgive me."],[3324,3561,"I'm so sorry!"],[3582,3707,"You're being too nice, Jessica."],[3707,3853,"You should not be apologizing."],[3987,4124,"Look what you've done, Mia."],[4124,4158,"You're the one"],[4158,4270,"who should be apologizing."],[4283,4416,"I'm not apologizing to her"],[4416,4529,"because she's lying."],[4546,4650,"We don't need to make this"],[4650,4833,"any nastier than it already is."],[4833,4946,"Mia, please."],[4946,5050,"I'm not the nasty one."],[5376,5509,"I think that security camera"],[5509,5638,"over there is gonna tell everyone"],[5638,5793,"the truth about your little fall."],[6001,6231,"Why are you always so fucking dramatic?"],[6239,6373,"Just say sorry and move on."],[6377,6485,"Okay, you know what?"],[6502,6660,"This is a waste of my time."],[6677,6777,"You're a desperate liar."],[6777,6861,"So you two are perfect"],[6861,6952,"for each other."],[7027,7190,"Who the fuck are you calling desperate?"],[7190,7315,"Get your hand off of me!"]],"11":[[867,1055,"Stop playing hard to get, Mia."],[1084,1184,"I know that you want me."],[1197,1334,"I know what you're planning."],[1468,1572,"What are you talking about?"],[1618,1693,"Jason told me."],[1847,1989,"I know you got us matching rings,"],[1989,2089,"and you're gonna propose to me."],[2502,2631,"Are you delusional?"],[2631,2773,"What point of we are broken up"],[2773,2890,"do you not understand?"],[3232,3299,"If you keep"],[3299,3424,"embarrassing me like this,"],[3424,3616,"there's gonna be no chance I say yes."],[3661,3816,"So just ask for my forgiveness,"],[3816,3974,"and then we can talk about it in private"],[3974,4079,"about our engagement."],[4175,4283,"Engagement?"],[4441,4496,"Yeah, okay,"],[4496,4621,"I don't want your forgiveness"],[4621,4813,"and that ring is definitely not for you."],[4842,4988,"Then who the hell is it for?"],[5943,6072,"Look at me when I'm talking to you!"],[6072,6164,"Answer me!"],[6197,6377,"Get your fucking hands off her!"],[6664,6735,"Aw!"],[6919,6986,"Are you okay?"],[7144,7323,"Who the fuck are you?"],[7394,7590,"None of your fucking business!"],[7724,7849,"I'm her husband."],[7966,8053,"What? - What?"]],"12":[[20,87,"That's right."],[216,329,"This guy?"],[329,471,"You expect me to believe"],[479,608,"you went out and got married"],[654,792,"within 48 hours?"],[792,930,"I don't care what you believe."],[930,1076,"Do you even know who he is?"],[1076,1284,"Why the fuck should I know who he is?"],[1284,1380,"It's obvious you hired some"],[1380,1534,"old-ass fucking fake actor"],[1534,1614,"to play your husband"],[1614,1735,"just to make me pissed."],[1822,1943,"So this is your ex?"],[2039,2177,"Yeah, I'm not proud of it either."],[2206,2277,"Could we just go?"],[2531,2715,"No, you're not fucking leaving me."],[2977,3069,"Come at her again,"],[3128,3261,"and I'll break both your arms."],[3461,3616,"What the fuck's wrong with you?"],[3616,3682,"Get off me!"],[3682,3795,"I don't take orders from"],[3795,3928,"pathetic children like you."],[4333,4475,"Holy shit!"],[4612,4746,"Okay, uh."],[4767,4892,"Carson, we're in a hospital."],[4892,4959,"Don't!"],[4959,5050,"Get up!"],[5146,5246,"Stay away from Mia."],[5317,5484,"Or next time, I'll pull the trigger."],[6214,6339,"Some ex you got there, huh?"],[6377,6552,"Oh my God, is he pissed?"],[6552,6719,"Why does he look so pissed?"],[6740,6894,"Thanks for saving me back there."],[6969,7019,"I'm sorry for"],[7019,7140,"causing you so much trouble."],[7265,7349,"You should've told me"],[7349,7465,"if your ex is violent."],[7515,7620,"I can protect you."],[8379,8554,"No, no, no, that won't be necessary."],[8554,8675,"You've already done so much for me"],[8700,8858,"by sparing my life and everything."],[8858,8979,"Besides, I'm tougher than I look."],[8979,9063,"I can handle myself."],[9263,9338,"She still thinks"],[9338,9446,"she's stuck in this marriage"],[9446,9534,"for survival,"],[9567,9676,"but I would never hurt her."],[9909,10005,"Is he having second"],[10005,10122,"thoughts about killing me?"],[10264,10343,"Look, I promise- - Mia."],[10527,10593,"Listen to me."],[10719,10923,"My heart is beating so fast."],[10923,11065,"I can't tell if I'm scared"],[11065,11194,"or if it's butterflies."],[11348,11490,"There's something I wanna tell you."]],"13":[[171,262,"I won't hurt you."],[325,400,"You're my wife,"],[450,567,"even if it's just a name."],[638,688,"For now,"],[775,875,"hopefully that changes."],[909,1009,"What is he getting at?"],[1101,1234,"I'll still respect our marriage"],[1234,1297,"and protect you"],[1347,1443,"like a real man would."],[1564,1643,"You understand?"],[1889,1968,"I think so."],[2152,2223,"Nick is fine."],[2268,2414