{"1":[[123,244,"Forgive me, sir,"],[244,383,"but I must ask."],[393,590,"This retreat... it was so sudden."],[590,814,"All our assets, networks"],[814,963,"abandoned in a breakfast."],[963,1040,"Why?"],[1044,1169,"I have toppled governments."],[1169,1306,"I have broken armies."],[1306,1514,"I fear no nation or force."],[1514,1721,"But this guy is scary."],[1735,1993,"A myth made real, they call him \"GHOST ONE\"."],[2429,2572,"Ok, we are safe now."],[2579,2697,"He failed this time."],[3343,3443,"Sorry, I'm late."],[3473,3550,"There's a little bit of traffic"],[3550,3692,"coming in from Champs-Élysées."],[5458,5538,"One second."],[5679,5745,"Hey, sweetheart."],[5835,6013,"Yes, we're still gonna eat pizza when I come back."],[6059,6149,"I'll come pick you up."],[6226,6335,"Alright, I love you too."],[6369,6419,"Bye."],[6996,7113,"Zero casualties."],[7113,7255,"Solo op, no backup."],[7270,7405,"He went in alone, sir."],[7721,7876,"He's our last resort."],[7967,8071,"Bring him home."],[8074,8132,"Sure."],[10387,10463,"Peter Rogers."],[10463,10690,"For unthinkable valor in South Africa,"],[10690,10900,"the Middle East, and actions which"],[10900,11109,"we'll probably never be able to declassify."],[11127,11458,"It's my privilege, and great pleasure"],[11578,11848,"to award you with the Medal of Honor again."],[12145,12258,"Thank you, sir."],[12315,12415,"We need you, Peter."],[12445,12562,"I want you to stay in D.C."],[12612,12856,"Homeland Command, civilian advisory"],[12856,13086,"with your choice of team, members and budget."],[13543,13616,"Daddy!"],[13666,13693,"Hey!"],[14174,14244,"Come here."],[14427,14631,"Sir, 15 years in the shadows."],[14711,14838,"It's time for me to come home."],[14918,14969,"For her."],[15085,15165,"You deserve it."],[15201,15356,"But if the world ever tilts again..."],[15388,15442,"I'll be there."],[15482,15602,"To tilt it right back."],[16836,17067,"Dad, this pizza looks so good!"],[17497,17544,"See?"],[17554,17748,"Way better than the President's food."],[17764,17894,"Okay, okay, you're right."],[17894,17939,"You win."],[17974,18018,"Now eat up."],[18058,18188,"Your tech camp starts soon."],[19436,19626,"Yeah, it's not a real marriage."],[19626,19755,"It's just paperwork,"],[19755,19959,"so I can secure my trust fund"],[19959,20143,"and not have an asset split."],[20170,20311,"Plus, the agency found"],[20311,20470,"a candidate who's manageable."],[20667,20806,"And there he is."],[20874,20963,"I'll talk to you later."],[22085,22155,"Hi?"],[22168,22263,"Hi."],[22308,22445,"Sydney Greenfield."],[22469,22929,"CEO, certified foodie, and occasional rock climber."],[23046,23122,"Your turn."],[23159,23317,"Um, Peter"],[23317,23417,"Rogers."],[23480,23910,"A military vet and a full-time father."],[23910,24190,"So this is the guy the agency arranged for me."],[24190,24387,"A jobless, single father?"],[24387,24701,"But also a hero with biceps."],[24788,25085,"So, shall we get married, Mr. Rogers?"],[25181,25251,"What?"]],"2":[[16,106,"What?"],[230,447,"I'm sorry, Miss Greenfield, but..."],[537,674,"Why would I marry you?"],[790,1111,"Aren't you the guy the agency sent?"],[1171,1301,"What agency?"],[1928,2148,"You've got to be kidding me."],[2148,2302,"That's what the agency sent?"],[2328,2564,"I'd take my chances with this one..."],[2564,2762,"I mean, he's far easier on the eyes.."],[2822,2979,"You know what? I'm so sorry."],[2979,3282,"I must have mistaken you for somebody else."],[3697,3781,"Leslie, what are you doing?"],[3973,4080,"Mommy!"],[4300,4379,"Mommy?"],[4511,4607,"Daddy, I like her."],[4607,4760,"Can she be my mommy?"],[5040,5099,"Leslie."],[5158,5225,"Don't be silly."],[5275,5435,"Daddy, I'm only six."],[5468,5723,"Are you sure you can raise me all by yourself?"],[5885,6062,"And look how pretty Mommy is!"],[6062,6268,"You might not get a chance like this again."],[6423,6586,"What do you think, Mommy?"],[6700,6992,"He's kinda cute, and raising a daughter"],[6992,7280,"on his own can't be easy with only an army stipend."],[7540,7642,"Well, well."],[7824,8078,"If it isn't Peter freaking Rogers."],[8094,8278,"They finally boot you out of the army, yeah?"]],"3":[[6,212,"Tell me, Peter, how's life as a broke"],[212,337,"living off of Happy Meals?"],[410,642,"Seriously! What did Mary ever see in you?"],[642,781,"She should have been with me!"],[880,954,"Cooper!"],[970,1237,"Same as always. Loud as hell."],[1334,1614,"Don't you talk about my daddy like this."],[1651,1801,"He's a hero!"],[1958,2202,"So you knocked someone up, Peter, huh?"],[2202,2355,"What happened to the baby mama?"],[2405,2669,"She get bored of you being broke and run for the hills?"],[2672,3012,"Your father is a worthless piece of trash."],[3059,3282,"And trash breeds trash."],[3313,3516,"Excuse me, who are you?"],[3833,3992,"Hello there! Name's Cooper."],[4087,4296,"General Manager of the Greenfield Group."],[4317,4506,"Biggest defence firm in the country."],[4551,4665,"Greenfield Group."],[4684,4831,"Have you heard of it? Tech Giants."],[4868,5139,"Worth over a hundred billion dollars, baby."],[5188,5397,"Got myself a sweet 401k,"],[5518,5869,"and up to two million dollars in bonuses a year."],[6196,6332,"Hey, don't touch her!"]],"4":[[16,203,"Hey, don't touch her!"],[620,710,"You little brat!"],[760,950,"Your father raised you with no class."],[987,1167,"Let uncle Cooper teach you some manners!"],[1905,2002,"Did you just hit me?"],[2022,2155,"I work for the Greenfield."],[2175,2228,"So?"],[2258,2366,"Greenfield's got the best"],[2366,2531,"security team in the country."],[2699,2763,"I've got backup."],[2846,3041,"Yo, bring the crew. Now!"],[3050,3183,"Alright, that's enough."],[3183,3271,"I'm not gonna let you drag"],[3271,3506,"the Greenfield name through the mud over this."],[3506,3631,"Stay out of this, bitch!"],[3646,3760,"Who are you to say that?"],[3843,3987,"I'm Peter's wife."],[4240,4374,"And I'm her mother"],[4374,4752,"which gives me the right to tell you to back off."],[4901,5259,"Wife! A girl like you with this loser."],[5441,5679,"That's the best joke I've heard all day."],[5699,5879,"Tell me again, Mrs Rogers."],[5919,6302,"Just what gives you the right to tell me what to do?"],[6339,6399,"Me?"],[6569,6930,"Well, I'm the one who signs your paycheck."],[8121,8318,"Damn, Cooper, you got clout."],[8321,8411,"Isn't that Rita Gray?"],[8438,8607,"The CEO's personal assistant."],[9469,9679,"Miss Greenfield, your instructions?"],[9876,10113,"M... Miss Greenfield?"]],"5":[[43,266,"You're the Sydney Greenfield?"],[407,724,"Miss Rita, did you just call this chick Miss Greenfield?"],[970,1164,"Call her chick again"],[1164,1344,"and you'll be leaving on your knees."],[1414,1521,"She's your boss."],[1601,1919,"Sydney Greenfield, CEO of Greenfield Group."],[2142,2262,"You're the CEO?"],[2462,2672,"And Peter, he's your husband?"],[2692,3025,"Rita, have security escort him off the premises."],[3043,3299,"His personal effects are to be couriered to him"],[3323,3616,"and his termination is effective immediately."],[3687,3963,"No, no, no, come on, please, please don't do this."],[3983,4032,"Please."],[4110,4267,"No, I didn't know who you were."],[4267,4340,"Forgive me."],[4411,4484,"Come on, Pete!"],[4597,4792,"Pete, we were bros in high school, man!"],[4828,5034,"Come on, talk to her. I can't lose this!"],[5081,5235,"You tried to lay a hand on my daughter."],[5368,5528,"We were never \"bros\"."],[5686,5752,"Come on."],[5769,5969,"Cooper Fin, you're fired."],[5995,6223,"Harrassement, assault and defamation."],[6276,6379,"Legal's coming for you."],[6379,6423,"No."],[6496,6573,"No, come on."],[6609,6819,"No, I'll do anything. I'll clean the toilets."],[6880,7033,"No, no, no, no, no, no, no."],[7077,7326,"No, no, no, please, come on, I'll do anything."],[7350,7557,"Anything! Don't do this to me."],[8074,8282,"Yay yay, I got a new mommy now."],[8334,8458,"I'm Peter's wife."],[8488,8678,"And I'm her mother"],[8678,8998,"which gives me the right to tell you to back off."],[9112,9239,"Hey, Leslie."],[9295,9516,"She stood up for us, but she's not really your..."],[9516,9572,"Peter."],[9683,9879,"You show up when it matters."],[9896,10095,"And that's exactly what I'm looking for"],[10095,10219,"in a fake husband."],[10850,10990,"So, what do you say?"],[11134,11187,"Marry me?"]],"6":[[6,266,"Thank you sincerely for speaking up for us, but..."],[373,526,"As for the proposal, I'm sorry."],[620,767,"I can't accept."],[791,916,"Hey Leslie,"],[916,1041,"we should get going. Come on."],[1067,1201,"No, I don't wanna go!"],[1431,1688,"Hey, please. Come on."],[1735,1998,"All the other kids have moms."],[2075,2245,"I want one too."],[2365,2594,"Peter, I know this is unconventional"],[2594,2815,"but think of it as a partnership."],[2876,3116,"You get a fortress of influence,"],[3116,3319,"Leslie gets a family"],[3319,3643,"and I get to deal with a problem."],[3703,3927,"Sounds like a fair exchange, don't you think?"],[4120,4381,"Daddy, say yes, please!"],[4654,4968,"Alright, if you're serious about this,"],[5001,5098,"I'm in."],[8485,8735,"Mr. Rogers, Leslie's stem camp"],[8735,8905,"check-in started 15 minutes ago."],[8938,9163,"Also, did you try to stitch her badge"],[9163,9287,"on with duct tape?"],[9299,9426,"Innovation over perfection?"],[9482,9681,"She's six, not a prototype."],[9681,9754,"Get moving!"],[9816,9930,"Okay, we'll be right there."],[10063,10266,"I'm sorry, but Leslie has a tech camp,"],[10266,10426,"and if I don't get her there right now,"],[10426,10593,"she might lose lab access, so..."],[10653,10907,"No worries. I have a company to run."],[10940,11151,"We'll catch up later, partner."],[11197,11334,"Okay. See you later."],[11621,11941,"Rita, schedule a welcome gift for Leslie."],[11941,12068,"Make it special."],[12098,12422,"And please, a ring that fits."],[12492,12595,"Already on it."]],"7":[[447,610,"The drone competition has started."],[633,696,"Sounds like fun."],[764,843,"What's the objective?"],[854,1031,"Design, build, fly."],[1044,1256,"Fastest drone through the finish gate wins."],[1274,1435,"Parents can relax in the lounge."],[1498,1614,"Okay, thank you."],[1651,1869,"Hey, you're going to crush it today."],[2185,2505,"Pilot Leslie Rogers reporting for launch. Sir."],[2609,2690,"Have fun!"],[2690,2790,"See you later, okay?"],[3707,3827,"Hey, that's mine!"],[3877,3989,"Now it's not."],[4090,4192,"Give it back!"],[4204,4489,"How can the school let you come here?"],[4531,4651,"Do you have a sponsor?"],[4891,5045,"Hey, what are you doing?"],[5075,5162,"What are you gonna do?"],[5181,5482,"Build a revenge robot and bully me?"],[6920,7127,"Why don't you say your sorry?"],[7167,7340,"I'm sorry."],[7350,7507,"I was wrong."],[7530,7712,"Please let me go."],[7891,8078,"Don't mess with me ever again."]],"8":[[400,580,"Oh, my poor baby!"],[600,750,"Who did this to you?"],[777,897,"She hit me!"],[920,1188,"He tried to hit me first and I'm the bully?"],[1214,1384,"Dad said real strength"],[1384,1651,"isn't for picking on people smaller than you."],[1678,1878,"You little brat!"],[1905,2032,"How dare you lay hands on him?!"],[2112,2379,"I highly recommend reconsidering."],[2989,3239,"Wait, do I know you?"],[3266,3456,"She made my son cry."],[3456,3613,"I don't care who you are, I'll..."],[3660,3840,"He tried to hit me with the remote."],[3840,4000,"I was just trying to stop him."],[4150,4224,"You okay?"],[4227,4352,"Not even a scratch."],[4524,4584,"You heard her."],[4584,4836,"Your son tried to hit her first with a weapon."],[4861,5064,"I don't give a damn who's right."],[5115,5423,"Make my son cry, and I'll make you bleed."],[5475,5678,"Wait, are you Peter?"],[5759,5919,"Peter Rogers."]],"9":[[16,142,"Mary Ann."],[179,335,"I didn't recognize you behind"],[335,587,"that fake BBC drama accent you're hiding behind."],[603,740,"What, you know this guy?"],[760,1097,"Yes, this is my ex back when he was broke"],[1097,1294,"and desperate enough to join the army."],[1354,1564,"Don't you see, unlike some fools,"],[1564,1894,"my man can pull in seven figures a year."],[1925,2214,"Right, so you're the loser she used to date."],[2252,2468,"No wonder your kid's such an animal."],[2535,2816,"Once a pikey, always a pikey."],[2816,2906,"Wow."],[2906,3162,"Judging others based on their paycheck, are we?"],[3173,3393,"That's really funny considering what I do now,"],[3393,3680,"your tiny little brains could barely comphrehend."],[3797,3957,"That's hilarious."],[3957,4107,"Have you not heard about Caden's"],[4107,4302,"upcoming deal with Greenfield Group?"],[4310,4641,"Once he signs it, we'll be set for life."],[4641,4798,"Sweetheart, why bother?"],[4798,4911,"Bottom-feeders like him"],[4911,5037,"wouldn't recognize the Greenfield name"],[5037,5121,"if it bit them."],[5121,5228,"Of course we know!"],[5251,5554,"My new mommy is the CEO of the Greenfield Group."],[5605,5882,"Wait, your wife's the CEO of Greenfield?"]],"10":[[400,506,"Miss Greenfield,"],[516,677,"the gifts for your daughter are ready."],[837,941,"Perfect."],[1017,1109,"Let's go."],[1145,1317,"It's time to bring them home."],[1371,1572,"Your wife's the CEO of Greenfield."],[1578,1728,"You mean that Sydney...?"],[1791,2052,"The one all those Wall Street boys jack off to."],[2152,2409,"What a cute little fairy tale!"],[2409,2636,"Did Daddy make this up for you?"],[2672,2811,"I'm not lying!"],[2835,2966,"You can ask my dad!"],[2972,3059,"Figures."],[3129,3293,"No wonder your kid's delusional."],[3293,3510,"Dad has been feeding her bedtime lies."],[3563,3780,"What kind of crap are you teaching your kid?"],[3793,4094,"This is not parenting, it's child abuse!"],[4174,4501,"And look at these rags."],[4501,4861,"While my Billy is dressed in Armani."],[4941,5148,"You know, trash like you"],[5148,5311,"shouldn't be allowed to breed."],[5331,5662,"These rags represent a soldier's honor."],[5662,5864,"I think it's about time you two learn to respect."],[5882,6129,"Here's some respect, soldier boy."],[6282,6543,"What's that honor worth on the open market?"],[6543,6790,"A man like you would do anything for the right price."],[7193,7554,"Mr. Rogers, special deliveries for you."],[7807,8021,"Personally prepared by your wife,"],[8054,8281,"CEO, Sydney Greenfield."]],"11":[[30,83,"Gifts?"],[96,130,"Yes."],[130,370,"Our CEO is quite fond of Miss Leslie."],[413,710,"Consider them a warm welcome into the family."],[725,907,"Wait, he was telling the truth?"],[930,1081,"No, they're hired actors."],[1081,1161,"Just look at them."],[1161,1361,"It's clearly stage show."],[1361,1423,"And..."],[1454,1538,"you are?"],[1538,1758,"They laughed at me and Daddy,"],[1758,2098,"and they said my mom can't be a CEO."],[2222,2615,"What a pair of rude municipals."],[2659,2837,"Hey, what the fuck did you just say?"],[2852,3020,"I'm Greenfield's top contractor."],[3073,3236,"Make millions a year, you bitch!"],[3246,3406,"You say this is from the CEO,"],[3406,3536,"why don't you prove it to us?"],[3563,3777,"Open up your fancy boxes"],[3777,3966,"and show us what's inside, huh?"],[4104,4220,"Mr. Rogers?"],[4250,4320,"Please!"],[4387,4811,"100 crates of Lego sets."],[4904,5238,"Worth $300,000."],[5311,5542,"It's $300,000!"],[5665,5942,"XTR 9 prototype drone."],[5972,6132,"Full AI integration."],[6182,6364,"Only 12 units made globally."],[6423,6696,"Mommy, I've never seen that thing in my whole life!"],[6730,7087,"And this, a private technology lab."],[7187,7460,"Built exclusively for Miss Leslie."],[7487,7782,"Outfitted with Greenfield's most advanced learning AI,"],[7847,8182,"robotics modules and 3D bio-printing base."],[8185,8355,"Construction cost"],[8355,8688,"$100 million."],[8775,8962,"$100 million!"]],"12":[[30,343,"Peter, the loser, there's no way he could get all of this!"],[383,590,"Is she really the CEO of Greenfield?"],[630,890,"Impossible! That idiot could not get a woman"],[890,1121,"half as good as me, let alone Sydney Greenfield!"],[1184,1341,"One hundred million dollars!"],[1458,1533,"Really, Peter?"],[1554,1845,"If you were gonna lie, at least make it believable."],[2202,2389,"You losers are a joke."],[2425,2642,"My dad got me the new iPhone."],[2642,2992,"And you just have fake gifts and a fake mom"],[3019,3227,"because your real mom is dead."],[3319,3510,"You better learn your manners."],[3510,3753,"This is your one warning."],[3907,4077,"What the hell did you just say?"],[4077,4210,"You don't speak to my son!"],[4210,4499,"I'm defending the CEO's daughter."],[4524,4671,"You should be more concerned about"],[4671,4824,"losing your Greenfield's contract."],[4831,5098,"The CEO really? Prove it to us."],[5098,5388,"Come on, bring her in and show her face to us!"],[5388,5580,"Do you really want to test your fate?"],[5682,5935,"No, you know what? You all crossed the line."],[5999,6209,"I don't care if you all apologize right now."],[6209,6406,"It will not fix what your son just said to my daughter."],[6443,6589,"You're gonna be a tough guy now, huh?"],[6639,6743,"I tell you what,"],[6743,6936,"I own the top lawyer in the city."],[6936,7163,"Even if I beat your whole family to death,"],[7163,7333,"I'd walk away scot-free."],[7333,7467,"I'd like to see you try."],[8104,8324,"I would love to know who is threatening"],[8324,8482,"my daughter and my husband."],[8488,8667,"Where did this bitch crawl in from?"],[8678,8812,"We can smash her too."],[9102,9202,"Miss Greenfield."]],"13":[[36,170,"CEO?"],[300,450,"That's right."],[483,640,"This is Miss Greenfield."],[640,804,"The most beautiful"],[804,947,"and powerful woman in the country."],[974,1144,"Miss Greenfield, these lunatics"],[1144,1266,"claimed to be your family."],[1266,1421,"I was just putting them in their place."],[1464,1661,"You were putting them in their place?"],[1768,1928,"Exactly! If that's not enough, then I'll-"],[2058,2168,"What the hell?"],[2175,2365,"That is for laying your hands"],[2365,2569,"on my daughter and my husband."],[2602,2716,"Husband?"],[2762,2862,"Daughter?"],[2922,3009,"You mean they're..."],[3013,3076,"Yes."],[3093,3166,"They're my family."],[3249,3483,"And as far as our deal goes, consider it off."],[3566,3693,"It's over. I'm-"]],"14":[[16,136,"It's okay, it's okay, baby."],[136,393,"Forget about them and we'll find new partners!"],[497,583,"Shut up!"],[640,824,"If you haven't pissed off the CEO,"],[877,1064,"we wouldn't have been in this mess in the first place!"],[1191,1371,"If this deal falls through, I'm ruined!"],[1451,1644,"Why are you crying, stupid girl?"],[1731,1825,"Apologize!"],[1865,1941,"Now!"],[2058,2132,"Now!"],[2148,2272,"I'm sorry."],[2642,2896,"How is it the man that I cheated on and dumped"],[2896,3121,"married a powerhouse CEO?"],[3149,3276,"While the guy that I chose"],[3333,3481,"lost everything?"],[3536,3729,"I don't care that you're a CEO."],[3747,4068,"My family runs the biggest gang in this town, okay?"],[4080,4254,"And they're gonna make you pay."],[4551,4764,"Phil, I'm being bullied right now, okay?"],[4794,4994,"Come to the tech camp and bring your men."]],"15":[[13,196,"Last chance to reverse your decision,"],[196,320,"Miss Big CEO."],[373,497,"Or else you're gonna find out"],[497,717,"that money doesn't get you everything."],[734,817,"Is that a threat?"],[837,977,"Have you lost your mind?"],[977,1194,"This is the only way I can save our company,"],[1194,1344,"and I'm not gonna let a guy"],[1344,1544,"that I dumped rise above me!"],[1544,1601,"She's right."],[1624,1828,"Reinstate the deal or her uncle will make"],[1828,1938,"you learn the hard way."],[1958,2060,"Call the police."],[2075,2206,"They're twenty minutes out."],[2222,2305,"Relax."],[2305,2470,"They're probably just a bunch of local thugs."],[2472,2559,"Relax."],[2559,2817,"They're probably just a bunch of local thugs."],[4577,4864,"Who the hell touched my niece?"]],"16":[[16,250,"Who the hell touched my niece?"],[316,433,"Phil, it's them!"],[433,577,"They cancelled Caden's deal"],[577,720,"and they tried to ruin us!"],[740,1071,"Don't twist it. You started this mess."],[1311,1538,"Here's my turf. My rules."],[1568,1688,"Touch my niece..."],[1751,1868,"You're dead."],[1975,2032,"Peter."],[2032,2182,"Crimson Bats, huh?"],[2198,2429,"Ah, just a bunch of street trash with tattoos."],[2619,2749,"You've got balls"],[2749,3146,"but I got one thousand men outside waiting for you."],[3196,3393,"Kneel down, kiss my boots,"],[3393,3526,"and I might let you crawl out."],[4274,4481,"I have another deal for you."],[4517,4801,"You let me spend a night with your wife."],[5605,5759,"Are you insane?"],[5759,5952,"He's the Crimson Bat's boss!"]],"17":[[13,176,"You're dead meat, man."],[223,390,"He's just been washed up vet, okay?"],[390,600,"Mooching off his wife, just shoot him already!"],[633,787,"Don't hurt him!"],[1174,1317,"You see, there's two problems"],[1317,1471,"with the way that you're holding your weapon."],[1544,1855,"One, his grip is weak, so his aim is gonna be off."],[1885,2175,"And two, his brass is gonna recoil right in his face."],[4761,4901,"What just happened?"],[4981,5205,"Oh my gosh, he just took out four people"],[5205,5341,"all with a kid by his side!"],[5382,5472,"So what?"],[5472,5715,"I have one hundred guys out there."],[5749,6062,"Just a word and this place becomes a war zone."],[6062,6129,"Is that the case?"],[6162,6435,"If so, I should probably go wipe this slate clean."],[6579,6690,"I'll be right back."],[6733,6783,"Peter!"],[6926,7123,"Don't worry, Mommy. A hundred men"],[7123,7364,"is just a warm-up for my daddy."]],"18":[[13,216,"Hey, are you still running your mouth?"],[306,497,"Light him up."],[904,1224,"Boss, he's shooting us down! He's too fast!"],[1264,1541,"You useless fool! There's 100 of you!"],[2022,2228,"Mike, flank him now!"],[2258,2373,"We're already down."],[2373,2504,"He's everywhere!"],[2572,2759,"Hey, what the hell is going on?"],[2836,2982,"It's just one guy!"],[2992,3276,"That's no guy, it's a damn ghost!"],[3556,3736,"You think Peter will really take them all out?"],[3750,3833,"There's no way!"],[3833,4054,"There's like a hundred men and they all have guns!"],[5605,5742,"Are you okay?"],[5812,5905,"Not a scratch."],[5999,6206,"I might have just taken out the biggest gang"],[6206,6302,"in the country."],[6439,6533,"What's wrong?"]],"19":[[13,153,"Still thinking about calling backup?"],[233,347,"No way, boss."],[397,503,"I was wrong."],[503,627,"I shouldn't have come here!"],[724,927,"Peter, you're not really just a vet, are you?"],[1301,1391,"I, uh..."],[1391,1621,"Uncle Phil, when do you ever cower"],[1621,1806,"for something like this trash?"],[1835,2112,"You are the boss of the biggest gang in this city!"],[2128,2235,"Just crush him!"],[2716,3136,"My only regret is to share blood with fools like you!"],[3306,3453,"I'm done, man. I'm done."],[3506,3700,"Can I only beg you to spare me..."],[3710,3780,"Fine."],[3823,3933,"I'll let you walk out of here"],[3933,4017,"on one condition."],[4017,4204,"You rebranded your gang as a charity."],[4204,4387,"No more bad deeds, only good ones."],[4387,4507,"Do you understand?"],[4517,4544,"Okay."],[4604,4674,"Okay."],[4741,5138,"Deal. Crimson Bats, from now on, are a charity."],[5545,5665,"As for you two..."]],"20":[[16,292,"I'm sorry. It was all my fault."],[313,420,"I'm a terrible father."],[453,636,"My son insulted your daughter."],[643,817,"Please! Forgive us!"],[1027,1317,"Peter, I didn't know you were this powerful."],[1317,1454,"How about we, you know,"],[1454,1705,"forget the past and start anew?"],[1878,2141,"Mary, you bitch! Are you serious?"],[2155,2262,"Shut up!"],[2262,2445,"It's all your fault anyway, okay?"],[2445,2549,"Why do I even need you?"],[2736,2982,"Greed and desperation don't look good on you two."],[3166,3243,"Let's go."],[3823,3910,"Peter?"],[4784,5001,"Dad, this place is so big!"],[5051,5235,"Well, it's our house now."],[5375,5542,"You two make yourselves at home."],[5542,5642,"I'm gonna go freshen up."],[5668,5755,"Okay."],[6322,6489,"Alright, careful kiddo."],[7013,7226,"Hey Sydney, where's Leslie's room?"],[7530,7600,"Sydney?"],[9839,9979,"Sydney?"]],"21":[[46,156,"Sydney?"],[1091,1261,"Don't move."],[1351,1524,"If you let go, this falls."],[1604,1708,"I know."],[2221,2309,"I'm sorry."],[2662,2759,"Peter..."],[3149,3249,"Mommy?"],[3293,3490,"What is it, sweetheart?"],[3526,3730,"Nothing, just felt like calling you."],[4280,4417,"She's crazy."]],"22":[[1071,1263,"This better be life or death."],[1511,1658,"30 billion."],[1658,1885,"The military wants a full-scale chip order?"],[2639,2772,"Military chips?"],[3299,3426,"Tactical smart chips?"],[3433,3540,"That's right!"],[3550,3787,"Top-priority bid is Project Nightingale."],[3787,3900,"The competition is brutal,"],[3900,4120,"so there is no guarantee we'll land it."],[4177,4277,"You'll get it."],[4297,4494,"It'd be amazing if we did."],[5375,5425,"Roman."],[5512,5705,"Is there a new military chip deal on the table?"],[5822,5912,"Project Nightingale."],[5945,5992,"Good."],[6069,6152,"I made my choice."],[6276,6401,"Award it to the Greenfield Group."]],"23":[[23,126,"Understood."],[126,317,"I'll confirm the Greenfield deal immediately."],[350,420,"There's one more thing."],[487,650,"The President's officially confirmed you"],[650,840,"as Deputy Director of strategic planning."],[944,1150,"He's scheduled a meeting for 1400 hours."],[1161,1250,"Position accepted."],[1281,1461,"Tell him I'm on vacation."],[1474,1551,"Understood."],[1921,2096,"Peter, it's incredible."],[2158,2329,"Rita just called and we got it."],[2352,2469,"Project Nightingale."],[2469,2772,"It's our biggest preliminary contract in history."],[2792,2932,"Congratulations."],[2946,3207,"You know, ever since I married you, my luck's..."],[3207,3476,"my luck has just skyrocketed."],[3656,3847,"We're having a charity banquet tomorrow."],[3923,4007,"Come with me."],[4087,4190,"What about Leslie?"],[4284,4391,"Of course she can come."],[4481,4668,"There's a supervised children's club,"],[4668,4818,"and we're family now."],[6760,6840,"Arrived a bit early."],[6880,7065,"Figured I'd scout the room first."],[7323,7456,"Isn't that Peter?"]],"24":[[43,103,"Tim."],[170,350,"Greenfield just landed Project Nightingale"],[350,560,"with a budget of $30 billion."],[600,740,"Congratulations."],[964,1230,"Caden, I heard your deal with us got axed."],[1287,1724,"Well, we accidentally pissed off your sister's husband."],[1745,1818,"She cut us off."],[1845,1985,"Sydney? Please, half sister."],[2072,2303,"I'll get her kicked off the board sooner or later."],[2318,2494,"Don't worry, Caden, we'll still be partners."],[2512,2866,"And I will be the true CEO of Greenfield."],[2892,3009,"That's great news."],[3039,3213,"Well, if that's the case,"],[3273,3614,"here's to the real Greenfield CEO."],[4060,4217,"That's him, Peter."],[4217,4277,"Who?"],[4304,4492,"Your sister's husband."],[4514,4697,"You seriously don't recognize him?"],[4748,5001,"I heard she married some guy to unlock the trust fund."],[5025,5114,"Fake marriage."],[5141,5218,"Obviously."],[5288,5588,"Come on, let's go teach this clown a lesson."],[5929,6042,"Contract husband."],[6112,6293,"This is for real players."],[6293,6419,"Somebody get lost, yeah?"]],"25":[[36,106,"Who are you?"],[153,296,"This is Tim Greenfield."],[337,457,"VP of Greenfield Group."],[510,603,"Sydney's younger brother."],[660,804,"Rightful heir to the company."],[834,904,"Hey, stop it."],[904,964,"Brother!"],[1024,1149,"Well, that makes us family."],[1161,1229,"I'm Peter."],[1229,1318,"Syney's husband."],[1554,1781,"Freeloader living off Sydney?"],[1821,2001,"Touching you might give me fleas."],[2205,2342,"Where is my sister anyway?"],[2355,2542,"Doesn't want to be seen with her trophy husband?"],[2622,2689,"No."],[2699,2809,"She's finished up the contracts"],[2809,2920,"for those smart chips."],[2942,3056,"She'll be here soon."],[3199,3381,"Greenfield only got that deal because of me."],[3381,3543,"Roman Garner, Chief Engineer for the military,"],[3548,3630,"is my..."],[3630,3721,"personal client."],[3830,3953,"Roman Garner, huh?"],[4144,4274,"I think you're mistaken."],[4307,4409,"I believe my impact"],[4409,4585,"was much more important than yours."],[4624,4691,"You?"],[4768,4968,"Wait. Who are you again?"]],"26":[[76,337,"Tim, he's just a freeloader, okay?"],[337,483,"He's a washed-up vet."],[487,648,"Mooching off your sister."],[667,715,"Right."],[730,940,"My sister has always had a soft spot for"],[961,1096,"charity cases."],[1324,1594,"My sister is paying you to stick around, right?"],[1594,1763,"Whatever she's paying you, I'll give you double."],[1768,1822,"Walk away."],[1942,2073,"She loses you."],[2075,2230,"She loses the trust fund."],[2245,2482,"I become CEO of Greenfield."],[3513,3713,"Bet your army pension can't even sniff"],[3713,3790,"that kind of money."],[3930,4207,"I don't care who takes over the family business."],[4207,4308,"You insult the men and women"],[4308,4440,"who serve this country again,"],[4440,4584,"and you're not just an idiot."],[4671,4761,"You're an enemy."],[4921,5125,"Who are you to represent the army?"],[5168,5390,"Insult me again, and I'll have Roman Garner"],[5390,5588,"deal with you himself."],[5622,5681,"Call Roman."],[5702,6122,"See if he dares to talk to me without using sir first."],[6122,6355,"Who do you think you are, Roman's superior?"],[6423,6591,"Guards, come and deal with this guy."],[6591,6760,"Knock his teeth out one by one."],[6786,7003,"See if he still runs his lying mouth then."]],"27":[[110,186,"Tim?"],[200,487,"What were you planning on doing to my husband?"],[510,774,"He was disrespecting Mr. Garner."],[774,925,"I was just teaching him a lesson."],[945,989,"Hm."],[989,1076,"What happened?"],[1081,1208,"Tim here was trying to take credit"],[1208,1322,"for your military deals."],[1374,1514,"I was just setting the record straight."],[1534,1675,"That deal wouldn't have happened without me."],[1675,1831,"See, this military deals depended on"],[1831,1949,"only two things."],[1988,2227,"One, Sydney's tech is top tier."],[2238,2487,"Two, I vouched for Greenfield"],[2487,2696,"directly to Garner."],[2696,2772,"Personally."],[2792,3104,"So your efforts equate to about zero."],[3156,3209,"Please."],[3229,3447,"Someone like you goes into uniform"],[3447,3617,"and runs around like you own the place."],[3640,3794,"A guy like you wouldn't even breathe the same"],[3794,3933,"air as someone like Garner."],[4110,4272,"Better go get this guy's brain checked."],[4297,4374,"I trust him."],[4464,4587,"He stood up for me,"],[4587,4811,"and even if Garner wasn't involved,"],[4811,4927,"I would still choose Peter."],[4961,5031,"It's nice to hear."],[5031,5248,"A little more faith wouldn't hurt though."],[5248,5529,"I thought your relationship had been terminated."],[5568,5860,"Seems Mr. Caden and his wife"],[5860,6026,"are no longer welcome here."],[6059,6179,"I invited them."],[6309,6520,"Sydney, you know, you're really gonna let"],[6520,6856,"this local boy of yours ruin deals with VIPs?"],[6946,7107,"They threatened my daughter"],[7107,7279,"and insulted my husband."],[7320,7529,"It's not petty at all, and it would be wise"],[7529,7707,"of you to remember the family name."],[7731,7854,"You two deserve each other."],[7944,8081,"Good thing I brought backup."],[8118,8281,"Real backup."]],"28":[[16,183,"Bro, I have someone here"],[183,276,"you need to take care of."],[276,387,"Break his legs."],[387,552,"Make sure he never walks again."],[1000,1127,"Tim, maybe that's..."],[1127,1464,"Relax. Coward, worst case, I'll bury them in lawsuits."],[1558,1634,"Now kill him."],[1641,1780,"That's not really the problem."],[2108,2445,"Where is the punk causing trouble over here?"],[2492,2579,"This guy."],[2579,2682,"Send him to the hospital."],[2866,3036,"Oh, Phil."],[3036,3186,"You're the one who's supposed to beat me up?"],[3263,3333,"Interesting."],[4170,4357,"What the hell, man?! You hit the wrong guy!"],[4357,4531,"Him, Peter!"],[4531,4821,"You freaking idiot, he is my boss!"],[4944,5091,"Who the hell is this Peter guy?"]],"29":[[0,213,"I paid you, Phil, and this is what I get?"],[236,471,"Boss, you feel better or you'll want me"],[471,653,"to smash his face in again?"],[910,1007,"What are you all looking at?"],[1127,1157,"Tim."],[1161,1467,"Remember whoever Peter is, he's no joke in a fight."],[1498,1675,"He took down the entire Crimson Bats"],[1675,1761,"alone two days ago."],[1761,1871,"Who cares, okay?"],[1941,2259,"I've got Garner. One call and this place is Swiss cheese."],[2265,2499,"Boss, you know how the Crimson Bats"],[2499,2632,"are fried out right now."],[2632,2880,"If he really has some military backing,"],[2880,3016,"my advice would be we back down."],[3039,3280,"Your wife's safety and yours are more important."],[3406,3623,"Alright, you keep throwing the Garner name around"],[3623,3743,"like some kind of shield."],[3763,3897,"How about I just call him up"],[3897,4100,"and then we'll really see who he answers to."],[4154,4327,"You? Like you have his number."],[4841,4911,"Roman."],[4974,5153,"You have three minutes to get your ass here."],[5188,5367,"Yes, sir. I'm almost there, sir."]],"30":[[33,193,"Sorry, Peter called."],[193,276,"There's been an emergency"],[276,343,"at the banquet."],[343,465,"So we're going to have to discuss the"],[465,620,"SkyEye cooperation another day."],[620,704,"Peter?"],[794,1034,"Peter Rogers? I'm going with you."],[1034,1114,"Yes, but why?"],[1137,1271,"Two years ago,"],[1271,1512,"I was kidnapped for a $100 million"],[1512,1644,"ransom from my dad."],[1668,1825,"Peter was the one who rescued me."],[1931,2068,"He was so cool."],[2068,2303,"I fell for him right there and then."],[2325,2387,"Very well."],[2435,2585,"Can you be fast please?"],[2605,2698,"I'm sure Mr. Rogers"],[2698,2826,"would want to see you straight away."],[3073,3223,"Peter, you really just called"],[3223,3402,"a top military officer?"],[3426,3480,"I also have the"],[3480,3569,"president's private line."],[3730,3817,"You want me to get him on the line?"],[3907,3970,"Could this Peter guy"],[3970,4101,"have some kind of unknown identity?"]],"31":[[13,192,"Look, don't fall for it, Tim, okay?"],[206,334,"I dated him for a year,"],[334,549,"there's no way he has this kind of pull."],[563,732,"Yeah, who knows if that call even connected?"],[787,867,"He's bluffing."],[867,1000,"Ha, Roman is not coming."],[1034,1131,"We have three minutes"],[1131,1251,"to find out, don't we?"],[1277,1451,"Three minutes won't change anything."],[1451,1553,"And you're afraid that it will?"],[1611,1786,"I'm not afraid of you, you peasant!"],[1981,2205,"Three minutes will cost me a long time."],[2228,2436,"My time is worth millions."],[2452,2693,"Three minutes is worth three million."],[2709,2799,"You gonna cover that?"],[2830,3053,"Oh, I can assure you"],[3199,3453,"my time is worth much more than yours."],[3533,3785,"But here, let's make a bet."],[3840,3903,"A bet?"],[3970,4074,"Garner doesn't show up"],[4074,4144,"in three minutes,"],[4150,4341,"then I owe you three million dollars"],[4341,4542,"right here, right now, out of my own pocket."],[4584,4625,"If he does..."],[4651,4674,"Impossible!"],[4728,5000,"If he does, you release all of your shares"],[5000,5188,"and assets in the Greenfield Group."],[5198,5399,"And you walk away from this family, forever."],[5495,5568,"Never coming back."],[5568,5648,"My shares and..."],[5705,5772,"inheritance?"],[5845,6013,"What? You're afraid you're gonna lose?"]],"32":[[23,283,"Tim, he's just a loser who married up, okay?"],[283,479,"There's no way he can get Roman here."],[497,706,"Yeah, he's bluffing, plain and simple!"],[764,1001,"Peter, Roman is a top military officer."],[1001,1181,"I can't even get a meeting with him."],[1214,1276,"Trust me."],[1381,1767,"Fine. But I don't want just three million, okay?"],[1788,2052,"I want her to give up all her shares,"],[2052,2325,"and the seat, as CEO."],[2802,2862,"Deal."],[2969,3196,"Betting Greenfield to some broke ex-soldier?"],[3196,3400,"Funniest thing I've heard in years."],[3470,3581,"I must thank you, Peter,"],[3581,3864,"for handing me Greenfield on a silver platter."],[4230,4317,"Roman,"],[4317,4470,"you have two minutes."],[4517,4599,"Almost there, sir."],[4657,4816,"Oh, and while you're at it,"],[4816,4894,"go ahead and add a"],[4894,5118,"couple more billion dollar deals for Greenfield."],[5121,5408,"Consider it gift from me to Sydney."],[5468,5518,"Yes, sir."]],"33":[[16,216,"More billion dollar contracts,"],[216,355,"are you serious?"],[397,530,"See what's happening, everybody?"],[530,679,"This guy is delusional."],[717,980,"One phone call, and Garner hands out billions."],[1027,1145,"That's total loss!"],[1167,1286,"Think about it, everyone."],[1286,1470,"If Garner finds out about this stunt,"],[1470,1579,"we're all ruined."],[1771,1879,"There's only one thing to do."],[2045,2523,"Cut ties with Sydney and make me CEO!"],[2575,2716,"Tim, you've been after my position"],[2716,2802,"this whole time?"],[2842,3049,"I've been sick of you for a long time."],[3049,3303,"I should have been CEO from day one."],[3343,3493,"Pull your contracts fast!"],[3493,3620,"You don't wanna go down with her."],[3670,3790,"Act fast!"],[3797,3976,"I'm cutting ties with Greenfield Group."],[4034,4137,"Cancel everything."],[4137,4339,"We want no part of this mess."],[4341,4606,"You are making a huge mistake."],[4611,4769,"No, they're making the right one."],[4798,4951,"Peter's just some fake husband,"],[4951,5121,"so you can get your trust fund."],[5128,5248,"And now you're treating him like a hero"],[5248,5327,"because he can"],[5327,5507,"command Roman Garner?"],[5535,5575,"Really?"],[5595,5702,"You better leave, Peter."],[5702,5835,"Or when Garner gets here,"],[5835,5993,"you'll be the first to be wiped out."],[6016,6245,"Or is it you, that's afraid of being erased."],[6269,6489,"Oh, Peter, please don't hurt me."],[6489,6606,"I'm so scared."],[6710,6855,"Military Chief Roman Garner"],[6855,7084,"confirms a strategic partnership with"],[7084,7191,"Greenfield Group."],[7217,7526,"Five new billion dollar contracts awarded!"]],"34":[[16,110,"That's impossible!"],[110,233,"The billion dollar contract"],[233,340,"was Garner's favor to me!"],[360,465,"There's no way there's more!"],[493,787,"Could Peter actually be so powerful?"],[910,1112,"Oh, I know! These new deals are"],[1112,1266,"clearly Tim's doing, right?"],[1291,1609,"One wasn't enough, so five is more like it."],[1634,1755,"Right! Exactly!"],[1765,1918,"See, even these esteemed guests"],[1918,2031,"won't believe your lies."],[2085,2271,"Step down, Sydney. Now!"],[2285,2369,"Never!"],[2439,2532,"You know what?"],[2532,2702,"I've been playing this for years anyway."],[2706,2972,"Bribing senators, back-end deals."],[3026,3179,"Even if you don't resign,"],[3179,3307,"they'll push you out anyway."],[3336,3420,"So what you're saying is that"],[3420,3508,"everyone here has been"],[3508,3610,"doing the same thing."],[3636,3773,"Bribing government officials,"],[3773,3897,"finding legal loopholes"],[3897,4064,"to exploit just to get rich?"],[4084,4164,"What else will they be doing?"],[4164,4273,"Welcome to the real world."],[4300,4377,"Well then,"],[4377,4601,"I guess I'll just invite my friends over the IRS"],[4601,4831,"to the biggest seafood buffet they've ever seen."],[4831,4956,"So many fat fish swimming around."],[4956,5083,"They won't know where to start."]],"35":[[3,216,"The IRS? Are you serious?"],[223,352,"Did your paranoia switch"],[352,531,"get flipped on recently?"],[537,730,"Please, not even Mr. Garner"],[730,820,"could pull this off."],[820,1008,"And you think we'll believe you could"],[1008,1134,"do it with just one phone call?"],[1147,1224,"Yeah, Peter."],[1247,1418,"Mooching off Sydney is one thing,"],[1418,1601,"but spouting these lies infront of her?"],[1648,1703,"Really?"],[1718,1985,"You're a loser with no job, no income."],[2125,2297,"Where's this real power coming from?"],[2535,2649,"You'll see soon enough."],[2686,2739,"And one more thing."],[2759,2930,"Stop touching me with your filthy hand."],[2969,3063,"Son of a..."],[3116,3196,"Guards!"],[3620,3797,"Tim, what do you think you're doing?"],[3827,3940,"What do you think I'm doing?"],[3940,4102,"Putting this garbage back where it belongs."],[4110,4207,"Get him!"],[4614,4691,"IRS?"],[4921,5055,"Audit notices?"],[5055,5275,"Five million of fines? What the hell?"],[5308,5448,"Three million in penalties?"],[5448,5578,"It will wipe out my company!"],[5578,5789,"So Tim, you still think I was bluffing?"],[5789,5875,"This can't be real."],[5875,6121,"How can you actually summon the IRS?"],[6142,6262,"Who the hell are you?"]],"36":[[3,183,"Is Peter really this powerful"],[183,343,"that I completely misjudged him?"],[343,473,"Is it too late to fix this?"],[473,590,"My company's on the line."],[590,731,"I can't afford to go bankrupt!"],[737,887,"Right. We forget about pride."],[887,971,"We need to survive!"],[1007,1141,"Calm down, you cowards!"],[1141,1261,"When Garner gets here"],[1261,1374,"and those five million dollar"],[1374,1474,"deals go through,"],[1474,1651,"your stocks will skyrocket."],[1651,1785,"You just gotta get rid of this guy,"],[1785,1936,"and everything will go back to normal."],[1948,2112,"You think these two will still listen to you?"],[2132,2349,"Shut up, you know. This is all staged."],[2349,2530,"Maybe they just had tax notices or something."],[2530,2649,"Why didn't I get one, huh?"],[2652,2800,"Well, let's finish this the simple way."],[2819,2906,"Ask them."],[2906,3077,"Who do they side with? Me..."],[3193,3259,"Or you?"],[3276,3353,"You know what?"],[3392,3599,"I know Garner. They'll all choose right."],[4020,4251,"Peter, please. Spare my company!"],[4251,4457,"I was blind, completely blind!"],[4768,4957,"Peter, we're so sorry. We're wrong!"],[4957,5100,"Give us another chance, please!"],[5155,5224,"What the hell!"],[5318,5438,"What is wrong with you?"]],"37":[[13,193,"Everyone sees the truth."],[193,379,"You're the only one still in denial."],[423,623,"Screw your truth! Bunch of lies."],[623,760,"There's no way he's this powerful."],[850,920,"How would you have known?"],[980,1064,"You didn't deserve to."],[1124,1327,"What's wrong with you? I know Garner personally."],[1354,1564,"You're the reason we're in this mess!"],[1564,1813,"I'm not losing my company over your ego!"],[1835,2035,"We're barely staying afloat, Tim."],[2118,2208,"You cowards!"],[2208,2339,"Open your eyes."],[2339,2516,"Peter just turned this entire banquet"],[2516,2607,"upside down."],[2607,2763,"He's beyond anything we can touch!"],[2829,2999,"Bullshit! That is impossible!"],[3009,3160,"Don't you get it now, Tim?"],[3175,3404,"You built your wealth with dirty tricks"],[3404,3584,"and that never lasts."],[3596,3723,"Lies! All of it!"],[3723,3834,"If he was this powerful,"],[3834,3996,"why didn't he say so before?"],[4007,4083,"Why would you have known?"],[4130,4240,"Screw you!"],[4294,4422,"Okay, there's no way"],[4422,4671,"you could do all this and get away with it."],[4671,4798,"Tim, are you insane?"],[4798,4904,"Get out of the way!"],[4941,5031,"Sydney, what are you doing?"],[5045,5212,"Protecting my husband."],[5218,5342,"Drop the gun, you idiot!"]],"38":[[16,127,"Drop the gun, you idiot!"],[150,220,"You're here!"],[286,344,"Peter?"],[360,437,"Roman, you're here!"],[503,627,"Now you're done for, Peter."],[657,855,"And everyone here who followed him"],[855,997,"are going down with him."],[1017,1177,"Peter's been spilling nonsense all night,"],[1177,1426,"saying you're just his subordinate."],[1431,1491,"Can you imagine that?"],[1511,1692,"Going around saying that he owns you!"],[1705,1789,"What did you say?"],[1858,1929,"Exactly!"],[1948,2152,"And you see these five billion dollar deals,"],[2152,2225,"he did them, and"],[2225,2417,"especially you calling the IRS,"],[2417,2591,"like he runs the government?"],[2615,2762,"And he's been going around insulting me."],[2762,2867,"Put him in his place."],[2922,2973,"Roman."],[3003,3154,"Am I no longer authorized"],[3154,3247,"to give you orders?"],[3276,3353,"Shut up, dirtbag!"],[3390,3495,"Stop spilling this nonsense!"],[3636,3710,"Shut your mouth!"],[3773,3897,"You're the one begging for death!"],[3927,4024,"Why are you hitting me?"],[4024,4157,"He's the one that insulted you!"]],"39":[[60,277,"Sir, I'll cut all ties and cooperation"],[277,371,"with him immediately."],[430,687,"Just please... go easy on me."],[714,964,"Wait, Peter's actually a big deal."],[1000,1134,"How did I not see this?"],[1167,1399,"Thank God we came to our senses of what we did."],[1441,1550,"Tim almost ruined us!"],[1601,1785,"Tim is a good liar after all."],[1785,1878,"You two fell for it."],[1951,2182,"Why are you saluting him for?"],[2182,2300,"He's a nobody!"],[2375,2598,"Because he's not just a man who saved my life."],[2632,2880,"He's also a man that you can't afford to offend."],[2944,3042,"I owe him everything."],[3076,3314,"You should get down on your knees and apologize,"],[3314,3582,"otherwise I'll blacklist you everywhere."],[3773,3902,"Peter, I'm sorry."],[3902,4096,"Take everything, my money, my company."],[4140,4293,"Please. Sydney, help me. I'm sorry."],[4330,4474,"You don't feel remorse."],[4474,4656,"You just know now that you've lost."],[4774,4969,"Screw you."],[5008,5097,"This wouldn't have happened"],[5097,5198,"if it wasn't for you."],[5215,5349,"What are you talking about?"],[5375,5705,"You and your bullshit fake matters with this guy!"],[5705,5805,"If he hadn't showed up,"],[5805,5917,"none of this would have happened."],[5932,6191,"The company, the inheritance and everything!"],[6286,6369,"Go to hell!"]],"40":[[13,103,"Go to hell!"],[897,1183,"You could't lead a dog, let alone a company."],[1274,1351,"Are you okay?"],[2689,2787,"You'll regret this!"],[2809,3013,"I am the rightful heir of Greenfield!"],[3506,3606,"Peter."],[3630,3736,"Oh god, Peter, it's been..."],[3873,4176,"It's long time, and you' re as handsome as ever..."],[4220,4340,"Who the hell is that?"],[4340,4593,"She's clinging all over Peter right in front of Sydney!"],[4711,4821,"Sydney, I can explain-"],[4821,5070,"Excuse me, I don't know who you are."],[5075,5417,"But can you please unhand my husband?"],[5852,6092,"Oh my god. You're Catherine."],[6092,6304,"Like, the famous Catherine."]],"41":[[0,93,"What are you doing?"],[223,465,"It took me a long time to finally see Peter."],[653,732,"Catherine, stop."],[784,832,"Peter?"],[894,1146,"You are always on duty. I never got my chance."],[1181,1314,"But now that you're finally here,"],[1314,1503,"I'm not letting you slip away again."],[1695,1808,"I'm proposing to you."],[2022,2235,"Right here, right now."],[2285,2323,"What?"],[2349,2538,"This is the same Peter that I dated!"],[2552,2742,"How is Catherine head over heels for him?"],[2786,2972,"Forget that, she's proposing!"],[2972,3053,"Catherine,"],[3093,3273,"top superstar in the world."],[3303,3383,"My goddess!"],[3586,3857,"You can't propose to Peter."],[3890,4029,"Who are you, anyway?"],[4077,4236,"I've been seeing you clinging on Peter"],[4236,4318,"the whole time."],[4334,4446,"Are you trying to steal my man?"],[4461,4504,"Steal?"],[4597,4755,"I am Peter's wife."],[4818,4964,"And he is my husband."],[5362,5569,"What is happening?"],[5655,5912,"Peter's being fought over by both Catherine and Sydney?"],[5932,6133,"Not even James Bond gets this kind of attention."],[6159,6286,"What's Peter got going for him?"],[6393,6588,"This is insane!"],[6616,6813,"Did I completely miss my chance with Peter?"],[6833,6993,"Well, maybe if I left Caden right now,"],[6993,7147,"I could make that all work out a little bit better."],[7147,7323,"What the hell did you just say?"],[7460,7556,"You bitch!"],[7567,7755,"You think you deserve a man like Peter?"],[7821,8007,"How dare you hit me!"]],"42":[[0,154,"Someone like her..."],[154,309,"I can't believe it, Peter!"],[390,510,"How could you be married?"],[830,916,"And you chose her..."],[1097,1174,"Over me?"],[1237,1418,"I'm just as good as you are."],[1508,1569,"Maybe..."],[1648,1743,"Even better."],[2245,2484,"Fine! Then I'll make you pay."],[2659,2776,"I'll have my daddy"],[2829,3051,"in SkyEye Group to blacklist your company."],[3159,3433,"We will see how long your marriage lasts."],[3453,3588,"Catherine, that's enough."],[3693,3803,"Come with me."],[4174,4299,"Catherine, Sydney and I"],[4299,4494,"are in a contract marriage, okay?"],[4544,4800,"We can't just go around shutting down companies."],[4808,5011,"Greenfield has thousands of employees"],[5011,5241,"and if you shut it down, they'll lose everything."],[5258,5422,"It's a contract marriage?"],[5465,5612,"Yes, okay. But, the point..."],[5612,5665,"Okay, settled."],[5735,5969,"When that contract ends, you're marrying me."],[6142,6311,"What are you two talking about?"],[6586,6630,"Nothing."],[6703,6892,"Just post-divorce arrangement."],[6933,7144,"Peter? Is this true?"],[7200,7480,"Peter, tell her. Are you marrying me or not?"],[7510,7815,"I think... I think Leslie is waiting for me."],[7815,8066,"So I should go check on her."],[8066,8268,"Yeah... Bye."],[9696,9733,"Hello."],[9796,10099,"Sir, this is Brittany Radcliffe from the CIA."],[10103,10268,"Brittany, what's going on?"],[10357,10489,"We've obtained the intel."],[10520,10730,"Someone plans to assassinate Arno Dunk,"],[10730,11063,"SkyEye Group's CEO, and frame Sydney Greenfield,"],[11077,11264,"Greenfield's CEO, for the crime."]],"43":[[13,130,"Understood."],[130,457,"So, SkyEye Group and Greenfield Group"],[457,694,"are on the guest list for the gala in two weeks."],[747,874,"Is that the time frame?"],[940,1041,"That's correct, sir."],[1114,1203,"I'll handle it."],[2342,2518,"What's going on with you and Catherine?"],[2575,2625,"Why?"],[2732,2808,"Are you jealous?"],[2899,3001,"No."],[3103,3330,"But even Mr. Garner vows to you."],[3330,3430,"So who are you?"],[3493,3661,"This isn't the time."],[3672,3921,"Some truths are still classified."],[5278,5505,"You know, this whole charming rogue act"],[5505,5668,"is not really fooling me."],[5825,5924,"What are you hiding?"],[6026,6156,"What if I'm not acting?"],[6269,6469,"The truth always has a way of coming out..."],[6509,6670,"sooner or later."],[6689,6786,"How do you figure it?"],[7577,7825,"See? I always get what I want."],[7827,8034,"Seems we have a..."],[8034,8238,"sensual interrogation."],[8238,8304,"Yeah?"],[8378,8541,"And what if it is?"]],"44":[[36,166,"And what if it is?"],[3580,3747,"Richard, I need your help, okay?"],[3747,3907,"I've been kicked out of my own family."],[4024,4083,"Useless."],[4194,4371,"You couldn't even handle a simple situation."],[4394,4538,"It's not my fault, okay?"],[4567,4658,"Blame Sydney."],[4708,4798,"How was I supposed to know"],[4798,4981,"she'll marry this wild soldier?"],[5031,5143,"Do you still want Greenfield?"],[5171,5288,"Oh God, yes. Just..."],[5378,5448,"Tell me what to do."],[5468,5709,"There's a gala in two weeks."],[5742,5797,"SkyEye"],[5849,5969,"and Greenfield will be there."],[5992,6273,"Now I've sent in my men to pose as Greenfield."],[6306,6655,"Once they assassinate Mr. Dunk,"],[6783,6857,"Sydney's finished."],[6946,7188,"All you need to do is point a finger at Sydney,"],[7188,7279,"say it's her fault."],[7340,7407,"That's it."],[7474,7654,"Won't the Secretary of Defense,"],[7654,7816,"Hartman, be there at the gala?"],[7824,8061,"What if the DoW gets involved, you know?"],[8111,8225,"We get exposed."],[8225,8332,"Relax."],[8395,8590,"Tens of millions of dollars in bribes,"],[8605,9056,"and one billion dollars in future pipeline profit."],[9082,9435,"Once the dust settles, SkyEye would be mine,"],[9502,9647,"Greenfield would be yours."],[9806,9865,"Are you in?"],[10030,10095,"I'm in."]],"45":[[100,150,"Leslie."],[245,433,"Pull all inbound data traffic from the banquet."],[505,610,"Employee rosters,"],[635,725,"badge logs,"],[773,935,"surveillance blind spots."],[975,1076,"Already did."],[1151,1490,"Greenfield Staff database was taxed six hours ago."],[1524,1851,"The attack signature traces back a shell company"],[1851,1967,"linked to SkyEye."],[1988,2232,"Someone cloned ten employees ID."],[2232,2537,"Two just got scanned in the gala's west entrance."],[2548,2675,"Any communication drills?"],[2690,2989,"One flag convo... Encrypted VOIP."],[2989,3105,"But I'm trying something..."],[3266,3581,"Get those clean, Greenfield badge, blame her."],[3581,3724,"Make it look personal."],[3747,3919,"That's the shooter, he's already inside."],[3937,4030,"And so am I."],[4277,4397,"I'm coming too!"],[4474,4611,"Don't even think about it."],[4631,4900,"You need eyes. I'll stay in the control room,"],[4900,4994,"just like in Madrid."],[5008,5267,"Fine. Set a mobile command."],[5302,5389,"You run point."],[5475,5667,"Already syncing drones."],[5820,5862,"Hartman."],[5922,6127,"Sir, we've got a problem. Someone's digging"],[6127,6274,"into Mr. Rogers."],[6289,6432,"Intel suggests a frame-up."],[6432,6526,"They're targeting his wife"],[6526,6696,"for the hit on Arno Dunk tonight."],[6696,6816,"Who is behind it?"],[6816,7071,"Richard Feynman, VP of SkyEye Group."],[7077,7307,"Peter's cover as Deputy Director"],[7307,7462,"of Strategic Planning holds."],[7480,7733,"He is untouchable for now."],[7794,8068,"Protect his family, warn Roman."],[8068,8340,"Tell him to tip off Arno and play along."],[8391,8631,"Put a tac team on standby outside."],[8635,8780,"Copy that, sir."]],"46":[[326,557,"Ladies, gentlemen,"],[557,768,"SkyEye is about to enter a new chapter."],[897,1054,"Soon to become the most powerful force"],[1054,1134,"in this country."],[1191,1388,"With Richard's backing, you'll all be richer"],[1388,1504,"than you could ever imagine."],[1591,1865,"We're backing the future, and the future starts now."],[1898,2072,"Cheers."],[2515,2802,"Arno Dunk is giving the keynote speech tonight,"],[2802,3012,"so try not to cause a scene."],[3076,3198,"It's just a defense contractor."],[3296,3385,"What's the big deal?"],[3473,3754,"You know, SkyEye is the most powerful private"],[3754,3926,"military firm in the world."],[3937,4100,"Even Secretary Hartman is here."],[4100,4267,"So if anything goes wrong,"],[4267,4337,"it won't be good."],[4421,4484,"Don't worry."],[4534,4629,"If everything goes south,"],[4701,4777,"I've got to handle it."],[4942,5000,"That's him."],[5048,5206,"Let's go show them who's in charge."]],"47":[[0,240,"This gala isn't for backwater trash like you."],[283,465,"I'm sorry. Who are you again?"],[490,776,"That's Richard Feynman, Vice President of SkyEye."],[840,981,"Show some goddamn respect!"],[990,1144,"Tim, what are you doing here?"],[1191,1298,"I thought you were ousted."],[1381,1620,"Loyalty always has a way of coming back."],[1638,1869,"Well, looks like you found a new pair of shoes to lick."],[1938,2040,"Unfortunately for you,"],[2132,2297,"they don't look like they're worth that much."],[2392,2465,"Chill out."],[2469,2575,"Who do you think you're talking to?"],[2575,2719,"Acting like you own place."],[2742,2796,"Who am I?"],[2879,3062,"Well, let's just say that Dunk doesn't have a clearance"],[3062,3132,"to know that."],[3146,3243,"So why would you?"],[3386,3422,"See?"],[3536,3634,"I don't chase drama."],[3717,3827,"Drama chases me."],[3907,4114,"Richard, Mr. Dunk in the security defense"],[4114,4258,"should be here any moment."],[4287,4434,"Do you really want to embarrass yourself,"],[4434,4610,"and throw a tantrum right in front of them?"],[4644,4844,"Yeah. The only thing embarrassing"],[4844,4961,"is standing right here."],[5111,5358,"Sydney, this is why we can't argue with clowns."],[5410,5573,"What did you say, you piece of shit?"]],"48":[[0,156,"You piece of shit."],[156,250,"What gives you the permission"],[250,337,"to talk to me that way?"],[420,521,"You sure you want to do this?"],[600,738,"In front of all these people?"],[1755,1949,"You think Garner's gonna protect you forever?"],[2005,2183,"Once these VIPs arrive, you're done."],[2242,2396,"Squashed like a bug."],[2435,2653,"Richard, you don't get to insult my husband."],[2653,2981,"Push me and I'll use every resource I have against you."],[3046,3219,"Babe, I got this."],[3253,3366,"I'm not just gonna stand here and let"],[3366,3643,"some second-rate exec bark at my wife."],[3713,3865,"What kind of man would that make me?"],[3907,3980,"Man?"],[4047,4322,"You're a freeloader with delusions of grandeur."],[4457,4557,"Sydney, when are you gonna get this"],[4557,4668,"lunatic committed?"],[4991,5239,"This VIP, you two are sweating so much over."],[5288,5361,"What's his name?"],[5522,5690,"I bet I already have him on speed dial."],[5695,5934,"Bullshit! He's millitary brass."],[6032,6211,"You think you're in some league above him?"],[6249,6459,"I don't know who you think you're referring to."],[6533,6840,"But from where I stand, there's no one in this room"],[6840,6995,"more important than me."]],"49":[[43,120,"You."],[173,287,"You think you're at the same level"],[287,390,"as tonight's guest of honor?"],[453,507,"That's right."],[547,790,"Well, that's rich. We all know tonight's"],[790,940,"guest of honor is the Secretary of Defense."],[1034,1275,"So what's next? You take orders from the President?"],[1331,1428,"You're not far off."],[1670,1835,"Well, you've got balls."],[1840,2043,"A washed-up grunt like you."],[2065,2223,"You know that kind of talk"],[2223,2360,"will get you buried."],[2360,2639,"No trial. No call. Just disappear."],[2639,2836,"Richard, that's enough."],[2872,3209,"Oh! I'll bury you so deep,"],[3309,3514,"your ghost will need clearance."],[3543,3619,"Yeah, Peter."],[3710,3810,"Garner can't save you now."],[3903,4054,"One call from Richard and..."],[4144,4173,"Poof."],[4287,4356,"You're dust."],[5058,5102,"What?"],[5168,5261,"Gone mad already?"],[5298,5345,"No."],[5438,5540,"Just giving your performance"],[5540,5691,"the applause it deserves."],[5782,5933,"You really think that's what power is?"],[6019,6207,"Intimidation in body bags?"],[6279,6412,"Power, leverage,"],[6429,6527,"fear is control."],[6603,6849,"People like you have dirt on the bottom of my feet."],[6870,6923,"Everyone here?"],[6996,7283,"Pigs lined up for SkyEye's slaughter House."],[7350,7405,"And we?"],[7537,7642,"We have the knives."],[7687,7824,"Oh, I can turn African presidents"],[7824,7964,"into ash over breakfast."],[8021,8067,"You?"],[8088,8191,"You're just an afterthought."],[8251,8294,"Good."],[8408,8603,"Then give a message to your boss, Dunk."],[8718,8888,"Tell him that his parasite,"],[8962,9073,"named Richard,"],[9202,9312,"I'm flushing him tonight."]],"50":[[43,155,"Peter, you're only still breathing"],[155,255,"because of your wife."],[340,565,"Now you think you can advise Arno Dunk?"],[573,704,"A guy that married up"],[704,858,"and lives off his wife's name."],[937,1069,"He wants to play kingmaker."],[1094,1218,"You're a joke, Peter."],[1241,1313,"And you, Sydney."],[1374,1541,"How's pretty boy in bed?"],[1594,1797,"How about you ditch the toy and be with a real man?"],[1965,2195,"Oh, what's that, you little bitch?"],[2225,2308,"Want me to break you?"],[2308,2517,"Kill Peter, and once he's gone, she's yours."],[2517,2633,"Oh."],[2635,2779,"I'll bend her over and make her"],[2779,3018,"scream over his dead corpse."],[3239,3313,"Apologize."],[3356,3435,"Now!"],[3435,3613,"Remove your hand, you little mutt!"],[3613,3717,"Peter, you lunatic."],[3770,4087,"Piss off Richard and the Greenfield family is ruined."],[4130,4246,"I won't ask you again."],[4364,4456,"Apologize."],[4554,4623,"Never!"],[4744,4937,"Then I guess you won't be needing this hand."]],"51":[[480,603,"Dad, hurry up!"],[633,723,"If we're any later,"],[723,921,"somebody's gonna steal Peter from me."],[1000,1211,"Sweetheart, relax."],[1211,1407,"No. I already made up my mind."],[1414,1558,"Today at the banquet,"],[1558,1821,"I'm going to announce our engagement."],[1898,2012,"Peter has to be mine."],[2088,2162,"Only mine."],[2308,2407,"We'll leave right away."],[2689,2865,"I guess you won't be needing this hand."],[2866,2929,"You're dead!"],[2949,3023,"All of you!"],[3043,3126,"Wait! Stop!"],[3126,3423,"Peter, stop! He's not worth it."],[3917,4080,"Oh, you'll regret this. Guards! Kill him!"],[4384,4527,"I'd love to see you try!"],[4748,4910,"Mr. Dunk, this man assaulted me"],[4910,4993,"and said you'd back him."],[5068,5142,"Dunk?"],[5221,5603,"Your so-called \"employee\" insulted my wife."],[5642,5808,"And then tried to attack me."],[5829,6022,"Still bluffing. You're toast."],[6049,6200,"You brainless fool!"],[6326,6521,"Do you have any idea who you're talking to?"],[6583,6669,"Mr. Dunk?"],[6886,7186,"Mr. Rogers is our guest of honor tonight."],[7910,8024,"No, it can't be..."]],"52":[[16,109,"No, it can't be."],[193,373,"The guest of honor is Secretary Hartman,"],[407,652,"the man who runs the global military machine?"],[674,1040,"Yet you thought it's smart to insult the man"],[1040,1219,"he trusts the most?"],[1244,1500,"Oh Richard, I must have been blind"],[1500,1661,"to even let you near a board seat."],[1685,1911,"You're officially dismissed from SkyEye."],[1971,2038,"Effective now."],[2085,2185,"You can't fire me,"],[2318,2448,"for offending a nobody?"],[2475,2635,"For disgracing this event."],[2649,3039,"And I'll have your name blacklisted"],[3039,3293,"throughout every defense firm."],[3353,3525,"From here to Geneva."],[3570,3887,"Good luck getting a lunch meeting after this."],[3967,4144,"Oh, you can't fire me."],[4200,4502,"I put this company's face,"],[4562,4721,"all over the internet and the web."],[4764,4841,"This is my company."],[4841,5015,"I've built this company from the ground up."],[5051,5238,"Well, then..."],[5398,5729,"I think this is your swan song."],[5832,6316,"Now you leave willingly, or be escorted out."],[6429,6739,"Not now. We still have the plan tonight, remember?"],[6836,7015,"Fine. I'll leave."],[7150,7460,"Break a leg, Mr. Dunk, and I'll be seeing you later."],[7801,8002,"Leslie, keep an eye on Richard."],[8094,8217,"I'm going after the shooter."]],"53":[[353,441,"Status update."],[487,727,"Micro-cams are live. He's on the north side,"],[727,927,"the one with the camera blind spot."],[940,1093,"The man in the press vest."],[2252,2360,"Signal trace active."],[2360,2603,"He's receiving commands from Richard."],[2732,2816,"Can you decrypt it?"],[2892,3057,"Target: Arno, confirm visual."],[3076,3329,"Wait for detonation to frame the woman in blue."],[3386,3426,"Sydney."],[3546,3797,"Ladies and gentlemen, good evening."],[3923,4247,"Tonight marks a new chapter in innovation,"],[4330,4424,"and security."],[5625,5722,"Back up slowly."],[7627,7821,"Execute now! What are you waiting for?"],[7884,7988,"Your time is up, Richard."]],"54":[[1177,1424,"Plan B. Lock it down now."],[2776,2819,"Good evening."],[2936,3035,"Sorry for the delay."],[3119,3209,"Technical issues."],[3283,3496,"Let's get something straight, Mr. Dunk."],[3583,3853,"You'll be retiring tonight and I will be taking over"],[3853,4077,"as CEO of the SkyEye Group."],[4240,4302,"You snake!"],[4354,4462,"I gave you everything."],[4484,4644,"This is how you repay me?"],[4731,4913,"You should have retired a long time ago."],[4924,5065,"Time for fresh blood, Mr. Dunk."],[5171,5258,"Richard Feynman."],[5438,5716,"You hired mercenaries to kill Arno Dunk."],[5809,5979,"That's attempted murder,"],[5982,6165,"and an act of domestic terrorism."],[6276,6365,"Big words, Peter."]],"55":[[30,382,"Big words, Peter, as is part of your proof."],[443,797,"Oh, you want proof? Give me 30 seconds."],[820,917,"30 seconds."],[987,1071,"If you don't have proof,"],[1071,1326,"I want you to get on your knees and beg."],[1351,1516,"Or tomorrow you'll become"],[1516,1728,"the news of fire and ash."],[1888,1969,"Richard Feynman?"],[2078,2255,"This folder contains everything."],[2308,2528,"Proof of your plot, weapons deal and"],[2528,2799,"assigned confession from your assassin."]],"56":[[16,120,"Sorry, who are you?"],[230,479,"Brittany Radcliffe, Director of the CIA."],[490,648,"And Mr. Feynman,"],[717,936,"we have enough evidence to put you away"],[936,1127,"for at least three lifetime sentences."],[1127,1352,"So you might want to consider to invoke"],[1352,1544,"your right to remain the fuck silent"],[1601,1827,"while it still matters."],[1888,2044,"Oh, lies."],[2175,2321,"It's all fake, a setup."],[2405,2551,"And you, who are you?"],[2551,2682,"I mean, really, who are you?"],[2899,3152,"This is Peter Rogers, the Deputy Director"],[3152,3268,"of Strategic Planning."],[3373,3478,"Oh my god..."]],"57":[[46,263,"Richard! Put the gun down!"],[333,655,"That is the director of the CIA."],[670,912,"And that is Peter's real identity."],[980,1104,"You need to accept that."],[1131,1257,"You dirty old bastard."],[1338,1408,"You set me up."],[1481,1618,"You think I'm some kind of fool?"],[1708,1791,"He's a nobody."],[1838,1935,"What? You think he's some kind"],[1935,2071,"of high ranking official?"],[2385,2490,"Game's over, Richard."],[2642,2776,"You have no moves left."],[2896,3069,"That's why you're wrong, Peter."],[3186,3276,"You see this?"],[3556,3636,"You know what it is?"],[3717,3810,"A trigger for a bomb!"],[4347,4496,"You're fast, I'll give you that."],[4521,4674,"But you're not as fast as bullets."],[5088,5125,"Leslie!"],[5228,5281,"Party mode!"],[5422,5475,"Now!"]],"58":[[56,232,"Oh, playing house with your little girl."],[253,318,"How adorable."],[433,526,"What are you waiting for?"],[570,623,"Fire!"],[1401,1537,"Night vision, you idiots!"],[1604,1745,"Daddy! Party time!"],[2232,2319,"Hold your ground!"],[2328,2523,"Find the goddamn light controls!"]],"59":[[400,533,"It's over, Richard."],[653,737,"Over?"],[794,959,"Oh, it's not over!"],[1070,1195,"I haven't lost."],[1204,1312,"I still have my ace."],[1458,1821,"Now, I told you, if I go down, we all go down together."],[1921,2202,"Sec two, sec three... Get on your knees and beg."],[2202,2505,"Before this whole place turns into one big crater."],[2505,2792,"Richard, you're not the only one..."],[2792,2881,"with a toy."]],"60":[[43,258,"What is that? AC remote from downstairs."],[258,502,"You think showing me some kind of toy"],[502,615,"is going to scare me?"],[1685,1845,"Your remote doesn't work anymore."],[1845,2031,"I built a signal jammer for Daddy."],[2075,2245,"Your bomb is totally useless now."],[2265,2361,"You big meanie!"],[2719,2896,"Hoo hoo, the bad guy loses."],[3263,3365,"Congratulations."],[3560,3633,"Take him away."],[3847,4001,"Charge him with attempted murder..."],[4104,4192,"and treason."]],"61":[[16,313,"Peter, now everybody knows your identity."],[313,437,"You can divorce Sydney, right?"],[503,588,"Let's get married."],[640,767,"What the hell are you doing?"],[810,1150,"Peter is my husband, both legally and emotionally."],[1254,1364,"Peter, you choose."],[1364,1455,"Who are you marrying?"],[1524,1592,"What now?"],[1654,1865,"Yeah, go on, Peter. Why don't you choose?"],[2022,2350,"Uh, I think I forgot to get a gift for Leslie, so..."],[2350,2574,"I should probably get going and do that"],[2574,2655,"and not forget."],[2655,2854,"So I'll see you two later, okay?"],[2899,3070,"-You're not going anywhere. -You're not going anywhere."],[3073,3296,"-Answer me. Now! -Answer me. Now!"]]}