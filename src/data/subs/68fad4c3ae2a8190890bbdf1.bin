{"1":[[162,321,"Spencer Realty is worth over"],[321,487,"one hundred billion dollars now."],[571,646,"Eliza,"],[696,821,"it's time you hand the company"],[821,946,"over to your stepbrother."],[1026,1096,"When you get married,"],[1096,1192,"everything you own"],[1192,1317,"will be Matt's anyway."],[1426,1601,"We're just looking out for you, sweetie."],[1634,1760,"I mean, no man wants a woman"],[1760,1856,"who's more successful"],[1856,1976,"than he is."],[1976,2060,"How are you supposed to get"],[2060,2164,"married like this?"],[2206,2302,"And don't worry, sis."],[2302,2369,"I'll take really good"],[2369,2489,"care of the company for you."],[2523,2723,"You can't even take care of yourself!"],[2948,3103,"What the hell is that supposed to mean?"],[3148,3328,"I started Spencer Realty."],[3428,3770,"I built this company from the ground up."],[3903,4091,"Why would I hand it off to a parasite"],[4091,4266,"who hasn't worked a day in his life!"],[4337,4496,"Oh, and Dad?"],[4575,4675,"If you still want your"],[4675,4846,"million dollar allowance."],[4975,5025,"Then..."],[5092,5313,"I would get your useless son"],[5392,5526,"out of my sight."],[5588,5663,"You..."],[5739,5880,"You ungrateful bitch!"],[5943,6051,"How dare you?!"],[6101,6218,"I am your father!"],[6218,6364,"Ungrateful?"],[6710,6810,"You have been living"],[6810,6948,"off of my money"],[6948,7161,"since I was sixteen years old!"],[7161,7382,"Spencer Realty is everything to me!"],[7474,7678,"I would rather die"],[7678,7778,"than hand this company"],[7778,7874,"off to Matt."],[9154,9242,"Then die."],[9401,9576,"I gave you a chance, bitch!"],[9676,10076,"I gave you a fucking chance!"],[10293,10435,"Bravo, son."],[10489,10635,"The bitch deserved it."],[11515,11607,"That's deep enough."],[11774,11916,"Help me roll her in."],[12750,12900,"Don't blame us, Eliza."],[12942,13100,"If only you'd listened to us."],[13163,13325,"Shut up, George."],[13325,13446,"She can't hear you."],[13517,13609,"Her precious company"],[13609,13751,"and all her millions,"],[13751,13947,"they all belong to my Matty now."]],"2":[[1493,1551,"Hey!"],[1743,1810,"I'll give you something to eat"],[1810,1943,"you filthy piece of shit!"],[3770,3887,"I'm sorry, Mr. Patton!"],[3887,4041,"I'll never do it again! Please, don't..."],[4200,4245,"Scram!"],[5201,5430,"No! Don't hit me! Don't hit me!"],[5543,5689,"It's okay, I won't hurt you."]],"3":[[433,613,"That's not what I was..."],[1146,1234,"Here!"],[1234,1388,"You should eat when you're sick."],[1401,1493,"Mr. Patton, please. We're going to be"],[1493,1589,"late for the blind date your"],[1589,1697,"stepmother arranged for you."],[1897,2052,"She wants to marry me off, only to clear"],[2052,2193,"her son's way to success."],[2377,2502,"Well, if that's what she wants,"],[2698,2794,"let's give it to her, shall we?"],[3048,3119,"Do you want to get married?"],[3290,3361,"Marry?"],[3557,3641,"What's marry?"],[3666,3824,"It means we'll be together forever."],[3887,4008,"If I marry you,"],[4233,4446,"can I eat lots of yummy food?"],[4491,4596,"Yes, absolutely!"],[4763,4833,"Okay!"],[5142,5313,"We could be together forever!"],[5434,5484,"Forever."]],"4":[[62,129,"Mr. Patton,"],[129,258,"you cannot marry this beggar."],[296,387,"You've spent the past ten years"],[387,492,"of your life being mistreated"],[492,642,"by your family so you can uncover"],[642,717,"the truth behind"],[717,804,"your mother's death."],[846,905,"And if you piss off"],[905,1017,"your stepmother now,"],[1017,1163,"your hard work will be for nothing."],[1242,1422,"Not to mention, this woman, she..."],[1539,1630,"She seems like she's got"],[1630,1739,"a few screws loose."],[1830,1956,"Come on, Phillip, look at her!"],[2064,2168,"She wouldn't hurt a fly."],[2302,2385,"She's perfect."],[2481,2606,"Now take her to the hospital."],[2811,2952,"You can call me Justin."],[2952,3128,"This is my friend, Phillip."],[3128,3261,"He's going to take you to the doctor"],[3261,3374,"and make sure you're okay."],[3382,3486,"Justin!"],[3541,3611,"Okay!"],[4191,4346,"The young lady's medical reports"],[4346,4479,"say she suffered a blunt force"],[4479,4550,"head trauma."],[4579,4708,"She has severe amnesia"],[4708,4779,"as a result."],[4779,4959,"So severe, in fact, that she has"],[4959,5109,"the mental capacity of a child."],[5125,5226,"I see."],[5309,5422,"Are you sure she'd be"],[5422,5530,"the right wife for you?"],[5559,5643,"Yes."],[5689,5751,"She needs someone"],[5751,5930,"to protect her, and I need someone"],[5930,6010,"to make my stepmother"],[6010,6106,"lower her guard."],[6177,6331,"By the way, I heard the CEO"],[6331,6468,"of Spencer Realty, Eliza Spencer,"],[6468,6552,"is missing."],[6581,6664,"Find out if it's true."],[6777,6865,"Thanks."],[7932,8045,"Justin!"]],"5":[[33,383,"Justin, why is your face all red?"],[504,625,"And hot!"],[625,771,"Are you sick?"],[1113,1317,"Your legs are all better!"],[1509,1655,"I've been faking my condition"],[1655,1830,"so my greedy family will dismiss me"],[1830,1981,"and let their guards down."],[1981,2106,"It's the only way I can find the truth"],[2106,2206,"about my mother's death."],[2373,2460,"This is my secret."],[2506,2610,"Okay, can you help me keep it?"],[2815,2969,"I won't tell anybody."],[3144,3299,"Okay, thank you."],[3478,3649,"I still don't know how to address you."],[3712,3778,"What's your name?"],[3853,3920,"Name?"],[5518,5705,"My name is..."],[5805,5943,"No, I don't know."],[5943,6081,"I don't know, I don't..."],[6081,6214,"I don't remember."],[6243,6343,"She can't even remember"],[6343,6393,"her name."],[6393,6560,"- Hey, hey. It's okay. - I don't remember."],[6669,6781,"I'll give you a name, for now."],[6819,7002,"Alright? Um..."],[7123,7248,"You like muffins, right?"],[7311,7390,"Yeah."],[7424,7574,"How about I call you Muffin"],[7574,7699,"when we're alone,"],[7699,7882,"and Lily when we're outside."],[7945,8008,"Okay!"],[8137,8220,"Muffin."],[8733,8846,"Justin."],[9017,9138,"I'm hungry."],[9196,9355,"Okay. Let's go get some dinner."],[9526,9693,"Shh. Secret."],[9901,10010,"Very clever, Muffin."],[11507,11599,"Justin, who are they?"]],"6":[[8,108,"That's my brother, Derek,"],[250,342,"and his wife, Kim."],[650,738,"What are you guys doing here?"],[763,905,"We heard you got married."],[905,984,"Mom wanted me to"],[984,1092,"check in on you two..."],[1180,1288,"Newlyweds."],[1292,1472,"Justin, I hear my new sister-in-law"],[1472,1626,"is special."],[1689,1843,"Wow, a cripple and a dimwit."],[1864,2006,"What a match made in heaven!"],[2006,2081,"Kim."],[2293,2406,"Well, you've seen us."],[2494,2573,"You can leave now."],[2623,2848,"Not so quick brother-in-law."],[2848,3023,"I brought you two a little wedding gift."],[3407,3486,"Hello?"],[3511,3591,"Mr. Patton,"],[3591,3728,"it's regarding Spencer Realty."],[3766,3891,"Okay, I'm listening. Go."],[4229,4320,"Come here, girl!"],[4375,4454,"Come here."],[4496,4617,"I have a little gift for you."],[4804,4900,"A gift for me?"]],"7":[[453,536,"Lily, come back!"],[570,656,"We don't need your gifts!"],[743,880,"What's wrong, Justin?"],[883,970,"Want more?"],[1123,1266,"Look at your pitiful home."],[1320,1393,"It's nothing compared"],[1396,1520,"to the family mansion."],[1600,1766,"Go on, take it."],[1803,1886,"I know you need it."],[1886,2043,"Justin doesn't have any money?"],[2120,2263,"That's right, Lily."],[2303,2446,"If you want to help your hubby,"],[2450,2556,"come take this."],[2723,2763,"Lily."],[3470,3610,"Wave a bone and she comes running"],[3610,3700,"like a little bitch."],[3753,3813,"Bitch?"],[3980,4123,"That's right, dummy."],[4126,4236,"Bitches."],[4240,4423,"Female dogs that bark."],[4453,4543,"Bark."],[4566,4620,"Woof!"],[4640,4746,"Woof, woof, woof, woof."],[4750,4823,"Kim!"],[4886,5070,"What the hell are you doing?"],[5116,5166,"I-"],[5236,5293,"Woof, woof!"],[5296,5423,"She's a bitch!"],[5663,5750,"I'm sorry,"],[5846,6013,"did you just call me a bitch?"],[6376,6416,"Lily!"],[6826,6960,"You fucking numbskull!"],[6983,7086,"You've gone too far!"]],"8":[[0,95,"Stop it!"],[95,212,"We can't afford"],[212,367,"to go against Justin yet."],[371,529,"I don't care."],[529,713,"This bitch just called me a bitch!"],[800,888,"You."],[888,1013,"Get on your knees"],[1013,1205,"and apologize to me right now."],[1222,1363,"Apologize?"],[1405,1589,"What is that to big a word for you?"],[1589,1739,"Well, you know how to kneel, right?"],[1739,1835,"Oh, yeah!"],[1885,1943,"Lily."],[2381,2681,"May you two rest in piece, forever."],[2702,2769,"Amen."],[2827,2902,"You..."],[2944,3207,"You think you're so clever, don't you?"],[3236,3332,"Kim, enough!"],[3390,3482,"Justin is my brother,"],[3482,3670,"you can't treat his wife like that!"],[3737,3920,"I'm so sorry."],[3920,4108,"Come on, we're leaving."],[4241,4379,"Oh, I almost forgot."],[4379,4525,"We're hosting a luncheon"],[4525,4646,"at my mansion."],[4646,4792,"You should bring your lovely..."],[4850,4921,"Wife."],[5092,5159,"You..."],[5296,5543,"I'm not finished with you."],[6039,6089,"Woof!"],[6268,6406,"You really had to go and mock"],[6406,6527,"Justin's wife, didn't you?"],[6560,6685,"Come on, Derek!"],[6685,6815,"Don't tell me you're scared of him."],[6815,6898,"He's a cripple."],[6956,7203,"Who can threaten my place as CEO of"],[7244,7357,"of our family's company."],[7432,7474,"I mean..."],[7536,7682,"I can't even believe it."],[7749,8012,"Justin really married a lunatic."],[8153,8375,"Well, in seven days,"],[8466,8629,"Matt Spencer will become"],[8629,8812,"the new CEO of Spencer Realty."],[8938,9025,"And then..."],[9079,9259,"I'm going to convince him"],[9309,9455,"to renew their contract with us."],[9538,9622,"Yeah..."],[9676,9826,"And once that happens,"],[9826,9901,"no one"],[9959,10110,"can dethrone me from Patton."],[10110,10289,"Especially not my pathetic"],[10289,10406,"handicapped brother."],[10548,10681,"Just wait and see, Justin."],[10839,10973,"I'm going to end you."]],"9":[[208,296,"Breaking news!"],[296,387,"According to sources"],[387,513,"close to the Spencer family,"],[513,713,"Eliza Spencer, the founder and CEO"],[713,925,"of Spencer Realty, is missing."],[1267,1443,"I would rather die"],[1443,1568,"than hand this company"],[1568,1664,"off to Matt."],[2147,2193,"Muffin!"],[2560,2744,"My head, it's so loud!"],[2773,2952,"Make it stop, make it stop!"],[2952,3115,"It hurts, Justin!"],[3136,3311,"It's okay, I'm here."],[3687,3778,"Something on the TV"],[3778,3983,"seems to have upset her."]],"10":[[567,633,"Mr. Patton."],[754,921,"Apologies, Mr. Patton."],[921,1030,"I didn't mean to interrupt."],[1088,1197,"Does your head still hurt?"],[1589,1705,"Why don't you try to get some sleep?"],[2427,2494,"What is it?"],[2540,2635,"Sir, we've verified"],[2635,2769,"Eliza Spencer's disappearance."],[2806,2961,"And, although Spencer Realty"],[2961,3086,"can't rival your own Justus Corp,"],[3086,3186,"they're still a major player."],[3257,3349,"Do we take this opportunity"],[3349,3482,"to acquire Spencer Realty?"],[3516,3636,"It's time to play my ace."],[3712,3812,"Acquire as many shares of"],[3812,3941,"Spencer Realty as you can."],[3999,4049,"Yes, sir."],[4567,4742,"Justin, I can't sleep."],[4925,5192,"Muffin, your room is next door, okay?"],[5609,5772,"You smell nice."],[6043,6181,"Thank you, Lily."],[6339,6506,"No. This is wrong."],[6535,6690,"She has a head injury, Justin."],[6752,6806,"Okay."],[6856,6944,"Let's go to bed, alright?"],[7232,7474,"I want to stay here with you."],[7649,7907,"Your hand is really warm, Justin."],[7907,7962,"Lily."],[9676,9797,"Do we kiss now?"],[9851,9947,"Where'd you learn that?"],[10001,10139,"I saw it on TV!"],[10189,10310,"When two people like each other,"],[10310,10368,"they kiss."],[10472,10556,"And I like you."]],"11":[[37,179,"Pull yourself together, man."],[179,241,"She doesn't even know"],[241,333,"what she's doing!"],[496,613,"We can't do that, Muffin."],[613,746,"Alright? Go back to your room."],[1618,1847,"I'm tired. Goodnight, Justin."],[3019,3153,"I wonder why my stepson"],[3153,3315,"would marry a nutcase?"],[3524,3666,"I wonder if she really..."],[3666,3816,"Oh, she sure is."],[3862,3987,"Who else would marry a cripple"],[3987,4083,"like Justin?"],[4154,4266,"I don't know, Kim."],[4404,4587,"There's something off about that girl."],[4979,5163,"Why don't we try a little test"],[5163,5276,"to make sure."],[6377,6477,"Lily."],[6610,6760,"You should watch your table manners,"],[6760,6906,"you'll embarrass Justin."],[6986,7173,"Here, I'll teach you."],[7691,7824,"Go ahead, eat it now."]],"12":[[0,54,"Go on."],[133,183,"Eat it."],[896,1017,"Quickly, now."],[2152,2318,"How is it? Yummy?"],[2331,2414,"Yummy!"],[2460,2669,"Aw, good girl."],[2769,2852,"Eat it, then."],[3107,3278,"Is that enough proof for you?"],[3303,3561,"My crippled stepson actually married"],[3561,3670,"this psycho."],[3728,3849,"There's no way he can take the"],[3849,4074,"CEO title from Derek now."],[4141,4333,"Things are looking up!"],[4371,4583,"Justin may be disabled,"],[4646,4884,"but he didn't have to settle for this."],[4884,4988,"Maybe it's because"],[4988,5138,"he's the illegitmate one."],[5138,5434,"No, no. Justin is not the illegitimate one."],[5522,5701,"Eva, she's the mistress."],[5734,5889,"After Justin's mother died,"],[5889,6031,"Eva and her son, Derek,"],[6031,6210,"were brought into the Patton family."],[6247,6452,"See, they're the illegitimate ones,"],[6452,6552,"not Justin."],[6552,6648,"Oh my God."],[6765,6877,"Good girl."],[6911,7136,"You make a perfect show dog"],[7136,7294,"for wheelchair Justin."],[7294,7461,"You gave me a cookie."],[7549,7699,"You're so nice!"],[7928,8033,"You should try some!"],[8033,8091,"Ew!"],[8091,8224,"Back off you moron!"],[8224,8366,"Stop that at once!"],[8558,8683,"Oh, Granny should try some too!"],[8683,8812,"You're a psycho!"]],"13":[[70,137,"You alright?"],[191,387,"Your stupid wife"],[387,567,"has ruined our luncheon!"],[650,855,"Playing around with dog food!"],[900,1172,"She is a disgrace to the Patton name."],[1172,1234,"You're the one ruining"],[1234,1334,"our family's name"],[1334,1430,"by insulting my wife"],[1430,1526,"in front of our guests!"],[1555,1710,"She attacked Kim!"],[1710,1897,"Kim was only being nice to her."],[1897,2139,"I was just trying to offer her food!"],[2189,2310,"But then, she's an imbecile,"],[2310,2410,"how would she know?"],[2410,2535,"She's not an imbecile,"],[2535,2631,"she's my wife."],[2631,2765,"And you're going to apologize to her"],[2765,2836,"right now."],[3103,3336,"I can't risk upsetting Justin."],[3336,3570,"Not until Derek gets full control"],[3570,3724,"of Patton Corporation."],[3724,3849,"Just be a bigger person"],[3849,3983,"and apologize."],[4087,4233,"But, Eva, you told me to..."],[4233,4316,"Shut up!"],[4316,4441,"Listen to me."],[4491,4575,"There will be plenty of time"],[4575,4667,"to do that later."],[4667,4859,"Right now we have to protect Derek."],[5117,5201,"Sorry."],[5438,5526,"Happy now?"],[5697,5955,"Betty, come take Lily to the bathroom"],[5955,6051,"for cleanup."],[6181,6293,"Miss, come with me."],[6293,6393,"No, I'll come with you."],[6393,6456,"Huh."],[6456,6735,"Looks like Justin actually likes"],[6735,6952,"this little fool of his."],[7044,7273,"I think it would be better if only"],[7273,7399,"Betty accompanied her."],[7482,7703,"You know, lady things."]],"14":[[316,400,"Lily."],[508,588,"Granny!"],[621,767,"Granny Eva is here!"],[792,1038,"Oh, don't call me Gram!"],[1213,1301,"Anyway."],[1568,1643,"Lily."],[1722,1935,"Is Justin treating you well?"],[1956,2089,"Justin!"],[2147,2293,"He's the best."],[2377,2552,"He gives me yummy food,"],[2552,2711,"and a comfy bed,"],[2811,2932,"and Kitty! Kitty the teddy."],[2932,3023,"Just everything!"],[3040,3261,"Well, you need to help him in return."],[3261,3478,"There's a lot of bad people"],[3478,3599,"who want to trick him."],[3687,3870,"So, I need you"],[3916,4066,"to tell me who he sees"],[4066,4387,"and what he does every day, okay?"],[4387,4608,"Granny wants me to spy?"],[4629,4763,"Exactly!"],[4763,5013,"Such a smart girl!"],[5221,5351,"Spying is bad,"],[5430,5543,"and Justin is nice,"],[5543,5684,"and I'm not going to spy on him."],[5718,5889,"You ungrateful brat!"],[6097,6318,"You do as I say,"],[6356,6577,"or I will toss you back on the street!"],[6631,6773,"Granny, you're hurting me!"],[6852,7061,"Don't you dare touch me!"],[8199,8283,"Who is it?"]],"15":[[0,91,"Mom?"],[362,446,"Mom, what did you do?"],[550,771,"This idiot attacked me, I had to!"],[859,963,"Do you think Justin..."],[963,1067,"Relax."],[1067,1217,"No one cares about Justin."],[1276,1480,"I just talked with Matt Spencer."],[1480,1639,"He's taking over Spencer Realty"],[1639,1768,"and he's going to secure my position"],[1768,1835,"at Patton Corp."],[1939,2035,"Soon, we'll be able"],[2035,2181,"to get rid of Justin and..."],[2289,2452,"This stupid piece of trash"],[2452,2585,"that he calls his wife."],[2623,2902,"I knew I could count on you, my son!"],[2965,3136,"Justin and his dumb bride"],[3136,3382,"can rot in hell now."],[4612,4683,"What's your name?"],[4683,4959,"No, I don't... I don't remember."],[5113,5276,"My name is not Lily."],[5338,5726,"I am the CEO of Spencer Realty."],[5860,6156,"I'm Eliza Spencer."]],"16":[[166,241,"Where's Lily?"],[296,350,"Lily..."],[462,563,"I haven't seen her."],[654,759,"Betty said she saw her with you"],[759,859,"in the vanity room."],[884,1030,"Well, I went to check on her,"],[1030,1146,"but she wasn't there."],[1217,1305,"Maybe she went"],[1305,1451,"back to the party already."],[1488,1555,"Lily, are you in there?"],[1555,1643,"We said..."],[1718,1801,"She's not in there."],[2139,2273,"If anything happens to my wife,"],[2348,2452,"you're responsible."],[2531,2723,"Are you threatening me?"],[3157,3319,"Ow, you son of a bitch!"],[3541,3653,"What do we do now?"],[3703,3841,"That dimwit. We don't even know"],[3841,3999,"if she's dead or alive!"],[4104,4237,"If Justin sees her..."],[4237,4408,"Well, if she's dead then"],[4408,4554,"we have to kill Justin, too."],[4688,4829,"Are you crazy?"],[4950,5255,"If Justin dies, we'll be the top suspects."],[5330,5497,"You can't kill him yet."],[5497,5651,"Not until you become the CEO"],[5651,5734,"of Patton."],[5872,6031,"Spencer Realty has my back."],[6097,6306,"We can just say that Justin and Lily"],[6306,6398,"were killed."],[6452,6527,"In a robbery."],[6619,6681,"Tragic."],[6765,6835,"Sudden."],[6835,6961,"And then I step in"],[6998,7319,"as Justin's grieving brother,"],[7411,7624,"to lead Patton Corp into a new era."],[7724,7828,"My era."],[7982,8041,"Muffin!"]],"17":[[221,300,"I can't reveal"],[300,462,"that I'm Eliza Spencer now."],[508,667,"I have to keep up the amnesia act"],[667,880,"until Justin and I get the upper hand."],[1096,1159,"Derek!"],[1197,1380,"Any last words, Justin?"],[2198,2448,"Yay! Pretty clown! Pretty clown!"],[2460,2598,"You smooth-brained bitch,"],[2598,2690,"I'm going to kill you!"],[2731,2773,"Lily!"],[3453,3607,"Don't play with that you idiot!"],[3703,3774,"Give it back."],[3824,3895,"Play?"],[3970,4104,"Wait, I've never seen a toy like this."],[4104,4183,"How do you play?"],[4229,4291,"Like this?"],[4425,4525,"Lily! No."],[4717,4763,"Derek!"],[4863,5188,"Justin, get the gun out of her hand!"],[5209,5259,"Lily."],[5342,5522,"Be a good girl and give me the gun."],[5593,5651,"Please?"],[5855,5943,"Okay, Justin."],[6431,6531,"Now tell me what happened."],[6690,6769,"How'd you get hurt?"],[6915,7040,"The dimwit probably fell."],[7107,7261,"Get used to it hot wheels."],[7298,7353,"That's what happens"],[7353,7549,"when you marry a fucking dumbass."],[7957,8145,"I told you not to disrespect my wife."]],"18":[[12,191,"I told you not to disrespect my wife."],[400,546,"Next time you insult my wife,"],[588,684,"this bullet goes inside of you!"],[1046,1117,"Tell me."],[1222,1322,"Did someone hurt you?"],[1330,1488,"Justin, your family mistreats you"],[1488,1651,"because they think you're a cripple."],[1697,1851,"Even if I tell you the truth,"],[1906,2006,"you can't help me."],[2256,2348,"I don't know."],[2444,2648,"It hurts, Justin. My head hurts!"],[2681,2894,"That lazy maid, Betty."],[2894,3094,"I told her to watch over Lily"],[3094,3224,"and look what happened."],[3224,3486,"I mean, poor Lily."],[3486,3862,"She must've slipped and fell accidentally."],[3862,4041,"Let me call a doctor."],[4041,4129,"There's no need."],[4308,4400,"We're out of here."],[4838,4913,"Derek."],[5021,5246,"Why does Justin seem different"],[5246,5530,"from usual. That gun stunt."],[5555,5651,"It's nothing."],[5751,5914,"Cripple just wants to be a hero."],[5972,6051,"We should've killed him"],[6051,6156,"when we had the chance."],[6156,6352,"Well, after you take over Patton Corp,"],[6410,6527,"we can do whatever we want"],[6527,6810,"with Justin and his airhead bride."],[7278,7415,"Sir, Derek has Matt Spencer"],[7415,7553,"soon-to-be CEO of Spencer Realty"],[7553,7624,"on his side."],[7736,7791,"Should Justus Corp"],[7791,7878,"take advantage of it?"],[8058,8212,"Why don't you get some rest, Muffin?"],[8249,8358,"Alright? I'll see you later."],[8546,8616,"Okay!"],[8933,8996,"Let's get to work."],[9718,9922,"Eliza Spencer it is time for you"],[9922,10047,"to get to work as well."]],"19":[[196,325,"Jesus Christ."],[325,492,"He's already taken over my office."],[500,558,"Matt."],[558,759,"I am going to get back everything"],[759,963,"that you have stolen from me."],[975,1059,"Oh..."],[1105,1297,"Matty, you must be so exhausted"],[1297,1443,"after all those meetings."],[1451,1526,"Mom!"],[1572,1676,"Call me Mr. Spencer when"],[1676,1789,"we're in the office."],[1956,2056,"You know..."],[2056,2256,"it really is nice to be in the CEO's chair."],[2314,2414,"No wonder Eliza didn't want to"],[2414,2494,"give up her company."],[2610,2694,"Her company?"],[2815,2969,"The only child I see is you, Matt."],[3028,3119,"You deserve this."],[3365,3445,"But we still don't have"],[3445,3545,"the signet ring."],[3582,3632,"Okay?"],[3791,3987,"Without that ring, I'll have no legitimacy"],[3987,4145,"as CEO, okay? It is the fucking key"],[4145,4250,"to everything!"],[4375,4525,"That bitch is still causing problems"],[4525,4617,"beyond the grave."],[4625,4750,"Don't worry about that Matty."],[4750,4871,"She's missing."],[4913,5038,"And you're the next of kin."],[5055,5134,"It makes sense that"],[5134,5246,"you take over the company."],[5276,5388,"Ring or no ring."],[5526,5626,"I think it's time."],[5718,5893,"Tomorrow we announce"],[5893,6231,"Eliza Spencer, CEO of Spencer Realty"],[6364,6473,"is dead."],[6489,6656,"My own dad is celebrating"],[6656,6744,"my death."],[6881,7002,"Don't worry guys."],[7002,7219,"Karma will take real good care of you."],[7219,7336,"I'll make sure of it."],[7336,7436,"Hey, who are you?"],[7653,7757,"Are you a Spencer employee?"],[7899,7949,"You!"],[8045,8212,"That's... Is that Eliza?"],[8295,8379,"Get her Matt!"]],"20":[[8,50,"Matt!"],[83,133,"Get her!"],[588,675,"Did you get a clear look?"],[696,775,"Was it Eliza?"],[788,917,"I couldn't tell with that mask on."],[925,1017,"I'm not sure either."],[1163,1259,"Is that brat still alive?"],[1292,1451,"We buried her with our own hands!"],[1484,1543,"She should be"],[1543,1664,"a rotting corpse by now."],[1680,1839,"Whoever this Peeping Tom is"],[1839,1935,"she must've overheard"],[1935,2010,"our conversation."],[2047,2135,"We must catch her!"],[2227,2327,"And if it's really Eliza..."],[2377,2481,"This time I'll make sure to slit"],[2481,2656,"her throat so she's really dead."],[3332,3449,"Hey, stop right there!"],[3937,3999,"Fuck!"],[4295,4491,"Mom, Dad, block the exits!"],[6952,7086,"I've got you now bitch!"]],"21":[[20,175,"There's no way out of here sweetheart!"],[1539,1672,"Aren't you Justin Patton?"],[1672,1760,"What are you doing here?"],[1797,1893,"I heard you're about to become"],[1893,2031,"the CEO of Spencer Realty,"],[2031,2185,"so I came to congratulate you."],[2281,2339,"Yeah, more like come"],[2339,2439,"to butter me up, huh?"],[2473,2598,"Well, you're too late because I already"],[2598,2711,"promised to help your brother, Derek."],[2736,2827,"Ah, what a shame."],[2869,3057,"Well, in that case I'll be heading out."],[3073,3123,"Wait."],[3153,3282,"No, you can leave but..."],[3345,3445,"That woman stays."],[3578,3841,"Justin, he's scary."],[3853,4020,"Apologies, my wife gets frightened"],[4020,4087,"very easily."],[4108,4225,"What business do you have with her?"],[4250,4408,"Oh, this is your braindead wife,"],[4408,4471,"I've heard of her."],[4508,4679,"Hey, watch your mouth, Mr. Spencer."],[4704,4775,"Why was she sneaking"],[4775,4854,"around my office?"],[4900,5013,"Why was Lily sneaking around"],[5013,5096,"Spencer Realty?"],[5209,5309,"I met her around the same time"],[5309,5451,"Eliza Spencer disappeared."],[5518,5718,"Could she be..."]],"22":[[0,283,"No, Eliza Spencer is known to be"],[283,458,"a sharp and astute business woman."],[529,650,"And Lily..."],[713,850,"Lily's so naive."],[884,980,"So childlike."],[1038,1138,"Apologies..."],[1217,1514,"Mr. Spencer. I lost sight of my wife"],[1514,1651,"when I was heading to your office, so..."],[1705,1835,"Sorry for the trouble, but..."],[1860,1922,"Huh."],[1976,2122,"Seems like we were mistaken."],[2147,2352,"Well, we'll be heading out now"],[2352,2452,"so goodnight."],[3624,3757,"Yeah, Derek, I..."],[3899,4012,"I need your help with something."],[4358,4450,"Lily..."],[4533,4696,"You should be in bed at home."],[4771,4854,"How'd you get here?"],[5005,5176,"I missed my Justin,"],[5176,5301,"so I came to find you!"],[5463,5559,"I want the truth."],[5680,5801,"Who are you really?"],[5868,5939,"And how do you know"],[5939,6006,"Matt Spencer?"],[6010,6177,"I can't tell him who I am just yet."],[6177,6314,"Not until we both get back"],[6314,6452,"what our families stole from us."],[6514,6685,"Think Eliza... Think! Think!"]],"23":[[70,158,"What was that?"],[216,308,"Kissing!"],[308,425,"When two people like each other"],[425,483,"they kiss!"],[675,859,"Don't be mad Justin!"],[859,1009,"Pretty please?"],[1042,1109,"You really don't know what's"],[1109,1205,"going on, do you?"],[1680,1772,"No more running around"],[1772,1876,"willy-nilly, alright?"],[1931,2006,"It's dangerous."],[2010,2102,"Okay!"],[2331,2581,"Eliza Spencer, CEO of Spencer Realty"],[2581,2736,"who mysteriously disappeared"],[2736,2844,"three weeks ago"],[2844,3028,"is now presumed to be dead."],[3073,3190,"Her grieving father announced"],[3190,3349,"that in six days her brother,"],[3349,3490,"Matt Spencer, will take over"],[3490,3666,"as CEO of Spencer Realty."],[3749,3941,"Save those fake tears for later."],[4054,4179,"Miss Lily, you're awake!"],[4416,4491,"I'm Lola,"],[4491,4621,"Mr. Patton's housekeeper."],[4662,4821,"He left for work early this morning"],[4821,4959,"and has asked me to look after you."],[5009,5134,"Justin isn't here..."],[5134,5213,"Great!"],[5213,5401,"I'll go visit my board members"],[5401,5522,"and get them on my side."],[5543,5638,"I want to go play outside!"],[5638,5709,"Oh no, no, no."],[5805,5989,"Mr. Patton gave me strict orders"],[5989,6135,"to have you rest at home."],[6206,6314,"Let me call Justin!"],[6460,6606,"Mr. Patton might be busy at work"],[6606,6790,"right now, so just leave a message,"],[6790,6840,"okay?"],[6873,6936,"Okay!"],[7469,7607,"Sir, it's your housekeeper."],[7720,7807,"Okay, read it."],[8162,8395,"Justin, I miss you!"],[8395,8554,"I want to play with you."],[8554,8704,"When are you coming home?"]],"24":[[33,296,"Let's end the meeting here today."],[638,859,"I told you to read it, not broadcast it."],[859,1038,"I'm sorry, sir. My apologies."],[1071,1272,"Mr. Patton, pardon me, but ever since"],[1272,1355,"your wife was seen at the"],[1355,1505,"Spencer Realty office yesterday,"],[1551,1680,"something feels off about her."],[1701,1839,"Well sometimes a little mystery"],[1839,1935,"is good for a marriage."],[2010,2114,"I haven't told her I'm the CEO"],[2114,2260,"of Justus Corporation yet."],[2264,2373,"Look, I'm leaving."],[2398,2460,"Keep acquiring"],[2460,2560,"Spencer Realty shares."],[2598,2690,"But sir, you still have a few"],[2690,2765,"meetings later today."],[2911,2977,"Cancel them."],[3069,3157,"Didn't you hear? I've got a date"],[3157,3249,"with my wife."]],"25":[[120,221,"Here, try this."],[362,437,"After lunch, I'll take you to the"],[437,521,"amusement park."],[554,613,"Sound fun?"],[658,900,"Why did he come back so early?"],[980,1042,"I thought my message"],[1042,1151,"would put him off."],[1197,1363,"I need to meet with my board members."],[1363,1484,"Lily, did you hear me?"],[1626,1801,"I love amusement parks."],[2515,2665,"Matt Spencer wants me to take"],[2665,2919,"a picture of Justin's pea-brain wife."],[2948,3144,"I guess he's into trashy bimbos too."],[3144,3290,"I can't believe that dimwit"],[3290,3465,"is so good at seducing men."],[3557,3699,"Wait a second, I have an idea."],[3787,4175,"Let's present Lily to Matt as a..."],[4175,4291,"bedroom present."],[4291,4408,"That'll strengthen our relationship"],[4408,4508,"with Spencer Realty."],[4600,4742,"But Justin's right here."],[4767,4871,"I'll distract Justin."],[4938,5113,"You take Lily upstairs"],[5176,5334,"and we'll just say that Lily crawled"],[5334,5467,"into Matt's bed herself."],[5480,5626,"Excellent idea."],[5751,5885,"Poor little Lily."],[5943,6122,"Going to get banged up today!"]],"26":[[166,329,"Hey, Justin!"],[354,487,"What a surprise!"],[517,654,"Didn't expect to see you two"],[654,763,"lovebirds here."],[829,917,"Do you need something?"],[930,1084,"No, I..."],[1084,1205,"We..."],[1205,1397,"Just wanted to apologize"],[1397,1564,"for Kim's behavior at the luncheon."],[1630,1793,"She was just having fun, it was a prank."],[1793,1951,"She didn't really mean to hurt..."],[2081,2168,"Lily."],[2227,2485,"Lily, it really hurts my heart"],[2485,2656,"to see you like this."],[2660,2819,"Well, well, well."],[2852,3040,"Look at this two-faced bitch."],[3153,3249,"Don't cry!"],[3274,3370,"Let me help you!"],[3432,3524,"You're going to mess up"],[3524,3591,"my makeup!"],[3670,3757,"You idiot!"],[3828,3891,"Stop!"],[3924,3987,"Right now."]],"27":[[179,425,"Kim, what did we just talk about?"],[613,788,"I'm sorry Lily."],[788,950,"I didn't mean to get all worked up."],[1017,1163,"Why don't you come to the"],[1163,1276,"bathroom with me and help me"],[1276,1418,"fix my makeup."],[1484,1626,"She's not going anywhere with you."],[1655,1851,"Come on, Justin, we're all family!"],[1935,2035,"I mean you have to have a little more"],[2035,2135,"faith in us."],[2143,2264,"Precisely!"],[2339,2485,"Then it's settled."],[2485,2594,"Let's go Lily."],[2660,2794,"Justin is already in a weird"],[2794,2965,"situation with his family."],[3036,3144,"I don't want to make it any more"],[3144,3249,"difficult for him."],[3299,3403,"And..."],[3465,3624,"I'm curious to see what these two"],[3624,3787,"snakes are plotting."],[3899,4058,"I love makeup."],[4087,4195,"Great."],[4200,4254,"Lily!"],[4692,4833,"Women, am I right?"]],"28":[[517,713,"Why did she bring me to a hotel room?"],[713,838,"Quit standing around"],[838,917,"like an idiot."],[917,1105,"Hurry up and get into bed!"],[1142,1317,"It's bedtime for dumb-dumb."],[1347,1413,"Oh..."],[1413,1568,"So they're planning a honey pot."],[1618,1710,"Assholes."],[1710,1897,"Derek, the room number is 888."],[2110,2256,"Little fool."],[2302,2427,"I hope you enjoy it."],[2477,2606,"Don't play too hard."],[2627,2731,"Toodles!"],[2765,2932,"Where's Justin? I want Justin."],[2969,3240,"It's bye-bye Justin now, you moron!"],[3282,3370,"That cripple is about to kick"],[3370,3511,"the bucket any day now."],[3628,3762,"I'm giving you the chance"],[3762,3924,"to find a new sugar daddy."],[3966,4054,"So..."],[4062,4320,"Spread your legs and take it."],[4429,4529,"If you were in my position,"],[4529,4646,"would you just spread your legs"],[4646,4733,"and take it!"],[5213,5405,"How dare you talk about my husband"],[5405,5492,"like that."],[5538,5613,"Lily!"],[5751,5860,"What happened?"],[6168,6243,"Justin!"],[6310,6435,"I was so scared!"],[6548,6677,"I'm glad you're here."],[6731,6856,"It's okay, I'm here now."],[6877,6998,"Hello?"],[7011,7090,"Crap!"],[7090,7269,"That's my idiot brother's voice."],[7369,7557,"Justin, I want to play hide-and-seek!"],[7603,7753,"Her reaction when I entered..."],[7811,8020,"It seemed a little too quick."],[8028,8162,"Who is my wife really?"],[8233,8304,"Does she really"],[8304,8450,"have a mental disability?"]],"29":[[162,417,"Derek, you sneaky rascal!"],[925,1021,"I can't believe you'd offer up"],[1021,1113,"your own wife!"],[1393,1530,"This is so fucking hot."],[1576,1747,"Derek, you're so freaky!"],[1868,1960,"Son of a..."],[1989,2160,"Mr. Spencer..."],[2160,2356,"Do you like my little surprise?"],[2711,2819,"What the fuck?!"],[3098,3261,"How dare you touch my wife!"],[3299,3370,"What the hell, you freak!"],[3370,3486,"You told me to come here!"],[3545,3657,"This is the right room,"],[3657,3757,"but Lily was supposed to be"],[3757,3883,"on that bed, not Kim!"],[4116,4225,"I wouldn't spare your wife"],[4225,4350,"a second glance if you hadn't"],[4350,4491,"pimped her to me, you freak!"],[4583,4700,"You can say goodbye to"],[4700,4875,"to your partnership with Spencer"],[4875,5109,"Realty, and your inheritance"],[5109,5238,"of Patton Corporation."],[5568,5709,"God damnit, woman!"],[6047,6210,"You're useless!"],[6594,6760,"Mr. Spencer, I'm so sorry,"],[6760,6915,"it was a mistake!"],[6948,7123,"Karma's a bitch..."],[7407,7603,"Hide-and-seek is no fun anymore."],[8416,8487,"Tell me."],[8571,8687,"Who are you, muffin?"]],"30":[[25,191,"Justin's getting suspicious."],[200,321,"I need to be more careful."],[321,421,"I don't want to hide"],[421,542,"the truth from you, but..."],[575,750,"I have to wait until we both get"],[750,884,"what was taken from us."],[1242,1493,"Justin, I'm sleepy."],[1522,1668,"I want to take a nap."],[1743,1822,"Can I?"],[2039,2147,"Okay, let's go home."],[2998,3128,"Oh, now you're awake!"],[3128,3307,"What the hell is wrong with you!"],[3365,3482,"You couldn't handle loony tunes?"],[3482,3649,"How did I get here?"],[3649,3766,"Oh, you've got some nerve"],[3766,3853,"asking that..."],[3945,4049,"After offering yourself"],[4049,4166,"to Matt Spencer and nearly"],[4166,4245,"ruining me!"],[4245,4308,"What?"],[4354,4483,"No, Derek, this isn't my fault."],[4483,4650,"It's all because of that idiot, Lily!"],[4650,4771,"She knocked me unconscious,"],[4771,4884,"I don't know what happened"],[4884,4963,"after that!"],[5530,5668,"I think she said something..."],[5834,5935,"She didn't sound like she was"],[5935,6022,"mentally disabled!"],[6039,6106,"Enough!"],[6164,6327,"Stop trying to talk your way out of it."],[6427,6564,"Just leave and never"],[6564,6719,"show your face again."],[6719,6898,"Wait, no, no, Derek, I'm telling the truth!"],[6898,7036,"What if she's just faking it?"],[7061,7228,"Why would anyone in their right mind"],[7228,7336,"marry Justin?"],[7407,7482,"Think about it!"],[7599,7928,"If Justin's dimwit wife is faking it,"],[7949,8195,"Justin must be in on it too!"],[8270,8391,"And if she isn't,"],[8420,8579,"then we can use that girl to"],[8579,8733,"finish him off."],[8746,9013,"I know exactly how to get that bitch"],[9013,9134,"to tell the truth."],[9743,9872,"That's genius, Mom."],[10018,10130,"I can't wait to see"],[10130,10314,"who this psycho really is."]],"31":[[158,279,"Aren't you a little old to be playing"],[279,375,"with that, idiot?"],[483,563,"Give it back."],[688,750,"Well,"],[779,913,"you know, I"],[992,1184,"would buy you as many of these"],[1184,1317,"little bears that you would like,"],[1317,1451,"if you help me."],[1480,1534,"Okay!"],[1551,1710,"What are they planning now?"],[1764,1914,"As Justin's wife,"],[1976,2256,"you should keep an eye on his health."],[2293,2402,"So..."],[2498,2794,"Go give him this vitamin water."],[2844,3061,"She's trying to use me to poison Justin!"],[3153,3224,"But..."],[3278,3399,"If I refuse they'll realize"],[3399,3549,"I've just been putting on an act."],[3716,3924,"Don't zone out, dimwit."],[3924,4104,"Go give the water to Justin."],[4320,4487,"What, you don't want to?"],[4587,4650,"Screw it."],[4725,4833,"It doesn't matter if she finds out"],[4833,4925,"I've been faking it."],[4967,5163,"I can't let anything happen to Justin."],[5492,5538,"Lily!"],[5755,5885,"You must've read my mind."],[5943,6064,"I'm parched, can I have a sip?"],[6840,6961,"Justin..."],[7198,7269,"Thanks."]],"32":[[625,829,"Oh, Eva, since, you know, Lily and I"],[829,938,"rushed through our marriage,"],[938,1017,"we missed some"],[1017,1163,"important milestones."],[1163,1322,"Like, you know, a ring for her."],[1430,1559,"Oh, yes, of course."],[1693,1897,"How silly of me to forget."],[1993,2227,"Well, let's see here..."],[2298,2573,"One million dollars would be enough?"],[2719,2869,"You insufferable cripple."],[2911,3036,"You can't spend our money"],[3036,3132,"when you're dead!"],[3478,3657,"Finish your drink, son."],[3670,3883,"Lily made it especially for you."],[4337,4537,"Oh, God. I've had a bad cough, sorry."],[4579,4700,"Lily can you help me change?"],[4700,4867,"And don't forget that check."],[4896,4963,"Okay!"],[5030,5238,"Well, now that I'm thinking about it,"],[5313,5434,"You don't need a million dollars"],[5434,5647,"for a ring. Why don't I write you"],[5647,5751,"a new check!"],[5793,5926,"That's okay, I like this one!"],[6731,6940,"That dreadful cripple!"],[6940,7161,"Why is he so hard to kill?"],[7161,7386,"And I've lost a million dollars!"],[7486,7582,"And that Lily..."],[7582,7720,"Oh, she is undoubtedly"],[7720,7920,"who we thought she was all along!"],[7920,8199,"She's obviously a... A..."]],"33":[[0,141,"She's an imbecile!"],[179,333,"I mean anyone would look at her"],[333,483,"and see that she's loony!"],[538,608,"And you!"],[646,834,"Oh, you... If it wasn't for you"],[834,996,"and your idea that she was faking it"],[996,1163,"I wouldn't even be here today!"],[1163,1401,"But Eva, she clearly is faking it!"],[1443,1539,"Do you want tea?"],[1589,1776,"Lily can make you hot, hot tea!"],[1889,1997,"Is that boiling?"],[1997,2235,"Yup! Yup! Hot! Hot! Very hot!"],[2277,2406,"Boiling water?! No!"],[2406,2448,"Very hot!"],[2598,2882,"You crazy bitch! Put that kettle down!"],[2886,3098,"Tea time! Tea time! Tea time!"],[3207,3349,"Just because I act like an idiot,"],[3349,3503,"doesn't mean I am one."]],"34":[[0,221,"Shit! Did Justin hear what I said?"],[342,417,"Justin!"],[437,500,"Granny doesn't want to"],[500,629,"play with me. I don't think she"],[629,738,"likes me very much."],[771,859,"How could she not like someone"],[859,988,"as sweet as you muffin?"],[1017,1151,"Look, she just gave us a million dollars"],[1151,1247,"to go get you a ring!"],[1334,1422,"So where do you want to get it from?"],[1438,1580,"Tiffany's? Cartier?"],[1601,1743,"One of my board members"],[1743,1914,"will be inspecting Spencer Mall today."],[1947,2035,"I should go there."],[2439,2531,"I want to go here."],[2552,2694,"He didn't figure it out..."],[2777,2836,"Did he?"],[2902,3011,"Okay. Let's go."],[3019,3073,"Yay!"],[3236,3332,"Spencer Mall?"],[3461,3599,"Interesting choice..."],[3691,3828,"Who is my wife, really?"]],"35":[[91,375,"Alright, pick any ring you like muffin."],[404,479,"It's time to exchange that"],[479,579,"old, tarnished one"],[579,646,"you've been wearing."],[696,821,"He doesn't know, but,"],[821,1030,"it's Spencer Realty's seal."],[1138,1230,"Okay, Justin!"],[1326,1438,"You need to get that back,"],[1438,1568,"I'm telling you."],[1730,1856,"Fiona, do you remember when"],[1856,1964,"my mother-in-law wanted"],[1964,2118,"to set you up with Justin?"],[2143,2302,"Can you believe that he rejected"],[2302,2439,"you for her?"],[2498,2706,"So, this is the mental patient"],[2706,2898,"you said no to our engagement for."],[3015,3115,"Must say..."],[3136,3286,"Your taste is..."],[3286,3436,"Unique, Justin."],[3507,3632,"Oh, Justin."],[3678,3795,"You rejected the heiress"],[3795,3941,"of the Young Estate, and now she's"],[3941,4087,"engaged to Matt Spencer!"],[4108,4266,"CEO of Spencer Realty"],[4266,4425,"and owner of this mall."],[4517,4779,"Matt's marrying this pompous idiot?"],[4808,4921,"You embarrassed me."],[4967,5084,"I might have you and your dummy"],[5084,5205,"wife banned from here!"],[5317,5397,"But..."],[5488,5605,"I'll let it go."],[5676,5834,"If you get on your knees..."],[5922,6039,"And apologize."],[6181,6343,"Fiona, he's a cripple."],[6343,6477,"How is he going to get on his knees?"],[6535,6644,"Oh, dear!"],[6644,6856,"I completely forgot!"],[6927,6994,"Well..."],[7019,7248,"Since the poor thing can't kneel..."],[7336,7615,"We'll have his slow wife kneel for him!"]],"36":[[0,204,"Since the poor thing can't kneel,"],[275,604,"we'll have his slow wife kneel for him!"],[813,955,"What are you doing, moron?"],[1063,1317,"Lady, you have bad breath."],[1388,1463,"Did you even brush"],[1463,1685,"your teeth this morning?"],[1705,1835,"What did you say bitch?!"],[1843,1922,"Lily!"],[2014,2181,"Let go of me, you maniac!"],[2623,2831,"I'm going to fucking skin you alive"],[2831,2927,"you little snake!"],[2977,3199,"Manager! I want to see the manager!"],[3219,3374,"Miss Young. Hi, how can I help?"],[3420,3574,"Break their arms and throw"],[3574,3657,"them out of here!"],[3766,3899,"But Miss Young, he's a member"],[3899,3995,"of the Patton family."],[3995,4120,"Who cares if he's a Patton!"],[4154,4266,"The Spencers could crush them"],[4266,4341,"in seconds."],[4412,4646,"Do you really want to offend me,"],[4646,4884,"the future wife of Spencer Realty's"],[4884,5038,"CEO, just for some cripple!"],[5084,5284,"No, no, no, of course not. Guards!"],[5426,5663,"Mr. Barnes, Spencer Realty"],[5663,5905,"condemns such uncouth behavior."],[6056,6147,"Ma'am you..."],[6252,6360,"I know you!"]],"37":[[12,120,"I know you!"],[200,346,"I don't remember from where, but..."],[367,550,"Maybe you saw her in a loony bin,"],[550,721,"who cares, throw them out!"],[754,809,"Now!"],[846,934,"Apologies Miss Young,"],[934,1067,"but she looks very familiar."],[1067,1126,"You know, I'm worried-"],[1126,1238,"Miss Young is engaged"],[1238,1380,"to Mr. Spencer."],[1397,1618,"Your boss, who owns this mall."],[1655,1835,"Do you really want to lose your job"],[1835,1960,"by pissing her off?"],[1960,2143,"No, no, no, of course not."],[2143,2306,"No, I'll escort them out immediately."],[2414,2494,"Actually..."],[2560,2686,"I've changed my mind."],[2731,2898,"I would like to personally"],[2898,3028,"break their arms."],[3073,3140,"Do you really think you're"],[3140,3211,"going to get away with that?"],[3432,3570,"Get away with it?"],[3624,3803,"Sweetie, I own everything"],[3803,4033,"and everyone in this town."],[4183,4325,"None of this would have happened"],[4325,4508,"if you would've let your dimwit wife"],[4508,4621,"kneel in your place."],[4662,4850,"If you hurt him..."],[4854,5092,"I will destroy you."],[5292,5392,"Aww."],[5430,5680,"Baby learned some big words, huh?"],[5747,5860,"Who do you think you are?"],[5893,6106,"The future CEO of Spencer Realty?"],[6210,6406,"That's hilarious, Fiona!"],[6406,6531,"Can you imagine her running"],[6531,6660,"a major company?"],[7119,7399,"You arrogant bitch."],[7565,7682,"You insulted me."],[7795,7953,"Clearly, you missed the part"],[7953,8116,"where I rip off your arms!"],[8254,8354,"Stop right there!"]],"38":[[8,116,"Stop right there!"],[241,342,"What's going on here?"],[354,546,"Mr. Bates, these people just"],[546,729,"offended Miss Young, so she was"],[779,917,"going to break their arms."],[1184,1255,"Miss Spen-"],[1480,1568,"How dare you?!"],[1601,1768,"This is not how we treat our customers"],[1768,1881,"at Spencer Mall!"],[1926,2043,"Release them now!"],[2552,2631,"Miss Spencer..."],[2790,3007,"Thank you, Mister. My name is Lily."],[3136,3228,"Ah..."],[3274,3390,"Miss... Lily."],[3436,3524,"Are you alright?"],[3553,3653,"You old fart!"],[3670,3832,"How dare you stick your nose"],[3832,3928,"in my business!"],[3949,4170,"Don't you know who my fiancé is?"],[4170,4283,"I've been a board member at"],[4283,4483,"Spencer Realty for ten years."],[4517,4788,"I know your fiancé, Matt, very well."],[4884,4942,"Matt?!"],[4996,5209,"How dare you address him"],[5209,5321,"by his first name?"],[5392,5601,"Once he takes over Spencer Realty."],[5601,5797,"I'll make sure Matt kicks your ass"],[5797,5885,"off the board!"],[6039,6197,"Takes over Spencer Realty?"],[6277,6435,"Yeah, you're scared now, huh?"],[6435,6531,"Now scram!"],[6635,6769,"Leave now,"],[6902,7115,"and I'll pretend that none of this"],[7115,7223,"ever happened."],[7286,7474,"You're so kind, Fiona."],[7545,7632,"You should be grateful"],[7632,7816,"she's giving you a second chance."],[7932,8016,"Sure."],[8062,8158,"In that case,"],[8179,8320,"let me show my gratitude"],[8320,8450,"to Miss Young."],[8500,8579,"Throw these women out!"],[8600,8662,"What?"],[8742,8775,"What?"],[8892,8979,"They are permanently"],[8979,9159,"banned from Spencer Mall!"],[9188,9250,"Didn't you hear me?"],[9250,9420,"I am Matt Spencer's fiancé!"],[9434,9471,"What are you waiting for!"],[9534,9667,"Kick them out of here immediately!"],[9667,9784,"This is ridiculous!"],[9884,10105,"Mr. Bates, that was our future CEO's"],[10105,10331,"fiancé. These two, they aren't worth it!"],[10331,10410,"Shut up!"],[10502,10610,"You ignorant fool."],[10673,10823,"You don't know who you're pointing at."],[10865,10935,"You're fired!"],[11307,11436,"Apologies, Mrs..."],[11507,11615,"Miss Lily."],[11669,11803,"Please allow me to serve you"],[11803,11966,"some tea and refreshments."],[12099,12249,"Yay! I'm hungry."],[12274,12449,"Justin, come on, let's go."],[12545,12691,"This man is a Spencer Realty"],[12691,12766,"board member."],[12892,12992,"Why is he speaking to Lily"],[12992,13138,"like she's his superior?"],[13229,13446,"Lily, you should go with Mr. Bates."],[13446,13613,"I'll catch up with you guys later."],[13663,13730,"Okay!"]],"39":[[325,550,"Miss Spencer. You're alive!"],[588,784,"I'm so happy to see you!"],[900,1038,"Take a seat, Mr. Bates."],[1201,1359,"Take a seat, Mr. Bates."],[1372,1480,"All the news outlets"],[1480,1630,"were saying that you died."],[1664,1814,"You should've sent me a message."],[1830,1910,"I know."],[1985,2085,"But I knew you'd be here today"],[2085,2239,"for your quarterly inspection,"],[2273,2381,"and I'm here now, aren't I?"],[2406,2498,"Of course."],[2635,2894,"Miss Spencer, I'll inform the board"],[2961,3098,"that you've returned real quickly."],[3119,3211,"Ah, you know what?"],[3228,3374,"Let's keep the news of my return"],[3374,3507,"under wraps for now."],[3582,3645,"I've got a plan."],[3891,4008,"So..."],[4179,4279,"How is my company?"],[4379,4504,"I'm afraid your brother, Matt,"],[4504,4633,"has thrown the company into"],[4633,4742,"utter chaos."],[4825,4950,"Many of the directors have"],[4950,5071,"deflected to his side."],[5171,5234,"Okay, well..."],[5296,5330,"Look."],[5409,5526,"Harry, thank you."],[5580,5747,"Thank you so much for standing by me,"],[5747,5809,"and just..."],[5910,6064,"Hang in there a little longer, okay?"],[6114,6260,"I am not going to let Matt take"],[6260,6377,"Spencer Realty."],[6548,6614,"Yes, ma'am."],[6685,6840,"We will follow your orders."],[7040,7144,"Alright, well I should get going."],[7144,7336,"I don't want Justin to get suspicious."],[8103,8216,"Justin!"],[8258,8404,"Hey, Lily. How were the refreshments?"],[8600,8833,"It was so yummy!"],[8921,8992,"Let's go home!"],[9409,9538,"Miss Lily has no documentation"],[9538,9617,"that I can find."],[9655,9780,"No record of who she was"],[9780,9880,"before you found her."],[9972,10014,"But I did notice"],[10014,10118,"something interesting."],[10206,10293,"She appeared the same day"],[10293,10402,"Eliza Spencer went missing."],[10427,10506,"Do you think that's just"],[10506,10598,"a coincidence, sir?"],[10789,10919,"It's not a coincidence."],[11094,11223,"Lily is Spencer Realty's"],[11223,11323,"missing CEO."]],"40":[[225,367,"Should I investigate more?"],[379,471,"There's no need."],[471,538,"How many Spencer shares"],[538,621,"have you acquired?"],[642,796,"At this point we own twenty-five percent"],[796,900,"of Spencer Realty."],[980,1063,"Justin!"],[1080,1197,"It's sleepy time."],[1351,1438,"See ya, Phillip."],[2590,2669,"Justin..."],[2727,2831,"Do you want to tell me something?"],[2977,3090,"Um..."],[3294,3474,"Muffin really likes Justin."],[3691,3757,"Well you'll have to show me"],[3757,3883,"how much you like me."],[4783,4879,"Justin?"],[5159,5313,"My sweet little liar."]],"41":[[450,625,"Congratulations on gaining control"],[625,817,"of Spencer Realty, Mr. Spencer."],[880,1021,"I hope that you'll consider"],[1055,1276,"supporting the Patton corporation."],[1347,1514,"Once I'm officially CEO,"],[1514,1614,"I will sign the contract"],[1614,1739,"with Patton corporation."],[1810,1918,"That should help you secure"],[1918,2006,"your position."],[2177,2373,"You are so kind."],[2494,2594,"Mr. Spencer."],[2673,2794,"Under your leadership,"],[2794,3069,"Spencer Realty will reach new heights."],[3069,3144,"Yes."],[3144,3328,"Once you inherit Spencer Realty,"],[3328,3486,"everyone will be vying"],[3486,3603,"for your attention."],[4216,4316,"Ladies and gentlemen,"],[4396,4625,"as you know, my daughter, Eliza,"],[4625,4721,"went missing."],[4783,4954,"And is now presumed dead."],[4984,5163,"She poured her heart and soul"],[5163,5301,"into Spencer Realty"],[5392,5501,"As her father,"],[5551,5805,"I can't bear to see her hard work"],[5805,6010,"fall into the wrong hands."],[6085,6322,"So, starting today,"],[6352,6519,"her beloved half-brother,"],[6573,6702,"Matt Spencer,"],[6710,6973,"will take over at Spencer Realty."],[7344,7424,"Thanks, Dad."],[7570,7874,"It is with a heavy heart"],[7874,8112,"that I inherit my sister's legacy,"],[8112,8320,"but, I promise to make her proud."],[8454,8654,"Now, let us all toast."],[8654,8854,"To Matt becoming CEO"],[8854,9000,"of Spencer Realty."],[9025,9146,"And to Eliza."],[9146,9259,"May she rest in peace,"],[9259,9384,"wherever she is."],[10468,10560,"I'm right here."]],"42":[[354,600,"I'm so sorry to disappoint you fam,"],[600,692,"but..."],[713,813,"Heaven thought it was a little"],[813,1063,"too soon for me to rest in peace."],[1113,1347,"How the hell is this bitch still alive?"],[1814,1918,"Am I going blind?"],[1972,2077,"That can't be..."],[2210,2339,"That bitch!"],[2373,2540,"How is she still alive?"],[2540,2635,"How is she here?"],[2665,2786,"Stop it, guys!"],[2869,2936,"Who cares if I couldn't"],[2936,3028,"kill her the first time?"],[3211,3299,"I'll do it right now!"],[3299,3432,"Matt, be careful!"],[3432,3541,"Everyone's watching!"],[3578,3695,"Don't worry, they can't take"],[3695,3828,"Spencer Realty away from you."],[3862,4070,"How did you sneak in here, you lunatic!"],[4112,4300,"I am so sorry, Mr. Spencer."],[4300,4504,"My sister-in-law is mentally ill,"],[4504,4596,"I'll get rid of her."],[4729,4808,"What are you, deaf?"],[4846,4959,"Get the hell out of here and stop"],[4959,5096,"embarrassing our family."],[5451,5697,"How dare you touch me!"],[5718,5951,"You fucking bird-brained bitch!"],[6139,6214,"Let go!"],[6281,6381,"If you offend Matt Spencer"],[6381,6502,"not even Justin can save you."],[6527,6606,"Let go!"],[6748,6869,"Patton corporation is signing"],[6869,6969,"a major deal with him"],[6969,7057,"and Spencer Realty."],[7057,7148,"If you get in the way..."],[7148,7215,"A deal?"],[7273,7361,"Matt has no say in that."],[7361,7557,"I call the shots at Spencer Realty."],[7645,7691,"Yeah."],[7703,7845,"Yeah! Right!"],[7845,7962,"And I'm Superman!"],[8220,8341,"Dad... Mom..."],[8387,8466,"Matty..."],[8529,8683,"How about you tell my ignorant"],[8683,8837,"brother-in-law who I am."]],"43":[[66,216,"I'm sorry, what did you just call them?"],[216,350,"Oh, you heard it."],[421,684,"Mr. Spencer, what the hell is going on?"],[742,921,"Is she really Eliza Spencer?"],[963,1146,"Wasn't she presumed dead?"],[1146,1226,"It's her."],[1255,1443,"I've worked with her for ten years."],[1455,1639,"I'd know that face anywhere."],[1747,1830,"Miss..."],[1889,2060,"You do look similar to Eliza,"],[2110,2239,"but my daughter is dead."],[2310,2427,"You're an impostor!"],[2640,2752,"I can't..."],[2777,3019,"Losing Eliza shattered us!"],[3019,3148,"This is like pouring salt"],[3148,3261,"into the wounds,"],[3261,3432,"with this shoddy act."],[3749,3853,"Figures."],[3853,4041,"An idiot like you doesn't deserve"],[4041,4212,"to be at elite galas."],[4212,4283,"Let's go."],[4533,4612,"Wow..."],[4692,4796,"Not even recognizing"],[4796,4992,"your own daughter!"],[5096,5201,"That's a new low."],[5313,5384,"Security!"],[5447,5626,"Hurry up and drag this maniac"],[5626,5718,"out of here!"],[5930,6022,"Don't you dare!"],[6097,6177,"I hold the key"],[6177,6360,"to Spencer Realty's safe"],[6439,6519,"right here."],[6664,6936,"I am Eliza Spencer."],[7148,7236,"Is anyone brave enough"],[7236,7332,"to try me now?"],[7378,7507,"How does my dim-witted"],[7507,7653,"sister-in-law have that ring?"],[7782,7866,"What if..."],[7907,8120,"She's really Eliza Spencer."],[8245,8379,"I need to rethink this."],[8529,8683,"Playtime is over fam."],[8812,8917,"Spencer Realty"],[8958,9088,"will never"],[9146,9263,"be yours."]],"44":[[171,321,"Oh, please..."],[358,583,"You're claiming to be Eliza Spencer"],[583,742,"with that rusty old ring?"],[813,996,"Matty, don't be fooled"],[996,1096,"by this phony."],[1172,1263,"I've seen her hooking up"],[1263,1401,"with a Spencer Realty board"],[1401,1534,"member at the mall."],[1609,1805,"I bet he told her all about Eliza's"],[1805,1935,"little disappearance."],[1964,2131,"And that ring must be forged."],[2302,2527,"You trespassed into our gala."],[2686,2873,"Impersonated my late daughter."],[2957,3157,"Even forged her signet ring."],[3194,3311,"You better leave now before"],[3311,3470,"I stop playing nice."],[3541,3703,"I don't think so, Dad."],[3762,3895,"This ring..."],[3966,4099,"It opens the precious"],[4099,4287,"Spencer Realty safe."],[4458,4567,"Let's test it out!"],[4625,4713,"See if it's real."],[4738,5030,"This is the Spencer Annual Gala."],[5092,5280,"We're not here to fulfill the demands"],[5280,5388,"of some lunatic."],[5430,5526,"Oh..."],[5705,5809,"You scared?"],[5972,6039,"Scared?"],[6189,6297,"I was trying to save"],[6297,6443,"you the embarrassment."],[6519,6723,"But if you insist on being so..."],[6723,6815,"Shameless."],[6911,6990,"I'll play along."],[7019,7090,"Guard!"],[7595,7678,"How exciting."],[8195,8308,"Here, you little brat..."],[8404,8521,"The company safe."],[8712,8879,"I'm giving you one last chance."],[8929,9075,"Admit you're an impostor."],[9255,9300,"How about we"],[9300,9484,"make a little bet, instead?"]],"45":[[20,246,"Since you're so confident..."],[329,408,"Let's make a bet."],[479,633,"Ten percent Spencer Realty"],[633,709,"shares."],[1021,1134,"Who do you think you are,"],[1134,1322,"to bet with Spencer Realty shares?"],[1368,1509,"I'm Eliza Spencer..."],[1584,1810,"CEO of Spencer Realty."],[1885,2027,"You think we're fool enough"],[2027,2189,"to take a risk with ten percent"],[2189,2289,"of the company,"],[2335,2502,"at no advantage to us."],[2552,2640,"Well..."],[2640,2827,"You're the one who thinks that"],[2827,2944,"I am an impostor."],[3011,3199,"George, agree to it."],[3199,3336,"I've prepared the safe."],[3336,3453,"This is our chance to get rid of"],[3453,3616,"your wretched daughter for good."],[3678,3716,"Fine."],[3799,3983,"I'm not afraid of impostors."],[4033,4124,"I'll gamble with you."],[4124,4287,"Give me a pen."],[4733,4817,"You brought this upon"],[4817,4921,"yourself, Eliza."],[5130,5238,"Don't blame me."],[5505,5605,"You know..."],[5680,5839,"If you hadn't tried to kill me"],[5839,6035,"and steal all of my assets,"],[6093,6181,"I would've supported you"],[6181,6327,"for the rest of your life."],[6373,6435,"But..."],[6498,6644,"Now you'll spend it rotting away"],[6644,6731,"in prison, instead."],[6852,6944,"Don't blame me."],[7374,7461,"Let's start."],[7553,7674,"If you can open the safe,"],[7674,7811,"we'll give you ten percent"],[7811,7907,"of the shares."],[7978,8095,"But if you can't..."],[8162,8229,"We get to do whatever"],[8229,8387,"we want with you."],[9826,9918,"Access denied."],[9930,10030,"Access denied."]],"46":[[0,87,"Access denied."],[112,204,"Access denied."],[291,462,"Is her ring really a fake?"],[496,608,"No way. What's going on?"],[667,754,"Something's wrong."],[813,900,"I need to make a call."],[1005,1126,"You idiot."],[1126,1263,"You really thought you could"],[1263,1426,"stroll in here with a fake ring"],[1426,1580,"and open the company safe?"],[1743,1851,"Accept your defeat."],[1906,2093,"When you're buried six feet under,"],[2127,2373,"I'll remember to bring flowers."],[2431,2594,"Thanks for making it so easy"],[2594,2786,"for me to inherit Spencer Realty."],[2831,2915,"No, this is impossible."],[2915,3103,"Something's wrong. Let me try again."],[3165,3244,"It doesn't matter if you try it"],[3244,3353,"a thousand times."],[3353,3636,"That safe won't open."],[3674,3749,"No, it's fine."],[3770,3883,"I'll let you try again."],[3953,4200,"For giving me the company safe, sis."],[4950,5042,"Access denied."],[5063,5146,"Access denied."],[5309,5405,"Oh, would you look at that!"],[5405,5501,"Do you want to try"],[5501,5618,"a couple more times, sis?"],[5684,5809,"No, that can't be."],[5876,5951,"Enough messing around."],[5951,6085,"I have a party to go back to."],[6202,6356,"As a thank you for fulfilling"],[6356,6506,"Matt's dreams,"],[6506,6623,"I promise to get you"],[6623,6765,"a beautiful tombstone."],[7007,7107,"The safe is a fake."],[7228,7357,"The safe has to be a fake!"]],"47":[[100,179,"The safe is fake?"],[179,325,"There's no other explanation."],[325,604,"Eliza needs the real one now!"],[696,792,"I have the safe."],[792,888,"Our intel said it was going to be"],[888,967,"tampered with, so I had our men"],[967,1055,"take care of it."],[1101,1205,"Good work, Phillip."],[1297,1393,"I just can't believe the Spencers"],[1393,1505,"would pull a dirty trick like this"],[1505,1601,"on their own daughter."],[1659,1726,"But, quickly,"],[1726,1830,"send the real one to the gala."],[1851,1897,"Yes sir."],[2314,2444,"This safe has to be a fake!"],[2565,2711,"Don't be ridiculous."],[2756,2844,"If this safe is fake,"],[2844,2952,"then where is the real one?"],[3119,3244,"The real safe is right here!"]],"48":[[45,212,"The real safe has the serial number"],[212,342,"on record."],[342,588,"All we did was check."],[825,1017,"Please, try again, Miss Spencer."],[1818,2031,"Access granted to Eliza Spencer."],[2223,2427,"She opened the safe with the ring!"],[2427,2744,"She's Eliza Spencer, the CEO!"],[2852,2998,"Welcome back,"],[2998,3244,"CEO, Eliza Spencer."],[4033,4149,"Anybody else"],[4149,4316,"want to question my identity?"],[4500,4592,"No?"],[4867,5013,"As long as I,"],[5075,5355,"Eliza Spencer, am still standing,"],[5413,5584,"Spencer Realty"],[5626,6001,"will never be in your filthy hands."]],"49":[[29,212,"Matty, what is going on?"],[237,492,"Is this moron really Eliza Spencer?"],[492,554,"Shut up!"],[638,713,"Harry..."],[925,1034,"Thank you so much"],[1034,1217,"for your loyalty and support."],[1330,1397,"How did you know"],[1397,1530,"the safe was switched?"],[1551,1676,"I was informed by someone"],[1676,1805,"from Justus Corp."],[1872,2010,"I've never interacted with"],[2010,2143,"Justus Corp before."],[2293,2427,"Why would they help me?"],[2723,2811,"Well..."],[3153,3278,"Thank you so much"],[3278,3453,"for the ten percent, Dad?"],[3478,3566,"You..."],[3649,3812,"You ungrateful daughter!"],[3974,4037,"Daughter?"],[4145,4208,"Wait, I..."],[4316,4508,"I thought you said I was an impostor?"],[4592,4633,"Are you..."],[4788,4871,"Are you actually admitting"],[4871,4959,"that I'm your daughter?"],[5025,5117,"You!"],[5376,5476,"George!"],[5476,5580,"Oh no."],[5855,6106,"Eliza, sweetie..."],[6222,6477,"You were gone for so long,"],[6477,6639,"you didn't call us."],[6685,6873,"Of course we were suspicious"],[6873,7032,"when you just showed up."],[7082,7240,"Oh, so it's..."],[7353,7490,"It's my fault now?"],[7695,7928,"Lindsey, Lindsey, Lindsey, Lindsey."],[8162,8329,"You should've been an actress."],[8425,8571,"Because you're so good at it."],[8571,8679,"Could have won an Oscar."],[8837,8979,"You bitch!"],[9029,9225,"Apologize to my mom right now!"]],"50":[[371,475,"You skank!"],[504,604,"I'll kill you!"],[2085,2168,"Is this what you used"],[2168,2273,"to try and kill me?"],[2481,2623,"I'll deal with you two later."],[2723,2815,"Take them away."],[3136,3224,"I'm your father."],[3278,3420,"You can't treat me like this!"],[3507,3645,"God will strike you down!"],[3778,3908,"After everything you've done,"],[3908,4008,"I think you're the one who's"],[4008,4154,"going to get struck down."],[4258,4320,"Take him."],[4562,4708,"Um... Miss Spencer."],[4867,5005,"Girly, um..."],[5034,5196,"I was misled by Matt."],[5196,5296,"I would have never..."],[5296,5384,"Harry."],[5397,5538,"Spread the news."],[5609,5768,"I would like the Young family"],[5768,6018,"to be blacklisted from the industry."],[6047,6210,"And please have Miss Young"],[6210,6410,"banned from all Spencer properties."],[6423,6510,"Yes, Ma'am."],[6744,6898,"Let go of me! Let go!"],[7590,7757,"I've kept you all waiting."],[7995,8220,"Eliza Spencer is back!"],[8666,8771,"And now..."],[8883,9029,"It's time to tell my husband"],[9029,9154,"about my identity."]],"51":[[1322,1388,"Justin."],[1564,1730,"Welcome home, Miss CEO."],[1931,2002,"You..."],[2056,2260,"Don't seem very surprised."],[3240,3336,"You already knew."],[3490,3611,"You were very impressive"],[3611,3678,"out there."],[4079,4154,"Justin..."],[4266,4362,"I'm really sorry."],[4475,4667,"I didn't want to lie to you, but..."],[4871,5025,"Look, if it bothers you, then we can-"],[5025,5155,"Do you know what's really bothering me?"],[5276,5397,"It's that I'm no match"],[5397,5526,"to the super smart,"],[5601,5697,"powerful,"],[5751,5855,"and beautiful,"],[5893,6068,"CEO of Spencer Realty."],[6393,6493,"I mean, do you..."],[6614,6769,"Still want to be with me?"],[6877,6940,"Muffin."],[8116,8195,"I do."]],"52":[[855,980,"Get out of here, you piece of shit!"],[1088,1188,"I just want to be alone."],[1272,1443,"Mr. Spencer..."],[1539,1726,"Looks like you've seen better days."],[1889,1976,"What, did you just come here"],[1976,2060,"to mock me?"],[2160,2310,"No. No, no, no."],[2419,2569,"You misunderstand me. You see,"],[2569,2694,"we're in the same boat."],[2802,2957,"You want control of Spencer Realty"],[2957,3148,"and I want Patton Corporation."],[3186,3265,"Oh!"],[3319,3457,"Well when you put it like that,"],[3457,3757,"it's just so fucking easy, isn't it?"],[3799,4045,"You see, it actually is that simple."],[4095,4358,"I heard that your sister, Eliza, is"],[4421,4546,"holding a board meeting"],[4546,4650,"soon, yeah?"],[4967,5030,"And?"],[5105,5176,"And..."],[5176,5338,"This is your last chance, Matt."],[5459,5618,"Have the board impeach"],[5618,5780,"your sister from her position."],[5839,5968,"And with my support..."],[6018,6122,"I'll have them appoint you"],[6122,6318,"as Spencer Realty's CEO."],[6898,6977,"You're good."],[7032,7115,"Oh, I know."],[7236,7390,"You snide bastard."],[7711,7941,"Eliza is not winning this time."],[8983,9100,"I have to tell Eliza"],[9100,9250,"I own Justus Corporation."],[9305,9451,"Before she finds out on her own."],[9617,9751,"Eliza, I..."],[9751,9914,"Shut up and kiss me."]],"53":[[754,880,"My wife is a much better kisser"],[880,1030,"when she's not playing dumb."],[1213,1368,"Yeah, you like it?"],[1368,1572,"I think I'd like another taste."],[5084,5209,"Sir, your wife's dramatic return"],[5209,5313,"at the Spencer Gala has erased"],[5313,5442,"all doubt about her identity."],[5484,5555,"She is the undisputed"],[5555,5680,"head of Spencer Realty."],[5680,5830,"Does she even need these shares?"],[5847,6047,"Eliza's family is just as greedy as mine."],[6110,6177,"I'm sure they'll strike"],[6177,6310,"at the board meeting today."],[6322,6443,"But these shares will give my wife"],[6443,6544,"an additional twenty-five"],[6544,6694,"percent stake of Spencer Realty,"],[6752,6827,"Making her the majority"],[6827,6948,"shareholder, and giving her"],[6948,7048,"complete control."],[7061,7178,"Pardon me, sir, but why not just tell"],[7178,7332,"your wife that you're the CEO of Justus?"],[7407,7574,"I can't tell her about Justus until"],[7574,7661,"I uncover the truth"],[7661,7770,"of my mother's death."],[7803,7903,"I don't want to risk her life"],[7903,8024,"by dragging her into that."],[8058,8137,"I understand, sir."],[8137,8266,"I'll make sure to keep it a secret."],[8324,8404,"Keep what a secret?"]],"54":[[91,150,"Oh!"],[350,425,"Ma'am, it's..."],[471,596,"What's this? Nothing. It's..."],[608,759,"It's something for Phillip, from me."],[909,1001,"Yes, um..."],[1001,1155,"I'm short on rent, and Mr. Patton"],[1155,1234,"was willing to help."],[1397,1455,"Are you sure?"],[1480,1572,"Uh, yes."],[1705,1785,"Muffin, don't you have"],[1785,1835,"an important meeting"],[1835,1910,"with the board?"],[1976,2043,"Don't want to be late!"],[2181,2231,"Hmm."],[2694,2765,"Well, from everything"],[2765,2831,"we talked about."],[2869,2973,"I think it's time we take a vote."],[3532,3599,"What are you doing here?"],[3641,3687,"Get out."],[3795,3903,"Why don't you hear what the board"],[3903,3999,"has to say first?"],[4308,4391,"Miss Spencer."],[4441,4562,"If your brother is interested in"],[4562,4696,"taking care of the company,"],[4696,4833,"why not give him a chance?"],[4875,5188,"Matt is smart and capable."],[5259,5401,"The company would be in great hands."],[5463,5618,"You want me to step down."],[5643,5722,"Eliza..."],[5751,5864,"It's for your own good."],[5893,5997,"You're married now."],[6043,6139,"It's time for you to focus"],[6139,6231,"on your new family."],[6281,6368,"How dare you."],[6398,6489,"Miss Spencer founded"],[6489,6677,"Spencer Realty from scratch."],[6698,6827,"You'd be nothing without her,"],[6827,6994,"and this is how you repay her?!"],[6994,7077,"Shut up and sit down."],[7077,7248,"You don't know shit, old man."],[7394,7507,"The board is smart enough to make"],[7507,7595,"the right decision."],[7711,7782,"Spencer Realty"],[7782,7957,"belongs to me now, sis."]],"55":[[162,421,"You know that is big talk"],[496,658,"coming from someone who"],[846,1038,"hasn't worked a day in his life."],[1276,1484,"I created Spencer Realty,"],[1580,1760,"and it will always..."],[1801,1876,"be mine."],[2072,2173,"Well, everyone's here."],[2273,2364,"Why don't we vote?"],[2502,2627,"All in favor of appointing"],[2627,2798,"Matt Spencer as CEO."],[2982,3144,"All in favor of Eliza Spencer"],[3144,3290,"remaining as CEO."],[3695,3766,"We're tied."],[3916,4016,"Maybe this will help."],[4275,4483,"If you choose Matt Spencer,"],[4546,4738,"Patton Corporation will lower"],[4738,4954,"its margin down to just five percent,"],[5021,5155,"which will mean much larger"],[5155,5238,"profit share."],[5388,5467,"You see that?"],[5467,5584,"Now this..."],[5663,5780,"This is business."],[5893,6202,"Eliza doesn't have the balls"],[6202,6460,"or authority to run this company,"],[6573,6752,"and it's time for her to step aside"],[6802,6894,"for a real leader."],[7148,7207,"Me."],[7282,7436,"Mr. Spencer is right."],[7465,7595,"All in favor of appointing"],[7595,7757,"Matt Spencer as CEO."],[7991,8245,"Eliza Spencer built this company,"],[8245,8358,"and you'd turn on her"],[8358,8516,"for some scraps from the Pattons?"],[8516,8650,"It's business."],[8650,8762,"Money is money."],[8792,8892,"You see that, sis?"],[8942,9059,"It's time to hand over"],[9059,9163,"Spencer Realty."],[9309,9426,"What's the rush, Matty?"]],"56":[[20,112,"What are you doing here?"],[342,450,"You'll find out soon."],[483,588,"You've lost, Eliza."],[654,759,"Spencer Realty is"],[759,917,"under my control now."],[1005,1134,"I would rather give my company"],[1134,1217,"to a chimp."],[1338,1497,"It would do a better job than you."],[1564,1705,"I'm done asking nicely!"],[1751,1785,"Hey!"],[1826,2031,"Agh! Ow, let go! Ow! Ow!"],[2052,2156,"Mr. Spencer, you watch how you"],[2156,2256,"speak to my wife."],[2256,2398,"And you keep your hands off her."],[2448,2489,"You got that?!"],[2489,2594,"Yeah, I got it. Let go!"],[2736,2894,"I'll fucking kill you, you cripple."],[2957,3057,"How dare you talk down"],[3057,3136,"to my husband!"],[3157,3215,"Eliza..."],[3240,3311,"Just give me"],[3311,3465,"the signet ring and leave."],[3465,3657,"The board voted against you."],[3678,3803,"Don't make me kick you out."],[4471,4592,"Justin, it's over."],[4621,4708,"Not yet, Muffin..."],[4788,4842,"Not yet."],[4909,4967,"Boss."],[5017,5176,"Mr. Blake Hale, the general manager"],[5176,5296,"of Justus Corp is here."],[5380,5480,"Justus Corp?"],[5509,5643,"At the banquet, they were the ones"],[5643,5772,"that found the real safe."],[5818,5968,"Could it be that Justin..."]],"57":[[4,112,"Justus Corp..."],[208,308,"Did you call them here?"],[608,809,"Mr. Hale, it is an honor, sir."],[821,942,"You're here for?"],[942,1021,"Just..."],[1213,1301,"Just thought I'd drop in"],[1301,1376,"as soon as possible."],[1622,1747,"Derek must be right."],[1814,2031,"Justus Corp's mysterious CEO"],[2031,2260,"must be thrilled to see me take over."],[2260,2427,"That's why he sent the GM here."],[2444,2565,"The Justus Corporation holds"],[2565,2802,"a twenty-five percent stake"],[2802,2907,"in Spencer Realty."],[2994,3094,"Our boss has decided"],[3094,3236,"to transfer those shares"],[3236,3374,"to the CEO"],[3420,3516,"of Spencer Realty."],[3586,3674,"At no cost."],[3999,4099,"See that, Mr. Bates?"],[4099,4333,"Even Justus Corp is backing Matt."],[4366,4454,"It's not too late"],[4454,4567,"to pick the winning side."],[4692,4783,"Mr. Spencer,"],[4783,4950,"now with Justus Corp's support,"],[4950,5138,"you're sure to lead Spencer Realty"],[5138,5242,"into a bright future."],[5338,5413,"Where do I sign?"],[5476,5518,"Wait."],[5718,5910,"I said this was meant for the CEO"],[5910,6014,"of Spencer Realty."],[6014,6160,"Miss Eliza Spencer."]],"58":[[141,316,"You said Justus Corp"],[316,383,"was here for me."],[383,525,"You're making me look like a fool."],[571,658,"Hold on."],[658,821,"No, no, no."],[821,1009,"There must be a mistake."],[1109,1230,"Well, the agreement is clear."],[1284,1472,"The shares are to be transferred to"],[1472,1710,"Eliza Spencer, founder and CEO."],[1776,1814,"But..."],[1885,1968,"Why? I have never worked with"],[1968,2060,"your boss, and..."],[2143,2293,"I don't even know who he is."],[2540,2702,"Our boss is a mysterious man."],[2731,2969,"He has his reasons. Please,"],[3048,3119,"just sign right there"],[3119,3232,"and the shares will be yours."],[3315,3432,"This will give you majority stake"],[3432,3507,"in your company."],[3528,3616,"And no one..."],[3732,3812,"Can vote you out."],[4425,4612,"Ma'am, I am so sorry."],[4612,4688,"I got carried away"],[4688,4813,"in all the excitement."],[4921,5180,"Yeah, we've worked with you for years!"],[5180,5401,"Please just give us another chance."],[5430,5497,"Well..."],[5759,5893,"None of you seemed to be"],[5893,6043,"very generous when I was"],[6043,6164,"on the chopping block."],[6297,6439,"Mr. Bates."],[6460,6544,"Now that I am"],[6544,6731,"majority shareholder,"],[6731,6877,"I would like to fire"],[6877,7032,"every single board member"],[7032,7211,"who voted for Matt."],[7219,7353,"So please escort them out."],[7386,7478,"Yes, Ma'am."],[7590,7661,"Guard!"],[8020,8158,"Oh, and um..."],[8229,8425,"Could you take the trash out, as well?"],[8521,8666,"And never let him come back."],[8725,8875,"Do not touch me! Wait."],[8954,9029,"Why?"],[9042,9184,"Why'd your boss transfer the funds"],[9184,9250,"for nothing?"],[9300,9455,"Is he sleeping with my sister?"],[9743,9838,"How dare you."],[9955,10068,"Ma'am, I hope you dont mind"],[10110,10239,"if I can teach him a lesson."]],"59":[[45,150,"Ma'am, I hope you don't mind"],[208,312,"if I can teach him a lesson."],[496,575,"Go for it."],[596,746,"Eliza, you can't do this to me, okay?"],[746,867,"The guys at Justus Corp"],[867,984,"are known to be ruthless!"],[984,1096,"Okay, you have to save me!"],[1134,1301,"No. Look, I'm sorry, okay? It was..."],[1447,1514,"It was Derek."],[1564,1672,"Yeah, it was him!"],[1701,1814,"I should've never listened to him!"],[1814,1964,"It was all his idea!"],[2022,2198,"I have no idea"],[2198,2369,"what you're talking about, Matt."],[2398,2556,"I didn't force you into anything."],[2640,2702,"You know, you would jump"],[2702,2815,"at the chance to take your sister"],[2815,2965,"down, so I think it's definitely your fault."],[2965,3032,"No, shut up!"],[3032,3103,"Woah!"],[3123,3178,"Woah!"],[3190,3353,"No! No, please, Eliza!"],[3353,3482,"You can't do this to me, please!"],[3524,3670,"Please save me, Eliza!"],[3678,3749,"Eliza, no!"],[3749,3849,"Bye, Matty!"],[4008,4220,"So, I think now's a good time"],[4220,4312,"for me to leave."],[4421,4504,"But just so you know..."],[4592,4688,"It's far from over."],[4796,4896,"Mark my words."],[5505,5622,"Congratulations!"],[5739,5797,"Thank you."],[5826,5889,"You want to head home?"],[5960,6018,"Yeah."],[6035,6197,"Just give me a few minutes"],[6197,6331,"to wrap things up with Harry."],[8149,8199,"Can you come back"],[8199,8258,"when you have a moment?"],[8320,8379,"Thanks."],[8750,8900,"So, how's that Matt Spencer doing?"],[9042,9196,"Two broken legs so far."],[9334,9455,"Any special requests, sir?"],[9522,9626,"No, that should be enough."],[9722,9859,"Send him back to his parents."],[9859,9926,"Hopefully, that will"],[9926,10005,"keep them occupied,"],[10005,10080,"taking care of him."],[10122,10193,"Absolutely."],[10222,10360,"Why is Justus Corp's GM"],[10360,10523,"following Justin's orders?"],[10623,10752,"Who is my husband, really?"]],"60":[[379,500,"Hey, you're back!"],[617,688,"Yeah."],[746,871,"What were you two talking about?"],[871,959,"You seemed to be..."],[1096,1176,"Do you guys know each other?"],[1201,1359,"Mr. Blake was just asking for, uh..."],[1422,1614,"Some money for his son's tuition."],[1639,1693,"Yes."],[1743,1868,"Certainly, that's it."],[1910,2064,"And it's all squared away now."],[2248,2339,"Justin's a good man."],[2360,2494,"I guess I'd better be going now."],[2556,2694,"Borrowing money..."],[2715,2886,"Haven't I heard that excuse before?"],[3849,3887,"Hello?"],[3920,4004,"Ma'am, Mr. Patton"],[4004,4099,"won't be home for dinner."],[4129,4229,"I ordered food for you from"],[4229,4337,"The International Hotel."],[4366,4421,"It's on the counter."],[4625,4754,"Okay. Thank you, Phillip."],[5584,5764,"Justin's busy on the same day"],[5764,5885,"the Justus Corp is acquiring"],[5885,6051,"The International Hotel."],[6189,6318,"I think I know his secret."]],"61":[[129,212,"Here's the file"],[212,367,"for the Johnson transaction."],[1205,1301,"He's busy..."],[1447,1526,"Just like I thought,"],[1526,1668,"and Justin always answers my calls"],[1668,1789,"which means he's dealing with"],[1789,2077,"something really important."],[2173,2281,"Justus Corp."],[2748,2827,"Hey!"],[2894,2986,"Why didn't you answer"],[2986,3082,"my phone earlier?"],[3194,3282,"Miss me already?"],[3465,3603,"Okay, well, come home soon, okay?"],[3603,3674,"Okay."],[3774,3887,"-Bye -Bye."],[4029,4179,"Okay, am I reading too far into this?"],[4212,4325,"Is there really a connection"],[4325,4446,"between my husband..."],[4521,4625,"and the Justus Corp?"],[5000,5130,"Well it is time to find out."]],"62":[[379,483,"If Justin is really"],[483,696,"the CEO of Justus Corp,"],[784,934,"I'll catch him in the act tonight."],[1038,1272,"I saw him go down this hallway..."],[1359,1451,"Where'd he go?"],[2177,2314,"Well, it is fancy seeing you here."],[2314,2414,"What are the chances?"],[2502,2656,"What are the chances, indeed."],[2802,2915,"What are you doing here?"],[3061,3174,"My sweet little liar."]],"63":[[45,129,"What do I do?"],[204,271,"I can't just say that"],[271,421,"I'm trying to expose him!"],[579,679,"You said that you were staying"],[679,821,"out late, so I just wanted to see."],[896,1055,"You know, if you were..."],[1213,1338,"Seeing someone else on the side."],[1818,1868,"Oh!"],[1868,2064,"Wait, put me down!"],[2686,2752,"What are you doing?"],[2752,2869,"Just trying to prove to my wife"],[2869,2998,"that I only have eyes for her."],[4129,4220,"Fucking damnit!"],[4454,4587,"Okay, uh..."],[4662,4750,"The board..."],[4867,5092,"Is going to picking a new CEO"],[5092,5196,"of Patton Corporation"],[5196,5276,"in two days."],[5367,5467,"It's either me..."],[5518,5580,"Or Justin."],[5697,6022,"If it wasn't for that bitch, Eliza,"],[6089,6164,"then the board wouldn't"],[6164,6314,"even be considering Justin!"],[6356,6556,"Eliza is ruthless!"],[6556,6664,"As long as she's around"],[6664,6819,"Justin is untouchable!"],[6881,7007,"Fiona is shattered."],[7061,7244,"Matt Spencer may never walk again."],[7273,7365,"And, I mean, his parents"],[7365,7444,"aren't much better off."],[7444,7557,"I mean, they've been mooching"],[7557,7749,"off of Eliza's money for years."],[7824,7937,"They're useless now."],[8008,8083,"Okay..."],[8141,8287,"Desperate times call for"],[8287,8458,"desperate measures, right?"],[8562,8783,"Mom, do you still have those pills?"],[8921,8996,"You know..."],[9042,9121,"The pills you used"],[9121,9267,"to kill Justin's mom?"],[9638,9722,"Yes..."],[9805,9951,"Alright, this is what we're going to do."],[10035,10114,"We're going to invite"],[10114,10314,"Justin and Eliza over for..."],[10410,10527,"A little tea time."]],"64":[[342,696,"Justin, Lily, or, I mean..."],[704,809,"Eliza."],[859,938,"Welcome."],[1009,1247,"Eliza, we've been so silly!"],[1276,1447,"Not recognizing the founder"],[1447,1697,"and CEO of Spencer Realty."],[1764,1897,"I guess I've just never met"],[1897,2072,"a woman as important as you!"],[2352,2594,"Come in guys, have a seat."],[3144,3215,"Justin..."],[3357,3582,"We invited you here to bury the hatchet."],[3641,3795,"Let's just put all this behind us."],[3858,4012,"I mean, we are brothers after all,"],[4012,4074,"right?"],[4179,4354,"These snakes are up to something."],[4471,4583,"The question is..."],[4646,4721,"What?"],[4829,5009,"Here, have some tea."],[5513,5609,"Justin!"]],"65":[[150,200,"Justin!"],[554,608,"I'm okay."],[829,980,"Eliza, relax!"],[1030,1238,"A cripple's legs can't feel a thing."],[1409,1497,"You know what? That is enough!"],[1730,1814,"And how dare you"],[1814,1914,"disrespect my husband?!"],[1931,2164,"Don't be dramatic, Eliza."],[2164,2310,"It was an accident."],[2310,2444,"I'll call someone to help"],[2444,2590,"Justin get changed."],[2590,2669,"No, I will do it!"],[3791,3862,"You know what? I think they're"],[3862,3945,"planning something."],[4162,4312,"Look, we have to be careful."],[4625,4738,"Justin?"]],"66":[[133,429,"Justin, I have an antibiotic for you."],[487,621,"I know that your legs couldn't"],[621,788,"feel the burn, but you should take it,"],[838,1013,"to avoid infection."],[1234,1322,"Justin, no."],[1397,1447,"It's okay."],[1501,1639,"I think I left my phone downstairs,"],[1639,1755,"could you please get it for me?"],[2085,2131,"But, I..."],[2706,2865,"Thank you so much, Eva."],[3011,3132,"This is very thoughtful of you."],[5442,5513,"This is..."],[5751,5809,"Justin!"]],"67":[[1159,1305,"What are you two doing here?"],[1305,1426,"Justin is sick,"],[1426,1622,"of course we wanted to come."],[1664,1793,"What does the doctor say?"],[1843,2022,"Sick? Really?"],[2022,2110,"You are the one"],[2110,2223,"who gave him those pills!"],[2227,2348,"Eliza, enough!"],[2373,2565,"I was just trying to help!"],[2619,2811,"Justin just fell over."],[2865,3007,"It reminded me of his mother"],[3007,3190,"just before she passed."],[3319,3432,"Eva Patton..."],[3490,3799,"If anything happens to him,"],[3866,4029,"I will make sure that the Patton family"],[4029,4250,"is wiped off the map."],[4371,4479,"Mark my words."],[4833,4925,"Doctor, how is he?"],[5067,5167,"Justin's alive,"],[5221,5292,"for now."],[5463,5634,"But it's not looking good for him."],[5834,6010,"You should prepare for the worst."]],"68":[[870,910,"Sir."],[1143,1166,"Sorry."],[1230,1356,"I've spoken with the doctor."],[1356,1426,"He's on our side."],[1483,1533,"Everyone will think"],[1533,1603,"you're on your deathbed."],[1770,1840,"Have this tested."],[2363,2416,"Yes, sir."],[2616,2706,"Don't you want to tell your wife?"],[2746,2846,"She's a little worried about you."],[2893,2950,"I'll tell her."],[2950,3040,"Okay? Don't worry."],[3130,3173,"This is the chance"],[3176,3276,"I've been waiting for."],[3356,3426,"I have to get it right."],[3446,3506,"Of course."],[4490,4690,"Phillip, when did you get here?"],[4740,4833,"Just now, ma'am."],[4873,4960,"Sorry for waking you."],[5113,5320,"No, it's okay. I can walk you out."],[5960,6013,"Phillip."],[6293,6426,"Didn't my husband ask you"],[6426,6553,"to get those pills tested?"],[6636,6723,"Well, um..."],[6776,6883,"Get these tested as well."],[7000,7050,"Uh..."],[7113,7240,"Ma'am, I'm afraid I don't know"],[7243,7326,"what you're talking about."],[7596,7733,"I heard everything in there."],[7826,8116,"And I know Justin is perfectly healthy."],[8360,8436,"So..."],[8523,8616,"What else is my husband"],[8620,8740,"hiding from me, Phillip?"]],"69":[[734,867,"Justin Patton, if you don't open"],[867,1021,"your eyes in three seconds,"],[1021,1134,"I am divorcing you."],[1217,1292,"Three..."],[1338,1422,"Two..."],[1572,1676,"Muffin!"],[1751,1872,"Please, sit down."],[1872,1972,"Let me explain."],[2890,3036,"I didn't want you to get hurt."],[3182,3257,"Knowing..."],[3415,3511,"It could bring you trouble."],[3582,3632,"Justin."],[3674,3816,"Did you think that I was going to"],[3816,3895,"bring you trouble when you"],[3895,4062,"found out that I was Eliza Spencer?"],[4145,4208,"I'm sorry."],[4446,4525,"My mother..."],[4650,4825,"Didn't die of natural causes."],[5005,5113,"So I've spent the last decade"],[5113,5205,"pretending to be"],[5251,5347,"frail and sick,"],[5413,5484,"just so I could"],[5484,5613,"fly under the radar, and..."],[5701,5847,"Uncover the truth behind her death."],[6135,6193,"Eliza..."],[6585,6715,"I'll tell you anything you want to know."],[7307,7461,"No more secrets between us."],[7674,7720,"Okay."],[7857,7962,"Start from the beginning."],[8345,8629,"We've waited years, and now..."],[8679,8821,"Patton Corporation"],[8863,9017,"will finally be yours."],[9067,9275,"The doctors say that Justin"],[9275,9434,"is going to kick the bucket"],[9434,9613,"any day now."],[9788,9947,"Today, I will be crowned"],[9947,10160,"CEO of Patton Corporation."],[10247,10331,"And Justin..."],[10414,10518,"He'll be six feet under"],[10518,10635,"where he belongs."]],"70":[[100,233,"Patton Corporation"],[233,442,"is without a capable leader,"],[442,525,"as of right now."],[525,625,"My dear brother,"],[713,846,"he's in a deep coma"],[900,1026,"and showing no signs"],[1026,1101,"of improvement."],[1142,1317,"So we need to appoint a new CEO."],[1426,1543,"I was thinking me."],[1655,1835,"I support Mr. Patton's proposal."],[1956,2035,"I agree as well."],[2102,2218,"I always considered Derek to be"],[2218,2377,"the sole heir of the Patton family."],[2481,2531,"Great!"],[2531,2694,"Now that we're all in agreement..."],[2731,2911,"Not so fast."],[3253,3340,"Eliza."],[3390,3486,"Why are you here?"],[3516,3616,"You should be taking care of"],[3616,3841,"my dead... Dying brother."],[3899,4054,"Well, I'm actually here"],[4054,4216,"to congratulate"],[4216,4421,"Patton Corp's new CEO"],[4421,4558,"on behalf of Spencer Realty."],[4629,4675,"I am..."],[4742,4879,"Welcome, right?"],[4979,5042,"Of course."],[5105,5238,"Miss Spencer please have a seat."],[5484,5626,"Let's skip the formalities."],[5701,5839,"Everyone is in support"],[5839,5939,"of Derek Patton."],[6001,6135,"He is our only choice."],[6260,6418,"Well, shouldn't you put it up to a vote"],[6418,6519,"before you decide?"],[6740,6840,"I mean, we're all here."],[6877,7027,"Justin's basically dead."],[7107,7219,"Are we waiting on a dead man?"],[7824,7916,"Good morning, everyone."]],"71":[[325,575,"Justin, shouldn't you be, uh..."],[671,813,"You said he was dying!"],[888,1001,"How is he here?"],[1067,1167,"Derek, I thought you'd be happier"],[1167,1309,"to see your brother make such a"],[1309,1438,"miraculous recovery."],[1459,1643,"Of course I'm happy."],[1676,1797,"Justin Patton looks healthy."],[1951,2093,"Derek's got some competition."],[2114,2227,"He's still crippled!"],[2298,2435,"Is that what you want for the face"],[2435,2535,"of the company?"],[2648,2761,"We'll look weak!"],[2890,2957,"Eva."],[3036,3098,"Reveal the truth"],[3098,3215,"about my mother's death,"],[3215,3365,"and I'm willing to step aside."],[3365,3511,"What are you talking about?"],[3511,3616,"Your mother?"],[3653,3878,"She died from a sudden illness."],[4175,4316,"This is your last chance"],[4316,4400,"brother-in-law."],[4504,4679,"Tell your mother to spit out the truth,"],[4792,4896,"or else."],[5038,5146,"They're bluffing."],[5146,5296,"They don't have proof."],[5372,5543,"The board supports you!"],[5747,5880,"Before the board votes,"],[5960,6010,"there's one more thing"],[6010,6076,"they should know."]],"72":[[546,675,"Your legs work?"],[713,855,"Justin can stand?"],[967,1055,"And walk?"],[1151,1272,"If Justin isn't disabled,"],[1338,1443,"then he's just as capable"],[1443,1530,"as Derek is."],[1555,1676,"You lying bastard!"],[1735,1814,"Gentlemen."],[1876,2147,"If you appoint Derek here as CEO,"],[2185,2310,"Patton Corporation will become"],[2310,2435,"the number one enemy"],[2435,2565,"to Spencer Realty"],[2598,2736,"and Justus Corp."],[2811,2961,"Just because you support your"],[2961,3115,"useless husband, doesn't mean"],[3115,3307,"that Justus Corp will do the same."],[3536,3616,"Mr. Hale!"],[3666,3937,"Oh, yes! I am so glad you're here!"],[4029,4120,"Everybody, this is"],[4120,4216,"the general manager"],[4216,4300,"of Justus Corp."],[4337,4412,"You wouldn't believe it."],[4412,4592,"My sister-in-law is claiming that"],[4592,4700,"Justus Corp is going to go"],[4700,4796,"against Patton."],[4833,4984,"Boss, I have the reports."],[5067,5201,"Wait, I'm sorry."],[5201,5296,"What did you just call him?"],[5488,5638,"Mr. Patton is the founder and CEO"],[5638,5747,"of Justus Corporation,"],[5747,5860,"which makes him my boss."],[6035,6135,"That's impossible!"],[6172,6302,"He's been crippled for over a decade,"],[6302,6398,"he can't be the founder"],[6398,6473,"of Justus Corp."],[6715,6844,"You insult my boss or Miss Spencer"],[6844,7044,"again, and it won't just be a slap."],[7194,7349,"It's not an insult, actually."],[7440,7561,"You know it's funny,"],[7561,7695,"if you all didn't look down on people"],[7695,7782,"with disabilities,"],[7841,7924,"Eliza and I wouldn't have got"],[7924,8037,"the justice we deserve."],[8191,8295,"Your prejudice made it easy"],[8295,8362,"to fool you."],[8479,8562,"So thanks."]],"73":[[154,229,"He's really..."],[279,462,"Just-us Corp."],[462,621,"Named after its founder,"],[713,825,"Justin Patton."],[946,1046,"That's why they handed over"],[1046,1188,"twenty-five percent stake"],[1188,1347,"of Spencer Realty to Eliza."],[1413,1480,"God!"],[1584,1672,"If there's no other questions,"],[1672,1755,"we can start voting."],[1785,1830,"No."],[1864,1956,"That's not fair."],[1956,2147,"Don't trust him, he's a scam artist."],[2147,2223,"Look at him!"],[2252,2519,"I vote for Justin to be CEO."],[2715,2844,"I vote for Justin as well."],[3057,3203,"You cowards!"],[3232,3319,"Derek, Derek,"],[3319,3495,"please don't take it personally."],[3545,3782,"We can't go against Spencer Realty"],[3782,4062,"and Justus Corp at the same time."],[4154,4341,"Fine. Justin,"],[4479,4629,"you may have won this time,"],[4675,4771,"but it's not over."],[4854,4929,"You're right."],[5042,5117,"It's not over."],[5259,5384,"You've already won."],[5384,5580,"You're CEO. What more do you want?"],[5638,5780,"Eva still needs to reveal the truth"],[5780,5885,"about my mother's death."],[6014,6210,"Justin, I'm your stepmother."],[6210,6464,"We're family. You can't do this."],[6464,6527,"According to the"],[6527,6644,"toxicology report,"],[6790,6981,"the pills Eva Patton used"],[6981,7094,"to poison Justin,"],[7298,7411,"are the same ones"],[7411,7499,"found in his mother's system"],[7499,7570,"when she died."],[7774,7907,"Stop, you're lying!"],[7907,8087,"You're trying to frame me!"],[8128,8237,"Tell that to the judge."],[8408,8717,"Justin! I'm your stepmother. Please!"],[8717,8863,"Please, I'm really sorry!"],[8863,8996,"I'm so sorry!"],[8996,9259,"Please, you can't put me in prison!"]],"74":[[0,75,"Please!"],[75,183,"You killed my mother!"],[233,379,"Treated me like dirt for years."],[433,567,"Prison is the least you deserve."],[679,792,"Let go of me!"],[850,1013,"Derek! Derek, save me!"],[1013,1242,"Please! Derek!"],[1488,1626,"So..."],[1705,1864,"I think it's time for me to leave."],[1997,2097,"I'm just going to go."],[2097,2235,"If I ever see you anywhere near"],[2235,2331,"me or my wife,"],[2377,2448,"You'll be sharing a cell"],[2448,2519,"with your mother."],[4833,4909,"I've got some papers"],[4909,5030,"I'd like you to sign."],[5163,5226,"Oh."],[5271,5342,"Okay."],[5601,5768,"I'm transferring Patton Corporation"],[5768,5905,"and Justus Corporation"],[5905,5976,"to your name."],[6293,6414,"No, Justin, I can't do that."],[6473,6552,"Hang on."],[6602,6798,"The last page is the most important."],[6902,7094,"Ok, well, I'm not going to sign..."],[7365,7486,"I want to do this right."],[7574,7670,"No secrets."],[7670,7870,"No more hidden identities."],[8116,8220,"Eliza Spencer..."],[8379,8479,"Will you marry me?"],[8833,8925,"Yes!"],[8992,9267,"Yes, I will marry you Justin Patton."],[9534,9592,"But..."],[9655,9772,"On one condition."],[9897,10018,"If I marry you,"],[10139,10272,"can I eat lots of yummy food"],[10272,10356,"everyday?"],[10694,10806,"Of course!"]]}