,"You're a dirty janitor"],[3186,3224,"who doesn't"],[3224,3294,"deserve such"],[3294,3495,"a beautiful painting."],[3541,3649,"Jack, he's"],[3649,3849,"not a thief."],[3849,4049,"There must be a misunderstanding."],[4099,4300,"He did all this for me."],[4320,4404,"Punish me instead."]],"55":[[37,183,"Emma."],[183,346,"You don't have to do this."],[346,396,"I can't let"],[396,567,"this happen to you."],[567,792,"You've done so much to help me."],[813,900,"Emma."],[900,930,"You're going"],[930,1084,"to lose everything."],[1084,1188,"You'll even lose"],[1188,1388,"the title as chairwoman."],[1438,1664,"Jack stood by me every time."],[1685,1726,"I'm willing"],[1726,1926,"to do the same for him."],[1939,2139,"Emma."],[2173,2364,"You don't have to do this."],[2364,2565,"We're family."],[2610,2681,"We share the same"],[2681,2794,"problems, and we"],[2794,2994,"deal with them together."],[3365,3499,"Emma,"],[3499,3687,"you're willing to give up"],[3687,3887,"everything for Jack?"],[3953,4133,"Yes, Vivian."],[4133,4287,"Very well."],[4287,4391,"But there's something"],[4391,4592,"you all should know."],[4600,4742,"I never said the painting"],[4742,4942,"was stolen."],[4971,5188,"What if the painting wasn't stolen?"],[5230,5305,"How else could"],[5305,5380,"a janitor"],[5380,5538,"have gotten his hands on it?"],[5538,5739,"Because it was already given"],[5751,5843,"as a gift."]],"56":[[8,112,"What?"],[112,229,"Gifted?"],[229,350,"To whom?"],[350,504,"To my boss."],[504,704,"The CEO of Orion Company."],[763,838,"Just."],[838,1009,"Does that mean my dad is-"],[1009,1092,"Impossible!"],[1092,1242,"Your dad is a janitor."],[1242,1322,"How could he be"],[1322,1539,"Orion Corporation's CEO?"],[1584,1680,"No, no, no."],[1680,1847,"The Orion Corporation"],[1847,1960,"is an international"],[1960,2081,"arms company."],[2081,2302,"Its control spans the whole world."],[2389,2481,"The CEO has"],[2481,2652,"been famously discreet,"],[2652,2702,"and he has"],[2702,2765,"never made"],[2765,