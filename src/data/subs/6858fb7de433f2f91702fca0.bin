{"1":[[1488,1626,"Kids will be kids."],[1776,1868,"It's nice to have some peace"],[1868,1985,"and quiet, finally."],[3023,3157,"What the fuck, Jack?"],[3253,3386,"Who said you could come in here?"],[3628,3716,"Listen..."],[3920,4004,"Hey, hey."],[4074,4187,"No reason to get worked up,"],[4187,4275,"Principal Davis."],[4491,4642,"What did you see, you old perv?"],[4696,4842,"Look, I didn't see anything."],[4859,5017,"I'm just here to clean, okay?"],[5017,5113,"Good boy."],[5138,5417,"Now keep your mouth shut or else."],[8921,9004,"What the fuck?"],[9004,9096,"What's happening?"],[9121,9246,"Isn't that our janitor, Jack?"],[9813,9880,"Really?"],[9880,9968,"Smoking?"],[10026,10155,"Don't you know that these will kill you?"],[10585,10660,"Boss!"],[10714,10769,"Boss!"],[10935,11073,"All right, kids, come on, get out of here."]],"2":[[25,216,"What have I told you two?"],[241,425,"Don't make a scene in public."],[462,638,"What's with the crazy entourage?"],[667,725,"Boss,"],[725,900,"you’re the CEO of Orion Corporation."],[900,1051,"Orion has become the world's"],[1051,1263,"largest military defense contractor"],[1263,1422,"under your leadership."],[1455,1714,"We need you now, more than ever."],[1780,1876,"Boss, you're the richest man"],[1876,1956,"in the world."],[1989,2160,"You really going to retire as a janitor?"],[2193,2302,"I'm old now."],[2331,2523,"I don't care about any of that stuff."],[2540,2690,"Besides, there's nothing wrong"],[2690,2786,"with being a janitor."],[2877,2961,"Now, today..."],[3019,3190,"Today is my grandson's birthday,"],[3215,3336,"and all I want now,"],[3382,3511,"is to watch him grow up"],[3511,3678,"safe and happy."],[3807,3953,"You two leave me in peace."],[4041,4137,"Boss, wait!"],[4346,4604,"This is from the Da Vinci collection."],[4604,4767,"It's $50 million."],[4767,5025,"It's our birthday gift for your grandson."],[5121,5230,"This is a corporate card."],[5280,5355,"No limit set."],[5572,5697,"In case you need to buy anything."],[5864,5989,"I don't need these things."],[6339,6556,"All right, all right."],[6556,6694,"Just this once."],[6861,6936,"Now,"],[6936,7019,"somebody give an old man"],[7019,7140,"a ride home, okay?"],[7165,7232,"I can't be late for"],[7232,7349,"my grandson's birthday."],[8012,8179,"Just drop me off here."],[8237,8308,"I don't want anyone"],[8308,8454,"to see me with you guys."],[8579,8679,"Thanks for the ride."],[9517,9630,"Who is that?"],[9655,9830,"What is a janitor doing here?"],[9847,9968,"Maybe he's homeless,"],[9968,10118,"and is trying to steal some food?"],[10735,10785,"Dad?"],[11031,11111,"Why did you come here"],[11111,11198,"dressed like that?"]],"3":[[33,120,"It’s Tommy's birthday party"],[120,304,"and your dad pulls this shit on me."],[304,483,"He's obviously trying to spite me."],[483,629,"Grandpa, why are you dressed"],[629,759,"like a poor person?"],[792,1063,"Mommy, she said that"],[1063,1226,"janitors are losers."],[1292,1359,"Tommy,"],[1434,1609,"clothes aren't important, okay?"],[1609,1760,"What's important is I'm here to"],[1760,1910,"celebrate your birthday, buddy."],[1960,2210,"Dad, you're embarrassing us."],[2210,2318,"Exactly."],[2318,2410,"All of our guests are"],[2410,2527,"dressed to the nines."],[2527,2665,"You are being so rude to them,"],[2665,2815,"showing up looking like a bum."],[2831,3073,"Who is that? He looks broke."],[3094,3194,"Wait, did you hear Mike?"],[3194,3340,"He was calling him his dad."],[3582,3699,"Lisa, Mike."],[3699,3870,"Come on. It's not a big deal."],[3887,3999,"Let's not make a scene, okay?"],[3999,4066,"We can talk about it"],[4066,4179,"after the birthday party."],[4225,4325,"Not a big deal?"],[4341,4462,"You're the one embarrassing us."],[4462,4617,"You don't get to say it's not a big deal."],[5309,5388,"Thank you all for coming to"],[5388,5497,"Tommy's birthday party."],[5551,5647,"I'd also like to share"],[5647,5818,"some exciting news with you all."],[5901,6143,"Tommy will be getting a new baby"],[6143,6285,"sibling soon."],[6573,6623,"What?"],[6673,6769,"Lisa's pregnant?"],[6831,6990,"That's amazing. Mike."],[7023,7165,"Congratulations, Lisa."],[7265,7323,"Guys,"],[7382,7536,"I have a very special"],[7536,7620,"present for you."],[7661,7882,"Are you going to tell your dad or me?"],[8245,8299,"Dad."],[8391,8546,"Lisa's pregnant."],[8687,8758,"We don't have enough room"],[8758,8837,"in the house."],[9067,9138,"What does that mean?"],[9205,9296,"The best present you could"],[9296,9421,"give my family."],[9480,9538,"Move out."]],"4":[[75,116,"What?"],[196,325,"You can't be serious."],[325,442,"Dad, I'm almost 30."],[492,583,"I want to live alone here"],[583,838,"with my wife and my kids."],[838,867,"Mike,"],[867,984,"I mean, I bought this house."],[1076,1176,"Where am I supposed to go?"],[1192,1255,"Who cares?"],[1255,1401,"You're just a useless old man"],[1401,1518,"that no one wants around."],[1530,1668,"I can't have a smelly,"],[1668,1830,"filthy janitor around my baby."],[1847,2047,"Mike has everything that he needs."],[2089,2289,"A beautiful wife, and soon"],[2289,2489,"two healthy little children."],[2527,2694,"We're the picture of a perfect family."],[2719,2794,"Are you really going to"],[2794,2923,"ruin things for him?"],[2982,3090,"I wasn't there"],[3153,3278,"when Mike was growing up,"],[3286,3499,"and I regret that every single day."],[3670,3753,"Guys, I just..."],[3841,4033,"I just want to spend time with my family."],[4124,4266,"But we don't want to spend time"],[4325,4383,"with you."],[5134,5180,"Okay."],[5242,5334,"Yeah. I'll just... I'll go."],[5914,6022,"One last thing, Mike,"],[6022,6101,"before I go."],[6214,6272,"What?"],[6352,6452,"Don't make the same mistake"],[6452,6523,"that I did."],[6698,6819,"Family's everything."],[7036,7111,"Remember that."],[7887,8049,"I spent the last 20 years"],[8087,8229,"working for money and power."],[8245,8362,"What’s the use"],[8387,8612,"being CEO of Orion Corporation,"],[8612,8837,"if I have no one by my side?"],[8883,8975,"Leave me alone!"],[9313,9442,"Don't be so cold."],[9442,9563,"Let's have some fun."],[9576,9693,"Just giving you what you wanted!"],[9751,9855,"You're asking for it,"],[9880,10068,"strutting around late at night,"],[10068,10164,"dressed like that!"],[10260,10293,"Stop!"]],"5":[[16,125,"Mr. Bradshaw."],[150,266,"Who the fuck are you?"],[412,533,"Hey, you old fuck."],[604,717,"Mind your business."],[796,855,"Or..."],[925,1034,"we’ll beat your ass!"],[1138,1209,"Leave her alone."],[3699,3812,"Wow."],[3849,4012,"I didn't know our school's janitor's"],[4012,4112,"so dope."],[4195,4316,"Are you all right, Amelia?"],[4379,4454,"Yeah."],[4525,4600,"Thank you,"],[4633,4754,"Mr. Bradshaw."],[4838,4934,"Yeah."],[5121,5234,"Mr. Bradshaw."],[5409,5580,"If it's not too much trouble,"],[5618,5743,"could you walk me home?"],[5847,5922,"Yeah, of course."],[6348,6423,"So, what were you doing"],[6423,6535,"at the school so late?"],[6577,6723,"I forgot to bring my homework after"],[6723,6898,"cheer practice, so I came back to get it."],[6998,7086,"What about you?"],[7144,7290,"How come you're out so late at night"],[7290,7386,"all along, too?"],[7507,7574,"No reason."],[7599,7766,"Oh, come on, you can tell me."],[7791,7836,"Fine."],[7928,8158,"My son and daughter in law"],[8233,8341,"kicked me out of the house."],[8441,8575,"I have nowhere to go, so,"],[8575,8654,"went back to the school."],[8946,9113,"After my wife died, I..."],[9259,9413,"buried myself in work."],[9505,9613,"Neglected my son."],[9738,9880,"I guess this is what I get."],[9880,10043,"No. Your son and daughter in law"],[10043,10151,"are terrible."],[10222,10314,"They don't deserve you."],[10381,10543,"You're handsome,"],[10543,10681,"and you're really tough."],[10819,10865,"Hey,"],[10960,11031,"do you want a wife?"]],"6":[[12,75,"What?"],[100,354,"Listen, I'm serious. You're a great guy."],[354,450,"I really like you."],[471,684,"No, no, no!"],[717,892,"I'm too old for you."],[892,1109,"You're too young for even my son, no!"],[1109,1272,"I know that, duh."],[1297,1455,"I was talking about my mom."],[1530,1568,"Oh."],[1693,1743,"Wait."],[1801,1876,"Your mom?"],[1885,1939,"Yeah."],[1960,2043,"My mom is our school's"],[2043,2114,"chairwoman."],[2131,2235,"She's pretty."],[2235,2348,"She's smart,"],[2369,2535,"and a total badass."],[2535,2615,"Do you want to meet her?"],[2652,2823,"I could totally introduce you two."],[2823,2869,"Thank you."],[2902,2944,"No."],[2994,3048,"That's ok."],[3048,3174,"Look, are we almost there"],[3174,3286,"because I got to get going."],[3324,3415,"Come on!"],[4149,4295,"Amelia, it's late."],[4358,4421,"Where were you?"],[4471,4637,"Mom, I ran into some trouble"],[4637,4713,"on the way home,"],[4713,4900,"but Mr. Bradshaw saved me."],[6552,6644,"Are you okay?"],[6681,6735,"Yeah."],[6798,6865,"I'm all right."],[6911,7048,"Okay. We'll talk about that later."],[7090,7194,"And you are?"],[7219,7307,"Jack Bradshaw."],[7349,7565,"I'm a janitor at your school."],[7628,7691,"Janitor?"],[7795,7920,"And you're walking my daughter"],[7920,8045,"home alone, why?"],[8058,8283,"Mom, I asked him to."],[8433,8671,"It's only right to help those in need."],[8671,8750,"Is that so?"],[8892,9029,"Well, aren't you a man of principle."],[9063,9263,"Mom, Mr. Bradshaw is a good man."],[9300,9380,"He saved me."],[9421,9547,"Amelia, why don't you go inside"],[9547,9722,"so I can talk to this good man?"],[10343,10481,"Now that she's gone."],[10560,10627,"Why don't you tell me"],[10627,10777,"why you really came all this way?"],[10902,10960,"Money?"],[11040,11111,"A promotion?"],[11165,11219,"Something else?"]],"7":[[145,204,"No."],[308,425,"Just trying to do the right thing."],[496,608,"It's okay to want money."],[688,775,"I'll write you a check."],[792,963,"Just come by my office to pick it up."],[1030,1121,"I know you think because"],[1121,1209,"I'm a janitor."],[1255,1401,"I want money or something,"],[1401,1555,"but I really don't."],[1764,1826,"Good night."],[1856,1922,"Wait."],[2110,2344,"I should thank you for helping Amelia."],[2502,2573,"That's all I need."],[2748,2831,"You're welcome."],[3511,3636,"What an interesting man."],[5271,5317,"Mom."],[5367,5488,"What did you think about Jack?"],[5655,5755,"What do you mean?"],[5951,6118,"I mean, isn't he handsome?"],[6177,6302,"And he saved me today."],[6377,6510,"He is handsome."],[6606,6681,"And?"],[6748,6848,"And single."],[6894,7032,"So you should marry him."],[7182,7236,"What?"]],"8":[[58,137,"What?"],[171,221,"Yeah."],[266,538,"You've been single for so long, mom."],[550,709,"It's time for you to find a cute guy"],[709,804,"and get married."],[842,950,"Jack is handsome,"],[980,1130,"and he's a good person."],[1130,1343,"And you look so cute together."],[1343,1509,"You can't joke like that."],[1555,1710,"He's the janitor at my school."],[1760,1922,"I'm his boss's boss."],[1993,2277,"Oh, come on, you can at least try."],[2314,2410,"Come on. For me."],[2456,2569,"Please."],[2627,2802,"All right, I'll consider it."],[2848,2973,"But before I even think about"],[2973,3044,"dating him,"],[3103,3294,"I got to see if he'll pass my test."],[3374,3478,"Test?"],[5334,5405,"Excuse me."],[5463,5543,"Excuse me."],[5593,5739,"No littering, please."],[5914,6039,"Unbelievable."],[7044,7161,"She dropped her wallet?"],[7799,7882,"Mom, he..."],[7928,8045,"He took the money?"],[8191,8337,"Looks like he failed my test."],[8425,8612,"Maybe he had a good reason?"],[8650,8812,"We shouldn't jump to conclusions."],[8892,8979,"It's over."],[9084,9213,"How people act when they think"],[9213,9330,"nobody's watching shows their"],[9330,9421,"true character."],[9534,9642,"I can't trust somebody who"],[9642,9768,"would give in to their greed"],[9768,9851,"so easily."],[10381,10460,"My wallet."],[10493,10635,"Has anyone seen my wallet?"]],"9":[[200,246,"Yeah."],[321,446,"I think you must've drop this."],[1042,1276,"Oh, and it's all here."],[1297,1447,"Aren't you the sweetest, Jack?"],[1697,1847,"Hey, big guy."],[1897,2097,"Let me show you how grateful I am."],[2097,2289,"Did you like what you saw last time?"],[2310,2560,"Or we can do anything else"],[2560,2627,"you want."],[2644,2865,"I never told her to try and seduce him."],[2865,2944,"Okay, wait."],[2944,3065,"Let's not be hasty."],[3094,3215,"Um, look, sorry."],[3215,3282,"Mom, look."],[3315,3420,"He gave back the wallet"],[3420,3599,"and he didn't give in to that floozy."],[3616,3695,"You were right."],[3741,3866,"I jumped to conclusions."],[3891,4158,"So you're going to give him a chance?"],[4191,4233,"Fine."],[4287,4391,"I'll consider it."],[5113,5234,"Hey, Jack."],[5814,6043,"I've had my eyes on you for a while now."],[6097,6214,"Why don't we go on a date,"],[6214,6356,"get to know each other?"],[6489,6556,"Thank you."],[6594,6861,"But just, I'm okay. I'm not interested."],[6861,7077,"Oh, don't be shy."],[7127,7290,"I'm a teacher, and you're just"],[7290,7382,"some janitor."],[7449,7545,"You should be honored"],[7545,7640,"I'm into you."],[7782,7862,"No. Thank you."],[7924,8149,"I just, I'm really not looking for romance"],[8149,8220,"right now, so..."],[8354,8487,"What's your problem, huh?"],[8579,8733,"You think you're too good for me?"],[8808,9009,"You scrub toilets for a living."],[9071,9205,"I know my own worth,"],[9246,9371,"and I don't need your approval."],[9384,9492,"Oh, please."],[9517,9647,"You're just some loser."],[9730,9901,"You're never landing anyone"],[9901,10001,"better than me."],[11302,11373,"Hop in, Jack."],[11407,11486,"We're late for dinner."]],"10":[[75,137,"Sorry."],[216,308,"My ride's here."],[1714,1864,"How did that janitor"],[1864,2014,"land the chairwoman?"],[2268,2402,"Thanks for saving me back there."],[2473,2552,"I can't let anyone"],[2552,2660,"pick on my husband."],[2756,2811,"What?"],[2857,2932,"Husband?"],[2932,3061,"Yes, husband."],[3236,3324,"Relax."],[3361,3545,"We can just have a contract marriage."],[3561,3703,"A contract marriage?"],[3762,3928,"You saved Amelia's life."],[3983,4162,"She's so grateful to you, and"],[4312,4404,"she likes you a lot."],[4608,4700,"But that's just..."],[4700,4859,"She doesn't have a father."],[4929,5059,"All she's ever wanted is to have"],[5059,5155,"a full family."],[5267,5359,"You've met her."],[5359,5417,"You know how stubborn"],[5417,5488,"she can be."],[5526,5663,"I don't want to disappoint her."],[5860,5930,"I see."],[6210,6302,"So where are we?"],[6360,6489,"A charity banquet."],[6535,6677,"There's a $30 million donation"],[6677,6798,"to the school on the line."],[6877,7019,"I had my secretary purchase"],[7019,7157,"a prized Da Vinci painting."],[7161,7278,"A Da Vinci painting?"],[7303,7461,"Just like the one Vivian gave me?"],[7478,7716,"This is from the Da Vinci collection."],[7736,7895,"It's $50 million."],[8070,8128,"You ready?"],[8270,8320,"Yeah."],[8320,8375,"Okay."],[9705,9772,"I'm going to go speak to the"],[9772,9876,"school's biggest patron."],[9976,10055,"The painting, please."],[10055,10093,"Yeah."],[10293,10427,"Well, there she is."],[10452,10635,"If it isn't the gorgeous"],[10635,10814,"chairwoman, Miss Grayson."],[10856,11019,"Okay. Keep your distance, Carl."],[11019,11127,"We're not that close."],[11223,11307,"Jack?"],[11373,11594,"What's a dirty janitor doing"],[11594,11765,"in a black tie affair?"]],"11":[[16,175,"Do you know where you are?"],[196,483,"This is a high society event."],[538,654,"You're not even good enough"],[654,813,"to wait tables here."],[842,992,"Jack is my guest."],[992,1105,"Show some respect."],[1105,1263,"Guest?"],[1297,1459,"You brought a janitor?"],[1468,1564,"Emma,"],[1580,1730,"have you lost your mind?"],[1755,1872,"Watch your mouth!"],[1872,2002,"Know your place."],[2014,2173,"You're the principal at my school."],[2577,2681,"I'm sorry, Jack."],[2681,2806,"I didn't know he'd be so rude."],[2806,2890,"It's alright."],[2911,3015,"I'm used to it."],[3048,3165,"Words don't hurt me."],[3232,3336,"Alright."],[3365,3424,"I'll be right back,"],[3424,3541,"Okay?"],[4229,4387,"Chairman Grumman."],[4396,4554,"I have a present for you."],[4600,4763,"I hope you like it."],[5246,5401,"This is a classic piece."],[5718,5780,"Emma,"],[5780,5922,"how did you get this?"],[5922,6056,"From a private collector."],[6072,6210,"I hope it's to your liking."],[6210,6339,"Like it?"],[6339,6452,"It's amazing!"],[6452,6573,"It's going to be the centerpiece"],[6573,6706,"of my collection!"],[6723,6844,"I had my secretary purchase"],[6844,7002,"a prized da Vinci painting."],[7002,7132,"A da Vinci painting?"],[7132,7303,"Just like the one Vivian gave me?"],[7699,7778,"Emma,"],[7778,7945,"you are so thoughtful."],[7966,8128,"I'm so glad you like it."],[8149,8241,"You've been donating"],[8241,8370,"to the school for decades now."],[8370,8466,"It's the least I can do"],[8466,8562,"to show my gratitude"],[8562,8671,"for your patronage."],[8687,8850,"Of course, I will be donating"],[8850,9079,"$30 million this year as well."],[9150,9275,"No expenses spared"],[9275,9388,"for the best private school"],[9388,9488,"in the country."],[9509,9655,"Thank you for your continued trust,"],[9655,9726,"Mr. Grumman."],[9751,9876,"Wait!"],[10143,10318,"That painting is a fake!"]],"12":[[4,87,"What?"],[87,250,"It's a fake?"],[296,400,"Unbelievable."],[579,734,"What do you mean it's a fake?"],[734,892,"Carl, what do you mean?"],[1071,1234,"Because I bribed the secretary."],[1255,1472,"She tricked you into buying a forgery."],[1701,1810,"That painting is in"],[1810,1985,"the British Royal Collection."],[2043,2206,"It's a one of a kind."],[2243,2402,"So how is it here, Emma?"],[2452,2615,"Were you scammed?"],[2698,2823,"Or were you just"],[2823,2969,"lying?"],[2977,3073,"Emma,"],[3073,3182,"is this how you treat"],[3182,3340,"the biggest donor to your school?"],[3382,3516,"No, Mr. Grumman."],[3516,3674,"There must be a misunderstanding."],[3720,3803,"I had my secretary"],[3803,3862,"purchased this"],[3862,3991,"from a very reputable vendor."],[3991,4154,"A fake is a fake."],[4187,4358,"But don't take my word for it."],[4408,4592,"The head authenticator"],[4592,4788,"of Christie's Auction House"],[4788,4921,"is here tonight."],[5009,5146,"Why don't we let"],[5146,5326,"Dr. Certus be the judge?"],[7007,7161,"Valerian Certus."],[7161,7282,"Let me be of some assistance here,"],[7282,7390,"- may I? - Yes."],[7474,7561,"Yes,"],[7607,7836,"the texture of the canvas,"],[7937,8083,"you can see that"],[8083,8274,"it's just not consistent"],[8274,8387,"with what's expected"],[8387,8500,"in the 18th century."],[8500,8608,"This..."],[8608,8742,"I regret to inform"],[8742,8900,"all of you"],[8921,8983,"that this is,"],[8983,9146,"without a doubt, a fake."],[9246,9405,"Damn, Emma's in trouble."],[9421,9584,"I need to help her."],[9663,9822,"I can't believe she would do this."],[9851,10010,"I think she did it on purpose."],[10018,10176,"No, I didn't."],[10176,10339,"I need a chance to prove it."],[10364,10523,"Emma, you're done for."],[10552,10723,"You'll be removed by the board."],[10764,10990,"Then I'll be able to take your place."],[11236,11394,"That's enough!"],[12187,12316,"Emma,"],[12316,12474,"I'm disappointed in you."],[12545,12721,"I won't be making a donation anymore."],[12929,13088,"And you can leave."],[13221,13329,"Mr. Grumman,"],[13384,13546,"you're so commanding"],[13546,13684,"and assertive."],[13692,13834,"But please,"],[13834,14034,"give our school another chance"],[14076,14239,"once I am named"],[14239,14401,"chairman."],[14493,14593,"You?"],[14593,14756,"I won't be donating to Emma."],[14760,14814,"Yeah."],[14814,14906,"I can't trust her."],[16174,16332,"Jack?"],[16366,16408,"Sorry,"],[16408,16566,"Madam Chairwoman."],[16579,16737,"I grabbed the wrong present."],[16879,16979,"This"],[17221,17384,"is the right present"],[17384,17513,"for Mr. Grumman."]],"13":[[37,162,"My goodness."],[162,346,"What do we have here?"],[467,625,"This is impeccable."],[675,838,"This..."],[846,1017,"This is the genuine article."],[1126,1297,"This will likely fetch"],[1426,1584,"$50 million"],[1626,1785,"at auction."],[2706,2836,"Two paintings?"],[2836,2886,"When..."],[2886,3028,"- I didn't... - Trust me."],[3028,3174,"This isn't a joke."],[3174,3307,"This is a serious event."],[3307,3465,"The whole school is on the line."],[3507,3641,"What is the meaning of this?"],[3641,3895,"Why are there two identical paintings?"],[3924,4041,"I'm sorry, Mr. Grumman."],[4116,4191,"I must have just"],[4191,4329,"brought out the wrong one."],[4341,4504,"Please, forgive my mistake."],[4550,4783,"Well, if Dr. Certus says it's genuine,"],[4871,5030,"then it must be real."],[5430,5588,"Maybe Emma stole it."],[6493,6594,"How dare you accuse me"],[6594,6685,"of stealing?"],[6685,6886,"Emma, can you guarantee that"],[6886,7044,"this painting is real?"],[7365,7528,"I promise."],[7882,8091,"That painting is the real thing."]],"14":[[16,150,"You?"],[150,308,"A janitor?"],[325,462,"Your promise is worth"],[462,625,"nothing."],[663,821,"Who are you again?"],[992,1209,"Mr. Grumman, he's a janitor"],[1209,1317,"at my school."],[1347,1505,"A janitor?"],[1605,1764,"Yes."],[1780,1943,"A dirty,"],[1964,2206,"lowly janitor."],[2268,2402,"Eww, janitor."],[2402,2560,"How did he even get in here?"],[2577,2686,"Emma, what did you bring him for?"],[2686,2844,"Are you trying to embarrass us?"],[2923,2998,"Emma,"],[2998,3161,"explain yourself."],[3211,3349,"Yes, Mr. Grumman."],[3370,3486,"I think that she's trying"],[3486,3774,"to humiliate you by bringing a janitor"],[3774,3933,"to your banquet,"],[3941,4062,"uninvited!"],[4062,4220,"The audacity!"],[4287,4446,"Oh my,"],[4483,4542,"I can smell"],[4542,4708,"the bleach on him from over here."],[4758,4854,"Yes."],[4854,5017,"He was unclogging"],[5038,5267,"the ladies toilets the other week."],[5330,5534,"Would you like to see pictures of him"],[5534,5701,"scrubbing the toilets"],[5701,5864,"on his knees?"],[6231,6389,"That's enough!"],[6660,6752,"He's my husband."]],"15":[[129,183,"She really"],[183,342,"just admitted I'm her husband"],[358,521,"in front of everyone."],[525,617,"Even though she thinks I'm"],[617,775,"just a janitor."],[821,980,"Any man is lucky to have her."],[1284,1405,"What?"],[1405,1534,"You would take a janitor"],[1534,1614,"as a husband?"],[1639,1751,"Yes."],[1797,1864,"And?"],[1931,2106,"What are you, desperate for men?"],[2214,2314,"You know, I've asked you out"],[2314,2389,"for years."],[2427,2623,"I figured you were playing hard to get."],[2652,2727,"But you would take"],[2727,2919,"this piece of trash over me?"],[2986,3148,"That's none of your business."],[3148,3311,"Emma, you're crazy."],[3336,3495,"Maybe she is crazy."],[3595,3753,"Or maybe she's just into men"],[3753,3937,"that crawl out of the gutter."],[4074,4233,"Tell me,"],[4237,4416,"do you fuck in the dumpster?"],[4696,4854,"Oh, what's the matter?"],[4871,4988,"You're going to hit me?"],[4988,5109,"Go on, do it."],[5714,5872,"How dare you hit me?"],[5893,6056,"You asked for it."],[6093,6189,"Carl,"],[6235,6398,"that slap was just a warning."],[6468,6627,"But remember this."],[6639,6831,"Next time you insult my wife,"],[7111,7203,"you'll regret it for"],[7203,7361,"the rest of your life."],[7386,7440,"Fuck!"],[7440,7599,"I'm going to fire you."],[7640,7799,"As long as I'm still your boss,"],[7836,7932,"you don't have the authority"],[7932,8045,"to fire him."],[8058,8145,"And I won't tolerate"],[8145,8283,"any threats against him."]],"16":[[37,208,"Emma, you're making a scene."],[275,433,"Mr. Grumman,"],[446,513,"were you not bothered"],[513,592,"when they were ridiculing"],[592,671,"my husband?"],[700,863,"Was that not making a scene?"],[1247,1351,"Wait,"],[1376,1468,"you're going against"],[1468,1659,"Mr. Grumman for a janitor?"],[1780,1872,"Emma,"],[1872,2018,"have you forgotten"],[2018,2173,"that our school needs"],[2173,2310,"the chairman's donations,"],[2310,2398,"and without them,"],[2398,2560,"we will have no funding!"],[2836,3028,"And it will be all your fault."],[3069,3144,"He's right."],[3144,3215,"This is about keeping"],[3215,3328,"the school open."],[3349,3507,"She's too emotional."],[3557,3753,"Apologize to Mr. Grumman."],[3778,3862,"Apologize?"],[3924,4087,"For what?"],[4129,4216,"I'm not going to throw aside"],[4216,4379,"my husband to beg for mercy."],[4400,4558,"God, she's so brave."],[4592,4750,"I'm so lucky to have found her."],[4800,4904,"Come on, Jack."],[4904,5013,"Let's go."],[5092,5255,"Okay."],[6126,6289,"Emma."],[6318,6481,"Emma!"],[6802,6961,"Emma,"],[6994,7152,"why are you crying?"],[7315,7478,"I'm so sorry."],[7624,7749,"Did I just ruin everything?"]],"17":[[8,166,"It's too late to take it back now."],[187,350,"I'm sorry."],[350,454,"I'm sorry that I spoke out."],[454,588,"I couldn't stand there"],[588,771,"and watch them picking on you."],[1309,1401,"I'm sorry, Jack."],[1401,1559,"I'm sorry for losing my temper."],[1768,1901,"You didn't do anything wrong."],[2097,2260,"I'm just so tired."],[2419,2502,"I'm so"],[2502,2677,"sick of kissing up to billionaires"],[2677,2836,"just to keep the school open."],[2869,3032,"I'm sorry you had to go through that."],[3211,3374,"No, Jack,"],[3470,3628,"I should be thanking you."],[3687,3787,"Having you by my side"],[3787,3853,"gave me the strength"],[3853,3916,"to finally say"],[3916,4008,"what I've always been holding"],[4008,4079,"back on."],[4204,4358,"But what about the school?"],[4358,4450,"Without that donation,"],[4450,4504,"the school's"],[4504,4642,"really going to go bankrupt?"],[4642,4750,"If the school closes,"],[4750,4888,"hundreds of students will be left"],[4888,5009,"without an education,"],[5009,5167,"especially those on scholarships."],[5209,5259,"Not to mention,"],[5259,5417,"the teachers will be unemployed."],[5442,5605,"Their families will be in trouble too."],[5684,5843,"I'm not going to let that happen."],[5860,5960,"What's done is done."],[6056,6214,"Grumman has made it very clear"],[6214,6343,"his opinion of me."],[6352,6502,"Carl has been waiting to usurp me"],[6502,6639,"for years."],[6639,6710,"Without their support,"],[6710,6869,"the school is doomed."],[6890,7023,"Let me help."],[7023,7182,"What could you possibly do?"],[7390,7440,"It's okay."],[7440,7599,"I will find a new donor."],[7603,7766,"I'll find a new source of funds."],[8133,8212,"This is everything"],[8212,8370,"that I've saved up over the years."],[8400,8579,"If you need it, it's yours."]],"18":[[246,404,"Jack, you're so sweet."],[508,571,"But we're missing"],[571,734,"30 million, not 3000."],[888,930,"There's nothing"],[930,1038,"you can do about me."],[1092,1251,"Actually I can."],[1276,1459,"This is everything that I've saved"],[1459,1622,"for the last 20 years."],[1918,2077,"It's okay."],[2302,2444,"It's been a long day."],[2444,2602,"I'm tired."],[2715,2873,"Let's go home."],[3753,3908,"Mr. Grumman,"],[3908,4079,"I want to apologize"],[4116,4279,"for the way that Emma ruined"],[4279,4437,"your party."],[4466,4629,"Apologize?"],[4650,4771,"I don't need that."],[4771,4971,"I think I deserve an explanation"],[4971,5096,"from the school."],[5096,5221,"Of course."],[5234,5347,"Of course, I've already called"],[5347,5563,"for an emergency board meeting"],[5563,5847,"where I will propose that she be fired"],[5847,6006,"from her position."],[6139,6297,"A chairwoman"],[6327,6427,"marrying a janitor."],[6427,6669,"Well, that's simply not qualified"],[6702,6873,"in shaping young minds."],[6927,7157,"Wouldn't you agree, Mr. Grumman?"],[7240,7399,"If this goes through,"],[7457,7645,"I'll reconsider my decision."],[7745,7849,"Remember."],[7849,8095,"A $30 million donation"],[8095,8254,"is on the line."],[8596,8754,"Don't blame me, Emma."],[8767,8925,"It's your own fault."],[8942,9121,"You made the wrong choice."]],"19":[[746,905,"Mom."],[967,1146,"Is everything going to be okay?"],[1222,1305,"No."],[1305,1438,"It's worse than I imagined."],[1455,1568,"What are we going to do?"],[1568,1626,"Is the school"],[1626,1789,"really going to go bankrupt?"],[2506,2594,"No, Amelia."],[2594,2702,"Don't worry."],[2702,2823,"I'll take care of it."],[2898,3057,"Take care of it?"],[3090,3153,"Come on, Jack."],[3153,3311,"Don't make empty promises."],[3328,3424,"This isn't a fairy tale."],[3424,3582,"We're talking about 30 million."],[3582,3745,"$30 million!"],[3837,4020,"I'm not making empty promises."],[4045,4162,"I'm telling you."],[4162,4320,"I can take care of this."],[4346,4416,"Okay, Jack."],[4416,4575,"Whatever you say."],[4587,4704,"But even if we have the money,"],[4704,4863,"Carl is never going to give up."],[4867,4979,"He'll do whatever he has to do"],[4979,5138,"to get whatever he wants."],[5213,5326,"He can't."],[5326,5484,"Trust me."],[5572,5680,"Wait, Jack."],[5705,5855,"Where are you going?"],[5855,6051,"Didn't your family kick you out?"],[6206,6364,"Back to school."],[6373,6527,"Jack,"],[6527,6685,"did you forget?"],[6760,6856,"You're my husband."],[7002,7165,"You have a family now."],[7269,7599,"Mom, you and Jack are already..."],[7599,7757,"Amelia."],[7891,8033,"Stay,"],[8033,8174,"at least for tonight."],[8195,8312,"Please."],[8445,8596,"I need you to stay."]],"20":[[216,312,"Oh, mom."],[312,496,"You're blushing."],[513,692,"Go back to your room now, please."],[700,880,"Okay, okay."],[880,1009,"But you know,"],[1009,1188,"soundproof isn't great."],[1255,1434,"Don't stay up too late."],[2010,2189,"You should go shower."],[2235,2318,"Get out of this"],[2318,2498,"janitor uniform."],[2798,2923,"I'll find you something to wear."]],"21":[[120,258,"Oh, I'm sorry that"],[258,412,"was an accident."],[558,767,"No, it's okay."],[771,925,"It's a..."],[1051,1092,"Originally,"],[1092,1272,"this was my dad's."],[1297,1393,"Why don't you try it on?"],[1397,1488,"Yeah."],[1488,1593,"Okay."],[2744,2894,"Wow,"],[2952,3103,"you clean up nicely."],[3424,3549,"Thank you."],[6535,6715,"I'm sorry."],[7127,7211,"What is it?"],[7211,7340,"It's late."],[7369,7461,"Chairwoman,"],[7461,7640,"this is a formal notice."],[7657,7728,"The school board"],[7728,7891,"has called an emergency meeting"],[7891,8028,"for tomorrow at 9 A.M."],[8091,8187,"They have requested"],[8187,8270,"you attend."],[8299,8437,"An emergency board meeting?"],[8437,8562,"For what?"],[8562,8725,"To discuss Principal Davis's"],[8725,8846,"proposal to have you"],[8846,9009,"removed as chairwoman."]],"22":[[133,279,"Carl, he..."],[279,442,"He's faster than we thought."],[779,913,"Don't worry,"],[913,1017,"I told you."],[1076,1197,"I'll take care of this."],[1889,2047,"Trust me."],[3336,3478,"The past 20 years..."],[3478,3624,"I'm worth billions."],[3624,3695,"Not to mention"],[3695,3853,"this black card Lewis gave me."],[3924,4108,"Emma, I won't let them threaten you."],[4154,4396,"I'll ruin anyone who rises against you."],[5030,5192,"Vivian."],[5196,5301,"Right now,"],[5301,5455,"as CEO of Orion Corporation,"],[5455,5597,"I need you to do something for me."],[5605,5693,"Yes, boss."],[5709,5922,"First, make an announcement"],[5968,6151,"that in three days Orion Corporation"],[6151,6314,"will be holding a charity banquet"],[6356,6514,"with an emphasis on education."],[6606,6710,"Second,"],[6740,6823,"before 9 A.M."],[6823,6952,"tomorrow morning,"],[6965,7190,"I need you to prepare $30 million"],[7223,7311,"in cash."]],"23":[[1230,1359,"Mr. Davis, as principal,"],[1359,1455,"do you have anything to say"],[1455,1605,"about the future of the school?"],[1618,1730,"Everyone,"],[1772,1931,"I will be stepping up"],[1939,2118,"and taking control of the school."],[2152,2293,"And I will steer it"],[2293,2456,"toward a prosperous future."],[2577,2740,"Now, as far as Emma..."],[2911,2994,"As far as Emma,"],[2994,3257,"she has seriously offended"],[3257,3353,"Chairman Grumman,"],[3353,3636,"One of our school's long time patrons."],[3707,3933,"Emma has seriously damaged"],[3933,4091,"our school's reputation."],[4229,4416,"I condemn her reckless"],[4446,4629,"and irresponsible behavior."],[5130,5288,"From this day on,"],[5326,5488,"I will be leading the school"],[5530,5793,"to the new age of glory!"],[6481,6527,"Look."],[6527,6685,"Someone's coming!"],[7386,7461,"Who is this?"],[7461,7565,"I've never seen him."]],"24":[[41,125,"Ms. Grayson,"],[125,216,"what do you have to say to"],[216,342,"Mr. Davis's accusations?"],[350,487,"Please don't push. Just stay back."],[487,592,"Thank you. Please, stay back."],[592,692,"Ms. Grayson, it's rumored"],[692,850,"your conflicts with Principal Davis"],[850,955,"are due to your failures"],[955,1092,"to secure funding for the school."],[1092,1222,"What do you have to say?"],[1230,1338,"Ms. Grayson, you've been"],[1338,1447,"accused of sleeping with the school"],[1447,1480,"janitor"],[1480,1551,"and seriously"],[1551,1689,"offending Chairman Grumman"],[1689,1768,"for his sake."],[1768,1851,"Explain yourself."],[1856,2010,"I'll answer that question."],[2056,2218,"After all, I am that janitor."],[2448,2594,"But do you know who I really am?"],[2727,2890,"You don't know?"],[2986,3144,"Enough of that for now."],[3144,3328,"Today will not be Emma Grayson's"],[3328,3449,"last day,"],[3499,3691,"but rather a new beginning."],[3787,3945,"And as for Carl Davis,"],[4220,4379,"Carl's through."],[4379,4425,"That's all."],[4425,4542,"No more questions. Thank you!"]],"25":[[475,738,"They're already starting to vote."],[921,1021,"Emma's going to be a nobody"],[1021,1101,"after today."],[1101,1205,"You're so right,"],[1205,1305,"Ms. White."],[1347,1438,"Emma should have been fired"],[1438,1505,"years ago."],[1593,1785,"She's not fit to manage the school."],[1810,1947,"Of course."],[1960,2085,"But don't you worry."],[2085,2260,"Once I become part of this faculty,"],[2277,2381,"I'll make sure to put you"],[2381,2540,"in charge of finances."],[2544,2794,"Oh, thank you, Ms. White."],[2840,2957,"And tell Mr. Davis,"],[2957,3094,"I won't let him down."],[4600,4667,"Wow."],[4667,4825,"Look who's here."],[4838,4979,"It's the janitor who's been"],[4979,5146,"dragging the chairwoman down."],[5226,5463,"Jack, this is an important"],[5476,5680,"exclusive board meeting."],[5726,5885,"There's no place for you here."],[5935,6060,"Just get out of our way."],[6068,6322,"Jack, you're just a dirty janitor."],[6327,6477,"How dare you speak to Ms. White"],[6477,6564,"like that?"],[6573,6715,"And you."],[6715,6877,"You're just hurting my eyes."],[6886,7007,"You get out of the way too."],[7119,7261,"Security,"],[7269,7419,"throw them out!"],[7620,7707,"No!"]],"26":[[41,125,"Emma,"],[158,283,"you've already been fired"],[283,396,"by the school board."],[412,575,"Who do you think you are?"],[592,729,"Fired? By whom?"],[746,809,"By Carl?"],[809,892,"That's right."],[900,992,"Mr. Davis's already"],[992,1151,"gathered the necessary votes."],[1184,1276,"It's all over."],[1284,1359,"Wonderful."],[1372,1564,"Well, Mr. Davis can tell me to my face."],[1609,1722,"Now move."],[1810,1972,"What are you waiting for?"],[1989,2147,"Throw them out!"],[3799,3962,"You okay?"],[4854,5017,"You're lucky I don't hit women."],[5038,5201,"What are you so smug about?"],[5313,5476,"All this talk, Emma,"],[5476,5634,"and your last hope is a janitor"],[5634,5839,"who punches his problems."],[5922,6081,"Thanks for protecting me."],[6210,6368,"Jack is above hitting women,"],[6398,6556,"but I'm not."],[6898,7061,"Why don't you escort us in?"],[7061,7115,"Oh my God."]],"27":[[1222,1288,"Carl,"],[1288,1426,"Emma is attacking me!"],[1468,1543,"Emma,"],[1543,1726,"the board meeting is in progress"],[1726,1906,"to determine your fate."],[1943,2239,"And as you are the involved party,"],[2281,2460,"you cannot be here."],[4654,4808,"Emma"],[4808,4904,"is the chairwoman."],[4904,5009,"And as the chairwoman,"],[5009,5121,"she's also a member"],[5121,5251,"of the school board."],[5305,5484,"So any school board meeting"],[5530,5709,"without the chairwoman"],[5722,5901,"is ineligible."],[5943,6122,"So your decision today..."],[6147,6331,"Well, does it matter?"],[6418,6527,"Now, tell me."],[6606,6690,"Who's for"],[6894,7052,"and who's against?"],[7298,7419,"Emma,"],[7419,7620,"the forgery that you presented to"],[7620,7699,"chairman Grumman"],[7699,7849,"is the reason that the school"],[7849,8003,"has lost its funding."],[8028,8191,"Or have you forgotten?"],[8191,8454,"Enough with your baseless"],[8454,8583,"accusations."],[8687,8875,"I have uncovered the truth."],[8942,9121,"And it was you."],[9505,9622,"You were the one"],[9622,9805,"who planted the forgery"],[9813,9926,"in an attempt"],[9926,10185,"to ruin my wife's good reputation."]],"28":[[45,208,"Where's your proof?"],[296,454,"Without proof,"],[462,688,"your accusations are just slander."],[759,942,"We're not interested"],[942,1201,"in your personal differences"],[1213,1380,"with Mr. Davis."],[1380,1547,"We need solutions!"],[1572,1668,"That's right."],[1668,1826,"The school has no funding."],[1843,2006,"We need to do something."],[2118,2239,"Hey."],[2239,2373,"Don't worry."],[2373,2477,"I got this."],[3307,3503,"Funding won't be a problem."],[3799,3916,"In three days,"],[3916,4041,"the governor's daughter, Vivian,"],[4058,4233,"will be hosting a charity banquet"],[4233,4325,"in the city."],[4366,4533,"She works for the Orion Corporation."],[4600,4763,"So what?"],[4800,4971,"So Emma will attend"],[4971,5130,"as chairwoman,"],[5167,5380,"and once she secures a donation"],[5380,5551,"from the governor's daughter, Vivian,"],[5613,5705,"the school"],[5705,5864,"will have more than enough funding."],[5951,6110,"I didn't know anything about this."],[6126,6285,"Don't be absurd."],[6293,6468,"Why would the governor's daughter care"],[6468,6627,"about what you have to say?"],[6664,6827,"Because"],[6898,7057,"I'm her boss."],[7386,7490,"Now,"],[7524,7649,"any objections?"]],"29":[[41,291,"You, a janitor?"],[362,533,"Now, why would Vivian,"],[533,717,"the governor's daughter,"],[717,829,"listen to you?"],[900,1051,"Ridiculous!"],[1051,1172,"Jack,"],[1192,1305,"you're just a janitor."],[1309,1455,"You're not fooling anyone."],[1455,1668,"You're expecting this janitor"],[1668,1826,"to save you?"],[1981,2143,"Ridiculous."],[2281,2398,"Jack,"],[2398,2556,"can you really take care of this?"],[2577,2736,"We can't risk anything."],[2798,2957,"Trust me, Emma."],[2961,3119,"Emma,"],[3123,3311,"you have been making mistake"],[3311,3486,"after mistake after mistake."],[3578,3753,"Ever since you chose a"],[3766,3862,"janitor"],[3874,4008,"as a husband."],[4008,4095,"Jack, I..."],[4166,4325,"That's enough!"],[4358,4504,"What we need"],[4504,4667,"is more money."],[4817,4975,"You see, sweetheart?"],[4996,5159,"They can't wait for our demise."],[5201,5326,"Well, what should we do?"],[5326,5447,"Don't worry."],[5447,5605,"I came doubly prepared."],[5618,5797,"We're talking $30 million."],[5872,6031,"30 million?"],[6068,6285,"I could bring 300 million."],[7152,7232,"Come in."]],"30":[[25,183,"Come in?"],[183,329,"Who?"],[329,496,"Your janitor buddies?"],[884,967,"They're too busy"],[967,1126,"mopping the floors."],[1488,1668,"I prepared $30 million"],[1730,1889,"for this school,"],[1893,1964,"and it's going to arrive"],[1964,2122,"in three minutes."],[2131,2339,"Jack, it was already a stretch to say"],[2339,2456,"that we could get"],[2456,2615,"all the funding from Vivian."],[2623,2815,"How are you going to get $30 million?"],[2861,3053,"It's $30 million, Jack."],[3107,3265,"So you could sell Emma"],[3328,3490,"and still come up short."],[3570,3670,"But now you say"],[3670,3745,"you'll have the money"],[3745,3903,"ready in three minutes?"],[3903,4033,"That's absurd."],[4033,4179,"What if I do?"],[4179,4337,"If you bring us"],[4346,4512,"$30 million."],[4554,4742,"I will get down on my knees"],[4775,4942,"and I will lick your shoes."],[5013,5176,"But if you fail,"],[5238,5405,"you'll get down on your knees"],[5438,5676,"and beg me for mercy."],[5951,6093,"Deal."],[6164,6256,"I'd say we got about"],[6256,6343,"one more minute."],[6343,6589,"Mr. Davis, you're too kind."],[6660,6798,"But this isn't something"],[6798,6977,"getting on your knees will solve."],[7069,7228,"Emma still needs to be fired."],[7240,7382,"That's right."],[7382,7515,"It's why we're gathered here"],[7515,7590,"today."],[7620,7736,"Emma,"],[7736,7882,"don't be stubborn."],[7882,8074,"We need Chairman Grumman's"],[8074,8145,"support."],[8195,8375,"Only Principal Davis"],[8400,8529,"can save the school"],[8529,8712,"from bankruptcy now."],[8712,8808,"Emma,"],[8871,8925,"don't worry."],[8925,9084,"I won't make you beg."],[9129,9250,"Just"],[9267,9492,"be in my bed this evening and"],[9522,9597,"I'll help you out,"],[9597,9697,"I promise."],[9697,9859,"You're disgusting."],[9872,9980,"Well,"],[9980,10135,"it's been three minutes."],[10135,10247,"Where's the money?"]],"31":[[625,792,"This is impossible."],[817,988,"Where did you get that money?"],[1013,1184,"Jack, Emma,"],[1255,1422,"I knew it."],[1472,1676,"The future of the school is bright"],[1676,1847,"with you two at the lead."],[1906,2110,"Are you really turning on us?"],[2293,2464,"Shut up!"],[2464,2569,"Carl, will you please"],[2569,2698,"control your subordinates?"],[2727,2898,"We only act in the best interest"],[2898,2965,"of the school."],[2994,3199,"Whoever saves it from bankruptcy"],[3199,3261,"wins."],[3507,3657,"Wait wait wait."],[3657,3832,"Are we sure that this money is legal?"],[4008,4191,"Are you trying to pin us"],[4191,4362,"with money laundering?"],[4721,4896,"Yes. He's right."],[4929,5100,"This money must be dirty!"],[5138,5321,"Carl, you have such an"],[5321,5442,"active imagination."],[5484,5584,"I agree."],[5584,5755,"We need the funds."],[5789,5997,"But can you prove the money is clean?"]],"32":[[4,120,"Clean?"],[120,271,"$30 million from"],[271,437,"a janitor,"],[475,621,"how could it be legal?"],[621,700,"That's right."],[700,792,"Who knows where the money"],[792,871,"came from?"],[884,980,"You don't need to know"],[980,1151,"where my money came from."],[1163,1334,"What you need to do"],[1351,1455,"is admit"],[1455,1626,"that you lost."],[2118,2285,"What's wrong, Carl?"],[2285,2385,"Did you forget your own terms"],[2385,2506,"so quickly?"],[2552,2606,"Yep."],[2606,2765,"We bring the 30 million,"],[2765,2911,"you get down on your knees"],[2911,3082,"and lick his shoes."],[3190,3290,"How dare you"],[3290,3461,"humiliate me?"],[3720,3924,"Jack, do you really think"],[3924,4191,"$30 million will solve everything?"],[5017,5217,"How long do you think"],[5217,5426,"$30 million is going to last?"],[5668,5822,"Emma offended"],[5822,5914,"Chairman Grumman,"],[5914,5968,"who is the most"],[5968,6202,"dedicated patron in our school."],[6252,6398,"She's ruined our reputation"],[6398,6498,"in high society."],[6498,6573,"We're going to have trouble"],[6573,6744,"even finding students."],[6806,6944,"Exactly."],[6944,7044,"And I,"],[7044,7194,"I am the only one that is in good"],[7194,7282,"standing with"],[7307,7419,"Chairman Grumman."],[7440,7595,"The school needs me."],[7674,7791,"You?"]],"33":[[25,83,"Emma,"],[171,250,"do you really think"],[250,396,"Jack can save you?"],[454,571,"He's just a janitor."],[571,675,"Even if he has the money."],[675,767,"You still offended"],[767,863,"Chairman Grumman."],[925,1076,"Emma,"],[1142,1380,"if you beg very nicely to me,"],[1534,1651,"maybe I'll"],[1664,1776,"put in a couple good words"],[1776,1893,"for you."],[2010,2147,"Emma,"],[2177,2352,"you don't have to give in to him."],[2352,2456,"Jack,"],[2473,2531,"I get that"],[2531,2702,"you're new money,"],[2740,2890,"but you'll never understand"],[2890,3065,"what it's like to truly"],[3065,3340,"have wealth and status."],[3370,3541,"That's true."],[3545,3674,"Without Chairman Grumman's"],[3674,3745,"patronage,"],[3770,3945,"the school is going to fall into ruin."],[4024,4162,"Ms. Grayson,"],[4191,4362,"we'll give you three more days,"],[4416,4612,"but find a way to repair"],[4612,4729,"the school's relationship"],[4729,4900,"with Chairman Grumman."],[4929,5100,"Wow."],[5121,5347,"You really are too kind."],[5384,5543,"She's put the school at risk,"],[5543,5618,"and you're going to give her"],[5618,5751,"three more days?"],[5764,5876,"We're giving you another chance"],[5876,6093,"on account of the $30 million"],[6135,6206,"that you managed"],[6206,6377,"to scrounge up today for us."],[6410,6485,"But"],[6523,6585,"can you please"],[6585,6756,"cut the janitor out?"],[6781,6906,"I can't stand being in the same"],[6906,7082,"room with him, right?"],[7286,7386,"No!"],[7461,7570,"No?"],[7570,7657,"No!"]],"34":[[162,258,"I know you all might think"],[258,442,"of him as just a janitor,"],[462,642,"but he has proven himself"],[667,892,"to be a loyal, wonderful,"],[892,1071,"loving husband."],[1547,1643,"Let's get out of here."],[1643,1714,"Yeah."],[2227,2360,"Emma!"],[3778,3962,"Esteemed members of the board,"],[3962,4058,"please,"],[4154,4333,"calm down."],[4475,4738,"Emma will regret her decision."],[6923,7102,"What?"],[7532,7665,"Seatbelt."],[7941,8049,"Right."],[8362,8470,"Mom."],[8575,8696,"What are we going to do now?"]],"35":[[45,95,"Amelia,"],[95,204,"what are you doing in the car?"],[229,346,"Does it matter?"],[346,508,"What happens now?"],[517,633,"Three days."],[633,696,"How are we going to get"],[696,813,"Mr. Grumman's approval?"],[838,1001,"I don't know."],[1067,1226,"I now have a question."],[1234,1330,"Who's a bigger deal?"],[1330,1488,"Chairman Grumman or"],[1509,1668,"the governor's daughter, Vivian?"],[1668,1826,"That's obvious."],[1864,2077,"Of course it's the beautiful, generous,"],[2077,2264,"smart and business savvy, Vivian."],[2281,2377,"You're banking on the charity"],[2377,2535,"banquet in three days?"],[2590,2748,"It's no use."],[2748,2877,"A charity banquet for the elite"],[2877,2944,"is going to be arranged"],[2944,3082,"by Chairman Grumman."],[3082,3128,"There's no way"],[3128,3215,"we're getting invitation."],[3219,3378,"I just need to know,"],[3382,3545,"would Vivian be able to help?"],[3561,3687,"Of course."],[3687,3845,"Okay."],[3891,4037,"You'll get an invitation."],[4079,4158,"I'm sure of it."]],"36":[[625,717,"We're home."],[717,796,"Are you coming?"],[821,1001,"No. You guys go ahead."],[1001,1034,"I just..."],[1034,1205,"I have a quick call to make."],[2027,2118,"Vivian."],[2118,2231,"It's Jack."],[2268,2394,"I need an invitation."],[2394,2498,"Yes, boss."],[3849,3978,"It's late."],[3978,4108,"What are you still doing up?"],[4149,4270,"Can't sleep."],[4446,4571,"Maybe..."],[4708,4838,"Maybe it's time to"],[4838,5009,"beg Chairman Grumman for help?"],[5301,5434,"We all know"],[5434,5613,"$30 million is more than enough money"],[5613,5751,"to keep the school going."],[5776,5947,"And Carl's just looking for"],[5947,6118,"an excuse to get you fired."],[6151,6339,"But the whole board is behind him."],[6443,6577,"The charity banquet is a long shot,"],[6577,6756,"but it's my only hope."],[6956,7069,"If Mr. Grumman can just spare me"],[7069,7240,"an invitation..."],[7611,7778,"You should get that."],[7803,7866,"Maybe it's just what"],[7866,8003,"we've been waiting for."],[9238,9396,"Ms. Grayson,"],[9438,9622,"I'm here to deliver an invitation."]],"37":[[400,600,"Jack."],[750,934,"Is this invitation your doing?"],[1013,1226,"What invitation?"],[1397,1530,"Well, look,"],[1601,1668,"maybe Chairman Grooman"],[1668,1818,"just had a change of heart."],[1939,2135,"Don't play coy."],[2135,2256,"That man was clearly here"],[2256,2431,"to hand-deliver this invitation."],[2431,2673,"I think you’re just overthinking it."],[2769,2798,"There are"],[2798,2998,"too many coincidences."],[3103,3303,"I need answers."],[3345,3545,"What are you hiding from me?"],[3620,3762,"Sometimes things are just"],[3762,3862,"that simple."],[3862,3962,"Okay, don't overthink it."],[3962,4016,"Besides, what's"],[4016,4191,"important is now"],[4191,4287,"you can attend the charity"],[4287,4387,"banquet, right?"],[4608,4725,"But-"],[4846,5042,"Because"],[5071,5221,"I'm her boss."],[5309,5392,"Now,"],[5426,5626,"any objections?"],[6035,6235,"Who are you really?"],[6335,6418,"Why are you able to do"],[6418,6464,"all this?"]],"38":[[150,437,"I'm just an ordinary,"],[437,554,"hard working man."],[1080,1280,"And sometimes,"],[1501,1697,"ordinary men"],[1797,1897,"can do extraordinary"],[1897,1993,"things."],[2285,2485,"Maybe you're right."],[2606,2748,"I just feel like"],[2748,2944,"you have a big secret,"],[2944,3144,"you're hiding from me."],[3199,3315,"Like there's"],[3315,3390,"a whole side of you"],[3390,3591,"that I've never seen."],[3678,3920,"You’ve seen every bit of me."],[7811,7912,"Looks like I’ve found"],[7912,8087,"your big secret."]],"39":[[1881,1964,"Look who it is."],[2139,2264,"Principal Davis."],[2264,2427,"It's been a long time."],[2427,2494,"I heard that"],[2494,2585,"Chairman Grumman,"],[2585,2706,"personally invited you"],[2706,2823,"as a guest of honor."],[2823,3015,"Yes. Of course."],[3015,3090,"As you know,"],[3090,3178,"our school is in"],[3178,3378,"need of some resources."],[3399,3478,"Mr. Davis,"],[3478,3553,"your school should be"],[3553,3599,"honored"],[3599,3737,"to have such a hardworking,"],[3737,3916,"dedicated principal."],[3916,3958,"You'd make"],[3958,4104,"a splendid headmaster,"],[4104,4245,"should you get the chance."],[4245,4354,"Thank you."],[4738,4829,"Bye."],[6051,6202,"Principal Davis,"],[6202,6268,"thank you so much"],[6268,6431,"for inviting us to such an"],[6431,6631,"important banquet."],[6631,6765,"No, Mike."],[6765,6881,"You're welcome."],[6881,7077,"I'm so glad you could make it."],[7077,7219,"Mr. Davis, I heard that"],[7219,7328,"all of high society"],[7328,7424,"was clamoring for an"],[7424,7545,"invitation tonight."],[7545,7615,"Thank you so much"],[7615,7724,"for inviting us."],[7728,7828,"Oh, no."],[7828,7932,"You should be thanking"],[7932,8041,"your father,"],[8041,8199,"old man Jack."]],"40":[[100,237,"Who is that?"],[237,404,"They're so intimidating."],[404,542,"Is he with Emma?"],[542,704,"Why is she here?"],[704,846,"Who's that man with her?"],[846,1046,"He looks important."],[1084,1259,"Mike, isn't that your dad?"],[1259,1459,"But isn't he just a janitor?"],[1501,1622,"That's right."],[1622,1822,"He's just a janitor."],[2256,2364,"Dad, what are you doing here?"],[2364,2531,"You shouldn’t be in a place like this."],[2686,2836,"Who are you?"],[2836,2998,"He's my son."],[2998,3082,"That's right."],[3082,3178,"I'm his son."],[3178,3349,"And who are you? Why did you bring him"],[3349,3490,"to such a high class banquet?"]],"41":[[54,254,"I'm Emma Grayson, the chairwoman."],[325,421,"And who I bring as a guest"],[421,508,"is no one's business"],[508,625,"but my own."],[625,713,"Chairwoman?"],[713,834,"So you should know my father"],[834,988,"is just a janitor"],[988,1126,"at your school."],[1126,1234,"Mike."],[1234,1426,"Shut up!"],[1426,1551,"Dad! Don't embarrass me"],[1551,1659,"in front of everybody."],[1659,1755,"Mr. Davis personally"],[1755,1947,"invited me here."],[1947,2106,"You're just a janitor."],[2106,2306,"Why do you get to be here?"],[2394,2515,"Oh, Mike,"],[2515,2623,"don't be so hard"],[2623,2744,"on your father."],[2744,2848,"After all, he's"],[2848,3065,"no simple janitor."],[3111,3169,"Carl, what are you"],[3169,3303,"trying to say?"],[3303,3353,"Nothing."],[3353,3470,"It's just."],[3470,3536,"Not everyone"],[3536,3699,"is supposed to be here."],[3699,3816,"Miss Grayson,"],[3816,3983,"if I remember correctly,"],[3983,4179,"you weren't invited."],[4179,4237,"The security."],[4237,4275,"Just letting"],[4275,4354,"anyone into the"],[4354,4458,"charity banquet,"],[4458,4579,"I was invited."],[4579,4758,"Oh, really?"],[4758,4854,"By whom?"],[4854,4963,"Because I'm pretty sure"],[4963,5059,"Mr. Davis never sent"],[5059,5142,"you an invitation."]],"42":[[400,546,"My invitation."],[546,746,"Impossible."],[1046,1172,"Mike, was your dad"],[1172,1338,"actually invited?"],[1338,1480,"Mr. Grumman would"],[1480,1676,"never have invited you."],[1689,1951,"Emma, crashing a charity banquet?"],[1951,2102,"Hosted for the elite?"],[2110,2344,"That doesn't seem proper."],[2356,2510,"Proper?"],[2510,2711,"Proper by whose standards?"],[2798,2932,"Principal Davis’?"],[2932,3086,"Jack, what are you trying to say?"],[3086,3224,"Give the invitation back."],[3232,3294,"No."],[3390,3566,"This invitation is a fake."]],"43":[[4,204,"What are you doing?"],[258,329,"Emma,"],[329,529,"your invitation is a fake."],[550,675,"What do you mean?"],[675,859,"I personally designed"],[859,967,"all the invitations"],[967,1092,"myself."],[1092,1197,"Our guests"],[1197,1343,"all had invitations"],[1343,1543,"that were blue and silver."],[1559,1643,"He's right."],[1643,1722,"Their invitation"],[1722,1793,"looks completely"],[1793,1885,"different from mine."],[1885,1926,"Is this"],[1926,2127,"so embarrassing for Emma?"],[2127,2243,"Emma and Jack"],[2243,2444,"must feel humiliated."],[2473,2519,"Dad, if you're"],[2519,2631,"going to forge an invitation,"],[2631,2694,"at least make it"],[2694,2802,"the right color."],[2802,2890,"Mike, I can't"],[2890,2961,"believe your father"],[2961,3086,"would do this."],[3086,3240,"Carl,"],[3240,3370,"are you so certain"],[3370,3474,"that the invitation is fake?"]],"44":[[41,141,"Of course,"],[141,304,"a black invitation."],[304,504,"Don't be ridiculous."],[525,629,"The black invitation"],[629,817,"was delivered in person."],[817,971,"It's for one person."],[971,1126,"The guest of honor."],[1126,1234,"It's above your pay grade."],[1234,1426,"So that's why you didn't see it."],[1426,1697,"Jack, you're taking your bluff"],[1697,1906,"a little too far."],[1914,2077,"Guest of honor?"],[2077,2227,"You?"],[2227,2348,"You're a fraud."],[2348,2419,"Who does this guy"],[2419,2510,"think he is?"],[2510,2711,"A black invitation?"],[2711,2898,"He's too special for us."],[2898,3098,"Ridiculous."],[3140,3232,"Dad, you're embarrassing"],[3232,3432,"yourself."],[3449,3520,"Carl,"],[3549,3595,"we'll find out"],[3595,3691,"who the true fraud is"],[3691,3828,"soon enough."],[3828,3933,"Jack, we're done"],[3933,4029,"with your lies."],[4029,4162,"Security!"],[4162,4279,"Take them out of here."],[4279,4466,"Sir, ma’am."]],"45":[[392,592,"There's no rush."],[775,888,"Chairman Grumman."],[900,1092,"You got here just in time."],[1092,1159,"Some people are"],[1159,1276,"trying to crash"],[1276,1447,"the charity banquet."],[1447,1493,"They even"],[1493,1693,"forged their invitations."],[1739,1814,"Don't worry."],[1814,1943,"We're on it."],[1943,2056,"Forging an invitation"],[2056,2256,"to the charity banquet?"],[2260,2398,"Who would dare?"],[2398,2598,"They chose the wrong color too."],[2610,2811,"They have black invitations."],[2831,2882,"Thinking that"],[2882,3082,"they could fool us."],[3090,3290,"Black invitation?"],[3315,3353,"Could it be"],[3353,3499,"the VIP invitation"],[3499,3741,"that Vivian had me personally prepare?"],[3787,3987,"Let me see who."],[4517,4675,"Emma?"],[4675,4800,"It can't be you."],[4800,4892,"Why can't it be me?"],[4992,5100,"Can you be the guest of"],[5100,5167,"honor that the"],[5167,5234,"governor's daughter,"],[5234,5330,"Vivian, mentioned?"]],"46":[[0,196,"Guest of honor?"],[196,283,"I didn't hear anything"],[283,400,"about that."],[400,508,"I received an invitation,"],[508,596,"so I came here"],[596,675,"to the charity banquet."],[675,875,"That's it."],[1034,1121,"Chairman Grumman,"],[1121,1247,"was a black and gold invitation,"],[1247,1405,"really sent out?"],[1405,1680,"I can confirm that we did"],[1680,1856,"prepare a special black invitation"],[1856,1997,"for the guest of honor."],[2022,2289,"But the identity of that guest"],[2289,2489,"is still unknown."],[2590,2727,"So I'm up."],[2727,2927,"Show me your invitation."],[2961,3186,"I can't."],[3186,3420,"Carl destroyed it."],[3858,3995,"I cannot tell anything"],[3995,4166,"from such a small piece."],[4166,4266,"Chairman Grumman."],[4266,4450,"It couldn't be Emma,"],[4450,4525,"let alone"],[4525,4725,"her janitor husband."],[4783,4925,"Do you remember that"],[4925,5000,"painting that"],[5000,5188,"they forged and gave you?"],[5188,5342,"Are you saying that Emma's"],[5342,5572,"invitation is also a forgery?"]],"47":[[0,112,"What?"],[112,208,"Emma has a history"],[208,312,"of forgery?"],[312,525,"Then the invitation must be fake too."],[650,684,"Emma."],[684,884,"What do you have to say for yourself?"],[913,1059,"It isn't a forgery."],[1059,1234,"Mr. Grumman."],[1234,1351,"The painting."],[1351,1476,"Did you have it appraised?"],[1476,1572,"What did they say?"],[1710,1910,"It is genuine."],[2022,2223,"However?"],[2260,2398,"However,"],[2398,2598,"the painting belongs to"],[2652,2869,"the governor's daughter, Vivian."],[3553,3687,"Oh my God!"],[3687,3732,"How did the"],[3732,3828,"janitor get his"],[3828,4033,"hands on that painting?"],[4033,4200,"Who is this man?"],[4300,4521,"The painting belongs to Vivian?"]],"48":[[29,141,"Correct."],[141,237,"The painting belonged"],[237,337,"to Vivian."],[337,437,"Jack."],[450,517,"You stole the"],[517,709,"painting from Vivian?"],[709,788,"Stole?"],[788,863,"Carl, you have such"],[863,996,"an active imagination."],[1009,1067,"Okay, Jack."],[1067,1138,"How did you get"],[1138,1263,"a hold of that painting?"],[1347,1547,"Vivian gave it to me."],[1822,1960,"The governor's daughter"],[1960,2122,"gave it to, Vivian?"],[2122,2314,"You're a janitor."],[2314,2356,"Who's going to"],[2356,2523,"believe your lies?"],[2523,2585,"Emma,"],[2585,2706,"you must apologize"],[2706,2786,"and beg Vivian"],[2786,2848,"for forgiveness"],[2848,3019,"the moment she arrives."],[3019,3219,"Stealing from the elite?"],[3232,3432,"That's a serious crime."],[3445,3536,"Dad,"],[3591,3728,"what has gotten into you?"],[3745,3807,"You disappeared"],[3807,3945,"from our lives for 20 years."],[3945,4049,"And the moment you come"],[4049,4137,"back, you've been causing"],[4137,4266,"us nothing but trouble."]],"49":[[0,45,"Jack."],[45,125,"Stealing from the"],[125,325,"elite will affect us."],[400,483,"If it comes down to it."],[483,538,"I'll divorce"],