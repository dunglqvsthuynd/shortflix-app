88,"That you invited"],[788,867,"us personally."],[867,946,"Say it!"],[946,1146,"You little shit!"],[1242,1480,"We don't know you. Stay away"],[1480,1676,"from Carl, you dumb bitch!"],[1747,1885,"Carl is ruthless,"],[1885,2022,"turning on them like that."],[2022,2164,"Poor Lisa."],[2164,2364,"Played like a fool."],[2477,2677,"That's enough."],[2702,2852,"Throw these two out of here now!"],[2852,3057,"-What? - No no no."],[3057,3211,"-No no no no! -Dad!"],[3224,3386,"Dad, save me, please! No, wait!"],[3395,3436,"Come on."],[3436,3616,"You can’t treat me like this."],[3616,3678,"I'm sorry!"]],"61":[[50,162,"I can't believe Jack was"],[162,275,"personally invited by the"],[275,475,"governor's family as the guest of honor."],[487,600,"But I can't lose sight of"],[600,721,"the real prize."],[721,855,"As long as I secure that"],[855,992,"$10 billion grant,"],[992,1063,"I'll still be"],[1063,1192,"the winner tonight."],[1192,1338,"Emma."],[1338,1539,"Look at what you've done."],[1539,1718,"How could you do this to me?"],[1718,1830,"Carl, shut up."],[1993,2064,"Everyone,"],[2064,2235,"sorry for the interruption,"],[2235,2364,"but we still must not lose"],[2364,2565,"sight of our goal tonight."],[2577,2740,"We are here to honor"],[2740,2940,"our tireless educators."],[3011,3211,"So let's continue."],[3215,3349,"Yes, Chairman Grumman."],[3349,3549,"Let's continue."],[3699,3737,"Jack,"],[3737,3916,"I'm nervous."],[3916,4070,"There's no need for you to be nervous."],[4116,4183,"Why?"],[4250,4391,"Because I told you."],[4391,4450,"Tonight,"],[4529,4587,"you're the star"],[4587,4788,"of this charity event."],[4938,5217,"Now, who would like to put their"],[5217,5397,"name forward for the grant?"]],"62":[[12,196,"Vivian,"],[196,304,"our lovely"],[304,446,"governor's daughter."],[446,646,"I would be honored"],[671,855,"to be in charge of that $10"],[855,1055,"billion grant."],[1230,1292,"I'd also like"],[1292,1317,"to put"],[1317,1426,"myself into consideration."],[1426,1580,"Vivian."],[1580,1735,"Chairwoman Grayson?"],[1735,1810,"Bur aren't they from the"],[1810,1901,"same school?"],[1901,1981,"They're competing"],[1981,2093,"against each other."],[2093,2310,"Oh, wow."],[2323,2502,"This is the most exciting banquet"],[2502,2744,"I've ever seen."],[2802,2952,"Emma, are you sure?"],[2952,3203,"This is a $10 billion grant."],[3236,3436,"We can't have somebody that's"],[3445,3645,"so emotional at the helm."],[3712,3945,"Emotional? Yes."],[3983,4212,"I completely agree. Which is why"],[4212,4291,"I'm confident"],[4291,4333,"that I'm the"],[4333,4533,"right person for the job."],[4542,4662,"This grant is a"],[4662,4808,"very serious matter."],[4808,4971,"We must make the best"],[4971,5171,"possible choice."],[5188,5238,"Who are they going"],[5238,5380,"to choose?"],[5380,5530,"Chairman Grumman?"],[5551,5689,"Principal Davis?"],[5689,5843,"It can't be Emma."],[5843,6001,"Can it?"],[6001,6202,"With much deliberation."],[6243,6498,"We have decided to award"],[6498,6652,"the grant to:"],[7044,7207,"Emma Grayson."]],"63":[[8,183,"What? Emma Grayson?"],[183,325,"Impossible."],[325,625,"She got the $10 billion grant."],[746,880,"Miss Grayson, please"],[880,975,"prepare a proposal"],[975,1076,"for the grant."],[1076,1222,"We'll set it up with you"],[1222,1309,"as the director"],[1309,1455,"as soon as possible."],[1455,1568,"The $10 billion grant"],[1568,1618,"will be under"],[1618,1768,"your complete discretion."],[1810,1972,"Jack, am I dreaming?"],[1972,2173,"No, you're not dreaming Emma."],[2185,2385,"I told you, tonight"],[2406,2552,"you are the star of the ball."],[3278,3357,"Vivian."],[3357,3495,"This is not right."],[3628,3695,"Why?"],[3695,3799,"Why Emma?"],[3799,3945,"This is impossible."],[3945,4245,"Emma's just a normal person."],[4304,4571,"Who Emma is, is not important."],[4629,4733,"What is important"],[4733,4850,"is who Emma chose."],[5155,5251,"Boss."]],"64":[[120,229,"I can't believe you're the"],[229,429,"CEO of Orion Corporation,"],[483,5