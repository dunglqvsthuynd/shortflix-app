{"1":[[1364,1460,"Harry."],[1460,1612,"Hey, my love."],[1879,2076,"—Please. This is your spot. —Yup."],[2344,2436,"So?"],[2548,2660,"What's the occasion, Harry?"],[2768,2888,"Well…"],[2888,3026,"Listen, we've been together"],[3026,3222,"for three years. And..."],[3336,3592,"I was thinking about our future…"],[3664,3796,"So, um…"],[4976,5232,"Cynthia, will you marry me?"],[6112,6212,"Harry…"],[6444,6556,"I don't know what to say…"],[6633,6891,"Just say yes."],[6963,7088,"We love each other."],[8136,8232,"Yes…"],[8408,8508,"She said yes."],[9336,9508,"Everybody on the floor!"],[9892,9992,"Cynthia!"]],"2":[[48,180,"Call your boss, or she dies."],[284,460,"Greetings, gentlemen!"],[460,619,"It seems you have a problem."],[664,880,"You have the wrong hostage."],[880,964,"On the floor."],[964,1084,"Or the next bullet is yours."],[1132,1248,"Stef…"],[1296,1500,"Look at the stone on his watch."],[1548,1660,"The tattoo on his neck…"],[1764,1900,"Those are symbols"],[1900,2040,"of the D'Angelo family."],[2124,2221,"I apologize"],[2221,2392,"for not introducing myself."],[2572,2684,"Allan D'Angelo."],[2738,2885,"Allan D'Angelo."],[2885,3117,"His name seemed to cut through the air"],[3117,3296,"with its power and danger."],[3296,3388,"The head of the most"],[3388,3574,"powerful mafia clan in the city"],[3574,3740,"is saving my life."],[3744,3828,"Listen."],[3870,4011,"This is the territory"],[4011,4177,"of the Romano family."],[4296,4396,"We have unfinished business"],[4396,4475,"with their owner,"],[4475,4743,"so stay out of it."],[4792,4876,"I don't give a shit"],[4876,5036,"about your business, buddy."],[5176,5434,"And you have to let the girl go."],[5496,5702,"Because she's my fiancée."]],"3":[[201,314,"Or have you forgotten"],[314,488,"the family inviolability code?"],[868,1195,"Mr. D'Angelo, we don't want war."],[1196,1348,"So, take your fiancée and go."],[1488,1592,"Let's go, darling."],[1932,2031,"Hey."],[2200,2292,"Harry."],[2292,2353,"Hey."],[2376,2504,"Hey, stop!"],[2792,2892,"Gentlemen."],[2984,3140,"You have ten seconds."],[3544,3644,"Let's go."],[4388,4520,"Are you okay?"],[4696,4808,"Yes."],[4952,5112,"Oh, you're out now."],[5220,5320,"How was it there?"],[5586,5674,"Safe?"],[6212,6512,"Thank you for protecting Cynthia."],[6604,6688,"I was afraid—"],[6688,6864,"Yes, you were afraid."],[6984,7096,"But when a man hides"],[7096,7240,"under the table,"],[7240,7424,"leaving his woman in danger…"],[7552,7681,"it's not fear."],[7741,7867,"It's a choice."],[8140,8286,"And you made it."],[8824,9112,"Today, I made a choice too…"],[9296,9584,"when I called you my fiancée."],[9691,9802,"What choice?"],[9802,9937,"What did he mean by that?"],[9937,10124,"It's just a lie to protect me."],[10224,10382,"Because my real fiancé"],[10382,10509,"didn't protect me."],[10532,10680,"He hid under the table,"],[10680,10826,"saving his life."],[10864,10964,"Maybe that's why"],[10964,11102,"his lie made me feel"],[11102,11356,"more than Harry's truthful confession."]],"4":[[780,864,"What happened?"],[912,1116,"Allan D'Angelo shot me."],[2082,2217,"He shed the first blood"],[2217,2336,"on our territory."],[2956,3096,"D'Angelo wouldn't have…"],[3160,3453,"violated the rules of the families."],[3976,4267,"Why did he do it?"],[5760,6008,"Why did he do it?"],[6272,6552,"We took his fiancée hostage."],[7168,7320,"Fiancée?"]],"5":[[80,132,"Honey."],[132,252,"Please understand."],[424,704,"I was just confused."],[872,1096,"I'm not some kind of criminal mastermind."],[1512,1612,"Please talk to me."],[1796,1896,"Cynthia…"],[2624,2724,"I love you."],[4444,4536,"Harry, stop it."],[4596,4696,"No, I can't."],[4792,4944,"Harry! Harry, stop it!"],[4944,5092,"You're making it worse!"],[5572,5889,"Listen. Please, let's just…"],[5944,6106,"forget about this incident."],[6152,6252,"No."],[6456,6656,"I think I need time."],[6844,6944,"Right."],[8164,8264,"Wow…"]],"6":[[596,696,"Okay."],[1124,1244,"I'll wait."],[2480,2641,"Vito will not forgive interference"],[2641,2776,"in his territory."],[2884,3012,"They threatened his fiancée."],[3192,3408,"She's not his real fiancée, Tony."],[3532,3700,"She's just some chick."],[3700,3884,"And when Vito finds out about it—"],[3884,4116,"She's not just some chick."],[4176,4288,"She's Cynthia."],[4520,4736,"There is nothing more vulnerable…"],[4800,5124,"than a man who has fallen in love."],[5212,5492,"He loses his vigilance…"],[5632,5936,"makes stupid mistakes."],[6132,6532,"And we will use each of them."],[6756,6884,"Find this girl."]],"7":[[48,148,"Find this girl."],[324,564,"Find out everything about her."],[612,860,"From her favorite coffee"],[860,997,"to the size of her shoe."],[1292,1420,"Good news."],[2140,2224,"Wake up. She's out."],[2476,2598,"I feel danger"],[2598,2783,"surrounding me from all sides."],[2846,2955,"What is it?"],[3000,3186,"Stress after yesterday…"],[3216,3356,"or a real threat?"],[3444,3544,"She noticed us."],[3828,3964,"Stop it, Cynthia."],[3964,4121,"This is just paranoia."],[4428,4572,"This is the danger"],[4572,4844,"that my body felt before I saw it."],[4892,5156,"Like an animal senses a predator."],[5768,5868,"Get in."]],"8":[[1468,1568,"Give it to me."],[2340,2500,"Where did her wedding ring go?"],[3192,3304,"Where are we going?"],[3304,3492,"Where you will be safe."],[3724,3967,"What? Am I in danger?"],[4080,4192,"Yes."],[4344,4652,"Vito Romano. A rival family"],[4652,4836,"that wants to use you against me."],[5214,5430,"No. No."],[5444,5639,"No, this is nonsense."],[5804,6019,"Look. I don't understand"],[6019,6088,"what's going on here,"],[6088,6240,"but I really need to get to work."],[6240,6408,"So, if you don't mind?"],[6408,6612,"Please, I'll get off here."],[7336,7552,"Are you deaf? Stop the car!"],[7552,7877,"No. His people are already watching you."],[8016,8192,"What? Why?"],[8248,8425,"What do I have to do with this?"],[8432,8656,"Because you're my fiancée."],[8672,8800,"But those were just words."],[8856,8988,"You lied to save me."],[8988,9128,"Yes, I lied."],[9276,9476,"And if they find out about it,"],[9476,9604,"there will be war."],[9776,9876,"War?"],[9960,10112,"War. War…"],[10184,10352,"You are my fiancée"],[10352,10472,"who will live with me"],[10472,10607,"from this day forward."],[10630,10963,"Under my care. In my mansion."],[11130,11240,"What?"]],"9":[[720,984,"Please stop the car."],[1172,1348,"Otherwise, I'll call the police."],[1348,1460,"You know who I am."],[1552,1716,"The police won't stop me."],[2224,2384,"Your heart rate is too high."],[2556,2732,"Your pupils are dilated."],[2864,2966,"Did you take any drugs"],[2966,3092,"before getting behind the wheel?"],[3140,3240,"What?"],[3692,3840,"Your pulse is off the charts."],[3904,4136,"Dilated pupils. Light sweating."],[4536,4620,"Okay."],[5300,5384,"I've been kidnapped"],[5384,5536,"by Allan D'Angelo!"],[5584,5668,"He's on drugs"],[5668,5852,"and taking me to his mansion."],[5916,6052,"If you don't stop the car,"],[6052,6232,"I'll send this to a journalist I know."],[6356,6471,"Do you think the press will be"],[6471,6664,"a bigger problem for you than the police?"]],"10":[[572,672,"Hey."],[832,932,"When they come—"],[1004,1116,"and they will come—"],[1300,1476,"I will not be able to save you,"],[1476,1568,"Cynthia."],[2288,2388,"They won't come."],[2868,2968,"I'm nobody."],[3068,3152,"I'm just a nurse"],[3152,3236,"who happened to be"],[3236,3320,"in the wrong place"],[3320,3440,"at the wrong time."],[3592,3692,"Not anymore."],[4804,5028,"I could still feel his heart pounding"],[5028,5164,"with my fingertips."],[5182,5371,"Just as frantic as mine."],[5390,5769,"I just dared to threaten Allan D'Angelo himself."],[5820,6085,"And in the end, he disappeared."],[6106,6396,"So why, instead of being relieved,"],[6396,6660,"do I feel disappointed?"]],"11":[[200,364,"Yeah, I'm right outside."],[564,684,"Hey."],[1788,1880,"Thank you."],[2072,2360,"Listen. I wanted to talk about—"],[2360,2560,"Harry, please."],[2756,2848,"Remember I asked you"],[2848,2960,"to give me some time?"],[2960,3170,"So, please don't put any pressure"],[3170,3244,"on me, okay?"],[3244,3443,"I just want you to know that..."],[3652,3812,"I'm here for you."],[4148,4248,"Goodbye, Harry."],[4536,4664,"Yeah."],[4664,4931,"And thanks again for the flowers."],[5816,5984,"I wonder what this lover boy was doing"],[5984,6099,"at their engagement party."],[6700,6960,"Finally, water…"],[7060,7372,"I want to wash off all the dust of today."],[7400,7656,"And finally, forget about Allan."],[7685,7814,"Forget his look."],[7856,8031,"The feeling of his touch."]],"12":[[348,588,"Stop imagining his hands"],[588,680,"on my hips…"],[756,1024,"his fingers digging into my skin."],[1108,1244,"He is behind me…"],[1300,1716,"strong, powerful, dangerous."],[1808,2028,"His lips leave a burning mark"],[2028,2123,"on my neck."],[2196,2477,"He awakens something primitive in me,"],[2487,2668,"something forbidden…"],[2704,2928,"Stop. This has to stop."],[2928,3180,"It's not right. It's dangerous."],[3180,3384,"It's too exciting."],[3440,3640,"And that's why it has to stop"],[3640,3768,"right now."],[6744,6864,"Help! Help!"]],"13":[[5672,5828,"Hey! Open the door!"],[5940,6040,"Damn it."]],"14":[[48,132,"You?"],[420,520,"Why am I here?"],[820,1060,"Vito went after your fiancé, Harry."],[1544,1712,"So, that means"],[1712,1880,"they already know the whole truth,"],[1880,1992,"and there's no need for me"],[1992,2104,"to be kept here. Right?"],[2104,2376,"No. I managed to intercept him"],[2376,2508,"and send him out of town."],[2544,2768,"What? What did you do?"],[2768,2941,"Hey, don't worry about him."],[2992,3128,"I deposited enough money"],[3128,3256,"into his account."],[3304,3404,"Who are you?"],[3540,3676,"Who are you to decide"],[3676,3844,"who should live where and how?"],[4267,4377,"Listen to me."],[4386,4515,"Sooner or later,"],[4515,4681,"Vito will find out the truth"],[4681,4838,"that I called someone else's bride"],[4838,4964,"my own."],[5400,5682,"I gave you family status, Cynthia."],[5732,5960,"I gave you untouchable status."],[6024,6235,"I have insulted his family with this lie."],[6235,6359,"Do you understand?"],[6420,6568,"And to restore his honor,"],[6568,6748,"he will have to kill you."],[6924,7150,"That's why I have to keep you here."],[7180,7295,"Not just to protect you"],[7295,7480,"but to maintain the illusion"],[7480,7664,"that you are really my fiancée."],[7800,7968,"This is the only way"],[7968,8126,"I can save your life."]],"15":[[1216,1356,"Does it still hurt?"],[1570,1650,"Stop it."],[1716,1904,"I don't need your concern."],[2060,2172,"First, you have your people"],[2172,2280,"break into my shower,"],[2280,2374,"push me against the wall"],[2374,2476,"until I faint…"],[2512,2612,"and then you pretend"],[2612,2736,"to care about me?"],[2777,2988,"As if you had nothing to do with it?"],[2988,3184,"Are you fucking serious?"],[3268,3396,"You were pushed?"],[4580,4708,"I hate you!"],[7372,7516,"Listen to me. No one…"],[7564,7796,"No one dares to touch her."],[7796,7910,"You understand?"]],"16":[[0,100,"Cynthia?"],[332,524,"You weren't supposed to see this."],[688,812,"Hey…"],[1268,1428,"I'm sorry for what you suffered"],[1428,1596,"at the hands of my men"],[1596,1716,"and for what you saw."],[1924,2068,"He won't touch you again."],[2068,2188,"I promise."],[3316,3540,"This is the real Allan D'Angelo."],[3588,3844,"Brutal. Ruthless. Dangerous."],[3844,3940,"Playing with me"],[3940,4156,"like a beast plays with its prey."],[6232,6332,"Good morning."],[7048,7152,"Eat."],[7520,7638,"You will eat…"],[7804,8028,"even if I have to force-feed you."]],"17":[[576,688,"Well done."],[1792,1892,"Why?"],[1940,2040,"I'm engaged…"],[2104,2216,"in case you forgot."],[2432,2552,"Really?"],[2796,2936,"It's none of your business."],[3172,3332,"It is my business."],[3556,3752,"Tonight is the family dinner."],[3752,3933,"The heads of the mafia families"],[3933,4028,"will be there."],[4252,4336,"So…"],[4648,4872,"For him, it's not just a ring."],[4872,5176,"It is a brand that marks me as his."],[5176,5392,"One move, and I will become…"],[5392,5648,"Allan D'Angelo's fiancée."],[5648,5820,"Even if it's just a game…"],[5868,6020,"something inside me tells me"],[6020,6273,"that there will be no turning back."]],"18":[[316,504,"I will introduce you to them"],[504,669,"as my fiancée."],[1420,1580,"You'll find a dress in this room."]],"19":[[200,432,"No. I'm sorry, I—"],[532,632,"I'm out of town."],[1052,1230,"No, I won't be back soon."],[1284,1384,"I'm sorry."],[1748,1840,"Hey, Harry."],[3012,3104,"What do you want?"],[3160,3296,"I didn't tell anyone."],[3296,3396,"Like I promised."],[3512,3664,"Who did you promise, Harry?"],[3832,4080,"You're from Allan D'Angelo, right?"],[4368,4480,"Uh-uh."],[4760,5008,"Listen. I don't know who you are,"],[5008,5380,"but Cynthia and I are not together anymore."],[5380,5512,"She's Allan's fiancée."],[5616,5708,"Really?"],[5756,5876,"Then what's this?"],[6000,6085,"Isn't that the ring"],[6085,6280,"I saw on Cynthia's finger"],[6280,6400,"in the restaurant?"]],"20":[[760,872,"What the hell, Cynthia?"],[1048,1148,"We have to go."],[1296,1528,"Go to dinner yourself."],[1620,1704,"What?"],[2004,2179,"You're holding me captive."],[2272,2416,"Telling me what to eat…"],[2480,2730,"what to wear, who to marry."],[2852,2952,"Okay."],[3120,3260,"I was able to feed you…"],[3744,3904,"I can put a dress on you."]],"21":[[456,717,"My protest turned against me."],[752,896,"I wanted to prove to him"],[896,1061,"that he doesn't control me."],[1088,1248,"And now, I'm standing there…"],[1284,1436,"freezing at his touch."],[2732,2988,"Don't ever test me like that again."],[3884,4008,"And the worst part is"],[4008,4124,"that I can't figure out"],[4124,4274,"what scares me more."],[4312,4466,"His control over me…"],[4486,4676,"or how much I enjoy it."]],"22":[[568,681,"I obeyed."],[681,823,"I surrendered."],[823,1051,"I decided to play his game."],[1604,1704,"Gentlemen."],[1760,1980,"I'd like you to meet my fiancée…"],[2028,2128,"Cynthia."],[2232,2324,"But Allan…"],[2372,2547,"He plays so convincingly…"],[2604,2696,"that I'm starting to believe"],[2696,2840,"in this play myself."],[3088,3256,"Very nice."],[4640,5030,"My most sincere congratulations…"],[5056,5189,"on your engagement."],[5192,5336,"Thank you, Vito."],[5400,5512,"Thank you very much."],[5624,5752,"How are you feeling?"],[5852,5996,"With God's help, Allan."],[6232,6332,"With God's help."],[6504,6804,"By the way, I want to introduce you"],[6804,6904,"to my new friend."],[7132,7368,"Hey, dear. Stand up."]],"23":[[672,784,"Congratulations…"],[892,1012,"on your engagement."],[1012,1132,"Harry turned out"],[1132,1376,"to be an extremely loyal friend."],[1468,1740,"He told me about a terrible lie."],[1856,2020,"A lie your clan can only"],[2020,2258,"wash itself clean of…"],[2258,2380,"on one condition."],[2768,2928,"When the cause of this lie…"],[3048,3140,"stops breathing."]],"24":[[484,668,"Listen carefully, Vito."],[730,887,"You can threaten me."],[960,1332,"You can try to take away all my territories."],[1360,1492,"You can declare war."],[1492,1740,"But if you ever try"],[1740,1972,"to threaten my future wife again…"],[2128,2372,"I will forget all the rules and codes."],[2428,2668,"And you will beg for a quick death."],[2764,2908,"Then the war!"],[3120,3212,"Okay."],[3260,3360,"Okay!"],[3724,3836,"The dinner is over!"]],"25":[[204,388,"What is he thinking about now?"],[436,556,"What is he hiding?"],[612,836,"Does he regret attacking Vito?"],[900,1140,"There was such rage in his eyes."],[1140,1389,"So real, so personal."],[1424,1616,"Like I was really his."],[2356,2476,"Good night."],[3268,3380,"Why did you do that?"],[3644,3812,"You could've just handed me over"],[3812,3932,"to them."],[3932,4060,"I'll never give you away."],[4160,4288,"Not to anyone."],[4420,4589,"Even if it means war?"],[4724,5076,"Even if it means losing everything."],[5604,5748,"You said…"],[5880,6026,"\"your future wife\"."],[6268,6368,"Yes."],[6564,6664,"I wasn't lying…"],[6804,6972,"not before in the restaurant…"],[7088,7216,"not today."]],"26":[[5924,6024,"Look at me."],[6128,6288,"I want to see your eyes."],[8284,8404,"At that moment…"],[8468,8612,"there were no clans…"],[8660,8984,"no wars, no past for us."],[9076,9208,"There was only us…"],[9292,9500,"our intertwined bodies…"],[9699,9812,"and the passion"],[9812,10012,"that consumed us completely."]],"27":[[4884,5044,"We have to be very careful."],[5136,5312,"They have twice as many people."],[5404,5524,"Three times, Allan."],[5628,5764,"If we attack here…"],[5868,6124,"we'll cut off their main suppliers."],[6280,6408,"7 Brooklyn St."],[6508,6600,"Yes."],[6600,6924,"Boss, this war will be fatal for us."],[6924,7161,"It's gonna be better if we get Vito"],[7161,7312,"to sign a peace treaty"],[7312,7401,"in front of witnesses"],[7401,7522,"from the other families."],[7604,7748,"How do you see it?"],[7852,7952,"Give them…"],[8026,8107,"Cynthia."]],"28":[[235,341,"What?"],[796,924,"Get outta here."],[1264,1528,"Marco, look at me."],[1720,1840,"What did you say?"],[1908,2004,"Allan!"],[2420,2628,"If it's all because of me…"],[2804,2980,"maybe I can help in some way?"],[3128,3288,"Cynthia, get outta here."],[3368,3516,"You don't need to get involved."],[3600,3784,"Hey, from now on…"],[3832,4008,"you're personally responsible"],[4008,4140,"for her safety."],[4400,4608,"I'll be much more useful here…"],[4668,4752,"boss."],[4752,4952,"It's not your decision, Marco."],[5076,5196,"If a single hair"],[5196,5345,"falls from her head—"],[5355,5475,"Marry me."]],"29":[[528,690,"If we get married…"],[764,892,"and I become your wife,"],[892,1132,"then I will truly…"],[1180,1348,"officially become yours, right?"],[1520,1606,"Perhaps then"],[1606,1727,"you can avoid the war."],[1728,1992,"Cynthia, you will become my wife."],[2268,2500,"But not because of Vito"],[2500,2667,"and not because of the war."],[2844,3080,"It is because I want it."],[3200,3390,"And only when you really want it…"],[3640,3740,"Now…"],[3824,4013,"please leave us."],[4164,4264,"Okay?"],[4408,4588,"But I already want this."],[5560,5660,"No."],[5848,6012,"You're not ready yet."],[7808,7920,"I understand that you—"],[7920,8096,"You don't understand anything."],[8096,8228,"Marco, maybe if we talk—"],[8292,8392,"Talk?"],[8464,8564,"Talk about what?"],[8672,8801,"About how Allan started the war"],[8801,8900,"for you?"],[9004,9276,"The war he's most likely to die in."]],"30":[[48,312,"The war he's most likely to die in."],[408,508,"Will he die?"],[556,700,"These words reverberated"],[700,828,"with physical pain"],[828,940,"throughout my body."],[2128,2212,"Fuck."],[2648,2748,"So..."],[2944,3128,"How are you going to beat him?"],[3128,3260,"It's none of your business."],[3716,3816,"Allan…"],[3964,4097,"I am a bone of contention"],[4097,4249,"in this war. So..."],[4249,4424,"I think I have the right"],[4424,4559,"to know what to expect."],[5156,5256,"Well…"],[5484,5626,"There are two options."],[5880,6088,"Force Vito to sign a peace treaty…"],[6160,6316,"in front of witnesses"],[6316,6455,"from the other families."],[6576,6748,"And what's the other one?"],[7132,7288,"We end up killing each other."]],"31":[[464,548,"Don't worry."],[576,720,"Everything will be fine."],[785,879,"I promise."],[904,1004,"\"Don't worry.\""],[1076,1200,"It's easy to say."],[1272,1472,"He sits there so calmly,"],[1472,1556,"as if talking"],[1556,1724,"about the weather outside."],[1772,1952,"But I see his determination"],[1952,2096,"behind this calmness."],[2180,2312,"He will not back down."],[2360,2460,"But I—"],[2516,2616,"I can't just sit here"],[2616,2708,"and wait for them"],[2708,2808,"to kill each other."],[2864,3056,"There has to be some way out."],[3056,3148,"How are you feeling?"],[3196,3340,"With God's help, Allan."],[4264,4364,"Heart failure."]],"32":[[116,216,"Heart failure."],[300,424,"What are you talking about?"],[436,508,"Hmm?"],[652,844,"Nothing. Never mind."],[1324,1490,"I won't be here tonight…"],[1600,1744,"but Marco will be with you."],[2088,2231,"You're in good hands."],[2516,2708,"I know how to use Vito's illness"],[2708,2828,"against him."],[2828,2980,"But Allan won't listen to me…"],[3028,3195,"so I have to get out of this house"],[3195,3316,"without being seen."],[3456,3728,"Marco, my faithful dog…"],[3728,3972,"He will not take his eyes off me."],[3972,4072,"Shit."],[4320,4432,"Marco?"],[4552,4756,"Thanks for guarding me."],[5136,5305,"We'll have to take it by cunning."],[6960,7060,"It's time."],[9096,9280,"Marco! Marco!"]],"33":[[576,756,"Marco! Marco!"],[804,904,"Marco…"],[1160,1241,"What happened?"],[1241,1333,"My stomach..."],[1345,1564,"I need to get to the hospital."],[1564,1727,"I need to get to the hospital now."],[2116,2222,"If something happens to you,"],[2222,2335,"the boss will kill me."],[2476,2579,"I have to call Allan."],[2580,2768,"No, no, no! There's no time!"],[2768,2916,"I just need a drip."],[2916,3050,"Two hours, and I'll be fine."],[3216,3368,"Marco, he'll never know."],[4388,4488,"Lily?"],[4536,4704,"Lily. Lily, hi."],[4704,4836,"Cynthia? Where have you been?"],[5024,5148,"What happened?"],[5148,5248,"Food poisoning."],[5312,5512,"Please prepare a room for me…"],[5560,5660,"for a couple of hours."],[5720,5876,"I'm going to take some meds."],[5876,5996,"Okay. Uh…"],[6080,6224,"I'll prepare room 212."],[6308,6408,"Okay."],[10204,10468,"Harry, I'm in the hospital."],[10468,10640,"Come get me. Now."]],"34":[[264,348,"How are you?"],[348,496,"It will be better soon."],[596,696,"We'll be back at the mansion"],[696,796,"in a couple of hours."],[1988,2088,"Lily?"],[2232,2332,"You have to help me."],[2720,2812,"How is she?"],[2812,2912,"She is recovering."],[2912,2996,"But don't disturb her"],[2996,3091,"for a couple of hours."],[3092,3140,"Come with me."],[3140,3234,"I'll give you the medicine"],[3234,3400,"she needs to take tomorrow."]],"35":[[1344,1464,"Hey…"],[1464,1548,"Hey."],[1548,1724,"So, are you gonna tell me"],[1724,1836,"what happened?"],[1952,2052,"Take me to Vito."],[2052,2152,"What?"],[2284,2384,"Are you crazy?"],[2384,2496,"Yes, yes."],[2644,2744,"I'm crazy."],[2928,3304,"Please, just do what I say, okay?"]],"36":[[596,744,"I don't like this, Cynthia."],[816,928,"You have no idea"],[928,1048,"how dangerous Vito is."],[1252,1428,"Don't you think it's a little too late"],[1428,1540,"to worry about me?"],[1588,1688,"Let's go."],[2512,2648,"Here, on the west side,"],[2648,2800,"their security is weak."],[3311,3390,"Um..."],[3512,3895,"Mr. Romano, Cynthia wanted to—"],[3895,3988,"Shut up."],[4176,4276,"Well?"],[4380,4516,"Did Allan decide"],[4516,4644,"to give away his bride?"],[4776,4888,"Was he afraid of war?"],[5024,5324,"Or are you a Trojan horse?"],[5532,5660,"Come."],[6140,6260,"Allan doesn't know I'm here."],[6472,6572,"I ran away."],[6860,6972,"I need to talk to you."],[7088,7200,"In private."],[7600,7931,"If you want to talk, talk."],[8096,8232,"No one is leaving this room."],[8700,8784,"Well?"],[8856,9048,"Why don't you say something?"],[9204,9304,"Have you changed your mind?"],[9616,9920,"Because there is no turning back…"],[9968,10068,"darling."],[10160,10492,"You're not getting away from here."],[11412,11660,"Did I really put myself in a trap?"]],"37":[[0,100,"Well?"],[236,444,"Pull yourself together, Cynthia."],[492,640,"It's your fault you're here."],[688,864,"So, do something about it."],[864,1024,"The first thing you need to do…"],[1072,1196,"is get him alone."],[3708,3937,"I know that I will die in this war…"],[3984,4084,"anyway."],[4420,4660,"So, I'm ready to do anything…"],[4808,4936,"to save myself."],[5292,5392,"And I mean…"],[5604,5716,"anything."]],"38":[[300,392,"Everyone out."],[4180,4321,"For reconciliation?"],[4916,5100,"Did you put something in it?"]],"39":[[712,824,"You don't trust me?"],[1028,1267,"Would such a chaste girl be ready"],[1268,1531,"to satisfy old Don Vito?"],[1676,1852,"I'm not ready to be sober."],[2684,2852,"This bottle is the only way"],[2852,3132,"I can force myself to go through it."],[4428,4512,"So?"],[4980,5132,"Not so fast, kitty."],[5284,5660,"You have to catch your mouse first."],[5832,5960,"I love this game."],[6892,6992,"Meow."],[7040,7200,"Well…"],[8311,8440,"You're really…"],[8552,8732,"You're really hot…"],[8816,9112,"to make my heart pound so much."],[9560,9848,"You're really making me"],[9848,9948,"work for this."],[10424,10516,"Pills won't help."],[10564,10788,"You just took a beta blocker."],[10916,11000,"In five minutes,"],[11000,11188,"you're going to have a heart attack."]],"40":[[0,200,"But you drank too."],[216,284,"Yeah."],[379,500,"But unlike you,"],[500,668,"I don't have heart failure."],[752,944,"And I can handle a little dizziness."],[1124,1224,"What do you want?"],[1332,1573,"I want you to sign a peace treaty"],[1573,1688,"between the families."],[1780,1960,"We're gonna go out the back door…"],[2008,2197,"sit in the car, and go to Allan."],[2300,2428,"On the way, I will inject you"],[2428,2532,"with the antidote."],[2570,2752,"So, if you wanna survive—"],[3352,3552,"So, Uncle, how hot is she?"],[3552,3804,"Stef, help!"],[4208,4524,"Shit. Shit."]],"41":[[48,148,"To the office!"],[576,736,"Fuck, Cynthia…"],[736,836,"What have you done?"],[1080,1192,"Help…"],[1192,1352,"Help! Help!"],[1620,1720,"Uncle?"],[1896,1996,"Get away from him!"],[2144,2272,"We were just fooling around…"],[2328,2460,"when he had a heart attack."],[2576,2704,"Call Doc."],[2704,2832,"Hold on, hold on!"],[3104,3204,"She—"],[3788,3937,"What did you do to him?"]],"42":[[60,228,"Nothing! I swear!"],[360,520,"What did you do to him?"],[700,833,"He pointed at you!"],[868,1020,"Well, of course he pointed at me!"],[1020,1112,"I'm a nurse!"],[1150,1258,"And he's dying!"],[1265,1336,"Let me help him"],[1336,1504,"while the doctor is on his way."],[1504,1620,"Boss?"],[1724,1852,"Doc's on his way."],[1852,2003,"He'll be here in half an hour…"],[2036,2099,"no sooner."],[2164,2375,"He's not going to make it that long."],[2399,2520,"His pulse is too weak."],[2520,2634,"Let me help him."],[3320,3455,"I'm going to save you."],[3455,3509,"Do you hear me?"],[3509,3624,"I'm going to save you."],[3772,3936,"If you are gonna be a good boy."],[4200,4328,"Let's take him to the hospital."],[4788,4988,"Faster. We don't have any time."]],"43":[[388,488,"Cynthia?"],[1096,1196,"Cynthia?"],[1432,1524,"Shit."],[2140,2240,"Shit!"],[2648,2731,"What—"],[2756,2856,"What happened there?"],[3244,3344,"Turn right."],[3416,3612,"What? But the hospital—"],[3684,3844,"We're going to Allan."],[4008,4108,"What?"]],"44":[[328,496,"I have some bad news."],[728,879,"Two families have refused"],[879,984,"to support me."],[1416,1516,"Cynthia…"],[1644,1744,"is gone."],[2060,2146,"What?"],[2160,2300,"We went to the hospital."],[2300,2548,"She said she was not feeling well."],[2684,2876,"I was waiting outside the ward,"],[2876,2976,"but then…"],[3048,3178,"she just disappeared somewhere."],[3252,3569,"You lost her."],[3736,3885,"She's in danger…"],[4024,4155,"because of you."],[4414,4558,"You, Marco."]],"45":[[64,240,"No, no, no. Cynthia, please…"],[296,424,"stop this madness."],[424,544,"What are you doing?"],[544,720,"You're signing our death sentence."],[720,820,"You signed it yourself"],[820,998,"when you decided to hide under the table."],[998,1240,"So, maybe at least now act like a man"],[1240,1432,"and help stop this war that started"],[1432,1584,"because of your goddamn cowardice!"],[1632,1744,"Turn right!"],[2392,2520,"Where's Cynthia?"],[2568,2732,"What? Who are you?"],[2732,2865,"Cynthia Collins."],[2865,3070,"She was here a couple of hours ago."],[3074,3176,"Where did she go?"],[3248,3524,"Go away. Or I'll call security."]],"46":[[48,248,"Where is Cynthia Collins?"],[340,446,"I don't know, really."],[481,707,"She asked to distract this man,"],[707,892,"and then she disappeared somewhere."],[1068,1152,"Where the hell"],[1152,1244,"could she have gone?"],[1328,1412,"What did she do?"],[1412,1532,"Who did she call? Think!"],[1532,1704,"Think, please."],[1704,1788,"She—"],[1844,1944,"She took something"],[1944,2056,"from the pharmacy."],[2140,2272,"And then she left"],[2272,2400,"with her fiancé, Harry."],[2400,2500,"Harry?"],[2622,2700,"Call Harry."],[2763,2916,"Find out where she is."],[2960,3072,"Harry… Fuck!"]],"47":[[536,696,"Please give him the antidote."],[768,960,"If he dies, his people will kill us."],[1084,1184,"It's still early."],[1348,1432,"I'm gonna give it to him"],[1432,1516,"at the peak moment"],[1516,1634,"so that he doesn't recover"],[1634,1772,"until we get him to Allan."],[2812,2912,"It's time."],[4074,4206,"I'm sorry, but..."],[4290,4428,"I don't wanna die."]],"48":[[284,400,"Harry!"],[488,664,"No, no, no. No!"],[838,909,"Harry?"],[957,1072,"Harry, what are you doing?"],[1856,1956,"Harry?"],[2080,2180,"Who are you calling?"],[2308,2508,"Harry, please don't call them."],[2592,2685,"Listen, look at me."],[2685,2780,"Look at me."],[2780,2880,"Give me the phone."],[3020,3308,"Give me the phone."],[3440,3564,"Give me the fucking phone!"],[3564,3684,"It's too late!"],[3964,4084,"I've already given them"],[4084,4211,"our location."],[4572,4732,"You're disgusting."],[4732,4934,"Sorry. Sorry."],[5316,5408,"Well…"],[5508,5668,"What a brave girl."],[5824,5936,"But…"],[6052,6164,"so stupid."],[6436,6724,"You trusted a coward."],[6832,6932,"Sorry."],[7252,7364,"My boys?"]],"49":[[1716,1852,"I must admit…"],[1908,2128,"that the evening was very…"],[2476,2596,"interesting."],[2972,3200,"But it's time to say goodbye."],[3296,3538,"No, no, no. Please."],[3720,3968,"I would love to. Believe me."],[4084,4237,"But the code of honor…"],[4272,4456,"doesn't allow me"],[4456,4580,"to leave you alive."]],"50":[[232,324,"Excuse me, Uncle."],[420,560,"What the hell?"],[560,660,"Allan D'Angelo's car"],[660,816,"just drove onto the property."],[848,1020,"It seems he's alone."],[1182,1247,"Oh."],[1372,1521,"That's even better. Yeah?"],[1656,1800,"Invite our guest."],[1874,1941,"Mm-hmm."],[2592,2868,"I'll give you a few more minutes"],[2868,2948,"to live."],[2948,3144,"No, no, no."],[3144,3352,"Stupid. I'm so stupid."],[3352,3465,"And you can say goodbye"],[3465,3568,"to your loved one."],[3568,3724,"I wanted to save him…"],[3752,3987,"but I lured him into a trap."],[4044,4243,"Now, he's going to die…"],[4264,4396,"because of me."],[4452,4758,"Again, because of me."]],"51":[[0,136,"Welcome!"],[136,228,"Cynthia."],[588,868,"Welcome to our party."],[1088,1172,"Don't touch her."],[1172,1272,"Don't hurry."],[1584,1872,"Okay, okay. I came alone."],[2064,2164,"Not for war…"],[2328,2480,"but for negotiations."],[2788,2908,"Let her go…"],[2988,3216,"and all my territories will be yours."],[3724,3996,"They'll soon be mine anyway."],[4132,4216,"Do you want to"],[4216,4324,"senselessly shed"],[4324,4444,"your people's blood?"],[4584,4736,"My people are warriors."],[4784,4920,"They are ready to die for me."],[5404,5524,"Then my life…"],[5756,5876,"in exchange for hers."]],"52":[[0,136,"As soon as she is safe,"],[136,248,"you can shoot me."],[248,400,"No. No!"],[400,600,"Allan, don't! Please, don't!"],[648,904,"No, no. Allan, don't."],[904,1144,"I have a better offer. Yeah."],[1280,1576,"Let's play Russian roulette."],[1880,1992,"Chair."],[2340,2468,"Sit, please."],[2832,2944,"A revolver."],[3064,3224,"Everything will be fine."],[3396,3508,"I love you."],[3572,3672,"The rules…"],[3896,4008,"are simple."],[4228,4328,"One shot…"],[4572,4664,"at her…"],[5156,5268,"and you get one."],[5300,5396,"And so on."],[5460,5644,"Until the bullet…"],[5740,6028,"finds its target."]],"53":[[48,184,"What guarantees do I have"],[184,383,"that if I die, you'll let Cynthia go?"],[384,624,"There are none."],[688,808,"But you have no options."],[1112,1212,"I agree."],[1312,1424,"On one condition."],[1648,1816,"I will have the first shot."],[2048,2160,"As you wish."],[2352,2680,"The game begins."],[3160,3324,"No… No…"]],"54":[[812,912,"How—"],[912,1024,"How did you get out?"],[1276,1428,"You don't value the lives"],[1428,1540,"of your men, Vito."],[1604,1788,"So, it's not in their best interest"],[1788,1908,"to tighten the ropes."],[1956,2100,"My people are warriors."],[2156,2312,"They are ready to die for me."],[2720,2833,"Help me…"],[3144,3312,"and the port will be yours."],[5112,5340,"Your boss, guys…"],[5404,5665,"has just given up half the city…"],[5744,6072,"the port, and millions in profit."],[6144,6244,"And for what?"],[6336,6420,"For the sake"],[6420,6560,"of sadistic entertainment."],[6560,6792,"Stop these cheap manipulations."],[6792,7032,"And it is you who will die in a war…"],[7080,7208,"to win what he could get"],[7208,7300,"right now."],[7300,7400,"Don't listen to him."],[7484,7608,"We are family."],[7608,7920,"So, why don't you let your boss…"],[7968,8148,"risk his life for once?"],[8240,8396,"Play this roulette with me."]],"55":[[0,243,"Three shots out of six."],[304,424,"If he survives…"],[508,608,"you eliminate him…"],[728,933,"take my northern territories…"],[988,1088,"and the port…"],[1188,1372,"and peace comes"],[1372,1564,"between our families."],[1564,1716,"Don't even think about it."],[1780,1892,"They won't betray me."],[2032,2152,"If he dies…"],[2324,2588,"Cynthia and I leave."],[2708,2908,"Think, guys."],[3684,3820,"I'm sorry, Uncle."],[4124,4216,"You've lost your influence"],[4216,4316,"on the family."],[4567,4621,"No..."],[4944,5048,"No."],[5292,5452,"What are you guys doing?"],[5544,5644,"Come on."],[5780,5900,"Shoot him."],[6192,6348,"I'm ordering you to shoot!"],[7004,7100,"Turn around."],[7320,7420,"Well?"],[7596,7816,"Here we go."]],"56":[[1724,1900,"Vito is dead."],[1900,2084,"But not from a bullet."],[2084,2268,"He had a heart attack."],[2268,2480,"Although I think his heart died"],[2480,2656,"long before that."],[2704,2817,"I could've lost you."],[3042,3244,"Don't ever run from me again."],[3308,3572,"Never. Never! Do you hear me?"],[3672,3828,"Never. I promise."],[3828,4012,"Because when it doesn't just beat"],[4012,4220,"but bursts out of the chest,"],[4220,4348,"out of happiness,"],[4348,4556,"pain, or crazy love,"],[4556,4865,"only then does it truly live."]],"57":[[204,324,"Not even a hint?"],[524,651,"Do you want him to play roulette"],[651,756,"with me?"],[912,1152,"I hate his surprises."],[1500,1600,"And I adore them"],[1600,1744,"at the same time."],[1744,1944,"They are always on the verge"],[1944,2152,"of delight and fear."],[2152,2372,"Just like my whole life with him."],[3664,3820,"This restaurant…"],[3830,4019,"It was here that my life"],[4019,4288,"was divided into before and after."],[4344,4616,"Here, I first felt the coldness"],[4616,4764,"of a gun at my temple."],[4828,5036,"And here, I first saw him—"],[5084,5324,"the man who changed everything."],[5872,5972,"Then, I lied."]],"58":[[100,200,"Then, I lied."],[556,812,"Lied? What are you talking about?"],[1028,1348,"I lied about you being my fiancée."],[1652,1928,"And I said yes to the wrong man."],[2272,2384,"So..."],[2584,2824,"Shall we correct our mistakes?"],[3480,3615,"Will you be my wife?"],[4242,4323,"Yes."]],"59":[[268,352,"Turn around."],[3548,3632,"It's beautiful."],[3652,3713,"Mm."],[3812,3971,"Is this a family heirloom?"],[3972,4072,"Yes."],[4336,4428,"In our family,"],[4428,4660,"this medallion is passed down"],[4660,4884,"from the mother to the wife"],[4884,5076,"of her eldest son."],[5144,5189,"Mm."],[5300,5492,"And what's this?"],[5800,6023,"Some kind of spellbinding potion?"],[6260,6360,"Poison."],[6756,6856,"Is this a joke?"],[7120,7220,"Cynthia…"],[7328,7592,"A don's wife must be ready"],[7592,7840,"for anything, even death…"],[7920,8095,"to protect her family."],[8592,8872,"You know, when Vito tied me up"],[8872,9056,"and threatened to kill me…"],[9220,9355,"I prayed for you to come…"],[9564,9664,"and save me."],[9912,10012,"Again."],[10216,10360,"But when Vito put a gun"],[10360,10476,"to your head, I—"],[10684,10804,"Hey, hey, hey."],[11016,11168,"What are you talking about,"],[11168,11268,"my silly girl?"],[11540,11768,"Only I have the right"],[11768,11944,"to give up my life for you."],[12124,12420,"You're not allowed to. Understand?"]],"60":[[220,372,"I look at my reflection"],[372,580,"and barely recognize myself."],[652,796,"Where is the scared girl"],[796,972,"who was trembling at gunpoint?"],[1028,1185,"The one who said yes…"],[1236,1351,"just to avoid seeing"],[1351,1480,"that pleading look?"],[3056,3200,"Now, I am the wife"],[3200,3408,"of the most dangerous man"],[3408,3500,"in the city."],[3500,3688,"The mother of his future children."],[3736,3936,"The keeper of his secrets."],[3984,4084,"And you know what?"],[4132,4400,"For the first time in my life…"],[4448,4696,"I know exactly who I am."],[5580,5716,"The dagger between us"],[5716,5808,"is like the line"],[5808,5986,"between life and death."],[6040,6140,"Like an oath"],[6140,6356,"to protect each other at all costs."],[6412,6620,"He, with his dagger…"],[6620,6836,"openly and fearlessly…"],[6908,7132,"I, with my poison…"],[7180,7392,"secretly and lethally…"],[7476,7724,"Two people. One weapon."],[7724,7948,"One life. One death."]]}