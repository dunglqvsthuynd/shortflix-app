e some"],[3633,3720,"nerve showing up here!"],[3745,3783,"John!"],[3858,3933,"Stop it!"],[3970,4058,"Don't touch her!"],[4095,4170,"Why the hell do you keep"],[4170,4258,"defending her?"],[4258,4370,"She attacked Mom twice."],[4370,4458,"The only reason I dropped the"],[4458,4620,"charges is because you made me!"],[4620,4770,"Think about it, John."],[4770,4945,"How could Ellie ever hurt the"],[4945,5045,"one person who"],[5045,5133,"loved her the most?"],[5183,5258,"Explain the footage."],[5295,5333,"What?"],[5358,5395,"The security"],[5395,5495,"cameras set her up?"],[6345,6420,"You're not going"],[6420,6520,"anywhere near Grandma."],[6558,6620,"Not this time."],[6708,6758,"Why are you gonna"],[6758,6883,"stop being so blind?"],[6933,6995,"I'm not gonna let"],[6995,7083,"you touch her again."],[7183,7320,"Dropping the charges doesn't"],[7320,7395,"mean you're off the hook."],[7420,7520,"If your grandfather hadn't"],[7520,7658,"stepped in, I swear I would"],[7658,7695,"have beat the"],[7695,7808,"living shit out of you."],[7833,7958,"After everything you've done,"],[7995,8033,"you're not"],[8033,8145,"welcome here ever again!"],[8220,8295,"Security,"],[8320,8404,"get her out of here!"]],"47":[[4,66,"Security!"],[100,191,"Get her out of here!"],[200,400,"No, stop, no, let go!"],[400,475,"I am not leaving"],[475,562,"without Grandma!"],[566,600,"Why?"],[637,704,"So you can finish"],[704,800,"what you started?"],[812,900,"I don't get it."],[900,1000,"Why would you attack her?"],[1000,1087,"What did she do to you?"],[1112,1183,"Exactly!"],[1337,1437,"Why would I hurt her?"],[1450,1500,"You know, I have"],[1500,1608,"that same question."],[1754,1812,"Why?"],[2050,2120,"Of course."],[2150,2237,"You're jealous because"],[2237,2300,"Grandma always"],[2300,2412,"liked her more than you."],[2454,2575,"The person who resents her"],[2575,2616,"the most is"],[2616,2754,"standing right behind you."],[2766,2829,"What?"],[2875,3004,"Why would I hurt her?"],[3004,3129,"She's my Gran