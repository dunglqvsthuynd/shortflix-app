{"1":[[54,200,"Ellie Lane, back up!"],[200,275,"Your family's going to"],[275,350,"be here in an hour."],[425,562,"If it isn't the fake"],[562,762,"Lane family heiress, hiding in her"],[762,900,"room like a little rodent."],[987,1125,"And look, she's even throwing"],[1125,1212,"herself a sad"],[1212,1362,"little birthday party!"],[1375,1462,"Forgot the rules?"],[1500,1591,"Doors stay open."],[1612,1712,"Don't think you can run and"],[1712,1825,"hide just because it's your"],[1825,1983,"last day, princess."],[2995,3100,"Maybe there's nothing left"],[3100,3212,"holding onto."],[3225,3337,"My family?"],[3441,3495,"They’re the ones"],[3495,3612,"who sent me here…"],[3687,3750,"No, I would"],[3750,3858,"never hurt grandma."],[3900,3987,"It was her."],[4050,4154,"She did it."],[4187,4387,"You've stolen her life."],[4412,4562,"And now grandma's in the hospital,"],[4562,4700,"and you want to blame Annie?"],[4725,4862,"You had a good life."],[4887,5004,"And you took it for granted."],[5025,5125,"I guess there's no choice but"],[5125,5229,"to send you to juvie."],[5258,5308,"No."],[5387,5437,"No, dad!"],[5537,5762,"Mom, Charlie, I didn't do it!"],[5779,5837,"I swear!"],[5875,5987,"Three years of my life"],[5987,6075,"were stolen."],[7087,7200,"Charlie!"],[8354,8441,"Why is she so..."],[8466,8554,"cold?"],[8762,8875,"Three years in juvie and all"],[8875,9025,"you've learned how to do is"],[9025,9150,"to be indifferent towards the"],[9150,9279,"people who've done the most for you?"],[9300,9412,"Mr. Lane,"],[9445,9520,"three years ago"],[9520,9570,"you told me"],[9570,9670,"not to call you Charlie."],[9700,9762,"Simply doing"],[9762,9850,"what you told me."],[10225,10275,"Charlie?"],[10350,10425,"Don't call me that."],[10466,10550,"Only Annie gets"],[10550,10625,"to call me that."],[10700,10812,"You're just the servant girl"],[10812,10925,"who stole her life."],[11125,11250,"It's Annie's birthday today."],[11350,11450,"Grandpa said he won't show"],[11450,11537,"unless you're there,"],[11537,11675,"so I'm here to pick you up."],[11750,11825,"Of course."],[11887,11975,"No one remembers that"],[11975,12087,"it's my birthday too."],[12333,12437,"What are you doing?"],[12462,12512,"Are you trying"],[12512,12591,"to piss me off?"],[12625,12750,"No, I just thought you"],[12750,12787,"wouldn't want to"],[12787,12862,"sit next to me."],[13262,13300,"Fine."],[13350,13416,"Walk home."],[14075,14125,"Home."],[14225,14337,"What even is home anymore?"],[14562,14637,"Is this a home"],[14662,14787,"or another prison?"],[14862,14962,"I'm not sure."],[15012,15125,"All I know is that the love"],[15125,15250,"that once lived here is dead."]],"2":[[662,812,"Oh my God, sweetheart."],[900,1062,"You're skin and bones."],[1275,1350,"You used to have the"],[1350,1475,"prettiest cheeks."],[1562,1687,"Did somebody hurt you?"],[1787,1900,"Were you hurt in there?"],[1937,2012,"Mom can never know"],[2012,2087,"that I paid those"],[2087,2187,"girls to bully her."],[2225,2300,"Mom, come on."],[2337,2425,"You called the staff."],[2462,2587,"Everyone knew she was Lane's"],[2587,2691,"family princess."],[2750,2837,"They wouldn't touch her."],[2850,2912,"Right?"],[3000,3112,"No, don’t touch my hand!"],[3462,3587,"I, I didn't mean to."],[3587,3650,"Ellie!"],[3650,3800,"What are you doing?"],[3812,3862,"Mom was just"],[3862,3950,"worried about you."],[4087,4175,"Ellie, I know you're still"],[4175,4275,"upset with us and"],[4275,4400,"I understand."],[4400,4475,"I don't blame you,"],[4475,4529,"but,"],[4575,4737,"three years ago you pushed your"],[4737,4866,"grandmother down the stairs."],[4912,4975,"She's been in a"],[4975,5125,"coma ever since."],[5162,5225,"Sending you away"],[5225,5366,"was our only choice."],[5475,5562,"I'm not the one that should"],[5562,5662,"have been sent away."],[5687,5762,"That's enough."],[5787,5887,"Three years in juvie"],[5887,5987,"and you're still throwing"],[5987,6129,"accusations at Annie?"],[6137,6275,"Did you ever once"],[6300,6450,"show an ounce of remorse"],[6450,6566,"for what you did to grandma?"],[6600,6737,"You're not my actual"],[6737,6900,"granddaughter after all!"],[6925,7000,"How long were you"],[7000,7141,"planning to lie to us?"],[7400,7475,"Grandma!"],[7600,7662,"No, grandma."],[7754,7850,"No, grandma, wake up."],[7912,7962,"Grandma, wake up!"],[7962,8075,"Please wake up!"],[8087,8166,"Grandma, please."]],"3":[[58,241,"I am not framing anyone."],[383,445,"Enough!"],[520,633,"It's Annie's birthday."],[683,820,"Let's not let this ungrateful"],[820,950,"wretch ruin the festivities."],[1045,1095,"We're celebrating"],[1095,1170,"our real daughter."],[1270,1333,"Your grandpa's"],[1333,1400,"here to see you."],[1420,1508,"We told him you were studying"],[1508,1645,"abroad so he wouldn't worry."],[1683,1758,"I know you've always been"],[1758,1837,"jealous of Annie."],[1870,2008,"Thought she stole your place."],[2058,2183,"But today's not about you."],[2283,2445,"Don't ruin it, alright?"],[2533,2695,"If you hate me that much,"],[2800,2858,"why bother"],[2858,2970,"trying to bring me back?"],[3020,3187,"Ellie, despite everything,"],[3283,3412,"you're still our daughter."],[3483,3633,"Of course we love you."],[3720,3820,"If you want to be mad,"],[3820,3945,"be mad at me, but,"],[3970,4058,"please,"],[4108,4220,"stop hurting mom."],[4245,4345,"You thought we brought you"],[4345,4520,"back because we wanted to?"],[4545,4691,"If grandpa hadn't begged to"],[4691,4770,"see you again,"],[4795,4933,"we wouldn't have bothered."],[5083,5208,"If it weren't for grandpa and"],[5208,5370,"grandma, I wouldn't have come"],[5370,5483,"back to this place either."],[5495,5620,"What are you sneering at?"],[5658,5870,"It was juvie, not prison."],[5920,6008,"Stop acting like you"],[6008,6133,"got back from a war."],[6133,6245,"It couldn't have been that bad."],[6433,6550,"Not that bad?"],[7225,7383,"Sorry, Mr. and Mrs. Lane,"],[7383,7420,"I shouldn't have"],[7420,7520,"been so emotional."],[7520,7620,"What did you call us?"],[7733,7870,"Ellie, I'm still your mother."],[7908,7970,"Not anymore."],[8058,8170,"I lost my parents"],[8170,8258,"three years ago."],[8358,8491,"How dare you!"],[8520,8620,"Ungrateful brat!"]],"4":[[0,95,"How dare you!"],[95,283,"You ungrateful little brat!"],[345,433,"This family raised"],[433,570,"you for 17 years."],[608,658,"We don't owe you"],[658,783,"a goddamn thing!"],[820,908,"You hurt grandma,"],[933,1045,"you refused to admit it,"],[1045,1170,"you come back from juvie with"],[1170,1295,"this stuck-up attitude?"],[1333,1445,"If we'd known you'd grow up"],[1445,1570,"like this, we never would"],[1570,1670,"have taken you in!"],[1670,1795,"Oh Ellie,"],[1820,2020,"still as foolish as ever."],[2083,2195,"You're digging your own grave"],[2195,2345,"before I even lift a finger."],[2420,2583,"Mom, leave her,"],[2612,2670,"okay?"],[2720,2883,"We gave her the best meal plan"],[2883,3008,"and the best room in the"],[3008,3083,"whole facility."],[3095,3233,"If she wants to come back and"],[3233,3358,"throw tantrums and bite the"],[3358,3445,"hand that feeds her,"],[3479,3570,"she should at least show us a"],[3570,3658,"little bit of gratitude."],[3695,3833,"No, Charles, you're wrong."],[3933,3995,"Look,"],[4033,4158,"she's gaunt and frail"],[4158,4250,"and she's hurt."],[4270,4345,"I know she went"],[4345,4433,"through hell in there."],[4500,4570,"I can see it."],[4570,4658,"Hell?"],[4683,4745,"Mom, she's the"],[4745,4845,"Lane Family heiress."],[4920,5020,"No one would have bothered to"],[5020,5108,"lay a finger on her."],[5145,5333,"And if they did, it wouldn't"],[5333,5483,"be half as bad as what she"],[5483,5570,"did to grandma."],[6583,6683,"Okay, please just,"],[6770,6883,"just let me go."],[6883,6995,"Oh, not so fast."],[7045,7120,"Not until you give me that"],[7120,7220,"goddamn necklace."],[7533,7620,"No!"],[8983,9033,"You're right."],[9095,9158,"It's nothing."],[9208,9270,"See?"],[9308,9387,"Drama Queen."],[10320,10370,"I'm here to take"],[10370,10462,"Annie for a drive."],[11295,11387,"Daxon Blaine."],[11458,11558,"I have had a crush"],[11558,11720,"on him for ten years."],[11845,11945,"He's always kept me"],[11945,12033,"at an arm's length."],[12083,12183,"Turns out his heart belongs"],[12183,12258,"to someone else."],[12358,12445,"If you’ll excuse me."],[12520,12558,"Hey, Ellie."]],"5":[[29,129,"If you’ll excuse me."],[191,266,"Hey, Ellie."],[304,429,"Fake ass bitch."],[491,579,"As if I don't know, she's"],[579,716,"been swooning over Daxon for"],[716,791,"ten whole years."],[916,1091,"Daxon, you know my sister."],[1141,1254,"She's a spoiled brat."],[1291,1404,"Three years in juvie and she"],[1404,1504,"couldn't even say hello."],[1541,1591,"For real."],[1616,1691,"You know, Ellie used to"],[1691,1716,"follow me"],[1716,1791,"around like a shadow."],[1829,1891,"So I guess juvie"],[1891,1954,"at least fixed that."],[2016,2066,"But hey,"],[2066,2179,"a Lane girl like her?"],[2216,2329,"She probably did her fair"],[2329,2429,"share of bullying in there."],[2591,2641,"Let's go."],[3891,3991,"Guess I'll never be able to"],[3991,4029,"wear something"],[4029,4104,"like that again."],[4141,4229,"Ellie, are you ready?"],[4779,4841,"Mom wanted me"],[4841,4908,"to come get you."],[4941,5029,"Hey, this is my room."],[5054,5120,"Get out."],[5604,5729,"What are you hiding, sis?"],[5816,5904,"It's none of your business."],[5916,6095,"Okay? Now please leave."],[6379,6516,"You poor thing."],[6583,6704,"You know, it must suck"],[6791,6891,"to see everything that"],[6891,6941,"used to be yours"],[6941,7041,"get taken away?"],[7141,7216,"You know this"],[7216,7316,"dress mom got for you?"],[7316,7391,"The one you..."],[7429,7541,"love so much?"],[7654,7741,"I've been wearing it all the"],[7741,7779,"time over the"],[7779,7858,"last three years."],[7941,8041,"Take whatever you want."],[8116,8233,"Ok? I don't care."],[8291,8329,"Really?"],[8641,8866,"What are you hiding, sis?"],[9041,9141,"Whatever it is,"],[9179,9354,"I'm sure once mom and dad see it,"],[9354,9504,"they'll demand you give it to me."],[9629,9704,"I mean, face it."],[9729,9866,"Everything that used to be"],[9866,10008,"yours is mine now."],[10129,10291,"It makes you happy to think that,"],[10291,10416,"then go right ahead."],[10454,10541,"Now please"],[10541,10679,"get out of my room."],[10691,10754,"No!"],[10779,10879,"I live here."],[10879,11016,"This is my house."],[11104,11229,"You're the outsider now."],[11370,11416,"You're the one"],[11416,11491,"who should leave."],[11612,11691,"But first let me see what"],[11691,11791,"you're hiding, huh?"],[11837,11879,"No!"],[11900,11979,"Kids, you all set?"],[11979,12054,"We’re heading out."],[12391,12479,"Ellie, you..."]],"6":[[12,54,"Ellie,"],[87,175,"why aren't you wearing the dress"],[175,275,"that I picked out for you?"],[287,362,"It's fine, okay?"],[362,450,"I'll just wear this one."],[475,525,"Is it because"],[525,600,"I've been wearing it?"],[637,741,"But you were gone and..."],[787,900,"I'm sorry, I shouldn't have-"],[900,975,"Annie,"],[975,1112,"stop blaming yourself."],[1162,1262,"That dress is yours."],[1350,1475,"Ellie's unfit to be seen in"],[1475,1537,"something meant for"],[1537,1612,"the true Lane heiress..."],[1612,1750,"Charlie, don't talk about"],[1750,1862,"your sister like that."],[1875,1912,"Why?"],[1987,2050,"She's the one who's been"],[2050,2187,"calling herself a servant girl,"],[2225,2287,"and servant girls"],[2287,2337,"aren't meant to"],[2337,2450,"wear dresses like that."],[2487,2537,"At least now she"],[2537,2600,"knows her place."],[2712,2762,"Let's go."],[3037,3075,"Ellie,"],[3112,3187,"you're free to wear"],[3187,3287,"whatever you like, okay?"],[3400,3450,"Come on."],[4750,4837,"Thanks, Mom."],[5050,5187,"Happy 20th birthday, Annie."],[5337,5387,"Thank you."],[5412,5475,"I'm so glad to"],[5475,5562,"call you my sister."],[5587,5637,"Happy to have you"],[5637,5700,"part of this family."],[6000,6037,"Grandpa."],[6162,6250,"You came."],[6312,6400,"I've been waiting all night"],[6400,6462,"for your present."],[6950,7012,"Grandpa."],[7150,7200,"Ellie,"],[7300,7387,"happy birthday,"],[7437,7612,"my beautiful girl."],[9112,9200,"This is for you."],[9650,9762,"Thank you, Grandpa."],[10625,10700,"Darling, you're"],[10700,10862,"growing so thin."],[11000,11100,"What have they been feeding"],[11100,11375,"you at that school overseas?"],[11525,11600,"Where the hell"],[11600,11725,"did you send her?"]],"7":[[12,87,"Where the hell"],[87,212,"did you send her?"],[337,437,"Have you been giving her"],[437,575,"enough money while she's off"],[575,687,"studying abroad?"],[800,962,"Don't tell me I don't know."],[1012,1175,"Ever since Annie came back,"],[1200,1350,"you've done everything you"],[1350,1525,"can to push Ellie out."],[1575,1775,"You chose to take care of her,"],[1775,1912,"so you should treat her right,"],[1937,2100,"not to toss her aside"],[2125,2225,"after you find your"],[2225,2350,"biological daughter."],[2500,2700,"Ellie, tell me the truth."],[2700,2837,"Have they been hurting you?"],[2875,3025,"Where did they send you?"],[3387,3475,"No, Grandpa."],[3587,3625,"I'm okay."],[3712,3787,"Everyone has been"],[3787,3862,"really good to me."],[3925,3950,"Right."],[4012,4112,"I have some exciting"],[4112,4250,"news for you, Xavier."],[4350,4525,"Annie and Daxon are dating."],[4550,4712,"And Daxon here is"],[4712,4837,"the Blaine family heir."],[4862,4937,"We're planning their"],[4937,5112,"engagement soon and,"],[5125,5300,"locking in a business partnership"],[5300,5412,"with the Blaines."],[5425,5537,"Isn't that exciting?"],[5775,5950,"But ever Ellie was"],[5950,6187,"supposed to marry Daxon."],[6262,6412,"That's all you ever talked"],[6412,6562,"about since she was born!"],[6637,6787,"Now, Annie comes back and"],[6787,6912,"suddenly she's"],[6912,7025,"engaged to him?"],[7075,7237,"I guess I'm getting old."],[7237,7400,"I just can't keep up with"],[7400,7500,"the kids these days."],[7612,7862,"Falling in and out of love"],[7862,7962,"faster than they"],[7962,8100,"change clothes."],[8150,8200,"Grandpa, that's"],[8200,8300,"not what this is."],[8362,8637,"Daxon never liked Ellie."],[8837,8887,"Ellie,"],[9012,9187,"you wanted to marry Daxon"],[9187,9362,"since you were little."],[9412,9625,"If you still have feelings for him,"],[9662,9862,"Grandpa will make it happen."],[10075,10337,"I'll oppose his engagement to"],[10337,10500,"Annie and I'll"],[10500,10700,"make him marry you."]],"8":[[0,137,"If you still have feelings"],[137,412,"for him, I'll oppose his"],[412,675,"engagement to Annie and I'll"],[675,900,"make him marry you."],[1037,1162,"No, that's out"],[1162,1212,"of the question."],[1262,1387,"The Blaines want their son to"],[1387,1550,"marry the real Lane family"],[1550,1700,"heiress and that's Annie."],[1825,1975,"What is this real"],[1975,2187,"and fake heiress talk?"],[2237,2350,"The way I see it,"],[2475,2612,"Ellie is the one"],[2612,2800,"who carries the true"],[2800,2950,"Lane spirit."],[2950,3062,"Who has the"],[3062,3300,"courage and the kindness that"],[3337,3625,"defines our family legacy."],[3675,3712,"But-"],[3712,3887,"But what, John?"],[4037,4300,"The Lane group was built by me"],[4325,4425,"and your mother from the"],[4425,4512,"ground up."],[4562,4762,"And we're the ones"],[4762,4975,"that talked to the Blaines and"],[4975,5100,"made the engagement."],[5300,5462,"Now your mother's in a coma."],[5587,5725,"And I'm the one calling the"],[5725,5862,"shots around here!"],[6175,6262,"But only if..."],[6362,6662,"if it's what our Ellie wants."],[6700,6750,"Dad."],[7062,7100,"No."],[7237,7337,"No Grandpa, it's okay."],[7462,7512,"I'm fine."],[7600,7637,"I don't even"],[7637,7750,"like Daxon anymore."],[7937,8037,"Then it's settled."],[8112,8225,"That's the granddaughter"],[8225,8512,"Barbara and I adored so much."],[8575,8825,"Always clear about what she wants."],[8825,8925,"And darling,"],[8975,9187,"I believe you about what"],[9187,9350,"happened to Grandma."],[9800,9975,"Ellie, it's Red Velvet,"],[9975,10087,"your favorite."],[10087,10187,"Have some."],[10762,10850,"How's it taste?"],[11000,11075,"Nope."],[11700,11787,"Your mother was nice enough"],[11787,11937,"to bring you a cupcake and"],[11937,12012,"that's how you react?"],[12062,12137,"Wipe that look off"],[12137,12287,"your face and eat it."],[12312,12400,"Ellie, is it because it's my"],[12400,12487,"birthday cake?"],[12612,12712,"Is that why you don't want it?"]],"9":[[145,245,"What's the matter, Ellie?"],[358,483,"Are you feeling sick?"],[483,583,"Just because you're jealous"],[583,695,"of Annie doesn't give you an"],[695,833,"excuse to fuck up her birthday."],[845,883,"Charlie!"],[970,1020,"Everything I'm"],[1020,1095,"saying is true."],[1133,1245,"Ever since she came back,"],[1245,1445,"all she's done is mope around and"],[1445,1508,"play the victim."],[1545,1658,"In case you forgot,"],[1670,1808,"you're not one of us."],[1883,1945,"We don't owe"],[1945,2045,"you a damn thing."],[2158,2208,"He's right."],[2270,2383,"I'm the one who owes this"],[2383,2520,"family for raising"],[2520,2608,"me all these years."],[5195,5283,"I'll check on her."],[6070,6283,"My dear sister."],[6483,6608,"If you hate us all so much,"],[6608,6845,"then why bother coming home?"],[6895,6995,"Clearly your life as a"],[6995,7145,"spoiled trust fund baby"],[7145,7258,"was just too"],[7258,7383,"much to give up."],[7433,7545,"Stop pretending that's not"],[7545,7608,"why you're back."],[7645,7708,"Don't put your twisted"],[7708,7808,"thoughts on me, okay?"],[7808,7945,"I came back for grandpa."],[8008,8120,"You know grandma's been in"],[8120,8183,"a coma for"],[8183,8270,"almost three years."],[8383,8504,"Have you ever felt guilty"],[8541,8654,"for even a second?"],[9020,9083,"Guilty?"],[9145,9220,"For what?"],[9308,9395,"I'm her real granddaughter,"],[9395,9483,"but she only ever"],[9483,9650,"had love for you."],[9758,9870,"She got what she deserved."],[9920,10033,"So you do know you're her"],[10033,10108,"granddaughter?"],[10120,10195,"And luckily,"],[10245,10283,"that old hug"],[10283,10383,"can't talk anymore."],[10520,10595,"Let's see."],[10695,10870,"If your ex-family members"],[10870,11083,"still love you"],[11083,11158,"more than love me?"],[11220,11333,"Ellie, Annie?"],[12758,12900,"It hurts!"]],"10":[[245,333,"Annie, what happened?"],[333,412,"Were you hurt?"],[608,770,"It hurts, my leg."],[870,970,"Jesus Christ."],[1320,1408,"Ellie, what did you do?"],[1520,1583,"Ellie, did you"],[1583,1645,"do this to her?"],[1670,1758,"You bullied her"],[1758,1833,"again, didn't you?"],[1870,1995,"Oh my God, call the"],[1995,2108,"family doctor, now!"],[3158,3220,"Thank God it's"],[3220,3295,"not a deep wound."],[3433,3595,"Dad, we can't keep track of"],[3595,3708,"how many times Ellie's gone"],[3708,3808,"after Annie like this."],[3870,4008,"If we let this go on,"],[4025,4108,"we're neglecting our"],[4108,4195,"duty as parents."],[4245,4358,"She has to learn how to"],[4358,4437,"behave herself."],[4545,4583,"It's okay."],[4645,4695,"I know Ellie"],[4695,4783,"didn't mean to hurt me."],[4820,4858,"Annie, you're"],[4858,4970,"being too soft on her."],[5033,5170,"You don't need to defend her"],[5170,5295,"after what she did to you."],[5370,5495,"Ellie attacked Annie because"],[5495,5595,"she's jealous of her."],[5620,5708,"That's all there is to-"],[5708,5770,"Charles,"],[5870,6008,"you grew up with Ellie."],[6095,6195,"You two may not"],[6195,6320,"be related by blood"],[6320,6533,"but she's still your sister."],[6583,6783,"Do you really think a nice"],[6783,6883,"girl like her"],[6920,7020,"would hurt someone?"],[7108,7295,"Besides, she's hurt too."],[7333,7408,"That heartless"],[7408,7583,"brat is not my sister."],[7633,7733,"And if she got hurt,"],[7820,7908,"it's her own fault."],[8170,8358,"How dare you talk like that?"],[8495,8708,"Ellie, don't be afraid."],[8770,8895,"Grandpa trusts you."],[9033,9120,"Now tell me,"],[9120,9270,"did you do this to Annie?"],[9333,9370,"No."],[9470,9545,"No, I didn't."],[9833,10020,"Ellie's an honest girl."],[10058,10233,"If she says she didn't do it,"],[10258,10370,"she didn't do it."],[10420,10533,"Then how come Annie is hurt?"],[10595,10658,"What, are you saying"],[10658,10720,"she just threw"],[10720,10833,"herself on the floor?"],[11008,11095,"It still hurts."],[11195,11370,"Grandpa, you accuse us of"],[11370,11470,"caring more about Annie,"],[11470,11558,"yet you clearly only"],[11558,11633,"care about Ellie."],[11658,11745,"Watch how you speak"],[11745,11808,"to your grandfather."],[11833,11883,"You say you"],[11883,11958,"didn't hurt Annie."],[12083,12133,"Prove it."]],"11":[[241,391,"Even if I had proof,"],[441,541,"you wouldn't believe me anyway."],[604,679,"You didn't believe"],[679,766,"me three years ago."],[891,991,"You won't believe me now."],[1191,1341,"You're all demanding"],[1379,1579,"that Ellie prove her innocence."],[1629,1779,"But why isn't anyone asking"],[1779,2016,"Annie to prove Ellie's guilt?"],[2066,2154,"It was her!"],[2266,2416,"I was cleaning just outside"],[2416,2616,"the restroom when I saw Ellie"],[2616,2704,"push Miss Lane."],[2729,2779,"I saw it with"],[2779,2883,"my own two eyes."],[3129,3316,"I ought to beat you to death"],[3391,3541,"before you hurt someone else."],[3579,3716,"You psychotic brat!"],[3791,3916,"For Annie,"],[3916,4066,"and her comatose grandma."],[4329,4441,"Stop the madness!"],[4741,4816,"Ellie,"],[4816,5004,"just apologize to Annie."],[5116,5304,"And this all ends now."],[5354,5429,"No, I didn't do"],[5429,5491,"anything wrong."],[5491,5591,"I'm not apologizing."],[5629,5779,"Three years later and you're"],[5779,5929,"just as stubborn as ever."],[5991,6054,"Why?"],[6254,6379,"You want me to do"],[6466,6641,"exactly what"],[6641,6741,"I did back then."],[6904,7004,"Confess to something"],[7004,7179,"I didn't do and then beg for your"],[7179,7279,"forgiveness because you gave"],[7279,7429,"me no other choice!"],[7604,7779,"