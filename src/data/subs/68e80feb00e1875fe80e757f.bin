 walk all over our"],[3750,3812,"family and get"],[3812,3912,"whatever she wants."],[3962,4025,"Patricia!"],[4100,4325,"Throw these away or give them"],[4325,4400,"to the homeless."],[4400,4475,"I don't care."],[4887,5016,"You know, I was thinking"],[5016,5150,"about teaching those juvie"],[5150,5262,"girls a lesson..."],[5337,5425,"for messing with Ellie?"],[5462,5512,"No."],[5587,5725,"No, she did this to herself."],[5762,5875,"You don't owe her a thing."],[6137,6200,"But you're right."],[6237,6312,"Those girls need to"],[6312,6387,"learn their lesson."],[6450,6575,"Ellie might have been in the wrong,"],[6612,6725,"but it's our job to"],[6725,6900,"discipline her, not theirs."],[7575,7637,"So you're the ones who"],[7637,7725,"hurt Ellie Lane."]],"22":[[141,216,"So you're the ones who"],[216,304,"hurt Ellie Lane."],[316,366,"Mr. Lane,"],[366,454,"it wasn't our fault."],[466,529,"It was Ellie."],[529,579,"She didn't know"],[579,641,"when to give up."],[641,779,"We just snatched a few little"],[779,891,"things from her."],[1616,1766,"But she kept fighting us like"],[1766,1904,"her life depended on it."],[1904,1991,"Otherwise, we never would"],[1991,2079,"have gone that far."],[2091,2154,"Yeah, she was..."],[2154,2266,"she was too stubborn."],[2266,2354,"I mean, we beat her half-dead"],[2354,2404,"and she still"],[2404,2466,"didn't get the memo."],[2466,2591,"We had no other choice."],[2616,2704,"No other choice,"],[2704,2866,"but to break her arm?"],[3029,3079,"You."],[3166,3279,"What did you steal from her?"],[3579,3641,"This is the only"],[3641,3754,"thing we haven't sold."],[3754,3866,"Everything else is gone."],[4029,4091,"No!"],[5116,5191,"Wow."],[5241,5404,"It's so pretty."],[5416,5554,"I made it by hand."],[5941,6004,"Wait."],[6029,6154,"Charlie, what does this mean?"],[6266,6366,"It's a Portuguese word."],[6416,6529,"It depicts the kind of love"],[6529,6629,"that you have for someone you"],[6629,6754,"can't be with right now."],[6754,6854,"Which means no matter what,"],[6891,6966,"no matter where you go,"],[6966,7066,"I'll always be with you."],[7141,7216,"And I will always"],[7216,7304,"take care of you."],[7541,7666,"So you're saying that she was"],[7666,7754,"willing to fight for this"],[7754,7841,"even if it meant getting"],[7841,7916,"beaten to death?"],[7941,8129,"She...she said it was the most"],[8129,8254,"important thing she owned."],[8291,8354,"But I mean, come on,"],[8354,8479,"it's just a necklace, right?"],[8529,8666,"She was being too stubborn."],[8791,8891,"Find out which one of them"],[8891,8991,"hurt her and"],[8991,9079,"then take her hands."],[9116,9229,"If it was all three of them,"],[9229,9329,"I'd better see six"],[9329,9416,"hands on the ground."],[9454,9479,"No!"],[9508,9554,"No, no!"],[9554,9591,"Mr. Lane."],[9591,9654,"Please, stop!"],[9679,9716,"Wait!"],[9716,9766,"No!"],[9791,9829,"Please!"],[10383,10458,"Charles,"],[10504,10691,"do you even still see Ellie as your sister?"],[10779,10941,"Daxon, you're Annie's boyfriend,"],[10941,11004,"so how about you"],[11004,11104,"keep your nose out of places"],[11104,11191,"that doesn't bill on?"],[11216,11258,"Right."],[11258,11412,"Just figured I'd give you a heads-up,"],[11412,11520,"Ellie's getting married."],[11520,11616,"And her fiancé?"],[11616,11737,"Let's just say he's..."],[11737,11850,"not all there mentally."],[11879,11979,"But since she's apparently"],[11979,12116,"not family to you anymore,"],[12116,12191,"I'm guessing you"],[12191,12320,"won't lose sleep over it-"],[12366,12437,"Daxon, what are"],[12437,12541,"you talking about?"]],"23":[[387,487,"We can't do this, John."],[512,612,"That man has a mind"],[612,700,"of a six-year-old."],[725,825,"If we marry them off,"],[850,1012,"she is going to ruin her life."],[1037,1162,"What choice do we have?"],[1187,1237,"We made an"],[1237,1325,"agreement with the McLeans."],[1437,1537,"If we back out now,"],[1575,1700,"our family is finished."],[1750,1937,"Yeah, but Ellie still hates"],[1937,2062,"us ever since we"],[2062,2162,"took her to do juvie."],[2200,2337,"So we cannot let"],[2337,2462,"her marry this idiot."],[2512,2637,"She'll never forgive us."],[2650,2762,"What do you propose?"],[2775,2887,"We sacrifice Annie?"],[2925,3012,"She's our real daughter,"],[3012,3062,"Claire."],[3250,3387,"Ellie isn't even a Lane."],[3487,3600,"We gave her comfort for 20"],[3600,3750,"years and raised her"],[3750,3875,"like she was our own."],[3975,4037,"It's time for"],[4037,4162,"her to repay us."],[4312,4512,"Look, whatever happens,"],[4562,4687,"my father can't find out about"],[4687,4787,"Ellie's engagement."],[4837,4950,"He'll never agree to it."]],"24":[[95,145,"Mom!"],[195,220,"Dad!"],[258,333,"Are you really going to marry"],[333,470,"Ellie off to the McLeans?"],[545,608,"I'm not going to"],[608,683,"let that happen."],[695,858,"Hudson McLean is a moron."],[945,983,"Ellie is going"],[983,1045,"to be miserable."],[1070,1133,"Charles, we're"],[1133,1220,"out of options."],[1245,1333,"Annie and Daxon's"],[1333,1408,"marriage is set."],[1445,1520,"There's no one else we can"],[1520,1583,"offer the McLeans"],[1583,1670,"except Ellie."],[1833,2033,"Dad, Ellie already lost her"],[2033,2133,"arm because of us and you're"],[2133,2195,"going to what?"],[2233,2345,"Sell her future off for the"],[2345,2433,"family legacy?"],[2458,2558,"If you go through with it,"],[2558,2670,"you are fucking evil."],[2695,2820,"Watch your tone, son!"],[2833,2858,"Dad!"],[2933,3083,"Charlie, stop!"],[3133,3220,"If it's really that"],[3220,3333,"big of a problem, then..."],[3495,3608,"I'll marry him."],[3645,3683,"What?"],[3733,3920,"Look, even your sister's more"],[3920,3995,"mature than you."],[4033,4145,"Are you really going to stand"],[4145,4333,"back and watch Annie"],[4333,4483,"dive headfirst into hell?"],[4483,4633,"No, that... that's not"],[4633,4708,"what I'm saying."],[4745,4795,"There just has"],[4795,4883,"to be another way."],[4920,5133,"Daxon, say something, okay?"],[5133,5233,"Once upon a time, you were"],[5233,5320,"engaged to Ellie."],[5333,5420,"Are you really going to let"],[5420,5583,"them marry her to a moron"],[5583,5708,"like Hudson McLean?"],[5858,5920,"Mr. Lane,"],[5933,6070,"this really isn't fair to Ellie."],[6108,6183,"If you need something,"],[6183,6283,"the Blaine family can..."],[6283,6458,"Daxon, look, I know you want"],[6458,6595,"to help Ellie, but you're the"],[6595,6770,"Blaine family's only son and"],[6770,6895,"our agreement stipulates you"],[6895,6995,"marry our daughter."],[7045,7183,"Now, we've already finalized"],[7183,7345,"Ellie's engagement with the McLeans,"],[7383,7520,"so I'm not changing my mind."],[7545,7583,"It's what's"],[7583,7695,"best for everyone."],[7695,7808,"No, you can't do that!"],[7845,7933,"You're going to throw away"],[7933,8045,"Ellie's future to what?"],[8058,8120,"Save your own?"],[8370,8533,"Ellie, the Lane family's"],[8533,8583,"survival is"],[8583,8695,"hanging in the balance."],[8708,8808,"It's our only choice."],[8870,9008,"Please, we're just asking-"],[9008,9170,"Mom, be honest."],[9245,9333,"Nobody wants to marry"],[9333,9445,"a moron like Hudson."],[9445,9495,"I do."],[9908,10020,"I will marry him."],[10045,10195,"Seventeen years of kindness,"],[10195,10283,"three years of chains."],[10283,10445,"And today, I cut them off"],[10445,10545,"with this marriage."],[10558,10658,"From now on, we're even."],[10695,10783,"If I cannot be loved"],[10783,10858,"as their daughter..."]],"25":[[20,120,"I will marry him."],[170,295,"I never belonged to this"],[295,358,"family anyway."],[408,583,"I just stole the life of the"],[583,770,"real Lane family heiress by"],[770,945,"accident for seventeen years."],[995,1120,"Marrying into the McLean"],[1120,1320,"family is my way of thanking"],[1320,1520,"you for raising"],[1520,1620,"me all these years."],[1645,1795,"And once I marry Hudson McLean,"],[1795,1895,"we'll be even."],[1920,2020,"Yeah, I won't owe the"],[2020,2133,"Lane family anything."],[2170,2220,"No!"],[2433,2583,"Mother, what are"],[2583,2658,"you trying to say?"],[2708,2783,"No!"],[2883,3020,"She's not!"],[3245,3308,"Your real..."]],"26":[[0,133,"She's not!"],[133,220,"Your real..."],[270,545,"Grandma, it's okay."],[595,708,"I'm choosing this."],[795,933,"I want to marry Hudson."],[1095,1133,"No."],[1233,1333,"Ellie, I object!"],[1420,1545,"You can't marry Hudson."],[1670,1708,"Okay."],[1745,1895,"He is not a bad man."],[1895,2008,"He's a little different,"],[2008,2058,"but that doesn't"],[2058,2158,"make him any less."],[2233,2283,"I know."],[2370,2408,"Okay?"],[2495,2633,"I know you hate it here."],[2720,2858,"But you can't jump into one"],[2858,3008,"nightmare to escape another."],[3058,3120,"I'm sorry."],[3158,3245,"I have been a terrible"],[3245,3320,"brother to you."],[3345,3445,"Ellie, I don't see"],[3445,3570,"you as a servant girl."],[3645,3758,"I don't see you as a maid."],[3758,3883,"I see you as my sister."],[3933,3970,"Look."],[4058,4170,"I found your necklace."],[4208,4320,"I know the truth now."],[4320,4395,"I know what happened."],[4395,4433,"I know how they"],[4433,4545,"tortured you in juvie-"],[4545,4620,"I don't care."],[4795,4845,"Your love meant"],[4845,4945,"the world to me."],[5058,5120,"But now there's"],[5120,5208,"only darkness."],[5283,5333,"Ellie."],[5495,5533,"Please."],[5558,5695,"We can try again."],[5745,5833,"Do you remember what I said"],[5833,5945,"when I gave you this pendant?"],[5983,6083,"I said I was going to love"],[6083,6170,"you forever and I would"],[6170,6295,"always be there for you."],[6333,6433,"That is why I cannot"],[6433,6558,"let you marry Hudson."],[6570,6620,"Charles!"],[6620,6845,"Now who I marry is none of"],[6845,6945,"your business,"],[7020,7095,"Mr. Lane."],[7108,7158,"Ellie, please..."],[7258,7333,"call me Charlie."],[7358,7470,"I know you hate me."],[7470,7583,"I know you're mad at me."],[7595,7708,"If you want to yell at me or"],[7708,7795,"if you want to hit me,"],[7833,7883,"please."],[7908,8033,"I know I can make you"],[8033,8158,"cupcakes every day."],[8195,8308,"Alright, whatever it takes to"],[8308,8445,"make it up to you, I will do."],[8495,8583,"What the hell is"],[8583,8683,"wrong with Charles?"],[8733,8858,"You still want to be a part"],[8858,8945,"of this family."],[8995,9120,"That's why you fought so hard"],[9120,9220,"to protect this necklace."],[10245,10395,"It's just a stupid necklace."],[10433,10670,"I was young and naive..."],[10683,10808,"and I fought for something"],[10808,11045,"that was worth nothing in the end."],[11070,11233,"From now on, I am"],[11233,11383,"living life on my terms."]],"27":[[20,195,"If I marry into the McLean family,"],[208,333,"I would have my own"],[333,558,"life and my own home."],[758,895,"Why wouldn't I do that?"],[1308,1333,"Fine."],[1570,1708,"If you don't want me as your brother,"],[1795,1870,"then I guess there's"],[1870,1970,"nothing I can do."],[2083,2145,"Charlie!"],[2333,2383,"Ellie,"],[2383,2470,"we're happy to hear you"],[2470,2570,"agreed for the marriage."],[2583,2670,"The McLeans would like to"],[2670,2758,"host a dinner for you tonight."],[2758,2883,"So you could meet Hudson."],[3120,3208,"Would that be alright?"],[3683,3770,"Mr. Lane,"],[3820,3883,"welcome."],[3933,3970,"It's great to"],[3970,4045,"finally meet you."],[4058,4158,"Mr. McLean, likewise."],[4183,4295,"For nothing but great thanks."],[4445,4587,"-How do you do? -Mr. Lane."],[5108,5258,"This must be Hudson."],[5320,5470,"He seems like a great guy."],[5570,5683,"I can't believe Ellie is"],[5683,5833,"supposed to marry this nutjob."],[5883,5958,"Come over here,"],[5970,6108,"meet your new in-laws."],[6108,6158,"Come on."],[6858,6933,"Hudson!"],[6933,7020,"Hudson, stop!"],[7058,7133,"I told you,"],[7133,7245,"no horsing around!"],[7308,7420,"Mr. Lane,"],[7433,7520,"apologies."],[7533,7708,"Hudson was in an accident"],[7708,7870,"a short while ago and ever"],[7870,8020,"since then he's become a bit..."],[8258,8333,"rebellious."],[8333,8520,"I hope you can understand."]],"28":[[16,204,"I hope you can understand."],[491,566,"Stop!"],[1379,1529,"Whoa, whoa, whoa!"],[1529,1666,"Bad people, bad people!"],[1666,1829,"Go away, go away!"],[1879,1916,"Go away!"],[1954,2041,"Stop, stop!"],[2154,2241,"Come here."],[3341,3404,"It's for you."],[3941,4154,"Oh, my dear sister."],[4191,4279,"Have fun being a"],[4279,4391,"lifelong babysitter."],[4416,4579,"If Ellie marries this nutcase,"],[4591,4704,"her life is over."],[5416,5666,"So, this is Ellie,"],[5691,5829,"my future daughter-in-law."],[5866,5941,"Indeed it is."],[5979,6079,"Mr. and Mrs. McLean,"],[6091,6179,"meet Ellie Lane,"],[6179,6291,"my beautiful daughter."],[6529,6591,"Ellie,"],[6591,6641,"say hello to"],[6641,6716,"your new in-laws."],[6741,6879,"Hello, Mr. and Mrs. McLean."],[7629,7679,"Ew."],[7891,7941,"Oh!"],[7991,8079,"Oh, dear!"],[8341,8441,"Oh!"],[8466,8541,"Oh!"]],"29":[[279,341,"Oh, my God."],[391,591,"I'm so sorry, Ellie."],[616,679,"Why don't you go"],[679,779,"clean yourself up?"],[779,904,"You're so silly."],[1466,1600,"You have a little bit on you."],[1725,1795,"Sorry."],[2479,2529,"Ellie,"],[2566,2716,"is this really what you want?"],[2741,2891,"To be the miserable wife of a"],[2891,2979,"mental patient?"],[3016,3216,"What a pathetic bitch."],[3279,3391,"If you'll excuse me,"],[3391,3479,"Mr. and Mrs. McLean,"],[3479,3566,"I'm gonna go get"],[3566,3691,"myself dried off."],[4104,4266,"Well, Mr. Lane,"],[4291,4341,"well done."],[4341,4454,"You've raised a"],[4454,4541,"wonderful daughter."],[4554,4641,"Indeed she is."],[4829,4879,"To Ellie."],[4966,5016,"To Ellie."],[5591,5779,"Ellie, listen to me."],[5804,5916,"Don't marry this guy."],[6041,6204,"You are already engaged,"],[6204,6266,"Mr. Blaine."],[6279,6366,"You should be focusing on"],[6366,6516,"your own marriage, not mine."],[6604,6791,"Look, I don't want you to"],[6791,6904,"marry him, alright?"],[6904,7066,"I know I was blind before,"],[7066,7179,"but I see it now."],[7304,7366,"I see you."]],"30":[[37,200,"You're drunk, Daxon. Ok?"],[200,262,"Sober up."],[350,400,"I promise,"],[400,550,"I'm sober as a judge."],[550,587,"I just-"],[587,675,"Daxon!"],[737,812,"Here you are."],[900,962,"We've been"],[962,1087,"looking everywhere..."],[1112,1175,"for you."],[1275,1325,"So,"],[1425,1550,"you've met your new husband."],[1562,1675,"You still gonna marry him?"],[1862,1900,"Ellie!"],[2212,2250,"Ellie!"],[2350,2487,"You know, Ellie, I actually"],[2512,2625,"feel bad for you."],[2787,2850,"What do you want?"],[2862,2975,"It's kind of funny."],[3037,3187,"You know, you're marrying a"],[3187,3362,"man with a brain of a kindergartner,"],[3362,3450,"and I get to"],[3450,3737,"spend the rest of my life"],[3737,3975,"with your one that got away."],[3987,4187,"I could cry tears of happiness,"],[4187,4312,"just thinking about it."],[4362,4550,"Well, congrats, Charles,"],[4550,4750,"Daxon, the whole Lane family..."],[4787,4875,"They're all yours."],[6300,6825,"Take good care of Ellie!"],[6987,7062,"Barbara, you..."],[7350,7437,"You can talk!"]],"31":[[187,425,"Daxon, need I remind you that"],[425,550,"you are engaged to Annie?"],[550,825,"If I so much as find you thinking"],[825,962,"about another woman."],[1062,1175,"Annie, what were you and"],[1175,1275,"Ellie talking about?"],[1275,1412,"Ellie said the McLeans are"],[1412,1537,"rich and powerful,"],[1537,1712,"so marrying into their family"],[1712,1762,"would be better"],[1762,1850,"than staying with us."],[1862,1912,"What?"],[1962,2012,"Of course."],[2025,2150,"She was angling after their"],[2150,2262,"money the whole time."],[2287,2350,"I can't believe I"],[2350,2437,"underestimated her."],[2437,2487,"Charlie, don't be"],[2487,2587,"too hard on yourself."],[2600,2712,"Wait, look at it this way..."],[2762,2850,"Ellie's always had a hard"],[2850,2962,"time accepting that she's not"],[2962,3062,"the real heiress."],[3137,3225,"Makes sense that she'd want"],[3225,3350,"to marry rich and get a taste"],[3350,3437,"of a good life."],[3450,3487,"Fine."],[3512,3625,"If that's what she wants to do,"],[3625,3687,"then fine!"],[3712,3800,"But she better not come"],[3800,3950,"crawling back begging for us"],[3950,4062,"to take her in again."],[4312,4362,"Annie,"],[4387,4512,"did Ellie really say that?"],[4575,4650,"Of course she did."],[4687,4787,"Daxon, she just spent"],[4787,5000,"three years in juvie."],[5112,5162,"Of course she'd"],[5162,5250,"want a better life."],[5262,5312,"Yeah, but..."],[5350,5575,"Is that really a better life?"],[5650,5750,"Of course not."],[5762,5925,"Not with me around it isn't."],[5925,6137,"Because Ellie, my job is to"],[6137,6275,"make sure every second you"],[6275,6425,"spend on this earth"],[6425,6650,"is a living hell."]],"32":[[712,787,"So that's the"],[787,887,"McLean bride, huh?"],[912,987,"Is it just me,"],[987,1087,"or she not really give off"],[1087,1204,"the vibe of a..."],[1225,1291,"Lane girl."],[1337,1462,"It's cause she's not even their"],[1462,1554,"real daughter."],[1562,1650,"That's why they're marrying"],[1650,1787,"her off to some mentally"],[1787,1912,"handicapped fool."],[2737,2950,"Ellie Lane, will you take"],[2950,3162,"this man to be your husband,"],[3200,3487,"to love and to cherish,"],[3487,3637,"in good times and in bad,"],[3662,3837,"in sickness and in health."],[3900,3987,"No!"],[4075,4166,"I object!"],[4212,4266,"Grandpa!"],[4400,4512,"Mom, Dad,"],[4550,4625,"what are you doing here?"],[5125,5287,"You didn't invite me to my"],[5287,5400,"granddaughter's wedding?"],[5462,5537,"John,"],[5575,5737,"you're Ellie's father."],[5762,5962,"How can you just stand by and"],[5962,6162,"watch her run straight into a"],[6162,6237,"burning building?"],[6287,6512,"Mr. Lane, are you comparing my"],[6512,6637,"family to a burning building?"],[6675,6850,"No offense, Mr. McLean."],[6850,7187,"I'm sure your son can find a nice"],[7187,7362,"girl and make her very happy."],[7400,7537,"But I don't think that girl"],[7537,7675,"should be Ellie."],[7687,7729,"Dad!"],[8037,8187,"Grandpa, it's not like..."],[9087,9195,"grandpa."]],"33":[[316,454,"She's an amputee!"],[616,829,"Mr. Lane, did you honestly think"],[829,954,"you could keep this a secret"],[954,1041,"from your in-laws?"],[1070,1129,"We weren't trying"],[1129,1191,"to hide a thing."],[1216,1329,"I thought you already knew."],[1341,1379,"Besides-"],[1391,1466,"Yeah, save it!"],[1466,1529,"I don't wanna hear"],[1529,1604,"another word out of you."],[1629,1829,"Mr. Lane, as the most esteemed"],[1829,1941,"member of the Lane family,"],[1979,2029,"what do you have"],[2029,2116,"to say about this?"],[2291,2529,"Three years ago, my imbecile"],[2529,2691,"of a son sent my"],[2691,2845,"granddaughter to juvie."],[2891,3016,"While she was there,"],[3016,3241,"someone broke her arm and it"],[3241,3354,"had to be amputated."],[3366,3429,"What?"],[3604,3804,"Ellie was switched at birth."],[3829,3941,"Are you sorry or not?"],[3966,4079,"No, I'm not."],[4116,4304,"If they're still alive."],[4316,4429,"She has..."],[4504,4629,"no family,"],[4629,4791,"no safety net,"],[4791,4941,"not even a left arm."],[5066,5191,"And now,"],[5191,5416,"her adoptive parents"],[5416,5641,"want to marry her off to your"],[5641,5779,"manchild son."],[5841,6141,"It's just all too cruel."],[6304,6604,"Ellie needs someone who can support her,"],[6604,6716,"not someone"],[6779,6866,"who wants her to be"],[6866,6979,"their caretaker."],[7029,7266,"My granddaughter is"],[7266,7554,"resilient, kind, stronger"],[7554,7704,"than any of you,"],[7704,7941,"but she's suffered enough."],[7966,8116,"She deserves to be with"],[8116,8291,"someone who truly loves her,"],[8316,8479,"someone who can take care of her,"],[8504,8741,"and not be in a bad"],[8741,8866,"business deal,"],[8866,9070,"treated like a pawn."],[9316,9429,"Well, who would have thought"],[9429,9554,"the Lane family had so many"],[9554,9654,"skeletons in its closet?"],[9666,9754,"Look, the kids are already on"],[9754,9854,"the altar, but it's not too"],[9854,9954,"late to call this off."],[9979,10116,"No, we can't cancel."]],"34":[[12,137,"Dad, do you even hear"],[137,237,"yourself right now?"],[237,287,"We are on the"],[287,412,"brink of bankruptcy!"],[437,537,"We are barely holding on,"],[562,662,"yet here you are risking"],[662,750,"everything for someone that's"],[750,875,"not even part of our family."],[887,937,"Silence!"],[950,1075,"I don't care if the Lane"],[1075,1250,"family uses every"],[1250,1362,"penny to their name."],[1387,1550,"You're not forcing Ellie in"],[1550,1637,"this marriage."],[1662,1800,"You owe her that much!"],[1825,2012,"Owe her? Dad, we raised her."],[2012,2112,"She had the best food,"],[2112,2200,"the best clothes, and"],[2200,2312,"she owned it for nothing!"],[2350,2600,"You ignorant buffoon!"],[2612,2687,"She was treated like a"],[2687,2900,"princess for 17 years."],[2937,3125,"If anything, she owes us."],[3150,3250,"She should be grateful."],[3275,3362,"Even her real parents"],[3362,3412,"couldn't do what"],[3412,3487,"we did for her."],[3487,3650,"Damn, that's pretty harsh."],[3712,3787,"I thought the Lanes always"],[3787,3900,"treated their children so"],[3900,4037,"well, but it turns out they"],[4037,4150,"got their adopted daughter's"],[4150,4237,"arm chopped off."],[4312,4425,"Yeah, but at the"],[4425,4537,"same time I get it."],[4562,4687,"I mean, she's not even their"],[4687,4762,"real daughter, right?"],[4812,4925,"It's not a surprise they"],[4925,5075,"tossed her aside as soon as"],[5075,5250,"the true heiress came back."],[5300,5375,"Seriously?"],[5387,5487,"Real daughter or not,"],[5525,5650,"treating someone so cruelly"],[5650,5762,"after 17 years?"],[5825,5887,"I hope they go"],[5887,5962,"fucking bankrupt."],[6275,6462,"Grandpa, it's okay."],[6525,6662,"I want to marry him."],[6950,7100,"Why, sweetheart?"],[7162,7304,"He's a nice person."],[7400,7587,"Ellie, you're very sure of this,"],[7587,7691,"given his condition."],[7887,7937,