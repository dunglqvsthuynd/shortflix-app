mother!"],[2404,2504,"I'm here for Grandma."],[2516,2595,"I'm not letting her stay"],[2595,2716,"alone with you guys."],[2716,2829,"You're still a suspect."],[2841,2958,"You're not taking her anywhere."],[2979,3066,"First, my mother,"],[3066,3183,"and just now my daughter,"],[3191,3316,"you're inflicting nothing but pain"],[3316,3429,"on everyone around you."],[3429,3554,"I've let a lot slide because"],[3554,3591,"we've been"],[3591,3704,"family for 20 years."],[3729,3854,"But this is my house!"],[3854,3958,"You don't get to come in here"],[3958,4054,"and boss us around!"],[4054,4204,"Get her out!"]],"50":[[0,129,"Get her out!"],[195,316,"The McLean family bodyguards"],[316,395,"are waiting outside."],[416,508,"Touch me again"],[508,604,"and see what happens."],[616,766,"Mrs. McLean, just because you"],[766,879,"married rich doesn't give you"],[879,933,"the right to throw"],[933,1045,"a fit in my house."],[1083,1229,"Think whatever you want,"],[1229,1283,"but I'm taking"],[1283,1383,"Grandma home with me."],[1516,1566,"And if anyone"],[1566,1691,"tries to stop me,"],[1895,1983,"you'll regret it."],[2004,2104,"No, I, I can't"],[2104,2220,"let her take Grandma."],[2229,2320,"Not after all this."],[2345,2466,"I already messed up once."],[2495,2616,"Now I have to"],[2616,2733,"end this for real."],[2991,3045,"Grandma?"],[3170,3216,"Do you want to"],[3216,3291,"come home with me?"],[3441,3558,"Grandma can't even speak."],[3566,3654,"You expect her to just go"],[3654,3762,"with you against her will?"],[3841,3925,"She nodded."],[3954,4050,"That's a yes."],[4254,4320,"I don't care if"],[4320,4416,"you believe her, Dad."],[4441,4529,"I don't!"],[4566,4658,"She's my mother."],[4666,4716,"I'm not letting"],[4716,4820,"anyone take her away!"],[4866,4916,"I'm going to say"],[4916,5016,"this one last time."],[5029,5083,"Grandma is"],[5083,5216,"leaving with me now."],[5266,5416,"Miss, as a suspect,"],[5416,5554,"you're not allowed to take away"],[5554,5654,"the alleged victim."],[5683,5854,"Mr. Lane might not be pressing"],[5854,6041,"charges, but his next of kin"],[6041,6154,"are requesting a"],[6154,6229,"restraining order."],[6254,6404,"And we plan to enforce it."]],"51":[[20,150,"Get the hell out of here!"],[220,337,"Hey Grandma, Grandpa, just"],[337,412,"hold on, okay?"],[412,520,"I'm coming back for you."],[725,808,"The truth will come out"],[808,858,"whether you're"],[858,970,"ready to hear it or not."],[995,1112,"And as for the people who I"],[1112,1225,"love that you hurt?"],[1483,1583,"My husband and I are going to"],[1583,1720,"make sure you pay for that."],[3050,3108,"No."],[3158,3275,"I'm not letting that happen."],[3320,3375,"Ellie."],[3500,3675,"And her little grandparents."],[3733,3920,"I swear, I'll drag you all"],[3920,4095,"straight to hell."]],"52":[[900,962,"Grandma?"],[1237,1287,"Grandma?"],[1312,1362,"Hey, tell..."],[1391,1491,"Hudson call the police."],[1491,1554,"They kidnapped"],[1554,1629,"my grandmother."],[1629,1662,"I'm going to"],[1662,1766,"Camarillo Trail now."],[1812,1875,"No, ma'am."],[1875,1962,"You can't go there."],[1962,2050,"It's too dangerous."],[2062,2137,"If I don't go,"],[2137,2216,"she'll kill her."],[3225,3312,"Grandma?"],[3412,3475,"Grandma?"]],"53":[[891,1054,"What did you do to Grandma?"],[1054,1300,"God, you're just so stupid."],[1350,1462,"You know, three years ago I"],[1462,1550,"outsmarted you and"],[1550,1700,"you ended up in juvie."],[1716,1800,"And you're still"],[1800,2000,"falling for my games."],[2012,2150,"But this time, it's not just your"],[2150,2262,"arm on the line,"],[2262,2362,"it's your life."],[2400,2462,"Where is she?"],[2537,2604,"Tell me!"],[2612,2841,"Grandma, at home, of course."],[3200,3266,"The photo."],[3337,3425,"You faked it."],[3504,3625,"Took you long enough."],[3666,3725,"You know, since you're not"],[3725,3804,"going to make it out of here,"],[3804,3850,"I might as well"],[3850,3962,"tell you the truth."],[4137,4291,"The arm you lost?"],[4404,4662,"I paid someone to do it."],[4750,4829,"And guess what?"],[4875,5112,"I'm not the real Lane heiress."],[5166,5325,"You are."],[5912,5979,"Find my wife,"],[5979,6050,"wherever she is."],[6112,6200,"And whoever did this,"],[6241,6300,"make sure they don't"],[6300,6391,"make it out alive."],[6504,6700,"But what about the DNA test?"],[6712,6750,"It's not the"],[6750,6825,"hard to fake one."],[7037,7100,"So this whole"],[7100,7225,"thing was just a setup?"],[7225,7300,"Yes!"],[7429,7800,"You're the real true heiress."]],"54":[[0,216,"Ellie Lane, how does it feel"],[216,483,"watching your entire family"],[483,716,"rip itself apart"],[716,904,"just like I planned?"],[1166,1191,"I mean,"],[1191,1266,"how do you think your parents"],[1270,1420,"will feel once they realize"],[1420,1491,"their adopted daughter"],[1491,1645,"that they tormented..."],[1654,1791,"was their real daughter"],[1833,1970,"all along?"],[1995,2104,"And that kind of guilt?"],[2116,2204,"It could break a person."],[2241,2379,"You crazy bitch!"],[2666,2741,"That's not how a"],[2741,2916,"real heiress should talk."],[2941,3016,"You know, I,"],[3016,3220,"I was going to let you go after you"],[3220,3416,"married that dumb idiot."],[3470,3604,"But then it turns out,"],[3604,3766,"he was faking it"],[3791,3979,"the whole time."],[4016,4154,"And then you got your hands"],[4154,4516,"on the entire McLean estate!"],[4604,4683,"I..."],[4683,4829,"I couldn't let you"],[4829,5008,"get away with it!"],[5008,5254,"Why is it always you?"],[5270,5354,"Why do you always get"],[5354,5479,"everything you want"],[5479,5608,"without even trying?"],[6683,6754,"Damn."],[6804,6979,"She'll sell for a good price."],[7045,7104,"Who are you?"],[7308,7395,"What do you want?"],[7395,7516,"Don't worry, sweet thing."],[7529,7666,"I'll find you a nice husband."],[7670,7854,"First, I get my turn."],[7854,7966,"No, don't, don't, don't touch me,"],[7966,8058,"don't touch me!"],[8066,8116,"Help!"],[8141,8233,"Help me!"],[8266,8366,"It’s Ellie."],[8366,8454,"She's in trouble!"]],"55":[[0,87,"That was Allie's voice!"],[100,129,"That way!"],[141,179,"That way!"],[375,454,"Here's the money."],[487,637,"She's all yours, but if she"],[637,854,"escapes, I never talk to you again."],[1254,1400,"Annie, my beautiful daughter."],[1554,1675,"Say hi to your mom for me."],[1675,1716,"Take care of"],[1716,1804,"yourself in the city."],[1875,2004,"I'll be here waiting for you."],[2125,2412,"I'm not your daughter!"],[2870,2933,"No."],[3141,3204,"Hey!"],[3512,3675,"Get your hands off my wife!"]],"56":[[41,137,"Ellie, it's okay."],[191,254,"It's okay."],[329,387,"I'm here now."],[475,537,"You're safe."],[837,1025,"It's now 9.19 PM, and the"],[1025,1166,"Camarillo wildfire continues"],[1166,1370,"to spread at an alarming rate."],[1437,1512,"Hudson and Ellie!"],[1525,1629,"They're still in the woods!"],[1666,1712,"Uh, Jade?"],[1737,1779,"Yes, sir?"],[1779,1850,"Get more people"],[1850,1925,"out there searching."],[1925,2025,"I need my son and daughter-in-law"],[2025,2087,"back safe."],[2087,2125,"Go on."],[2141,2204,"Immediately, sir."],[2950,3100,"Boss, they're saying this is"],[3100,3304,"the worst wildfire in ten years."],[3325,3450,"Could take days to get it"],[3450,3525,"under control."],[3525,3587,"Damn it!"],[3600,3737,"GPS is down too."]],"57":[[412,450,"What?"],[450,525,"What do you mean?"],[579,704,"Dad, Ellie and Hudson are"],[712,800,"trapped in the forest fire."],[825,987,"We need to send people now!"],[1004,1100,"Ellie's in danger!"],[1112,1225,"You have to do something!"],[1250,1350,"Dad, I want to."],[1350,1437,"I, I really do."],[1437,1525,"But the forest is huge and"],[1525,1654,"that fire is moving fast."],[1662,1775,"We'll never make it in time."],[1775,1837,"We go in now."],[1837,1987,"It's basically suicide."],[2075,2150,"Ellie!"],[2175,2225,"Grandma!"],[2325,2379,"Daughter!"],[2437,2487,"Mom!"],[2512,2579,"Don't rush."],[2625,2712,"Speak slowly."],[2754,2825,"Ellie!"],[2912,3000,"Daughter!"],[3037,3075,"What?"],[3104,3187,"What did you say?"],[3216,3291,"Ellie"],[3412,3754,"is your biological daughter."],[3866,3916,"What?"],[3929,3975,"What?"]],"58":[[4,50,"Somebody..."],[79,175,"Somebody died in the"],[175,287,"Camarillo Forest."],[354,412,"Who?"],[416,554,"Tell me who, is Ellie okay?"],[562,616,"She's fine."],[616,687,"She's safe."],[712,825,"They found Ellie and Hudson,"],[875,987,"took them to the hospital."],[1550,1662,"Do you know who died?"],[1679,1754,"Was it a man?"],[1791,1862,"Patricia, what are you"],[1862,1925,"talking about?"],[1954,2050,"It's my husband."],[2066,2187,"He was in the woods too."],[2187,2262,"Your husband?"],[2275,2391,"Annie, say something!"],[2437,2537,"Help your dad!"],[2625,2750,"Get off of me!"],[2887,3004,"Your dad?"],[3062,3362,"She's Patricia White's daughter."],[3375,3425,"What?"],[3425,3462,"What?"],[3462,3487,"No."],[3512,3675,"No, it's not true."],[3700,3900,"They tricked all of you."],[3925,4162,"When I found out they faked"],[4162,4312,"the paternity test,"],[4312,4600,"she pushed me down the stairs."],[4775,4812,"No."],[4900,4950,"Please."],[4950,5054,"Mom, Dad,"],[5054,5262,"Grandma has no idea what she's"],[5262,5362,"talking about, all right?"],[5362,5466,"Her memory is"],[5466,5566,"all over the place."],[5566,5675,"You have to believe me."],[5729,5962,"Mr. Lane, I am begging you."],[5962,6104,"Please save my husband."],[6125,6225,"It was my fault."],[6237,6341,"I was greedy."],[6341,6500,"Back then I made Annie fake"],[6500,6650,"the paternity report so she"],[6650,6729,"could pretend to"],[6729,6825,"be your daughter."],[6825,7041,"I swear, I never intended it"],[7041,7150,"to go this far."],[7154,7216,"No!"],[7237,7387,"All right, she's lying!"],[7425,7462,"You're gonna"],[7462,7587,"believe a housemaid?"],[7591,7679,"You want the truth?"],[7700,7800,"Let's take a look at this."]],"59":[[125,212,"You want the truth?"],[300,404,"Let's take a look at this."],[512,591,"Honey,"],[591,687,"you're safe!"],[700,850,"So, are you gonna come clean"],[850,912,"or do you want me"],[912,991,"to do it for you?"],[991,1050,"Wait, what?"],[1050,1100,"I thought you were"],[1100,1187,"mentally disabled."],[1204,1287,"That was an act."],[1287,1400,"He did it to protect the"],[1400,1512,"McLean family trust."],[1512,1650,"You threatened the life of my son"],[1650,1750,"and daughter-in-law."],[1750,1787,"And now you're"],[1787,1854,"gonna pay the price."],[1875,2012,"Annie, is this true?"],[2087,2125,"No."],[2216,2400,"No, it's not true!"],[2450,2491,"Really?"],[2525,2737,"Then, uh, explain this."],[2950,3050,"She used this photo to lure"],[3050,3100,"Ellie into the"],[3100,3191,"woods and kidnap her."],[3437,3550,"Then she paid these two goons"],[3550,3650,"to sell her off."],[3654,3775,"You're full of it, Annie White."],[3775,3900,"This is who you really are."],[3925,3941,"No."],[4079,4150,"No."],[4237,4400,"It's not true."],[4529,4579,"It's true."],[4600,4666,"She hired us to"],[4666,4750,"sell that girl."],[4754,4841,"And this paternity test"],[4841,5004,"proves that Ellie"],[5025,5112,"is your real daughter."],[5937,6062,"The whole Lane family,"],[6062,6225,"fooled by a filthy rat!"],[6241,6362,"You turned me against my own"],[6362,6487,"daughter, you bitch!"]],"60":[[20,225,"Dad, please,"],[225,333,"it's not true!"],[620,858,"Mom, please don't leave me."],[1283,1383,"But you said that you would"],[1383,1441,"always love me"],[1441,1633,"when you gave me this necklace."],[1900,2095,"You don't deserve this."],[2120,2270,"You don't deserve this!"],[2370,2537,"Charlie, Charlie,"],[2537,2745,"I'm your baby sister,"],[2775,2958,"you always love me the most, right?"],[3458,3537,"Take her to jail"],[3625,3725,"and make sure she suffers"],[3725,3845,"like my sister."],[4025,4120,"No!"],[4120,4258,"Ten times worse!"],[4287,4333,"No!"],[4370,4433,"No!"],[4508,4583,"Please!"],[4645,4820,"I'm begging you please have"],[4820,4958,"mercy on Annie!"],[5025,5158,"And take her out of here too."],[5220,5358,"Let the police deal with her."],[5583,5670,"Hudson, please,"],[5700,5812,"take me to see Ellie."]],"61":[[41,104,"I know."],[166,316,"No, it was so crazy,"],[416,491,"Ellie,"],[520,641,"I'm so sorry."],[679,804,"This is all my fault."],[829,941,"I'm so terribly sorry."],[954,1091,"Will you forgive me?"],[2216,2291,"Ellie."],[2529,2804,"Ellie, I was wrong."],[2829,2870,"I listened to"],[2870,2970,"the wrong people."],[3004,3116,"I should have known better."],[3395,3604,"Ellie, please."],[3754,3879,"We know we messed up."],[4045,4120,"I'm not asking"],[4120,4304,"you for forgiveness."],[4354,4420,"I'm asking you"],[4420,4554,"for a second chance."],[4570,4620,"Please, we can"],[4620,4716,"make this right."],[4991,5316,"Mom, Dad, let's go."],[6295,6545,"Ellie, please look at me."],[6604,6641,"Ellie?"],[6770,6841,"So that's it?"],[6866,6970,"You're just gonna leave us?"],[7304,7533,"Ellie, my daughter, please come back."],[7566,7708,"If this is what you want,"],[7708,7795,"then I'll let you go."],[7833,7891,"I just hope you"],[7891,7970,"find true happiness."],[9229,9329,"They say if you fold a"],[9329,9429,"thousand paper cranes,"],[9429,9516,"your wish will come true."],[9541,9650,"I folded two thousand."],[9766,9866,"I've already made my wish,"],[9866,9941,"now it's your turn."],[10341,10541,"My wish is to spend"],[10541,10679,"the rest of my life with"],[10679,10791,"the people I love."],[10833,11158,"Happy, healthy, and at peace."],[11204,11304,"And my wish is to be the one"],[11304,11391,"by your side,"],[11454,11533,"making that come true."]]}