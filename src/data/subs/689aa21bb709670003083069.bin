1192,"He's not here."],[1251,1338,"I know it's hard,"],[1347,1543,"but you have to face the truth."],[1589,1668,"No, he didn't."],[1805,1947,"He wouldn't, he wouldn't leave me."],[1947,2018,"He loves me."],[2189,2339,"Dad, do you see this ring on my finger?"],[2398,2477,"He gave this to me."],[2477,2631,"He put it on my finger."],[2631,2706,"He wouldn't leave me"],[2706,2811,"after all of that."],[2861,2940,"He loves me!"],[3186,3224,"Dad,"],[3286,3432,"did, did Neil get all the gifts"],[3432,3511,"that I've been sending him?"],[3582,3670,"Because I've been sending him"],[3670,3732,"all those gifts"],[3732,3824,"for all the big holidays,"],[3824,3912,"for Christmas,"],[3912,4045,"his birthday, our anniversary."],[4124,4241,"I'm, I'm just trying to make up"],[4241,4341,"for all the gifts that he gave me"],[4341,4416,"over the last five years"],[4416,4512,"because that's the only time,"],[4537,4596,"that's the only way"],[4596,4700,"he's gonna forgive me."],[6327,6435,"No! - Keira, stop."],[6498,6652,"Get a grip on yourself."],[6931,7019,"Oh, Neil."],[7294,7365,"Happy anniversary!"],[7432,7532,"I got this for you."],[7599,7657,"No, no."],[7657,7753,"No, you're saying that"],[7753,7862,"Neil found it?"],[7882,8008,"That Simon lied?"],[8078,8216,"Oh, Simon."],[8408,8504,"Okay, just hang tight."],[8504,8579,"I'm gonna get him to the hospital"],[8579,8646,"and I will come back,"],[8646,8767,"and I will get you patched up."],[9542,9680,"If he takes me back,"],[9680,9755,"I promise"],[9755,9918,"I'll put his happiness first."],[10089,10247,"I love him with all of my heart."]]}