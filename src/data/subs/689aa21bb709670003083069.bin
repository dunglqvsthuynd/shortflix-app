{"1":[[66,204,"Happy anniversary, Keira."],[258,392,"Eight years of loving you."],[417,608,"Five years of calling you my wife."],[633,842,"Today, our special day,"],[884,971,"I'll finally give you"],[971,1084,"what you've always wanted,"],[1138,1222,"freedom,"],[1222,1526,"sealed in ink, divorce papers."],[1680,1793,"Now you can be with your"],[1793,1935,"first and only love."],[2477,2619,"Oh, Simon."],[2765,2948,"I've putting seizure medication"],[2948,3086,"in all your jackets."],[3094,3165,"Spraying your clothes"],[3165,3282,"with diazepam."],[3319,3386,"But you never even"],[3386,3507,"notice these things."],[3578,3661,"That's fine,"],[3687,3745,"Simon can take"],[3745,3870,"care of you from now on."],[3953,4062,"I learned how to cook for you"],[4062,4179,"and our future child."],[4216,4450,"But, you don't even want kids with me."],[4708,4863,"So that's why you never got pregnant."],[5005,5125,"Even now I sit here,"],[5125,5296,"still worrying about your safety."],[5467,5655,"Old habits die slow, I guess."],[5722,5864,"But unloving you will take some time."],[5864,5943,"Hey, where have you been?"],[5943,6031,"It's 1 in the morning."],[6189,6239,"You have a condition,"],[6239,6368,"you can't drink."],[6402,6464,"You know that."],[6531,6610,"Yeah, Simon,"],[6610,6719,"I just got home."],[6919,6990,"That smile."],[7036,7165,"She never smiled at me like that."],[7282,7361,"So are we still on"],[7361,7474,"for Norway next week?"],[7486,7620,"Because I found a gorgeous,"],[7645,7736,"gorgeous ski resort"],[7736,7836,"in the mountain."],[7941,8187,"Oh yeah, of course it'll be just us."],[8295,8454,"And uh, thanks for letting me"],[8454,8546,"wear your jacket."],[8687,8821,"It smells just like you."],[9338,9471,"What the hell is your problem?"],[9634,9709,"Pick that up."]],"2":[[20,133,"Why do you have Simon's jacket?"],[158,266,"Oh my God."],[333,508,"We were drinking in his hotel room"],[508,654,"and I spilled some wine on myself,"],[654,729,"so I showered"],[729,838,"and changed my clothes,"],[838,996,"and I borrowed his jacket."],[1001,1142,"What is the big deal?"],[1255,1368,"You were at his hotel room,"],[1380,1493,"drinking alone and..."],[1672,1739,"it doesn't matter."],[1830,1864,"Look,"],[1914,1981,"I made you a meal"],[1981,2102,"and I fixed your room up upstairs."],[2122,2168,"Okay?"],[2168,2252,"God Neil,"],[2252,2381,"can you get off my back?"],[2423,2560,"I mean, seriously,"],[2585,2702,"you remember that I"],[2719,2836,"pay for everything, right?"],[2902,3107,"And you are just a useless"],[3261,3411,"stay-at-home husband."],[3591,3712,"You know, if you have this much time"],[3712,3787,"to lecture me,"],[3795,3949,"you could try being useful,"],[3978,4045,"like Simon."],[4266,4354,"Keira, if I didn't agree to"],[4354,4504,"take care of you five years ago,"],[4504,4558,"I'd still be"],[4558,4804,"a lead astrophysicist at NASX."],[5392,5434,"Hey,"],[5492,5555,"yeah, Simon,"],[5555,5668,"I am free tomorrow night."],[5718,5864,"Okay, yeah, I'll see you soon."],[6051,6131,"Tomorrow,"],[6247,6398,"both of us will be free."],[6569,6681,"Oh my gosh, yeah,"],[6681,6790,"the photo you sent of the northern lights"],[6790,6915,"was perfect."],[7144,7244,"I should have known then."],[7286,7407,"I'd never compare to Simon."],[7490,7615,"Neil where's my breakfast?"],[7657,7716,"Keira,"],[7716,7853,"yesterday was the last meal"],[7853,7970,"I'd ever cook for you."],[8024,8091,"I'm hungry."],[8254,8345,"Hello?"],[8437,8562,"Hey, are you deaf or something?"],[8646,8692,"Keira,"],[8833,8900,"let's get a divorce."]],"3":[[25,70,"Keira,"],[154,262,"let's get a divorce."],[387,475,"Whatever."],[829,909,"Where are you, honey?"],[909,1017,"I can't wait to see you."],[1209,1280,"Yeah, no no no."],[1280,1380,"I'm gonna get changed"],[1380,1476,"and I'll be right out, okay?"],[1530,1680,"Same story every time."],[1718,1793,"I talk,"],[1847,1931,"she tunes out."],[1976,2147,"Even when I'm asking for a divorce."],[2448,2489,"Do you have any idea"],[2489,2565,"what you just signed?"],[2669,2744,"Yeah, some"],[2744,2886,"form about my medical treatment?"],[2965,3086,"God, I don't know why you bother me"],[3086,3132,"with such"],[3132,3269,"unimportant things, Neil."],[3307,3370,"You know, you should be"],[3370,3457,"more like Simon."],[3499,3586,"He actually knows"],[3586,3674,"how to treat me."],[3741,3853,"And he's done more for me"],[3853,3962,"than you ever could."],[4004,4137,"Simon's done more for you than me?"],[4208,4258,"Yeah."],[4366,4450,"You know, when my mom died,"],[4450,4537,"I was a wreck."],[4592,4704,"Before my mom died,"],[4750,4813,"she told me"],[4813,4942,"she was gonna come back as a star"],[4959,5050,"to look after me."],[5063,5196,"So Simon stayed up for months"],[5196,5259,"stargazing,"],[5259,5372,"trying to find an asteroid"],[5372,5463,"to name it after her."],[5697,5822,"Simon helped me heal."],[5864,5997,"What have you done for me?"],[5997,6081,"You think Simon was the one"],[6081,6210,"who found that asteroid for you?"],[6277,6331,"Yeah!"],[6393,6485,"I mean, who else"],[6485,6602,"could have been that thoughtful?"],[6656,6735,"It was me."],[6915,7073,"Keira, I spent night after night"],[7090,7207,"looking for that asteroid for you."],[7207,7278,"I- - Hey,"],[7286,7415,"No no no, I'm- - I just"],[7432,7561,"hope that she realizes"],[7561,7624,"how much effort"],[7624,7757,"you're putting into this."],[7803,7857,"She does."],[7932,8045,"Hope she's worth all this."],[8049,8095,"She is."],[8249,8345,"You never really listen."],[8404,8516,"Not to my words,"],[8546,8654,"not to my heart."],[8771,8992,"I always knew Simon was your first love."],[9121,9188,"I knew you married me"],[9188,9330,"just to make him jealous."],[9480,9634,"Five years I tried so"],[9634,9813,"hard to make you love me."],[9847,9968,"I gave up my career,"],[10010,10197,"my dreams for you."],[10322,10535,"But all I got was the cold shoulder."],[10631,10839,"Turns out love can't be fabricated."],[12066,12128,"Dr. James?"],[12187,12228,"Neil!"],[12249,12391,"Congratulations,"],[12408,12575,"everyone here at NASX"],[12575,12758,"is blown away by your proposal."],[12800,12925,"Now, if the data holds up,"],[12946,13088,"we believe this has the"],[13113,13267,"potential to change the world."],[13288,13463,"I would feel much more confident"],[13463,13634,"if you could lead the mission."],[13701,13763,"How do you feel about"],[13763,13855,"going to Mars?"]],"4":[[83,204,"Space was always my dream."],[258,358,"When I married Keira,"],[358,525,"I shelved it for her."],[575,667,"Not anymore."],[734,788,"Count me in."],[884,971,"That's what I wanna hear."],[1017,1051,"Look,"],[1096,1209,"full transparency,"],[1322,1505,"you're gonna be off planet for a year."],[1547,1714,"No calls, no contact."],[1856,1981,"Some people crack under that."],[2056,2139,"It won't be an issue for me."],[2248,2298,"I'll see you there."],[3140,3274,"I spent the last five years"],[3274,3432,"putting my life on hold for you."],[3578,3661,"Starting today,"],[3807,3903,"I'm living for me."],[4004,4049,"Hey, David."],[4066,4245,"Look, I wanted to tell you in person."],[4291,4391,"NASX chose me to"],[4391,4496,"lead the mission to Mars."],[4562,4662,"I report to Kennedy Space Center"],[4662,4767,"next week to start training."],[4821,4975,"And Keira's recovering fine,"],[4975,5167,"so, she'll be okay without me."],[5217,5305,"A mission to Mars?"],[5313,5463,"That is amazing, Neil!"],[5513,5559,"You know,"],[5588,5655,"I always knew"],[5655,5768,"you were headed for big things."],[5772,5822,"Thanks."],[5830,5880,"Thank you."],[5893,5951,"Um."],[6097,6151,"Look,"],[6151,6302,"Keira and I are divorced."],[6352,6406,"What?"],[6527,6619,"Is this another one of"],[6619,6723,"Keira's tantrums?"],[6735,6777,"Look,"],[6873,7036,"whatever awful things"],[7094,7223,"she might have said to you,"],[7303,7386,"she didn't mean it."],[7524,7670,"It was my decision to get a divorce."],[7841,7924,"I understand."],[8049,8199,"Neil, I am sorry,"],[8199,8358,"I made you take care of Keira."],[8445,8512,"I owe you."],[8575,8616,"No."],[8650,8679,"No."],[8679,8725,"Look,"],[8792,8954,"you paid for my entire tuition to MIT."],[9159,9263,"Without you, I wouldn't be here."],[9288,9384,"So when you came to me"],[9417,9576,"after Simon broke Keira's heart,"],[9609,9718,"you asked me to marry her."],[9784,9880,"I mean, how could I say no?"],[9939,10014,"I owe you everything."],[10018,10060,"Neil,"],[10172,10318,"it may have started as a debt."],[10322,10518,"But I know you fell in love with her."],[10560,10677,"Anyone could see it."],[10706,10894,"No, it doesn't matter now."],[10990,11073,"Simon's back"],[11073,11186,"and Keira chose him."],[11223,11357,"So as far as I'm concerned,"],[11357,11486,"the contract has run its course."],[11991,12053,"It's her loss."],[12178,12358,"One day, she's going to regret"],[12412,12516,"letting you walk away."]],"5":[[542,629,"Five years,"],[688,771,"there's nothing much of"],[771,880,"my things here anyway."],[1664,1801,"Didn't we discuss this?"],[1847,1972,"I knock, you open."],[1989,2143,"Five seconds, max."],[2168,2248,"You took 30."],[2410,2531,"Now apologize for making me wait."],[2702,2873,"Hey, are you deaf or something?"],[2894,3028,"I said apologize"],[3028,3115,"or I'm gonna tell Keira"],[3115,3215,"that you're being a fucking dick"],[3215,3349,"and she won't talk to you for a week."],[3520,3703,"Oh my God."],[3712,3841,"Did you just push me?"],[3874,3974,"You know what, Neil,"],[4024,4112,"I'm gonna tell Keira"],[4112,4279,"to divorce your ass!"],[4346,4396,"Thank God"],[4396,4496,"Simon's coming and he'll show you"],[4496,4621,"how a real man acts."]],"6":[[483,558,"What's going on in here?"],[563,658,"I thought I heard some arguing."],[671,750,"Keira,"],[817,988,"Neil's being such a douche."],[996,1063,"I just showed up"],[1063,1155,"and then he started"],[1159,1338,"giving me attitude for no reason."],[1397,1501,"I mean, thank God,"],[1501,1634,"Simon's here to show him"],[1634,1793,"what a real man acts like."],[1885,2035,"Simon."],[2072,2173,"You know, you're the one"],[2173,2373,"I always wanted to get with my sister."],[2373,2419,"I mean, you're the one"],[2419,2590,"she really wanted."],[2606,2798,"She'll buy us little gifts for you."],[2806,2936,"Travels halfway across the world"],[2936,3057,"just to see you,"],[3057,3282,"and she will not shut up"],[3282,3461,"about how much she misses you."],[3524,3574,"I mean,"],[3578,3674,"just say the word,"],[3682,3820,"and she'll drop Neil like dead weight."],[3828,3983,"Beth, shut up."],[4062,4183,"Neil, don't listen to my sister."],[4183,4216,"You know,"],[4216,4341,"she doesn't mean what she says."],[4354,4416,"Yeah, Neil,"],[4416,4554,"it's nothing to get mad about."],[4567,4650,"Oh, I'm not mad."],[4879,5021,"Okay, enough small talk."],[5084,5167,"Why are we standing by the door"],[5167,5271,"like a bunch of idiots?"],[5276,5355,"Simon just moved in."],[5355,5501,"Let's show him around."],[5534,5663,"Wait, Simon's moving in?"],[5693,5805,"Yeah, he's back in town,"],[5805,5930,"looking for a new place to stay."],[5930,6051,"So I figured"],[6056,6143,"why not let him crash here"],[6143,6227,"for a few nights?"],[6281,6418,"You don't mind, do you, Neil?"],[6439,6510,"No, no."],[6510,6681,"Hey, Neil doesn't mind."],[6690,6810,"He's very accommodating."],[6810,6944,"Yeah, he's just like"],[6977,7115,"a glorified housekeeper."],[7132,7282,"What he thinks doesn't matter."],[7361,7457,"Even if I did mind,"],[7457,7624,"I doubt it would make a difference."],[7699,7853,"Keira, Neil doesn't seem"],[7853,7978,"too thrilled about this."],[8024,8074,"Don't worry,"],[8078,8229,"I'll just go back to my hotel."],[8233,8266,"No!"],[8266,8454,"No, Neil, shut up!"],[8462,8500,"Okay?"],[8500,8562,"And stop acting like"],[8562,8637,"you deserve respect."],[8646,8679,"You're the one"],[8679,8821,"who should be packing your bags."]],"7":[[0,95,"Okay, that's enough."],[141,241,"Simon is staying."],[266,346,"End of discussion."],[654,704,"What's wrong?"],[746,804,"Oh."],[863,959,"Uh, it's nothing."],[959,1105,"I just, it would be a shame"],[1105,1247,"if I walked all over your"],[1247,1376,"squeaky clean floor"],[1376,1505,"with my muddy shoes."],[1505,1651,"Simon, don't worry about"],[1651,1793,"tracking dirt all over the house."],[1805,1906,"Neil will clean it up."],[1939,2002,"Actually,"],[2035,2114,"Neil, do you mind"],[2164,2273,"cleaning Simon's shoes?"],[2435,2565,"You want me to clean his shoes?"],[2573,2660,"You should be grateful"],[2660,2769,"for even touching a man"],[2769,2869,"like his shoes."],[2961,3082,"Yeah, I'm not gonna do that."],[3094,3265,"Neil, what is going on with you?"],[3265,3345,"You're being incredibly"],[3345,3424,"rude today."],[3457,3574,"Hey, guys,"],[3632,3791,"no need to argue over me."],[3832,3974,"I'm not royalty."],[4024,4200,"I can clean my own shoes, okay?"],[4287,4325,"Look,"],[4375,4512,"I'm heading out for some tennis."],[4525,4571,"Keira,"],[4583,4700,"I'm going to our old spot."],[4700,4754,"Remember?"],[4754,4871,"Cheyenne Park? - Cheyenne Park!"],[4888,4959,"Oh."],[5030,5096,"Oh my gosh."],[5130,5271,"Wait, Beth, Neil, we should go."],[5271,5326,"It'd be great"],[5326,5417,"to get some exercise in."],[5472,5551,"You guys go ahead."],[5626,5768,"I don't even own any tennis shoes."],[5805,5893,"Seriously?"],[5960,6006,"Man,"],[6035,6189,"now I almost feel guilty."],[6231,6381,"Keira, you should really get him"],[6381,6456,"some things."],[6481,6552,"People are gonna think"],[6552,6790,"the Thorne family's gone cheap."],[6798,6890,"Oh, it's not like"],[6890,7027,"I haven't gotten him anything."],[7219,7294,"Neil, what happened to"],[7294,7415,"all that money I gave you?"],[7574,7691,"Your sister took it all"],[7741,7857,"and blew it on handbags"],[7857,7974,"and trips to Ibiza."],[8083,8128,"Whatever."],[8128,8199,"Let's just go already."],[8400,8521,"Neil, if you don't have decent shoes,"],[8521,8600,"I can have Dad's assistant"],[8600,8692,"drop you off something."],[8779,9017,"Now, come on, let's go get ready."]],"8":[[175,342,"So the form is all there."],[346,387,"Mhm."],[392,513,"You've just gotta put a little"],[529,625,"fire into it."],[658,930,"Why am l even here watching all this?"],[1209,1263,"Now you're gonna go down and"],[1263,1313,"you're just gonna hit it."],[1401,1459,"Just like that."],[1459,1518,"Oh my God. - Guess I am"],[1518,1626,"just getting used to"],[1626,1797,"saying yes to whatever she wants."],[1818,1985,"You're up there in the stands,"],[2027,2077,"watching me"],[2077,2227,"win every game, obviously."],[2260,2360,"It's okay,"],[2360,2481,"I'm leaving in seven days."],[2540,2644,"This is the last time."],[2644,2756,"And you kissed me."],[2802,3003,"Not bad for a first kiss story, huh?"],[3011,3078,"Yeah."],[3199,3240,"Oh."],[3532,3591,"I..."],[3624,3720,"I shouldn't have said that."],[3741,3837,"You understand, right? I..."],[3953,4079,"Uh, Neil, that doesn't actually"],[4079,4170,"bother you, right?"],[4175,4291,"That was a long time ago."],[4295,4346,"I mean, kind of."],[4346,4458,"Not that long ago, but-"],[4458,4604,"Well, maybe Simon could make it up"],[4604,4721,"to you by helping you"],[4721,4792,"work on your swing?"],[4792,4833,"Yeah."],[4833,4913,"I know, I know your form"],[4913,5013,"could use work."],[5196,5259,"Oh Keira, watch out!"],[5317,5355,"Woah."],[5822,5851,"Oh!"],[5897,5930,"Neil?"],[5947,5997,"Aw."],[6014,6085,"Neil?"],[6106,6168,"Hey, are you okay?"],[6168,6264,"Should we go to the hospital?"]],"9":[[37,112,"Ow!"],[175,237,"Ah!"],[266,316,"Oh!"],[333,404,"Oh shit!"],[437,517,"Oh my God!"],[517,625,"Simon sprained his wrist."],[629,746,"This time it looks serious."],[746,817,"Are you okay?"],[817,905,"I'll be fine, Keira."],[942,1063,"I was just minding my business"],[1063,1180,"when Neil shoved me"],[1180,1292,"and I landed on my wrist."],[1401,1514,"It could have been way worse."],[1589,1626,"Neil,"],[1626,1801,"what the hell is wrong with you?"],[1843,1947,"It's one thing not to like Simon,"],[1947,2056,"but to hurt him on purpose?"],[2056,2173,"That's just evil!"],[2306,2427,"Keira, we gotta get him to the hospital."],[2427,2473,"If we waits,"],[2473,2581,"he won't hold up a racket again."],[2581,2702,"Wait, you think I did this?"],[2756,2786,"He was the one-"],[2786,2861,"We all saw you knock"],[2861,2961,"him down, Neil!"],[2986,3128,"His hand looks really bad."],[3140,3244,"I'm gonna take him to the ER,"],[3244,3365,"and you better hope it's just a sprain."],[3386,3536,"And if your back hurts that bad,"],[3536,3691,"just call yourself an Uber."],[3757,3870,"Come on, Simon, can you get up?"],[3899,3958,"Yeah, I'll be okay."],[4183,4254,"Good job."],[4371,4450,"There's only room"],[4450,4579,"for one man in her heart,"],[4637,4796,"and it's always been Simon."]],"10":[[287,446,"This patient's got it good, I'll tell ya."],[496,658,"He gets a tiny scrape on his wrist,"],[663,725,"and his girlfriend"],[725,850,"books out the entire ward"],[863,925,"just to give him"],[925,1013,"some peace and quiet."],[1109,1201,"She's one in a million,"],[1230,1301,"hot, rich,"],[1301,1430,"and treats him like a king."],[1659,1810,"Just be careful in the shower, okay?"],[1810,1876,"The doctor said"],[1876,1993,"it might increase your swelling."],[2181,2252,"You abandoned"],[2252,2348,"your injured husband"],[2348,2460,"so you couldn't nurse your old"],[2460,2623,"flame's little wrist scratch."],[2711,2752,"Neil?"],[2781,2857,"Hey, I was just"],[2857,2952,"coming to check on you."],[3119,3219,"Sure you were."],[3332,3374,"Look, the maid said"],[3374,3499,"you didn't come home last night."],[3553,3624,"Is it because of"],[3624,3724,"what happened with Simon?"],[3749,3778,"You know,"],[3778,3891,"you can't just go and hide"],[3891,4004,"when things don't go your way."],[4029,4091,"I don't understand"],[4091,4220,"what you're so mad about anyway."],[4270,4391,"We wouldn't even be in the hospital"],[4391,4512,"if you hadn't knocked him down."],[4529,4629,"I got hurt too you know."],[4713,4771,"Are you trying to"],[4771,4854,"guilt trip me right now?"],[5046,5125,"You know, a real man"],[5125,5246,"wouldn't be this petty about it."],[5505,5601,"Keira, do you love me?"],[5885,5964,"Neil, you're my husband."],[5964,6056,"I wouldn't have married you"],[6056,6122,"if I didn't love you."],[6122,6214,"Then tell me you love me."],[6293,6468,"Jesus Neil, we're in public."],[6639,6723,"You know why you can't say it?"],[6815,6881,"Because you don't."],[7444,7494,"Keira,"],[7494,7590,"can you help me on my towel?"],[7607,7699,"My wrist is hurting."],[7874,8037,"You want me to?"]],"11":[[33,216,"Okay, I see what's going on here."],[291,412,"You help him go shower, huh?"],[583,696,"I thought you'd at least remember"],[696,792,"you have a husband."],[846,946,"That I existed."],[988,1059,"Neil, I-"],[1080,1234,"No no, it's fine, honestly."],[1309,1351,"Come on."],[1422,1530,"Don't keep the man waiting."],[1568,1626,"Neil,"],[1710,1835,"don't take it the wrong way."],[1947,2097,"We grew up skinny dipping together"],[2097,2210,"in the ocean all the time."],[2248,2364,"He's like a brother to me."],[2506,2569,"Don't be mad."],[2961,3128,"Oh, my darling, Frank."],[3169,3282,"What in the world would I do"],[3282,3370,"without you?"],[3478,3566,"I used to believe"],[3566,3687,"if I did everything right,"],[3762,3912,"you'd eventually follow up with me."],[4070,4141,"Now I know,"],[4191,4287,"that'll never happen."],[4992,5067,"Neil,"],[5067,5246,"it's James, listen,"],[5246,5455,"we've got just 10 days till lift off"],[5455,5638,"and we need you at the space center"],[5638,5793,"for training ASAP."],[5818,5897,"Got it?"],[5897,5972,"Yes sir."],[6035,6110,"I'll be right there."],[6110,6218,"Amazing."],[6218,6356,"Oh uh,"],[6356,6464,"did you tell your wife you'll be"],[6464,6660,"out of contact for a year?"],[6723,6844,"How'd she take it?"],[6927,7011,"I'm divorced."],[7144,7215,"Divorced?"],[7344,7428,"Neil, what the hell are you"],[7428,7515,"talking about?"]],"12":[[0,87,"How did we get divorced"],[87,158,"without me knowing?"],[158,233,"Are you serious?"],[258,379,"You signed the papers yourself."],[408,429,"What?"],[429,500,"No, I didn't."],[500,675,"When would I have signed the papers?"],[746,813,"Oh, gosh."],[950,1038,"I hope I'm not the reason"],[1038,1142,"you guys are fighting."],[1180,1267,"I, I'm so sorry."],[1267,1363,"I didn't mean to cause trouble."],[1459,1568,"Oh, hey."],[1622,1668,"The doctor said"],[1668,1805,"you really can't move your wrist."],[1810,1922,"Let's get you back into bed."],[1989,2027,"Neil,"],[2056,2160,"anything that happened"],[2160,2223,"between us,"],[2223,2306,"it's nothing."],[2327,2389,"We used to shower"],[2389,2485,"all the time as kids."],[2485,2531,"Okay?"],[2531,2656,"It's nothing sexual."],[2690,2731,"Cool."],[2811,2877,"Great."],[3278,3361,"I will say,"],[3420,3607,"your wife does have a banging bod."],[3661,3716,"And her ass"],[3716,3899,"fits perfectly in my hand."],[4133,4241,"What the hell is wrong with you?"],[4241,4366,"Was injuring his hand not enough?"],[4558,4617,"Hey,"],[4667,4738,"come on."],[5392,5588,"This is it, Keira."]],"13":[[0,162,"It's time to live for myself."],[583,642,"Welcome back."],[1038,1092,"Ah,"],[1180,1263,"here he is,"],[1297,1393,"man of the hour."],[1438,1480,"Tim,"],[1501,1584,"this is our fearless"],[1593,1701,"and brilliant leader,"],[1705,1818,"Dr. Neil Wade."],[1847,1972,"He's the lead astronaut"],[1972,2173,"in our Tecton 7 mission to Mars."],[2193,2306,"He's gonna be joining us"],[2306,2448,"as we begin training."],[2477,2673,"He's also going to be overseeing"],[2694,2836,"preparation procedures"],[2869,3011,"right before liftoff."],[3115,3194,"Can't wait, sir."],[3224,3286,"All right, let's go."],[4679,4763,"Well done, Neil."],[4817,4909,"Your fitness level"],[4909,5013,"and technical knowledge"],[5013,5113,"already rivaled the"],[5130,5309,"best astronauts in the country."],[5347,5434,"You passed your training"],[5434,5547,"with flying colors."],[5547,5789,"So uh, it's set in stone then."],[5805,5847,"You"],[5910,6185,"will be flying to Mars in a week."],[6210,6310,"Sounds good to me, sir."],[6356,6443,"Oh, uh,"],[6523,6706,"since it's Christmas in a few days,"],[6706,6794,"we'll probably let you"],[6831,7011,"spend the next few days on earth"],[7011,7152,"with your families."],[7178,7390,"So here you go."],[7599,7703,"Happy holidays."],[7745,7866,"Happy holidays, James."],[9159,9317,"34 missed calls from Keira?"],[9405,9471,"What does she want?"],[9768,9813,"Neil?"],[9884,10022,"Why the fuck have you not picked up?"],[10072,10168,"Keira's losing her mind"],[10168,10231,"trying to find you."],[10231,10276,"I mean, like,"],[10301,10452,"literally losing her mind."],[10789,10890,"Keira's looking for me?"]],"14":[[442,504,"My God,"],[504,679,"Neil, you're finally home."],[679,746,"What's the matter, Keira?"],[779,884,"You have no idea"],[884,988,"what I have been through."],[1013,1142,"I have had three maids come in,"],[1142,1280,"and they're completely useless."],[1280,1418,"And don't even get me started"],[1418,1526,"on the chefs, Neil."],[1555,1622,"They don't understand"],[1622,1730,"my dietary restrictions."],[1739,1818,"Everything they make"],[1818,2002,"is just disgusting and inedible."],[2002,2164,"And I've had a fire like ten of them"],[2164,2239,"since you left."],[2248,2452,"Oh, so that's all it was."],[2494,2635,"She just couldn't find good help"],[2635,2740,"to replace me with."],[2927,3061,"Oh, where have you been"],[3061,3186,"the last few days?"],[3261,3411,"I've been at work, Keira."],[3445,3536,"Okay, look,"],[3541,3670,"you really need to quit your job"],[3670,3799,"as this research assistant."],[3849,3974,"They pay you like nothing."],[3974,4037,"And if you quit,"],[4037,4200,"you can spend more time with me."],[4233,4362,"Nothing's changed, Keira."],[4421,4567,"It's still all about what you want."],[4596,4671,"And if you're asking me"],[4671,4788,"to give up my dream,"],[4817,4959,"a chance to explore another planet,"],[4967,5046,"all just to keep being"],[5046,5163,"your personal servant,"],[5234,5376,"well, I won't make"],[5376,5488,"the same mistake again."]],"15":[[367,467,"Look, Neil, I'm really hungry."],[467,533,"Can you please"],[533,638,"just go make some dinner?"],[675,804,"We're divorced, Keira."],[821,905,"I'm not gonna cook you dinner."],[909,1026,"Okay, stop saying that."],[1026,1126,"I know you're just saying that"],[1126,1201,"to scare me."],[1338,1422,"Look, I know"],[1476,1559,"what this is about."],[1601,1764,"You're mad about Simon,"],[1764,1889,"you're rattling off some stuff"],[1889,1964,"about divorce,"],[1964,2052,"and now you don't even wanna"],[2052,2131,"cook for me."],[2173,2210,"Look,"],[2252,2348,"what happened with Simon"],[2348,2469,"was just a one-time thing,"],[2473,2519,"Neil."],[2665,2827,"I only put his towel on for him"],[2827,2919,"because he's my friend."],[2919,3132,"It was a platonic favor for a friend."],[3153,3207,"You and Simon"],[3207,3319,"can do whatever you want."],[3370,3470,"I don't care anymore."],[3478,3545,"Neil, he doesn't even"],[3545,3641,"live here anymore."],[3645,3745,"Can you just get over it?"],[3887,3933,"You know what?"],[4295,4366,"What's this?"],[4371,4429,"A gift."],[4483,4600,"I know you're mad about Simon,"],[4600,4704,"so I got you this"],[4704,4838,"to hopefully patch things up."],[4871,5013,"Merry Christmas, my love."]],"16":[[554,608,"A yacht?"],[633,688,"Yeah."],[696,771,"Yeah, you've always said"],[771,875,"you wanna sail around the world."],[875,955,"And I thought we could take it"],[955,1121,"to Hawaii next summer."],[1463,1593,"Keira, I can't accept those."],[1739,1776,"Why?"],[1935,2127,"Listen, all I'm saying is"],[2127,2239,"I think you should move back in"],[2239,2306,"with Keira."],[2335,2402,"I mean, think about"],[2402,2544,"how lonely she'll be on Christmas"],[2544,2598,"if you're not there"],[2598,2698,"to celebrate with her."],[2723,2819,"Oh my God!"],[2840,2882,"Simon,"],[2882,2998,"weren't you just talking about"],[2998,3061,"how much you love"],[3061,3194,"those WaveSpeeder yachts?"],[3253,3374,"Looks like Keira got you one"],[3374,3470,"for Christmas!"],[3495,3528,"Keira,"],[3532,3645,"you really went all out this year?"],[3645,3737,"You got me a yacht?"],[3782,3874,"Keira loves"],[3874,4008,"to splurge on gifts for you."],[4029,4200,"Beth, are we sure it's not for Neil?"],[4208,4275,"What?"],[4291,4391,"Are you kidding?"],[4429,4479,"They've been together"],[4479,4587,"for like five years,"],[4587,4692,"and she's never even bothered"],[4692,4808,"to fill his stocking,"],[4808,4963,"let alone get him a Christmas gift."],[5025,5080,"Right, Keira?"]],"17":[[33,162,"A Christmas gift for me."],[216,346,"But five years too late."],[379,529,"I don't want your gifts anymore."],[621,704,"Yeah, Beth."],[750,942,"I think that Keira got this for Simon."],[950,1046,"So, Simon,"],[1234,1313,"there you are."],[1526,1559,"Keira,"],[1559,1655,"this is already"],[1655,1801,"the best Christmas ever."],[1826,1897,"Thank you."],[1989,2064,"You're a good guy, Neil."],[2314,2364,"Neil."],[2410,2431,"Keira,"],[2431,2556,"I already know what we'll name it."],[2606,2736,"Violet Horizons."],[2756,2836,"Remember the restaurant"],[2836,2969,"we went to on our first date?"],[3057,3111,"Keira,"],[3186,3286,"after Christmas,"],[3445,3603,"I'll be out of your world for good."]],"18":[[254,308,"Hey."],[412,529,"Uh, tonight's my family's"],[529,667,"annual Christmas party."],[717,875,"I got this suit tailored just for you."],[1013,1222,"It's a Thorne family party."],[1272,1351,"It's your family,"],[1418,1493,"not mine."],[1559,1655,"What are you talking about?"],[1655,1726,"You're my husband."],[1843,1897,"Plus, you know,"],[1897,2047,"my dad put you on the list himself,"],[2047,2189,"so it'd be rude to be a no-show."],[2281,2377,"I should give David"],[2377,2464,"a proper goodbye."],[2619,2727,"It's Christmas after all."],[3974,4091,"My, my, Simon."],[4099,4208,"Those WaveSpeeder yachts"],[4208,4383,"are worth 200 million."],[4408,4642,"Keira must really love you."],[4658,4813,"Yeah, that's a given."],[4838,4925,"Keira loves Simon"],[4925,5009,"more than any woman"],[5009,5105,"has ever loved a man."],[5117,5201,"All right, come on Beth."],[5205,5338,"Let's not joke about that anymore."],[5405,5559,"Keira's still married to Neil."],[5864,6014,"Don't worry about them, bud."],[6018,6118,"We were just talking about how"],[6118,6235,"sometimes marriage and love"],[6235,6381,"don't always go hand-in-hand."],[6410,6473,"Oh, you guys"],[6473,6594,"talk about whatever you want."],[6619,6731,"Pretend I'm not here."],[7132,7261,"Speaking of which, Simon."],[7332,7449,"You're the one Keira loves,"],[7469,7520,"not me."],[7578,7678,"You should be with her."]],"19":[[45,166,"Look at yourself, Neil."],[212,354,"Sulking like a child,"],[354,429,"hoping that Keira"],[429,567,"feels sorry for you."],[617,700,"A real man"],[721,842,"would try to measure up to Simon,"],[855,917,"okay?"],[917,996,"He wouldn't be throwing himself"],[996,1096,"a little pity party,"],[1101,1213,"trying to manipulate his wife"],[1213,1301,"into staying."],[1338,1459,"Oh, I'm not manipulating her."],[1555,1651,"Keira and I are separated."],[1701,1856,"Yeah, as if you'd ever"],[1856,2022,"have the balls to leave Keira."],[2056,2160,"You should feel grateful"],[2160,2264,"that she ever said yes"],[2264,2502,"to a dirt-poor, orphaned, loser,"],[2519,2619,"like you."],[2640,2752,"Especially when Simon"],[2752,2894,"has you beat in every category."],[2965,3169,"Family background, net worth,"],[3199,3382,"good looks, you name it."],[3445,3607,"Beth, just put a lid on it."],[3666,3741,"It's Christmas,"],[3741,3891,"can you just try to be civil?"],[3978,4254,"Beth is just speaking facts, Keira."],[4291,4375,"I mean,"],[4375,4583,"we all saw you and Simon"],[4583,4713,"during college."],[4738,4988,"You guys were so cute together."],[5046,5134,"I was with Keira"],[5134,5296,"on the day you broke up with her,"],[5317,5576,"she was absolutely crushed."],[5647,5826,"I don't think I've ever seen someone"],[5826,5947,"cry so hard in my life."],[5947,6126,"Well, college was a lifetime ago."],[6189,6268,"What happened then"],[6268,6368,"doesn't even matter now."],[6410,6456,"Keira,"],[6506,6719,"I'm trying to help you out here."],[6773,6831,"I mean, sure,"],[6840,7073,"Simon was gone for a while,"],[7090,7248,"but he's back now."],[7286,7390,"You don't have to hide"],[7390,7503,"how you feel anymore."],[7528,7603,"Exactly."],[7645,7803,"Keira, we all know how long"],[7803,7941,"you've been waiting for this."],[7945,8003,"Do you remember how"],[8003,8087,"devastated you were"],[8087,8141,"when you found out that"],[8141,8270,"Simon had a new girlfriend?"],[8391,8470,"Simon,"],[8533,8725,"she has made it crystal clear"],[8725,8833,"that she wants you."],[8879,8971,"Now that you're back,"],[9050,9163,"it's time to make a move."],[9213,9376,"Ask her out on a date!"],[9638,9713,"Let's have a drink."],[9747,9805,"All right."],[9947,10005,"Cheers."],[10543,10643,"Uh, um."],[10785,10852,"Look, Neil,"],[10852,11048,"that was just Beth and Alice"],[11048,11156,"trying to get a rise out of me."],[11173,11232,"Please,"],[11336,11461,"please don't be mad."],[11590,11699,"I'm not mad, Keira."],[11807,11886,"Keira, every time"],[11886,12041,"they humiliated me in the past,"],[12082,12241,"you never once came to my defense."],[12333,12445,"Was it because deep down,"],[12445,12533,"you agreed with them?"],[12591,12687,"Look, Keira, be honest,"],[12800,12904,"you've never taken me seriously"],[12904,12975,"as a husband."],[13067,13175,"You've never seen me as an equal."],[13329,13392,"But, Neil..."]],"20":[[137,212,"But, Neil..."],[429,542,"No, Neil, listen, I-"],[859,963,"Merry Christmas, old friend."],[1088,1201,"Oh thank you, Neil."],[1222,1272,"Yeah."],[1322,1468,"So you're really"],[1514,1601,"planning to end things"],[1601,1680,"with Keira, then?"],[1889,1935,"Yeah."],[1968,2056,"I think it's time to"],[2056,2181,"start focusing on the future."],[2273,2439,"This is the best for both of us."],[2464,2573,"You know, I don't blame you."],[2573,2727,"She's a handful to put up with."],[2798,2840,"Well,"],[2886,3011,"put me through college."],[3078,3219,"It's a fair trade if you ask me."],[3866,4024,"Don't be ridiculous, Neil."],[4049,4212,"All I did was pay your tuition."],[4245,4337,"You sacrificed"],[4337,4525,"five years of your life."],[4587,4658,"Not only that,"],[4667,4758,"you went above and beyond"],[4758,4917,"the terms of the contract."],[4942,5100,"You loved Keira with"],[5113,5205,"all of your heart."],[5255,5417,"I hoped that with time,"],[5438,5643,"she would see your devotion."],[5676,5751,"Regardless."],[5843,5901,"Neil,"],[5960,6081,"you're my son,"],[6156,6210,"forever."],[6506,6539,"Yeah."],[7207,7269,"No."],[7290,7374,"Come on. - No."],[7720,7874,"You know, Simon got one thing right,"],[7991,8074,"sometimes love and marriage"],[8074,8208,"don't always go hand-in-hand."],[8429,8546,"I did love Keira."],[8658,8746,"I cared for her."],[9125,9238,"But she didn't feel the same way."],[9492,9584,"That's all there is to it."]],"21":[[262,325,"And listen,"],[325,471,"I have one more favor to ask you."],[563,608,"Tell me."],[658,709,"Anything."],[734,792,"Well, as you know,"],[792,925,"I'm heading to Mars soon."],[996,1046,"And um,"],[1180,1326,"I don't want Keira to know where I am,"],[1418,1518,"and I don't want her to know"],[1518,1618,"about the contract."],[1735,1843,"Could you keep those two secrets"],[1843,1939,"for me, please?"],[1951,1989,"Neil,"],[1997,2223,"you haven't told Keira about Mars?"],[2235,2348,"Nor the contract?"],[2381,2548,"We were together for five years."],[2590,2652,"I don't want her to know that"],[2652,2740,"every moment of that was"],[2744,2840,"because of some contract"],[2840,2907,"with her dad."],[2907,2973,"I mean,"],[3011,3111,"I can't do that to her."],[3282,3436,"Look, I gotta get going soon, so,"],[3566,3636,"this will be the last time"],[3636,3691,"you see me."],[3874,3933,"Yeah."],[4120,4208,"Neil, you're leaving?"]],"22":[[150,246,"Neil, I swear,"],[246,442,"something is off with you today."],[513,604,"Look, if you're leaving,"],[604,717,"I mean, that's fine,"],[717,821,"but can you at least tell me"],[821,900,"where you're going?"],[930,1088,"Uh, honey, a representative"],[1088,1205,"from the Atlas Group"],[1213,1363,"is delivering a Christmas present"],[1363,1472,"to the office later."],[1522,1626,"Neil's heading over"],[1626,1768,"to receive it on my behalf."],[1805,1864,"Oh."],[2064,2118,"Okay."],[2152,2223,"That's a relief."],[2302,2381,"Oh Dad,"],[2381,2506,"do you wanna come cut the turkey?"],[2556,2665,"The party's waiting on you"],[2665,2781,"and everyone is starving."],[2819,2907,"Honey, I think"],[2907,3073,"I had a little bit too much to drink."],[3082,3253,"I need to go lay down for a bit."],[3307,3474,"You take care of it for me, okay?"],[3553,3720,"Yeah, of course."],[3812,3870,"Thank you."],[4366,4416,"You wanna,"],[4446,4604,"come cut a turkey with me?"],[4717,4867,"I don't think that's a good idea."],[4967,5100,"Your friends have made it quite clear"],[5100,5205,"I'm not welcome here."],[5351,5472,"So I think you and Simon"],[5472,5576,"should go cut the turkey."],[5626,5701,"Because I think"],[5701,5839,"that's what you really want."],[5880,5976,"Cutting the turkey"],[5976,6147,"is a family tradition, Neil."],[6147,6285,"Why would I do that with Simon?"],[6427,6573,"Oh, I get it."],[6740,6856,"You're still jealous,"],[6881,6927,"aren't you?"],[7102,7223,"Neil, I promise"],[7303,7436,"to never do that again."],[7436,7582,"I'm gonna put you first."],[7636,7736,"I'm gonna treat you the way"],[7736,7882,"a wife should treat her husband."],[7899,7978,"Oh Keira,"],[8099,8191,"we're past the point of"],[8191,8291,"empty promises."]],"23":[[129,241,"I'm not jealous, Keira."],[358,467,"I just think somebody else"],[467,571,"should cut the turkey, okay?"],[767,825,"Alright."],[975,1038,"Um."],[1067,1222,"Well, I'll, I'll go cut the turkey,"],[1222,1309,"grab a quick bite,"],[1309,1401,"and then we can head home."],[1488,1543,"Yeah, just"],[1626,1768,"meet me back here in 30 minutes."],[1926,1960,"Okay?"],[2544,2798,"Ah, they're so cute together."],[2819,2957,"That's what a real couple"],[2957,3073,"looks like right there."],[3465,3636,"Um, Neil,"],[3720,3803,"I was gonna take a photo of them,"],[3803,3874,"but my phone died."],[3878,3941,"Can you take it?"],[4012,4166,"Beth, it's fine, just use mine."],[4204,4283,"Yeah, Beth."],[4283,4358,"You shouldn't ask a man"],[4358,4487,"to take a picture of his wife"],[4487,4583,"and another man."],[4738,4779,"No."],[4846,4917,"No, it's fine."],[4988,5059,"I'll do it."],[5438,5547,"Oh my God,"],[5547,5747,"you guys look perfect together."],[5764,5914,"Just date already."],[5960,6548,"Date! Date! Date!"],[6556,6623,"Come on,"],[6635,6886,"let's see a kiss for the camera."],[6894,7561,"Kiss! Kiss!"],[7670,7745,"Awww."],[7878,8133,"Merry Christmas!"],[8370,8500,"Awww."],[8537,8812,"Merry Christmas!"]],"24":[[208,258,"Morning!"],[271,329,"Morning."],[371,454,"Made your favorite."],[487,558,"Pancakes!"],[1021,1126,"Don't worry, love."],[1163,1309,"You'll be better by morning."],[2686,2752,"Oh Simon."],[2998,3107,"Aww."],[3107,3286,"Merry Christmas!"],[3745,3787,"Keira,"],[3791,3933,"every time I tried to kiss you,"],[3933,4024,"you pulled away."],[4041,4124,"But with Simon,"],[4145,4258,"it's like second nature."]],"25":[[187,229,"Oh!"],[542,617,"You guys."],[663,788,"This is so cute!"],[788,959,"You have to put it on Instagram."],[1001,1088,"It's just a photo,"],[1134,1247,"doesn't mean anything."],[1272,1330,"Fine!"],[1372,1422,"I didn't realize"],[1422,1514,"there was a time limit"],[1514,1609,"for looking at a photo,"],[1609,1735,"Mr. Party Pooper."],[1739,1876,"Beth, give it a rest."],[1922,2047,"Give what a rest?"],[2052,2227,"He's the one who's acting bitter."],[2277,2414,"I guess Neil's just butt hurt"],[2414,2498,"because he realized"],[2498,2648,"if Simon hadn't gone back to Europe"],[2648,2740,"all those years ago,"],[2773,2919,"she would have married him instead."],[2944,3032,"I mean,"],[3094,3194,"what the hell did you think"],[3194,3278,"this all was?"],[3311,3386,"You're just Keira's"],[3386,3586,"fucking emotional support animal"],[3603,3682,"that she adopted"],[3682,3807,"when she was feeling down."],[3841,3945,"Beth, shut the fuck up!"],[3978,4154,"No lies detected, Beth."],[4212,4450,"Neil is a grimy, outcast orphan"],[4450,4604,"that nobody wants."],[4642,4771,"I mean, he was probably"],[4771,4992,"a fucking bum until Keira let him in."],[5067,5209,"Now that Simon's back,"],[5242,5334,"it's time for Neil"],[5334,5442,"to take his rightful place"],[5442,5534,"on the streets"],[5547,5651,"and stop tainting"],[5651,5751,"the Thorne family name."]],"26":[[16,145,"Oh my God, Neil!"],[316,375,"Neil!"],[513,675,"Hey, are you okay?"],[788,850,"Okay, we gotta get you"],[850,950,"to a hospital right now."],[955,1059,"What is wrong with you?"],[1063,1201,"Why do you keep messing with Neil?"],[1213,1247,"Oh."],[1259,1388,"Don't put this on us."],[1409,1576,"We were just having a little fun."],[1655,1776,"I didn't know he was gonna fall"],[1776,1839,"and injure himself"],[1839,1956,"like a little bitch."],[1968,2102,"Yeah, don't fall for this"],[2102,2264,"fucking creep's act, Keira."],[2264,2344,"I mean, he's probably just"],[2344,2414,"pretending to be hurt"],[2414,2527,"to gain your sympathy."],[2573,2677,"Okay, come on."],[2677,2752,"Can you sit up?"],[3044,3178,"Ow, oh!"],[3228,3307,"Ow."],[3411,3511,"Oh, it hurts."],[3570,3624,"Ow!"],[3624,3699,"Simon,"],[3699,3803,"what happened?"],[3820,3987,"My tennis elbow is acting up."],[4054,4179,"It's been bothering me for years."],[4220,4316,"Oh my God, Keira,"],[4325,4408,"get over here."],[4416,4529,"Simon is in serious pain."],[4554,4713,"Ah but, but Neil."],[4733,4896,"Neil just has a few scratches, okay?"],[4896,4979,"He'll be fine."],[5034,5075,"Simon,"],[5075,5196,"he might have to go to the hospital."],[5251,5309,"Ah!"],[5372,5430,"Oh!"],[5451,5509,"Ah!"],[5659,5718,"Oh!"],[5747,5818,"Come on, Keira."],[5876,5960,"Simon needs you."],[5989,6056,"Check on him."]],"27":[[45,104,"Oh!"],[129,300,"Look, we both know how this goes."],[367,513,"Simon's tennis elbow flares up"],[513,617,"when you go right to him."],[625,688,"But Neil, I-"],[688,792,"No no no, Beth's right."],[871,1001,"Just a few cuts, it's nothing."],[1088,1238,"You never hesitate to go right to him,"],[1276,1355,"so why wait now?"],[1359,1418,"Look, that last time"],[1418,1518,"shouldn't have happened, okay?"],[1518,1576,"I should have stayed"],[1576,1655,"with you. - Keira, just,"],[1780,1872,"just do whatever you want."],[1914,1964,"Okay?"],[2143,2310,"Keira, get over here now!"],[2460,2510,"Uh."],[2515,2665,"Okay, just hang tight, okay?"],[2665,2781,"I'm gonna take him to the hospital."],[2781,2840,"I'll come back"],[2840,2932,"and I'll get you patched up."],[3023,3103,"Hey, come on."],[3140,3203,"Can you get up?"],[4141,4254,"Neil, I promise"],[4346,4471,"to never do that again."],[4471,4604,"I'm gonna put you first."],[4671,4771,"I'm gonna treat you the way"],[4771,4909,"a wife should treat her husband."],[5017,5117,"Like I said,"],[5205,5359,"we're past empty promises."],[5367,5442,"You see that, Neil?"],[5509,5739,"Keira doesn't give a shit about you."],[5814,5918,"Okay, you're bleeding"],[5918,6001,"from your forehead"],[6039,6160,"and she still chose Simon."],[6218,6264,"Neil,"],[6302,6443,"there's nothing a woman hates more"],[6443,6569,"than a man who doesn't know"],[6569,6723,"when he's overstayed his welcome."],[6765,6890,"Don't you think it's about time"],[6890,7007,"you stop moping around"],[7007,7107,"and get a divorce?"],[7240,7290,"Divorce?"],[7482,7582,"We are divorced."]],"28":[[692,804,"Keira got these painkillers"],[804,867,"from Walgreens"],[867,988,"and told me to bring them to you."],[1026,1059,"I don't know"],[1059,1163,"what the hell's gotten into her."],[1226,1355,"I mean, Simon was getting a shot"],[1355,1426,"in his elbow"],[1426,1547,"and she just ran right out."],[1601,1768,"But whatever,"],[1818,1885,"here you go."],[1931,1985,"I don't need them."],[2302,2410,"What's that all about?"],[2456,2569,"Pulling a disappearing act"],[2569,2652,"in hopes that Keira"],[2652,2773,"actually starts missing you?"],[2781,2948,"I told you, we got a divorce."],[3023,3090,"Why would I stay"],[3090,3194,"at my ex-wife's house?"],[3203,3274,"You don't actually expect me"],[3274,3390,"to buy that, do you?"],[3461,3574,"You follow Keira around"],[3574,3682,"like a lost puppy."],[3695,3849,"You wouldn't just up and divorce her."],[3866,3945,"Now,"],[3966,4112,"this is your pathetic attempt"],[4112,4287,"at pulling back her attention"],[4287,4421,"because Simon's come home."],[4446,4550,"Look, if you don't believe me,"],[4554,4692,"the divorce paper's right over there."],[4704,4796,"Take a look for yourself."],[5451,5538,"Jesus Christ,"],[5538,5630,"you're actually leaving."],[5672,5780,"Okay, fine."],[5780,5855,"When are you coming back?"],[6147,6189,"I'm not."],[6356,6460,"The man you're looking at,"],[6569,6715,"he isn't Keira's husband anymore."],[6823,6906,"He's Neil Wade,"],[6998,7144,"world-class astrophysicist."],[7328,7490,"And he's about to chase his dreams."]],"29":[[1401,1509,"Choosing to be with Keira"],[1509,1651,"meant leaving my dreams behind."],[1755,1889,"I closed the door on my future."],[2031,2081,"Think about it."],[4371,4412,"Hey, honey."],[4462,4546,"Happy anniversary."],[4662,4725,"I got this for you."],[4767,4917,"Oh, uh."],[4959,5059,"You know, honestly, I forgot that"],[5059,5163,"it was our anniversary."],[5267,5372,"I'll get you something next year."],[5555,5701,"I did everything in my power"],[5701,5818,"to make Keira happy,"],[5947,6081,"And all I got in return"],[6081,6260,"was hostility and abuse."],[6452,6569,"I'm tired of being treated"],[6569,6660,"like a pushover."],[6802,6915,"enough is enough."],[7574,7653,"Goodbye, Keira."],[7791,7899,"This time, it's forever."]],"30":[[33,75,"Neil?"],[379,471,"Neil, I'm home!"],[567,617,"Neil?"],[934,1071,"Can you start the bath for me?"],[1142,1242,"And don't forget the two cups"],[1242,1368,"of the pink Himalayan salt."],[1689,1735,"Neil!"],[2027,2210,"Fuck, he must be out getting groceries."],[2544,2686,"Hi, you've reached Neil."],[2702,2848,"I'm probably out and about right now,"],[2861,2957,"but I'll give you a call back"],[2957,3078,"as soon as I get the chance."],[3107,3190,"And always remember,"],[3232,3336,"shoot for the stars."],[3753,3883,"Hi, you've reached Neil."],[3912,4058,"I'm probably out and about right now."],[4058,4149,"Neil, what the fuck?"],[4149,4304,"You never not pick up when I call."],[4717,4771,"Neil,"],[4792,5000,"I've told you a thousand times,"],[5005,5159,"there is nothing going on"],[5159,5251,"between me and Simon."],[5251,5409,"So you have no legitimate reason"],[5409,5576,"not to be picking up when I call you."],[5643,5718,"But you know what?"],[5718,5868,"If you wanna keep acting like a child,"],[5901,5980,"that's fine with me."],[5980,6093,"I have no room in my life"],[6093,6243,"for a jealous and insecure man."],[6281,6335,"Don't come home"],[6335,6410,"unless you're planning on"],[6410,6523,"begging me to take you back."],[6669,6748,"God, what an idiot."],[7148,7253,"A divorce agreement?"]],"31":[[8,133,"A divorce agreement?"],[283,433,"No, okay, clearly this is just"],[433,529,"a prank Neil's trying to pull."],[533,663,"He would never divorce me."],[767,809,"This is not like"],[809,905,"I even signed anything,"],[905,971,"so it's just."],[1443,1547,"It's my signature."],[1764,1885,"Why would I have signed this?"],[1885,1926,"I..."],[2181,2281,"Was it then?"],[2573,2610,"Keira."],[4312,4362,"Of course!"],[4462,4567,"Of course I picked"],[4567,4742,"this moment to have a seizure."],[4850,5063,"God, am I really gonna die like this?"],[5130,5317,"Lying right next to this stupid"],[5317,5492,"fucking divorce paper I signed?"],[5597,5714,"Neil, where are you?"],[5739,5905,"I need you here with me."],[5997,6081,"I don't wanna die"],[6081,6293,"without seeing you one last time."],[7002,7127,"Oh God."],[7207,7332,"Wait, what is this?"]],"32":[[0,162,"This spray just saved my life."],[187,266,"How did this"],[266,437,"get in my pocket to begin with?"],[1051,1109,"Right."],[1167,1267,"Of course it was Neil."],[1322,1368,"Who else?"],[1509,1589,"And here I was,"],[1589,1747,"cursing him for leaving me."],[1839,1943,"But even after he's gone,"],[1943,2189,"he still finds a way to save my life."],[2227,2356,"Of course it was you."],[2510,2569,"See?"],[2615,2798,"See, you wouldn't divorced me."],[2798,2940,"You love me more than anything."],[3098,3165,"This is just"],[3219,3403,"a ploy for you to catch my attention."],[3541,3586,"Three weeks?"],[3586,3716,"No, I'd give him three days"],[3716,3870,"until he's back on my doorstep,"],[3883,3920,"begging"],[4033,4129,"to get me back."],[5159,5242,"You saved my life,"],[5242,5363,"so I will make you a deal."],[5555,5726,"Just, a kiss and an apology,"],[5726,5814,"and I will forgive you"],[5814,5901,"for disappearing on me"],[5901,5980,"out of the blue."],[6322,6489,"Oh, but first I have to check on Simon!"]],"33":[[58,154,"Simon's been pain-free"],[154,254,"for three days."],[287,350,"Keira,"],[429,558,"you must be his good luck charm."],[571,892,"Yeah, Keira, I owe you a big thanks."],[909,1017,"You've been a huge help"],[1017,1151,"since I've been back from Europe."],[1159,1230,"Okay, okay,"],[1230,1343,"enough with all the praise."],[1347,1497,"Let's just, let's just eat."],[1747,1822,"EWWW,!"],[1872,2006,"This is the nastiest salad"],[2006,2068,"I've ever eaten."],[2072,2243,"What the fuck is this dressing?"],[2323,2435,"Tell Neil to make a new one."],[2656,2777,"Uh, he, he's not here."],[2961,3123,"He's been gone for like three days,"],[3123,3199,"so I've just been having"],[3199,3311,"the maids cook for me."],[3315,3411,"Oh my God."],[3449,3511,"Keira,"],[3599,3753,"the stars are aligning."],[3782,3928,"Neil's fading into the background"],[3928,4145,"and you and Simon can be together."],[4175,4325,"You guys can get married!"],[4379,4508,"This is so exciting."],[4508,4650,"I get to be the maid of honor, right?"],[4779,4900,"Beth, Neil is my husband."],[4900,5030,"That's not gonna change."],[5050,5150,"What do you mean your husband?"],[5209,5288,"Didn't he divorce you?"],[5714,5784,"Who told you that?"],[5789,5830,"He did."],[5876,5926,"He told me"],[5926,6051,"when he picked up those meds."],[6172,6218,"Keira,"],[6281,6481,"Neil has made it very clear"],[6489,6585,"what he wants."],[6594,6731,"You guys are divorced."],[6777,6861,"There's nothing worth"],[6861,6956,"saving anymore."],[7061,7157,"It's time to move on."],[7244,7286,"No, Beth,"],[7290,7419,"you can't take Neil seriously."],[7432,7524,"He's just pissed off"],[7524,7615,"and he said a bunch of shit"],[7615,7661,"he didn't mean."],[7661,7728,"You know that."],[7795,7832,"You know what?"],[7832,7862,"Screw this,"],[7862,7949,"I'm gonna call him right now"],[7949,8037,"and tell him to come back."],[8433,8554,"The number you have dialed"],[8562,8704,"is not in service."]],"34":[[25,125,"Not in service?"],[262,442,"Did he seriously delete his number?"],[442,604,"I mean, is he trying to hide from me?"],[938,1026,"Keira, where are you going?"],[1026,1126,"To find Neil."],[1463,1501,"Ok,"],[1501,1609,"what is going on right now?"],[1664,1764,"Does she seriously want that"],[1764,1872,"idiot to come back?"],[1976,2081,"Fuck, this is bad."],[2114,2273,"Keira's really in love with Neil."],[2648,2698,"Dad?"],[2898,3015,"Do you know where the hell Neil is?"],[3040,3078,"Keira,"],[3094,3190,"you've been living with him"],[3190,3265,"for five years."],[3265,3357,"If anybody would know"],[3357,3482,"where Neil is, it's you."],[3595,3732,"No, don't be such a smart-ass!"],[3732,3883,"Do you know where he is or not?"],[3903,3945,"Keira,"],[3945,4145,"I don't know his whereabouts."],[4216,4387,"But if Neil wants to leave you,"],[4387,4512,"you need to let him go."],[4671,4763,"What?"],[4779,4859,"What, what, what"],[4859,4934,"does that even mean?"],[4938,5096,"Neil is not gonna leave me."],[5121,5284,"Wait, this is just some twisted game"],[5284,5363,"he's playing to see"],[5363,5467,"how much I care about him."],[5488,5601,"Isn't this what you wanted?"],[5668,5776,"You and Neil have split."],[5784,5876,"He was the only thing"],[5876,6022,"standing between you and Simon."],[6026,6085,"God damn it,"],[6085,6177,"why does everybody think"],[6177,6285,"I want to be with Simon!"],[6289,6485,"Dad, he and I are just friends!"],[6510,6581,"Divorcing Neil"],[6581,6760,"has never even crossed my mind."],[6802,6848,"Keira,"],[6861,7040,"you signed the divorce papers."],[7490,7649,"The divorce has been finalized."],[8800,8900,"Neil wasn't kidding?"],[9250,9342,"He really divorced me?"]],"35":[[125,241,"He really divorced me?"],[892,1026,"Keira, I'm gonna call 911."],[1726,1876,"Keira, back in college,"],[1889,1993,"your entire world"],[1993,2122,"revolved around Simon."],[2139,2314,"You were in pieces when he left you."],[2314,2456,"Said you didn't want to live anymore."],[2523,2594,"Now,"],[2644,2773,"you're divorced from Neil."],[2815,2998,"Simon seems to want you back."],[3065,3148,"I don't understand"],[3148,3257,"why you're so miserable."],[3290,3461,"Simon was my first boyfriend"],[3461,3603,"and, and I loved him"],[3641,3728,"once upon a time."],[3728,3883,"But that was years ago."],[4029,4191,"Neil is the only man that I want."],[4216,4291,"But Keira,"],[4346,4454,"you're divorced."],[4521,4612,"You lost him."],[4742,4775,"No."],[5005,5088,"No, okay, I,"],[5288,5359,"I object."],[5359,5442,"Without my consent,"],[5442,5526,"this is null and void, so..."]],"36":[[29,104,"Okay, you know,"],[104,179,"you know what I'm gonna do?"],[179,275,"I'm gonna sue Neil."],[333,433,"I'm gonna tell the courts that"],[433,592,"he coerced me into this divorce,"],[592,738,"and then he'll have to take me back!"],[742,875,"Jesus Christ, Keira,"],[875,1030,"do you even hear yourself?"],[1088,1167,"Dad, what the hell"],[1167,1280,"am I supposed to do?"],[1359,1522,"I love him, he's my husband."],[1589,1630,"Keira,"],[1651,1797,"I assume you don't know"],[1797,1872,"the real reason"],[1914,2014,"that Neil married you?"],[2064,2173,"What, what, what do you mean?"],[2173,2260,"He, he married me"],[2260,2356,"because he loves me."],[2427,2565,"God, you sound just like Beth."],[2565,2686,"Everyone is assuming"],[2686,2806,"he was only after my money."],[2806,2923,"That's not what I'm saying."],[2940,3086,"You know, maybe I wasn't sure before,"],[3086,3182,"but I am now."],[3249,3332,"I love him."],[3424,3520,"And he loves me."],[3603,3678,"God, fuck this,"],[3695,3853,"what am I even doing here?"],[3878,3941,"He's out there,"],[3941,4104,"probably waiting for me to find him."],[4104,4208,"And I, I'm just standing here"],[4208,4291,"wasting time?"],[4375,4579,"Neil, you don't have to apologize."],[4729,4892,"I just want that kiss you owe me."],[5242,5417,"What will she think when she finds out?"]],"37":[[158,254,"Professor Westfield,"],[275,358,"have you seen Neil?"],[396,496,"Isn't he your husband?"],[525,633,"Why are you asking me,"],[692,729,"some stranger,"],[784,871,"where your husband is?"],[871,992,"I've looked everywhere for him,"],[992,1134,"our, our friends, our old hangouts,"],[1134,1242,"our place, nothing."],[1301,1393,"But I remember he used to"],[1393,1501,"live at your lab during college,"],[1501,1568,"so I..."],[1601,1659,"Come on, please,"],[1659,1764,"you are my last hope."],[1768,1893,"Neil makes it clear,"],[1893,2081,"he wanted a clean break."],[2114,2289,"I can't tell her he's gone to Mars."],[2289,2344,"God, he's just"],[2344,2489,"jealous of me and Simon."],[2510,2577,"He doesn't understand"],[2577,2656,"how much that asteroid"],[2656,2711,"meant to me,"],[2711,2786,"and how much it meant that"],[2786,2902,"he named it after my mom."],[2911,2957,"Hold on."],[2982,3078,"Did you just say that"],[3148,3324,"Simon discovered the asteroid?"],[3332,3370,"Well, yeah."],[3370,3465,"That's what he told me."],[3712,3762,"Alright."],[3949,3983,"Ah."],[4066,4108,"Here."],[4191,4270,"Take a good look."],[4325,4412,"This is the official"],[4421,4625,"NASX submission for that entry."],[4675,4813,"You can see whose name is on it."],[4884,5055,"No, no, no, no, no,"],[5063,5217,"you're saying that Neil found it?"],[5276,5372,"That Simon lied?"],[5409,5630,"Ms. Theron, this is NASX."],[5643,5739,"Do you really think"],[5739,5797,"that we would get"],[5797,5922,"something like that wrong?"],[6118,6373,"Why, why wouldn't he tell me this?"],[6393,6548,"Oh, I think the question really is,"],[6548,6648,"did he never tell you?"],[6648,6865,"Or, did you just never listen?"],[7127,7286,"Keira, I spent night after night"],[7307,7436,"looking for that asteroid for it I-"],[7436,7511,"Hey, no, no, no,"],[7511,7615,"I'm on my way out right now."],[7811,7991,"Neil spent months."],[8003,8099,"He went without breaks,"],[8099,8179,"without sleep,"],[8179,8337,"just to give you that gift,"],[8375,8475,"you didn't even know?"],[8666,8787,"This is all my fault."],[8825,8863,"God,"],[8863,9004,"it's just another misunderstanding."],[9004,9071,"I, I keep,"],[9205,9338,"I keep breaking his heart."]],"38":[[492,575,"Jesus!"],[700,738,"Keira,"],[738,859,"are you trying to drink yourself"],[859,925,"to death?"],[934,1096,"The doctor said too much alcohol"],[1096,1192,"could trigger a seizure."],[1205,1351,"Well, Neil would always make sure"],[1351,1438,"I wouldn't drink too much."],[1438,1484,"He'd,"],[1576,1735,"count my glasses, but,"],[1872,1981,"now he's gone."],[2056,2135,"We're divorced"],[2135,2277,"and nobody knows where he is."],[2277,2318,"So,"],[2398,2444,"oh, well."],[2619,2740,"No one's here to stop me now,"],[2740,2932,"so I can get wasted."],[2969,3065,"Stop."],[3073,3207,"I just, I wonder,"],[3428,3574,"what he would do if he was here."],[3607,3728,"Would he help me change?"],[3728,3828,"Would he tuck me in?"],[3828,3878,"Would he"],[4049,4116,"hold me?"],[4158,4225,"Come on, Keira,"],[4283,4412,"Sober up, okay?"],[4446,4692,"Neil is a worthless loser."],[4783,4867,"He was just after your"],[4867,4979,"fortune the whole time."],[5134,5201,"Keira,"],[5251,5351,"I, I can't watch you do this"],[5351,5397,"to yourself."],[5447,5559,"Not over someone like Neil."],[5580,5705,"I mean, I'm way better than him."],[5739,5839,"Don't touch me."],[5880,6010,"You think I don't know what you did,"],[6010,6072,"Simon?"],[6131,6272,"You lied."],[6318,6398,"You took credit"],[6398,6602,"for the asteroid that Neil found."],[6623,6660,"Shit."],[6710,6852,"How the hell did she find out?"],[6894,6931,"Keira,"],[7019,7152,"whatever Neil did for you in the past,"],[7152,7278,"it does not matter, okay?"],[7278,7349,"It was all an act."],[7461,7590,"Take a look at this bank statement."],[7903,8066,"He stole a million dollars"],[8066,8149,"from the family company,"],[8149,8233,"the day he left you."]],"39":[[70,304,"I told you, time and time again,"],[316,504,"Neil is scum."],[504,538,"Okay?"],[538,642,"He does not love you."],[684,784,"He was just after the money"],[784,863,"in your pockets."],[875,1009,"No, he, he wouldn't do this."],[1009,1172,"He's not that kind of person."],[1192,1276,"Keira, you,"],[1301,1409,"you don't even know who he was."],[1409,1522,"He was, he was faking it"],[1522,1601,"the whole time."],[1647,1751,"What else explains why he would"],[1751,1922,"steal a million fucking dollars"],[1922,2010,"from your family?"],[2064,2202,"He was sucking you dry."],[2218,2352,"Keira, forget everything"],[2352,2527,"Neil pretended to do for you."],[2569,2631,"He's gone."],[2640,2715,"The evidence is here."],[2748,2907,"He stole a million dollars from you"],[2915,3044,"and he divorced you, and he left."],[3082,3236,"It's not worth crying over him anymore."],[3286,3436,"No, I don't, I don't care."],[3436,3561,"He wouldn't do this!"],[3632,3716,"Ok, I have to find him."],[3716,3883,"I have to hear this from himself."],[3908,4033,"Wait, wait, wait, you're doing what?"],[4091,4216,"He took a million dollars and left."],[4216,4262,"He's probably"],[4262,4387,"out of the country by now."],[4412,4604,"I don't care where he is, Simon."],[4683,4788,"I, I'm gonna file"],[4788,4884,"a missing person's report"],[4884,4967,"and I, I'm gonna"],[4992,5088,"get a ten million dollar,"],[5088,5221,"fifty million dollar reward"],[5221,5313,"to whoever finds him."]],"40":[[867,967,"Was Neil really after"],[967,1067,"my family fortune?"],[1655,1693,"Keira?"],[1772,1835,"Dad?"],[1885,1976,"What are you doing here?"],[1976,2022,"Keira,"],[2022,2135,"do you really think Neil"],[2143,2285,"just married you for your money?"],[2381,2439,"I..."],[2540,2731,"Neil didn't steal any of your things."],[2773,2861,"I saw the maid,"],[2911,3069,"and she said when he left,"],[3069,3244,"he barely took anything with him."],[3303,3382,"She also said"],[3382,3649,"he only owned two pairs of shoes."],[3687,3883,"If he stole a million dollars from you,"],[3887,3995,"do you really think"],[4033,4141,"that he would hold on"],[4166,4366,"to two worn-down pair of shoes?"],[4375,4462,"So he really"],[4462,4637,"only had two pairs of shoes?"],[5109,5255,"Oh, those must be the other pair"],[5255,5338,"the maid mentioned."],[5367,5501,"Those were his favorites."],[5513,5684,"Wore them for four years"],[5684,5793,"until they were practically"],[5793,5914,"falling apart."],[5972,6039,"And even then,"],[6076,6185,"he wouldn't get rid of them."],[6289,6393,"He said they were from you."],[6731,6823,"Yeah, Simon."],[6881,6915,"Yeah,"],[6915,7007,"I got you the shoes you like."],[7069,7136,"You can just let me know"],[7136,7236,"if they fit or not, because if not,"],[7236,7323,"I can always exchange them"],[7323,7444,"for a different size."],[7757,7807,"Those for me?"]],"41":[[16,75,"Those for me?"],[262,350,"Oh, um."],[421,521,"Yeah, they're just a"],[521,775,"hand-me-down from a friend of mine."],[800,942,"I, I don't even think"],[942,1092,"they're your size or not so."],[1263,1343,"You can just toss them"],[1343,1426,"if you don't like them."],[1447,1493,"No."],[1559,1722,"No, they're perfect."],[1860,1939,"I'm never getting rid of them."],[2102,2202,"Great."],[2289,2419,"Yeah, I'm happy you like them."],[2460,2569,"Thank you, really."],[2660,2736,"I mean, for somebody who says"],[2736,2827,"they can't give gifts,"],[2827,2940,"you're pretty damn good at it."],[3186,3332,"I'm the luckiest man alive."],[4004,4120,"I only gave these to him"],[4124,4225,"because I felt bad."],[4254,4337,"I didn't know they were"],[4337,4466,"his most cherished item."],[4550,4696,"I mean, look at how thrashed these are."],[4696,4792,"He could have thrown these out"],[4792,4917,"years ago, but he didn't."],[5055,5142,"No, it's..."],[5217,5342,"It's just, it's not possible."],[5342,5513,"He wasn't here just for the money."],[5668,5855,"Neil, I only took you for granted."],[5955,6097,"You were only thinking about me"],[6097,6235,"and trying to make me happy."],[6368,6506,"Neil, if you love me so much,"],[6506,6644,"why did you just walk away?"],[6765,6906,"Dad, he has to come back."],[6994,7036,"Right?"],[7115,7269,"He has to come back."],[7399,7503,"I mean, I, I'm not gonna"],[7503,7590,"change anything in the house,"],[7590,7720,"and I'm not gonna throw anything away"],[7720,7887,"until he comes back."]],"42":[[0,450,"T minus, 3, 2, 1, 0."],[450,558,"Liftoff!"],[558,729,"We have a liftoff!"],[1101,1313,"And the shuttle has cleared the tower."],[9263,9384,"One small step for man,"],[9484,9613,"one big leap for mankind!"],[9634,9676,"Neil,"],[9734,9809,"we're streaming live"],[9809,9914,"in front of the whole world."],[9980,10080,"Seeing as you're a leader"],[10080,10164,"of this mission,"],[10222,10301,"I'd like to conduct"],[10301,10443,"a short Q&A with you."],[10497,10623,"Because everyone's itching"],[10623,10764,"to figure out what you're gonna say."]],"43":[[41,212,"Today marks a monumental moment"],[212,304,"in human history."],[337,437,"The first astronaut"],[437,604,"has officially landed on Mars,"],[617,804,"and NASX officials describe the mission"],[804,905,"as a giant leap"],[905,1067,"towards space exploration."],[1134,1259,"And we're going live now"],[1259,1472,"to speak with the astronaut on Mars."],[1497,1651,"Neil, I have been searching,"],[1701,1822,"the world, trying to find you."],[1826,1885,"And I,"],[1956,2077,"I can't find you anywhere."],[2077,2118,"Just,"],[2210,2373,"please tell me where you are."],[2373,2573,"How does it feel to be a national hero?"],[2602,2694,"A national hero?"],[2811,2932,"I don't know about that, but"],[2998,3186,"maintaining integrity to my research,"],[3219,3324,"inspiring others,"],[3324,3528,"is far more important to me than any"],[3528,3603,"title, or"],[3687,3753,"status."],[3845,3933,"I can't see his face,"],[3933,4045,"but I would recognize"],[4045,4158,"that voice anywhere."],[4750,4808,"Put me onto that"],[4808,4896,"Mars livestream now."],[4896,5034,"I need to speak to the astronaut."],[5134,5284,"No, I don't care how much it costs,"],[5284,5392,"or what strings you have to pull."],[5392,5522,"Put me on now."],[5659,5730,"We've got a question"],[5730,5880,"from a Keira Thorne."],[5914,6051,"She says it's very urgent."],[6172,6214,"Neil?"],[6377,6473,"Is that really you?"]],"44":[[8,104,"Why didn't you tell me"],[104,229,"you were going to Mars?"],[258,300,"I have been"],[300,454,"searching the earth for you."],[554,592,"Look, I know"],[592,742,"you're still mad at me, okay?"],[742,871,"I get it, and I'm sorry."],[871,971,"Just please,"],[996,1088,"please come back."],[1117,1180,"Sorry, ma'am."],[1259,1368,"I think you may have me confused"],[1368,1468,"with somebody else."],[1484,1559,"No, no, no."],[1559,1626,"When I was sick,"],[1626,1780,"you read to me every single night"],[1780,1856,"before I fell asleep."],[1856,2022,"I would never forget your voice."],[2052,2293,"Maybe anyone else's, but not yours."],[2323,2423,"Well, then I gotta say,"],[2431,2510,"you sound pretty eager"],[2510,2615,"to find this Neil fellow."],[2627,2719,"Neil, I messed up."],[2794,2877,"Bad, okay?"],[2882,2944,"I know."],[3086,3211,"But it wasn't until you left"],[3211,3274,"that I realized"],[3274,3411,"how much I really needed you."],[3486,3649,"I can't eat, I can't sleep,"],[3649,3766,"I can't do anything."],[3766,3912,"But it all makes sense now because"],[3949,4091,"I realized I have been in love"],[4091,4250,"with you the entire time."],[4250,4433,"I was just too stupid to see it."],[4792,4888,"Neil, please."],[4971,5088,"Please, I will do anything."],[5088,5150,"I'll do anything."],[5150,5288,"I'll cook, I'll do your laundry."],[5288,5526,"I'll, I will do anything"],[5563,5726,"in the universe to get you back."],[5726,5905,"Just please, please come home."],[5985,6035,"Ma'am,"],[6231,6302,"Keira,"],[6414,6523,"trying to relive the past"],[6523,6669,"is like holding on to sand."],[6744,6815,"The harder you grip,"],[6906,6965,"the more it slips"],[6965,7069,"through your fingertips."],[7111,7298,"I do hope that one day you find love"],[7332,7545,"that's solid and stable."],[7624,7753,"A love that, uh,"],[7803,7916,"you don't wanna let go of."]],"45":[[29,141,"The team of astronauts"],[150,367,"collected 12 geological samples"],[367,642,"during their 376 day stay"],[642,717,"on the planet,"],[750,859,"which breaks the record"],[859,1001,"for the longest time spent"],[1001,1230,"stationed on Mars in human history."],[1255,1372,"The collected samples"],[1372,1543,"have been handed over to a team"],[1543,1747,"of leading NASX researchers,"],[1780,1939,"and will play a crucial role"],[1939,2043,"in the country's effort to"],[2043,2206,"build a manned Mars base"],[2231,2419,"by the year 2030."],[2811,2902,"Ladies and gentlemen."],[2957,3132,"I am proud to announce"],[3132,3357,"that our Tecton 7 Mars mission"],[3378,3549,"was a resounding success"],[3570,3653,"and has yielded to"],[3653,3757,"many new breakthroughs"],[3757,3849,"in our research."],[3874,4008,"All of the thanks goes to"],[4008,4233,"our lead astronaut and space hero,"],[4279,4371,"Neil Wade!"],[4713,4888,"It is all thanks to all of your hard work."],[4934,5038,"I'm completely gagged."],[5092,5171,"Thank you so much"],[5171,5284,"for all you've done for us."],[5305,5488,"Come on, Neil, don't be so modest."],[5492,5643,"You were at the helm of it all."],[5643,5826,"You were braving obstacles"],[5839,5960,"and performing miracles."],[5997,6085,"And you were exposed to"],[6114,6247,"to radiation a thousand times"],[6247,6402,"greater than here on earth,"],[6431,6498,"and that is just"],[6506,6623,"scratching the surface."],[6673,6727,"You"],[6760,6873,"are a certified"],[6936,7027,"space warrior!"],[7082,7119,"He's right."],[7119,7278,"Neil, we could not have done this"],[7278,7340,"without you."],[7403,7482,"You're a hero!"],[7515,7707,"And now on behalf of NASX,"],[7720,7845,"I want to present you"],[7899,8049,"with the Distinguished"],[8049,8137,"Service Medal"],[8145,8416,"for space research."],[8596,8679,"Congrats, Neil."],[8725,8933,"You are the youngest recipient ever"],[8967,9113,"of this distinguished medal."]],"46":[[33,145,"Space hero!"],[166,300,"Space hero!"],[325,433,"Space hero!"],[462,588,"Space hero!"],[617,738,"Space hero!"],[759,892,"Space hero!"],[921,1038,"Space hero!"],[1067,1176,"Space hero!"],[1176,1251,"Oh, uh."],[1338,1555,"Neil, this is Daisy Nash."],[1609,1768,"She is the Nash family heiress"],[1768,2031,"and the future CEO of the Nash Group."],[2060,2239,"Without her family's support,"],[2281,2339,"this mission"],[2339,2435,"would never have happened."],[2481,2669,"She's also a former student of mine."],[2669,2840,"She has a deep passion"],[2844,2998,"for astrophysics."],[3023,3144,"You know, I thought maybe, uh,"],[3194,3407,"maybe she could show you around"],[3407,3499,"over the holidays and"],[3503,3599,"get you re-acclimated"],[3599,3712,"to life on earth, huh?"],[3712,3791,"I'd be honored"],[3791,3912,"to serve as your tour guide."],[3958,4079,"I'm sure you've barely even left"],[4079,4220,"the Space Center in your time here."],[4291,4337,"Well, it's a pleasure"],[4337,4471,"to meet you, Ms. Nash."],[4500,4654,"Congratulations, Mr. Wade."],[4683,4829,"My family will also be funding"],[4829,4950,"the Mars Space Camp,"],[4967,5084,"and tomorrow"],[5088,5246,"we'll be hosting a banquet"],[5246,5392,"for the investment signing contract."],[5501,5622,"I'd be honored to see you there"],[5622,5743,"on behalf of NASX."]],"47":[[8,158,"Oh well, thank you,"],[158,316,"but I don't think it should be me."],[329,467,"I think you guys should have James"],[467,525,"do it instead."],[525,579,"Come on."],[633,658,"Neil,"],[658,775,"you've been changing the world"],[775,917,"behind the scenes for so long."],[938,996,"I think it's time"],[996,1067,"the world gets to know"],[1067,1234,"one of the great space heroes"],[1234,1384,"of the 21st century, huh?"],[2181,2327,"To be honest, Neil,"],[2398,2565,"it's like a dream come true for me"],[2573,2686,"to be able to speak to you"],[2686,2777,"in private like this."],[2815,2969,"I'm kind of a huge fan of yours."],[3165,3282,"Anyway, I have your"],[3282,3415,"full itinerary planned."],[3420,3549,"You'll be staying at the flagship"],[3549,3636,"Nash Hotel, okay?"],[3724,3807,"Oh, the Nash Hotel"],[3807,3878,"is pretty expensive."],[3878,3937,"I don't mind"],[3949,4049,"staying some place cheaper."],[4049,4254,"Neil, I'm the Nash family heiress."],[4279,4337,"I've made sure"],[4337,4475,"your trip will be fully covered."],[4512,4575,"Well, thank you,"],[4575,4733,"but I really don't need all-"],[4742,4854,"Neil, it's okay."],[4896,5025,"You've been in space for a whole year."],[5025,5171,"You deserve a real vacation."],[5271,5338,"Well, thank you."],[5409,5455,"Thank you."]],"48":[[429,467,"Neil?"],[487,525,"Keira."],[533,679,"Don't lean out the window like that."],[679,829,"I promise you, Neil's not out there."],[921,992,"Yeah, maybe,"],[992,1155,"maybe I'm just seeing things."],[1159,1288,"Yeah, you're seeing ghosts."],[1288,1368,"It's been a year."],[1422,1514,"You've traveled the world,"],[1514,1564,"you've exhausted"],[1564,1630,"all your connections,"],[1630,1751,"and there's not been a trace."],[1772,1851,"I promise you,"],[1885,1981,"he's hiding out somewhere"],[1981,2089,"using that money that he stole."],[2147,2277,"Guys like Neil will do anything"],[2277,2398,"to make a quick buck."],[2423,2544,"Besides, you have me now."],[2615,2781,"Look at these as happy times,"],[2794,2827,"you know?"],[2827,3032,"I just started my new job at NASX."],[3032,3086,"They have a big"],[3086,3207,"investment banquet tomorrow."],[3207,3353,"You guys are both invited."],[3353,3428,"Oh my God, Simon,"],[3428,3586,"you're working for the Nash company?"],[3653,3766,"The, the company that funded"],[3766,3908,"the NASX mission to Mars?"],[3941,4037,"That is so exciting."],[4037,4162,"I had no idea you were working"],[4162,4316,"for such a famous company!"],[4341,4466,"Oh my God, you're amazing!"],[4483,4746,"Yeah, getting the job at NASX"],[4746,4846,"was pretty easy."],[4900,5042,"But I heard the Nash heiress"],[5042,5109,"is gonna be there."],[5146,5255,"probably be rubbing shoulders"],[5255,5347,"with her quite a bit."],[5347,5538,"The Nash family heiress?"],[5559,5722,"The super drop-dead gorgeous"],[5722,5834,"international woman of mystery"],[5834,5997,"that everyone has been talking about?"],[6018,6122,"Oh my God, I would kill"],[6122,6206,"to meet someone like her."],[6206,6314,"I'll introduce you to her."],[6348,6406,"You can?"],[6406,6556,"That, that's amazing."],[6602,6710,"Fuck, I shouldn't have talked"],[6710,6810,"such a big game."],[6810,6923,"I'm way too small time"],[6923,7036,"to even get in the same room"],[7036,7144,"as the Nash heiress."],[7161,7261,"I wouldn't even recognize her"],[7261,7357,"if I saw her."]],"49":[[25,83,"Keira,"],[120,250,"why are you so low?"],[283,421,"You should be happy for Simon."],[437,538,"Like, all I can think about"],[538,621,"is finding Neil."],[688,738,"Okay,"],[884,1005,"the less you start thinking about"],[1005,1146,"that lowlife, the better."],[1197,1330,"And now Simon has a job"],[1330,1480,"at the Nash company,"],[1505,1626,"the sky's the limit."],[2494,2535,"Alright."],[2535,2673,"This is where we'll stay tonight."],[2719,2794,"Let's go get some rest"],[2794,2852,"because we've got some"],[2852,2977,"sightseeing to do in the morning."],[2977,3128,"I love this place already."],[3128,3265,"I can't get enough of the ambiance"],[3265,3353,"in this lobby."],[3353,3536,"And that was the best"],[3536,3682,"valet service I've ever had in my life."],[3682,3745,"Of course."],[3745,3903,"It's a top Nash hotel."],[3949,4037,"It's actually a gift"],[4037,4220,"from the Nash CEO to his daughter."],[4220,4358,"It's like custom built for her."],[4404,4483,"What if we run into"],[4483,4604,"the Nash family heiress?"],[4792,4896,"Or what if we run into that"],[4896,4979,"new space hero?"],[4979,5142,"I am literally obsessed with him."],[5480,5530,"Neil?"]],"50":[[83,196,"Keira, what was that about?"],[250,308,"Um."],[387,479,"No, that, that was nothing."],[604,721,"Look, let's just go to the room."],[721,821,"I'm ready for a nap."],[875,938,"Neil,"],[963,1155,"do I really miss you so much"],[1155,1326,"that I'm starting to hallucinate you?"],[1368,1547,"It's like you just vanished"],[1547,1672,"off the face of the earth."],[1722,1847,"But I won't give up, Neil."],[1906,2110,"You've got to be somewhere."],[2519,2577,"Keira,"],[2660,2736,"I love you."],[3199,3365,"Jesus, are you drunk or something?"],[3399,3507,"No, I want you."],[3603,3737,"I want you now."],[3878,4033,"Simon, knock it off!"],[4066,4179,"We're just friends."]],"51":[[216,346,"Alright, well, rest well."],[350,404,"I look forward to"],[404,496,"seeing you again soon."],[955,992,"Neil?"],[1138,1176,"Neil!"],[1176,1313,"Oh my God, it's really you."],[1710,1760,"Neil,"],[1826,1918,"look, I am so sorry."],[1918,2068,"I didn't appreciate you before,"],[2068,2127,"but I'm changed."],[2127,2302,"I, I'm ready to be a better wife."],[2352,2494,"Can we please just start over?"],[2927,3078,"Aren't you gonna say something?"],[3078,3119,"No."],[3161,3207,"I have"],[3207,3340,"nothing left to say to you Keira."],[3370,3503,"Neil, I just traveled the globe"],[3503,3574,"looking for you."],[3574,3699,"And yet, now you don't even wanna"],[3699,3757,"talk to me?"],[3803,3858,"I didn't asked you to come"],[3858,3933,"looking for me."],[3999,4104,"We're not starting over."],[4170,4241,"We're done."],[4258,4300,"Neil,"],[4300,4479,"why are you torturing me with this?"],[4587,4754,"I already said I'm sorry."],[4792,4950,"What more do you want from me?"],[4950,5034,"What I want from you"],[5034,5142,"is to leave me alone."],[6110,6222,"It's because of her, isn't it?"],[6222,6343,"The girl that was just in your room?"],[6389,6439,"What?"],[6502,6585,"Who is she, Neil?"],[6685,6798,"Are you dating her?"],[6869,6998,"You're dating her, aren't you?"],[6998,7203,"You finally found some rich heiress"],[7203,7307,"you can mooch off of?"],[7336,7436,"Congratulations."],[7449,7599,"I mean, you're unbelievable, Keira."],[7799,7937,"This is why you wanted a divorce,"],[7937,8020,"huh?"],[8112,8195,"God, I never thought"],[8195,8320,"you'd stoop this low."],[8387,8466,"Let go of me."],[8583,8662,"I need to get some sleep."],[8662,8717,"Sleep?"],[8758,8850,"What's that code for?"],[8850,8929,"Are you gonna go fuck"],[8929,9050,"the bitch you left me for?"]],"52":[[254,354,"We're done, Keira."],[379,462,"We're divorced."],[479,604,"What I do with my life"],[604,704,"is none of your business."],[734,942,"Stop playing the divorce card, Neil."],[992,1046,"You tricked me"],[1046,1126,"into signing the papers"],[1126,1251,"as a scam anyway."],[1276,1359,"Are you serious?"],[1384,1422,"You know what?"],[1422,1484,"It doesn't matter,"],[1497,1572,"because tomorrow"],[1572,1655,"we're getting remarried"],[1655,1797,"and you are moving back in,"],[1814,1906,"that's an order."],[1906,2060,"The Neil you used to know is dead."],[2147,2218,"He's gone."],[2293,2360,"Now go."],[2414,2552,"Oh, so you want to do this the hard way?"],[2648,2736,"Fine, Neil."],[2794,2890,"I'll just call the cops and let them know"],[2890,2982,"you stole a million dollars"],[2982,3078,"from my family's company."],[3211,3436,"Did uh, Simon and Beth tell you that?"],[3611,3695,"I didn't steal any money"],[3695,3799,"from your family, Keira."],[3953,4024,"We're done here."],[4170,4212,"Neil?"],[4400,4529,"Neil, we are not done!"],[4625,4671,"Neil!"],[4821,4879,"Neil, God damn it!"],[4879,4963,"Open this door!"],[4963,5034,"You do not get to"],[5034,5130,"slam a door in my face"],[5130,5230,"and not even say sorry!"],[5230,5367,"You should be begging"],[5384,5501,"to have me back!"],[5601,5659,"You know what, Neil?"],[5659,5734,"I'm gonna have this cop"],[5734,5809,"bursting down your door"],[5809,5905,"in two minues!"],[6360,6402,"Fuck."],[6673,6723,"Neil."]],"53":[[75,266,"Neil, please, let me in."],[316,354,"Keira."],[412,504,"What's wrong?"],[563,633,"Are you seriously"],[633,754,"this upset over Neil?"],[759,829,"He is in there."],[829,984,"He just doesn't want me anymore."],[988,1121,"Keira, calm down."],[1134,1226,"Neil's not here."],[1226,1326,"He's probably in the mountains"],[1326,1438,"running from the cops right now."],[1438,1522,"No. - Let's just go."],[1522,1559,"Come on."],[1559,1714,"No, he's in there, you guys."],[1714,1856,"No, he's in that room."],[2085,2118,"Come on."],[2819,2861,"Hi."],[2894,2998,"Yeah, I need a favor."],[3053,3115,"We have an employee"],[3115,3203,"named Simon, right?"],[3240,3474,"I need you to make him the signatory"],[3474,3549,"for tomorrow's"],[3549,3687,"investment signing contract"],[3737,3812,"with Neil."],[3895,3949,"Great."],[4187,4433,"Simon, Beth, and Keira."],[4466,4592,"You're about to learn that"],[4592,4688,"the man that you bullied"],[4688,4796,"and tossed to the curb"],[4796,4925,"is a national hero."],[5067,5280,"Keira's been acting so different lately."],[5321,5409,"I swear it's because of"],[5409,5488,"that fucker, Neil."],[5488,5559,"It's always him."],[5609,5714,"What are you guys talking about?"],[5868,5968,"Oh, uh,"],[6018,6156,"nothing, the banquet later."],[6502,6606,"Guess who they picked"],[6627,6744,"to sign the contract."],[6744,6790,"Who?"],[6790,6919,"I bet it's that mysterious"],[6919,7157,"hotshot astronaut, Mr. Wade."],[7157,7286,"I hear this is his first ever"],[7286,7369,"public appearance."],[7378,7415,"Wrong."],[7482,7711,"It's me, Simon Franklin."],[7741,7853,"It's only my first week"],[7853,7978,"and they've already picked me"],[7978,8120,"to be the one to sign the contract."],[8141,8216,"It looks like I'm already"],[8216,8299,"climbing the corporate ladder."],[8299,8400,"Oh my God,"],[8441,8608,"Simon, that is huge!"],[8637,8787,"You just, like, cannot stop winning."],[8787,8879,"And it gets better."],[8900,9004,"The one who picked me"],[9004,9121,"to sign the contract"],[9121,9288,"was Mr. Wade himself."],[9334,9392,"That means that"],[9392,9592,"even NASX's top astronaut"],[9592,9701,"sees my potential."]],"54":[[0,112,"Damn, Mr. Franklin,"],[125,271,"a new hire and already"],[271,367,"you're being asked to be"],[367,471,"a signatory on a"],[471,646,"monumental investment contract."],[646,721,"At this rate,"],[721,930,"you will be executive in no time!"],[934,1080,"Ooh, Mr. Franklin,"],[1080,1163,"You must have made a"],[1163,1292,"great impression"],[1292,1451,"on Ms. Nash."],[1451,1539,"I usually do."],[1605,1714,"Mr. Wade seems to be"],[1714,1856,"pretty impressed with me, too."],[1860,1985,"Oh, speaking of Mr. Wade,"],[1985,2106,"I cannot wait"],[2106,2223,"to meet him in person."],[2223,2344,"To be a head of an astronaut team"],[2344,2623,"under 30, ha, it's iconic."],[2631,2744,"And that he was able to"],[2744,2806,"keep his identity"],[2806,2944,"under wraps for so long."],[2944,3132,"Oh, brilliant!"],[3190,3265,"Oh, my gosh."],[3265,3365,"I just, I'm just curious of"],[3365,3536,"who he is."]],"55":[[183,375,"What the fuck are you doing here?"],[450,617,"You've got some nerve, Neil."],[617,779,"You go MIA for a year,"],[779,846,"and then as soon as"],[846,934,"you're fresh out of cash,"],[934,1101,"you come crawling back to Keira?"],[1117,1167,"Oh Beth,"],[1184,1280,"I'm not here for Keira."],[1355,1438,"And I'm certainly not here to"],[1438,1497,"talk to you."],[1555,1676,"Look at yourself, Neil,"],[1760,1918,"you're a fucking imposter."],[1951,2052,"You come here in this"],[2052,2235,"fake-ass designer suit"],[2264,2448,"to a Nash Group banquet?"],[2540,2761,"I have every right to throw you the"],[2765,2840,"fuck out of here."],[2886,2982,"Don't make a rash decision,"],[3028,3078,"Simon."],[3098,3165,"Rash?"],[3211,3340,"I'll show you rash."],[3374,3490,"I'll show you what the fuck happens"],[3490,3599,"when you mess with me."],[3636,3816,"This dunce just waltzes in here,"],[3816,4024,"starts talking smack to Mr. Franklin?"],[4037,4079,"Hmph."],[4116,4220,"He's going down."],[4300,4341,"Alright."],[4433,4546,"You wanna be stubborn, huh?"],[4625,4675,"Security."],[4763,4921,"I wouldn't do that if I were you."],[5326,5442,"Do any of you even know"],[5480,5580,"who I actually am?"]],"56":[[16,154,"Good God, that's a Nash"],[154,283,"Distinguished Service Medal!"],[283,329,"Wait."],[387,567,"Is he one of the astronauts"],[592,721,"from the Mars mission?"],[738,838,"No way!"],[863,1076,"Tecton 7's space research program"],[1076,1217,"is like revolutionary,"],[1251,1330,"brought us closer to"],[1330,1422,"colonizing Mars"],[1422,1534,"than we've ever been before."],[1597,1764,"Simon, I understand you're excited"],[1764,1805,"that you were hired"],[1805,1951,"as a senior exec from Nash Group,"],[1968,2143,"so, before you try to embarrass me"],[2156,2256,"in front of all your peers,"],[2310,2515,"I suggest you get it clear"],[2515,2736,"exactly who you're dealing with."],[3011,3048,"Wait."],[3111,3219,"Neil, you're..."],[3361,3436,"you were part of"],[3436,3586,"the Tecton 7 Mars mission?"],[3682,3858,"Simon, we're fucked."],[3874,4108,"If Neil's actually a NASX astronaut,"],[4108,4137,"then,"],[4162,4304,"he's gonna make us pay big time"],[4304,4441,"for everything we just said to him."],[4496,4587,"If you know what's good for you,"],[4587,4783,"I suggest you leave while you still can."],[5167,5213,"Oh."],[5284,5459,"We're not going anywhere, asshole."],[5492,5659,"You can't do shit to us."],[5693,5864,"You're the one who needs to leave."],[5893,5980,"Get out now!"],[6068,6202,"You know you're something else, Neil."],[6239,6381,"You thought you had Beth fooled"],[6381,6544,"with your fake fucking medal?"],[6610,6664,"It's clear,"],[6694,6940,"you're just a cowardly phoney"],[6969,7065,"trying to pass off"],[7065,7198,"as a real astronaut?"],[7228,7303,"Taking away clout"],[7303,7428,"for your own personal gain"],[7428,7561,"from the real space heroes?"],[7628,7678,"You know what?"],[7732,7782,"Guards,"],[7828,7962,"get him the fuck out of here!"],[7974,8033,"Now!"],[8237,8345,"Not so fast."]],"57":[[4,120,"Not so fast."],[221,354,"Keira, you're finally here."],[375,450,"You would not believe"],[450,533,"what is happening."],[558,775,"Neil's impersonating an astronaut."],[804,905,"Simon was about to tell him off."],[938,1038,"Zip it, Beth."],[1071,1180,"I saw everything"],[1180,1263,"you and Simon have been"],[1263,1359,"ganging up on Neil."],[1443,1580,"Keira, are you seriously"],[1580,1710,"taking Neil's side on this?"],[1710,1885,"I, I'm your sister, for God's sake."],[1885,1976,"I don't really care that"],[1976,2064,"you're my sister."],[2131,2227,"You're a stuck-up,"],[2235,2356,"self-obsessed bitch."],[2356,2477,"And it is your fault"],[2502,2615,"that Neil has been avoiding me"],[2615,2690,"this last year."],[2752,2915,"Keira, are you insane?"],[2923,3065,"I, I didn't do anything."],[3115,3169,"Really?"],[3253,3340,"Because when Neil and I"],[3340,3374,"were married,"],[3374,3507,"he treated you like family."],[3566,3707,"And you made his life a nightmare."],[3716,3858,"You made him so miserable"],[3874,3978,"that he had no choice"],[3978,4133,"but to leave and go into hiding."],[4166,4212,"Keira,"],[4212,4325,"Beth had nothing"],[4325,4441,"to do with Neil leaving."],[4450,4491,"Okay look,"],[4491,4633,"I don't want excuses, Simon."],[4692,4829,"But from now on, I want both of you"],[4829,5000,"to leave him alone for good."],[5096,5159,"Keira, I don't need their"],[5159,5267,"empty apologies."],[5359,5467,"And I don't know what you heard,"],[5467,5613,"but I wasn't in hiding for the past"],[5613,5759,"year like some kind of fugitive."],[5797,5843,"And I sure as hell"],[5843,5976,"did not steal a million dollars"],[5976,6064,"from your family."],[6297,6352,"You didn't?"],[6506,6589,"You know, you were off the grid"],[6589,6669,"for a whole year."],[6669,6827,"What, what happened?"]],"58":[[0,66,"Okay, look."],[100,183,"Neil, I get it."],[283,387,"You're not proud that"],[387,471,"you took the money,"],[471,579,"and you don't wanna talk about it."],[579,671,"That's fine."],[746,842,"That's fine, hey,"],[842,971,"because I forgive you."],[1017,1096,"I'm gonna overlook"],[1096,1230,"you stealing from me."],[1301,1380,"Because honestly,"],[1380,1526,"I've been thinking about it and"],[1726,1876,"we should get remarried."],[2106,2214,"You think we should do what?"],[2277,2498,"Keira, have you lost your mind?"],[2527,2623,"You really wanna remarry"],[2623,2740,"this worthless fuck?"],[2786,2873,"Does our last year together"],[2873,2969,"mean nothing to you?"],[2990,3044,"Yeah, Keira,"],[3044,3094,"why would you wanna"],[3094,3182,"go back to that?"],[3182,3382,"I mean, everyone knows that"],[3382,3511,"Neil was just a replacement"],[3511,3566,"for Simon."],[3566,3649,"No, that's not true."],[3649,3866,"Neil was never just a replacement."],[3895,4095,"Neil, look, I know that I messed up."],[4104,4241,"I know, I know I messed up."],[4241,4383,"But if you give me a second chance,"],[4383,4512,"I swear I will be better."],[4512,4629,"I promise."],[4984,5034,"Neil,"],[5100,5226,"I'm warning you,"],[5238,5367,"Keira is mine."],[5388,5618,"If you even think about remarrying her,"],[5643,5834,"you won't leave this room in one piece."]],"59":[[45,154,"What do you want me to say,"],[154,200,"Keira?"],[241,400,"I'll be filled with gratitude"],[400,517,"of your generous offer?"],[542,604,"Follow you home"],[604,750,"with a smile on my face?"],[754,905,"Neil, look, I know that you're mad."],[942,1017,"I get it."],[1063,1267,"But I am being so serious about us."],[1267,1359,"And I just wanna show you"],[1359,1518,"how much I truly care about you."],[1518,1676,"Let me make this perfectly clear."],[1797,1901,"I didn't go into hiding."],[1922,2072,"I didn't steal a million dollars"],[2072,2164,"from your family."],[2231,2352,"And last but not least,"],[2352,2677,"I don't want anything to do with you."],[2698,2748,"Neil,"],[2827,3007,"you were gone for a year."],[3111,3299,"It's okay to admit that you were hiding"],[3299,3403,"in some remote location,"],[3403,3516,"dodging the cops."],[3620,3745,"Okay, look, I know that it's,"],[3762,3941,"it's embarrassing to say that"],[3941,4024,"you stole the money."],[4129,4237,"But I'm, come on,"],[4237,4429,"I'm gonna let bygones be bygones."],[4450,4600,"I mean, you have no respect for me."],[4696,4813,"You still refuse to listen"],[4825,4996,"to anything I have to say."],[5063,5125,"Look, this is an"],[5125,5201,"important day for me."],[5230,5292,"And I don't wanna keep"],[5292,5409,"digging up the past with you,"],[5447,5497,"okay?"],[5584,5714,"So if you really wanna know,"],[5714,5801,"where I was."],[6189,6289,"It's right there Keira"],[6414,6489,"Just have a look."],[7123,7240,"This medal of honor"],[7240,7378,"is awarded to Neil Wade"],[7378,7515,"for extraordinary"],[7628,7741,"experiments conducted on"],[7741,7957,"Tecton 7 spacecraft."]],"60":[[254,337,"You're the"],[375,467,"Mr. Wade?"],[558,713,"The mysterious lead astronaut"],[713,763,"for NASX."],[763,905,"The man who just spearheaded"],[905,1092,"the longest Mars mission in history?"],[1092,1192,"Keira, what's going on here?"],[1430,1593,"No, no, this, this can't be right."],[1618,1760,"There must be some kind of mistake."],[1826,1914,"I knew it."],[1997,2152,"I knew it was you on the TV."],[2152,2293,"I recognized your voice."],[2356,2481,"Neil, why didn't you say anything?"],[2481,2598,"Then how come you never told me"],[2598,2686,"who you really are?"],[2686,2773,"It was classified,"],[2831,2907,"confidential."],[3003,3165,"Couldn't take any risks,"],[3249,3361,"even if that meant letting"],[3424,3591,"Simon and Beth humiliate me."],[3653,3762,"Keira, you couldn't find me"],[3762,3816,"for a whole year"],[3816,3953,"because I was on Mars."],[4116,4341,"140 million miles away."],[4396,4542,"Fuck, fuck, fuck,"],[4542,4692,"okay, the space hero is Neil?"],[4783,4959,"Okay, time to change tactics."],[4959,5080,"I'll have him forgive me"],[5080,5259,"and I'll get Keira to remarry him."],[5284,5384,"Neil, I had no idea"],[5384,5497,"that you were such a big deal."],[5497,5638,"This is great news."],[5663,5784,"Because now when we're back together,"],[5784,5868,"no one can question"],[5868,5989,"if you're with me for my money."],[6031,6139,"Keira, you need to get back"],[6139,6231,"together with Neil."],[6231,6306,"I'll, I'll just tell him"],[6306,6389,"I'm sorry for everything,"],[6389,6439,"and we can be"],[6439,6573,"one big happy family again."],[6648,6760,"Beth, are you insane?"]],"61":[[16,129,"Beth, are you insane?"],[141,250,"Keira's only falling for this"],[250,350,"because she can't get over him,"],[350,458,"but you should know better!"],[487,554,"I mean, look at this."],[571,688,"It's shoddy craftsmanship."],[688,825,"It's obviously a fake!"],[1042,1176,"I wouldn't do that if I were you."],[1184,1288,"Oh, you wouldn't, would you?"],[1334,1372,"Just wait"],[1372,1509,"till the real Mr. Wade gets here"],[1518,1659,"and sees you impersonating him."],[1705,1764,"Guards!"],[1810,1960,"Kicking this fraud out isn't enough,"],[2002,2097,"break his legs!"],[2114,2260,"Show the whole world what happens"],[2273,2356,"when you impersonate"],[2356,2427,"real heroes!"],[2448,2535,"No, Simon, stop!"],[2565,2702,"If not for him, then for me."],[2798,2898,"Simon, I'm exercising a lot of"],[2898,3003,"restraint today."],[3107,3257,"If you don't leave this second,"],[3257,3382,"I will stop being so kind"],[3382,3499,"and I will make you pay."],[3536,3591,"Fuck you."],[3611,3682,"You're nobody."],[3716,3832,"I'll take you right here,"],[3849,3920,"right now!"],[4408,4546,"You're a dead man walking, Neil."],[4554,4700,"No one fucks with Simon."],[4804,4859,"Guards!"],[4904,5030,"Get this fraud out of here!"],[5326,5442,"Someone's impersonating"],[5442,5509,"Mr. Wade?"]],"62":[[379,425,"Ah."],[487,554,"You're the bitch"],[554,667,"that was in Neil's hotel room"],[667,746,"the other day."],[829,942,"Neil, you told me there was nothing"],[942,1055,"going on between you two."],[1055,1146,"Are you lying to me?"],[1201,1334,"Hey, you're fucking her, aren't you?"],[1334,1493,"Wow, they really don't believe"],[1493,1626,"a thing you say, do they?"],[1659,1710,"Listen,"],[1772,1922,"Neil and I didn't sleep together."],[1935,2168,"So, don't go spewing accusations"],[2168,2352,"just because you're feeling insecure."],[2489,2560,"Well, either way,"],[2560,2698,"you should keep your distance."],[2769,2919,"Neil and I are getting remarried,"],[2919,3032,"so I have every right"],[3032,3178,"to stick my nose in his affairs."],[3182,3315,"Even if that were true,"],[3382,3532,"it wouldn't be necessary."],[3545,3682,"Because of my position"],[3699,3853,"and all of my connections,"],[3912,4112,"I could make any of Neil's problems"],[4112,4400,"disappear with a wave of my hand."],[4416,4596,"And just in case you forgot,"],[4612,4725,"Neil has no intentions of"],[4725,4838,"remarrying you."],[4921,4946,"What are you?"],[4967,5088,"Neil's guardian angel?"],[5221,5330,"I was just about to fuck him up."],[5330,5397,"You came at me."],[5459,5534,"You wanna go again?"],[5568,5689,"Look at this cocky shit."],[5722,5826,"Let me remind you."],[5864,5989,"When you go against me,"],[6047,6147,"you go against all"],[6147,6243,"of the Nash Group."],[6268,6331,"Matter of fact,"],[6331,6510,"you go against Mr. Wade himself."],[6510,6548,"Exactly,"],[6548,6731,"someone kick this idiot out"],[6731,6886,"before the real space hero gets here."],[6940,7061,"He's gonna ruin the banquet!"],[7061,7228,"Your space hero is here."],[7257,7349,"And as for the banquet,"],[7349,7528,"it's already ruined, thanks to you."],[7528,7636,"Wait, he's here?"],[7640,7686,"Really?"],[7686,7757,"Where is he?"]],"63":[[0,54,"He's here?"],[54,95,"Really?"],[95,162,"Where is he?"],[237,392,"He's right in front of you."],[437,638,"Neil is Mr. Wade."],[684,825,"The space hero."],[1105,1201,"Give me a break."],[1255,1413,"Neil's just an astronaut"],[1413,1618,"impersonating, fake NASX medal"],[1618,1710,"wearing clown."],[1751,1976,"Everyone can see that except you."],[2077,2131,"Or maybe,"],[2223,2452,"you're just as dirt-poor as Neil."],[2469,2581,"And your dress"],[2623,2777,"is just as fake as his medal."],[2882,3123,"You're just a gold-digging slut"],[3123,3294,"looking for a sugar daddy."],[3399,3461,"Damn right."],[3474,3520,"Look,"],[3561,3649,"Mr. Carter,"],[3670,3845,"acting CEO of Nash Group,"],[3845,3995,"is gonna be here any second."],[4033,4133,"So let's get this fraud"],[4133,4262,"and his gold-digging whore"],[4262,4320,"out of here"],[4320,4454,"before they ruin my big day."],[4487,4542,"Security."],[4758,4871,"Hold it right there!"]],"64":[[4,112,"Hold it right there!"],[308,387,"Mr. Carter,"],[421,554,"thank God you're here."],[567,688,"This lunatic"],[688,880,"is posing as Mr. Wade"],[888,1121,"and he and his gold-digging sidekick"],[1151,1288,"are ruining the whole banquet."],[1739,1826,"What kind of ignorant fool is"],[1826,1935,"trying to kick Ms. Nash"],[1935,2056,"out of her own banquet?"],[2081,2223,"Apologize to her, now!"],[2239,2298,"Wait,"],[2344,2410,"Mr. Carter,"],[2477,2540,"What did you just"],[2540,2623,"call that woman?"],[2702,2894,"That's Daisy Nash."],[2911,3028,"Nash Family heiress."],[3082,3123,"I knew it."],[3157,3215,"Wait."],[3353,3457,"She's Ms. Nash?"],[3457,3649,"The future CEO of the Nash Group?"],[3691,3720,"No."],[3753,3787,"No."],[3820,3937,"That's, that's crazy."],[3937,4062,"What, what would Ms. Nash"],[4062,4320,"be doing with some loser like Neil?"],[4458,4617,"Who does Ms. Nash spend her time with"],[4617,4808,"is none of your goddamn business."],[4950,4996,"Shit."],[5088,5155,"It really is,"],[5192,5309,"the Nash heiress?"]],"65":[[137,237,"You, you fucked me!"],[237,308,"You didn't tell me"],[308,442,"Ms. Nash was gonna be here."],[471,613,"Oh, so you finally admit"],[613,742,"that I'm Ms. Nash, huh?"],[779,863,"So what if you are?"],[900,1001,"Yeah, you think I'm scared of you?"],[1063,1267,"This whole 100 billion dollar contract"],[1292,1401,"is moot without me."],[1443,1547,"Yeah, that's right."],[1601,1776,"Mr. Wade nominated me personally"],[1776,1893,"to be the signatory."],[1922,2022,"None of you shit-stirrers"],[2022,2093,"can touch me."],[2173,2277,"What the fuck are you laughing at?"],[2289,2473,"I'm laughing at your stupidity."],[2540,2669,"Mr. Wade,"],[2740,2961,"I am deeply sorry for the confusion."],[3003,3061,"We were hoping to"],[3061,3169,"reveal your identity"],[3169,3274,"tonight at the banquet,"],[3303,3407,"but we didn't release any"],[3407,3545,"photos of you in advance."],[3570,3666,"If you'll forgive me,"],[3695,3816,"we'll get started with the signing"],[3816,3887,"of the ceremony."],[3949,4045,"No, that's not possible."],[4074,4250,"Mr. Wade nominated me"],[4258,4366,"to be the signatory."],[4366,4491,"Neil wouldn't do that."],[4529,4671,"He's my girlfriend's ex-husband."],[4671,4742,"He hates me."],[4754,4842,"He would never"],[4842,4979,"want me to sign the contract."],[5013,5130,"Well, if you must know,"],[5138,5284,"I was the one who arranged for you"],[5284,5401,"to be the signatory."],[5422,5530,"I just couldn't wait to see"],[5530,5655,"the looks on all of your faces"],[5655,5847,"when you realize who Neil really is."],[5922,5989,"No,"],[6056,6118,"that can't be,"],[6118,6202,"that can't be real."],[6252,6302,"Neil."],[6302,6410,"Neil is useless."],[6410,6485,"He doesn't have what it takes"],[6485,6598,"to be an astronaut."],[6598,6702,"Neil has been making"],[6702,6810,"major contributions"],[6810,7069,"to the future of space exploration."],[7111,7257,"Meanwhile, you blind bozos"],[7257,7449,"only humiliate him at every turn."],[7461,7653,"If anybody here is useless,"],[7653,7711,"it's you."],[7736,7841,"Simon Franklin,"],[7862,7941,"you're fired."],[7982,8066,"Not only that,"],[8074,8212,"the entire Franklin family"],[8212,8350,"will be bankrupt by midnight."]],"66":[[0,79,"The Franklin family"],[79,233,"will be bankrupt by midnight."],[567,738,"Ms. Nash, no please."],[813,930,"This has all just been"],[934,1042,"a misunderstanding."],[1092,1180,"Oh, has it now?"],[1230,1322,"Yes, yes."],[1351,1484,"A huge misunderstanding."],[1593,1659,"It's her fault."],[1743,1785,"Yeah."],[1814,1985,"She turned me against Neil."],[2002,2143,"I would have never done that."],[2143,2268,"It's, you should blame her."],[2268,2310,"Simon,"],[2310,2414,"what are you talking about?"],[2414,2481,"Don't act like you don't know"],[2481,2548,"what I'm talking about."],[2548,2673,"I would have never gone against Neil."],[2673,2786,"I mean, we were friends."],[2786,2923,"And she pit me against him,"],[2923,3007,"I would have never done that."],[3057,3178,"Fuck you, Simon."],[3178,3269,"All you do is"],[3269,3395,"pass blame on other people."],[3411,3620,"You're a pathetic excuse for a man."],[3687,3795,"Get the fuck off me!"],[3845,4012,"Simon, you're deranged!"],[4104,4170,"Ms. Nash,"],[4187,4220,"please."],[4304,4337,"Please."],[4337,4450,"It's my fault."],[4479,4558,"I'm the problem."],[4608,4742,"Neil, please."],[4779,4859,"Have mercy on me."],[4859,4934,"Just forgive me."],[4934,5000,"We're past"],[5000,5150,"the point for apologies,"],[5150,5238,"Mr. Franklin."],[5292,5438,"Ms. Nash, I'll do anything."],[5455,5584,"Anything you ask, I'll do it."],[5597,5684,"And no problem at all."],[5693,5801,"I, I promise."],[5801,5922,"Please just don't fire me"],[5922,6060,"and don't hurt my family."],[6089,6227,"I, I mean, please,"],[6247,6318,"I'll never make"],[6318,6406,"another mistake, ever."],[6410,6519,"Not, not a single one."],[6539,6727,"You're not actually sorry, Simon."],[6731,6827,"You're just scared,"],[6890,7036,"because of how fucked you are."]],"67":[[171,316,"Neil, I'm a piece of shit!"],[346,396,"I know."],[442,533,"Big idiot, right?"],[563,679,"I, I should have never"],[692,792,"come between you and Keira!"],[813,905,"She's all yours."],[921,984,"I'll never do it again."],[984,1017,"Watch."],[1017,1063,"See?"],[1076,1146,"Here, you do it."],[1146,1184,"Come on."],[1197,1251,"Come on, hit me."],[1272,1347,"Hit me, come on, do it!"],[1347,1388,"Right here!"],[1405,1443,"I don't care."],[1443,1509,"I want you to be mad."],[1509,1580,"Just hit me right there"],[1580,1676,"in the face. - Security!"],[1697,1751,"No, no, please."],[1751,1826,"Get a move on. - No, no, no."],[1826,1968,"I want this scrap of human filth"],[1968,2093,"out of my sight this instant."],[2093,2122,"Keira."],[2131,2177,"Keira!"],[2198,2281,"Don't you love me?"],[2335,2364,"What"],[2364,2489,"are you not doing anything for?"],[2489,2560,"Come on, help!"],[2790,2827,"Neil,"],[2907,2973,"I..."],[3023,3182,"you forgive me, right?"],[3257,3432,"I, I, I know I"],[3436,3566,"said a lot of bad things about you,"],[3566,3807,"but, but Keira, she, she really loves you."],[3849,3983,"And if you remarry her,"],[3995,4124,"we'll be one big happy family again."],[4124,4404,"I will be the perfect sister-in-law."],[4458,4608,"Yeah, that's not gonna happen."],[4662,4700,"Neil."],[4700,4871,"I, I am owning up to my wrongdoings,"],[4871,4963,"can't you do the same?"],[5038,5226,"I, I was just trying to be practical."],[5226,5330,"I just wanted my sister"],[5330,5438,"to have a happier life."],[5584,5663,"God damn it, Neil."],[5663,5764,"Won't you say anything?"],[5839,5926,"Okay, okay."],[5947,6010,"How about this?"],[6047,6172,"If you remarry Keira,"],[6206,6410,"I will be your personal maid, okay?"],[6435,6535,"I will cook for you."],[6535,6623,"I will do your laundry."],[6623,6702,"I'll do whatever you want."],[6702,6835,"You just order me around and I'll do it!"],[6852,6998,"I mean you sound pretty sincere."],[7098,7240,"Would be kind of foolish to"],[7265,7503,"say no to such a generous offer."]],"68":[[0,112,"Would be kind of foolish to"],[162,379,"say no to such a generous offer."],[471,521,"Yeah."],[542,646,"You see, Keira,"],[663,729,"I told you,"],[767,880,"he wants you back."],[888,946,"But first,"],[988,1067,"we should figure out"],[1067,1197,"where that million dollars went."],[1267,1384,"You have any idea, Beth?"],[1484,1564,"You know where it went?"],[1710,1772,"You took it."],[1843,1926,"And you blamed me."],[2022,2127,"But I have a plan."],[2210,2277,"How about"],[2302,2456,"you turn yourself in to the police,"],[2494,2627,"then I will marry Keira."],[2686,2790,"That sound fair to you?"],[2806,2969,"No, Keira, listen."],[2969,3157,"Okay, I, I did frame Neil"],[3157,3219,"for stealing the money,"],[3219,3303,"but I did it to punish him"],[3303,3403,"because he left you."],[3403,3578,"I, I am 24 years old."],[3578,3728,"I, I can't go to jail!"],[3745,3853,"Beth, are you saying that"],[3853,4041,"you stole the money and not Neil?"],[4162,4320,"I'm not saving you this time."],[4375,4471,"If jail is what it takes"],[4471,4562,"to make you a better person,"],[4562,4642,"then so be it."],[4700,4867,"Keira, I am your own sister."],[4867,5017,"You can't let me rot in jail!"],[5121,5196,"Security,"],[5238,5296,"take this woman"],[5296,5430,"to the nearest police station."],[5430,5530,"No, Neil."],[5563,5630,"I will change."],[5630,5684,"I will be better."],[5684,5739,"You just..."],[5793,5947,"Don't send me to jail!"],[6143,6210,"Okay, well"],[6210,6373,"you've settled your score with Simon,"],[6373,6464,"and now Beth's going to jail,"],[6464,6610,"so we can get remarried."],[6685,6785,"Sorry, babe."],[6827,6919,"Neil's with me now."]],"69":[[141,258,"Listen, everything Simon said"],[258,312,"about you being"],[312,421,"some rich woman's boy toy"],[421,604,"was just a big misunderstanding."],[671,767,"Please, you love me, right?"],[767,850,"This woman's just trying to"],[850,934,"stir shit up."],[984,1038,"Oh, my God."],[1051,1163,"Am I seeing that right?"],[1188,1272,"Daisy Nash,"],[1272,1405,"heiress to the Nash Group,"],[1413,1584,"fighting with Theron family's Keira"],[1584,1710,"over the same man?"],[1726,1810,"What kind of magic does"],[1810,1926,"this Neil guy have?"],[1951,2118,"He's got two of the most powerful,"],[2118,2273,"gorgeous women in the country"],[2273,2394,"ready to claw each other's"],[2394,2585,"eyes out over him?"],[2665,2736,"Neil, look,"],[2752,2840,"this is all because"],[2840,2961,"we haven't been intimate."],[2994,3073,"But I can fix that,"],[3073,3148,"I can take the lead,"],[3148,3274,"and then we can go upstairs,"],[3274,3319,"and when we're done,"],[3319,3361,"it's like everything"],[3361,3474,"will fall back into place."],[3474,3678,"God, you're relentless!"],[3695,3807,"He's already told you no."],[3807,3887,"Take a hint!"],[3899,4029,"Who even are you?"],[4058,4175,"You're just an outsider."],[4175,4258,"You have no idea"],[4258,4379,"how deep our bond runs."],[4379,4475,"Oh, you mean the bond"],[4475,4587,"that you trampled all over"],[4587,4679,"when you started hooking up"],[4679,4746,"with other men?"],[4746,4904,"Okay, I made a mistake."],[4959,5046,"Neil, please,"],[5075,5238,"just give me one more chance."],[5301,5484,"Don't fall for her act, Neil."],[5543,5643,"Betrayal can't be fixed"],[5643,5780,"with a half-assed apology."],[5801,5893,"And besides,"],[5935,6035,"the Nash Group is bigger"],[6035,6106,"than the Therons"],[6106,6227,"could ever dream of being."],[6331,6381,"And Neil,"],[6439,6585,"I've loved you for years."],[6602,6673,"Marry me,"],[6690,6819,"and the entire Nash Empire"],[6819,6923,"will be yours one day."],[6977,7057,"Holy shit."],[7090,7244,"That's a billionaire heiress"],[7307,7490,"begging for a man to pick her."],[7490,7615,"This Neil guy has got to be"],[7615,7774,"the luckiest bastard alive."],[8041,8103,"Look, Keira."],[8170,8308,"Keira, I only wanted to say this"],[8308,8454,"as a last resort, but..."],[8600,8754,"I only married you to repay a debt."]],"70":[[66,233,"I only married you to repay a debt."],[321,375,"Repay a debt?"],[375,433,"What, what are you,"],[433,583,"what are you talking about, Neil?"],[1726,1860,"A marriage contract?"],[2039,2173,"When Simon went to Europe,"],[2214,2298,"you were distraught."],[2344,2444,"You were drinking a lot,"],[2460,2565,"and always stayed home."],[2644,2736,"You dad came to me"],[2736,2844,"and he asked to me marry you,"],[2936,3015,"to help you out,"],[3073,3203,"to get you back on your feet."],[3294,3386,"So you're telling me,"],[3465,3607,"that everything you did for me"],[3607,3737,"the last five years"],[3737,3803,"of our marriage"],[3803,3978,"was because of this contract?"],[4029,4079,"That's right."],[4471,4504,"No."],[4592,4642,"No."],[4708,4783,"Okay, no."],[4804,4884,"Just because you made"],[4884,5021,"some agreement with my dad"],[5021,5180,"does not mean you don't love me."],[5221,5363,"It doesn't matter, Keira."],[5455,5597,"Contract or no contract,"],[5597,5730,"we never would have lasted."],[5768,5935,"Our entire five years of marriage,"],[5935,6064,"you spent fawning over Simon."],[6156,6293,"You never cared about how I felt"],[6352,6414,"or what I wanted."],[6489,6627,"Neil, I've changed."],[6648,6710,"That's not me."],[6710,6790,"I've changed!"],[6790,6956,"Just give me one more chance!"]],"71":[[20,95,"You never remembered"],[95,204,"my shellfish allergy."],[316,408,"You never got me a present"],[446,717,"for anniversaries, Christmas, birthdays."],[771,888,"You never knew my phone number."],[921,1080,"You never cared about me, Keira."],[1121,1230,"Our five years of marriage,"],[1230,1359,"I was invisible to you."],[1368,1505,"No, that's not true."],[1559,1676,"Of course I care about you."],[1676,1826,"You were the most important person"],[1826,1910,"in my life!"],[1943,2039,"You cared about me"],[2039,2127,"because I helped you."],[2173,2318,"I helped you do everything."],[2348,2448,"When I left,"],[2448,2523,"you had nobody to care"],[2523,2594,"for you anymore."],[2840,2923,"That's not love,"],[2973,3032,"Keira."],[3215,3357,"We can't turn back the clocks."],[3641,3774,"And I found somebody who"],[3795,3962,"I do care for."],[4024,4124,"And who cares about me."]],"72":[[229,266,"Neil."],[383,533,"I can't live without you."],[629,704,"If you leave me,"],[704,896,"I will fucking kill myself."],[992,1088,"Jesus, Keira."],[1192,1305,"Are you fucking insane?"],[1363,1534,"See, see, I knew that you loved me."],[1534,1697,"If you didn't love me, I would be 