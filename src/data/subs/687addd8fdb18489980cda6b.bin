{"1":[[145,195,"I look forward to"],[195,304,"doing business with you."],[541,800,"Oh, I almost forgot to tell the boys."],[1037,1125,"Boys?"],[1150,1370,"Listen, tomorrow is your grandparents’"],[1370,1541,"50th wedding anniversary."],[1541,1820,"As you know, it's been ages"],[1820,1945,"since I've been home."],[1945,2125,"And I've decided to go."],[2200,2312,"I would really love it"],[2312,2445,"if you all came with me."],[2612,2729,"Yep. Sounds good, Mom."],[2729,2866,"I gotta go, but I'll talk to you soon."],[2891,3054,"Good morning, President Nolan."],[3054,3133,"Good morning, fellas."],[3350,3437,"Yeah, we'll be there."],[3470,3545,"Mr. Sterling,"],[3545,3633,"it's working."],[3650,3808,"And you added 40 milliliters, right?"],[3808,3875,"Yes, sir."],[4375,4429,"Mom!"],[4587,4687,"Yeah, of course I'll be there."],[4712,4800,"I'll see you soon."],[5520,5662,"It's been so long"],[5662,5795,"since I've been home."],[6104,6175,"Athena!"],[6208,6275,"Wait."],[6333,6454,"I know you've made up your mind"],[6454,6520,"about leaving,"],[6520,6641,"and I'm not going to try and stop you"],[6641,6733,"like your mother did."],[6791,6891,"I want you to take this."],[6916,6970,"Dad!"],[7191,7329,"No matter where life takes you,"],[7341,7429,"rich or poor,"],[7441,7604,"I will always be here."],[7654,7816,"Waiting for you to come back home."],[8483,8595,"I'll go in from here."],[8679,8791,"I don't want to draw attention."],[8925,9108,"Time to reunite with the family"],[9108,9291,"after all these years."]],"2":[[87,204,"Ma'am, this is the gift"],[204,341,"you asked for specifically."],[362,491,"The 300 million dollar"],[491,587,"Cullinan Blue Diamond."],[841,979,"Mom loves diamonds."],[1037,1145,"Blue is her favorite color."],[1191,1354,"She's gonna be over the moon."],[1445,1566,"This packaging is too much."],[1566,1795,"Can we put it in a regular bag?"],[2937,3037,"You can head back."],[3125,3200,"I'll go alone."],[3650,3800,"Look who's here."],[3812,4025,"My youngest daughter."],[4041,4304,"The one who married rich."],[4304,4516,"Mom, happy anniversary."],[4575,4700,"You love diamonds."],[4712,4850,"So Hunter and I bid on this"],[4850,5037,"at auction just for you."],[5150,5275,"Oh my!"],[5337,5475,"A diamond necklace."],[5500,5637,"That must have cost a fortune."],[6137,6512,"And here comes my eldest, Silas."],[6537,6779,"The best lawyer in town."],[6779,6862,"Mother."],[7162,7300,"Happy anniversary."],[7354,7537,"I picked this diamond watch out"],[7562,7662,"just for you."],[7662,7750,"Holy."],[7750,7925,"Wow, Mr. Wilson."],[7975,8141,"You sure know how to spoil your mother."],[8204,8400,"I am so proud"],[8400,8516,"of all of you."],[8529,8604,"Wait."],[8650,8829,"Isn't that your eldest daughter?"],[8854,8962,"The one who disappeared"],[8962,9062,"several years ago."],[9291,9437,"That disgrace?"],[9462,9729,"She dare show her face here?"]],"3":[[62,125,"Mom."],[154,279,"Happy anniversary."],[279,387,"Oh, so you remember"],[387,516,"you even have a mother?"],[562,687,"Did you walk here?"],[687,862,"You don't even have a car?"],[891,962,"I do."],[962,1066,"I just parked on the street."],[1066,1154,"Whatever."],[1154,1287,"You came alone?"],[1304,1391,"Oh, the boys."],[1391,1541,"They're still tied up with work."],[1541,1650,"But they'll be here in a bit."],[1666,1779,"Work?"],[1779,1904,"Oh, please."],[1904,2191,"Your boys don't even have real jobs."],[2229,2416,"And they're coming late to my party?"],[2466,2754,"Are you trying to ruin my big day?"],[2766,2816,"Mom,"],[2837,2991,"I got you a gift."],[3554,3912,"Your sister got me a diamond necklace."],[3912,4066,"Your brother,"],[4066,4212,"a diamond watch."],[4250,4491,"And you bring me"],[4491,4687,"a brown paper bag?"],[4775,4912,"Aren't you ashamed?"],[4925,5150,"Why would anybody come to a party"],[5150,5312,"without a proper gift?"],[5362,5487,"Call your boys"],[5487,5762,"and tell them not to come."],[5862,6075,"They're not welcome here either."],[6629,6712,"Athena."],[6779,6833,"Dad!"],[6904,6950,"Oh! - Oh!"],[7141,7212,"Oh..."],[7279,7391,"Oh, look at you."],[7400,7554,"You've even got some gray hairs now."],[7625,7779,"You've had a tough time out there."],[7841,7912,"Haven't you?"],[7925,7979,"Dad."],[8037,8137,"You're the only reason"],[8137,8312,"I never gave up all these years."],[8766,8887,"You know how your mother is."],[8962,9100,"Don't let her get to you."],[9212,9287,"Okay, Dad."],[9500,9566,"I can't believe"],[9566,9712,"you're still married to that husband."],[9966,10116,"What do you think you're doing?"],[10154,10291,"Why don't you go help out"],[10291,10425,"in the kitchen or something?"],[10479,10716,"Silas and Gloria are just sitting here."],[10716,10804,"Why do I have to be"],[10804,10916,"the only one working?"],[10925,11316,"Gloria and Silas have master's degrees."],[11329,11550,"They have high-paying jobs."],[11562,11737,"What do you have to compare?"],[11737,11804,"Sis,"],[11804,11941,"when you're poor,"],[11941,12075,"you have to work harder."],[12075,12229,"Otherwise, people will always"],[12229,12329,"look down on you."],[12654,12737,"No, sweetheart."],[12737,12841,"You don't have to."],[12862,12979,"You just got here."],[13000,13129,"Sit and relax."],[13204,13362,"I'll take care of everything."],[13404,13612,"Well, that's all you're good for anyway,"],[13612,13912,"you useless old fool."],[13929,14037,"Oh, Dad."],[14087,14266,"I'm sure you've been on your feet all day,"],[14266,14400,"so let me take care of it."],[14441,14641,"Just relax and enjoy your day."],[14662,14762,"Thank you, sweetheart."],[15112,15212,"Bye, bye."],[15266,15341,"Dad!"],[16050,16154,"Nolan."]],"4":[[0,41,"Hey, Mom."],[41,204,"Victor, Felix, and I are all together."],[204,283,"We're heading over now."],[341,466,"It's been years since you've been back."],[466,541,"How's everything?"],[583,658,"Yes."],[766,841,"It's fine."],[866,933,"All right."],[933,1016,"Wait for us."],[1016,1104,"We'll be there soon."],[1370,1520,"Sir, I've loaded the gifts in the car."],[1520,1608,"We're ready to go."],[1625,1662,"Good."],[3100,3187,"Athena,"],[3225,3375,"this is a diamond brooch"],[3375,3529,"Silas brought home last year."],[3612,3700,"I found it."],[3737,3837,"Give it to your mother,"],[3862,3950,"it'll make her happy."],[4025,4175,"Dad, there's no need."],[4204,4450,"The gift that I got her is a diamond."],[4450,4604,"It's not just a rock, okay?"],[4604,4675,"It's real."],[4691,4837,"I don't, I don't need this."],[4850,5066,"Sweetheart, you know your mother,"],[5066,5241,"she cares about appearances,"],[5241,5362,"about what people think."],[5400,5500,"If you give her this,"],[5500,5675,"maybe she'll back off."],[5750,5879,"At least for today."],[5925,6137,"Dad, trust me,"],[6137,6262,"the diamond that I brought"],[6262,6441,"is worth way more than this,"],[6441,6500,"okay?"],[6562,6662,"Please keep this."],[6679,6779,"Okay, sweetheart."],[6854,6929,"As you say."]],"5":[[12,58,"Hey,"],[70,133,"Silas."],[241,370,"Guess what I just saw."],[395,595,"Dad was in the kitchen with Athena"],[595,762,"having a little heart to heart."],[770,845,"Oh yeah?"],[925,1020,"What were they talking about?"],[1020,1225,"She didn't have a proper gift."],[1225,1345,"So guess what?"],[1375,1608,"Dad dug up that old diamond brooch"],[1608,1733,"you gave mom last year,"],[1787,2033,"and tried to pass it off as hers."],[2083,2183,"Are you kidding me?"],[2258,2345,"Why the hell should she be able"],[2345,2520,"to use my brooch as her gift?"],[2520,2645,"Oh, I'm gonna nip this."],[2675,2758,"Oh, relax."],[2758,2870,"She didn't take it."],[2933,3012,"Are you sure?"],[3012,3087,"Oh yeah."],[3145,3233,"She actually said"],[3233,3387,"she has her own diamond."],[3433,3533,"And get this,"],[3550,3645,"she claims it's worth"],[3645,3825,"more than your brooch."],[4008,4108,"There's no way."],[4145,4270,"She can't afford a diamond."],[4270,4395,"Exactly."],[4400,4520,"I mean, she probably just picked up"],[4520,4637,"some cheap crystal"],[4637,4858,"hoping to fool mom into thinking it's real."],[4870,4945,"Yeah, figures."],[4945,5070,"You saw that brown paper sack"],[5070,5170,"she showed up with?"],[5200,5370,"There was no jewelry box."],[5370,5495,"There was no certificate"],[5495,5595,"of authenticity."],[5595,5658,"Nothing."],[5725,5945,"Clearly, there was nothing real"],[5945,6045,"in that bag."],[6045,6195,"She's trying to trick mom"],[6195,6308,"with a fake diamond."],[6329,6491,"And I won't stand for that."],[6525,6625,"Do you got a plan?"],[6725,6850,"Of course."],[6875,7079,"My husband owns a jewelry store,"],[7079,7179,"remember?"],[7179,7316,"He's got a diamond tester"],[7316,7512,"that can test the authenticity"],[7512,7737,"and value of any stone."],[7875,7937,"Honey!"],[8029,8100,"Huh? - Go get that"],[8100,8250,"diamond tester out of the car."],[8325,8504,"Let's put on a little show for everyone."],[8566,8679,"Cheers!"],[9204,9483,"If Athena gives her mother a proper gift,"],[9525,9679,"maybe Hazel won't embarrass her"],[9679,9808,"in front of everyone."],[9829,9925,"Maybe, for once,"],[9925,10029,"this family can just"],[10029,10187,"have a peaceful night."],[10645,10720,"Dad!"],[10783,10983,"What exactly are you doing?"]],"6":[[0,62,"It's nothing."],[141,191,"Come on,"],[191,300,"the party's about to start."],[312,437,"Let's head to the dining room."],[475,525,"Come."],[858,1200,"Today marks the 50th year"],[1220,1462,"that Vince and I have been married."],[1483,1720,"Thank you all for celebrating with us"],[1720,1875,"on this special day."],[1920,1995,"Mom!"],[2012,2195,"You won't believe this."],[2212,2445,"Dad saw that Athena didn't have a gift."],[2495,2812,"So he tried to give her Silas' brooch."],[2887,2950,"No."],[2979,3162,"She tried to pass it off as her own."],[3162,3287,"I saw it with my own eyes."],[3287,3337,"No."],[3475,3550,"Dad?"],[3604,3762,"This is unbelievable."],[3762,3912,"Athena got herself into this mess."],[3912,3975,"Why do I always"],[3975,4075,"have to cover for her?"],[4079,4287,"Vince, is this true?"],[4312,4600,"Did that useless girl put you up to this?"],[4612,4712,"Of course not."],[4754,4875,"What is going on?"],[4920,5154,"You lying idiot."],[5416,5587,"Apologize right now."],[5866,6037,"Why am I apologizing?"],[6045,6183,"What exactly did I do?"],[6225,6350,"This is on me."],[6350,6533,"I just wanted to help Athena."],[6779,6945,"I put the brooch in the bag."],[7208,7258,"See?"],[7316,7429,"Without telling her."],[7454,7520,"Dad."],[7541,7679,"She had no idea."],[7700,7858,"She did nothing wrong."],[7870,8037,"Dad, you did nothing wrong."],[8062,8183,"Neither of us did."],[8200,8450,"I don't need someone else's gift"],[8450,8525,"because the diamond"],[8525,8591,"that I brought,"],[8591,8804,"it's, it's worth more than any of you"],[8804,8925,"could even imagine."],[9054,9112,"Yeah."],[9779,9875,"Shut up."],[9912,10062,"Are you trying to embarrass me"],[10062,10191,"in front of everyone?"]],"7":[[16,191,"If you had just brought some"],[191,329,"cheap trinket,"],[329,529,"I might have let it pass."],[541,750,"But you lied to me."],[750,862,"And you took credit"],[862,1037,"for your brother's brooch."],[1062,1300,"You've been out in the world"],[1300,1516,"for 30 years."],[1541,1791,"And what do you have to show for it?"],[1829,1987,"A person can be poor."],[2000,2350,"But at least they have some dignity."],[2350,2500,"I told you."],[2566,2845,"I never wanted Silas' brooch."],[2866,3037,"Oh, give it a rest."],[3066,3266,"Everybody already knows your story."],[3279,3504,"Your husband died when he was young."],[3504,3650,"You don't have a real job."],[3650,3912,"And your three sons are losers."],[3937,4116,"And now you want us to believe"],[4275,4487,"that you can afford a diamond."],[4587,4662,"Exactly."],[4700,4850,"No fancy packaging?"],[4862,5037,"No certificate of authenticity?"],[5070,5195,"Why should we believe you?"],[5216,5308,"Mom's right."],[5329,5541,"Being poor isn't the crime here."],[5566,5729,"But pretending you're not?"],[5754,5929,"That's just sad."],[6033,6095,"Dad."],[6175,6250,"Mom."],[6258,6516,"The diamond that I brought, it's real."],[6516,6591,"Enough."],[6604,6854,"I don't want to hear another word"],[6854,6979,"out of you."],[7016,7225,"What do I have to do for you"],[7225,7329,"to believe me?"],[8033,8158,"Oh, it's wonderful."],[8195,8395,"Athena, do you know what this is?"],[8433,8525,"This little machine"],[8525,8725,"is about to expose your lies."],[8770,9020,"It's so simple, an idiot can use it."],[9037,9158,"We simply place the diamond"],[9158,9233,"on the scanner."],[9275,9400,"It judges everything"],[9400,9650,"from weight, color, cut, and clarity."],[9650,9758,"And then on this screen,"],[9758,9970,"it displays the exact market value."],[10050,10183,"A diamond tester?"],[10233,10487,"That was your big plan all along?"],[10533,10608,"What's wrong?"],[10658,10783,"Getting nervous?"],[10833,10975,"I mean, didn't you just say"],[10975,11170,"that your blue diamond is real?"],[11195,11400,"Well, go on then."],[11400,11475,"Prove it."]],"8":[[237,333,"Alright, Athena."],[337,575,"If your diamond turns out to be fake,"],[608,775,"then you'll apologize."],[775,970,"Right here, in front of everyone."],[1033,1237,"Admit you're a liar."],[1295,1495,"And then, you're gonna smash"],[1495,1737,"that worthless rock into pieces."],[1812,1854,"Deal."],[1950,2266,"Athena, maybe it's best if we don't-"],[2291,2462,"Don't worry, I got this."],[2529,2750,"Oh, but since we're setting rules,"],[2750,2887,"I have one too."],[2937,3075,"If my diamond is real,"],[3075,3312,"then every single one of you"],[3312,3416,"who doubted me"],[3437,3725,"will apologize out loud"],[3725,4025,"for accusing me of nothing."],[4104,4254,"If your diamond is real,"],[4275,4425,"I'll toss my watch."],[4487,4512,"Oh."],[4512,4658,"I'll throw in my necklace."],[4733,4983,"But let's just be honest, Athena."],[4983,5233,"We all know your diamond is fake."],[5233,5295,"But, you know,"],[5295,5470,"I'll just play along, just for fun."],[5591,5633,"Oh."],[5725,5766,"Mom."],[6404,6654,"Let's start with Mom's diamond ring."],[6654,6787,"You know, just to make sure"],[6787,6987,"that the machine is legit."],[7012,7287,"Now, everyone, this was purchased"],[7287,7662,"on 5th Avenue for $70,000."],[8616,8725,"Oh!"],[8787,8983,"Wow, wow, wow!"],[8983,9150,"That thing is spot on!"],[9166,9400,"It even shows the diamond purity,"],[9400,9566,"hardness, and cut."],[9600,9787,"I mean, okay, now do my necklace."]],"9":[[170,291,"Gloria, is this necklace"],[291,516,"really worth $800,000?"],[541,666,"Of course!"],[683,1016,"Unlike some people, I don't run my mouth."],[1104,1279,"Wow, I can't believe it's that expensive."],[1308,1466,"And the clarity is top notch too."],[1504,1720,"Gloria's family must be loaded"],[1754,2129,"to casually give a $800,000 necklace."],[2154,2345,"Hazel, you're so lucky."],[2358,2479,"Oh, that's right."],[2479,2645,"Oh, Gloria's always been"],[2645,2845,"my most thoughtful daughter."],[2845,2966,"And her husband."],[2979,3233,"Oh, what a wonderful son-in-law."],[3308,3516,"Well, Mom, it's your anniversary."],[3529,3704,"No price is too high to pay."],[3891,4066,"Let's test my watch next!"],[5312,5358,"Wow!"],[5595,5670,"My God!"],[5683,5866,"That watch worth two million?"],[5916,6066,"That's more than a house!"],[6066,6241,"With clarity that high,"],[6241,6366,"the price makes sense."],[6379,6508,"It's an investment piece."],[6520,6758,"Absolutely, Hazel!"],[6758,6929,"You did well with the kids."],[6929,7033,"Look at the wonderful"],[7033,7154,"gifts they're bringing."],[7154,7333,"Yes, my kids are wonderful."],[7395,7491,"Both of them."],[7804,7895,"All right, Athena."],[7929,8104,"Silas and I tested ours."],[8104,8183,"Now it's your turn."],[8233,8395,"Why don't you just admit"],[8395,8533,"that you were lying?"],[8533,8716,"Save yourself the embarrassment,"],[8716,8904,"because as soon as we test that rock,"],[8904,9041,"everyone's gonna know it's fake."],[9079,9141,"Fake?"],[9191,9320,"Well, why are you so sure"],[9320,9458,"my blue diamond is fake?"],[10670,10783,"Let's do this."]],"10":[[229,354,"Oh, Athena."],[1091,1216,"That looks just like"],[1216,1291,"one of those knockoffs"],[1291,1400,"they sell on the street."],[1400,1666,"It's too perfect, too big, too flawless."],[1666,1925,"It screams cheap imitation."],[1954,2100,"I've been in the jewelry business"],[2100,2179,"for years,"],[2179,2266,"and I've never seen"],[2266,2491,"a flawless blue diamond of that size."],[2504,2616,"Even if it existed,"],[2616,2879,"it would be half a billion dollars."],[2879,3066,"No way something you could afford."],[3087,3166,"Typical."],[3179,3366,"If you knew anything about jewelry,"],[3366,3416,"you would know that"],[3416,3704,"that cheap blue hue isn't the real deal."],[3837,3941,"You idiot."],[3941,4087,"Put that fake diamond"],[4087,4187,"away already."],[4187,4275,"Why should I?"],[4312,4462,"We haven't even tested it yet."],[4487,4625,"Test what?"],[4650,4712,"Why do you keep"],[4712,4862,"embarrassing yourself?"],[4900,5100,"How did I ever give birth"],[5100,5287,"to such a worthless child?"],[5337,5612,"Silas and Gloria are wonderful."],[5725,5800,"But you?"],[5825,6087,"You only keep humiliating me."],[6112,6225,"I should never have"],[6225,6400,"invited you to this party."],[6450,6600,"No matter what I do,"],[6600,6725,"you will always think"],[6725,6875,"that I am the problem, won't you?"],[7000,7212,"Hazel, don't say that."],[7250,7525,"Athena is just trying to make you happy."],[7537,7700,"She's like that"],[7700,8062,"because you keep coddling her!"],[8087,8362,"Mom, how could you push dad like that?"],[8375,8725,"You have made him weak, just like you."],[8750,9050,"Athena, stop making this worse than it is."],[9050,9187,"Just admit you're a liar"],[9187,9312,"and we can move on."],[9325,9475,"Take the tester away."],[9475,9587,"There's no need to test"],[9587,9850,"my sister's worthless piece of shit."],[9912,10012,"Fifty bucks."],[10025,10125,"Max."],[10262,10375,"This diamond is worth"],[10375,10537,"three hundred million dollars"],[10537,10737,"and we are testing it now!"],[10862,10975,"Test it, sweetheart."],[10975,11150,"I mean, if my sister wants to"],[11150,11287,"make a fool of herself,"],[11287,11400,"who are we to stop her?"],[13404,13479,"Honey!"],[13554,13637,"Honey!"],[13670,13745,"What’s happening?"]],"11":[[762,895,"Honey, what's wrong?"],[908,970,"I don't know."],[970,1145,"It shouldn't be malfunctioning,"],[1145,1470,"but unless the value of the stone"],[1470,1695,"exceeds eight figures?"],[1695,1766,"What?"],[1862,1958,"That's impossible."],[1958,2137,"This tester can only measure diamonds"],[2137,2320,"valued up to eight figures."],[2345,2483,"Anything beyond that"],[2483,2645,"causes system errors."],[2645,2670,"So,"],[2687,2837,"that diamond is worth"],[2837,3066,"more than eight figures?"],[3075,3225,"If it is that valuable,"],[3225,3387,"then the diamond must be real."],[3412,3516,"Just before the blackout,"],[3516,3712,"the clarity level jumped to FL."],[3712,4016,"That is the highest possible purity level."],[4016,4125,"It's flawless."],[4275,4516,"Incredible!"],[4550,4616,"I've never seen"],[4616,4779,"a blue diamond that massive."],[4804,4962,"Let me see that."],[5270,5483,"No wonder this is so beautiful."],[5483,5712,"The purity is unmatched."],[5833,6033,"Athena, you really"],[6033,6295,"did get me the perfect gift."],[6325,6462,"Dad, I wasn't lying."],[6533,6708,"My diamond truly is the best."],[6745,6916,"I believe you, Athena."],[7004,7054,"How the hell did you"],[7054,7191,"get enough money to afford that?"],[7191,7304,"Did you steal it from someone?"],[7345,7441,"Seriously?"],[7491,7604,"You think I would be able"],[7604,7745,"to steal this kind of diamond"],[7745,7829,"from someone?"],[7829,7966,"I still don't believe"],[7966,8204,"that she can afford a diamond like this."],[8233,8383,"Something's off."],[8383,8441,"Honey!"],[8458,8683,"Is there any other reason"],[8683,8933,"why the detector could have glitched?"],[9008,9087,"I've got it!"],[9112,9425,"If the object tested wasn't a diamond,"],[9441,9666,"it would cause an error!"]],"12":[[33,158,"Everyone heard that, right?"],[170,387,"This so-called diamond"],[387,545,"isn't even a real diamond!"],[562,675,"Yeah, I told you so."],[675,737,"There's no way"],[737,870,"that somebody like Athena"],[870,1016,"could afford a real diamond."],[1016,1091,"Mom!"],[1091,1212,"That thing is probably just"],[1212,1475,"a nicely polished piece of glass!"],[1512,1604,"Glass!"],[1775,1900,"Take this garbage"],[1912,2270,"and get out of my party right now!"],[2329,2620,"I planned this day to be perfect,"],[2629,2804,"and you ruined it."],[2804,3091,"If you came just to piss me off,"],[3091,3329,"just get out now!"],[3583,3920,"Why can't you just believe me for once?"],[3920,4058,"Because all you ever do"],[4058,4254,"is argue with me and lie."],[4279,4441,"How did I end up with"],[4441,4616,"such a useless daughter?"],[4641,4829,"Ever since you left the family,"],[4854,4929,"you've been nothing"],[4929,5079,"but a disappointment."],[5108,5258,"How can you say that?"],[5258,5366,"I dropped out of school"],[5366,5679,"and worked nonstop for this family."],[5679,5754,"Do you really think"],[5754,5970,"we would have this life"],[5970,6091,"if it wasn't for me?"],[6091,6141,"Shut up!"],[6141,6241,"Am I wrong?"],[6266,6558,"You forced me to drop out of school"],[6558,6683,"and get a job."],[6683,6854,"And the money that I made"],[6862,7150,"paid for Silas and Gloria's tuition."],[7150,7320,"Without me, do you even think"],[7320,7512,"that they would be where they are now?"],[7554,7720,"Why are you bringing this up now?"],[7766,7875,"Are you blaming me"],[7875,8150,"because I didn't let you finish school?"],[8150,8295,"I'm your mother."],[8320,8637,"If I tell you to do something, you do it"],[8641,8845,"without complaint."],[8895,9004,"Why are you bringing up things"],[9004,9129,"from the past, Athena?"],[9129,9341,"Clearly, it made mother"],[9341,9458,"very uncomfortable."],[9491,9591,"No matter what,"],[9591,9695,"a daughter should never"],[9695,9904,"give her mother a fake diamond."],[9904,10083,"My sentiments exactly."],[10083,10195,"No matter how tough"],[10195,10329,"Hazel has been with you,"],[10329,10420,"she's your mother."],[10445,10712,"How do you even have the nerve"],[10712,10883,"to cry here?"],[10891,11170,"You are not going to ruin my party."],[11229,11383,"Get her out of this house!"],[11433,11508,"What?"],[11558,11620,"Wait!"],[11766,12033,"May I take a look at that diamond?"]],"13":[[66,133,"Robert?"],[162,258,"What are you doing?"],[295,533,"The diamond looks familiar."],[533,737,"I'd like to take a closer look."],[737,783,"Right."],[783,1020,"Robert is a top tier gemologist."],[1020,1220,"He works on multiple national treasure"],[1220,1350,"authentication projects."],[1358,1495,"If anyone can tell"],[1495,1645,"if this diamond is real,"],[1645,1720,"it's him."],[2870,3108,"Well, is it real or not?"],[3137,3529,"This diamond is real."],[3562,3637,"What?"],[3716,3791,"Really?"],[3825,4050,"Only a genuine diamond produces"],[4050,4266,"this fluorescence reaction"],[4266,4400,"under UV light."],[4437,4587,"I can guarantee you"],[4587,5012,"this is the Cullinan Blue Diamond."],[5054,5275,"The king of diamonds."],[5304,5479,"It was once sold at auction"],[5479,5712,"for three hundred million dollars."],[5737,6025,"Three hundred million?"],[6062,6216,"Are you serious, Robert?"],[6216,6329,"Oh, absolutely."],[6329,6441,"There are news reports"],[6441,6566,"about this diamond."],[6566,6729,"You can look it up yourselves"],[6729,6829,"if you don't believe me."],[6933,7000,"Oh my god."],[7041,7108,"It's true."],[7216,7358,"The Cullinan Blue Diamond"],[7358,7437,"was auctioned for"],[7437,7579,"three hundred million dollars."],[7737,7937,"Athena!"],[7937,8100,"Look at you!"],[8100,8391,"You absolutely love your mother."],[8391,8562,"Look at the gifts you bring."],[8712,8929,"A real diamond?"],[8966,9062,"Give it to me!"],[9279,9495,"Athena, is it really worth"],[9495,9604,"three hundred million?"],[10100,10229,"Let me see that."],[10479,10562,"Wait."],[10575,10687,"There's something wrong"],[10687,10791,"with this diamond."]],"14":[[12,100,"Look at this!"],[125,262,"The Blue Cullinan Diamond"],[262,375,"was originally auctioned"],[375,550,"in an embellished box."],[575,862,"But hers just came in a cheap paper bag."],[912,1025,"I didn't want to"],[1025,1175,"use the original packaging."],[1175,1350,"It was too flashy."],[1358,1554,"Or maybe there never was a box."],[1579,1829,"Maybe she just got a cheap knock-off"],[1829,1904,"and didn't have time"],[1904,2029,"to fake the packaging."],[2137,2187,"That's why"],[2187,2362,"the diamond tester malfunctioned."],[2362,2512,"It wasn't because of the value."],[2512,2662,"It was because this thing is a fake."],[2729,2837,"Damn it, Athena."],[2875,3029,"I almost believed you."],[3037,3125,"Again."],[3150,3350,"A bottom feeder like Athena"],[3350,3454,"could never afford"],[3454,3554,"a three hundred million"],[3554,3641,"dollar diamond."],[3662,3825,"There's no way it's real."],[3875,3975,"Oh, come on."],[3975,4041,"A fake,"],[4041,4162,"and not just any fake."],[4162,4312,"The world's biggest diamond?"],[4312,4391,"What a joke."],[4391,4487,"I'm not lying."],[4487,4654,"My diamond is real."],[4687,4862,"Then why did my tester crash?"],[4904,5041,"You're just embarrassing"],[5041,5150,"yourself, Athena."],[5162,5312,"Just admit you're a liar."],[5362,5479,"Alright, everyone."],[5479,5737,"Let's all calm down for a second."],[5737,5787,"Shall we?"],[5866,6087,"I have a way to prove"],[6150,6541,"whether Athena's diamond is real."]],"15":[[0,137,"As you all may know,"],[137,450,"a regular diamond can scratch glass."],[450,625,"But a Cullinan blue diamond"],[625,854,"is hard enough to shatter it."],[904,1162,"Bring in the bulletproof glass!"],[1437,1725,"This is professional grade material."],[1754,1970,"All we need to do is test it"],[1970,2266,"against the bulletproof glass."],[2304,2466,"Yeah, if the glass shatters,"],[2466,2604,"it's the Cullinan blue."],[2629,2762,"Save it, Hunter."],[2775,2975,"Athena barely even went to school."],[3054,3212,"Like she'd understand all that."],[3212,3379,"You know, there's still some time"],[3379,3545,"to admit that it's fake, Athena,"],[3545,3620,"or else you're just going to"],[3620,3687,"embarrass yourself"],[3687,3762,"in front of everyone."],[3762,3870,"I have nothing to fear"],[3870,4008,"because my diamond is real."],[4062,4300,"Mr. Lewis, please, proceed."],[4304,4437,"If the glass breaks,"],[4462,4762,"this is the Cullinan blue diamond."],[4808,5000,"Everyone here will be a witness."]],"16":[[1150,1216,"Nothing happened?"],[1337,1500,"The glass didn't break at all."],[1525,1637,"It didn't break,"],[1679,1791,"which means"],[1987,2225,"this isn't the Cullinan blue diamond."],[2475,2579,"See that, everyone?"],[2637,2787,"Her cheap fake diamond"],[2787,2962,"couldn't even crack the glass."],[3025,3104,"What do you have to say"],[3104,3250,"for yourself now, Athena?"],[3300,3412,"This doesn't make any sense."],[3416,3566,"Of course it does."],[3566,3600,"No."],[3600,3762,"But you're a fraud, Athena."],[3812,4012,"Mom, this is insane."],[4054,4241,"Athena didn't just lie to you."],[4266,4379,"She tried to pass off"],[4379,4550,"some cheap fake as a gift!"],[4600,4750,"We can't just let this go."],[4762,4837,"Exactly."],[4837,4954,"She's basically saying"],[4954,5150,"you don't deserve a real diamond."],[5150,5304,"No, there must be some mistake."],[5304,5379,"Enough!"],[5425,5616,"You worthless failure."],[5687,5812,"You cause a scene here"],[5812,6008,"and then you try to drag it out"],[6008,6120,"even further?"],[6183,6408,"Everyone saw that it didn't break, Athena."],[6475,6770,"You are a worthless, shameless liar."],[6787,6850,"You've wasted"],[6850,6983,"everyone's time here today."],[7041,7279,"The least you can do is apologize."],[7279,7416,"Yeah, apologize!"],[7450,7516,"Yeah."],[7558,7666,"Say you're sorry."],[8691,8979,"Something's going on with the glass."]],"17":[[25,100,"What?"],[141,400,"You really think that a fake diamond"],[425,612,"could actually shatter?"],[1062,1200,"My face! - Oh, God!"],[1329,1450,"Oh, babe!"],[1487,1637,"Stay still, stay still, babe!"],[1679,1779,"Let me get you a bandage!"],[1779,1837,"Oh my God."],[1912,2175,"Huh, I guess I didn't press hard enough"],[2175,2275,"earlier, huh?"],[2354,2591,"That's why the glass didn't break."],[2612,2712,"I told you."],[2775,2954,"My diamond isn't fake."],[3204,3266,"Yes."],[3325,3462,"It's real!"],[3541,3837,"This is the Cullinan Blue Diamond"],[3837,3950,"from the auction."],[4037,4179,"Oh, I never dreamed that"],[4179,4512,"I would hold such a masterpiece"],[4512,4691,"in my own hands."],[4775,5029,"This is truly an honor!"],[5375,5437,"Yes."],[5512,5712,"This is perfect."],[5766,6041,"The diamond is now mine!"],[6066,6387,"Oh, three hundred million!"],[6462,6529,"That's"],[6550,6875,"three hundred million dollars!"],[6900,7075,"I've never seen a diamond like this"],[7075,7175,"in my life!"],[7187,7454,"So expensive, so exquisite, so"],[7462,7550,"unmatched."],[7650,7775,"Wow, Athena."],[7862,8087,"That was very generous of you."],[8150,8537,"Athena, I totally misjudged you."],[8566,8879,"Sweetheart, I am so proud of you"],[8916,9300,"for giving me this precious gift."]],"18":[[0,225,"This precious gift."],[391,550,"Oh, proud of me?"],[662,837,"No, I don't think so, Mother."],[862,1120,"You never even recognized me."],[1275,1483,"Athena, wait."],[1545,1645,"Don't take it."],[1720,1858,"I, I see you now."],[1858,1962,"I, I mean it."],[2000,2037,"Um."],[2133,2370,"You've done better than any of them."],[2433,2608,"Silas and Gloria could"],[2608,2745,"never compare."],[2833,2908,"Mom!"],[2925,3058,"What's that supposed to mean?"],[3125,3270,"We both bought you diamonds, too."],[3270,3375,"How come Athena"],[3375,3508,"gets to be better than us?"],[3550,3645,"Shut up."],[3737,3858,"Both of your diamonds"],[3858,4145,"aren't even worth a fraction of Athena's."],[4175,4220,"Wait."],[4245,4433,"Mr. Lewis, are you sure"],[4433,4695,"this is the Cullinan Blue Diamond"],[4695,4787,"from the auction?"],[4845,5037,"What, you think I'd lie about that?"],[5095,5208,"Come on, Hunter."],[5245,5408,"Robert is a nationally"],[5408,5575,"recognized gem expert."],[5595,5750,"He's even authenticated"],[5750,5895,"royal family jewels."],[5895,6008,"He's not going to get this wrong."],[6033,6175,"That's not what I was asking."],[6175,6287,"I'm sorry, Mr. Lewis."],[6287,6408,"I just have one question."],[6570,6645,"Go ahead."],[6708,6800,"Is there something"],[6833,7058,"that could shatter glass and not"],[7108,7183,"be a diamond?"],[7233,7395,"I mean, as far as I know,"],[7395,7562,"there are plenty of materials"],[7562,7700,"that can shatter glass."]],"19":[[50,150,"You're right."],[200,375,"There are other materials"],[375,537,"that can break glass."],[537,637,"Exactly!"],[679,887,"As long as the fake is hard enough,"],[887,1000,"it can break glass."],[1004,1200,"This proves nothing."],[1404,1529,"I mean, think about it."],[1637,1862,"Three hundred million dollars?"],[1862,2012,"How could someone like Athena"],[2037,2100,"afford that?"],[2404,2516,"Damn it, Athena!"],[2575,2800,"Did you lie to me again?"],[2929,3025,"You know, there's another way"],[3025,3100,"to know for sure"],[3100,3241,"if this diamond is for real."],[3391,3487,"What is it?"],[3512,3675,"Well, if Athena bought the diamond"],[3675,3787,"at the auction,"],[3841,4000,"she should have the official"],[4000,4154,"purchase certificate."],[4300,4566,"Which is something that cannot be faked."],[4600,4712,"Exactly!"],[4825,5050,"So, Athena, you have it, right?"],[5104,5179,"Let's see it!"],[5304,5462,"I left the certificate in the car,"],[5475,5637,"along with the original box."],[5675,5779,"I don't have it on me,"],[5779,5979,"but if you really need proof,"],[5987,6154,"I can have my son, Nolan, bring it over."],[6154,6262,"He's on his way."]],"20":[[0,125,"Are you kidding me?"],[150,408,"You really think that your worthless son"],[408,587,"is just going to waltz in here"],[587,845,"and provide a purchase certificate?"],[887,1008,"Pretending your son"],[1008,1108,"can magically produce"],[1108,1258,"an auction certificate"],[1258,1412,"isn't exactly the same thing,"],[1433,1525,"Athena!"],[1720,1858,"You're trying to stop me"],[1858,1937,"because you're afraid"],[1937,2083,"the diamond is real, aren't you?"],[2262,2395,"Scared of you?"],[2675,2887,"Athena, let it go."],[2975,3120,"Don't fight with your sister."],[3158,3225,"Dad?"],[3258,3383,"You don't believe me either?"],[3383,3495,"No, no, I just-"],[3495,3558,"Fine,"],[3558,3645,"I'll prove it."],[3762,3837,"Just wait and see."]],"21":[[0,62,"Hey, mom."],[112,262,"Nolan, how far are you guys?"],[262,312,"What's wrong?"],[412,487,"Are you here yet?"],[600,662,"Almost."],[687,762,"I'll be there soon."],[825,1012,"Listen, I left the auction certificate"],[1012,1225,"for the Cullinan Blue Diamond in the car."],[1262,1387,"Can you go grab it for me?"],[1425,1500,"Yeah, of course."],[1500,1612,"I took some photos of them"],[1612,1662,"at the auction,"],[1662,1787,"so I'll send them to you now."],[2050,2141,"Thank you."],[2375,2487,"Athena, listen."],[2550,2725,"It's not that I don't believe you."],[2825,3062,"I just don't want you to get hurt again."],[3212,3325,"It's okay, dad."],[3400,3462,"I'm not scared."],[3600,3675,"So?"],[3737,3887,"Did your useless son"],[3887,4037,"finally send in the proof?"],[4100,4200,"Let's be real."],[4200,4325,"Whatever he sends will be"],[4325,4550,"just as fake as the diamond itself."],[4762,4812,"Well."],[5050,5125,"Here it is."],[5200,5362,"The auction certificate."],[5412,5487,"Take a good look."],[5612,5662,"Tell me."],[5825,5987,"Is it a real diamond or not?"]],"22":[[50,275,"This is legit paperwork."],[312,462,"This diamond is really worth"],[462,650,"three hundred million dollars."],[675,950,"Hazel, your daughter is incredible."],[975,1200,"This is beyond impressive."],[1200,1525,"Well, I must have raised her right."],[1637,1862,"She's so sweet."],[1987,2275,"Not that Silas and Gloria aren't,"],[2275,2387,"of course."],[2600,2762,"You both saw it clearly, didn't you?"],[2850,2912,"Tell me."],[2962,3112,"Is the diamond real or not?"],[3437,3575,"You said you'd apologize"],[3575,3662,"if it was real."],[3687,3758,"Well."],[3825,3875,"It is."],[3950,4050,"So let's hear it."],[4100,4237,"Silas, you promised to throw out"],[4237,4375,"your diamond watch, remember?"],[4587,4762,"I mean, I didn't mean that literally."],[4787,5100,"And you, Gloria, your necklace?"],[5175,5300,"Yeah, that has to go too."],[5362,5512,"You said it yourselves."],[5512,5587,"What now?"],[5662,5737,"Trying to back out?"]],"23":[[29,341,"The necklace and watch are my gifts,"],[354,466,"so nobody"],[466,704,"is throwing anything away."],[704,916,"But you did cause a scene,"],[916,1129,"so I think it would only be proper"],[1129,1329,"for you to apologize to Athena."],[1416,1491,"Mom!"],[1516,1679,"You're actually taking her side?"],[1766,1954,"Well, if you had given me"],[1954,2095,"a three hundred million"],[2095,2216,"dollar diamond,"],[2216,2366,"I would be on your side."],[2554,2891,"Now, apologize to Athena."],[3004,3154,"And let's get on"],[3154,3379,"with celebrating my big day."],[3458,3591,"Absolutely not."],[3591,3679,"Hurry up!"],[3754,3916,"Does my word mean nothing"],[3916,4016,"to you two anymore?"],[4166,4254,"I'm..."],[4529,4666,"I'm sorry."],[4704,4816,"Oh gosh, I'm so sorry."],[4816,4916,"I didn't hear that."],[4916,5041,"Could you say it a little louder, please?"],[5041,5241,"Now you've pushed it too far."],[5366,5529,"Babe, look at her."],[5554,5666,"Aren't you going to say anything?"],[5666,6154,"Oh, sweetie, you got cut by the glass too."],[6241,6404,"Oh, look what you're doing."],[6479,6766,"Wait, let me see that certificate again."],[6766,6854,"What now?"],[6854,7029,"The proof is right here."],[7091,7291,"Are you still trying to deny it?"],[7679,7791,"Look at this signature"],[7791,7916,"on this certificate."]],"24":[[104,266,"Sterling Group."],[291,366,"Wait."],[391,529,"The Sterling Group?"],[641,741,"I heard of them."],[754,866,"They're one of the biggest"],[866,1016,"financial firms in the country."],[1204,1404,"Then why does the auction stamp"],[1404,1554,"say Sterling Group?"],[1641,1829,"Athena, how do you explain this?"],[1879,1991,"I explain what?"],[1991,2204,"That Sterling Group is my company?"],[2891,3166,"You, you run the Sterling Group?"],[3166,3279,"You're joking, right?"],[3329,3416,"Oh, wait."],[3466,3654,"If Athena is the CEO"],[3654,3754,"of the Sterling Group,"],[3766,3954,"I'm Bill Gates' brother."],[4566,4866,"Athena, enough of this nonsense."],[4866,5041,"Have you lost your mind?"],[5116,5241,"Do you even know"],[5241,5329,"what kind of company"],[5329,5466,"the Sterling Group is?"],[5516,5691,"How dare you lie to us?"],[5741,5904,"No one knows the Sterling Group"],[5904,5991,"better than I do."],[5991,6116,"I'm the one who built it"],[6116,6341,"from the ground up 20 years ago."],[6379,6504,"I'm Athena Sterling."],[7266,7416,"That is wonderful."],[7416,7541,"That's wonderful!"],[7566,7679,"That is some of the best acting"],[7679,7804,"that I have seen all year."],[7804,7941,"You know, if you really want to"],[7941,8054,"make a go of it,"],[8066,8216,"you should try your luck at Hollywood."],[8241,8354,"Maybe Broadway."],[8566,8679,"Whatever you say, Silas."],[8741,8841,"One more thing."],[8879,9079,"Look at the buyer's signature."],[9116,9266,"That's Carl Jones."],[9279,9366,"Not you."],[9691,9741,"No."],[9766,9904,"Carl Jones is my assistant."],[9904,10079,"I was too busy to go to the auction,"],[10079,10241,"so I had him bid for me."],[10291,10454,"You sent your assistant"],[10491,10625,"to get a three hundred million"],[10625,10716,"dollar diamond."],[10779,10854,"It happens."],[10954,11079,"You think just because"],[11079,11179,"Mom's getting older"],[11179,11304,"that she's easy to fool?"],[11366,11704,"Athena, stop this nonsense now!"]],"25":[[0,287,"Mom, I'm not making this up."],[312,462,"I said enough!"],[512,712,"I swear, sometimes"],[712,1037,"I wish I had never had you."],[1112,1312,"You've been such a disappointment"],[1312,1400,"to this family."],[1500,1775,"Unlike your brother and sister."],[2275,2350,"Really?"],[2487,2662,"You wish you'd never had me?"],[2887,2987,"Mom's right."],[3025,3175,"Maybe you should read the news"],[3175,3300,"before making stuff up."],[3362,3562,"CEO of Sterling Group?"],[3587,3650,"Please."],[3700,3800,"You're not even close."],[3987,4337,"She is really losing it these days."],[4387,4450,"You-"],[4462,4537,"Athena."],[4612,4712,"That's enough!"],[5175,5300,"Just let it go."],[5325,5412,"Dad, I thought you said"],[5412,5500,"you believed me."],[5500,5687,"I do believe you, my sweetheart."],[5850,5962,"Come on, Athena."],[5962,6112,"These lies are getting out of hand."],[6112,6337,"The CEO of the Sterling Group?"],[6350,6437,"That's literally"],[6437,6625,"the richest person in the world."],[6662,6800,"Athena, you've officially"],[6800,7037,"embarrassed the entire Wilson family"],[7037,7225,"by pretending to be"],[7225,7400,"the richest person alive."],[7475,7750,"Alright, enough of this squibbling."],[7762,7900,"Oh, I am so sorry"],[7900,8050,"you all had to witness this."],[8087,8262,"Enjoy some refreshments and,"],[8337,8587,"let's keep this party going."]],"26":[[87,325,"Athena, you just got back."],[325,462,"Don't waste your energy"],[462,562,"fighting with them."],[587,775,"I know, but they started it, Dad."],[800,1225,"I know, but can't you just let it go for me?"],[1300,1525,"Let's just enjoy our family dinner."],[1612,1687,"Please?"],[1787,1825,"Fine."],[1912,2025,"Only because it's you."],[2125,2200,"Let's go eat."],[2300,2379,"I'm going to go put this"],[2379,2450,"somewhere safe."],[2487,2550,"Okay."],[4687,4787,"That's rough."],[4862,4912,"I mean, that's why"],[4912,5100,"you don't show up uninvited."],[5212,5387,"I'd be so embarrassed."]],"27":[[504,741,"She doesn't belong at this table."],[879,1041,"You don't think I belong here?"],[1041,1179,"Of course not."],[1204,1391,"Failures like you,"],[1391,1566,"don't deserve to be anywhere"],[1566,1816,"near elite people like us."],[1891,2054,"It must have been a mistake."],[2104,2304,"Maybe the staff just forgot."],[2329,2466,"They didn't forget."],[2491,2704,"Athena wasn't even supposed to be here."],[2754,2954,"Athena, why don't you just"],[2954,3091,"go grab some leftovers"],[3091,3204,"in the kitchen?"],[3204,3454,"You tried to pass off a fake diamond"],[3454,3729,"and you lied about being a CEO."],[3745,3929,"That's just embarrassing."],[3954,4029,"Maybe you should"],[4029,4129,"just stay in the kitchen."],[4166,4291,"You'd be more help there."],[4341,4466,"They're right, you know."],[4504,4766,"Someone as inadequate as you"],[4766,4954,"does not belong here."],[5016,5116,"Go to the kitchen."],[5166,5354,"Where you fit in better."],[5391,5591,"Oh, and let's not forget,"],[5591,5879,"she's not the only failure."],[5929,6241,"Her three sons are just as pathetic."],[6266,6441,"My sons are more successful"],[6441,6604,"than either of your children."],[7404,7516,"Are you seriously"],[7516,7679,"comparing them with our children?"],[7716,7816,"Absolutely."],[7879,8029,"Gloria's son, Edwin,"],[8029,8216,"is already an executive"],[8216,8516,"at a huge corporation."],[8579,8716,"And Silas' kids?"],[8766,8929,"Your daughter just graduated"],[8929,9066,"from an Ivy League school."],[9066,9204,"And she's already"],[9204,9354,"prepping for grad school."],[9441,9654,"His son is about to go pro in hockey."],[9704,9929,"Your kids really are amazing."],[9929,10029,"Yeah, that's true."],[10054,10366,"Every single one of them's a standout."],[10379,10454,"Face it,"],[10479,10804,"your kids don't even compare to mine."],[10891,11129,"Stop embarrassing yourself, Athena."],[11154,11591,"I've been way too kind letting you stay."],[11654,11804,"Just leave."],[11891,11941,"Why?"],[11941,12041,"They started it."],[12041,12204,"Why am I the one getting kicked out?"],[12204,12366,"Did you really think"],[12391,12641,"that you could sit at our table"],[12679,12991,"showing up with a fake diamond?"],[13054,13141,"Madam,"],[13266,13441,"your gifts have arrived."]],"28":[[50,437,"10 boxes of premium sturgeon caviar."],[437,500,"Oh."],[525,762,"A case of rare white truffles."],[787,1037,"And a bottle of the finest red wine."],[1187,1300,"Mrs. and Mr. Wilson,"],[1300,1475,"these gifts were sent specially by"],[1475,1637,"three extraordinary gentlemen"],[1637,1712,"to wish you both"],[1712,1900,"a wonderful anniversary."],[2062,2225,"Who could they be?"],[2387,2587,"Dad, these gifts are from my sons."],[2612,2687,"Do you like them?"],[2725,2887,"Yes, they're wonderful."],[2912,3037,"Wait, wait."],[3112,3462,"These gifts are from your sons?"],[3462,3537,"Yes."],[3562,3687,"The Cullinan Blue Diamond"],[3687,3800,"was my gift to you."],[3800,3975,"These are from my sons."],[4437,4587,"Do you all realize"],[4587,4850,"how rare this caviar is?"],[4862,5000,"Russian sturgeon is one of"],[5000,5187,"the most expensive fish out there."],[5200,5437,"Basically, it's worth a house."],[5487,5725,"And look at these white truffles."],[5775,5937,"Wait, is this from"],[5937,6187,"the V Research Institute?"],[6262,6600,"That rare new truffle they are developing."],[6612,6775,"I heard it's like"],[6775,7062,"$35,000 per kilogram."],[7087,7137,"Of course."],[7137,7275,"And this wine."],[7312,7462,"A Romanée-Conti!"],[7487,7575,"This is one of the most"],[7575,7787,"prestigious wines in the world."],[7825,8137,"One bottle costs nearly $100,000."],[8575,8837,"They're all mine."],[8875,9025,"Mom, are these gifts"],[9025,9187,"expensive enough for you?"],[9200,9350,"Are you satisfied now?"],[9350,9475,"Oh, yes."],[9537,9750,"I, I love them."],[9837,10175,"Silas, Gloria, more complaints?"],[10287,10375,"Grandma!"],[10387,10475,"Grandpa!"],[10512,10675,"Happy Anniversary!"]],"29":[[37,175,"Happy Anniversary!"],[175,275,"Hey!"],[275,412,"Edwin, you're here!"],[725,862,"There they are!"],[970,1050,"Clara!"],[1225,1450,"Is this the exclusive sturgeon caviar?"],[1525,1800,"This is reserved only for the CEO."],[1837,1950,"What CEO?"],[1975,2250,"The CEO of the Nolan Group,"],[2312,2412,"where I work now."],[2412,2625,"You got into Nolan Group?"],[2650,2887,"That's one of the top 500 companies"],[2887,3012,"in the world."],[3112,3225,"Nolan Group."],[3287,3437,"Isn't that Nolan's company?"],[3525,3662,"Yeah, they headhunted me"],[3662,3825,"and offered an executive role."],[3900,3962,"So I took it."],[4100,4225,"Wait, so you're saying"],[4225,4437,"that this caviar is from the CEO?"],[4437,4625,"Yeah, this specific sturgeon"],[4625,4712,"is actually from"],[4712,4850,"the CEO's private farm."],[4850,5050,"Only a handful of selected clients"],[5050,5187,"ever get this caviar."],[5187,5337,"So maybe this is a..."],[5387,5437,"a little bit of a"],[5437,5637,"special something for me."],[5800,6012,"Athena, you hear that?"],[6012,6137,"This caviar didn't"],[6137,6287,"come from your sons."],[6337,6500,"It's a gift for my son"],[6500,6625,"from the Nolan Group."],[6675,6775,"Pretty shameless of you"],[6775,6925,"to try to take credit."],[7100,7337,"What do you mean, take credit?"],[7375,7437,"Eddie."],[7525,7662,"Your aunt Athena,"],[7662,7766,"oh, she's something else."],[7800,7925,"She claimed that"],[7925,8100,"that caviar was sent by her sons."],[8100,8175,"Can you believe that?"],[8175,8300,"What?"],[8325,8462,"You tried to take credit"],[8462,8662,"for something from our CEO?"],[8662,8825,"Do you have any idea"],[8825,8962,"what could possibly happen"],[8962,9087,"if this gets back to my company?"],[9087,9237,"I could lose my job."],[9250,9400,"If you mess this up,"],[9400,9575,"I'll make sure you regret it."],[9762,9804,"Wait."],[9950,10100,"These white truffles."]],"30":[[16,141,"What about the white truffles?"],[141,204,"They're from"],[204,379,"the V Research Institute, right?"],[379,466,"Yeah, there's a"],[466,716,"V Research Institute logo"],[716,791,"right on the box."],[891,991,"I knew it."],[991,1066,"Dad."],[1066,1204,"I almost forgot to tell you."],[1241,1391,"I got in."],[1416,1641,"This must be a gift from them."],[1641,1791,"They must be for me."],[1791,1979,"That's one of the top"],[1979,2266,"academic research institutes"],[2266,2391,"in the country."],[2516,2729,"Victor runs V Research Institute."],[2866,3029,"These white truffles?"],[3029,3141,"They're a special kind"],[3141,3291,"developed by the Institute."],[3291,3591,"The taste is completely different"],[3591,3716,"than the regular ones."],[3716,4029,"Only the director has access to them."],[4029,4204,"And since they only take"],[4204,4391,"one student every five years,"],[4416,4641,"the fact that they're sending them to me"],[4641,4841,"must mean I'm pretty important to them."],[4929,5029,"That's my girl."],[5054,5166,"That's fantastic."],[5166,5329,"It sounds like the V Research Institute"],[5329,5491,"has great hopes for you, Clara."],[5766,5916,"Seriously, Athena."],[5941,6066,"First the caviar"],[6066,6254,"and now you want to take credit"],[6254,6541,"for another gift from your sons?"],[6616,6754,"It sounds like you're the one"],[6754,6829,"trying to take credit"],[6829,7004,"for something that isn't yours."],[7004,7141,"What is that supposed to mean?"],[7191,7304,"You think I'm trying to"],[7304,7504,"steal a gift from your son?"],[7504,7641,"Do you even know anyone"],[7641,7816,"in the V Research Institute?"],[7816,7991,"The white truffles are a gift"],[7991,8291,"from my son, Victor Sterling."],[8291,8529,"He's the director of V Research Institute."]],"31":[[0,216,"He's the director of V Research Institute."],[979,1129,"Are you crazy?"],[1129,1304,"If the director heard about this,"],[1304,1479,"I could lose my spot."],[1504,1616,"She's always been crazy."],[1616,1879,"Every word out of her mouth is a lie."],[1879,2029,"Everything I say is true."],[2029,2104,"I'm not lying,"],[2104,2341,"but you guys choose not to believe me."],[2341,2429,"Enough!"],[2479,2804,"You lying, shameless idiot!"],[2841,3054,"If you try to destroy"],[3054,3254,"my grandkids' future,"],[3254,3454,"I swear I'll throw you"],[3454,3616,"out of the house for good!"],[3641,3766,"Don't get worked up, Hazel."],[3816,3929,"At least Athena's sons"],[3929,4079,"brought a fine bottle of wine."],[4179,4254,"Wine?"],[4279,4366,"Knowing her,"],[4366,4466,"I wouldn't be surprised"],[4466,4604,"if that was a lie, too."],[4641,4729,"Aunt Gloria's right."],[4754,4866,"That wine was probably sent"],[4866,5004,"by my hockey team's manager."],[5004,5116,"It's a gift to celebrate"],[5116,5304,"my acceptance into the Eagles."],[5366,5466,"You made the team?"],[5466,5529,"Yeah."],[5529,5691,"That's awesome, son!"],[5741,5866,"I'm still a substitute for now,"],[5866,6016,"so I haven't met the team yet."],[6016,6116,"But it's just a matter of time"],[6116,6204,"before I start playing."],[6204,6316,"It's fantastic."],[6404,6641,"The Eagles, that's truly impressive."],[6666,6854,"The Eagles, that's one of the top teams"],[6854,6941,"in the country."],[6941,7041,"Colin, you're killing it."],[7041,7241,"Making it onto the best hockey team"],[7241,7316,"in the U.S.?"],[7341,7466,"That is insane."],[7516,7591,"The Eagles?"],[7654,7841,"Felix is the captain of that team."],[7854,8016,"All right, Athena, let's be real."],[8016,8166,"Not one single one of these presents"],[8166,8266,"came from your son."],[8266,8341,"How long are you going to"],[8341,8491,"keep up this ridiculous act?"]],"32":[[29,141,"I'm not lying."],[216,504,"My oldest son is the CEO"],[504,629,"of the Nolan Group."],[691,916,"My second son is the director"],[916,1079,"of the V Research Institute."],[1129,1279,"And my youngest son"],[1279,1504,"is the captain of the Eagles."],[1541,1754,"These gifts are from them."],[1779,2016,"They're not for any of you."],[2566,2704,"Are you kidding me?"],[2716,2829,"Come on, Athena."],[2829,3029,"You can't go around saying stuff like that."],[3029,3191,"People will think you've lost it."],[3216,3516,"And you'll ruin our reputation"],[3516,3641,"in the industry."],[3679,3766,"Exactly."],[3766,3929,"Dad, if my boss hears"],[3929,4104,"that my aunt is claiming"],[4104,4379,"to be his mother, I'm done."],[4391,4529,"I'm going to get kicked out for sure."],[4541,4641,"Same here."],[4691,4816,"If my coach hears that,"],[4816,4879,"I'm going to be"],[4879,5041,"warming the bench forever."],[5041,5229,"This could mess everything up."],[5304,5454,"Mom, do you hear"],[5454,5629,"what this crazy lady is talking about?"],[5641,5804,"She's going to ruin our kid's future."],[5804,5904,"You've got to do something."],[5904,6066,"Don't worry, dears."],[6141,6354,"Let me handle this."],[6729,6829,"Hazel!"],[7229,7479,"Are you trying to ruin this family?"]],"33":[[20,270,"Are you trying to ruin this family?"],[308,458,"Why did you even come back here"],[458,570,"in the first place?"],[608,770,"Ever since you came back,"],[783,1045,"all you've done is, is try to"],[1045,1258,"ruin my anniversary."],[1258,1383,"Mom, they've been"],[1383,1570,"insulting me nonstop."],[1570,1683,"Why are you blaming me"],[1683,1783,"for everything?"],[1783,1845,"Shut up."],[1895,2033,"I'm warning you."],[2058,2220,"If you lie again"],[2220,2383,"or try to screw up"],[2383,2645,"Colin, Clara, and Edwin's future,"],[2658,2995,"I will make you pay for it."],[3070,3220,"I'm your daughter."],[3245,3445,"How can you say that?"],[3483,3783,"I wish I never had a daughter like you."],[3845,4095,"Your existence has been"],[4095,4333,"a stain on this family."],[4383,4545,"In order to protect"],[4545,4795,"Colin, Clara, and Edwin's future,"],[4845,5158,"I'm cutting ties with you forever."],[5350,5429,"No."]],"34":[[629,779,"Nice work, Mom."],[866,954,"That was perfect."],[991,1066,"That was exactly"],[1066,1179,"what needed to happen."],[1304,1479,"Do you really hate me that much?"],[1529,1604,"How can someone"],[1604,1829,"love a worthless being like you?"],[1891,2104,"Ever since you came back here,"],[2104,2291,"you've been nothing but a problem."],[2516,2766,"Hazel, don't say that."],[2766,2866,"I mean it."],[2941,3179,"Everything was fine until she got here."],[3354,3504,"Get out!"],[3516,3779,"I don't ever want to see you again!"],[3829,4116,"You're no longer my daughter."],[4566,4641,"Hazel."],[4679,4754,"Stop it."],[4816,5054,"I didn't do anything wrong."],[5054,5166,"I've had enough."],[5216,5466,"Someone drag her out of here now."],[5541,5604,"What are you doing?"],[5641,5716,"It's time to go."],[5716,5766,"Stop."],[5766,5866,"Somebody grab the restraints."],[6029,6129,"You're insane."],[6129,6179,"Stop."],[8091,8216,"What are you doing?"],[8216,8316,"Let go of me!"],[8316,8466,"You're gonna regret this!"],[8466,8604,"Oh no, stop it."],[8604,8741,"She's still family!"],[8741,8804,"Dad,"],[8829,8904,"back off!"],[9404,9529,"That's enough!"]],"35":[[0,133,"That's enough!"],[883,920,"Mom."],[983,1033,"You all right?"],[1033,1120,"I'm fine."],[1120,1158,"Yes."],[1158,1208,"Mom."],[1320,1445,"Dad, are you okay?"],[1445,1508,"Did you get hurt?"],[1508,1645,"I'm, I'm okay."],[1645,1708,"Okay."],[1708,1883,"Don't worry about me."],[1958,2295,"Boys, this is your grandfather."],[2408,2495,"How are you, Grandpa?"],[2570,2620,"Hey."],[2633,2720,"Nice to meet you."],[2720,2795,"Grandpa."],[2795,2883,"Hey boys."],[3283,3508,"Your sons look very impressive."],[3533,3595,"Thank you."],[3670,4020,"So, these are your sons, Athena?"],[4070,4195,"Um, I'm sorry."],[4233,4308,"You are?"],[4345,4533,"She's your grandmother."],[4575,4733,"Nicely dressed."],[4745,4870,"I'll, I'll give you that."],[4870,5058,"But that doesn't change the fact"],[5058,5345,"that your mother is a liar and a thief,"],[5345,5520,"and that says enough about you."],[5545,5583,"Hey,"],[5583,5670,"watch your mouth."],[5695,5858,"Don't speak about my mom like that."],[5908,6095,"Say something about her like that again,"],[6145,6358,"and I promise you'll regret it."],[6395,6570,"This is ridiculous."],[6608,6745,"Edwin, get him out of here."],[6808,6895,"Get some of your men"],[6895,7058,"over here right now."]],"36":[[45,120,"Go ahead."],[158,258,"Call whoever you want."],[308,408,"It's not going to change a thing."],[445,658,"If anyone lays a hand on my mother,"],[695,783,"they will regret it."],[858,1033,"Do you even hear yourselves?"],[1058,1245,"Who the hell do you think you are?"],[1258,1433,"Bunch of nobodies!"],[1433,1558,"You and your mom"],[1558,1733,"should all get kicked out."],[1795,1995,"Mom, who even are these people?"],[2033,2250,"That is your Uncle Silas"],[2250,2395,"and Aunt Gloria."],[2445,2633,"So these are the ungrateful"],[2633,2750,"liars and traitors"],[2750,2812,"that I've been hearing"],[2812,2908,"so much about."],[2908,3058,"Excuse me?"],[3133,3270,"Ungrateful?"],[3345,3458,"With Athena as a mother,"],[3458,3583,"what do you expect?"],[3620,3670,"Hey!"],[3670,3745,"Watch it!"],[3783,3820,"You don't get to"],[3820,3958,"speak about my mom like that."],[4070,4170,"Why not?"],[4170,4283,"He, he's not wrong."],[4308,4445,"You guys lie about everything."],[4458,4620,"Your mom said this was from you?"],[4720,4833,"Yeah, it is."],[4833,4958,"What's so wrong about it?"],[4958,5045,"You're lying."]],"37":[[20,70,"You're lying."],[133,245,"This was for me."],[270,408,"It's from the Eagles team manager."],[408,483,"That bottle?"],[558,633,"The team president"],[633,733,"gave that to me last year"],[733,933,"after I led the Eagles to a championship,"],[995,1133,"as the team captain."],[1145,1220,"Bullshit."],[1270,1358,"I saw this bottle"],[1358,1508,"in the team manager's office."],[1545,1708,"It was a gift for me for making the team."],[1708,1833,"You're such an idiot."],[1858,1970,"I kept that in the office"],[1970,2045,"for safekeeping."],[2045,2133,"It's always been mine."],[2133,2258,"A nobody like you,"],[2283,2458,"claiming to be the Eagles team captain."],[2483,2583,"When the real team captain"],[2583,2658,"hears about this,"],[2658,2720,"you're going to get sued"],[2720,2795,"for defamation."],[2845,3045,"Don't even bother, Colin."],[3083,3333,"This whole family is delusional."],[3345,3445,"They think they're better"],[3445,3570,"than everyone else."],[3570,3833,"Lying is in Athena's blood,"],[3833,3983,"and clearly she's passed it off"],[3983,4070,"to her sons."],[4870,4995,"Hey Felix, what can I help you with today?"],[4995,5108,"Hey coach."],[5158,5258,"Quick question for you."],[5258,5370,"Did a kid named Colin come in"],[5370,5508,"and grab that bottle from the office?"],[5570,5608,"No."],[5608,5708,"You took it with you."],[5708,5758,"Yeah."],[5758,5783,"No."],[5783,5858,"All good."],[5941,6058,"Uh, one more thing."],[6133,6233,"Cut Colin from the team,"],[6233,6333,"we don't need him in the lineup."],[6383,6445,"Okay."],[6445,6495,"Done."]],"38":[[83,233,"Here we go again!"],[283,383,"Don't be scared."],[383,595,"They're just messing with you."],[820,945,"You had me for a second."],[1983,2045,"What's wrong?"],[2095,2158,"Dad."],[2283,2358,"You're not going to believe this."],[2358,2470,"They just kicked me off the team."],[2520,2608,"What?"],[2733,2858,"Is Athena's youngest son"],[2858,2995,"really the Eagles' captain?"],[3058,3245,"It must be a big deal on the team."],[3258,3458,"Even the manager listens to him."],[3495,3633,"This doesn't prove anything."],[3658,3820,"Even if he is the captain,"],[3820,4008,"he can't actually get you fired."],[4058,4245,"This is all staged."],[4258,4483,"Anyone can fake an email."],[4670,4958,"Son, you go check this out yourself."],[5083,5183,"Don't let them fool you."],[5495,5583,"They're full of it."],[5583,5795,"Everything that they say is a joke."],[5870,5970,"What makes you say that?"],[5995,6120,"I have proof."],[6208,6320,"Oh, you have proof."]],"39":[[0,112,"I have proof."],[162,300,"Everyone, look."],[337,675,"These white truffles prove they're lying."],[712,787,"I brought those."],[850,937,"So what's your point?"],[1012,1100,"Are you kidding?"],[1162,1287,"This was a gift"],[1287,1487,"from the V Research Institute"],[1487,1737,"to celebrate me getting accepted."],[1775,1887,"Oh, wow."],[1925,2087,"The V Research Institute."],[2187,2275,"I didn't know that"],[2275,2425,"they were accepting new applicants."],[2425,2600,"Well, I don't know what to tell you,"],[2600,2725,"but I was accepted"],[2725,2975,"by the Associate Director personally."],[3025,3287,"Personally accepted by the, who?"],[3312,3412,"Associate Director."],[3425,3562,"Associate Director."],[3587,3675,"Hey, Zack."],[3712,3837,"I heard that you accepted"],[3837,4037,"a new student named Clara."],[4037,4125,"Mr. Sterling."],[4187,4250,"I'm sorry."],[4250,4325,"I can explain."],[4325,4462,"Yeah, well, you better explain quick"],[4462,4537,"because I want to know"],[4537,4687,"why you went behind my back"],[4687,4825,"and accepted a new student"],[4825,4962,"when we haven't accepted anyone"],[4962,5050,"for five years."],[5050,5287,"I, I'm sorry, Mr. Sterling."],[5362,5450,"I just needed somebody"],[5450,5512,"to help me out."],[5512,5637,"All right, cut the crap, Zack."],[5712,5787,"What is really going on?"],[5875,5937,"It's her."],[5937,6012,"It was her."]],"40":[[4,104,"Clara bribed me."],[104,229,"I was just being stupid."],[254,354,"I went along with it."],[1029,1129,"You're fired, Zack."],[1166,1404,"Take your student and get out."],[1754,1904,"Enough of this nonsense."],[1904,2166,"This is just a setup to humiliate my kids."],[2191,2316,"Don't worry, darling."],[2441,2529,"Liars."],[2737,2775,"Oh."],[2891,2941,"Hello?"],[2979,3166,"You ungrateful bitch."],[3179,3379,"I risked everything to get you in"],[3379,3529,"and now I'm fired because of you!"],[3729,3904,"That was the Associate Director."],[3904,4079,"He just yelled at me"],[4079,4279,"and said that I ruined his career."],[4316,4391,"Oh, no,"],[4391,4441,"no."],[4441,4654,"This has got to be a mistake."],[4654,4791,"Oh, please."],[4816,5041,"That was obviously a fake call."],[5041,5216,"Anyone can make a fake call."],[5216,5304,"Why are we still"],[5304,5504,"talking to these people anyway?"],[5541,5695,"Let's call the police and"],[5733,5904,"get them for trespassing already."],[5904,5991,"Enough."],[6054,6441,"Don't you dare insult my sons like that."],[6804,6954,"Dad, look."],[7029,7129,"Just got another email"],[7129,7204,"from the Eagles."]],"41":[[0,125,"Dad, look."],[212,312,"Just got another email"],[312,387,"from the Eagles."],[425,550,"It's from the official team."],[587,725,"I actually got kicked off."],[900,1000,"This can't be."],[1025,1100,"You can't,"],[1300,1487,"you can't actually fire him!"],[1487,1737,"I mean, they're lying!"],[1800,1937,"What a bunch of idiots,"],[1950,2087,"still living in a dream."],[2112,2225,"How did this happen?"],[2300,2362,"Does this mean"],[2362,2475,"that I can't enroll either?"],[2475,2612,"So it's true."],[2637,2887,"Athena's sons really are"],[2887,3025,"the captain of the Eagles"],[3025,3312,"and the director of V Research Institute."],[3337,3462,"No way!"],[3487,3687,"Everyone, listen to me!"],[3725,3950,"Those three are brothers!"],[3950,4187,"Of course they're in a scam together!"],[4187,4387,"They're probably running some con!"],[4425,4562,"Shut up."],[4625,4800,"You can insult me all you want,"],[4800,4925,"but don't you dare"],[4925,5112,"drag my sons into this."],[5212,5350,"Who's trying to mess with Edwin?"],[5800,5900,"You mess with him,"],[5937,6025,"you mess with me."]],"42":[[0,104,"You mess with him,"],[154,229,"you mess with me."],[379,466,"There they are."],[479,566,"Ryan!"],[641,741,"Ah, I see."],[779,929,"Still pulling dirty tricks."],[929,1016,"That's all you got, huh?"],[1116,1254,"You're a bunch of liars."],[1291,1466,"And you stole our gifts."],[1466,1529,"Stole?"],[1591,1779,"You think that caviar is a gift from you?"],[1879,1941,"That's right."],[2016,2091,"This was a gift"],[2091,2316,"from the CEO of the Nolan Group."],[2366,2541,"And they gave me a high salary."],[2591,2666,"Of course they want to"],[2666,2779,"make me feel welcomed."],[2866,2991,"So they sent this"],[2991,3116,"to show their appreciation."],[3116,3166,"Okay."],[3204,3441,"So you're sure that that gift"],[3466,3641,"was from the Nolan Group CEO?"],[3641,3741,"Of course I'm sure."],[3891,4054,"Once I settle into my role"],[4054,4166,"at the Nolan Group,"],[4166,4279,"I'm going to be making millions."],[4279,4479,"You couldn't even dream of"],[4479,4566,"competing with me."],[4641,4804,"Edwin is so successful."],[4841,5016,"My son is incredible."],[5179,5529,"Edwin, you've made me so proud."]],"43":[[8,345,"Edwin, you've made me so proud."],[620,733,"Don't worry, you two."],[770,970,"Once I hit my million dollar salary,"],[970,1145,"I can fix everything."],[1145,1245,"Fix how?"],[1370,1620,"With money, anything is possible."],[1658,1820,"Clara, I can pay for you"],[1820,1995,"to enroll in an even bigger,"],[1995,2170,"more prestigious institution."],[2195,2420,"And Colin, I can fund"],[2420,2620,"an entire private hockey team"],[2620,2833,"and make you the team captain."],[2833,2908,"Really?"],[2945,3083,"That's amazing."],[3195,3308,"Thank you, Edwin."],[3333,3433,"Just wait until I'm fully settled"],[3433,3533,"in Nolan Group."],[3558,3783,"This will be very soon."],[3783,4058,"You know, Edwin, what I heard is that"],[4058,4145,"you're not an executive"],[4145,4258,"at Nolan Group at all."],[4358,4558,"You're just an entry-level employee,"],[4583,4833,"barely making over minimum wage."],[4833,5095,"Yet you promise this million dollar salary."],[5095,5283,"It's just, it's crazy."],[5370,5408,"Yeah?"],[5470,5583,"Well, what do you know?"],[5608,5833,"You bottom-feeding loser."],[5883,6008,"Actually, you're just jealous."],[6058,6108,"That's what it is."],[6108,6170,"You're jealous."],[6170,6233,"That's why you're trying"],[6233,6308,"to tear me down."],[6370,6495,"You know, that's too bad, Edwin."],[6620,6758,"Because you're not going to be"],[6758,6945,"an entry-level employee anymore."],[7170,7283,"You messed with my mother."],[7445,7533,"So I've decided to fire you"],[7533,7595,"from Nolan Group."],[7983,8108,"Listen to yourself."],[8145,8270,"Do you actually think"],[8270,8508,"that you're the CEO of the Nolan Group?"],[8583,8758,"Well, yeah, I am the CEO of Nolan Group."],[8820,8945,"And that caviar?"],[8958,9083,"It wasn't meant for him."],[9133,9258,"It was a gift from me."]],"44":[[4,79,"Liar."],[91,266,"How dare you pretend to be"],[266,366,"our CEO."],[404,504,"I knew it!"],[541,666,"I've been known this all along."],[666,829,"They're nothing but scammers."],[866,1066,"You know, the level of stupidity here"],[1066,1204,"is just truly unbelievable."],[1204,1404,"You shut your mouth."],[1479,1704,"Edwin is a hard-working,"],[1704,1879,"successful man."],[1904,2304,"Unlike you deplorable nobodies."],[2316,2679,"A mother who gifts fake jewelry?"],[2704,2966,"And sons who take credit"],[2966,3191,"for other people's gifts?"],[3229,3304,"Fake jewelry?"],[3304,3479,"Mom, what is she talking about?"],[3504,3754,"I already explained everything to them."],[3754,4016,"But they still believe"],[4016,4154,"that the Cullinan Blue Diamond"],[4154,4216,"is fake."],[4216,4304,"And they think"],[4304,4466,"that the gifts that you sent"],[4466,4679,"actually belong to their kids."],[4679,4779,"Yeah, so that's why"],[4791,4933,"you needed the auction receipt."],[4933,4966,"Yeah."],[4979,5066,"Wow."],[5116,5291,"What a bunch of clueless morons."],[5341,5429,"Please."],[5479,5729,"As if you useless nobodies"],[5729,5991,"could afford any of these gifts."],[6004,6091,"You know, I just can't"],[6091,6204,"wrap my head around this."],[6229,6391,"Why do you keep referring to us"],[6391,6491,"as nobodies?"]],"45":[[0,125,"Oh, come on!"],[150,275,"Isn't it obvious?"],[300,537,"Athena is broke and uneducated."],[550,650,"There's no way"],[650,825,"that her sons can be successful."],[850,1050,"Now, even if you rent"],[1050,1400,"fancy suits and luxury cars"],[1400,1612,"to make yourself important,"],[1637,1987,"you can't hide what you really are."],[2025,2362,"An absolute waste of a human being."],[2412,2600,"And don't you go telling people"],[2600,2725,"you're related to me."],[2787,2962,"Because I do not want"],[2962,3137,"to be embarrassed."],[3137,3487,"Mom, my sons are not liars."],[3487,3662,"Nobody would believe you."],[3725,3825,"And Athena,"],[3850,4100,"I've already disowned you."],[4100,4329,"Your sons no longer mean"],[4329,4487,"anything to me."],[4487,4737,"So, just get out."]],"46":[[29,191,"Just get out."],[379,666,"Edwin, get rid of them."],[716,854,"Ryan, time to move."],[1016,1066,"What?"],[1079,1154,"Wait!"],[1254,1354,"Isn't that the guy"],[1354,1491,"who delivered the gifts earlier?"],[1529,1616,"Why is he back?"],[1679,1804,"Well, I remember you."],[1829,1908,"You're, you're the"],[1908,2054,"CEO's personal assistant,"],[2054,2220,"Mr. uh,"],[2220,2329,"Aaron Davis."],[2366,2566,"You came just in time."],[2616,2720,"This idiot is pretending"],[2720,2841,"to be CEO."],[2854,3054,"Take care of this right now."],[3654,3854,"Mr. Davis, what are you doing?"],[3929,4054,"Did I say something wrong?"],[4254,4354,"You're the idiot."],[4416,4604,"You have it all wrong."],[4604,4729,"He's the one pretending to be"],[4729,4866,"the CEO, not me."],[5354,5529,"How dare you touch my son?"],[5529,5691,"Your son is clearly blind."],[5691,5866,"He just offended a very powerful man."],[5866,6029,"Even if I beat him to death right here,"],[6029,6179,"he'd have no one to blame but himself."],[6179,6316,"A powerful man? - A powerful man?"],[6354,6441,"Who? - Who?"],[6879,7091,"Mr. Nolan, my CEO."],[7129,7304,"Forgive me for arriving late."],[7404,7629,"Wait, did he just call Nolan his CEO?"]],"47":[[312,512,"Mr. Nolan, my CEO."],[562,700,"Forgive me for arriving late."],[975,1100,"That's impossible."],[1137,1387,"How can he be CEO?"],[1387,1475,"Wait!"],[1525,1687,"Does that mean that everything"],[1687,1850,"that Athena has said all day long"],[1850,1962,"is actually true?"],[1962,2112,"Athena, is this true?"],[2237,2475,"Nolan is the CEO of the Nolan Group?"],[2575,2900,"Victor is director of the Institute?"],[2950,3150,"And Felix is captain?"],[3275,3375,"Yes, Dad."],[3450,3587,"And you are?"],[3587,3825,"I am the CEO of the Sterling Group."],[3825,3912,"From the very beginning,"],[3912,4100,"I never lied about anything."],[4212,4475,"What about the expensive caviar"],[4475,4800,"and the truffles and the wine and..."],[4837,4950,"Yes, I mean,"],[4987,5175,"those were gifts from my sons."],[5237,5412,"I bought the Blue Diamond at auction."],[5412,5712,"Every single word that I've said is true."],[5775,5837,"I know."],[5900,5950,"I know."],[6175,6312,"I never doubted you."],[6362,6412,"I..."],[6500,6712,"I've just been gone for so long."],[6750,6837,"So many years."],[6837,7062,"And I, I came back to show you"],[7062,7262,"that I never let you down."],[7325,7512,"I had no idea"],[7512,7687,"that any of this would"],[7687,7825,"end up like this."],[7887,7987,"This has been"],[7987,8237,"a terrible misunderstanding."],[8337,8625,"Finally, our family is together again."],[8750,9000,"Let's just, sit down"],[9000,9137,"have some food"],[9137,9362,"and, and talk things over."],[9425,9575,"We already cut ties."],[9725,9850,"You were about to throw us out,"],[9850,10112,"so there is no reason to stay."]],"48":[[100,237,"Mom's right."],[300,475,"This is all a misunderstanding."],[575,662,"Yeah."],[687,825,"Athena, tell your sons"],[825,962,"not to fire our kids."],[975,1025,"Yeah."],[1025,1100,"Please."],[1125,1325,"It was just a misunderstanding."],[1325,1475,"I mean, the kids are innocent."],[1475,1525,"Yeah."],[1525,1737,"Mr. Nolan, please don't fire me."],[1762,1912,"Director Victor, if you kick me out,"],[1912,2075,"my career is over."],[2125,2262,"Captain Felix, I was wrong."],[2375,2450,"Please."],[2525,2675,"Give me one more chance."],[2737,2800,"Too bad."],[2850,2912,"It was too late."],[2950,3150,"Athena, please."],[3175,3350,"We were wrong."],[3475,3587,"Forgive us."],[3650,3837,"The kids are innocent."],[3837,4150,"Athena, don't be mad."],[4200,4525,"If you don't want to see Gloria and Silas,"],[4525,4700,"I'll make sure they're gone."],[4750,5075,"Just, please, stay for dinner."],[5075,5212,"Enough, Mom."],[5250,5412,"I have had enough"],[5412,5687,"of your disgusting hypocrisy."],[5750,5875,"I see it now."],[5937,6037,"Clear as day."],[6075,6262,"You only care about your children"],[6262,6400,"when they are bringing you"],[6400,6625,"wealth and status."],[6675,6825,"Because that's all you care about."]],"49":[[245,533,"Dad, you have a choice to make."],[633,770,"Do you want to stay here"],[770,1058,"with these selfish, ungrateful people?"],[1270,1408,"Or do you want to come with me?"],[1520,1695,"Look, I know you love them."],[1733,1883,"And I won't force you to leave."],[2033,2320,"But if you stay, know this."],[2395,2583,"I will always protect you."],[2820,3008,"Whoever disrespects Grandpa"],[3045,3258,"is an enemy of the Sterling family."],[3320,3445,"And for the rest of you all,"],[3483,3583,"bullying my mother"],[3583,3695,"doesn't go unpunished."],[3695,3833,"We have absolute power"],[3858,4033,"and connections in every field."],[4045,4133,"So I suggest you"],[4133,4270,"take a look at your own future."],[4308,4545,"Aaron, get the gifts, we're leaving."],[4983,5070,"Hey!"],[5183,5283,"That's mine."],[5370,5495,"That's my caviar."],[5858,5983,"Gloria, this is all your fault."],[5983,6075,"If you hadn't started this fight,"],[6075,6195,"none of this would have happened."],[6195,6295,"Me?"],[6295,6433,"You were right there with me"],[6433,6545,"and now you're blaming me?"],[6558,6658,"You're a dick!"],[6695,6858,"If you hadn't continued"],[6858,6933,"to provoke them,"],[6933,7045,"we wouldn't be in this mess!"],[7045,7170,"Oh, shut up!"],[7170,7345,"Come on, you were part of this, too!"],[7345,7433,"You shut up!"],[7433,7533,"And I am tired of you"],[7533,7625,"doing this all the time."],[7625,7770,"My kids are better than yours."],[7770,7829,"You clearly-"],[7829,7900,"It's all your fault!"],[7900,8029,"No, no, it's not my fault."],[8633,8808,"Athena, wait."],[8883,9058,"Don't take the blue diamond."],[9108,9320,"It was a gift for me, wasn't it?"],[9420,9595,"You can't take it."],[9633,9870,"Athena, the blue diamond!"],[9870,9958,"You gave it to me"],[9958,10133,"as a present for me, remember?"],[10133,10383,"No, don't take the diamond!"],[10808,10933,"A diamond worth"],[10958,11245,"hundreds of millions of dollars."],[11358,11520,"Just like that."],[11720,11808,"Gone."],[12108,12270,"What have I done?"]],"50":[[20,158,"Hey, Mom, don't be sad."],[220,320,"They went way too far."],[358,445,"I'm not sad."],[483,545,"I always knew"],[545,670,"what kind of people they were."],[820,883,"I wanted to know"],[883,1020,"that Grandpa was doing good."],[1033,1083,"You know?"],[1183,1258,"I understand."],[1320,1445,"Oh, by the way,"],[1445,1583,"I set up a special banquet"],[1583,1683,"for you on Mother's Day."],[1808,1983,"I want you to meet my girlfriend."],[2020,2195,"You have a girlfriend?"],[2333,2370,"Yeah."],[2395,2483,"What? - I do."],[2620,2683,"Nolan, wait,"],[2683,2783,"this is great news."],[2783,2933,"Why didn't you tell me earlier?"],[2933,3016,"Don't worry, mom."],[3033,3133,"You'll meet her at the banquet."],[3133,3395,"She's beautiful and kind."],[3570,3633,"Well, then."],[3720,3833,"I can't wait to meet her."],[4370,4420,"Come in."],[4545,4670,"Nolan, I'm here."]],"51":[[141,191,"Hi."],[441,604,"Nolan, why have you been so cold lately?"],[704,816,"I'm so sorry, Daisy."],[866,979,"I've been so busy with work."],[1041,1083,"But hey, we've got"],[1083,1204,"the banquet coming up."],[1204,1379,"And I want to introduce you"],[1379,1441,"to my mom."],[1604,1679,"Really?"],[1841,1991,"I promised to make your mom love me."],[2091,2204,"I, unfortunately,"],[2204,2279,"gotta get back to work."],[2454,2529,"But we haven't been on a date,"],[2529,2616,"like, forever."],[2641,2691,"I know."],[2716,2766,"I know."],[2766,2829,"I'm sorry."],[2854,2991,"But unfortunately, I can't go out tonight."],[3091,3304,"But once things settle down,"],[3304,3416,"I'll make it up to you."],[3654,3729,"Okay, deal."],[3879,3954,"Bye, babe."],[3954,3991,"Bye."],[4016,4116,"Don't forget to miss me."],[4166,4229,"You got it."],[4554,4691,"I hope my mom actually likes her."],[5154,5204,"You ready?"],[5204,5241,"Yeah."],[5479,5516,"Wow."],[5516,5591,"What the hell?"],[5716,5816,"What are you, blind?"],[5816,5941,"Watch where you're going."]],"52":[[45,145,"What are you, blind?"],[145,270,"Watch where you're going."],[295,395,"Oh, I believe you're the one"],[395,533,"who ran into me, Miss."],[583,645,"Oh?"],[708,733,"Yeah."],[733,783,"And who saw?"],[833,945,"Laura, did you see anything?"],[1008,1058,"Nope."],[1133,1308,"You're the one who bumped into me."],[1533,1708,"And now my shoe has a scuff on it."],[1708,1883,"Do you know how much these cost?"],[1895,2108,"$20,000."],[2108,2283,"Either you pay me back for the shoes,"],[2345,2470,"or you get on your knees"],[2470,2558,"and you clean them."],[2558,2645,"Wow."],[2645,3033,"You are absolutely ridiculous."],[3058,3233,"Ms. Daisy, we're in the main lobby"],[3233,3320,"of the Nolan group."],[3370,3483,"If you make a scene here,"],[3483,3608,"your boyfriend won't be happy."],[3708,3808,"Well, it's your lucky day."],[3845,3958,"Consider yourself spared."],[4008,4108,"Laura, we're leaving."],[4683,4883,"What an arrogant brat."],[6795,6908,"Has Nolan arrived yet?"],[6908,7083,"Mr. Serling will be here promptly."],[7083,7158,"They asked you to go ahead"],[7158,7283,"and enjoy the banquet first."],[7395,7458,"Okay."]],"53":[[1154,1454,"Daisy, tonight is crucial for you."],[1554,1766,"If our family wants to secure ties"],[1766,1854,"with the Sterlings,"],[1854,2104,"this is our best opportunity."],[2104,2191,"Exactly."],[2191,2354,"Winning over Nolan's mother"],[2354,2466,"should be your top priority."],[2516,2641,"Relax, Mom and Dad."],[2716,2891,"Making his mom love me"],[2891,3016,"will be a piece of cake."],[3541,3666,"Nolan never told me"],[3666,3816,"what his girlfriend looks like."],[3866,4029,"Which one is my"],[4029,4154,"future daughter-in-law?"],[4379,4491,"What the hell are you doing here?"],[4591,4729,"Oh, you again."],[4816,4966,"I just can't seem to get rid of you."],[5004,5179,"How did you get into an event like this?"],[5229,5491,"Daisy, who is this woman?"],[5566,5704,"An absolute nobody."],[5779,6054,"She rudely crashed into me yesterday"],[6054,6266,"and ruined my limited edition heels."],[6266,6466,"And now she's here"],[6466,6604,"dressed like she belongs."],[6654,6929,"People like you don't belong here."],[6979,7129,"How did you even get past security?"],[7166,7454,"I belong here more than any of you."],[7579,7729,"And I'm here to meet"],[7729,7866,"my future daughter-in-law."]],"54":[[37,125,"Daughter-in-law?"],[150,275,"Like anyone would want you"],[275,387,"to be their mother-in-law."],[412,512,"Pathetic."],[762,912,"Miss, don't you think"],[912,1075,"you're going too far?"],[1100,1175,"Too far?"],[1237,1350,"Well, I haven't even started."],[1425,1587,"Do you know what kind of event this is?"],[1650,1862,"If you mess this up for me, you'll pay."],[1950,2187,"Who the hell is this classless woman?"],[2250,2387,"And why is she even here?"],[2450,2612,"I think it's time for you to leave."],[2712,2837,"If she stays here any longer,"],[2837,2937,"she'll ruin our plan."],[3012,3175,"There's leftovers on the way out."],[3237,3362,"Disgrace."],[3375,3587,"I was invited to this event."],[3637,3750,"And I'm not going,"],[3850,3925,"anywhere."],[3987,4125,"You must be joking."],[4137,4287,"This is a Mother's Day banquet"],[4287,4450,"hosted by Nolan Group's CEO"],[4450,4537,"for his mother."],[4625,4800,"Why on earth would anyone invite you?"],[4900,5100,"Miss, do you even know who I am?"],[5137,5187,"Yeah."],[5275,5387,"A pathetic woman"],[5387,5512,"who's delirious enough"],[5512,5662,"to think that she belongs here."],[5775,6012,"Yeah, I'm the guest of honor"],[6050,6150,"at this event."],[6212,6375,"Because I gave birth"],[6400,6637,"to the CEO of Nolan Group."]],"55":[[745,895,"The audacity."],[895,1045,"Do you even know"],[1045,1295,"who the CEO of the Nolan Group is?"],[1370,1695,"How dare you claim to be related to him?"],[1758,1908,"This deplorable woman"],[1908,1975,"claiming to have ties"],[1975,2120,"to the Sterling family."],[2120,2295,"That's just ridiculous."],[2295,2408,"Unworthy people like you"],[2408,2620,"don't belong in an event like this."],[2645,3020,"And what makes you think you belong?"],[3133,3420,"My daughter is more than qualified."],[3420,3620,"Daisy's the COO of the SN Group."],[3645,3845,"She's young and accomplished."],[3870,4033,"And she has every right to be here"],[4033,4145,"whereas you don't."],[4183,4258,"That's right."],[4283,4570,"Daisy here is young, beautiful,"],[4570,4720,"and intelligent."],[4770,4908,"Unlike you, old woman."],[4983,5283,"So because she's a COO"],[5283,5400,"that gives her the right to"],[5400,5520,"judge people?"],[5520,5595,"Shut up!"],[5683,5758,"Today's the day"],[5758,5945,"that I meet someone very important."],[5995,6170,"It's one thing for you to crash the party."],[6170,6308,"It's another thing for you"],[6308,6383,"to pretend to be"],[6383,6533,"Nolan Sterling's mom."],[6533,6683,"I'm Nolan's girlfriend."],[6758,6845,"You're not fooling me."],[6883,6970,"What?"],[6995,7145,"She's Nolan's girlfriend?"]],"56":[[33,145,"So this is the woman"],[145,308,"Nolan wanted to introduce me to."],[333,495,"Is he out of his mind?"],[520,645,"How could he possibly"],[645,758,"choose someone like her?"],[783,870,"What are you looking at?"],[983,1095,"Do yourself a favor"],[1095,1208,"and leave this banquet"],[1208,1345,"before it gets ugly for you."],[1408,1483,"I have more important"],[1483,1558,"things to do"],[1558,1783,"than waste my time looking at you."],[1833,1945,"Oh, really?"],[1945,2058,"You sure about that?"],[2120,2233,"You might regret that later."],[2370,2470,"The only thing I'd regret"],[2470,2608,"is letting you stay a second longer."],[2733,2845,"And what makes you think"],[2845,3120,"that you have the right to kick me out?"],[3120,3220,"She has every right."],[3295,3445,"She is the soon-to-be wife"],[3445,3583,"of the Nolan Group CEO."],[3620,3720,"Someone like her can do"],[3720,3845,"whatever she likes"],[3845,4120,"to an irrelevant nobody like you."],[4208,4383,"So what you're saying is"],[4383,4708,"as long as someone is powerful and rich,"],[4745,4820,"they have the right"],[4820,5020,"to walk all over other people."],[5020,5170,"Is that how you see the world,"],[5170,5258,"Miss Daisy?"],[5345,5433,"Obviously."],[5508,5608,"People like you don't deserve"],[5608,5708,"a second glance"],[5708,5808,"from someone like me."],[5870,5958,"Fascinating."],[6083,6245,"And yet I heard someone say"],[6245,6520,"that you are beautiful and kind."],[6670,6883,"You may have a pretty face,"],[6945,7183,"but your heart is empty."],[7320,7508,"I don't reserve my kindness"],[7558,7695,"for nobodies like you."]],"57":[[725,1062,"So, Nolan, is our future sister-in-law"],[1062,1137,"almost here?"],[1150,1300,"We're waiting for you to introduce us."],[1337,1487,"Yes, I will, brother."],[1500,1675,"I just hope mom likes her."],[1737,1812,"Let's go inside."],[2000,2075,"Of course she will."],[2112,2225,"Of course she will. - Thank you!"],[2275,2375,"I'm a nobody?"],[2437,2525,"You sure about that?"],[2587,2662,"You heard me."],[2737,2812,"Nobody."],[2862,2937,"Nothing."],[3000,3112,"Non-existent."],[3225,3375,"Even if I was the help,"],[3437,3550,"at least I would be somebody"],[3550,3737,"making an honest living."],[3787,3987,"How is it that you can just"],[3987,4212,"insult people like this?"],[4312,4412,"Did I hit a nerve?"],[4450,4587,"You're just wasting air"],[4625,4850,"and dragging down the country's GDP."],[4862,5062,"Let's face it, people like you"],[5062,5337,"just don't deserve to exist."],[5616,5862,"And my son actually called you kind."],[5925,6050,"What a joke."],[6050,6162,"Come on."],[6200,6275,"We're still pretending"],[6275,6362,"to be his mom?"],[6362,6437,"Give it a rest."],[6562,6625,"I see."],[6687,7087,"Daisy, let me make one thing very clear."],[7137,7300,"As long as I'm alive,"],[7337,7600,"you will never marry my son."]],"58":[[129,279,"Are you insane?"],[354,504,"You're still deluding yourself"],[504,779,"that you're the CEO's mother."],[966,1041,"Look at you."],[1041,1116,"Do you really believe"],[1116,1254,"you could raise a CEO?"],[1279,1429,"How about we make a little wager"],[1429,1679,"since you all seem to know everything?"],[1729,1791,"A bet?"],[1829,2154,"If the CEO of Nolan Group is my son,"],[2191,2491,"then you, your entire family,"],[2491,2629,"will leave this banquet"],[2629,2954,"and leave us alone forever."],[3316,3366,"Wow."],[3366,3666,"You really do not give up, do you?"],[3666,3829,"If Nolan was your son,"],[3829,4004,"I'm sure he'd be too ashamed"],[4004,4079,"to admit it."],[4141,4341,"Absolutely delusional."],[4566,4679,"What's wrong, Daisy?"],[4741,4829,"Are you and your parents"],[4829,4941,"scared to make a bet?"],[5016,5129,"Who says I'm afraid?"],[5179,5254,"You want to bet?"],[5291,5354,"Fine."],[5404,5466,"Let's bet."],[5516,5804,"But if you lose, you will become the help."],[5854,6041,"And you'll clean this entire banquet"],[6041,6141,"by yourself."],[6191,6441,"On your hands and knees."],[6479,6566,"In front of everyone."],[6666,6804,"So they can see what you truly are."],[6970,7066,"Nothing."],[7191,7266,"Deal?"],[7479,7529,"Deal."],[7941,8066,"Alright, but you brought this"],[8066,8154,"on yourself, so,"],[8229,8416,"don't come crying to me when you lose."],[8454,8679,"Let's see if you're still laughing"],[8679,8779,"when Nolan gets here."]],"59":[[29,216,"Miss, the banquet's about to start."],[229,429,"We cannot let her ruin things for us."],[429,529,"We need to get rid of her"],[529,616,"before Mr. Sterling"],[616,866,"and his actual mother arrive."],[941,1016,"Security."],[1079,1216,"Remove this trespasser."],[1241,1329,"What? No."],[1341,1504,"What the hell do you think you're doing?"],[1541,1654,"What does it look like I'm doing?"],[1679,1816,"I'm getting you ready for your punishment"],[1816,1954,"when you lose this bet."],[1991,2179,"No, Nolan isn't even here yet."],[2179,2266,"The bet isn't-"],[2270,2370,"Why should I wait?"],[2416,2516,"When Nolan gets here,"],[2516,2641,"he's going to be too busy"],[2641,2766,"introducing me to his mother."],[2779,2941,"I can't have you ruining the moment."],[2966,3079,"So let's settle this now."],[3154,3204,"Exactly."],[3216,3341,"What could be more important"],[3341,3416,"than my daughter"],[3416,3566,"meeting her future mother-in-law?"],[3654,3766,"We can't let this bitch"],[3766,3879,"ruin everything we've worked for."],[3954,4166,"So, what corner of the room"],[4166,4304,"would you like to start with first?"],[4354,4591,"You are beyond saving."],[4629,4941,"Look, if Nolan really is your son,"],[4941,5091,"then when he gets here he'll save you."],[5129,5229,"But if you're lying,"],[5229,5404,"which we know you are,"],[5441,5529,"you lose the bet."],[5591,5729,"So might as well get a head start."],[5904,5991,"Put her on her knees."],[6066,6116,"What?"],[6141,6266,"No, stop it."],[6279,6329,"Get off."],[6379,6491,"What is going on?"],[6529,6666,"Let go of me!"]],"60":[[41,166,"Let go of me!"],[629,741,"Serves you right."],[766,941,"That's what you get for messing with me."],[1091,1154,"Mom!"],[1254,1404,"Get your hands off my mother."],[1441,1554,"That is Nolan Sterling."],[1716,1879,"What the hell is going on here?"],[2166,2366,"Oh my God, I know those three."],[2366,2495,"The one in the middle,"],[2495,2629,"is Nolan Sterling,"],[2629,2791,"the CEO of Nolan Group."],[2791,2904,"And the other two?"],[2904,3141,"Victor, the genius scientist."],[3141,3416,"And Felix, the pro hockey player."],[3416,3616,"And they just called her mom."],[3679,3804,"So she wasn't lying."]],"61":[[175,350,"This can't be real."],[350,550,"So she's, really?"],[687,837,"Judging by their reaction,"],[875,1037,"she must be the very woman"],[1037,1237,"Mr. Sterling wanted to introduce you to."],[1337,1425,"Oh my God."],[1475,1625,"I just humiliated her."],[1650,1737,"I had her on her knees."],[1737,1825,"What have I done?"],[1912,2087,"Daisy, what the hell is going on here?"],[2087,2262,"Nolan, this is just like"],[2262,2412,"a huge misunderstanding."],[2412,2525,"Oh, let me explain."],[2587,2850,"This wonderful girlfriend of yours,"],[2850,3037,"Nolan, accused me of"],[3037,3162,"stepping on her shoes"],[3162,3312,"outside of your office."],[3312,3587,"And today, humiliated me"],[3587,3712,"in front of everyone"],[3712,4100,"and tried to make me scrub the floors."],[4137,4262,"It's not like that."],[4262,4475,"I thought that she was lying."],[4500,4587,"So that makes it okay"],[4587,4675,"to bully my mother."],[4841,4891,"Daisy,"],[4962,5066,"I was gonna introduce you"],[5066,5187,"to my entire family."],[5225,5325,"What is wrong with you?"],[5325,5487,"Have you lost your mind?"],[5495,5587,"No, Nolan."]],"62":[[79,366,"Daisy, now that we know the truth,"],[366,566,"I won the bet, didn't I?"],[729,916,"Of course you did, Miss Sterling."],[1041,1129,"I'm so sorry."],[1129,1204,"Please forgive me."],[1279,1391,"We're really sorry."],[1391,1504,"We, we, we had"],[1504,1579,"no idea."],[1579,1691,"We didn't know any better."],[1716,1879,"Please, don't hold it against us."],[1916,2016,"Weren't you the one"],[2016,2204,"who was just calling me a, a nobody?"],[2304,2391,"What happened?"],[2516,2679,"Why is everybody so quiet?"],[2679,2766,"Look, I was wrong."],[2829,2891,"Okay, please just give me"],[2891,2941,"another chance-"],[2941,3029,"I told you."],[3141,3354,"So long as I am alive,"],[3466,3804,"you will never marry my son."],[4066,4291,"Daisy, we're done."],[4316,4691,"No, no, Nolan, please, please, don't."],[4716,4904,"Security, get them out."],[4904,5004,"No, what?"],[5054,5166,"No, no, you can't."],[5166,5291,"It was a mistake."],[5291,5416,"It was just a mistake!"],[5416,5529,"I'm your girlfriend!"],[5529,5666,"We're supposed to get married!"],[6016,6079,"Yikes."]],"63":[[279,391,"Mom, I'm so sorry"],[391,504,"I let that happen to you."],[629,704,"You've already gone through"],[704,816,"so much already,"],[816,979,"and I just didn't know what was going on."],[1029,1154,"Honey, it's okay."],[1216,1329,"I don't blame you."],[1429,1516,"If anything,"],[1516,1779,"that Daisy was really good at pretending."],[1966,2254,"But hey, do me a favor next time."],[2504,2629,"Can you please find yourself"],[2629,2816,"a genuinely kind girl?"],[2941,2991,"Yeah?"],[2991,3066,"I will."],[3066,3116,"I will."],[3141,3191,"I promise."],[3191,3391,"And I won't let anything like this"],[3391,3466,"ever happen again."],[3654,3779,"What a mess."],[3941,4104,"A perfectly good Mother's Day."],[4166,4279,"Ruined by them."],[4366,4541,"Hey, doesn't mean it has to end."],[4629,4691,"I mean, now that"],[4691,4854,"those irrelevant losers are gone,"],[4854,5079,"we can finally celebrate properly!"],[5241,5304,"You know what?"],[5366,5454,"Felix is right."],[5516,5729,"Forget about those irrelevant people."],[5766,6029,"Tonight, you're the star of the show."],[6208,6316,"Champagne, please."],[6354,6441,"Ah, there you go."],[6445,6483,"Oh!"],[6554,6629,"Sorry."],[6666,6929,"Everyone, I'd like to propose a toast."],[7029,7229,"Today, we celebrate Mother's Day."],[7266,7341,"And I think we should"],[7341,7466,"raise our glass"],[7466,7566,"to the guests of honor."],[7604,7729,"My incredible mother,"],[7770,7875,"Athena Sterling."],[8004,8191,"Mom, thank you"],[8191,8354,"for being such a great role model."],[8454,8554,"Thank you for everything"],[8554,8641,"you've done for us."],[8666,8804,"You mean more to us than,"],[8866,9029,"anything in the whole entire world."],[9191,9516,"To Athena, a fabulous mother,"],[9516,9975,"a self-made CEO, and a true queen."],[10029,10116,"To Athena."],[10191,10316,"To Athena!"],[10366,10466,"Let's toast to that."]]}