{"1":[[637,725,"Dr. Gray."],[762,866,"This whole operation is"],[866,954,"riding on you."],[1279,1350,"Here."],[1437,1491,"Be careful."],[1558,1695,"It's Derek Wolf’s new kidney."],[1754,1854,"Get it there safe."],[1991,2087,"I'm counting on you."],[3025,3095,"Let's go."],[3112,3195,"Straight to the airport."],[3420,3504,"Yes, Mr. Wolf."],[3504,3637,"Dr. Gray is on the way."],[3666,3729,"Perfect."],[3741,3854,"Thank you, Doctor Franco,"],[3854,4029,"for everything you're doing for my father."],[4358,4470,"All right, Gentlemen,"],[4504,4641,"sync your watches."],[4962,5058,"Dr. Gray's plane"],[5058,5245,"lands in Miami in two hours."],[5383,5466,"Team A,"],[5491,5683,"make sure that flight stays on track."],[5716,5870,"No surprises."],[5870,5979,"Yes, sir!"],[6012,6087,"Team B,"],[6120,6212,"you're with Ada."],[6258,6425,"Meet Dr. gray at the airport."],[6425,6583,"I don't care what you have to do."],[6583,6820,"Keep him and that kidney safe."],[6820,7116,"This operation has to happen on time."],[7116,7237,"Yes, sir!"],[7283,7387,"This is not just about"],[7387,7545,"saving my father's life."],[7570,7820,"This is about saving our legacy."],[7879,7979,"No leaks."],[7979,8116,"If anything goes sideways,"],[8116,8279,"you come to me first."],[8316,8454,"And if any of you"],[8454,8570,"breathe a word of this"],[8570,8725,"to anyone on the outside."],[8733,9033,"I promise it will not end pleasantly."],[9075,9170,"Move out."],[9170,9262,"Yes, sir."],[9350,9462,"Sir, from what I've heard,"],[9462,9579,"Derek Wolf is the biggest"],[9579,9712,"arms dealer in the area."],[9745,9837,"His family has been at the top"],[9837,9995,"of the Forbes list for years."],[10033,10187,"The surgery isn't just about"],[10187,10283,"keeping him alive,"],[10283,10375,"it'll make or break the whole"],[10375,10487,"Wolf dynasty."],[10487,10579,"Are you sure we should"],[10579,10720,"send Shaun alone in this?"],[10783,10854,"There wasn't enough time"],[10854,10954,"to rent a private jet."],[11037,11104,"And with Derek's"],[11104,11275,"complicated reputation,"],[11375,11516,"couldn't risk this going public."],[11516,11683,"Not even Erik Wolf,"],[11683,11841,"Matt Wolf’s own son knows about this."],[11854,11929,"Well,"],[11929,12004,"if we're down to one man,"],[12004,12091,"at least it’s Shaun."],[12154,12262,"If anyone can handle this,"],[12262,12341,"it's him."],[12391,12508,"May God be with him."]],"2":[[591,670,"Excuse me."],[687,775,"How long until boarding"],[775,879,"for the Miami flight?"],[925,1008,"Ten minutes, sir."],[1058,1145,"Alright."],[1145,1212,"Thanks."],[1945,2062,"Hi, Baby."],[2125,2287,"Yeah, I'll be boarding soon."],[2354,2395,"Uh-huh."],[2395,2470,"You better have that"],[2470,2575,"gift waiting when I arrive."],[2625,2691,"Hey, Baby."],[2691,2854,"Don't worry, it's all set, okay?"],[2912,3045,"Just call me the second you land."],[3058,3162,"You are the best."],[3162,3233,"Thanks, Baby."],[3245,3308,"Okay."],[3329,3508,"Kisses, muah, muah, muah, muah, muah!"],[3679,3820,"This trip is it, Jess."],[3875,4062,"Lock in that ring and we are in."],[4062,4179,"High society,"],[4237,4379,"here we come."],[4429,4691,"The Wolf family is basically royalty."],[4720,5012,"And it all starts with Erik's grandpa,"],[5012,5095,"Derek Wolf."],[5125,5195,"Once I get"],[5195,5275,"Grandpa Derek's"],[5275,5391,"approval and marry Erik,"],[5433,5500,"we're golden."],[5537,5712,"Those million dollar debts,"],[5758,5920,"we blew in loan sharks?"],[5995,6079,"Gone!"],[6191,6308,"A little pout to Erik,"],[6308,6450,"and the Wolf family will wipe it all."],[6495,6620,"That's my girl."],[6700,6866,"Attention passengers,"],[6866,7200,"flight AC 3165 to Miami,"],[7200,7295,"is now boarding."],[7300,7366,"Come on, Mom,"],[7366,7591,"let's get on our flight to happily ever after."],[7891,7950,"Sorry."],[8020,8100,"Excuse me."],[8129,8225,"Wait, Jess,"],[8225,8354,"I got to hit the ladies room first."],[8400,8500,"You go ahead, I'll catch up."],[8512,8566,"Oh, okay."],[8566,8729,"Yeah, I'll just meet you on the plane."],[8950,9033,"Sorry."],[9033,9125,"Watch where you're going,"],[9125,9237,"you broke piece of shit."],[9320,9362,"What?"],[9362,9483,"Racing home to your mom's funeral"],[9483,9545,"or something?"]],"3":[[1533,1579,"Oh,"],[1608,1695,"I'm sorry sir."],[1704,1887,"Did you need me to store that for you?"],[1900,1958,"Oh."],[2004,2091,"No, thank you."],[2112,2262,"This is extremely important."],[2287,2391,"I'd rather keep it right here."],[2454,2579,"Of course. And let me know"],[2579,2700,"if you need anything else."],[2733,2816,"Yeah,"],[2816,2904,"great."],[4237,4275,"Hey,"],[4275,4391,"what the hell do you think you're doing?"],[4441,4525,"Can't you see my mom"],[4525,4604,"isn't on board yet?"],[4616,4662,"Ma'am,"],[4670,4808,"we're about to take off, and"],[4808,4908,"this isn't safe."],[4925,4991,"Take off?"],[5020,5158,"Over my dead body."],[5179,5379,"This door stays open until my mom's butt"],[5379,5454,"is in her seat."],[5495,5662,"I'm a VIP with this airline."],[5679,5737,"So,"],[5737,5837,"you can go ahead and tell your"],[5837,5916,"little captain"],[5925,6087,"that he's not going anywhere"],[6108,6233,"until my mom boards."],[6287,6341,"Ma’am,"],[6341,6433,"I understand."],[6483,6600,"But we're on a schedule,"],[6600,6766,"and we can't delay take off,"],[6766,6883,"for one passenger."],[6887,6983,"Schedule?"],[7016,7058,"Well,"],[7058,7145,"then consider your schedule"],[7145,7300,"officially delayed."],[7329,7433,"Because this plane isn't moving"],[7433,7541,"without my mom on it."],[7545,7641,"Come on, Miss."],[7641,7762,"I’ve got a meeting to catch."],[7762,7929,"Yeah, we're all on the clock here."],[7941,8133,"Can't hold up a whole flight for one person."],[8133,8262,"That's not how this works."],[8283,8370,"Book a private jet"],[8370,8466,"if you're in such a hurry."],[8508,8637,"What? Can't afford it?"],[8691,8791,"Then sit down,"],[8791,8883,"shut up,"],[8883,9041,"and be patient."],[9054,9200,"It's not like it's going to kill anyone"],[9200,9308,"if you wait a few more minutes."],[9320,9416,"Ma'am, please."],[9462,9500,"Okay?"],[9566,9650,"Oh my God."],[9691,9791,"I have something extremely"],[9791,9866,"important today,"],[9866,9933,"and I can't afford even"],[9933,10045,"even the slightest delay."],[10108,10183,"Important?"],[10245,10370,"I seriously doubt some"],[10370,10495,"bottom rung loser like you"],[10495,10683,"has anything that actually matters."],[10758,10912,"I don't care what your excuses are."],[10912,10983,"Even if you told me"],[10983,11070,"the whole world was going to end"],[11070,11129,"if we don’t fly,"],[11129,11316,"but this plane still isn't going anywhere"],[11316,11416,"without my mom on it!"]],"4":[[112,162,"Okay."],[241,279,"Look."],[279,329,"Hey."],[366,437,"How about this, okay?"],[475,562,"I'll cover your flight."],[600,683,"You and your mom's."],[1045,1191,"You broke piece of shit."],[1283,1433,"You seriously think"],[1433,1650,"I need your crumpled up loser money?"],[1845,2012,"How dare you insult me?"],[2025,2091,"Yeah, well,"],[2091,2300,"your mom missed her boarding time, so"],[2341,2391,"all of us shouldn't be"],[2391,2512,"held accountable for that."],[2512,2579,"Yeah, lady."],[2579,2716,"This is ridiculous."],[2750,2895,"You lowlifes should be grateful you're"],[2895,3079,"on the same plane as me and my mom."],[3091,3195,"Do you know who I am?"],[3195,3316,"Who my fiancé is?"],[3475,3583,"It doesn't matter who you"],[3583,3683,"you or your fiancé are."],[3770,3833,"You don't have the right to hold"],[3833,3937,"the entire plane hostage"],[3937,4075,"just because you feel entitled."],[4212,4279,"Okay."],[4445,4566,"Listen, alright."],[4566,4716,"I'm transporting a human kidney."],[4716,4870,"A man's life depends on it, okay?"],[4870,4937,"Please."],[5000,5116,"We're already ten minutes behind."],[5158,5283,"He can't wait any longer."],[5287,5379,"Okay,"],[5379,5445,"even"],[5445,5666,"if he's so fragile,"],[5666,5725,"a few minutes"],[5725,5841,"wouldn't change anything."],[5941,6004,"And,"],[6004,6091,"if it does,"],[6137,6366,"well, then I guess he wasn't meant to last."],[6404,6558,"What the hell is wrong with you?"],[6583,6733,"You'd screw over a whole plane"],[6733,6825,"for one person?"],[6825,6908,"Have you ever heard of"],[6908,7025,"basic human decency?"],[7025,7108,"Delays like this"],[7108,7258,"cost people serious money."],[7258,7354,"Blah, blah, blah."],[7354,7616,"You poor people and all your complaining."],[7662,7766,"But at the end of the day,"],[7766,7929,"it's still just about cash, right?"],[8329,8466,"Go cry into that."]],"5":[[262,312,"What?"],[362,450,"Not enough?"],[804,875,"How about now?"],[1075,1204,"Take your little payday,"],[1229,1312,"sit down,"],[1312,1400,"and shut up,"],[1412,1537,"like the peasants you are."],[1550,1725,"Money doesn't pay for everything, Miss."],[1800,1950,"Especially not this."],[2075,2187,"How greedy are you people?"],[2237,2304,"That's fine."],[2337,2412,"Money's the one thing"],[2412,2525,"I'll never run out of."],[2779,2904,"Here's 40 grand."],[3100,3216,"Satisfied now?"],[3475,3529,"Boss,"],[3541,3604,"Dr. Gray's flight is already"],[3604,3712,"ten minutes behind."],[3750,3829,"What?"],[3916,4029,"Get him on the line,"],[4029,4225,"and find out what the hell is going on."],[4225,4275,"On it."],[5037,5100,"Dr. Gray?"],[5125,5229,"This is Mr. Wolf's assistant."],[5229,5312,"We've met before."],[5337,5412,"I need to know why"],[5412,5491,"haven't it taken off yet?"],[5529,5675,"There's a passenger blocking takeoff"],[5675,5750,"because her mom's late."],[5812,5950,"She's refusing to let the plane leave."],[5975,6037,"Alright."],[6050,6141,"I'll contact the airport"],[6141,6250,"and let them handle it."],[6550,6687,"Ma'am, is that your mother?"],[6737,6775,"Oh."],[7141,7200,"Never mind."],[7225,7312,"She's here."],[7341,7400,"Good."],[7400,7512,"Meet you at the airport."],[7550,7654,"Ma'am, please hurry."],[7654,7787,"We need to close the cabin."],[7850,7937,"What's the big deal?"],[7937,8062,"It's only a few minutes."],[8141,8279,"Nobody's dying."]],"6":[[670,741,"Sorry."],[787,983,"Any idea how much longer until we land?"],[983,1141,"About 20 minutes, sir."],[1216,1283,"Got it."],[1283,1375,"Thanks."],[2308,2358,"Hey."],[2408,2508,"Mom, what's wrong?"],[2587,2770,"Oh, why won't this damn window open?"],[2954,3020,"Attendent, hey!"],[3041,3091,"Attendent."],[3091,3129,"Ma'am,"],[3129,3208,"how can I help you?"],[3208,3312,"I can't breath."],[3312,3387,"Open the windows"],[3387,3500,"so I can get some air."],[3550,3625,"I'm sorry,"],[3625,3745,"the windows don't open."],[3745,3895,"This is a pressurized cabin,"],[3895,3966,"and they're sealed."],[3991,4075,"What kind of"],[4075,4183,"crappy airline is this?"],[4254,4329,"Figure it out,"],[4425,4525,"open the window."],[4575,4675,"Or I will file a"],[4675,4783,"complaint against you."],[4800,4916,"I'm really sorry, ma'am, but"],[4916,5041,"there's nothing I can do."],[5450,5600,"I thought they came from money."],[5641,5791,"Turns out they're just a couple of"],[5791,6016,"clueless country bumpkins."],[6054,6141,"Even kids know airplane"],[6141,6250,"windows don't open."],[6287,6370,"What a joke."],[6583,6716,"I don't feel so good."],[6762,6820,"Mom?"],[6929,6975,"Mom?"],[7120,7162,"Help!"],[7195,7262,"Somebody help!"],[7650,7758,"Well, then say something."],[7758,7866,"What is wrong with her?"],[7866,7962,"She's in distress."],[7966,8154,"We need to start emergency care now,"],[8154,8337,"or I don't think she's gonna to make it."],[8379,8508,"Well, then do something."],[8516,8608,"I swear to God,"],[8608,8712,"if something happens to my mom,"],[8712,8808,"every single person"],[8808,9000,"on this plane is gonna pay for it."]],"7":[[0,133,"Ma'am, I need you to stay calm."],[133,195,"We're doing everything"],[195,254,"that we can."],[341,479,"Is there a doctor on board,"],[479,658,"or anyone with medical training?"],[679,820,"We have a patient in critical need."],[908,1054,"My top priority is getting this"],[1054,1166,"kidney to Derek Wolf."],[1291,1337,"But..."],[1500,1620,"Please, anyone at all."],[1620,1745,"This woman might not make it."],[1745,1812,"Please."],[1812,1929,"We're running out of time."],[1958,2075,"Just please wake up."],[2441,2537,"I'm a doctor."],[2641,2704,"Damn."],[2737,2854,"Talk about luck."],[2891,3091,"There's actually a doctor on board."],[3316,3375,"Hey, hey."],[3404,3579,"You know, after the way she treated you,"],[3600,3720,"you don't owe her anything."],[3720,3779,"You hear that?"],[3791,3895,"He said he's a doctor."],[3895,3983,"Let him through."],[3983,4041,"Now."],[4041,4100,"Sir,"],[4100,4233,"are you really a doctor?"],[4237,4291,"Yes,"],[4350,4412,"I'm a doctor."],[4425,4579,"Then what the hell are you waiting for?"],[4620,4787,"Your job is to save people, right?"],[4787,4895,"Then get your ass over here"],[4895,4979,"and fix my mom."],[5112,5212,"And now he's supposed to just"],[5212,5279,"help you?"],[5329,5495,"After the way you humiliated him?"],[5508,5562,"Yeah,"],[5587,5720,"she was throwing money in his face"],[5720,5808,"two minutes ago."],[5866,6012,"Funny how the tables have turned."],[6025,6225,"And asking for help with that attitude?"],[6262,6333,"Karma's a bitch."],[6333,6487,"If it were me, I'd let her sit in it."],[6583,6720,"Doctor, please."],[6733,6912,"Please, just, just help her."],[6958,7058,"I was wrong."],[7058,7112,"Okay?"],[7112,7262,"I'll give you anything you want."],[7291,7462,"Money. I'll, I'll give you a ton of money."],[7462,7583,"Just please save my mom."],[7583,7725,"I don't want your money, okay?"],[8133,8254,"Please step aside."],[8320,8416,"I'm a doctor."],[8433,8508,"And I took an oath."],[8595,8750,"I can't just sit back and watch her die."]],"8":[[45,212,"I can’t just sit back and watch her die."],[733,854,"But just so we're clear."],[854,979,"Things could go sideways."],[979,1129,"But I will do everything that I can."],[1129,1183,"I just..."],[1220,1304,"don't know if it'll help."],[1354,1495,"You need to be ready for that."],[1533,1629,"I know, I know."],[1629,1704,"I, I, I swear,"],[1704,1812,"I won't blame you if anything happens."],[1812,1916,"Just, just please,"],[1950,2062,"save my mom."],[2062,2133,"All right."],[3320,3445,"She's in cardiac arrest."],[3445,3562,"We need to lay her flat now."],[3729,3862,"Slow, slow, slow."],[4320,4454,"I'm going to have to do CPR."],[4491,4616,"But in these conditions,"],[4616,4741,"if things go wrong..."],[4779,4837,"I get it."],[4837,4966,"I swear I won't hold it against you"],[4966,5087,"if anything happens, just please"],[5133,5245,"do what it takes."],[5295,5383,"Alright."],[7250,7304,"What?"],[7366,7458,"What happened?"],[7479,7608,"Oh my God."],[7608,7679,"Mom,"],[7679,7775,"you're awake."],[7800,7958,"This man just saved your life."],[8375,8433,"Easy, mom."],[8433,8491,"Let's get you up."],[8575,8633,"Slow."],[9341,9404,"Ow."],[9404,9491,"What is it?"],[9579,9787,"I think my rib is broken."],[10100,10216,"Oh, no, you don’t."],[10216,10341,"You just broke my mom's rib."],[10341,10516,"You don't get to walk away like that."],[10562,10812,"It was likely from the chest compressions."],[10812,10962,"It's a common risk."],[10962,11100,"A common risk?"],[11195,11370,"What kind of doctor,"],[11370,11475,"breaks bones"],[11475,11604,"when trying to save someone?"],[11620,11837,"You worthless piece of shit."]],"9":[[50,162,"You're a total lunatic."],[212,300,"What the hell's wrong with you?"],[300,475,"He just saved your mother's life."],[475,562,"Unbelievable."],[587,691,"You were begging him for help"],[691,787,"five minutes ago."],[825,962,"And what's more important, lady?"],[1004,1162,"A busted rib or a beating heart?"],[1216,1354,"Shut your filthy mouth,"],[1354,1504,"you shit eating peasants."],[1550,1612,"My mom,"],[1629,1779,"is worth more than your entire"],[1779,1941,"sorry bloodlines combined."],[1987,2166,"I warned you about the complications,"],[2166,2300,"and you agreed."],[2337,2512,"I wouldn't have started otherwise."],[2512,2587,"Agreed?"],[2679,2741,"Me?"],[2837,2887,"Okay."],[2887,3112,"When the hell did that happen?"],[3150,3225,"I'm sorry."],[3225,3312,"I must have missed the part"],[3312,3425,"where I signed off"],[3450,3662,"on you breaking my mother's rib."],[3679,3775,"Are you kidding me?"],[3800,3912,"Everyone heard you."],[3937,3987,"That's right."],[4025,4150,"I heard it clear as day."],[4179,4287,"You gave him the go."],[4312,4429,"Don't try to flip the script now."],[4429,4537,"You asked him for help."],[4579,4641,"Hey, hey."],[4729,4791,"Everyone,"],[4887,4979,"it's fine."],[5079,5237,"All that matters is that the patient"],[5237,5375,"is alive and well."],[5375,5479,"Alive and well?"],[5575,5812,"Does that look alive and well to you?"],[5862,5962,"I don't even know"],[5962,6066,"how you can call yourself"],[6066,6250,"a doctor with those skills."],[6391,6500,"And to think"],[6566,6700,"I lowered myself"],[6700,6904,"to beg a worthless hack like you."],[6966,7150,"God, I must have lost my mind."],[7191,7325,"You're unbelievable, you know that?"],[7387,7529,"Absolutely shameless."],[7704,7787,"You, you!"],[7787,7879,"Ma'am, that's enough."],[7925,8000,"Without him,"],[8000,8075,"your mother wouldn't be"],[8075,8191,"breathing right now."],[8350,8462,"You bitch!"],[8500,8679,"How dare you curse my mother?"],[8687,8887,"I hope your entire family rots and hell."],[8891,9012,"Ma'am, you need to return to your seat"],[9012,9087,"now, I swear-"],[9162,9212,"Who..."],[9316,9537,"do you low tier,"],[9562,9687,"tray carrying,"],[9691,9900,"nobody's think you are?"],[9941,10187,"And don't stand there acting all noble."],[10216,10404,"Even a single strand on my mother's head"],[10425,10487,"is worth more"],[10487,10841,"than your entire miserable existence."],[10887,11041,"And you broke her rib."],[11041,11216,"So here's what's going to happen."],[11216,11337,"You're going to march your"],[11337,11487,"sorry ass over there,"],[11487,11650,"and stand in front of her,"],[11725,11850,"and slap yourself."],[11887,11950,"Over,"],[11979,12062,"and over again,"],[12079,12200,"until she forgives you."],[12266,12329,"Or,"],[12329,12579,"your life is about to become a living hell."]],"10":[[8,129,"She's the devil itself!"],[195,262,"Honestly,"],[300,420,"you should have let her mom die."],[433,604,"There's nothing left in her worth saving."],[650,775,"You want me to apologize,"],[775,904,"after I saved your mother's life?"],[991,1100,"This isn't just crazy,"],[1137,1279,"it's pure humiliation."],[1341,1433,"Exactly."],[1529,1766,"You made me beg."],[1787,1825,"Me."],[1904,2066,"And I never begged anyone for anything"],[2066,2191,"in my entire life."],[2191,2341,"That pissed me off."],[2379,2445,"So,"],[2525,2625,"you are going to make it up"],[2625,2729,"to me and my mom."],[2804,2954,"So do exactly as I said,"],[2954,3029,"right now."],[3379,3437,"Sorry."],[3541,3637,"But that's not gonna to happen."],[3841,3941,"Not happening?"],[3979,4037,"Want it back?"],[4037,4070,"No, no..."],[4070,4204,"Because I'll smash this thing into pieces"],[4204,4270,"right here, right now."],[4270,4379,"No, no, no, no. Please don't."],[4387,4462,"Oh. -Please."],[4462,4604,"So I take orders from you now?"],[4662,4704,"What?"],[4704,4966,"Is this little box so precious to you?"],[5212,5270,"Listen."],[5337,5525,"Inside that box is a kidney for a"],[5525,5637,"very powerful man."],[5704,5804,"And if you destroy it,"],[5879,5979,"there's no backup."],[6041,6120,"And trust me, lady,"],[6229,6358,"you don't want that kind of heat."],[6395,6562,"Oh no, a powerful man!"],[6575,6733,"What? Do you think that scares me?"],[6804,6991,"I'll break it here, right now just for fun."],[7004,7179,"No, no, no, no. Please don't."],[7241,7291,"Oh!"],[7300,7404,"What are you gonna do about it?"],[7437,7550,"No, no, no, wait! Don't, please!"],[7583,7612,"Please."],[7625,7691,"Please, please, just..."],[7725,7870,"You want it back safe and sound?"],[7950,8087,"Then do what I said."],[8170,8229,"That's it."],[8241,8354,"You crossed the line."],[8354,8441,"Come on, everybody."],[8441,8545,"Let's get that case!"],[8566,8675,"- Yeah. - Yeah, go!"],[8675,8750,"Come on."],[8829,8883,"Try."],[8900,9033,"See what happens."],[9108,9220,"My fiancé,"],[9245,9325,"is the heir"],[9345,9475,"to the Wolf family"],[9491,9566,"of Florida."]],"11":[[0,108,"My fiancé,"],[108,208,"is the heir,"],[233,358,"to the Wolf family,"],[375,454,"of Florida."],[545,650,"Derek Wolf's grandson."],[720,766,"Yeah."],[800,912,"You know Derek Wolf?"],[945,1100,"The biggest arms kingpin,"],[1100,1204,"in the whole planet?"],[1266,1337,"The Wolf family?"],[1404,1470,"Oh, God."],[1537,1679,"Who the hell wants to cross them?"],[2045,2104,"Wait."],[2216,2320,"Derek Wolf's Grandson"],[2320,2408,"is your fiancé?"],[2433,2570,"That's right."],[2616,2883,"Look at your terrified little faces now."],[2958,3108,"Bunch of broke bottom feeders."],[3212,3308,"The Wolf family's known"],[3308,3429,"for staying low key,"],[3508,3650,"and treating people with respect."],[3725,3787,"But you,"],[3845,3954,"you use their name"],[3954,4079,"and throw it around like a weapon."],[4175,4304,"They would be ashamed of this."],[4304,4370,"Yeah, well,"],[4370,4525,"I'll use it as a weapon."],[4525,4687,"I'll bully whoever the hell I want."],[4687,4800,"So what are you gonna to do about it?"],[4845,4970,"You have three seconds,"],[5070,5270,"before I smash this thing into pieces."],[5341,5412,"Three,"],[5450,5508,"two,"],[5529,5558,"one."],[5558,5620,"No, don't!"],[5800,5866,"Please."],[6112,6158,"Alright."],[6158,6212,"Okay."],[6212,6237,"Just,"],[6270,6304,"listen."],[6325,6387,"Please."],[6387,6525,"Inside that box is carrying a"],[6525,6695,"kidney for your fiancé's grandfather,"],[6695,6754,"Derek Wolf."],[6820,6950,"He's in critical condition."],[7012,7100,"And this is the only"],[7100,7187,"thing that can help him."],[7316,7