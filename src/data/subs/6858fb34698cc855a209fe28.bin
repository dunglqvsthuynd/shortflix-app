use it's a, you know,"],[3078,3282,"a three Michelin star restaurant."],[3315,3482,"She couldn’t eat here otherwise."],[3541,3578,"Whatever,"],[3670,3787,"I'm feeling generous."],[3812,3949,"Consider it charity."],[4166,4225,"Thank you."],[4500,4583,"Excuse me."],[4683,4842,"Good evening ma’am, how may I help you?"],[4904,5096,"I want you to take this away."],[5134,5201,"And I want you to bring out"],[5201,5330,"your finest dishes."],[5547,5789,"Ma'am, the premium set at Maple Dining"],[5789,5955,"is quite expensive."],[5989,6147,"Do you like to review the cost first?"],[6193,6318,"Does it look like"],[6318,6402,"I can't afford it?"],[6402,6552,"You're wasting my time."],[6577,6669,"I said your most"],[6669,6785,"expensive dishes."],[6794,6981,"Oh, and your priciest bottle."],[7069,7148,"Yes ma'am."],[7319,7661,"Wow, Regina, you are so amazing."],[7745,7903,"Not like Cato's wife."],[7987,8183,"Now, now, that's not fair."],[8220,8400,"Most women can't compare to me."],[8450,8733,"But Elise doesn't even stand a chance."]],"54":[[0,296,"Regina, we're coworkers, so,"],[308,425,"I'll just be real with you."],[500,633,"I would take that order back."],[671,792,"Are you sure you can afford that?"],[909,971,"Colleagues?"],[1076,1226,"You think a loser like you is"],[1226,1476,"on the same level as an RG manager?"],[1501,1555,"Relax."],[1559,1743,"I've got two million on this card."],[1743,1822,"I could cover all"],[1822,1943,"of you for years."],[2202,2410,"Honey, don’t waste your breath on that."],[2410,2502,"Women like her that"],[2502,2627,"lives paycheck to paycheck doesn't"],[2627,2761,"know what it's like to have real money."],[4016,4316,"A 1795 Louis XIII Cognac?"],[4391,4446,"Damn."],[4525,4658,"Didn't think Maple Dining"],[4658,4867,"stocked five million dollar bottles."],[4988,5142,"If this is my last meal,"],[5230,5409,"I'm gonna die happy."],[5655,5855,"Now this is some top shelf brandy."],[5968,6026,"Let's eat."],[6493,6702,"Are you sure about this, Regina?"],[6