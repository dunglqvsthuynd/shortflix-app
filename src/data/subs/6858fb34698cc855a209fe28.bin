{"1":[[58,158,"Attention!"],[187,287,"You guys heard about the CEO?"],[321,412,"Apparently she got called to"],[412,513,"duty right after her wedding."],[538,629,"And after duty,"],[629,750,"she founded RAPTOR GROUP."],[792,875,"It became the largest"],[875,1034,"aerospace and defense company"],[1034,1101,"for the government."],[1163,1230,"How did a woman"],[1230,1292,"accomplish that?"],[1292,1326,"I wouldn't"],[1326,1422,"underestimate a woman."],[1488,1530,"If I were you."],[2648,2715,"Welcome boss!"],[3240,3307,"Welcome back boss."],[3349,3382,"Annie."],[3453,3503,"It's been a while."],[3582,3653,"How's the new airplane"],[3653,3741,"factory coming on?"],[3799,3912,"We have to have 30 new"],[3912,4029,"fighter jets to the Pentagon"],[4029,4108,"by next year."],[4108,4208,"Everything running smoothly?"],[4212,4266,"Yes, boss!"],[4312,4400,"Got a solid team,"],[4425,4550,"smart, hardworking."],[4592,4696,"I'll introduce you to them tomorrow."],[4704,4742,"Great."],[4767,4808,"Mayor Woods,"],[4842,4929,"nice to meet you."],[4963,5105,"Thank you so much for your support."],[5150,5246,"Setting up RG's new factory"],[5246,5409,"would not have been possible without it."],[5417,5505,"RG's giving jobs"],[5505,5609,"to half the town."],[5643,5689,"If anything,"],[5689,5776,"we should be thanking you."],[5951,6097,"Boss, I heard you came back"],[6097,6285,"to Silverfield to finally have a proper"],[6285,6402,"wedding with your husband."],[6535,6564,"Yeah,"],[6664,6765,"Cato and I never got one."],[6827,6952,"I left before we could."],[6977,7027,"So,"],[7073,7223,"now that my contract's ending,"],[7223,7340,"I wanna make it up to him."],[7378,7457,"I'm sure he'll understand"],[7457,7561,"once you tell everything."],[7590,7707,"Including your identity."],[7782,7891,"My work in the military has"],[7891,8024,"been strictly confidential,"],[8062,8199,"I can't tell him anything yet."],[8249,8425,"My NDA expires in three days."],[8441,8500,"So,"],[8562,8650,"after that,"],[8675,8787,"I can explain everything,"],[8787,8888,"all that I've been up to,"],[8888,8954,"who I've become."],[9025,9104,"But until then,"],[9121,9184,"not a word."],[9217,9267,"Understood?"],[9526,9567,"He's gonna be"],[9567,9642,"proud of you, Elise."],[9734,9859,"Oh, I almost forgot."],[9909,10051,"The gifts you asked us to prepare"],[10051,10168,"for your mother-in-law's"],[10168,10289,"birthday are on the way."],[10318,10410,"Here's the itemized receipt."],[10531,10643,"You’re a lifesaver at lease."],[10685,10814,"Thank you for coming all this way."],[10956,11002,"All right,"],[11023,11098,"you guys head back."],[11140,11207,"Get back to work."],[11307,11419,"I have to go home first."],[11494,11544,"Yes, boss."],[11619,11682,"Yes, boss."],[11836,11886,"Ben Woods."],[11999,12049,"Please, welcome."],[13868,13913,"Mom."],[13980,14009,"Dad."],[14222,14272,"I’m back."]],"2":[[642,667,"Cato."],[734,754,"Elise."],[1447,1526,"I missed you so much."],[1555,1618,"I missed you."],[1710,1730,"Cato."],[2548,2702,"Is this the dingy trailer"],[2702,2794,"Elise grew up in?"],[2986,3003,"Cato,"],[3115,3153,"who's this?"],[3211,3253,"Cato,"],[3319,3432,"you never told her about us?"],[3549,3653,"Beatrice, don't talk like that."],[3699,3812,"I don't want Elise to misunderstand"],[3812,3891,"our relationship."],[3912,3978,"This is Beatrice."],[4020,4270,"It's an old colleague from work."],[4316,4466,"Mom asked me give her"],[4466,4537,"a ride to the party."],[4829,4888,"Nice to meet you."],[4942,4992,"I'm Elise."],[5442,5492,"Let's go home."],[5509,5597,"There's so much I'm want to"],[5597,5676,"talk to you about."],[6010,6202,"I never agreed to give her a ride."],[6239,6389,"Jane, it's been so long."],[6389,6493,"When's the divorce?"],[6493,6531,"Jane,"],[6548,6631,"what are you talking about?"],[6664,6765,"Oh, come on."],[6819,6973,"This army bitch has been gone for,"],[6973,7027,"what?"],[7065,7203,"Four years and"],[7203,7336,"didn't even make Sergeant."],[7390,7599,"Now she's back to leech off you again."],[7599,7657,"And you think"],[7657,7895,"I'm just gonna stand here and watch?"],[7916,7999,"Elise worked hard"],[7999,8091,"and served our country."],[8091,8179,"You don't get to talk about"],[8179,8233,"her like that."],[8441,8558,"She's my wife."],[8654,8783,"And your sister in law."],[8804,8904,"So treat her with respect."],[8950,9071,"Respect is earned,"],[9084,9171,"not given."],[9188,9309,"I give my respect"],[9309,9501,"to people at my level."],[9559,9676,"Not some..."],[9772,9976,"trailer trash like her."]],"3":[[354,396,"Yeah,"],[421,513,"I was raised here."],[554,658,"I'm not ashamed of that."],[729,855,"Everything I have in life,"],[855,955,"I worked hard for."],[1101,1167,"I'm proud of that."],[1201,1272,"Oh, see, Cato?"],[1272,1347,"Oh, see, Cato?"],[1430,1614,"You've spoiled her so much,"],[1614,1710,"she actually thinks"],[1710,1851,"she's some big-shot now."],[1968,2173,"You've wasted four years on her."],[2173,2352,"And for what?"],[2360,2456,"What has she ever done for you?"],[2477,2623,"Does she even care that you had"],[2623,2702,"to sell your car?"],[2736,2815,"I'm just saying,"],[2861,2998,"Beatrice would never put"],[2998,3132,"her husband through that."],[3349,3445,"Did you sold your car?"],[3465,3578,"But you loved that car."],[3578,3728,"Is money really that tight?"],[3753,3849,"I would explain it to you later."],[3874,3937,"Jane's right."],[3970,4079,"Without me,"],[4079,4258,"you'd be walking home right now."],[4325,4441,"But it's okay, Cato."],[4583,4667,"If you like it,"],[4713,4829,"you can keep it."],[5276,5317,"No, thanks."],[5380,5559,"I sold my car but..."],[5584,5659,"I'll get it back once"],[5659,5751,"the money's not tight."],[5772,5822,"Why are you"],[5822,5926,"being so stubborn?"],[5985,6039,"Beatrice is"],[6039,6218,"being very generous,"],[6293,6389,"Elise can't give you a car."],[6452,6552,"She can much less"],[6552,6690,"support your career."],[6744,6890,"Jane, love isn't about what"],[6890,6977,"someone can give you."],[7007,7048,"Whatever."],[7119,7415,"I guess it's fine, if Elise is"],[7415,7532,"all right sitting in the back"],[7532,7736,"seat of Beatrice's car."],[7749,7786,"No need."],[7862,7962,"I'll be driving my own car."],[8058,8108,"What?"],[8179,8237,"What car?"],[8287,8383,"If you had one,"],[8383,8662,"you wouldn't ask Cato for a ride."],[9551,9638,"Send a car over."],[9726,9826,"A simple one will do."]],"4":[[4,120,"Are you calling a car?"],[171,254,"How cute."],[300,346,"Fine,"],[346,442,"I'll be nice and let"],[442,542,"you ride with us."],[642,771,"As a favor to Cato."],[809,880,"Not necessary."],[1063,1163,"Cato can drive my car."],[1276,1384,"Are you really going to make"],[1384,1576,"Cato show up to our mom's"],[1576,1643,"party in some"],[1643,1768,"dingy little cab?"],[1826,1968,"He's a CEO now."],[2006,2143,"You're going to embarrass him."],[2181,2264,"You started a company?"],[2398,2494,"Yeah, but that's"],[2494,2560,"why I sold the car."],[2560,2660,"I needed some startup money."],[2736,2819,"Why didn’t you tell me?"],[2819,2894,"I could have helped you."],[2948,3036,"Connections, funding,"],[3036,3098,"whatever you need."],[3157,3207,"You?"],[3249,3315,"Help?"],[3357,3445,"What money?"],[3470,3545,"What connections?"],[3641,3887,"You grew up in a trailer,"],[3920,3978,"Elise."],[4041,4208,"You didn't even go to college."],[4283,4371,"You know, money and degree"],[4371,4462,"don't define someone."],[4633,4750,"You don't know anything about me,"],[4750,4846,"so don't act like you do."],[4892,4975,"Look at her being all"],[4975,5084,"high and mighty."],[5176,5284,"It's ridiculous."],[5355,5413,"Cato,"],[5413,5563,"you know how many men"],[5563,5701,"would jump"],[5739,5864,"at the chance to be with me."],[5930,6110,"Whatever Elise can offer,"],[6110,6247,"I can give you more"],[6247,6360,"and then some."],[6510,6581,"So tell me,"],[6748,6873,"do you finally see"],[6873,6994,"who you should really be with?"],[8721,8908,"Oh my god!"],[8988,9196,"This is a limited edition Porsche."],[9221,9359,"There's only five in existence."],[9359,9530,"It's worth at least 500,000 dollars."],[9613,9751,"Who the hell, in this dump"],[9751,9943,"could have afford something like this?"],[10206,10260,"Ma'am,"],[10347,10410,"your car."],[10485,10518,"Thank you."],[10593,10627,"What?"],[10885,10931,"Do you like it?"]],"5":[[50,83,"What?"],[154,204,"Do you like it?"],[362,550,"How could she afford this?"],[604,796,"You own this car?"],[834,1051,"Yeah, but it's Cato's now."],[1463,1559,"Is this really your car?"],[1718,1843,"But if you want something else,"],[1843,1976,"I can get you another one."],[2022,2139,"You just have a fleet of cars"],[2139,2227,"to choose from."],[2264,2331,"If Cato would like."],[2502,2635,"Don't let her fool you, Cato."],[2694,2790,"I bet it's just your rental."],[2919,3065,"Yeah, that way she can switch"],[3065,3115,"it out whenever."],[3182,3224,"Beatrice,"],[3244,3361,"you're so smart for"],[3361,3486,"seeing right through her."],[3553,3645,"Believe what you want."],[3741,3824,"Cato, we should go home."],[3849,3933,"It's your mom's birthday."],[3970,4049,"I don't want to be late."],[4984,5046,"I will see you later."],[5134,5155,"Wait,"],[5251,5284,"Cato?"],[5363,5401,"Cato!"],[5488,5543,"Wait, no,"],[5580,5672,"Beatrice, it's okay."],[5701,5780,"I don't need a Porsche."],[5805,5968,"Your car is really nice too."],[6022,6081,"Get,"],[6081,6218,"your own damn ride."],[6243,6348,"I've gotta pick up some real"],[6348,6439,"birthday gifts for your mom."],[6519,6623,"Let her see who truly"],[6623,6681,"deserves to be"],[6681,6748,"the new daughter-in-law."],[6961,6986,"What?"],[6998,7102,"Wait, wait, wait, Beatrice."],[7207,7290,"Wait, Cato, wait."],[7328,7378,"Wait, Cato."],[7507,7561,"Cato, wait."],[7949,8012,"Damn it."]],"6":[[950,1034,"Oh no."],[1126,1234,"Happy birthday, Stacy."],[1263,1384,"It was."],[1530,1680,"Well, Stacy,"],[1697,1751,"it looks like"],[1751,1835,"your daughter-in-law"],[1835,1993,"is back from playing soldier."],[1993,2260,"And look at the shiny metal."],[2289,2489,"Never seen that one before."],[2652,2740,"Because it's probably some"],[2740,2936,"cheap knock off that she"],[2936,3048,"bought in the streets."],[3111,3303,"I haven't accepted a brat"],[3303,3482,"from the trailer park"],[3482,3695,"into this family and I don't plan"],[3695,3807,"on doing it now."],[3812,3853,"Mom!"],[3945,4058,"What are you talking about?"],[4087,4166,"Elise came here to"],[4166,4262,"celebrate your birthday."],[4320,4421,"How can you say that?"],[4504,4571,"Mom's right."],[4829,4954,"This is not my baby one."],[4988,5192,"This bitch rented a fancy car"],[5192,5313,"and wouldn't give me a ride."],[5355,5488,"I had to walk the"],[5488,5622,"whole way home."],[5647,5772,"Oh my baby."],[5801,5880,"Sit down, sit down."],[5947,6010,"Sit down."],[6051,6160,"Take good care of her."],[6193,6268,"You little!"],[6268,6398,"How dare you treat my daughter"],[6398,6468,"like that?"],[6468,6564,"Mom, isn't like that."],[6614,6702,"We thought Jane was gonna"],[6702,6798,"a ride with Beatrice."],[6861,6906,"Cato,"],[6906,7115,"I don't wanna pick on Elise,"],[7182,7344,"but it's mom's birthday"],[7382,7536,"and she didn't even bring her gift."],[7590,7766,"Can you really blame mom for"],[7766,7982,"not accepting her into our family?"],[8041,8087,"I did."],[8153,8258,"The gifts are on their way."],[8283,8358,"They'll be here soon."],[8404,8566,"Well, let's see what you"],[8566,8725,"managed to scrape together."],[8775,8917,"I don't want anything gifted"],[8917,9134,"to me from trailer trash."],[9317,9396,"Let me guess,"],[9396,9496,"you ran out of"],[9496,9617,"money and now you've come"],[9617,9793,"crawling to Cato."],[9843,9893,"Cato,"],[9947,10060,"don't let her fool you."],[10130,10214,"I've been financially"],[10214,10331,"set for a while now."],[10406,10527,"I don't need Cato's money."],[10677,10756,"Elise,"],[10785,10839,"let me give you some"],[10839,10985,"advice as your elder."],[11040,11261,"If you can't afford a decent gift,"],[11261,11319,"fine."],[11348,11478,"But don't come here"],[11478,11544,"pretending to be"],[11544,11624,"something you're not."],[11649,11770,"We all know what kind of"],[11770,11866,"person you are."],[11911,11970,"Yes,"],[11982,12187,"so let's not waste any time."],[12312,12370,"Thank you."],[12570,12704,"Sign this divorce agreement."],[12816,12908,"And you can get the"],[12908,12996,"hell out of here."],[13038,13146,"And if you signed it,"],[13146,13267,"I'll throw in an extra"],[13267,13355,"half a million dollars,"],[13355,13409,"how's that?"]],"7":[[0,33,"What,"],[33,95,"is that not good"],[95,162,"enough for you?"],[333,479,"Elise isn't after money."],[479,571,"Don't you keep falling for this"],[596,658,"trailer trash,"],[658,763,"she's gonna drag you down."],[792,871,"If you put her"],[871,950,"before your career,"],[984,1146,"your company's going to tank!"],[1201,1338,"Starting a company isn't that hard."],[1434,1576,"I can back Cato on my own."],[1956,2068,"I'm gonna get it myself."],[2214,2323,"Wait what,"],[2323,2444,"explain what you're gonna do."],[2444,2523,"Are you gonna"],[2523,2731,"scrub floors to raise capital?"],[2731,2811,"You really think"],[2811,2894,"you would get funding?"],[2919,3032,"Listen to her, she's insane."],[3053,3136,"No problem,"],[3144,3236,"of course I can."],[3432,3607,"I can, I can."],[3649,3762,"Cut the crap."],[3832,3966,"The only person"],[3966,4137,"who can take care of Ceto"],[4166,4316,"is Beatrice."],[4433,4546,"What can Beatrice do?"],[4633,4763,"So much more than you can do."],[4846,4896,"Beatrice!"],[5009,5176,"I really hope you explain myself"],[5192,5255,"to you."],[5518,5597,"Beatrice!"],[5597,5739,"It's always a pleasure."],[5830,5922,"You see that, Jane?"],[5980,6060,"You can tell when someone"],[6060,6151,"comes from real money."],[6214,6368,"Look at her grace, class."],[6485,6577,"You can't fake that."],[6631,6798,"Of course, it's not something"],[6798,6852,"trailer trash"],[6852,6952,"can just pick up."],[7136,7265,"Oh, you flatter me."],[7294,7461,"Beatrice, darling, welcome."],[7595,7699,"You look marvelous."],[7753,7916,"Happy birthday, Mrs. Newton."],[7999,8120,"I brought a few gifts."],[8212,8304,"I hope you like them."],[8412,8462,"Me?"],[8692,8825,"Oh my godness."]],"8":[[16,162,"Oh, you really must"],[162,325,"call me Stacy, dear."],[412,450,"And of course"],[450,567,"I'm going to love these."],[567,792,"At least someone knows not to"],[792,971,"show up empty-handed."],[1184,1334,"We went all out."],[1693,1918,"This purse alone"],[1964,2206,"cost 300,000 dollars."],[2556,2752,"This whole haul has to be at least"],[2761,2907,"one million dollar!"],[2919,3007,"Well, of course,"],[3036,3178,"Beatrice has taste."],[3290,3603,"Hard work and accomplishment."],[3653,3732,"Why she’s"],[3749,3858,"the daughter-in-law"],[3858,4029,"every mom's dreams."],[4095,4220,"Too bad it's wasted."],[4254,4295,"No."],[4320,4433,"If only my brother wasn't"],[4433,4654,"throwing away his best years"],[4654,4871,"on some useless grunt."],[4929,5046,"Oh, don't worry."],[5100,5251,"The second Cato dumps her,"],[5251,5367,"I'll marry him in a heartbeat."],[5467,5559,"Sounds like a great plan."],[5559,5655,"Right, Stacy?"],[5689,5776,"Should I call you mom?"],[5830,5851,"Oh."],[6035,6135,"Yeah, I'm still here."],[6214,6310,"Or have you all forgotten?"],[6331,6427,"I don't see the point"],[6427,6598,"wasting time on someone so..."],[6644,6735,"insignificant."]],"9":[[87,266,"While you were off playing soldier,"],[404,675,"I was attending global conferences,"],[675,784,"making connections,"],[784,975,"securing investors for Cato."],[1026,1067,"Tell me,"],[1176,1351,"what exactly"],[1372,1509,"have you done for him?"],[1547,1680,"Are we just gonna believe everything"],[1680,1793,"Beatrice says?"],[1814,1906,"No questions asked."],[1968,2097,"Well, why wouldn't we?"],[2156,2406,"I mean, Beatrice's father, Mark,"],[2464,2602,"was just made"],[2602,2794,"general manager of"],[2794,3178,"RG Industries' Silverfield factory."],[3232,3328,"I think everyone."],[3336,3482,"Everyone's trying to get on"],[3482,3624,"Beatrice's good side."],[3687,3928,"Wow, so he's the general manager."],[3937,3983,"That's right."],[4062,4229,"And for the record,"],[4266,4446,"I'm the new Head of Finance, too."],[4529,4704,"Once my dad steps down,"],[4704,4896,"I'll take over as general manager."],[4979,5059,"Meanwhile,"],[5075,5313,"your dad's only legacy to you"],[5376,5601,"is a run-down trailer."],[5834,5964,"So, she's been using my"],[5964,6110,"company's name to boost her"],[6110,6185,"own reputation."],[6252,6285,"Interesting."],[6377,6502,"Let's see how far she thinks"],[6502,6602,"she can take this."],[6644,6677,"Wow."],[6765,6890,"I didn't realize general"],[6890,7057,"manager of RG was"],[7057,7178,"a family inheritance."],[7286,7390,"Too bad that won't be happening,"],[7432,7536,"unless I approve it."]],"10":[[16,116,"You approval?"],[187,308,"Who do you think you are?"],[346,546,"The CEO of Raptor Group?"],[800,1042,"RG is the top"],[1042,1176,"aerospace and defense"],[1176,1330,"contractor in the country."],[1413,1609,"The founder is a high-ranking"],[1609,1818,"female officer."],[1893,2039,"She's brilliant,"],[2039,2218,"ruthless,"],[2218,2535,"and a genius with military tech."],[2594,2669,"Nobody's even"],[2669,2798,"seen her in public."],[2902,2986,"And you know what?"],[2998,3132,"I know one thing for sure."],[3136,3307,"She's not some worthless,"],[3374,3449,"low life,"],[3495,3557,"gold digger."],[3595,3716,"You better watch out."],[3757,3937,"If you piss Beatrice off,"],[3937,4079,"and we lose RG's backing"],[4079,4183,"because of you,"],[4337,4450,"I’ll make you regret it."],[4550,4604,"Jane, enough."],[4667,4738,"Elise is family."],[5030,5130,"Beatrice helped me for the"],[5130,5209,"last four years."],[5309,5463,"She's not usually like that."],[5488,5555,"Maybe there's a"],[5555,5622,"misunderstanding."],[5693,5801,"Let’s just talk this out, okay?"],[5951,6072,"You don't need Beatrice's"],[6072,6147,"support anymore."]],"11":[[54,87,"I'm back."],[166,246,"I can handle everything."],[333,408,"He doesn't need"],[450,633,"your empty promises."],[725,817,"Beatrice already called her"],[817,967,"dad to set up a"],[967,1092,"contract to RG."],[1176,1301,"Once that contract's signed,"],[1368,1547,"Cato’s company will be golden."],[1601,1634,"So stop"],[1634,1747,"embarrassing yourself."],[1793,1914,"Welcome back to reality,"],[1947,2139,"where money and power rule."],[2239,2373,"And lucky for you, whoa!"],[2469,2548,"You have neither."],[2610,2652,"Elise,"],[2861,3094,"If you love Cato, let him go."],[3153,3240,"Sign the divorce please."],[3240,3307,"That's enough!"],[3378,3495,"You don't have to like Elise,"],[3545,3582,"but you have"],[3582,3670,"gotta respect her."],[3958,4037,"Elise,"],[4079,4208,"I'm sorry about my family."],[4208,4320,"This isn't how I wanted to"],[4320,4387,"welcome you home."],[4425,4529,"If you want, we can just go."],[4558,4621,"I know, Cato."],[4738,4850,"I don't wanna get in between"],[4850,4929,"you and your family."],[5059,5196,"Jane and your mom,"],[5196,5330,"they just don't understand me yet."],[5401,5472,"Give them some time."],[5543,5588,"They'll come around."],[5663,5726,"They will,"],[5726,5801,"just like Cato."],[5893,5976,"I don't know what sort of"],[5976,6093,"spell she put on you,"],[6093,6222,"but when she leaves you for broke,"],[6222,6352,"don't come crying to us."]],"12":[[37,271,"Girls like her only want one thing."],[346,400,"A way out."],[483,604,"She's just using you to keep"],[604,696,"her roof over her head."],[721,771,"Beatrice,"],[771,850,"I appreciate everything"],[850,963,"you've done for my company,"],[963,1076,"but stay out of my marriage."],[1205,1347,"Don't get mad at me, Cato."],[1351,1505,"I'm just looking out for you."],[1830,1901,"Anyways,"],[1901,1972,"the mysterious"],[1972,2314,"RG CEO is finally back in town,"],[2314,2439,"and they're throwing a huge"],[2439,2535,"welcome party for her"],[2535,2660,"tomorrow at the factory."],[2790,2982,"You should come with me."],[3244,3328,"You know, did you hear that?"],[3357,3461,"This is your chance."],[3490,3603,"You have to take it."],[3653,3782,"Listen, if you made a good"],[3782,3987,"impression with the CEO herself."],[4058,4175,"It'll open up all the"],[4175,4383,"business doors in the world."],[4833,4863,"Thank you."],[4913,4963,"That'd be great."],[5038,5100,"Of course."],[5184,5397,"Oh, but there is one thing."],[5488,5718,"RG has very strict security"],[5718,5814,"clearance policies."],[5855,5960,"They won't let anyone in"],[5960,6097,"unless an employee takes you."],[6143,6306,"So, should I tell them you're"],[6306,6368,"coming with me"],[6368,6519,"as my boyfriend?"],[6652,6794,"Or maybe my husband?"],[6794,6927,"That won't be necessary."],[7082,7148,"My team has already"],[7148,7307,"drafted a contract for Cato."],[7411,7528,"He'll be receiving a direct"],[7528,7695,"offer from RG soon."],[7887,7999,"Wait, what?"]],"13":[[87,200,"Wait, what?"],[200,312,"You're being dramatical-"],[396,596,"Don't be ridiculous,"],[596,729,"and it has stopped making"],[729,896,"such wild claims."],[950,992,"Please!"],[1067,1176,"And nobody like you wouldn't"],[1176,1284,"even get past security"],[1284,1380,"without my help."],[1539,1764,"And you want us to believe that"],[1764,2018,"you landed Cato a contract."],[2106,2235,"If you keep feeding into"],[2235,2448,"Elise's delusions,"],[2448,2552,"I might have to hand this"],[2552,2706,"opportunity to someone else."],[2715,2798,"No, wait, Beatrice!"],[2831,2952,"We really need this contract."],[3319,3395,"Elise,"],[3436,3653,"RG isn't just a tech company."],[3787,3920,"They have military backing,"],[4033,4266,"and cutting-edge innovations,"],[4300,4454,"funding, everything I need"],[4454,4654,"for my company to survive."],[4708,4829,"I can't let that go."],[4854,4904,"I know."],[4954,5059,"I can handle all of this."],[5096,5188,"But Elise, this is"],[5188,5284,"way out of your league."],[5347,5505,"Without RG's support,"],[5505,5618,"my company is done."],[5663,5801,"I can solve this whole thing"],[5801,5897,"with one phone call."],[5947,6076,"You don't need to go with it."],[6076,6131,"Elise, please."],[6281,6331,"There's no shame"],[6331,6406,"asking for help."],[6539,6652,"I get that you're jealous,"],[6652,6777,"but I can't make a rash"],[6777,6931,"decision and lose everything."]],"14":[[87,246,"I love you for who you are."],[283,379,"You don't have to pretend to"],[379,517,"be someone else to keep me."],[633,654,"Okay?"],[909,1009,"Fine, I'll go with you,"],[1017,1109,"not as yours."],[1146,1188,"We're not-"],[1188,1242,"Oh, I know!"],[1276,1347,"Don't worry."],[1739,1835,"You know,"],[1868,1981,"I've known Cato way"],[1981,2089,"longer than you."],[2202,2289,"I was his first."],[2414,2473,"We actually"],[2473,2602,"look like a couple."],[2727,2777,"Which makes..."],[2827,2911,"You,"],[2969,3190,"the home wrecker."],[3858,3958,"Beatrice,"],[3958,4016,"are you okay, Beatrice?"],[4062,4170,"I think I sprained my ankle."],[4258,4346,"I'm sorry, Cato,"],[4346,4404,"it was an accident."],[4471,4592,"Please don't blame Elise."],[4688,4788,"Elise, why would you do that?"]],"15":[[4,108,"Elise, why would you do that?"],[266,329,"Take a seat."],[329,412,"I will get you some ice."],[417,442,"Okay."],[1639,1714,"See that?"],[1901,2018,"You mean nothing to him."],[2106,2252,"I said one thing he needed"],[2252,2364,"and he was all ears."],[2439,2540,"What do you have to offer?"],[2623,2648,"Money?"],[2756,2823,"Connections?"],[2957,3032,"You really think"],[3032,3115,"you can keep up with me?"],[3199,3278,"Pretty cocky for someone"],[3278,3516,"who's just a local finance manager"],[3516,3620,"at an RG factory."],[3691,3807,"You have no idea"],[3807,3866,"who you're dealing with."],[3916,3983,"Yeah, sure."],[4054,4112,"Keep talking."],[4216,4346,"Once Cato signs that contract,"],[4362,4441,"he's mine."],[4529,4579,"He won't even"],[4579,4692,"remember you exist."],[4896,4967,"That was a warning."],[5017,5092,"Don't test me again."],[5138,5234,"You bitch!"],[5251,5359,"How dare you!"],[5497,5609,"Oh, my ankle."],[5655,5718,"Okay, sit down."],[5926,6022,"Can you ice it for me?"],[6364,6443,"You always have"],[6443,6594,"such good care for me."]],"16":[[237,300,"Elise,"],[342,525,"I know Beatrice can be difficult,"],[525,688,"but my company"],[688,763,"need this deal."],[792,884,"Can you just let it go?"],[955,1059,"You know you're"],[1059,1151,"the only one for me."],[1242,1343,"Enough of this."],[1409,1555,"Stop wasting your time on her."],[1630,1755,"The only thing that matters"],[1755,1993,"now is sealing the deal with RG."],[2060,2223,"Stacy, didn't Elise say she"],[2223,2323,"had some gifts for you?"],[2398,2456,"Where are they?"],[2494,2702,"Yeah, with all that big talk,"],[2744,2786,"I hope you brought"],[2786,2840,"something impressive."],[2898,2969,"They'll be here soon."],[3061,3182,"You can judge for yourselves."],[3261,3453,"Sure, we're not expecting much."],[3561,3636,"Excuse me, if I could"],[3636,3703,"have a moment."],[4508,4667,"On behalf of a VIP client,"],[4667,4813,"Luxesphere Mall is honored to present"],[4813,4975,"these gifts to Mrs. Stacy Newton."],[6139,6385,"A Patek Philippe ladies' Nautilus."],[6385,6627,"A custom Rolls-Royce Phantom."],[6664,6856,"A haute couture crystal embellished"],[6856,6948,"gown from Dior."],[6986,7265,"A bottle of Cognac Napoleon 1811"],[7265,7374,"Grand Reserve."],[7469,7661,"And finally, a ten-carat"],[7661,7849,"natural blue diamond,"],[7853,7970,"the Heart of the Sea."]],"17":[[29,325,"Oh my gosh, mom!"],[362,462,"The watch alone"],[462,638,"is worth millions."],[704,888,"More than all of Beatrice’s gifts"],[888,959,"combined!"],[1046,1255,"Mom, who got you these?"],[1355,1555,"Are these really that expensive?"],[1634,1851,"Are all of these really mine?"],[1939,2047,"Who else could afford"],[2047,2168,"something like this?"],[2298,2394,"It's gotta be Beatrice."],[2585,2635,"Beatrice!"],[2698,2890,"I knew you had great taste."],[2940,3132,"These are perfect."],[3591,3653,"What?"],[3716,3878,"As if I could ever afford this."],[3916,4066,"Let alone waste it on her."],[4116,4316,"Oh well, if they think it's from me."],[4337,4396,"Of course!"],[4437,4462,"Stacy!"],[4621,4796,"As long as you like them,"],[4796,4896,"that's all that matters."],[4971,4992,"What?"],[5188,5284,"You're sure they're from you?"],[5743,5876,"Who else would it be?"],[5972,6081,"What, are you trying to say you"],[6097,6160,"bought them?"],[6377,6531,"Yeah. Cause I did."],[7115,7332,"These are worth millions."],[7453,7536,"I thought you'd never even"],[7536,7645,"heard of these brands."],[7678,7903,"As if you could"],[7903,8012,"afford all of these."],[8074,8258,"You're just a useless grunt!"],[8299,8420,"Oh Stacy,"],[8429,8616,"don't let her ruining your birthday!"],[8675,8938,"Here, let me put this watch on you."],[9025,9063,"Thank you!"],[9146,9230,"Excuse me, ma'am."],[9334,9467,"I'll need to see a receipt first."],[9476,9592,"We have to verify the purchase."],[9864,9993,"Do it, you can."],[10585,10639,"Receipt?"],[10735,10781,"Why?"],[10931,11052,"I've never had this back before."],[11098,11223,"It's standard procedure for"],[11223,11369,"high-value purchases, ma'am."],[11398,11503,"Before we can release them,"],[11503,11665,"we need to confirm the buyer's identity."],[11724,11845,"Go ahead."],[12183,12303,"Do you know who I am?"],[12374,12583,"I'm the head of finance at RG."],[12658,12791,"I'm the only one here"],[12791,12892,"who could even afford these."],[12979,13129,"I'm just following orders."],[14706,14906,"Is this what you're looking for?"]],"18":[[0,137,"How could she have it?"],[487,621,"Forgery is a crime, you know."],[663,792,"I'm sure he can tell if it's real."],[1514,1580,"Thank you ma'am,"],[1580,1676,"everything checks out."],[1755,1868,"Mrs. Newton, Luxsphere Mall"],[1872,1989,"hopes you enjoy your gifts."],[2052,2156,"Have a wonderful day."],[2156,2206,"No way,"],[2318,2565,"she's just a private."],[2594,2669,"She doesn't even,"],[2669,2744,"how would she?"],[2756,2823,"How does she have the"],[2823,2915,"money to afford this?"],[2994,3082,"This can't be."],[3186,3253,"She's broke."],[3378,3474,"They must make a mistake."],[3561,3666,"You better look into this."],[3741,3928,"There's no way Elise could"],[3928,4070,"afford a watch worth millions."],[4137,4300,"If you let this slide,"],[4300,4429,"you might lose your job."],[4508,4646,"I'm just here to verify the receipt,"],[4708,4750,"nothing more."],[4879,4992,"So you're just gonna let her"],[4992,5080,"steal my gifts?"],[5159,5221,"That's theft."],[5434,5597,"Luxesphere Mall is exclusive"],[5597,5734,"only to their members."],[5784,5910,"They're not open to the public."],[6039,6101,"Are you a member?"]],"19":[[246,367,"Luxesphere Mall is exclusively"],[367,550,"services a hundred VIP members"],[563,638,"across the globe."],[721,742,"Miss..."],[779,863,"Beatrice, was it?"],[1493,1551,"My bad."],[1597,1768,"I thought these were mine."],[1789,2089,"I have so many just like them."],[2235,2256,"Oh?"],[2423,2573,"That's interesting."],[2715,2915,"These are all limited edition."],[3032,3090,"One of a kind."],[3186,3407,"Are you sure you have others"],[3407,3536,"just like them?"],[4421,4504,"Could these"],[4504,4704,"all really be from Elise?"]],"20":[[0,66,"Could these"],[66,266,"all really be from Elise?"],[316,371,"All of you,"],[450,521,"don't believe me,"],[550,642,"I can just send it back."],[679,850,"Oh, wait, wait, wait..."],[971,1092,"That's not what we meant."],[1151,1255,"Sweetheart,"],[1255,1418,"I'm just surprised."],[1463,1614,"No one's ever given me such"],[1614,1768,"an extravagant gift like this."],[1789,1906,"Oh, mom, this gift are too expensive."],[1956,2085,"We can't accept it."],[2093,2181,"What do you mean?"],[2235,2460,"She's been living off our money for years!"],[2494,2577,"It's about time we had a"],[2577,2711,"little payback from Elise."],[3324,3411,"Elise,"],[3461,3541,"be honest with me."],[3561,3632,"Where did you get the money for"],[3632,3691,"all this?"],[3774,3849,"Sorry, Cato."],[3887,4062,"I can't reveal my identity yet."],[4208,4421,"I promise I paid for these"],[4421,4500,"things myself."],[4579,4679,"From everything I earned the"],[4679,4763,"past few years."],[5159,5359,"Okay, okay, I believe you."],[5543,5730,"Do you guys seriously believe"],[5730,5847,"that that broke bitch"],[5847,5976,"bought all of this?"]],"21":[[0,100,"Who cares?"],[191,392,"These are worth millions of dollars."],[471,633,"If we sell them, we will have"],[633,738,"be more than enough"],[738,850,"to fund your brother's company."],[913,942,"What?"],[2152,2302,"Hey everyone, check out what"],[2302,2419,"someone got me."],[2456,2602,"Guess how much this costs."],[2761,2907,"Holy shit, those are all"],[2907,3019,"limited editions from"],[3019,3094,"Luxesphere Mall."],[3119,3190,"That's over ten million!"],[3303,3436,"Jane, did you get a sugar daddy"],[3436,3499,"or something?"],[3557,3695,"Don't keep him all to yourself."],[4033,4141,"Are you sure they're for you?"],[4195,4283,"I work at Luxesphere."],[4337,4441,"Those were all reserved for"],[4441,4512,"RG's director."],[4562,4704,"Jane, I'm pretty sure those are fake."],[4704,4879,"Fuck, she tricked us!"]],"22":[[16,70,"What do you mean?"],[154,316,"Elise sent us a bunch of fakes."],[396,667,"RG's CEO bought the real ones."],[725,867,"That bitch lied to us."],[1172,1322,"I knew it."],[1384,1572,"How would a grunt fresh out"],[1572,1797,"the military have this much money?"],[1839,1951,"There's no way she could"],[1951,2160,"afford such expensive gifts."],[2214,2373,"So you sent us a bunch of"],[2373,2615,"worthless fakes, you bitch."],[2681,2740,"Derek, get the scissors!"],[2790,2819,"Ok."],[3503,3611,"Mom, what are you doing?"],[3666,3837,"Jane exposed her."],[3899,4108,"I almost fell for your stupid tricks."],[4166,4270,"I never lied to you."],[4275,4371,"Cut the bullshit, Elise."],[4421,4608,"We all know these are fakes."],[4733,4842,"Luxesphere's manager"],[4842,4967,"personally delivered"],[4979,5109,"these gifts to you."],[5171,5221,"They're genuine."],[5301,5459,"I bet he was fake too."]],"23":[[37,191,"I bet he was fake too."],[258,400,"Probably a hired actor."],[1155,1284,"I'd be careful with that if I were you."],[1330,1476,"That's a vintage cognac from"],[1476,1597,"Napoleon's private collection"],[1597,1747,"worth over two million dollars."],[1830,1885,"I don't think you could"],[1885,1989,"afford any accidents."],[2610,2873,"Do you really think"],[2873,2969,"I wouldn't be able to tell if"],[2969,3023,"it was a fake?"],[3069,3086,"Oh."],[3128,3324,"As if a random soldier like"],[3324,3536,"you could afford a two million dollar"],[3536,3695,"bottle of cognac."],[3824,3945,"We aren't interested in your"],[3945,4066,"bottom shell of trash."]],"24":[[187,342,"Mayor woods, ever since RG"],[342,487,"opened a factory here,"],[487,583,"half the town has jobs."],[638,675,"And the"],[675,825,"investments keep rolling in."],[880,925,"Your approval"],[925,1017,"rating's never been higher."],[1092,1121,"Yeah."],[1234,1255,"Yeah."],[1317,1447,"Well that's all due to Elise"],[1447,1514,"and her company."],[1605,1643,"Come on,"],[1747,1876,"we should go see her and tell"],[1876,2035,"her how much we appreciate"],[2085,2185,"what she's done for silver."],[2285,2456,"And I hope she likes those"],[2456,2552,"gifts I got her."],[2890,2969,"How could you do that?"],[3019,3107,"Elise got those gifts."],[3115,3219,"Don't worry, Cato."],[3253,3294,"They're all"],[3294,3395,"cheap fakes anyways."],[3474,3532,"I get it."],[3561,3620,"You don't know any"],[3620,3824,"better but I am curious,"],[3908,4095,"does your father know how"],[4095,4175,"arrogant you are?"],[4212,4341,"Are you really trying to"],[4341,4496,"threaten me with my dad?"],[4571,4696,"Everyone in this town knows"],[4696,4888,"how powerful RG is."],[4971,5034,"And since we're the"],[5034,5271,"executives at RG, everyone in"],[5271,5363,"this town is"],[5363,5547,"basically beneath us."],[5597,5701,"I hope you can handle the"],[5701,5847,"consequences of your own actions."],[5901,6118,"You're not a threat to me."],[6514,6927,"As if I wear such a cheap knockoff."],[6998,7052,"Like this."],[8808,8829,"Derek."],[8992,9125,"I like you to take care of this."],[9171,9246,"Oh, fantastic."],[11907,11991,"Stop!"],[12057,12120,"Don’t do that,"],[12120,12195,"listen to Elise."],[12199,12270,"It's okay, Cato."],[12320,12420,"They're your mom's gifts."],[12420,12491,"She can do what she wants"],[12491,12654,"with them, but I just hope"],[12654,12758,"she won't regret it."]],"25":[[0,145,"You're pretty cocky for someone that's"],[145,329,"absolutely worthless."],[387,533,"You're just embarrassed that"],[533,667,"we see right through you."],[1080,1222,"I hope this is the wake-up call"],[1222,1380,"you needed, Cato."],[3040,3249,"Mom, the mayor is here."],[3474,3616,"Looks like they heard about"],[3616,3716,"Elisa's little scam."],[3782,3887,"Let's see how she tries to"],[3887,3999,"talk her way out of this one."],[4688,4813,"Mayor, come in."],[5205,5509,"Mayor Woods, what an honor on"],[5509,5689,"behalf of the Newton family."],[5751,5780,"Welcome."],[6631,6773,"And happy birthday, Mrs. Newton."],[6806,6906,"I hope you enjoy the gifts"],[6906,6990,"that your daughter-in-law."],[7077,7178,"Oh, oh, oh."],[7190,7307,"This really is embarrassing."],[7457,7645,"The wrench just brought us a-"],[7649,7841,"Wait a minute, that smell,"],[7912,8012,"it's familiar."],[8153,8408,"Is that the vintage bottle of cognac"],[8470,8621,"from the Napoleon’s own collection?"],[8779,8925,"This is a piece of history!"],[8963,9029,"Who broke it?"]],"26":[[33,212,"Mayor Woods,"],[212,308,"you must be mistaken."],[371,529,"This bottle is a knock-off."],[646,921,"Elise sent a whole batch of fakes"],[921,988,"to Mrs. Newton"],[988,1130,"based of the CEO of"],[1130,1259,"RG's Luxesphere order."],[1326,1463,"The real bottles are with the CEO."],[1672,1805,"Are you crushing my judgment?"],[1901,2006,"I have had the honor of"],[2006,2206,"attending a banquet held from"],[2206,2356,"the founder of RG."],[2394,2515,"She was generous enough to"],[2515,2598,"give me a bottle."],[2640,2744,"I will never forget that"],[2744,2923,"taste or that smell."],[2994,3165,"That is the 1811 Napoleon"],[3165,3249,"Grand Reserve."],[4971,5088,"No way, this taste..."],[5242,5409,"This is Napoleon's own cognac."],[5476,5584,"Is a two-million-dollar bottle."],[5643,5776,"There's only three left in the world."],[6147,6277,"That's impossible."],[6381,6523,"How would Elise ever buy"],[6523,6656,"such a legendary item..."],[6965,7119,"I told you to be more careful."]],"27":[[37,104,"It's just something that"],[104,191,"cannot be replaced."],[646,784,"T-two million dollars?"],[917,992,"I can't afford that."],[1076,1434,"If that bottle is real,"],[1434,1626,"then does that mean that all the"],[1626,1739,"other gifts are real too?"],[2519,2740,"Mayor Woods, this is a crystal"],[2740,2961,"embellished haute couture gown"],[2961,3140,"from Dior, hand-crafted."],[3186,3265,"One-of-a-kind."],[3324,3495,"This is a five hundred thousand"],[3495,3591,"dollar Dior gown."],[4396,4512,"A Patek Philippe watch."],[4600,4796,"This is worth over a million dollars."],[4838,5075,"This is a custom, one-of-a-kind"],[5075,5330,"Rolls-Royce Phantom."],[5834,6006,"Oh no, no."],[6627,6644,"No."],[6677,6727,"Oh no."],[7098,7399,"That is a ten-carat"],[7399,7578,"natural blue diamond."],[7686,7874,"It's a 5 million dollar gem, and you"],[7874,8012,"throw it in the fireplace!"],[8053,8170,"How dare you?"],[8262,8350,"How dare you"],[8350,8487,"destroy them like that?"]],"28":[[0,162,"Well, shouldn't"],[162,262,"they be with the director, then?"],[342,425,"Why are