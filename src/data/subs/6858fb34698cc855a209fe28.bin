,1042,"Please!"],[1088,1205,"It's an emergency!"],[1255,1305,"Be there, sir."],[1393,1438,"Cato,"],[1463,1572,"the thing has just come up"],[1589,1647,"very important."],[1668,1830,"I have to go, but I'll be back tomorrow."],[1889,1951,"What is it?"],[1981,2097,"Is there something I can help?"],[2168,2310,"No, I can handle it."],[2352,2423,"I'll see you soon."],[2681,2790,"Don't worry Mr. Newton."],[2802,2990,"I'll call security and ensure her safety."],[3207,3274,"Don't worry."],[3307,3395,"I'll be back tomorrow."],[3845,3933,"Everyone,"],[3983,4158,"the CEO of RG will be holding"],[4158,4291,"her wedding here at"],[4291,4454,"Maple Dining tomorrow."],[4521,4646,"She asked me to invite you"],[4646,4742,"all to attend."],[4800,4900,"She would be honored if you"],[4900,4971,"could make it."],[4988,5434,"The CEO of RG invited us!"],[5447,5505,"Of course!"],[5530,5605,"Of course we will be there!"],[5605,5726,"We will be there early!"],[5743,5801,"Early!"],[5809,5855,"Early!"],[5910,6035,"Who is Elise?"],[6093,6210,"How she know the owner of"],[6210,6285,"Maple Dining?"],[6410,6523,"It doesn't matter!"],[6635,6815,"The CEO of RG's wedding"],[6815,6956,"is tomorrow!"],[6965,7178,"And the most powerful and"],[7178,7415,"richest families in the country"],[7415,7469,"will be there."],[7524,7674,"I can find my perfect match."],[7686,7791,"Mom, we gotta go!"],[7791,7924,"I have to find the perfect outfit."],[7924,7974,"Oh look, we have"],[7974,8045,"to go with her!"],[8254,8308,"Bye, Mom!"],[8400,8450,"Bye, Cato!"],[8742,8942,"Elise, what are you hiding from me?"]],"63":[[1051,1180,"The fighter jet project?"],[1209,1272,"It's fine now."],[1288,1384,"Everything is back on track."],[1438,1543,"Let's get you a change into"],[1543,1647,"your wedding dress."],[1680,1730,"No need."],[1760,1826,"We're already"],[1826,1918,"behind schedule."],[1976,2106,"Cato has been waiting long enough."],[2435,2494,"Let's go!"],[3636,3845,"What a beautiful wedding!"],[3845,4083,"And so expensive."],[4133,4329,"Whoever is marrying RG CEO"],[4329,4441,"is a lucky man."],[4454,4654,"If only Cato wasn't so dumb ass"],[4654,4846,"to insist on marrying a grunt."],[4950,5080,"He's good looking enough that"],[5080,5326,"he could have shot the CEO."],[5405,5559,"RG's founder and CEO is a"],[5559,5684,"self-made billionaire."],[5684,5801,"There's no need to be dreaming about"],[5801,5947,"someone way out of my league."],[6064,6106,"Look!"],[6214,6360,"Someone's coming!"],[6360,6631,"Oh my god, CEO!"]],"64":[[12,87,"Cato!"],[120,187,"Elise!"],[200,287,"You finally back?"],[412,529,"What the hell is this?"],[550,700,"I thought it was the CEO."],[996,1092,"But, why are you"],[1092,1184,"wearing a veil?"],[1284,1368,"I'm so sorry."],[1368,1459,"I've had to keep it a secret"],[1459,1580,"this whole time because of my job,"],[1580,1797,"but the NDA has finally"],[1797,1914,"expired and I can"],[1914,2027,"tell you everything. - I want to know."],[2152,2381,"This is the CEO's wedding."],[2381,2585,"You don't belong here."],[2606,2711,"You weren't invited."],[2723,2811,"Right."],[2861,3073,"And look at your dirty uniform."],[3148,3299,"How poor you have to be enought"],[3299,3461,"even afford a decent dress."],[3541,3607,"Get out."],[3641,3712,"You're embarrassing"],[3712,3803,"the Newton family!"],[3820,3891,"No, Jane-"],[4208,4371,"Jane, Stacey."],[4371,4587,"I know you've always looked down on me"],[4587,4775,"for being raised poor,"],[4775,4954,"but it's made me who I am today."],[5021,5159,"I wouldn't be where I am"],[5213,5367,"if I forgotten where I came from."],[5409,5488,"I'm not ashamed"],[5488,5572,"of where I grew up."],[5630,5784,"Stop it, litter pretty words."],[5855,6047,"You are and always will be poor."],[6072,6252,"You're a lazy, useless person"],[6252,6393,"who doesn’t belong here!"],[6427,6619,"So get out of here before you"],[6619,6752,"ruin the CEO's wedding!"],[6781,6898,"I think the wedding would be ruined"],[6898,6981,"if I did now."],[7152,7186,"What?"],[7424,7469,"Wow."],[7674,7824,"The wedding is about to start."],[7841,7932,"Please, everyone,"],[7953,8033,"take your seats."]],"65":[[4,83,"Glad you're here."],[83,233,"Where is CEO?"],[275,358,"She’s already here."],[504,542,"What?"],[629,875,"She is? Why haven’t we seen her?"],[984,1067,"No need to look."],[1113,1388,"The wedding is for us."],[1463,1543,"Me and Cato."],[1747,1935,"No, Elise, stop messing around."],[1935,2089,"This is the CEO's wedding."],[2089,2143,"I'm not."],[2206,2356,"Cato, this wedding is for you and I."],[2406,2456,"I mean it."],[2506,2577,"Thank you for always"],[2577,2686,"being there for me."],[2740,2840,"I wouldn't have done any of"],[2840,2927,"this without you."],[2986,3161,"Didn't this trailer trash marry"],[3161,3265,"into the Newton family?"],[3336,3420,"She's stupid."],[3474,3607,"How could this be her wedding?"],[3741,3912,"Stop causing trouble, will you?"],[3912,4041,"Do you know where you are?"],[4041,4120,"Mom, calm down."],[4120,4170,"Move it!"],[4170,4250,"Stay out of this."],[4337,4533,"I'll throw this bitch out myself."],[5438,5588,"How dare you insult her?"],[5588,5680,"Who do you think you are?"]],"66":[[12,83,"That bitch"],[187,337,"not only she's poor."],[362,508,"She's sleeping around,"],[567,717,"on my son."],[738,817,"They were married for years"],[817,959,"and she walked out."],[1005,1172,"I am her mother-in-law,"],[1172,1330,"I have a right to put her in her place."],[1372,1447,"Oh, really?"],[1497,1609,"Well, when my husband walked"],[1609,1780,"out on me and left me with nothing,"],[1922,2085,"it was Ms. Gray who kept me in."],[2118,2231,"She taught me how to build"],[2231,2406,"this restaurant from the ground up."],[2406,2523,"So, if she's poor,"],[2556,2669,"what is that make you?"],[2844,3023,"Ms. Grey rose through the ranks"],[3023,3253,"faster than anyone in the military."],[3332,3461,"But she left it all behind"],[3507,3657,"just to be with the people she loves."],[3791,3958,"You don't deserve her as 