ng behind and"],[2873,2973,"scrubbing the toilets."],[3874,4008,"Who said you could talk like this?"],[4012,4133,"You came just in time,"],[4133,4266,"this bitch is try to get a free meal."],[4671,4738,"Idiot!"],[4854,4975,"I'm sorry, Ms. Gray."],[4975,5088,"I came as quickly as I could."],[5130,5180,"That's alright."],[5309,5342,"What?"],[5518,5689,"What the hell is going on?"],[5701,5905,"Why is the owner of Maple Dining"],[5905,6143,"treating this trailer trash like royalty?"],[6189,6268,"Trash?"],[6402,6531,"Do you even know this card is?"],[6531,6652,"It's just some fake."],[6744,6835,"It's the Exclusive"],[6835,6986,"VIP Reserve Black Card."],[7007,7061,"The only one like"],[7061,7136,"it in the world."],[7228,7303,"Wait, what?"]],"59":[[0,70,"Ms. Gray,"],[141,271,"on behalf of Maple Dining,"],[271,412,"I sincerely apologize"],[412,538,"for how you're retreated tonight."],[592,804,"Your meal and your family's,"],[804,905,"it's on the house."],[1226,1484,"The card is actually real, Elise."],[1505,1622,"Who on earth is she?"],[1685,1743,"It's okay."],[1789,1981,"I can pay full price for my meal."],[2102,2369,"But Regina plans to pay for"],[2369,2456,"everyone else's."],[2544,2677,"Thank you, Regina."],[2865,2907,"Fine!"],[2982,3132,"It's not like I can't afford it."],[3199,3244,"I'll pay."],[4062,4250,"Ma’am, it seems you have insufficient"],[4250,4346,"funds in your account."]],"60":[[25,225,"What? I have two million dollars"],[225,279,"on that account."],[279,362,"How could that not be enough"],[362,479,"for just one meal?"],[517,746,"You ordered our premium dishes"],[746,930,"without checking the price?"],[992,1172,"All of these meals are made"],[1172,1305,"with the finest ingredients,"],[1305,1493,"rare delicacies from around the globe."],[1609,2043,"Oh, and that 1795 Louis XII Cognac."],[2077,2206,"That's worth five million."],[2239,2364,"So it seems like you wouldn't"],[2364,2519,"have enough funds to cover it."],[2640,2702,"It's true."],[2761,3119,"It rea