{"1":[[471,583,"Move it, Lieutenant!"],[1151,1238,"Lieutenant Cross!"],[1338,1434,"You've done enough."],[1472,1601,"Don't die trying to save us all."],[1659,1793,"I promised I'd get you all out of here,"],[1810,1889,"and I meant it!"],[2677,2781,"Lieutenant!"],[3687,3778,"Suppressing fire!"],[3778,3895,"Cover Lieutenant Cross!"],[4433,4500,"Alice,"],[4579,4654,"you're free now."],[4742,4821,"Back then you said"],[4821,4942,"if your dad hadn't forced you,"],[5013,5117,"you never would have married me."],[5809,6001,"I'm leaving Alice in your hands now,"],[6039,6177,"you better make her happy."],[6239,6302,"Yes, sir."],[6373,6481,"I won't let you down."],[7365,7432,"Don't touch me."],[7536,7661,"I know why you're doing this."],[7711,7816,"You think marrying me,"],[7816,7974,"making yourself the General's son-in-law,"],[7974,8108,"will help you climb the ranks?"],[8149,8212,"No, Alice."],[8212,8299,"I'm doing this"],[8341,8437,"because I love you."],[8437,8495,"Save it."],[8629,8746,"I know you fooled my father,"],[8746,8917,"but I won't be falling for your little act."],[8950,9042,"I'll be your wife."],[9213,9421,"But don't ever expect me to love you."],[10168,10260,"Alice."],[10318,10464,"Five years of marriage."],[10497,10648,"Five years of loving you."],[10731,10881,"Now, to die here,"],[10935,11027,"at last,"],[11073,11344,"this must come as a relief to you..."],[15548,15648,"I thought I died."],[15970,16086,"How am I suddenly back home?"],[16086,16149,"I..."],[16566,16624,"Alice!"],[16825,17008,"Why isn't your husband here?"],[17029,17146,"Oh, he's right there."],[17275,17363,"All these years"],[17363,17471,"you have been so cold to me."],[17538,17680,"Is being sent to the frontline"],[17680,17776,"really changed your mind?"],[19865,19999,"Poppy, I'd like to introduce"],[19999,20153,"you to my husband-to-be."],[20182,20270,"Jason Lang."]],"2":[[16,104,"Really, Alice?"],[104,187,"You're gonna flaunt your affair"],[187,287,"right in front of me?"],[1397,1455,"Am I dead?"],[1539,1689,"And now I came back as a ghost?"],[2168,2268,"Is this what you really wanted"],[2268,2394,"all along, Alice?"],[2940,2998,"If so,"],[3094,3232,"I won't hold you back anymore."],[4696,4988,"When I was alive, you felt chained to me."],[5184,5288,"Now that I'm dead,"],[5563,5684,"I'm tied to you."],[5764,5964,"What do you mean, husband?"],[6043,6177,"What about Ryan?"],[6177,6398,"You haven't divorced him yet, have you?"],[6439,6552,"Ryan?"],[6685,6794,"I never loved him."],[6877,7082,"Jason has always been the one for me."],[7257,7428,"Oh, coming."],[7987,8058,"Hello, ma'am."],[8058,8170,"Are you Alice Cross?"],[8204,8383,"I'm here to deliver Lieutenant Cross'"],[8383,8525,"combat pay to his family."],[8633,8804,"Oh, you must have the wrong house."],[8804,9029,"The Ryan I know is a complete coward."],[9029,9167,"He would never brave the front lines,"],[9167,9334,"much less engage in combat."],[9401,9501,"Is that what you really think of me,"],[9501,9563,"Alice?"],[9626,9701,"A coward?"],[9747,9918,"Ma'am, I'm sure this is the right address."],[9947,10118,"Here is Lieutenant Cross' combat pay."],[10122,10235,"Please, take it."],[10264,10493,"Is Ryan playing a little prank?"],[10543,10643,"What, is he mad that"],[10643,10714,"I'm letting Jason"],[10714,10848,"stay over for a few days?"],[10848,10998,"Is that why he hasn't come home?"],[10998,11194,"Is he hiding down at the army base"],[11194,11382,"waiting for me to come find him?"],[11478,11607,"Well, you can tell him that"],[11607,11770,"I'm not gonna play his little game."],[12003,12074,"Good day."],[12379,12466,"The news of my death"],[12466,12575,"hasn't reached home yet."],[12629,12708,"Once it does,"],[12775,12921,"I'm sure you'll be overjoyed."],[12979,13054,"After all,"],[13104,13217,"if it wasn't for me,"],[13263,13334,"you could have married"],[13334,13405,"your first love"],[13455,13517,"Jason."],[13705,13801,"Hey, baby, who was that?"],[13863,14018,"Just one of Ryan's army buddies,"],[14018,14139,"helping him play a dirty trick"],[14139,14235,"for my attention."],[14297,14397,"He's lying about"],[14397,14476,"being on the front lines,"],[14514,14585,"even sending"],[14627,14739,"combat pay."],[14869,15002,"It's a little too late for him to be"],[15002,15127,"putting on an act"],[15127,15227,"to keep your eyes on him."],[15749,15857,"I'm calling his bluff."],[15890,15982,"I'm going straight down"],[15982,16041,"to the army base"],[16041,16157,"to see just how long"],[16157,16274,"he can keep the act up."],[18468,18556,"Hello."],[18556,18631,"I am here to..."]],"3":[[91,216,"I am here to see Ryan Cross."],[241,350,"Can you please tell him to come out?"],[408,483,"Stand by."],[950,1055,"Lieutenant Cross is not on post"],[1055,1126,"at the moment."],[1126,1192,"Wow."],[1284,1397,"He is unbelievable."],[1397,1518,"I already caved in"],[1518,1630,"and came all the way down here"],[1630,1785,"and still he refuses to see me?"],[1826,1951,"What is he playing at?"],[2089,2214,"What am I playing at?"],[2293,2456,"Just earlier you were throwing a party"],[2481,2556,"without a care for"],[2556,2690,"where I was and what I was doing."],[2831,2961,"Now suddenly you care?"],[3073,3370,"If you keep hiding, I will divorce you."],[3891,3983,"Before I was deployed,"],[4054,4158,"I prepared the divorce papers"],[4158,4283,"to be sent out in case"],[4283,4412,"I was killed in action."],[4542,4587,"Alice,"],[4683,4821,"you should be getting them soon."],[6740,6798,"What's wrong?"],[6802,6873,"You don't look well."],[6927,7178,"You and Ryan have a fight because of me?"],[7344,7586,"I'm sorry, I never wanted to upset you."],[7757,7845,"I should move out now-"],[7845,7899,"No, no,"],[7899,8058,"this has nothing to do with you."],[8233,8291,"Thanks, babe."],[8666,8875,"You're not even gonna read my text?"],[9017,9096,"Fine, Ryan."],[9138,9225,"Looks like our marriage"],[9225,9342,"really is over."],[9997,10139,"Get me a drink, Ryan."],[10193,10281,"I'm thirsty."],[10723,10881,"You never cleaned when I was home."],[10965,11115,"I thought you just disliked housework."],[11182,11340,"But for Jason, you jumped to your feet?"],[11444,11549,"I guess you never considered"],[11549,11649,"our house a home."]],"4":[[533,617,"Do you love me?"],[717,838,"I'm going to divorce Ryan."],[1222,1301,"Will you marry me?"],[1418,1605,"Of course I'll marry you!"],[1605,1693,"If it hadn't been for your father"],[1693,1797,"keeping us apart,"],[1805,1864,"we'd been married"],[1864,1956,"for years now!"],[2122,2281,"I promise I'll treat you right."],[2360,2448,"You'll be the happiest bride"],[2448,2531,"in the world."],[2644,2761,"You just texted me about"],[2761,2857,"getting divorced and,"],[2927,3028,"now you're already rushing"],[3028,3153,"to marry Jason?"],[3224,3445,"Alice, are you this anxious to leave me?"],[3557,3695,"Ahh, ah."],[4091,4233,"Why am I in such a hurry?"],[4233,4383,"She doesn't even want my help."],[4404,4504,"She needs Jason now."],[4504,4542,"Ryan."],[4600,4708,"Ryan, my meds."],[4721,4779,"Alice?"],[4817,4896,"What's wrong?"],[4904,5038,"Don't scare me now."],[5288,5426,"Ahh, ah."],[5655,5739,"Here."],[6835,6902,"Are you okay?"],[7165,7290,"Why do you have my medication?"],[7365,7482,"I'm your husband."],[7486,7653,"Of course I have your medication on me."],[7816,7966,"Okay, drop the cool guy act."],[8020,8116,"I know you're just doing that"],[8116,8308,"so I'll put in a good word with my father,"],[8308,8495,"but I'm not gonna fall for it."],[8787,8858,"Alice?"],[8938,9088,"Alice, what's wrong?"],[9180,9309,"It's just my stomach condition"],[9309,9405,"flaring up again."],[9605,9722,"Shit, I don't have my meds."],[9726,9830,"You should have your meds with you"],[9830,10001,"all the time if it's that serious."],[10022,10160,"How could you be so careless?"],[10160,10206,"I'll..."],[10289,10372,"I'll go home and get 'em."],[10410,10489,"Go home?"],[10489,10564,"Right now?"],[10602,10694,"Do you know how hard it was"],[10694,10802,"to get this reservation?"],[10802,10981,"We still have like three courses to go."],[11119,11177,"Sorry."],[11344,11382,"You're right."],[11386,11436,"It's my fault."],[11440,11482,"I..."],[11511,11669,"I should have my medication with me"],[11669,11740,"at all times."],[11790,11928,"You're apologizing?"],[12028,12095,"You never showed me"],[12095,12208,"that tenderness before."],[12278,12383,"Not in the slightest."],[12850,12912,"You again."],[12967,13071,"What did Ryan send you for"],[13071,13154,"here this time?"],[13204,13300,"Please don't misunderstand,"],[13300,13367,"ma'am."],[13371,13471,"I was only instructed"],[13471,13551,"to give this letter to you."]],"5":[[175,258,"I just"],[304,442,"texted him about a divorce"],[442,546,"and he immediately sends me"],[546,638,"divorce papers?"],[692,880,"Is he that eager to toss me aside?"],[909,984,"Ma'am, please,"],[984,1063,"I'm only the messenger."],[1117,1267,"Ryan must have found someone new,"],[1267,1463,"and that's why he's so ready to move on."],[1847,1951,"Oh, what am I talking about?"],[1976,2110,"Ryan wouldn't do that, right?"],[2235,2385,"No, you're right."],[2485,2615,"Ryan must be having an affair."],[2615,2752,"There's no other explanation."],[2915,3065,"Ryan is a complete coward."],[3128,3232,"He only ever made lieutenant"],[3232,3370,"because he's a general's son-in-law."],[3420,3570,"He would never have the balls"],[3570,3678,"to divorce me first."],[3807,3941,"You think I'm leaving you"],[3941,4045,"for another lover?"],[4158,4233,"The irony."],[4592,4662,"Soldiers are returning"],[4662,4725,"from the war zone"],[4725,4783,"next week?"],[4850,4921,"Understood."],[5075,5201,"Soldiers are returning"],[5201,5326,"from the war zone?"],[5447,5634,"Looks like my body will return next week."],[6352,6456,"Disgusting."],[7044,7148,"What is this?"],[7315,7436,"Cleared for combat."],[7557,7686,"As if Ryan would ever actually"],[7686,7786,"fight in a war zone."],[7916,8016,"He must have forged this"],[8016,8116,"as part of his prank."],[8241,8320,"Shameless."],[8370,8454,"What the fuck?"]],"6":[[116,296,"How long has your toilet been clogged?"],[329,533,"Were you too lazy to call a plumber?"],[533,671,"Now my shirt is ruined!"],[2043,2248,"Well, Alice, I fixed the toilet."],[2302,2364,"Ew, Ryan!"],[2364,2456,"Take that somewhere else!"],[2456,2581,"You're disgusting!"],[2581,2660,"Don't come near me"],[2660,2794,"until you scrub yourself clean!"],[2961,3115,"You called me disgusting?"],[3244,3357,"But look at you now."],[3478,3599,"You're willing to dirty your hands"],[3599,3703,"for the man you love?"],[3795,3953,"That man has never been me."],[4804,4879,"Wow."],[5084,5209,"Babe,"],[5242,5409,"you are absolutely stunning."],[5597,5726,"You're the most beautiful bride"],[5726,5830,"I've ever seen."],[5830,5976,"And I'm so excited for"],[5976,6101,"our wedding in three days."],[6101,6197,"Me too."],[6264,6414,"I never dreamed that I would"],[6414,6548,"marry you in this lifetime."],[6639,6727,"You've never said anything"],[6727,6827,"that sweet to me."],[6919,7019,"Instead, you just remind me"],[7019,7173,"that the worst part of your life"],[7173,7319,"was being forced to marry"],[7319,7415,"a loser like me."],[7582,7699,"When I hold my funeral,"],[7828,7962,"will you even attend?"],[8829,8921,"Mrs. Alice Cross."],[8925,9084,"This is Street Paul Hospital."],[9084,9230,"We found something strange"],[9230,9396,"during your last physical exam."],[9405,9517,"You need to come to the hospital"],[9517,9634,"as soon as possible."]],"7":[[166,308,"Doctor, my fiance doesn't have"],[308,500,"anything serious, right?"],[500,667,"Ma'am, you had a kidney transplant."],[696,804,"Whoa, whoa, whoa."],[804,880,"What did you say?"],[880,1046,"A kidney transplant?"],[1080,1217,"Babe, why didn't you tell me about this?"],[1217,1355,"Well, there's nothing to tell."],[1355,1559,"I had a condition back then"],[1559,1801,"and needed a kidney transplant."],[1826,2047,"Fortunately, I found a donor quickly"],[2047,2127,"and was"],[2127,2285,"in and out of the hospital in no time."],[2331,2414,"Oh, yeah."],[2444,2585,"Now I remember you."],[2660,2831,"Yeah, you came here with a man"],[2831,3036,"called Ryan three years ago."],[3165,3353,"That man took such good care of you,"],[3353,3582,"just buzzin' around like a bee."],[3599,3678,"But..."],[3870,4008,"Wait, wasn't he your husband?"],[4008,4141,"So what if he ran around for me?"],[4141,4270,"Anyone could do that."],[4270,4375,"Exactly."],[4412,4554,"And if it was me by your side back then,"],[4554,4654,"I'd do the same."],[4667,4733,"No, actually..."],[4750,4925,"I'd do ten times better."],[4925,5063,"But no, no, no."],[5063,5213,"He didn't just take care of you."],[5276,5338,"Ma'am,"],[5367,5509,"we just wanted to confirm that"],[5509,5630,"you had a kidney transplant."],[5634,5680,"Other than that,"],[5684,5868,"you are the perfect picture of health."],[5872,5976,"And congratulations"],[5976,6126,"on your upcoming wedding."],[6285,6356,"Thank you."],[6936,7152,"Why would you bring that up?"],[7157,7257,"Read the room."],[7257,7428,"I feel bad for that Ryan guy."],[7465,7645,"Everyone knew how much he loved her."],[7645,7832,"He even gave away his kidney to her."],[7987,8149,"I guess he's just"],[8149,8279,"not the one she's marrying."],[8333,8441,"This kidney..."],[8495,8646,"came from Ryan?"],[8758,8883,"Why didn't he tell me?"],[8979,9242,"Alice, do you really think Ryan"],[9242,9380,"donated his kidney to save you?"],[9380,9542,"Well, so what if he gave me his kidney?"],[9542,9693,"It's not like I asked him to."],[9722,9847,"Besides, there are so"],[9847,9926,"many donors out there."],[9926,10035,"I would have found somebody"],[10035,10105,"in no time."],[10268,10402,"I bet Ryan only did this"],[10402,10510,"to impress my father."],[10548,10869,"Everything he does is for himself."],[10994,11140,"That's who I am to her?"],[11282,11528,"A selfish, opportunistic fool?"],[11728,11874,"Maybe it's for the best."],[12032,12178,"I don't owe you anything anymore,"],[12178,12262,"Alice."],[12358,12462,"Not anymore."],[12858,12942,"Alice,"],[13058,13104,"wouldn't it be better"],[13104,13284,"if we had never met in this lifetime?"]],"8":[[275,433,"Alice, please."],[433,613,"Tell Ryan to come out and see me."],[633,742,"And tell him if he doesn't,"],[742,909,"I'm going to marry someone else!"],[913,967,"Ma'am,"],[967,1042,"Lieutenant Cross is"],[1042,1130,"still on the front lines."],[1217,1476,"Oh, out on the front lines."],[1476,1576,"Is he still sticking"],[1576,1705,"with that dumb story?"],[1793,1847,"Fine."],[1893,2031,"If he refuses to see me,"],[2031,2168,"then I hope he doesn't come back."],[2173,2289,"And I never have to see that"],[2289,2431,"stupid face of his."],[2627,2761,"Why make a scene when we both know"],[2761,2940,"Jason's the only one in your heart?"],[3082,3257,"Besides, you already got your wish."],[3378,3528,"You never have to see me again."],[3620,3757,"Since you refuse to see me,"],[3757,3933,"I will grant you your wish."],[3949,4108,"A divorce it is."],[5997,6056,"Tell him"],[6056,6147,"Jason and I"],[6147,6256,"are getting married this afternoon."],[6281,6423,"If he still wants to see me,"],[6423,6560,"then he better grow a spine."],[6598,6744,"This is his last chance."],[7540,7707,"My body should arrive home today."],[10035,10214,"Lieutenant Ryan Cross"],[10247,10385,"single-handedly"],[10385,10585,"wiped out a terrorist zone"],[10585,10877,"and saved countless American lives."],[10877,10981,"But sadly,"],[11006,11273,"our reinforcements arrived too late"],[11273,11415,"and Lieutenant Cross"],[11415,11557,"died in the line of duty."],[11611,11903,"He bravely sacrificed his life"],[11953,12166,"for our great nation."],[12166,12374,"We owe our victory"],[12474,12575,"to him."],[12670,12983,"All soldiers and all citizens"],[13000,13238,"shall remember his sacrifice."],[13338,13450,"Ten-hut!"],[13842,13926,"Come on, boys."],[14001,14134,"Let's take Lieutenant Cross home."],[14164,14297,"Sir, yes, sir!"]],"9":[[884,1159,"Wow, you look gorgeous."],[1159,1363,"You're gonna knock Jason's socks off."],[1564,1722,"Ryan, I gave you a chance."],[1722,1826,"You didn't take it."],[1826,1951,"You cheated first."],[1981,2056,"If you're not coming,"],[2072,2147,"I can marry Jason"],[2147,2293,"without any reservations."],[2385,2711,"Oh my God, Alice, you look incredible."],[3028,3253,"Babe, I'll love you forever."],[3269,3378,"I'll never cheat on you"],[3378,3532,"or ghost you like Ryan."],[3532,3837,"I will never, ever forgive him."],[3837,4020,"Divorcing him was the best decision."],[4020,4158,"He doesn't deserve your love,"],[4158,4316,"and definitely doesn't deserve"],[4316,4450,"you waiting for him like this."],[4696,4838,"It's almost time, let's head out."],[7340,7403,"Stop the car!"]],"10":[[212,275,"Stop the car!"],[479,579,"Are you crazy?"],[596,692,"We could have killed you!"],[742,825,"Where is Ryan?"],[871,955,"Is he in there?"],[955,1034,"Is Ryan here?"],[1076,1201,"I asked you a question."],[1242,1326,"Where is he?"],[1326,1422,"Babe, what's wrong?"],[1422,1514,"Answer me!"],[1526,1626,"Lieutenant Cross died"],[1626,1693,"in the line of duty during a"],[1693,1881,"counter-terrorist operation."],[2193,2344,"He was a true American hero."],[2448,2577,"Lieutenant Cross single-handedly"],[2577,2706,"took down a terrorist organization"],[2706,2869,"of over 300 members."],[2982,3128,"In the process of saving my life..."],[3420,3503,"He died."],[3883,3966,"Hey, babe."],[3966,4070,"I'm making your favorites."],[4104,4204,"I know you'll love it."],[4291,4391,"Here are your meds."],[4425,4562,"Make sure you take them on time."],[4742,4813,"Don't worry."],[4813,4942,"I'll do all the house work."]],"11":[[1026,1230,"It really is Ryan's uniform."],[1230,1322,"Babe, this must be"],[1322,1447,"another one of Ryan's pranks."],[1447,1539,"I bet that loser"],[1539,1710,"couldn't stand seeing you happy,"],[1710,1826,"so he orchestrated"],[1826,2077,"a fake funeral to ruin our wedding day!"],[2135,2218,"What kind of bull crap"],[2218,2314,"are you talking about?"],[2356,2448,"How dare you spread lies"],[2448,2594,"about Lieutenant Cross?"],[3207,3345,"Jason is right."],[3349,3486,"If Ryan really is dead,"],[3486,3636,"then where is the body?"],[3636,3749,"Why only put a photo"],[3749,3895,"in his uniform in the coffin?"],[3895,4049,"From where I'm standing,"],[4049,4337,"It looks like you're in cahoots with Ryan."],[4350,4446,"You all should"],[4446,4662,"be ashamed of yourselves."],[4671,4821,"You are disgracing this country"],[4821,5025,"with your fake American hero story."],[5025,5117,"Lieutenant Cross took"],[5117,5255,"several bullets for his country."],[5334,5459,"We can't show his bullet-ridden body"],[5459,5534,"at the procession."],[5584,5680,"That's why we had to put"],[5680,5759,"his photo and uniform"],[5759,5830,"in the casket."],[5830,6031,"Wow, how convincing."],[6097,6393,"What did Ryan offer you all to play along?"],[6452,6627,"You're really sticking to your guns?"],[6773,6919,"No matter what you hear about me,"],[6969,7065,"you think this is still just a trick"],[7065,7186,"to get your attention?"],[7223,7307,"Alice!"],[7828,7903,"Dad?"],[8037,8195,"Ryan sacrificed his life for this country"],[8195,8345,"and today is his funeral!"],[8387,8458,"And here you are"],[8458,8629,"marrying another man?"],[8662,8771,"You're dishonoring"],[8771,8996,"his memory and our family."]],"12":[[0,75,"I..."],[125,291,"was just wondering where Ryan"],[291,454,"got so many people to cooperate."],[454,558,"Turns out,"],[558,750,"my father had a hand in this all along."],[834,934,"What did you say?"],[938,1046,"Only the great and powerful"],[1046,1130,"General Vega"],[1130,1355,"could order so many people to play along"],[1355,1459,"with Ryan's little..."],[1459,1539,"prank."],[1539,1922,"Why do you insist on being so stubborn?"],[2135,2223,"Grab her."],[2281,2335,"What?"],[2339,2489,"She's attending Ryan's funeral"],[2489,2648,"and that's final."],[2648,2744,"If Ryan wanted to"],[2744,2840,"stop me from marrying Jason,"],[2840,2927,"then he should come out"],[2927,3061,"and say it to my face."],[3090,3182,"Coward!"],[3199,3303,"General Vega,"],[3303,3403,"I know you don't approve of me,"],[3407,3532,"but trust me when I say"],[3532,3695,"I'll make your daughter happy!"],[3695,3820,"You're in no position"],[3820,3928,"to be speaking to me."],[3966,4091,"Get the hell out!"],[4091,4291,"Dad, I love Jason."],[4333,4441,"I don't know why you insist on"],[4441,4550,"Ryan and I being together,"],[4550,4650,"but I never loved him,"],[4675,4758,"not once."],[4779,4875,"You're coming with me."],[4875,4959,"General!"]],"13":[[200,404,"I thought I felt a hand catching me,"],[458,579,"but no one's there."],[604,717,"Am I hallucinating?"],[717,838,"You're going to pay for that, punk."],[838,963,"See you at the court-martial."],[963,1038,"Let him go."],[1038,1130,"Jason didn't mean to."],[1130,1234,"It was an accident."],[1242,1401,"Alice, come with me."],[1426,1639,"Dad, why are you taking Ryan's side?"],[1672,1797,"He cheated on me first."],[1830,2035,"He's been ignoring me this entire time,"],[2035,2114,"and now he just"],[2114,2252,"doesn't want me to get remarried?"],[2285,2498,"He sent me the divorce papers."],[2556,2673,"I signed them."],[2673,2840,"He and I are over."],[2844,2961,"Divorce papers?"],[3061,3165,"Ryan."],[3211,3415,"Is this really what you've chosen?"],[3958,4049,"Alice,"],[4183,4462,"this is your last chance to see him."],[4658,4829,"If you want closure,"],[4963,5146,"Ryan and I will be waiting for you."],[5242,5476,"32 Oak Avenue."],[6698,6802,"Babe, that's probably part of"],[6802,6944,"Ryan's scheme to win you back."],[6944,7086,"He's just trying to get your attention."],[7119,7194,"I know."],[7194,7332,"A coward like him would never"],[7332,7411,"brave the front lines,"],[7411,7607,"much less sacrifice his life for anybody."],[7645,7878,"His stupid, petty tricks"],[7878,8024,"are not going to win me back."],[8053,8195,"They only disgust me."],[9296,9430,"General, we..."],[9459,9563,"Don't mind her."],[9751,9926,"Ryan's ready to be laid to rest."],[10076,10135,"Let's give him the"],[10135,10293,"hero's send-off he deserves."]],"14":[[141,321,"Dear Holy Father who art in heaven,"],[437,558,"we gather here today,"],[558,875,"to honor the memory of Ryan Cross."],[925,1034,"Dearly beloved,"],[1067,1259,"we gather here today,"],[1259,1493,"to join this man and this woman"],[1539,1680,"in holy matrimony."],[1705,1772,"Oh God,"],[1872,2081,"we come before you today"],[2081,2189,"with heavy hearts."],[2302,2548,"We thank you for the gift of life"],[2548,2848,"and for the life of Ryan Cross."],[2865,3065,"May he now find peace"],[3111,3253,"from earthly suffering."],[3361,3603,"And by the power vested in me,"],[3661,4008,"I now pronounce you husband and wife."],[4124,4270,"You may now kiss your bride."],[4537,4667,"You've never kissed me before."],[4771,4846,"Not like that."],[5213,5409,"Congrats, Alice."],[5434,5638,"You finally married your true love."],[5663,5759,"You'll never have to see"],[5759,5914,"that loser Ryan, again."],[5930,6043,"True."],[6043,6210,"I am really free of him."],[6214,6302,"And I can finally be"],[6302,6468,"with my one true love."],[6623,6731,"Let's take a group photo."],[6748,6886,"Ooh, let's do it."],[6973,7044,"Okay."],[7069,7240,"A big smile, everybody."],[7344,7511,"I wish you happiness, Alice."],[8116,8212,"See if you like it."],[8466,8579,"Ryan?"]],"15":[[171,246,"Ryan?"],[304,404,"What did you say?"],[725,863,"I don't see anything."],[863,996,"You must be mistaken."],[1105,1213,"Are you crazy?"],[1242,1330,"Why would you bring up"],[1330,1463,"your ex-husband's name?"],[1463,1580,"You're going to upset Jason."],[1664,1743,"I'm sorry."],[1793,1856,"You're right."],[1860,1947,"It's just..."],[1947,2035,"On the way over here,"],[2035,2193,"everyone kept saying that Ryan had died,"],[2193,2389,"and I can't get it out of my head."],[2389,2523,"That damn Ryan."],[2523,2669,"What is he, a ghost?"],[2673,2815,"It's like he keeps haunting us"],[2815,2932,"each step of the way."],[3023,3207,"I can't believe he faked his own death"],[3207,3328,"to get your attention."],[3353,3495,"Well, I'm not gonna fall for it."],[3703,3803,"Ooh, babe,"],[3803,3924,"we should head to the cocktail order"],[3924,3966,"right now."],[3991,4083,"Oh, you go first."],[4116,4191,"I'll meet you there"],[4191,4304,"after I head to the restroom."],[4316,4358,"Okay."],[4550,4625,"Did you hear?"],[4667,4804,"The bride's ex-husband"],[4804,4896,"was a soldier"],[4896,5071,"who died in action a week ago."],[5071,5296,"She just dropped it with no hesitation"],[5296,5434,"and married Jason today."],[5434,5630,"Oh my God, are you for real?"],[5630,5726,"Dead serious."],[5780,5922,"I heard the funeral's today."],[5968,6010,"That's why the"],[6010,6126,"bride's father is not here."],[6193,6418,"He's attending her ex-husband's funeral."],[7257,7369,"Could Ryan,"],[7532,7645,"really be dead?"]],"16":[[175,296,"Where have you been?"],[296,433,"We've all been waiting for you."],[483,608,"Actually, could you"],[608,746,"hold them off a bit longer?"],[779,884,"I'll be back soon."],[884,946,"I just..."],[946,1005,"I need to check out"],[1005,1076,"the address my father gave me-"],[1076,1134,"No, no, no, babe."],[1134,1263,"There's no need for you to go."],[1263,1363,"You know it's just another one of"],[1363,1497,"Ryan's schemes to win you back."],[1526,1714,"But something just feels off."],[1718,1893,"I need to see it with my own eyes."],[1906,1956,"Ah!"],[2031,2106,"What's wrong?"],[2243,2318,"Nothing."],[2318,2394,"It's just..."],[2398,2510,"Remember that injury I got"],[2510,2602,"from saving you back then?"],[2635,2765,"It's flaring up again."],[3036,3157,"Three years ago..."],[3157,3274,"When I was hiking,"],[3290,3449,"I got caught in a landslide."],[3482,3566,"When I woke,"],[3582,3816,"I was already lying on a hospital bed."],[4120,4258,"Are you the one that saved me?"],[4358,4441,"Huh?"],[5021,5313,"Yeah, I'm the one that saved you."],[5626,5705,"Does it hurt?"],[5709,5834,"Should I take you to the hospital?"],[5872,5951,"It's fine."],[5972,6051,"Just go to the address"],[6051,6135,"your father gave you."],[6160,6268,"I'll be okay."],[6339,6414,"Alice,"],[6498,6656,"the person who actually saved you"],[6656,6781,"from that landslide back then"],[6781,6865,"was me."]],"17":[[66,183,"Back then in the hospital,"],[183,367,"I noticed a soldier who ran in"],[367,496,"carrying a woman in his arms."],[538,688,"He was covered in wounds,"],[692,850,"but he left before her treatment finished."],[909,1009,"I went over to the woman"],[1009,1151,"out of curiosity,"],[1151,1292,"and that's when I met Alice."],[1343,1447,"Her misunderstanding"],[1447,1589,"let me win her heart."],[1593,1730,"No, no, forget it."],[1839,1935,"This is our wedding."],[1989,2122,"I should be by your side."],[2339,2506,"They say till death do you part,"],[2506,2615,"but our bride took that"],[2615,2769,"a little too seriously."],[2794,2973,"As soon as her ex-husband died,"],[2977,3086,"she immediately jumped"],[3086,3174,"to the next guy."],[3174,3249,"How scandalous."],[3311,3474,"She looks all sweet and innocent,"],[3474,3645,"but she's just a cold-hearted vixen."],[4020,4129,"What did you say?"],[4166,4237,"Say it again!"],[4250,4433,"Get your hands off me."],[4487,4658,"And I think you heard exactly what I said."],[5096,5188,"Well, so what?"],[5280,5488,"So am I not just allowed to remarry?"],[5651,5889,"Ryan is the one who cheated on me first."],[5930,6031,"But I'm just supposed to"],[6031,6147,"stay by his side?"],[6193,6343,"Play the dutiful wife"],[6343,6569,"and keep suffering in silence?"],[6735,6810,"Jason!"],[6844,7027,"Jason is the one who saved me back then!"],[7027,7140,"I love Jason!"],[7269,7461,"My father forced me to marry Ryan."],[7607,7699,"So tell me,"],[7753,7857,"am I not allowed to"],[7857,8058,"pursue my own happiness for once?"],[8233,8362,"Babe, babe, what's wrong?"],[8366,8462,"Why are we arguing?"]],"18":[[0,45,"Tell me,"],[45,120,"I am asking you,"],[120,204,"am I not allowed to"],[204,342,"chase my own happiness?"],[362,513,"If you're here to congratulate us,"],[513,642,"then we welcome you."],[650,775,"But if you're here to start a fight,"],[775,838,"then I'm sorry,"],[838,971,"I'm going to have to ask you to leave."],[1034,1117,"Please."],[1117,1247,"I don't know why you're acting dumb."],[1288,1459,"Your ex-husband was a hero"],[1459,1639,"who died fighting for this country."],[1659,1901,"We all know how well he treated you, too."],[1906,2060,"But instead of attending his funeral,"],[2064,2248,"you're off marrying this other guy."],[2335,2494,"Aren't we allowed to share our opinions?"],[2515,2615,"Exactly."],[2648,2706,"Don't you see"],[2706,2902,"how ridiculous your actions are?"],[2977,3057,"Oh, I get it."],[3178,3420,"Ryan hired you both as actors."],[3578,3753,"He really will spare no expense"],[3753,3895,"to try to win me back."],[4095,4266,"Calling us actors now?"],[4308,4462,"We all know your father gave you"],[4462,4604,"the address to the funeral home"],[4604,4750,"on 32 Oak Avenue."],[4800,4992,"Go find out the truth for yourself."],[5430,5538,"Babe, don't let them get to you."],[5643,5759,"Just take a deep breath."],[5768,5855,"Calm down."],[5943,5989,"Just think,"],[5989,6060,"by 6 o'clock,"],[6060,6181,"we'll be at our honeymoon."],[6185,6260,"Lieutenant Cross"],[6260,6389,"died in the line of duty during a"],[6389,6514,"counter-terrorist operation."],[6527,6644,"He was a true American hero."],[6669,6823,"Ryan sacrificed his life for this country,"],[6827,6961,"and today is his funeral."],[7019,7107,"And here you are,"],[7107,7257,"marrying another man?"],[7336,7511,"You're dishonoring his memory"],[7511,7649,"and our family."],[7782,7841,"No."],[7978,8087,"Now I need to see for myself"],[8087,8199,"what's really going on."]],"19":[[258,387,"While Lieutenant Cross'"],[387,542,"earthly journey has ended,"],[608,850,"he will forever remain in our hearts."],[975,1038,"Oh God,"],[1146,1368,"lead us through these difficult times."],[1368,1493,"In the name of the Father,"],[1493,1568,"the Son,"],[1597,1735,"and the Holy Spirit."],[1772,1847,"Amen."],[2373,2623,"If we have all said our final goodbyes,"],[2690,2902,"we will now close the coffin"],[2994,3265,"and lay Lieutenant Cross to rest."],[3303,3374,"Father,"],[3457,3682,"just one more moment, please."],[3766,3970,"We're waiting on one last person."],[4300,4462,"Did Ryan really die in battle?"],[4708,4804,"General, enough waiting."],[4829,4979,"Just let Ryan rest in peace."],[5171,5263,"Exactly, sir."],[5280,5459,"A hero should not be treated this way."],[6143,6231,"Close the coffin."]],"20":[[358,483,"You're just getting here now,"],[483,579,"do you even know-"],[608,721,"Thats enough, Tom."],[963,1092,"Wow!"],[1163,1330,"A fake funeral!"],[1397,1630,"Ryan really will go to such great lengths"],[1630,1780,"just to keep me from marrying Jason."],[1868,1968,"What did you say?"],[2006,2081,"Dad,"],[2131,2285,"will you only be satisfied once you"],[2285,2469,"have destroyed my reputation?"],[2544,2777,"Ryan's little prank has gone too far."],[2777,2873,"Do you know"],[2873,3028,"what people are saying about me?"],[3103,3319,"They say that I'm a fickle woman"],[3319,3445,"who jumped to the next man"],[3445,3645,"before my husband was six feet under."],[3887,4129,"Are you really going to ruin me"],[4129,4287,"just to help out one of your soldiers?"],[4287,4354,"You-"],[4354,4408,"Ryan"],[4408,4479,"gave me the"],[4479,4608,"divorce papers in the first place."],[4704,4796,"He shouldn't have a problem"],[4796,4917,"with me marrying Jason now."],[4917,5055,"I never even loved Ryan."],[5059,5142,"That's enough."],[5401,5492,"Didn't you come here"],[5492,5638,"to see Ryan one last time?"],[5734,5918,"Well, he's right through these doors."]],"21":[[33,212,"Why would I want to see a cheater?"],[266,425,"I came here to tell Ryan"],[425,567,"that he's never gonna win me back"],[567,763,"by using such a low-handed tactic,"],[763,1001,"so he might as well just quit."],[1013,1092,"Really?"],[1092,1184,"You still think Ryan’s"],[1184,1334,"playing a prank,"],[1334,1472,"just to get your attention?"],[1514,1639,"Lieutenant Cross was on"],[1639,1768,"the battlefield the whole time."],[1768,1914,"He never had time to cheat on you."],[1956,2072,"Oh, please."],[2143,2189,"I know you're"],[2189,2406,"just protecting your boys."],[2406,2602,"You soldiers are thick as thieves."],[2686,2798,"Deep down, she believes"],[2798,3011,"that I'm weak, useless,"],[3036,3123,"a coward."],[3211,3349,"That's why she looks down on me."],[3390,3445,"That's why she keeps"],[3445,3591,"denying the truth."],[3611,3737,"What about me, Alice?"],[3870,3991,"You don't believe me?"],[4033,4104,"You were the one"],[4104,4279,"who pressured me back then."],[4308,4391,"You were the only"],[4391,4504,"reason that I married"],[4504,4612,"someone I didn't love."],[4729,4817,"It's only natural for"],[4817,4934,"me to suspect you."],[4967,5105,"I mean,"],[5150,5213,"how else could"],[5213,5321,"a loser like Ryan"],[5321,5417,"get so many people"],[5417,5572,"to cooperate in his act?"],[5655,5864,"So you're really not going"],[5864,6064,"to go see Ryan one last time?"],[6110,6272,"Why should I see him?"],[6272,6389,"He's refused to see me"],[6389,6544,"this whole time."],[6544,6669,"If he really wants"],[6669,6823,"to see me, then he should come out"],[6823,7019,"begging me for forgiveness."],[7019,7207,"He's dead, Alice!"],[7282,7444,"He died on the battlefield,"],[7444,7645,"saving one of his fellow soldiers."],[7674,7791,"He couldn't see you even"],[7791,7957,"if you wanted to."],[7995,8120,"Do you not see what's"],[8120,8241,"clearly in front of you?"],[8241,8508,"This is Ryan's funeral!"]],"22":[[504,775,"You're really trying to tell me"],[775,984,"that cowardly Ryan"],[984,1134,"fought on the front lines"],[1134,1234,"and even bravely"],[1234,1472,"sacrificed himself to save others?"],[1730,1818,"Okay,"],[1818,1860,"okay,"],[1860,2047,"so this is a funeral."],[2085,2181,"So what happens when"],[2181,2289,"I walk up there?"],[2360,2552,"Is Ryan gonna rise up out of the coffin,"],[2552,2706,"and give me a surprise?"],[2857,2986,"He is a disgrace,"],[3044,3178,"an utter disgrace"],[3178,3307,"to American soldiers."],[3307,3361,"You!"],[3482,3545,"You're"],[3624,3728,"hopeless."],[3874,4295,"How could I have a daughter like you?"],[4692,4788,"Alice, we've got to head"],[4788,4875,"to the airport now,"],[4875,4967,"if we want to make it"],[4967,5075,"to our honeymoon."],[5075,5246,"Okay, I'll be right there."],[5505,5647,"Jason and I"],[5647,5776,"are going on our honeymoon."],[5910,6014,"Bye."],[6056,6126,"Stop!"],[6126,6252,"You still haven't seen Ryan."],[6252,6389,"Don't piss me off!"],[6427,6523,"Let go of me!"]],"23":[[0,116,"Let go of me!"],[125,250,"Let her go!"],[905,1192,"I only hoped you won't regret this."],[2164,2427,"If he really isn't dead."],[2506,2756,"Then please tell him that we are never"],[2756,2898,"getting back together."],[2957,3028,"But,"],[3098,3253,"if he really is dead..."],[3716,3853,"Then even better."],[4187,4287,"Finally, I can get that"],[4287,4429,"loser off my back."],[5380,5547,"I'm sorry, son."],[5668,5818,"You sacrificed your life"],[5818,5951,"for this country."],[6047,6172,"You suffered so much"],[6172,6322,"indignity in death."],[6427,6589,"It's my fault."],[6589,6740,"I raised a woman who doesn't"],[6740,6902,"cherish true love."],[6931,7211,"Instead, she runs off with a man"],[7211,7478,"who has no honor."],[7561,7624,"I never should have"],[7624,7757,"pushed you two together."],[7820,8033,"I'm so sorry I have made you suffer."]],"24":[[504,633,"Ryan,"],[633,763,"are you trying to tell me"],[763,909,"that you don't blame me?"],[1476,1580,"Babe, our honeymoon is"],[1580,1730,"gonna be amazing."],[1755,1835,"We're gonna make memories"],[1835,1972,"that'll last us a lifetime."],[2127,2239,"Babe, what's going on?"],[2373,2556,"Maybe a celebrity just landed."],[2585,2756,"Man, is that going to delay our flight?"],[2915,2990,"President Miller,"],[3003,3082,"President Miller."],[3123,3215,"President Miller,"],[3215,3290,"please tell us why"],[3290,3436,"your itinerary suddenly changed."],[3436,3524,"What business brings"],[3524,3599,"you here today?"],[3599,3687,"I'm here today"],[3687,3741,"to attend the"],[3741,3903,"funeral of a war hero"],[3903,3995,"who gave his life"],[3995,4129,"fighting for our country."],[4158,4312,"I want the people of this nation"],[4312,4437,"to remember his name."],[4479,4546,"Wow."],[4587,4658,"I never expected"],[4658,4713,"the president"],[4713,4796,"of the United States"],[4796,4959,"to be honoring my sacrifice."],[5000,5134,"And what was his name?"],[5134,5359,"His name was Ryan Cross."],[5380,5597,"He's a truly great American hero."]],"25":[[12,229,"His name was Ryan Cross."],[375,621,"He's truly a great American hero."],[809,1017,"No, I must be hearing things."],[1017,1155,"How could that coward's name ever"],[1155,1309,"come out of the president's mouth?"],[1947,2089,"Hi, may I see both of your passports,"],[2089,2143,"please?"],[2706,2794,"Babe, what's wrong?"],[2915,3153,"I think I left my passport at home."],[3219,3324,"What is wrong with you?"],[3324,3411,"Didn't I remind you"],[3411,3486,"a million times"],[3486,3557,"and you still forgot"],[3557,3645,"your passport?"],[3645,3791,"I'm sorry, I..."],[3841,3920,"I'm going to run home"],[3920,4004,"and grab it quick."],[4137,4308,"In all these years we were married,"],[4308,4446,"you never told me sorry."],[4571,4646,"Wait up."],[4646,4742,"I'll go with you."],[4742,4817,"No. It's fine."],[4817,4879,"I'm just gonna"],[4879,5009,"grab it and run back."],[5117,5217,"Okay, be quick though."],[5234,5292,"I'll be here."]],"26":[[1326,1476,"At ease, gentlemen."],[1730,1926,"My sincere condolences."],[1976,2127,"He was truly a hero."],[2147,2239,"Thank you sir."],[3044,3290,"Nearly 250 years ago,"],[3290,3449,"our forefathers founded"],[3449,3591,"this great nation."],[3674,3945,"One born from the ideals of freedom,"],[3945,4112,"and dedicated to the belief"],[4112,4375,"that all men are created equal."],[4475,4592,"We are only able to"],[4592,4729,"enjoy this democracy"],[4729,4967,"because our brave soldiers"],[4967,5109,"put their lives on the line"],[5109,5255,"to protect our freedoms."],[5376,5588,"Lieutenant Ryan Cross"],[5588,5764,"was one of these heroes."],[5847,5943,"While the citizens of"],[5943,6089,"America may not remember"],[6089,6252,"my eulogy here today."],[6297,6560,"I believe they will never forget"],[6560,6710,"this hero"],[6710,6919,"who died to protect our country."],[6956,7111,"Lieutenant Cross,"],[7173,7311,"we salute you."],[7311,7494,"America's finest hero."],[8166,8299,"Thank you. Sir."],[8671,8858,"Ashes to ashes."],[8858,9021,"Dust to dust."],[9088,9213,"Let us begin the burial."]],"27":[[112,208,"It's okay, ma'am."],[246,337,"Don’t be afraid."],[425,579,"You see that National Cemetery?"],[613,738,"They're holding a military"],[738,880,"funeral honors today."],[917,1084,"What you heard just now"],[1084,1238,"was a three volley salute."],[1292,1497,"Military funeral honors?"],[1793,1972,"Am I disappearing"],[2060,2143,"soon?"],[2181,2268,"Yeah, I heard they're..."],[2268,2460,"They're holding for a hero who died"],[2460,2615,"saving his comrades."],[2640,2702,"He defeated"],[2702,2869,"hundreds of terrorists."],[2869,2952,"Didn’t you notice"],[2952,3136,"a lot more of the soldiers in town?"],[3136,3274,"They're all here for his funeral."],[3474,3670,"Save fellow soldiers"],[3712,3995,"and killed hundreds of enemy soldiers?"],[4091,4225,"He was a true American hero."],[4241,4362,"Lieutenant Cross single-handedly"],[4362,4391,"took down"],[4391,4487,"a terrorist organization"],[4487,4650,"of over 300 members."],[4708,4829,"In the process of saving my life."],[4909,4988,"He died."],[5030,5117,"I'm here today"],[5117,5171,"to attend the"],[5171,5334,"funeral of a war hero"],[5334,5426,"who gave his life"],[5426,5559,"fighting for our country."],[5580,5747,"I want the people of this nation"],[5747,5847,"to remember his name."],[6022,6093,"Wait here."],[6193,6243,"Got it."],[6318,6377,"Be careful."]],"28":[[20,183,"Were they all telling the truth?"],[183,396,"Did Ryan really die in battle?"],[1518,1680,"No, it can't be."],[1680,1830,"Ryan has to be playing a prank."],[1830,1931,"I have to expose him."],[1931,2089,"How could a coward like him die"],[2089,2227,"on the battlefield?"],[2227,2360,"How could he become a martyr?"],[2360,2581,"How could he just leave me like this?"],[3023,3098,"Don't worry."],[3098,3244,"I'll do all the housework."],[3440,3578,"Here're your meds."],[3607,3753,"Make sure you take them on time."],[6919,7019,"Let me go!"],[7019,7111,"Let me see Ryan."]],"29":[[0,87,"Let me go."],[87,191,"Let me see Ryan."],[191,333,"You've got no right to be here."],[333,404,"Shouldn't you be on your way"],[404,471,"to your honeymoon"],[471,529,"with your new husband?"],[529,625,"Get the hell out of here!"],[625,792,"No, tell Ryan to come out."],[792,950,"This isn't funny anymore."],[963,1192,"Even now, you still believe"],[1192,1493,"we're all here for some prank?"],[1526,1664,"You're unbelievable."],[1676,1789,"What about me?"],[1818,2052,"You think I'm just here for a prank?"],[2268,2356,"I..."],[2531,2606,"I..."],[2857,2957,"No."],[3082,3224,"No, it can't be."],[3224,3378,"He can't be dead."],[3482,3595,"I didn't even get to see him"],[3595,3720,"for the last time."],[3778,3912,"I'm his wife."],[3912,4020,"Ex-wife."],[4020,4158,"No, I'm not."],[4429,4771,"Ryan, I’m ordering you to wake up."],[4771,4967,"You can't leave me behind."],[5530,5618,"Dad."],[5680,5768,"Please."],[5805,5989,"Please, I'm your daughter."],[5989,6135,"Please let me see him."],[6197,6519,"I gave you so many chances."],[6631,6848,"You didn't take any of them."],[6944,7090,"The biggest mistake"],[7127,7244,"of my life"],[7294,7545,"was arranging your marriage to Ryan."],[7653,7745,"And now I..."],[7853,8108,"I can't ever make it up to him."]],"30":[[212,458,"Lieutenant Cross is an American hero."],[513,600,"He deserves better"],[600,754,"treatment than this."],[813,967,"So you mean"],[967,1088,"all those times he wasn't"],[1088,1280,"responding to my messages,"],[1372,1480,"it wasn't because he was"],[1480,1618,"having an affair."],[1701,1814,"It was because he died on the"],[1814,1897,"front line."],[2214,2298,"And he only sent me"],[2298,2477,"the divorce papers"],[2477,2598,"because he was worried about"],[2598,2752,"what would happen if he died."],[2919,3019,"This whole time, I've"],[3019,3148,"misunderstood him."],[3224,3499,"Ryan never actually abandoned me."],[3499,3653,"Instead, I was the one"],[3653,3787,"who abandoned him."],[3837,4066,"He must be so disappointed in me."],[4166,4371,"I have Lieutenant Cross’s"],[4371,4558,"last will and testament here."],[4879,5013,"As I sit to..."],[5088,5267,"to write this will, I..."],[5342,5543,"I realize that I don't have"],[5543,5797,"the words to express"],[5918,6068,"the love that I have"],[6068,6197,"for my God,"],[6348,6481,"my country,"],[6623,6735,"and my wife."],[6773,6919,"In this life I..."],[6919,7211,"I have given all that I had to give."],[7340,7457,"And in death"],[7524,7720,"all that remains are"],[7720,8020,"my meager, worldly possessions."],[8062,8216,"To my men,"],[8216,8362,"my subordinates."],[8400,8483,"I leave all of"],[8483,8696,"my personal items at the base."],[8792,8938,"To my wife,"],[8992,9225,"I leave my accrued savings"],[9225,9392,"and combat pay."],[9576,9738,"I only hope"],[9759,10014,"the money can help her"],[10014,10385,"start a new life after my passing."],[10502,10739,"Ryan, Ryan..."],[10739,10831,"Lieutenant Cross sent"],[10831,11006,"his entire combat pay"],[11006,11223,"going right into your lover's pockets."],[11261,11444,"His devotion was wasted on you."],[11465,11565,"How did I raise"],[11565,11749,"such an ungrateful daughter?"],[11790,11982,"In his last moments,"],[11982,12237,"all he could think of was you."],[12262,12516,"He gave his life for us,"],[12541,12892,"and all we gave him was combat pay,"],[13004,13175,"which you spent"],[13238,13321,"on the man"],[13321,13613,"who sent him to his death."],[13613,13709,"What? Are you..."],[13709,13897,"Are you talking about Jason?"],[14022,14147,"What does Jason have to do"],[14147,14268,"with Ryan's death?"],[14301,14443,"Mr. president, I know it's classified,"],[14443,14522,"but she should know."],[14789,14839,"We did an"],[14839,14981,"investigation and"],[14981,15173,"found that Lieutenant Cross's"],[15173,15265,"bulletproof vest has been"],[15265,15515,"sabotaged by Jason Lang."],[15515,15644,"Lieutenant Cross should"],[15644,15744,"have survived the shot."]],"31":[[37,191,"What?"],[191,321,"That's impossible!"],[321,483,"I was with him"],[483,700,"as he took his last breath."],[800,1017,"I saw for myself that his equipment"],[1017,1151,"had been tampered with."],[1205,1438,"I knew something was wrong."],[1459,1522,"He should have been"],[1522,1655,"able to take that shot."],[1735,1881,"So I asked the president"],[1881,2064,"to launch an investigation."],[2114,2485,"That bastard Jason Lang"],[2548,2886,"is the reason that Ryan is dead."],[3069,3261,"Our investigation concluded"],[3261,3436,"that if Lieutenant Ryan's"],[3436,3557,"bulletproof vest hadn't"],[3557,3666,"been sabotaged,"],[3720,3845,"he'd be alive today."],[3878,4091,"So, Jason is Ryan's murderer?"],[4266,4387,"And I married him?"],[4446,4621,"Jason Lang had a personal vendetta"],[4621,4738,"against Lieutenant Ryan."],[4767,4871,"He was determined"],[4871,5025,"to steal everything from him."],[5117,5184,"His life,"],[5230,5388,"his combat pay,"],[5388,5526,"but most especially,"],[5572,5672,"his wife."],[5868,5935,"Babe,"],[5972,6156,"I'll love you forever."],[6156,6314,"I'll never cheat on you or ghost you"],[6314,6373,"like Ryan."]],"32":[[12,225,"Jason is at the airport now."],[266,400,"I'm going to go settle this."],[483,575,"I'm going to make him"],[575,667,"pay for this."],[688,930,"I will not let him get away with it."],[975,1051,"Wait."],[1322,1459,"Lock down that airport."],[1459,1526,"Make sure"],[1526,1701,"Jason Lang does not"],[1701,1847,"escape overseas."],[1935,2089,"We'll be there when I finish here."],[2114,2193,"Yes, sir."],[2356,2452,"I'll join you."],[2510,2631,"It'd be a slap in the face"],[2631,2756,"to every soldier who puts"],[2756,2819,"life at risk"],[2819,2990,"for this country to let that bastard"],[2990,3098,"get away with this."],[3236,3424,"Tell the FBI to drop everything."],[3461,3599,"I want to know everything there is"],[3599,3820,"to know about this Jason Lang."],[3858,3978,"All hands on deck."],[3978,4066,"Yes, sir."],[5134,5209,"Yup."],[5960,6097,"Jason,"],[6097,6197,"you killed Ryan!"]],"33":[[45,95,"Oww."],[212,300,"Ow, I don't know what you're"],[300,396,"talking about."],[404,533,"Still playing dumb?"],[533,725,"You sabotaged Ryan's gear."],[725,900,"You are the reason he's dead."],[917,984,"How did you..."],[1005,1034,"What?"],[1034,1146,"Where did you hear this from?"],[2293,2565,"Why don't we calm down?"],[2565,2681,"I did it, okay?"],[2681,2769,"So what?"],[2769,2852,"Shouldn't you be happy"],[2852,2957,"I got rid of him for us?"],[2957,3123,"I'm your husband now."],[3123,3257,"We both got what we wanted."],[3257,3382,"Not for much longer."],[3407,3603,"No, my father is on his way here,"],[3603,3803,"so get ready to face your crime."],[3816,3853,"Whoa, whoa, whoa."],[3853,3958,"Leo knows too?"],[3970,4099,"Stop right there!"],[4187,4245,"Jason,"],[4329,4400,"weren't you heading to"],[4400,4466,"your honeymoon?"],[4466,4550,"What's going on?"],[4550,4658,"Mom, you have to save me."],[4658,4825,"This woman is going nuts."],[4825,4888,"She wants her"],[4888,5000,"general dad to throw me in"],[5000,5159,"jail for her ex-husband."],[5159,5334,"That's the only trick she knows."],[5384,5547,"Flaunting her father's power"],[5547,5668,"as if it was her own."],[5709,5793,"Don't worry, Jason."],[5905,6072,"I have some very good news."],[6072,6147,"Yeah? What?"],[6147,6335,"You remember that White House"],[6335,6535,"job I helped you apply for?"],[6560,6710,"Well, you're basically"],[6710,6790,"a foot-in now."],[6906,7011,"I just found out"],[7011,7169,"the president himself"],[7169,7382,"personally ordered a check on you."],[7382,7494,"My guess is"],[7540,7607,"he's arranging"],[7607,7741,"the perfect post for you."],[7791,8070,"Presidential personal secretary,"],[8070,8162,"at the very least."]],"34":[[33,312,"Presidential personal secretary,"],[312,417,"at the very least."],[417,475,"Does that mean"],[475,533,"I don't have to be"],[533,658,"scared of Alice or her dad?"],[692,809,"No, honey,"],[809,842,"you have"],[842,975,"the president's favor"],[975,1155,"at such a young age."],[1197,1359,"What is an old general on the"],[1359,1451,"verge of retirement"],[1451,1555,"going to do to you?"],[2106,2164,"Hello?"],[2164,2231,"Hello."],[2231,2335,"Is this the future"],[2335,2527,"Presidential Aide, Mr. Lang?"],[2527,2610,"That's me."],[2610,2702,"Oh, well, I'm not"],[2702,2886,"the presidential secretary."],[2886,2973,"Not yet, at least."],[3023,3153,"It's only a matter of time."],[3194,3324,"This is the routine check"],[3324,3449,"the president does before"],[3449,3591,"naming his personal aide."],[3616,3707,"Mr. Lang,"],[3707,3782,"I'll be seeing you"],[3782,3891,"in the White House soon."],[3891,4087,"Oh, really? I, uhm..."],[4158,4371,"I...I don't know."],[4416,4525,"Mr. Lang, it's a long way"],[4525,4658,"to Washington, if you don't mind,"],[4658,4821,"I've got a private jet at the airport"],[4821,4946,"right where you are."],[4946,5050,"I've transferred it to you,"],[5050,5163,"just a couple of minutes ago."],[5259,5376,"Really? Wow."],[5376,5505,"You're too generous."],[5505,5588,"Thank you."],[5714,5885,"Is this what it's like to have power?"],[5885,6014,"I barely know the guy's name."],[6014,6168,"He just gifted me a private jet!"],[6331,6393,"I don't have to be"],[6393,6489,"scared of your dad,"],[6489,6660,"the old general, anymore."],[6731,6923,"Do you really think"],[6923,7007,"that the president would"],[7007,7086,"run a check on you,"],[7086,7232,"because he wants to"],[7253,7357,"hire you?"]],"35":[[37,183,"Duh, what else?"],[225,337,"Alice, just drop it"],[337,446,"and join me for the honeymoon."],[446,546,"And who knows,"],[546,658,"maybe I'll put in a good word"],[658,713,"for the president"],[713,813,"on your father's behalf."],[871,975,"Jason, have you considered"],[975,1084,"the fact that maybe"],[1084,1263,"the president is looking into you"],[1263,1347,"because you've just"],[1347,1509,"killed a war hero?"],[1509,1597,"The president doesn't"],[1597,1676,"actually care about"],[1676,1922,"a useless cannon fodder like him."],[1922,2047,"Ryan was just"],[2047,2156,"a coward who married"],[2156,2273,"the general's daughter"],[2273,2389,"to make Lieutenant."],[2389,2527,"It's almost too easy for me to"],[2527,2644,"steal his combat pay,"],[2686,2802,"his wife,"],[2848,2994,"and his worthless life."],[3090,3203,"Keep his name out of"],[3203,3374,"your filthy mouth."],[3382,3520,"He never used me."],[3586,3820,"He loved me with his whole heart."],[3912,4079,"He wasn't a coward like you."],[4145,4254,"Just turn yourself in now,"],[4254,4371,"because when my father"],[4371,4462,"gets here,"],[4462,4783,"you are in for a rude awakening."],[4946,5113,"I think you're overestimating"],[5113,5213,"your father's power."],[5213,5447,"Once Jason is in the White House,"],[5447,5572,"who knows,"],[5572,5630,"he might fudge"],[5630,5726,"a few documents"],[5726,5834,"and force your father"],[5834,5955,"into early retirement."],[5968,6064,"Exactly."],[6064,6193,"And you're over here saying,"],[6193,6402,"Ryan this, Ryan that,"],[6418,6552,"looks like you still have feelings left"],[6552,6681,"for some piece of shit."]],"36":[[0,116,"Looks like you still have feelings"],[116,246,"left for some piece of shit."],[308,417,"Oh, and"],[458,650,"I found his diary in your house."],[650,692,"I'm sure"],[692,825,"you'd like to know what's inside."],[825,892,"No?"],[917,1051,"That loser wrote all sorts of"],[1051,1130,"corny shit."],[1130,1217,"Give me that diary!"],[1217,1313,"What if I don't?"],[1351,1409,"Huh?"],[1409,1522,"I was planning on bringing this"],[1522,1597,"with us on the plane"],[1597,1718,"so we could laugh at it together."],[1718,1785,"But if the honeymoon's"],[1785,1918,"not happening anymore..."],[2031,2147,"There's no point in keeping this."],[2147,2243,"No!"],[2444,2590,"Just forget about him!"],[4683,4871,"Wow. You hated him before,"],[4871,4963,"and now you're acting like"],[4963,5146,"a lovesick schoolgirl?"],[5146,5267,"How hysterical."],[5467,5501,"Alice."]],"37":[[0,54,"What have you done"],[54,120,"to my daughter?"],[154,296,"Your pathetic little girl"],[296,387,"tripped and fell down"],[387,462,"the stairs"],[462,563,"all by herself."],[596,717,"Looks like Ryan's tragic"],[717,863,"death really messed with her."],[888,1026,"Now she's defending this loser"],[1026,1167,"like her life depends on it."],[1259,1401,"Too late to save him now, though."],[1401,1559,"Watch your mouth, soldier."],[1622,1705,"A brother-in-arms"],[1705,1897,"is fallen by your hand."],[1914,2035,"Have you no shame?"],[2043,2143,"Ryan's death means"],[2143,2252,"nothing to me."],[2264,2414,"And an old geezer like you doesn't"],[2414,2548,"mean shit to me either."],[2548,2627,"Soon the president"],[2627,2702,"of the United States"],[2702,2861,"will summon me to the White House."],[2861,3053,"I'm not afraid of your little lies."],[3340,3470,"I understand now."],[3582,3770,"He thinks the president"],[3770,4049,"wants a parasite like him."],[4083,4254,"Of course he wants me."],[4254,4333,"That's enough."],[4383,4546,"Let's leave this old man"],[4546,4713,"some shred of dignity."],[4771,4979,"After all, he hasn't retired,"],[5055,5105,"yet."],[5213,5388,"And when the time comes,"],[5426,5547,"he will change his tune."],[5568,5734,"Speaking of time,"],[5797,6014,"the Secret Service should be here"],[6014,6135,"any second."],[6135,6231,"What? The president's"],[6231,6393,"personally coming to see me?"],[6410,6535,"Am I that important?"],[6535,6765,"Oh, yes."],[6806,6961,"You're a VIP."],[6969,7203,"You slandered a war hero,"],[7223,7403,"embezzled his earnings,"],[7424,7607,"stole his wife,"],[7645,7799,"and caused his death."],[7970,8058,"The American people"],[8058,8191,"have something for you."],[8249,8395,"It's called justice."],[8625,8721,"And you,"],[8754,8829,"you leaked"],[8829,8942,"classified information."],[8975,9113,"Have you ever been to prison?"],[9113,9180,"No, you must be"],[9180,9305,"playing a joke on us."],[9305,9459,"The president is extremely busy."],[9459,9584,"He has no time for"],[9584,9709,"small measures like this."],[9934,10076,"Are you so sure about that?"]],"38":[[208,371,"Are you so sure about that?"],[575,696,"Are you Jason Lang?"],[725,829,"Mr. president."],[829,967,"You really came to see me?"],[967,1063,"Oh, wow."],[1063,1167,"You really didn't have to."],[1167,1251,"I came"],[1251,1363,"because I wanted to see"],[1363,1522,"what kind of traitorous scum"],[1522,1630,"killed an American hero!"],[2072,2135,"What?"],[2135,2239,"Mom, this is different"],[2239,2348,"than what you said."],[2364,2573,"Lieutenant Cross selflessly"],[2573,2756,"gave his life in the line of duty."],[2756,2894,"He never imagined"],[2894,2973,"a fellow soldier"],[2973,3094,"would sabotage him."],[3136,3236,"You will be tried"],[3236,3395,"before a military court,"],[3395,3620,"to face the harshest sentence"],[3620,3695,"this country is"],[3695,3824,"capable of carrying out."],[3920,4058,"Forgive me, Mr. President."],[4058,4158,"I made a mistake."],[4158,4291,"I was wrong."],[4308,4396,"It wasn't a mistake"],[4396,4446,"because you know"],[4446,4583,"what you did was wrong."],[4617,4725,"It was a mistake"],[4725,4850,"because you don't"],[4850,5075,"want to face the punishment."],[5117,5313,"It is too late for regrets."],[5417,5555,"No, Mr. President."],[5555,5634,"There must be"],[5634,5751,"some kind of mistake."],[5751,5868,"Get him out of here"],[5868,5980,"into interrogation."],[5980,6076,"No! Why does Ryan"],[6076,6222,"get to be a war hero,"],[6222,6272,"when he sleeps"],[6272,6402,"with the general's daughter?"],[6402,6614,"And I have to rot in jail?"],[6614,6698,"Why?"],[6698,6823,"I hate him!"],[6823,6923,"I wish I had what he had."],[6923,7090,"Power, connections..."],[7190,7332,"It should have been mine!"],[7332,7399,"Mine!"],[7582,7653,"General."],[7716,7778,"Sir."],[7799,7949,"Justice will be done."],[8033,8149,"Yes, sir."],[9092,9300,"I know I should be relieved,"],[9300,9392,"but..."],[9392,9601,"I mean, isn't it a little cruel?"],[9693,9738,"After all,"],[9738,9868,"he was the one that rescued me"],[9868,10060,"from that landslide back then."],[10060,10168,"What do you mean?"],[10289,10506,"Ryan was the one who saved you."],[10581,10639,"What?"]],"39":[[16,154,"What?"],[229,325,"It was"],[396,508,"Ryan?"],[508,633,"Not Jason?"],[633,792,"You really don't remember?"],[892,1055,"When the landslide happened,"],[1101,1305,"Ryan immediately jumped into action."],[1305,1463,"He broke protocol"],[1463,1764,"and abandoned his post at the base."],[1830,1901,"He rushed off to"],[1901,2093,"save as many people as he can."],[2131,2235,"Alice, when he came back,"],[2235,2423,"he was covered in blood."],[2448,2565,"His commanding officer"],[2565,2740,"disciplined him so strictly"],[2740,2811,"that it..."],[2811,2994,"it's severely handicapped"],[2994,3123,"his career advancement,"],[3123,3207,"Alice."],[3224,3386,"How could you not know this?"],[3436,3474,"I..."],[3474,3737,"I just assumed it was Jason,"],[3745,3920,"because he was"],[3920,4058,"right in front of me, but..."],[4237,4416,"Why didn't Ryan tell me?"],[4416,4546,"Have you ever really"],[4546,4688,"listened to him?"],[4813,5050,"Have you ever sat down,"],[5050,5163,"and just"],[5234,5451,"talked to him?"],[5718,5839,"I didn't know that"],[5839,5960,"it was him."],[6314,6406,"Alice?"],[6406,6468,"What's wrong?"],[6539,6644,"Alice, what's wrong?"],[6723,6798,"Help!"],[6840,6981,"Somebody help!"],[7565,7645,"Doctor!"],[7724,7807,"What's wrong with her?"],[7962,8066,"Her body's undergoing"],[8066,8187,"an acute rejection"],[8187,8320,"to her kidney transplant."],[8425,8541,"It's very serious."],[8583,8692,"How can that be?"],[8729,8888,"Ryan's kidney's been fine"],[8888,9084,"all these years."],[9100,9263,"We have to run more tests."],[10214,10410,"Karma's a real bitch."],[10477,10623,"This must be my punishment."]],"40":[[54,95,"Back then,"],[95,196,"Ryan's medical report"],[196,379,"did show he was missing a kidney."],[458,538,"He was almost forced into"],[538,642,"retirement."],[650,717,"He had a train harder"],[717,796,"than everyone else"],[796,980,"just to prove he could handle it."],[1021,1109,"Do you know how much suffering"],[1109,1213,"he went through back then?"],[1284,1372,"How exhausted he was?"],[1372,1459,"Tom!"],[1497,1605,"That's enough."],[3482,3611,"Father, please."],[3795,3953,"Forgive me, for I have sinned."],[4029,4116,"And what sins"],[4116,4279,"do you wish to confess?"],[4337,4554,"I let my wrath get the better of me."],[4650,4779,"I resented my husband"],[4779,4850,"because my father"],[4850,5005,"forced us to get married."],[5021,5201,"I didn't appreciate anything"],[5201,5301,"he did for me."],[5447,5543,"Alice, hold on."],[5572,5722,"We'll get to the hospital soon."],[5935,6026,"Alice,"],[6068,6185,"it was tough, but..."],[6247,6389,"we got your kidney donor."],[6468,6506,"It's from-"],[6506,6589,"It was tough?"],[6652,6777,"Doesn't sound so tough"],[6777,6919,"if you found one so quickly."],[7019,7157,"Don't use this as a conversation"],[7157,7253,"starter with me."],[7315,7419,"Just leave me alone."],[7670,7757,"I didn't know he"],[7757,7962,"donated his kidney to me."],[8153,8245,"Father."],[8412,8537,"Can my sins be forgiven?"]],"41":[[0,95,"Father,"],[254,417,"can my sins be forgiven?"],[467,663,"God will forgive all of your sins."],[717,942,"But I cannot speak for whether"],[942,1142,"your husband's soul"],[1222,1388,"can forgive you for the pain"],[1388,1476,"you caused him."]],"42":[[1251,1405,"Ryan,"],[1405,1476,"the results of your"],[1476,1643,"physical exam were excellent."],[1676,1785,"Your consciousness"],[1785,1901,"and this new body"],[1901,2097,"have synced remarkably well."],[2160,2243,"Even though it's already"],[2243,2373,"been a few days."],[2373,2469,"I still can't believe"],[2469,2615,"I've been resurrected."],[2615,2744,"Well, strictly speaking,"],[2744,2994,"it's not true resurrection."],[2994,3282,"It's advanced bionic technology."],[3282,3324,"We were"],[3324,3490,"successfully able to take"],[3490,3866,"your consciousness and transfer it"],[3928,4229,"to the cyborg body."],[4450,4808,"So now your body"],[4808,5067,"and consciousness are one..."],[5380,5451,"Ah..."],[5630,5797,"Ah, please wear the helmet."],[5834,5951,"You just woke up."],[5951,6252,"So your mind and body are still"],[6289,6381,"stabilizing"],[6381,6552,"with their synchronization."],[6664,6752,"It'd be amazing"],[6752,6798,"if more"],[6798,7044,"people had access to this technology."],[7115,7232,"Yeah, I agree."],[7286,7503,"But you're the first specimen to"],[7503,7736,"ever successfully awaken."],[7774,7895,"Otherwise, a whole lot of"],[7895,8074,"soldiers who were killed in action"],[8074,8187,"would have"],[8187,8270,"been reunited with"],[8270,8358,"their families by now."],[8479,8571,"But what about you?"],[8571,8871,"It says here you had a wife"],[8933,9167,"before, and you were unable"],[9167,9296,"to contact her for a while"],[9296,9576,"because you were on a secret mission."],[9955,10105,"I'll never contact her again."],[10247,10314,"Now that I've been"],[10314,10456,"given a second chance,"],[10506,10631,"I'm not gonna waste it on her."]],"43":[[955,1117,"The base gave us the day off today."],[1201,1309,"So to surprise Alice"],[1309,1447,"with her favorite beef stew,"],[1505,1597,"I got up early and toiled"],[1597,1730,"at the stove for six hours"],[1730,1864,"to make sure it's perfect."],[1901,2018,"I know she'll love it."],[2056,2114,"Hungry, babe?"],[2335,2569,"I already have plans with Jason."],[2569,2844,"You can eat that by yourself."],[2965,3073,"Just have a bite,"],[3073,3157,"you'll love it."],[3157,3207,"Quit it."],[3566,3695,"I refuse to eat"],[3695,3832,"at the same table as you."],[4304,4487,"Even for something as simple as stew,"],[4487,4671,"you were always so thoughtful."],[4854,5055,"What the hell was I doing back then?"],[5363,5455,"Today,"],[5455,5693,"I organized Alice's medication."],[5714,5822,"Now, she'll never have trouble"],[5822,5947,"finding her meds again."],[6072,6231,"Today I made dinner and"],[6231,6339,"waited for Alice,"],[6377,6527,"but she never came back."],[6598,6827,"Alice is a really amazing gal."],[6827,7007,"From the moment I laid eyes on her,"],[7023,7107,"I knew she was the one."],[7369,7520,"Alice was really cold to me today,"],[7520,7699,"but I'm sure that if I keep persisting,"],[7699,7816,"and keep treating her right,"],[7878,7928,"I might be able"],[7928,8083,"to thaw that cold heart."],[8103,8249,"I love her so much,"],[8249,8458,"so can I do at least this much..."],[8479,8708,"Ryan, you cherished me so much."],[8854,8954,"But this whole time,"],[8954,9175,"I never truly understood you."]],"44":[[1038,1163,"She fainted due to intense,"],[1163,1347,"extreme emotional distress."],[1347,1413,"Make sure she doesn't"],[1413,1505,"get too agitated"],[1505,1647,"in the next few days, okay?"],[1710,1785,"Okay."],[2410,2548,"Oh, Alice,"],[2694,2894,"did it have to be like this?"],[2998,3374,"You should have just appreciated"],[3374,3661,"Ryan while he was still alive."],[3724,3920,"Now that he's gone,"],[3920,4179,"It's much too late for regret."],[4383,4562,"What are you..."],[4562,4725,"What are you talking about?"],[4854,4913,"Ryan's..."],[4913,5142,"Ryan is still at the base."],[5251,5363,"I'm gonna go find him."]],"45":[[0,91,"I'm gonna go find him."],[91,200,"No, no, what did you say?"],[425,575,"I need to go to the base"],[575,667,"to see Ryan."],[667,692,"He's..."],[692,850,"He's training there right now."],[963,1059,"I'm gonna go find him."],[1155,1338,"No, wait. What are you doing?"],[1355,1539,"Ryan's already gone."],[1539,1643,"Gone?"],[1643,1701,"He's gone."],[1701,1793,"How can you say that?"],[1793,1830,"No."],[1881,1989,"I, he's"],[1989,2097,"waiting for me to come find"],[2097,2198,"him at the base."],[2302,2414,"I need to see him."],[2431,2577,"Doctor! Help!"],[2815,2927,"I need to go."],[2969,3115,"I need to go."],[3282,3415,"I need to see him."],[3674,3787,"According to our test results,"],[3787,3916,"everything is fine."],[4008,4154,"My guess she's still reeling"],[4154,4354,"from the shock of losing her husband."],[4412,4500,"We'll watch her closely"],[4500,4671,"for the next three days, okay?"],[4742,4808,"How long would it be"],[4808,4950,"until she fully recovers?"],[5059,5176,"It's hard to say."],[5196,5305,"Shortest,"],[5426,5518,"three days."],[5563,5655,"Longest,"],[5655,5755,"three to four years."],[6131,6172,"Dad,"],[6268,6364,"where's my ring?"]],"46":[[16,95,"Dad,"],[166,287,"where's my ring?"],[625,754,"You told me you threw it away"],[754,842,"at the base."],[863,942,"What?"],[1005,1138,"Why would I throw my ring away?"],[1138,1317,"No, I need to find my ring."],[1317,1447,"No, you need to rest."],[1447,1568,"Besides, it's raining"],[1568,1676,"cats and dogs outside."],[1701,1839,"If I can't find it,"],[1839,2006,"I'll hurt Ryan's feelings."],[2006,2085,"Alice,"],[2227,2452,"you need to get a hold of yourself."],[2469,2644,"Ryan's already dead."],[2702,2877,"No, no, I don't believe you."],[2877,2957,"You're lying."],[3057,3178,"I need to find my ring."],[3716,3908,"Where is it? Where?"],[3908,4041,"Where is my ring?"],[4041,4270,"Where are you? I had my ring."],[4270,4512,"Why did my dad say you were dead?"],[4512,4729,"I can't find my ring for Ryan."],[4946,5138,"I can't find my ring."],[5764,5880,"Is that Ryan's wife?"],[5893,6031,"Yes, but if you ask me,"],[6031,6164,"she brought it upon herself."],[6214,6293,"Just ignore her."]],"47":[[12,133,"Ryan was a devoted husband"],[133,225,"to her."],[225,354,"He did everything for her,"],[387,458,"but she just kept"],[458,621,"hurting him over and over."],[838,996,"Worse, immediately after Ryan died,"],[996,1063,"she upped and married"],[1063,1167,"someone else!"],[1167,1317,"No hesitation."],[1426,1488,"I really don't get"],[1488,1647,"why she's only regretting it now."],[1810,1872,"If I had a man"],[1872,2010,"like that, I cherish him."],[2081,2131,"I'd give him"],[2131,2235,"everything he wanted."],[2298,2431,"Ryan,"],[2431,2644,"you probably forgot about me,"],[2644,2723,"but I remember our"],[2723,2911,"childhood so clearly."],[3053,3140,"These are my"],[3140,3224,"homemade jump ropes?"],[3224,3315,"Well, they don't look"],[3315,3407,"like homemade jump ropes."],[3432,3599,"I don't know what these even are."],[3645,3712,"What do you think?"],[3741,3883,"Hay, leave her alone!"],[4133,4229,"Don't be scared."],[4229,4366,"I already chased him off."],[4654,4808,"Thank you."],[5889,5968,"Ryan,"],[5968,6039,"what do you want to be"],[6039,6164,"when you grow up."],[6352,6460,"My mommy and daddy"],[6460,6552,"were soldiers."],[6552,6677,"Grandma said that they died"],[6677,6819,"protecting our country."],[6819,6961,"I want to be like them."],[6961,7107,"I want to be a soldier!"],[7127,7319,"Wow, that's so cool."],[7319,7494,"Then I want to be an army doctor"],[7494,7649,"so I can fix you up,"],[7649,7766,"if you get hurt."],[7766,7899,"I won't let you die."],[8241,8341,"Although I didn't become"],[8341,8420,"an army doctor,"],[8420,8658,"I still kept my promise."],[8658,8762,"I didn't let you die"],[8762,8896,"on the battlefield."],[8917,9000,"Now,"],[9054,9242,"I'll do my best to protect you."]],"48":[[1126,1388,"Oh, my tin soldier has returned."],[1539,1676,"Did the mission go smoothly?"],[1718,1822,"Smooth as silk."],[1847,1989,"I saved a lot of lives."],[2185,2285,"What's on the menu?"],[2318,2489,"Strawberries and chicken?"],[2489,2602,"My favorite."],[2698,2811,"Dinner's almost done."],[2811,2886,"So, do you mind"],[2886,3053,"helping set the table..."],[4596,4688,"Oh, Ryan, wait,"],[4688,4988,"I need to talk to you about something."],[5096,5234,"What is it, sweetheart?"],[5267,5392,"Over the last three years,"],[5392,5588,"you have been on so many"],[5588,5847,"successful secret missions, and"],[6006,6160,"everyone loves you."],[6160,6260,"And soon,"],[6260,6385,"we're going to tell them"],[6385,6635,"about this cyborg soldier initiative."],[6648,6773,"Which means that"],[6886,7098,"General Vega will want to see you."],[7232,7440,"Sweetheart, that's fantastic news."],[7499,7661,"You know Leo is like a father to me."],[7695,7891,"Yeah, I know, uhm..."],[8024,8128,"It's just that means"],[8128,8408,"that your ex-wife will know that"],[8441,8583,"you're back."],[8971,9154,"You know, I'll never go back to her,"],[9180,9259,"right?"],[9663,9797,"Well, I know that."],[9993,10085,"Well, then,"],[10122,10231,"is there anything else"],[10231,10368,"you wanted to tell me?"],[10568,10731,"Well, there is one thing."],[10785,10881,"Oh, yeah?"],[11002,11086,"You wanna"],[11148,11365,"keep doing that sweet thing?"],[11544,11611,"This thing?"],[11624,11690,"Yeah."]],"49":[[208,396,"Quickly, show me now."],[596,709,"This is the photo."],[734,792,"Look,"],[821,1001,"they captured my husband's ghost."],[1263,1330,"Ryan?"],[1393,1463,"I have already been"],[1463,1584,"to so many psychiatrist,"],[1584,1655,"and they all want me"],[1655,1772,"to accept the fact that he's dead."],[1772,1910,"But I know in my gut that"],[1910,2052,"he is alive out there."],[2615,2706,"I can sense it."],[2748,2865,"You must go to where he spent"],[2865,3040,"the most time when he was alive."],[3153,3244,"I see."],[3328,3511,"Well, he was always at the base."],[3561,3703,"I'll go try there."],[4466,4646,"Nice outfit, son."],[4842,4934,"I'm not sure how useful"],[4934,5096,"it will be on the battlefield, but..."],[5367,5551,"Sir, Alice is waiting outside."],[5551,5663,"She wants to see you."]],"50":[[417,592,"Alice, General Vega's in a meeting,"],[592,725,"but he'll be out soon."],[967,1051,"To be honest,"],[1051,1242,"I'm not a big fan"],[1242,1493,"of the Cyborg Soldier Initiative."],[1493,1735,"These things"],[1735,1910,"that come out of your lab."],[2043,2344,"It can't compare to my highly skilled"],[2344,2556,"real soldiers."],[2585,2756,"For instance, my boys,"],[2756,2873,"from this distance,"],[2873,2919,"they can hit"],[2919,3261,"that bullseye with 100% accuracy"],[3303,3420,"every time."],[3582,3699,"Can you do that?"],[5476,5551,"That shot"],[5551,5730,"should be neatly executed"],[5730,5930,"within five seconds."],[5960,6035,"That's a shame,"],[6035,6189,"only one of your rounds"],[6189,6314,"found its way to the bullseye,"],[6314,6423,"and all the rest missed."],[6481,6623,"I guess your cyborg"],[6623,6819,"soldiers aren't really all that, huh?"],[6890,7027,"General, I think you might wanna"],[7077,7178,"take a closer look."]],"51":[[1363,1559,"You targeted all the rounds"],[1559,1680,"dead center?"],[1739,1901,"What kind of machine are you?"],[1951,2089,"Well, I'm glad you can appreciate"],[2089,2231,"how incredible he is."],[2231,2414,"Um, don't get ahead of yourself."],[2414,2602,"I've seen this before."],[2602,2744,"I had a soldier"],[2744,2902,"once who could do this, he's..."],[3036,3194,"Lieutenant Ryan Cross, he uhm..."],[3303,3365,"Sadly, he..."],[3407,3611,"He died in the line of duty."],[3611,3782,"He's like a son to me."]],"52":[[450,538,"Ryan?"],[746,863,"Is that you?"],[921,1026,"Yes, sir."],[1126,1230,"Ryan Cross"],[1230,1359,"reporting for duty."],[1751,1935,"It really is you!"],[1997,2147,"Our hero has returned."],[2268,2394,"Accurately speaking,"],[2394,2565,"this is Ryan's consciousness"],[2565,2831,"transferred into his cyborg body."],[2882,2982,"Apologies, sir."],[3028,3132,"I've been conducting secret missions"],[3132,3253,"for the past few years, and"],[3307,3465,"that's why I couldn't contact you."],[3570,3766,"No worries at all, son."],[3845,3966,"Just..."],[4041,4133,"I can't believe you're back."],[4133,4300,"I'm so happy you're back."],[4333,4471,"Alice is going to be overjoyed"],[4471,4629,"when she hears about this."],[4629,4738,"This is incredible."],[5138,5234,"Actually, sir,"],[5367,5509,"I don't want to see Alice."],[5726,5793,"Oh."],[5980,6143,"Oh, yes, I see."],[6289,6527,"My greatest regret has been"],[6527,6806,"forcing you two together."],[6944,7040,"But this,"],[7073,7278,"this is your fresh start, son."],[7311,7553,"You should never waste your love on"],[7553,7678,"someone like her."],[7724,7811,"I won't."],[7862,7920,"And,"],[8103,8224,"I have someone else in my heart."],[8892,8988,"I understand."],[9021,9142,"I wish you both"],[9209,9380,"nothing but happiness."],[9434,9476,"Thank you."],[9601,9788,"We're getting married."],[9788,9918,"And I was wondering if you'd"],[9918,10076,"be able to be our witness."]],"53":[[62,158,"Oh, Ryan,"],[158,275,"your mind-body link"],[275,383,"hasn’t fully stabilized,"],[383,492,"so you should probably put"],[492,600,"that helmet back on."],[2014,2102,"Alice."],[2139,2264,"I, I'm with"],[2264,2356,"some people right now."],[2356,2573,"Could you, could you wait outside?"],[3057,3174,"Ma'am, we'd appreciate it"],[3174,3382,"if you could keep your distance."],[3837,3866,"Alice,"],[3866,4016,"let me, let me introduce you."],[4016,4258,"This is, Dr. Linda Connors, and..."],[4371,4487,"And this is our"],[4487,4758,"our new military cyborg soldier."],[4850,5000,"He's quite a novelty."],[5067,5217,"A cyborg soldier?"],[5363,5488,"I’m sorry, you just"],[5488,5576,"you've reminded me"],[5576,5780,"so much of my late husband."],[5847,5939,"When I was outside,"],[5939,5993,"I even thought that"],[5993,6118,"I heard his voice."],[6118,6164,"Your voice"],[6164,6314,"sounds eerily similar to his."],[6327,6402,"Apologies, ma'am,"],[6402,6585,"but this is not your husband."],[6585,6685,"Alice, just... Look,"],[6731,6969,"why don't you go wait outside"],[6969,7107,"and I'll come and find you"],[7107,7273,"when I finish up with them?"],[7273,7319,"Alright?"],[7365,7436,"Okay."],[8829,8929,"You are Ryan!"]],"54":[[0,150,"You are Ryan, my husband."],[150,279,"You even have a serial number"],[279,392,"that says Ryan."],[888,1026,"It's just a serial number."],[1026,1180,"I'm not your husband."],[1426,1584,"All cyborg soldiers are"],[1584,1735,"assigned to random serial number."],[1735,1926,"And it's just a coincidence that"],[1926,2031,"his also happens"],[2031,2268,"to have your late husband's name."],[2281,2577,"No, but you sound just like him."],[2669,2882,"You are my husband, aren't you?"],[2936,3011,"No, ma'am."],[3011,3128,"I'm not your husband."],[3157,3253,"Alice,"],[3253,3336,"get a hold of yourself."],[3336,3445,"He said he isn't."],[3445,3603,"So stop pestering him."],[3603,3762,"It's been three years of this."],[3762,3983,"Stop searching for Ryan everywhere,"],[4016,4108,"okay? Enough!"],[4145,4262,"I'm not stupid!"],[4316,4425,"I know Ryan is dead."],[4425,4500,"I just..."],[4554,4683,"I can't accept it."],[4700,4842,"I still have so many things"],[4842,4925,"I need to tell him."],[4925,5046,"And he might still"],[5046,5226,"be alive out there somewhere."],[5367,5580,"But today, I finally"],[5580,5739,"found so