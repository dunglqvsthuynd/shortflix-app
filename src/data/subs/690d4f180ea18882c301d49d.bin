if that was true,"],[500,613,"it has nothing to do with you."],[725,875,"I want this bitch to pay,"],[917,1046,"an eye for an eye."],[1192,1347,"Do you know who I am?"],[1418,1630,"My father is a five-star General."],[1689,1822,"I don't know what your position is,"],[1822,1868,"but if you're in"],[1868,2052,"the military, I can absolutely"],[2052,2185,"have him punish you."],[2252,2448,"Alice, you're being irrational."],[2469,2535,"Your father would"],[2535,2711,"never do anything against Linda."],[2756,2944,"He's even here as a witness today."],[2969,3061,"Well, fine!"],[3111,3219,"Even without my father's help,"],[3219,3311,"I can make sure this bitch"],[3311,3415,"doesn't have it easy."],[3436,3528,"I would cling"],[3528,3741,"to her like a vengeful ghost."],[3753,3845,"And then one day,"],[3845,4016,"I will take my revenge."],[4037,4200,"You will not lay a finger on her"],[4200,4354,"as long as I'm alive."],[4425,4521,"Ryan,"],[4521,4692,"you probably don't know,"],[4692,4775,"but there are a lot"],[4775,4896,"of very powerful people"],[4896,5017,"in this world who would love"],[5017,5176,"to get close to my father through me."],[5288,5367,"Just a word,"],[5367,5488,"I can make her disappear."],[5576,5622,"But"],[5705,5826,"if you come with me,"],[5943,6085,"I promise not to hurt her."],[6106,6256,"You're despicable."],[6314,6502,"So what's it going to be, Ryan?"],[6573,6731,"Do you really want to test me?"],[6765,6873,"Do you think a regular guy"],[6873,6986,"like you can handle"],[6986,7157,"the dark side of politics?"],[7791,7899,"The president has arrived."],[7970,8087,"Please make way, everyone."],[8283,8420,"President of the United States?"]],"68":[[725,863,"Why is the president of the"],[863,1042,"United States at your wedding?"],[1092,1276,"Congratulations on your marriage."],[1372,1451,"Thank you. Sir."],[1547,1697,"Wow, I really can't believe"],[1697,1764,"that the president"],[1764,1851,"of the United States"],[1851,1972,"came to our wedding."],[2002,2077,"Sorry."],[2160,2335,"America's most powerful soldier,"],[2377,2464,"our youngest,"],[2464,2619,"most outstanding scientist"],[2619,2694,"getting married?"],[2736,2923,"I wouldn't miss this for the world!"],[2961,3057,"Thank you for making time"],[3057,3132,"in your busy scheduled,"],[3132,3194,"Mr. President."],[3691,3799,"You two are the future"],[3799,3891,"of this nation."],[3928,4095,"I will not tolerate anyone"],[4095,4254,"threatening you in any way."],[4295,4346,"I will do"],[4346,4446,"everything I can"],[4446,4525,"to protect you"],[4525,4662,"and your lovely wife."],[4729,4825,"Alice,"],[4833,5000,"if I hear anything about you"],[5000,5109,"attempting to scheme"],[5109,5226,"against these two,"],[5263,5434,"I will make you pay the price."],[5455,5622,"Do I make myself clear?"],[5655,5818,"Crystal, Mr. president."],[5980,6122,"All happiness to you."],[6723,6769,"Ryan."],[6886,6931,"Please."]],"69":[[29,150,"Please, I am begging you,"],[150,296,"tell me how to win you back."],[321,408,"I can't,"],[421,504,"I won't believe"],[504,679,"that you would just toss me aside."],[784,896,"There is no one,"],[967,1055,"no one,"],[1101,1251,"who loves you as much as I do."],[1322,1388,"Remember that night"],[1388,1438,"when you said you're"],[1438,1530,"stuck in the rain?"],[1580,1697,"You yelled at me for being late,"],[1697,1822,"but I was cooking dinner for you."],[1868,2052,"With one call I picked up"],[2052,2189,"and I ran outside with an umbrella,"],[2231,2373,"soaking, shivering,"],[2373,2489,"desperate to reach you."],[2548,2644,"But when I got there,"],[2677,2723,"you were having"],[2723,2877,"a candlelit dinner with Jason."],[2948,3069,"Not a drop of rain on you."],[3086,3132,"No."],[3174,3278,"You can't blame me."],[3278,3403,"I don't like the rain, Ryan."],[3403,3457,"I thought you would"],[3457,3536,"understand."],[3536,3611,"That's it."],[3628,3795,"I always tried to understand you,"],[3795,3958,"but you never tried to understand me."],[4262,4416,"You always thought I was a coward,"],[4462,4612,"an unqualified soldier,"],[4612,4804,"even my precious military career"],[4804,4904,"was a joke to you."],[4984,5113,"Our entire marriage,"],[5113,5284,"you never tried to understand me."],[5321,5438,"I'll change."],[5472,5584,"I told you, I promise you,"],[5584,5722,"I'll definitely change."],[5751,5897,"Once a heart freezes,"],[5930,6010,"not even the flames"],[6010,6110,"of hell can thaw it."],[6172,6293,"But I love you."],[6410,6502,"The person who loves you"],[6502,6639,"most in this world is me."],[6690,6823,"You don't love me."],[6852,6931,"You love the person"],[6931,7144,"that catered to your every request."],[7190,7273,"You used the excuse of"],[7273,7411,"being forced to marry me"],[7411,7565,"to take the moral high ground."],[7624,7682,"The person who"],[7682,7807,"desperately loved you is dead."],[8041,8174,"The only person in my heart now"],[8174,8266,"is Linda."],[8658,8804,"Let go of me, Alice."],[8896,9009,"Release me,"],[9125,9246,"and free yourself too."]],"70":[[412,533,"Free yourself too."],[942,1184,"Once you lose someone precious,"],[1184,1330,"you lose them forever."],[2677,2727,"I should be"],[2727,2919,"the one up there wearing that ring."],[3128,3257,"He should be my husband,"],[3257,3399,"but I didn’t cherish him."],[3561,3787,"What the hell was I thinking?"],[3832,3974,"Why the hell was I thinking?"],[4095,4195,"Oh, how did I..."],[4262,4421,"How did I let this happen?"],[4596,4767,"How can I let him get away?"]]}