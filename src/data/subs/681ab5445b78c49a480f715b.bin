"],[2527,2606,"You're right."],[2698,2781,"This time"],[2848,2982,"Anastasia's lucky."],[3090,3328,"My dad doesn't like me bullying people."],[3420,3616,"I'll make sure to fire those two salespeople"],[3616,3774,"before they run their mouths."],[4070,4166,"Wow wow babe."],[4220,4383,"You see that jacket your dad's wearing?"],[4466,4562,"That's gonna be worth"],[4562,4671,"6 figures."],[4859,4979,"By sticking with Claudia,"],[4979,5142,"I’ll rise to the top."],[5155,5351,"Live a good life."],[5405,5626,"Good thing I got rid of Anastasia."],[7132,7211,"Mr. Chester."],[7803,7916,"How's the madam doing?"],[7949,8187,"She's okay. She's in shock."],[8258,8420,"She'll be alright after she gets some rest."],[8429,8537,"We checked out the location"],[8537,8604,"you asked for"],[8604,8704,"the surveillance,"],[8737,8821,"it's broken."],[8908,9038,"We're working on a fix,"],[9054,9138,"but"],[9167,9205,"Miss Claudia"],[9205,9355,"was also at the jewelry store"],[9355,9417,"this afternoon."],[9434,9576,"She even fired two employees."],[9576,9663,"who were helping Miss Fallon."],[9693,9780,"I understand."]],"35":[[87,175,"I understand."],[283,592,"Sir, Claudia's temper is no mystery to you,"],[675,788,"and she doesn't take well to anyone"],[788,863,"but you ."],[942,1092,"Even the slightest dissatisfaction"],[1092,1242,"and she'll lash out at others."],[1397,1584,"Her attitude needs to be dealt with."],[3232,3319,"You're right?"],[3432,3557,"Do we wake you talking outside?"],[3737,3820,"No no."],[3970,4099,"I woke up on my own."],[4133,4337,"I didn't hear your talking at all."],[4462,4487,"Good."],[4529,4775,"The house has really good soundproofing."],[5009,5121,"Are you still feeling scared?"],[5180,5317,"As long as you're with me,"],[5413,5522,"I'm not scared."],[5830,6018,"You were trembling earlier so,"],[6068,6164,"didn't want to ask."],[6164,6297,"But now that you're feeling better,"],[6531,6619,"can you tell me"],[6810,6923,"who did this to you?"],[7240,7311,"It was Clau-