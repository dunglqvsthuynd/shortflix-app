ne who sent Anastasia"],[817,992,"to my dad's bed."],[1034,1234,"And now she's carrying the true heir"],[1234,1380,"of the Chester family?"],[1705,1860,"You don't need to act anymore."],[1935,2052,"I know about all the wrongs"],[2052,2289,"Anastasia has suffered at your hands."],[2289,2402,"Dad."],[2460,2644,"I know I was wrong."],[2673,2932,"I, I'll get along with with Anastasia"],[2932,3082,"from here on out."],[3107,3207,"I promise."],[3207,3420,"You only care about money and power."],[3495,3749,"You're selfish and ruthless,"],[3762,4016,"and you refuse to reflect on yourself."],[4066,4195,"I'll disown you and announce it"],[4195,4304,"to everyone."],[4375,4450,"From now on,"],[4450,4554,"your life has nothing to do"],[4554,4700,"with the Chester family."],[4750,4850,"And you won't get a single thing from"],[4850,5000,"the Chester group."]],"60":[[0,75,"Dad!"],[158,342,"I know I was wrong."],[371,508,"I was possessed by a demon."],[542,713,"And that was the problem."],[729,905,"I swear it wasn't me."],[955,1142,"I, just please don't make me"],[1155,1305,"leave the Chester family."],[1305,1434,"I'll do anything."],[1451,1559,"Please, dad. I please."],[1580,1664,"I'm not the one."],[1664,1805,"you should be apologizing to."],[1814,2031,"It's Anastasia. William,"],[2118,2277,"get her out of here."],[2410,2489,"Dad."],[2515,2686,"I never want to see her again."],[2686,2865,"No no dad."],[2865,3253,"No no no no!"],[3253,3386,"No no!"]],"61":[[229,350,"Anna, you're awake."],[383,492,"Are you feeling alright?"],[675,850,"Sir, you lied to me."],[975,1071,"You're Kayden,"],[1076,1238,"the richest man in the state,"],[1238,1338,"and Claudia's"],[1355,1497,"adoptive father."],[1518,1751,"But you didn't tell me any of this."],[1789,1997,"Do you think like Claudia that"],[2081,2268,"I only care about your status?"],[2448,2569,"I wanted to be a wife"],[2569,2715,"that you could be proud of."],[2781,2844,"But,"],[2844,2923,"why?"],[2990,3119,"Why did you lie to me?"],[3199,3278,"I'm sorry."],[3399,3520,"I'm so sorry."],[3595,3770,"I really didn't care about your money,"],[3866,3978,"even if you didn't want"],[3978,4037,"to keep the baby,"],[4037,4279,"I would have taken care of her myself."],[4404,4596,"Lucius lied to me but why did you?"],[4596,4879,"Why'd you lie to me?"],[4963,5042,"Why?"],[5809,6031,"Kayden, I want to try to trust you again."],[6076,6306,"I want to be brave and stay with you,"],[6402,6631,"even if I end up regretting it."],[6690,6827,"I won't let you regret it."]],"62":[[287,625,"What the fuck is her life?"],[950,1146,"It is reported that Mr. Chester"],[1146,1272,"has divided his share"],[1272,1472,"equally and transferred them to"],[1472,1697,"Mrs. Chester and their child."],[2018,2097,"Well so much"],[2097,2273,"for the daughter of the richest man"],[2273,2494,"in this state, huh?"],[2531,2656,"You're nothing but"],[2656,2873,"an adopted kid,"],[2919,3032,"with no chance of"],[3032,3157,"getting an inheritance."],[3253,3424,"Can't believe I waste my time"],[3432,3503,"with you."],[3503,3791,"How dare you blame me?"],[3849,3958,"Seriously?"],[4070,4166,"You couldn't even keep"],[4166,4266,"your own woman"],[4270,4350,"in check."],[4404,4600,"You're just an useless loser now."],[4742,4975,"An useless loser!"],[4975,5134,"I'm not gonna listen to you."],[5163,5263,"You're nobody."],[5605,5730,"Fuck you."],[5730,5822,"It is reported that"],[5822,6043,"Mr. Chester has divided his share"],[6043,6256,"equally and transferred them to"],[6256,6406,"Mrs. Chester and their child."]],"63":[[141,250,"Look at her,"],[271,421,"she looks just like Mr. Chester"],[421,571,"when he was a baby."],[717,909,"Mr. Chester, can I hold him too?"],[1939,2081,"This is the ring that my"],[2081,2189,"mother left me."],[2189,2444,"It's a symbol of the Chester family."],[2444,2527,"From now on,"],[2635,2831,"everyone will know that you're my wife."],[3290,3370,"I love you."],[3570,3741,"I love you too."]]}