{"1":[[888,1021,"For the longest time,"],[1063,1126,"I thought..."],[1126,1172,"Help!"],[1322,1376,"Love"],[1447,1589,"meant patience,"],[1630,1810,"meant loyalty..."],[2314,2377,"Are you okay?"],[2577,2640,"Oh, Henry!"],[2690,2831,"I thought I would never see you again."],[3090,3357,"...meant if I waited long enough,"],[3420,3574,"he would finally see me."],[3649,3824,"But he never did."],[4200,4291,"Henry!"],[4491,4583,"Henry!"],[5467,5518,"Henry!"],[5597,5743,"Happy anniversary, Henry."],[6147,6268,"I thought he was loyal,"],[6306,6423,"until the night"],[6423,6594,"everything fell apart."],[6694,6823,"Aw, Henry,"],[6848,6986,"I didn't know you had a maid."]],"2":[[471,554,"Oh, Henry?"],[638,692,"Miss,"],[746,825,"you're awake."],[842,975,"You were in critical condition."],[1159,1284,"It took time to stabilize you."],[1301,1443,"Oh, my head hurts."],[1443,1589,"There's something you need to know."],[1589,1868,"The accident allowed us to run a few scans."],[1897,1976,"We found"],[1985,2081,"a brain tumor."],[2239,2369,"What are you talking about?"],[2398,2540,"I know it's a lot to take in."],[2540,2686,"We ran the tests... You should probably..."],[2686,2811,"I'm dying?"],[2811,2936,"The condition is severe."],[2936,2982,"However,"],[2982,3140,"there are clinical trials in Switzerland."],[3140,3278,"Advanced treatment,"],[3278,3399,"high success rates."],[3440,3607,"But you may want to think carefully."],[3799,3895,"What do you mean?"],[3920,4016,"Means that"],[4024,4145,"all of your memories"],[4145,4258,"will be erased."],[4333,4500,"My memories?"],[4500,4567,"Yes."],[4579,4675,"Some might return,"],[4708,4875,"with the help of family and friends."],[5034,5121,"I..."],[5213,5351,"I don't have a family."],[5905,6081,"We removed this during the tests."],[6406,6635,"The surgery is scheduled in two weeks."],[6735,6873,"Let us know when you make a decision."],[8370,8420,"Hello?"],[8445,8516,"Henry?"]],"3":[[116,166,"Hello?"],[212,283,"Henry?"],[396,475,"Henry!"],[538,600,"Henry!"],[759,825,"Henry!"],[1197,1288,"Where did you go?"],[1338,1455,"That crash was serious."],[1480,1634,"You need to take care of yourself."],[1668,1789,"Stop fussing."],[1814,1939,"I told you I'm fine."],[1981,2110,"You've been with me this whole time."],[2147,2293,"Did you even talk to Olivia?"],[2356,2448,"You're still injured."],[2535,2581,"I have no time"],[2581,2690,"to take care of anything else."],[2902,2998,"She's calling you."],[3065,3178,"Aren't you gonna answer?"],[3324,3415,"Don't worry about her."],[3524,3603,"You're still hurt."],[3645,3812,"I don't want her to get the wrong idea."],[3816,3953,"She is your wife after all."],[4362,4429,"Right now,"],[4458,4575,"no one matters more than you."],[4713,4771,"Let's go."]],"4":[[300,362,"Oh no!"],[387,425,"My leg..."],[425,525,"Hey, are you okay?"],[571,667,"I think I hurt it."],[692,771,"Are you okay?"],[792,859,"I don't know."],[859,1030,"It suddenly feels hard to walk."],[1042,1213,"Don't be sorry, okay?"],[1222,1401,"You know I would do anything for you."],[1580,1643,"Miss,"],[1760,1843,"are you alright?"],[1868,1951,"Can you stand up?"],[2598,2694,"Are you Chloe Moore?"],[2702,2748,"Yes?"],[2786,2932,"Your test results just came in."],[2957,3048,"You're pregnant."]],"5":[[0,91,"You're pregnant."],[171,271,"What, Chloe?"],[271,379,"You're pregnant?"],[421,467,"Why?"],[467,525,"I thought..."],[625,746,"Oh my god!"],[771,846,"I'm pregnant!"],[846,909,"Henry!"],[1076,1197,"Good thing you came on time."],[1197,1301,"The baby looks healthy."],[1305,1493,"This is such wonderful news, Henry!"],[1509,1643,"Congratulations to you both."],[1651,1814,"Again sir, congratulations."],[1839,1918,"Please take care of her."],[1918,1981,"Thank you!"],[2131,2252,"No wonder I felt heavier."],[2314,2460,"Walking has been a struggle lately."],[2552,2669,"Can you carry me, Henry?"],[2727,2790,"Chloe."],[2852,2936,"Just a little."],[3065,3169,"Please."],[3937,4004,"Happy now?"],[6139,6185,"Mrs. Lloyd."],[6185,6252,"Doctor."],[6277,6335,"Are you alright?"],[6531,6573,"I..."],[6581,6719,"I'm taking the surgery."],[6798,6986,"Are you ready to leave all your..."],[6986,7148,"All of my memories."],[7286,7407,"In fourteen days,"],[7565,7653,"I'll start over."],[7912,7966,"Alright."]],"6":[[308,400,"Are you mad at me?"],[487,617,"Is it because I'm pregnant?"],[717,775,"Chloe, I..."],[775,934,"I came because I care about you."],[967,1096,"You're like a sister to me."],[1217,1547,"But why are you telling people I'm the father?"],[1680,1860,"I was caught up in the moment and I..."],[2006,2097,"I didn't mean that."],[2231,2323,"We're not together."],[2344,2427,"We've never been."],[2469,2540,"And I'm married."],[2610,2723,"You knew that as well."],[2777,2915,"Henry, please."],[3040,3182,"The baby's father left me."],[3249,3415,"I didn't want to come alone for the check-up."],[3453,3505,"I'm scared"],[3505,3653,"people would look at me differently."],[3687,3791,"I'll be there for you."],[3807,4004,"I made a promise to your family."],[4049,4095,"If your wife"],[4095,4220,"misunderstood anything,"],[4258,4375,"I'll apologize."],[4387,4496,"She must be jealous."],[4508,4621,"Olivia's harmless."],[4621,4800,"She's very understanding."],[4988,5176,"Even the kindest woman can turn cruel"],[5176,5380,"when it comes to protecting her marriage."],[5522,5630,"I wasn't gonna tell you,"],[5797,5914,"but the day of the accident,"],[6018,6110,"she was there."],[6156,6210,"What?"]],"7":[[4,262,"Olivia was there the day of the accident?"],[266,358,"She met with me,"],[367,546,"and told me to stay away from you."],[592,775,"She said you were only helping me"],[775,850,"out of pity."],[884,963,"She said that?"],[1130,1209,"I'm sorry."],[1288,1393,"I shouldn't have brought it up."],[1426,1555,"I can't ruin your marriage!"],[1639,1705,"Chloe,"],[1747,1847,"tell me what happened."],[2064,2143,"Olivia..."],[2243,2304,"She's the one"],[2304,2427,"who pushed me into the street."],[2506,2565,"What?"],[2686,2806,"Right before the accident,"],[2873,2986,"she came at me and..."],[3082,3169,"she pushed me!"],[3324,3370,"That..."],[3470,3582,"That doesn't sound like her."],[3582,3645,"Just..."],[3666,3812,"I knew you wouldn't believe me."],[3945,4066,"I'm so sorry, Henry."],[4074,4212,"I... I shouldn't have said anything!"],[4354,4462,"It's my fault."],[4590,4658,"Chole, it's not that."],[4658,4829,"I... I believe you, okay?"],[4938,5000,"Henry,"],[5034,5113,"please,"],[5142,5205,"let it go."],[5205,5355,"I... I care about you."],[5392,5543,"I don't want to cause problems."],[5885,5976,"Will you hold me?"]],"8":[[300,433,"Have you spoken to your family?"],[517,592,"Please,"],[621,734,"keep this confidential."],[763,913,"I don't want anyone to know."],[1121,1222,"What are you keeping from me?"],[1438,1547,"What were you hiding just now?"],[1572,1622,"Sir,"],[1643,1718,"are you..."],[1718,1805,"Mrs. Lloyd's family?"],[1872,1914,"Yeah."],[1922,1985,"Her condition is..."],[1985,2085,"It's fine."],[2173,2230,"Please, doctor."],[2230,2327,"Give us a moment."],[2506,2590,"You were at the accident"],[2590,2681,"that day, weren't you?"],[2731,2886,"No, I wasn't."],[2936,3048,"You didn't even ask"],[3073,3236,"what accident I was talking about."],[3303,3453,"Why did you jump straight to denial?"],[3591,3712,"I didn't know what you meant."],[3741,3916,"Chloe was in a car accident."],[3958,4133,"Okay, she could have been seriously injured."],[4141,4258,"I came here to check on her."],[4308,4396,"Of course you did."],[4421,4529,"Did you meet with Chloe"],[4542,4650,"before the car accident?"],[4710,4804,"I..."],[4896,5009,"You think I had something"],[5009,5113,"to do with it?"],[5192,5259,"Henry,"],[5309,5417,"I'm your wife!"],[5434,5501,"Olivia,"],[5559,5693,"I'll ask you one more time."],[5776,5947,"Were you at the scene that day?"]],"9":[[625,688,"Chloe?"],[738,859,"Are you here to meet Henry?"],[867,1042,"No, I came to see you."],[1113,1159,"Me?"],[1205,1288,"Tell me something."],[1338,1484,"If both of us were in danger,"],[1534,1584,"who do you think"],[1584,1743,"Henry would run to first?"],[1793,1906,"What are you talking about?"],[1931,2031,"And more importantly,"],[2093,2206,"who would he believe?"],[2352,2481,"What are you trying to say?"],[4612,4679,"Henry!"],[4700,4767,"I..."],[4767,4871,"Something happened!"],[4884,4942,"Please,"],[4959,5046,"help me!"]],"10":[[20,129,"Did you see Chloe"],[137,275,"before the car accident?"],[291,400,"Does it even matter?"],[400,500,"Just answer me!"],[542,654,"What's the point?"],[709,867,"You already made up your mind."],[900,1101,"Chloe could have been badly hurt."],[1109,1213,"Do you even realize that?"],[1217,1280,"Hurt?"],[1355,1463,"What about me?"],[1530,1618,"I'm in the hospital, too."],[1618,1743,"Do you even care?"],[1793,1897,"What are you talking about?"],[1939,2006,"You were injured?"],[2006,2085,"Let go!"]],"11":[[25,112,"It's nothing."],[112,237,"I just grabbed the wrong file."],[283,402,"It said high risk."],[402,513,"Whose file is that?"],[513,615,"It's none of your business."],[625,821,"We're married, Olivia. Answer me!"],[821,888,"Oh, yes?"],[942,1051,"I see our marriage didn't"],[1051,1209,"stop you from snoozing up with Chloe."],[1322,1434,"Chloe was hurt."],[1434,1559,"That has nothing to do with..."],[1826,2043,"Olivia, what's wrong with you?"],[2122,2177,"What's wrong?"],[2218,2372,"A husband I haven't seen in days"],[2372,2557,"shows up at a hospital for another woman,"],[2573,2719,"and you think that's normal?"],[2911,3169,"I have nothing to say to you."],[3257,3420,"Answer my question."],[3449,3545,"Let go!"],[3574,3678,"Why should I?"],[3703,3791,"Because I'm your husband!"],[3816,3903,"Oh yes?"],[3983,4029,"Fine."],[4066,4162,"Let's get divorced!"],[4229,4320,"What did you just say?"]],"12":[[45,254,"I said, I want a divorce."],[304,404,"Olivia, what's gotten into you?"],[404,623,"We just celebrated our third anniversary!"],[642,809,"The night you stumbled home drunk"],[809,891,"with another woman?"],[921,996,"You've got it wrong."],[1126,1267,"That was a company party."],[1267,1343,"Chloe and I didn't-"],[1343,1522,"Oh! You always have an excuse."],[1655,1730,"Oh my god,"],[1730,1850,"I thought you were more reasonable."],[1989,2110,"Maybe Chloe was right."],[2152,2313,"If you really did hurt her out of jealousy-"],[2313,2415,"I hurt her?"],[2690,2973,"Can you even hear yourself?"],[2990,3101,"Chloe's kind."],[3111,3232,"Even if you did hurt her,"],[3232,3420,"all she wants is an apology."],[4129,4208,"I've had enough."],[4380,4495,"Olivia, wait!"],[4550,4704,"What really happened at that accident?"]],"13":[[767,863,"What are you doing?"],[888,1026,"I thought you were heading home."],[1096,1247,"Is he here to pick me up?"],[1263,1497,"Maybe, he still cares."],[1514,1618,"If you need me to..."],[1680,1718,"I can..."],[1755,1822,"Henry!"],[2060,2198,"Oh! Olivia!"],[2248,2398,"What are you doing at the hospital?"],[2448,2523,"What do you think?"],[2577,2769,"Oh no! Did Henry tell you?"],[2827,2965,"I'm so sorry, Olivia!"],[2982,3129,"I know it's just a misunderstanding,"],[3186,3386,"I won't hold it against you. Please?"],[3449,3687,"I really want us to get along!"],[3741,3832,"Please, can we be friends?"],[3862,4052,"Oh, don't touch me, Chloe!"],[4145,4220,"Olivia!"],[4233,4354,"That's enough, Olivia!"],[4379,4559,"Chloe, get in the car!"]],"14":[[0,162,"So you're here to pick her up?"],[200,229,"What else?"],[362,509,"You just said we were getting divorced,"],[509,558,"remember?"],[633,738,"You're getting divorced?"],[829,1038,"Olivia, this must be a misunderstanding."],[1076,1142,"Please don't leave Henry."],[1184,1284,"I'm begging you!"],[1343,1455,"Can you drop the act?"],[1551,1593,"Just..."],[1668,1841,"looking at you two makes me sick!"],[1872,1926,"Olivia!"],[1968,2072,"How can you be so cruel?"],[2198,2323,"Chloe's pregnant right now."],[2323,2446,"She needs extra care!"],[2602,2772,"Henry, don't blame Olivia."],[2815,2886,"It's all my fault."],[2969,3044,"I've heard enough."],[3157,3365,"Olivia, I'm really disappointed in you."],[3482,3611,"Don't be so hard on her, Henry."],[3724,3827,"Let's just take her home."],[3895,3933,"No."],[3974,4095,"I don't want her anywhere near you!"],[4229,4308,"Henry?"],[4617,4768,"When you've come to your senses,"],[4813,4946,"then you can apologize to Chloe."],[6010,6260,"Thirteen days from now, I will leave him"],[6306,6531,"and this life for good."]],"15":[[437,596,"My mother's necklace, where is it?"],[696,734,"Amy?"],[825,877,"Amy!"],[955,992,"Yes, Miss?"],[1005,1118,"Have you seen my necklace?"],[1134,1220,"The crystal pendant."],[1251,1393,"No, it's the only gift she left you,"],[1393,1493,"I would never touch it."],[1543,1646,"Has anyone been in the room?"],[1822,1889,"Last week,"],[1889,2094,"Mr. Lloyd brought Miss Chloe here."],[2164,2218,"Oh."],[2439,2489,"Thank you."],[3749,3828,"What is it now?"],[3849,4116,"Henry, did you bring Chloe home last week?"],[4141,4272,"Is this about Chloe again?"],[4295,4488,"You've been searching for excuses."],[4508,4667,"No, no, no, I'm calling because"],[4667,4771,"my necklace is..."],[4783,5004,"Henry, is everything okay?"]],"16":[[25,104,"Where are you?"],[150,229,"Harrington Hotel."],[287,479,"We're hosting a company dinner tonight."],[542,587,"Okay."],[1226,1309,"Sorry, Miss."],[1322,1372,"Guests only."],[1401,1476,"I am a guest."],[1480,1606,"I'm Henry Lloyd's wife."],[1814,1931,"You are Mrs. Lloyd?"],[2077,2143,"Mrs. Lloyd?"],[2206,2248,"Please."],[2268,2410,"You look like you crawled out of a shelter!"],[2515,2628,"Here to serve drinks?"],[2660,2784,"Wrong entrance, sweetheart."],[3361,3602,"I am Olivia Lloyd, the CEO's wife."],[3620,3720,"In your dreams, hobo."],[3778,3962,"It makes me sick just looking at her."],[4029,4143,"I'm telling the truth."],[4183,4237,"Let me in."],[4262,4334,"Step away."],[4354,4429,"I warned you."],[4429,4550,"It's invitation only."],[4696,4851,"I'm here to talk to my husband."],[4875,4947,"Please."],[4979,5053,"Let me in."],[5096,5208,"Shut up, liar."],[5230,5427,"If you're Mrs. Lloyd, then who is that?"],[5459,5664,"Everyone knows Chloe's the real fiancée."],[5672,5709,"Look at her."],[7152,7224,"My necklace!"]],"17":[[0,85,"My necklace!"],[237,342,"This one's desperate, trying to"],[342,466,"stir up drama for attention."],[554,625,"Don't touch me!"],[688,772,"Or what?"],[829,968,"Pathetic bitch and liar."],[1017,1130,"Please let me go."],[1155,1296,"Bitch really thought she could come in here"],[1296,1420,"and seduce him?"],[1543,1655,"Pathetic beggar."],[1701,1776,"Let me go."],[1839,1951,"If you can't even dress"],[1951,2077,"properly for the occasion,"],[2106,2168,"let me help."],[2861,3079,"The charity case just got a makeover."],[3111,3269,"At least she finally has some color on her."],[3721,3793,"Olivia?"]],"18":[[108,171,"Olivia!"],[400,453,"What happened?"],[521,598,"Why are you here?"],[625,772,"She's really the CEO's wife?"],[809,955,"Shit, what did we just do?"],[984,1155,"Oh my god, Olivia!"],[1226,1447,"What happened? Are you alright?"],[1501,1582,"Save the act!"],[1639,1814,"Mr. Lloyd, I'm so sorry."],[1814,1922,"I did not know she was your wife."],[1922,2014,"Not for much longer."],[2014,2131,"We're getting divorced."],[2227,2273,"Olivia!"],[2360,2452,"Please, Olivia."],[2452,2615,"This is just a misunderstanding."],[2631,2804,"Maybe change into something decent first,"],[2804,2882,"then we can talk?"],[2998,3268,"No need. I came to take back what is mine."],[3457,3603,"Olivia! What are you doing?"],[3641,3755,"This is my necklace."],[3807,3891,"No, this?"],[3937,4084,"This was a gift from Henry."]],"19":[[2068,2256,"That bitch had some good taste, huh?"],[2510,2623,"Sorry!"],[2744,2882,"I didn't mean to come in here."],[3232,3334,"What's wrong?"],[3375,3458,"Why are you crying?"],[3578,3887,"Nothing. It's just... Olivia's so lucky."],[3974,4109,"She has a husband who spoils her"],[4109,4313,"with such beautiful things."],[4446,4650,"I won't dream of that kind of happiness."],[4817,5017,"Chloe, you're family to me."],[5017,5150,"You're like a sister."],[5263,5483,"Whatever you want, it's yours."],[5518,5734,"I only want to try on Olivia's necklace."],[5789,6018,"Just for the banquet, I'll return it after."],[6227,6385,"If it's too much, forget it!"],[6385,6514,"I shouldn't have asked."],[6569,6669,"Don't say that."],[6961,7094,"You deserve happiness too."],[7219,7311,"Which one did you want?"],[9234,9438,"Did you give my necklace to her?"],[9492,9776,"It's just a necklace, Olivia."],[9818,9984,"So what if she borrows it for the day?"],[10130,10350,"Like how she's borrowing my husband right now?"]],"20":[[0,191,"Like how she's borrowing my husband right now?"],[208,271,"Olivia!"],[337,456,"I'm so sorry!"],[471,613,"If I knew Olivia would get this upset,"],[613,742,"I never would have asked."],[788,968,"If this causes problems in your marriage,"],[1021,1150,"I don't want it anymore."],[1180,1391,"I'd never touch what belongs to someone else."],[1405,1514,"No wonder they're divorcing."],[1572,1693,"Henry married the wrong woman."],[1780,1935,"Olivia's so dramatic."],[1997,2089,"She's so tense."],[2152,2223,"Please, Olivia,"],[2293,2373,"don't blame Henry."],[2427,2556,"It's all my fault."],[2648,2857,"No, Chloe. Stop. It's nothing."],[2915,3030,"Everything you have"],[3030,3181,"was bought with my money."],[3215,3324,"It's not even yours."],[3382,3654,"If I lend something out, why should it matter?"],[3712,3773,"It's mine."],[3820,3970,"You two make me sick."],[4074,4221,"Take your filthy things back!"],[4300,4354,"Olivia!"],[4383,4508,"Give me my necklace."],[4562,4625,"Henry!"]],"21":[[275,489,"-I... -Henry, no!"],[583,696,"Chloe's pregnant."],[696,992,"She can't handle stress right now."],[1088,1218,"That necklace,"],[1235,1397,"it's my mother's heirloom."],[1469,1667,"It's the only thing she left me."],[1743,1876,"You didn't buy it!"],[1876,2106,"It was never yours to give!"],[2377,2633,"Oh god, I'm really sorry."],[2633,2766,"I didn't know."],[2795,2957,"I swear, Olivia, I didn't."],[3123,3204,"Olivia, I-"],[3207,3278,"No."],[3307,3363,"I..."],[3370,3491,"Not another word."],[3502,3695,"We're done, Henry Lloyd!"],[4825,4884,"Chloe!"],[4950,5063,"My stomach!"]],"22":[[417,538,"No, no, no, no, no!"],[583,734,"-Chloe, are you okay? -My necklace!"],[896,959,"Mom!"],[1000,1197,"Mom, no, no, no!"],[1292,1405,"Chloe, are you okay?"],[1443,1694,"Henry, I think the baby might be hurt."],[1701,1806,"Somebody call the doctor!"],[1830,1981,"Check on Olivia. Please!"],[2022,2122,"She might have been hurt too."],[2218,2260,"Olivia."],[2398,2569,"Olivia, are you hurt?"]],"23":[[16,183,"Olivia, are you hurt?"],[279,421,"My necklace!"],[613,804,"You're worried about that necklace?"],[863,1096,"Did you not just see Chloe fall?"],[1113,1226,"She's pregnant!"],[1226,1384,"She could have been seriously injured"],[1384,1568,"and she's still worried about you"],[1568,1697,"while you're over here"],[1697,1935,"scrambling for your damn trinket."],[1976,2089,"It was my mother's!"],[2198,2373,"Why did you ruin it?"],[2414,2569,"What did I ever do to you?"],[2594,2702,"Why are you blaming her"],[2702,2827,"for your mistake?"],[2840,2969,"Someone pushed me!"],[3030,3151,"She planned it!"],[3170,3307,"She destroyed my necklace!"],[3499,3657,"I can't believe I never saw it."],[3682,3897,"We were married three years."],[3933,4266,"You are so bitter and so cruel!"],[4362,4576,"Henry, it's okay."],[4608,4763,"Please don't get mad at her."],[4783,4950,"I must have stood too close."],[4967,5071,"It was my fault."],[5201,5472,"Olivia, I'm so sorry."],[5505,5734,"Please forgive him."],[5830,5989,"Don't apologize, Chloe."],[6101,6262,"She doesn't deserve your kindness."],[6398,6644,"It was the last thing I had left of her."],[6664,6881,"You promised her on her dying bed."],[6931,7131,"You promised you'd take care of me!"]],"24":[[296,512,"Henry, I think something's wrong."],[583,759,"I... I can't walk."],[842,1051,"Please, hold me."],[1126,1159,"Yeah."],[1242,1284,"Let's go."],[1326,1385,"No!"],[1505,1769,"You're not leaving until you both apologize!"],[1772,1885,"Are you serious?"],[1976,2152,"Chloe is unwell."],[2181,2431,"She doesn't have time to argue with you."],[2489,2660,"So you care about her feelings?"],[2752,2865,"About her pain?"],[3048,3287,"Was there ever a second or even a flicker"],[3287,3456,"you saw me as your wife?"],[3853,3974,"What's gotten into you?"],[4033,4421,"Henry, I think there's blood on her hands."],[4462,4713,"It's making me dizzy."],[4713,4849,"I have a condition, remember?"],[4892,5042,"I can't handle the sight of blood."],[5109,5299,"Please, let's go."],[5299,5517,"No! No one's leaving!"]],"25":[[12,128,"Stay and apologize!"],[145,225,"You've gone crazy!"],[458,500,"Henry!"],[621,706,"She'll be fine."],[2736,2799,"Henry?"]],"26":[[87,131,"Henry?"],[162,392,"Sorry, I didn't mean to startle you."],[550,621,"Looks like you needed it"],[621,701,"more than I did."],[842,888,"Thank you."],[980,1009,"May I?"],[1142,1326,"Yeah, just... please be careful."],[1368,1530,"It's all I have left from my mother."],[1764,1847,"I'm sorry to hear that."],[2118,2210,"I know a jeweler."],[2243,2389,"He's worked miracles before."],[2519,2669,"If there's anything to save,"],[2706,2773,"he'll find a way."],[2857,3010,"Wait, the necklace can be restored?"],[3053,3137,"There's a chance."],[3269,3340,"Thank you."],[3741,3920,"If I wasn't soaked in cheap wine and"],[3920,4079,"heartbreak, I would give you a hug."],[4700,4846,"Your clothes may be dirty,"],[4879,4975,"but your heart is clean."],[5121,5226,"It's the part I see."],[5680,5780,"Thank you"],[5860,5930,"for seeing me."]],"27":[[0,145,"You rushed back to check on her"],[145,253,"and this is what she did?"],[312,450,"Is this why she's divorcing you?"],[496,696,"Was she cheating on you this whole time?"],[1213,1284,"Let's go."],[1943,1981,"Good news."],[2056,2234,"Your necklace will be ready next week."],[2289,2366,"Fully restored."],[2402,2600,"Oh, that's amazing. Thank you."],[2648,2756,"I'll pay for it, of course."],[2998,3128,"Olivia, I have something to confess."],[3365,3639,"I didn't exactly meet you by accident."],[3724,3801,"What do you mean?"],[3849,3991,"I'm head of the Barone Medical,"],[3991,4183,"the company behind your upcoming surgery."],[4433,4596,"When I saw your name in the system,"],[4671,4808,"I recognized you."]],"28":[[145,275,"At first I was just curious."],[304,446,"You signed the consent form without"],[458,533,"hesitation."],[596,675,"Kept wondering why you"],[675,742,"chose to forget."],[771,1021,"After the banquet, I understood."],[1092,1209,"I just want to start over."],[1655,1843,"There's a small chance,"],[1843,1981,"just a theory I've been working on,"],[2056,2230,"that some of your memories"],[2230,2320,"could be preserved."],[2519,2744,"Wait, you mean I get to keep my memories?"],[2827,3094,"Yeah, and I don't know,"],[3094,3194,"maybe afterwards"],[3194,3321,"I could help you with your recovery."],[3390,3428,"And..."],[3603,3823,"What if I don't want to remember?"],[3949,4047,"Because you want to start over?"],[4295,4480,"Olivia, starting over"],[4480,4634,"doesn't depend on you forgetting."],[4767,4897,"It's always been your choice."],[5605,5842,"Henry, are you free for lunch?"]],"29":[[663,717,"See you tomorrow."],[867,917,"Olivia!"],[1276,1382,"What the hell was that?"],[1418,1534,"What are you doing here?"],[1576,1797,"Well, forget it, it has nothing to do with you."],[1830,1964,"Nothing to do with me?"],[1985,2110,"Another man kisses you,"],[2127,2281,"and you tell me it's none of my business?"],[2281,2419,"Mr. Lloyd, please, we were just leaving."],[2435,2573,"I wasn't talking to you!"],[2744,2822,"Stop."],[2857,2961,"You're making a scene."],[2969,3073,"Then explain to me,"],[3094,3199,"what I just saw!"],[3286,3403,"We're done here!"],[3687,3774,"You're not leaving"],[3782,3958,"until you tell me what that was!"],[4087,4216,"Let go! You're hurting me!"],[4287,4337,"Henry!"],[4446,4517,"Let her go."],[4604,4825,"I said, I'm not talking to you."]],"30":[[50,196,"What the hell is wrong with you?"],[254,321,"Are you insane?"],[496,546,"Are you okay?"],[925,1055,"You're coming with me."],[1493,1639,"Let me go. Now!"],[1689,1789,"Not until you tell me"],[1789,1893,"what the hell that was."],[1922,1993,"You're insane!"],[2047,2127,"Answer me!"],[2127,2243,"What were you doing with him?"],[2339,2416,"We're getting divorced."],[2498,2702,"What I do is no longer your concern."],[2877,2965,"So you're leaving me?"],[3182,3253,"For him?"],[3269,3399,"Okay, that's... That's it."],[3486,3582,"You're cheating on me."],[3661,3866,"Oh, you calling me a cheater?"],[3970,4094,"You are the last person who should"],[4094,4200,"be throwing this word around."],[4245,4350,"What the hell does that mean?"]],"31":[[95,193,"I'm talking about Chloe."],[287,446,"What about her? She's harmless."],[462,608,"Oh yes, so harmless."],[638,779,"Just waltzing into my married life"],[779,900,"and sitting in my husband's bed"],[900,992,"like she owns it."],[1176,1372,"This is exactly what I mean."],[1372,1501,"You twist everything."],[1514,1651,"You've hated Chloe from day one"],[1651,1803,"because you can't stand anybody"],[1803,1889,"getting close to me."],[1922,2198,"Oh. You think I want to compete with her?"],[2277,2420,"Why the hell else"],[2420,2544,"would you keep coming after her?"],[2594,2727,"Because she lies!"],[2765,2869,"She manipulates and you're too"],[2869,2982,"blind to see it."],[2982,3169,"You've completely lost it."],[3169,3299,"This isn't even about her."],[3299,3482,"You're just jealous, bitter"],[3490,3596,"and unreasonable."],[3599,3653,"Right."],[3699,3812,"Because watching another woman"],[3812,3912,"cling to my husband"],[3912,4033,"and parade around in my life"],[4033,4138,"is totally reasonable."],[4138,4270,"I've been supporting her"],[4270,4358,"because she's been going"],[4358,4467,"through something emotional."],[4487,4688,"Oh. Okay. Then go back to her"],[4713,4804,"and hold her hand while"],[4804,4921,"she gives birth to your child."],[5216,5343,"You think that's my baby?"]],"32":[[37,137,"I don't even care anymore."],[187,350,"Yours or not makes no difference."],[458,558,"We are done."],[704,792,"What's that supposed to mean?"],[792,988,"We're getting divorced. Did you forget?"],[1130,1226,"I'm not signing anything."],[1288,1384,"Then I'll see you in court."],[1430,1522,"Don't push me, Olivia."],[1626,1705,"Or what will you do?"],[1822,2043,"Just wait until I forget how messed up this is?"],[2043,2171,"You don't think I know what you're doing?"],[2214,2373,"What the hell are you talking about?"],[2373,2652,"No. No, not until you admit it."],[2681,2762,"Admit what?"],[2861,3053,"That you're still in love with me."],[3107,3428,"If I ever was, you killed it."],[3595,3674,"Let me go."],[3799,3949,"You don't get to walk away that easily."],[4004,4054,"Stop!"],[4913,5106,"We're not over until I say it's over."]],"33":[[604,696,"Why are you crying?"],[967,1247,"I'd rather die than stay with you."],[1455,1564,"Olivia, this isn't you."],[2147,2189,"Henry?"],[2202,2231,"Shit."],[2248,2352,"I've been waiting at the restaurant"],[2352,2431,"for so long."],[2489,2596,"Are you still coming?"],[2640,2836,"Yeah, I'll be right there. Hold on."],[2915,3096,"I married a monster."],[3182,3318,"If Chloe hadn't called,"],[3318,3409,"he really would have..."],[3516,3644,"...forced himself on me."],[4209,4294,"Drive yourself home."],[4294,4416,"I've got something I have to deal with."],[4462,4621,"Just seven more days,"],[4671,4758,"and I'll be free"],[4808,4917,"from this prison"],[4988,5096,"called marriage."]],"34":[[154,204,"Henry,"],[275,375,"good to see you."],[429,538,"Pleasure's all mine, Mr. Hastings."],[688,788,"And you must be Mrs. Lloyd."],[896,963,"This is my..."],[963,1059,"Lovely to meet you."],[1305,1388,"He's a family man."],[1409,1501,"Just play along."],[1664,1780,"We're here to finalize the deal."],[1826,1881,"Well, about that."],[1951,2018,"I liked your proposal."],[2068,2147,"I really did."],[2185,2282,"But the board chose another."],[2385,2441,"Another?"],[2527,2715,"Better funding, cutting-edge tech,"],[2748,2840,"stronger political ties."],[2890,2996,"Who could have pulled that off?"],[3098,3146,"Ah!"],[3211,3267,"Speak of the devil."],[3403,3494,"What a surprise!"]],"35":[[29,150,"See? We meet again, Mr. Lloyd."],[196,255,"Right."],[350,550,"The man who loves"],[550,711,"to take what isn't his."],[880,1012,"You planned this, didn't you?"],[1105,1166,"Planned what?"],[1180,1256,"Don't play dumb."],[1347,1524,"You knew we were betting on this,"],[1524,1768,"so you came in and sabotaged the deal."],[1768,1906,"Okay, I didn't sabotage you."],[1906,2052,"Your pitch just wasn't good enough."],[2052,2117,"Bullshit!"],[2310,2579,"Or maybe you just can't handle losing."],[2760,2808,"Henry!"],[2936,3047,"Have you lost your mind?"],[3111,3402,"It's Aaron Barone, the CEO of the"],[3402,3586,"biggest corporation on the planet."],[3945,4042,"Always a pleasure, Henry."],[4325,4421,"Enjoy your epic fail."],[4500,4585,"Mr. Barone!"],[4854,4957,"I heard rumors."],[4979,5075,"There's been a leak."],[5121,5279,"What if Olivia let something slip?"],[5305,5446,"This ends now."],[6035,6178,"Follow Aaron Barone."],[6252,6335,"Film everything,"],[6393,6624,"especially if he meets Olivia."]],"36":[[166,212,"Olivia,"],[425,483,"you're leaving?"],[909,1039,"When did you get that fixed?"],[1209,1518,"Olivia, why aren't you answering me?"],[1655,1808,"And I don't owe you an answer."],[1939,2087,"Why are you shutting me out?"],[2156,2414,"And if I don't answer, what?"],[2481,2628,"You're gonna force yourself on me again?"],[2635,2674,"What?"],[2811,2961,"That's not what happened."],[3002,3174,"Just stay away from me."],[3174,3411,"You have no idea what I'm dealing with."],[3586,3720,"Work's a nightmare,"],[3720,3841,"everything's falling apart!"],[3958,4095,"Not my problem."],[4295,4416,"The divorce papers are there."],[4462,4537,"I've signed them."],[5176,5276,"About the divorce?"],[5292,5385,"You're serious."],[5522,5613,"Just sign it."],[5672,5818,"Save some time for both of us."],[5876,6022,"This is about Aaron, isn't it?"],[6039,6109,"What?"],[6118,6294,"I saw the way that you look at him."],[6418,6589,"You're being ridiculous."]],"37":[[50,216,"So that's what this is."],[479,608,"You're not going anywhere."],[675,791,"What the hell are you doing?"],[871,935,"Let me go."],[967,1067,"Answer me first."],[1180,1247,"You and Aaron,"],[1338,1473,"how long has it been going on?"],[1505,1553,"What?"],[1564,1680,"Have you been sleeping with him?!"],[1797,1943,"Have you been giving him company intel?!"],[1964,2147,"Oh, you've lost your mind."],[2202,2293,"Let me go!"],[2435,2698,"You think I don't see it?"],[2827,3190,"The looks, the timing? Don't lie to me!"],[3307,3482,"You don't own me."],[3770,3862,"Let me go now."],[4020,4275,"We were married three years."],[4325,4444,"Don't pretend like"],[4444,4550,"that meant nothing to you."],[4550,4742,"Oh, you're disgusting!"],[4742,4938,"You still love me! Admit it!"],[5004,5138,"Oh, I hate you!"],[5138,5194,"You're lying!"],[5194,5257,"You love me!"],[5388,5467,"No! Stop!"],[5467,5545,"Please!"],[5601,5670,"Let go!"],[5710,5768,"No!"],[6135,6385,"Oh, my head hurts."]],"38":[[12,243,"Oh, my head hurts."],[325,457,"Stop playing games."],[721,775,"Don't..."],[921,988,"Don't."],[1040,1089,"Olivia."],[1222,1290,"Olivia!"],[1947,2178,"Sir, are you with Olivia Lloyd?"],[2227,2477,"Yes, I'm her husband. How is she?"],[2552,2677,"Well, considering her condition,"],[2677,2744,"she's well."],[2761,2894,"Her condition?"],[3015,3244,"What do you mean? What's wrong with her?"],[3274,3354,"You mean you don't know?"],[3395,3461,"Know what?"],[3499,3605,"You didn't know she was sick?"]],"39":[[75,196,"What do you mean she's sick?"],[229,316,"What's wrong with her?"],[567,784,"Please, keep this confidential."],[804,946,"I don't want anyone to know."],[1000,1117,"It's nothing serious."],[1159,1328,"Likely a result of exhaustion."],[1438,1531,"She just needs rest."],[1601,1726,"What, that leads to fainting?"],[1776,1892,"You should take better care of her."],[1976,2052,"She's been through a lot."],[3570,3778,"All I ever wanted"],[3870,4041,"was something this simple-"],[4216,4425,"someone who stayed."],[4558,4650,"But now,"],[4754,4850,"it's too late."]],"40":[[187,312,"Tomorrow's the big day."],[358,462,"Are you ready?"],[462,725,"Yes, I'm actually looking forward to it."],[1167,1405,"Doctor, my necklace! Where is it?"],[1426,1537,"We handed all your belongings"],[1537,1601,"to your husband."],[1659,1830,"Don't worry, he said he'd keep them safe."],[2456,2498,"You're home."],[2640,2720,"Where's my necklace?"],[2748,2823,"I'll give it to you."],[2936,3148,"Just spend the night with me, huh?"],[3244,3541,"Oh, Henry, I don't have time for this."],[3966,4064,"It's my birthday, Olivia."],[4158,4303,"That's right, his birthday."],[4341,4592,"I've never forgotten it, except today."],[4671,4838,"One evening. Just tonight."],[4925,5027,"And then I'll sign the papers."],[5138,5355,"Whatever you want. I'll agree too."],[5476,5554,"Eight o'clock?"],[5584,5744,"I'm leaving tomorrow anyways."],[5834,5895,"Check the bag."],[5955,6208,"Maybe just give him one last night."],[7545,7640,"You must be Mrs. Lloyd."],[7682,7746,"Yes?"],[7774,7911,"Your husband booked the entire place."],[7937,8054,"He's been waiting a long time."]],"41":[[550,758,"I know I've said a lot of stupid things."],[813,881,"Done worse."],[959,1160,"If I hurt you, I'm sorry."],[1238,1471,"Well, you didn't mean to, but"],[1471,1597,"it doesn't mean it didn't hurt."],[1697,1938,"Still, I wanted to ask,"],[2085,2247,"would you reconsider the divorce?"],[2419,2481,"Henry,"],[2527,2692,"this marriage, it's just..."],[2692,2876,"worn us both down."],[2911,3061,"Staying in something without love,"],[3111,3225,"it's torture."],[3349,3420,"I see."],[3490,3720,"I owe you an apology."],[3820,3989,"Okay, for not listening sooner."],[4003,4220,"If there's anything I messed up,"],[4220,4300,"I wanna hear it."],[4366,4583,"Henry, the reason I..."],[4667,4813,"It's fine. Don't worry about it."],[4871,4966,"No, please."],[5088,5198,"Say what you're going to say."],[5230,5402,"I just... I..."],[5501,5621,"Maybe you should take it."],[5689,5915,"If it's something important..."],[5997,6049,"I'm sorry,"],[6049,6214,"it'll just be a sec, okay?"],[6577,6681,"Did you convince her?"],[6681,6752,"You know what will happen"],[6752,6895,"if the divorce goes public."],[6902,7015,"We must stop her."]],"42":[[100,321,"Olivia, it's not what it sounded like."],[333,471,"Just don't."],[504,563,"Please."],[704,767,"Listen to me."],[888,1084,"Was any of this real?"],[1184,1355,"Or was I just a pawn in your game?"],[1393,1522,"Of course it was real."],[1539,1717,"That call had nothing to do with us."],[1747,1898,"Everything makes sense now."],[1964,2093,"You were just buying time."],[2252,2317,"Olivia."],[2394,2485,"Olivia, wait!"],[2573,2686,"Olivia, stop!"],[2781,2883,"Where are you going?"],[3002,3128,"Come back, okay?"],[3128,3248,"You're not thinking clearly."],[3299,3451,"I've never thought more clearly"],[3451,3507,"in my life."],[3524,3698,"Every lie. Every move."],[3841,3977,"And I've made my choice."],[3977,4093,"What does that even mean?"],[4175,4245,"Olivia!"],[4817,4883,"Olivia!"],[4883,4986,"What do you think you're doing?"],[5042,5155,"Henry, wait, you can't."],[5226,5356,"Let me go. She's drowning!"],[5384,5447,"Think about me."],[5476,5557,"About the baby!"],[5689,5938,"If you get hurt, what will happen to us?"],[5938,6048,"Think about someone other"],[6048,6212,"than yourself for once, Chloe!"],[6227,6396,"It's always about her, isn't it?"],[6410,6516,"No matter what I do,"],[6516,6682,"you'll never stop chasing after her."],[6735,6856,"This isn't about you."],[6961,7134,"Then drown with her, Henry."],[7232,7296,"Olivia!"]],"43":[[296,525,"I've made three mistakes in my life."],[721,952,"One, loving the wrong man."],[1134,1477,"Two, giving him chance after chance."],[1597,1889,"And three, letting him hurt me,"],[2110,2255,"even at the very end."]],"44":[[329,425,"That's him again."],[533,605,"Still here?"],[633,798,"He's been crashing here for three weeks."],[846,1024,"Say's he's looking for his wife."],[1051,1209,"The poor man's losing it."],[1247,1369,"She's not even in the system."],[2410,2481,"Please..."],[2523,2711,"Just check, one more time."],[2790,3011,"Her name 's Olivia Lloyd. She was here."],[3107,3294,"Sir, we've told you already"],[3294,3420,"over and over again."],[3449,3586,"There's no file under her name."],[3586,3695,"She's not in the system."],[3716,3791,"She..."],[3853,3978,"She was here..."],[3978,4116,"Sir, if you keep disrupting"],[4116,4187,"the staff like that,"],[4187,4312,"we'll have to call security."],[4387,4650,"I... I just want my wife..."],[4846,4942,"Mr. Lloyd?"],[5113,5255,"There's something"],[5255,5384,"you should know about your wife."]],"45":[[16,87,"Brain cancer?"],[191,237,"Stage four?"],[346,437,"There's no treatment left."],[625,834,"She was terminal when she came in."],[867,950,"Where is she now?"],[1013,1059,"Where-"],[1092,1169,"Where's Olivia?"],[1209,1317,"She didn't want you to know."],[1418,1687,"She underwent surgery alone."],[1805,1826,"Surgery?"],[1981,2139,"Where is Olivia now?"],[2335,2419,"I'm sorry, Mr. Lloyd."],[2527,2594,"She passed away."],[2694,2822,"I received her death certificate"],[2822,2923,"two months ago."],[3891,3980,"I'm so sorry."],[4550,4602,"Please."],[4671,4783,"Please forgive me."],[4925,5004,"I'm so sorry."],[5201,5257,"He came."],[5342,5385,"Yes."],[5522,5661,"I told him Olivia's dead."]],"46":[[12,198,"In light of your prolonged"],[198,550,"absence and ongoing instability,"],[596,725,"the board has voted"],[725,1013,"unanimously to remove you from all executive"],[1013,1192,"and shareholder responsibilities."],[1217,1352,"Effective immediately."],[1926,2039,"You just sat there and let them"],[2039,2145,"take everything?"],[2189,2210,"Chloe?"],[2273,2427,"Think about the baby, Henry."],[2544,2607,"What baby?"],[2694,2848,"Inside me, or did you forget"],[2848,2968,"you have responsibilities?"],[3002,3144,"You can take whatever you want."],[3144,3315,"There's not much left."],[3407,3511,"You serious?"],[3570,3737,"I didn't ask for any of this."],[3778,3874,"Olivia's gone!"],[3891,3999,"She's gone, Henry."],[4020,4191,"I finally have you to myself."],[4441,4557,"What did you just say?"]],"47":[[0,244,"Nothing. I just meant she's gone."],[316,379,"-That's... -You'll finally see that."],[429,563,"That's not what you meant."],[684,750,"What do you know?"],[825,913,"I didn't mean it like that."],[963,1080,"I just want you to cheer up."],[1121,1190,"You misunderstood."],[1222,1272,"I need to go."],[1376,1605,"Please, Henry, pull yourself together."],[2206,2297,"I need security footage."],[2385,2543,"Front entrance, office building."],[2619,2686,"Three months ago."]],"48":[[12,122,"Going somewhere?"],[212,362,"Henry, you scared me."],[362,429,"What are you-"],[583,704,"You ruined everything."],[759,913,"You drove her away from me."],[955,1130,"Henry, what are you talking about?"],[1259,1355,"You think I don't know?"],[1401,1618,"You pretended. Manipulated."],[1676,1868,"No. It's not me."],[1875,2018,"She was already broken."],[2018,2137,"You broke her."],[2137,2355,"You pushed her away step by step."],[2394,2723,"How did I not see? You're sick!"],[2798,2882,"No, Henry."],[2882,3048,"You're the one who's pathetic."],[3048,3274,"You don't deserve love. You never did."],[3741,3964,"You're right. It's me."],[4020,4232,"I- I destroyed her."],[4729,4912,"Chloe Moore, you're under arrest"],[4912,5063,"for assault with intent to harm."],[5077,5236,"What? No!"],[5236,5326,"Where did he go?"],[5326,5434,"Henry!"]],"49":[[12,171,"This piece is by"],[171,291,"the most astonishing talent"],[291,454,"we've seen in recent years."],[517,742,"She lost all memory after a critical illness,"],[800,1026,"but it's a chance to start over."],[1063,1247,"You can see the chaos,"],[1330,1522,"the mind rebuilding itself."],[2669,2756,"Nice work."],[2815,2961,"Your exhibit is a hit,"],[2961,3064,"just like expected."],[3111,3340,"Thanks to you, my first patron."],[3549,3752,"Any new memories?"],[3795,4020,"Bits, fragments."],[4124,4362,"Some of them were unhappy."],[4625,4688,"Would you ever want to"],[4688,4807,"see somebody from your past?"],[4990,5085,"No need."],[5179,5307,"What's past is past."]],"50":[[204,250,"Olivia?"],[417,468,"Olivia!"],[542,644,"Sorry, do I know you?"],[644,753,"Is it really you?"],[1080,1167,"I must be dreaming."],[1213,1286,"What was that?"],[1405,1462,"Oh, sorry."],[1472,1572,"You need some change."],[1584,1626,"Wait."],[1805,1856,"Here you go."],[2206,2323,"It's getting cold,"],[2356,2473,"get yourself something warm."],[2623,2698,"I'm sorry, ma'am."],[2831,2965,"I must have mistaken you"],[2965,3057,"for somebody else."],[3107,3128,"Yeah."],[3178,3382,"Yeah, I think so too."],[3832,4058,"Goodbye, Henry Lloyd."]]}