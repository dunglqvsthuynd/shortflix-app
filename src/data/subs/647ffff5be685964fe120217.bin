autiful."],[4258,4458,"You look amazing."],[4458,4662,"All right, let's do this!"],[4771,4842,"You can't do this by"],[4842,4988,"yourself, silly."],[4988,5084,"Where is the man?"],[5176,5267,"I can't believe he's not here."],[5267,5342,"He's the one who wanted"],[5342,5572,"me to do the ceremony."],[5855,5943,"I can't believe I didn't"],[5943,6022,"find you sooner,"],[6022,6118,"my Luna."],[6268,6343,"You might be my"],[6343,6539,"Luna, and an Alpha,"],[6539,6664,"but there's one title"],[6664,6752,"you're still missing."],[6865,6948,"My wife."],[7073,7173,"Selene Lovette,"],[7207,7328,"will you marry me?"],[7511,7595,"Yes!"],[7678,7803,"I'm so excited!"]],"60":[[834,1021,"I, Selene Lovette,"],[1021,1146,"accept my role as"],[1146,1267,"Nightwind's Pack Luna"],[1380,1501,"and your wife."],[1618,1910,"I, Alexander Kane,"],[1947,2114,"fucking love you."],[3115,3199,"Oh."],[3507,3749,"Wow, two Alphas together."],[3749,3974,"Better get to making those super babies."],[3974,4129,"Right now."],[4129,4212,"Dad!"],[5188,5284,"Wait!"],[5284,5367,"Wait."],[5647,5701,"Please don't tell me"],[5701,5801,"you need to shower."],[6368,6448,"You think this is"],[6448,6498,"funny?"],[6648,6727,"I'm glad that my"],[6727,6835,"suffering entertains"],[6835,6865,"you."],[7094,7244,"Wait, holy shit,"],[7244,7344,"do you think that"],[7344,7474,"Alexander Jr.?"],[7603,7761,"AJ?"],[7761,7882,"AJ Lovette-Kane?"]]}