w that."],[400,604,"What's going on?"],[604,696,"How can you say"],[696,779,"those things?"],[779,950,"Selene, are you okay?"],[1113,1209,"Maybe we should"],[1209,1251,"go home."],[1380,1468,"So I can finally be"],[1468,1580,"inside her."],[1726,1960,"Wait, no way."],[1960,2031,"Is she reading my"],[2031,2077,"mind?"],[2285,2414,"I think so."],[2414,2565,"I think I am."],[2565,2673,"What's going on?"],[2673,2752,"Honey."],[2898,3061,"I think Selene's a gifted Alpha."],[3153,3228,"I think she can"],[3228,3290,"read minds."]],"54":[[946,1063,"Ready?"],[1063,1234,"Ready."],[1914,2064,"Welcome home!"],[2243,2327,"Our Luna!"],[2527,2594,"We're so glad you're"],[2594,2681,"back!"],[2681,2765,"Welcome home, my Luna."],[2765,2890,"Ooh, okay, everybody"],[2890,2994,"calm down."],[2994,3157,"Selene is not"],[3157,3282,"Luna yet."],[3282,3453,"She hasn't even had her ceremony."],[3453,3591,"Caitlin, get out."],[3591,3766,"I don't want you here."],[3766,3883,"Alpha, that's not what you said"],[3883,4066,"the night we slept together."],[4066,4195,"If you mention that lie again"],[4195,4316,"I'm not lying!"],[4496,4575,"You blacked out."],[4575,4758,"You don't remember it."],[4758,4842,"He doesn't."],[4842,5013,"So let me help."],[5013,5217,"That night, you used your father's influence"],[5217,5397,"to get a seat next to Alexander,"],[5397,5584,"you laced his drink with sleeping pills,"],[5584,5789,"then you helped him back to his room,"],[5789,6051,"took his shirt off, and gave him a hickey."],[6051,6177,"All without his consent."],[6285,6368,"You're lying."],[6368,6468,"That is not what"],[6468,6569,"happened."],[6569,6723,"Do I need to say more?"],[6723,6944,"You're sick in the head, Caitlin."],[6944,7198,"Holy shit, you could read minds?"],[7198,7349,"Why are looking at me?"],[7349,7432,"Move!"]],"55":[[1026,1138,"What you did back there"],[1138,1226,"is the sexiest thing"],[1226,1317,"I've ever seen."],[1497,1618,"Read my mind now."],[1664,1805,"She tastes so good."],[1906,2