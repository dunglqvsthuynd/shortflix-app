{"1":[[138,277,"Please don't..."],[634,750,"Please."],[1342,1476,"Miss?"],[1476,1603,"We're here."],[3480,3653,"Three months, Tina."],[3653,3907,"Three months since you disappeared."],[3965,4307,"No signs, no messages, nothing."],[4530,4626,"But I'll find you."],[4815,4969,"No matter what."],[7588,7734,"Tina? Where are you?"],[7788,7850,"Um..."],[8038,8119,"I'm here."],[8153,8280,"Tonight. Midnight."],[8326,8446,"Meet me at the Red Veil."],[8480,8707,"You're on the list under Camilla Villalante."],[8761,8865,"See you there."],[9223,9303,"Where is she?"]],"2":[[411,500,"Where is she?"],[553,726,"Boss, please."],[811,942,"She's nowhere to be found."],[1157,1257,"Useless."],[1415,1607,"My poor dear brother."],[1607,1834,"Always so dramatic."],[2065,2234,"Still obsessed with that little human?"],[2300,2353,"She's gone."],[2353,2461,"I can feel her."],[2666,2756,"Focus."],[2756,2889,"Tonight, the Voronov deal"],[2889,3019,"secures our place as the"],[3019,3250,"most powerful family in the West."],[3319,3611,"We wouldn't want to screw that up now, would we?"],[4684,5015,"This club is the only source of blood like this."],[5030,5165,"And blood this good..."],[5253,5503,"...always comes with a price."],[9607,9769,"Who are you? Where's Tina?"],[9769,10007,"I'm Sophia. Her sister."],[10169,10234,"You shouldn't be here."],[10234,10369,"I'm not leaving until I find her."],[10400,10619,"You don't get it. You don't come here to find people."],[10707,10834,"This is where they disappear."],[10834,10950,"Then I'm in the right place."],[10950,11115,"Leave now while you still have time."],[11461,11561,"Don't move."]],"3":[[1384,1480,"Who is that?"],[1703,1830,"Nikolai Voronov."],[1830,1938,"He's a billionaire."],[1938,2048,"He also owns the largest"],[2048,2210,"shipping empire in the West."],[2350,2500,"And the Von Dráks."],[2707,2769,"Who?"],[2788,2888,"They own this place."],[2907,3146,"Nikolai, welcome to the Red Veil."],[3146,3280,"Amara Von Drák."],[3315,3443,"Dorian Von Drák."],[3443,3557,"Everything is ready for you."],[3557,3738,"Good. Let's not waste time then."],[3765,3911,"Please, this way."],[4165,4242,"Tina?"],[4403,4534,"Eyes forward, Dorian."]],"4":[[111,250,"Oh, that makes sense."],[250,369,"Tina knew about this."],[376,434,"About?"],[434,523,"The Voronov deal."],[523,603,"What deal?"],[603,746,"Listen to me. You need to-"],[1807,1888,"It's you."],[1926,2138,"I'm not leaving until I find answers."],[2276,2388,"What are you doing?"],[2465,2584,"I'm saving your life."],[2742,2780,"What?"],[2784,2884,"Let's go."],[3161,3300,"There's an exit through the gate..."],[3334,3411,"Go."],[3488,3665,"My sister is in there somewhere."],[3676,3830,"Your sister's dead."],[3919,3973,"You don't know that."],[3973,4065,"They're watching you."],[4065,4219,"If you stay any longer..."],[4219,4319,"...they'll end up killing you too."],[4319,4480,"If you're not gonna help me, I'll do it myself."],[5246,5330,"Mmm."],[5384,5657,"The purity is remarkable."],[5984,6115,"Is something wrong?"],[6280,6653,"The taste is flawless, but can you ensure the supply?"],[6657,6965,"The finest blood floods our supply."],[7100,7230,"We own it all."],[7615,7700,"Excuse me."],[8246,8350,"He's..."],[8407,8473,"...distracted."]],"5":[[88,276,"Loyalty demands action, Amara."],[365,480,"I propose a union."],[538,695,"My daughter, Viktoria,"],[695,907,"marries your brother, Dorian."],[950,1036,"With that,"],[1036,1384,"the entire Western Hemisphere become ours."],[1526,1703,"A Voranov-Von Drák union?"],[3176,3253,"Noah."],[3284,3365,"Dorian."],[3438,3542,"Where is she?"],[3546,3623,"She who?"],[3634,3715,"Tina."],[3930,4150,"She's here. I saw her."],[4211,4311,"Careful, Dorian."],[4315,4446,"I know what I saw."],[4446,4561,"You're helping her."],[4561,4815,"Ooh, are we fighting over me?"]],"6":[[30,261,"Ooh, are we fighting over me?"],[534,757,"Your father's gonna be pissed. Come on."],[765,938,"Can I finish my drink first?"],[1065,1176,"You're cute."],[1215,1361,"Maybe I'll see you later."],[1630,1761,"What do you say, Amara?"],[1761,2011,"Shall we merge our houses?"],[2376,2511,"I'll drink to that."],[3484,3588,"You are late."],[3700,4011,"Papa, don't rush beauty. (Russian)"],[4073,4146,"She's trouble."],[4342,4453,"I like it."],[4973,5046,"Amara."],[5250,5453,"Yeah, I know who you are."],[5573,5826,"You're a bit of a mess, aren't you?"],[6000,6207,"We can fix that."],[7384,7757,"The union is all set. You will marry Viktoria."],[8480,8615,"I'm sorry..."],[8615,8780,"I was looking for the restroom."]],"7":[[684,800,"Tina..."],[869,1007,"Wait!"],[1138,1330,"I searched everywhere for you, my love."],[1442,1538,"What happened?"],[1838,2265,"Sorry. I didn't mean to hurt you."],[2457,2619,"You're here now."],[2673,2857,"That's all that matters."],[2880,3030,"Look at me, Tina."],[3119,3265,"Shh."],[3415,3573,"Let go of the fear."],[3861,4076,"And let me in."]],"8":[[2284,2419,"I shouldn't be here."],[2576,2626,"Please."],[2846,3046,"Trust me, my love."],[3365,3642,"I've searched lifetimes for you."],[4338,4534,"And the only way..."],[4534,4761,"to keep you safe..."],[4873,5234,"is to make us... eternal."]],"9":[[3434,3615,"Drink, my love."],[4134,4503,"Don't fight it. Let it in."],[4703,4850,"Step away from her, Dorian."],[5184,5346,"Noah."],[5676,5811,"Finally."],[5965,6103,"Let her go."],[6242,6476,"You don't give the orders."],[6511,6665,"It's my world."],[7276,7434,"What's happening?"],[7434,7700,"You take from the innocent."],[7726,7876,"Now, you'll finally understand"],[7876,8111,"what it means to be powerless."],[8830,9065,"I'm here. You're safe now."],[9542,9728,"No! No!"],[9728,9934,"You can't take her from me!"],[10346,10450,"What's happening?"],[10580,10834,"I'm saving your life. That's all you need to know."],[11115,11323,"Noah!"],[11323,11476,"You think you can take her from me?"],[11557,11722,"She's already mine!"],[12250,12404,"You..."],[12434,12576,"you're an angel?"],[12661,12788,"Hold on tight."],[13157,13311,"This isn't over!"],[13311,13530,"You'll never escape me!"]],"10":[[326,561,"He wants to marry me off to Dorian."],[603,738,"Can you imagine?"],[776,1000,"Me and your brother playing house?"],[1161,1300,"He might surprise you."],[1311,1430,"I doubt it."],[1450,1565,"But you..."],[1630,1780,"You're a real mystery."],[1926,2242,"Always watching... Always calculating..."],[2400,2642,"But never... touching."],[4276,4515,"Some things aren't meant to be touched."],[4923,5157,"That sounds like a challenge."],[5303,5526,"You don't know what you're asking for."],[5903,6065,"Maybe I do."]],"11":[[946,1100,"Goodnight, darling."],[2530,2684,"What the hell happened to you?"],[2746,3003,"Looks like he picked a fight..."],[3003,3150,"And lost."],[3157,3453,"Dorian. I asked you a question."],[3500,3607,"He's back."],[3607,3703,"Who?"],[3811,3930,"Noah."],[4038,4138,"And?"],[4165,4238,"Tina."],[4265,4411,"Sounds like trouble."],[4411,4553,"We'll handle it."],[4834,5034,"We always do."]],"12":[[276,426,"Sophia, this is gonna hurt."],[480,599,"But it's the only way."],[1423,1520,"Stay with me."],[3111,3242,"By the light..."],[3276,3473,"cleanse her."],[3630,3784,"By my blood..."],[4080,4300,"Restore her."],[4853,4969,"By the symbol of faith..."],[5480,5715,"Drive out the darkness."],[6126,6325,"I can't do it..."],[6325,6433,"I can't do it."],[6433,6510,"Fight it."],[6673,6819,"I can't..."],[6976,7057,"Stay with me!"],[7080,7215,"Sophia!"]],"13":[[50,85,"Hmm..."],[200,431,"\"The blood of the mortal twin...\""],[500,696,"\"corrupted by the blood thirsty...\""],[696,908,"\"and bound to the ethereal...\""],[981,1273,"\"shall shatter the reign of shadows.\""],[1552,1674,"Sophia."],[2231,2377,"You're quite the scholar."],[2427,2538,"Who are you?"],[2785,3046,"Let's just say we share similar interests."],[3119,3223,"If you're with them..."],[3238,3381,"I'm not with anyone."],[3519,3608,"But..."],[3673,3896,"I know where you'll find the answers you're looking for."],[4119,4319,"Midnight. Tomorrow."],[6015,6662,"Save her."]],"14":[[88,211,"Save her."],[238,457,"Shh. Shh."],[457,676,"Hey... hey. Sophia, you're okay."],[903,1034,"You're safe here."],[1238,1365,"Why are you helping me?"],[1384,1461,"Because..."],[1484,1707,"I know exactly what you're up against."],[1865,2003,"What are you?"],[2165,2288,"I'm Nephilim."],[2561,2711,"I'm half human..."],[2753,2915,"but I'm also half angel."],[3007,3276,"The Von Dráks wiped out my entire family"],[3276,3426,"to maintain their reign."],[3680,3834,"I'm the last one."],[4065,4242,"I saw Tina."],[4403,4523,"The prophecy..."],[4646,4819,"She left it for me."],[4930,5034,"Tell me."],[5100,5265,"It was something like..."],[5330,5515,"\"the blood of the mortal twin...\""],[5573,5740,"\"corrupted by the blood thirsty...\""],[5740,5946,"\"and bound to the ethereal...\""],[5946,6173,"\"shall shatter the reign of shadows.\""],[6184,6330,"What does it mean?"],[6357,6488,"You're the one."],[6800,7084,"The mortal twin walks among us."],[7253,7480,"Care to explain, Dorian?"]],"15":[[530,761,"Maybe she just wanted to crash the party."],[811,1019,"Mortals do love pretending they're one of us."],[1023,1126,"Tina is dead."],[1242,1361,"I made sure of it."],[1442,1557,"And if she's back..."],[1669,1826,"someone turned her."],[2073,2331,"If this puts my deal at risk..."],[2423,2573,"I need answers now."],[2688,3073,"Can you even be trusted to stand by Viktoria's side?"],[3090,3165,"Oh..."],[3200,3361,"Relax, Papa."],[3403,3669,"If Dorian's been playing house with a mortal..."],[3738,3880,"maybe that's exactly what we need."],[3880,4057,"Is this a game to you?"],[4119,4300,"Bloodbound twins tied to a prophecy"],[4300,4511,"don't come back without consequences."],[4538,4626,"Maybe..."],[4626,4800,"...it's an opportunity."]],"16":[[34,161,"Maybe..."],[269,411,"...it's an opportunity."],[442,734,"Say Tina's blood is bound to Noah..."],[780,930,"Mix it with ours..."],[1011,1161,"Bind it properly..."],[1176,1323,"We'd be unstoppable."],[1376,1580,"You can't just mix blood."],[1646,1757,"Can't we?"],[1784,1938,"With the right ritual..."],[2023,2165,"The right sacrifice..."],[2253,2503,"We could transcend the prophecy."],[2519,2638,"Ambitious..."],[2638,2846,"Sometimes risk..."],[2884,3115,"is the path to power."],[3126,3434,"I'm going to ask you one last time..."],[3565,3857,"Did you turn her?"],[4169,4250,"Yes."],[4307,4565,"Yay! Bravo!"],[4638,4769,"You put us all in danger."],[4769,4900,"Or I've saved us."],[4938,5209,"She's the key, Amara, to everything."],[5209,5584,"If you're wrong, brother... I'll kill you myself."],[8538,8676,"Sophia..."],[8726,8919,"I think you need to see this."]],"17":[[61,150,"Sophia..."],[276,420,"I think you need to see this."],[1688,1826,"Sophia..."],[1826,2088,"if you're reading this, I'm already gone."],[2130,2357,"I made my choice to protect you,"],[2357,2523,"to protect all of them."],[2588,2765,"The blood that runs through your veins"],[2765,2988,"is more powerful than you know."],[3019,3253,"It's the key to ending their reign..."],[3319,3500,"but it comes with a cost."],[3526,3757,"The red veil holds the key."],[3842,4022,"\"Beneath the light of the blood moon...\""],[4022,4184,"\"you will find the truth.\""],[4319,4449,"\"It's hidden where the shadows...\""],[4449,4665,"\"and the light meet.\""],[4757,4873,"\"Find it.\""],[4957,5073,"\"End this.\""],[5153,5330,"\"For both of us.\""],[5546,5676,"\"I love you.\""],[5834,5950,"\"Tina.\""],[6165,6242,"I don't think that you-"],[6242,6346,"She is gone."],[6407,6530,"Because of me."],[6607,6746,"Sophia, that's not it."],[6976,7138,"I need to get some air."]],"18":[[1061,1253,"What is happening to me?"],[1576,1711,"Hello, baby."],[1760,1884,"What's a pretty thing like you"],[1884,2046,"doing out here all alone?"],[2065,2150,"Stay back."],[2150,2330,"Well, don't worry. I don't bite."],[2357,2573,"Come on, sweetheart. Don't you want to play?"],[2576,2673,"Come on."],[3111,3211,"Come here."]],"19":[[230,373,"Sophia."],[407,580,"Oh my God..."],[580,715,"I killed him."],[730,915,"I didn't mean to."],[980,1130,"Let's get you somewhere safe."],[1319,1417,"What is that?"],[1830,1920,"Hot cocoa."],[2312,2365,"Hmm?"],[2365,2600,"This doesn't smell like cocoa."],[2773,2865,"It's..."],[2953,3100,"...vampire cocoa."],[3923,4057,"It's not bad."],[4311,4461,"You're still shivering."],[4523,4620,"Here."],[5307,5453,"What are you doing?"],[5553,5646,"Relax..."],[5676,5823,"It's not what you think."],[6076,6187,"Trust me."],[6357,6503,"Come here."],[7650,7819,"Your body's fighting itself."],[7819,8026,"The two bloods inside you, they're..."],[8146,8307,"battling for control."],[8461,8760,"The ethereal side is rejecting"],[8760,8830,"what's happening,"],[8830,9046,"while the vampire side is..."],[9173,9411,"Well, let's just say it's a control freak."],[9688,9876,"This feels really nice."],[9930,10119,"It's like a hot water bottle."],[10203,10461,"With pretty good cocoa making skills."],[10630,10838,"Thank you for this."],[10861,10950,"Yeah."]],"20":[[865,1161,"If this is about the wedding, I don't want to hear it."],[1203,1373,"You're marrying Dorian."],[1419,1523,"You look stunning."],[1523,1715,"I don't have time for this, Viktoria."],[1765,1880,"What do you want?"],[1911,2011,"Fine."],[2042,2188,"Let's skip the bullshit..."],[2388,2580,"This marriage is about control,"],[2580,2876,"and you and I both know that Dorian isn't fit for it."],[2938,3100,"He's more capable than you think."],[3100,3188,"Capable of what?"],[3188,3388,"Falling apart over a mortal?"],[3446,3676,"He jeopardized our empire."],[3700,3938,"That's not just reckless. It's unforgivable."],[3973,4250,"What exactly are you proposing?"],[4711,5003,"I want you to remove him from the equation."]],"21":[[173,288,"Kill my own brother?"],[288,461,"With Dorian out of the picture?"],[530,688,"You wouldn't have to share..."],[742,900,"Not with him..."],[900,1061,"Certainly not with me."],[1369,1607,"And what exactly do you get out of this?"],[1715,1815,"Freedom..."],[1953,2061,"No strings..."],[2200,2453,"No husband to hold me back..."],[2661,2907,"I'd still play my part, of course..."],[2934,3126,"Loyal to the Von Drák name..."],[3257,3434,"Loyal to you."],[4088,4407,"If I do this..."],[4476,4646,"it'll be on my terms..."],[4723,4907,"My timing."],[5026,5326,"And if you step one foot out of line..."],[5426,5569,"you won't see me coming."],[5726,5907,"Of course, my queen."],[7180,7329,"My dear brother..."],[7553,7788,"I raised you when no one else would..."],[7880,8015,"Protected you..."],[8203,8307,"Loved you..."],[8342,8573,"But love isn't enough anymore."],[8707,8842,"This isn't for me..."],[8984,9138,"It's for the family."],[9273,9476,"For everything we've built."],[9550,9746,"I'm sorry, Dorian."]],"22":[[146,253,"Who is it?"],[330,465,"Your sister."],[2115,2238,"What do you want?"],[2365,2523,"I come in peace."],[2611,2815,"Since when do you care about peace?"],[2826,2922,"I'm your sister."],[2922,3057,"I hate seeing you like this."],[3057,3265,"Hey! Don't start..."],[3276,3476,"I don't want another lecture from you."],[3542,3676,"No lectures."],[3961,4138,"I actually came to apologize."],[4303,4434,"You apologizing?"],[4453,4669,"I know I can be intense sometimes."],[4715,4915,"But that's because I love you."],[5057,5184,"It's because I care."],[6107,6219,"Why don't we have a drink?"],[6246,6373,"You and I."]],"23":[[607,765,"I say..."],[842,1119,"We put all this nonsense behind us."],[1473,1780,"Why don't we drink to something beautiful?"],[2276,2480,"Let's drink to the empire we built."],[2853,2957,"To us."],[3200,3303,"To us."]],"24":[[211,365,"Amara..."],[426,550,"What did you do?"],[1200,1338,"\"Nightshade essence\"."],[1774,1926,"Smallest drop will take down"],[1926,2053,"even the strongest of us."],[2461,2607,"I warned you, Dorian..."],[2823,2965,"Your love for mortals..."],[3065,3207,"for her..."],[3309,3409,"It threatens everything that"],[3409,3630,"we've worked so hard to protect."],[3765,3884,"Our family..."],[4019,4165,"Our empire."],[5434,5546,"I'm sorry, brother."],[6461,6580,"Amara..."],[6834,7107,"This isn't over!"]],"25":[[1011,1130,"You've gotta be kidding me."],[1130,1303,"I'm not here to fight."],[1500,1638,"I need to see her."],[2069,2269,"What the hell is he doing here?"],[2319,2446,"Bleeding out, apparently."],[2480,2573,"Tina..."],[2669,2780,"Please."],[2965,3169,"I had to see you before I go."],[3234,3388,"Does he know I'm not Tina?"],[3415,3561,"I don't think so."],[3573,3726,"I love you..."],[3769,3973,"more than you'll ever know."],[4061,4257,"You've got some nerve showing up here."],[4311,4407,"Now, get out!"],[4415,4538,"Wait, wait, wait."],[4569,4634,"Let him speak-"],[4638,4757,"He shouldn't be here."],[4765,4915,"Sophia, he's dying."],[4919,5073,"Tina, please."],[5388,5553,"You're the reason that she's gone."],[5657,5830,"I know."],[6069,6250,"I failed you, Tina..."],[7769,7865,"Dorian?"],[8003,8084,"Tina."],[8107,8249,"It's me, my love."],[8650,8788,"It's you."]],"26":[[173,253,"Tina."],[265,426,"It's me, my love."],[446,630,"Even in the darkness..."],[730,900,"You were my light."],[950,1088,"Sorry..."],[1273,1453,"For everything."],[1788,2134,"I failed you."],[2180,2369,"You didn't fail me."],[2388,2538,"You loved me."],[2600,2853,"But now it's time to let go of the past."],[2930,3257,"Sophia, she needs you."],[3365,3669,"She held the light that I once carried."],[3738,3903,"She can't do it alone."],[3976,4080,"Sophia...?"],[4115,4219,"My sister."],[4261,4480,"Protect her as if she were me."],[4519,4700,"Promise me, Dorian."],[4800,5042,"I promise."],[5161,5265,"Good."],[5373,5638,"I love you, always."],[5769,5926,"It's time to go now."],[5969,6057,"No!"],[6150,6253,"Wait."],[6384,6684,"I can't lose you again."]],"27":[[238,388,"Focus, Sophia."],[442,553,"It's in you."],[607,723,"You just need to unlock it."],[723,880,"I am focusing."],[911,1038,"It's not working."],[1076,1253,"You're overthinking it."],[1600,1750,"It's an extension of you."],[2365,2534,"Feel it."],[3661,3773,"I can't control it."],[3776,4126,"You can't control it because you're fighting it."],[4284,4370,"You shouldn't be out here."],[4388,4514,"You think this is preparing her"],[4514,4623,"for what's coming?"],[4653,4969,"The light is not gonna save you from this fight."],[5069,5273,"You've gotta learn to use your instincts."],[5276,5438,"So, she should just give in to her hunger"],[5438,5584,"and become like you, Dorian?"],[5607,5950,"No, she's a Nephilim, just like you."],[5973,6130,"Way more powerful than me."],[6138,6326,"You have both sides in you."],[6369,6453,"Start using them."],[6453,6569,"Why should we trust you?"],[6573,6888,"Because if Amara wins, none of us survive."],[6950,7173,"She tried to kill me, her own brother."],[7203,7338,"If she's willing to do that to me,"],[7338,7538,"what do you think that she's gonna do to you two?"],[7553,7638,"Okay, enough."],[7638,7819,"If you really think that you can help us,"],[7819,7988,"then why don't you prove it, Dorian?"]],"29":[[357,703,"If Tina's journal is right, then this is the place."],[880,1023,"And you're sure we weren't followed?"],[1038,1184,"Amara's people like to avoid places"],[1184,1334,"that expose darkness."],[1607,1788,"Then we're definitely in the right place."],[3103,3280,"You're Eryndra?"],[3450,3550,"Yes."],[3657,3774,"I'm Sophia."],[3819,4146,"My sister Tina said that you could help us find the way."],[4273,4607,"Your sister embraced her fate."],[4665,4866,"Are you ready to do the same?"],[4950,5080,"I am."]],"30":[[200,342,"Give me your hands."],[1780,1930,"The blood-bound twin."],[1950,2203,"The Nephilim, the midnight hunter."],[2250,2553,"You've come to fulfill the prophecy."],[2553,2661,"We need answers."],[2661,2976,"The world has fallen out of balance, Sophia."],[3042,3259,"The blade of Lumira"],[3259,3530,"was forged at the dawn of creation..."],[3600,3769,"to restore this balance."],[3865,3965,"What does it mean?"],[3976,4200,"The blade is only a tool."],[4353,4661,"Its true power comes from your blood."],[4707,5011,"Blood that holds both light and shadow..."],[5080,5403,"creation and destruction."],[5403,5542,"And how do we find this blade?"],[5561,5980,"The man of dark ambitions grips it tightly."],[6084,6165,"Voronov."],[6211,6442,"In order to fulfill the prophecy..."],[6500,6703,"there must be a sacrifice."],[6726,6930,"One of you..."],[6930,7080,"must die."]],"31":[[1360,1493,"The Smell Of Power... (Russian)"],[1511,1661,"...there is nothing like it."],[1661,1788,"Oh, Papa."],[1926,2088,"Power is a funny thing..."],[2230,2400,"More of it you have..."],[2469,2634,"Hungrier you get."],[3761,3842,"You're late."],[3884,4023,"And you're impatient."],[4061,4219,"Dorian is alive."],[4311,4442,"And he's not alone."],[4484,4665,"He's with Tina..."],[4700,4911,"...and that freak, Noah."],[4965,5061,"Are you scared?"],[5061,5215,"They're coming for us."],[5215,5376,"And if we're not careful..."],[5765,5919,"they'll take everything."],[5957,6184,"I'd love to see them try."]],"32":[[400,453,"Dorian."],[723,926,"Look at you."],[976,1140,"From aristocrat"],[1140,1415,"to scavenging for scraps in the gutter."],[1415,1515,"Viktoria..."],[1588,1819,"What the hell are you doing here?"],[1976,2281,"Whatever that smell is, it's disturbing."],[2281,2400,"Get lost."],[2411,2646,"Believe it or not, I came to rescue you."],[2761,2888,"You're a Von Drák..."],[2919,3026,"Start acting like it."],[3030,3355,"I don't need your pity or your lectures."],[3355,3469,"No pity..."],[3488,3707,"And no lectures, Dorian."],[3838,3976,"Just an opportunity."],[4269,4388,"What opportunity?"],[4530,4746,"I can bring Tina back."]],"33":[[76,165,"What did you say?"],[203,365,"Tina, the real Tina..."],[365,577,"not that cheap substitute you've been following"],[577,665,"around like a lost puppy."],[669,784,"You're lying!"],[880,1038,"Didn't Eryndra tell you?"],[1080,1211,"And how did you know"],[1211,1357,"that we went to go see her?"],[1430,1588,"We all have our sources."],[1619,1773,"The blade of Lumira..."],[1773,2111,"doesn't just balance light and shadows..."],[2161,2373,"It can restore life."],[2423,2603,"The blade can bring her back?"],[2611,2765,"With the right blood..."],[3034,3123,"Sophia."],[3157,3376,"Give her to us..."],[3376,3557,"and we'll bring Tina back."],[3807,4096,"Or just keep holding onto your little mortal toy"],[4096,4311,"and let the prophecy destroy us all."],[4484,4776,"If I bring her to you..."],[4988,5084,"you've got a swear-"],[5088,5311,"On my life, darling."],[5357,5600,"You'll get your precious Tina back..."],[5600,5961,"whole and eternal."]],"34":[[326,473,"Your favorite Cocoa."],[553,723,"Thought you might want some."],[834,973,"Thank you."],[1173,1430,"This is all just happening really fast."],[1507,1961,"One minute I'm looking for Tina and now it's this."],[2026,2338,"Battles and prophecies and bloodlines."],[2411,2526,"You're doing great."],[2584,2753,"I messed everything up."],[2773,3023,"Tina's gone and now because of me..."],[3065,3203,"one of us is gonna die."],[3219,3353,"You're not alone in this."],[3353,3534,"Whatever happens tomorrow..."],[3673,3830,"we'll get through it together."],[4123,4211,"Um..."],[4469,4673,"I have to tell you something."],[5565,5776,"Sophia, I'm so proud of you."],[5900,5946,"And-"],[5946,6042,"Noah, I-"],[6042,6226,"You don't have to say anything."],[6353,6476,"You got this."],[6611,6780,"And if you fall..."],[6861,7038,"I'll be there to catch you."],[7350,7504,"You already have."],[8888,8980,"I brought dinner."]],"35":[[623,688,"Right here."],[788,1003,"Room No.4, the collection room."],[1003,1189,"It's right next to the painting"],[1189,1315,"with the woman in the red dress."],[1326,1423,"How do we get it?"],[1438,1576,"Through the back alley..."],[1603,1804,"Amara and Viktoria won't see it coming"],[1804,1903,"if we act quickly."],[1903,2046,"And how do we know it's safe?"],[2073,2180,"You don't."],[2211,2369,"But, this is the best option."],[2380,2511,"Unless you got a better idea."],[2511,2661,"I don't think we have a choice."],[3050,3255,"Trust me, I want to resolve this prophecy"],[3255,3442,"just as much as you do."]],"36":[[519,607,"Clear that room."],[636,760,"Make sure we're alone."],[858,961,"I'll be quick."],[2784,2903,"Dorian?"],[3357,3461,"Noah?"],[3653,3765,"Sophia..."],[4315,4530,"Sophia..."],[4615,4707,"Help me..."],[4726,4834,"Sophia, hurry!"],[4834,4919,"Tina?!"],[5038,5188,"Help me, Sophia."],[5465,5588,"Sophia..."],[5773,5934,"Help me, Sophia."],[5953,6138,"Come and save me."]],"37":[[57,215,"Welcome, little princess."],[215,319,"Where's Tina?"],[384,765,"Tina... Tina... Tina... It's always about Tina."],[876,1030,"You must be so tired of living"],[1030,1126,"in her shadow by now."],[1126,1238,"What have you done to her?"],[1253,1361,"She begged..."],[1447,1591,"She screamed your name"],[1591,1815,"as my blade kissed her throat."],[1988,2188,"Her blood flowed like a river."],[2284,2419,"So fragile..."],[2550,2634,"So beautiful."],[2634,2773,"Poor little Sophia."],[2780,3003,"So desperate to be the hero."],[3034,3134,"To save the day."],[3150,3369,"Yet, the only thing you've brought us..."],[3369,3553,"is exactly what we need..."],[3800,3900,"Your blood."],[3930,4069,"You want my blood?"],[4150,4269,"Come and get it."]],"38":[[42,180,"You want my blood?"],[219,338,"Come and get it."],[661,919,"What a charming reunion!"],[919,984,"Noah?"],[1034,1303,"Nifty little invention..."],[1338,1726,"A masterpiece of pain and control."],[1911,2261,"Especially for the creature like him."],[2426,2523,"Stop it!"],[2523,2865,"Careful! One wrong move and your knight dies."],[2865,3284,"He's a really loyal fool, isn't he?"],[3438,3538,"What do you want?"],[3538,3753,"Just your blood. Your power."],[3861,4026,"Everything we've been waiting for."],[4026,4323,"I would rather die than give you anything."],[4430,4576,"Patience, darling."],[4665,4850,"The fun's just getting started."],[5146,5284,"It's over, Sophia!"]],"39":[[211,319,"You're with them."],[319,407,"Oh, Sophia..."],[488,680,"This prophecy, this fight..."],[746,900,"It's a losing battle."],[930,1056,"The only way to save all of us"],[1056,1269,"is to give us what we want."],[1269,1507,"You turned your back on us."],[1507,1646,"Didn't he tell you?"],[1650,1841,"Your precious Dorian agreed to"],[1841,2000,"lead you straight to us."],[2211,2334,"I did what I had to do..."],[2423,2546,"For Tina."],[2546,2711,"You don't know what they're capable of."],[2711,2826,"You coward!"],[2857,3203,"You sold out the only people who trusted you!"],[3203,3280,"Enough!"],[3319,3476,"We are wasting time..."],[3530,3742,"Bring her to the altar."],[4500,4676,"You'll have to kill me first."]],"40":[[2465,2600,"Is that all you've got?"],[5611,5769,"You're gonna have to do a hell of a lot"],[5769,5861,"better than that."],[7965,8069,"Dorian!"],[9103,9388,"Not so tough now, are we, Sophia?"],[10411,10550,"It's over, Sophia."]],"41":[[2569,2784,"The Blade of Lumira..."],[2880,3319,"A weapon for both creation and destruction..."],[3388,3638,"darkness and light..."],[3684,3926,"life and death."],[5038,5342,"Tonight, the balance of power is broken."],[5361,5607,"The eternal light will fall under shadow."],[5642,5957,"I must say, Dorian, your loyalty's admirable."],[5957,6076,"Save it, Viktoria."],[6134,6400,"Deliver Tina to me, then I'll believe you."],[7015,7200,"The loyal protector..."],[7253,7361,"Right on time."],[7388,7484,"Noah!"]],"42":[[1369,1534,"Sophia..."],[2138,2269,"Drink!"],[2342,2534,"The blood of the ancients..."],[2661,2830,"Let it free you..."],[3034,3238,"The shadow overcome you."],[3276,3526,"No, I won't."],[4438,4642,"Sophia, fight it."],[4730,4853,"Fight it!"],[4942,5119,"The thing of beauty..."],[5211,5361,"So defiant..."],[5426,5684,"Yet, so easily broken."],[9219,9550,"By the power of the shadow, I command you..."],[10180,10336,"Strike the light."]],"43":[[223,357,"Strike the light."],[1461,1588,"Listen to me, Sophia..."],[1834,1909,"This isn't you."],[2165,2276,"Okay?"],[2519,2661,"Look at me..."],[2823,3026,"Sophia, you can do this. Remember..."],[3146,3215,"Please."]],"44":[[546,657,"No, what have I done?"],[680,753,"No!"],[926,1111,"You are reborn in darkness..."],[1161,1307,"One of us."],[1457,1580,"At last."],[1653,1842,"It wasn't your fault..."],[1934,2003,"No..."],[2030,2111,"No!"],[2884,3030,"You made me do this..."],[3103,3257,"And now you'll pay."],[3773,3840,"No."],[4353,4442,"What's happening?"],[4446,4576,"This isn't supposed to happen."],[4584,4673,"The curse!"],[4700,4803,"Impossible!"]],"46":[[57,288,"The prophecy must be fulfilled."],[819,915,"Balance..."],[957,1115,"requires sacrifice."],[1603,1653,"Noah?"],[1830,1953,"Please don't go."],[2257,2376,"Please..."],[3761,3926,"Oh no."]],"47":[[1338,1638,"Two souls bound by blood..."],[1688,1919,"split across lifetimes..."],[1923,2334,"entwined in the eternal dance of fate."],[7869,8038,"It's you."]],"48":[[350,715,"Where there is light, there is always hope."],[850,996,"He's gone."],[1065,1504,"His sacrifice is not the end, but the beginning."],[1565,1730,"Drink this, child."],[1765,2019,"Drink this. Drink this!"],[2134,2338,"It'll give you strength."],[3342,3669,"His light, restored the balance..."],[3742,4115,"but your blood holds the power of creation."],[4149,4229,"Take it."],[4407,4773,"The blade of Lumira is bound to you both."],[4773,4944,"Its power combined"],[4959,5157,"can awaken what lies dormant..."],[5157,5361,"within you."],[6100,6242,"Please, let this work."],[6269,6515,"Please, please let this work."]],"49":[[2869,3011,"Noah."],[3203,3338,"Sophia."],[3534,3742,"I remember everything now."],[3757,3903,"Every life..."],[3942,4219,"All the moments lost to time..."],[4261,4484,"Across every life..."],[4561,4703,"And every death..."],[4926,5157,"It's always been you."],[5338,5565,"And it always will be."]],"50":[[2975,3109,"Dorian..."],[3122,3174,"Dorian..."],[3257,3353,"Dorian!"],[4069,4346,"It's over now, dear brother..."],[4369,4526,"You're free."],[4546,4751,"You can finally be with Tina."],[6099,6222,"Papa."],[6411,6684,"Oh God, no. (Russian)"],[6838,6988,"They're all gone."],[7200,7334,"All of them."],[8080,8230,"It's just us now."],[10130,10330,"They're gonna pay for what they've done."],[10526,10669,"All of them..."],[11007,11160,"This is far from over."],[11453,11560,"We'll rebuild..."],[11688,11823,"Stronger than ever."],[11973,12142,"I promise you."],[12226,12350,"No. No, hey..."],[12380,12519,"Hey! Look at me."],[12623,12730,"I promise."],[14434,14576,"And we have each other."],[16923,17083,"This isn't the end..."],[17380,17502,"It's the beginning."]]}