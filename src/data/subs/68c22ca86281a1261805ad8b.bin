{"1":[[944,1124,"#You have a dangerous# #body, Adam.#"],[1144,1280,"#Shame this# #has to end.#"],[1287,1398,"#Who said anything# #about ending?#"],[1491,1604,"We can go for another round."],[1638,1675,"No!"],[1781,1855,"We're done here."],[1891,1973,"Save your stamina"],[1973,2089,"for your next sugar mama."],[2365,2479,"What is that supposed to mean?"],[3319,3484,"You've been my sugar baby for a year."],[3484,3570,"So..."],[3613,3740,"Let's talk severance."],[4003,4080,"One million."],[4127,4244,"I'm a generous tipper."],[4421,4497,"We're done here!"],[4788,4921,"Are you dumping me?"],[4991,5141,"This better not be what I think it is."],[5198,5285,"Hey, Adam..."],[5321,5432,"I'm gonna miss you."],[5458,5505,"But..."],[5595,5749,"All good things come to an end."],[5842,5982,"Try not to miss me too much."],[5995,6116,"Are you out of your mind?"],[6166,6256,"You were into this!"],[6286,6379,"I'm getting married!"],[6479,6549,"This is over."],[6938,7067,"Take the million, Adam."],[7133,7303,"And live a happy life without me."],[8101,8238,"Catherine Rogers..."],[8318,8463,"You don't decide how this ends!"],[8808,8898,"Mr. Hartford,"],[8908,9125,"did Miss Rogers piss you off again?"],[9162,9330,"Let's find out who her fiancé is."]],"2":[[330,437,"Come on, Catherine."],[483,636,"Time to face your demons."],[1247,1414,"Oh, Catherine!"],[1461,1604,"Didn't expect you to pick us up."],[1661,1745,"Us?"],[1788,1941,"I'm here to pick up my husband!"],[1965,2115,"Pretty sure I married a man, unless"],[2115,2314,"you've made a life decision recently."],[2325,2389,"Watch it!"],[2459,2629,"Amy's pregnant with my child."],[2856,2929,"Pregnant?"],[2979,3263,"Oh, Catherine, you're just the contract wife,"],[3293,3602,"I, on the other hand, am the real deal."],[3636,3879,"So, help me with this?"],[4314,4424,"Catherine!"],[4461,4624,"I'm warning you, she is pregnant!"],[4644,4874,"With your child, not mine!"],[4974,5133,"I agreed to this marriage because"],[5133,5346,"your parents once showed me kindness."],[5365,5520,"I thought good people"],[5520,5684,"couldn't possibly raise an asshole."],[5782,5915,"Clearly, I was wrong."],[5965,6056,"You know what?"],[6149,6216,"I told your parents"],[6216,6329,"I'd meet you at the airport."],[6393,6463,"Didn't say anything"],[6463,6569,"about you riding with me!"],[6790,6873,"Unbelievable."],[6923,7066,"You're telling me that bastard is her"],[7066,7137,"husband?"],[7167,7280,"Peter Wilson."],[7310,7413,"Supposed heir"],[7413,7640,"to the crumbling Wilson Estate."],[7660,7855,"Have a nice life, assholes!"],[8058,8173,"That washed-up family?"],[8173,8298,"Catherine!"],[8298,8469,"You crazy bitch!"],[8488,8655,"Wilson and Rogers go way back."],[8705,8866,"Might be a contract marriage."],[8892,8975,"I don't care."],[9012,9172,"The title husband doesn't suit him."],[9212,9350,"We're throwing a party next week."],[9366,9534,"Get Catherine Rogers an invitation."],[9559,9805,"Let her know who she just pissed off!"]],"3":[[1261,1412,"Catherine, don't be mad."],[1464,1588,"I just needed some air."],[1641,1835,"Peter brought me here to clear my head."],[1881,2012,"Where are we, Central Park?"],[2085,2178,"Peter, I don't think they allow"],[2178,2270,"pets on the property."],[2275,2328,"Watch it!"],[2412,2515,"If it wasn't for my family's"],[2515,2643,"connection with Mr. Hartford,"],[2672,2785,"you wouldn't even get an invite."],[2789,2964,"And if it wasn't for our marriage,"],[2972,3126,"your family wouldn't back you at all!"],[3206,3351,"Good luck inheriting the Wilson fortune"],[3351,3473,"with this little trophy gal."],[3473,3575,"Shut it, Catherine!"],[3640,3687,"What?"],[3687,3825,"We're dropping the niceties already?"],[3847,3903,"Catherine!"],[3957,4050,"You have no right"],[4050,4170,"to speak to Amy this way."],[4177,4276,"I have every right."],[4297,4414,"I'm your legal wife!"],[4474,4524,"Don't cross-"],[4544,4671,"I swear to God!"],[4708,4811,"Look around, Peter."],[4924,5038,"You want to start a scandal?"],[5068,5119,"Here?"],[5295,5412,"Offend the Hartfords, and your business"],[5412,5540,"won't last a day in New York."],[5919,6026,"Now be a good boy"],[6139,6244,"and leash your pet!"]],"4":[[216,316,"- Peter... - Enough!"],[523,577,"Behave."],[1294,1368,"Cheers!"],[1511,1682,"When is Adam Hartford arriving?"],[1705,1862,"I heard he's incredibly hot!"],[1878,1981,"Oh, have you seen him?"],[2008,2257,"He is gorgeous, but his looks"],[2268,2487,"are nothing compared to his bank account."],[2562,2732,"Even the presidential candidates"],[2736,2922,"are fighting for his sponsorship."],[2932,3049,"I didn't even care about his money,"],[3063,3200,"I just wanna see that face!"],[3286,3473,"Trust me, when you see him,"],[3483,3687,"you'll never forget!"],[3717,3900,"Everyone who's ever met him"],[3917,4114,"craves him for life!"],[4130,4217,"Just wait."],[4217,4297,"You'll see what I mean."],[4317,4441,"He's impossible to forget."],[4454,4566,"Impossible to forget?"],[4647,4721,"Yeah..."],[4774,4934,"I've seen a face like that."],[5492,5610,"I'll have what she's having."],[5862,5957,"Is that a pickup line?"],[6146,6189,"No."],[6219,6299,"It's a shame."],[6489,6593,"I already took the bait."],[7410,7490,"Do you know who I am?"],[7510,7590,"Yes."],[7657,7741,"Right now,"],[7771,7951,"you're the man I wanna kiss"],[8031,8104,"and fuck!"],[8311,8385,"Hey, he's here!"],[8682,8845,"Come on, guys, let's get closer."],[9936,10081,"Mr. Hartford!"]],"5":[[60,210,"Did I just see Adam?"],[380,440,"What are you doing?"],[550,603,"Working."],[730,827,"We need Adam Hartford to"],[827,950,"invest in your family business?"],[1014,1104,"We haven't even seen him,"],[1104,1211,"let alone talked to him."],[1401,1491,"Okay, so now,"],[1491,1605,"you actually want to help me?"],[1624,1789,"Not you, your parents."],[1918,2062,"When my family went bankrupt,"],[2062,2158,"they helped me rebuild."],[2178,2299,"I'm just returning the favor."],[2308,2438,"I'm sorry, are you married to me"],[2438,2541,"or are you married to them?"],[2655,2805,"God, I wish I were married to them."],[2849,3003,"At least they're not total assholes."],[3283,3430,"I warned you, let go!"],[3456,3594,"And I said no!"],[3757,4020,"Don't forget, you are still my wife."],[4037,4274,"Don't worry, I never forget pain."],[4341,4447,"Now, let go!"],[4502,4564,"Make me!"],[4731,4841,"Didn't you hear her?"],[5555,5652,"The lady said no!"],[5945,6106,"Did Adam Hartford just step in?"],[6106,6348,"Oh no, Peter Wilson just poked a bear."],[6750,6796,"No."],[6840,6913,"No way!"],[6970,7087,"It has to be a mistake."],[8411,8521,"Catherine Rogers."],[8745,8838,"My call boy,"],[8905,9029,"my sugar baby Adam,"],[9095,9192,"is Adam Hartford!"]],"6":[[994,1174,"Miss, your phone?"],[1798,1978,"Miss, your phone?"],[2202,2429,"You're really hot."],[2559,2732,"You really don't know who I am, huh?"],[2829,2942,"What, are you an angel?"],[3070,3196,"You know what, Earth sucks."],[3253,3546,"Don't worry, I'll keep you safe."],[4647,4891,"Mr. Hartford, apologies,"],[4891,5078,"I hope we didn't cause any trouble."],[5115,5305,"Really appreciate that, by the way, thank you for-"],[5305,5485,"I was not talking to you."],[5592,5641,"Thank you."],[6172,6412,"Mr. Hartford, do you know my wife?"],[6690,6795,"You look familiar."],[6910,7113,"Perhaps we've met before."],[7377,7460,"Maybe in bed?"]],"7":[[347,570,"Mr. Hartford, you know my wife?"],[707,764,"In bed?"],[920,990,"My mistake,"],[1051,1164,"my lover was"],[1217,1323,"way sexier"],[1360,1404,"and"],[1498,1631,"definitely more passionate."],[2058,2197,"Right, of course."],[2255,2562,"Yes, my wife is rather bland, isn't she?"],[2565,2609,"Wow."],[2866,2906,"Really?"],[2906,2964,"Yes!"],[3066,3135,"Totally forgettable."],[3135,3328,"People mistake her for others all the time."],[3373,3493,"Anyway, no need to apologize,"],[3493,3567,"Mr. Hartford,"],[3570,3670,"I was hoping to talk to you"],[3670,3793,"about a business opportunity,"],[3793,3960,"an investment, if you will."],[4007,4099,"An investment?"],[4247,4337,"Easy, maybe."],[4421,4567,"But I won't be discussing it with you."],[4627,4763,"You've got questionable"],[4763,4970,"business instincts, Peter Wilson."],[5071,5290,"And if you've got someone else handling things,"],[5331,5445,"I might reconsider."],[5518,5739,"Mr. Hartford, hi."],[5852,6078,"I'm Mr. Wilson's business associate."],[6700,6923,"Wilson Corp. has huge potential."],[7010,7130,"Perhaps you could approach this"],[7130,7500,"partnership with a more open mind?"],[7540,7590,"Open?"],[7640,7796,"Like the way he treats his marriage?"]],"8":[[43,189,"Mr. Hartford, there must be"],[189,333,"some sort of misunderstanding."],[357,608,"I invited you and your wife,"],[650,827,"and yet you brought your business associate"],[827,1044,"who does not have a business degree,"],[1044,1144,"nor understands the most"],[1144,1308,"basic shit about finance."],[1401,1614,"The private affairs does not concern me,"],[1638,1919,"but your taste in company says a lot about you"],[1919,2095,"and your crumbling family empire."],[2108,2222,"That's not true!"],[2225,2285,"I am not."],[2405,2573,"And I was not talking to you, miss."],[2672,2762,"Can we talk?"],[2916,2982,"I mean,"],[3049,3358,"would you prefer to talk business with me?"],[3993,4164,"Let's see how serious you are this time."],[4224,4313,"Catherine Rogers."],[4441,4518,"Wait for my call."]],"9":[[740,973,"Why would Adam Hartford want to talk to her?"],[1381,1458,"Are you okay?"],[1574,1701,"You're pregnant, be careful."],[1791,1880,"Thank you, baby."],[2072,2159,"I'm great."],[2325,2544,"But she won't be."],[3596,3830,"Oh my god, Catherine, are you OK?"],[4000,4194,"Was it the conversation with Mr. Hartford?"],[4230,4383,"Got your knees shaking?"],[4427,4521,"What happened here?"],[4557,4693,"You spilled food on a guest?"],[4704,4924,"The lady, she collapsed onto me."],[4924,5075,"Unbelievable!"],[5155,5284,"You ruined Mr. Hartford's event."],[5305,5435,"How are you going to fix this?"],[5625,5772,"You deserve a damn Oscar."],[5842,6112,"Unfortunately, I'm allergic to bitches."],[6166,6318,"What are you doing?"],[6326,6406,"You crazy?"],[6416,6540,"She is pregnant."],[6553,6666,"You stay the hell away from her!"],[6703,6840,"I hope your kid doesn't turn out"],[6840,6983,"as trashy as their parents."],[6983,7047,"Are you-"],[7110,7207,"Get off him!"],[7270,7362,"Get off him!"],[7902,8054,"Who touched her?"]],"10":[[433,542,"I repeat,"],[637,740,"who touched her?"],[900,1087,"I'm so sorry."],[1124,1277,"We didn't know she was your guest."],[1361,1434,"Clean this mess up."],[1441,1667,"Right, this is all just a misunderstanding."],[1695,1815,"There's been plenty of those today,"],[1815,1995,"don't you think, Peter Wilson?"],[2055,2308,"Mr. Hartford, Catherine pushed me!"],[2369,2485,"I'm pregnant."],[2519,2719,"She tried to hurt my baby."],[2752,2892,"I had to defend myself."],[2892,3089,"Do not lay a finger on Catherine."],[3133,3230,"She's with me."],[3393,3487,"With you?"],[3526,3649,"Yes, with me."],[3697,3777,"Are we clear?"],[4144,4200,"Come with me."],[4200,4281,"It's okay, I can"],[4297,4413,"walk, really."],[4557,4790,"Then, you leave me no choice."]],"11":[[543,650,"I need to change."],[710,769,"Please leave."],[1301,1358,"What?"],[1584,1688,"Feeling a bit shy?"],[1915,2088,"Remember I used to help you with these, too."],[2208,2288,"We shouldn't!"],[2372,2439,"Tell me,"],[2575,2652,"do you want me?"],[2742,2913,"Just say it and I will give you everything."]],"12":[[13,230,"Just one thing."],[303,369,"Yes?"],[433,582,"I'm not your sugar baby anymore."],[653,784,"You want to sleep with me?"],[870,947,"Just say it."],[1000,1094,"You know what I want to hear,"],[1094,1207,"even if you lied to me."],[1424,1489,"I lied?"],[1598,1686,"That's what you think?"],[1991,2080,"The world's richest man"],[2080,2216,"plays sugar baby for fun."],[2238,2335,"Then flips the switch like"],[2335,2468,"I'm the one playing games?"],[2692,2813,"I didn't lie."],[2992,3171,"You just didn't ask the right questions."],[3279,3353,"You know what?"],[3363,3446,"Forget it!"],[3500,3716,"Not sleeping with you isn't exactly a tragedy."],[3733,3876,"There are other men on this planet."],[4024,4200,"Are you sure about this?"],[4287,4424,"Do you know how many women"],[4474,4605,"and men would kill"],[4605,4705,"to be in this position?"],[4751,4867,"Then go find one of them!"],[4941,5064,"Just don't come looking for me."],[5642,5753,"Damn it, Catherine!"],[6413,6459,"Matt,"],[6553,6674,"pull out every cent we invested"],[6674,6829,"in Wilson's corporation."],[6863,6955,"Let's see how long she lasts"],[6955,7048,"before crawling back."]],"13":[[690,877,"William, what's wrong?"],[1114,1341,"If this is about Amy and Peter, I'm sorry."],[1341,1481,"No, no, Catherine."],[1508,1714,"I'm not here to blame you."],[1735,1883,"I came to apologize."],[1978,2059,"Apologize?"],[2168,2360,"I mean, I don't know"],[2360,2576,"what went wrong between you and Peter."],[2649,2759,"But I know"],[2802,2921,"it wasn't your fault."],[3016,3142,"If I could choose,"],[3193,3437,"I would want you as my daughter."],[3593,3799,"You are the one working hard for this family,"],[3840,4054,"and we appreciate that."],[4230,4404,"When I had nothing,"],[4454,4564,"you helped me."],[4701,4821,"That already made us family."],[5031,5094,"So,"],[5265,5422,"I don't mean to burden you,"],[5468,5505,"but..."],[5578,5749,"would you know why the Hartford family"],[5749,5917,"suddenly blacklisted us?"],[6099,6196,"The Hartfords?"],[6269,6420,"As in Adam Hartford?"],[6433,6570,"Yes, yes."],[6593,6849,"I thought that gala was going to open doors,"],[6920,7066,"but we just got notice."],[7150,7340,"Hartford Enterprise is"],[7340,7556,"pulling all current investments"],[7556,7629,"from our business."],[7640,7691,"What?"],[7784,7884,"That serious?"],[8001,8088,"It's OK."],[8164,8291,"One way or another,"],[8408,8518,"we'll figure it out."],[10010,10217,"Didn't expect to see you again so soon."]],"14":[[490,657,"Leave the Wilsons alone, Adam."],[750,853,"William's not well."],[947,1081,"Don't drag him into this."],[1081,1158,"He's old."],[1324,1545,"Relax, I'm not after the old man."],[1651,1730,"I'm after you."],[2560,2642,"You know what I want."],[2902,3079,"If it'll save the Wilson company,"],[3139,3268,"I'll do whatever you want."],[3830,3889,"Take it off."],[4037,4094,"What?"],[4220,4376,"I used to be you're sugar baby for years."],[4380,4419,"Now,"],[4481,4633,"it's your turn to return the favor."],[4801,5003,"Adam, people can see us."],[5081,5289,"Please, don't."],[5330,5400,"Alright."],[5530,5640,"Then, get out!"],[5932,6004,"Wait!"],[6315,6370,"Fine."],[6566,6673,"I'll do it!"],[9750,9826,"Are you happy now?"]],"15":[[1354,1473,"You've got your strip game."],[1624,1748,"I hope you keep your promise."],[2140,2244,"I lost interest."],[2298,2352,"Get out!"],[2569,2645,"Don't forget,"],[2696,2850,"Wilson's survival was the deal."],[2929,3065,"I said get out!"],[4531,4645,"I can't believe she went that far"],[4645,4763,"for that asshole."],[5919,6012,"I've resumed the investments"],[6012,6100,"on Wilson Corp."],[6169,6266,"You owe me a thank you."],[6346,6569,"My sincerest gratitude, Mr. Hartford."],[6593,6733,"Hope we never see each other again."],[6813,6997,"I have a feeling that you'll come back,"],[6997,7102,"begging for my help again."],[7177,7304,"It's never gonna happen."],[7784,7850,"I have a feeling"],[7850,7951,"we'll see each other again soon."],[9099,9178,"Alright, everyone."],[9189,9406,"We have a new colleague joining us today."],[9469,9536,"Come on in!"],[9906,9958,"Amy?"]],"16":[[76,305,"Hi everyone, I'm Amy Foster."],[413,690,"And as a welcome gift, Amy will be taking on"],[690,834,"this issue's cover story."],[1044,1161,"You said I was doing the cover."],[1324,1519,"Catherine, don't be selfish."],[1604,1828,"Amy has exclusive access to the nation's"],[1828,2038,"richest man, Adam Hartford."],[2038,2162,"Mm-hmm."],[2162,2411,"That interview alone is cover worthy."],[2452,2728,"Adam Hartford, Amy? Seriously?"],[2782,2857,"Yeah."],[2982,3162,"Catherine, stay humble."],[3416,3638,"Amy was highly recommended by the board."],[3717,3935,"Don't question your colleagues' qualifications."],[4037,4182,"Don't be a bitter loser, Cath."],[4320,4467,"As far as I know, you've never done"],[4467,4655,"a serious interview in your life."],[4655,4820,"You're not qualified for this."],[4921,5188,"Are you challenging our bosses' decision?"],[5234,5363,"I'm challenging you!"],[5568,5808,"Seems like your staff aren't very welcoming."],[6032,6303,"Catherine, you've been here a long time."],[6393,6527,"I don't want this to get messy."],[6527,6652,"I don't mind messy."],[6700,6889,"All I care about is fair play."],[6990,7042,"Fine."],[7160,7389,"You want the cover? Prove it."],[7494,7728,"But if you lose, Catherine, what then?"],[7875,8035,"I'll apologize."],[8081,8196,"That's it?"],[8271,8418,"You wanted fair play."],[8418,8540,"Don't stop now."],[8660,8791,"What do you want?"],[9009,9083,"You fail."],[9222,9352,"You leave the company."],[9650,9743,"Deal."]],"17":[[704,806,"Let me guess."],[880,1003,"Came here to see me?"],[1107,1269,"Fine. You win again."],[1344,1423,"Happy?"],[1541,1614,"Ecstatic!"],[2886,3016,"You humiliated me once!"],[3033,3099,"We're done."],[3293,3450,"Then, what are you doing here?"],[3526,3604,"I..."],[3763,4017,"because I need you for an exclusive interview,"],[4030,4165,"arrogant bastard."],[4381,4592,"Miss Rogers, that's barely the tone"],[4592,4734,"of someone asking for a favor."],[5118,5205,"What do you want?"],[5795,5949,"The same thing I gave you in bed?"],[6149,6331,"I want you to return the favor."],[6469,6552,"We're in a car."],[6629,6747,"I'm counting down."],[6923,6991,"Three..."],[7097,7168,"two..."],[7377,7425,"one."],[7787,7893,"Where's Catherine?"],[7907,8064,"She was just out here."],[8101,8176,"I'll call her."],[8460,8537,"Shit."],[8840,8907,"Did you hear that?"],[9169,9263,"Catherine?"],[9312,9419,"Is she in the car?"],[10333,10473,"Imagine the face of your co-workers"],[10473,10560,"when they find out you're"],[10560,10725,"making out with Adam Hartford."],[10830,10908,"Wait, no!"]],"18":[[680,796,"Oh my God, no!"],[827,939,"She's not here."],[990,1095,"People are so"],[1095,1246,"thirsty, God!"],[1544,1578,"Asshole!"],[1955,2042,"No wonder you kept me"],[2042,2145,"around for a year."],[2202,2309,"Being on the receiving end"],[2309,2416,"has its own perks."],[2472,2581,"You owe me that interview now."],[2782,2863,"Tomorrow morning,"],[2909,3114,"Long Island Golf Club, 8am."],[3183,3289,"You better show up!"],[4354,4441,"I'm here."],[4481,4546,"Where are you?"],[4901,4984,"Go to the front desk,"],[4984,5065,"I'll tell you what to say."],[5305,5349,"Hello, ma'am,"],[5349,5438,"how can I help you today?"],[5632,5718,"I'm at the desk."],[5849,5925,"Tell them you're..."],[5982,6126,"Mr. Hartford's woman."],[6266,6346,"No, what?"],[6346,6430,"You gotta be kidding!"],[6463,6550,"Only family of members"],[6550,6612,"are allowed,"],[6653,6719,"so,"],[6736,6890,"admit you're mine,"],[6963,7103,"or miss your shot at the interview."]],"19":[[1097,1225,"Miss Rogers, finally!"],[1321,1405,"Nice seeing you again."],[1528,1650,"So, how does it feel"],[1650,1716,"being my woman?"],[1791,1881,"Actually,"],[2055,2147,"I figured being a member"],[2147,2233,"was a much better deal"],[2233,2379,"than being your property."],[2479,2570,"So, Mr. Hartford,"],[2615,2755,"should we get this interview started?"],[3166,3342,"You really do have a few tricks."],[3453,3532,"It's a shame, though."],[3600,3755,"Who said you'll be my only option?"],[4401,4541,"You see, Catherine."],[4601,4691,"I'm a businessman."],[4754,4892,"I always have two cards."]],"20":[[100,216,"You're still playing games with me?"],[263,549,"No. I'm just offering you a chance."],[670,1022,"Mr. Hartford, have you made your pick?"],[1207,1413,"Since we're on a golf course,"],[1508,1628,"why not play for it?"],[1708,1832,"Winner gets the interview."],[2078,2195,"Mr. Hartford,"],[2272,2425,"why don't we switch to a sport"],[2425,2581,"I'm much better at?"],[2655,2740,"In bed!"],[2869,2937,"Get off me."],[3139,3250,"I'm not interested."],[3536,3600,"Game on?"],[4197,4375,"Golf's kind of my thing, swetheart."],[4431,4544,"You're toast."],[4547,4779,"Really? I thought acting was your real talent."],[5562,5672,"Wow, did you see that?"],[5715,5832,"Textbook perfect!"]],"21":[[23,210,"Oh my god,"],[210,403,"I'm useless at this."],[447,579,"Do I really have to learn?"],[620,837,"It may come in handy one day."],[920,976,"Fine."],[1061,1174,"Then, teach me."],[1340,1409,"Seriously, Adam,"],[1409,1551,"do you have to know everything?"],[1651,1796,"I'm a man of many talents."],[1868,2039,"Oh yes, many."],[2315,2433,"Alright, focus."],[2572,2693,"Relax your shoulders."],[4177,4411,"Looking back, there were clues."],[4424,4683,"It was obvious he wasn't just some sugar baby."],[4691,4914,"I just never wanted to see it."],[4951,5044,"Congrats!"],[5125,5216,"Interview Granted."],[5342,5388,"But,"],[5468,5595,"I pick the location."],[5835,5959,"Oh, Miss Foster,"],[6002,6146,"we have things to discuss."],[6152,6304,"You stay here and practice."],[6332,6466,"You'll need it."],[7784,7927,"I don't think this qualifies"],[7927,8109,"as a professional setting."],[8214,8407,"You said I can pick the location."],[8468,8651,"I just prefer watching you from the bed."],[8831,8885,"Mm."],[8975,9067,"So do I."]],"22":[[603,747,"If you want my heart,"],[800,980,"pleasing me isn't enough."],[1114,1418,"You need to keep me happy all the time."],[1808,1858,"And"],[1921,2024,"what do you want me to do?"],[2085,2166,"Keep investing in your"],[2166,2276,"husband's family business?"],[2719,2883,"You're just stringing me along,"],[2883,3020,"so I keep chasing you."],[3020,3107,"You're using me."],[3156,3278,"Believe whatever you want!"],[3980,4183,"Stop interfering with my life, Adam."],[4254,4355,"I don't wanna hate you."],[6580,6768,"Catherine, wait!"],[6916,6995,"Fuck!"],[8051,8178,"What the hell are you doing here?"],[8288,8446,"I should've changed the passcode."],[8446,8492,"What?"],[8588,8794,"Can't a man drop by and visit his legal wife?"],[8818,8975,"William is the only reason"],[8975,9133,"I haven't filed the paperwork."],[9149,9262,"Don't push your luck!"],[9275,9548,"Why can't you just talk like a normal woman?"],[9596,9664,"How about,"],[9699,9789,"hi husband,"],[9816,9923,"how was your day?"],[10003,10229,"Maybe try being someone worth talking to."],[10243,10427,"I felt bad for you."],[10523,10674,"Don't think that you've got it all."],[10697,10819,"Because without this marriage, what are you?"],[10819,11004,"Some washed-up woman that nobody wants?"],[11067,11244,"Don't touch me ever again!"]],"23":[[170,402,"Happy birthday, my dear!"],[440,591,"Thank you for coming, William!"],[600,808,"I'm pleasantly surprised."],[914,1014,"I have to say,"],[1064,1263,"I didn't expect to see Peter here today."],[1381,1479,"But at least we know"],[1479,1661,"he remembers your birthday after all."],[1958,2055,"I got a call."],[2102,2215,"You two catch up."],[3249,3425,"Let's just eat and get this over with, okay?"],[3483,3523,"Here."],[3660,3817,"I got this custom ordered for you."],[3863,3953,"Happy now?"],[4200,4264,"Ta-da."],[4364,4475,"It has nuts."],[4664,4743,"So?"],[4811,5002,"Did you forget I'm allergic?"],[5058,5201,"Oh god, you are so difficult."],[5201,5265,"Can't you just..."],[5352,5449,"I don't know, deal with it?"],[5525,5602,"Deal with it?"],[5602,5655,"Yes!"],[5702,5748,"What?"],[5755,5924,"You want me to spend my birthday in the ER?"],[6339,6413,"Look."],[6553,6673,"I don't want to fight."],[6743,7007,"Either eat it or throw it out. I don't care."],[7007,7163,"Look, if you don't take a bite,"],[7170,7309,"you're going to disappoint my dad."],[7400,7607,"You're the disappointment, not me!"],[8158,8231,"Come out."],[8281,8378,"I'm waiting outside,"],[8378,8515,"even if you don't want to see me."],[8598,8715,"I do want to."],[8792,8881,"Desperately!"],[9055,9112,"Hey!"],[9195,9269,"Hello?"],[9312,9433,"Where are you going?"],[10246,10323,"Oh god!"],[10343,10427,"Another cake."],[10463,10549,"Relax."],[10583,10677,"No nuts,"],[10727,11035,"no strawberries, mangoes, or kiwis."],[11191,11281,"I know you hate those."],[11838,11918,"Wait..."],[11955,12065,"This cake!"]],"24":[[50,262,"It tastes familiar."],[326,445,"I've had this before!"],[1047,1253,"A cake. Really?"],[1388,1508,"It's your birthday, isn't it?"],[1618,1691,"How'd you know?"],[1855,2145,"I saw it on your ID when we checked in."],[2228,2396,"You really are a great sugar baby."],[2435,2488,"Taste it!"],[3413,3496,"That's amazing!"],[3600,3648,"Where's it from?"],[3777,3930,"Just around the corner."],[4050,4123,"What corner?"],[4160,4206,"What shop?"],[4260,4446,"Just the corner. Eat it."],[5078,5179,"I went looking."],[5265,5465,"I checked every bakery by the hotel,"],[5498,5663,"and none of them make this cake."],[5863,6036,"You made it, didn't you?"],[6132,6325,"You knew I was allergic to nuts."],[6396,6553,"You knew everything I like,"],[6553,6722,"everything I hate."],[6746,6886,"That's just me"],[6886,7084,"being a very qualified sugar baby."],[7233,7643,"But you're not anymore, are you?"],[7751,7981,"So tell me, are you in love with me?"],[8110,8171,"Catherine!"]],"25":[[407,550,"Catherine, really?"],[570,664,"I can explain."],[677,880,"Mr. Harford mentioned he might drop by."],[927,1031,"Why didn't you invite him in?"],[1314,1654,"Mr. Harford, are you and Catherine close?"],[1668,1761,"Are you friends?"],[1781,1927,"Yes, we are, actually."],[1995,2072,"We're friends with bene-"],[2185,2258,"I mean,"],[2258,2352,"we're friends with"],[2352,2453,"best friends potential."],[2535,2716,"Well, I'm just impressed"],[2716,2865,"Catherine made such a connection."],[3366,3460,"Stop it!"],[3773,3914,"What exactly is going on between you two?"],[4024,4171,"I'm interviewing Mr. Harford"],[4171,4295,"for our next issue."],[4317,4437,"He's been very"],[4454,4559,"cooperative."],[4874,4932,"Really?"],[5048,5207,"Since when are you so well-connected?"],[5241,5379,"So in the circle."],[5418,5554,"Oh, be polite, Peter."],[5575,5773,"If you worked half as hard as Catherine,"],[5795,5939,"I would trust you with the company."],[6040,6080,"Sure."],[6172,6259,"As always,"],[6286,6393,"I'm the useless one!"],[6436,6486,"Got it!"],[7210,7347,"Catherine, what the hell are you doing?"]],"26":[[53,173,"Catherine, what the hell are you doing?"],[560,779,"Did you just step on Mr. Hartford's foot?"],[807,977,"I, because, um-"],[977,1224,"Just because the table is too low,"],[1224,1447,"my leg ended up under her's accidentally."],[1541,1677,"I deeply apologize."],[1798,1937,"I sincerely apologize"],[1937,2097,"to you and your husband."],[2185,2355,"I didn't upset you, did I?"],[2495,2542,"Of course not."],[3807,3878,"Are you insane?"],[3907,3989,"Get out of my room."],[4074,4134,"Yeah,"],[4184,4260,"insane for not"],[4260,4414,"sleeping with you earlier."],[4728,4804,"Come on."],[4901,5001,"I saved us back here."],[5045,5098,"How about"],[5205,5328,"a little reward?"],[5700,5749,"Catherine?"]],"27":[[120,194,"Catherine?"],[663,726,"Catherine?"],[1024,1075,"One kiss."],[1154,1301,"Or I'll make sure I give your husband a show"],[1301,1399,"he will never forget."],[1931,2025,"Where the hell is she?"],[2205,2273,"Catherine!"],[3023,3139,"Why do you look so disgusted?"],[3139,3246,"It was just a kiss."],[3303,3422,"I'm not in the mood tonight."],[3486,3557,"What do you want?"],[3640,3765,"I played charming."],[3797,3935,"I played nice."],[3970,4030,"What else?"],[4030,4169,"Why do you still act so cold?"],[4310,4495,"We had fun, Adam."],[4611,4679,"But that doesn't mean"],[4679,4791,"I owe you anything else."],[4854,4924,"You should go."],[6136,6292,"Thank you so much for your hospitality."],[6302,6444,"You're too kind, Mr. Hartford."],[7063,7189,"Catherine, wait."],[7243,7320,"About the interview,"],[7320,7421,"I forgot to tell you something."],[7774,7895,"What is it?"]],"28":[[253,410,"Relax, I angled it perfectly,"],[410,490,"they didn't see anything."],[580,666,"Okay, Mr. Hartford,"],[666,822,"I got your message loud and clear."],[970,1147,"I'll be waiting for the day you kiss me back."],[1177,1354,"Keep waiting, asshole."],[1594,1668,"It's getting late."],[1811,1905,"Get back inside."],[2055,2318,"Don't be pulled into his games, Catherine!"],[4401,4574,"I knew I would find you here."],[5225,5465,"You hate your birthday because"],[5465,5608,"it's the day before your father's death,"],[5608,5672,"isn't it?"],[5779,5916,"So you did your research?"],[5942,6053,"Not research,"],[6076,6190,"I just"],[6199,6289,"wanted to get to know you better."],[6373,6483,"How would you know where I am?"],[6716,6823,"There's no one in this world"],[6873,6966,"who knows you better than I do."]],"29":[[176,359,"Stop playing games, Adam!"],[437,570,"I'm not gonna fall for you."],[740,858,"I'm not gonna fall for anyone."],[1154,1356,"Haven't I been good enough to you?"],[1935,2234,"My father's will said I'd only inherit"],[2234,2352,"if I married Peter."],[2515,2741,"He thought Peter was the best man for me."],[2829,3053,"Look how that turned out."],[3199,3386,"Peter betrayed me,"],[3473,3590,"my father's gone,"],[3717,3807,"and me?"],[4137,4210,"At least he'll never know"],[4210,4487,"how miserable I turned out."],[4624,4871,"I am done believing in men."],[5328,5535,"Come on, let me take your home."],[5635,5712,"No,"],[5759,5865,"I'm not going anywhere with you."],[5972,6029,"For all I know,"],[6029,6156,"you'll take me somewhere insane."],[6276,6418,"I'd rather stand here in the rain."],[7103,7133,"Fine."],[7300,7402,"Then I'll stand here with you."],[7891,8098,"Can I really trust you, Adam Hartford?"]],"30":[[1164,1354,"Mr. Harford's ideal type?"],[1354,1498,"Who wrote this trash?"],[1895,2144,"I happen to like those questions."],[2225,2312,"You wrote this."],[2602,2709,"You agreed to the interview,"],[2709,2855,"at least try to act professional."],[2916,3046,"I've been nothing but professional."],[3096,3183,"I promise I'll answer"],[3183,3364,"all questions without limitations."],[3400,3582,"You're disrupting my work!"],[3780,3883,"Honestly, Catherine,"],[3920,4027,"Mr. Harford's been the best"],[4027,4184,"interviewee we've ever had."],[4471,4601,"You look very unhappy with"],[4601,4739,"the ideal type questions."],[4851,4891,"Why?"],[5045,5188,"Is it becaust it will"],[5188,5350,"mess with your dating prospects?"],[5515,5782,"Or, are you scared to find out the answer?"]],"31":[[43,123,"We're ready."],[440,544,"Ready when you are, Catherine."],[630,713,"I was born ready."],[1471,1559,"Now, for a few"],[1559,1765,"light-hearted questions to wrap up."],[1845,2022,"Mr. Hartford, what's your favorite color?"],[2235,2322,"The color of your suit."],[2422,2682,"Mr. Hartford's humor never disappoints."],[2799,3143,"And your ideal type?"],[3333,3418,"Well..."],[3626,3695,"Let's see."],[3940,4031,"Tall,"],[4118,4242,"dark hair,"],[4356,4486,"brown eyes,"],[4616,4818,"and very proud."],[5125,5262,"Isn't that... Catherine?"],[5398,5568,"Well... you know what?"],[5635,5750,"Looks like Ms. Rogers"],[5750,5903,"fits the descriptions perfectly."],[6009,6087,"Maybe you're my type."]],"32":[[76,283,"Just kidding, I have"],[283,474,"utmost respect for Miss Rogers."],[800,877,"You know,"],[960,1089,"I want someone fun."],[1191,1394,"Someone I can go on wild adventures with."],[1414,1501,"Miss Rogers."],[1588,1793,"We can't go wild, can we?"],[3019,3290,"Mr. Hartford, it was a pleasure."],[3373,3489,"Thank you for your time."],[3489,3663,"Let's not do it again."],[4204,4410,"Leaving so soon?"],[4544,4694,"You can't go wild, right?"],[5075,5245,"I've seen your wild side."],[5335,5528,"Even in a business suit and heels,"],[5759,5908,"you're exactly my type."]],"33":[[677,737,"Mr. Hartford?"],[867,991,"I still have equipment in there."],[1021,1125,"Mind opening the door?"],[1644,1715,"Ignore him."],[1828,1955,"Just continue where we left."],[2058,2202,"We have to let him in."],[2365,2600,"Besides, he's my type."],[2759,2816,"What?"],[2846,2929,"I don't know,"],[3123,3389,"beard, tattoos,"],[3416,3578,"carrying heavy stuff around."],[3660,3766,"You know, that's sexy!"],[4080,4227,"I want to go out with him."],[5188,5268,"Adam Hartford is even"],[5268,5397,"more charming in person."],[5415,5556,"I think I'm in love."],[5598,5645,"Really?"],[5652,5715,"He looked like he was"],[5715,5842,"going to bite my head off."],[5915,6006,"He glared at me like I"],[6006,6185,"broke his property or something."],[6229,6342,"Not his property."]],"34":[[380,570,"He's so good looking."],[610,747,"And you're so close with him."],[747,864,"I'm jealous."],[880,980,"This interview went"],[980,1121,"so much smoother than expected."],[1184,1277,"All thanks to Catherine!"],[1798,2000,"Footage and final transcripts are on this."],[2022,2288,"Back it up and please don't lose it."],[2652,2815,"If I can't have that interview,"],[2869,3005,"neither can she."],[3847,3981,"You idiots!"],[3987,4199,"You lost the interview footage?"],[4234,4370,"Unbelievable!"],[4391,4549,"Boss, please."],[4587,4739,"Don't blame the innocents."],[4838,5027,"Catherine's the project owner."],[5035,5215,"I'm sure she'll take care of it."],[5246,5331,"Right?"],[5608,5768,"If this isn't fixed,"],[5802,5879,"Catherine,"],[5962,6069,"pack your things."],[6309,6469,"Take your team with you!"],[7307,7654,"Catherine, could you maybe ask Mr. Hartford"],[7654,7833,"if he'd be willing to reshoot?"],[7984,8100,"We're not exactly"],[8100,8234,"on speaking terms right now."],[8748,8852,"Catherine, please."],[9000,9163,"I can't afford to lose this job."]],"35":[[23,289,"Oh my god, it's so sunny out!"],[357,487,"At least it's a beautiful day."],[510,732,"Um, oh my god."],[780,926,"Is that Mr. Hartford?"],[1041,1256,"He actually showed up!"],[1338,1434,"Lovely seeing you all."],[1561,1603,"Hi."],[1675,1737,"Shall we?"],[2962,3176,"Looks like you're back in my arms, Catherine."],[3430,3575,"You know what comes next?"]],"36":[[43,201,"Fine."],[230,337,"Whatever you want."],[890,1048,"As much as I want to"],[1048,1178,"have you naked over dinner,"],[1271,1446,"I don't think restaurants allow nudity."],[1484,1705,"Wait, we're not going to a hotel?"],[1965,2045,"I mean,"],[2195,2339,"we can if you want to."],[2392,2555,"Uh, no."],[2555,2652,"The restaurant's good."],[3466,3523,"Try it."],[3603,3674,"It's good."],[3767,3897,"Is he trying to get me drunk?"],[3973,4078,"Not your type of food?"],[4184,4374,"Or did he drug the meal?"],[4684,4800,"Why'd you really bring me here?"],[4888,5000,"What's the catch?"],[5081,5157,"Catch?"],[5398,5593,"We've done everything together"],[5593,5819,"other than sit down for a real meal."],[5905,5962,"Tonight,"],[6019,6167,"I just wanted a dinner with you."]],"37":[[100,170,"That's it?"],[250,344,"Just dinner."],[400,499,"And you'll do the interview."],[750,816,"Yeah."],[850,926,"Just dinner."],[1004,1080,"That's all."],[2389,2555,"I thought you said you were just getting ready."],[2682,2837,"How much longer do you need?"],[2882,2982,"Coming!"]],"38":[[657,850,"It's been a while since you touched me."],[1137,1247,"Especially down there."],[1484,1867,"You should really be wearing pants."],[2238,2280,"Alright."],[2489,2678,"If you're that desperate for attention,"],[2678,2758,"you'll get it!"],[3046,3216,"It's my job as a journalist"],[3226,3473,"to show the world who you truly are."],[3650,3847,"Your lens cap's still on."],[4651,4875,"Let's skip the questions you've already answered,"],[4878,5011,"like your type."],[5241,5454,"Then ask me something you haven't before."],[5542,5707,"Like if I have a girlfriend or not."],[5829,5867,"Fine."],[5909,6114,"Mr. Hartford, do you have a girlfriend?"],[6152,6225,"Nope."],[6296,6384,"No girlfriend."],[6519,6560,"But"],[6613,6713,"I do have someone in mind"],[6713,6824,"who I want to marry."]],"39":[[36,313,"I first saw her in high school."],[337,569,"It was like love at first sight."],[997,1150,"Look at what she's wearing."],[1244,1482,"You're an orphan. Nobody wants you."],[1528,1678,"I warned you, back off!"],[1698,1867,"Psycho, your parents are dead."],[1898,2015,"Who's gonna save you?"],[2098,2298,"Look around. You're outnumbered."],[2349,2499,"Don't blame me when you regret it."],[2679,2855,"She's gonna get herself hurt!"]],"40":[[216,313,"You wanna piss me too?"],[337,460,"No, I just..."],[477,517,"Watch out!"],[717,912,"Seriously? A brick?"],[1061,1203,"You hit someone who wasn't even in the fight."],[1491,1561,"Are you okay?"],[1848,1917,"Thank you."],[1995,2061,"What's your name?"],[2288,2382,"There you are!"],[2459,2558,"What are you doing?"],[2558,2705,"My dad's been looking everywhere for you."],[2769,2929,"Come on, let's go!"],[2976,3053,"My bag!"],[3116,3263,"Every time! Let's go!"],[3263,3381,"- Okay. - Jesus!"],[3526,3796,"I've been looking for her ever since."],[3920,4059,"To me, she's the only person"],[4080,4180,"who I want to marry."]],"41":[[250,475,"I'm not interested in your romantic history."],[760,933,"Thank you for the interview, Mr. Hartford."],[964,1042,"Goodbye."],[1654,1815,"I've waited for you all these years."],[2168,2265,"I'm not gonna let him"],[2265,2379,"take you away from me again."],[3390,3533,"You're back in the country?"],[3650,3770,"Alright, I'll come get you."],[4461,4611,"A girlfriend?"],[4641,4729,"Seriously?"],[4788,4889,"Doesn't matter."],[4931,5033,"What do I care?"]],"42":[[56,233,"Adam Hartford set to marry"],[233,395,"British heiress Diana Vaughn."],[530,648,"Is this for real?"],[1031,1231,"And look! Look at this picture."],[1311,1378,"Diana,"],[1414,1571,"she kind of looks like Catherine, right?"],[1574,1699,"Oh, my God!"],[1898,2018,"So when Mr. Hartford's"],[2018,2175,"been talking about his type,"],[2225,2394,"he really means Diana."],[2622,2666,"Oh."],[2826,2879,"Catherine,"],[2932,3080,"you're pretty close to him, right?"],[3146,3275,"Did you know anything about this?"],[3350,3420,"How would I know?"],[3520,3606,"I'm not close to him"],[3697,3776,"at all!"],[5068,5126,"What?"],[5165,5247,"Are you free tonight?"],[5265,5495,"There is someone I'd like for you to meet-"],[5495,5542,"Nope."],[5608,5679,"Just hearing your voice"],[5679,5834,"makes me lose my appetite."],[5875,5978,"Enjoy your fucking dinner!"],[6676,6792,"Oh, is she coming?"],[6803,6938,"I'd really love to meet the girl"],[6938,7043,"you're so in love with."]],"43":[[216,276,"She's mad."],[363,420,"Again."],[613,744,"I'm just a sugar baby, right?"],[767,953,"Can't exactly demand much."],[1031,1161,"Seriously?"],[1171,1281,"It's been years"],[1281,1427,"and you still haven't won her over?"],[1560,1680,"Adam bloody Hartford,"],[1680,1885,"you've wasted that face on that attitude!"],[2422,2672,"You clearly don't know how to pursue a woman."],[2722,2906,"Lucky for you, I'm back now."],[2959,3062,"I'll win her over."],[5528,5679,"Hi, Catherine."],[5685,5825,"I've heard so much about you."],[6046,6176,"Wait, you're..."],[6176,6232,"Diana,"],[6249,6407,"Adam's old classmate from high school."],[6519,6675,"High school classmate?"],[6743,7038,"I first saw her in high school."],[7043,7251,"It was like love at first sight."],[7464,7620,"So the girl Adam talked about..."],[7674,7774,"that was you?"]],"44":[[126,343,"Wait, Adam's actually mentioned me?"],[433,563,"I guess that boy does have a conscience."],[563,677,"I thought he forgot me already."],[760,901,"He could never forget you."],[972,1024,"Ever."],[1331,1398,"Anyway,"],[1424,1698,"I am just so excited to meet you."],[1698,1861,"Adam's terrible at communicating,"],[1861,2005,"so I figured I would just come and tell you-"],[2085,2172,"I already know."],[2252,2397,"I know cheating is disgusting."],[2455,2649,"Fine. I'm an idiot."],[2762,2979,"But rest assured, I'll never have"],[2979,3089,"anything to do with him."],[3100,3168,"Ever again!"],[3340,3420,"Wait!"],[3550,3673,"What was that?"],[5101,5225,"Catherine,"],[5225,5402,"what the hell did you do to yourself?"],[5435,5561,"Don't touch me!"],[5585,5656,"What?"],[5745,5809,"What do you mean?"],[5839,5965,"Do whatever you want."],[6029,6132,"I don't care anymore."],[6289,6530,"I will never, ever love you."],[6833,6904,"We're done!"]],"45":[[40,172,"Done?"],[433,590,"Catherine, I'll destroy the Wilsons,"],[590,724,"and then you will go down with them."],[1004,1164,"Sober up before you make a decision."],[1351,1526,"I've never been more sober."],[1811,2046,"And if you do that, I'll disappear."],[2078,2181,"And I swear,"],[2181,2390,"you'll never see me again."],[3660,3730,"She's not home?"],[3827,3954,"She's not at work either."],[4140,4183,"Fine."],[4317,4471,"Pull every cent out of Wilson Corp."],[4644,4854,"Sir, are you sure?"],[4921,4977,"Do it!"],[5081,5199,"I want to see how long she can hide."],[5225,5363,"Are you out of your mind?"],[5439,5544,"Tell me,"],[5550,5668,"do you love Catherine,"],[5668,5833,"or do you just love your stupid pride?"],[6266,6400,"These vultures turned a greeting"],[6400,6542,"into a scandal."],[6542,6721,"No wonder she's furious!"],[6786,6973,"You pushed her away, Adam."],[7040,7165,"Is that what you really want?"]],"46":[[580,717,"I messed up, Dad."],[887,1147,"Cried over a man, again."],[1518,1644,"Don't worry."],[1705,1986,"I won't give anyone another chance."],[2539,2619,"What are you doing here?"],[2782,2948,"I came to find you."],[3213,3423,"You have impressive stamina, Mr. Hartford."],[3496,3613,"It must be exhausting"],[3613,3761,"keeping all your women happy."],[4040,4260,"And if you love your girlfriend so much,"],[4260,4432,"maybe stop cheating on her."],[4511,4634,"I'm not Amy!"],[4647,4761,"I never will be."],[4908,5099,"This isn't cheating."],[5258,5411,"Because the woman I'm in love with..."],[5628,5709,"is you."]],"47":[[80,186,"Stop that!"],[240,324,"What about Diana?"],[333,465,"She just returned."],[540,709,"I am not stepping between you two."],[747,1040,"She is not the one who I was talking about."],[1171,1290,"She doesn't even like men."],[1341,1501,"She told me she'll help me win you back,"],[1501,1739,"but made everything worse."],[1811,2007,"What game are you playing, Adam?"],[2035,2158,"Stop lying to me."],[2212,2435,"I'm not lying to you, Catherine."],[2435,2726,"I swear, everything I said is true."],[2916,3008,"That's still a lie."],[3163,3239,"Catherine,"],[3380,3543,"I've been in love with you"],[3560,3713,"longer than you can think."],[3933,4227,"I've been in love with you for six years."],[4371,4479,"I don't want to hear this."],[4564,4647,"You should go."],[4908,5091,"Catherine, I'm here."],[5145,5218,"I'm not leaving."],[5382,5655,"No pride, no excuses."],[5865,5992,"I just came here to tell you"],[6106,6162,"that"],[6529,6596,"I'm"],[6659,6770,"deeply,"],[6893,7007,"hopelessly,"],[7173,7320,"helplessly in love"],[7394,7487,"with you."],[7624,7796,"I love you, Catherine Rogers."]],"48":[[56,193,"Catherine, my dad asked me to-"],[370,410,"Catherine?"],[1975,2062,"She cheated."],[2298,2428,"With Adam Hartford!"],[3283,3326,"Dad?"],[3460,3613,"There's something you gonna need to know."],[5101,5268,"How could you betray me?"],[5275,5393,"Peter, that's enough."],[5403,5579,"Let her sit, then talk."],[5625,5728,"William, maybe Peter and I"],[5728,5851,"should talk outside."],[5851,6048,"No, no, no, no, no. We should talk here."],[6060,6159,"So tell me,"],[6216,6363,"how long have you been fucking Adam Hartford?"],[6363,6527,"Don't say that in front of William!"],[6549,6690,"No, no, no, let's say it."],[6713,6853,"You shameless whore!"],[7270,7348,"Touch her,"],[7370,7532,"and I'll break your fucking arm!"]],"49":[[330,459,"You invited him into your home?"],[720,811,"This is the woman that you"],[811,1000,"think is the ideal wife, Dad?"],[1000,1137,"That's enough, Peter."],[1348,1401,"Catherine,"],[1484,1611,"are you and Mr. Hartford"],[1668,1729,"together?"],[1745,1791,"William..."],[1951,2122,"Adam Hartford is my boyfriend."],[2185,2252,"I love him."],[2325,2412,"Mr. Wilson,"],[2422,2635,"Catherine has been a victim of this marriage."],[2732,2792,"Peter and Amy have-"],[2792,2865,"I know."],[3013,3070,"I know."],[3166,3270,"Catherine, I'm sorry."],[3307,3565,"I came here today to end my mistake."]],"50":[[100,377,"I knew Peter had been distracted."],[467,583,"He's not a good husband."],[650,902,"I checked his records, his phone,"],[947,1029,"and that's how I found out"],[1029,1141,"about Amy's pregnancy,"],[1141,1314,"though far too late."],[1344,1575,"And I had broken a promise to your father"],[1621,1738,"to always protect you."],[1831,2007,"You took me in when I had no one."],[2125,2316,"It's more than I could have ever asked for."],[2422,2508,"Wait, wait."],[2592,2729,"Dad, you checked in on me?"],[2742,2838,"Peter, shut up!"],[2892,3088,"You have humiliated this family!"],[3146,3267,"Can't you see that?"],[3416,3543,"Mr. Hartford has shown"],[3543,3738,"nothing but respect to this family."],[3850,3936,"Grow up!"],[4100,4215,"Mr. Hartford,"],[4250,4392,"you seem like a good man."],[4491,4660,"All I have is one request."],[4741,4971,"Is it about the investment?"],[4991,5134,"No, no."],[5201,5307,"I don't care about that."],[5425,5548,"All I wish for..."],[5658,5806,"is for Catherine and you"],[5839,5960,"to be happy together."],[6122,6338,"I support your divorce from Peter."],[6753,6876,"I'm sorry!"],[7090,7149,"Don't be."],[7230,7365,"You deserve happiness."],[7570,7641,"You have my word."],[7817,7966,"I'll make sure I spend the rest of my life"],[7966,8081,"making sure she's happy."]],"51":[[173,244,"Babe!"],[360,465,"Guess what?"],[787,910,"I'm officially divorced!"],[977,1033,"Oh my god."],[1117,1213,"Congratulations!"],[1578,1642,"Well,"],[1701,1829,"in that case,"],[1835,1935,"Catherine..."],[2455,2550,"will you marry me?"],[2599,2742,"You can't just propose"],[2742,2899,"to someone fresh out of a divorce."],[2936,3103,"I've waited all these years."],[3103,3216,"I'm not wasting another second."],[3313,3399,"Just say yes and"],[3399,3540,"we'll get the marriage certificate."],[3700,3786,"Yes!"],[4317,4360,"Good."],[4384,4487,"Because"],[4541,4675,"I already booked the church."],[4858,4967,"You schemer."],[5008,5127,"So this was planned all along?"],[5161,5460,"Not planned. Just... hopeful."],[5515,5634,"I knew you would say yes."],[6429,6607,"I love you, my dear sugar baby."]]}