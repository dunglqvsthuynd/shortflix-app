{"1":[[1448,1501,"Ow..."],[1501,1718,"no, no, no, no, no..."],[2278,2339,"Luna!"],[2379,2439,"Stop!"],[2439,2475,"Lu-"],[2686,2752,"Hey, Jess."],[2776,2826,"Uh, sorry."],[2826,2929,"I'm kind of in the middle of something."],[2929,2982,"What's up?"],[2982,3069,"Oh, nothing."],[3083,3227,"Only the cute guy you were spying on"],[3227,3286,"at the wedding"],[3286,3423,"just asked me where you were."],[3436,3543,"Look, I, I really... I don't..."],[3543,3703,"I don't... I don't have time for this."],[3720,3803,"Your loss."],[3803,3943,"I think he is super rich."],[4150,4194,"Luna!"],[4227,4300,"Bad girl, stop!"],[5208,5255,"Here."],[5378,5485,"I'll go get these cleaned up."],[5929,5995,"While you're at it,"],[6039,6219,"ask the hotel to get me another drink,"],[6269,6349,"something nice."],[6366,6409,"Yeah, sure!"],[7077,7120,"Luna!"],[9709,9973,"Is this the hotel's idea of something nice?"],[10130,10243,"Is this the guy from the wedding?"],[10340,10490,"He is even hotter up close."],[10740,10804,"Come here, you."],[13847,13900,"Shh..."],[15975,16059,"What the hell?"],[16539,16589,"Who are you?"],[17010,17175,"Wait, you can't just leave like this."],[17357,17397,"Ha!"],[17397,17470,"Ow..."],[18007,18068,"Aw..."],[18068,18168,"Should've got a chihuahua."],[18328,18405,"Okay, come on."],[18581,18625,"Hey!"],[19029,19159,"Billionaire banker's kinky night"],[19159,19249,"with secret bridesmaid."],[19319,19409,"That's front-page gold!"]],"2":[[343,537,"Oh my God, I was so worried!"],[807,874,"Sarah,"],[874,944,"listen!"],[944,1037,"We need to talk."],[1087,1217,"Ever since I remarried,"],[1227,1384,"I've decided to sell the apartment."],[1494,1558,"What?"],[1621,1748,"It's my mom's apartment."],[1748,1865,"I won't let you sell it!"],[1875,2092,"Your mother's been dead for years!"],[2148,2285,"It's no longer hers!"],[2302,2519,"She passed half of it down to me!"],[2519,2622,"Give me"],[2622,2716,"that half!"],[2726,2882,"I need the money to support"],[2882,2996,"Anna and Emily."],[3019,3183,"I have a contract for you to sign."],[3263,3406,"Dad, you're impossible."],[3430,3523,"I won't sign it!"],[3650,3710,"Wait!"],[3870,3973,"What happened to its collar?"],[4004,4114,"I just bought it!"],[4164,4277,"It was real leather!"],[4347,4467,"I'll buy you a new one."],[6680,6856,"Investors are freaking out."],[6870,6973,"Board wants a statement."],[7023,7100,"Some..."],[7100,7157,"want you out."],[7480,7640,"Then I guess I'm getting married."],[8034,8224,"You can't run away from this,"],[8224,8324,"Emily Clark."]],"3":[[1204,1417,"I'm here to interview for the CEO's bodyguard."],[1498,1578,"This way, please."],[1578,1691,"With other candidates."],[3997,4187,"No way it's the same Hartman."],[5131,5331,"Same damn Hartman!"],[5382,5445,"Gotta go."],[7597,7664,"Sorry."],[7914,7957,"Bye."],[8101,8201,"This isn't Comic-Con."],[8201,8278,"Get out!"],[8478,8535,"You're hired."]],"4":[[50,143,"You're hired."],[533,617,"Seriously?"],[717,814,"I need a bodyguard"],[814,977,"because the paparazzi took a photo of me"],[977,1027,"last night."],[1027,1234,"Which is exactly why you need protection"],[1234,1311,"from them!"],[1534,1735,"What, so the paparazzi can spot me faster?"],[2015,2128,"She does Muay Thai."],[2188,2238,"She is good."],[2605,2702,"It's in the resumé."],[2742,2809,"Page two."],[3410,3540,"Doesn't he recognize me?"],[4667,4724,"Guess what?"],[4781,4824,"What?"],[4924,5205,"I got a job in HARTMAN Group!"],[5318,5455,"I'm gonna buy out mom's other share."],[5602,5702,"HARTMAN Group?"],[5729,5839,"Why is she so lucky?"],[6106,6192,"Tag is ready."],[6279,6346,"Follow me."],[6436,6489,"Be right back."],[8495,8558,"Bitch!"],[9192,9272,"We're trying to confirm"],[9272,9419,"if this dog tag was made here?"],[9516,9649,"Yeah, that's ours."],[9683,9856,"The owner is right over there."],[10580,10647,"It's you?"]],"5":[[427,497,"It's you?"],[764,850,"Emily Clark?"],[970,1041,"That's me."],[1394,1454,"So,"],[1654,1808,"I suppose you've seen the headlines."],[1915,2012,"Kind of hard to miss."],[2322,2442,"There's a way to fix this."],[2599,2836,"I'll give you one hundred thousand dollars."],[2966,3086,"All you have to do"],[3166,3246,"is leave town."],[3420,3486,"Quietly."],[3873,4104,"You know, I think I've got a better idea."],[4330,4471,"How about we fake a marriage?"],[4611,4721,"Just as I planned."],[4804,4964,"This way you'll get to save your reputation"],[4994,5111,"and a hundred grand."],[5198,5308,"A hundred grand?"],[5342,5415,"Please."],[5452,5592,"I'm worth more than that."],[5618,5765,"We'll see who owns your name."],[6449,6536,"What are you doing here?"]],"6":[[287,537,"Come here."],[537,617,"Where's Emily?"],[684,780,"She left with a guy."],[2632,2749,"Take her to my place."],[2862,2949,"Straight there."],[3019,3056,"Got it."],[3236,3373,"I haven't packed my stuff yet."],[3466,3543,"There's no need."],[3660,3750,"Anything you want,"],[3770,3897,"my assistant will get it for you."],[4154,4224,"Wow."],[4314,4491,"This van is so comfy."],[4634,4774,"You've been in this ride before,"],[4838,4894,"haven't you?"],[5281,5472,"Is she really the woman from that night?"],[6006,6156,"Sign the contract!"],[6219,6322,"If you don't,"],[6339,6546,"don't expect to live here!"],[6683,6726,"Cool!"],[6726,6906,"I don't wanna see you anyway, Anna."],[6950,7017,"Huh!"]],"7":[[1177,1361,"I will take my mom's apartment back."],[1438,1501,"No matter what."],[1945,2072,"First day on the new job."],[2072,2248,"Try not to fall in the boss's lap today."],[3183,3316,"He has a fiancée?"],[3436,3510,"What was that?"],[3753,3887,"Uh, the..."],[3887,3987,"you've... ugh... the..."],[4070,4154,"Beyoncé!"],[4207,4481,"You know, I just, I really love her."],[4481,4597,"You know, the whole..."],[4597,4751,"All the single ladies..."],[4851,4951,"all the single ladies..."],[4971,5148,"Are you going to finish the whole routine?"],[5275,5525,"Messing around outside with a fiancée?"],[5572,5618,"Come on."],[5675,5815,"What a scumbag!"],[6603,6656,"So..."],[6756,6960,"is it true that COO, Mark, is like"],[6960,7063,"the hottest guy in the city?"],[7207,7310,"You've done your homework."],[7394,7480,"Obviously."],[7510,7677,"You know, some people even said you two"],[7677,7794,"were like..."],[7931,8078,"you know, like... like a thing."],[8104,8241,"I shipped it for a sec,"],[8241,8334,"before I found out"],[8334,8468,"you were... straight"],[8468,8551,"that night."],[8835,8918,"What night?"]],"8":[[123,263,"Uh... the..."],[360,440,"the, the night..."],[440,613,"ugh... your news broke."],[613,660,"I mean,"],[684,774,"everyone saw it."],[840,933,"Not that I watched it."],[974,1101,"Or like re... rewatched it."],[1101,1376,"Or... like screenshotted it..."],[1548,1685,"If you were going to be my bodyguard,"],[1768,1921,"we should have some kind of boundaries."],[2178,2252,"See no evil,"],[2262,2335,"hear no evil,"],[2362,2439,"speak no evil."],[2512,2569,"Got it, boss."],[2629,2749,"Are you saying I'm evil?"],[3019,3089,"Depends."],[3156,3453,"Do evil CEOs buy their staff lunch?"],[3777,3853,"Nice dodge."],[4751,4844,"I forgot my phone."],[4858,4961,"I'll be right with you."],[4970,5008,"Okay."],[5301,5412,"What are they doing here?"]],"9":[[36,133,"Here she is."],[266,333,"Sarah!"],[457,583,"The deadline is today."],[583,700,"The buyers are waiting."],[700,874,"Please, sign the contract!"],[907,1027,"Not happening!"],[1087,1458,"Emily found herself a rich boyfriend."],[1481,1652,"We need to get ourselves decked out"],[1652,1921,"for a visit to his huge mansion,"],[1988,2102,"by using"],[2105,2272,"your pathetic"],[2272,2405,"dead mom's"],[2405,2482,"money."],[2619,2719,"You bitch!"],[2719,2829,"Sarah, please."],[2869,2966,"For my sake."],[3133,3259,"You wanna hit me?"],[3299,3493,"You little slut."],[3583,3707,"How dare you?"],[4908,5098,"If you don't sign,"],[5188,5301,"we'll strip you"],[5301,5465,"in front of everyone,"],[5635,5812,"and dump you on some"],[5812,6019,"random homeless guy!"],[6319,6383,"Emily..."],[6496,6533,"please..."],[6533,6596,"Sarah,"],[6653,6840,"just sign the contract already."],[6860,6912,"Otherwise,"],[6912,7107,"this is gonna get really embarrassing"],[7107,7160,"for you."],[7434,7537,"What the hell are you guys doing?"]],"10":[[834,884,"Hey."],[944,1011,"Get away from her!"],[1668,1825,"Wasn't that your boyfriend?"],[1875,2138,"Why was he saving Sarah?"],[2225,2315,"You two just focus on"],[2315,2439,"getting the apartment sold."],[2505,2679,"I'll make sure Alex is on our side."],[2769,2836,"Let's go, let's go."],[2836,2886,"-Let's go. -Go, go, go..."],[3910,3953,"Here."],[4451,4594,"Aren't you supposed to be a bodyguard?"],[4624,4721,"What happened out there?"],[4844,4931,"I let it slide."],[5015,5141,"For my stepsister."],[5141,5342,"She's the only one who doesn't want me dead."],[5942,5989,"Here."],[6596,6759,"Well, I understand why your stepmom must"],[6759,6866,"hate you so much..."],[6920,7173,"it's because you outshine her daughter by a mile."],[7277,7384,"Don't say that."],[7527,7590,"Understood."],[7674,7764,"The sisterhood, huh?"],[7881,7974,"Don't get me started."],[8655,8765,"Don't start without a beer."],[10326,10520,"Now, that is what I needed."],[11778,12052,"Tonight, I have to get with Alex."],[12469,12572,"Oh, God!"],[12702,12896,"No wonder you almost blacked out that night."],[12896,13043,"One can and you're out?"],[13126,13233,"Alex, you're home."],[13233,13329,"I've been waiting for..."],[13636,13710,"Sarah?"]],"11":[[577,660,"I'll see you in the morning."],[2395,2449,"Uh..."],[2449,2579,"I don't know how to..."],[2579,2645,"I'll teach you."],[4100,4150,"There."],[4150,4260,"You're getting it."],[5261,5442,"Why does she seem so familiar?"],[6222,6383,"You were just a mistake in a van."],[6409,6528,"I'm his future."]],"12":[[794,904,"Have you been eating snacks"],[904,980,"in my van again?"],[1141,1184,"What?"],[1257,1294,"No."],[1541,1765,"You have Cheeto crumb on your lips."],[2032,2072,"I mean..."],[2198,2242,"maybe."],[2369,2482,"No snacks in my van."],[2519,2572,"Ever."],[2716,2762,"Fine."],[2819,3006,"I swear on my last bag of Cheetos."],[3093,3143,"Happy?"],[4110,4234,"Alex, you're home."],[4361,4424,"I've been"],[4424,4497,"waiting for you."],[4828,4941,"Put your clothes back on."],[5115,5155,"Why?"],[5238,5352,"Am I not good enough for you?"],[5985,6076,"Go back to your room."],[7020,7147,"I need the surveillance footage"],[7147,7307,"from the hotel parking lot that night."],[7407,7484,"Immediately."]],"13":[[100,170,"In that folder,"],[170,266,"you'll see some information"],[266,367,"that's very important"],[400,523,"for next week's presentation."],[580,720,"Congratulations!"],[870,957,"You..."],[984,1171,"made Forbes' 30 Under 30."],[1277,1344,"Aha!"],[1494,1541,"Wait..."],[1678,1818,"you're Mark Johnson,"],[1818,1951,"COO of HARTMAN Group."],[1998,2168,"Oh, yes, I am."],[2168,2275,"Nice to meet you."],[2425,2509,"Relax."],[2635,2742,"He is not a superhero."],[2856,2906,"You're"],[2906,3129,"the business genius everyone talks about."],[3376,3466,"I mean, the face..."],[3466,3606,"Wow, even better in real life."],[3663,3727,"Well..."],[3727,3887,"someone has to keep up the charm here,"],[3887,3955,"huh, Alex?"],[4124,4294,"Business genius by day,"],[4414,4541,"heartbreaker by night."],[4721,4871,"Flirting with my bodyguard"],[4871,5005,"in my office?"],[5028,5125,"That's a bold move."],[5325,5462,"What? Are you jealous, huh?"],[5575,5625,"Hmm?"],[5989,6116,"Let's celebrate!"],[6129,6176,"Huh?"],[6649,6700,"The lady."],[6770,6856,"Of course."],[7153,7317,"Cheers, 30 under 30."],[7894,7987,"It's champagne."],[8001,8041,"Wow..."],[8041,8111,"Of course."],[8174,8318,"It's about five grand."],[8368,8408,"What?"],[8641,8792,"I hate rich people."],[9125,9222,"Okay, kids,"],[9235,9325,"I'm going."],[9539,9649,"Oh, whoa, wait, wait, wait..."],[9856,9933,"Wait, wait, wait..."],[10043,10140,"That's a..."],[10140,10296,"that's a $5,000 bottle!"],[10810,10880,"She just..."],[10924,10977,"Yeah,"],[11117,11171,"she did."],[11361,11448,"That's..."],[11461,11508,"cute."],[11818,11898,"She won't tell Alex"],[11898,12005,"about the night, will she?"],[12108,12162,"No way."],[12198,12362,"I can't lose everything I have now."],[12629,12839,"That Sarah really knows how to"],[12839,13046,"twist men around her little finger,"],[13046,13113,"doesn't she?"],[13189,13309,"She will not be getting that"],[13309,13453,"administrative manager role."],[13630,13723,"Not over my dead body."],[13950,14167,"A sharp blade just revealed itself."]],"14":[[580,670,"Alex is preparing to"],[670,797,"give that promotion to Sarah."],[977,1014,"What?"],[1014,1077,"Who are you?"],[1201,1341,"I'm Alex's fiancée."],[1554,1715,"I think you're much better suited to the role"],[1715,1811,"than Sarah."],[1865,2052,"Then you need to help me out, Ma'am."],[2265,2359,"Do exactly"],[2389,2469,"as I say,"],[2622,2796,"and you'll get everything you want."],[3650,3690,"Sir?"],[3860,3997,"The parking lot surveillance footage"],[3997,4047,"is gone."],[4077,4157,"Someone erased it."],[4244,4361,"So we have no clear image"],[4361,4467,"of the bridesmaid, is that right?"],[4511,4551,"Right."],[4597,4798,"Even the paparazzi couldn't get her face."],[4931,4981,"It's fine."],[5128,5315,"Bridesmaids are the worst."],[5375,5502,"Always bad luck."],[5528,5572,"What?"],[5658,5722,"You know,"],[5745,5959,"I was a bridesmaid at my dad's wedding."],[6006,6229,"Watched my neighbor become my stepmom."],[6309,6463,"Then she stole my mom's apartment."],[6566,6786,"Worst day ever."],[6910,7023,"And you know what happened"],[7023,7207,"in the parking lot after the wedding?"],[7267,7367,"You won't believe it."],[7414,7464,"Wait, what..."],[7487,7554,"what happened?"],[7554,7664,"What parking lot?"]],"15":[[760,810,"All right."],[860,920,"We're leaving."],[957,1077,"You need sleep."],[1247,1304,"Come on."],[1508,1541,"Sarah."],[2349,2402,"Hey!"],[2622,2746,"Hey, get off me!"],[2962,3089,"I was just trying to hold you up."],[3136,3269,"You touched me first."],[3269,3470,"That is a suspicious behavior."],[3506,3580,"Suspicious?"],[3606,3670,"Hmm."],[3703,3867,"I just saved you from hitting the ground."],[4014,4117,"Jury's still out."],[4214,4290,"Tough crowd."],[4404,4504,"Let me tell you something."],[4577,4848,"Don't mess with a drunk girl"],[4848,4998,"trained in Muay Thai."],[5141,5342,"One elbow and he almost cried."],[5445,5668,"I guess those Muay Thai classes really paid off."],[6026,6059,"Ha!"],[6239,6433,"Why do you remind me so much of her?"]],"16":[[1227,1348,"What the hell are you doing here?"],[1401,1578,"It's no wonder you're surprised."],[1578,1701,"It's not often that I spend time"],[1701,1865,"in shoebox apartments like this."],[2078,2215,"Oh my God!"],[2215,2335,"Did, did we..."],[2335,2405,"um..."],[2739,2892,"Don't pretend you don't remember."],[3830,3937,"Hey, handsome."],[4090,4164,"Be careful."],[4274,4418,"Or I don't know the things that I might"],[4418,4489,"do to you."],[4517,4674,"What do you want to do to me?"],[4998,5071,"I..."],[5128,5285,"just want to..."],[6466,6589,"Relax."],[6589,6756,"I didn't lay a finger on you."],[7203,7270,"Do you want me to?"]],"17":[[220,348,"Still worried something happened?"],[480,617,"Typical playboy!"],[643,911,"Already has a fiancée and still acting like this?"],[1351,1384,"I should"],[1444,1561,"compensate you for the"],[1608,1684,"suit."],[1701,1781,"It's a good idea."],[1885,1995,"I think you should pay up now."],[3109,3186,"Alex."],[5061,5145,"What the hell?"],[5468,5518,"Sorry."],[5632,5692,"Um..."],[5755,5819,"Look, I know"],[5842,5985,"I ruined your suit,"],[5985,6192,"and everything, but um..."],[6419,6573,"Can we go somewhere cheaper?"],[6830,6913,"Relax."],[6943,7064,"The company is covering it."],[7203,7332,"The company is covering it?"],[7624,7747,"Oh..."],[7804,7987,"Oh, I love my job!"]],"18":[[316,390,"Let's try that one."],[1084,1141,"Alright."],[1795,1988,"Jesus take my visa!"],[2105,2339,"Oh, who do I have to marry to afford this?"],[2836,2952,"Would you like to try that on?"],[2952,3036,"It's new arrival."],[3073,3176,"Oh, no, no, no."],[3176,3366,"I'm just... just looking."],[3386,3470,"All right."],[4064,4120,"Like it?"],[4227,4280,"Like it?"],[4361,4544,"I'm pretty sure it's the love of my life,"],[4584,4718,"but don't tell my credit card."],[4951,5011,"After you."],[5899,5962,"Wrap it up."],[6072,6149,"Have it delivered."],[6269,6343,"Sure thing."]],"19":[[286,390,"I need your help with something."],[517,590,"Yeah, sure."],[627,677,"Next week,"],[677,810,"the company's hosting a conference,"],[810,967,"and I'll be announcing Alex's award"],[967,1041,"to the press."],[1127,1207,"Awesome!"],[1257,1351,"What do you need from me?"],[1418,1651,"All I need you to do is make sure of his safety."],[1758,1881,"Oh, and don't tell Alex."],[1895,2052,"We don't wanna ruin his surprise."],[2138,2185,"Sure."],[2208,2339,"This is just between us."],[2339,2445,"I won't tell anybody!"],[2599,2655,"Amazing."],[3530,3750,"The show is about to begin."]],"20":[[106,326,"Amanda, where the hell are you?"],[326,453,"Pick up the phone!"],[563,707,"Where the hell is Amanda?"],[707,857,"She's not picking up the phone!"],[870,1014,"It's starting in ten minutes."],[1067,1171,"We can't bomb this."],[1454,1564,"Amanda, where are you?"],[1591,1748,"I got rear-ended on the freeway."],[1748,1865,"My car's wrecked."],[1865,2019,"No way I can make it in time."],[2019,2077,"Are you kidding?"],[2077,2182,"The press are already out there!"],[2182,2232,"Listen."],[2232,2332,"You're gonna have to host."],[2405,2466,"What?"],[2466,2625,"No, I didn't prepare anything."],[2652,2749,"You got this."],[3613,3840,"See how the media will respond to that one."],[3850,3920,"You'll be gone"],[3987,4054,"very soon."],[4274,4324,"Okay."],[4330,4447,"I have ten minutes."],[4491,4627,"Who can I borrow a dress from?"],[4844,4898,"Miss,"],[5015,5165,"I was instructed to give this to you."],[5919,6026,"Who got me this?"],[6686,6893,"Here is the love of your life."],[6916,6986,"Don't worry."],[7003,7153,"I didn't tell your credit card."],[7177,7267,"It's our secret."]],"21":[[353,453,"What's going on?"],[500,633,"Why is no one in charge?"],[1207,1391,"Let's see what our charming"],[1391,1584,"little bodyguard does now."],[3430,3573,"Is that Sarah?"],[3757,3848,"Who is she?"],[3848,4004,"She is like a professional host."],[4077,4143,"She looks like"],[4143,4284,"she belongs on a red carpet."],[4481,4574,"Damn..."],[4651,4764,"She is a charm."],[4851,4904,"Hey!"],[5001,5131,"Stay away from my bodyguard."],[5221,5288,"I'll try."],[5528,5719,"How did you get such a beautiful dress"],[5719,5835,"in ten minutes?"],[5955,6016,"Bitch!"],[6032,6166,"I can't let you win like this!"],[8104,8158,"Amanda?"],[8545,8595,"Thank you."],[10967,11087,"Oh, no..."]],"22":[[256,407,"She is finished."],[500,533,"Whoo!"],[593,653,"Nice body."],[774,860,"What's she gonna do?"],[1154,1194,"Got it!"],[1758,1825,"What?"],[1861,2009,"Under Alex Hartman's leadership,"],[2048,2295,"HARTMAN Group keeps breaking the rules,"],[2318,2499,"and dropping the old ways,"],[2602,2676,"sometimes..."],[2739,2812,"even the dress."],[2912,3193,"So, no a boring press conferences tonight."],[3266,3373,"Let's party!"],[3440,3560,"Nice save!"],[3580,3643,"Come on, everybody."],[3643,3747,"Let's light this place up."],[4227,4391,"That's impossible!"],[4678,4824,"Now, that's a press conference."]],"23":[[233,350,"She's got them hooked!"],[543,663,"I like her!"],[787,917,"You're aware you've only met her..."],[977,1031,"twice?"],[1087,1177,"Doesn't take long."],[1177,1331,"She is sharp, fearless..."],[1368,1468,"and that smile..."],[1518,1554,"Whoa..."],[1601,1701,"both of us are in love."],[1858,1938,"What did you say?"],[2025,2074,"Nothing."],[3206,3396,"You've had one job, Amanda."],[3396,3450,"One!"],[3450,3576,"I swear I had all planned."],[3576,3640,"It's just the..."],[3730,3943,"Then why is this bitch still smiling"],[3943,4080,"like she owns the place?"],[4317,4401,"One more screw-up,"],[4474,4544,"and you're out."],[4641,4688,"Who's there?"]],"24":[[56,100,"Who's there?"],[230,290,"Amanda?"],[323,387,"You're all right?"],[423,530,"And the car accident?"],[610,694,"Yeah, I'm fine."],[694,787,"Yes, Mr. Hartman."],[907,980,"You're so good..."],[1017,1101,"at lying."],[1227,1317,"Don't think I don't know"],[1317,1471,"what's going on with your little stunt."],[1501,1604,"Fake car accident,"],[1618,1785,"forcing Sarah up on stage,"],[1785,1908,"unzipping her dress?"],[2042,2082,"I..."],[2082,2225,"You're... fired."],[2295,2369,"No, you can't..."],[2369,2402,"I..."],[2435,2472,"I didn't..."],[2472,2519,"it wasn't..."],[2552,2609,"it was..."],[2609,2742,"It was what?"],[3593,3650,"It was me."]],"25":[[860,1024,"You made me lose my job."],[1685,1785,"I'm giving you one..."],[1811,1951,"last chance."],[2235,2352,"You wanna fix this?"],[2562,2672,"Then get rid of Sarah!"],[3526,3576,"Go!"],[3990,4124,"Alex, there is a rumor about"],[4124,4281,"a certain bodyguard's been stealing"],[4281,4421,"your spotlight lately."],[4564,4688,"She is not stealing anything."],[4761,4934,"Just proving she belongs in it."],[5201,5255,"She is here?"],[5338,5455,"Let's invite her on stage."],[5502,5568,"Why not?"],[5645,5712,"Come on, Sarah."],[6943,7113,"Just stand there and watch your boss"],[7113,7263,"embarrass himself in public."],[7263,7494,"You'll be fired for messing up in no time."],[7794,7844,"No way..."]],"26":[[700,762,"Are you okay?"],[968,1041,"Let go!"],[1091,1161,"Don't let her go!"],[1181,1234,"I won't."],[2168,2238,"Amanda?"],[2295,2425,"What the hell were you doing?"],[2699,2826,"I don't believe you do this alone!"],[2882,2956,"Who sent you?"],[3159,3370,"This is your last chance."],[3470,3687,"I'm not stupid enough to rat out my bankroll"],[3687,3793,"after you fired me."],[3827,3873,"No one."]],"27":[[670,774,"You should be resting,"],[790,894,"not... smiling."],[1017,1094,"Are you kidding?"],[1154,1284,"I just saved the day."],[1324,1424,"Totally worth it!"],[1478,1524,"Worth it?"],[1588,1678,"You look like..."],[1678,1798,"someone who just survived"],[1798,1895,"a paint explosion."],[1968,2102,"Heroic paint explosion."],[2302,2405,"You know I've never seen someone"],[2405,2495,"look so good"],[2499,2595,"covered in paint before."],[2756,2949,"You must have a thing for messy situations."],[3043,3096,"Maybe..."],[3196,3283,"I have a thing for you."],[3750,3820,"Look, I..."],[3820,3890,"I know you have a thing"],[3890,4047,"for me covered in paint,"],[4047,4100,"but uh..."],[4184,4270,"I need to take a shower."],[5815,5892,"Why'd you do it?"],[6102,6162,"It's my job."],[6279,6423,"No matter how messy I get,"],[6456,6557,"I won't let you get hurt."]],"28":[[40,80,"Hey."],[113,236,"Sarah..."],[236,397,"you're all over the internet now."],[427,717,"“CEO's Badass Bodyguard”, huh?"],[757,1004,"That's what they're calling it?"],[1004,1107,"I'm really curious."],[1137,1234,"If it were me up there,"],[1261,1348,"would you save me?"],[2028,2142,"Don't waste your time with him."],[2959,3009,"Are you okay?"],[3166,3249,"Don't let her go!"],[3777,3867,"Seriously?"],[3890,4041,"What makes Sarah so special?"],[4097,4184,"Just a little bit of paint,"],[4184,4391,"and suddenly she is the center of the universe!"],[4467,4618,"That spotlight should have been mine."],[4674,4853,"I'm the one who belongs at Alex's side."],[6286,6326,"Hello?"],[6343,6623,"Do you want Sarah to disappear?"],[6880,6950,"I'm listening."]],"29":[[507,657,"Mrs. Hartman!"],[694,857,"What an honor to finally meet you!"],[867,1101,"I've heard so much about you from Alex."],[1207,1271,"Really?"],[1321,1394,"That's funny."],[1421,1621,"Alex and I aren't as close as you think."],[1971,2012,"Oh..."],[2088,2149,"I see."],[2776,2836,"Are you okay?"],[2909,2999,"Don't let her go!"],[3013,3073,"I won't..."],[3093,3223,"I'm sure you've seen this,"],[3246,3376,"and it makes you feel jealous."],[3560,3630,"Jealous?"],[3703,3750,"No,"],[3873,4007,"I'm beyond jealous."],[4067,4207,"I want that girl shattered."],[4247,4381,"I want her eviscerated!"],[4381,4567,"I want her out of Alex's life"],[4584,4758,"like she never existed."],[4768,4851,"Easy, darling..."],[4934,5078,"Even if Sarah disappears,"],[5088,5175,"he won't love you."],[5258,5398,"He is as stubborn as a mule"],[5398,5558,"when it comes to feelings."],[5648,5759,"So what do you think I should do then?"],[5822,6122,"How about we make both Sarah and Alex"],[6122,6196,"vanish,"],[6236,6462,"and we split the company between us?"],[6493,6523,"What?"]],"30":[[23,66,"What?"],[90,133,"Money"],[160,363,"is way more reliable than men."],[547,633,"Be on my side."],[697,834,"So, I'm guessing you've got a plan."],[934,1127,"Do you know Sarah's address?"],[1524,1644,"What's your new address?"],[2248,2282,"Done."],[3093,3166,"Get some rest."],[3166,3263,"It's been a long day."],[3850,3907,"Got them!"],[3970,4134,"Boss spends night at his bodyguard's"],[4134,4240,"cozy apartment."]],"31":[[253,393,"No, I can't be pregnant!"],[393,475,"Not with his baby!"],[475,613,"He has a fiancée!"],[1264,1361,"Miss Thompson,"],[1361,1568,"any comment on your affair with Alex?"],[1611,1725,"What are you talking about?"],[2909,3043,"This can't be happening!"],[3156,3343,"I can't let anybody find out I'm pregnant."],[4310,4447,"Who leaked this?"],[6676,6740,"Seriously?"],[6740,6840,"The press again?"],[7307,7447,"Mark, what are you doing here?"],[7484,7564,"You wanna get in or"],[7564,7657,"we can have a chat here."],[7821,7884,"Come on."],[7884,7961,"Don't start."]],"32":[[1394,1478,"That must hurt."],[1675,1808,"I'm sure they're just friends!"],[2032,2122,"I meant your foot, Sir."],[2932,3036,"So..."],[3089,3269,"I got you a hotel room,"],[3403,3510,"so you can lay low for a while."],[3713,3870,"Why would you do this?"],[3940,4084,"Oh, I'm actually Wonder Woman."],[4224,4304,"-Oh... -Hmm!"],[4344,4381,"Yeah."],[4394,4524,"But don't tell anyone, okay?"],[4808,4904,"Yeah, our secret."],[5198,5278,"Thank you, Mark."],[5355,5473,"That really made my day."],[5608,5815,"But I, I don't wanna drag you into this."],[5892,5945,"Too late."]],"33":[[1331,1374,"Sir?"],[1578,1778,"The PR department just released a statement."],[3680,3747,"You"],[3777,3913,"shouldn't be alone tonight."],[4124,4170,"Sarah,"],[4394,4444,"stay..."],[4828,4881,"Please..."],[4998,5105,"Unbelievable!"],[5739,5789,"Margaret,"],[5849,5989,"I wanna go with our second plan."],[6099,6236,"I want Sarah to die."]],"34":[[1004,1051,"Hello?"],[1091,1161,"Hey, Sarah."],[1181,1290,"I'm sorry for what happened,"],[1290,1334,"but..."],[1334,1464,"He is gonna fire me, right?"],[1538,1661,"Sarah, it's the only way."],[1708,1841,"The company needs a clean break."],[1971,2035,"Where do I sign?"],[2098,2207,"Company headquarters."],[2252,2292,"Today."],[2439,2509,"I'll be there soon."],[3223,3370,"No wonder why the boss is always"],[3370,3456,"protecting her."],[3500,3536,"Yeah,"],[3550,3720,"always seen hanging around the boss."],[3720,3803,"Guess we all know why."],[3837,3960,"Look at what she is wearing."],[3960,4134,"I still can't understand why the boss"],[4134,4244,"has a crush on her."],[4270,4451,"You are much better looking than she is."]],"35":[[210,256,"Mark?"],[303,437,"And... what are you doing here?"],[550,657,"Officially resigning."],[714,784,"Resigning?"],[837,967,"You don't have to do this, you know."],[1054,1114,"It's not me."],[1114,1254,"It's the company's decision."],[1334,1484,"I don't know about this."],[1484,1641,"Is this what Alex told you to do?"],[1831,2048,"Look, you're one of our best hires."],[2048,2135,"I don't buy this."],[2135,2225,"I'm gonna talk to Alex myself..."],[2225,2302,"No, no, no, no."],[2312,2397,"Don't, don't."],[2679,2796,"You're just too kind."],[2826,2922,"I just wanna help you."],[2969,3076,"I know, Mark."],[3123,3290,"But I want this to end here."],[3340,3463,"At least let me give you a hug."],[4000,4145,"Was that really necessary?"],[4781,4954,"Here she comes."],[5665,5719,"Sarah!"]],"36":[[387,510,"If you can't protect her,"],[530,620,"stay away from her!"],[630,720,"Protect her?"],[774,924,"The only one who's hurt her is you!"],[927,1027,"It's not fair!"],[1031,1117,"Not fair?"],[1151,1261,"Look in the mirror, man."],[1274,1398,"You're the problem here."],[1564,1688,"Well, well..."],[1688,1798,"Look at this."],[1881,2138,"The CEO and the COO"],[2138,2302,"fighting over one woman."],[2409,2559,"I'm sorry, have we met?"],[2559,2662,"I'm Margaret,"],[2679,2806,"Alex's stepmother."],[2889,2979,"Oh, uh..."],[2979,3159,"it's nice to meet you, Mrs. Hartman."],[3159,3229,"I didn't realize..."],[3229,3416,"I've been dying to see the girl"],[3416,3563,"who's been setting boardrooms"],[3563,3713,"and tabloids on fire."],[3840,3907,"Margaret,"],[3907,3990,"don't start."],[4030,4144,"Relax, darling."],[4240,4454,"I just wanna see the woman who's been..."],[4567,4711,"occupying your attention."],[4801,4894,"I must say,"],[4894,5038,"you're gorgeous!"],[5098,5398,"Just the kind of face that could lure a guy in."],[5475,5518,"I..."],[5518,5729,"I don't know what I've done to offend you,"],[5729,5792,"but I promise,"],[5792,6012,"I'm nothing like what the paparazzi wrote."],[6686,6770,"I should... go."],[7010,7053,"Take care."]],"37":[[560,630,"I found something."],[690,864,"Your stepmother's been meeting with Emily"],[864,924,"regularly."],[954,1074,"We caught them at the same cafe"],[1074,1151,"several times."],[1351,1446,"I had them recorded."],[1481,1564,"You need to watch this."],[1771,1991,"We don't need to ruin Sarah's life."],[2042,2272,"Just give it a little push."],[2372,2485,"If we play it right,"],[2515,2652,"the public turns."],[2679,2852,"Investors get nervous."],[2872,3046,"Alex's position weakens."],[3129,3266,"I get the board."],[3323,3380,"You..."],[3453,3566,"get what you want."],[3693,3723,"Good."],[3763,3917,"That bitch took everything from me."],[4020,4134,"I want her to lose it all."],[4497,4544,"Emily!"],[4814,4868,"Get out!"],[4901,5001,"What, Alex?"],[5001,5058,"Please!"],[5752,5795,"Alex..."],[5839,5955,"Alex, it's not what it looks like."],[5955,6012,"Please!"],[6012,6136,"Please, I... I promise..."],[6136,6266,"I won't see her ever again."],[6266,6393,"Please, just let me stay..."],[6393,6473,"Please, no..."],[6473,6521,"please..."]],"38":[[3717,3763,"I..."],[3857,3980,"just want to..."],[4431,4637,"No, you can't think about him anymore."],[5398,5490,"How'd you find this place?"]],"39":[[46,130,"Needed a break."],[180,286,"Invited myself."],[400,537,"Go, just go."],[623,672,"Why?"],[850,1011,"We shouldn't see each other anymore."],[1057,1098,"What?"],[1134,1261,"You're afraid the paparazzi's gonna"],[1261,1311,"come back?"],[1448,1511,"Yes."],[1511,1718,"I don't wanna be the center of social media."],[1768,1921,"Why do you care so much about that?"],[1921,2088,"Hey, mister, you have a fiancée."],[2088,2185,"You remember that?"],[2285,2369,"It's not what you think."],[2369,2419,"I'm not..."],[2419,2445,"Don't."],[2509,2572,"Just leave."],[2625,2706,"I'm not..."],[2759,2836,"going anywhere."],[4761,4878,"You're not gonna make me leave."],[5128,5181,"Come on."],[6573,6656,"You're pregnant?"]],"40":[[20,106,"You're pregnant?"],[193,253,"Give that back!"],[1051,1137,"Whose kid is this?"],[1167,1271,"None of your business!"],[1401,1468,"Is it Mark's?"],[1601,1735,"I saw you two hugging in the hallway."],[1891,1995,"What are you talking about?"],[1995,2118,"Mark and I are just friends."],[2118,2235,"Like I believe that."],[2339,2494,"I saw you getting into his car the other night."],[2532,2679,"Who knows where you were heading off?"],[2902,3016,"Are you following me?"],[3253,3289,"Yeah,"],[3366,3410,"so what?"],[3556,3720,"You disgusting stalker..."],[3740,3813,"Well, I must be"],[3813,3987,"the world's worst stalker then!"],[4117,4197,"What do you mean?"],[4287,4327,"Well..."],[4374,4531,"there are other guys, aren't there?"],[4811,4974,"No, there are no other guys."],[4974,5128,"I've only been with one guy and that guy is..."],[5128,5185,"Who is the guy?"],[5261,5301,"Tell me."]],"41":[[23,76,"Who is the guy?"],[163,203,"Tell me."],[453,570,"I can't tell him that..."],[647,780,"I've had enough with the drama."],[1074,1171,"The guy is a jerk."],[1464,1634,"So you'd rather sleep with a jerk,"],[1688,1788,"and have a baby with him,"],[1825,1858,"huh?"],[2052,2142,"You're unbelievable."],[2846,2909,"What the hell?"],[3326,3380,"Who are you?"],[3897,3943,"Sarah..."],[4010,4047,"Ha!"],[4461,4521,"It's you!"]],"42":[[23,83,"It's you!"],[260,320,"It's you."],[690,747,"I told you,"],[787,1017,"never mess with a girl trained in Muay Thai."],[1181,1271,"Are you the van girl?"],[1568,1634,"What van girl?"],[2248,2318,"How is Luna?"],[2492,2539,"I don't know."],[2615,2776,"I miss her so much..."],[3129,3173,"Shit!"],[3226,3346,"Don't lie to me again."],[3536,3600,"The dog,"],[3600,3673,"the tattoo,"],[3673,3743,"the elbow,"],[3743,3827,"the \"ha\"!"],[4017,4210,"Yes, it... it was me,"],[4297,4444,"but it meant nothing to me."]],"43":[[20,180,"You've been here this whole time,"],[270,353,"and you kept it from me."],[353,397,"Why?"],[437,563,"Because you're not single."],[603,787,"You have a fiancée, remember?"],[787,847,"My fiancée..."],[1084,1251,"I wouldn't have a fiancée"],[1284,1484,"if you hadn't put me on a leash that night."],[1638,1715,"What do you mean?"],[1785,1831,"I mean..."],[1935,2112,"I've been trying to save my public image,"],[2112,2228,"but I can't do that"],[2245,2409,"without my master of the night."],[2455,2625,"You mean... you were looking for me?"],[2639,2689,"Yes,"],[2719,2799,"of course!"],[2819,2979,"But you didn't find me, obviously."],[3053,3179,"I found the wrong person."],[3293,3428,"Well, whose mistake is that?"],[3526,3586,"Yours!"],[3683,3883,"This is all your fault!"],[3957,4064,"Why is it my fault?"],[4114,4190,"Because you..."],[4290,4414,"are a fake dog lover."],[4511,4651,"I love my dog very much."],[4721,4901,"Well then, why didn't you put your name"],[4901,4998,"on the dog tag?"],[5091,5181,"Dog tag..."],[5488,5658,"I put my stepsister's name on it,"],[5658,5835,"because she really wants the dog."],[5995,6066,"Your stepsis..."],[6232,6326,"Emily Clark?"],[6463,6546,"How do you know her?"],[6576,6636,"Know her?"],[6700,7003,"She is posing as you, as my fiancée!"]],"44":[[193,260,"Wait, you mean..."],[260,410,"she is pretending to be me?"],[684,724,"No!"],[794,834,"No..."],[904,987,"No, she wouldn't do that."],[1057,1217,"She... she saved my life"],[1217,1368,"when I was drowning in the pool."],[1368,1408,"We..."],[1488,1614,"we were so close."],[1721,1868,"She is the only one in my family"],[1868,2008,"I actually trust..."],[2151,2213,"Wait..."],[3259,3406,"She was so innocent back then."],[3743,3787,"Wait,"],[3897,3957,"look at this."],[4337,4481,"Why isn't she helping me?"],[4624,4718,"Maybe she was..."],[4748,4854,"trying to drown you."],[5101,5215,"But she was just a kid."],[5261,5321,"You never know."],[5755,5920,"Did she do this on purpose?"],[6226,6373,"Now you see the truth."],[7043,7267,"Speaking of truth..."],[7327,7374,"um..."],[7857,7957,"the baby is yours."]],"45":[[123,210,"The baby's yours."],[250,390,"Why didn't you tell me before?"],[503,653,"I didn't wanna ruin your life."],[653,784,"I thought you had a fiancée."],[807,850,"Oh, I'm..."],[850,1011,"I'm not engaged, not anymore."],[1137,1348,"You can't show mercy to someone"],[1348,1444,"who tried to drown you."],[1634,1685,"Uh..."],[1895,2015,"Should we call the police?"],[2105,2142,"No,"],[2305,2372,"we'll make her pay..."],[2482,2539,"properly."],[3923,4027,"I've given it a lot of thought."],[4060,4214,"And I think it's time I give the press"],[4214,4304,"the perfect"],[4327,4404,"family image."]],"46":[[90,220,"Does this mean you're finally accepting"],[220,302,"our engagement?"],[326,480,"I'll be announcing my fiancée"],[480,617,"at the press conference tomorrow."],[807,1007,"I knew you'd finally come around."],[2155,2345,"Now they'll finally see who you really are."],[2439,2521,"And so will she."],[2986,3049,"Hello?"],[3049,3279,"You think you can betray me this easily?"],[3490,3583,"I don't need you..."],[3613,3737,"to get what I want."],[3787,3942,"Sarah's already out of the picture,"],[4000,4087,"and Alex is about to"],[4087,4224,"announce me as his fiancée."],[4351,4397,"Oh,"],[4404,4484,"I'm sorry."],[4484,4561,"I gotta go."],[4561,4621,"Bye."],[4898,4961,"Mommy!"],[4961,5098,"Darling, darling..."],[5171,5438,"soon we'll be part of the Hartman family."],[5498,5679,"How lucky are we?"],[5745,5929,"Emily is making history."],[6122,6229,"She's got this."],[6730,6790,"Perfect!"],[6896,6956,"Let's go."]],"47":[[323,413,"What are you doing here?"],[500,593,"Oh, I, uh..."],[593,684,"work here again."],[714,877,"Makes perfect sense, doesn't it?"],[927,1047,"But what are you doing here?"],[1144,1184,"Oh..."],[1221,1341,"I guess you're about to find out."],[1410,1490,"Oh."],[1498,1858,"Do you really think you belong here?"],[1898,2115,"Sarah, don't make a fool of yourself!"],[2806,2846,"Tonight,"],[3016,3166,"I'd like to introduce you all"],[3179,3286,"to my fiancée."],[3646,3760,"This is why I'm here."],[4140,4224,"Mr. Hartman,"],[4224,4347,"what led to your decision"],[4347,4504,"of making your fiancée public?"],[4541,4604,"Honestly,"],[4688,4886,"she is been with me through a lot lately."],[5008,5071,"And I thought,"],[5131,5355,"how can I keep someone so amazing"],[5405,5455,"a secret"],[5485,5555,"any longer?"],[7374,7454,"Ladies and gentlemen,"],[7711,7801,"my fiancée,"],[8064,8174,"Sarah Thompson."],[8278,8334,"What?"]],"48":[[16,100,"My fiancée,"],[180,280,"Sarah Thompson."],[967,1114,"What the hell is this?"],[1174,1254,"You tell me."],[1388,1448,"Murderer."],[1761,1981,"We don't need to ruin Sarah's life,"],[2022,2238,"just give it a little push."],[2625,2736,"If we play it right,"],[2769,2909,"the public turns."],[2926,3116,"Investors get nervous."],[3126,3313,"Alex's position weakens."],[3396,3513,"I get the board."],[3583,3636,"You..."],[3710,3823,"get what you want."],[4320,4367,"Good."],[4424,4637,"That bitch took everything from me."],[4728,4834,"I want her to lose it all."],[5682,5715,"Sarah..."],[5775,5825,"Sarah,"],[5825,5862,"please..."],[5889,5985,"I didn't mean it..."],[6126,6276,"You weren't my savior."],[6322,6433,"You tried to kill me."],[6433,6576,"You almost made me drown!"]],"49":[[433,600,"Cause... cause you're always..."],[600,884,"so freaking perfect, aren't you, Sarah?"],[930,1174,"You always had the love and the attention,"],[1174,1401,"even the dead freaking sob story"],[1401,1511,"with your mama!"],[1548,1608,"You have everything."],[1608,1861,"Even the dog loves you better than it loves me!"],[1885,2012,"Do you know how it feels"],[2012,2202,"to always be second best?"],[2432,2475,"It's not..."],[2499,2559,"fair!"],[3159,3216,"Emily!"],[3666,3757,"Emily Clark,"],[3757,3843,"Margaret Hartman,"],[3843,3937,"you're under arrest."],[4037,4084,"What?"],[4100,4137,"No..."],[4224,4270,"no, no, no..."],[4314,4424,"Get away from me!"],[4507,4678,"It wasn't meant to be like this!"],[4701,4851,"Emily, your lies will always"],[4851,4928,"catch up with you."],[5091,5241,"Alex, please..."],[5241,5398,"for your father's sake."],[5485,5628,"He wouldn't wanna see this"],[5628,5742,"if he were with us."],[5769,5899,"I am doing exactly"],[5899,6012,"what Father would want."],[6129,6276,"I'm not gonna let you destroy"],[6299,6536,"everything that he took his entire life to build!"],[6740,6853,"Sarah, please..."],[6853,7023,"don't let them take Emily."],[7107,7223,"If you do this,"],[7223,7567,"we'll never see our daughter again."],[7751,7869,"You will see her again."]],"50":[[240,326,"I've recorded"],[350,420,"everything."],[607,667,"Evidence,"],[697,864,"illegal property deal..."],[1214,1307,"You'll be reunited"],[1354,1498,"in prison."],[1574,1728,"Sarah, please!"],[1728,1815,"Don't do this."],[1895,2002,"I'm your father!"],[2058,2125,"Oh..."],[2188,2288,"take care in prison, Dad."],[5041,5081,"Here."],[5198,5248,"What's this?"],[5311,5358,"Open it."],[5985,6139,"Is this my mom's apartment?"],[6236,6276,"No."],[6439,6616,"The old property had a bunch of legal issues,"],[6616,6723,"so I couldn't buy it."],[6820,6860,"It's fine."],[7043,7220,"So I bought the whole building."],[8818,8875,"Hey, girl..."],[10050,10110,"Marry me?"],[10593,10657,"Yes."]]}