{"1":[[0,225,"Uncle Hank, Aunt Sharon, please."],[229,483,"Don't send me back to the orphanage."],[487,754,"I will eat less and work more."],[758,937,"I can take good care of your son."],[941,1137,"And I'll collect bottles to sell"],[1141,1283,"to buy him candy."],[1308,1429,"You want us to adopt you?"],[1433,1625,"You were just our son's nanny!"],[1629,1725,"But what have you done?"],[1729,1966,"You caused my son's hand to get burned"],[1970,2083,"and you even stole my money."],[2087,2154,"Our family"],[2158,2358,"doesn't welcome a thief like you."],[2375,2716,"I didn't steal the money."],[2858,3004,"Sharon took it."],[3008,3295,"I just saw her with another man..."],[3495,3595,"How dare you lie!"],[3606,3679,"You d*mn girl!"],[3679,3883,"You're just an unwanted stray!"],[3908,4066,"Get the h*ll back to your orphanage!"],[4254,4370,"Hank, Sharon."],[4458,4566,"Please don't kick me out."],[4570,4687,"I was wrong."],[4712,4762,"You d*mn brat."],[4779,4904,"You're nothing but a jinx."],[4908,5087,"Whoever adopts you gets bad luck!"],[5827,5930,"You d*mn girl!"],[5941,6029,"You'd better die out there!"],[6070,6154,"If you dare come back,"],[6158,6287,"I'll break your legs!"],[7151,7354,"I don't wanna go back to the orphanage."],[7403,7614,"Are there any kind-hearted people"],[7623,7818,"who can adopt me?"],[9458,9633,"Hey there, little one."],[9637,9787,"I'm sorry, Mister."],[9791,9983,"I didn't mean to."],[10007,10135,"Why are you out here all alone?"],[10204,10304,"Where are your parents?"],[10350,10454,"It's dangerous for you to be here."],[10458,10575,"I..."],[10579,10845,"I'm just an unwanted orphan."],[10850,11037,"I don't have a mommy or daddy."],[11129,11186,"I'm dying,"],[11189,11280,"only getting 3 months left to live."],[11340,11492,"My uncle is after my fortune."],[11551,11655,"Rather than letting him win,"],[11658,11839,"I'd rather give my money to this poor child."],[11912,11971,"So she could live"],[11972,12098,"a stable life."],[12367,12437,"Emma."],[12550,12781,"Would you like to have a daddy?"],[12841,13164,"Does he want to be my daddy?"],[13208,13329,"Of course I do."],[13366,13466,"But..."],[13470,13695,"Nobody wants me."],[13741,13841,"Come here."],[14108,14183,"Emma."],[14375,14608,"Then I'll be your daddy, okay?"],[14612,14816,"Then... Will you hit me?"],[14820,15070,"Will you let me eat enough?"],[15091,15225,"I won't hit you."],[15279,15395,"I will protect you."],[15408,15520,"Whatever you want,"],[15550,15650,"Daddy will buy it for you."],[15704,15816,"From now on,"],[15841,16012,"you're the Hayes family's little princess."],[16079,16245,"No one will ever bully you again."],[16277,16496,"Daddy! Daddy!"],[16501,16548,"Good girl."],[16834,16910,"That's odd."],[16951,17041,"My lungs"],[17062,17217,"actually don't hurt as much."],[17241,17450,"Emma, let's go home."],[19591,19645,"Mom."],[19683,19820,"Why aren't you resting in your room?"],[19825,20000,"The doctor said you need bed rest."],[20087,20304,"I know my own body."],[20341,20429,"Andrew,"],[20433,20725,"I don't have much time left."],[20729,20829,"Mom,"],[20833,21037,"you'll live a long life."],[21129,21329,"Emma."],[21370,21458,"Say hello to Grandma."],[22341,22479,"Who is she?"],[22520,22620,"Mom."],[22625,22800,"Her name is Emma."],[22804,22975,"She's the daughter I just adopted."],[23012,23150,"You always said"],[23170,23337,"this house was too quiet."],[23358,23487,"With Emma keeping you company,"],[23491,23637,"the house will surely liven up."],[23935,24033,"If I'm gone,"],[24060,24164,"Emma can take my place"],[24165,24261,"and keep my mom company."],[24645,24716,"Hello, Grandma."],[24750,24941,"I'm Emma."],[25156,25226,"Hello, sweetie."],[25301,25387,"Emma is such a good girl!"],[25950,26020,"Grandma."],[26025,26287,"Why are you tied up with iron chains?"],[26291,26445,"I'll help you."],[27637,27691,"Mom!"]],"2":[[12,87,"Emma,"],[97,179,"what did you do?"],[191,291,"Andrew,"],[341,470,"even though I couldn't see"],[491,637,"the chains Emma mentioned,"],[654,1037,"my body feels so much better."],[1108,1304,"I no longer feel chest pains."],[2012,2062,"Emma,"],[2158,2237,"did you say Grandma"],[2275,2375,"was tied up with iron chains?"],[2541,2625,"Yeah."],[2675,2837,"But I've already"],[2854,3137,"thrown the chains away for Grandma."],[3144,3211,"Daddy,"],[3233,3420,"Grandma will live a long life."],[3510,3602,"Iron chains?"],[3654,3773,"Why couldn't I see them?"],[3831,3884,"Could it be that"],[3914,4094,"Emma can see things that others can't?"],[4133,4220,"Andrew,"],[4241,4329,"perhaps Emma"],[4383,4475,"can really see things"],[4479,4633,"that are invisible to us."],[4829,4916,"Daddy."],[4962,5200,"Did I do something wrong?"],[5512,5608,"You didn't do anything wrong."],[5641,5816,"You did a great job!"],[5820,5937,"You are Grandma's"],[5941,6087,"Little Lucky Sweetie."],[6300,6395,"Grandma,"],[6400,6575,"I'm not a Lucky Sweetie."],[6633,6816,"I'm a jinx."],[6825,7137,"They all called me a jinx."],[7175,7425,"A pitiful wretch no one wants."],[7670,7850,"Come here, Emma."],[8091,8287,"Emma, look."],[8316,8420,"Because you came here,"],[8475,8637,"Grandma is all better."],[8720,8829,"Emma is clearly"],[8833,8983,"a Little Lucky Sweetie!"],[10012,10270,"Daddy prepared some gifts for you."],[10891,10958,"Look, Emma."],[11695,11887,"Hello, Miss Emma!"],[12679,12804,"Wow."],[12808,13020,"What a beautiful dress!"],[13500,13866,"Emma, you can have all these gifts."],[14341,14433,"Thank you, Daddy."],[14439,14631,"He's so good to me!"],[15350,15391,"Mr. Hayes,"],[15408,15487,"I've secured the invitation"],[15491,15545,"to the auction."],[15562,15666,"But getting the project"],[15670,15729,"through a blind box auction"],[15733,15854,"is too risky!"],[15874,16054,"No matter how risky this auction is,"],[16150,16266,"I must go."],[16529,16629,"Andrew,"],[16691,16791,"blind box auctions"],[16833,16941,"can lead to bankruptcy,"],[16975,17070,"or even death!"],[17091,17225,"You can't go!"],[17283,17408,"This auction"],[17441,17587,"is our family's only chance."],[17725,17795,"I have to go!"],[17875,17950,"Andrew,"],[17983,18125,"I heard that admission"],[18129,18245,"requires proof of funds."],[18279,18358,"Without money,"],[18404,18504,"We aren't even qualified"],[18508,18625,"to enter the auction."],[18654,18804,"Do we have enough money?"],[18945,19050,"Mom,"],[19104,19170,"I've already applied"],[19175,19287,"for a bank loan."],[19391,19504,"I'll get an answer today."],[19668,19833,"Daddy spent a lot of money"],[19840,19991,"buying gifts for Emma."],[20049,20259,"I want to help him earn money."],[21237,21354,"Really?"]],"3":[[29,100,"Really?"],[158,245,"That's great!"],[391,425,"Mom,"],[462,616,"the bank approved our loan."],[637,708,"We finally have the funds"],[712,854,"to attend the auction."],[891,1104,"My tummy is rumbling..."],[1341,1387,"Emma."],[1441,1658,"Cathy will take you to eat, okay?"],[1779,1875,"Miss Emma。"],[1916,2112,"I'll take you to eat something yummy."],[2308,2404,"Dad, you've worked hard."],[2412,2579,"You need to eat too."],[2791,2908,"Grandma also needs to eat"],[2925,3045,"to stay healthy."],[3120,3225,"You're so sweet."],[3300,3387,"You go eat first, Emma."],[3433,3575,"Dad will join you in a bit, okay?"],[3625,3687,"Okay."],[3733,3887,"Take her to get changed."],[4325,4416,"Take these gifts"],[4458,4637,"to Emma's room."],[4662,4750,"Yes, sir."],[5012,5087,"Andrew,"],[5091,5187,"have you finished investigating"],[5191,5262,"Emma's background?"],[5325,5400,"I have."],[5433,5487,"Sharon Shaw"],[5491,5570,"gave money to her secret lover,"],[5604,5704,"and Emma caught her."],[5750,5870,"She was afraid Hank would know this."],[5912,6050,"So she framed Emma for stealing,"],[6054,6175,"and called her a jinx."],[6241,6354,"She tried to send her back to the orphanage."],[6525,6629,"That couple"],[6633,6737,"is worse than animals."],[6820,6958,"Since Emma came to our family,"],[7000,7137,"my health has been much better."],[7212,7404,"Our loan was approved."],[7462,7637,"Emma is clearly a lucky charm."],[7804,7850,"Mom."],[7883,7979,"This time,"],[8008,8104,"I want to take Emma with me"],[8108,8175,"to the auction."],[8208,8329,"I'll take this chance"],[8341,8487,"to let everyone know it."],[8541,8691,"Emma is my daughter."],[8837,8950,"No one will ever bully her again!"]],"4":[[533,716,"Grandma, Dad, dinner's ready."],[791,837,"Okay."],[929,1016,"Let's go."],[2120,2175,"Dad!"],[2208,2404,"Andrew."],[2408,2520,"Son, what's wrong?"],[2712,2808,"Are you okay?"],[3000,3045,"Dad."],[3091,3216,"Dad, what's the matter?"],[3220,3325,"Are you alright?"],[3550,3641,"I'm fine."],[3725,3808,"Just a little tired."],[4330,4463,"Dad, drink some water."],[4479,4670,"You'll feel better if you drink it."],[6062,6166,"Weird."],[6170,6320,"After drinking the water Emma handed me,"],[6325,6458,"my lung pain is gone,"],[6462,6616,"and my body feels much lighter."],[6700,6745,"Dad,"],[6762,6912,"do you feel any better?"],[7041,7137,"Come here, Emma."],[7591,7733,"I feel much better."],[7845,7920,"Emma."],[7975,8050,"Tomorrow,"],[8091,8141,"I'm going to take you"],[8145,8225,"to have fun at the auction."],[8275,8337,"How does that sound?"],[8375,8483,"Yay, great!"],[8500,8587,"I love"],[8591,8754,"going out to play with Dad."],[11475,11579,"That sick a*shole."],[11583,11687,"Why hasn't he kicked the bucket yet?"],[11758,11875,"Was the poison we used"],[11920,12004,"not a strong enough dose?"],[12083,12129,"Shut up!"],[12233,12320,"Take this secret"],[12325,12412,"to your grave!"],[12458,12745,"We've blocked off all of Andrew's paths."],[12750,12975,"How can he still attend the auction?"],[13075,13154,"Why did Andrew"],[13179,13366,"bring a d*mn girl to the auction?"],[13437,13575,"Does he think this is a playground?"],[13845,13995,"Haven't you heard?"],[14083,14195,"Andrew picked up"],[14200,14316,"a stray girl on the street."],[14348,14465,"He even made her"],[14485,14658,"the Hayes family heiress."],[14804,14966,"He gave the family fortune to an outsider,"],[14970,15108,"instead of me, his uncle."],[15112,15237,"Andrew Hayes."],[15241,15308,"I'm going to make you"],[15312,15545,"lose everything at today's auction!"]],"5":[[1308,1362,"Ladies and gentlemen."],[1366,1650,"Welcome to the Quinn family's"],[1683,1837,"Mystery Box Auction."],[1858,1920,"This year,"],[1941,2170,"we're playing something a little different."],[2525,2604,"Sir Quinn,"],[2670,2850,"every mystery box is marked with a price."],[2900,3020,"But the value inside"],[3025,3125,"has nothing to do with"],[3150,3245,"the price on the tag, right?"],[3325,3416,"Correct."],[3500,3566,"Ladies and gentlemen,"],[3587,3770,"investment carries risk."],[3804,4150,"So, choose carefully."],[4241,4354,"I heard Sir Quinn"],[4358,4495,"even put Quinn Group's"],[4500,4650,"upcoming partnership projects"],[4654,4800,"inside these mystery boxes."],[4854,5245,"If we can secure those contracts,"],[5300,5466,"we'll make a fortune!"],[5662,5750,"These mystery boxes"],[5754,5858,"all look exactly the same."],[5883,5945,"Trying to win"],[5950,6079,"a partnership with Quinn Group"],[6083,6179,"is next to impossible."],[6212,6387,"The bigger the storm, the better the catch."],[6391,6587,"I can't wait to pick a box."],[6720,6787,"Daddy."],[6804,6895,"Are those pretty boxes"],[6900,7075,"all filled with toys?"],[7350,7491,"You could say that."],[7529,7633,"But different toys"],[7637,7737,"have different prices."],[7787,7887,"Whatever you like,"],[7912,7995,"I will buy it for you."],[8020,8087,"Daddy."],[8104,8187,"I already have"],[8191,8320,"so many toys."],[8341,8437,"You don't need to"],[8441,8579,"buy me any more."],[8808,8887,"A toy?"],[8929,9058,"That's hilarious!"],[9095,9187,"Andrew,"],[9204,9641,"is this girl you adopted on the street a fool?"],[9779,9925,"My daughter said it's a toy,"],[9975,10087,"then it's a toy."],[10141,10208,"If you don't like it,"],[10275,10337,"suck it up."],[10850,10950,"Little girl."],[10979,11100,"It's you!"]],"6":[[33,108,"Little girl."],[141,241,"It's you!"],[300,454,"Hello, sir."],[525,579,"Emma,"],[658,758,"you actually know Sir Quinn?"],[783,845,"Daddy,"],[866,1008,"he fell down,"],[1045,1287,"and I helped him up."],[1312,1366,"Emma,"],[1425,1520,"you have such a kind heart."],[1695,1954,"Last time I had a heart attack and fell,"],[1958,2129,"if Emma hadn't helped me up,"],[2133,2245,"I would be dead by now."],[2300,2383,"Since then,"],[2387,2595,"my heart condition has improved a lot."],[2600,2787,"This little girl is my savior!"],[2875,2933,"Emma."],[2979,3104,"For all the mystery boxes here,"],[3125,3262,"pick whichever one you want!"],[3312,3416,"And I'll buy it for you!"],[3475,3670,"Andrew is so lucky!"],[3708,3845,"With the Quinn Group on his side,"],[3862,4045,"his company will definitely survive."],[4112,4183,"If it were me,"],[4187,4354,"I'd definitely pick the most expensive box."],[4358,4487,"It's not my money anyway."],[4625,4716,"Sir."],[4720,4820,"Thank you."],[4875,5245,"But I can't just take gifts from others."],[5500,5562,"Emma,"],[5591,5700,"whichever mystery box you like,"],[5704,5837,"just tell Daddy,"],[5870,5958,"I'll buy it for you."],[5991,6045,"Daddy,"],[6050,6258,"why are some boxes gold"],[6262,6429,"and others black?"],[7258,7337,"Gold?"],[7358,7437,"Black?"],[7475,7529,"Andrew."],[7600,7737,"Is this girl you adopted"],[7779,7937,"colorblind or something?"],[8358,8425,"Daddy,"],[8429,8558,"I really saw it."],[8562,8720,"Gold and black boxes."],[8933,9016,"Don't be scared, Emma."],[9066,9158,"You're right."],[9270,9412,"Whatever color my daughter says it is,"],[9425,9550,"that's the color it is."],[9679,9720,"Emma,"],[9754,9845,"pick whichever color"],[9858,9954,"you like best."],[10937,11158,"This mystery box looks the cheapest."],[11162,11366,"I can't let Daddy spend any more money."],[11662,11708,"Daddy,"],[11716,11837,"I like this one."],[11891,11966,"Okay."],[12112,12187,"Little girl,"],[12204,12287,"are you stupid?"],[12324,12387,"Your dad's company"],[12391,12475,"is about to go bankrupt."],[12500,12537,"Why didn't you"],[12579,12687,"pick the most expensive one?"],[12741,12820,"Andrew."],[12858,13075,"Letting a fool be your heiress"],[13120,13258,"is just ridiculous!"],[13312,13504,"I'm not a fool!"],[13508,13650,"People who talk nonsense"],[13654,13800,"will get rotten mouths!"],[15125,15187,"Dad!"],[15537,15570,"Dad!"],[15608,15687,"Your mouth is rotting!"],[15750,15900,"Your mouth is rotting too!"],[16041,16187,"Is this kid a little oracle?"],[16283,16325,"Daddy,"],[16341,16441,"this is for you."],[16679,16787,"Thanks, Emma."]],"7":[[683,729,"Emma!"],[825,962,"Emma only spent $990,000."],[966,1100,"But we got the land worth $30 million!"],[1650,1708,"What?"],[1758,1858,"How is that possible?"],[2029,2200,"A $990,000 mystery box"],[2225,2404,"contained a contract worth a fortune!"],[2854,3025,"A contract worth $30 million."],[3050,3266,"Emma has such good luck!"],[3437,3508,"See that, everyone?"],[3570,3658,"I told you before."],[3770,3875,"The price on the mystery box"],[3916,4083,"and the value of the items inside"],[4187,4308,"have nothing to do with each other."],[4991,5008,"Dad,"],[5062,5141,"these two boxes are the cheapest."],[5241,5400,"There must be good stuff inside."],[5604,5637,"Mr. Hayes,"],[5675,5770,"sell me one of those boxes."],[5812,5887,"I'll give you $20 million."],[5933,6008,"I'll offer $30 million!"],[6062,6216,"I'll offer $35 million!"],[6325,6437,"Sorry."],[6487,6575,"I'm not selling!"],[6941,7066,"Sir Quinn, good for you."],[7125,7270,"You hid the good stuff"],[7308,7537,"in the corner."],[7591,7754,"Good thing you were quick, son,"],[7800,8000,"You managed to snatch the treasure."],[8091,8125,"Dad,"],[8179,8270,"let's hurry and open it."],[8341,8412,"Maybe there's"],[8454,8695,"a partnership contract with Quinn Group!"],[9870,9920,"Daddy,"],[9933,10037,"turns out adults"],[10041,10191,"like playing with toys, too."],[10200,10300,"Toys?"],[10362,10479,"Could the mystery boxes"],[10491,10650,"Brandon bought for $15 million"],[10658,10866,"be only with toys inside?"],[12375,12454,"Ultraman figures."],[12578,12640,"What's going on?"],[12750,12808,"Brandon!"],[12858,13020,"You spent 15 million"],[13033,13170,"just to buy two Ultraman figures?"]],"8":[[58,162,"Did Emma know all along"],[166,329,"there were Ultraman figures inside?"],[354,404,"Um..."],[458,591,"Impossible!"],[595,729,"She spent $990,000"],[733,891,"and got a contract worth a fortune!"],[908,1062,"I spent $15 million"],[1066,1204,"just to find Ultraman figures!"],[1208,1350,"There must be something fishy going on!"],[1491,1666,"Are you questioning the Quinn family"],[1670,1791,"of rigging the mystery boxes"],[1795,1954,"to scam people out of money?"],[1958,2037,"Sir Quinn"],[2041,2120,"isn't hosting an auction"],[2125,2208,"for the first time."],[2212,2304,"You're the one with bad luck."],[2308,2412,"How dare you question Sir Quinn?"],[2416,2500,"Brandon,"],[2504,2670,"thank God you didn't sell that box to me."],[2675,2725,"Otherwise,"],[2729,2837,"I would have lost my shirt."],[2841,2983,"This is so thrilling."],[2987,3066,"I don't even know"],[3070,3166,"which one I should pick."],[3170,3204,"Exactly!"],[3483,3566,"Emma,"],[3604,3737,"whichever mystery box you like,"],[3741,3862,"just go pick it."],[3912,4004,"I'll buy it for you."],[4008,4133,"I have money."],[4233,4341,"Andrew,"],[4345,4458,"are you going to"],[4462,4575,"let a little girl"],[4579,4770,"pick a mystery box for you?"],[4775,4870,"Be careful."],[4875,5050,"Don't lose everything."],[5175,5329,"Uncle Victor."],[5333,5550,"You'd better worry about yourself."],[5591,5816,"Stop letting Brandon pick blindly."],[5820,5895,"After all,"],[5941,6066,"his judgment"],[6120,6258,"is worse than a child's."],[6516,6658,"But a 30-million-dollar contract"],[6662,6804,"can't solve my company's problems."],[6833,7016,"I might as well make a big bet."],[7016,7175,"Go ahead."],[7175,7258,"Daddy believes in you."],[7366,7495,"Do the glowing boxes"],[7500,7654,"all have good stuff inside?"],[7658,7900,"I wanna give all the good things to Daddy."],[7904,8045,"So Daddy will be happy."],[8354,8479,"Daddy, this one."],[8525,8600,"Okay."],[8750,8808,"This one."],[8862,8925,"And this one."],[9050,9187,"Let's go pick a few, too."],[9191,9350,"Don't let them take"],[9354,9441,"all the good stuff."],[12050,12175,"Dad!"],[12179,12333,"We spent 50 million"],[12337,12570,"and got a land worth 100 million!"],[12575,12825,"We made money on this deal!"],[12929,13108,"That's a hundred million!"],[13370,13491,"Andrew,"],[13495,13650,"you let this little girl"],[13654,13937,"spend 300 million picking mystery boxes."],[13983,14129,"What did you get?"],[14179,14266,"Open it up"],[14270,14458,"and let everyone see!"],[16962,17087,"Why is it a rock?"],[17170,17337,"You spent ten million"],[17341,17520,"and got a lousy rock."],[17641,17745,"Little girl,"],[17750,18020,"you've really ruined Andrew!"]],"9":[[62,225,"I'm sorry, Daddy."],[229,479,"I think I messed up."],[570,716,"You didn't mess up."],[733,858,"You're a good girl."],[954,1354,"We can keep this rock at home."],[1358,1537,"It'll make for a nice decoration."],[1641,1804,"Emma picked this box."],[1808,1991,"She must have had her reasons."],[2100,2175,"Wait."],[2241,2329,"Let me see that."],[2404,2537,"This is a rough stone."],[2658,2775,"The skin is tight,"],[2791,2904,"and the texture is unique."],[3058,3170,"Emma,"],[3208,3383,"can I cut it open"],[3387,3570,"to take a look?"],[3662,3787,"Sure!"],[3895,3945,"Hurry up."],[3950,4120,"Bring the stone cutter over."],[5854,5929,"Oh my God!"],[5933,6004,"My God! This jade..."],[6008,6100,"It's Imperial Green Jade!"],[6112,6195,"With this quality,"],[6200,6320,"it's worth at least $300 million!"],[6325,6508,"Andrew just made a fortune!"],[6808,6854,"Emma,"],[7125,7229,"once is a coincidence,"],[7233,7341,"but twice?"],[7345,7416,"Emma is clearly"],[7420,7600,"a blessed Little Lucky Sweetie."],[8054,8266,"Cut mine open, too."],[9369,9416,"Uh..."],[9787,9866,"What?"],[9891,9970,"How is this possible?"],[10029,10108,"Victor!"],[10112,10254,"You spent $50 million"],[10258,10404,"and bought a piece of scrap!"],[10766,10904,"I just don't believe"],[10908,11070,"every mystery box you pick"],[11091,11212,"is worth a fortune!"],[12252,12337,"How is this possible?"]],"10":[[425,479,"It's..."],[483,625,"It's a contract from the Quinn Group!"],[704,779,"Wonderful!"],[783,845,"Emma."],[845,958,"It's great!"],[958,1112,"Our company won't go bankrupt!"],[1675,1758,"I also got"],[1762,1879,"a deal with the Quinn Group."],[1908,2037,"But it's not as valuable"],[2041,2158,"as Andrew's project."],[2229,2437,"Oh, Brandon."],[2441,2704,"It seems your luck is bad, huh?"],[3000,3087,"Dad."],[3091,3154,"I..."],[3316,3378,"Uh..."],[3391,3570,"You useless trash!"],[3591,3737,"You lost so much money!"],[3975,4054,"Andrew."],[4083,4558,"Could you sell that Imperial Green Jade to me?"],[4591,4804,"I will offer $400 million."],[5012,5500,"$400 million?"],[5812,5925,"Sir Quinn,"],[5975,6066,"the mystery box"],[6100,6225,"was picked by Emma."],[6258,6416,"We should ask for her opinion."],[6420,6608,"Daddy, I agree."],[6620,6737,"If we sell the stone,"],[6741,6916,"Daddy will have money."],[6991,7070,"Alright,"],[7112,7200,"we'll do as Emma says."],[7375,7566,"Sir Quinn, here you are."],[8879,9064,"Oh my god! My gosh!"],[9085,9168,"Wow!"],[9204,9345,"It's full of contracts!"],[9404,9479,"Emma."],[9483,9629,"Are you helping your dad"],[9633,9837,"with taking on the Quinn Group's"],[9841,10029,"projects for the next year?"],[10112,10200,"Sir Quinn."],[10204,10429,"My dad is really lucky."],[10433,10620,"If you work with him,"],[10625,10800,"you'll make a fortune too!"],[10954,11029,"All right."],[11033,11087,"Andrew,"],[11091,11208,"tomorrow morning at nine,"],[11229,11416,"you and Emma bring the contract"],[11420,11529,"to my office."],[11533,11779,"We'll discuss the partnership details together."],[12145,12220,"Oka