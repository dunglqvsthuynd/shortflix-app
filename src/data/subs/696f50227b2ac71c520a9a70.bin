u"],[4458,4645,"partner with us instead?"],[4675,4837,"We'll make money together."],[4891,5254,"I always choose the partner I like!"],[5304,5358,"You two,"],[5383,5625,"get out of the Quinn Group right now!"]],"19":[[79,183,"Bad guy!"],[187,358,"Sir Quinn told you to leave!"],[425,570,"Go away!"],[1775,1820,"Dad,"],[1879,1966,"Andrew is partnering"],[1970,2066,"with the Quinn Group,"],[2112,2254,"you have to think of something!"],[2408,2529,"What are we going to do?"],[2695,2841,"Ever since Andrew"],[2845,3008,"adopted that little girl,"],[3075,3300,"his luck has been incredible."],[3320,3704,"But what if that little girl died?"],[3845,3895,"Dad,"],[3987,4133,"Andrew keeps such a close watch on her."],[4212,4320,"It's hard to catch her."],[4395,4570,"Then we'll cause him trouble"],[4645,4762,"to keep him busy."],[4958,5020,"That way,"],[5087,5258,"we can find a chance"],[5379,5533,"to kill that girl."]],"20":[[695,745,"Dad,"],[825,1045,"did you heart that sound?"],[1558,1687,"That sound is familiar!"],[2208,2266,"Hornets!"],[4395,4444,"Mr. Hayes,"],[4446,4520,"this is the contract"],[4523,4591,"Grandpa asked me to prepare."],[4604,4695,"If everything looks good,"],[4700,4787,"you can sign it."]],"21":[[975,1037,"Mr. Quinn,"],[1129,1266,"I promise I won't let you down."],[2554,2870,"I trust Emma's judgment."],[3625,3683,"Hello?"],[3875,3929,"What?"],[4008,4087,"I'll be right there!"],[4145,4229,"The deal is on hold."],[4408,4441,"Mr. Quinn,"],[4495,4595,"what happened?"],[4695,4783,"You should head back now."],[4858,4891,"Amelia,"],[4929,5000,"see them out."]],"22":[[129,179,"Mr. Quinn!"],[183,229,"Grandpa!"],[241,362,"What happened?"],[441,575,"Benjamin is in critical condition."],[612,758,"The doctor called and said,"],[762,1004,"he might die soon."],[1275,1354,"Grandpa,"],[1358,1466,"don't worry."],[1508,1641,"Benjamin has luck on his side."],[1645,1770,"He'll be fine."],[1891,2041,"Sir Quinn,"],[2045,2308,"I want to visit Benjamin."],[2408,2500,"Emma."],[2541,272