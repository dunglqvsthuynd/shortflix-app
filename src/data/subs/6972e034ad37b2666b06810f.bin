{"1":[[1562,1670,"Master."],[1675,1787,"Senior Brother."],[1816,2137,"I never hurt Faye during the duel!"],[2141,2254,"Please, I beg you."],[2258,2320,"Shut up!"],[2341,2433,"Genny,"],[2445,2658,"Master brought you back to the sect,"],[2662,2816,"and I taught you how to use sword."],[2820,2987,"We want you to uphold justice,"],[2995,3258,"not so you could hurt your peers!"],[3283,3366,"Today,"],[3379,3508,"I'll cripple your cultivation."],[3679,3737,"Do it!"],[5175,5379,"Senior Brother, no!"],[5383,5741,"No, I never hurt anyone! Never!"],[6316,6475,"Senior Brother, please!"],[6479,6583,"No, Senior Brother!"],[6587,6687,"Shut up."],[7441,7641,"You used your sword to hurt Faye."],[9391,9483,"I told you,"],[9562,9800,"I told you I never hurt Faye!"],[9825,10000,"Why won't you believe me?"],[10004,10179,"Why?"],[10379,10431,"Master,"],[10441,10604,"Genny is possessed!"],[10916,10987,"You wretch."],[10991,11233,"Why are you still in denial and won't repent?"],[11283,11425,"Now your inner demons control you."],[11437,11766,"You'll reflect on yourself in the Serpent Cave!"],[13158,13295,"Broadcasting her thoughts"],[13300,13495,"to control guys is a heroine trait now?"],[13495,13737,"Author's definitely on something"],[13754,13862,"What a scheming heroine."],[13866,14083,"Jealous of her Senior Sister's talents,"],[14087,14283,"she stopped at nothing to kill her."],[14304,14366,"Commenter above,"],[14370,14470,"you don't understand."],[14479,14620,"That's how scheming heroines are."],[14645,14745,"How else would she gather a harem"],[14750,14841,"and dominate the Cultivation World?"],[14854,14883,"What?"],[14966,15070,"What the hell?"],[15250,15370,"Just watch me roast you!"],[15375,15458,"Ah!"],[16016,16300,"Host vitality detected is draining."],[16354,16425,"Ah!"],[16462,16616,"Where am I?"],[16620,16779,"- Mom... - Host vitality detected"],[16783,16912,"- I want to go home. - is draining."],[16916,17037,"I want to go home."],[17062,17220,"It hurts so much."],[17225,17383,"Initiating repair mode."],[17533,17875,"Ah!"],[19758,19841,"Repair complete."],[19845,20008,"Initiating identity verification mode."],[20070,20258,"Host: Jenny Lane."],[20262,20395,"21st-century wage slave."],[20400,20633,"Cause of death: Falling into a sewer."],[20816,20979,"Original host: Genny Lane."],[20987,21100,"Cannon fodder side character."],[21104,21337,"Cause of death: Knocked off a cliff by her Master,"],[21341,21433,"falling into the Serpent Cave."],[21437,21608,"Warning: Insufficient energy."],[21642,21950,"What the hell? I transmigrated into a book?!"],[22004,22112,"And the System is out of energy"],[22116,22220,"and went offline early."],[22270,22420,"Do you have to screw me so hard!?"]],"2":[[25,120,"Baby."],[220,316,"Sys."],[386,494,"Baby."],[654,779,"Good God,"],[783,1079,"where on earth are you?"],[1100,1248,"Sys,"],[1287,1775,"where are you?!"],[1779,1904,"Boo-hoo."],[1916,2025,"Sys,"],[2050,2275,"how can I live without you?"],[2279,2483,"At least give me your number"],[2487,2687,"before you go offline!"],[3208,3350,"System!"],[5108,5300,"Help me."],[5304,5495,"Whoever you are,"],[5525,5766,"I can give you anything you want."],[6154,6200,"You perv!"],[6241,6354,"Let go of me!"],[9337,9537,"Danger to Host detected."],[9541,9750,"Activating Defense Mode."],[10183,10366,"Defending \"now\"?"],[10404,10600,"Who defends afterwards, huh?"],[10633,10754,"What kind of system are you,"],[10758,10858,"going offline daily!?"],[10866,11000,"Host, please don't snap."],[11004,11125,"Dispose the daily-off guy."],[11420,11550,"What have I done?"],[11554,11645,"I gave my first time"],[11650,11812,"to a fictional character."],[12462,12554,"You jerk."],[12558,12741,"Unfortunately, I hate blood,"],[12766,12891,"or I would have killed you!"],[13391,13575,"My head…"],[13616,13737,"Sorry."],[13791,13925,"Sorry, man."],[14358,14491,"I'm sorry!"],[14495,14787,"I didn't want to kill you. I swear!"],[16741,17012,"It's okay."],[17016,17170,"Just a fictional character."],[17216,17412,"Mom, I killed someone!"]],"3":[[179,295,"My Lord."],[366,441,"My Lord."],[604,758,"Those mortal hypocrites ambushed"],[762,916,"the Serpent King during his heat!"],[954,1000,"My Lord."],[1020,1187,"Bear with me."],[1587,1704,"I'll be quick."],[2791,2962,"Let me help you up."],[3025,3145,"My Lord,"],[3150,3300,"I'm so glad you're alright."],[3383,3541,"Did those hypocrites of Peak Sect hurt you?"],[3573,3816,"I'll slaughter everyone on Peak Sect!"],[3820,3887,"No."],[3941,4004,"What?"],[4095,4187,"My Lord,"],[4191,4320,"are you saying"],[4366,4566,"we shouldn't punished whoever ambushed you?"],[4633,4775,"But…"],[5025,5137,"Spit it out."],[5304,5354,"My Lord,"],[5416,5733,"you always believe in an eye for an eye."],[5770,5929,"Someone just stabbed you,"],[5937,6095,"why won't you seek revenge?"],[6100,6345,"It's impossible. Who are you now?"],[6629,6770,"Are you feeling okay?"],[6875,7200,"Zip it if you have nothing else to say."],[7275,7433,"It's annoying."],[7641,7754,"You made me say it."],[7791,7933,"Now you're salty."],[7983,8141,"Next time I'm just gonna nod."],[9066,9120,"What is this?"],[9125,9179,"Piggy!"],[9412,9516,"Watch out!"],[9769,9919,"Piggy!"],[11087,11229,"Home."],[11316,11570,"Sweet home…"],[11587,11762,"I finally made it."],[12345,12541,"Other transmigrators have systems"],[12545,12645,"to rule the world,"],[12700,12850,"but when I transmigrate,"],[12854,13120,"I get stuck with one that goes offline constantly."],[13137,13337,"I was a corporate slave in the real world,"],[13341,13441,"and now that I'm here,"],[13466,13712,"I'm a slave riding a pig."],[13787,14337,"I almost sold my kidney on my way home."],[14683,14862,"It's so miserable."],[14916,15120,"It's raining!"],[15187,15570,"Can anyone help me?"],[15741,15837,"Where did this smelly beggar come from?"],[15841,15908,"Shoo!"],[15995,16154,"I'm Genny."],[16179,16420,"The lady of the Lane family!"],[16450,16733,"Miss Lane is the head disciple of Peak Sect."],[16762,16854,"But you're beggar."],[16870,16933,"What a liar."],[17004,17037,"Wait."],[17145,17291,"You do look like Miss Lane."],[17387,17562,"Because I'm her!"],[17616,17712,"Master, Madam!"],[17716,17775,"Bad news."],[17779,17941,"Miss Lane has become a beggar!"],[17945,18112,"Wait!"],[18137,18341,"Take the pig I bought to the stable."],[18350,18566,"It's my ride home."],[18570,18700,"Okay."]],"4":[[520,658,"Slow down."],[662,808,"Don't choke."],[850,1041,"Sweetie, no one's gonna take it from you."],[1069,1208,"How did you get back?"],[1283,1375,"Honey,"],[1437,1579,"she rode a pig back home."],[1591,1687,"A pig?"],[1916,2083,"Ox carts and carriages were too expensive."],[2087,2258,"Pigs were the only thing cheap enough."],[2262,2412,"I didn't want to ride it, either."],[3270,3362,"I'm full."],[3462,3566,"Genny,"],[3570,3820,"did something happen at Peak Sect?"],[3979,4108,"Originally,"],[4112,4358,"Faye broadcast her thoughts on Genny"],[4362,4550,"and made her shunned by the whole sect then died."],[4554,4670,"After she died,"],[4675,4791,"the Lanes were wiped out"],[4795,4962,"during a city massacre."],[5000,5129,"In the cultivation world,"],[5195,5379,"ordinary people are less than ants."],[5425,5504,"So,"],[5537,5754,"after Genny Lane joined Peak Sect,"],[5779,5937,"they had been sending money"],[5941,6095,"and rare jewels to the sect."],[6150,6316,"They used the entire clan's resources"],[6320,6508,"to support her cultivation."],[6554,6670,"But in the end,"],[6675,6900,"all they got was her tragic death."],[6970,7141,"Peak Sect is fine."],[7320,7425,"It's me."],[7504,7666,"My cultivation has been destroyed."],[7782,7857,"Dad,"],[7879,7958,"Mom,"],[7983,8116,"from now on,"],[8140,8294,"I can never go back to Peak Sect."],[8345,8495,"What?!"],[8508,8629,"Your cultivation is destroyed?"],[8633,8800,"How is this possible?"],[9316,9409,"Mom, Dad,"],[9429,9583,"I've failed you."],[9595,9787,"I've failed your expectations,"],[9854,9995,"and those of our entire clan."],[10258,10350,"I can't let her parents"],[10354,10487,"know the truth."],[10504,10691,"Aside from hastening the Lane family's fall,"],[10695,10812,"it would serve no purpose."],[11454,11587,"Silly girl."],[11666,11808,"When your cultivation was crippled,"],[11812,11962,"no one took it harder than you."],[11966,12033,"That's right."],[12037,12087,"Genny,"],[12108,12195,"tell me,"],[12229,12466,"did it hurt when it happened?"],[12879,13037,"You don't blame me?"],[13170,13279,"Silly girl."],[13466,13800,"Perhaps we're not destined to produce an immortal."],[13858,13933,"Let it be."],[14008,14220,"Maybe it's fate."],[14633,14733,"At first,"],[14737,14904,"I thought they were just fictional characters."],[14966,15075,"But is that true?"],[15112,15279,"They feel so alive,"],[15283,15445,"with feelings and thoughts."],[15479,15662,"They are living people."],[15837,16025,"Why should they be ants,"],[16029,16241,"groveling at the feet of so-called immortals?"],[16245,16375,"They deserve better!"],[16387,16504,"Mom, Dad,"],[16516,16629,"don't worry."],[16633,16850,"So what if I don't belong in Peak Sect?"],[16858,17012,"I can still cultivate."],[17033,17291,"I'll protect you and the whole Lane family."],[18100,18150,"Genny!"],[18154,18225,"It hurts!"],[18229,18279,"Genny!"],[18300,18366,"What's wrong?"],[18370,18516,"Genny! Genny!"],[20079,20133,"Dr. Wayne,"],[20179,20425,"does Genny have some kind of incurable disease?"],[20550,20641,"Not at all."],[20678,20782,"The young lady is"],[20820,20925,"pregnant."],[20929,21083,"Pregnant?!"]],"5":[[1658,1745,"You vixen!"],[2237,2275,"Quinn."],[2450,2562,"My Lord."],[2566,2741,"Prepare a safe Cave"],[2745,2987,"for my seclusion."],[2991,3175,"I need to spend the rest"],[3225,3462,"of my mating season there."],[3562,3654,"My Lord."],[3683,3745,"But…"],[3750,3825,"Shut up!"],[3954,4008,"Yes."],[4012,4370,"Whoever prepares a cave for his seclusion,"],[4404,4652,"I'll flay him."],[4895,5033,"Greetings, Lady Vivian."],[5104,5216,"Mother."],[5231,5448,"No heir in five hundred years."],[5463,5613,"It's a disgrace!"],[5629,5904,"You have made me lose face."],[5941,6108,"Do you know what people are saying about you?"],[6145,6300,"That you're infertil,"],[6333,6525,"and that you're impotent!"],[6854,7041,"I want to focus on my cultivation."],[7066,7187,"I don't want children yet."],[7191,7287,"Hah."],[7291,7450,"The Serpent Clan"],[7454,7612,"are highly fertile,"],[7637,7820,"but our bloodline is too powerful."],[7837,8054,"Offspring survival rates are extremely low."],[8058,8216,"Since you came of age,"],[8267,8483,"I've waited 300 years for an heir."],[8487,8825,"This time, you will choose a female Serpent"],[8866,9062,"to spend your mating season with!"],[9108,9233,"She'll carry an heir!"],[9450,9570,"Come in, everyone."],[9720,10041,"Sweetie."],[10045,10145,"My Lord."],[10437,10558,"Sweetheart."]],"6":[[195,291,"Son,"],[295,687,"they're the robust female serpents in our clan."],[712,820,"I'm sure they can withstand"],[825,995,"the power of our bloodline."],[1570,1696,"Sweetie!"],[1696,1828,"My Lord."],[1902,2054,"My Lord."],[2054,2112,"You…"],[2137,2300,"My Lord."],[2325,2433,"You all…"],[2462,2558,"Stay back!"],[2562,2654,"My Lord."],[2654,2770,"Sweetie!"],[3070,3895,"- Honey. - My Lord."],[4691,4750,"Stop!"],[4887,4945,"Stop touching him!"],[5450,5512,"Hey,"],[5537,5758,"this little thing is glowing."],[6129,6300,"It's the Orifice Mystic Bead."],[6329,6404,"It's glowing."],[6408,6600,"The Serpent King has an heir!"],[6720,6816,"Mother,"],[6820,6966,"the Orifice Mystic Bead lit up."],[6987,7125,"I have a child."],[7166,7333,"I have a blood heir!"],[7959,8079,"An heir!"],[8300,8554,"I'm going to have an heir!"],[8575,8770,"Quick, take me to your Serpent Queen."],[8787,9004,"She's carrying your heir."],[9025,9220,"We need to take good care of her."],[9225,9291,"Otherwise,"],[9295,9654,"both the mother and the child might be in danger."],[10158,10354,"Mom, I killed someone!"],[10450,10600,"But she's a human girl."],[10658,10937,"She might not come to the Serpent Clan's territory."],[11045,11116,"What is it?"],[11279,11354,"Mother."],[11400,11558,"I'm going to the human realm."],[11633,11862,"I told you to find your Serpent Queen."],[11864,12091,"Why are you going to the human realm?"],[12959,13045,"That brat!"],[13050,13241,"He's getting more unruly as he grows up."],[13416,13500,"Miss Lane,"],[13566,13704,"once you drink the abortion medicine,"],[13708,13875,"there's no turning back."],[14316,14425,"Is one bowl enough?"],[14436,14504,"Huh?"],[14654,14787,"It should be."],[14936,15008,"No."],[15037,15116,"Get me a different one."],[15225,15287,"A different one?"],[15350,15408,"Yes."],[16025,16087,"If I'm drinking,"],[16129,16379,"I want the biggest bowl."]],"7":[[171,296,"Bad news!"],[417,625,"Your dad, he's in trouble!"],[654,762,"What happened to Dad?"],[786,900,"Your dad has always wanted to know"],[904,1112,"what happened to you in Peak Sect."],[1125,1279,"When he heard people from the Peak Sect"],[1283,1404,"had come to our Treasure Pavilion,"],[1412,1562,"he went to ask them why."],[1566,1725,"But somehow they got into an argument,"],[1750,1887,"and the Treasure Pavilion was smashed."],[1904,1966,"Your dad"],[1970,2208,"was also taken away by them."],[2366,2608,"Those people have gone too far."],[2629,2937,"How dare they show up here and bully us?"],[3000,3050,"Mom,"],[3054,3187,"I'll go get Dad."],[3200,3283,"Stay at home."],[3300,3375,"Genny,"],[3404,3562,"you lost your cultivation."],[3575,3804,"How can you fight people from Peak Sect?"],[3900,4025,"Mom, don't worry."],[4029,4212,"Even though I lost my cultivation,"],[4216,4379,"I'm still a force to be reckoned with."],[4416,4545,"I have my own ways to protect myself."],[4675,4716,"What?"],[4962,5045,"Brothers!"],[5050,5258,"Someone wants to mess with the Lanes!"],[5275,5491,"They're messing with your boss!"],[5495,5570,"Are we gonna get them?"],[5575,5795,"Get them!"],[5891,6000,"Grab your weapons!"],[6604,6708,"Follow me."],[7470,7645,"Your daughter got kicked out of Peak Sect."],[7683,7858,"Serves her right."],[7883,8050,"Just because she had a bit of talent,"],[8054,8175,"she disrespected everyone."],[8245,8579,"But I'm surprised she'd make it back alive."],[8620,8850,"My daughter is ten times better than you!"]],"8":[[121,225,"Old man,"],[266,375,"I won't kill you if you"],[395,662,"hand over the crown jewel of Treasure Pavilion."],[775,966,"I will spare your life."],[1045,1116,"Faye has been stuck"],[1120,1291,"at the Foundation stage."],[1302,1475,"She needs the Dragon Blood Fruit"],[1479,1575,"to make a breakthrough."],[1579,1766,"Once I get the Dragon Blood Fruit,"],[1770,1900,"I'll kill this old man"],[1904,2012,"and that b*tch Genny."],[2663,2722,"Pah!"],[3012,3220,"If it weren't for Genny,"],[3270,3337,"the Lane family"],[3341,3558,"would never have given the rare treasures"],[3575,3679,"to leeches like you for free!"],[3700,3787,"Without Genny,"],[3804,3995,"Peak Sect isn't worth"],[4000,4112,"jack sh*t to me."],[4120,4383,"You want the Dragon Blood Fruit for free?"],[4388,4570,"Keep dreaming."],[4575,4854,"I'd feed it to a dog than give it to you!"],[4900,5141,"You have a f*cking death wish!"],[5229,5286,"Stop!"],[5595,5670,"Genny!"],[5729,5837,"You b*tch,"],[5854,5979,"you aren't dead."],[6062,6229,"No, I'm not dead."],[6283,6525,"Junior Brother, why bother with"],[6529,6870,"someone who has lost her cultivation?"],[6875,6987,"I know,"],[6991,7233,"you want the Dragon Blood Fruit, right?"],[7237,7391,"I know where it is."],[7404,7550,"Can you please"],[7704,7950,"spare my father and me?"],[7983,8058,"Genny!"],[8116,8316,"I would rather die on our feet"],[8354,8487,"than live on my knees!"],[8513,8592,"Dad,"],[8604,8700,"save it!"],[8720,8941,"It's better to live in shame than die in glory!"],[9070,9145,"You!"]],"9":[[120,312,"Aft losing the cultivation,"],[412,604,"the high-and-mighty Senior Sister"],[679,1050,"is nothing more than a pathetic dog."],[1095,1279,"Yates Nash is just as brainless"],[1304,1612,"and full of himself as in the book."],[1616,1780,"Yes!"],[1783,2162,"I'm just a dog wagging its tail at your feet."],[2216,2404,"Junior Brother, if I recall,"],[2416,2625,"you haven't hit the Grain Avoidance stage, right?"],[2629,2829,"This trip down the mountain"],[2845,3045,"must have drained your spiritual power."],[3075,3133,"How about this?"],[3158,3412,"I'll take all the treasures in the shop"],[3416,3691,"and stew them to help you recover."],[3783,3858,"Good."],[3862,3995,"I'll use these treasures"],[4000,4120,"to replenish my strength."],[4150,4304,"Once I get the Dragon Blood Fruit,"],[4308,4500,"I'll silence these two."],[4958,5054,"Good."],[5183,5287,"Since you offered,"],[5391,5570,"scram and get it ready."],[5608,5687,"Yes, yes."],[5691,5862,"I'll go prepare it right now."],[6016,6091,"Genny,"],[6129,6304,"show some backbone!"],[6366,6445,"Dad,"],[6450,6541,"let's be real."],[6575,6662,"If we die,"],[6679,6779,"forget about backbone,"],[6783,6916,"we won't even have bones left."],[7104,7204,"Listen to me."],[7208,7291,"In a moment,"],[7304,7500,"I'll spike his food with arsenic."],[7554,7637,"Let's poison him to death."],[7641,7729,"Come on."],[7916,8020,"Coming, coming!"],[8120,8341,"Junior Brother, the food is here. Try it."],[8862,8962,"You're tricking me?"],[8975,9108,"The dishes have turned into paste"],[9112,9200,"because of your arsenics!"],[9229,9316,"Do you take me for a fool?"],[9662,9837,"Junior Brother, actually,"],[9958,10116,"this is a seasoning"],[10120,10250,"from my hometown"],[10254,10320,"called \"salad.\""],[10325,10500,"Try some. It's really good."],[10547,10634,"Salad?"],[10700,10820,"I'll slay you first!"]],"10":[[150,200,"You b*tch."],[254,312,"I'm gonna kill you!"],[404,508,"Fine, don't eat then."],[525,620,"Why pull a sword on me?"],[650,816,"Are you that salty to eat my food?"],[837,933,"Die!"],[1016,1220,"Critical crisis imminent detected."],[1225,1370,"Initiating Emergency Evasion Mode."],[1741,1825,"Dodging, huh?"],[2370,2462,"Why can't I aim you?"],[2491,2566,"Something's wrong."],[2608,2708,"This isn't right."],[2733,2858,"You've lost your cultivation."],[2883,2991,"Why can't I kill you?"],[3087,3208,"System! Sys!"],[3254,3420,"Is this the skill you gave me"],[3425,3575,"to stall for time?"],[3579,3854,"Even if he doesn't stab me to death,"],[3858,4012,"I'm gonna die from all this twisting!"],[4016,4125,"Talent Skill."],[4129,4291,"Loading... 98%."],[4295,4425,"Talent Skill."],[4429,4600,"Loading... 99%."],[4604,4704,"Talent Skill."],[4708,4850,"Loading... 100%."],[6662,6779,"Your cultivation isn't ruined!"],[6837,6937,"Awesome."],[6941,7045,"Instantly a master!"],[7087,7166,"I can finally"],[7170,7300,"go on a killing spree!"],[7391,7508,"Idiot."],[8650,8737,"Someone's behind you."],[8741,8862,"I'm not stupid."],[8970,9179,"How dare you bully my meal ticket?"],[9628,9812,"N-no, my apologies."],[9845,9970,"You have a death wish!"]],"11":[[370,625,"Turning your back on your enemy?"],[704,793,"You little bast*rd,"],[800,929,"you're staring death in the face."],[1220,1279,"Bi*ch!"],[1358,1516,"How could you ambush me?"],[1537,1616,"Dare let me heal up"],[1620,1700,"for a one-on-one duel?"],[2283,2529,"You're waiting for your help, aren't you?"],[2554,2812,"I see that coming long ago!"],[3345,3420,"Who's there?"],[6332,6408,"Whoa."],[6495,6662,"Hello, handsome."],[6933,7225,"Why does he look familiar?"],[7520,7600,"It's you."],[7833,7904,"You're not dead?"],[7945,8125,"You weren't just ruthless with me."],[8156,8262,"You show no mercy"],[8266,8412,"to anyone else, either."],[8416,8591,"If my investigation is correct,"],[8595,8729,"that dead man"],[8841,8979,"was your junior brother, right?"],[9608,9779,"You investigated me."],[9783,9920,"Are you reporting me to Peak Sect?"],[10512,10554,"No, I…"],[10558,10637,"Cut the cr*p."],[10687,10795,"Anyone who knows my secrets"],[10800,10887,"deserves to die."],[10929,11004,"Sword!"],[11975,12025,"You're dodging?"],[12237,12375,"Skill is on cooldown."],[13475,13525,"You…"],[13987,14075,"Handsome."],[14079,14154,"No."],[14283,14387,"Hero, spare me."],[14391,14566,"I know I messed up."]],"12":[[12,166,"I know I messed up."],[170,470,"Weren't you threatening to kill me?"],[783,962,"What are you talking about?"],[966,1241,"I've been stuck in bed for too long,"],[1258,1408,"I just needed to stretch a bit."],[1475,1620,"My bones are getting stiff."],[2012,2083,"What are you doing?"],[2350,2479,"Checking your body."],[2837,2979,"It's not appropriate."],[3091,3183,"Strange."],[3350,3520,"Your cultivation was there moments ago,"],[3595,3733,"but now it's completely gone."],[3837,4225,"Is that why you're surrendering?"],[4270,4408,"You surrender when you can't win,"],[4454,4525,"but if you can,"],[4670,4783,"you leave no survivors."],[5654,5791,"You're not sorry."],[5962,6100,"You're scared."],[6391,6600,"Man, you really"],[6662,6804,"know how to read people."],[7070,7187,"Everyone says the Serpent Clan"],[7191,7308,"is cold-blooded."],[7375,7466,"I beg to differ."],[7541,7820,"Hypocrites in the Cultivation World"],[7854,8037,"are far more cold-blooded."],[8162,8296,"You're a Serpent?"],[8358,8450,"Yes."],[8541,8745,"So, the child in your belly,"],[8850,8987,"don't even think about getting rid of him."],[9070,9287,"Our bloodline is very strong."],[9333,9483,"If he lives, the mother lives."],[9533,9616,"If he dies,"],[9817,10095,"he'll take the mother down with him."],[10241,10420,"And during a Serpent pregnancy,"],[10425,10795,"you need the father's pheromones to soothe him."],[10858,10983,"D*mn it."],[11008,11341,"The Serpent Clan is the most troublesome,"],[11420,11525,"especially during pregnancy."],[11554,11670,"They even need sex"],[11675,11975,"to soothe the fetus with the pheromones."],[11979,12116,"I seriously suspect"],[12120,12291,"the author wrote about the Serpent Clan"],[12295,12423,"for the smut!"],[13041,13116,"Behave."],[13175,13433,"I won't let you have a hard pregnancy."],[13437,13616,"Before your junior brother died,"],[13620,13854,"he crushed his life jade."],[13858,14000,"I assume the news of his death"],[14071,14237,"has already reached Peak Sect."],[14312,14479,"When they come, I'm afraid"],[14483,14679,"the entire Clouden City"],[14795,14925,"will be slaughtered."],[14990,15183,"As a former cultivator,"],[15187,15300,"you know better than anyone"],[15341,15808,"that mortal lives are weak and worthless."],[16170,16375,"I don't want the Lanes or Clouden gone."],[16379,16487,"Will you help me?"],[16570,16850,"Even if those Peak Sect b*tches don't come,"],[16854,17095,"I'll find them and put an end to everything."],[17166,17520,"It'd be best to let this man tear them apart."],[17550,17754,"Then I can keep the child myself."],[17779,17883,"If I help you,"],[18045,18258,"shouldn't you satisfy me first?"],[18475,18750,"You said that if the little snake egg lives,"],[18754,18862,"then I live."],[18929,19125,"I'd really like to know."],[19145,19262,"If I die,"],[19329,19612,"will he die with me?"],[19741,19862,"Are you threatening me?"],[19992,20095,"I wouldn't."],[20133,20420,"Just a little trick for self-protection."],[20475,20662,"I hope you don't mind, sweetheart."]],"13":[[1036,1120,"Faye!"],[1162,1250,"Are you okay?"],[1304,1437,"I'm fine, Senior Brother."],[1441,1662,"Just twisted my ankle."],[1666,1887,"Stop training. Come, sit."],[2194,2278,"Senior Brother,"],[2334,2479,"you were zoning out just now."],[2487,2575,"Were you thinking about"],[2579,2675,"what happened to Genny?"],[2775,2871,"It's all my fault."],[3108,3362,"If I had sucked it up,"],[3366,3612,"they wouldn't have found out"],[3616,3795,"Genny was bullying me."],[3800,3962,"And she wouldn't have been"],[3966,4204,"sentenced to the Serpent Cave."],[4266,4445,"This is Faye's voice."],[4450,4637,"Deep down, she feels sorry."],[4745,4937,"Faye, don't blame yourself."],[4979,5145,"She was thrown into the Serpent Cave"],[5175,5308,"because she brought it on herself."],[5358,5412,"But…"],[5466,5529,"Faye,"],[5704,5845,"you're too kind."],[5983,6079,"Bad news, Senior Brother!"],[6308,6383,"Something happened to Yates!"],[6529,6608,"What happened?"],[7337,7412,"Yates."],[7450,7562,"His Life Jade has shattered."],[7566,7658,"I'm going to see"],[7662,7783,"who has the audacity"],[7787,7975,"to lay a hand on a disciple of Peak Sect."],[9512,9637,"Master did throw that bi*ch"],[9641,9729,"into the Serpent Cave, right?"],[9762,9958,"I can't believe she murdered Yates!"]],"14":[[195,258,"How is that possible?"],[316,441,"How could it be her?"],[466,562,"Senior Brother."],[583,750,"Back then, we punished her"],[754,895,"because of what she did to Faye."],[900,1037,"How could she murder Yates?"],[1070,1179,"If we had known,"],[1208,1429,"we should have torn her soul apart right then!"],[1433,1570,"She should never be reincarnated!"],[1608,1741,"When Yates was murdered,"],[1800,1900,"he was at the Treasure Pavilion."],[1966,2241,"Why would he be there?"],[3266,3516,"Senior Brother, it's all my fault."],[3575,3745,"Yates knew that I couldn't"],[3750,3862,"break through the Foundation stage."],[3945,4020,"He wanted to"],[4066,4212,"get the Dragon Blood Fruit for me."],[4250,4412,"But he was murdered because of it."],[4791,5023,"Yates got killed because of me."],[5026,5191,"How can I face anyone and keep living?"],[5202,5344,"I might as well kill myself"],[5400,5529,"to atone for Yates!"],[5595,5679,"Junior Sister."],[5712,5808,"Faye."],[5829,5950,"What are you doing?"],[5954,6129,"Yates was killed by that b*tch, Genny,"],[6162,6291,"not you!"],[6354,6587,"But Yates was trying to help me"],[6591,6700,"get the Dragon Blood Fruit."],[6704,6750,"That's why he died."],[6754,6841,"Junior Sister,"],[6845,7066,"this isn't your fault."],[7083,7237,"Just for a mere Dragon Blood Fruit,"],[7262,7366,"she could be ruthless enough"],[7370,7483,"to kill her former junior brother."],[7604,7716,"I never expected"],[7734,7884,"she'd turn out this way."],[7970,8037,"Back then,"],[8091,8341,"we took whatever we wanted from the Lanes."],[8391,8504,"Murdering Yates"],[8508,8670,"was definitely calculated revenge."],[8675,8895,"Since she's provoking Peak Sect,"],[8950,9150,"I'll make her pay!"]],"15":[[883,1129,"Do think you Genny was captured by Peak Sect?"],[1233,1529,"After all, Yates was a direct disciple in the sect."],[1629,1812,"You really shouldn't have let Genny"],[1816,1954,"go to the Treasure Pavilion."],[2033,2233,"I didn't have a choice!"],[2245,2425,"If I had known it would put Genny in danger,"],[2429,2550,"I would've rather died with you"],[2554,2720,"than let my daughter take that risk."],[2725,2841,"What do we do?"],[2916,3050,"Dad, Mom!"],[3102,3181,"Genny!"],[3757,3915,"Genny, are you okay?"],[3984,4184,"Where have you been these days?"],[4212,4420,"Your mother and I were worried sick."],[4425,4662,"We were searching the whole town for you."],[4700,4900,"Chase Raine was such a jerk."],[4962,5120,"He's hundreds of years old,"],[5125,5312,"yet acts like he's never shagged a woman before."],[5445,5533,"Since you promised"],[5537,5670,"to help me deal with Peak Sect,"],[5675,5866,"come home with me then."],[5912,6112,"I'll tell my parents"],[6116,6212,"that you're a freelance master"],[6216,6283,"in the cultivation world."],[6287,6362,"Just show off a little"],[6366,6466,"in front of my parents,"],[6470,6591,"and they'll buy it."],[6595,6641,"Let's go."],[6670,6750,"Hold on."],[6887,6995,"You can't leave yet."],[7208,7408,"The baby is still unstable."],[7545,7679,"In my cave,"],[7683,7870,"I've set up an array to stabilize the fetus."],[7908,8091,"Now, we just need the two of us here."],[8433,8591,"Here for what?"],[9791,9837,"Dual cultivation."]],"16":[[21,308,"Are... are you serious?"],[312,420,"There's no time to waste."],[458,557,"Let's get started."],[1045,1150,"You big lecherous snake!"],[1154,1233,"Put me down!"],[1242,1441,"I don't believe a single word you say!"],[3758,3912,"Don't let your tail out."],[3941,4016,"Put it back!"],[4087,4241,"I've lost control."],[4300,4429,"Can't put it back now."],[4537,4629,"I'm sorry."],[5370,5516,"Why are you like this?"],[5550,5700,"You always answer,"],[5704,5829,"but never listen!"],[7770,7891,"Luckily, that stinking snake"],[7895,8087,"had urgent business at the Serpent Clan."],[8145,8316,"If he tormented me for a few more days,"],[8320,8516,"I'd be dead for sure."],[9012,9204,"Mom, Dad."],[9241,9341,"On my way back,"],[9345,9650,"I ran into an old friend from my cultivation days."],[9665,9838,"We hung out for a few days,"],[9840,10033,"and I didn't have time to send word."],[10066,10133,"I'm sorry."],[10300,10379,"What,"],[10395,10529,"you worried me to death."],[10679,10800,"Wait, something's wrong."],[10887,10962,"Genny,"],[11045,11112,"your eyes,"],[11116,11233,"why are there such dark circles?"],[11658,11779,"Ah!"],[11804,11958,"Maybe"],[11962,12191,"staying up all night talking with that friend"],[12241,12341,"really wore me out."],[12729,12803,"The past few days,"],[12804,12979,"Genny kept rejecting me."],[13016,13183,"She must be unsatisfied with my performance."],[13187,13433,"If the clan elders found out"],[13437,13645,"that the mighty Serpent King"],[13650,13829,"couldn't even satisfy his pregnant wife…"],[14150,14229,"My Lord."],[14233,14362,"I searched the entire library"],[14404,14562,"and brought every Pregnancy Manual"],[14566,14670,"I could find."]],"17":[[145,220,"Check this one out first."],[304,417,"18 Pregnancy Techniques."],[454,587,"It teaches you how to give birth to"],[591,750,"healthy snake babies."],[920,1070,"You hate it?"],[1216,1383,"What about this one?"],[1387,1475,"It teaches you how to become"],[1479,1562,"an excellent husband"],[1566,1758,"and comfort a pregnant female."],[1975,2112,"Doesn't seem useful, huh?"],[2508,2562,"This one."],[2600,2662,"Shocking!"],[2700,2925,"The greatest husband in 500 years"],[2929,3179,"compiled this Pregnancy Manual."],[3183,3291,"Don't miss out!"],[3391,3629,"Enough, stop reading."],[6145,6325,"What are you looking at?"],[6516,6675,"Is your wife expecting again?"],[6733,6879,"No, no."],[6883,6983,"She never…"],[7229,7337,"Never mind."],[7341,7445,"I'll zip it now."],[7466,7733,"I hate people who hem and haw."],[7825,7904,"Spit it out."],[7987,8054,"My Lord."],[8058,8212,"I'll be blunt."],[8216,8362,"When my wife was pregnant,"],[8366,8470,"I didn't need these books at all."],[8883,8995,"My Lord,"],[9100,9283,"if you still need to study these,"],[9325,9500,"is it because you can't perform?"],[9516,9595,"Shut up!"],[9716,9833,"You asked me to speak,"],[9866,10037,"now you want me to zip it."],[11212,11270,"System."],[11433,11508,"Sys."],[11646,11737,"Sys!"],[12066,12204,"Is there any way"],[12208,12362,"to quickly improve"],[12366,12495,"my cultivation?"],[12500,12650,"Based on my calculations,"],[12654,12791,"there are two ways for you"],[12795,12925,"to improve cultivation."],[12929,13058,"You can use Spirit Stones"],[13062,13254,"to buy manuals from the System Store."],[13258,13450,"One manual costs 300 Spirit Stones."],[13475,13587,"Only 300?"],[13666,13779,"We may not have much else,"],[13783,13920,"but we certainly have money."],[13945,14041,"We're loaded."],[14045,14145,"I want to buy it!"],[14150,14312,"Give me ten to start with."],[15916,15991,"System,"],[16012,16137,"how long will it take me"],[16141,16212,"to reach the Golden Core stage?"],[16227,16391,"To break through to the Golden Core,"],[16429,16541,"it only takes three hundred years."]],"18":[[175,250,"What?"],[333,495,"300 years?"],[612,854,"I'll be dead and buried by then!"],[858,1033,"Is there any shortcut?"],[1070,1195,"How fast do you want to break through?"],[1591,1675,"Within a hundred years."],[1679,1850,"diligent practice might make it possible"],[1854,2045,"with your talent."],[2170,2312,"No, no, no."],[2420,2495,"One week."],[2516,2750,"F*ck me. Are you out of your mind?"],[3566,3745,"Whatever."],[3766,3966,"Let's rot together."],[3979,4220,"When that mob Peak Sect attacks us,"],[4225,4404,"I'll be the first to hang myself."],[4412,4675,"You can go find a new host."],[4704,4933,"Though you'd probably be wiped out"],[4937,5016,"along with me, right?"],[5083,5275,"You put on this robotic act,"],[5279,5362,"but you're actually scared."],[5366,5520,"I can tell you're afraid to die."],[5616,5695,"Come on,"],[5766,5920,"why else would you always"],[5925,6254,"drain your energy to save"],[6258,6354,"when I'm dying?"],[6363,6587,"F*ck!"],[6916,7116,"I don't care how you do it."],[7204,7404,"I need to gain the power"],[7425,7654,"of a Supreme Expert in no time."],[7720,7841,"My dear Sys,"],[7879,8066,"it's up to you."],[8841,8962,"I don't want to bet everything"],[8966,9158,"on that stinky snake."],[9225,9370,"Who knows if I can lean on him?"],[9915,10137,"This is Genny's hometown, right?"],[10141,10325,"I'll use my artifact to satrt a fire"],[10329,10479,"and burn the whole city into ash."],[10604,10675,"Faye,"],[10720,10829,"guard me while I cast the spell."],[10854,10958,"Yes, Alex."],[15358,15504,"May I ask who you are, sir?"],[15516,15620,"My Junior Sister and I"],[15625,15758,"are direct disciples of Mr. Shore"],[15762,15870,"from Peak Sect."],[15933,16141,"We didn't know you were here. Forgive us."]],"19":[[15,166,"You ants."],[183,358,"Before my true form arrives,"],[400,475,"scram."],[581,731,"Otherwise, don't blame me"],[829,991,"for turning you all to ash."],[1016,1120,"You're just an avatar."],[1137,1258,"Why so cocky?"],[1266,1433,"I told you my sect's name."],[1437,1512,"Don't tell me"],[1516,1700,"that you don't even respect Peak Sect?"],[1704,1941,"Peak Sect is nothing."],[1945,2137,"Even that old fart Desmond"],[2141,2566,"only grovels in my presence."],[2583,2704,"How dare you insult my Master?"],[2720,2812,"Take this!"],[3454,3562,"You have a death wish."],[3866,3975,"Ah!"],[6308,6395,"Forgive me, sir."],[6433,6587,"Burning Clouden down"],[6716,6870,"was all my Senior Brother's idea."],[6933,7020,"I didn't want to come."],[7058,7250,"He forced me here!"],[7270,7500,"Faye, what are you saying?"],[7545,7695,"I forced you?"],[7708,7766,"You were the one..."],[7770,7837,"Shut up!"],[7920,8112,"Yes, you forced me!"],[8134,8212,"I've been sick of"],[8216,8333,"your behavior for a long time."],[8362,8487,"As a cultivator,"],[8495,8687,"you treat common people like ants."],[8712,8808,"People like you"],[8812,8945,"deserve to be struck by lightning"],[8950,9041,"and die a horrible death!"],[9087,9150,"You!"],[9245,9350,"Don't deny it!"],[9425,9500,"I…"]],"20":[[446,529,"Sir,"],[566,766,"Faye Seth at your service."],[1244,1344,"Wha service?"],[1537,1687,"Once I kill this eyesore,"],[1716,1916,"I will sever ties with Peak Sect for good."],[1987,2158,"Then I will belong to you."],[2237,2508,"Whatever you want me to do,"],[2520,2620,"I will do it."],[2800,2900,"You sl*t!"],[2954,3025,"I never expected"],[3058,3204,"you to be a sl*t!"],[3904,3979,"Sir,"],[3983,4100,"I can kill him right now"],[4104,4229,"as proof of my loyalty."],[4533,4670,"What a dog-eat-dog show."],[4725,4800,"Brilliant."],[4841,4941,"Truly brilliant."],[5054,5129,"Enough."],[5191,5362,"Now that I've watched your little performance,"],[5437,5791,"you can die in peace."],[8629,8862,"You rats from Peak Sect"],[8954,9150,"dared to ambush my clone."],[9512,9629,"Hold on."],[9908,10116,"Are you going to the Human Realm?"],[10145,10237,"Mother,"],[10320,10550,"what brings you here so late?"],[10587,10883,"The Serpent Clan received a secret report"],[10900,11125,"concerning the safety of the whole land."],[11162,11416,"You can handle it while in the Human Realm."],[11941,12079,"Yes, Mother."],[12187,12320,"The second barrier I set in Clouden"],[12325,12429,"is still intact."],[12454,12616,"I presume those rats"],[12641,12745,"wouldn't act rashly."],[12775,12866,"Once this matter is settled,"],[12912,13058,"I'll go to Clouden then."],[14537,14616,"Senior Brother."],[14637,14854,"You're finally here!"],[14883,15008,"Alex, Faye."],[15020,15141,"Are you two all right?"],[15302,15438,"Faye Seth!"]],"21":[[37,175,"Faye Seth!"],[329,475,"I was trying to stall for time"],[479,612,"until Senior Brother could save us."],[616,770,"I had to pretend to surrender."],[820,983,"But Senior Brother might not believe me."],[1012,1083,"Forget it."],[1087,1245,"As long as Alex survives,"],[1270,1458,"it doesn't matter if I'm misunderstood."],[1546,1625,"Alex,"],[1666,1900,"I know you won't believe me."],[1929,2087,"Everything Faye did"],[2100,2254,"was to save my life."],[2257,2333,"Faye,"],[2337,2570,"I believe you. You're so innocent and kind."],[2600,2745,"How could you possibly betray me?"],[2766,2829,"It's all right."],[2833,3045,"Alex, as long as you're safe,"],[3083,3220,"I'll do anything."],[3291,3383,"Senior Brother,"],[3445,3595,"it's all that woman Genny's fault."],[3645,3725,"If it weren't for her,"],[3745,3804,"Faye and I"],[3808,3862,"would never have encountered"],[3866,4075,"such a terrifying avatar of a Venerable."],[4412,4659,"Senior Brother!"],[4987,5137,"The plan to massacre Clouden"],[5154,5258,"is suspended."],[5267,5413,"Although I repelled"],[5413,5521,"that Venerable's avatar,"],[5620,5762,"I took a backlash."],[5833,5987,"That Venerable is terrifyingly powerful."],[6066,6170,"One wrong move,"],[6208,6312,"and I could endanger the sect."],[6529,6691,"It's my fault for being useless."],[6712,6945,"I couldn't even avenge Yates."],[7012,7208,"I've disgraced Peak Sect."],[7254,7512,"After all, the Lord of Clouden is formidable,"],[7541,7716,"having hired a Supreme Expert to guard the city."],[7862,7966,"Senior Brother,"],[8022,8129,"that expert"],[8133,8254,"is protecting Clouden."],[8304,8495,"He has nothing to do with Genny."],[8512,8625,"We just need to explain our intentions"],[8629,8725,"to the Lord of Clouden."],[8783,8916,"If we wipe out the whole Lane family,"],[8966,9075,"surely,"],[9092,9187,"the Lord of Clouden"],[9191,9308,"won't blame us."],[9775,9945,"It's the only way."],[9966,10079,"The dignity of Peak Sect"],[10083,10220,"will not tolerate provocation."],[10758,10900,"Brother, Alex,"],[10954,11070,"we don't need to do it ourselves."],[11125,11270,"Back when I was at Peak Sect,"],[11275,11383,"I heard Genny say"],[11425,11520,"that the Lanes"],[11525,11620,"has always been at odds with their clan."],[11695,11808,"Why don't we take this chance"],[11816,11929,"to intensify their conflict"],[11933,12170,"and reap the benefits?"],[12190,12270,"This way,"],[12279,12391,"we won't offend that"],[12395,12483,"Supreme Expert,"],[12495,12720,"and we can avenge Yates."],[13100,13329,"Mortals are cunning and despicable."],[13362,13491,"Using them to deal with the Lanes"],[13495,13591,"isn't a bad idea."],[13712,13829,"Is Junior Sister"],[13837,13954,"really as kind"],[13958,14058,"and innocent"],[14066,14220,"as we thought?"]],"22":[[483,595,"Come, Genny."],[1616,1825,"This is the Merfolk Spirit."],[1845,2062,"This is the Heaven Pearl."],[2162,2433,"And this is the Resurrection Grass."],[2537,2708,"I knew the Lane family was rich,"],[2712,2883,"but I didn't know they were this rich."],[2991,3170,"How many spirit stones is this worth?"],[3216,3608,"I finally get to live the high life!"],[4116,4162,"Genny,"],[4166,4304,"starting today, the Treasure Pavilion"],[4308,4404,"is officially in your hands."],[4429,4562,"This is the key to the secret chamber."],[5145,5262,"Don't worry, Dad."],[5266,5429,"I'll make sure our shop"],[5437,5570,"flourishes!"],[5604,5762,"Robert!"],[6200,6483,"Chief Lane, what brings you here?"],[6487,6808,"I brought our clansmen to take back"],[6812,6950,"all your shops."],[6962,7250,"This Treasure Pavilion is one of them."],[7291,7604,"Chief, this shop is my private property."],[7650,7766,"What gives you the right to take it?"],[7925,8129,"Because I'm the Chief of our clan."],[8187,8337,"We're all Lanes."],[8354,8525,"Why should you be filthy rich,"],[8550,8716,"while we have to live in such poverty?"],[8720,8854,"Exactly, Robert."],[8858,8970,"We're all from the same clan."],[9004,9087,"You made a fortune,"],[9091,9212,"but only care about your own pleasure."],[9229,9412,"You shouldn't be so selfish."],[9414,9458,"- Yeah. - That's right."],[9462,9575,"Robert,"],[9583,9783,"your daughter's cultivation is crippled."],[9787,9962,"She's been kicked off Peak Sect."],[9966,10224,"Let's see what you're capable of today."],[10304,10412,"You found out"],[10416,10529,"I was kicked off Peak Sect,"],[10533,10662,"that's why you're so cocky."],[10804,10987,"Dad, she's so pretty."],[11004,11312,"I want to marry her."],[11379,11595,"Don't push us too far!"]],"23":[[29,162,"Robert,"],[169,354,"my son has his eye on your daughter"],[363,591,"is a blessing she couldn't earn."],[595,649,"Hmph."],[651,833,"You can keep that blessing for yourself."],[837,1008,"You think you can marry my daughter?"],[1016,1062,"You!"],[1091,1208,"Tammy, get her!"],[1537,1683,"Cut the cr*p, old man."],[1725,1783,"Your daughter"],[1800,1991,"is no longer Peak Sect's golden girl."],[1995,2116,"She's just a useless cripple now."],[2229,2450,"Is my system loaded?"],[2579,2654,"Hyah!"],[2975,3062,"Ah! My hand!"],[3608,3766,"So what if my cultivation is crippled?"],[3843,4020,"Dealing with trash like you"],[4025,4200,"doesn't require any spiritual power."],[4600,4637,"Bind!"],[5133,5250,"The Super Binding Rope."],[5266,5441,"Looks like my guess was spot on."],[5466,5591,"You were put up to this"],[5595,5712,"by that bunch at Peak Sect."],[5745,5937,"That bunch must be hiding in the shadows."],[5950,6158,"This game of cat and mouse"],[6162,6291,"is actually quite interesting."],[6379,6408,"Genny."],[6454,6491,"What's this?"],[6816,7008,"This is a treasure"],[7012,7104,"the immortals at Peak Sect"],[7108,7250,"bestowed upon me."],[7354,7866,"If you hand over the Treasure Pavilion's vault key,"],[7891,8033,"I wouldn't mind"],[8062,8299,"letting my son marry your daughter."],[8316,8537,"To carry on our family line."],[8600,8754,"If you refuse,"],[8758,9062,"don't blame me for getting rough."],[9195,9370,"I'm getting a wife!"],[9558,9683,"You want your idiot son"],[9687,9766,"to marry my daughter?"],[9816,9958,"In your dreams!"],[9969,10166,"Have it your way, then."],[10179,10245,"Men!"],[10258,10404,"Break his legs!"],[10716,10862,"Don't you dare!"]],"24":[[1787,2000,"Good kick, Wifey!"],[2179,2232,"Chief,"],[2237,2333,"stop making things hard for my dad."],[2404,2566,"It's just a marriage, isn't it?"],[2570,2808,"I'll do it. I'll marry into your family"],[2869,2976,"and give you"],[2984,3166,"serveral sons."],[3704,3800,"See that?"],[3804,3883,"Robert,"],[3887,4004,"if you were as sensible"],[4008,4125,"as your daughter is,"],[4137,4366,"you wouldn't be suffering now."],[4517,4584,"Dad,"],[4646,4771,"you have to listen to me."],[4825,5188,"Better to stay alive, no matter what."],[5256,5394,"The last time Genny said that,"],[5398,5595,"was when Yates came looking for trouble."],[5620,5716,"Now the grass on his grave"],[5726,5830,"is three feet high."],[6066,6283,"I trust you."],[6850,7041,"That's more like it."],[7045,7208,"Where's the Treasure Pavilion key?"],[7220,7429,"Chief, the Treasure Pavilion key,"],[7458,7562,"my dad already gave it to me."],[7624,7944,"But I'm tied up with Super Binding Rope,"],[7980,8125,"it's hard to get to."],[8158,8233,"Hold on."],[8237,8316,"If the Chief unties you,"],[8320,8416,"what if you run away?"],[8595,8729,"Are you stupid?"],[8733,8837,"This is the Surper Binding Rope."],[8849,9002,"I'd have run long ago if I could."],[9010,9137,"Why would I wait until now?"],[9288,9529,"Dummy! Hahaha, dummy!"],[9570,9758,"Even my son knows"],[9762,9908,"how to protect his wife."],[11079,11162,"That's great."],[11504,11608,"Go on, go on."]],"25":[[391,466,"Freeze!"],[2237,2366,"System."],[2370,2629,"How many spirit stones is this thing worth?"],[2658,2787,"Host, this Merfolk Pearl"],[2791,2958,"is worth 3,000 spirit stones."],[2983,3141,"Just laugh if you want to."],[3145,3275,"We're close enough."],[3279,3358,"Can't you drop that"],[3362,3466,"fake robotic vibe?"],[3483,3670,"Host, do you intend to use this Merfolk Pearl"],[3675,3770,"to enhance your strength?"],[3779,3883,"Exactly."],[3925,4025,"To upgrade myself to"],[4029,4129,"the level of a Supreme Expert,"],[4145,4266,"how many more spirit stones do I need?"],[4283,4429,"You still need 100 million spirit stones."],[4433,4520,"Also,"],[4525,4695,"the power gained this way"],[4700,4787,"can only be used"],[4791,4900,"for fifteen minutes at a time."],[4904,5054,"Then there's a one-week cooldown."],[5062,5120,"After all,"],[5125,5195,"this isn't power"],[5200,5297,"you cultivated yourself."],[5312,5429,"Your body can't handle"],[5433,5562,"being in that state for long,"],[5579,5741,"or you'll explode and die."],[6179,6341,"It's fine, whatever."],[6387,6500,"If there's a shortcut,"],[6512,6691,"who'd bother doing it the hard way?"],[6704,6845,"Even if the Supreme Expert power"],[6858,7000,"only lasts fifteen minutes,"],[7008,7125,"that's enough time to pound"],[7129,7300,"those scumbags from Peak Sect"],[7316,7433,"into the dirt."],[7975,8037,"Out of my way!"],[8125,8266,"Look at you all,"],[8270,8391,"acting like country bumpkins."],[8395,8545,"So uncivilized."],[8562,8637,"Hmph."],[8650,8725,"Gah."],[8970,9070,"This..."],[9075,9179,"Quick,"],[9691,9775,"where are the treasures?"],[9779,9966,"You father and daughter,"],[9970,10054,"you played me for a fool!"],[10494,10570,"Oh my."],[10570,10775,"I've never heard such a filthy mouth."]],"26":[[733,816,"You!"],[850,995,"Hey, Dad."],[1020,1337,"Oh, Chief, please calm down."],[1341,1462,"Listen to my spin on this…"],[1498,1806,"Pfft, I mean, listen to my explanation."],[1808,2012,"Recently, the Treasure Pavilion"],[2016,2120,"was taking inventory,"],[2125,2329,"and we moved the treasures"],[2333,2500,"to another shop."],[2562,2908,"Didn't you want to take back our shops in Clouden?"],[2983,3120,"What's your point?"],[3125,3329,"I'll fetch the deeds right now"],[3341,3529,"and transfer them all to you for free."],[3554,3762,"The shops and the treasures inside"],[3795,3975,"will all belong to you and the Lane clan."],[4016,4179,"Giving it all to us?"],[4370,4595,"Handing over the shops to us so easily."],[4650,4833,"Could there be a trap?"],[4929,5183,"Oh, Chief."],[5204,5379,"Hearing you say that"],[5408,5700,"really breaks my heart."],[5779,5916,"Didn't you just say"],[5920,6166,"you wanted me to marry your son?"],[6170,6291,"As the saying goes,"],[6304,6570,"a married daughter is like spilled water."],[6575,6750,"From now on,"],[6750,6904,"I'll be on my in-laws' side."],[6925,7004,"Right?"],[7483,7549,"Dad."],[7596,7841,"Do as my wife says."],[7875,8091,"- Alright, alright. - Do as my wife says."],[8116,8262,"Geez."],[8366,8437,"Fine."],[8441,8616,"Then when we go to the other shops,"],[8666,8766,"you and Robert"],[8770,8870,"aren't allowed to come."],[8875,9004,"Okay, okay, okay."],[9008,9278,"I won't argue. How about"],[9312,9454,"we sign the transfer contract"],[9458,9579,"right now?"],[9625,9720,"Genny,"],[9825,9964,"you can't do this!"],[9968,10100,"Come on, Dad."],[10100,10300,"You already handed the shop over to me."],[10325,10454,"So what I do with it"],[10458,10575,"is my business."],[10587,10770,"Genny, you're ruining the family!"],[10812,11008,"I'm so furious!"],[11691,11812,"Is everything in order?"],[11875,12025,"No problems here."],[12037,12187,"Sign and seal it."],[12691,13037,"Oh no. It's over."],[13041,13391,"Our family legacy is ruined."],[13737,13854,"It's all ours now!"],[13858,14033,"- Yeah. - Let's go."],[14183,14258,"Freeze!"],[14837,14912,"Hmph."],[15038,15092,"Dad."],[15140,15341,"Just follow my lead in a moment."],[15695,15775,"Got it?"],[15779,15825,"Okay."],[16134,16391,"Dad, your acting was great!"]],"27":[[216,504,"Genny, your idea was brilliant."],[508,654,"They all think those shops make money,"],[692,884,"but they have no idea that in Clouden,"],[888,996,"for just a single shop,"],[1001,1212,"the taxes are absolutely killer."],[1216,1412,"Plus, the shops downtown"],[1437,1587,"are all in Mr. White's hands."],[1608,1687,"Just like you said,"],[1691,1783,"no matter how much we earn,"],[1787,1983,"we're just slaves to Mr. White."],[2008,2083,"Oh, right,"],[2100,2279,"are you sure the treasures in the other shops"],[2341,2458,"have all been safely transferred?"],[2508,2625,"Of course."],[2675,2741,"Now,"],[2745,2804,"that we've let them take"],[2808,2912,"those empty shops off our hands,"],[2916,3154,"they won't be able to return them"],[3158,3325,"whenever they please."],[3600,3695,"Miss, right now,"],[3700,3812,"the Lane clansmen"],[3816,3962,"are all wailing and screaming outside."],[4212,4312,"Let's go, let's go."],[4395,4554,"Come on, let's go feast our eyes."],[4770,4916,"Miss, a melon?"],[5070,5200,"Not that kind of feast."],[6441,6700,"Robert, get out here!"],[6729,6883,"The treasures in those shops"],[6887,7036,"have already been moved by you!"],[7041,7212,"We don't want those shops anymore!"],[7268,7546,"- Come out! Hurry up! - Get out here!"],[7548,7800,"Dad, I want a wife."],[7820,7956,"Dad."],[8004,8266,"That's what you're thinking about?"],[8358,8454,"I've been smart my whole life."],[8458,8658,"How did I end up with a son like you,"],[8662,8695,"an idiot,"],[8700,8783,"a moron!"]],"28":[[58,133,"Open up!"],[175,229,"Chief,"],[233,370,"Robert refuses to show his face."],[375,512,"What do we do?"],[525,625,"To scrape together the shop rent,"],[633,775,"we've drained our savings."],[812,900,"That's right, Chief."],[908,1062,"We've sold almost all the village land."],[1066,1166,"If we can't pay the taxes,"],[1170,1404,"Lord White will throw us all into jail."],[1420,1537,"Don't worry."],[1550,1733,"I have a way to force him out."],[1875,1983,"Robert!"],[1987,2162,"Don't forget,"],[2166,2279,"your mother's grave"],[2283,2408,"is still on our clan grounds."],[2475,2604,"If you don't come out,"],[2608,2816,"I'll dig up your mother's grave"],[2850,3091,"and crush her bones to feed the dogs!"],[3450,3545,"You're shameless!"],[3550,3654,"You're despicable!"],[3666,3758,"You're filthy!"],[3766,3879,"You're vile!"],[3983,4133,"Your son is an idiot!"],[4376,4586,"Chief!"],[4806,4995,"How do you know?"],[5137,5295,"I won't waste my breath"],[5300,5387,"arguing with you."],[5434,5491,"Thomas,"],[5523,5629,"take the men and charge!"],[5637,5729,"Those treasures"],[5733,5888,"must be hidden inside."],[5966,6041,"Get them!"],[7045,7145,"Good lad."],[7342,7675,"Why is it always me getting hurt?"]],"29":[[616,725,"You wretched girl,"],[766,962,"do you really think I'm a pushover?"],[1217,1297,"Bind!"],[1491,1537,"Miss!"],[1673,1832,"Chief really is powerful."],[1832,1913,"Yeah."],[1913,1993,"Indeed."],[3107,3182,"Nice rope."],[3228,3325,"I'll take it."],[3617,3700,"Old man,"],[3750,4095,"using the same trick twice is boring."],[4195,4325,"Those Immortals said,"],[4329,4466,"it was absolutely impossible"],[4470,4604,"to break free from a Surper Binding Rope."],[4633,4837,"H-How is this possible?"],[4887,5040,"Because you suck."],[5158,5216,"You suck."],[6400,6566,"Wifey,"],[6570,6691,"I'm scared."],[7079,7216,"Lord White sent word."],[7250,7433,"Any Lane who can't pay taxes"],[7479,7700,"will be thrown in the dungeon and tortured!"],[7754,8000,"Robert used to bring his wife"],[8004,8141,"to distribute money and grain."],[8145,8191,"It's all because the Chief"],[8195,8346,"insisted on seizing their shops."],[8354,8587,"Yeah. He's the one to blame."],[8591,8729,"What does that have to do with us?"],[8775,8829,"You!"],[8833,9162,"You ungrateful bunch!"],[9186,9358,"As the Chief of the Lane clan,"],[9360,9516,"I did all of this"],[9520,9650,"for your sake!"],[9654,9754,"Bullsh*t!"],[9800,9895,"You did it for"],[9900,10025,"that useless idiot son of yours!"],[10050,10137,"You actually want him"],[10141,10233,"to marry Genny?"],[10266,10520,"You're delusional!"],[10787,10891,"Take him away."],[11729,11820,"He stinks."],[11845,11912,"Walk on your own."],[12442,12616,"Those ingrates from Peak Sect"],[12620,12808,"devised such a vicious scheme"],[12825,13012,"to target me and the Lane clan."],[13079,13304,"We'll settle all scores, old and new."]],"30":[[445,570,"The Lane clan"],[575,695,"is a bunch of useless trash."],[729,883,"They cost me a Super Binding Rope for nothing."],[966,1112,"I'll go over there with my sword"],[1116,1250,"and slaughter that b*tch's whole family."],[1291,1450,"Let's see if she can still be so cocky."],[1825,1983,"If we make a move in Clouden,"],[2046,2265,"we might attract the Venerable himself."],[2316,2529,"We'd better put this aside."],[2575,2729,"Let's return for the Sect Tournament."],[2775,2912,"That's our top priority."],[2921,3050,"After all, the Tournament"],[3104,3304,"is held at Peak Sect."],[3871,3946,"Alex,"],[3991,4166,"let's do as he says."],[4170,4391,"The prizes for this year's Sect Tournament"],[4396,4517,"are better than in previous years."],[4558,4654,"Since we're the hosts,"],[4679,4800,"we have to shine"],[4829,5045,"and impress the other sects."],[5200,5266,"Faye,"],[5304,5370,"don't worry."],[5454,5650,"we will definitely win the prize for you."],[5825,5900,"Mmm."],[5929,6137,"Let's let that b*tch Genny"],[6191,6333,"live a little longer."],[6666,6741,"Miss,"],[6795,7062,"are you really competing in the Sect Tournament?"],[7201,7335,"Of course I am."],[7366,7554,"In previous Tournaments,"],[7595,7770,"all the heavenly treasures I won"],[7829,8062,"were snatched by those ingrates"],[8066,8173,"from Peak Sect."],[8179,8262,"This year,"],[8329,8462,"small as I am,"],[8508,8679,"I will reclaim everything!"],[8712,8787,"Miss,"],[8807,8954,"those are battles between immortals."],[9016,9133,"Your cultivation is ruined."],[9159,9316,"Can you really beat them?"],[9508,9650,"Don't worry."],[9712,9854,"Your lady"],[9858,9995,"is tougher than she looks."],[10059,10154,"Miss,"],[10215,10312,"if you're so tough,"],[10337,10437,"why are you riding a donkey"],[10441,10541,"to the Tournament?"],[10591,10762,"Everyone else is flying there."],[10833,10920,"I can't fly"],[10929,11114,"because of Chase, that stinky snake."],[11136,11258,"I fed so many rare treasures"],[11262,11350,"to the System,"],[11391,11541,"but it couldn't even make"],[11545,11625,"a flying sword."],[11703,11933,"Instead, it was all absorbed by the egg."],[12225,12333,"Once I get my power back,"],[12429,12654,"the first thing I'll do is skin you."],[12915,12995,"Miss!"],[13450,13525,"Miss, look!"],[13670,13862,"A flying carriage!"],[15369,15523,"If I hadn't been passing by"],[15563,15696,"and decided to check on you,"],[15792,16045,"I wouldn't have known you were bold enough"],[16100,16287,"to want to skin me."],[18191,18395,"What? You're coming as well?"],[18465,18540,"No, no, no."],[18577,18675,"I'm afraid of heights."],[18825,19050,"I'm also heading to the tournament,"],[19070,19183,"let's give her a ride."],[19250,19391,"Yes, Master."]],"31":[[54,245,"You look so handsome."],[550,845,"Your chain is really pretty."],[1016,1191,"Behave."],[1195,1520,"Do you want to do it in the carriage?"],[1658,1812,"You look hot."],[1833,2108,"Just like my scumbag ex."],[2150,2245,"Except,"],[2270,2504,"I'm still carrying his egg."],[2525,2704,"And he just walked out on me."],[2995,3100,"Why?"],[3225,3313,"Can't let him go?"],[3404,3470,"Hmph."],[3520,3650,"Who says I can't let him go?"],[3675,3850,"It's good that he left. Good riddance."],[3858,4016,"It's absolutely fantastic."],[4358,4516,"Don't tell me you can't get it up?"],[4516,4702,"Can't get it up?"],[5625,5912,"Aren't we taking the Serpent Queen?"],[6100,6308,"Let her walk there."],[6358,6429,"Huh?"],[8795,9012,"Who am I? Where am I?"],[9087,9229,"I think I dreamed about"],[9233,9437,"that stinking snake last night."],[10654,10729,"Hey."],[10791,10958,"Are you heading to"],[10962,11100,"the Sect Tournament?"],[11125,11462,"Mind giving me a ride?"],[11637,11910,"Is that the former head disciple of Peak Sect,"],[11911,12002,"Genny?"],[12729,12795,"Genny."],[12841,13008,"You were expelled from your sect"],[13058,13137,"and lost all your cultivation."],[13170,13300,"You actually want"],[13304,13450,"to compete in this year's Sect Tournament?"],[13454,13608,"We're all friends here."],[13620,13766,"That makes things easier."],[13829,13895,"Yeah,"],[13912,14066,"I'm going to the Sect Tournament."],[14137,14275,"Mind giving me a lift?"],[14279,14362,"I'll pay in spirit stones."],[14466,14629,"No need for spirit stones."],[14633,14787,"I don't mean to be rude,"],[14791,14916,"but now that your cultivation is ruined,"],[14937,15100,"and you can't even fly on a sword,"],[15133,15475,"you'll be in danger if you go."],[15533,15650,"Thank you for the concern."],[15654,15741,"But this Sect Tournament,"],[15783,15887,"I must go."],[15970,16187,"Back in the day, Genny was truly magnificent."],[16212,16295,"Even the Eldest Senior Brother,"],[16316,16495,"Justus, couldn't hold a candle to her."],[16512,16604,"With just her sword,"],[16616,16741,"she swept through every sect."],[16770,16950,"Now she insists on the Sect Tournament,"],[16954,17100,"probably because"],[17104,17216,"it's held at Peak Sect,"],[17233,17441,"and she wants to relive her glory days."],[17487,17587,"Back at that Sect Tournament,"],[17612,17733,"I lost to you in battle,"],[17754,17920,"and I've always wanted a rematch."],[17954,18175,"It's a pity. Since we can't be rivals,"],[18266,18362,"let's be friends instead."],[18383,18483,"I'll take you there."],[18520,18629,"Thank you."]],"32":[[183,233,"My friend."],[237,391,"Faster, faster, faster!"],[395,466,"Hold on tight."],[2375,2487,"Thanks for your help."],[2562,2625,"Don't mention it."],[2629,2712,"Want me to get you in?"],[2750,2833,"I have an invitation."],[2862,2950,"I can bring a guest"],[2954,3050,"to watch the Sect Tournament."],[3087,3162,"No need."],[3166,3229,"I actually"],[3233,3354,"plan to compete"],[3358,3454,"as a free agent."],[3529,3612,"What's a"],[3650,3712,"free agent?"],[3804,3941,"You know, a rogue cultivator."],[3945,4020,"But…"],[4058,4270,"But you don't have any cultivation power left."],[4275,4408,"For a rogue cultivator to convert,"],[4441,4591,"you have to pass a brutal test."],[4620,4691,"One wrong step,"],[4754,4908,"and you could die here."],[4975,5070,"Don't worry."],[5075,5212,"Since I dared to come,"],[5216,5395,"I have my own ways."],[5400,5520,"See you later."],[6459,6622,"I want to join the Sect Tournament."],[7470,7570,"How can it be you?"],[7623,7741,"Didn't the Master"],[7775,7854,"destroy your cultivation"],[7879,8000,"and throw you into the Serpent Cave?"],[8050,8300,"Even if you made it back alive,"],[8304,8433,"you're just a"],[8437,8566,"useless piece of trash."],[8616,8712,"What gives you the right to join"],[8716,8837,"the Sect Tournament?"],[8841,8958,"You really are a bunch of"],[8962,9095,"snobbish ingrates."],[9154,9258,"Back when we went to the Secret Realm,"],[9291,9462,"The original host saved him countless times,"],[9554,9662,"but now, they all just want"],[9712,9900,"to kick me while I'm down."],[10183,10408,"Isn't there a stone here to test spiritual power?"],[10412,10554,"In previous Sect Tournaments,"],[10558,10708,"anyone who passed the test"],[10712,10895,"could get an entry pass."],[12266,12320,"Hold on."]],"33":[[137,379,"You actually have the nerve to show up?"],[400,537,"Why wouldn't I?"],[1725,1970,"You deserve to die for murdering Yates."],[2100,2216,"Got proof?"],[2220,2366,"Of course."],[2370,2508,"Right before Yates died,"],[2512,2633,"he crushed his Life Token"],[2637,2754,"and transmitted the image of his death."],[2758,2804,"Shut up!"],[2966,3054,"Alex."],[3216,3245,"I…"],[3395,3479,"I seem to recall"],[3483,3629,"the United Sects has a rule."],[3679,3808,"Cultivators must not"],[3812,3883,"plunder mortal property"],[3887,4062,"or take their lives."],[4104,4350,"Or they'll be taken back to the United Sects"],[4354,4495,"for severe punishment,"],[4500,4650,"and their Sect"],[4691,4887,"will be penalized as well."],[4891,5037,"Yeah, exactly."],[5041,5112,"That's right."],[5133,5212,"That's the only way to restrain"],[5216,5358,"cultivators' behavior,"],[5379,5500,"so they don't act like gods"],[5545,5691,"and treat commoners like ants."],[5713,5808,"She's right."],[5962,6050,"Indeed."],[6383,6558,"Typical of Peak Sect."],[6562,6787,"You went to the mortal realm to pillage,"],[6829,6995,"but got killed instead."],[7000,7104,"It's bad enough you're evil,"],[7187,7329,"but are you useless too?"],[7383,7545,"Hahaha."],[7629,7766,"Lanny, you!"],[7970,8104,"Leaving Yates aside,"],[8250,8387,"you took advantage of the match"],[8412,8625,"to nearly destroy Junior Sister's cultivation."],[8679,8862,"That is an indisputable fact."],[8937,9045,"Genny,"],[9100,9195,"today,"],[9200,9354,"while everyone is watching,"],[9387,9500,"kneel before Junior Sister"],[9504,9600,"and kowtow to admit your guilt."],[9675,9850,"I might just put in a good word"],[9854,9975,"for you with Master."],[10154,10262,"If it were the original owner,"],[10304,10408,"she might actually kowtow"],[10412,10541,"just to return to the sect."],[10566,10662,"In the original story,"],[10666,10750,"this Justus"],[10754,10933,"is a master manipulator."],[10962,11058,"That way, he not only shifts the blame"],[11062,11195,"onto me,"],[11216,11412,"but also saves face for Peak Sect."],[12216,12312,"You little sl*t."],[12333,12512,"Even if you got lucky and survived,"],[12516,12620,"so what?"],[12733,12900,"Aren't you still just an ant"],[12920,13075,"fit only to kneel"],[13120,13291,"at my feet?"],[13408,13445,"Hmph."],[13733,13870,"Junior Sister,"],[13912,14100,"Hahaha."]],"34":[[916,1025,"You"],[1141,1325,"You actually hit me?"],[1329,1470,"I hit you, alright."],[1475,1654,"Why compete if you've got no skills?"],[1658,1758,"Don't you know I'm the best"],[1762,1870,"among the sect's"],[1875,1958,"youngest generation?"],[2016,2166,"Don't you know I used to be"],[2170,2275,"the sect's top swordswoman?"],[2329,2450,"What can a scrub like you"],[2454,2575,"possibly compete with me in?"],[2625,2791,"You're used to being a slacker."],[2795,2912,"When others go easy on you,"],[2916,2987,"you start thinking"],[2991,3100,"you're actually tough."],[3150,3283,"You really are shameless."],[3441,3504,"You"],[3508,3612,"You, you, you"],[3616,3741,"You what?"],[3745,3862,"You're weak, but you keep asking for it."],[3866,4004,"Who else would I hit?"],[4037,4133,"Sl*t!"],[4162,4237,"Don't you dare"],[4241,4354,"humiliate Junior Sister!"],[4933,5104,"Lanny, what do you mean?"],[5120,5212,"Genny is a guest"],[5216,5329,"that I brought here."],[5354,5500,"Is this how Peak Sect"],[5504,5641,"treats its guests?"],[5675,5754,"You"],[5795,5895,"Calm down."],[6158,6254,"Genny,"],[6354,6466,"I never expected"],[6470,6612,"you would disregard"],[6616,6812,"our past bond as sisters"],[6816,6958,"just to humiliate me."],[7008,7187,"Genny humiliating me like this,"],[7266,7554,"isn't just a slap in Peak Sect's face,"],[7591,7812,"but a slap in Master's face too?"],[7875,7995,"You vicious sl*t."],[8045,8112,"You're just a piece of trash"],[8116,8220,"with no cultivation,"],[8291,8470,"yet you're so arrogant."],[8516,8612,"Genny,"],[8662,8762,"have you lost your mind?"],[8850,8995,"You never used to be like this."],[9029,9175,"Even if you're jealous of Junior Sister,"],[9220,9345,"there has to be a limit."],[9516,9608,"What makes her so special"],[9612,9762,"that I should be jealous?"],[10208,10300,"Genny, since you"],[10304,10445,"look down on me so much,"],[10537,10654,"then why don't"],[10704,10833,"we have a duel?"],[10975,11075,"Genny,"],[11115,11223,"surely you aren't"],[11275,11383,"too scared to fight me?"],[11425,11495,"Huh?"]],"35":[[16,212,"For someone with ruined cultivation,"],[312,433,"you probably can't even"],[437,545,"lift this sword, can you?"],[550,637,"Surely you can't just rely on"],[641,766,"talking big."],[829,950,"Genny,"],[954,1075,"don't be scared."],[1112,1275,"I don't really want to fight you."],[1316,1433,"I just want to remind you,"],[1487,1666,"times have changed."],[1708,1920,"No matter how impressive you used to be,"],[1925,2070,"it doesn't change the fact"],[2095,2375,"that your cultivation is ruined."],[2437,2579,"You can't compare to even a single strand"],[2583,2712,"of Faye's hair."],[2716,2866,"How could you possibly compare to her?"],[3133,3237,"Lend me a sword."],[3337,3445,"Genny!"],[3454,3591,"You can't use spiritual power now."],[3595,3762,"Even if your swordsmanship is excellent,"],[3766,3920,"you won't withstand a single blow from her."],[6866,6895,"This…"],[7350,7416,"Junior Sister,"],[7745,7845,"such a fine sword,"],[7850,8000,"yet you wield it like a butcher's knife."],[8062,8208,"What a disgrace."],[8429,8491,"Watch out!"],[8495,8579,"She's using spiritual energy!"],[8808,8879,"You little bi*ch,"],[8908,9000,"die!"],[9416,9462,"Ah!"],[9666,9737,"This"],[9741,9841,"How is this possible?"],[10037,10087,"Ah!"],[10533,10675,"You fraud!"],[12620,12700,"My face!"],[12791,12925,"Ah!"],[12929,13012,"Why?"],[13016,13104,"Your cultivation,"],[13108,13241,"wasn't it already ruined?"],[13266,13400,"You actually hid your true strength"],[13404,13487,"to set me up"],[13491,13600,"and humiliate me."],[13604,13779,"You're so vicious!"]],"36":[[166,226,"Careful."],[1098,1260,"He is No. 1 on the Sky-Reaching Ranking,"],[1286,1384,"Mr. Stone!"],[1384,1474,"Oh my god!"],[1498,1656,"I actually get to see him in person!"],[1656,1804,"Rumor has it that a hundred years ago,"],[1804,1946,"he entered the Nether Secret Realm to cultivate."],[1946,2038,"Since then,"],[2038,2134,"in the Cultivation World,"],[2134,2272,"there have only been legends about him,"],[2272,2396,"but no trace of him."],[2422,2582,"He helped me."],[2598,2714,"He represents the entire Cultivation World's"],[2714,2878,"number one rogue cultivator!"],[2916,3010,"Wow."],[3010,3090,"I really want to see"],[3090,3214,"Mr. Stone's true face"],[3214,3346,"underneath that mask."],[3346,3596,"- Wow. - He must be so handsome."],[4066,4232,"In a fair match,"],[4326,4532,"why did you attack from behind?"],[4818,4894,"Mr. Stone,"],[4978,5058,"it is all Genny's fault,"],[5058,5162,"that vicious b*tch."],[5210,5276,"Before the match,"],[5276,5402,"she intentionally hid her strength."],[5402,5502,"Mr. Stone,"],[5540,5716,"Genny is despicable by nature."],[5716,5880,"Using matches to maliciously hurt people,"],[5880,6002,"it's not her first time, either."],[6024,6130,"That is exactly why"],[6172,6288,"she was expelled from the sect."],[6334,6442,"Mr. Stone,"],[6442,6584,"it's all my fault."],[6606,6740,"I gave Genny"],[6740,6922,"the chance to frame me."],[6948,7172,"Please don't blame my senior brothers."],[7402,7662,"Please don't blame my senior brothers."],[8152,8194,"Tch."],[8204,8350,"In the original novel, Silas"],[8350,8492,"was always mysterious."],[8492,8578,"He never actually appeared."],[8598,8744,"The author only wrote a few words"],[8744,8910,"bragging about how powerful he was."],[8960,9068,"It's a shame I transmigrated"],[9078,9228,"before I could find out"],[9228,9336,"his true identity."],[9366,9560,"I didn't think much of it reading the book,"],[9578,9758,"but seeing him in that mask now,"],[9790,9928,"he sure is pretentious."],[10636,10746,"Senior,"],[10746,10938,"if you don't mind,"],[10976,11110,"please give me some pointers."],[11140,11438,"I will learn from you."],[11740,11830,"Ah."],[12158,12356,"Just a tiny little spar"],[12420,12610,"left you in this state."],[12648,12750,"If I can't hold back my power"],[12750,12910,"and end up crippling you,"],[12952,13010,"I'm afraid"],[13010,13212,"your fellow brothers"],[13298,13382,"will be crying"],[13382,13528,"at your funeral today."]],"37":[[10,714,"Hahaha!"],[772,894,"It seems"],[916,1078,"Silas isn't one of Faye's simps"],[1078,1226,"from the original novel."],[1256,1434,"He sure talks tough."],[1458,1604,"His mouth is so venomous,"],[1604,1752,"one lick would probably kill you."],[2078,2174,"Junior Sister."],[2226,2344,"Mr. Stone,"],[2344,2494,"I wonder, how has Peak Sect"],[2530,2658,"offended you?"],[2700,2800,"Why must you humiliate"],[2800,2928,"our disciples like this?"],[3000,3204,"I'm just stating the facts."],[3264,3406,"Since when is that humiliation?"],[3444,3518,"You!"],[3676,3858,"Mr. Stone is telling the truth."],[3886,4058,"With Faye's skill level,"],[4108,4288,"she expects Mr. Stone's guidance?"],[4356,4518,"If something actually happened,"],[4538,4732,"wouldn't you blame Mr. Stone"],[4796,4958,"for not going easy on her?"],[5078,5172,"At the start, Genny"],[5172,5288,"didn't even use spiritual power."],[5318,5508,"Faye used hers first when she was losing,"],[5564,5720,"yet she accused Genny of hiding her strength."],[5778,5936,"It's a good thing she hid it."],[5966,6104,"I saw it clearly-"],[6132,6328,"Faye from Peak Sect"],[6352,6488,"used a lethal move."],[6550,6620,"If that had been"],[6620,6766,"an ordinary person without power,"],[6808,6946,"they'd be dead by now."],[6950,7060,"- That's right! - Exactly!"],[7060,7132,"- For sure. - You said it."],[7156,7258,"Enough!"],[7326,7454,"This farce"],[7496,7620,"ends here."],[7684,7768,"Hmph."],[7890,8022,"Bye-bye."],[8038,8138,"Tsk."],[9148,9248,"This is the registration card"],[9248,9356,"for the Sect Tournament."],[9378,9532,"As a rogue cultivator,"],[9578,9668,"you're strong enough to compete."],[9940,10052,"That's great!"],[10212,10292,"Congratulations,"],[10292,10370,"Genny."],[10428,10576,"May I call you that?"],[10576,10724,"Of course."],[10724,10824,"Here."],[10914,11110,"I owe you for today's match."],[11164,11258,"You're welcome."],[11626,11734,"Enough out of you."],[11734,11874,"I was the one who gave her the card."],[12444,12642,"What business is it of yours?"],[12756,12888,"You're right, Senior."],[12888,13032,"It's none of my business."],[13106,13206,"Please don't be angry."],[13744,13864,"Hmph."],[14572,14650,"He..."],[14650,14712,"He..."],[14712,14848,"Did he just glare at me?"]],"38":[[344,460,"Fellow cultivators,"],[460,518,"I won't guide you"],[518,614,"to your rooms personally."],[614,698,"Please find your rooms"],[698,816,"using the numbers"],[816,926,"on your keys."],[1018,1108,"Lanny,"],[1108,1236,"I'm going back to rest."],[1332,1440,"Rest well."],[1978,2042,"Ah!"],[2042,2174,"Can't you be gentle?"],[2562,2636,"Ah!"],[2892,3002,"Sorry, Senior Sister."],[3028,3138,"I'm sorry."],[3198,3264,"Faye."],[3290,3424,"Senior Brother and I came to see you."],[3468,3570,"Get out."],[4324,4498,"Senior Brother, Alex."],[4592,4668,"Junior Sister."],[4720,4870,"How's your face?"],[4918,4988,"Does it still hurt?"],[5068,5116,"No."],[5156,5272,"It doesn't hurt."],[5502,5606,"Even if it hurts, I can't tell"],[5606,5754,"Senior Brother and Alex."],[5854,6092,"I don't want them worrying about me."],[6092,6208,"Even Master's"],[6208,6282,"Regeneration Salve"],[6282,6388,"can't stop the pain?"],[6504,6568,"She must have"],[6568,6682,"tampered with the sword."],[6682,6850,"I'll go settle the score with her now."],[6902,6980,"Wait."],[7088,7236,"It's the Sect Tournament."],[7270,7504,"After what happened today,"],[7524,7664,"if you go make trouble for her,"],[7714,7826,"do you want to provide leverage"],[7826,7972,"against Peak Sect?"],[8428,8530,"Alex,"],[8572,8680,"I agree."],[8680,8908,"We shouldn't make any rash moves right now."],[8946,9032,"Junior Sister,"],[9072,9226,"you'll have to bear with it for now."],[9416,9516,"I'm fine,"],[9516,9620,"Senior Brother."],[9674,9788,"Get some rest."],[9788,9900,"We're heading back now."],[11262,11424,"Two useless losers."],[11424,11576,"What good are you to me?!"],[11612,11730,"I absolutely won't spare"],[11730,11904,"that b*tch Genny!"],[11944,12092,"Argh!"]],"39":[[930,1088,"Such a beauty."],[1088,1324,"It'd be a pity to just kill you."],[1408,1530,"I'm going to peel off your face"],[1530,1696,"and make a human skin lantern out of it."],[1862,1938,"Get off!"],[3508,3558,"Bind!"],[4200,4328,"How did you know I would come?"],[4362,4554,"Not only did I know you'd come,"],[4580,4680,"but I also know"],[4680,4856,"who sent you."],[4872,4970,"Impossible."],[5010,5246,"It was Faye who sent you, wasn't it?"],[5272,5502,"You, a dignified Guardian of the Demons,"],[5502,5654,"willingly became a slave"],[5654,5830,"to do her bidding?"],[5860,5982,"Don't try to trick me."],[6132,6290,"Your first time with Faye"],[6290,6462,"was in the Great Hall of the Demons, wasn't it?"],[6462,6600,"Back then, your people"],[6600,6720,"were discussing plans to attack"],[6720,6822,"the whole land,"],[6822,6930,"while you"],[6930,7174,"were fooling around with her in secret."],[7242,7386,"How could you possibly know that?"],[7458,7542,"I know because I read"],[7542,7686,"the original novel."],[7894,8006,"I"],[8006,8182,"I mean, I heard rumors."],[8182,8342,"It's all over the grapevine."],[8372,8502,"You know,"],[8526,8700,"you treat Faye like a goddess,"],[8700,8860,"but she treats you like a lapdog."],[8886,9126,"Faye tells everyone you're useless in bed."],[9126,9190,"She says being touched by"],[9190,9306,"a monster from the Demons"],[9306,9438,"makes her absolutely sick."],[9466,9504,"This story"],[9504,9680,"has spread all over Peak Sect."],[9694,9810,"Oh,"],[9810,9974,"my goodness."],[10036,10226,"Don't tell me you didn't know?"],[10250,10302,"No"],[10302,10390,"Impossible."],[10390,10546,"Faye isn't that kind of person."],[10546,10654,"She isn't!"],[10654,10754,"It must be you, you bi*ch,"],[10754,10858,"slandering her!"],[12026,12124,"Oh,"],[12464,12520,"I forgot."],[12520,12626,"Among the Demons, Faye has"],[12626,12762,"more than one simp."],[12810,12918,"Man,"],[14072,14364,"that old hag really has a lot of simps."],[14364,14560,"Does she have a Succubus Physique?"],[14582,14732,"Even I'm getting jealous."]],"40":[[406,646,"The demon energy is coming from ahead."],[646,784,"With the Demons attacking this time,"],[784,916,"we have Silas to thank"],[916,1020,"for coming as an examiner"],[1020,1136,"to help us."],[1182,1356,"Thank you, Mr. Stone."],[1768,1858,"Master,"],[1858,1994,"Mr. Stone,"],[1994,2190,"I sense demon energy coming from that place."],[2220,2308,"That place"],[2308,2426,"is the temporary residence"],[2426,2538,"for disciples from all sects."],[2556,2656,"So,"],[2688,2854,"someone in there"],[2854,2952,"must be colluding"],[2952,3064,"with the Demons."],[3178,3330,"How can you be so sure?"],[3364,3508,"Where do you get such confidence?"],[3550,3686,"To me, it feels like"],[3686,3914,"demon energy is coming from all directions."],[4146,4228,"I"],[4284,4384,"I just feel that"],[4384,4524,"the demon energy there"],[4524,4656,"is the most intense."],[4734,4824,"How about we"],[4824,5020,"search the direction Faye pointed out first?"],[5064,5188,"Desmond,"],[5188,5294,"when I defeated you back then"],[5294,5462,"and became No. 1 on the Heaven Ranking,"],[5462,5626,"I still thought you were somebody."],[5700,5862,"But after a few years apart,"],[5916,6104,"how can a mere direct disciple"],[6170,6376,"sway your judgment?"],[6404,6596,"You're really going backwards."],[6680,6820,"If you ask me,"],[6838,6904,"if this turns out to be"],[6904,7052,"a diversion by the Demons,"],[7086,7174,"the consequences"],[7212,7346,"can you bear them?"],[7790,7868,"Indeed."],[7868,8046,"Ever since Faye joined the sect,"],[8070,8142,"it seems I really have been,"],[8142,8272,"without realizing it,"],[8272,8428,"heavily influenced by her words."],[8452,8552,"All right,"],[8586,8694,"I'll take some disciples"],[8718,8820,"to search."],[9488,9592,"I'll search this area,"],[9636,9786,"and you take some disciples over there."],[9806,9934,"We'll split up."],[10272,10336,"Master,"],[10336,10432,"Eldest Brother,"],[10432,10516,"Alex."],[10516,10618,"I'll go with Mr. Stone"],[10618,10756,"to search for the Demons."],[10772,10948,"That way, we can look out for each other."],[10982,11060,"All right."],[11360,11454,"Then the rest of you,"],[11454,11544,"follow me"],[11544,11662,"to search in that direction."],[11712,11782,"- Yes, - Yes,"],[11782,11866,"- Master. - Master."]],"41":[[270,424,"Once he falls for the Mind-Confusing Art,"],[424,488,"he will hear"],[488,670,"the inner voice I project on purpose."],[670,750,"By then,"],[750,942,"Silas will naturally become"],[942,1162,"a dog at Faye's beck and call."],[1802,1972,"Why are you following me?"],[2088,2188,"Oh"],[2218,2330,"I was just afraid"],[2330,2438,"that if you ran into the Demons, Mr. Stone,"],[2438,2566,"you wouldn't have any backup."],[2644,2806,"You think you could actually help me?"],[3298,3408,"Mr. Stone"],[3452,3624,"I just twisted my ankle."],[3658,3842,"Could you help me?"],[3874,3998,"If you twisted your ankle,"],[3998,4190,"crawl back yourself."],[5248,5344,"Where am I"],[5422,5540,"Am I back?"],[5640,5766,"No."],[5892,5984,"It's an illusion."],[6078,6168,"It's an illusion."],[6168,6260,"It's an illusion."],[6260,6400,"It's a trick by the Demons."],[6400,6524,"It's not real."],[7514,7576,"This"],[7576,7722,"It's Genny."],[7750,7902,"She's not in her quarters."],[7922,8056,"Why is she here?"],[8100,8184,"Could it be"],[8204,8266,"that she's the one"],[8266,8438,"colluding with the Demons?"],[8454,8538,"Why don't we"],[8538,8614,"take her"],[8614,8682,"to the Water Dungeon right now,"],[8682,8744,"torture her,"],[8764,8956,"and force the truth out of her?"],[9936,10040,"Genny."]],"42":[[976,1082,"I"],[1192,1434,"Did I... Did I transmigrate back?"],[2560,2686,"It's really hot in here."],[2732,2902,"Why don't you guys turn on the AC?"],[2924,3050,"We can't."],[3074,3224,"Our CEO says the AC wastes electricity."],[3270,3426,"If we turn it on again,"],[3426,3590,"he'll dock our pay next month."],[3618,3704,"Huh?"],[3818,3970,"What a stingy CEO."],[4134,4230,"But"],[4256,4342,"why do you all"],[4342,4494,"look like workhorses?"],[4498,4692,"Because we represent workhorses."],[4724,4818,"Ah!"],[4972,5066,"Genny."],[5206,5376,"Hurry, take the files to the CEO."],[6138,6270,"Sir,"],[6392,6552,"here are the files you wanted."],[7632,7712,"Sir"],[7740,7782,"You"],[7794,7844,"You"],[7870,7998,"Why do you look exactly"],[8008,8092,"like Chase?"],[8096,8190,"Come here."],[9284,9388,"Sir."],[9420,9484,"Genny."],[9524,9584,"Marry me."],[9584,9762,"Cook, clean, and bear me a son."],[9792,9956,"Be a workhorse at the office by day,"],[9978,10042,"and at night,"],[10078,10186,"take care of my whole family."],[10302,10490,"And hand over all your wages."],[10922,11038,"I don't want to be a workhorse!"],[11094,11224,"I don't want to turn into an old hag!"],[11258,11370,"I won't! I won't do it!"],[11382,11466,"I won't!"],[11488,11604,"Stay away! I"],[11604,11700,"Stay back!"],[11796,11878,"No!"],[11950,12080,"Ah!"],[12614,13012,"Ah!"],[13090,13236,"I don't want to be a drudge!"],[13258,13360,"I don't want to be a drudge!"],[13380,13462,"I don't want to!"],[13470,13642,"I don't want to be a haggard housewife!"],[13808,13930,"The Demons' Heart-Devouring Bug"],[14014,14082,"traps its victims in"],[14082,14224,"fear and lust,"],[14262,14442,"leading to a most despairing death."],[14524,14688,"What exactly did you see"],[14726,14890,"to make you this terrified?"],[15024,15114,"It's so hot."],[15150,15260,"I want air conditioning."],[15288,15378,"I want air conditioning."],[15406,15540,"- Someone save me! - Air Conditioning?"],[15684,15810,"Where did you meet this \"Air Conditioning\"?"],[15810,15896,"Is he your secret lover?"],[15940,16134,"That \"Air Conditioning\" can't save you now."],[16172,16312,"Only I can save you."]],"43":[[22,216,"That \"Air Conditioning\" can't save you now."],[246,356,"Only I can save you."],[1722,1846,"I'll transfer the Heart-Devouring Bug"],[1952,2112,"into my own body."],[2182,2428,"You're not allowed to think about other men."],[3626,3726,"Are you crazy?"],[3736,3802,"Who are you?"],[3814,3916,"I don't even know you."],[3916,4028,"Why are you helping me?"],[4066,4118,"Run!"],[4208,4324,"I've already transferred the Heart-Devouring Bug"],[4324,4414,"into my body."],[4584,4736,"I'm afraid I might hurt you."],[5136,5266,"Are you"],[6134,6224,"Chase?"],[7652,7732,"Go! Hurry!"],[7748,7848,"I can't control"],[7850,7940,"myself anymore."],[7956,8040,"You helped me."],[8044,8170,"I'm not leaving."],[8188,8288,"What exactly do I need to do"],[8290,8398,"to cure the poison?"],[8444,8512,"Or maybe,"],[8590,8724,"I can draw the Heart-Devouring Bug's poison"],[8726,8864,"back into me."],[8864,8986,"It's no use."],[9006,9128,"I either find the antidote,"],[9132,9304,"or rely on my cultivation"],[9378,9568,"and willpower to resist it."],[10112,10280,"Why is she here?"],[10382,10528,"No"],[10576,10716,"Stay away!"],[10768,10894,"Impossible."]],"44":[[142,222,"Chase."],[340,420,"Chase."],[714,876,"Genny, run!"],[1214,1334,"Why are you here?"],[1404,1538,"Cousin."],[1596,1662,"An illusion"],[1662,1782,"It's all an illusion."],[1826,1886,"It's so hot."],[1904,2006,"The Heart-Devouring Bug"],[2088,2152,"makes you see"],[2152,2312,"your greatest fear."],[2334,2454,"The same thing happened to me."],[2504,2624,"So the poison"],[2764,2844,"is taking effect."],[2948,3032,"Chase."],[3192,3316,"Chase, are you okay?"],[3642,3748,"Cousin."],[3864,3986,"You can never escape"],[3986,4138,"from my grasp."],[4182,4322,"I will be your Serpent Queen,"],[4382,4562,"and bear you a nest of snake babies."],[4742,4842,"I already have a Serpent Queen."],[4864,5002,"I'll never marry you."],[5068,5286,"Cousin, please let me go."],[5584,5752,"I don't believe it! I don't!"],[5984,6080,"You promised"],[6080,6198,"you'd make me your Serpent Queen"],[6208,6342,"and love me forever!"],[6352,6440,"That was just childish talk."],[6448,6584,"We were just kids back then."],[6704,6868,"Liar! You liar!"],[6904,7022,"I am your Serpent Queen!"],[7022,7234,"I should be the one you love most!"],[7234,7610,"Ahhh!"],[7884,7964,"Don't touch me!"],[7964,8044,"Stay back!"],[8102,8230,"Stay away from me!"],[8302,8388,"Chase."],[8412,8494,"It's all an illusion."],[8540,8660,"None of it is real."],[8746,8894,"My Serpent Queen is Genny."],[8966,9136,"The only one I love is Genny!"],[9144,9214,"Chase."],[9314,9458,"You say you love me,"],[9688,9816,"so open your eyes"],[9816,9872,"and look at me."],[9872,10044,"Stay calm."],[10198,10336,"It's me."],[10478,10570,"Don't touch me."],[10570,10668,"Chase."],[10784,10870,"Don't touch me."],[11032,11112,"Don't touch me."],[11820,11900,"Don't touch me."],[11912,12010,"Don't touch me!"],[12110,12200,"Don't touch me."],[12218,12298,"Don't touch me."],[12648,12830,"Bind!"],[13484,13562,"Don't touch me."],[13570,13648,"Don't touch me."],[13748,13814,"Chase,"],[13976,14106,"I'll go find the antidote."],[14106,14144,"Don't touch me."],[14144,14222,"Wait for me."],[14250,14334,"Don't touch me."],[14440,14526,"Don't touch me."],[15006,15174,"Pitying a man brings a lifetime of bad luck."],[15276,15392,"It's only because"],[15676,15794,"it's only because"],[15794,15944,"he just helped me."]],"45":[[88,278,"It was Silas who rescued Genny."],[336,448,"That bi*ch Genny,"],[482,712,"when did she get her claws into Silas?"],[800,962,"That little sl*t"],[1028,1230,"She acts so proper usually,"],[1250,1346,"but behind closed doors,"],[1350,1426,"she's nothing but a"],[1426,1622,"wh*re who throws herself at men!"],[1770,1864,"Who's there?"],[2734,2984,"Ah!"],[3780,3880,"Genny?"],[3880,3988,"Have you lost your mind?"],[3988,4142,"I don't have time for your nonsense."],[4148,4306,"Give me the Heart-Devouring Bug antidote."],[4354,4478,"What Heart-Devouring Bug antidote?"],[4490,4606,"I don't know what you're talking about."],[4606,4706,"I told you,"],[4716,4876,"I don't have time to waste."],[4896,5018,"Hand over the antidote!"],[5118,5336,"The Heart-Devouring Bug belongs to the Demons."],[5400,5612,"How could I possibly have the antidote?"],[5684,5788,"Do you want me to reveal"],[5870,6082,"what you did with Blackis and Reddie,"],[6108,6286,"and the positions you used?"],[6298,6424,"Or shall I tell everyone"],[6452,6534,"how, right there in the"],[6534,6648,"Main Hall of the Demons,"],[6648,6802,"you and the Left and Right Guardians"],[6850,7036,"went at it wildly?"],[7094,7238,"How do you know that?"],[7312,7454,"Give me the antidote."],[7458,7550,"Or else,"],[7612,7706,"you die."],[7810,7892,"I'll give it!"],[7938,8034,"I'll give it!"]],"46":[[320,664,"Ah!"],[1004,1484,"Ugh... Argh"],[2188,2348,"You want the antidote, don't you?"],[2354,2440,"Fine."],[2456,2580,"Hand over the Heart-Devouring Bug's antidote"],[2586,2662,"to me right now."],[3218,3400,"I'm sorry, I was wrong."],[3400,3454,"B-But"],[3454,3540,"I really don't have the"],[3540,3682,"Heart-Devouring Bug's antidote."],[3748,3876,"Then have one of"],[3876,3934,"Blackis and Reddie"],[3934,4014,"bring it to me."],[4048,4158,"Time waits for no one."],[4190,4330,"You don't look"],[4510,4652,"so good right now."],[7042,7092,"Faye."],[7174,7338,"Why did you suddenly summon me?"],[7660,7738,"And why are you in"],[7738,7840,"Faye's room?"],[8192,8288,"Nether"],[8372,8462,"I"],[8480,8570,"Ah!"],[8624,8696,"Are you and she"],[8696,8810,"spreading rumors about me?"],[8830,8920,"Saying I can't perform?"],[8964,9094,"Saying my touch makes you sick?"],[9204,9414,"You can't tell guys they can't perform."],[9536,9724,"Ah!"],[10046,10146,"Nether,"],[10146,10336,"I have never slandered you."],[10336,10446,"In my heart,"],[10446,10642,"you've always been the strongest."],[10826,10884,"Faye,"],[10906,10970,"I'm sorry."],[11016,11126,"I was just too angry."],[11154,11234,"I didn't mean to use so much force."],[11332,11390,"Your face,"],[11420,11534,"why has it turned so purple?"]],"47":[[126,202,"Faye,"],[244,302,"are you okay?"],[338,420,"Don't scare me."],[444,524,"I know"],[572,624,"you would never"],[624,732,"talk about me behind my back."],[752,834,"You've always been so"],[834,918,"understanding."],[1034,1178,"Stop... stop shaking me."],[1178,1332,"I'm just poisoned."],[1476,1540,"Poisoned?"],[1592,1654,"That's right."],[1706,1818,"She is poisoned."],[1848,1986,"As for the antidote,"],[2002,2138,"it's in my hands."],[2256,2368,"Give me the antidote."],[2416,2628,"Seems you really care about Faye."],[2752,2832,"It's simple."],[2870,2992,"Hand over the antidote"],[2996,3080,"for the Heart-Devouring Bug,"],[3084,3188,"and I'll give you hers."],[3396,3476,"Nether,"],[3476,3640,"just give her the antidote."],[3690,3860,"T-The antidote for this poison,"],[3860,4004,"there... there is only one."],[4032,4126,"If I can't get it,"],[4126,4256,"I'm done for."],[4318,4398,"Fine."],[4464,4524,"I'll give you"],[4524,4678,"the Heart-Devouring Bug antidote."],[4678,4758,"Great."],[4790,4876,"Then we'll exchange antidotes"],[4876,4986,"at the same time."],[6226,6306,"Where's the antidote?"],[6382,6476,"The antidote?"],[6486,6664,"It's in my hand, of course."],[6722,6842,"I'm not stupid."],[6862,6946,"What if"],[6946,7106,"I give you the real antidote,"],[7130,7202,"and you give me"],[7202,7382,"A fake Heart-Devouring Bug antidote."],[7382,7550,"Then what am I supposed to do?"],[7830,7896,"What about you?"],[7912,8070,"Was the antidote you gave her real,"],[8070,8152,"or was it fake?"],[8324,8436,"I gave her the real one."],[8602,8662,"You actually gave her"],[8662,8768,"the real antidote!"],[8790,8942,"You idiot! You fool!"],[9156,9240,"You honest fool."],[9262,9366,"Thanks a lot."],[9432,9484,"Stop!"],[9580,9740,"Give me the Ultimate Poison antidote!"],[10570,10706,"Ah!"],[10818,10892,"Argh!"],[10892,10974,"Genny!"],[10974,11058,"You bi*ch!"],[11058,11188,"I'm going to kill you!"]],"48":[[558,652,"Cousin,"],[730,910,"we just aren't meant to be."],[1074,1216,"I've let you down"],[1280,1472,"and caused you pain for years."],[1530,1676,"It wasn't my intention."],[1766,1910,"I'm willing to castrate myself"],[1998,2128,"to apologize."],[2150,2312,"Chase's feelings for me,"],[2312,2470,"have actually reached the point"],[2470,2536,"where he'd castrate himself"],[2536,2686,"just to keep himself pure for me."],[2734,2834,"This stinking snake"],[2886,3022,"isn't useless after all."],[3082,3334,"At least he's handsome and devoted."],[3378,3468,"Don't be afraid."],[3528,3694,"I'm here to give you the antidote."],[4606,4684,"Return."],[5286,5382,"Chase."],[5520,5616,"It's you."],[5698,5790,"Genny."],[5854,6072,"Did you find the antidote to save me?"],[6110,6174,"Yeah."],[6312,6522,"If I hadn't found it,"],[6526,6642,"you might have actually"],[6690,6828,"gone and castrated yourself."],[6950,7184,"After the Heart-Devouring Bug got you,"],[7216,7378,"you kept calling out to your cousin."],[7462,7584,"She must be"],[7622,7728,"very important to you, huh?"],[8014,8146,"There's absolutely nothing between us."],[8224,8388,"We were betrothed as children,"],[8428,8488,"but"],[8510,8654,"I only see her as a cousin."],[8662,8794,"She's just like a sister to me."],[8970,9058,"I know."],[9130,9210,"And I"],[9344,9452,"also know"],[9636,9756,"how you feel about me."],[10340,10414,"Chase,"],[10466,10552,"we"],[10614,10764,"Let's raise the child together,"],[10910,11046,"and give the little snake egg inside you"],[11118,11284,"a complete family."]],"49":[[22,160,"Senior Brother,"],[190,326,"that's what happened."],[358,454,"I was tricked by Genny,"],[454,600,"that little b*tch."],[670,732,"I'm going right now"],[732,862,"to kill that b*tch, Genny."],[958,1132,"Just because of the Sect Tournament,"],[1150,1250,"she thinks she can provoke us"],[1250,1362,"time and time again."],[1392,1472,"Wait."],[1828,1954,"Don't make things worse."],[1992,2086,"Our top priority right now"],[2132,2256,"is to find the antidote for Junior Sister."],[2274,2404,"The antidote for the Ultimate Poison"],[2422,2518,"is extremely difficult to refine."],[2534,2654,"Just gathering the ingredients alone"],[2654,2734,"is hard enough."],[2792,2914,"If we delay any longer,"],[2918,3006,"the Ultimate Poison"],[3006,3116,"will spread through her entire body,"],[3116,3240,"until she rots away"],[3240,3406,"and dissolves into a puddle of blood."],[3474,3710,"Genny, that vicious b*tch."],[3742,3862,"I'm going to find her"],[3886,4042,"and take back the antidote for Junior Sister."],[4214,4294,"Senior Brother,"],[4338,4534,"I'm afraid it won't be that easy."],[4618,4676,"Mr. Stone seems to be"],[4676,4848,"very close with her."],[4900,4950,"Exactly."],[4992,5062,"That is why I didn't"],[5062,5226,"want Alex to make a move."],[5280,5360,"But why would Mr. Stone"],[5420,5590,"be involved with her?"],[5678,5830,"When Genny was still in the Sect,"],[5870,5968,"she never mentioned him."],[6178,6358,"Greetings, Master."],[6670,6742,"Faye,"],[6776,6848,"your face"],[7608,7688,"Master."],[7746,7938,"I really had no other choice,"],[7950,8170,"or I wouldn't be here begging you."],[8230,8338,"Who on earth"],[8340,8482,"is so audacious?"],[8498,8612,"To dare poison my direct disciple"],[8612,8774,"right here on Peak Sect?"],[8890,8970,"Master,"],[8970,9086,"it was... it was"],[9100,9180,"Master,"],[9238,9408,"it was Genny who poisoned Faye,"],[9408,9514,"trying to kill her."],[9550,9668,"That wretch."],[9718,9860,"She has already been expelled from the sect,"],[9870,9986,"yet she refuses to repent."],[10070,10228,"Acting so viciously,"],[10250,10380,"how dare she!"]],"50":[[342,398,"Faye,"],[466,586,"don't worry."],[598,828,"I'll send a voice transmission right now"],[862,1052,"to summon your Junior Uncle back"],[1056,1206,"to make the antidote for you."],[1224,1330,"Thank you, Master."],[1392,1468,"That wretch."],[1516,1620,"Back then, I"],[1648,1826,"should have crushed her to dust."],[1860,2026,"Since she has a death wish,"],[2082,2206,"I will make sure"],[2244,2438,"she never leaves here alive!"],[2476,2532,"Master,"],[2552,2642,"that Genny"],[2652,2844,"seems to be very close to Mr. Stone."],[3064,3250,"You mean Silas?"],[3262,3342,"Yes."],[3434,3532,"Ever since Silas"],[3532,3638,"appeared out of nowhere two hundred years ago"],[3674,3824,"and defeated me to take the top spot,"],[3846,3930,"countless sects"],[3930,4072,"have tried to suck up to him in vain."],[4146,4260,"He's always been a loner"],[4278,4380,"and looks down on everyone."],[4400,4488,"How could he possibly"],[4534,4636,"have any dealings with"],[4638,4718,"that wretch Genny?"],[5090,5138,"I've heard"],[5138,5228,"that among the Demons,"],[5272,5438,"there is a Seduction Art."],[5470,5580,"If a woman learns it,"],[5600,5768,"she can easily bewitch men."],[5820,5986,"Could Genny,"],[5986,6060,"that little b*tch,"],[6070,6176,"have used this very method"],[6182,6292,"to bewitch Mr. Stone?"],[6314,6410,"But how"],[6410,6570,"would Genny know the Demons' Seduction Art?"],[6618,6706,"Unless Genny"],[6706,6840,"has been colluding with the Demons all along?"],[6930,7050,"No wonder her spiritual energy"],[7050,7140,"comes and goes."],[7162,7340,"She must be practicing demonic arts."],[7432,7600,"Could the invasion of"],[7600,7690,"the Demons at Peak Sect"],[7690,7820,"be Genny's doing?"],[7836,7918,"That must be it."],[7972,8028,"Last night,"],[8052,8122,"Senior Brother and I"],[8122,8262,"followed Master to hunt the Demons,"],[8274,8354,"but we searched all night"],[8354,8464,"and found no trace of the Demons."],[8512,8562,"Peak Sect has"],[8562,8744,"so many traps against the Demons."],[8832,9034,"No matter how powerful they are,"],[9058,9122,"it's impossible"],[9122,9234,"to leave no trace at all."],[9276,9460,"It must be Genny"],[9464,9646,"colluding with the Demons."],[9726,9906,"Since she dared to collude with the Demons,"],[9958,10260,"that wretch must die!"]],"51":[[258,358,"One day later."],[390,612,"The Sect Tournament officially begins."],[650,886,"In past years, we competed in three events:"],[924,1004,"swordsmanship,"],[1044,1206,"magical combat, and alchemy."],[1236,1516,"This year, the elders of the United Sects"],[1580,1628,"have decided"],[1628,1712,"to give all disciples"],[1740,1866,"a chance to gain experience"],[1936,2088,"by hunting treasures in the Secret Realm."],[2088,2147,"The Secret Realm?"],[3376,3596,"The rare treasures found inside"],[3628,3710,"will serve as the prizes"],[3710,3896,"for the participating disciples."],[3922,4002,"In the end,"],[4094,4258,"the disciple with the most treasures"],[4298,4444,"will take the top spot."],[4512,4682,"Since it's a treasure hunt this year,"],[4712,4928,"won't the Secret Realm be dangerous?"],[4944,5048,"The Secret Realm"],[5048,5176,"is meant for training purposes."],[5176,5336,"And since it's the Sect Tournament,"],[5336,5492,"they surely wouldn't put us in real danger."],[5506,5632,"Wow,"],[5636,5732,"the prizes this year"],[5732,5860,"must be bigger than usual."],[5952,6108,"Suddenly competing in the Secret Realm"],[6132,6258,"I bet Faye,"],[6258,6356,"that d*mn woman,"],[6356,6502,"is pulling strings behind the scenes."],[6618,6748,"Trying to set me up?"],[6770,6972,"If she's willing to die,"],[7072,7258,"I'm willing to bury her."],[7272,7542,"Tomorrow, we enter the Secret Realm trials."],[7558,7898,"Everyone, rest well tonight."],[7928,8046,"For tomorrow's Secret Realm trial,"],[8048,8146,"let's team up"],[8186,8266,"and take everyone else out."],[8328,8422,"Sounds good."],[8444,8538,"I'm in."],[8550,8630,"Right."],[8630,8758,"Even if we don't team up,"],[8758,8862,"they certainly will."],[8998,9068,"Genny,"],[9094,9124,"do you want to"],[9124,9204,"team up with us?"],[9224,9344,"Once we enter the Secret Realm,"],[9386,9474,"those people will definitely"],[9516,9644,"target a lone rogue cultivator"],[9646,9830,"like you first."],[9844,9926,"No need, Lanny."],[9956,9984,"Actually, I"],[9984,10034,"Genny,"],[10086,10256,"you don't have to be polite with me."],[10292,10380,"I"],[10408,10542,"Can I call you Genny?"],[10558,10690,"Of course,"],[11496,11636,"Mr. Stone."]],"52":[[96,186,"Mr. Stone,"],[216,322,"come with me."],[408,524,"I have something to tell you."],[534,612,"Oh,"],[1070,1146,"Lanny,"],[1156,1260,"see you tomorrow."],[1572,1652,"See you."],[1746,1848,"Is"],[1886,1956,"is this still the"],[1956,2118,"ethereal Mr. Stone?"],[3560,3694,"Didn't you promise"],[3714,3806,"to be a"],[3820,3974,"loving couple with me?"],[4020,4088,"Yeah."],[4180,4260,"But tell me,"],[4328,4482,"in broad daylight,"],[4494,4656,"right out in the open,"],[4726,4866,"can we just make out anywhere?"],[4906,4960,"What if"],[4960,5132,"someone sees us?"],[5220,5358,"Who are you afraid will see?"],[5474,5638,"That Lanny guy?"],[5874,5978,"Jealous?"],[6348,6520,"If you aren't jealous,"],[6576,6708,"then I'll really go find"],[6722,6858,"that Lanny guy."],[7314,7404,"Don't you dare."],[7458,7576,"And you say you're not jealous."],[7598,7758,"Keep your distance when you team up tomorrow."],[7830,7920,"I'm the proctor,"],[7966,8092,"so I can't enter the Secret Realm to help."],[8182,8362,"Only if a candidate sends a distress signal"],[8406,8520,"can I decide"],[8520,8680,"whether to intervene."],[8812,8872,"Then are you okay"],[8882,8962,"with me teaming up with him?"],[9052,9372,"Be careful inside the Secret Realm."],[9420,9488,"Okay."],[9770,9864,"Take off your mask."],[10038,10138,"What for?"],[10210,10442,"I just want to take a good look at you."]],"53":[[702,830,"Each of you has been issued"],[860,1032,"a Trial Stone."],[1106,1272,"If you encounter danger,"],[1272,1440,"you can crush it,"],[1486,1582,"and the examiners"],[1616,1688,"will rescue you from"],[1688,1822,"the Secret Realm."],[1872,1956,"However,"],[1976,2166,"once you crush the Trial Stone,"],[2192,2292,"it means you have forfeited"],[2300,2482,"the Sect Tournament."],[2532,2614,"Alright,"],[2644,2864,"the competition starts now."],[4130,4190,"Genny,"],[4190,4286,"don't worry."],[4300,4390,"I'll protect you."],[4426,4506,"Okay."],[5836,5916,"You guys"],[5940,6004,"Senior Brother,"],[6014,6070,"I don't agree"],[6070,6184,"with letting her join our team."],[6196,6266,"She's nothing but a castoff"],[6266,6386,"kicked out of Peak Sect,"],[6400,6544,"a useless cripple."],[6594,6704,"Teaming up with her"],[6714,6894,"will only drag us down."],[6906,6936,"Yeah,"],[6936,6990,"Senior Brother."],[6990,7120,"This is the Sect Tournament."],[7156,7264,"Even if we team up,"],[7266,7330,"in the end,"],[7330,7480,"we still have to determine a winner."],[7506,7626,"And in the Secret Realm treasure hunt,"],[7640,7724,"there's no need for us"],[7724,7786,"to drag a cripple along"],[7786,7856,"and share the spoils."],[7916,8094,"Lanny defeated Faye that day,"],[8124,8176,"which proves"],[8176,8290,"she is capable"],[8290,8404,"and won't hold us back."],[8432,8652,"Hmph. Who knows about that match?"],[8654,8742,"Maybe she just got lucky"],[8742,8874,"and won by sheer accident."],[8902,8994,"I can't sense a trace"],[8994,9144,"of spiritual power in her."],[9184,9278,"Or maybe,"],[9282,9372,"Faye is just incompetent,"],[9372,9482,"and only relied on her looks"],[9494,9610,"to become"],[9626,9676,"a direct disciple"],[9676,9794,"of the sect."],[9804,9902,"So that match"],[9926,10022,"didn't prove anything."],[10042,10096,"But she"],[10100,10198,"Lanny,"],[10254,10418,"don't waste your breath defending me."],[10462,10558,"I didn't come here"],[10558,10622,"planning to team up"],[10622,10752,"with you guys."],[10772,10884,"I'm a rogue cultivator,"],[10920,11010,"so I work alone."],[11044,11174,"Since we're friends,"],[11202,11302,"I won't attack you"],[11302,11404,"this time."],[11458,11578,"But next time we meet,"],[11602,11778,"we'll be enemies,"],[11810,12104,"and I won't show any mercy!"],[12244,12344,"See ya."],[12836,12978,"I look forward to our battle."],[13054,13190,"I'll give it my all."],[13898,13946,"Oh my God,"],[14066,14148,"that pose I just struck"],[14150,14314,"was so cool!"],[14342,14518,"Ten out of ten! I nailed it!"]],"54":[[372,462,"What a perfect place"],[462,642,"to kill and steal treasures."],[1160,1322,"This Secret Realm is perilous."],[1354,1440,"We can't lower our guard."],[1706,1830,"Inside this Secret Realm,"],[1830,1932,"quietly"],[1932,2094,"killing Genny"],[2138,2280,"is a brilliant idea."],[2440,2540,"Be careful when you strike."],[2594,2694,"Don't leave any traces."],[2780,2860,"Don't worry, Senior Brother."],[2884,2988,"I won't be that reckless."],[3120,3194,"I actually think"],[3210,3398,"we shouldn't kill Genny so soon."],[3408,3542,"Let her find some treasure first,"],[3568,3680,"then we kill her and take it."],[3746,3890,"Isn't that killing two birds with one stone?"],[3944,4006,"But if we"],[4006,4094,"don't find her soon,"],[4140,4206,"what if her Trial Stone"],[4206,4304,"gets crushed by someone else?"],[4338,4422,"If she gets eliminated early"],[4432,4514,"and leaves the Secret Realm, what then?"],[4602,4682,"That won't happen."],[4698,4794,"Her Trial Stone"],[4794,4914,"won't be crushed by anyone else."],[5384,5540,"Finally found a straggler."],[5560,5646,"Sorry,"],[5646,5698,"nothing personal."],[5720,5890,"Blame yourself for being a sectless"],[5890,5970,"rogue cultivator."],[6010,6176,"Hand over your Trial Stone. Now."],[6436,6518,"Fellow cultivators,"],[6548,6760,"why don't you let me join you?"],[6778,6910,"There's strength in numbers."],[6930,7086,"I just want to train in the Secret Realm."],[7104,7232,"I won't compete for the top prizes."],[7254,7480,"Hey, on my way here,"],[7494,7690,"I saw some Spirit Grass."],[7698,7890,"- Spirit Grass? - I can take you there."],[8114,8204,"Since you don't plan"],[8204,8294,"to fight us for the top prize,"],[8350,8514,"then please hand your Trial Stone"],[8514,8620,"over to us for safekeeping."],[8688,8800,"We promise"],[8800,8894,"we won't crush your Trial Stone"],[8916,9082,"until the very end,"],[9148,9208,"so you can"],[9208,9348,"stay in the Secret Realm."]],"55":[[94,174,"Here."],[200,280,"Take it."],[656,764,"Is it real?"],[764,856,"Better not be a trick."],[900,980,"It's real."],[1070,1126,"Fellow cultivator,"],[1150,1284,"then please lead us to"],[1288,1384,"that Spirit Grass."],[1422,1536,"Sure, sure."],[1536,1616,"This way."],[1916,2136,"Here we are."],[2212,2278,"Look."],[2306,2454,"This Spirit Grass"],[2462,2538,"is my offering to join"],[2538,2674,"the Formless Sect."],[2704,2784,"Rest assured,"],[2802,2932,"I definitely won't"],[2932,3042,"fight you for it."],[3066,3298,"Besides, my Trial Stone"],[3322,3392,"is already"],[3392,3526,"in your hands, isn't it?"],[3604,3684,"Oh,"],[3714,3878,"if you're really worried,"],[3908,4042,"I'll step further back."],[4062,4208,"Help yourselves."],[4622,4704,"Please."],[4714,4838,"Go ahead."],[6206,6256,"Oh no!"],[6278,6406,"- It's an Exotic Beast! - Not good!"],[7824,7984,"Quick! Everyone cast spells!"],[7984,8162,"Hold these beasts back!"],[8208,8348,"Get over here and help!"],[8394,8486,"Or else,"],[8486,8692,"I'll crush your Trial Stone!"]],"56":[[88,230,"Go ahead and crush it if you can."],[276,516,"You can't crush my Trial Stone."],[1140,1286,"You tricked me!"],[1336,1456,"Don't blame me."],[1502,1646,"Those ingrates at Peak Sect"],[1680,1804,"were afraid someone else would eliminate me,"],[1842,1944,"so they specifically gave me"],[1944,2084,"a Trial Stone that can't be crushed."],[2168,2340,"Their desire to kill me"],[2354,2504,"matches my desire to kill them"],[2528,2604,"perfectly."],[2730,2936,"I guess the feeling is mutual."],[3016,3276,"Oh no! The barrier can't hold!"],[3340,3440,"Senior Brother!"],[3440,3646,"Should we just surrender?"],[3666,3800,"Call the proctor over."],[3820,3860,"Surrendering"],[3860,4056,"means forfeiting the trial."],[4424,4590,"You despicable scoundrel!"],[4718,4816,"At your service."],[5154,5298,"Forget it. Forget it."],[5322,5502,"Quick, take out your Trial Stones"],[5522,5680,"and crush them!"],[6836,7056,"You brats actually dare to touch"],[7056,7222,"the Spirit Grass?"],[7246,7366,"Good thing this is just a trial."],[7382,7538,"You're way too reckless."],[7914,8004,"Those who are eliminated"],[8020,8222,"cannot take anything from the Secret Realm."]],"57":[[446,566,"Fellow cultivators,"],[590,690,"fellow cultivators,"],[730,872,"fellow cultivators,"],[886,1062,"thank you so much."],[1226,1306,"Lanny,"],[1412,1572,"your skin"],[1596,1808,"is thicker than a city wall."],[1872,1990,"Proctor,"],[1990,2120,"look at him."],[2146,2246,"Eliminated participants"],[2246,2372,"must not verbally attack"],[2386,2530,"other competitors"],[2530,2716,"or affect their mindset."],[2796,2876,"Fine."],[2950,3050,"We admit defeat."],[3086,3186,"Once our wounds heal,"],[3230,3330,"we'll leave."],[5512,5620,"I didn't expect"],[5620,5770,"the Formless Sect's disciples"],[5770,5922,"to be eliminated so soon."],[5942,6022,"Hmph."],[6042,6182,"And your Jade Sect disciples,"],[6198,6324,"are they any better?"],[6328,6434,"Regardless,"],[6440,6560,"my Jade Sect disciples"],[6602,6768,"haven't been eliminated yet."],[7050,7112,"Didn't you claim"],[7112,7298,"your Jade Sect is formidable?"],[7298,7450,"Aren't they eliminated now too?"],[7484,7662,"Still better than your Formless Sect."],[7724,7792,"Hmph."],[7826,7926,"Your Jade Sect"],[7926,8066,"only dares to compare with us."],[8066,8244,"Compare with Peak Sect if you dare."],[8460,8552,"I wonder which team"],[8602,8680,"Mr. Stone"],[8718,8800,"favors the most?"],[8852,8986,"Except for Genny."],[9030,9168,"Mr. Stone means,"],[9182,9280,"anyone but Genny."],[9318,9544,"Everyone has a chance to come out on top?"],[9572,9702,"Except for Genny,"],[9792,9912,"you're all trash."],[9942,10028,"You"],[10040,10150,"Hmph."]],"58":[[188,268,"Look!"],[278,408,"This looks like Spirit Grass."],[448,538,"It really is."],[576,736,"Can't believe we got this lucky."],[2232,2338,"With this"],[2338,2448,"Spirit Grass as bait,"],[2454,2606,"they won't be able to resist."],[2650,2828,"First, I'll eliminate them all,"],[2842,2988,"then go to Peak Sect"],[2988,3086,"to find those ingrates,"],[3086,3206,"kill them and take their treasures."],[3348,3450,"I really am"],[3450,3642,"a clever little genius."],[4384,4474,"Help!"],[4482,4688,"Help!"],[4714,4878,"Help me!"],[4904,4986,"Whoa!"],[4998,5076,"Ah!"],[5098,5182,"Fellow cultivators,"],[5200,5306,"what are you doing?"],[5326,5384,"Don't tell me"],[5392,5516,"you're playing on a swing?"],[5516,5592,"Is it fun?"],[5600,5652,"Fellow cultivator,"],[5682,5820,"we're not on a swing."],[5882,5986,"This is a Man-Eating Vine."],[6018,6164,"It automatically attacks moving objects."],[6184,6322,"We weren't paying attention just now,"],[6334,6468,"and got trapped by this Man-Eating Vine."],[6478,6628,"If you save us,"],[6636,6712,"we can help you"],[6712,6850,"catch that moving"],[6850,6996,"Spirit Grass as a reward."],[7036,7144,"You mean this?"],[7182,7258,"Yes, yes, yes."],[7308,7412,"This Spirit Grass"],[7412,7576,"must have gained sentience."],[7592,7672,"It lured us into"],[7672,7796,"the Man-Eating Vine's territory."],[8306,8384,"Look."],[8384,8456,"See? Isn't it easy"],[8456,8560,"to pick?"],[8612,8708,"Junior Brother,"],[8708,8812,"she set us up."],[8828,8908,"You're the one who"],[8946,9030,"used this Spirit Grass"],[9030,9126,"to set a trap"],[9136,9264,"and lure us in."]],"59":[[16,108,"Despicable! Shameless!"],[574,668,"So dirty!"],[684,798,"There's no honor in a win like this!"],[898,950,"Cursing?"],[1000,1104,"You like cursing, huh?"],[1903,2150,"Argh!"],[2164,2368,"Ouch!"],[2836,2910,"Whoa."],[3002,3140,"Look, they even dropped gear."],[3794,3904,"No! Don't!"],[4560,4668,"- It's you again. - It's you again."],[4698,4790,"Hey."],[4824,4950,"Examiners,"],[4972,5102,"what a coincidence."],[5108,5240,"We meet again."],[6330,6410,"Stop!"],[6434,6514,"Eliminated participants"],[6542,6718,"cannot take Secret Realm items."],[6834,7032,"Why does that sound so familiar?"],[7118,7188,"Why?"],[7220,7314,"We earned this."],[7314,7418,"It just happened to fall on the ground."],[7444,7570,"Anything inside the Secret Realm"],[7570,7690,"belongs to the Secret Realm."],[7882,7994,"Oh well."],[8004,8192,"Sorry about that, then."],[8448,8526,"You"]],"60":[[840,900,"Fellow cultivators,"],[942,996,"how were you all"],[1000,1114,"eliminated?"],[1242,1308,"It's hard to say."],[1336,1406,"Yeah, hard to say."],[1488,1678,"Getting eliminated in such a stupid way,"],[1678,1788,"if we said it out loud,"],[1800,1914,"we'd be a laughingstock."],[1930,1980,"You tell them."],[1990,2150,"If we had fought fair and square,"],[2156,2262,"we could've at least bragged about it."],[2326,2372,"Hey,"],[2444,2568,"how did you guys get eliminated?"],[2742,2820,"We'd rather not say."],[2842,2980,"Yeah, rather not say."],[3656,3682,"Sigh."],[3682,3754,"Fellow cultivators,"],[3778,3930,"how did you get eliminated?"],[4458,4510,"There are already"],[4510,4650,"so many sects eliminated."],[5182,5220,"Hey,"],[5236,5384,"weren't you guys eliminated?"],[5388,5486,"Why so happy?"],[5524,5640,"If it means meeting Chase,"],[5670,5844,"getting eliminated is worth it."],[5886,5974,"I've never seen anyone"],[5974,6054,"as handsome"],[6054,6166,"as Chase."],[6184,6264,"In this life,"],[6266,6424,"marrying Chase would be worth everything."],[6446,6504,"Yeah."],[6582,6624,"Ugh,"],[6660,6780,"have some dignity!"],[6810,6910,"That was Genny!"],[6912,7070,"To trick you out of your Trial Stones,"],[7070,7186,"she used the Face-Changing Art"],[7186,7292,"to fool you!"],[7328,7480,"I'm just glad she put in the effort for us."],[7516,7628,"What more could we ask for?"],[7638,7706,"Shut up."]],"61":[[40,90,"Master,"],[236,332,"was Genny's"],[332,452,"transformed face"],[452,544,"really that handsome?"],[560,696,"Look how she has you all"],[696,812,"completely under her spell."],[846,934,"He was handsome!"],[966,1062,"Extremely handsome!"],[1070,1166,"I've never seen anyone"],[1166,1296,"as good-looking as Chase in my life."],[1634,1708,"Master,"],[1724,1840,"do you want to see?"],[1858,2004,"I specifically used a Shadow Stone"],[2004,2072,"to capture Chase's"],[2072,2198,"stunning face."],[2404,2522,"I wonder whose appearance"],[2522,2612,"Genny assumed"],[2612,2768,"to seduce these female disciples."],[2924,3034,"Let's have a look then."],[3198,3248,"Here."],[3260,3330,"The Shadow Stone."],[3480,3704,"Such a bunch of shallow, ignorant fools."],[3724,3834,"It's merely a physical shell."],[3882,3986,"What is there to covet?"],[4038,4096,"Then later,"],[4096,4196,"close your eyes and don't look."],[4254,4374,"Day in, day out,"],[4436,4544,"must you always act so high and mighty?"],[5024,5120,"Heavens!"],[5120,5182,"Chase!"],[5182,5296,"- Come catch me! - Catch me!"],[5310,5358,"I'm coming,"],[5366,5438,"my beauties."],[5458,5624,"- So handsome! - So handsome!"],[5648,5710,"Chase!"],[5720,5866,"You just love teasing us."],[6072,6181,"You're too much!"],[6312,6420,"Genny,"],[6516,6676,"you are so dead!"]],"62":[[1538,1666,"Who misses me so much?"],[1774,1868,"Don't tell me"],[1884,2054,"it's those beauties?"],[2136,2294,"Tsk, tsk."],[2368,2550,"If it weren't for the competition,"],[2610,2782,"I wouldn't have the heart to crush"],[2782,2940,"their Trial Stones."],[2998,3120,"Their little hands"],[3140,3290,"were smoother than silk."],[3302,3420,"Those legs"],[3430,3564,"that went on for days."],[3596,3718,"And those faces,"],[3748,3880,"oh my,"],[4532,4788,"I really miss them already."],[6650,6738,"You fool."],[6820,6952,"But I really should thank you"],[6996,7050,"for getting rid of"],[7050,7100,"those sect members for us."],[7176,7302,"After we kill you,"],[7328,7390,"first place will naturally"],[7420,7586,"belong to Peak Sect."],[7696,7762,"What?"],[7816,7930,"Killing is forbidden"],[7940,8066,"in this Secret Realm tournament!"],[8088,8284,"If the Joint Elders find out,"],[8284,8370,"you"],[8382,8556,"you'll definitely be punished!"],[8602,8750,"You won't get a chance to tell anyone outside."],[8802,8882,"That's impossible."],[8894,8968,"I don't believe you."],[8998,9146,"As soon as I crush my Trial Stone,"],[9166,9358,"the examiners will come save me."],[9374,9506,"Then your crimes"],[9512,9668,"will be exposed to everyone."],[9704,9754,"Oh,"],[9754,9854,"Genny,"],[9854,9950,"Genny."],[9984,10176,"I didn't think you could be this stupid."],[10224,10384,"From the moment you entered this Secret Realm,"],[10400,10464,"you had already fallen into"],[10464,10600,"You've fallen into our trap."],[10704,10784,"If you don't believe me,"],[10824,10894,"go ahead and try"],[10894,11048,"to crush your Trial Stone."],[11352,11438,"How is this possible?"],[11458,11570,"Why can't I crush it?"],[11600,11656,"It was you!"],[11708,11818,"You tampered with"],[11818,11900,"the Trial Stone!"],[11912,12008,"It must have been you!"]],"63":[[4,94,"It definitely was you guys."],[130,224,"That's right."],[240,446,"That Trial Stone is unbreakable."],[486,666,"You can neither get eliminated,"],[704,816,"nor call for help."],[926,1036,"This Secret Realm,"],[1142,1410,"will be your grave!"],[1642,1730,"Genny."],[1732,1816,"Rest assured,"],[1816,1906,"after you die,"],[1928,2126,"I'll send your parents down to join you,"],[2166,2300,"so you won't get lonely"],[2348,2456,"on the road to the afterlife."],[2526,2578,"Oh?"],[2744,2920,"Are you so sure"],[2952,3198,"I won't be the one sending you to your deaths?"],[3250,3336,"You're at death's door,"],[3336,3450,"yet you still talk tough!"],[4206,4542,"Hahaha."],[4548,4670,"Oh, Genny."],[4688,4776,"Hahaha."],[4776,4966,"I thought you had a backup plan."],[4972,5122,"Is that it?"],[5130,5510,"Hahaha."],[5612,5732,"You don't actually think"],[5776,5976,"you can make it out of here alive, do you?"],[6004,6122,"What a joke."],[6130,6364,"Hahaha."],[8106,8186,"Give it up."],[8246,8476,"We've set an inescapable trap here."],[8476,8696,"Not even a fly could escape."],[8810,8872,"Who says"],[8878,9060,"this Shadow Stone is for me?"],[9122,9220,"Haven't you guys"],[9240,9346,"heard the saying?"],[9368,9512,"The best hunters"],[9536,9620,"often appear"],[9622,9776,"disguised as prey."],[9798,9866,"You b*tch!"],[9872,9940,"You're about to die!"],[9940,10060,"Still playing tricks?"],[11410,11560,"It's been a while,"],[11602,11792,"but you're just as weak as ever."],[12050,12130,"You bi*ch!"],[12158,12330,"I'm going to kill you!"],[12494,12538,"Junior Sister,"],[12566,12666,"let me handle this."],[12704,12920,"Before you die,"],[12922,13006,"I'll toy with and humiliate you"],[13006,13138,"like a dog."],[13196,13360,"But don't worry."],[13360,13596,"I'll torture you bit by bit,"],[13628,13908,"until you beg for death!"]],"64":[[356,428,"This strike"],[486,558,"is for the scum!"],[606,674,"How dare you!"],[732,790,"And this strike"],[1062,1238,"is for the d*mn b*stard!"],[1282,1360,"Your swordsmanship"],[1360,1506,"when did it become so brilliant?"],[1520,1608,"It's impossible!"],[1682,1782,"Back at Peak Sect,"],[1782,1856,"when I sparred with you,"],[1902,1968,"I was saving you face,"],[2006,2100,"letting you win on purpose."],[2116,2216,"Did you really think"],[2218,2334,"you were actually capable?"],[2366,2470,"You're trash and don't even know it."],[2510,2626,"That's exactly what you are."],[4088,4184,"You're the same."],[4212,4316,"Just like Faye,"],[4350,4516,"blind and overconfident."],[4590,4708,"Now you're the only one left."],[4810,4948,"What have you got?"],[4984,5084,"Don't worry."],[5112,5216,"I won't let you"],[5216,5328,"die too quickly."],[5328,5580,"I'll torture you bit by bit,"],[5614,5784,"make you beg for life"],[5784,5916,"but unable to die."],[5988,6044,"You bi*ch!"],[6064,6180,"You dare mock me?"],[6236,6294,"So what?"],[6338,6426,"What are you gonna do?"],[6442,6504,"Because I feel like it."],[6642,6720,"Genny,"],[6744,6840,"don't push it."],[6884,7004,"Do you really think"],[7018,7150,"we can't handle you?"],[7168,7330,"Well, that's exactly the case."],[7348,7446,"You can't stand me,"],[7488,7616,"but you can't kill me."],[7638,7756,"Don't waste breath on her."],[7826,7950,"Let's all attack together!"],[8552,8626,"System!"],[8656,8750,"While in the Secret Realm,"],[8750,8884,"I've fed you so many rare treasures."],[8918,9032,"Now, level me up!"],[9032,9124,"Give me a massive boost!"],[9124,9234,"I'll let you ants"],[9258,9346,"witness"],[9346,9502,"my true power!"]],"65":[[1058,1184,"H-How is this possible?"],[1194,1372,"Her spiritual energy was weak just a moment ago"],[1372,1528,"I couldn't even sense it!"],[1528,1610,"How did she suddenly"],[1610,1720,"break through to the Nascent Soul stage?"],[1732,1820,"No, not Nascent Soul."],[1866,2018,"She's breaking into Soul Formation!"],[2080,2152,"How is her cultivation"],[2152,2312,"rising so fast?"],[2312,2450,"Even practicing demonic arts"],[2470,2550,"couldn't possibly"],[2550,2692,"reach this level!"],[4172,4316,"Is this the power of the Soul Formation stage?"],[4370,4460,"It's absolutely terrifying."],[4516,4688,"Why did we ever try to"],[4688,4814,"fight someone this terrifying?"],[4872,5054,"I... I don't want to die! I don't want to die!"],[5106,5184,"Senior Sister, I was wrong!"],[5184,5326,"I really know I was wrong!"],[5504,5648,"It's all because of that b*tch Faye!"],[5648,5696,"We"],[5696,5816,"we were all bewitched by her!"],[5858,5996,"Y-Yes, exactly!"],[6104,6232,"N-No, it wasn't me!"],[6298,6402,"It's obvious they're just jealous"],[6402,6456,"of your talent!"],[6456,6610,"They're just using me as an excuse!"],[6642,6724,"Senior Sister,"],[6724,6878,"I was used by them too!"],[6912,7078,"Please, I beg you, don't kill me!"],[7078,7214,"- It was your inner voice! - Don't kill me!"],[7214,7344,"That's why we went after Senior Sister!"],[7362,7446,"Everything we did"],[7464,7602,"was all because of you!"],[7644,7718,"That's just because"],[7720,7816,"you're all stupid!"],[7870,8008,"I just projected a bit of my inner voice,"],[8034,8092,"and you all"],[8092,8208,"swarmed around like dogs!"],[8208,8258,"So, all of this"],[8258,8398,"You're the one behind all this."]],"66":[[18,110,"So, all of this,"],[110,268,"was your doing all along."],[340,418,"Hmph."],[444,612,"Bravo, bravo."],[672,788,"I just love watching"],[788,892,"dogs tearing each other apart."],[1238,1342,"Senior Sister,"],[1384,1518,"I was wrong."],[1560,1690,"I'll kill this"],[1690,1806,"culprit right now"],[1830,1944,"to make it up to you!"],[2934,3038,"The Demons!"],[3038,3100,"Junior Brother!"],[3916,4084,"Darko, get Faye out of here first."],[4156,4214,"So,"],[4256,4362,"the one colluding with the Demons"],[4362,4464,"has been you all along."],[4568,4682,"So what if I am?"],[4728,4894,"You have only your own stupidity to blame."],[4952,5134,"You believed whatever I said."],[5176,5320,"To tell you the truth,"],[5344,5412,"the reason"],[5412,5528,"you could hear my inner voice"],[5548,5610,"is because"],[5614,5754,"you fell for the Demons' Heart-Illusion Art."],[5820,5886,"You"],[6052,6182,"Darko, let's go."],[6224,6280,"Okay."],[6442,6602,"I gotta say,"],[6642,6854,"taking simping to this level,"],[6870,7034,"I'm actually impressed."],[7096,7176,"I won't let you"],[7176,7296,"hurt Faye."],[8342,8532,"Your cultivation goes beyond Soul Formation"],[8532,8656,"How can ants like you"],[8656,8838,"perceive a true god?"],[8994,9210,"I totally nailed that flex."],[9566,9652,"I'll do it myself."],[9702,9802,"No need for you to lift a finger,"],[10250,10318,"Junior Sister."],[10334,10408,"I'm begging you,"],[10484,10568,"since we are both"],[10568,10644,"disciples of"],[10664,10852,"the same sect,"],[10862,10948,"spare me."],[11016,11194,"Spare me! Please spare me!"],[11280,11424,"If you don't have the guts,"],[11424,11582,"why play the hero?"],[11628,11832,"Come on. Let me help you."],[11986,12119,"You've put on quite a show."],[12141,12250,"Cooldown complete."]],"67":[[940,992,"Look,"],[1010,1052,"isn't that"],[1052,1176,"Faye from Peak Sect?"],[1200,1266,"Why is she with"],[1266,1380,"the Demons?"],[1740,1832,"Faye,"],[1848,1914,"what's going on?"],[1978,2106,"How dare you fool around"],[2106,2220,"with the Demons?"],[2294,2380,"So what if I fool around"],[2380,2490,"with the Demons?"],[2540,2630,"Do you think your"],[2630,2840,"orthodox sects are any better?"],[2844,2912,"You disgrace!"],[2970,3084,"Stop spouting nonsense!"],[3164,3260,"Peak Sect has already"],[3260,3442,"fallen to my Demon army."],[3492,3646,"You'd better not make a move,"],[3664,3878,"or my Demon army"],[3878,4092,"will slaughter everyone at Peak Sect."],[4116,4198,"Hah."],[4472,4626,"Who says your Demon army"],[4734,4892,"has conquered Peak Sect?"],[5088,5276,"Silas, even if you are"],[5280,5418,"No. 1 on the Heaven Ranking, so what?"],[5470,5618,"Do you think you can single-handedly"],[5652,5844,"defeat my army of 100,000 Demons?"],[5844,5952,"The whole land"],[5990,6072,"will sooner or later belong to"],[6072,6264,"our Demon King."],[6294,6532,"You lot are only fit to bow and submit!"],[6878,7140,"The Demons are the true rulers!"],[7536,7732,"Wait, isn't that the Serpent Clan?"],[7732,7850,"Why are they here?"],[8032,8134,"That's the Demon King."],[8158,8280,"They've captured the Demon King!"],[8422,8540,"Greetings, My Lord."],[8566,8642,"Mission accomplished."],[8652,8762,"We set an ambush in advance"],[8778,8944,"and wiped out the entire Demon army."]],"68":[[38,114,"Mission accomplished."],[126,236,"We set an ambush in advance,"],[242,408,"and wiped out the entire Demon army."],[508,640,"I never expected Mr. Stone"],[640,788,"to be the Lord of the Serpent Clan."],[846,1050,"Rumor has it that men of the Serpent Clan"],[1070,1186,"are all extraordinarily handsome,"],[1218,1378,"but the women"],[1470,1682,"I wonder which lucky woman"],[1698,1824,"got to be the Serpent Queen."],[1824,1978,"For such a god-like figure"],[2020,2188,"to be paired with a monster"],[2230,2326,"What a waste."],[2480,2604,"My Serpent Queen"],[2614,2716,"is as beautiful as an angel."],[2780,2878,"I don't need your concern."],[3524,3612,"Look, she's coming out."],[5676,5838,"Didn't you say you were terrifyingly strong"],[5904,6052,"and told me to focus on the Demons?"],[6314,6466,"Guess you were just talking big."],[6538,6588,"Take him away."],[6898,6992,"Impossible."],[7032,7162,"How could the Demon King be captured?"],[7162,7340,"Faye, it's over."],[7340,7436,"Just surrender."],[7524,7632,"I'm not one of the Demons."],[7632,7750,"Why should I surrender?"],[7922,8104,"Master,"],[8114,8220,"you've always loved me the most."],[8230,8378,"Please give me one more chance."],[8768,8828,"You wretch."],[8938,8996,"At a time like this,"],[9052,9190,"you still expect me to spare you?"],[9274,9566,"I will purge the sect today."],[9820,9996,"Master!"],[10660,10756,"- Master! - Master!"],[10850,10958,"You old bast*rd!"],[10970,11096,"Stop pretending"],[11096,11278,"to be so high and mighty."],[11330,11512,"If you won't let me live,"],[11560,11722,"Then go to hell!"],[11880,12122,"Hahaha!"],[12178,12322,"This dagger"],[12322,12546,"is the Demons' Blood Blade."],[12684,12922,"Even a Deity Transformation master"],[12950,13124,"can't escape death."],[13166,13486,"Hahaha!"]],"69":[[332,458,"Not only did you collude with the Demons,"],[464,602,"but you dared to commit such"],[602,716,"betrayal against your master!"],[746,798,"Hmph."],[3668,3840,"Faye. Faye."],[4084,4152,"Now that things have"],[4156,4246,"settled down,"],[4304,4424,"let's return to the Serpent Clan"],[4470,4568,"and meet my mother."],[4596,4706,"Huh? Uh"],[4896,4986,"So suddenly?"],[5170,5326,"But I'm not ready yet."],[5354,5610,"It's okay. She's very easygoing."],[5662,5766,"She'll definitely like you."],[5852,5936,"That's right, Serpent Queen."],[5946,6080,"You don't need to worry."],[6102,6178,"My Lord"],[6178,6318,"hasn't had an heir for centuries."],[6318,6526,"Lady Vivian has always wanted a grandchild."],[6534,6692,"With a daughter-in-law like you,"],[6700,6784,"she will be"],[6790,6912,"absolutely overjoyed."],[7062,7154,"No heir, huh?"],[7196,7382,"No one thinks you're mute if you keep quiet."],[7458,7570,"Mm."],[8358,8450,"What's going on?"],[8636,8752,"Did you just come out of the Secret Realm?"],[8790,8860,"Exactly."],[8976,9084,"Inside the Secret Realm,"],[9174,9324,"we didn't meet a single opponent."],[9400,9462,"Oh no."],[9552,9616,"We forgot the people from Cloud-Soaring Sect"],[9622,9706,"are still inside."],[9732,9792,"We're done for."],[9798,9890,"Then the top prize this time,"],[9890,10028,"won't it go to them?"],[10262,10320,"I declare"],[10366,10484,"that for this Sect Tournament,"],[10504,10628,"the winner of the top prize is"],[10634,10724,"Cloud-Soaring Sect."],[11118,11258,"Genny! Genny!"]],"70":[[538,790,"Don't be nervous. Just be yourself."],[882,1028,"You're not the one meeting your mother-in-law."],[1066,1198,"Of course you're not nervous."],[1440,1598,"I have long wanted to see"],[1598,1708,"my future daughter-in-law."],[1780,1872,"Lady Vivian"],[1890,2042,"Her voice is enchanting,"],[2084,2228,"and having a son like Chase,"],[2234,2350,"who is peerlessly handsome,"],[2388,2444,"she must be"],[2444,2594,"a rare beauty."],[3918,4020,"Did meeting your mother-in-law"],[4038,4182,"leave you speechless?"],[4272,4366,"No,"],[4416,4538,"no,"],[4600,4698,"I just"],[4894,4990,"I just"],[5010,5100,"never imagined"],[5100,5356,"Lady Vivian would be so"],[5402,5544,"would be so"],[5602,5700,"So what?"],[5706,5902,"So amiable."],[6172,6318,"You sure have a way with words."],[6336,6556,"I know what you wanted to say."],[6572,6788,"We of the Serpent Clan are all like this."],[6810,6892,"You see,"],[6954,7144,"because only with a body like this"],[7200,7284,"can we better breed"],[7284,7406,"the Serpent Clan's offspring."],[7482,7564,"However,"],[7674,7778,"times are changing."],[7824,7914,"Nowadays, many"],[7914,8122,"women of the Serpent Clan pursue"],[8122,8250,"slender figures."],[8266,8370,"Whether fat or thin,"],[8430,8528,"it doesn't matter."],[8572,8706,"Health is what counts."],[8896,9106,"Look at her, such a sweet talker."],[9154,9290,"Like she dipped her lips in honey."],[9306,9428,"Alright. Let's go."],[9782,9894,"Bad news! Bad news!"],[9948,10062,"Lady Vivian, My Lord,"],[10062,10180,"The Lady is here."],[10182,10250,"What?"],[10392,10566,"Mother, could you please stall Cousin?"],[10604,10762,"Genny and I are going to my in-laws'"],[10762,10860,"to stay for a while."]],"71":[[32,282,"Ahhh!"],[326,668,"Argh!"],[694,786,"Oh my."],[900,1020,"Serpent Queen, hang in there a bit longer."],[1020,1154,"For you human women,"],[1154,1308,"giving birth is always such an ordeal."],[1362,1552,"I'm not doing this!"],[1590,1884,"I don't want to give birth anymore!"],[1980,2244,"Let whoever wants this baby have it!"],[2244,2370,"I quit!"],[2396,2596,"Serpent Queen, save your strength."],[2596,2698,"Scream later."],[2750,2956,"Genny, you're suffering so much."],[2980,3044,"Mom!"],[3158,3546,"Mom, I don't want to do this anymore!"],[3546,3668,"I can't do this!"],[3758,3888,"Watching you suffer"],[4004,4184,"is like cutting flesh from my heart."],[4226,4414,"My heart is breaking."],[4492,4704,"Ahhh!"],[4818,4990,"When women of the Serpent Clan give birth,"],[4990,5094,"it's never like this."],[5166,5248,"How can this be?"],[5260,5406,"Why is Genny in so much pain?"],[5422,5470,"Oh dear."],[5470,5640,"You're Serpent Clan, and she's human."],[5692,5736,"Who knows"],[5736,5890,"what will happen during the birth?"],[5944,6044,"I finally understand."],[6060,6182,"Genny kept yelling about"],[6182,6270,"\"reproductive isolation.\""],[6270,6492,"This is simply... simply incompatible!"],[7238,7396,"I, Chase of the Serpent Clan, vow here and now:"],[7452,7630,"if the Heavens keep my wife safe,"],[7684,7842,"I will offer a hundred years of my cultivation"],[7864,7962,"to bless the whole land."],[8374,8518,"Ahhh!"],[8532,8706,"Heavens! It's not an egg!"],[8714,8840,"It's a live birth!"],[8890,9000,"Come on, Serpent Queen!"],[9010,9162,"The baby's head is coming out!"],[9170,9284,"Push harder!"],[9316,9552,"Ah!"],[9584,9680,"Wonderful! Just wonderful!"],[9684,9806,"The baby is out!"],[9826,9940,"It's a boy!"],[9978,10094,"That's great, Genny!"],[10120,10198,"There's more!"],[10282,10330,"Ah!"],[10348,10412,"Serpent Queen,"],[10440,10584,"that's how our Serpent Clan is."],[10614,10722,"More children mean more blessings!"],[10722,10896,"Use your strength! Keep going!"],[11026,11298,"Ah!"],[12108,12388,"Why are there so many babies?!"],[13058,13194,"There's just too many!"],[13216,13698,"Chase, I'm going to kill you!"]]}