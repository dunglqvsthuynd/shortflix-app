{"1":[[100,226,"Do we have a Jane?"],[226,350,"Jane Lockhart?"],[453,629,"Room 305 for dermatology."],[1693,1883,"I never believed in love at first sight."],[2046,2096,"Until now."],[2286,2396,"Heartbeats really don't lie."],[2916,2986,"Name?"],[3253,3329,"Henry Darcy?"],[3516,3643,"Your name, please."],[3766,3883,"Oh, Jane!"],[3923,3993,"Jane Lockhart."],[4060,4176,"And what brings you in today?"],[4210,4383,"Why does my heart race like this?"],[4489,4600,"Oh, my heart... my heart."],[4710,4876,"You'll need a cardiologist for that?"],[4923,5046,"This is dermatology."],[5046,5170,"We treat skin issues."],[5233,5431,"I mean, my skin allergy."],[5446,5583,"It's been really terrible."],[5623,5699,"Show me where."],[6829,7073,"I have it on my butt too. Do you need to check?"]],"2":[[139,246,"I'm just kidding!"],[313,566,"It's the same as the one on my arm, so..."],[819,959,"When did the symptoms start?"],[959,1093,"Is this a recurring issue?"],[1213,1423,"Ever since I can remember, yeah."],[1486,1710,"every time I eat peaches, really."],[1733,1866,"And you ate them anyway?"],[2036,2193,"Dr. Darcy,"],[2219,2406,"Do you know anything about..."],[2430,2546,"unrequited love?"],[3186,3356,"You should avoid things that harm you."],[3573,3753,"I'll write you a prescription for the allergies."],[4406,4489,"Thank you, Doc."],[4836,5053,"I have one rule in life."],[5126,5356,"If you have nothing to lose, be brave."],[5576,5733,"Dr. Darcy."],[6023,6126,"Can I get your number?"],[6213,6360,"Because sometimes..."],[6420,6553,"love favors the brave."]],"3":[[40,106,"Can I get your number?"],[370,409,"No."],[636,676,"Oh."],[863,893,"Okay."],[1400,1526,"And just like that,"],[1526,1660,"the love of my life"],[1660,1769,"has walked away."],[1906,2073,"The wedding is next month!"],[2350,2463,"Look at my skin."],[2463,2653,"I can't get married like this."],[2653,2746,"Wait, you have skin issues?"],[2796,2850,"Yes!"],[2880,3003,"Should I see a doctor?"],[3039,3246,"Yes, yes, absolutely you should!"],[3246,3353,"You know, I know someone,"],[3353,3470,"skin God!"],[3470,3646,"Literally, I can come with you."]],"4":[[676,890,"Fake lashes too, Jane?"],[996,1119,"I just want to be prepared"],[1119,1286,"for whatever comes next."],[1380,1576,"Yeah, it feels more like date prep."],[1676,1766,"Lily Adams?"],[1850,2010,"Room 305 for dermatology."],[2213,2343,"Whoa, slow down!"],[3346,3596,"Oh, that was date prep!"],[3660,3779,"It's fine, just go."],[4300,4356,"Name?"],[4403,4486,"Lily Adams."],[4596,4733,"And what's the issue today?"],[4779,4863,"Um, I have..."],[4863,4906,"Pimples!"],[5113,5286,"And what's your sleep schedule like?"],[5306,5416,"Total night owl!"],[5446,5583,"Practically the vampire schedule."],[5823,5920,"Which one is the patient?"],[5989,6016,"Me."],[6379,6466,"Dr. Darcy..."],[6516,6646,"I was here last week."],[6713,6793,"You know, peach allergies."],[6870,6950,"It affected my arm."],[7066,7116,"And my butt."],[7229,7303,"Do you remember?"],[7376,7406,"No."],[7843,7970,"I prescribed you a treatment."],[8000,8203,"If you could please just wait outside."],[8220,8286,"Thank you, doctor."],[8359,8423,"Dr. Darcy."],[8573,8800,"Since I'm a returning customer,"],[8903,9023,"could I get your number now?"],[9209,9250,"No."],[9420,9526,"I am so sorry."],[9603,9829,"She's just a bit much sometimes."],[9966,10100,"Please excuse us."],[10100,10163,"Hold on."],[10820,10943,"Did he change his mind?"],[11043,11133,"Is this yours?"]],"5":[[239,363,"I'm still here!"],[570,613,"Sorry."],[676,729,"Sorry, sorry."],[859,1023,"At least you made an impression."],[1073,1223,"I think he's not going to forget you now."],[1280,1333,"Stop!"],[1356,1476,"I don't want to relive that!"],[1580,1696,"Look at the bright side."],[1756,1830,"Hey, sure."],[1863,1916,"He's hot."],[1960,2103,"Everyone's hot under a mask."],[2189,2339,"What if he has like,"],[2339,2473,"weird lips, or"],[2473,2560,"missing teeth?"],[2610,2689,"Yeah, right."],[2730,2766,"Nice try."],[2823,2950,"You wouldn't even recognize him"],[2950,3030,"without a mask."],[3089,3186,"That's not true!"],[3210,3379,"I'm good with faces, okay?"],[3406,3560,"And he has a certain..."],[3603,3663,"vibe..."],[3726,3800,"A certain charm."],[3946,4100,"Lily Adams to the treatment room?"],[4153,4193,"That's me."],[4239,4400,"Just try not to overthink it."],[4920,5029,"I'm not ugly or anything."],[5029,5093,"I mean,"],[5143,5256,"I just wanted his number."],[5379,5443,"What if he's married?"],[5586,5656,"What if he's gay?"],[6350,6603,"Wow, they have a lot of hot doctors."],[9116,9203,"Do you have any chocolate?"],[9273,9296,"What?"],[9379,9473,"Oh, yes, I..."],[9573,9603,"Here!"],[9786,9986,"Sorry, my mom's blood sugar dropped."],[10040,10106,"Thanks for helping."],[10176,10376,"Just give her these, she'll be okay."],[11009,11086,"Doctor!"],[11200,11329,"Which department are you in?"],[11379,11486,"You seem really familiar."],[11733,11879,"Can I get your number?"]],"6":[[106,246,"What kind of phone do you have?"],[396,433,"What?"],[483,613,"Must have a lot of storage,"],[676,813,"given all the numbers you collect."],[1236,1496,"Dr. Darcy, um, I..."],[1496,1593,"Even if you ask every"],[1593,1760,"handsome man you meet for his number,"],[1873,2000,"The answer is still..."],[2030,2076,"No."],[2169,2323,"Have a good day, Ms. Lockhart."],[4560,4733,"Ms. Lockhart, you dance so well."],[4756,4883,"When will I dance like that?"],[4923,5113,"Oh, Chloe, you're gonna be an"],[5113,5293,"even better dancer when you grow up."],[5339,5550,"You're so pretty. I wish you were family."],[5643,5777,"My uncle's still single."],[5777,5896,"I can set you two up!"],[5903,6023,"Really?"],[6073,6186,"You know, I'm really picky."],[6186,6276,"So is my uncle!"],[6276,6403,"He's never with anyone!"],[6443,6603,"But I think you would be perfect."],[6686,6853,"Chloe, you're really sweet."],[6879,6976,"But, you know,"],[6990,7233,"I was just rejected three times!"],[7309,7413,"I'm still healing."],[7490,7596,"Then he can heal you!"],[7596,7693,"He's a doctor too!"],[7733,7776,"Oh."],[7876,7933,"Chloe!"],[8000,8100,"Uncle Henry!"]],"7":[[316,536,"Is Chloe really Dr. Darcy's niece?"],[646,753,"What are the odds?"],[916,1036,"I came to pick you up."],[1093,1250,"I'm so happy you're here."],[1326,1483,"Why are you picking me up today?"],[1509,1700,"Well, your mom said you missed me."],[1700,1903,"So, I thought I'd surprise you."],[2160,2246,"Dr. Darcy."],[2503,2616,"Chloe, should we head home?"],[2693,2786,"Wait!"],[2786,2923,"This is Ms. Lockhart."],[2923,3066,"I've told you about her."],[3066,3220,"I think you should be friends."],[3239,3400,"You know, we already met."],[3400,3479,"And you're right,"],[3479,3663,"Dr. Darcy is very picky."],[3820,3923,"Goodbye, Ms. Lockhart."],[4026,4129,"Wait, um,"],[4166,4279,"we actually need to update"],[4279,4383,"our contact list"],[4383,4516,"for all the parents."],[4553,4679,"It's just routine, so..."],[5063,5163,"Could I get your number?"],[5383,5476,"Yeah, Uncle Henry,"],[5476,5576,"give her your phone number!"],[6063,6120,"Fine."],[6996,7173,"Oh, um, and your social media."],[7200,7283,"You know, to tag you in"],[7283,7564,"performances, photos, stuff like that."],[7773,7883,"I don't think that's..."],[7883,7973,"Please, Uncle Henry!"],[7973,8093,"It's for all the great performances."],[8150,8309,"And we'll post lots of great pictures."]],"8":[[693,826,"No, that sounds really weird."],[1296,1506,"No, that sounds really desperate!"],[2293,2403,"What am I doing?"],[3116,3220,"What is she doing?"],[3326,3436,"What are you doing?"],[3916,4020,"Who are you talking to?"],[4066,4196,"Nothing. No one."],[4320,4438,"I've never seen you this glued"],[4438,4543,"to your phone before."],[4606,4710,"Who were you messaging?"],[4783,4889,"No, I was..."],[4889,5046,"I was just blanking out."],[5200,5283,"Why are you here?"],[5370,5500,"Since you refuse to visit,"],[5500,5629,"I have to come see you myself."],[5833,5903,"How's Dad?"],[5903,6006,"Dissappointed."],[6086,6220,"After all, his own son,"],[6220,6424,"the heir to the world's biggest medical group,"],[6424,6609,"refuses to take over."],[6693,6876,"I've made my choices clear for years now."],[6956,7093,"He just needs to accept them."],[7133,7356,"When you saved a random student"],[7356,7543,"over the mayor and took all the blame?"],[7616,7690,"Henry,"],[7726,7829,"is it worth it?"],[7856,8086,"You can't put a price tag on people's lives."],[8136,8266,"Well, it's hard for dad."],[8323,8526,"He expects his son to continue his legacy,"],[8526,8723,"yet you're stuck in a small hospital."],[8740,8929,"Just keep an eye on him for me."],[9283,9496,"Have you met Chloe's dance teacher,"],[9496,9579,"Ms. Lockhart?"],[9659,9803,"Yes. Why?"],[9936,10053,"Thought you might click."],[10086,10220,"Clearly, I was mistaken."],[10426,10572,"Absolutely not."],[10572,10736,"She is not my type."],[11286,11390,"Morning, Dr. Darcy!"],[11896,12046,"Maybe I need a cardiologist."],[12173,12359,"Why does my heart feel like this?"]],"9":[[906,1013,"Name?"],[1043,1180,"Jane Lockhart?"],[1206,1330,"You know it!"],[1606,1733,"Dr. Darcy,"],[1743,1850,"it's good to see you again."],[1973,2100,"I'm here for that"],[2100,2243,"follow-up for the peach allergy."],[2513,2646,"Good, just..."],[2706,2816,"Stay away from peaches."],[3196,3456,"I saw that conference poster"],[3456,3556,"that you shared."],[3750,3829,"Can I go?"],[3953,4043,"You're interested?"],[4079,4210,"Yeah, I mean, absolutely."],[4270,4543,"Everyone should know about medical stuff, right?"],[4593,4703,"Could come in handy."],[4763,4970,"Really? You find it useful?"],[5070,5116,"Yeah."],[5293,5376,"Yeah, I mean, it is..."],[5426,5579,"It is a medical conference, right?"]],"10":[[139,183,"Um."],[403,563,"I was just..."],[563,806,"trying to learn about men."],[806,1013,"My future husband. I..."],[1043,1180,"I don't know what I'm saying."],[1219,1321,"The conference is"],[1321,1500,"for medical professionals only."],[1586,1684,"If there's nothing else,"],[1684,1836,"I have other patients to see."],[1973,2176,"Yeah. Got it."],[3046,3256,"Why didn't you check that stupid poster?"],[3333,3446,"Brilliant, Jane. Just brilliant!"],[3536,3770,"You gotta admit, Dr. Darcy is a total dream!"],[3896,4076,"You know he's only here because he messed up."],[4093,4160,"Real time."],[4179,4273,"Wait, what? Seriously?"],[4300,4486,"He used to be some hotshot surgeon,"],[4510,4646,"and then he botched a surgery"],[4646,4903,"on someone important. The mayor!"],[4976,5229,"So, surely, the hospital threw him under the bus."],[5229,5429,"Now he's stuck here in dermatology."],[5470,5653,"Wait, really? That bad?"],[5696,5879,"Yeah, Dr. Darcy messed up big time!"],[5943,6020,"You know how it is."],[6030,6090,"One mistake"],[6090,6236,"and your whole career's in the trash."],[6356,6409,"That's it."],[6426,6483,"That's enough!"],[6663,6779,"Hi, may I help you, miss?"],[6786,6921,"Yeah, you can help me by keeping quiet"],[6921,7093,"and minding your own business."],[7159,7263,"Excuse me?"],[7283,7426,"You know, this isn't a gossip corner."],[7426,7533,"I don't expect nurses"],[7533,7636,"to be talking about doctors,"],[7656,7800,"especially right outside of their offices."],[7870,8083,"Excuse us, we have other patients to attend to."],[8083,8236,"Good, go, do your jobs!"],[8909,8983,"Dr. Darcy?"]],"11":[[63,143,"Dr. Darcy?"],[236,320,"You, um..."],[366,476,"You forgot this."],[1823,1989,"You seem really happy today."],[1989,2113,"Anything good happen?"],[2226,2469,"Yes. I was reading The Little Prince,"],[2469,2550,"and I like it."],[2550,2693,"Oh, I love that book."],[2703,2780,"You know"],[2780,2903,"I cried like a baby"],[2903,2993,"when he died at the end."],[3116,3166,"Wait."],[3283,3489,"The little prince dies?"],[3646,3739,"No, no."],[3739,3833,"I can't believe it!"],[3833,3986,"No, no, honey, I'm sorry."],[4060,4143,"I didn't mean that."],[4213,4356,"Chloe, you okay?"]],"12":[[3,83,"Sorry!"],[106,276,"Chloe, are you okay?"],[343,600,"Uncle Henry, Ms. Lockhart told me"],[600,766,"that the little prince dies."],[850,1143,"Oh, Lord, just kill me now!"],[1150,1260,"Ms. Lockhart,"],[1260,1396,"quite the spoiler, huh?"],[1419,1673,"Dr. Darcy, I swear I didn't mean it."],[1703,1863,"Chloe, you remember that cake"],[1863,2016,"you've been craving all week?"],[2063,2263,"We could go get that right now if you wanted."],[2330,2366,"I..."],[2533,2656,"I'm still sad."],[2753,2860,"It's okay to be sad,"],[2889,3053,"but do you still want cake?"],[3313,3350,"Yes."],[3496,3606,"I can come too."],[3606,3706,"Cake's on me."],[3783,3871,"Chloe,"],[3871,4016,"can you please forgive me?"],[4723,4827,"Look at the cookies."],[4827,4956,"They still look warm!"],[4986,5150,"Oh my gosh, it's like a family trip!"],[5260,5396,"Chloe, we had a deal."],[5470,5650,"Cake today, no candy."],[5773,5833,"Okay."],[6239,6350,"No way!"],[6366,6500,"Jane Lockhart?"],[7146,7296,"I can't believe it!"],[7323,7516,"I haven't seen you since"],[7516,7690,"the mistress scandal!"]],"13":[[43,210,"Lydia, it's good to see you as well."],[253,339,"See you haven't changed."],[363,413,"Come on."],[490,640,"I'm just genuinely concerned."],[696,923,"People still label you as the cheater."],[980,1083,"It stings!"],[1083,1246,"I've told you a thousand times"],[1246,1356,"that it's just a rumor."],[1366,1423,"A rumor?"],[1483,1553,"So you're saying"],[1553,1660,"you didn't sleep with the judge"],[1660,1798,"to win the dancing tournament?"],[1826,2024,"Okay, I don't know why you resent me so much,"],[2024,2096,"but there are kids."],[2213,2246,"Kids?"],[2323,2443,"Oh, Jane!"],[2539,2833,"Look at you, acting all high and mighty."],[2910,3000,"But your kid,"],[3083,3183,"she deserves to know"],[3183,3453,"what kind of a disgusting mother she has."],[3453,3593,"You're crossing the line!"],[3623,3679,"Come on!"],[3726,3796,"I'm just curious."],[3913,4056,"How old is your kid?"],[4056,4246,"I don't need to explain my life to you."],[4273,4376,"And your husband,"],[4423,4523,"does he know what you did?"],[4583,4906,"And sir, are you sure the kid's even yours?"],[4933,5270,"I mean, after all, she is a cheater."],[5270,5303,"Lydia!"],[5406,5489,"That's none of your business!"],[5650,5776,"I don't care who you are,"],[5776,5900,"you don't talk to her like that!"]],"14":[[83,176,"Do you even know what she did?"],[243,356,"I told you, I don't care!"],[416,501,"We're shopping"],[501,623,"and you're wasting our time."],[673,786,"You need to leave."],[873,1093,"But you're defending a shameless whore."],[1119,1159,"Enough!"],[1256,1456,"If you can't behave, I'll call security,"],[1456,1593,"or better yet, the police."],[1636,1780,"Maybe they can teach you some manners."],[1880,1916,"Fine."],[2026,2096,"But Jane..."],[2289,2360,"People talk."],[2450,2550,"They'll know the truth."],[2613,2723,"You'll pay for this."],[3200,3253,"Dr. Darcy, I..."],[3276,3366,"Sweet or sour?"],[3513,3570,"What?"],[3606,3753,"We were picking candies."],[3796,4050,"Did you say you prefer sweet or sour?"],[4286,4326,"Sweet."]],"15":[[63,236,"Thank you, Dr. Darcy."],[276,423,"For taking Chloe out"],[423,570,"and for defending me."],[570,726,"I really appreciate it."],[800,833,"Next!"],[926,963,"Hi there."],[1059,1216,"Hey, how you doing?"],[1286,1380,"Great, thanks for asking."],[1456,1680,"You signed up to our membership program?"],[1680,1880,"It's pretty sweet, you got discounts and stuff."],[1880,1913,"Sure."],[2000,2219,"Let's exchange numbers."],[2219,2366,"I'll send you some deals."],[2750,2836,"What's your number?"],[3126,3320,"There's no need for that."]],"16":[[43,229,"There's no need for that."],[426,526,"What's taking so long?"],[616,693,"Chloe wants her cake."],[900,1086,"Your total is $53.21."],[1163,1213,"I'll get it."],[1246,1316,"What? No."],[1316,1500,"Give me my phone back and I can pay."],[2356,2436,"I think you've collected"],[2436,2646,"enough numbers today, Ms. Lockhart."],[2763,2833,"Come on, Chloe."],[3103,3286,"Dr. Darcy, I can explain!"],[3336,3443,"You don't need him."],[3673,3850,"Wait, Dr. Darcy, please!"],[3893,4096,"I just wanted the membership."],[4129,4193,"You have to believe me,"],[4193,4426,"I've never asked a guy for contact info before."],[4643,4689,"Come on."],[4753,4846,"Oh my God!"],[4933,5106,"He wants to hold my hand!"]],"17":[[453,546,"What are you doing?"],[636,743,"You wanted to hold my hand."],[773,866,"No, the bag!"],[890,1193,"Oh, I mean, I can hold it myself."],[1236,1323,"We're at the car."],[1416,1566,"The bag goes in the trunk."],[1639,1743,"I see, yeah."],[1813,1973,"Oh, what am I doing?"],[2680,2716,"Jane,"],[2726,2839,"I'm the one"],[2839,2973,"getting checked for maternity"],[2973,3143,"and somehow you're the one freaking out?"],[3143,3346,"Shh! Quiet, Dr. Darcy could hear you!"],[3346,3506,"So? Isn't that what you wanted?"],[3539,3741,"No. No, because something happened last night"],[3741,3836,"and I was an idiot."],[3876,4020,"Because I always make a complete"],[4020,4220,"fool of myself every time I see him."],[4243,4326,"And I don't know why."],[4446,4563,"Naive worries."],[4606,4723,"How about, \"Hey, Lily,"],[4723,4893,"don't worry, don't be scared."],[4906,5110,"Pregnancy isn't gonna ruin your life.\""],[5170,5389,"Hey, are you scared?"],[5389,5521,"Yes, of course I am!"],[5521,5589,"Luke's at work"],[5589,5829,"and I don't want to face this alone."],[5860,5963,"Don't worry."],[6036,6126,"I got you."],[6236,6286,"Lily Adams?"],[6559,6653,"No, you go."],[6743,6893,"You hear it, and you tell me."],[7309,7529,"Uh, Lily Adams?"],[7616,7793,"Congratulations! You're pregnant!"]],"18":[[23,233,"Congratulations! You're pregnant!"],[300,479,"Here's your report. Congrats again!"],[796,863,"Henry."],[1303,1383,"Who's that?"],[1453,1603,"You're so focused..."],[1860,1919,"No one."],[2706,2806,"Are you excited about the"],[2806,2956,"recitals this year, Ms. Lockhart?"],[2966,3163,"I'm so excited. Are you excited?"],[3226,3246,"Yeah."],[3279,3316,"Chloe?"],[3383,3456,"Uncle Henry!"],[3516,3589,"How's it going?"],[3626,3666,"Good."],[3706,3826,"Dr. Darcy,"],[3826,3956,"it's been a while."],[3956,4063,"Have you been busy?"],[4100,4213,"Very, yeah."],[4303,4493,"Um, well, I mean, I was just,"],[4493,4643,"I was thinking about our last meeting."],[4696,4756,"Last meeting?"],[4793,5016,"Yeah, um, you know, at the bakery."],[5136,5263,"Yeah, you know, I didn't mean–"],[5263,5570,"I'm sorry, Ms. Lockhart, but uh, we have to go."],[5616,5646,"Oh."],[5683,5723,"Goodnight."],[5723,5813,"So soon? I–"],[6093,6273,"You know, you're really great with Chloe."],[6420,6533,"She ever told you that?"],[6686,6833,"I think you'd make a great dad."],[6896,7033,"I'm sorry, Ms. Lockhart."],[7033,7283,"I'm not interested in playing stepdad."],[7356,7416,"What?"]],"19":[[156,250,"What did you say?"],[366,446,"Goodnight."],[479,796,"Come on, Chloe. Let's go."],[876,1000,"What is he talking about?"],[2213,2360,"Jane, you're back!"],[2403,2526,"A letter arrived."],[2546,2713,"It's from Aura Dance Competition."],[2746,2943,"Great, maybe they approved my appeal."],[3529,3660,"We regret to inform you"],[3660,3823,"that the appeal has been denied."],[4050,4200,"How is that possible?"],[4316,4416,"Didn't they say you had good"],[4416,4589,"chances of clearing the rumors?"],[4729,4970,"This says \"new reports and complaints.\""],[5056,5136,"Who would do this?"],[5283,5539,"You know, I did see Lydia recently."],[5816,6004,"I haven't seen her in years."],[6004,6096,"Why would she do that?"],[6466,6676,"You know what else came for you?"],[6773,6923,"This high school reunion invitation."],[6963,7059,"Yeah, I don't do reunions."],[7096,7370,"Yeah, but the people who want to hurt you"],[7370,7483,"might be there."],[7526,7646,"You may find the truth."],[10496,10629,"It's hurting again."],[11333,11390,"Dr. Darcy!"]],"20":[[16,50,"Um..."],[433,529,"What are you doing here?"],[570,750,"I came to pick up Chloe."],[993,1283,"Uh, Chloe's mom picked her up earlier."],[1313,1503,"I... did she forget to tell you?"],[2380,2537,"I'll head back."],[2567,2703,"Sorry to interrupt."],[2736,2826,"Wait, um,"],[2939,3053,"could you, uh,"],[3146,3276,"go to the hospital with me?"],[3323,3466,"I just need to get something checked out."],[3623,3889,"You want me to go with you?"],[3913,4079,"Yeah, if you're not busy or anything."],[4236,4386,"Isn't there somebody else?"],[4496,4606,"Maybe the father?"]],"21":[[3,116,"The father?"],[116,199,"What father?"],[260,423,"I guess it's supposed to be a secret."],[553,646,"What are you talking about?"],[700,776,"Never mind."],[909,1100,"Alright. Yeah, I'll take you"],[1100,1196,"to the hospital."],[1209,1291,"Great."],[1291,1416,"Just give me one second."],[1800,2043,"You're just taking care of a pregnant patient."],[2119,2180,"That's all."],[2276,2363,"Nothing special."],[2736,2836,"Hey, let's go."],[3183,3343,"Alright, you're all set."],[3343,3529,"They'll call your name in a bit."],[3696,3863,"Thank you, Dr. Darcy."],[3983,4163,"I'm normally not scared of the hospital,"],[4163,4256,"but I... just."],[4289,4460,"I've been putting it off for a really long time."],[4553,4656,"I don't know, it's a big decision."],[4723,4779,"You're welcome."],[4900,5070,"Yeah, I was hoping after this"],[5070,5186,"I could just start fresh"],[5186,5376,"and get back to dancing on stage."],[5450,5756,"Right. I mean, usually recovery takes"],[5756,6113,"about 6 to 12 months, but maybe quicker."],[6166,6303,"But you haven't even checked me yet."],[6316,6396,"How do you know"],[6396,6556,"how long recovery is going to be?"],[6583,6720,"Doesn't it vary from person to person?"],[6773,6953,"I mean, I do work in a hospital,"],[6953,7146,"even if it's not maternity."],[7336,7420,"Maternity?"],[7453,7559,"What do you mean?"]],"22":[[126,235,"Maternity?"],[235,336,"What do you mean?"],[409,507,"It's okay."],[507,636,"I already know."],[736,819,"Know what?"],[930,1259,"The child. Your pregnancy."],[1346,1496,"I don't know why you kept it a secret..."],[1496,1603,"- What? - But it's okay."],[1666,1753,"Who's pregnant?"],[1839,2063,"I figured it out last time you came to the hospital."],[2133,2323,"I happened to pass by."],[2633,2796,"Congratulations! You're pregnant!"],[3166,3333,"Wait. Wait. Wait."],[3333,3460,"You think I'm pregnant?"],[3676,3820,"Are you laughing?"],[3863,3996,"Parenthood isn't a joke."],[3996,4093,"Oh, no, but ..."],[4093,4220,"I'm not pregnant."],[4233,4386,"It's my friend!"],[4396,4606,"I was here with her for her checkup."],[4663,4750,"Wait!"],[4783,4910,"Dr. Darcy,"],[4950,5070,"did you think that I was looking"],[5070,5243,"for a stepdad for my child?"],[5379,5573,"That's why you've been avoiding me."],[5929,6129,"Don't worry, Dr. Darcy."],[6229,6326,"If I were pregnant,"],[6326,6446,"the father would definitely be you!"],[6493,6693,"You can't say things like that."],[6800,6916,"Dr. Darcy,"],[6986,7166,"do you want to be the father of my child?"]],"23":[[210,229,"Enough!"],[393,520,"That's why you've been avoiding me?"],[616,751,"No, I'm just..."],[751,840,"I'm not interested."],[936,1013,"Oh, okay."],[1080,1180,"I'm curious though,"],[1180,1373,"do you treat all your patients like this?"],[1423,1563,"Or do you just care about me specifically?"],[1626,1846,"It's just concern for Chloe's teacher."],[1866,1993,"You're misinterpreting."],[2000,2093,"Sure, okay."],[2236,2326,"Well, since you're here,"],[2413,2523,"could you get me a glass of water?"],[2836,3013,"It's just a glass of water!"],[3146,3306,"Hello, Dr. Darcy."],[3343,3453,"Since you're not pregnant,"],[3453,3623,"you can take care of yourself."],[3733,3836,"Hey there, young man!"],[3926,4003,"That's not cool."],[4063,4166,"Your girlfriend's in the hospital"],[4166,4336,"and you can't even get her a glass of water?"],[4466,4593,"That's not how you show responsibility."],[4866,5026,"Yeah, that's right, boyfriend."],[5073,5176,"I'm not... We're not–"],[5220,5279,"Jane Lockhart?"],[5476,5520,"I gotta go!"],[5583,5646,"Remember,"],[5676,5776,"water, yeah?"],[6553,6659,"Doctor, how's my ankle?"],[6800,6943,"Do you think I can start dancing again?"],[7273,7329,"Ms. Lockhart."],[7403,7550,"How long have you been feeling pain"],[7550,7626,"in your ankle?"]],"24":[[30,153,"Why? What's wrong? Is it serious?"],[229,333,"No, not at all!"],[426,616,"In fact, your ankle is perfectly fine."],[726,868,"If you're still feeling pain,"],[868,1009,"it could be psychological."],[1143,1256,"Psychological?"],[1316,1436,"Many athletes"],[1436,1603,"who've been through emotional traumas"],[1603,1796,"often develop a mental block."],[1880,2043,"I'd recommend seeing a therapist"],[2043,2133,"to work this through."],[3893,4039,"Oh, Lydia! Finally!"],[4120,4250,"Saved the best for last, huh?"],[4416,4626,"The guest of honor isn't me tonight."],[4653,4803,"Isn't that right, Jane?"],[4929,5053,"Come on, sit next to me!"],[5139,5186,"Here?"],[5316,5386,"Yeah, Jane."],[5386,5513,"We haven't seen you since..."],[5513,5583,"what happened..."],[5720,5983,"Jane blesses us with her presence tonight."],[6163,6253,"How honored!"],[6366,6526,"Yeah, we just saw each other, Lydia,"],[6526,6663,"so I wouldn't over exaggerate."],[6736,6793,"You know,"],[6840,7096,"you're pretty famous online these days!"],[7140,7313,"What are they calling you..."],[7359,7496,"Oh, the Mistress Dancer!"]],"25":[[50,229,"Oh, the Mistress Dancer!"],[373,436,"Alright,"],[473,600,"let's look at the menu."],[656,763,"What are we getting?"],[826,943,"Let Jane decide!"],[1050,1159,"I'm sure she has"],[1159,1283,"quite an appetite,"],[1283,1443,"considering her..."],[1463,1553,"taste in men!"],[1750,1876,"Why don't we just order everything"],[1876,1969,"off the menu?"],[1986,2039,"Remind me,"],[2039,2180,"who's picking up the bill again tonight?"],[2210,2296,"Are you crazy?"],[2373,2536,"Ah right, you're paying the check, right?"],[2630,2773,"Well, I hope your wallet can handle it,"],[2773,2950,"considering I have such a big appetite."],[3000,3110,"Big appetite, huh?"],[4096,4156,"You know,"],[4166,4279,"I came here tonight"],[4279,4443,"so that I could actually catch up with you,"],[4443,4573,"but you're all just the same"],[4573,4800,"pathetic, mean bunch from high school."],[4989,5303,"You know, I hope you all live a miserable life!"],[5666,5756,"Did we go too far?"],[5796,5993,"Her skin still looks perfect."],[6116,6203,"Shut up!"],[6289,6383,"All of you, shut up!"],[6853,7059,"This is why I don't do reunions!"]],"26":[[1453,1506,"Wow!"],[1536,1696,"You're really something, aren't you?"],[1906,1983,"It really is you!"],[2239,2310,"What are you doing here?"],[2456,2586,"Well, I was out with friends"],[2586,2763,"but then I saw you sitting out here,"],[2823,2886,"all alone."],[3039,3136,"You know, it's late."],[3246,3339,"It can be dangerous."],[3843,4056,"You're too good to me, Dr. Darcy!"],[4413,4616,"Everything is going to be okay, Jane!"],[4960,5083,"How much did you drink tonight?"],[5186,5250,"One can!"],[5373,5450,"I promise!"],[5626,5660,"Liar!"],[6186,6289,"Why did you drink tonight?"],[6429,6536,"Some trouble at work."],[6640,6796,"I just wanted to forget. For a little."],[8703,8856,"Dr. Darcy..."],[9150,9293,"How do you face..."],[9400,9520,"rumors..."],[9616,9733,"and lies"],[9809,10000,"when people are trying to tear you down?"],[10296,10420,"If you're misunderstood,"],[10490,10650,"just explain yourself once."],[10729,10846,"Because sometimes,"],[10863,11073,"no matter how hard you try,"],[11140,11312,"People just want to believe the lies"],[11312,11429,"that fit their narrative."],[11496,11656,"People who truly believe in you,"],[11736,11940,"they don't need any explanation."],[12453,12583,"They just know."],[12869,12966,"Do you believe in me?"]],"27":[[700,806,"I believe in you."],[1900,2066,"And... It's so cute..."],[2308,2452,"Yeah, it's very cute."],[3739,3866,"Dr. Darcy,"],[4020,4086,"you know,"],[4146,4253,"when I first met you,"],[4336,4556,"you were so unapproachable."],[4743,4783,"Like,"],[4783,4956,"you didn't even seem like a real person!"],[5079,5153,"I don't know."],[5166,5279,"Your vibe..."],[5316,5383,"It's just..."],[5383,5489,"unreal."],[5873,5996,"Are you really just a doctor?"],[6213,6250,"Yes?"],[6279,6416,"Yeah, because like doctors, they have,"],[6463,6613,"they have like long hours"],[6613,6716,"and sleep deprivation"],[6773,6883,"and they like, look the part,"],[6883,7000,"but like, you don't,"],[7040,7279,"you just kind of look like,"],[7333,7617,"like a rich billionaire heir or something."],[7793,7853,"Is that so?"],[8120,8326,"But you're just a regular doctor, right?"],[8450,8590,"If I really try hard,"],[8623,8776,"then I can win you over?"],[9290,9403,"Why did you defend me?"]],"28":[[3,119,"This isn't a gossip corner!"],[153,273,"You know, I don't expect nurses"],[273,400,"to be talking about doctors,"],[400,573,"especially right outside of their offices!"],[843,883,"Oh!"],[996,1066,"Oh, right."],[1066,1180,"You saw that!"],[1296,1393,"I..."],[1416,1496,"just–"],[1583,1826,"I know what it's like to..."],[1826,1943,"be affected by rumors."],[2030,2156,"And I don't know."],[2156,2316,"It's hard for ordinary people"],[2316,2439,"to deal with it themselves."],[2873,2946,"So,"],[3150,3260,"don't worry, Dr. Darcy."],[3379,3446,"I'll protect you!"],[3586,3666,"Protect me?"],[3696,3736,"Mm-hmm."],[3889,4086,"Because we're just regular people."],[4110,4366,"I mean, we don't have, like, crazy, you know,"],[4366,4543,"privilege or wealth or anything like that."],[4593,4729,"So, we gotta take care of each other."],[4920,5193,"Plus, I really, really like you!"],[5406,5510,"You knew that already."],[5810,5946,"I should– I should go."],[6016,6060,"No, wait."]],"29":[[759,806,"Jane!"],[916,963,"I..."],[1626,1693,"Are you okay?"],[1843,1966,"Dr. Darcy,"],[1966,2143,"just forget that happened"],[2163,2286,"and reset your memory."],[3896,3956,"Jesus!"],[4096,4189,"You scared me!"],[4296,4446,"What happened?"],[4533,4663,"Just kill me!"],[4723,4856,"Okay, spill first"],[4856,5029,"and I'll decide later if I kill you."],[5370,5543,"I kissed Dr. Darcy last night."],[5613,5663,"That doctor?"],[5706,5793,"The doctor?"],[5879,6013,"You finally got with him?"],[6066,6170,"No, I..."],[6189,6320,"I kissed him..."],[6339,6483,"and then I threw up!"],[6506,6726,"Like right in front of him, so..."],[7043,7136,"Was it bad breath?"],[7136,7336,"No, I was a drunk and I..."],[7386,7483,"and I shoved him away!"],[7483,7786,"But I vomited like right in front of him!"],[7903,8003,"He saw everything?"],[8390,8526,"Maybe I should kill you."],[8626,8826,"I should..."],[8826,9009,"text him and apologize!"],[9073,9233,"No, you're probably blocked already."],[9263,9433,"It took me so long to get his number."],[9433,9573,"I can't just miss this chance."],[9640,9856,"Alright, if you wanna fix it,"],[9883,10063,"don't just go with a lazy message, okay?"],[10106,10376,"I mean, get him a gift, show up in person"],[10396,10490,"and say you're sorry."],[10640,10676,"Yeah."],[11606,11713,"Wow, you're everywhere."]],"30":[[786,953,"We had fun at the reunion without you!"],[1013,1069,"You know,"],[1069,1183,"nobody really misses"],[1183,1346,"the notorious mistress dancer!"],[1419,1526,"Yeah, you know, Lydia,"],[1526,1663,"I don't have time for this, so..."],[1700,1756,"I'm not done!"],[1939,2093,"What is wrong with you?"],[2169,2200,"Wow!"],[2263,2413,"Trying to land yourself a doctor now?"],[2500,2616,"Who's your target this time?"],[2753,2916,"Yeah, you know those rumors aren't true."],[3003,3166,"So, why do you keep trying to ruin my life?"],[3273,3406,"We grew up together, Jane."],[3489,3696,"I was the one working harder,"],[3696,3866,"pushing myself further!"],[3933,4056,"I was the best,"],[4056,4176,"but nobody cared!"],[4300,4436,"They only saw you!"],[5400,5583,"So, you ruined my life"],[5610,5713,"out of jealousy!"],[5886,6029,"You don't know how it feels"],[6029,6179,"to come second, Jane!"],[6373,6483,"And I never knew what it felt like"],[6483,6606,"to be first,"],[6676,6770,"until you left!"],[6986,7176,"I won't let anyone take it from me!"],[8320,8390,"Dr. Darcy!"]],"31":[[76,133,"Dr. Darcy!"],[260,313,"You okay?"],[426,606,"Yeah, I'm fine."],[653,846,"You sure? Who are you talking to?"],[900,936,"No one."],[1303,1356,"What's that?"],[1490,1536,"Nothing!"],[1653,1826,"I'm just... I'm clumsy. I just dropped it."],[1936,2056,"Are you sure you're okay?"],[2106,2336,"Yeah, um, thank you for your time."],[2383,2500,"I just, I really need to..."]],"32":[[386,516,"Hey, Clara!"],[516,653,"Have you heard the rumors"],[673,823,"about Jane Lockhart's"],[823,976,"dance studio?"],[1040,1103,"Matt!"],[1243,1313,"I got the report."],[1359,1446,"I'm pregnant."],[1516,1586,"Get rid of it!"],[1593,1723,"I can't have my wife find out."],[1793,1986,"You promised me you'd get a divorce!"],[2046,2136,"Clara's about to take over"],[2136,2233,"her father's company."],[2233,2400,"It's the biggest medical group in the world."],[2426,2533,"How long do I have to wait?"],[2619,2703,"Just be patient!"],[2806,2893,"Stop stalling!"],[2993,3150,"I have your wife's contact info,"],[3169,3300,"and I have seen your daughter,"],[3320,3373,"Chloe!"],[3443,3596,"Don't push me!"],[4243,4379,"I'm here to schedule my next appointment."],[4436,4650,"Haven't you heard that Dr. Darcy is the heir"],[4650,4800,"to the Polaris Medical Group?"],[4903,5100,"He's only here because of some family drama."],[5186,5260,"Polaris?"],[5300,5466,"That's the largest medical company in the world!"],[5500,5566,"Mm-hmm."],[5566,5666,"He must be loaded!"],[5739,5836,"Dr. Darcy?"],[5929,6060,"He's the heir to Polaris Group?"],[6253,6293,"I'm sorry."],[6316,6455,"We were just–"],[6455,6587,"We were just talking about someone"],[6587,6695,"from a TV show."]],"33":[[1823,1856,"Clara?"],[1896,2156,"It seems like Jane pissed off the wrong people."],[2230,2310,"But why do you care?"],[2439,2493,"I..."],[2493,2569,"I don't know."],[2650,2930,"I've said it before, Jane Lockhart and you?"],[2980,3080,"A perfect match!"],[3370,3550,"Does she know who you are?"],[3666,3839,"She knows I'm Henry Darcy,"],[3873,3970,"and that's enough."],[3986,4079,"No, Henry."],[4150,4339,"Our lives are more complicated than that."],[4406,4646,"If you like her, you need to tell her."],[5133,5353,"Because we're just regular people."],[5353,5529,"So, we gotta take care of each other."],[6316,6400,"Dr. Darcy!"],[6490,6776,"Hey Jane, are you, uh, still in the studio?"],[6846,7090,"No, actually I'm on my way to see you now!"],[7129,7229,"Oh, you are?"],[7290,7483,"Yes, last time I brought you a gift,"],[7483,7570,"but it's ruined."],[7603,7786,"I brought double this time just to be safe."],[7926,8020,"I'm almost there!"]],"34":[[276,416,"Uh, I have to call you back."],[570,683,"Hello, Dr. Darcy!"],[746,1006,"I heard you're the best doctor in this field."],[1163,1213,"Can I help you?"],[1419,1583,"No need to be so formal."],[1706,1839,"I'm just here because..."],[1839,2069,"I think I have some sort of"],[2076,2246,"allergic reaction in some"],[2269,2419,"sensitive areas."],[2486,2626,"Maybe you could take a look?"],[2716,2880,"Miss, this is a hospital!"],[2913,3004,"Address your issue"],[3004,3103,"or I'll call in the next patient."],[3103,3189,"Wait, no, doctor!"],[3189,3303,"I really need your help!"]],"35":[[200,320,"Of course it's you!"],[320,429,"Ever heard of knocking?"],[646,703,"Uh,"],[703,891,"clearly I came at the wrong time,"],[891,969,"so I'll leave."],[1050,1163,"No, Jane, stay!"],[1223,1323,"I was here first!"],[1419,1530,"We've not even done my session!"],[1923,2050,"I don't care who you are,"],[2050,2169,"you don't talk to her like that!"],[2339,2523,"Wait, you're Henry Darcy?"],[2600,2746,"Heir to Polaris Medical Group?"],[3036,3176,"Dr. Darcy?"],[3206,3450,"You really hit the jackpot this time."],[3496,3636,"Sleeping with billionaires now?"],[4089,4256,"You have three seconds to leave,"],[4256,4420,"or I'll make you regret it!"],[4953,5220,"Dr. Darcy, what did she mean?"]],"36":[[23,160,"I was gonna tell you!"],[266,403,"So it's true, you're..."],[436,523,"you're the heir to"],[550,666,"Polaris Medical Group?"],[693,783,"It's a long story!"],[833,963,"And you didn't tell me about it!"],[963,1083,"Jane, I'm sorry."],[1143,1253,"No, no, you know what?"],[1290,1446,"Don't apologize."],[1446,1619,"I'm not anything to you,"],[1619,1660,"so,"],[1819,1939,"I shouldn't even ask."],[1963,2160,"Jane, I need to apologize,"],[2160,2360,"but Lydia was spreading rumors about you"],[2360,2456,"and I was worried."],[2456,2560,"Why do you even care?"],[2630,2739,"It's none of your business!"],[2826,2883,"You know what?"],[2883,3070,"I shouldn't ask about your life and, and, and,"],[3070,3226,"you shouldn't ask about mine!"],[3536,3703,"I have taken up enough of your time."],[3863,3913,"So,"],[4053,4133,"goodbye."],[4253,4283,"Jane!"],[5273,5403,"What is it this time?"],[5516,5646,"Are all men liars?"],[5746,5916,"Yeah, it's in their DNA."],[5916,6046,"They can't help it!"],[6189,6286,"Okay, well, what do you do"],[6286,6403,"when one breaks your heart?"],[6503,6556,"Well,"],[6559,6766,"it's probably not the healthiest answer,"],[6766,6890,"but I'd probably go out"],[6890,6976,"and meet another man."],[7133,7183,"What?"],[7353,7468,"The rebound strategy is"],[7468,7553,"a bit messy,"],[7553,7743,"but you know, it's very effective."],[7823,7943,"You'll feel better fast!"],[8196,8359,"Try it for yourself, okay?"],[8433,8526,"Luke has a friend"],[8526,8693,"who's also a doctor..."],[8706,8896,"and I can set you up!"],[8956,9046,"Okay."]],"37":[[663,703,"Hello there!"],[846,876,"Hi."],[959,1019,"I'm Dick!"],[1123,1256,"You can tell I'm a doctor, right?"],[1313,1416,"I wanted to save you"],[1416,1509,"the trouble of guessing."],[1623,1660,"Yeah,"],[1743,1796,"It's pretty obvious."],[1853,1916,"So, what do you do?"],[1963,2019,"Oh, I–"],[2026,2216,"I run a dance studio for kids."],[2253,2313,"They're ages five–"],[2313,2456,"Ah, I see!"],[2500,2596,"Starving artist."],[2743,2919,"Ah, this isn't going well!"],[2953,3016,"It's really not."],[3133,3200,"But you're pretty!"],[3283,3323,"So,"],[3356,3436,"as long as you promise"],[3436,3546,"to keep things separate, you know,"],[3546,3676,"keep your fingers out of my wallet,"],[3806,3939,"I'm sure we can work something out!"],[4036,4060,"Yeah..."],[4286,4433,"Wow, look at the time!"],[4503,4716,"You know, we've been talking for so long!"],[4763,4843,"Been here for five minutes."],[4896,4953,"Yeah, and you know,"],[4953,5093,"my phone's almost dead,"],[5103,5256,"so I just gotta go!"],[5896,6086,"Could you update the patient's file, please?"],[6363,6520,"Depressing times we live in, isn't it?"],[6626,6713,"Are you alright, doctor?"],[6803,6956,"I went on this date with this"],[6956,7026,"dance instructor..."]],"38":[[3,153,"I went on this date with this"],[153,270,"dance instructor,"],[286,389,"and she looked good!"],[389,509,"So, I gave her a shot."],[566,709,"But then, I looked her up later online"],[709,826,"and it turns out"],[826,966,"she's somebody's mistress!"],[1023,1136,"It was all over the news!"],[1159,1243,"What did you just say?"],[1336,1396,"Who was this?"],[1426,1490,"Who, my date?"],[1553,1619,"Her name is..."],[1666,1856,"Jane Lockhart or something."],[1896,2073,"She looks good, but underneath..."],[2150,2203,"Disgusting!"],[2433,2603,"Don't talk about her like that!"],[2693,2783,"Where did you meet her?"],[2980,3119,"The restaurant on the corner."]],"39":[[93,189,"I promise!"],[250,426,"This guy's better than the last one!"],[436,606,"No, I've already been on two dates today,"],[606,781,"and I just feel like this rebound idea"],[781,896,"is not the solution, so–"],[969,1109,"I think I should call it a day."],[2430,2533,"Dr. Darcy."],[2610,2696,"What are you doing here?"],[2803,2950,"You're going on blind dates?"],[3026,3130,"Yes, and"],[3130,3320,"it's really none of your business, so..."],[3396,3576,"So you're looking for a date, right?"],[3693,3839,"Yeah, and Like I just said"],[3839,3903,"it's none of your–"],[3903,3966,"Date me!"]],"40":[[113,346,"If you're so determined to date somebody,"],[346,459,"then..."],[520,600,"date me!"],[890,1030,"I wouldn't date you"],[1093,1259,"if you were the last man on Earth!"],[4516,4653,"So,"],[4653,4776,"will you date me now?"],[5036,5300,"Um, I need to go to the bathroom."],[6210,6329,"Oh my god!"],[6329,6490,"I'm burning up!"],[7093,7276,"Where did he learn how to kiss like that?"],[7500,7683,"And I didn't throw up this time!"],[7909,8233,"No, Jane, no, he's still a liar!"],[8270,8383,"You need to just..."],[8383,8500,"Be strong and,"],[8500,8626,"and resist temptation!"],[9826,9956,"I've thought about it, and..."],[9956,10050,"I don't date liars."],[10050,10209,"So, goodbye."],[10426,10509,"Jane Lockhart,"],[10570,10666,"stay with me!"]],"41":[[36,76,"Fine."],[139,246,"I liked you before."],[300,353,"But,"],[400,520,"you lied to me!"],[656,729,"I'm"],[729,830,"no longer interested."],[956,1080,"I'm interested!"],[1130,1269,"Very interested!"],[1426,1593,"It's too late. I don't forgive you!"],[1700,1833,"You don't have to forgive me."],[1956,2113,"I know I made mistakes."],[2219,2396,"And I'll explain everything!"],[2533,2676,"You don't have to say yes right now."],[2676,2766,"Just give me a chance!"],[3053,3180,"What kind of deal is that?"],[3383,3579,"I'm no longer in love with you."],[3853,3923,"It's okay."],[4216,4343,"Because I'm in love with you!"],[5329,5450,"I have a class to teach,"],[5450,5620,"so I have to go."],[7656,7726,"Ms. Lockhart?"],[7763,7793,"Yes."],[7833,7923,"Um, Chloe?"],[8120,8300,"Something happened!"],[8320,8363,"What?"],[8390,8493,"No, no."],[8573,8696,"You're acting a lot like"],[8696,8863,"Uncle Henry did earlier today."],[9146,9170,"Really?"],[9313,9343,"Yeah."],[9470,9706,"Did something happen between you two?"],[10040,10156,"Chloe!"],[10406,10576,"What are you doing here?"],[10716,10756,"Dad!"]],"42":[[226,323,"Hello, Miss Lockhart."],[363,496,"It's my first time picking up Chloe."],[570,686,"Clara usually handles this."],[726,779,"Right,"],[840,986,"sorry, where is Clara today?"],[1013,1069,"She's busy."],[1119,1290,"This is Lydia, my assistant."],[1453,1613,"She might be the one picking up Chloe"],[1613,1683,"from now on."],[1723,1876,"You know how Clara is,"],[1876,1959,"always busy!"],[2016,2200,"Little things like this shouldn't concern her."],[2383,2446,"Don't worry!"],[2469,2626,"Jane and I go way back!"],[2676,2756,"Don't we, Jane?"],[2973,3119,"Alright. Chloe, time to go."],[3119,3196,"Okay."],[3453,3576,"Bye, Ms. Lockhart."],[4776,4933,"I can't be sure. I mean,"],[4933,5026,"what if..."],[5026,5176,"Lydia is just pretending?"],[5560,5723,"This is my assistant."],[5929,6046,"Little things like this shouldn't concern her."],[6106,6160,"No,"],[6160,6220,"you know,"],[6220,6353,"Matt looked too comfortable,"],[6353,6420,"and..."],[6440,6609,"he looked like he was used to it!"],[6716,6846,"There's definitely something going on."]],"43":[[953,1023,"What do you want?"],[1190,1326,"What's your schedule like tomorrow?"],[1456,1630,"I'm busy, very busy."],[1763,1813,"Busy with what?"],[2026,2153,"Stuff, important stuff."],[2223,2310,"None of your business!"],[2500,2566,"I see."],[2586,2676,"Well,"],[2676,2819,"I was just..."],[2819,2916,"wanting to..."],[2916,3039,"ask you out tomorrow!"],[3166,3196,"Really?"],[3346,3403,"I mean,"],[3403,3470,"I..."],[3520,3616,"I'll have to think about it."],[3656,3720,"I'll see you tomorrow."],[3813,3843,"What?"],[4266,4383,"I didn't say yes!"],[5426,5493,"Clara!"],[5579,5720,"She's his sister!"],[5770,5876,"and Chloe, I..."],[5976,6103,"What should I do?"],[7506,7579,"Clara?"],[7676,7859,"I have to change that passcode."],[8003,8076,"Clara!"],[8103,8190,"What happened?"],[8376,8523,"Have you been drinking?"],[8990,9109,"Matt's cheating on me."]],"44":[[83,170,"How did you find out?"],[323,456,"I think I've always known."],[633,858,"Yesterday, Jane called me just asking"],[858,1060,"if I was aware that an assistant"],[1060,1250,"was gonna start picking Chloe up."],[1343,1480,"But the moment she mentioned it"],[1480,1646,"I knew something wasn't right."],[1760,1816,"Jane?"],[1863,1973,"She figured it out?"],[2046,2133,"She's sharp!"],[2139,2223,"Maybe she did."],[2366,2496,"I confronted Matt and he..."],[2516,2676,"didn't even bother denying it."],[2726,2799,"He shrugged it off"],[2799,2996,"and told me to stay out of his life!"],[3053,3130,"Matt's an asshole!"],[3220,3276,"Yeah!"],[3346,3476,"I've always known that too."],[3606,3736,"I just thought at the very least"],[3736,3933,"he would try to be a decent father!"],[4076,4243,"Instead, he lets that woman,"],[4266,4346,"Lydia,"],[4366,4453,"pick Chloe up."],[4556,4629,"How dare he?"],[4733,4783,"Lydia?"],[4863,4976,"Yeah, his assistant."],[5120,5243,"I heard she knew Jane too."],[5243,5339,"She's also a dancer."],[5420,5543,"She's not just anyone!"],[5543,5683,"She's hurt Jane before."],[5783,5946,"I stopped by Matt's office earlier."],[6020,6182,"I was planning to confront Lydia,"],[6182,6286,"but she wasn't there."],[6346,6526,"Co-workers said she went to a dance studio."],[6626,6756,"Does Chloe have class today?"],[6859,6893,"No."],[7033,7073,"Why?"],[7223,7340,"I think Jane might be in danger!"]],"45":[[529,729,"How do you explain the news online?"],[809,933,"It's all over the internet!"],[980,1133,"And you're a teacher!"],[1133,1273,"I won't let someone like you"],[1273,1386,"ruin my daughter!"],[1436,1543,"Refund our money!"],[1543,1653,"Agreed. Refund!"],[1653,1753,"Shut this place down!"],[2139,2239,"Shameless whore!"],[2239,2453,"You're just a mistress for hire, aren't you?"],[2506,2619,"Disgusting!"],[2619,2786,"OK, please just calm down!"],[2786,2919,"It's all baseless rumors!"],[2936,3036,"You have to believe me!"],[3036,3130,"Why would we believe you?"],[3153,3220,"Where's the proof?"],[3276,3416,"Your friend filed a report!"],[3420,3536,"Thank God she warned us!"],[3566,3696,"Or our kids would be ruined!"],[3739,3770,"Yeah!"],[4296,4526,"Absolutely despicable!"],[6223,6346,"Didn't anyone tell you?"],[6533,6613,"Snitches get stitches!"]],"46":[[250,416,"Parents, it's okay."],[486,613,"I think she's suffered enough."],[700,800,"It's only a matter of time"],[800,943,"before the studio shuts down."],[1019,1093,"Let her go today."],[1336,1466,"Lydia, you're too kind."],[1509,1666,"Yeah, she doesn't deserve kindness."],[1716,1876,"She should face the consequences!"],[1989,2163,"She's an old friend of mine and,"],[2236,2433,"I can't bear to see her like this!"],[2543,2663,"Give us a moment, please."],[2710,2816,"I wanna talk to her."],[2866,2966,"We'll be right outside."],[3006,3176,"But we're shutting this place down today!"],[3246,3296,"That's right!"],[3853,3966,"Haven't you done enough?"],[3966,4133,"Why are you still trying to ruin my life?"],[4196,4293,"Because you went to Clara!"],[4410,4541,"You thought you could meddle in my life"],[4541,4616,"and get away with it?"],[4639,4820,"It's not meddling when you involve Chloe."],[4860,5006,"Whatever!"],[5033,5238,"Matt has already secured Polaris shares,"],[5243,5373,"he'll divorce Clara soon."],[5373,5453,"And you?"],[5493,5656,"You're stuck with Henry Darcy,"],[5656,5776,"that fucking loser!"],[5933,6103,"So, this is just about fame and fortune, huh?"],[6216,6492,"I fought to finally come first in competitions,"],[6492,6720,"only to realize, for some people,"],[6720,6853,"I'm still second place!"],[7236,7313,"Wow,"],[7356,7466,"you're pathetic!"],[7516,7596,"Shut up!"],[7613,7743,"I won, you lost!"],[7766,7859,"Don't you get it?"]],"47":[[863,1000,"Everything you've just said,"],[1033,1136,"I recorded it!"],[1183,1376,"And for everything you've done to Jane,"],[1376,1466,"trust me,"],[1493,1650,"you'll face the consequences!"],[1669,1813,"You can't do anything!"],[1883,2023,"Even Clara can't stop Matt"],[2023,2123,"from taking over now."],[2206,2326,"I wouldn't be so sure about that."],[2386,2493,"Matt's already head of Polaris."],[2546,2636,"You can't change anything"],[2636,2723,"by reporting an affair."],[2753,2833,"Oh, come on!"],[3110,3310,"Do you really think you're the first"],[3310,3500,"or only mistress?"],[3556,3656,"You know, thanks to you,"],[3656,3906,"I finally get to see who Matt really is,"],[3989,4116,"nothing but scum!"],[4350,4526,"It didn't take much digging to uncover"],[4526,4639,"the mess he's been hiding."],[4729,4956,"He has racked up countless complaints."],[5023,5196,"Because while maybe you have put up with him,"],[5220,5336,"plenty of others couldn't."],[5476,5576,"Here's the real kicker..."],[5733,5913,"You're not even a second choice, Lydia."],[6123,6203,"You're his tenth!"],[6496,6616,"And let me remind you,"],[6633,6840,"the agreements are crystal clear."],[6943,7146,"Any penalties or criminal charges"],[7156,7323,"void all ownership rights."],[7506,7536,"No."],[7686,7716,"No."],[7820,7886,"This isn't true."],[7983,8086,"These are lies!"],[8200,8303,"You of all people"],[8303,8403,"should know how hard it is"],[8403,8520,"to clear someone's name."],[8620,8743,"You ruined Jane's career"],[8743,8859,"with your baseless rumors!"],[8979,9106,"But unlike you and Matt,"],[9183,9293,"we don't just spread lies,"],[9376,9543,"we actually care about the truth"],[9590,9713,"and justice!"],[10883,10986,"I told you,"],[10986,11126,"everything's gonna be OK."]],"48":[[0,103,"This is unacceptable."],[103,223,"We can't let this go on!"],[260,356,"There she is!"],[403,516,"Shut this place down"],[516,656,"or we'll go straight to the police!"],[700,756,"Fine!"],[783,853,"Go to the police!"],[900,996,"And I'll report all of you"],[996,1126,"for disturbing public order!"],[1190,1376,"We are protecting our children!"],[1390,1463,"Exactly!"],[1463,1543,"Check your phones!"],[1603,1693,"The truth is out!"],[1776,1839,"The dance committee"],[1839,1953,"is holding a press conference"],[1963,2039,"as we speak,"],[2039,2176,"apologizing to Jane."],[2296,2486,"Good afternoon. I'm Tina Gray,"],[2526,2696,"president of the Aura Dance Committee."],[2773,2900,"I'm here to formally"],[2900,3156,"apologize to Jane Lockhart."],[3203,3320,"A few years ago,"],[3320,3500,"we received an anonymous report"],[3526,3846,"accusing Jane Lockhart of misconduct."],[3866,4016,"Based on fake evidence"],[4039,4223,"fabricated by"],[4223,4363,"the whistleblower,"],[4363,4470,"Lydia Lynn."],[4600,4836,"We wrongfully disqualified Jane"],[4846,5006,"from the competition."],[5063,5243,"I want to make it loud and clear!"],[5353,5529,"Jane Lockhart has never engaged"],[5529,5650,"in any behavior"],[5710,5816,"that compromised"],[5846,5920,"fair game."],[6003,6123,"As for Lydia Lynn,"],[6123,6270,"we have revoked her honors"],[6296,6516,"and have filed a lawsuit against her."],[6766,6829,"To Jane,"],[6920,7113,"I offer my sincerest apologies."],[7176,7290,"We were wrong."],[7306,7426,"And I am sorry."]],"49":[[0,63,"Lydia?"],[96,253,"Isn't she supposed to be Jane's friend?"],[433,643,"Could this all have been her scheme?"],[783,1040,"You were all so quick to believe Lydia's lies."],[1153,1236,"Spreading rumors,"],[1273,1466,"attacking someone without any evidence."],[1536,1726,"You never once stopped to question the truth!"],[1869,2100,"If any of you harass Jane ever again,"],[2169,2296,"I will file a police report"],[2296,2466,"and hold you accountable under the law."],[2536,2693,"It was all a misunderstanding!"],[2750,2830,"Yeah, let's go!"],[2926,2960,"Sorry."],[4873,4946,"Thank you!"],[5136,5250,"This wasn't your fault."],[5346,5453,"You deserve a new beginning."],[5846,5910,"Yeah, you're right."],[6089,6196,"Okay,"],[6216,6333,"someone needs to tell me."],[6356,6603,"When exactly did this start happening?"],[6693,6876,"It's a long story."],[7006,7206,"Actually, it's pretty simple."],[7383,7566,"I'm in love with Jane Lockhart!"]],"50":[[1000,1166,"Got any lunch plans, boyfriend?"],[1256,1403,"Where to, girlfriend?"],[1496,1633,"The restaurant on the corner in 30 minutes."],[1700,1800,"Don't be late."],[1800,1896,"No excuses!"],[2013,2073,"See you soon!"],[3720,3856,"Hey, come sit!"],[4120,4233,"Did you ask her to call me here?"],[4270,4439,"Well, hello to you too, son."],[4770,4889,"Henry, don't be so harsh!"],[4889,5018,"You know, me and Mr. Darcy"],[5018,5176,"have been having a really great conversation."],[5316,5353,"I'm leaving."],[5536,5593,"Henry!"],[5703,5789,"Please stay."],[6103,6170,"I'm sorry."],[6553,6636,"You're apologizing?"],[6666,6850,"Yes, Henry, I was wrong!"],[6933,7006,"Please, I'm..."],[7006,7196,"I'm not here to ask you to take over"],[7209,7409,"or push you into something you hate."],[7563,7646,"Just wanna talk."],[7993,8166,"Clara invited me to a movie,"],[8166,8320,"so please, you two talk."],[8593,8733,"You helped me heal my wounds."],[8833,8943,"Let me help you heal yours."],[9593,9640,"She's good!"],[9753,9856,"Yeah, too good!"],[9970,10066,"I'm glad you settled down."],[10223,10303,"Me too, Dad."]],"51":[[323,433,"Oh my gosh, I'm going to be late!"],[540,690,"Told you not to stay up so late,"],[696,813,"but, no..."],[813,986,"you wanted to try that thing and–"],[986,1119,"Okay, stop!"],[1136,1316,"I told you what happens in the bedroom"],[1316,1406,"stays in the bedroom!"],[1483,1503,"Okay."],[1573,1723,"Are you making pancakes?"],[1736,1866,"Yeah, almost done."],[1900,2019,"Why do I love you so much?"],[2050,2219,"I think you only love me for the pancakes."],[2373,2473,"Are you gonna come tonight?"],[2496,2656,"It's at six and I know I'm gonna nail it."],[2680,2726,"Of course."],[2796,2910,"You know I always have your back."],[3313,3496,"Dr. Darcy, why do you gotta be so kissable?"],[3546,3716,"That's actually not a kiss!"],[4006,4260,"I never believed in love at first sight."],[4336,4393,"Until her!"],[4689,4846,"Heartbeats really don't lie."],[8029,8126,"What do we got?"],[8146,8270,"The patient is a dance student"],[8270,8390,"and had a stage accident."],[8390,8509,"A light fell and hit her head."],[8509,8620,"She's unconscious."],[8659,8773,"Have we contacted the family?"],[8800,8963,"Any known allergies or medical history?"],[8996,9106,"No history of illness,"],[9106,9233,"and she's allergic to peaches."]],"52":[[156,333,"Okay, take her to the OR prep right away."],[333,413,"I'm gonna scrub in."],[1830,1883,"Incision."],[1933,2096,"Mr. Darcy, you can't go in there!"],[2096,2236,"Get my son out here!"],[2253,2373,"The mayor needs him!"],[2376,2503,"The mayor's not feeling well."],[2526,2739,"Get Dr. Darcy to come with us now!"],[2773,2926,"We need the mayor's endorsement"],[2950,3093,"to keep Polaris thriving."],[3143,3236,"Get him now!"],[3239,3396,"But the surgery's already started!"],[3396,3453,"We don't care."],[3466,3626,"The mayor needs to see him now!"],[3686,3846,"If he doesn't show up right now,"],[3893,3960,"your son"],[3960,4179,"can kiss his medical career goodbye!"],[4546,4766,"Dr. Darcy, I hear the mayor's asking for you."],[4803,4926,"I think you should go see the mayor."],[4956,5093,"Just focus on the surgery."],[5129,5383,"But he's gonna create big trouble for you."],[5406,5556,"Lives don't come with price tags."],[5556,5626,"Just keep going."],[7723,7833,"Jane, you're awake!"],[8100,8236,"No, did I miss rehearsals?"],[8383,8483,"Forget about that!"],[8500,8546,"Okay?"],[8626,8726,"You're still the best."],[8800,8976,"Lydia doesn't stand a chance against you!"],[9343,9453,"Did you get me flowers?"],[9596,9743,"No, wasn't me."],[9803,9963,"It was the doctor who treated you."],[10000,10090,"My doctor?"],[10103,10136,"Yeah!"],[10263,10393,"I tried finding him, but..."],[10463,10659,"the staff said he's already left the hospital."],[10763,10923,"Apparently, you were his last surgery here."],[11023,11123,"I wanted to thank him."],[11266,11386,"I guess I missed my chance."],[11526,11646,"You know what else I heard?"],[11716,11909,"Apparently, this doctor is a big deal."],[11933,12176,"The mayor's personal physician, no less!"],[12259,12290,"Wow!"],[12466,12586,"I guess I got lucky then."],[12626,12646,"Yeah!"],[12679,12883,"You'll be back in the stage in a week."],[12993,13173,"Nothing can stop you!"],[14093,14273,"I hope we'll meet again someday!"]]}