{"1":[[8,108,"This is it, folks,"],[108,291,"the moment we've all been waiting for."],[304,421,"After a week-long"],[421,671,"international culinary competition,"],[692,821,"three chefs remain,"],[863,1251,"representing France, Italy, and the USA."],[1455,1609,"The judges are about to decide"],[1609,1697,"who will be named"],[1697,1856,"the Culinary Grand Champion"],[1856,1976,"of the World."],[1976,2143,"The Queen of Cuisine always"],[2143,2306,"keeps the focus on her food."],[2323,2560,"Her cooking is as mysterious as she is."],[2644,3044,"Five, four, three, two..."],[4145,4425,"I give you my Sun-Kissed Iceberg."],[4462,4562,"One!"],[4808,5038,"The Queen of Cuisine won, she won!"],[5059,5543,"Queen Cuisine!"],[5601,5709,"This is my last time"],[5709,5839,"standing before the public"],[5839,5972,"as the Queen of Cuisine."],[6006,6197,"After this, I'm hiding my name"],[6197,6318,"for someone I love."],[6406,6539,"In a shocking development,"],[6556,6710,"the mysterious Queen of Cuisine,"],[6740,6915,"four-time Culinary Champion,"],[6936,7082,"has announced her retirement."],[7115,7282,"The reason for her decision"],[7282,7386,"remains unknown."],[7444,7515,"Tiffany."],[8141,8345,"Sorry, I've got flour all over me."],[8383,8491,"I can't believe I'm leaving you"],[8491,8604,"for three whole years."],[8633,8704,"I'm gonna miss you."],[8733,8800,"Don't worry."],[8804,8896,"You'll do great"],[8896,9038,"at Le Cordon Bleu, honey."],[9071,9217,"Your food is amazing."],[9280,9401,"And it was thanks to your cooking"],[9401,9501,"that I was able to recover"],[9501,9676,"from my eating disorder, after all."],[9755,9880,"I'll always support you."],[9918,10005,"Tiff, when I get back,"],[10005,10064,"I'm gonna make you"],[10064,10176,"the happiest woman alive."],[11311,11423,"Don't worry, Barry."],[11448,11549,"I'll take care of your mom."],[11619,11790,"Your dream is my dream as well."]],"2":[[12,95,"I want a divorce."],[141,279,"Barry, what the hell is this?"],[308,417,"I'm Sera Rose,"],[417,617,"Le Cordon Bleu's rising star,"],[650,863,"and Barry's future wife."],[1113,1201,"Future wife?"],[1255,1380,"She's not like you, Tiff."],[1426,1614,"She's the Queen of Cuisine's protégé,"],[1622,1730,"with full backing"],[1730,1885,"from DX Restaurant Group."],[1885,2072,"I never had a protégé."],[2072,2143,"Tiff, I'm moving on"],[2143,2231,"to bigger and better things,"],[2231,2344,"and that includes a better woman."],[2344,2460,"But three years ago,"],[2573,2665,"you said-"],[2665,2727,"Even the best food"],[2727,2844,"turns sour eventually, right?"],[2877,2940,"So does love."],[3069,3211,"After all the sacrifices"],[3211,3315,"I've made for you,"],[3361,3457,"that's all I get?"],[3528,3712,"Love turns sour?"],[3787,3912,"Sacrifices?"],[4037,4241,"What sacrifices could a housewife"],[4241,4371,"possibly make?"],[4838,4996,"Just sign the damn divorce papers, Tiff."],[5167,5259,"Let's see what your mother"],[5259,5376,"has to say about this."],[5417,5480,"Hmm?"],[5939,6126,"Elena, your son is back."],[6206,6343,"He wants to divorce me."],[6364,6435,"Finally."],[6473,6685,"It's about time my son divorces you."],[6731,6790,"What?"],[7132,7194,"Hi, Mom."],[7278,7374,"This is Sera."],[7461,7699,"So this is my new daughter-in-law."],[7699,7887,"So good to finally meet you, Elena."],[7916,8133,"Barry has told me so much about you."],[8508,8579,"Elena,"],[8654,8858,"you knew about Barry's affair"],[8858,8971,"this whole time?"],[8992,9084,"Affair?"],[9171,9288,"Don't be ridiculous."],[9321,9434,"I never thought of you"],[9434,9547,"as my daughter-in-law."],[9567,9718,"You're just a glorified maid."],[9747,9880,"What the hell can you do"],[9880,10010,"to help Barry's career?"],[10039,10176,"Sera here is going to bring him"],[10176,10343,"unprecedented success."],[10402,10648,"You cannot compare to that."],[10710,10865,"I'll take good care of you from now on,"],[10865,10960,"Mrs. Wallace."],[11161,11269,"Three years ago,"],[11290,11482,"I gave up everything to stay back"],[11482,11603,"and take care of your mother,"],[11690,11832,"so you could go to Cordon Bleu"],[11832,12032,"and pursue your culinary dreams."],[12066,12270,"I gave you peace of mind, Barry!"],[12270,12366,"I, I took"],[12366,12512,"care of your home! - Shut the fuck up!"]],"3":[[45,171,"Really, Tiffany?"],[221,404,"Making my mom eat this shit"],[404,629,"and calling it taking care of her?"],[629,838,"Elena has high blood sugar, okay?"],[838,1051,"She needs a healthy diet, in order-"],[1051,1197,"Excuses, excuses!"],[1217,1355,"You just can't cook."],[1384,1488,"You have done nothing"],[1488,1580,"but freeload"],[1580,1747,"for the last three years."],[1847,2031,"Barry, that's bullshit and you know it."],[2056,2177,"You're a parasite."],[2256,2452,"All you've ever done is wait for me"],[2452,2619,"to come home and provide."],[2656,2827,"A maid would be better than her."],[2886,3019,"Three years, Elena."],[3119,3411,"Three years of me cooking, cleaning,"],[3411,3624,"and making sure you never missed a meal."],[3716,3837,"How dare you?"],[3837,3995,"Son, do you see this?"],[4091,4320,"I've endured so much abuse"],[4320,4441,"while you've been gone."],[4567,4625,"How dare you"],[4625,4717,"speak to my mother like that,"],[4717,4850,"you ungrateful bitch."],[5009,5071,"Fine."],[5176,5309,"You want a divorce?"],[5989,6064,"Here."],[6410,6585,"Mark my words, Barry."],[6902,7048,"You will regret this."],[8875,8929,"Here."],[9017,9200,"It's your salary for being a housewife."],[9980,10080,"Consider us even."],[10214,10352,"Oh my gosh, babe."],[10352,10477,"Is she going to pick up that money"],[10477,10660,"like a wet dog?"],[10660,10777,"Keep your money, Barry."],[10802,10906,"One day you're going to need it"],[10906,10977,"more than me."],[11707,12012,"And Sera, you didn't steal my man."],[12062,12216,"You inherited my trash."],[12550,12771,"I can't wait for the day they find out"],[12771,12975,"that I'm the Queen of Cuisine."]],"4":[[2027,2093,"Hi."],[2156,2289,"Excuse me, can I come in?"],[2352,2477,"I just want to get out of the rain."],[2544,2660,"This is Maison Éclat."],[2660,2798,"We don't serve hobos."],[2819,2873,"Get out."],[2882,2982,"I'm not a hobo."],[3044,3194,"Look, I can buy a glass of wine"],[3194,3332,"while I wait and call my Uber."],[3332,3541,"You couldn't possibly afford our wine."],[3549,3661,"Now, get out of here!"],[5526,5634,"Are you okay, miss?"],[6093,6156,"Boss."],[6706,6873,"Is this how you treat our customers?"],[6944,7052,"Apologize now."],[7394,7465,"I'm sorry."],[7520,7590,"Go home."],[7611,7782,"And don't let me see this happen again."],[7832,7916,"Yes, boss."],[8721,8796,"Thank you."],[9042,9104,"Come on."],[9267,9325,"I'm not going to"],[9325,9488,"let one of my customers starve"],[9517,9609,"and leave cold."]],"5":[[400,642,"Welcome to Maison Éclat."],[1205,1363,"Yo, put this on."],[1584,1647,"It's okay."],[1956,2035,"Thanks."],[2156,2231,"Okay."],[2289,2414,"I'm gonna go make you a hot meal."],[2414,2577,"Oh, no, that's okay."],[2619,2748,"Your kitchen must be closed"],[2748,2831,"by now anyway."],[2840,2927,"I'm not hungry."],[2982,3136,"A glass of wine would be just fine."],[3395,3495,"This has got to be the most"],[3495,3770,"embarrassing day of my life."],[3820,3953,"Look, I don't let my customers"],[3953,4024,"go hungry."],[4104,4187,"And don't worry about it."],[4187,4275,"It's on the house."],[4295,4450,"It's the least I can do for my employee"],[4450,4562,"treating you so poorly."],[4662,4754,"Here, have a seat."],[5030,5167,"Here, I want you to try this."],[5276,5426,"This is my grandmother's"],[5426,5526,"risotto."],[7257,7353,"Is it that bad?"],[7399,7586,"No, no, not at all."],[7761,7920,"It's the best thing I've ever tasted."],[8871,8946,"Hey, hey, hey."],[8946,9113,"Whoa, whoa, slow down."],[9146,9250,"I didn't know my risotto"],[9250,9409,"could make a girl cry."],[9713,9822,"I'm Claude, by the way."],[9993,10093,"Thank you, Claude."],[10281,10356,"I'm Tiffany."],[11044,11131,"So, Claude,"],[11219,11282,"does your restaurant"],[11282,11419,"happen to be hiring right now?"],[11519,11624,"I know how to cook,"],[11661,11828,"and I can help you out in your kitchen."],[11866,11986,"Tiffany, are you a chef?"]],"6":[[83,200,"I'm actually..."],[221,300,"Look, to be honest,"],[300,392,"I'd love to hire you,"],[392,550,"but I can't right now."],[583,658,"My grandfather,"],[658,734,"he's forcing me"],[734,813,"to close this place soon."],[813,900,"What? Why?"],[1013,1163,"This place is so nice."],[1501,1605,"If you can hire me,"],[1622,1735,"I can turn things around."],[1822,2010,"I'm actually pretty good at-"],[2018,2131,"Marriage problems."],[2231,2360,"My grandfather expects me"],[2360,2494,"to be married by 30,"],[2531,2786,"and here I am, still single."],[3778,3853,"Allow me, sir."],[3874,3966,"The street is cleared."],[3966,4083,"No one will interfere."],[5080,5305,"Why does this man look so familiar?"],[5405,5605,"Where have I seen him before?"],[5672,5739,"Hey, Eric."],[5789,5910,"Good evening, Mr. Wyndham."],[5939,6001,"Wait."],[6056,6164,"Claude Wyndham?"],[6210,6322,"As in, heir"],[6322,6489,"to the biggest chip company"],[6489,6606,"in America?"],[6606,6681,"Hello, Grandpa."],[6719,6894,"I knew you were hiding here, Claude."],[6965,7094,"Now, your time is up."],[7119,7390,"Where is that bride that you promised?"],[7461,7586,"What is a trillion-dollar"],[7586,7678,"trust fund baby"],[7678,7874,"opening a restaurant in Culver City?"],[8083,8149,"Is this her?"],[8249,8404,"Grandpa, this restaurant"],[8437,8571,"is my passion project,"],[8608,8729,"and it was my mother's dream."],[8796,8896,"Besides, I already made"],[8896,8996,"the company's value"],[8996,9121,"increase by billions."],[9138,9242,"Does this marriage,"],[9246,9396,"does it really matter that much?"],[9446,9572,"Yes, it matters."],[9634,9768,"You're the Wyndham heir,"],[9809,9955,"and we had a deal."],[10005,10147,"Now, I let you"],[10147,10368,"open your passion project,"],[10381,10552,"and your part of the deal was"],[10552,10727,"you were going to get married."],[10756,10935,"Now, if there's some other deal,"],[10952,11036,"let me know."],[11323,11403,"Actually,"],[11524,11657,"Grandpa, you were totally right."],[11815,11882,"This is her."],[12028,12103,"My fiancée,"],[12233,12283,"Tiffany."]],"7":[[0,54,"Tiffany."],[221,266,"What?"],[404,554,"Play along and the job is yours."],[884,1038,"Yes, that's me."],[1071,1159,"Hi, Mr. Wyndham."],[1159,1297,"It's a pleasure to meet you."],[1313,1443,"I'm Tiffany Lockhart."],[1443,1564,"Miss Lockhart,"],[1668,1910,"are you engaged to my grandson?"],[2356,2460,"Of course!"],[2494,2619,"We're recently engaged"],[2619,2790,"and so, so in love."],[2873,2977,"Why else would I be here"],[2977,3069,"so late at night?"],[3078,3278,"So good, and I'm happy."],[3424,3732,"But that ring's rather small."],[3803,4054,"Thank God, I forgot to take off my ring."],[4054,4300,"When did you get so stingy, Claude?"],[4300,4437,"Wait, she's already married?"],[4475,4587,"Why does she have a ring on?"],[4658,4813,"But our deal was marriage,"],[4867,5055,"so don't try to throw me off"],[5055,5205,"with an engagement."],[5238,5313,"When are you two"],[5313,5459,"actually getting married?"],[5497,5588,"Grandpa, come on."],[5609,5730,"I just proposed."],[5730,5922,"Let us enjoy the engagement, please."],[6018,6210,"Well, but this restaurant"],[6210,6335,"closes tonight"],[6335,6552,"until you get married."],[6748,6806,"Tomorrow."],[7107,7173,"We're getting married"],[7173,7273,"tomorrow, Grandpa."]],"8":[[955,1038,"Surprise!"],[1605,1718,"Oh my gosh, babe."],[1743,1810,"I can't believe"],[1810,2022,"we finally got our marriage license."],[2043,2181,"Everything I ever did for you,"],[2206,2285,"every moment,"],[2310,2389,"was worth it."],[2389,2535,"Who knew it would be that easy"],[2535,2723,"to get her to sign the divorce papers?"],[3340,3532,"Oh my God, Tiffany."],[3582,3728,"Did you seriously follow us here"],[3728,3820,"to get me back?"],[3933,4016,"It's not gonna happen."],[4041,4162,"Or are you here"],[4162,4220,"for your little"],[4220,4421,"divorce settlement refund?"],[4517,4621,"Never in a million years"],[4621,4754,"would I take you back, Barry."],[4909,4967,"Okay."],[4992,5155,"If not for me, why would you be here?"],[5221,5342,"Well, she's here to marry me."],[6664,6752,"Sorry I'm late, honey."],[6810,6890,"These are for you."],[6981,7048,"Thank you."],[7102,7332,"Is everything okay?"],[7449,7515,"I'm fine."],[7515,7691,"Just ran into some flies."],[7874,7932,"Come on."],[7987,8083,"Let's go get married."],[8963,9038,"Excuse us."],[9768,9855,"There's no way"],[9855,10010,"she got married again this fast."],[10030,10135,"She's just doing this"],[10135,10247,"to make me jealous."],[10385,10464,"They were probably"],[10464,10639,"sneaking around way before."],[10727,10835,"No wonder she agreed"],[10835,11011,"to the divorce so easily."],[11123,11173,"No."],[11223,11286,"There's no way."],[11286,11419,"Tiffany's obsessed with me."],[11503,11653,"That guy's probably just a paid actor."],[11724,11828,"You're not still thinking about"],[11828,11928,"your ex, are you?"],[12312,12379,"Of course not."],[12583,12658,"Whatever."],[12804,12937,"Who the hell is that guy?"],[12983,13154,"Why do I feel like I've seen him before?"]],"9":[[396,550,"I can't believe I got divorced,"],[550,613,"remarried,"],[613,896,"and found a new job all within 24 hours."],[913,975,"Your ex-husband"],[975,1130,"sounds like a real piece of work."],[1305,1451,"Yeah, I can't believe"],[1451,1626,"I wasted three years on that man."],[1839,1985,"Tiffany, we all make mistakes."],[2002,2147,"Whether it's the people we trust,"],[2147,2389,"or making our enemies friends."],[2402,2494,"But at the end of it,"],[2560,2694,"if you stay true to your heart,"],[2731,2844,"nothing can break you."],[3165,3219,"Alright,"],[3219,3436,"so what can I help you with, boss?"],[3436,3532,"Well, I could use some help"],[3532,3674,"organizing these receipts."],[3724,3903,"Yeah, you betcha."],[3903,4037,"Oh, before I forget."],[4129,4170,"Here."],[4275,4375,"I'm gonna give this to you."],[4412,4587,"I put a million dollars on there."],[4708,4821,"Thank you for marrying me."],[4833,4992,"A million dollars?"],[5000,5142,"I can't take that."],[5217,5347,"You've already given me a job"],[5347,5480,"and a roof over my head."],[5497,5584,"That's enough."],[5584,5693,"Yeah, but this is-"],[5693,5772,"No buts."],[5801,6014,"I can't take a million dollars from you."],[6122,6381,"Now boss, I'm gonna get back to work."],[6610,6773,"Okay, well, you heard my grandpa."],[6881,6990,"He wants me to do better."],[7369,7465,"I hope you don't mind."],[7711,7757,"No."],[7786,7932,"I was gonna toss it anyway."],[8979,9059,"Oh, my God."],[9217,9330,"Claude, I can't."],[9505,9697,"If you're not going to take my money,"],[9726,9880,"at least accept this ring."],[10014,10139,"Just think of it as a prop."],[10639,10714,"Hope you like it."],[11498,11628,"Jesus, Joey!"],[11682,11795,"Don't you know how to knock?"],[11903,12032,"I, I did knock."],[12103,12174,"Sorry boss,"],[12174,12287,"but there's a customer here"],[12287,12404,"causing a huge scene"],[12404,12562,"and he's a food critic, too."],[12658,12754,"I'll handle it."]],"10":[[8,221,"This is awful."],[271,354,"I'm not paying for this-"],[354,513,"I deeply apologize for..."],[513,629,"Wait, I know this guy."],[629,759,"Andre Lorenzo."],[759,850,"He was the judge"],[850,1001,"for my last championship."],[1001,1092,"...right, this-"],[1092,1159,"Excuse me."],[1205,1288,"Sir, is there something wrong"],[1288,1359,"with your meal?"],[1534,1630,"Are you the manager?"],[1747,1856,"You call this"],[1856,1993,"pan-seared duck breast?"],[2160,2273,"Not even close."],[2302,2389,"You try it."],[2986,3136,"This does taste awful."],[3219,3286,"What happened"],[3286,3461,"to the Maison Éclat Chef?"],[3891,3983,"I'm sorry, sir."],[3987,4124,"We'll get you a new dish right away."],[5176,5334,"Boss, this isn't the first time"],[5334,5492,"that guy's come in and harassed us."],[5492,5538,"Okay?"],[5538,5655,"DX Group has to be"],[5655,5755,"paying him or something."],[5755,5839,"It's pretty bad."],[6172,6231,"I tried it."],[6310,6431,"DX Restaurant Group"],[6431,6581,"poached three of my chefs."],[6581,6790,"Alice is stepping in and helping out."],[6827,6911,"To be honest,"],[6927,6998,"I'm still searching"],[6998,7115,"for the Queen of Cuisine."],[7115,7294,"Claude's been looking for me?"],[7294,7411,"So far, no luck."],[7419,7632,"What does she even know about cooking,"],[7632,7691,"huh?"],[7716,7786,"Who do you think you are"],[7786,7941,"to judge our food, hmm?"],[7941,8091,"The sauce is completely wrong."],[8103,8204,"The cherry overwhelms"],[8204,8299,"the duck's flavor."],[8299,8462,"Alice has cooked in five-star hotels."],[8462,8558,"You're seriously gonna doubt her"],[8558,8758,"ability all because of one bite?"],[8858,8983,"The customer didn't like it either."],[9017,9067,"Fine!"],[9121,9234,"You think you can do better?"],[9234,9351,"Then make it yourself!"],[9563,9638,"What's wrong?"],[9709,9818,"Cat got your tongue?"],[9838,9934,"She's just a hostess."],[9934,9997,"What does she know?"],[9997,10051,"She's just here"],[10051,10164,"to smile and clean plates."],[10164,10210,"It's okay."],[10210,10260,"One day you can"],[10260,10335,"talk with the real chefs."],[10335,10472,"Okay, that's enough, you two."],[10472,10623,"Tiffany's just trying to help out."],[10643,10873,"Okay, I pay you two to cook, not Tiffany."],[10873,11019,"So, y'all fix this."],[11240,11332,"Actually,"],[11398,11482,"I'll make it."],[11686,11903,"One time and one time only,"],[11903,12020,"so watch closely."]],"11":[[112,187,"Chef's coat."],[2790,2873,"Oh, please."],[2890,3036,"All show, no skill."],[5755,5793,"I didn't know"],[5793,5922,"you could do something like that."],[5976,6076,"Oh, come on."],[6076,6277,"Plating isn't everything, okay?"],[6277,6381,"That customer is just"],[6381,6477,"trying to cause trouble."],[6477,6539,"Go ahead!"],[6539,6606,"Send it out!"],[6606,6723,"Watch it come right back in."],[6723,6781,"Exactly."],[6794,6952,"It's all about taste, okay?"],[6952,7048,"You're just a random lobby girl."],[7048,7136,"You can't put yourself"],[7136,7261,"on the menu with just that."],[7307,7444,"Let's find out, shall we?"],[7645,7753,"I gotta see this."],[8187,8308,"Oh, God."],[8400,8571,"Sir, we remade the dish for you."],[11582,11715,"You changed chefs?"],[12166,12328,"Please, give that a try."],[13058,13142,"Just wait."],[13192,13321,"He's gonna spit it out."]],"12":[[529,604,"Oh, my..."],[696,804,"This is delicious."],[842,1001,"Now that is a work of art."],[1063,1247,"Who are you?"],[1267,1334,"Enjoy."],[1931,2102,"Oh, my God."],[2189,2277,"Tiffany, you didn't tell me"],[2277,2344,"you can cook."],[2452,2556,"I'm actually..."],[2890,3069,"Knowing how to make one dish"],[3069,3194,"doesn't mean she can cook."],[3194,3311,"Yeah, pure luck."],[3332,3407,"There's no talent."],[3503,3636,"I'm gonna go get back to work."],[4112,4208,"You two need to watch it."],[4850,5025,"Tiffany, try this."],[5025,5117,"I'm okay, thank you."],[5117,5176,"I'm working."],[5184,5321,"Tiffany, please."],[5321,5434,"I just made this."],[5922,6026,"Alright, fine."],[6777,6898,"That taste."],[10472,10560,"That flavor."],[10618,10727,"I'd know it anywhere."],[10856,10906,"Well..."],[11077,11198,"Food expires,"],[11478,11611,"taste is forever."],[12091,12224,"Was that your custard"],[12224,12324,"I had back then?"],[12804,12879,"Boss!"],[13088,13158,"This again."],[13225,13334,"What do you want this time?"],[13425,13726,"Sorry, boss, but, um, we got company."],[13805,14014,"DX Restaurant Group is here."],[14055,14155,"What the hell are they doing here?"]],"13":[[250,304,"Boo!"],[496,588,"What do you want, Seth?"],[596,734,"Y'all are still operating?"],[746,800,"I was sure"],[800,950,"you'd be out of business by now."],[971,1055,"You really think"],[1055,1255,"some trust fund baby like you"],[1280,1551,"can compete in the Culinary World?"],[1601,1801,"I got a hard truth for you, son."],[1810,1989,"Money can't buy real talent."],[2002,2118,"I wouldn't put my passion"],[2118,2202,"into something"],[2202,2348,"if it wasn't going to be the best."],[2414,2640,"Oh, arrogant as ever."],[2711,3048,"Well, feast your eyes on today's gift."],[4229,4421,"Sell me this place while you still can."],[4450,4733,"Otherwise, I will open up shop"],[4767,4929,"right across the street."],[4929,5067,"Our new head chefs,"],[5080,5292,"Le Cordon Bleu prodigies."],[5292,5409,"And we will take"],[5409,5613,"every one of your customers"],[5651,5747,"and make you"],[5747,5980,"the laughingstock of this town."],[6569,6652,"Mr. Lorenzo."],[6806,6911,"Mr. Lorenzo."],[6969,7236,"What is someone of your status doing"],[7236,7382,"in this horrible restaurant?"],[7382,7469,"Sometimes you have to"],[7469,7632,"hide your true identity"],[7632,7928,"to experience the place's... quality."],[7949,8112,"Well, I'm so sorry"],[8112,8320,"that you're in a dump like this."],[8320,8466,"Come to one of my restaurants"],[8508,8629,"for the real thing."],[8666,8888,"Every dish is world-class."],[8888,9088,"Not like this garbage."],[9184,9376,"Actually, Mr. Lorenzo"],[9376,9576,"had pretty high praise on this dish."],[9738,9914,"Well, he hasn't tried mine yet."],[9968,10160,"Since Mr. Lorenzo is here,"],[10222,10402,"let's have a little contest."],[10681,10777,"You're afraid?"],[10935,11023,"That's right."],[11111,11273,"You don't have any chefs left."],[11294,11378,"You know why"],[11407,11574,"no good chefs want to work for you?"],[11590,11770,"Because you know nothing"],[11770,11878,"about cooking."],[11878,12091,"You're just some trust fund kid"],[12091,12233,"with his daddy's money"],[12233,12466,"and no real talent."],[12504,12662,"You are so pathetic."],[12942,13017,"I can't let them"],[13017,13163,"embarrass Claude like this."],[13350,13417,"Fine."],[13438,13567,"You want a competition?"],[13626,13717,"Let's do it."]],"14":[[158,462,"Obviously, you are some hostess."],[496,642,"Since when do you get a say?"],[734,821,"I'd say a hostess"],[821,946,"is appropriate competition"],[946,1071,"for your two chefs."],[1201,1247,"No."],[1355,1455,"Ignore her."],[1497,1701,"DX Group hires master chefs."],[1701,1793,"She'll get wrecked."],[1793,1993,"This is a real deal celebrity pair."],[2010,2093,"I think we're better off"],[2093,2248,"negotiating a partnership."],[2410,2485,"Wow."],[2527,2836,"Not all your staff are useless dimwits."],[2836,2948,"Surrender to me."],[3019,3240,"And maybe, maybe I might"],[3240,3578,"let your staff help out in our kitchen."],[4037,4229,"Claude, I promised you"],[4229,4362,"I'd pack this place out."],[4379,4475,"This is our shot."],[4846,5038,"Hey, shut it, rookie."],[5038,5171,"Go clean tables or something."],[5171,5305,"Don't do this, boss."],[5305,5472,"Seriously, if anybody should compete,"],[5472,5580,"it's me, okay?"],[5580,5722,"Not this front-of-house girl."],[6222,6297,"Tiffany."],[6906,6981,"Suit up."],[7749,7891,"Man, this is going to"],[7891,8049,"get ugly real fast."]],"15":[[1076,1167,"Oh, my God."],[1222,1422,"That's Barry Wallace,"],[1488,1685,"Le Cordon Bleu prodigy,"],[1743,2002,"the hottest star in cooking cuisine."],[2002,2152,"What are we even doing here?"],[2152,2419,"Behold, the golden boy,"],[2419,2711,"new celebrity chef, Barry Wallace."],[3144,3240,"You want his autograph"],[3240,3428,"for your sad promo wall?"],[3636,3737,"So that's him?"],[3828,3995,"Wait, that means the new guy"],[3995,4058,"Tiffany married"],[4058,4179,"is the Wyndham heir?"],[4225,4421,"A multi-billionaire?"],[4454,4592,"How does she even know him?"],[4629,4725,"My time is valuable."],[4779,4842,"Which of your chefs"],[4842,4946,"am I going up against?"],[5230,5442,"So what if he's a billionaire?"],[5484,5630,"Money can't buy skills."],[5684,5793,"I'll crush him."],[5793,6006,"Where'd that mouthy front desk-girl go?"],[6006,6093,"She probably bolted it"],[6093,6264,"to save herself the embarrassment."],[6264,6393,"Any of you got the balls to face me?"],[6656,6735,"I do."],[7152,7282,"I'll be your opponent."],[7382,7461,"Tiffany?"]],"16":[[145,208,"Tiffany?"],[287,450,"You're working here?"],[471,554,"That's right."],[579,696,"This is a joke, right?"],[742,884,"You're not actually pitting me"],[884,1030,"up against a housewife."],[1059,1146,"This is insulting."],[1155,1280,"You two know each other?"],[1322,1430,"Know each other?"],[1463,1589,"She's my ex-wife."],[1593,1664,"I tossed her out"],[1664,1776,"and now she's slumming it"],[1776,1922,"in this third-rate kitchen."],[1939,2052,"You're not gonna take it easy"],[2052,2202,"on your ex-wife, are you?"],[2252,2344,"Of course not."],[2423,2531,"But I will make sure"],[2531,2640,"she knows her new man"],[2640,2761,"as lesser than me."],[3115,3228,"Pity she isn't here."],[3249,3370,"Otherwise everyone would have to"],[3370,3549,"watch me beat you both at once."],[3549,3616,"It's big talk"],[3616,3699,"for someone who only knows"],[3699,3807,"how to make dry steaks"],[3807,3903,"and shitty salads."],[4108,4375,"Barry Wallace is a Le Cordon Bleu star."],[4375,4483,"Okay, we can't embarrass"],[4483,4558,"ourselves like this,"],[4558,4642,"Mr. Wyndham."],[4662,4859,"Yeah, let's just surrender."],[4859,4959,"Can it, you two."],[5213,5271,"Tiffany,"],[5538,5622,"I believe in you."],[6389,6443,"A good chef"],[6443,6610,"can make something out of nothing."],[6706,6852,"I challenge you today"],[6852,7036,"to use only what's in this room."],[7115,7323,"No kitchens, no burners,"],[7365,7636,"just knife skills and your ingenuity"],[7670,7945,"to create something delicious."],[8187,8299,"Choose your equipment."],[8541,8737,"First come, first served."],[8775,8900,"I guess we're going vegetarian."],[8958,9121,"Since all you ever did make was salad,"],[9121,9296,"I guess we're in your comfort zone."],[9351,9409,"Fine."],[9492,9801,"Three, two, one..."],[9884,9926,"Go!"]],"17":[[487,558,"That's for you."],[888,971,"How is she supposed"],[971,1076,"to win a knife contest"],[1076,1167,"with no knife?"],[1526,1576,"Is this"],[1576,1726,"what Le Cordon Bleu taught you?"],[1764,1918,"Using cheap tricks against women"],[1918,2022,"to get a head start?"],[2077,2273,"Yeah, what kind of man does that?"],[2298,2435,"The kind that wins."],[2523,2644,"You have 30 minutes."],[2698,2806,"Ready, chefs?"],[3240,3315,"Three,"],[3528,3582,"two,"],[3616,3691,"one..."],[3707,3762,"Go!"],[4295,4441,"A knife in each hand?"],[4504,4629,"And different cut styles?"],[4738,4963,"Meanwhile, our front-desk girl"],[4963,5109,"hasn't even gotten started."],[5171,5255,"She's never gonna measure up"],[5255,5338,"to a prodigy."],[5401,5551,"Yeah, and when she loses,"],[5551,5672,"then we all lose."],[5672,5885,"She's gonna ruin this entire restaurant."],[6060,6247,"Tiffany, the more I see it,"],[6247,6368,"the more curious I get."],[6439,6569,"Just how good are you?"],[6886,7015,"Pushing the carving further"],[7015,7165,"with specialized blades."],[7278,7361,"Impressive."],[7453,7620,"I can't wait to see the results."],[7640,7907,"Now that is a celebrity chef."],[7949,8099,"Cooking isn't just heat."],[8099,8174,"It's pressure."],[8174,8262,"It's chemistry."],[8262,8324,"It's knowing"],[8324,8537,"how matter changes under force."],[9718,9864,"Wait, is that a technique"],[9864,9989,"by the Queen of Cuisine?"]],"18":[[16,191,"What on earth is she doing?"],[358,563,"Drinking at a time like this?"],[563,759,"Has she lost her damn mind?"],[759,863,"What the hell?"],[1055,1163,"Already drinking away"],[1163,1259,"the pain of losing?"],[1743,1889,"What the hell is she planning?"],[2427,2510,"There's only 10 minutes left"],[2510,2590,"on the timer."],[2615,2677,"She hasn't even started"],[2677,2777,"working on the squash."],[2777,2923,"Yeah, because she doesn't know how."],[2927,3057,"She's a glorified server."],[3057,3186,"I mean, what did you expect?"],[3845,4054,"She's giving the squash a massage."],[4529,4662,"She didn't even grab a single knife."],[4662,4850,"Because she doesn't have a fucking clue"],[4850,4946,"what she's doing."],[4967,5130,"Mr. Lorenzo specifically said"],[5130,5271,"he wanted to see some knife work."],[5543,5747,"A housewife that doesn't even know"],[5747,5826,"how to cook."],[5897,6060,"Can you get more useless than that?"],[6318,6393,"She doesn't know"],[6393,6510,"what she's fucking doing."],[6510,6614,"She's an amateur."],[6614,6848,"Three, two, one..."],[6923,6994,"Chefs!"],[7082,7144,"Time's up."],[7182,7294,"Present your dishes."],[7611,7761,"Did she seriously"],[7761,8003,"just serve a plain squash?"],[8145,8283,"It's probably raw inside."],[8283,8345,"Yeah, William's gonna"],[8345,8450,"spit that right out."],[8612,8662,"Really?"],[8754,8858,"No knife work at all?"],[8917,8988,"My dish?"],[9134,9280,"Squash ice cream."],[9672,9851,"He carved an elaborate design."],[9951,10143,"Set the shape with liquid nitrogen."],[10293,10352,"Clever."],[10664,10865,"Tiffany, what's your big move?"]],"19":[[500,658,"Elaborately carved."],[675,817,"He set the final shape"],[817,938,"with liquid nitrogen."],[1013,1067,"Clever."],[1230,1413,"Is she seriously serving up"],[1413,1584,"a plain squash?"],[1618,1793,"It's probably still raw on the inside."],[1830,1964,"Le Cordon Bleu's prodigy"],[1964,2072,"on full display."],[2127,2273,"Unmatched knife work"],[2273,2477,"really puts a shame to that"],[2477,2752,"rather ordinary squash."],[2857,2982,"Restaurant on the line,"],[3003,3190,"and you cook up a steaming turd?"],[3190,3307,"It's pathetic."],[3307,3453,"Hey, if we lose, it's fine."],[3499,3586,"I'll take the blame."],[3674,3862,"Are you trying to humiliate us?"],[3866,4020,"There's no need to drag this out."],[4020,4104,"We're done here."],[4137,4220,"Hold it!"],[4450,4621,"You haven't even seen my carving yet."]],"20":[[2660,2877,"How... how is that possible?"],[3249,3332,"My dish,"],[3370,3516,"Soul of the Phoenix."],[3591,3674,"Did she,"],[3745,3908,"did she carve a phoenix into that?"],[3908,4083,"I, I didn't even see her use a knife."],[4133,4208,"She didn't."],[4212,4350,"Those marks are hammered in."],[4379,4542,"The vodka on the mallet"],[4542,4692,"left the indentations on the skin."],[4692,5050,"The final flame did the engraving."],[5251,5422,"This is God tier work."],[6164,6264,"It's the legendary"],[6264,6418,"Fire-Phoenix engraving."],[6477,6652,"I've only seen it once before."],[6790,7048,"The Queen of Cuisine."],[7399,7507,"So what, alright?"],[7507,7628,"We're supposed to be making food."],[7628,7745,"Can you even eat that?"],[7745,7803,"Yeah."],[7866,7970,"I bet it's raw."],[8016,8137,"Cool party trick."],[8208,8350,"You still lost."],[8537,8633,"Wait, there's a..."],[9217,9376,"Oh my, there's a fragrance."]],"21":[[70,196,"Squash soup."],[241,316,"That's right."],[396,500,"How basic."],[500,554,"Are you,"],[554,688,"are you actually proud of that?"],[1964,2085,"I can taste your passion"],[2085,2335,"and your love for your partner."],[4621,4708,"Unbelievable."],[5125,5426,"There are no words to describe"],[5505,5689,"how delicious this is."],[5964,6097,"The winner of this challenge..."],[6719,6777,"Tiffany."],[8379,8512,"What the fuck, Barry?"],[8529,8600,"I thought you said"],[8600,8737,"she was just a housewife."],[8800,8837,"There's gotta be"],[8837,8921,"some type of mistake."],[8921,9054,"It's squash soup!"],[9563,9659,"That flavor..."],[9780,9876,"it's perfect."],[9947,10051,"How is it possible?"],[10122,10235,"She's just a housewife,"],[10285,10443,"the parasite in my family."],[10890,10948,"No."],[11148,11207,"Thank you."],[11315,11365,"No!"],[11411,11473,"No, no, no, no."],[11503,11578,"She cheated."]],"22":[[8,87,"Really, Barry?"],[158,258,"That's your excuse?"],[300,408,"For a soup that rich,"],[408,483,"you'd have to let it simmer"],[483,579,"for at least an hour."],[579,709,"Anything under is impossible."],[746,788,"She must have"],[788,925,"used premade ingredients."],[955,1038,"Cutting corners"],[1038,1096,"when your restaurant's"],[1096,1180,"on the line."],[1242,1326,"It's pathetic."],[1388,1576,"You two really are clueless."],[1601,1697,"Jesus."],[1730,1851,"You just got caught cheating"],[1851,1914,"and you're still"],[1914,2043,"acting all high and mighty."],[2097,2206,"You know, you're a disgrace"],[2206,2335,"to chefs everywhere."],[2335,2464,"Alice, shut your mouth."],[2510,2690,"She didn't use premade anything."],[2690,2819,"She poured the vodka,"],[2819,2965,"into the squash,"],[2965,3123,"creating a chimney effect."],[3123,3253,"That accelerated the cook,"],[3253,3415,"pulled the flavor inward."],[3465,3657,"The flesh of the squash"],[3657,3816,"then melted into the soup,"],[3837,4012,"and the alcohol reduction"],[4012,4195,"that deepened the flavor."],[4250,4408,"Wait, so when she brought it out,"],[4508,4646,"the inside was still cooking?"],[4675,4779,"Exactly."],[4804,4954,"That's why the flames burst out"],[4954,5138,"when she opened the lid."],[5217,5355,"Only one person"],[5355,5538,"could execute something like that..."],[5926,6035,"the Queen of Cuisine."],[6239,6285,"What?"],[6327,6556,"Wait, she's the Queen of Cuisine?"],[6598,6652,"No."],[6690,6802,"No, if she was,"],[6852,6973,"why would she be here?"],[7148,7344,"Is Tiffany who I've been looking for?"],[7407,7474,"No, no, no."],[7474,7578,"She's my ex-wife."],[7590,7724,"She's the Queen of Nothing."],[7778,7912,"If she was the Queen of Cuisine,"],[7912,7999,"I would have known."],[7999,8299,"Oh Barry, you know nothing."],[8299,8454,"I stand by what I said."],[8558,8687,"Only one person"],[8717,8879,"could craft something like this,"],[8929,9046,"the Queen of Cuisine."]],"23":[[25,183,"It doesn't matter who I really am."],[258,437,"What matters is that I won."],[613,704,"I'm here live"],[704,921,"watching rising culinary star"],[921,1013,"Chef Barry"],[1013,1184,"get his ass handed to him!"],[2435,2485,"Alright."],[2531,2652,"You had this talent all along,"],[2652,2731,"why hide it from me?"],[4708,4833,"I dimmed my light"],[4833,4967,"so you could shine, Barry."],[5013,5188,"The biggest mistake of my life."],[5359,5488,"You never knew me at all."],[5668,5784,"Now get out."]],"24":[[58,229,"If I knew she was this good,"],[229,400,"I never would have let her go."],[475,646,"You lied to me for three years?"],[784,905,"You touch my wife"],[905,1021,"and you won't leave this restaurant"],[1021,1105,"in one piece."],[1305,1459,"I knew something was going on."],[1459,1643,"She's the boss's wife?"],[1714,1801,"The front-of-house girl?"],[1943,2077,"Okay, I see."],[2131,2260,"You actually married this guy."],[2339,2444,"So you think you're hot shit"],[2444,2502,"because you snagged"],[2502,2602,"some rich dude?"],[2652,2819,"You're the one who cheated, Barry."],[2873,2982,"And we're divorced."],[3003,3073,"Who I'm with now"],[3073,3194,"is none of your business."],[3219,3324,"A Wyndham heir"],[3324,3536,"scooping up my sloppy seconds."],[3557,3670,"Didn't see that one coming."],[4212,4346,"You insult my wife again,"],[4346,4441,"the force of the entire"],[4441,4529,"Wyndham empire"],[4529,4629,"will come down on you."],[4646,4738,"You'll be vanquished"],[4738,4867,"from this city for life."]],"25":[[16,108,"You think this is over?"],[158,312,"Next week, Sera and I"],[312,375,"will be selected"],[375,504,"as the official national"],[504,596,"banquet chefs."],[625,738,"Then, you'll see"],[738,896,"how the real Queen of Cuisine"],[896,1001,"really does it."],[1130,1313,"I'm still putting you out of business."],[1455,1580,"If only they knew"],[1630,1864,"that I'm the real Queen of Cuisine."],[2218,2323,"He didn't hurt you, did he?"],[2469,2681,"I'm fine, thanks to you."],[2927,3107,"Tiffany, we, we had no idea"],[3107,3224,"you were so talented."],[3249,3374,"Yeah, seriously."],[3465,3624,"Would you be willing to mentor us?"],[3624,3712,"Heck, I mean,"],[3749,3912,"I'd give you my head chef title"],[3912,4041,"for that soup recipe."],[4366,4475,"You weren't talking like that"],[4475,4550,"a minute ago."],[4583,4792,"We, uh, we didn't realize she..."],[4792,4954,"Apologize properly."],[4984,5100,"You can pack your things"],[5100,5180,"and hit the road."],[5647,5793,"I'm sorry, Mrs. Wyndham."],[5818,5922,"I was wrong about you."],[5968,6031,"I'm sorry."],[6143,6297,"Me too, Mrs. Wyndham."]],"26":[[629,679,"Mom."],[792,842,"Mom."],[1021,1151,"Mom, mom."],[1163,1222,"Are you okay?"],[2131,2223,"What did you eat today?"],[2260,2811,"Sera made me buttermilk soup."],[3386,3449,"Mom,"],[3449,3586,"you have diabetes."],[3586,3737,"Why would Sera feed you that?"],[3953,4087,"Did she at least give you your meds?"],[4112,4195,"I ran out."],[4195,4504,"Tiffany she usually gets them for me."],[4504,4558,"I..."],[4700,4967,"I don't know where she keeps the extras."],[6076,6172,"Chef Tiffany?"],[6481,6644,"A celebratory custard."]],"27":[[1146,1292,"Claude, by the way,"],[1292,1347,"where did you learn"],[1347,1459,"to make this custard?"],[1672,1876,"Well, this is one of the first recipes"],[1876,1968,"my mom taught me."],[2035,2097,"I used to make it"],[2097,2214,"all the time in high school."],[2306,2531,"I used to hand it out to the classmates."],[4567,4692,"Was this sticker yours?"],[4733,4850,"From Maple High School?"],[4917,5009,"Yeah, it was."],[5284,5434,"Wait, did we go to the same school?"],[5530,5701,"I looked really different back then"],[5722,5834,"with my eating disorder."],[5918,6047,"If it weren't for your custard,"],[6068,6118,"I don't think"],[6118,6239,"I ever would have recovered."],[6352,6544,"It actually made me like food again."],[6715,6781,"I can't believe"],[6781,6919,"we didn't know about this until now."],[7132,7240,"You were right."],[7323,7674,"Food expires, but taste doesn't."],[7753,7932,"It only deepens with time."],[7995,8141,"Your custard, it,"],[8279,8404,"it healed me."],[8554,8616,"It's funny,"],[8616,8787,"I used to think it was Barry's."],[8837,9038,"He had the same sticker on his desk."],[9146,9309,"I can't believe I thought it was him"],[9309,9392,"this whole time."],[9918,10051,"Well, now you know the truth."],[10147,10414,"It's better late than never, right?"]],"28":[[1814,1956,"Please leave your message."],[2969,3073,"What do you want, Barry?"],[3098,3190,"Lose my number."],[3249,3345,"Tiffany, what took you so long"],[3345,3411,"to answer?"],[4179,4262,"Are you with somebody"],[4262,4325,"right now?"],[4475,4567,"What are you doing?"],[4604,4717,"Just play along."],[5834,5951,"Tiffany, answer me."],[6981,7036,"Tiffany?"],[7887,7974,"Are you with a man?"]],"29":[[880,1009,"You taste so sweet."],[1705,1810,"Tiffany, I-"],[2198,2239,"I don't care"],[2239,2364,"what you're doing right now, okay?"],[2364,2456,"I just need to know"],[2456,2581,"where my mom's meds are."],[2681,2740,"She said that"],[2740,2827,"you used to get them for her."],[2827,2886,"She's..."],[3040,3144,"She's really sick, okay?"],[3144,3303,"Please, I just, I need your help."],[5130,5205,"She really..."],[5405,5492,"She doesn't give a shit"],[5492,5588,"about me anymore."],[6886,7023,"They're upstairs, they're upstairs"],[7023,7065,"just..."]],"30":[[166,304,"That was too funny."],[346,458,"Thank you for the fun idea"],[458,583,"to piss off my ex."],[750,846,"Well, maybe I didn't want to"],[846,959,"piss off your ex."],[1059,1247,"Maybe I simply enjoyed kissing you."],[2285,2381,"So where are we going?"],[2502,2644,"Why, do you have somewhere to be?"],[2681,2761,"No."],[2882,3207,"Okay, then I'm taking my wife home then."],[3315,3449,"Oh right."],[3486,3566,"But we still have to"],[3566,3741,"put up an act for his grandpa."],[3845,4070,"As in, the Wyndham family home."],[4220,4287,"Don't worry."],[4354,4496,"It's not this grand thing."]],"31":[[746,813,"Welcome."],[846,1067,"So this is the Wyndham Mansion..."],[1956,2118,"Well, well, well."],[2118,2323,"Tiffany, this is my cousin, Rob."],[2339,2439,"Cousin!"],[2510,2623,"Good to see you, man."],[2660,2731,"Grandpa told me"],[2731,2811,"you were getting married,"],[2811,2894,"but a..."],[3036,3219,"I had to see it with my own eyes"],[3219,3307,"to believe it."],[3474,3570,"Pleasure to meet you."],[3570,3661,"Nice to meet you."],[3770,3887,"You've been hiding her from me?"],[3899,3983,"Something like that."],[4079,4129,"Uhm..."],[4170,4337,"Anyway, I have some news."],[4408,4571,"The Culinary Institute"],[4571,4813,"has announced a qualifying camp."],[4838,5025,"Only the absolute best chefs"],[5025,5105,"are getting invited."],[5121,5347,"Your rival, the DX Group,"],[5367,5459,"they're already on that list."],[5551,5743,"The celebrity chefs, Barry and Sera,"],[5780,5860,"if they win,"],[5951,6081,"they will absolutely"],[6081,6151,"crush your restaurant"],[6151,6252,"into powdered sugar."],[6773,6861,"Why doesn't he enter"],[6861,6956,"under Maison Éclat?"],[7065,7186,"It's only restaurants accredited"],[7186,7357,"by the Institute that can enter."],[7482,7565,"Mine is not."],[7653,7770,"Yeah, sorry, cousin."],[7857,7937,"It's probably time"],[7937,8033,"to let that dream die."],[8137,8245,"Besides, the Wyndham name"],[8245,8537,"can't be attached to a failing business."]],"32":[[62,271,"DX only competes if they qualify, right?"],[316,367,"But what if"],[367,538,"they don't win the qualifying stage?"],[608,713,"No, that's impossible."],[713,892,"The president of the institution,"],[921,1084,"Liam Dunlap, he signs off"],[1084,1192,"on every accreditation."],[1343,1422,"Dunlap?"],[1605,1772,"Consider it taken care of."],[1839,1918,"And perhaps"],[1918,2064,"there's going to be another person"],[2064,2223,"at the competition who is better."],[2273,2339,"You never know."],[2698,2786,"You're talking about"],[2786,2977,"going against the Culinary God."],[3011,3203,"Trust me, it won't be a problem."],[3232,3332,"I'll get Maison Éclat,"],[3332,3424,"the accreditation."],[3891,4091,"Okay, well,"],[4154,4362,"I will leave you two lovebirds to it."],[4383,4479,"Great to meet you."],[4637,4859,"Claude, congrats, brother."],[4967,5050,"Good night, Rob."],[5388,5526,"The maids have made your bed."],[5526,5622,"I'll be in my quarters"],[5622,5743,"if you need anything else."],[5801,5876,"Thank you, Alfred."],[5905,5989,"Good night, sir."],[6022,6076,"Good night."],[6143,6218,"Mrs. Wyndham."],[6243,6352,"Good night, Alfred."],[6414,6502,"And nice to meet you."]],"33":[[1764,1847,"You can have the bed."],[1939,2068,"I'll sleep on the sofa. - Oh."],[2093,2164,"No need."],[2198,2264,"I can..."],[2323,2398,"Can... - Sleep in the bed"],[2398,2439,"with me?"],[2502,2560,"No."],[2606,2752,"I was gonna say,"],[2752,2865,"I can take the couch"],[2865,3040,"and you can sleep on the bed."],[3040,3090,"Oh."],[3240,3336,"I was just kidding."],[3403,3474,"And no way."],[3490,3591,"You take the bed."],[3632,3737,"I'll take the sofa."],[3874,3983,"I'm gonna go take a shower."]],"34":[[187,296,"Hey, Tiffany?"],[367,454,"Can you bring me a towel?"],[454,567,"I forgot to bring one in."],[842,967,"Yeah, sure."],[1726,1793,"There you go."],[1793,2081,"Thanks!"],[3432,3541,"I'm sorry."],[3661,3707,"I'm sorry."],[3707,3791,"I didn't mean to."],[4091,4212,"Tiffany."],[4854,4959,"Are you nervous?"]],"35":[[6452,6527,"I'm sorry."]],"36":[[0,133,"I haven't done this in a long time."],[934,1005,"It's okay."],[1163,1234,"I can wait."],[2498,2615,"I'll give you some privacy."],[2706,2798,"I'll be downstairs."]],"37":[[4975,5075,"Claude..."]],"38":[[867,1021,"I'm making something special."],[1042,1167,"Chef's creation."],[1280,1372,"Lucky me."],[1480,1559,"What is it? - M-mm!"],[1559,1622,"No, no, no. - What is it?"],[1622,1776,"There's no peeking, there's no peeking."],[2577,2640,"Ah."],[3040,3107,"Let's play a game."],[3336,3411,"What game?"],[3853,4141,"I want you to guess all the ingredients."],[4633,4688,"Did you know that"],[4688,4821,"when you lose your sight,"],[4867,5075,"your body's senses sharpen?"],[7223,7265,"Let's see"],[7265,7440,"if you can tell me all the flavors,"],[7565,7657,"Chef Tiffany."],[7836,8020,"You really think you can stump me,"],[8037,8145,"Chef Claude?"]],"39":[[0,179,"You really think you can stump me,"],[179,271,"Chef Claude?"],[1242,1401,"It's a hearty borscht."],[1651,1793,"Many different ingredients."],[1951,2135,"So many different flavors."],[2289,2414,"Tons of layers."],[2460,2736,"Just like you, Chef."],[2936,2982,"Hmm."],[3232,3365,"Tell me what you taste."],[3490,3828,"Beef, potatoes, parsley."],[4667,4725,"You."],[5897,6043,"So who wins the challenge?"],[6322,6523,"I never lose, Chef."]],"40":[[3874,4091,"It's only fair if you get a chance, too."]],"41":[[346,454,"Now it's your turn."],[638,792,"Tell me what I taste like."],[1284,1405,"Close your eyes."],[3474,3611,"Tell me what I taste like."],[7682,7878,"You're making me hungry for more."],[8174,8291,"I want you, Claude."]],"42":[[563,896,"Barry, I've warned you again and again."],[950,1030,"Your mother's diet"],[1030,1238,"has to be strictly controlled."],[1263,1376,"Have you even listened?"],[1522,1601,"How is she?"],[1634,1743,"Her blood glucose spiked"],[1743,1835,"to a dangerous level."],[1835,1918,"This isn't just about"],[1918,2031,"her wheelchair anymore."],[2064,2364,"She's one step away from losing a limb."],[2402,2656,"She's been fine for three years."],[2656,2769,"How is that possible?"],[2802,2902,"She was fine"],[2902,3048,"because Tiffany was here."],[3161,3274,"Tiffany's cooking?"],[3453,3528,"She was controlling"],[3528,3716,"my mom's glucose levels that precisely?"],[3732,3841,"Of course she was."],[3908,4033,"Barry, do you have any idea"],[4033,4116,"how much effort she put"],[4116,4254,"into taking care of your mother?"],[4571,4700,"I'll take great care of your mom"],[4700,4767,"while you're away."],[4821,4913,"We'll be right here at home"],[4913,5030,"waiting for you when you get back."],[5834,5951,"So the whole time I was away,"],[5951,6131,"she was carrying all that on her own?"],[6243,6460,"Well, let's hope your new wife"],[6460,6548,"can handle it now."],[6569,6752,"If she manages half of what Tiffany did,"],[6831,6952,"we can all be so lucky."],[7507,7661,"If Tiffany was here,"],[7686,7870,"I wouldn't be like this."],[8024,8262,"Sera keeps feeding me junk."]],"43":[[558,688,"You're a parasite."],[846,971,"You ungrateful bitch."],[1021,1142,"You want a divorce?"],[1242,1305,"Here."],[1347,1488,"You will regret this."],[2802,3082,"These are top-tier blades."],[3086,3215,"This is a Damascus blade"],[3215,3353,"by Leon Kennedy,"],[3440,3557,"the King of Cooking."],[3578,3632,"What?"],[3762,3866,"Why are these here?"],[4195,4329,"Do these belong to Tiffany?"]],"44":[[116,196,"My dish."],[221,371,"Soul of the Phoenix."],[412,533,"Only one person"],[533,675,"could craft something like this,"],[700,800,"the Queen of Cuisine."],[821,946,"She's the queen of nothing."],[1009,1130,"If she was the Queen of Cuisine,"],[1130,1217,"I would have known."],[1931,2118,"I heard that Seth took you"],[2118,2227,"to a contest yesterday."],[2293,2460,"Are these your trophies?"],[2531,2585,"No."],[2731,2802,"I lost."],[2819,2882,"What?"],[2940,3065,"Who was your opponent?"],[3336,3420,"It was Tiffany."],[3532,3616,"Tiffany?"],[3691,3837,"The salad-making housewife?"],[3920,4033,"You lost to her?"],[4062,4170,"These knives, they're..."],[4383,4454,"They're hers."],[4771,4892,"Clearly they're fake, okay?"],[4892,5013,"She just lined them up"],[5059,5125,"to make you feel bad"],[5125,5255,"about losing to her."],[5338,5622,"God, what a bunch of soap opera garbage."],[5693,5814,"Typical housewife bullshit."],[6489,6548,"No."],[6823,6919,"She lied to me."],[6956,7102,"Her cooking skills, they're,"],[7186,7240,"they're greater"],[7240,7378,"than we could have ever imagined."]],"45":[[116,283,"Babe, you're too soft on her, okay?"],[283,404,"Just because she's your ex"],[404,458,"doesn't mean"],[458,579,"you have to go easy on her."],[592,825,"You are DX's star chef, okay?"],[880,1063,"You can't have her get the last laugh."],[1551,1634,"Don't worry."],[1768,1889,"I'll get revenge for you."],[2181,2264,"And one more thing,"],[2344,2439,"I'm thinking of putting your mom"],[2439,2519,"in a nursing home."],[2535,2619,"It's more appropriate"],[2619,2727,"for someone her age"],[2727,2898,"and with her illness."],[2932,3019,"Saves me the trouble"],[3019,3115,"of taking care of her."],[3194,3315,"A nursing home?"],[3332,3490,"You promised you'd take care of her."],[3524,3670,"She's sick because you fed her"],[3670,3828,"a diet of high sugars"],[3828,3978,"and now you want her sent off?"],[3999,4108,"If you wanted a housewife,"],[4108,4179,"you should have stayed"],[4179,4358,"with that loser ex of yours."],[4416,4683,"I went to Cordon Bleu just like you."],[4700,4879,"I am not gonna waste my education."],[4959,5025,"If you think that,"],[5025,5159,"we can just get a divorce."],[5217,5317,"No, no, no."],[5588,5689,"I'm sorry, okay."],[5689,5893,"I, I won't bring it up again."],[6256,6610,"Tiffany, I will get my revenge."]],"46":[[37,116,"Mr. Dunlap,"],[187,312,"we finished compiling the list"],[312,425,"for the training competition."],[425,554,"Top restaurants nationwide"],[554,650,"are gonna vie"],[650,859,"for the top national banquet slots."],[871,980,"Just as they should be."],[1001,1096,"The national banquet"],[1096,1276,"is the signature event"],[1276,1434,"of the Culinary World."],[1972,2097,"If the Queen of Cuisine"],[2097,2206,"were still around,"],[2235,2364,"everyone else would just be"],[2364,2469,"window dressing."],[2569,2694,"Is she really that good?"],[2761,2869,"You better believe it."],[2869,3048,"Always kept a low profile,"],[3061,3224,"but she was the best of the best."],[3236,3386,"I still can't get over the fact"],[3386,3545,"that she gave it all up"],[3545,3636,"just to get married"],[3636,3774,"and be a stay-at-home wife."],[4283,4466,"Would you grab me more