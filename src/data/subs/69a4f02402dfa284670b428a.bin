litary assignment."],[5438,5526,"If you can't hack it,"],[5576,5622,"you're out."],[5789,5864,"Jesus Christ,"],[5864,5955,"you guys look like you're about"],[5955,6060,"to piss your pants."],[6135,6214,"Relax."],[6252,6381,"We'll do some team bonding today."],[6456,6523,"Lunch is on me."],[6777,6823,"Sweet."],[6861,6919,"Hell yeah."],[7695,7862,"Hi, what can I do for you today, sir?"],[7912,8016,"I'm with the FDA."],[8016,8166,"I have a meeting with Ms. Brooks."],[8174,8220,"Okay."],[8362,8450,"You're going to be taking"],[8450,8608,"the elevator to the third floor."]],"20":[[483,575,"Something just came up."],[658,717,"Grab lunch."],[1026,1105,"I really hope"],[1105,1259,"that's not who I think it is."],[4195,4300,"Josh Winslow,"],[4387,4496,"from the FDA."],[4617,4750,"Mr. Winslow."],[4788,4896,"What can I do for you?"],[4934,5121,"Well, for starters,"],[5134,5330,"you can tell me and the FDA"],[5330,5476,"exactly how Divina works."],[5543,5701,"Showing up without notice,"],[5701,5818,"a demanding attitude,"],[5818,5951,"and those scars?"],[5985,6089,"There's no way"],[6089,6264,"he's actually from the FDA."],[6335,6393,"Of course."],[6431,6535,"Let me just get you a coffee"],[6535,6656,"and we can talk it over."],[7987,8112,"Well, well."],[8199,8379,"Looks like you've figured me out."]],"21":[[817,1026,"Ah, ah!"],[1359,1547,"I can smell your fear."],[1618,1818,"I find it to be an aphrodisiac."],[1881,2052,"It gets me hard."],[2081,2168,"Let go!"],[2173,2256,"Let you go?"],[3190,3319,"About to get your ass kicked?"],[3340,3436,"You!"],[5251,5459,"Walk away, or die."],[5563,5809,"Big words from a lapdog bodyguard."],[5855,5930,"Do you have any idea"],[5930,6035,"who you're fucking with?"],[6060,6139,"I don't care."],[6172,6243,"You should."],[6243,6339,"I'm Daniel"],[6339,6481,"motherfucking Wilson."],[6493,6614,"I kill fleshbags like you"],[6614,6740,"and eat them for breakfast."],[6765,6865,"The serial killer?"],[6886,6965,"Number one"],[6965,7161,"on the FBI's most wanted list."],[7290,7490,"You should consider dying."],[7553,7724,"My hand and honor!"],[7724,7807,"Watch out!"]],"22":[[938,1017,"Who sent you?"],[1121,1251,"When Damian couldn't do it,"],[1301,1438,"I was sent in."],[1514,1614,"I might have failed,"],[1643,1835,"but they will send more."],[1985,2081,"And more."],[2127,2202,"Do you really think"],[2202,2410,"you can protect Chloe all by yourself?"],[2544,2635,"Turn away."],[4558,4621,"It's okay."],[4646,4713,"It's okay."],[4721,4808,"It's over."],[4875,5046,"It's over, it's over, it's over."],[5301,5372,"It's okay."],[5492,5555,"You're safe."],[5947,5997,"Listen."],[6110,6206,"I have to go pay this"],[6206,6331,"Damian guy a visit."],[6973,7048,"You'll be okay."]],"23":[[271,379,"Daniel has probably already"],[379,508,"wiped Caspian out."],[571,658,"Now it's time to"],[658,813,"bend that bitch Chloe over"],[813,971,"and make her beg me for mercy."],[1092,1138,"Sounds like"],[1138,1238,"someone's in a good mood."],[1267,1326,"What?"],[1405,1463,"No."],[1572,1630,"Caspian, I-"],[1659,1814,"How the fuck are you still alive?"],[2031,2077,"Wait."],[2135,2198,"I-"],[2256,2452,"I have a hundred guards out there"],[2452,2594,"and a state of the art security system."],[2602,2756,"How are you in here right now?"],[2802,2957,"That's what you're worried about?"],[2969,3028,"Listen."],[3190,3278,"There's something I think"],[3278,3357,"you should see."],[3782,4033,"Killing the FBI's most wanted assassin,"],[4058,4266,"murdering you on your own estate"],[4270,4400,"is the type of shit I do"],[4400,4529,"without breaking a sweat."],[4817,5055,"You think I'm scared of you?"],[5221,5467,"Know your place, you filthy peasant."],[5467,5580,"You are a bodyguard"],[5580,5718,"with some cheap tricks."],[5734,5784,"That is it."],[5822,5951,"Nobody can stop me."],[6001,6097,"And I'm going to make"],[6097,6206,"the Brooks sisters"],[6210,6389,"my own personal sex slaves."],[6389,6443,"Mmhmm?"],[7140,7278,"You fucking hit me!"],[7311,7469,"I am Damian Jones family heir."],[7469,7520,"Wait!"]],"24":[[0,79,"Ow, ow, ow, ow."],[83,312,"Sh, sh, sh, sh, shh."],[408,467,"Shut up."],[517,704,"A top-tier hitman like Daniel Wilson"],[704,771,"wouldn't take a job"],[771,909,"from nobodies like the Jones family."],[909,996,"So tell me,"],[1034,1222,"who are you working for?"],[1238,1376,"I can't, I can't."],[1388,1438,"I-"],[1480,1576,"They'll kill me."],[1589,1651,"They'll kill me."],[1718,1764,"No."],[1764,1839,"They won't."],[2018,2081,"But I will."],[2106,2223,"Oh, okay, okay, okay!"],[2223,2339,"It's the Carter."],[2369,2498,"The Carter family."],[2540,2681,"They are the most powerful family"],[2690,2752,"in America."],[2752,2857,"They run, they run"],[2857,2940,"the entire East Coast!"],[2969,3098,"They are the ones who want Divina."],[3098,3169,"I'm just, I'm just"],[3169,3265,"following their orders."],[3916,4020,"The Carters, huh?"],[4020,4066,"Yes."],[4108,4145,"Yes."],[4154,4404,"They try to appear legit,"],[4504,4708,"but they are controlling Cerberus."],[4792,4959,"The largest crime syndicate"],[4959,5038,"in the country."],[5159,5209,"Look."],[5251,5401,"Whatever Jack Carter wants,"],[5401,5497,"Jack Carter gets."],[5497,5647,"Nobody goes up against him"],[5647,5714,"and lives."],[5851,5930,"So things are finally"],[5930,6010,"getting interesting."],[6139,6264,"Oh, okay."],[6293,6322,"Just,"],[6339,6468,"you know, just, let me go."],[6477,6648,"and I, I will not bother"],[6690,6819,"Chloe ever again."],[6819,6890,"Chloe who?"],[6911,6956,"Right."],[6956,6994,"You won't."],[7319,7365,"No."],[7378,7490,"No, no, no, no, no, no!"],[7490,7528,"Look."],[7536,7636,"You will, you will ruin me!"],[7636,7761,"You will destroy my family!"]],"25":[[0,104,"You will destroy my family!"],[104,204,"Not necessarily."],[204,279,"Do as I say,"],[279,379,"and that recording stays"],[379,496,"between the two of us."],[525,571,"Okay."],[759,834,"What do you want?"],[834,963,"Get me a meeting with Jack Carter."],[992,1071,"Him and I need to talk."],[1071,1151,"You have 3 days."],[1151,1213,"3 days-"],[1976,2039,"Mr. Carter."],[2106,2214,"I, I need to see you."],[2936,2998,"Mr. Carter!"],[2998,3078,"Oh, shit!"],[3153,3282,"This better be important."],[3749,3849,"You're a dick."],[4562,4612,"So?"],[4654,4813,"Daniel is dead."],[4813,5009,"Okay, this nobody bodyguard Caspian,"],[5013,5084,"he killed him."],[5096,5226,"And then he broke into my mansion,"],[5226,5367,"got past my security guards"],[5376,5480,"and he almost killed me too."],[5480,5626,"Alright, the man is a monster,"],[5626,5705,"I'm telling you!"],[6694,6731,"Mr. Carter?"],[6848,7086,"You worthless weakling scum!"],[7115,7265,"Divina will be mine"],[7265,7403,"and I will crush anyone"],[7403,7520,"that gets in my way."]],"26":[[4,145,"Caspian, you said?"],[221,329,"Well, it's been a while"],[329,442,"since anyone's been crazy enough"],[442,521,"to challenge me."],[638,788,"I look forward to watching him fail,"],[788,909,"just like all the others did."],[1117,1288,"Send an invite to Chloe Brooks."],[1372,1451,"Maple House."],[1476,1551,"Tomorrow noon."],[2469,2610,"I can't believe the Carters"],[2610,2761,"were backing Damian all along."],[2794,2890,"I'm not one to back down"],[2890,2990,"from a fight, but"],[3007,3115,"the Carters are against us."],[3115,3244,"We don't stand much of a chance."],[3244,3465,"Hey, Divina is yours."],[3507,3695,"You poured your heart and soul into it."],[3712,3870,"No one's taking that away from you."],[3878,3999,"Not while I'm alive."],[4108,4241,"Divina is my life's work."],[4291,4454,"But I can't keep putting you"],[4454,4587,"and Iris in danger"],[4587,4675,"in order to protect it."],[4675,4742,"Stop."],[4859,4967,"I'm not going anywhere."],[5217,5251,"Okay?"],[6035,6093,"No."],[6210,6318,"You stay outside."]],"27":[[4,145,"Mr. Carter, please,"],[145,271,"do not underestimate"],[271,350,"Caspian, alright?"],[371,467,"He took out my men"],[467,608,"like they were goddamn children!"],[621,709,"Relax."],[750,950,"My men aren't schmucks like yours."],[975,1071,"You stay outside."],[1797,1910,"Oh my God."],[3136,3228,"You know, Mr. Carter,"],[3228,3349,"I'm not sure who raised you"],[3349,3495,"but sending us an invite"],[3495,3603,"and not letting us in"],[3603,3691,"isn't proper etiquette."],[3716,3845,"Just a little test to make sure"],[3845,3987,"you're worthy of meeting with me."],[4074,4149,"Ms. Brooks,"],[4216,4275,"welcome."],[4333,4537,"I asked you here to discuss"],[4537,4729,"working together on Divina."],[4788,4913,"What are you proposing,"],[4913,5030,"Mr. Carter?"],[5075,5242,"Chloe, I'm sure it's no secret"],[5242,5397,"that Divina is highly coveted"],[5397,5505,"by the Carter family."],[5597,5872,"In our hands, and only our hands,"],[5922,6068,"will it reach its true potential."],[6143,6297,"Well, as the one who actually"],[6297,6439,"developed the product,"],[6502,6606,"I have to disagree."],[6639,6831,"You're a respectable scientist, Chloe."],[6902,7065,"But Storm Pharmaceuticals"],[7065,7194,"isn't fit to handle"],[7194,7365,"a breakthrough drug like Divina."],[7394,7536,"I believe in my company."],[7628,7753,"And I believe in myself."],[8283,8562,"If you work with us, I guarantee you"],[8562,8712,"that Storm Pharmaceuticals"],[8712,8829,"will be valued at over"],[8829,9250,"10 billion dollars within 3 years."],[9275,9405,"You'll be one of the richest women"],[9405,9513,"in the country, Chloe."]],"28":[[454,633,"What's your plan for Divina, Mr. Carter?"],[725,809,"It's simple."],[921,1055,"We sell it to the rich"],[1055,1230,"at a million bucks a pop."],[1272,1455,"The poor can get a weaker version."],[1480,1701,"One that doesn't cure them,"],[1701,1864,"but still keeps them alive."],[1947,2068,"No one's gonna buy it"],[2068,2243,"if people are dropping dead, right?"],[2489,2686,"It's a win-win for both of us, Chloe."],[2711,2907,"I'll control the whole market,"],[2907,3003,"and your net worth"],[3003,3182,"is going to increase tenfold."],[3420,3674,"I made Divina to cure cancer."],[3682,3887,"To save lives, not to make a profit."],[3933,4179,"Everyone deserves the right to live."],[4241,4379,"The rich and the poor."],[4429,4587,"That's one of the most naive things"],[4587,4704,"I've heard in a while."],[4804,4900,"Only the rich"],[4925,5184,"deserve to live, Chloe."],[5201,5405,"If broke peasants wanted to,"],[5497,5680,"well, then they'd work harder."],[5793,6076,"You are an evil man, Jack Carter."]],"29":[[45,296,"You are an evil man, Jack Carter."],[446,492,"Good, evil,"],[492,554,"I mean, what's,"],[604,675,"what's the difference?"],[721,754,"Here."],[896,1026,"Join me in a drink,"],[1126,1309,"and you'll become one of the"],[1309,1584,"newest friends of the Carter family."],[1897,2248,"Let me say this as clearly as possible."],[2510,2556,"No."],[3128,3282,"I don't think you understand, Chloe."],[3407,3536,"I'm not just asking you."],[4496,4579,"She said no."],[4775,4842,"Kill them."]],"30":[[0,83,"Kill them."],[1647,1730,"Quite a step up"],[1730,1931,"from a serial killer like Daniel, huh?"],[4329,4391,"Enough!"],[5084,5313,"One more time, Chloe."],[5463,5793,"Are you going to work with us?"],[5809,5885,"Never."],[5930,6126,"I would rather die than work with you."],[7273,7344,"Let them go."],[7982,8049,"Go."]],"31":[[279,412,"The Carters were just testing"],[412,504,"the waters today."],[533,704,"They won't go down without a fight."],[704,863,"What if they come after you next?"],[875,938,"Let them."],[1034,1159,"You'll be safer that way."],[1430,1634,"I can't let you risk your life for me."],[1705,1822,"If it comes down to it,"],[1839,1993,"if the Carters don't back down,"],[2031,2198,"I'll give up Divina to save you."],[2314,2427,"Mr. Carter, you are"],[2427,2610,"really just going to let them go?"],[2610,2719,"What's the rush?"],[2777,2977,"With arrogant pricks like Caspian,"],[3090,3228,"there's nothing better than"],[3228,3345,"watching the hope drain"],[3345,3503,"from their eyes bit by bit."],[3566,3707,"But, but they were right here-"],[3778,3866,"You know, Damian,"],[3987,4175,"the Carter family really trusted you"],[4175,4312,"to take care of Chloe."],[4379,4433,"I mean,"],[4491,4617,"you really hyped yourself up."],[4942,5013,"I won't be needing"],[5013,5138,"your services anymore."],[5618,5701,"Spread the word."],[5751,5926,"Any suppliers that work with Chloe"],[5926,6056,"will be considered enemies"],[6056,6189,"of the Carter family."],[6189,6239,"Oh,"],[6314,6514,"and let Paul know it's time to act."]],"32":[[938,996,"You okay?"],[1071,1255,"Divina is going into production soon."],[1263,1388,"I can't let anything go wrong."],[1409,1559,"Keep doing what you're doing, Chloe."],[1593,1685,"I've got your back."],[1810,1885,"I don't get it."],[2022,2072,"Why?"],[2072,2273,"Why are you willing to put your life"],[2273,2398,"on the line to protect me?"],[2873,3032,"Look, I may not be a medical genius"],[3032,3219,"like you, but I know how to fight."],[3249,3386,"So if anyone's going to try to hurt you,"],[3386,3440,"they're gonna have to"],[3440,3532,"get through me first."],[5150,5217,"What was that?"],[5401,5484,"A gift."],[5663,5793,"For protecting me yesterday."],[5922,6047,"That's not nearly enough."]],"33":[[3098,3144,"Hello?"],[3144,3174,"Chloe,"],[3194,3274,"something happened."],[3294,3353,"It's bad."],[3378,3507,"You have to come to the office."],[3541,3607,"Now!"]],"34":[[525,629,"What's going on, Iris?"],[629,734,"Someone raided our labs"],[734,909,"and stole all of our raw materials."],[909,1009,"All the raw materials"],[1009,1142,"for Divina are missing."],[1159,1226,"That's at least"],[1226,1380,"2 billion dollars in losses."],[1401,1501,"Well, have we found out who did this?"],[1501,1543,"No."],[1576,1718,"We don't have a single lead."],[1718,1801,"Okay, um,"],[1939,2027,"contact our suppliers."],[2027,2131,"Let them know we're gonna make"],[2131,2218,"an emergency order."],[2218,2323,"Oh, Divina's production"],[2323,2402,"cannot be delayed."],[2402,2506,"Chloe, I, I already did."],[2527,2690,"Not a single supplier"],[2690,2773,"wants to work with us."],[2773,2877,"They all rejected us."],[2923,3128,"Boss, someone's short-selling"],[3128,3240,"our stocks."],[3261,3520,"It just plummeted over 80%."],[3520,3753,"There has to be a way to fix this."],[3816,3887,"Call the board."],[3995,4187,"I know exactly what you can do."],[4571,4813,"You're with. Cerberus, aren't you?"],[4813,5005,"Are you the one who stole our supplies?"],[5021,5117,"I don't know a thing about"],[5117,5267,"your stolen supplies, sweetheart."],[5267,5430,"I'm just here to deliver a message."],[5463,5563,"Mr. Carter,"],[5597,5755,"in his infinite compassion,"],[5776,5955,"has given you 3 days."],[5955,6147,"Hand over all patents for Divina,"],[6218,6381,"everything gets to go back to normal."],[6489,6773,"Oh, in your dreams."],[6906,7002,"And if we don't?"],[7065,7169,"You really wanna know?"],[7499,7661,"We take everything from you."]],"35":[[0,171,"We take everything from you."],[333,467,"Go tell Carter"],[513,692,"that Storm Pharmaceuticals"],[692,946,"will not back down."],[1343,1459,"Wow, we got a"],[1459,1626,"real frisky one here, fellas."],[1739,1901,"Okay, we'll do."],[1947,2056,"Just don't come to us"],[2056,2181,"when you end up penniless,"],[2256,2360,"powerless,"],[2398,2581,"drowning in your own tears."],[2640,2731,"Let's go, fellas."],[3057,3194,"Chloe, what are we gonna do?"],[3194,3290,"The Carters are tanking"],[3290,3428,"our company's stocks."],[3482,3653,"And Cerberus is sending goons"],[3653,3757,"to steal our supplies."],[3757,3970,"They're attacking us on all sides."],[3970,4149,"If we take out the head of Cerberus,"],[4149,4333,"that solves half the problem, right?"],[4333,4371,"What?"],[4371,4529,"What do you mean, take out?"],[4629,4721,"Like kill him?"],[4754,4846,"You're kidding, right?"],[4846,5005,"Don't do anything rash, Caspian."],[5005,5055,"We-"],[5088,5234,"We, we will figure something out."],[5234,5347,"Right, yeah, I was kidding."],[5442,5497,"Obviously."],[5547,5630,"Look, this business stuff"],[5651,5822,"is way over me. Um."],[5989,6085,"I'm gonna take a walk"],[6106,6218,"and, clear my head."],[6218,6268,"Okay."]],"36":[[291,371,"Mr. Carter,"],[396,504,"it's a pleasure doing business"],[504,604,"with you as always."],[621,717,"Get me Divina,"],[746,959,"and I will give Cerberus everything."],[984,1059,"Of course, sir."],[1142,1226,"Ms. Brooks won't be able to"],[1226,1334,"survive much longer."],[1843,1914,"Who are you?"],[1931,2002,"How'd you get up here?"],[2085,2185,"Name's Caspian."],[2335,2456,"You're Ms. Brooks' bodyguard,"],[2456,2515,"aren't you?"],[2531,2610,"That's right."],[2744,2886,"And if I were you,"],[2886,3073,"I'd give back everything you stole"],[3073,3178,"from her company"],[3307,3382,"right now."],[3411,3511,"I've known a thousand"],[3511,3607,"guys like you."],[3653,3874,"Young, reckless idiots"],[3874,4012,"charging head first into trouble."],[4012,4133,"You know where they all ended up?"],[4158,4325,"Rotting in the ground."],[4433,4517,"Forgot to mention"],[4517,4646,"if you're trying to call for backup,"],[4654,4738,"it's not gonna work."],[4738,4808,"I cut all the wires"],[4808,4921,"leading to your office."],[5180,5330,"Not that it would matter."],[5330,5472,"They can't save you from me."],[5705,5864,"Who needs backup when you got a gun?"]],"37":[[0,125,"Go for it, pull the trigger."],[179,229,"You'll be dead"],[229,325,"before the bullet hits me."],[971,1026,"No!"],[1055,1167,"That's impossible!"],[1176,1255,"I told you."],[1292,1388,"Who the hell are you?"],[1459,1564,"Are you even human?"],[1572,1651,"Relax."],[1726,1810,"Let's get some air."],[2602,2669,"Stop."],[2786,2836,"What are you doing?"],[2882,2973,"Look, I already told"],[2973,3098,"the nice lady at reception"],[3098,3232,"that you were gonna jump off the roof"],[3232,3353,"and commit suicide."],[3395,3486,"You don't wanna make me out"],[3486,3582,"to be a liar, do you?"],[3599,3666,"Kill me"],[3687,3870,"and Cerberus will murder Chloe Brooks"],[3870,4062,"and your whole fucking family."],[4266,4387,"I've been looking for my family"],[4387,4487,"my entire life."],[4550,4708,"You're not gonna fucking find them."],[6589,6815,"Return the supplies within 24 hours,"],[6815,6994,"or I wipe Cerberus"],[6994,7140,"off the face of the earth."],[7361,7494,"Sir, there's a body"],[7494,7615,"splattered over the sidewalk."],[7624,7711,"It's Mr. Cohen."],[7957,8091,"Gather all members of Cerberus."],[8179,8224,"We're going after"],[8224,8350,"Storm Pharmaceuticals."]],"38":[[254,321,"Breaking news,"],[337,392,"Paul Cohen,"],[392,496,"president of Cerberus,"],[496,579,"jumped out of his office"],[579,654,"window last night,"],[671,775,"in an apparent suicide."],[796,867,"Was that..."],[1005,1063,"you?"],[1263,1384,"There's no way that he"],[1384,1597,"snuck into the Cerberus sky rise,"],[1597,1739,"fought his way to their boss,"],[1739,1822,"threw him out the window"],[1822,2010,"and then walked out totally unnoticed."],[2168,2218,"Right?"],[2323,2377,"Ma'am,"],[2469,2610,"Cerberus has us surrounded."],[2994,3186,"Did you actually go to Cerberus?"],[3303,3449,"Let's go see what they want."],[5088,5150,"Boss."],[5326,5467,"They've been here for 10 minutes."],[5467,5559,"All they said is that"],[5559,5751,"they're here for you and Ms. Brooks."],[5818,5993,"Did you really kill their boss?"],[6056,6197,"Now, we know"],[6264,6481,"Storm Pharma is responsible"],[6481,6627,"for Mr. Cohen's death."],[6777,6890,"Ms. Brooks,"],[6998,7178,"be so kind as to hand over the killer."],[7240,7340,"What killer?"]],"39":[[529,675,"Now what, Caspian?"],[1172,1459,"I will kill every single one of them"],[1459,1643,"the same way I killed your boss."],[1668,1868,"Don't do anything stupid, Caspian."],[1889,2027,"There's too many of them."],[2077,2164,"Mr. Graves,"],[2164,2293,"maybe we can just talk this over."],[2293,2344,"I mean, maybe-"],[2344,2452,"There's nothing to talk about."],[2798,3057,"Go on and set down your weapons, fellas."],[3916,3970,"Caspian,"],[4029,4212,"as is Cerberus tradition,"],[4300,4533,"whoever eliminates our president"],[4554,4708,"becomes the new leader."],[5221,5505,"All hail Caspian Williams!"],[5643,5797,"What the hell is going on?"],[5834,5955,"And Ms. Brooks,"],[5955,6143,"we have returned all stolen supplies"],[6143,6231,"to your company."],[6235,6343,"As an apology,"],[6393,6498,"we've doubled the quantity."],[6531,6614,"Please do feel free"],[6614,6719,"to reach out to your labs"],[6719,6806,"if there's any question"],[6810,6927,"about our sincerity."],[6969,7165,"Everything Mr. Graves said is true."],[7232,7415,"We've got twice the supplies now."],[7428,7524,"Mr. Williams,"],[7590,7665,"Cerberus is now"],[7665,7761,"under your command."],[7791,7895,"My brothers and I"],[7895,8045,"are willing to die for you."],[8062,8212,"I haven't agreed to anything."],[8358,8466,"Let me think about it."],[8583,8666,"Of course, sir."],[8746,8946,"Cerberus awaits your command."]],"40":[[204,325,"Alright, spill."],[362,471,"What the hell did you do?"],[492,704,"Did you kill the head of Cerberus?"],[800,880,"Who, me?"],[975,1042,"Oh."],[1105,1272,"I'm just a bodyguard."],[1272,1380,"You read the news."],[1380,1463,"It was a suicide."],[1518,1651,"Well, whatever happened,"],[1651,1801,"I think it's safe to say that"],[1801,1947,"Cerberus is no longer going to be"],[1947,2060,"an issue for us."],[2198,2381,"Which just leaves us with the Carters."],[2506,2723,"Ma'am, the Carters have used their"],[2723,2948,"stock holdings in Storm Pharma"],[2948,3073,"to demand an emergency"],[3073,3148,"board meeting."],[3148,3224,"Already?"],[3849,4029,"Our stocks are in free fall."],[4091,4220,"And just 10 minutes ago,"],[4229,4329,"Cerberus members"],[4329,4496,"forced their way into the lobby."],[4504,4608,"Storm Pharmaceuticals is"],[4608,4758,"on the verge of collapse."],[4825,4942,"Chloe doesn't have what it takes"],[4942,5046,"to save the company."],[5063,5134,"I vote"],[5180,5342,"we remove her as CEO,"],[5392,5622,"then, sell everything for scraps."],[5676,5851,"Are we really out of other options?"],[5976,6110,"Not just yet!"],[6314,6456,"Your final hope"],[6514,6652,"is to hand over Divina"],[6652,6894,"and Chloe Brooks to the Carter family."]],"41":[[41,187,"Ms. McCarthy, welcome."],[187,333,"I heard Alice McCarthy was"],[333,492,"one of Mr. Brooks' fiercest rivals"],[492,579,"back in the day."],[608,688,"Then she married into"],[688,759,"the Carter family"],[759,905,"and her net worth skyrocketed."],[971,1184,"Want to save Storm Pharmaceuticals?"],[1251,1359,"Your only option"],[1359,1555,"is to enter into a partnership"],[1555,1689,"with the Carter family."],[1976,2202,"Storm Pharma got where it is today"],[2202,2435,"through innovation and hard work,"],[2448,2619,"not by giving in to bullies."],[2619,2831,"You don't get to decide our fate!"],[2902,3086,"Chloe, you know how far back"],[3086,3224,"your father and I go?"],[3257,3599,"I can't let his life's work be squandered"],[3599,3799,"by his reckless little daughter."],[4350,4521,"I am the CEO"],[4550,4746,"of Storm Pharmaceuticals."],[4808,4913,"Not a little girl."],[4938,5271,"You will address me as Ms. Brooks."],[5839,5989,"The board has decided to hand"],[5989,6135,"Divina over to the Carter family."],[6135,6243,"Divina is mine."],[6243,6414,"Nobody is taking it."],[6460,6673,"Are you asking your entire board"],[6694,6898,"to follow you to the grave?"],[6936,7057,"Dignity isn't worth shit"],[7057,7244,"when you're 6 feet under, Chloe."],[7319,7394,"He's right."],[7449,7528,"The Cerberus people"],[7528,7665,"are still down in the lobby."],[7665,7807,"If we don't pick a side soon,"],[7807,8008,"they're gonna raid the whole office."],[8016,8116,"Oh, you haven't heard?"],[8162,8358,"Cerberus is on our side now."]],"42":[[0,196,"Cerberus is on our side now."],[300,400,"Seriously?"],[558,621,"Chloe,"],[658,788,"you can't just lie your way"],[788,900,"out of this crisis."],[900,1159,"What a pathetic excuse for a CEO."],[1159,1326,"Chloe, the Carter family"],[1326,1689,"is a major player across all industries."],[1722,1826,"Working with us would only"],[1826,1968,"benefit your business."],[1989,2193,"Agree to be Jack Carter's wife"],[2193,2394,"and Storm Pharma's set forever."],[2402,2677,"Ugh, it's a no-brainer, Chloe!"],[2677,2869,"Jack Carter is a catch!"],[2869,3061,"And frankly, you could do a lot worse."],[3278,3374,"Oh, wow."],[3490,3582,"You know,"],[3616,3849,"if you are so very fond of Mr. Carter,"],[3849,3945,"you could just try"],[3991,4208,"marrying him yourself, princess."],[4287,4404,"Mr. Graves?"],[4575,4688,"Why is he here?"],[4742,4854,"Oh my God,"],[4854,5063,"Cerberus is gonna murder us all."],[5096,5246,"Edward, could you be so kind as to"],[5246,5401,"inform everyone on what's happening?"]],"43":[[0,91,"Caspian."],[175,300,"You're just a glorified doorman!"],[300,408,"How dare you speak to"],[408,513,"Mr. Graves like that?"],[558,654,"Ow!"],[750,888,"No one asked you anything."],[996,1101,"Keep your mouth shut."],[1151,1497,"Starting today, Cerberus works with"],[1497,1651,"Storm Pharmaceuticals."],[1651,1881,"And the enemies of Ms. Brooks"],[1981,2131,"is an enemy of ours."],[2193,2273,"Edward,"],[2314,2473,"you're just another dog"],[2473,2644,"on the Carter family leash."],[2698,3019,"Do not bite the hand of your owners!"],[3345,3474,"Chloe, if this is true,"],[3520,3720,"you just declared war on the Carters."],[3741,3795,"No."],[3853,3916,"I'm out!"],[3949,4104,"I don't need the Carters on my head."],[4220,4308,"I'm out, too."],[4320,4471,"I'm separating my ties with them, too."],[4496,4629,"Oh! Okay..."],[4679,4775,"Now wait a minute, everyone."],[4775,4979,"Let's take a second to think"],[4979,5159,"before we make any rash decisions."],[5167,5451,"Are you absolutely sure you want out?"]],"44":[[0,108,"Very well then."],[162,321,"Prepare to face"],[321,475,"the Carter family wrath!"],[871,1046,"What have you done?"],[1076,1197,"Storm Pharma is gonna be"],[1197,1292,"nuked off the map,"],[1292,1426,"just like that York family that"],[1426,1597,"messed with the Carters a while back."],[1664,1818,"Listen up."],[1947,2072,"Storm Pharmaceuticals"],[2072,2248,"was my father's life's work."],[2248,2494,"It's not going to die on my watch."],[2523,2694,"I will have things back on track"],[2694,2819,"in the next 6 hours."],[2819,2923,"That's a promise."],[3123,3328,"Jesus, the arrogance."],[3340,3420,"How about this?"],[3420,3536,"If you don't keep your promise,"],[3536,3691,"you resign as CEO"],[3691,3878,"and hand over Divina to the Carters."],[3991,4029,"Deal."],[4087,4187,"Alright then."],[4371,4558,"Go on, sign your death warrant."],[4587,4679,"Under one condition."],[4708,4850,"If Chloe keeps her promise,"],[4850,5038,"you all give her your shares,"],[5038,5205,"and get the hell out of Storm Pharma."],[5680,5768,"Wait."],[5805,5905,"You actually think"],[5905,6085,"you have a chance of winning this?"],[6110,6235,"Handling the Carter family"],[6235,6356,"within 6 hours?"],[6406,6581,"What are these people smoking?"],[6619,6673,"Deal!"],[6719,6781,"Deal."],[7132,7294,"It's over for you, suckers."]],"45":[[216,321,"Those men founded"],[321,429,"Storm Pharmaceuticals"],[429,521,"with my father."],[567,767,"They were basically like uncles to me."],[809,938,"You're better off not having them"],[938,1042,"breathing down your neck."],[1055,1126,"You're right."],[1176,1343,"Besides, I need to focus on"],[1343,1472,"what's really important."],[1514,1651,"And that is keeping"],[1651,1747,"Storm Pharmaceuticals"],[1747,1810,"safe."],[1810,1931,"So, you have a plan?"],[2560,2686,"So, I ran some numbers and..."],[2969,3007,"Here."],[3069,3136,"Thank you."],[3136,3182,"Mmhmm."],[3511,3649,"Alright, team, you see here"],[3649,3745,"on the chart."],[3745,3966,"Q1, I think we're gonna save"],[3966,4149,"about 2 million people."],[5593,5684,"It's over."],[5809,5876,"We did it."],[6089,6210,"Time's up, Chloe!"],[6327,6385,"I'll take your"],[6385,6510,"resignation letter now."],[6623,6781,"Who says I'm resigning?"]],"46":[[0,108,"We made a deal, Chloe."],[187,354,"You said you'd resign as CEO"],[354,446,"and hand over Divina."],[446,625,"You can't go back on your word."],[679,896,"Are you really sure you won the bet?"],[1159,1301,"Storm Pharma stocks are as steady"],[1301,1384,"as ever."],[1409,1568,"But weren't they just tanking?"],[1593,1714,"They're not just steady,"],[1755,1885,"they're skyrocketing."],[1922,1972,"No."],[2047,2164,"Impossible!"],[2377,2481,"How could she do all of this"],[2481,2590,"in 6 hours?"],[2627,2686,"First,"],[2727,2873,"Mr. Graves returned everything"],[2873,2994,"that Cerberus stole."],[3065,3282,"Then they stationed security"],[3282,3428,"at our manufacturing plants,"],[3428,3632,"protecting production lines."],[3636,3782,"Carter's family attack on us"],[3782,3945,"was vicious, yes."],[3945,4045,"And it's true."],[4045,4141,"They do indeed"],[4141,4308,"run most of the East Coast."],[4333,4529,"But the world's a big place."],[4537,4717,"So I went international."],[4800,4946,"You were talking to other investors"],[4946,5105,"before we made our deal, weren't you?"],[5125,5309,"You were scheming this entire time."],[5522,5572,"You know what?"],[5572,5613,"Fine."],[5747,5814,"You win."],[6006,6068,"Let's go."],[6448,6527,"What are you doing?"],[6619,6690,"Chloe won."],[6773,6840,"It's time to"],[6840,6973,"keep up your side of the bargain."]],"47":[[41,91,"Chloe,"],[158,312,"we're old friends of your father's."],[367,538,"We're founders of this company."],[538,625,"There's no reason"],[625,759,"to take this any further."],[792,892,"Come on, Chloe."],[925,1126,"Storm Pharma needs us."],[1151,1292,"Chloe, you're being unreasonable."],[1292,1363,"We were just doing"],[1363,1514,"what was best for the company."],[1630,1701,"No."],[1718,1876,"You tried to sell this company"],[1876,2022,"and whore me off to Jack Carter,"],[2022,2181,"all to keep your profits."],[2206,2323,"You were thinking about nobody"],[2323,2385,"but yourselves."],[2385,2431,"Admit it."],[2444,2581,"Shut the fuck up!"],[2619,2702,"Even your father"],[2702,2848,"never spoke to me like this."],[2961,3011,"Now,"],[3082,3257,"apologize and open that door."],[3299,3411,"Or I will- - Hey!"],[3478,3628,"I'm tired of your bullshit."],[3682,3824,"No one goes anywhere"],[3824,4074,"until you keep up your end of the deal."],[5171,5276,"Watch your back, Chloe."],[5276,5359,"This isn't over."],[5442,5630,"Edward, show them out."],[5655,5926,"Out the way you came in, gentlemen."],[7665,7811,"Why are you locking the door?"]],"48":[[25,137,"It's been a long day."],[621,754,"I thought we'd have some fun."],[1051,1155,"Finish what we started?"],[1647,1743,"Exactly."],[2777,2890,"Here, in the office?"],[3194,3265,"Why?"],[3407,3499,"Are you scared?"],[3545,3607,"Terrified."]],"49":[[508,617,"I am gonna go change"],[617,709,"into something nicer."],[709,884,"And then we have to celebrate."],[1768,1839,"Mr. Williams!"],[1864,1893,"Help!"],[1910,1964,"Save us!"],[2344,2419,"What is it?"],[2540,2585,"Nothing."],[2686,2811,"I have to head out for a bit."],[3082,3199,"Don't leave the house while I'm gone."],[3924,4004,"What the hell happened?"],[4004,4083,"Mr. Williams,"],[4083,4187,"the Carters came in here."],[4187,4362,"They, they forced me"],[4362,4521,"to give them 90% of Cerberus."],[4521,4683,"I'm so sorry, sir."],[4683,4850,"They were gonna kill me if I didn't."],[4913,4971,"And they,"],[5046,5159,"they also said that"],[5196,5347,"you're already as good as dead."],[5555,5630,"What else?"],[5747,5930,"They gave me 3 hours to make"],[5930,6076,"the most important decision in my life."],[6076,6260,"Either start following their orders,"],[6260,6352,"or they kill me."],[6552,6631,"3 hours to"],[6631,6773,"destroy the Carter family?"],[6902,7077,"Yeah, that should be enough."],[7178,7282,"Get yourself cleaned up."],[7465,7540,"Ow, ugh."]],"50":[[2302,2489,"Mr. Carter, Edward's here."],[2544,2715,"Caspian Williams is with him."],[2944,3086,"That guy just doesn't quit."],[3132,3194,"Let them in."],[3912,3991,"Relax, Eddie."],[3991,4145,"You're the VP of Cerberus."],[4170,4233,"We'll be fine."],[4262,4466,"Mr. Williams, I know you're a badass."],[4466,4587,"We are just two people."],[4587,4675,"The odds here are-"],[4688,4763,"Are in our favor."],[4929,4984,"They're the ones"],[4984,5092,"who should be terrified."],[5480,5593,"The Carter family"],[5613,5739,"should be afraid of you?"],[5764,5880,"You might be the first person"],[5880,6056,"on the East Coast to make that claim."],[6151,6252,"Shit."],[6252,6356,"Silent 6."],[6389,6489,"It's the Carters' deadliest"],[6489,6614,"team of assassins, sir,"],[6614,6852,"we are so fucked."],[6852,6911,"Kill them."]],"51":[[688,775,"Fuck!"],[834,967,"Is that the best you can do?"],[1184,1272,"Whoever kills him"],[1272,1493,"gets a 10 million dollar reward!"]],"52":[[905,1067,"Die, motherfucker."],[1772,1885,"Listen up, Jack."],[1951,2022,"Cerberus"],[2081,2193,"belongs to me now."],[2227,2410,"Overstep your authority again"],[2544,2756,"and even God will be scared to save you."],[4612,4825,"Father, I've failed you."],[5330,5530,"You fucking disappointment."],[5555,5672,"Father, I'm sorry."],[5672,5864,"I never should have underestimated him."],[6001,6131,"I'll handle Storm"],[6131,6277,"Pharmaceuticals myself."],[6322,6406,"Make them vanish"],[6406,6548,"like I did the York family."],[7023,7215,"Remind the world what happens"],[7273,7382,"when you go against the Carters."],[7382,7436,"Understand?"],[7507,7574,"Yes, sir."]],"53":[[358,396,"Sis,"],[396,521,"if you're so worried about Caspian,"],[521,621,"just give him a call."],[621,792,"I think he went to the Carter house."],[825,875,"What?"],[900,988,"I am done"],[988,1117,"letting him risk his life for me."],[1117,1217,"I can lose Divina."],[1247,1376,"I can't lose Caspian."],[1680,1768,"Mr. Williams,"],[1789,1985,"this ledger contains info on"],[1985,2114,"every one of Cerberus'"],[2114,2260,"members and contacts."],[2260,2402,"Only the boss has access."],[2427,2502,"That's you."],[4838,4984,"After 20 years,"],[5067,5205,"I'll finally know the truth"],[5205,5309,"about my past."],[6256,6318,"Samuel,"],[6389,6594,"our synthetic bone tissue project"],[6623,6706,"was a success!"],[6760,6919,"York Group is going to bring hope"],[6919,7161,"to countless patients around the world!"],[7186,7265,"That's incredible."],[7315,7415,"This is one of the most important"],[7415,7520,"scientific breakthroughs"],[7520,7657,"in modern history!"],[7932,8053,"Let's celebrate as a family"],[8053,8254,"when Caspian gets home from school."],[8254,8295,"Yeah."]],"54":[[150,200,"Chloe,"],[241,329,"mommy said"],[329,508,"she's gonna throw a party tonight."],[521,621,"Can I come, Caspy?"],[642,704,"Of course."],[804,884,"Let's go home."],[896,1080,"Caspian's gonna be waiting for us."],[1376,1597,"Well, you two seem in high spirits."],[1689,1872,"I hope I'm not interrupting."],[1947,2031,"Mr. Carter."],[2097,2289,"We weren't expecting you."],[2331,2585,"I am here to propose a partnership"],[2635,2736,"between the York Group"],[2802,2907,"and the Carter family."],[2936,3061,"Ah, the York Group"],[3061,3303,"is a small family office."],[3311,3420,"We didn't think we'd be on"],[3420,3528,"the Carter family's radar."],[3532,3586,"Sure."],[3591,3912,"I have seen your latest updates,"],[3974,4183,"lab-grown bone tissue."],[4183,4358,"It's quite an achievement,"],[4358,4504,"medical miracle, even."],[4504,4679,"It's certainly worthy of investment."],[4721,4875,"I trust we can reach an agreement"],[4875,5063,"that will be good for both of us."],[5063,5155,"We're just"],[5351,5467,"at the beginning of this."],[5467,5613,"We're open to a partnership."],[5659,5960,"But can you give us some specifics?"],[5972,6043,"Yes, sir."],[6468,6698,"All synthetic bone tissues will be"],[6698,6940,"unconditionally relinquished"],[6940,7102,"to the Carter family"],[7102,7332,"for further research and development?"],[7378,7582,"With a five percent share in profits"],[7582,7695,"for the York Group?"],[7786,7978,"This is a highway robbery!"]],"55":[[0,191,"We reject that proposal."],[204,296,"Samuel, I'm afraid"],[296,417,"you don't understand."],[442,621,"I'm not here to negotiate terms."],[629,771,"I'm here to alert you"],[771,913,"to a changing partnership."],[930,1030,"This is how the Carter family"],[1030,1113,"operates with..."],[1230,1334,"I think it would be"],[1334,1505,"in your best interest to accept."],[1664,1826,"After all, you do have a"],[1826,1935,"5-year-old son"],[1935,2031,"to consider. - Hey."],[2031,2131,"Touch my son,"],[2185,2385,"and I send you straight to hell!"],[2385,2477,"I don't want to hear shit"],[2477,2585,"about my family."],[2640,2790,"We reject your proposal."],[3244,3336,"That is a shame."]],"56":[[0,62,"Sir,"],[108,246,"Caspian has antagonized"],[246,412,"the Carter family for my sake."],[429,646,"I take full responsibility."],[646,875,"As an apology, I am willing to offer"],[875,1063,"1 billion dollars in compensation."],[1242,1409,"Okay, I will give the Carter family"],[1409,1601,"exclusive distribution rights"],[1601,1672,"to Divina."],[1689,1906,"Just please forgive Caspian."],[2327,2419,"That's not enough."],[2444,2594,"I want the formula, the patent,"],[2594,2756,"and fifty-one percent"],[2756,2882,"of Storm Pharmaceuticals."],[2944,3094,"But sir, that will ruin"],[3094,3178,"my company. - And that"],[3178,3299,"is the point."],[3340,3407,"Look, I knew"],[3407,3532,"you wouldn't agree to this."],[3561,3657,"But since you're here,"],[3695,3912,"in my castle, where I'm king,"],[4037,4141,"it doesn't really matter"],[4141,4237,"if you agree or not."],[4245,4354,"What are you gonna do?"],[4466,4542,"Kill me?"],[4604,4692,"I'd like to."],[4696,4904,"But if you become my son's woman,"],[4946,5125,"I'll consider keeping you alive."],[5180,5255,"Never."],[6010,6222,"You really walked right into my lair"],[6222,6377,"just to save Caspian?"],[6631,6815,"Too bad he's not coming to save you."],[7624,7741,"She's all yours."]],"57":[[579,646,"What the-"],[1630,1710,"Mommy?"],[1851,1935,"Daddy?"],[2965,3115,"I'll take care of your child."],[3148,3278,"I'll make sure he lives right."],[3278,3361,"And someday,"],[3361,3482,"when he's strong enough,"],[3553,3678,"he will avenge you."],[3678,3812,"I'll tell him everything."],[3995,4070,"Caspy?"],[5284,5417,"I'm going to end them once"],[5417,5492,"and for all."],[6106,6272,"You think Caspian's gonna show?"],[6272,6435,"No fucking way, man."],[6435,6552,"He's not that dumb."],[6552,6660,"And even if he did,"],[6673,6840,"he's just a fucking security guard."],[6852,7011,"We can take him easy."],[7011,7152,"You see this girl Chloe though?"],[7203,7378,"Bro, she's fucking hot."],[7490,7649,"You think Mr. Carter might let us-"]],"58":[[583,667,"You better let me go"],[667,800,"before Caspian gets here."],[800,1021,"Caspian, Caspian, Caspian."],[1021,1084,"Shut up!"],[1084,1259,"He's a fucking security guard,"],[1288,1426,"a fucking doorman."],[1426,1555,"He's got no chance."],[1555,1735,"And if you'd just given us Divina,"],[1735,1847,"like a good girl,"],[1847,1947,"you wouldn't find yourself"],[1947,2018,"in this mess."],[2018,2102,"Let me go."],[2152,2218,"You think"],[2218,2398,"Caspian's really gonna want you"],[2452,2631,"after he sees you squirming"],[2631,2727,"underneath me?"],[2794,2902,"What are you talking about?"],[2973,3082,"Don't touch me."],[3082,3157,"Stop it!"],[3666,3737,"Oops."],[3891,4024,"Champagne tastes so much better"],[4024,4099,"this way."],[4650,4717,"Fuck."],[4792,4838,"Fuck."],[5021,5130,"You're finished, Carter."]],"59":[[850,950,"Are you crazy?"],[988,1084,"You came here alone?"],[1130,1288,"I'd walk head first into hell"],[1288,1368,"to bring you back."],[1397,1476,"Ugh."],[1505,1609,"Well, well."],[1705,1881,"Look who finally showed up."],[1935,2035,"I thought the help"],[2035,2168,"was gonna be a no-show."],[2193,2264,"Tell your father"],[2264,2389,"to get his ass out here."],[2389,2464,"Yeah."],[2548,2673,"That's not gonna happen."],[3240,3490,"You stupid, inbred peasant."],[3566,3720,"Your fate was sealed the second"],[3720,3853,"you walked into this house."]],"60":[[2448,2489,"Chloe!"],[4792,4879,"You know,"],[4942,5109,"I bet if I killed you,"],[5167,5305,"your father would show up."],[5434,5513,"No, no, no."],[5572,5613,"Don't."],[5726,5809,"Don't!"],[6719,6790,"Caspian."]],"61":[[16,354,"I have one last offer for you."],[404,517,"Join the Carter family,"],[617,684,"and then I'll"],[750,850,"let Chloe go."],[921,1067,"I'll even let her keep Divina."],[1101,1301,"We'll wipe the slate clean,"],[1359,1459,"make things go away."],[1526,1589,"What do you think?"],[1634,1739,"Father, help!"],[1780,1868,"Help me!"],[1868,2027,"Shut up!"],[2135,2273,"Caspian, you ought to be honored."],[2273,2435,"You're the first man I've ever given"],[2464,2581,"such a generous offer."],[2631,2694,"Sebastian,"],[2694,2815,"do you remember the York family?"],[2840,2927,"The Yorks?"],[3003,3157,"You're Samuel York's son?"],[3174,3303,"20 years ago,"],[3336,3457,"you killed my parents."],[3503,3570,"You stole their"],[3570,3678,"breakthrough research."],[3716,3799,"And now you're doing"],[3799,3966,"the same thing to Divina."],[3987,4104,"So what?"],[4216,4287,"The Carter family"],[4287,4487,"runs the entire East Coast,"],[4537,4646,"If we want something,"],[4646,4754,"we take it!"],[4792,4971,"Now you let my son go,"],[4971,5125,"or you and Chloe are not making it"],[5125,5246,"out of here alive."],[5764,5830,"Jack!"],[6435,6669,"I am gonna fucking kill you."]],"62":[[8,62,"You."],[2035,2156,"It's impossible."],[2385,2548,"I've trained my entire life"],[2548,2781,"with the best killers on earth."],[2923,3036,"How did you beat me?"],[3036,3115,"Should've seen this"],[3115,3282,"coming the day you killed my parents."],[4316,4387,"Hey, Chlo."],[4567,4658,"Remember me?"],[4733,4808,"York."],[5284,5417,"You're Caspy?"]],"63":[[1096,1167,"Chloe."],[1434,1539,"How many times do I have to"],[1539,1643,"remind you to take it easy?"],[1710,1793,"At this rate,"],[1793,1943,"our baby's gonna be a workaholic"],[1943,2056,"just like their mom."],[2268,2323,"You ready?"],[2439,2502,"Yeah."],[2623,2711,"Let's go."],[2827,2911,"The press conference"],[2911,2990,"is about to start."],[3161,3219,"Okay."],[3319,3357,"Come on."],[3678,3745,"Ms. Brooks,"],[3745,3908,"when will your sister be arriving?"],[4020,4083,"Right now."],[4654,4783,"Is she pregnant?"]],"64":[[33,162,"1 year ago today,"],[200,350,"on this very stage,"],[379,617,"I introduced Divina to the world."],[667,750,"Today,"],[775,896,"after a year of development"],[896,1001,"and production,"],[1046,1117,"Divina will"],[1117,1292,"finally be released to the public."],[1305,1376,"Ms. Brooks,"],[1384,1576,"how much will Divina cost?"],[1597,1710,"Will living cancer-free"],[1710,1901,"be a luxury only for the rich?"],[1914,2068,"After much deliberation,"],[2093,2206,"Storm Pharmaceuticals"],[2206,2385,"has decided to set Divina's"],[2385,2585,"total cost of treatment at"],[2598,2731,"100 dollars."],[2731,2790,"What?"],[2790,3061,"So 100 dollars to cure cancer?"],[3144,3307,"I mean, that would mean almost"],[3328,3445,"everyone can afford it."],[3478,3611,"We've never seen anything like this"],[3611,3745,"in the history of medicine."],[3958,4045,"And for anyone"],[4045,4170,"who still can't afford it,"],[4170,4283,"Storm Pharmaceuticals"],[4283,4366,"will be donating"],[4366,4571,"all of Divina's profits to charity,"],[4604,4771,"with the goal of ensuring that"],[4771,4967,"every single cancer patient"],[4967,5117,"has access to treatment."],[5192,5384,"Divina is going to make cancer"],[5384,5551,"a thing of the past."]]}