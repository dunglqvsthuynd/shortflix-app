e Fortune 500"],[4771,4888,"owes you favors."],[4892,4979,"Consider it done."],[5784,5830,"Yes, sir."],[6172,6252,"Understood."],[6310,6360,"Wheels up."],[6360,6519,"I'll be in New York before sunrise."],[6652,6798,"Turn us around airport, fast."],[6798,6973,"Sir, we're due at a signing."],[6998,7152,"Nine figures."],[7152,7265,"That's nothing compared to this."],[7269,7361,"Airport, go."],[7887,7995,"We're headed to New York."],[8078,8170,"Brief me in the car."]],"58":[[863,996,"Mommy, you're awake."],[1009,1092,"Hi, Dear."],[1113,1176,"Baby."],[1263,1359,"Breakfast is hot."],[1397,1476,"Dig in."],[1580,1630,"Connor,"],[1735,1814,"upstairs."],[1822,1910,"We need to talk."],[2085,2127,"Kiddo,"],[2156,2302,"mommy and daddy need five minutes,"],[2302,2335,"okay?"],[2335,2402,"You'll be good."],[2410,2473,"Okay."],[2481,2552,"Okay, cutie."],[3382,3445,"Baby, I don't want to"],[3445,3549,"leave Summer down there too long."],[3549,3607,"What's up?"],[4079,4175,"There's five million dollars"],[4175,4258,"in this account."],[4287,4421,"Take it and leave New York."]],"59":[[50,145,"What the hell is this?"],[162,279,"I don't want your money, baby."],[304,446,"I only have three days"],[454,684,"to pull Asterion out of this nosedive."],[729,838,"And I don't think I can."],[888,1021,"If the board dumps me,"],[1076,1155,"I'm destroyed."],[1259,1338,"You've been good to me."],[1384,1484,"And you've been good to Summer,"],[1484,1551,"and..."],[1776,1864,"You're a good dad."],[1989,2089,"And a good husband."],[2214,2398,"And I'm sorry, but if you stay here,"],[2398,2535,"I will just drag you down with me."],[2535,2765,"Okay, so you think that a good father"],[2786,2827,"and a..."],[2827,2969,"You know, a decent husband"],[2982,3182,"walks when a house is on fire?"],[3424,3611,"Just go while you still can."],[3611,3720,"No, listen."],[3720,3862,"Let me take care of you both."],[3903,3974,"Please."],[4024,4074,"But-"],[4074,4212,"No, marriage means that we"],[4212,4333,"ride it together."],[4429,4546,"All right, for once,"],[4654,4808,"let me be here for you both."],[5221,5347,"Thank you, Connor."],[6715,6835,"Ms. Hayes Asterion's"],[6835,6931,"press conference today"],[6931,7044,"will announce the result of"],[7044,7182,"your wager against the board."],[7198,7315,"If you lose, you're out."],[7319,7374,"Are you ready?"],[7407,7557,"If you're removed as CEO,"],[7557,7757,"what's next for you and Asterion?"],[7799,7870,"What next?"],[7920,8045,"Is she going to be escorted off"],[8045,8124,"the premises,"],[8124,8312,"disgraced and penniless?"]],"60":[[0,216,"Don't talk about my mommy like that!"],[216,358,"Listen here, you little brat."],[417,550,"If you don't stop yapping,"],[583,738,"I'm going to shut your mouth for you!"],[754,855,"What did you just say?"],[1167,1247,"The press conference"],[1247,1363,"hasn't started yet."],[1397,1488,"No one's won a thing."],[1543,1664,"We'll see who's last standing."],[1956,2139,"Why was she acting so calm?"],[2139,2273,"She doesn't have an ace hiding up"],[2273,2323,"her sleeve,"],[2323,2406,"does she?"],[2489,2590,"Of course not."],[2602,2819,"She's just too dumb to be scared."],[3003,3086,"So true."],[3674,3753,"Ladies and gentlemen,"],[3782,3958,"thank you for coming on such"],[3987,4083,"short notice."],[4154,4266,"Under my"],[4266,4396,"daughter's leadership,"],[4471,4554,"the Asterion Group"],[4554,4792,"has alienated some key suppliers,"],[4800,4938,"including the Whitmore Group."],[4979,5059,"Now, these..."],[5125,5376,"actions, along with poor execution,"],[5392,5522,"put our company at risk."],[5559,5734,"Now, we've given her three days"],[5805,5960,"to secure new suppliers"],[5960,6189,"and stabilize operations."],[6218,6322,"If she fails,"],[6322,6564,"she will resign and surrender all"],[6627,6702,"her equity."],[7766,7949,"Now, Ms. Hayes,"],[8028,8099,"time is up."],[8133,8233,"You gave your word."],[8299,8437,"Have you brought new suppliers to the"],[8437,8537,"Asterion Group,"],[8537,8746,"or will you be stepping down?"]],"61":[[0,83,"Look at her."],[91,183,"Pathetic."],[229,350,"Scarlett, three days ago"],[350,454,"we gave you an out."],[487,684,"Step down, leave with a share,"],[717,888,"walk away with some of your dignity."],[896,1151,"But now, you have nothing."],[1255,1463,"Wasn't she supposed to be a killer CEO?"],[1493,1601,"PR polish."],[1609,1751,"Heard her private life's a mess."],[1751,1889,"She had a kid out of wedlock."],[1918,2064,"Family scandal."],[2131,2377,"Hello, I'm talking to you, Scarlett."],[2394,2606,"Did you land any new suppliers or no?"],[3849,3999,"How about you show my wife"],[4041,4191,"the respect that she deserves?"],[4379,4496,"Respect?"],[4521,4604,"Please."],[4633,4725,"She's a slut,"],[4742,4871,"she's always been a slut,"],[4888,4975,"and her dirty four-year-old"],[4975,5125,"trash baby is proof."],[6085,6197,"You hit me!"],[6210,6264,"I did."],[6335,6569,"You say one more word about my wife"],[6598,6677,"or my daughter"],[6715,6827,"and I will take out your tongue,"],[6827,6927,"so please try me."],[6981,7127,"Oh, Scarlett."],[7140,7374,"You have lost your mind."],[7390,7478,"Dragging your..."],[7549,7695,"stray in here"],[7695,7941,"and assaulting people in public?"],[8003,8153,"I stand by my husband."],[8174,8295,"You don't talk about my daughter"],[8295,8354,"like that."],[8450,8566,"And you better watch your mouth."],[8566,8671,"Because the next time,"],[8708,8829,"you'll get more than a slap."]],"62":[[8,216,"Look at this woman."],[241,483,"Nothing but violent trash."],[542,650,"People like her?"],[684,900,"They should be spit out of this city."],[930,1034,"Shut the fuck up."],[1042,1163,"Enough chatter!"],[1301,1572,"Scarlett, since you haven't landed"],[1672,1764,"any new suppliers,"],[1918,2077,"sign the transfer now."],[2890,2977,"I'm sorry I let"],[2977,3078,"you and Summer down."],[3378,3457,"I gave you my word."],[3632,3682,"I'll keep it."],[3757,3837,"Finally!"],[3858,3966,"Consequences!"],[4004,4129,"You knew this was coming."],[4262,4341,"You lose."],[5180,5317,"Hey, wait."]],"63":[[129,367,"Who says we lost?"],[700,788,"Come on, bro."],[875,984,"What do you think you're doing?"],[984,1096,"So did you just think we were gonna"],[1096,1238,"roll over and take it?"],[1501,1643,"That's your grand plan?"],[1655,1772,"Tear the contract?"],[1830,1981,"That's the thought process of"],[1981,2139,"a kept-man with no brains."],[2289,2373,"You sign today."],[2398,2556,"Cameras or no cameras."],[2990,3165,"If I lost, I lost."],[3357,3432,"It's okay."],[3545,3611,"We'll rebuild."],[3728,3774,"Hey."],[4129,4266,"I say you didn't lose."],[4362,4462,"So you didn't lose."],[4621,4704,"Come here."],[5413,5638,"Talon Group CEO Gus Chambers,"],[5638,5876,"Sky nine Industries CEO Owen Lake,"],[5901,6122,"Redwater Capital CEO Grant Rivers"],[6122,6231,"on site."]],"64":[[8,79,"Talon,"],[91,179,"Sky nine,"],[204,275,"Redwater?"],[300,350,"Those are all"],[350,487,"national level whales."],[508,658,"Why the hell are they in Midtown"],[658,809,"for a mid-cap presser?"],[850,1071,"This is because of him?"],[1213,1351,"Mr. Chambers."],[1388,1463,"Mr. Lake."],[1476,1547,"Mr. Rivers."],[1547,1664,"Welcome, welcome."],[1714,1901,"We're so proud to have you."],[1910,1997,"Truly."],[2022,2072,"What can I-"],[2077,2118,"You are?"],[2268,2581,"I'm acting CEO of Asterion Capital"],[2581,2744,"and host of this event."],[2748,2840,"Funny because we were told"],[2840,2998,"that Scarlett Hayes runs Asterion."],[3103,3153,"Well,"],[3215,3390,"she was relieved of her duties"],[3390,3486,"by the board."],[3486,3599,"Effective today."],[4083,4304,"What are you doing?"],[4529,4654,"We're here for Ms. Hayes,"],[4725,4909,"not for some mid-level wannabe."],[4942,5005,"That's right."],[5038,5130,"All of us."]],"65":[[517,642,"Mr. Chambers,"],[650,738,"Mr. Lake."],[738,863,"Mr. Rivers."],[917,1042,"You got it wrong."],[1088,1276,"Scarlett is a fraud."],[1943,2152,"Now, which one of you"],[2152,2285,"is Scarlett Hayes?"],[2506,2573,"I am."],[2990,3174,"Gus Chambers, Talon Group."],[3224,3294,"Owen Lake."],[3332,3457,"Sky nine Industries."],[3503,3582,"Grant Rivers,"],[3628,3737,"Redwater Capital."],[3812,3903,"We're all here to work with you,"],[3903,3962,"Ms. Hayes."],[4183,4245,"No way."],[4270,4458,"You've got to be kidding me."],[4529,4579,"Work with"],[4675,4721,"me."],[4750,4800,"That's right."],[4829,4904,"People, capital,"],[4904,5030,"whatever you need, we'll supply it."],[5113,5263,"These are our opening terms."],[5347,5492,"Our sincerity on paper."],[6181,6314,"A hundred billion dollar"],[6314,6439,"investment package?"],[6581,6685,"Development rights to the"],[6685,6831,"Grand Summit project?"],[6944,7127,"A port logistics concession?"]],"66":[[33,112,"This is too much."],[162,337,"I don't know what I did to deserve this."],[337,483,"Don't be polite, Ms. Hayes."],[521,621,"You're doing us a favor"],[621,692,"working with us."],[892,971,"If he asked,"],[971,1163,"I'd hand him my entire company."],[1167,1267,"Can I at least ask"],[1267,1372,"who asked you to come here?"],[1430,1459,"Baby,"],[1630,1801,"they showed up with real terms."],[1931,2014,"We accept."],[2352,2502,"So it really is him."],[2527,2598,"And you"],[2598,2748,"said that once my wife landed"],[2748,2823,"real partner,"],[2823,2915,"stabilized the company,"],[2915,3040,"that you would transfer your shares,"],[3040,3090,"right?"],[3128,3224,"It's time to sign."],[3253,3324,"Scarlett,"],[3399,3503,"shares in your hand,"],[3503,3582,"shares in my hand."],[3582,3674,"What's the difference?"],[3699,3787,"We're family."],[3787,3912,"Exactly."],[3949,4149,"Your father never meant any harm."],[4162,4325,"We've only done what's best"],[4350,4446,"for the company."],[4471,4546,"Family?"],[4633,4708,"That's cute."]],"67":[[0,200,"So when you called my wife a slut,"],[200,354,"you called my daughter a bastard."],[412,521,"Where was family then?"],[550,779,"Okay, so, we made a mistake."],[800,925,"I made a mistake."],[967,1046,"Please, just"],[1067,1222,"give us a pass this one time."],[1338,1405,"Then kneel."],[1539,1659,"Yeah, go ahead and kneel."],[1685,1881,"Apologize with your face on the ground."],[1956,2081,"And you promise that you stay out"],[2081,2185,"of my wife's sight forever."],[2185,2394,"You do that, hey, we're done here."],[2469,2540,"You,"],[2640,2961,"Scarlett, in front of half the city?"],[3003,3161,"Must you humiliate us?"],[3390,3536,"Doesn't feel so good when it's you,"],[3536,3603,"does it?"]],"68":[[4,166,"I'm still your father."],[258,325,"Father?"],[404,529,"You don't deserve that title."],[563,667,"The day you dumped my mother"],[667,796,"for that trash,"],[846,930,"is the day you became"],[930,1034,"nothing to me."],[1092,1155,"Who"],[1222,1288,"fed you?"],[1368,1555,"Who raised you to this day?"],[1555,1714,"Oh, cut the act, Stephen."],[1814,1897,"You know exactly"],[1897,2002,"how you've treated me."],[2018,2135,"How you've treated Summer."],[2168,2293,"I will never forgive you."],[2356,2460,"Not in this lifetime."],[2523,2606,"Enough."],[2706,2973,"Kneel and apologize or sign."],[3078,3199,"You're dreaming."],[3240,3315,"You think because"],[3324,3490,"you beat me here, you're taking control"],[3490,3582,"of this company?"],[3674,3753,"Not today."],[3787,3933,"What is that supposed to mean?"],[4141,4229,"You want the truth?"],[4266,4500,"Before this little press circus,"],[4571,4829,"I went ahead and sold all the equity."]],"69":[[225,283,"What?"],[350,425,"You won."],[513,596,"So what?"],[709,838,"You know why I despise you?"],[867,996,"Because you're just like that"],[1046,1188,"saint of a mother."],[1284,1405,"She made me sick."],[1455,1568,"And so do you."],[1939,2106,"How dare you hit me!"],[2110,2214,"Baby, come here."],[2940,3094,"Tell me who you sold it to."],[3161,3211,"Say it."],[3278,3357,"That's the last thing"],[3357,3478,"my mother left me."],[3507,3653,"What difference does it make?"],[3720,3816,"It's gone."],[3891,4054,"Who did you sell it to?"],[4083,4149,"To me."]],"70":[[129,279,"Why is Bennett Whitmore here?"],[300,421,"Did he buy Asterion?"],[467,563,"What are you doing here?"],[621,717,"Place is buzzing."],[754,846,"Why wouldn't I show up?"],[859,1026,"Mr. Whitmore, you're finally here."],[1055,1280,"Well, we're in this together now."],[1451,1505,"We?"],[1543,1743,"You sold to me,"],[1801,1956,"which means I have no more use for you."],[1960,2027,"What?"],[2039,2110,"You said when the"],[2110,2227,"acquisition was done,"],[2243,2314,"you would keep me on to"],[2314,2398,"run the company."],[2398,2473,"You promised!"],[2489,2610,"No, I never said that."],[2702,2802,"Even if I did,"],[2836,2940,"you don't have proof."],[2969,3086,"So this was all you're doing?"],[3136,3269,"You pulled all this?"],[3282,3420,"Oh, you're damn right I did."],[3461,3561,"Watching your family"],[3561,3670,"eat itself alive?"],[3703,3887,"Best show in town."],[3895,4029,"I barely lifted a finger"],[4041,4200,"and walked off with your company."],[4225,4300,"Honestly."],[4404,4487,"Thanks, Scarlett."],[4529,4612,"Without you,"],[4675,4808,"this deal doesn't happen."],[4829,4950,"You're so shameless."],[5009,5167,"You made me do this."],[5217,5388,"I loved you and you chose"],[5472,5747,"some grease stained nobody"],[5747,5839,"over me?"],[5864,6056,"Do you realize how much this makes me"],[6056,6126,"hate you?"],[6160,6348,"Give me back my company."],[6402,6464,"Sure."],[6569,6669,"Under one condition."],[6773,6844,"You're mine."],[6902,6986,"For one month."],[7073,7223,"And you do whatever I say."]],"71":[[208,350,"She will never be yours."],[350,500,"You hit me."],[546,617,"Yeah, I did."],[884,1017,"And now I've hit you twice."],[1063,1142,"Get in here!"],[1151,1217,"Guards!"],[1263,1338,"Tear him apart!"],[1338,1388,"Kill him!"],[1388,1472,"Connor!"],[1472,1568,"Daddy!"],[1576,1651,"Touch him!"],[1672,1785,"Try it!"],[2389,2540,"Grandpa! Grandpa!"],[2544,2681,"There's my girl."],[2719,2840,"I missed you."],[2944,3111,"Grandpa, those bad people want to"],[3111,3232,"hurt daddy."],[3495,3632,"You've got guts."],[3674,3916,"If my granddaughter hadn't called,"],[3966,4166,"I would have never known anyone in this"],[4166,4366,"country who was dumb enough"],[4429,4721,"to lay a finger on my family."]],"72":[[0,70,"Mr. Reed,"],[70,233,"it's an honor to have you here."],[262,479,"But this is our turf."],[479,588,"No need to start a war"],[588,767,"over some bastard, right?"],[825,975,"I've stared down presidents."],[1042,1209,"Toppled their governments."],[1292,1459,"And they've never dared"],[1488,1685,"lay a finger on my family."],[1872,2252,"You just became the first."],[2882,2986,"Family?"],[3090,3174,"This kid"],[3224,3315,"belongs to this woman"],[3315,3445,"and that loser."],[3499,3611,"How is that your family?"],[3682,3899,"This is Summer,"],[3949,4095,"my granddaughter."],[4250,4337,"And Connor?"]],"73":[[0,66,"And Connor"],[237,321,"is my son."],[638,692,"Connor,"],[788,905,"are you really his son?"],[963,1088,"Mr. Reed, you're joking."],[1205,1301,"Please tell me you're joking."],[1347,1555,"You really don't quit."],[1764,1801,"Take him!"],[1860,1997,"No, this is impossible."],[2081,2181,"Hey, hey,"],[2181,2277,"say something!"],[2277,2360,"What is he to you?"],[2389,2498,"Is he really your father?"],[2619,2731,"Connor, what is he to you?"],[3161,3224,"Hi, Dad."]],"74":[[16,54,"No."],[104,158,"We're dead."],[266,396,"The Whitmores are finished."],[437,675,"Take this trash out of here."],[700,850,"As for the Whitmores,"],[917,1034,"pull every lever."],[1084,1146,"Permits,"],[1267,1430,"shipping lanes, credit."],[1430,1680,"Burn them to the ground!"],[1714,1780,"Yes, sir!"],[1810,1864,"No!"],[1885,1981,"Scarlett, please!"],[1981,2047,"Help me!"],[2173,2302,"You stubborn punk."],[2327,2477,"After all these years,"],[2531,2648,"you say it out loud."],[2690,2802,"Don't get all sentimental,"],[2802,2882,"old man."],[2882,3057,"I'm only admitting it because"],[3078,3265,"you actually showed up for my daughter."],[3324,3503,"Your mouth on you hasn't changed."],[3545,3632,"Mr. Reed,"],[3695,3832,"are you really Connor's father?"],[3832,3999,"You can stop the Mr. Reed."],[4120,4245,"We're family now."],[4362,4416,"Try..."],[4612,4650,"Dad."],[4733,4796,"Okay."],[4875,4950,"Dad."],[4984,5046,"See?"],[5134,5321,"She's got more sense than you."],[5321,5580,"Scarlett, I'm your father."],[5605,5814,"Please, forgive me."],[5910,6035,"You made this mess."],[6085,6206,"You live with it."],[7144,7236,"Besides,"],[7311,7469,"I have a new family now."],[7907,8008,"Woo!"],[8333,8454,"All right, my little princess."],[8491,8612,"We're going home, OK?"],[8692,8762,"Come on."],[8917,8988,"Big smile!"]]}