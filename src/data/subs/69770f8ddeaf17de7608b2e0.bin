e God damn hero"],[2085,2202,"as if you're not the one"],[2202,2360,"pulling all the strings."],[2394,2489,"And that woman,"],[2544,2627,"your ex."],[2660,2894,"She was in your room in a robe"],[2923,3040,"after whatever bullshit"],[3040,3119,"last night was,"],[3119,3224,"and you expect me"],[3224,3340,"to just follow you around"],[3340,3474,"like some lost little puppy?"],[3795,3849,"No!"],[4066,4233,"You say that you're trying to"],[4233,4375,"protect me and fine, fine,"],[4375,4483,"maybe you have been."],[4550,4700,"But you're also playing some game"],[4700,4833,"that I don't understand"],[4833,4963,"and it hurts."],[5034,5100,"Annie, just-"],[5138,5255,"I don't want to play anymore."],[5338,5526,"I lose every time."],[5780,5889,"I can't do this."],[6051,6156,"I'll send you divorce papers"],[6156,6239,"in the morning."],[6314,6364,"We're done."],[6389,6510,"Annie, please, you"],[6510,6589,"don't understand. - No!"],[6664,6781,"I don't wanna understand."],[6990,7102,"Don't try to follow me."],[7161,7282,"I don't want you near me."],[8750,8808,"Annie."]],"58":[[1071,1151,"No, no."],[1188,1338,"No, no, no, no, no."],[2577,2640,"You?"],[2923,3132,"Yes, me."],[3428,3712,"And you really fucked up this time."],[3791,3908,"Made it so much worse"],[3908,4074,"than it had to be, but"],[4191,4312,"don't worry, darling."],[4350,4446,"We'll make it happen."],[4446,4575,"One way or another."],[4979,5080,"Look at her."],[5155,5292,"The perfect bride."],[5463,5530,"Finally."],[6460,6564,"Hello, sister."],[6660,6777,"I'm the videographer."],[6810,6952,"In case anyone needs proof"],[6956,7069,"of the happy union."],[7336,7461,"Took long enough, didn't it?"],[7511,7620,"All the games,"],[7653,7791,"all the running around."],[7978,8066,"But now you can't run away"],[8066,8187,"from me anymore, Annie."],[8199,8266,"Fuck you!"],[8279,8324,"Oh."],[8470,8546,"Ohh."],[8600,8733,"She'll thank me later."],[8771,8888,"Now, the papers."]],"59":[[850,959,"Jesus Christ."],[984,1142,"All this money, all this power."],[1176,1359,"And I couldn't save the one thing"],[1359,1463,"I really cared about,"],[1497,1547,"her."],[1922,2047,"We've got it. Time stamps,"],[2047,2164,"data trails, everything."],[2164,2289,"It's airtight."],[2389,2456,"Finally."],[2915,3011,"Where are you, Annie?"],[4083,4195,"I'm coming for you, Annie."],[4216,4329,"I'll explain everything."]],"60":[[771,930,"You're gonna sign the annulment."],[975,1080,"And then,"],[1080,1259,"you're gonna marry Christian."],[1359,1472,"And once you do,"],[1497,1685,"everything will be ours,"],[1685,1755,"forever."],[1835,1951,"Logan will never sign."],[2010,2127,"Oh, you don't think so?"],[2193,2281,"He will drop you"],[2281,2414,"as soon as it's convenient."],[2460,2540,"You're nothing to him."],[2660,2831,"Just a stripper."],[3194,3257,"Now."],[3516,3586,"Sign."]],"61":[[187,258,"Sign."],[817,942,"Fuck you!"],[1351,1668,"Alright, let's play a little game."],[1801,1864,"Oh."],[2427,2531,"All you have to do is"],[2531,2673,"sign to make it stop."],[3153,3428,"I would rather die than marry you!"],[3941,4062,"Well, that can be arranged."]],"62":[[700,779,"Something's wrong."],[1451,1505,"Bring the team."],[1555,1672,"Something doesn't feel right."],[2544,2698,"You're just gonna let her die?"],[2727,2890,"Yeah, if we must."],[2890,3065,"Grow some fucking balls, Christian."],[3465,3524,"What the hell?"],[3649,3762,"This isn't funny!"],[4325,4425,"Annie!"]],"63":[[905,1059,"You think you can take her from me?"],[1368,1426,"Annie."],[1522,1584,"Annie."],[1597,1722,"Annie, what did they do to you?"],[1872,1935,"No!"],[1943,2043,"Get lost!"],[2064,2127,"Fuck..."],[2206,2369,"How did you find me?"],[2414,2527,"How did you know?"],[2811,2940,"Who are these people?"],[3282,3545,"Who the hell do you think you are, huh?"],[3566,3661,"What you think this little"],[3661,3883,"stunt of yours makes you powerful, huh?"],[3883,3970,"You're nothing"],[3970,4158,"but a thug in a leather jacket!"],[4266,4308,"Yeah!"],[4362,4446,"You're just the same rat"],[4446,4550,"from high school!"],[4567,4700,"Nothing's changed."],[5005,5130,"Take them to the police station."],[5163,5276,"Tell them Logan Dane sent them."],[5288,5330,"No."],[5355,5447,"They already have the evidence."],[5480,5522,"Mom!"],[5522,5572,"Help!"],[5572,5643,"You don't know"],[5643,5747,"who you're messing with!"],[6210,6289,"You're safe now."],[6402,6481,"The video's gone,"],[6481,6535,"forever."]],"64":[[788,834,"Annie."],[971,1067,"Christian's in prison."],[1180,1284,"Your step-family too."],[1338,1476,"The video's been deleted forever."],[1514,1672,"Don't play with me, please."],[1839,1939,"I can't take it."],[2043,2185,"No games, Annie."],[2293,2414,"I have something to show you."],[2552,2690,"Do you think you can get up?"],[3536,3661,"All of this is yours?"],[3832,3941,"You mean yours?"],[4108,4145,"No."],[4408,4475,"It's yours, Annie."],[4650,4746,"And..."],[4821,4909,"I have one more thing."]],"65":[[734,809,"Dad!"],[1735,1780,"Annie."],[1860,2052,"I've missed you so much."],[2252,2456,"Dad, you're awake?"],[2477,2548,"Yes."],[2740,2852,"Logan over here,"],[2890,3028,"he found the doctors."],[3078,3199,"They took care of me."],[3586,3762,"Is this, is this real?"]],"66":[[788,1063,"Everything I do is for you, Annie."],[1151,1380,"Every deal, every fight,"],[1426,1518,"every secret,"],[1639,1722,"was all for you."],[1743,1818,"Always for you."],[1947,2031,"I've loved you"],[2031,2143,"from the very beginning."],[2302,2456,"But I didn't think that I deserved you."],[2531,2823,"Not until I fixed this mess."],[2940,3057,"But it was always you, Annie."],[3203,3319,"Since the very beginning."],[3453,3549,"Since we were in high school,"],[3549,3724,"sitting in that storage closet."],[3845,4049,"Watching you doodle little hearts."],[4408,4512,"You were so kind."],[4596,4758,"And the world was so cruel to you."],[4846,4975,"It was always you, Annie."],[5271,5347,"Always."],[6064,6197,"And the marriage?"],[6339,6456,"It's convenient."],[6510,6556,"Oh?"],[6748,6923,"I just wanted to be married to you."],[7023,7152,"I just wanted to keep you safe."],[7257,7374,"Will you believe me now?"],[7661,7736,"Show me."],[9042,9300,"You really always loved me?"],[9392,9555,"From the very beginning?"],[9634,9718,"Always."],[9943,10114,"Then why did you let me"],[10114,10268,"spiral for nearly a decade"],[10293,10560,"while you were off becoming Batman?"],[10760,10852,"You asshole."]],"67":[[100,166,"Mr. Dane!"],[212,308,"You look great tonight!"],[308,383,"You look great!"],[1693,1785,"Ladies and gentlemen."],[1851,1947,"Thank you all for coming"],[1947,2106,"to celebrate Halo's new beginning."],[2160,2277,"I would like to introduce you all"],[2277,2406,"to Halo's newest owner."],[2481,2673,"Owner of my heart, my wife,"],[2781,2902,"Ms. Annie Dane."],[3382,3461,"Holy shit."],[3461,3557,"She really did it."],[3557,3674,"Mm-hmm. She married him."],[3674,3837,"Well, I'll be damned."],[4262,4354,"There's no shame"],[4354,4491,"in dancing for a living."],[4542,4608,"But tonight,"],[4667,4888,"we dance for ourselves."],[4946,5096,"Woo!"],[5096,5201,"Yeah!"],[5388,5580,"I know a lot of people asked,"],[5618,5768,"why I bought Halo."],[6047,6156,"Now you know why."],[6185,6297,"Woo!"],[6297,6406,"Nice."],[6443,6560,"So cool."],[6731,6877,"You want a little dance?"],[6986,7119,"You wouldn't dare."],[7328,7399,"You know,"],[7482,7649,"I normally dance for tips."],[7703,7887,"But tonight I dance for myself,"],[7945,8016,"and for you."],[8183,8324,"You always were an angel."],[8637,8925,"Woo!"]]}