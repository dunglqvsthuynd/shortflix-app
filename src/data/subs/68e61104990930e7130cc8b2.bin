{"1":[[644,764,"Oh, wow."],[820,932,"Daniel's never done"],[932,1120,"anything like this for me before."],[2096,2355,"Oh, Daniel. I..."],[2372,2564,"I appreciate the effort, but I'm—"],[3144,3228,"Ethan?"],[3616,3736,"Sis, this is, um—"],[3796,3896,"You misunderstand."],[3924,4060,"This can't be happening."],[4108,4365,"Yes, I'm sleeping with your brother."],[4456,4576,"Our wedding is coming up."],[4576,4728,"You said I was the only one."],[5056,5188,"Oh, what are we gonna do?"],[5252,5388,"What will my grandmother,"],[5388,5472,"the Queen, think?"],[5576,5661,"We've been engaged"],[5661,5836,"since before we were even born."],[5924,6048,"Calm down, flower."],[6048,6141,"There's no need for the hysterics."],[6141,6224,"The wedding's still on."],[6224,6396,"You think I can forgive this?"],[6532,6758,"Please… cover yourself."],[6956,7128,"You want to be Queen, right?"],[7252,7364,"Well, I'm your only chance."],[7412,7489,"You don't have time"],[7489,7563,"to find another groom"],[7563,7692,"before the coronation."],[7932,8016,"Come on, love."],[8016,8120,"Let's give her some chance"],[8120,8252,"to process this."],[8560,8680,"If you think about it…"],[8772,8843,"It's actually a good thing"],[8843,8954,"you found out."],[8967,9068,"At least this way,"],[9068,9206,"we won't have to hide anymore."],[9660,9772,"Chin chin."]],"2":[[3404,3542,"What is all this commotion,"],[3542,3640,"young lady?"],[4044,4260,"Mum, how did you get in here?"],[4260,4360,"I locked the door."],[4408,4508,"It was open."],[4556,4772,"And you were screaming so loudly."],[4844,4956,"Very careless."],[5012,5148,"With servants around…"],[5240,5376,"what will people think?"],[5424,5552,"And what will people think"],[5552,5636,"when they find out"],[5636,5797,"that my fiancé is sleeping"],[5797,5896,"with my brother?"],[6072,6157,"I told Ethan"],[6157,6344,"that this unnatural obsession with men"],[6344,6480,"would lead nowhere good."],[6564,6790,"I'm sorry your fiancé chose him…"],[6820,6940,"and not you."],[7176,7360,"Please just leave me."],[7360,7460,"I want to be alone."],[7584,7710,"I promise I'll keep myself"],[7710,7800,"under control."],[7912,8012,"As you wish."]],"3":[[0,201,"Your injuries are not serious."],[320,404,"You were lucky"],[404,504,"you had a flowerbed"],[504,604,"under your window."],[972,1056,"My daughter was"],[1056,1224,"in a depressed state."],[1312,1472,"She even tore her wedding dress."],[1580,1736,"She's too young to be Queen."],[1800,2004,"Someone pushed me…"],[2136,2312,"Seeing enemies everywhere…"],[2608,2740,"What if Eliza is right?"],[2852,2985,"We can't take the risk."],[2985,3204,"We need to hire a professional bodyguard."],[3420,3643,"Very well. If you trust her…"],[3736,3936,"I will find the best of the best."],[7180,7280,"Alright, gentlemen."],[7372,7494,"Please remove your shirts."]],"4":[[252,580,"Darling, could I have a word?"],[844,944,"Wait there."],[1392,1492,"What are you doing?"],[1556,1684,"What does it look like?"],[1792,1907,"I'm finding a bodyguard…"],[1932,2042,"for my future wife."],[2204,2420,"Daniel, I barely recognise you."],[2420,2574,"What happened"],[2574,2773,"to that gentle fiancé"],[2773,2919,"to whom I once said yes?"],[2996,3108,"He never existed."],[3176,3344,"It was all an act, Eliza."],[3428,3528,"See? This…"],[3696,3796,"This is the real me."],[4064,4293,"Now, if you want to be my wife,"],[4293,4421,"you'd better get used to this."],[4880,4980,"Is there something else?"],[5124,5252,"No. That's all."],[5308,5460,"Thank you for clarifying."],[5516,5765,"Now, please excuse me…"],[5900,6000,"Alright, lads."],[6148,6260,"Let's get those quads out."],[6360,6480,"My wife's bodyguard"],[6480,6712,"must have very, very strong legs."],[7300,7454,"I need to get away from here."],[7520,7632,"Just for a day."],[9710,9836,"Need a hand?"]],"5":[[116,376,"No. No. I've got it under control."],[376,472,"Thank you."],[510,656,"Doesn't look that way."],[656,776,"Climbing a gate in a dress?"],[860,988,"Not the best idea."],[1044,1242,"Just mind your own business,"],[1242,1340,"please."],[1424,1524,"As you wish."],[1984,2120,"Wait, please."],[2352,2584,"Sorry, did you say something?"],[2700,2810,"I think I'm stuck."],[2932,3065,"I thought you had everything under control."],[3065,3244,"I mean, that's what you said, right?"],[3244,3356,"Well, I was mistaken."],[3428,3532,"Now, help me down."],[3724,3808,"Please."]],"6":[[724,816,"It's rather improper"],[816,961,"to stare so intently at someone"],[961,1068,"you don't know."],[1152,1244,"You were staring too."],[1452,1572,"Who are you, anyway?"],[1572,1710,"I've never seen you around here before."],[1776,1940,"Never seen you before here either."],[2172,2332,"You must be the new driver…"],[2396,2500,"How on earth did you get hired"],[2500,2616,"with manners like that?"],[2664,2860,"You must drive brilliantly."],[2940,3050,"And who might you be?"],[3108,3192,"A maid?"],[3254,3392,"Yes, actually."],[3440,3532,"And now, I must get back"],[3532,3632,"to cleaning the palace."],[3632,3744,"So, goodbye."],[4412,4513,"That's twice now"],[4513,4646,"you've been pressed up against me."],[4699,4779,"Could it be"],[4779,4894,"that you find me so alluring?"],[4920,5052,"I don't find rudeness alluring"],[5052,5136,"in any man."],[5820,6033,"Damn it. Where did you come from"],[6033,6148,"to torment me like this?"]],"7":[[84,228,"So, is this all of them?"],[254,356,"Well, there was one more,"],[356,512,"recommended by one of our staff,"],[512,696,"but he hasn't arrived."],[1168,1288,"Where's Daniel?"],[1420,1512,"He was called away."],[1560,1685,"Something to do with the surprise"],[1685,1776,"for your wedding."],[1832,1960,"Well, shall we get on?"],[2188,2408,"Apologies for being late. A maid—"],[2408,2626,"It doesn't matter. You're late."],[2644,2772,"So, you've lost your chance."],[2820,3016,"I agree. How am I supposed"],[3016,3136,"to entrust my life—"],[3136,3336,"the princess' life—"],[3384,3560,"to someone who won't even be punctual?"],[3585,3692,"I wouldn't've been late"],[3692,3882,"if a certain maid hadn't pushed me"],[3882,3950,"in the mud."],[3950,4056,"We aren't interested"],[4056,4244,"in your escapades. You heard her."],[4292,4492,"This is a fair selection process."],[4492,4589,"And I think this gentleman"],[4589,4740,"deserves a chance."],[4788,4920,"There'll be no more discussion."],[5044,5256,"Well, let's get started."]],"8":[[3280,3380,"I'm tired."],[3380,3529,"After the attempt on my life,"],[3529,3628,"I need more rest."],[5470,5602,"I've saved you for the third time"],[5602,5688,"in just a few hours."],[5744,5851,"Is there really nobody better"],[5851,5940,"than me?"]],"9":[[228,312,"How can you be"],[312,424,"so sure of yourself?"],[560,675,"Not one of your"],[675,786,"so-called best candidates"],[786,860,"moved a muscle"],[860,1000,"when your daughter was in danger."],[1076,1212,"Except for—"],[1268,1404,"My name is Derek Hill."],[1452,1580,"Thank you, Mr. Hill."],[1580,1704,"Consider yourself hired."],[2148,2292,"Do you have any objections?"],[2424,2600,"No. It seems like"],[2600,2800,"Mr. Hill is quite a professional."],[2848,3032,"Excellent. Then we're all in agreement."],[3088,3228,"Because you and Mr. Hill"],[3228,3392,"will be together 24/7."],[3500,3592,"But, Your Majesty—"],[3592,3756,"No arguing, Eliza."],[3804,3996,"You will do as Mr. Hill says"],[3996,4124,"for your own safety."],[4172,4320,"No exceptions."],[4740,4832,"The head of security said"],[4832,4972,"you'd be an ideal candidate."],[4972,5072,"And he wasn't wrong."],[5120,5245,"Please escort my granddaughter"],[5245,5352,"to her room, where you'll make"],[5352,5512,"your next moves."],[6844,7064,"I know where my own bedroom is."],[7732,7996,"Thank you, Mr. Hill. You can go now."],[8536,8672,"Are you even listening to me?"],[8768,8880,"No need to shout, princess."],[8928,9096,"I'm responsible for your safety now."],[9144,9316,"If I must, we'll even sleep"],[9316,9408,"in the same room."],[9540,9712,"I have a fiancé."],[9712,9824,"He won't like that."],[9872,9972,"He doesn't need to know."]],"10":[[48,225,"Are you planning to make advances"],[225,329,"on me?"],[648,780,"You're imagining things, princess."],[996,1096,"You're just a client to me."],[1220,1332,"And I do my job well."],[1440,1660,"Well, you won't be making it"],[1660,1780,"in this room without permission"],[1780,1880,"from the head of security"],[1880,1964,"and Her Majesty."],[2176,2268,"Then I'll see you at 8:00…"],[2316,2400,"tomorrow morning."],[5592,5752,"What are you doing in here?"],[5800,5920,"How did you get in here?"]],"11":[[80,260,"While you slept through our appointment,"],[300,432,"I sent you a reminder."],[496,588,"Luckily,"],[588,748,"one of the actual maids let me in."],[832,952,"At least they can follow orders."],[1000,1098,"Is that my phone?"],[1324,1481,"Is it? Because I didn't see it"],[1481,1620,"on security's official register."],[1952,2192,"I just needed a bit of privacy."],[2288,2431,"They bug everything in here."],[2484,2716,"Eliza, given your current situation,"],[2716,2852,"you can't be that careless."],[2908,3028,"Someone tried to kill you."],[3188,3348,"I know. You're right."],[3620,3790,"That phone's the only private thing"],[3790,3891,"that I have left."],[3976,4212,"Please just give it back to me."],[4524,4740,"I promise I'll be more careful."],[5544,5704,"Think of it as my welcome gift."],[5704,5817,"But…"],[5817,5986,"total honesty from here on."],[6030,6176,"Anything else I should know about?"],[6344,6444,"What the—"],[6536,6835,"Eliza, why are you dressed like that?"],[6855,7012,"Looks like I've walked into a cheap brothel"],[7012,7104,"by mistake!"]],"12":[[0,137,"Sir,"],[137,301,"watch how you talk to the future queen."],[632,908,"Sorry? Who do you think you are?"],[964,1212,"I'm her new bodyguard, Derek Hill."],[1232,1315,"Oh."],[1380,1516,"Sorry. Hi, Derek."],[1564,1688,"I'm the future king…"],[1752,1880,"and her future husband."],[1880,2048,"So, actually, if it's okay with you…"],[2096,2224,"I'll speak to the future queen"],[2224,2352,"however I'd like to."],[2472,2572,"Now, get out."],[3032,3312,"Derek, please leave us."],[3312,3432,"You heard her."],[3772,3908,"I'll be right outside the door."],[3956,4040,"Good boy."],[6112,6248,"Daniel, what do you want from me?"]],"13":[[168,304,"So, there's actually something"],[304,512,"I've been wanting to talk to you about."],[588,688,"Get out. I need a word"],[688,804,"with Her Majesty."],[804,924,"But I—"],[924,1036,"I said, \"Get out\"."],[1868,2103,"Mum, Eliza isn't threatened"],[2103,2252,"by anyone but herself."],[2252,2388,"I saw her state that day."],[2452,2680,"She cannot handle responsibility."],[2728,2896,"And you would suggest?"],[3032,3164,"Rescind your decision"],[3164,3280,"and reinstate my right"],[3280,3366,"to the throne."],[3408,3536,"I'd make a much better queen"],[3536,3660,"than Eliza."],[3660,3772,"Jacqueline, you had an affair"],[3772,3908,"with Eliza's father."],[3908,4036,"And then you married that actor."],[4084,4266,"Well, only after Eliza's father died."],[4266,4372,"Doesn't matter."],[4372,4556,"You broke the rules."],[4577,4764,"Well, you could've made an exception,"],[4764,4958,"but you care more about public opinion"],[4968,5200,"than your own child's happiness."],[5300,5464,"This conversation is over."],[5464,5567,"You know the way out."],[6376,6584,"I won't give up so easily. Come on."],[7252,7420,"You've got good taste in men."],[7741,7815,"If it weren't for Ethan,"],[7815,7980,"I'd have fought you for that bodyguard."],[8468,8568,"What are you doing?"],[8760,8892,"I'm just confirming…"],[8940,9076,"how unattractive…"],[9192,9284,"you truly are."],[10056,10242,"Why do you hate me so much?"],[10320,10439,"Because my parents…"],[10492,10592,"forced you on me."],[10805,11063,"And I can't wait to be a widower."]],"14":[[204,340,"Oh, by the way…"],[396,530,"Ethan and I are going away"],[530,608,"for the weekend."],[656,857,"But we have a press conference."],[857,956,"You're the future queen."],[1040,1140,"Figure that out!"],[2108,2248,"Princess, are you alright?"],[2248,2340,"Did he hurt you?"],[2388,2472,"Just say the word."],[2472,2704,"I'm fine! Mr Hill, please, next time,"],[2704,2856,"knock before barging in."],[2904,3124,"Just give me ten minutes"],[3124,3224,"to pull myself together."],[3476,3576,"Alright."],[3744,3844,"And I'll, um—"],[3944,4064,"I'll, uh—"],[4064,4196,"I'll check the balcony"],[4196,4316,"from which you were pushed."],[4440,4540,"Why?"],[4575,4776,"The police have already examined it."],[4876,4968,"So what?"],[5010,5201,"The attacker hasn't been found. I mean..."],[5220,5380,"I swear, I'm the only one in this palace"],[5380,5496,"who's actually worried about that."],[8180,8316,"You just have to arrange it for me…"],[9212,9312,"What the fuck?"]],"15":[[300,437,"Well said."],[470,696,"That is my fiancé and my brother."],[1032,1132,"How long have you known?"],[1216,1367,"Since the day of the attack."],[1516,1616,"I'm sorry for you."],[1784,1936,"I don't need your pity."],[2104,2304,"It's sympathy, not pity."],[2468,2580,"You don't deserve this."],[2628,2740,"How do you bear it?"],[2740,2895,"It's fine."],[2895,3040,"They've trained me for this"],[3040,3124,"since I was little."],[3124,3224,"No, it's not fine."],[3336,3436,"When was the last time"],[3436,3521,"someone actually asked you"],[3521,3624,"how you feel?"],[3708,3889,"I can't remember."],[3940,4180,"Future queens handle everything themselves."],[4520,4620,"Look at me."]],"16":[[92,192,"So, I'm asking."],[292,452,"How are you feeling, my princess?"],[676,768,"You must try again!"],[816,968,"It didn't work the first time."],[968,1104,"Try again. Prove your love to me."],[1196,1344,"If anyone finds out about this,"],[1344,1479,"my life is ruined."],[1479,1576,"Look, I hate her too,"],[1576,1720,"but we're not doing this now."],[1720,1852,"Let's wait a month or two."],[1984,2112,"I'm done waiting, Ethan!"],[2344,2456,"I hate this family!"],[3116,3212,"Derek…"],[3268,3354,"My brother's no angel,"],[3354,3490,"but he's not a murderer either."]],"17":[[268,428,"I don't trust anyone in this place."],[476,588,"Starting tomorrow,"],[588,710,"you're learning self-defence."],[764,888,"And you're not going anywhere"],[888,980,"without telling me."],[1028,1192,"What? Not even the bathroom?"],[1264,1364,"Not even there."],[1504,1648,"Perhaps you'll install cameras"],[1648,1760,"everywhere next?"],[1767,1953,"If necessary, yes."],[2156,2316,"You can't be serious."],[2596,2800,"How did you change so quickly?"],[2884,2968,"A minute ago,"],[2968,3088,"you were someone else."],[3208,3344,"I was just doing my job."],[3432,3541,"Oh."],[3636,3844,"I thought we might be friends."],[3844,3972,"I never get emotionally involved"],[3972,4064,"with a client."],[4356,4552,"Understood. Thank you, Mr. Hill."],[4716,4844,"Just carry on being yourself."],[4928,5112,"Good, dull, aristocratic."],[5260,5333,"And stay in your room"],[5333,5492,"until I give you permission to leave."],[6060,6264,"I'll show you who's dull."]],"18":[[248,360,"What do people wear to clubs"],[360,444,"these days?"],[1372,1532,"My mother's wardrobe…"],[1728,1925,"She must have something daring."],[3512,3636,"Wasn't expecting that."],[3748,3934,"But I think it suits me."],[7916,8100,"Miss, you've got no invitation."],[8100,8192,"You have to wait."],[8328,8512,"Don't you know who I am?"],[8596,8696,"No, should I?"],[8872,8984,"I'm short on time."],[8984,9100,"Isn't there any way I can just—"],[9156,9405,"There're 50 people like you waiting."],[9430,9532,"Really nothing I can do."],[9635,9765,"Chin up, baby."],[9803,9911,"I'll get us in."],[10064,10264,"Really? Thank you."],[10312,10452,"You're such a gentleman."],[10452,10564,"Yeah, real gent."],[10744,10864,"Have a good night, Mr. Fury."],[11096,11272,"You'd be better off going home."]],"19":[[1436,1553,"Jack, you won't believe this,"],[1553,1708,"but this is my first time"],[1708,1800,"drinking alcohol."],[1884,1988,"Such a funny feeling."],[1988,2184,"It's like I'm floating or something."],[2232,2372,"Yeah. Um, another round, please."]],"20":[[176,304,"Jack, I really like you."],[304,448,"You're such a nice guy."],[596,708,"Let's be friends."],[708,860,"You can be my first best friend."],[1136,1272,"You wanna see the VIP lounge?"],[1404,1504,"Only a select few get in."],[1552,1724,"What's in there, some sort of show?"],[1876,2004,"That is one way to put it."],[2132,2232,"Another first."],[2416,2567,"Today is the day of firsts."],[2728,2869,"I'm so glad I met you."],[2912,3110,"Yeah, let's go. Enough talk."]],"21":[[1040,1232,"Where are the performers?"],[1232,1384,"The stage?"],[1384,1600,"The props? The show?"],[1856,1968,"The show is about to start."],[2076,2176,"We're the main act."],[2340,2440,"Props are there."],[2912,3068,"Jack, I think"],[3068,3208,"you've got the wrong idea."],[3932,4181,"Help! Help! Help! Somebody!"],[4181,4339,"Can you hear me? Help!"],[4339,4456,"Shh. Don't bother."],[4490,4684,"The door's locked. I have the only key."],[4816,4900,"The music's too loud"],[4900,5000,"for anyone to hear you."],[5176,5340,"Is it money that you want?"],[5452,5600,"My family has plenty."],[5776,5912,"I'm a princess."],[5960,6088,"That must mean I'm a king."],[6256,6402,"No way a girl with money would be"],[6402,6508,"in a dress like that."]],"22":[[0,69,"With the amount of money"],[69,184,"I spent on you tonight…"],[244,376,"I might even leave you a tip."],[688,772,"I've seen the way"],[772,856,"you looked at me before."],[996,1108,"I know you want me."],[1900,2004,"Can you walk?"],[2988,3100,"You'll regret that."],[3100,3198,"Jack Fury always gets"],[3198,3297,"his own way."],[3820,4064,"-Yes, sir. -Yeah. Check the cameras."],[4064,4148,"I wanna know everything"],[4148,4290,"about that girl I came in with."],[4290,4436,"Got it. We'll begin the check."]],"23":[[244,356,"Eliza, what were you thinking?"],[376,511,"I nearly went mad trying to find you."],[511,633,"What if I hadn't arrived in time?"],[633,731,"I'm sorry."],[870,1040,"Does anyone know that I'm gone?"],[1124,1256,"No, I didn't tell anyone."],[1664,1764,"You sure you're alright?"],[1864,1956,"He didn't manage to—"],[1956,2088,"No, he didn't."],[2160,2311,"I'm so pathetic."],[2412,2524,"I just wanted to prove"],[2524,2616,"that I'm not dull,"],[2616,2835,"that I can be interesting…"],[2928,3136,"I'm just so fed up with the palace"],[3136,3304,"and all my responsibilities."],[4172,4309,"All because of the words I said?"],[4416,4516,"Don't rub it in."],[4572,4716,"I already feel bad enough as it is."],[6040,6140,"Where are we going?"],[6140,6276,"This isn't the way to the palace."]],"24":[[528,628,"Where are we going?"],[628,776,"This isn't the way to the palace."],[804,904,"Calm down."],[904,1050,"You had a lot to drink, alright..."],[1080,1208,"and nothing to eat."],[1270,1312,"In this state,"],[1312,1424,"you probably shouldn't go back"],[1424,1528,"to the palace just yet."],[1660,1904,"You're right. As always."],[4156,4407,"I have never eaten anything like this before."],[4572,4700,"Well, it's the best hangover cure."],[5200,5302,"Um..."],[5336,5428,"So, from tomorrow,"],[5428,5600,"we're starting self-defence training."],[5812,6092,"Alright. I'll do as you say now."],[6200,6300,"I've learnt my lesson."],[7572,7748,"See? Isn't life with me better"],[7748,7928,"when you're more obedient?"]],"25":[[1016,1096,"What?"],[1096,1268,"It's the most comfortable outfit I have."],[1352,1499,"Right. Well, don't say"],[1499,1580,"I didn't warn you."],[1724,1808,"Get on."],[2656,2768,"Let's see how fit you are."],[2876,2976,"Start crawling."],[3076,3280,"Right now? In this?"],[3428,3534,"I am a princess"],[3534,3595,"and the future queen."],[3595,3760,"I'm not crawling in the dirt."],[4244,4344,"Too much talk."],[4408,4540,"Remember our first meeting?"],[5212,5312,"This is payback."]],"26":[[856,1064,"Not bad for a princess."],[1216,1320,"But overall, still weak."],[1468,1564,"Since you're so clever,"],[1582,1700,"why don't you show me how it's done."],[1700,1832,"As you wish, Your Highness."],[7260,7388,"Twenty reps in a minute?"],[7388,7564,"Not exactly impressive."],[7688,7772,"Princess,"],[7772,7888,"I saw the way you looked at me."],[8312,8536,"You are rubbish at lying."],[10228,10328,"How did that happen?"]],"27":[[92,264,"Please tell me."],[408,520,"It's not something I'm proud of."],[632,820,"Derek, everyone makes mistakes."],[820,976,"You can't punish yourself forever."],[1148,1232,"People don't die"],[1232,1332,"from simple mistakes."],[1508,1628,"C'mon, princess. It's getting cold."],[3280,3392,"What the—"],[4620,4852,"Mr. Hill, come here immediately."]],"28":[[668,788,"Where did you get this?"],[788,888,"I was about to ask you"],[888,972,"the same question."],[1076,1160,"I swear."],[1160,1296,"I had nothing to do with this."],[1380,1492,"What a coincidence."],[1492,1592,"First, you threatened"],[1592,1676,"to install cameras,"],[1676,1836,"and then I find one in my bedroom."],[1884,2092,"Eliza, if I installed it,"],[2092,2276,"you'd never find it. Trust me."],[2468,2604,"Well, then who did?"],[3400,3656,"Well, my sister's no saint either."],[4500,4584,"Damn that bodyguard."],[4584,4668,"He ruins everything."],[4932,5024,"Someone's very interested"],[5024,5140,"in your private life, princess."],[5348,5556,"You need to learn how to use a gun."]],"29":[[1252,1388,"I'm hopeless at this."],[3232,3392,"Don't let anyone steal your spark."]],"30":[[432,528,"Forgive me."],[596,696,"It shouldn't have happened."],[828,956,"It's my mistake."],[956,1080,"Especially after what that guy did"],[1080,1192,"to you in the club."],[1284,1416,"But I didn't mind."],[1572,1672,"You don't understand."],[1976,2076,"It's getting dark."],[2124,2224,"We should head back."],[3352,3648,"Derek, we need to talk!"],[3648,3756,"There's nothing to talk about."],[3804,3972,"I refuse to believe that I'm the only one"],[3972,4068,"who felt something."],[4196,4288,"I know you."],[4520,4648,"You know nothing about me."],[5188,5308,"Let's just return home."],[5356,5460,"No!"],[5724,5844,"Have you lost your mind?"]],"31":[[48,168,"Bloody hell! Where are the keys?"],[360,496,"Fine! Go on!"],[544,668,"What do you possibly have to say?"],[716,852,"The silly little aristocratic girl"],[852,980,"who falls for her bodyguard."],[1120,1316,"How cliché and dull."],[1444,1588,"You kissed me first."],[1684,1784,"Call it a momentary lapse."],[1884,2028,"You're young and pretty."],[2144,2240,"That's it."],[2404,2532,"Well, screw you!"],[2532,2712,"Oh, how the princess' vocabulary"],[2712,2832,"has changed."],[3028,3188,"And what are we gonna do now?"],[4036,4172,"Congratulations, princess."],[4220,4320,"No signal."],[4452,4600,"Looks like we're sleeping in the car."]],"32":[[680,840,"I can't believe it's the only option."],[1232,1368,"Well, come on. Say something!"],[1572,1672,"If it weren't for you, princess,"],[1672,1812,"we wouldn't be in this mess."],[2852,2964,"Can we turn the heating on?"],[3288,3528,"Eliza, the car has no power."],[3636,3736,"No heating."],[5340,5468,"You can lie back here with me."],[5864,5976,"I'm not sure"],[5976,6104,"that would be appropriate."],[6256,6356,"It's more inappropriate"],[6356,6484,"listening to your teeth chatter."]],"33":[[1372,1472,"Derek?"],[1704,1936,"You're pressing into me."],[2184,2284,"I know."],[3688,3788,"You smell nice."],[4040,4216,"Thanks… I guess."],[4832,5056,"Eliza, forgive me for what I've said."],[5304,5448,"You must understand…"],[5568,5680,"Your wedding is imminent."],[5796,5924,"You're destined to be the queen."],[6136,6248,"I could never be with you."],[6964,7064,"I know."],[7156,7332,"I don't exactly win you over."],[7488,7656,"And I do behave rather foolishly."],[8072,8172,"Don't be silly."],[8456,8556,"You're the most brilliant…"],[8640,8888,"beautiful, and clever girl in—"]],"34":[[3744,3988,"Your Highness? Are you alright?"],[4144,4296,"You bastard, outta the car."],[4344,4464,"Hands on the bonnet."],[4464,4584,"And no sudden moves."],[4656,4740,"You're under arrest"],[4740,4868,"for kidnapping the princess."],[4972,5084,"Move!"],[5632,5732,"Your Majesty,"],[5732,5940,"please just let me explain."],[5940,6208,"Silence! I'll do the talking."],[6300,6452,"Spending the night"],[6452,6552,"with your bodyguard"],[6552,6724,"when on the brink of marriage?"],[6964,7124,"You're no better than your mother."],[7404,7524,"Just let me explain…"],[7524,7756,"The whole nation depends on you,"],[7756,7956,"Eliza. There's no room for feelings"],[7956,8048,"in that."],[8096,8320,"But I refuse to give up on love."],[8368,8488,"You have no choice."],[8696,8844,"Please let Derek know he can come in."],[9308,9452,"Don't even think of going to him,"],[9452,9552,"Eliza."]],"35":[[449,516,"Oh my god."],[516,604,"What have they done to you?"],[604,704,"Don't."],[952,1296,"Derek, if you have feelings for me"],[1296,1432,"after that night…"],[1496,1684,"I'm ready to renounce the throne."],[1684,1768,"Because I—"],[1768,1900,"Stop degrading yourself."],[2580,2876,"So, you just used me?"],[2948,3048,"You didn't exactly resist."],[3572,3672,"I just need a day off."],[3836,3964,"And I'll find you a new bodyguard."],[4124,4236,"Try not to jump into bed with him"],[4236,4356,"so quickly."],[5608,5704,"A little farewell gift."]],"36":[[992,1039,"I didn't tell her"],[1050,1180,"you installed the cameras,"],[1180,1264,"as agreed."],[1364,1496,"Don't know how I can thank you."],[1550,1748,"Just give me all the footage you've recorded."],[6536,6628,"I can't believe"],[6628,6776,"that you don't care about me."]],"37":[[3904,4016,"Hello, love."],[4088,4188,"Dinner's nearly ready."],[4360,4624,"Daddy! You're finally home."]],"38":[[2464,2696,"Derek, I trusted you so much…"]],"40":[[784,909,"How's work?"],[1063,1200,"Any regrets that I helped you get that job?"],[1376,1552,"After Juan's death, I became soft."],[1852,1964,"Coming back was a mistake."],[2888,3088,"Eliza's missing. Her phone's off."],[3464,3608,"Something happened to the princess?"],[3752,3864,"She's off somewhere again."],[3964,4076,"She drives me crazy."],[4224,4380,"So tired of worrying about her."],[4692,4816,"You speak as if you have feelings"],[4816,5044,"for her. Are they serious?"],[5352,5448,"Yeah…"],[5620,5720,"Don't worry, Gracey."],[5776,5868,"I'm yours forever…"],[5916,6016,"as promised."],[6956,7056,"Derek…"],[7232,7316,"You must stop"],[7316,7428,"sacrificing your happiness…"],[7684,7784,"for me and the boy."]],"41":[[1084,1184,"You again…"],[1340,1500,"I can't escape you in my thoughts"],[1500,1600,"nor in real life."],[1968,2112,"Why must you consistently put yourself"],[2112,2224,"in danger?"],[2376,2468,"You said you'd resign,"],[2468,2560,"so why do you care?"],[2716,2816,"How'd you find me anyway?"],[3008,3140,"Remember that first day you woke"],[3140,3240,"to find me in your room?"],[3448,3592,"I put a tracker on your phone."],[3784,3884,"Come on. Let's go."],[4008,4128,"I'll drive you back to the palace."],[5280,5380,"You know?"],[5452,5544,"I never would've imagined"],[5544,5664,"that you'd be a cheater."],[5944,6044,"Don't worry."],[6128,6256,"Grace will figure it all out."],[6396,6496,"You disgust me."],[7896,7996,"You two just made my life"],[7996,8080,"a whole lot easier"],[8080,8180,"with your drama."]],"42":[[84,176,"Where were you?"],[248,360,"We've been worrying sick."],[516,764,"Never mind. It's good you both came."],[884,1020,"We're letting your bodyguard go."],[1188,1308,"We found the perpetrator."],[1356,1516,"Just some crazy fan who managed"],[1516,1708,"to get a job as a palace cleaner."],[1792,1956,"Those responsible for hiring him"],[1956,2092,"have also been fired."],[2176,2344,"That's good news."],[3272,3408,"I hope I never see you again."],[4528,4648,"Are you certain"],[4648,4748,"you caught the right man?"],[4796,4900,"It all seems a little too simple"],[4900,5128,"for some random stalker."],[5128,5240,"None of your business now."],[5368,5520,"You'll be paid six months upfront…"],[5568,5688,"for ending your contract early."],[6936,7048,"What are you doing here?"]],"43":[[176,288,"You were supposed to kill him"],[288,372,"tonight."],[436,520,"Calm down."],[668,768,"With Derek Hill's gun…"],[912,1040,"which he gave to the princess…"],[1132,1292,"nobody's gonna suspect us."],[1972,2056,"Eliza?"],[2272,2384,"Your Majesty…"],[2552,2648,"You needn't have come down."],[2648,2744,"I'd have come to you."],[2828,2956,"Eliza…"],[2956,3092,"I've heard rumours about Daniel."]],"44":[[48,232,"Dear, speak to me…"],[348,432,"not as your queen"],[432,536,"but as your grandmother."],[844,956,"I don't love Daniel."],[1236,1336,"It doesn't matter."],[1420,1564,"I didn't used to love my husband"],[1564,1684,"either."],[1768,2000,"But in time, I got used to him."],[2176,2368,"But how do you live a life"],[2368,2540,"with someone that you don't love?"],[2588,2700,"You choose."],[2700,2884,"Serve your nation or be happy."],[3268,3428,"Then I've chosen…"],[3732,3860,"I'll never be happy."],[6148,6268,"Finally, I know who the killer is."]],"45":[[1392,1492,"Eliza…"],[1492,1620,"I didn't come here for nothing."],[1744,1888,"I have some important news."],[2092,2208,"The wedding is tomorrow!"],[2256,2356,"And again, I find you"],[2356,2452,"in a compromising position"],[2452,2552,"with your ex-bodyguard."],[2648,2880,"Security! Security!"],[2928,3128,"Eliza, you're in serious danger."],[3176,3292,"Please, can we speak in private?"],[3292,3424,"I don't trust anyone here."],[3660,3784,"I don't have any secrets"],[3784,3916,"from my fiancé."],[3964,4076,"If you have something to say,"],[4076,4220,"then just say it. Otherwise,"],[4220,4304,"please leave."],[5548,5660,"I'll decide on your punishment"],[5660,5840,"later. Oh, by the way…"],[5924,6076,"Ethan's gonna be coming with us"],[6076,6176,"on our honeymoon."],[6372,6492,"It's just the beginning, kitty."]],"46":[[676,804,"Oh my goodness."],[964,1076,"Derek, you're frightening me."],[1160,1280,"Where's William?"],[1328,1440,"I've already put our son to bed."],[1672,1936,"But I need your help."],[2252,2352,"It's a matter of life and death."],[3460,3560,"Grace…"],[3608,3796,"I'm so mortified…"],[3928,4048,"I knew nothing about you,"],[4048,4148,"I swear."],[4148,4308,"Speak to Derek. He has"],[4308,4436,"some very important information."],[4508,4620,"How low of him,"],[4620,4892,"sending his wife to his mistress?"],[5048,5192,"Is he blackmailing you?"],[5240,5340,"We could have him thrown"],[5340,5508,"in prison. I can arrange that."],[5508,5700,"Your Highness, please calm down."],[5764,5944,"Derek is not blackmailing me."],[6216,6368,"It seems I must tell you the truth…"],[6452,6536,"about our marriage."]],"47":[[324,408,"My first husband…"],[456,724,"and the father of my child, Juan…"],[848,960,"was Derek's best friend."],[1060,1160,"He saved Derek's life…"],[1216,1316,"at the cost of his own."],[1436,1548,"Derek still bears the scars"],[1548,1700,"as a reminder of that sacrifice."],[1824,1924,"When Juan died…"],[2040,2160,"Derek married me."],[2312,2612,"Which allowed my son and me"],[2612,2712,"to remain in the country."],[3000,3128,"I want Derek to be happy."],[3360,3472,"He loves you."],[3660,3804,"And I can see you love him too."],[3976,4076,"You should call him."],[5664,5760,"He must be at home."],[5856,5956,"Let's go."],[6880,6980,"It's locked…"],[7028,7112,"Glad to hear"],[7112,7212,"you're done with Derek."],[7296,7480,"Yes, I've trapped Eliza and Grace."],[7616,7776,"They're waiting for you, Jack Fury."]],"48":[[844,964,"Will? William?"],[1236,1340,"Stay here."],[1340,1460,"If anything strange happens,"],[1460,1544,"hide as I taught you."],[1592,1704,"You got it?"],[2964,3060,"Remember me?"],[3504,3588,"The club scum"],[3588,3700,"who got Eliza plastered?"],[3768,3860,"Hard to forget."],[4304,4416,"Thought I'd be scared?"],[4416,4536,"You thought did I got your gun?"],[4712,4796,"A jilted wife"],[4796,4896,"couldn't get over your betrayal."],[4944,5036,"So, she killed you…"],[5104,5196,"and then shoots herself"],[5196,5280,"with your pistol"],[5280,5376,"and her fingerprints…"],[5432,5592,"I killed you both with one shot!"],[6672,6856,"Daddy, are you okay?"]],"49":[[600,756,"If only Derek were here,"],[756,876,"he'd know what to do."],[1120,1204,"Okay."],[1892,1992,"Grace…"],[2048,2196,"we have to climb over the balcony."],[2540,2680,"But I'm scared of heights."],[2680,2900,"So am I. So, we'll die!"],[3000,3144,"And this Jack, he'll kill us!"],[3264,3376,"What's he done to Derek?"],[3600,3824,"And my son… Oh my God, my son…"],[4588,4724,"I'm hopeless at this."],[6184,6336,"Don't let anyone steal your spark."]],"50":[[904,1000,"Why am I here?"],[1132,1280,"Where's my son? Where's Eliza?"],[1448,1632,"Please leave us."],[2668,2828,"You were brought here"],[2828,3004,"after Jack Fury attacked you."],[3096,3244,"Jack is already in prison."],[3344,3456,"Your son is fine."],[3556,3684,"He called the ambulance."],[3836,4036,"It's a long story, really…"],[4084,4224,"but the queen approved of you"],[4224,4324,"being here."],[4576,4752,"You saved my life, Derek."],[4888,4972,"Once again,"],[4972,5156,"if it weren't for your training,"],[5156,5292,"Grace and I would be dead."],[5668,6024,"Eliza, I know"],[6024,6152,"who pushed you off the balcony."],[6352,6448,"It was your—"],[6448,6548,"My mum."],[6764,6864,"How did you know?"],[7100,7316,"She locked Grace and I"],[7316,7416,"in my room."],[7480,7624,"And then I overheard her"],[7624,7768,"on the phone to Jack Fury…"],[7840,8008,"asking him to kill us both."],[8160,8272,"Unfortunately…"],[8320,8480,"I don't have any evidence."],[8652,8736,"I have."]],"51":[[144,240,"On the day of the incident,"],[240,324,"I found a diamond"],[324,456,"from the royal jewellery collection."],[540,684,"A diamond from one of the earrings"],[684,812,"your mother loved to wear."],[1020,1132,"That wasn't enough evidence."],[1228,1312,"Until…"],[1416,1592,"you found the cameras."],[1592,1676,"I discovered"],[1676,1796,"Ethan had installed them."],[1928,2144,"So, he, too, wanted me dead?"],[2228,2348,"No."],[2348,2488,"He was merely collecting evidence"],[2488,2604,"against your mother…"],[2668,2760,"so he wouldn't be found guilty…"],[2760,3000,"if everything came to light."],[3240,3488,"I can't imagine I almost lost you."],[3728,3840,"I'm a terrible person."],[4004,4156,"I don't deserve an angel like you."],[4380,4472,"My heart…"],[4708,4808,"is yours…"],[4880,4980,"forever."],[5128,5240,"And as long as it beats…"],[5340,5596,"know that I'd give my life for you"],[5596,5732,"without a moment's hesitation."],[6288,6488,"Eliza… I love you."],[6836,6920,"But I am—"],[7116,7284,"Grace told me everything."],[7420,7532,"She approves of us."],[7616,7796,"She wants you to be happy."],[8240,8396,"Now, nothing can stop me."],[8396,8508,"Not even the queen."],[8752,8928,"Now, I can have you all to myself."]],"52":[[356,660,"I'm renouncing the throne."],[1076,1160,"I'm sorry…"],[1208,1352,"to have disappointed you…"],[1512,1688,"but I refuse to give up on love"],[1688,1808,"for the sake of duty."],[2280,2380,"You're right."],[2464,2592,"No more sacrifices."],[2720,2769,"I won't let"],[2770,2924,"there be another unhappy woman"],[2924,3024,"in our family."],[4380,4580,"What will happen to my mother?"],[4768,4928,"Well, she must be punished."],[5104,5276,"Aren't you afraid of a scandal?"],[5440,5560,"I was always afraid."],[5608,5720,"Look where that's led us."]],"53":[[588,804,"Get off me! Get off!"],[1132,1292,"For the assassination attempt,"],[1292,1404,"my mother was sentenced"],[1404,1540,"to ten years in prison."],[1632,1768,"It was a massive scandal."],[2244,2336,"My grandmother had"],[2336,2512,"a serious conversation with Ethan."],[2780,2932,"But rumour has it"],[2932,3120,"that Ethan wasn't alone."],[3760,3904,"As for Derek and me…"],[4068,4212,"Yes, I'm leaving."],[4268,4420,"We'll see each other every week."],[4420,4532,"I promise."],[4812,5120,"Be happy, Derek. You deserve it."],[6976,7192,"…we are incredibly happy."]]}