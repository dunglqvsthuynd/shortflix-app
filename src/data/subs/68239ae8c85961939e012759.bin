{"1":[[417,588,"That right there is my husband,"],[588,734,"Levi Carlson,"],[734,917,"NHA MVP of the year,"],[917,1013,"and he's about to join"],[1013,1063,"the biggest,"],[1063,1180,"baddest team in the league,"],[1180,1409,"the Falcons."],[1409,1672,"There's just one little secret."],[1672,1943,"My father owns the Falcons."],[1972,2064,"Mr. Carlson!"],[2064,2189,"How does it feel to be labeled"],[2189,2364,"“MVP of the year?”"],[2364,2456,"For starters,"],[2456,2523,"I'd like to thank"],[2523,2790,"my beautiful wife, Renee."],[2882,2998,"She has stood by my side"],[2998,3140,"this entire time."],[3420,3532,"Lastly,"],[3532,3636,"I would like to thank the"],[3636,3858,"team doctor, Madeline."],[3858,4124,"As you may know, three years ago"],[4145,4279,"I was hurt on the ice"],[4279,4458,"and fell into a terrible coma."],[4458,4562,"Madeline took care of me"],[4562,4696,"while I recovered."],[4696,4871,"Thank you."],[5171,5330,"I haven't told him my real identity"],[5330,5434,"because my father doesn't"],[5434,5647,"approve of us."],[5647,5834,"But now that I'm pregnant,"],[5834,5976,"maybe daddy will change his mind."],[8270,8487,"If it isn’t my favorite sister."],[8487,8604,"Hey."],[8692,8892,"What are you doing here?"],[8892,8954,"I thought I told you"],[8954,9067,"not to find me in public."],[9067,9234,"What if someone sees us?"],[9234,9376,"I’m your brother."],[9376,9580,"You're treating me like some"],[9580,9718,"dirty secret lover."],[9718,9826,"Oh, God, Clark."],[9826,9918,"That's disgusting."],[9918,10110,"Don't say things like that."],[10110,10377,"Anyways, in all seriousness, I..."],[10377,10460,"I wanted to come tell you"],[10460,10564,"in person."],[10564,10689,"Dad’s ready to accept Levi"],[10689,10877,"into the family."],[10994,11156,"Are you serious?"],[11156,11232,"You can't,"],[11232,11286,"you can't joke"],[11286,11407,"about something like that."],[11407,11532,"I'm not."],[11532,11653,"And think about it, you’re pregnant,"],[11653,11695,"Renee."],[11695,11932,"He... he wants to meet his grandchild."],[11932,12087,"And besides, he loves you."],[12087,12153,"We all miss you."],[12153,12354,"It's about time you came home."],[12566,12737,"Well, okay."],[12737,12791,"Then tonight"],[12791,13063,"I’ll tell Levi I’m pregnant and"],[13067,13221,"we’ll come home."],[13221,13313,"It's a deal."],[13384,13563,"Good to see you, sis."],[13563,13663,"You too."],[13780,14051,"Finally got you, skank!"],[14051,14451,"Levi Carlson is going to be mine."]],"2":[[216,417,"That’s her, right?"],[417,563,"Yeah."],[563,658,"That woman is always"],[658,850,"hanging around my husband."],[850,1005,"She's the team doctor, but"],[1005,1121,"something just feels off"],[1121,1251,"about her."],[1497,1659,"Hey, babe."],[1801,1985,"Wait, what's wrong?"],[1985,2089,"Renee, there's"],[2089,2156,"too many people here."],[2156,2364,"Let's just talk when you get home, ok?"],[2364,2423,"Okay."],[2423,2581,"Oh, Levi."],[2581,2786,"My car is in the shop."],[2786,2861,"I was wondering"],[2861,3003,"if I could get a ride."],[3003,3132,"Of course, Maddie."],[3132,3257,"Let's go."],[3257,3353,"Thank you."],[3353,3574,"You're such a lifesaver."],[3891,4033,"What’s up, boys?"],[4033,4104,"Levi."],[4104,4229,"Oh, hey!"],[4229,4375,"We got you this good luck charm"],[4375,4487,"so you're guaranteed"],[4487,4662,"a contract with the Falcons."],[4662,4742,"No way!"],[4742,4808,"Good luck."],[4808,4950,"You guys rock. Thanks."],[4950,5130,"Bye, boys."],[5130,5209,"Bye, cap."],[5209,5296,"Bye, doc."],[5447,5580,"Oh,"],[5580,5714,"Maddie, this is my seat."],[5714,5926,"I get carsick really easily,"],[5926,6089,"so Levi usually"],[6089,6268,"lets me sit in front."],[6268,6398,"Oh..."],[6477,6664,"But... I can... I can"],[6664,6752,"go in the back"],[6752,7019,"if that would be... easier."],[7019,7165,"Renee,"],[7165,7424,"Maddie gets carsick."],[7424,7507,"Yeah, but, Levi, I’m–"],[7507,7670,"But what?"],[7670,7766,"It's not like you're pregnant."],[7766,7849,"Just get in."],[12520,12662,"Who was that?"],[12662,12779,"Why’d you hang up?"],[12779,12937,"Oh, it was..."],[12937,12992,"I don't know,"],[12992,13158,"I think it was a telemarketer."],[13158,13263,"Really?"],[13263,13388,"Because I saw"],[13388,13526,"you leave earlier"],[13526,13763,"to take a call and"],[13763,13880,"I was wondering..."],[13880,14151,"Are you hiding something?"],[14389,14497,"You know, you have no idea"],[14497,14639,"what you're talking about."],[14639,14681,"Renee,"],[14681,14764,"why are you always on"],[14764,14885,"Maddie's back?"],[14885,15040,"It’s so annoying."],[15473,15603,"Levi, watch out!"]],"3":[[2510,2702,"Levi, please help me."],[3924,4083,"Levi!"],[4083,4133,"Come here!"],[4350,4525,"Please!"],[4879,5105,"Hello, ma’am?"],[5180,5351,"You okay?"],[5388,5526,"Hello, ma’am?"],[5580,5793,"A stranger is helping me,"],[5793,5893,"while my husband is"],[5893,6014,"helping another woman."]],"4":[[433,592,"You’re awake."],[646,742,"You have a concussion."],[742,900,"Please take it easy."],[900,1046,"Is my baby okay?"],[1046,1176,"You're pregnant?"],[1176,1288,"We didn't know."],[1288,1405,"Let me get a doctor right away."],[2665,2836,"Your call has been forwarded to..."],[2836,3048,"Where's my husband?"],[5184,5326,"I'm your wife."],[5326,5409,"Why are you tending"],[5409,5593,"to another woman?"],[5722,5822,"OMG."],[5822,5947,"Isn’t that the hockey star,"],[5947,6056,"Levi Carlson,"],[6056,6268,"in there with his wife?"],[6268,6485,"Yeah, who knew he’d be so sweet?"],[7945,8033,"There you are!"],[8033,8083,"The doctor wants"],[8083,8174,"to check your baby."],[8174,8366,"Please follow me."],[9847,10064,"So is my baby okay?"],[10064,10226,"Yes, everything looks good."],[10226,10397,"Heartbeat is strong."],[10552,10860,"But I want you to be careful,"],[10860,10981,"okay?"],[10981,11073,"That car accident"],[11073,11232,"gave your body quite a shock."],[11232,11323,"I want you on bed rest"],[11323,11490,"for the next three days,"],[11490,11607,"and then"],[11607,11824,"you come in for another checkup."],[11824,11957,"Okay."],[11957,12145,"Thank you so much, doctor."],[12658,12904,"Thank you, baby, for being strong."],[12904,13000,"Mommy will do her best"],[13000,13146,"to protect you from now on."],[13417,13697,"What a shame you didn't die."],[13776,13959,"Now you're gonna have to watch"],[13959,14114,"as I take your husband."]],"5":[[16,79,"What the hell are you"],[79,229,"going on about now?"],[229,412,"Let's face it, Renee."],[412,529,"You're not good enough"],[529,700,"for Levi anymore."],[700,975,"He's the biggest name in the NHA."],[975,1180,"And you?"],[1180,1397,"You're just a housewife."],[1397,1609,"Oh, I'm not good enough for him?"],[1609,1722,"I'm the one that's been with him"],[1722,1814,"through thick and thin."],[1814,1901,"When he was in a coma,"],[1901,2068,"when he had nothing."],[2068,2164,"And I gave him"],[2164,2344,"the biggest deal in his career."],[2344,2623,"“The biggest deal of his career?”"],[2711,2898,"Renee, you're"],[2898,3169,"so delusional."],[3249,3603,"You are nothing but a pathetic,"],[3603,3749,"jobless,"],[3749,3912,"housewife."],[3991,4258,"What do you know about careers?"],[4333,4625,"Besides, wasn't it obvious?"],[4729,4979,"Levi cares more about me"],[4979,5238,"than he does about you."],[5238,5417,"Levi is my husband."],[5417,5576,"Back off."],[5684,5893,"Trust me."],[5893,6160,"Not for long."],[6160,6368,"Especially with all the dirt"],[6368,6519,"I have on you."],[6519,6664,"What are you talking about?"],[7219,7386,"Ah! Renee!"],[7386,7536,"Ow, Renee!"],[7966,8037,"Renee!"],[8037,8220,"Why would you push me?"],[8220,8312,"Maddie!"],[8792,8967,"Thank... you..."],[9171,9396,"Levi..."],[9676,9880,"What is wrong with you today?"],[10381,10527,"Wrong with me?"],[10527,10623,"She pushed me."],[10623,10752,"Why are you helping her?"],[10752,11002,"Levi."],[11002,11215,"Levi, I am so sorry."],[11215,11532,"I was just trying to apologize"],[11532,11824,"to Renee, and she pushed me"],[11874,12132,"and told me to stay away from you."],[12132,12237,"What?"],[12237,12316,"Really!"],[12316,12374,"Renee,"],[12374,12562,"there is nothing going on"],[12562,12829,"between me and Levi."],[12829,13004,"Renee,"],[13004,13071,"we’ll talk about this"],[13071,13188,"when we get home."],[13238,13417,"Wait, where are you going?"],[13417,13580,"Don't touch me!"],[13755,13959,"Ow! Ow!"],[14618,14647,"Wait!"],[14647,14743,"Wait, Levi! Help me, please!"],[14743,14894,"Our baby!"],[14894,15190,"Please, I need a doctor!"]],"6":[[66,229,"Doctor,"],[229,396,"could you save my baby."],[1672,1830,"Sorry, Mr. Carlson."],[1830,1972,"The baby is gone."],[3420,3678,"I didn't know she was pregnant."],[3678,3824,"Why didn’t she tell me?"],[3824,4054,"Your wife is inside,"],[4054,4141,"and she's awake."],[4141,4279,"You should go and talk to her."],[8550,8821,"There was a baby in there"],[8946,9217,"and we lost it."],[9221,9309,"Why didn't you tell me"],[9309,9580,"you were pregnant?"],[9672,9805,"Renee, what other secrets are"],[9805,10076,"you keeping from me?"],[10206,10231,"I mean,"],[10231,10489,"would it have changed anything?"],[10489,10694,"Would you have saved me first?"],[10694,10898,"Cared for me first?"],[10898,11056,"Believed me over Madeline?"],[11056,11169,"Why do you keep on bringing up"],[11169,11315,"Madeline?"],[11315,11469,"When you"],[11469,11636,"were the one that cheated on me?"]],"7":[[25,233,"Wait, what are you talking about?"],[316,437,"No, Levi,"],[437,521,"take that back."],[521,596,"Don't say something"],[596,688,"you're going to regret."],[971,1163,"Just admit it, Renee."],[1163,1393,"Madeline told me everything."],[1393,1505,"Must be why you've been acting weird"],[1505,1689,"all these months."],[1689,1826,"How dare you accuse me"],[1826,2006,"of cheating on you?"],[2006,2218,"After everything I have done for"],[2218,2485,"you, after I just lost our baby."],[2560,2744,"Yeah."],[2744,2794,"How do I even know"],[2794,2886,"the baby is mine?"],[3299,3436,"Renee!"],[3436,3749,"You cannot hit Levi."],[3749,3987,"I know that you just"],[3987,4120,"lost your baby."],[4262,4466,"But that’s not Levi’s fault."],[4466,4637,"Just stay out of our business"],[4637,4704,"unless you want to"],[4704,4850,"get slapped, too."],[4850,5121,"I am done playing nice."],[5201,5342,"Oh, yeah?"],[5342,5497,"You want proof, Renee?"],[5497,5718,"Maddie, give me your phone."],[6068,6322,"What more proof do you need?"],[6322,6418,"Look, I may have kept"],[6418,6560,"some things from you."],[6560,6664,"But I have never,"],[6664,6890,"ever cheated on you."],[6890,6998,"And if this is all it takes"],[6998,7073,"to make you believe"],[7073,7169,"I cheated on you,"],[7169,7244,"well then maybe this"],[7244,7440,"marriage is a joke."],[7440,7628,"Yeah."],[7628,7824,"Seems like it."],[8487,8717,"See how easy that was?"],[8717,8850,"I told you,"],[8850,9209,"I can take your man."],[9417,9584,"Earth to Renee!"],[9584,9851,"Can you hear me?"],[10952,11144,"Maybe this marriage is a joke."],[11144,11327,"Yeah."],[11327,11440,"Seems like it."],[12157,12224,"Clark, pick me up"],[12224,12395,"tomorrow at nine."],[12499,12625,"You were right, this marriage was"],[12625,12825,"the biggest mistake of my life."]],"8":[[1017,1092,"Excuse me,"],[1092,1205,"where do you think you're going?"],[1205,1292,"It's 9am"],[1292,1401,"and I don't see any breakfast"],[1401,1509,"on the table."],[1509,1576,"Well, from now on,"],[1576,1755,"you can make your own breakfast."],[1755,1864,"I'm leaving."],[1864,2002,"Leaving?"],[2002,2118,"Well,"],[2118,2206,"I don't recall"],[2206,2331,"approving any vacation"],[2331,2469,"time for you."],[2469,2590,"You're a housewife."],[2590,2773,"It's your job to make breakfast"],[2773,2861,"for your mother in law"],[2861,2952,"and your husband,"],[2952,3078,"who will be home soon"],[3078,3186,"from practice."],[3186,3457,"Make yourself useful."],[3520,3641,"What part of I'm leaving"],[3641,3812,"do you not understand?"],[3812,3949,"Get out of my way!"],[3949,4124,"You did a good job with this hat."],[4124,4225,"So cute."],[4225,4300,"I know that little boy was-"],[4300,4383,"That was so sweet-"],[4383,4454,"Wow, she really"],[4454,4617,"follows you around, huh?"],[4667,4800,"Oh, well,"],[4800,4859,"it just so happens"],[4859,5013,"that my mom isn't feeling well."],[5013,5280,"And Maddie’s the team doctor, so uh..."],[5280,5447,"Son, thank goodness"],[5447,5563,"you are finally home."],[5563,5709,"She's been disrespecting me"],[5709,5818,"all morning."],[5818,5926,"And guess what?"],[5926,6106,"If you were half as useful"],[6106,6206,"as Maddie,"],[6206,6314,"I wouldn't be feeling"],[6314,6468,"unwell in the first place."],[6468,6585,"Oh, well, maybe he can marry"],[6585,6710,"Maddie instead."],[6710,6927,"Be a pretty family!"],[6927,7007,"Renee, what's your problem?"],[7007,7186,"I just got done with practice."],[7424,7645,"What is this?"],[7878,8145,"Levi Carlson..."],[8162,8295,"I'm divorcing you."]],"9":[[187,300,"Wait."],[300,496,"You're serious?"],[608,880,"You're actually gonna divorce me?"],[880,1088,"There's nothing left to say."],[1088,1242,"I'm done with you."],[1242,1447,"Don't you owe me an explanation?"],[1447,1730,"Well, I was going to give you one, but,"],[1730,1810,"now I don't really think"],[1810,1881,"there's a point."],[1881,2022,"And where are you going to go,"],[2022,2156,"Renee?"],[2248,2419,"You are nothing but a housewife."],[2419,2494,"You don't have anything."],[2494,2727,"Just sign the damn papers Levi,"],[2727,2923,"or I'll get my lawyers involved."],[2923,3119,"Lawyers? You? Please."],[3119,3365,"She's fucking bluffing."],[3365,3482,"Renee."],[3561,3757,"I'm warning you."],[3858,4099,"If you do this,"],[4099,4237,"there’s no going back."],[4237,4491,"I'll give you one more chance."],[4491,4575,"Just one."],[4575,4725,"And then maybe I'll forget this"],[4725,4842,"happened, okay?"],[5280,5518,"There's nothing to go back to."],[5989,6085,"You're the biggest mistake"],[6085,6256,"I ever made."],[6669,6831,"You bitch!"],[6831,6981,"You're the only mistake."],[6981,7232,"You were never worthy of my son."],[7232,7365,"Levi, let her go."],[7365,7490,"Madeline is a much better"],[7490,7590,"fit for you."],[7590,7728,"Yeah, you should listen to your mom"],[7728,7853,"like the good little boy you are."],[7945,8016,"You leeched"],[8016,8124,"off my son for"],[8124,8299,"three horrible years."],[8299,8462,"The minute you walk out that door,"],[8462,8733,"don't expect another cent."],[8825,9096,"You think I need your son's money?"],[9096,9384,"Oh, don't make me laugh."]],"10":[[262,433,"Renee. Renee!"],[433,613,"Holy shit, wait."],[613,775,"You don't have any money, okay?"],[775,880,"Take this."],[880,1080,"Go, clear your head."],[1080,1226,"Then come back and we can talk."],[1226,1393,"I know losing a child can be hard, but–"],[1393,1672,"Don't talk about my baby."],[1672,1768,"Levi."],[1768,1981,"Levi, what the hell are you doing?"],[1981,2131,"Do not give her another penny."],[2131,2302,"You know I'm done"],[2302,2410,"being tossed around by"],[2410,2494,"you and your mother."],[2494,2615,"I'm done fighting with you"],[2615,2773,"about Madeline."],[2773,2994,"I never, ever"],[2994,3265,"want to see you again."],[4708,4929,"Who are these people?"],[4929,5226,"Is that Clark Molson?"],[5313,5580,"His dad is the owner of the NHA!"],[7315,7482,"You're nothing but a housewife."],[7482,7620,"You don't have anything."]],"11":[[316,613,"So that must be her new man."],[613,817,"It all is starting to make sense now."],[817,934,"Renee must be sleeping"],[934,1088,"with Clark Molson."],[1088,1343,"Three years."],[1343,1522,"Three years of marriage."],[1522,1651,"And I never knew"],[1651,1785,"who you really were."],[1785,1889,"Not to worry."],[1889,2047,"It's only a matter of time"],[2047,2181,"before he bores of her"],[2181,2327,"and drops her ass."],[2327,2515,"She better not come crawling back"],[2515,2656,"here when that happens."],[2656,2802,"Not to worry, sweetheart."],[2802,2957,"I will not let her step"],[2957,3224,"foot in this house again."],[3340,3457,"Find out everything you can"],[3457,3799,"on a Mr. Clark Molson."],[3799,3937,"Who he's been with,"],[3937,4129,"who he's worked for,"],[4129,4316,"everything."],[4316,4471,"Renee,"],[4471,4729,"you need to be gone for good."],[4729,4838,"That's the only way"],[4838,5080,"Levi will ever be mine."],[5317,5501,"Oh my God!"],[5501,5626,"Edward Hughes?"],[5626,5726,"Oh, my God, look at you."],[5726,5922,"You are all grown up."],[5922,6022,"Wait, how are you even here?"],[6022,6101,"Shouldn't you be in Canada?"],[6101,6214,"You're like the hottest player"],[6214,6247,"right now."],[6247,6322,"I'm surprised your coach"],[6322,6514,"let you come to the U.S."],[6514,6723,"Well, your brother told me"],[6723,6898,"about the divorce, so"],[6898,7040,"I figured I'd be here."],[7040,7123,"Why?"],[7123,7311,"Well, Coach Molson."],[7311,7453,"Don't call me that."],[7453,7540,"I coached you through, what,"],[7540,7615,"one season?"],[7615,7695,"And I haven't"],[7695,7841,"coached in three years."],[7841,8066,"That life is behind me."],[8066,8224,"Well, you'll always be"],[8224,8437,"the greatest coach in my eyes."],[8437,8583,"Oh, that's sweet Eddie."],[8583,8717,"Thank you."],[8963,9067,"Come on, man."],[9067,9129,"Out with it."],[9129,9225,"Tell her the only thing"],[9225,9296,"you've been thinking about"],[9296,9380,"the last few years"],[9380,9559,"is her and hockey."],[9797,9955,"Okay, so"],[9955,10176,"since you're getting a divorce"],[10176,10447,"and I actually have a chance."],[10464,10618,"I figured I'd ask."],[10814,10990,"Will you go out with me?"]],"12":[[125,304,"Will you go out with me?"],[834,963,"Oh my gosh."],[1134,1242,"That was really good."],[1242,1443,"That was really good, you guys."],[1443,1551,"Oh, man, I needed that."],[1551,1822,"Thank you for trying to cheer me up!"],[1822,2139,"Eddie, you're like a little brother to me."],[2139,2394,"And Clark, my real brother."],[2394,2460,"Oh my God,"],[2460,2640,"thank you both for being here."],[2640,2773,"Really."],[3123,3269,"Right."],[3378,3511,"I was just kidding."],[3620,3924,"Anyway, I figured I'd ask."],[3962,4233,"Can you just take a look at this?"],[4295,4416,"So our starter"],[4416,4567,"just got injured, so"],[4567,4662,"our entire game plan"],[4662,4733,"has been thrown off"],[4733,4829,"for the next week."],[4829,4879,"And I don't know–"],[4879,4942,"Wait, why is Richards playing"],[4942,4992,"the blue line?"],[4992,5113,"He should be in the slot."],[5113,5217,"Eddie, you shouldn't be at the"],[5217,5301,"board, you should be at the net"],[5301,5426,"battling for loose pucks."],[5605,5797,"Is Levi blind or something?"],[5797,6060,"He gave up a gem like you"],[6060,6318,"for that trash."],[6318,6468,"Well, let's see how well he plays"],[6468,6681,"without the system I built for him."],[8358,8521,"Did you find anything?"],[8521,8646,"Mr. Carlson,"],[8646,8771,"according to my sources,"],[8771,8917,"Clark Molson doesn’t have"],[8917,9004,"a girlfriend."],[9004,9159,"And that car belongs to his friend,"],[9159,9259,"Edward Hughes,"],[9259,9492,"the Falcons center forward."],[9559,9688,"The game's in a couple of days."],[9688,10010,"Maybe you could talk to Mr. Hughes directly."],[10260,10389,"Levi,"],[10389,10664,"now that your divorce"],[10664,10935,"is finalized with Renee,"],[10985,11186,"I was thinking,"],[11186,11457,"I should be the one by your side."],[11457,11657,"I should be your wife."],[11720,11924,"Madeline, we've been over this"],[11924,12091,"a thousand times, okay?"],[12091,12191,"I'm grateful"],[12191,12303,"for everything you've done for me"],[12303,12424,"while I was in a coma."],[12424,12545,"And I promised"],[12545,12629,"I would take care of you"],[12629,12721,"until you were fully recovered"],[12721,12841,"from the accident, okay?"],[12942,13017,"But, Madeline, I don't"],[13017,13275,"feel the same way, and..."],[13421,13692,"I don't think I ever will."],[14185,14343,"I'm going to go to practice."],[14343,14527,"You're still the team doctor, so"],[14527,14798,"I suggest you go, too."],[17625,17817,"Welcome home, Ms. Molson."],[17817,18001,"Welcome home, sis."],[18180,18322,"Hi, dad."],[18981,19089,"Hey."],[19089,19210,"You're back."],[19210,19373,"That's all that matters."]],"13":[[116,221,"Hey, baby."],[221,300,"Hi, Boxer,"],[300,437,"I missed you."],[884,1051,"And, voila!"],[1493,1534,"Dad, look,"],[1534,1697,"I know that I messed up,"],[1697,1776,"but I'm fixing it."],[1776,1922,"The divorce papers are filed already."],[1922,1989,"Good."],[1989,2135,"That guy's been dragging you down"],[2135,2293,"since day one."],[2293,2435,"You're a Molson."],[2435,2502,"You should be leading"],[2502,2602,"championships,"],[2602,2715,"not wasting your talent"],[2715,2882,"on some second rate team"],[2882,3069,"with its pipe dreams."],[3069,3294,"It’s time to take your place, Renee."],[3641,3816,"Falcons are waiting for you"],[3816,3974,"to lead them."]],"14":[[800,950,"Excited for your first press conference,"],[950,1034,"coach?"],[1034,1180,"The circus is all for you."],[2344,2552,"Levi, are you okay?"],[2552,2777,"Look, I know divorce is hard."],[2777,2840,"I get it,"],[2840,3144,"but today is not about your past."],[3236,3445,"It’s about your future."],[3445,3549,"You’re going to be signing"],[3549,3782,"with the Falcons’ head coach."],[3862,3916,"Do you really think"],[3916,4079,"I have a chance to meet her?"],[4079,4300,"I heard her conferences are"],[4300,4583,"off the record, invite only."],[4583,4738,"Trust me."],[4738,4934,"I have connections."]],"15":[[233,325,"That's Maggie."],[325,458,"She's my press contact."],[458,629,"She'll get us in."],[629,725,"Thanks again, Madeline,"],[725,779,"for everything."],[779,892,"Don't thank her,"],[892,1005,"marry her."],[1076,1217,"Oh, Maggie."],[1217,1409,"I'm serious, Mr. Carlson,"],[1409,1551,"with a wife that could actually"],[1551,1618,"boost your career,"],[1618,1680,"you could be the next"],[1680,1814,"Clark Molson."],[1814,1910,"Besides,"],[1910,1985,"when will you ever get"],[1985,2039,"another shot"],[2039,2252,"to meet the mysterious Ms. R?"],[2252,2377,"She's like a ghost."],[2377,2635,"No photos, no interviews."],[2635,2769,"Yeah, it's crazy."],[2769,2852,"I mean,"],[2852,2940,"three days on the job"],[2940,2990,"and she's already"],[2990,3065,"turned the whole league"],[3065,3190,"upside down."],[3190,3261,"No one even knows"],[3261,3374,"what she looks like."],[3374,3495,"And soon,"],[3495,3578,"you'll be working"],[3578,3766,"with that genius."],[3766,3853,"Shall we?"],[4400,4617,"You got to be kidding me!"],[4617,4733,"Renee is the Falcons'"],[4733,4913,"new head coach?"]],"16":[[308,521,"Renee, what are you doing?"],[521,604,"That’s Ms. R’s seat."],[604,725,"You can’t just do whatever you want."],[725,838,"Ok, let’s-"],[1192,1297,"Yeah."],[1297,1384,"Ma, what's up?"],[1860,2093,"Oh, Renee."],[2093,2239,"This is a private"],[2239,2356,"press conference."],[2356,2464,"You can't be here"],[2464,2640,"even if you are warming Clark"],[2640,2773,"Molson’s bed."],[2773,2865,"Yeah, Clark"],[2865,3019,"might be your sugar daddy,"],[3019,3178,"but Mr. Edward Hughes,"],[3178,3311,"the Falcons golden boy,"],[3311,3395,"is coming, too."],[3453,3666,"I've heard he's quite the diva."],[3674,3770,"Hasn't had a single"],[3770,3853,"press conference"],[3853,3962,"his entire career,"],[3962,4133,"but he's making"],[4133,4304,"an exception for Ms. R."],[4371,4529,"So you better scram"],[4529,4742,"before security throws you out."],[4954,5096,"What's so funny?"],[5217,5384,"Oh,"],[5384,5488,"look at this."],[5576,5730,"Look at your little pathetic"],[5730,5851,"fake badge."],[5851,5930,"Oh, we're"],[5930,6026,"getting a little"],[6026,6147,"desperate to chase"],[6147,6306,"the rich boys, aren't we?"],[6398,6485,"Not as desperate as"],[6485,6564,"sleeping with someone"],[6564,6685,"else's husband."],[6869,6969,"You..."],[6969,7102,"bitch."]],"17":[[20,112,"Bitch!"],[1251,1534,"Oh, my limited edition"],[1534,1972,"Gucci heels, you bitch!"],[1972,2310,"I waited in line for three hours"],[2310,2498,"to get these to meet Ms. R!"],[2498,2715,"Do you have any idea"],[2715,2873,"how much they cost?"],[2873,3119,"No, because someone like you"],[3119,3236,"couldn't afford them."],[3386,3482,"Woah."],[3482,3545,"I mean, it sounds"],[3545,3641,"like you really want"],[3641,3845,"to impress this new coach, huh?"],[3958,4141,"I only came here today"],[4141,4400,"to get Levi signed by Ms. R."],[4400,4512,"And you,"],[4512,4775,"you useless bitch!"],[4896,5159,"You ruined my shoes!"],[5159,5309,"Pay up"],[5309,5472,"or get on your knees"],[5472,5693,"and lick them clean."],[5693,5868,"You done?"],[5868,6076,"Drop the act, Renee."],[6076,6218,"Clean my shoes right now"],[6218,6402,"before Edward Hughes gets here"],[6402,6581,"and has security toss you out"],[6581,6735,"like the trash you are."],[6735,6781,"Yeah."],[6781,6948,"You're going to end up in jail"],[6948,7086,"if this gets out."],[7086,7236,"Funny."],[7236,7349,"Let's see who security throws out"],[7349,7499,"when Ed gets here."],[7499,7615,"Ed?"],[7615,7716,"The nerve!"],[7761,7999,"Mr. Hughes is practically royalty"],[7999,8141,"in this league."],[8245,8512,"I said"],[8512,8675,"lick."],[9230,9346,"What's going on?"]],"18":[[100,221,"Uh, Mr. Hughes!"],[221,471,"Oh, thank God you're here."],[471,646,"This woman was just causing"],[646,804,"a disturbance to Ms. R’s"],[804,917,"press conference."],[917,1126,"She must be removed."],[1126,1259,"Please call security."],[1259,1476,"We can't let Ms. R. see this shrew."],[1505,1676,"What took you so long?"],[1676,1801,"My apologies."],[1801,1951,"Fresh brew for my queen."],[1951,2089,"Aw, thanks, little Ed."],[2348,2686,"Mr. Hughes, there must be a mistake."],[2731,2898,"You know this woman?"],[2898,2990,"Renee happens to be"],[2990,3111,"the most important person"],[3111,3194,"in my life."],[3194,3307,"And I don't appreciate"],[3307,3424,"the word shrew."],[3507,3682,"Oh, Renee’s good."],[3682,3837,"Landing two Falcons?"],[3949,4195,"Please, Mr. Hughes,"],[4195,4408,"she is just hunting for"],[4408,4529,"wealthy athletes."],[4529,4683,"She's using you."],[4683,4792,"Hear that?"],[4792,4925,"I’m the rich one now!"],[4925,5067,"Woah!"],[5067,5171,"Well..."],[5242,5488,"I would buy the whole damn league"],[5488,5676,"for Renee if she asked me."],[6110,6218,"Is that all you got?"],[6218,6398,"Some cheap rumors?"],[6398,6493,"I mean, the press will be here"],[6493,6560,"any minute."],[6560,6644,"Do you really want to be"],[6644,6765,"tomorrow's headline as"],[6765,6890,"lying skank?"],[6890,7002,"Leave now"],[7002,7157,"or I will have you removed."]],"19":[[70,408,"Nice try, but I'm an invited guest."],[408,658,"The only person that can remove me"],[658,992,"is the genius, Ms. R herself."],[1605,1651,"Hey!"],[1651,1764,"Levi!"],[1764,1885,"Oh!"],[1885,1997,"Renee!"],[1997,2185,"You should not be cheating"],[2185,2402,"on Levi with Edward!"],[2502,2627,"Levi!"],[2627,2865,"I was trying to protect you."],[2936,3161,"Just imagine the press."],[3161,3453,"Ms. R, seeing your not-yet-"],[3453,3586,"ex-wife wrapped up"],[3586,3791,"in the arms of your rival."],[3791,3908,"I was just trying to reason"],[3908,3978,"with her."],[3978,4279,"She attacked me with coffee."],[4304,4471,"That's right, Mr. Carlson."],[4471,4667,"They were totally bullying us."]],"20":[[0,79,"The press conference"],[79,196,"is about to start."],[196,437,"I can't have Ms. R seeing me like this."],[437,521,"Really, Renee?"],[521,729,"Today's a huge day for me."],[729,971,"I am meeting the Falcons' coach"],[971,1126,"to finally seal the deal."],[1126,1267,"I know you would never care"],[1267,1376,"as much as Madeline does,"],[1376,1451,"but can"],[1451,1622,"you stop trying to sabotage me?"],[1622,1735,"Are you serious?"],[1735,1822,"If you really want"],[1822,1910,"to join the Falcons,"