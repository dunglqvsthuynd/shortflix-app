9,4207,"Fine, then."],[4288,4439,"Looks like I get this huge bed"],[4471,4643,"all to myself tonight."],[4743,4807,"The door's over there."],[5000,5064,"See yourself out."],[6260,6367,"Amateur."],[6396,6531,"Thinking you can beat me."],[6579,6692,"I'll tame you sooner or later."],[7795,7864,"Did I"],[7904,8020,"scare her just now?"],[8084,8220,"She's actually quite young."],[8240,8376,"If my mom hadn't tricked her,"],[8451,8623,"she wouldn't have married me so blindly."],[9035,9140,"If you're scared,"],[9207,9335,"let's go get a divorce tomorrow."],[9348,9448,"I won't touch you tonight."],[9487,9579,"Hubby, come look!"],[9595,9792,"There's so much fun stuff here!"]],"17":[[4,96,"Hubby, come look!"],[115,275,"There's so much fun stuff here!"],[712,751,"You"],[843,919,"That's good."],[935,996,"Today"],[996,1127,"is your wedding night."],[1148,1324,"I've already arranged the bridal suite,"],[1356,1503,"so you two should rest early."],[1644,1723,"Over the years,"],[1764,1871,"to rush me into marriage,"],[1917,2083,"my mom has stopped at nothing."],[2176,2351,"She must have prepared these, too."],[2596,2719,"Hubby, you know what?"],[2732,2880,"I've only ever seen these things"],[2880,2996,"in smutty comics."],[3035,3207,"This is my first time touching one."],[3432,3579,"Let me see"],[3632,3792,"which one to use tonight."],[3820,3971,"Who said I'd play with those with you?"],[4135,4215,"You don't want to?"],[4388,4535,"You don't like this one?"],[4990,5071,"How about this?"],[6335,6456,"Look how fun this is."],[6520,6707,"Are you really not gonna consider it?"]],"18":[[287,348,"Nora."],[391,459,"Stop it."],[507,600,"What?"],[655,724,"Don't you know"],[748,832,"that behaving like that"],[932,1043,"makes you an easy target for men?"],[1172,1251,"I know."],[1428,1488,"But"],[1516,1655,"you're my husband now."],[1671,1892,"Isn't this what we're supposed to do?"],[1916,1987,"Nora,"],[2023,2083,"marriage should be"],[2083,2216,"a union of two loving hearts."],[2235,2316,"You married me"],[2396,2523,"just for the money."],[2551,2716,"Have you considered your own future?"],[2760,2860,"I have."],[2876,2944,"Graham,"],[3039,3315,"even though you seem cold,"],[3360,3452,"I feel like"],[3503,3615,"you're not a bad person."],[3720,3788,"I don't love you."],[3971,4088,"I know."],[4096,4279,"Lots of couples rush into marriage"],[4360,4539,"and still wind up happy."],[4571,4760,"It's okay if you don't accept me yet."],[4767,4932,"We can let our feelings grow."],[5552,5615,"From now on,"],[5624,5715,"I'll sleep on this side,"],[5728,5800,"and you sleep over there."],[5879,6011,"It's been a long day."],[6047,6179,"Since we're skipping the wedding night,"],[6184,6264,"I'm going to sleep."],[7407,7579,"I have to get that money."],[7940,8043,"I almost softened"],[8043,8168,"because of what she said."],[8223,8340,"She just sees me as"],[8340,8456,"a tool to make money."]],"19":[[888,1143,"Judging by the way you're holding your waist,"],[1291,1435,"your wedding night"],[1456,1632,"must have been intense."],[1751,1803,"How was it?"],[1887,2032,"How was the experience"],[2032,2071,"with Colton?"],[2132,2287,"It's not what you think."],[2287,2428,"We didn't."],[2428,2551,"Didn't?"],[2739,2887,"Don't tell me he"],[3051,3180,"can't get it up?"],[3239,3352,"That's not it."],[3560,3603,"Sister,"],[3664,3764,"I think"],[3971,4207,"he's different from other men."],[4225,4388,"He didn't touch me last night"],[4417,4603,"because he feels we lack a connection."],[4620,4800,"But since we're married,"],[4811,4964,"we can develop feelings slowly."],[5188,5256,"What about you?"],[5284,5456,"You swore you were going"],[5456,5596,"to tame that little bully."],[5675,5764,"Don't bring it up."],[5824,5975,"He is just a handful."],[5996,6088,"Those two brothers"],[6088,6235,"are so guarded right now."],[6292,6415,"If we want to win them over"],[6443,6551,"and have a baby soon,"],[6656,6815,"we need to come up with another plan."],[7687,7764,"Good morning,"],[7779,7856,"madams,