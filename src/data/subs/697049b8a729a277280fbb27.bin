ght now."],[4535,4588,"Let go of me!"],[4637,4693,"I'm telling you,"],[4716,4828,"I'm Colton Johnson's wife!"],[4871,4988,"Do you dare mess with the Johnsons?"],[5032,5100,"Let me go!"],[5111,5292,"You're Colton Johnson's wife?"],[5375,5479,"How come I didn't know that?"],[5600,5671,"Enough."],[5711,5824,"Stop struggling."],[5843,5967,"The more you struggle,"],[5993,6137,"the more I like it."],[6186,6401,"I'm gonna show you a really good time."],[6519,6639,"Get off me!"],[6643,6723,"Help!"],[6794,6890,"Let her go!"]],"43":[[78,181,"Let her go!"],[551,736,"Mr... Mr. Johnson."],[1043,1116,"I'm sorry, Mr. Johnson."],[1116,1164,"I"],[1164,1227,"I didn't know"],[1227,1296,"she was your wife."],[1308,1403,"Otherwise, I wouldn't"],[1419,1567,"have dared to lay a finger on her."],[1756,1872,"Touch her again,"],[1900,2016,"and I'll kill you!"],[2023,2093,"Get lost!"],[2271,2360,"Okay,"],[2396,2471,"I'm leaving right now."],[3183,3271,"Are you okay?"],[3343,3428,"I'm fine."],[3507,3571,"Colton,"],[3639,3703,"thank you."],[3975,4066,"No worries."],[4152,4284,"You're my wife, after all."],[4315,4447,"It's my job to protect you."],[4735,4867,"Still,"],[4867,4932,"thank you."],[4956,5088,"Since we're at a bar,"],[5150,5296,"let me buy you a drink."],[5647,5747,"Are you kidding?"],[5803,5903,"How could a man"],[5924,6024,"let his wife pick up the tab?"],[6139,6187,"Tell you what."],[6267,6367,"Order whatever you want,"],[6404,6504,"it's on me."]],"44":[[297,465,"You know, sometimes,"],[519,656,"you're actually pretty nice."],[980,1064,"If"],[1075,1227,"we keep going on like this,"],[1227,1314,"as time goes by,"],[1349,1585,"will you fall for me?"],[1803,1876,"Strange."],[1932,2039,"When she touches me,"],[2067,2164,"I actually"],[2164,2312,"feel so comfortable."],[3264,3379,"D*mn it."],[3403,3511,"That bi*ch Vivian"],[3511,3675,"got away again."],[3692,3896,"Since you refuse to divorce,"],[3916,4092,"I'll just have to help you out."],[4692,4775,"Hubby,"],[5051,5191,"thanks for standing up for me today,"],[5265,5356,"and treating me to dinner."],[5975,6084,"You look pretty happy."],[6315,6435,"Graham,"],[6504,6579,"thank you."],[6715,6776,"Thank me?"]],"45":[[20,119,"I know that"],[119,279,"it was you who gave me the chance"],[312,375,"to fulfill my dream"],[375,536,"of becoming a designer."],[536,600,"Don't worry."],[663,916,"I'll work harder than ever."],[1735,1807,"Slow down."],[1864,1928,"You'll get drunk."],[1987,2032,"Come on."],[2296,2416,"How could I?"],[2555,2664,"Even if I do get drunk,"],[2687,2835,"I still have you, don't I?"],[3903,4039,"I want more."],[4367,4535,"Fill it up, fill it up."],[4571,4763,"This wine is delicious."],[4892,5000,"I'll go get you some water."],[5825,5972,"Hubby, don't go."],[6075,6181,"Nora."],[6215,6303,"Stop messing around."],[6392,6512,"I'm not messing around!"],[6765,6877,"Graham."],[6912,7053,"Be a good boy,"],[7078,7258,"and let me give you a kiss."],[7279,7376,"Okay?"]],"46":[[108,220,"Graham,"],[260,424,"from now on,"],[424,604,"let's live happily together,"],[667,788,"okay?"],[832,1008,"Nora."],[1035,1180,"You're drunk,"],[1180,1327,"and you're not thinking straight."],[1388,1519,"We'll talk when you're sober."],[1548,1780,"I'm perfectly sober."],[1783,2080,"I know exactly what I'm doing."],[2080,2239,"Don't worry."],[2271,2544,"I'll take responsibility for you."]],"47":[[24,173,"With a tolerance like yours,"],[240,296,"how dare you call"],[305,465,"yourself the Prince of Nightclubs?"],[520,636,"Honey."],[1032,1143,"Colton."],[1143,1288,"Why did you drink so much?"],[1288,1410,"Jessie."],[1488,1607,"What are you doing here?"],[1616,1739,"I came here"],[1739,1955,"to get you to divorce Colton!"],[2083,2165,"Divorce?"],[2419,2487,"That's right."],[2487,2587,"Vivian,"],[2651,2751,"I'm pregnant."],[2880,2967,"You're an orphan."],[2976,3076,"You should understand"],[3092,3167,"how pitiful it is"],[3167,3235,"for a child"],[3235,3360,"without a complete family."],[4132,4284,"You're... pregnant?"],[4409,4556,"Here is my pregnancy report."],[4611,4728,"The baby was an accident."],[5364,5447,"Vivian,"],[5500,5575,"actually, I"],[5575,5684,"didn't want to fight with you."],[5732,5911,"But in Colton's heart,"],[5912,6076,"the one he's always loved is me."],[6228,6367,"If you don't believe me,"],[6431,6559,"see for yourself."],[7456,7534,"We have"],[7579,7704,"known each other since childhood."],[7704,7839,"I was immature back then."],[7895,8084,"I always liked to provoke Colton,"],[8104,8251,"so I went abroad out of spite."],[8284,8335,"I wanted him"],[8335,8459,"to chase after me."],[8459,8584,"A month ago,"],[8595,8748,"we met abroad."],[8800,8951,"We slept together by accident."],[9271,9395,"Actually,"],[9423,9587,"He's always wanted to divorce you,"],[9604,9759,"and take responsibility for me."],[9759,9815,"But,"],[9815,9976,"you just refuse to let go."],[10031,10131,"So,"],[10164,10295,"I hope you'll step aside,"],[10295,10424,"and let us be a family."]],"48":[[428,663,"The person Colton loves..."],[872,956,"I only recently"],[956,1132,"heard people talking about it."],[1159,1391,"I heard Colton didn't want to marry"],[1427,1607,"because he was already in love."],[1612,1732,"As for why they broke up,"],[1732,1919,"no one in the Johnsons dared to mention it."],[1951,2019,"Colton"],[2087,2196,"I just thought"],[2203,2300,"that if I worked hard,"],[2360,2419,"you would"],[2419,2548,"accept me as your wife."],[2564,2644,"Turns out,"],[2671,2807,"you won't fall in love with me."],[2880,2955,"It makes sense."],[2996,3083,"Our marriage"],[3128,3288,"was a mistake from the start."],[3343,3567,"Now it's time to end it."],[4171,4300,"I"],[4407,4524,"I understand."],[4670,4747,"But this is a matter"],[4747,4928,"between my husband and me."],[5022,5082,"You need to"],[5088,5207,"give me some time."],[5272,5376,"Good."],[5420,5560,"You better keep your word."],[5560,5707,"Otherwise, once I start showing,"],[5707,5815,"the Johnsons won't"],[5815,5952,"let the child live outside the family."],[5956,6024,"By then,"],[6039,6115,"they'll definitely"],[6115,6196,"kick you out."]],"49":[[1712,1783,"Since she and I"],[1783,1916,"have slept together,"],[1976,2051,"I have to"],[2051,2171,"take responsibility for her."],[3215,3411,"Order me a diamond engagement ring."],[3898,4169,"Sister, what time is it?"],[4861,4957,"What's going on?"],[5041,5200,"What did I do last night?"],[6057,6156,"Nora,"],[6156,6300,"you're drunk."],[6367,6564,"You're not thinking straight."],[6587,6740,"Wait until you sober up."],[6740,6942,"I'm perfectly sober."],[7017,7268,"I know what I'm doing."],[7310,7410,"Don't worry,"],[7480,7699,"I'll take responsibility for you."],[8021,8185,"Nora, are you crazy?!"],[8221,8413,"You actually slept with Graham!"],[9065,9165,"Oh, right."],[9218,9318,"He's my husband."],[9439,9691,"Touching and kissing isn't a crime."]],"50":[[444,483,"Sister,"],[508,608,"what are you doing here?"],[667,759,"You've been crying."],[874,1100,"Didn't you go negotiate a deal yesterday?"],[1203,1375,"Did it fall through?"],[1392,1440,"No."],[1508,1559,"Nora,"],[1635,1723,"I just found out"],[1723,1883,"that Colton and Jessie"],[1904,2035,"already have a child."],[2064,2128,"What?"],[2180,2267,"He cheated?!"],[2644,2683,"Vivian,"],[2683,2816,"what are you gonna do now?"],[2951,3003,"Get a divorce!"],[3064,3155,"He doesn't love me,"],[3211,3320,"and I don't love him either!"],[3320,3403,"That's right."],[3433,3561,"Divorce him. You have to."],[3924,4039,"But after the divorce,"],[4039,4156,"I'll have to leave here."],[4275,4367,"What will happen to you?"],[4707,4764,"Also,"],[4803,4975,"did you and Graham sleep"],[4975,5056,"together last night?"],[5147,5252,"I know,"],[5252,5411,"Graham is great,"],[5503,5557,"but"],[5652,5760,"you're my sister."],[5839,5975,"We grew up together."],[6079,6132,"So,"],[6152,6228,"wherever you go,"],[6228,6292,"I'm going with you."],[6456,6500,"Okay."],[6523,6620,"After you get a divorce,"],[6640,6756,"I'll find you someone handsomer."],[6948,7100,"Let's sign the divorce papers,"],[7123,7187,"pack our bags,"],[7200,7295,"and go back to the orphanage."]],"51":[[160,227,"Look great."],[240,339,"Vivian, Nora,"],[364,408,"come downstairs."],[416,532,"Look what I bought for you."],[816,955,"Strange. Where are they?"],[1159,1203,"What's this?"],[1357,1460,"Divorce papers?"],[1551,1596,"Mom,"],[1619,1787,"thank you for taking care of us."],[1848,1916,"You made us"],[1916,2051,"feel a mother's warmth"],[2051,2144,"for the first time."],[2171,2216,"But,"],[2239,2371,"Colton and I aren't a good match,"],[2416,2467,"so"],[2500,2580,"we've decided to divorce."],[2635,2844,"We wish you a long and healthy life."],[2928,3090,"From Vivian and Nora."],[3247,3311,"My two"],[3311,3435,"wonderful daughters-in-law"],[3479,3592,"are just gone."],[4192,4279,"I clearly remember"],[4279,4443,"drinking with Vivian last night."],[4471,4579,"How did I wake up"],[4579,4652,"on the road?"],[4947,4975,"Mom."],[5211,5303,"You little brat!"],[5384,5418,"Mom,"],[5458,5524,"I wonder if"],[5524,5622,"she'll like this ring."],[5638,5751,"You little bast*rd!"],[5856,5947,"Mom, stop hitting me!"],[5947,6054,"You're gonna kill your son!"],[6133,6245,"Bro, stop her!"],[6296,6384,"Hold Mom back!"],[6500,6535,"Mom,"],[6676,6768,"what on earth is going on?"],[6868,6959,"What's going on?"],[7020,7166,"Your wives are gone,"],[7271,7372,"that's what's going on!"],[7379,7474,"See for yourselves!"]],"52":[[759,832,"Vivian"],[856,1000,"She actually wants to divorce me."],[1067,1148,"Why?"],[2210,2292,"Hello? Who is it?"],[2355,2396,"Honey."],[2655,2760,"Graham."],[2828,2937,"Who's your wife?"],[3096,3155,"Colton"],[3155,3300,"dared to knock up another woman"],[3367,3432,"and upset my sister."],[3432,3567,"You Johnsons are our enemies!"],[3724,3843,"You saw the divorce papers"],[3843,3943,"I left for you."],[3943,4052,"I want a divorce."],[4084,4204,"Don't ever call again!"],[4652,4728,"Colton!"],[4803,4871,"How could you"],[4871,4967,"cheat on your wife"],[4979,5128,"and even have a b*stard child?"],[5128,5171,"Mom,"],[5215,5343,"I didn't!"],[5343,5443,"You still deny it?"],[5460,5545,"Then what is this?"]],"53":[[148,176,"Madam,"],[224,272,"I found out."],[272,408,"Last night, it was Jessie"],[408,475,"who told Ms.Collins"],[475,563,"that she was pregnant."],[843,972,"So Ms.Collins asked for a divorce."],[1088,1191,"It was her."],[1288,1359,"Colton,"],[1408,1580,"how could you still be mixed up"],[1580,1641,"with that woman, Jessie?"],[1803,1939,"Don't tell me you really have a child with her."],[2060,2167,"How is that possible?"],[2264,2371,"Her sister died because of me."],[2476,2555,"I was just honoring"],[2555,2712,"her wish to take care of Jessie."],[2868,3056,"But now that she's upset my wife,"],[3096,3215,"I'll send her abroad."],[3243,3320,"She's never allowed to return!"],[3511,3671,"What's the use of saying that now?"],[3747,3788,"The two of you,"],[3788,3939,"go get my daughters-in-law"],[3939,4007,"back here!"],[4028,4128,"If you fail to get them back,"],[4164,4239,"neither of you"],[4239,4335,"bother coming back either!"],[5096,5139,"It's your fault."],[5256,5320,"If it weren't for you,"],[5371,5447,"why would my wife have left?"],[5447,5535,"You're blaming me?"],[5588,5707,"I'm a victim here too, okay?"],[5707,5815,"That woman,"],[5852,5952,"thinking she can divorce me?"],[5996,6039,"No way in hell!"],[6107,6152,"Enough."],[6235,6332,"No we need to find"],[6435,6523,"out where they are."],[6687,6743,"I know."],[6768,6820,"The orphanage."],[6820,6935,"They must have gone back to the orphanage."],[7004,7104,"Vivian."],[7207,7387,"You think you can marry me on a whim,"],[7400,7507,"and divorce me whenever you please?"],[7619,7764,"You want to kick me to the curb?"],[7792,7859,"Not a chance!"]],"54":[[204,360,"The countryside beats the city any day."],[416,600,"My wonderful life of lazy retirement,"],[600,683,"here I come!"],[827,896,"Ms. Tayler!"],[919,996,"We're back."],[1108,1151,"You're here."],[1564,1683,"Ms. Tayler."],[1776,1855,"Vivian, Nora."],[1867,1919,"Why didn't"],[1919,2119,"you tell me in advance?"],[2135,2348,"We wanted to surprise you."],[2460,2523,"My good girls."],[2528,2555,"Come on,"],[2555,2635,"come inside."],[2728,2748,"Come."],[2839,2916,"Children,"],[2916,3019,"look who's here!"],[3019,3087,"Vivian!"],[3087,3167,"Nora!"],[3387,3471,"Let me look at you."],[3515,3607,"You've grown so tall."],[3632,3767,"Vivian! Nora!"],[3778,3942,"We missed you so much!"],[3947,4079,"I missed you too."],[4139,4247,"And since we're back,"],[4247,4320,"we brought you gifts!"],[4384,4439,"Here."],[4639,4752,"Wow!"],[4856,4905,"Don't push."],[4911,5008,"One for you,"],[5011,5123,"and one for you."],[5187,5329,"Thank you!"],[5371,5415,"Here."]],"55":[[783,851,"Vivian,"],[900,996,"did something happen"],[996,1124,"while you were away?"],[1440,1559,"Why do you look"],[1559,1676,"so pale?"],[1696,1739,"Mom,"],[1835,1971,"I fell in love with someone."],[2067,2132,"Really?"],[2467,2507,"Where is he?"],[2519,2619,"Did he come back with you?"],[2939,2983,"No."],[3067,3151,"He's from a rich family,"],[3311,3428,"and he likes someone else,"],[3452,3592,"so he'll never love me."],[3952,4107,"Just a man."],[4320,4420,"It's okay."],[4447,4543,"I'll introduce you"],[4543,4722,"to a better man."],[5035,5171,"Nora and I are back,"],[5171,5243,"and we're not leaving."],[5352,5456,"We'll stay right here with you"],[5456,5539,"and these kids."],[5620,5720,"And me! And me!"],[6007,6060,"Okay."],[6103,6200,"Stay with me."]],"56":[[763,796,"Brother,"],[808,919,"are you sure we're in the right place?"],[980,1048,"Did Vivian"],[1048,1216,"really grow up in a place like this?"],[1327,1356,"That's right."],[1451,1508,"Vivian and Nora"],[1508,1588,"were abandoned as kids"],[1896,1980,"and grew up in an orphanage."],[2255,2316,"Excuse me, sir."],[2339,2464,"Do you know where Nora is?"],[2619,2664,"Who?"],[2676,2767,"No... ra."],[2812,2900,"No-what?"],[2927,3019,"Nora."],[3055,3139,"What-ra?"],[3215,3247,"Sir,"],[3307,3407,"do you know Vivian?"],[3415,3500,"Vivi-what?"],[3664,3696,"Sir,"],[3760,3828,"thanks for your time."],[3911,3971,"You got it."],[4456,4532,"You're"],[4532,4675,"looking for Vivian and Nora,"],[4692,4728,"right?"],[4739,4760,"Yes."],[4788,4871,"Do you know where they are?"],[4896,4956,"Right over there."],[4984,5088,"Head that way and you'll find them."],[5371,5515,"Vivian! Nora!"],[5515,5639,"There are two handsome"],[5639,5720,"guys outside."],[5720,5803,"They said"],[5803,5960,"they're our brothers-in-law."],[6106,6197,"Brothers-in-law?"],[6264,6463,"Did Graham come to find us?"]],"57":[[256,296,"Nora."],[432,479,"Honey."],[567,628,"Colton,"],[691,808,"we're already divorced."],[927,1016,"I don't want to see you"],[1016,1111,"or hear any word you say."],[1172,1224,"You should be"],[1224,1335,"with the girl you love right now."],[1427,1545,"No, honey,"],[1559,1616,"you misunderstood."],[1616,1751,"I don't like Jessie at all."],[1796,1896,"I don't want to hear it."],[2319,2376,"Nora,"],[2400,2483,"their issues"],[2483,2616,"have nothing to do with us."],[2623,2680,"Come home with me."],[2680,2696,"You"],[2823,2861,"No."],[3019,3080,"My sister and I"],[3080,3211,"have never been apart."],[3303,3360,"Where she is,"],[3360,3420,"is where I am."],[3479,3528,"If she divorces,"],[3528,3579,"I'm divorcing too."],[5003,5043,"Sister,"],[5071,5156,"it's been three days."],[5156,5260,"I bet those two are long gone."]],"58":[[36,112,"I don't care."],[167,268,"Out of sight, out of mind."],[888,956,"Nora."],[1016,1224,"I'm making braised pork for you today."],[1359,1464,"But we're out of sugar."],[1464,1583,"Go to the grocery store"],[1583,1632,"and buy a bag, will you?"],[1666,1748,"Sure."],[1748,1816,"I'll go right now."],[2528,2635,"I'd like to buy some sugar."],[2635,2699,"How much is it?"],[2764,2816,"It's free"],[2871,2912,"for you."],[3235,3347,"Graham?"],[3449,3624,"W-What are you doing here?"],[3639,3720,"You wouldn't come to see me,"],[3781,3920,"so I acquired every shop"],[3964,4000,"and clinic"],[4000,4071,"in the village."],[4088,4160,"If you stepped out,"],[4207,4300,"I'd eventually find you."],[4403,4578,"We're just a contract couple."],[4615,4752,"We don't have any feelings for each other."]],"59":[[40,160,"You'd better leave now."],[160,287,"Stay out of my life."],[559,608,"Nora."],[748,808,"Have you forgotten"],[808,932,"what you said to me that night?"],[972,1075,"What did I say?"],[1194,1426,"I'm perfectly sober."],[1467,1764,"I know exactly what I'm doing."],[1803,1935,"Don't worry,"],[1955,2171,"I'll take responsibility for you."],[4056,4111,"How about"],[4171,4296,"you just forget I said that?"],[4296,4471,"Let's pretend nothing happened."],[4584,4688,"If that doesn't work,"],[4721,4853,"I'll give you some money."],[4869,4935,"Nora,"],[5011,5115,"what do you take me for?"]],"60":[[52,136,"what do you take me for?"],[176,239,"Don't you realize"],[291,387,"that I'm your legal husband?"],[401,528,"You're not my husband."],[528,620,"I never agreed to a divorce."],[728,783,"Come home with me."],[796,835,"No."],[875,967,"I won't abandon my sister"],[967,1027,"to go back with you."],[1291,1367,"Tell your sister"],[1400,1551,"that Colton doesn't love Jessie,"],[1591,1687,"and Jessie isn't pregnant."],[1728,1796,"Really?"],[1816,1855,"Of course."],[1892,1951,"It's all one big,"],[1951,2048,"complete misunderstanding."],[2617,2767,"G-Graham."],[3116,3203,"What are you doing?"],[3991,4188,"Why... why did you kiss me again?"],[4284,4356,"Nora."],[4435,4592,"I've never liked being close to people,"],[4647,4756,"and I've never dated anyone."],[4839,4932,"The first person I've ever liked"],[4985,5043,"is you."],[5266,5335,"So,"],[5335,5567,"are you confessing your feelings?"],[5628,5660,"Yes."],[5728,5792,"Nora,"],[5896,5964,"I like you."],[6256,6296,"No."],[6468,6543,"Why not?"],[6620,6695,"I own this place now,"],[6695,6779,"so no one will come in."],[6828,6887,"We can't."],[6948,7085,"Let's just forget about this."]],"61":[[12,60,"Forget"],[60,104,"Forget it?"],[124,187,"My sister doesn't"],[187,308,"like Colton anymore."],[448,551,"And her childhood friend"],[551,616,"is back."],[655,779,"I bet pretty soon,"],[779,905,"he'll marry my sister."],[975,1072,"Is that why"],[1167,1264,"you don't want me anymore?"],[1288,1356,"We swore"],[1356,1467,"we'd always be together."],[1580,1671,"Since my sister is staying here,"],[1671,1819,"I can't go back with you."],[1851,1928,"So,"],[1996,2060,"Graham,"],[2264,2328,"please stay"],[2328,2460,"out of my life."],[3456,3511,"Nora,"],[3528,3607,"what's with that look?"],[3628,3724,"I'm still your brother-in-law."],[3747,3815,"Brother-in-law,"],[3843,3979,"Vivian is about to get married."],[4015,4079,"You should"],[4107,4220,"think about how to win her back."],[4220,4320,"Married?"],[4484,4596,"I'm still her husband."],[4647,4715,"She's getting married?"],[4747,4843,"Is she planning to have the baby"],[4843,4947,"call someone else 'Dad'?"],[5164,5292,"Graham... honestly."],[5332,5407,"He's nothing like"],[5407,5567,"the reclusive, stoic guy he used to be."],[5671,5792,"My lips hurts."],[6003,6088,"Nora,"],[6303,6356,"wht"],[6356,6471,"took you so long?"],[6587,6656,"What's wrong with your lips?"],[6876,6915,"I"],[6935,7084,"just ate some spicy strips."],[7179,7251,"Here's the sugar."],[7335,7412,"Just leave it there."],[8071,8151,"Tell me the truth,"],[8216,8328,"where did you go just now?"]],"62":[[148,196,"Vivian,"],[220,463,"about what happened between"],[463,528,"Colton and Jessie,"],[551,671,"could it be that you misunderstood him?"],[811,880,"Nora,"],[935,1108,"did you go see Graham just now?"],[1780,1855,"Don't tell me"],[1876,2007,"you believed what he said."],[2112,2203,"I just feel like"],[2203,2400,"Colton might still have feelings for you."],[2419,2551,"Otherwise, why would he come"],[2551,2639,"all the way out here?"],[2780,2887,"So he hasn't left yet."],[3107,3180,"Who knows?"],[3196,3324,"He's just a rich playboy."],[3352,3403,"I guess"],[3428,3588,"getting dumped hurt his pride."],[3675,3732,"Anyway,"],[3732,3779,"Nora,"],[3807,3860,"he and I"],[3860,4011,"are from completely different worlds."],[4033,4184,"I don't want to consider him anymore."],[4307,4379,"Ms. Tayler"],[4379,4524,"set me up on a new blind date."],[4592,4679,"I'm going to meet him tomorrow."]],"63":[[68,139,"Ms. Tayler"],[139,283,"set me up on a new blind date."],[331,440,"I'm going to meet him tomorrow."],[636,724,"Is it here?"],[911,983,"Right here."],[1089,1183,"Vivian, Nora."],[1480,1548,"You guys go play."],[1548,1644,"I'll come find you later."],[1644,1728,"Be careful."],[1923,2003,"Matron."],[2028,2135,"This is..."],[2332,2387,"Vivian,"],[2387,2532,"this is the one I told you about,"],[2551,2612,"Brian."],[2628,2716,"Brian."],[2760,2851,"You're Brian?"],[3003,3146,"The chubby kid from back then?"],[3158,3194,"It's me."],[3220,3279,"I'm back."],[3288,3364,"Back then,"],[3364,3479,"didn't your birth parents"],[3479,3556,"take you back home?"],[3607,3724,"So why"],[3824,3856,"Vivian,"],[3954,4092,"I've liked you since we were kids."],[4228,4292,"I promised,"],[4377,4441,"that I'd"],[4452,4543,"come back and marry you."]],"64":[[68,196,"You still remember things"],[260,356,"from our childhood?"],[356,396,"Of course!"],[487,520,"Vivian,"],[551,624,"my feelings for you"],[624,704,"have never changed."],[888,940,"I know"],[964,1075,"you can't bear to leave these kids,"],[1232,1275,"so"],[1308,1388,"I'm willing to stay here with you"],[1388,1532,"and help you take care of them."],[1716,1828,"Will you give me a chance?"],[1900,1964,"Vivian,"],[2055,2255,"Brian has always cared about you."],[2300,2435,"You've known each other since childhood,"],[2447,2571,"and you know everything about him."],[2676,2748,"Why don't you"],[2748,2892,"give it a try?"],[2907,2983,"I won't allow it!"],[3100,3164,"I object!"],[3547,3620,"You brat,"],[3664,3732,"what are you doing here?"],[3739,3829,"Get out of here right now."],[3979,4035,"Vivian,"],[4284,4352,"you can't marry him."],[4367,4488,"We're already divorced."],[4524,4644,"Who I choose to marry now"],[4660,4752,"is none of your business."],[5860,5979,"We aren't divorced yet."],[6007,6091,"If you marry him,"],[6107,6188,"that's bigamy."],[6296,6352,"Colton,"],[6423,6515,"didn't I already"],[6515,6643,"step aside for you and Jessie?"],[6904,6976,"Colton,"],[7071,7148,"let go of me."],[7187,7235,"No, I won't."],[7243,7312,"I'll never let you go."]],"65":[[163,216,"Colton,"],[248,343,"let go of me."],[551,687,"The one you should hold and care for"],[744,787,"isn't me."],[851,1011,"I've never liked Jessie,"],[1180,1275,"and I've never touched her."],[1311,1375,"What?"],[1591,1648,"Actually,"],[1680,1793,"she's my driver's daughter."],[1967,2083,"She had a twin sister"],[2160,2228,"named Gemma."],[2367,2500,"We grew up together."],[2939,2992,"Back then,"],[3012,3071,"I liked her."],[3170,3335,"One time, I asked her out,"],[3384,3492,"but I didn't get there in time,"],[3532,3667,"so she was killed."],[3715,3824,"Her parents couldn't"],[3824,3900,"handle the blow."],[4043,4120,"They got distracted"],[4120,4175,"while driving,"],[4239,4320,"and died in an accident."],[4707,4807,"Before they died,"],[4900,5043,"they asked us to take care of Jessie."],[5132,5211,"I've always felt"],[5260,5384,"that I got them killed."],[5403,5432,"I"],[5520,5656,"I didn't deserve to be happy."],[5679,5800,"So from then on,"],[5835,5943,"I gave up on myself."],[5992,6097,"You mean"],[6171,6239,"you never"],[6239,6347,"liked Jessie?"],[6396,6451,"Of course not."],[6651,6707,"I've always"],[6707,6776,"seen her as a sister."],[6979,7123,"She has a congenital bleeding disorder"],[7168,7259,"and a rare blood type."],[7484,7520,"That's why"],[7520,7576,"on that day, I"],[7576,7671,"I rushed her to the hospital,"],[7764,7843,"so the doctors could save her."],[7912,7943,"Mm."],[7979,8095,"I already know all of that."],[8151,8212,"If you're done,"],[8212,8270,"you can leave."]],"66":[[36,200,"I've explained everything clearly!"],[408,451,"Why won't"],[451,567,"you just forgive me?"],[803,891,"Are you really going to"],[891,967,"marry this man?"],[1396,1459,"Why?"],[1508,1655,"Because from the very start,"],[1732,1867,"you never loved me."],[1948,2003,"Colton,"],[2076,2132,"in the beginning,"],[2132,2248,"I did treat marrying you"],[2248,2380,"like it was just a job."],[2460,2539,"But I forgot"],[2616,2735,"that I'm not a machine."],[2735,2828,"I'm human too,"],[2923,3060,"and I fell for you."],[3403,3471,"Vivian,"],[3584,3635,"what did you say?"],[3679,3760,"You like me?"],[3803,3839,"Yes."],[4128,4264,"At first, I did like you."],[4292,4407,"But you despised me."],[4471,4611,"You wanted out of this marriage."],[4911,4992,"It was my fault."],[5100,5167,"I shouldn't have"],[5167,5284,"forced you to marry me."],[5411,5464,"Colton,"],[5464,5567,"let's get a divorce."],[5603,5707,"It's better for both of us."]],"67":[[104,132,"No."],[184,248,"I don't want a divorce."],[324,375,"Vivian,"],[375,516,"from the moment I saw you,"],[548,675,"I fell for you."],[883,956,"But I kept"],[956,1072,"suppressing my feelings."],[1091,1188,"I told myself"],[1256,1383,"that someone like me"],[1383,1524,"should spend my life atoning."],[1635,1896,"But after you left,"],[2012,2055,"I realized"],[2055,2176,"I can't live without you."],[3535,3612,"Are you hurt?"],[4275,4352,"Vivian"],[4467,4517,"Vivian,"],[4535,4588,"please,"],[4656,4747,"give me another chance"],[4971,5088,"to prove myself."],[5156,5223,"Okay?"],[5567,5620,"I swear,"],[5720,5860,"I'll do whatever you say"],[5979,6024,"and always"],[6167,6243,"love you."],[6664,6734,"Sister,"],[6748,6915,"he seems really sincere."],[6971,7092,"Why not give him a chance?"]],"68":[[451,532,"Sister."],[724,864,"But if we leave,"],[1030,1188,"what about these kids here?"],[1771,1844,"You're right."],[2264,2348,"Don't worry."],[2551,2651,"I've taken care of everything."],[2716,2744,"Mom?"],[2825,2907,"What are you doing here?"],[2935,3007,"What do you think?"],[3007,3071,"You brat."],[3112,3239,"If I counted on you to win her back,"],[3239,3332,"I would've died of frustration long ago."],[3664,3794,"Vivian, Nora,"],[3956,4056,"don't worry."],[4215,4300,"I plan to"],[4360,4471,"invest in a new project"],[4503,4647,"to build a new orphanage"],[4752,4835,"and a school."],[4911,4967,"That way,"],[4984,5124,"we can help more orphans"],[5239,5343,"and let them"],[5343,5471,"grow up happily here."],[5503,5560,"Then,"],[5560,5656,"you can put your minds at ease."],[5807,5896,"Thank you, Mrs. Johnson."],[6000,6064,"Vivian,"],[6103,6184,"what did you call me?"],[6307,6343,"I"],[6700,6743,"Mom."],[6828,6859,"Yes!"],[7128,7164,"Yay!"],[7292,7328,"Honey,"],[7551,7635,"you're not divorcing me?"],[7800,7898,"You're coming home with me?"]],"69":[[52,156,"Who is going home with you?"],[548,632,"I haven't agreed to that yet."],[700,843,"But aren't we already married?"],[1043,1075,"Back then,"],[1075,1227,"didn't you refuse to marry me?"],[1240,1283,"Now,"],[1283,1424,"I haven't agreed to marry you again."],[1519,1616,"I agree."],[1616,1703,"I'm willing."],[2632,2683,"Nora,"],[2716,2760,"what's wrong?"],[3064,3207,"My stomach suddenly feels weird,"],[3235,3328,"and I feel a bit dizzy."],[3407,3515,"Did you maybe"],[3515,3624,"eat something bad?"],[3747,3811,"Nora,"],[3856,3960,"don't tell me"],[4024,4143,"you're pregnant?"],[4620,4696,"I'm going to be a dad!"],[5064,5175,"I might be."],[6211,6284,"This is"],[6296,6407,"an engagement ring."],[6464,6551,"I bought it a while ago."],[6604,6664,"I didn't expect"],[6792,6935,"to come home and find divorce papers."],[7107,7151,"Honey,"],[7207,7259,"now,"],[7292,7400,"you're the mother of my child."],[7400,7484,"You can't run away anymore."],[7671,7723,"Don't worry,"],[7751,7843,"I'll take good care of you two."],[7904,7992,"Great, great."],[8031,8084,"I need to"],[8084,8179,"get people to start"],[8192,8243,"preparing"],[8243,8356,"for your wedding."],[8487,8543,"Otherwise,"],[8543,8620,"when your belly gets big,"],[8668,8840,"you won't look good in a wedding dress."],[8912,8940,"Mhm."]],"70":[[160,216,"Honey,"],[291,436,"since Nora is marrying my brother,"],[496,644,"can you bear to leave her all alone"],[644,732,"living with the Johnsons?"],[763,848,"Of course not."],[872,988,"I'll move in with the Johnsons"],[1024,1148,"to take care of Nora myself."],[1300,1388,"As for you,"],[1451,1619,"once you pass my test,"],[1644,1783,"we'll talk about marriage."],[2692,2748,"Don't worry."],[2803,2855,"It's my turn"],[2855,2919,"to chase you now."],[3543,3624,"Come on, everyone."],[3624,3684,"Kids,"],[3692,3864,"come take a family photo with us!"],[3884,3915,"Come on."]]}