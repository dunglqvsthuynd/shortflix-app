[5832,5884,"Be careful!"],[6815,6884,"Are you okay?"],[6992,7079,"Are you hurt?"],[7631,7712,"Colton,"],[7764,7904,"that was quite a kick."],[7943,8048,"I didn't realize"],[8100,8235,"you could play the hero"],[8379,8523,"and protect your wife."]],"24":[[396,536,"Don't flatter yourself."],[596,827,"I just don't want people saying I'm a jinx."],[1388,1472,"Evan Shaw,"],[1472,1588,"you've lost your mind."],[1644,1735,"I never imagined"],[1760,1839,"that I'd raise"],[1845,1960,"two ingrates like you!"],[2044,2144,"As for the evidence of your crimes,"],[2148,2251,"I'll have my assistant compile it"],[2251,2319,"and hand it to the police."],[2564,2667,"From now on,"],[2692,2787,"you have nothing to do"],[2787,2896,"with the Johnsons."],[2928,2967,"Get out!"],[3639,3684,"Hmph."],[4322,4402,"Vivian,"],[4432,4584,"I'm glad you told me about this."],[4600,4652,"Otherwise,"],[4652,4807,"I'd still be getting fooled by them."],[4896,4928,"Mom,"],[4952,5084,"it was the right thing to do."],[5384,5479,"But,"],[5528,5720,"Colton seems to have changed quite a bit"],[5735,5884,"since getting married."],[6360,6443,"I remember"],[6459,6628,"you both enjoy music."],[6751,6831,"Colton even started"],[6831,6959,"a band of his own."],[7059,7179,"How about tomorrow,"],[7235,7276,"Vivian,"],[7312,7459,"you go to Colton's studio?"],[7515,7579,"That way,"],[7584,7756,"you can keep an eye on him for me,"],[7779,7887,"and keep yourself busy too."],[7948,8020,"You can also"],[8020,8140,"work on your relationship."],[8264,8412,"Sure. Thanks, Mom."],[8812,8892,"Hey!"],[9042,9124,"I don't agree."],[9284,9384,"I'm your mother."],[9476,9664,"I call the shots in this house."],[9707,9868,"If you dare upset Vivian,"],[9879,9948,"I'm telling you,"],[9948,10056,"you'll kneel on"],[10056,10179,"a washboard like a good boy."],[10476,10659,"I can't stay in this house anymore!"],[10687,10748,"I rank lower"],[10776,11020,"than that crazy woman!"],[11220,11351,"Glad you realize that."],[11407,11548,"Treating your wife well"],[11548,11731,"is how a family prospers."],[12919,12984,"Sister,"],[13008,13087,"are you really"],[13087,13240,"going to join Colton's band?"],[13643,13708,"Of course."],[13715,13863,"Proximity gives me the edge."],[13875,13963,"If I don't get on the inside,"],[13984,14131,"how will I snag a rich husband?"],[15244,15336,"Are you busy?"]],"25":[[156,212,"Are you busy?"],[361,508,"No, not really."],[559,740,"I'm just sketching before bed."],[967,1083,"Put your number in here."],[1100,1235,"You want my number?"],[1332,1359,"Yeah."],[1416,1524,"Since you married me,"],[1572,1687,"you are my wife."],[1712,1832,"It's only right that I protect you."],[1892,1951,"If anything"],[1951,2035,"like today happens,"],[2128,2219,"contact me immediately."],[2992,3123,"Is this your design sketch?"],[3392,3611,"Is it ugly?"],[3715,3920,"I've loved drawing and designing clothes"],[3920,4011,"since I was little."],[4039,4175,"Do you know why?"],[4203,4256,"Why?"],[4332,4556,"After my sister and I were kicked out,"],[4575,4724,"we grew up in an orphanage."],[4771,4915,"The kids there"],[4928,5128,"wore donated old clothes."],[5164,5311,"Back then, I thought,"],[5339,5435,"when I grew up,"],[5456,5600,"I'd design lots of"],[5600,5752,"beautiful new clothes"],[5752,5879,"for the younger kids."],[5928,5992,"That's why"],[6035,6147,"you want to make a lot of money."],[6203,6284,"Of course."],[6360,6451,"But,"],[6451,6568,"it's too bad that because"],[6568,6684,"I grew up in an orphanage,"],[6712,6871,"I never got the chance to study design."],[6971,7068,"I guess"],[7092,7176,"my dream"],[7176,7312,"would never come true."],[7451,7523,"Who says?"],[7684,7756,"I think"],[7790,7918,"you have a real talent for design."],[7943,8007,"Besides,"],[8007,8087,"I heard that"],[8087,8179,"D Studio is currently"],[8179,8284,"hiring fashion designers."],[8335,8487,"You should give it a try."],[8720,8820,"Me?"],[8984,9284,"But I have no experience or degree."],[9584,9656,"I heard"],[9684,9864,"D Studio only cares about talent and skill,"],[9912,10048,"so just go for it."],[10359,10556,"Do you really think I can?"],[10640,10700,"Of course."],[10759,10843,"You're talented"],[10864,10935,"and hardworking."],[10992,11112,"You're bound to succeed."],[11423,11476,"Alright,"],[11512,11620,"it's getting late."],[11620,11664,"Good night."],[14819,14924,"Send a message to HR"],[14924,15019,"at D Studio for me."],[15047,15143,"Tell them to get my wife"],[15143,15296,"into the design department."]],"26":[[1135,1208,"Vivian."],[1259,1391,"Don't think because my mom backs you,"],[1391,1464,"I'll accept"],[1464,1527,"this marriage."],[1548,1655,"I don't love you."],[1764,1860,"When we go inside,"],[1907,2028,"watch what you say."],[3076,3180,"Colton, you're here."],[3352,3452,"We have prepared"],[3452,3611,"a big surprise for you today."],[4611,4684,"Colton,"],[4724,4796,"what's going on?"],[4828,4928,"Why did you bring her?"],[5084,5143,"You aren't"],[5156,5279,"planning to spend your life with her?"],[5411,5460,"Exactly."],[5503,5643,"You don't even like her."],[5767,5860,"The one you love is..."],[5860,5928,"Tsk."],[6143,6243,"If that incident"],[6243,6352,"hadn't happened,"],[6367,6471,"you'd be married by now."],[6504,6584,"Enough."],[6585,6684,"Even if I don't like her,"],[6712,6787,"she is my wife."],[6800,6864,"It's not"],[6864,6951,"your place to judge her."],[7720,7820,"Hi."],[8195,8279,"Our band has"],[8287,8428,"a new commercial gig coming up."],[8531,8620,"The new songs need"],[8620,8679,"a guitarist"],[8707,8787,"and a female singer."],[8828,8887,"Can you do it?"],[8968,9031,"Of course."],[9048,9207,"I worked at a bar before,"],[9264,9395,"and learned from the house band."],[9607,9748,"You just picked it up in a bar."],[9867,9992,"With skills like yours,"],[10004,10179,"how could you qualify for a proper gig?"]],"27":[[25,200,"You just picked it up in a bar."],[268,400,"With skills like yours,"],[440,508,"how can you"],[508,592,"qualify for a proper gig?"],[712,771,"Hi!"],[1419,1559,"Colton!"],[1559,1639,"I'm back."],[1639,1719,"Aren't you happy?"],[1800,1883,"Who is this?"],[1900,2016,"Don't tell me she's a rival."],[2264,2323,"I'm happy."],[2603,2651,"Why not"],[2651,2739,"tell me you were coming back?"],[3012,3080,"Colton,"],[3103,3243,"how do you like this surprise?"],[3579,3667,"Colton."],[3899,3987,"Who is she?"],[4124,4215,"She's the one I used to..."],[4215,4384,"You must be Colton's"],[4384,4507,"new wife."],[4747,4875,"I'm Jessie."],[4894,5101,"I've known Colton since we were little."],[5239,5352,"We are actually"],[5364,5573,"childhood sweethearts."],[5611,5720,"Childhood sweethearts"],[5740,5891,"Did Colton not want to marry me"],[5932,5984,"because"],[5984,6100,"he's in love with her?"],[6179,6232,"Is that it?"],[6303,6420,"If you're just"],[6420,6558,"childhood sweethearts,"],[6648,6740,"then don't get"],[6740,6856,"so close to a married man"],[6895,6979,"like that."],[7340,7451,"People will gossip,"],[7476,7564,"and it won't be good."],[7851,8043,"Colton,"],[8127,8264,"does she"],[8300,8464,"not welcome me back?"],[9043,9107,"No."],[9264,9351,"That's good."],[9435,9536,"Mrs. Johnson,"],[9571,9684,"I'm sorry."],[9848,10051,"My family has all passed away."],[10156,10295,"Now Colton and these guys"],[10295,10451,"are the only family I have."],[10540,10592,"So,"],[10592,10700,"as soon as I got off the plane,"],[10700,10820,"I came straight to the studio"],[10823,10915,"to see everyone."],[10931,11007,"Hey,"],[11015,11056,"I thought"],[11056,11164,"you'd forgotten us."],[11192,11312,"How could I?"],[11331,11543,"I've been studying abroad these years"],[11543,11643,"and seeing the world."],[11900,11956,"By the way,"],[12031,12164,"since I just got back,"],[12207,12356,"could you guys come with me"],[12364,12512,"to buy some new furniture?"],[12863,13036,"We can have dinner tonight"],[13056,13124,"and catch up."]],"28":[[0,160,"We can have dinner tonight,"],[184,252,"and catch up."],[287,343,"Sure, sounds great."],[372,416,"Tonight,"],[424,491,"I'll do the cooking."],[740,851,"Colton,"],[883,1043,"we haven't seen each other in years."],[1132,1256,"Having an outsider here"],[1316,1508,"will spoil our gathering."],[1696,1796,"Why don't we"],[1823,1983,"leave her out this time?"],[2196,2335,"Vivian, that gold-digging b*tch,"],[2348,2451,"is clinging to me now."],[2507,2619,"If I can use Jessie to"],[2619,2700,"get her to divorce,"],[2716,2812,"that would be great."],[2948,3000,"Sure."],[3067,3180,"Jessie hasn't been back for a long time."],[3271,3392,"I'm going to help her move."],[3432,3560,"You go home by yourself tonight."],[3714,3778,"Let's go."],[4743,4875,"Colton,"],[4940,5052,"you b*stard."],[5088,5235,"Don't think using this trick"],[5235,5375,"will make me back down."],[6512,6679,"Here we go."],[6895,6940,"Come on,"],[7123,7259,"let's celebrate Jessie's return."],[7268,7356,"Cheers."],[7412,7492,"Thanks."],[7528,7640,"By the way, Jessie,"],[7731,7831,"you're not"],[7840,7964,"leaving again, are you?"],[8012,8100,"No, I'm staying."],[8159,8292,"I'm not young anymore."],[8328,8459,"It's time I settled down"],[8479,8615,"and thought about marriage."],[9031,9092,"Colton,"],[9212,9320,"what are you waiting for?"],[9358,9507,"Jessie's practically spelling it out."],[9548,9684,"Aren't you going to say something?"]],"29":[[204,275,"Say what?"],[432,548,"I have no interest"],[571,659,"in romance."],[767,864,"I've always seen her as a sister."],[1048,1124,"Don't talk nonsense."],[2787,2844,"Jessie,"],[2896,2976,"don't be sad."],[3016,3096,"Colton"],[3103,3220,"never dated anyone."],[3279,3384,"I think he rejected you"],[3396,3503,"all because of Vivian."],[3535,3652,"Vivian."],[3667,3735,"It's okay."],[3764,3864,"Now that you're back,"],[3888,4032,"Colton will be yours sooner or later."],[4624,4900,"♪ Small dimples, long eyelashes ♪"],[4900,5100,"♪ Your most beautiful trait ♪"],[5100,5306,"♪ Keep me sleepless every day ♪"],[6007,6220,"Friend request from Jessie"],[7459,7564,"Colton"],[7612,7704,"how old is he to"],[7704,7840,"still be playing these games?"],[8112,8203,"What is it?"],[8543,8604,"Sister,"],[8668,8835,"so the person Colton likes"],[8835,8900,"looks like this."],[8984,9195,"The person Colton likes?"],[9195,9256,"Yeah."],[9300,9395,"I only learned about it"],[9395,9515,"from their chat recently."],[9620,9851,"I heard Colton won't marry"],[9851,9948,"because he already has"],[9948,10040,"someone he likes."],[10109,10276,"As for why they broke up,"],[10306,10423,"no one dares mention it."],[10528,10615,"I guess"],[10648,10759,"it's exactly because of"],[10759,10887,"those dark secrets."],[10915,11114,"The brothers strongly resist marriage,"],[11140,11243,"so the two of us"],[11243,11312,"got lucky"],[11312,11420,"and married into this family."],[11907,11956,"Sister,"],[12005,12077,"if Colton"],[12123,12223,"really wants"],[12223,12335,"to divorce you,"],[12351,12456,"what are you gonna do?"]],"30":[[1291,1391,"Are you hurt?"],[1771,1907,"There's a show in Riverton the day after tomorrow."],[1907,2003,"Make sure you're ready."],[2003,2103,"See you in Riverton."],[2260,2383,"Of course I won't divorce."],[2467,2587,"I'm Colton's lawful wife,"],[2587,2687,"after all."],[2880,2935,"Anyway,"],[3007,3107,"back to my practice."],[3187,3328,"I'll sketch some designs too,"],[3367,3488,"and send my resume to D Studio."],[3488,3584,"Let's do our best."],[5047,5139,"Vivian,"],[5148,5288,"why are you so late?"],[5300,5400,"You kept everyone waiting."],[5415,5492,"You're not famous yet,"],[5492,5607,"but you're acting like a big shot."],[5815,5903,"If you don't wanna do it,"],[5903,6003,"just get the h*ll out!"],[6003,6079,"Enough."],[6256,6315,"Cut the cr*p."],[6384,6464,"Go get the paperwork done."],[6995,7076,"Vivian,"],[7212,7304,"you must have seen"],[7304,7448,"the post I made."]],"31":[[143,279,"You mean those petty tricks of yours?"],[344,449,"Petty tricks."],[567,679,"You know, don't you,"],[679,796,"that the one Colton has loved"],[796,903,"has always been me."],[919,1019,"If I hadn't been so willful"],[1019,1127,"and gone abroad back then,"],[1188,1340,"we'd have been married long ago."],[1391,1548,"You went abroad,"],[1559,1692,"you didn't die."],[1703,1796,"If Colton"],[1796,1903,"really liked you,"],[1971,2123,"he would have chased after you."],[2171,2328,"What do you know?"],[2355,2564,"He is a young master of the Johnsons."],[2592,2667,"He just couldn't"],[2687,2800,"put aside his pride."],[2878,2969,"Do you believe that?"],[3241,3364,"I don't."],[3539,3607,"Fine."],[3607,3684,"Vivian,"],[3715,3896,"I'll make you believe it today."],[3932,4043,"I'm going to show you"],[4071,4143,"who Colton"],[4143,4184,"truly holds"],[4188,4307,"in his heart."],[5411,5567,"You're seriously faking a fall?"],[5807,5900,"What's going on?"],[5971,6100,"Colton,"],[6111,6200,"she fell on her"],[6200,6271,"Colton,"],[6292,6388,"it's all my fault."],[6607,6723,"I just"],[6756,6987,"wanted to talk to Ms. Collins,"],[7004,7076,"but"],[7135,7200,"she's pissed"],[7200,7295,"as you helped me move,"],[7295,7376,"so she took it out on me."],[7435,7531,"I"],[7584,7707,"You're already married."],[7731,7868,"I shouldn't have bothered you."],[8212,8345,"I'll leave right now."],[9156,9223,"Jessie!"],[9492,9543,"Oh no."],[9576,9673,"Jessie has a clotting disorder."],[9695,9800,"She could bleed to death!"],[9831,9904,"Vivian!"],[9915,9995,"You lunatic."],[9995,10084,"I'll make you pay"],[10084,10205,"if anything happens to Jessie!"],[10328,10443,"Colton,"],[10468,10584,"I didn't do it."],[10612,10779,"Vivian!"],[10792,10940,"Go to hell!"],[11676,11784,"Idiot!"],[11835,11884,"You men"],[11884,11987,"love manipulative bi*ches, don't you?"],[12020,12151,"If they told you"],[12151,12235,"to eat sh*t,"],[12235,12331,"you'd do it."],[12331,12391,"Exactly!"]],"32":[[303,391,"What are you doing?"],[408,544,"Security! Get over here!"],[675,771,"Miss, are you okay?"],[1435,1511,"Ms. Collins,"],[1519,1600,"you're awake."],[1760,1864,"Your arm is injured,"],[1876,1964,"so you shouldn't move."],[5028,5141,"Since yesterday,"],[5235,5375,"Colton has been by my side."],[5411,5500,"I knew it."],[5524,5711,"As long as that woman isn't here,"],[5732,5960,"Colton only cares about me."],[7104,7192,"Jessie is sick."],[7225,7368,"I'm with her at the hospital."],[7456,7528,"Vivian,"],[7540,7679,"the one I love is back."],[7720,7859,"You better ask for a divorce"],[7904,8028,"and leave the Johnsons on your own."],[8680,8743,"Colton,"],[8879,9068,"do you hate me that much?"],[9723,9831,"Why did you take my phone?"]],"33":[[867,1000,"Why did you take my phone?"],[1556,1676,"Colton,"],[1676,1839,"your phone was ringing just now."],[1871,2028,"I saw you were asleep,"],[2032,2203,"so I hung up for you."],[2983,3112,"Don't touch my phone again."],[3720,3807,"The doctor said you're fine."],[3839,3943,"You just lost too much blood."],[3947,4035,"Just rest a bit and you'll be fine."],[4064,4156,"I've got work with the band,"],[4160,4243,"so I'm heading out."],[4532,4592,"Colton,"],[4639,4792,"are you really not staying with me?"],[5032,5115,"Jessie,"],[5128,5211,"don't forget,"],[5215,5356,"I only promised your sister"],[5388,5443,"to take care of you."],[5479,5567,"Aside from that,"],[5615,5720,"I have no obligation to you."],[6184,6320,"My sister, my sister"],[6343,6468,"I don't believe"],[6500,6720,"that you really don't have feelings for me."],[7184,7264,"Honey,"],[7264,7371,"when are you coming back?"],[7515,7620,"Strange."],[7628,7707,"Vivian"],[7707,7764,"Why hasn't she"],[7768,7888,"messaged me today?"],[8428,8479,"Colton,"],[8492,8659,"what's going on with Vivian?"],[8668,8792,"She hasn't arrived at the venue,"],[8804,8920,"and hasn't checked into the hotel."],[8940,9007,"Is it just because you"],[9007,9115,"took Jessie to the hospital"],[9131,9271,"that she's ignoring the band?"],[9271,9343,"What did you say?"],[9359,9479,"Vivian isn't at the hotel?"],[11471,11568,"Sis, why did you hang up"],[11568,11633,"the phone?"],[11735,11835,"Right now, I"],[11904,12020,"I don't want to hear him speak."]],"34":[[24,138,"Why should you?"],[162,300,"He made you perform,"],[300,368,"then abandoned you,"],[368,524,"and almost got you killed."],[1807,1896,"Vivian."],[1900,1987,"Where are you right now?"],[2016,2155,"Why are you yelling, Colton?"],[2164,2223,"It's all because of you"],[2223,2328,"that my sister almost died."],[2364,2487,"I'll settle this with you later."],[2516,2583,"What did you say?"],[2583,2683,"Did something happen to Vivian?"],[2728,2816,"That's right."],[2839,2928,"But don't worry."],[2976,3087,"My sister doesn't need you."],[3087,3183,"I'll take care of her."],[5679,5756,"Vivian."],[6612,6687,"Vivian."],[6740,6868,"Are you okay?"],[7068,7164,"Relax."],[7171,7240,"Thanks to you,"],[7248,7360,"she won't die."],[7743,7784,"Vivian."],[7784,7835,"I'm sorry."],[7864,7935,"I"],[8000,8140,"I really didn't know you were in danger."],[8352,8431,"Colton."],[8479,8607,"I know the only person"],[8659,8784,"you care about is Jessie."],[8843,8948,"Are you done?"],[9020,9123,"If you're done, leave."],[9228,9304,"Nora."],[9304,9343,"Let's go."],[10357,10460,"This woman"],[10487,10576,"Why is she trying to be so tough?"],[11635,11700,"Hey!"],[11868,11943,"Colton!"],[11951,12020,"What are you doing?"],[12020,12092,"Put me down!"],[12115,12200,"Vivian."],[12256,12351,"You crazy bi*ch!"],[12384,12523,"Move again, and I'll throw you in the river!"]],"35":[[128,196,"Colton!"],[227,275,"What are you doing?"],[275,364,"Put me down!"],[448,512,"Vivian,"],[555,644,"you crazy bi*ch."],[700,736,"Move again,"],[736,832,"I'll throw you out!"],[867,911,"Hey!"],[996,1088,"Put me down!"],[2987,3035,"No need."],[3123,3180,"I can do it myself."],[3584,3656,"Vivian,"],[3732,3856,"It's my fault"],[3911,3992,"you got hurt,"],[4096,4235,"so I came to take care of you."],[4475,4547,"And I didn't mean to"],[4547,4632,"leave you behind."],[4679,4767,"It's because Jessie"],[4788,4847,"has a condition."],[4915,5060,"She could die from blood loss."],[5143,5228,"I know."],[5275,5432,"So go take care of Jessie."],[5484,5571,"I don't need your help."],[6407,6484,"Vivian,"],[6716,6851,"are you throwing a fit?"],[7384,7451,"Who are you"],[7451,7530,"to get angry with me?"],[7533,7664,"You're just forced your way"],[7664,7779,"into this marriage for the money."],[7792,7879,"You don't actually think"],[7879,7995,"that makes you my wife, do you?"],[8056,8164,"You're the one refusing to"],[8164,8231,"get a divorce!"],[8259,8368,"You're the one refusing to"],[8368,8463,"get a divorce."],[10620,10795,"Vivian, oh Vivian."],[10911,11051,"You're such a fool."],[11187,11304,"You thought you were"],[11304,11431,"marrying just for the money,"],[11497,11717,"but why couldn't you guard your heart?"],[11815,11868,"Why fell for a man"],[11868,12015,"whose loves someone else."]],"36":[[2413,2504,"You're awake."],[2518,2626,"How are you feeling?"],[2873,2949,"Much better."],[2994,3102,"Thanks for asking."],[3707,3756,"By the way,"],[3788,3896,"there have been a lot of"],[3896,4032,"well-paid gigs lately."],[4135,4211,"Do you want to"],[4217,4285,"No thanks."],[4415,4560,"I won't be going to the studio anymore."],[4676,4720,"Ma'am,"],[4745,4801,"your breakfast."],[5024,5139,"You're not going to the studio?"],[5235,5388,"Didn't you say you wanted to make money?"],[5462,5518,"Then you..."],[5530,5634,"I'll find a job myself."],[5885,5954,"Don't worry,"],[6003,6092,"I won't cling to you"],[6092,6156,"like before."],[6265,6365,"Once I find a job and"],[6393,6465,"make enough money,"],[6505,6605,"I'll leave here."],[7920,7971,"Whether"],[7971,8071,"she goes to the studio"],[8196,8292,"is none of my business."],[8723,8839,"Why do I care about her?"],[11529,11585,"Vivian,"],[11594,11678,"good news."],[11721,11849,"When you sang at the bar,"],[11872,12020,"a musician named Mason Duke"],[12038,12126,"spotted you."],[12152,12260,"He wants to sign you."],[12306,12450,"Come meet him at the bar tonight."],[12558,12638,"Really?"],[12683,12787,"I'll be there on time!"]],"37":[[156,227,"Sis,"],[235,331,"what's the good news?"],[459,528,"Nora,"],[567,675,"an agent said"],[675,744,"he spotted me"],[763,880,"and wants to sign me as an artist."],[1332,1511,"Is this Ms. Nora Collins?"],[1532,1660,"This is HR at D Studio."],[1683,1755,"We saw"],[1755,1883,"your resume online,"],[1907,2051,"and we'd like to set up an interview."],[2076,2219,"Are you available this afternoon?"],[2232,2433,"Did you say D Studio?"],[2983,3083,"Yes, I'm available!"],[3479,3547,"Sister,"],[3556,3743,"I have an interview at D Studio!"],[4728,4864,"From now on,"],[4956,5147,"I'm going to be a famous singer."],[5403,5452,"Superstar,"],[5484,5592,"can I have an autograph?"],[6207,6324,"And I'll be the most famous"],[6324,6431,"fashion designer."],[6907,7048,"Nice to meet you, Ms. Designer."],[7298,7400,"Once I make some money,"],[7411,7543,"I can finally renovate"],[7543,7604,"the orphanage."],[7656,7728,"Then the kids"],[7743,7807,"won't have to"],[7807,7912,"worry about school fees anymore."],[7912,8084,"And I'll take care of all the kids'"],[8087,8215,"clothes."],[8368,8492,"Let's hurry and get ready."],[8526,8643,"We need to secure those contracts."],[8643,8753,"Okay, let's do it."],[9107,9180,"Vivian!"],[10951,11023,"Nora!"],[11128,11204,"Tell me,"],[11271,11376,"where did your sister go?"],[12207,12271,"Nora,"],[12271,12379,"I'm asking you a question!"],[12615,12712,"Who are you to me?"],[12721,12825,"Why should I tell you anything?"],[14440,14500,"Tell me!"],[14587,14700,"Where did Vivian go?"],[14875,14978,"I think she said"],[14988,15096,"she was going to a bar"],[15112,15215,"to sign with a guy"],[15243,15391,"named Mason Duke."],[15652,15724,"What?"],[15819,15891,"Mason Duke?"],[16268,16400,"That old man,"],[16456,16510,"he got"],[16516,16656,"many women killed."],[16663,16808,"Does Vivian have a death wish?"]],"38":[[184,256,"No, no."],[2296,2351,"Vivian,"],[2435,2564,"where on earth 