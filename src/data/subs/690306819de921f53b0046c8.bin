n!"],[1238,1334,"Let go of me!"],[1401,1497,"This is not the time"],[1497,1630,"for one of your tantrums, Sara."],[1672,1889,"Ryan, we grew up together."],[1939,2039,"Now you're siding with this"],[2068,2218,"backwater charity case?"],[2252,2398,"No, I'm here to make sure"],[2398,2523,"that you don't bully anybody."],[2544,2598,"Otherwise I'm going to"],[2598,2719,"have to tell your grandpa."],[3778,3859,"Here."],[4888,4963,"Come on, let's go."],[5476,5572,"That bitch"],[5618,5780,"dares steal Ryan from me?"],[5893,5980,"I'll ruin her."],[6623,6669,"Sara,"],[6827,6923,"I think I know a way"],[6923,7027,"we can get back at her."]],"9":[[1355,1430,"Oh my."],[1484,1551,"Dolores,"],[1609,1680,"are you okay?"],[1680,1847,"My God, your nose is so red."],[1876,1918,"No, no."],[1926,2047,"I'm fine, I'm fine."],[2056,2118,"Alright."],[2231,2348,"Thank you for standing"],[2348,2431,"up for me today."],[2544,2581,"Yeah."],[2660,2698,"Um,"],[2723,2786,"Ryan King."],[2998,3069,"Nice to meet you."],[3315,3395,"Dolores Cooper."],[3449,3532,"It's nice to meet you too."],[3812,3908,"Oh, Dolores, look out!"],[4454,4596,"Uh, I'm, I'm going to be late"],[4596,4704,"for art club sign-ups."],[4775,4838,"I gotta go."],[4913,4963,"Thank you."],[5251,5284,"Wow."],[5409,5484,"She's adorable."],[5597,5734,"Wait, did she just say art club?"],[5826,5864,"Damn it."],[5960,6022,"Dolores!"],[7015,7069,"Oh my God,"],[7069,7173,"that's the scholarship girl,"],[7173,7211,"right?"],[7282,7419,"I can't believe she got invited"],[7419,7632,"to the Elite Arts Group Society."],[7653,7795,"That's the most exclusive place"],[7795,7870,"on campus."],[7907,8020,"Everyone from that group"],[8020,8095,"ends up famous."],[8241,8312,"This is it."],[8383,8521,"Rachel Grant's art society."],[8571,8646,"My idol."],[8687,8821,"I'm one step closer to her."],[10239,10301,"What?"]],"10":[[8,95,"What do you want from me?"],[125,241,"I was invited here."],[262,362,"Oh my God,"],[379,529,"you actually think someone like you"],[529,663,"belongs in a society"],[663,809,"created by Sara's mom?"],[817,980,"Sara runs this place."],[1009,1071,"The only reason"],[1071,1209,"why your cheap ass got in"],[1209,1305,"was so we could teach you"],[1305,1384,"some manners."],[1443,1584,"You think money makes you better?"],[1668,1764,"All the cash in the world"],[1764,1826,"couldn't cover up"],[1826,1931,"how rotten you all are."],[1997,2156,"Just let me out!"],[2339,2640,"God, you reek of desperation."],[2715,2773,"Let me help you"],[2773,3132,"scrub off that cheap, dirty scent."],[3432,3482,"What?"],[3586,3741,"No, no, please, please."],[3757,3924,"Just let me go, please."],[3974,4179,"Stop, don't do it, please, please."],[6327,6406,"Let me go!"],[6710,6944,"I hope you like raw sewage, bitch."],[7490,7540,"Let me go"],[7540,7670,"or I'll report you to the dean."],[7807,7991,"My family's money runs the school,"],[8033,8087,"bitch."],[8149,8304,"Nobody's gonna save you."],[8387,8612,"This is what you get for crossing me"],[8633,8796,"and for flirting with Ryan."],[9442,9505,"Sara!"],[9580,9697,"Get your hands off her!"],[9697,9776,"That's enough!"],[11102,11269,"What the hell is wrong with you?"],[11332,11461,"Why are you being so cruel?"],[11507,11632,"So this is what it is now?"],[11711,11878,"You've turned on me twice today"],[11895,12003,"for this nobody."],[12099,12328,"Who dare mess"],[12328,12529,"with my granddaughter?"]],"11":[[617,788,"If I hadn't decided to check"],[788,900,"on my granddaughter,"],[900,1117,"I wouldn't know she was being bullied"],[1151,1330,"on her first day."],[1655,1951,"You are the girl from this morning."],[2143,2298,"Grandpa, thank God you're here!"],[2331,2444,"They're all turning on me!"],[2573,2656,"What's happening?"],[2756,2952,"Well, she ruined my dress"],[2952,3128,"so I decided to teach her a lesson,"],[3128,3249,"but Ryan,"],[3303,3461,"he took her side over mine."],[3486,3599,"Mr. Grant, that is not-"],[4154,4266,"Oh, Dolores."],[4308,4466,"She forgot her lunch again."],[4763,4838,"Where are you going?"],[5030,5213,"Just, going out for a walk."],[6189,6322,"Where is that cursed brat?"],[6443,6560,"You let her out again, didn't you?"]],"12":[[4,125,"You let her out again, didn't you?"],[417,471,"Yes."],[613,825,"I sent her off to school."],[942,996,"Molly,"],[1009,1226,"that kid is special and you know it."],[1272,1401,"She can't just waste away"],[1401,1534,"in this dump forever."],[1547,1701,"Well, that's not your decision to make."],[1701,1805,"She's my daughter,"],[1839,1960,"so I'm gonna go get her"],[1960,2106,"and bring her back here right now."],[2143,2185,"No!"],[2302,2556,"I won't let you crush her dreams."],[2623,2915,"That school is the top art academy"],[2915,3073,"in the entire country."],[3140,3257,"Even the Grant family"],[3257,3428,"sent their youngest daughter there."],[3511,3749,"You don't have to be proud of Dolores,"],[3828,3958,"but I won't just sit back"],[3958,4154,"and watch you destroy her future."],[4237,4412,"Wait, the Grant family?"],[4525,4692,"So Sara Grant goes to that school?"],[4742,4813,"That's right."],[5050,5142,"Sara Grant."],[5246,5430,"Sara Grant is my real daughter."],[5597,5680,"Where is that school?"],[5709,5809,"I'm going there right now."],[6006,6122,"I'm going to see my daughter."],[6364,6443,"Hi, young lady."],[6443,6685,"I'm Sara's grandfather"],[6685,6785,"and I would like to"],[6827,7036,"personally apologize"],[7069,7165,"for her behavior."],[7223,7273,"What?"],[7340,7390,"Grandpa,"],[7390,7557,"why are you apologizing to her?"],[7665,7978,"Sara, you crossed the line today."],[8041,8166,"But Grandpa!"],[8454,8646,"My granddaughter is,"],[8666,8758,"she's impulsive,"],[8758,8963,"but she's not cruel at heart."],[9009,9196,"Look, the Grant family"],[9238,9355,"will make it up to you"],[9355,9455,"for, for"],[9455,9647,"what happened here today."],[9743,9980,"I hope you'll accept our apology."],[10060,10181,"She's so lucky."],[10276,10385,"No matter what she does,"],[10