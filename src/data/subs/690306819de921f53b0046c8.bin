{"1":[[91,241,"Ho, ho, ho!"],[262,479,"God bless every child"],[479,667,"born on Christmas."],[692,900,"Keep pushing, keep pushing."],[900,1030,"It's almost there!"],[1614,1726,"Merry Christmas, ma'am."],[1755,1847,"Congratulations"],[1847,2027,"on your beautiful baby girl."],[2815,2948,"Why does this baby's dad"],[2948,3053,"have the same name"],[3053,3253,"as the billionaire heiress's husband"],[3253,3328,"next door?"],[3641,4008,"My granddaughter is absolutely perfect!"],[4049,4108,"Rachel,"],[4108,4258,"this is the best"],[4258,4416,"Christmas present ever."],[4708,4767,"Yeah."],[5726,5822,"You will always be"],[5822,5943,"Mommy's little princess."],[6410,6690,"Colton, Rachel, you filthy bastards."],[7328,7582,"What the hell are you doing here?"],[7640,7720,"Get out of here"],[7720,7891,"before my wife sees you!"],[7899,8020,"Why should I leave?"],[8074,8170,"I brought our child"],[8170,8341,"so she could see the heartless man"],[8341,8445,"who abandoned us."],[8445,8687,"I told you to get rid of it!"],[8775,8892,"This is your child."],[8892,9034,"How could you be so cruel?"],[9084,9188,"I'm telling your wife."],[9363,9442,"You bitch!"],[9488,9705,"Don't you dare ruin me!"],[9830,9880,"Listen up."],[9934,10055,"And listen good."],[10139,10318,"We were a fling"],[10364,10502,"and not a very good one."],[10564,10844,"Both of you disappear forever."]],"2":[[16,104,"Bastard!"],[241,396,"This is your child."],[408,788,"The only child I will claim is Rachel's."],[788,842,"No."],[875,996,"That's not what you said."],[996,1092,"You said you would leave her"],[1092,1201,"and you would marry me."],[1405,1547,"You actually believe"],[1568,1722,"a man's bedroom lies?"],[1747,1910,"Rachel is the heiress"],[1943,2214,"to the richest family in America."],[2239,2565,"You are a rat from the slums."],[2594,2690,"Do you really think"],[2719,2940,"that I would leave her for you?"],[2990,3148,"You will always be beneath her."],[3203,3282,"Always!"],[3574,3632,"No!"],[3666,3807,"You can't do this to me!"],[4149,4279,"Take that two hundred grand"],[4320,4529,"and make that bastard vanish."],[4750,4850,"You think I won't run"],[4850,5055,"to that bitch Rachel and expose you?"],[5142,5213,"Go ahead."],[5334,5405,"If you do,"],[5451,5805,"you, your sister, and that thing"],[5935,6001,"will die."],[6510,6656,"Colton!"],[7119,7203,"Rachel Grant,"],[7257,7390,"you took everything from me."],[7478,7553,"Now your daughter"],[7553,7682,"will grow up beside me,"],[7766,7941,"drowning in the same hell"],[7941,8058,"I had to survive,"],[8158,8291,"living the lowest,"],[8304,8458,"filthiest life imaginable."],[11757,11828,"My baby."]],"3":[[221,283,"My baby."],[2318,2373,"Molly!"],[2444,2565,"Why did you come home alone?"],[2565,2736,"You're supposed to be resting."],[2765,2857,"I was going to pick you up"],[2857,2965,"from the hospital."],[3044,3090,"Look,"],[3123,3194,"I hung this up"],[3194,3328,"for the baby's welcome party."],[4004,4133,"Molly, what the hell?"],[4170,4233,"A bastard"],[4233,4387,"doesn't deserve a celebration."],[4446,4504,"What?"],[5221,5363,"Where did this come from?"],[5417,5467,"Shit!"],[5522,5613,"Rachel must have given it"],[5613,5701,"to the bastard."],[5789,5901,"I gave it to her, okay?"],[5955,6056,"Let's just take it off."],[6081,6302,"Whoa, whoa, why take it off now?"],[6356,6473,"This is your blessing to her"],[6473,6535,"as her mom,"],[6535,6685,"wishing her a beautiful life."],[6840,6961,"She should always wear it."],[7082,7157,"Haha,"],[7203,7282,"Rachel's bastard"],[7282,7465,"will grow up in the slums like me."],[7503,7665,"And my daughter's gonna go to live"],[7665,7870,"their perfect brilliant life."],[7907,8070,"I'll make sure this little bastard's"],[8070,8233,"life is a living hell."],[10139,10222,"Useless!"],[10222,10356,"You can't even stack soda"],[10356,10485,"without screwing it up!"]],"4":[[0,70,"I'm sorry, Mom."],[70,237,"I'll, I'll clean it up right now, okay?"],[446,663,"That woman is so heartless."],[663,717,"I can't believe"],[717,892,"that poor girl is her daughter."],[913,1001,"She's been beating her"],[1001,1142,"ever since she was a kid"],[1142,1326,"and everyone sees it."],[1343,1463,"Rough doesn't even cut it."],[1505,1593,"She's a monster."],[1618,1701,"What kind of a woman"],[1701,1826,"does that to her own child?"],[2494,2560,"Idiot!"],[2702,2840,"Maybe a good beating"],[2877,3040,"will knock some freaking sense"],[3040,3119,"into you, huh?"],[3178,3253,"Dolores!"],[3524,3595,"You got in!"],[3632,3749,"Saint Peter's Academy"],[3749,3837,"of Fine Arts"],[3866,3974,"with a full ride."],[4800,4854,"Molly,"],[4929,5059,"are you hitting her again?"],[5288,5388,"It's okay, Aunt Rose."],[5447,5497,"What did you say"],[5497,5626,"about Saint Peter's Academy?"],[5709,5809,"You did it, sweetie."],[5847,5972,"Your classes start tomorrow."],[5972,6110,"I'm so proud of you."],[6735,6785,"Molly,"],[6827,6986,"what the hell is wrong with you?"],[7002,7061,"Mom!"],[7077,7211,"You're not going anywhere."],[7244,7403,"Not now, not ever!"],[8028,8195,"Happy first day of school, baby."]],"5":[[75,196,"This crown was once worn"],[196,300,"by a real princess."],[337,442,"Now it's yours."],[462,571,"I hope your life shines"],[571,792,"with as much joy and grace"],[804,913,"as it once carried."],[1021,1130,"Thanks, Mom."],[1564,1701,"Every child in the Grant family"],[1701,1814,"has been born with asthma,"],[1830,1918,"but not Sara."],[1956,2052,"She's the first."],[2089,2227,"Our little Christmas miracle."],[2327,2439,"The original ring"],[2439,2548,"your mother gave you"],[2577,2686,"somehow went missing"],[2686,2811,"on the day you were born,"],[2844,2882,"so"],[3003,3190,"this one's from Grandpa."],[3274,3611,"It symbolizes the Grant family legacy."],[3657,3978,"And it's my way of celebrating the fact"],[3978,4070,"that you got accepted"],[4070,4183,"into Saint Peter's."],[4291,4483,"Graduate from Saint Peter's"],[4512,4679,"and everything we built,"],[4704,4975,"the entire Grant fortune"],[4984,5096,"will be yours."],[5980,6089,"Get your ass in there!"],[6106,6147,"No."],[6185,6277,"No, Mom!"],[6293,6427,"Mom, it's the first day."],[6427,6573,"Saint Peter's is my dream."],[6573,6644,"Dreams?"],[6694,6819,"You're a goddamn curse."],[6865,6948,"Everything shitty"],[6948,7065,"that has happened in my life"],[7086,7198,"is because of you."],[7286,7465,"You're nothing more than dirt"],[7465,7636,"at the bottom of someone's shoes."],[7640,7728,"A nobody."],[7786,7937,"You're stuck in this hellhole,"],[7949,8070,"so get used to it!"],[8070,8133,"Mommy!"],[8216,8274,"Mom!"],[9547,9747,"Your mom gave you that necklace"],[9747,9897,"the day you came into this world."],[9964,10060,"She loves you"],[10114,10322,"probably more than she'll ever admit."],[10360,10460,"She just doesn't know"],[10460,10531,"how to show it."],[11056,11140,"Come on, baby."],[11244,11353,"Let's get you out of here."],[12946,12979,"Here."],[13013,13209,"Consider this a back-to-school gift."],[13259,13355,"Those little brats"],[13355,13459,"always had something"],[13459,13630,"to say about your shoes, right?"],[13951,14084,"Get yourself a new pair."],[14143,14305,"Let's not give your new classmates"],[14305,14418,"anything to laugh about."],[15152,15198,"No-"],[15269,15336,"Aunt Rose,"],[15411,15536,"my mom's still sick."],[15603,15778,"I won't be around to take care of her"],[15778,15882,"while I'm still at school."],[15999,16145,"This is everything I've saved up"],[16145,16262,"from my part-time jobs."],[16274,16470,"Please, give it to her"],[16529,16579,"for me."],[17242,17463,"Go chase your dreams."],[17625,17688,"Thank you,"],[17784,17855,"for everything."]],"6":[[550,650,"Hey, what the hell?"],[1626,1772,"Sir, today is Miss Grant's first day"],[1772,1860,"at Saint Peter's."],[1893,1956,"Per your request,"],[1956,2068,"I spoke with the school board."],[2118,2218,"No one's gonna mess with her."],[2268,2318,"Good."],[2360,2540,"Saint Peter's is Grant territory."],[2573,2