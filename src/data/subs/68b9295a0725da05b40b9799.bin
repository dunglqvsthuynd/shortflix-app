{"1":[[1159,1330,"Congratulations! Mama!"],[1338,1438,"Thank you!"],[1543,1705,"You're having a baby!"],[1705,1772,"I can't believe I'm"],[1772,1860,"gonna to be a mom!"],[1860,1951,"Oh my gosh, Ellie,"],[1951,2114,"you're gonna be a great mom!"],[2114,2277,"I'm so happy that the IVF"],[2277,2364,"finally worked."],[2364,2435,"Thank you."],[2452,2548,"I never thought I'd hear you"],[2548,2644,"say those words."],[2673,2811,"After the PCOS diagnosis,"],[2811,2919,"I was ready to give up."],[3028,3123,"I...I should go!"],[3123,3232,"I have to tell Adam."],[3244,3361,"We're gonna have a baby!"],[3361,3541,"You're gonna have a baby!"],[4279,4341,"Hello."],[4354,4441,"Dr. Chloe,"],[4441,4596,"I hope Ms. Barton is still there."],[4596,4738,"There's been a terrible mistake."],[4738,4808,"A mix-up."],[4817,5055,"She was given Ace Parker's sample."],[5059,5180,"Ace Parker?"],[5180,5342,"The head of the mafia?"],[5342,5422,"He's"],[5476,5572,"a monster!"],[7232,7357,"Excuse you, sir."],[7357,7474,"You're outside of a hospital"],[7474,7553,"with sick people"],[7553,7645,"and pregnant mothers."],[7645,7766,"You can't smoke here."],[7782,7991,"The boss can do"],[7991,8124,"whatever he wants."],[8174,8254,"Mr. Parker,"],[8266,8345,"would you like me to"],[8345,8487,"take care of this problem?"],[8508,8583,"Parker?"],[8612,8683,"The men?"],[8708,8779,"The guns?"],[8779,8854,"The suits?"],[8888,8975,"Oh my god."],[8975,9104,"The Parkers are the most"],[9104,9205,"ruthless mafia"],[9205,9321,"family in the city."],[9609,9830,"Uh, Mr. Parker, sir, um..."],[9868,9943,"I'm sorry."],[9943,10043,"I didn't mean to."],[10043,10143,"It...It was just a"],[10143,10276,"friendly suggestion."],[10306,10372,"I'm pregnant."],[10372,10468,"Please don't hurt me."],[11457,11524,"Pregnant mothers"],[11524,11657,"deserve to be doted on."],[11686,11790,"They'll never harm one."],[11807,11903,"Keep the umbrella."],[11995,12120,"You two stay out of the rain."],[12512,12612,"Pleasure to meet you."],[13384,13521,"I wish I could say the same."],[13801,13909,"Adam!"],[14001,14076,"Great news!"],[14076,14176,"We're gonna have a..."],[15015,15077,"I love you!"],[15085,15223,"Adam, I love you so much!"],[15544,15648,"Fuck me, Adam."]],"2":[[200,387,"Nobody gets you going like me, baby,"],[387,446,"huh?"],[446,542,"Not her?"],[550,729,"She's a dead fish in bed."],[729,825,"You're the only one"],[825,959,"who can get me like this."],[959,1071,"You know that."],[1576,1651,"What the fuck is"],[1651,1768,"wrong with you two?"],[1785,1856,"Fuck you, Ruby,"],[1856,1943,"you're my best friend."],[1943,1989,"How could you"],[1989,2110,"sleep with my fiancé?"],[2118,2189,"Bitch!"],[2381,2502,"Did she hurt you?"],[2502,2610,"Is the baby okay?"],[2736,2802,"Baby?"],[2894,3036,"What baby, Adam?"],[3036,3148,"We've been trying for months."],[3148,3190,"How long has"],[3190,3269,"this been going on?"],[3269,3395,"Long enough to create a"],[3395,3536,"beautiful little life."],[3570,3682,"Our baby?"],[3874,3966,"I'm pregnant too."],[4433,4512,"Pregnant?"],[4512,4575,"You?"],[4592,4754,"With your rusty ovaries?"],[4875,4971,"I don't think so."],[4979,5038,"You're broken."],[5038,5084,"I thought you"],[5084,5171,"wanted this too."],[5180,5317,"It's our baby, Adam!"],[5401,5463,"You're lying."],[5501,5584,"There's no baby."],[5618,5714,"Adam's been switching your"],[5714,5914,"IVF meds for vitamins."],[5985,6143,"You were here to pay the bills and"],[6143,6268,"entertain me for a while."],[6297,6364,"If you're pregnant,"],[6364,6439,"get rid of it."],[6464,6531,"We're over."],[6760,6919,"Your bastard baby isn't worth"],[6919,7115,"bringing into this world, anyway."],[8216,8308,"How could you do this to me"],[8308,8358,"after everything"],[8358,8445,"I've done for you?"],[8470,8596,"After all the sacrifices I"],[8596,8737,"made to build a life for you?"],[8737,8846,"All I ever wanted was to be"],[8846,8979,"the mother of your child."],[9067,9125,"Get out."],[9184,9280,"Leave, both of you!"],[9280,9338,"I never want to"],[9338,9417,"see you again!"],[9459,9626,"Adam, she's hurting our baby!"],[9634,9726,"Do something!"],[10101,10322,"Stay there, you dumb bitch!"],[10339,10464,"If you did anything to hurt"],[10464,10639,"Ruby's baby, I'll make sure"],[10639,10698,"it's the biggest"],[10698,10835,"regret of your life."],[11136,11190,"Oh!"],[11319,11457,"No, my baby!"],[11695,11945,"Oh, no, my baby."]],"3":[[408,508,"These surrogates have all"],[508,613,"been pre-screened."],[633,721,"Tick-tock, boss."],[746,838,"Your father's instructions"],[838,930,"are pretty clear."],[963,1071,"He wants a grandchild,"],[1071,1184,"your birthright is on the line."],[1222,1280,"You want to be the head of"],[1280,1368,"the family, don't you?"],[1422,1501,"Of course I do."],[1543,1676,"It's not so simple, Ben."],[1718,1810,"It has to be."],[1810,1868,"Otherwise,"],[1889,1997,"your brother's gonna rule."],[2006,2089,"And then you'll be stuck to"],[2089,2198,"grovel at his feet."],[2327,2431,"I don't like being rushed."],[2548,2594,"Look,"],[2644,2715,"I'm not saying you're"],[2715,2831,"out here picking a wife."],[2861,2961,"You're picking a surrogate."],[2986,3082,"Which is exactly why she"],[3082,3132,"needs to be the"],[3132,3215,"perfect mother."],[3465,3520,"Yeah, this..."],[3591,3636,"What?"],[3636,3774,"What do you mean Mr. Parker's sperm"],[3774,3887,"has already been used?"],[4137,4216,"You're not gonna tell me they"],[4216,4316,"used my sperm without my"],[4316,4408,"permission, are you?"],[4462,4683,"Sir, there seems to be some"],[4683,4771,"kind of mistake."],[4779,4829,"Excuses."],[4871,4967,"Find the woman who stole my"],[4967,5125,"sperm right now."],[5176,5242,"On it."],[5801,5860,"Chloe,"],[5918,6043,"is my baby okay?"],[6160,6210,"The little one's"],[6210,6289,"more than okay."],[6443,6502,"You've got quite"],[6502,6602,"the little fighter."],[6973,7069,"Everything looks great."],[7157,7223,"Thank God."],[7344,7494,"And thank you, little one,"],[7494,7582,"for staying with me."],[7599,7661,"Your daddy may"],[7661,7774,"not want you, but..."],[7799,7849,"Mama will love"],[7849,7949,"you twice as much."],[7995,8033,"Ellie..."],[8170,8233,"I, uh..."],[8395,8508,"I need to tell you something."],[8616,8679,"There was a mix-up"],[8679,8787,"at the sperm bank."],[8950,9088,"That's not Adam's baby."],[9138,9184,"What?"]],"4":[[4,45,"What?"],[125,171,"Wait,"],[221,300,"what are you talking about?"],[300,346,"So,"],[421,583,"I'm having a stranger's baby?"],[625,784,"Someone at the lab made a"],[784,900,"terrible mistake."],[921,1096,"I'm so sorry."],[1130,1242,"You can probably take legal"],[1242,1376,"action if you want to."],[1426,1534,"But there's something else."],[1555,1722,"Your reproductive system is"],[1722,1856,"fragile from the IVF."],[1901,2097,"If you choose to abort the fetus,"],[2152,2277,"it's likely you won't"],[2277,2385,"get pregnant again."],[2952,3048,"I'm not aborting it."],[3103,3240,"It doesn't matter who the dad is,"],[3240,3345,"it's still my baby."],[3386,3486,"This is probably the only"],[3486,3545,"chance I'll get"],[3545,3611,"to be a mother."],[3837,3941,"Can you...Can you tell me"],[3941,4020,"about the donor?"],[4049,4220,"I don't care about his looks"],[4220,4362,"or his wealth, as long as"],[4362,4529,"he's a good person and not"],[4529,4683,"some criminal."],[4763,4833,"About that..."],[4984,5096,"He's in the mafia."],[5130,5188,"I hope that"],[5188,5309,"doesn't scare you."],[5910,6018,"That terrifies me."],[6126,6210,"So you're the thief"],[6210,6343,"who stole my sperm."],[6781,6848,"Mr. Parker!"],[7019,7123,"Please tell me it's not him."],[7127,7261,"I can't because he is the"],[7261,7382,"father of your baby."],[7820,7912,"Hello, little thief."],[7928,7999,"We meet again."],[8012,8099,"Ellie's the victim of"],[8099,8229,"medical incompetence."],[8229,8312,"She's not a thief."],[8312,8429,"I'll be the judge of that."],[8445,8512,"Leave."],[9084,9234,"We need to talk."]],"5":[[658,713,"What do you think you're"],[713,792,"doing with my baby,"],[792,871,"Miss Barton?"],[884,917,"You think I"],[917,1005,"don't know your plan?"],[1067,1151,"What plan?"],[1201,1418,"This is a lottery ticket."],[1455,1518,"You thought you could get"],[1518,1626,"pregnant with my child and"],[1626,1768,"leech off my family forever."],[1810,1926,"Luckily I know that everybody"],[1926,2039,"has their price."],[2060,2122,"Name yours."],[2135,2177,"How much do you"],[2177,2256,"want for the baby?"],[2281,2460,"My baby is not for sale."],[2577,2660,"Your sperm is not a"],[2660,2794,"paycheck to me, Mr. Parker."],[2802,2944,"I want nothing to do with you"],[2944,3111,"or your heinous lifestyle."],[3199,3253,"You should have thought of"],[3253,3311,"that before you"],[3311,3415,"stole my sperm."],[3440,3532,"Even if I was desperate"],[3532,3687,"enough to steal sperm, why on"],[3687,3841,"earth would I choose yours?"],[3858,4049,"You're a dragon of a man, Mr. Parker."],[4066,4295,"Cold, ruthless, and born into"],[4295,4366,"one of the most dangerous"],[4366,4479,"families in the world."],[4512,4650,"My baby deserves a life far"],[4650,4758,"away from the mafia."],[4763,4896,"Not trapped in it."],[4942,5130,"She's fierce, protective,"],[5155,5284,"perfect mother material."],[5960,6126,"This dragon always gets what he wants."],[6151,6264,"You're coming home with me."],[6264,6310,"I'm not going"],[6310,6435,"anywhere with you, Mr. Parker."],[6435,6514,"I hardly know you."],[6531,6631,"And what I do know tells me"],[6631,6664,"that you're"],[6664,6773,"ruthless and dangerous."],[6794,6840,"Trusting you"],[6840,6927,"would be a mistake."],[6948,7007,"One that could get"],[7007,7098,"both of us killed."],[7111,7194,"You want feelings?"],[7257,7378,"I can give you feelings."],[7432,7499,"Wait...what are you-"],[7499,7615,"I'm giving you what you want."],[7636,7711,"Feelings."]],"6":[[125,266,"I can only speak for myself,"],[266,371,"but I felt something."],[392,458,"You're crazy."],[513,