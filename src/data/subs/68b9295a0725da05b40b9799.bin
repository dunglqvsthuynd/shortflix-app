first?"],[5121,5201,"Go..."],[5284,5384,"and kill the woman,"],[5447,5559,"and the baby."],[6306,6460,"Sorry, baby, but Mama can't"],[6460,6552,"let you grow up around"],[6552,6694,"violence and disorder."],[6756,6869,"You'll be safe soon."],[6886,6940,"I'll always keep"],[6940,7057,"you safe, little one."],[8366,8470,"Well, well, well."],[8470,8604,"If it isn't Ace's little queen."],[8604,8692,"Let Harry know we've"],[8692,8842,"found his brother's weakness."]],"8":[[0,66,"Who are you?"],[87,154,"What do you want?"],[154,254,"We're here to take that demon"],[254,312,"spawn in your"],[312,412,"belly straight to hell."],[859,921,"Let go!"],[942,996,"I don't know what you're"],[996,1059,"talking about!"],[1059,1142,"You know exactly what I'm"],[1142,1192,"talking about."],[1192,1297,"Don't play dumb with me."],[1413,1488,"What are you waiting for?"],[1488,1568,"Get the bitch!"],[1976,2097,"My baby!"],[2281,2414,"No, I beg of you, please"],[2414,2548,"don't hurt my baby."],[2569,2606,"It's nothing"],[2606,2711,"personal, sweetheart."],[2719,2811,"Ace knew exactly what would"],[2811,2852,"happen if he"],[2852,2919,"got anyone pregnant."],[2952,3015,"Blame him."],[3578,3603,"No!"],[3632,3653,"No!"],[5413,5522,"You three just signed your"],[5522,5618,"death warrants."]],"9":[[4,100,"You three just signed your"],[100,191,"death warrants."],[2235,2352,"Are you okay?"],[2615,2719,"You asked for this."],[2786,2848,"Close your eyes."],[2852,2894,"Don't look."],[3153,3240,"Take care of these guys and"],[3240,3311,"drop the bodies on"],[3311,3399,"Harry's doorstep."],[3403,3495,"Yes, sir!"],[4008,4112,"I'm so sorry that happened."],[4112,4208,"Are you alright?"],[4337,4375,"Ellie!"],[4396,4425,"Ellie!"]],"10":[[959,1046,"My baby."],[1146,1263,"Our baby is safe."],[1426,1564,"I had my doctors take a look."],[1664,1722,"Ace?"],[1935,1997,"Where am I?"],[2060,2131,"You're with me."],[2239,2377,"Or, as you might call it..."],[2377,2431,"the most dangerous"],[2431,2527,"place in the world."],[2690,2765,"I'm leaving."],[2882,3019,"Don't be foolish."],[3290,3345,"There are already threats"],[3345,3445,"against your life."],[3445,3520,"People are just waiting for"],[3520,3616,"you to step outside to"],[3616,3745,"extinguish your existence."],[5580,5672,"That's no way to gaze at your"],[5672,5780,"knight in shining armor."],[5935,5980,"My what?"],[6031,6131,"You're the whole reason I'm"],[6131,6264,"in danger in the first place."],[6327,6368,"You're right."],[6456,6519,"And so long as you're"],[6519,6606,"carrying my baby,"],[6606,6723,"whether you're with me or not,"],[6723,6869,"your life will be in danger."],[6927,7040,"I can protect you."],[7040,7136,"I'm the only one"],[7136,7248,"who can keep you safe."],[7853,7891,"Ellie,"],[8033,8074,"nothing can"],[8074,8170,"happen to that baby."],[8170,8220,"You know that"],[8220,8312,"as well as I do."],[8470,8529,"Stay here and"],[8529,8625,"let me protect you."],[8700,8808,"This place isn't as bad as"],[8808,8917,"you think, I promise."]],"11":[[0,87,"This place isn't as bad as"],[87,208,"you think it is, I promise."],[346,446,"You were here to pay the"],[446,487,"bills and"],[487,625,"entertain me for a while."],[625,738,"If you're pregnant, get rid of it."],[763,855,"We're over."],[855,1005,"Your bastard baby isn't worth"],[1005,1188,"bringing into this world, anyway."],[1322,1443,"Ace is fighting for a baby"],[1443,1568,"that Adam didn't even want."],[1626,1780,"He's already a better father."],[1856,1993,"Darling, mama only wants"],[1993,2085,"what's best for you."],[2156,2210,"I'll stay."],[2314,2498,"But you can't keep me here"],[2498,2598,"against my will."],[2598,2715,"I won't be your prisoner."],[2736,2811,"I wouldn't dream of keeping"],[2811,2911,"you against your will."],[2911,2961,"We'll put it in the"],[2961,3044,"marriage agreement."],[3161,3224,"Marriage?"],[3319,3457,"Mrs. Parker?"],[3557,3728,"No, I refuse to wear the"],[3728,3828,"blood on the hands that comes"],[3828,3920,"with that 