{"1":[[2565,2736,"The hell is going on here?"],[2852,2948,"Damn it Cole."],[2948,3023,"I told you,"],[3023,3215,"stop touching my old Navy equipment!"],[3215,3378,"Relax, I'm just training."],[3378,3490,"Look at you."],[3490,3628,"Out of breath,"],[3628,3770,"with an oxygen tank."],[3803,3987,"It's not happening, Cole."],[3987,4112,"No chance."],[4112,4295,"You're never going to be a fighter pilot!"],[4295,4466,"What the hell is wrong with you?"],[4500,4604,"You're the one who told me that"],[4604,4717,"if I trained as hard as I could,"],[4717,4842,"I could be a pilot."],[4863,5059,"You put this dream in my head."],[5059,5280,"Ever since you came home from prison,"],[5280,5417,"you just make me feel like shit!"],[5417,5714,"Because that's what you are, Cole."],[5793,5918,"Shit."],[7432,7553,"Hey buddy,"],[7553,7691,"I know it's not much,"],[7757,7978,"it's kind of hard to get toys in here."],[8016,8141,"Happy birthday son."],[8141,8191,"Open!"],[8441,8675,"An FA-18 Super Hornet?"],[8675,8858,"This can go Mach 1.8"],[8858,8975,"and hold up to 8 missiles."],[9013,9092,"Thank you, Dad."],[9092,9163,"I love it."],[9163,9338,"Now you're being attacked"],[9338,9476,"by enemy Migs."],[9530,9634,"What are you gonna do?"],[9634,9747,"Create space and utilize"],[9747,9843,"superior weaponry."],[9843,9955,"Because I'm faster."],[9955,10135,"You really are my son."],[10343,10385,"Okay."],[10385,10468,"Time's up."],[10468,10560,"Let's go."],[10610,10731,"I love you buddy."],[11169,11273,"I'm gonna be a fighter pilot"],[11273,11386,"just like you, Dad."],[11423,11619,"I'm gonna be the best in the world."],[11732,12003,"You're never gonna be a fighter pilot,"],[12057,12295,"because you're just not good enough."]],"2":[[8,108,"Seven years"],[108,208,"you've been in the Navy"],[208,508,"and you're nothing but a fucking janitor!"],[508,592,"Did it ever occur to you"],[592,709,"that maybe I'm just a janitor"],[709,759,"because I have a"],[759,967,"fucking traitor for a father?"],[1343,1463,"Is that what do you really think of me?"],[1463,1651,"You think I turned my back on my country?"],[1651,1739,"Did you?"],[1851,1956,"Did you?"],[2047,2164,"I will become a pilot."],[2164,2348,"I don't give a fuck what you think."],[3111,3228,"Mr. Summers,"],[3265,3470,"you don't have to be so hard on him."],[3495,3712,"He can't help it he's weak."],[3712,3878,"You think I'm holding him back"],[3878,4004,"because he's not good enough?"],[4258,4350,"Cole’s the best"],[4350,4517,"fighter pilot I've ever seen."],[4583,4725,"He didn’t even realize,"],[4863,5025,"that oxygen tank is empty."],[5113,5263,"That's impossible."],[5288,5401,"Well that'd mean that-"],[5401,5538,"He did that entire workout"],[5559,5718,"while suffocating himself."],[5872,6043,"And there isn't another pilot"],[6043,6143,"walking this earth"],[6143,6239,"who can do that."],[6281,6414,"What?"],[6431,6598,"Why are you lying to him?"],[6802,6911,"To save his life."]],"3":[[613,717,"Rick..."],[750,871,"finally found something"],[871,1051,"you could pilot drunk, eh?"],[1051,1255,"What the fuck are you doing here?"],[1292,1488,"Is that any way to speak to a"],[1488,1630,"U.S. senator?"],[1630,1726,"You are nothing"],[1726,1993,"but a traitorous piece of shit!"],[2002,2139,"Oh, you're still mad"],[2139,2427,"because I sabotaged your plane,"],[2448,2594,"framed you for treason huh?"],[2594,2702,"You’re the fucking reason"],[2702,2869,"why I’m in this chair!"],[2869,3023,"Not my fault."],[3023,3157,"That's what happens"],[3157,3332,"when you sell out your country."],[3332,3457,"Get the fuck out of my way."],[3457,3620,"I'm going to see my son."],[3687,3766,"He's testing"],[3766,3999,"for the Navy pilot program today."],[3999,4062,"Aww,"],[4062,4208,"afraid not."],[4229,4408,"See your janitor son"],[4496,4650,"had a little accident."],[4813,4921,"What did you do?"],[4921,5050,"Calm down."],[5050,5196,"Just broke an arm."],[5309,5680,"But if your son ever becomes a pilot,"],[5755,5943,"I'll make sure he dies"],[5943,6056,"on his first flight."],[6243,6327,"If Cole"],[6327,6627,"ever gets his wings,"],[6765,6902,"he’ll be killed."],[6944,7107,"I can't let that happen."],[7194,7319,"And if he hates me,"],[7490,7590,"then he hates me."],[7707,7816,"I need to make sure"],[7816,7953,"no one knows how good"],[7953,8091,"he really is."],[8137,8333,"Not even Cole himself."]],"4":[[95,221,"Summers!"],[221,417,"You moron mop maggot!"],[417,571,"You're late again!"],[571,654,"Sorry, sir!"],[654,796,"Was at home training, sir!"],[796,867,"Training?"],[909,1059,"There's no way in hell"],[1059,1213,"you'll ever be a pilot."],[1213,1351,"You're the child of a"],[1351,1605,"drunk fucking traitor!"],[1701,1851,"Look at you,"],[1851,1926,"you've been in the Navy"],[1926,2039,"for seven years,"],[2077,2335,"and you're still a janitor."],[3073,3240,"Now clean this mess up."],[3532,3595,"Mop,"],[3595,3707,"maggot."],[3753,3858,"Yes, sir."],[5417,5584,"The enemy's long range missile"],[5584,5701,"facility will be up"],[5701,5951,"and running in three days."],[5989,6126,"If we don't find a pilot"],[6126,6302,"that can destroy it by then,"],[6335,6489,"they are going to bomb America"],[6489,6677,"back into the Stone Age."],[6677,6840,"I don't know what else to do, sir."],[6840,6973,"The top secret flight simulators"],[6973,7132,"have been sent to every base."],[7182,7336,"And every top pilot who has attempted"],[7336,7532,"them has failed miserably."],[8420,8562,"Simulation starting."]],"5":[[0,120,"Simulation starting. - What?"],[141,262,"There's not another run scheduled."],[262,316,"Who's in there?"],[316,462,"Contact that C.O."],[462,638,"and you shut this down right now!"],[638,771,"This is a top secret mission."],[771,825,"No, wait!"],[825,909,"Look!"],[1176,1301,"He’s doing it."],[1580,1710,"He's going so fast."],[1718,1868,"How has he not crashed yet?"],[1868,1947,"I don't know"],[1947,2085,"but he’s still accelerating."],[2277,2369,"He’s approaching a third"],[2369,2502,"turn at Mach one."],[2540,2594,"Oh my God."],[2594,2711,"Four seconds to go."],[2765,2898,"Approaching Death Bend."],[3190,3274,"Two seconds."],[3274,3328,"No one has"],[3328,3482,"ever surived Death Bend!"],[4079,4200,"Mission sucessful."],[4237,4329,"Yes! - What?"],[4329,4421,"Oh my."],[4450,4517,"We've got a pilot"],[4517,4596,"who could fly the mission"],[4596,4729,"and hit the target."],[4729,4792,"Who is it?"],[4792,4904,"Uh..."],[4904,5042,"Data base says"],[5042,5163,"Cole Summers. - Yeah?"],[5196,5309,"He's a..."],[5309,5559,"unexceptional enlisted janitor."],[5559,5684,"That base is holding"],[5684,5843,"Top Gun trials this week."],[5843,5935,"Every elite pilot"],[5935,6081,"in America will be there."],[6106,6368,"I want Cole Summers on that list."],[6510,6681,"The fate of the world now rests"],[6681,6810,"in a janitor's hands."]],"6":[[8,112,"Down!"],[166,312,"Two. Lower."],[312,417,"Down!"],[467,550,"Three."],[567,650,"Down!"],[742,917,"You've got to be kidding me."],[942,1080,"They must have mixed up the pilots"],[1080,1322,"with piece-of-shit janitors."],[1322,1497,"What are you doing janitor boy?"],[1530,1751,"Here to mop up our piss and shit?"],[1926,2118,"I'm here to get into Top Gun."],[2439,2527,"Summers!"],[2560,2740,"As in the son of Rick Summers?"],[2752,2965,"The one that's in jail for treason?"],[2965,3069,"I don't know who you had"],[3069,3257,"to give hand jobs to to get in here."],[3299,3553,"Your technique must be amazing."],[3616,3699,"You learn that from your"],[3699,3807,"convict daddy?"],[3807,3903,"See if you're still laughing"],[3903,4070,"when I'm flying circles around you."],[4070,4116,"Aw."],[4233,4325,"Attention!"],[4654,4746,"Admiral on deck!"],[4946,5046,"You are here to test"],[5046,5159,"for the The Strike Fighter Tactics"],[5159,5246,"Program."],[5292,5397,"AKA,"],[5397,5509,"Top Gun."],[5701,5843,"And I'm Admiral Jager."],[5885,6093,"Time to show my dad who I am."],[6093,6202,"Joining us on this trial is"],[6202,6277,"the head of Senate"],[6277,6452,"Naval Council, Tony Dubois."],[6452,6614,"I had to come"],[6614,6852,"when I found out the son of a traitor"],[6852,7057,"somehow got in this trial."],[7086,7361,"You are the best pilots of the Navy."],[7361,7511,"All but one."],[7511,7645,"Before we fly"],[7678,7849,"we need to test your strength,"],[7849,7966,"mental toughness,"],[7966,8120,"and the dedication."],[8120,8229,"These tests are designed"],[8229,8358,"to break the weak."],[8404,8516,"Any questions?"],[8516,8637,"I have a question!"],[9238,9300,"Why are you trying"],[9300,9430,"to kill my son?"]],"7":[[4,150,"He's not even a pilot!"],[150,229,"How could he possibly"],[229,342,"handle Top Gun?"],[342,375,"Dad!"],[375,467,"Aww..."],[467,546,"Cole's traitor"],[546,738,"daddy came to protect him."],[738,921,"What are you doing here?"],[921,1188,"This is a secret Navy trial"],[1188,1351,"not a soup kitchen."],[1351,1455,"Please."],[1514,1639,"I've saved the lives"],[1639,1910,"of half the soldiers on this base."],[2002,2152,"Alright."],[2152,2243,"Security."],[2260,2306,"No."],[2306,2452,"Oh wait, wait."],[2477,2777,"Let Rick watch his son"],[2798,2998,"make a fool of himself."],[3028,3382,"A janitor with the blood of a traitor?"],[3420,3541,"At Top Gun?"],[3607,3841,"America is done."],[4295,4446,"You better hope"],[4446,4604,"Cole shits his pants"],[4604,4788,"because if he flies,"],[4846,5146,"I will personally kill him."],[5238,5472,"Unless my son does it first."],[5472,5538,"Boy!"],[5668,5797,"Please welcome,"],[5814,5935,"Gunnar"],[5935,6101,"The Giant Dubois."],[6101,6227,"Best pilot in the Navy"],[6227,6389,"and my son."],[6610,6644,"Is that"],[6644,6902,"the stench of dirty shit water?"],[6998,7119,"Or is it treason?"],[7248,7449,"I'm gonna break you into a cripple"],[7449,7745,"just like your traitor old man."]],"8":[[58,279,"Go ahead, hit me, bitch."],[279,392,"You can join drunk"],[392,592,"daddy dearest in prison."],[604,746,"He's just trying to get in your head."],[746,863,"Speaking of head?"],[863,959,"Who'd you suck off to"],[959,1059,"get in here?"],[1059,1138,"Back off!"],[1138,1234,"Summers!"],[1301,1509,"Control yourself."],[1960,2106,"First round."],[2106,2218,"The opposing G-forces"],[2218,2298,"to make it feel like"],[2298,2414,"you're being ripped apart."],[2498,2660,"To simulate that,"],[2765,2894,"the Heli-trial."],[2894,3019,"Here's how it goes."],[3019,3157,"The helicopter will lift off,"],[3157,3240,"and you're gonna try to hold"],[3240,3420,"down yourself as long as you can."],[3461,3536,"First up,"],[3591,3745,"Captain Paul Daniels,"],[3745,3816,"callsign"],[3866,3974,"Buckeye."],[3974,4070,"Begin."],[4988,5088,"Buckeye,"],[5088,5246,"5.3 seconds."],[5246,5351,"Well done."],[5351,5426,"Next!"],[5676,5855,"4.7 seconds."],[5855,6060,"4.5 seconds."],[6060,6118,"Next up,"],[6118,6364,"we have Lieutenant Mina Rylance."],[6381,6498,"Callsign,"],[6498,6589,"Nightfall."],[6589,6652,"Good Luck."],[6790,6898,"Don't think she's gonna"],[6898,7015,"wet your mop."],[9200,9351,"6.1 seconds."],[9351,9517,"Nightfall takes the lead."]],"9":[[0,100,"Next up,"],[100,216,"the Giant."],[2006,2089,"Ladies and gentlemen,"],[2089,2252,"we have a brand new leader."],[2252,2419,"Gunnar The Giant Dubois,"],[2519,2690,"with 10.1 seconds."],[2690,2998,"And finally, we have Cole Summers."],[2998,3107,"Callsign"],[3319,3395,"Mop Bucket."],[3395,3520,"Admiral,"],[3520,3586,"I'm requesting a"],[3586,3699,"moment with my son."],[3799,3978,"Will you at least drink this?"],[4041,4200,"You look like you're about to pass out."],[4200,4279,"I'm fine."],[4366,4429,"Son,"],[4521,4637,"don't do this."],[4667,4750,"Just quit."],[4750,4867,"Why would I do that?"],[4900,5013,"Because all you're going to do"],[5013,5267,"is make a complete ass out of yourself."],[5267,5426,"You are not good enough!"],[5426,5701,"You have no idea what I'm capable of."],[6389,6489,"You happy?"],[6589,6756,"Cole, don't do this."],[6756,6936,"Cole, think about it!"],[7061,7190,"Sorry Cole."],[7315,7507,"I'm doing this to save your life."],[7603,7699,"I can't mess this up."],[7761,7849,"I might not get a chance"],[7849,7945,"like this again."],[8008,8128,"But why do i feel so weak?"]],"10":[[1860,2160,"4.3 seconds, Mop Bucket."],[2235,2419,"That means you're in last place."],[2565,2652,"I druged him with enough"],[2652,2727,"tranquilizers to"],[2727,2848,"put a horse to sleep."],[2986,3161,"Yet he held on as long as the others."],[3274,3378,"My son..."],[3516,3670,"is unbelievable."],[3728,3924,"I was expecting so much more."],[3970,4066,"Oh my God..."],[4066,4233,"Well, I guess Cole is not the one"],[4233,4362,"that's gonna save the world."]],"11":[[116,329,"What's the matter, sweet pea?"],[329,487,"You look a little woozy."],[487,604,"Just drop out."],[604,754,"Mop maggot."],[1284,1363,"What?"],[1363,1580,"Summers I think you’ve been drugged."],[1580,1726,"Those fuckers."],[1964,2047,"How do I shake it?"],[2047,2198,"For a mystery drug?"],[2264,2419,"You'd need an adrenaline shot,"],[2419,2523,"but that could kill you."],[2531,2640,"We have to go to the E.R."],[2752,2861,"Not today."],[2923,3028,"Second trial."],[3065,3211,"Who's ready for a swim?"],[3253,3349,"Cole don't do it,"],[3349,3428,"you’ll drown."],[3482,3624,"Then I’ll drown."],[3670,3787,"The Houdini Trial."],[3837,4079,"This is to test your spatial awareness,"],[4079,4200,"pressure under fire,"],[4200,4346,"and your determination."],[4346,4441,"Your mission"],[4441,4571,"is to free yourself"],[4571,4679,"before you drown."],[4713,4800,"As you can see,"],[4800,4900,"you are tied behind your back"],[4900,5063,"with some nice thick rope."],[5063,5167,"In your right hand"],[5167,5292,"is a remote."],[5317,5501,"Press it and we will rescue you."],[5501,5705,"But you will be disqualified."],[5818,5943,"You okay, Summers?"],[5943,6114,"Of course he's not okay."],[6139,6339,"He had 10 tranquilizers"],[6339,6452,"20 minutes ago."],[6514,6685,"Never been better, sir!"],[6685,6748,"Then,"],[6810,6911,"begin."]],"12":[[650,717,"Mop Bucket."],[796,871,"Third place,"],[959,1051,"still in the running."],[1126,1317,"He passed out like his drunk daddy."],[1422,1484,"Son!"],[1668,1893,"Well, Cole may not have the skills,"],[1893,2097,"but he sure has got the grit."],[2097,2323,"Grit is not gonna save the world."],[2773,2961,"What the hell were you thinking?"],[3011,3128,"You could have died!"],[3203,3315,"When's the next trial?"],[3566,3695,"I'm still in the running."],[3749,3858,"The remaining pilots,"],[3887,4058,"Nightfall, Giant,"],[4129,4233,"will go head to head"],[4233,4329,"in the next dogfight."],[4675,4767,"Winner has a place"],[4767,4942,"in The Strike Fighter Tactics program."],[5138,5334,"Pilots, engage!"],[6101,6227,"I can't see him anywhere!"],[6231,6393,"Right behind you, Princess."],[6519,6623,"I'm caught in his draft!"],[6648,6740,"Losing control!"],[6790,6952,"Giant, you're too close, back up."],[7140,7240,"I'm going into a tailspin!"],[7240,7315,"Mayday!"],[7323,7394,"Mayday!"],[7432,7582,"Eject, Nightfall! Eject!"],[8087,8170,"Nightfall?"],[8224,8324,"What happened?"]],"13":[[4,95,"Is she okay?"],[150,225,"You fucking idiot."],[225,329,"You could have killed her!"],[412,500,"Well, it's not my fault"],[500,713,"she flies the way daddy here walks."],[742,888,"Now, if you'll excuse me,"],[917,1080,"I have to go to Top Gun,"],[1080,1213,"unless you can sober up enough"],[1213,1459,"to fly a jet, Mop Bucket."],[1589,1760,"Son, look at me."],[1797,1885,"After today,"],[1918,2147,"I hope you finally realize the truth."],[2210,2398,"You are never gonna be a pilot."],[3174,3303,"You'd need an adrenaline shot."],[3303,3395,"But that could kill you."],[5005,5134,"What are you doing, janitor boy?"],[5221,5417,"Here to mop up our piss and shit?"],[5467,5572,"Just drop out,"],[5613,5718,"mop maggot."],[5772,6014,"You're never gonna be a fighter pilot."],[6035,6260,"Because you're just not good enough."],[6327,6398,"Cole?"],[6531,6619,"What are you doing?"],[7069,7119,"Cole..."],[7203,7261,"stop."],[8187,8249,"Don't!"],[8274,8375,"That could kill you."],[8425,8495,"I know."],[8946,9063,"I'm gonna be a fighter pilot"],[9063,9163,"just like you, Dad."],[9426,9492,"Jager."],[9559,9855,"Spell it out for old traitor Rick."],[9897,10151,"Top Gun belongs to my son."],[10193,10322,"Not yet, it doesn't!"],[11069,11169,"This isn't over."],[11411,11482,"I'm gonna blow you"],[11482,11611,"out of the fucking sky."]],"14":[[1130,1384,"You know, in about three mintues,"],[1384,1614,"your family is gonna have not one,"],[1643,1935,"but two disabled ex-pilots."],[1935,2081,"You know, that's great for parking."],[2252,2510,"I told you, if your son became a pilot,"],[2510,2652,"I would kill him."],[2681,2869,"But now I may not have to."],[2869,3061,"My son may do it for me."],[3174,3236,"You might want to"],[3236,3415,"take a look at the screen,"],[3461,3628,"you bribe-taking bitch."],[3924,4020,"How's he flying like that?"],[4708,4792,"What the hell?"]],"15":[[225,412,"Where are you, Mop Bucket?"],[538,646,"I'm right behind you."],[704,763,"Shit!"],[1076,1180,"Summers nearly took him out"],[1180,1263,"in under a minute."],[1288,1459,"This can't be happening."],[1822,1972,"That's a lucky start."],[2043,2139,"But, you're out of your league,"],[2139,2252,"janitor boy."],[2277,2485,"You don't stand a chance."],[2485,2665,"I've trained with the best."],[2665,2894,"I am the best."],[2911,3040,"Giant's luring him in"],[3061,3157,"for the killing blow."],[3194,3319,"Keep talking, fly boy."],[3319,3399,"Keep talking."],[3503,3774,"You are a janitor."],[3795,3928,"Son of a traitor."],[3928,4124,"You should have drank your bleach"],[4124,4329,"and flushed yourself down the toilet."],[4537,4633,"He's making his move."],[4833,5059,"Say goodbye, Mop Bucket."],[5413,5501,"Where'd he go?"],[5839,5893,"You know..."],[6068,6239,"I've always hated the call sign"],[6239,6297,"Mop Bucket."],[6339,6443,"Where is he?"],[6581,6698,"But the good news is,"],[6748,6898,"I think I figured out a better one."],[7032,7119,"Giant Killer."],[7340,7394,"Shit."]],"16":[[12,95,"Direct hit."],[112,216,"Direct hit."],[425,596,"The Giant eliminated."],[596,654,"God!"],[675,804,"There's no fucking way!"],[880,942,"God!"],[1026,1126,"Summers wins."],[1292,1451,"He's a genius!"],[1534,1701,"Oh my God, he actually did it."],[1860,1960,"Back to base, gentlemen."],[2206,2298,"How'd he do that?"],[2323,2469,"No one's been able to beat The Giant"],[2469,2711,"in a dogfight in five years."],[2923,3157,"It is time to meet Cole Summers"],[3178,3440,"and have him stop World War III."]],"17":[[1138,1259,"You can fly, Summers."],[1259,1338,"I'll give you that."],[1418,1484,"Summers."],[1551,1697,"Boy, you were doing things up there"],[1697,1835,"that I've never seen before."],[1931,2002,"There's a place for you"],[2002,2139,"at The Strike Fighter Tactics program,"],[2264,2369,"if you want it."],[2452,2531,"Yes, sir."],[3349,3453,"Did you see me out there?"],[3524,3670,"I told you I could do it."],[3782,3903,"I know you're good enough, son."],[4391,4454,"I've always known"],[4454,4579,"you were good enough."],[4729,4842,"I'm going to be a fighter pilot"],[4842,4925,"just like you, Dad."],[4996,5163,"You think I'm holding him back,"],[5205,5338,"because he's not good enough?"],[5409,5576,"Cole's the best fighter pilot"],[5576,5655,"I've ever seen."],[5739,5914,"You really are my son."],[6076,6277,"You're the best pilot I've ever seen."],[6398,6735,"And you were born to own those guys."]],"18":[[20,291,"You have no idea how long I've waited"],[291,408,"to hear you say that."],[1205,1292,"I’m sorry, son."],[1355,1530,"I've always wanted to tell you sooner."],[1701,1780,"But I couldn't."],[1901,1981,"Why not?"],[2168,2452,"Because of me."],[2523,2598,"Grab him."],[2806,2898,"I warned you, Rick."],[2898,2998,"Leave him alone!"],[2998,3132,"This is on you."],[3144,3249,"Dad, what's going on?"],[3265,3499,"Cole Summers, you are under arrest."]],"19":[[0,225,"Cole Summers, you are under arrest."],[225,308,"For what?"],[321,575,"For sabotaging US military equipment."],[600,950,"Does anyone think a lowly janitor,"],[950,1101,"could beat the top fighter pilot"],[1101,1197,"in the Navy?"],[1238,1476,"He sabotaged Gunnar's plane."],[1476,1572,"That's bullshit!"],[2002,2085,"I knew it!"],[2118,2277,"And my plane wasn't handling right."],[2277,2360,"It's the only way"],[2360,2523,"the Mop Bucket could have beat me."],[2523,2602,"You little bitch!"],[2602,2731,"I beat you fair and square!"],[3119,3269,"That's for cheating!"],[3282,3503,"My son could have been killed up there."],[3503,3611,"Fuck you, Tony!"],[3645,3883,"Your fight is with me, not my son!"],[3916,4058,"My fight with you is over."],[4058,4229,"It has been since I put you in a chair"],[4229,4362,"and framed you as a traitor."],[4458,4604,"Dad, what is he talking about?"]],"20":[[16,120,"This son of a bitch"],[221,362,"ruined my fucking life!"],[408,546,"It all started with him wanting me"],[546,704,"to sabotage a mission"],[729,1134,"to protect his crooked donors."],[1184,1634,"What you're asking is treason and murder."],[1714,1910,"Thousands of lives would be lost."],[1939,2198,"Thousands of people die every day."],[2198,2373,"You can't think about that."],[2423,2535,"Rick, how long have we known"],[2535,2598,"each other?"],[2686,2790,"If nothing else,"],[2790,3044,"do it as a favor to me, Rick."],[3094,3411,"I will make you an Admiral."],[3703,3837,"You can go to hell."],[3953,4237,"I will not betray my country."],[4692,4921,"Then you'll die serving it!"],[5601,5722,"Approaching the base."],[6197,6297,"Sorry, Summers."],[6339,6548,"But you should’ve done what I said."],[6664,6806,"Now you die."],[7132,7307,"My systems are down!"],[7353,7520,"Everything just went dead!"],[7661,7928,"Mayday! Mayday!"]],"21":[[1059,1192,"You son of a bitch."],[1259,1438,"You sabotaged my plane!"],[1493,1705,"That's the least of your worries."],[1730,1922,"Every crime I've committed"],[1922,2064,"will be pinned on you."],[2131,2348,"You will rot in prison"],[2348,2602,"as a traitor and a drunk."],[2686,3011,"That's what you get for playing hero."],[3098,3265,"You're gonna pay for this."],[3428,3541,"But he didn't pay!"],[3616,3866,"Because the rich never do!"],[3953,4166,"If I just would’ve listened"],[4166,4291,"to the Senator."],[4371,4500,"I could have been there for you,"],[4500,4567,"growing up,"],[4621,4742,"instead of becoming this"],[4804,4934,"embarrassment of a father."],[5230,5509,"Dad, you're not an embarrassment."],[5647,5739,"You're my hero."],[6306,6464,"I wouldn’t be so sure of that, son."],[6556,6690,"I've been sabotaging"],[6690,6848,"you becoming a pilot for years."],[7069,7240,"I'm the one who drugged you."]],"22":[[25,83,"What?"],[179,262,"Why?"],[300,396,"He said he..."],[550,842,"If your son ever becomes a pilot,"],[880,1059,"I'll make sure he dies"],[1059,1184,"on his first flight."],[1317,1426,"He said he'd kill you,"],[1484,1618,"if you ever became a pilot."],[1705,1872,"And I understand if you hate me, Son."],[2089,2260,"But I wasn't just gonna let you die."],[2377,2473,"I understand."],[2473,2623,"You were just trying to protect me."],[2681,2815,"You're Captain Rick Summers."],[2886,2973,"You're the best pilot"],[2973,3082,"this country has ever seen."],[3082,3253,"And I am proud to be your son."],[3253,3370,"I love you, Dad."],[3495,3716,"Nothing can keep me from the skies."],[3920,4033,"I hate to break up"],[4033,4241,"this trashy little love fest,"],[4241,4366,"but I promised"],[4366,4562,"if you ever became a pilot,"],[4562,4658,"I'd kill you."],[4688,4813,"And what can I say?"],[4813,5005,"I'm a man of my word."],[5005,5188,"Oh, you bastard."],[5201,5430,"Just let him go."],[5476,5572,"Or what?"],[5630,5897,"You're gonna roll over my foot?"],[6502,6564,"Dad!"],[6589,6669,"Put him down."],[7090,7190,"I’m sorry, Cole."],[7716,7882,"I'm gonna break you"],[7882,8053,"like I broke your daddy!"]],"23":[[250,400,"Less than 30 clicks out, sir."],[400,450,"Oh, good."],[450,588,"We have no time to spare."],[588,709,"We need to prep Summers"],[709,788,"for his mission."],[846,988,"The world depends on it."],[1705,1772,"Sorry..."],[1872,1943,"Dubois!"],[2831,3028,"What the hell is going on here?"],[3028,3157,"Watch your tone."],[3157,3282,"I'm a US Senator"],[3282,3395,"and I don't give a fuck"],[3395,3599,"about your rank, Admiral."],[3620,3837,"This traitorous janitor"],[3837,4037,"sabotaged my son's plane."],[4037,4170,"That's bullshit!"],[4225,4329,"The thought of my son"],[4329,4462,"sabotaging a plane"],[4462,4596,"is ridiculous!"],[4642,4771,"Not half as ridiculous"],[4771,4979,"as a low-level janitor"],[4979,5146,"with no flying skills,"],[5146,5384,"beating the top pilot in the Navy."],[5734,5834,"Prepare for landing."],[5914,5968,"Alright."],[6026,6110,"Let's meet this"],[6164,6260,"Cole Summers."],[6606,6740,"My men are gonna take him"],[6740,6835,"into custody."],[6936,7132,"And nobody has the power to stop me."],[7499,7636,"But I do!"]],"24":[[20,125,"Who the hell are you?"],[154,354,"Well, I am Agent Smith."],[371,629,"This is my associate, Agent Jones."],[663,963,"We're CIA, and we are now in charge."],[963,1176,"I am a US Senator!"],[1176,1309,"And don't you dare-"],[1413,1726,"If you'd like to remain a US Senator,"],[1747,2018,"and not a prisoner at Guantanamo Bay,"],[2060,2335,"you'll stay the fuck out of our way."],[2431,2644,"And that goes for the rest of you here."],[2694,2877,"We're CIA, and we're in charge."],[2911,3065,"And if you've got a problem with that,"],[3065,3240,"contact your superior."],[3253,3319,"Who's then gonna"],[3319,3457,"contact their superior."],[3457,3566,"And they're gonna tell you"],[3566,3745,"exactly what I said."],[3745,3970,"You can't do that to my dad!"],[4012,4316,"He is a very important-"],[4546,4612,"Dubois."],[4671,4859,"Tell your little pup here to calm down,"],[4859,5009,"or we're gonna take him out, too."],[5009,5142,"Shut the hell up, Gunnar."],[5226,5271,"But-"],[5292,5447,"I said shut the hell up!"],[5601,5693,"Cole Summers."],[5780,5880,"Cole Summers."],[5922,5993,"Yes, sir?"],[6018,6068,"We need you to"],[6068,6193,"come with us to prep."],[6302,6398,"Prep for what?"],[6506,6639,"To save the world."]],"25":[[4,120,"I need you to come with us"],[120,246,"to Black Site Delta"],[279,400,"to prep for your mission."],[400,596,"There is no way!"],[617,729,"I'm in charge here-"],[850,988,"That's for what you did to my dad."],[1046,1176,"Well, it looks like"],[1176,1405,"the Senator fell and hit his head."],[1447,1589,"Wouldn't you say, Admiral?"],[1634,1680,"Yeah."],[1718,1835,"He should be really careful."],[1914,2027,"This is bullshit!"],[2035,2156,"When my dad wakes-"],[2394,2464,"This,"],[2494,2627,"is for what you did to Nightfall."],[3382,3661,"Now, escort your boss off of my base,"],[3661,3824,"before I have him court-martialed."],[3891,3949,"So..."],[4104,4262,"Are you ready to save the world?"],[4496,4658,"I've been ready my whole life."]],"26":[[888,996,"Nothing like a little swim"],[996,1130,"before saving the world."],[1130,1305,"I'm just trying to get the poison"],[1305,1397,"out of my system."],[1735,2014,"You were amazing up there today."],[2068,2185,"How do you fly like that?"],[2223,2398,"So effortless."],[2456,2544,"Instinctual."],[2648,2752,"Everything in my life"],[2752,2840,"has been a struggle."],[2894,2973,"I have to fight for"],[2973,3073,"a lot of things, but,"],[3115,3199,"since the first time"],[3199,3340,"I went up into the sky, I just"],[3599,3703,"feel fearless."],[3757,3899,"I'm free, and I don't"],[3974,4133,"really think about it too much."],[4183,4245,"Well,"],[4300,4437,"thanks for standing up for me to Dubois."],[4542,4621,"Are you kidding?"],[4621,4783,"You would have done the same for me."],[4934,5017,"How are you feeling?"],[5130,5192,"Warm."],[5276,5405,"In need of recovery."],[5405,5513,"Mind if I join you?"],[5551,5609,"No."]],"27":[[1722,2002,"So, you're gonna save the world, huh?"],[2056,2143,"I'm gonna try."],[2193,2556,"Well, if you fail, call me."],[2736,2882,"Why would I call you if I fail?"],[2952,3011,"Well,"],[3053,3207,"if it's gonna be my last night on earth,"],[3224,3370,"I could think of a few ways"],[3370,3465,"we could spend it."]],"28":[[996,1276,"Tony, I see that one of your hookers"],[1276,1501,"has finally got some retribution."],[1555,1735,"Johan, we have a problem."],[1772,2018,"I don't pay you millions of dollars"],[2018,2227,"to come back to me with problems."],[2227,2423,"It seems the Navy has a pilot,"],[2423,2556,"who can fly that mission."],[2581,2640,"What?"],[2765,2844,"I thought that mission was"],[2844,3007,"supposed to be impossible."],[3044,3136,"It was."],[3174,3403,"Somehow, Rick Summers' boy"],[3403,3595,"snuck in and completed it."],[3616,3803,"If they complete that mission,"],[3841,4045,"then they will soon realize"],[4045,4183,"that I was the one"],[4183,4333,"that supplied the weapons."],[4396,4475,"I'll be ruined."],[4496,4692,"But I will take you down with me."],[4692,4821,"I am working on it."],[4821,4942,"Not fast enough!"],[5071,5205,"Where are they flying out of?"],[5213,5413,"CIA's Black Site Delta."],[5442,5684,"Then, that's where we'll be going."],[5714,5851,"And once I'm there,"],[5914,6164,"I will annihilate that pilot myself."]],"29":[[229,379,"I can't believe Mr. Oxblood"],[379,446,"got us sworn in"],[446,617,"as Navy Lieutenants."],[617,709,"He had to."],[734,921,"I mean, only Navy officers"],[921,1026,"are allowed down here."],[1042,1263,"Besides, we deserve it."],[1263,1405,"We are definitely smarter"],[1405,1526,"than those high school"],[1526,1705,"dropout soldiers."],[1722,1830,"Meatheads."],[1972,2210,"Our drones will be what saves"],[2210,2314,"this country."],[2314,2464,"I heard they finally found someone,"],[2464,2627,"who can lead on this mission."],[2715,2827,"Whoa, whoa, whoa. - Whoa."],[2882,2986,"What are you doing in here?"],[3015,3178,"This is a restricted area."],[3199,3370,"No grunts allowed!"],[3382,3624,"Go play your G.I. Joes."],[3687,3924,"The real heroes are at work."],[3924,4062,"Actually, I'm here to-"],[4062,4291,"What the hell is that, Seaman?"],[4291,4475,"You're supposed to salute"],[4475,4642,"when addressing an officer."],[4808,4875,"Yes, sir."],[4954,5009,"Wow."],[5034,5159,"Look at this little puppet"],[5196,5426,"having to do everything"],[5426,5605,"that we say."],[5605,5893,"It must suck to spend all your life"],[5893,6135,"working so hard to be in the Navy,"],[6135,6368,"only to be made completely obsolete"],[6368,6489,"by our machines."],[6539,6669,"Drop and give me twenty."],[6777,6823,"Are you-"],[6831,6906,"Now!"]],"30":[[258,425,"Kiss my feet while you're down there."],[696,775,"I’m not gonna do that."],[784,959,"Did I say you could speak, grunt?"],[1001,1117,"You are nothing."],[1192,1263,"Nobody."],[1409,1580,"I mean, we've been in the Navy"],[1580,1697,"for all of a day."],[1697,1881,"And we're already higher ranked"],[1881,2022,"than you'll ever be."],[2022,2152,"Okay, look, I don't have time for this."],[2152,2489,"You do not talk back to your betters."],[2631,2802,"You're going to the briggs."],[2852,2936,"You put me in the brigg,"],[2936,3011,"and the fate of the world"],[3011,3123,"is in your hands."]],"31":[[41,150,"Alright, it's time for you both"],[150,237,"to know who I am"],[237,333,"and what I'm doing here."],[333,433,"I'm done with you!"],[1034,1117,"Don't try to dance"],[1117,1242,"if you don't know the steps."],[1280,1472,"Are you resisting arrest, Seaman?"],[1484,1614,"I'm not resisting anything."],[1614,1730,"Please, go tell your boss"],[1730,1864,"that Cole Summers is here."],[1864,1947,"What an idiot!"],[1947,2064,"Does he think anyone cares"],[2064,2131,"who he is?"],[2131,2298,"I'm so happy that we don't have to"],[2298,2423,"deal with these meatheads"],[2423,2494,"all the time."],[2548,2769,"My supervisor hasn't arrived yet,"],[2794,2923,"but he's about to lead"],[2923,3053,"one of the most important"],[3053,3236,"and dangerous missions of all time."],[3236,3303,"So I don't think"],[3303,3436,"he gives a fuck about you,"],[3436,3524,"Cole Summers!"],[3553,3645,"She doesn't realize"],[3645,3778,"I'm the one leading the mission."],[3778,3937,"I'll give you three seconds"],[3937,4058,"to get out of here."],[4062,4129,"Three."],[4175,4254,"Two."],[4404,4496,"Just listen to me."],[4592,4696,"Put the gun down,"],[4788,4850,"slowly."],[4925,5171,"If you don't get the fuck out of here!"],[5372,5463,"The hell are you doing?"],[5772,5889,"Lower your firearm."],[5922,5989,"Now!"]],"32":[[20,158,"I don't have to listen to you!"],[175,350,"I'm a very important part"],[350,458,"of this project!"],[604,738,"What the hell is your problem?"],[759,850,"Who are you?"],[930,988,"Jaeger."],[1071,1217,"Admiral Jaeger."],[1493,1605,"And you absolutely have to do"],[1605,1705,"what I say."],[1735,1872,"Now, I don't give a damn,"],[1872,2110,"if Johan Oxblood pulls strings for you."],[2110,2323,"If you ever talk to a ranking officer"],[2323,2439,"like that ever again,"],[2439,2548,"I will personally send you"],[2548,2627,"to your maker."],[2627,2711,"Understood?"],[2907,2973,"Yes, sir."],[2990,3236,"It's, It’s just that this enlisted grunt"],[3236,3294,"tried to get into"],[3294,3399,"this high security room."],[3428,3749,"This grunt is Cole Summers."],[3770,3845,"And you will treat him"],[3845,3974,"with the utmost respect."],[3974,4083,"Understand me?"],[4083,4416,"He's just a basic seaman! A nobody!"],[4416,4533,"Yeah, he doesn't belong here"],[4533,4671,"with us officers."],[4829,5075,"You know, they do have a point."],[5301,5367,"See?"],[5442,5563,"Fucking idiot. - My God, right?"],[5580,5739,"Congratulations, Cole Summers."],[5872,6014,"You've now been promoted to captain."],[6477,6552,"Thank you, sir."]],"33":[[229,358,"Now salute your captain."],[525,579,"Now!"],[654,734,"Furthermore,"],[754,992,"you will do whatever he says."],[1059,1176,"What, what the hell is-"],[1197,1422,"What, the hell is he doing in here?"],[1501,1576,"And who are you?"],[1626,1760,"I'm Lynn Penzie."],[1760,2031,"Formerly the Chief Technical Officer"],[2031,2210,"of Oxblood Weaponry."],[2210,2344,"And as of today,"],[2344,2590,"Admiral of the US Navy."],[2627,2840,"So they made a tech exec an admiral?"],[2886,3028,"Well, desperate times calls"],[3028,3119,"for desperate measures."],[3119,3336,"Especially when fools like you"],[3336,3499,"are allowing sons of traitors"],[3499,3666,"into these private meetings!"],[3666,3749,"You don't know what the hell"],[3749,3845,"you're talking about."],[3862,3920,"Don't I?"],[3941,3983,"Everyone,"],[4004,4270,"look up Rick Summers."],[4754,4963,"Oh my God."]],"34":[[221,342,"His father went to prison"],[342,525,"for betraying his country."],[675,917,"He's here to steal secrets,"],[955,1276,"just like his commie old man."],[1297,1468,"This unpatriotic bastard should be"],[1468,1651,"tossed off the side of this cliff!"],[1714,1847,"I'd like to see any of you"],[1847,2031,"stolen-valor weaklings try."],[2156,2210,"Stop it!"],[2235,2548,"I will not be ridiculed by a traitor!"],[2581,2861,"How stupid are you military dumbasses?"],[2869,3015,"You mouth breathers"],[3015,3157,"just let him run around,"],[3157,3403,"while threatening the real talent!"],[3403,3457,"Yeah."],[3490,3632,"it took us all of what,"],[3632,3828,"one second to figure out,"],[3828,4108,"he's a spy from a family of traitors?"],[4108,4279,"Call me or my father a traitor again,"],[4279,4350,"and I will show you"],[4350,4433,"what the difference is"],[4433,4558,"between a real soldier"],[4558,4738,"and a tech bro who plays dress up."]],"35":[[279,400,"Summers should’ve been back"],[400,571,"from the situation room by now!"],[571,696,"I hope those Oxblood idiots"],[696,834,"haven't given him too much trouble."],[946,1076,"Brown, get in here."],[1109,1284,"Listen, you need to go"],[1284,1430,"to the situation room right now,"],[1430,1555,"and make sure that that mission leader"],[1555,1680,"has everything he needs."],[1710,1789,"Yes, sir."],[1860,2077,"And Brown, do not be afraid to"],[2077,2243,"crack some skulls if you need to."],[2752,2927,"Admiral, are you just gonna"],[2927,3182,"let this Anti-American spy"],[3182,3428,"speak to a superior officer like that?"],[3503,3557,"Yeah."],[3603,3695,"I think I am."]],"36":[[29,120,"What-"],[133,225,"Did you hear that?"],[275,479,"This so-called admiral"],[479,734,"is conspiring with a filthy traitor!"],[746,863,"I, I’ll have you both"],[863,955,"court-martialed for this!"],[963,1217,"You, you, take them away now!"],[1676,1739,"You."],[1764,1856,"Don't look at me."],[1956,2122,"You're all a disgrace to the uniform."],[2198,2306,"Just give up, Penzie."],[2331,2419,"You don't have the power"],[2419,2548,"to have us arrested."],[2577,2706,"I don't have the power?"],[2706,2882,"This is my technology!"],[2882,3044,"These are my drones-"],[3044,3328,"And this is my base!"],[3561,3753,"Admiral of the Pacific Fleet on deck."],[4308,4717,"Now, can you give me one good reason,"],[4792,5055,"why I don't make you just disappear?"]],"37":[[141,375,"You, you can't talk to me like that!"],[467,546,"Gentlemen?"],[679,963,"Escort Admiral Panzie-ass"],[988,1176,"out of my situation room."],[1176,1447,"It's, it's, it's, it's Penzie."],[1447,1534,"Wait, hey, hey!"],[1534,1609,"You can't-"],[1609,1797,"I'm, I'm Lynn Penzie!"],[1797,1885,"I'm gonna be-"],[1885,1993,"I'm the one in charge of this!"],[1993,2077,"Whatever."],[2223,2369,"Captain Cole Summers,"],[2448,2585,"It is my honor, sir."],[2631,2736,"The honor is mine, sir."],[2806,2952,"You've got to be kidding me!"],[2952,3048,"Why is the man in charge of"],[3048,3219,"the entire Pacific Fleet"],[3219,3353,"giving so much respect"],[3353,3570,"to this lowly traitor?"],[3591,3720,"Maybe he really is the person"],[3720,3849,"who's going to lead this mission."],[4258,4504,"This is, this is, bullshit!"],[4558,4821,"I was promised by Oxblood himself,"],[4842,5034,"that I would be in charge."],[5138,5417,"I am supposed to be leading this mission!"],[5701,5801,"Listen, you need to"],[5801,6018,"go to the situation room right now"],[6018,6143,"and make sure that that mission leader"],[6143,6277,"has everything he needs."],[6493,6623,"You're the leader of this mission?"],[6865,7015,"Yes, I am."],[7057,7123,"Except for some"],[7123,7298,"bullshit meatheads in there"],[7298,7432,"just trying to take me away"],[7432,7674,"from doing the job I was born to do!"],[7766,7866,"Don't worry, sir."],[7903,7991,"I'm here to help."]],"38":[[62,137,"Listen up!"],[175,283,"Eyes front!"],[429,608,"This is Captain Cole Summers."],[663,788,"The finest damn pilot,"],[788,942,"this country's ever seen."],[942,1092,"The man, now,"],[1121,1263,"in charge of this mission."],[1338,1401,"Captain."],[1447,1555,"Captain,"],[1605,1976,"Look, I, I am so, so sorry."],[2043,2223,"I was fed wrong information!"],[2223,2494,"I have nothing but respect for-"],[2494,2610,"Sorry, didn't you just tell me"],[2610,2786,"to kiss your feet two seconds ago?"],[3044,3174,"And you drew your firearm"],[3174,3299,"on your commanding officer."],[3299,3399,"I, I, I..."],[3536,3661,"I can't trust either of you"],[3661,3757,"and you're clearly incompetent."],[3757,3849,"You're off this mission."],[3849,3924,"You can't!"],[3924,3983,"Clear out!"],[3983,4049,"Now!"],[4104,4200,"That's enough!"]],"39":[[25,112,"Who the hell are you?"],[112,225,"Watch it, flyboy."],[241,379,"The real power is in the room."],[437,525,"Real power?"],[600,658,"Son."],[738,880,"I am Admiral Baldwin,"],[934,1138,"Commander of the Pacific Fleet."],[1292,1347,"And you are?"],[1347,1501,"Not in your chain of command."],[1568,1760,"And I don't care who you are."],[1830,2064,"My name is Agent Brown."],[2106,2252,"CIA."],[2394,2669,"I am in charge of this"],[2669,2890,"unofficial and top secret mission."],[2915,3132,"And we are the ones who call the shots."],[3157,3236,"And if anyone wants to"],[3236,3407,"have a pissing contest with me,"],[3457,3720,"I promise you, you will lose!"],[3778,3933,"Now, I understand that some of you"],[3933,4108,"have decided to throw out"],[4108,4250,"Admiral Penzie,"],[4250,4387,"the leader of this mission."],[4387,4512,"That's because Admiral Peewee is"],[4512,4646,"not the leader of this mission."],[4646,4717,"I am."],[4771,4929,"I designed the drones."],[4954,5059,"I'm in charge."],[5059,5259,"Your drones are only designed"],[5259,5451,"to assist the pilots."],[5480,5822,"You really think a human can navigate"],[5822,5951,"and run this mission?"],[5955,6185,"The era of meathead sky jockeys"],[6185,6281,"is over."],[6310,6493,"Let the geniuses take over now."]],"40":[[12,183,"This makes so much more sense."],[183,321,"Why would they put the fate of the world"],[321,454,"in that guy's hand?"],[454,571,"Maybe back in World War Two"],[571,642,"or something,"],[679,846,"but this is the digital age."],[880,1009,"We are the real heroes now."],[1042,1101,"Yeah."],[1101,1242,"But don't feel too bad."],[1255,1359,"I tell you what."],[1405,1555,"If you're a real good boy,"],[1605,1810,"I'll let you fly my private jet."],[1872,2127,"You could be my chauffeur."],[2127,2181,"Oh."],[2248,2389,"Hey, look."],[2427,2598,"Don't take it personal."],[2640,2790,"I support the troops."],[2794,2994,"Hey, I almost joined the reserves"],[2994,3069,"in the military."],[3069,3140,"Doubt it."],[3140,3244,"But right now,"],[3244,3532,"the real men need to work."],[3561,3866,"So that means you and your bosses"],[3866,4016,"with their little medals"],[4041,4237,"need to get the fuck out"],[4237,4416,"of my situation room!"],[4416,4542,"I'd worry much less about"],[4542,4642,"what my bosses,"],[4642,4792,"who are both decorated veterans,"],[4792,4892,"who have served this country"],[4892,5071,"long before you were even born"],[5071,5159,"are doing,"],[5171,5259,"and worry more about"],[5259,5413,"what your bosses are gonna say."],[5472,5605,"What are you talking about?"],[5638,5764,"I'm talking about your bosses,"],[5764,6026,"Agent Smith and Agent Jones."],[6218,6297,"How, how did you"],[6297,6435,"know my bosses' names?"]],"41":[[467,596,"Where the hell is Brown?"],[650,763,"He should've reported in by now."],[804,905,"Leave it to that"],[905,1163,"fucking Ivy-League asshole"],[1163,1313,"to fuck up a simple task."],[1313,1376,"Come on!"],[1405,1539,"We gotta go to the situation room"],[1539,1605,"right now."],[2264,2423,"I thought you knew everything, CIA."],[2423,2669,"I asked you a fucking question."],[2669,2898,"How did you know my bosses' names?"],[2927,3090,"Are you really the leader"],[3090,3207,"of this mission?"],[3257,3436,"Fucking moron, no!"],[3436,3599,"Do you think that your bosses"],[3599,3766,"are gonna put a redneck pilot"],[3766,3845,"in charge?"],[3845,4033,"He probably got that information"],[4033,4245,"from his commie connections."],[4250,4487,"A traitor, just like his father."],[4504,4596,"He's a spy!"],[4646,4750,"That's gotta be it!"],[4771,4888,"I'm onto your shit!"],[4963,5246,"And this patriot can't be fooled"],[5246,5572,"by stupid commie traitors like you!"],[5572,5668,"That's enough!"],[5709,5951,"Agent, you are way out of line!"],[5980,6089,"You and your men"],[6089,6268,"stand down, and leave!"],[6268,6356,"Do you hear this?"],[6356,6418,"Now!"],[6418,6498,"Do you hear him?"],[6535,6677,"He's trying to forcibly"],[6677,6835,"take over this mission,"],[6835,7077,"so that his stupid outdated Navy"],[7077,7228,"can take all the credit?"],[7257,7494,"Not only is this behavior reckless,"],[7536,7691,"it's treasonous!"],[7887,8149,"And I will not let it stand!"]],"42":[[225,396,"I swear to God,"],[396,533,"if Brown does anything"],[533,608,"to Summers,"],[608,779,"I will have his head on a spike."],[817,959,"Just call Smith and Jones,"],[959,1096,"they'll tell you what's going on."],[1096,1242,"I don't need to talk to them."],[1267,1438,"I am perfectly capable"],[1438,1609,"of handling a couple of fools!"],[1609,1780,"These are admirals in the US Navy!"],[1780,1856,"Exactly."],[1868,2014,"And if they were actually smart,"],[2014,2189,"they would be in the private sector."],[2189,2389,"Do you realize that I make"],[2389,2719,"billions in my stock options alone?"],[2902,3144,"Brown, have your soldiers"],[3178,3374,"get rid of them now."],[3411,3478,"You heard the man."],[3478,3766,"We do not have time for this bullshit!"],[3816,4045,"We have a mission to prepare for!"],[4045,4229,"Brown, if you do this,"],[4270,4341,"you will regret it"],[4341,4471,"for the rest of your life."],[4471,4596,"That sounds like a threat?"],[4662,4900,"The CIA does not respond kindly"],[4900,5005,"to threats!"],[5042,5125,"Cut him down!"],[5192,5246,"Now!"],[5296,5422,"Sir, he's unarmed."],[5422,5538,"Too much of a pussy?"],[5538,5638,"Fine, I'll do it!"],[5939,6064,"This is what you get,"],[6064,6252,"when you fuck with me!"],[6256,6381,"Just put the gun down!"],[6435,6506,"Brown!"],[6656,6823,"What the hell is going on?"]],"43":[[0,171,"The hell are you doing? Huh?"],[196,337,"No need to worry, sir."],[337,579,"These Navy cavemen tried to"],[579,775,"sabotage Admiral Penzie's mission."],[775,950,"But I've taken care of them."],[1005,1267,"Finally, some real leadership here."],[1309,1522,"I'm Lynn Penzie, and as of yesterday,"],[1547,1764,"I'm an Admiral in the Navy."],[1810,1881,"Are you?"],[1906,2081,"I am, but don't worry."],[2089,2235,"I'm from the tech world."],[2268,2427,"I didn't spend my days,"],[2427,2502,"shitting in some"],[2502,2644,"bunker in the Middle East."],[2706,2769,"Wow."],[2923,3082,"Brown, I understand"],[3082,3315,"that you forcibly took the power"],[3315,3428,"from these men,"],[3495,3799,"and you just handed it over"],[3824,3933,"to Admiral Penzie."],[3933,4016,"Yes, sir."],[4054,4179,"Just doing my job. - Yeah."],[4208,4320,"No need for a promotion"],[4320,4396,"or anything."],[4733,4888,"Arrest this fucking idiot!"],[4904,5046,"This motherfucker!"],[5046,5138,"What? Why?"],[5138,5334,"Cole Summers is the mission leader here!"],[5334,5609,"You limp-dick motherfucker!"]],"44":[[0,200,"You're the actual leader"],[200,300,"of this mission?"],[321,442,"I tried to warn you."],[467,588,"And now get him out of here!"],[588,642,"No!"],[663,880,"I am so, so sorry."],[880,971,"I'll do anything."],[971,1026,"Forgive me."],[1026,1113,"I was wrong-"],[1155,1301,"Oh, take him away."],[1301,1384,"Get out of here!"],[1384,1434,"No!"],[1455,1564,"Come on. - Please!"],[1564,1693,"Bought yourself a ticket to"],[1693,1793,"Guantanamo. - No!"],[1818,1910,"No!"],[1997,2097,"No!"],[2356,2498,"Where are you going, Admiral?"],[2527,2569,"Huh?"],[2569,2711,"Are you gonna arrest me?"],[2711,2836,"Of course not."],[2836,2977,"I'm not gonna arrest you."],[2998,3174,"I mean, you're an Admiral"],[3174,3286,"in the US Navy."],[3319,3478,"Yes, I am."],[4137,4250,"Which now means,"],[4329,4496,"you come under my command,"],[4496,4738,"Admiral Panzie-ass!"],[4821,5125,"And yes, I will court-martial you."],[5184,5280,"Get him out of here!"],[5280,5451,"No, you cannot do that!"],[5451,5605,"I am very important!"],[5605,5843,"I'm very important!"],[5843,5897,"Yeah."],[5901,5997,"Bye bye now."],[6177,6239,"Admiral."],[6364,6573,"This is Cole Summers,"],[6573,6856,"the greatest pilot in the world."],[6915,7182,"And he is also our last, best hope."],[7194,7336,"So everyone in here"],[7336,7607,"is going to do exactly as he says."],[7607,7757,"Anybody have a problem with that?"],[7953,8087,"I have a problem with it."]],"45":[[237,400,"I know you're the best fighter pilot"],[400,475,"on the planet."],[579,688,"But I'm still your father."],[784,880,"You're about to go on"],[880,1042,"one of the most dangerous missions"],[1042,1192,"in US military history."],[1284,1451,"Thought you could use a familiar face."],[1488,1747,"Even if it's a rough one like mine."],[2181,2302,"What are you doing here?"],[2318,2565,"Just... here for moral support."],[2652,2731,"Nothing else?"],[2765,2969,"And, Captain Summers,"],[3019,3257,"if you shit the bed, I'm your back up."],[3887,4070,"I'm sorry for what I did to you, son."],[4099,4145,"It's okay."],[4145,4208,"I know you were just"],[4208,4283,"trying to protect me."],[4283,4437,"But I didn't protect you."],[4458,4550,"I held you back."],[4671,4758,"But not anymore."],[4825,5005,"I was briefed about this mission."],[5025,5159,"If it was any other pilot"],[5159,5234,"on the planet,"],[5234,5342,"it would be impossible."],[5372,5455,"But not with you."],[5484,5580,"You can do this."],[5638,5747,"You're the only one."],[5855,5964,"And I'm gonna be here every step"],[5964,6139,"of the way to watch your back."],[6272,6368,"You alright, kiddo?"],[6631,6681,"Yeah."],[6806,6848,"I'm good."],[6848,6927,"Let's fucking do this."],[6927,7057,"Kick their ass."],[7378,7649,"Aw, so sweet."],[7699,7899,"Sorry to spoil the party."],[7945,8087,"But Cole Summers"],[8087,8341,"will no longer be part of this mission."]],"46":[[100,371,"Oxblood, what are you doing here?"],[379,558,"I supply the weapons,"],[558,788,"so of course I'm gonna come here"],[788,1021,"and see if you're using them correctly."],[1046,1230,"And if you think this punk"],[1230,1401,"is gonna fly with my drones,"],[1480,1647,"you're in for a rude awakening."],[1689,1868,"Mr. Oxblood, Cole is the best pilot-"],[1956,2110,"Admiral Baldwin,"],[2135,2348,"why is your secretary talking to me?"],[2348,2573,"That secretary is one of the best pilots"],[2573,2686,"in the US Navy."],[2686,2802,"Show some respect."],[2865,3032,"Watch your tone, boy."],[3069,3274,"You are talking to the man,"],[3307,3461,"who is single-handedly"],[3461,3582,"responsible for"],[3582,3724,"protecting our country."],[3724,4012,"Like, even these CIA boogeymen,"],[4012,4187,"they know to respect him."],[4208,4371,"He's the real patriot,"],[4371,4512,"more than any of you."],[4558,4675,"So, in the future,"],[4675,4771,"please remember that"],[4771,5080,"this is a high-priority security meeting,"],[5080,5171,"not a gathering of"],[5171,5467,"the Cole Summers fan club."],[5693,5822,"As a member of this"],[5822,5972,"high-priority security meeting,"],[5972,6047,"I'd like to remind you"],[6047,6206,"that we are hours away from an attack"],[6206,6393,"that'll decimate every major US city,"],[6393,6581,"cost tens of millions of lives,"],[6581,6715,"and plunge us into World War III."],[6740,6877,"I'd also like to remind you"],[6877,6961,"that the only human"],[6961,7082,"capable of preventing that"],[7082,7182,"is Cole Summers."],[7207,7282,"So yeah,"],[7298,7490,"I'm a part of his fucking fan club,"],[7499,7628,"and if you valued your life,"],[7628,7711,"you would be too."]],"47":[[16,125,"And there it is."],[141,279,"The only human"],[279,500,"capable of preventing it."],[596,917,"Gentlemen, oh, and lady."],[1046,1184,"Are we going to"],[1184,1518,"allow human error to be a factor"],[1551,1697,"in the fate of the world?"],[1718,1835,"Not on my watch."],[1893,2081,"And fortunately, we don't need to."],[2097,2385,"Not when the bombs can be deployed"],[2385,2727,"by my new Mark-Six drones."],[2773,2927,"Are you serious?"],[2965,3073,"You actually think"],[3098,3336,"a squadron of your M-6 drones,"],[3336,3595,"can get to the enemy base unescorted?"],[3607,3766,"Of course they can't."],[3799,4020,"But by then, me and my allies"],[4020,4166,"will be safe in my bunker."],[4191,4304,"No one will find out"],[4304,4450,"I'm supplying the enemy."],[4542,4713,"My drones can destroy"],[4713,4971,"the enemy base with ease."],[4992,5046,"No."],[5105,5430,"We cannot just have the fate of the world"],[5430,5626,"with some unproven tech."],[5663,5972,"Thank you for your cute little opinion."],[6022,6281,"But this time, you've been overruled."],[6310,6573,"The Congressional Security Council"],[6627,6781,"had an emergency meeting"],[6781,6848,"this morning,"],[6848,7198,"and I quote, due to the drones' ability"],[7198,7449,"to outperform any human pilot,"],[7478,7595,"the drones"],[7595,7799,"will be completing this mission."]],"48":[[20,258,"This is absolute bullshit!"],[312,454,"This operation is-"],[454,696,"Is no longer your concern."],[738,905,"I had a little chat"],[905,1042,"with our dear friends"],[1042,1222,"at the Joint Chiefs of Staff,"],[1251,1497,"and they said that the CIA"],[1497,1751,"is no longer part of this operation."],[1785,1981,"You can't be serious!"],[2006,2085,"Guards."],[2122,2223,"Get them out of here."],[2252,2331,"Look, no, no,"],[2331,2498,"this is not gonna be necessary."],[2498,2669,"We can find our own way out."],[2890,2957,"Summers."],[3028,3115,"It's up to you now."],[3207,3303,"Don't let us down."],[4175,4291,"Actually, Summers,"],[4291,4508,"you will be letting him down."],[4542,4800,"Your services are no longer required."]],"49":[[20,100,"You can't do that."],[129,296,"You're way out of line."],[312,513,"Actually, Summers, your promotion"],[513,775,"was based on flying this mission."],[838,1096,"And since it's abundantly clear,"],[1117,1472,"that my weapons are totally superior"],[1472,1685,"to anything you can provide,"],[1735,1960,"then you're no longer needed"],[1960,2056,"for this mission."],[2164,2264,"No mission,"],[2481,2565,"no promotion."],[2777,2886,"Not now, son."],[2911,3007,"I'm sorry, Cole."],[3048,3144,"You'll get your chance."],[3265,3390,"I give you my word."],[3411,3557,"The hell he will."],[3586,3703,"He assaulted me."],[3703,3770,"I'll have you"],[3770,3887,"dishonorably discharged"],[3887,3999,"before the end of the day."],[4099,4270,"Just like your traitor dad."],[4788,4875,"Oxblood team."],[4984,5155,"Deploy the drones."],[5251,5342,"Woohoo!"],[5359,5438,"Yeah!"],[5772,5985,"Get this mop-jockey out of here."]],"50":[[1589,1693,"How you holding up, son?"],[1739,1839,"Yeah, Dad, I'm great."],[1843,1989,"It's awesome to be behind bars"],[1989,2106,"on my last day on Earth."],[2235,2327,"I brought you something."],[2606,2752,"Might cheer you up."],[2940,3057,"Is that your old helmet?"],[3098,3182,"Updated."],[3269,3361,"With your..."],[3599,3703,"new call sign."],[3799,3878,"Legacy."],[3899,3974,"If you like it,"],[4008,4195,"it would be a real honor for the family."],[4312,4362,"It would,"],[4421,4579,"it would be a real honor for me."],[4646,4821,"I'm honored to be your legacy, but"],[5005,5080,"I failed."]],"51":[[4,112,"Dad, I'm grounded."],[133,204,"It's over."],[646,734,"There's still time."],[779,950,"You can still fly this mission."],[1009,1096,"I'm grounded."],[1142,1380,"Those two Dubois guards"],[1380,1564,"standing behind me"],[1639,1718,"are the only thing"],[1718,1847,"standing between you"],[1943,2198,"and a fully loaded F-18"],[2198,2314,"with enough range"],[2314,2489,"to get you to that enemy base."],[2489,2585,"Are you crazy?"],[2585,2706,"You want me to steal a jet?"],[2769,2907,"I'd be kicked out of the Navy."],[2932,3032,"You stole,"],[3157,3336,"our neighbor's plane,"],[3395,3591,"when you were ten years old."],[3649,3778,"Wasn't the end of the world."],[3895,4099,"If you don't steal that jet,"],[4204,4291,"it could"],[4291,4496,"quite possibly be the end of the world."]],"52":[[316,492,"Let's go, janitor boy."],[513,684,"We're taking you back to the States."],[3670,3770,"Sorry, boys."],[3866,3999,"I've got a plane to catch."]],"53":[[325,462,"Where the hell is Oxblood?"],[483,663,"These are his goddamn drones."],[663,846,"Oxblood and Dubois left last night"],[846,963,"along with his techies."],[975,1059,"We don't know where."],[1080,1138,"Damn it."],[1201,1413,"We'll have to send them in without Cole."],[1776,1885,"Launch the drones."],[1976,2089,"Drones deploying, sir."],[2327,2469,"If you believe in God,"],[2544,2635,"start praying."],[3737,3903,"I can get used to this."],[3920,4062,"Well, you had better."],[4062,4145,"We're gonna be here"],[4145,4371,"until the nuclear fallout has cleared."],[4412,4491,"And then,"],[4562,4763,"the world is ours."]],"54":[[16,158,"Drones approaching the run, sir."],[250,329,"Send them in."],[538,625,"They're not fast enough,"],[625,709,"they'll be shot down"],[709,834,"by the surface-to-air system."],[834,996,"Well, accelerate, goddamnit."],[996,1051,"They're not gonna make it"],[1051,1155,"at this speed."],[1155,1217,"I'm trying, sir,"],[1217,1343,"but they're at max speed."],[1755,1851,"We've lost one drone."],[1922,2110,"Well, override their speed regulators."],[2110,2248,"If I do that, we could lose control."],[2273,2427,"I don't give a good goddamn."],[2427,2569,"They're gonna fail if you don't!"],[2602,2669,"Affirmative."],[2673,2806,"Overriding speed regulators."],[3420,3520,"We've just lost another one"],[3520,3632,"to anti-air fire."],[3653,3753,"Push them faster!"],[3753,3820,"Damn it!"]],"55":[[137,275,"Sir, they're starting to shut down."],[316,404,"How far out are we?"],[458,583,"Still two clicks away, sir."],[621,779,"Push, push, push!"],[1034,1163,"One just collided with the valley."],[1238,1338,"Only two left."],[1405,1530,"They're approaching the Death Bend."],[1664,1764,"Come on, come on, come on."],[1989,2097,"Another drone down."],[2122,2293,"Final drone coming to the Death Bend"],[2293,2515,"in three, two, one."],[2802,2886,"Come on."],[3274,3349,"Come on,"],[3370,3457,"get through it."],[3470,3624,"Come on, let's go, let's go!"],[3912,4045,"Final drone down."],[4066,4149,"Mission failure."],[4149,4316,"I repeat, mission failure."],[4371,4441,"Damn it!"],[5839,5980,"To the new world."],[6001,6168,"Where we will be kings."]],"56":[[208,308,"So, that's it?"],[308,425,"There's nothing we can do?"],[471,546,"I'm afraid not."],[546,608,"What if I try?"],[608,704,"I can take one of the jets and then I-"],[704,759,"No."],[884,967,"The enemy nukes launch"],[967,1067,"in less than three minutes."],[1067,1172,"You'd never make it in time."],[1172,1263,"There's gotta be something"],[1263,1322,"we can do!"],[1322,1409,"It's too late!"],[1651,1801,"The only thing left is to..."],[1868,1985,"to let the men know."],[2160,2356,"Men and women of Black Site Delta."],[2448,2577,"This is Admiral Baldwin."],[2673,2756,"I have an announcement"],[2756,2836,"I hope I'd never,"],[2919,3032,"never have to make."],[3053,3244,"In a few moments, this base,"],[3290,3524,"as well as most strategic targets,"],[3561,3712,"all major US cities"],[3803,3899,"will be destroyed."],[4170,4320,"This is Captain Cole Summers."],[4592,4717,"I'm approaching the target."]],"57":[[287,342,"Cole?"],[396,471,"I thought they took you"],[471,558,"back to the States."],[596,734,"Yeah, about that."],[817,980,"You're gonna find the two Dubois guards"],[980,1188,"having a nice little nap in my jail cell."],[1259,1313,"Really?"],[1384,1539,"You knocked out two of the Senator's men?"],[1597,1718,"Also, I hope it's okay"],[1718,1797,"that I commandeered"],[1797,1960,"this seventy-million- dollar jet."],[2035,2152,"Figured if I save the world,"],[2152,2243,"we can call it even."],[2243,2377,"You got a deal, son!"],[2389,2510,"Pull up his coordinates!"],[2510,2690,"Let's get this man some support!"],[2840,2911,"Location up."],[2927,3011,"He's four clicks"],[3011,3103,"from the start of the run."],[3169,3290,"Alright now, Captain Summers."],[3311,3503,"This will be harder than a VR simulation."],[3524,3628,"Because of the drones,"],[3636,3728,"they'll know you're coming."],[3749,3816,"Roger that."],[3899,4029,"Accelerating to Mach One."],[4237,4475,"F-18 entering enemy territory."],[4512,4617,"What the hell's going on?"],[4675,4758,"Summers."]],"58":[[37,125,"Captain Summers,"],[196,337,"you're almost to Death Bend."],[492,671,"What the hell is going on there?"],[692,842,"Senator, we don't have time"],[842,938,"for this bullshit."],[988,1222,"A disgraced con steals a jet"],[1222,1288,"and goes on"],[1288,1447,"an unsanctioned mission,"],[1480,1676,"and you dare to talk to me like that."],[1705,1885,"If you don't abort this mission"],[1885,1981,"right now,"],[2006,2164,"I will get the President"],[2164,2260,"himself involved."],[2260,2414,"I think the President's"],[2414,2544,"maybe a little busy dealing with"],[2544,2681,"the end of the world, Senator."],[2706,2923,"Alright, smart ass."],[2944,3169,"We know you're nothing but a fake"],[3169,3365,"who can't fly an F-18."],[3749,3845,"Approaching base."],[3953,4074,"You die today."],[4233,4371,"My systems are down!"],[4404,4554,"Everything just went dead!"],[4592,4667,"Mayday!"],[4704,4771,"Mayday!"],[4771,4929,"And something tells me"],[4929,5267,"janitor boy is going to crash right"],[5342,5417,"now."]],"59":[[145,212,"Now."],[442,542,"Everything's stable."],[575,671,"Approaching the valley."],[1055,1126,"Before I commandeered"],[1126,1213,"this here jet,"],[1284,1418,"I did a thorough investigation"],[1418,1514,"of all its systems."],[1514,1685,"And I found this little microchip"],[1764,1910,"embedded into its coding."],[2043,2139,"So I took it out."],[2185,2385,"Oxblood has a kill switch?"],[2389,2560,"And my guess, is that"],[2560,2702,"if you look at my dad's plane"],[2702,2811,"that he flew in that mission"],[2811,2907,"all those years ago,"],[2948,3132,"you'll find the same kill switch installed."],[3157,3299,"Listen you janitor shit,"],[3299,3586,"I will destroy you and everyone you love."],[3616,3741,"And you Admirals"],[3770,3933,"will be tried for treason"],[3933,4041,"when this is over."],[4049,4320,"I'm a very powerful man and I-"],[4508,4571,"Whoops!"],[4600,4767,"Must have accidentally"],[4767,4863,"terminated his feed."],[4892,4959,"Silly me."],[5009,5096,"Captain Summers,"],[5130,5246,"you're clear for the mission."],[5284,5363,"Godspeed."]],"60":[[212,350,"Surface-to-air missile systems"],[350,396,"are engaging."],[396,546,"I'm accelerating to Mach Two."],[554,704,"He's going almost Mach Two"],[704,796,"through Death Bend."],[1017,1092,"What?"],[1092,1247,"That's suicide. Cole, please!"],[1547,1643,"Talk to me, Dad."],[1768,1876,"When you’re up there,"],[1989,2260,"just trust your instincts."],[2298,2373,"Just let go,"],[2498,2594,"and soar."],[3044,3119,"He's blasted through"],[3119,3224,"the surface-to-air system."],[3224,3336,"Too fast to track."],[3353,3486,"You're at the Death Bend danger zone."],[3545,3657,"Slow down."],[3787,3928,"Eight seconds til the enemy rockets"],[3928,4004,"are operational."],[4346,4387,"No!"],[4454,4529,"You'll crash."],[4558,4617,"Five..."],[4704,4763,"Four..."],[4867,4917,"Three..."],[5013,5080,"Two..."],[5280,5334,"One."]],"61":[[200,262,"What happened?"],[296,375,"The icon disappeared."],[375,471,"Does that mean Cole crashed?"],[471,542,"We don't know."],[571,688,"We have no satellite signals"],[688,746,"in that area."],[800,871,"So either."],[888,1067,"Either he made it to the base or..."],[1080,1142,"he's failed."],[1213,1297,"The enemy nukes"],[1297,1388,"are already launched."],[1418,1526,"Come on, Cole."],[1630,1722,"Captain Summers."],[2177,2310,"You can do this, my boy."],[2431,2523,"Captain Summers."],[2644,2786,"Captain Summers, do you read me?"],[2786,2836,"Cole!"],[2898,3007,"Cole, are you there?"],[3119,3211,"I'm afraid that..."],[3311,3382,"Cole!"],[3645,3737,"Direct hit!"],[3874,4012,"Enemy base destroyed."]],"62":[[8,133,"Target eliminated."],[246,375,"Oh my God!"],[521,650,"Yes! - Yes!"],[767,829,"Yes!"],[913,1001,"That's my boy."],[1130,1251,"Heading back to base."],[1459,1580,"This means nothing."],[1580,1764,"You disobeyed direct orders."],[1764,1951,"And you'll all be court-martialed"],[1951,2056,"and tried for treason."],[2185,2364,"I don't think so, Senator."],[2364,2515,"And you better find a good rock"],[2515,2606,"to hide under,"],[2606,2698,"because I'm coming"],[2698,2882,"for your treasonous ass!"],[3011,3174,"Who do you think the US government's"],[3174,3261,"gonna choose?"],[3261,3411,"Rogue officers"],[3428,3495,"or me,"],[3495,3691,"who supplies the entire"],[3691,3866,"advanced weapons stockpile"],[3866,3949,"to the United States?"],[3949,4145,"And the enemy."]],"63":[[25,221,"How the hell did you get in here?"],[241,362,"We're CIA."],[392,508,"You know, we devised a way"],[508,583,"into your bunker"],[583,750,"before it was even finished."],[750,875,"You two are trespassing,"],[875,1088,"and I'm going to have you arrested."],[1088,1192,"I don't think so."],[1238,1405,"You see, the video footage"],[1405,1526,"from Summer's jet"],[1559,1872,"confirmed what we had long suspected."],[1872,1976,"That the two of you"],[1976,2131,"are arming the enemy."],[2214,2448,"Good luck making that stick!"],[2469,2602,"I'm a US senator"],[2602,2815,"and I am a very powerful man."],[2815,2998,"Not anymore."],[3015,3144,"As of thirty seconds ago,"],[3144,3428,"the President himself disavowed you"],[3428,3524,"as a traitor."],[3545,3716,"You have no allies left."],[3716,3816,"Take him away!"],[3870,3933,"Now!"],[4024,4079,"No!"],[4079,4141,"Don't you-"],[4175,4300,"Get your hands off me!"],[4300,4441,"I'm a US senator!"],[4441,4704,"I'm a very powerful, powerful man!"],[4704,4954,"Well, he might not be able"],[4954,5130,"to protect himself, but I can."],[5155,5355,"I know all the secrets"],[5355,5543,"involving national security."],[5593,5793,"I am too big for you to arrest."],[5793,6106,"Oh, you might be too big to arrest."],[6106,6398,"However, you are not too big"],[6398,6644,"to accidentally overdose."],[6702,6769,"What?"],[6769,6835,"No, no!"],[6835,6911,"You can't!"],[6940,7040,"You wouldn't!"],[7040,7219,"Sorry, Mr. Oxblood."],[7253,7565,"It's a matter of national security."],[7574,7716,"Open wide."],[7745,7816,"No!"],[7862,7995,"No!"],[8008,8170,"No!"]],"64":[[191,329,"Captain Cole Summers,"],[396,525,"present yourself!"],[6143,6443,"Here, even a janitor can become a hero."],[6552,6698,"God bless America."]]}