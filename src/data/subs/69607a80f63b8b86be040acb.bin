{"1":[[496,604,"Oh, my God!"],[604,688,"That’s good!"],[1614,1739,"Christmas Eve, Lila!"],[1739,1839,"Christmas Eve!"],[1839,1989,"I hope Santa brings you gifts."],[2052,2193,"Merry Christmas, Luna."],[2277,2381,"Auntie Karen's finally"],[2381,2473,"pregnant again."],[2535,2719,"I'll have a baby boy cousin."],[2744,2840,"It's all because you blessed them"],[2840,2986,"with your magical power."],[2986,3165,"You're their lucky star!"],[3378,3566,"I'm done shoveling snow."],[3649,3812,"Can I eat dinner too?"],[3832,3908,"Ew, Mommy."],[3945,4058,"She smells."],[5125,5217,"That's not for you!"],[5284,5363,"I'm sorry."],[5397,5522,"I thought you guys were full."],[5543,5684,"I didn't eat any yet."],[6277,6418,"It's all for me."],[6418,6589,"You just mooch off our family."],[6760,6969,"I want this brat gone!"],[7011,7077,"Tonight!"],[7094,7207,"Alright, alright."],[7273,7344,"You want dinner?"],[7390,7440,"Here."],[7494,7565,"That's your dinner."],[7645,7707,"Eat up."],[8049,8108,"Please."],[8187,8258,"Please,"],[8270,8379,"give me something better than thi-"],[8379,8466,"You should've thought about that"],[8466,8621,"before you ruined your aunt's carpet"],[8637,8737,"and upset your cousin."],[8762,8900,"Now eat, and go to bed."],[8963,9067,"Please."],[9150,9246,"Now, Lila."],[9684,9780,"Mr. Blackwood,"],[9851,9955,"we have exhausted"],[9955,10181,"every possible option"],[10181,10264,"known to man."],[10347,10735,"Your wife's death hit Noah very hard."],[10794,10998,"He has trauma-induced"],[10998,11123,"selective mutism,"],[11131,11315,"which means, I don't believe"],[11315,11478,"he will ever speak again."],[11578,11649,"I'm sorry."],[12137,12420,"Noah, what should I do?"],[12625,12704,"I just can't believe"],[12704,12862,"your sister dumped that kid on us."],[12887,13046,"She knew we were having troubles."],[13075,13213,"I only agreed to be the Godfather"],[13213,13371,"because my parents were still alive."],[13450,13542,"But,"],[13542,13634,"we're having a boy now."],[13646,13817,"He deserves our full attention."],[14039,14201,"There's a legal way to dump her."],[14272,14326,"Let's go."]],"2":[[191,283,"Nuns are gonna take"],[283,446,"real good care of you."],[804,967,"Karen, she's too big for the box."],[1046,1238,"Too fat for the orphan box?"],[1263,1413,"I guess we're doing it the hard way."],[1422,1559,"Stick her in the trash can."],[1626,1768,"Love how you think, babe."],[1793,1989,"All right, you little trash monster,"],[1989,2114,"in you go."],[2531,2610,"Please don't leave me."],[3011,3078,"Step on it!"],[3620,3687,"Uncle!"],[3732,3837,"Where are you going?"],[3858,3987,"Please, please, please!"],[4012,4083,"I'll be good,"],[4083,4187,"I promise."],[5805,6060,"No!"],[6060,6243,"Don't leave me!"],[6277,6389,"Come back!"],[6502,6581,"No!"],[7273,7328,"Ethan."],[7670,7757,"Ethan, stop!"]],"3":[[959,1159,"Please don't leave me."],[1272,1434,"This kid's parents dumped her."],[1459,1572,"I need to save her."],[1622,1672,"Hey,"],[1755,1822,"come with me."],[1918,2072,"I'll help you find your family, okay?"],[2285,2348,"Really?"],[2373,2448,"I promise."],[2540,2594,"Let's go."],[3274,3349,"My name’s Jonathan,"],[3370,3432,"and this,"],[3482,3582,"this is my son, Noah."],[3732,3845,"Hi, Noah."],[3883,3978,"I'm Lila."],[4325,4567,"Sir, why won't he talk to me?"],[4625,4675,"Um,"],[4763,5000,"Noah lost his voice."],[5030,5117,"He doesn't talk."],[5367,5601,"My wife died in a car crash."],[5601,5722,"My only son,"],[5722,5818,"will never speak again."],[5885,6001,"I'm the richest man in the world,"],[6001,6218,"but I can't even help my own family."],[6335,6731,"Maybe I can help bring his voice back."],[8166,8312,"Hi, Noah."],[8433,8491,"Hi,"],[8591,8675,"Lila."],[8754,8875,"Oh my God, Noah."],[9004,9084,"You can talk?"]],"4":[[25,129,"Dad,"],[129,233,"my voice works!"],[679,767,"Woah."],[804,963,"So much for Noah."],[1222,1338,"Is this for me?"],[1372,1488,"This is so much food."],[1488,1572,"Thank you, sir."],[1609,1664,"Lila."],[1764,1868,"Don't eat that."],[1897,2027,"That's for the dog, Coco."],[2097,2331,"So, Lila has no food?"],[2381,2448,"Yes."],[2623,2690,"You can eat at the table,"],[2719,2806,"with us."],[2998,3103,"You can have anything you want."],[3536,3636,"Woah."],[4037,4116,"Wow!"],[4179,4308,"Is this,"],[4308,4454,"really all for me?"],[4500,4537,"Yeah,"],[4558,4733,"and you can have whatever you like."],[4792,4900,"And if you don't like something"],[4900,5000,"and want something else,"],[5038,5113,"just tell the chef,"],[5113,5226,"and they'll make you something."],[5342,5405,"Lila,"],[5442,5505,"eat."],[5559,5626,"Okay."],[6172,6327,"So yummy."],[6377,6493,"This is everything"],[6493,6652,"I've ever dreamed of."],[6673,6727,"You've never"],[6727,6844,"had fried chicken before?"],[6877,6940,"No."],[6969,7019,"Fried chicken"],[7019,7157,"is only for the grown-ups,"],[7223,7319,"and Jessica."],[7678,7795,"Look up Lila's uncle."],[7849,7991,"I want to know everything there is"],[7991,8204,"to know about that child-abusing jerk."]],"5":[[12,108,"Mr. Blackwood,"],[133,187,"we've looked"],[187,300,"in every nook and cranny,"],[300,475,"still no sign of Anna's violin."],[629,825,"Anna, where did your violin go?"],[875,1005,"Noah needs it to recover."],[2035,2168,"Whatever it takes,"],[2206,2427,"I'm going to help them find that violin."],[3286,3370,"Hi, Coco."],[3399,3478,"I'm Lila."],[3507,3591,"Nice to meet you."],[3595,3766,"Nice to meet you too, Lila!"],[3787,3949,"Do you know where Noah's violin is?"],[3983,4054,"Yes!"],[4091,4141,"Shh."],[4229,4325,"Don't wake them up."],[4341,4575,"That evil maid Clara broke it and hid it!"],[4879,4975,"Miss Maggie,"],[4975,5075,"I need your help."],[5130,5330,"Coco told me where the violin is."],[5392,5497,"Coco the dog?"],[5543,5613,"Yes."],[5818,5868,"Come on."],[5910,5980,"Follow me."],[6118,6168,"Okay."],[6760,6886,"Lila! I found it."],[7002,7148,"It's in the box on the right."],[7945,8020,"Oh my God,"],[8020,8145,"the missing violin!"],[8191,8375,"Noah and Sir will be so happy."],[11799,11878,"Mr. Blackwood,"],[11891,11953,"look."],[12391,12487,"Where did you find that?"]],"6":[[87,187,"Where did you find that?"],[204,383,"Miss Lila found it in the pool house."],[533,596,"Lila,"],[667,792,"how did you know to look there?"],[859,1005,"Coco told me where it was."],[1051,1155,"The dog?"],[1155,1263,"No way."],[1263,1426,"It's probably a coincidence."],[1426,1430,"It's probably a coincidence."],[1576,1639,"Dad,"],[1664,1797,"I heard you found Mom's violin."],[1868,1985,"It's broken?"],[2081,2164,"Who broke it?"],[2369,2448,"Who did this?"],[2623,2815,"Clara did it!"],[2857,2982,"Coco said it was Clara."],[3032,3194,"Clara broke it and hid it."],[3253,3403,"You can't slander me like that."],[3507,3607,"This child is lying!"],[3607,3703,"I'm not lying!"],[3732,3899,"Coco says the bow is in your room."],[4087,4166,"Go check her room."],[4996,5080,"Mr. Blackwood,"],[5105,5292,"look what I found under Clara's bed."],[5380,5467,"Miss Anna's bow."],[5522,5597,"I'm sorry."],[5622,5689,"I was scared"],[5689,5834,"because I broke the stupid violin!"],[5834,5918,"Stupid?"],[5930,6093,"The violin could have saved my son."],[6202,6318,"And you just kept quiet."],[6360,6498,"You showed your true colors."],[6606,6669,"You're fired."],[6669,6765,"No!"],[6765,6861,"You can't fire me!"],[6894,6956,"I am broke!"],[6956,7077,"I've got big loans to pay."],[7077,7148,"You cannot"],[7148,7194,"fire me! - You’re lucky"],[7194,7323,"I'm not pressing charges!"],[7449,7524,"Get."],[7595,7657,"Out."],[7657,7857,"You rich people are all the same!"],[7870,8120,"I work here day and night like a dog,"],[8153,8254,"and you fire me"],[8266,8512,"over some stupid dead lady's violin?"],[8541,8687,"Oh, fine."],[8762,8829,"Fire me?"],[9054,9146,"Die!"],[9325,9392,"No!"]],"7":[[779,859,"Ethan, get her!"],[1005,1155,"Lila, Lila, are you okay?"],[1372,1514,"I am done playing nice."],[1543,1601,"Ethan,"],[1609,1772,"get this evil wench out of my house"],[1772,1864,"and thrown in jail!"],[1914,2022,"Get the Chief of Medicine."],[2464,2627,"Absolutely no need to worry."],[2690,2823,"She'll make a full recovery."],[2911,2957,"Thank you."],[3357,3403,"Dad,"],[3436,3516,"Lila's awake."],[3716,3820,"Mr. Sir?"],[3887,3962,"Hey."],[4054,4120,"Noah?"],[4304,4379,"How do you feel?"],[4429,4521,"Does anything hurt?"],[4579,4796,"I'm fine, sir."],[4842,4959,"You saved my life"],[5017,5163,"and you found Noah's violin."],[5196,5238,"I don't know"],[5238,5363,"how I could ever repay you."],[5547,5638,"Is there anything you want?"],[5880,5935,"What is it?"],[6006,6160,"Can I work here as a maid?"],[6289,6531,"My uncle and aunt don't want me."],[6573,6702,"Both of my parents are dead,"],[6752,6894,"and I have nowhere else to go."],[6977,7157,"I promise I won't eat a lot."],[7236,7449,"I know how to shine shoes,"],[7520,7653,"wash dishes,"],[7707,7853,"and shovel snow."],[7991,8058,"Please?"],[8204,8283,"Dad,"],[8320,8441,"can Lila stay?"],[8483,8575,"Please?"],[8754,8825,"How about"],[8850,8950,"you can stay here..."],[9063,9142,"as my daughter?"],[9200,9280,"If you want,"],[9384,9476,"you can call me Dad."],[9826,9880,"Daddy!"],[10789,10881,"Get the adoption papers"],[10881,10969,"to the city ASAP."],[11052,11211,"Harold Sinclair and this Karen Sinclair"],[11211,11344,"are despicable human beings."],[11394,11511,"How could they do that to Lila?"],[11569,11669,"You know, I did some digging,"],[11678,11811,"found out they both worked"],[11811,11907,"at Southside Steel."],[11970,12037,"That mill you bid"],[12037,12187,"against the Fairchild Group to acquire."],[12266,12354,"Well, that deal blew up"],[12354,12441,"after an insider"],[12441,12554,"leaked trade secrets."],[12604,12816,"I found out that insider was"],[12850,12912,"Harold."],[13008,13108,"That bastard."],[13150,13221,"Also, sir,"],[13254,13334,"the Chamber President"],[13350,13513,"invited you to this year's auction."],[13567,13747,"Our cash flow has crumbled"],[13763,13876,"ever since the Southside Steel"],[13876,13997,"acquisition blew up."],[14022,14139,"We have to win it big"],[14139,14276,"on this year's blind box."],[14301,14406,"If our company loses that,"],[14422,14510,"it could mean the end."],[14681,14798,"Lila's had a rough life."],[14960,15077,"I'm not leaving her at home."],[15202,15331,"Get her the best clothes possible."],[15386,15452,"Right away, sir."]],"8":[[325,392,"Sir."],[437,500,"Miss Lila."],[1747,1801,"Sir-"],[1893,1956,"Daddy."],[2085,2218,"Why didn't Noah come?"],[2273,2414,"Noah hasn't fully recovered yet."],[2494,2569,"It's kind of hard for him"],[2569,2656,"for large crowds."],[2723,2873,"Can I bring Noah a present?"],[2923,2986,"Of course."],[3032,3103,"He would love that."],[3190,3249,"Come on."],[3282,3345,"Let's go."],[3407,3490,"So pretty."],[3582,3645,"Great job."],[3862,3999,"I heard Mr. Blackwood"],[4004,4179,"picked up a stray kid."],[4254,4316,"That her?"],[4358,4533,"I know all about foster kids."],[4558,4725,"Not an honest bone in their body."],[4758,4871,"She probably just scammed her way"],[4871,4979,"into the Blackwood family."],[5359,5476,"Woah."],[5547,5784,"This place is so"],[5818,5926,"big and,"],[6039,6114,"pretty."],[6281,6352,"Mr. Blackwood,"],[6356,6431,"the Chamber President"],[6431,6502,"would like a word."],[6731,6785,"Lila,"],[6827,6873,"I have to go"],[6873,7002,"take care of a few things, but,"],[7002,7132,"just hang out, have some food."],[7219,7286,"But,"],[7323,7428,"don't wander off, okay?"],[7449,7511,"Okay."],[7528,7590,"Okay."],[8120,8341,"Ms. Fairchild, we owe you."],[8379,8470,"If you hadn't bought"],[8470,8687,"those Steel Mill's secrets I stole,"],[8708,8754,"we would have never"],[8754,8925,"gotten a foot in with the elite."],[8950,9034,"Exactly."],[9054,9129,"We're in your debt."],[9138,9271,"Anything you need."],[9288,9367,"By the way,"],[9380,9534,"I heard Mr. Blackwood is here"],[9534,9667,"at your invitation."],[9722,9880,"Sounds like congratulations"],[9880,9964,"are in order."],[10160,10281,"Go see if he's arrived."],[10573,10635,"Jonathan is here"],[10635,10777,"because of the Chamber President."],[10823,10994,"His heart's still with that dead hag,"],[10994,11061,"Anna."],[11065,11161,"But not today."],[11202,11428,"Today's the day he falls for me."]],"9":[[262,312,"Uncle!"],[321,387,"Auntie!"],[433,533,"Are you here for me?"],[633,700,"Lila?"],[734,925,"Get your filthy hands off me!"],[2423,2698,"I'm sorry, Aunt Karen."],[2744,2952,"I, I was happy to see you."],[3003,3107,"Isn't that the stray"],[3107,3261,"that Mr. Blackwood brought?"],[3286,3445,"What is she doing now?"],[3445,3524,"Told you."],[3528,3645,"Street rats."],[3661,3770,"They pick a target"],[3770,3908,"and call them family."],[3924,4095,"Bad luck if she latches on."],[4124,4183,"Hear that?"],[4208,4329,"You're a street rat."],[4379,4458,"Now scram!"],[4491,4596,"I'm not a rat."],[4662,4804,"I have a daddy, now"],[4829,4917,"and a brother."],[4967,5121,"You have a family?"],[5180,5405,"No one wants to be your family, Lila."],[5434,5638,"You bring bad luck wherever you go."],[5663,5851,"That's why your parents died."],[6206,6364,"Aunt Karen,"],[6418,6610,"that's so mean."],[6623,6744,"I'm not your aunt!"],[6744,6848,"Don't call me aunt."],[6906,6977,"Get rid of her."],[6977,7123,"People will think she's with us."],[7127,7203,"Alright."],[7215,7357,"Lila, come on, come on."],[7390,7436,"Go! - No!"],[7436,7494,"Uncle Harold,"],[7494,7599,"please don't take me away!"],[7691,7786,"Daddy said I have to stay here"],[7786,7866,"and wait for him."],[8149,8237,"You don't have a daddy."],[8258,8425,"Stop making things difficult, Lila!"],[8566,8683,"You don't belong here."],[9092,9150,"How dare you"],[9150,9300,"lay your hands on my daughter?"],[10397,10518,"Your daughter? - Your daughter?"]],"10":[[45,154,"Everyone listen."],[196,283,"Lila was abandoned"],[283,450,"by this heartless couple."],[471,563,"Yes, they're related."],[617,800,"But they treated Lila like a servant."],[838,963,"We had our reasons."],[971,1113,"She's a horrible kid."],[1180,1251,"What the hell?"],[1263,1459,"How did this little jinx land a tycoon"],[1459,1622,"like Jonathan Blackwood?"],[1626,1826,"She doesn't deserve his money."],[1851,1939,"Mr. Blackwood,"],[1939,2118,"you're going to regret your decision."],[2156,2335,"This little brat brings bad luck"],[2335,2444,"wherever she goes."],[2494,2590,"You just wait."],[2898,3015,"You silly goose."],[3111,3199,"You're my lucky star."],[3228,3307,"Don't listen to her."],[3411,3482,"The adoption papers"],[3482,3570,"have gone into the city."],[3611,3691,"From now on,"],[3707,3824,"Lila is my daughter."],[3945,4074,"And unlike her aunt and uncle,"],[4120,4220,"who abused her,"],[4250,4387,"Lila will be treated like a princess"],[4387,4471,"in the Blackwood family."],[4587,4671,"No way."],[4696,4913,"The Sinclairs are really her family."],[4929,5100,"So, Harold and Karen"],[5100,5288,"have been lying to us this whole time?"],[5442,5538,"Mr. Blackwood,"],[5547,5705,"we did not abuse her."],[5705,5893,"She's obviously spinning lies."],[5910,5976,"Exactly."],[6006,6122,"Don't let her con you."],[6193,6272,"Don't insult me."],[6318,6431,"I saw with my own eyes"],[6431,6544,"the night you abandoned her"],[6544,6606,"in the snow."],[6731,6848,"What did he say?"],[6902,7044,"As, as my wife said,"],[7044,7203,"we, we had our reasons."],[7253,7432,"Lila truly is bad luck."],[7461,7553,"If you don't believe us,"],[7553,7728,"you should let her pick the blind lots"],[7728,7816,"for you at the auction."],[7824,8016,"See for yourself how unlucky she is."],[8016,8187,"The best chest wins,"],[8187,8312,"loser pays all."],[8312,8483,"Sir, Harold has teamed up"],[8483,8596,"with Vivienne Fairchild,"],[8596,8775,"this smells like a plan to bankrupt us."],[9184,9234,"Deal."],[9551,9722,"My daughter chooses the lots."],[9947,10164,"I won't let you go bankrupt, Daddy."]],"11":[[29,154,"Ladies and gentlemen,"],[154,346,"welcome to the blind box"],[346,467,"charity auction."],[487,667,"I'll be your treasure appraiser"],[667,838,"and auctioneer today!"],[838,996,"OMG! The Sinclairs are here."],[996,1159,"l heard they have an exceptional eye"],[1159,1317,"for spotting real treasure."],[1317,1409,"Lot One."],[1430,1597,"Two ancient chests"],[1597,1876,"from the SS Central America,"],[1901,2018,"the Ship of Gold."],[2043,2139,"Per our rules,"],[2143,2381,"what's inside and what it's worth"],[2435,2519,"is a secret."],[2911,3132,"It's glowing."],[3207,3253,"Daddy,"],[3311,3403,"buy that one."],[3449,3566,"Why would Lila want the"],[3566,3707,"ugly wooden chest?"],[3753,3987,"The SS Central America?"],[4020,4079,"That's the one"],[4079,4258,"that was hauling a ton of gold"],[4258,4371,"during the Gold Rush."],[4379,4487,"Look at that chest."],[4491,4650,"It's worth a fortune, even empty."],[4683,4842,"If I get this golden box,"],[4879,4992,"I can save my company."],[5030,5121,"We are gonna open"],[5121,5234,"with the gold chest."],[5301,5401,"Starting bid,"],[5426,5530,"five million."],[5563,5634,"Alright kiddo,"],[5634,5709,"what do you think?"],[5772,5872,"It's not glowing."],[5935,6218,"Glowing? What is she talking about?"],[6289,6360,"Six million."],[6377,6456,"Six million."],[6485,6535,"Seven."],[6556,6639,"Seven million."],[6677,6785,"Fifteen million."],[6810,6915,"Fifteen million."],[6944,7086,"That's close to my budget."],[7111,7257,"But if I don't bid now,"],[7257,7353,"I might lose the chance"],[7353,7453,"to save my company."],[7469,7574,"Too much for you, Jonathan?"],[7599,7645,"Now that you have to feed"],[7645,7782,"a dirty little street rat?"],[7903,8070,"Nobody talks about Lila like that."],[8170,8299,"Twenty million dollars."],[8345,8454,"Twenty million."],[8466,8650,"Woah! l want the gold box too,"],[8650,8892,"but I wouldn't bet twenty million!"],[8958,9134,"Twenty million for a chest, sir?"],[9171,9330,"Please don't do anything rash."],[9330,9421,"No. - We have wages,"],[9421,9488,"loans,"],[9517,9655,"payments to process."],[9676,9788,"In case you all didn't know,"],[9805,9951,"the supposed richest man"],[9951,10005,"in the room"],[10010,10110,"has no cash flow."],[10155,10235,"He's broke."],[10268,10410,"And here he is parading around"],[10410,10564,"like he's capable of winning anything"],[10564,10639,"at this auction."],[10660,10894,"His empire is on the brink of collapse."],[10906,10985,"Making a deal"],[10985,11123,"with Jonathan Blackwood"],[11123,11240,"is certain death."],[11428,11486,"Daddy,"],[11519,11615,"don't buy that one."],[11674,11790,"Get the wooden one."],[11882,11945,"What?"],[12016,12066,"Why?"],[12116,12203,"I can see it."],[12208,12283,"Trust me."],[12374,12675,"The golden chest is a waste of money."],[12696,12841,"But, the wooden one,"],[12908,13021,"it's shining."],[13104,13284,"It's full of treasure."],[13375,13517,"Does she really have the power"],[13517,13621,"to see through the box?"]],"12":[[83,258,"The wooden chest is shining?"],[271,346,"All I see"],[346,542,"is a beat-up piece of junk."],[554,625,"It was the same"],[625,734,"when Lila lived with us,"],[734,867,"always spewing gibberish"],[867,1042,"at that damn bird all day."],[1105,1305,"Could Lila really see the chest glowing?"],[1338,1522,"No, that, that would be impossible."],[1597,1780,"But she did save my son."],[1947,2056,"Please,"],[2081,2173,"trust me?"],[2264,2323,"Sir,"],[2360,2535,"I know you want to make Lila happy."],[2573,2673,"We need a good payout"],[2673,2882,"to keep this company afloat."],[2940,3053,"I'd listen to your assistant"],[3053,3161,"if I were you, Jonathan."],[3215,3307,"It's a pity, really."],[3328,3395,"The gold chest"],[3395,3474,"could have saved you."],[3511,3574,"Seems like"],[3574,3807,"Jonathan Blackwood is a liar"],[3807,3945,"who can't pay the bills."],[3970,4104,"Now he's bidding the company's"],[4104,4250,"fortune on this little brat?"],[4250,4404,"He must be out of his mind."],[4496,4646,"What would l need the money for,"],[4675,4929,"if l can't even make my daughter happy?"],[5163,5259,"I trust my daughter."],[5543,5634,"Yes!"],[6147,6210,"Daddy,"],[6231,6322,"I won't let you down."],[6356,6514,"I have a great idea."],[6886,7036,"So, we’re going..."],[7265,7365,"Uncle Harold,"],[7374,7549,"if twenty million makes you sweat,"],[7578,7703,"we'll take the gold chest,"],[7720,7920,"and you can come see it at our place."],[8003,8083,"What?"],[8112,8245,"Who says I can't afford it?"],[8254,8320,"I was merely"],[8320,8516,"sparing your dad his pride."],[8541,8625,"But if you want to push it?"],[8650,8712,"Fine."],[8729,8871,"The kid gloves are off."],[8908,9038,"You're not taking anything"],[9059,9146,"from my daddy."],[9200,9371,"I bid twenty-five million."],[9659,9801,"Twenty-five mil..."],[9809,9905,"Lila, sir,"],[9934,10051,"we need to save some cash flow"],[10051,10218,"for the deal with Maple Enterprises."],[10314,10422,"I know you want to do good"],[10422,10548,"by Lila, but-"],[10548,10698,"Jonathan, if you fail again,"],[10706,10848,"your company will be ruined."],[10856,11086,"Don't be some arrogant, stupid dad."],[11115,11269,"That little brat isn't worth it."],[11319,11498,"Otherwise, you'll not only be broke,"],[11498,11686,"but you'll also be saddled with debt."],[11720,11849,"You'll never be able to pay it back"],[11849,11928,"in your lifetime."],[11957,12024,"No way!"],[12037,12095,"You know nothing"],[12095,12245,"about my daddy's power."],[12274,12487,"He has hundreds of millions."],[12504,12587,"Good lord."],[12587,12779,"With the money they poured into this box,"],[12779,12900,"whatever's inside had better"],[12900,13092,"be rare enough to justify the gamble."],[13175,13300,"I mean, he let that little girl"],[13300,13434,"tack on five mil"],[13434,13521,"like it was nothing."],[13571,13676,"Those new-money Sinclairs"],[13676,13805,"add on a couple thousand,"],[13805,13918,"and think they're ballin'."],[13976,14043,"Mr. Blackwood's"],[14043,14197,"in a whole other stratosphere."],[14230,14422,"I'm backed by Fairchild money."],[14435,14543,"What do I have to lose?"],[14560,14639,"Thirty million."],[14668,14735,"Forty!"],[14843,14989,"What's wrong, Uncle Harold?"],[15010,15081,"Running dry?"],[15106,15256,"Want my daddy to lend you some?"],[15369,15432,"Great,"],[15448,15494,"at this rate"],[15494,15578,"I'm going to have to sell"],[15578,15728,"the whole damn office building."],[15761,15861,"Damn you, Lila."],[16036,16145,"She's so confident,"],[16216,16332,"her plan might just work."]],"13":[[87,145,"Fine."],[179,354,"Even if I don't win the gold chest,"],[379,500,"I'll make you bleed for it."],[533,642,"Deep pockets, huh?"],[684,746,"Good."],[788,892,"I'll burn all your money."],[900,1001,"Sixty million!"],[1034,1126,"Sixty million!"],[1430,1497,"Alrighty."],[1593,1651,"We're out."],[1680,1743,"Wait, what?"],[1918,2056,"Sixty million once."],[2181,2331,"Sixty million twice."],[2473,2627,"Sixty million sold!"],[2648,2869,"The gold chest goes to Mr. Sinclair!"],[2952,3090,"Oh, thank God."],[3111,3186,"Thank God."],[3249,3336,"You snake!"],[3365,3507,"You're backing out just like that?"],[3536,3691,"Are you trying to make fools of us?"],[3699,3770,"Auntie,"],[3849,3949,"you really wanted it,"],[3949,4083,"so we let you have it."],[4120,4229,"Or if you want,"],[4254,4416,"you take the wooden chest."],[4416,4517,"We'll take the gold."],[4592,4821,"That wooden chest is cheap trash."],[4846,5038,"No way I'm falling for her bluff."],[5059,5150,"Not a chance."],[5196,5326,"The gold chest is ours."],[5351,5563,"You can take that silly wooden crate."],[5613,5772,"The wooden chest buyout price is"],[5772,5872,"twenty million, sir."],[6189,6343,"Trust me, Daddy."],[6519,6577,"Sir,"],[6639,6710,"no."],[6765,6856,"Don't worry, Daddy."],[6902,7094,"I saw the wooden chest glowing."],[7094,7211,"You won't lose money."],[7232,7374,"I promise!"],[7403,7561,"Forget about the money, Jonathan."],[7586,7720,"As long as Lila's happy,"],[7757,7891,"today's a win for me."],[7891,7949,"Deal."],[8016,8116,"Then I'll gamble on the wood."],[8170,8312,"Mr. Prescott, shall we open them?"],[8433,8491,"Ha!"],[8508,8662,"Don't say we didn't warn you."],[8671,8792,"You and that cursed brat"],[8792,8900,"are going down!"]],"14":[[1564,1664,"It's full of gold."],[1672,1735,"Wow."],[1760,1881,"Oh my God."],[1881,2006,"Look at that haul."],[2064,2248,"Gold, coins, jewels."],[2264,2452,"No wonder it looked like it was glowing."],[2498,2623,"The kid wasn't lying."],[2635,2781,"How did she even see that?"],[2781,2911,"She hit the jackpot."],[2940,3032,"She was right."],[3032,3144,"But how did she know?"],[3144,3361,"Look at that gold chest."],[3395,3528,"All shiny on the outside."],[3549,3716,"It's trash on the inside."],[3741,3824,"You smell that?"],[3824,4012,"It's, it’s moldy like a cellar."],[4012,4087,"Oof!"],[4087,4145,"Yeah, it looks like"],[4145,4337,"the crew's personal items."],[4346,4575,"But why put it in a gold chest?"],[4925,5046,"Maybe Lila really had"],[5046,5217,"super powers all along!"],[5292,5409,"Mr. and Mrs. Sinclair,"],[5455,5568,"I'll do the math for you."],[5593,5680,"You just lost"],[5680,5889,"eighty million dollars."],[6097,6218,"How did this happen?"],[6239,6335,"How is this possible?"],[6348,6477,"Eighty mil on this?"],[6619,6810,"Daddy, I told you."],[6869,6948,"You,"],[7007,7148,"are my lucky charm, Lila."]],"15":[[50,112,"This,"],[158,358,"this is a Bohemian crystal."],[454,558,"Bohemian what?"],[608,759,"That, that's cheap glass."],[759,834,"They’re not glass."],[880,1109,"A rare Bohemian crystal."],[1117,1209,"In candlelight,"],[1209,1309,"or sunshine,"],[1326,1601,"the cuts set off a seven-color flare."],[1618,1851,"Only top families have this."],[1856,1956,"So we're talking"],[1956,2160,"a once-in-a-lifetime treasure there."],[2210,2277,"This,"],[2318,2556,"is a Mississippi Moonstone."],[2573,2790,"A sapphire eagle carving."],[2827,2890,"And this,"],[2998,3294,"is a European royal crown."],[3328,3453,"Oh my lord."],[3511,3595,"Jesus."],[3636,3724,"There's gotta be"],[3737,3937,"ten million dollars worth of gold,"],[3937,4045,"just on that crown!"],[4070,4229,"You bundle all this together,"],[4283,4583,"it's worth north of nine figures."],[4625,4879,"Mr. Blackwood, he hit the mother lode."],[4929,5105,"Meanwhile, eighty million"],[5117,5413,"for a box of trash and mildew?"],[5455,5547,"Game over."],[5576,5764,"No, no, absolutely not."],[5764,5868,"He hasn't won anything."],[5893,6068,"Please, Mr. Prescott, please."],[6085,6252,"There must be something of value."],[6252,6297,"Here, please."],[6297,6410,"Right, there has to be."],[6431,6631,"These are heirlooms, antiques."],[6810,6894,"With respect,"],[6961,7111,"this is crew junk."],[7140,7298,"Bowls, cups,"],[7311,7457,"rusted utensils,"],[7465,7590,"warped and soiled."],[7632,7724,"Auction value?"],[7749,7824,"Zero."]],"16":[[50,216,"We dropped eighty million dollars"],[216,308,"on trash!"],[404,663,"Mr. Blackwood, I am very interested"],[663,834,"in the contents of that crate."],[875,980,"Would you consider"],[1013,1251,"selling me the whole lot,"],[1251,1347,"the crate and all?"],[1468,1564,"I'm prepared to offer you"],[1564,1664,"three hundred million."],[2022,2102,"Oh my God."],[2152,2231,"Three hundred?"],[2398,2585,"That's a massive number."],[2748,2827,"Lila,"],[2848,3036,"you just saved the company."],[3361,3453,"I, I'm sorry."],[3507,3570,"This whole lot"],[3570,3670,"belongs to my daughter."],[3695,3762,"She chose it."],[3912,3970,"So,"],[4175,4291,"what do you say, kiddo?"],[4491,4667,"Dad, can we keep"],[4683,4825,"the moonstone for Noah?"],[4888,4992,"Sell the rest."],[5121,5326,"I can't count to three hundred million."],[5359,5663,"But it's a big number."],[5855,6010,"You and Noah can eat"],[6035,6264,"plenty of fried chicken."],[6360,6414,"Chicken."],[6464,6519,"You heard her."],[6552,6614,"Make me an offer"],[6614,6706,"for the rest of the crate."],[6735,6823,"And I'll have my assistant"],[6823,6873,"coordinate."],[6906,7061,"Thank you, Mr. Blackwood."],[7123,7269,"And thank you, little lady"],[7290,7424,"for parting with that chest."],[7444,7507,"You!"],[7603,7678,"Damn you!"],[7749,7924,"You told me that this was solid gold."],[7924,8024,"You lured me in"],[8024,8124,"so you could cherry-pick"],[8124,8341,"this little jinx's wooden crate."],[8366,8437,"You set me up."],[8437,8537,"You set me up!"]],"17":[[12,137,"That's ridiculous."],[150,312,"I wasn't the only one that said it."],[333,471,"Half the room did."],[513,650,"Use your head."],[650,696,"You believe"],[696,813,"everything you hear?"],[850,1080,"And don't blame us for the outcome."],[1092,1134,"Yeah,"],[1155,1255,"you ran up the price"],[1255,1330,"so no one could bid."],[1330,1488,"And now it's all our fault?"],[1488,1568,"What's the matter?"],[1568,1705,"Cash poor today?"],[1739,1947,"Nouveau riche playing tycoon?"],[2364,2456,"I get it now."],[2519,2686,"You're all in on this!"],[2786,2927,"You all set me up."],[3065,3199,"Nice move, Blackwood,"],[3232,3319,"using a little girl"],[3328,3432,"as your smoke screen."],[3566,3628,"Lila,"],[3703,3753,"what did you know"],[3753,3903,"about these chests beforehand?"],[4074,4145,"Answer me!"],[4175,4325,"I didn't know anything."],[4617,4688,"Tell me the truth or I’m gonna-"],[4688,4725,"Ow! - Hey!"],[4725,4863,"beat it out of you! - Let her go!"],[5167,5238,"You okay?"],[5271,5330,"You're safe."],[5417,5588,"If you ever touch her again,"],[5588,5680,"I'll bury you!"],[5701,5764,"We clear?"]],"18":[[4,162,"I'll put you down again, we clear?"],[221,266,"Clear."],[621,675,"Fine."],[742,829,"Remember this."],[829,1051,"That little jinx is going to sink you!"],[1222,1272,"Yeah."],[1297,1459,"Just wait till you marry Ms. Fairchild,"],[1505,1547,"then we'll see"],[1547,1655,"how long you stay Lila's"],[1655,1768,"bodyguard then."],[2381,2569,"Worth every dollar"],[2569,2731,"I poured into this body."],[2802,3019,"Jonathan's gonna lose his mind."],[3107,3186,"Ms. Fairchild!"],[3207,3303,"Oh, sorry."],[3370,3474,"Ever heard of knocking?"],[3549,3624,"Where's Jonathan?"],[3624,3749,"You were supposed to bring him here."],[3791,3862,"Bad news."],[3891,4020,"Mr. Blackwood actually left early,"],[4070,4216,"over that little stray girl."],[4270,4329,"What?"],[4358,4558,"He really adopted some random girl?"],[4583,4646,"Yes."],[4658,4733,"God knows"],[4733,4888,"what spell she's got him under."],[4913,5055,"He didn't just take her in."],[5121,5234,"He spoils her."],[5313,5388,"Outrageous!"],[5447,5597,"A mute son was one thing."],[5638,5764,"But now a stray brat?"],[5864,5910,"Fine."],[5930,6076,"Playtime's over, Jonathan."],[6114,6256,"Time to turn up the heat."]],"19":[[271,333,"Little lady's like"],[333,479,"a walking good luck charm, huh?"],[525,625,"Three hundred million dollar haul"],[625,709,"like it was nothing."],[779,967,"No, the chest was my purchase."],[975,1092,"Lila had nothing to do with it."],[1138,1226,"And no more"],[1226,1376,"good luck charm talk ever."],[1418,1568,"Rumors like that can get people hurt."],[1672,1730,"Clear?"],[1826,1885,"Clear."],[1964,2022,"Come on."],[2640,2706,"Noah!"],[2731,2802,"Maggie!"],[2806,2982,"I brought you presents."],[3007,3115,"Look. - Whoa!"],[3178,3244,"Cool."],[3278,3395,"Thanks, Lila."],[3486,3603,"Noah's been smiling"],[3603,3799,"since Lila came into our lives."],[3832,3924,"If this keeps up,"],[3966,4145,"he'll be fully recovered soon."],[4216,4287,"You know what, Maggie."],[4329,4462,"Go get the blue velvet box."],[4462,4550,"The one in the drawer."],[5367,5518,"Sir, isn't that the diamond necklace"],[5518,5613,"from the Christie's auction"],[5613,5730,"you were gonna give your wife?"],[5751,5818,"That's worth"],[5818,5935,"hundreds of millions."],[6039,6114,"That's the one."],[6297,6535,"And now, I'm gonna give it to, Lila."],[6710,6861,"Whoa, Daddy."],[6881,6973,"Are you really"],[6973,7094,"gonna give me something"],[7123,7290,"that pretty?"],[7332,7419,"Of course."],[7503,7632,"You got a gift for Maggie,"],[7632,7753,"and you got a gift for Noah."],[7836,7903,"It's only right"],[7903,8020,"someone gets a gift for you."],[8099,8183,"Thank you."],[8287,8345,"Come here."],[8429,8529,"There we go."],[8946,9004,"Daddy,"],[9092,9275,"why is that one different?"]],"20":[[58,154,"That one's special."],[187,279,"I made it myself"],[329,442,"from my shirt buttons."],[546,742,"I like that bead most of all."],[792,859,"And guess what?"],[871,1030,"If any of the diamonds fall off,"],[1217,1317,"you activate it."],[1605,1647,"Woah! - The whole"],[1647,1747,"necklace lights up."],[1847,2002,"It's glowing."],[2110,2173,"That way,"],[2235,2352,"you'll never lose it."],[2510,2590,"Thank you, Daddy."],[2702,2811,"What about me?"],[2836,3019,"Oh, what about me?"],[3178,3303,"Look at you guys."],[4158,4341,"Sir, I'm sorry to break this up,"],[4341,4425,"I just received some"],[4425,4542,"really bad news."],[4938,5021,"Five banks are"],[5059,5188,"freezing our company's assets"],[5188,5347,"and demanding we pay off our loans."],[5355,5426,"I mean our,"],[5442,5572,"stocks are plummeting."],[5601,5759,"We've lost billions already."]],"21":[[54,166,"It's Vivienne Fairchild."],[233,421,"She's trying to force me to marry her."],[546,613,"What with the crucial"],[613,696,"land sales tomorrow."],[696,809,"We need cash flow."],[829,913,"What are we gonna do?"],[921,1042,"Okay, so she made her move."],[1180,1305,"Now it's time we make ours."],[1388,1484,"Let me help you."],[1705,1793,"That's the spirit."],[2047,2210,"Welcome to the Horizon Group's"],[2210,2369,"annual land sale."],[2410,2494,"This year, we've got"],[2494,2602,"twenty-one plots of land"],[2602,2702,"for you to purchase."],[2769,2886,"The details can all be found"],[2886,2944,"on this model,"],[2944,3007,"so take a look"],[3007,3128,"and see what catches your eye."],[3178,3236,"Man, this one's going for"],[3236,3365,"for eight billion?"],[3403,3507,"Why are you surprised?"],[3524,3687,"This is one of the most expensive"],[3687,3787,"neighborhoods in the city."],[3803,3970,"Celebrities, doctors, lawyers,"],[3970,4104,"all the elites have homes there."],[4154,4200,"I honestly thought"],[4200,4287,"it would sell for more."],[4346,4500,"That is a good location,"],[4542,4679,"but after the bank freeze,"],[4708,4896,"eight billion's too steep."],[4950,5009,"I'd be fine"],[5009,5138,"with something less central,"],[5159,5276,"but the ones within my budget"],[5276,5480,"are all the way out in the sticks."],[6085,6243,"Wait, are those the Sinclairs?"],[6272,6393,"Didn't know they were coming today."],[6431,6581,"I heard the husband has teamed up"],[6581,6740,"with the billionaire Fairchild Group."],[6773,6894,"Everything Harold touches"],[6894,7002,"turns to gold."],[7032,7127,"He doesn't miss."],[7615,7682,"Woah!"],[7870,8049,"That one has coins on it."],[8450,8666,"Daddy, that one's really cool."],[8767,8850,"Can we buy it?"],[8900,8971,"That was fast."],[9050,9146,"You already have a favorite?"],[9167,9246,"She was all over"],[9246,9363,"that wooden chest too."],[9392,9567,"Well, whatever makes Lila happy,"],[9592,9693,"makes me happy."],[9751,9889,"We'll take plot number fifteen."],[9934,9976,"Wait-"],[9976,10130,"Jonathan Blackwood,"],[10172,10285,"here you go again,"],[10285,10372,"dropping millions"],[10372,10552,"just because your daughter said so."],[10568,10648,"Sold. - Wait!"],[10648,10931,"Plot fifteen sold for thirty million!"]],"22":[[12,150,"You know your company stock"],[150,296,"has cratered, right?"],[383,504,"Probably not the best time"],[504,596,"to be snatching up"],[596,746,"a piece of useless land."],[842,909,"There's no such thing"],[909,1038,"as useless land."],[1080,1184,"Only people who don't know"],[1184,1305,"how to develop properly."],[1343,1422,"It's far from the city."],[1480,1539,"So what?"],[1593,1710,"Maybe I'll just build"],[1747,1939,"Lila's perfect little paradise."],[1993,2198,"Plot fifteen goes to Mr. Blackwood."],[2206,2327,"What a beautiful idea,"],[2331,2473,"buying land to build something"],[2473,2544,"for his daughter."],[2677,2819,"Now sir, you're throwing away"],[2819,2965,"thirty million dollars."],[2973,3115,"We need to be frugal today."],[3169,3332,"Wooden chests are one thing but,"],[3365,3507,"this is a land sale"],[3507,3657,"where people drop big bucks."],[3674,3841,"So if you were just some poor schlub"],[3841,3974,"wasting thirty mil,"],[3974,4083,"I'd let it slide."],[4120,4225,"Unfortunately,"],[4225,4391,"you made fools out of us at the auction."],[4425,4475,"Just wait"],[4475,4646,"till your capital chain ruptures."],[4662,4771,"You'll go from billionaire"],[4775,4871,"to bankrupt."],[4875,4992,"What can I say?"],[5138,5280,"The CEO of the Fairchild"],[5280,5422,"conglomorate has arrived!"],[5951,6101,"My man's a big spender."],[6131,6214,"But don't worry."],[6289,6452,"He's playing by my rules now."]],"23":[[37,233,"Ms. Fairchild, you made it."],[346,471,"Welcome, Ms. Fairchild."],[479,621,"I hear you're a mainstay"],[621,721,"at land sales."],[738,809,"Please,"],[809,930,"lend us your expertise."],[1001,1113,"Here's my golden rule."],[1176,1297,"When it comes to buying land,"],[1297,1455,"you only need to look at three things."],[1501,1743,"Location, location, location."],[1864,1993,"Then it's obvious,"],[1997,2118,"the eight billion plot"],[2118,2360,"is the crown jewel of this whole sale."],[2385,2469,"And now that we know"],[2469,2594,"that Jonathan Blackwood"],[2594,2711,"is about to be broke,"],[2719,2861,"Ms. Fairchild might be"],[2861,3132,"the richest one to snap it up."],[3174,3244,"Jonathan,"],[3319,3395,"you know that"],[3395,3603,"Vivienne is in the major leagues."],[3624,3703,"Too bad you're stuck"],[3703,3799,"playing wiffle ball."],[3841,3978,"Might be best for you to get out"],[3983,4112,"before things get ugly for you."],[4200,4316,"Leave my daddy alone."],[4483,4604,"He's not ugly!"],[4783,4921,"Sticking up for me like a big girl?"],[4979,5150,"I feel safer already."],[5167,5242,"Safer?"],[5338,5476,"What, you think this little brat"],[5476,5584,"can stop your stocks"],[5584,5655,"from plummeting?"],[5693,5764,"You think she can bring"],[5764,5926,"your company back from the brink?"],[5968,6060,"Dream on."],[6118,6252,"I don't know what that brat did"],[6252,6498,"to turn you into a full-time babysitter,"],[6498,6652,"but, it'll be the death of you."],[6652,6752,"Don't blame us"],[6752,6877,"when you go bankrupt."],[6877,6940,"Yeah,"],[6940,7023,"when you're broke,"],[7023,7190,"I can hire you to come work for me."],[7207,7361,"Would you prefer to shine my shoes"],[7361,7461,"or clean the toilets?"],[7657,7720,"How could Jonathan"],[7720,7824,"become so desperate?"],[7849,7928,"I heard he was rich"],[7928,8041,"and doted on his daughter,"],[8041,8299,"but never thought he'd buy bad land."],[8329,8479,"The rich are narcissists."],[8512,8587,"They have no money"],[8587,8712,"but still wanna keep their pride"],[8712,8892,"and live such a luxurious life."],[8983,9184,"My daddy won't go bankrupt."],[9217,9371,"You'll go bankrupt."],[9405,9492,"Shut up."],[9567,9651,"Excuse me."],[9855,9922,"What?"],[9964,10026,"What?"],[10093,10135,"They're building"],[10135,10306,"a new Maplewood Mega Resort"],[10306,10422,"on plot fifteen?"],[10523,10581,"What?"],[10664,10727,"The land value"],[10727,10839,"has risen to five hundred"],[10839,10948,"million dollars!"],[11081,11136,"Wait."],[11440,11532,"Damn you, Blackwood,"],[11532,11611,"you've done it again!"]],"24":[[12,70,"What?"],[87,225,"Lila worked her magic again?"],[250,329,"Unbelievable."],[354,517,"And Lila reeled in a big one this time."],[533,700,"Mapleland Mega Resort."],[738,900,"God, she sure is a good luck charm."],[909,980,"Thanks to her,"],[996,1209,"my company's got a new lease on life."],[1226,1338,"No, how can that be?"],[1338,1455,"There has to be something"],[1455,1526,"wrong here."],[1564,1718,"Congratulations on your purchase,"],[1718,1801,"Mr. Blackwood."],[1822,1960,"Are you interested in buying"],[1960,2118,"any other plots of land today?"],[2131,2298,"I'm on a limited budget."],[2327,2510,"Gotta be careful with my choices."],[2510,2577,"Seriously?"],[2585,2631,"You're going to let her"],[2631,2723,"pick for you again?"],[2736,2794,"What's wrong?"],[2794,2919,"You scared of losing to a kid?"],[2961,3048,"Like hell I am."],[3078,3161,"I'm warning you,"],[3174,3261,"that little brat's luck"],[3261,3349,"is about to run out."],[3349,3532,"And when it does, you'll be broke."],[3553,3732,"Yeah, you won't be lucky all the time."],[3757,3908,"Keep your little rat on a leash."],[3908,4041,"You're crazy to trust her."],[4062,4358,"I'd rather be broke, than be a bad man"],[4375,4525,"who only cares about money."],[5342,5463,"Oh God, not another bad one."],[5463,5513,"A good one. - No,"],[5526,5613,"Choose a good one. - no, no."],[5793,5885,"Sold,"],[5885,6031,"for four hundred million."],[6126,6210,"Lila, wait."],[6210,6260,"Oh my God."],[6260,6423,"I know her first choice"],[6423,6473,"was a winner,"],[6473,6644,"but let's not push our luck."],[6690,6823,"Oh, Jonathan,"],[6823,7048,"look at the plot that Lila picked."],[7065,7215,"It's, it's worthless."],[7244,7394,"It's a patch of deserted land"],[7394,7482,"in the middle of nowhere."],[7524,7590,"You'd be better off"],[7590,7728,"buying land on Mars."],[7761,7870,"You know what it's good for?"],[7878,8020,"A coffin you can't afford."],[8041,8195,"Lila is bad luck."],[8379,8508,"Daddy, did"],[8537,8687,"Lila do something wrong?"],[8717,8762,"No."],[8762,8925,"Is Lila not allowed"],[8925,9025,"to choose anymore?"],[9025,9142,"No, no, no, you did nothing wrong."],[9180,9342,"A run-down, empty lot"],[9342,9484,"for four hundred million?"],[9534,9638,"That's a reckless purchase"],[9638,9838,"even if our company was doing well."],[9905,10080,"Lila must be tired."],[10097,10260,"Maybe you should have her rest"],[10260,10393,"and you pick for yourself?"],[10406,10564,"You're unreal, Jonathan."],[10589,10760,"You're really gonna let a little girl"],[10760,10927,"run your company into the ground?"],[10994,11232,"Daddy, please trust me."],[11265,11311,"I picked it"],[11311,11465,"because it has the coins on top."],[11490,11711,"Maybe Lila does have super powers."],[11711,11899,"Should l trust her?"]],"25":[[183,350,"It doesn't matter what she picks."],[379,558,"Her happiness is what matters most."],[646,742,"Whichever one you want,"],[804,880,"go ahead and choose."],[942,1005,"Okay."],[1101,1276,"No, sir, please,"],[1276,1413,"land is not cheap."],[1426,1505,"Our capital chain"],[1505,1655,"is on the verge of collapse."],[1697,1789,"One wrong step"],[1789,1889,"and the Blackwood Empire"],[1889,2018,"goes up in flames."],[2039,2185,"We can't afford to waste money."],[2185,2264,"Not a waste,"],[2310,2398,"if it makes her happy."],[2535,2635,"A father will do anything"],[2635,2690,"to put a smile"],[2690,2798,"on his daughter's face."],[2806,2882,"And you'll learn that"],[2882,3007,"when you become a father."],[3123,3290,"You're giving up your whole empire"],[3290,3374,"to be a father"],[3374,3561,"to a little pet from the street?"],[3582,3703,"You've lost it."],[4166,4371,"What's this kid trying to do now?"],[4371,4508,"What the heck? - No, Miss Lila,"],[4508,4629,"please stop! - I don't think she's"],[4629,4717,"allowed to do that."],[6110,6239,"Shoot. - She did it."],[6681,6894,"Oh, look at what Lila's done now."],[6944,7032,"Really stepped in it."],[7048,7161,"That plot she's picked,"],[7161,7207,"it's right in the middle"],[7207,7303,"of Death Bend."],[7357,7415,"There's"],[7415,7649,"not a gas station within fifty miles."],[7703,7749,"And that's straight"],[7749,7841,"where you're headed too,"],[7841,7924,"Death Bend."],[8024,8116,"If you catch my drift."],[8179,8233,"No."],[8245,8329,"Sir, I told you"],[8329,8454,"we shouldn't push our luck."],[8579,8654,"We're screwed."],[8683,8737,"Jonathan,"],[8737,8808,"seeing as you're about"],[8808,8946,"to lose everything,"],[8950,9067,"it seems like your only choice"],[9067,9263,"is to marry into the Fairchild family."],[9292,9413,"Congrats on your engagement."],[9438,9584,"Better to be a son-in-law"],[9584,9659,"than a father."],[9697,9872,"Easier to rely on a woman"],[9872,10055,"than to make money by yourself."],[10105,10168,"No!"],[10214,10306,"I'm not letting Daddy"],[10306,10422,"marry a mean lady."],[10685,10823,"Oh, shut up, you brat!"],[10865,10981,"Plots sixteen,"],[10981,11127,"eighteen, and nineteen"],[11131,11369,"all go to Mr. Blackwood."]],"26":[[16,141,"Mr. Blackwood,"],[158,300,"I didn't peg you as the type"],[300,442,"to blow up your whole empire"],[442,629,"just to make a stupid kid happy."],[663,838,"Jonathan's had a decent run,"],[838,1076,"but now his true colors are showing."],[1080,1151,"I don't know what you saw"],[1151,1242,"in the bastard."],[1309,1359,"Ow!"],[1455,1647,"Are you questioning my taste in men?"],[1710,1851,"I am the reason you're here."],[1897,1985,"And I can be the reason"],[1985,2064,"you disappear."],[2160,2306,"Harold, what are you thinking"],[2306,2464,"talking back to Ms. Fairchild?"],[2494,2544,"If you don't have"],[2544,2644,"anything worth saying,"],[2644,2773,"then keep your mouth shut!"],[2823,3040,"No, no, no, Ms. Fairchild, please,"],[3040,3182,"I didn't mean it as a criticism."],[3182,3382,"We just, we, we care about you."],[3507,3649,"I'll take the eight billion dollar plot"],[3649,3707,"right there."],[4454,4571,"That one's a no-brainer,"],[4600,4688,"if you've got the funds."],[4700,4829,"Ms. Fairchild's gonna be sitting"],[4829,4996,"pretty for generations."],[5038,5192,"I bet Blackwood's kicking himself."],[5230,5321,"In normal times,"],[5330,5397,"he could have forked out"],[5397,5455,"the eight billion,"],[5455,5555,"but since the stock crash,"],[5572,5709,"I'd say only the Fairchilds"],[5709,5789,"had that kind of money."],[5897,6051,"And maybe the Sinclairs."],[6076,6181,"Time to show them"],[6181,6373,"how us Sinclairs do business."],[6473,6523,"Now."],[6544,6727,"We'll take plot number five."],[7340,7515,"That plot happens to be right"],[7515,7678,"near your house, yes?"],[7699,7803,"I heard you talking one day"],[7803,7912,"about how nice it would be"],[7912,8037,"to have your own private"],[8037,8258,"high-tech hospital all to yourself."],[8354,8504,"What do you say I sell you the land"],[8504,8587,"and we can make your dream"],[8587,8687,"come true, hmm?"],[8771,8863,"See that, Blackwood?"],[8863,9050,"That's what real power looks like."],[9075,9205,"Enjoy playing kid games"],[9205,9317,"with that stupid brat."],[9359,9467,"The richest man"],[9467,9676,"has become the stupidest man"],[9676,9872,"after taking in the little brat."],[9901,10043,"But Auntie,"],[10085,10331,"your plot of land has no coins on it."],[10331,10485,"Coins, coins, coins,"],[10485,10598,"where are these coins?"],[10639,10752,"What do you know?"],[10777,10931,"Hmm? I'll tell you one thing."],[10985,11148,"My wallet is going to be flushed"],[11148,11244,"with bitcoins"],[11244,11398,"once that hospital is built."],[11440,11682,"Plot one goes to Ms. Fairchild,"],[11720,11928,"and plot five to Mr. Sinclair."],[11966,12178,"Jonathan, we know you can't afford"],[12178,12312,"all that land you bought."],[12354,12449,"How about this?"],[12495,12562,"Marry me,"],[12591,12662,"and I'll hand you"],[12662,12804,"that eight billion dollar plot,"],[12804,12896,"and tell the banks"],[12896,13054,"to lay off the Blackwood Group."],[13129,13188,"Deal?"],[13267,13626,"Auntie V, bullying brings you bad luck."],[13676,13893,"Shut your mouth."],[14268,14335,"What?"],[14848,15081,"Unfortunately, testing has revealed"],[15081,15311,"the soil in plots one and five"],[15352,15432,"is contaminated"],[15432,15628,"with highly toxic metals."],[15682,15786,"Due to the health hazard,"],[15786,16007,"the government has forced construction"],[16016,16091,"at these sites"],[16091,16257,"to be delayed indefinitely."],[16637,16758,"No way."]],"27":[[50,158,"That's impossible!"],[258,333,"Sorry,"],[392,521,"your land is being fenced off"],[521,613,"like Chernobyl."],[642,775,"No one's allowed inside."],[796,834,"Sounds like"],[834,934,"nothing is going to be built there"],[934,1059,"for a very long time."],[1101,1159,"No."],[1167,1230,"How?"],[1242,1397,"No, this can't be happening!"],[1463,1572,"Toxic substances?"],[1572,1685,"How is that even possible?"],[1718,2002,"Buying land is a very calculated risk."],[2010,2181,"We'd like to remind all buyers"],[2181,2235,"to remember"],[2235,2423,"to exercise caution"],[2460,2698,"and do sufficient research"],[2698,2827,"before making decisions."],[2898,3078,"You spoiled little twerp!"],[3403,3636,"Whatever, it's a measly eight billion."],[3653,3778,"We'll make that back in a week."],[3824,3891,"But you?"],[3949,4104,"Your company's on cardiac arrest"],[4104,4262,"and you're still snapping up land"],[4262,4450,"like we're playing Titans and Tycoons."],[4508,4621,"You should write a book called"],[4621,4792,"How to Go Bankrupt for Dummies."],[4833,5025,"Don't celebrate too soon, Blackwood."],[5063,5113,"Talk to us"],[5113,5176,"when you can actually"],[5176,5259,"cough up the dough"],[5259,5347,"for all this land."],[5380,5480,"Daddy has the money."],[5576,5743,"Daddy, the plot you bought"],[5743,5947,"is worth five hundred million, right?"],[5993,6235,"Just sell that and buy all the rest."],[6264,6381,"Uncle Harold"],[6393,6602,"must not do good at math."],[6977,7065,"You damn brat!"],[7073,7161,"If you insult me again,"],[7161,7269,"I'll rip your tongue out!"],[7328,7432,"Can't take an innocent joke"],[7432,7515,"from a little girl?"],[7595,7640,"Everyone else"],[7640,7716,"thought it was funny."],[7782,7907,"Fine, whatever."],[7978,8066,"Doesn't change the fact"],[8066,8170,"that you've purchased"],[8179,8258,"dead land."],[8274,8425,"Maintaining it alone will bankrupt you."],[8479,8612,"He is right, sir."],[8704,8921,"Daddy, our land has coins."],[8967,9059,"I promise."],[9071,9142,"I believe you."],[9209,9255,"It's okay."],[9255,9300,"We'll,"],[9334,9455,"We'll sell our assets,"],[9484,9572,"to make do."],[9805,9905,"We're getting word"],[9905,10080,"that oil has been found"],[10080,10168,"in Death Bend."],[10176,10239,"What?"],[10285,10443,"And a Fortune 500 company"],[10443,10543,"just announced it’s,"],[10589,10940,"going to do a fifty billion dollar refinery"],[10940,11027,"of the land."],[11073,11302,"And it's expected to skyrocket in value."],[11419,11498,"Didn't Mr. Blackwood"],[11498,11594,"just buy land there?"],[12237,12324,"Oh my God."],[12449,12604,"Oh my God, she did it again."]],"28":[[29,116,"Mr. Blackwood's"],[116,246,"lucky streak continues!"],[258,337,"I never doubted you."],[362,462,"The value of this land"],[462,596,"just went up fiftyfold!"],[596,709,"It doesn't make any sense."],[709,825,"How does this keep happening?"],[855,992,"I see what this is, Jonathan."],[1017,1121,"You have inside info."],[1134,1288,"You made this kid choose everything"],[1288,1443,"so it looks like you're getting lucky."],[1484,1584,"Are you that desperate"],[1584,1680,"to embarrass us?"],[1701,1785,"Yeah, Jonathan,"],[1835,1922,"why don't you be generous, huh?"],[1931,2010,"Spread the wealth!"],[2043,2181,"Sell each, each of us"],[2181,2318,"one of your plots of land."],[2394,2498,"If you get too selfish,"],[2531,2598,"someone might actually"],[2598,2694,"go after your family."],[2744,2819,"Selfish?"],[2819,2852,"You're mad"],[2852,2965,"because you keep losing."],[3003,3107,"He earned these plots"],[3107,3199,"fair and square."],[3215,3516,"If you want land, buy it yourself."],[3661,3807,"Sir, if you'd like to do business,"],[3807,3874,"I'm your guy."],[3883,4012,"I'll give you twenty billion"],[4024,4120,"for the one in Death Bend."],[4141,4245,"Twenty billion!"],[4258,4404,"That's ten times what he spent today!"],[4421,4508,"Are you kidding?"],[4537,4612,"A second ago,"],[4612,4767,"you were drooling all over the land"],[4767,4842,"I bought."],[4859,4979,"Now you're begging to do business"],[4979,5038,"with him?"],[5063,5271,"Ms. Fairchild, I'm not stupid."],[5305,5422,"They found toxic chemicals"],[5422,5492,"at your site."],[5513,5597,"It makes Chernobyl"],[5597,5751,"look like Disneyland."],[5751,5818,"It does."],[5889,6022,"Goddamn bastard!"],[6122,6247,"Mr. Blackwood, do we have a deal?"],[6631,6723,"I'll have my assistant"],[6723,6802,"draw up the contract."],[6827,7032,"So, so that's a yes?"],[7061,7236,"All right, fantastic!"],[7286,7361,"Pleasure doing business"],[7361,7424,"with you, sir."],[7699,7770,"Come on, sweetheart."],[7824,7887,"Let's go home."]],"29":[[287,483,"This must be some kind of bad dream."],[850,1030,"Thank you so much for everything, Lila."],[1055,1159,"You saved my company."],[1201,1418,"You really are Daddy's lucky star."],[1480,1647,"Daddy, I'm hungry."],[1739,1826,"Let's get you something to eat."],[1826,1893,"What do you want?"],[1910,2060,"If anybody deserves a feast, it's you."],[2102,2289,"I'll eat whatever Daddy likes."],[2327,2385,"You make everything"],[2385,2489,"so easy for me."],[2540,2590,"Let's go."],[2686,2844,"Hey, hey, hey, not so fast."],[2890,2961,"Admit it,"],[2990,3190,"you illegally fixed this whole sale."],[3215,3449,"How else could this street-trash stray"],[3457,3503,"have chosen"],[3503,3728,"every single prized piece of land?"],[3737,3853,"You tell me that, Blackwood."],[3853,3912,"Ow!"],[4079,4141,"Yes!"],[4583,4796,"Lila is not a street rat,"],[4808,4992,"and she's definitely not street trash."],[5059,5130,"She's my daughter."],[5188,5288,"And if you ever insult"],[5288,5380,"my daughter again,"],[5447,5668,"I'll do way worse than just slap you."],[5747,5809,"Wait!"],[5834,6051,"Jonathan, I like you."],[6097,6281,"I've had a crush on you for years."]],"30":[[25,196,"But, you're a mean lady."],[241,517,"Daddy only likes nice ladies."],[546,750,"Just stay out of this, you devil child."],[763,884,"You say you like me,"],[921,1038,"and you insult my daughter"],[1038,1126,"right in front of me?"],[1209,1276,"Lila was right."],[1334,1368,"You're nothing"],[1368,1530,"but a mean, disgusting woman."],[1584,1680,"Get out of my face."],[1743,1776,"Damn it,"],[1776,1901,"you'll regret this, Jonathan."],[1918,2018,"I'll bring the full wrath"],[2018,2160,"of the Fairchilds upon you!"],[2214,2289,"Full wrath?"],[2339,2444,"That stunt with the banks,"],[2444,2510,"that was cute."],[2577,2656,"I can't wait to see"],[2656,2869,"what the Fairchilds fail at next."],[3978,4104,"That little devil child!"],[4137,4283,"First she cost us the auction,"],[4287,4383,"then the land deal,"],[4412,4475,"now she's coming"],[4475,4600,"between me and Jonathan!"],[4617,4688,"Ms. Fairchild,"],[4688,4829,"don't waste your energy on this."],[4863,4938,"We have a plan"],[4938,5113,"to make sure Lila will never"],[5125,5267,"come between you and Jonathan again."]],"31":[[525,583,"Maggie."],[613,663,"Yes?"],[663,804,"Noah loves balloons."],[846,896,"Oh."],[1001,1055,"Well,"],[1121,1297,"I don't see the vendor,"],[1317,1518,"but I'll get you guys balloons, okay?"],[1555,1601,"Yay!"],[1601,1697,"Thanks, Maggie!"],[1701,1785,"Of course."],[1814,1881,"Stay right here."],[1985,2035,"Okay."],[3086,3240,"That damn devil child"],[3240,3353,"has gotten in my way"],[3353,3461,"for the last time."],[3516,3620,"No more games."],[3962,4045,"Hey there, Lila."],[4049,4175,"You're gonna come with us, okay?"],[4208,4329,"No, Uncle Harold."],[4329,4421,"Hey, stop it."],[4425,4517,"Let her go!"],[4517,4662,"Hey, I wasn't talking to you."],[4783,4833,"No!"],[4888,4929,"Help!"],[4929,5038,"Hey, stop it."],[5201,5259,"Help!"],[5326,5451,"Hey, what are you two looking at?"],[5467,5568,"Talking to my daughter here."],[5568,5647,"Mind your business."],[5668,5805,"Our baby girl."],[6085,6147,"No, I'm-"],[6147,6214,"You're nothing."],[6235,6277,"Bet you don't get"],[6277,6377,"to throw a temper tantrum"],[6377,6527,"because I didn't buy you balloons, okay?"],[6527,6639,"We are leaving now."]],"32":[[37,208,"Noah, get Maggie."],[312,371,"Hey!"],[483,725,"Honey, your daddy's still alive."],[759,925,"We can be a family again."],[1084,1205,"Daddy's still alive?"],[1222,1338,"Daddy's coming back?"],[1505,1564,"Yes."],[1601,1697,"Let's go see him, okay?"],[1697,1747,"Come on."],[1789,1847,"Come on."],[2444,2531,"You remember your Aunt Vivienne,"],[2531,2581,"don't you?"],[3073,3244,"Is Daddy really alive?"],[3424,3541,"Is that what you told her?"],[3762,3824,"He's not."],[3874,3953,"Keep up, kid."],[3962,4137,"You're not ready for the grown-up table."],[4950,5017,"Where is she?"],[5075,5134,"I don't know."]],"33":[[204,312,"Got you, you brat."],[379,412,"You know,"],[412,538,"I was gonna make Jonathan mine"],[538,638,"without all this mess."],[729,813,"But thanks to you,"],[859,980,"that's off the table now."],[1051,1113,"So,"],[1255,1422,"what to do with you?"],[1484,1568,"Let me go!"],[1630,1722,"Ms. Fairchild,"],[1722,1843,"nothing good happens"],[1843,1947,"when that kid's around."],[1981,2223,"She embarrassed me, cost us money."],[2248,2423,"We can't let her out of here alive."],[2460,2540,"You're lying!"],[2577,2631,"Yeah."],[2677,2790,"I went easy on you, Lila,"],[2790,2877,"because you were family."],[2894,3019,"Big mistake."],[3053,3161,"We have to get rid of her."],[3528,3649,"She's been in my way long enough."],[3695,3787,"I should've gotten rid of her"],[3787,3895,"the first time we met."],[3895,4049,"Please, let me out!"],[4087,4258,"But killing you would be too easy."],[4333,4433,"She needs to pay."],[4512,4642,"What if we give Jonathan"],[4642,4746,"the wrong address?"],[4771,4929,"He shows up with a ransom."],[4963,5059,"We take the money"],[5059,5259,"and tie up loose ends."],[5321,5442,"Then the money will be gone"],[5442,5597,"and so will she."],[5597,5680,"Don't do that!"],[5680,5780,"Just let me out"],[5780,5939,"and everything will be fine!"],[5993,6068,"Perfect."],[6122,6306,"Make it hurt, but make it clean."],[6343,6481,"Nice, and..."],[6769,6902,"I have to find a way"],[6902,7069,"to let Daddy know where I am."]],"34":[[1113,1172,"What?"],[1263,1388,"What do you mean Lila's gone?"],[1555,1639,"Sir,"],[1672,1789,"I'm really sorry."],[1839,1960,"This is all my fault."],[2022,2072,"Maybe we should"],[2072,2181,"get the cops involved?"],[2181,2256,"No, no, no, no."],[2256,2335,"If we file a report,"],[2335,2452,"it'll spook whoever has her."],[2460,2519,"They'll kill her."],[2535,2677,"Then what do we do, Dad?"],[3553,3607,"Yes?"],[3641,3870,"Give me fifty million in forty-eight hours."],[3870,4087,"Meet me at East Main, 7 a.m."],[4087,4245,"Cash, no police."],[4262,4354,"Try anything stupid?"],[4354,4429,"And she's dead."],[4504,4700,"So they're holding Lila for ransom?"],[4725,4913,"If you want cash, so be it."],[4967,5071,"But you return my daughter"],[5071,5142,"to me unharmed,"],[5142,5234,"or there's no deal."],[5438,5497,"Hello?"],[5559,5618,"Hello?"]],"35":[[150,266,"Track that number, now."],[312,500,"Sir, this is obviously a setup."],[533,625,"If we hand them over the cash,"],[625,700,"how can we be certain"],[700,842,"that they won't vanish with her?"],[959,1180,"They used a voice mod, and a relay."],[1209,1351,"Caller ID is scrubbed."],[1384,1543,"I'm not able to lock their location,"],[1543,1597,"but I will."],[1609,1651,"Wait, wait, wait."],[1651,1693,"So this was"],[1697,1789,"a planned kidnapping?"],[2114,2235,"Who would benefit from that?"],[2352,2456,"Obviously Vivienne."],[2456,2590,"She's unhinged."],[2619,2752,"God, Vivienne."],[2794,2894,"Okay, forget about East Main."],[2944,3011,"Track Vivienne."],[3057,3253,"Track her cars, her credit cards,"],[3274,3386,"her security cam, everything."],[3449,3591,"If we find Vivienne, we find Lila."],[3632,3745,"Okay, I'm on it."],[4316,4375,"Lila's,"],[4404,4462,"she's wearing"],[4462,4575,"that tracker necklace I gave her."],[4575,4633,"She's clever."],[4633,4771,"She's gonna try and send a signal."],[4800,4925,"Look out for that necklace."],[4934,5059,"If anything jumps, call me."],[5080,5130,"Yes, sir."],[5155,5267,"Lila, where are you?"],[5267,5401,"l gave you that necklace so l can"],[5401,5651,"find you anywhere. Just hold on for me."]],"36":[[212,262,"Got it."],[325,392,"Thanks, Pablo."],[521,642,"Got eyes on Blackwood."],[646,800,"They're stacking cash."],[817,896,"Looks like they'll be making"],[896,996,"the drop tomorrow."],[1042,1096,"Good."],[1113,1197,"Stick to the plan."],[1197,1297,"No screw ups."],[1297,1393,"And after that,"],[1422,1526,"what do we do with her?"],[1814,1876,"Simple."],[2122,2214,"One shot and we're done."],[2214,2302,"Let me go!"],[2352,2473,"My daddy's not gonna let you"],[2473,2573,"get away with this."],[2573,2644,"Shut up!"],[2690,2781,"If it weren't for you,"],[2815,2940,"I'd have married the richest man"],[2940,3011,"in the country."],[3078,3211,"Your daddy doesn't want you anymore."],[3261,3345,"You're lying!"],[3370,3453,"Daddy's coming!"],[3470,3599,"He always comes for me."],[3920,3962,"Ow!"],[4020,4116,"You little brat!"],[4162,4225,"Bite me again"],[4225,4341,"and I'll end you right here."],[4421,4483,"Joseph."]],"37":[[362,613,"All you have to do is activate it."],[738,875,"The whole necklace lights up."],[934,1113,"That way, you'll never lose it."],[1284,1343,"Wait!"],[1351,1438,"Uncle Harold,"],[1480,1647,"don't you remember what Daddy said?"],[1693,1793,"If you hurt me,"],[1810,1939,"he's gonna get you back"],[1939,2102,"ten times worse this time."],[2106,2218,"Shut up, you little rat."],[2248,2344,"What, you think you're all that"],[2344,2477,"because your daddy's rich?"],[2535,2652,"Beat you to death right now"],[2652,2740,"and he wouldn't even know."],[2815,2886,"He loves me."],[2907,2986,"He'll find me."],[3340,3490,"Look at this priceless necklace"],[3490,3561,"he got me."],[3878,3962,"Well, well."],[4016,4162,"Look at what we've got here."],[4262,4362,"Jonathan gave you that?"],[4391,4466,"Hand it over."],[4542,4604,"No."],[4612,4825,"Daddy said it's worth billions."],[5146,5301,"We raised you for years."],[5342,5509,"Think of it as payback."],[5814,5922,"Ms. Fairchild, this,"],[5989,6185,"gem is worth a fortune."]],"38":[[145,291,"That looks like the Blue Star."],[333,433,"It's worth millions."],[763,817,"Wait."],[905,1063,"What's this worthless thing?"],[1155,1397,"I need to get that bead from her!"],[1397,1526,"It's a magic marble."],[1580,1818,"I found it with the dog."],[1897,1956,"Ew!"],[1997,2202,"Nasty girls can keep their nasty toys."],[2335,2427,"I don't wanna wear something"],[2427,2569,"the little devil child wore."],[2581,2731,"Great! I got the tracker."],[2731,2819,"Just one more step."],[2819,2877,"No!"],[2927,3115,"Not my billion dollar necklace."],[3207,3328,"Wait, wait, wait, wait, wait."],[3378,3524,"If it really is valuable,"],[3541,3636,"I could sell it."],[3678,3753,"The Summit Hotel"],[3753,3912,"is holding a jewelry auction today."],[3937,4008,"The money will make up"],[4008,4120,"for that land deal."],[4266,4320,"Sure."],[4375,4500,"I don't wanna look at it anymore."],[4842,5055,"Daddy, you'll see the necklace."],[5059,5155,"You'll find me."],[5609,5684,"Did you prepare the cash"],[5684,5751,"for the exchange?"],[5789,5918,"No, but sir,"],[6018,6122,"I found the necklace."],[6310,6402,"It's being auctioned off"],[6402,6498,"at the Summit Hotel."],[6644,6731,"They've been distracting us"],[6731,6790,"with the ransom."],[6831,6961,"It's a classic bait and switch."],[6961,7019,"Let's go!"]],"39":[[179,446,"Next up, a newly added piece."],[479,763,"A 12.8 carat Sri Lankan"],[775,925,"royal blue sapphire,"],[967,1155,"surrounded by eighteen"],[1159,1347,"flawless diamonds."],[1418,1572,"Yep, that's Lila's necklace."],[1655,1735,"Top quality."],[1789,1972,"Starting bid, ten million."],[2327,2448,"Whatever the price,"],[2448,2585,"I'll get that necklace!"],[2585,2706,"And I'll fnd out who took Lila!"],[2731,2819,"One hundred million."],[3603,3741,"One hundred million?"],[3837,3949,"Jackpot."],[4008,4116,"Going once."],[4250,4316,"Twice."],[4475,4662,"Sold for one hundred million."],[4829,4921,"I wanna meet the seller,"],[4954,5034,"or there’s no deal."]],"40":[[37,129,"Ladies and gentlemen,"],[158,350,"this piece is provided by"],[375,450,"Mr. Sinclair."],[988,1109,"Time to pay the-"],[1835,1901,"It's you!"],[1960,2035,"No, no!"],[2193,2302,"Hey, let's be civilized."],[2318,2419,"Everybody out!"],[2569,2631,"Hey, where are you going?"],[2631,2681,"Don't leave me!"],[2681,2748,"That necklace"],[2748,2852,"was a gift for my daughter."],[3007,3082,"Where is she?"],[3123,3190,"You're crazy."],[3199,3311,"That, that necklace is mine."],[3324,3386,"It's not my fault"],[3386,3461,"if you can't keep track"],[3461,3528,"of your own kid."],[3528,3570,"What?"],[3570,3628,"Ow!"],[3716,3841,"You lying rat."],[3887,3999,"I have the receipts."],[4024,4095,"Where is she?"],[4108,4166,"I, I,"],[4225,4295,"I, I don't know!"],[4404,4475,"I swear to God,"],[4475,4592,"if anything happens to Lila,"],[4608,4763,"I'll bury you myself."],[4779,4842,"Now move! - Hey!"],[4842,4946,"Hey, watch the suit!"],[4971,5038,"Watch the suit!"]],"41":[[141,241,"It's been long enough."],[275,333,"Why aren't they back"],[333,412,"with the money yet?"],[700,809,"Finally, our money."],[980,1055,"Where's the money?"],[1105,1217,"The Blackwoods didn't pay."],[1263,1322,"What?"],[1359,1476,"So is Jonathan just going to"],[1476,1634,"let this devil child die?"],[1672,1718,"No."],[1743,1881,"Mr. Blackwood went to the auction"],[1881,2010,"and caught Mr. Sinclair."],[2039,2106,"What?"],[2156,2268,"Where are they now?"],[2302,2377,"On their way here."],[2669,2752,"Of course he is."],[2823,2915,"A man like Jonathan"],[2915,3069,"doesn't fall for tricks that easily."],[3115,3186,"I knew it!"],[3211,3328,"Daddy's coming for me!"]],"42":[[75,262,"Oh my God, how did they find us?"],[308,433,"You little devil child"],[433,558,"made us take your necklace."],[633,742,"Take her to the basement."],[759,813,"Now!"],[850,971,"No, please!"],[1001,1130,"Not the basement."],[1242,1309,"Please!"],[1468,1534,"Please!"],[1593,1743,"Anybody, help!"],[1868,1947,"Please!"],[1972,2031,"No!"],[2473,2535,"Wait!"],[2535,2602,"Wait, wait!"],[2602,2665,"Don't close it!"],[2665,2744,"Wait, no!"],[2781,2952,"Please, don't go!"],[2977,3094,"Please don't leave me!"],[3144,3374,"Try getting out now, you little pest."],[3482,3611,"Totally unnecessary."],[3958,4024,"Harold?"],[4058,4179,"What the hell happened?"],[4450,4537,"Where is she?"]],"43":[[0,70,"Where is she?"],[237,287,"Who?"],[312,396,"Cut the act!"],[412,525,"Where are you hiding Lila?"],[542,663,"Miss Lila, don't worry, it's us."],[663,742,"We're here to save you."],[746,842,"Stop yelling."],[892,1034,"There's no Lila here."],[1088,1184,"Maybe if you actually"],[1184,1276,"watched your kid,"],[1284,1426,"she wouldn't have wandered off."],[1447,1501,"Don't make me"],[1501,1584,"have you all arrested"],[1584,1672,"for trespassing."],[1768,1881,"The only reason"],[1889,1972,"why I'm holding back"],[1972,2081,"is because you're a woman."],[2122,2306,"But I swear to God, if you've hurt Lila,"],[2331,2469,"I'll kill you myself."],[2502,2802,"Now tell me, where is Lila?"],[2836,2936,"Mr. Blackwood,"],[2936,3165,"that little brat runs away all the time."],[3207,3328,"How's that our fault?"],[3361,3482,"You're just looking for someone"],[3482,3557,"to blame."],[3603,3749,"Yeah, get your hands off me."],[3799,3958,"Security, get them out of here."]],"44":[[842,913,"What the hell?"],[955,1155,"Tell me, where is she?"],[1217,1276,"Now!"],[1317,1514,"You can't just break into my house"],[1514,1668,"and wave guns in my face."],[1714,1810,"I'll call the cops."],[1830,1964,"I'll make sure the whole world sees"],[1964,2118,"what kind of evil man you are."],[2160,2260,"Watch your company stock"],[2260,2331,"tank overnight!"],[2331,2452,"To hell with the stocks!"],[2494,2640,"I swear, if you've hurt Lila,"],[2644,2731,"I'll make you pay."],[2761,2894,"If anyone should be calling the cops,"],[2894,2948,"it's me."],[3044,3119,"Let me go."],[3169,3219,"Help!"],[3236,3374,"He's trying to kill me!"],[3395,3486,"Nobody move!"],[3553,3695,"If anybody touches my daughter,"],[3695,3778,"you're all dead!"],[3812,3974,"Search the whole damn house!"],[3995,4083,"And call the cops."],[4099,4149,"On it."],[4466,4604,"With me, that way."],[4788,4967,"Go on, search all you want."],[4967,5092,"There's nothing to find."]],"45":[[316,375,"Why?"],[746,875,"Why isn't it glowing?"],[1013,1205,"Daddy, where are you?"],[1317,1463,"So cold."],[1539,1626,"Dark."],[1689,1780,"And they're so mean."],[1868,1964,"I'm scared."],[2022,2093,"Please."],[2131,2198,"And guess what?"],[2202,2369,"If any of the diamonds fall off,"],[2473,2585,"you activate it."],[2848,2894,"Woah! - The whole"],[2894,2994,"necklace lights up."],[3094,3357,"Daddy, are you coming soon?"],[3474,3545,"Lila?"],[3812,3887,"Lila?"],[4008,4291,"Daddy, I'm so cold."],[4629,4696,"Lila?"],[4829,5059,"Am I dying?"],[5422,5534,"God, where are you?"],[5701,5764,"Lila?"],[5864,5926,"It's us."],[6756,6840,"Sir, look."],[7086,7148,"Lila."]],"46":[[183,246,"Lila's in here."],[258,316,"Open the door."],[738,800,"It's locked."],[817,938,"Open the door!"],[1126,1176,"The key!"],[1230,1301,"Where's the key?"],[1301,1376,"What key?"],[1426,1605,"I haven't used that basement in years."],[1605,1764,"I don't even know where the key is."],[1814,1893,"She's lying."],[2260,2373,"Are you crazy?"],[2406,2510,"Put that gun away."],[2510,2615,"I don't wanna die."],[2640,2698,"Too late."],[2761,2840,"I asked you where's the key"],[2840,2919,"and you didn't listen."],[2923,2994,"Don't shoot!"],[3044,3207,"Please, don't kill me!"]],"47":[[421,471,"Wait."],[629,713,"This could be a trap."],[754,813,"I don't care."],[829,896,"It's Lila."],[934,1026,"Stay here."],[2481,2610,"It's glowing."],[2723,2840,"Daddy's here,"],[2936,3023,"to save me."],[3657,3720,"Lila?"],[3807,3866,"Daddy!"],[3866,3928,"Lila!"],[4162,4262,"Oh my God."],[4396,4537,"Lila, are you okay?"],[4621,4658,"Are you okay?"],[4658,4717,"Are you hurt?"],[4746,4804,"Sweetheart,"],[4804,4929,"you scared me half to death."],[4950,5071,"I'm fine, Daddy."],[5134,5284,"I knew you wouldn't leave me."],[5313,5422,"I would never leave you,"],[5422,5497,"silly goose."],[5697,5855,"We'll always be together."],[6197,6268,"Always."],[6468,6527,"Daddy,"],[6560,6652,"Auntie V has"],[6652,6810,"a bunch of snow over there."],[7036,7102,"Snow?"],[7123,7173,"Yeah."],[7211,7269,"Come."],[7536,7603,"Follow me."]],"48":[[20,150,"Daddy, come on."],[225,333,"Look at the snow."],[404,467,"Whoa."],[684,838,"I found this notebook too."],[1288,1359,"What's wrong?"],[1372,1493,"It's just snow."],[1522,1701,"This is a pipeline."],[1764,1881,"The Fairchild family's"],[1881,2010,"drug smuggling ring?"],[2093,2281,"You really are Daddy's lucky star."],[2431,2481,"Come on."],[2535,2594,"Let's go."],[2982,3036,"Here's this."],[3516,3632,"Looks like the Fairchild's"],[3632,3753,"innovation portfolio"],[3753,3878,"runs deeper than we thought."],[3928,4079,"Ethan, I want you to go in that cellar"],[4079,4195,"and count every crate,"],[4220,4437,"every bar, and every roll."],[4475,4612,"And give this cocaine ledger"],[4654,4746,"to the FBI."],[4817,4871,"Yes, sir."],[4896,4959,"Wait!"],[5021,5134,"Now that you know my secret,"],[5171,5301,"I can't let you walk out."],[5384,5459,"What, are you gonna kill us"],[5459,5555,"to keep your secret?"]],"49":[[0,70,"What, are you gonna kill us"],[70,166,"to keep your secret?"],[191,354,"No, no, Jonathan,"],[354,467,"that's not what I meant."],[487,671,"That ledger is pretty hard to misread."],[679,838,"No, Jonathan,"],[867,1005,"do you have to be this cold?"],[1005,1172,"I've been nothing but love."],[1201,1401,"Why won't you just look at me once?"],[1434,1488,"Because we were never"],[1488,1605,"the same type of person."],[1664,1730,"Get off me."],[2002,2060,"Wait!"],[2089,2193,"How about we split the money,"],[2231,2306,"fifty-fifty?"],[2331,2377,"I'll sign over"],[2377,2469,"that Fifth Avenue building"],[2469,2531,"you want."],[2552,2690,"As long as we keep this between us,"],[2690,2748,"I'll do,"],[2915,3019,"whatever it takes."],[3148,3211,"What makes you think"],[3211,3319,"you can bargain with me?"],[3511,3666,"Hey, where do you think you're going?"],[3774,3933,"Hey, get your hands off!"],[4254,4358,"You too, come here."],[4371,4441,"Hey don't touch her-"],[4441,4500,"Take her."],[4500,4562,"I'll sue you."],[4562,4621,"You hear me?"],[4825,4892,"Ms. Fairchild,"],[4988,5142,"Fairchild Group is under investigation"],[5142,5246,"for drug smuggling."]],"50":[[54,129,"Ms. Fairchild,"],[175,321,"Fairchild Group is under investigation"],[321,412,"for drug smuggling."],[462,554,"We need all three of you"],[554,625,"to come with us."],[750,850,"Hey, what the hell"],[850,917,"do you think you're doing?"],[917,975,"Hands off!"],[975,1067,"I'm pregnant!"],[1071,1188,"Hold off on her transfer."],[1217,1297,"She gets a delay."],[1305,1393,"Take the other two in."],[1480,1522,"Hey."],[1543,1634,"Get your hands off me."],[1643,1693,"Stop!"],[1701,1764,"Ow!"],[1818,1889,"Get off me!"],[2006,2106,"Jonathan Blackwood,"],[2156,2248,"you broke my heart"],[2248,2369,"and now you're locking me up?"],[2469,2565,"You'll regret this."],[2623,2719,"This isn't over."],[4621,4700,"Hey, watch out."],[5075,5155,"All right, come on."],[5180,5338,"Lila, you just saved the day."],[5409,5563,"I'm gonna take you two shopping."],[5597,5718,"Yay! - Yay!"],[5759,5822,"Let's go."]],"51":[[1146,1222,"All right, kiddos,"],[1247,1313,"let's go home."],[1313,1372,"Yes."],[1401,1459,"That's cool."],[2702,2786,"Hmm,"],[2786,3098,"something under the seat feels weird."]],"52":[[337,404,"Daddy,"],[513,654,"something's under the seat."],[688,796,"It's poking me."],[859,942,"It hurts."],[975,1055,"Miss Lila,"],[1055,1226,"I just swapped the cushions."],[1226,1301,"There shouldn't be anything"],[1301,1363,"under there."],[1368,1551,"There is, Uncle Ethan."],[1572,1655,"I'm not lying."],[1760,1818,"Daddy,"],[1901,2006,"I don't want this car."],[3511,3716,"I wanna ride that home."],[4287,4362,"The scooters?"],[4404,4642,"Lila, let's just wait till we get home,"],[4642,4696,"okay?"],[4704,4884,"No, I want it now."]],"53":[[162,216,"Dad,"],[241,425,"I wanna ride the scooters with Lila."],[433,629,"Come on, just this once."],[650,709,"Well, look at you,"],[709,817,"sticking up for your sister."],[1005,1138,"You really want this scooter, don't you?"],[1222,1284,"Mm-hmm."],[1413,1643,"Well, all right, scooter it is."],[1705,1843,"Ethan, let's go."],[2410,2464,"What?"],[2569,2648,"They're getting out."],[2740,2815,"Hurry, hurry."],[2840,3007,"Let's go get scooters."],[3023,3128,"You know, Miss Lila,"],[3174,3253,"it'll take hours"],[3253,3374,"to get home by scooters."],[3436,3536,"Sir, you have that meeting"],[3536,3611,"in twenty minutes,"],[3611,3666,"remember?"],[3678,3787,"Oh my God, you're right."],[3845,4045,"Lila, I promise we'll do this"],[4045,4124,"next time, okay?"],[4133,4179,"Exactly."],[4179,4262,"There is plenty of time"],[4262,4358,"to ride scooters later."],[4358,4483,"Let's just head back to the car."]],"54":[[0,62,"All right, let's go."],[150,262,"I don't want the car."],[358,483,"I want the scooter."],[546,667,"You almost never dig in like this."],[821,875,"You know what?"],[884,1059,"Okay, scooters it is."],[1092,1188,"Let's go on scooters."],[2844,2902,"Sir,"],[2919,2973,"the car."],[3499,3603,"So, Lila."],[3720,3841,"Wait, did Lila just save us"],[3841,3962,"from the explosion?"],[4049,4120,"Oh my God."],[4183,4245,"Lila."],[4320,4379,"Tell me,"],[4400,4446,"did you know"],[4446,4500,"there was something wrong"],[4500,4562,"with the car?"]],"55":[[25,62,"Did you know"],[62,125,"there was something wrong"],[125,187,"with the car?"],[266,421,"It felt weird."],[487,608,"I wanted to get out."],[650,809,"Lila, you saved us again."],[967,1138,"You really are our lucky star."],[1238,1305,"What the hell?"],[1459,1564,"They got out in time?"],[3395,3453,"What?"],[3516,3670,"They survived the explosion?"],[3699,3841,"How is that even possible?"]],"56":[[20,95,"Lila, tell me."],[137,233,"What did you see?"],[258,437,"There was a weird guy"],[533,629,"hiding back there."],[921,971,"Ethan,"],[1009,1046,"go!"],[1051,1113,"I'm on it."],[1422,1514,"Okay, look, look, look."],[1547,1593,"Hey,"],[1626,1726,"who's behind this?"],[1751,1818,"It wasn't me."],[1910,2022,"I was hired, okay?"],[2027,2122,"By who?"],[2214,2318,"You better start talking"],[2318,2477,"or I'm calling the cops right now."],[2606,2731,"Vivienne Fairchild and,"],[2819,2902,"Harold Sinclair."],[3098,3169,"You turn him"],[3190,3269,"and all the other evidence"],[3269,3332,"to the police."],[3332,3478,"I want all of them to pay."],[3528,3603,"Yes, sir."],[3641,3687,"Let's go."]],"57":[[667,734,"All right, you two."],[771,838,"Scooter time."],[838,896,"Let's go."],[930,1005,"Hop on, pilot."],[1038,1251,"I'm kinda scared."],[1284,1359,"Don't be."],[1380,1418,"Here."],[1459,1539,"My mom's charm."],[1551,1739,"If you wear it, it'll protect you."],[2806,2861,"Noah,"],[2919,3161,"I saw one like this in Vivienne's room."],[3194,3261,"No way!"],[3265,3390,"My mom made these."],[3432,3545,"Mine and hers."],[3566,3774,"Hers got lost in the car crash."],[4024,4170,"If Vivienne has Anna's pendant,"],[4170,4229,"then..."],[4500,4658,"the car crash wasn't an accident."],[5334,5551,"Ethan, reopen Anna's case."],[5659,5755,"We just found a new lead."]],"58":[[358,412,"Damn it."],[425,513,"Useless."],[542,721,"You couldn't even blow up one car?"],[800,980,"And you left a trail straight back to us."],[980,1063,"It wasn't my fault."],[1088,1255,"It was that little brat, she wrecked it."],[1338,1468,"I'll finish the job myself."],[1472,1530,"How?"],[1555,1697,"Our hitman is in custody."],[1697,1910,"I bribed the guards for a key."],[2022,2210,"We run, grab the girl,"],[2243,2452,"and then snap her little devil neck, huh?"],[4450,4583,"We’re home free!"],[4675,4725,"What?"],[4725,4788,"Son of a..."],[4829,4904,"Come on. - What?"],[4934,5000,"Harold!"],[5000,5050,"This is a fucking"],[5050,5125,"joke! - Show's over!"],[5176,5280,"You're not getting out of here."],[5280,5351,"Don't you touch me."],[5409,5551,"Ms. Fairchild, do something!"],[5551,5601,"What?"],[5613,5764,"I wasn't anywhere near that bomb."],[5860,5968,"You recognize this?"],[6168,6348,"We found it in your room."]],"59":[[8,137,"We found it in your room."],[246,379,"What is this cheap trinket?"],[483,558,"You can't prove anything"],[558,650,"with this. - Cut the act!"],[746,863,"Your DNA's all over it."],[925,980,"Tell me,"],[1071,1172,"what did Anna ever do to you"],[1172,1317,"to justify taking her life?"],[1910,2027,"I hated Anna."],[2156,2314,"I hated that she came from nothing"],[2339,2523,"and still shone brighter than me."],[2581,2748,"I hated that she was talented."],[2882,2998,"But I really hated"],[3065,3315,"that you picked her, not me."],[3411,3503,"So you paid someone"],[3503,3599,"to run her down,"],[3707,3899,"and left her to die in a ditch?"],[3899,3974,"So what?"],[4024,4095,"Without her,"],[4129,4212,"you would have loved me"],[4212,4291,"eventually."],[4396,4471,"You should have seen"],[4471,4600,"the way she begged me"],[4600,4783,"not to hurt Noah with her last breath."],[4783,4838,"Shut up."],[5388,5559,"Go on, shoot."],[5659,5764,"If I can't have you,"],[5793,5972,"we can rot in prison together."],[6239,6414,"Mr. Blackwood, don't."],[6585,6664,"Not like this."]],"60":[[529,700,"I'm not gonna stain my hands with this."],[842,925,"I'll do worse."],[1009,1247,"You're gonna rot in prison alone"],[1334,1463,"until the day you die."],[1568,1672,"You heard Mr. Blackwood."],[1672,1751,"Take them away."],[1780,1889,"No, no!"],[1935,2022,"Jonathan!"],[2077,2256,"If they give me a plea bargain I'll take it,"],[2256,2335,"please!"],[2369,2448,"Please, I can't."],[2602,2681,"You did the right thing."],[3424,3520,"Anna, I'm sorry."],[3745,3899,"I swear I'll make them pay."]],"61":[[200,354,"Fairchild Group has declared bankruptcy"],[354,479,"following smuggling charges."],[500,588,"The heiress, Vivienne,"],[604,696,"faces a life sentence"],[696,763,"for murder."],[792,925,"The Sinclairs have also been indicted"],[925,1051,"on child abuse charges."],[1071,1159,"Mr. Blackwood! - Mr. Blackwood!"],[1159,1213,"Mr. Blackwood,"],[1222,1305,"our sources say"],[1305,1426,"that you cracked the case"],[1426,1514,"and that your adopted"],[1514,1609,"daughter Lila"],[1609,1705,"found the key evidence."],[1714,1881,"Will Lila help solve more crimes?"],[1981,2085,"Lila's just a kid,"],[2114,2214,"just like anybody else."],[2264,2360,"You know what, can you do me a favor?"],[2360,2444,"Can you please give Lila"],[2444,2515,"some space?"],[2544,2640,"Are you doing all of this"],[2640,2719,"just to keep your title"],[2719,2844,"as the richest man in the country?"],[2982,3044,"Do I have to?"],[3123,3194,"Please, excuse me,"],[3219,3324,"I have to get to my kids."],[3353,3465,"Sir, just a few more questions."],[3486,3553,"Just another question."],[3553,3682,"Please, no more further questions."],[3707,3762,"Thank you."],[4612,4717,"Dad, you're home!"],[4746,4975,"Daddy, we saw you on TV."],[5055,5121,"You were like,"],[5171,5276,"a superhero."],[5380,5513,"That's only because"],[5613,5718,"you're my lucky star."],[6043,6101,"Dad, look!"]]}