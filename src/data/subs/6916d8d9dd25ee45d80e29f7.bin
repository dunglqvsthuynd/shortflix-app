[6819,6981,"Friends take sides in divorces,"],[6981,7148,"so I don't trust him for a second."],[7265,7486,"I have the feeling that he's"],[7486,7657,"obsessed with you, Claire."],[7745,7941,"I think he always was,"],[7941,8074,"and maybe that's the reason why he"],[8074,8204,"moved back to the States."],[8458,8746,"Really? Yes, yes, yes, yes!"],[8771,8829,"You think a billionaire"],[8829,8933,"came back for me?"],[8967,9046,"A waitress?"],[9129,9234,"What kind of fairy tale is this,"],[9234,9296,"Maid in Manhattan?"],[9367,9488,"Girl, anything is possible."],[9517,9734,"Okay, please promise me you won't"],[9734,9893,"blow off a billionaire."],[9947,10072,"For God's sake."],[10610,10694,"Hey, ladies."],[10752,10860,"Do you need a ride?"]],"20":[[25,154,"No, that's okay. Maggie's-"],[154,279,"She does need a ride."],[396,734,"If I drive her, it would just be a"],[734,850,"really big burden."],[938,1042,"You said it was fine."],[1042,1242,"Go with this nice gentleman, Claire."],[1326,1497,"Please be sure to enjoy the handcrafted"],[1497,1889,"leather interior and that panoramic moonroof."],[1922,2040,"-Please! -Hey!"],[2510,2673,"You know, Maggie"],[2673,2761,"was always a little bit"],[2844,2944,"eccentric."],[2998,3107,"In a good way."],[3303,3370,"I thought"],[3370,3507,"billionaires have drivers."],[3616,3770,"I do. I have a driver."],[3807,3874,"Yeah?"],[3895,4087,"He's in the trunk."],[4433,4679,"Please, come with me."],[7098,7215,"When was the last"],[7215,7357,"time we sat together?"],[7399,7549,"Summer, 2017."],[7653,7828,"How do you remember that?"],[7962,8024,"I don't think that"],[8024,8170,"I could ever forget."],[8337,8400,"Oh!"],[8500,8612,"Yes, because you were on"],[8612,8717,"the soccer team."],[8750,8896,"And you broke your arm."],[8896,9146,"And I felt so bad for you."],[9180,9225,"And..."]],"21":[[838,932,"Uh..."],[1042,1160,"We should go."],[2181,2306,"Thank you for the ride."],[2873,2927,"Claire!"],[3015,3087,"Hey."],[3820,3920,"Why don't you come work for me"],[3920,4033,"at my company?"],[4087,4141,"I mean, listen,"],[4141,4250,"you are always so smart."],[4433,4571,"I'm sure that we can find something"],[4587,4792,"that you would like to do, and"],[4871,4959,"you'd love it."],[4988,5117,"Do you have a problem with me"],[5117,5234,"being a waitress?"],[5342,5430,"No, no, no."],[5518,5622,"Listen, it's just that, uh..."],[5659,5734,"Wait."],[5801,5980,"Did Miles ask you to do this?"],[6218,6327,"Because he's embarrassed"],[6364,6477,"that his ex-wife is working"],[6477,6560,"in a bar?"],[6577,6744,"No, no, Claire."],[6902,7152,"I care about you, and I want you-"],[7152,7294,"And you're a billionaire."],[7428,7511,"And?"],[7912,8091,"You look down on people like me."],[8091,8204,"No, I don't."],[8224,8358,"Your fancy car?"],[8391,8566,"It costs more than a house."],[8646,8782,"Well, I work my ass off"],[8782,8929,"for 50 bucks a day."],[9188,9342,"You're the Dominic Bridges,"],[9342,9467,"and I'm nobody."],[9651,9780,"So let's just keep it that way, okay?"],[9893,10072,"I don't wanna see you again."],[10689,10777,"Claire."],[10856,10965,"Wait, Claire!"]],"22":[[1363,1488,"Shoot."],[1710,1830,"I forgot to tip."],[2327,2560,"Hey, how's the deal with the bar coming?"],[2706,2794,"You got it."],[2844,2944,"But we did have to pay"],[2944,3073,"double the comp value."],[3182,3269,"Whatever."],[3311,3478,"Sir, if you don't mind me asking,"],[3645,3807,"what is so special about this bar?"],[3899,4054,"There's a very special woman."],[4170,4233,"That's..."],[4421,4508,"You know what?"],[4508,4633,"Let's go this afternoon."],[4779,4859,"Excuse me."],[5113,5188,"Hello?"],[5226,5347,"Hello, James?"],[5518,5709,"Hey, it's Claire."],[5801,5955,"Newton..."],[6026,6131,"I just..."],[6197,6372,"I wanted to say that I had a really"],[6372,6468,"fun time with you."],[6468,6679,"Great time last night. And..."],[6727,6898,"I know that Maggie already paid you,"],[6919,7068,"but I just, I wanted to"],[7068,7132,"give you a tip."],[7211,7447,"Or I mean, I'm not really sure"],[7447,7590,"how these things work."],[7678,7953,"It's my first time being with an escort or"],[8037,8137,"a call boy."],[8308,8495,"Sorry, a personal assistant."],[8637,8779,"Do you have a Zelle?"],[9138,9205,"Hello?"],[9463,9617,"Alright, forget the tip."],[9813,9930,"What the hell?"],[10143,10256,"What was that?"]],"23":[[62,187,"What was that?"],[237,357,"I don't know, some woman calling"],[357,501,"about tipping a call boy."],[529,617,"Seemed like a scam, they were"],[617,709,"probably about to ask me for my"],[709,863,"credit card number or something like that."],[913,1055,"Did she say her name?"],[1159,1226,"Yes."],[1584,1693,"Newsome?"],[1776,1860,"Newton?"],[1939,2047,"Yeah."],[2097,2235,"How do you know that?"],[2281,2435,"She remembers me."],[2581,2631,"Hmm."],[2681,2857,"She remembers our night."],[2932,3115,"Your night together?"],[3257,3324,"Huh."],[3357,3461,"Oh my god, you..."],[3570,3661,"You are the call boy."],[3661,3732,"Enough."],[3778,3873,"For God's sake."],[3887,3978,"Sorry, sorry, I just..."],[4241,4441,"Didn't expect my billionaire boss"],[4441,4642,"to be moonlighting as a call boy."],[4667,4758,"Okay."],[4838,4917,"Thanks."],[4950,5100,"Don't push it."],[6001,6197,"She was thinking of tipping me?"],[6285,6439,"Then I guess I did an okay job."],[6660,6802,"Come on, let's go."]],"24":[[346,471,"Hey you, this bar's"],[471,604,"been acquired by a rich guy,"],[629,746,"which means this place needs"],[746,842,"to be spotless."],[913,1051,"Like a mirror."],[1092,1259,"To make a great first impression."],[1326,1438,"Get on it."],[1480,1555,"Tate, I just"],[1555,1676,"cleaned the entire place."],[1676,1810,"I did the windows and the floors too."],[1960,2068,"Then do it better."],[2127,2239,"Team players, Claire!"],[2277,2422,"This bar needs team players."],[2477,2569,"Are you on the team?"],[2598,2698,"Or do you want to check today's"],[2698,2798,"help wanted section?"],[2966,3103,"Thanks, Tate."],[4813,5004,"A $5,000"],[5004,5155,"bottle of wine has gone missing."],[5180,5259,"What?"],[5351,5505,"The 2006 Palermo Blunt?"],[5526,5622,"You moved the box."],[5668,5759,"Where is it?"],[5759,5851,"It's right here."],[6535,6623,"That's impossible."],[6623,6740,"I'll give you one chance to"],[6740,6873,"put the bottle back, Claire."],[7002,7102,"You think that I did it?"],[7178,7385,"I didn't steal your damn wine bottle, Tate."],[7425,7506,"No?"],[7507,7553,"No!"],[7553,7645,"Then, show me your bag."],[7670,7757,"Gladly."]],"25":[[141,228,"Mm-hmm?"],[542,658,"Don't tell me."],[709,821,"It wasn't me!"],[846,967,"Yeah! You did it!"],[1000,1163,"You're fired."],[1247,1359,"Oh, hey."],[1359,1447,"Hey."],[1518,1668,"What are you doing here?"],[1701,1860,"Oh, you know, I'm just..."],[1906,2006,"getting a drink."],[2039,2081,"Yeah."],[2152,2293,"What are you doing here?"],[2302,2485,"Oh, you're drinking at noon."],[2535,2606,"Yeah."],[2711,2944,"I'm just here to check on my wife."],[3011,3194,"Cool. See you later."],[3411,3534,"Okay, I need you to make sure that"],[3534,3635,"nobody knows I’m the new owner"],[3635,3691,"of this bar."],[3691,3791,"Can you do that?"],[3874,3933,"Okay."],[4191,4258,"No, I won't be"],[4258,4350,"railroaded like this."],[4375,4425,"Oh no?"],[4425,4479,"No."],[4479,4604,"Then how about I call the police?"],[4604,4729,"We'll see what they have to say about it."],[4750,4817,"You wouldn’t dare."],[4817,4917,"Oh, try me."]],"26":[[0,179,"I will not be railroaded like this."],[208,241,"Oh no?"],[262,291,"No."],[312,437,"Then how about I call the police?"],[437,487,"We'll see what they"],[487,558,"have to say about it."],[558,638,"You wouldn't dare."],[658,850,"I swear to god. People like you"],[850,975,"will do anything for money."],[1272,1343,"Excuse me."],[1376,1434,"Hi."],[1472,1564,"Who the hell are you?"],[1651,1810,"He's the new boss, idiot."],[1976,2044,"What the fuck?"],[2248,2402,"Is this some kind of a prank?"],[2439,2615,"No. Okay, it's not what you think."],[2656,2752,"Really?"],[2802,2977,"Because I told you to stay out of"],[2977,3111,"my life, Dominic."],[3178,3261,"And now you bought the bar"],[3261,3332,"that I worked at?"],[3332,3495,"No. No. Okay, it has nothing to do"],[3495,3636,"with that. This is strictly business."],[3799,3916,"You want me to believe that?"],[3999,4120,"You're playing me, Dominic."],[4120,4237,"Both of you are!"],[4237,4358,"I'm not playing you."],[4512,4587,"You know what?"],[4683,4788,"You want someone to wait tables at"],[4788,4975,"your bar? Have your bro do it."],[4975,5046,"I quit."],[5751,5889,"You see? That's why I was"],[5889,5997,"calling the police."],[6010,6214,"People like Claire are good for nothing."],[6214,6443,"Lying egotistical, manipulative."],[6493,6652,"If you ever mention her name again,"],[6677,6790,"I'm gonna make sure you get put in"],[6790,6965,"the meat locker and sliced up for"],[6965,7111,"happy hour. You got it?"]],"27":[[79,546,"Okay. I apologize. I'll never mention Claire."],[721,980,"Her name... again."],[1042,1284,"Now you can see your sorry ass out"],[1284,1497,"and never show your face"],[1497,1714,"around here ever again."],[2694,2841,"I'm sorry for my big mouth."],[3136,3240,"You didn't want her to know that"],[3240,3370,"you bought the bar, right?"],[3411,3636,"No. I didn't."],[4012,4104,"Is she the one that"],[4104,4441,"called me and tipped me? You?"],[4600,4913,"But she's your friend from college."],[5050,5271,"And she's also your best friend's ex-wife."],[5271,5405,"You say one more word,"],[5472,5576,"and you're fired."],[7394,7595,"Hi, Doctor!"],[7962,8095,"Okay, okay. I'll be right there."],[8095,8208,"Thank you. Thank you so much."],[8341,8416,"Claire."],[8491,8758,"No. No. If you take one more step"],[8758,8842,"towards me, I will file a"],[8842,8971,"restraining order against you, Miles."],[9000,9150,"What? I'm your husband."],[9180,9526,"No, you were! You WERE my husband!"]],"28":[[279,358,"How is she?"],[383,496,"We had a situation."],[521,700,"Her vitals were dangerously low,"],[700,863,"but she's stable now."],[1051,1142,"Thank God."],[1297,1450,"If this happens again,"],[1530,1718,"I'm not sure she can make it."],[2031,2135,"No,"],[2235,2356,"you said one year."],[2439,2615,"If she wants to live,"],[2690,2886,"but if she feels that she has"],[2886,3015,"nothing to live for,"],[3336,3500,"it's really up to her."],[3928,4062,"How you feeling today, Grandma?"],[4112,4212,"Tired."],[4212,4283,"Oh."],[4325,4404,"Hey."],[4446,4617,"I brought you"],[4704,5004,"sushi from Masako."],[5096,5230,"It's your favorite rolls."],[5263,5417,"Thank you, sweetheart."],[5497,5605,"Maybe later."],[5790,5955,"You know, I haven't seen Miles"],[5955,6122,"in a really long time."],[6122,6247,"Is he okay?"],[6339,6406,"Yeah."],[6468,6539,"Yeah, yeah."],[6539,6819,"He's just busy."],[6955,7050,"I'm sorry."],[7085,7265,"I have to lie to you, Grandma."],[7382,7557,"I have some good news."],[7703,7778,"I'm pregnant."],[7778,7995,"Oh my God!"],[8108,8216,"Oh my God!"],[8245,8350,"Oh, my little baby."],[8350,8546,"Claire is gonna be a mama!"],[8725,8938,"That is the best news."]],"29":[[25,229,"Oh my god! Oh, my little baby."],[229,404,"Claire is gonna be a mama!"],[625,792,"That is the best news!"],[850,975,"Finally, I'm just..."],[1076,1384,"I'm so excited to meet the baby."],[1459,1514,"Yes!"],[1514,1614,"And everything."],[1701,1839,"You know what? Maybe I will have"],[1839,1960,"some sushi after all."],[1960,2043,"Yeah!"],[2064,2202,"Okay. Yeah."],[2402,2577,"Oh, it fell apart"],[2577,2706,"but it's just as good."],[3098,3194,"You are the best."],[3274,3374,"Thank you."],[4191,4262,"I have no choice."],[4316,4433,"I have no choice."],[4542,4662,"Okay."],[5501,5597,"Mr. Scott."],[5701,5864,"It's her. Miss Newton."],[5901,5997,"Put her on the speaker."],[6039,6118,"Hello."],[6227,6339,"Miss Newton."],[6410,6581,"Hi. Um..."],[6723,6865,"I would... I would like..."],[7006,7223,"to see you again."],[7390,7486,"What?"],[7716,7786,"Tonight?"],[7816,7907,"Every night."],[8099,8233,"Every night."],[8299,8412,"For how long?"]],"30":[[100,333,"I'm sorry, um, you-"],[333,500,"you sound a little different."],[588,829,"This is James Goodwin, isn't it?"],[871,963,"Personal assistant, say that you're"],[963,1046,"a personal assistant."],[1088,1384,"I'm the personal assistant to..."],[1576,1651,"Matt Scott."],[1726,1868,"You can speak to me."],[1914,2114,"Matt Scott? That's his real name?"],[2206,2293,"Even a call boy"],[2293,2406,"has an assistant now."],[2477,2565,"Interesting."],[2698,2923,"Okay, yeah. Hi."],[2998,3319,"Uh, if you could tell your boss"],[3449,3799,"that I would like him to come to my"],[3799,4220,"house on Spring Street every night."],[4337,4579,"Until I am pregnant."],[4767,4979,"Um, of course, you know, Matt will"],[4979,5117,"have nothing to do with the baby"],[5117,5213,"once he's born, and this is a"],[5213,5342,"completely confidential agreement."],[5401,5576,"We'll sign the paperwork."],[5701,5955,"I'll give him two days to consider."],[6131,6189,"Yes."],[6381,6473,"Uh, sorry?"],[6473,6694,"We'll do it. He'll do it."],[6723,6940,"Are you sure? You don't"],[6940,7108,"have to ask him first?"],[7198,7520,"Miss Newton, I am Mr. Scott's"],[7520,7782,"personal assistant and his agent."],[7866,7999,"I can make these decisions for him."],[7999,8170,"In fact, Miss Newton, you have made"],[8170,8329,"a fantastic choice."],[8491,8767,"He has great genes. Top of the line"],[8767,8967,"DNA. He even has a master's degree"],[8967,9104,"from an Ivy League school."],[9213,9342,"I think you'll be very impressed"],[9342,9463,"with his performance,"],[9651,9834,"body, baby."],[10168,10293,"Alright."],[10314,10543,"There's just one condition."],[10656,10944,"Yeah, it's just, uh, this is an"],[10944,11165,"exclusive agreement."],[11165,11411,"I will be his only client"],[11540,11649,"until,"],[11732,11886,"you know,"],[11957,12099,"mission accomplished."]],"31":[[75,187,"It's settled then."],[246,404,"It's an exclusive deal."],[462,525,"Okay."],[621,788,"Uh, Miss Newton,"],[788,909,"can you hold on one second?"],[984,1105,"Uh, yeah."],[1234,1388,"Are you forgetting something?"],[1618,1789,"She knows who you are."],[1901,1976,"What's she gonna"],[1976,2143,"say when you see her?"],[2235,2381,"I don't want to see you again."],[2515,2569,"Oh, God."],[2590,2744,"Okay, I gotta call it off then."],[2798,2861,"Don't call it off."],[2952,3123,"Say, say that we"],[3123,3236,"have a condition too."],[3361,3440,"Okay."],[3586,3678,"Um, Miss Newton."],[3699,3795,"Yes, yes."],[3795,3937,"Sorry for the delay. I failed to"],[3937,4108,"mention that my client"],[4200,4329,"also has a condition."],[4542,4642,"What is it?"],[4671,4875,"Can't wear glasses or contacts."],[4925,5142,"That you cannot wear"],[5142,5342,"glasses or contacts."],[5422,5547,"Uh, huh?"],[5601,5847,"Because he's shy."],[6001,6197,"And he doesn't want"],[6197,6310,"to be seen clearly."],[6423,6598,"Uh, well, as long as"],[6598,6744,"he gives me what I want."],[6852,6977,"A baby."],[7269,7394,"Uh, we're all set then."]],"32":[[300,433,"What are you doing, Claire?"],[500,704,"Oh, Dominic, what are you doing?"],[771,896,"Boss."],[913,1042,"Feelings for Miss Newton?"],[1138,1397,"Yes. Okay, she is the"],[1397,1526,"only one that I love,"],[1526,1622,"and she's also going to be"],[1622,1747,"the last one that I love."],[1872,2010,"I might be overstepping my"],[2010,2168,"boundaries by saying this, but..."],[2252,2469,"Why don't you just tell her the way"],[2469,2594,"you feel about her?"],[2615,2844,"Because she hates me."],[3115,3313,"You know what? I have a plan."],[3345,3566,"I want you to go buy a house in"],[3566,3720,"the same neighborhood as her"],[3782,3953,"right next to where her house is."],[3953,4037,"Can you do that?"],[4120,4237,"Yes, sir."],[4650,4817,"I can't see anything clearly again."],[4996,5150,"Why didn't he want me to see him?"],[5355,5518,"Mysterious call boy."],[6060,