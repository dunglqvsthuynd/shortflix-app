king name of"],[3990,4080,"the college is."],[4107,4194,"I'm gonna divorce"],[4194,4254,"her for a"],[4254,4330,"single month."],[4457,4617,"Yeah? So what?"],[4751,4881,"I'm hotter than her."],[4941,5065,"Oh, you know it."],[5105,5238,"The company is preparing"],[5238,5398,"for an IPO next month."],[5402,5515,"Before that,"],[5515,5645,"find a way to buy back"],[5645,5755,"the shares from your wife."],[5762,5852,"Listen,"],[5909,5959,"My company's"],[5959,6022,"going public."],[6152,6239,"And during this"],[6239,6319,"time, I think"],[6319,6436,"it's better if we"],[6436,6563,"had some space."],[6626,6656,"What are you"],[6656,6816,"talking about?"],[6816,6876,"I came to her"],[6876,6966,"because of you."],[7043,7080,"And now you're"],[7080,7163,"like, oh, I'm"],[7163,7197,"going to"],[7197,7253,"my family."],[7357,7397,"Are you"],[7397,7460,"playing me?"],[7497,7741,"Yes. Yes, we're"],[7741,7767,"playing"],[7767,7821,"each other."],[8264,8588,"Well, IPO, huh?"],[8738,8825,"So that means"],[8825,8882,"you're gonna"],[8882,8925,"become"],[8925,9039,"super rich."],[9179,9472,"Listen, after IPO, we're not"],[9472,9526,"gonna have any"],[9526,9572,"more work."],[9639,9666,"We can"],[9666,9729,"marry then."],[9826,9889,"And I promise"],[9889,10026,"when we do so,"],[10060,10076,"it's"],[10076,10136,"gonna be okay."],[10467,10573,"Well, you just"],[10573,10640,"promise you're"],[10640,10734,"gonna keep out of"],[10734,10827,"trouble during"],[10827,10890,"this period."],[10967,11041,"Yes sir."],[11384,11584,"Hey, Diana, I need you."],[11708,11768,"What happened?"],[11805,11885,"Liam and I"],[11885,11985,"are getting a divorce."],[12102,12252,"Lucy, I really want to help"],[12252,12512,"but I haven't dealt with a divorce case in years."],[12599,12696,"I know but"],[12726,12846,"you're the only one"],[12846,12942,"I can trust."],[12942,13006,"Year, but..."],[13006,13079,"Hey!"],[13079,13286,"Could you have look at this I send you."],[13316,13380,"Please?"],[13433,13586,"Before you make a decision"],[14094,14130,"Oh!"],[14487,14674,"My own marriage is a complete mess."],[14714,14808,"Six years of marriage"],[14808,14974,"and I've gone from a shining star,"],[15018,15248,"the youngest top divorce lawyer in New York,"],[15275,15402,"to a desperate housewife"],[15402,15532,"obsessed with revenge."],[15628,15722,"What changed me?"],[16476,16606,"Why are you up so early?"],[16606,16793,"School hasn't started yet."],[16793,16940,"I was checking my stocks."],[17003,17143,"Wait, you trade stocks?"],[17267,17374,"I'm getting some McDonald's."],[17374,17440,"Do you want some?"],[17507,17670,"No, I don't eat breakfast."],[17881,18011,"“The founder of CC Coin"],[18011,18161,"wants to discuss a new community."],[18161,18314,"Are you free to meet?”"],[18381,18478,"Oh, but what do you want"],[18478,18541,"to eat for dinner?"],[18598,18671,"We should celebrate."],[18818,18875,"Celebrate what?"],[18955,19079,"Well, I heard you"],[19079,19209,"got the scholarship"],[19209,19379,"for the computer science thing."],[19419,19562,"That's not easy to get."],[19562,19656,"We should celebrate that."],[19733,19873,"That little program I wrote for fun"],[19873,20009,"that got me a full ride,"],[20009,20143,"I don't even need the money."],[20273,20346,"So what do you want to eat?"],[20487,20570,"I never thought someone"],[20570,20717,"would celebrate these small things."],[20750,20857,"My mom would never do that."],[20907,21054,"I'm cool with anything."],[21114,21177,"Okay."],[21177,21321,"I'll figure something out."],[21401,21448,"That's..."],[21494,21564,"That's not healthy."],[21634,21671,"You should..."],[21795,21881,"I got you a burger."],[22242,22442,"Listen about yesterday."],[22639,22692,"Excuse me!"]],"6":[[33,96,"So,"],[176,363,"the genius IT boy."],[550,617,"Yes, your mom's"],[617,784,"told me all about you."],[987,1111,"Is that so..."],[1284,1408,"Seems like my best friend"],[1408,1628,"told you more than I did."],[1654,1688,"Interesting."],[2419,2719,