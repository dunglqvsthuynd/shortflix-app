m as an excuse to maybe"],[2258,2372,"bump into her now"],[2372,2409,"and then."],[2505,2709,"I never dreamed."],[2709,2806,"I have spare room."],[2836,2896,"You know."],[2896,3069,"We need to go to take care of Leo."],[3086,3113,"so..."],[3206,3380,"How about you come to my place?"],[3426,3463,"Wait."],[3503,3556,"What?"],[3573,3613,"Why?"],[3656,3790,"It’s really kind of you, but we don't need"],[3790,3860,"Sure."],[3860,3940,"Leo."],[3940,4217,"I have no idea what this woman is up to..."],[4234,4371,"Why not?"],[6156,6209,"No,"],[6209,6393,"this isn't going according to plan."],[6563,6656,"Hey Diana!"],[6716,6853,"Could you bring me a towel?"],[6853,6936,"I forgot one!"],[6976,7053,"What are you"],[7053,7143,"trying to do?"],[7300,7370,"The towel"],[7370,7460,"and your underwear."],[7460,7517,"They are already"],[7517,7594,"on your bed."],[7624,7711,"Oh, I'm sorry."],[7711,7811,"I didn't see them."],[7811,7871,"Could you, uh..."],[7904,7987,"Could you bring them here?"],[8068,8134,"Shit!"],[8498,8638,"I left the towel and"],[8638,8715,"underwear"],[8715,8785,"by the door."],[8868,8932,"Okay, you can"],[8932,8998,"leave them there."],[9032,9105,"You can go now."],[9359,9492,"Of course I saw them."],[9556,9693,"What were you expecting?"]],"4":[[180,323,"How am I gonna tell him"],[323,630,"that my son is living with his wife?"],[707,800,"Oh, it doesn't matter anyway."],[840,1027,"He came here to get them divorced."],[1127,1317,"I'm gonna take everything from her."],[1411,1508,"Let's do this."],[1638,1758,"You've got this."],[1888,1968,"Relax."],[3246,3306,"Kiss me."],[3720,3883,"What was I thinking just now?"],[5638,5825,"Would you be able to call my mom for me?"],[5892,6016,"Um... why?"],[6016,6099,"What's wrong?"],[6152,6433,"Um... I left my charger"],[6433,6669,"and my laptop bag at my mom's."],[6706,6800,"And my phone's dead."],[6800,6853,"I'm sorry."],[6953,7063,"Yeah, sure."],[8868,8978,"Your wife."],[11211,11251,"What the hell?"],[11474,11524,"Oh my god."],[1