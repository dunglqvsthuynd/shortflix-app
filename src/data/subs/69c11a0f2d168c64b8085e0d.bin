{"1":[[416,540,"I'm a sinner."],[540,630,"I am sleeping with"],[630,744,"my best friend's son."],[807,994,"I'm doing this for revenge."],[1044,1170,"Revenge against the woman"],[1170,1310,"who destroyed my marriage."],[1425,1515,"My best friend."],[1580,1668,"His mother."],[1720,1872,"And against my husband,"],[1872,2090,"who has long abused and gaslit me."],[2500,2652,"In the beginning we were happy."],[2675,2945,"I believed this gentleman-like man."],[2976,3133,"And I thought he would truly lead"],[3133,3365,"my life to a land of freedom and abundance."],[3400,3477,"Until..."],[3830,4025,"Of course I knew where he was going."],[4025,4205,"I've known since our wedding day."],[4865,4978,"That stupid bitch."],[5281,5395,"Long time no see."],[5395,5525,"You look stunning?"],[5535,5765,"Yeah, and so do you."],[5765,5866,"Look at your bag."],[5942,5995,"Look at that."],[5995,6166,"Rock on your finger."],[6166,6279,"It's brighting me."],[6339,6569,"All bought with our marital assets"],[6569,6653,"I presume!"],[6653,6797,"What about Victor?"],[6797,6900,"He didn't come."],[6923,7004,"What a pity!"],[7023,7200,"Yeah. Why is that pity?"],[7263,7457,"I haven't seen him so long."],[7500,7578,"Guess what?"],[7637,7860,"I'll be with him tonight."],[7897,7984,"Of course, bitch."],[8007,8144,"Oh, what happened here?"],[8375,8542,"I... bumped into something"],[8705,8768,"Here you go."],[8845,8902,"Thanks."],[8978,9075,"Oh, Leo,"],[9075,9272,"I heard you got a full scholarship at"],[9272,9422,"NYU for computer science."],[9456,9550,"Congratulation!"],[10086,10236,"Revenge on a bitch like this?"],[10255,10340,"Simple."],[10493,10764,"You must be your mother's pride and joy."],[10887,11000,"I have a great idea."],[11071,11224,"I live close to campus"],[11224,11388,"and I have spare room."],[11411,11458,"You know."],[11458,11634,"And you need someone to take care of Leo"],[11634,11761,"while he's there,"],[11761,11915,"so how about you"],[11915,12105,"come and see my place?"],[12135,1