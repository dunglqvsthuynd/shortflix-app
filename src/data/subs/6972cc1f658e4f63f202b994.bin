{"1":[[900,1017,"He has the pilgrim gene."],[2002,2102,"I can not believe it."],[2152,2335,"After nearly 5 years of searching,"],[2335,2464,"we finally found the one!"],[2836,3028,"Wait, but he's only 17."],[3061,3199,"We'll need guardian's consent."],[3474,3516,"No need."],[3636,3762,"I turn 18 in three days."],[3795,3978,"You know, even with the Pilgrim gene,"],[3978,4120,"there's no guarantee you'll survive"],[4120,4275,"30 years in a coma."],[4333,4479,"Are you really ready to take that risk"],[4479,4579,"at your age?"],[4612,4763,"I mean, unless you know somebody else"],[4763,4921,"who not only has the gene,"],[4946,5038,"but is also trained in"],[5038,5188,"spacecraft operation"],[5251,5359,"and cybernetics."],[5467,5618,"I think I'm your best bet."],[5651,5697,"But it's not-"],[5697,5910,"Do you wanna save the human species"],[5968,6035,"or not?"],[6243,6352,"Hand me the forms."],[6506,6644,"And notify the pentagon."],[6644,6723,"We'll officially begin"],[6723,6810,"prepping for launch."],[7040,7198,"Wait, Timothy Snyder?"],[7265,7457,"As in the Snyder family's only son?"],[7499,7590,"If your sisters find out"],[7590,7665,"that I approved this,"],[7665,7749,"then I'm done for."],[7770,7937,"This entire lab is done for."],[7970,8066,"No, no."],[8074,8229,"You've got me confused with"],[8229,8362,"Matthew Snyder."],[8395,8475,"That right there,"],[8475,8717,"is the Snyder family's only son."],[8817,8888,"Me?"],[8933,9042,"I'm just a nobody."],[9071,9180,"I'm just an orphan."],[9205,9371,"The Snyder Family adopted me."],[9438,9522,"My sisters used to be"],[9522,9626,"my whole damn world."],[9688,9818,"The moment they found Matthew,"],[9818,9939,"I became an outsider."],[9989,10135,"No matter how hard I tried,"],[10193,10381,"there's no place for me anymore."],[10427,10527,"Miss Gianna Snyder,"],[10552,10652,"Project Hail Mary"],[10652,10844,"has been making headlines worldwide."],[10865,10973,"Time is of the essence"],[10973,11136,"for the survival of the human race."],[11177,11332,"Have you found the volunteer yet?"],[11332,11448,"The volunteer needs to"],[11448,11569,"possess a genetic trait"],[11574,11736,"that is one in a million."],[11786,11882,"Can you tell us more about"],[11882,11961,"Project Hail Mary?"],[12049,12137,"Project Hail Mary"],[12137,12274,"is the collective efforts"],[12274,12466,"of Snyder Labs, NASX,"],[12466,12566,"and world governments."],[12604,12683,"Snyder Labs"],[12683,12862,"is the provider of top of the line"],[12862,13017,"cryogenic sleeping pods."],[13071,13146,"With earth's decay,"],[13146,13329,"we must find a new planet"],[13329,13509,"to secure humanity's survival."],[13563,13697,"We need to send a volunteer"],[13697,13805,"across the stars,"],[13859,14014,"someone so genetically special"],[14014,14147,"that they are able to withstand"],[14147,14314,"years of medically induced coma."],[14401,14539,"Can you tell us more about your family?"],[14602,14723,"The Snyder family is"],[14723,14856,"the best that we've ever been."],[14956,15060,"We've been lucky enough"],[15060,15206,"to be reunited with our,"],[15248,15331,"dare I say,"],[15331,15477,"favorite brother, Matthew."],[15536,15619,"We consider ourselves"],[15619,15732,"very, very lucky."],[15807,15882,"Family was supposed"],[15882,15957,"to be forever,"],[15957,16262,"but I guess it was never meant to last."],[16303,16533,"So let me do one last thing for you all,"],[16587,16695,"and for all of mankind."],[16737,16904,"Um, I do have one request."],[16979,17062,"I just ask that you"],[17079,17204,"keep my identity a secret."],[17254,17325,"You don't wanna let"],[17325,17429,"your loved ones know"],[17538,17688,"so you can have a proper goodbye?"],[18455,18685,"I, I have nobody to say goodbye to."],[19077,19235,"Here's your death certificate."],[19285,19352,"Tomorrow,"],[19398,19552,"NASX will officially begin"],[19552,19715,"prepping for launch in three days."],[19794,19890,"I assure you,"],[19961,20186,"this will be kept strictly confidential."],[20207,20462,"In three days, I'll leave this all behind."],[20491,20653,"The Snyder family gave me love,"],[20720,20908,"and they gave me pain."],[20937,21029,"But at the end of the day,"],[21071,21158,"they raised me."],[21229,21363,"And this is how I repay them."]],"2":[[1017,1067,"It's done."],[1288,1455,"It's, it's finished."],[1463,1572,"Helena's eye."],[1689,1830,"She'll finally be able to see again."],[2444,2644,"NASX will pick you up in 20 minutes."],[2698,2761,"I have less than"],[2761,2894,"72 hours before launch."],[2923,3073,"Thank God I finished"],[3073,3190,"Helena's eyes in time."],[4959,5055,"You guys,"],[5088,5155,"you come with me"],[5155,5267,"to every single checkup."],[5321,5459,"Seriously, you're the best."],[5484,5559,"Of course."],[5559,5684,"You're our little brother."],[5722,5868,"Who else would we do it for?"],[5905,5968,"And at least you actually"],[5968,6047,"appreciate it,"],[6047,6177,"unlike someone"],[6177,6293,"who didn't bother to show up for the"],[6293,6431,"press conference yesterday."],[6473,6544,"Where are you going?"],[6544,6656,"Shouldn't you be in school?"],[6660,6798,"They didn't come to my graduation."],[6815,6919,"Of course they wouldn't know"],[6919,7136,"I already graduated top of my class."],[7173,7290,"You guys know I already-"],[7290,7461,"Now you're just what, skipping school"],[7461,7603,"like a fucking degenerate?"],[7603,7657,"Who even cares"],[7657,7786,"what he does with his life?"],[7791,7966,"Matthew, don't be like him, okay?"],[7966,8070,"Keep your grades up,"],[8070,8274,"go to college, make us proud."],[8333,8525,"I will, trust me."],[8587,8679,"We're taking Matthew"],[8679,8837,"to the hospital for a checkup now,"],[8837,8929,"but I can call someone"],[8929,9054,"to get you a ride to school."],[9079,9175,"You can't keep wasting"],[9175,9280,"your life away."],[9313,9463,"I'm not wasting my life."],[9547,9630,"I actually have a very important"],[9630,9705,"meeting today."],[9726,9905,"You have an important meeting?"],[10001,10068,"Yeah, right."],[10097,10231,"Timothy, you should really stop"],[10231,10326,"with the lies."],[10372,10648,"I can not help you if you won't try."],[10673,10773,"I mean, what do you plan to do"],[10773,10894,"with the rest of your life?"],[10902,11098,"And I heard that you're doing drugs,"],[11140,11211,"is that true?"],[11265,11319,"I swear to God,"],[11319,11498,"I will not tolerate a crackhead"],[11507,11624,"in the Snyder family."],[11649,11803,"No, I'm not doing drugs."],[11811,11891,"Who told you that?"],[12087,12145,"Was it Matthew?"],[12183,12358,"Why are you always blaming Matthew?"],[12437,12566,"We're all just trying to help you out."],[12566,12729,"Why are you always so ungrateful?"],[13175,13242,"Let's just go."],[13250,13325,"We're going to miss"],[13325,13459,"Matthew's appointment."],[13475,13596,"Oh, and let's not all forget"],[13626,13813,"why he has to go to these appointments,"],[13813,13918,"because somebody"],[13918,14168,"pushed him down the stairs."],[14422,14647,"Everything you have is mine now, brother."],[14964,15085,"Matthew so obviously"],[15085,15165,"framed me."],[15194,15290,"But my sisters won't believe"],[15290,15386,"a word I say."],[15990,16128,"You've changed, Timmy."],[16262,16387,"I'm really disappointed in you."],[17233,17367,"Maybe I'm not the one who changed."],[17467,17542,"Maybe you did."],[17713,17867,"It's whatever. I'll be gone soon anyway."],[19573,19715,"So you're the young gentleman"],[19715,19936,"who's tasked to save mankind."],[20020,20161,"My name is Ford McGee."],[20241,20407,"My job is to get you ready."],[20774,20862,"What are we waiting for?"]],"3":[[2010,2143,"His heart rate's over 180."],[2143,2227,"You've had him running"],[2227,2302,"for over two hours."],[2302,2364,"That's enough."],[2364,2527,"Hey, I want to test his limits."],[2527,2560,"Why?!"],[2560,2615,"He's passed"],[2615,2727,"every physical requirement"],[2727,2827,"with flying colors!"],[2827,2965,"Because running just isn't about"],[2965,3048,"physical fitness."],[3048,3219,"It's about mental endurance."],[3219,3328,"It's a mind game."],[3353,3465,"This will help him survive"],[3465,3566,"on a new planet."],[3670,3820,"Oh look, he's gonna break records today."],[3820,3887,"Nice."],[3899,4095,"Okay, just a few more minutes, son!"],[4095,4195,"You can do this!"],[4195,4300,"Keep going!"],[4650,4754,"Fucking degenerate."],[4754,4825,"Who even cares"],[4825,4921,"what he does with his life?"],[4950,4992,"I swear to God,"],[4992,5176,"I will not tolerate a crackhead"],[5176,5296,"in the Snyder family."],[5296,5372,"Don't give up."],[5430,5522,"Endure this."],[5563,5638,"Push through."],[5709,5805,"You're not a degenerate."],[5826,5951,"And time!"],[5976,6110,"Okay, son, you did it."],[6110,6227,"You broke records."],[6322,6427,"Whoa, hey."],[6456,6573,"Hey, what's wrong?"],[6660,6852,"I'm not a degenerate."],[6852,6940,"What?"],[6973,7090,"There's something wrong with him!"],[7090,7161,"Breathe, son."],[7186,7257,"I need,"],[7315,7419,"my inhaler."],[7449,7545,"He has asthma."],[7545,7603,"Hey, get him to"],[7603,7766,"Walter Reed hospital now!"],[7778,7862,"Call an ambulance!"],[7862,7982,"Oh, oh, stay with me, son."],[7982,8112,"Timothy, Timothy. - Hey!"]],"4":[[608,725,"Wait, is that Timmy?"],[838,913,"Timmy!"],[988,1105,"Timmy, what happened?"],[1105,1188,"Gianna."],[2089,2239,"Gianna, my legs!"],[2464,2619,"Matt, are you okay?"],[2940,3111,"Don't scare us like that."],[3315,3436,"Yo, what the hell is this?"],[3486,3620,"You know, you're such a snake."],[3620,3812,"You push him down the stairs."],[3812,3962,"Now he's in a wheelchair."],[3962,4045,"You come in with some"],[4045,4149,"fake-ass disease"],[4149,4229,"to get our attention?"],[4229,4462,"If you don't cut this shit out,"],[4471,4546,"I'm gonna make sure"],[4546,4688,"whatever this fake shit is,"],[4688,4754,"is real."],[5397,5622,"I never pushed him down the stairs."],[5622,5784,"I never pushed him down the stairs."],[5809,5880,"Shut up!"],[5893,5989,"Forget him!"],[6018,6156,"Let's get Matt to a doctor!"],[6218,6385,"Even if I died right here,"],[6468,6564,"they wouldn't care."],[6727,6806,"It's clear as day."],[6827,6940,"Compared to Matthew,"],[7007,7086,"I mean nothing."],[7749,7882,"Get him to the ER, now!"]],"5":[[175,354,"Timmy, don't scare us like that."],[429,563,"I'll bring in the best doctors."],[667,792,"Don't worry, you'll be fine."],[829,959,"This is all my fault."],[967,1134,"I should've been taking care of you."],[1743,1801,"Guys."],[2314,2419,"It was just a dream."],[2481,2598,"Mr. Timothy,"],[2631,2819,"you really scared me this time!"],[2844,3057,"Your asthma was so bad."],[3098,3211,"Please don't let yourself"],[3211,3395,"get so worked up again, okay?"],[3428,3595,"I'm, I'm fine, Miriam."],[3620,3691,"Really."],[3795,3908,"Three years ago,"],[3983,4149,"when the mansion caught on fire,"],[4208,4316,"you got asthma"],[4316,4496,"from saving Miss Arya."],[4496,4654,"Why didn't you just tell them?"],[4792,4921,"I just didn't wanna worry them."],[5113,5246,"But I guess it doesn't matter anymore."],[5455,5543,"Hurry, in here."],[5668,5789,"Mom, Dad."],[5943,5997,"Timothy."],[6139,6247,"Matt's room must be next door."],[6272,6377,"Yeah, come on."],[6377,6523,"I don't wanna miss his checkup."],[7019,7115,"Grow up and be a man."],[7152,7311,"Stop acting like a child!"]],"6":[[12,279,"You all used to be so close."],[279,492,"How did it end up like this?"],[579,746,"Are you still gonna take part"],[771,917,"in Project Hail Mary?"],[1001,1076,"I have the gene,"],[1121,1255,"so it's my responsibility"],[1259,1380,"to see this through."],[1430,1630,"Plus, it means the world to Gianna"],[1651,1801,"and the Snyder family, so"],[1901,1997,"it's kinda like my way of"],[1997,2072,"paying them back."],[2131,2327,"Please, please don't tell them."],[3111,3261,"Hey loser, check this out."],[3545,3670,"Just recording a happy day"],[3670,3795,"with my family here."],[4083,4208,"Hey."],[4612,4679,"Here, honey,"],[4679,4833,"eat your soup while it's still hot."],[4842,5059,"Oh, Mommy, did you make it just for me?"],[5059,5201,"Of course, sweetheart."],[5259,5380,"You're my special baby boy."],[5380,5530,"No one else gets this."],[5580,5759,"And then I got him right in the jaw."],[6502,6785,"Here, Timmy, I made it just for you."],[6785,7044,"Yay, my favorite chicken pot pie!"],[7069,7157,"Thank you, Mom."],[7169,7223,"Yeah."],[7253,7361,"We don't even get any?"],[7415,7532,"Mom, you spoil him."],[7553,7665,"Well, of course I do."],[7678,7849,"He's my special baby boy."],[7995,8187,"Okay, girls, you leave that pie alone."],[8204,8266,"Yeah, right."],[8354,8400,"Hey."],[8433,8516,"No, no, no."],[8516,8604,"Hang on, hang on."],[8604,8671,"No. - Hang on."],[8671,8758,"Just this tiny bite. - No!"],[8787,8875,"A little bit. - Wait!"],[9526,9676,"Dang, Bro is the golden child."],[9676,9788,"Wish I had a family like that."],[9788,9918,"I mean, what can I say?"],[9918,10085,"I just got very lucky, right, guys?"],[10264,10385,"I mean, a lot of people aren't as"],[10402,10535,"fortunate as me."],[10606,10752,"They'll probably die alone."],[10940,11023,"Die alone?"],[11194,11319,"Yeah, I probably will."],[11999,12078,"Hello?"],[12141,12195,"What?"],[12283,12379,"You guys found someone"],[12379,12483,"with the Pilgrim gene?"],[12771,12992,"Finally, after five years!"],[13000,13138,"Who, who's the volunteer?"],[13163,13300,"I shouldn't be saying this,"],[13300,13580,"but the volunteer is..."]],"7":[[41,183,"The volunteer is requesting to"],[183,329,"keep his identity a secret."],[358,542,"NASX has already approved this, so"],[567,734,"I will not be able to release his name."],[804,863,"Of course."],[938,1021,"That's their right."],[1096,1188,"Just make sure"],[1188,1288,"that the volunteer's family"],[1288,1368,"is taken care of."],[1368,1530,"Every expense will be covered"],[1530,1609,"by Snyder Group."],[1647,1747,"That's the problem."],[1780,1906,"There's no family on file."],[1968,2039,"He's an orphan."],[2318,2423,"Timmy was too."],[2806,2902,"I should go check on him."],[2911,3036,"Wait, no, no, no, hold on."],[3123,3224,"Matt's your real brother."],[3278,3436,"Don't let Timmy guilt trip you."],[3457,3570,"Yeah, honey."],[3578,3674,"Have you forgotten?"],[3674,3774,"He's the whole reason"],[3774,3912,"Matty is in a wheelchair."],[3962,4099,"You still feel sorry for the kid?"],[4099,4220,"Guys, guys, please."],[4325,4408,"Do not fight"],[4408,4517,"because of me, alright?"],[4575,4683,"Forget about my legs."],[4742,4884,"My brother matters more right now."],[4963,5138,"Timmy has lived with us for 12 years."],[5196,5384,"Whether he's faking it or not,"],[5459,5597,"I still need to go see if he's okay."],[5826,5935,"Fine, I'll go with you."],[5935,5989,"Me too!"],[6151,6318,"There's one last thing, Miriam."],[6381,6498,"I spent the last three years"],[6498,6619,"developing a cybernetic eye"],[6619,6706,"for Helena."],[6706,6890,"So she'll be able to see again."],[6952,7032,"Really?"],[7082,7190,"How do you know it'll work?"],[7828,8045,"Because I already tested it on myself."],[8066,8137,"What?"],[8195,8274,"You mean"],[8274,8462,"you removed one of your own eyes?"],[8495,8566,"Doesn't matter."],[8658,8867,"But could you do me a favor?"],[9150,9196,"Please,"],[9238,9359,"just make sure you ship it"],[9359,9471,"to Doctor Chloe when I'm gone."],[9734,9788,"Gone?"],[9884,10055,"Timothy, where are you going?"]],"8":[[16,70,"Timothy."],[70,171,"Where are you going?"],[246,442,"Do they actually care if I'm gone?"],[492,638,"Damn, he really will fake"],[638,771,"anything for attention."],[809,909,"Is this another one of your"],[909,1021,"dumb little tricks?"],[1055,1217,"Timmy, tell us where you're going."],[1301,1363,"Does it matter?"],[1447,1539,"See, he's bluffing!"],[1539,1647,"He doesn't have anywhere to go."],[1647,1747,"That's why he can't say."],[1780,1864,"The least you could do is"],[1864,1956,"let us know ahead of time"],[1956,2093,"if you're planning on taking a trip."],[2139,2293,"Whatever it is, do it after the launch."],[2306,2452,"Something big happened today."],[2452,2531,"We need to celebrate."],[2573,2660,"What happened today?"],[2669,2773,"You didn't know?"],[2806,2911,"We found a volunteer"],[2911,3036,"for Project Hail Mary,"],[3061,3249,"a one in a million genetic carrier"],[3249,3349,"of the Pilgrim gene."],[3357,3461,"We're hosting a launch event"],[3461,3532,"in three days."],[3611,3749,"This is definitely worth celebrating."],[3862,3966,"You're coming too."],[4004,4154,"It's a family celebration."],[4842,5000,"If you knew that I was leaving tonight,"],[5034,5146,"would you ask me to stay?"]],"9":[[725,921,"It's your birthday tomorrow."],[921,1142,"This must be a gift from your sisters."],[1230,1372,"I'm gonna go grab my camera."],[1372,1526,"I gotta catch a picture of this."],[2318,2444,"Happy birthday, Timmy!"],[2444,2506,"Here's your gift."],[2565,2648,"Wow!"],[2686,2827,"This is my favorite car."],[2848,3007,"I've only seen these on TV."],[3019,3107,"I'll get you a real one"],[3107,3207,"for your 18th birthday."],[3257,3340,"Promise."],[3361,3490,"You're the best, Gianna."],[3799,3899,"Gianna remembered."],[4621,4717,"Hey, hands off!"],[4775,4846,"It's mine."],[4888,5009,"Look, you already scratched it up,"],[5009,5130,"you fucking degenerate."],[5513,5638,"What the hell is wrong with you?"],[5684,5818,"I haven't done shit to you!"],[5830,5880,"So?"],[5926,6072,"Just looking at you pisses me off."],[6072,6227,"Now get the fuck away from my car."],[6343,6427,"Your car?"],[6448,6544,"Of course it's mine."],[6677,6815,"Oh, wait."],[7082,7198,"No fucking way."],[7198,7315,"You thought it's yours?"],[7432,7561,"Tomorrow's my birthday."],[7590,7691,"Gianna got it for me."],[7816,7945,"What was I hoping for?"],[8012,8128,"Whatever, enjoy your present."],[8220,8295,"Wait, wait, wait."],[8387,8541,"I'm not done with you yet."],[8600,8650,"Just..."],[8779,8875,"What are you doing?"],[8975,9034,"Ah!"],[9288,9388,"What the fuck?"],[9446,9580,"Timothy, I'm sorry!"],[9847,9926,"Matthew!"],[10155,10243,"Matthew!"]],"10":[[95,179,"Matthew!"],[237,342,"What happened?"],[342,508,"Everything was fine a few minutes ago."],[508,588,"Oh, God."],[646,759,"Oh my God, your hand,"],[759,834,"you're bleeding."],[888,950,"Let's get you inside - I'm sorry."],[950,1059,"and get you patched up."],[1259,1372,"What happened?"],[1409,1580,"Timmy just shoved Matty to the ground"],[1580,1659,"is what happened."],[1659,1751,"No, no, no, no, no."],[1751,1843,"It's all my fault."],[1843,2002,"I just fell by myself."],[2031,2127,"Stop defending him."],[2127,2277,"I just watched him push you."],[2277,2464,"What the fuck is wrong with you?"],[2464,2548,"No, no, no, no, no."],[2548,2686,"Please don't be mad at him. Uh..."],[2748,2857,"It's all because you guys didn't"],[2857,2957,"get him a car."],[2990,3057,"But look,"],[3057,3199,"if you really love the car,"],[3199,3286,"you can have it."],[3324,3440,"You're right what you said."],[3474,3566,"I'm in a wheelchair."],[3566,3720,"I'm not gonna be using it anyways."],[3824,3916,"Timothy!"],[3970,4095,"How can you say that?"],[4120,4262,"Apologize to him right now."],[4291,4454,"No, no, I'm not going to."],[4454,4521,"I didn't touch him!"],[4521,4637,"He's the one who hit me with the-"],[5551,5655,"Miss Arya!"],[5697,5947,"How dare you slap your own brother?"],[6106,6202,"He deserved it."],[6281,6373,"He should've apologized"],[6373,6485,"when I asked him to."],[6577,6681,"It's okay, Miriam."],[6798,6911,"Sorry, Matthew."],[7040,7115,"Enjoy your car."],[7198,7269,"Timothy,"],[7336,7494,"if you want a car,"],[7511,7645,"I will get you another one."],[7732,7786,"No."],[7899,7987,"No thanks."],[8078,8179,"It's not like I'll have much time"],[8179,8266,"driving it anyway."],[8579,8675,"I'm going to my room."],[8767,8858,"You guys have fun."],[9154,9263,"Wait, your room."],[9638,9697,"Hey."],[10001,10110,"Where's all my stuff?"]],"11":[[108,208,"No, no, no, no, no, no."],[208,383,"I don't have time to make another one."],[1217,1272,"I'm alright,"],[1272,1359,"please don't worry about me."],[1359,1422,"Are you sure?"],[1422,1488,"I'm fine."],[1547,1726,"I don't believe what happened."],[1764,1868,"I should ask Bob"],[1868,2027,"to pull the security footage."],[2060,2223,"Where the hell is my stuff?"],[2318,2431,"Stop that!"],[2740,2865,"Where is my stuff."],[2923,3078,"I was going to tell you."],[3128,3336,"Matthew is moving into your room."],[3365,3453,"The doctor said in order"],[3453,3586,"for his legs to get better,"],[3595,3720,"he needs more vitamin D."],[3737,3895,"And your room has the most sunlight."],[3912,4141,"So they just gave my room away"],[4141,4300,"without even letting me know?"],[4391,4608,"I guess I really am just an outsider."],[4608,4808,"You can move into the attic for now."],[4867,5034,"We'll clear the guest room for you soon."],[5067,5167,"Or you just be a man"],[5167,5301,"and move out, period."],[5334,5455,"Arya, don't say that."],[5563,5755,"Look, I, I don't care about the room."],[5755,5839,"He can have it."],[5964,6072,"But I had some really"],[6072,6235,"important prototypes in my workstation,"],[6252,6327,"and now they're gone."],[6356,6544,"Oh, Timothy, I'm so sorry."],[6623,6848,"Your desk was just covered in junk, so"],[6865,6981,"I didn't know what to do with it."],[7019,7090,"I tossed it out."],[7127,7178,"Junk?"],[7223,7332,"Those weren't junk!"],[7332,7474,"I spent three years"],[7474,7615,"working on those prototypes"],[7615,7770,"that could change lives!"],[7878,7932,"And who said you could"],[7932,8053,"touch my stuff anyway?"],[8158,8241,"I need those back!"],[8358,8462,"That's enough!"],[8546,8629,"You making something"],[8629,8792,"that's gonna change lives?"],[8792,8867,"That's a joke."],[8867,9067,"It's just material things, Timmy."],[9088,9292,"We can buy back whatever you need."],[9292,9371,"It's not like our family"],[9371,9459,"is short on money."],[9476,9588,"It's not something you can just"],[9588,9659,"buy back."],[9659,9797,"Shut up, already."],[9797,9851,"Okay?"],[9889,10126,"Everything that you own"],[10164,10268,"is from us."],[10297,10422,"The clothes on your back,"],[10422,10568,"the shoes on your feet,"],[10602,10719,"all of your junk"],[10769,10994,"was paid for by the Snyders."],[11002,11323,"You don't own anything,"],[11348,11478,"so who are you to get mad?"],[14723,14777,"Look,"],[14839,14923,"you can have it all back."],[15081,15215,"And I swear I'll never ask"],[15215,15361,"anything of you guys again."],[15444,15640,"I mean, it never really mattered"],[15640,15715,"to me anyway."],[15782,15899,"Not the money,"],[15978,16061,"not the things."],[16224,16312,"It was just family."],[16362,16462,"That's all I cared about."],[16583,16708,"I guess I was wrong about that, too."],[16825,17067,"So now, all I'm asking, no,"],[17133,17229,"I'm begging."],[17375,17484,"Please just tell me"],[17500,17663,"where the things from my desk are."],[18076,18251,"I mean, it should be in the junk outside."],[18280,18368,"Matthew,"],[18393,18543,"why would you throw away his things?"],[18543,18601,"I'm sorry,"],[18601,18764,"I really thought it was just junk."],[18831,18914,"Probably was junk."]],"12":[[375,471,"I have to find it."],[471,583,"I'm running out of time!"],[650,759,"I, I have to bring"],[759,871,"Helena's eye sight back."],[1413,1539,"I invented the world's first"],[1539,1718,"fully cybernetic eye for Helena."],[1735,1876,"I have to bring her eye sight back,"],[1876,1989,"it's my promise to her."],[4262,4421,"He's been at it for hours."],[4479,4567,"It's raining way too hard."],[4567,4675,"I need to go check on him."],[7874,7999,"Shit, one is broken."],[8103,8191,"I don't even know if I can"],[8191,8287,"fix this in time."],[8516,8596,"Unless..."],[8833,8896,"Timmy?"],[9271,9380,"Did you find it?"],[9455,9526,"Show me."],[9617,9763,"What was it that got you so worked up?"],[9822,9922,"She wouldn't believe me"],[9922,10051,"even if I told her."],[10072,10147,"Doesn't matter."],[10260,10322,"Fine."],[10431,10552,"Here, at least take my jacket."],[10552,10593,"No."],[10706,10789,"No, I don't need it."],[11052,11165,"Timothy, when are you gonna stop"],[11165,11315,"being so immature?"],[11423,11578,"Was it really that big of a deal?"],[11661,11815,"Fine, we will give you your room back."],[11849,12020,"And the car, I will get you one too."],[12070,12162,"There, happy?"],[12220,12295,"Is that what you want?"],[12470,12525,"What?"],[12570,12712,"Why are you staring at me?"],[12791,12971,"And why aren't you saying anything?"],[13150,13238,"I just realized,"],[13350,13421,"that you really"],[13421,13526,"don't know me at all."]],"13":[[191,325,"It's completely shattered."],[4996,5063,"Timothy?"],[5063,5242,"Did you get any sleep last night?"],[5309,5351,"No."],[5442,5588,"I'll be asleep for the next 30 years,"],[5588,5705,"so I don't think it really matters."],[6085,6243,"What happened to your eye?"],[6277,6377,"One of the cybernetic eyes"],[6377,6489,"was completely shattered."],[6598,6673,"So I,"],[6719,6844,"took out my own prototype"],[6844,6977,"and modified it for Helena."],[7123,7161,"Look."],[7378,7557,"This is my life's work."],[7649,7761,"So when I'm gone,"],[7882,8091,"please bring it to Dr. Chloe."],[8458,8579,"Does it hurt at all?"],[8746,8825,"No, it doesn't."],[8863,9009,"Compared to the pain in my heart,"],[9096,9180,"this is nothing."],[9250,9367,"At least have some milk,"],[9367,9484,"you need energy."],[10890,11036,"Timothy, Timothy!"],[11036,11207,"Help, someone help!"],[11490,11649,"He's been passed out all day."],[11703,11815,"If he doesn't wake up soon,"],[11815,11991,"we need to take him to the hospital."],[12362,12445,"What's this?"],[13446,13680,"This will be kept strictly confidential."],[13738,13813,"You don't wanna let"],[13813,13926,"your loved ones know"],[13947,14114,"so you can have a proper goodbye?"]],"14":[[688,800,"Oh my God, you're awake."],[821,975,"Miriam said you scratched your eye."],[975,1080,"How did you manage to do that?"],[1192,1276,"How are you feeling?"],[1372,1443,"Any pain?"],[1472,1614,"You scared us to death."],[1697,1810,"Don't go and get yourself"],[1810,1972,"that worked up again, okay?"],[2014,2173,"Since Matthew came back,"],[2214,2298,"this is the first time"],[2298,2444,"they've looked at me like this."],[2494,2615,"Like they actually care."],[2648,2857,"Yeah, I know I overreacted"],[2894,2969,"the other day,"],[2969,3169,"but Matt's your brother, just"],[3240,3357,"go easy on him, okay?"],[3395,3432,"Yeah."],[3453,3574,"No, I won't fight with him anymore."],[3603,3787,"Because tonight, I'm leaving."],[3895,3991,"That's better."],[4004,4166,"We're still family after all."],[4266,4433,"Do you need to get your eyes checked?"],[4483,4592,"No, no, it's cool."],[4592,4704,"It's just a scratch,"],[4704,4813,"it'll be cool in a few days."],[4884,4979,"Alright, just be careful"],[4979,5071,"with your eyes."],[5071,5230,"You don't wanna end up blind like me."],[5351,5422,"Not for long."],[5534,5588,"What?"],[5676,5759,"No, nothing."],[5814,5955,"Alright, enough with the chatting."],[5980,6068,"If you're feeling better,"],[6068,6231,"get dressed for the launch party."],[6277,6431,"Tonight's the big night."],[6448,6577,"I'm so excited."],[6606,6694,"If you knew I'd be the one"],[6694,6819,"taking off to space tonight,"],[6861,6994,"would you still be this happy?"],[7449,7670,"Thank you all for being here tonight."],[7695,7811,"We are celebrating"],[7811,7932,"the official launch"],[7957,8108,"of the Project Hail Mary."],[8616,8683,"None of this"],[8683,8821,"would've been possible without our"],[8821,8975,"anonymous volunteer,"],[9059,9117,"our hero."],[9325,9434,"Let's raise a glass to them."],[10189,10343,"And before we continue,"],[10377,10598,"I have one more announcement."],[10623,10731,"Three years ago,"],[10731,10894,"our family was reunited"],[10894,11106,"with our true heir, Matthew."],[11165,11302,"From this day forward,"],[11302,11453,"the Project Hail Mary"],[11453,11644,"will be officially renamed"],[11695,11845,"Project Matthias,"],[11861,11982,"meaning gift of God,"],[11982,12141,"in honor of his return."],[12608,12746,"Woo! - Wow"]],"15":[[1167,1201,"Hey."],[1434,1555,"Do you see that blind bitch"],[1555,1647,"with a cane over there?"],[1785,1939,"Go tell her Timothy's looking for her."],[2869,3007,"Four hours left,"],[3057,3128,"then it's over."],[3244,3428,"Not so fun being forgotten, is it?"],[3486,3595,"But I didn't forget."],[3670,3858,"It's your 18th birthday, Timmy."],[3883,4041,"See, I remember."],[4066,4154,"What do you want?"],[4154,4366,"Oh my God, dude, relax."],[4433,4533,"I just wanted to give you a"],[4533,4650,"birthday present"],[4721,4846,"for my dear brother."],[5693,5743,"Whew!"],[5784,5834,"Whoa."],[5889,5985,"Wait, wait, wait."],[6051,6106,"You..."],[6260,6402,"you can, you can walk?"]],"16":[[79,158,"You can walk?"],[191,316,"Surprise, bitch."],[329,425,"So you've been pretending"],[425,538,"this entire time?"],[538,617,"Of course."],[633,709,"Or what?"],[734,817,"You thought I really"],[817,963,"crippled myself just to set you up?"],[1059,1130,"Honestly,"],[1180,1347,"I didn't think you'd all be dumb enough"],[1347,1522,"to believe it. But.."],[1555,1689,"Why, why are you doing this?"],[1689,1814,"I didn't take anything from you."],[1814,1885,"Take?"],[1922,2085,"You've been living my life, bro."],[2143,2277,"Every good thing that happened to you"],[2277,2364,"should've been mine."],[2406,2469,"You owe me,"],[2535,2648,"and I'll make you pay"],[2740,2886,"a thousand times more."],[2969,3036,"Timmy?"],[3078,3199,"You were looking for me?"],[3682,3795,"Timmy, is that you?"],[3853,3962,"Matthew, what are you doing?"],[5601,5714,"What happened?"],[5780,5918,"Timmy, how could you?"],[5918,6060,"You pushed her towards the candles"],[6060,6164,"you could've killed her!"],[6181,6331,"No, no, I didn't do it!"],[6331,6406,"Matthew did it!"],[6427,6556,"Stop lying, Timmy."],[6606,6702,"I heard footsteps."],[6702,6781,"Matt can't walk,"],[6781,6877,"how could he push me?"],[6898,7007,"He's lying about that too!"],[7007,7090,"He can walk!"],[7102,7286,"Hey, I know that you're jealous"],[7286,7374,"that family loves me,"],[7374,7520,"but don't take it out on Helena."],[7520,7586,"That's not what I-"],[7586,7661,"That's enough!"],[7766,7999,"I may be blind, but I am not stupid."],[8062,8204,"Stop trying to pin this on Matt."],[8266,8466,"You have resented our family for years."],[8495,8629,"You're looking for revenge."],[8850,9042,"No, Helena, I would never hurt you!"],[9109,9209,"Everything I did last night,"],[9209,9288,"I did it for you!"],[9305,9421,"What are you talking about?"],[9651,9705,"Nevermind."],[9822,10060,"Helena, I'm so tired."],[10143,10339,"I'm so tired of explaining myself."],[10427,10485,"Alright."],[10602,10710,"Maybe I went too far."],[10806,10948,"Let's just forget about this."],[10998,11073,"Damn it."],[11123,11207,"My asthma."],[11311,11378,"Not now."],[12120,12312,"No, Timmy, please don't hit me!"],[12358,12437,"Matt!"],[12495,12575,"Timothy!"],[12645,12771,"What is wrong with you?"]],"17":[[125,179,"Timothy!"],[241,346,"Oh my God."],[346,467,"What is wrong with you?"],[567,713,"You've already hurt him once."],[713,813,"Isn't that enough?"],[813,934,"Alright, there we go."],[934,1080,"Nice and easy, here we go."],[1134,1234,"There you go. - It's okay, honey."],[2239,2352,"Say whatever you want."],[2519,2686,"You're not gonna believe me anyway."],[3078,3203,"I just need my inhaler."],[3365,3495,"I am so sick of this"],[3495,3682,"fake asthma bullshit."],[4817,4929,"You can't just get asthma"],[4929,5050,"out of nowhere, Timmy."],[5071,5180,"It doesn't work like that."],[5301,5497,"I got asthma because-"],[5497,5638,"Drop the act, liar!"],[5897,6076,"Because I saved you, sis."],[6318,6398,"Help!"],[6418,6510,"Somebody help!"],[6539,6669,"Somebody help me!"],[6698,6865,"The smoke destroyed my lungs,"],[6902,7052,"and l hid it so you wouldn't worry."],[7223,7315,"The funny thing is..."],[7603,7695,"you all never cared."],[7832,7912,"Forget it."],[7966,8066,"Doesn't matter."],[11119,11211,"You know, I tried so hard"],[11211,11332,"to fix things between us,"],[11403,11490,"but then I realized"],[11590,11682,"it's not my fault that"],[11728,11795,"you guys don't know"],[11795,11903,"what's right from wrong."],[12012,12078,"It's not my fault"],[12078,12220,"that you guys are too blind"],[12220,12341,"to see what's really happening."],[12529,12675,"And you're gonna have to live with that."],[12954,13013,"Yeah."],[13888,14093,"You are a fucking disgrace."],[14093,14280,"How dare you talk to me that way?"],[14343,14439,"I was so stupid"],[14439,14568,"to think of you as a son."]],"18":[[16,233,"You are a fucking disgrace!"],[233,471,"How dare you talk to me that way?"],[483,592,"If it weren't for us,"],[592,763,"you'd still be on the streets."],[813,900,"We took you in,"],[900,1026,"we gave you everything,"],[1026,1222,"and this is how you repay us?"],[1317,1539,"You are an ungrateful brat."],[1555,1664,"From this day forward,"],[1664,1780,"we're cutting ties with you."],[1830,2085,"You are no longer a Snyder."],[2498,2573,"Dad! - Dad!"],[2573,2644,"My God!"],[3094,3211,"Timothy didn't mean it."],[3211,3328,"We can fix this."],[3328,3449,"He just needs help."],[3528,3595,"No, he's right."],[3720,3899,"I'm not a Snyder and I never will be."],[3953,4112,"Timmy, you're not a kid anymore."],[4133,4225,"Don't make this harder"],[4225,4308,"than it already is."],[4316,4450,"You really wanna leave us?"],[4462,4604,"From everything you have?"],[4621,4767,"Fine, if you wanna cut ties,"],[4767,4896,"don't bother coming back."],[5067,5134,"Don't worry."],[5342,5455,"I won't be coming back."],[5885,6006,"It was good knowing all of you."],[6936,7048,"That's NASX's car!"],[7048,7190,"General McGee, General!"],[7323,7440,"General, General!"],[7440,7520,"Excuse me, sir-"],[7520,7636,"NASX is here."],[7695,7820,"Why are they here right now?"],[7820,7966,"Shouldn't they be at the launch pad?"],[7974,8112,"Sir, look at here. - General McGee."],[8112,8287,"Son, it's time."],[8341,8445,"Who's that young man?"],[8445,8583,"He looks like a big deal."],[8625,8717,"Just gotta go home"],[8717,8850,"and do one last thing before we launch."],[8896,8954,"Okay."],[9718,9809,"Wait!"]],"19":[[20,133,"Wait!"],[650,855,"Is that NASX picking up the volunteer?"],[855,971,"Why else would they be here?"],[1005,1092,"Is it just me,"],[1092,1226,"or is the person they are picking up"],[1230,1309,"kinda look like Timothy?"],[1309,1430,"No, that's impossible."],[1430,1526,"Timothy would never sign up"],[1526,1634,"for something like this."],[1634,1768,"He's not that brave."],[1810,1864,"Yeah."],[1939,1997,"Miss Gianna,"],[1997,2081,"do you still want me to set up"],[2081,2177,"for the family photo?"],[2786,2932,"Happy birthday, Timothy."],[3370,3553,"Chocolate cake, I baked it myself."],[3795,3849,"Thank you for"],[3849,3949,"remembering, Miriam."],[4320,4433,"You really have to leave."],[5518,5630,"Thank you for taking care of me"],[5630,5714,"all these years."],[6106,6210,"This is all I got saved."],[6210,6402,"Oh no, I, I couldn't, no."],[6427,6493,"Please take it."],[6577,6694,"Please remember what I told you."]],"20":[[1013,1167,"Timmy, no one else comes up here."],[1188,1393,"So, this attic is our secret base now."],[1564,1680,"What's that box for?"],[1735,1868,"That's our tree hollow."],[1960,2056,"If we wanna say something,"],[2056,2181,"but we don't wanna say it out loud,"],[2181,2289,"we write it on a piece of paper"],[2289,2398,"and we put it in the box."],[3090,3257,"Thanks for being my eyes, Timmy."],[3336,3516,"You've made the dark less scary."],[3699,3757,"Timmy,"],[3799,3995,"you're the best brother in the world."],[4033,4149,"I'll always have your back."],[4704,4871,"You'll always be our baby brother."],[4900,4984,"Whatever you want,"],[5025,5105,"I'll get it for you."],[5113,5196,"Just say the word."],[5217,5292,"You had already walked away,"],[5384,5613,"and I stayed frozen in the same place,"],[5718,5830,"waiting for the promises"],[5830,5955,"you no longer remembered."],[6393,6577,"Only I realized it too late."],[6760,6861,"No one cuts deeper"],[6861,6952,"than the ones you love."]],"21":[[12,137,"If we're taking a family photo,"],[137,254,"we should wait for Timmy."],[442,508,"Why?"],[613,734,"I'm your real brother."],[742,896,"I'm the real son of this family."],[896,1038,"Why does he always come first?"],[1038,1163,"Matthew, seriously?"],[1163,1326,"We do so much to put you first."],[1326,1480,"You can wait for one photo."],[1518,1676,"Matty, we do baby you more,"],[1676,1856,"but Timmy is still family."],[2031,2122,"Okay, I'm sorry."],[2168,2252,"I didn't mean it."],[2414,2640,"Yes, let's wait for him."],[2694,2765,"He's been with us"],[2765,2890,"since he was six years old."],[2890,2998,"I did raise him."],[3048,3199,"He's always wanted a family photo,"],[3199,3324,"but something always"],[3324,3420,"got in the way."],[3470,3670,"Gosh, these 12 years have just flown by."],[3866,3924,"Wait."],[4049,4149,"What's the date today?"],[4308,4396,"Uh, September 10th."],[4650,4763,"Oh my God."],[4763,4925,"It's his 18th birthday."],[4975,5059,"I got so worked up"],[5059,5142,"about the launch event,"],[5142,5267,"I, I completely forgot."],[5267,5347,"Oh shit."],[5347,5509,"None of us remembered?"],[5530,5659,"He must be so hurt."],[5676,5751,"Maybe that's why he was"],[5751,5868,"acting out today."],[5980,6106,"I need to go find him."],[6143,6189,"Okay."],[6231,6318,"We'll go with you. - Yeah."],[6318,6423,"Let's go. - Yeah."],[6573,6715,"Mom, Dad, Gianna!"],[7357,7624,"Too late to fix anything anyways."],[7770,7870,"But you will never know"],[7870,8041,"that the boy you cast aside"],[8199,8337,"is actually the real son"],[8337,8458,"of Snyder family."],[8683,8754,"Oops."],[8842,9113,"Timmy, please wait for us."]],"22":[[354,433,"Timmy?"],[458,613,"Timmy! - Timmy!"],[1063,1159,"Timmy?"],[1230,1388,"Timmy! - Timmy, Timmy!"],[1743,1914,"Son, your mission is clear."],[1985,2193,"30 years alone in outer space."],[2193,2302,"If you live long enough"],[2302,2473,"to reach a new planet, Artemis,"],[2489,2610,"you will test its mercy."],[2815,2965,"I once had the sweetest life"],[2965,3053,"I could ever have."],[3098,3257,"You gave me all I could ask for."],[3474,3695,"And now, I will give my life back to you."],[3716,3883,"That's all I have left."],[3966,4141,"Ready to launch in 10,"],[4245,4295,"9,"],[4362,4425,"8."],[4425,4662,"I may be blind, but I am not stupid."],[4671,4842,"Stop trying to pin this on Matt."],[4842,4963,"Timothy, when are you gonna stop"],[4963,5121,"being so immature?"],[5171,5338,"Fine, we will give you your room back."],[5405,5505,"There, happy?"],[5572,5701,"Grow up and be a man."],[5722,5885,"Stop acting like a child!"],[5997,6139,"I am so sick of this"],[6139,6293,"fake asthma bullshit!"],[6293,6398,"People don't just suddenly"],[6398,6510,"get asthma, Timmy."],[6510,6627,"It's not how it works."],[6652,6877,"You are no longer a Snyder."],[6986,7090,"But if I could choose again,"],[7549,7711,"may we never be family."],[7745,7828,"Ignition start."],[7828,8220,"Ready to launch in three, two, one."],[9622,9667,"See you on the"],[9667,9768,"other side of the stars."]],"23":[[204,312,"He's not here either."],[421,517,"I should've done better"],[517,617,"as the eldest sister."],[642,742,"I will call him."],[775,955,"I will bring him back myself."],[1451,1547,"He blocked me."],[1797,1926,"He blocked me too!"],[1972,2127,"We forgot his birthday."],[2156,2260,"After what happened today,"],[2260,2402,"of course he's still upset."],[2452,2573,"Oh, now you feel bad?"],[2686,2773,"Oh, Miriam,"],[2819,2907,"do you know where he went?"],[2948,3040,"You're closest to him."],[3128,3199,"Where was"],[3199,3370,"all that when he was still here?"],[3386,3465,"He said he wanted to spend"],[3465,3557,"his birthday alone."],[3674,3866,"No, it's his 18th birthday."],[3866,3970,"It's like the biggest one."],[4012,4112,"We're not gonna let him spend it"],[4112,4179,"by himself."],[4195,4283,"I'm gonna go look for him."],[4300,4383,"I'm coming with you."],[4425,4546,"Okay, then prove it."],[4733,4833,"If you really mean it,"],[4833,4992,"then throw him a real birthday party"],[4992,5067,"in three days."],[5117,5213,"Maybe when he comes back"],[5213,5359,"and sees it, he'll change his mind."],[5367,5430,"We'll do it."],[5472,5563,"We'll make sure he gets"],[5563,5668,"everything that he wants."],[5780,5885,"Timmy, we'll be waiting here."],[5939,6097,"He spent years"],[6097,6235,"waiting for you to come around."],[6281,6452,"Now it's your turn to wait."]],"24":[[175,329,"He won't even talk to us."],[375,542,"He's still really hurting."],[554,688,"Don't cry, sweetheart."],[734,909,"You have your eye surgery tomorrow."],[925,1055,"Helena, don't worry."],[1055,1184,"He knows your surgery's tomorrow."],[1184,1280,"He's not gonna miss it."],[1368,1459,"Do you think so?"],[1463,1668,"He always cared about you the most."],[1676,1755,"He used to say that"],[1755,1889,"he would give you his eyes"],[1889,2039,"if it meant that you could see again."],[2089,2289,"If it means taking Timmy's eyes,"],[2389,2519,"I'd rather stay blind."],[3503,3561,"Ow."],[3653,3799,"Why can't I just be normal?"],[3820,3974,"Whoa, hey, hey, hey, hey."],[4016,4062,"You okay?"],[4258,4362,"Oh, don't cry."],[4625,4779,"One day you're gonna see again."],[4850,4913,"I promise."],[5055,5251,"Timmy, I'm finally gonna see."],[5309,5392,"Please come back."],[5447,5668,"I want you to be the first person I see."]],"25":[[321,392,"Don't worry."],[467,654,"Helena's surgery went very well."],[654,804,"It is the world's first"],[804,946,"cybernetic eye surgery."],[988,1126,"This will go down in history."],[2298,2339,"Helena."],[2535,2610,"Timmy?"],[3094,3203,"Oh, you're Matt."],[3315,3415,"Hi, my angel."],[4571,4625,"Mom?"],[4667,4758,"Dad?"],[4788,4867,"Gianna?"],[4896,4979,"Arya?"],[5142,5380,"Oh baby, you can finally see."],[5488,5588,"We owe this to the inventor"],[5588,5697,"of the cybernetic eye."],[5697,5822,"Whoever this genius is,"],[5843,5918,"needs to work for"],[5918,6060,"Snyder Labs immediately."],[6151,6235,"I tried to reach out,"],[6235,6318,"but he wants to keep"],[6318,6460,"his identity anonymous."],[6468,6627,"We'll never know who he is."],[6673,6831,"Then I'll write a thank you letter."],[6848,7027,"Gianna will you make sure it gets to him?"],[7082,7161,"Of course."],[7173,7278,"Oh, by the way,"],[7286,7428,"how is Timothy's asthma?"],[7624,7745,"Timmy has asthma?"]],"26":[[37,187,"Timmy has asthma?"],[221,325,"You didn't know?"],[450,608,"My colleague treated him"],[608,704,"a few days ago."],[742,813,"He said that"],[813,930,"Timothy has had asthma"],[934,1096,"ever since he inhaled a lot of smoke"],[1096,1409,"from a fire incident three years ago."],[1601,1685,"Help!"],[1697,1805,"Somebody help!"],[1826,1964,"Someone help me!"],[1968,2081,"Hang on, Ayra."],[2110,2181,"I'll get you out, come on."],[2181,2223,"Okay."],[2489,2698,"That was when he saved me."],[2740,2873,"His asthma is severe."],[2873,2948,"Three days ago,"],[2948,3078,"he nearly died from an attack."],[3132,3274,"He needs to be calm."],[3299,3436,"Too much stress could kill him."],[3520,3611,"Mom, Dad."],[3724,3782,"Timothy."],[3870,3987,"Matt's room must be next door."],[4004,4049,"Yeah."],[4371,4479,"Grow up and be a man."],[4537,4667,"Stop acting like a child!"],[4829,5121,"So, Timmy got sick because of me,"],[5121,5255,"and I've been treating"],[5255,5384,"him like shit?"],[5455,5593,"You know, you're such a snake."],[5593,5739,"If you don't cut this shit out,"],[5739,5805,"I'm gonna make sure"],[5805,5930,"your fake disease is real."],[6135,6260,"If anything happens to him,"],[6260,6427,"I'll never gonna forgive myself."],[6493,6614,"We really messed up."],[6656,6756,"When he gets back,"],[6810,6923,"we will make this right."],[7007,7190,"I knew he still cared about us."],[7407,7578,"Timothy, you better die out there."],[7615,7770,"Don't you dare come back."]],"27":[[104,183,"It's been two days."],[183,275,"Where's Timmy?"],[408,496,"Ladies,"],[550,654,"there's been something"],[654,750,"on my chest."],[759,825,"It's regarding"],[825,942,"Matthew and Timothy."],[971,1046,"What about them?"],[1046,1172,"Looks can be deceiving."],[1205,1288,"I believe Timothy"],[1288,1463,"has been wrongly accused."],[1493,1618,"You remember the recent"],[1618,1826,"glitches with the security camera."],[1868,2006,"Bob was able to fix it."],[2060,2143,"I have to show you."],[2198,2318,"Security camera?"],[2452,2577,"Isn't this from the day we got"],[2577,2740,"Matt the Corvette for his birthday?"],[2919,3044,"Hands off my car,"],[3044,3174,"you fucking degenerate."],[3345,3470,"So Matthew was the one"],[3470,3595,"that hit Timmy first?"],[3674,3774,"He lied to us?"],[3791,3891,"There's more."],[3912,4058,"This is the most shocking one."],[4208,4354,"Wait, isn't this the day that"],[4354,4554,"Timmy pushed Matty down the stairs?"],[4554,4650,"I thought that the cameras"],[4650,4763,"were broken that day?"],[4763,4863,"Not broken."],[4863,5030,"Bob said someone wiped it clean."],[5088,5230,"Luckily, he was able to find someone"],[5230,5292,"who could recover"],[5292,5388,"the drive. - What is that?"],[5651,6106,"Ow!"]],"28":[[141,250,"You!"],[304,442,"You stole my identity"],[442,646,"for 10 fucking years."],[658,734,"You owe me!"],[750,871,"And I'm taking back"],[871,1080,"every single thing."],[1105,1255,"I didn't take anything from you, man."],[1255,1363,"I'll warn you!"],[1422,1505,"The only son,"],[1505,1755,"the only heir of Snyder family"],[1893,1976,"is me."],[4279,4379,"Matt!"],[4379,4512,"My leg!"],[4917,4954,"Matt!"],[5092,5251,"It hurts so bad!"],[5488,5676,"Timothy, why did you push me?"],[6835,7161,"So Matthew fell on purpose."],[7257,7394,"Then all these years,"],[7728,7949,"he played us like a fiddle."],[8058,8237,"And everything we did to Timothy."],[8358,8425,"So that's who Matthew"],[8425,8512,"really is, huh?"],[8662,8817,"Matty's true colors."],[8817,8896,"Oh God."],[9063,9125,"Oh God,"],[9125,9338,"how could we have been so blind?"],[9338,9559,"Timmy must be so disappointed in us."],[9626,9718,"Yeah, Matthew's got some"],[9718,9830,"explaining to do."],[10001,10064,"Yeah, Mom,"],[10064,10168,"you need to bring Matty home"],[10168,10260,"right now!"]],"29":[[221,392,"That was so fun. - How fun."],[392,442,"Yeah."],[750,821,"I can't believe we"],[821,934,"fell for your stupid act."],[934,1063,"Arya, what the hell?"],[1063,1255,"Jesus, Arya, what..."],[1297,1413,"Have you lost your damn mind?"],[1413,1614,"No, we've lost our damn minds."],[1710,1755,"You know,"],[1755,1918,"if we didn't share the same blood,"],[1926,2156,"I'd kill a psychopath like you."],[2360,2498,"Could somebody please tell me"],[2498,2656,"what's going on right now?"],[2656,2773,"Mom, Dad."],[2781,2923,"Matthew's been bullying Timothy"],[2923,3019,"all along."],[3082,3274,"He fell down the stairs on purpose."],[3499,3595,"Mom, Dad."],[3716,3870,"How could I ever hurt Timmy?"],[3870,3999,"Sure, we fight sometimes,"],[3999,4104,"but we're still brothers."],[4145,4237,"I'm on his team."],[4546,4767,"The only heir of Snyder family"],[4796,4859,"is me."],[5138,5317,"Still not giving up the act?"],[5363,5509,"You're unbelievable!"],[5593,5697,"Why, Matthew?"],[5718,5818,"How could you do that"],[5818,5910,"to your own brother?"],[5951,6031,"Why?"],[6093,6210,"We still feel so guilty"],[6210,6364,"about losing you back then."],[6393,6527,"We've done everything to try"],[6527,6690,"to make you feel at home here."],[6731,6965,"We've spoiled you more than Timothy!"],[7002,7152,"Just so you wouldn't feel jealous!"],[7152,7236,"Is it not enough?"],[7236,7444,"Okay, okay, I'm sorry!"],[7586,7753,"Yes, I was jealous. I just,"],[7807,7907,"I just wanted you guys"],[7907,8020,"to love me more."],[8112,8237,"Why aren't I as good as him?"],[8274,8391,"I'm your real son."],[8420,8541,"You'll never be good enough."],[8566,8725,"Get the hell out of our faces."]],"30":[[20,175,"Get the hell out of our faces."],[613,779,"This is unbelievable."],[1063,1184,"Oh my God."],[1501,1760,"You are a fucking disgrace."],[1760,1968,"How dare you talk to me that way?"],[1997,2089,"I was so stupid"],[2089,2210,"to think of you as a son."],[2389,2456,"What have I done?"],[2540,2652,"We failed him."],[2877,3028,"But Timothy has a kind"],[3028,3161,"and a generous heart."],[3190,3282,"When he comes home,"],[3282,3378,"we will talk it through"],[3378,3520,"and I'm sure that he'll forgive us."],[3691,3807,"Then we can start fresh."],[3849,3978,"Oh God, I hope so."],[4116,4258,"We have a special message today"],[4258,4358,"for Timothy Snyder."],[4458,4696,"Happy 18th birthday from your family!"],[4779,4888,"They're waiting for you at home"],[4888,5034,"with a big birthday surprise."],[5130,5209,"They miss you"],[5209,5363,"and hope you'll come home soon."]],"31":[[208,337,"Do you think he saw our messages?"],[371,467,"Of course."],[487,654,"We covered every inch of the city."],[696,800,"Unless he's in outer space,"],[800,921,"he's seen our messages."],[959,1063,"He'll come home tonight,"],[1063,1155,"I just know it."],[1238,1313,"Girls,"],[1363,1522,"your mother and I decided to gift"],[1522,1643,"the Malibu and Culver City"],[1643,1776,"properties to Timothy."],[1785,1901,"He grew up in an orphanage,"],[1901,1976,"never had a home,"],[1985,2093,"so we think this will give him"],[2093,2156,"a peace of mind."],[2239,2406,"All of that should've belonged to me."],[2435,2510,"Now Timothy,"],[2510,2640,"you better not come back"],[2727,2915,"or else you'll be leaving in a coffin."],[3178,3286,"You couldn't celebrate"],[3286,3499,"your birthday with your family, Timothy."],[3586,3816,"I'll witness it in your honor."]],"32":[[371,454,"It's getting late."],[454,608,"Why isn't Timothy back yet?"],[750,842,"He's still hurting."],[842,955,"I should go find him."],[1305,1384,"Is that Timmy?"],[2619,2698,"It's just some mail."],[2886,2965,"Maybe it's from him!"],[2965,3007,"Open it."],[3007,3078,"Hurry, hurry!"],[3749,3820,"This is just"],[3832,3953,"the thank you letter I sent to"],[3953,4145,"the inventor of my cybernetic eyes."],[4692,4779,"Oh my God,"],[4996,5167,"Timothy got the Maple Award."],[5167,5296,"I thought that they only gave this"],[5296,5384,"to people who have made"],[5384,5518,"tremendous contributions"],[5518,5634,"to the medical field."],[5655,5734,"That means..."],[5964,6047,"Timothy"],[6106,6185,"was the inventor of"],[6185,6306,"my cybernetic eyes?"],[6627,6685,"What?"],[6760,6869,"Not only the inventor,"],[6940,7036,"but also the person"],[7036,7165,"who gifted you his eye."]],"33":[[8,141,"Miriam, what do you mean?"],[221,279,"I thought my eyes"],[279,383,"were purely synthetic."],[383,483,"You had the first pair of"],[483,600,"cybernetic eyes,"],[696,880,"but who do you think tested it first?"],[971,1126,"Because I already tested it on myself."],[1151,1368,"You removed one of your own eyes?"],[1843,1947,"Not only that, but,"],[2006,2122,"Matthew threw them away."],[2193,2381,"Your desk was just covered in junk,"],[2381,2544,"so, I didn't know what to do with it."],[2598,2665,"I tossed it out."],[2690,2765,"Junk?"],[2882,3032,"Timothy dug for hours"],[3032,3161,"in the storm to find them."],[4437,4604,"One was completely broken."],[4683,4767,"He had to,"],[4813,4879,"he had to..."],[5259,5359,"Oh my God."],[5743,5814,"That's why he was"],[5814,5943,"wearing the eye patch!"],[6548,6685,"He didn't have time to fix it."],[6744,6898,"He had to dig out his own eye."],[6986,7157,"Oh, God..."],[7407,7574,"What do you mean he didn't have time?"],[7599,7686,"Where is he?"],[7832,7916,"Please!"],[7982,8128,"Tell us, where is Timmy?"],[8258,8345,"Please."]],"34":[[75,225,"Please tell us."],[300,367,"I'm sorry."],[387,500,"Oh no. - I can't say."],[884,946,"Miriam!"],[1059,1213,"Please, we are begging you."],[1272,1451,"Right now he's out there all alone,"],[1488,1564,"blind!"],[1634,1760,"What if something happens to him?"],[1760,1910,"Look, we know that we hurt him."],[1910,2085,"We're just trying to make it up to him!"],[2093,2252,"Miriam, please."],[2310,2469,"Please, we are begging you!"],[2531,2681,"Please, we need to find him."],[2681,2819,"Please, he's my son!"],[2819,2915,"Miriam!"],[3136,3186,"Please!"],[3203,3249,"Please."],[3678,3762,"Please."],[3933,4129,"Timothy left you a note in the attic."],[4225,4350,"I suggest you all go see it."],[4429,4479,"Okay."],[4517,4554,"Honey..."],[4554,4596,"Okay."],[4612,4646,"Honey."],[7269,7323,"No."],[7565,7640,"Timmy."]],"35":[[58,154,"Oh hey, hey, hey."],[312,396,"Timmy."],[513,675,"No, no, no, this can't be."],[917,967,"Timmy,"],[967,1142,"this is as far as I will lead them."],[1201,1372,"Now it's up to themselves"],[1372,1484,"to discover the truth."],[1714,1847,"He was fine just a few days ago."],[1847,1956,"How could he be dead?"],[1956,2027,"Wait, look."],[2077,2248,"This was signed on September 7th, but"],[2248,2369,"he was with us through the 10th."],[2489,2615,"Why would a living person"],[2615,2715,"get a death certificate"],[2715,2802,"ahead of time?"],[2844,2940,"This is just his way of"],[2940,3061,"punishing us, right?"],[3119,3224,"But he's okay."],[3294,3365,"Right?"],[3520,3570,"Please."],[3636,3732,"Let us see him."],[3945,4120,"I know you all loved him."],[4229,4466,"So why did it come to this?"]],"36":[[50,179,"Before Timmy left,"],[358,462,"he said if the truth"],[462,592,"were ever to come out,"],[750,959,"that I should give this to you all."],[1522,1618,"He recorded this"],[1618,1793,"before, uh, the launch event."],[2056,2160,"The launch event?"],[2231,2352,"From this day forward,"],[2352,2473,"we're cutting ties with you."],[2523,2815,"You are no longer a Snyder."],[2986,3048,"Don't worry."],[3153,3265,"I won't be coming back."],[3816,4049,"How could I be so stupid?"],[4170,4237,"We..."],[4487,4717,"We're the ones that chased him away."]],"37":[[350,408,"Hey Mom."],[496,558,"Hey Dad."],[817,980,"These are my final words."],[1234,1368,"By the time you're watching this,"],[1476,1543,"I'll be dead."],[1676,1760,"I'll be gone."],[1860,1910,"So,"],[2068,2156,"don't go looking for me."],[2298,2640,"I think this was inevitable and I,"],[2660,2794,"I will cherish every moment"],[2794,2923,"I got to spend with you guys."],[2977,3186,"Because I know, at one point,"],[3228,3440,"you did love me."],[3536,3582,"Right?"],[4408,4500,"Back when you,"],[4558,4700,"when you gave me a family,"],[4792,4959,"and you showed me love"],[4959,5096,"that I didn't know was possible."],[5192,5380,"These past 12 years have been amazing."],[5518,5659,"And I would cherish those memories"],[5659,5730,"to the very end."],[6556,6619,"Mom."],[6664,6715,"Dad."],[6881,6956,"Thank you"],[7015,7115,"for letting me be your son."],[7315,7524,"Gianna, Helena, Arya."],[7670,7774,"I had a wonderful time"],[7774,7862,"being your brother."],[7924,8108,"As wonderful as any dream could be."],[8508,8658,"But I think it's time to wake up."],[8746,8958,"If I had to choose again,"],[9192,9351,"I wouldn't choose this family."]],"38":[[1468,1568,"What's up guys?"],[1914,2072,"You chased him away."],[2072,2235,"This is all your fault!"],[2348,2494,"What the fuck, Arya?"],[2882,2994,"Your legs!"]],"39":[[58,208,"Your legs are fine."],[275,383,"Have you been pretending"],[383,517,"this entire time?"],[542,613,"No."],[671,767,"No. It's..."],[809,1001,"I also just found out, wow!"],[1067,1180,"It's a miracle guys."],[1180,1317,"Stop lying."],[1317,1459,"Just shut up!"],[1526,1689,"So Timothy was telling the truth"],[1689,1780,"the whole time."],[1901,1976,"I was wrong."],[1976,2147,"You've been lying to us!"],[2156,2264,"You bullied Timothy and"],[2264,2381,"made all of us play along!"],[2381,2452,"How could you?"],[2452,2590,"Mom, Dad, guys!"],[2681,2811,"I can stand."],[2873,2977,"Shouldn't we all be"],[2977,3111,"celebrating right now?"],[3278,3461,"What the hell is wrong with you?"],[3461,3599,"No, what the fuck is wrong with you?"],[3599,3720,"Hey, you watch your mouth!"],[3720,3862,"I'm your real son!"],[3945,4062,"He took everything from me!"],[4062,4179,"And I have every single right"],[4179,4266,"to take it back!"],[4300,4408,"It doesn't give you the right"],[4408,4546,"to treat him like that!"],[4621,4758,"He was also my son!"],[4758,4884,"I raised him!"],[4884,5021,"I'm gonna fucking kill you."],[5021,5134,"Oh bitch, please."],[5422,5480,"Stop!"],[5518,5630,"Calm down, Arya!"],[6206,6398,"Arya, he's still your brother!"],[6398,6485,"Arya, I know your heart is"],[6485,6581,"breaking for Timmy,"],[6581,6727,"mine is too, baby- - No."],[6727,6827,"Please, no, no, no,"],[6827,6956,"don't be rash, don't be rash."],[6956,7011,"Yes."],[7011,7044,"Okay."],[7044,7136,"I'm fine."],[7361,7478,"Crazy bitch."],[7753,7795,"Matthew."],[7841,7899,"Matthew!"]],"40":[[158,287,"Arya, you could've killed Matthew."],[287,362,"You know that, right?"],[362,467,"We just lost Timmy."],[508,633,"We can't lose Matthew too."],[692,813,"Well, if Timmy's not coming back,"],[813,946,"I'm not letting that asshole"],[946,1051,"back in either."],[1313,1459,"Doctor, how's our son?"],[1547,1676,"He has internal bleeding"],[1689,1835,"and he needs a transfusion,"],[1835,2018,"but we just ran out of type B blood."],[2147,2323,"Wait, aren't Mom and Dad type A?"],[2444,2610,"How can Matthew be type B?"],[2652,2781,"Two type A parents"],[2781,2957,"can't have a child with type B blood."],[3003,3119,"Unless they're not related."],[3294,3424,"No, we did a DNA test"],[3424,3553,"before taking Matthew home."],[3624,3712,"He's our son."],[4208,4291,"You know, something's off."],[4341,4479,"Let's ask Matthew directly."],[5480,5638,"Tell us the truth."],[5843,5960,"Who the hell are you?"]],"41":[[216,321,"Who the hell are you?"],[400,450,"What?"],[679,767,"I'm your brother."],[788,950,"Enough with the lies."],[996,1080,"We just found out that"],[1080,1205,"you are blood type B."],[1205,1422,"Our parents are blood type A."],[1514,1647,"Still keeping up the act?"],[1647,1768,"Oh, no, no, no, no, no."],[1768,1876,"There must be a mistake."],[1889,1964,"I swear to God,"],[1964,2047,"if this is another one of"],[2047,2218,"your little fucking lies,"],[2227,2402,"you're gonna wish you were dead."],[2907,2969,"Fine."],[3119,3215,"You caught me."],[3657,3737,"It's true."],[3924,4054,"I'm not your real son."]],"42":[[154,229,"It's true."],[433,546,"I'm not your real son."],[1309,1351,"What?"],[1397,1493,"What did you just say?"],[1589,1676,"Three years ago,"],[1705,1826,"when you came to the orphanage"],[1826,1976,"looking for your lost son, I..."],[2469,2644,"I knew it was my golden chance."],[2811,2982,"Couldn't let it just slip away, right?"],[3082,3182,"How could you?"],[3319,3461,"You played us for years."],[3461,3611,"We hurt Timmy because of you."],[3611,3762,"You harassed Timothy"],[3762,3949,"and you faked a DNA test?"],[3983,4124,"You're gonna pay for your crimes."],[4124,4229,"Who the fuck said that"],[4229,4396,"the DNA test was fake?"],[4738,4921,"All I did was just change the name."],[5176,5292,"Are you saying our real brother"],[5292,5422,"is still at the orphanage?"],[5509,5609,"Where is he?"],[5655,5801,"Who is my son?"],[6035,6218,"You stupid fucking bitch."],[6377,6452,"Your son"],[6519,6619,"has been by your side"],[6619,6710,"this whole time."],[6710,6886,"How could you not recognize him?"],[6886,7011,"Mother! - No."],[7236,7353,"Your real son"],[7653,7732,"is Timothy."]],"43":[[0,112,"No more lies."],[175,254,"The truth."],[275,342,"Now!"],[437,600,"You're pathetic, old man."],[742,842,"That is the truth."],[875,975,"Can't handle it?"],[1021,1201,"Oh, sorry."],[1309,1413,"Can't handle that you"],[1413,1559,"abused your real son?"],[1693,1751,"Oops."],[2156,2239,"Timmy."],[2369,2494,"This whole time,"],[2494,2711,"Timothy was our son."],[2761,2836,"Why?"],[2894,3094,"Matthew, why would you do this?"],[3123,3215,"Why?"],[3319,3516,"Why the fuck not?"],[3812,3974,"We were both orphans,"],[3974,4099,"but why did he get adopted"],[4099,4225,"by a loving, rich family"],[4225,4316,"that turned out to be"],[4316,4471,"his real fucking family?"],[4537,4742,"And I was still the unwanted one."],[5096,5180,"Fuck that."],[5296,5392,"But now."],[5538,5618,"Now he's dead."],[5739,5834,"I win."],[5851,6064,"I fucking win!"]],"44":[[604,767,"Fucking psycho!"],[767,930,"You stole his identity!"],[1167,1343,"That wasn't the only thing I did."],[1409,1651,"I also framed him for doing drugs"],[1651,1826,"and pushing me down the stairs."],[1826,1976,"A lot of random shit, really."],[2089,2293,"It all is so funny to me."],[2310,2548,"I played you guys like a fiddle."],[2615,2744,"But was it really me"],[2815,2944,"who did anything to him?"],[3169,3236,"No."],[3374,3574,"I was merely the puppet master."],[3653,3782,"You guys were the one"],[3782,3916,"who pulled the trigger."],[3924,4024,"You're an asshole."],[4129,4275,"You drove him to death."],[4396,4512,"I'm gonna make you fucking pay-"],[4512,4675,"I drove him to death?"],[4813,5030,"No, no, no, no, no, no."],[5038,5205,"Dearest family, no."],[5397,5501,"You all did."]],"45":[[95,216,"You say you love Timothy,"],[216,325,"but did you really?"],[329,387,"Shut up."],[387,462,"We-"],[462,621,"Especially you, Arya."],[667,763,"Whenever I framed him,"],[763,938,"you were the first one to punish him."],[1071,1155,"Was that love?"],[1313,1447,"And you, Gianna."],[1551,1739,"You seem all fair and reasonable,"],[1739,1956,"but I had to whine just a little bit"],[1956,2043,"and you would make him"],[2043,2202,"hand over everything to me."],[2256,2327,"Was that love?"],[2410,2494,"Please."],[2552,2627,"And you,"],[2736,2902,"my stupid little angel."],[3061,3282,"Timothy protected you with his life."],[3428,3578,"But with a few lies from me,"],[3578,3728,"you would turn on him instantly."],[3870,4037,"So much for love is blind."],[4387,4496,"But you two."],[4725,4879,"You take the cake."],[4971,5109,"You both clearly knew that"],[5109,5284,"I was in the wrong sometimes,"],[5342,5463,"but you still defended me"],[5463,5572,"because..."],[5643,5709,"What's that?"],[5809,6026,"Oh, because I was your real son."],[6256,6406,"You would punish him"],[6443,6677,"and you would toss him aside"],[6677,6848,"no matter how much he suffered."],[6956,7169,"Blood is thicker than water, am I right?"],[7169,7307,"Or am I right?"]],"46":[[58,237,"Is that what your love amounts to?"],[237,287,"Hm?"],[387,608,"Doubting him, neglecting him,"],[608,709,"breaking his heart."],[746,934,"You lost him."],[988,1180,"You brought that poor guy home"],[1213,1380,"and you kicked him out too."],[1697,1856,"I wasn't the one who killed him."],[2293,2473,"You all did!"],[2886,3165,"His precious family of Snyder!"],[3628,3812,"Mommy's so sorry Timothy."],[3903,4087,"I waited for you for so long."],[4308,4471,"I promised to love you."],[4633,4859,"And then I hurt you more than anyone!"],[5321,5455,"Fuck me."],[5568,5651,"I hurt Timothy"],[5651,5814,"and I will never forgive myself."],[5905,6047,"But I will make sure you suffer"],[6047,6222,"a hundred more times than he did."],[6247,6314,"Ooh."],[6364,6539,"You are going to live in misery"],[6539,6710,"for the rest of your days."],[6777,6886,"You will be repenting"],[6886,7052,"until the day that you die."],[7440,7595,"What the fuck?"],[7599,7782,"Where the fuck are you taking me?"],[7799,7920,"What the fuck?"],[7920,8128,"No sane person does this."],[8128,8249,"Take him to the asylum"],[8249,8345,"where he belongs."],[8358,8462,"What the fuck?"],[8462,8583,"Get your hands off of me!"],[8583,8771,"I'm the Snyder heir!"]],"47":[[617,775,"Mom, Dad, you guys are back!"],[867,988,"Oh, Timmy."],[1076,1130,"Oh!"],[1459,1685,"Oh, Timmy, baby, I'm sorry."],[1760,1931,"I'm so sorry."],[1931,2022,"Come here."],[2348,2556,"Mr. and Mrs. Snyder, my resignation."],[2644,2698,"What?"],[2823,2882,"But Miriam,"],[2882,3073,"you've worked for us for 20 years."],[3194,3261,"Are you in trouble?"],[3261,3361,"If so, we can help."],[3403,3632,"No, I wanted to retire for a while now."],[3724,3824,"Timothy was the only one"],[3824,3941,"who kept me here."],[3999,4091,"Now that he's gone,"],[4104,4237,"there's no reason to stay."],[4308,4500,"I collected the rest of his things."],[4533,4633,"I thought you could keep it"],[4633,4738,"to remember him by."],[5597,5651,"No."],[6010,6068,"Lawrence,"],[6068,6151,"what do we do?"],[6177,6289,"Wait, Miriam."],[6339,6431,"You still never told us"],[6431,6523,"what happened to him."],[6694,6806,"Did, did he really fake"],[6806,6973,"his own death to get away from us?"],[7294,7453,"You have all the answers you need"],[7453,7574,"to uncover the truth."]],"48":[[1055,1163,"Wait, what's this?"],[1743,1864,"He got a 4.0."],[1968,2085,"He was top of his class."],[2348,2435,"We didn't even know."],[2502,2585,"I thought that he was"],[2640,2831,"doing drugs and skipping school."],[3424,3490,"No."],[3707,3845,"Here's the necklace that he took off."],[4212,4329,"With all of our names on it."],[5125,5284,"These were the first pair of sunglasses"],[5284,5347,"he bought me."],[5730,5814,"I thought they broke."],[5939,5989,"Wait."],[6343,6448,"I bought these for him"],[6448,6627,"for Christmas, like, ten years ago."],[6627,6685,"I can't believe"],[6685,6840,"he kept them all these years."],[7240,7394,"It's a DNA screening report."],[7465,7611,"It's dated one month ago."],[7682,7757,"Why would he get a"],[7757,7862,"DNA screening report?"],[8170,8287,"Blood type A?"],[8808,8925,"Oh my God."],[8975,9029,"What?"],[9200,9342,"He's a carrier of the Pilgrim gene."],[9467,9601,"He's our one in a million."]],"49":[[333,379,"The day that we"],[379,475,"found the participant,"],[684,880,"Timothy missed the conference."],[975,1088,"And the day that he left"],[1197,1330,"was the day that the participant"],[1330,1455,"took off in the space shuttle."],[1472,1568,"I remember you saying"],[1568,1639,"something about"],[1639,1801,"NASX picking someone up?"],[2010,2189,"Someone who looked like Timothy."],[2277,2356,"What, what are you guys"],[2356,2448,"trying to say right now?"],[2602,2765,"No, no, no, no, no, no."],[2815,2915,"That's impossible."],[3219,3382,"Timothy wouldn't do this, would he?"],[3411,3499,"He wouldn't!"],[3591,3670,"Oh my God."],[3853,3941,"Oh my God."],[4045,4149,"Wait, Gianna, wait,"],[4149,4229,"where are you going?"],[4229,4287,"Do what?"],[4304,4404,"Oh my God, Arya."],[4416,4525,"Do you still not get it?"],[4529,4646,"Come on, let's go."],[4667,4750,"No, I..."],[4804,4859,"What?"]],"50":[[158,233,"Open up!"],[258,421,"Somebody open this door!"],[654,809,"Gianna, what are we doing here?"],[809,921,"I thought you found Timmy."],[921,1009,"Will somebody"],[1009,1130,"explain what's going on?"],[1172,1292,"Miss Gianna, I can't believe"],[1292,1438,"you're visiting our lab in person."],[1493,1622,"What can I do for you?"],[1697,1918,"You can tell me who the participant is."],[2077,2189,"Are you trying to say"],[2189,2323,"that it's Timothy?"],[2377,2485,"Think about it, Arya."],[2527,2681,"Timmy carries the Pilgrim gene."],[2752,2852,"Who else could it be?"],[2852,2990,"So you're saying that my son"],[2990,3132,"is alone in space?"],[3157,3265,"Look, that's impossible."],[3265,3345,"He would never do that."],[3345,3478,"He loves his family too much."],[3499,3707,"This is basically a death sentence."],[3716,3770,"Please."],[3770,3849,"Joanne,"],[3928,4145,"I need a firm, yes or no."],[4162,4220,"Miss Gianna,"],[4220,4346,"this goes against our policy."],[4346,4450,"Your brother asked to keep"],[4450,4571,"his identity a secret!"],[4975,5046,"Oh my God."],[5355,5451,"So I was right."],[5743,5830,"It was him."]],"51":[[621,717,"General McGee!"],[763,909,"It's only been three days."],[946,1088,"Surely we can bring the spacecraft"],[1088,1184,"back, right?"],[1217,1280,"Miss Snyder,"],[1280,1430,"you're a scientist yourself."],[1430,1622,"You know that's not possible."],[1651,1772,"The spacecraft was built"],[1772,1964,"for a one-way-trip to Planet Artemis,"],[1964,2039,"not back."],[2093,2231,"No, there must be something"],[2231,2323,"that we can do."],[2377,2464,"There has to be."],[2502,2623,"We brought a man to a new planet."],[2623,2761,"We can bring him back!"],[3078,3240,"Ma'am, I had the honor"],[3240,3361,"of meeting your brother."],[3374,3516,"And he's a fine young lad."],[3545,3712,"Smart, brave."],[3766,3870,"The one-in-a-million"],[3870,4033,"carrier of the Pilgrim Gene."],[4070,4204,"Even if we can turn that"],[4204,4295,"spacecraft around,"],[4295,4371,"what are you going to do?"],[4371,4592,"Just, just give up on Project Hail Mary?"],[5184,5309,"I don't know, I just..."],[5501,5651,"I never thought that it would be Timmy."],[5709,5851,"Ma'am, you said so yourself."],[5851,6014,"Humans are not built"],[6039,6227,"for long-term intergalactic travel."],[6268,6418,"Only carriers of the gene"],[6443,6635,"can last 30 years in a sleeping pod."],[6719,6810,"Your brother was also a"],[6810,6965,"cybernetics genius."],[7077,7173,"His skills"],[7194,7357,"will increase the chance of surviving"],[7357,7461,"on the new planet."],[7503,7699,"So if not Timothy, who?"],[8395,8554,"I at least wanna give him a message."]],"52":[[446,588,"By the time that you see this,"],[754,817,"I will be"],[817,975,"a middle-aged, old woman."],[1088,1209,"And you'll be on a new planet."],[1689,1801,"It's strange, isn't it?"],[1956,2022,"You'll wake up"],[2022,2318,"surrounded by a sky that I'll never see."],[2435,2494,"Breathing air that's"],[2494,2594,"never touched Earth."],[2911,2961,"I hope that"],[2961,3073,"it's beautiful there, Timmy."],[3461,3595,"I hope that it feels like..."],[3653,3778,"Like all the dreams we used to"],[3778,3924,"talk about when we were kids."],[3991,4129,"I'm so sorry, Timothy."],[4546,4688,"I wish that I had been kinder."],[4771,4859,"I wish that we hadn't"],[4879,5055,"pushed you away before you left."],[5221,5301,"I've replayed"],[5326,5522,"our last fight so many times"],[5568,5734,"that the words have worn thin. And,"],[5976,6126,"I wish that I could take it all back."],[6364,6460,"Every last word."],[6673,6756,"But I know you."],[7094,7228,"And I know that you would just laugh."],[7403,7574,"And you would tell me to stop crying."],[7695,7916,"And to just look at the stars instead."]],"53":[[62,175,"If the mission worked,"],[296,396,"and you are seeing this"],[396,504,"on that new world,"],[675,754,"then you made it."],[921,1038,"You really did it."],[1155,1301,"You're among the stars now."],[1476,1643,"And I just wanted to tell you"],[1643,1851,"how proud we are of you."],[2022,2122,"And that we are going to"],[2122,2277,"miss you terribly."],[2419,2531,"Even if we didn't say it."],[2877,2986,"Especially then."],[3307,3490,"Goodbye, my sweet little brother."],[3807,3962,"We hope that we'll get to see you again."]],"54":[[304,396,"Thirty years ago,"],[396,529,"Snyder Group and NASX"],[529,638,"successfully launched"],[638,742,"Project Hail Mary"],[775,934,"to ensure Earth's survival"],[934,1001,"despite Earth's"],[1001,1117,"continued deterioration."],[1197,1297,"In the last thirty years,"],[1297,1376,"we have successfully"],[1376,1480,"solved the problems of"],[1480,1697,"global warming and natural disasters"],[1697,1826,"thanks to the concerted efforts"],[1826,1926,"of Snyder Labs."],[2064,2185,"Even better news."],[2235,2293,"We have just"],[2293,2419,"received confirmation"],[2448,2581,"that Timothy Snyder"],[2602,2831,"has arrived on planet Artemis."],[2890,2977,"He really did it."],[3174,3257,"Of course he did."],[3274,3349,"It's Timmy."],[3399,3486,"It's our baby brother."],[4308,4466,"Timothy is such a genius."],[4491,4592,"He's already set up a base"],[4592,4692,"on the new planet."],[4729,4888,"His first batch of data came back,"],[4888,5000,"and planet Artemis"],[5000,5130,"can fully support human life."],[5238,5347,"He's even turned the spaceship"],[5347,5397,"into a new"],[5397,5522,"communications device."],[5522,5655,"We've been going back and forth, and,"],[5980,6031,"I'm sorry."],[6089,6193,"I, that was..."],[6222,6289,"That was inconsiderate."],[6289,6352,"It's okay."],[6439,6498,"Joanne."],[6756,6890,"I know somewhere out there,"],[7036,7203,"he's watching a new sunrise."],[7440,7545,"And I finally understand"],[7545,7645,"why he had to go."],[7866,7966,"That's enough for me."]],"55":[[1180,1372,"Sol 134."],[1555,1634,"Sunny."],[1722,1964,"It's about 28 degrees Fahrenheit."],[2147,2243,"It's gonna be a good day."],[2961,3036,"What's up, buddy?"],[3057,3148,"How are you feeling?"],[3261,3357,"Timothy."],[3386,3624,"Checking in on your eye."],[3778,4045,"Do you require a bandage change?"],[4095,4137,"No."],[4250,4325,"My eyes are all good."],[5359,5551,"No, no, no, no!"],[5568,5739,"No, let me out!"],[5793,5885,"Let me out!"],[5885,6031,"I'm not crazy!"],[6081,6452,"No, let me out, I'm the Snyder heir!"]]}