{"1":[[25,171,"Special offer today!"],[171,308,"Buy one, get one free!"],[308,364,"Jennifer!"],[408,492,"You're fired!"],[658,704,"What?!"],[754,842,"What did I do?"],[842,946,"Shut your trap!"],[1013,1146,"We're replacing you"],[1146,1305,"with someone who is more"],[1305,1401,"qualified."],[1401,1478,"Oh, who?"],[1826,1906,"What the hell?"],[2002,2056,"A dog."],[2122,2260,"You're replacing me with a dog?"],[2314,2406,"In this business,"],[2406,2590,"an old hag like you"],[2590,2865,"has less value than a dog."],[2919,2977,"Now,"],[2977,3053,"get"],[3053,3119,"out!"],[3269,3345,"You know what you are?"],[3395,3461,"An asshole!"],[3745,3837,"I'll be okay."],[3878,4037,"I still have my house and my loving son."],[4400,4458,"SOLD?"],[4500,4621,"My house isn't for sale."],[5146,5201,"Quick!"],[5201,5242,"Run!"],[5296,5401,"Look, Daniel, Rebecca,"],[5401,5491,"what the hell is going on?"],[5518,5580,"Sorry, Mom..."],[5580,5739,"Rebecca forced me to make some investments"],[5739,5814,"and it went south."],[5860,6018,"I had to sell the pension and the house"],[6018,6085,"to pay the debt."],[6095,6139,"What?"],[6139,6281,"Daniel, how could you do this to me?"],[6281,6381,"I..."],[6731,6777,"Come on!"],[6956,7019,"Daniel!"],[7098,7294,"It's all your fault, you old fart!"],[7361,7490,"If you hadn't gotten divorced,"],[7490,7612,"Daniel would've grown up rich!"],[7645,7703,"It's only fair"],[7703,7853,"that you owe him the house and your pension."],[7903,8028,"How can you even say that?"],[8028,8179,"You know that my ex-husband,"],[8179,8404,"he was a cheating bastard."],[8404,8466,"No!"],[8596,8646,"We have to go."],[8646,8750,"The creditors are coming."],[8821,8913,"And you?"],[8913,9035,"We're going to his rich daddy."],[9079,9271,"Don't ever contact us again!"],[9271,9305,"No..."],[9305,9371,"Daniel!"],[9417,9484,"Daniel!"],[9605,9684,"Fuck you!"],[9797,9972,"I've lost everything..."],[10005,10093,"God..."],[10093,10259,"what am I supposed to do now?"],[11257,11344,"Diamond Bachelor?"],[11394,11561,"The love reality TV show?"],[11653,11807,"Food and accommodation provided?"],[12445,12637,"L.A.'s wealthiest bachelor,"],[12637,12816,"the legendary Paul Marshall"],[12816,12979,"joins “Diamond Bachelor”."],[13025,13263,"His business empire includes aerospace,"],[13300,13601,"real estate, solar energy and AI."],[13663,13797,"An adventure seeker,"],[13797,14018,"Paul wants a partner with zest for life-"],[14018,14214,"and a heart as pure as his own."],[14272,14431,"Four stunning women."],[14431,14685,"One irresistible billionaire."],[14685,14777,"The stakes?"],[14777,14873,"His heart."],[14873,14956,"But in the end,"],[14956,15152,"only one will capture it."],[15152,15261,"Who will it be?"],[15261,15423,"Tune in and find out."],[15423,15498,"This is too much."],[15603,15644,"What?"],[15703,15761,"Why, Dad?"],[15903,16074,"Look, if you want me to get on this show,"],[16074,16182,"I'll do it."],[16182,16278,"Just one condition—"],[16433,16583,"I keep my identity secret."]],"2":[[35,81,"Fine."],[105,250,"I'll have them reshoot the promo."],[308,442,"I don't mean to be pushy, I just..."],[479,673,"want someone to care for you and love you, Dad."],[884,955,"I know, sweetheart."],[1013,1107,"Going undercover is the only way"],[1107,1208,"I'll find true love."],[1705,1910,"I can't believe it's happening!"],[1910,2214,"I'm going to be on a Bachelor reality TV show."],[2256,2335,"Gotta find work"],[2335,2449,"while I film here."],[2640,2686,"Watch out!"],[4020,4104,"You're..."],[4104,4225,"one of the contestants on the show?"],[4250,4366,"Ah, yeah, I am."],[4408,4517,"GRANNY ALERT!"],[4604,4758,"Looks like we got a granny,"],[4758,4884,"phishing for a sugar daddy."],[4959,5046,"I didn't know this was"],[5046,5146,"“The Diamond Bachelor:"],[5146,5330,"Retirement Home Edition.”"],[5488,5651,"I'm not here to compete."],[5651,5754,"I'm here to show you"],[5754,5880,"what a real woman looks like."],[6122,6247,"You old hag!"],[6247,6360,"Know your place!"],[6360,6464,"You're dead!"]],"3":[[8,87,"Damn!"],[87,221,"My face!"],[221,342,"I have decades of grit,"],[342,467,"hands that built a life,"],[467,575,"and a right hook"],[575,709,"that doesn't miss."],[727,784,"You know what?"],[784,825,"Forget it."],[825,942,"The show's about to start."],[942,1130,"She's getting booted, anyway."],[2118,2285,"What a fascinating woman."],[2861,3028,"Tonight's bachelor is..."],[3028,3174,"Paul Marshall."],[3528,3599,"He's a..."],[3682,3745,"huh?"],[3874,3995,"A... truck driver?"],[4200,4454,"He is a hardworking, funny guy"],[4454,4496,"who is..."],[4496,4554,"Hold up!"],[4662,4817,"A truck driver?!"],[4817,4921,"Yeah, what is this?"],[4971,5188,"Bum on the Run or Diamond Bachelor?"],[5188,5238,"Yeah!"],[5238,5326,"Get him out of here"],[5326,5445,"and bring in someone rich!"],[5568,5755,"Are you looking for love, or an ATM?!"],[5755,5851,"Please."],[5851,5922,"What is this?"],[5922,6039,"Washed-up,"],[6039,6189,"menopause lady,"],[6189,6367,"and a broke truck driver?"],[6410,6489,"Anyone..."],[6489,6645,"that doesn't want to continue..."],[6710,6918,"can just pay the penalty and leave!"],[7169,7286,"Four contestants,"],[7357,7502,"three roses."],[7565,7753,"If you don't receive a rose,"],[7753,7811,"you"],[7811,7857,"are"],[7857,7917,"out."],[7978,8191,"The first rose recipient"],[8191,8291,"gets a..."],[8337,8537,"one-on-one date."],[9480,9601,"Will you join me on a date?"],[9955,10043,"Wait a damn minute."],[10101,10231,"This guy is Paul Marshall,"],[10301,10456,"the wealthiest man in L.A.!"]],"4":[[41,133,"It's not... me."],[212,352,"The real billionaire is someone else."],[392,500,"You might wanna double-check that."],[663,771,"Good thing I came prepared."],[1184,1242,"Okay,"],[1242,1356,"so it's just a name mix-up..."],[1413,1472,"You really are"],[1472,1579,"just a driver!"],[1793,1835,"Paul,"],[1872,2140,"you can only give one rose per contestant."],[2193,2347,"I'm giving them all to Jennifer."],[2690,2769,"Well,"],[2769,2919,"I guess we can't eliminate"],[2919,3069,"anyone now, can we?"],[3282,3403,"Let's move on to the next date,"],[3403,3470,"shall we?"],[4308,4500,"Oh my god, he's such a loser."],[4583,4692,"Of course the producers picked"],[4692,4817,"the one sport I suck at."],[4925,5075,"What a total loser."],[5075,5138,"What kind of man"],[5138,5267,"doesn't know how to ice skate?"],[5355,5541,"Absolutely pathetic."],[5563,5905,"Loser! Loser! Loser! Loser..."],[5905,6014,"Hey, producer."],[6074,6268,"Could you please get the extras off the rink?"],[6268,6418,"It's supposed to be a one-on-one date."],[6519,6610,"Yes, get off!"],[6656,6823,"You heard her, ladies."],[6823,6902,"Off to the corner."],[6986,7057,"Come on, shoo."],[7428,7503,"Okay, just..."],[7503,7603,"don't listen to them."],[7603,7741,"I'm really good at skating."],[7741,7811,"Just here."],[7811,7870,"Just let me show you."],[8525,8629,"Hey!"],[8850,8950,"Alright!"],[8950,9063,"Whoo!"],[9134,9230,"Hey, this is fun!"],[9463,9517,"So,"],[9567,9622,"Jennifer,"],[9676,9809,"did you come on this show"],[9809,9939,"to find true love?"]],"5":[[116,166,"Well..."],[229,316,"actually..."],[367,571,"I came onto the show because I'm..."],[692,746,"homeless..."],[842,905,"and..."],[955,1030,"broke."],[1134,1251,"What happened?"],[1305,1376,"It's a..."],[1426,1551,"It's a long story."],[1893,2056,"I can't believe this happened to you."],[2110,2256,"Your house, your pension..."],[2577,2648,"I have to find a way"],[2648,2706,"to help you."],[3061,3224,"That's very kind of you."],[3336,3415,"But..."],[3415,3478,"Paul..."],[3553,3695,"why did you come onto this show?"],[4049,4207,"My daughter dragged me into this,"],[4295,4379,"but..."],[4500,4658,"maybe I came for the right reasons."],[4921,4984,"Jennifer..."],[5084,5230,"do you believe in love at first sight?"],[5384,5438,"Yeah,"],[5501,5584,"I do."],[5876,6014,"Cue the ambiance!"],[7824,7928,"The moment I saw you,"],[8003,8058,"I knew..."],[8133,8291,"you're the one I've been searching for."],[8550,8700,"My ideal partner..."],[9984,10055,"Will you..."],[10222,10322,"A proposal?!"],[10385,10464,"No way!"],[10485,10543,"Paul!"],[10623,10802,"We've just started rolling!"],[10802,10990,"Stick to the program, okay?"],[11156,11282,"I only wanna follow my heart."],[11344,11407,"Jennifer,"],[11436,11536,"will you..."],[11611,11674,"Paul."]],"6":[[100,296,"We signed a contract."],[487,663,"We should follow the show's rules."],[804,871,"Guess I have to wait"],[871,950,"for a better moment."],[1201,1263,"Alright."],[1334,1409,"Next up..."],[1443,1647,"is our one-on-four pool party!"],[2631,2766,"Oh, Paul..."],[2766,2930,"You used to serve in the Navy, didn't you?"],[3048,3132,"He's got the looks."],[3132,3319,"Too bad he's a lousy driver."],[3319,3395,"You keep saying that"],[3395,3528,"like you're some kind of royalty."],[3599,3691,"What's wrong, grandma?"],[3749,3958,"Too scared to show some skin?"],[3958,4079,"Why would she do that?"],[4079,4320,"Her boobs are sagging past her waist by now."],[4458,4608,"I just don't want my body to be the reason"],[4608,4758,"you drop dead from jealousy."],[4758,4854,"What a crock of shit!"],[5330,5430,"Stay out of my way."],[6464,6533,"Oh, my God!"],[6533,6639,"She can't swim!"],[7065,7144,"I got... I got you."],[7399,7469,"Towel!"],[7970,8074,"What's wrong, grandma?"],[8124,8274,"Thought you had a hot body"],[8274,8470,"that'd make us die from jealousy?"],[8541,8596,"Show us!"],[8633,8746,"Now that you're naked."],[8746,8871,"Touch her again and you'll regret it."],[8871,8963,"Who do you think you are?"],[8963,9098,"You're just a stupid driver!"]],"7":[[20,125,"I have the power to..."],[179,354,"I can't reveal my identity yet."],[479,538,"Doesn't matter."],[654,744,"You'll pay for this."],[775,821,"Phone!"],[821,955,"Who do you think you're calling?"],[988,1055,"Show-off?"],[1184,1242,"Police!"],[1276,1417,"You're under arrest for attempted murder."],[1480,1534,"What?"],[1626,1692,"I quit!"],[1718,1813,"Yeah, I quit too."],[2268,2352,"Let's get you dried off,"],[2352,2477,"so you don't catch a cold."],[2477,2552,"You too!"],[2873,2973,"It's... It's over!"],[3065,3140,"I have..."],[3140,3207,"no..."],[3207,3285,"contestants."],[3336,3445,"The show..."],[3445,3507,"is..."],[3586,3678,"ruined!"],[3737,3878,"I'll get you some more contestants."],[3949,4079,"I just need you to do me one favor."],[5000,5100,"Oh my God!"],[6010,6085,"Jennifer..."],[6289,6381,"will you marry me?"],[6731,6815,"Isn't that..."],[6815,6919,"a bit too soon?"]],"8":[[87,220,"I almost lost you just now."],[342,462,"I don't wanna wait another second."],[604,684,"All I know is..."],[784,850,"I like you."],[1005,1098,"And I can't wait to"],[1098,1243,"spend the rest of my life with you."],[1468,1568,"Well, at any age,"],[1568,1685,"we don't have any time"],[1685,1768,"to waste, so..."],[1835,1968,"If something feels right,"],[1968,2064,"we should hold on to it."],[2181,2306,"Yes, Paul!"],[3361,3447,"You're now officially"],[3447,3573,"husband and wife."],[3770,3832,"Well,"],[3832,3991,"now that you're officially my wife,"],[4045,4149,"I wanna get to know you."],[4195,4229,"Well,"],[4229,4415,"you're just gonna have to figure me out."],[4600,4742,"But I do hate being lied to."],[4879,5046,"I need to tell her the truth."],[5117,5188,"Actually,"],[5188,5305,"Jennifer, I need to tell you"],[5305,5447,"something about my identity."],[5447,5522,"Mr. Marshall,"],[5563,5701,"can I get a picture with you?"],[5747,5926,"I am such a huge fan!"],[6031,6097,"Wait,"],[6097,6256,"since when did you have fans?"],[6377,6506,"Are you kidding?"],[6560,6794,"Mr. Marshall is a legend!"],[6856,6919,"L.A.'s.."],[6919,6994,"self-made..."],[6994,7082,"billionaire!"],[7144,7211,"Wait!"],[7211,7248,"What?"],[7248,7436,"You have been lying to me this whole time?"]],"9":[[41,116,"Me?"],[116,367,"No, I'm just a regular old truck driver."],[367,554,"You must be mixing me up with somebody else."],[554,646,"Oh,"],[646,884,"this must be some kind of rich guy kink!"],[955,1088,"Alright, I'll play along."],[1088,1151,"Oh..."],[1217,1288,"Wait."],[1288,1438,"Actually, you're right, sir."],[1547,1680,"I'm sorry for the mistake."],[1785,1978,"My eyesight is awful."],[2139,2206,"Whew, thank god,"],[2206,2406,"because if you had been lying to me,"],[2406,2527,"it would be the end of us."],[2631,2681,"Yeah..."],[2681,2823,"definitely not the right time to tell her."],[2936,3071,"I can take the picture for you."],[3274,3379,"C'mon, get cozy!"],[3436,3564,"Go in for a kiss!"],[3745,3787,"Wait..."],[3832,4111,"This isn't some scam wedding, is it?"],[4112,4225,"No, of course not!"],[5267,5309,"Hello?"],[5402,5475,"Right now?"],[5659,5755,"Okay, um,"],[5755,5828,"I'll be there soon!"],[6068,6235,"I'm really sorry, but I have to run."],[6235,6293,"Now?"],[6293,6348,"Yeah..."],[6410,6510,"Sorry!"],[6573,6635,"Bye!"],[7002,7102,"Does she have secrets, too?"]],"10":[[12,150,"Does she have secrets, too?"],[663,704,"Yeah..."],[750,925,"what did you find out about Jennifer's ex?"],[1059,1134,"Where does he live?"],[1263,1317,"Hello?"],[1647,1780,"Well, well..."],[1780,1922,"my ex-wife..."],[1922,2043,"applying to be my maid?"],[2202,2423,"That's a plot twist I did not see coming."],[2452,2540,"Oh..."],[2540,2615,"Jennifer..."],[2656,2869,"Scrubbing toilets at fifty?"],[2869,2990,"How tragic."],[2990,3098,"I, for one, have never done"],[3098,3236,"a day's worth of housework"],[3236,3330,"in my entire life."],[3382,3474,"But some of us..."],[3507,3657,"are just born for luxury."],[3695,3778,"And some people are"],[3778,3924,"just born to be mistresses."],[3924,3987,"You're not even worth"],[3987,4116,"scrubbing my toilets!"],[4583,4788,"But I can wash your filthy mouth, asshole!"],[4788,4917,"—Mom... —Mom!"],[5196,5347,"How dare you hurt my mother?!"]],"11":[[41,112,"Daniel,"],[112,287,"you called this bitch... Mom?!"],[429,571,"What? You think a poor loser like you"],[571,679,"deserves that title?"],[679,738,"Daniel!"],[784,930,"I am your mom!"],[930,1013,"Sorry..."],[1084,1167,"Lily..."],[1167,1284,"wants us to call her mom."],[1284,1468,"She paid off our million-dollar debt."],[1468,1572,"Did you think"],[1572,1760,"that your little toilet-scrubbing job"],[1760,1851,"could compare?"],[1906,1976,"Fine."],[1976,2118,"From today, we're done, but..."],[2147,2223,"Please,"],[2223,2473,"just give me back my house, my pension!"],[2473,2523,"Cheapo!"],[2523,2711,"Stop complaining about your pocket change!"],[3682,3741,"Daniel,"],[3916,4041,"break her..."],[4079,4149,"legs."],[4426,4521,"Wait, no, this..."],[4683,4788,"This is too far..."],[4821,4942,"Just do it."],[4955,5146,"I'll set you up with a new company."],[5497,5605,"I have a better idea."],[5670,5742,"No..."],[6744,6865,"No!"]],"12":[[967,1080,"Who the hell are you?!"],[1192,1272,"Her husband."],[1697,1801,"You're trash!"],[1881,2027,"How dare you"],[2027,2168,"act like this on my turf?!"],[2306,2419,"I'll crush you!"],[2581,2711,"Jack's a dangerous man."],[2790,2957,"What if he retaliates against Paul?"],[3036,3182,"Paul, I'm fine."],[3182,3282,"Okay? Just..."],[3357,3461,"How'd you even get here?"],[3607,3695,"I promised you I'd help you"],[3695,3802,"get your house back."],[3895,4054,"And I heard your son was nearby."],[4337,4412,"Can't believe you've kept that"],[4412,4531,"in your heart all this time."],[4975,5217,"So, you've stolen my wife's house and pension?"],[5217,5341,"She owes us!"],[5680,5799,"Give her back the money."],[5960,6068,"I don't have the ca..."],[6068,6137,"I don't have the money!"],[6153,6221,"Dad!"],[6240,6335,"Do something!"],[6335,6423,"I'm not giving this"],[6423,6594,"bastard a damn thing!"],[6919,6990,"How about..."],[6990,7161,"I practice my drive on your neck, huh?"],[7286,7336,"Here."],[7482,7545,"Take this."],[7586,7682,"Just don't hurt us."],[7720,7821,"$50,000.00"],[8053,8174,"Listen to me very carefully."],[8237,8416,"If you ever hurt Jennifer again,"],[8512,8625,"you'd wish you were dead."],[9680,9797,"Jack, are you okay?"],[9797,9940,"Those bastards..."],[10055,10114,"I'll make them"],[10114,10211,"pay for this!"],[10456,10510,"Paul?"],[10556,10702,"Who were those men and..."],[10744,10808,"Who's that guy?"],[10885,11098,"Some security guys from the company."],[11098,11178,"And that's my assistant."],[11461,11544,"Okay. Um..."],[11619,11669,"Just..."],[11724,11803,"thank you..."],[11803,11886,"for protecting me."],[11928,12112,"If anything ever happens,"],[12208,12341,"you need to tell me right away."],[12433,12479,"Promise?"],[12587,12652,"Promise."],[12837,12883,"Hey."],[12921,13067,"Dad, how's the show going?"],[13067,13192,"I'm already married now, Emma."],[13309,13355,"What?!"]],"13":[[162,275,"So..."],[275,391,"you're my dad's new wife,"],[411,508,"huh, Jennifer?"],[646,829,"Hi, Emma, it's nice to finally meet you."],[942,1130,"She really locked him down that fast."],[1159,1301,"Must be a pro at gold-digging."],[1551,1659,"You know our situation,"],[1693,1739,"right?"],[1805,1925,"We don't own this house."],[1939,2018,"It's rented."],[2052,2189,"My dad's salary isn't much and..."],[2218,2289,"I'm adopted."],[2331,2544,"Are you sure you want to move in with us?"],[2694,2877,"I never imagined you'd be so caring, Paul."],[2961,3044,"My ex-husband,"],[3044,3164,"he lost my daughter"],[3164,3311,"and I've never been able to find her."],[3474,3570,"I've always hoped that"],[3570,3720,"she'd find someone as kind as you."],[3795,3937,"I didn't know you lost your daughter."],[4496,4596,"I'll help you find her."],[4904,5013,"It's an emergency."],[5013,5096,"We need to locate"],[5096,5301,"and recover Jennifer's daughter for the CEO."],[5301,5380,"Yes, sir!"],[5488,5739,"Well, you truck drivers do travel nationwide!"],[5739,5910,"So, I'm sure you'll find her in no time."],[5968,6014,"Of course."],[6081,6131,"Emma,"],[6193,6379,"thank you so much for being honest with me."],[6443,6648,"Actually, my situation is worse,"],[6648,6902,"but your father, he never once judged me for it."],[7036,7169,"I believe if we..."],[7207,7319,"stay together,"],[7319,7431,"life will just get better."],[7553,7659,"She seems genuine."],[7695,7803,"Not like the others."],[8254,8316,"How does it taste?"],[8331,8379,"This..."],[8379,8425,"tastes like..."],[8470,8575,"my mom's cooking!"],[8608,8666,"Mom,"],[8666,8863,"this is the best spaghetti I've ever had"],[8863,8975,"in the whole world."],[9221,9321,"Do you think you could..."],[9321,9442,"make this for me more often?"],[9542,9655,"Of course!"],[9989,10055,"So, sweetheart,"],[10110,10210,"where do you wanna sleep tonight?"]],"14":[[58,221,"Oh, is it okay if we..."],[221,400,"sleep separately tonight?"],[558,625,"Sure."],[809,892,"Your room's down there."],[1655,1739,"Hey, Emma."],[1739,1801,"You're a woman."],[1872,2006,"How do I romance Jennifer?"],[2060,2102,"Easy."],[2143,2260,"We love two things."],[2323,2435,"Good food and hot men."],[2531,2665,"Just seduce her, Dad."],[4237,4462,"I make my wife the best damn breakfast ever!"],[5188,5256,"Hey, Emma..."],[5301,5394,"For fried eggs,"],[5394,5605,"do I use the white eggs or the beige ones?"],[5676,5793,"You've never been in a kitchen."],[5826,6014,"Dad, please don't poison Jennifer."],[6068,6268,"I run multi-billion-dollar companies."],[6268,6377,"I can't make breakfast?"],[8195,8237,"Whoa!"],[8283,8341,"Uh..."],[8712,8762,"Uh..."],[8800,8863,"Help! Help!"],[9121,9223,"Paul! Are you okay?!"],[9338,9384,"Sorry, babe."],[9384,9492,"I was trying to make you breakfast"],[9492,9572,"and I ruined it."],[9872,9934,"Okay."],[10068,10226,"Just let me take over and..."],[10256,10331,"you can help me."],[10593,10684,"Maybe, uh..."],[10709,10828,"maybe we both want something"],[10828,10958,"different for breakfast."]],"15":[[191,261,"Microwave!"],[392,471,"Oh, shoot!"],[1030,1167,"What were you trying to do?"],[1739,1881,"This is five hundred dollars?"],[1902,1964,"Mm!"],[2102,2143,"What?"],[2185,2333,"Never seen a microwave before?"],[2414,2548,"This is high-end stuff."],[2627,2754,"But if you can't afford it,"],[2823,2947,"maybe you should just..."],[2988,3053,"leave."],[3128,3188,"Okay, excuse me,"],[3188,3264,"what's with the attitude?"],[3370,3452,"Get lost, peasant!"],[3465,3589,"You're ruining the air in here!"],[3837,3958,"Harassing the customers?"],[3991,4104,"PM Mall doesn't tolerate"],[4104,4200,"clerks like you."],[4320,4379,"Big talk!"],[4433,4546,"And who do you think you are,"],[4579,4696,"the chairman of the board?"],[4817,4875,"Hey,"],[4875,4971,"what's all the noise?"],[5305,5401,"Cha-ch-Chairman..."],[5488,5534,"Wait,"],[5534,5592,"wait, what?"],[5634,5680,"Manager,"],[5714,5809,"get security!"],[5860,6076,"And throw those poor losers out!"],[6076,6153,"Shut up!"],[6202,6348,"You call us “poor losers”?"],[6439,6694,"Is this how PM Mall trains his staff now?"],[6694,6781,"Oh, please, sir,"],[6781,6835,"calm down."],[6906,6998,"You! You're fired!"],[6998,7077,"Get out of here."],[7474,7662,"I'm really terribly sorry about that."],[7703,7801,"Your purchase today"],[7816,7908,"will be on the house."],[7941,8016,"Wait, really?"],[8053,8091,"Yes."],[8166,8233,"Okay, well, we'll just"],[8233,8295,"take this one."],[8341,8395,"Okay."],[8395,8541,"You sure you don't want a fancier one?"],[8625,8728,"Don't be greedy."],[8933,8998,"How about these?"],[9059,9150,"Am I being greedy?"],[9150,9230,"Of course not!"],[9476,9626,"Okay, let me help you with that."],[10018,10064,"Wait..."],[10114,10236,"This is Patek Philippe?!"],[10251,10312,"Uh-oh."]],"16":[[137,221,"It's a prop..."],[266,329,"from the show."],[329,383,"It's fake."],[583,633,"Fake?!"],[667,784,"This is a global"],[784,871,"limited edition..."],[905,988,"Patek Philippe!"],[1509,1655,"Heard it can track your vitals."],[1655,1881,"Let's see what your heart rate is."],[1956,2093,"Oh my god, 120 BPM?!"],[2093,2185,"That is not normal!"],[2185,2289,"We need to take you to a doctor,"],[2289,2348,"right n..."],[2348,2410,"Jennifer,"],[2464,2535,"I'm alright."],[2594,2677,"It's because you're here."],[2723,2831,"You make my heart race."],[3743,3820,"We're honored to"],[3820,3991,"welcome today's guest-"],[3991,4083,"Paul Marshall,"],[4083,4275,"CEO of PM Group."],[4358,4479,"Mr. Marshall..."],[4479,4604,"That's the billionaire with your name!"]],"17":[[83,154,"Shit."],[154,383,"I forgot to handle that interview!"],[775,950,"That was way too close!"],[950,1067,"Good thing I followed them!"],[1084,1155,"Wait..."],[1155,1299,"Okay, what just happened?"],[1322,1388,"The guy on the screen..."],[1388,1605,"he looked exactly like you."],[1605,1685,"Well..."],[1685,1743,"I..."],[1922,1993,"It's fake."],[2027,2145,"I tried to make my dad look like"],[2145,2302,"a billionaire for The Diamond Bachelor."],[2481,2590,"But faking to be rich"],[2590,2811,"isn't that just plain old lying?"],[2811,2911,"But he refused."],[2911,3069,"He didn't want to look like some rich playboy."],[3069,3136,"Yeah, totally."],[3182,3324,"Well, that's what I love about you-"],[3324,3386,"Your honesty."],[3995,4054,"Got it."],[4091,4149,"I'll be right there."],[4471,4575,"I've got some work to do."],[4625,4742,"Let Emma take you shopping-"],[4788,4842,"on me."],[4904,5075,"No need, it's...it's fine."],[5075,5125,"Don't worry."],[5125,5255,"A good wife never takes away"],[5255,5426,"her husband's chance to spoil her."],[6210,6260,"How about this one?"],[6339,6445,"Classy, timeless?"],[6475,6552,"Let's go here."],[6727,6769,"Wait..."],[6877,7035,"you-you're buying lingerie?"]],"18":[[37,147,"Even us middle-aged women"],[147,274,"like a little bit of excitement"],[274,372,"now and then, Emma."],[397,450,"Plus,"],[483,567,"I am a newlywed,"],[671,750,"if you know what I mean."],[1655,1701,"Hey, Dad,"],[1755,1818,"come home early."],[1868,1951,"There's a surprise."],[2014,2089,"A surprise?"],[2323,2385,"Sounds good."],[2623,2727,"Hey, Emma..."],[2727,2844,"Do you think I should"],[2844,2969,"tell Jennifer the truth?"],[3053,3190,"Lying won't work fo