want to"],[3545,3720,"ask you if you um..."],[4091,4158,"hold that thought."],[4496,4525,"Hello?"],[4525,4612,"Madison's phone."],[4642,4767,"Personal cowgirl trainer"],[4767,4871,"Beau Hayes here."],[5305,5376,"It's for you."],[5426,5501,"It's Taylor."],[5830,5935,"Beau, wait!"]],"34":[[271,379,"It's been weeks"],[379,538,"since Beau Hayes kissed me."],[608,817,"I haven't even seen him at the saloon."],[1142,1238,"I don't know why,"],[1238,1422,"but I think he's avoiding me."],[1505,1856,"And I don't know why, but I hate it."],[2306,2510,"The only upside is I'm almost done"],[2510,2631,"paying Beau back."],[2840,3032,"And just in time because my mom"],[3032,3199,"is finally feeling better."],[3478,3566,"Downside?"],[3607,3757,"I still have to pay to get us both"],[3757,3853,"back to New York."],[3953,4024,"Hey Maddie."],[4024,4129,"Hey!"],[4175,4329,"I wouldn't normally cut anyone in"],[4329,4471,"on such a sweet deal,"],[4471,4533,"but I see how hard"],[4533,4596,"you've been working."],[4771,4871,"Do you want to bartend a private"],[4871,4938,"event with me?"],[5105,5255,"It's a fancy engagement party"],[5255,5326,"at a ranch,"],[5326,5355,"It's-"],[5355,5459,"Yes, Bonnie,"],[5459,5563,"thank you so much."],[5647,5730,"You're welcome."],[7069,7236,"I'm working my ex-fiance's"],[7236,7357,"engagement party?"]],"35":[[183,350,"Did I just hear what I think I heard?"],[379,521,"Luke Bryan isn't"],[521,625,"playing at our wedding?"],[667,771,"Was I supposed to charter a jet"],[771,900,"to fly him from tour for one night?"],[1046,1180,"Need I remind you,"],[1180,1305,"that my mama is the one"],[1305,1476,"promising to invest in your ranch?"],[1493,1555,"But you know,"],[1555,1730,"if this is too much for you,"],[1730,1851,"we can just call it all off."],[1851,1901,"Wait, no, no."],[1901,1956,"You're right."],[1997,2060,"I'll make it right."],[2060,2135,"I promise."],[2160,2223,"Good."],[2277,2402,"Because I deserve everything."],[2435,2527,"Don't I, sweetie?"],[2560,26