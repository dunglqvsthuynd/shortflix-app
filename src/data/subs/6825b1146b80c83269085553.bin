n I just..."],[2373,2590,"do this?"],[3428,3578,"Dinner has arrived!"],[3578,3641,"Taylor!"],[3641,3682,"Oh..."],[3858,3933,"That's Taylor?"]],"26":[[16,83,"Who are you?"],[291,425,"What are you doing in my home?"],[658,754,"I'm Beau Hayes."],[838,963,"Madison invited me."],[1021,1138,"Well, it's getting late."],[1184,1409,"If you're tired, you should go to bed."],[1680,1868,"Maybe, you're both right."],[1885,1972,"It is getting late"],[1972,2177,"and I'm getting tired."],[2177,2231,"So..."],[2381,2498,"Bye, Beau."],[2577,2681,"Does she seriously like him"],[2681,2752,"more than me?"],[2840,2927,"Why does that make me"],[2927,3023,"so goddamn mad?"],[4070,4145,"What was that?"],[4275,4400,"Did he do this to you?"],[4441,4500,"No."],[4537,4608,"Tay, he..."],[4708,4800,"saved me."],[4800,5046,"Some asshole at the bar got handsy."],[5046,5146,"He punched the dude."],[5146,5213,"It's fine."],[5292,5388,"So much for your knight"],[5388,5501,"in shining armor, huh?"],[5647,5776,"I'm worried about you, Maddie."],[5814,6001,"This Beau Hayes guy."],[6001,6143,"I don't think spending time"],[6143,6264,"with him is smart."],[6289,6564,"Well, thanks for your concern, friend."],[6606,6656,"But,"],[6694,6785,"I'm fine."],[7044,7248,"Why do I want to defend Beau?"],[7307,7457,"Do I have feelings for him?"]],"27":[[383,454,"Here you go."],[533,679,"Hope you're winning."],[754,855,"One for you too."],[880,930,"Amazing."],[946,996,"Can I get you-"],[1046,1130,"Max!"],[1130,1222,"What are you doing?"],[1222,1317,"Let go of me!"],[1397,1443,"What are you doing"],[1443,1551,"even working here, Madison?"],[1609,1718,"Trying to break up my engagement"],[1718,1818,"so you can win me back?"],[1926,2122,"Believe it or not, Max,"],[2122,2285,"I'm here to make money."],[2285,2469,"Some of us actually have to work."],[2469,2702,"I'd rather die than be back with you."],[2786,2844,"Why are you being"],[2844,2969,"such a bitter bitch, Maddie?"],[3053,3148,"I'm bitter?"],[3219,3340,"You dumped me when"],[3340,3490,"my father died,"],[3490,3616,"and then left me alone"],[3616,3712,"when I had nothing!"],[3812,3924,"You know I'm just with Evelyn"],[3924,3999,"for the money."],[3999,4095,"But you and I used to have"],[4095,4179,"so much fun."],[4179,4312,"You know what?"],[4312,4592,"For the first time, I am having fun."],[4633,4833,"I am so glad to be done"],[4833,5013,"with the fakeness and properness"],[5013,5121,"of my old life."],[5167,5267,"Leave me alone"],[5267,5426,"and let me get back to my new one."],[5426,5488,"How about this?"],[5488,5584,"I marry Evelyn,"],[5626,5759,"keep my family's ranch safe,"],[5759,5914,"and you and I will see each other"],[5914,5976,"when she's out of town."],[6264,6477,"You want me to be your mistress?"],[6510,6635,"I prefer the word lover."],[6677,6781,"Come on, Madison."],[6781,6936,"I'll even pay your mom's medical bills."],[6936,6977,"Just,"],[7052,7152,"just come back to me, Maddie."],[7152,7223,"Please."]],"28":[[291,467,"I'm not for sale!"],[496,667,"So go fuck yourself, Max."],[688,967,"In fact, let Evelyn do it for you."],[1026,1159,"You know, you're a real bitch, Madison."],[1180,1351,"Now I see why your dad killed himself."],[1351,1455,"To get away from you."],[1526,1580,"Hey!"],[1597,1772,"Get your hands off of her!"],[1772,1885,"Mind your business!"],[2010,2068,"You're just another one"],[2068,2164,"of Beau's whores."],[2344,2489,"Beau, get out here now."],[2489,2581,"It's Madison."],[2606,2723,"I am Max Archer."],[2723,2852,"My family owns this town."],[2852,2986,"Anyone got anything else to say"],[2986,3107,"about how I handle my business?"],[3186,3244,"You owe me now."],[3282,3453,"At least you're a fucking teaser, Maddie."],[3453,3582,"I remember just how you used to like it."],[3745,3862,"You're really gonna do this"],[3862,4016,"in a place your uncle owns?"],[4033,4099,"You're gonna anger"],[4099,4266,"the most important man in town?"],[4325,4462,"Most important man in town?"],[4496,4625,"I ain't scared o