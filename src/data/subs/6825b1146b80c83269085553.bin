{"1":[[62,221,"Why are you doing this, Max?"],[221,396,"I moved from New York"],[396,533,"to Texas for you."],[533,688,"You're all I have here."],[688,809,"Don't make a scene, Madison."],[859,930,"Just give me back the ring."],[934,1109,"Are you seriously breaking up with me"],[1109,1247,"because my family went bankrupt?"],[1247,1343,"What do you want me to say?"],[1401,1488,"You're no use to me."],[1509,1605,"Your daddy can't fund"],[1605,1676,"the ranch anymore."],[1676,1797,"My father died!"],[1797,1939,"He killed himself like a coward."],[1981,2085,"Caught embezzling and left you all"],[2085,2168,"with nothing, didn't he?"],[2214,2314,"I don't need you, Maddie."],[2314,2427,"And really, I don't love you anymore."],[2427,2544,"So hand over the ring now."],[3432,3532,"Don't cry, Madison."],[3586,3703,"Women are ugly when they cry,"],[3703,3741,"you know?"],[3791,3933,"You want to see ugly, Max?"],[3999,4083,"Look in the mirror."],[9009,9175,"That's my ex-fiancé's uncle."],[9184,9300,"The Beau Hayes."],[9300,9446,"He owns like half the town."],[9522,9743,"He's the biggest hot shot in Texas."],[10114,10201,"Forget that asshole."],[10289,10447,"You deserve a better man."],[11874,12049,"I'll have what Mr. Hayes is having."],[12620,12721,"What's a city girl like you"],[12721,12850,"doing in a place like this?"],[12896,13000,"Wandering these parts"],[13000,13129,"without your fiancé."],[13129,13238,"Ex-fiancé."],[13434,13542,"Max and I are over."],[13646,13738,"He doesn't want me."],[13855,13993,"How could anyone not want you?"],[14076,14147,"Now..."],[14293,14460,"I'm looking for something better."],[14689,14823,"Ride a real cowboy."],[15002,15081,"Little darling..."],[15240,15315,"Do you have any idea"],[15315,15440,"what you're getting yourself into?"],[15507,15578,"Then show me."]],"2":[[479,633,"If you want to ride a real cowboy,"],[650,763,"you gotta win them first."],[1242,1313,"Come with me."],[1735,1847,"We're gonna play a little game."],[2193,2339,"First one to sink the eight ball"],[2464,2523,"wins."],[2802,2936,"I'm no pool expert,"],[2936,3178,"but, what do I get if I win?"],[3269,3324,"Me."],[3453,3532,"You win me."],[3641,3745,"Good luck, city girl."],[5422,5605,"Looks like pool ain't your sport, city girl."],[5901,6035,"Let me help you with your position."],[6969,7044,"Looks like I know"],[7044,7178,"a few positions after all."],[7294,7361,"Impressive."],[7440,7603,"May I claim my prize now?"]],"3":[[575,654,"What, am I not good enough"],[654,759,"to take to your bed?"],[759,1009,"Givin' you the real cowboy experience."],[1009,1284,"You've gotta earn a slumber in my bed."],[1614,1901,"You sure you want to do this, city girl?"],[1901,2022,"I'm just claiming my prize"],[2022,2122,"from that pool game."],[2273,2369,"I'm showing your nephew"],[2369,2535,"what losing me feels like."],[3111,3290,"And you're sure that he lost you?"],[3541,3753,"I'm yours to claim, Lone Ranger."],[3787,3920,"Not so lone tonight, huh?"],[6189,6385,"Did I just sleep with my ex's uncle?"],[6431,6598,"The Beau Hayes?"],[7303,7411,"Hello?"],[7520,7599,"Oh god, okay."],[7640,7761,"Okay, I'll be right there."],[7912,7995,"I have to go."],[8078,8216,"Thanks for, um..."],[8316,8429,"hosting me last night."],[8429,8475,"Hey."],[8587,8717,"Let's keep this between us,"],[8717,8804,"yeah, city girl?"],[9367,9476,"Is that Max calling?"],[9530,9588,"Shit."],[9613,9747,"Why do I care so much?"]],"4":[[329,487,"Mom, I wish you'd wake up."],[571,658,"I miss you."],[1176,1372,"Dr. Harris, is she okay?"],[1372,1514,"Madison, your mother's condition"],[1514,1597,"has worsened."],[1618,1705,"We need to proceed"],[1705,1835,"with the treatment immediately"],[1835,2039,"if you ever hope to have her wake up."],[2356,2494,"Mom, this is all my fault."],[2577,2777,"You moved to Texas to be with me"],[2777,2973,"and after everything"],[2973,3119,"that happened with dad,"],[3207,3357,"your heart couldn't take it."],[3424,3570,"I wish I could have done more."],[3653,3762,"Doctor, please."],[3887,4108,"Whatever treatment she needs, do it."],[4333,4441,"We'll need a hundred thousand dollars"],[4441,4537,"to proceed."],[4537,4688,"A hundred thousand dollars?"],[4688,4971,"I, I don't have that kind of money."],[4971,5113,"I mean, not anymore."],[5113,5246,"I understand."],[5338,5568,"But really, this is her last chance."],[5739,5814,"I don't need you, Maddie."],[5814,5930,"And really, I don't love you anymore."],[5930,6051,"So hand over the ring now."],[6210,6302,"I'll get the money."],[6310,6418,"I know what I have to do."]],"5":[[496,571,"Can we keep it down, guys?"],[571,704,"I'm trying to relax over here."],[725,779,"Max!"],[892,955,"Madison?"],[1042,1126,"What the hell are you doing here?"],[1126,1197,"You gotta get out of here."],[1230,1272,"Believe me,"],[1272,1409,"I don't want to be here either."],[1409,1451,"I..."],[1518,1564,"I just need"],[1564,1668,"the hundred thousand dollars"],[1668,1764,"I lent you last year"],[1764,1897,"and I'll be gone."],[1935,1976,"Okay?"],[2039,2106,"Not okay."],[2114,2189,"That money's gone, Maddie."],[2189,2306,"I spent it all on the ranch."],[2431,2623,"More like on booze and women."],[2660,2840,"Look, Max, my mom is in the"],[2840,2948,"hospital, I just,"],[2948,3103,"I need the money you owe me and..."],[3795,3870,"Just my luck."],[3912,4137,"Max's whole damn family is here,"],[4137,4500,"including his rich, sexy cowboy uncle"],[4500,4646,"I just slept with."]],"6":[[0,91,"You gotta leave, Madison."],[91,208,"Uncle Beau's here to talk business"],[208,329,"and you are very in the way."],[329,487,"Like I said, we're not engaged anymore."],[487,617,"I don't care about your sick mom"],[617,763,"and I don't owe you anything."],[763,1034,"Joke's on me, Max, for ever loving you."],[1034,1222,"You big baby!"],[1222,1447,"What is this city trash"],[1447,1555,"doing here, Max?"],[1555,1722,"I was just leaving, Kate."],[1751,2043,"No need to protect your precious baby."],[2043,2235,"I don't intend to take him from you."],[2239,2477,"Well, bless your little heart."],[2477,2623,"Then what are you doing here?"],[2623,2786,"You're here to beg for him back."],[2786,2944,"My mom is in the hospital."],[2944,3219,"I just need the money I lent him."],[3219,3415,"The money that kept this farm running."],[3461,3595,"You always thought"],[3595,3782,"that you were too good for us."],[3782,3858,"And now,"],[3858,4095,"you're here begging, Yankee?"],[4283,4433,"You never treated me like this"],[4433,4508,"when my family"],[4508,4688,"was bankrolling everything."],[4688,4813,"I just need the money"],[4813,4925,"for my mom's treatments"],[4925,5113,"and then you'll never see me again."],[5113,5321,"Well, I will be damned."],[5467,5651,"Oh, money trouble, Maddie?"],[5651,5764,"Why don't you convince us"],[5764,5851,"to give it to you?"],[6026,6139,"Evelyn Campbell?"],[6156,6218,"Mhmm."],[6285,6431,"Really, Max?"],[6498,6594,"You dump me"],[6594,6806,"and hook up with my pageant rival?"],[6806,6881,"Unreal."],[6881,6956,"I should be the one"],[6956,7082,"asking you that question."],[7111,7282,"You're on my property, after all."],[7282,7386,"Your property?"],[7419,7524,"It will be soon enough."],[7549,7703,"Once Max and I get married."]],"7":[[8,112,"You might have bought yourself"],[112,321,"a couple of pageant wins, city girl."],[321,513,"But look who won the grand prize."],[538,588,"Me."],[633,763,"You're seriously still holding on"],[763,888,"to a childhood grudge?"],[992,1251,"If the prize is this cheating bastard,"],[1251,1355,"then you can have him."],[1355,1488,"Well, how dare you?"],[1488,1685,"My baby boy is a prize!"],[1685,1764,"Mhmm."],[1768,2056,"One that Evelyn more than deserves."],[2056,2310,"Did you know her daddy struck oil"],[2310,2473,"on his ranch last year?"],[2535,2594,"Huh."],[2627,2731,"A wealthy father."],[2752,2873,"Something you don't have anymore,"],[2873,2936,"huh, Maddie?"],[2936,3057,"Why don't we just talk privately?"],[3057,3157,"No way, baby."],[3157,3265,"This is way more fun."],[3828,3958,"This is how it's gonna go."],[3995,4187,"You're gonna get on your knees"],[4187,4300,"and you're gonna admit"],[4300,4487,"that your daddy was a corrupt liar."],[4487,4708,"And maybe, just maybe,"],[4708,4796,"I'll consider giving you"],[4796,4992,"the rest of this charity cash."],[5013,5146,"You know what Max once said"],[5146,5259,"when he saw your photo?"],[5280,5376,"That he wouldn't touch you"],[5376,5538,"for a thousand dollars."],[5538,5651,"I guess your family's"],[5651,5826,"paying him a lot more, huh?"],[5826,5960,"I never said that."],[5993,6081,"Shut up."],[6114,6243,"You're a liar."],[6268,6423,"Just like your dead daddy,"],[6423,6577,"you pathetic slut!"],[7595,7686,"Don't touch her!"]],"8":[[333,404,"You alright?"],[692,804,"Uncle Beau, Evelyn didn't,"],[804,880,"didn't mean that."],[896,1026,"It seems your new fiancée"],[1026,1134,"ain't quite the classy Bella"],[1134,1267,"she pretends to be, Max."],[1276,1468,"Uncle Beau, I don't know why I have to-"],[1468,1676,"That's Mr. Hayes to you, Ms. Campbell!"],[1676,1726,"Just because"],[1726,1818,"your daddy's doing business"],[1818,1885,"with my sister,"],[1885,1960,"don't mean shit."],[1960,2097,"I'm the one that owns this town."],[2097,2239,"So keep your pretty little mouth shut"],[2239,2356,"and mind your goddamn business."],[2431,2510,"Max, are you gonna let him"],[2510,2606,"talk to me like that?"],[2606,2681,"Shut up, Evelyn."],[2727,2894,"Okay, now, Beau,"],[2919,3003,"let's not get"],[3003,3144,"sidetracked here, okay?"],[3161,3424,"Let's all just sit down and"],[3424,3570,"talk about business."],[3657,3832,"What are you looking at?"],[3841,4062,"It's about time for you to skedaddle."],[4062,4175,"You have done enough damage"],[4175,4291,"here for one day."],[4312,4408,"You know what, Kate?"],[4458,4646,"For once, you're right."],[4733,4934,"Max, forget about the money."],[4934,5113,"I'll figure it out some other way."],[5113,5305,"Consider it pre-alimony"],[5305,5501,"since you won't be worth anything"],[5501,5705,"without a woman bankrolling you,"],[5705,5955,"you huge, fucking baby!"]],"9":[[0,396,"Well, isn't she just a ray of sunshine?"],[396,525,"The sooner she's gone for good,"],[525,600,"the better."],[633,734,"Now, come on,"],[734,875,"let's get back to business."],[888,971,"I don't think so."],[1009,1180,"I got more important matters to attend to."],[1906,2152,"Max, if your Uncle Beau"],[2168,2414,"doesn't agree to pay for this ranch,"],[2431,2569,"then next harvest"],[2569,2719,"is gonna be a disaster."],[2719,2819,"I've got this, Mama."],[2894,2969,"You heard her, Evelyn."],[3028,3086,"Now that our families"],[3086,3182,"are in business together,"],[3182,3286,"if this ship goes down,"],[3294,3403,"you're going down with it."],[3553,3670,"I need that money."],[3707,3799,"But I'll be damned"],[3799,3941,"if I grovel in front of Max"],[3941,4004,"and his new"],[4004,4179,"demon-in-a-dress fiancée."],[4179,4312,"And I definitely don't want to"],[4312,4479,"look pathetic in front of..."],[4604,4658,"Beau!"],[4700,4775,"Where do you think you're going,"],[4775,4846,"city girl?"],[4846,4996,"We've got things to discuss."],[5405,5518,"I want you to get on the horse."],[5547,5601,"Come on."],[6093,6231,"There you go."]],"10":[[50,133,"You ride pretty well"],[133,246,"for a girl from the city."],[321,471,"I thought I proved that to you last night."],[600,750,"Now, are you gonna let me off this beast?"],[750,834,"I wanna go home."],[834,925,"Whoa!"],[1063,1234,"First off, Stella ain't no beast."],[1305,1418,"She's my best gal."],[1451,1530,"Secondly,"],[1530,1676,"you don't have a place to stay."],[1718,1856,"Now that you and my nephew are..."],[1960,2064,"no longer together."],[2072,2235,"Let me off and I'll tell you."],[2936,3061,"I'm staying with my only friend"],[3061,3174,"out here, Taylor."],[3174,3257,"I just have to save up"],[3257,3353,"a little bit of money,"],[3386,3524,"to get my mom her treatment"],[3524,3682,"and then we can go back to New York."],[3682,3803,"How much is that gonna run you?"],[3853,4062,"$100,000 for her treatment."],[4441,4546,"A hundred thousand dollars?"],[5338,5384,"Here."],[5409,5543,"I can't accept that."],[5584,5739,"Your mom's all you have now, right?"],[5793,5897,"You wanna take care of her?"],[5997,6081,"I respect that."],[6202,6256,"Take it."],[6994,7090,"Thank you, Beau."],[7140,7194,"Really."],[7219,7382,"I'll pay you back, I promise."],[7382,7465,"I know you will."],[7682,7811,"Under my conditions."]],"11":[[0,41,"You want me"],[41,208,"to have sex with you for money?"],[271,375,"You think I buy my women"],[375,496,"like I buy my lifestyle?"],[496,667,"It's not how I treat women, Madison."],[729,875,"It's not how I get my girls."],[942,1051,"What would you have in mind?"],[1172,1238,"I'll show you."],[2156,2310,"Paying me to drink with you?"],[2310,2410,"Not quite, darling."],[2464,2623,"I'm paying you to work for me."],[2652,2727,"Work?"],[2727,2857,"Is that a foreign concept to you?"],[2915,3023,"Uptown princess?"],[3069,3178,"I own this place."],[3178,3332,"It's the best damn saloon in town."],[3436,3541,"Bonnie behind the bar here"],[3541,3653,"is gonna show you the ropes."],[3670,3799,"And I'll be around to..."],[3953,4054,"check up on you."],[4500,4625,"See you around, city girl."],[4821,4946,"What just happened?"],[4946,5159,"Did I just get hired"],[5159,5438,"by the most frustratingly sexy"],[5438,5593,"man I've ever met?"]],"12":[[8,112,"I'll teach you everything I know"],[112,283,"about slinging brews to Buckaroos."],[283,362,"Thank you."],[404,513,"I'm a hard worker,"],[513,709,"I promise I'm not gonna let you down."],[921,1067,"Take these drinks to table four."],[1230,1313,"You got it, boss."],[1539,1634,"Where's table four?"],[2485,2565,"Well, hello."],[2619,2719,"You're a fast learner."],[2794,2932,"Here are your tips from the day."],[2969,3103,"Customers seem to really like you."],[3244,3290,"Wow."],[3319,3490,"I never thought it would feel so good"],[3490,3653,"to earn something for myself."],[3703,3762,"As soon as you finish"],[3762,3853,"mopping up in the back,"],[3853,3941,"you can call it a night."],[3970,4054,"Thanks, Bonnie."],[4650,4771,"What are you doing back here, boss?"],[4771,4892,"You never help close up."],[4892,4971,"I, uh,"],[5009,5071,"well, I,"],[5071,5163,"I was just nearby"],[5163,5309,"and I thought I'd come"],[5309,5463,"and check up on the books."],[5722,5801,"Oh, shit."],[5801,5905,"Sorry, boss."],[5905,6001,"I probably got a spare shirt"],[6001,6064,"in the back room."],[6064,6156,"Why don't you go home?"],[6172,6306,"Um, I'll close up."],[6343,6414,"All right."],[8241,8483,"What's my hot new boss doing here?"],[8483,8583,"Dirty, dirty."]],"13":[[183,275,"Excuse me?"],[325,400,"The floors."],[546,608,"They're dirty."],[650,742,"Glad you're mopping."],[792,905,"Come to check up on me?"],[942,1051,"Don't flatter yourself."],[1163,1255,"I was coming from work"],[1255,1388,"and Bonnie spilled whiskey all over me."],[1568,1697,"Well, if you're all set,"],[1697,1872,"um, I'll just get going."],[2093,2223,"Not so fast, city girl."],[2252,2439,"I need you to do one last thing for me."],[3119,3232,"Help me put this on."],[3282,3361,"You're kidding."],[3453,3586,"I'm not gonna do that."],[3586,3636,"No?"],[3728,3766,"Well, shit,"],[3766,3908,"I guess you ain't clocking out tonight,"],[3908,3962,"then, huh?"],[4008,4066,"Fine."],[4237,4308,"Sir..."]],"14":[[212,325,"I forgot my jacket."],[492,617,"Uh, don't worry."],[788,871,"I was just leaving."],[1326,1430,"You know, Madison,"],[1501,1651,"Mr. Hayes is a lone ranger."],[1718,1822,"Ain't no lasso's tight enough"],[1822,1939,"to hold that man down."],[2018,2177,"Just don't get yourself hurt."],[2723,2840,"Idiot..."],[3824,4062,"Taylor, I cannot thank you enough"],[4062,4187,"for letting me crash here."],[4233,4425,"After Max dumped me,"],[4450,4612,"you're all I have left"],[4612,4904,"in this tiny little Texas town."],[4904,4996,"What are the odds?"],[5100,5192,"Getting an internship"],[5192,5313,"at a startup down here?"],[5367,5442,"You know,"],[5613,5689,"of course, I've known you"],[5689,5784,"since we were kids."],[5784,5922,"And I'm just glad"],[5922,6101,"to see you safe away from Max."],[6177,6289,"Safe in my home."],[6360,6448,"Our home,"],[6519,6606,"if you want."],[6677,6835,"Now that I have a job,"],[6835,7007,"I can pay my rent."],[7007,7198,"Mom can get her treatments."],[7198,7315,"And when she's feeling better,"],[7340,7461,"I can move us back to New York"],[7461,7649,"so I can go back to school."],[7649,7695,"I know,"],[7695,7962,"I see your flight home return jar."],[8083,8274,"You know, maybe I could just"],[8274,8391,"take care of you here."],[8416,8687,"I mean, Beau pays me pretty well."],[8687,8900,"Beau Hayes?"],[8933,8992,"You didn't tell me"],[8992,9079,"you're working for the guy"],[9079,9305,"who owns like, half the town."],[9342,9555,"That would be the one."],[9580,9822,"But I'm not sure he's a good guy."],[9889,9989,"Unlike you."],[10030,10193,"This is my chance."],[10193,10264,"I'm gonna tell her"],[10264,10372,"that I've been in love with her"],[10372,10452,"for years."],[10485,10618,"Before Beau can swoop in."],[10719,10827,"Hey Maddie, um..."],[10960,11081,"there's something,"],[11111,11265,"I've always wanted to tell you."],[11265,11323,"Wait."],[11323,11432,"Me first."]],"15":[[29,137,"I just want to say"],[137,329,"that I'm way happier"],[329,521,"sitting on this couch with you"],[521,788,"than I ever was with Max."],[996,1176,"You're like my brother,"],[1197,1301,"that I never had."],[1343,1484,"Thank you for being my family."],[1634,1693,"Yeah."],[2022,2081,"Family."],[2890,3032,"Best whisky sour I've ever had."],[3086,3211,"Any time, Sheriff."],[3236,3353,"You gonna buy us some drinks?"],[3449,3591,"I'll buy you some drinks."],[3591,3699,"Hey, superstar."],[3745,3874,"Can you handle the VIP table"],[3874,3941,"in the corner?"],[3941,4083,"They've ordered whiskeys to start,"],[4083,4225,"but they'll order more, trust me."],[4225,4333,"And they'll tip well."],[4333,4466,"Fancy types always do."],[4466,4525,"Thanks, Bonnie."],[4525,4592,"You got it."],[4859,4929,"Howdy, y'all."],[4929,5038,"My name's Madison."],[5038,5163,"I'll be taking care of..."],[5417,5593,"Happy to see me, bar wench?"],[5593,5668,"Evelyn?"],[5668,5797,"My ex's fiancée?"]],"16":[[4,187,"Well, bless my star."],[275,408,"I didn't realize I'd be serving"],[408,608,"such esteemed company tonight."],[629,754,"Why are you so surprised"],[754,809,"to see me here?"],[809,959,"My Uncle Beau owns this bar."],[1046,1184,"You're not married to Max yet,"],[1184,1338,"so you're not family."],[1363,1522,"And you never will be."],[1539,1764,"So know your place and serve us."],[1906,2043,"What's the hardest drink to make?"],[2168,2289,"Probably a mojito."],[2318,2385,"Great!"],[2410,2535,"We'll take ten of those."],[2535,2677,"All different flavors."],[2698,2811,"Oh, and we're in a rush,"],[2811,2932,"so make it snappy."],[3190,3311,"And you, sir?"],[3490,3628,"Who dragged in the fresh meat?"],[3670,3824,"Oh this is Max's fiancée."],[3824,3928,"Oh,"],[3928,4191,"I mean, ex-fiancée."],[4250,4371,"Remember her daddy, you know,"],[4433,4562,"left her with nothing and then..."],[5663,5822,"Bless your hearts."],[5872,6010,"Mitch, I heard you'll do"],[6010,6131,"just about anything."],[6131,6206,"Girls like Madison"],[6206,6373,"are desperate for cash."],[6373,6493,"Ain't that right, Maddie?"],[6510,6660,"Couldn't be more wrong."],[6777,7023,"The customer is always right, bitch."],[7082,7148,"Go ahead, Mitch."],[7148,7240,"Show her who's boss."],[7866,7987,"Oh my God."],[8053,8187,"There's two grand right there."],[8187,8299,"Why don't you have a drink with me"],[8299,8395,"like a good girl?"]],"17":[[66,129,"Mhmm."],[171,233,"Come on."],[567,679,"You down that,"],[788,925,"or we're gonna tell your boss"],[925,1084,"that you're just a terrible waitress."],[1151,1255,"It's just one drink."],[1297,1488,"I need the money for mom's surgery."],[1972,2022,"Come on."],[2106,2189,"There you go."],[2189,2281,"Mhmm."],[2556,2623,"There."],[2690,2907,"I did what you asked, sir."],[2932,3007,"You're right, Evelyn."],[3007,3128,"She sure is easy."],[3140,3324,"Here you go honey, you earn that."],[3853,4029,"If there isn't anything else,"],[4116,4175,"I'll go."],[4204,4312,"Don't stop now, Mitch."],[4312,4429,"She's just getting started."],[4454,4529,"Oh, hey, hey, hey."],[4529,4592,"Where you gonna go?"],[4608,4654,"Where you gonna go?"],[4692,4813,"If you want double,"],[4859,4959,"you gonna ride that bull"],[4959,5042,"in front of everyone."],[5134,5217,"No."],[5234,5351,"I already had a drink,"],[5351,5526,"I'm not gonna keep playing your game."],[5568,5793,"Your job is to entertain us, bitch."],[5830,5914,"Make her do it."],[6414,6535,"You need this cash."],[6535,6610,"For mom."],[6760,6886,"Ride him, cowgirl!"],[7127,7223,"Break a leg."],[7269,7340,"Literally."]],"18":[[2293,2464,"Hey, I'm actually good at this."],[4074,4187,"God, she's so hot."],[4329,4512,"Stop staring at her, Beau!"],[4696,4779,"The whole bar can see"],[4779,4884,"that you're turned on by her."],[4942,5055,"You need to get some air."],[5705,5889,"You were supposed to humiliate her."],[5914,6035,"Not make everybody want her."],[6035,6147,"Do something about it."],[6177,6239,"All right."],[6890,6944,"I'll tell you what,"],[6944,7061,"you want that cash?"],[7082,7257,"Then ride me next."],[7257,7344,"No way."],[7344,7486,"I did what you asked."],[7486,7624,"Pay up and leave me alone."],[7624,7811,"Not until I get my ride, cowgirl."],[8037,8258,"She's bucking like a heifer in heat!"],[8341,8487,"Maybe a drink will calm you down."],[8487,8596,"Here you go."],[8854,8946,"Bottoms up."],[8958,9021,"Bottoms up."],[9029,9096,"There you go."],[10122,10235,"You broke my nose."],[10260,10318,"Fuck."],[10581,10639,"Beau?"],[10856,10944,"Looks like a little bitch"],[10944,11106,"is causing troubles in my saloon?"]],"19":[[141,208,"Beau?"],[308,417,"We just havin' a litlle fun,"],[417,500,"right, sweetheart?"],[763,930,"Hey, if you want a turn next,"],[975,1213,"she's feisty, but she sure is a looker."],[1317,1409,"Get over here!"],[1751,1876,"Woah, hey!"],[1926,2014,"Didn't mean no harm."],[2014,2152,"Just a little fun."],[2152,2214,"A little fun?"],[2214,2285,"Huh?"],[2285,2523,"You think forcing a lady to drink is fun?"],[2627,2748,"How would you like it?"],[2756,2827,"Bonnie!"],[2894,3032,"Give me the La Cucaracha."],[3203,3345,"La Cucaracha!"],[3457,3545,"Cockroaches."],[3757,3820,"Exactly."],[3974,4062,"A delicacy."],[4187,4266,"You're gonna disrespect"],[4266,4341,"an offering?"],[4441,4579,"Shit, come on, man."],[4579,4633,"You're not gonna"],[4633,4738,"make me drink that shit."],[4909,5071,"Your daddy borrowed fifty grand"],[5071,5251,"from me last year for his harvest."],[5292,5438,"I'm going to make it due tomorrow,"],[5438,5622,"bankrupt your family's little farm."],[5976,6135,"Drink the goddamn drink."],[7019,7123,"Oh, God."],[7403,7503,"And your sister,"],[7578,7720,"has been borrowing my horses"],[7720,7816,"for her competitions."],[7816,7920,"Oh, come on."],[7920,7995,"I'll tell you what."],[8183,8362,"I ain't feeling so generous anymore."],[8500,8566,"I'm going to make sure"],[8566,8654,"she never rides again."],[9401,9509,"There you go."],[9597,9776,"Soak it all in, you little bitch."],[10018,10122,"Taste good?"],[10506,10589,"All right, man."],[10589,10677,"We're square."],[10719,10806,"Not quite."]],"20":[[0,150,"You got a newborn baby at home."],[179,312,"And a wife waiting for you."],[342,458,"I think that she would love"],[458,546,"to hear about you"],[546,742,"drinking it up with these broads,"],[742,917,"laying hands on my goddamn staff."],[1138,1301,"Get the fuck out of my bar."],[1380,1530,"I never want to see you again."],[1568,1680,"If you ever come in here again,"],[1680,1818,"I will kick your goddamn ass."],[1818,1943,"And if you ever lay a hand"],[1943,2118,"on any woman ever again,"],[2118,2248,"or touch Madison,"],[2248,2410,"I will snap your goddamn neck"],[2410,2481,"like a chicken bone,"],[2481,2569,"you understand me?"],[2590,2761,"Now get the fuck out of my sight!"],[3349,3411,"And you."],[3532,3624,"Me?"],[3687,3812,"If you ever pull a goddamn stunt"],[3812,3895,"like that again,"],[3895,3991,"not only will I kick you"],[3991,4066,"out of my family,"],[4066,4149,"I'll make sure"],[4149,4266,"that I'll run your ass"],[4266,4383,"right out of Texas."],[4404,4504,"All of you are banned"],[4504,4621,"from my establishments."],[4621,4708,"What?"],[4708,4796,"Scram!"],[4963,5063,"Get out of my sight."],[5330,5388,"Come here."],[5751,5814,"You okay?"],[5918,6006,"Let's go talk."]],"21":[[0,158,"You sure got that sucker pretty hard."],[158,212,"Huh?"],[246,333,"What can I say?"],[333,442,"I have a mean right hook."],[592,654,"Ah!"],[654,717,"Sorry."],[855,925,"Almost done."],[1021,1113,"Is it broken?"],[1217,1272,"No."],[1284,1380,"It's just a sprain."],[1380,1430,"Wait."],[1455,1543,"Am I even going to be able"],[1543,1655,"to use my hand?"],[1668,1801,"Am I going to be able to work?"],[1801,1935,"If I can't work,"],[1935,2072,"then I'm not going to be able to-"],[2072,2152,"Relax."],[2189,2306,"Take a couple weeks off."],[2369,2569,"I need the money, Beau."],[2706,2769,"But,"],[2848,2982,"of course you don't understand."],[2982,3061,"You're rich."],[3107,3203,"When I was rich,"],[3203,3357,"I wouldn't have understood either."],[3407,3499,"Just because I'm rich,"],[3499,3636,"doesn't mean we're worlds apart."],[3687,3787,"But it does!"],[4079,4354,"My dad worked so hard"],[4408,4554,"to give me and my mom"],[4554,4758,"the best life possible."]],"22":[[8,116,"When I met Max,"],[116,321,"everything was falling into place."],[321,650,"Then my dad was accused of fraud,"],[688,884,"and he killed himself."],[896,1121,"And my mom got so sick"],[1121,12