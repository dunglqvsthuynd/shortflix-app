 still"],[7891,8025,"the grand finale item?"],[8516,8570,"Next up,"],[8575,8750,"is our evening's grand finale,"],[8779,8920,"a two-hundred-year-old wild ginseng."],[9033,9116,"Experts have authenticated"],[9120,9279,"that this ginseng is perfectly preserved"],[9295,9445,"with extreme medicinal potency."],[9462,9570,"Starting bid, five million."],[9587,9791,"Minimum increment is five hundred thousand."],[9895,9979,"Six million!"]],"17":[[0,75,"Six million!"],[137,220,"Who is this kid?"],[241,320,"That was a fierce bid."],[341,470,"He raised it by a million straight away!"],[487,627,"Probably some brainless rich kid."],[662,783,"More money than sense."],[787,912,"Finally caught you."],[933,1025,"You want to play?"],[1058,1112,"I'll destroy you!"],[1166,1262,"Seven million."],[1370,1458,"Eight million."],[1462,1541,"Nine million."],[1550,1608,"It looks like"],[1612,1708,"Conrad is seizing the chance"],[1712,1783,"to take revenge on Keith."],[1962,2025,"Keith,"],[2066,2162,"what do we do?"],[2175,2270,"We can't compete with Conrad."],[2512,2595,"Ten million!"],[2616,2662,"Hmm?"],[2825,2970,"You've got guts, kid."],[2975,2995,"Hmph."],[3054,3162,"Trying to outspend me?"],[3175,3329,"Money is the one thing I don't lack."],[3362,3520,"I'm going to crush you today."],[3525,3654,"Eleven million."],[3658,3729,"Twel-"],[3933,4037,"We can't bid any higher."],[4041,4145,"Anything over eleven million,"],[4150,4266,"we can't afford."],[4283,4404,"Don't force it if you're broke."],[4487,4704,"You can't afford this wild ginseng."],[4708,4787,"Why stop bidding?"],[4833,4920,"Run out of money?"],[4937,5008,"You broke loser."],[5041,5154,"You want to fight me?"],[5204,5270,"I'll destroy you!"],[5329,5429,"Eleven million."],[5445,5595,"Anyone else want to bid?"],[5600,5745,"Eleven million, going once."],[5766,5912,"Eleven million, going twice."],[5920,5995,"This ginseng"],[6000,6108,"is crucial for my mother's"],[6112,6191,"post-surgery recovery."],[6237,6350,"I can't just give up like this!"],[6445,6525,"Eleven million, thr-"],[6529,6600,"Light the Sky Lantern, all in!"]],"18":[[8,116,"Light the Sky Lantern, all in!"],[170,333,"Lighting the Sky Lantern right away?"],[375,466,"Are you crazy?"],[512,745,"Lighting the Sky Lantern for a ginseng?"],[750,895,"How much I'm willing to spend"],[900,1012,"is none of your business."],[1016,1079,"Besides,"],[1083,1195,"Keith needs this ginseng"],[1200,1383,"to treat his mother's illness,"],[1425,1541,"it's worth every penny."],[1608,1795,"Sophie, you're so kind."],[1800,1862,"Keith,"],[1916,2154,"if you can extend my grandpa's life,"],[2183,2308,"forget ten million,"],[2320,2437,"even if it were a hundred million,"],[2445,2595,"my family could afford it."],[2625,2962,"Keith is under my protection today!"],[3016,3141,"To hell with the Moses!"],[3145,3233,"They ruined my plans!"],[3237,3391,"The Sky Lantern covers the floor."],[3408,3483,"If no one continues"],[3487,3641,"to challenge the bid,"],[3787,3862,"sold!"],[3920,4000,"Congratulations."],[4191,4266,"Keith."],[4304,4416,"Take this wild ginseng"],[4441,4562,"to treat your mother."],[4629,4787,"Thank you, Sophie."],[6137,6212,"Sophie,"],[6266,6358,"marry me!"]],"19":[[137,237,"Sophie,"],[250,320,"marry me!"],[358,429,"Justin,"],[458,554,"I told you a long time ago"],[558,708,"we weren't right for each other."],[750,854,"Stop pestering me!"],[862,925,"Sophie,"],[980,1095,"do you really have to embarrass me?"],[1150,1275,"I'm the son of the Spencer family!"],[1283,1320,"Who you are"],[1325,1437,"has nothing to do with me."],[1466,1529,"Now move!"],[1620,1700,"Sophie."],[1970,2066,"Why don't you look at this?"],[2091,2154,"What?"],[2316,2458,"This is the Glazed Jade Ring!"],[2562,2754,"How did you get my family heirloom?"],[2804,2925,"I was thinking,"],[2991,3112,"if you agreed to marry me,"],[3116,3212,"I would return this ring"],[3216,3312,"to the Moses family."],[3333,3520,"But since you're embarrassing me,"],[3637,3754,"then this ring"],[3758,3962,"will never return to you in this lifetime!"],[3966,4054,"How could you keep it?"],[4058,4158,"It belongs to the Moses."],[4162,4300,"Give it back to them."],[4304,4575,"Who the hell are you to meddle in my business?"],[4908,5100,"Either you marry me, or lose the ring."],[5150,5225,"Your choice."],[5279,5475,"This ring is everything to my family."],[5479,5612,"Grandpa has been looking for it his whole life."],[5645,5745,"Just marry him for the family."],[5750,5783,"I…"],[5787,5870,"Sophie,"],[5929,6041,"this ring is fake!"]],"20":[[820,920,"Sophie,"],[925,1066,"this ring is fake!"],[1091,1254,"What nonsense are you spouting, you brat?"],[1270,1387,"I spent thirty million"],[1391,1512,"buying this ring from an antique shop."],[1516,1650,"How could it possibly be fake?"],[1666,1775,"Who is this kid?"],[1779,1879,"He's full of crap!"],[1941,2104,"The color and craftsmanship of this ring"],[2108,2208,"look real at a glance."],[2212,2308,"It's the Moses family heirloom,"],[2325,2408,"it's not that easy to fake!"],[2495,2691,"Exactly!"],[2708,2787,"Keith,"],[2825,2995,"a-are you sure?"],[3029,3191,"But the pattern on this ring"],[3216,3333,"is identical to the one"],[3337,3437,"in our family album."],[3470,3566,"Sophie,"],[3595,3654,"look."],[3691,3854,"A real glazed jade thumb ring"],[3862,4062,"has natural veins on the inside."],[4116,4225,"Also, antique patterns"],[4237,4425,"are usually hand-carved,"],[4445,4737,"leaving a natural uneven texture inside."],[4762,4845,"But look here,"],[4891,5070,"the inside is smooth and reflective."],[5083,5154,"Obviously,"],[5175,5337,"it was recently polished."],[5395,5641,"The edges of the pattern are straight lines,"],[5695,5850,"clearly engraved by laser."],[5862,6095,"It's just mixed with regular jade"],[6120,6300,"and dyed on the surface to look like glaze,"],[6316,6466,"that's why it looks similar."],[6541,6633,"Justin!"],[6637,6829,"How dare you try to trick me with a fake ring!"],[7116,7270,"You nosey little brat,"],[7283,7391,"you must be tired of living!"],[7408,7504,"Let go of my son!"],[7508,7675,"Justin, let go of Keith!"],[7695,7800,"If you hurt him,"],[7804,7933,"my grandfather won't let you off!"],[7966,8087,"Your grandfather?"],[8091,8320,"Your grandfather is nothing but a dying man."],[8325,8470,"Once he's gone,"],[8487,8595,"you'll have no choice but to"],[8600,8725,"crawl into my bed!"],[8729,8816,"In your dreams!"],[8912,8958,"Ah!"],[9195,9358,"Cripple this little bastard!"],[9383,9454,"Stop!"]],"21":[[0,104,"Stop!"],[679,845,"Mr. Drake, what are you doing here?"],[1633,1800,"Mr. Drake, not only"],[1816,1937,"did this brat smash up my place,"],[1954,2095,"but also stole the 100-year wild ginseng"],[2100,2200,"I was going to present to you!"],[2266,2358,"Kid,"],[2450,2566,"you're quite impressive."],[2645,2770,"At such a young age,"],[2887,3029,"you've made my men"],[3033,3162,"suffer defeat at your hands"],[3166,3287,"twice already."],[3391,3475,"Austin Drake,"],[3491,3608,"you finally showed up."],[3641,3712,"Mr. Drake,"],[3745,3875,"my boy doesn't know any better."],[3879,4062,"If he has offended you in any way,"],[4116,4204,"please forgive him."],[4208,4275,"Mr. Drake,"],[4312,4491,"Keith is my grandpa's honored guest."],[4516,4683,"For the sake of my grandpa,"],[4716,4825,"please don't make things difficult for him."],[5025,5112,"Kid,"],[5150,5508,"I've taken a liking to that 200-year wild ginseng."],[5558,5733,"If you hand it over to me now,"],[5787,5937,"I'll let you all go."],[6062,6204,"Otherwise,"],[6379,6625,"would the great Mr. Drake really rob me,"],[6629,6825,"a six-year-old child?"],[6837,7050,"Aren't you afraid of being laughed at?"],[7054,7462,"Hahahaha!"],[7466,7570,"Kid."],[7575,7745,"Do you have any idea"],[7750,7875,"how long it's been since anyone dared"],[7879,8075,"to speak to me like that?"],[8283,8383,"So what?"]],"22":[[0,229,"If you want this wild ginseng,"],[233,316,"fine."],[366,454,"But we have to settle this"],[462,658,"by the rules. Let's compete."],[687,829,"If you win,"],[833,1095,"I'll hand over the wild ginseng willingly."],[1125,1254,"But if you lose,"],[1283,1429,"you have to let us go!"],[1766,1862,"Alright, kid."],[1887,2020,"You talk a big game."],[2025,2079,"Fine."],[2120,2262,"Then I'd like to see"],[2308,2512,"exactly what you want to compete in."],[2795,2904,"You can pick."],[2945,3029,"Treasures appraisal,"],[3033,3116,"judging stones,"],[3120,3295,"or identifying herbs. I'm fine with anything."],[3308,3458,"Is this kid crazy?"],[3475,3579,"Everyone knows"],[3600,3791,"Mr. Drake has experts hidden everywhere."],[3816,3895,"A six-year-old child"],[3912,4012,"actually dares to challenge him here?"],[4050,4179,"He's practically asking for death!"],[4204,4375,"He thinks a little skill"],[4404,4462,"gives him the right to look down"],[4466,4537,"on everyone."],[4554,4666,"He won't even know what hit him!"],[4720,4800,"Mr. Drake,"],[4841,4929,"don't waste your breath on him."],[4945,5020,"Just kill him."],[5058,5216,"If you dare say another word,"],[5337,5470,"I wouldn't mind"],[5475,5566,"killing you first."],[5775,5854,"Little kid."],[5958,6054,"We'll do it your way."],[6066,6154,"We'll compete in"],[6158,6250,"treasure appraisal,"],[6279,6370,"stone judging,"],[6375,6487,"and herb inspection."],[6516,6650,"Best two out of three."],[6654,6750,"How does that sound?"],[7212,7316,"I'll need to borrow your venue"],[7320,7408,"for a bit today."],[7420,7491,"Be my guest."],[8216,8295,"Specs!"],[8595,8641,"It's Specs!"],[8683,8850,"Mr. Drake's sharpest eye."],[8891,8983,"Last time, someone tried to"],[8987,9141,"fool Mr. Drake with a fake censer,"],[9158,9295,"and he saw through it at a glance."],[9308,9470,"I heard he can judge stones just by touch."],[9475,9554,"He's amazing."],[9566,9654,"That kid is done for today."],[9816,9895,"Mr. Drake,"],[9925,10112,"are you asking me to play house"],[10116,10229,"with this little brat?"],[10270,10345,"Don't get careless."],[10500,10612,"This kid"],[10666,10795,"beat Conrad twice."],[10941,11045,"He's a bit uncanny."],[11158,11241,"Then I'd really like to see"],[11245,11358,"just how uncanny he is."],[11462,11520,"Keith,"],[11600,11708,"this Specs guy is formidable."],[11716,11829,"I'm worried you can't beat him."],[11858,11975,"Keith,"],[12012,12125,"this is obviously a trap."],[12179,12220,"Let's not fall for it!"],[12233,12254,"Dad,"],[12345,12495,"Sophie,"],[12512,12591,"don't worry."],[12600,12708,"I have a way to win!"],[12745,12841,"You are the most impressive kid"],[12845,12962,"I have ever seen."],[12995,13079,"It's a shame"],[13083,13212,"you're up against me."],[13216,13287,"Sir,"],[13300,13504,"there's a fine for bragging!"]],"23":[[0,104,"Round one."],[416,558,"Appraise this bowl,"],[587,720,"its era,"],[725,812,"authenticity,"],[850,933,"and value."],[1008,1191,"Specs, you're up first."],[1862,2048,"This is a blue-glazed bowl from the 15th century."],[2091,2258,"The body is fine and the glaze is uniform."],[2283,2333,"However,"],[2354,2475,"there's a small chip on the bottom."],[2516,2612,"Its market value"],[2641,2762,"is about two million."],[2900,3000,"Two million!"],[3058,3150,"It's that expensive?"],[3162,3245,"That's Specs for you,"],[3258,3366,"he spotted it at a glance."],[3408,3604,"This kid is definitely losing."],[3625,3800,"The brat is in way over his head."],[3829,3950,"He needs to be taught a good lesson."],[4012,4087,"Hey brat,"],[4104,4208,"dumbfounded?"],[4250,4408,"Hand over the wild ginseng now."],[4441,4587,"Stop embarrassing yourself!"],[5416,5504,"This bowl"],[5508,5641,"isn't from the 15th century,"],[5645,5829,"but the 17th century."],[5891,5975,"You're talking nonsense!"],[6129,6275,"It was artificially aged"],[6279,6383,"using chemical reagents."],[6387,6487,"The inscription on the bottom"],[6491,6650,"was carved later, too."],[6679,6808,"It's worth fifty thousand at most."],[6854,6941,"Kid,"],[6970,7091,"do you know?"],[7129,7379,"I bought this bowl for one million."],[7404,7537,"It's worth fifty thousand?"],[7708,7770,"Believe it or not,"],[7775,7904,"I'll bury you alive!"],[7937,8037,"Look closely."],[8075,8229,"On a genuine ancient blue-glazed bowl,"],[8258,8475,"the glaze has a natural orange-peel texture."],[8566,8679,"But the texture on this bowl"],[8683,8820,"is too uniform."],[8825,8970,"And as for the chip on the bottom,"],[9008,9145,"the edges are too smooth."],[9166,9275,"It was ground down intentionally."],[9325,9466,"A real chip"],[9470,9650,"would have tiny, jagged edges."],[10179,10270,"Mr. Drake…"]],"24":[[58,162,"Proceed to round two."],[379,491,"For this second round,"],[495,612,"we will be appraising"],[658,825,"this faience bead in my hand."],[1052,1312,"Isn't that just a glass bead?"],[1341,1391,"What?"],[1450,1516,"A glass bead?"],[1520,1600,"Impossible!"],[2133,2266,"Are you blind?"],[2270,2462,"This is a faience bead from the 3rd century BC!"],[2470,2650,"It's extremely rare!"],[2675,2812,"A single one is worth ten million."],[2866,2950,"You're just a kid,"],[2954,3054,"so you wouldn't know."],[3058,3133,"I don't blame you."],[3316,3445,"Those who can recognize this treasure"],[3487,3612,"are few and far between."],[3733,3783,"Specs,"],[3850,3900,"good job."],[4058,4641,"A faience bead from the 3rd century BC..."],[4650,4754,"The surface of the bead"],[4795,5045,"should be composed of blue hemispheres"],[5050,5195,"with protruding dragonfly eyes"],[5237,5566,"grouped in fives forming a circle."],[5595,5850,"They are separated by pentagons"],[5870,6087,"adorned with raised blue hemispheres,"],[6116,6233,"painted yellow"],[6287,6495,"and dotted with three red spots."],[6554,6712,"The one in your hand"],[6729,6841,"is a hexagon,"],[6900,7075,"with only one dot at the intersection."],[7095,7245,"If that's not a fake, what is?"],[7258,7383,"The kid is telling the truth!"],[7412,7512,"The faience beads"],[7516,7625,"are indeed pentagonal."],[7637,7808,"This kid is unbelievable!"],[7812,7920,"He's even better than Specs!"],[7958,8062,"Two out of three."],[8066,8112,"I win."]],"25":[[179,320,"You can't even beat a kid."],[341,512,"What the f**k good are you to me?"],[766,833,"I won."],[858,920,"Now,"],[925,1016,"you can let us go, right?"],[1091,1158,"Of course."],[1208,1325,"I'm a man of my word."],[1350,1479,"You can certainly go."],[1500,1579,"However,"],[1583,1679,"I'm warning you."],[1700,1791,"From now on,"],[1808,1941,"especially at night,"],[1958,2070,"watch your step."],[2116,2241,"I'm not afraid of the dark."],[2262,2362,"But today's game"],[2366,2462,"didn't satisfy me!"],[2520,2600,"Keith,"],[2625,2704,"don't be impulsive!"],[2708,2879,"You can't use words so recklessly."],[2883,2950,"Mr. Drake,"],[2975,3183,"I heard you own a mining vein."],[3266,3387,"worth ten billion."],[3408,3487,"Why don't we"],[3516,3654,"bet on that mine?"],[3687,3750,"In my previous life,"],[3754,3991,"that mine was his most valuable asset."],[4025,4145,"Winning it"],[4175,4241,"would be like striking"],[4245,4358,"at his vitals."],[4379,4466,"It'll make him much easier"],[4470,4550,"to deal with later."],[4587,4637,"Mr. Drake,"],[4662,4725,"this kid"],[4729,4845,"has no respect for you."],[4866,4954,"Why don't I just…"],[5154,5216,"Kid,"],[5245,5366,"you're right about that mine."],[5445,5541,"But do you have the capital"],[5545,5675,"to play with me?"]],"26":[[50,183,"I'll bet ten billion in cash"],[195,262,"against you."],[275,354,"Do you have the guts?"],[554,629,"Kiddo,"],[633,741,"do you have any idea"],[745,920,"how much ten billion is?"],[933,1087,"What guarantee can you offer?"],[1091,1270,"Even the Moses family backing you"],[1275,1400,"couldn't produce that much."],[1454,1608,"You don't need to worry about that."],[1633,1745,"If I can't produce ten billion"],[1762,1912,"within three days,"],[1945,2050,"I'm at your disposal!"],[2054,2125,"Fine!"],[2175,2333,"I'll give you three days."],[2354,2458,"In three days,"],[2516,2708,"I'll be waiting for you"],[2716,2804,"at the Royal Hotel."],[2808,2966,"Show me the ten billion then."],[2983,3062,"Otherwise,"],[3091,3300,"I'll make your whole family disappear."],[3316,3408,"No problem."],[3475,3595,"But if I win,"],[3679,3804,"you have to hand over ownership"],[3808,3950,"of the mining vein."],[4254,4312,"Good."],[4316,4404,"It's a deal."],[4408,4587,"I'd like to see how you're going to"],[4591,4804,"come up with ten billion in three days."],[4925,5025,"Let's go."],[5479,5570,"Keith,"],[5587,5733,"that's ten billion we're talking about!"],[5758,5845,"How could you possibly"],[5850,5908,"raise that much money"],[5912,6041,"in just three days?"],[6058,6141,"Even if we sold off"],[6145,6262,"all of the Moses family's assets,"],[6325,6487,"it wouldn't be enough for ten billion."],[6512,6591,"Forget it."],[6620,6820,"Keith, let's pack up and move tonight."],[6866,6941,"Let's go somewhere"],[6945,7041,"where Mr. Drake can't find us,"],[7045,7112,"okay?"],[7116,7200,"I promise I'll protect"],[7204,7283,"you and Mom."],[7316,7429,"Sophie,"],[7433,7483,"Dad,"],[7512,7575,"don't worry."],[7616,7720,"Within three days,"],[7737,7883,"I will get that ten billion!"]],"27":[[329,408,"Keith,"],[441,562,"this medicine is amazing."],[620,775,"I feel so much lighter,"],[779,908,"and more energetic now."],[945,1133,"I was having trouble breathing before,"],[1150,1262,"but now I feel much better."],[1266,1337,"Really?"],[1404,1545,"That's wonderful!"],[1550,1641,"Keith, you're amazing!"],[2133,2208,"Mrs. Hart,"],[2212,2329,"how are you feeling now?"],[2333,2412,"Do you feel dizzy"],[2416,2500,"or have tightness in your chest?"],[2612,2675,"No."],[2704,2829,"After drinking the ginseng soup Keith made,"],[2833,2920,"I feel much better."],[2975,3041,"Dr. Lewis,"],[3058,3204,"it's all thanks to Keith's prescription."],[3225,3283,"Otherwise,"],[3287,3383,"I don't know"],[3387,3541,"how much I'd be suffering!"],[3558,3633,"Keith,"],[3666,3729,"your prescription is"],[3733,3812,"truly miraculous."],[3850,3954,"I've been a doctor for twenty years,"],[3987,4075,"and I've never seen such an"],[4079,4200,"effective post-op recovery method."],[4275,4420,"May I see the prescription?"],[5108,5270,"This prescription is brilliant."],[5333,5500,"It targets post-op low immunity"],[5504,5600,"and deficiency of energy."],[5604,5691,"The dosage of each herb"],[5695,5812,"is just right."],[5816,5916,"If this could be promoted,"],[5925,6066,"it could help so many patients."],[6108,6262,"Dr. Lewis, if you find it useful,"],[6316,6475,"you can use the version"],[6491,6566,"for general patient recovery."],[6604,6654,"However,"],[6666,6816,"the formula with wild ginseng"],[6850,6945,"cannot be used indiscriminately!"],[6970,7037,"Understood, understood!"],[7070,7179,"I will definitely use it with caution!"],[7208,7287,"Keith,"],[7291,7362,"your medical skills"],[7366,7495,"are truly superb!"],[7716,7904,"You're a prodigy! A true prodigy!"]],"28":[[20,83,"Keith,"],[100,220,"this prescription is amazing."],[275,412,"And I heard Dr. Lewis say"],[450,545,"it can be widely promoted."],[579,604,"So,"],[620,683,"does that mean we can"],[687,770,"use this prescription"],[775,850,"to make money?"],[904,920,"Dad,"],[1008,1137,"I've decided to take this prescription"],[1166,1333,"to negotiate a stake in a pharma company."],[1400,1466,"A stake?"],[1595,1712,"How do we get a stake?"],[2620,2683,"This prescription"],[2712,2820,"is designed for post-op recovery,"],[2837,2962,"so the market demand is huge."],[2995,3070,"I've checked,"],[3075,3162,"and Marriot Pharma"],[3191,3391,"is the largest pharmaceutical company in town."],[3450,3541,"They have been"],[3545,3712,"looking for new recovery formulas."],[3775,3937,"If we use this prescription"],[3962,4075,"to negotiate,"],[4116,4229,"we can definitely get shares!"],[4412,4470,"Keith,"],[4487,4516,"but"],[4562,4741,"what if they don't accept it?"],[4766,4795,"Or,"],[4862,5025,"what if they take advantage of our inexperience"],[5062,5200,"and offer us a tiny share?"],[5308,5437,"If they don't accept it,"],[5470,5600,"we'll just go to another company!"],[5645,5750,"They'll realize"],[5775,5862,"the value of this prescription."],[5908,6075,"Let's go home and get ready."],[6129,6312,"We'll go to Marriot Pharma this afternoon."],[6820,6979,"Did you write all this?"],[7070,7300,"I read a lot of medical books before,"],[7362,7483,"and I also looked up"],[7487,7612,"information on Marriot Pharma."],[7691,7800,"Sir Moses knows Mr. King."],[7862,7979,"If we can't make a deal,"],[7983,8129,"he can put in a good word for us."],[8216,8504,"If Sir Moses can help, things will be easier."],[8550,8612,"But Keith,"],[8679,8845,"even if we get shares,"],[8945,9108,"how big of a stake can we get?"],[9112,9250,"Will it be enough to reach ten billion?"],[9300,9529,"Let's just secure the first funds."],[9533,9712,"Marriot Pharma has a high market value."],[9766,9941,"As long as we get a decent share,"],[9970,10050,"we won't be far"],[10054,10162,"from ten billion."],[10212,10237,"Let's go,"],[10254,10304,"Dad."],[10333,10412,"To Marriot Pharma"],[10416,10558,"to negotiate our first deal."],[10579,10608,"Let's go."]],"29":[[16,104,"Kid,"],[145,312,"this post-op recovery recipe"],[337,425,"was written by you?"],[466,641,"You want equity for it?"],[1337,1425,"Kid,"],[1479,1612,"pharmaceutical R&D"],[1616,1754,"isn't playing house."],[1787,1975,"If your prescription has issues,"],[1991,2070,"our company"],[2075,2220,"will take a huge risk."],[2325,2433,"Do you realize that?"],[2437,2541,"What can such a young child"],[2587,2716,"possibly research?"],[2720,2833,"This is ridiculous!"],[2883,3020,"What do you think this place is?"],[3041,3129,"Where you get free stuff?"],[4725,4862,"Mr. King, look."],[4866,5066,"Astragalus and Codonopsis tonify body."],[5100,5279,"Ophiopogon and Solomon's Seal nourish energy."],[5287,5362,"Combined with"],[5366,5587,"Oldenlandia to fight tumors,"],[5633,5866,"this formula targets post-op patients"],[5900,5987,"suffering from energy deficiency."],[6008,6170,"and low immunity."],[6245,6425,"It perfectly fills the gap"],[6429,6579,"for restorative supplements."],[6591,6808,"These are all common herbs,"],[6812,7008,"and the mixing ratio isn't special."],[7079,7162,"How can you guarantee the results?"],[7208,7266,"Mr. King,"],[7291,7441,"if I'm not mistaken,"],[7466,7541,"your back"],[7545,7758,"has been hurting for years."],[7762,7875,"Especially when it rains,"],[7912,8033,"you can't even stand up straight."],[8037,8145,"If you don't treat it,"],[8150,8254,"I'm afraid you'll spend"],[8258,8525,"the rest of your life lying in bed."],[8529,8658,"You can see my illness?"],[8666,8837,"Not only can I see it,"],[8841,8945,"I can also cure it!"]],"30":[[316,362,"Mr. King,"],[387,491,"how do you feel now?"],[495,525,"It's amazing."],[529,566,"Simply amazing."],[570,650,"My back"],[654,750,"has never felt"],[754,812,"this comfortable before."],[941,1029,"I'm completely convinced."],[1091,1170,"Dr. Hart,"],[1245,1345,"I'm investing"],[1350,1416,"in your prescription."],[1475,1529,"No rush."],[1533,1662,"I have another formula"],[1691,1775,"specifically for your"],[1779,1891,"lumbar muscle strain."],[3487,3595,"This formula"],[3600,3766,"is called Strengthening Pills."],[3841,3941,"It is extremely effective"],[3945,4116,"for back pain."],[4375,4450,"Dr. Hart,"],[4541,4741,"I'll take both of these formulas."],[4841,4970,"How many shares do you want?"],[4975,5104,"I want a twenty percent stake"],[5116,5266,"in Marriot Pharma."],[5566,5625,"The market potential"],[5629,5737,"of these two formulas"],[5783,5908,"goes far beyond that."],[5912,6029,"Twenty percent?"],[6033,6095,"That is simply"],[6100,6166,"daylight robbery."],[6212,6258,"It's way too much."],[6283,6416,"The company's market cap is ten billion."],[6437,6512,"Twenty percent"],[6516,6595,"amounts to two billion!"],[6650,6683,"Hmph."],[6737,6795,"How could they possibly"],[6800,6879,"be worth that much?"],[6916,7012,"Young man,"],[7016,7112,"I admit,"],[7154,7245,"you're indeed quite skilled."],[7283,7404,"But twenty percent"],[7408,7487,"is just too much."],[7491,7562,"Is it?"],[7566,7641,"Do you have any idea"],[7645,7808,"what the market value"],[7812,7920,"of these two formulas is?"],[8375,8512,"Here is my market analysis."],[8533,8641,"I can tell you explicitly,"],[8666,8787,"that these two formulas"],[8808,8916,"will open up the"],[8920,9070,"post-op recovery market for you."],[9750,9904,"You'll earn at least"],[9945,10016,"500 to 800 million a year."],[10020,10208,"You'll break even in under three years."],[10258,10387,"I can also propose"],[10391,10545,"future improvement plans"],[10566,10675,"and help you develop"],[10679,10783,"a series of products."],[11020,11112,"Deal."],[11116,11195,"I agree."],[11300,11341,"However,"],[11366,11508,"you have to sign an agreement with us."],[11525,11666,"Any future improvements to the formula"],[11712,11866,"must be offered first to"],[11870,11945,"Marriot Pharma."],[12108,12162,"Two billion?"],[12250,12295,"I didn't expect Keith"],[12300,12416,"could really help me."],[12525,12579,"Sure."],[12583,12858,"Transfer the shares to my dad's name."],[12920,12991,"No problem."],[12995,13104,"I'll arrange it right now!"]],"31":[[4,87,"Two billion?"],[129,212,"I've never seen so much money"],[216,312,"in my entire life!"],[358,400,"Dad,"],[404,750,"I'll make sure you have even more money!"],[1087,1120,"In my past life,"],[1158,1258,"the Moses family heirloom,"],[1262,1350,"the Glazed Jade Ring,"],[1366,1470,"was bought by someone"],[1475,1558,"right here at Trent's Antiques."],[1595,1687,"It eventually sold at auction"],[1691,1741,"for a hundred million!"],[1791,1841,"In this life,"],[1883,2008,"I'll beat them to it."],[2016,2062,"Dad,"],[2075,2145,"we can make"],[2166,2258,"some extra money here,"],[2325,2420,"and make the Moses family"],[2470,2612,"owe us a favor."],[2670,2775,"An antique shop?"],[2787,2929,"Why are we here to buy antiques?"],[3008,3141,"You'll see."],[3570,3641,"Keith,"],[3645,3762,"this place doesn't look like it has"],[3766,3841,"anything valuable."],[3845,3937,"Make sure you have the right one."],[4345,4400,"Found it."],[4533,4583,"Hey, kid!"],[4645,4712,"Don't touch that!"]],"32":[[145,183,"Hey!"],[229,283,"Kid,"],[350,425,"don't go touching things."],[508,629,"Everything in here is valuable."],[662,745,"You can't afford the damages!"],[791,845,"Sir,"],[879,970,"what's inside this?"],[1004,1045,"I'd like to see."],[1116,1395,"It's a jade thumb ring in this box."],[1441,1516,"Look if you want,"],[1558,1641,"just don't break it."],[1675,1766,"It costs tens of thousands!"],[2483,2550,"This thumb ring,"],[2575,2666,"though not a top-tier piece,"],[2700,2858,"is quite old."],[2908,3033,"If you like it,"],[3116,3241,"fifty thousand"],[3245,3312,"and it's yours!"],[3462,3520,"Just as I thought."],[3533,3633,"It's the Moses family's heirloom,"],[3637,3733,"the glazed jade thumb ring."],[3870,3937,"Fifty thousand?"],[4004,4108,"Are you trying to rob us?"],[4112,4204,"For this lousy ring,"],[4250,4333,"five hundred tops!"],[4462,4587,"Get lost if you can't afford it!"],[4629,4770,"Don't disturb my sleep."],[5050,5112,"Sir,"],[5150,5283,"what is this scroll?"],[5304,5412,"Let me take a look at that too."],[5433,5533,"Look if you want."],[6258,6370,"That scroll"],[6429,6533,"isn't worth much."],[6583,6687,"I picked it up in the countryside."],[6791,6887,"If you want it,"],[6929,7012,"it'll be ten thousand."],[7129,7212,"Sir, you really have"],[7216,7308,"a big appetite."],[7312,7425,"You admitted it's not worth much,"],[7429,7516,"so why ask us for ten thousand?"],[7616,7720,"Even if it's not worth much,"],[7758,7879,"it's still an antique."],[7975,8033,"Sir,"],[8083,8245,"this scroll is corroded by dirt,"],[8320,8450,"and the contents are illegible."],[8479,8554,"It's worthless."],[8591,8650,"I'm mainly"],[8683,8820,"interested in that thumb ring."],[8879,8916,"My final offer,"],[8920,9158,"- ten thousand. - Ten thousand?"],[9229,9337,"My jade thumb ring"],[9341,9466,"is worth more than ten thousand alone."],[9508,9587,"Why don't you"],[9633,9695,"add a little more?"],[9795,9858,"Keith,"],[9916,10033,"I really don't think"],[10037,10187,"these two items are worth it."],[10191,10283,"Don't get ripped off."],[10345,10391,"Dad,"],[10395,10545,"let's go look somewhere else."],[10562,10604,"Hey, hey, hey,"],[10620,10662,"wait, don't go."],[10741,10795,"I'll sell,"],[10858,10925,"I'll sell right now."],[10995,11037,"Here,"],[11041,11087,"pay up."],[11529,11595,"Kid,"],[11641,11704,"come back often."],[11758,11870,"I've got plenty of treasures here!"]],"33":[[537,566,"Dad,"],[570,683,"we hit the jackpot!"],[904,1008,"You mean"],[1012,1145,"both of these things are valuable?"],[2633,2800,"This thumb ring is beautiful!"],[2845,2887,"Dad,"],[2891,3295,"this is the Moses family's lost heirloom."],[3341,3425,"What?"],[3600,3729,"Is this the heirloom"],[3762,3866,"the Moses family lost?"],[3933,3983,"Let's go."],[4016,4104,"We're going to the Moses house."],[4137,4187,"Okay,"],[4212,4262,"keep it safe."],[4475,4529,"Miss Moses."],[4608,4712,"Keith,"],[4716,4770,"Uncle Daniel,"],[4775,4812,"you're here."],[4845,4983,"My grandpa has been waiting for you."],[5033,5154,"He said after taking your medicine,"],[5179,5312,"his chest doesn't feel tight anymore."],[5354,5520,"Miss Moses, you're too kind."],[5525,5620,"We still haven't thanked you"],[5625,5737,"for what happened last time."],[5816,5929,"Sophie,"],[5933,6083,"I brought two gifts"],[6087,6212,"for Grandpa Lennon."],[6262,6387,"Keith, you're too polite."],[6404,6525,"You didn't have to bring anything!"],[6541,6583,"Come,"],[6587,6687,"I'll take you inside."],[6691,6741,"This way."],[7362,7445,"Keith,"],[7541,7625,"you're here."],[7716,7779,"Keith,"],[7783,7895,"let me tell you,"],[7912,7979,"yesterday,"],[7987,8120,"I went for a check-up,"],[8154,8279,"and the doctor told me"],[8325,8450,"that my lung tumor"],[8500,8600,"has shrunk."],[8616,8704,"It's all"],[8716,8837,"thanks to you!"],[8962,9037,"Grandpa Lennon,"],[9079,9266,"I found this in an antique shop."],[9316,9408,"Take a look."],[9412,9512,"Is this the heirloom"],[9516,9654,"that the Moses family lost?"],[10816,10887,"Yes,"],[10941,11033,"it is!"],[11116,11304,"This is the Moses family heirloom."],[11420,11512,"We've searched for years"],[11516,11612,"and never found it."],[11716,11787,"Keith,"],[11829,11920,"I never expected"],[11975,12083,"you would actually find it."]],"34":[[33,95,"Grandpa,"],[145,225,"is this our family's"],[229,375,"ancestral Glazed Jade Ring?"],[420,520,"It's so beautiful!"],[537,683,"Yes, it is!"],[725,800,"Keith,"],[829,933,"I want to thank you."],[945,1062,"You helped the Moses family"],[1075,1241,"recover our ancestral treasure."],[1262,1333,"Tell me,"],[1358,1475,"what reward do you want?"],[1479,1591,"Just say the word."],[1645,1750,"If it's in my power,"],[1791,1920,"I certainly won't refuse!"],[1979,2083,"Don't mention it."],[2145,2216,"Grandpa Lennon,"],[2237,2341,"take a look at this too."],[2854,2950,"Keith,"],[2979,3091,"forgive my clumsy eyes,"],[3137,3245,"but regarding this painting,"],[3250,3366,"I really don't see"],[3375,3508,"anything special about it."],[3562,3641,"Grandpa Lennon,"],[3658,3833,"please get me a pair of white gloves."],[4650,4729,"Grandpa Lennon."],[4766,4883,"Take another close look!"],[4900,4933,"This"],[4937,5025,"This is authentic."],[5108,5254,"It's an authentic work by Thomas,"],[5266,5370,"Bamboo and Rock."],[5404,5470,"Keith,"],[5512,5795,"where did you get such a precious treasure?"],[6016,6087,"Grandpa Lennon,"],[6108,6370,"I picked it up at an antique shop,"],[6404,6512,"and brought it for you."],[6537,6591,"Today,"],[6629,6804,"I'm here to borrow two billion"],[6837,6954,"to bet against Austin Drake,"],[6975,7091,"so I'd like to ask you"],[7116,7266,"to borrow the money."],[7283,7433,"You want to borrow two billion?"],[7579,7712,"That's a massive amount."],[7716,7858,"I'm afraid the Moses family"],[7883,8000,"can't come up with"],[8004,8137,"that much capital right now."],[8183,8279,"If I win,"],[8308,8420,"I will pay you back three billion."],[8516,8612,"If I lose,"],[8662,8812,"I'll serve as your appraiser for ten years,"],[8858,8979,"identifying all kinds of"],[8983,9170,"antiques and raw stones as compensation."],[9279,9412,"And regarding your health,"],[9437,9508,"I will also"],[9512,9654,"continue to help extend your life!"]],"35":[[20,54,"Grandpa,"],[91,225,"Keith is really amazing."],[270,429,"He beat Conrad before,"],[504,708,"and he exposed Justin's fake ring."],[795,870,"Besides,"],[875,1050,"he's helped us find our family heirloom."],[1104,1258,"We should help him!"],[1366,1595,"It's not that I don't trust him."],[1633,1716,"It's just that"],[1750,1891,"the amount is too large,"],[1958,2100,"and I have to consider the company's"],[2137,2258,"financial situation."],[2283,2362,"Grandpa Lennon,"],[2391,2512,"I know two billion"],[2516,2637,"is not a small sum."],[2675,2795,"Please don't feel obligated."],[2866,2962,"If it doesn't work out,"],[3066,3204,"I can figure something else out."],[3433,3483,"Grandpa,"],[3575,3825,"didn't the bank come by a few days ago"],[3829,3920,"to offer a secured loan?"],[3983,4191,"We can just take the loan!"],[4245,4312,"Why don't we help Keith"],[4316,4437,"get through this crisis first?"],[4537,4612,"Alright."],[4733,4783,"Keith,"],[4825,4895,"I will lend"],[4933,5025,"the two billion to you!"],[5120,5166,"Sir Moses,"],[5250,5400,"thank you so much."],[5437,5508,"Rest assured,"],[5512,5745,"we will pay back this money!"],[5791,5887,"Thank you, Grandpa Lennon."],[5970,6020,"Don't mention it."],[6091,6212,"You helped me retrieve"],[6250,6358,"my family heirloom,"],[6408,6575,"and you saved my life."],[6629,6700,"Consider this two billion"],[6745,6966,"as a sign of my trust in Keith!"],[7016,7204,"And I believe in Keith."],[7225,7412,"You'll definitely beat Mr. Drake!"],[7616,7675,"Grandpa Lennon,"],[7708,7820,"once I defeat Austin Drake,"],[7883,8033,"I'll pay you back the three billion,"],[8100,8187,"and help you"],[8191,8312,"authenticate all kinds of antiques."],[8391,8466,"No rush on the money."],[8516,8712,"Just make sure you beat Mr. Drake"],[8737,9008,"and stop him from causing more harm."],[9041,9125,"That's more important than anything!"]],"36":[[100,254,"Right now, we have four billion,"],[258,366,"but we're still short six billion."],[420,541,"We only have two days left."],[545,633,"What are we going to do, Keith?"],[670,704,"Dad,"],[729,825,"there's always a way."],[829,966,"Just waiting for the right moment."],[983,1125,"You just take care of Mom."],[1141,1279,"She's just starting to recover,"],[1283,1395,"we can't let her worry."],[1466,1637,"I just can't help feeling uneasy."],[1670,1854,"Mr. Drake is cruel and ruthless."],[1866,1979,"If we can't scrape the money together,"],[1983,2129,"he won't let us off the hook."],[2145,2283,"Trust me, Dad."],[2316,2483,"Tomorrow, I'll make ginseng soup for Mom,"],[2495,2716,"and cook her favorite dish."],[2770,2879,"Stop worrying,"],[2883,3054,"eat something, and get some sleep."],[3950,4033,"Keith,"],[4045,4275,"we used to always take care of you,"],[4312,4516,"but now the tables have turned."],[4662,4812,"My son has really grown up!"],[4883,4950,"Mom."],[4954,5208,"This ginseng soup has been simmering for hours."],[5212,5375,"Make sure you drink plenty of it,"],[5379,5466,"it's good for your health!"],[5650,5787,"Here, Keith, have some more."],[6158,6225,"Daniel."],[6279,6404,"Why aren't you eating?"],[6454,6545,"Are you"],[6575,6683,"hiding something from me?"]],"37":[[16,95,"Daniel."],[170,279,"Why aren't you eating?"],[283,383,"Are you"],[404,600,"hiding something from me?"],[654,700,"No."],[704,791,"It's just that"],[795,916,"I haven't had much of an appetite."],[941,1029,"Don't overthink it."],[1041,1095,"I'll eat."],[1262,1458,"We're a family."],[1462,1575,"I don't want my illness"],[1579,1654,"to become a burden."],[1658,1837,"Mom, everything's fine."],[1862,1933,"Dad has just been"],[1945,2179,"eating too much rich food,"],[2183,2258,"he's become a bit of picky."],[2279,2412,"He'll be fine in a few days."],[2416,2458,"Right."],[2604,2758,"Keith is so sensible."],[2900,2979,"Here,"],[3029,3108,"eat some more."],[3329,3412,"Keith,"],[3429,3520,"there's only one day left."],[3570,3775,"We won't be able to raise six billion."],[3895,4037,"Mr. Drake is ruthless."],[4041,4137,"Your mother and I aren't afraid to die,"],[4141,4266,"but you're still so young."],[4304,4441,"I don't want you destroyed by him."],[4504,4545,"Listen,"],[4591,4741,"tomorrow I'll go alone to see Mr. Drake."],[4766,4850,"I'll take him down with me."],[4883,4962,"That way, at least I can ensure"],[4966,5095,"you and your mother are safe."],[5120,5254,"Dad, don't be silly."],[5258,5450,"Throwing your life away won't solve anything,"],[5466,5675,"and it'll just break Mom's heart."],[5679,5754,"I promise,"],[5766,5829,"by tomorrow,"],[5833,6033,"I will raise the remaining six billion."],[6066,6170,"Trust me."],[6183,6312,"I can do it!"],[6316,6391,"Okay."],[7254,7379,"Daniel."],[7412,7529,"Keith."],[7550,7708,"If that day really comes,"],[7825,7979,"I'll trade my life"],[8054,8208,"to keep you two safe."],[8300,8379,"Levi, the Jade Tycoon of Dragal,"],[8400,8470,"lost a major bet,"],[8500,8583,"causing his Jade Cities"],[8587,8700,"to go bankrupt one by one."],[8820,8887,"Sure enough."],[8891,9033,"In my past life, Levi lost"],[9037,9220,"his ten-billion-dollar mine"],[9225,9341,"to Austin Drake."],[9354,9562,"He never recovered,"],[9566,9654,"hit rock bottom,"],[9658,9795,"and jumped to his death."],[9816,10012,"Now is my perfect opportunity!"]],"38":[[537,654,"The Ghost Market was also"],[658,783,"one of Levi's properties, huh?"],[845,958,"A Jade Tycoon indeed."],[1012,1116,"I just heard that,"],[1175,1320,"in order to pay his debts,"],[1325,1495,"Levi sold off the entire Jade Cities."],[1537,1687,"This stall is all that's left now."],[1750,1904,"I see."],[2000,2112,"He still has a fallback."],[2116,2375,"Then why did he still commit suicide?"],[2391,2458,"Keith,"],[2525,2770,"if we ask Mr. Goodman to lend us money,"],[2825,2912,"do you think he'll agree?"],[2958,3104,"We're complete strangers to him."],[3187,3229,"Dad,"],[3241,3383,"we're not here to borrow money,"],[3400,3495,"but to discuss a partnership."],[3545,3612,"As long as I show him"],[3616,3720,"what I'm capable of,"],[3754,3875,"he'll help us."],[4379,4416,"Miss,"],[4433,4679,"I'm looking for Mr. Levi Goodman."],[4866,4891,"Whoa."],[5012,5258,"Where did you two crawl out from?"],[5350,5475,"Do you know who Mr. Goodman is?"],[5533,5670,"How dare you use his full name?"],[5766,5829,"Hello."],[5916,6050,"We're here to talk business"],[6054,6170,"with Mr. Goodman."],[6175,6266,"Could you please let him know?"],[6333,6425,"Business?"],[6508,6645,"What kind of business can you have"],[6683,6833,"with Mr. Goodman?"],[6895,7083,"Mr. Goodman doesn't want guests lately."],[7108,7170,"Security!"],[7175,7312,"Kick them out."],[7320,7391,"Wait!"],[7608,7650,"Excuse me,"],[7683,7795,"are you Mr. Keith Hart?"],[7816,7975,"Mr. Goodman wants to meet you."]],"39":[[62,129,"Keith,"],[133,212,"Mr. Goodman wants to meet you."],[216,312,"We're saved!"],[325,375,"Gentlemen,"],[400,445,"please."],[866,904,"Mr. Goodman."],[1166,1212,"Oh?"],[1266,1333,"Mr. Hart."],[1354,1445,"Mr. Keith."],[1466,1566,"I've heard so much about you."],[1570,1654,"Your reputation precedes you."],[1670,1737,"Even Mr. Drake"],[1741,1895,"suffered a loss at your hands."],[1941,2016,"Impressive."],[2091,2195,"You're too kind, Mr. Goodman."],[2229,2325,"It was just luck."],[2412,2462,"Oh, no."],[2483,2570,"It wasn't just luck."],[2591,2691,"It was true skill."],[2720,2866,"Gentlemen,"],[2870,2929,"please, come inside."],[3583,3679,"Mr. Keith,"],[3737,4012,"I'm sure you didn't come for the stones."],[4050,4154,"What is it really about?"],[4191,4266,"Please speak frankly."],[4775,4833,"Mr. Goodman,"],[4854,4979,"I heard that you lost"],[4983,5312,"a ten-billion-dollar mining vein to Austin."],[5316,5408,"Is that correct?"],[5550,5712,"I'm going to help you"],[5716,5816,"win that mine back!"]],"40":[[0,129,"It's not that I don't trust you,"],[225,429,"but Mr. Drake is insidious and cunning."],[433,533,"He is extremely meticulous."],[633,750,"Beating him"],[866,925,"is too difficult."],[1125,1391,"I have been tracking this mining vein for years."],[1454,1591,"The jade reserves"],[1629,1800,"are worth at least fifty billion!"],[1937,2112,"Mr. Drake pulled a fast one on me this time."],[2216,2375,"I can't accept it,"],[2441,2595,"but there's nothing I can do."],[2650,2766,"Beating him"],[2854,2933,"is next to impossible!"],[2962,3170,"I know Mr. Drake's tricks,"],[3195,3300,"but as for my methods,"],[3304,3445,"he has no clue."],[3491,3712,"Since I dared to come to you,"],[3754,3937,"I'm very confident."],[3975,4112,"Worst case scenario,"],[4175,4333,"I lose,"],[4366,4508,"I'll work for you"],[4512,4587,"as an appraiser for ten years."],[4641,4716,"That value"],[4750,4883,"exceeds six billion,"],[4916,5066,"you won't lose out."],[5270,5333,"Alright."],[5416,5500,"I trust you."],[5579,5708,"Mr. Drake played me this time,"],[5750,5912,"and I really can't swallow this insult."],[5920,6112,"Even if I have to bet my life and fortune,"],[6170,6303,"I'm going to gamble against him again!"],[6337,6404,"Gavin,"],[6425,6508,"make the arrangements."],[6516,6600,"Mortgage the Goodman Group's"],[6604,6791,"entire assets to get a loan of six billion,"],[6816,6950,"and transfer it to Mr. Hart's account."],[7012,7095,"Do it immediately."],[7116,7216,"By tomorrow morning,"],[7220,7295,"the money must be there!"],[7300,7375,"Yes, Mr. Goodman!"],[7379,7437,"I'll get right on it."],[7716,7795,"Mr. Keith,"],[7837,7966,"tomorrow's game"],[7970,8054,"depends entirely on you."],[8070,8154,"If you can help me"],[8158,8250,"win back the mining vein,"],[8300,8520,"I will owe you a favor"],[8525,8595,"for the rest of my life."]],"41":[[141,316,"One, two, three…"],[950,1025,"Daniel,"],[1070,1158,"are you and Keith"],[1187,1329,"hiding something from me?"],[1416,1650,"Where have you been these days?"],[1654,1733,"No,"],[1770,1875,"we didn't do anything."],[2016,2120,"What's that on your phone?"],[2166,2229,"Let me see."],[2466,2529,"Is this"],[2989,3147,"ten billion?!"],[3320,3387,"Daniel,"],[3408,3450,"how do you have"],[3454,3566,"so much money?"],[3654,3712,"Huh?"],[3758,3808,"This is"],[3891,3975,"money Keith earned"],[4100,4150,"from writing prescriptions"],[4154,4208,"and"],[4270,4312,"appraising"],[4358,4412,"treasures."],[4979,5112,"What?"],[5191,5291,"How could you let Keith"],[5295,5420,"do things like that?"],[5483,5562,"Don't you know"],[5566,5683,"what kind of person Mr. Drake is?"],[5720,5795,"If we lose,"],[5812,5962,"our family is finished."],[6095,6195,"Mom, don't worry."],[6208,6304,"I'm confident I can win."],[6441,6525,"Keith,"],[6625,6729,"it's our fault for being useless,"],[6783,6866,"making you shoulder so much"],[6870,6975,"at such a young age."],[7104,7204,"If I'd known it would come to this,"],[7258,7379,"I wouldn't have treated my illness."],[7400,7470,"I can't just let you"],[7475,7558,"go and take such risks."],[7587,7641,"Mom,"],[7645,7704,"you have to get treated."],[7708,7791,"And what I'm doing"],[7820,7975,"isn't a risk."],[8008,8125,"I've already seen through"],[8150,8262,"Mr. Drake's tricks."],[8404,8504,"He can't beat me."],[8829,8879,"Mom,"],[8883,9012,"I had someone"],[9016,9079,"custom-make this for you."],[9129,9220,"Here, take it."],[9225,9429,"I'm going to make a lot of money,"],[9462,9537,"so you and Dad"],[9541,9654,"can live a good life!"]],"42":[[208,291,"Mr. Drake,"],[375,554,"aren't you overreacting?"],[654,833,"He's just a six-year-old kid."],[879,1012,"I can beat him"],[1045,1158,"with a single finger!"],[1208,1312,"Mr. Luke,"],[1345,1537,"we can't let our guard down."],[1541,1741,"This kid is uncanny."],[1795,1916,"Even though he's only six,"],[1925,2012,"he can tell the authenticity"],[2016,2179,"of any antique at a glance."],[2216,2312,"Do not underestimate him!"],[2354,2441,"Exactly!"],[2454,2541,"That kid"],[2545,2650,"knows some wicked tricks."],[2687,2854,"In our last stone appraisal match,"],[2895,3075,"he actually spotted the artificial seam"],[3079,3225,"in my raw stone!"],[3383,3458,"Mr. Luke,"],[3491,3629,"please help me"],[3633,3729,"teach him a lesson!"],[3779,3883,"Don't worry."],[3945,4154,"I've been in the appraisal business for decades,"],[4245,4358,"and there isn't a single person"],[4362,4500,"who has ever beaten me!"],[4895,4995,"That's excellent."],[5000,5112,"With an expert like you here,"],[5116,5241,"the ten billion and the mining vein"],[5266,5379,"are as good as mine."],[5658,5745,"For the gamble tomorrow,"],[5804,5958,"post two guards at the door"],[5983,6141,"and have a few men lie in ambush."],[6233,6420,"I want to make sure they never leave."],[6504,6591,"Rest assured, Mr. Drake."],[6595,6670,"I've arranged everything."],[6725,6812,"If they have the guts"],[6829,6941,"to show up tomorrow,"],[7008,7112,"I'll make sure the father and son"],[7195,7304,"have absolutely no escape!"],[7445,7520,"Keith,"],[7595,7775,"you beat me a few times before."],[7812,7904,"But this time,"],[8000,8145,"I'll make you realize"],[8204,8295,"that going against me"],[8358,8504,"is a dead end!"]],"43":[[970,1125,"Keith, you made it."],[1150,1279,"Grandpa said that this time,"],[1283,1379,"Mr. Drake has hired"],[1383,1491,"the famous appraiser, Henry Luke."],[1545,1658,"An appraisal master?"],[1716,1858,"Compared to my eyes,"],[1862,2016,"he's nothing at all."],[2400,2570,"Those look like Mr. Drake's men."],[2608,2712,"Don't worry."],[2741,2820,"Grandpa sent people"],[2825,2937,"to guard the hotel perimeter."],[2941,3075,"They won't dare try any tricks!"],[3079,3166,"Let's go."],[3812,3890,"Hey, kid."],[3900,4016,"You can go inside,"],[4020,4212,"but your dad stays here as a hostage."],[4241,4320,"Otherwise,"],[4337,4479,"don't even think about joining this competition."],[4483,4558,"Don't you dare."],[4591,4670,"Conrad,"],[4675,4750,"my grandpa's men"],[4754,4887,"are guarding the perimeter."],[4895,5025,"If you dare lay a hand on us,"],[5029,5162,"neither you nor Mr. Drake"],[5166,5300,"will get away with it!"],[5620,5708,"Move!"]],"44":[[433,641,"You actually have the guts to show up, kid!"],[770,925,"Did you get the money together?"],[945,1162,"I wouldn't be here if I hadn't."],[1379,1479,"Today,"],[1483,1633,"I'll make you understand that"],[1645,1804,"in the jade appraisal business,"],[1808,2029,"I call the shots!"],[2104,2237,"Consider your ten billion dollars"],[2241,2420,"a tribute to me."],[2645,2779,"This kid is done for."],[2804,2941,"With Master Henry here,"],[2945,3045,"he doesn't stand a chance."],[3116,3258,"That's ten billion dollars!"],[3287,3375,"If he loses,"],[3379,3516,"he's ruined for life."],[3654,3716,"Keith,"],[3800,3887,"maybe we should just leave."],[3929,4008,"This is too dangerous."],[4066,4112,"Dad,"],[4129,4287,"we're already here, let's see it through."],[4325,4395,"Kid,"],[4425,4545,"today's competition"],[4550,4675,"consists of three rounds."],[4737,4929,"The rules are simple."],[4941,5062,"Across these three rounds,"],[5066,5204,"you must win every one"],[5208,5320,"to be declared the winner."],[5354,5454,"Otherwise,"],[5504,5620,"it counts as a loss."],[5641,5695,"And if you lose,"],[5700,5904,"the ten billion stays,"],[5920,5983,"and you,"],[5987,6041,"get the hell out!"],[6075,6112,"You!"],[6212,6366,"Those terms are completely unfair!"],[6395,6483,"This is our turf,"],[6487,6612,"so naturally, we call the shots."],[6645,6720,"You don't have to play,"],[6825,6975,"but we'll consider that an automatic forfeit."],[7000,7154,"Leave the money and get lost."],[7204,7262,"Mr. Drake,"],[7275,7404,"I've treated you as a senior"],[7408,7537,"and shown you every courtesy."],[7579,7662,"Yet you have the nerve to use"],[7666,7783,"such dirty tricks"],[7787,7912,"to deal with a child."],[7916,7975,"If word gets out,"],[7979,8137,"aren't you afraid of being laughed at?"],[8166,8304,"Laughed at?"],[8387,8529,"Who would dare laugh at me?"],[8641,8750,"Do they have a death wish?"]],"45":[[12,162,"Three rounds it is then."],[195,383,"But I have a condition."],[420,595,"If I win,"],[600,804,"not only must you hand over the mine,"],[854,1083,"you must also leave the jade industry forever!"],[1087,1120,"Hmph."],[1154,1241,"You've got guts, kid!"],[1408,1554,"Trying to bargain with me?"],[1595,1650,"Fine!"],[1733,1870,"But if you lose,"],[1933,2025,"I'm not just keeping the ten billion."],[2087,2258,"The three of you must kneel down"],[2312,2433,"and kowtow to me three times!"],[2766,2933,"For the first round,"],[2941,3016,"we will compete in"],[3041,3179,"antique appraisal."],[3183,3250,"Now,"],[3254,3416,"from among these items here,"],[3441,3504,"you need to find"],[3541,3737,"the one and only authentic piece."],[3795,3900,"Whoever finds it"],[3941,4033,"wins the round."],[4037,4129,"You have"],[4183,4262,"three minutes."],[4295,4400,"I'll go first."],[5695,5770,"Mr. Drake,"],[5816,5875,"everyone,"],[5895,6012,"the authentic piece is right here."],[6112,6233,"This bowl has a floral design inside,"],[6308,6420,"bears the 'Made in 17th Century' mark,"],[6550,6670,"and has a clear glaze."],[6779,6950,"It is a genuine piece."],[7695,7754,"That is correct."],[7816,7916,"This is indeed"],[7920,8079,"a porcelain bowl made in the 17th century."],[8120,8262,"It's worth two million,"],[8266,8475,"and it's the only authentic piece available!"],[8479,8558,"Keith,"],[8654,8770,"what do you have to say?"],[8816,8866,"It's over."],[8883,9029,"They're finished this time."],[9041,9191,"It ended before it even started."],[9195,9312,"The ten billion is gone."],[9320,9512,"That brat is too arrogant."],[9516,9712,"He jumped right into the trap."],[9737,9875,"You can't stop a man with a death wish."],[9991,10108,"Who says I lost?"],[11308,11500,"The authentic piece is this teapot."]],"46":[[12,175,"The authentic piece is this teapot."],[183,379,"What is that brat doing?"],[383,462,"They already said"],[466,583,"there's only one authentic piece."],[587,716,"And he still refuses to give up."],[733,854,"He's just acting like a sore loser."],[875,1020,"But he picked the wrong place."],[1045,1195,"That teapot"],[1200,1316,"is a fake."],[1320,1454,"If you like it,"],[1475,1541,"take it home"],[1562,1641,"and use it as a chamber pot."],[1645,1741,"It's all yours!"],[1745,1904,"Hahaha!"],[1920,2079,"This is Dave Quinn's teapot,"],[2083,2158,"made of old purple clay"],[2175,2312,"from the 14th century."],[2320,2512,"The spout has a natural patina,"],[2537,2712,"and the seal on the bottom is hand-carved."],[2716,2820,"It's ten times more precious"],[2825,2933,"than that blue-and-white bowl!"],[2937,3091,"If you want to know if I'm lying,"],[3095,3258,"just find someone to appraise it."],[3404,3504,"You're not an authority."],[3508,3612,"We need an authoritative"],[3616,3741,"antique expert to judge!"],[3745,3812,"Professor Collins,"],[3816,3970,"you're an authority in the antique world."],[3987,4079,"Please take a look."],[4083,4141,"This is the resident expert"],[4145,4470,"of the National Museum, Edward Collins."],[4475,4587,"With Professor Collins here,"],[4591,4654,"he'll certainly be able to tell"],[4658,4783,"if this teapot is authentic!"],[5004,5079,"Uncle Levi,"],[5083,5141,"tomorrow,"],[5145,5412,"you must invite Dragal's appraisal expert"],[5416,5625,"to the stone venue."],[5629,5766,"Whether we succeed or fail"],[5770,5912,"depends on Professor Collins."],[5916,6029,"Don't worry, Keith."],[6033,6175,"Everything is arranged."],[6420,6508,"Professor Collins,"],[6512,6629,"what brings you here?"],[6654,6733,"I just came to take a look."],[7258,7333,"That's right."],[7358,7554,"This is a genuine Dave Quinn's piece."],[7558,7633,"It is worth"],[7658,7804,"at least five million!"]],"47":[[0,116,"We won!"],[120,191,"I never expected"],[195,266,"Keith to be so shrewd."],[270,412,"He actually managed"],[416,479,"to get Professor Collins"],[483,625,"to come personally!"],[629,712,"Mr. Drake,"],[733,787,"what do you say?"],[837,975,"The genuine piece Keith found"],[1000,1070,"is worth much more than"],[1075,1208,"what your people found."],[1233,1312,"We won"],[1316,1408,"this round!"],[1412,1512,"Hahahaha."],[1587,1725,"You only won one round."],[1737,1841,"Don't get too cocky."],[1925,2062,"There are still two rounds left!"],[2066,2175,"Round two."],[2437,2529,"For the second round,"],[2600,2770,"we're appraising coins."],[2795,2920,"You have ten minutes."],[2970,3083,"Whoever finds"],[3087,3291,"the oldest and most valuable coin"],[3316,3458,"in this pile"],[3462,3525,"will be the winner!"],[3804,3895,"This is a genuine piece"],[3900,4058,"I spent a fortune on the black market."],[4108,4212,"It is ancient"],[4241,4350,"and worth ten million!"],[4370,4462,"If that kid"],[4466,4558,"makes it to the second round,"],[4612,4733,"bring this out."],[4925,4987,"Yes, Mr. Drake."],[5116,5237,"I'll go first!"],[5591,5745,"Kid, you're going down!"],[5795,5870,"Keith,"],[5875,6075,"I think this is all just common coins,"],[6079,6187,"nothing valuable at all!"],[6191,6325,"Conrad has been causing trouble,"],[6329,6470,"there must be something good hidden."]],"48":[[283,337,"Mr. Drake,"],[366,437,"I found it!"],[491,750,"An ancient bronze coin from the 16th century BC?"],[1029,1225,"You have a sharp eye, Mr. Drake!"],[1233,1291,"Correct!"],[1295,1437,"This is indeed from the 16th century BC!"],[1487,1570,"It is ancient,"],[1587,1775,"and worth at least ten million!"],[3104,3175,"Professor Collins,"],[3187,3312,"please take a look at this one."],[3908,3979,"This is"],[4000,4191,"the prototype of the first coin!"],[4225,4325,"Look at the inscription."],[4404,4475,"It's the small seal script"],[4491,4620,"written by Simon Lee himself."],[4691,4808,"The coin is heavy,"],[4829,4958,"and the edge has the casting marks"],[5004,5179,"unique to a prototype coin."],[5204,5366,"There are fewer than ten in existence."],[5429,5633,"It is worth at least twenty million!"],[5675,5833,"It's much more precious"],[5866,5970,"than that ancient bronze coin!"],[6075,6125,"No way!"],[6129,6212,"It can't be!"],[6279,6383,"How could there be a coin"],[6387,6495,"more expensive than mine?"],[6575,6666,"These coins"],[6670,6825,"were all carefully inspected."],[6845,6970,"How could there be a mistake?"],[6995,7183,"But Professor Collins personally said it's"],[7187,7345,"the prototype of the first coin."],[7358,7416,"How?"],[7433,7525,"Are you questioning"],[7529,7679,"Professor Collins' authority?"],[7783,7862,"Please announce the result!"],[8370,8445,"After appraisal,"],[8466,8604,"the prototype coin"],[8608,8716,"found by Mr. Keith Hart"],[8720,8804,"is of higher value!"],[8812,8875,"Round two,"],[8879,8979,"Mr. Keith Hart wins."]],"49":[[0,79,"It is confirmed,"],[95,279,"Mr. Keith Hart wins the second round."],[291,404,"We won again!"],[408,500,"Keith, you're amazing!"],[504,591,"You're incredible!"],[595,695,"I knew you had a plan."],[733,900,"Now Mr. Drake's scheme"],[945,1029,"is going to fail."],[1079,1166,"Round three."],[1254,1329,"Painting appraisal."],[1533,1812,"Mr. Luke, please come to the stage."],[1925,1995,"Mr. Drake."],[2000,2070,"Mr. Luke,"],[2154,2245,"thank you for coming."],[2279,2312,"Is…"],[2333,2416,"Is that Mr. Luke?"],[2470,2604,"I didn't expect to see"],[2616,2716,"the appraisal world's"],[2720,2816,"two leading authorities"],[2841,3029,"together here today!"],[3075,3158,"I can't believe Mr. Drake"],[3162,3312,"brought such a powerful helper this time."],[3316,3504,"Even though this kid won the first two rounds,"],[3512,3587,"this time,"],[3595,3695,"he's probably done for!"],[3795,3925,"Two leading authorities?"],[3945,4304,"One is Professor Edward Collins."],[4358,4433,"And the other"],[4512,4612,"is Henry Luke."],[4704,4883,"In the appraisal world, the two of them"],[4912,5041,"are known as the 'Twin Stars',"],[5062,5175,"and are equally matched."],[5216,5308,"Now that Henry is here,"],[5312,5429,"how can Keith possibly compete?"],[5525,5612,"It seems impossible for him"],[5662,5770,"to win this final round."]],"50":[[8,91,"Kid,"],[133,225,"I admit"],[229,412,"that you've had great luck today."],[437,575,"But you need to learn"],[583,720,"what true professionalism is!"],[816,858,"Hmph."],[916,1095,"I've been an appraiser for years."],[1116,1241,"The treasures I've verified"],[1275,1562,"could fill the entire Royal Hotel!"],[1579,1737,"How can you compare to me?"],[1779,1804,"Old man,"],[1820,2162,"professionalism isn't shown by bluffing."],[2183,2245,"Arrogance"],[2275,2466,"comes with a price!"],[2470,2612,"Is that so? I'm waiting."],[3358,3587,"This painting is a fake."],[3691,3883,"It's worth a hundred bucks at most."],[3950,4025,"Kid,"],[4133,4241,"you're up."],[4408,4575,"This painting is authentic."],[4595,4779,"It's worth at least ten million."],[4895,5045,"But the top appraisers in town"],[5050,5170,"all say that it's a fake."],[5216,5350,"Is Keith going to"],[5395,5479,"lose this time?"],[5575,5687,"Little brat,"],[5766,5933,"you're still too green."],[5966,6104,"Even though this painting,"],[6108,6679,"looks like \"Court Ladies\" from the 7th century."],[6750,6862,"Unfortunately,"],[6883,7175,"Court Ladies was painted on hemp paper."],[7208,7508,"This painting, however, clearly uses rice paper."],[7558,7629,"Therefore,"],[7641,7845,"this painting is a fake."],[7995,8250,"Mr. Luke is truly a professional."],[8279,8600,"He noticed even such subtle differences."],[8633,8812,"Hahaha."],[8908,8966,"Keith,"],[8970,9087,"why don't we just admit defeat?"],[9091,9220,"Safety is more important than winning."],[9225,9300,"Okay?"],[9337,9437,"Oh, really?"],[9441,9566,"I wouldn't be so sure!"]],"51":[[150,204,"This kid…"],[216,404,"This kid is way too arrogant!"],[525,629,"Kid,"],[633,783,"do you know anything about appraisal?"],[804,916,"Wasn't the evidence I just presented"],[920,1025,"clear enough?"],[1066,1187,"If you continue to be unreasonable,"],[1216,1400,"it is a sign of disrespect to the industry!"],[1470,1604,"What right do you have"],[1608,1741,"to question Mr. Luke?"],[1745,1850,"Let me tell you,"],[1916,2087,"you're not even fit to shine his shoes!"],[2100,2129,"Dad,"],[2145,2262,"lend me your lighter."],[3320,3329,"Hey, hey, hey."],[3379,3500,"What are you doing?"],[3816,3975,"Destroying the evidence is useless."],[4016,4125,"You've already lost."],[4162,4312,"Even if you burn the painting,"],[4316,4433,"it won't change anything."],[4545,4662,"This is an act of desperation!"],[4666,4875,"Now, take a closer look!."],[5350,5391,"What?"],[6237,6300,"What?"],[6925,6979,"That's…"],[7058,7375,"This is \"Dwelling in the Mountains\"!"]],"52":[[0,54,"What?"],[145,433,"This is \"Dwelling in the Mountains\"!"],[512,612,"Oh my God!"],[616,762,"It actually is \"Dwelling in the Mountains\"!"],[812,900,"This is a masterpiece"],[904,1054,"created by Hugh Gavin."],[1058,1183,"It's priceless!"],[1220,1312,"How is this possible?"],[1466,1558,"This can't be real!"],[1641,1766,"Honey, you won again!"],[1829,1908,"I didn't expect him"],[1983,2125,"to snatch victory from the jaws of defeat."],[2212,2287,"He really won!"],[2366,2508,"It seems that starting today,"],[2550,2641,"the name Keith"],[2733,2870,"will resound throughout Dragal"],[2900,3012,"and even the entire world."],[3162,3275,"Mr. Drake, you have such sharp eyes!"],[3362,3545,"To be able to collect"],[3550,3695,"so many precious treasures."],[3700,3979,"Thanks for letting me appraise them."],[4025,4095,"Mr. Drake,"],[4170,4237,"what do we do?!"],[4387,4437,"Mr. Drake."],[4500,4541,"What?"],[4604,4725,"Fair is fair!"],[4745,4800,"Alright."],[4954,5029,"Round three,"],[5054,5187,"Mr. Keith Hart wins!"]],"53":[[0,100,"Round three,"],[112,250,"Mr. Keith Hart wins!"],[254,341,"A mere child"],[345,475,"defeated a master appraiser."],[516,604,"This news"],[608,654,"is enough to shake"],[658,787,"the entire appraisal world."],[829,1095,"Keith is truly a role model for us all!"],[1100,1170,"Mr. Drake,"],[1175,1387,"since I've won all three rounds,"],[1391,1524,"according to our agreement,"],[1616,1737,"shouldn't you"],[1783,1920,"hand over the ownership"],[1925,1979,"of the mine?"],[1983,2066,"Kid,"],[2116,2191,"what are you talking about?"],[2204,2254,"Do you believe"],[2258,2379,"I'll kill you right now?"],[2591,2683,"Is Mr. Drake"],[2737,2820,"planning to renege?"],[3154,3250,"This is my territory."],[3333,3470,"Even if I renege,"],[3587,3762,"what can you do to me?"],[3900,4025,"How can Mr. Drake do this?"],[4070,4125,"He's a man of status,"],[4129,4229,"so how can he"],[4266,4362,"just renege like that?"],[4391,4545,"This is a bet worth billions,"],[4575,4704,"so who would give it up easily?"],[4712,4904,"Who is trying to renege here?"],[5362,5454,"Levi."],[5458,5504,"Mr. Drake,"],[5600,5675,"long time no see."],[5758,5931,"You won the mine from me,"],[6025,6100,"but now that someone else has beaten you,"],[6175,6225,"you're reneging."],[6237,6312,"Are you a sore loser?"],[6337,6412,"Levi,"],[6487,6612,"this matter"],[6629,6733,"has nothing to do with you!"],[6758,6833,"I advise you"],[6908,7008,"to stay out of this."],[7066,7212,"Nothing to do with me?"],[7400,7491,"To tell you the truth,"],[7550,7679,"Keith is my guy."],[7779,7895,"He won back"],[7900,7983,"what belongs to me."],[8012,8095,"So tell me,"],[8120,8179,"do we have a connection?"],[8212,8287,"Keith"],[8325,8412,"is your guy?"],[8416,8504,"So what?"],[8520,8687,"You're allowed to cross me,"],[8691,8775,"but I'm not allowed"],[8795,8912,"to pay you back in kind?"],[9279,9354,"Levi,"],[9441,9566,"you'd better think this through!"],[9612,9704,"What belongs to me"],[9708,9854,"isn't easy to swallow!"],[9937,10141,"Hahaha!"]],"54":[[337,454,"Stop it, all of you!"],[812,979,"We just lost a mine, didn't we?"],[983,1112,"Why the panic?"],[1141,1341,"As long as we get rid of Keith,"],[1345,1562,"that mine will be ours sooner or later!"],[1633,1704,"Mr. Drake,"],[1733,1933,"Levi is protecting Keith."],[1970,2112,"If we try to force it, I'm afraid…"],[2154,2225,"Force it?"],[2266,2429,"Levi can protect him for a while,"],[2433,2591,"but can he protect him forever?"],[2629,2812,"Mr. Drake, what are you suggesting?"],[3183,3258,"Mr. Drake,"],[3350,3504,"Lennon's men are watching closely."],[3512,3645,"If we make a move on Keith,"],[3679,3812,"it might attract the police."],[3858,3979,"So what if the police come?"],[4079,4254,"We've already lost the mine."],[4300,4408,"We'll starve sooner or later!"],[4462,4600,"As long as it's done cleanly,"],[4670,4787,"no one will trace it back to us."],[4866,4987,"Alright, Mr. Drake."],[5016,5108,"I'm with you."],[5158,5241,"Listen up, boys."],[5270,5408,"Follow me if you want to live."],[5454,5570,"We're taking out Keith."],[5575,5733,"You'll be handsomely rewarded!"],[5966,6041,"Keith,"],[6154,6345,"let's see who can save you this time!"]],"55":[[16,50,"Look,"],[120,265,"Keith was right."],[316,416,"Mr. Drake is really making a move!"],[612,766,"What should we do?"],[1075,1108,"Maybe we should just"],[1112,1216,"lay low for a while."],[1241,1370,"We can run,"],[1375,1495,"but we can't hide forever."],[1529,1737,"Mr. Drake is cornered now,"],[1741,1912,"so he's capable of anything!"],[1950,2125,"Why don't we set a trap"],[2133,2325,"and lure him right into it?"],[2562,2620,"Exactly."],[2679,2787,"Keith is right."],[2845,2979,"We won't be safe"],[3012,3112,"until Mr. Drake is taken down!"],[3183,3350,"I've already chosen"],[3354,3483,"a prime location"],[3491,3691,"to be Mr. Drake's grave."],[4120,4179,"Good."],[4233,4337,"We'll do as Keith suggests."],[4395,4466,"Once Mr. Drake and his gang"],[4470,4587,"enter the warehouse,"],[4591,4633,"we will immediately"],[4637,4741,"seal off all the exits."],[4766,4854,"I'll lead some men"],[4858,4979,"disguised as warehouse staff"],[5070,5170,"to protect Keith."],[5466,5533,"Keith,"],[5537,5629,"don't worry."],[5666,5725,"We absolutely won't let"],[5729,5820,"Mr. Drake harm"],[5837,6004,"a single hair on your head!"],[6129,6295,"I'm not afraid, Grandpa Lennon."],[6320,6479,"Mr. Drake has done so much evil."],[6495,6641,"I'm going to make him"],[6645,6770,"pay for it this time!"],[6808,6904,"Otherwise, he'll just keep"],[6908,7045,"hurting more innocent people!"],[7150,7229,"Keith,"],[7275,7366,"I'm going with you."],[7387,7462,"I'll protect you"],[7466,7587,"even if it costs me my life!"],[7762,7791,"Dad,"],[7795,7916,"you don't need to go."],[7941,8062,"Stay home with Mom."],[8095,8270,"She'll be worried otherwise."]],"56":[[2133,2225,"Where is it?"],[2229,2316,"Why can't I find it?"],[2658,2766,"Kid,"],[3108,3450,"let's see how you are gonna escape."],[3454,3516,"How about this?"],[3554,3637,"If you"],[3683,3850,"hand over the mine,"],[3854,3966,"I'll make your death"],[3970,4154,"a quick one!"],[4158,4258,"Kid,"],[4295,4475,"I'm breaking your legs today."],[4516,4612,"Let's see if you ever dare"],[4616,4775,"cross Mr. Drake again!"],[4800,4837,"Huh?"],[4891,5012,"Did you really think"],[5033,5158,"I'd come here alone?"]],"57":[[0,125,"Did you really think"],[129,275,"I'd come here alone?"],[354,412,"Do it!"],[587,658,"Who are you people?"],[779,887,"Hahaha."],[933,1012,"Mr. Drake,"],[1108,1179,"I told you,"],[1208,1266,"you'd have to pay back"],[1270,1391,"what you owe me sooner or later."],[1437,1504,"Today"],[1562,1620,"is the day"],[1625,1704,"you die!"],[1937,2037,"Attention, all units."],[2058,2170,"The target is surrounded."],[2195,2333,"Make the arrests."],[2575,2779,"Whoever kills Keith for me,"],[2783,2920,"I'll give them a million dollars!"],[2933,3000,"Get him!"],[3050,3133,"You useless trash!"],[3237,3300,"Go."],[3304,3416,"Go kill him!"],[3420,3554,"I'll give you a million dollars!"],[3866,3937,"Stop them!"],[3975,4091,"Don't let them get away!"],[5141,5233,"Keith!"],[5262,5395,"I swear,"],[5433,5673,"I will haunt you from the grave!"]],"58":[[25,179,"Austin Drake is confirmed dead."],[191,262,"He died of a skull fracture"],[266,400,"caused by the fall."],[466,520,"Keith,"],[525,620,"are you okay?"],[625,720,"Are you shaken up?"],[775,920,"Austin Drake did so many wicked things."],[925,1066,"This is exactly what he deserved!"],[1133,1154,"Alright,"],[1158,1175,"it's okay."],[1225,1291,"It's all over now."],[1341,1437,"Conrad and his men"],[1441,1525,"have all been arrested."],[1529,1570,"From now on,"],[1600,1691,"no one will ever hurt"],[1695,1800,"you or your family again."],[2408,2554,"Mom, Dad."],[2725,2779,"Keith!"],[2800,2891,"You scared me to death!"],[2933,3054,"You can't take such risks ever again!"],[3058,3120,"Do you hear me?"],[3170,3212,"Mom,"],[3225,3291,"I'm really fine!"],[3354,3395,"Look,"],[3412,3541,"I made it back safe and sound, didn't I?"],[3591,3795,"Our lives are going to get better,"],[3829,3916,"and no bad guys will ever"],[3920,4016,"come to bother us again!"],[4100,4154,"Yeah."],[4466,4520,"Keith."],[4591,4783,"Mr. Goodman, Sir Moses, Sophie,"],[4820,4900,"what are you doing here?"],[4933,5008,"You did us"],[5012,5087,"such a huge favor,"],[5116,5220,"so naturally, we came"],[5225,5312,"to thank you!"],[5358,5429,"That's right, Keith."],[5491,5583,"Mr. Goodman and I"],[5604,5704,"have decided"],[5750,5866,"to give you a thirty percent"],[5870,5991,"stake in that mine."],[6079,6354,"On top of that, there's also 500 million in cash."],[6583,6708,"Mr. Goodman, Sir Moses,"],[6733,6850,"you've misunderstood."],[6887,6987,"I helped you purely"],[6991,7212,"to uphold justice."],[7216,7433,"I won't take a single penny of your money."],[7466,7720,"Right now, I just want to stay by my parents' side"],[7762,7895,"and live a simple life."]]}