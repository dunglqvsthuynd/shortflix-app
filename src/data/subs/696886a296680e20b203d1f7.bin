{"1":[[912,1062,"You're offering a treasure?"],[3475,3575,"It's in mint condition."],[3616,3745,"A rare find!"],[4216,4312,"You murderer!"],[4333,4508,"Pay for my parents' lives!"],[4762,4837,"Mr. Drake!"],[5420,5479,"Dad,"],[5562,5633,"Mom,"],[5695,5903,"I've finally avenged you."],[7129,7254,"Where am I?"],[7300,7445,"Didn't I die?"],[7887,7937,"Have I"],[7975,8079,"been reborn?"],[8087,8212,"Someone's jumping off the building!"],[9150,9320,"One jump will clear my debts"],[9387,9629,"and pay for Aileen's surgery fees."],[9725,9787,"Dad!"],[10016,10125,"Keith."],[10250,10416,"I'm sorry"],[10441,10612,"for letting you and your mom down."],[10666,10962,"I gambled away all our assets."],[10975,11162,"In my past life, Dad was sabotaged,"],[11187,11320,"losing Mom's surgery money,"],[11333,11450,"and jumped off the building."],[11479,11620,"Mom died from her illness,"],[11637,11812,"leaving me all alone."],[11841,11925,"In this life,"],[11933,12066,"I'm going to save everyone."],[12854,13037,"Is this the special power"],[13041,13175,"that came with my rebirth?"],[13216,13287,"Dad!"],[13300,13491,"I know how to get your money back!"]],"2":[[12,62,"Dad!"],[95,295,"I know how to get your money back!"],[350,516,"You're just a kid."],[520,708,"What could you do?"],[712,804,"Young man,"],[808,925,"don't do anything stupid!"],[929,1066,"You have your whole life ahead of you!"],[1087,1295,"Why even tried your hand at stone gambling?"],[1312,1483,"You deserve to be scammed!"],[1520,1645,"Daniel is ridiculous."],[1670,1858,"He'd be better off working an honest job,"],[1870,2000,"but he's always looking for shortcuts."],[2004,2104,"What a disgrace!"],[2112,2191,"Daniel,"],[2204,2379,"are you a sore loser?"],[2475,2604,"You're not loser!"],[2650,2737,"What did you say?"],[2745,2800,"Dad,"],[2804,2920,"I think this stone"],[2937,3079,"is gem inside!"],[3095,3375,"As if it's not dramatic enough, his son is mad now!"],[3379,3483,"This family is done for."],[3516,3750,"We should just go home. Don't bother with them."],[3770,3987,"The Harts are nothing but disgraces!"],[4012,4045,"Dad,"],[4075,4220,"if I'm right,"],[4245,4329,"this stone"],[4354,4533,"contains glass jade,"],[4545,4733,"which is worth at least a million!"],[5050,5112,"Dad."],[5154,5825,"Gem!"],[5975,6050,"Keith,"],[6108,6245,"what if it's not gem?"],[6333,6529,"I've already lost way too much."],[6533,6558,"I…"],[6583,6625,"Dad,"],[6645,6850,"we have to get back up where we fell."],[6862,6933,"Trust me."],[6937,7004,"I guarantee"],[7012,7108,"it's a gem."]],"3":[[8,241,"Gem!"],[254,425,"Ugh!"],[616,675,"Sir,"],[695,870,"could you help me cut this stone?"],[883,983,"Shoo, shoo!"],[1000,1091,"This piece of junk"],[1095,1233,"isn't even worth to prop up a table."],[1250,1325,"Get lost."],[1337,1454,"Don't disrupt my business."],[1466,1620,"Don't look down on me, sir."],[1658,1829,"There's gem in this stone."],[1850,1937,"Dare to make a bet?"],[1995,2200,"You want a bet with me, huh, kid?"],[2216,2270,"Bet on what?"],[2291,2370,"If we find gem,"],[2400,2541,"you apologize to me."],[2562,2629,"Otherwise,"],[2641,2733,"I'll give you a hundred grand!"],[2791,2925,"Deal!"],[2941,3058,"Everyone bear witness."],[3091,3225,"Remember to keep your word, huh?"],[3275,3458,"This kid sure talks big!"],[3466,3537,"A hundred grand?"],[3554,3675,"Not even his dad has that much money!"],[3679,3754,"Hahaha!"],[3800,3862,"Keith,"],[3916,4079,"we can't afford that much money."],[4104,4133,"Dad,"],[4183,4329,"just trust me once."],[4358,4800,"Gem!"],[4870,5016,"Oh no."],[5087,5170,"Kid,"],[5216,5270,"you lost."],[5300,5400,"What were you thinking,"],[5404,5566,"letting a child gamble?"],[5595,5716,"Just a peek at the window."],[5720,5779,"Hold your horses."],[5804,5912,"Switch to a cross-cut."],[5916,6000,"Alright, alright."],[6016,6212,"You're losing anyway."],[6354,6404,"Sir,"],[6441,6545,"three more cuts right here."],[6641,6708,"Kid,"],[6737,6833,"if we don't find gem,"],[6845,6937,"how are you gonna pay?"],[6958,7104,"With your dad's underwear?"],[7137,7300,"Hahaha!"],[7395,7495,"Don't worry, Dad."],[7516,7620,"Just watch."],[7708,7783,"Keep cutting!"],[8150,8195,"Wait,"],[8212,8283,"look at that transparency!"],[8312,8454,"It's Ice Jade!"]],"4":[[50,87,"Wait,"],[120,191,"look at that transparency!"],[195,329,"It's Ice Jade!"],[379,545,"This kid is incredible!"],[558,679,"This piece of junk"],[683,812,"actually turned out to be a gem!"],[816,912,"Kid."],[929,1075,"I'll pay 500,000 for that stone!"],[1079,1162,"I offer 700,000!"],[1166,1312,"Kid, don't listen to them!"],[1316,1375,"I'll pay a million!"],[1379,1454,"Sell it to me!"],[1462,1595,"It's really gem…"],[1641,1816,"Sorry, I'm not selling."],[1962,2054,"Let's keep cutting."],[2087,2345,"Sir, if you can't keep cutting, I will!"],[2675,2925,"You need years of experience to cut stones."],[2958,3083,"One wrong cut,"],[3087,3212,"and you'll split the gem in half."],[3229,3483,"To get close to Mr. Drake and take my revenge,"],[3520,3733,"I worked in a raw stone factory for ten years."],[3770,3912,"Cutting stones is"],[3916,4033,"just a piece of cake!"],[4158,4370,"It's red jade, and of the glassy variety!"],[4375,4541,"The color is exquisite!"],[4562,4650,"Young man,"],[4670,4783,"I'll offer two million."],[4787,4891,"How about selling it to me?"],[4945,5137,"Sweetie, this price is already very high."],[5175,5329,"This stone can be carved into"],[5333,5425,"a complete jewelry set."],[5429,5550,"It's worth more than that."],[5570,5737,"You have a good eye."],[5766,5887,"I'll add another 500,000."],[5912,6095,"If you find any more good stones,"],[6100,6250,"you can sell them to me first."],[6495,6575,"Sir,"],[6595,6725,"what about the apology you promised?"],[6837,6904,"I'm sorry."],[6908,7083,"I failed to recognize a true expert."],[7120,7291,"I have several raw stones at home."],[7295,7445,"Could you take a look at them for me?"],[7587,7833,"We have the money for Mom's surgery now."],[7837,7975,"Keith,"],[8125,8216,"thank you."],[8608,8766,"You're occupying a room for free!"],[8770,9045,"Your medical bills are overdue for days!"],[9095,9291,"You think this is a charity hospital or what?"],[9316,9466,"You're out of here, today!"],[9508,9687,"Make room for paying patients."],[9700,9791,"What are you doing?"]],"5":[[0,112,"What are you doing?"],[295,479,"Honey, are you okay?"],[529,675,"My mom hasn't been discharged yet."],[687,866,"Why are you throwing her things away?"],[904,1054,"Your mom's surgery?"],[1058,1120,"Hmph,"],[1141,1316,"It costs more than 500,000."],[1333,1637,"Don't waste my time if you can't pay up!"],[1662,1804,"Give up already!"],[1858,2095,"You still owe me the caretaker fee."],[2100,2175,"Not a single cent less!"],[2533,2662,"There's a million."],[2666,2870,"I'll pay the hospitalization, the surgery,"],[2875,3004,"and your caregiver fee!"],[3112,3212,"Stop!"],[3333,3450,"What is going on here?"],[3533,3612,"Director,"],[3616,3845,"this broke family can't afford treatment."],[3866,3987,"They're refusing to leave"],[3991,4145,"and causing a scene!"],[4208,4312,"We have money."],[4408,4533,"Money or no money,"],[4537,4654,"the patients deserve a better attitude!"],[4662,4783,"Pack up their things immediately"],[4791,4904,"and take them back to the ward."],[4920,5108,"If you're ever snobbish again,"],[5112,5220,"you're fired!"],[5258,5412,"Yes, I'll clean up right away."],[5458,5520,"Mom,"],[5525,5720,"let's get you back inside."],[5750,5870,"Easy now."],[6391,6466,"Daniel,"],[6541,6716,"let's just go home."],[6762,6945,"I know my condition."],[6979,7150,"Don't waste any more money on me."],[7187,7391,"Save it for Keith's education."],[7395,7504,"Aileen,"],[7541,7670,"just wait for the surgery."],[7712,7879,"We have money now."],[8025,8125,"Really?"],[8300,8429,"I thought"],[8470,8712,"I'd never see the two of you again."],[8816,9012,"This shadow is the lesion."],[9054,9187,"It's not a malignant tumor"],[9191,9254,"described in the records."],[9325,9508,"This is mastitis!"],[9525,9620,"Dr. Lewis,"],[9783,10012,"my mom has mastitis,"],[10016,10212,"not a malignant tumor."],[10216,10433,"You're playing with human lives."],[10454,10541,"What?"]],"6":[[8,104,"If you don't believe me,"],[108,254,"why don't you rerun my mom's checks?"],[458,550,"Keith,"],[554,858,"did you just say Aileen has mastitis,"],[862,954,"not a tumor?"],[962,1100,"Dad, don't worry."],[1104,1266,"We're transferring hospitals right now."],[1383,1516,"They falsified the records"],[1545,1670,"and disregarded human life."],[1687,1791,"They should be punished!"],[1825,1995,"Mr. Hart, Keith,"],[2000,2112,"don't be impulsive."],[2129,2229,"Transferring is such a hassle."],[2262,2366,"Let's sit down"],[2412,2512,"and talk this over."],[2562,2679,"What the hell happened?"],[2787,3012,"Dr. Lewis, I made a mistake!"],[3016,3133,"I was the one"],[3145,3320,"who swapped medical records for money."],[3400,3495,"I know I messed up."],[3500,3712,"Dr. Lewis, please spare me!"],[3733,3904,"You're utterly reckless!"],[3945,4145,"Hospitals are meant to save lives,"],[4170,4300,"not to extort blood money!"],[4304,4504,"How dare you profit over patients?"],[4508,4741,"You're going to rot in jail!"],[5087,5308,"Mr. Hart, I am terribly sorry."],[5354,5433,"I will arrange a new examination"],[5437,5558,"for Mrs. Hart immediately."],[5908,6008,"Hello, Mr. Warren."],[6037,6112,"Daniel,"],[6133,6279,"there's an auction tonight."],[6304,6495,"Can I borrow Keith for a while?"],[6554,6629,"When it's done,"],[6633,6800,"you'll get a twenty percent commission."],[6825,6912,"Well…"],[6933,7216,"Dad, let me go. I can do it."],[7404,7512,"All right then."],[7875,8112,"Stay safe, Keith,"],[8116,8241,"and come back early."],[8279,8354,"Dr. Lewis,"],[8470,8641,"I hope you keep your word."],[8645,8783,"Mr. Hart, don't worry."],[8808,8870,"I will keep a close watch"],[8875,8970,"on Mrs. Hart myself."],[8995,9054,"If anything happens,"],[9058,9125,"I'll give you a call."],[9533,9658,"That kid"],[9662,9808,"is extraordinary."],[9833,10066,"To think he identified the symptoms"],[10091,10295,"of his mother's illness with just one look."],[10345,10420,"Grandpa,"],[10458,10533,"do you think"],[10537,10666,"I should ask him"],[10670,10783,"how he did it?"],[10808,10920,"Maybe your condition…"],[10937,11004,"No, no."],[11029,11216,"Let's not alert him yet."],[11258,11400,"Follow him secretly."],[11450,11754,"Let's see what kind of method he's using."]],"7":[[916,1015,"This is quite nice."],[1093,1210,"I have a good feeling about this one!"],[1408,1467,"Daniel,"],[1471,1535,"Keith,"],[1662,1783,"you guys are finally here."],[1787,1904,"Today's auction"],[1916,2004,"is going to be extraordinary!"],[2033,2145,"It's Mr. Drake's venue."],[2191,2266,"A priceless piece of jade"],[2270,2391,"was once discovered here."],[2433,2520,"Mr. Drake?"],[2545,2641,"You mean"],[2683,2745,"Austin Drake?"],[2858,2912,"Shh!"],[2945,3158,"Don't call him by his full name!"],[3195,3308,"You'll get us in trouble!"],[3420,3495,"Austin Drake,"],[3520,3712,"you ruined my family in my past life."],[3725,3787,"In this life,"],[3816,3945,"I will destroy you!"],[3979,4037,"Let's go."],[4050,4133,"Let's head inside."],[4720,4800,"Well, well."],[4854,4987,"If it isn't Kevin."],[5008,5104,"At the last auction,"],[5108,5212,"you lost quite a fortune, didn't you?"],[5237,5287,"What?"],[5300,5383,"You still have the guts to show up?"],[5391,5412,"Huh?"],[5429,5545,"Hahaha!"],[5570,5633,"Later on,"],[5645,5741,"I hope you two"],[5762,5850,"will show us some mercy."],[5854,5970,"Hahaha!"],[5987,6100,"Sure, sure."],[6241,6308,"Hey,"],[6350,6462,"who are these two?"],[6495,6550,"Oh,"],[6616,6779,"this is Keith."],[6787,6866,"I invited him to be my appraiser."],[6920,7012,"Don't let his age fool you."],[7062,7112,"He is-"],[7120,7220,"Save it."],[7275,7354,"Kevin,"],[7400,7537,"is this \"expert\" you hired"],[7558,7666,"still nursing?"],[7675,7970,"Hahaha!"],[7991,8062,"Kevin,"],[8091,8329,"bringing a kid to appraise at an auction,"],[8366,8558,"you're looking to embarrass yourself!"],[8562,8712,"Hahaha!"]],"8":[[116,187,"It's alright."],[216,291,"I am young,"],[308,437,"but I won't stoop to their level."],[504,629,"They're just a bunch of blind fools."],[700,745,"Keith,"],[766,816,"just ignore them."],[862,970,"I trust you."],[1012,1208,"Whatever you pick later,"],[1241,1341,"I'll buy."],[1495,1575,"Green on the surface,"],[1587,1729,"but waste rock inside."],[1750,1904,"A synthetic trap for suckers."],[1929,2020,"This has some green,"],[2041,2125,"but the quality is too poor."],[2129,2208,"A hundred grand at most."],[2350,2600,"Welcome, everyone, to tonight's auction."],[2604,2700,"All the raw stones"],[2704,2837,"are ready for viewing."],[2858,3008,"Now, please feel free to inspect the stones"],[3012,3162,"and place your bids."],[3195,3312,"The outside looks vibrant,"],[3345,3458,"surely holding a fortune within."],[3575,3679,"I'll bid on Number Two."],[3704,3812,"Five hundred thousand!"],[3879,3958,"I assume no one"],[3966,4120,"would compete with me."],[4166,4354,"Mr. Collins is truly generous."],[4370,4579,"No one would dare compete with you."],[4629,4837,"I'll take that smaller Number Four."],[4891,4983,"Three hundred thousand!"],[4998,5078,"Wow, three hundred thousand!"],[5258,5404,"Congratulations to Mr. Collins and Mr. Porter"],[5408,5508,"on winning the raw stones."],[5512,5783,"Now, let the other guests continue bidding!"],[5791,5875,"Mr. Warren,"],[5916,6066,"if you don't act now,"],[6083,6270,"the good stones will be gone!"],[6295,6362,"Yes, Mr. Warren,"],[6412,6575,"we're waiting for your expert"],[6579,6666,"to show off his skills!"],[7037,7095,"Keith,"],[7195,7358,"which one should we bid on?"],[7700,7812,"The real treasure is here."],[7820,7920,"Although this piece is small,"],[7937,8191,"with a rough surface and dark cracks,"],[8216,8391,"inside lies Imperial Green,"],[8416,8583,"it's at least a hundred million!"],[8662,8808,"We'll bid on"],[8916,8995,"Number Six!"]],"9":[[8,183,"We'll bid on"],[194,271,"Number Six."],[280,391,"Number Six?"],[393,812,"Hahaha!"],[816,895,"Kevin,"],[925,1020,"is this expert you hired"],[1029,1183,"here just to be funny?"],[1200,1366,"Bidding on a scrap stone nobody wants"],[1416,1570,"You might as well throw money in the water"],[1575,1758,"Mr. Porter and I can hear the splash!"],[1762,1962,"Hahaha!"],[1966,2262,"This kid doesn't know anything at all."],[2270,2383,"Didn't you see that stone"],[2387,2495,"is full of cracks?"],[2500,2754,"It'd be a miracle if there's any gem inside!"],[2841,2904,"Mr. Warren,"],[2925,3108,"if you really have money to burn,"],[3116,3216,"just donate it to me."],[3220,3287,"At the very least,"],[3291,3429,"I'd say thank you."],[3433,3583,"Right? Hahaha!"],[3587,3879,"It must be his first time at such a big event."],[3883,4033,"He's scared!"],[4037,4350,"Kevin is going to crash and burn this time."],[4358,4458,"What do you know?"],[4616,4954,"My son is a prodigy at judging stones by eye!"],[4962,5037,"Heh,"],[5116,5350,"where did you pop out from, you clown?"],[5354,5558,"Back when I was trading stones in Myland,"],[5566,5741,"you were still playing in the mud somewhere!"],[5745,5800,"Exactly!"],[5833,5925,"Everyone sitting here"],[5958,6187,"is a leader in the industry."],[6191,6275,"Who are you"],[6287,6462,"to run your mouth here?"],[6466,6587,"Yeah, exactly!"],[6616,6737,"Hey, Mr. Porter,"],[6754,6829,"let it go."],[6837,6908,"Calm down."],[6916,7004,"This is Mr. Drake's turf."],[7020,7100,"Let it go."],[7212,7254,"Hmph."],[7550,7716,"Keith,"],[7720,7933,"why don't you check it again?"],[7966,8262,"Uncle Kevin, Number Six is the one."],[8733,8858,"We'll bid on Number Six."],[8870,8933,"One hundred and fifty thousand!"],[8937,9012,"He actually bought Number Six."],[9016,9079,"What's the point of buying"],[9083,9212,"such a piece of scrap?"],[9216,9300,"Congratulations, Mr. Warren,"],[9304,9537,"on winning the final raw stone of the session."],[10025,10095,"Keith."],[10425,10750,"Mr. Warren, why don't you cut it right now?"],[10791,10925,"Let us see what you've got."],[10933,11012,"Heh."],[11104,11229,"Forget it, Mr. Porter."],[11237,11370,"He doesn't have the guts."],[11441,11645,"How about we cut mine first?"],[11650,11820,"Let's put on a show for everyone."],[13116,13200,"No way!"],[13212,13312,"This is impossible!"],[13316,13391,"Keep cutting!"],[13809,13991,"It's a d**n piece of junk!"],[14066,14120,"Mr. Collins,"],[14145,14350,"looks like you're out of luck today."],[14416,14554,"Watch mine then!"],[15595,15679,"It's a bust!"],[15691,15766,"Hmph."],[15845,16041,"Kid, it's your turn."],[16079,16237,"I want to see what kind of gem"],[16241,16354,"you can find in that junk!"],[16362,16433,"Hurry up."],[16462,16629,"If it turns out to be a dud,"],[16633,16875,"don't go crying to your daddy for milk!"],[16895,16954,"Mr. Warren,"],[16975,17204,"would you like to cut the stone here?"],[17291,17337,"Hmph."],[17445,17625,"Yes. Cut it right now!"],[18179,18275,"Wait!"]],"10":[[8,208,"Wait, you can't cut it like that!"],[333,595,"Hmph, what does a brat know about cutting stones?"],[616,750,"He's probably scared it'll be a bust,"],[754,887,"so he's making up excuses!"],[916,954,"Exactly!"],[958,1175,"Stop bluffing, you little brat."],[1195,1291,"It's just a junk."],[1295,1408,"Cut right through it!"],[1429,1591,"You're no expert."],[1600,1745,"Cut along this pattern."],[1804,1916,"Mr. Warren,"],[1966,2166,"tell your guy to stop embarrassing himself."],[2183,2345,"It's not too late to quit now."],[2554,2637,"Cut it where he marked."],[3241,3408,"Hahahaha!"],[3412,3479,"It's a bust."],[3483,3629,"It's a bust! Haha!"],[3633,3804,"I told you, he's just a brat."],[3808,3912,"What could he possibly know?"],[3916,4091,"Hahahaha!"],[4095,4170,"Keith,"],[4200,4383,"maybe we should stop cutting?"],[4441,4554,"Keep going!"],[5354,5445,"Imperial Green?"],[5450,5525,"What?"],[5612,5679,"Imperial Green?"],[5683,5787,"It really is Imperial Green!"],[5791,5908,"And it's full color!"],[5912,6041,"This kid is amazing!"],[6045,6200,"He has a good eye!"],[6204,6475,"You can't judge a book by its cover."],[6491,6695,"Keith, I was right about you."],[6712,6845,"You really are amazing!"],[6862,7162,"How did Keith become so different?"],[7283,7358,"Mr. Collins,"],[7362,7533,"my guy is no expert, you say?"],[7545,7650,"What do you have to say now?"],[7708,7804,"Hehe."],[7850,8175,"Mr. Warren, I was just joking with you earlier."],[8212,8437,"If you want to sell this piece,"],[8475,8637,"I'll offer ten million!"],[8695,8904,"Ten million? Are you crazy?"],[8908,8983,"Get out of the way!"],[9133,9404,"Mr. Warren, that was all a misunderstanding."],[9420,9475,"How about this?"],[9495,9633,"I'll offer you thirty million."],[9645,9737,"Will you sell it to me?"],[9854,10095,"Once carved into an artifact,"],[10116,10316,"this piece is worth at least 100 million!"],[10366,10395,"What?"],[10454,10579,"Conrad has arrived!"],[10845,10933,"Who is that?"],[10937,11012,"He's making such a scene."],[11025,11270,"That's Mr. Drake's number one enforcer,"],[11275,11337,"Conrad."],[11354,11487,"He runs all the stone gambling venues."],[11545,11650,"Hold on."],[12158,12295,"Kid, you've got a sharp eye."],[12395,12625,"Finding Imperial Green in a piece of junk."],[12700,12766,"Impressive!"],[12837,13016,"Mr. Drake just sent word."],[13033,13262,"You have to stay for a big game."],[13408,13616,"We appreciate your kind offer,"],[13645,13795,"but my kid was just guessing blindly."],[13825,13912,"We'll get out of your hair now."],[13979,14304,"Are you refusing Mr. Drake's invitation?"],[14454,14533,"Tonight,"],[14641,14937,"you're going to play."],[14941,15350,"Whether you like it or not."],[15404,15562,"Otherwise…"],[15816,16020,"Alright. Sir, what are we playing?"]],"11":[[0,112,"You've got guts, kid."],[125,170,"Hmph."],[175,270,"Let's play for high stakes."],[287,537,"I have a 100-pound"],[583,650,"premium raw stone."],[708,854,"If you can determine its value,"],[858,954,"I'll give you ten million!"],[970,1133,"But if you can't,"],[1137,1220,"your Imperial Green"],[1225,1325,"is mine!"],[1345,1370,"Deal?"],[1375,1429,"Keith,"],[1458,1512,"you can't play."],[1550,1633,"It's a trap."],[1650,1712,"Conrad,"],[1758,1862,"he's still just a child."],[1883,1920,"Uh,"],[1937,2012,"this sort of gamble"],[2016,2137,"is too risky."],[2158,2233,"What?"],[2237,2354,"Scared to play"],[2383,2479,"right after winning?"],[2504,2641,"Then get out of my venue!"],[2704,2833,"You'll never set foot"],[2937,3079,"in my venue again."],[3083,3133,"Sir,"],[3154,3250,"I'll play with you."],[3262,3337,"Woo!"],[3375,3475,"Good boy!"],[3570,3654,"Come on!"],[3716,3845,"Come."],[3945,4112,"Let the show begin."],[4366,4450,"Are you sure"],[4454,4579,"you want to bet ten million with me?"],[4583,4679,"Kid,"],[4700,4816,"don't talk too big."],[4820,4979,"If you get it wrong,"],[4983,5095,"I wouldn't mind"],[5100,5162,"teaching you a lesson"],[5166,5316,"you'll never forget!"],[5475,5537,"Conrad,"],[5541,5616,"he's just a kid."],[5620,5712,"We don't want the money."],[5716,5812,"We're leaving now."],[5916,6012,"Stop!"],[6037,6237,"The game has just begun."],[6308,6554,"Do you really think you can walk out of here?"],[6583,6612,"Dad,"],[6616,6716,"we can win."],[6758,6962,"There is only scattered ice jade inside."],[6991,7195,"It's worth a million at most."],[7200,7304,"These three spots"],[7308,7504,"are artificially filled cracks,"],[7508,7670,"made just to deceive people."],[7716,7804,"Kid,"],[7808,7925,"be careful with your words."],[7929,8037,"They might get you killed, you know?"],[8070,8166,"In fact,"],[8208,8429,"I spent five million on this raw stone."],[8433,8570,"If you are wrong,"],[8683,9000,"I will break your legs, I'm not bluffing!"],[9012,9116,"I've told you the truth."],[9120,9312,"Why don't you cut it open to find out?"],[9333,9445,"Fine."],[9579,9654,"Cut it!"],[10245,10329,"Is that green showing