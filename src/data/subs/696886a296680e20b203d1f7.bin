8,3829,"I would have taken"],[3833,3945,"a huge loss today."],[3950,4066,"You're welcome,"],[4108,4195,"Sir."],[4200,4316,"I noticed your complexion looks pale."],[4320,4412,"Hey, kid,"],[4437,4562,"don't push your luck."],[4566,4633,"It's fine."],[4662,4720,"No harm done."],[4766,4850,"Please go on."],[4854,4920,"Sir,"],[4925,5137,"you seem to be suffering from a serious illness."],[5141,5308,"I know a little about medicine,"],[5312,5425,"I can take a look at you."],[5441,5762,"Then please check on me."],[6325,6416,"Sir,"],[6420,6591,"you have late-stage lung cancer."],[6716,6887,"Although I can't cure it completely,"],[6891,7054,"I can write you a prescription."],[7058,7166,"Extending your life by ten years"],[7170,7291,"shouldn't be a problem."],[7295,7416,"Please,"],[7437,7550,"do share your wisdom."],[7554,7641,"Boss,"],[7645,7808,"may I borrow a pen and paper?"],[8170,8395,"Astragalus and Codonopsis to nourish body,"],[8400,8545,"Oldenlandia diffusa,"],[8550,8729,"and Scutellaria barbata to fight the tumor."],[8804,8904,"Sir,"],[8908,8995,"these herbs"],[9000,9145,"can control the tumor's growth."],[9187,9366,"But if you use a 100-year mushroom as a catalyst,"],[9370,9483,"the effect will double."],[9512,9616,"Ginseng"],[9620,9762,"won't help you much."],[9775,9966,"Follow this prescription,"],[9970,10108,"take it twice a day"],[10125,10208,"for a month,"],[10212,10387,"and you'll live another ten years."],[10400,10462,"Young man,"],[10500,10575,"can this prescription"],[10600,10687,"really extend my grandpa's life"],[10691,10787,"by ten years?"]],"14":[[37,100,"Young man,"],[145,216,"can this prescription"],[250,354,"really extend my grandpa's life"],[358,437,"by ten years?"],[550,708,"But even top doctors"],[737,858,"said my grandpa"],[891,1004,"has six months to live at most."],[1075,1183,"Could your prescription"],[1204,1291,"be..."],[1316,1379,"Hey!"],[1475,1612,"Sophie, don't be rude!"],[1712,1812,"This young man saw through"],[1816,1950,"the fake ginseng at a glance."],[2000,2087,"His medical skills"],[2137,2233,"are extraordinary!"],[2295,2325,"I trust him!"],[2391,2462,"This prescription"],[2466,2658,"requires a 100-year mushroom as a base."],[2683,2883,"Ordinary mushrooms are half as effective."],[2995,3108,"While taking the medicine,"],[3112,3283,"avoid raw or cold foods,"],[3316,3450,"and make sure to get plenty of rest."],[3470,3520,"Sir Moses,"],[3550,3675,"I actually have"],[3691,3787,"a wild 100-year mushroom in my shop."],[3875,4020,"I was afraid you'd find it too expensive,"],[4025,4095,"so I didn't recommend it."],[4129,4179,"But now,"],[4216,4320,"I'll give it to you at cost"],[4370,4487,"for just five million."],[5004,5208,"This mushroom is genuine."],[5212,5300,"It will work!"],[5304,5354,"Good."],[5379,5500,"I'll take the mushroom."],[5616,5762,"Follow the young man's prescription"],[5766,5820,"and prepare the medicine."],[5825,5912,"Rest assured, Sir Moses."],[5916,6012,"I'll handle it right away."],[6283,6345,"Keith."],[6450,6545,"When did you learn"],[6550,6658,"such amazing medical skills?"],[6691,6737,"How come I"],[6758,6887,"didn't know anything about it?"],[6945,6983,"Dad,"],[7004,7229,"I learned it from an old book."],[7250,7395,"Is that so?"],[7450,7520,"Young man,"],[7525,7625,"thank you."],[7637,7708,"In the future,"],[7712,7920,"if you ever need help from me,"],[7941,8066,"just say the word."],[8154,8212,"I'll keep that in mind."],[8266,8362,"By the way, Boss,"],[8366,8458,"does your shop"],[8483,8641,"have any hundred-year-old wild ginseng?"],[8687,8883,"Don't try to fool me with fakes this time!"],[8887,8991,"You have such sharp eyes."],[9016,9141,"Even if I had a hundred guts,"],[9145,9212,"I wouldn't dare."],[9279,9362,"But my shop really doesn't have"],[9366,9512,"any hundred-year-old wild ginseng."],[9529,9729,"Then where can we buy it?"],[9758,9854,"Do you know about"],[9858,9929,"Healing Hall?"]],"15":[[41,329,"Healing Hall? What kind of place is that?"],[366,558,"It is the headquarters of medicine."],[612,725,"Everyone there is a"],[729,933,"retired master healer."],[962,1087,"At two o'clock this afternoon,"],[1091,1195,"Healing Hall will host"],[1200,1316,"a medicinal herb exhibition."],[1350,1408,"I heard that"],[1433,1558,"veteran collectors will bring out"],[1587,1737,"their hidden treasures for display."],[1795,1850,"There might actually be"],[1870,2012,"hundred-year-old wild ginseng."],[2050,2104,"However…"],[2208,2300,"However what?"],[2341,2516,"It's just that the exhibition is exclusive,"],[2579,2783,"and you need an invitation to enter."],[2837,3045,"How can we get an invitation?"],[3079,3120,"Sir Moses,"],[3175,3279,"you surely have connections."],[3300,3383,"If you just say the word,"],[3404,3470,"the organizers"],[3500,3591,"will definitely oblige!"],[3637,3733,"It's a small matter."],[3795,3970,"Just let Sophie take you there."],[4108,4237,"Would that be too much trouble?"],[4275,4341,"Not at all."],[4391,4562,"I happen to be going there myself."],[4600,4662,"Thank you."],[5179,5241,"Sir Moses,"],[5316,5420,"do you think this prescription"],[5491,5608,"can really extend life by ten years?"],[5712,5841,"That young man's methods,"],[5883,6012,"you saw them for yourself just now."],[6083,6258,"We set a trap using fake ginseng,"],[6287,6412,"and he saw through it instantly."],[6458,6612,"His medical skills are extraordinary!"],[6762,6887,"So regarding this prescription he wrote,"],[6916,6995,"I believe in it!"],[7058,7154,"You really have a keen eye."],[7725,7775,"Well, well."],[7854,8045,"Isn't this the master who won"],[8083,8275,"millions off me at the stone gambling contest?"],[8295,8358,"What?"],[8379,8475,"Was betting on stones not enough,"],[8541,8723,"that you had to join the fun at the herb auction?"],[8762,8825,"Conrad,"],[8854,9016,"we're just here to broaden our horizons."],[9029,9133,"Broaden your horizons?"],[9183,9395,"Medicinal herbs are different from raw stones."],[9425,9558,"Every single item here"],[9575,968