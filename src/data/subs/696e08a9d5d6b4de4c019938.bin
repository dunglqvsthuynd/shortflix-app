{"1":[[629,773,"I'm having dinner with Mom today."],[773,876,"No need to wait for me."],[876,956,"You can go back first!"],[969,1063,"Yes, ma'am."],[1266,1333,"At this hour,"],[1366,1526,"Mom should be off work."],[1813,1983,"She's been working her whole life."],[1983,2219,"I told her it's time for her to retire,"],[2219,2383,"but she insists on working as a housekeeper."],[2966,3066,"Ms. Summers,"],[3066,3236,"here is the vegetable salad you asked for."],[3616,3836,"The cherry tomatoes aren't even peeled."],[3866,4053,"Are you trying to feed me pig slop?"],[4110,4193,"I-I'm sorry."],[4210,4336,"I'll remake it right away!"],[4473,4570,"On your knees!"],[4586,4716,"Apologize!"],[4800,4879,"But…"],[4886,5023,"I said kneel down! Did you hear me?"],[5276,5450,"A stinking servant like you"],[5476,5663,"could only raise a daughter just as cheap!"],[5693,5833,"Who's she to steal my man?"],[5839,5926,"My daughter"],[5946,6039,"would never…"],[6106,6189,"Shut up!"],[6536,6600,"Come here!"],[7023,7126,"Trying to steal my man!"],[7146,7333,"How dare she try to steal my man!"],[8264,8448,"Why isn't Mom picking up?"],[8606,8788,"Oh my god! She just fell like that?"],[8993,9090,"Mom!"],[9753,10040,"Glad you're dead, you old hag!"],[10246,10366,"No way!"],[10429,10683,"I'll never let my mother's killer get away!"],[10796,10929,"I wouldn't settle for ten million,"],[11009,11233,"or even a hundred million!"],[11313,11446,"I've already called the police."],[11509,11640,"See you in court!"],[12396,12509,"Adrian,"],[12523,12613,"you're back!"],[12666,12863,"You have to help me find the best lawyer."],[12943,13130,"I need to get justice for my mom!"],[14040,14186,"Sign the settlement agreement, will you?"],[14226,14346,"What happened this time"],[14393,14506,"was nothing but an accident."],[14586,14713,"What do you mean?"],[15336,15516,"So the person who killed my mom"],[15516,15736,"was your ex-wife Serena?"],[16036,16183,"Serena told me everything."],[16269,16483,"Your mom slipped and fell by accident."],[16540,16650,"What happened"],[16716,16840,"really was just an accident."],[17190,17476,"My mom was covered in bruises."],[17550,17763,"Obviously, Serena pushed her off the building!"],[17763,17869,"This wasn't an accident."],[17869,18033,"It was murder!"],[18080,18216,"You're biased against Serena."],[18216,18350,"She's not that kind of person!"],[18423,18503,"Be a good girl."],[18609,18690,"Listen to me,"],[18750,18850,"and sign it."],[19059,19153,"No, I won't!"],[19840,19966,"Let me go!"],[20206,20333,"What are you doing?"],[20343,20463,"You kidnapped my father!"],[20463,20626,"Let him go!"],[20680,20809,"Sign the agreement,"],[20846,20930,"and I'll let him go."],[21166,21463,"And if I refuse?"],[21523,21616,"Evelyn,"],[21643,21806,"no matter what Serena has done,"],[21806,21990,"she is my son's mother."],[22043,22250,"Your father's got one foot in the grave anyway."],[22250,22480,"But my son can't be without a mother."],[22600,22696,"Don't blame me."],[22866,22959,"No!"]],"2":[[123,206,"Don't!"],[670,753,"Adrian,"],[890,969,"I…"],[1066,1223,"I can ask the judge"],[1396,1626,"to give her a lighter sentence."],[1710,1926,"I just want justice."],[1926,2083,"Can't I even have that?"],[2960,3176,"You have one minute to decide."],[4063,4170,"Adrian,"],[4210,4433,"is it really that your son needs a mother,"],[4450,4650,"or is it that you can't live without Serena?"],[4716,4866,"I know she's your true love,"],[4913,5093,"but I never imagined that you'd"],[5093,5393,"abandon your humanity for her!"],[5433,5523,"Fine."],[5746,5836,"I'll sign it!"],[6923,7073,"Mom,"],[7176,7326,"I'm sorry."],[7440,7709,"I can't let them hurt Dad."],[8433,8613,"Tell them to let my dad go!"],[8690,8896,"Once you sign it, they will."],[9146,9250,"I've sent the address to your phone."],[9763,9833,"Dad,"],[9853,9933,"hold on, I'm coming to save you!"],[9976,10166,"I've already contacted my godmother, Marian."],[10200,10313,"Once you return safely,"],[10353,10503,"we'll join her abroad"],[10550,10703,"and never come back!"],[10870,10956,"Dad!"],[10966,11096,"Let me go!"],[11290,11396,"I've already signed the agreement!"],[11396,11523,"Let him go, now!"],[11776,11856,"Release him."],[13866,13959,"No!"],[14019,14146,"Dad!"],[14196,14376,"Evelyn,"],[14463,14723,"Watching your father die with your own eyes…"],[14883,14990,"Does it feel good?"],[15450,15573,"Serena!"],[15643,15823,"Wasn't killing my mom enough for you?"],[15823,16066,"Now you have to kill my dad, too?"],[16166,16330,"You should've just accepted my check!"],[16366,16493,"Ten million!"],[16493,16663,"That's enough to buy a filthy maid's life!"],[16716,16823,"Let me tell you,"],[16856,17096,"even if I divorce Adrian,"],[17156,17306,"a lowly maid like you"],[17306,17443,"will never be worthy of being Mrs. Fletcher!"],[17496,17663,"You took something you shouldn't have,"],[17709,17776,"so"],[17776,17936,"this is your lesson!"],[18009,18093,"Serena,"],[18093,18296,"you'll pay with your life for murder!"],[18436,18716,"That's a rule that only applies to the poor."],[18746,18840,"As for me,"],[18840,19033,"having Adrian is enough!"],[19106,19240,"What do you mean?"],[19636,19716,"Calling the police?"],[19816,19896,"Evelyn,"],[19963,20073,"you're being very naughty!"],[20150,20276,"Adrian,"],[20386,20669,"you really love Serena, don't you…"]],"3":[[21,210,"Serena was a poisonous rose"],[210,417,"that Adrian raised himself."],[417,608,"He loved her deeply,"],[608,830,"but she betrayed him"],[830,1107,"and left the country with their son."],[1107,1271,"That was when I"],[1271,1469,"came into Adrian's life."],[1469,1653,"Since the divorce,"],[1653,1796,"Mr. Fletcher hasn't been doing well."],[1853,2013,"Please take good care of him."],[3860,3957,"Thank you."],[5213,5310,"Evelyn,"],[5310,5543,"you two are from different worlds."],[5563,5670,"You can never compare to"],[5670,5854,"the love of his life."],[5907,6000,"I know."],[6066,6204,"I just want to be by his side."],[7032,7172,"Since Adrian has fully recovered,"],[7238,7355,"it is time for me to leave."],[7670,7751,"Evelyn,"],[8326,8413,"let's get married!"],[9381,9472,"After we got married,"],[9472,9619,"Adrian was really good to me."],[9654,9761,"You're back early?"],[9794,9864,"Didn't you say"],[9864,10018,"you had an international meeting tonight?"],[10055,10156,"No meeting is"],[10156,10333,"more important than my wife's birthday!"],[10423,10588,"I once thought"],[10588,10779,"that he loved me,"],[10779,10932,"until that day…"],[10955,11081,"You actually haven't divorced"],[11081,11201,"that little maid yet?"],[11294,11434,"Didn't you only marry her"],[11434,11574,"to get back at Serena"],[11581,11701,"for marrying someone else abroad?"],[11735,11871,"She takes good care of the house."],[11885,11963,"True that."],[11993,12073,"Marrying her means you don't even"],[12103,12230,"have to pay a maid's salary."],[12283,12410,"But Serena is back in the country."],[12440,12580,"You should get rid of"],[12594,12674,"all these irrelevant people!"],[13548,13631,"Officer,"],[13655,13767,"my father was murdered!"],[13800,13930,"The killer is Serena Summers!"],[13930,14034,"I saw it with my own eyes."],[14034,14159,"You have to go arrest her!"],[14159,14279,"We went to the address"],[14279,14359,"you provided,"],[14364,14521,"but there were no bloodstains"],[14521,14637,"or traces of a homicide."],[14667,14774,"We couldn't even find"],[14774,14881,"your father's body."],[14898,15051,"We don't have enough grounds to open a case."],[15071,15133,"I'm sorry."],[15607,15712,"It was you,"],[15740,15820,"wasn't it?"],[15880,16000,"Serena isn't strong enough,"],[16010,16091,"that's why she couldn't hold onto your father"],[16136,16281,"and let him fall like that."],[16304,16408,"She didn't do it on purpose."],[16434,16558,"She did it on purpose!"],[16558,16701,"I saw her cut the rope!"],[16701,16791,"Why do you always have to"],[16791,16920,"think the worst of Serena?"],[16980,17187,"She was worried the bodyguards"],[17193,17310,"couldn't protect your father."],[17350,17480,"that's why she went to the warehouse herself."],[17515,17625,"She is the last person who"],[17625,17792,"wanted something like this to happen."],[17817,18094,"Do you just believe whatever she says?"],[18191,18355,"Stop being unreasonable, okay?"],[18375,18518,"As long as you leave Serena alone,"],[18568,18760,"I'll give you whatever you want."],[18818,19087,"Didn't you say you want a pink diamond?"],[19154,19411,"This necklace here, take it as compensation."],[19434,19521,"Compensation?"],[19621,19814,"Can two human lives really be"],[19821,20061,"compensated with a necklace?"],[20115,20251,"Then what do you want?"],[20273,20410,"Adrian."],[20473,20600,"Let's get a divorce."],[20794,20874,"Hello?"],[20910,20970,"Serena."],[20994,21131,"Hey, why are you crying?"],[21249,21399,"Oh, it's nothing."],[21409,21526,"Don't cry."],[21539,21629,"I'm right here."],[21751,21868,"Look how useless I'm."],[21868,21991,"I caused such a huge mess,"],[21991,22122,"and now you have to clean it up for me."],[22122,22318,"I even made Eve so upset."],[22318,22455,"Will you get sick of me?"],[22469,22590,"How could I?"],[22600,22771,"You're just too kindhearted."],[22794,22937,"But I still feel so guilty,"],[22937,23021,"and so sad."],[23048,23191,"If you're sad, just go shopping."],[23191,23371,"You don't like that pink diamond necklace"],[23371,23530,"I gave you last time, right?"],[23541,23708,"Just buy whatever you like this time."],[23753,23948,"This is the man I've loved for six years."],[23948,24109,"Even the gift meant to compensate me"],[24122,24297,"is just trash that Serena rejected."],[24355,24559,"Me seeking justice for my parents is wrong,"],[24617,24756,"but Serena has two lives on her hands,"],[24756,24866,"yet she's still considered \"kindhearted\"."],[24881,25101,"Is this retribution for my poor judgment?"],[25430,25610,"I promise I won't make a scene anymore."],[25630,25817,"But a necklace isn't enough."],[25844,26009,"That three-hundred-million downtown mansion,"],[26009,26196,"I want you to transfer it to my name."],[26337,26418,"No problem!"],[28224,28304,"Honey,"],[28304,28445,"you're so reasonable."],[28501,28571,"I love you."],[28591,28730,"But I don't dare love you anymore."],[28730,28810,"Adrian."],[28858,29052,"My love for you ends here."],[29095,29200,"From now on,"],[29227,29402,"I've got only one goal, which is revenge!"]],"4":[[123,325,"Serena is protected by the Fletchers."],[325,468,"On my own,"],[468,572,"it will be hard to get revenge."],[623,772,"I need an ally."],[1408,1468,"Mr. Sullivan."],[1509,1614,"Do you have a moment?"],[1773,1853,"Don't you want"],[1853,1991,"to take revenge on Serena?"],[2609,2709,"Twelve years ago,"],[2709,2814,"your sister"],[2814,2959,"was an intern at Fletcher Group."],[2979,3066,"Just because Adrian"],[3066,3176,"gave her a ride home,"],[3216,3331,"Serena became jealous."],[3363,3498,"So, she forced your sister to drink"],[3498,3575,"at a business dinner,"],[3575,3718,"causing her to die right there."],[3813,3927,"How do you know that?"],[4004,4104,"Who are you exactly?"],[4647,4813,"You are Adrian's wife,"],[4853,4946,"Evelyn Bennett?"],[4993,5130,"I'm already his ex-wife."],[5168,5358,"Serena killed my parents."],[5408,5535,"She is my sworn enemy!"],[5652,5715,"Mr. Sullivan,"],[5782,5905,"interested in teaming up?"],[6139,6272,"Frankly speaking, Ms. Bennett,"],[6332,6461,"now that Adrian is shielding Serena,"],[6461,6821,"you want to find evidence of her crimes?"],[6925,7005,"It'll be very difficult!"],[7073,7178,"Does this mean, Mr. Sullivan,"],[7210,7310,"that you agree to team up?"],[7349,7442,"Rest assured, Mr. Sullivan,"],[7500,7639,"I can help you find the evidence."],[7677,7744,"However,"],[7787,7904,"you have to do me a favor."],[8034,8114,"What favor?"],[8345,8471,"Help me escape the Fletcher family"],[8511,8611,"and send me abroad."],[8757,8820,"Deal."],[8935,8973,"However,"],[8973,9132,"I need seven days to process the paperwork."],[9332,9414,"Then, Mr. Sullivan,"],[9467,9547,"we have a deal."],[10073,10298,"Adrian's second wife"],[10298,10522,"is different from what I imagined."]],"5":[[1222,1354,"Mommy, look."],[1354,1461,"Is my drawing good?"],[1601,1708,"It's wonderful!"],[1761,1881,"You're amazing, sweetie!"],[2017,2113,"Why are you here?"],[2450,2657,"Your mother died in my house,"],[2657,2787,"which is terrible luck,"],[2787,2934,"so I had to move out."],[3006,3106,"After all,"],[3163,3370,"this is my son's father's house."],[3401,3471,"So staying here"],[3521,3651,"is perfectly reasonable, right?"],[3840,3967,"Isn't that right, Adrian?"],[4357,4591,"If Eve doesn't agree,"],[4708,4808,"then I'll have no choice"],[4808,5005,"but to take my son to my ex-husband."],[5028,5138,"Lately,"],[5138,5326,"he's been pestering me to remarry him!"],[5423,5500,"Don't go!"],[5527,5613,"You and our son"],[5653,5770,"can just stay here."],[5944,6016,"Evelyn,"],[6061,6202,"you're excellent at serving others,"],[6254,6419,"so please bear with it for a while."],[6451,6524,"Serena"],[6524,6616,"is a picky eater."],[6656,6713,"As for Andy,"],[6748,6836,"he's young and doesn't know better,"],[6873,6976,"so please be patient with him."],[7008,7077,"Later on,"],[7077,7182,"I'll make it up to you."],[7655,7789,"Honey, you've worked hard."],[7789,7882,"Let me cook for you."],[7969,8123,"My wife's hands are so beautiful,"],[8123,8276,"they aren't meant for housework."],[8276,8356,"From now on,"],[8356,8501,"I'll never let you do chores again."],[8551,8631,"Adrian,"],[9356,9499,"it turns out that in your heart,"],[9499,9659,"I'm still just a maid."],[9659,9738,"It's ridiculous that"],[9738,9873,"I actually believed you back then!"],[9939,10020,"Fine."],[10155,10286,"I'm here to gather evidence."],[10315,10432,"Until I achieve my goal,"],[10432,10522,"I'll have to lump it."],[10852,10899,"Evelyn!"],[10960,11114,"Andy is just a child!"],[11114,11207,"How could you be so vicious?"],[11207,11341,"You won't even spare a child?"]],"6":[[50,136,"What are you talking about?"],[136,220,"Stop acting!"],[346,516,"Serena already told me."],[516,673,"You poured soapy water on the stairs,"],[696,890,"causing Andy to fall down."],[903,1030,"He's still unconscious!"],[1123,1196,"Evelyn."],[1243,1383,"If you didn't want to wait on them,"],[1383,1516,"you could have just told me."],[1543,1660,"But you absolutely never"],[1693,1900,"should have laid a hand on my son."],[1980,2080,"I didn't!"],[2080,2136,"Guards!"],[2273,2439,"Lock her in the confinement room."],[2469,2633,"Don't you let her out"],[2676,2793,"until Young Master wakes up!"],[2889,2983,"No, no."],[3270,3346,"Adrian,"],[3436,3536,"I didn't do it."],[3546,3696,"I was just watering flowers in the backyard."],[3710,3863,"You can't accuse me like this!"],[3866,4050,"My son's mother wouldn't lie to me."],[4063,4123,"No…"],[4756,4966,"No, don't!"],[5289,5366,"Stop!"],[5410,5526,"Didn't you say"],[5583,5773,"that you liked champagne roses?"],[5826,6016,"I had a batch planted especially for you."],[6076,6139,"Do you like them?"],[6253,6343,"Mr. Fletcher,"],[6363,6506,"why are you so good to me?"],[6616,6736,"They are your roses."],[6846,6929,"and my rose"],[6990,7136,"is you!"],[7190,7236,"Be a good girl,"],[7279,7329,"call me 'Hubby'."],[7590,7696,"Rotten…"],[7786,7953,"It's all rotten!"],[8020,8136,"Whether it's the roses,"],[8229,8326,"or,"],[8423,8573,"our marriage…"],[9603,9720,"Let me out!"],[9806,9929,"Let me out!"],[9996,10070,"I…"],[10123,10256,"I'm starving to death."],[10870,10929,"Madam."],[10990,11100,"Ms. Summers said"],[11183,11429,"if you kneel and apologize to Young Master,"],[11479,11766,"she can secretly give you some food."],[12679,12773,"I'm sorry."],[12850,13063,"I shouldn't have made Young Master fall."],[13133,13253,"I was wrong!"],[14196,14319,"Snakes!"],[14363,14540,"No, no!"],[14563,14643,"Snakes!"],[14659,14783,"I'm going to die!"],[14783,14869,"Don't!"],[15009,15146,"Evelyn."],[15186,15306,"Don't you just love"],[15306,15459,"using your body to seduce men?"],[15493,15756,"These snakes haven't eaten in days."],[15756,15859,"They're starving!"],[15880,16006,"I'd love to see"],[16006,16186,"where they try to burrow."],[16219,16383,"Just go quietly"],[16426,16600,"to keep your dead parents company!"],[17330,17413,"No!"],[18190,18366,"Am I going to die here?"],[18516,18680,"I haven't taken my revenge yet."],[18996,19180,"I won't accept this!"],[19433,19540,"Evelyn."]],"7":[[103,210,"Evelyn."],[456,563,"Evelyn."],[903,1013,"Is this"],[1123,1326,"a hallucination before I die?"],[2689,2763,"Evelyn?"],[2826,2883,"You're awake."],[2953,3036,"Can you see?"],[3066,3136,"How do you feel?"],[3353,3463,"I can't see clearly."],[3600,3710,"I'm not dead…"],[3796,3926,"What happened to me?"],[3960,4013,"Ms. Bennett,"],[4053,4186,"you were poisoned by snake venom."],[4186,4353,"Fortunately, the venom wasn't strong."],[4353,4523,"It only affected your optic nerves,"],[4523,4633,"so you'll recover with treatment."],[4670,4720,"You alright?"],[4720,4873,"Your husband has been worried sick."],[4979,5210,"He's been watching over you 24/7."],[5410,5553,"It's the least I could do."],[5560,5620,"Don't worry."],[5650,5763,"All the snakes"],[5763,5866,"have been taken care of."],[5910,6070,"We've sprinkled realgar all around the villa,"],[6070,6193,"so there won't be any more snakes."],[6203,6389,"How could there be snakes in weather like this?"],[6426,6593,"Serena must have brought them."],[6626,6733,"Impossible!"],[6733,6846,"Serena isn't that kind of person."],[6846,6943,"I know her!"],[6946,7026,"Adrian,"],[7053,7153,"go check the breed of those snakes."],[7153,7216,"Enough!"],[7326,7440,"Even if Serena did do it,"],[7440,7573,"it was out of desperation."],[7603,7766,"Andy is still in a coma,"],[7766,7866,"and his high fever won't go down."],[7886,8063,"Serena is pitiful enough as it is!"],[8413,8483,"By the way,"],[8513,8706,"remember when I was in that car accident?"],[8706,8886,"Didn't you make a protective charm for me?"],[8906,8990,"It really worked."],[9009,9309,"Why don't you make one for Andy, too?"],[9383,9456,"I knew it."],[9493,9606,"You only saved me"],[9653,9859,"for the sake of Serena and her son."],[9896,10000,"Adrian."],[10063,10170,"Look at me."],[10170,10346,"Look at these snake bites."],[10413,10573,"My vision hasn't even recovered yet."],[10620,10840,"How am I supposed to sew a charm for your son?"],[11020,11129,"Where there's a will, there's a way."],[11343,11400,"Evelyn,"],[11426,11496,"I believe in you!"],[11743,11813,"Adrian,"],[11883,12103,"you recovered from your injuries"],[12103,12303,"not because of the charm I made."],[12359,12470,"But because my father"],[12470,12596,"used all his connections to find you"],[12596,12796,"the best doctor."],[12846,13050,"He went to the temple, bowing"],[13050,13256,"and kowtowing just to pray for you."],[13303,13426,"And it was my mother who stayed"],[13426,13553,"by your bedside for a whole month,"],[13553,13730,"taking care of you day and night."],[13826,14019,"I can't believe her parents did so much for me."],[14090,14290,"Why didn't they ever mention it?"],[14413,14503,"Evelyn."],[14596,14700,"Let's just forget about it."],[14700,14863,"Adrian, bad news!"],[14869,15000,"Andy is having convulsions again,"],[15000,15126,"he's been sent to the ER!"],[15156,15280,"I want that peace charm done by tomorrow."],[15330,15473,"Let's go, take me to him!"],[15976,16036,"Ma'am."],[16046,16116,"The Vice President sent us here"],[16116,16263,"to assist you in sewing the peace charm."],[16300,16383,"Assist?"],[16503,16643,"More like supervise!"],[16809,16956,"Just two more days."]],"8":[[1768,1815,"Evelyn."],[1865,1935,"Is the peace charm ready?"],[2761,2811,"Evelyn."],[2821,2909,"Thank you for your hard work."],[3149,3239,"Just last night,"],[3264,3450,"Andy was diagnosed with acute leukemia."],[3491,3576,"During this time,"],[3608,3727,"I have to stay by his side."],[3820,3877,"Evelyn,"],[3925,4052,"I hope you can understand"],[4052,4197,"how a father feels."],[4277,4394,"When Andy gets better,"],[4434,4589,"I will make it up to you!"],[5338,5428,"Make it up to me?"],[5493,5600,"That's ridiculous!"],[5625,5727,"Adrian,"],[5745,5857,"what you owe me"],[5889,6006,"can never be repaid!"],[6441,6563,"I used to think"],[6623,6775,"that this was my home."],[6801,6911,"I never imagined"],[6923,7098,"that I was just a clown."],[7142,7280,"Everything here"],[7340,7507,"has never belonged to me."],[8525,8725,"Come on, groom, give the bride a kiss."],[8753,8800,"Okay."],[9310,9481,"Good, good. Excellent."],[9512,9716,"I've never seen such a loving couple."],[9716,9868,"You can practically see the sparks flying."],[12670,12731,"Evelyn."],[12731,12802,"I'm home."],[13081,13164,"Evelyn."],[13191,13293,"What are you doing?"],[13313,13396,"What are you hiding there?"],[13396,13446,"Let me see!"],[13446,13586,"Hey, no, no."],[13621,13837,"This is a birthday surprise for you."],[13837,13902,"Oh."],[13928,13988,"Alright, then."],[13988,14054,"I'll just wait here"],[14054,14192,"for the gift from Mrs. Fletcher."],[14192,14267,"Mhm."],[18728,18868,"The trash has been cleared away."],[18900,19013,"Next,"],[19055,19137,"it's time to get down to business!"],[19571,19739,"With Serena's sloppy nature,"],[19804,19996,"she'd definitely leave some loose ends."],[20086,20230,"When that happens,"],[20230,20465,"these surveillance videos will be the proof!"],[21511,21599,"What are you doing?"]],"9":[[11,78,"What are you doing?"],[278,390,"Cleaning up."],[697,879,"No one has been home for a few days."],[920,1011,"There's dust everywhere."],[1146,1319,"You really are a born servant."],[1319,1501,"You get restless if you don't work for a day!"],[1569,1706,"Adrian is looking for you."],[1728,1841,"Come to the hospital with me!"],[2102,2233,"I can't let her get suspicious"],[2253,2369,"at a time like this."],[2390,2509,"I'll just go with her."],[3808,3903,"What's going on?"],[3928,4035,"Isn't that Adrian's"],[4035,4155,"sworn enemy, Liam?"],[4194,4332,"We've been kidnapped!"],[4372,4464,"Let them go."],[4544,4649,"If you have a problem, take it out on me!"],[4769,4874,"All right."],[4894,5001,"Adrian."],[5001,5171,"Years ago, you stole my business,"],[5195,5310,"left me hundreds of millions in debt,"],[5310,5417,"and tore my family apart."],[5437,5545,"You owe me this!"],[5545,5665,"Get on your knees!"],[5665,5752,"Call me Grandpa."],[5765,5922,"Adrian is so arrogant."],[5944,6039,"Even at our wedding,"],[6039,6184,"when serving tea to my parents,"],[6184,6314,"he refused to bend his knees."],[6363,6474,"How could he possibly kneel?"],[6529,6639,"If I kneel,"],[6675,6796,"will you let them go?"],[6973,7087,"I can let them go."],[7110,7247,"But not both."],[7283,7364,"Choose one."],[7364,7487,"An ex-wife,"],[7527,7624,"and a current wife."],[7632,7766,"One is your pure first love,"],[7771,7874,"the other is your burning passion!"],[7891,8016,"I'm dying to see which you pick."],[8016,8113,"I choose Serena."],[9089,9152,"Grandpa."],[9210,9315,"Please let Serena go."],[9362,9449,"I'll take her place!"],[9559,9639,"It turns out"],[9662,9889,"he loves Serena more than I imagined."],[9911,10053,"Enough to lose all dignity,"],[10071,10233,"to have no limits."],[10270,10453,"Even though I'm his wife,"],[10475,10608,"when it comes to life and death,"],[10608,10750,"he would never choose me."],[11066,11139,"Let her go!"],[11584,11656,"Adrian."],[11690,11771,"Go. Run."],[11791,11895,"Andy is waiting for you at the hospital."],[11915,11970,"Go now!"]],"10":[[6,93,"Run!"],[528,622,"Mr. Fletcher sure is devoted"],[622,759,"to his first love!"],[802,972,"It's just too bad for Mrs. Fletcher."],[972,1106,"Meeting Adrian"],[1139,1272,"was just bad luck for her!"],[1619,1720,"What are you doing?"],[1733,1866,"What do you think?"],[2005,2072,"No! Don't!"],[2367,2477,"Boys,"],[2574,2677,"let's move out!"],[2934,3024,"Evelyn."],[3184,3264,"Evelyn."],[3355,3470,"Why didn't you leave?"],[3470,3727,"Serena and your son are waiting for you."],[3727,3797,"I'm not leaving."],[3817,3887,"You are my wife."],[3887,4010,"We live together, and we die together."],[4024,4167,"I could never leave you behind!"],[5143,5190,"What's wrong?"],[5190,5370,"Why are you crying over a TV show?"],[5373,5453,"Oh."],[5457,5764,"This heroine is just so pitiful."],[5774,6007,"The hero sacrificed himself for love."],[6087,6244,"If…"],[6244,6351,"if I die one day,"],[6351,6444,"Adrian,"],[6474,6638,"you must live on well!"],[6728,6836,"What are you talking about?"],[6853,6973,"We're husband and wife, we're one."],[7007,7157,"If one day you're gone,"],[7163,7333,"I certainly wouldn't live on without you."],[7344,7474,"Don't worry, you little crybaby."],[7490,7567,"My wife"],[7597,7754,"is going to live a long, healthy life!"],[7787,7867,"Mmh."],[8268,8365,"Why are you just standing there?"],[8365,8398,"Go!"],[8398,8490,"Run, hurry!"],[10131,10248,"Evelyn."],[10301,10487,"Nothing can happen to you!"],[10704,10807,"Adrian,"],[10807,10930,"even at a time like this,"],[10930,11147,"who are you putting on this act for?"],[11147,11304,"What exactly do you want?"],[13785,13855,"I'm not leaving."],[13875,13945,"You're my wife."],[13945,14066,"We live together, and we die together."],[14082,14225,"I could never leave you behind!"],[14304,14381,"Adrian."],[14474,14594,"So what if you save me?"],[14704,14804,"He's awake! Thank goodness!"],[14804,14904,"Mr. Fletcher is awake."],[14931,15011,"Doctor!"]],"11":[[397,478,"Ah!"],[478,568,"You b*tch!"],[585,672,"If it weren't for you,"],[672,805,"Adrian wouldn't have gotten hurt!"],[832,885,"What?"],[885,1022,"You cursed your parents to death,"],[1022,1159,"and now you want to curse my son's father too?"],[1159,1272,"Serena, you…"],[1272,1353,"Evelyn."],[1463,1543,"Evelyn."],[1706,1786,"Evelyn?"],[1890,2032,"How are you feeling?"],[2068,2172,"Are you hurt?"],[2275,2472,"I'm fine. I don't need your concern."],[2554,2761,"Oh, good."],[2861,2961,"That's good, Evelyn."],[3094,3184,"Andy…"],[3204,3428,"Andy has developed acute leukemia,"],[3535,3867,"and he needs stem cells immediately."],[4007,4374,"Now, the only person who matches him"],[4374,4541,"is you!"],[4541,4754,"Get ready."],[4754,4928,"We're taking your bone marrow."],[4971,5155,"So you risked your life to save me,"],[5155,5355,"and kept saying I absolutely couldn't die…"],[5378,5537,"It was all just to harvest my marrow."],[5570,5714,"I should have known!"],[5937,6017,"Adrian,"],[6107,6267,"you want me to donate marrow to your son,"],[6267,6414,"but did you even ask for my permission?"],[6418,6551,"Why should I ask?"],[6594,6735,"As long as my son needs it,"],[6748,6931,"you should be flayed alive for all I care."],[6968,7098,"Your life is worthless anyway!"],[7110,7250,"In fact, I think your marrow"],[7250,7377,"will dirty my son's blood!"],[7510,7554,"Adrian,"],[7554,7727,"stop wasting time with her."],[7727,7897,"Our son can't wait any longer!"],[8018,8098,"Adrian."],[8114,8261,"Are you really going to do this to me?"],[8318,8495,"There's no time left."],[8538,8715,"We can't even use anesthesia."],[8760,8937,"Just bear with the pain."],[8937,9090,"I'll be right here with you."],[9134,9214,"No!"],[10128,10208,"No, no."],[10315,10445,"Don't!"],[11024,11171,"Adrian,"],[11171,11301,"do you think Andy"],[11301,11464,"will be safe?"],[11488,11634,"Of course!"],[11634,11810,"He's our son!"],[11830,12033,"As long as he survives,"],[12083,12384,"I don't care how many lives it costs!"],[12944,13034,"Is it done?"],[13044,13201,"Hurry and operate on my son now!"],[13201,13284,"Hurry!"],[13443,13533,"Adrian,"],[13550,13697,"you really are a good father"],[13697,13783,"and a good lover."],[13783,14034,"A b*tch and a dog do belong together."],[14062,14259,"I hope you two are stuck together tight,"],[14259,14464,"waiting for me to send you both to hell!"],[18141,18241,"Evelyn,"],[18241,18365,"you've been through a lot."],[18365,18486,"Get some rest."],[18486,18628,"After Andy's surgery,"],[18628,18823,"Serena will take him abroad."],[18823,18997,"We'll go back to how things were very soon."],[18997,19090,"From now on,"],[19090,19274,"I promise I'll make it up to you."],[19274,19412,"I love you."],[19412,19594,"What a pity."],[19607,19786,"We can't go back to the past,"],[19821,20013,"and there is no future anymore!"],[20040,20230,"Goodbye, Adrian."],[20412,20498,"Proceed"],[20528,20645,"according to the plan!"],[24677,24843,"The revenge"],[24939,25136,"has begun!"]],"12":[[180,246,"That's great!"],[280,380,"The surgery was a success!"],[410,510,"Andy is safe!"],[650,820,"The surgery was clearly a success,"],[883,1026,"why don't I feel happy at all?"],[1076,1190,"It feels as if I've unknowingly"],[1246,1400,"lost something very important."],[1680,1723,"Serena."],[1773,1840,"Don't be sad."],[1880,2030,"It's good news that Andy's surgery succeeded."],[2193,2266,"Andy still needs to stay"],[2293,2396,"in the sterile ward"],[2396,2480,"for a while."],[2533,2726,"I'll hire the best professionals to care for him."],[2780,2836,"You've had a tough time"],[2876,2940,"these past few days."],[3033,3126,"I'll take you home later"],[3150,3230,"so you can get some rest."],[3300,3370,"Okay."],[3430,3506,"Wait for me here."],[3540,3640,"I'm going to the restroom first."],[4070,4160,"Serena hasn't eaten well"],[4190,4293,"these past few days."],[4320,4420,"Book me a table at the"],[4420,4533,"revolving restaurant downtown."],[4586,4623,"Also,"],[4650,4803,"her favorite luxury brand has new arrivals."],[4883,5000,"Contact the store manager."],[5013,5090,"I'm booking the whole store tonight."],[5153,5193,"Right,"],[5256,5400,"get a bouquet of roses too."],[5753,5826,"What are you waiting for?"],[5870,5913,"Mr. Fletcher."],[5930,5993,"Have you forgotten?"],[6060,6226,"Mrs. Fletcher is still waiting for you in the ward!"],[6356,6393,"D*mn it."],[6446,6610,"Evelyn just donated bone marrow for my son,"],[6670,6780,"and she's still waiting in the ward!"],[6860,6963,"How could I forget her!"],[7126,7160,"Let's go."],[7456,7570,"Tell Serena to go home by herself."],[7610,7676,"Come upstairs with me."],[7726,7876,"Arrange a check-up for my wife"],[7906,8003,"and prepare the best supplements."],[8013,8063,"- Yes, sir. - Also,"],[8070,8163,"keep an eye on the auction houses."],[8183,8300,"I want to bid on a rare piece of jewelry"],[8350,8496,"as a gift to make it up to her."],[8543,8583,"Yes, sir."],[9083,9126,"Evelyn?"],[9146,9216,"Are you okay?"]],"13":[[133,173,"Evelyn?"],[196,263,"Are you okay?"],[1083,1176,"The bed is already cold."],[1226,1313,"She's been gone for a long time."],[1386,1536,"Is Evelyn really mad this time?"],[1580,1630,"That makes sense."],[1670,1766,"We were in a rush this time,"],[1790,1883,"and she didn't get anesthesia."],[1923,2010,"She must have been in too much pain."],[2080,2160,"The pain made her storm off for the"],[2200,2286,"first time in six years."],[2316,2396,"But she loves me so much,"],[2423,2556,"she'd never actually disappear."],[2620,2673,"Mr. Fletcher,"],[2740,2816,"Mrs. Fletcher..."],[2916,2956,"Oh, right."],[3033,3086,"She went home."],[3120,3190,"She must have"],[3210,3266,"gone back first."],[3340,3380,"Let's go."],[3740,3793,"Evelyn!"],[3880,3933,"Evelyn!"],[3980,4036,"Where are you?"],[4096,4180,"I came back for you!"],[4213,4300,"Come out, quickly!"],[4393,4460,"Mr. Fletcher,"],[4570,4680,"I've searched every room,"],[4703,4810,"but there's no one home."],[4900,4953,"However,"],[5080,5210,"I found this in the trash can."],[5860,5940,"Could Mrs. Fletcher have"],[6013,6123,"run away from home?"],[6193,6256,"Impossible."],[6323,6423,"She would never leave!"],[6546,6596,"Go investigate."],[6656,6740,"Track down Evelyn's whereabouts."],[6773,6883,"I want every detail!"],[6926,6990,"Right away."],[7333,7403,"Ms. Summers."],[7460,7543,"I have an emergency."],[7550,7620,"Please let me through."],[8033,8123,"No need to check."],[8150,8243,"Evelyn"],[8260,8373,"has indeed run away."],[8390,8493,"To be precise,"],[8510,8600,"she's gone,"],[8606,8746,"and she's never coming back!"],[8896,8936,"Serena,"],[9020,9123,"what nonsense are you spouting?"],[9153,9263,"Watch your words."],[9313,9463,"Evelyn is my wife."],[9566,9710,"I'm just telling the truth!"],[9750,9846,"Congratulations, Adrian."],[9856,10046,"You're finally rid of that stinking maid!"],[10350,10453,"Happy divorce!"]],"14":[[636,753,"I remember this photo."],[913,963,"Hubby,"],[990,1046,"look over here."],[1193,1260,"Smile."],[1736,1776,"Come on."],[2300,2430,"Ever since you joined the photography class,"],[2463,2553,"you've been taking pictures of me."],[2573,2660,"Don't you get bored?"],[2750,2813,"Can't help it."],[2890,3006,"It's your fault for being so handsome."],[3060,3203,"It's a crime to be this good-looking."],[3243,3336,"I just want to hide you away"],[3336,3446,"and keep you all to myself!"],[3803,3860,"Nice."],[3950,4013,"I think so too!"],[4510,4640,"It was supposed to be a private treasure,"],[4686,4733,"but now,"],[4810,4960,"how has it become the proof of our divorce?"],[5110,5173,"Adrian."],[5236,5293,"Adrian!"],[5340,5420,"Why are you zoning out?"],[5523,5670,"I checked this divorce certificate."],[5713,5890,"The seal and coding are authentic."],[5923,6070,"Evelyn must have realized"],[6086,6266,"she isn't worthy of being Mrs. Fletcher,"],[6283,6410,"so she slunk away in shame."],[6430,6546,"This is truly the best news"],[6546,6686,"I've heard all day!"],[6890,6963,"Adrian."],[7030,7153,"How about tonight"],[7220,7363,"we celebrate properly?"],[7626,7790,"All these years I was away from you,"],[7840,7970,"I missed you so much!"],[8093,8136,"Serena,"],[8186,8236,"don't do this."],[8356,8443,"I'm a married man."],[8526,8633,"But you're divorced!"],[8653,8710,"That's impossible!"],[8730,8813,"It's not true."],[8876,9030,"There must be some mistake!"],[9053,9140,"What mistake?"],[9196,9363,"You only married that wretched maid"],[9373,9553,"because John and I were married."],[9566,9740,"You did that just to make me jealous, no?"],[9790,9903,"Now that she's gone,"],[9923,10046,"we can be together again!"],[10166,10266,"Andy is still sick!"],[10290,10383,"He needs his mom and dad"],[10383,10490,"to be there for him together!"]],"15":[[578,660,"Mr. Fletcher."],[684,825,"You shouldn't drink anymore."],[860,972,"Get off me."],[972,1159,"A guy like me doesn't deserve a maid!"],[1176,1259,"Get out!"],[1309,1466,"A little setback is nothing."],[1501,1591,"Mr. Fletcher."],[1604,1695,"I believe in you!"],[1695,1851,"Don't sell yourself short."],[1898,2082,"You can definitely make a comeback!"],[3576,3668,"Hubby,"],[3707,3850,"I love you so much!"],[5016,5120,"So,"],[5158,5328,"you usually blush just holding hands,"],[5353,5408,"but I didn't expect you"],[5408,5512,"to steal a kiss"],[5512,5617,"while I was asleep."],[5617,5694,"You…"],[5757,5900,"You were pretending to sleep?"],[6054,6182,"It's been six years."],[6182,6284,"I'm used to it by now."],[6284,6433,"I've gotten used to life with Evelyn."],[6476,6621,"If from now on,"],[6628,6741,"I never see her again…"],[6871,6953,"Mr. Fletcher."],[7122,7217,"Well?"],[7217,7312,"Any news?"],[7332,7404,"I found something,"],[7489,7552,"but"],[7672,7789,"it's not good news."],[7837,7976,"Mrs. Fletcher has cancelled her identity."],[8002,8169,"The name Evelyn"],[8243,8385,"no longer exists in the system."],[8471,8563,"What did you say?"],[8625,8712,"How is that possible?"],[8793,8907,"She is a living person,"],[8907,9072,"how can she just disappear?"],[9129,9262,"She fits the profile of a housewife."],[9399,9541,"Her social circle is simple."],[9664,9794,"Go find her parents."],[9844,9921,"No, wait."],[9963,10073,"Her parents are already…"],[10135,10246,"But"],[10246,10330,"she has no parents now,"],[10330,10405,"and no home."],[10448,10582,"She only has me."],[10582,10755,"Why would she leave?"]],"16":[[295,375,"Oh, right."],[402,495,"This divorce certificate."],[515,625,"I never signed anything."],[625,754,"What bullsh*t divorce agreement?"],[754,932,"This certificate is definitely fake!"],[932,1049,"Investigate this lead."],[1049,1167,"I have verified it."],[1239,1433,"It was indeed issued by city hall."],[1666,1748,"It was Mrs. Fletcher who took"],[1748,1910,"the agreement you signed"],[1910,2000,"to file for it."],[2088,2173,"What did you say?"],[2240,2339,"I never signed"],[2339,2452,"any such agreement!"],[2557,2717,"Could it be that time…"],[2791,2904,"I promised you I wouldn't make a scene,"],[2927,2976,"but"],[2976,3073,"a single necklace isn't enough."],[3134,3391,"I want you to transfer the downtown mansion"],[3406,3478,"to my name."],[3513,3571,"No problem!"],[6850,6936,"Adrian,"],[7008,7163,"I know you're in a bad mood."],[7233,7375,"Have a drink."],[7390,7490,"Alcohol"],[7490,7640,"can make you forget everything."],[13358,13418,"You…"],[13418,13505,"I…"],[13641,13770,"What happened between us yesterday?"],[13820,13925,"What?"],[13947,14089,"Don't you remember?"],[14142,14207,"Adrian,"],[14267,14459,"so many years have passed,"],[14459,14549,"but your skills"],[14582,14786,"are still as good as they used to be."],[14786,14989,"You haven't lost your touch at all!"]],"17":[[1782,1942,"Is this betrayal?"],[1942,2062,"I guess not, right?"],[2096,2260,"Evelyn and I are already divorced."],[2284,2402,"But why"],[2402,2582,"do I still feel this d*mn guilt?"],[2604,2740,"I never intended for things to happen"],[2740,2844,"with Serena."],[2924,3094,"I only wanted to do it for our son,"],[3162,3388,"to fulfill my duty as a father and ex-husband"],[3414,3616,"by taking care of them."],[4412,4530,"Last night,"],[4530,4684,"you put something in my drink."],[4928,5062,"Why would you think that?"],[5434,5610,"I only had one glass of wine."],[5654,5822,"How could I have blacked out"],[5822,5962,"and slept with you?"],[5988,6140,"What exactly do you want?"],[6140,6334,"You clearly stopped loving me ages ago."],[7446,7552,"Serena,"],[7552,7686,"why did you betray me?"],[7726,7860,"I gave you my everything."],[7860,8000,"Why did you treat me like that?"],[8090,8308,"You blame me for cheating?"],[8344,8490,"It's your own fault for not being able"],[8490,8590,"to keep me interested."],[8730,8880,"Let me tell you, Adrian,"],[8880,9090,"I stopped loving you long ago!"],[9112,9272,"I was only with you"],[9272,9402,"for your money!"],[9446,9614,"Since you know everything,"],[9614,9780,"I don't need to pretend anymore."],[9780,9918,"Let's get a divorce!"],[10140,10260,"You left so resolutely back then."],[10300,10448,"What exactly do you want now?"],[10488,10580,"Adrian,"],[10660,10778,"I regret it."],[10828,10938,"After I left you,"],[10974,11106,"I realized"],[11106,11284,"that you're still the one I love most."],[11328,11468,"I was just too young back then."],[11468,11562,"I just wanted to have fun"],[11582,11736,"and didn't understand my own heart."],[11866,11964,"Please forgive me,"],[12002,12110,"won't you?"],[12322,12506,"Evelyn has left anyway,"],[12506,12652,"and she won't be coming back."],[12686,12872,"Let's start over,"],[12872,12954,"okay?"],[13094,13184,"Andy…"],[13184,13402,"Andy needs his biological father."],[13480,13600,"I'm begging you."],[13682,13798,"Is this for real?"],[13824,14064,"The woman who once treated me like trash"],[14064,14262,"now worships me like a god."],[14770,14932,"You're so good to me!"],[15006,15106,"Just consider it"],[15138,15324,"giving our son a complete home."]],"18":[[486,556,"Evie!"],[696,770,"Evie!"],[1026,1090,"Marian."],[1246,1319,"Evie,"],[1340,1473,"you're finally here."],[1506,1643,"I was worried sick!"],[1760,1843,"Marian."],[1956,2066,"I missed you so much!"],[2196,2276,"Oh, sweetie."],[2413,2663,"You were only a teenager when I left."],[2773,2866,"I never expected"],[2889,3030,"you'd be all grown up now!"],[3030,3169,"And you've become even more beautiful!"],[3383,3450,"Marian,"],[3729,3856,"my mom and dad,"],[3983,4133,"they died so unjustly!"],[4360,4473,"Back then,"],[4529,4746,"your mother worked for me for over ten years."],[4793,4889,"To me,"],[4910,5096,"she was already family and a best friend."],[5193,5363,"When my family immigrated,"],[5393,5579,"I offered her a million a year"],[5603,5739,"to try and get her to come with us,"],[5816,6066,"but she insisted on staying behind."],[6220,6306,"If only"],[6306,6463,"you had come with us back then,"],[6600,6756,"maybe none of this"],[6756,6913,"would have ever happened!"],[7016,7279,"Mom and Dad were such kind people."],[7309,7473,"They spent their whole lives doing good."],[7503,7663,"They should have lived long lives,"],[7696,7766,"but because of me,"],[7766,7906,"they met such a tragic end."],[8229,8336,"It's all my fault!"],[8503,8703,"I trusted the wrong person,"],[8816,9076,"and I caused my parents' deaths."],[9156,9300,"Don't blame yourself, sweetie."],[9300,9370,"It's not your fault."],[9446,9686,"If you must blame someone, blame those"],[9740,9933,"who use their filthy money"],[9983,10176,"to treat lives as worthless trash!"],[10279,10370,"Don't worry."],[10413,10506,"I am here for you,"],[10579,10776,"and I'll make sure you get justice!"],[11106,11200,"That's right, Ms. Bennett."],[11220,11366,"I'll work with you too."],[11393,11529,"You're not alone in this fight."],[11920,12120,"Evie, who is this?"],[12190,12240,"Marian,"],[12273,12366,"I've told you about him."],[12413,12640,"This is Mr. Sullivan from BX Ventures."],[12676,12756,"His sister"],[12813,12986,"is also one of Serena's victims."],[13073,13176,"For this revenge,"],[13183,13293,"he's been a great help."],[13469,13540,"Hello."],[13730,13873,"Good, young man."],[13936,13996,"Very good!"],[14106,14246,"If we all join forces,"],[14390,14750,"Serena will definitely pay"],[14776,14873,"for what she's done this time!"],[14943,15223,"Adrian, since you can't give me justice,"],[15263,15406,"I'll get it myself!"],[15456,15616,"The day the tower collapses"],[15643,15766,"is coming soon!"]],"19":[[53,113,"Mr. Fletcher,"],[170,393,"since you and Ms. Summers have reconciled,"],[413,646,"should we still search for your wife?"],[883,976,"Not for now."],[1019,1240,"Put away all of Evelyn's things."],[1326,1469,"I don't want to upset Serena."],[1733,1796,"Understood."],[1863,1916,"Wait."],[2316,2456,"Help me investigate Serena instead!"],[2643,2710,"Alright."],[3416,3496,"I just hope"],[3526,3736,"you can really adapt to life without your wife."],[3793,3846,"After all,"],[3920,4036,"relying on someone"],[4056,4186,"can be addictive!"],[4726,4853,"Drive. Let's go home."],[4900,4983,"Yes, Mr. Fletcher."],[5366,5446,"Did we switch cars?"],[5560,5653,"No."],[5873,5956,"That's strange."],[5993,6133,"Why is this backrest"],[6139,6220,"so uncomfortable today?!"],[6339,6546,"Mr. Fletcher, you have back problems."],[6596,6776,"In the past, Evelyn had a cushion customized"],[6776,6856,"to the curve of your spine"],[6906,7003,"and placed it in the car."],[7073,7196,"But since you said"],[7229,7426,"to clear out everything your wife left behind,"],[7536,7633,"I removed it."],[7663,7876,"Do you want me to put it back?"],[8140,8220,"No."],[8373,8436,"Let's go."],[9176,9256,"Justin,"],[9323,9423,"make me a cup of coffee."],[9476,9663,"Mr. Fletcher, have you forgotten?"],[9693,9806,"You can't drink coffee."],[9809,9909,"You're allergic to caffeine."],[10016,10096,"Then what am I supposed to do?"],[10146,10266,"I have meetings this afternoon."],[10303,10423,"How can I function in this state?"],[10536,10673,"It's so weird."],[10713,10840,"No matter how busy I used to be,"],[10856,10979,"I never felt this tired."],[11076,11153,"Mr. Fletcher,"],[11206,11426,"do you truly not know why?"],[11650,11750,"What do you mean?"]],"20":[[50,143,"What do you mean?"],[243,339,"In the past,"],[420,526,"every morning Evelyn"],[526,626,"would add energizing herbs"],[626,766,"to your breakfast."],[823,973,"To improve your health,"],[1063,1223,"she woke up at four every morning."],[1280,1440,"She made a variety of your favorite dishes,"],[1483,1610,"and even took classes to learn."],[1763,1900,"Please deliver today's lunch"],[1933,2086,"to Adrian for me."],[2110,2183,"Ma'am,"],[2243,2400,"you're a wealthy wife now."],[2423,2636,"Just let the servants handle this."],[2666,2769,"Why wear yourself out?"],[2833,2916,"I love him."],[2950,3106,"I'd do a million things for him."],[3143,3329,"If even one thing makes him happy,"],[3339,3413,"then I'm happy."],[3670,3760,"Mr. Fletcher."],[3860,4016,"Evelyn really loved you."],[4066,4183,"Unlike Ms. Summers,"],[4216,4346,"who only ever takes from you."],[4346,4393,"Shut up!"],[4476,4550,"Get out!"],[5953,6036,"I want this one,"],[6053,6189,"this one, and that one."],[6213,6316,"Wrap them all up!"],[6556,6636,"Honey."],[6700,6809,"Didn't you say you were dieting"],[6809,6976,"and just looking?"],[7000,7316,"I... I'm just having a light meal."],[7356,7456,"I only eat occasionally"],[7456,7573,"to have the energy to diet!"],[7616,7770,"Okay, I'll buy them all."],[7770,7850,"Really?"],[7936,8026,"We'll take everything."],[9090,9203,"What can you tell just by listening?"],[9270,9370,"I'll just buy the whole set."],[9376,9513,"If we miss one, I'll buy more."],[9566,9736,"Ugh, what do you know?"],[9763,9979,"With blind boxes, listening to guess"],[9979,10046,"is the fun part!"],[10086,10166,"I want this one!"],[11159,11270,"It's all your fault."],[11283,11436,"You kept talking in my ear,"],[11459,11600,"that's why I heard it wrong."],[11646,11786,"You're so annoying! So annoying!"],[12200,12309,"My Evelyn"],[12346,12459,"is just unbearably cute!"],[13906,14019,"What is wrong with me?"],[14053,14140,"Why am I crying over a woman"],[14140,14236,"I don't even love?"],[14286,14530,"Could it be that I've fallen in love with her?"]],"21":[[400,480,"Adrian,"],[480,588,"what are you looking at?"],[736,804,"Nothing."],[856,944,"What brings you here?"],[1020,1076,"Look,"],[1096,1216,"I bought a new outfit,"],[1216,1308,"and I need a new bag"],[1308,1356,"to go with it."],[1388,1468,"Let's go, Adrian."],[1480,1596,"Get your Black Card ready."],[1620,1736,"I'm in a good mood today."],[1760,1896,"I won't stop until I've spent"],[1896,1984,"eight figures!"],[2056,2113,"All she cares about"],[2113,2223,"is her handbags."],[2276,2340,"She never asks me"],[2340,2413,"if I'm busy"],[2430,2490,"or tired."],[2552,2644,"Unlike Evelyn."],[2728,2776,"D*mn it!"],[2799,2949,"Why am I thinking of her again?"],[3092,3184,"Let's go."],[3788,3896,"You go ahead."],[3896,4036,"We aren't going together?"],[4160,4216,"I don't want the staff"],[4216,4316,"to see us."],[4356,4504,"If you're not going, I will."],[4741,4864,"Why am I"],[4930,5033,"so unpresentable"],[5060,5164,"to her?"],[5472,5544,"Ms. Summers,"],[5544,5648,"you are naturally beautiful."],[5676,5732,"These bags"],[5732,5836,"only look good when you carry them."],[5864,5964,"That's right, ma'am."],[5964,6140,"Every single one of these bags suits you."],[6180,6340,"I'll take them all."],[6380,6516,"Send them all to the Fletcher estate!"],[6616,6664,"Let's go."],[6716,6788,"To the next store!"],[6972,7080,"Wait."],[7080,7192,"What's wrong?"],[7244,7324,"Serena,"],[7392,7444,"when do you plan"],[7508,7572,"to announce the news"],[7572,7704,"of our remarriage?"],[7780,7916,"What did you say?"],[7916,8000,"Remarriage?"],[8144,8268,"Yes."],[8296,8516,"We've come full circle"],[8516,8664,"and are together again."],[8672,8788,"Shouldn't we get remarried?"],[8920,9000,"What is that supposed to mean?"],[9000,9080,"Adrian,"],[9188,9388,"you think buying me a few lousy bags"],[9484,9580,"is enough to trap me for a lifetime?"],[9664,9748,"I'm telling you,"],[9844,9924,"no way!"],[9984,10160,"With the way you're acting,"],[10160,10288,"you're only worthy of dating me."],[10288,10360,"Take it or leave it!"]],"22":[[0,40,"Serena!"],[40,172,"What are you doing?"],[192,324,"If you make me unhappy,"],[344,400,"then no one gets"],[400,468,"to be happy!"],[644,740,"Trash"],[740,904,"belongs in the trash can!"],[1004,1100,"Useless junk!"],[1261,1304,"Serena,"],[1316,1392,"these bags add up to"],[1420,1548,"over ten million,"],[1548,1692,"and you're just stomping them to pieces."],[1736,1852,"That handsome guy is so pitiful."],[1876,1992,"He's so rich and handsome."],[2004,2044,"Why did he have to choose"],[2044,2148,"a girlfriend like that?"],[2188,2281,"He brought it on himself."],[2301,2420,"If a girl actually treated him well,"],[2420,2540,"he wouldn't even look at her."],[2540,2696,"He'd think she was too easy to get"],[2696,2800,"and not worth cherishing!"],[3260,3468,"Sir, are you alright?"],[3480,3688,"I'm fine."],[3980,4060,"Back then,"],[4060,4136,"the gifts I gave Evelyn"],[4136,4216,"were nowhere near this expensive."],[4242,4372,"But even if it was just"],[4420,4496,"a wooden hairpin"],[4496,4610,"worth a few bucks,"],[4673,4760,"she would treasure it"],[4760,4864,"and couldn't bear to wear it."],[5820,5904,"Hello?"],[5956,6072,"Mr. Fletcher, I found something."],[6128,6264,"Ms. Summers…"],[6264,6392,"While she was abroad,"],[6392,6544,"she never got a divorce at all."],[6712,6800,"Go on."],[6844,6932,"Young Master was diagnosed"],[6932,7100,"with leukemia while abroad,"],[7100,7184,"but Ms. Summers didn't want"],[7184,7304,"her husband to pay for the treatment,"],[7304,7468,"so she came back home"],[7468,7688,"to find you."],[7960,8080,"I knew it."],[8080,8220,"Anything else?"],[8290,8396,"Yes."],[8433,8593,"I questioned the doctor carefully."],[8610,8726,"Young Master didn't slip that day"],[8744,8820,"because of the soapy water."],[8820,8928,"It was actually because"],[8944,9092,"his condition had worsened."],[9132,9232,"And MrS. Fletcher"],[9272,9392,"was framed!"]],"23":[[337,403,"Someone fell from the building!"],[413,457,"Mom!"],[548,655,"No!"],[712,812,"No!"],[837,937,"Who is that?"],[942,1001,"No!"],[1029,1091,"How terrible!"],[1191,1327,"Serena told me everything,"],[1394,1584,"that your mother fell by accident."],[1603,1686,"No!"],[2951,3148,"Looks like it's another sleepless night."],[3321,3416,"Ms. Bennett."],[3478,3588,"Ms. Bennett, are you all right?"],[3680,3763,"Ms. Bennett?"],[4384,4484,"I'm glad you're okay."],[4531,4644,"I just finished a video meeting"],[4644,4744,"with the team back home."],[4798,4998,"I passed your room on my way out,"],[5071,5225,"and heard you screaming,"],[5276,5358,"so I came to check on you."],[5497,5607,"I'm sorry."],[5633,5804,"I haven't been sleeping well lately."],[5814,5937,"Sorry to disturb you."],[5957,6154,"It's fine, I understand."],[6224,6374,"When my sister first passed away,"],[6494,6598,"I had constant nightmares too."],[6678,6791,"I kept asking myself"],[6838,6963,"why someone as"],[6963,7083,"gentle and kind as my sister"],[7117,7250,"had to meet such a tragic end."],[7367,7447,"Exactly."],[7504,7584,"Why?"],[7694,7854,"Why do bad things happen to good people,"],[7937,8081,"while the wicked live carefree lives?"],[8283,8353,"But it doesn't matter."],[8503,8613,"Since there is no justice"],[8643,8723,"in this world,"],[8837,9014,"I will exact it with my own hands!"],[9397,9477,"That's fine."],[9517,9641,"I'm glad you see it that way."],[9699,9774,"Oh, right."],[9818,9916,"I have good news."],[9978,10198,"My assistant told me she's made contact"],[10205,10340,"with the insiders you mentioned."]],"24":[[357,535,"Are you the maid and butler for the Fletchers?"],[545,685,"Yes. We need to be quick."],[689,819,"Serena has a terrible temper."],[835,979,"If she can't find us,"],[1006,1086,"she'll fly into a rage."],[1134,1267,"Alright, I'll be brief."],[1327,1404,"You must already know about"],[1404,1531,"Ms. Bennett's situation."],[1531,1663,"She asked me to give this to you."],[1715,1805,"What is this?"],[1951,2042,"It's a hallucinogen,"],[2048,2110,"colorless and odorless."],[2122,2317,"Put it in Serena's food or drink."],[2337,2540,"Then, say something to provoke her."],[2567,2644,"Her inner malice"],[2644,2769,"will naturally spill out,"],[2769,2987,"and she'll confess everything she's done."],[3038,3128,"Understood."],[3128,3168,"By the way,"],[3168,3258,"a word of caution."],[3296,3453,"Serena is mentally unstable."],[3466,3616,"She'll be dangerous once she takes the drug."],[3685,3825,"Protect yourselves."],[3832,3895,"Rest assured,"],[3895,4095,"you'll be very satisfied with the payment."],[4139,4255,"What kind of people do you take us for?"],[4265,4389,"We aren't doing this for money."],[4389,4546,"Back when my daughter was critically ill,"],[4549,4756,"Ms. Bennett paid the bills without hesitation"],[4806,4986,"and found a specialist for the surgery."],[5016,5096,"I can never repay the kindness"],[5096,5240,"she showed me in this lifetime."],[5266,5390,"This is the least we can do."],[5435,5739,"My ex was abusive and wouldn't let me go."],[5769,5992,"If it weren't for Ms. Bennett, I'd be dead by now."],[5995,6146,"I'm willing to do anything for her."],[6186,6319,"Alright then, I'm counting on you."],[6428,6509,"Let's go!"],[6509,6588,"Let's move."],[7412,7469,"Wait!"],[7652,7839,"Serena is concerned about me?"],[7914,8156,"She must still have some feelings for me."],[8583,8683,"Adrian,"],[8683,8815,"where is my bag?"],[9719,9774,"I threw it away."],[9943,10076,"You did? Shouldn't you buy me a new one?"],[10106,10200,"With an attitude like that,"],[10223,10380,"how dare you say you love me?"]],"25":[[0,91,"If you want the bag,"],[153,280,"then remarry me!"],[298,388,"I told you,"],[397,510,"that's impossible!"],[510,560,"Fine."],[620,747,"Then let's go our separate ways."],[1204,1356,"What do you mean, Adrian?"],[1361,1458,"Are you playing me?"],[1483,1623,"You sleep with me and then try to run?"],[1626,1718,"I didn't sleep with you."],[1746,1876,"You drugged me,"],[1906,2070,"but I went to the hospital for a checkup."],[2090,2247,"Nothing happened between us that night."],[2278,2410,"I'm refusing to be with you,"],[2439,2622,"and it has nothing to do with sex."],[2654,2746,"It's because"],[2794,2894,"you and John"],[2916,3046,"never got divorced!"],[3298,3383,"How did you know?"],[3435,3630,"Not only do I know you aren't divorced,"],[3646,3707,"but I also know"],[3707,3842,"you only came back to the country"],[3842,3942,"to treat Andy's illness."],[3978,4142,"Andy is my son."],[4194,4319,"To cure him,"],[4346,4482,"I'd do anything!"],[4582,4662,"Serena,"],[4714,4851,"you didn't have to go to such lengths"],[4851,4958,"to hurt me again."],[5018,5078,"After all,"],[5151,5347,"I've already given you enough."],[5398,5530,"You actually dared to investigate me!"],[5774,5890,"So what if I'm not divorced?"],[5974,6106,"It's your honor that I'm still"],[6142,6274,"willing to sleep with you!"],[6511,6603,"Is it?"],[6865,6961,"I'm not surprised."],[7022,7110,"After all,"],[7158,7338,"this isn't the first time you've betrayed a marriage."],[7572,7659,"Adrian,"],[7686,7846,"didn't you say you loved me most?"],[7846,7974,"How can you treat me like this?"],[7997,8158,"Do you just care about the status?"],[8198,8284,"Or did you actually fall for"],[8284,8375,"that low-life maid,"],[8375,8546,"and you're just using this to dump me!"],[8867,8953,"Evelyn"],[9062,9199,"is my wife."],[9254,9426,"Show her some respect!"],[9502,9606,"If I ever hear you"],[9606,9726,"insult her again,"],[9758,9883,"I'll make you pay for that,"],[9883,9974,"and for framing her"],[9998,10155,"in the past!"],[10298,10378,"Adrian,"],[10388,10547,"how could you do this to me!"],[10562,10642,"I knew it,"],[10642,10802,"you fell for that slut!"],[10802,10959,"She has no money, no looks, no figure."],[10959,11091,"She is nothing compared to me!"],[11094,11202,"Why would you fall for her?"],[11202,11384,"Are you blind?"]],"26":[[337,468,"I never thought the day would come"],[470,680,"when I'd grow tired of Serena."],[734,805,"All these years,"],[805,1046,"her selfishness never changed."],[1061,1181,"But I seem to have changed."],[1221,1384,"I used to think she was just being genuine"],[1384,1498,"willful, and cute."],[1498,1716,"But now I just find her utterly annoying!"],[1750,1873,"What changed me?"],[2120,2202,"Evelyn."],[2342,2424,"Marry me!"],[2726,2829,"Didn't you tell me"],[2829,2967,"that you liked champagne roses?"],[3004,3134,"I had a batch grown just for you."],[3264,3331,"Do you like them?"],[3496,3576,"Mr. Fletcher."],[3641,3782,"Why are you so good to me?"],[3900,4047,"It's your fault for being so handsome,"],[4069,4237,"simply devastatingly handsome."],[4252,4406,"I just want to hide you away"],[4406,4514,"and keep you all to myself."],[4988,5085,"Evie."],[5176,5375,"Is that you?"],[5834,5867,"Hello?"],[5900,5972,"Justin."],[6032,6206,"Find out my wife's whereabouts."],[6237,6324,"Where is she right now?"],[6324,6441,"Who is she with?"],[6453,6564,"I'm going to North District to see her,"],[6564,6716,"when is the soonest flight?"],[6716,6850,"Find out everything!"],[6873,6953,"Mr. Fletcher."],[7017,7148,"I advise you to stop looking."],[7168,7248,"What do you mean?"],[7349,7454,"Did you find her?"],[7485,7645,"Your wife disappeared so completely,"],[7737,7884,"she couldn't have done it alone."],[7949,8093,"Either someone is helping her,"],[8181,8365,"or she has completely given up on you,"],[8410,8490,"and has gone so far"],[8581,8762,"that she is beyond my reach."],[8777,8893,"If she's beyond your reach,"],[8893,9020,"then expand the search!"],[9020,9205,"Do I have to teach you your job?"],[9237,9317,"Mr. Fletcher."],[9412,9549,"Do you really not understand?"],[9604,9764,"Mrs. Fletcher disappeared so completely"],[9838,10001,"because she wants to leave you."],[10085,10210,"Even if you find her,"],[10336,10417,"do you think she'll come back?"],[10482,10625,"As long as I apologize properly"],[10625,10697,"and make it up to her,"],[10697,10754,"she will definitely"],[10754,10885,"come back to my side!"]],"27":[[466,553,"You have no idea"],[623,790,"how long I've waited for this day!"],[986,1033,"Enough."],[1086,1143,"Justin."],[1240,1359,"Stop spouting nonsense."],[1400,1469,"Go investigate."],[1506,1593,"Investigate thoroughly!"],[1636,1710,"Yes, Mr. Fletcher!"],[2453,2543,"Why are you still standing there?"],[2610,2736,"I pay you so much money,"],[2746,2863,"and it's not for you to sit around doing nothing!"],[3270,3403,"Go get me a glass of wine,"],[3446,3533,"and then sweep this floor"],[3579,3666,"until it's spotless!"],[3743,3796,"Yes."],[3813,3883,"Ms. Summers."],[6673,6779,"Ms. Summers,"],[6829,6909,"here is your wine."],[7253,7363,"What took you so long?"],[7413,7516,"Are you slacking off?"],[7579,7793,"Just because Adrian argued with me,"],[7850,7993,"you assume I've fallen out of favor?"],[8403,8479,"Let me tell you,"],[8573,8706,"in Adrian's eyes,"],[8746,8890,"I will always be a goddess!"],[9076,9250,"Crushing a lowlife like you"],[9279,9443,"is even easier"],[9476,9559,"than squashing an ant!"],[9679,9756,"Ms. Summers,"],[9779,9866,"you've misunderstood."],[9873,9950,"Get away from me!"],[12656,12733,"My head!"],[12783,12959,"Why does my head hurt so bad?"],[13476,13569,"Serena."],[13769,13856,"Serena."],[13909,13959,"Who's there?"],[14003,14093,"Who is calling me?"],[14146,14246,"It hurts like hell!"]],"28":[[83,210,"Don't you remember me?"],[316,450,"But I'll never forget you!"],[553,620,"That day,"],[670,800,"you called me to that dinner party"],[846,946,"and forced me to drink."],[1056,1159,"I threw up everything,"],[1256,1423,"collapsed on the floor, unable to get up,"],[1526,1666,"but you still made me keep drinking!"],[1939,2056,"It's you,"],[2250,2396,"that Sullivan b*tch!"],[2583,2660,"That's right."],[2746,2873,"You killed me."],[2913,3046,"Don't you feel any guilt?"],[3483,3620,"A lousy intern like you"],[3656,3826,"didn't deserve a ride home from Mr. Fletcher!"],[4023,4123,"You b*tch."],[4166,4283,"You deserved to drink."],[4296,4423,"You deserved to drink yourself to death!"],[4650,4786,"What about me?"],[4839,4996,"Do you remember me?"],[5076,5236,"You killed my wife,"],[5366,5489,"hung me from the roof,"],[5589,5703,"and made my daughter"],[5750,5929,"watch me fall to my death!"],[6029,6136,"Serena."],[6270,6426,"When you cut that rope,"],[6453,6626,"didn't your hands shake?"],[6690,6783,"Serena."],[6863,6973,"My husband and I,"],[6996,7176,"we were both smashed to death."],[7236,7350,"It hurts so much."],[7400,7483,"It hurts…"],[7629,7776,"We're coming for you,"],[7809,7940,"to drag you down with us!"],[7950,8143,"No!"],[8179,8240,"Stay away!"],[8290,8420,"You two worthless lives"],[8420,8600,"You're dead! Why keep coming back?"],[8640,8713,"Don't come over here!"],[8750,8809,"Even though…"],[8856,9013,"even though I'm the one who killed you,"],[9033,9076,"but…"],[9076,9236,"but you can't blame me for that!"],[9266,9320,"If you want to blame someone,"],[9350,9479,"blame that daughter of yours"],[9479,9653,"who only knows how to sleep her way to the top."],[9756,9813,"No!"],[9813,9890,"Stay away!"],[9929,10026,"Don't come any closer!"],[10036,10220,"She stole what was mine!"],[10559,10709,"Serena."],[10846,11046,"Don't you have a guilty conscience saying that?"],[11140,11306,"You killed so many people,"],[11420,11593,"and now they've all come to find you."],[11729,11870,"Are you scared?"],[12116,12170,"Ev…"],[12296,12379,"Evelyn?"]],"29":[[329,513,"Evelyn, you b*tch!"],[540,716,"You left! Why did you come back?"],[743,826,"It's all because of you"],[850,1036,"that Adrian broke up with me!"],[1063,1183,"You b*tch!"],[1259,1359,"You just won't die, will you?"],[1396,1546,"Even those venomous snakes couldn't kill you."],[1576,1630,"Fine."],[1660,1726,"Today,"],[1736,1860,"I'll kill you myself!"],[3133,3193,"Are you okay?"],[3443,3523,"I'm fine, Dad."],[3589,3683,"Ms. Bennett's plan"],[3750,3833,"is about to succeed!"],[3996,4103,"That vicious woman"],[4116,4223,"is finally getting what she deserves!"],[4256,4350,"Hurry and inform Ms. Bennett!"],[4439,4476,"Let's go!"],[4933,5039,"I've received the video."],[5056,5113,"Thank you so much"],[5146,5216,"for your help this time,"],[5229,5273,"Eleanor."],[5373,5520,"No need for thanks, Ms. Bennett."],[5546,5676,"You've helped all of us."],[5720,5906,"We're just happy to have the chance to repay you."],[5963,6053,"We all believe"],[6079,6243,"that you'll get justice for your parents!"],[6363,6506,"She has helped so many people."],[6540,6696,"Is Adrian blind?"],[6759,6940,"How could he not like such a gentle, kind,"],[6940,7056,"and strong woman,"],[7136,7386,"and choose a viper like Serena instead?"],[8170,8266,"It's time to act!"],[8463,8526,"Now,"],[8559,8626,"leave the rest to me!"],[10096,10126,"Hello?"],[10186,10236,"What is it?"],[10236,10436,"Adrian, how dare you ignore my calls?"]],"30":[[293,518,"How dare you not answer me?"],[543,670,"What exactly do you want?"],[800,887,"Adrian."],[887,1084,"You haven't been home for days!"],[1097,1231,"Where on earth have you been?"],[1391,1471,"Working overtime."],[1531,1609,"Excuses!"],[1609,1775,"No matter how busy you were before,"],[1781,1950,"you never spent the night at the office."],[1963,2208,"Adrian, you're lying to me."],[2257,2430,"Are you seeing someone else?"],[2540,2650,"Think whatever you want."],[2696,2782,"You admit it!"],[2782,2909,"So you admit it!"],[2916,3089,"How dare you cheat on me behind my back?"],[3103,3239,"Who is the woman seducing you?"],[3239,3380,"I won't let her get away with this!"],[3403,3598,"Your imagination is running wild."],[3608,3705,"I'm still working."],[3705,3818,"I'm hanging up now."],[3872,3978,"Don't you dare!"],[4265,4532,"Ah! Adrian!"],[5857,6019,"Why did I ever think"],[6019,6154,"that this kind of drama was romantic?"],[6187,6307,"That her screaming and jealousy"],[6307,6419,"meant she cared about me?"],[6481,6644,"Someone who truly cares"],[6644,6873,"would never cause trouble while I'm working."],[6873,7058,"They'd only silently support me."],[7382,7495,"You've been busy all night."],[7495,7612,"Don't push yourself too hard."],[7612,7716,"Have something to eat."],[7716,7812,"Thanks, honey."],[7812,7922,"It's nothing."],[7922,8054,"It's the least I could do."],[8311,8391,"Push harder."],[8411,8471,"(Laughs)"],[8471,8526,"(Laughs)"],[8526,8666,"Isn't this hard enough?"],[8666,8755,"Okay, stop, stop."],[8755,8835,"I want some soup."],[8838,8932,"Alright, alright."],[9039,9552,"Evelyn, where on earth are you?"],[9556,9924,"Mr. Fletcher, bad news! It's an emergency!"],[9994,10205,"What is it? Did something happen to Evelyn?"],[10231,10472,"No, it's Ms. Summers."],[10862,11054,"Ex-Wife of Fletcher Group CEO"],[11054,11137,"committed attempted Murder,"],[11137,11339,"and confessed to taking three lives!"]],"31":[[260,448,"You're just a lousy intern,"],[448,638,"and you think you deserve a ride from Mr. Fletcher?"],[638,767,"You cheap sl*t."],[767,1021,"I hope you drink yourself to death!"],[1179,1272,"Stay back!"],[1311,1404,"Stay back!"],[1459,1629,"You two b*tches,"],[1683,1733,"you're already dead!"],[1733,1975,"Why are you coming for me?"],[1975,2158,"Even though I killed you,"],[2185,2342,"but you can't blame me."],[2379,2555,"Blame that daughter of yours"],[2555,2831,"who slept her way to the top."],[2846,3029,"Why did she have to steal what was mine?"],[3029,3109,"Ugh!"],[3186,3403,"Evelyn, you b*tch!"],[3410,3606,"Thought you're gone, why did you come back?"],[3606,3727,"It's all because of you"],[3727,3888,"that Adrian broke up with me!"],[3888,4092,"You sl*t!"],[4107,4377,"I even set snakes on you, but you didn't die."],[4392,4646,"Why are you so hard to kill?"],[4646,4806,"Go to hell!"],[5315,5542,"So Evelyn was telling the truth!"],[5545,5732,"Serena did it on purpose!"],[5732,5934,"That woman!"],[5934,6147,"That b*tch!"],[6147,6317,"Where is she now?"],[6343,6468,"Ms. Summers is…"],[7539,7719,"Adrian, were you looking for me?"],[8745,8860,"I know,"],[8860,9059,"you're still angry"],[9059,9162,"that I refused to remarry you."],[9232,9399,"But you've loved me for so many years."],[9412,9589,"You helped me deal with those peasants once,"],[9589,9824,"so surely you can help me again, right?"],[9928,10025,"As for me,"],[10025,10151,"my request isn't high."],[10161,10271,"Just send me abroad."],[10301,10422,"Once things settle down,"],[10422,10588,"I'll come back to see you and our son."],[10682,10812,"Don't you have anything else"],[10812,10905,"you want to say to me?"],[10987,11142,"What about?"],[11327,11408,"About"],[11503,11678,"how you lied to me!"]],"32":[[180,280,"What do you mean?"],[323,428,"You don't actually believe"],[428,605,"what that online mob is saying, do you?"],[612,725,"Someone must be jealous of me."],[725,869,"They're spreading rumors just to smear me!"],[942,1329,"You plied that intern with alcohol until she died,"],[1349,1506,"and you told me she drank too much"],[1506,1596,"while trying to meet her targets."],[1596,1796,"So I sold my startup company"],[1796,1910,"to compensate her family for you."],[2042,2305,"T-that really had nothing to do with me!"],[2332,2479,"You told me"],[2479,2702,"Evelyn's mother fell by accident."],[2732,2872,"As for Evelyn's father's death,"],[2872,2989,"you said you accidentally"],[2989,3171,"slipped and cut the rope."],[3226,3473,"I was afraid you'd suffer in detention,"],[3533,3705,"so I took the blame for everything."],[3762,3852,"But what is the truth!"],[3892,4079,"Tell me, what actually happened?"],[4079,4225,"I told you the truth!"],[4242,4549,"Adrian, how can you doubt me?"],[4589,4759,"Everything has been exposed online."],[4759,4984,"Are you still refusing to tell me the truth?"],[5362,5578,"Evelyn, you b*tch."],[5585,5789,"You were gone, why did you have to come back?"],[5789,5914,"It's all because of you"],[5914,6072,"that Adrian broke up with me!"],[6358,6666,"You were the one who left me back then,"],[6710,6931,"and you were the one who came back to find me!"],[6968,7122,"It's fine if you don't love me,"],[7125,7288,"but what exactly did Evelyn do wrong"],[7288,7542,"to deserve you harming her with snakes?"],[7622,7842,"How can you believe what those videos say?"],[7842,7982,"I was just spouting nonsense."],[7982,8149,"Someone must be framing me!"],[8159,8246,"Think about it."],[8246,8483,"How were those videos filmed?"],[8483,8628,"Don't you find it strange?"],[8651,8755,"It must be…"],[8755,8905,"Someone must be setting us up."],[8905,9049,"Yes, that must be it!"],[9049,9129,"Fine."],[9212,9399,"You won't tell the truth, will you?"],[9399,9532,"Then I'll just have to let the police question you."],[9572,9729,"You have three lives on your hands."],[9773,9903,"That's enough to get you the death penalty!"],[9903,10006,"No!"],[10133,10186,"No, don't!"],[10186,10370,"Don't! I'll talk!"]],"33":[[23,93,"Speak."],[160,296,"This is your last chance!"],[443,573,"That intern…"],[620,783,"You really can't blame me for that!"],[783,953,"I loved you so much back then!"],[993,1119,"But she got drunk on purpose,"],[1119,1263,"just so you would take her home."],[1316,1393,"I just…"],[1433,1593,"I just wanted to teach her a lesson."],[1593,1803,"I didn't expect her to actually die!"],[2050,2083,"So"],[2083,2173,"this is the pure, innocent 'white rose'"],[2173,2356,"that I held in my heart."],[2550,2666,"Then what about Evelyn's parents?"],[2763,2893,"I'm even less to blame for that."],[2973,3066,"Adrian,"],[3089,3323,"you said you would love me forever,"],[3323,3410,"and that you would wait for me."],[3410,3533,"But then you turned around and married"],[3533,3613,"that woman!"],[3683,3846,"You even sided with her parents."],[3870,3996,"Why shouldn't I hate her?"],[3996,4079,"Why shouldn't I teach"],[4079,4210,"the Bennett family a lesson?"],[5086,5283,"You really killed her parents?"],[5520,5583,"My mother"],[5583,5796,"was covered in bruises from a beating."],[5879,6123,"Serena pushed her off the building!"],[6123,6356,"This wasn't an accident, it was murder!"],[6429,6550,"You're biased against Serena."],[6550,6663,"She isn't that kind of person!"],[6766,6809,"Be good,"],[6940,7053,"listen to me."],[7076,7170,"Sign the agreement!"],[7700,7786,"It was you!"],[7840,7903,"Wasn't it?"],[7970,8086,"Serena isn't very strong."],[8133,8250,"She just lost her grip,"],[8263,8403,"and that's why your father fell."],[8416,8493,"It wasn't intentional!"],[8493,8653,"She did it on purpose!"],[8659,8779,"I saw her cut the rope with my own eyes."],[8779,8890,"Why do you always have to"],[8890,9020,"think the worst of Serena?"],[9063,9243,"I just want justice."],[9243,9403,"Is that too much to ask?"],[9566,9746,"Why didn't I believe Evelyn?"],[9863,10016,"I was her only support,"],[10076,10186,"yet I crushed her"],[10186,10306,"last glimmer of hope with my own hands!"],[10390,10506,"Why are you spacing out?"],[10506,10579,"Say something!"],[10579,10650,"Adrian."],[10676,10859,"Did you really fall in love with Evelyn?"],[10873,10979,"You promised me."],[10979,11146,"You said you'd protect me forever!"],[11556,11729,"You know that was in the past."],[12113,12220,"What do you mean?"],[12576,12729,"You got one thing right."],[12753,12936,"I did fall in love with Evelyn."],[12996,13109,"From now on,"],[13136,13259,"she is the woman I want to protect"],[13259,13380,"for the rest of my life!"]],"34":[[56,136,"What did you say?"],[326,523,"You really fell for that maid?"],[590,726,"What makes her better than me?"],[726,906,"Why choose her over me?"],[1016,1156,"Even if she has nothing,"],[1219,1306,"I will still love her."],[1363,1486,"Love needs no reason!"],[1639,1776,"I finally understand"],[1800,2039,"why I lost patience with Serena,"],[2066,2310,"and why I cried for Evelyn."],[2330,2363,"Because"],[2363,2486,"I fell in love long ago with that"],[2486,2636,"girl who stood by me for six years."],[2666,2846,"Sadly, I realized it too late."],[2866,3003,"Just too late."],[3110,3313,"Adrian, how can you not love me?"],[3343,3456,"I'm begging you."],[3460,3576,"Adrian, give me one more chance."],[3576,3666,"Please?"],[3666,3710,"Right…"],[3729,3789,"Andy."],[3839,3983,"I'm Andy's mother!"],[4066,4220,"Andy can't lose his mother!"],[4286,4383,"You don't need to worry about that."],[4410,4533,"I will take care of Andy."],[4579,4676,"As for you,"],[5086,5233,"I won't let my wife's parents"],[5233,5346,"die in vain."],[5363,5520,"Everyone is equal before the law!"],[5620,5750,"You've gone mad, Adrian."],[5756,5883,"You helped me destroy evidence."],[5883,5966,"If I get convicted,"],[5966,6126,"you'll be sentenced too!"],[6200,6279,"That's right."],[6350,6486,"You're a viper,"],[6503,6623,"and I was blind."],[6696,6770,"We"],[6823,6983,"will both pay the price"],[6983,7066,"for our mistakes!"],[8686,8770,"Take her away!"],[8970,9043,"Mr. Fletcher."],[9043,9173,"You are a person of interest here."],[9173,9286,"We need your cooperation."],[9286,9390,"Please come with us."],[9486,9543,"No problem."],[9579,9700,"Please just wait a moment,"],[9709,9800,"I need to get something."],[9840,9896,"Go ahead."],[11540,11759,"Evelyn, my Evelyn…"],[11833,11983,"Where on earth are you?"]],"35":[[25,75,"Evelyn."],[143,178,"Wait for me."],[230,415,"Once I've atoned for all the sins,"],[458,595,"I will go to the ends of the earth"],[633,725,"to bring you back to me!"],[805,925,"No matter how long it takes!"],[1189,1282,"Ms. Bennett, please come in."],[1366,1553,"You are both victims in the Serena case."],[1659,1733,"That's Evelyn."],[1776,1883,"I must be dreaming."],[1943,2075,"You'll both need to allow for questioning shortly."],[2278,2325,"Evelyn!"],[2519,2594,"It really is you!"],[2637,2737,"I knew you'd come back."],[2754,2816,"I knew you would"],[2816,2934,"come back to me!"],[3425,3521,"I am back,"],[3576,3661,"but not for you."],[3702,3760,"Adrian,"],[3805,3875,"don't forget,"],[3907,4074,"my parents lost their lives in North District."],[4135,4199,"I came back"],[4214,4377,"solely to seek justice for them!"],[4666,4718,"Of course."],[4729,4788,"Evelyn."],[4814,4866,"That's only right."],[4948,4996,"Then,"],[5033,5128,"you go in for questioning first."],[5181,5273,"I'll wait for you at the door."],[5313,5367,"Then shall we"],[5403,5485,"go home together?"],[5563,5643,"Go home?"],[5919,6047,"My boyfriend is right here!"],[6101,6194,"Why would I go home with you?"],[6241,6316,"Don't forget,"],[6354,6463,"we're already divorced!"],[6599,6664,"What did you say?"],[6848,6925,"Boyfriend?"],[7050,7135,"I'm Nathan."],[7183,7275,"Nice to meet you,"],[7300,7400,"Mr. Ex-husband."],[7570,7662,"What 'Mr. Ex-husband'?"],[7714,7816,"Evelyn and I aren't divorced yet!"],[7872,7922,"Evelyn,"],[7969,8023,"we haven't even said"],[8058,8184,"a proper goodbye to each other."],[8184,8298,"How can that count as a divorce?"],[8314,8383,"I never signed"],[8383,8465,"the divorce agreement,"],[8468,8580,"so it doesn't count at all!"]],"36":[[106,238,"Do you remember the document you signed"],[265,438,"on the day my father died?"],[478,685,"It wasn't a property transfer agreement."],[715,907,"It was the divorce papers I had prepared!"],[1096,1191,"How long have you"],[1191,1292,"been planning to leave me?"],[1346,1498,"We had a six-year relationship,"],[1569,1751,"and nine years of being together day and night!"],[1803,2018,"You still have the nerve to talk about feelings?"],[2060,2178,"How dare you?"],[2283,2475,"Serena killed my parents!"],[2510,2767,"And you, the husband who claims to love me,"],[2841,3041,"forced me to sign a letter of forgiveness"],[3183,3329,"and helped her destroy the evidence!"],[3400,3483,"Adrian,"],[3510,3730,"my parents are watching from heaven!"],[3768,4009,"You are nothing but an accomplice!"],[4219,4279,"Evelyn,"],[4334,4412,"I beg you,"],[4507,4589,"please forgive me!"],[5737,5767,"Mr. Fletcher,"],[5835,5942,"about Mrs. Fletcher just now…"],[5989,6056,"I know."],[6076,6142,"I saw everything."],[6177,6249,"I need you"],[6264,6343,"to do something for me."],[6399,6483,"What is it?"],[6563,6659,"Find someone"],[6715,6796,"in the detention center"],[6825,6973,"to take special care of"],[6978,7128,"that vicious woman!"],[7203,7253,"Yes, sir."],[7298,7355,"Also,"],[7395,7539,"hire the best lawyer in the North District"],[7539,7612,"to defend me."],[7686,7832,"There's no proof of the things"],[7877,7959,"I did for Serena."],[8124,8226,"I want the lawyer to guarantee"],[8273,8406,"my acquittal."],[8560,8618,"Mr. Fletcher,"],[8677,8748,"what are you planning?"],[8842,9007,"I'm willing to face the law,"],[9052,9144,"but not right now!"],[9322,9389,"Thankfully,"],[9447,9551,"she's back now."],[9574,9716,"I know she's still angry with me,"],[9786,9928,"but I need time to prove"],[9963,10060,"that she's the one I love!"],[11119,11151,"Evelyn."],[11261,11337,"I've been waiting for you!"]],"37":[[10,133,"Is there anything else?"],[213,310,"Evelyn,"],[310,450,"while you were away,"],[453,590,"I really missed you."],[590,730,"Come home with me!"],[730,830,"I've already made myself"],[830,913,"very clear."],[950,1110,"We're divorced!"],[1110,1240,"You have your Serena,"],[1280,1403,"and I have a new boyfriend."],[1453,1590,"We have nothing to do with each other."],[1683,1770,"If there is any relationship,"],[1840,1930,"it's just the one between"],[1930,2033,"an accomplice"],[2033,2110,"and a victim's family."],[2113,2173,"Evelyn."],[2173,2283,"I know you're saying that out of anger."],[2283,2400,"I truly know I was wrong!"],[2420,2463,"All these years,"],[2463,2590,"I've been in love with you all along."],[2633,2693,"Your things…"],[2693,2810,"I've kept them all safe for you."],[2810,2950,"I've treasured every photo of you!"],[2950,3040,"There's no need."],[3053,3180,"I don't need that stuff anymore."],[3200,3270,"Just throw it all away."],[3270,3330,"I know."],[3330,3520,"I know you must think Serena"],[3533,3643,"has tainted that villa."],[3660,3770,"That's why I've already bought a new one"],[3770,3880,"under your name."],[3890,3980,"As long as you're willing,"],[3980,4040,"we can move in there"],[4040,4123,"whenever you want."],[4140,4240,"Are you finished?"],[4290,4370,"Evelyn,"],[4440,4620,"you're still angry with me, aren't you?"],[4620,4740,"I'm not bored enough"],[4740,4900,"to get angry over an ex-husband."],[4920,5053,"I was just wondering,"],[5103,5340,"why are you trying so hard to please me?"],[5363,5443,"At a time like this,"],[5460,5610,"shouldn't you be running around"],[5610,5723,"helping the woman you love?"],[5753,5820,"After all,"],[5820,5960,"she's the one you love the most,"],[5960,6040,"isn't she?"],[6050,6120,"Evelyn,"],[6120,6220,"I regret everything."],[6223,6340,"I loved the wrong person before."],[6380,6460,"Only after you left"],[6460,6510,"did I realize"],[6510,6640,"how important you are to me."],[6663,6790,"During these past six years,"],[6790,6903,"I fell in love with you without even knowing it."],[6963,7070,"You fell in love with me?"],[7070,7113,"Yes."],[7113,7193,"I love you."],[7193,7340,"I just realized it too late."],[7340,7390,"Evelyn,"],[7390,7510,"please, give me one more chance."],[7510,7683,"I promise to love you properly this time!"],[7683,7810,"Too bad I don't love you anymore!"],[7910,7996,"I've been very happy"],[7996,8136,"living without you."],[8226,8300,"Adrian,"],[8300,8416,"in this world,"],[8416,8560,"yours isn't the only love"],[8560,8670,"that is precious!"],[8686,8830,"What I couldn't have in the past,"],[8830,8986,"I don't want now either!"]],"38":[[53,140,"Evelyn,"],[143,243,"you've loved me for six years."],[250,340,"How can you say you don't anymore?"],[340,390,"I just don't."],[390,460,"You might fool others,"],[460,550,"but you can't fool me!"],[580,673,"Adrian,"],[673,790,"are you done making a scene?"],[830,920,"What makes you think"],[920,983,"that after everything that's happened,"],[983,1090,"I can pretend none of it"],[1090,1200,"ever took place,"],[1240,1390,"and just confirm to love you?"],[1390,1570,"Have you forgotten how you and Serena"],[1570,1720,"treated me back then?"],[1720,1800,"Evelyn, I…"],[1870,2010,"To protect Serena,"],[2010,2140,"that murderer,"],[2163,2320,"you threatened me with my father's life,"],[2350,2440,"and even knocked me out"],[2440,2660,"to give her time to destroy evidence!"],[3093,3210,"Call the police?"],[3273,3390,"Evelyn,"],[3423,3546,"you're being very naughty!"],[3850,4000,"To stop me from calling the police,"],[4086,4273,"you used things Serena didn't want"],[4273,4400,"as gifts for me,"],[4400,4550,"playing me for a fool."],[4660,4773,"I really am so useless,"],[4806,4926,"causing such a huge mess,"],[4926,5046,"and I still need you to handle it."],[5046,5233,"I also made Eve so sad."],[5233,5373,"Do you find me annoying?"],[5373,5480,"How could I?"],[5520,5656,"You're just too kind-hearted."],[5686,5793,"But I still feel so guilty"],[5793,5896,"and sad."],[5906,6033,"If you're sad, just go shopping."],[6073,6223,"That pink diamond necklace I gave you,"],[6250,6343,"you didn't like it, right?"],[6436,6573,"This time, buy whatever you like."],[6896,7133,"You made me serve your woman"],[7146,7310,"and your son."],[7330,7440,"You watched them bully me,"],[7440,7530,"yet you turned a deaf ear"],[7530,7670,"and played dumb!"],[7892,8087,"Wow, good job!"],[8469,8618,"Hey, maid,"],[8629,8771,"pick up the glass, now!"],[8829,8931,"Hurry up and pick it up!"],[9022,9207,"Son, come here. Careful."],[9207,9314,"Don't cut yourself!"],[9445,9532,"It's okay, it's okay."],[9756,9829,"Ah!"],[10121,10353,"Serena framed me,"],[10353,10536,"and you didn't investigate or listen."],[10546,10763,"You locked me in the confinement room."],[10766,10993,"I was bitten by a snake and lost my sight,"],[11023,11143,"yet you made me sew a lucky charm"],[11143,11273,"for your son!"],[11273,11433,"Stop talking!"],[11433,11533,"Why?"],[11533,11663,"You can't even stand hearing it?"],[11663,11816,"I actually lived through"],[11816,11913,"every bit of it."],[12006,12213,"What about what I went through?"],[12213,12323,"Adrian,"],[12363,12563,"is this your love?!"]],"39":[[100,260,"I was too obsessed before,"],[260,340,"and I hurt you."],[463,563,"Evelyn,"],[643,793,"break up with him!"],[793,943,"Give me one more chance!"],[963,1123,"I promise I'll make it up to you!"],[1163,1303,"Haven't I made myself clear?"],[1303,1383,"I don't love you anymore!"],[1383,1543,"We're done!"],[1563,1716,"Say whatever you want,"],[1746,1903,"but I don't believe you! I don't!"],[1923,2023,"Then let me tell you this."],[2076,2173,"Serena's video,"],[2173,2263,"I filmed it!"],[2323,2406,"And I leaked it!"],[2486,2613,"I caused your Fletcher Group"],[2613,2723,"to lose nearly a billion"],[2723,2943,"in market value overnight!"],[3003,3143,"I did all of that!"],[3396,3493,"You love me."],[3493,3633,"That's why you spent my money."],[3773,3863,"It's just a few billion."],[3913,4013,"As long as you're happy,"],[4023,4133,"it's all worth it!"],[4243,4326,"Believe what you want!"],[4693,4760,"Evelyn."],[4946,5033,"Evelyn!"],[5533,5623,"Drive!"],[6163,6256,"I'm sorry."],[6273,6383,"I was desperate,"],[6383,6536,"so I asked you to pretend"],[6536,6623,"to be my boyfriend."],[6663,6783,"Sorry you had to see that."],[6836,6936,"It's okay."],[6936,7086,"We're practically that anyway."],[7203,7293,"It's just"],[7376,7486,"your ex-husband,"],[7486,7616,"he seems pretty devoted."],[7630,7703,"Do you"],[7753,7893,"really not love him anymore?"],[7923,8023,"I don't."],[8053,8143,"I'm too afraid to."],[8346,8476,"Then don't worry about him."],[8613,8703,"By the way,"],[8703,8823,"this time,"],[8823,8993,"Serena is definitely done for."],[8993,9136,"Once she's sentenced to death,"],[9183,9286,"what do you plan to do?"],[9456,9526,"Me?"],[9526,9646,"I plan to"],[9663,9873,"go to a small seaside town."],[9873,9973,"Originally,"],[10010,10186,"I wanted to wait for the weather to cool,"],[10203,10383,"and take my parents to the beach."],[10510,10583,"But sadly,"],[10583,10720,"they couldn't wait until then."],[10820,10953,"However,"],[11020,11273,"I'll take them there in my own way."],[11320,11430,"What about you?"],[11520,11590,"Me?"],[11683,11850,"My sister passed away"],[11850,11953,"when I was fifteen."],[12080,12190,"For over a decade,"],[12190,12500,"I've studied and worked desperately"],[12620,12790,"to make something of myself,"],[12870,13013,"all to avenge her."],[13053,13230,"If Serena dies,"],[13310,13416,"I really don't know"],[13416,13596,"what purpose I'll have left in life."],[13876,14070,"Serena will get her punishment,"],[14096,14296,"and you will find hope too."],[14343,14520,"Life is precious."],[14583,14790,"We must live well"],[14803,15000,"for the sake of our loved ones."],[15113,15166,"Okay."]],"40":[[20,113,"Fletcher Group CEO's"],[126,271,"ex-wife, Serena Summers,"],[290,408,"was recently arrested by the police."],[435,547,"The police announced that"],[565,715,"Serena is suspected of three murders,"],[739,874,"including the killing of Fletcher Group intern,"],[900,1022,"Marry Sullivan, ten years ago."],[1046,1236,"as well as the murder of her maid, Ms. Lang,"],[1256,1439,"and her husband, Mr. Bennett, this June."],[1469,1705,"The police have seized key evidence,"],[1746,1945,"and that Adrian himself is implicated."],[1972,2113,"The case has triggered a massive public outcry."],[2123,2196,"Fletcher Group's stock prices"],[2203,2326,"have plummeted for a week straight,"],[2355,2562,"with many partners terminating their contracts."],[2611,2767,"So far, the Fletcher Group has not yet"],[2771,2837,"responded to the matter."],[2936,2980,"Mr. Fletcher,"],[2980,3093,"could you please give us an explanation?"],[3166,3210,"Mr. Fletcher!"],[3303,3346,"Mr. Fletcher!"],[3420,3543,"Please explain yourself!"],[3810,3920,"Adrian is covering for a murderer!"],[3946,4073,"Why doesn't he just go die with that b*tch?"],[4103,4233,"They are cut from the same cloth."],[4263,4393,"Who knows? Maybe Serena"],[4416,4533,"wasn't the only one who killed them!"],[4590,4673,"Boycott the Fletcher Group!"],[4693,4756,"Boycott the privileged elite!"],[4786,4900,"Justice for the common people!"],[5220,5260,"Mr. Fletcher."],[5346,5406,"Mr. Fletcher, wait!"],[5516,5570,"Move!"],[5640,5703,"Mr. Fletcher,"],[5750,5856,"if you let things slide like this,"],[5883,6010,"the company will really be ruined!"],[6126,6226,"It's just a company."],[6296,6410,"It's nothing compared to Evelyn."],[6450,6600,"If you don't want to lose your job,"],[6663,6726,"then get out of my way!"],[6800,6910,"Mr. Fletcher, wake up!"],[6970,7046,"Ms. Bennett…"],[7133,7290,"she already has a new boyfriend."],[7370,7510,"This company is your life's work."],[7563,7653,"You can't give up on yourself"],[7660,7756,"just because Ms. Bennett left!"],[7783,7876,"If it weren't for Evelyn,"],[7880,7960,"I would have given up on myself"],[7966,8040,"six years ago!"]],"41":[[20,86,"If it weren't for Evelyn,"],[103,183,"I would have given up on myself"],[186,251,"six years ago!"],[281,313,"Mr. Fletcher,"],[423,510,"but you and Ms. Bennett are already…"],[513,545,"Shut up!"],[547,565,"Divorced!"],[668,767,"If you say one more word,"],[780,922,"I really will kill you!"],[1735,1828,"What do you know?"],[1946,2107,"Evelyn loves me."],[2183,2223,"That man is nothing but a tool"],[2228,2344,"she is deliberately using"],[2344,2469,"to spite me!"],[2617,2799,"I will get her back by my side,"],[2824,3001,"whether it takes a day or ten years."],[3176,3273,"As for the company,"],[3403,3486,"I don't care!"],[3581,3758,"If I can't have Evelyn by my side,"],[3812,3888,"then what is the use"],[3897,3968,"of making all this money?"],[5091,5183,"Mr. Fletcher has really gone mad!"],[5320,5380,"But"],[5520,5692,"he didn't cherish her when he had her,"],[5744,5885,"so what's the use of regretting it"],[5972,6067,"now that she is gone?"]],"42":[[624,734,"Evelyn."],[786,870,"Marian,"],[920,1152,"why are you letting trash into the house?"],[1472,1572,"Evie,"],[1572,1726,"he came here first thing in the morning"],[1742,1852,"saying he wants to atone!"],[2070,2180,"I'd like to see"],[2180,2370,"how he intends to pay for"],[2370,2522,"two human lives."],[2722,2788,"Hmph."],[3266,3340,"Evelyn,"],[3406,3502,"you're awake?"],[3552,3770,"Did you sleep well last night?"],[3846,3932,"Why are you here?"],[4032,4130,"Shouldn't you go"],[4130,4312,"keep your ex-wife, Serena, company?"],[4380,4460,"Evelyn,"],[4612,4726,"can we not talk about her?"],[4732,4982,"What else do we have to talk about?"],[4990,5110,"Every time you come here,"],[5110,5330,"isn't it always for your ex-wife, Serena?"],[5550,5618,"This time,"],[5638,5792,"no matter what you do,"],[5792,5972,"I will not sign a letter of forgiveness,"],[5980,6084,"so don't waste your breath!"],[6088,6156,"I…"],[6230,6362,"I really came to apologize."],[6362,6530,"It has nothing to do with Serena."],[6532,6704,"From the moment I realized my feelings,"],[6732,6912,"everything I've done has been for you!"],[7070,7282,"You have such a smooth way with words,"],[7306,7482,"but I'm sick of hearing them!"],[7486,7586,"Fine."],[7810,7922,"I'll stop talking."],[8006,8090,"I'll show you!"],[8962,9050,"What are you doing?"],[9166,9280,"This whip"],[9336,9460,"is coated in snake venom."],[9526,9710,"It can cause excruciating pain."],[9720,9782,"Evelyn,"],[9792,9966,"the pain your parents suffered before they died,"],[9992,10120,"and the pain you endured…"],[10120,10252,"today, I only ask you"],[10252,10442,"to return it to me a thousandfold."],[10480,10592,"Do you think doing this"],[10600,10684,"can make up for"],[10684,10892,"everything my parents and I suffered?"],[11080,11260,"If it can earn your forgiveness,"],[11260,11350,"I'm willing to try."]],"43":[[320,400,"I'm…"],[412,498,"I'm sorry!"],[498,594,"Evelyn."],[722,1050,"I didn't know Serena did all that on purpose."],[1352,1450,"Ah!"],[1542,1608,"Evelyn."],[1608,1690,"Wait a second."],[1980,2092,"Don't hurt yourself!"],[3622,3906,"Serena told me"],[3926,4142,"that your mother fell to her death,"],[4162,4270,"and your father died"],[4326,4470,"because she accidentally"],[4516,4630,"cut the rope."],[4730,4786,"Then"],[4854,4982,"what about my sister?"],[5042,5252,"Serena was jealous of your sister's beauty."],[5286,5344,"She assumed"],[5362,5582,"she had an affair with me,"],[5612,5746,"so she plotted revenge."],[5766,5942,"But Serena told me"],[5970,6186,"your sister drank with clients willingly,"],[6242,6346,"and that it was just an accident."],[7672,7774,"Evelyn,"],[7860,8030,"I fell for her lies."],[8062,8142,"I deserve to die!"],[9758,9842,"I've wronged you!"],[9880,9956,"Evelyn,"],[10032,10122,"please forgive me!"],[10558,10746,"You made all these choices yourself!"],[10748,11006,"Serena's lies were full of holes,"],[11006,11192,"yet you still chose to believe her!"],[11192,11276,"You have no one to blame but yourself."],[11328,11456,"Don't think that doing all this"],[11456,11568,"will make me forgive you!"],[12526,12638,"It's fine."],[12676,12988,"I owe you this!"]],"44":[[486,716,"Didn't we agree to see a show tonight?"],[732,786,"Let's go."],[786,846,"We'll be late."],[922,1002,"Okay."],[1450,1530,"Evelyn,"],[2744,2922,"why did you choose this restaurant?"],[2974,3182,"I heard you have to book a month in advance."],[3242,3494,"let alone booking the whole place."],[3540,3682,"Last time, you said you wanted to visit"],[3682,3900,"the places your parents had always wanted to go."],[3972,4078,"That reminded me of how much"],[4140,4224,"my sister wanted to eat"],[4224,4360,"at this restaurant."],[4396,4468,"Unfortunately,"],[4550,4646,"we were too poor."],[4716,4794,"A single meal here"],[4868,5020,"would have cost my sister two months' salary."],[5102,5208,"Back then, I made a silent vow"],[5264,5466,"to study hard and succeed,"],[5532,5698,"so I could bring her here."],[5776,5902,"If your sister is watching from heaven"],[5944,6090,"and sees your success,"],[6136,6270,"she must be so proud of you!"],[6386,6560,"Your parents must feel the same way."],[6662,6762,"I'm not like you."],[6926,7000,"If I hadn't been so stupid,"],[7000,7170,"I wouldn't have gotten them killed!"],[7286,7368,"No."],[7412,7508,"It's not your fault."],[7588,7758,"Serena has already been brought to justice."],[7810,7898,"Your parents"],[7930,8162,"would surely want you to move forward!"],[8188,8268,"Let go of the past"],[8292,8372,"and live a good life!"],[8548,8722,"I have let go of the past,"],[8734,9068,"but where do I go from here?"],[9764,9836,"Hello?"],[9836,9900,"Ms. Bennett"],[9900,9972,"Ms. Bennett."],[10058,10108,"Justin?"],[10160,10384,"The snake venom on the whip was too potent,"],[10420,10524,"and Mr. Fletcher wasn't treated in time."],[10524,10726,"He has suffered severe nerve damage."],[10764,10886,"He is paralyzed now."],[10886,10966,"He's bedridden,"],[11008,11166,"unable to take care of himself."],[11226,11334,"What does that have to do with me?"]],"45":[[88,145,"Ms. Bennett,"],[158,271,"for the sake of the marriage"],[278,450,"you and Mr. Fletcher once shared,"],[477,627,"please, just come see him once!"],[672,792,"I've told you,"],[832,995,"we have nothing to do with each other."],[1042,1212,"If you really hate Mr. Fletcher that much,"],[1226,1443,"then could you do it for my sake,"],[1446,1526,"and just go see him?"],[1556,1666,"Over the years,"],[1676,1848,"Justin has helped me many times."],[1853,1951,"When my parents were sick"],[1960,2102,"and Adrian was by Serena's side,"],[2102,2162,"unable to return,"],[2223,2333,"it was Justin"],[2354,2517,"who drove them to the hospital late at night."],[2559,2709,"I really do owe him."],[2962,3096,"Fine."],[3133,3296,"But this is the last time."],[4657,4778,"Ms. Bennett,"],[4931,5088,"you feel sorry for Mr. Fletcher, don't you?"],[5158,5281,"He's just an accomplice."],[5303,5427,"He's not worth my pity."],[5457,5553,"Justin,"],[5587,5750,"I've fulfilled my promise to you"],[5784,5894,"by coming to see him."],[5957,6074,"Now I should go."],[6571,6651,"Justin."],[6711,6828,"How could you do this too?"],[6883,6961,"Ms. Bennett,"],[7048,7132,"I'm sorry."],[7312,7415,"Mr. Fletcher has done so much for me,"],[7489,7595,"I have to help him!"],[7696,7776,"But rest assured,"],[7902,8079,"if Mr. Fletcher tries to harm you,"],[8159,8309,"I won't let him."],[8410,8516,"He"],[8533,8755,"just wants you to stay here for a while."],[9449,9549,"What?"],[9566,9743,"Serena killed my parents."],[9746,9856,"Is that not enough?"],[9879,10001,"Do you want to kill me, too?"],[10015,10150,"How could you think that, Evelyn?"],[10173,10321,"I love you more than anything!"],[10722,10822,"This is"],[10829,10962,"bone marrow extraction equipment."],[10962,11089,"Is he planning to…"]],"46":[[176,283,"Are you out of your mind, Adrian?"],[335,422,"Your bone marrow isn't a match"],[422,512,"for your son."],[528,647,"Why would you extract it?"],[732,852,"Evelyn,"],[872,1099,"this marrow isn't for Andy."],[1132,1259,"It's for you."],[1296,1413,"I told you before,"],[1473,1573,"that I owe you,"],[1636,1853,"and I'll repay you for everything"],[1913,2020,"to make it up to you."],[2118,2302,"This is completely pointless."],[2505,2612,"Let's begin."],[4366,4446,"Open the door!"],[4536,4646,"Ms. Bennett!"],[4733,4839,"You won't open it?"],[4878,4971,"Then I'll do it myself!"],[5176,5243,"Move!"],[5902,6039,"Evelyn!"],[6039,6142,"What you're doing"],[6162,6289,"is meaningless!"],[6312,6426,"And"],[6463,6616,"you are truly pathetic!"],[7082,7223,"Evelyn!"],[7352,7519,"Evelyn! Evelyn!"],[7847,7966,"Justin,"],[7999,8193,"why did Evelyn leave me?"],[8233,8406,"In the past,"],[8436,8610,"wasn't she the one who couldn't"],[8650,8808,"bear to be apart from me?"],[9824,9983,"Thank you."],[10940,11069,"Once, all of her gentleness"],[11069,11214,"belonged only to me."],[11249,11443,"But now, when I'm dying right in front of her,"],[11464,11643,"she calls me pathetic!"],[11716,11880,"Has she"],[12080,12338,"really left me for good?"],[12369,12542,"Mr. Fletcher,"],[12592,12826,"once certain things are lost,"],[12879,13139,"they can never come back."]],"47":[[142,280,"Judgment will now be delivered."],[280,420,"All rise!"],[662,832,"The court finds that regarding"],[832,952,"the defendant, Serena Summers,"],[952,1144,"and the three murder charges against her,"],[1144,1282,"the facts are clear,"],[1300,1390,"and the evidence is irrefutable."],[1390,1722,"She is sentenced to death,"],[1722,1842,"to be carried out immediately!"],[2350,2466,"Dad,"],[2466,2596,"Mom,"],[2660,2774,"did you see that?"],[2774,3052,"The sky over North District has finally cleared!"],[3052,3270,"I have finally avenged you!"],[3968,4086,"Mom, Dad."],[4122,4210,"The sinner who killed you"],[4210,4360,"has received her retribution."],[4366,4622,"I hope you can finally rest in peace."],[5936,6080,"What are you doing here again?"],[6080,6182,"Get lost!"],[6200,6364,"Evelyn,"],[6380,6598,"can you take me to see your mom and dad?"],[6672,6908,"Do you think you're worthy?"],[7846,7964,"What are you doing?"],[8594,8728,"Evelyn,"],[8786,8866,"I'm sorry."],[8992,9072,"From the very beginning,"],[9166,9400,"I've owed your parents an apology."],[9522,9650,"They don't need your apology."],[9666,9772,"Serena's death sentence"],[9812,9972,"is the best punishment for her!"],[10092,10172,"Evelyn,"],[10332,10450,"is there still a chance for us?"]],"48":[[110,308,"Is there still a chance for us?"],[308,456,"No."],[522,670,"You are the one I love."],[720,954,"Even if I can't be with you,"],[1000,1194,"I will never fall in love with anyone else."],[1242,1358,"During our three years of marriage,"],[1430,1662,"my love for you wasn't entirely fake."],[1726,1934,"I used to hope, just like you,"],[1934,2150,"that we could spend every day together"],[2150,2312,"and grow old side by side."],[2328,2478,"I never treated you"],[2478,2610,"as a substitute for Serena."],[2640,2742,"I really do love you!"],[2874,2946,"Evelyn,"],[3220,3298,"Let's get married!"],[3670,3870,"If only time could have stopped at that moment,"],[3870,3994,"how wonderful that would be!"],[4030,4172,"Evelyn,"],[4248,4368,"if I go to prison,"],[4400,4510,"could you ever forgive me?"],[4574,4714,"I just ask that you don't forget me."],[4778,4918,"I won't."],[4944,5062,"You're right."],[5062,5268,"It's better if you just forget."],[5268,5468,"I've caused you so much pain."],[5468,5658,"Remembering me wouldn't do you any good."],[6018,6194,"Let me say sorry to you one last time."],[6268,6394,"If I could turn back time,"],[6450,6588,"I would love you properly!"],[6638,6770,"If I could turn back time,"],[6836,6968,"Adrian,"],[7034,7230,"I wish I had never met you!"],[8212,8292,"Mr. Fletcher,"],[8316,8476,"where are we heading next?"],[8628,8708,"The police station."],[8888,9078,"It's time for me to pay the price"],[9078,9214,"for my actions."],[9436,9530,"Hello, sir."],[9530,9678,"Do you need any help?"],[9688,9796,"Hello."],[9818,9910,"Officer,"],[9916,10064,"I'm here to turn myself in."],[10130,10322,"Regarding a murder case from the past,"],[10358,10646,"I destroyed evidence to protect the killer."],[10678,10862,"I was an accomplice,"],[10896,11044,"and I deserve to be punished."]],"49":[[263,320,"Adrian,"],[358,480,"you're being released today."],[562,722,"Here are the personal effects you stored."],[749,835,"They are returned to you now."],[905,959,"Thank you."],[1369,1458,"Just a ring?"],[1491,1646,"Weren't you the boss of a big company?"],[1776,1878,"Before I came here,"],[1931,2048,"I sold off my company."],[2072,2153,"I donated all the proceeds"],[2190,2377,"to a disability foundation."],[2455,2582,"After losing Evelyn,"],[2615,2696,"I finally realized"],[2722,2909,"that vast wealth is meaningless."],[2996,3099,"You've rehabilitated well."],[3138,3258,"Don't look back once you leave."],[3400,3501,"Go live an honest life!"],[3688,3768,"Thank you."],[3808,3890,"After all this time,"],[3948,4139,"you're the only one who remembers me."],[4167,4244,"Mr. Fletcher,"],[4339,4411,"if you hadn't"],[4459,4597,"sponsored my education,"],[4642,4753,"I wouldn't be where I am today."],[4818,4896,"I've never forgotten that."],[5213,5286,"What about Evelyn?"],[5338,5428,"How is she doing?"],[5447,5562,"Ms. Bennett is doing well."],[5700,5780,"She"],[5930,6046,"has gotten married."],[6109,6316,"Marian opened a housekeeping agency for her,"],[6383,6486,"and business is booming."],[6588,6750,"She dated Nathan for over a year"],[6871,6963,"before they got married."],[7025,7183,"I saw Ms. Bennett a while ago."],[7258,7394,"She is pregnant."],[7440,7515,"Judging by the size of her bump,"],[7599,7707,"she is already in her third trimester."],[7749,7829,"Is that so?"],[7919,7991,"That's good."],[8174,8218,"Mr. Fletcher,"],[8279,8346,"look."],[8381,8498,"Isn't that Ms. Bennett over there?"],[9734,9866,"It is definitely a girl."],[9879,9918,"Really?"],[9953,10075,"That's not what you said just now!"],[10208,10435,"Boy or girl, the baby will be beautiful!"],[10455,10503,"You're right."],[10865,10914,"Let's go."],[11446,11493,"Mr. Fletcher,"],[11551,11706,"aren't you going to say hello to Ms. Bennett?"],[11811,11863,"No."],[11966,12095,"Seeing how happy she is now,"],[12170,12310,"why should I go and disturb her?"],[12474,12545,"I owe her more"],[12670,12797,"than I can repay in a lifetime."],[12861,12999,"Just let the six years she loved me"],[13229,13368,"be a memory for me alone."],[13875,13947,"Evelyn,"],[14220,14369,"let's get married."],[14848,15050,"I hope that in the next life,"],[15050,15205,"I can meet that girl"],[15205,15340,"named Evelyn."],[15340,15433,"And this time,"],[15433,15769,"I will cherish her like I should have."]]}