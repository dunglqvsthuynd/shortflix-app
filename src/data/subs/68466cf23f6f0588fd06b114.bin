{"1":[[136,230,"Breaking news."],[230,353,"Tonight, downtown erupted in"],[353,423,"gang violence,"],[423,570,"leaving multiple casualties."],[600,767,"Police are pursuing suspects."],[767,874,"We strongly advise citizens"],[874,964,"to avoid the area."],[1004,1154,"Police are currently investigating"],[1154,1211,"this gang war."],[1314,1491,"We'll keep you updated right here"],[1491,1578,"on Flex News."],[1634,1691,"Hi."],[1728,1835,"My name is Tessa."],[1855,2032,"I'm going to take care of you today, alright?"],[2065,2232,"Let's see what we've got going on here."],[2298,2529,"That is a nasty cut."],[2529,2706,"Now, I'm sorry. I'm sure that really stings."],[4267,4407,"Sir, you're bleeding."],[4494,4647,"Help! I need some help over here."],[4801,4914,"He's losing a lot of blood."],[4914,5075,"Yes, we should put pressure on the wounds."],[5542,5735,"Aren't you afraid I might be dangerous?"],[5735,5889,"I leave the criminals to the cops."],[5889,6049,"But if you bleed out during my shift,"],[6049,6202,"then it's my responsibility."],[7831,7894,"Search."],[8228,8478,"Don't tell me you cross Victor Norton and his gang."],[8531,8631,"What?"],[8698,8825,"You know him?"],[8845,8938,"He's infamous,"],[9009,9095,"the Grim Reaper himself."],[9095,9195,"Everyone knows him."],[9265,9496,"He’s powerful"],[9496,9746,"and he’s utterly merciless."],[9853,10110,"If you did cross him, I think you got pretty lucky."],[11711,11811,"What are you doing?"]],"2":[[210,330,"What, what are you doing?"],[1061,1131,"No."],[1174,1241,"Wait."],[1264,1351,"Sir!"],[1448,1591,"The traitor got away."],[1591,1685,"I'm sorry,"],[1725,1805,"Mr. Norton."],[2268,2422,"You're Victor Norton?"],[2422,2679,"Yeah. The notorious Victor Norton."],[2679,2849,"I imagined Victor would look menacing,"],[2849,2926,"not gorgeous."],[2926,3116,"But he's a mobster who kills anyone"],[3116,3226,"that gets in his way."],[3246,3546,"Scared?"],[3570,3867,"Hey!"],[4007,4204,"What's your name?"],[4204,4471,"Why should I tell you?"],[4471,4657,"So, I would know"],[4711,4944,"the name of my future wife."],[5352,5485,"Asshole."],[5742,5895,"24 hours."],[5895,6059,"Find out who she is."],[6059,6286,"Sir, you got plenty women on speed dial."],[6286,6466,"Why fixate on this nurse?"],[6509,6586,"Well,"],[6663,6796,"I don’t know."],[6923,7043,"Something special about it."]],"3":[[804,1031,"I got you some food."],[1031,1144,"I see."],[1144,1301,"You look like you're running on fumes."],[1301,1431,"What's up?"],[1431,1631,"Well, my boss still didn't approve"],[1631,1761,"my position at work,"],[1761,2028,"so I'm still on probation."],[2028,2162,"Sorry."],[2635,2792,"I mean, Tessa."],[2792,3046,"I've been in the red for years now."],[3046,3226,"And seriously, without you,"],[3226,3366,"I don't think I could have survived."],[3366,3510,"And that fact alone just"],[3510,3600,"makes me feel guilty."],[3600,3970,"Hey, hey. Don't start beating yourself up,"],[3970,4074,"okay?"],[4074,4224,"You got this."],[4224,4307,"I believe in you."],[4307,4431,"I love you."],[4531,4681,"I love you too."],[4921,5111,"Well. Guess this just means"],[5111,5231,"I have to hustle harder."],[5231,5532,"And I promise, that one day,"],[5532,5729,"I will give you the life you deserve."],[5729,5872,"And that dream wedding you deserve too."],[5942,5992,"Deal?"],[6042,6142,"Yeah."],[7684,7884,"Boss, the traitor's been caught."],[7884,8034,"Green family plant."],[8034,8184,"Just as we suspected."],[8184,8284,"Orders?"],[8284,8385,"Get rid of him."],[8385,8525,"Oh, and um,"],[8525,8738,"here's what we found on that nurse."],[9379,9576,"Cancel all of our plans tomorrow."],[9576,9736,"Hitting back at the Greens?"],[9736,9766,"No."],[9816,9969,"No. I have more pressing matters."],[10560,10707,"Hey, you're doing great."],[10707,10924,"It's okay. We're almost done here."],[11601,11775,"Damn, he's fine."],[11868,11995,"Right?"],[11995,12185,"Straight out of Hollywood."],[12382,12519,"Miss Bray!"],[12582,12732,"What a coincidence."]],"4":[[36,403,"Miss Bray, what a coincidence."],[533,734,"Looks like you're healing up nicely."],[834,1034,"I'm working, you really should leave."],[1234,1434,"Looks painful."],[1434,1751,"Drop this and let's get some dinner, huh?"],[1765,1915,"Have you lost your mind?"],[1915,2135,"I am at work, I am helping patients."],[2195,2335,"You need to stop this nonsense."],[2405,2535,"Yeah, this is a fucking hospital."],[2535,2736,"I'm bleeding here."],[2736,2936,"Right? This is the hospital, get a room."],[2936,3286,"Watch how fast your patient disappears."],[3286,3386,"Neil."],[3386,3586,"Attention all patients."],[3586,3883,"Find a different doctor"],[3983,4184,"and get paid for your troubles."],[4404,4627,"You know, I know Dr. Jones"],[4627,4784,"down the street is pretty good too."],[5208,5271,"Sir!"],[5585,5759,"You know, I just remembered."],[5759,5852,"They got a pretty good clinic"],[5852,5959,"down the street."],[6059,6159,"Thank you."],[6373,6506,"Look at that."],[6559,6750,"No more patients."],[6800,6900,"Shall we?"],[6900,7100,"You are literally insane."],[7100,7210,"You are bribing people"],[7210,7400,"in an emergency room."],[7400,7470,"Hey, yeah, yeah, yeah,"],[7470,7600,"okay, okay, okay, okay, fine."],[7647,7797,"You're right. No dinner."],[7857,7957,"How about shopping,"],[7957,8058,"we'll go a little dancing,"],[8058,8198,"whatever you want, okay?"],[8198,8268,"It's yours."],[8298,8481,"I have a boyfriend."],[8932,9029,"It's irrelevant."]],"5":[[76,186,"I have a boyfriend."],[280,370,"It's irrelevant."],[627,724,"I don't see a ring"],[724,900,"on this beautiful little finger."],[977,1114,"I guess you're still fair game."],[1164,1501,"I swear I will call the cops."],[1521,1604,"I'll dial the number for you."],[1604,1664,"Don't you..."],[2055,2148,"Here's my card."],[2285,2445,"You call me when you get home, okay?"],[2515,2625,"Not a chance."],[2629,2772,"We'll see about that."],[3273,3370,"Bye, Miss Bray."],[4050,4240,"What's going on?"],[4417,4728,"Sis! Look at all this! I mean..."],[4858,4991,"Peter got his promotion, right?"],[5168,5318,"When's the wedding?"],[5552,5642,"Look."],[5642,5779,"Andy, we can't touch these, okay?"],[5779,6016,"These are not from Peter."],[6016,6289,"I'm sorry, I gotta go."],[6289,6419,"Sis, what's the problem? I mean,"],[6419,6680,"after taking care of Peter for five years,"],[6680,6856,"you deserve whatever he wants to"],[6856,6943,"give you."],[6980,7077,"This is the minimum that you get."],[7077,7190,"No, really."],[7190,7293,"Andy, please. No more questions."],[7320,7540,"Okay? Don't touch them."],[7540,7657,"I will explain everything"],[7657,7781,"when I get back, but please."],[7781,7947,"Don't touch them."],[8391,8598,"Tessa, sorry, I'm still on the clock."],[8611,8712,"You alright? What's the emergency?"],[8982,9109,"Can we get married?"],[9109,9179,"Like,"],[9292,9426,"like now?"]],"6":[[0,120,"Can we get married?"],[216,340,"Like now?"],[360,430,"Please."],[430,537,"Look, Tessa,"],[537,707,"we've already talked about this."],[731,944,"Right? Marriage after my promotion."],[944,1034,"I mean, why the hurry now?"],[1108,1218,"I just..."],[1238,1418,"As soon as I get my promotion,"],[1474,1594,"I'll give you the world."],[1595,1662,"Just trust me."],[1712,2012,"I don't need the world."],[2029,2148,"I don't need luxury."],[2148,2302,"I don't need any of that."],[2309,2425,"I just need you"],[2425,2786,"and us together and stable."],[2829,2903,"Well, me too."],[2976,3160,"Babe, you're my life's greatest treasure."],[3233,3347,"I'm serious."],[3347,3517,"I will do everything. Just..."],[3533,3713,"Just, show up this weekend."],[3763,3860,"Please."],[4137,4221,"Alright."],[4221,4344,"Yeah, this weekend."],[4344,4438,"Let's do it!"],[4471,4521,"Yeah?"],[4521,4681,"Yeah, why not."],[4705,4795,"Okay...?"],[6123,6349,"Why are you sneaking off"],[6349,6500,"during work hours?"],[6653,6753,"What's the matter?"],[6753,6900,"Can't go an hour without me?"],[7047,7200,"Off to see your girlfriend?"],[7297,7474,"Word is"],[7474,7701,"she bankrolled your degree."],[7724,7951,"Baby, you know it's nothing like that."],[7951,8201,"You are all I want, Mary."],[8284,8435,"Say it again."],[8435,8732,"You are all I want."]],"7":[[533,657,"Oh yeah."],[784,994,"This designer stuff will fetch a pretty penny."],[994,1211,"Frank, Tess has told us not to take those."],[1211,1334,"Get out of here."],[1334,1424,"No, you can't take them."],[1424,1581,"I said get out of here."],[1621,1681,"Oh my god."],[1798,1831,"Andy."],[1955,2015,"Are you okay?"],[2218,2385,"What is wrong with you?"],[2509,2605,"I am your father"],[2605,2739,"and everything that"],[2739,2916,"belongs to you belongs to me."],[2916,3186,"Our real father is dead."],[3186,3383,"A stepfather is just as good as a father."],[3476,3650,"Besides, when your worthless mother"],[3650,3913,"died, I housed and fed the both of you."],[3923,4020,"This will pay that debt."],[4030,4297,"You have not given us a single cent."],[4317,4467,"You stole Andy's transplant"],[4467,4567,"fund for his heart."],[4581,4758,"You took everything."],[4804,4971,"We owe you nothing."],[4978,5008,"Enough!"],[5098,5405,"I'm selling this stuff no matter what you say."],[5462,5635,"Well, you can't do that"],[5635,5749,"because it was given on accident."],[5749,5925,"It has to be returned or"],[5925,6046,"it's going to be jail time for you."],[6069,6189,"But hey, that's your call."],[6546,6690,"Worthless junk."],[6690,6836,"You know, you've been giving yourself"],[6836,7143,"to Peter for years like a cheap whore."],[7143,7257,"You know what?"],[7257,7364,"I'm gonna take you down to"],[7364,7520,"Steve at the Nightshade Club."],[7520,7650,"If he likes you, he'll give us"],[7650,7794,"a hundred thousand dollars."],[7794,7921,"I'm even splitting."],[7921,7971,"No!"],[8064,8171,"Because Peter and I"],[8171,8355,"are getting engaged this weekend."],[8401,8478,"What?"]],"8":[[2118,2228,"Where's Peter?"],[2282,2379,"Did he forget?"],[2392,2495,"Seriously,"],[2495,2749,"poor Tessa's still standing there."],[3670,3713,"Hey, Mary."],[3780,3843,"Peter,"],[3843,4134,"join me at a business reception. Now."],[4217,4317,"You know, I wish I could,"],[4317,4574,"but I got this thing I gotta attend to, so..."],[4574,4894,"What? This isn't about your girlfriend,"],[4894,4984,"is it?"],[4984,5278,"No, no, baby. No, look, I told you."],[5278,5515,"You're the only one I care about."],[5532,5792,"Dad and every business titan in town"],[5792,5865,"will be there."],[5902,6016,"Career-making opportunity."],[6016,6282,"Address is in your text."],[6282,6483,"Your choice."],[7454,7677,"Peter obviously bailed."],[7677,8024,"Is Tessa still holding out for hope?"],[8024,8148,"He's just running late."],[8274,8351,"He'll be here."],[8878,9112,"Boss, I'm sorry to disturb you,"],[9112,9212,"but Miss Bray's having"],[9212,9446,"an engagement party at the Hilltop Hotel."],[9469,9512,"Really?"],[9649,9926,"Neil, get our boys."],[10003,10140,"We're going to crash a party."],[11021,11147,"Let's go see who has the guts"],[11241,11324,"to marry my woman."]],"9":[[617,1017,"Mary! Mary, wait up! Sorry I'm late."],[1017,1217,"You made the right choice."],[1217,1418,"Indeed I did."],[1795,2142,"Peter's clearly not showing up."],[2609,2699,"If you would have stayed"],[2699,2879,"with Steven, like I said,"],[2879,3029,"you wouldn't be humiliated."],[3029,3269,"He's gonna show. I know it."],[3306,3520,"Alright, that's it. We're out of here."],[3520,3770,"Hold on, hold on. The groom's on his way."],[3770,3870,"Wait, what?"],[3870,4070,"I know where he is. Come on."],[4254,4354,"Come on."],[4497,4581,"Right this way. He's up here."],[4581,4764,"He was just very nervous."],[4764,4974,"He's embarrassed about not being here"],[4974,5165,"on time. He's right in here."],[5165,5465,"You know how he gets."],[5465,5662,"Come on. Then you go."],[5779,5869,"Peter?"],[6339,6463,"Tessa, give it up!"],[6503,6706,"Frank, come on. Let me out!"]],"10":[[283,347,"Frank, come on."],[347,503,"You can't just trap me in here like this."],[580,690,"Frank, open the door."],[1121,1257,"Worth every penny."],[1481,1654,"Frank,you open this door right now!"],[1654,1845,"Please,come on. Open the door."],[1881,1971,"You are set for life,"],[1971,2075,"and don't you forget who made"],[2075,2145,"this happen."],[2168,2402,"Stephen is set up with the Norton family,"],[2402,2645,"and you will be living so high,"],[2645,2842,"you can't wait to thank me."],[3089,3263,"Easy, easy, gorgeous."],[3340,3526,"I'm going to make you feel really good."],[3803,3870,"No!"],[4017,4097,"No!"],[4244,4327,"Get out!"],[4357,4447,"No! Peter!"],[4494,4591,"Peter!"]],"11":[[143,223,"What the..."],[427,527,"Victor."],[527,627,"Touch my woman."],[627,727,"You're a dead man."],[1047,1097,"Get him!"],[1264,1364,"Victor."],[1398,1588,"I swear I didn’t know she was yours."],[1718,1851,"If I'd known,"],[1851,2015,"I never would've touched her."],[2882,2982,"What the hell are you doing?"],[3056,3183,"Do you know who this is?"],[3213,3283,"This is Steven."],[3283,3483,"He runs the Nightshade Club."],[3483,3583,"Nightshade Club?"],[3583,3683,"Uh, heard about it."],[3720,3873,"Owned by the Norton family?"],[3873,3983,"You're damn right!"],[3983,4184,"And you're still touching him?"],[4184,4304,"What are you, suicidal?"]],"12":[[0,76,"Damn right."],[86,216,"And you still touch him?"],[216,330,"What are you, suicidal?"],[643,944,"This is Steven. He works for Victor."],[944,1131,"You touch him and Victor's gonna have"],[1131,1211,"all your heads."],[1541,1865,"Oh, son of a bitch! You hit me!"],[1881,1965,"You got a problem with that?"],[1998,2122,"Steven, he hit me!"],[2145,2268,"Have Victor make this right!"],[2272,2328,"Shut up!"],[2389,2609,"Victor, I swear, it was his fault."],[2609,2769,"He said Tessa was fair game."],[2769,2852,"He said a hundred grand"],[2852,2972,"would buy her off."],[3019,3093,"Wait a minute."],[3236,3326,"You're Victor?"],[3326,3426,"You fool."],[3426,3526,"Screwed us both!"],[3663,3727,"Boss."],[3807,3927,"What are your orders?"],[3993,4054,"Bye."],[4124,4270,"Victor!"],[4270,4364,"Have mercy!"],[4484,4564,"Hey."],[4624,4724,"Don't worry."],[4798,4924,"I'm not your enemy."]],"13":[[1564,1715,"What is going on?"],[1715,1875,"Talk about extra."],[5468,5568,"Tessa,"],[5672,5852,"say yes"],[5852,5959,"and you and your brother never"],[5959,6096,"have to worry ever again."],[6413,6516,"Tessa,"],[6546,6693,"say yes dear."],[6693,6803,"Marying Victor will be"],[6803,6960,"the luckiest day of your life."],[6960,7100,"Consider it done."],[7100,7197,"I didn't ask for your input."],[7303,7437,"I'm her father."],[7437,7644,"I'm responsible for these decisions."],[7644,7761,"You sell your daughter for"],[7761,7837,"some pocket change"],[7837,7894,"and you dare call you..."],[7894,8081,"No."],[8081,8171,"You got it all wrong."],[8171,8318,"This is my daughter, and I hate..."],[8431,8511,"What are you doing?"],[8511,8755,"Hey, get off me. Get off me."],[8798,8922,"Tessa,"],[8922,9059,"it's your decision."],[9059,9232,"But just know I will give everything"],[9232,9369,"to protect you."]],"14":[[40,233,"Tessa, say yes."],[583,827,"Thank you so much for helping me."],[874,1104,"Gratitude is not love."],[1247,1341,"But I'm going to find a way"],[1341,1461,"to repay you someday."],[1651,1938,"Someday is not going to work for me."],[2125,2225,"I prefer now."],[2225,2262,"What?"],[2275,2422,"Whoa, hey, what are you..."],[2422,2519,"Put me down."],[2535,2602,"Crazy?"],[2625,2722,"Oh, my God."],[3079,3173,"I just saved you."],[3219,3333,"What's that worth to you?"],[3490,3670,"Do you want money or something?"],[3670,3833,"I mean, you could have my savings."],[3833,3957,"Do I look broke to you?"],[4010,4134,"Money's all I have to offer you."],[4861,4981,"You know what I want."],[5251,5545,"You could have any girl. Why me?"],[5545,5992,"Well, you see, men, they love to chase."],[6109,6272,"You give in too easily,"],[6573,6723,"and then the game is over."],[8068,8211,"Are you happy now?"]],"15":[[103,233,"Are you happy now?"],[740,877,"What do you actually want?"],[1121,1224,"One day."],[1368,1528,"You spend the day with me."],[1634,1808,"And we're even."],[2799,2972,"It's fancy, right?"],[3143,3279,"Shit,"],[3279,3430,"just look around real quick."],[3430,3636,"I got a quick call. I'll be right back."],[3723,3967,"Let's see what we can find for you here."],[4187,4454,"This would be perfect for you."],[4454,4571,"Care to try it?"],[4674,4874,"Sure. Thank you."],[5385,5485,"Stunning."],[5515,5705,"Like it was made for you."],[5855,6082,"And it's only $8,000."],[6082,6189,"Cash or credit?"],[6282,6453,"It's beautiful."],[6453,6720,"I just, I don't know if it's for me."],[6720,6873,"You can't afford it."],[6873,7033,"Why are you wasting my time"],[7033,7173,"trying things on then?"],[7193,7323,"I'll just take it off."],[7323,7600,"No way. No, no. You try it, you buy it."],[7600,7650,"That's extortion."],[7650,7751,"That's extortion."],[7751,7851,"And your point is?"],[7851,7951,"Oh my god."],[7951,8021,"Oh!"],[8271,8461,"You ruined it!"],[8461,8605,"You must pay for it."]],"16":[[36,86,"Oh!"],[160,387,"You ruined it!"],[387,537,"You must pay for it."],[537,707,"Yeah, I'll cover it, alright?"],[707,777,"Are you okay?"],[830,1131,"It's a limited piece. It's very costly."],[1131,1217,"Oh, is that right?"],[1408,1621,"What? What is this?"],[1661,1815,"Is this..."],[1815,2008,"a sufficient amount for your dress?"],[2055,2142,"It's plenty."],[2142,2222,"Oh, that's good."],[2222,2365,"It's more than enough."],[2365,2509,"Lovely, lovely."],[2509,2736,"And the rest will probably cover"],[2736,2889,"the other damages."],[3146,3243,"Gentlemen."],[4744,4971,"Maybe next time"],[4971,5135,"you'll be nicer to your customers."],[5135,5445,"I'm sorry, sir. Never again."],[5638,5795,"Hey."],[5952,6109,"It is late. I need to go home."],[6146,6309,"Excuse me. Thank you."]],"17":[[440,560,"Tessa."],[744,930,"Tessa, I had no choice."],[930,1087,"It's not my fault."],[1087,1241,"It's not your fault?"],[1241,1431,"Okay, then I would love to hear"],[1431,1608,"what excuse you have for ditching"],[1608,1765,"your fiancé at her own"],[1765,1865,"engagement party."],[1865,2058,"My boss dumped an urgent project on me."],[2155,2295,"Look, Tessa,"],[2295,2515,"you know I'm working my ass off"],[2515,2602,"for you, okay?"],[2602,2792,"To give you a better life."],[2792,2932,"Just give me one more chance."],[2932,2986,"Okay, I won't"],[2986,3159,"fuck it up, I promise."],[3386,3606,"Do you remember the day I saved you?"],[3827,4000,"Five years ago, the gang shootout."],[4074,4147,"I didn't think twice"],[4147,4337,"before stepping in to save you."],[6659,6960,"Tessa, that scared me. It really did."],[6960,7140,"But nothing scared me more"],[7200,7350,"than the thought of losing you."],[7411,7541,"Peter."],[7560,7744,"Just one more chance, Tess."],[7744,7857,"It's all I ask."]],"18":[[20,200,"Just one more chance, Tess."],[200,330,"It's all I ask."],[490,613,"Do you know I've literally been killing"],[613,754,"myself this past week?"],[774,934,"No, seriously, I drank so much with"],[934,1047,"one of my clients that I ended up in the"],[1047,1211,"hospital with a stomach ulcer."],[1234,1384,"You were in the hospital?"],[1384,1494,"Why didn't you tell me?"],[1494,1688,"I'm fine now, aren't I?"],[1688,1891,"Although the doctor did say no alcohol"],[1891,1971,"for a while."],[1991,2108,"Yeah, you should probably"],[2108,2202,"listen to your doctor."],[2379,2639,"So I was thinking"],[2729,2862,"if you’re free tomorrow night?"],[2862,3166,"I got reservations at Lillian's for just us."],[3229,3476,"You've got us a reservation at Lillian's ."],[3563,3763,"That's right. I love you."],[4290,4434,"Victor."],[4457,4704,"It’s been ages since I've heard from you."],[4704,4921,"Your daddy's spy's not reporting back?"],[4958,5045,"Strange."],[5078,5251,"Don't be like that."],[5251,5432,"I'm only worried about you."],[5458,5545,"Worried?"],[5545,5675,"Or spying?"],[5912,6039,"When do you plan to honor"],[6039,6099,"our engagement?"],[6232,6519,"Arrangement? That I never agreed to?"],[6750,6970,"You know, our worlds depend on this."],[6970,7137,"This goes beyond us."],[7160,7247,"Should have Daddy buy you"],[7247,7340,"another groom."],[7387,7504,"Victor!"],[7504,7691,"Why do you hate me so much?"],[7691,7837,"You see, you got me all wrong."],[7891,8078,"Hate requires emotion."],[8128,8248,"I don't feel anything."]],"19":[[513,750,"Hey, I really appreciate this."],[820,954,"I'm glad you're enjoying it."],[1134,1184,"Cheers."],[1331,1401,"Cheers."],[1421,1498,"To us."],[1841,1905,"Pardon."],[1968,2102,"I actually think it looks better."],[2238,2342,"No, Tessa, don't."],[2342,2445,"Excuse me?"],[2505,2689,"I think you just ruined my dress."],[2689,2852,"At least you could do is apologize."],[2886,3043,"Tessa, why don't we calm down?"],[3043,3173,"Look, I'll take care of the dress."],[3173,3273,"Let's not make a scene, okay?"],[3316,3413,"I'm so sorry, sir."],[3413,3490,"Let's get back to our dinner."],[3490,3573,"Are you just gonna let him"],[3573,3670,"harass me like that?"],[3707,3970,"Oh, she's a tough little thing, huh?"],[3970,4070,"Me too."],[4110,4194,"Hey, listen."],[4194,4371,"Why don't we go back to my place, right?"],[4371,4494,"Just my room's right up here."],[4494,4571,"We'll settle up."],[4571,4728,"Dude, I'm standing right here."],[4728,4871,"You really want to be a hero?"],[4871,5071,"That's not what I thought."],[5071,5211,"Listen, calm down."],[5211,5271,"Let's get out of here."],[5271,5402,"Come on, we'll get out of here."],[5488,5572,"Get lost!"],[5572,6172,"That's true, but feisty? Just how I like them."],[6286,6373,"Get off of me!"],[6833,7050,"Neil! Since when did my restaurant"],[7050,7170,"turn into a brothel?"]],"20":[[0,163,"Since when did my restaurant"],[163,323,"turn into a brothel?"],[690,770,"You okay?"],[974,1217,"And just who the fuck do you think you are."],[1818,1971,"Open your eyes, moron."],[1971,2138,"That's Victor Norton."],[2298,2435,"Oh..."],[2435,2709,"I'm sorry, Mr. Norton."],[2709,2856,"I think you owe an apology to"],[2856,2999,"someone else."],[2999,3166,"Yes, of course."],[3166,3319,"I'm very sorry Miss."],[3319,3523,"I didn't know you were Victor Norton's."],[3523,3693,"And and of course I was gonna pay for"],[3693,3810,"the dress. You know, I'll pay for"],[3810,3970,"ten of them. Just leave."],[3970,4170,"What, are you deaf? Get rid of him."],[4561,4691,"Yeah, you better run."],[4821,4968,"Is this your boyfriend?"],[5101,5362,"Yeah, sorry. My name is Peter."],[5412,5542,"Hey Peter."],[6149,6219,"Am I Okay?"],[6366,6633,"What the hell man, what are you doing?"],[6633,6746,"Just introducing myself to your"],[6746,6906,"spineless boyfriend."],[6906,7057,"What the fuck is wrong with you?"],[7057,7257,"You’re not better than that drunk asshole."],[7257,7344,"What did you just say to me?"],[7344,7514,"What you are fucking good for anyway."],[7514,7677,"Besides swinging your weight around."],[7677,7817,"You know, there's only one reason why"],[7817,7994,"guys act so big."],[8359,8454,"Good."],[8528,8628,"Tess,"],[8628,8775,"Tessa, I need help."]],"21":[[357,457,"Ow!"],[457,704,"I know it stings, okay?"],[704,1004,"Babe, I know what I'm doing. I promise."],[1004,1221,"So you never felt the need to mention that"],[1221,1431,"you're tied up with Victor?"],[1464,1541,"I don't know."],[1541,1708,"I guess I didn't feel the need to"],[1708,1771,"mention it."],[1771,1901,"It's not like you were gonna do anything"],[1901,1955,"about it."],[1955,2105,"Oh, come on."],[2105,2212,"Are you seriously mad at me"],[2212,2355,"because I didn't do anything back there?"],[2355,2482,"I..."],[2482,2792,"I... I think that maybe things could have"],[2792,2939,"gone a little differently if you'd shown"],[2939,3106,"a little backbone."],[3106,3306,"Some backbone. Okay."],[3370,3466,"Okay, let's say I did"],[3523,3616,"do something back there."],[3650,3807,"Things get escalated and"],[3807,4034,"maybe you get hurt in the mix of things."],[4034,4127,"Maybe I did"],[4127,4371,"everything I did for you, for your safety."],[5035,5238,"Uh, what the hell is this?"],[5402,5705,"Oh, God, what is that?"],[5722,6076,"Boss Mary. Mary, this is your boss."],[6076,6276,"Yeah, no, it's so..."],[6332,6683,"She has been just harassing me"],[6683,6816,"for my entire career"],[6816,6946,"and I've just had to tolerate it."],[6946,7193,"I'm sorry, this happens often?"],[7280,7407,"She's sending you pictures like that"],[7407,7530,"all the time or what?"],[7560,7751,"But it's nothing. I hate it. I don't like..."],[7751,7921,"Why didn't you tell me this?"],[7921,8264,"I just didn't want you to react like this."],[8264,8465,"I tried everything."],[8465,8578,"There's nothing I can do."],[8578,8745,"I mean, she's the chairman's daughter."],[8745,8898,"Look, there's only so much I can do, okay?"],[8898,9122,"I don't want to risk my job over this."],[9229,9406,"Okay, let me tell you what."],[9406,9676,"Next time I see her, I will be sure to set"],[9676,9786,"some boundaries."],[9816,9883,"For your sake."],[9936,9999,"I love you."],[10040,10093,"Tess,"],[10316,10453,"I'll never lie to you."],[11578,11678,"As usual, please."],[11708,11755,"Thank you."],[12178,12225,"Hey, boss."],[12282,12475,"Isn't that Tessa Bray's boyfriend?"],[13079,13209,"Well, well, well."]],"22":[[1171,1291,"Tessa,"],[1291,1431,"Nightshade Club."],[1431,1511,"Now."],[1511,1651,"Actually, I'm on shift,"],[1651,1831,"so that is not happening."],[1898,2058,"Your shift just ended."],[2058,2162,"20 minutes."],[2208,2332,"If you're not here,"],[2405,2579,"I'll come fetch you myself."],[3616,3747,"Hey, how’re you doing?"],[3747,3907,"Look, I'm not interested. Okay."],[4347,4574,"Oh, there you are."],[4574,4701,"What the hell do you want?"],[4761,4861,"How about a kiss?"],[5028,5108,"Victor, come on."],[5108,5301,"Really? I told you, I have a boyfriend."],[5345,5432,"And I love him."],[5432,5598,"Yeah, yeah, I heard you, I heard you."],[5598,5862,"So, um, the question is,"],[5862,6062,"does he love you back?"],[6132,6262,"Of course he loves me."],[6262,6376,"-Oh, you think so? -Yeah."],[6376,6663,"Do me a favor, look right over there."]],"23":[[553,663,"Let's get out of here."],[1111,1161,"Neil."],[2465,2615,"Dude, what the fuck."],[2796,3016,"Tessa, what are you doing here?"],[3153,3269,"Ow! Okay, okay."],[3340,3493,"What the hell was that?"],[3570,3717,"-I can explain. -Explain?"],[3823,4017,"Buddy, you were caught red-handed."],[4077,4317,"No. Look, just hear me out, okay?"],[4317,4517,"It's not what it looks like. I promise."],[4607,4768,"How do you want to deal with this?"],[4768,4864,"Just say the word."],[4864,5051,"I'll deal with him myself."],[5288,5525,"Okay. Let him go."],[6476,6639,"Tess, just hear me out."],[6639,6813,"Yeah, I only met up with her today to"],[6813,6960,"end things with her. Baby, you know I"],[6960,7167,"would never cheat on you, right?"],[7177,7297,"Also sticking your tongue down her"],[7297,7484,"throat, that's how you fucking end things?"],[7484,7674,"But do you still not trust me?"],[7674,7801,"After everything we've been through,"],[7801,7934,"you really think I'm that kind of guy?"],[7934,8188,"I want to trust you, but how can I unsee"],[8188,8294,"what I just saw?"],[8321,8451,"But you're missing the context."],[8451,8551,"What's the fucking context?"],[8551,8685,"The fact that I've given up everything"],[8685,8808,"for you, Tess!"],[8808,8952,"Mary's offered me everything from"],[8952,9082,"marriage to her father's"],[9082,9239,"entire company,"],[9239,9456,"but I gave that all up."],[9522,9602,"You did?"],[9656,9743,"That's right."],[9919,10166,"I cannot believe you still doubt me."],[10306,10553,"You know jealousy is real ugly on you Tess."],[10553,10687,"This relationship is over."]],"24":[[0,163,"This relationship's over."],[266,453,"Wait, Pete, no, wait."],[497,697,"Wait, no, come on, baby, please."],[697,797,"Tess, just drop it."],[797,997,"Pete, listen to me, please."],[997,1197,"I'm so stressed out right now."],[1197,1398,"I'm sorry. I know I'm acting."],[1398,1698,"I love you. I'm sorry."],[1778,2092,"I trust you."],[2135,2292,"All right."],[2315,2589,"You know, maybe I was being too harsh."],[2645,2882,"But hey, no more doubting me."],[3189,3289,"Let me take you home."],[4828,5068,"So, what about our wedding?"],[5125,5368,"Look, Tess, I just think maybe it's best if..."],[5468,5568,"Andy?"],[6336,6496,"What happened? Is he okay?"],[6496,6599,"Call 911 right now."],[6599,6736,"We need to go to a hospital."],[7454,7544,"Dr. Jones,"],[7660,7854,"what's going on with my brother?"],[7854,8051,"Andy's heart is failing."],[8051,8234,"And without an immediate transplant,"],[8268,8378,"he won't make it."],[8405,8498,"The good news is,"],[8498,8678,"we have a donor who has a healthy heart."],[8722,8872,"Okay, okay, great! Then do it."],[8872,8962,"Put him into surgery."],[8962,9115,"The cost, however..."],[9219,9382,"Uh, how much are we talking?"],[9382,9683,"All in, a million dollars, at least."]],"25":[[40,326,"All in a million dollars at least."],[433,577,"I don't have any way to come up with"],[577,657,"that much money."],[657,820,"The insurance isn't gonna cover it."],[820,947,"You can at least come up with"],[947,1134,"a portion so we can hold your spot."],[1197,1441,"I do need an answer by this afternoon."],[1514,1688,"This way the heart doesn't go to"],[1688,1845,"someone else on the waiting list."],[2118,2248,"Thank you, doctor."],[2565,2706,"That money..."],[2706,2886,"That money that I trusted you with"],[2886,3079,"I need you to go to the bank."],[3079,3193,"I need you to get it,"],[3193,3353,"because Andy is all that I have left."],[3393,3530,"The money?"],[3530,3646,"Yeah."],[3670,3740,"Right, yeah."],[3777,3987,"I will go get that right now."],[4004,4110,"Okay, thank you."],[4140,4287,"I think I'm really about to fucking"],[4287,4381,"lose it right now."],[4414,4474,"It'll be fine."],[4527,4561,"Okay?"],[4561,4631,"Andy will get his treatment."],[4741,4838,"I promise."],[4874,5075,"But you stay here."],[5075,5115,"Okay?"],[5115,5215,"Andy needs you."],[5215,5315,"I'll be back soon."],[5342,5442,"Okay."],[7477,7540,"Alright."],[8101,8181,"I should really get that."],[8181,8231,"Aww."],[8431,8481,"Tessa!"],[8481,8645,"Hey Pete, tell me you have the money."],[8712,8762,"Uh..."],[8855,8962,"The money, yeah."],[8962,9035,"No, it's uh..."],[9035,9085,"It's uh..."],[9085,9155,"It's coming."],[9155,9205,"Um..."],[9269,9352,"There's just a..."],[9386,9496,"A bank issue."],[11161,11214,"Get in."]],"26":[[310,407,"Word is,"],[467,577,"your brother Andy needs"],[577,684,"a medical treatment."],[770,850,"A million dollars."],[1094,1177,"I can make that happen."],[1191,1381,"I don't need your help. I can manage."],[1438,1698,"Tessa, the clock is ticking."],[1865,2058,"You willing to bet Andy's life on it?"],[2222,2318,"What's your price?"],[2499,2682,"The way I see it, we got two options."],[2779,2922,"You sign this"],[2976,3303,"and be my mistress until I release you."],[3416,3516,"Or..."],[3833,3943,"you put this on."],[4000,4337,"Be Mrs. Norton for one year."],[5101,5378,"Do you like playing on people's desperation?"],[5562,5712,"It's just business, Tessa."],[5762,5852,"You can say no."],[5909,6079,"It's entirely up to you."],[6139,6266,"But Andy's clock is ticking."],[7430,7624,"I thought the contract was more your style."],[7660,7797,"I'd rather have a deadline than"],[7797,7937,"wait for you to get bored."],[8031,8138,"That's fair."],[8138,8311,"Neil! City Hall!"],[8381,8511,"Let's make this official."],[8511,8665,"No. No, we go to the hospital."],[8665,8815,"Andy needs his operation."],[8965,9289,"Tessa, you're in no position to negotiate."]],"27":[[427,560,"Can we please go to the hospital now?"],[600,647,"Sure."],[790,1014,"But Andy's probably in surgery right now."],[1231,1338,"Wait, what?"],[1338,1534,"Hey, don't you worry, Ms. Bray."],[1534,1711,"Boss is taking care of everything."],[1711,1825,"He even hired the nation's best"],[1825,1918,"heart surgeon."],[2152,2285,"Victor."],[2405,2539,"Thank you."],[2639,2839,"Andy's condition was critical."],[2879,3039,"I didn't want to waste a second."],[3119,3256,"I don't even know what to say."],[3313,3440,"It's the least I can do."],[3486,3690,"Once Andy's fully recovered,"],[3703,3897,"I'm gonna give you a proper wedding."],[4771,4868,"Welcome home, madam."],[4921,4964,"Madam,"],[5041,5195,"boss sent me to select these maids"],[5195,5268,"just for you."],[5352,5438,"Will they suffice?"],[5482,5652,"I don't need maids."],[5685,5805,"Of course you don't."],[5815,5962,"The Victor Norton's wife does."],[5985,6039,"Come on."]],"28":[[647,754,"You sleep already?"],[864,920,"That was fast."],[2218,2292,"Don’t..."],[3186,3309,"What are you doing?"],[3353,3473,"Just being a good husband."],[3503,3680,"That's what being married is all about,"],[3680,3730,"right?"],[4244,4357,"Tessa,"],[4404,4691,"I'm no saint, but forcing women,"],[4768,4854,"it's not my style."],[4934,5145,"And I believe one day"],[5348,5475,"you'll want this too."],[5598,5689,"You'll want me."]],"29":[[663,824,"What the hell are you doing?"],[907,980,"Family, huh?"],[1017,1107,"Three minutes."],[1107,1301,"Get these losers out of my VIP suite."],[1301,1401,"Go on then."],[1548,1708,"Excuse me? Who are you?"],[1708,1865,"This room belongs to me now."],[1945,2225,"But hey, I'm feeling generous."],[2442,2535,"Grab the money."],[2565,2625,"Downgrade to the"],[2625,2736,"working man's hospital."],[2789,2932,"This has nothing to do with money."],[2932,3059,"This is a hospital."],[3059,3213,"There is a process here."],[3213,3383,"And we have the proper documentation"],[3383,3443,"for this room."],[3443,3593,"I am the rules around here."],[3646,3857,"Take the hint and disappear"],[3857,3990,"or I'll make sure both you went up"],[3990,4077,"in the parking lot."],[4104,4144,"Wow."],[4230,4447,"You have some serious audacity."],[4471,4654,"We are not going anywhere."],[4654,4708,"Fine."],[4791,4958,"I'll do it myself."],[5041,5161,"Do not touch me!"]],"30":[[0,153,"Hey! Do not touch me!"],[230,437,"Take it easy big fella, take it easy!"],[623,700,"Are you okay?"],[864,980,"Let me get this straight."],[1027,1161,"You think more money equals"],[1161,1267,"room privileges?"],[1267,1371,"Seriously."],[1371,1548,"Financial pissing contest?"],[1818,1901,"Listen up."],[1958,2075,"The only man I will bow to"],[2135,2228,"is Victor Norton."],[3400,3446,"Neil."],[3900,4000,"Is this enough for you?"],[4361,4501,"This chunk change?"],[4744,4871,"In your dreams."],[5362,5575,"You see there's two things that I hate."],[5675,5905,"Men who terrorize women"],[5905,6189,"and morons who disrespect my wife!"],[6296,6386,"Who the hell are you?"],[6459,6606,"Victor Norton."],[6873,7073,"Mr. Norton, I-"],[7107,7307,"I'm sorry."],[7397,7634,"The apology was for someone else."],[7927,8001,"Mrs. Norton, l’m sorry!"],[8011,8104,"Please, please, l’m sorry!"],[8181,8308,"Forgive me for my blindness."],[8378,8635,"Get him out of my sight. Permanently."]],"31":[[13,110,"Get him out of my sight."],[190,243,"Permanently."],[300,577,"No! No, let me go! I'm sorry! Please!"],[860,954,"Hey."],[1117,1231,"Hey, you okay?"],[1287,1354,"Thank you."],[1368,1414,"Yeah."],[1558,1638,"You're my wife."],[1748,1868,"No matter what happens,"],[1868,1975,"you call me first."],[2092,2135,"Okay?"],[2822,2979,"Put a guard on Andy's door."],[2979,3079,"24-7."],[3143,3256,"This little circus doesn't"],[3256,3370,"get a second act."],[3390,3453,"You got it."],[3646,3697,"Hey."],[3737,3867,"Isn't that Tessa's ex over there?"],[3927,4047,"What the hell is he doing here?"],[4324,4464,"What the fuck man? Get off me!"],[4464,4544,"Well,"],[4591,4647,"Peter."],[4701,4771,"What timing?"],[4791,4911,"You got a little stomach ache?"],[4958,5128,"A little hospital visit?"],[5128,5321,"Or are you here to mess with my wife?"],[5378,5525,"Tess is not your wife."],[5578,5672,"You out of the loop, Peter?"],[5709,5882,"She's wearing my wedding ring."],[5882,6032,"Oh, no that's bullshit."],[6032,6199,"She would never marry you. She loves me."],[6272,6409,"Loves you?"],[6409,6586,"A broke two-timing,"],[6586,6686,"nobody?"],[6743,6813,"Peter,"],[6860,7013,"she's out of your league."],[7197,7267,"No, I don't believe it."],[7267,7380,"Tessa would never."],[7724,7884,"Peter, what are you doing here?"],[7884,8038,"Tessa, thank God you're here."],[8038,8161,"Could you please tell this asshole"],[8161,8254,"that I'm your boyfriend?"]],"32":[[657,784,"What did I do?"],[1374,1481,"She loves me."],[1504,1611,"How about that, Peter?"],[1644,1751,"You believe me now?"],[1751,1908,"This can't be real."],[2012,2098,"You must have threatened her."],[2215,2295,"Didn't you?"],[2649,2872,"My methods are irrelevant."],[2892,3019,"Your betrayal,"],[3019,3059,"fact."],[3063,3169,"Our marriage, fact."],[3169,3440,"My warning, crystal clear."],[3440,3576,"You stay away from my wife."],[3777,3820,"Good."],[4070,4110,"Boss."],[4170,4304,"Riggs isn't letting this go."],[4354,4521,"Two guards on Tessa."],[4574,4721,"If Peter approaches her,"],[4814,4938,"put him on the ground."],[5128,5211,"Understood."],[5702,5765,"So you're back."],[5785,5995,"The old clinic was not very good."],[6059,6166,"Great to have you back."],[6202,6343,"Do you feel like there's been any"],[6343,6569,"more injury to the initial wound?"],[6569,6730,"I think it honestly just got worse."],[7197,7253,"It's alright."],[7347,7394,"He's okay."],[7540,7670,"You know I was just thinking I just"],[7670,7751,"remembered..."],[7807,7951,"my leg is so much better."],[8024,8158,"I was actually my way out."],[8158,8294,"Thank you so much for your help."],[8388,8471,"Great to see you again."],[8471,8548,"I was just on my way out."],[8868,8958,"What are you doing?"],[8982,9279,"Mrs. Norton, what can we do for you?"],[9372,9452,"Leave"],[9512,9689,"right now."],[9689,9759,"Sorry ma'am."],[9809,9893,"Boss's orders,"],[9906,10106,"we don't want to disappoint him."],[10106,10220,"Well I guess I'll just have to give him"],[10220,10330,"a call myself then."],[10417,10560,"Excuse me. Thank you."],[11244,11458,"Victor you call off your men right now."],[11458,11564,"My patients are leaving"],[11564,11658,"and this is a disaster."]],"33":[[140,310,"Calling me at this work hour?"],[347,423,"You must miss me."],[443,670,"Victor, you call off your men right now."],[670,770,"My patients are leaving"],[770,867,"and this is a disaster."],[1171,1311,"They're there for your protection."],[1324,1418,"Protection?"],[1458,1591,"Your idea of protection has people"],[1591,1708,"running out of the ER."],[1758,1875,"Put Neil on the phone."],[2465,2565,"Yeah, boss."],[2679,2779,"Understood."],[3003,3163,"Don't worry, Mrs. Norton."],[3216,3413,"We won't interfere with your duties."],[3446,3513,"Great."],[3613,3713,"Have a nice day."],[3713,3763,"Boys."],[3763,3887,"Pick that up."],[7660,7791,"I don't need you to follow me anymore."],[7834,7881,"Okay?"],[7934,7984,"I’m good."],[8064,8114,"Thank you."],[8415,8475,"Hey."],[8671,8772,"What, are you mad at me?"],[8818,9072,"I only did it because I care about you."],[9115,9229,"I want to make sure you're protected."],[9229,9449,"Protected? No."],[9449,9579,"No, this is possession."],[9579,9779,"This is you needing to put your stamp"],[9779,9939,"on every single thing that you touch."],[9969,10080,"What did you just say to me?"],[10080,10200,"Not once"],[10200,10400,"have you respected my choices."],[10443,10573,"If this were about possession,"],[10573,10680,"you'd be in my bed right now"],[10680,10817,"not treating your patients."],[10857,11077,"Wow, you have some nerve."],[11077,11154,"Okay, okay."],[11307,11508,"I promise, I'll stop."],[11594,11721,"Let me make it up to you."],[11748,11821,"I'll take you to dinner."],[11871,12118,"That's cute, but I have to pass."],[12118,12242,"I have to go get Andy's things"],[12242,12315,"from home."],[12479,12736,"Let me give you a ride. Alright?"],[12959,13029,"Fine."]],"34":[[1368,1411,"Tessa."],[1521,1581,"Hey."],[1751,1798,"How do you feel?"],[1855,1891,"A little better."],[1891,1955,"Yeah?"],[1968,2045,"Did you eat anything?"],[2238,2342,"What's he doing here?"],[2422,2512,"Just checking on you."],[2559,2629,"You hungry?"],[2659,2746,"Neil."],[2889,3169,"It's Luna Fresco's Harvard salad."],[3209,3273,"It's your favorite, right?"],[3466,3553,"How'd you know that?"],[3596,3697,"Tessa told me."],[3740,3823,"No mushrooms."],[3950,4160,"You knew about my mushroom allergy?"],[4250,4544,"Listen, I'll keep this over here."],[4621,4784,"I'll go check with the doctor"],[4784,4954,"on your progress, alright?"],[5432,5672,"Well, Mr. Scary is actually"],[5672,5845,"Mr. Detail-Oriented."],[5862,6009,"He even knew about my allergies."],[6116,6309,"He's just trying to get on your good side."],[6349,6419,"I don't know, if he's working"],[6419,6506,"this hard for me,"],[6546,6710,"it means he really cares about you."],[6710,6940,"Either way, he's miles better than Peter"],[6940,7093,"at Detail-Oriented."],[7227,7273,"Hey,"],[7327,7407,"great news."],[7444,7607,"Doctor said you come along real well."],[7647,7817,"You're gonna make it buddy."],[7954,8008,"Hey,"],[8178,8461,"that dinner invitation..."],[8565,8742,"Is it still open?"],[8998,9225,"Yeah, absolutely."],[9339,9382,"Cool."],[9586,9666,"Shall we?"]],"35":[[0,150,"Well, that was tasty."],[150,390,"Did the foie gras meet your standards?"],[487,577,"I loved it."],[590,760,"Good. Me too."],[820,957,"I thought it was interesting."],[1491,1658,"I need to go to work."],[1658,1875,"Or you don't."],[1875,2042,"Listen, I'll pay you ten times"],[2042,2142,"whatever they're paying you."],[2142,2359,"Just spend more time with me."],[2359,2519,"It's not about the paycheck."],[2542,2822,"Well, maybe it's time for an easier position."],[2822,2946,"The ER is killing you."],[2966,3099,"Well, the head nurse position,"],[3129,3236,"I'm running for it."],[3299,3536,"And I think I got a pretty good shot at it."],[3630,3790,"I just can't slip up now."],[3987,4187,"Okay, you win."],[4267,4527,"Can I give this head nurse a ride?"],[4731,4904,"Yes, you can give me a ride."],[4941,5031,"Come on."],[5672,5812,"They named a new head nurse."],[5842,5935,"Oh, surprise, surprise."],[6009,6079,"Linda?"],[6136,6286,"With her special qualifications."],[6336,6413,"What?"],[6476,6609,"Oh, you're out of the loop."],[6636,6780,"It's already posted."],[7871,7977,"Don't you knock?"],[8061,8231,"You chose Linda for head nurse"],[8231,8438,"and I think that I deserve"],[8438,8565,"an explanation."],[8565,8705,"Hospital administration"],[8705,8808,"made the call."],[8842,9035,"Linda's qualifications are excellent."],[9125,9229,"Excellent?"],[9229,9492,"She almost killed someone"],[9492,9649,"confusing lidocaine with saline."]],"36":[[23,280,"She almost killed someone"],[280,447,"confusing lidocaine with saline."],[607,720,"Mistakes happen."],[737,897,"Growth requires chances."],[947,1291,"Okay, so my flawless three-year record is"],[1291,1501,"going to be sidelined for someone"],[1501,1748,"can't manage routine care just because"],[1748,1848,"her father runs this place?"],[1858,2082,"Tessa, watch the attitude."],[2082,2195,"Get back to work if you know"],[2195,2349,"what's good for you. Or I..."],[2349,2549,"Or what? What, are you gonna fire me?"],[2672,2846,"Glad we understand each other."],[2896,3083,"And remember, your brother,"],[3133,3296,"he's still under our care."],[4671,4941,"Well, well. It isn't Little Miss Perfect Nurse."],[4974,5171,"They say you're too busy playing house"],[5171,5345,"with Victor to focus on your job."],[5805,5879,"What was that?"],[6029,6106,"Truth hurts."],[6106,6239,"While you're busy seducing Victor,"],[6239,6389,"I secured my promotion."],[6389,6479,"I owe you one."],[6509,6713,"Your promotion track is no secret."],[6750,6940,"Clearly Daddy has some serious"],[6940,7107,"influence here. But nursing?"],[7107,7293,"It actually requires competence."],[7293,7547,"Directors change and deans retire and"],[7547,7847,"your protection here,"],[7847,7984,"it's got an expiration date."],[7984,8118,"You're just bitter that"],[8118,8221,"I advanced first."],[8261,8465,"The director has my back so what."],[8465,8615,"Daddy runs this place and"],[8615,8818,"while he's here you're beneath me."],[8818,8952,"Your gangster boyfriend,"],[8978,9055,"temporary amusement"],[9055,9132,"at best."],[9175,9399,"A man in his position collects enemies like"],[9399,9532,"trophies. It's only a matter"],[9532,9615,"of time before you get-"],[9633,9734,"Shut up!"]],"37":[[33,146,"Shut up!"],[200,300,"Victor and I are not"],[300,377,"what you think we are."],[417,580,"And he's twice the person"],[580,700,"that you will ever be."],[700,880,"Defending your gangster boyfriend"],[880,960,"pretty hard there."],[1001,1227,"In love already? Hmm, poor ex,"],[1227,1401,"five years down the drain."],[1401,1551,"One more word and I swear..."],[1551,1701,"Well, what exactly?"],[1785,1901,"Thank goodness you're here."],[1971,2102,"Tessa's been threatening me."],[2165,2352,"It's okay, I got you covered, honey."],[2429,2579,"Tessa, you're done here."],[2692,2846,"Pack up and get out."],[2899,2966,"What?"],[3036,3156,"On what grounds?"],[3193,3343,"For chronic insubordination and"],[3343,3566,"creating a hostile workplace."],[3626,3740,"Guard! Guard!"],[3740,3833,"Wait, wait!"],[3897,4084,"Get in here and clear out all..."],[4290,4404,"What is it? What's wrong?"],[6119,6172,"Victor."],[6513,6680,"You care to repeat who you're firing?"]],"38":[[213,353,"You care to repeat who you're firing?"],[387,453,"What are you doing here?"],[530,653,"I got your back."],[754,887,"Mr. Norton,"],[924,1054,"there seems to be a mistake."],[1084,1221,"Tessa keeps her job."],[1321,1511,"Actually, she's our new"],[1601,1678,"head nurse."],[1748,1855,"That's a good start."],[1891,2052,"Please, have mercy."],[2052,2252,"Mr. Norton, your anger makes sense."],[2282,2352,"Tessa's yours."],[2402,2622,"But surely a man of your importance"],[2622,2779,"wouldn't be serious about some nurse."],[2826,2906,"Is that so?"],[2919,3033,"A woman from her background"],[3033,3133,"could never deserve you."],[3229,3360,"My father runs this place."],[3486,3626,"I'm your perfect match so..."],[3687,3773,"say the word"],[3813,3953,"and I'll show you what real satisfaction"],[3953,4150,"feels like, unlike that tramp."],[4190,4307,"Get your hands off him."],[4334,4511,"You whore getting in my way."],[4701,4821,"I respect women"],[4894,4968,"usually,"],[5031,5245,"but not when they threaten my wife."],[5422,5488,"Neil,"],[5515,5598,"get rid of them."],[5712,5765,"Don’t."],[5765,5815,"Stop."]],"39":[[0,60,"Don’t."],[60,126,"Stop!"],[894,1064,"Daddy, they're attacking me."],[1094,1207,"Shut up, Linda."],[1327,1458,"Daddy, why?"],[1521,1735,"Mr. Norton, forgive her foolishness."],[1785,1968,"I'll fire her right now."],[2022,2092,"I only ask you spare her a life."],[2092,2215,"I only ask you spare her a life."],[2292,2492,"Tessa, it's your call."],[2832,2986,"Look, I never seduced anyone."],[3089,3176,"You slandered me,"],[3176,3313,"and I would like an apology."],[3346,3413,"No way!"],[3466,3593,"We're legally married."],[3630,3827,"It's not seduction if it's your wife."],[3877,4010,"Married? Daddy!"],[4030,4154,"Apologize now."],[4351,4601,"I apologize. Sorry, Tessa."],[4684,4971,"And I'm also firing this useless director."],[4988,5125,"Wait, wait, wait, what?"],[5125,5452,"And I'm also making Tessa head nurse."],[5565,5652,"Thank you."],[5839,5965,"Great, let's go."],[6136,6229,"You notice that?"],[6282,6479,"My wife is too kind for her own good."],[6529,6613,"Your luck day."],[7127,7267,"Hey, hey."],[7520,7634,"It's a rough day,"],[7634,7731,"wasn't it?"],[7997,8111,"Let's get you changed."],[8194,8371,"I'll take you somewhere nice."],[9989,10130,"Victor this..."],[10160,10350,"This was planned as"],[10350,10503,"a surprise."],[10617,10864,"But now is comfort for my wife's nerves."],[10974,11084,"I swear to you."],[11121,11491,"I will never let anyone hurt you ever again."]],"40":[[503,597,"Boss."],[717,817,"One second."],[867,937,"What?"],[1441,1524,"Hey,"],[1614,1698,"we've got a situation."],[1755,1855,"Get some rest, okay?"],[1911,2008,"I'll be back."],[2018,2148,"Yeah, wait,"],[2158,2298,"just be careful."],[2312,2422,"Are you worried about me?"],[2432,2539,"No."],[2629,2762,"If you get hurt,"],[2772,2862,"don't expect me to play nurse."],[2929,3106,"You're not a very good liar, are you?"],[3256,3390,"Wait up for me."],[4334,4441,"Hey, Mary."],[4481,4631,"So, do you remember that project"],[4631,4781,"you promised me?"],[4781,4848,"What's the holdup?"],[4848,5135,"Darling, markets shift daily."],[5181,5382,"Some things can’t be forced."],[5382,5482,"No, no, no, no."],[5482,5582,"You promised me specifically."],[5862,5959,"Hello?"],[6216,6366,"I'm listening."],[7607,7637,"Tessa!"],[7691,7764,"Missed you."],[7764,7864,"God, I’ve missed you."],[7941,8064,"What are you doing here?"],[8064,8264,"Well, I thought we should talk, right?"],[8264,8465,"I don't think we have anything to talk about."],[8465,8665,"No, look, I'm sorry."],[8665,8838,"Okay, I tried to get the money,"],[8838,8965,"but the bank had issues."],[8965,9279,"And I was just too ashamed to face you."],[9366,9566,"But I love you."],[9566,9766,"You have to believe me, Tessa."],[9766,9966,"Were you at the bank?"],[9966,10126,"Or were you in Mary's bed?"],[10273,10440,"Well, that's funny."],[10440,10617,"You know, I don't want to hear it."],[10670,10737,"Where are you going, Tessa?"],[10737,10917,"I'm talking to you."],[10917,11097,"Just one more chance, okay?"]],"41":[[1324,1548,"Just one more chance, baby. Okay?"],[1745,1941,"We're done."],[2122,2225,"Tessa."],[2709,2792,"Hey, Peter."],[2832,2886,"You know what day it is."],[3089,3163,"Trash day."],[3286,3406,"Get off me, man."],[5742,5815,"Hey,"],[5865,5975,"Have you been drinking?"],[6046,6156,"Look who's still awake,"],[6266,6456,"expecting company?"],[6549,6666,"Peter?"],[6680,6973,"You're drunk. Asshole."],[6973,7250,"I saw you two outside of the hospital"],[7250,7430,"just holding each other."],[7430,7630,"What are you even talking about?"],[7717,7917,"Okay, no, no,"],[7917,8021,"that's not what was happening."],[8021,8131,"It was an accident!"],[8131,8284,"Accident, my ass."],[8298,8495,"You don't trust me? I'm your wife."],[8538,8638,"That's right."],[8638,8965,"Why don't you start acting like one?"],[8965,9085,"What are you doing?"],[9085,9152,"Stop."],[9152,9299,"Get off of me. Stop."],[9949,10040,"Tessa,"],[10106,10216,"I'm sorry, I..."],[10216,10350,"Get the fuck out."],[10417,10633,"Tessa, I'm sorry."],[10633,10754,"I don't know what just came over me."],[10754,10877,"Get the fuck out."]],"42":[[1478,1818,"Well, well. The great Victor Norton"],[1818,2078,"drowning his sorrows all by himself."],[2078,2225,"Fuck off."],[2425,2625,"What the fuck is that?"],[2632,2786,"Wedding band? That's new."],[2786,2976,"That's none of your concern, all right? Just-"],[2976,3163,"What you think you're better than us."],[3183,3343,"You can't get away from me."],[3343,3560,"That little bitch nurse"],[3560,3803,"and her sick brother are gonna"],[3803,3943,"see right through you."],[4184,4310,"You touch what's mine,"],[4310,4531,"you know how it is."],[4901,5131,"No one humiliates the Greens."],[5151,5338,"My father won't stand for it."],[5338,5752,"Oh yeah? Well you tell daddy to back off."],[5805,5922,"Otherwise,"],[5972,6202,"they'll be looking for a new Green heir."],[6496,6740,"Victor, you think you can escape me?"],[6813,7040,"I'm the best thing that's good for you."],[7364,7600,"I want the wife's identity."],[7600,7891,"Every detail. Every secret."],[7891,7981,"On it."],[8034,8104,"Victor,"],[8104,8324,"I'm gonna make you fucking choke"],[8324,8431,"on your threats."]],"43":[[633,737,"Mrs. Norton."],[770,987,"These are gifts from Mr. Norton."],[987,1147,"I don't want them."],[1281,1438,"Nothing catching your eye?"],[1571,1788,"So you think that gifts are gonna fix this?"],[1911,1988,"I was trying to..."],[2018,2225,"Trying to throw money?"],[2248,2298,"That's the problem,"],[2298,2419,"trying to throw money at me."],[2419,2589,"Okay."],[2589,2789,"What do you want?"],[2789,2989,"What do I want? I want, uh,"],[2989,3189,"respect. I want trust."],[3189,3390,"I would like some fucking equality."],[3390,3543,"I give you all of these things."],[3543,3646,"No, you don't"],[3646,3833,"because you don't know how to."],[3833,4057,"Because you just look through people."],[4057,4194,"You look right through me."],[4194,4354,"I am making an effort right now."],[4354,4524,"You're too blind to see it."],[4524,4601,"Making an effort to"],[4601,4768,"solve things your way?"],[4768,4994,"That's the problem."],[4994,5151,"Where are you going?"],[5151,5338,"I'm going to work."],[5765,5922,"You must be Tessa."],[6132,6226,"And you are?"],[6226,6426,"Get in, Victor sent me for you."],[6426,6589,"Why didn't he just come himself?"],[6589,6813,"He's freaking out and you're the only one"],[6813,7017,"that can help him, please get in."]],"44":[[437,687,"What the fuck do we have here?"],[734,1047,"What's so special about you?"],[1048,1611,"Why is Victor so obsessed with you?"],[1611,1748,"Who the hell are you?"],[1748,1911,"Why are you doing this?"],[1911,2112,"You're a fucking nobody."],[2112,2312,"You're a fucking nurse."],[2312,2455,"Okay, so did you bring me here"],[2455,2612,"to state the obvious?"],[2612,3013,"I'm gonna warn you one time only."],[3013,3313,"You don't belong in this world."],[3313,3707,"He is so above you."],[3870,3960,"You gutter."],[3997,4087,"Rat."],[4184,4351,"You fucking know who you're dealing with,"],[4351,4484,"bitch."],[4484,4667,"You don't scare me."],[4667,4931,"Well, let's see who's in trouble now."],[6262,6322,"Whoops."],[6393,6536,"My finger slipped."],[6593,6787,"Are you breaking already?"],[6893,7094,"You're so fucking pathetic."],[7094,7350,"And you think you deserve"],[7350,7511,"to be with Victor?"],[7541,7691,"You don't know him."],[7824,8081,"He doesn't need another killer."],[8235,8465,"You fucking defiant bitch!"],[8465,8611,"I thought sharpshooting was"],[8611,8715,"your specialty,"],[8715,8775,"Miss Green."],[8859,9002,"Don't fucking move."]],"45":[[50,270,"You fucking defiant bitch."],[270,417,"I thought sharpshooting was"],[417,520,"your specialty,"],[520,580,"Miss Green."],[580,607,"Miss Green."],[647,747,"Don't move."],[1047,1147,"Let go."],[1378,1494,"Sweetheart,"],[1494,1788,"since Miss Green enjoys games,"],[1858,2118,"well, let's play along."],[2148,2248,"Sorry about this, Miss Green."],[2295,2449,"Now it's our turn."],[2549,2649,"Fresh produce"],[2749,2949,"on it. There you go."],[3049,3099,"Victor,"],[3099,3350,"my father is gonna come after you."],[3350,3450,"We'll see about that."],[3450,3550,"She's going to kill me."],[3550,3747,"Isn't that what you wanted?"],[3857,4007,"Now focus."],[4711,4844,"Send my regards to your father."],[5802,5902,"I'm sorry."],[5985,6082,"I should have protected"],[6082,6186,"you back there."],[6186,6286,"I'm fine."],[6286,6386,"I know what this is."],[6386,6586,"I mean, it's a contract."],[6586,6686,"It's a year."],[6710,6786,"Do you know"],[6786,6983,"why I wanted it to be a year?"],[6983,7113,"Because a year is enough time"],[7113,7283,"for you to get to know me."],[7300,7484,"To see how much I really mean it."],[7524,7724,"I understand business."],[7797,7884,"But love..."],[7957,8084,"I just don't."],[8164,8421,"I want you to show me what you need."],[8478,8571,"I want you to show me"],[8571,8685,"what's important to you."],[8728,8825,"Okay?"],[9509,9591,"Bitch!"],[9969,10183,"You won't have it better than me."]],"46":[[353,570,"What brings you by?"],[640,727,"Seriously? Mary, I've been trying to"],[727,840,"get a hold of you for days."],[840,1041,"Are you like ghosting me or something?"],[1111,1217,"You know what, whatever. Look,"],[1217,1317,"remember that project"],[1317,1441,"you promised me?"],[1441,1551,"I just heard you handed it off."],[1678,1941,"Hey Mary! Come to bed, baby."],[1941,2238,"Go back to bed. I won't be long."],[2238,2439,"Mary, you said I was special."],[2439,2732,"Specially disappointing?"],[2732,3159,"You fuck like a virgin with a manual."],[3196,3249,"By the way,"],[3249,3456,"don't bother coming in tomorrow."],[3456,3740,"You didn't make it past probation."],[3740,3940,"No, no, no, Mary, wait, I just..."],[4694,4764,"One more."],[4764,4894,"No more, man."],[4978,5171,"Oh, come on, man, why me?"],[5171,5425,"I didn't do anything wrong, I'm just..."],[5425,5668,"Let me fucking drink, that's all I have left."],[5889,6159,"Mr. Riggs. Small world."],[6186,6322,"Who the hell are you?"],[6353,6553,"Someone who also hates Tessa."],[6583,6723,"You know she's responsible for"],[6723,6780,"getting you"],[6780,6936,"beat up after the wedding, right?"],[7017,7147,"Fucking whore!"],[7147,7303,"She ruined everything."],[7350,7534,"My hands, my career,"],[7534,7650,"my fucking life!"],[7744,8018,"We should team up. Make those two pay."],[8114,8314,"What do you want me to do?"],[8832,9019,"This is enough to lock Victor up,"],[9119,9179,"forever."],[9245,9466,"How did you get this stuff?"],[9466,9549,"I have a plan."],[9666,9966,"Call her and tell her to come to you."],[10507,10707,"You wanna save Victor?"],[10707,10870,"I have enough evidence to"],[10870,11107,"lock him away for decades."],[11107,11408,"Meet me at the Hyatt Hotel, room 2808."],[11408,11604,"And come alone."],[11755,11898,"What's wrong?"],[11938,12102,"Oh, nothing."],[12102,12285,"Just an emergency at the hospital."],[12365,12452,"So I..."],[12499,12635,"get going."]],"47":[[290,350,"Peter?"],[1661,1915,"Where do you think you're going Tessa?"],[1915,2008,"Hey just breathe,"],[2008,2215,"you'll feel real relaxed in a sec."],[2315,2389,"How do you think"],[2389,2579,"your little gangster hubby"],[2579,2816,"is gonna feel after seeing this?"],[3219,3650,"Peter, you sick bastard! Get off me."],[3957,4184,"Hey, did you track her down?"],[4184,4250,"Where's Tessa?"],[4250,4417,"I'm sorry, we looked everywhere."],[4417,4617,"We got eyes and ears all over her."],[4617,4818,"There's no sign of her anywhere."],[4918,5118,"You're gonna want to see this."],[5188,5365,"Your whore of a wife"],[5365,5618,"is screwing her ex-boyfriend."],[5618,5759,"And they're going at"],[5759,5935,"it like animals as we speak."],[6369,6553,"Victor’s gonna kill you when he finds out."],[6553,6760,"He's not coming for me after seeing this."],[6760,6836,"After he sees this,"],[6836,6970,"he'll be done with you."],[6970,7137,"Don't do this, Peter, don't do this."],[7137,7323,"I love it when you beg for me."],[8291,8405,"Tessa."],[8415,8528,"I’ll kill you."],[9215,9312,"Let's get you out of here."]],"48":[[153,226,"Okay."],[296,370,"Hang on."],[430,603,"I'm gonna get you to a doctor, okay?"],[694,807,"Wait."],[954,1161,"I don’t need a doctor right now, okay?"],[1187,1287,"What?"],[1307,1408,"I just need you."],[2672,2966,"Do you even know what you're doing?"],[2966,3253,"I know exactly what I'm doing."],[5085,5155,"No!"],[5228,5508,"Tessa, his fate is in your hands."],[5542,5752,"Peter, what turned you"],[5752,5882,"into this monster?"],[5882,6069,"What happened to"],[6069,6226,"the guy who saved me?"],[6239,6426,"Save you? Oh Tessa,"],[6426,6583,"I wasn't trying to save you."],[6583,6960,"When I saw you alone and scared,"],[7053,7183,"I knew I had to take my chance."],[7183,7384,"Wait, what did you just say?"],[7417,7660,"Five years ago, that bloodbath,"],[7774,7904,"I saw you in the kill zone."],[7977,8168,"And I ran like hell to save my ass,"],[8168,8385,"but you just so happened to survive."],[8385,8685,"So, when you grabbed my hand,"],[8685,8958,"I knew I had to seize my opportunity."],[8958,9135,"And that's when the fake hero"],[9135,9372,"got his undying loyalty."],[9386,9586,"The Triangle Tower shootout?"],[9686,9783,"How did you know that?"]],"49":[[0,146,"How do you know that?"],[610,910,"You are even lower than I imagined."],[910,1111,"Victor, you got nothing on me."],[1311,1408,"Dump him in the alley."],[2148,2349,"Wait, what happened five years ago?"],[2349,2549,"The Greens versus the Nortons."],[2549,2649,"They ambushed us."],[2816,3033,"Tessa, I'm the one who saved you."],[3957,4057,"Boss!"],[4057,4157,"You okay?"],[4197,4257,"Come on, come on!"],[4307,4357,"You gotta run!"],[4748,4858,"Just stay here."],[4888,4988,"Don't make a sound."],[5088,5285,"Boss, we gotta go come on."],[5618,5695,"It was you."],[5722,5792,"If it wasn't for you"],[5792,5942,"I wouldn't be here right now."],[6006,6079,"Thank you."],[6116,6256,"Saving you,"],[6373,6476,"saved me."],[6826,6940,"What are you doing?"],[6986,7057,"Destiny linked us"],[7057,7180,"before we even knew it."],[8094,8258,"Fate reunited us."],[8361,8598,"I would never let you go this time."],[8932,9122,"I am going to give you a wedding"],[9202,9295,"so the whole world knows"],[9295,9422,"that you are mine."]],"50":[[0,210,"Victor, that son of a bitch!"],[296,423,"He humiliated me"],[470,623,"in front of everyone."],[667,927,"Dad, I want blood."],[1061,1261,"He is a dead man."],[1654,1748,"Boss."],[1748,2038,"Whoa, whoa! What's with all the panic?"],[2038,2138,"Tessa's missing."],[2245,2345,"What?"],[2786,2996,"Paradise Casino. Solo,"],[2996,3353,"or your bride comes home in a box."],[3393,3470,"Call the boys?"],[3470,3520,"No."],[3520,3670,"Boss, that's suicide."],[3670,3793,"Her life is on the line."],[3883,3977,"I can’t risk it."],[4828,5051,"Ah, there he is."],[5051,5185,"The guest of honor."],[5185,5305,"How you doing, Victor?"],[5475,5815,"Jackson, your beef is with me."],[5815,5972,"Why bring her into this?"],[5972,6079,"You see, Victor,"],[6122,6466,"a smart man builds alliances."],[6466,6626,"Oh, our families together,"],[6626,6943,"we could have owned this town."],[6943,7193,"But you, you made the wrong choice."],[7193,7397,"And now it's time to pay."],[7637,7824,"Lay another finger on my wife,"],[7824,7941,"and I will rain hell"],[7941,8188,"down on all you motherfuckers,"],[8258,8441,"even if it's the last thing I do."]],"51":[[23,196,"Even if it's the last thing I do."],[196,397,"Oh, you are so tough."],[397,560,"I like that."],[563,734,"You know what, Victor?"],[810,947,"Out of respect to your father,"],[947,1214,"I am going to make you a deal."],[1277,1341,"One game."],[1428,1561,"If you win, you get"],[1701,1761,"the bride."],[1928,2015,"I win."],[2068,2272,"I get all your territory."],[2519,2615,"How's that sound?"],[2766,2842,"I'll play."],[2946,3079,"But not before my bride"],[3126,3246,"is by my side."],[3486,3626,"No, Dad!"],[3853,3970,"Hey,"],[3970,4080,"you okay?"],[4080,4167,"It's okay now."],[4167,4387,"Okay, Victor, let's get this started."],[4934,5061,"Mr. Green, Mr. Norton."],[5278,5318,"Four."],[5392,5425,"Two."],[5505,5572,"The call is yours, Mr. Green."],[5622,5672,"Hit me."],[5762,5809,"Ten."],[5859,5922,"Mr. Norton."],[6096,6179,"Nine."],[6229,6349,"Hit or stay, Mr. Green."],[6349,6459,"Hit me."],[6576,6656,"Nineteen."],[6656,6840,"Oh, hit me again."],[6863,6953,"Dad."],[7223,7437,"Sweetheart, do the honors."],[7617,7697,"Twenty."],[7717,7967,"Looks like you lost. Ditch the bride."],[8024,8198,"I'm still available."],[8198,8278,"Mr. Norton."],[8752,8835,"Flip it for me."],[8878,8998,"I can’t."],[8998,9235,"Yes, you can. I've lost more before."],[9282,9362,"Come on."]],"52":[[383,533,"Mr. Norton wins."],[533,774,"How is that possible? You cheated!"],[1027,1237,"It's your house. It's your cards,"],[1294,1378,"your dealer."],[1414,1561,"Better luck next time."],[2495,2522,"You think"],[2522,2625,"they’re gonna keep their word?"],[2659,2839,"There's no promises in this business."],[3206,3416,"Jackson we had a deal."],[3566,3747,"I promised you could leave."],[3817,3937,"Never said you'd be breathing."],[4504,4561,"Kill them."],[4614,4637,"Now."],[4701,4771,"Stay back."],[4914,5005,"Remember me?"],[5789,5862,"Watch out!"]],"53":[[33,120,"Watch out!"],[4337,4431,"Go."],[4431,4514,"No."],[5505,5668,"Boss, go out!"],[5979,6052,"Victor."],[7487,7751,"Should anyone object to this union?"],[7971,8101,"Anyone feeling brave?"],[8178,8468,"All right, good. Continue."],[8685,8765,"Jesus."],[9873,9989,"Can I kiss the bride?"],[10046,10503,"I now pronounce you husband and wife."],[10807,10930,"May I?"],[10997,11104,"Yes."]]}