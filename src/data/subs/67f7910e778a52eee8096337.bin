1,"It's only natural."],[6364,6556,"Mia is the perfect match"],[6556,6673,"for Noah Harper."],[6715,6785,"There's not better."],[7349,7428,"Do you really have to"],[7428,7528,"marry Noah Harper?"],[7603,7724,"What about our plans?"],[7724,7803,"Grow up!"],[7828,7953,"Once I marry Noah,"],[7953,8153,"I’ll have everything I've ever wanted."],[8195,8241,"Money,"],[8345,8454,"status,"],[8583,8654,"power."],[8863,8954,"And you."],[9142,9267,"You'll get your cut,"],[9267,9513,"but only if you stay quiet."],[9651,9851,"I'll do what you ask."],[9876,9926,"But don't forget"],[9926,10014,"what you promised me,"],[10014,10076,"Mia."],[10643,10731,"Mia!"],[10731,10890,"You're here."],[11353,11482,"What's going on?"],[12354,12424,"Everyone!"],[12516,12754,"Meet Noah Harper's mistress!"]],"8":[[262,517,"You shameless slut!"],[905,1092,"How dare you!"],[1092,1276,"Did you think your little tricks would"],[1276,1468,"help you climb the social ladder?"],[1764,1843,"What's this?"],[2131,2231,"Mia, Lena!"],[2231,2352,"Got to take a look at this."],[2623,2731,"The Elysium estate?"],[2911,3023,"And the keys?"],[3240,3399,"That place has got to be worth"],[3399,3499,"50 million, easy."],[3912,4062,"Did Noah give you this?"],[4137,4337,"Is this where you've been hiding?"],[4337,4529,"No, it's not like that."],[4583,4713,"That's the first design"],[4713,4888,"Noah did his dream project."],[4888,5100,"I haven't taken anything from him."],[5100,5184,"Funny."],[5309,5401,"Noah has mentioned"],[5401,5513,"the estate to me before,"],[5626,5680,"but he said"],[5680,5855,"it didn't live up to his standards."],[5880,6006,"He never took me there,"],[6006,6131,"and now it makes sense."],[6131,6431,"He was hiding his dirty secret there."],[6435,6635,"Don't let her take this away from you."],[6635,6861,"If she's been living off Noah,"],[6861,7007,"she owes you."],[7007,7057,"I don't want"],[7057,7215,"somebody else's leftovers."],[7265,7403,"But you don't deserve"],[7403,7528,"to have this either."],[