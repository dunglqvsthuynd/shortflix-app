{"1":[[1042,1130,"Answer me!"],[1230,1351,"Are you his mistress?"],[1705,1881,"On my son's engagement day,"],[1881,2106,"his fiancée mistook me for a mistress"],[2106,2252,"and humiliated me"],[2252,2485,"in every possible way."],[5176,5342,"Mom!"],[5342,5459,"It's a huge surprise."],[5689,5801,"I don't think you'll make it."],[5801,5889,"I've been abroad"],[5889,5985,"for two years,"],[5985,6135,"and suddenly you're engaged."],[6135,6322,"I'm not missing your wedding."],[6402,6439,"Noah,"],[6439,6610,"where's my future daughter-in-law?"],[6610,6719,"I can't wait to meet her."],[6719,6823,"Oh, she's just upstairs"],[6823,6902,"getting ready, but I'm..."],[6902,6923,"Here."],[6944,6969,"Come on,"],[6969,7073,"you'll meet her soon enough."],[7073,7236,"Oh, well, I have some gifts."],[7236,7394,"I hope they'll be up to her taste."],[7394,7444,"Mom,"],[7444,7603,"your taste is timeless."],[7603,7799,"Flattery will get you everywhere."],[7845,8024,"I've missed you so much."],[8049,8166,"I've missed you too, mom."],[9217,9342,"My dream comes true."],[9488,9576,"Do I look gorgeous?"],[9576,9701,"- So gorgeous. -So beautiful."],[9701,9805,"You're stunning."],[9805,9926,"I know."],[10047,10164,"Mia, I think you're gonna"],[10164,10239,"want to see this."],[10510,10702,"Unbelievable!"],[10848,10965,"It's our wedding day,"],[10965,11065,"and he's flaunting some woman"],[11065,11207,"like she's the one in this dress."],[11857,11928,"Sorry."],[12141,12228,"Hey..."],[12771,12837,"Mia, cheating?"],[12837,12950,"What are you talking about?"]],"2":[[33,100,"Mia, cheating?"],[100,229,"What are you talking about?"],[229,404,"Don't even try to deny it, Noah."],[442,513,"Your photos are"],[513,671,"all over the tabloids."],[704,746,"Photos?"],[746,804,"What?"],[863,971,"Denying what?"],[1080,1192,"It's our wedding day,"],[1192,1259,"and you're out there"],[1259,1409,"making a fool of me."],[1409,1622,"You better give me an explanation now!"],[1876,1914,"Listen, Mia."],[1914,2043,"I don't know what you're talking about."],[2043,2114,"So, maybe stop"],[2114,2223,"believing every piece of trash"],[2223,2285,"you see online,"],[2285,2314,"and..."],[2631,2665,"Hello?"],[3057,3190,"If I find that bitch,"],[3269,3403,"I am going to kill her."],[4241,4279,"Mia,"],[4358,4446,"just let it go."],[4500,4596,"You know how it is."],[4596,4688,"All wealthy guys"],[4688,4854,"have someone on the side."],[4959,5088,"I've busted my ass"],[5088,5209,"to lock down my place"],[5209,5351,"in the Harper family."],[5351,5559,"No way I'm letting some nobody"],[5559,5634,"steal Noah."],[5805,5905,"Give me that."],[6247,6356,"Noah, what’s wrong?"],[6398,6448,"Um..."],[6448,6598,"Fight with Mia?"],[6619,6652,"You know it's um..."],[6773,6898,"She saw something online."],[6986,7048,"And sort of lost it."],[7048,7086,"But,"],[7169,7223,"maybe now is not"],[7223,7394,"the best time to meet her."],[7394,7540,"Let's get you inside,"],[7540,7720,"get you rested up."],[7720,7816,"Got a big day."],[8287,8395,"Victoria."],[8395,8558,"You're actually marrying"],[8558,8758,"the homeless guy from New York."],[8812,8967,"Oh, sweetheart."],[9017,9175,"This is just beautiful."],[9175,9213,"Hey, it's"],[9213,9413,"not too bad for a couple mil."],[9471,9559,"Let's get you upstairs."],[9559,9597,"Yea."],[9713,9768,"Are you ok?"],[9780,9818,"Yes."],[9859,9947,"Oh my god!"],[9980,10155,"That’s the woman from the tabloids!"],[10218,10335,"Noah’s mistress!"],[10673,10727,"And,"],[10827,10873,"here we are."],[10931,10977,"Thank you."],[12053,12237,"Shameless slut!"],[12237,12362,"Who does she think she is"],[12362,12550,"cozying up to my fiancé?"],[12633,12725,"Girls!"],[12758,12825,"Let's go!"],[12937,13104,"We're putting this so-called mistress"],[13104,13238,"in her place."]],"3":[[200,300,"I'm going to go smooth things out"],[300,358,"with Mia."],[387,462,"Just stay up here,"],[546,646,"relax for a little bit."],[717,771,"And just,"],[842,892,"come downstairs,"],[892,971,"I'll finally introduce you two."],[1042,1213,"You go take care of business."],[1330,1397,"Thanks, mom."],[2444,2635,"I hope Mia sees the love behind"],[2635,2781,"this pearl bracelet."],[2794,2882,"It's been in our family"],[2882,2977,"for generations."],[3065,3165,"And this estate,"],[3165,3361,"the first thing Noah ever designed."],[3432,3561,"He was so proud of it."],[5042,5080,"Look at him,"],[5080,5180,"all smug."],[5276,5363,"I guess she knows how to"],[5363,5492,"keep him happy in bed."],[5559,5755,"This bitch thinks she's going to"],[5755,5880,"steal Noah from me?"],[5918,6101,"Over my dead body."],[6197,6235,"Let’s go."],[7102,7219,"Back so soon?"],[7474,7578,"You slut!"],[7665,7887,"How dare you sleep with my fiancé"],[7887,8003,"on our wedding day?"],[8099,8204,"You think I'm going to"],[8204,8370,"let you humiliate me?"],[8379,8466,"Me!"],[8466,8629,"The future Mrs. Harper."]],"4":[[33,100,"Hold her down."],[154,204,"What?"],[262,375,"What is this all about?"],[375,462,"Who are you people?"],[471,563,"Let go of me!"],[688,1059,"How dare you seduce my fiancé?"],[1071,1222,"Do you know who I am?"],[1222,1518,"I am the future Mrs. Harper."],[1518,1705,"You're messing with the wrong woman."],[2181,2231,"Wait."],[2306,2352,"Mia?"],[2515,2623,"You're Mia?"],[2623,2765,"You know who I am?"],[2919,3048,"You know who I am,"],[3048,3282,"and you still dare to go after my man?"],[3328,3470,"My daughter-in-law thinks"],[3470,3620,"I'm Noah's mistress?"],[3661,3862,"Mia, you've got it all wrong."],[3862,3912,"Wrong?"],[3937,4116,"So, Noah told you my name?"],[4162,4366,"You must feel so special!"],[4387,4437,"Mia,"],[4454,4517,"please listen."],[4579,4633,"Noah and I..."],[4633,4700,"Shut up!"],[4754,4888,"You knew damn well"],[4888,5067,"he was my fiancée."],[5067,5317,"And you still went ahead with this?"],[5367,5555,"You're disgusting."],[6114,6214,"She thought that she could"],[6214,6368,"talk her way out of this."],[6393,6473,"Pathetic."],[6523,6727,"Messing with Noah Harper's fiancée?"],[6760,6931,"She's lucky this is all she's getting."],[6931,7090,"Please, let me just call him."],[7090,7278,"We'll get this all situated."],[7303,7490,"Just listen to me."],[7545,7716,"Texting Noah to save you."],[7857,8028,"You're intentionally"],[8028,8220,"flaunting with him in public."],[8220,8450,"Getting your picture taken by the media."],[8487,8558,"Pictures?"],[8558,8679,"This is all because of"],[8679,8842,"those misleading tabloids."],[8842,8854,"Listen..."],[8854,9025,"Stop acting innocent."],[9025,9138,"You think Noah is just going to"],[9138,9267,"come running to save you?"],[9342,9484,"Well, too bad he's busy"],[9484,9642,"preparing for our wedding."],[9684,9843,"Please, listen."],[9947,10022,"Strip her."],[10243,10372,"I want to see"],[10372,10610,"if she still has one single ounce"],[10610,10760,"of dignity left in her."]],"5":[[421,517,"Get her in there."],[1213,1397,"Let’s wash the filth off you,"],[1397,1472,"shall we?"],[2152,2310,"No, please."],[3603,3657,"Mia,"],[3657,3812,"you got it all wrong!"],[3899,3995,"I'm Noah’s mother!"],[3995,4179,"Your mother in law!"],[4612,4671,"What?"],[4696,4779,"His mother?"],[4813,4967,"My mother-in-law?"]],"6":[[16,125,"You?"],[287,400,"My mother-in-law?"],[400,538,"Don't make me laugh."],[980,1105,"Mia, what if we're wrong?"],[1159,1242,"I mean,"],[1242,1297,"should we double check?"],[1297,1405,"What if she really is?"],[1422,1505,"Seriously?"],[1593,1747,"My fiancé would tell me"],[1747,1893,"if his own mother was coming to"],[1893,1989,"my wedding."],[1989,2097,"He tells me everything."],[2127,2243,"You're full of shit."],[2310,2456,"She's lying through her teeth."],[2519,2598,"Let's make her pay"],[2598,2698,"for messing with you."],[2815,2877,"Hold her down."],[2927,3086,"We're not done with you yet."],[3086,3148,"No!"],[3148,3265,"Get off me!"],[3282,3403,"Get off me!"],[3403,3490,"Stop!"],[3490,3516,"Get off me!"],[3516,3720,"Let's get this on camera."],[3807,3920,"Here, Mia."],[4112,4216,"Smile.