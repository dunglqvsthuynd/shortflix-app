[4871,4988,"Grab that lunatic."],[5017,5134,"She just shot Kiefer!"],[5134,5184,"No!"],[5267,5401,"Lock Nora in the study."],[5442,5547,"Do not let her out"],[5563,5726,"until I find out who killed my child."],[5743,5801,"What?"],[5847,5918,"Kiefer?"],[5935,6101,"Don't make me repeat myself!"],[6193,6252,"Fuck."],[6318,6381,"What?"],[6423,6485,"Ugh!"],[6552,6652,"I am going to look into"],[6652,6777,"everything that you said."],[6806,6923,"No one wants to know the truth"],[6923,6994,"more than I do."],[7019,7090,"You don't care."],[7127,7190,"seven years ago"],[7190,7303,"when I was in the hospital,"],[7390,7503,"losing our baby."],[7503,7582,"Where were you?"],[7645,7803,"Rolling around in bed with Nora."],[8149,8287,"You're not Gen."],[8287,8412,"Fuck, get off, let go."],[8600,8666,"Look at me."],[8767,8958,"I didn't have sex with Nora."],[8996,9109,"That night I was drunk,"],[9146,9280,"and mistook her for you."],[9313,9463,"The second I realized it wasn't you,"],[9463,9563,"I pushed her off me."],[9609,9713,"That's the truth."],[9738,9822,"He didn't?"],[9843,10068,"Did I misunderstand him all this time?"],[10164,10272,"Get rid of Nora for good,"],[10272,10418,"and maybe I'll actually believe you."],[10435,10518,"Try."],[10518,10560,"Come here."],[10560,10610,"Kiefer!"],[11173,11244,"Now sit down."],[11348,11436,"Stay there."],[11528,11728,"Now you are gonna wash up."],[11770,11836,"No."],[11836,11986,"Oh yes you are."],[12137,12287,"Or I'm gonna do it for you."],[12449,12512,"Come here."],[12554,12675,"Don't fucking move."],[13851,13938,"Relax."],[14080,14164,"I can,"],[14255,14339,"I can do"],[14460,14589,"whatever I want"],[14660,14781,"with my wife."],[15298,15402,"Don't touch me."],[15402,15502,"Oh, honey,"],[15553,15682,"save your strength."],[15728,15865,"You're gonna need it."],[15878,15986,"When you're screaming my name"],[15986,16066,"so loud,"],[16095,16328,"you can barely breathe."],[16395,16512,"He is so right."],[16566,16704,"I still crave him."],[1