r, I, I, I,"],[4212,4329,"I didn't mean to hurt you!"],[5092,5176,"All you ever do"],[5176,5296,"is hurt the people I love."],[5309,5405,"Let me go!"],[6060,6122,"Nora,"],[6210,6310,"you killed my child."],[6477,6552,"It is now."],[6673,6752,"It is time"],[6815,6965,"for you to pay the ultimate price."]],"26":[[0,70,"Kiefer!"],[171,279,"We grew up together."],[346,521,"Everything I've ever done,"],[521,675,"it's all been for you."],[700,796,"You can't kill me."],[796,1005,"You should be begging Gen!"],[1117,1184,"Not me."],[1292,1384,"I told you"],[1384,1518,"that I would bring you Nora."],[1630,1747,"You wanna pull the trigger?"],[1839,1947,"Be my guest."],[2473,2523,"Because of you,"],[2523,2677,"I'll never see my baby again."],[2711,2848,"Stop, Genesis."],[2911,3023,"You won't shoot me."],[3082,3165,"You can't!"],[3265,3390,"No, no, no, no, I messed up!"],[3390,3582,"But I, I didn't mean to hurt your baby."],[3607,3728,"Just please don't kill me."],[3732,3824,"Ah!"],[4049,4175,"You're right, I'm not a killer."],[4216,4308,"But there are some things"],[4308,4433,"that are worse than death."],[4508,4642,"Like living in constant,"],[4642,4796,"unrelenting pain."],[4963,5155,"Your family owns a private island right?"],[5388,5472,"Send her there."],[5680,5772,"You heard her."],[5809,5914,"Make sure Nora"],[5976,6135,"never steps foot off that island."],[6135,6177,"Huh?"],[6272,6343,"Don't, Kiefer,"],[6343,6523,"that island is uninhabitable!"],[6602,6756,"I'll die there by myself!"],[6781,6873,"Kiefer!"],[7015,7061,"Kiefer."],[7169,7240,"Kiefer, no!"],[7344,7394,"Kiefer."],[7494,7557,"Kiefer!"],[7645,7724,"Someone help!"]],"27":[[16,125,"The bullet missed your heart"],[125,237,"by a few centimeters."],[287,400,"You're lucky to be alive."],[417,538,"Gosh, it's my fault."],[688,750,"If you hadn't"],[750,850,"protected- - I chose to."],[1017,1226,"Doc, uh, if my Mom asks,"],[1226,1297,"just tell her that"],[1297,1397,"my injuries are minor."],[1418,1472,"Okay?"],[1639,1760,"I don't want her blaming Gen."],[1964,2064,"ls this really the man"],[2064,2218,"I hated for 7 years?"],[2256,2344,"He almost died for me,"],[2344,2548,"but all he's thinking about now"],[2548,2686,"is how to shield me from blame."],[3324,3449,"Gen, I'm yours."],[3482,3641,"You can touch me wherever you want."],[3782,3862,"Still beating."],[3987,4083,"Feel better now?"],[4095,4166,"Kiefer, why did you"],[4166,4275,"take a bullet for me?"],[4329,4462,"This isn't gonna change anything."],[4466,4642,"You're not gonna win my gratitude."],[4696,4746,"Really?"],[4763,4963,"Because your hand on my chest,"],[5109,5288,"and the tears in your eyes"],[5372,5501,"say otherwise."],[5534,5626,"What tears?"],[5693,5739,"I'm not-"],[5739,5872,"Struggle all you want."],[5872,5997,"But it'd be a real shame"],[5997,6168,"if you re-opened my wound."],[6281,6414,"A bullet almost grazed your heart"],[6414,6527,"and you still can't shut your"],[6527,6639,"stupid mouth."],[6639,6865,"Again, your body is being"],[6865,7107,"more honest than your words."],[7203,7294,"And right now,"],[7424,7595,"it's saying that you still love me."],[7720,8020,"It's saying that you are still my wife."]],"28":[[283,417,"My baby."],[525,663,"God, why is forgiving him"],[663,855,"so much easier than hating him?"],[896,1084,"But still I can't forget that nightmare."],[1297,1422,"Don't flatter yourself."],[1480,1601,"Just because you got rid of Nora"],[1601,1755,"doesn't mean anything's changed."],[1755,1856,"But Gen, listen."],[1947,2052,"Now that we both know"],[2052,2177,"the truth about Nora,"],[2177,2248,"why can't we just..."],[2339,2414,"talk?"],[2498,2652,"What is standing between us?"],[2698,2936,"I can't go back to 7 years ago."],[2982,3136,"It wasn't just Nora, okay?"],[3136,3236,"It was everything."],[3236,3324,"It was your mother."],[3445,3553,"It was the way she constantly"],[3553,3616,"put me down and"],[3616,3782,"she made me feel so small."],[3987,4154,"It was you, too, Kiefer."]],"29":[[8,120,"It was the way you lived."],[183,279,"The way you loved."],[383,471,"Always too late."],[621,725,"Always halfway."],[938,1063,"It was you failing me"],[1088,1372,"over and over and over,"],[1372,1559,"and me pretending that it didn't hurt."],[1726,1860,"And the worst part is"],[1981,2164,"that I've spent 7 years"],[2164,2323,"trying to un-love you,"],[2473,2610,"trying to forget you."],[2698,2798,"And I can't."],[3353,3415,"Gen."],[3549,3670,"I am so,"],[3803,3891,"so sorry."],[4108,4279,"I should rot in hell for this."],[4316,4437,"I was so blind,"],[4625,4746,"fucking arrogant."],[4800,4879,"If I were you,"],[4884,4988,"I wouldn't have turned me"],[4988,5071,"into the FBI."],[5071,5267,"I would've just put me out of my misery."],[5363,5426,"Kiefer."],[5543,5709,"Hating you takes strength."],[5818,5989,"And forgiving you takes courage."],[5989,6160,"And I'm running low on both."],[6477,6544,"It's your mother."],[6544,6685,"She, uh, knows you've been shot."],[6685,6810,"But she's heading to the villa."],[6810,6886,"The villa?"],[6931,7094,"I'm in the fucking hospital."],[7173,7311,"There's no one at the villa except-"],[7311,7382,"Egan!"],[7532,7582,"Gen."],[7615,7665,"Gen!"],[7786,7849,"God."]],"30":[[375,496,"Damn bitch!"],[508,629,"She comes back for a second"],[629,792,"and my son almost dies."],[792,1005,"I swear to God, I will drag her"],[1005,1126,"out of this house myself"],[1126,1242,"if that's what it takes."],[1764,1822,"Oh."],[1881,1951,"Hey there."],[2064,2285,"You must be little Egan."],[2356,2460,"Come here, sweetie."],[2460,2598,"Give Grandma a hug."],[2861,2998,"Oh, look at you."],[3078,3249,"Well, how's a scaredy-cat like you"],[3249,3361,"supposed to be the heir"],[3361,3482,"to a mob family?"],[3507,3578,"Lisa."],[3599,3766,"Get your hands off my son!"],[3983,4258,"Mommy, is she really my Grandma?"],[4266,4429,"The one who sent those guys"],[4429,4604,"with the guns after you?"],[4604,4750,"I don't want her here."],[4750,4859,"Don't worry, I've got you."],[4984,5109,"Egan, why don't you go upstairs"],[5109,5192,"for a minute, okay?"],[5201,5276,"Okay."],[5684,5860,"My son is off limits, Lisa."],[5901,5951,"Oh?"],[6001,6214,"Since when do you give me orders,"],[6214,6343,"Genesis?"]],"31":[[8,108,"Let's catch up,"],[154,221,"shall we?"],[429,554,"You come back"],[554,767,"and everything falls apart."],[842,1051,"Kiefer beats Declan half to death,"],[1092,1230,"Nora's locked up,"],[1280,1447,"and you keep screaming"],[1447,1534,"you want out,"],[1543,1735,"but somehow you're glued to his side."],[1780,1997,"He even took a bullet for you."],[2093,2210,"If I wasn't worried that boy"],[2210,2281,"would cut me off,"],[2281,2398,"you'd already be out of this house"],[2398,2494,"on your ass."],[2494,2594,"Don't play dumb."],[2606,2702,"You know very well"],[2727,2848,"that Egan and I got dragged"],[2848,2977,"back into this hellhole."],[3011,3161,"Touch my son again,"],[3236,3345,"and I'll bury you."],[3353,3424,"Oh."],[3474,3782,"I'm not here for war, Genesis."],[3849,3999,"You want out."],[4033,4287,"Help me, and I'll help you."],[4379,4437,"Deal?"],[4521,4600,"What do you mean?"],[4942,5025,"Bring them in."],[6806,6890,"What is this?"],[6936,7115,"Help Kiefer take a new wife,"],[7157,7374,"and I'll help you disappear,"],[7453,7528,"for good."]],"32":[[342,396,"Egan?"],[425,500,"Daddy,"],[500,646,"grandma brought a bunch of ladies"],[646,746,"to scare mommy."],[775,817,"Daddy,"],[817,925,"please come home."],[925,1013,"Don't worry, Egan, okay?"],[1013,1121,"I, I'm on my way."],[1422,1534,"Step on it, alright?"],[1543,1714,"Since when do we stop at red lights?"],[1714,1768,"Jesus!"],[1768,1864,"Boss, you're still bleeding."],[1864,1997,"We should get you back to the hospital."],[1997,2122,"I said drive faster."],[2369,2615,"Since Kiefer's so obsessed with you,"],[2615,2731,"you must know exactly"],[2731,2815,"what he wants."],[2857,2919,"Come on,"],[2919,3086,"help me pick your man's new wife."],[3086,3211,"You want me to choose"],[3274,3453,"a new wife for my own husband?"],[3474,3624,"Well, pick one"],[3624,3903,"and train her to be Kiefer's type."],[3962,4175,"And if she can replace you,"],[4195,4446,"I'll be gracious and let you walk free."],[4896,5038,"No, this is ridiculous."],[5100,5242,"Kiefer's not gonna marry any of them."],[5242,5296,"What?"],[5301,5492,"So your plan is to just keep"],[5492,5609,"hanging on to him,"],[5609,5805,"keep dragging him down?"],[5818,5943,"You know, any one of these women"],[5943,6106,"would make a better wife than you."]],"33":[[0,204,"Genesis, you're selfish."],[233,283,"Vile."],[321,546,"Mediocre at best."],[575,671,"You turn Kiefer"],[671,859,"against his own family."],[913,1026,"But these women here,"],[1059,1176,"they are beautiful"],[1205,1326,"they're refined."],[1397,1551,"And most importantly,"],[1551,1722,"they know their place."],[1735,2031,"That's the kind of wife Kiefer deserves."],[2031,2122,"Refined?"],[2198,2268,"I, I'm sorry,"],[2268,2348,"but that's just not the word"],[2348,2414,"that comes to mind"],[2414,2544,"when I think of someone auditioning"],[2544,2669,"to be someone's mistress."],[2669,2727,"More like"],[2806,2877,"desperate."],[2936,3136,"Wow, someone's defensive."],[3182,3257,"What's wrong?"],[3274,3365,"You scared the second"],[3365,3532,"Mr. O'Reilly sees me,"],[3541,3716,"he's gonna lose interest in you"],[3716,3841,"and realize just how"],[3974,4091,"underwhelming you are?"],[4371,4433,"Watch it."],[4479,4587,"I'll hold back for his mother,"],[4596,4679,"but not for you."],[4725,4921,"How dare you hit my guest!"],[5025,5242,"No, you are not gonna bully me"],[5242,5392,"like you did 7 years ago."],[5392,5459,"Uh!"],[5538,5618,"Genesis,"],[5634,5814,"you should have stayed just as"],[5814,6068,"weak and pitiful as you were then."],[6093,6231,"You think just because"],[6231,6356,"Kiefer's in love with you now"],[6356,6544,"that it's gonna last forever?"]],"34":[[58,129,"Oh."],[166,266,"I know what I'll do."],[312,496,"I will bring these women"],[496,759,"straight to Kiefer myself."],[788,1021,"Let's see how fast he gets bored of you."],[1038,1188,"Oh, he won't last a minute."],[1222,1384,"Have you seen my body?"],[1413,1614,"The second he lays eyes on me,"],[1639,1897,"Mr. O'Reilly is going to be hooked."],[1901,2010,"And once I've got him,"],[2047,2156,"he'll be mine forever."],[2168,2293,"You traitorous bitch."],[2531,2698,"My son's in the hospital"],[2711,2802,"because of you."],[2806,2990,"There couldn't be a better time"],[3007,3211,"for you to pack up and disappear."],[3240,3453,"Now, sign the divorce papers."],[3490,3682,"Pick a wife for Kiefer."],[3703,3820,"And I promise,"],[3862,3991,"I will let you walk free."],[5063,5230,"Gen, after everything,"],[5259,5380,"do you still wanna leave me?"]],"35":[[671,717,"What?"],[1013,1167,"You don't get to decide what happens"],[1167,1317,"between me and Kiefer."],[1384,1639,"You think you can just say no?"],[1651,1847,"The second you come back,"],[1847,2010,"my son gets shot."],[2056,2218,"You're a curse, Genesis."],[2243,2356,"You won't stop till he's in a"],[2356,2456,"damn coffin."],[2456,2556,"Your daughter shot him."],[2631,2811,"And I have tried my best"],[2811,2915,"not to come between you two."],[2915,3036,"But if you don't get these women"],[3036,3153,"out of my sight,"],[3157,3249,"I'll call Kiefer home"],[3249,3411,"and I'll have him drag them out himself."],[3411,3470,"Hey!"],[3486,3653,"No one talks to Mrs. O'Reilly like that."],[3653,3770,"Oh, she thinks she can act"],[3770,3883,"all high and mighty"],[3883,4062,"just because my son's not here."],[4108,4208,"Don't worry, Mrs. O'Reilly."],[4233,4375,"I'll teach this bitch a lesson."],[5380,5568,"Kiefer, you should be in the hospital!"],[5780,5935,"You just smacked my wife."]],"36":[[0,137,"Please, Mr. O'Reilly, please."],[137,312,"I didn't mean to do it, I swear."],[321,433,"Your mother told me to do it."],[492,575,"Please, forgive me."],[633,742,"If you do that again"],[804,934,"I'll cut off your hand."],[1088,1151,"Get out."],[1205,1347,"All of you, get out!"],[1710,1789,"So that's it."],[1835,1931,"You're turning against"],[1931,2068,"your own mother"],[2068,2260,"for that traitorous bitch?"],[2289,2348,"Kiefer."],[2444,2619,"Either you release Nora"],[2640,2848,"and kill Genesis,"],[2919,3119,"or you no longer have a mother."],[3153,3286,"Choice is yours."],[3737,3849,"Well, I guess you no longer"],[3849,3912,"have a son."],[4104,4195,"Kiefer!"],[4195,4287,"She is the reason"],[4287,4437,"that you were locked up!"],[4446,4662,"She kept your son from you."],[4662,4763,"Have you forgotten?"],[4763,4984,"I am willing to move past all of that."],[5134,5321,"As long as Gen loves me again."]],"37":[[33,187,"I was so blind"],[233,429,"to what you and Nora did to her."],[475,704,"So blind to her being so alone."],[754,888,"How helpless she was."],[930,1063,"How that she never fought back"],[1063,1192,"because she didn't want me choosing"],[1217,1334,"between the woman who raised me"],[1334,1438,"and the woman that I loved."],[1484,1693,"I was so fucking blind"],[1747,1847,"to her suffering."],[1997,2060,"But never again."],[2152,2310,"I am never leaving her side."],[2352,2502,"And no one is gonna hurt her,"],[2502,2702,"and no one is taking her away from me."],[2761,2890,"You've lost your mind."],[2932,3028,"And for her?"],[3161,3349,"Genesis, this is all your fault."],[3557,3687,"Kiefer, you're bleeding."],[3895,4020,"No, Kiefer."],[4079,4383,"Genesis is my line in the sand."],[4446,4558,"You touch her again,"],[4646,4796,"and you lose me forever."],[4946,5021,"This is our home."],[5055,5176,"And if you can't respect the woman"],[5176,5263,"of the house,"],[5271,5397,"then I suggest you leave"],[5451,5538,"and never come back."],[5830,5897,"Madam?"],[6010,6126,"Allow me to escort you out."],[6197,6368,"Kiefer, you can't do this."],[6402,6481,"Please."],[6535,6594,"Please!"],[6594,6664,"For her?"],[6664,6819,"I don't understand!"]],"38":[[66,183,"What, you think you're invincible"],[183,312,"just because you're some mob boss?"],[404,492,"Did the doctor even say"],[492,600,"you could leave the hospital?"],[600,692,"Our son called,"],[750,846,"terrified."],[917,992,"Smart kid."],[1071,1305,"But Gen, that's not really"],[1305,1468,"what I'm thinking about right now."],[1747,1906,"You said that you were leaving me,"],[1906,1968,"weren't you?"],[2064,2131,"So tell me,"],[2193,2377,"why rip up the divorce papers?"],[2377,2481,"Why refuse to"],[2481,2635,"choose another wife for me?"],[2840,2936,"You were jealous."],[3028,3228,"You couldn't stand the idea"],[3336,3624,"of another woman touching me."],[3753,3870,"What if I was?"],[4120,4254,"Would that make you happy?"],[4387,4458,"Very."],[4754,4842,"Why did you stand up"],[4842,4925,"for me back there?"],[4996,5105,"That was your mother."],[5355,5451,"Because..."],[5705,5868,"I refuse to let you go."],[5930,6010,"Even if it means"],[6010,6135,"cutting ties with your family?"],[6135,6247,"Even if it means"],[6289,6493,"losing everything I have."],[6723,6815,"I love you, Gen."],[6927,7023,"More than anything."],[7086,7323,"He said he loves me before."],[7390,7582,"But this time, I can tell he means it."],[7682,7782,"He really loves me."],[7899,8024,"But can I forgive him?"]],"39":[[75,229,"Why are you being all gentle?"],[291,342,"What happened to"],[342,442,"ripping my clothes off?"],[525,679,"Pinning me against the wall?"],[796,1101,"I think that this works a lot better."],[2085,2243,"What's that poking me down there?"],[2289,2427,"I didn't even kiss you."],[2427,2535,"Can you blame a man who hasn't"],[2535,2744,"made love to his wife for"],[2802,2932,"7 whole years?"],[3082,3182,"You feel that?"],[3228,3432,"He's even harder than he was before."],[3582,3678,"Come on, Gen."],[3774,3966,"Don't you miss how it feels inside you?"],[4254,4350,"If I said yes,"],[4350,4483,"what would you do about it?"],[4483,4567,"Oh, Gen."],[4592,4779,"let me inside you."],[5034,5130,"Oh, Gen."],[5130,5238,"Don't ask."],[5342,5484,"Just put it inside me."]],"40":[[66,191,"Don't you test me."],[283,375,"You're gonna turn me into"],[375,517,"a fucking wild animal."],[517,617,"You already are one."],[1001,1130,"Look, if we're not doing this,"],[1130,1205,"I'm getting up."],[1205,1263,"Oh, no."],[1443,1522,"You"],[1605,1760,"are not going anywhere."],[1760,1960,"God, I've missed this feeling."],[1985,2052,"You want more?"],[2218,2285,"Beg me."],[2414,2540,"Or ride me."],[2594,2740,"Don't tell me what to do."],[2927,2973,"Careful."],[3094,3182,"I don't care."],[3265,3403,"I want you right now."],[3837,3928,"Oh, Gen."],[4070,4346,"Tell me you love me and I'll fuck you."]],"41":[[0,87,"Say you love me."],[200,358,"Tell me you want this"],[358,487,"because you love me."],[550,729,"I do want him. But-"],[746,875,"You've saved me twice."],[1080,1197,"I owe you this much."],[1413,1572,"I'm just not ready to love him again."],[1960,2010,"Kiefer."],[2056,2331,"I thought you actually wanted this."],[2373,2473,"I do want it."],[2523,2644,"But not because you love me."],[2740,2940,"What exactly was your plan just now?"],[2986,3115,"Use your body to"],[3132,3294,"pay your debt and make us even"],[3294,3415,"just so you could leave here"],[3415,3528,"and not feel bad about it?"],[3528,3595,"That's not how this"],[3636,3782,"fucking works, Genesis!"],[4446,4575,"You don't have to force yourself."],[4863,5230,"Until you say that you love me."],[5401,5530,"I'm not gonna touch you."],[5622,5726,"I'm not gonna hurt you"],[5726,5889,"like I did 7 years ago."],[6485,6673,"He'd rather choke down his desire"],[6673,6815,"than trample my feelings?"],[7148,7219,"God,"],[7340,7407,"that makes me"],[7407,7520,"want him even more."]],"42":[[971,1076,"That asshole."],[1347,1484,"Gets me all hot and bothered"],[1484,1639,"and then just leaves me hanging?"],[2506,2598,"Kiefer."],[3303,3365,"Kiefer?"],[3420,3699,"Gen, I owe you an apology."],[3707,3770,"For what?"],[3824,3983,"I lost my temper earlier,"],[4020,4175,"I don't want you to be angry with me."],[4200,4391,"Oh God, I'm losing it."],[4462,4667,"Just his voice makes me even more horny."],[4683,4788,"Say something, Gen."],[4842,4938,"Are you still mad?"],[4971,5234,"Gen. Oh, Gen."],[5292,5438,"Oh."],[5809,5926,"Kiefer, what are you doing?"]],"43":[[20,125,"Working out,"],[208,308,"missing you,"],[400,487,"badly."],[521,658,"He's touching himself."],[763,975,"God, I can't stop picturing it."],[1055,1238,"Are you working out too?"],[1280,1418,"No, I'm just taking a bath."],[1418,1488,"I'm just,"],[1584,1722,"I'm really relaxed."],[1764,1822,"Sure,"],[1889,1968,"I believe you."],[2085,2252,"Just like you believe me."],[2331,2456,"Let me hear you."],[2477,2602,"You want me to go harder?"],[2615,2690,"Faster?"],[2723,2827,"Faster, Kiefer."],[2898,3032,"Oh fuck."],[3207,3294,"Oh."],[3832,3891,"Gen,"],[4129,4287,"did you just come thinking about me?"],[4521,4608,"Shit."]],"44":[[371,462,"Hello, sweetheart."],[613,792,"You still didn't answer my question"],[792,884,"from last night."],[971,1055,"What question?"],[1184,1409,"Did you finish thinking about me?"],[1484,1576,"Faster, Kiefer."],[2014,2097,"Morning, Mommy."],[2097,2173,"Morning, Daddy."],[2335,2435,"Good morning, champ."],[2515,2602,"Look at you."],[2631,2723,"You slept in."],[2811,2894,"You know that means?"],[2894,3007,"You feel safe here."],[3069,3140,"Dad likes that."],[3211,3374,"Come on, let's have some breakfast."],[3628,3774,"There are 3 plates today."],[3799,3970,"Yesterday, there were only 2."],[4033,4233,"Mommy, is this an extra one for Daddy?"],[4308,4366,"Does this mean"],[4366,4517,"you guys are done fighting?"],[4617,4746,"Well, I made extra,"],[4746,4896,"so I just figured it's better to eat up"],[4896,5042,"instead of letting it go to waste."],[5042,5159,"Daddy, she's lying."],[5159,5330,"If you believe her, you're silly."],[5430,5513,"Well, good news,"],[5534,5601,"I don't."],[5659,5764,"Come on, dig in."],[5826,5914,"It's time that we have our"],[5914,6068,"first family breakfast."],[6185,6368,"They get along so well with each other."],[6393,6460,"I have to say"],[6460,6589,"I'm pretty happy now too."],[6681,6873,"If I let go of the past and start over,"],[6990,7127,"will this happiness last?"]],"45":[[329,475,"I have a big meeting tonight."],[475,613,"I'm gonna be home a little late."],[996,1092,"Oh, and, uh..."],[1351,1501,"when I get home,"],[1526,1584,"I'm gonna have a little"],[1584,1689,"surprise for you."],[2027,2122,"A surprise?"],[2193,2277,"I wonder what it is."],[2665,2706,"Ugh."],[2994,3094,"What's wrong, mother?"],[3115,3240,"Who pissed you off this time?"],[3282,3357,"Genesis."],[3378,3445,"Who else?"],[3516,3624,"I gave her a way"],[3624,3766,"out of her marriage with Kiefer"],[3774,3995,"and she had the nerve to refuse."],[4033,4116,"Can you imagine"],[4116,4241,"if Kiefer is foolish enough"],[4241,4412,"to bring that traitor as his date"],[4412,4537,"to the upcoming gala?"],[4629,4733,"The O'Reillys will be the"],[4733,4917,"laughingstock of this city."],[5630,5751,"If you knew I wanted"],[5751,5905,"to bring Genesis as my date,"],[6006,6160,"you'd lose your damn mind."]],"46":[[517,667,"Is this the surprise?"],[950,1113,"Is it some kind of special occasion?"],[1726,1947,"Genesis, tonight's Gala won't be"],[1947,2131,"complete without its leading lady."],[2168,2227,"Kiefer."],[4633,4925,"You look absolutely stunning,"],[4979,5071,"Mrs. O'Reilly."],[5205,5351,"Are you sure you wanna bring me?"],[5409,5492,"When everyone knows"],[5492,5563,"what happened."],[5588,5772,"Your enemies are gonna laugh at you."],[5843,5910,"Honey,"],[5997,6147,"people like staying alive."],[6218,6389,"They're not nearly as bold as you are."],[6389,6556,"I'm sure they'll keep their mouths shut."],[6681,6802,"It looks like, um,"],[6927,7052,"you're missing something."],[7107,7186,"What are you talking about?"],[7415,7478,"What is that?"],[7524,7590,"A tra