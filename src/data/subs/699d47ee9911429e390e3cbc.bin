{"1":[[316,454,"Sweetie, I found the one you wanted."],[600,725,"I'll take this one."],[813,1001,"When are you coming home,"],[1001,1134,"Mommy?"],[1605,1705,"She's done for."],[1772,1847,"Kiefer O'Reilly,"],[1872,2002,"the biggest mob boss in town,"],[2002,2093,"had a bounty on her head"],[2093,2189,"for seven years."],[2202,2394,"It's only a matter of time before-"],[2498,2540,"Hey!"],[2610,2694,"Your change."],[2786,3040,"Yeah, the woman on that poster is me."],[3057,3219,"I've been on the run for seven years,"],[3224,3365,"all because I put one"],[3365,3607,"very dangerous man behind bars."],[4337,4587,"And now that man's standing"],[4587,4725,"right across the street from me."],[4763,4875,"Kiefer O'Reilly."],[4892,4988,"Mob boss."],[5042,5113,"My husband."],[5447,5601,"I'm so sorry, Mrs. O'Reilly."],[5618,5776,"But one of your twins didn't make it."],[7107,7269,"Yes, Kiefer!"],[7399,7528,"Harder, Keifer."],[7590,7670,"Fill me up."],[7995,8208,"Your wife's watching, Kiefer."],[8337,8537,"Tell her I'm the one you really love."],[8692,8817,"How could you, Kiefer?"],[8875,9029,"You're not just ruining our marriage,"],[9029,9142,"you're sleeping with the woman"],[9142,9255,"who killed our child!"],[9334,9630,"Yes, you're so hard Keifer."],[10126,10235,"Yes, Agent Ford."],[10427,10539,"I've changed my mind."],[10660,10764,"I'm turning him in."],[11115,11282,"I finally found you, honey."],[11382,11557,"It's time to stop running, Genesis."],[11611,11657,"Seven years,"],[11657,11786,"and he's still the one"],[11786,11886,"who makes my heart race,"],[11886,11978,"my blood boil."]],"2":[[412,479,"Never."],[2093,2264,"Find her and drag her out."],[2510,2581,"Ah!"],[2998,3061,"What?"],[3061,3128,"Jesus."],[3745,3832,"What are you looking at?"],[4095,4195,"Excuse me."],[4333,4433,"Excuse me."],[5330,5463,"Search everywhere."],[5463,5680,"I want her back by the end of the day!"],[5755,5834,"Shit."],[5860,5972,"What do I do?"],[6031,6160,"I can't let him catch me."],[7803,7978