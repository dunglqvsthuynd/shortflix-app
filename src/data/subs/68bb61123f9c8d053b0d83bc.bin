{"1":[[375,500,"I turned 18 today."],[563,650,"Got my wolf."],[742,905,"Now, if I don't marry this monster,"],[913,1076,"he'll kill what's left of my pack."],[1121,1267,"Just like he murdered my family."],[2356,2431,"Hello, bride."],[2531,2698,"Oh, hell no."],[2698,2882,"Rowan, where are you?"],[2882,3144,"Your evil father is about to mate me."],[3299,3549,"I think there's been a mistake,"],[3561,3636,"Alpha Boris."],[3636,3858,"I, I'm just a servant and,"],[3858,3999,"and you already have a Luna."],[4058,4137,"Not anymore."],[4366,4571,"She's the 9th Luna."],[4604,4800,"Nobles don't send their daughters."],[4825,5067,"The new one's just a peasant."],[5088,5276,"Let's see how long she lasts."],[5935,6081,"Don't you fucking touch her!"],[6548,6619,"Son,"],[6681,6981,"you dare challenge my claiming?"],[7027,7173,"She was never yours."],[7198,7290,"She's mine!"],[7499,7640,"You could take me,"],[7640,7728,"but now,"],[7891,8116,"even a weak-ass wolf"],[8128,8420,"would be drawn to a servant girl."],[10243,10410,"The old Alpha is dead."],[10443,10685,"I'm the new Alpha King now."],[11315,11382,"You came."],[11440,11590,"I'll always come for you."]],"2":[[567,792,"I couldn't let you marry my father."],[850,1080,"He is, was vile."],[1209,1284,"He would have done"],[1284,1413,"fucked up things to you."],[1501,1647,"I couldn't watch him break you."],[1764,1910,"You killed the Alpha King,"],[1968,2122,"your father, for me."],[2248,2344,"Why would you do that?"],[2431,2569,"I knew at the moment I saw you."],[2794,2865,"Father,"],[3011,3153,"the Azor Pack Royals are dead."],[3178,3374,"Even the Alpha Princess?"],[3732,3899,"I killed the girl myself."],[4149,4200,"Rowan."],[4600,4646,"Here."],[4688,4763,"Let go of me!"],[4771,4888,"Lose the attitude."],[4938,5013,"And this."],[5134,5263,"Now, put these on."],[5409,5509,"You protected me."],[5593,5647,"Why?"],[5655,5759,"I'll tell you when you're older."],[5814,5943,"Just do what I say"],[5943,6064,"and you'll stay alive."],[6126,6185,"You're no longer"],[6185,6264,"an Alpha Princess."],[6310,6423,"You're a servant girl."],[6502,6639,"And I'm gonna need that."],[7032,7136,"Now, come with me."],[7261,7432,"I hid you amongst the servants"],[7494,7670,"and waited until you were ready."],[7745,7874,"But my psychotic father"],[7874,8028,"figured out what you were to me"],[8028,8174,"and wanted to claim you."],[8241,8470,"And what I am to you, Rowan?"],[10548,10627,"What is this?"],[10806,10910,"Our mate bond."],[11023,11194,"You're my fated mate, Mara."],[11219,11394,"I've been waiting for you to turn 18"],[11394,11486,"and get your wolf."],[11498,11699,"I've been waiting for so long."],[11807,11941,"But now you're here"],[11949,12024,"where you belong."],[12032,12099,"With me."]],"3":[[133,321,"Your father killed my family."],[354,425,"Yes."],[475,633,"I lost everything."],[721,784,"Yes."],[855,975,"All these years, and"],[1113,1263,"you protected me."],[1280,1384,"Because you're mine!"],[1397,1543,"I can't fall for the enemy."],[1693,1872,"I'm supposed to hate him,"],[1872,2081,"but every time he gets close,"],[2114,2248,"I can't pull away."],[2744,2894,"Fate chose you for me."],[2952,3061,"And me for you."],[3178,3274,"Do you understand?"],[3349,3461,"You're it for me."],[4733,4850,"This changes nothing."],[4879,5142,"This changes everything."]],"4":[[529,646,"I dreamt of this."],[696,804,"I dreamt of you."],[967,1138,"I didn't dare let myself dream."],[2018,2168,"I want to make all your dreams"],[2168,2243,"come true."],[3336,3440,"Rowan, behind you!"],[5730,5901,"They are going to keep coming back."],[5914,6039,"I need to protect her."],[6523,6577,"Rowan,"],[6614,6794,"where are you taking me?"],[6802,6952,"Someplace safe."],[6994,7136,"I can walk."],[7244,7349,"Silence, mate."],[7365,7474,"Let me protect you."]],"5":[[871,971,"What is this place?"],[992,1067,"A palace."],[1138,1238,"All to yourself."],[1330,1363,"Quiet."],[1388,1443,"Safe."],[1526,1626,"Perfect for thinking."],[2027,2122,"These are for you."],[2740,2823,"What's the catch?"],[2873,2965,"You'll stay here."],[3032,3123,"Until I return."],[3286,3566,"So you're locking me away"],[3566,3728,"with jewelry for company?"],[3787,3937,"You can't just leave me here."],[3945,4124,"This was just a first attack."],[4162,4312,"I must hunt down those"],[4312,4471,"who plot to steal my throne"],[4471,4575,"before they get you."],[4604,4683,"Don't do this, Rowan."],[4683,4854,"Just let me fight at your side."],[4867,4959,"You'll have maids."],[4984,5071,"Hot meals."],[5167,5317,"Dresses stitched in gold."],[5342,5438,"No one will touch you."],[5467,5626,"I'll return as often as I can."],[5743,5935,"You're making me a sitting duck."],[6043,6172,"I'll give them a Fake Luna."],[6239,6414,"A lie to feast on."],[6493,6552,"A fake Luna?"],[6552,6627,"You can't..."],[6785,6952,"I believe that belongs to you."],[7811,7862,"You're no longer"],[7862,7953,"an Alpha Princess."],[8020,8120,"You're a servant girl."],[8437,8600,"The Azor Alpha necklace."],[8600,8800,"The upcoming months will test us,"],[8846,8946,"but don't forget,"],[9004,9171,"you are an Alpha Princess."],[9872,9980,"How can you lock away"],[9980,10118,"your fated mate?"],[10318,10514,"You can't just leave me here, Rowan!"],[12141,12295,"It is time to draw your bath, my lady."],[12328,12399,"A bath?"],[12445,12541,"For your prisoner?"],[12558,12658,"No, my lady."],[12691,12766,"Our queen."],[12896,12967,"We were instructed"],[12967,13104,"to give you the very best care."],[13834,13888,"My lady."],[13959,14034,"You are..."],[14205,14330,"No , no, no, no way."],[14351,14456,"I, I can't be-"],[14518,14631,"Pregnant."]],"6":[[179,246,"Tonight is the"],[246,358,"engagement ceremony"],[358,471,"to Alpha Rowan."],[517,596,"I am Luna"],[604,746,"in everything but name."],[759,884,"And yet, he treats me"],[884,1005,"like I'm nothing."],[1213,1297,"I deserve to know"],[1297,1426,"what's behind that door."],[1593,1743,"Are you sure we can enter?"],[1789,1935,"The North Tower is forbidden."],[1939,2027,"I'm sure."],[2152,2264,"I am the Luna."],[2389,2477,"And you two,"],[2556,2660,"stay loyal to me,"],[2660,2794,"and you'll be rewarded."],[2844,2957,"My brother Lord Garrick"],[2957,3073,"tells me that the Alpha"],[3073,3207,"of the Whitehorn pack"],[3207,3349,"is seeking a Luna."],[3420,3636,"Perhaps the most vicious among you"],[3636,3908,"will be a worthy candidate."],[4029,4187,"We would be honored, my Luna."],[4229,4316,"But Alpha Rowan?"],[4358,4487,"He killed a guard last week"],[4487,4571,"who tried to enter."],[4621,4758,"Are you certain he won't mind?"],[4763,4846,"He won't."],[4988,5138,"My Rowan worships me."],[5684,5851,"Why did he lock this tower away"],[5851,6018,"like a cursed storybook?"],[6139,6239,"People are talking."],[6368,6560,"'The Alpha's weakness', they say."],[6698,6923,"I must know as his Luna."],[7628,7736,"I wish to enter."],[7891,8045,"You're not permitted entry, miss."],[8074,8216,"Do you know who I am?"],[8270,8324,"Yes."],[8379,8487,"And I have orders preventing,"],[8487,8633,"especially you, from entering."],[8904,9096,"Well, Alpha Rowan shouldn't have left it"],[9096,9217,"so poorly guarded."],[9513,9588,"Catch him."]],"7":[[275,479,"He's been keeping someone here."],[1059,1292,"Alpha Boris' servant bride?"],[1343,1455,"What is this place?"],[1480,1643,"Why is the Alpha hiding you here?"],[1655,1776,"You need to leave now."],[1805,1893,"Rowan will kill you"],[1893,2010,"if he finds you here."],[2018,2122,"How dare you speak"],[2122,2235,"to your Luna like that."],[2369,2523,"Learn your place, bitch."],[2556,2702,"Why would he hurt a Luna"],[2715,2844,"for someone like you?"],[2911,3086,"She's the Fake Luna?"],[3169,3353,"If you don't tell"],[3353,3495,"why you're here now,"],[3561,3695,"you will be carrion."],[4358,4491,"No, it's not possible."],[4491,4608,"It's Alpha Rowan's."],[4658,4771,"Where did this come from?"],[4804,4896,"This is the Alpha's."],[4900,5030,"This was supposed to be mine."]],"8":[[8,116,"Where did this come from?"],[179,271,"This is the Alpha's."],[271,417,"This was supposed to be mine."],[571,638,"What?"],[654,850,"How could she have this sigil ring?"],[880,963,"After the engagement"],[963,1017,"ceremony,"],[1017,1192,"it is mine by right."],[1580,1647,"What are you?"],[1710,1780,"His whore?"],[1872,1943,"A witch?"],[1993,2093,"His little rebellion"],[2093,2231,"in a servant gown?"],[2369,2477,"I am the Luna."],[2585,2798,"You are nobody."],[2840,2994,"I don't want any trouble."],[2994,3098,"But you need to leave."],[3098,3186,"He'll be here soon."],[3186,3307,"You won't be anything"],[3307,3428,"when I'm done with you."],[3470,3545,"Grab her."],[4704,4909,"This will keep your wolf in its cage."],[4946,5050,"No shifting."],[5384,5580,"Now, let's talk."],[5864,5947,"What's your name?"],[5985,6118,"You don't want to do this."],[6126,6281,"Just leave and I promise"],[6281,6427,"I won't tell him you were ever here."],[6435,6510,"I promise,"],[6552,6631,"he doesn't care"],[6631,6802,"about a little shit like you."]],"9":[[150,216,"Speak."],[241,325,"What happened?"],[1172,1222,"What is that?"],[1297,1380,"Please, no."],[1380,1564,"That's all I have left of my family."],[1593,1672,"What?"],[1747,1839,"This cut,"],[1860,2010,"these stones,"],[2060,2223,"they're from Azor territory."],[2264,2356,"Could her father"],[2356,2519,"be the fallen Alpha?"],[2531,2602,"No."],[2644,2773,"It's just a coincidence."],[2811,2915,"Give it back!"],[3069,3136,"Only"],[3211,3349,"if you admit who you are,"],[3386,3566,"and why Rowan gave you this ring."],[3632,3720,"Please."],[3778,3899,"He is coming."],[3912,4095,"He comes every night."],[4095,4250,"He will kill you for touching me."],[4250,4346,"Just leave."],[4571,4754,"I am the Luna, bitch!"],[4808,5046,"You are nobody."],[5205,5263,"Admit it."],[5347,5497,"I just need her to give me"],[5497,5647,"the necklace and go."],[5697,5855,"She can't know about my baby."],[5885,5939,"Fine."],[6018,6135,"I'm just his whore."],[6231,6314,"And the ring?"],[6398,6573,"I don't even know what it is!"],[6602,6781,"He doesn't tell me everything."],[6865,6973,"I knew it."],[7027,7152,"You're not important to him."],[7194,7240,"Now,"],[7332,7474,"swear fealty to me,"],[7553,7703,"as the Luna of this pack."],[7757,7932,"I pledge myself,"],[7941,8095,"by blood and bone,"],[8099,8283,"to the Luna of this pack."],[8287,8395,"Now leave."],[8416,8546,"Before he comes here"],[8546,8679,"and kills you all."],[9129,9196,"No!"],[9751,9951,"I need to protect my baby."]],"10":[[229,283,"No."],[362,479,"No, what is happening?"],[554,650,"Impressive."],[746,834,"Most people can't even"],[834,913,"begin the shift"],[913,1026,"after that kind of a dose."],[1080,1126,"But,"],[1263,1409,"if you're trying to attack me?"],[1755,1922,"Even though he locks me here,"],[1947,2089,"Rowan is my alpha,"],[2089,2277,"and my child is innocent."],[2293,2348,"Grab her."],[2431,2535,"We'll take her to the party."],[2581,2731,"I want them all to see what happens"],[2731,2823,"when someone tries to"],[2823,3098,"steal my crown or my Alpha."],[3157,3257,"Let them watch."],[3257,3307,"No."],[3345,3490,"Rowan will kill you."],[3490,3641,"He'll kill you all."],[3661,3849,"No one must know I exist."],[3862,3974,"Are you sure, Selene?"],[3995,4133,"The Alpha's in a war meeting,"],[4149,4270,"perhaps he will not approve."],[4283,4416,"Do you doubt me?"],[4479,4587,"Of course not."],[4608,4850,"He would never hurt me"],[4909,5121,"over a little gutter-born thing"],[5121,5209,"like you."],[5918,6160,"You're just a dirty secret he'll bury."],[6423,6481,"Take her."]],"11":[[0,187,"Not many mourn the old Alpha."],[241,371,"But he did have loyal nobles"],[371,492,"who supported him"],[579,742,"and got rich doing so."],[742,842,"Enough to challenge me?"],[875,1088,"No one can defeat you in open battle."],[1172,1305,"Everybody saw how easily"],[1305,1434,"you executed your own father"],[1434,1547,"at the wedding."],[1693,1805,"But a secret coup-"],[1810,1931,"What became of the girl?"],[2002,2085,"The one I saw"],[2085,2252,"you drag from the track,"],[2268,2360,"from the altar?"],[2394,2560,"Wild little thing, wasn't she?"],[2610,2686,"Yeah."],[2706,2794,"I'd like a taste of her"],[2794,2898,"when you're done with her,"],[2898,2973,"Alpha."],[3011,3182,"I'll bet she cried and begged for it."],[3307,3449,"Say that again."],[3495,3628,"Just a joke, Alpha King."],[3670,3749,"She's nothing,"],[3770,3974,"a nameless slut from the dirt."],[4346,4517,"My Alpha, I meant no offense."],[4575,4692,"No, no."],[5397,5559,"You wanted a taste of her."],[5584,5743,"Mercy, my Alpha."],[6097,6231,"The last thing that you will taste"],[6231,6373,"is your own blood."],[6573,6715,"Don't even breathe her name."],[6752,6956,"I'll hang your pelts at my gates."],[6986,7102,"Now clean this up."],[7115,7253,"I won't let a war over"],[7253,7444,"the stink of coward blood."],[8037,8195,"Apologies for the delay."],[8258,8458,"I had a little pest to clean up."],[8566,8725,"This is the thing your Alpha"],[8787,8979,"has been hiding in the North Tower."]],"12":[[266,371,"Tell them what you are."],[433,596,"The Alpha's pet whore."],[617,842,"You don't understand."],[867,1021,"You have to let me go,"],[1038,1222,"or he'll kill all of you!"],[1468,1576,"She's delusional."],[1647,1751,"She's just a toy"],[1751,1918,"passed from father to son."],[2218,2369,"She bears his scent."],[2373,2577,"She must be cleansed!"],[2610,2836,"Oh, she's defied the sacred laws."],[2844,3023,"The Alpha's whore."],[3136,3403,"The fire cleanses what is false."],[3461,3720,"The fire cleanses what is false."],[3757,4033,"The fire cleanses what is false!"],[4062,4329,"The fire cleanses what is false!"],[4366,4629,"The fire cleanses what is false!"],[5451,5618,"Let the fire strip her"],[5618,5789,"of the Alpha's scent."],[5830,5955,"Let the pack see"],[5993,6181,"what happens to traitors."],[6306,6410,"You will all"],[6544,6652,"regret this."]],"13":[[112,271,"The Alpha has more important things"],[271,383,"to be doing besides"],[396,608,"paying attention to a cheap whore."],[738,892,"Look at her on her knees."],[930,1063,"Will you beg for mercy?"],[1105,1242,"You're all alone."],[1259,1413,"Just the Alpha's plaything."],[1430,1547,"And now ours."],[1764,1826,"Oops!"],[1835,1918,"Did that hurt?"],[1943,2156,"Too bad no one in the world cares."],[2185,2406,"Oh, that's good, Cassie."],[2598,2765,"Well, I think she needs a haircut."],[2831,3044,"This is far too luxurious"],[3044,3161,"for someone of her rank,"],[3161,3228,"don't you think?"],[3282,3449,"Oh, creative girls."],[4262,4341,"You know what?"],[4421,4546,"I'm a fair Luna."],[4567,4717,"Let's make this democratic."],[4775,4879,"Let's set it to a vote."],[4963,5117,"Who here thinks"],[5134,5317,"this bitch should live?"],[5363,5434,"Raise your hand."],[6010,6126,"Just as I thought."],[6289,6435,"Not even one."],[6531,6652,"You're all alone."],[6694,6798,"Unloved."],[6890,7082,"And you're gonna die alone too."],[7086,7232,"What the fuck is going on here?"]],"14":[[87,221,"What the fuck is going on here?"],[579,717,"Hello, brother."],[742,963,"I found the Alpha's pet whore."],[975,1076,"You know."],[1080,1192,"Rowan will come."],[1251,1426,"And when he finds me here,"],[1434,1664,"he will kill every one of you."],[1672,1730,"Will he?"],[1793,1889,"Over a little slut?"],[1951,2147,"You look so tempting on the floor,"],[2260,2377,"bloody and beaten."],[2560,2686,"I'm sure the Alpha wouldn't mind"],[2686,2823,"if I took you for a ride."],[2827,2907,"Would he?"],[2915,2969,"Don't!"],[2973,3061,"Get off me!"],[3415,3478,"Wait."],[3561,3666,"You little bitch."],[3737,3832,"Are you pregnant?"],[4049,4187,"No!"],[4329,4441,"Liar!"],[4462,4696,"There's no way that thing is his!"],[4767,4863,"She's a whore."],[4863,4979,"She probably spread her legs"],[4979,5084,"for half the guardhouse."],[5088,5238,"She knew exactly what she was doing."],[5238,5359,"Pretend it's the Alpha's baby,"],[5359,5530,"crawl her way into power."],[5584,5768,"This thing could ruin everything."],[6231,6485,"Everyone pay attention."],[6527,6719,"This is what happens"],[6752,7082,"when you try and steal my place."],[9088,9242,"And we'll brand her."],[9305,9547,"So no one forgets who she really is."],[13400,13551,"No!"],[15002,15256,"Alpha, I need you."],[15386,15440,"Rowan."],[15465,15569,"Come to me."],[15707,15778,"Rowan."],[15857,15915,"Please."],[16474,16570,"Alpha Rowan?"],[16775,16875,"Get out of my way!"]],"15":[[759,950,"We can't let this abomination live."],[1051,1138,"It threatens everything."],[1197,1380,"And what do you propose, Brother?"],[1797,1881,"This will end whatever"],[1889,2035,"bastard is growing inside of her."],[2777,3023,"Get our guest a chair."],[4975,5109,"Poor thing."],[5271,5430,"You've had it rough."],[5601,5734,"Knocked up,"],[5797,6039,"a bastard in your belly."],[6310,6560,"But I have something for you"],[6639,6823,"that will make it all better."],[7211,7307,"Drink this"],[7528,7657,"and the bastard"],[7753,7957,"will bleed out between your thighs."],[8312,8375,"Fuck"],[8416,8491,"you."],[8512,8712,"I won't let you kill my baby!"],[8996,9417,"I tried to be patient, you mongrel,"],[9471,9638,"but you've made your choice."],[9734,9809,"Hold her down."],[10272,10410,"Open up."],[10585,10664,"Wait!"],[10668,10752,"Stop!"]],"16":[[95,166,"Wait!"],[166,241,"Stop!"],[308,454,"She bears the Alpha's mark."],[496,554,"What?"],[608,721,"But this means..."],[804,950,"She's his."],[1126,1267,"Could the bastard be the Alpha's?"],[1267,1334,"Enough!"],[1463,1543,"Alpha Rowan"],[1559,1722,"is betrothed to my sister."],[1776,1876,"My brother's right."],[1926,2043,"That mark, it means nothing."],[2043,2227,"It, it could just be a scratch or,"],[2273,2419,"or another wolf's bite!"],[2548,2660,"Rowan would never-"],[2715,2831,"She can't be his mate."],[2890,2973,"This filthy servant"],[2973,3090,"who's been serving scraps"],[3090,3153,"in our hall?"],[3261,3319,"No."],[3353,3428,"It's not possible."],[3511,3553,"Do it."],[3591,3687,"Get rid of the bastard."],[3807,3945,"Open up, bitch."],[4154,4233,"My baby."],[4262,4387,"I will protect her"],[4387,4479,"with everything I am."]],"17":[[475,604,"He will come for you."],[604,817,"But maybe I'll kill you first."],[1443,1626,"You're a spirited thing, aren't you?"],[1701,1881,"No wonder he likes fucking you."],[1972,2085,"Don't you understand?"],[2189,2439,"I am your Luna!"],[2519,2731,"And my brother is a Lord."],[2790,3086,"And you are nothing."],[3161,3307,"You're just a whore"],[3336,3666,"who is taken from father to son."],[3949,4371,"Drink this fucking potion, bitch!"]],"18":[[2585,2761,"Get the poison off me!"],[3190,3336,"I will end you!"],[3340,3507,"I've survived worse than you,"],[3507,3682,"you psychotic bitch!"],[3812,3887,"Chain her."],[4245,4383,"We don't need the poison."],[4425,4491,"There are other ways"],[4491,4608,"to kill this child."],[4754,4859,"We just kill the girl."],[4938,5021,"Finally."],[5488,5601,"Where did you get that ring?"],[5793,5851,"This ring."],[5851,5926,"Where did you get it?"],[6022,6076,"It's mine."],[6210,6331,"Did Alpha Rowan give that to you?"],[6506,6556,"No."],[6639,6752,"Then did he give it to her?"],[6923,6986,"Selene."],[7002,7069,"Tell me now."],[7411,7520,"Tell me right now."]],"19":[[16,133,"Tell me right now."],[216,275,"Yes."],[379,408,"No."],[412,450,"No."],[450,558,"I found it in her room."],[654,746,"What have you done?"],[775,900,"What are you talking about?"],[921,988,"The mark."],[1005,1059,"The ring."],[1092,1146,"That girl,"],[1146,1251,"she means something to him."],[1263,1313,"So?"],[1405,1555,"You're the real Alpha anyways."],[1555,1718,"He's just a boy playing king."],[1739,1826,"You don't understand."],[1847,1906,"Selene,"],[1926,2093,"you don't understand his power."],[2135,2310,"He's vicious, ruthless."],[2352,2469,"We've had to be so careful"],[2469,2548,"with our plans,"],[2569,2677,"the coup's almost in place,"],[2677,2794,"but if he comes after her,"],[2794,2919,"it could ruin everything."],[3015,3161,"You sound like a coward."],[3340,3395,"Drink."],[3507,3586,"Celebrate."],[3645,3787,"And if it calms your nerves,"],[3803,3899,"I'll return the girl"],[3899,4008,"to her precious little tower"],[4008,4158,"before he even knows she's missing."],[4279,4429,"Then, we'll make her death"],[4429,4550,"look like an accident."],[5855,5993,"Kneel her at my feet."],[6994,7286,"You are exactly where you belong."]],"20":[[33,183,"Is she dead?"],[429,521,"It looks like it."],[788,859,"No."],[892,1042,"She's just knocked out, I think."],[1172,1280,"Rowan mated me,"],[1326,1501,"locked me away to protect me."],[1564,1689,"He'll kill them for this."],[1739,1814,"But the baby and I"],[1814,1964,"will be dead before he gets here."],[2957,2986,"Quick."],[2990,3065,"Hide the body now."],[3103,3174,"Silence her."],[4854,4971,"If any of you mention the girl,"],[4971,5084,"I'll make sure your entire family"],[5084,5196,"dies before your eyes."],[6039,6135,"Where is she?"]],"21":[[87,179,"Where is she?"],[375,521,"What do you mean, darling?"],[617,775,"Who entered the North Tower?"],[959,1059,"Answer me!"],[1080,1222,"Really, Rowan,"],[1313,1418,"it's our wedding party."],[1426,1493,"Relax."],[1814,1931,"Who killed my guard?"],[1993,2131,"Who disobeyed my order?"],[2344,2402,"No one?"],[2531,2598,"Really?"],[2748,2831,"There are other ways"],[2831,2923,"to figure this out."],[3386,3461,"Blood."],[3574,3661,"Lies."],[3949,4029,"Guilt."],[4145,4300,"It sticks to the skin."],[4792,4863,"Thank God"],[4863,5055,"the iron will mask her scent."],[5113,5234,"Hopefully, she's dead"],[5251,5388,"and we can just toss the body"],[5388,5559,"in the river and be done with this."],[5593,5826,"But why is he so concerned"],[5826,6006,"with some random servant girl?"],[6047,6227,"She can't really mean anything to him."],[6289,6435,"Because then why would he"],[6435,6556,"be engaged to me?"],[7061,7119,"You."],[7240,7357,"No, please."]],"22":[[50,95,"You."],[446,563,"No, please."],[604,696,"I only did it because..."],[859,984,"because Viren said we should."],[1076,1226,"And why would she say that?"],[1434,1493,"Because..."],[1705,1843,"because the Luna told us to."],[2540,2665,"She said things were handled."],[2665,2831,"Said it's what you would have wanted."],[3023,3115,"Darling,"],[3144,3278,"there's an easy explanation"],[3278,3374,"for all of this."],[3386,3474,"Explain."],[3503,3557,"I,"],[3599,3707,"I saw someone trying to run"],[3707,3799,"toward the North Tower."],[3799,3924,"And I know you hate that."],[3974,4087,"So we followed them."],[4145,4195,"We thought that"],[4195,4304,"they were trying to break in."],[4404,4491,"We caught one,"],[4533,4633,"the others, they got away."],[4633,4688,"And we don't know"],[4688,4783,"what happened after that."],[4800,4959,"And who's the one that you caught?"],[5918,5955,"Him."],[5993,6072,"No, Alpha,"],[6114,6177,"I swear."],[6197,6343,"I don't know what she's talking about."]],"23":[[45,129,"My Alpha,"],[179,279,"who is this girl to you?"],[342,475,"Your future Luna is here."],[613,750,"Beautiful, fierce,"],[800,884,"and ready to give you"],[884,1005,"a strong bloodline."],[1121,1238,"There's no need to consort"],[1238,1334,"with common rabble."],[1509,1609,"Don't call her that."],[1655,1826,"I only keep you alive now"],[1826,2031,"because as youths, we trained together."],[2060,2168,"Speak of her again, and"],[2177,2298,"I will kill you."],[2339,2469,"I've never seen him like this."],[2515,2640,"We're dead if he finds her."],[2686,2786,"Who is this girl to him?"],[3128,3207,"Well, my Lord,"],[3244,3424,"if she matters to you so deeply,"],[3532,3636,"I'll execute a full search"],[3636,3720,"of the castle."],[3782,3953,"Describe her for us, my Alpha."],[4079,4158,"What does she look like?"],[4763,4833,"I'm sorry,"],[4875,5034,"who are we talking about exactly?"],[5242,5313,"A prisoner?"],[5313,5405,"A spy?"],[5538,5676,"One of the castle girls?"],[5693,5784,"He won't answer."],[5814,5860,"Why?"],[5889,5989,"Is she a weakness?"],[6068,6172,"Or a weapon?"],[6302,6427,"Whoever this girl is,"],[6519,6614,"she's in our way."],[6723,6865,"She was bleeding here."],[7102,7190,"Where is she?"],[7273,7399,"Why can't I scent her?"]],"24":[[25,116,"Where is she?"],[171,225,"Alpha."],[279,350,"Careful, boy."],[371,442,"The wrong sentence"],[442,538,"could end your life."],[625,692,"The blood,"],[700,850,"Alpha Rowan, it's nothing."],[955,1038,"One of the servants"],[1038,1117,"cut her hand earlier."],[1117,1226,"And I had it cleaned."],[1242,1409,"You cleaned it with iron chains?"],[1572,1714,"You sound paranoid, Rowan."],[1735,1889,"There are guards here in this room."],[1889,1976,"Surely, one of them would have"],[1976,2043,"said something"],[2043,2210,"if it was a girl here that mattered."],[2248,2419,"Mara's blood was spilled in here."],[3199,3303,"I can feel her."],[3386,3516,"Her pain is in my chest."],[3516,3649,"But I can't smell her."],[3937,4058,"If she dies,"],[4062,4170,"there will be nothing left"],[4170,4279,"of this place!"],[4300,4483,"I'll rip it down brick by brick"],[4483,4667,"with my bare hands!"]],"25":[[287,408,"Rowan is here."],[475,558,"He came."],[579,759,"He will save us, little baby."],[896,996,"But he hid me away"],[996,1138,"like a dirty secret."],[2135,2314,"He didn't stop his father from"],[2314,2477,"murdering my family."],[3194,3294,"Rowan's here,"],[3345,3486,"but he's too late."],[3520,3799,"I'm dying and my baby,"],[3933,4170,"my baby must survive."],[4533,4658,"Get Alpha Rowan out of here."],[4717,4821,"I'll dispose of the girl."],[4900,5025,"Make it painful."],[5117,5188,"I'll give her to the men"],[5188,5288,"after I'm done with her."],[5301,5372,"Have you ever seen anyone"],[5372,5459,"fucked to death?"],[5764,5855,"Alpha."],[6018,6131,"I'm sure you're tired"],[6131,6289,"after your long meeting."],[6339,6523,"Allow me to have a bath drawn for you."],[6773,6890,"Where did you get this ring?"]],"26":[[196,308,"Where did you get this ring?"],[396,554,"It's just a ring."],[1438,1584,"You smell of lies."],[1601,1739,"Alpha, please, that's my sister."],[1747,1847,"Silence!"],[1939,1997,"Tell me,"],[2131,2314,"Why is her ring on your finger?"],[2398,2494,"Alpha."],[2565,2669,"Rowan, wait."],[3215,3307,"My baby."],[3345,3524,"Please, save my baby."],[3991,4083,"Alpha."],[4471,4662,"Alpha, please,"],[4696,4800,"you're hurting me."],[4838,5009,"I'll ask you one more time."],[5071,5263,"Why is her ring on your finger?"]],"27":[[12,200,"A, A, Alpha."],[621,713,"Stop!"],[763,921,"I am your Luna!"],[2731,2790,"Mara."],[2944,3032,"You came."],[3128,3278,"I'll always come for you."],[3991,4133,"What have they done to you?"],[4504,4637,"They'll pay for this."],[5042,5155,"You're my future."],[5263,5397,"I swear to my blood,"],[5522,5601,"I'll punish"],[5613,5772,"everyone who's done this to you."],[6272,6385,"Take her to the medic."],[6735,6881,"If this baby dies,"],[6927,7040,"every single one of you"],[7040,7186,"will die with it."]],"28":[[400,475,"And now,"],[604,692,"where were we?"],[917,1088,"You all knew where she was."],[1192,1305,"You hid her from me."],[1609,1726,"You made her bleed."],[2293,2498,"You spilled what belongs to me."],[2898,2977,"Take it off."],[3011,3136,"It's not yours!"],[3215,3365,"Who is this whore"],[3411,3586,"that you brought into our marriage?"],[3753,3899,"You would risk everything"],[3970,4074,"for her?"],[4141,4195,"Us?"],[4270,4379,"Our alliance?"],[4404,4658,"The loyalty of every house in the East?"],[4658,4733,"Selene."]],"29":[[33,329,"It is one thing to take a mistress."],[462,567,"Lock her in a tower?"],[567,629,"Fine."],[667,804,"Breed her in the dark?"],[821,880,"Fine."],[888,967,"But this?"],[988,1197,"This is an insult to me."],[1213,1351,"To my family."],[1413,1614,"I mean, did you hear yourself?"],[1614,1764,"You, you were licking her off"],[1764,1826,"of your fingers"],[1826,1985,"like she's some goddess!"],[2031,2206,"While I am standing here,"],[2227,2348,"your future Luna."],[2348,2419,"Selene, enough!"],[2439,2577,"No, he needs to hear it!"],[2761,2961,"This ring belongs to me,"],[2969,3082,"as the true Luna."],[3224,3449,"You would throw this kingdom"],[3449,3561,"into chaos"],[3591,3757,"for a servant whore?"],[3853,3941,"Remember?"],[4099,4241,"I asked you to take it off!"],[4662,4729,"Ah!"]],"30":[[754,875,"You, you, you..."],[913,1080,"Pick up the ring and hand it to me."],[1305,1472,"I can't, I can't."],[1514,1597,"I can't."],[1672,1764,"Pick it up!"],[3123,3207,"No."],[3336,3449,"Now, give it to me."],[5046,5188,"You monster!"],[5551,5663,"You stole her ring."],[5822,5993,"You dare call her a whore."],[6035,6168,"You made her bleed."],[6177,6377,"Now you bare your teeth"],[6377,6523,"as a mongrel bitch."],[6589,6673,"Let me show you"],[6673,6806,"how much you matter to me."],[7665,7778,"The marriage contract?"]],"31":[[325,375,"Alpha."],[375,458,"Surely you wouldn't"],[458,567,"break a contract for,"],[583,671,"for some- - Silence!"],[913,963,"Wait."],[1026,1238,"Please, I, I told them not to do it."],[1238,1359,"I tried to stop them."],[1376,1609,"It, it was, it was Cassie."],[1722,1830,"She burned her hand."],[1872,1997,"And then she stepped on it."],[2047,2214,"And, and Viren."],[2239,2364,"Viren, she dragged her"],[2364,2477,"across the hall and,"],[2485,2635,"and she, she ripped"],[2686,2840,"her hair right out of her head."],[2873,2927,"Liar!"],[2927,3040,"You told us to!"],[3065,3240,"You told us we'd be rewarded."]],"32":[[617,709,"Look at you,"],[784,842,"pathetic."],[1005,1067,"My Alpha, wait."],[1134,1217,"We have always"],[1217,1330,"stood beside each other"],[1359,1451,"as allies."],[1526,1668,"I have always been loyal to you"],[1680,1810,"as friend and Alpha."],[1881,2010,"Surely there's room for"],[2156,2227,"mercy."],[2281,2389,"Selene is my sister,"],[2423,2569,"and, and your sworn Luna."],[2606,2731,"And I think we both know it was,"],[2740,2869,"it was Cassie and Viren"],[2882,2927,"who were the ones"],[2927,3040,"whispering in her ears."],[3073,3123,"Low-born."],[3157,3228,"Reckless."],[3240,3378,"They're always looking to rise."],[3395,3440,"What?"],[3490,3561,"That's not-"],[3561,3703,"You lying coward."],[4058,4141,"Mercy?"],[4437,4562,"I'll show you mercy."],[5226,5438,"That's for Mara's burned hands."],[5839,5989,"Be grateful that's all."],[6047,6177,"Now leave my sight."],[6239,6331,"Thank you, Alpha."],[6343,6464,"Thank you, Alpha."]],"33":[[504,625,"We'll see what Selene's"],[625,729,"punishment will be"],[738,867,"when Mara returns."],[909,1126,"When I'll know what all of you did."],[1201,1376,"If it's as bad as I think,"],[1539,1689,"I will not spare you."],[2002,2068,"Rowan."],[2256,2318,"Who is she?"],[2481,2535,"Who's this girl"],[2535,2652,"that's turned you inside out?"],[2702,2815,"You'd burn your court for her?"],[2873,2986,"Over your future Luna?"],[3003,3119,"Watch yourself!"],[3862,3983,"It's time to move earlier"],[3983,4062,"than intended."],[4083,4262,"Alpha Rowan is clearly unfit to rule."],[4325,4412,"Prepare the others."],[4771,4888,"When she returns,"],[4896,5059,"I will know everything."],[5718,5843,"And there she is now."],[7140,7228,"She's alive?"],[7228,7349,"She should be dead."],[7349,7540,"It's remarkable she can even walk."],[8979,9084,"The baby lives."],[9271,9492,"But you will not."]],"34":[[29,162,"The baby lives."],[337,550,"But you will not."],[700,750,"You,"],[896,1005,"you bitch!"],[1067,1247,"You ruined everything!"],[1322,1430,"He was mine!"],[1438,1605,"She was never yours to torture,"],[1626,1751,"and you were never a Luna."],[2022,2152,"Take her to the dungeons."],[2435,2489,"Wait."],[2619,2694,"Wolves."],[2731,2848,"Is this really how we want"],[2848,2957,"our Alpha to behave?"],[3036,3240,"A wolf who burns his contracts"],[3253,3328,"for lust?"],[3411,3499,"For a woman"],[3499,3595,"who cleaned our toilets?"],[3903,4054,"Who killed his own father?"],[4275,4454,"Disgraces his bloodline."],[4517,4675,"We deserve better than this."],[4688,4854,"You've already told me you want better."],[4992,5130,"Perhaps it's time we got it."],[5130,5196,"Yeah."],[5230,5417,"Lord Garrick is the True Alpha!"],[5484,5613,"He is the true power."],[5897,6072,"So it was you all along."]],"35":[[108,196,"It's been you"],[196,329,"plotting in the shadows,"],[329,475,"trying to take my crown."],[475,625,"You're unfit to be Alpha."],[817,988,"Now it's plain for all to see."],[1814,2035,"I knew that it was a traitor in our pack."],[2068,2235,"I'm not surprised that it's you, Garrick."],[2281,2410,"Surrender now, Rowan."],[2481,2627,"And your death will be swift."],[3561,3832,"Too cowardly to face me all yourself."],[3866,4079,"This has been your plan all along,"],[4087,4245,"to turn everyone against me."],[4266,4404,"You made it easy for me"],[4429,4587,"by slumming with this whore!"],[4704,4846,"It's gonna be so much fun."]],"37":[[567,704,"You're just like your father,"],[763,963,"drunk on power, blind to the cost."],[1021,1092,"He ruled in terror,"],[1092,1192,"and so do you."],[1313,1384,"I always knew that"],[1384,1564,"you were a dog looking for scraps,"],[1564,1626,"Garrick."],[1626,1710,"I just didn't know"],[1710,1814,"you were dumb enough"],[1814,1989,"to bite the hand that feeds you."],[2306,2502,"With my brother as Alpha,"],[2531,2736,"I'll be the Luna by default anyway."],[2756,2902,"You're gonna die, bitch."],[2915,3086,"You have no idea"],[3086,3215,"the forces you are dealing with."],[3232,3357,"You'll lose more than a finger"],[3357,3474,"by the end of this."],[3478,3557,"Face me!"],[3895,3978,"How?"],[4029,4204,"You're just a lowly servant!"],[4204,4295,"Or am I?"],[4437,4600,"You were never fit to be Alpha."],[4612,4758,"I've waited in your shadow,"],[4783,4875,"playing loyal,"],[4917,5021,"biding my time."],[5055,5238,"Then you gave me the perfect chance."],[5280,5434,"Who would ever follow an Alpha"],[5451,5655,"who slaughters his nobles for some"],[5655,5768,"chambermaid whore?"],[6268,6402,"I warned you."],[6448,6623,"Shut the fuck up"],[6648,6785,"about my mate!"],[6990,7082,"His mate?"]],"38":[[70,246,"His mate?"],[717,804,"No, it's not possible."],[809,855,"I-"],[1146,1376,"Yes, my fated mate."],[1476,1672,"Given to be mine by the Gods."],[1768,1981,"Nothing overrides the bond of destiny."],[2110,2214,"And you, Selene,"],[2273,2435,"were nothing but a decoy."],[2548,2681,"His fated mate?"],[2736,2798,"But then,"],[2857,3028,"she is our true Luna."],[3044,3211,"How is it possible for the Alpha"],[3211,3324,"to mate a chambermaid?"],[3345,3465,"I've never heard of such a thing."],[3536,3582,"No."],[3624,3741,"No, you're lying!"],[3782,3916,"She's just a nobody!"],[3953,4179,"I will never bow to her!"],[4304,4483,"Die, you fucking nobody!"],[4900,5292,"I am Alpha Princess Mara Azor,"],[5388,5618,"daughter of Alpha Azor."],[5672,5935,"And you will all bow before me"],[5976,6151,"and my unborn child."]],"39":[[16,287,"You will all bow before me"],[321,475,"and my unborn child."],[483,613,"No, that's impossible."],[650,779,"She is the true Luna."],[834,921,"A princess"],[967,1076,"worthy of our Alpha."],[1105,1242,"Their child is our heir."],[1263,1409,"Of course you'd kill for her."],[1459,1576,"Their lives are one."],[2064,2152,"Do you see now?"],[2206,2310,"Do you understand?"],[2373,2498,"If I'd claimed you publicly,"],[2498,2623,"they would have killed you."],[2702,2844,"I had to make it look real."],[2869,2982,"You made it look real."],[3048,3119,"Too real."],[3144,3311,"There's nothing I wouldn't do for you."],[3382,3532,"You're the air I breathe."],[3574,3749,"Or the blood in my veins."],[3782,3853,"I would protect you"],[3853,3991,"with everything I have."],[4020,4124,"And my family?"],[4166,4245,"Their deaths?"],[4383,4542,"I can't bring your family back."],[4808,4984,"But they'll live on in our children."],[7407,7536,"How is this possible?"],[7536,7678,"Selene destroyed it."],[7795,7957,"There are benefits being an Alpha."],[8045,8149,"You're my fated mate,"],[8191,8291,"my True Luna."],[8345,8425,"My equal."],[8483,8725,"I bow to you as I never bowed before,"],[8762,8892,"and I never will."],[9267,9380,"Will you accept me?"]],"40":[[287,387,"They're fated mates!"],[417,563,"Kill her and he dies too."],[592,671,"Go Selene!"],[684,796,"Prove our bloodline!"],[859,1013,"Don't move."],[1042,1126,"Let her go."],[1130,1188,"No."],[1247,1418,"You don't get to take everything."],[1459,1593,"You don't get to take him,"],[1639,1822,"and the pack, and the bond."],[1876,1981,"And my brother."],[2235,2331,"Make me Luna."],[2548,2610,"Swear it,"],[2610,2736,"swear it in front of them all."],[2811,2952,"You stay back."]],"41":[[54,212,"You stay back."],[221,371,"That title was never yours."],[371,533,"Then I'll cut her open."],[579,750,"Your precious mate,"],[767,871,"your child,"],[892,942,"dead."],[1017,1230,"I was raised for this."],[1230,1309,"I was promised."],[1309,1543,"My father said I was born to be Luna."],[1568,1605,"Don't."],[1614,1697,"Stay back."],[1705,1864,"Selene, don't do this."],[1914,2081,"I am Luna."],[2152,2260,"I am Luna!"],[2790,2873,"No, get off me!"],[2907,3032,"I am your Luna!"],[3048,3107,"No."],[3132,3249,"You never were."],[3282,3440,"You will not harm our True Luna."]],"42":[[37,166,"You stupid little fool."],[216,304,"Did you really think"],[304,421,"you can outmatch her?"],[504,608,"Bring me the fire."],[692,784,"Wait, what?"],[792,900,"Wait, no, no, no."],[900,1038,"Rowan, no, please, no."],[1096,1176,"No, no!"],[1276,1459,"All you ever had was a face."],[1760,1860,"Pretty enough to lie."],[1910,2010,"Pretty enough to mask"],[2010,2110,"what you really are."],[2164,2235,"Jealousy."],[2260,2339,"Cruelty."],[2373,2531,"Rot wrapped in silk."],[2531,2610,"No, Rowan."],[2648,2806,"Rowan, please don't do, don't do it!"],[2806,2882,"Beg louder."],[2882,3023,"Please, don't do it!"]],"43":[[62,279,"I hereby exile you to the wilds"],[329,487,"beyond the borderlands,"],[521,700,"into the rogue territories."],[754,875,"Let the wild wolves"],[875,1038,"do what they have to do with you."],[1109,1238,"You'll have no name."],[1251,1355,"No pack."],[1388,1501,"No protection."],[1601,1768,"No, Alpha, please."],[1768,1856,"No, they're going to,"],[1901,2010,"They will kill me."],[2056,2173,"If you're lucky."],[2198,2339,"Please, please."],[2389,2531,"No, please just kill me."],[2627,2786,"Please, please, just kill me."],[2936,2990,"Huh?"],[3023,3128,"Please, Luna."],[3240,3365,"You could spare me."],[3428,3557,"You could show me mercy."],[3607,3766,"I, I bow to you."],[3837,3949,"Please, Luna."],[3962,4016,"Please."],[4066,4233,"I'll show you more compassion"],[4233,4329,"than you showed me."],[4667,4779,"Luna, please."],[4863,4950,"Leave, Selene."],[5025,5121,"Leave now."],[5150,5347,"With only the clothes on your back."],[5451,5588,"Leave and never return."]],"44":[[300,392,"Touching really."],[633,725,"All this show..."],[838,921,"the crown,"],[992,1071,"the ring,"],[1159,1263,"all the kneeling."],[1384,1526,"You destroyed my sister."],[1726,1897,"She deserved it, the fool."],[2010,2147,"But it won't matter anyway."],[2248,2481,"Your line will fail, Rowan!"],[2598,2865,"That baby inside her belly"],[2890,2969,"will die!"],[3103,3203,"If not by me"],[3253,3395,"then by someone else"],[3432,3553,"who challenges you"],[3657,3845,"and your weak Luna."],[3883,4091,"His bloodline will live."],[4483,4667,"Die knowing yours is lost."],[5413,5584,"Long live the Luna!"],[5609,5830,"Long live the Alpha!"],[6243,6343,"Don't ever"],[6418,6552,"lock me away again."],[6623,6715,"Never."],[6898,7011,"If we're to rule together,"],[7090,7207,"I need to be free."],[7269,7357,"Then you will be."],[7853,7991,"So will our child."],[8762,8871,"This is your Luna."],[8925,9075,"The last daughter of Azor."],[9129,9263,"My fated mate."],[9288,9367,"My equal."],[9376,9455,"My queen."],[9751,9876,"This throne was never meant to"],[9876,9976,"hold just one."],[10043,10147,"I love you, Mara."],[10222,10326,"We'll do this together."],[10427,10585,"Together, my love."],[11156,11327,"Long live the Luna!"],[11353,11549,"Long live the Alpha!"]]}