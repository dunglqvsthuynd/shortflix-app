 gonna"],[3616,3804,"call the cops on me, for her?"]],"42":[[29,179,"Are you serious?"],[179,370,"This tramp has been playing"],[370,495,"both you and Thomas"],[495,541,"and you're gonna"],[541,729,"call the cops on me, for her?"],[754,795,"Yeah."],[820,904,"I love Gloria."],[970,1145,"And she had nothing to do with this mess."],[1145,1279,"And if anyone has anything to say,"],[1308,1370,"come to me."],[1408,1483,"Leave her alone."],[1770,1983,"Thomas, aren't you gonna say anything?"],[2020,2120,"Gloria's been playing you."],[2120,2208,"Do you not care?"],[2241,2379,"I don't care about her past."],[2379,2583,"I care about her future with me."],[2804,2858,"Take them away."],[3158,3229,"You're all nuts!"],[3229,3441,"This whole family is insane!"],[4033,4104,"I'll take you home."],[4704,4766,"Thomas."],[5054,5183,"I'm sorry I lied to you."],[5241,5383,"Let's just end this engagement."],[5445,5545,"No, listen to me."],[5616,5679,"This engagement"],[5679,5808,"was just a game to me at first,"],[5958,6070,"but I've fallen in love with you."],[6195,6258,"Okay?"],[6629,6695,"Can you give me a chance"],[6695,6758,"to pursue you?"],[6916,6983,"Thomas,"],[7058,7208,"you're such a good guy."],[7270,7433,"But I can't lie to myself"],[7470,7537,"or to you."],[7645,7704,"Thomas,"],[7733,7833,"actually, I-"],[7845,7920,"It's not gonna happen."]],"43":[[312,350,"Come with me."],[512,637,"I'm not losing her again."],[662,812,"I'm not losing her to you."],[837,883,"No."],[883,1012,"Gloria's not going with you,"],[1012,1070,"okay?"],[1100,1225,"You guys broke up years ago."],[1258,1358,"Bringing her back into your life"],[1358,1475,"would only make things harder for her."],[1558,1633,"I can handle it."],[1687,1770,"You sure about that?"],[1870,1962,"I'm her fiancé."],[1995,2045,"The one who's gonna be"],[2045,2162,"standing next to her at the altar."],[2275,2375,"You're just a part of her past."],[2375,2458,"Shut up!"],[2500,2537,"No!"],[2633,2712,"Stop fighting!"],[3037,3112,"I can't let their"],[3112,3220,"relationship fall apart"],[3220,3287,"because of me."],[3316,3433,"I have to talk to Justin"],[3433,3533,"and set things straight."],[3812,3862,"No!"],[3937,4062,"That's enough, Justin!"],[4387,4462,"I'll go with you."],[4883,4933,"Don't worry."],[4933,5000,"I'll be fine."]],"44":[[37,150,"Justin, let's end it here."],[212,262,"I don't think"],[262,375,"we should be meeting anymore."],[375,500,"It's bad for everyone involved."],[500,550,"What?"],[550,587,"Hey."],[725,837,"Is it because of Thomas?"],[837,1000,"You finally succeeded."],[1041,1191,"Do I have to tie myself to you"],[1191,1337,"just because of our past?"],[1362,1437,"And so what?"],[1500,1662,"It's been impossible from the beginning."],[1775,1912,"Whoever I choose to be with in the future"],[1912,2012,"is none of your business."],[2250,2312,"Hey, no!"],[2312,2379,"No."],[2512,2562,"Dream on."],[3150,3212,"Stop it."],[3600,3650,"Justin!"],[3712,3775,"Stop it."],[3775,3837,"Let me go."],[3875,3937,"Calm down."],[4000,4100,"How do you expect me"],[4100,4270,"to calm down now, Gloria?"]],"45":[[1154,1220,"Hey."],[1454,1537,"You can stay here now."],[1604,1662,"If you need anything,"],[1662,1762,"just tell the housekeeper."],[1787,1850,"If you want to go anywhere,"],[1850,1925,"I'll take you myself."],[2012,2104,"That's ridiculous."],[2137,2254,"You can't control what I do."],[2254,2341,"I'm gonna go home."],[2404,2450,"Hey."],[2516,2625,"Your aunt and uncle's family"],[2625,2766,"are in the middle of a financial crisis."],[2804,2925,"The house just got repossessed."],[2987,3054,"Where are you gonna go?"],[3516,3600,"I'll be back."],[3800,3879,"Oh! And..."],[3891,4004,"take care of our home while I'm gone."],[4004,4062,"Okay?"],[4241,4300,"Our home?"],[5025,5091,"Yes?"],[5129,5279,"Gloria, it's Dr. Anderson."],[5300,5375,"Your mother's condition"],[5375,5466,"has suddenly worsened."],[5491,5654,"Please come to the hospital right away."]],"46":[[266,350,"I have to go."],[350,454,"It's an emergency!"],[1975,2037,"Gloria!"],[2954,3004,"Hey!"],[3016,3054,"Hey!"],[3125,3241,"I'm so glad you're okay."],[3279,3341,"Your mother's condition"],[3341,3441,"has suddenly worsened."],[3466,3612,"Please come to the hospital right away."],[3641,3741,"Justin, let go of me."],[3787,3829,"I need to go."],[3829,3862,"My mom..."],[3862,3916,"No, no, no."],[3916,3975,"It's okay."],[4004,4079,"I've got specialists"],[4079,4191,"looking after her right now."],[4241,4329,"The best surgeons"],[4329,4454,"are preparing for her surgery."],[4516,4629,"You knew about her condition?"],[4679,4741,"Yeah."],[4800,4929,"I figured you weren't marrying Thomas"],[4929,5029,"for any specific reason,"],[5029,5125,"so I looked into it."],[5154,5250,"I thought I could help you."],[5391,5504,"I even thought I could surprise you."],[5504,5562,"I don't know."],[5629,5729,"Thank you, Justin."],[5766,5866,"You don't need to thank me."],[5904,5991,"I just don't want you"],[5991,6150,"to be doing this alone, you know?"],[6175,6279,"I'm always going to be here for you."],[6279,6358,"I got your back."],[6358,6425,"You know that."]],"47":[[291,325,"Mom,"],[325,429,"what are you doing here?"],[429,562,"Good thing I came when I did."],[562,762,"This girl is trying to ruin you completely."],[762,854,"No, she's not."],[879,1012,"Mom, this is my decision."],[1075,1287,"Chelsea's in jail because of you."],[1287,1429,"You're fighting with your nephew"],[1429,1566,"over his fiancée?"],[1566,1716,"Is this woman really worth it?"],[1716,1762,"Yeah!"],[1816,1900,"She is."],[2554,2629,"Something urgent came up."],[2629,2716,"I'll be right back, okay?"],[2816,3000,"Mom, I get you're worried."],[3000,3191,"You know, this is between Gloria and I."],[3191,3254,"Trust me."],[3300,3425,"Let's talk when I get back, yeah?"],[3516,3566,"I'll be right back."],[3887,3966,"Mrs. Wilson-"],[3966,4066,"Shut up!"],[4141,4200,"Grandma!"]],"48":[[37,87,"Grandma!"],[162,225,"What are you doing?"],[308,475,"What is wrong with you and Justin"],[475,600,"fighting over this woman?"],[600,758,"What is so special about her?"],[758,912,"Do you not realize how much"],[912,1070,"you messed up Justin's career?"],[1070,1158,"Seven years ago,"],[1158,1300,"you said you'd stay out of it."],[1300,1375,"You left."],[1375,1475,"You came back."],[1475,1650,"You're dragging Thomas into this."],[1650,1845,"Are you trying to tear my family apart?"],[1883,1983,"So this is what happened"],[1983,2087,"seven years ago."],[2137,2237,"I'm sorry."],[2287,2475,"I don't want your apologies."],[2495,2708,"I want you to stay out of my son's life."],[2775,2883,"I know why you're here."],[2950,3025,"You want money."],[3025,3125,"Your family's bankrupt."],[3125,3187,"I brought it."],[3187,3300,"I got your cash."],[3300,3462,"I got all of this cash,"],[3462,3583,"and all of this is for you."],[3587,3650,"Grandma!"],[3650,3695,"I'm sick of you!"],[3695,3758,"Stop!"],[3850,3937,"This isn't fair."],[3975,4075,"Okay, apologize to Gloria."],[4075,4183,"She doesn't deserve this."],[4250,4362,"Apologize?"],[4412,4620,"She needs to apologize to me!"],[4758,4950,"Mrs. Wilson, I don't want your money."],[5087,5225,"But you're right about one thing."],[5308,5437,"This mess needs to stop."]],"49":[[375,466,"Doctor! Doctor!"],[541,625,"Where is the patient"],[625,700,"that was just in this room?"],[700,766,"Oh, she checked out"],[766,866,"about 30 minutes ago."],[950,1000,"Oh, God!"],[1225,1287,"Gloria!"],[1504,1562,"Gloria?"],[1829,1954,"Stop, sweetheart."],[1954,2100,"She left with Thomas."],[2225,2404,"No, that's impossible."],[2437,2516,"I'm gonna go find her."],[2516,2579,"No."],[2604,2800,"Gloria is not the woman for you."],[2804,2866,"Did you forget"],[2866,3004,"she left you seven years ago?"],[3079,3154,"No, Mom."],[3154,3229,"I didn't."],[3291,3379,"But I love her."]],"50":[[133,212,"I've already moved your mother"],[212,312,"to a different hospital."],[337,450,"So you don't have to worry about"],[450,612,"running into Justin when you visit her."],[725,800,"Thank you."],[1775,1875,"Are you sure you want to leave?"],[1958,2108,"If you can't do it, just stay."],[2400,2437,"No."],[2562,2662,"Mrs. Wilson is right."],[2808,2887,"Staying here will only"],[2887,2987,"make things worse for him."],[3333,3437,"Lucky Justin."],[3612,3758,"I wish I had met you first."],[3825,3962,"Maybe we'd have a different story."],[4100,4170,"I'm sorry."],[4237,4300,"It's alright."],[4308,4358,"I mean..."],[4462,4595,"I guess we're better off as friends."],[4750,4812,"So look."],[4845,4933,"Keep this on you."],[5025,5108,"If anything happens,"],[5108,5225,"I want to be the first to find you."],[6562,6645,"Where's Gloria?"]],"51":[[50,187,"A little late to the party, aren't you?"],[270,350,"Gloria is gone."],[350,437,"She's not coming back."],[437,500,"You're lying."],[558,633,"I'll find her."],[633,712,"Don't waste your time."],[775,875,"Alright, even if you do find her,"],[875,987,"it's not going to change anything."],[1050,1112,"You really think that"],[1112,1250,"Gloria left you seven years ago"],[1250,1370,"just because she got tired of you?"],[1475,1533,"What do you mean?"],[1770,1837,"When you turned down"],[1837,1975,"that job in Silicon Valley,"],[1995,2150,"your mom went to go visit Gloria."],[2183,2262,"I looked into it."],[2420,2575,"Gloria's dad took his life that day."],[2783,2950,"She broke up with you to protect you."],[3012,3058,"She didn't want to"],[3058,3141,"drag you down with her."],[3187,3308,"You're just as heartless as ever,"],[3308,3370,"you know that?"],[3420,3475,"Take it."],[3562,3658,"Put in the trash."],[3725,3820,"You've always been good at that."],[3983,4158,"I'm such an idiot, dude."],[4512,4633,"She must have been suffering."],[4775,4933,"I... I didn't even know."],[5162,5333,"Here, her location is on this."],[5512,5620,"Why are you helping me?"],[5887,6012,"I just want her to be happy."],[6195,6295,"Thank you."],[7062,7125,"Gloria!"]],"52":[[637,700,"Gloria!"],[770,825,"Get in here!"],[825,883,"Help!"],[895,950,"Help!"],[1412,1462,"Damn it!"],[2862,2962,"Did you have a good sleep?"],[2962,3012,"No."],[3175,3212,"Let go of me!"],[3212,3312,"This is kidnapping!"],[3350,3445,"This is illegal!"],[3812,3937,"Do I look like I care?"],[4050,4137,"Because of you,"],[4225,4400,"my family lost everything."],[4600,4683,"My mother wouldn't have"],[4683,4787,"taken her own life,"],[4825,4925,"if it wasn't for you."],[5000,5062,"Stop!"]],"53":[[95,145,"Stop!"],[320,404,"Well, well, well."],[445,558,"If it isn't Mr. Wilson."],[662,729,"So..."],[958,1070,"You here to play hero?"],[1095,1154,"Just let her go."],[1154,1333,"We'll, we'll work this out."],[1395,1470,"Whatever you want."],[1554,1633,"I can make it happen."],[1729,1783,"Anything?"],[1979,2020,"Justin."],[2020,2070,"Yeah."],[2091,2195,"Please, she's going insane."],[2195,2266,"Don't believe anything"],[2266,2341,"she's saying."],[2341,2408,"Just leave."],[2433,2483,"Please."],[2516,2616,"Shut up, bitch."],[2654,2716,"One more word"],[2716,2833,"and I'll blow your head right off."],[3091,3170,"Stay back!"],[3320,3404,"I'm staying back."],[3441,3541,"Just don't hurt her, okay?"],[3666,3716,"Look at me."],[3829,3904,"Whatever you want."],[3941,4008,"It's yours."],[4129,4208,"Aw,"],[4291,4429,"how cute."],[4533,4683,"Well, if that's the case,"],[4845,4941,"get on your knees."],[4983,5095,"And maybe I'll let her go."]],"54":[[300,354,"So."],[487,566,"Are you gonna do it?"],[712,829,"Don't forget."],[954,1075,"Gloria's life is in your hands."],[1075,1129,"Fine."],[1229,1291,"I'll do it."],[1379,1462,"Get on your knees."],[1500,1579,"No, Justin."],[1637,1691,"Please."],[1712,1816,"Please don't do this for me."],[1816,1891,"Just go."],[1891,1941,"Please."],[1941,2000,"Go!"],[2004,2091,"I'm not going anywhere."],[2191,2266,"Not this time."],[2425,2479,"No."],[2516,2604,"I did what you want."],[2704,2775,"Let her go."],[3079,3404,"You really went this far for her?"],[3450,3637,"What is so special about 