{"1":[[762,900,"I am Gloria Miller,"],[900,1050,"the richest girl in school."],[1204,1370,"Everyone wants to be me,"],[1416,1504,"but they don't know"],[1504,1666,"what makes me truly happy."],[1920,2066,"My name is Justin Wilson"],[2066,2229,"and I am a nobody."],[2295,2454,"I can only afford to be at this college"],[2454,2608,"because of my secret patron."],[2820,3054,"Gloria is the only one in the world that"],[3091,3245,"sees me for who I am and"],[3312,3450,"believes in who I can be."],[3637,3812,"We are the perfect couple"],[3812,3987,"even if no one else agrees."],[4200,4337,"You're finally back from Singapore!"],[4375,4425,"How was it?"],[4425,4512,"I want to hear all about"],[4512,4637,"your conference with Professor Brown."],[4675,4812,"He said I might have a real shot"],[4812,4887,"at launching my work."],[5050,5225,"The princess and the frog."],[5225,5400,"How did a loser like Justin"],[5400,5550,"even afford to be here?"],[5550,5633,"I bet his sugar mommy"],[5633,5770,"paid for everything,"],[5770,5975,"even the clothes he's wearing."],[6016,6079,"Do you want to go somewhere"],[6079,6141,"more private?"],[6383,6600,"Having a woman pay for your shit,"],[6600,6708,"it's pathetic."],[6708,6883,"It's all about Gloria Miller"],[6883,6970,"and her favorite"],[6970,7133,"rescue dog of the month."],[7570,7645,"Ignore them."],[7700,7762,"They're just jealous"],[7762,7850,"because you're talented."],[7879,7954,"I promise I'm going to"],[7954,8104,"work very hard every day"],[8154,8287,"just to be worthy of you."],[8287,8379,"You already are, babe."],[8650,8725,"By the way,"],[8762,8887,"if he's a rescue,"],[8887,9037,"you three are cockroaches."],[9091,9200,"The only thing I'd buy for you"],[9200,9337,"is pest control."],[9633,9683,"Ciao."],[10095,10158,"Here's the deal."],[10312,10362,"Flip a coin."],[10362,10475,"If it's heads,"],[10475,10650,"I will marry you right now."],[10687,10816,"And if it's tails..."],[10866,11000,"I'll just marry you when I'm rich"],[11000,11125,"then I can just give you everything."],[11529,11591,"Tails."],[11800,11900,"Looks like I'll just have to"],[11900,12016,"get crazy rich."],[12329,12550,"I could care less about money..."],[12550,12750,"because I know Justin is the one."],[12916,13112,"I can't wait to tell Dad about Justin."],[13166,13266,"Dad, guess what?"],[13350,13400,"Gloria."],[13675,13779,"I'm so sorry."],[13891,13975,"Dad!"],[14000,14062,"No!"],[14179,14275,"Joe,"],[14316,14475,"no!"],[14654,14750,"Mom, he wouldn't."],[14841,14925,"Linda,"],[14925,14987,"Gloria..."],[15037,15112,"the insurance company"],[15112,15187,"has changed"],[15187,15387,"the terms of our agreement,"],[15441,15587,"so we're not gonna get a penny."],[15587,15737,"We're gonna have to sell the house"],[15741,15854,"and everything of value."],[16216,16266,"No!"],[16266,16325,"Linda!"],[16325,16375,"Wake up!"],[16375,16412,"Linda!"],[16412,16504,"Mom, wake up!"],[16620,16820,"My whole family fortune is gone."],[16883,17012,"But I have to be strong"],[17012,17125,"for those I love."],[17795,17883,"Justin?"],[17991,18154,"He can never find out about this."],[18441,18537,"Mrs. Wilson,"],[18629,18750,"what are you doing here?"],[18750,18866,"I heard everything."],[18912,18979,"Mrs. Wilson,"],[18979,19120,"my family, they're-"],[19120,19445,"I am so sorry you're going through this,"],[19495,19683,"but you cannot tell my son!"],[19737,19945,"You cannot bring him into your mess."]],"2":[[8,200,"But you cannot tell my son!"],[200,362,"Professor Brown has invited Justin"],[362,412,"to go abroad."],[412,695,"He is the only student invited."],[695,787,"If he finds out about this,"],[787,870,"he won't go."],[887,1045,"I can wait for him, please."],[1225,1437,"I raised him as a single mom."],[1437,1562,"After his father died,"],[1562,1787,"I worked like a dog."],[1787,1958,"Day and night to get him through school."],[1958,2137,"He is so close to success."],[2137,2225,"That is your"],[2225,2425,"godforsaken mother in there, in a coma,"],[2425,2570,"for God knows how long."],[2575,2695,"That is your burden."],[2845,2925,"Okay."],[3025,3133,"I understand."],[3375,3425,"Here."],[3512,3637,"$50,000 for the Porsche."],[3787,3833,"I can't even believe"],[3833,3950,"you're selling it for so cheap."],[4045,4258,"This is my last gift to you, Justin."],[4733,4862,"My future starts today,"],[4887,4941,"and I need you"],[4941,5108,"to be there with me, Gloria."],[5150,5345,"I've spent everything I have on this, but..."],[5408,5575,"you deserve so much more."],[6062,6112,"Hey."],[6258,6320,"Um..."],[6408,6450,"There's something"],[6450,6537,"I've been meaning to tell you."],[7050,7220,"Gloria Miller, will you-"],[7220,7262,"There's something"],[7262,7350,"I need to tell you, too."],[7387,7500,"Can I go first, please?"],[7500,7525,"This is-"],[7525,7612,"I'm breaking up with you."],[8212,8287,"That's not..."],[8358,8437,"that's not funny."],[8462,8625,"It's been fun, Justin."],[8625,8875,"But you really are my little rescue dog."],[8962,9108,"We've been dating for two years."],[9108,9187,"You said you loved me."],[9287,9350,"Love."],[9395,9575,"Justin, you know my family's"],[9575,9687,"worth billions, right?"],[9700,9745,"Yeah."],[9745,9925,"So it's time I get serious"],[9937,10150,"and be with someone of my own kind."],[10200,10325,"And what's this?"],[10370,10508,"You call this a diamond ring?"],[11833,11895,"Hey, babe!"],[11895,12000,"You're finally here!"],[12725,12837,"Oh my God, is he serious?"],[12837,12950,"He's not a real man."],[12970,13050,"Not like you."],[14425,14487,"The ring!"],[15050,15120,"Gloria, stop!"],[15120,15195,"You're bleeding!"],[15287,15358,"No..."],[15400,15512,"No, I have to find the ring!"],[16220,16345,"I'm sorry, Justin."],[16408,16475,"Forget me."],[17075,17158,"To the airport."],[17325,17520,"Gloria Miller, you are a liar."],[17545,17687,"And you're gonna regret this."]],"3":[[191,333,"Mr. Wilson, your company,"],[333,420,"Wilson Enterprise,"],[420,533,"launched in Singapore."],[533,662,"It's now taking Silicon Valley"],[662,712,"by storm."],[762,825,"What's next"],[825,941,"now that you're back in the States?"],[1062,1104,"I have some"],[1104,1212,"unfinished business here."],[1387,1466,"Something I should have dealt with"],[1466,1587,"years ago before I left."],[1800,1866,"Hey you!"],[1941,2091,"Go make yourself look presentable."],[2304,2375,"What for?"],[2400,2500,"You should know that"],[2500,2641,"the head of Wilson Enterprise"],[2641,2812,"has requested to marry you"],[2812,2891,"to his nephew."],[3116,3162,"What?"],[3187,3300,"No, I won't."],[3300,3429,"Your mom is in a hospital"],[3479,3579,"in a coma."],[3800,3966,"And if I pulled my support,"],[4000,4066,"then you won't be able"],[4066,4200,"to afford the medical bills."],[4375,4512,"You two are disgusting."],[4554,4666,"I'm not doing this."],[4704,4816,"Tina, sweetheart,"],[4816,4904,"call the hospital"],[4904,4937,"and tell them"],[4937,5116,"we're cancelling all payments."],[5166,5208,"No."],[5241,5304,"Wait!"],[5566,5666,"Changed your mind?"],[5916,6016,"That was fast."],[6362,6429,"I'll marry"],[6429,6512,"the nephew."],[7104,7241,"If it's not you, Justin,"],[7291,7416,"I guess it really doesn't matter"],[7416,7491,"who I marry."],[8079,8212,"You better not mess this up."],[10816,10987,"This is the nephew?"],[11062,11179,"You must be Gloria Miller."],[11237,11316,"My future bride."],[11579,11716,"You're hotter than I thought you'd be."],[11779,11854,"I want to set something"],[11854,11929,"straight with you."],[12037,12166,"Don't piss off my uncle."],[12262,12416,"I'll be as invisible as I can be."],[12516,12579,"Good."],[12641,12775,"Let me introduce you to my family."],[13179,13341,"Dad, meet my future bride,"],[13387,13450,"Gloria Miller."],[13675,13766,"Where's Uncle Justin?"],[13787,13875,"I thought he'd be here by now."],[13941,14025,"Justin?"],[15254,15441,"Wait, that sound!"],[15529,15604,"Sorry, everybody."],[15637,15750,"The interview went a little longer"],[15750,15837,"than anticipated."],[15904,15979,"This voice..."],[16029,16104,"It can't be."],[16979,17112,"How could this be?"],[17279,17441,"Tell me the truth, Gloria,"],[17462,17554,"because..."],[17675,17804,"my feelings have never changed."]],"4":[[58,187,"It's been seven years."],[250,387,"He looks so different."],[1095,1250,"Do you know my uncle or something?"],[1433,1495,"No."],[1570,1787,"I just didn't know your uncle was..."],[1850,1950,"the Justin Wilson."],[2170,2320,"So it's time I get serious"],[2329,2391,"and be with someone"],[2391,2491,"of my own kind."],[2633,2862,"Now you're with your own kind, Gloria."],[2925,3075,"Justin, is this why"],[3075,3175,"you brought me here?"],[3270,3395,"Don't just stand there."],[3395,3500,"Introduce yourself."],[3587,3812,"I'm Gloria, Thomas's fiancée."],[3895,3987,"It's nice to meet you."],[4562,4720,"Dad, Uncle Justin,"],[4720,4862,"I asked to marry Gloria."],[4875,5025,"And after meeting her in person,"],[5025,5200,"I'm even more sure now."],[5237,5325,"I mean,"],[5337,5462,"we call it love at first sight."],[5558,5770,"You rejected the love you deserve, so..."],[5895,6033,"Now I'll give you the love you want."],[6037,6087,"Why would you"],[6087,6233,"punish me like this, Justin?"]],"5":[[62,170,"Call it love at first sight."],[425,595,"Well, if that's how it's gonna be,"],[595,725,"then let's set a date for the wedding."],[745,900,"Oh lovely, and the trust fund?"],[900,970,"Hold on."],[1087,1200,"Gloria Miller, right?"],[1500,1583,"Marrying Thomas."],[1825,2037,"And that's what you want?"],[2237,2350,"What's that supposed to mean?"],[2362,2437,"Let her speak."],[3100,3295,"If this is what you want, Justin."],[3533,3583,"Yes,"],[3700,3837,"I want to marry Thomas."],[3937,4245,"So this is who you really are."],[4425,4487,"Very well then."],[4825,5012,"It's not like he still cares about you."],[5062,5208,"It's been seven years."],[5375,5508,"Are you sure you don't know my uncle?"],[5537,5725,"Your face went pale when you saw him."],[5883,6175,"Well, since we'll all be family soon,"],[6237,6450,"please stay the night."],[6475,6633,"The estate is huge,"],[6633,6725,"and I would love to"],[6725,6883,"give you guys a tour tomorrow."],[6908,7045,"If it isn't too much trouble."],[7045,7158,"Of course not."],[7158,7337,"Besides, we should give"],[7337,7500,"Thomas and Gloria some time"],[7500,7612,"to get to know each other."],[7787,7850,"What?"],[7850,8012,"Staying in the same house overnight"],[8012,8075,"as Justin?"]],"6":[[1491,1608,"Thomas is mine."],[1633,1804,"I won't let him marry this skank."],[1945,2158,"Ms. Miller, your room's all set."],[2158,2291,"It's all the way at the end of the hall"],[2291,2395,"on the second floor."],[2620,2783,"Have fun in Justin's room."],[2808,2945,"Thomas will be furious"],[2945,3041,"when I tell him."],[4029,4083,"Justin!"],[4133,4233,"What are you doing here?"],[4295,4395,"I should be asking you that."],[4395,4491,"This is my room."],[5095,5183,"The letter G."],[5208,5366,"When did he get this tattoo?"],[5579,5633,"Are you done?"],[5970,6158,"So what are you doing in my room?"],[6229,6345,"Are you here to tell me"],[6345,6529,"that my kind are beneath you?"],[6541,6625,"Or..."],[6833,7033,"Or are you here to tell me the truth?"],[7475,7645,"Justin, I know you must hate me."],[7675,7850,"But I've never stopped loving you."]],"7":[[41,133,"It was an accident."],[208,320,"That maid set me up."],[320,391,"Why?"],[495,658,"You know, seven years ago"],[658,808,"you told me you were marrying Owen."],[870,1058,"Now, you're engaged to my nephew."],[1108,1245,"I'm sorry, but you're a liar"],[1245,1358,"and I don't believe a single thing"],[1358,1466,"you say to me anymore."],[1666,1745,"Why does my heart"],[1745,1866,"still hurt looking at her?"],[2041,2141,"If that's how you feel,"],[2141,2241,"then let go of me."],[2316,2383,"I'll leave."],[2520,2608,"Let you go?"],[2683,2745,"I'm sorry."],[2745,2883,"I'm not that noble."],[3770,3870,"Have you guys seen Gloria?"],[3904,4045,"I've been looking all over for her."],[4070,4129,"She said she was"],[4129,4183,"going to the bathroom,"],[4183,4345,"but it's been like 20 minutes."],[4345,4458,"We've been looking for her too."],[4458,4629,"We've searched the entire house."],[4654,4879,"I saw Ms. Miller head into the last room"],[4879,4991,"on the second floor."],[5129,5233,"What the fuck is she doing"],[5233,5312,"in my uncle's room?"]],"8":[[0,175,"What is that little tramp thinking?"],[250,329,"If she does anything"],[329,441,"to ruin this engagement,"],[441,587,"I'm gonna make her pay for this."],[1916,1979,"No!"],[2016,2179,"Justin, we can't do this."],[2266,2337,"This isn't right."],[2337,2504,"I'm, I'm engaged to your nephew now."],[2579,2704,"Engaged to my nephew?"],[2762,2941,"Tell me, do you even love him?"],[3041,3150,"It doesn't matter."],[3241,3375,"He's the man I'm gonna marry."],[3529,3604,"I'm sorry."],[3604,3745,"I don't think I can let that happen."],[5941,6066,"No, Justin, you can't."],[6137,6241,"I'm going to."],[8329,8454,"Uncle Justin, have you seen Gloria?"],[8554,8637,"We're looking for her."],[8825,8966,"Your fiancé is right outside."],[8966,9062,"What are you going to do?"],[9129,9241,"Uncle Justin, are you there?"],[9387,9450,"Please, Justin."],[9541,9666,"I can't have them see me here."],[9666,9745,"Help me."],[9791,9854,"I'll help you."],[9904,9991,"Under one condition."],[10100,10204,"Call off the engagement."],[10279,10354,"I can't."],[10429,10516,"Or Mary and Tina"],[10516,10641,"will stop my mom's treatment."],[10779,10854,"Why does she insist on"],[10854,10950,"marrying Thomas?"],[11112,11166,"Hey!"],[11229,11266,"Fine."],[11391,11504,"Let's see how Thomas reacts"],[11533,11729,"when he finds his fiancée"],[11729,11866,"in his uncle's room"],[11866,12016,"wearing nothing but a towel."],[12266,12329,"Oh, no."]],"9":[[225,316,"Is everything alright in there?"],[833,954,"Alright, I'm coming in."],[1825,1987,"So my room is open to everyone now."],[1987,2154,"Sorry, it's just Gloria's missing"],[2154,2229,"and I don't know,"],[2229,2291,"I thought maybe..."],[2291,2479,"You thought I was hiding her in here?"],[2616,2704,"That's not what I meant."],[2729,2791,"Then leave."],[2908,2991,"Now."],[4316,4412,"You're crossing the line."],[4454,4616,"Uncle Justin, I just need to know"],[4616,4700,"if she's in here."],[4754,4887,"Okay, are you really hiding her in there?"],[4912,5066,"Mr. Wilson, please don't be upset."],[5066,5254,"We're just concerned about disturbing you."]],"10":[[616,700,"You in a rush?"],[700,916,"You want me to step out"],[916,1004,"so you guys can flip my room"],[1004,1162,"upside down again or what?"],[1216,1329,"Look, I'm sorry, Uncle Justin."],[1329,1437,"I got carried away."],[1529,1604,"We'll leave now."],[3354,3450,"I hate you."],[3679,3804,"Did I take it too far?"],[4125,4262,"You bitch!"],[4262,4416,"Did you really try to sneak in there"],[4416,4525,"and seduce Mr. Wilson?"],[4566,4700,"This is none of your business."],[4741,4895,"Don't forget,"],[4895,5054,"you're Thomas's fiancée now."],[5116,5191,"And if I catch you"],[5191,5366,"sneaking around with Mr. Wilson,"],[5412,5641,"I'll end your mom's treatment right away."],[5729,5875,"This is none of your business."],[5891,6004,"Don't boss me around."],[6050,6162,"If you go back on your word"],[6162,6216,"about my mom,"],[6216,6450,"I will end this engagement myself."],[6662,6729,"No!"],[6766,6912,"I have to make sure she marries Thomas"],[6912,7016,"as soon as possible."]],"11":[[208,279,"Morning."],[550,675,"Thomas wanted me to tell you"],[675,820,"to take these vitamins."],[875,1000,"He said it'll make you feel better."],[1108,1179,"Thank you."],[1937,2037,"And when you're done,"],[2037,2225,"he said he wanted to meet you."],[2400,2483,"Had a surprise"],[2483,2575,"or something to give you."],[2812,2858,"Okay."],[4812,4883,"Thomas?"],[5025,5091,"Hello?"],[5808,5958,"Enjoy the little surprise"],[5958,6120,"I planned for you, Gloria."],[6600,6725,"Thomas!"],[6770,6950,"Just the person I was looking for."],[7012,7133,"Gloria wanted me to tell you"],[7133,7300,"that she has a surprise for you"],[7333,7391,"in your room."],[7562,7629,"Cool."],[8750,8825,"Hello?"],[8900,9000,"Open the door!"],[9083,9175,"Open the door!"]],"12":[[891,945,"Gloria?"],[995,1054,"What happened?"],[1195,1316,"I..."],[1316,1441,"Justin I feel"],[1495,1608,"I feel light-headed."],[1704,1783,"I'm burning."],[2008,2145,"Didn't you say Gloria was waiting for me?"],[2245,2308,"Where is she?"],[2333,2416,"Damn it!"],[2445,2570,"Where the hell did she go?"],[2783,2883,"I saw Ms. Miller"],[2883,2983,"heading into the study"],[2983,3095,"with Mr. Wilson."],[3133,3266,"They seemed pretty close."],[3770,3837,"Stop it."],[3895,3983,"Do you know what you're doing?"],[4145,4220,"Don't..."],[4308,4395,"Don't push me away."],[4491,4579,"I need you."],[5958,6108,"Was that Gloria?"],[6145,6216,"Damn it!"],[6258,6420,"I can't let this bitch get away with it."]],"13":[[1437,1479,"Justin."],[2891,2962,"You have no idea"],[2962,3112,"how bad I want you right now."],[4775,4929,"She's asleep."],[5979,6062,"Are you feeling better?"],[6187,6254,"Yes."],[6350,6466,"Sorry I was so much trouble."],[6487,6575,"I should go."],[6575,6641,"No, no."],[6891,6991,"Why are you still wearing this?"],[7816,7925,"You still love me, don't you?"],[8100,8250,"No, no, you're overthinking it."],[8341,8400,"And don't forget,"],[8400,8566,"I'm your nephew's fiancée now."],[8629,8750,"Show me a little respect."],[8904,9062,"Let's see if I'm overthinking this."]],"14":[[175,216,"Hey."],[295,337,"Hey."],[1404,1479,"No, Justin."],[1600,1679,"We can't do this."],[1737,1879,"I'm engaged to Thomas now."],[1954,2066,"This isn't fair to him."],[2179,2279,"You left me seven years ago"],[2279,2341,"and now you're engaged"],[2341,2404,"to my nephew."],[2491,2591,"How is that fair to me?"],[2716,2929,"Are you still hurting because of me?"],[3366,3454,"You owe me this."],[4379,4587,"God, Justin, you're such an asshole."],[4612,4741,"Why'd you have to push her like that?"],[4791,4900,"She's never gonna forgive you."],[5200,5275,"I'm so sorry..."],[5275,5404,"I didn't... I wasn't thinking..."],[5791,5966,"Thomas, slow down."],[5966,6091,"I'm sure we'll find her."],[6329,6400,"Thomas."],[6504,6641,"Your uncle was really upset about us"],[6641,6741,"barging in yesterday."],[6741,6816,"Maybe we shouldn't."],[6816,6900,"I have every right to know"],[6900,6991,"where my fiancée is."]],"15":[[516,608,"They're not here."],[670,720,"Maybe we should check"],[720,783,"somewhere else?"],[1033,1108,"Thomas?"],[1166,1233,"It's the second time"],[1233,1316,"you barge into my room"],[1316,1391,"without knocking."],[1466,1608,"We're so sorry for barging in,"],[1608,1679,"Mr. Wilson."],[1679,1804,"We were just..."],[1804,1879,"Uncle Justin,"],[1879,1970,"Tanya said she saw you"],[1970,2095,"and Gloria near the study."],[2095,2220,"I can't find her anywhere."],[2220,2370,"So you came to search my room."],[2458,2545,"Have you found anything?"],[2591,2695,"You searched every corner of the room"],[2695,2779,"and she's not here."],[2808,2858,"Leave."],[2995,3108,"There's one place I haven't checked."]],"16":[[479,541,"Enough."],[612,691,"Get out of my room."],[991,1054,"And you?"],[1125,1216,"Go get your mom."],[1241,1316,"Leave my house."],[2016,2191,"Thomas, slow down."],[2191,2300,"I'm sure we'll find her."],[2341,2487,"I can't let them see me in here."]],"17":[[125,279,"Ugh, that was close."],[316,391,"One more second,"],[391,487,"and my thing with Justin"],[487,641,"would have been totally exposed."],[1754,1816,"Justin..."],[1866,1916,"Don't move"],[1916,2066,"if you don't want anyone to see us."],[2716,2779,"If it hurts,"],[2779,2900,"you can squeeze my shoulder."],[3129,3229,"Okay, thank you."],[4441,4525,"Thank you, I..."],[4541,4604,"Wait."],[4829,5004,"Tell me, was there ever a moment"],[5004,5079,"you kept the ring"],[5079,5162,"because you thought..."],[5354,5429,"you couldn't let go?"],[5516,5650,"Maybe I should be brave."],[5666,5766,"Just this once."],[5891,5979,"Justin!"],[6050,6229,"I've missed you so much."]],"18":[[0,87,"Justin!"],[150,316,"I've missed you so much."],[375,537,"What are you doing here, Chelsea?"],[625,725,"I invited her."],[779,937,"Don't you think it's time"],[937,1116,"that you figure things out with Chelsea?"],[1150,1287,"Thomas is settled now."],[1325,1400,"What about you?"],[1516,1675,"Seems like he's already moved on,"],[1691,1866,"and is in love with someone else."],[1866,2066,"I'm just letting you know"],[2066,2216,"what your mother wants."],[2216,2400,"You know she's not in the best health."],[2400,2537,"And Chelsea has been"],[2537,2687,"looking after her in LA."],[2687,2866,"Now that she's back,"],[2866,3025,"we should make her feel welcome."],[3162,3312,"What are you still expecting?"],[3375,3450,"It's over."],[3466,3612,"Now, you two lovebirds"],[3612,3650,"come with me."],[3650,3775,"I've got something to show you."],[4562,4637,"There you are."],[4637,4766,"I've been looking all over for you."],[4825,4900,"Don't leave just yet."],[4900,5025,"I've got a surprise for you later."],[5875,5979,"I still can't believe"],[5979,6129,"Gloria is engaged to my nephew."],[6225,6329,"Am I too late?"],[6604,6762,"Oh, sorry Uncle Justin."],[6825,6916,"I didn't know you were in here."],[6950,7012,"It's alright."],[7025,7150,"There's room for two of us."],[7462,7637,"So, uh, about last night."],[7654,7750,"I don't want to talk about it."],[7987,8175,"Look, I... I just wanted to apologize."],[8204,8237,"Okay?"],[8237,8337,"For barging in like that."],[8400,8500,"You know, I was just..."],[8562,8675,"just worried about Gloria."],[8716,8800,"She's my fiancée."],[8800,8962,"And, uh, you know me."],[8987,9037,"I'm not a..."],[9154,9250,"one-woman man."],[9250,9304,"But, uh..."],[9362,9454,"you know, I actually like her."],[9575,9612,"I didn't think"],[9612,9700,"I would at first. - Just stop."],[9850,9925,"Just don't."],[10062,10200,"So, uh, how do you like it"],[10200,10300,"being back in the States?"],[10379,10487,"I've lived in Singapore for years."],[10487,10550,"It's- I don't know."],[10550,10637,"It's a little hard to adjust to,"],[10637,10812,"but I'll get there eventually."],[10887,10937,"Yeah."],[11162,11287,"So, if I may ask,"],[11287,11412,"what made you come back?"],[11662,11725,"Oh my God,"],[11725,11829,"I'm so sorry."],[11829,11900,"I had no idea"],[11900,12000,"someone was in here."],[12037,12112,"It's all good."],[12175,12262,"Oh, no."],[12275,12425,"I need to leave this house,"],[12425,12562,"or these awkward situations"],[12562,12641,"will keep happening."],[12679,12825,"What mess did I get myself into?"],[13100,13270,"Hey, what does that G stand for anyways?"]],"19":[[2295,2483,"Gloria, I hope you like everything"],[2483,2595,"I prepared for you tonight."],[3416,3483,"May I have the honor of"],[3483,3629,"sharing dinner with you, Ms. Miller?"],[3720,3820,"Think of your mother."],[3841,3970,"Just go along with it."],[4466,4545,"Thank you."],[5508,5595,"Surprise."],[6312,6412,"Wow."],[6545,6654,"Don't you two look like"],[6654,6766,"the perfect couple?"]],"20":[[204,354,"Hope you don't mind us"],[354,537,"witnessing this special moment."],[612,712,"No, of course not."],[2662,2741,"Justin, if you keep"],[2741,2837,"staring at her like that,"],[2837,2991,"I'm gonna start getting jealous."],[3229,3391,"So, you're Gloria, right?"],[3491,3591,"You're lucky."],[3637,3854,"Your fiancé seems to really care about you."],[3854,3916,"Gloria's the one"],[3916,4066,"I want to spend the rest of my life with."],[4104,4279,"It's my responsibility to take care of her."],[4525,4625,"Until you walk her down the aisle,"],[4625,4691,"nothing's guaranteed,"],[4691,4762,"my friend."],[5041,5137,"Isn't that right, Gloria?"],[5250,5337,"You're right, Uncle Justin."],[5337,5516,"I owe Gloria a proper proposal."],[5716,5929,"Gloria, will you marry me?"],[6025,6141,"I promise I'll make you happy."],[6304,6466,"Are you really gonna say yes, Gloria?"],[6625,6775,"I'm sorry, I'm not feeling well."],[6854,6979,"I need to go to the restroom."],[7245,7320,"Okay."],[7379,7491,"Calm down, Gloria."],[7554,7629,"You can do this."]],"21":[[166,225,"Justin."],[1529,1666,"Justin, what the hell are you doing?"],[1841,1987,"Why do you keep defying me, Gloria?"],[2250,2491,"Justin Wilson, what do you want?"],[2604,2666,"I want you to call off"],[2666,2775,"the engagement with Thomas."],[2979,3075,"Of course not."],[3075,3166,"Are you crazy?"],[3479,3537,"No."],[3716,3837,"Are you really in love with him?"],[3862,3979,"It's none of your business."],[4041,4154,"You should worry about Chelsea."],[4154,4304,"I... I need to go."],[4304,4416,"Thomas is waiting for me."],[4516,4579,"Gloria?"]],"22":[[158,291,"Is he really that important to you?"],[591,695,"If Thomas did see us,"],[695,833,"maybe he would call off the engagement."],[1458,1558,"Gloria, you in there?"],[2141,2241,"It's been ten minutes."],[2858,2958,"What's going on in there?"],[3004,3083,"Alright, I'm coming in."],[3229,3304,"Please, Justin."],[3345,3429,"We can't get caught."],[3429,3629,"My mom's treatment depends on this."],[5158,5216,"Gloria?"]],"23":[[1891,1941,"Hey."],[3050,3179,"Are you having fun messing with me?"],[4179,4341,"What was he doing in there with her?"]],"24":[[250,312,"Gloria."],[429,487,"Where'd you go?"],[487,562,"I was getting worried."],[616,704,"Sorry, I..."],[704,779,"Something urgent came up."],[779,925,"I have to leave and go home."],[1087,1204,"Is it because you didn't like the ring?"],[1266,1291,"No!"],[1291,1354,"No, no, no."],[1354,1425,"Of course not."],[1454,1541,"It was perfect."],[1566,1679,"Thank you, Thomas."],[1804,1841,"Alright."],[1841,1966,"Well, I'm glad you liked it."],[2004,2141,"It's Chelsea's birthday in two days"],[2141,2250,"and she invited us."],[2316,2412,"Should I pick you up then?"],[2529,2600,"Yeah."],[2891,3062,"Maybe you could wear this."],[3137,3204,"See if you like it."],[3316,3412,"Yeah, sure."],[3854,3912,"Thank you."],[3912,3975,"Goodnight."],[5950,6016,"Don't you think"],[6016,6191,"you're a little out of place here?"],[6191,6295,"Keep your dirty hands"],[6295,6437,"off the merchandise."]],"25":[[66,183,"I'm... I'm sure I can look at"],[183,300,"whatever I want."],[362,487,"Oh, please."],[525,704,"You think you can afford this?"],[704,837,"Stop embarrassing yourself"],[837,929,"and just leave."],[929,1150,"You're lowering the store standard."],[1191,1266,"You're right."],[1375,1479,"With employees like you,"],[1479,1687,"it's just a waste of time anyway."],[1850,2012,"You little..."],[2191,2275,"The diamond ring"],[2275,2425,"Mr. Garrett told us to watch,"],[2425,2504,"it's gone."],[2504,2666,"That ring is worth a fortune."],[2666,2854,"If we don't find it, we're screwed!"],[2987,3066,"I knew it."],[3116,3304,"You stole it, didn't you?"],[3304,3500,"Hand over the ring, you thief!"],[3812,3862,"What?"],[3891,3954,"No!"],[4016,4129,"Where is it?"],[4304,4412,"I bet you're hiding it"],[4412,4587,"under that outfit of yours."],[4712,4812,"Stop!"]],"26":[[875,1004,"Mr. Garrett, this woman"],[1004,1179,"touched the jewelry without permission,"],[1179,1379,"and she stole the diamond ring!"],[1491,1591,"Justin, I didn't..."],[1591,1704,"I swear, I didn't..."],[1704,1766,"It's fine."],[1841,1916,"I believe you."],[2066,2137,"Are you kidding me?"],[2187,2304,"Why would she steal anything?"],[2354,2454,"I could literally buy her"],[2454,2554,"anything she wants."],[2704,2816,"And you, seriously?"],[2866,2975,"Is this how we're training our staff"],[2975,3062,"to treat customers?"],[3100,3279,"Is he really standing up for me?"],[3304,3475,"I'm really sorry, Mr. Wilson."],[3491,3679,"There's clearly been a misunderstanding."],[4062,4179,"Are you kidding me?"],[4216,4366,"Quit making the stuff up!"],[4400,4591,"That ring has been locked in the safe"],[4591,4729,"the whole time!"],[4804,4904,"Falsely accusing someone"],[4904,5000,"without any proof."],[5029,5166,"Well, you should really learn"],[5166,5279,"when to keep your mouth shut."],[5329,5387,"Guys,"],[5466,5537,"rough her up."],[5654,5891,"No, Mr. Garrett, please help me!"],[5891,6041,"Get your hands off of me!"],[6041,6150,"You're fired!"]],"27":[[37,91,"Take her away."],[125,250,"I don't ever want to see her again."],[908,983,"Mm..."],[1179,1254,"What do we think?"],[1279,1329,"I..."],[1329,1500,"This is perfect."],[1500,1587,"Let's wrap this one up for me."],[1600,1654,"Please."],[1654,1704,"Thank you."],[1791,1837,"Ooh!"],[1966,2166,"Could we wrap up all the new pieces?"],[2191,2275,"It's for her."],[2595,2662,"Thanks."],[2929,3066,"I'm glad you stood up for me, but..."],[3179,3341,"this is all a little much."],[3504,3654,"You think I did all this to defend you?"],[3850,3929,"Mr. Wilson,"],[4137,4250,"this is the sapphire ring"],[4250,4391,"that you reserved last month."],[4416,4579,"A fifty million dollar piece."],[4579,4741,"You live off of financial aid."],[4775,4829,"What makes you think"],[4829,4929,"you're good enough for me?"],[5116,5216,"And what's this?"],[5266,5412,"You call this a diamond ring?"],[5579,5687,"Don't make me laugh."],[6179,6316,"What was I thinking?"],[6379,6454,"Of course it's for"],[6454,6604,"Chelsea's birthday tomorrow."],[6666,6766,"He doesn't even remember"],[6766,6866,"mine is today."]],"28":[[187,262,"Hold on a sec."],[475,545,"Seven years ago,"],[545,670,"you said I wasn't good enough"],[670,712,"and I couldn't"],[712,812,"give you what you wanted."],[887,958,"You know, I worked..."],[979,1175,"very, very hard,"],[1262,1362,"just to prove you wrong."],[1525,1587,"So what?"],[1695,1850,"You regret leaving me, Gloria?"],[2487,2595,"Happy birthday."],[2762,2933,"I promised I was gonna get you"],[2933,3095,"a nice, big ring."],[3095,3150,"Remember?"],[3212,3325,"He remembered."],[3458,3562,"I've been lying to myself"],[3562,3637,"this whole time,"],[3637,3762,"pretending I moved on."],[3845,3900,"But I'm actually"],[3900,4062,"still in love with you, Gloria."],[4150,4283,"Will you give us another chance?"],[4362,4445,"Don't forget."],[4520,4675,"You're Thomas's fiancée now."],[4737,4812,"And if I catch you"],[4812,4987,"sneaking around with Mr. Wilson,"],[5025,5162,"I'll end your mom's treatment."],[5183,5262,"Right away."],[5433,5562,"Seven years, Justin."],[5650,5812,"And you're still just as gullible."],[5887,6045,"Don't you remember how I left you?"],[6312,6425,"You're just as heartless as ever,"],[6425,6483,"you know that?"],[6537,6595,"Take it."],[6687,6783,"Put it in the trash."],[6845,6929,"You've always been good at that."]],"29":[[504,550,"Hey."],[704,962,"Thomas, what are you doing here?"],[987,1070,"Well, you seemed"],[1070,1154,"a little bummed last night"],[1154,1225,"when leaving,"],[1225,1450,"so I thought I'd stop by and say hi."],[1466,1529,"That's sweet."],[1616,1704,"I guess you're right."],[1729,1850,"You met me at a very strange time"],[1850,1916,"in my life."],[2016,2104,"Maybe this will cheer you up."],[2725,2775,"Not that."],[2775,2841,"Wrong gift."],[2904,3091,"But maybe you'll like this."],[3354,3508,"Wow, Thomas, you..."],[3575,3666,"you shouldn't have."],[3700,3791,"I thought it would go well"],[3791,3875,"with the dress I got you"],[3875,3966,"for tomorrow evening."],[4091,4179,"I hope you'll like it."],[4204,4291,"Thank you, Thomas."],[4291,4404,"It's... it's beautiful."],[4487,4579,"I can't wait to wear it."],[4866,4954,"I should go inside."],[5016,5079,"My aunt probably"],[5079,5175,"needs me for something."],[5241,5358,"Alright, I'll leave you to it then."],[5412,5454,"I'm excited for you"],[5454,5562,"to leave this place for good,"],[5562,5662,"and come move in with me."],[5766,5854,"That would be sweet."],[5891,5962,"All right."],[6029,6104,"I'll see you tomorrow."],[6304,6429,"It could really be sweet."],[6466,6604,"Thomas is such a nice guy."]],"30":[[1104,1154,"Hello?"],[1154,1291,"It's Ben, Justin's friend."],[1316,1479,"He's drunk and he keeps asking for you."],[1504,1587,"I've got to go now,"],[1587,1716,"but I don't want to leave him alone."],[1737,1841,"Can you come over for a bit?"],[1966,2066,"Yes, alright."],[2066,2166,"I'll be there soon."],[3204,3304,"Oh, thank you."],[3362,3437,"Good luck."],[3941,4000,"Justin."],[4187,4229,"Hey."],[5000,5141,"Justin, stop."],[5316,5404,"I've worked so hard"],[5404,5487,"to give you what you want."],[5837,5954,"Why can't you look at me?"],[6129,6191,"Hey,"],[6266,6466,"I guess you just don't love me anymore."],[6704,6841,"No, it's not that."],[6904,6987,"I actually..."]],"31":[[1420,1566,"Justin's already taken."],[1612,1679,"You can't keep"],[1679,1812,"messing up his new life."],[3691,3866,"Stop drinking so much."],[3875,3979,"It's not good for you."],[4925,5062,"I'm so sorry I'm late."],[5129,5304,"Dear God, she's too beautiful"],[5304,5404,"for my own good."],[5591,5750,"Oh, no, you're right on time."],[5775,5966,"And you look beautiful."],[6041,6154,"Both the dress and the necklace"],[6154,6325,"look stunning on you."],[6325,6387,"Thank you."],[6554,6616,"Let's go."],[7800,7866,"I'll be back."],[7866,8016,"Feel free to walk around."],[8916,9079,"What the hell are you doing here?"]],"32":[[95,262,"What the hell are you doing here?"],[275,487,"This is the Smiths' family birthday party."],[525,637,"You shouldn't be here."],[637,687,"So just leave"],[687,837,"before you embarrass yourself."],[900,1000,"Thomas invited me."],[1062,1195,"You have no right to make me leave."],[1250,1345,"Oh, please."],[1345,1437,"Like anyone would invite"],[1437,1587,"a freeloader like you."],[1608,1650,"You're just here"],[1650,1833,"to pull some desperate stunt."],[1850,1937,"I'm warning you,"],[1937,2075,"know your place."],[2133,2408,"Just focus your time on marrying Thomas."],[2425,2500,"Don't forget,"],[2525,2662,"your mother's life depends on it."],[2975,3100,"She's just like her mother,"],[3120,3225,"just needs a good slap."],[3425,3570,"Say whatever you want about me,"],[3612,3775,"but don't talk about my mom like that."],[3987,4112,"Have you lost your mind?"],[4112,4275,"How dare you hit my daughter?"],[5116,5195,"Help!"],[5500,5575,"Please!"],[5933,5995,"Help!"],[6150,6312,"Oh, what are you gonna do now?"],[6400,6475,"Help!"],[6625,6683,"Please!"],[7062,7170,"Gloria!"]],"33":[[104,162,"Help!"],[316,366,"Please!"],[1275,1341,"Help!"],[1641,1716,"Help!"]],"34":[[75,125,"Gloria!"],[187,233,"Gloria!"],[283,333,"Gloria!"],[387,437,"Wake up!"],[1595,1662,"Thank you, Justin."],[1725,1837,"I... I can walk on my own."],[2145,2370,"Oh, you're all wet."],[2625,2758,"Let's get you into dry clothes."],[3308,3450,"You pushed my fiancée into the pool."],[3483,3583,"You think I'll let that slide?"],[3583,3787,"Mr. Franco, this is a misunderstanding."],[3800,3908,"She slipped in by herself."],[3908,3937,"Yeah."],[3937,4045,"We didn't do anything."],[4045,4145,"We didn't push her."],[4145,4200,"No, no."],[4237,4312,"I know what I saw."],[4375,4512,"Guys, throw them in the pool."],[4545,4637,"Let's see how they like it."],[4687,4725,"What?"],[4750,4837,"You can't do this to us."],[4837,4950,"No, get your hands off my daughter!"],[4950,4987,"Let-"],[4987,5137,"Oh, and cut ties with the Miller family."],[5137,5200,"Get off my daughter!"],[5200,5262,"No more business with them."],[5262,5350,"Get off me!"],[5375,5433,"Get off!"],[5433,5512,"Get your hands off!"],[5512,5612,"Get off my daughter!"],[6483,6558,"We need to talk."],[6658,6712,"Now."]],"35":[[75,133,"So,"],[320,562,"you're in love with Gloria, aren't you?"],[662,712,"Yeah."],[887,1012,"I've always been in love with her."],[1037,1137,"Is she the girl you broke up with"],[1137,1220,"seven years ago?"],[1587,1725,"You two are done."],[1787,1900,"She's my fiancée now."],[1945,2008,"You got that?"],[2070,2220,"That's between Gloria and me."],[2262,2375,"Let's not forget"],[2375,2562,"that Tina was supposed to be"],[2562,2645,"your fiancée."],[2987,3100,"I'm not giving up on her."],[3612,3700,"Sorry, Thomas."],[3812,3912,"I'm not giving up on her either."],[4925,5050,"You fucking bitch!"]],"36":[[129,241,"You fucking bitch!"],[379,487,"Are you crazy?"],[516,625,"What is wrong with you?"],[666,762,"Crazy?"],[779,954,"Not when it comes to someone like you."],[979,1129,"You deserve worse than this."],[1229,1404,"Stringing along your fiancé,"],[1404,1566,"while cozying up to his uncle?"],[1591,1666,"Does Thomas even know"],[1666,1866,"what kind of snake he's engaged to?"],[1866,2012,"I am not a snake."],[2041,2104,"Right."],[2137,2250,"Keep telling yourself that."],[2291,2454,"But I'm only going to say this once."],[2454,2612,"Stay away from Justin."],[2704,2779,"He's mine."],[3416,3591,"Make sure she puts this on"],[3591,3641,"and I'll throw in"],[3641,3804,"a little something extra for you."],[3825,3937,"Yes, Ms. Smith."],[4395,4529,"Justin's mine."],[4616,4816,"You don't stand a chance, bitch."]],"37":[[391,479,"Ladies and gentlemen,"],[600,650,"welcome to"],[650,837,"Mrs. Smith's birthday celebration."],[887,1050,"Let's get this party started with a dance."],[1075,1225,"Find your partners and hit the floor."],[1354,1433,"Gloria, may I - Gloria, may I"],[1433,1516,"have this dance? - have this dance?"],[1629,1691,"Geez."],[1716,1825,"What's wrong with them?"],[2479,2550,"Justin,"],[2591,2729,"Gloria is your nephew's fiancée."],[2729,2841,"Isn't it a little weird for you"],[2841,2950,"to make a joke like that?"],[3254,3354,"Come on, Justin."],[3354,3479,"It's my birthday today."],[3775,3879,"After all the time I spent"],[3879,4000,"keeping your mother accompanied,"],[4000,4066,"you're not really gonna"],[4066,4216,"leave me here all alone, are you?"],[5654,5750,"Alright, everyone."],[5775,5904,"It's time for a partner switch."],[6445,6504,"Oh..."],[6562,6666,"Nice, Uncle Justin."]],"38":[[408,512,"If you don't stop fighting back,"],[512,570,"I'm gonna kiss you"],[570,662,"in front of everyone."],[1037,1075,"What?"],[1150,1225,"You don't believe me?"],[1562,1662,"That bitch."],[1712,1875,"Your fiancée doesn't seem very loyal."],[1912,1983,"If you have a problem"],[1983,2054,"with my uncle,"],[2054,2270,"you can take it out on him, not Gloria."],[2320,2362,"Okay?"],[2362,2500,"She doesn't deserve your accusations."],[2933,3000,"So why did you come over"],[3000,3083,"when I was drunk?"],[3475,3575,"You still love me, don't you?"],[4016,4183,"I... umm..."],[4354,4433,"I..."],[5250,5337,"Alright, everyone."],[5358,5400,"Let's get this"],[5400,5537,"birthday celebration started."],[5570,5783,"Give it up for the birthday girl!"],[5954,6008,"There she is!"],[6158,6350,"Sweetheart, this is for you."],[6383,6695,"It's a custom-made $30 million gown"],[6695,6812,"for my one and only."],[6950,7058,"It's one of a kind."],[7175,7287,"Thank you, Mom."],[7370,7458,"I love it."],[7487,7570,"You're welcome."],[8033,8112,"What the hell?"]],"39":[[133,216,"What the hell?"],[345,433,"What is going on?"],[433,566,"Where is her dress?"],[933,1158,"Why are you wearing my daughter's dress?"],[1483,1595,"I'm sorry, Ms. Miller."],[1595,1791,"I can't keep your secret any longer."],[2104,2229,"Did you steal it?"],[2254,2441,"I can't believe Mr. Franco's fiancée"],[2441,2583,"stole from the birthday girl."],[2583,2745,"That's so embarrassing."],[2858,2954,"Wait."],[2954,3091,"Wasn't Mr. Franco engaged"],[3091,3229,"to her cousin, Tina?"],[3283,3495,"I heard Gloria's family went bankrupt"],[3495,3616,"and now she's literally"],[3616,3766,"freeloading off of her aunt."],[3804,4020,"People like her don't belong here."],[4279,4408,"Get out of here, you thief!"],[4691,4820,"You're so embarrassing!"],[5316,5445,"I didn't steal anything."],[5604,5716,"Why are you lying?"],[5716,5820,"Oh, stop denying it."],[5845,6033,"This is the dress I bought Chelsea."],[6033,6179,"It's one of a kind."],[6179,6320,"I invited you as a friend"],[6320,6470,"and this is how you repay me?"],[6545,6708,"Gloria, I'm so disap