{"1":[[571,675,"Congratulations,"],[675,775,"Miss Hollinger."],[846,1042,"you're six weeks pregnant"],[1042,1188,"with twins."],[1280,1443,"Pregnant?"],[1443,1705,"But I'm 45 years old."],[2198,2306,"Hi."],[2444,2552,"Um..."],[2619,2798,"Sorry."],[3057,3103,"Oh..."],[3582,3645,"Your card’s declined."],[3937,4074,"That...That's impossible."],[4074,4225,"I, I just got paid."],[4225,4320,"Can you try it again?"],[4600,4767,"Your card is declined."],[4767,4875,"Oh...Um."],[5059,5196,"Oh...Um."],[5196,5309,"Here."],[5505,5559,"We stopped"],[5559,5705,"accepting cash years ago."],[6177,6327,"If you can't afford lunch,"],[6385,6544,"then you need to move."],[7173,7294,"Dumb bitch."],[7349,7532,"Can't even afford lunch."],[7570,7657,"Broke, right?"],[7657,7853,"Yeah, broke every day."],[7853,7995,"Yeah, eats lunch on the floor..."],[8608,8704,"Brandon,"],[8704,8896,"did you drain my account again?"],[8896,9029,"I brought Rose a new MacBook."],[9029,9109,"If I don't keep my girlfriend"],[9109,9221,"happy, she'll break up with me."],[9221,9296,"Is that what you want?"],[9296,9384,"Son."],[9384,9530,"Rent is due on Friday."],[9597,9822,"I'm two months behind."],[9822,9980,"I'm going to get evicted."],[9980,10080,"You'll figure it out."],[10080,10160,"You always say family"],[10160,10235,"comes first, right?"]],"2":[[1222,1372,"Who is that?"],[2260,2410,"May I suggest someone a"],[2410,2660,"bit younger, sir,"],[2681,2752,"for the sake of"],[2752,2898,"securing an heir."],[2898,2965,"The investors"],[2965,3115,"have been very clear."],[3115,3207,"If you don't provide one"],[3207,3428,"by your 55th birthday,"],[3428,3507,"your family will"],[3507,3699,"lose the company."],[3699,3841,"I know what the investors want"],[3841,3970,"Greg."],[4045,4295,"It just doesn't matter."],[4437,4567,"I’m infertile."],[4567,4646,"Well,"],[4646,4688,"the younger"],[4688,4779,"the woman, the better"],[4779,4950,"the chances."],[4950,5013,"There's no use"],[5013,5196,"longing for a future"],[5196,5447,"that can't exist."],[5889,5985,"You."],[5985,6235,"Maid."],[6348,6539,"Me? Oh."],[6656,6844,"Yes?"],[6844,6977,"Get the presidential suite"],[6977,7257,"ready for a special night."],[7403,7528,"Rose petals."],[7528,7670,"Champagne."],[7670,7874,"The whole nine."],[7874,7924,"There's more"],[7949,8053,"where that came from."],[8053,8237,"If you help them seal the deal."],[8237,8437,"Seal the deal."],[8437,8512,"Does he want me to"],[8512,8612,"sleep with his boss,"]],"3":[[29,83,"He’ll be up"],[83,191,"there with a hot"],[191,337,"date in an hour."],[337,475,"So you better work quick."],[692,834,"Of course he doesn’t."],[905,1017,"I’m just an old maid."],[1455,1597,"You never look twice"],[1597,1718,"at any of the women"],[1718,1851,"I set you up with."],[2669,2765,"An aphrodisiac will"],[2765,2852,"get him in the mood."],[2857,2944,"Plus..."],[2944,3153,"A little blue pill to keep him going all"],[3153,3257,"night long."],[5242,5367,"You drugged me."],[5401,5513,"You deserve to have"],[5513,5626,"some fun boss."],[5626,5714,"Trust me."],[5914,5997,"You're going to have a great"],[5997,6089,"time tonight."],[6339,6423,"Hi..."],[7482,7582,"Okay."],[8224,8366,"George Sullivan?"],[8366,8554,"I’m cleaning for the CEO"],[8554,8692,"of this hotel?"],[9592,9688,"I..."],[9813,9943,"Was feeling."],[10214,10326,"So..."],[10343,10485,"Sir. Are you..."],[10548,10618,"Oh!"]],"4":[[83,204,"I know you."],[383,650,"You’re the woman from earlier today."],[1021,1184,"You're so beautiful."],[1251,1351,"No one’s called me beautiful"],[1351,1480,"in such a long time."],[1668,1826,"I find that hard to believe."],[2360,2540,"I haven't,"],[2540,2640,"I haven't done this in years."],[2640,2748,"Are you..."],[2748,2857,"Are you sure?"],[3265,3436,"I'll go slow."],[3436,3611,"Just tell me what you like."],[3770,3870,"Tell me."],[3908,4079,"This feels so good..."],[4149,4337,"I haven’t been touched in so long..."],[4996,5125,"Hey."],[5296,5405,"You don't need to worry."],[5405,5497,"I'm,"]