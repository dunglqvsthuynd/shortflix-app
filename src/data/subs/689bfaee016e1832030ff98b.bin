h?"],[8108,8258,"I don’t feel very good..."],[8733,8804,"Good."],[8825,8900,"Got to go."],[9059,9142,"Jesus."],[9188,9284,"Mr. Sullivan."],[9409,9547,"Fancy seeing you here..."]],"16":[[529,771,"How could I forget morning sickness."],[855,1067,"I'm 45 now..."],[1113,1267,"Could my body really handle"],[1267,1393,"another pregnancy?"],[1668,1776,"George?"],[2314,2431,"The hotel manager..."],[2481,2648,"She’s young and beautiful"],[2648,2840,"and George is rich and handsome..."],[2986,3240,"She’s obviously more his type."],[3853,3933,"We don't carry"],[3933,4083,"orthopedic footwear here."],[4112,4275,"There's a Goodwill around the corner."],[4379,4462,"I heard you stayed at"],[4462,4567,"our presidential suite"],[4567,4696,"the other night."],[4696,4842,"Next time, you should call me."],[4925,5059,"As the hotel manager."],[5084,5167,"I have access"],[5167,5359,"to all premier services."],[5497,5651,"I can get you anything"],[5651,5755,"you want."],[6231,6502,"I'm the CEO of the hotel."],[6531,6677,"I could have you fired"],[6731,6886,"for propositioning me."],[7027,7232,"I have everything that I need now."],[7294,7374,"So..."],[7457,7565,"If you’ll excuse me?"],[7949,8003,"Excuse me,"],[8003,8103,"I was just-"],[8103,8229,"Did you wash this?"],[8229,8337,"or did you come straight"],[8337,8458,"from scrubbing toilets?"],[8458,8525,"I work at a"],[8525,8654,"five star hotel..."],[8850,9046,"More like a seedy motel."],[9063,9146,"You better get out of here"],[9146,9209,"before you spread"],[9209,9313,"lice in here."],[9313,9392,"There's a..."],[9421,9588,"Strip mall across the street."],[9588,9776,"That's more your speed."],[9830,9914,"I bet you eat nothing"],[9914,10047,"but fast food."],[10047,10214,"Poor people always do."],[10214,10281,"If you weren't"],[10281,10364,"old enough to be"],[10364,10439,"my grandma,"],[10439,10489,"I'd say"],[10489,10660,"that you look pregnant."],[10727,10827,"Now get out of here"],[10827,10952,"before I call security"],[10952,11069,"an