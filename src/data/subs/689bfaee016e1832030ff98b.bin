 would do anything to"],[7611,7753,"hurt you or your family."]],"62":[[70,125,"I had nothing"],[125,175,"to do with this."],[175,279,"You have to believe me."],[387,600,"You convinced us to do this."],[646,775,"You even promised us money"],[775,938,"if we got her to leave town."],[984,1184,"Yeah and she gave us a syringe"],[1184,1284,"to get her to go to sleep."],[1322,1426,"Liars!"],[1438,1505,"George,"],[1518,1593,"you can't believe"],[1593,1689,"them over me."],[1689,1743,"Come on."],[1743,1881,"They come from trash."],[1922,2056,"You and I grew up together."],[2056,2143,"They're lying."],[2189,2344,"Who are you calling trash?"],[2452,2531,"No one."],[2531,2652,"I'm just saying"],[2669,2761,"that I had nothing"],[2761,2852,"to do with this."],[2886,2994,"And you swear this"],[2994,3174,"on your family legacy?"],[3265,3336,"What?"],[3378,3486,"What does my family have to do"],[3486,3545,"with this?"],[3553,3620,"I told you"],[3620,3807,"to stay away from us Amy."],[3824,3933,"And out of respect"],[3933,4041,"to your father."],[4066,4145,"Your punishment"],[4145,4383,"was a little less severe"],[4458,4679,"than I would have liked, but"],[4704,4796,"you didn't listen."],[5284,5334,"I..."],[5363,5568,"I...That-that is not me."],[5568,5663,"They're setting me up."],[5663,5864,"I swear to god that’s AI."],[5930,6022,"You're going to prison."],[6106,6218,"All of you are."],[6464,6594,"Lock her up for life."],[6673,6752,"And make sure there's no"],[6752,6861,"chance of parole."],[6902,6977,"You got it, boss."],[7040,7107,"Let's go."],[7127,7365,"George! You can’t do this George!"],[7599,7707,"Let’s go."],[8646,8775,"Hey."],[8833,8963,"You're awake."],[8963,9113,"Mommy's awake."],[9430,9522,"Harper..."],[9597,9693,"Are you okay?"]],"63":[[25,137,"I'm just..."],[325,433,"I never imagined I"],[433,554,"could be this happy."],[725,855,"Feels like a second chance."],[1176,1334,"At family..."],[1443,1539,"Life..."],[1780,1931,"After Brandon, I just..."],[2064,2206,"I never thought anyone"],[2260,2402,"would treat me this way,"],[2519,2623,"so kindly."],[2877,3044,"Go with Auntie Victoria."],[3044,3182,"There you go."],[3328,3453,"Bye guys."],[3762,4054,"Well, they are beautiful."],[4250,4400,"And it's just the beginning."],[4496,4587,"I plan on giving you"],[4587,4821,"the world Harper Sullivan."],[4859,5013,"Are you sure about this?"],[5125,5205,"Us..."],[5305,5451,"Raising twins together"],[5451,5563,"at our age?"],[5714,5780,"Is it too late to"],[5780,5889,"change my mind now?"],[6352,6448,"I knew"],[6527,6748,"the moment I laid eyes on you."],[6856,6973,"Then I'm the luckiest"],[6973,7057,"woman alive."],[7086,7219,"I'm the lucky one."],[7732,7907,"I'm never gonna let you go."],[7978,8074,"Even though I did"],[8074,8183,"nothing but"],[8183,8287,"cause you trouble"],[8287,8429,"ever since we met?"],[8537,8650,"Right back at you."],[8875,9088,"I love you Harper Sullivan."],[9230,9392,"I love you too, George."]]}