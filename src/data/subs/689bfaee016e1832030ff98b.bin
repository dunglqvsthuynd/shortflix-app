at's all over"],[12107,12274,"the internet right now."]],"30":[[450,550,"Who’s that?"],[704,950,"Am I...Jealous?"],[1451,1522,"Harper."],[1597,1697,"Harper. What's wrong?"],[1722,1801,"Nothing."],[1918,1968,"Look at me."],[1968,2089,"A grown woman crying."],[2089,2181,"Pathetic."],[2206,2448,"I'm fine, I'm fine."],[2489,2615,"I can tell when you're lying."],[2656,2740,"He's the father"],[2740,2848,"of my children."],[2890,3023,"I should be able to tell him"],[3023,3111,"the truth."],[3219,3303,"Hey..."],[3566,3749,"You don't have to be fine."],[3874,3970,"Not with me."],[3970,4049,"Okay?"],[4104,4237,"It's my son."],[4425,4704,"He wants five million dollars."],[4838,4979,"And the staff at my hotel."],[4979,5071,"They're spreading lies"],[5071,5209,"about me online."],[5438,5547,"But you don't have to save"],[5547,5630,"me, I..."],[5705,5855,"I can handle this on my own."],[5976,6072,"No, you won't."],[6364,6523,"I'm gonna handle everything."],[6523,6594,"What?"],[6594,6685,"Why?"],[6915,6969,"Never mind."],[6969,7040,"I know the answer."],[7040,7132,"The babies."],[7298,7374,"Harper,"],[7444,7661,"it's not just the babies."],[7703,7782,"Look at me."],[7928,8058,"It's you."],[8370,8525,"I want you to be my wife."],[8754,8871,"I want you"],[8942,9104,"to be Mrs. Sullivan."],[9134,9242,"For real."],[9271,9359,"George,"],[9401,9555,"you don't have to do that."],[9851,9964,"I know we're both older,"],[9964,10130,"but we still have time. You..."],[10130,10285,"You deserve to marry"],[10285,10406,"someone you really love."],[10456,10581,"Why not you, Harper?"],[10581,10714,"Why not you?"],[10785,10869,"George we come from"],[10869,10994,"different worlds."],[11094,11319,"I have no money to my name."],[11319,11394,"I'm a maid."],[11453,11586,"You. Your family."],[11586,11703,"You're rich, powerful."],[11703,11732,"I'm."],[11732,11849,"I'm not."],[12153,12303,"None of that matters to me."],[12358,12449,"None of it."],[12608,12683,"Just..."],[13175,13292,"Is there something wrong?"],[13425,13530,"No. You're just."],[13580,13659,"Yeah."],[13763,13813,"You're different"],[13813,13959,"than I expected..."],[14122,14360,"But in a...In a good way."],[15177,15269,"Oh."],[15482,15628,"It's because of you."],[15724,15819,"You make me a..."],[15986,16086,"A better man."]],"31":[[1801,1893,"Everything alright?"],[1939,2043,"All taken care of."],[2127,2185,"Good."],[2344,2489,"You wanted to see me?"],[2827,2944,"We are going to send"],[2944,3086,"a strong message"],[3086,3232,"to your son and his friends."],[3591,3682,"Care to join me?"],[3774,3924,"Strong message?"],[4079,4175,"You won't regret it."],[4366,4450,"Yeah, okay."],[5246,5305,"Harper."],[5459,5526,"If any of this"],[5526,5684,"feels like it's too much,"],[5801,5905,"just let me know."],[5905,5980,"Okay?"],[6210,6297,"Okay."],[6327,6418,"It's gonna be fine."],[6564,6644,"Let's go."],[7132,7257,"Oh, oh."]],"32":[[75,166,"You okay?"],[271,358,"Do you want to leave?"],[500,579,"No."],[654,738,"I'm fine."],[738,813,"Good."],[909,984,"But what are you gonna do"],[984,1034,"with them?"],[1046,1180,"Well, then- Please just"],[1217,1301,"release us."],[1401,1534,"We’re really sorry."],[1593,1693,"We’ll, disappear."],[1789,1893,"Just let us go."],[1918,2002,"Sorry."],[2039,2118,"I think you all need"],[2118,2227,"to be taught a lesson."],[2252,2427,"Nobody messes with my wife."],[3211,3378,"No! No!"],[3470,3674,"We’ll be good this time! I swear!"],[3766,3870,"It's your lucky day."],[3937,4045,"Just so happens"],[4095,4225,"my wife is one of the"],[4250,4487,"kindest women that I know."],[4742,4813,"Just escort him"],[4813,4900,"out of the city."],[4979,5130,"And if any of you"],[5180,5288,"dare to come back."],[5351,5442,"Well, then there's"],[5442,5538,"no stopping me."],[5563,5643,"Get em’ out."],[5868,5926,"You okay?"],[6085,6164,"Oh, now"],[6164,6331,"here is our guest of honor."],[6352,6489,"Right on time."],[6644,6723,"Oh!"],[7082,7148,"Mom?"],[7211,7265,"Brandon!"]],"33":[[29,237,"You are nothing"],[237,425,"but a heartless whore."],[458,575,"You abandoned-"],[575,692,"You watch your tone"],[692,817,"when you address Mrs. Sullivan."],[992,1038,"Oh..."],[1142,1197,"Oh, I see"],[1197,1326,"she belongs to you now."],[1447,1509,"Well, since this is"],[1509,1647,"purely transactional,"],[1747,1864,"here's what I propose."],[1981,2243,"You cover my expenses"],[2314,2502,"for the rest of my life,"],[2602,2702,"and I go away."],[2765,2823,"After all,"],[2823,2890,"it's only fair"],[2890,2965,"that you provide"],[2965,3069,"for your stepson."],[3820,3908,"Your mother"],[3958,4175,"belongs to nobody but herself."],[4204,4266,"You!"],[4379,4542,"You don’t deserve my money."],[4562,4671,"Get him outta here."],[4671,4738,"Wait wait wait"],[4738,4796,"wait wait wait wait wait!"],[4796,4971,"Stop! Where are they taking me?"],[4971,5009,"Stop!"],[5009,5063,"Wait, please."],[5063,5155,"I'm your son!"],[5201,5405,"You don't owe him anything."],[5405,5505,"He's a monster."],[5980,6068,"Let him go."],[6189,6331,"But if you ever"],[6452,6614,"try to hurt me"],[6635,6785,"or your siblings again"],[6823,7015,"there's no saving you."]],"34":[[475,571,"What you did back there"],[571,734,"Harper was brave."],[984,1080,"You faced them,"],[1247,1347,"and you let them go."],[1534,1614,"I wish it didn’t"],[1614,1705,"come to that."],[1797,1935,"He’s still my son."],[1985,2056,"Hey."],[2177,2289,"And he can still hurt you."],[2414,2552,"I respect you,"],[2602,2798,"I do, for showing him mercy."],[2857,2944,"But as long as he's"],[2944,3053,"walking free."],[3336,3420,"I'm not going to stop"],[3420,3532,"worrying about you."],[3899,3970,"Hey."],[4145,4275,"I want you close to me."],[4562,4683,"I want you safe."],[4971,5030,"I want you to move"],[5030,5117,"into my bedroom."]],"35":[[437,571,"I'm across the hall."],[633,729,"A lot of people out there"],[729,846,"trying to hurt you."],[934,1059,"I know, I’d rest"],[1059,1192,"a lot easier at night"],[1276,1397,"knowing you're not alone."],[1518,1735,"But don't you have bodyguards?"],[1755,1839,"Please."],[1935,2022,"For me?"],[2260,2398,"We can have seperate duvets."],[2473,2527,"Keep my hands"],[2527,2615,"to myself."],[2773,2890,"Unless you don’t want me to."],[3073,3144,"Okay."],[3236,3294,"Good."],[3328,3411,"I’ll move in."],[3411,3478,"Good."],[4308,4379,"Let's go."],[5084,5284,"Time? -2:34, sir."],[5284,5367,"Oh, man."],[5455,5526,"Getting old."],[5597,5684,"Nonsense. You’re an"],[5684,5776,"oceanic predator."],[6106,6181,"You know what?"],[6268,6393,"I want Harper to feel"],[6393,6523,"like she's appreciated."],[6577,6698,"Like she belongs."],[6769,6915,"Let’s throw her a birthday party"],[6915,7002,"at the hotel."],[7027,7165,"Just invite everybody."],[7223,7336,"Just really want to show her..."],[7440,7553,"What she means to me."],[7611,7678,"Yes sir."],[7753,7857,"Make us some money."],[7999,8145,"Also. Mr. Sullivan"],[8145,8237,"wants to gift"],[8237,8366,"Miss Hollinger..."],[8408,8583,"Miss Hollinger?"],[8583,8725,"Surely he doesn’t mean that"],[8725,8929,"middle aged housekeeper..."],[8929,9084,"Is there a problem?"],[9217,9367,"No, not at all."],[9476,9542,"I can’t wait to"],[9542,9605,"meet the woman"],[9605,9755,"Mr. Sullivan chose"],[9755,9897,"and replace her."],[10005,10130,"As I was saying,"],[10143,10276,"Mr. Sullivan will give her"],[10276,10431,"the diamond engagement"],[10431,10510,"ring in front of"],[10510,10606,"the whole crowd."],[10631,10694,"She'll need to be"],[10694,10781,"on stage for that."],[10881,10981,"Absolutely."],[11136,11336,"That rock is worth millions."],[11373,11519,"I’m the one he should give it to."]],"36":[[221,337,"Last week, I was"],[337,462,"a poor hotel maid."],[462,604,"And now I'm sleeping"],[604,717,"in a billionaire's bed"],[717,863,"carrying his twins."],[1092,1217,"I can't remember the last time"],[1217,1317,"I slept with someone."],[1655,1814,"I mean, slept"],[1885,2060,"next to someone."],[2590,2681,"Me neither."],[2848,3082,"Is he...Telling the truth?"],[3757,3832,"Good night."],[3974,4045,"Good night."],[5447,5547,"I want her."],[5726,5880,"But I promised I’d keep my hands"],[5880,5980,"to myself."],[6097,6331,"I can wait until after the engagement."],[9013,9109,"Bad hair day?"],[9138,9259,"It's Couture."],[9346,9505,"What is this?"],[9563,9630,"Oh..."]],"37":[[20,125,"We’re throwing a birthday"],[125,279,"party for you tomorrow."],[279,350,"It's called"],[350,563,"the Diamond Ball."],[563,834,"I booked the best French designer"],[834,1026,"to make you a custom dress."],[1026,1188,"Diamond Ball?"],[1405,1559,"That's-that's too much."],[1559,1755,"I-I'd be happy with a..."],[1793,1893,"Chocolate cake."],[1893,2002,"Oh..."],[2093,2289,"You're part of the family now."],[2364,2473,"You deserve"],[2473,2677,"the most fabulous celebration."],[2882,3123,"Diamon Ball!"],[3236,3357,"Who is this woman"],[3357,3486,"Mr. Sullivan is throwing a party"],[3486,3566,"for anyway."],[3595,3774,"She can only be royalty."],[3828,3903,"I heard he might be"],[3903,4029,"finally settling down"],[4029,4091,"with her."],[4158,4275,"Well, I won't give up on him"],[4275,4433,"until he's actually married."],[4471,4596,"Neither will I."],[5442,5593,"That's her?"],[5593,5684,"It can't be."],[5684,5935,"She's so...Old."],[6081,6151,"That dress"],[6151,6252,"does nothing for her"],[6252,6343,"body shape."],[6343,6423,"I mean, ever"],[6423,6548,"heard of Spanx, grandma?"],[6664,6769,"One look at us."],[6769,6835,"George will fold"],[6835,6927,"like a lawn chair."],[6965,7015,"Watch this."],[7328,7407,"We need to go."],[7741,7774,"Hey hun"],[7774,7891,"why don’t you go find yourself"],[7891,7978,"something to drink."],[7978,8074,"There’s a little matter"],[8074,8128,"I..."],[8208,8324,"Need to take care of."],[8362,8445,"Need to make sure the"],[8445,8637,"engagement ring is worthy of her."],[8758,8850,"But I don't know"],[8850,8938,"anyone here."],[8983,9100,"You're the guest of honor."],[9154,9275,"These people would be"],[9321,9434,"lucky to get to"],[9434,9530,"speak to you."],[9530,9597,"Okay?"],[9747,9813,"I'll be back."],[9843,9997,"You look beautiful too."],[11198,11273,"Oh!"],[11302,11403,"Watch it!"],[11453,11528,"Where are your"],[11528,11686,"glasses, granny?"]],"38":[[16,183,"You bumped into me."],[241,333,"How dare you?"],[371,558,"You are talking to the heiress"],[558,688,"of the Muir Corporation."],[750,863,"Mr. Sullivan's number"],[863,946,"one partner?"],[967,1076,"And you look like you"],[1076,1230,"can't afford Botox"],[1242,1401,"or Weight Watchers."],[1418,1568,"Who even invited you here?"],[1630,1801,"What is that old maid"],[1801,2018,"doing here dressed like that?"],[2060,2156,"She should be cleaning"],[2156,2268,"the hotel rooms."],[2268,2381,"Apologies"],[2381,2481,"for my staff's"],[2481,2602,"incompetence."],[2656,2848,"Clean this up immediately."],[2907,3090,"That's the hotel manager, does she"],[3090,3199,"not know I quit?"],[3211,3303,"I-I don't..."],[3303,3382,"I don't work here."],[3382,3474,"You need to remember"],[3474,3574,"where you belong."],[3574,3670,"Down with the staff."],[3670,3737,"Not up here"],[3737,3824,"in the ballroom."],[3845,3995,"So clean this up and leave"],[3995,4129,"before I call security."],[4149,4262,"I'm a guest here."],[4262,4421,"George invited me."],[4421,4483,"I.."],[4625,4713,"Sure."],[4763,4846,"Is that why you got"],[4846,4979,"all dressed up and decided"],[4979,5075,"to sneak in here"],[5092,5163,"hoping to land"],[5163,5280,"your next sugar daddy?"],[5347,5434,"Yeah."],[5472,5622,"I heard about the rumors"],[5622,5826,"about you sleeping around for money,"],[5868,6097,"but our CEO would never go"],[6097,6272,"for some old leftovers"],[6272,6460,"when he has a deluxe five course"],[6460,6594,"meal in front of him."],[6594,6669,"George will be here"],[6669,6773,"any minute now,"],[6815,6902,"and he will tell you"],[6902,7027,"that he invited me."],[7161,7265,"How sad."],[7332,7478,"These washed up old women,"],[7499,7682,"they're so delusional."],[7682,7857,"Do you really believe that?"],[7857,8099,"I am not delusional- -Enough!"],[8099,8287,"You are an embarrassment"],[8299,8408,"to Mr. Sullivan."]],"39":[[408,542,"Mr. Sullivan, I was just"],[542,604,"What?"],[684,863,"Harassing the most important"],[863,975,"woman here?"],[1096,1217,"This is her party?"],[1242,1338,"Mr. Sullivan."],[1338,1455,"She-She's a maid."],[1455,1614,"And she refused to clean."],[1614,1680,"May I please?"],[1730,1818,"Oh..."],[2147,2231,"Actually pretty good."],[2452,2515,"Oh..."],[2648,2723,"There you go."],[2723,2786,"Thank you."],[2848,2911,"Well, then..."],[2990,3090,"I’ll need you to get down"],[3090,3161,"on your hands"],[3161,3319,"and knees and scrub"],[3319,3453,"that floor yourself."],[3603,3757,"But, Mr. Sullivan, that's"],[3757,3845,"not my job."],[3845,3903,"Aren't you the"],[3903,4095,"hotel manager, correct?"],[4133,4204,"I mean,"],[4204,4270,"if you can't"],[4270,4400,"scrub the floor. Really,"],[4400,4567,"what good are you to me?"],[4729,4946,"Yes, I am the hotel's"],[4946,5038,"general manager."],[5038,5096,"I'm not some"],[5096,5246,"worthless housemaid"],[5246,5338,"like Harper."],[5480,5559,"Well,"],[5697,5768,"not anymore"],[5768,5830,"you're not."],[5968,6072,"You've been demoted"],[6097,6277,"to housekeeper,"],[6343,6418,"you're going to spend"],[6418,6506,"the next week"],[6506,6685,"walking in Harper’s shoes."],[6727,6777,"Then you're going"],[6777,6835,"to come back"],[6835,6923,"and tell me how"],[6923,7123,"worthless she is. And..."],[7219,7303,"If you give her a hard"],[7303,7557,"time anymore, you're fired."],[7665,7753,"Now just get down there"],[7753,7899,"and clean up that mess, please."],[8049,8166,"Come on, let's go."],[8863,9000,"I’m so sorry."],[9013,9117,"I'm so sorry."],[9355,9613,"What a good waste of champagne."],[9634,9734,"Come on, let's go."]],"40":[[233,350,"Hey, you okay?"],[483,558,"I'm sorry."],[558,621,"I never should've"],[621,717,"left you alone."],[1134,1297,"Would you care to dance with me?"],[1409,1564,"You want to dance with me here?"],[1584,1651,"Yeah."],[1680,1785,"Are you sure?"],[2039,2248,"I've never been more sure"],[2314,2469,"about anything"],[2469,2585,"in my life."],[2848,2927,"Shall we?"],[4004,4233,"Come here you..."],[6139,6368,"Come back to me now!"],[6831,6919,"Harper, I need to"],[6919,7044,"ask you a question."],[8087,8191,"Oh!"]],"41":[[41,154,"Harper Hollinger."],[212,329,"Will you marry me?"],[454,613,"George, are you sure?"],[613,754,"You could have any woman"],[754,834,"you want to..."],[834,905,"I-I don't-"],[905,1059,"Harper, please."],[1088,1197,"Just say yes."],[1347,1430,"Yes."],[1547,1634,"Come here you!"],[3695,3878,"Had to go to work early."],[3953,4041,"Happy birthday"],[4041,4166,"to the most important"],[4166,4291,"woman in my life."],[4337,4425,"See you tonight."],[4517,4612,"G."],[4733,4821,"I keep waiting for"],[4821,4963,"the moment he realizes"],[4963,5109,"I'm not what he wants."],[5138,5213,"Could he really"],[5213,5284,"just like me"],[5284,5372,"for me?"],[5989,6085,"Kieran, hi."],[6110,6172,"Harper"],[6206,6302,"can I see you today?"],[6335,6431,"Is something wrong?"],[6489,6623,"I'm not sure."],[6706,6844,"Harper there’s something"],[6844,6973,"you should know about George."],[7061,7169,"Can I talk to you in person?"]],"42":[[171,254,"Kieran...."],[254,387,"What is it?"],[442,487,"I'm worried"],[487,596,"about you, Harper."],[742,817,"You disappeared"],[817,946,"after the incident with Erin,"],[946,1067,"and then I heard you quit."],[1301,1388,"I did quit."],[1484,1743,"It's a long story, but um..."],[1906,2056,"I’m-I'm fine."],[2185,2335,"I heard about the engagement..."],[2460,2569,"And the twins."],[2569,2702,"Congratulations."],[2902,2977,"But..."],[3090,3257,"Are you really happy Harper?"],[3328,3424,"I mean,"],[3511,3803,"Mr. Sullivan isn't exactly known"],[3803,3899,"for settling down."],[3899,3958,"And how do you know"],[3958,4087,"he's not just using you?"],[4149,4308,"I really am happy."],[4383,4496,"George has been nothing"],[4496,4604,"but kind to me and..."],[4788,4863,"Beneath that cold"],[4863,4963,"exterior is a"],[5009,5113,"really good man."],[5221,5288,"Well,"],[5376,5442,"you're a good judge"],[5442,5555,"of character, Harper."],[5680,5743,"If you're happy,"],[5743,5830,"then I'm happy."],[6001,6085,"Thank you."],[6364,6527,"He’s the guy from the hotel again."],[6594,6669,"And she said yes"],[6669,6777,"to my proposal."],[6848,6890,"But is this"],[6890,7027,"what she really wants?"],[7027,7111,"He’s younger."],[7119,7228,"And he makes her laugh."],[7269,7369,"I'm old..."],[7378,7586,"And serious, past my prime."]],"43":[[784,1017,"Mrs. Sullivan, you need to eat."],[1055,1134,"You and the baby"],[1134,1251,"need nutrition."],[1434,1547,"Mr. Sullivan was supposed"],[1547,1589,"to join me"],[1589,1714,"for dinner tonight."],[1960,2018,"I know you've been out"],[2018,2143,"of the game for a while,"],[2202,2364,"but have you tried maybe"],[2448,2540,"talking to her?"],[2681,2756,"Can't you ask her"],[2756,2877,"who that guy was?"],[3153,3203,"You're right."],[3203,3244,"Drinking in"],[3244,3361,"silence is much better."],[3524,3661,"I want your advice,"],[3716,3845,"I’ll ask for it."],[4279,4358,"Keep an eye on him for me,"],[4358,4404,"will you?"],[4404,4496,"And uh..."],[4537,4654,"Cut him off if you need to."],[4654,4779,"No matter what he says."],[4979,5055,"Good night boss."],[5288,5359,"Hey, can I get another"],[5359,5476,"drink, please?"],[5722,5843,"George!"],[5843,6001,"Oh my God."],[6001,6164,"I haven't seen you"],[6164,6314,"since your sister's"],[6314,6410,"garden party."],[6410,6448,"What was that,"],[6448,6535,"like, four years"],[6535,6623,"ago or something?"],[6856,6952,"Amy."]],"44":[[37,141,"I've tried calling you"],[141,258,"a few times over the years,"],[258,342,"but you must have"],[367,567,"lost my number or something."],[638,717,"Just busy."],[767,850,"You know?"],[859,1009,"My father handed the company"],[1009,1155,"over to me a year ago."],[1176,1255,"Looks like you and I"],[1255,1322,"are both running"],[1322,1405,"the show now."],[1539,1647,"We should get together"],[1647,1818,"and catch up sometime, huh?"],[1830,1922,"Yeah just..."],[2035,2168,"reach out to my secretary."],[2256,2360,"I didn't mean over"],[2360,2464,"a business meeting."],[2519,2677,"Silly goose."],[2694,2932,"I meant over a date."],[3311,3436,"I don't have time to date."],[3595,3699,"Georgie."],[3737,3887,"When are you going to admit"],[3887,4129,"that we just make sense?"],[4166,4262,"Come on, you and I both know"],[4262,4454,"it's only a matter of time before..."],[4596,4758,"This happens."],[4967,5163,"Harper and I make sense."],[5276,5526,"She means the world to me."],[5584,5755,"Who the fuck is Harper?"],[5789,5876,"George?"],[5943,6047,"Greg called me."],[6118,6214,"Harper!"],[6264,6439,"Oh, my God, is that a diamond?"],[6523,6685,"Are you engaged to this..."],[6727,6915,"Elderly pregnant woman?"],[6969,7052,"Let's go home."],[7123,7207,"Come on George."],[7941,8020,"Almost there..."],[8354,8445,"Okay."],[8521,8633,"Let me get you some water."],[8704,8775,"Oh, wait."],[8867,8967,"Stay with me."]],"45":[[429,517,"Still wearing"],[517,604,"your ring?"],[725,884,"Why would that surprise him?"],[950,1105,"Is he having second thoughts?"],[1238,1384,"Of course I am."],[1384,1497,"Why wouldn't I be?"],[1572,1705,"I saw you Harper..."],[1872,2014,"In the cafeteria."],[2056,2285,"You were with a man"],[2327,2431,"laughing."],[2552,2635,"I wasn't..."],[2727,2852,"Wasn't following you."],[2911,3190,"I just happened to be there,"],[3190,3332,"and I uh, I passed"],[3332,3649,"by, and I saw you with-"],[3657,3891,"With an ex coworker,"],[3908,4004,"Kieran."],[4133,4308,"He's an old friend George."],[4316,4487,"He's my son's age."],[4521,4679,"He's too young for me."],[5167,5276,"Better get some rest."],[5313,5397,"No, no."],[5409,5534,"Stay."],[5680,5910,"Stay with me."],[6502,6610,"Tell 