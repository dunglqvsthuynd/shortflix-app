92,"And if I do, you'll be"],[492,596,"the first to know."],[625,859,"Oh, you like her, don't you?"],[859,1001,"I saw the way you looked at her."],[1676,1780,"Where is she?"],[1780,1876,"I must meet"],[1876,2010,"my new sister in law."],[2010,2089,"Did you make sure"],[2089,2206,"she had everything she needed?"],[2273,2406,"You too VIctoria?"],[2473,2569,"She's upstairs. She's fine."],[2569,2669,"She's just resting."],[2744,2836,"Good."],[2882,2977,"Imagine a mother"],[2977,3094,"working tirelessly"],[3094,3211,"to provide for her family"],[3211,3486,"and her own son abusing her."],[3536,3611,"Thank God"],[3611,3670,"you brought her here"],[3670,3828,"where she can finally rest."],[3891,4045,"Now, aren’t"],[4045,4195,"you going to introduce us?"],[4300,4429,"Sure."],[4429,4537,"Shall we?"],[5221,5438,"Why is the mother of your children"],[5438,5634,"cleaning her own room?"],[5680,5743,"She's worked"],[5743,5910,"as a maid for decades."],[5910,6139,"It's all she knows."],[6435,6627,"Oh, Mr. Sullivan..."]],"13":[[129,271,"It's George."],[604,696,"Well, as long as you're"],[696,792,"staying here."],[909,988,"I do not want"],[988,1151,"you lifting a finger."],[1151,1338,"You understand? -Yes."],[1422,1522,"George."],[1614,1701,"Greg!"],[1868,2031,"Make sure the entire staff knows"],[2031,2168,"that she is the mother"],[2168,2281,"of my children."],[2298,2485,"I want her treated no different"],[2498,2623,"than they treat me."],[2623,2698,"Understood?"],[2723,2827,"Yes, sir."],[2827,2923,"Good."],[3028,3086,"Well,"],[3153,3224,"since we got that"],[3224,3311,"out of the way."],[3311,3374,"Harper."],[3374,3516,"This is Victoria, my sister."],[3599,3903,"Oh, it’s so nice to meet you."],[3937,4066,"If you need anything at all,"],[4066,4175,"you let us know."],[4266,4375,"Do you like your room?"],[4433,4512,"Would you rather"],[4512,4700,"a view of the rose garden?"],[4767,4925,"It’s...It's perfect."],[4925,5013,"Thank you."],[5046,5221,"I’ve spent most of my life"],[5221,544