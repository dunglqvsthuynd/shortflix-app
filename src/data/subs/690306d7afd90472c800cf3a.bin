,[5380,5497,"It's, it's not a big deal."],[5580,5634,"Walker?"],[5676,5759,"Donald Walker?"],[5784,5847,"The president?"],[5868,6001,"You're saying the president"],[6018,6122,"owes you a favor?"],[6218,6327,"Who are you really?"]],"61":[[29,137,"Who are you really?"],[296,358,"It's funny"],[358,479,"you keep getting asked this question."],[508,625,"Who I am doesn't matter."],[696,829,"What does matter is that"],[829,959,"the Sterling family problem"],[1042,1134,"is officially over."],[1163,1251,"Told you."],[1292,1380,"My Daddy's the most"],[1401,1601,"awesome person on this planet."],[1647,1789,"There's nothing he can't do!"],[1797,1876,"Right, Daddy?"],[1906,2060,"That is right, my little princess."],[2202,2331,"Thank you, Cassius."],[2423,2544,"It's the least I can do."],[2602,2723,"No, no."],[2740,2806,"I don't buy it."],[2861,2911,"Think about it."],[2911,3073,"My brother is the sitting governor,"],[3073,3199,"and even he struggled to get a"],[3199,3274,"ten-year exemption,"],[3274,3399,"much less a hundred."],[3420,3724,"This is obviously a fake document."],[3724,3870,"Get over yourself, Preston!"],[3933,3999,"It's real."],[4029,4141,"I believe Cassius."],[4141,4262,"Of course you do."],[4308,4512,"You and your kid are both blind as hell."],[4525,4658,"I mean, forging the"],[4658,4825,"president's signature"],[4825,4950,"and the White House seal,"],[4950,5105,"that is a federal crime."],[5105,5213,"Everyone listen up."],[5246,5355,"Don't be fooled by him."],[5355,5488,"Because when the president sees this,"],[5488,5655,"it's not just him who's going down,"],[5655,5822,"but the entire Sterling family"],[5822,5922,"is fucked."],[5939,6064,"So we need to tear it up"],[6064,6189,"before it's too late."],[6210,6356,"We'll let you handle it, Preston."],[6919,6961,"Careful."],[7086,7207,"I wouldn't do that if I were you."],[7265,7428,"Even a tiny scratch on that document"],[7428,7549,"and there could be"],[7549,7657,"a lot of problems for you."]],"62":[[759,804,"Oh."],[1026,1071,"Wow."],[1359,1534,"Cut the bullshit."],[1580,1722,"Cassius, you think I'm going to buy into"],[1722,1864,"your fake little counterfeit?"],[1876,1943,"Oh oh, and"],[1943,2047,"where are the consequences, huh?"],[2047,2135,"What the, what the,"],[2143,2264,"the president just gonna show up"],[2264,2348,"at our house?"],[2381,2673,"And I bet those gifts were fake too."],[2673,2769,"Because last time I checked,"],[2769,2886,"they belonged to the head of"],[2886,3048,"the Enros Group, Mr. S."],[3048,3186,"And if you're stealing his shit,"],[3261,3478,"brother, you must have a death wish."],[3520,3591,"Did you think you were going to"],[3591,3720,"scam our whole family?"],[3745,3903,"Should've done your research first."],[3903,3974,"Listen,"],[3987,4045,"Mark's going to be here"],[4045,4120,"soon with Grandpa,"],[4120,4291,"and you know that Grandpa"],[4291,4500,"is obsessed with rare collectibles."],[4500,4654,"All right, so let's just let him"],[4654,4763,"check all these things out!"],[4767,4875,"No, Mom."],[4909,5025,"Grandpa hates fakes more"],[5025,5105,"than anything else."],[5105,5246,"This lying ass"],[5246,5413,"forged presidential documents."],[5447,5538,"And he faked"],[5538,5726,"Mr. S's private collection, too."],[5739,5972,"If he finds out, we're all screwed."],[6035,6185,"When Mark arrives,"],[6206,6331,"we're handing this fraud"],[6331,6452,"over to the cops."],[6510,6556,"Forging a"],[6556,6719,"presidential document"],[6756,6952,"and impersonating Mr. S's collection."],[6952,7094,"Cassius, I've got to give it to you,"],[7115,7219,"you've got guts."],[7248,7349,"But how about this?"],[7349,7428,"Family,"],[7432,7674,"what if Mr. S owes us one"],[7674,7874,"if we take care of this loser for him."],[7874,7982,"And he can solve"],[7982,8153,"all the Sterling family crisis"],[8153,8299,"with just one word."],[8366,8495,"My daddy's gifts are real."],[8512,8687,"He didn't fake anything!"],[8687,8771,"Oh yeah?"],[8863,9017,"What proof do you have?"],[9029,9104,"Proof."],[9163,9275,"You want proof."],[9505,9584,"That's funny."],[9655,9788,"Well, what if I told you,"],[9855,9972,"I am Mr. S."]],"63":[[29,137,"I am Mr. S."],[342,450,"Okay, wait a second."],[517,613,"Did you guys hear that?"],[617,658,"I, I..."],[696,888,"I think you just said you're Mr. S."],[992,1055,"Do you have any idea"],[1055,1155,"what that name means?"],[1226,1338,"The puppet master behind"],[1338,1380,"the world's most"],[1380,1505,"powerful conglomerate."],[1530,1685,"I mean, the President himself"],[1685,1851,"owes him a seat, and here he is."],[1910,2089,"Mr. S himself!"],[2431,2548,"You've got to be kidding me."],[2548,2631,"Oh, my God."],[2660,2840,"Are you fresh out of a psych ward"],[2840,2915,"or something?"],[2936,3053,"Get this lunatic"],[3053,3244,"and his pile of trash out of here now."],[3294,3499,"And anyone who gets in our way"],[3511,3641,"should consider themselves an"],[3641,3816,"enemy of the Sterling family!"],[4562,4854,"Happy Thanksgiving!"],[5334,5555,"Did I just walk into a yard sale?"],[5684,5855,"Grandpa, thank God you're here."],[5930,6014,"Freya,"],[6068,6193,"brought her loser husband"],[6252,6364,"who's trying to scam us with"],[6364,6473,"all these fakes."],[6535,6614,"Honey, could you get him the"],[6614,6698,"Boeing deed, and"],[6719,6873,"Mom, could you bring the diamond?"],[7077,7161,"Here you go."],[8333,8504,"It's best if we get rid of"],[8504,8604,"these counterfeits"],[8604,8812,"before Mr. S finds out."],[8812,8954,"We would hate to piss him off."],[8971,9046,"Preston's right."],[9046,9246,"Let's throw all of this away now."],[9396,9505,"Are you crazy?"]],"64":[[20,104,"Are you guys..."],[120,183,"Are you.."],[342,458,"Grandpa, are you okay?"],[471,546,"Move!"],[629,684,"What's wrong?"],[809,1001,"It's your husband's junk that set him off!"],[1001,1092,"Quickly, get him to his room,"],[1092,1180,"get him his meds."],[1180,1292,"You better pray he's okay."],[1292,1363,"Because if not,"],[1384,1501,"I'm going to make you pay for it."],[1997,2122,"You son of a bitch!"],[2339,2410,"You gave my grandfather"],[2410,2565,"a heart attack at Thanksgiving."],[2673,2898,"I'm going to burn all this crap!"],[2998,3123,"Jackson, burn that,"],[3123,3219,"and you will regret it."],[3841,3895,"Regret?"],[3991,4129,"The only thing I regret"],[4145,4279,"is not letting my dog tear you"],[4279,4362,"apart on the way in!"],[4821,4942,"Where's all the stuff?"],[5130,5251,"Where's all the stuff?"]],"65":[[12,91,"You idiot!"],[120,250,"Where's all the stuff?"],[262,367,"Relax, Grandpa. I..."],[442,492,"I, I, I..."],[492,617,"I threw all the junk in the,"],[617,675,"in the fire."],[775,946,"Yeah, Dad, Dad, it's all right."],[946,1046,"I will handle"],[1046,1184,"this asshole for you, okay?"],[1201,1334,"What are you guys waiting for?"],[1347,1468,"Get him out of here."],[1509,1647,"Don't touch my daddy!"],[1735,1785,"Back off."],[1785,1935,"If you lay one hand on Cassius,"],[1935,2081,"I swear I'm done with this family"],[2081,2160,"for good!"],[2160,2264,"Break his legs,"],[2302,2410,"take him out of here,"],[2431,2590,"and lock up Freya and Elsa"],[2590,2644,"in their room"],[2644,2786,"until they come to their senses."],[2786,2848,"Freya, it looks like"],[2848,2932,"it's time for you to"],[2932,3073,"apologize to your dad."],[3090,3144,"Now."],[3178,3257,"You idiot."],[3311,3420,"Where's all the stuff?"],[3524,3591,"Where?"],[3695,3820,"Give me the tongs!"],[4859,4904,"Dad."],[4929,5067,"Put that garbage down."],[5067,5196,"Your coat's worth a fortune."],[5196,5317,"You're going to ruin it."],[5534,5626,"You idiots."],[5651,5784,"This is real!"]],"66":[[100,246,"I told you they were all real."],[362,458,"No one believed me."],[500,563,"God."],[638,792,"What if all that was real?"],[871,1067,"And that it really belonged to Mr. S,"],[1155,1288,"and we destroyed it?"],[1413,1572,"What's that going to cost us?"],[1630,1776,"Screw the costs."],[1818,1931,"It's not about the money."],[2014,2102,"Don't you get it?"],[2164,2360,"Anyone who messes with Mr. S"],[2360,2456,"is in big trouble."],[2510,2635,"One idiot tried to scratch"],[2635,2744,"one of his paintings, and it,"],[2744,2836,"it was, it was over."],[2836,2894,"They hit him with a"],[2894,2994,"federal investigation."],[2994,3057,"We're screwed!"],[3057,3261,"Guys, calm down, okay?"],[3261,3461,"Because he's not Mr. S."],[3461,3599,"He's stealing from Mr. S,"],[3599,3766,"so if anyone's going to go down,"],[3795,3862,"it's him."],[3891,4104,"My daddy would never steal anything."],[4120,4204,"Those gifts?"],[4204,4283,"They're his."],[4312,4433,"All his."],[4471,4592,"Cassius, what's going on?"],[4617,4792,"You stole from Mr. S, didn't you?"],[4833,4892,"Mark?"],[4921,5105,"Cassius, how did you get your hands"],[5109,5255,"on a presidential document"],[5255,5376,"and Mr. S's assets?"],[5422,5563,"If you don't explain yourself,"],[5580,5734,"I'm going to have to arrest you"],[5759,6035,"for grand larceny and federal fraud."]],"67":[[25,95,"Mark, stop!"],[95,179,"You have no proof"],[179,283,"he did anything wrong."],[308,471,"My daddy would never steal."],[513,563,"Never!"],[575,688,"Seriously, sis."],[825,892,"Why?"],[1017,1146,"Why are you defending this liar?"],[1146,1222,"Can't you just think about"],[1222,1434,"this family for, for one second?"],[1463,1514,"Yeah."],[1559,1668,"He didn't just piss off"],[1668,1810,"some random guy."],[1864,2031,"That's Mr. S."],[2031,2252,"He's the power behind the president."],[2252,2331,"Enough!"],[2352,2544,"Mark, take him to the station."],[2556,2752,"Let the law handle this fraud."],[2752,2882,"You can't do this."],[3028,3098,"It's okay."],[3194,3328,"I'm going to go with you, okay?"],[3445,3549,"But I swear,"],[3670,3845,"if I come back and there is one tear"],[3858,4037,"on Freya or Elsa's face,"],[4108,4283,"you will all feel the full power"],[4283,4416,"of what I'm capable of."]],"68":[[12,229,"Enough of your shit,"],[254,312,"Cassius."],[312,387,"Mark, get him out of here."],[387,529,"And if you don't find any dirt"],[554,663,"on this scumbag,"],[663,775,"don't bother coming back."],[913,996,"I'll be back soon,"],[1017,1067,"okay?"],[1142,1388,"Mommy, is Daddy coming back?"],[1426,1547,"He will, I promise."],[1559,1630,"Coming back?"],[1668,1776,"No, he's about to spend the"],[1776,1964,"rest of his life in federal prison."],[2610,2744,"Officer, you mind if I make a call?"],[2798,2898,"Your phone will do."],[3057,3136,"You're entitled to one."],[3728,3774,"Good work."],[3774,3832,"Looks like we're"],[3832,3953,"in good place for the treaty."],[4279,4333,"Yes?"],[4412,4487,"What?"],[4554,4721,"They're doing what to you?"],[5021,5109,"I'm coming right now."],[5363,5472,"This meeting's over."],[5501,5601,"Get the car ready."],[5693,5893,"We're going to the police station."],[5943,6131,"And I'm going to find out myself"],[6151,6277,"who's been doing this."]],"69":[[225,262,"Thank you."],[1505,1543,"Look, man,"],[1543,1718,"I suggest you just come clean."],[1780,1835,"Forging a"],[1835,1956,"presidential document,"],[2002,2206,"stealing Mr. S's property."],[2239,2352,"Let's not make this any"],[2394,2594,"uglier than it has to be."],[2677,2752,"Really, Mark?"],[2848,2911,"You trying to beat a"],[2911,3015,"confession out of me?"],[3078,3194,"Not very smart."],[3194,3411,"I don't have time for games."],[3578,3678,"Sign this,"],[3816,3920,"admit what you did,"],[3970,4099,"and we'll both walk away from here"],[4099,4187,"a little bit happier."],[4233,4371,"Yeah, I'm not going to sign that"],[4371,4517,"because I didn't do anything."],[4587,4800,"Don't blame me for what happens next."],[5259,5426,"Mark, this is your last warning."],[5588,5730,"Stop this before you burn"],[5730,5897,"the only bridge you have left."],[5930,6068,"Wake the fuck up!"],[6168,6306,"Now you're gonna sign this,"],[6314,6381,"or am I going to take..."],[6381,6498,"Mr. Adams."],[6539,6694,"My apologies for the delay."],[6802,6931,"I should have come sooner."],[6998,7057,"President Walker,"],[7057,7140,"what are you doing here?"],[7140,7269,"Do you have any idea"],[7269,7374,"what you're about to do?"],[7399,7595,"Do you even know who this man is?"],[7653,7912,"He's leader of the Enros Group."],[8003,8220,"This is Mr. S."]],"70":[[20,241,"This is Mr. S."],[392,542,"You're all right, Mr. Adams?"],[567,638,"I'm fine."],[658,759,"But I do need to get back to"],[759,842,"the Sterling estate."],[842,905,"My wife and daughter"],[905,980,"are still there."],[1021,1105,"You give me a ride?"],[1105,1192,"Yes, of course."],[1201,1326,"In fact, I'll go with you."],[2181,2248,"Sorry, sir."],[2293,2360,"You're suspended."],[2377,2515,"Effective immediately."],[2786,2890,"Daddy, please."],[2936,3115,"Tell Mark to let Cassius go."],[3165,3324,"He didn't do anything wrong!"],[3345,3395,"Matt,"],[3440,3691,"Cassius is Freya's husband,"],[3703,3820,"like it or not."],[3837,4070,"Just tell Mark to release him."],[4079,4166,"Release him?"],[4229,4287,"So what?"],[4325,4537,"Mr. S can come and crush us?"],[4600,4850,"Freya, he just stole from the most"],[4850,5021,"powerful man in the world."],[5021,5138,"Sign the papers"],[5138,5276,"and cut all ties with him."],[5342,5605,"Look, Freya, you want him safe, yeah?"],[5638,5726,"Well, it's simple."],[5764,5885,"I talk to my brother,"],[5885,6047,"who then talks to the president"],[6068,6202,"to make that happen."],[6239,6364,"Under one condition."],[6510,6648,"You have to marry me."],[6790,6848,"Ow!"],[6919,7032,"Don't you touch my mommy,"],[7032,7111,"you creep."],[7161,7290,"You little brat."],[7290,7424,"You just bit me."],[7507,7570,"Hey!"],[7937,8074,"Touch her and I'll break your arm."]],"71":[[16,87,"What the fuck?"],[87,212,"What the hell is he doing here?"],[212,300,"Where's Mark?"],[738,855,"Wait a second is..."],[946,1059,"Is that the President?"],[1067,1213,"Yeah, the President's here."],[1222,1317,"That settles it then."],[1317,1430,"It is game over"],[1447,1622,"for this fucking convict."],[1735,1860,"Daddy, you're back!"],[2018,2127,"Freya, are you blind?"],[2218,2360,"That's the President."],[2410,2527,"He's here to arrest this"],[2527,2644,"lying husband of yours."],[2644,2723,"Do me a favor and"],[2723,2890,"sign the divorce papers"],[2932,3019,"before this whole family"],[3019,3107,"goes down with him."],[3128,3386,"Freya, please marry Preston."],[3474,3586,"You don't actually want to"],[3586,3816,"bring this family down, do you?"],[3866,4170,"Sign these papers or I will disown you!"],[4216,4266,"Fine."],[4316,4446,"Then from this moment forward,"],[4446,4612,"I am not a Sterling anymore."],[4667,4800,"I am Freya Adams."],[4846,4971,"And just so we're clear,"],[5000,5180,"if he does end up behind bars,"],[5188,5388,"I will wait for him to get out."],[5401,5559,"Are you crazy?"],[5605,5772,"Do you even hear yourself?"],[5801,5922,"I'm going to knock the..."],[5951,6018,"Do not"],[6047,6106,"touch"],[6172,6243,"my wife."],[6314,6485,"You little punk."],[6556,6619,"Jackson."],[6710,6798,"Stand down!"],[7173,7332,"Do any of you even know"],[7332,7469,"who this man is?"],[7565,7778,"He's the leader of the Enros Group,"],[7828,7937,"the most powerful"],[7937,8062,"conglomerate in the world!"],[8258,8562,"This, is Mr. S."]],"72":[[54,358,"This, is Mr. S."],[513,600,"Oh my God."],[617,704,"My God."],[721,821,"I have to call my Dad"],[821,905,"and my, and my brother and..."],[905,1101,"Oh, don't worry about that."],[1117,1234,"We have a nice"],[1251,1372,"family reunion planned"],[1372,1480,"for the three idiots"],[1509,1572,"in prison."],[1622,1714,"Oh, did you think"],[1714,1872,"we wouldn't find out about you"],[1872,1968,"forging those"],[1968,2139,"exemption documents?"],[2377,2619,"Guys, come on, no. It, it's..."],[2635,2727,"It wasn't fraud."],[2727,2815,"Just come on."],[3574,3666,"Mr. Adams,"],[3695,3845,"I mean Mr. S."],[3903,4166,"Sir, I am so sorry,"],[4204,4333,"about everything today."],[4400,4496,"And I was hoping"],[4533,4667,"that you could forgive us"],[4675,4938,"and maybe give us the exemption?"],[5084,5184,"Just ten years."],[5217,5321,"Did you forget already?"],[5409,5522,"I gave you an exemption"],[5522,5630,"for 100 years."],[5726,5818,"You burned it."],[5864,5960,"That was your one shot."],[5960,6114,"And now it is gone."],[7265,7357,"Yeah, yeah, I just-"],[7532,7661,"It's going to be okay, honey."],[7786,7920,"Oh my God."],[8379,8425,"Yeah."],[9759,9918,"Freya, I..."],[10014,10206,"know that I should have told you"],[10206,10335,"who I am from the start."],[10435,10585,"And that I put you through a lot."],[10764,10881,"But I want to make it up to you."],[11390,11461,"So,"],[11565,11715,"will you marry me..."],[12045,12120,"again?"],[12312,12412,"For real this time."],[12575,12645,"Yes!"],[12658,12825,"Absolutely yes."],[13734,13893,"This is the best gift ever!"],[13934,14151,"Now we'll be together forever!"]]}