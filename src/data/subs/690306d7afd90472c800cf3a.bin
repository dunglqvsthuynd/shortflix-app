{"1":[[646,721,"Mr. President,"],[738,959,"after winning the presidential election,"],[959,1134,"your first stop is a State prison?"],[1163,1209,"Milo,"],[1209,1280,"we are here"],[1280,1422,"to see a very important man."],[1434,1568,"In fact, so important"],[1589,1726,"that he helped decide"],[1726,1851,"the Presidential election"],[1851,1956,"victory for us."],[2002,2118,"Oh, here he comes now."],[3282,3428,"Mr. S!"],[3453,3528,"It's an honor to"],[3553,3678,"finally meet you in person."],[3712,3782,"After all,"],[3791,3949,"you helped decide the victory"],[3970,4095,"for the Presidential election"],[4095,4158,"and,"],[4183,4316,"single-handedly built"],[4316,4421,"the Enros Group"],[4441,4554,"from the ground up."],[4587,4683,"So you were waiting for"],[4683,4829,"the most mysterious mastermind"],[4846,4967,"who built the Enros Group?"],[4984,5096,"You're waiting for the man"],[5096,5267,"who runs the most powerful"],[5267,5447,"financial empire,"],[5492,5572,"Mr. S."],[5597,5689,"No worries, Donald."],[5718,5814,"It wasn't a big deal."],[5847,5926,"Besides, I've been meaning to"],[5926,6089,"takedown your opponents for years,"],[6131,6285,"GEO Defense Systems."],[6293,6523,"So, is that why you went to prison"],[6523,6598,"six years ago?"],[6635,6677,"No."],[6727,6881,"My girlfriend got into some trouble,"],[6898,7036,"and I couldn't let an innocent woman"],[7036,7111,"go to jail."],[7203,7298,"Took the fall myself."],[7361,7415,"I see,"],[7499,7674,"but I still don't understand."],[7711,7920,"Your prison sentence ends tomorrow."],[7949,8212,"Why go through a parole application,"],[8212,8354,"just to get out one day early?"],[8391,8500,"Well sir, six years ago,"],[8500,8604,"I promised that I would"],[8604,8783,"propose to my girl on this very day."],[8833,8913,"I’m a man of my word."],[8946,9013,"So sir,"],[9013,9117,"I've got a ride to catch."],[9184,9246,"Keep in touch."],[10873,10935,"There he is!"],[10935,11019,"Look at this guy."],[11073,11131,"Great news."],[11173,11248,"Ms. Davis"],[11265,11448,"is finally on Mirror Media's radar,"],[11448,11586,"one of the top media companies"],[11586,11669,"in the country."],[11695,11790,"Thanks to your support,"],[11799,11878,"they actually made her"],[11878,12007,"the Director of News!"],[12024,12183,"They're even having an inauguration"],[12183,12291,"ball for her tonight."],[12295,12424,"Every major player in the industry"],[12424,12504,"is going to be there."],[12533,12645,"Isabelle has always wanted to be"],[12645,12779,"a world-famous journalist."],[12841,12908,"Warren, let's give her that"],[12908,12992,"final push tonight."],[13058,13167,"I want you to personally deliver"],[13167,13288,"my exclusive interview rights"],[13288,13359,"to her at the gala."],[13392,13480,"And Warren, this won't"],[13480,13567,"just be an interview,"],[13596,13722,"I'm going to ask her to marry me,"],[13747,13930,"and reveal the truth"],[13968,14055,"that Mr. S,"],[14134,14264,"the man behind Enros Group,"],[14310,14418,"the one who's been guiding her career"],[14418,14514,"every step of the way,"],[14514,14664,"opening up every door,"],[14793,14914,"has been me, all along."],[15457,15607,"I'll have all the specials, please."],[15632,15686,"All right."],[15728,15786,"Right away."],[15882,16053,"Whether you like it or not Freya,"],[16053,16161,"this marriage,"],[16161,16257,"is happening."],[16278,16387,"Really, Preston?"],[16399,16520,"We both know this marriage"],[16520,16604,"is just your play to"],[16604,16674,"swallow up my company,"],[16674,16754,"Mirror Media."],[16837,16929,"So what if it is?"],[16929,16996,"I mean, this marriage"],[16996,17075,"is already a done deal."],[17075,17158,"Both of our families have"],[17158,17263,"made that choice,"],[17263,17367,"and there is nothing"],[17367,17513,"that you can do about it."],[17521,17705,"And your precious Mirror Media,"],[17705,17867,"is as good as mine."],[17884,17959,"You're mean!"],[17959,18118,"Stop yelling at my mommy!"],[18118,18255,"I don't want her to marry you!"],[18272,18380,"Shut it, you little bastard,"],[18380,18501,"nobody asked you!"]],"2":[[1059,1238,"Who says I don't have a daddy?"],[1280,1393,"He's my daddy!"],[1906,2060,"Kiddo, I think you might have me"],[2060,2168,"mixed up with someone else."],[2189,2293,"Elsa, what are you talking about?"],[2293,2377,"Come back here."],[2540,2640,"I'm so sorry, sir."],[2640,2727,"She must've thought"],[2727,2831,"you were someone else."],[2831,3023,"No, Mommy, I didn't get it wrong."],[3036,3128,"He's my daddy!"],[3453,3541,"Hey, jerk!"],[3561,3661,"My dad's back now."],[3737,3824,"You better watch out,"],[3824,3949,"or he'll knock your teeth out."],[3983,4083,"I told you to shut it,"],[4083,4158,"you little brat,"],[4158,4262,"or I will rip that mouth"],[4262,4354,"right off your face!"],[4746,4833,"You must feel real tough"],[4833,4959,"going after a little girl, huh?"],[5071,5125,"Back off."],[5726,5805,"Who the hell are you?"],[5847,5922,"You know what, how about this?"],[5922,6006,"How about you"],[6026,6122,"stay out of it."],[6147,6368,"Because it's none of your damn business."],[6385,6448,"And Freya,"],[6514,6648,"how about you control your kid"],[6648,6911,"before she ropes in this street trash,"],[6931,7040,"fresh out of prison,"],[7086,7190,"who's wanting to play"],[7223,7278,"daddy."],[7365,7515,"You know, Preston, who I marry"],[7515,7661,"is none of your business."],[7661,7791,"But let me be clear,"],[7828,7974,"it will never be you!"],[8074,8137,"Fine,"],[8137,8254,"but I swear to you, Freya,"],[8254,8345,"I will make you"],[8350,8550,"regret those words."],[8566,8671,"You are not"],[8671,8767,"going to like"],[8767,8883,"how this ends."],[9230,9380,"Elsa's never known her father."],[9409,9534,"She's put up with snide remarks"],[9534,9605,"her whole life."],[9617,9780,"Maybe it's time I find her a dad."],[9797,9859,"In one move,"],[9859,10022,"I could finally shut my family up"],[10022,10126,"and keep Mirror Media"],[10126,10256,"in my own hands."],[10527,10614,"I know this"],[10614,10723,"might sound crazy,"],[10760,10827,"but,"],[10873,11011,"you helped my daughter just now."],[11011,11065,"And..."],[11252,11373,"will you marry me?"],[11398,11482,"Be my husband?"]],"3":[[29,120,"I know this"],[137,225,"sounds crazy,"],[237,271,"but,"],[283,404,"I can make it worth your while."],[437,492,"I can pay you"],[492,600,"one million dollars a month"],[600,784,"and a Bugatti as a signing bonus."],[863,925,"Ma'am,"],[1005,1163,"that is a"],[1188,1272,"very"],[1272,1409,"tempting offer, but"],[1455,1534,"I'm afraid I'm going to have"],[1534,1618,"to turn you down."],[1685,1785,"You see, I already"],[1785,1906,"have a girlfriend and,"],[2006,2198,"well I plan on proposing tonight."],[2227,2402,"Is she prettier than my mommy?"],[2531,2740,"I am so sorry for her."],[2761,2873,"And my own"],[2936,3032,"reckless offer."],[3219,3307,"Congratulations!"],[3345,3470,"I am sure your proposal"],[3470,3557,"will go perfectly."],[3557,3611,"Come on."],[3999,4112,"Your dessert's ready, sir."],[4204,4266,"Thank you."],[4416,4475,"Wait, what?"],[4537,4671,"The top three media companies"],[4671,4804,"are teaming up against Mirror Media?"],[4829,4896,"And they're dragging my"],[4896,5000,"personal life into this?"],[5042,5113,"Who's behind this?"],[5150,5288,"It's Preston Norton."],[5317,5409,"I double-checked."],[5409,5522,"The Nortons are one of the most"],[5522,5693,"powerful families in the country,"],[5718,5868,"easily the richest in the state."],[5868,6022,"We're helpless against them."],[6035,6202,"Preston, you son of..."],[6206,6310,"Brooke, we're out of options."],[6377,6485,"There might be one person left"],[6485,6560,"who could help us."],[6610,6723,"The boss of Enros Group,"],[6890,6981,"Mr. S."],[7044,7173,"They need my help."],[7173,7286,"I know, I know"],[7303,7478,"we're nobodies to a guy like that, but"],[7603,7665,"reach out."],[7716,7828,"Whatever he wants, I'll do it."],[8108,8195,"Mr. Handsome,"],[8195,8345,"please save my mommy."],[8366,8441,"Elsa, come here."],[8479,8583,"Sorry for"],[8583,8717,"listening to your phone call, but,"],[8858,8950,"maybe I can help."],[9146,9221,"You?"]],"4":[[58,171,"Consider it an apology"],[171,250,"for,"],[250,375,"turning down your proposal."],[963,1013,"Warren,"],[1076,1205,"I need you to find and delete"],[1205,1418,"every negative post about the CEO..."],[1664,1760,"Sorry, your name again?"],[1906,2022,"Freya Sterling."],[2260,2389,"Freya Sterling."],[2427,2577,"And scrub every platform clean"],[2577,2706,"of any smears against her"],[2706,2827,"or Mirror Media."],[2840,2898,"And Warren,"],[2936,3078,"let's leak some dirt on the Nortons."],[3107,3144,"Remind them"],[3144,3269,"who really runs things around here."],[3928,4012,"It's all taken care of."],[4158,4279,"You're joking, right?"],[4387,4533,"Just with one phone call?"],[4550,4617,"Just like that?"],[4808,4867,"This guy's just"],[4867,5000,"some random guy on parole."],[5059,5163,"There's no way he actually"],[5163,5259,"fixed anything."],[5276,5359,"Probably bluffing"],[5359,5447,"so he doesn't look weak"],[5447,5559,"in front of me and Elsa."],[5605,5697,"I get it, Ms. Sterling."],[5697,5876,"I... I know it sounds unbelievable"],[5876,6076,"but, yeah, just give it a moment."],[6189,6281,"You'll like the surprise."],[6335,6493,"Oh, and..."],[6514,6614,"yeah, that's my cue."],[6690,6794,"My girlfriend's here."],[7486,7620,"What are we doing here again?"],[7620,7736,"You remember that guy"],[7736,7845,"like six years ago"],[7878,7949,"who went to jail for me?"],[8012,8091,"Yeah, ew."],[8179,8249,"Isabella?"],[8366,8483,"Cassius."],[8483,8591,"Good, you're right on time."],[8696,8754,"We're done."]],"5":[[70,129,"We're done."],[433,508,"Wait, what?"],[592,671,"Are you serious?"],[754,913,"I, I just finished my sentence."],[955,1092,"We can finally be together."],[1146,1305,"I... I picked up your favorite dessert."],[1605,1818,"Are you trying to get me fat?"],[1839,1926,"Do you really think"],[1926,2085,"I want to eat cheap junk like that?"],[2085,2285,"Get lost, Cassius."],[2285,2477,"You're a broke, jobless loser"],[2477,2598,"with a criminal record."],[2598,2752,"Isabella's way out of your league."],[2786,2873,"Isabella,"],[3019,3128,"where is this coming from?"],[3203,3453,"I'm about to be Head of News"],[3453,3599,"at Mirror Media."],[3599,3837,"That's twenty-million a year."],[3837,4029,"I'm not wasting my time on"],[4029,4129,"gutter trash that"],[4129,4237,"can easily be sent back"],[4237,4387,"into the slammer at any moment."],[4500,4650,"That's why you're breaking up with me?"],[4725,4813,"Six years ago,"],[4813,4917,"you were the one caught"],[4917,5105,"red-handed with stolen goods."],[5117,5242,"I took the fall for you."],[5242,5397,"Blah, blah, frickin' blah."],[5413,5568,"You volunteered."],[5588,5739,"Nobody forced you to do it."],[5739,5797,"Honestly,"],[5797,5885,"you're lucky"],[5885,6056,"that you got to sacrifice yourself"],[6056,6135,"for Isabella."],[6168,6418,"Just stop with this sob story, Cassius."],[6418,6556,"I know what you're really here for."],[6581,6652,"A payout."],[6669,6777,"Well here."],[6844,6894,"Take it!"],[7424,7624,"You think I give a shit about the money?"],[7649,7778,"Isabella, how do you think"],[7778,7953,"that someone with zero connections"],[7970,8095,"just stumbled their way into"],[8095,8254,"exclusive interviews year after year?"],[8254,8362,"Everything you have..."],[8362,8521,"Is because I worked"],[8521,8687,"my ass off to get here."],[8767,8846,"I certainly"],[8846,8979,"didn't need any of your help."],[9042,9221,"And whose help did you need, Isabella?"],[9376,9476,"You really want to know?"],[9576,9705,"Freya Sterling,"],[9705,9934,"CEO of Mirror Media!"],[9934,10014,"Freya?"],[10014,10189,"That's the woman I just helped."],[11052,11148,"Just wait, Mom."],[11190,11252,"There's no way"],[11252,11365,"that handsome guy was lying."],[11861,11924,"Ms. Sterling,"],[11924,12057,"you're not going to believe it."],[12074,12183,"Every smear post about you"],[12183,12341,"and Mirror Media is gone."],[12341,12424,"All of it."],[12424,12512,"Vanished!"],[12541,12587,"What?"],[12641,12791,"What, that's incredible."],[13438,13521,"Freya, how did you get"],[13521,13613,"that dirt on my family?"],[13613,13717,"Our stock just plummeted"],[13717,13826,"eighty percent!"],[13863,13980,"It was you, wasn't it?"],[14018,14139,"I'm going to get you for this!"],[14243,14293,"See?"],[14318,14447,"I told you he's awesome."],[14460,14622,"Like superhero-level awesome!"],[14685,14827,"I wish he were my real dad."],[14881,14973,"Crashed the Nortons' stock"],[14973,15060,"by eighty percent?"],[15077,15198,"Who is this guy?"]],"6":[[129,237,"Oh, you see that?"],[329,567,"Ms. Sterling sent that car just for me."],[625,792,"You'll never get such a nice ride"],[792,992,"in your whole miserable, broke life!"],[1138,1230,"What happened to you?"],[1347,1426,"Six years ago,"],[1426,1605,"you didn't give a shit about my status"],[1605,1710,"when you were saving me."],[1710,1843,"Now you're so,"],[1897,1981,"shallow and"],[1981,2097,"money-obsessed."],[2131,2223,"People change."],[2223,2356,"With Ms. Sterling's help,"],[2356,2527,"I'm part of the elite now."],[2560,2677,"You have a criminal record,"],[2677,2848,"so you could never get a proper job."],[2848,2990,"And besides, six years ago,"],[2990,3153,"I wasn't the one who saved you."],[3399,3461,"Wait, what?"],[3791,3949,"You weren't the one who saved my life?"],[3949,4158,"No, of course not, idiot."],[4170,4254,"Six years ago,"],[4254,4383,"when I worked at the hotel,"],[4400,4525,"I just snuck into your room"],[4525,4667,"to get some extra cash."],[4696,4829,"It was you who woke up"],[4829,4979,"and started blabbing about"],[4979,5167,"devoting the rest of your life to me."],[5338,5388,"I mean,"],[5413,5476,"okay, you weren't"],[5476,5588,"completely useless though."],[5588,5701,"I mean, thanks for going to"],[5701,5797,"prison for me,"],[5797,5889,"Cassius!"],[5910,6097,"I wouldn't be here today without you."],[6464,6569,"Did anyone follow you?"],[6639,6702,"No."],[6781,6877,"No, I don't think so."],[6948,7102,"Cassius, I didn't steal anything."],[7148,7223,"I'm so scared."],[7223,7340,"I don't want to go to jail."],[7394,7444,"Hey."],[7611,7716,"It's going to be okay."],[7795,7878,"You know, I'm going to tell them"],[7878,7949,"that I did it."],[8208,8320,"I'm going to take your place."],[8458,8566,"Cassius!"],[8625,8750,"I don't know what to say."],[8829,8904,"Thank you."],[8979,9104,"I'm going to marry you, okay?"],[9234,9384,"You save me first, okay?"],[9384,9534,"I'm going to handle this for you and"],[9580,9667,"when I get out,"],[9763,9897,"I'm going to give you the life"],[9897,10014,"you always dreamed of."],[10689,10860,"See you never, dumbass."],[11123,11202,"So you lied to me."],[11207,11298,"Oh, lied?"],[11298,11373,"Please."],[11373,11553,"I didn't make you do anything."],[11582,11720,"And I don't know who rescued you,"],[11728,11828,"probably some nobody"],[11828,11986,"I wouldn't let polish my shoes."]],"7":[[70,112,"Hey."],[266,337,"What happened to you?"],[437,663,"Get your filthy hands off of me!"],[671,829,"I have a gala to get to."],[829,1001,"I'm done talking to you."],[2135,2273,"Six years."],[2298,2515,"Six years wasted."],[2652,2798,"All those sleepless nights,"],[2886,2994,"what a joke."],[3086,3148,"Who was it"],[3148,3303,"who saved me six years ago?"],[3345,3470,"Mr. Handsome!"],[3536,3678,"You saved my Mommy today,"],[3707,3749,"right?"],[3807,3883,"Thank you!"],[3962,4095,"I do want to thank you."],[4116,4166,"You,"],[4166,4295,"saved me twice today."],[4387,4500,"Can I at least get your name?"],[4658,4754,"Cassius Adams."],[5017,5080,"Handsome guy!"],[5109,5230,"Where is your girlfriend?"],[5255,5338,"Did she dump you?"],[5359,5413,"Elsa!"],[5459,5588,"He's going to propose."],[5626,5701,"Nuh-uh."],[5722,5768,"Look,"],[5801,5901,"his case on the ground."],[5935,6110,"He totally just got dumped!"],[6177,6293,"Looks like we got a smart little"],[6293,6385,"detective, huh?"],[6456,6573,"My offer still stands."],[6639,6756,"We could get married today."],[6773,6831,"Right now."],[6906,6990,"Ms. Sterling,"],[7086,7211,"as you can see, I'm"],[7269,7436,"just a convict on parole."],[7465,7578,"Why would you want to marry me?"],[7657,7841,"You don't care about your public image?"],[7903,7999,"I don't care about that."],[8053,8149,"You stepped in and saved"],[8149,8345,"two strangers today without hesitating."],[8387,8491,"That's the kind of man that will"],[8491,8637,"build his own empire one day."],[8708,8879,"And I'd be proud to stand by him,"],[8908,9067,"as a wife and a partner."],[9371,9409,"Okay."],[9592,9672,"I will marry you."],[9805,10014,"And as your husband and Elsa's father,"],[10043,10172,"I promise that no one"],[10189,10364,"will dare harm you two ever again."],[10389,10548,"Yay, I have a daddy!"]],"8":[[296,375,"Cassius,"],[421,525,"my gala's tonight."],[525,638,"And I want you by my side."],[667,829,"I've arranged a car and my stylist"],[829,963,"to help you look the part."],[988,1067,"I'm going to meet up with you"],[1067,1222,"after I wrap up things in the office."],[1330,1405,"Sounds perfect."],[1501,1580,"I'll see you two there."],[4863,5100,"Congratulations, Miss Davis."],[5121,5342,"Handpicked by Ms. Sterling"],[5342,5501,"to lead Mirror Media's"],[5501,5609,"news division,"],[5626,5814,"and at such a young age."],[5814,6114,"Oh, I'm so incredibly honored."],[6131,6227,"It's all because"],[6227,6435,"Ms. Sterling's belief in me."],[6477,6585,"A toast to her."],[7449,7578,"Cassius?"],[7653,7895,"What the hell is he doing here?"]],"9":[[296,408,"Cassius!"],[483,550,"Move!"],[642,784,"Don't think that just because you're"],[784,900,"dressed up all fancy"],[900,1034,"that you're part of the elite."],[1055,1255,"This is a high society event,"],[1259,1384,"not a prison yard."],[1409,1514,"Get out!"],[1555,1772,"Cassius, invites were sent out"],[1772,1960,"to the social elite,"],[1981,2231,"not jobless losers like you."],[2344,2469,"How the hell did you even"],[2469,2623,"sneak in here anyways?"],[2652,2702,"Sneak in?"],[2965,3040,"Oh, hardly."],[3115,3244,"Freya sent a driver for me."],[3261,3336,"And,"],[3395,3499,"didn't mention anything"],[3499,3611,"about needing an invitation."],[4170,4462,"Okay, you've officially lost it."],[4504,4717,"Do you actually expect us"],[4717,4892,"to believe that Freya"],[4892,5059,"personally sent you a driver"],[5059,5217,"to Isabella's gala?"],[5280,5409,"Are you nuts?"],[5455,5634,"Cassius, I don't know how to get it"],[5634,5768,"through your little head."],[5822,5918,"We're done."],[5972,6060,"Over."],[6164,6268,"Why don't you just leave"],[6268,6352,"before I have to throw you out"],[6352,6423,"on the street?"],[6493,6581,"Oh Isabella,"],[6660,6760,"I'm not here for you."],[6823,6981,"And this is Freya's gala,"],[7019,7090,"and trust me,"],[7090,7294,"she does not mind that I'm here."],[7294,7457,"Cassius, do you know"],[7457,7607,"who you're speaking about?"],[7628,7836,"Freya Sterling isn't just a CEO-"],[7836,8070,"she's the Queen of News."],[8112,8233,"How the hell would she know"],[8233,8337,"some broke loser"],[8337,8495,"who just got out of prison?"],[8650,8737,"Yeah, that's a good question."],[8863,8925,"why don't you ask her"],[8925,9021,"when she gets here?"],[9722,9797,"Ms. Sterling,"],[9851,9955,"we tried everything."],[10001,10143,"We found that Mr. Adams"],[10143,10256,"turned himself in for theft"],[10256,10356,"six years ago,"],[10389,10447,"but that's it."],[10472,10535,"And now"],[10535,10639,"we're getting direct warnings"],[10639,10794,"from the CIA director himself"],[10794,10877,"to back off."],[10952,11090,"So my brand-new husband"],[11090,11336,"has a past that even I can't reach?"],[11507,11611,"Cassius Adams,"],[11619,11832,"I'm going to find out exactly who you are."]],"10":[[50,141,"Cassius!"],[221,333,"Cassius, don't you think that"],[333,446,"you're taking these jokes"],[446,538,"of yours too far?"],[800,925,"But everything I've said is the truth."],[925,996,"Cassius,"],[996,1126,"once Ms. Sterling"],[1126,1343,"learns about the disrespectful lies"],[1343,1430,"you've been spewing,"],[1430,1580,"there won't be a single corner of"],[1580,1685,"this entire country"],[1685,1764,"that you can hide in."],[1785,1818,"Oh, wow."],[1872,1956,"Freya's that scary?"],[2031,2097,"Didn't realize-"],[2097,2193,"That's enough!"],[2264,2469,"Freya Sterling is the real deal."],[2494,2610,"Filth like you need to keep"],[2610,2761,"her name out of your mouth."],[2836,2973,"I'm going to teach you a lesson."],[3215,3290,"Isabella,"],[3340,3490,"I am willing to let things slide."],[3507,3574,"But trust me,"],[3599,3691,"you don't want to push me."],[4029,4245,"First, you sneak in here"],[4245,4379,"without an invitation"],[4379,4642,"and then you attack my sister?"],[4679,4838,"Oh, you've been in prison so long,"],[4838,4979,"you forgot your manners?!"],[4979,5138,"When your sister tries to hit me,"],[5138,5201,"it's justice."],[5201,5384,"But when I try to defend myself,"],[5384,5476,"I'm a barbarian?"],[5613,5680,"Isabella,"],[5680,5784,"you can't have journalistic"],[5784,5943,"integrity with that kind of bias."],[6252,6314,"Careful."],[6385,6418,"Keep it up"],[6418,6523,"and you might lose your job."]],"11":[[8,125,"Shut your goddamn mouth,"],[125,275,"you stupid fucking clown."],[316,571,"Ms. Davis is Ms. Sterling's protégé."],[600,767,"If her sister strikes you,"],[767,913,"you turn the other cheek,"],[942,996,"got it?"],[1217,1326,"Insolent fool!"],[1326,1451,"Get out, before we"],[1451,1614,"throw you out ourselves."],[1647,1751,"Hey, buddy."],[1843,1918,"You're out."],[1951,2039,"Haul your ass out of here."],[2093,2260,"Yeah, don't push your luck."],[2260,2348,"You wouldn't want us to"],[2348,2481,"get our hands dirty."],[2481,2719,"Let's be nice, for Miss Davis's s