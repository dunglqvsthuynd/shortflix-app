{"1":[[45,112,"Phoebe,"],[112,246,"thank you so much for"],[246,425,"being our surrogate mother."],[425,633,"Without you, our family"],[633,813,"could never be complete."],[813,938,"Thank you. Phoebe."],[1126,1288,"It is an honor."],[1334,1434,"I get to help a family"],[1434,1647,"make their dream come true."],[1647,1818,"This is why I decided to become"],[1818,2010,"a surrogate for John and Nora."],[2010,2089,"And the money I make"],[2089,2152,"will finally pay"],[2152,2352,"for my mother's surgery."],[2627,2815,"Sorry to interrupt."],[2815,2977,"The doctor is ready to come in"],[2977,3136,"and begin the procedure."],[3336,3482,"Good luck."],[3482,3578,"Thank you."],[5301,5438,"Alright, Abby, ready?"],[5438,5555,"Just lie back down"],[5555,5705,"and spread your legs for me."],[5705,5910,"This should only take a second."],[6126,6214,"Wait. Did the doctor say"],[6214,6327,"Abby or Phoebe?"],[7127,7190,"All done."],[7190,7248,"Just lie"],[7248,7369,"there for five minutes,"],[7369,7444,"and then you can"],[7444,7632,"get changed and head home."],[7716,7849,"That was fast."],[7849,7895,"I thought"],[7895,8016,"the embryo transfer was going"],[8016,8128,"to take at least 20 minutes."],[8224,8308,"Embry..."],[8324,8466,"embryo transfer?"],[8721,8867,"Oh my God!"],[8867,9079,"You're not Abigail Brown?"],[9079,9146,"You're not here"],[9146,9351,"for an artificial insemination?"],[9351,9409,"What?"],[9409,9617,"What artificial insemination?"],[9617,9768,"Oh, shit."],[11832,11999,"If the artificial insemination"],[11999,12074,"is successful,"],[12074,12166,"grandpa will"],[12166,12303,"hand over the Sinclair group,"],[12303,12374,"as promised."]],"2":[[337,425,"I need a surrogate"],[425,642,"who can provide her eggs."],[642,930,"She must be single, smart, and"],[930,1188,"most importantly, healthy."],[1188,1422,"Money is not an issue."],[1422,1543,"Name your price."],[1543,1726,"Rest assured, Mr. Sinclair."],[1726,1801,"All our women are"],[1801,1956,"rigorously tested."],[1956,2039,"Are you perhaps"],[2039,2152,"thinking of doing this"],[2152,2298,"the traditional way?"],[2298,2381,"With an added fee,"],[2381,2548,"we can make this happen."],[2548,2610,"No, no, no."],[2610,2690,"This is going"],[2690,2811,"to be done artificially, okay?"],[2811,3044,"There's no sex. There's no hassle."],[3044,3253,"Strictly business."],[3253,3345,"Is that clear?"],[3345,3432,"Crystal."],[3661,3791,"What about her?"],[3920,4079,"Abigail Brown,"],[4079,4225,"graduated from Oxford,"],[4225,4354,"straight A’s,"],[4354,4487,"IQ 130,"],[4487,4696,"semi-professional tennis player."],[4821,5005,"She is very expensive though,"],[5088,5388,"asking price is one million."],[5388,5467,"Done."],[6573,6719,"Please wait."],[8266,8379,"Mr. Sinclair,"],[8379,8466,"you're here."],[8946,9038,"Oh my God."],[9038,9196,"It’s his sperm, isn't it?"],[9196,9338,"I'm so fucked."],[9338,9451,"Oscar Sinclair is"],[9451,9701,"the richest man in Los Angeles."],[9701,9772,"He's going to"],[9772,9922,"sue the shit out of me."],[9980,10155,"I'm so sorry."],[10155,10235,"There must have"],[10235,10389,"been a system glitch."],[10389,10598,"The room numbers were switched"],[10598,10769,"for Abby and Phoebe."],[10998,11177,"What are you talking about?"],[11177,11302,"Is this not..."],[11532,11678,"Who the hell is she?"],[11745,11832,"I..."],[11966,12112,"We regret to inform that"],[12112,12274,"he accidentally injected"],[12274,12395,"Ms. Phoebe with"],[12395,12525,"Mr. Sinclair's sperm."]],"3":[[137,296,"Look,"],[296,383,"you're obviously not"],[383,479,"who I intended to be"],[479,738,"my surrogate, okay?"],[738,784,"First of all,"],[784,930,"you're too young for me."],[930,1030,"Second,"],[1030,1163,"you weren't even vetted by my agent."],[1163,1251,"Hey, I'm sorry."],[1251,1330,"I didn't want to be your"],[1330,1434,"surrogate either."],[1897,2139,"But since this is already happening,"],[2139,2214,"we might as well"],[2214,2344,"make arrangements."],[2652,2777,"I'm Oscar Sinclair,"],[2777,3007,"COO of Sinclair Group,"],[3053,3224,"a top fortune 500 company."],[3303,3424,"I asked for a surrogate"],[3424,3516,"to carry my child"],[3516,3636,"because I need an heir"],[3636,3678,"in order to"],[3678,3807,"take over my company."],[3933,4045,"And like the doctor said,"],[4045,4191,"you have a 25% chance"],[4191,4300,"of having my child."],[4300,4433,"So if it happens..."],[4433,4600,"If that happens,"],[4617,4733,"what I do with my child"],[4733,4863,"will have nothing to do with you,"],[4863,4934,"Mr. Sinclair."],[4934,5050,"Because I am never"],[5050,5205,"seeing you again."],[5205,5313,"What do you mean?"],[5313,5447,"If you become pregnant,"],[5447,5588,"we'll sign a contract."],[5588,5672,"You'll simply hand"],[5672,5851,"the baby over to me once it's born."],[5851,5972,"And I'll pay you."],[5972,6139,"That is never going to happen."],[6231,6327,"You think"],[6327,6544,"because you're some rich billionaire"],[6544,6694,"that you can buy a baby?"],[6694,6827,"My baby?"],[6919,6994,"I'm confused."],[6994,7061,"Were you not about"],[7061,7269,"to be a surrogate for that couple?"],[7269,7361,"I'm assuming this is"],[7361,7532,"because of money."],[7532,7653,"If you were going to sell for them,"],[7653,7766,"why can't you just sell to me?"],[7766,7836,"I don't understand."],[7836,7949,"What's the difference?"],[7949,8016,"The difference"],[8016,8120,"is that I am helping"],[8120,8208,"that family have a child"],[8208,8345,"of their own."],[8345,8487,"And yes,"],[8487,8629,"I did it for the money"],[8629,8842,"because my mother is in the hospital"],[8842,8971,"and she needs money"],[8971,9096,"for surgery."],[9209,9413,"But I am not selling"],[9413,9693,"my own baby."],[9693,9847,"Those are two"],[9847,10147,"very, very different things."],[10289,10573,"And when I have my own baby,"],[10573,10835,"it is going to be with my husband."],[10835,10927,"And that baby,"],[10927,11090,"that child,"],[11090,11236,"it will be born out of love."],[11373,11440,"If you"],[11440,11695,"cannot wrap your head around that,"],[11695,11778,"then you do not"],[11778,11911,"deserve to be a father."],[11974,12132,"Okay."],[12303,12404,"We'll get married."]],"4":[[91,271,"Get married?"],[283,392,"Yes."],[400,517,"If you get pregnant,"],[517,633,"we'll get married."],[692,792,"And after a year,"],[792,959,"we'll get a divorce."],[959,1071,"Name your terms."],[1172,1317,"You needed money, right?"],[1393,1522,"For your mom's surgery."],[1568,1630,"I mean, obviously,"],[1630,1851,"you're not getting paid anymore."],[1851,2047,"How much money do you need?"],[2047,2168,"One million dollars?"],[2264,2394,"Five million dollars?"],[2548,2640,"Name your price."],[2640,2802,"Oh my God, do you..."],[2802,2927,"Do you even hear yourself?"],[2973,3132,"I'm going to tell you this one last time."],[3232,3411,"If I am pregnant,"],[3465,3553,"that baby will have"],[3553,3724,"nothing to do with you."],[4166,4341,"Dear God."],[4441,4642,"Feisty girl."],[5526,5663,"Come on, Oscar, make your move."],[5663,5855,"What's taking you so long?"],[6081,6206,"Let's say I do have an heir,"],[6206,6322,"Grandpa."],[6573,6760,"But no wife."],[6861,7027,"Will that fulfill your requirement"],[7027,7190,"to take over the company?"],[7244,7428,"Wife. Child. Family."],[7482,7549,"And if you're thinking of"],[7549,7745,"adopting or worse, surrogate,"],[7745,7895,"you can kiss the company goodbye."],[8204,8387,"That was careless, Oscar."],[8516,8683,"Without the queen,"],[8721,8933,"the king is worthless."],[9776,9905,"Checkmate."],[10222,10272,"You win."]],"5":[[129,171,"Boss,"],[171,342,"her name is Phoebe Lamb,"],[342,429,"21 years old,"],[429,608,"5 feet 5, raised by a single mother"],[608,771,"who also happens to be seriously ill"],[771,863,"and hospitalized."],[863,921,"She's a junior"],[921,1046,"at Maple Hill University,"],[1046,1180,"owned by the Sinclair Group."],[1180,1288,"Oh, not bad."],[1288,1484,"Maple Hill University,"],[1484,1626,"means she's intelligent."],[1626,1714,"Ahh, well."],[1714,1755,"It looks like"],[1755,1881,"Miss Lamb is struggling."],[1881,2031,"Her GPA is below 2.5."],[2089,2139,"At this rate,"],[2139,2264,"she might not graduate."],[2277,2385,"She's failing?"],[2456,2598,"All of her classes?"],[4975,5013,"Hey!"],[5075,5167,"Watch it!"],[5167,5280,"Part time student."],[5280,5442,"Part time janitor."],[5442,5605,"I wonder who it can be?"],[5605,5759,"It's pathetic Phoebe."],[5759,5860,"Loser in high school,"],[5860,5968,"loser in college."],[5968,6160,"Some things never change."],[6160,6318,"She's even worse now."],[6318,6398,"At least in high school,"],[6398,6506,"she didn’t clean toilets."],[8416,8575,"Was that a pregnancy test?"],[8746,8954,"Looks like our nerd lost her V-card."],[9743,9930,"God please."],[9930,9959,"Please,"],[9959,10185,"don’t let me be pregnant."],[10239,10385,"Please don’t let me be pregnant."],[10385,10639,"Please, please, please."],[11544,11653,"Hey, it's me,"],[11653,11715,"Oscar."],[11811,11920,"It's been ten days."],[11920,11991,"Are you pregnant?"],[11991,12087,"I need to know."],[12149,12228,"Oscar?"]],"6":[[29,212,"How did you get my number?"],[212,296,"I mean,"],[392,496,"are you stalking me?"],[496,650,"I thought I told you that..."],[1071,1138,"Oh, no."],[1138,1317,"This can't be happening."],[1317,1405,"What?"],[1472,1601,"What's happening?"],[1601,1739,"Are you pregnant?"],[1826,1926,"Hello?"],[2002,2147,"I’m really pregnant."],[2306,2494,"What am I gonna do?"],[2540,2669,"She just hung up on me."],[2815,2869,"It sounded like"],[2869,2977,"something happened."],[3028,3144,"Could she be pregnant?"],[3144,3224,"Steven, drive."],[3224,3307,"Phoebe's at school."],[3307,3420,"I need to find her right away."],[4058,4137,"No matter what,"],[4137,4233,"this is my baby."],[4337,4496,"I will do whatever I can"],[4496,4721,"to raise this baby on my own."],[5630,5764,"Oh my God."],[5764,5901,"She really is pregnant."],[5918,5985,"Stop."],[6014,6222,"Are you having a bastard child?"],[6222,6289,"Just give it-"],[8062,8103,"Everyone"],[8103,8174,"check this out."],[8420,8566,"Phoebe is going to be a mom."]],"7":[[25,133,"Everyone check this out."],[133,283,"Phoebe's going to be a mom."],[696,742,"See?"],[742,892,"Even God's mocking you."],[1584,1776,"Why is it suddenly raining?"],[1776,1914,"I hope she brought a jacket."],[1985,2081,"Whoever got you pregnant"],[2081,2260,"must be old and disgusting."],[2260,2356,"Why are you doing this to me?"],[2356,2494,"I never did anything to you."],[2494,2615,"Because you're poor,"],[2615,2761,"and an eyesore."],[2761,2907,"How dare poor trash like you"],[2907,3053,"attend the same school as us?"],[3053,3123,"Exactly."],[3153,3219,"Poor people should"],[3219,3307,"know their place."],[3353,3382,"What’s the point of"],[3382,3516,"having kids if you're broke?"],[3636,3753,"I wonder how far along"],[3753,3903,"little bastard is."],[4429,4500,"No, no!"],[4533,4596,"Let me go!"],[4662,4721,"Let me go!"],[4884,4963,"Take off her clothes"],[4963,5105,"and see how far along she is."],[5284,5459,"This is against school rules."],[5459,5509,"Stop!"],[5626,5684,"Emma,"],[5684,5872,"what if someone sees?"],[5872,6006,"We could get into trouble."],[6006,6101,"So what?"],[6101,6239,"She's just a broke bitch."],[6239,6356,"My dad is the president."],[6356,6535,"My family basically runs the school."],[6698,6790,"What are you waiting for?"],[6790,6961,"Get those rags off her."],[9484,9684,"How dare you kick me, you bitch!"],[10168,10251,"Let me show you how to"],[10251,10410,"act like the broke bitch you are."],[10410,10543,"Guys, get her!"],[10994,11081,"Let me go!"],[12867,12958,"You dirty whore!"],[12958,13175,"Let the rain wash away your filth."]],"8":[[925,1105,"Phoebe, I am so sorry."],[1130,1292,"Oscar, what are you doing here?"],[1918,2056,"I came here to talk to you."],[2156,2235,"Don't worry."],[2235,2306,"I'm here."],[2306,2339,"Okay?"],[2339,2427,"You're safe."],[2781,2831,"Hey!"],[2831,2911,"My phone!"],[2911,3023,"Who do you think you are"],[3023,3115,"to intervene?"],[3115,3236,"Oh my God."],[3236,3328,"Is this her old and"],[3328,3457,"disgusting baby daddy?"],[3712,3866,"You two like the rain?"],[3895,3970,"Then you can stay there"],[3970,4099,"until you learn your lesson."],[4337,4408,"How dare you!"],[4408,4529,"Do you even know who I am?"],[4529,4633,"Yeah, Emma’s dad"],[4633,4783,"is the school's president."],[4783,4888,"When he gets here,"],[4888,5067,"you all are so dead."],[5226,5292,"You hear that?"],[5292,5380,"You better let me go"],[5380,5538,"and apologize right now."],[5951,6064,"Your dad's school?"],[6731,6852,"Do you know who I am?"],[6873,7023,"You're part of the security team?"],[7023,7152,"Just wait until my daddy gets"],[7152,7294,"here and fires all of you."],[7357,7440,"What if I told you"],[7440,7624,"that I own this school"],[7624,7903,"and that your daddy is on my payroll?"],[8237,8316,"Yeah, right."],[8316,8454,"He's bluffing!"],[8454,8521,"Wait."],[8521,8708,"I think he looks familiar."],[8808,9042,"Isn't he on the school board?"],[9042,9225,"He's bluffing, right?"],[9225,9296,"Emma?"],[9388,9476,"Of course he is."],[9476,9601,"He's with Phoebe."],[9601,9772,"He must be a loser like her."],[9864,9989,"Then call your dad."],[10251,10402,"Dad, I need you here right now."],[10402,10493,"I'm at the gym."],[10493,10668,"Security beat me up."],[11294,11574,"What the hell is going on here?"],[11682,11732,"Dad!"],[11732,11786,"It's them."],[11786,11916,"They're the ones bullying me."],[12041,12091,"Turn around."],[12091,12195,"I want to see the person"],[12195,12404,"who's bullying my daughter."],[12862,12950,"It's me,"],[13021,13104,"Mr. President."]],"9":[[0,225,"Mr, Mr, Mr, Mr. Sinclair."],[296,462,"What are you doing here?"],[462,546,"Dad, make him"],[546,704,"apologize to me right now."],[930,1084,"Dad, why did you hit me?"],[1084,1192,"Shut up!"],[1251,1509,"Mr. Sinclair is head of the board."],[1509,1697,"He owns the school."],[1985,2152,"He owns the school I'm attending?"],[2285,2485,"This has nothing to do with us."],[2485,2669,"Yeah, it was all them."],[2669,2794,"We didn't do anything."],[2794,2886,"Mr. Sinclair. I'm sorry."],[2886,2932,"We,"],[2965,3094,"we didn't know."],[3111,3219,"Emma put me up to it."],[3219,3282,"She's been bullying"],[3282,3411,"Phoebe since high school."],[3411,3549,"Eva, you bitch!"],[3549,3687,"MHU has a zero tolerance"],[3687,3778,"for bullying."],[4029,4116,"Everyone involved here"],[4116,4220,"today is expelled."],[4654,4779,"And as for you."],[4850,4925,"You're fired."],[4996,5121,"Steven,"],[5121,5213,"make sure I don't see"],[5213,5296,"any of these people"],[5296,5405,"at my school again."],[5601,5784,"My stomach hurts."],[5784,5976,"Is my baby okay?"],[6072,6239,"Phoebe, Phoebe!"],[6289,6356,"Steven."],[6356,6489,"Hospital."],[7578,7741,"What happened?"],[7741,7866,"Where am I?"],[8742,8854,"Is my baby okay?"],[8900,8988,"Yes."],[9042,9154,"They're fine."],[9484,9526,"Phoebe,"],[9526,9597,"why didn't you tell me"],[9597,9776,"you were pregnant with my baby?"],[9776,9905,"That was very dangerous."],[9934,10072,"I should have came to you sooner."],[10422,10506,"No."],[10885,11065,"Not a baby."],[11065,11182,"Babies."],[11236,11407,"I just took a closer look and..."],[11636,11799,"Congratulations."],[11799,11986,"You're pregnant with triplets."],[12024,12091,"Triplets? - Triplets?"]],"10":[[16,175,"Congratulations."],[175,375,"You're pregnant with triplets."],[375,487,"Triplets? - Triplets?"],[1067,1209,"Oh my God."],[1209,1338,"I’m pregnant with triplets."],[1488,1593,"Let’s get married."],[1768,1847,"What?"],[2010,2064,"No."],[2193,2356,"Look, like I said, this is..."],[2356,2452,"this is not your fault,"],[2452,2577,"the doctor messed up."],[2640,2706,"I am going to"],[2706,2848,"take care of these babies on my own."],[2848,2907,"On your own?"],[2907,3019,"How?"],[3019,3128,"With what money?"],[3190,3386,"You're a student in college,"],[3386,3440,"and this has"],[3440,3536,"everything to do with me."],[3536,3661,"These are my babies, too."],[3678,3770,"No."],[3795,3928,"No, these babies are a way for you"],[3928,4062,"to take over the company."],[4141,4179,"For me,"],[4179,4312,"these babies are my family."],[4312,4371,"And I don't have"],[4371,4525,"very many family left."],[4700,4763,"Okay."],[4829,4984,"I'm sorry I said that."],[5025,5150,"That was earlier."],[5296,5405,"But now,"],[5472,5605,"I actually look forward to you"],[5605,5663,"being the mother"],[5663,5772,"of my children."],[5851,5960,"Now what?"],[6327,6410,"Nothing."],[6531,6752,"Anyways, I'm sorry, Phoebe."],[6881,6961,"The truth is,"],[7119,7319,"it's because of my grandfather."],[7424,7611,"Wife, child, family."],[7661,7782,"And if you're thinking of adopting"],[7782,7903,"our worse, surrogate."],[7928,7978,"You can kiss"],[7978,8078,"the company goodbye."],[8212,8316,"If he finds out we're"],[8316,8441,"not the real deal,"],[8525,8721,"and he learns that you're pregnant."],[8721,8829,"Pregnant with my babies,"],[8829,8950,"Sinclair babies."],[9054,9221,"He's going to do anything he can"],[9221,9334,"to take them from you."],[9705,9784,"He wouldn't."],[9784,9909,"He wouldn't do that."],[9909,9968,"You don't know"],[9968,10164,"my grandfather like I do."],[10164,10281,"He's one of the most traditional"],[10281,10447,"and stubborn men that I know."],[10506,10685,"He's the reason I'm in this mess."],[10860,10990,"All I'm saying is,"],[11048,11161,"help me,"],[11236,11357,"so I can help you."],[11632,11765,"Please."],[11953,12112,"What do we need to do?"],[13150,13400,"I can't believe we're married."],[13400,13655,"Even if it is a contract marriage."],[13655,13926,"So, Mr. Sinclair,"],[14039,14197,"we’re married."],[14260,14376,"Now what?"],[14376,14510,"Well, Mrs. Sinclair,"],[14614,14718,"the real test starts when"],[14718,14894,"you meet my grandfather."],[14944,15056,"Remember, he cannot find"],[15056,15156,"out the truth."],[15219,15336,"For both of our sakes."]],"11":[[988,1167,"Married with an heir?"],[1167,1355,"What kind of shit is my uncle"],[1355,1522,"pulling this time?"],[2919,3219,"So, you expect me to believe,"],[3219,3345,"that you went from single"],[3345,3578,"to married with triplets?"],[3578,3645,"We've been dating"],[3645,3849,"for a while, grandpa."],[3849,3999,"But when she got pregnant"],[3999,4074,"with triplets."],[4074,4254,"I mean, it was the right thing to do"],[4254,4425,"to get married."],[4425,4546,"Isn't that right, sweetheart?"],[4750,4838,"Yeah."],[5063,5176,"So how do we even know"],[5176,5372,"these are your kids, Oscar?"],[5543,5634,"You know, I knew nothing"],[5634,5772,"good would come from your mouth."],[5772,5826,"Why don't you take"],[5826,5922,"a look for yourself?"],[5922,6193,"This is In-Vitro DNA testing."],[6193,6364,"Okay, these babies are mine."],[6861,6931,"And,"],[7036,7228,"how do we know this random woman,"],[7290,7428,"isn't just a surrogate?"],[7428,7511,"Okay, she's not some"],[7511,7599,"random woman, okay?"],[7599,7753,"She's my wife."],[7753,7836,"And from here on out,"],[7836,8028,"you'll call her Aunt Phoebe."],[8028,8149,"Show some respect."],[8775,8933,"Mr. Sinclair, I know that this"],[8933,9121,"doesn't sound..."],[9159,9330,"You can call me Grandpa Robert."],[10005,10164,"Welcome to the family."],[10402,10485,"Okay,"],[10485,10694,"that was easier than I thought."],[10694,10794,"And here I thought"],[10794,10994,"Oscar’s grandpa would be scary."],[11482,11686,"Well, grandpa, it's getting late."],[11686,11770,"Maybe you and William"],[11770,11899,"should head home,"],[11899,12099,"and we can celebrate this"],[12099,12199,"some other time."],[12199,12420,"Who said anything about going home?"],[12420,12620,"William and I are staying the night."],[12620,12729,"Surely that's all right"],[12729,12871,"with you two lovebirds."]],"12":[[75,250,"Crap, crap!"],[250,421,"I cannot believe his grandfather"],[421,600,"and nephew are both staying the night."],[729,9