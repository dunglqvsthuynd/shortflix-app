{"1":[[0,166,"Sir, you should rest."],[166,291,"I'll leave you alone now."],[654,792,"I've been drugged!"],[992,1138,"Ice water sent up?"],[1447,1526,"There you go,sir."],[1526,1664,"Do you need anything else?"],[1697,1797,"Is everything alright?"],[1797,1951,"You don't look too well."],[2840,2948,"Please."],[2948,3057,"You have to help me."],[3123,3311,"Make it worth your while."],[5705,5826,"Boss! Are you hurt?"],[5964,6068,"Not my blood."],[6164,6247,"Whose then?"],[6314,6435,"She left before I woke up."],[6585,6731,"I got her employee number."],[6961,7044,"She deserves a tip."],[7094,7219,"Send her $10,000."],[7878,8099,"Chloe! You covered for me, right?"],[8133,8350,"The hotel sent me a ten grand tip!"],[8445,8604,"How did you manage to do this?"]],"2":[[141,187,"Last night,"],[187,375,"I had to deal with a drunk customer."],[529,671,"I guess $10,000 is"],[671,800,"pocket change for the rich."],[892,1071,"Wow, it's amazing."],[1092,1305,"This money is for your wedding fund!"],[1743,1860,"Ms. Hartman,"],[1860,2010,"your degree is impressive,"],[2010,2081,"but you don't have"],[2081,2239,"any work experience."],[2285,2406,"We've chosen someone else"],[2406,2523,"for the secretary role."],[2565,2619,"Sorry."],[4187,4354,"What is he doing here?!"],[4792,4871,"Careful, boss."],[4896,5067,"You almost stepped on her resume."],[5459,5568,"Do I know you?"]],"3":[[158,333,"No, I don't think so."],[1251,1322,"Mr. West,"],[1347,1438,"this is Ruby Ross,"],[1438,1539,"our top candidate for"],[1539,1668,"the secretary position."],[1843,1976,"Did a Ms. Hartman interview today?"],[1997,2064,"Yes, sir."],[2064,2214,"Her name is Chloe Hartman."],[2214,2385,"College grad, no experience."],[2402,2506,"Let me see her resume."],[2548,2669,"Ruby is more qualified."],[2890,3023,"Hire, Chloe."],[4300,4375,"Hello?"],[4441,4546,"Chloe Hartman?"],[4575,4675,"Congratulations!"],[4675,4900,"Mr. West wants to extend an offer for"],[4900,5042,"the secretary position."],[5680,5880,"Oh, he must have recognized me!"],[5951,6081,"Won't this be weird?"],[6106,6239,"You've really lucked out!"],[6277,6335,"You were chosen"],[6335,6535,"out of many qualified applicants!"],[6556,6664,"Can you start Monday?"],[6685,6748,"No!"],[6748,6873,"There's no way he remembers"],[6873,6940,"that night."],[6956,7057,"He's too busy."],[7136,7386,"I should take the job so mom can retire."],[7465,7520,"Yeah!"],[7553,7695,"I can definitely start on Monday."],[7757,7845,"Thank you."]],"4":[[37,83,"Erik."],[133,246,"Look into the woman"],[246,387,"that worked at the Golden City Hotel,"],[412,492,"two weeks ago."],[513,600,"I think it might've been"],[600,667,"Chloe Hartman."],[734,825,"I already did when"],[825,975,"you had me send the payments."],[1021,1092,"The ID you gave me"],[1092,1192,"belonged to a woman"],[1192,1405,"in her forties, not Chloe."],[1509,1618,"Could I be mistaken?"],[1710,1810,"That night..."],[2494,2623,"The woman was younger!"],[3065,3148,"Good morning."],[3294,3386,"Mr. West!"],[3432,3503,"Good morning."],[3561,3586,"Chloe,"],[3586,3737,"have you ever worked at a hotel?"],[3853,4037,"No, I didn't."],[4154,4220,"Two weeks ago?"],[4471,4596,"The Golden City Hotel?"],[5100,5213,"Eason, I brought you..."],[5309,5392,"breakfast."],[5551,5676,"What's going on?!"],[5718,5839,"She's my new Secretary."],[5935,6068,"And you're just standing there?"],[6197,6335,"Clean up this mess."],[6548,6631,"Eason,"],[6631,6848,"I saw the cute dress yesterday."],[6848,7011,"But I'm not sure if I should get it."],[7040,7157,"Will you want to come with me"],[7157,7240,"to try it on?"],[7319,7453,"If you like it, just buy it."],[7465,7749,"Oh Eason, you spoil me!"],[7786,7916,"Maybe..."],[7916,8037,"you should spend the night"],[8037,8179,"at my place."],[8258,8425,"Or should I come over to yours?"],[8800,8942,"I'm so sorry, Mr. West!"],[8975,9038,"Please forgive me."],[9104,9376,"Don't you dare to judge me!"],[9484,9622,"You may think you're pretty,"],[9672,9834,"but you'll never replace me."],[10026,10197,"I'm the one Eason loves."]],"5":[[37,162,"I should go back to work."],[442,558,"Careful, dear."],[604,654,"You wouldn't want"],[654,800,"to make a bad impression."],[1747,1864,"If there's nothing else,"],[1864,2047,"I'll just take out the trash and leave."],[2089,2156,"Come with me to"],[2156,2289,"a crucial lunch meeting."],[2419,2548,"Shouldn't you be going shopping"],[2548,2627,"with your girlfriend?"],[2673,2727,"So what?"],[2873,3048,"No, I don't want to risk upsetting her."],[3073,3215,"I will have her go with Erik."],[3315,3399,"It's..."],[3457,3557,"complicated."],[3611,3707,"Let's just say"],[3707,3874,"it's for appearances."],[3941,4116,"He's so ruthless."],[4729,4875,"Mr. West,"],[4875,5046,"your new secretary looks"],[5109,5188,"young!"],[5238,5422,"Can she hang with the boys?"],[5830,5926,"Cheers Chloe!"],[5997,6076,"Cheers."],[7107,7219,"Cheers!"],[7399,7469,"Cheers."],[8266,8379,"Excuse me."],[9467,9526,"Mr. West,"],[9663,9801,"I think I drank too much."],[9801,9889,"I feel sick."],[9984,10155,"If you don't want to join us for a drink,"],[10155,10247,"just be honest."],[10581,10727,"Were you at the hotel that night?"],[11069,11136,"Chloe!"],[11223,11323,"Chloe, you okay?"],[11503,11557,"Chloe!"]],"6":[[971,1155,"It's you, Eason."],[1330,1434,"You're wasted."],[1785,1981,"It's the room from last time."],[2060,2248,"Why did you bring me here?"],[2298,2577,"What are you trying to do to me?"],[2623,2736,"Do you even know?"],[2848,2915,"You don't want who"],[2915,3011,"always provokes me."],[3436,3570,"I just want to make you feel good."],[3757,3841,"Feel good?"],[4016,4079,"How?"],[4275,4341,"Like this."],[4587,4625,"Chloe!"],[4671,4871,"Don't ever pretend you don’t know me."],[5046,5121,"This time"],[5226,5313,"I'll leave so many"],[5313,5405,"marks on you that"],[5476,5597,"you can't deny it!"],[7265,7344,"Wait,"],[7344,7461,"I haven't had my period"],[7461,7549,"over a month."],[7574,7786,"I've been nauseous all day."],[7828,7945,"Could I be pregnant?"],[8466,8579,"I'm pregnant!"],[8637,8767,"How is that possible?"],[8804,8875,"Chloe?"],[8979,9038,"You alright?"]],"7":[[45,212,"Yeah, I'm fine."],[300,467,"You smell like alcohol."],[467,558,"Were you drinking at work?"],[679,804,"I didn't drink much."],[834,909,"Don't worry Mom."],[942,1105,"And my boss is very understanding."],[1105,1172,"He even let me"],[1172,1297,"leave a little early today."],[1330,1430,"Please take a shower."],[1505,1630,"Dinner's on the table."],[1664,1772,"I'm working the night shift."],[1814,1910,"See you later."],[2298,2373,"Twins?"],[2439,2540,"Twins?!"],[2540,2702,"I can't afford twins!"],[2752,2944,"Plus, my doctor warned me that"],[2944,3044,"terminating the pregnancy"],[3044,3169,"will affect my fertility."],[3274,3374,"What do I do?!"],[3987,4054,"You okay?"],[4216,4283,"How was the appointment"],[4283,4425,"with the doctor?"],[4504,4575,"I'm fine."],[4633,4717,"Are you sure?"],[4842,4954,"Yeah, I'm fine."],[5005,5121,"Show me the results."]],"8":[[54,150,"Show me the results."],[350,408,"Boss,"],[450,613,"are you sure this is an appropriate"],[613,717,"question to be asking"],[717,804,"your employee?"],[838,980,"The doctor said i’m..."],[980,1076,"allergic to alcohol,"],[1076,1213,"and I shouldn't drink anymore."],[1317,1459,"Just scared of losing my job."],[1497,1639,"Even if you weren't allergic,"],[1689,1747,"I wouldn't let you"],[1747,1835,"drink with me anymore."],[1885,2010,"You're such a light weight."],[3103,3199,"Hi."],[3219,3361,"I was just passing by your office,"],[3361,3520,"so I decided to drop by."],[3570,3737,"Are you free this weekend?"],[3737,3795,"My parents are"],[3795,3933,"inviting us for dinner."],[3987,4079,"It's over, Maura."],[4079,4154,"We're done."],[4250,4320,"Why?"],[4425,4562,"If you don't want to go to my house,"],[4562,4654,"that's fine!"],[4725,4884,"Have you found someone else?"],[4909,4979,"We had an agreement."],[5000,5121,"It was all for the show."],[5292,5367,"Here's your payment."],[5401,5538,"I don't want your money!"],[5613,5693,"Is this because of"],[5693,5797,"your new secretary?"],[5839,5976,"Did she seduce you?"],[5993,6081,"Don't be foolish."],[6126,6193,"Take the check"],[6193,6281,"and get out!"],[6785,6906,"Mr. West,"],[6923,6998,"I overheard"],[6998,7119,"Maura's accusations."],[7119,7223,"Why didn't you deny it?"],[7273,7403,"We didn't do anything wrong."],[7449,7524,"She's up to something."],[7682,7761,"You were..."],[7761,7824,"all over me when"],[7824,7941,"I brought you to the hotel."],[8053,8170,"You weren't so innocent."],[8195,8333,"I don't remember any of that."],[8362,8458,"Please don't make up scenarios"],[8458,8521,"in your head."],[8587,8729,"You don't remember this time either?"],[8821,8988,"Maybe I'll show you the evidence."],[9238,9346,"What are you doing?"]],"9":[[500,629,"I left marks everywhere"],[629,750,"so you can't deny it."],[1096,1205,"How about now?"],[1347,1488,"You can't deny it, right?"],[1764,1843,"Chloe, you are the one"],[1843,1993,"who always seduces me."],[2857,2923,"That was before"],[2923,3082,"I knew you had a girlfriend."],[3174,3286,"So you mean"],[3345,3403,"that was mean"],[3403,3524,"the night a month ago."],[3774,3853,"Yes."],[3895,4045,"But I didn’t know it back then."],[4325,4400,"This is wrong."],[4400,4525,"You have a girlfriend."],[4612,4750,"I broke up with Maura."],[4821,4925,"Now, I can do it."],[5092,5159,"Do it?"],[5205,5326,"What are you talking about?"],[5405,5530,"I have something to say."],[5634,5718,"8 PM."],[5789,5930,"Green Island Restaurant."],[6798,6894,"Mr. West."],[7090,7198,"I'm pregnant."],[7336,7461,"And the baby is..."],[9325,9463,"He just left."],[9563,9684,"Doesn't care."],[9722,9930,"I was so stupid to think he might."],[10397,10552,"I'm so sorry, babies."],[10648,10748,"I can't raise you."],[10748,10848,"I just..."],[10906,11077,"I just can't do it."]],"10":[[66,187,"He just left."],[250,354,"He doesn't care!"],[408,483,"He doesn't even"],[483,588,"care about our babies."],[1205,1276,"Eason,"],[1322,1509,"your grandma's situation is serious."],[1555,1747,"I've heard Dr. Julian Greene"],[1747,1810,"is the best"],[1810,1951,"neurosurgeon in the country."],[1951,2060,"Call Maura."],[2093,2273,"Ask her father to do the surgery."],[2277,2344,"Dad,"],[2427,2531,"Maura and I broke up."],[2552,2606,"What?"],[2627,2731,"When did this happen?"],[2748,2811,"Yesterday."],[2898,2973,"But I'll ask her father"],[2973,3082,"to perform the surgery."],[3111,3182,"Good."],[3215,3328,"And be polite!"],[3357,3436,"Maura loves you."],[3461,3553,"Even after a breakup,"],[3553,3670,"she wouldn't hold a grudge."],[4133,4258,"Eason West!"],[4404,4504,"You've got the nerve"],[4504,4571,"to show up here"],[4571,4658,"after breaking"],[4658,4758,"my daughter's heart?!"],[4796,4959,"She cried all night because of you."],[5021,5167,"How could you hurt her like that?"],[5188,5313,"I'll apologize to Maura."],[5422,5476,"Right now, I need to"],[5476,5568,"save my grandmother."],[5718,5809,"Name your price."],[5901,6047,"If I save her,"],[6139,6285,"you'll have to marry Maura."],[6456,6569,"And don't you dare"],[6569,6677,"break her heart again."],[7102,7194,"Fine."],[8604,8750,"The surgery was a success."],[8892,9071,"She should come to in the next"],[9071,9163,"24 hours."],[9217,9446,"Dr. Greene, we're deeply in your debt."],[9446,9488,"I don't know how"],[9488,9609,"we'll ever repay you."],[9705,9926,"Eason agreed to marry Maura"],[9926,10060,"if the surgery was successful."],[10297,10472,"I hope your family will keep their word."],[10589,10698,"The West family"],[10698,10844,"always honors its commitments."]],"11":[[392,437,"Erik,"],[529,717,"why isn't Eason here today?"],[809,1005,"He's dealing with something at home."],[1005,1080,"Didn't he tell you?"],[1155,1297,"Is everything okay?"],[1372,1468,"What happened?"],[1484,1609,"Family matters."],[1768,1935,"I misunderstood him."],[1935,2089,"I'll wait until he's less busy"],[2089,2264,"to tell him about the twins."],[2615,2740,"I'm pregnant."],[2781,2907,"It's our baby."],[3866,3995,"I'm pregnant."],[3995,4095,"It's our baby."],[4200,4375,"So that's why he broke up with me!"],[4471,4646,"Because of that tramp, Chloe!"],[4721,4946,"She thinks she can steal my man?"],[5017,5238,"She is going to regret it."],[5563,5689,"Oh my god!"],[5751,5868,"Our boss and Maura"],[5868,5968,"are getting married!"],[5980,6072,"Wait,"],[6072,6177,"how did you know?"],[6177,6418,"Maura just posted it on her socials!"],[6448,6577,"She said once Eason's grandma"],[6577,6752,"is better, they're getting hitched!"],[6781,6902,"She tagged him!"],[6902,7002,"Did he respond?"],[7057,7152,"Not yet,"],[7152,7307,"but his mom did!"],[7374,7499,"She called Maura"],[7499,7661,"\"daughter-in-law.\""],[7686,7816,"It's official!"]],"12":[[900,955,"What?"],[980,1030,"Chloe,"],[1030,1163,"did you say you're pregnant?"],[1213,1309,"Yes."],[1309,1422,"Whose baby is it?"],[1530,1647,"It's not yours."],[1647,1710,"Don't worry."],[1768,1889,"I heard you're marrying Maura."],[1926,2031,"Congratulations."],[2052,2185,"Chloe! Are you crazy?!"],[2185,2264,"You're pregnant"],[2264,2389,"with another man's child,"],[2427,2569,"and you have the nerve to tell me?"],[2569,2619,"Yeah,"],[2665,2819,"I told you on purpose."],[2865,3023,"I don't want to be lied to anymore."],[3065,3161,"You've got Maura,"],[3161,3274,"and I’ve got my baby."],[3374,3453,"Let's call it quits."],[3470,3557,"Who's the father?"],[3611,3695,"It's personal."],[3695,3778,"Chloe Hartman,"],[3803,3903,"you've got some nerve!"],[3962,4120,"My phone's about to die. Bye."],[4879,4954,"Miss Hartman,"],[5000,5217,"it's rare to be pregnant with twins."],[5217,5267,"Are you sure"],[5267,5426,"you want to go through with this?"],[5551,5668,"I'm sure."]],"13":[[487,633,"Is this Mrs. Hartman?"],[684,829,"You have a parcel from your daughter."],[959,1055,"Chloe never mentioned"],[1055,1163,"anything about a gift."],[3499,3561,"Hello?"],[3607,3737,"Is this Chloe Hartman?"],[3803,3924,"Your mother, Lucy Hartman,"],[3924,4058,"was in a car accident."],[4129,4191,"She..."],[4191,4354,"passed away shortly after."],[4466,4617,"No, she's at work!"],[4617,4738,"That can't be true!"],[4771,4842,"You must have called"],[4842,4913,"the wrong person."],[4938,5042,"The accident happened"],[5042,5163,"right outside the hotel."],[5217,5296,"Her coworkers"],[5296,5417,"confirmed her identity."],[5455,5555,"I'm coming right now."],[5697,5759,"Miss Hartman,"],[5759,5822,"are you going ahead"],[5822,5910,"with the procedure?"],[5930,6060,"No, I can't."]],"14":[[1288,1522,"This can't be happening!"],[1764,1835,"Miss Hartman,"],[1914,2052,"I'm so sorry, but we have to move"],[2052,2168,"your mother's body now."],[2268,2406,"Who killed her?!"],[2498,2635,"The suspect has fled the scene."],[2635,2769,"But we're doing everything we can"],[2769,2873,"to track them down."],[2961,3132,"You have to catch them!"],[3169,3332,"You have to catch them!"],[5030,5125,"She's gone..."],[5209,5351,"my only family,"],[5401,5472,"gone."],[5559,5764,"Why does the God hate me so much?"],[6873,6944,"Hello?"],[6944,7077,"This is a warning."],[7123,7294,"Stay away from Eason West."],[7399,7553,"Was this Maura's doing?"],[8008,8116,"What are you doing here?"],[8254,8379,"Trying to be a third wheel?"],[8521,8633,"You had my mother Killed!"]],"15":[[25,125,"She's lost it!"],[141,333,"I have no idea what she's talking about!"],[333,412,"Chloe! Let her go!"],[429,525,"How dare you not own up to what"],[525,588,"you've done?"],[621,792,"My mother was everything I had"],[792,934,"and you took her away from me."],[1009,1071,"I swear."],[1113,1313,"I'm not let you get away with this."],[1343,1434,"Eason, my hand!"],[1434,1572,"It's going to break up!"],[1572,1672,"Do something!"],[2068,2235,"The only person to ever hate me this"],[2235,2318,"much is Maura."],[2373,2506,"You know it, Eason!"],[2615,2731,"The only reason you're defending"],[2731,2902,"her because she's your fiancée!"],[2932,3048,"Eason, I swear."],[3082,3307,"I didn't even know Chloe's mom died!"],[3353,3528,"If I had something to do with it,"],[3528,3687,"I can drop dead right now!"],[3699,3795,"After killing someone,"],[3795,3903,"what good is your word?"],[3991,4124,"Chloe, I'm going to investigate."],[4183,4312,"If it turns out Maura had nothing to do"],[4312,4408,"with your mom's death,"],[4483,4608,"you will need to apologize."],[4717,4788,"Fine."],[4884,5038,"I'll wait for the truth."],[6151,6247,"Mom,"],[6302,6481,"Eason said he'd find out the truth."],[6698,6848,"I don't know if I can trust him."],[7077,7186,"I have no one else."],[7353,7507,"I've decided to keep the twins."],[7736,7816,"I know"],[7816,7899,"it's risky."],[7978,8112,"Like I already lost you."],[8383,8512,"But I don't want to lose them too."]],"16":[[16,70,"Hello?"],[125,229,"Where are you?"],[271,467,"I don't even know where am I now."],[508,658,"The cops are all over me!"],[738,930,"I'm stuck in some random field!"],[967,1105,"You were supposed to send someone"],[1105,1259,"to take me out from the country!"],[1284,1459,"I’ll send you my location,"],[1459,1593,"send someone qucikly!"],[1593,1693,"Send me the location."],[1726,1818,"I'll take care of it."],[2147,2268,"You're Maura's guys, right?"],[2406,2510,"Where are we going now?"],[3566,3674,"The cops called me earlier."],[3787,3824,"They found the guy"],[3824,3916,"who killed your mom."],[3987,4058,"And?"],[4087,4216,"Let's go to the station!"],[4287,4375,"They found him,"],[4412,4479,"but..."],[4721,4800,"but he's dead."],[4900,4954,"What?"],[5009,5067,"How?"],[5155,5217,"No."],[5271,5476,"Eason, I refuse to accept that!"],[5513,5705,"You promised you find out the truth,"],[5739,5868,"not some dead end!"],[5930,6001,"The cops"],[6089,6227,"found no connection"],[6247,6348,"between Maura"],[6348,6456,"and the suspect."],[6560,6731,"The case is soon to be closed."],[6840,6886,"No."],[6965,7011,"No."],[7032,7186,"No, this can't be happening."]],"17":[[83,154,"Chloe,"],[229,333,"I know your father passed away"],[333,417,"when you were young,"],[496,621,"and it's always been"],[621,725,"just you and your mom."],[804,959,"Losing her like that is"],[1038,1138,"devastating,"],[1151,1276,"but it was an accident."],[1313,1397,"Accident?"],[1430,1580,"What about that phone call?"],[1580,1760,"Did you even listen to the recording?"],[1810,1935,"That man said I was flirting with"],[1935,2064,"somebody else's man, that's why"],[2064,2177,"he killed my mother."],[2235,2356,"To teach me a lesson."],[2406,2464,"Do you really think"],[2464,2573,"that was an accident?"],[2602,2769,"The police couldn't find any evidence"],[2815,2894,"linking Maura and"],[2894,3036,"your mom's accident."],[3144,3190,"No."],[4008,4104,"Chloe,"],[4145,4254,"your mom is gone."],[4320,4466,"Your life isn't over."],[4537,4650,"Take some time off."],[4733,4850,"I'll give you two weeks."],[4929,5013,"When you're ready,"],[5092,5242,"I'll give you your old job back."],[6936,7044,"Your grandmother suffered some"],[7044,7203,"brain damage from the stroke."],[7298,7536,"She's going to need time to recover."],[7590,7691,"She can't speak or"],[7691,7945,"recognize people yet, but don't worry."],[7995,8153,"I'll monitor her closely."],[8212,8412,"So she's in a vegetative state?"],[8441,8541,"In a manner of speaking,"],[8591,8825,"but it's not as bad as you think."],[8908,9054,"From the medical standpoint,"],[9054,9205,"her surgery was a success."],[9259,9446,"I'm not questioning your skills, Dr."],[9496,9592,"But I'm going to wait until"],[9592,9797,"my grandmother can speak"],[9855,9997,"before I marry Maura."]],"18":[[417,513,"Mr. West,"],[571,679,"how may I help you?"],[779,925,"Are you struggling with anything"],[925,1026,"in your personal life?"],[1134,1188,"No,"],[1209,1380,"everything is perfectly fine."],[1493,1609,"Thank you for asking."],[1655,1780,"What about your pregnancy?"],[1818,1939,"What will you do?"],[2260,2352,"Your mother is gone."],[2364,2456,"And It's only you now."],[2502,2610,"Whoever the father is,"],[2656,2827,"clearly doesn't intend to step up."],[2827,2969,"That is none of your business."],[3019,3140,"Are you seriously thinking about"],[3140,3194,"keeping it?"],[3278,3336,"Chloe,"],[3353,3490,"who's going to take care of the kid?"],[3561,3707,"You don't have the means to provide"],[3707,3812,"a good life for them."],[3891,4024,"I'm giving you good advice."],[4054,4141,"Don't be stubborn!"],[4312,4446,"You're getting marry to Maura."],[4525,4579,"Maybe you should just"],[4579,4696,"focus on her instead."],[4971,5075,"That's everything?"],[5075,5209,"I'll see myself out."],[5305,5405,"You're seriously thinking about"],[5405,5572,"giving birth to a bastard child?"],[5609,5772,"My child is not a bastard."],[5814,5901,"If my pregnancy"],[5901,6026,"bothers you this much,"],[6143,6277,"I don't have to work here anymore."],[6368,6481,"Are you threatening me?"],[6514,6677,"I'm just a secretary."],[6735,6831,"How could I possibly"],[6831,6915,"threaten you?"],[8179,8350,"Boss, can I take you home now?"],[8454,8541,"Call Chloe now."],[8571,8616,"What?"],[8637,8708,"Why?"],[8762,8833,"Ask her"],[8875,8963,"how's it going to take her"],[8963,9075,"to get rid of that"],[9146,9259,"bastard child!"]],"19":[[396,508,"Chloe, tell me the truth."],[588,650,"What's going on"],[650,759,"between you and the boss?"],[800,942,"There's nothing going on!"],[1001,1092,"You called me at this hour"],[1092,1184,"just to ask me that?"],[1284,1397,"You think I wanted to?"],[1422,1509,"He made me!"],[1555,1705,"Why didn’t he call me himself?"],[1726,1830,"He's wasted!"],[1847,1943,"He told me to ask you"],[1943,2002,"what it will take"],[2002,2185,"for you to get rid of your baby?"],[2310,2356,"Wait,"],[2439,2585,"when did you get pregnant?"],[2631,2731,"I didn't know!"],[2894,2973,"You tell him"],[2973,3174,"I'm not getting rid of my baby!"],[3832,3899,"Boss,"],[3899,4029,"she's not having an abortion."],[4049,4145,"Can I take you home now?"],[4204,4312,"Take me to Chloe's place."],[4379,4500,"Boss, it's too late!"],[4517,4650,"What if Maura finds out?"],[4688,4779,"She'll be pissed!"],[4796,4900,"Who's the boss here?"],[4996,5067,"You or me?"],[5088,5267,"Alright, I'll take you to Chloe's."],[6218,6264,"Erik,"],[6318,6427,"why did you bring him here?!"],[6456,6544,"He insisted!"],[6564,6694,"What I was supposed to do?"],[6727,6865,"Let him pass out at the bar?"],[6948,7119,"He's all yours now, I'm clocking out!"],[7144,7223,"Erik, no!"],[7253,7369,"You can't leave him here!"],[7453,7515,"God."],[8120,8191,"Great."]],"20":[[1526,1593,"Chloe!"],[2068,2160,"Mr. West,"],[2198,2402,"you got really drunk last night and"],[2402,2506,"just barged into my place."],[2690,2781,"I'm letting it go this time,"],[2781,2932,"but if it happens again..."],[3269,3374,"Threatening me now?"],[3478,3653,"Maybe I should give you a real reason to"],[3682,3799,"hold me accountable."],[7845,8020,"There's no sign of a guy living here."],[8020,8058,"So tell me."],[8199,8274,"Who's the father?"],[8324,8470,"You shouldn't talk with your mouth full."],[8525,8662,"Watch who you're talking to, Chloe!"],[8833,8950,"This isn't your office."],[8971,9100,"You're sitting at my table,"],[9100,9217,"eating the food I made,"],[9255,9346,"and you think you have the right to"],[9346,9492,"question what I do with my life?"],[9513,9597,"I'm concerned about"],[9597,9676,"my employees."],[9784,9884,"What's wrong with that?"],[9947,10018,"Oh."],[10047,10201,"Do you usually show concern by"],[10201,10310,"ending up in their bed?"],[10335,10406,"You know damn well"],[10406,10510,"you're different than them."],[10577,10698,"Don't pretend you don't know."],[10723,10852,"Well you're engaged to Maura."],[10852,10910,"So maybe you should"],[10910,10998,"worry about her."],[11015,11148,"I'm not marrying her."]],"21":[[50,175,"I'm not marrying her."],[254,375,"Let's get one thing straight."],[437,604,"I'm not going to be your sidepiece."],[604,675,"Okay?"],[746,855,"So if you're going to be keep"],[855,1009,"forcing yourself of me"],[1009,1101,"I'll quit."],[1109,1176,"Really?"],[1222,1351,"Seriously going to do that?"],[1384,1476,"I'm serious."],[1534,1630,"I'll get another job."],[1676,1843,"I can't break up with Maura yet."],[1931,2031,"I need more time."],[2060,2122,"Mr. West,"],[2122,2293,"I'm not asking you to leave Maura."],[2394,2489,"So..."],[2656,2756,"you want me to marry her?"],[3007,3086,"Chloe,"],[3086,3232,"I know you have feelings for me."],[3274,3395,"You can deny it all you want,"],[3490,3653,"but your body tells a different story."],[3941,4024,"Get dressed,"],[4049,4183,"you're coming with me."]],"22":[[62,183,"What do you think of this one?"],[241,400,"I think it's a little bit trendy"],[433,558,"for an older woman."],[688,850,"I think..."],[892,975,"I think this one"],[975,1092,"is more appropriate"],[1092,1192,"for somebody her age."],[1213,1272,"Then pick something"],[1272,1418,"a younger woman would like."],[1484,1601,"A younger woman?"],[1601,1676,"He must be getting"],[1676,1785,"something for Maura."],[2035,2156,"Maybe this one?"],[3274,3353,"I thought you were buying"],[3353,3453,"this for Maura."],[3591,3712,"I can't accept it."],[3732,3837,"I've never personally buy"],[3837,3953,"Maura's gift."],[4020,4166,"Anything she wants,"],[4166,4362,"I had Erik to buy it for her."],[4542,4675,"But this is too much,"],[4675,4754,"really."],[4754,4879,"I can't accept it."],[4879,5084,"Chloe, this is just the beginning."],[5163,5347,"I'll be giving you more gifts."],[5914,6035,"Maura, guess what!"],[6056,6202,"A friend of mine saw Eason"],[6202,6368,"shopping at the mall today."],[6398,6531,"He's probably buying"],[6531,6702,"your mom's birthday present!"],[6827,6969,"And he didn't even ask me to"],[6969,7065,"come with him."],[7119,7253,"He bought a bracelet"],[7253,7361,"and a necklace!"],[7361,7557,"That bracelet cost a fortune,"],[7557,7716,"and the diamond necklace?"],[7716,7870,"It has to be for you!"],[7870,8112,"I bet he's planning to surprise you!"]],"23":[[54,162,"What kind of necklace"],[162,308,"did he get me?"],[487,667,"I can not wait to wear it."],[667,784,"Hold on, I'll ask my friend"],[784,892,"who works at the store."],[925,1051,"She's tight with one of the girls"],[1051,1130,"at that counter."],[1130,1338,"I bet Eason is planning to surprise"],[1338,1501,"me on my mom's birthday."],[1572,1643,"I think so!"],[1705,1814,"Okay, bye."],[2811,2902,"Juice?"],[2961,3057,"Why are you ordering juice?"],[3123,3228,"We're all drinking."],[3290,3374,"She can't drink."],[3407,3499,"Why does it matter"],[3499,3607,"what she drinks, Eason?"],[3666,3766,"You're marrying Maura, right?"],[3845,3995,"Or are you not that into her"],[3995,4104,"she's never around."],[4145,4233,"This is my woman."],[4233,4366,"You'd better show some respect."],[4387,4479,"So she's the one?"],[4479,4617,"You should've said so earlier!"],[5659,5768,"Excuse me."],[5868,6001,"What's up with her?"],[6001,6206,"She's not pregnant, is she?"],[6252,6327,"She is."],[6327,6364,"What?"],[6398,6514,"Eason, you're gonna be a father!"],[6514,6623,"Congrats!"],[6673,6823,"How many months along is she?"],[6823,6940,"Is it a boy or girl?"],[6956,7077,"Baby is not mine."]],"24":[[79,216,"Baby is not mine."],[241,316,"What do you mean?"],[316,450,"Didn't you say she's your girl?"],[450,575,"Why aren't you a father?"],[613,679,"Look man,"],[713,875,"Chloe's hot, alright?"],[875,1005,"But there are plenty of women out there"],[1005,1138,"who are just as good-looking."],[1180,1330,"Why are you trying to be step-dad"],[1330,1455,"of someone else's kid?"],[1455,1609,"It just doesn't make any sense!"],[1651,1801,"Once she falls in love with me,"],[1826,1943,"she'll get rid of the baby."],[1960,2097,"What's so special about her?"],[2168,2306,"Maura is probably a better choice."],[2323,2381,"At least she's not"],[2381,2494,"a single mother."],[2510,2565,"Look Eason,"],[2565,2652,"you're playing with fire."],[2706,2802,"Chloe's the kind of woman you have"],[2802,2861,"fun with,"],[2861,2965,"but you don't marry her."],[2998,3115,"You'll regret it, trust me."],[3144,3236,"That's enough."],[3286,3395,"You've said enough."],[3670,3807,"Sorry about that."],[4087,4225,"Why is everyone so quiet?"],[4379,4462,"Don't mind him."],[4542,4612,"Eat."],[5013,5084,"Hi, Eason."],[5096,5196,"I brought you something."],[5213,5409,"I wasn't sure if you'd like it, so"],[5409,5618,"I just decided to bring it to you first."],[5643,5789,"Just leave it on the table."],[5789,5960,"I'm little bit busy right now."],[6101,6222,"Do you need anything else?"],[6272,6385,"Well, next Thursday"],[6385,6502,"is my mom's birthday."],[6527,6694,"You'll be able to make it, right?"],[6773,6856,"Yeah,"],[6856,6936,"I'll be there."],[7761,7903,"Has Chloe been in today?"],[7903,7974,"Oh, yes."],[7974,8116,"She was here earlier just stepped"],[8116,8279,"out to deliver some documents."],[8379,8512,"Are you kidding me?"],[8633,8754,"Chloe!"]],"25":[[208,308,"Losing your mom"],[308,408,"must've been tough."],[538,679,"But, girls like you"],[679,888,"should stick with your kind."],[988,1251,"You're just an ordinary woman,"],[1251,1409,"so start acting like one."],[1493,1589,"Stop fantasizing"],[1589,1780,"about climbing the social ladder."],[1818,1964,"The higher your rise,"],[2022,2164,"the harder you fall."],[2202,2318,"You threatening me?"],[2318,2435,"Threatening you?"],[2456,2594,"Why would I do that?"],[2627,2715,"You're Eason's"],[2715,2836,"precious secretary now."],[2894,3011,"When your mom died, he even"],[3011,3174,"helped with the investigation!"],[3286,3591,"You must feel so special."],[3712,3853,"You have any issues"],[3853,3953,"with Eason's behavior,"],[3953,4074,"you should take it up with him."],[4116,4233,"I'm just a secretary."],[4233,4366,"I don't make decisions."],[4387,4479,"Nice necklace."],[4529,4592,"Did you buy that"],[4592,4667,"with your mom's life"],[4667,4754,"insurance money?"],[4763,4859,"Don't you dare"],[4859,4992,"bring my mom into this!"],[5080,5163,"Never ever"],[5180,5296,"want to hear you mention her again."],[5305,5492,"Who the hell do you think you are,"],[5492,5622,"talking back like that?"],[5672,5943,"I'll say whatever I want!"],[6297,6364,"That's the necklace"],[6364,6493,"Eason bought yesterday!"],[6519,6673,"He gave it to her?"],[6719,6806,"No!"],[6861,6923,"There's no way"],[6923,7069,"Eason would give it to her!"],[7169,7236,"Chloe,"],[7273,7399,"tell me the truth."],[7469,7649,"Did you buy that necklace yourself?"]],"26":[[8,120,"It's work hours."],[120,250,"I need to go back to work."],[287,408,"Where are you leaving?"],[496,663,"I asked you a question!"],[713,930,"Did you buy that necklace yourself?"],[1026,1080,"Chloe!"],[1251,1376,"Go back to work."],[1468,1664,"I didn't do anything to her."],[1722,1826,"Why are you always"],[1826,1981,"standing up for Chloe?"],[2014,2106,"It breaks my heart."],[2135,2227,"This is my company,"],[2268,2331,"Chloe's my employee."],[2423,2565,"Why did you bring her to the hallway?"],[2565,2736,"There was just a misunderstanding."],[2736,2915,"I was trying to clear the air."],[2936,3028,"There's no need!"],[3069,3207,"You two have no reason to interact."],[3232,3365,"Stop bothering her."],[3420,3524,"Eason,"],[3553,3657,"I know you hate me"],[3657,3824,"for forcing you into that engagement."],[3912,4099,"I hate myself for it too!"],[4204,4375,"I just love you so much!"],[5063,5163,"The diamond necklace"],[5163,5376,"Eason bought wasn't for me!"],[5543,5689,"That bitch, Chloe has it!"],[5689,5784,"Did he say that?"],[5805,6018,"I saw it with my own eyes!"],[6064,6168,"That bitch was"],[6168,6322,"wearing my necklace!"],[6464,6631,"It's definitely from Eason!"],[6677,6831,"What's wrong with Eason?"],[6890,7015,"How could he ignore you,"],[7015,7090,"his fiancée,"],[7090,7253,"and mess around with Chloe?"],[7319,7636,"Don't you dare talk bad about Eason!"],[7661,7857,"Okay, okay, I won't."],[7895,8083,"It's all that Chloe's fault!"],[8174,8233,"Maura,"],[8283,8491,"you want me to teach her a lesson?"],[8708,8904,"What do you have in mind?"],[9455,9559,"Okay,"],[9634,9801,"let's do this."]],"27":[[450,496,"Hey,"],[529,658,"I want that necklace!"],[750,813,"Not the necklace!"],[813,984,"I can give you money!"],[984,1038,"No!"],[1101,1155,"This is theft."],[1155,1263,"You're breaking the law!"],[1297,1409,"If you call the police,"],[1409,1522,"you know what's good for you."],[1730,1906,"Why did he only take my necklace"],[1906,2031,"and nothing else?"],[2181,2331,"Is this Maura's doing?"],[2998,3065,"Eason,"],[3065,3219,"I tried a few new recipes today"],[3219,3386,"and I made you a lunch."],[3440,3561,"I hope you like it."],[4804,4921,"Do you still have that necklace"],[4921,5000,"I gave you?"],[5013,5180,"It was stolen last night."],[5180,5321,"I'm so sorry."],[5384,5551,"I wanted to tell you in person."]],"28":[[404,529,"It's Chloe's necklace, isn't it?"],[588,713,"She was mugged last night."],[788,875,"Did you do it?"],[892,1021,"Eason, what?"],[1096,1280,"I didn't steal her necklace!"],[1301,1401,"I saw her wearing one,"],[1401,1539,"and I liked the design, so I bought"],[1539,1651,"exact same one."],[1797,1901,"I even have the receipt."],[2360,2469,"Oh, okay!"],[2506,2569,"You know what?"],[2598,2706,"When I was buying it,"],[2706,2844,"the salesperson mentioned that"],[2844,2998,"you'd purchased the exact same one"],[2998,3107,"for someone else."],[3203,3324,"What are the odds, huh?"],[3378,3524,"I bought that necklace for Chloe."],[3557,3653,"If you can't accept the fact"],[3653,3762,"that I care about her,"],[3816,3866,"maybe we should"],[3866,3978,"end the engagement."],[3978,4062,"No!"],[4095,4275,"You're my fiancé!"],[4312,4546,"And you're going to be my husband."],[4608,4696,"I won't let anyone"],[4696,4813,"take you away from me!"],[5726,5826,"Chloe."],[6022,6106,"What happened?"],[6239,6377,"I was robbed last night."],[6377,6514,"And just a little bit shaken up."],[6664,6760,"How did you fall?"],[6852,6973,"Is that because of that necklace?"],[7011,7082,"Yes."],[7123,7207,"How did you know?"],[7207,7290,"Maura"],[7307,7378,"showed up with a necklace"],[7378,7478,"just like yours."],[7674,7761,"Eason,"],[7849,7949,"I've been thinking,"],[7949,8053,"and I..."],[8120,8270,"I don't need this job anymore."],[8299,8391,"Since my mom passed,"],[8391,8533,"I've got some money and"],[8579,8762,"my health is suffering."],[8863,8967,"I want to quit."],[9230,9426,"Until you and Maura end things,"],[9592,9713,"I don't want to see you."]],"29":[[216,367,"Eason, I'm sorry."],[458,583,"I like you,"],[633,738,"but there’s no room for"],[738,909,"three people in a relationship."],[1001,1242,"I can’t keep lying to myself anymore."],[2293,2410,"Are you free in evening?"],[3236,3311,"Ma'am."],[3340,3403,"Ma'am!"],[3461,3570,"Please, wait."],[3611,3741,"Please, help save our boss."],[3803,3916,"Who took your boss?"],[3945,4012,"I think..."],[4012,4099,"the name was Eason."],[4212,4304,"Eason West?"],[5042,5150,"Who the hell are you?"],[5488,5538,"Who sent you"],[5538,5651,"to steal Chloe’s necklace?"],[5651,5755,"It was Ruby!"],[5822,5868,"Call her."],[5893,6014,"Tell her to get here, now!"],[6523,6581,"Eason!"],[6610,6690,"I’m sorry!"],[6690,6844,"I was only helping Maura!"],[6965,7123,"I couldn’t stand to see her suffering,"],[7123,7211,"so I did it!"]],"30":[[250,329,"Please, Eason!"],[375,450,"I made a mistake!"],[450,579,"I'm not gonna do it again."],[600,759,"Please don’t send me to prison."],[792,971,"I haven’t even started a family"],[1001,1113,"or got married."],[1113,1267,"Please!"],[1267,1359,"Go beg Maura."],[1363,1484,"Maybe she can help you."],[3824,4004,"They already gave back the necklace."],[4120,4250,"Maybe we should just let it go."],[4287,4421,"Ruby is going to prison."],[4483,4625,"Ruby is Maura’s friend."],[4625,4671,"Don't you think"],[4671,4821,"you're being a little harsh?"],[4846,4934,"I don’t forgive"],[4934,5005,"and I don't forget."],[5080,5171,"She messed with me,"],[5209,5347,"now she faces the consequences."],[5459,5522,"Just..."],[5522,5588,"take me home."],[5618,5705,"I’m exhausted."],[5793,5868,"I will not let"],[5868,5989,"anything happens to you."],[6089,6151,"Trust me."],[6247,6431,"We can’t be together Eason."],[6506,6619,"Not until you break off"],[6619,6715,"your engagement to Maura."],[6740,6890,"You know I can’t do that right now!"],[6936,7040,"Why are you pushing me?"],[7232,7328,"I’m sorry."],[8078,8191,"Eason, please!"],[8291,8400,"Ruby’s been my best friend"],[8400,8529,"since we were kids."],[8658,8758,"If she goes to prison"],[8758,8821,"because of me,"],[8821,9009,"I’ll never forgive myself!"],[9113,9213,"Please,"],[9213,9309,"drop the charges!"],[9359,9522,"I’ll drop the charges"],[9522,9655,"if we cancel the engagement."],[9676,9759,"No!"],[9805,10105,"I will never break off the engagement!"]],"31":[[204,362,"Then you can send your best friend to"],[362,492,"prison by yourself."],[875,975,"Chloe Hartman,"],[1046,1109,"you’re sending"],[1109,1234,"my best friend to prison?"],[1301,1593,"I’ll make sure you pay for this!"],[2268,2327,"Mom,"],[2431,2581,"it’s hard to believe you’ve been gone"],[2581,2756,"for 35 days already."],[2877,2994,"Back home, they say"],[2994,3148,"it’s after 35 days"],[3148,3261,"that the dead realize"],[3261,3365,"they’re actually gone,"],[3365,3474,"and they come to say goodbye"],[3474,3578,"one last time."],[5117,5246,"What are you doing here?"],[5317,5426,"It's been 35 days"],[5426,5563,"since your mom passed,"],[5597,5789,"and my best friend, only in her twenties,"],[5789,6001,"is going to prison for the next decade."],[6081,6185,"Can you imagine"],[6185,6310,"ten years for a woman?"],[6911,6981,"Remember when you thought"],[6981,7082,"I had something to do"],[7082,7190,"with your mom’s death?"],[7261,7307,"Well,"],[7361,7444,"you were right."],[7490,7553,"I did it."],[7661,7770,"You gonna send me to prison?"],[7974,8062,"Try me."],[8149,8229,"You monster!"],[8262,8416,"You killed my mother!"],[8458,8541,"Teach her a lesson."],[8692,8808,"Just don't kill her."],[10610,10685,"Is that..."],[10714,10794,"Eason?"]],"32":[[33,100,"Is that..."],[133,221,"Eason?"],[696,750,"Miss,"],[784,863,"can you hear me?"],[900,988,"I can't die!"],[1034,1184,"I have to avenge my mother."],[1238,1347,"Maura must pay."],[1409,1493,"Please wake up!"],[1914,2056,"She’s able to sit up now,"],[2056,2248,"though she still can’t speak or walk."],[2310,2485,"With time, she should recover fully."],[2485,2631,"But given her age,"],[2669,2802,"it’s a slow process."],[2836,2890,"For now,"],[2932,3065,"we’ll have her rest at home,"],[3111,3224,"and next year"],[3294,3436,"we’ll consider another surgery."],[3478,3732,"Julian, we have full faith in your skills."],[3807,3912,"My mother is old,"],[3937,4054,"she won’t recover"],[4054,4195,"like a young person would, but"],[4212,4371,"with you overseeing her care,"],[4408,4587,"I know she’ll get back to her old self."],[4621,4683,"Thank you."],[4771,4817,"Now,"],[4904,5084,"about Eason and Maura’s wedding."],[5121,5305,"It’s time to start planning."],[5305,5530,"Maura isn’t getting any younger,"],[5563,5714,"and it won't look good"],[5768,5951,"if we keep postponing things."],[5985,6160,"Eason, what do you say?"],[6181,6368,"Let’s wait until the second surgery."],[6431,6510,"If..."],[6560,6702,"Dr. Greene can’t wait for his"],[6702,6831,"daughter to get married,"],[6952,7123,"maybe she can find another husband."]],"33":[[133,271,"You're the one who brought me here."],[316,392,"No problem."],[454,608,"My name is Patrick Hale."],[642,713,"And you are?"],[754,817,"Chloe."],[867,963,"Chloe Hartman."],[1055,1113,"Can I get your"],[1113,1226,"contact information?"],[1226,1347,"I'd like to repay you."],[1430,1564,"I actually live abroad."],[1643,1780,"I only came back here"],[1780,1910,"to visit my family’s grave."],[2110,2239,"The rain started right"],[2239,2377,"when I got to the cemetery,"],[2460,2615,"and then I found you."],[2740,2819,"Miss Hartman,"],[2861,3032,"you’re pregnant with twins."],[3228,3361,"The kids are okay right now."],[3399,3436,"But..."],[3449,3566,"who did this to you?"],[3653,3787,"I don’t even know how to explain it."],[3812,3899,"Was that the father?"],[4004,4158,"If you need some legal help,"],[4200,4275,"I can recommend"],[4275,4508,"some good divorce attorneys."],[4529,4683,"Mr. Hale, I’m not married."],[4683,4729,"And..."],[4758,4804,"no,"],[4888,4992,"it wasn’t the father."],[5025,5109,"Alright then."],[5167,5347,"If there’s nothing else I can do,"],[5405,5509,"I’ll be on my way."],[5547,5622,"You saved my life"],[5622,5709,"by bringing me here."],[5709,5822,"That’s more than enough."],[5914,5985,"Thank you."],[6031,6156,"No need to thank me."],[6189,6318,"Oh, I forgot to mention."],[6318,6431,"I’m a doctor too."],[6481,6585,"Take care of yourself."],[6681,6915,"I’ll be in the country for about a week,"],[6944,7098,"so if you need anything..."],[7374,7444,"Thank you."],[8408,8475,"Boss!"],[8512,8591,"I discovered"],[8591,8708,"something important!"],[8762,8879,"The night Chloe and you spent"],[8879,9021,"together lines up perfectly"],[9021,9188,"with Chloe's pregnancy weeks!"]],"34":[[0,125,"So her baby is mine?"],[125,204,"That’s right!"],[225,346,"It all fits now."],[358,446,"That baby..."],[492,629,"is definitely yours."],[725,813,"I have to find her."],[1376,1484,"Chloe, open the door!"],[1497,1626,"Boss, maybe she’s at work"],[1626,1701,"or something."],[2002,2131,"The number you have dialed"],[2143,2231,"is not available..."],[2394,2498,"What if she moved out?"],[2540,2627,"Get a locksmith."],[2627,2765,"I’m not leaving here untill I find her."],[3445,3607,"Boss, it’s already ten."],[3661,3732,"Chloe’s probably"],[3732,3858,"not living here anymore."],[3920,4095,"The vegetables in her kitchen look like"],[4095,4241,"they’ve been sitting out for days."],[4266,4412,"Her belongings are still there."],[4483,4575,"If she’s not staying here,"],[4575,4637,"where is she?"],[4667,4754,"Her phone’s off."],[4779,4909,"Maybe something happened."],[4942,4971,"You think"],[4971,5067,"something happened to her?"]],"35":[[25,45,"You think"],[45,150,"something happened to her?"],[179,308,"Even if something did,"],[350,479,"it’d be hard to trace her."],[563,684,"Both her parents are gone,"],[729,888,"she doesn’t have close family,"],[909,1013,"no best friends..."],[1063,1238,"If she doesn’t reach out to us,"],[1263,1388,"it would be hard to find her."],[2139,2223,"Eason!"],[2260,2369,"Are you looking for me?"],[2398,2469,"Where are you?"],[2485,2577,"I’ll come meet you."],[2594,2698,"Have you seen Chloe lately?"],[2715,2761,"No."],[2781,2840,"Why?"],[2852,3044,"You cut things off with her, didn’t you?"],[3065,3190,"Has she reached out to you?"],[3307,3428,"I’m looking for her, but I can’t."],[3461,3541,"Haven't you..."],[3607,3707,"contacted her at all?"],[3724,3816,"Why would I?"],[3862,3995,"Are you going to accuse me"],[3995,4149,"every time you can not find her?"],[4717,4771,"Ms. Hartman,"],[4792,4867,"you’re in good shape."],[4900,5021,"You can be discharged now."],[5055,5121,"After you leave,"],[5121,5317,"make sure to visit OB-GYN"],[5334,5463,"to get baby’s records"],[5476,5526,"in order."],[5555,5601,"Okay."],[5634,5714,"Thank you."],[5764,5780,"Oh."],[5801,5935,"And Dr. Patrick asked me"],[5935,6089,"to remind you to give him a call"],[6106,6202,"when you're ready to leave."],[6231,6272,"Got it."],[6335,6385,"I’ll call him,"],[6410,6460,"thank you."]],"36":[[37,154,"Eason called me?"],[208,354,"How does he know what happened?"],[446,496,"No..."],[538,608,"no way..."],[700,859,"No one knows except Maura."],[1167,1230,"Patrick?"],[1230,1405,"Come to the café near the hospital"],[1405,1497,"when you’re discharged."],[1559,1647,"Lunch is on me."],[1672,1797,"Okay, I'll be there."],[2773,2831,"Chloe!"],[2831,2902,"You answered!"],[2952,3094,"I’ve been waiting at your apartment"],[3094,3165,"for three days."],[3224,3282,"Where are you?"],[3307,3403,"Why haven’t you been home?"],[3470,3578,"Two months and a half ago"],[3578,3687,"at the hotel, do you remember?"],[3712,3870,"Eason, that was one-time thing."],[3928,4033,"Let's just leave it at that."],[4033,4120,"One-time thing?"],[4162,4216,"Done?"],[4262,4366,"The one you’re carrying is mine,"],[4366,4404,"Chloe!"],[4458,4517,"So what?"],[4579,4646,"Do you want it?"],[4646,4733,"Of course, I do!"],[4817,4896,"That's my child!"],[4921,5013,"Tell me where you are!"],[5013,5184,"We need to talk face to face."],[5205,5271,"I'm busy."],[5292,5388,"When are you free?"],[5388,5426,"Where have you been"],[5426,5547,"for the past few days?"],[5576,5701,"I've been in the hospital."],[5830,5885,"Eason,"],[5935,6085,"we have nothing left to talk about."],[6122,6227,"You aborted the child?"],[6260,6310,"Chloe,"],[6331,6410,"how could you do that"],[6410,6514,"without telling me!"],[6569,6677,"You killed my child!"]],"37":[[45,137,"We are over!"],[166,221,"Eason."],[325,492,"You have your life, and I have mine."],[608,717,"We live in different worlds."],[750,829,"You lied to me,"],[884,988,"you hid everything,"],[1021,1151,"and you gonna leave me hanging?"],[1217,1334,"You like see me look like a fool,"],[1334,1380,"aren’t you?"],[1488,1614,"You just gonna walk away,"],[1634,1718,"abort the child,"],[1826,1976,"and act like none of this matters!"],[2018,2164,"You only ever cared about yourself,"],[2164,2227,"Chloe."],[2314,2394,"Never me."],[2669,2731,"Yes."],[2815,2940,"It’s just me and my mom."],[3036,3215,"There’s no space for anybody else."],[4658,4758,"Dr. Patrick,"],[4867,4984,"thank you so much for covering"],[4984,5138,"my medical expenses."],[5159,5267,"I'll pay you back."],[5284,5355,"I promise."],[5426,5538,"Don't worry about it."],[5638,5755,"Tell me, what's your plan?"],[6056,6206,"Fisrt I'll have this baby and"],[6231,6377,"then think about the rest."],[6489,6614,"Have you thought about"],[6631,6790,"leaving the country for a while?"],[6865,7048,"If there’s nothing keeping you here,"],[7132,7273,"you could try something new."],[7390,7520,"Why don't you come with me"],[7574,7691,"and see the world?"],[8450,8516,"Okay."],[8687,8750,"I'll go."],[9355,9421,"Boss,"],[9484,9663,"here’s Patrick Hale’s file."],[9726,9901,"He’s originally from France,"],[9939,10093,"studied in New York City,"],[10143,10226,"and now works"],[10226,10389,"at one of the top medical centers"],[10389,10477,"in the world."],[10548,10652,"He’s only thirty"],[10685,10769,"but already"],[10802,10944,"one of the top neurosurgeon"],[10944,11031,"in the US."],[11086,11207,"Were you thinking of hiring him"],[11207,11340,"to treat your grandmother?"]],"38":[[95,179,"He's back in town?"],[271,316,"Do you want me"],[316,429,"to get in touch with him?"],[529,588,"Help me set up"],[588,684,"an appointment with him."],[684,759,"Alright."],[1055,1197,"For this industry conference,"],[1197,1276,"how did you manage"],[1276,1393,"to get Annie invited?"],[1409,1543,"She’s so mysterious!"],[1593,1718,"Ever since she blew up,"],[1755,1922,"she’s never appeared in public."],[1989,2164,"No one knows how she looks like."],[2193,2339,"Annie is from France."],[2373,2477,"She plans to develop"],[2477,2581,"her career here,"],[2606,2740,"so she wants to take advantage of"],[2740,2844,"this industry conference"],[2844,2919,"to network"],[2919,3086,"with top American designers."],[3111,3307,"I have to meet her in person."],[3407,3516,"I’ll be definitely"],[3516,3645,"attending this conference."],[4220,4329,"Has Annie arrived?"],[4354,4504,"Not yet. We're all waiting."],[4542,4654,"I can not wait to meet her."],[4654,4796,"First, let me introduce"],[4796,5013,"a familiar yet new friend."],[5050,5205,"Familiar because..."],[5221,5363,"we know her brand well,"],[5409,5618,"but new because most of you"],[5618,5759,"haven’t met her in person!"],[5830,5889,"She is"],[5922,5989,"Annie!"],[6022,6264,"Let’s give her a warm welcome!"]],"39":[[196,271,"Annie?"],[316,433,"Chloe is Annie?"],[462,617,"Maura, the staff just called her"],[617,696,"Miss Annie."],[696,800,"I heard that!"],[834,1013,"But she was just Eason's secretary."],[1096,1113,"How..."],[1113,1251,"how could she be Annie?"],[1351,1480,"Annie has skyrocketed"],[1480,1693,"to the top in the last two years."],[1856,2031,"No wonder she's so smug!"],[2031,2185,"Taking advantage of tonight,"],[2218,2381,"I’m excited to announce"],[2427,2523,"that Annie"],[2548,2711,"will be collaborating closely"],[2731,2852,"with our fashion group."],[2907,3140,"Let’s look forward to the new miracles"],[3140,3253,"she’ll create!"],[3353,3449,"What's going on?"],[3561,3749,"Mr. Su is collaborating with"],[3749,3866,"Annie instead of me!"],[3962,4020,"Why?"],[4149,4283,"It’s Chloe’s fault!"],[4358,4446,"She’s trying to ruin"],[4446,4600,"my reputation in this industry!"],[4667,4821,"So what are you gonna do about it?"],[4884,5063,"I'm not just gonna sit back and take it!"],[5113,5238,"I need to find a new backer."],[5367,5509,"Without the company’s support,"],[5576,5718,"I have other card to play."],[5822,5985,"Chloe’s trying to ruin my life,"],[6047,6185,"it won't be that easy."],[6631,6756,"Chloe Hartman."],[6781,6873,"It's really you."],[6961,7077,"I thought you were gone."],[7286,7390,"Long time no see."],[7490,7570,"I'm guessing you're already"],[7570,7682,"married to Eason now."],[7695,7849,"Should I call you Mrs. West?"],[7866,8003,"Spare me your sarcasm."],[8041,8149,"We are not married yet,"],[8170,8304,"but we’re still together."],[8391,8487,"And how about you?"],[8587,8808,"Disappeared for so long,"],[8808,8908,"and now you’re back."],[9004,9079,"What for?"],[9192,9309,"I came back for you."],[9538,9642,"I almost forgot"],[9642,9914,"about your pathetic mother."],[10589,10739,"How dare you hit me?"],[10835,10994,"Did you want to join your mom"],[10994,11123,"six feet under?"],[11290,11373,"Try messing with me"],[11373,11528,"like you did four years ago."],[11528,11686,"And see what happens."]],"40":[[271,362,"Eason,"],[454,625,"you called me out of nowhere-"],[650,779,"something on your mind?"],[884,955,"We're done."],[971,1051,"What?"],[1159,1288,"Is this because that bitch Chloe"],[1288,1351,"came back?"],[1422,1568,"I ran into her today."],[1597,1685,"She’s back?"],[1730,1860,"You haven’t seen her yet?"],[1901,2002,"I figured she’d come back"],[2002,2081,"running to you."],[2198,2298,"Let’s focus on us."],[2348,2452,"I don’t need your father"],[2452,2573,"to treat my grandmother"],[2573,2656,"anymore."],[2740,2798,"We’re through."],[2819,2898,"Are you giving up"],[2898,3023,"on your grandma, Eason?"],[3078,3286,"Just give my dad one more chance."],[3324,3424,"I found a better doctor."],[3599,3691,"A better doctor?"],[3712,3782,"Who?"],[3803,3949,"There’s no one else like my dad."],[4066,4179,"Patrick Hale."],[4241,4337,"Patrick Hale?"],[4454,4546,"I’ve heard of him."],[4562,4662,"He's brilliant,"],[4688,4896,"but impossible to get ahold of."],[5009,5184,"My father was trying to meet him once,"],[5184,5355,"and he got rejected."],[5484,5563,"Good luck."],[5663,5776,"That's my business."],[7077,7161,"Boss,"],[7215,7394,"Patrick Hale’s assistant replied."],[7457,7536,"He said unless"],[7536,7665,"you two have a mutual friend,"],[7707,7816,"Hale won’t meet you."],[7891,8003,"From what I’ve found,"],[8028,8120,"you two move in"],[8120,8287,"completely different circles-"],[8312,8450,"no connections."],[8491,8575,"Then make one."],[8612,8704,"How are we supposed to"],[8704,8783,"do that?"],[8783,8946,"Patrick Hale’s untouchable."],[8963,9138,"Even planting someone in his life"],[9138,9259,"is impossible."],[9376,9496,"He’s got kids, right?"],[9547,9655,"They must go to school."],[9809,9880,"Got it."],[9951,10055,"I'll look into it."],[10589,10689,"Why do you keep renting"],[10689,10831,"that old place?"],[10877,10994,"It’s where my mother and I"],[10994,11098,"made memories."],[11186,11244,"Fine."],[11315,11461,"Just spend weekends with me."],[11519,11619,"Kids miss you."],[11932,12012,"Okay."],[12049,12112,"I will."],[12337,12466,"Thank you, Patrick."],[12562,12645,"Once I settle things,"],[12645,12816,"I’ll take care of them myself."]],"41":[[83,171,"We’ll cross that bridge"],[171,250,"when we get there."],[287,383,"If you need my help"],[442,529,"with anything,"],[567,663,"just say the word."],[729,905,"Just take care of the kids and..."],[1042,1151,"I can handle the rest."],[1263,1322,"By the way,"],[1384,1493,"Eason’s been trying to"],[1493,1559,"reach me about"],[1559,1685,"his grandmother’s surgery."],[1914,1997,"Do what you want."],[2006,2097,"It's your job."],[2252,2439,"I told my assistant to tell him..."],[2498,2669,"I won’t see him until a mutual friend"],[2669,2777,"introduces us."],[2907,3019,"Do you think he’ll figure out"],[3019,3098,"our connection?"],[3136,3169,"Patrick,"],[3169,3311,"are you doing this on purpose?"],[3386,3482,"Eason and I broke up"],[3482,3574,"a long time ago."],[3749,3841,"I’m just curious"],[3841,3970,"if you’d ask me to help him."],[4145,4241,"Because if you did,"],[4329,4396,"I would."],[4412,4521,"He wouldn't reach out to me."],[4558,4617,"I'm sure."],[4788,5075,"We left things on pretty bad terms."],[6064,6143,"Mom!"],[6181,6243,"Mom."],[6685,6744,"How..."],[6806,6961,"Chloe and Patrick have kids?"]],"42":[[0,112,"Which one is your favorite?"],[346,404,"Chloe,"],[538,650,"no wonder you insisted on"],[650,725,"breaking up with me."],[821,905,"Turns out you were"],[913,1017,"involved with Patrick."],[1067,1251,"Could you be a bit more polite, Eason?"],[1363,1526,"I checked Patrick Hale's profile."],[1655,1764,"Are those two kids yours?"],[1847,2014,"Eason, this is a public space."],[2072,2177,"I don't think it's appropriate for"],[2177,2268,"this conversation."],[2460,2548,"Let's talk outside."],[2990,3090,"I've broken up with Maura."],[3286,3395,"Just broke up?"],[3490,3641,"Because I ran into her the other day"],[3649,3820,"and she said you are still together."],[3903,3987,"Her father couldn't help"],[3987,4091,"my grandmother's illness,"],[4137,4283,"so I'm switching doctors."],[4425,4575,"Patrick is indeed a good doctor."],[4612,4713,"How did you two meet?"],[4783,4884,"Your kids are grown up,"],[4954,5080,"and according to the timeline,"],[5134,5221,"you almost immediately"],[5221,5296,"got involved with him"],[5305,5417,"after we broke up, right?"],[5509,5668,"Eason, there's no need to taunt me."],[5705,5843,"If you're trying to reach Patrick,"],[5847,5955,"I can help you with that."],[5989,6051,"No need!"],[6101,6193,"I have my ways"],[6210,6335,"to arrange a meeting with him."]],"43":[[83,254,"We don't have to act like enemies."],[258,367,"If you need my help,"],[367,471,"I can help you."],[500,633,"Don't pretend to be the good guy!"],[713,846,"After you aborted my child,"],[884,1030,"I swore I never trust you again!"],[1134,1192,"Okay."],[1238,1422,"If you so clearly don't need my help,"],[1497,1568,"I'll go now."],[1826,1872,"Chloe,"],[2097,2198,"you used to despise me"],[2198,2273,"because I didn't give you"],[2273,2364,"a proper status."],[2464,2560,"Now you're staying with Patrick"],[2560,2723,"and still have no proper status?"],[2752,2852,"Why aren't you causing a scene to"],[2852,2944,"break up with him?"],[3015,3169,"My relationship with Patrick is not"],[3169,3236,"what you think."],[3315,3453,"Not that it's any of your business."],[3549,3641,"I'm a designer now,"],[3682,3803,"and I support myself."],[4379,4517,"She's such a beautiful girl."],[4546,4608,"Too bad she's"],[4608,4746,"Patrick's bastard child!"],[4796,4917,"If Chloe hadn't aborted our child"],[4917,4975,"back then,"],[5042,5150,"maybe I would have a daughter"],[5150,5251,"as beautiful as her."],[5709,5784,"Brother?"],[5801,5855,"Dad?"],[5872,5951,"Mom?"],[6268,6364,"Who are you?"],[6481,6614,"Enter your father's phone number."],[6631,6781,"And call him to get you."]],"44":[[704,917,"Daddy, daddy come save me!"],[942,1071,"Nina, don't be afraid."],[1121,1251,"Tell Daddy where you are now."],[1263,1401,"I'll come get you right away."],[1739,1826,"Dr. Patrick,"],[1931,2031,"this is Eason West."],[2118,2202,"I'm at home."],[2277,2373,"Drive over directly,"],[2373,2481,"and I'll have someone to meet"],[2481,2540,"you at the door."],[2540,2694,"Eason, how dare you kidnap"],[2694,2786,"my daughter!"],[2786,2977,"Do you believe I'll let you get away"],[2977,3115,"without reporting you?"],[3132,3324,"Dr. Patrick, this is an exaggeration."],[3357,3440,"I brought your daughter"],[3440,3520,"to my home"],[3536,3632,"as a guest."],[3695,3799,"I won't harm her."],[3820,3983,"If you dare to lay a finger"],[3983,4070,"on my daughter,"],[4095,4179,"I won't treat"],[4179,4329,"your grandmother's illness!"],[4396,4483,"Dr. Patrick,"],[4508,4675,"I said I won't harm your daughter,"],[4692,4763,"so I won't."],[4934,5050,"I'll wait at home, so"],[5105,5246,"come as soon as possible!"],[5534,5588,"Eason!"],[5768,5860,"Whose child is this?"],[5872,5976,"She's beautiful!"],[6114,6227,"This is Patrick's daughter."],[6243,6277,"Oh,"],[6322,6452,"Dr. Patrick doesn't see you,"],[6464,6635,"so you bring his daughter home?"],[6735,6886,"Aren't you afraid he'll hate you?"],[6886,7027,"I won't harm his daughter."],[7086,7228,"What does he have to hate me for?"],[7315,7428,"Alright then!"],[8212,8412,"This Eason West is truly a scoundrel!"],[8429,8521,"He kidnapped Nina"],[8521,8654,"and forced me to meet him."],[8721,8879,"I'm on my way to his house now."],[8938,9042,"Well, I need to know,"],[9113,9200,"is he always this"],[9200,9309,"domineering and rude?"],[9409,9484,"Is this the way"],[9484,9609,"Eason handles things?"],[9784,9918,"He hasn't changed at all!"]],"45":[[154,258,"Where is my daughter?"],[287,429,"My mother took her out to play."],[467,533,"Don't worry,"],[617,688,"when you leave,"],[767,892,"I'll have my mother send her back"],[892,950,"immediately."],[980,1042,"Eason,"],[1088,1259,"using such despicable means"],[1259,1359,"to force me out"],[1438,1597,"only makes me dislike you more."],[1626,1680,"Dr. Patrick,"],[1680,1818,"you're not willing to meet me"],[1851,1910,"because I've talked to"],[1910,2010,"Chloe before, right?"],[2089,2235,"This has nothing to do with Chloe."],[2252,2448,"You go to France and ask around,"],[2485,2594,"I indeed don't take"],[2594,2736,"on unfamiliar surgeries."],[2765,2923,"Until it’s through mutual friends."],[2940,3053,"But even if we do,"],[3119,3294,"I'm not taking on every surgery."],[3307,3440,"Dr. Patrick, make a deal!"],[3495,3586,"As long as you can cure"],[3586,3653,"my grandmother,"],[3703,3795,"I'll double your fee."],[3883,3953,"If you don't agree,"],[4087,4229,"I'll have to take other actions."],[4354,4475,"I don't need money."],[4517,4662,"If I don't practice medicine,"],[4746,4842,"I'll go home,"],[4900,5075,"and take over my family business,"],[5150,5226,"so Eason,"],[5276,5397,"don't even think about"],[5397,5480,"threatening me."],[5497,5593,"Chloe told me that"],[5638,5834,"if she talked to you, you'd help."],[5847,5897,"Is that right?"],[5926,5985,"Yes."],[6010,6097,"What's your relationship"],[6097,6160,"with her?"],[6272,6335,"She had..."],[6348,6435,"two kids with you,"],[6489,6594,"and still didn't marry?"],[6723,6790,"Because"],[6823,6981,"she has some things to handle."],[7065,7207,"Once she's done with her business,"],[7207,7290,"I'll marry her."],[7374,7457,"How did you two meet?"],[7511,7603,"Four years ago,"],[7699,7866,"I went to my grandfather's grave"],[7903,8078,"and found her lying injured"],[8112,8174,"in front of her"],[8174,8279,"mother's tombstone."],[8358,8470,"It was pouring rain..."],[8470,8562,"She was injured?"],[8641,8775,"How didn't I know about that?"],[8892,8979,"That's something you need to"],[8979,9059,"ask yourself."],[9142,9225,"You don't understand"],[9225,9288,"her at all,"],[9430,9584,"and you don't love her enough."],[9693,9755,"Otherwise,"],[9772,9926,"she wouldn't have left with me."]],"46":[[204,279,"Eason,"],[362,563,"I think Dr. Patrick's daughter"],[588,725,"looks a bit like you."],[763,917,"Especially those eyes."],[980,1096,"Exactly the same."],[1146,1309,"Mom, every kid looks like me"],[1317,1401,"because you want to have"],[1401,1484,"a grandchild."],[1543,1593,"Eason,"],[1630,1714,"your mom is right."],[1789,1881,"Maybe it's time to"],[1881,2022,"focus on your personal life."],[2423,2515,"I understand."],[3053,3103,"Who is it?"],[3440,3490,"Chloe,"],[3553,3624,"four years ago,"],[3737,3812,"you were injured"],[3912,4008,"and you fainted in front of"],[4008,4116,"your mother's tombstone."],[4237,4329,"Why you didn’t tell me?"],[4404,4475,"Who did it?"],[4621,4746,"Did Patrick tell you that?"],[4967,5071,"Answer my questions!"]],"47":[[120,212,"There were no cameras,"],[212,312,"no witnesses."],[358,467,"Even if I have told you,"],[467,567,"what could you have done?"],[729,859,"It's Maura Greene, wasn’t it?"],[934,971,"Eason,"],[971,1121,"let me handle my own grudges."],[1301,1451,"No wonder you had to..."],[1480,1584,"abort our child."],[1655,1768,"You suffered such"],[1780,1876,"humiliation,"],[2056,2198,"and I stood by the person who"],[2198,2285,"bullied you…"],[2314,2506,"Chloe, you never trusted me."],[2640,2823,"I didn’t distrust you."],[2877,2986,"I know you’re a good man."],[3119,3278,"You have people you need to protect."],[3328,3386,"I get it."],[3474,3582,"So considerate..."],[3678,3791,"of the bigger picture!"],[3908,4062,"But even if a choice had to be made,"],[4154,4283,"it should have been mine to make,"],[4325,4508,"not you deciding to sacrifice our child"],[4508,4617,"by yourself!"],[4717,4875,"Past is in the past, okay?"],[4929,5075,"Please, let’s not argue anymore."],[5176,5271,"I think you should leave."],[5288,5397,"I need a rest."],[5593,5714,"Your number still the same, right?"],[5943,6010,"Yes."]],"48":[[329,496,"Eason, what are you doing here?"],[608,679,"Did you have someone"],[679,738,"to hurt Chloe"],[738,813,"four years ago?"],[892,967,"You lied to me!"],[980,1126,"Eason, you’ve got it all wrong!"],[1151,1359,"I've never contacted Chloe privately..."],[1434,1589,"It was Ruby’s boyfriend who did it."],[1634,1768,"I... I was afraid he might do"],[1768,1897,"something extreme to Chloe,"],[1897,2018,"so I followed him..."],[2077,2260,"It was Ruby’s boyfriend who did it."],[2394,2519,"I was scared he might do"],[2519,2602,"something bad,"],[2602,2765,"so I tried to stop him."],[2773,2886,"What was his name?"],[2944,3019,"I think Josh!"],[3019,3157,"Yes, it was Josh."],[3265,3353,"But he's moved abroad"],[3353,3445,"with his family."],[4575,4621,"Thank you."],[4954,5117,"My parents want to take the kids"],[5117,5251,"back for lunch tomorrow."],[5359,5476,"Do you want to come with me?"],[5555,5622,"I'd love to."],[5676,5830,"I haven't met your parents yet so,"],[5847,5922,"that'll be nice."],[6014,6089,"But"],[6110,6264,"they’ve seen your pictures and"],[6327,6443,"they really like you."],[6502,6631,"If you come with me tomorrow,"],[6631,6806,"they might push us to get married."],[6890,6981,"Haven't you told them"],[6981,7094,"about my situation?"],[7207,7369,"Well, not in detail."],[7528,7645,"Then I can't join you."],[7699,7845,"I don't want any misunderstandings"],[7845,7941,"with your parents."],[8241,8383,"It feels like you hate me."],[8408,8454,"Hate you?"],[8462,8512,"Of course,"],[8512,8654,"I don't hate you Patrick."],[8721,8854,"I'm so grateful you're here."],[8854,8954,"How could I hate you?"],[9067,9180,"You're like a brother to me."],[9459,9517,"Are you saying"],[9517,9672,"you'd like to see other people?"],[9813,9893,"Patrick,"],[10064,10151,"you deserve someone"],[10151,10231,"better than me."]],"49":[[1059,1113,"Hello?"],[1155,1242,"Chloe, hi."],[1284,1472,"I’m Grace, Eason’s mother."],[1514,1659,"I know you haven’t met me,"],[1693,1922,"but I’ve always known about you."],[1993,2081,"Hi, Grace."],[2127,2218,"What can I do for you?"],[2256,2469,"I'd like to meet with you and talk."],[2756,2902,"You are truly beautiful."],[2957,3015,"No wonder"],[3015,3211,"Eason was so taken with you."],[3249,3399,"Mrs. West, Eason and I"],[3399,3611,"broke up for a long time ago, and..."],[3636,3774,"I'm sure that's not what you want to"],[3774,3858,"talk about."],[3899,3953,"Right?"],[3962,4029,"Exactly."],[4129,4262,"I need to ask you a favor."],[4291,4421,"You should know that"],[4421,4550,"Eason’s grandmother"],[4550,4850,"has been bedridden and hasn’t received"],[4850,4971,"proper treatment."],[5005,5109,"I’ve heard..."],[5109,5401,"that Dr. Patrick is an excellent doctor."],[5413,5643,"Unfortunately, he’s hard to reach,"],[5643,5897,"and since you have a special"],[5905,6043,"relationship with him,"],[6072,6285,"I’m hoping you can help us out."],[6335,6410,"Does Eason know"],[6410,6535,"you’re asking me this?"],[6598,6798,"Because he did say he wouldn’t ask me"],[6798,6911,"for help and..."],[6931,7119,"I think he will be upset if he knows."],[7132,7203,"He doesn't."],[7228,7382,"Please, don't tell him."],[7461,7532,"Mrs. West,"],[7532,7665,"even if Patrick helps,"],[7665,7924,"he cannot cure every illness."],[8033,8153,"As long as there is"],[8153,8316,"even a slight chance,"],[8387,8533,"we have to try, right?"],[8621,8700,"Right."],[8833,8913,"I'll talk to him."],[8933,9021,"Thank you, dear."],[9038,9075,"And"],[9088,9225,"please, don't tell Eason"],[9225,9317,"we had a chat."],[9480,9551,"Okay."]],"50":[[171,225,"So,"],[225,425,"Eason is the father of your kids, right?"],[533,621,"How did you know?"],[754,859,"They look like him."],[984,1071,"Smart."],[1146,1292,"Do you still have feelings for him?"],[1413,1630,"I bet you still have feelings for him."],[1664,1705,"Otherwise,"],[1705,1851,"why would you reject Patrick?"],[1906,2072,"He’s asked you out several times,"],[2072,2202,"and you’ve been ignoring him."],[2214,2410,"Shelly, I can’t have kids anymore."],[2444,2594,"But Patrick doesn’t care about that."],[2610,2656,"Right?"],[2665,2815,"Yeah, maybe he doesn’t, but"],[2836,2940,"what about his family?"],[3011,3153,"Patrick is my lifesaver."],[3153,3345,"I’m so grateful for everything"],[3345,3428,"he’s done for me."],[3574,3699,"But I will not marry him."],[3795,3870,"Alright, then."],[4300,4371,"Patrick,"],[4450,4571,"how were the kids today?"],[4617,4783,"I hope they didn't give your parents"],[4783,4854,"too much trouble."],[4925,5084,"No, my parents love them."],[5100,5246,"They were playing outside today."],[5355,5430,"It's good."],[5643,5734,"And I..."],[5734,5855,"need to ask you something."],[6014,6139,"About the West family?"],[6231,6310,"Yes."],[6373,6510,"Did Eason ask you?"],[6581,6627,"No."],[6644,6794,"He did not reach out to me."],[6927,6981,"So,"],[7040,7161,"why are you helping him?"],[7307,7457,"Because his mother did."],[7507,7624,"Maybe Eason"],[7624,7845,"had his mother reaching out to you."],[7916,8120,"No. Eason is not that kind of person."],[8133,8245,"You haven’t seen each other"],[8245,8358,"in four years."],[8370,8500,"How can you be so sure"],[8500,8616,"he hasn’t changed?"],[8666,8737,"Patrick, listen."],[8737,8842,"If you don’t want to help"],[8842,8929,"his grandmother,"],[8954,9017,"that's fine."],[9142,9255,"I don’t want to make you upset."],[9342,9426,"Okay, calm down."],[9555,9693,"You’ve begged me..."],[9830,9951,"I can't refuse."],[10130,10181,"Alright."],[10360,10468,"Eason doesn’t deserve you"],[10468,10614,"to be treating yourself like this!"]],"51":[[291,342,"Boss,"],[396,554,"Patrick’s assistant just called."],[621,742,"He wants us to organize"],[742,884,"your grandmother’s medical treatment"],[884,996,"and send it over."],[1030,1163,"Dr. Patrick is willing to treat"],[1163,1251,"my grandmother?"],[1338,1422,"It seems so!"],[1472,1576,"His assistant said"],[1626,1726,"he needs to review"],[1739,1885,"her medical records first"],[1889,2002,"and might require a detailed"],[2002,2122,"check-up at the hospital."],[2690,2769,"Dr. Patrick."],[2848,2911,"Thank you for agreeing"],[2911,3003,"to treat my grandmother."],[3090,3199,"I’m doing it..."],[3228,3386,"because Chloe asked."],[3449,3516,"She begged you?"],[3574,3611,"Yes."],[3632,3757,"If she hadn’t asked me,"],[3787,4008,"I wouldn’t agree to any terms you set."],[4258,4304,"Mom,"],[4371,4533,"why didn't you tell Chloe to come?"],[4575,4688,"Isn’t that a good thing?"],[4733,4888,"I went to see Chloe myself."],[4892,4967,"Just for me."],[5025,5146,"I didn’t mention you."],[5184,5267,"You're my mother."],[5342,5455,"Even if you don’t mention me,"],[5455,5568,"she’ll think of me."],[5584,5638,"Eason,"],[5643,5768,"don’t overthink it."],[5843,6001,"Chloe is easy to talk to."],[6047,6256,"She’s much gentler than Maura."],[6356,6481,"You’re not married yet,"],[6514,6639,"and neither is she."],[6702,6835,"Why don’t you win her back?"],[6990,7161,"As long as she’s willing to marry you,"],[7211,7386,"we won’t mind her past with the kids."]],"52":[[684,738,"Annie!"],[763,850,"How are you settling into"],[850,905,"your job?"],[975,1109,"Quite well, I'd say."],[1201,1272,"How can I help you?"],[1343,1493,"We've ended our collaboration"],[1493,1559,"with Maura."],[1593,1722,"She's semi blacklisted now."],[1776,1843,"Thank you."],[1881,1985,"I’ll honor our promise"],[1985,2110,"and work diligently"],[2156,2260,"for the fashion company."],[2285,2431,"I really admire your talent."],[2473,2552,"Maura Greene"],[2560,2731,"doesn’t compare to you at all."],[2836,2919,"I’m curious,"],[2932,3098,"why do you hate Maura so much?"],[3415,3666,"I used to be Eason's Assistant."],[3837,3937,"I understand!"],[3958,4104,"You three had some sort of"],[4104,4245,"romantic entanglement."],[4416,4517,"I have even..."],[4550,4667,"deeper hatred for her."],[4671,4717,"But..."],[4742,4825,"that’s personal,"],[4825,4900,"and I think it's best"],[4900,5042,"if we don't talk about it."],[5067,5146,"Alright."],[5167,5242,"I won't ask."],[5351,5463,"Just focus on your work."],[5492,5689,"If there’s anything I can help you with,"],[5714,5776,"let me know."],[5901,6014,"Okay, thank you."],[6798,6898,"Are you free this evening?"],[6965,7019,"Let's meet up."],[7682,7728,"Thank you,"],[7916,8024,"for helping my grandma."],[8149,8220,"You’re welcome."],[8358,8521,"If the surgery goes well,"],[8625,8725,"You should thank Patrick."],[8825,8946,"Your kids are with Patrick,"],[8996,9079,"but you’re still living alone"],[9079,9192,"in your old apartment?"],[9292,9338,"Yes."],[9421,9538,"Haven't you moved on yet?"],[9580,9667,"Moved on?"],[9743,9822,"How can I move on"],[9822,9964,"when my mother was murdered?"]],"53":[[25,108,"Moved on?"],[191,271,"How can I move on"],[271,417,"when my mother was murdered?"],[450,538,"Didn’t the police"],[538,638,"clear this up before?"],[663,784,"No, it wasn’t true!"],[846,880,"You might think"],[880,1001,"I’m saying nonsense here?"],[1059,1113,"Four years ago,"],[1113,1217,"Maura showed me a video."],[1276,1384,"It was footage of my mother"],[1384,1459,"being attacked."],[1459,1543,"It was proof!"],[1572,1689,"It was not an accident!"],[1818,1910,"And until Maura Greene"],[1910,1985,"is punished,"],[2047,2139,"I can’t find peace."],[2248,2406,"Why didn’t you tell me earlier?"],[2494,2598,"Maybe she already destroyed"],[2598,2673,"all the evidence!"],[2744,2873,"How could I have told you?"],[3132,3178,"Now,"],[3324,3428,"four years have passed."],[3507,3624,"And it’s hard"],[3649,3757,"to gather evidence,"],[3837,4062,"and we can’t use legal means"],[4062,4183,"to bring her to justice."],[4383,4525,"But I can make her go bankrupt."],[4642,4708,"She grew up with"],[4708,4838,"everything handed to her."],[4988,5146,"If she suddenly loses everything,"],[5242,5355,"she’ll be miserable."],[5509,5555,"You want to help me"],[5555,5651,"get revenge?"],[5805,5847,"Do you believe"],[5847,5951,"what I’m saying is true?"],[6126,6235,"If you’re lying to me,"],[6318,6418,"I can deal with it."],[7082,7190,"Mr. Hu,"],[7311,7411,"I’ll need your support"],[7411,7494,"from now on."],[7724,7836,"That depends..."],[7874,8095,"on how well you perform tonight!"],[8304,8429,"If you can make me happy,"],[8650,8821,"I’ll definitely take care of you."]],"54":[[342,404,"Hello?"],[446,550,"Are you Ms. Maura Green?"],[642,800,"Your father was taken last night."],[921,1138,"What-, what, what do you mean?"],[1172,1334,"How could this happen?"],[1530,1651,"Was it Chloe?"],[1693,1735,"Sorry?"],[1755,1864,"Anyway, your father is"],[1864,1956,"soon to stand trial."],[1972,2068,"Please come to the police station"],[2068,2173,"as soon as possible."],[2469,2569,"You bitch!"],[2802,2848,"Hello?"],[2882,2982,"Chloe you bitch!"],[3003,3086,"Did you report my father"],[3086,3174,"because of me?"],[3240,3445,"You’re living in your fantasy world!"],[3453,3678,"My father is absolutely fine!"],[3791,3937,"But if your dad's fine,"],[3999,4141,"then what are you worried about?"],[4270,4329,"Fuck!"],[4479,4646,"Chloe, you are going to regret it!"]],"55":[[354,404,"Eason?"],[479,558,"Are you busy right now?"],[604,654,"Not really."],[671,709,"What's up?"],[754,875,"Maura just called me,"],[888,921,"saying that"],[921,1067,"somebody reported her father."],[1155,1230,"Was that you?"],[1251,1297,"Yeah."],[1343,1434,"I dug up some..."],[1447,1576,"scandals about her dad."],[1651,1776,"I figured if they push me"],[1776,1906,"to marry Maura again,"],[1951,2077,"I could use those scandals"],[2085,2168,"as leverage."],[2218,2348,"And what will happen to him?"],[2402,2519,"He'll lose his reputation"],[2519,2648,"and face fines."],[2669,2756,"Maura's future..."],[2777,2902,"doesn't look good either."],[3032,3174,"Thank you, Eason."],[3190,3249,"No problem."],[3324,3420,"Are you free this weekend?"],[3461,3566,"My mom wants to invite you"],[3566,3645,"over for dinner."],[3678,3778,"I have to watch the kids"],[3778,3828,"this weekend."],[3883,4004,"I've already met your kids."],[4233,4358,"Let's talk about it over the weekend,"],[4358,4400,"okay?"],[4450,4496,"I have to see"],[4496,4612,"if the kids are okay with that."],[4717,4763,"Alright."]],"56":[[429,475,"Chloe,"],[504,650,"today I'll watch the kids,"],[650,746,"and you can have"],[759,892,"free time with Eason."],[959,1138,"Grace, the kids can be a handful."],[1163,1376,"Nonsense! They're delightful!"],[1755,1835,"I'll see you later."],[2444,2523,"I have a feeling"],[2523,2711,"you didn’t invite me here just for dinner."],[2823,2911,"What would you like to eat?"],[2940,3015,"I can have the nanny"],[3015,3107,"prepare anything."],[3123,3249,"I'm actually not that hungry."],[3253,3370,"I had a big breakfast."],[3445,3545,"Does Patrick know you’re..."],[3570,3674,"coming to our house today?"],[3745,3866,"I did not tell him."],[3916,4049,"He’s working late today."],[4049,4095,"And..."],[4149,4287,"I think he might be a little upset"],[4300,4466,"if he knew I brought the kids over."],[4529,4579,"He told me"],[4579,4675,"he wants to marry you."],[4700,4779,"Do you feel the same?"],[4829,4963,"Can we not talk about this?"],[4996,5055,"Why not?"],[5155,5271,"If he proposes,"],[5351,5417,"will you accept?"],[5626,5680,"No,"],[5947,5989,"I'm..."],[6047,6206,"not considering marriage right now."],[6218,6364,"I just want to focus on my career"],[6373,6423,"and..."],[6485,6614,"think about the rest later."],[7044,7102,"Eason,"],[7157,7303,"Andy looks so much like you."],[7403,7482,"Mom, it's late."],[7507,7603,"Why bring this up now?"],[7678,7853,"I took a picture of Andy today."],[7991,8045,"See?"],[8133,8279,"He looks exactly like you did"],[8279,8379,"when you were a kid."],[8433,8587,"Andy must be your son, right?"],[8683,8796,"Mom, the kids’ last name"],[8796,8858,"is Hale."],[8908,9046,"They’re definitely Patrick’s."],[9100,9184,"But those kids"],[9184,9351,"do not look like Dr. Patrick!"],[9401,9522,"Andy looks like you,"],[9522,9684,"and Nina looks like Chloe."],[9734,9901,"They just do not resemble him."],[10018,10093,"Mom, calm down."],[10110,10176,"It's late."],[10193,10272,"You should rest."],[10339,10460,"Do you want to ask Chloe"],[10460,10552,"about this now?"],[10852,10969,"Let's talk about it tomorrow."]],"57":[[496,563,"Boss!"],[600,704,"You're early today!"],[788,838,"Erik,"],[880,921,"look."],[1046,1222,"Is that a photo of you as a kid?"],[1292,1384,"It's Chloe's son."],[1514,1572,"My mom told me"],[1572,1676,"he looks just like me."],[1718,1818,"He really does!"],[1922,1976,"Boss,"],[2010,2085,"if you hadn’t said"],[2085,2198,"these kids are Patrick’s,"],[2256,2335,"I might’ve thought it's your"],[2335,2427,"childhood photo."],[2544,2627,"My mom wants me to run"],[2627,2727,"a paternity test."],[2773,2873,"Let's do it, Boss!"],[2927,3044,"Given the kids' ages,"],[3073,3224,"it’s possible he’s yours."],[3716,3832,"Go contact the kindergarten."],[3862,4004,"Tell them to arrange a check-up routine"],[4004,4129,"for the kids in the afternoon."],[4233,4270,"Once we get"],[4270,4441,"Andy and Nina’s blood samples,"],[4491,4533,"send them to"],[4533,4721,"the paternity testing center immediately."],[4800,4854,"Got it."],[4996,5159,"Have you talked to Chloe about this?"],[5317,5426,"She's still holding back."],[5543,5622,"Once we get the results,"],[5622,5722,"if Andy is mine,"],[5797,5872,"I'll talk to her."]],"58":[[4,54,"Dad,"],[87,179,"are you okay?"],[241,383,"They didn’t find anything, right?"],[446,529,"Maura, I’m sorry."],[542,671,"I made a lot of mistakes."],[725,850,"I thought everything was perfect"],[855,963,"and wouldn’t be exposed,"],[963,1163,"but they found so much evidence."],[1209,1313,"To protect you,"],[1343,1438,"I’m planning to divorce"],[1438,1501,"your mother."],[1514,1622,"How could this happen!"],[1630,1726,"Dad please,"],[1760,1868,"don’t leave us!"],[1889,2035,"I have to pay fines"],[2081,2198,"and sell the house."],[2231,2369,"I need to distance myself"],[2369,2439,"to protect you."],[2619,2773,"How did Chloe manage to get"],[2773,2902,"so much dirt on you?"],[3044,3161,"It wasn’t Chloe."],[3428,3499,"What?"],[3536,3620,"It was Eason"],[3620,3753,"who wanted to take me down."],[4654,4729,"How do you feel?"],[4825,4963,"You are pregnant."],[4979,5055,"Congratulations."],[5109,5171,"What?"],[5246,5347,"I’m pregnant?"],[5447,5576,"Eason never touched me."],[5659,5722,"How?"],[5822,5964,"If it were his baby,"],[5993,6147,"Dad wouldn’t ruin anything."],[6231,6281,"You seem better."],[6331,6406,"Have a good rest."],[6431,6552,"I'll come back to you later."],[6781,6931,"Even if it's not his,"],[7194,7382,"I need Eason to think it is."]],"59":[[66,116,"Eason."],[212,246,"What?"],[321,442,"It was my fault."],[513,621,"I loved you too much,"],[621,675,"I forced you"],[675,850,"into marrying me against your will."],[871,975,"Everything happening to"],[975,1167,"my family is probably karma."],[1209,1384,"I feel like I have nowhere to turn."],[1559,1609,"Eason,"],[1705,1780,"we’ve known each other"],[1780,1901,"for so long."],[1951,2022,"Can you really bear"],[2022,2139,"to see me destroyed?"],[2185,2218,"Maura,"],[2235,2369,"don't pretend to be innocent!"],[2439,2531,"Chloe’s mother was killed"],[2531,2590,"because of you,"],[2590,2644,"wasn’t she?"],[2806,2898,"That's your karma."],[3933,4016,"Eason,"],[4158,4333,"I won’t appear in your life anymore."],[4396,4487,"I wish you and Chloe"],[4487,4575,"all the best."],[4700,4838,"May you all grow together,"],[4896,5034,"happily ever after."],[8120,8204,"Eason,"],[8324,8508,"even though you'll never be mine."],[8616,8737,"At least for tonight,"],[8863,8983,"you belong to me."],[10314,10381,"Boss,"],[10402,10506,"the paternity test"],[10506,10698,"results for you and the kids are here."]],"60":[[350,454,"She lied to me again!"],[538,675,"She said she aborted our child,"],[804,917,"but they're twins!"],[959,1105,"Congratulations, boss!"],[1180,1372,"Even though Chloe deceived you,"],[1372,1568,"she gave you two beautiful twins."],[1614,1772,"You can’t be too harsh on her."],[1805,1968,"She put in a lot of effort."],[2035,2160,"I'm going to find Chloe right now!"],[2160,2285,"Boss, when you meet Chloe,"],[2285,2385,"don’t lose your cool."],[2414,2548,"She’s a renowned designer"],[2548,2681,"at the fashion group now"],[2681,2852,"with plenty of options."],[2886,3003,"If you upset her,"],[3040,3240,"you might lose custody of the kids."],[3524,3586,"Chloe,"],[3645,3782,"Eason is looking for you."],[3958,4037,"He came here?"],[4104,4245,"Yeah, he's just outside."],[4433,4479,"Let him in."],[5155,5313,"Andy and Nina are my kids."],[5434,5543,"Why did you lie to me?"],[5676,5789,"Why did our kids think"],[5789,5918,"another man is their father?"],[6018,6139,"When I was at my lowest,"],[6164,6297,"it wasn't you who stood by me."],[6322,6427,"It was Patrick."],[6485,6652,"You’re just shifting the blame onto me?"],[6719,6810,"I never let you leave"],[6810,6919,"if I knew about our children."],[7015,7107,"You just deceive me"],[7107,7198,"all this time."]],"61":[[33,191,"You were with Maura back then,"],[191,321,"We couldn’t be together."],[321,354,"Then,"],[400,454,"how did you know"],[454,588,"I wouldn't leave the Greene’s family"],[588,671,"for you and our kids?"],[717,850,"I didn't want you to have to choose"],[850,913,"between me"],[913,1059,"and saving your grandmother."],[1184,1305,"Plus, we..."],[1305,1388,"were not compatible."],[1493,1601,"The kids were an accident."],[1634,1747,"You never cared about me."],[1789,1935,"You just wanted me for my kids."],[1956,2035,"Kids are mine."],[2052,2139,"They're my kids, too."],[2210,2264,"Without me,"],[2289,2364,"could you get these kids"],[2364,2423,"on your own?"],[2585,2677,"No matter what,"],[2723,2857,"I won't let my kids carry"],[2857,2940,"Patrick’s last name!"],[3136,3269,"Are you trying to take away my kids"],[3269,3315,"from me?"],[3365,3453,"Don't push me,"],[3486,3536,"Eason."],[3787,3837,"Alright."],[3991,4104,"Once the surgery is done,"],[4170,4270,"you’ll give the kids back."],[4408,4533,"Why did you give our kids"],[4533,4625,"Patrick’s last name?"],[4654,4808,"You two aren't even in a relationship!"],[4925,5046,"I had the kids in France."],[5201,5255,"There,"],[5255,5422,"your capability of taking care"],[5422,5501,"about child determines"],[5501,5609,"whether you can keep it or not."],[5734,5839,"If you are deemed unfit,"],[5947,6076,"they get sent to foster care."],[6101,6256,"So you couldn’t care for the kids"],[6310,6448,"and had them registered under"],[6448,6544,"Patrick's last name?"],[6614,6723,"I didn't have a choice."],[6752,6861,"You'd rather"],[6861,7061,"ask a complete stranger"],[7090,7152,"for help"],[7186,7257,"and not me?"]],"62":[[54,154,"Eason, please."],[204,291,"The kids are healthy"],[291,429,"and that's all that matters."],[429,508,"I don't want to argue"],[508,600,"about this anymore."],[625,754,"I'm the one who was deceived!"],[838,934,"My own kids"],[975,1088,"are calling someone else"],[1088,1121,"\"Dad\"."],[1192,1355,"I have all reason to be upset!"],[1393,1447,"Fine!"],[1530,1643,"Be upset all you want."],[1730,1814,"I have work to do."],[2047,2139,"You must marry me."],[2907,2961,"Eason,"],[2977,3069,"what brings you here?"],[3174,3278,"I know you and Chloe used to"],[3278,3345,"have a thing."],[3436,3499,"Normally,"],[3524,3645,"I wouldn’t get involved in"],[3645,3749,"a personal affairs,"],[3812,3883,"but now"],[3903,3999,"that I’m her boss."],[4020,4233,"I'm still the father of her kids!"],[4233,4350,"I won't interfere with"],[4350,4454,"Chloe working here,"],[4466,4600,"so don't worry about me"],[4600,4688,"coming to see her."],[4746,4833,"Are you the father of"],[4833,4892,"her kids?"],[4950,5067,"I have a paternity test."],[5100,5171,"Would you like to see?"],[5309,5459,"No wonder you and Maura broke up."],[5547,5697,"So, you are planning to marry"],[5697,5768,"Chloe now?"],[5910,6026,"She has to marry me."]],"63":[[300,442,"Eason's quite the catch."],[475,550,"Handsome,"],[567,663,"successful,"],[709,867,"and with a clean reputation."],[896,996,"Maura always wanted to"],[996,1063,"marry him"],[1096,1230,"but he wasn't interested."],[1276,1438,"Now he's willing to marry you."],[1522,1647,"Why the hesitation?"],[1735,1906,"Marrying him was always my dream."],[1997,2135,"We didn't work out back then."],[2135,2193,"And now,"],[2248,2427,"not sure marriage is the right step."],[2531,2594,"Chloe,"],[2606,2773,"with your talent and status,"],[2786,2944,"you deserve someone great."],[3007,3107,"If I were you,"],[3132,3340,"I'd consider Eason seriously."],[3365,3415,"Plus,"],[3453,3599,"he's the father of your children."],[3720,3878,"And my kids are doing just fine."],[3912,4029,"But with Eason,"],[4058,4220,"things could be even better."],[4237,4329,"No matter how good"],[4329,4412,"Patrick is,"],[4450,4596,"can he love your children"],[4621,4758,"like their real father?"],[4792,4888,"I can tell you."],[4892,4950,"Only"],[4975,5134,"a biological father's love is"],[5134,5251,"truly unconditional."],[5743,5834,"I told you,"],[5885,6106,"Andy looks exactly like Eason!"],[6143,6277,"Andy has to be his son!"],[6297,6514,"And I can’t believe Nina is too!"],[6569,6639,"Twins,"],[6719,6848,"that’s so perfect!"],[6848,6915,"Why aren't you"],[6915,7027,"bringing the kids back?"],[7098,7282,"We don't abandon family,"],[7298,7349,"Eason."],[7399,7478,"Now is not the time."],[7515,7657,"Let's talk after Grandma’s surgery."],[7691,7761,"Are you worried"],[7761,7957,"Dr. Patrick won’t give the kids back?"],[8028,8149,"They’re not his."],[8204,8270,"Why won’t he"],[8270,8391,"return them to us?"],[8491,8604,"Because while the kids are"],[8604,8687,"under his roof,"],[8767,8921,"Chloe won’t run away."],[9004,9171,"Patrick just wants to be with Chloe."]],"64":[[25,83,"Then,"],[83,191,"when Chloe back?"],[446,546,"That's the plan tonight."],[617,688,"Good luck."],[2168,2239,"What are you doing here"],[2239,2310,"so late at night?"],[2398,2556,"Aren’t we agreed to talk after"],[2556,2640,"grandmother's surgery?"],[3103,3215,"Don't pretend like you don't have"],[3215,3286,"feelings for me."],[3486,3553,"Eason,"],[3724,3812,"you weren't the only one"],[3812,3928,"struggling, ok?"],[4041,4129,"I carried our children"],[4129,4204,"for nine months,"],[4204,4329,"you know how hard that was?"],[4416,4471,"I admitted"],[4471,4533,"I..."],[4583,4713,"was wrong to deceive you,"],[4746,4779,"but I did"],[4779,4904,"what I thought was best."],[5025,5134,"Never blamed you."],[5271,5347,"Please."],[5430,5543,"Don't see me as the enemy."],[7411,7507,"Good morning."],[7557,7682,"I made you some breakfast."],[7716,7824,"Go wash up so we can eat."],[8191,8291,"After breakfast,"],[8466,8596,"take me to your mom's grave."],[8842,8904,"Eason."]],"65":[[592,671,"Mrs. Hartman,"],[804,909,"I should have come sooner."],[988,1109,"Even though we never met,"],[1209,1322,"I feel responsible."],[1455,1630,"If Chloe hadn't met me,"],[1760,1864,"you'd still be here."],[1960,2018,"Eason,"],[2152,2285,"I never blamed you"],[2314,2456,"for what happened to my mother."],[2715,2794,"I never"],[2844,2890,"regretted."],[2973,3136,"Besides apologizing to your mom,"],[3278,3382,"I want her to know that"],[3457,3611,"I'm willing to spend the rest of my life"],[3611,3753,"taking care of you and our kids."],[3978,4070,"Chloe Hartman,"],[4517,4621,"will you marry me?"],[4725,4954,"A proposal at my mom's grave?"],[5000,5167,"Only Eason would think of this."],[5451,5555,"Let me think about it."],[5755,5805,"After your"],[5805,5905,"grandmother’s surgery,"],[6006,6110,"I’ll give you an answer then,"],[6160,6189,"okay?"],[6222,6348,"Is it because of Patrick?"],[6348,6398,"No,"],[6398,6519,"no, it's not because of Patrick."],[6519,6552,"I..."],[6573,6706,"I just don’t want to rush things."],[6769,6877,"Patrick is focusing on"],[6877,6994,"your grandmother's surgery,"],[6994,7023,"and"],[7048,7090,"just..."],[7136,7311,"I don't think it's the right timing"],[7319,7411,"to announce this."],[7474,7603,"The roles were reversed,"],[7603,7703,"how would you feel?"],[7799,7857,"Alright."],[7982,8078,"After the surgery,"],[8095,8153,"let's talk."],[8237,8295,"By the way,"],[8379,8491,"have you thought about moving?"],[8550,8637,"Your mom wouldn't like you"],[8637,8750,"living in that old apartment"],[8750,8804,"forever."],[8850,8892,"I know."],[9075,9188,"I'll start looking soon."],[9246,9384,"I have several places."],[9421,9551,"Let's pick one you like."],[9601,9747,"It can be our wedding gift."]],"66":[[171,408,"Well, if everything goes well,"],[408,579,"the surgery will be next Friday."],[671,788,"Dr. Patrick,"],[788,921,"we can't thank you enough."],[1021,1155,"Can't guarantee success,"],[1155,1217,"but..."],[1247,1351,"I'll do my best."],[1376,1488,"Don't put too much pressure"],[1488,1555,"on yourself."],[1614,1814,"We're prepared for any outcome."],[2460,2615,"We're also grateful for"],[2615,2740,"how you've cared for"],[2740,2840,"Andy and Nina."],[2907,3028,"And if you're willing,"],[3044,3140,"we'd be honored"],[3140,3286,"if you could continue to be"],[3286,3382,"part of their lives."],[3632,3732,"Did you tell them?"],[3828,3891,"Dr. Patrick,"],[3912,4045,"Chloe didn’t tell us anything."],[4066,4179,"It just happened to"],[4195,4329,"see Andy and thought he"],[4391,4466,"looked like me."],[4550,4692,"So we ordered a paternity test"],[4692,4758,"for the kids."],[4775,4896,"You guys didn't ask for"],[4896,5055,"my permission to do that!"],[5150,5288,"What you've done is illegal!"],[5359,5513,"I'm their biological father."],[5622,5809,"Being called \"Dad\" doesn't make you"],[5809,5889,"their father."],[5985,6139,"Regardless of biology,"],[6139,6281,"I've been there for them."],[6327,6393,"Please,"],[6439,6552,"don't argue."],[6631,6723,"Dinner's getting cold."],[6748,6823,"Let's just eat."],[6944,7007,"Okay?"]],"67":[[291,462,"Patrick, I've moved."],[558,675,"You’re telling me now?"],[779,925,"Why didn’t you tell me sooner?"],[1101,1201,"It seemed unimportant"],[1201,1305,"back then and I"],[1305,1413,"didn't want to bother you."],[1468,1572,"Does Eason know?"],[1985,2060,"Yes."],[2243,2352,"Are you..."],[2431,2548,"getting back with Eason?"],[2656,2694,"Patrick,"],[2694,2836,"I just started a new job."],[2836,3007,"I'm still adjusting."],[3069,3153,"Really not thinking about"],[3153,3253,"relationships right now."],[3374,3545,"But Eason and his family,"],[3603,3766,"they seem very welcoming."],[3816,3999,"They don't see you as an outsider."],[4095,4195,"But they’re very welcoming"],[4195,4279,"to you, too."],[4283,4379,"They also don’t see you"],[4379,4454,"as an outsider."],[4475,4612,"Well, it's different."],[4625,4688,"I guess..."],[4713,4796,"I guess it is."],[5075,5263,"I've known Eason for a very long time,"],[5334,5463,"so his parents know me."],[5522,5755,"Now that they know about the kids,"],[5814,5889,"we're closer."],[6177,6302,"So what are you thinking?"],[6552,6656,"I'm not sure."],[6723,6765,"Even though"],[6765,6931,"I cared about Eason before,"],[6990,7127,"it's been four years."],[7303,7474,"I can't just decide so hastily."],[8124,8312,"My guess was right."],[8358,8479,"Chloe is already"],[8479,8625,"tangled up with Eason."],[8746,8896,"Maybe all the houses here"],[8896,9004,"belong to Eason."],[9129,9217,"Chloe,"],[9242,9409,"I’ve been so good to you,"],[9484,9672,"why can’t I warm your heart?"],[9851,9993,"What is Eason doing better"],[9993,10064,"than me?"],[10181,10318,"I can give you everything"],[10318,10427,"Eason can give you."],[10527,10635,"I’m not giving up!"],[11394,11532,"Why didn't you call me back?"]],"68":[[70,129,"Sorry,"],[129,300,"I'm so exhausted today."],[362,504,"Finished work late and"],[525,625,"didn’t really check my phone."],[625,742,"I just have to take a shower."],[800,917,"Want me to get you a nanny?"],[1009,1055,"Oh, no."],[1113,1167,"That's okay."],[1167,1272,"We can just get a cleaner"],[1272,1380,"for the weekends."],[1438,1564,"Why are you pushing me away?"],[1659,1743,"It's been four years,"],[1743,1822,"we didn't see each other."],[1931,2081,"We need to spend more time together,"],[2122,2185,"don't you think?"],[2410,2448,"Chloe,"],[2902,3028,"this is a gift from my mom."],[3174,3236,"Please."],[3878,3933,"Are you sure"],[3933,4074,"this is a gift from your mom?"],[4145,4316,"This feels more like your style."],[4341,4433,"My mom asked me"],[4433,4612,"what kind of gift you’d want."],[4654,4792,"I said I wasn’t sure."],[4884,4934,"So..."],[4963,5113,"suggested to give you money."],[5142,5271,"So you can buy what you want."],[5372,5509,"So, she prepared this card."],[5609,5714,"Classic Eason!"],[5955,6026,"I don't need it."],[6114,6243,"I can earn my own money,"],[6285,6389,"not short on cash."],[6431,6506,"Then I'll buy you"],[6506,6623,"another gift tomorrow."],[6715,6790,"It's okay."],[6873,6969,"Go freshen up."],[7082,7165,"After my grandmother’s"],[7165,7311,"surgery next week,"],[7344,7469,"you have to clear things up"],[7469,7540,"with Patrick."],[7607,7678,"You’re mine."],[7774,7953,"Tell him to stop interfering."],[8070,8233,"Said that love can’t accommodate"],[8233,8304,"three people."],[8370,8429,"I will."]],"69":[[12,87,"Chloe,"],[137,300,"I just picked up a package for you"],[300,400,"from the front desk."],[450,575,"I brought it to you, here."],[600,658,"What is it?"],[688,813,"It’s from a jewelry store."],[825,900,"The staff said"],[900,1005,"a customer bought it"],[1038,1176,"and had it delivered here."],[1226,1359,"The customer is either"],[1376,1509,"Patrick or Eason!"],[2360,2427,"Wow!"],[2519,2652,"These are beautiful!"],[2711,2781,"Chloe,"],[2790,2936,"your skin is so fair,"],[2957,3119,"these would look amazing on you!"],[3232,3415,"Eason must have bought these."],[3490,3557,"He said he wanted to"],[3557,3695,"give me a gift last night."],[3787,3995,"I didn’t expect him to leave them here."],[4688,4767,"Eason!"],[4796,4988,"I just got a set of jewelry."],[4988,5100,"Did you buy this for me?"],[5192,5238,"Yeah,"],[5263,5330,"do you like them?"],[5472,5538,"I love it."],[5568,5668,"How much I work,"],[5668,5768,"I don't really have any work"],[5768,5872,"to wear those."],[5935,6047,"Really, you don’t have to spend"],[6047,6147,"that much money on me."],[6147,6202,"Just..."],[6202,6310,"Let me something affordable"],[6310,6368,"next time."],[6510,6577,"Okay?"],[6694,6731,"Chloe,"],[6735,6810,"keep working."],[6886,6994,"We'll talk at lunch."],[7440,7515,"Eason!"],[7578,7674,"I'm sorry."],[7695,7899,"I know we agreed not to stay in touch,"],[7899,7945,"but..."],[8220,8341,"I’m pregnant."],[8375,8546,"The baby is yours, Eason."],[8546,8650,"I didn’t know what to do,"],[8650,8796,"so I had to call you."],[8863,8967,"What are you talking about?"],[8979,9142,"I’m pregnant, Eason."],[9175,9371,"The baby is yours."],[9392,9484,"I don’t want to ruin"],[9484,9622,"your relationship with Chloe."],[9626,9667,"But..."]],"70":[[25,58,"Maura,"],[58,166,"are you sure the baby is mine?"],[241,321,"I was drunk,"],[354,417,"I don’t remember"],[417,513,"anything happening."],[629,734,"You don't remember,"],[734,842,"but I do."],[880,1026,"Maura, you better not be lying."],[1055,1155,"I'm not!"],[1280,1380,"If you don't believe me,"],[1380,1509,"we can do a paternity test,"],[1509,1680,"after the baby is yours."],[1705,1835,"I won't let that come."],[1931,2068,"So you really have"],[2068,2243,"no feelings for me?"],[2285,2394,"You don't even want"],[2394,2515,"your own child?"],[2515,2635,"I already have children."],[2677,2744,"Chloe and I"],[2765,2869,"have twins."],[2911,3011,"She is the only one"],[3011,3115,"I plan to marry."],[3186,3315,"If you tell her about this,"],[3353,3499,"there will be consequences."],[3541,3687,"If I abort the baby,"],[3707,3803,"you'll have to clear"],[3803,3962,"my dad's reputation."],[3962,4091,"Absolutely not!"],[4245,4346,"Then give me money."],[4508,4600,"How much do you want?"],[4621,4700,"Ten million."],[4733,4884,"It's not much for you, and..."],[4884,5013,"my family needs it."],[5084,5176,"If you abort the baby,"],[5184,5296,"I’ll transfer the money!"],[5372,5467,"Okay, but..."],[5547,5697,"can you please come with me?"],[5709,5851,"My parents don't know and"],[5905,6018,"they would never allow it."],[6085,6218,"I'm scared to go alone."],[6435,6493,"Fine!"],[6598,6702,"I'll meet you at the hospital"],[6702,6769,"this afternoon."],[6840,6919,"Okay."]],"71":[[663,725,"Eason,"],[750,842,"thanks for agreeing to"],[842,892,"come with me"],[892,1017,"to prenatal appointment."],[1059,1230,"I'll be at St. Mary's Hospital"],[1230,1372,"at 2:30 PM."],[2565,2748,"Oh sorry, wrong person."],[2773,2836,"Chloe,"],[2836,3078,"I've paid dearly for my past mistakes."],[3090,3203,"My dad is ill,"],[3203,3378,"and my family is falling apart."],[3407,3495,"I'm sorry."],[3532,3616,"I promise not to"],[3616,3716,"bother you anymore."],[3891,3999,"Are you pregnant?"],[5434,5655,"So Maura really is pregnant with"],[5655,5759,"Eason's child?"],[5847,5997,"He's promising to be with me"],[5997,6089,"and the kids, but"],[6106,6214,"he's here with her?"],[6352,6498,"I can't handle this!"]],"72":[[108,166,"Chloe,"],[266,379,"what are you doing here?"],[379,446,"Are you okay?"],[533,692,"Why are you here with Maura?"],[867,930,"Eason,"],[930,1088,"since Chloe isn't feeling well,"],[1192,1297,"you should stay with her."],[1330,1468,"I'll head inside first."],[1739,1843,"Chloe, I'm sorry!"],[1881,2035,"This all happened so suddenly."],[2110,2168,"I didn't expect"],[2168,2298,"Maura to be pregnant."],[2323,2356,"But we..."],[2356,2439,"You told me to end things"],[2439,2506,"with Patrick,"],[2506,2569,"even though we had"],[2569,2694,"nothing going on."],[2727,2790,"While saying"],[2790,2907,"you and Maura were done,"],[2952,3065,"and now this?"],[3132,3219,"A baby?"],[3315,3490,"Don't you see how absurd this is?"],[3520,3628,"I'll take care of it."],[3687,3791,"Take care of it?"],[3845,3912,"How?"],[4179,4262,"Chloe!"],[4341,4433,"I was drunk."],[4454,4529,"I don't remember"],[4529,4625,"anything happening."],[4704,4813,"She claims the baby is mine,"],[4813,4909,"but I doubt it."],[4992,5042,"You were drunk"],[5042,5155,"when we first met too."],[5159,5292,"Is that what you usually do?"],[5317,5397,"You get drunk"],[5397,5538,"and you slept with women?"],[5689,5834,"I'm so disappointed in you."]],"73":[[437,525,"Is everything done?"],[571,621,"Yeah."],[717,763,"Eason,"],[796,925,"why are you still here?"],[975,1055,"I thought I told you to"],[1055,1163,"stay with Chloe."],[1230,1309,"She left."],[1384,1472,"I'm sorry."],[1530,1676,"Everything is my fault."],[1676,1814,"If I hadn't gotten pregnant,"],[1814,1964,"none of this would've happened."],[1976,2102,"Maura, did you call her here?"],[2185,2264,"How else would she"],[2264,2348,"just happen to show up"],[2348,2406,"at the hospital?"],[2414,2531,"I didn't!"],[2585,2715,"Please believe me."],[2756,2857,"I wouldn't dare to make"],[2857,2982,"more mistakes."],[3007,3186,"I'll do whatever you ask."],[3228,3365,"From now on, we're done."],[3424,3536,"Don't contact me again."],[3582,3666,"Okay."],[3695,3858,"I won't reach out to you again."],[3908,4045,"I'll have our CFO"],[4045,4216,"transfer the money for you later."],[4287,4387,"Thank you."],[4725,4779,"Erik,"],[4825,4925,"I need you to have someone"],[4925,5000,"follow Maura."],[5105,5280,"I want daily check on who she meets."],[5321,5380,"Also,"],[5447,5576,"check who she's been seeing"],[5576,5676,"after we broke up."],[5739,5830,"Boss,"],[5851,6018,"didn't you end things with her?"],[6106,6256,"Why investigate now?"],[6368,6406,"She claimed"],[6406,6544,"she was pregnant with my child,"],[6594,6652,"but I suspect"],[6652,6765,"the baby wasn't mine."],[6965,7098,"Last time we met,"],[7136,7328,"I was blackout drunk."],[7374,7520,"When I was drunk with Chloe"],[7586,7699,"years ago,"],[7782,7966,"I remembered everything."]],"74":[[16,175,"I need to get to the bottom of this."],[175,254,"Otherwise,"],[308,462,"I won't be able to explain things"],[462,529,"to Chloe."],[579,734,"Does Chloe know about this?"],[817,913,"Yeah."],[925,1013,"I ran into her"],[1013,1088,"when I brought Maura"],[1088,1184,"to the hospital."],[1234,1322,"I suspect"],[1347,1505,"Maura might have called her,"],[1597,1689,"but she denies it."],[1718,1839,"Alright, Boss."],[1885,1989,"I'll get someone on it"],[1989,2056,"right away."],[2097,2252,"You need to keep Chloe steady."],[2264,2406,"Don't let Dr. Patrick use"],[2406,2540,"this opportunity to come"],[2540,2631,"between you two."],[2836,2915,"I know."],[3357,3415,"Chloe,"],[3436,3524,"I made dinner."],[3524,3687,"It's my first time cooking so,"],[3712,3816,"not sure it's any good."],[3858,4024,"I'm here to pack my things."],[4054,4104,"Chloe!"],[4170,4258,"I can explain!"],[4329,4416,"I'm having my people"],[4416,4508,"look into it."],[4542,4637,"I'll have more information"],[4637,4750,"I promise!"],[5113,5213,"You know what kind of person"],[5213,5292,"Maura is."],[5321,5434,"Her father's downfall was"],[5434,5618,"because I exposed him."],[5776,5897,"She'd take any chance"],[5897,6010,"to get back at me."],[6143,6289,"Let's not fall into her trap."],[6510,6569,"Fine."],[6719,6819,"Let's have dinner."],[6944,7027,"Even though it's"],[7027,7148,"my first time cooking,"],[7194,7369,"I tasted everything and..."],[7428,7565,"it's not that bad."]],"75":[[79,208,"If you didn't do anything wrong"],[208,275,"then..."],[275,404,"what's all this?"],[533,688,"Maura's baby isn't mine."],[734,867,"I'm certain of that."],[930,1105,"But I did promise you dinner."],[1197,1397,"Anyway, if I had feelings for Maura,"],[1484,1626,"we'd be married with kids"],[1626,1685,"by now."],[1755,1818,"I know."],[1989,2118,"I won't let Maura"],[2143,2264,"gets to me that easily"],[2264,2360,"moving forward."],[2377,2427,"Chloe,"],[2427,2535,"I just want to be with you"],[2535,2694,"and raise our kids together."],[2848,2965,"I missed three years of"],[2965,3036,"their lives."],[3103,3244,"I'm not going to miss any more."],[3328,3415,"I know."],[3712,3795,"Shall we eat?"],[3853,3924,"Sure."],[5601,5718,"So you deliberately"],[5718,5876,"sent me the wrong message today,"],[5876,5947,"didn't you?"],[6118,6189,"Maura,"],[6235,6356,"I'm messaging you now"],[6356,6498,"to tell you your little scheme"],[6498,6573,"didn't work."],[6635,6727,"Oh, really?"],[6819,6986,"How did Eason smooth things over"],[6986,7052,"with you?"],[7190,7344,"I believe he didn't touch you."],[7424,7653,"He doesn't even like you, so..."],[7686,7770,"how could he have"],[7770,7891,"gotten you pregnant?"]],"76":[[750,880,"Chloe, don't go!"],[1105,1255,"Didn't we agree last night?"],[1422,1534,"Why are you leaving?"],[1672,1818,"I have to go on a business trip."],[1885,1993,"I'll be back when it's done."],[2114,2214,"Oh man,"],[2256,2398,"guilty conscience really gets you."],[2456,2581,"I thought you were leaving me."],[2677,2790,"Didn't you say you'd have sombody"],[2790,2882,"to investigate?"],[2990,3153,"I hope when the time I'm back,"],[3153,3278,"you'll have the answers."],[3332,3474,"How long will you be gone?"],[3520,3607,"I'll be back by your"],[3607,3724,"grandmother's surgery."],[3849,4008,"Alright, then..."],[4045,4166,"I'll try to have everything figured"],[4166,4258,"out by then."],[4421,4500,"Chloe,"],[4500,4583,"I know you're still bothered"],[4583,4771,"by what's going on with Maura."],[4959,5130,"Anything I say now probably sounds"],[5130,5226,"like an excuse."],[5338,5513,"But I promise I'll find out the truth."],[5593,5709,"In the meantime,"],[5793,5910,"if anything comes up,"],[5997,6193,"promise me you'll tell me right away."],[6410,6481,"Okay."],[6548,6660,"I'll let you know."],[6923,7002,"I love you."],[7086,7203,"I love you, too."],[8033,8174,"Shelly said Chloe doesn't really need"],[8174,8337,"to go on this business trip,"],[8345,8470,"but she's insisting on it."],[8558,8733,"Feels like she's avoiding something."],[8804,9042,"She must've had a fight with Eason."]],"77":[[25,166,"Eason might be rich,"],[187,446,"but he's not as mature and stable"],[446,504,"as you are."],[554,638,"If I were Chloe,"],[663,821,"I would definitely choose you."],[938,1063,"Chloe's still young,"],[1113,1192,"she doesn't really know"],[1192,1276,"what she wants."],[1401,1488,"But it's okay."],[1618,1722,"After the surgery,"],[1722,1881,"I'll take her away from here."],[1939,2081,"Do you think she'll go with you?"],[2152,2277,"I have my ways"],[2318,2456,"to make sure she does."],[2806,2994,"Chloe's no match for me."],[2994,3153,"Even you know why she went on that"],[3153,3232,"business trip?"],[3424,3653,"Because I pissed her off."],[3653,3720,"Maura,"],[3720,3837,"do you think there's still a chance"],[3837,3958,"between you and Eason?"],[4041,4200,"I hate him now."],[4291,4517,"Unless he comes back crawling,"],[4550,4633,"I'm done."],[4633,4746,"So what's your plan?"],[4746,4896,"Once I'm back on my feet,"],[5025,5150,"I'm going back to work."],[5217,5305,"I've already talked to"],[5305,5426,"the Hudson Corp boss."],[5472,5772,"He said I can start whatever I want."],[6189,6277,"Boss,"],[6277,6427,"I got in touch with one of Maura's"],[6427,6531,"old friends."],[6577,6744,"We managed to get her to mention"],[6744,6873,"Hudson Corp's boss."],[6977,7073,"Hudson Corp?"],[7198,7303,"Who's the boss there?"],[7332,7428,"Hunter Hughes."],[7478,7595,"The guy's a grease ball."],[7686,7853,"Want me to set up a meeting so you two"],[7853,7991,"can talk in person?"]],"78":[[233,350,"Mr. West,"],[429,554,"I'm gonna saying"],[554,621,"it's an honor that"],[621,721,"you'd invite me to lunch."],[809,909,"But..."],[963,1096,"what do you need from me?"],[1201,1322,"Is there something I'm missing?"],[1409,1505,"Just because"],[1505,1643,"we don't collaborate now doesn't mean"],[1643,1743,"we won't in the future."],[1847,2039,"I wanted to meet today to"],[2039,2106,"make friends."],[2289,2435,"Well if you want to be friends,"],[2435,2519,"I'm all for it!"],[2631,2736,"Doesn't matter fact,"],[2894,2977,"lunch's on me."],[2998,3065,"It's okay."],[3090,3199,"I'll take care of the bill."],[3257,3357,"Mr. Hughes,"],[3357,3457,"I was..."],[3511,3712,"hoping to ask some"],[3812,3970,"personal matters, if that's alright."],[4074,4166,"Yours?"],[4225,4300,"Or mine?"],[4346,4429,"Yours."],[4725,4813,"Well..."],[4888,5009,"You're not gonna ask about Maura,"],[5009,5059,"are you?"],[5201,5309,"As I recall"],[5363,5488,"she was your girlfriend."],[5580,5676,"That's right."],[5809,5947,"Has she been in touch with you?"],[6031,6118,"Sure has."],[6331,6448,"You're not thinking about"],[6448,6573,"getting back with her, are you?"],[6685,6781,"I mean..."],[6886,7011,"She's an exciting woman!"],[7294,7482,"When did Maura \"excite\" you?"],[7557,7682,"Did you use protection?"],[7828,7937,"A while back."],[8062,8295,"Can't remember exactly when but..."],[8379,8504,"Didn't use protection,"],[8600,8683,"never do."],[8737,8808,"Got it."],[8888,9017,"Thank you for letting me know."],[9067,9150,"I have no plans on"],[9150,9280,"getting back with Maura."],[9421,9567,"By the way, Mr. Hughes,"],[9730,10035,"I have a good news and a bad news."],[10105,10256,"The good news is, she was pregnant"],[10256,10356,"with your baby."],[10435,10543,"The bad news is,"],[10543,10710,"she terminated the pregnancy."]],"79":[[16,125,"Mr. Hughes,"],[204,287,"your assistant asked me"],[287,371,"to wait here,"],[421,533,"she said you wanted to speak"],[533,596,"with me."],[771,950,"I came right after I got the call."],[1084,1222,"Did you have some drinks at lunch?"],[1305,1418,"How about"],[1530,1655,"I make you some tea?"],[1693,1760,"Maura,"],[1885,2068,"were you pregnant with my child?"],[2160,2306,"Who did you have lunch with?"],[2385,2460,"Eason?"],[3549,3699,"Do you think I'm a some kind of fool?"],[3716,3824,"You were pregnant with my kid and"],[3824,3974,"you went running to Eason!"],[4029,4104,"He gave you ten million"],[4104,4191,"for an abortion?"],[4233,4383,"It wasn't about the money."],[4446,4558,"I was trying to restore"],[4558,4654,"my dad's reputation."],[4771,4942,"I didn't mean to disrespect you."],[4988,5055,"Please."],[5105,5155,"So"],[5238,5422,"you were pregnant with my kid all long!"],[5780,5864,"Yes."],[5972,6089,"Yes, it was yours."],[6790,6915,"Mr. West,"],[6956,7082,"you heard all that, didn't you?"],[7082,7278,"I'll treat you to dinner soon."]],"80":[[50,137,"Eason!"],[204,300,"After everything"],[300,375,"we've been through,"],[375,458,"do you really have to"],[458,583,"ruin me completely?"],[750,909,"Hunter won't speak with me!"],[984,1155,"You're a lying, malicious woman."],[1226,1334,"Everything's happening to you is"],[1334,1451,"your own karma!"],[1605,1722,"You're not going to ask"],[1722,1910,"about ten million back, are you?"],[2035,2173,"My lawyers will be in touch."],[2223,2444,"You remember your friend Ruby,"],[2560,2773,"you can join your bestie in prison!"],[2844,2936,"Asshole!"],[5851,5918,"Hello?"],[5976,6051,"Chloe!"],[6110,6243,"I've cleared everything up."],[6477,6577,"I sent you a recording,"],[6619,6731,"listen to it, and"],[6760,6823,"you'll understand"],[6823,6919,"everything happened."],[6990,7127,"You figured it out already?"],[7178,7236,"Yeah."],[7273,7419,"Maura's child wasn't mine."],[7511,7657,"She tried to extort ten million dollars"],[7657,7716,"from me."],[7724,7816,"I've handed everything"],[7816,7903,"to the lawyers."],[8033,8220,"She might go to jail, and"],[8220,8329,"you'll get your avenge."],[8479,8641,"I didn't expect to avenge my mother"],[8641,8712,"like this."],[8762,8871,"The process doesn't matter as"],[8871,9025,"long as we get the result we want."],[9109,9175,"Eason,"],[9213,9288,"I..."],[9288,9405,"owe you an apology."]],"81":[[133,287,"After all this happened, I..."],[308,479,"doubted you and got angry."],[542,646,"I didn't trust you enough"],[646,750,"and I'm sorry for that."],[825,942,"The fact that you were upset"],[959,1117,"shows that you care about me."],[1180,1322,"You don't have to apologize."],[1480,1568,"If I were in your shoes,"],[1601,1693,"I'd be mad too."],[1843,1893,"When are you"],[1893,1985,"coming back though?"],[2139,2248,"In a couple of days."],[2264,2373,"I... just"],[2373,2485,"need to finish the job here"],[2485,2631,"and I’ll... head back."],[2669,2723,"Alright."],[2769,2882,"I'll be waiting for you."],[3128,3219,"Will you still cook for me"],[3219,3294,"when I’m back?"],[3428,3561,"Just let me know when you arrive,"],[3595,3807,"and I'll have dinner ready for you."],[3908,3958,"Deal."],[4600,4658,"Chloe,"],[4679,4846,"you must not have been eating well"],[4846,4971,"on your business trip."],[5025,5171,"You've lost weight!"],[5255,5522,"I asked Eason to bring you over"],[5522,5768,"so we could have a chat over dinner."],[5864,5914,"Chloe,"],[5960,6210,"you and Eason are at the perfect age"],[6210,6306,"for marriage"],[6331,6443,"and you have such"],[6443,6585,"beautiful twins together."],[6644,6848,"Why not tie the knot this year?"],[6911,7115,"I'll even help you plan the wedding."],[7194,7332,"Mrs. West, I was planning to"],[7332,7478,"discuss this with Eason"],[7478,7532,"after his"],[7532,7645,"grandmother's surgery."],[7645,7699,"But..."],[7757,7874,"since you've brought it up,"],[8078,8229,"I've been in love with Eason"],[8229,8341,"for a very long time-"],[8370,8641,"since four years actually."],[8696,8812,"I still love him."],[8917,9034,"I'd be more than happy"],[9034,9129,"to marry him."]],"82":[[312,387,"Patrick,"],[442,550,"I got you a little something"],[550,675,"from my business trip."],[750,842,"You look well."],[871,1009,"Did you and Eason make up?"],[1222,1401,"My parents took Andy and Nina"],[1401,1522,"out for some fun."],[1593,1760,"They know you've been spending"],[1760,1835,"a lot of time"],[1835,2056,"with Eason lately and..."],[2118,2198,"they are afraid"],[2298,2452,"they won't get to see the kids"],[2452,2535,"as much anymore."],[2627,2686,"So..."],[2815,2865,"they wanted to"],[2865,2977,"make some memories"],[3044,3174,"before things change."],[3244,3420,"Even if I'm with Eason,"],[3457,3582,"you can come see the kids"],[3582,3712,"anytime you want."],[3766,3933,"You're like an uncle to them."],[4029,4187,"Seems like you two are..."],[4187,4308,"talking about marriage."],[4450,4525,"Patrick."],[4587,4650,"My work"],[4692,4913,"won't be affected by my personal life."],[5017,5201,"Even if you told me right now that"],[5226,5351,"you've married Eason,"],[5451,5634,"I'd still perform surgery tomorrow."],[5789,5872,"I..."],[5926,6131,"do plan to marry him."],[6435,6506,"Alright."],[6823,6944,"Is it because of the kids?"],[7111,7203,"No!"],[7298,7399,"I love him."],[7578,7636,"Love..."],[7899,8137,"Love is a pretty superficial thing."],[8295,8441,"For a relationship to last,"],[8441,8558,"it takes more than that."],[8566,8696,"I don't think he’s gonna hurt me"],[8696,8808,"like that anymore."],[8996,9142,"I'm willing to give him a chance."],[9246,9355,"If you've set your mind on"],[9355,9434,"marrying him,"],[9667,9776,"I can't stop you."],[10076,10168,"I'm sorry."]],"83":[[1618,1718,"How do I look?"],[1864,1947,"Amazing!"],[2339,2435,"Makes me want to marry you"],[2435,2510,"immediately."],[2627,2690,"You know,"],[2752,2902,"other than doing this ceremony,"],[2902,3069,"we’re pretty much married already."],[3157,3240,"It'd be perfect"],[3240,3378,"if the kids were here with us."],[3561,3653,"I miss them too."],[3724,3874,"Once they're back from their trip,"],[3899,3999,"I'll bring them home."],[4020,4141,"And from now on,"],[4141,4300,"the four of us won't be apart."],[4329,4425,"Absolutely."],[5055,5155,"Dr. Patrick,"],[5238,5342,"thank you for performing"],[5342,5430,"my grandmother's surgery"],[5430,5518,"as promised."],[5860,5935,"Here's the compensation"],[5935,6018,"I owe you."]],"84":[[221,287,"Chloe and I are"],[325,421,"planning our wedding"],[446,538,"on October 1st."],[554,692,"I hope you'll come."],[850,909,"Well,"],[1051,1121,"we'll see."],[2273,2339,"Grandma,"],[2494,2581,"are you awake?"],[2660,2765,"Do you recognize me?"],[2823,2911,"Can you speak?"],[2927,3023,"Eason..."],[3061,3132,"It's you."],[3207,3357,"It's been so long since I've heard you"],[3357,3440,"say my name."],[3478,3586,"I'll go get the doctor."],[3628,3678,"Yes."],[3916,3995,"Eason,"],[4033,4120,"who was that?"],[4175,4441,"I don't think I've met her before."],[4546,4612,"Grandma,"],[4633,4713,"that's Chloe."],[4738,4833,"I'm going to marry her."],[4888,4950,"She gave me"],[4979,5109,"two beautiful children."],[5155,5217,"A boy,"],[5292,5351,"and a girl."],[5580,5697,"That's wonderful."],[5747,5872,"Where are the kids?"],[6381,6460,"Excuse me,"],[6485,6631,"have you seen Dr. Patrick?"],[6656,6769,"Dr. Patrick has left."],[6773,6915,"He only handles surgeries."],[6956,7098,"We'll be taking care of Mrs. West's"],[7098,7211,"post-operative care."]],"85":[[471,663,"Dad, Chloe and I need to swing to"],[663,759,"Patrick's place."],[825,917,"Sure thing."],[955,1067,"And you two should hurry up"],[1067,1217,"and bring the kids back."],[1251,1438,"I'm grateful to Dr. Patrick, but..."],[1455,1522,"he can't just keep"],[1522,1655,"our grandkids forever!"],[1693,1889,"Mr. West, Patrick is not like that."],[1968,2072,"We'll go talk to him."],[2181,2252,"Alright then,"],[2293,2398,"you kids go ahead!"],[3036,3123,"Is Patrick home?"],[3144,3315,"Mr. Hale left a few days ago."],[3324,3432,"He said if you stopped by,"],[3432,3524,"I should give you this."],[4237,4404,"That's the check I gave to Patrick!"],[5188,5301,"Chloe, I'm in Europe."],[5372,5476,"The kids are with me."],[5501,5693,"I won't hand them over to Eason."],[5759,5864,"If you want the kids,"],[5872,5972,"come find me here!"],[6006,6097,"He's a jerk!"],[6135,6277,"Using our kids to threaten you!"],[6314,6448,"Chloe, you can't do what he says!"],[6510,6635,"What about our children!"],[6698,6815,"I can’t just abandon them."]],"86":[[20,200,"We're not going to abandon them."],[221,362,"Patrick kidnapped our kids"],[362,442,"to get to you."],[483,592,"If you go to Europe,"],[604,717,"he'll kidnap you too!"],[750,880,"Eason, he won't hurt me."],[959,1071,"You don't really know him."],[1071,1146,"I do."],[1230,1413,"I'll go to Europe and bring our kids back."],[1443,1539,"Let me go with you."],[1539,1614,"No way."],[1689,1822,"You stay here"],[1822,1943,"and wait for my call."],[2848,2923,"Patrick,"],[2965,3044,"Chloe always told me"],[3044,3144,"you were a good person."],[3253,3353,"You saved her,"],[3415,3516,"helped her a lot,"],[3516,3636,"even raised our kids."],[3670,3757,"I'm grateful for that."],[3849,3983,"You can name your price, and"],[4020,4158,"I'll do my best to meet it."],[4229,4275,"Do you know"],[4275,4429,"why she doesn't marry me?"],[4525,4688,"It's not because she doesn't love me."],[4825,5105,"It's because she's infertile."],[5351,5447,"She was afraid."],[5534,5689,"I'd regret it later,"],[5805,5935,"afraid that my parents"],[5935,6022,"wouldn't accept her."]],"87":[[175,287,"I don't want kids."],[412,538,"But you do, don't you?"],[671,829,"I can give the kids back,"],[875,988,"if you give me Chloe."],[1042,1146,"Do you think Chloe is some kind of"],[1146,1238,"bargaining chip?"],[1288,1426,"She chose to be with me."],[1480,1651,"Are you sure she chose you?"],[1780,1951,"You're as manipulative as me."],[2002,2156,"I didn't manipulate her!"],[2210,2335,"Patrick, you've been together for"],[2335,2398,"four years"],[2419,2523,"and didn't marry."],[2577,2644,"That means she never"],[2644,2752,"want to marry you!"],[2869,3190,"Her \"infertility\" is just a polite excuse."],[3253,3336,"So you think"],[3386,3507,"you can just pay me off"],[3507,3620,"and take the kids?"],[3666,3791,"It's just a compensation of"],[3791,3928,"appreciation for taking care of them"],[3928,4016,"all these years."],[4079,4229,"If we can't make an agreement,"],[4258,4462,"then there's nothing more to discuss."],[4533,4654,"The kids are happy with me."],[4779,4909,"Let me see them."],[4996,5075,"You can."],[5105,5234,"But you can't take them."],[5321,5467,"Let me see them, first."],[5734,5793,"Fine."]],"88":[[125,212,"Chloe,"],[212,283,"marry me."],[346,496,"Otherwise, Eason will never"],[496,571,"return home."],[734,809,"Patrick,"],[850,967,"please don't hurt him!"],[1071,1197,"I'm coming to Europe!"],[1659,1730,"Chloe,"],[1730,1872,"did you bring all your documents?"],[1960,2022,"Yes."],[2118,2214,"Is Eason okay?"],[2293,2385,"Don't worry."],[2402,2519,"I haven't harmed him."],[2590,2711,"Once we get married,"],[2711,2811,"I'll let him go."],[2915,2977,"Let's go."],[3232,3307,"Eason,"],[3386,3474,"I'm sorry."],[3561,3732,"I'm going to marry Patrick."],[3745,3941,"Only then can you and our kids safely"],[3941,4074,"return home."],[5492,5634,"What's going on?"]],"89":[[4,37,"Boss,"],[58,175,"Eason escaped with the kids!"],[212,333,"He had help, and they were armed."],[354,437,"We couldn't stop them."],[909,1026,"Is everything alright?"],[1209,1326,"Yeah, all is good."],[1418,1459,"Let's get our"],[1459,1555,"marriage license."],[1639,1776,"Patrick, I want to make sure that"],[1776,1876,"Eason is safe."],[1926,2035,"Can I video call him?"],[2085,2235,"But there's no reception"],[2235,2306,"at the villa."],[2331,2577,"Oh, so we can pass by before we go."],[2677,2794,"Chloe, trust me."],[2840,2915,"He's fine."],[2957,3082,"Once we get our marriage,"],[3178,3278,"I'll take him back to you."],[3315,3490,"This is a simple request, Patrick."],[3699,3883,"Are you afraid that Eason escaped?"],[4466,4562,"Chloe,"],[4562,4658,"I rescued the kids."],[4696,4796,"We're at the airport,"],[4796,4909,"about to board!"],[4929,5059,"Wait for us at home!"],[5146,5296,"Eason just texted me."],[5334,5509,"He's already left with the kids."],[5547,5689,"Why did you lie to me?"],[5780,5880,"Chloe,"],[5880,6039,"I'll give you everything!"],[6122,6289,"Please, don't leave me!"],[6556,6673,"I love Eason,"],[6710,6815,"Patrick."]],"90":[[892,1163,"Eason West, do you take Chloe Hartman"],[1163,1276,"to be your wife?"],[1330,1455,"Will you love her,"],[1505,1609,"comfort her,"],[1659,1805,"honor and keep her,"],[1860,2043,"in sickness and in health,"],[2064,2214,"for richer or poorer,"],[2281,2460,"and forsaking all others,"],[2510,2702,"be faithful to her"],[2702,2957,"as long as you both shall live?"],[3086,3207,"I do."],[3357,3482,"Chloe Hartman,"],[3482,3620,"do you take Eason West"],[3620,3770,"to be your husband?"],[3837,3983,"Will you love him,"],[4037,4158,"comfort him,"],[4212,4362,"honor and keep him,"],[4404,4642,"in sickness and in health,"],[4642,4788,"for richer or poorer,"],[4896,5084,"forsaking all others,"],[5134,5342,"be faithful to him"],[5342,5551,"as long as you both shall live?"],[5768,5876,"I do."]]}