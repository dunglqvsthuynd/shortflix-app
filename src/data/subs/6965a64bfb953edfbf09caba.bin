,"that presence…"],[429,591,"A big customer!"],[762,854,"Hi, beauty."],[920,995,"Want to buy a melon?"],[1037,1129,"Three bucks each."],[1170,1300,"You can haggle if you think it's pricey."],[1337,1450,"But if you don't know how to haggle,"],[1470,1533,"you don't have to."],[1570,1637,"I hope"],[1641,1812,"that everything you buy,"],[1816,1912,"you buy it because you like it,"],[1975,2229,"and not because it's cheap."],[2283,2362,"That b*stard."],[2375,2529,"I even gave him a child,"],[2533,2712,"yet he didn't even recognize me."],[2758,2983,"Wow, Papa is amazing!"],[3262,3325,"Papa!"],[3366,3454,"Hey, kiddo."],[3500,3612,"Are you talking to me?"],[3779,3814,"Pfft."],[3841,3920,"Jerk!"],[3941,3991,"This guy,"],[3995,4091,"he has a kid,"],[4129,4200,"yet he's still out here flirting."],[4204,4262,"Exactly."],[4266,4329,"Scumbag."],[4358,4454,"Kiddo,"],[4512,4587,"look closely."],[4600,4720,"I'm not your Papa."],[4737,4812,"Excuse me, beauty,"],[4829,4916,"you've got to tell the child"],[4920,5012,"to take a good look at her dad."],[5062,5208,"Otherwise, the misunderstanding"],[5212,5345,"would be so awkward, right?"],[5407,5473,"Hmph."],[5567,5736,"I brought my daughter here specifically"],[5770,5929,"to identify her father."],[5966,6020,"Huh?"],[6325,6420,"This melon of yours,"],[6425,6520,"is it guaranteed ripe?"],[6541,6725,"Beauty, what kind of question is that?"],[6754,6933,"Would I sell you a raw one?"],[7445,7583,"And if it's not ripe,"],[7600,7683,"then what?"],[7729,7837,"This broad"],[7841,7995,"is here to pick a fight."],[8779,8866,"Hey, beauty,"],[8879,8983,"let's talk this out."],[8995,9112,"Why don't you put the knife down first?"],[9533,9654,"If it's not ripe,"],[9691,9841,"can I chop you up?"],[9875,9970,"Holy sh*t!"],[9975,10062,"You are…"],[10362,10470,"I've been drugged."],[10556,10631,"Help me."],[10708,10812,"Beauty, calm down."],[10816,10908,"We don't know each other."],[10954,11050,"We'll soon enough."],[11170,11250,"That's right."],[11329,11408,"It's me."],[11508,11650,"Now that we've had a child,"],[11654,11808,"let me ask you one more time,"],[11847,11918,"do we know each other?"]],"4":[[87,262,"Whoa, beauty,"],[270,366,"let's talk nicely."],[370,479,"Just put the knife down."],[512,625,"What's left to talk about?"],[725,816,"Five years."],[858,1025,"I've been looking for you for five years."],[1083,1175,"Do you have any idea"],[1179,1308,"how I lived through those five years?"],[1325,1420,"So, for the last five years,"],[1425,1525,"she's been the one looking for me."],[1545,1720,"I thought it was my father."],[1787,1954,"I'll ask you one last time."],[2016,2116,"Speak!"],[2179,2466,"Do we know each other?"],[2487,2695,"Hahaha, we do."],[2720,2820,"Intimately."],[2845,3058,"We went at it so many times that night,"],[3062,3204,"how could we not be?"],[3441,3545,"Then come get a marriage license with me."],[3587,3704,"What marriage license?"],[3708,3804,"Just like that?"],[3900,4008,"Do you think I'm not good enough,"],[4108,4245,"or do you not want to claim your daughter?"],[4408,4483,"Huh?"],[4516,4616,"My daughter?"],[4683,4929,"Didn't we only do it that one time?"],[4970,5045,"Oh!"],[5162,5345,"Think carefully."],[5387,5533,"How many times?"],[5537,5595,"Oh,"],[5600,5695,"I remember now."],[5708,5920,"She's the CEO of the Sowle Group,"],[5925,6045,"Sarah Sowle."],[6050,6145,"What?"],[6158,6387,"A CEO of a multi-billion dollar group"],[6391,6545,"was abandoned by a heartless jerk"],[6550,6700,"for five years?"],[6704,6775,"This guy!"],[6779,6962,"He didn't just hook up with SG's CEO,"],[6966,7162,"he also got her to have his baby."],[7170,7316,"Why is he even selling melons?"],[7320,7533,"He should just kick back and be a kept man."],[7666,7720,"Daddy,"],[7725,7925,"please don't leave Mommy and me behind,"],[7929,8020,"okay?"],[8050,8191,"Evie doesn't want to be without a daddy."],[8212,8362,"If Daddy comes home,"],[8366,8612,"Evie will be very, very good."],[9020,9204,"Daddy, can you stay with me?"],[9208,9387,"I'll be a good, good girl."],[10862,10912,"Okay."],[10941,11012,"Evie,"],[11016,11083,"from now on,"],[11087,11212,"Daddy will never leave you two again."],[11458,11579,"That's wonderful!"],[11583,11875,"I'll give Daddy a present when we get home."],[11895,12012,"Alright, sweetie."],[12016,12233,"Daddy will cut some watermelon for you, okay?"],[12583,12666,"Don't!"]],"5":[[0,87,"Don't!"],[487,591,"Evie can't walk."],[1312,1437,"What's going on?"],[1441,1600,"Why is Evie like this?"],[1695,1841,"Daddy, it's okay."],[1850,2158,"Even though I can't walk like other kids,"],[2162,2241,"Mommy carries me"],[2245,2387,"all the time."],[2391,2625,"You will carry me too from now on, right?"],[2875,2950,"Right."],[3070,3162,"Mommy, Daddy,"],[3166,3304,"you don't need to be sad."],[3308,3487,"As long as I can be with you,"],[3491,3666,"Evie is happy."],[4398,4475,"Slow down."],[4491,4541,"Mhm."],[5033,5112,"Honey,"],[5150,5312,"your house is huge."],[5358,5504,"If I knew I could live off you,"],[5508,5625,"why'd I have bothered selling melons?"],[5629,5704,"Psh."],[6233,6320,"Mr. Cox,"],[6429,6587,"it's been five years."],[6695,6883,"Don't you think you should do something?"],[6950,7008,"Huh?"],[7229,7366,"Don't \"huh\" me."],[7470,7608,"I'm waiting for your answer."],[7629,7750,"Seriously?"],[7770,8033,"Hot to trot as soon as we reunite?"],[8395,8591,"Honey, why don't we wait until tonight?"],[8708,8820,"You pervert!"],[8825,8962,"What are you thinking?"],[9070,9170,"I wanted to ask you"],[9191,9350,"to start taking care of Evie."],[9370,9512,"SG has a new drug"],[9516,9625,"that has reached a critical stage."],[9658,9791,"I can't get away,"],[9845,10025,"so I need you to help look after Evie."],[10070,10212,"It's just a lousy product."],[10233,10362,"How is that more important than being with Evie?"],[10429,10545,"That drug"],[10550,10741,"is the only hope for curing Evie."],[10850,10945,"What exactly is wrong with Evie?"],[11079,11166,"Evie has…"],[11570,11629,"Daddy,"],[11633,11829,"this is a present for you."],[11854,11950,"Do you like it?"]],"6":[[1170,1270,"Thank you, Evie."],[1316,1408,"Daddy loves it."],[1883,1929,"Ms. Sowle,"],[1958,2087,"Dr. Gray has arrived in Hayville."],[2116,2212,"What?"],[2241,2341,"Dr. Gray?"],[2395,2475,"Dr. Gray"],[2500,2541,"That old geezer,"],[2545,2675,"when did he get to Hayville?"],[2687,2837,"Okay, I'll be right there."],[2970,3016,"Ethan,"],[3045,3166,"I need to take Evie out."],[3212,3275,"Where are you going?"],[3279,3345,"I'll go with you."],[3350,3545,"You'd better not go today."],[3570,3712,"Dr. Gray is eccentric."],[3733,3916,"With you dressed like that,"],[3941,4066,"you better not meet him."],[4104,4225,"It would be even worse"],[4262,4354,"if you say the wrong thing."],[4383,4420,"Honey,"],[4425,4554,"actually, Gordon and I…"],[4558,4683,"Alright, enough, there's no time."],[4687,4804,"We'll talk details when I get back."],[4808,4841,"Uh…"],[4887,4995,"Uh, wait."],[5129,5208,"Hey."],[5458,5568,"Call me if anything comes up."],[5700,5900,"Daddy, I want one, too."],[6037,6133,"Okay."],[6695,6775,"Bye."],[6983,7116,"Let's go."],[9404,9695,"- Dragon Lord! - Dragon Lord!"],[10145,10212,"Boss,"],[10216,10358,"what are you doing here?"],[10404,10508,"This is my wife's home."],[10516,10616,"Where else would I be?"],[10634,10712,"- What? - What?"],[10758,10825,"Boss,"],[10845,11000,"when did you get married?"],[11016,11100,"Yeah, Boss."],[11137,11212,"You got married,"],[11216,11354,"and didn't even tell us?"],[11379,11437,"The boys wanted"],[11441,11554,"to give you a wedding gift!"],[11575,11650,"Get lost."],[11691,11800,"Like you actually want to give a gift!"],[11900,12025,"You just want to crash my wedding night!"],[12054,12145,"(Laughs)"],[12150,12225,"Man,"],[12233,12391,"if those foreign Princesses"],[12395,12495,"and noble ladies"],[12500,12637,"knew you got married,"],[12662,12791,"they'd be heartbroken."],[12862,12950,"Cut the crap."],[13108,13200,"I have serious business for you."],[13300,13470,"Take this for a paternity test."],[13545,13658,"Also, investigate my wife."],[13720,13787,"- Yes, sir. - Yes, sir."],[13791,13929,"If all of this is true,"],[13975,14141,"I'll give everything I have"],[14145,14291,"to make it up to both of them."]],"7":[[387,508,"Why are you here?"],[725,820,"Where is Dr. Gray?"],[837,975,"If we hadn't used Dr. Gray to trick you,"],[979,1158,"would you have come here willingly?"],[1620,1720,"What do you want?"],[1725,1820,"You little sl*t."],[1825,2016,"Five years ago, you slept around,"],[2020,2137,"got pregnant out of wedlock,"],[2150,2291,"and offended the Lane family."],[2308,2520,"If you weren't making money for the Sowle family,"],[2525,2629,"we'd have kicked you out long ago!"],[2633,2841,"Now, for this little b*stard,"],[2845,2970,"you want to drain the company's funds"],[2975,3108,"on your research projects."],[3112,3154,"Bah!"],[3162,3358,"Evie isn't a b*stard."],[3362,3570,"Evie has a dad now."],[3616,3691,"Pfft!"],[3729,3950,"You've been a burden since day one."],[3954,4179,"Why else would you have a strange illness"],[4191,4404,"and be in a wheelchair since childhood?"],[4458,4591,"No,"],[4595,4825,"I'm not a burden!"],[5008,5095,"It's okay, Evie."],[5100,5258,"Mommy is here."],[5612,5750,"Evie is just a child."],[5775,5933,"How can you talk to her like that?"],[5937,6095,"So what? I'll talk to her however I want!"],[6112,6275,"You shameless woman."],[6287,6375,"Let me tell you something."],[6379,6508,"We brought you here today"],[6516,6729,"to sleep with Leonard."],[6854,6962,"What?"],[6966,7191,"Don't you like children?"],[7195,7400,"Then you and Leonard can just have one."],[7425,7520,"Once that happens,"],[7554,7737,"and you become Mrs. Lane,"],[7754,8045,"our family will rise right along with you."],[8050,8116,"Oh, right."],[8162,8320,"Your shares in the Sowle Group"],[8325,8429,"will belong to me then."],[8441,8512,"And that"],[8516,8612,"lousy special drug project,"],[8616,8758,"I'll sell the whole thing off"],[8762,8908,"so you can stop obsessing over it."],[8912,9029,"Hahaha!"],[9166,9250,"You!"],[9650,9766,"Let me go!"],[9770,9912,"What are you doing?"],[10220,10325,"Nothing."],[10337,10516,"Just feeding you this,"],[10520,10804,"get you ready to sleep with Leonard."],[11029,11133,"I'm not drinking that!"],[11137,11345,"You don't have a choice."],[11358,11466,"You little b*tch."],[11470,11629,"Letting you sleep with Leonard"],[11633,11716,"is for your own good."],[11720,11841,"Don't be so ungrateful!"],[11933,12204,"You're drinking this,"],[12212,12379,"whether you like it or not!"]],"8":[[8,175,"Don't bully my mommy!"],[179,400,"My daddy won't let you get away with this!"],[404,487,"Hahaha!"],[508,641,"That's hilarious."],[645,866,"Tell your daddy to come here, then."],[883,1025,"He can watch"],[1029,1120,"his wife"],[1125,1316,"sleeping with Leonard."],[1320,1429,"What are you waiting for?"],[1454,1608,"Get that annoying brat under control!"],[1654,1812,"Don't touch my mommy!"],[1916,2037,"Mommy!"],[2070,2145,"No!"],[2300,2412,"Let go of my daughter!"],[2433,2570,"If you have a problem, come at me."],[2591,2729,"Leave my daughter out of this!"],[2783,2841,"Since"],[2854,3020,"you're so worried about your daughter,"],[3025,3150,"why don't you drink this,"],[3170,3258,"be a good girl,"],[3262,3437,"and go sleep with Leonard?"],[3470,3575,"Otherwise,"],[3579,3712,"I can't guarantee"],[3716,3816,"what might happen."],[3820,3929,"You people…"],[3933,4075,"You'll pay for this!"],[4245,4420,"Mommy!"],[4445,4766,"- Evie! - Mommy!"],[4945,5087,"Evie!"],[6004,6066,"Evie!"],[6258,6383,"Ah!"],[6433,6500,"Evie!"],[6650,6712,"Evie!"],[6758,6858,"Are you okay?"],[6887,7012,"Are you hurt?"],[7254,7370,"Don't you people"],[7395,7583,"have any conscience?"],[7637,7837,"She couldn't stand up on her own."],[7841,8000,"None of our d*mn business."],[8016,8125,"Hahaha."],[8537,8712,"Evie,"],[8716,8850,"does your heart hurt?"],[8862,8987,"Mommy."],[9666,9795,"I beg you,"],[9812,9991,"please get my daughter to a hospital!"],[10016,10137,"Her heart condition is acting up."],[10141,10312,"It'd be too late!"],[10354,10491,"She's only five years old."],[10516,10729,"And she only just found her father."],[10875,11204,"I'm begging you!"],[11625,11812,"Heart acting up, huh?"],[11837,11983,"Drink this first,"],[12062,12179,"and we'll consider"],[12195,12320,"whether to take her to a hospital or not."],[14082,14154,"Evie."],[14154,14229,"I want"],[14233,14291,"Daddy"],[14325,14387,"to come"],[14454,14508,"protect us."],[14512,14541,"Now,"],[14545,14708,"can you take my daughter to the hospital?"],[14775,14883,"Whoa, whoa, whoa."],[14912,15129,"Wait until you've slept with Leonard."],[15400,15612,"If anything happens to Evie,"],[15645,15850,"I'll haunt you from the grave!"],[16062,16233,"You'd better just think about"],[16254,16487,"how to keep Leonard happy."],[16675,16787,"Evie."],[16925,17104,"Evie!"],[17166,17245,"Evie!"],[17425,17508,"Daddy."]],"9":[[562,612,"Boss,"],[662,795,"the paternity test results are in."],[808,912,"Evie is your daughter."],[1045,1225,"Evie really is my daughter."],[1250,1308,"Boss,"],[1350,1441,"we investigated Ms. Sowle's background."],[1445,1512,"We found that"],[1516,1650,"she's had a hard life these past few years."],[1670,1779,"These are"],[1783,1870,"the video diaries"],[1875,2037,"she kept over the years."],[2083,2183,"We retrieved them for you."],[2650,2712,"Sweetheart."],[2716,2837,"Mommy is finally meeting you."],[2858,3033,"Although Daddy isn't here with us,"],[3037,3270,"I will use all my love"],[3275,3345,"to care for you."],[3350,3633,"You are Mommy's little angel."],[3666,3750,"Sweetheart,"],[3754,4012,"today is your first birthday."],[4037,4270,"The doctor says you have a genetic mutation"],[4279,4475,"and diagnosed you with a heart condition."],[4483,4587,"But don't be afraid."],[4616,4837,"Mommy will cure you."],[4845,5008,"I promise."],[5050,5195,"I'm sorry, sweetheart."],[5200,5366,"Mommy failed to protect you."],[5387,5512,"You fell from upstairs"],[5516,5654,"while looking for Daddy,"],[5658,5829,"and it broke Mommy's heart."],[5833,5916,"The doctor said"],[5929,6037,"only Dr. Gray can"],[6041,6150,"heal your legs."],[6170,6333,"I'll find Dr. Gray"],[6350,6512,"and help you walk again."],[6516,6591,"Also,"],[6612,6737,"the genetic mutation treatment"],[6741,6916,"I developed is ready."],[6979,7166,"I named it Evie Care."],[7170,7320,"I hope my Evie"],[7345,7591,"will always be healthy."],[7608,7741,"If it weren't for me,"],[7754,7933,"they wouldn't be so helpless."],[7937,8016,"I swear,"],[8025,8187,"I will give everything I have"],[8191,8262,"to make it up to them"],[8266,8366,"and protect them."],[9029,9175,"Hello, Evie?"],[9195,9258,"Did you miss Daddy?"],[9283,9370,"Daddy."],[9400,9658,"Bad guys are hurting"],[9737,9912,"Mommy and me."],[9916,10110,"- Evie! - Please, save my daughter!"],[10110,10329,"- Evie! - Please!"],[10537,10679,"Thunder, Blaze!"],[10720,10804,"Find my wife and daughter"],[10808,10912,"immediately!"]],"10":[[50,158,"Don't"],[162,279,"hurt"],[304,412,"my mommy."],[512,600,"My daddy"],[625,675,"is coming."],[783,879,"He'll be here!"],[908,1104,"Still dreaming about that lousy dad of yours?"],[1108,1195,"Look at you two."],[1200,1262,"A slut,"],[1275,1358,"and a burden."],[1375,1533,"So what if that b*stard shows up?"],[1554,1758,"I bet he's nothing but a lowlife punk."],[1762,1850,"When he gets here,"],[1862,2012,"the three of you"],[2016,2229,"can all die together."],[2312,2383,"Fiona,"],[2400,2466,"Mike,"],[2491,2654,"you will rot in hell!"],[2954,3129,"Mommy,"],[3158,3329,"it's all my fault."],[3333,3533,"I'm just a burden to you."],[3550,3883,"I just want to be healthy"],[3887,4283,"and be a good daughter to you and Daddy."],[4300,4337,"No,"],[4381,4470,"Evie,"],[4533,4712,"you're not a burden."],[4812,5016,"It's me who didn't take good care of you."],[5366,5462,"Please,"],[5466,5562,"save my daughter!"],[5579,5712,"I'm begging you!"],[6179,6258,"Who the f**k is that?"],[6262,6345,"Crying and wailing!"],[6362,6508,"I could hear it from a mile away."],[6520,6662,"Oh, Leonard,"],[6666,6758,"you're here."],[6850,6937,"Cut the cr*p."],[6941,7070,"I just got back from overseas."],[7112,7266,"How are the arrangements?"],[7304,7337,"Leonard,"],[7383,7454,"she's right inside."],[7487,7658,"Go enjoy your wedding night."],[7720,7854,"The most beautiful woman in Hayville."],[7891,8016,"If she doesn't submit to me today,"],[8020,8191,"I'll break her until she does."],[8800,8875,"Don't touch me."],[8966,9083,"Sarah!"],[9108,9212,"I'm warning you."],[9254,9475,"If you don't want that little b*stard outside"],[9479,9537,"to suffer,"],[9554,9762,"just be good and sleep with Leonard!"],[9783,9845,"Otherwise,"],[9887,10062,"neither of you will get off easy!"],[10229,10341,"Stop pretending."],[10362,10491,"What a buzzkill."],[10500,10679,"Looks like I need to teach you a lesson!"],[11712,11870,"You have a death wish!"]],"11":[[300,392,"Go to hell!"],[480,560,"Evie."],[928,1072,"Don't be afraid, Evie."],[1072,1160,"Daddy's here."],[1260,1344,"Daddy."],[1420,1672,"Please save Mommy."],[1968,2096,"Quick, take her to the hospital."],[2096,2152,"Hurry!"],[2212,2340,"Who the f*ck are you?"],[2348,2448,"Stop them!"],[3468,3568,"Don't be afraid."],[3612,3692,"No!"],[3744,3904,"I'll be very gentle."],[3952,4104,"No, I have a husband!"],[4128,4236,"Don't touch me!"],[4816,4896,"Stop!"]],"12":[[244,312,"No!"],[312,392,"Let me go!"],[392,596,"I have a husband! Don't touch me!"],[596,676,"Honey, look at me."],[676,756,"It's me, Ethan."],[776,884,"Get up and look at me."],[1004,1104,"Just look at me."],[1372,1492,"- Ethan? - I'm sorry."],[1552,1688,"I'm sorry, honey. I'm late."],[1976,2072,"Where's Evie?"],[2072,2192,"Go save Evie!"],[2196,2368,"She's having a heart attack!"],[2376,2472,"Don't worry, honey."],[2484,2572,"I've already had someone take Evie"],[2572,2652,"to the hospital."],[2652,2692,"She'll be fine."],[3412,3644,"You punk, do you know who I am?"],[3644,3784,"How dare you ruin my plans!"],[3784,3880,"I don't care who you are."],[3880,4036,"Anyone who hurts my wife and daughter"],[4036,4124,"will pay the price!"],[4164,4268,"In all these years,"],[4284,4452,"he is the first man to shield me"],[4452,4568,"and protect me."],[4592,4752,"I thought you were some big fish."],[4752,4872,"Turns out you're just some hookup"],[4872,5012,"this b*tch picked up."],[5112,5232,"He's not a hookup."],[5292,5424,"He is my husband!"],[5424,5504,"Shut your mouth,"],[5504,5568,"you b*tch!"],[5868,6044,"I dare you to insult my wife one more time."],[6080,6236,"She's just a b—"],[6504,6620,"Outrageous!"],[6624,6704,"Guards!"],[6704,6840,"Seize this punk!"],[6856,6984,"Beat him to death!"]],"13":[[640,748,"That's my husband."],[836,900,"He's amazing."],[960,1040,"You…"],[1060,1164,"What do you want?"],[1200,1292,"I'm warning you,"],[1300,1440,"I'm the heir to the Lane Group!"],[1440,1560,"If you mess with me,"],[1572,1708,"there'll be hell to pay!"],[1724,1812,"That's right!"],[1856,1980,"No one messes with Leonard"],[2012,2100,"and lives to see"],[2100,2188,"the sun rise the next day!"],[2588,2840,"Like I said, no matter who it is,"],[2840,3024,"if you hurt my wife and daughter,"],[3048,3160,"you will pay the price!"],[3220,3440,"You talk a big game, kid."],[3472,3608,"Do you really think Leonard is someone"],[3608,3760,"you can just mess with?"],[4524,4608,"Scorpion,"],[4608,4792,"this punk ruined my night."],[4792,4900,"Cripple him immediately!"],[4900,4972,"That's right!"],[4996,5124,"He even hit Leonard just now."],[5140,5256,"You punk,"],[5288,5560,"now that Scorpion is here, you're dead."],[5580,5680,"What?"],[5680,5912,"The Lane family retainer, Scorpion?"],[5944,6024,"Exactly."],[6104,6204,"Scorpion is one of the top three"],[6204,6340,"masters in Hayville."],[6360,6532,"His power is unfathomable."],[6532,6656,"Listen, punk."],[6692,6860,"You might have a few moves,"],[6872,7012,"but in front of Scorpion,"],[7032,7140,"you're absolutely nothing!"],[7552,7648,"Scorpion,"],[7692,7756,"everything that happened today"],[7756,7872,"started because of me."],[7912,8032,"It has nothing to do with my husband."],[8076,8208,"Please, don't hurt him."],[8208,8408,"Too late to beg for mercy."],[8464,8712,"Today, I'm not only going to cripple him,"],[8712,8864,"but I'll also make him watch"],[8864,9004,"as I take you to bed!"],[9156,9236,"Honey,"],[9304,9424,"don't beg that old b*stard."],[9504,9592,"He can't touch me."],[9644,9736,"How dare you!"],[9776,9944,"You d*mn punk,"],[9952,10084,"who do you think you are,"],[10136,10324,"saying Scorpion can't touch you?"],[10332,10484,"Do you know how powerful Scorpion is?"],[10516,10724,"He could kill you with a single finger!"],[10772,10924,"Disrespecting Scorpion"],[10932,11184,"leads only to death!"],[11352,11428,"Ethan,"],[11452,11564,"Scorpion is extremely powerful."],[11564,11652,"You're no match for him."],[11652,11732,"Run, quickly!"],[11828,11992,"If I don't make it back today,"],[12204,12336,"please take good care of Evie."],[12396,12560,"Honey, there is no one in this world"],[12560,12640,"that your husband"],[12640,12728,"cannot handle."],[12760,12836,"As long as I'm here,"],[12872,12944,"no one can"],[12944,13076,"touch you or Evie."],[13076,13164,"Kid,"],[13196,13432,"you've successfully angered me."],[13448,13528,"However,"],[13564,13796,"I'll give you one chance."],[13812,13952,"Cut off one of your arms"],[13952,14116,"and obediently let your wife"],[14116,14272,"sleep with Leonard!"],[14320,14568,"Or catch the consequences!"]],"14":[[60,248,"Then I'll give you a chance, too."],[280,412,"Cut off both your arms,"],[412,468,"kneel down,"],[468,588,"and apologize to my wife."],[640,764,"Otherwise,"],[824,936,"you die!"],[992,1112,"Arrogant!"],[1848,1964,"Watch out!"],[1988,2092,"Get lost!"],[2320,2488,"You... who are you?"],[2492,2632,"Hmph, old b*stard."],[2672,2780,"I gave you a chance, but you just ignored it."],[2972,3104,"Ah! No, no, don't! Don't!"],[3136,3208,"I give up!"],[3276,3348,"I surrender!"],[3352,3468,"I'll cut off my arms!"],[3904,4020,"I'm sorry, Ms. Sowle!"],[4136,4232,"It was all my fault."],[4292,4404,"Please, just pretend I'm nothing"],[4404,4508,"and let me go!"],[4620,4804,"What do you say, Honey?"],[4832,4992,"If you can't stand the sight of this b*stard,"],[5048,5164,"I'll cripple him right now."],[5180,5284,"Forget it."],[5360,5512,"He's just a servant of the Lane family."],[5592,5672,"Let him get lost."],[5704,5784,"Did you hear that?"],[5812,5892,"Get lost!"],[5932,5996,"Scorpion,"],[5996,6152,"what am I supposed to do if you leave?"],[6192,6328,"Screw you!"],[6372,6544,"You've been so domineering for years,"],[6544,6640,"committing all sorts of crimes."],[6640,6804,"I've had enough of you!"],[6812,6980,"To hell with being a servant of the Lane family,"],[6980,7144,"I quit!"],[7488,7572,"Let me tell you,"],[7572,7768,"don't think just because you're tough that I…"],[7992,8168,"I'll call you Godfather, okay?"],[8180,8260,"Godfather,"],[8320,8492,"I really didn't know anything."],[8500,8628,"I didn't even lay a finger"],[8628,8752,"on her just now!"],[8788,8868,"It was all them!"],[8868,9100,"They said there was a good deal."],[9112,9180,"As soon as I walked in,"],[9188,9364,"I saw them harassing her!"],[9376,9572,"I really didn't know anything!"],[9848,10012,"Sarah, I messed up!"],[10052,10208,"Please forgive me, Sarah!"],[10304,10380,"Sis,"],[10420,10584,"I'm your brother!"],[10592,10704,"Sis, I know I was wrong!"],[10872,10988,"Don't call me that!"],[11092,11228,"I used to think of you as my"],[11228,11280,"stepmother"],[11336,11424,"and brother,"],[11532,11724,"but look at how you treated me."],[11888,11968,"From now on,"],[12124,12308,"I never want to see you again."],[12340,12464,"You may be spared death,"],[12484,12576,"but you cannot escape punishment."]],"15":[[512,592,"Now get lost!"],[1284,1644,"What did you just do to them?"],[1672,1768,"I just gave them a little"],[1768,1896,"punishment, that's all."],[2052,2160,"It's the Mid-Venom Strike."],[2236,2288,"Those struck by it"],[2288,2412,"will suffer the agony of a thousand bites"],[2460,2568,"every single day"],[2592,2676,"at midnight and noon."],[2720,2844,"Unless the energy is removed."],[2908,3104,"But those in this world who can remove it"],[3152,3260,"can be counted on one hand."],[3424,3552,"How come I never noticed"],[3552,3684,"that you were so powerful before?"],[3752,3956,"You even scared Scorpion off."],[4020,4184,"Evie is already this big,"],[4184,4340,"and you're just realizing now?"],[4340,4424,"Get out of here."],[4424,4592,"You have the nerve to say that?"],[4676,4856,"You abandoned us for five years"],[4884,5044,"without a single care."],[5144,5224,"Honey,"],[5252,5340,"I promise that from now on,"],[5340,5484,"I'll make it up to you and Evie."],[5556,5760,"I also know about Evie's condition."],[5792,5868,"I promise you,"],[5868,5968,"that I will find a way"],[5968,6072,"to cure Evie completely."],[6152,6296,"How can you promise that?"],[6364,6492,"With Evie's condition,"],[6552,6728,"only the special drug I'm developing"],[6728,6852,"might be able to cure her."],[6916,7008,"For now,"],[7028,7196,"just focus on taking good care of Evie."],[7204,7284,"That is the only way"],[7284,7436,"I'll have the time and energy"],[7444,7604,"to complete the Evie Care Project."],[7704,7816,"Don't worry, honey."],[7824,7916,"Leave taking care of Evie"],[7916,8056,"entirely to me."],[8120,8188,"I will fulfill my duties"],[8188,8292,"as a father."],[8344,8408,"And of course,"],[8432,8564,"I'll also fulfill my duties"],[8564,8672,"as a husband."],[8812,8896,"In your dreams."],[9254,9296,"Hey, honey."],[9296,9376,"What's wrong?"],[9496,9672,"They drugged me."],[9792,9904,"I've been drugged."],[10000,10092,"Help me."],[10476,10556,"Honey,"],[10592,10692,"let me help you!"]],"16":[[600,671,"Boss,"],[671,763,"we've taken your daughter"],[763,823,"to the hospital."],[823,903,"But…"],[1144,1215,"What happened to Evie?"],[1232,1319,"It's hard to explain"],[1319,1396,"over the phone."],[1423,1459,"You should just"],[1459,1548,"come to the hospital."],[1707,1803,"- Let's go. - Let's go."],[2200,2296,"Your two friends"],[2296,2407,"really know how to keep people in suspense."],[2432,2659,"They almost scared me to death earlier."],[2659,2728,"When we get back,"],[2751,2848,"I'll teach them a lesson."],[2988,3096,"If it weren't for Thunder,"],[3111,3219,"I'd have helped my wife out at the hotel."],[3251,3367,"We wouldn't need the hospital for an antidote."],[3384,3463,"Mommy,"],[3471,3623,"Daddy saved us today."],[3648,3836,"How are you going to reward him?"],[3876,4003,"I need to give him a reward?"],[4023,4123,"Of course."],[4136,4251,"Didn't you say"],[4251,4363,"that if we do the right thing,"],[4384,4519,"we get a reward?"],[4540,4644,"So, Evie,"],[4655,4759,"what reward are you"],[4759,4919,"giving Daddy?"],[5388,5448,"Evie,"],[5467,5572,"you are Daddy's"],[5572,5680,"sweetest little angel."],[6944,7011,"Honey,"],[7011,7096,"is this the reward"],[7096,7163,"you're giving me?"],[7200,7300,"What else?"],[7315,7455,"I'm not short on cash."],[7467,7544,"I don't want this reward."],[7544,7651,"From now on,"],[7651,7792,"you need to focus on Evie."],[7811,7919,"How can you do that without money?"],[7959,8084,"I have money."],[8084,8207,"All those years,"],[8215,8323,"you were a designated driver"],[8323,8455,"and a fruit vendor."],[8480,8559,"How much money could you possibly have?"],[8600,8692,"Should I tell her"],[8703,8780,"that seventy percent"],[8780,8896,"of the global economy"],[8896,9000,"is in my hands?"],[9007,9107,"There is"],[9107,9255,"five million in this card."],[9503,9651,"Five years ago, ten thousand"],[9651,9767,"gave me quite the workout."],[9792,9851,"With five million,"],[9900,9988,"we'd be flying high, wouldn't we?"],[10166,10215,"Pfft!"],[10259,10303,"Who wants to do that with you?"],[10507,10580,"Let's go home."],[10619,10696,"Evie,"],[10696,10771,"we're going home."],[10771,10828,"Okay."],[10919,11023,"Your daughter had a close call,"],[11023,11151,"but she's out of danger."],[11163,11248,"However,"],[11248,11380,"our examination shows that"],[11380,11536,"her genetic mutation symptoms"],[11540,11648,"will start to deteriorate"],[11651,11776,"in at most a month."],[11800,11911,"You two need to"],[11911,12051,"prepare for the worst."],[12071,12123,"Evie."],[12123,12244,"Mommy promises to finish"],[12244,12399,"the Evie Care Project within a month"],[12408,12500,"and cure you."],[12511,12576,"Evie,"],[12580,12723,"Daddy will use the world's top"],[12723,12792,"medical resources"],[12792,12907,"to make you healthy again."]],"17":[[140,196,"Evie."],[196,371,"I'm coming to catch you!"],[736,923,"Gotcha, Evie!"],[1511,1576,"Ethan,"],[1592,1707,"take a good look."],[1707,1859,"Is that your daughter you caught?"],[2011,2123,"Oops!"],[2128,2248,"Honey, I was trying to catch our daughter."],[2248,2388,"Why did you get in the way?"],[2388,2536,"Get in the way, my foot!"],[2611,2719,"Go on, get out."],[2719,2807,"I need to put her to sleep."],[2811,2892,"Okay, going, going."],[2907,2951,"Evie,"],[3036,3096,"goodnight."],[3096,3211,"Goodnight, Daddy."],[4359,4440,"Get your *ss out here."],[4826,4988,"You idiot."],[4988,5032,"You almost scared"],[5032,5088,"my wife to death."],[5088,5128,"Do you know that?"],[5148,5211,"Boss, calm down."],[5211,5300,"I'll beat him up for you."],[5396,5425,"Boss,"],[5427,5534,"I was wrong."],[5615,5696,"- That's enough. - I'm sorry."],[5696,5792,"Drop the act."],[5915,5963,"How is the task I gave you two"],[5963,6040,"coming along?"],[6055,6096,"Boss,"],[6107,6240,"we've acquired all"],[6240,6307,"of the world's top ten"],[6307,6400,"medical research institutes."],[6407,6532,"Dr. Gray has also left the mountain."],[6544,6667,"He is expected to arrive in Hayville"],[6667,6784,"by the day after tomorrow at the latest."],[6788,6900,"Spare no expense"],[6907,6967,"to help my wife"],[6967,7067,"complete the Evie Care Project,"],[7084,7148,"and work with her"],[7148,7248,"to treat my daughter."],[7271,7308,"- Yes, sir. - Yes, sir."],[7367,7427,"By the way, Boss,"],[7451,7523,"your father"],[7523,7584,"has already tracked down"],[7584,7632,"your whereabouts."],[7640,7728,"He even knows"],[7728,7848,"about your wife and daughter."],[7848,7932,"We couldn't hide it anymore."],[7944,8011,"Mr. Smith"],[8011,8119,"will arrive in Hayville tonight."],[8371,8471,"When I was alone before,"],[8471,8580,"that old geezer didn't come for me."],[8640,8671,"Now that I have"],[8671,8767,"a wife and daughter,"],[8788,8963,"being found was only a matter of time."],[9003,9059,"But…"],[9063,9192,"So what if he finds me?"],[9236,9340,"We're just worried that Mr. Smith,"],[9340,9451,"will target your wife and daughter"],[9488,9700,"just to force you back to the Smith Clan."],[9755,9840,"That old geezer wouldn't dare."]],"18":[[620,700,"Mr. Smith."],[700,832,"We've found Young Master."],[983,1067,"I knew he couldn't escape"],[1067,1164,"the palm of my hand."],[1164,1235,"I just didn't expect"],[1235,1340,"that brat to hold a grudge against me"],[1340,1491,"for ten whole years."],[1511,1612,"Mr. Smith,"],[1612,1664,"I was able to"],[1664,1819,"track down Young Master"],[1819,1944,"only because he now"],[1944,2076,"has a wife and a daughter."],[2116,2192,"What?"],[2192,2276,"You're saying that brat"],[2276,2416,"has a wife and daughter now?"],[2416,2519,"Yes, sir."],[2519,2667,"The intel is absolutely solid."],[2783,2867,"That's wonderful!"],[2867,3019,"That means I'm a grandfather!"],[3196,3228,"Listen."],[3228,3275,"Wilson."],[3275,3384,"Go make preparations immediately."],[3384,3524,"We're going to Hayville tomorrow."],[3524,3632,"I'm going to acknowledge"],[3647,3779,"my granddaughter at the charity gala."],[3779,3864,"Also, don't forget"],[3864,4020,"to prepare plenty of gifts for her."],[4020,4084,"Yes, sir."],[4967,5111,"D*mn it!"],[5111,5360,"What the hell is going on?"],[6108,6165,"F**k."],[6203,6324,"Did you two feel that pain just now?"],[6324,6431,"Hey, Leonard,"],[6471,6587,"you too?"],[6668,6720,"I know who it was."],[6771,6935,"It must be that little punk."],[7104,7271,"He used a dirty trick on us!"],[7351,7484,"I'll give you three days."],[7531,7656,"Get that b*tch Sarah"],[7656,7784,"to sleep with me willingly,"],[7784,7864,"or else"],[7904,7971,"the Sowle Group"],[7971,8123,"can just wait to go bankrupt!"],[8831,8971,"Sarah,"],[9112,9231,"you forced me into this!"],[9320,9384,"Mom,"],[9448,9535,"do you have a plan?"],[9640,9848,"That little b*tch Sarah"],[9892,10087,"has been trying to develop a cure"],[10143,10271,"for her daughter."],[10368,10456,"If we get the other shareholders"],[10456,10676,"to join us"],[10676,10807,"and withdraw their capital overnight,"],[10848,11040,"I'd like to see how she continues research!"],[11123,11200,"Good."],[11328,11415,"When that happens,"],[11415,11592,"she'll surely come crawling back"],[11592,11707,"to beg us!"],[12612,12684,"Honey,"],[12684,12779,"it's time for bed."],[12808,12952,"We only have one month left."],[12984,13063,"I have to finalize"],[13063,13187,"the drug proposal."],[13900,13959,"Hello?"],[14087,14147,"What?"],[14252,14391,"A mass withdrawal of capital?"],[14763,14847,"Honey, what's wrong?"],[15059,15191,"Fiona and Mike"],[15191,15303,"have united with other shareholders"],[15303,15491,"to force a divestment."],[15491,15628,"The Lane family also put out the word"],[15628,15812,"blocking any company from working with me."],[15852,16047,"Without funds or partners,"],[16047,16147,"the Evie Care Project"],[16147,16291,"will be impossible to complete."],[16352,16508,"Honey, I thought it was something serious."],[16536,16603,"Don't worry,"],[16603,16740,"I'll take care of this for you."],[16875,16984,"You can?"],[17036,17263,"Do you think you're the richest man in the country?"],[17275,17412,"I'm not the richest man in the country."],[17419,17563,"I'm the richest man in the world."],[17640,17728,"Honey, actually I'm…"],[17728,17796,"Enough."],[17796,17915,"Stop messing with me."],[17915,18031,"Tomorrow,"],[18047,18231,"the country's richest man, Mr. William Smith,"],[18231,18412,"will host a charity gala."],[18412,18496,"Right now,"],[18519,18587,"the only solution"],[18612,18787,"is to partner with him."]],"19":[[64,184,"Evie, watch Daddy."],[184,420,"A big watermelon,"],[420,575,"cut in two."],[575,724,"One piece for Mommy,"],[724,824,"and one piece"],[900,1083,"for Evie."],[1100,1208,"Wow."],[1208,1275,"Daddy,"],[1275,1508,"you really know your stuff!"],[1700,1819,"Back in the day,"],[1819,2023,"when I was on Mount Owl,"],[2044,2303,"an evil dragon came out to cause chaos."],[2364,2451,"I"],[2451,2583,"tamed it completely"],[2583,2692,"with just one move."],[2692,2812,"Wow!"],[2812,2996,"I really want to see that!"],[3144,3224,"Watch closely."],[4056,4152,"Look here, Evie."],[4152,4252,"Wow!"],[4252,4335,"Daddy,"],[4335,4532,"you're amazing!"],[4564,4652,"Not bad, right?"],[4784,4867,"Mommy's here."],[5115,5224,"What are you holding in your hand?"],[5247,5303,"Nothing."],[5343,5456,"I'm not holding anything."],[5479,5560,"Show me."],[5600,5779,"Really, nothing, Honey."],[5807,5903,"Nothing at all."],[5903,6032,"You're always playing with"],[6032,6139,"this weird junk."],[6139,6288,"You're a bad influence on Evie."],[6324,6379,"Are you going to show me?"],[6415,6548,"I'll get angry if you don't."],[7171,7235,"I…"],[7235,7343,"Honey, I told you,"],[7343,7404,"it's nothing."],[7404,7484,"But since you insist…"],[7484,7607,"You're holding a snake,"],[7607,7728,"and you say it's nothing!"],[7771,7840,"Ethan,"],[7840,7971,"if you ever dare"],[7971,8068,"let Evie play with this stuff again,"],[8123,8268,"I'll punch you."],[8331,8415,"Punch where?"],[8435,8559,"My little chest?"],[8620,8707,"Mommy,"],[8707,8864,"are you going out?"],[8948,9068,"Yes."],[9068,9235,"Mommy is going to attend"],[9235,9335,"a charity gala."],[9335,9484,"If all goes well,"],[9523,9743,"Evie will be healthy again."],[9915,10031,"Stay home,"],[10031,10179,"and take good care of Evie."],[10215,10320,"Don't let Evie"],[10320,10464,"play with that junk anymore."],[10464,10540,"Do you hear me?"],[10635,10748,"Roger that, Honey!"],[11156,11235,"I'm off."],[13819,13928,"Hello, Young Master."],[13952,14040,"Hello, Young Master."],[14068,14191,"Hello, Young Master."],[14340,14443,"Who sent you?"]],"20":[[24,132,"Who sent you?"],[132,243,"Young Master,"],[243,379,"Mr. Smith sent me to pick you up"],[379,528,"for the charity gala."],[767,900,"Go back and tell that old geezer"],[900,1040,"that if he's going to be there,"],[1040,1132,"I'm not going."],[1132,1227,"Young Master,"],[1243,1364,"Mr. Smith says that he must"],[1364,1556,"see his granddaughter today."],[1556,1660,"If you don't go,"],[1660,1771,"he'll come here himself."],[1771,1948,"The leader of The Shades hasn't been found yet."],[1996,2148,"I can't expose my identity right now."],[2444,2551,"Young Master,"],[2551,2760,"Mr. Smith actually cares about you."],[2760,2892,"Just because you're at odds,"],[2892,3055,"you shouldn't keep him from his granddaughter."],[3076,3139,"After all,"],[3139,3224,"grandparents dote on their grandchildren."],[3271,3335,"Enough."],[3335,3424,"I got it."],[3424,3592,"I'll take Evie there myself later."],[3603,3664,"Okay."],[3692,3839,"I'll leave a car for you, sir."],[4339,4435,"Daddy,"],[4484,4684,"do I have a grandpa?"],[4839,4903,"Yes, you do."],[4935,5075,"Do you want to see Grandpa?"],[5300,5375,"Alright."],[5400,5496,"Then later, I will take you"],[5496,5664,"to meet that old geezer."],[7628,7707,"Daddy,"],[7707,7804,"are we going"],[7804,8020,"to see Grandpa soon?"],[8020,8215,"You really want to see Grandpa, don't you?"],[8215,8315,"I used to always"],[8315,8487,"look forward to seeing you."],[8515,8612,"Don't you want"],[8612,8784,"to see Grandpa too?"],[9304,9407,"Daddy…"]],"21":[[451,559,"Daddy!"],[823,951,"Wow!"],[951,1067,"Daddy,"],[1067,1319,"your slippers are so awesome!"],[1319,1488,"Isn't Daddy the awesome one?"],[1488,1623,"What's that got to do with the slippers?"],[2123,2223,"You loser!"],[2223,2355,"How dare you smash my car!"],[2355,2536,"You were the one driving blindly"],[2536,2607,"and tried to hit me."],[2615,2732,"Even if I ran you over today,"],[2732,2828,"you'd deserve it."],[2840,2963,"Do you have any idea what car this is?"],[2963,3132,"It's a Porsche worth over a hundred grand!"],[3144,3292,"Even if I sold you,"],[3292,3371,"the money wouldn't cover it!"],[3376,3503,"Don't you insult my daddy!"],[3528,3655,"So what if I do?"],[3655,3796,"You really are father and daughter."],[3796,3928,"One little cripple,"],[3928,4051,"and one loser."],[4051,4240,"Who gave you the nerve to smash my car?"],[4263,4403,"Apologize to my daughter."],[4403,4576,"Did I say something wrong?"],[4576,4680,"I'm warning you,"],[4680,4892,"don't think just because you're a cripple"],[4892,5011,"and a loser"],[5011,5132,"that I'll have any sympathy for you."],[5132,5296,"You must pay for my car today!"],[5471,5628,"What? You want to hit me?"],[5628,5759,"Let me tell you something,"],[5759,6019,"I'm a Project Director at Sowle Group."],[6019,6123,"I'm here today to discuss a partnership"],[6123,6259,"with Ms. Sowle."],[6259,6388,"If you make me late,"],[6388,6480,"you'll pay for it!"],[6480,6711,"So, you work for my wife."],[6711,6919,"You're an employee of SG."],[6919,7140,"In that case, I'll give you a chance."],[7140,7288,"If you apologize,"],[7288,7400,"I won't hold you responsible."],[7411,7500,"You loser."],[7500,7703,"You're clearly scared and trying to save face."],[7703,7911,"I'm not gonna let you keep acting tough."],[7911,8019,"Hit me if you dare!"],[8019,8071,"Come on!"],[8211,8307,"You loser."],[8307,8362,"You f**king…"],[8511,8676,"You actually dared to hit me!"],[8680,8776,"I normally don't hit women,"],[8776,8915,"but you kept begging for it."],[8915,9011,"It's the first time I've ever heard"],[9011,9144,"such an absurd request."],[9151,9332,"You dirty loser,"],[9332,9459,"how dare you hit me!"],[9556,9632,"And you,"],[9632,9711,"what are you laughing at?"],[9715,9828,"You little cripple."],[9828,9919,"I'll make you both"],[9919,10028,"pay for this!"],[10028,10240,"Who are you going to make pay?"]],"22":[[40,176,"Ms. Sowle, you're here."],[176,351,"You just said,"],[351,544,"who exactly will you make pay?"],[548,619,"Ms. Sowle,"],[619,776,"it was these two bumpkins."],[776,907,"They smashed my car."],[907,992,"I bet they were sent"],[992,1119,"by a rival company"],[1119,1276,"to sabotage our partnership."],[1276,1407,"And this little brat,"],[1407,1600,"she's faking a disability to scam me."],[1755,1800,"Ms. Sowle,"],[1800,1936,"did you hit the wrong person?"],[1936,2051,"I hit exactly who I intended to!"],[2459,2571,"Mom,"],[2655,3028,"she almost hit Daddy and me with her car,"],[3028,3215,"and she yelled at us."],[3307,3471,"That's right, honey."],[3471,3551,"I mean,"],[3551,3715,"it's fine if she insults me,"],[3728,3892,"but she insulted our daughter,"],[3892,4067,"and said some really nasty things."],[4067,4311,"Mom? Honey?"],[4311,4471,"Don't cry, Evie."],[4471,4715,"Mommy's going to teach her a lesson for you."],[4871,5063,"Ms. Sowle, let me explain!"],[5063,5151,"Sandra,"],[5151,5288,"you're fired."],[5288,5351,"Also,"],[5351,5515,"there are funding irregularities"],[5515,5671,"in many of your recent projects."],[5671,5819,"Later,"],[5819,6063,"I'll have the authorities investigate you."],[6103,6163,"Ms. Sowle!"],[6163,6303,"Please give me another chance!"],[6303,6403,"Ms. Sowle!"],[6403,6528,"Give me one more chance!"],[6528,6628,"Ms. Sowle!"],[6628,6740,"Honey,"],[6740,6828,"you're amazing."],[6928,7076,"Mommy, you're the best!"],[7159,7392,"Why did you bring Evie here?"],[7392,7492,"Mommy,"],[7492,7696,"Daddy brought me to find Grandpa."],[7867,8051,"Evie has a grandfather?"],[8051,8215,"Why didn't you tell me?"],[8215,8363,"Oh, that old geezer?"],[8363,8500,"He's not even worth mentioning."],[8500,8707,"If he hadn't asked to see Evie,"],[8707,8836,"we wouldn't be here."],[8963,9132,"Where is Evie's grandfather?"],[9132,9280,"I really should meet him."],[9336,9455,"That's my wife for you."],[9484,9607,"She's not only beautiful,"],[9607,9723,"but also so well-mannered."],[9723,9915,"Oh, that old geezer…"],[9915,10036,"He, uh... He..."],[10036,10111,"Well, well."],[10163,10296,"Isn't this Hayville's"],[10296,10555,"most sl*tty, beautiful CEO?"],[10555,10680,"Thought you got pregnant out of wedlock."],[10680,10811,"Why aren't you at home raising your kid"],[10811,10940,"instead of running around here?"]],"23":[[3,92,"I mean, Ms. Sowle,"],[92,280,"today's charity gala is hosted by"],[280,500,"Mr. Smith, the richest man in the country."],[500,700,"Why is a shameless woman like you"],[700,819,"crashing the party?"],[819,915,"Miss Lane,"],[915,1023,"she came here today specifically"],[1023,1171,"to partner with Mr. Smith."],[1176,1251,"Oh my."],[1251,1444,"That really is unfortunate."],[1444,1551,"So am I."],[1551,1636,"Ms. Sowle,"],[1636,1740,"tell me,"],[1740,1928,"which of us will get to"],[1928,2003,"collaborate with William Smith today?"],[2003,2144,"Fair competition."],[2163,2303,"May the best person win."],[2303,2548,"What do you have to compete with Miss Lane?"],[2548,2700,"Regarding your private life,"],[2700,2815,"you got pregnant out of wedlock."],[2815,2907,"Regarding status,"],[2907,3180,"Miss Lane is the richest heiress in Hayville."],[3180,3303,"Oh, right."],[3303,3415,"I already sent"],[3415,3519,"all of Sowle Group's"],[3519,3651,"project data"],[3651,3819,"to Miss Lane."],[3819,4023,"You want to partner with William Smith?"],[4023,4196,"Pfft, keep dreaming."],[4196,4376,"Leaking company secrets…"],[4376,4507,"Aren't you afraid of going to jail?"],[4507,4763,"She is now the Lane Group's director."],[4763,4896,"If you're not happy about it,"],[4896,5028,"go ahead and sue us."],[5171,5332,"Where did this stinking stray dog come from?"],[5332,5488,"It smells like it ate sh*t."],[5500,5611,"Who the f**k are you?"],[5611,5684,"How dare you curse at me?"],[5692,5900,"Hey, I was cursing at a dog."],[5900,6071,"What, you admit you're a dog?"],[6071,6159,"Aren't you just pathetic?"],[6159,6244,"You…"],[6244,6328,"Miss Lane,"],[6328,6488,"he is Sarah's husband."],[6728,6836,"Sarah,"],[6836,6980,"you must really be desperate."],[6980,7184,"To think you'd even stomach"],[7184,7296,"a country bumpkin like him."],[7296,7388,"Enough!"],[7388,7492,"My husband"],[7492,7619,"is not someone you get to insult."],[7628,7719,"Well, well, well."],[7719,7863,"He's just a stinking loser,"],[7863,8028,"and you actually treat him like a treasure."],[8028,8132,"Keep spouting sh*t,"],[8132,8271,"and I'll smash your face in."],[8288,8428,"Hit me?"],[8428,8563,"Oh, I'm so terrified."],[8563,8684,"Sarah,"],[8684,8811,"did you come today to attend"],[8811,8971,"the charity gala,"],[8971,9115,"or did you bring your husband"],[9115,9223,"just to beat people up?"],[9223,9363,"Everyone, come look at this!"],[9363,9500,"Ms. Sowle"],[9500,9648,"dragged her whole family to"],[9648,9780,"the charity gala,"],[9780,9948,"and her husband wants to beat people up!"]],"24":[[7,123,"Ms. Sowle,"],[123,307,"if you really can't live without a man,"],[307,471,"you should just stay home."],[471,684,"Why come to a charity gala?"],[684,855,"What if you dirty the venue?"],[855,1051,"Watch your mouth."],[1051,1203,"Did I say something wrong?"],[1203,1419,"Five years ago, you got pregnant out of wedlock."],[1419,1563,"Can you pretend you aren't dirty?"],[1648,1840,"The dignified 'Most Beautiful CEO in Hayville'"],[1840,2076,"has now sunk to being a loose woman."],[2076,2200,"You brought this on yourself."],[2215,2363,"William Smith is hosting the"],[2363,2471,"charity gala today."],[2471,2663,"Her showing up with her whole family"],[2663,2740,"is really inappropriate."],[2740,2892,"I heard Mr. Smith plans"],[2892,3100,"to acknowledge his granddaughter today."],[3100,3303,"If she jinxes to the event or something,"],[3336,3440,"it's going to be a problem."],[3511,3700,"You should take our daughter home first."],[3700,3788,"Mom,"],[3788,4028,"I haven't seen Grandpa yet."],[4028,4136,"Grandpa?"],[4136,4280,"Where is your grandpa?"],[4280,4500,"Don't tell me he's in the Jade Hotel, too?"],[4503,4636,"So what if he is?"],[4636,4744,"What a joke."],[4744,4855,"The Jade Hotel has been"],[4855,5011,"booked by Mr. Smith today."],[5011,5159,"A loser like you"],[5159,5323,"trying to leech off Mr. Smith?"],[5323,5423,"You bumpkin."],[5423,5588,"You want to enter the Jade Hotel?"],[5588,5736,"Do you even have an invitation?"],[5736,5863,"If I want to go in,"],[5863,6007,"no one dares to stop me."],[6023,6223,"Daddy, you're amazing!"],[6376,6496,"Sarah,"],[6496,6592,"where did you find"],[6592,6676,"this stray man?"],[6676,6876,"He's a real piece of work."],[6876,7059,"He brags without even blinking."],[7071,7151,"Ethan,"],[7151,7276,"this gala"],[7276,7428,"is crucial for Evie's medicine."],[7428,7592,"Don't cause any trouble."],[7592,7823,"Besides, I only have one invitation,"],[7823,7923,"so you can't get in anyway."],[7923,8032,"Honey,"],[8032,8240,"even if we don't attend this gala,"],[8240,8344,"I can still help you get"],[8344,8467,"the medicine for our daughter."],[8467,8623,"As for the Jade Hotel,"],[8623,8796,"they'll be begging me to enter."],[8796,8896,"I don't need an invitation."],[8896,9084,"You? Pfft."],[9084,9167,"If you can actually get"],[9167,9315,"into the Jade Hotel today,"],[9315,9407,"I'll let you stomp"],[9407,9540,"all over my face."],[9551,9619,"Fine."],[9619,9763,"You said it."],[9763,9851,"You loser."],[9851,9955,"Who do you think you are?"],[9963,10092,"Mr. Smith's son or something?"],[10100,10196,"How dare you!"],[10323,10515,"Who are you calling a loser?"],[10900,10971,"Young Master!"],[10987,11079,"Young Master!"]],"25":[[8,88,"Young Master?"],[108,243,"Who is the Young Master?"],[327,583,"This hotel is the Smith family's property."],[587,724,"The Young Master they just greeted—"],[724,840,"could it be…"],[856,927,"That old geezer,"],[996,1148,"always into fanfare!"],[1203,1272,"Mr. Armstrong,"],[1316,1448,"where is Mr. Smith's son?"],[1844,2007,"I thought I saw him just now."],[2148,2307,"Did I see wrong?"],[2412,2528,"You scared me to death."],[2539,2648,"I thought this bumpkin"],[2648,2751,"was Mr. Smith's son."],[2812,2903,"How is that possible?"],[2903,2987,"Miss Lane,"],[3032,3192,"with his shabby look,"],[3247,3492,"who would believe he's Smith Jr?"],[3528,3724,"Who are you calling a bumpkin?"],[3788,3879,"Who is the pauper?"],[3892,3964,"Mr. Armstrong,"],[3964,4107,"it's this loser."],[4139,4252,"He claims he doesn't need an invitation"],[4252,4407,"to enter the Jade Hotel."],[4411,4479,"This is simply"],[4479,4620,"an insult to the Jade Hotel!"],[4652,4739,"Mr. Armstrong."],[4743,4884,"Ms. Sowle from the Sowle Group"],[4884,5043,"is here for the charity event,"],[5056,5200,"dragging her whole family along."],[5228,5347,"Since you're here,"],[5360,5511,"you should kick them all out!"],[5520,5696,"Don't let them dirty the venue"],[5728,5852,"and jinx the event."],[5911,5975,"Shut up!"],[6024,6128,"Mr. Armstrong,"],[6128,6271,"did you hit the wrong person?"],[6271,6335,"Miss Lane is…"],[6384,6507,"I hit exactly who I meant to!"],[6543,6631,"Mr. Armstrong,"],[6631,6723,"why?"],[6784,6859,"Mr. Armstrong"],[6859,6992,"can't stand mad dogs biting people."],[7059,7100,"Right,"],[7100,7168,"Mr. Armstrong?"],[7200,7312,"Yes, yes, exactly."],[7364,7476,"You two"],[7476,7692,"insulted Ms. Sowle and her husband."],[7731,7887,"How is that any different from mad dogs?"],[7907,7984,"But Mr. Armstrong…"],[7992,8051,"Enough."],[8051,8131,"Stop talking."],[8156,8271,"Making a scene here"],[8304,8392,"is disgraceful."],[9115,9212,"I'm going inside."],[9284,9404,"Aren't you"],[9431,9559,"taking Evie to find Grandpa?"],[9748,9800,"Take this."],[9823,9951,"Buy something nice."],[10040,10100,"Okay."],[10287,10368,"We're off."],[10728,10887,"You're the best, honey."],[10915,11104,"I'll reward you with a second baby later."],[11323,11379,"Young Master,"],[11379,11484,"Mr. Smith is upstairs."],[11484,11576,"He sent me to get you."],[11687,11856,"So much fuss."]],"26":[[663,744,"Mr. Smith,"],[767,880,"your little granddaughter is here."],[1056,1132,"My sweet granddaughter."],[1151,1288,"Grandpa finally gets to meet you."],[1340,1427,"Grandpa."],[1427,1519,"Yes, sweetheart."],[1551,1623,"My darling girl."],[1639,1687,"Come,"],[1687,1755,"let Grandpa give you a hug."],[2544,2628,"Where is that brat?"],[2664,2739,"Young Master…"],[2760,2823,"Fine."],[2839,2976,"I can let him see Evie,"],[2992,3076,"but I don't want to see him."],[3139,3215,"That ungrateful brat."],[3215,3288,"He doesn't want to see me?"],[3288,3420,"Well, I don't want to see him either."],[3467,3547,"Grandpa,"],[3579,3800,"please don't be mad at Daddy."],[3832,4011,"He went to find Mommy."],[4047,4100,"Alright."],[4100,4260,"Grandpa isn't mad at him."],[4292,4415,"As long as I can see my darling granddaughter,"],[4443,4515,"I am happy."],[4747,4803,"Wilson,"],[5020,5096,"bring out the gifts."],[5296,5367,"D*mn it."],[5392,5475,"What the hell was wrong"],[5475,5575,"with Godfrey just now?"],[5603,5692,"Miss Lane,"],[5747,5847,"I guess Godfrey"],[5847,6007,"just has the hots for that slut,"],[6043,6175,"and that's why he helped her."],[6220,6292,"But"],[6292,6512,"this is a charity gala."],[6579,6695,"I bet Godfrey"],[6695,6868,"can't protect her forever."],[6895,6971,"Come on,"],[6976,7104,"let's go pay her another visit."],[7415,7520,"Ms. Sowle."]],"27":[[28,112,"Honey, are you all right?"],[156,279,"How did you get in?"],[335,428,"Where is Evie?"],[459,528,"Don't worry,"],[528,640,"she's with her grandpa."],[702,791,"You loser."],[791,891,"How dare you trip me!"],[943,1043,"You two."],[1072,1196,"One of you tried to trip my wife,"],[1232,1467,"and the other tried to throw champagne on her."],[1519,1603,"Do you think I'm blind?"],[1639,1719,"You don't have an invitation."],[1719,1828,"How did you get in here?"],[1855,1912,"Security!"],[1919,2071,"Throw this bumpkin out!"],[2071,2187,"Whoa,"],[2187,2300,"can you stop screaming?"],[2332,2516,"I heard someone outside say"],[2539,2671,"that if I managed to get in,"],[2676,2823,"they'd let me step on their face."],[2860,2948,"Who was that?"],[2952,3054,"You loser."],[3064,3144,"Don't think I don't know"],[3144,3264,"that you snuck in."],[3271,3324,"Exactly."],[3356,3484,"It's bad enough that you snuck in,"],[3524,3647,"but you're also making a scene!"],[3692,3860,"You clearly tried to embarrass me,"],[3879,4032,"and now you're shifting the blame?"],[4071,4252,"Who's really the one making a scene?"],[4303,4371,"Fine."],[4396,4584,"Then let's let everyone here be the judge."],[4652,4784,"Everyone, come take a look!"],[4784,4832,"We've got a"],[4832,5020,"shameless tramp here"],[5067,5288,"trying to defile this gala,"],[5324,5539,"and she brought a savage along to cause trouble!"],[5584,5643,"Penny,"],[5688,5903,"do you really have to be so vicious?"],[5932,6088,"You're the one who got pregnant out of wedlock"],[6088,6211,"and soiled your reputation."],[6224,6375,"Yet you still came to this charity gala"],[6375,6464,"just to disgust us."],[6492,6651,"And you didn't just come yourself,"],[6684,6884,"you brought a savage to make a scene, too."],[6907,7000,"And you think you can discuss business"],[7000,7187,"with Mr. Smith like this?"],[7200,7268,"Dream on!"],[7292,7459,"Mr. Smith brought billions in capital"],[7459,7607,"when he came to Hayville."],[7631,7820,"Do you think a petty CEO like you"],[7820,8012,"is worthy of working with him?"],[8031,8107,"Exactly."],[8135,8271,"Don't waste your time"],[8292,8412,"and energy here."],[8451,8615,"Go home and raise your kid."],[8659,8764,"Shut the hell up, all of you!"],[8907,9092,"If anyone insults my wife again,"],[9168,9276,"I'll cripple him!"]],"28":[[16,191,"Look! Everyone, look!"],[208,408,"This is Ms. Sowle's"],[408,563,"barbarian husband."],[600,671,"What?"],[700,796,"Are you planning to cripple"],[796,908,"every single one of us today?"],[1011,1196,"This is William Smith's turf."],[1208,1340,"What makes him think he can be so arrogant?"],[1343,1503,"If he causes a huge scene"],[1511,1644,"and angers Mr. Smith,"],[1671,1807,"forget about the partnership,"],[1807,2012,"he'll be lucky to leave here in one piece!"],[2032,2096,"Ethan,"],[2107,2183,"you need to leave now."],[2219,2328,"If you stay here,"],[2339,2471,"things will only get worse."],[2551,2703,"If I can't finalize the partnership"],[2703,2807,"with Mr. Smith today,"],[2823,2951,"the medicine to save Evie"],[2987,3112,"will never be completed."],[3151,3228,"Honey,"],[3252,3360,"if you really want to"],[3360,3443,"land this project,"],[3475,3560,"I can help you."],[3728,3879,"Did I hear that right?"],[3903,4096,"You're going to help her land this project?"],[4143,4200,"Who do you think you are?"],[4200,4360,"Mr. Smith's son?"],[4367,4492,"Stop talking."],[4500,4639,"I know you mean well,"],[4700,4803,"but this situation"],[4860,5052,"can't be solved with fists."],[5084,5143,"Go now."],[5143,5284,"Before it's too late."],[5311,5407,"Stop right there!"],[5552,5688,"What else do you want?"],[5688,5796,"He tripped me,"],[5807,6003,"and spilled champagne all over me."],[6020,6247,"He must get on his knees and apologize!"],[6300,6512,"Or else he isn't leaving this place today."],[6531,6640,"Penny,"],[6640,6751,"you're crossing the line!"],[6779,6935,"You clearly brought this on yourself,"],[6948,7071,"and now you expect my husband"],[7071,7223,"to kneel and apologize?"],[7243,7312,"Fine."],[7323,7471,"Let's make a scene then."],[7471,7659,"I'd like to see how you negotiate your deal."],[7668,7823,"Even if we make a scene,"],[7851,8000,"you were the one asking for trouble."],[8020,8112,"I think Mr. Smith"],[8112,8200,"is a reasonable man."],[8268,8371,"As for the partnership,"],[8384,8559,"it depends on the project's merit and capability,"],[8607,8771,"so why shouldn't I fight for it?"],[8920,9031,"Sarah,"],[9043,9284,"you don't actually think Mr. Smith will handle"],[9284,9543,"a ten-billion investment personally, do you?"],[9564,9720,"Of course not."],[9740,9868,"Mr. Smith has already entrusted"],[9868,10207,"full authority over the investment to me."],[10223,10348,"It's Mr. Ward!"],[10348,10551,"The head of investment at Smith Group."],[10568,10731,"Did Mr. Smith really hand over"],[10731,10812,"the Ten-Billion Investment to Mr. Ward?"],[10864,10959,"That's right."],[11023,11268,"For this Ten-Billion Investment,"],[11328,11443,"I've already chosen the Lane Group."]],"29":[[212,360,"The Ten-Billion Contract is huge."],[391,540,"As the Smith Group representative, how can you"],[563,687,"just hand it to the Lane Group?"],[700,840,"Where did this punk come from?"],[891,1091,"Do I need you to tell me how to do my job?"],[1100,1216,"Exactly."],[1235,1440,"The Lane family is the wealthiest in Hayville."],[1451,1603,"If Mr. Ward doesn't give the contract"],[1603,1707,"to the Lane Group,"],[1707,1807,"should he give it to you?"],[1951,2028,"Mr. Ward,"],[2092,2264,"could you please give me a chance?"],[2287,2464,"This partnership means everything to me."],[2487,2576,"Besides,"],[2603,2812,"if the Evie Care Project is completed,"],[2819,2928,"it could save many children"],[2928,3123,"suffering from genetic mutations."],[3647,3828,"Mr. Ward, here are the project details."],[3852,3939,"Please take a look."],[4867,4943,"Well, as for a chance,"],[4943,5084,"there might be one."],[5167,5296,"However,"],[5367,5507,"it depends on your performance."],[5611,5728,"Go to hell!"],[5728,5867,"How dare you touch my woman!"],[5911,6043,"Well done, Sarah."],[6056,6224,"Mr. Ward represents the Smith Group."],[6264,6371,"The savage you brought"],[6371,6468,"hit Mr. Ward,"],[6468,6623,"which is a direct insult to the Smith Group."],[6651,6768,"You're finished!"],[6784,6868,"Exactly."],[6868,7048,"Even if you apologize on your knees,"],[7048,7140,"that's not gonna help!"],[7187,7351,"Truly a country bumpkin."],[7368,7571,"He dared to hit the Smith Group's representative."],[7659,7828,"Forget about the partnership now."],[7843,7959,"I'm afraid the entire Sowle family"],[8004,8220,"will cease to exist."],[8368,8623,"You little punk, how dare you kick me!"],[8643,8756,"If I don't cripple you today,"],[8768,8900,"I'm not a Ward!"],[8959,9048,"Guards!"],[9168,9276,"Seize this punk"],[9276,9364,"and lock him up!"],[10368,10443,"Evie,"],[10459,10607,"do you like these gifts?"],[10679,10740,"Grandpa,"],[10740,10920,"I like them a lot."],[10984,11051,"But,"],[11051,11243,"I can only have one."],[11287,11392,"Why is that?"],[11459,11592,"Because Mommy says"],[11607,11923,"we shouldn't be greedy."],[12000,12195,"Seems my daughter-in-law has good character."],[12404,12476,"Evie,"],[12476,12579,"among all these gifts,"],[12579,12720,"which one do you like the most?"],[13000,13084,"Grandpa,"],[13084,13247,"can I have this one?"]],"30":[[191,235,"This one?"],[331,487,"This isn't a toy, Evie."],[487,612,"Why do you choose that?"],[655,759,"Because Mommy"],[759,896,"wants to cure my illness,"],[908,1067,"so she really needs this."],[1235,1488,"Those two have suffered enough over the years."],[1548,1628,"Alright."],[1687,1760,"Today, I will sign"],[1760,1907,"this Ten-Billion Contract"],[1916,2067,"in my dear granddaughter's name."],[2076,2167,"That's great!"],[2167,2292,"Thank you, Grandpa."],[2467,2760,"Then, Grandpa, can I give this to Mommy?"],[2796,2867,"Of course."],[2916,2951,"How about this?"],[2971,3032,"In a little while,"],[3044,3155,"Grandpa will come find you downstairs."],[3267,3328,"Oh, right."],[3343,3511,"Let me give you my number."],[3511,3652,"When you miss me,"],[3656,3735,"or if anything happens"],[3735,3832,"and you need me,"],[3852,3943,"just give me a call."],[3943,3996,"Okay?"],[4143,4315,"Here, let me put it in your phone."],[4635,4696,"There, saved."],[4696,4796,"This is Grandpa's number."],[4796,4828,"Don't forget."],[4884,4911,"Okay."],[5032,5167,"Someone, see the young lady out."],[5500,5600,"Let me carry you."],[5775,5856,"Here,"],[6011,6092,"hold this tight."],[6500,6635,"Bye, Grandpa."],[6676,6740,"Goodbye."],[6935,7031,"Mr. Smith,"],[7056,7223,"your granddaughter hasn't had"],[7300,7407,"an easy life these past years."],[7476,7584,"Go investigate exactly"],[7584,7735,"what illness Evie has."],[7784,7871,"Spare no expense"],[7871,7964,"to cure her."],[7995,8064,"Also,"],[8095,8335,"find out who bullied my precious granddaughter."],[8387,8507,"Show them no mercy!"],[8528,8587,"Yes, sir."],[8635,8804,"Cripple that kid for me!"],[8835,8900,"Mr. Ward,"],[8915,9076,"I apologize on behalf of my husband."],[9095,9164,"I hope you can"],[9164,9343,"give me another chance."],[9371,9431,"Honey,"],[9479,9607,"don't listen to this b*stard."],[9623,9712,"Regarding this project,"],[9712,9812,"he doesn't call the shots."],[9831,9968,"Mr. Ward doesn't call the shots?"],[9968,10100,"Does that mean you do?"],[10115,10192,"You bumpkin."],[10220,10356,"You hit Mr. Ward today,"],[10387,10504,"so the entire Sowle Group"],[10504,10628,"is going to collapse."],[10723,10804,"By the way,"],[10831,10984,"your wife wants the project"],[10984,11192,"to develop a cure for your daughter, right?"],[11231,11328,"Too bad."],[11368,11484,"That's not happening."],[11531,11620,"Ethan,"],[11623,11776,"can you stop causing trouble?"],[11804,11987,"If we don't get the ten-billion project today,"],[12048,12187,"Evie's condition will worsen,"],[12295,12468,"and I won't be able to go on!"],[12507,12628,"Sarah,"],[12651,12792,"don't blame me for not giving you a chance."],[12831,13147,"If you show me a good time tonight,"],[13187,13331,"and make your hillbilly husband"],[13352,13443,"kneel before me"],[13443,13608,"and kowtow for forgiveness,"],[13675,13787,"I might consider"],[13796,13996,"giving you a share of the investment."],[14024,14128,"Mommy, Mommy!"],[14163,14356,"Look what I brought you!"]],"31":[[132,220,"Evie,"],[236,368,"why are you here?"],[420,660,"Mom, I just saw Grandpa."],[660,824,"He was so nice to me,"],[836,1000,"and he gave me this!"],[1018,1300,"Hmph. At least that old geezer has some sense."],[1308,1352,"What?"],[1352,1556,"Your grandpa gave you the Ten-Billion Contract?"],[1556,1696,"How come I didn't know about this?"],[1696,1800,"What's going on?"],[1800,1876,"Was the Ten-Billion Contract"],[1876,2028,"given to the Sowle family?"],[2028,2120,"I heard Mr. Smith's"],[2120,2248,"going to recognize his granddaughter today."],[2248,2404,"Could it be this little girl?"],[2420,2500,"Tch."],[2504,2592,"This little girl"],[2592,2712,"is just a jinx born to Sarah"],[2712,2948,"and that wild man."],[2948,3116,"How could Mr. Smith possibly have"],[3116,3264,"such an unlucky granddaughter?"],[3264,3332,"Exactly."],[3332,3492,"This Ten-Billion Contract must be"],[3492,3584,"something this brat stole!"],[3584,3740,"I didn't steal it!"],[3740,3924,"If you don't believe me, go ask Grandpa!"],[3924,4088,"You little brat,"],[4088,4224,"do you think I'm stupid?"],[4224,4320,"Tell me the truth,"],[4320,4516,"where did you steal the contract?"],[4516,4612,"Give it back to me right now!"],[4728,4868,"Screw you!"],[4868,4980,"You scared my daughter,"],[4992,5140,"you piece of trash."],[5144,5340,"I haven't settled the score with you from earlier yet."],[5460,5560,"I get it now."],[5560,5640,"It must be that"],[5640,5800,"you ordered this little girl"],[5800,5940,"to steal the contract."]],"32":[[0,124,"So that's what happened."],[152,316,"I almost believed this girl"],[316,492,"was actually Mr. Smith's granddaughter."],[504,596,"How is that possible?"],[616,704,"If this girl really were"],[704,824,"Mr. Smith's granddaughter,"],[824,1016,"then her dad would have to be Smith Jr."],[1016,1188,"Look at him, looking like such a loser."],[1204,1360,"Does he look anything like Smith Jr?"],[1368,1464,"That explains it."],[1464,1624,"I wondered why this bumpkin was so confident"],[1624,1764,"about getting the contract."],[1820,1996,"Turns out he had his daughter steal it."],[1996,2088,"How stupid."],[2092,2200,"Did you think stealing the contract"],[2200,2356,"would let you work with the Smith family?"],[2356,2620,"Like father, like daughter."],[2664,2788,"A d*mn loser"],[2788,2968,"raising a wild brat."],[2968,3116,"What else could we expect?"],[3148,3356,"No wonder she's in a wheelchair so young."],[3392,3612,"It must be God's punishment for you."],[3612,3704,"Ms. Sowle,"],[3756,3940,"it's bad enough you married a loser,"],[3940,4084,"but how could you also give birth"],[4104,4396,"to such an uneducated daughter?"],[4408,4552,"Do you deserve this,"],[4552,4760,"or is your life just meant to be pathetic?"],[4976,5096,"If I don't slap you,"],[5096,5232,"you won't stop yapping, will you?"]],"33":[[924,980,"D*mn."],[980,1204,"Is Miss Lane that horny?"],[1204,1320,"She even carries male enhancement oil."],[1352,1520,"Miss Lane has really unique kinks."],[1556,1680,"So you're into that stuff, huh?"],[1680,1840,"You wouldn't even spare an Indian guy?"],[1856,1996,"You just like it dirty and rough, don't you?"],[2144,2344,"You filthy loser, this isn't over!"],[2396,2484,"Don't touch me!"],[2484,2564,"You disgust me."],[2592,2644,"You"],[2644,2732,"little punk!"],[2732,2868,"Are you f**king crazy?"],[2892,3020,"You hit me just now,"],[3024,3268,"and now you lay a hand on Miss Lane."],[3268,3460,"You even got this little brat"],[3460,3608,"to steal the Ten-Billion Contract."],[3624,3856,"Any one of these things"],[3856,4040,"is enough to destroy you!"],[4040,4160,"And you, you b*tch,"],[4176,4504,"bringing your husband and daughter"],[4504,4716,"to cause trouble at the charity gala."],[4736,4880,"Your Sowle Group"],[4940,5080,"can just wait to go bankrupt."]],"34":[[42,164,"Mr... Mr. Ward."],[184,364,"My husband hit you on impulse."],[388,528,"I apologize on his behalf."],[564,676,"But we really weren't"],[676,788,"trying to cause trouble."],[812,988,"Penny provoked us first."],[996,1148,"I don't want to hear your excuses."],[1156,1408,"None of you three"],[1436,1628,"are getting out of here safely today!"],[1768,1940,"Mommy, don't cry."],[1940,2056,"Daddy and Grandpa"],[2056,2200,"will protect us."],[2208,2316,"That's right, honey."],[2316,2460,"I'm here. It'll be okay."],[2516,2616,"Ethan!"],[2616,2740,"What do you mean 'okay'?"],[2772,2896,"Because of your recklessness,"],[2932,3120,"my partnership with Smith Group is gone."],[3132,3340,"You even told Evie to steal the contract."],[3376,3580,"Do you think this is saving Evie?"],[3588,3804,"You're hurting Evie!"],[3804,4052,"Mom, stop yelling at Daddy."],[4060,4308,"Grandpa really gave this to me."],[4308,4484,"Disaster is looming, yet you still lie!"],[4532,4680,"Arrest them!"],[4808,4928,"You reckless fools."],[4932,5020,"Stop!"]],"35":[[40,152,"It's Smithes' Head Steward,"],[152,220,"Elmer Wilson."],[220,332,"Elmer is"],[332,468,"Mr. Smith's confidant."],[468,700,"He is second only to him."],[704,828,"Elmer,"],[828,964,"what brings you here?"],[992,1240,"I can handle this myself."],[1240,1344,"Handle what?"],[1408,1572,"They are causing trouble here."],[1584,1740,"Especially this loser."],[1764,1888,"He not only hit me,"],[1924,2072,"but also hit Miss Lane."],[2100,2224,"He even made this little girl"],[2224,2360,"steal the contract."],[2408,2500,"You b*stard!"],[2512,2600,"Get out of Smith Group!"],[2620,2720,"Elmer,"],[2720,2908,"did you make a mistake?"],[2920,3080,"They are the troublemakers."],[3236,3388,"You old fool."],[3388,3564,"Do I need you to teach me my job?"],[3596,3700,"Guards!"],[3700,3856,"Teach him a good lesson."],[3864,4000,"Elmer, I was wrong!"],[4000,4080,"Elmer!"],[4152,4292,"Please spare me, Elmer!"],[4292,4442,"Bro, come to the gala quickly!"],[4660,4752,"Elmer,"],[4752,4912,"we didn't mean to cause trouble."],[5036,5176,"As for the contract,"],[5252,5504,"probably Evie accidentally took it."],[5504,5576,"I…"],[5612,5796,"Ms. Sowle, you don't need to be afraid."],[5796,5988,"This contract"],[5988,6156,"was indeed a gift from Mr. Smith to your daughter."]],"36":[[16,108,"What?"],[260,340,"Elmer,"],[348,464,"are you saying that"],[464,700,"Mr. Smith is willing to work with the Sowle Group?"],[728,860,"Did I hear that right?"],[880,1016,"The Ten-Billion Contract"],[1016,1120,"in the little girl's hand"],[1132,1308,"was really a personal gift from Mr. Smith?"],[1340,1484,"The girl just said"],[1484,1656,"the contract was a gift from her grandpa."],[1672,1772,"Could it be that Mr. Smith"],[1772,1876,"is really her grandfather?"],[1892,2032,"The Smith Group can indeed"],[2032,2140,"collaborate with the Sowle Group."],[2260,2340,"However…"],[2340,2472,"Save your 'howevers'!"],[2472,2620,"Give the contract if you want,"],[2656,2844,"but we don't care if you don't."],[2872,3000,"If you think you can use it to force me"],[3000,3084,"to return to the family,"],[3120,3204,"you're dreaming."],[3252,3476,"How long does Young Master intend"],[3476,3604,"to keep feuding with Mr. Smith?"],[3604,3844,"Forget it. As for the reunion,"],[3844,3976,"I should let Mr. Smith"],[3976,4096,"announce it himself."],[4172,4252,"Fine."],[4292,4376,"Then just wait."],[4808,5076,"Honey, this contract isn't important."],[5088,5168,"Let's go home."],[5340,5500,"Who said you could leave?"]],"37":[[52,116,"Brother,"],[116,232,"they bullied me."],[232,380,"You have to avenge me!"],[380,512,"Who dares to bully my sister?"],[540,600,"It's him!"],[752,888,"Well, isn't this my obedient son?"],[988,1076,"I'll take you as my godfather."],[1076,1148,"Is that not enough?"],[1156,1228,"Godfather,"],[1316,1444,"I really didn't know anything."],[1496,1580,"I didn't even"],[1580,1736,"lay a single finger on anyone just now."],[1908,2024,"You little punk."],[2024,2188,"Last time I fell into your hands,"],[2188,2412,"but this time I'll make you pay a hundredfold."],[2428,2504,"What?"],[2504,2636,"Was the pain that good?"],[2636,2740,"Did you not get enough of a thrill?"],[2740,2868,"Want me to go harder?"],[2884,3028,"Don't you threaten me."],[3044,3216,"This is Mr. Smith's turf."],[3216,3292,"And I've brought so many"],[3292,3364,"capable helpers."],[3364,3476,"I'm going to kill you."],[3504,3596,"You bad man!"],[3596,3704,"It was you last time."],[3704,3820,"You bullied my mommy."],[3820,3908,"I'm going to tell Grandpa,"],[3908,4056,"and let Grandpa punish you!"],[4064,4172,"And what kind of"],[4172,4276,"old geezer is your grandpa?"],[4364,4552,"My grandpa is the richest man in the country."],[4552,4636,"You brat."],[4636,4844,"Elmer just mistook you for someone else."],[4844,4976,"You really think you're"],[4976,5120,"the little princess of the Smith family?"],[5140,5244,"Didn't you hear Elmer"],[5244,5364,"tell you to wait?"],[5500,5716,"It'll scare the hell out of you."]],"38":[[32,140,"You little punk."],[140,220,"Kneel down immediately."],[220,376,"Kowtow and apologize to my sister."],[376,584,"Then let your wife serve me properly."],[588,792,"Maybe I'll spare your life."],[792,884,"Otherwise,"],[884,952,"I'll make sure you don't see"],[952,1052,"the sun tomorrow."],[1080,1268,"You want my husband to kneel?"],[1268,1396,"Impossible."],[1396,1472,"And another thing,"],[1484,1644,"show some respect when you speak."],[1660,1740,"Pah!"],[1760,1896,"I liked you so much,"],[1896,2020,"but you chose a punk like him"],[2020,2104,"to have a child with."],[2144,2224,"Fine."],[2224,2408,"I'll cripple him first,"],[2420,2544,"then take my time torturing you."],[2708,2852,"W-What are you doing?"],[2852,3008,"Teaching you a lesson."],[3020,3188,"Why are you just standing there? Get him!"],[3884,4060,"Daddy, you're so strong!"],[4996,5088,"Stop right there!"]],"39":[[168,280,"Oh my god."],[280,400,"It's actually Tyran and Tiger,"],[400,500,"the two masters!"],[528,780,"The duo known as Tyran and Tiger."],[780,948,"They are ranked the top two"],[948,1028,"fighters in Hayville,"],[1044,1196,"and have always worked for the Lane family."],[1248,1328,"Uncle Tyran, Uncle Tiger,"],[1328,1408,"you're finally here."],[1408,1448,"Quick,"],[1448,1536,"cripple him!"],[1564,1664,"You punk."],[1664,1912,"Tyran and Tiger are here. You're finished."],[1932,2060,"So you're the kid from last time"],[2060,2208,"who chased Scorpion away."],[2212,2360,"If you two had been there,"],[2388,2468,"you would have run away too."],[2480,2568,"Arrogant!"],[2568,2828,"Scorpion is ranked third in Hayville,"],[2828,3120,"but his skills are worlds apart from ours."],[3124,3340,"Did you hear that, punk?"],[3340,3464,"No matter how tough you are,"],[3464,3664,"Tyran and Tiger can crush you"],[3664,3848,"as easily as crushing an ant."],[3884,4004,"Hurry, take Evie and go."],[4048,4148,"Leonard is right."],[4148,4296,"Scorpion was strong last time,"],[4328,4492,"but he can't compare to Tyran and Tiger."],[4616,4744,"You can't handle them."],[4972,5072,"Don't worry, honey."],[5076,5236,"Even if God himself came down,"],[5296,5384,"he couldn't touch"],[5384,5460,"our family of three."]],"40":[[16,184,"Mommy, don't be scared."],[184,352,"I'm calling Grandpa right now"],[352,520,"to have him teach them a lesson."],[756,928,"Grandpa, there are bad guys here"],[928,1072,"bullying Mommy and me."],[1072,1184,"What?"],[1184,1276,"Do they have a death wish?"],[1276,1404,"How dare they bully my granddaughter!"],[1404,1508,"Don't be afraid, Evie."],[1508,1592,"I am on my way."],[1600,1628,"Okay."],[1692,1852,"My grandpa will be here soon."],[1852,1964,"Just you wait."],[2016,2140,"You're young,"],[2140,2340,"but you sure know how to bluff."],[2340,2528,"If Mr. Smith really were your grandpa,"],[2528,2620,"he must've committed some terrible sins"],[2620,2728,"in his past life."],[2980,3112,"Evie, be a good girl."],[3112,3232,"Let Daddy take you away."],[3232,3368,"If we don't go now, it'll be too late."],[3644,3768,"You've offended the Lane family."],[3800,3932,"None of the three of you"],[3932,4056,"are leaving here."],[4056,4288,"Uncle Tyran, Uncle Tiger, do it."],[4912,5060,"You have some nerve!"]],"41":[[960,1100,"The Capital's Chief Steward,"],[1136,1248,"Elmer Wilson!"],[1404,1532,"Evie, Grandpa is here."],[1532,1624,"Are you okay?"],[1652,1772,"I'm fine, Grandpa."],[1780,1872,"What?"],[1880,1972,"Grandpa?"],[1972,2052,"Oh my God."],[2052,2180,"Did I hear that right?"],[2180,2424,"Is she really William Smith's granddaughter?"],[2460,2592,"What is going on?"],[2592,2764,"Tell me who bullied you."],[2764,2896,"It was them."],[2900,2952,"Mr…"],[2952,3040,"Mr. Smith."],[3052,3204,"How is she your granddaughter?"],[3204,3296,"Mr. Smith,"],[3296,3444,"do you have the wrong person?"],[3776,3984,"Watch your mouth."],[3984,4060,"Would I mistake"],[4060,4176,"my own granddaughter?"],[4176,4260,"Mr. Smith,"],[4260,4344,"I really didn't know she was"],[4344,4412,"your granddaughter."],[4428,4540,"If I had known,"],[4548,4832,"I wouldn't have dared to bully her!"],[4844,4948,"Yes, Mr. Smith."],[4948,5048,"We know we were wrong."],[5048,5172,"Please forgive us!"],[5208,5432,"You two blind fools."],[5440,5636,"You bullied my precious granddaughter."],[5660,5788,"Do you think a simple apology is enough?"],[5804,5916,"Guards!"],[7080,7256,"Come here, Evie. Let Grandpa hold you."],[7280,7340,"Old geezer."],[7364,7480,"Don't you touch her."],[7484,7580,"She is my daughter."],[7580,7660,"You punk."],[7672,7788,"Could it be"],[7788,8100,"is Ethan Mr. Smith's son?"],[8364,8472,"Mr. Smith,"],[8472,8756,"you say Evie is your granddaughter."],[8776,9020,"Then who is my husband to you?"],[9020,9156,"- Stranger. - Stranger."],[9264,9344,"Sigh."],[9344,9534,"Mr. Smith and Young Master"],[9538,9660,"neither is willing to back down."]],"42":[[140,244,"- Stranger? - Stranger?"],[280,364,"See?"],[364,416,"I knew it."],[416,520,"Mr. Smith must have the wrong person."],[536,676,"It must be this little brat"],[676,848,"pretending to be Mr. Smith's granddaughter"],[848,1012,"and tricking him."],[1220,1316,"I didn't punish you"],[1316,1400,"harshly enough."],[1400,1628,"Mr. Smith, didn't you say you're strangers?"],[1628,1716,"I'm acknowledging my granddaughter."],[1716,1824,"What business is it of anyone else?"],[1840,1948,"What's going on?"],[1992,2104,"This little girl"],[2104,2272,"is Mr. Smith's granddaughter,"],[2280,2416,"but her father and Mr. Smith"],[2416,2520,"are strangers?"],[2552,2664,"I get it."],[2684,2828,"Mr. Smith must just think"],[2828,3028,"this little girl is cute,"],[3028,3140,"so he accepted her as his granddaughter."],[3140,3276,"So Mr. Smith"],[3276,3440,"is the little girl's grandfather,"],[3440,3580,"but has no relation to her parents."],[3592,3668,"That makes sense."],[3668,3808,"Ethan's last name is Cox."],[3808,3980,"How could he be Smith Jr?"],[3980,4164,"Otherwise, all these years,"],[4164,4328,"he wouldn't have been a driver"],[4328,4464,"and sold fruit."],[4500,4680,"You two blind fools."],[4712,4832,"Just wait for the Lane Group"],[4832,4940,"to go bankrupt."],[4940,5028,"Get out!"],[5152,5204,"Mr. Smith,"],[5204,5324,"I was wrong!"],[5372,5512,"Please forgive me!"],[5764,5820,"Evie,"],[5820,5912,"look, Grandpa taught those bad guys"],[5912,5988,"a lesson for you."],[5988,6076,"I got back at them for you."],[6076,6168,"Are you happy?"],[6176,6236,"Yeah."],[6236,6348,"Thank you, Grandpa."]],"43":[[504,624,"Thank you, Mr. Smith."],[624,780,"I should be the one thanking you"],[780,908,"for giving me such a cute"],[908,1028,"and beautiful granddaughter."],[1040,1112,"Mom,"],[1112,1264,"I didn't steal anything."],[1264,1356,"This gift"],[1356,1524,"really was from Grandpa."],[1632,1716,"Take it."],[1760,1948,"Consider the cooperation between Smith"],[1948,2100,"and Sowle Groups official."],[2520,2596,"Thank you."],[2596,2720,"Thank you, Mr. Smith."],[2816,3032,"Come on, it's just a lousy contract."],[3032,3120,"Why get so sentimental?"],[3264,3384,"Watch your mouth!"],[3412,3512,"You little b*stard,"],[3512,3636,"you really piss me off."],[3700,3944,"Evie, we got the contract. Let's go home."],[4032,4112,"Don't be in such a rush."],[4112,4272,"I haven't finished talking with my granddaughter."],[4272,4368,"Who is your granddaughter?"],[4436,4576,"I'm sorry, Mr. Smith."],[4576,4732,"My husband is simply undisciplined."],[4732,4880,"He didn't mean to offend you."],[4908,5088,"I apologize on his behalf."],[5088,5192,"It's okay, it's okay."],[5208,5328,"I just hope you"],[5328,5588,"will bring my granddaughter to visit me."],[5672,5764,"We will."],[5916,6052,"Goodbye, Grandpa."],[6052,6280,"I will call you."],[6280,6396,"Okay."]],"44":[[392,528,"It's just a contract."],[528,660,"Look how happy you are."],[668,888,"Of course. With this contract,"],[900,1020,"I can devote myself entirely"],[1020,1188,"to drug development."],[1560,1644,"Sweetie,"],[1644,1764,"thank you for helping Mommy"],[1764,1868,"get this contract."],[1912,2092,"You're Mommy's little angel."],[2128,2212,"Mommy,"],[2212,2328,"this contract"],[2328,2528,"is for curing me."],[2528,2680,"I know that."],[2820,2896,"Mommy,"],[2896,3140,"actually, you should thank Daddy."],[4314,4464,"Get the f**k out!"],[4464,4616,"How dare you touch my woman!"],[5284,5340,"Let's go,"],[5340,5396,"inside."],[5420,5684,"Tonight, I'm going to cook a big feast!"],[5728,5816,"Yay!"]],"45":[[0,132,"Let's go!"],[764,892,"Here, honey."],[892,972,"Eat this."],[1084,1184,"Don't just eat the rice."],[1288,1372,"Thanks, honey."],[1444,1696,"Mommy is so good to Daddy."],[2132,2320,"Honey, have some soup."],[2432,2524,"Don't choke."],[2556,2636,"Okay."],[3272,3380,"It's delicious."],[3380,3456,"Honey,"],[3456,3536,"what kind of soup is this?"],[3544,3680,"It's eel soup."],[3740,3960,"I also added yam and goji berries."],[3992,4080,"How is it?"],[4080,4192,"Do you like the taste?"]],"46":[[672,784,"Evie is asleep."],[1084,1164,"Yeah."],[2032,2160,"Honey,"],[2196,2432,"are we taking off tonight?"],[3080,3224,"That depends on"],[3256,3408,"whether you have the stamina."],[4224,4312,"Honey,"],[4324,4592,"tonight I will definitely make you fly high."]],"47":[[236,344,"Boss, bad news!"],[344,440,"The plane Dr. Gray was on"],[440,552,"has crashed."],[572,656,"What?"],[656,772,"Is Gordon dead?"],[820,912,"My wife said that"],[912,1080,"the development of the cure for our daughter"],[1080,1200,"is at a critical stage,"],[1200,1388,"and only Gordon can help complete it."],[1432,1568,"And about Evie's legs,"],[1568,1708,"only Gordon can treat them, too."],[1768,1924,"If something happened to Gordon…"],[1984,2052,"No, no."],[2052,2220,"Dr. Gray was only seriously injured."],[2232,2380,"He just can't make it back tonight."],[2680,2840,"Then, what's with such dramatic pauses?"],[2862,2931,"- Well... - Uh."],[3132,3212,"Stop."],[3244,3324,"Come back."],[3528,3660,"Run fifty laps each. That's an order."],[3796,3924,"Boss,"],[3924,4032,"this track,"],[4032,4172,"it's six miles long!"],[4188,4340,"Can we do twenty laps?"],[4436,4536,"Maybe twenty-five?"],[4684,4788,"Make it a hundred."],[4880,4944,"- Yes, sir. - Yes, sir."]],"48":[[92,276,"Alright, I'm going to work."],[288,380,"Take good care of Evie."],[420,524,"Honey,"],[552,748,"what if I miss you?"],[1080,1264,"Was last night not enough?"],[1392,1528,"No."],[1528,1632,"It's never enough."],[1740,1836,"Alright."],[1836,1928,"Once I finish"],[1928,2060,"the medicine for Evie,"],[2112,2196,"I'll be all yours."],[3204,3320,"Listen to Daddy, okay?"],[3352,3432,"- Okay. - Okay."],[3468,3636,"Bye, Mom."],[4112,4200,"Did you hear?"],[4200,4328,"Ms. Sowle secured"],[4328,4468,"that Ten-Billion Contract."],[4484,4616,"I heard about that last night."],[4664,4880,"But I heard Ms. Fisher called"],[4880,4992,"a meeting with all the shareholders today"],[5036,5228,"to remove Ms. Sowle as President."],[5248,5368,"Why?"],[5368,5524,"Didn't Ms. Fisher"],[5524,5668,"already divest her shares?"],[5692,5884,"Apparently, the paperwork isn't done."],[5912,6048,"When Ms. Fisher heard"],[6048,6180,"Ms. Sowle got the Ten-Billion Contract,"],[6240,6356,"she decided not to withdraw."],[6404,6500,"Daddy,"],[6516,6780,"it seems Mom is in trouble again."],[6800,6984,"Evie, with Daddy here,"],[6984,7136,"any trouble will be solved."],[7148,7236,"Let's go upstairs"],[7236,7316,"and stand up for Mom."],[7344,7452,"Okay."],[7828,7888,"Ms. Sowle."],[7888,8020,"Ms. Fisher wants you in the conference room"],[8020,8144,"for the shareholder meeting."],[8168,8288,"Do you know what it's about?"],[8288,8372,"It seems"],[8372,8556,"they plan to remove you as President."]],"49":[[1540,1748,"You guys sure change your tune fast."],[1748,1948,"Yesterday, you threatened to pull your shares,"],[1952,2096,"but today,"],[2096,2364,"you showed up for the shareholder meeting."],[2424,2620,"Sarah, what do you mean by that?"],[2664,2796,"Are you trying to force us all to withdraw?"],[2816,2896,"Before I secured the Ten-Billion Contract"],[2896,3060,"from the Smith Group,"],[3060,3172,"you were all already"],[3172,3300,"processing your withdrawals."],[3332,3512,"Now that I have the contract,"],[3524,3644,"go ahead and withdraw."],[3644,3772,"Be my guest."],[3820,3924,"Sarah,"],[3924,4096,"even if we withdraw our shares,"],[4096,4260,"you can't keep that ten-billion investment"],[4260,4408,"all to yourself."],[4480,4732,"You want a piece of the Ten-Billion Contract?"],[4836,4932,"Have you no shame?"],[5020,5180,"Sarah, say one more word!"],[5212,5312,"So what if I do?"],[5312,5432,"Some people"],[5432,5540,"just deserve to be scolded."],[5604,5660,"You!"],[5712,5772,"Enough!"],[5772,5880,"Sarah,"],[5896,6080,"the Ten-Billion Contract"],[6080,6244,"was signed with the Sowle Group."],[6252,6428,"It's not up to you alone."],[6448,6600,"I don't have time for this nonsense."],[6660,6744,"Spit it out."],[6744,7124,"Why'd you call this shareholder meeting today?"]],"50":[[8,116,"It's simple, really."],[116,244,"We just want you to withdraw from"],[244,348,"the Evie Care Project."],[356,524,"Stop researching that useless drug of yours."],[804,996,"You want me to give up the Evie Care Plan?"],[1084,1164,"On what grounds?"],[1236,1500,"Because you can never complete the project."],[1520,1784,"It will just be a waste of"],[1784,1872,"the Ten-Billion Contract."],[1872,1944,"Ms. Sowle, over the years,"],[1944,2048,"you've focused entirely on"],[2048,2176,"the Evie Care Project,"],[2180,2296,"but it still isn't finished."],[2300,2556,"What if we pour that ten-billion"],[2564,2736,"investment into it and it fails?"],[2736,2916,"Exactly. If it fails"],[2916,3048,"and the Smith Group blames us,"],[3048,3268,"who can bear the consequences?"],[3600,3776,"You want me to give up the Evie Care Project?"],[3956,4116,"Absolutely not."],[4268,4416,"We knew you wouldn't."],[4456,4608,"That's why we're preparing"],[4608,4836,"to remove you as President."],[4880,5012,"The Evie Care Project has reached"],[5012,5120,"its final critical phase."],[5176,5264,"Give me one month,"],[5288,5520,"and I guarantee it will be completed."],[5528,5684,"How exactly are you going to complete it?"],[5684,5808,"Don't think I don't know"],[5808,5960,"that your Evie Care Project requires"],[5960,6096,"Dr. Gray's participation."],[6108,6212,"But now,"],[6212,6480,"Dr. Gray is dead!"],[6596,6696,"What?"]],"51":[[8,150,"Dr. Gray is dead?"],[150,287,"Don't you watch the news?"],[470,570,"At 3:00 AM today,"],[570,804,"flight CE1014 crashed."],[804,862,"Passengers included the State of Haiyver's"],[862,945,"top physician, Gordon Gray."],[1112,1204,"Well?"],[1262,1416,"Do you still think"],[1445,1650,"you can successfully develop your useless drug?"],[1679,1929,"You have only two choices now."],[1945,2204,"Either give up the Evie Care Project,"],[2212,2500,"or leave Sowle Group."],[2500,2729,"Even though Dr. Gray had an accident,"],[2729,2883,"with the Ten-Billion Contract in hand,"],[2883,3045,"I still have a chance"],[3045,3158,"to complete the Evie Care Project."],[3158,3314,"But if I leave Sowle Group,"],[3314,3472,"there's no saving Evie."],[3629,3804,"I won't give up on the Evie Care Project,"],[3900,4062,"and I certainly won't leave Sowle Group."],[4079,4270,"Sarah, do you really think"],[4270,4412,"we can't remove you?"],[4558,4704,"On what grounds? My father"],[5029,5295,"left Sowle Group to me!"],[5391,5475,"I still hold"],[5475,5616,"forty-five percent of the shares."],[5625,5737,"So what?"],[5750,5925,"Our combined shares"],[5925,6050,"total fifty-five percent."],[6079,6304,"That's enough to kick you out."]],"52":[[28,200,"Our combined shares"],[200,328,"total fifty-five percent."],[356,580,"That's enough to kick you out."],[636,720,"You!"],[924,1088,"I declare!"],[1088,1228,"Sarah is hereby removed"],[1228,1352,"from the position of President!"],[1632,1884,"The Ten-Billion Contract belongs to Sowle Group"],[1884,1984,"and has nothing to do with her."],[2000,2084,"Any objections?"],[2540,2628,"I object."],[3340,3460,"I object, too."],[3460,3556,"Who is that?"],[3556,3632,"I don't know."],[3636,3752,"Since when does our company"],[3752,3828,"have another shareholder?"],[4420,4528,"Why are you here?"],[4528,4668,"Dad and I heard"],[4668,4808,"you were in trouble."],[4808,4968,"so we came to stand up for you."],[4968,5068,"That's right, honey."],[5088,5240,"The Smith Group's Ten-Billion Contract"],[5240,5344,"belongs to you."],[5568,5828,"No one else is getting a piece of that pie."]],"53":[[100,260,"It's you again, you b*stard."],[364,580,"I haven't settled the score from last time yet,"],[584,740,"and here you are causing trouble again!"],[740,868,"You dare bring up last time?"],[888,1008,"My wife was kind enough"],[1008,1104,"to let you off the hook then."],[1132,1420,"Did you not learn your lesson?"],[1420,1560,"Let us off, my *ss!"],[1580,1708,"What exactly did you do to us?"],[1708,1832,"Why are we in pain and itching"],[1832,1944,"every day at noon and midnight?"],[1980,2080,"So you do know it hurts."],[2100,2232,"Since you know the pain,"],[2240,2400,"maybe I should dial up the intensity,"],[2460,2634,"so you won't bother my wife ever again."],[3084,3208,"What are you doing?"],[3208,3312,"I'm warning you,"],[3344,3600,"this is the Sowle Group's territory."],[3600,3844,"Violence won't work here."],[4044,4124,"Don't try anything."],[4368,4452,"Fine."],[4904,4984,"Alright."],[5052,5192,"You can proceed with the meeting."],[5192,5272,"I won't lift a finger."],[5288,5392,"But if anyone dares"],[5392,5540,"to give my wife a hard time,"],[6508,6632,"you'd better watch out."],[6632,6940,"Wow, Daddy is so cool!"]],"54":[[4,116,"This guy!"],[116,468,"Who'd know he's such a bad*ss?"],[496,632,"Have a seat, honey."],[716,828,"Don't be afraid to speak your mind."],[872,968,"Sarah,"],[968,1200,"do you think that bringing him here"],[1216,1404,"will save your position as CEO?"],[1404,1488,"Ms. Sowle, since you refuse"],[1488,1596,"to give up the ECP,"],[1596,1728,"we have no choice but to remove you."],[1728,1808,"The Ten-Billion Contract"],[1808,1904,"is too important."],[1904,2044,"We can't gamble on it with you."],[2044,2232,"But what if I can guarantee"],[2244,2444,"that the ECP will be completed?"],[2444,2584,"Dr. Gray is dead."],[2604,2712,"What do you have to guarantee it?"],[2716,2812,"I pledge the forty-five percent"],[2812,2980,"of the shares I hold."],[2996,3168,"If I can't complete the ECP,"],[3168,3412,"I'll give my shares to the company for free."],[3680,3816,"- Well... - Uh."],[3852,3976,"Quit hemming and hawing."],[4004,4188,"Does anyone have an objection"],[4224,4328,"to what my wife just said?"],[4328,4444,"You have guts, Ms. Sowle."],[4496,4684,"If you use your forty-five percent stake"],[4684,4764,"as collateral,"],[4776,4856,"I have no objections."],[4856,4952,"I agree, two."],[4964,5044,"- I agree. - I agree."],[5108,5236,"That's acceptable,"],[5328,5612,"but we need to set a deadline."],[5632,5704,"One month."],[5704,5892,"No, the company can't wait that long."],[6028,6104,"Five days."],[6104,6204,"Ten days."],[6204,6284,"Fine."],[6344,6484,"Then in ten days,"],[6532,6656,"we'll meet at the press conference."]],"55":[[100,188,"Wait."],[200,320,"What now?"],[544,796,"If I can complete the ECP within ten days,"],[820,1160,"you must hand over your shares to me."],[1524,1708,"What? Scared?"],[1708,1816,"If you think my wife can actually"],[1816,1920,"pull this off in ten days,"],[1948,2084,"you'd better get lost right now!"],[2084,2168,"Fine."],[2300,2432,"I just don't believe that"],[2444,2568,"without Dr. Gray,"],[2568,2708,"you can actually develop that junk drug"],[2708,2848,"in just ten days."],[3260,3520,"Hey, it's almost noon."],[3544,3660,"Make sure you enjoy your lunch."],[4080,4168,"Thank you."],[4168,4380,"Honey, no need to be so polite with me."],[4388,4540,"So, about the ten days,"],[4540,4656,"are you confident?"],[4888,5160,"Mom, please don't be sad."],[5160,5360,"If treating me"],[5360,5560,"is stressing you out,"],[5564,5780,"I'll be very sad."],[5952,6052,"Silly girl,"],[6120,6276,"you just need to be happy."],[6276,6372,"Okay?"]],"56":[[75,192,"It's time to hand over those ten"],[196,436,"medical research institutes to my wife."],[512,744,"Don't worry. I'm here."],[856,952,"And I've got your back."],[952,1192,"Alright, take Evie home now."],[1224,1360,"I need to get to work."],[1400,1536,"If they give you any more trouble,"],[1536,1636,"remember to call me."],[1652,1732,"Mhm."],[2032,2220,"Mom, how could Sarah possibly"],[2220,2416,"complete the ECP in just ten days?"],[2432,2600,"Her only chance now"],[2612,2780,"is to find Dr. Gray's disciple."],[2812,2944,"Dr. Gray's disciple?"],[2996,3156,"Is that the Little Sage, Luther,"],[3156,3292,"who claims to have received"],[3292,3452,"Dr. Gray's true teachings?"],[3464,3552,"Exactly."],[3560,3744,"But Luther disappeared years ago."],[3760,3900,"Where is Sarah supposed to find him?"],[3916,4104,"I heard that Luther"],[4104,4244,"came to Hayville recently"],[4264,4364,"and joined the Lane family."],[4402,4576,"So that little b*tch"],[4576,4684,"will either have to give us her shares"],[4684,4788,"in ten days,"],[4788,5184,"or walk into the lion's den to find Luther."],[5336,5608,"Neither path leads anywhere for her."],[5656,5808,"Hahaha!"]],"57":[[383,583,"Ms. Sowle, Dr. Gray's disciple, Luther,"],[583,750,"indeed arrived in Hayville recently."],[812,945,"Really? Where is he?"],[945,1062,"Luther is elusive,"],[1062,1187,"but we found out that"],[1187,1333,"he frequents the Evernight Club."],[1337,1483,"The Evernight Club?"],[1483,1591,"Yes, Ms. Sowle."],[1591,1787,"The Evernight Club is quite special."],[1800,1950,"It's hard for ordinary people to get in."],[1958,2037,"I got it."],[2650,2800,"Hello, Mandy?"],[2825,2920,"I remember"],[2920,3120,"you work as a manager at the Evernight Club."],[3158,3340,"I need to ask you for a favor."],[3600,3737,"Uh, how do I play this?"],[3737,3929,"It's intense, thrilling, and wonderful…"],[4629,4737,"My wife needs to finish"],[4737,4812,"the Evie Care Project within ten days."],[4858,4970,"Arrange for the top ten"],[4975,5079,"medical research institutes."],[5120,5170,"I want them moved"],[5170,5262,"to Hayville by tomorrow."],[5279,5358,"Yes, Boss."],[5362,5537,"By the way, how is Gordon?"],[5545,5612,"He's fine."],[5612,5750,"He'll arrive in Hayville tomorrow morning."],[5787,5850,"Good."],[5850,5929,"By the way, Boss,"],[6020,6170,"we have news on the leader of The Shades."],[6170,6208,"And?"],[6208,6325,"It seems the leader of The Shades"],[6325,6450,"has contacted the Lane family."],[6450,6554,"And the Evernight Club"],[6554,6637,"is also suspected to be"],[6637,6729,"one of their strongholds."],[6762,7008,"The Lane family and the Evernight Club?"],[7016,7100,"Boss,"],[7100,7191,"why don't we just wipe out the Lane family"],[7191,7291,"and the Evernight Club?"],[7308,7387,"We can force them to give up"],[7387,7504,"the leader's hiding spot."],[7529,7700,"That would only alert the enemy."],[7725,7804,"Just keep an eye on the Lane family"],[7804,7891,"and the Evernight Club."],[7925,8150,"Lure them out if necessary."],[8166,8250,"Yes, Boss."]],"58":[[920,1112,"Are you sure that college classmate of yours"],[1112,1204,"is really coming?"],[1204,1412,"Don't worry, Luther."],[1412,1533,"If she wants to make that special drug,"],[1533,1633,"she has to rely on you."],[1691,1854,"Is she really as beautiful as you say?"],[1854,1991,"I won't lie to you."],[1995,2158,"She's Sarah Sowle,"],[2158,2462,"the most beautiful woman in Hayville."],[2595,2783,"Surely you've heard of her, Luther?"],[2791,2958,"Sarah?"],[3137,3229,"Oh, boy."],[3241,3350,"What's wrong, Luther?"],[3391,3512,"Sarah is the woman"],[3512,3712,"Leonard has his eyes on."],[3712,3879,"I can't touch her."],[3879,3937,"Otherwise,"],[3937,4187,"it might cause a rift with Leonard."],[4200,4408,"Luther, why don't you just"],[4408,4562,"give Leonard a heads-up first?"],[4562,4775,"You two can share her then."],[4791,4908,"After all, Sarah"],[4908,5020,"got pregnant out of wedlock,"],[5025,5137,"so she's long past being chaste."],[5162,5370,"Hahaha, great idea."],[5904,6204,"Luther, Sarah is stubborn."],[6204,6316,"I'm afraid if she won't"],[6316,6433,"cooperate obediently,"],[6441,6625,"it might spoil the fun for you two."],[6658,6891,"Why don't we spike her drink?"]],"59":[[24,424,"No need. The feistier she's, the more exciting it gets."],[424,552,"Hahahaha."],[552,736,"Besides, she needs my help."],[752,868,"Whatever you say, Luther."],[2168,2321,"Sarah, you're finally here."],[2324,2396,"Have a seat."],[2636,2824,"Sarah, let me introduce you."],[2824,2968,"This is Dr. Gray's"],[2968,3060,"personal disciple,"],[3060,3224,"the Little Sage, Luther."],[3224,3504,"Dr. Long, I've heard a lot about you."],[3952,4132,"Hahaha."],[4240,4384,"Dr. Long,"],[4384,4488,"I came here"],[4512,4700,"to invite you to join the Sowle Group."],[4764,4900,"As long as you can help me"],[4904,5000,"complete the drug development"],[5000,5100,"for the Evie Care Project,"],[5152,5272,"you will surely go down in history."],[5324,5592,"And of course, there will be plenty of benefits."],[5632,5732,"No problem."],[5740,5952,"It's just developing drugs, right?"],[5972,6244,"I can do it, but I don't want money."],[6280,6524,"I don't care about going down in history either."],[6536,6692,"Then, Dr. Long,"],[6724,6844,"what do you want?"],[6864,6988,"I only want one thing."],[7048,7252,"And that is you, Ms. Sowle."]],"60":[[29,150,"I only want one thing."],[212,420,"And that is you, Ms. Sowle."],[625,729,"Hahaha."],[729,941,"Dr. Long, please show some respect."],[941,1029,"I'm married."],[1066,1283,"Sarah, why get so worked up?"],[1300,1420,"So what if you're married?"],[1420,1566,"Dr. Long doesn't mind,"],[1566,1720,"so why should you care?"],[1750,1979,"Besides, Dr. Long"],[1979,2187,"is highly accomplished in the medical field."],[2200,2337,"If you take good care of him,"],[2337,2566,"it'll benefit your company too, right?"],[2650,2708,"Mandy."],[2779,2962,"I came here to discuss legitimate business."],[2979,3204,"Sarah, stop pretending."],[3229,3300,"Everyone knows"],[3300,3454,"you got pregnant out of wedlock five years ago."],[3479,3679,"You've been damaged goods for a long time."],[3700,3850,"Yet here you are acting innocent,"],[3883,4062,"talking about 'legitimate business'."],[4070,4200,"It's laughable."],[4237,4350,"Alright, enough."],[4350,4462,"Cut the crap."],[4462,4608,"Mandy already told me."],[4616,4762,"You're researching this miracle drug"],[4762,4929,"just to save your daughter, aren't you?"],[4945,5129,"Sure, no problem."],[5145,5283,"If you service me well,"],[5316,5483,"I'll help you develop the drug."],[5550,5945,"Or you can just watch your daughter drop dead."],[5945,6149,"How can Dr. Gray's true disciple"],[6185,6343,"be such a degenerate?"],[6397,6472,"How could a man like this"],[6520,6624,"possibly help me"],[6626,6814,"develop a cure?"],[6950,7045,"I'm right here,"],[7150,7245,"and I'll guarantee everything works out."],[7300,7458,"Have you made up your mind?"],[7466,7566,"If you want to save your daughter,"],[7566,7720,"take off your clothes. Now."],[7883,7979,"I can treat my daughter's illness"],[7995,8141,"on my own."],[8262,8504,"Coming here today was a mistake. Goodbye."],[8566,8700,"You think the Evernight Club"],[8700,8829,"is a place you can just come"],[8829,9000,"and go as you please?"],[9087,9300,"Exactly. Since you're here,"],[9300,9437,"be a good girl and stay."]],"61":[[162,500,"The Prince and Cinderella lived happily together,"],[500,725,"never to be parted."],[1708,1866,"Boss, I just saw Ms. Sowle"],[1866,1983,"heading into the Evernight Club."],[1991,2112,"The Evernight Club?"],[2150,2233,"What is she doing there?"],[2233,2358,"She seems to be looking for"],[2358,2516,"Dr. Gray's disciple, Luther."],[2525,2750,"Luther? Is he the traitor"],[2750,2820,"Gordon spoke of?"],[2820,3129,"Yes. Luther is greedy and lecherous."],[3145,3283,"He might have already joined The Shades."],[3312,3408,"Keep a close watch."],[3441,3520,"I'm heading over there now."],[4454,4529,"Mr. Smith."],[4529,4633,"What is it?"],[4662,4883,"Ms. Sowle secured the ten-billion contract,"],[4883,5041,"but the shareholders of the Sowle Group"],[5041,5283,"are using the Evie Care Project to corner her."],[5295,5562,"With Dr. Gray dead in that plane crash,"],[5566,5708,"Ms. Sowle had no other choice"],[5708,5820,"but to go to the Evernight Club"],[5820,5916,"to find Luther."]],"62":[[28,268,"Luther? At the Evernight Club?"],[272,452,"Yes, the Evernight Club."],[452,620,"It's a mysterious underground faction in Hayville."],[636,736,"As for Luther,"],[748,960,"he claims to be Dr. Gray's disciple,"],[960,1072,"but he's trouble."],[1072,1168,"This is outrageous!"],[1224,1300,"That Ten-Billion Contract"],[1300,1460,"was a gift for my daughter-in-law."],[1512,1612,"What does it have to do"],[1612,1716,"with those people at the Sowle Group?"],[1752,1920,"Mr. Smith, Ms. Sowle"],[1920,2020,"might be in danger."],[2040,2292,"Go, take some men to the Evernight Club at once."],[2372,2536,"I'll see who dares bully my daughter-in-law."],[2536,2592,"Yes, sir."],[2604,2652,"Let's go."],[2896,3116,"Sarah, I hadn't even come looking for you,"],[3116,3288,"and here you are, delivering yourself to me."],[3288,3476,"Are you that eager to throw yourself at me?"],[3496,3720,"Leonard, what do you want?"],[3720,3824,"What do you think?"],[3852,4060,"I was beaten by your wild man several times."],[4100,4208,"Today,"],[4208,4424,"I'm going to take it all out on your body!"],[5052,5160,"Sarah,"],[5160,5260,"your job today"],[5260,5480,"is to service Luther and Leonard well."],[5528,5728,"No one is going to interrupt."],[5992,6100,"Stop her!"]],"63":[[141,304,"Leonard, why don't we"],[304,433,"deal with her together later?"],[533,687,"Sure. This woman"],[687,779,"isn't pure anymore anyway."],[837,1000,"Let me go!"],[1000,1179,"If you cooperate obediently,"],[1179,1333,"I might consider letting you go."],[1370,1470,"Even if I die,"],[1554,1729,"I won't let you have your way!"],[2229,2433,"This chick is pretty stubborn."],[2433,2616,"Mr. Long, Leonard,"],[2637,2754,"I think she"],[2754,2912,"really will fight to the death."],[2929,3116,"Why don't we drug her?"],[3129,3329,"Wait untill she experiences your prowess,"],[3329,3466,"and she'll naturally become obedient."],[3466,3645,"All women are like that."],[3662,3845,"Makes sense. Add the drug."],[3845,3954,"No!"],[3966,4225,"Mandy, we were college classmates!"],[4262,4433,"I used to help you all the time!"],[4604,4733,"Shut up, Sarah."],[4762,4966,"I couldn't stand you back in college!"],[4975,5141,"Giving me your hand-me-downs,"],[5141,5254,"handing out food like charity…"],[5262,5387,"Stop acting like a saint."],[5412,5545,"You think you're so high and mighty,"],[5545,5675,"acting like you're so special."],[5691,5829,"Today, I'm going to turn you"],[5829,5995,"into a total slut."]],"64":[[0,136,"Today, I'm going to turn you"],[136,304,"into a total slut."],[1780,1884,"Mandy!"],[1952,2104,"You'll pay for this!"],[2284,2364,"Ah!"],[2364,2448,"Don't touch me, you b*stards!"],[2448,2632,"Don't touch me! Let go!"],[2636,2700,"Scream all you want."],[2708,2848,"You can scream your throat raw,"],[2848,3020,"but no one is coming to save you today."],[3028,3188,"The louder you scream,"],[3188,3436,"the more excited we get."],[3840,4104,"Leonard, looks like the drug is kicking in."],[4348,4428,"Ethan…"],[4548,4668,"Come save me…"],[4692,4816,"Even now,"],[4816,4980,"you're still hoping that lover of yours"],[4980,5048,"will come to save you?"],[5080,5248,"This is the Evernight Club."],[5264,5380,"He can't even get in,"],[5400,5528,"and even if he did,"],[5532,5620,"he'd just be crawling on the ground,"],[5620,5732,"watching you get ravaged."],[5760,5864,"Let's not waste any time."],[5864,5972,"Let's get started."],[6060,6268,"Hahaha!"],[6412,6540,"Let go of my wife!"]],"65":[[72,180,"You have a death wish!"],[752,872,"Honey, are you okay?"],[872,1120,"I knew you would come."],[1144,1264,"Where did this loser come from?"],[1264,1396,"Do you have any f**king idea who you just hit?"],[1396,1540,"You're searching for death!"],[2600,2768,"You little punk,"],[2780,2900,"you actually have the guts to show up."],[2912,3112,"You're not leaving here alive today!"],[3888,3984,"Listen, punk."],[3992,4132,"Last time at the charity gala,"],[4132,4260,"you managed to slip away,"],[4264,4668,"but today, there's no escape!"],[4800,4928,"You dare to touch my wife?"],[4928,5168,"None of you is leaving today!"],[5340,5424,"How dare you!"],[5424,5560,"Get him, boys!"],[5580,5660,"Cripple this guy!"],[6816,7024,"I see you're pretty arrogant."],[7024,7196,"Turns out you know how to fight."],[7220,7336,"But even if you're an expert,"],[7348,7484,"once you step into the Evernight Club,"],[7484,7620,"you'll still end up crawling on the floor."],[7648,7896,"You think you're so f**king tough, kid?"],[7900,8048,"This is the Evernight Club."],[8056,8196,"We have hundreds of fighters"],[8208,8340,"and over a dozen masters."],[8356,8536,"You're dead meat today!"],[9476,9564,"Don't bother clapping."],[9596,9764,"I've already dealt with your men outside."]],"66":[[172,300,"Mr. Smith, why are you here?"],[484,628,"You reckless fool."],[664,736,"Mr. Smith,"],[736,944,"I didn't bully your granddaughter this time."],[968,1120,"It's all because of this b*tch,"],[1120,1176,"Sarah."],[1176,1324,"She took your Ten-Billion Contract"],[1340,1492,"to research some garbage drug."],[1512,1640,"She's totally scamming you!"],[1640,1844,"I was just teaching her a lesson for you!"],[2164,2244,"You scumbag."],[2280,2412,"How dare you touch my family!"],[2592,2680,"What are you waiting for?"],[2680,2800,"Take him away."],[3704,3840,"Make sure they suffer."],[3880,3944,"Don't worry."],[3944,4076,"Anyone who bullies my family"],[4080,4242,"will pay the price."],[4244,4320,"- Mr. Sm... - Wilson."],[4320,4360,"Mr. Smith!"],[4360,4408,"Shut the door!"],[4408,4600,"Mr. Smith! Mr. Smith!"],[4600,4732,"- Ah! - Whoa"],[5240,5412,"Honey, can you make it home?"],[5588,5680,"What do you think?"],[5748,5846,"It's a good thing I sent Blaze"],[5848,6032,"to watch over Evie."],[6644,6928,"Honey, kiss me, quick."]],"67":[[212,392,"Honey, what's wrong?"],[396,492,"Are you still feeling unwell?"],[528,636,"Unwell? What do you mean?"],[636,832,"You worked so hard last night."],[856,980,"Honey, it was clearly you"],[980,1104,"who was too rough last night."],[1108,1224,"Look, I have proof."],[1244,1408,"Okay, okay, stop."],[1408,1552,"Why are you taking your clothes off here?"],[1748,1864,"Alright, honey."],[1864,2004,"Don't be sad."],[2016,2144,"Give me a smile."],[2192,2384,"How can I smile right now?"],[2404,2548,"With Dr. Gray gone,"],[2568,2672,"and his only disciple"],[2672,2772,"having that kind of attitude,"],[2772,2932,"finishing the Evie Care Project"],[2932,3032,"alone within ten days"],[3056,3160,"is just too hard."],[3176,3324,"They say there's always a twist of fate."],[3324,3492,"And a light at the end of the tunnel."],[3512,3612,"What if Dr. Gray didn't die?"],[3612,3760,"Don't try to comfort me."],[3832,4048,"The plane Dr. Gray was on crashed."],[4192,4312,"How could he possibly have survived?"],[5840,5925,"Hello, Ms. Sowle."],[5933,6056,"Hello, Ms. Sowle."],[6076,6268,"Are you... Dr. Gray?"],[6268,6436,"Yes, that's me."],[6436,6612,"Dr. Gray, weren't you…"],[6628,6784,"Don't listen to the online rumors."],[6836,6996,"Although the plane crashed,"],[7036,7224,"I was saved."],[7332,7564,"That's great! That is really great!"],[7644,7724,"Dr. Gray,"],[7804,8032,"how did you know I was looking for you?"],[8124,8220,"Uh."],[8224,8332,"Honey,"],[8396,8516,"Dr. Gray probably knows"],[8516,8620,"that you're working on"],[8620,8748,"a groundbreaking drug,"],[8748,8972,"so he came specifically to join your team."],[8984,9248,"Yes, yes, exactly, Ms. Sowle."],[9264,9344,"That's exactly it."],[9544,9664,"Is that really it?"]],"68":[[327,483,"Is it really?"],[716,808,"Dr. Gray,"],[856,935,"wasn't it"],[964,1156,"Mr. Smith who sent you here?"],[1388,1483,"Mr. Smith?"],[1548,1580,"Yes."],[1623,1800,"William Smith, the richest man in Haiyver."],[1864,2044,"Didn't he send you?"],[2100,2271,"Oh, right, yes."],[2271,2464,"Mr. Smith did reach out to me."],[2544,2719,"But ultimately,"],[2780,3048,"this drug you're researching"],[3096,3407,"is a major medical breakthrough."],[3471,3643,"We want to be part of it."],[3700,3984,"I thought my wife had figured out my identity."],[4235,4347,"Thank you, Dr. Gray."],[4407,4507,"With you joining us,"],[4579,4700,"I am fully confident"],[4715,4820,"that we can complete the Evie Care Project."],[5028,5360,"They are fellows from the world's top"],[5364,5575,"medical research institutes."],[5639,5728,"There are five more of them,"],[5788,5932,"who should arrive by tomorrow."],[5988,6028,"All of them are willing"],[6067,6296,"to lend you a hand, Ms. Sowle."]],"69":[[16,84,"What?"],[156,308,"Top medical research institutes?"],[408,491,"And five more?"],[540,755,"I can't believe Mr. Smith has such influence."],[819,935,"To think he could invite"],[935,1180,"the world's top ten medical research institutes."],[1200,1240,"Yes."],[1291,1359,"They have practically"],[1403,1719,"moved the most prestigious research institutes"],[1755,1892,"right here to Hayville."],[2255,2296,"Honey,"],[2344,2428,"see, I told you."],[2512,2687,"There's always a light at the end of the tunnel."],[2716,2751,"Look,"],[2800,2903,"good things are finally coming our way."],[2939,3083,"But this good news,"],[3103,3267,"isn't it a little too good to be true?"],[3815,3871,"What?"],[3943,4092,"Sarah went looking for Luther,"],[4135,4224,"but was saved by Mr. Smith?"],[4320,4400,"Yes, Mom."],[4425,4596,"And Dr. Gray isn't dead."],[4603,4728,"Early this morning, I saw"],[4732,4888,"Dr. Gray going to Sarah's villa."],[5071,5156,"D*mn it."],[5184,5256,"How is this possible?"],[5447,5492,"Mom,"],[5535,5803,"Mr. Smith must be the one"],[5803,5892,"who sent Dr. Gray to see Sarah."],[5932,6024,"That little b*tch."],[6088,6152,"She actually got such huge support"],[6152,6275,"from Mr. Smith."],[6396,6443,"Mom,"],[6515,6615,"what should we do?"],[6659,6800,"Now that she has Dr. Gray,"],[6831,7004,"if she really completes"],[7007,7100,"the Evie Care Project within ten days,"],[7151,7271,"are we really just going to"],[7295,7392,"hand our shares over to her?"]],"70":[[316,496,"Even with Dr. Gray's help,"],[563,632,"that b*tch"],[663,811,"can forget about finishing the project."],[843,880,"Mom,"],[956,1027,"do you have a plan?"],[1051,1111,"Don't forget,"],[1251,1388,"we have our people"],[1388,1488,"inside the lab where Sarah"],[1491,1632,"is developing the drug."],[1692,1996,"As long as we swap the ingredients,"],[2051,2167,"then what she produces"],[2207,2412,"won't be a miracle cure,"],[2435,2544,"but poison."],[2780,2864,"If Sarah"],[2864,3051,"ends up creating poison,"],[3112,3300,"I'd like to see how she explains that"],[3360,3479,"at the launch event in ten days."],[3671,3747,"Mr. Smith"],[3824,3984,"gave that b*tch a massive contract"],[4003,4135,"and invited Dr. Gray to help her."],[4256,4524,"If she produces poison,"],[4564,4771,"Mr. Smith will surely be furious."],[4856,4915,"When that happens,"],[4928,5096,"she'll be done for."]],"71":[[24,200,"Thank you for healing my wounds, King of Shades!"],[239,304,"Speak."],[335,479,"How exactly did this happen?"],[504,624,"It's that b*tch, Sarah."],[671,811,"You told me to capture her"],[832,919,"to develop drugs for you,"],[959,1056,"but she refused to comply."],[1056,1164,"Get to the point!"],[1224,1267,"Yes,"],[1311,1383,"KOS."],[1440,1491,"Last night,"],[1527,1639,"I tried to seize her,"],[1676,1800,"but William Smith suddenly appeared"],[1844,1928,"and saved her."],[2064,2144,"The Darknight Club"],[2167,2300,"was also taken down by him."],[2419,2528,"Preposterous!"],[2551,2616,"KOS,"],[2660,2803,"now Dr. Gray has also joined"],[2803,2916,"their drug research."],[2971,3132,"Rumor has it that in ten days,"],[3176,3271,"Sarah will hold"],[3275,3371,"a drug launch event!"],[3503,3615,"Ten days."],[3671,3824,"That is enough time."],[3896,4032,"Go make the arrangements."],[4075,4184,"In ten days,"],[4220,4415,"I will come out of seclusion!"],[4415,4456,"Yes,"],[4484,4567,"KOS."],[4584,4707,"Sarah,"],[4756,4852,"Ethan,"],[4875,4988,"William."],[5015,5203,"Once KOS emerges,"],[5271,5439,"you'll wish you were dead!"]],"72":[[224,272,"Honey,"],[316,479,"you're the star of the launch today."],[532,675,"Why dress me up so formally?"],[708,827,"You're my husband."],[872,1008,"Of course you have to join me."],[1159,1243,"So handsome."],[1272,1359,"You bet."],[1367,1475,"Look whose husband I am."],[2087,2167,"Mommy, Daddy,"],[2183,2380,"do I look pretty?"],[2667,2735,"Evie,"],[2760,3028,"you're so pretty, you're blinding Daddy!"],[3267,3332,"Evie,"],[3392,3535,"you've been running around so much."],[3552,3684,"Are you feeling okay?"],[3728,3875,"Don't worry, Mommy."],[3879,3992,"Dr. Gray told me"],[4003,4147,"that I need to exercise more."],[4400,4447,"Alright."],[4488,4660,"All the hardships of the past"],[4679,4760,"are behind us now."],[4788,4879,"Now that you have me,"],[4900,5015,"you and Evie"],[5015,5228,"will be even happier."],[5400,5435,"So,"],[5488,5584,"is the medicine ready?"],[5639,5703,"Yes, it is."],[5796,5871,"Let's go."],[5935,5988,"Let's go, Evie."],[6047,6075,"Let's go."],[6892,6948,"Ms. Sowle,"],[6968,7140,"we heard that the drug you're launching"],[7159,7300,"has been in development for five years"],[7312,7384,"and can cure all diseases"],[7384,7507,"caused by genetic mutations."],[7523,7600,"Is that true?"],[7628,7679,"Ms. Sowle,"],[7695,7815,"ten days ago, in the final sprint"],[7815,7931,"of the drug's development,"],[7948,8071,"did you sign a betting agreement"],[8071,8179,"with the other shareholders of Sowle Group?"],[8204,8340,"Do you have confidence in yourself?"],[8348,8476,"If the launch fails,"],[8476,8620,"what will happen to you?"],[8700,8840,"For this drug launch,"],[8871,9023,"there is no such thing as failure."],[9143,9295,"Who gave you that confidence?"]],"73":[[20,167,"Who gave you that confidence?"],[524,628,"Are you really so sure"],[628,796,"that your drug is a success?"],[843,951,"What do you mean?"],[1035,1127,"Nothing."],[1164,1272,"I'm just letting you know"],[1340,1472,"that when the drug is launched,"],[1503,1692,"we're going to inspect it very carefully."],[1755,1848,"You don't know sh*t."],[1900,1980,"How would you inspect it?"],[2012,2100,"We might not understand it,"],[2144,2264,"but we can hire an expert, can't we?"],[2364,2464,"Suit yourselves."],[2507,2700,"Just make sure you have the"],[2700,2807,"share transfer agreements ready."],[2823,2892,"You!"],[2932,2987,"Let's go."],[4571,4703,"What a trashy family."],[4752,4803,"Ms. Fisher."],[4820,4967,"Ms. Sowle seems quite confident."],[5020,5184,"She didn't actually succeed, did she?"],[5196,5300,"Yes, Ms. Fisher."],[5328,5460,"This concerns whether we can"],[5503,5607,"hold onto our shares or not."],[5671,5752,"Why are you panicking?"],[5792,5884,"She's only confident"],[5947,6071,"because she thinks"],[6071,6184,"the development was a success."],[6192,6275,"But in fact,"],[6307,6379,"what she developed"],[6435,6531,"is poison."]],"74":[[4,80,"Exactly."],[139,256,"When she launches the drug,"],[275,391,"we'll expose the truth publicly."],[463,575,"Let's see how she cleans up that mess."],[591,724,"When will Mr. Lee get here?"],[779,875,"I've already notified him."],[875,940,"He'll be here soon."],[1540,1628,"Hello, everyone."],[1692,1871,"Thank you for taking the time to be here."],[1896,2164,"to attend the Sowle Group's new drug launch."],[2335,2539,"What I'm holding right now"],[2580,2700,"is the specific drug that I've spent"],[2700,2823,"five years developing."],[2880,2932,"It can treat any disease"],[2935,3160,"caused by genetic mutations."],[3264,3588,"I have named this drug"],[3660,3728,"Evie Care."],[3867,4067,"Are you sure the drug in your hand"],[4084,4139,"can really treat diseases"],[4139,4335,"caused by genetic mutations?"]],"75":[[152,316,"Are you certain that what you're holding"],[316,492,"is really a miracle cure"],[492,612,"for genetic diseases?"],[628,740,"What do you mean?"],[772,888,"It's obvious."],[944,1060,"I suspect your \"miracle drug\""],[1060,1232,"was never successfully developed."],[1236,1388,"And that what you're holding"],[1392,1540,"is just a semi-finished product."],[1544,1648,"Or perhaps,"],[1684,1804,"it is a poison."],[1864,1928,"Evie's illness"],[1928,2068,"was cured by this very drug."],[2068,2072,"Evie's illness was cured by this drug!"],[2072,2192,"It's not poison!"],[2276,2364,"You little brat."],[2420,2512,"When grown-ups are talking,"],[2536,2656,"children shouldn't interrupt."],[2656,2660,"Why is a child interrupting the adults?"],[2676,2744,"Besides,"],[2760,3012,"who knows if you're actually cured?"],[3048,3188,"Oh, right."],[3260,3308,"It's also possible"],[3308,3548,"that what you took was poison."],[3584,3720,"That's not true!"],[3720,3912,"You're all bad people!"],[4268,4348,"You brat,"],[4392,4532,"if you keep spouting nonsense,"],[4548,4756,"I'll rip your mouth open!"],[5204,5256,"Who gave you the right"],[5256,5392,"to speak to my daughter like that?"],[5460,5536,"I'm going to teach you a lesson!"],[5796,5844,"Don't be scared."],[5892,6000,"Daddy's got your back."],[6056,6188,"Okay. Thank you, Daddy."]],"76":[[156,252,"Sarah!"],[280,288,"This is a press conference!"],[288,480,"We're at a press conference!"],[480,620,"In front of all this media,"],[620,800,"you're just letting your husband hit us?"],[1012,1176,"Some people have foul mouths."],[1212,1476,"If you don't slap them, they just get worse."],[1476,1632,"Was my husband wrong to hit you?"],[1644,1720,"You!"],[1732,1820,"Enough."],[1884,2156,"We didn't come here to bicker."],[2212,2480,"Sarah, don't get too cocky."],[2484,2592,"I heard"],[2604,2708,"that William Smith,"],[2708,2876,"in order to get you to develop this cure,"],[2900,3096,"gave you the Ten-Billion Contract"],[3100,3256,"and hired Dr. Gray for you."],[3328,3440,"But if today,"],[3440,3604,"what you're holding turns out to be poison,"],[3660,3744,"do you think"],[3776,3988,"he will let you off the hook?"],[4144,4312,"The Ten-Billion Contract is nothing!"],[4366,4518,"Even if it were trillions,"],[4522,4592,"I'd still give it"],[4596,4720,"to my daughter-in-law!"]],"77":[[44,244,"I said, ten billion is nothing!"],[244,504,"I'd give trillions"],[504,660,"to my daughter-in-law!"],[836,944,"Whatever I give my daughter-in-law,"],[944,1020,"the Ten-Billion Contract included,"],[1020,1144,"is none of your d*mn business!"],[1164,1280,"Did I hear that right?"],[1280,1384,"Mr. Smith said"],[1384,1564,"Ms. Sowle is his daughter-in-law?"],[1568,1640,"But isn't Ms. Sowle's husband"],[1640,1816,"that man named Ethan?"],[1828,2008,"Is Ms. Sowle two-timing?"],[2100,2380,"Grandpa, you're finally here!"],[2380,2568,"I missed you so much!"],[2568,2640,"My darling granddaughter,"],[2640,2780,"Grandpa missed you too!"],[2780,2824,"How are you feeling?"],[2824,2912,"Have you felt any discomfort"],[2912,3004,"these past two days?"],[3020,3304,"I'm fine. Nothing hurts anymore."],[3304,3420,"I can walk now,"],[3420,3564,"and I'm healthy and strong."],[3580,3704,"I can play with Grandpa from now on."],[3704,3876,"We can play hide-and-seek!"],[3888,3996,"That is wonderful."],[4020,4208,"Let's go to Smith Manor then."],[4208,4400,"It's big enough for you to hide anywhere, okay?"],[4400,4500,"Mm-hmm!"],[4556,4636,"Mr. Smith,"],[4696,4840,"how did Sarah"],[4840,4984,"become your daughter-in-law?"],[5084,5128,"Oh, I get it now."],[5128,5208,"Mr. Smith,"],[5240,5364,"you must have accepted this little girl"],[5368,5476,"as your god-granddaughter,"],[5476,5560,"which is why you're calling Sarah"],[5560,5700,"your daughter-in-law."],[5728,5800,"Mr. Smith,"],[5800,5860,"you absolutely must not"],[5860,5952,"let them deceive you!"],[5996,6156,"Exactly, Mr. Smith."],[6204,6396,"Sarah and this little girl"],[6396,6500,"are nothing but trouble."],[6556,6688,"And that wild man"],[6736,6840,"is just a brute"],[6840,6948,"who only knows how to use his fists."]],"78":[[24,140,"Take this instance for example."],[164,404,"You gave Sarah the Ten-Billion Contract"],[432,604,"and even hired Dr. Gray for her,"],[644,884,"but she squandered the money."],[928,1092,"She failed to develop the cure,"],[1144,1324,"and created a poison instead."],[1344,1428,"What makes you so sure"],[1428,1560,"that what I'm holding is poison?"],[1560,1664,"I'll tell you the truth,"],[1700,1844,"Mr. Lee, the expert, will be here any minute."],[1860,2044,"He'll decided if it's poison."],[2044,2304,"You'll be the ones crying then."],[2584,2780,"You're the ones who should be crying."],[2860,2964,"You dare call my daughter-in-law"],[2964,3120,"and granddaughter trouble,"],[3152,3424,"and call my son a wild man?"],[3468,3620,"Who gave you the nerve?"],[3684,3860,"You reckless fools!"],[3860,3928,"What?"],[4008,4144,"Son?"],[4228,4472,"You brat, look at the situation."],[4484,4544,"Are you still not ready"],[4544,4644,"to acknowledge me?"],[4700,4792,"Do you want me"],[4792,4904,"to kneel down and beg you?"],[4908,5112,"If you want to shorten my life,"],[5120,5204,"then go ahead and kneel."],[5228,5332,"I can't stop you."],[5344,5452,"You little rascal."]],"79":[[8,76,"Oh my god,"],[124,244,"Ms. Sowle's husband"],[272,392,"is actually Smith Jr!"],[452,596,"Fiona and Mike have really"],[600,756,"messed with the wrong people this time."],[772,868,"No, no,"],[868,984,"how is that possible?"],[1048,1212,"How could a random wild man Sarah picked up"],[1247,1376,"possibly be Smith Jr?"],[1480,1532,"How dare you!"],[1796,1856,"How dare you insult"],[1858,1968,"Young Master like that?"],[2288,2488,"You reap what you sow."],[2584,2644,"For all these years,"],[2644,2808,"you've bullied my wife,"],[2856,3064,"and today you'll pay for it all."],[3096,3308,"So what if you are Smith Jr?"],[3412,3668,"The Smith Group may be a titan in Haiyver,"],[3752,3964,"but you can't escape the fact that your investment"],[3968,4168,"resulted in nothing but poison."],[4192,4324,"Fine."],[4392,4500,"You're all family, right?"],[4528,4628,"Great."],[4676,4776,"Then today,"],[4812,4948,"you can all be disgraced together!"],[4996,5136,"How can you be so sure"],[5208,5352,"that what my wife made is poison?"],[5404,5508,"I'm positive."]],"80":[[4,124,"In that case,"],[200,380,"let's have an expert verify it."],[424,564,"Oh my god, it's actually"],[564,676,"the top drug identification expert"],[676,792,"in the State of Haiyver."],[804,908,"Although in terms of medical skills"],[908,1044,"and research, Mr. Lee"],[1044,1184,"may not be as good as Dr. Gray,"],[1192,1320,"in the field of drug identification,"],[1320,1484,"he is absolutely in a league of his own."],[1524,1644,"With Mr. Lee's appraisal,"],[1648,1748,"we will know if today's drug"],[1748,1904,"is a miracle cure or poison."],[1904,1992,"The truth will be revealed."],[2012,2284,"Mr. Lee, you're finally here."],[2432,2464,"I heard"],[2464,2632,"someone is passing off poison"],[2632,2764,"as a miracle cure."],[2792,2854,"That's right."],[2940,3088,"It's the pill in her hand."],[3120,3280,"So, Mr. Smith is here."],[3280,3372,"Mr. Lee,"],[3432,3584,"please examine it carefully."],[3628,3776,"I've spent my life evaluating pharmaceuticals,"],[3832,3984,"and I've never been wrong."],[4012,4204,"Mr. Smith, everyone, please rest assured."],[5684,5804,"This is poison."],[5848,5976,"What?"]],"81":[[116,238,"This is poison."],[238,330,"What?"],[718,852,"If this counts as poison,"],[910,1084,"then there are no real medicines in this world."],[1114,1292,"Who claimed this drug was toxic?"],[1358,1402,"In fact,"],[1402,1576,"this drug isn't toxic at all."],[1598,1760,"For treating genetic diseases,"],[1782,1908,"it is absolutely effective."],[1962,2062,"-What? -What?"],[2130,2288,"That old man!"],[2314,2552,"He really kept us in suspense."],[2602,2674,"You really"],[2702,2804,"scared me to death just now."],[2804,2896,"Ms. Sowle."],[3038,3106,"Prof. Lee,"],[3106,3202,"what are you doing?"],[3244,3372,"Ms. Sowle,"],[3412,3545,"this is the most precious,"],[3548,3614,"and meaningful miracle cure"],[3648,3844,"that I have ever evaluated."],[3876,4020,"The properties of this drug can treat"],[4020,4196,"thousands of patients with genetic mutations."],[4240,4388,"Even on a global scale,"],[4392,4548,"it is incredibly rare."],[4548,4666,"You are truly great."],[4688,4756,"Thank you."],[4756,4824,"Thank you."],[5304,5436,"What else do you all have to say?"],[5444,5472,"No…"],[5496,5576,"That's impossible."],[5636,5676,"Mom."],[5692,5812,"Mr. Lee must have made a mistake."],[5832,5873,"I already"],[5873,5984,"had someone swap the ingredients."],[6028,6164,"How... how is this possible?"],[6200,6324,"Screw you."],[6344,6443,"You finally admitted"],[6443,6530,"that you swapped the drugs."],[6604,6704,"Luckily, my husband"],[6704,6846,"saw through your scheme"],[6884,7016,"and beat you at your own game."],[7144,7216,"We also have to thank"],[7216,7344,"the world's top ten"],[7344,7436,"pharmaceutical labs."],[7648,7728,"Security!"],[7748,7840,"Take these two pieces of trash"],[7840,7952,"and send them to prison."],[8000,8128,"Make sure they never get out!"],[8152,8232,"No, sis!"],[8232,8288,"No, no!"],[8288,8392,"- Don't send me to prison! - Sarah!"],[8408,8482,"- For the rest of my life, - Sarah, sorry!"],[8482,8557,"I'll slave away for you!"],[8568,8764,"- Sis, I was wrong! - Let us go!"],[8764,8840,"Slave away for me?"],[8840,8940,"You're not worthy."]],"82":[[276,400,"The snake has finally come out of its hole."],[580,620,"Leonard."],[620,704,"My sister wants to"],[704,784,"send me to the police station."],[796,880,"You're finally here."],[880,1020,"You must help me!"],[1040,1120,"Get lost."],[1416,1496,"Lord KOS!"],[1780,1900,"What are you all staring at?"],[1940,2060,"Lord KOS has arrived."],[2060,2196,"Make way!"],[2300,2348,"Leonard,"],[2348,2452,"today is the Sowle Group's"],[2452,2560,"drug launch event."],[2560,2688,"Why are you here?"],[2720,2888,"Leonard, may I ask who this is?"],[3004,3100,"Get lost!"],[4024,4092,"You b*tch."],[4112,4256,"With Lord KOS here today,"],[4284,4416,"I'm going to turn this launch event"],[4444,4568,"into a funeral."],[4640,4760,"You little punk,"],[4760,4780,"and you,"],[4780,4928,"you old geezer,"],[4928,5076,"you'll all suffer a fate worse than death."],[5076,5188,"I remember now."],[5200,5284,"KOS?"],[5336,5500,"Isn't he the leader of The Shades?"],[5508,5612,"What?"],[5656,5760,"The Shades?"],[5760,5920,"The world's largest underground organization?"],[5960,6040,"We're doomed."],[6068,6180,"When KOS gets angry,"],[6204,6324,"there will be a bloodbath."],[6380,6468,"Mr. Smith,"],[6468,6608,"this doesn't look good."],[6610,6780,"I can't believe KOS showed up here."],[6808,6880,"Leonard."],[6912,7056,"Mr. Smith is right here."],[7056,7160,"Do you dare cause a scene?"],[7236,7420,"So what if he's the richest man in the country?"],[7440,7604,"In front of Lord KOS,"],[7620,7776,"he's nothing but an ant."],[7776,7948,"Was it you who led the raid"],[7976,8264,"on my club?"],[8268,8528,"Bad man! Don't bully my Grandpa!"],[8528,8668,"Where did this wild brat come from?"],[8696,8784,"Get lost!"]],"83":[[44,312,"You reckless fool!"],[360,478,"That is Smithes' Head Steward,"],[482,716,"the Capital's top fighter?"],[790,862,"Pfft."],[896,1016,"You're KOS, right?"],[1072,1160,"Since you're here,"],[1260,1392,"then die here."],[1402,1702,"How dare you, you little punk."],[1742,1918,"You're at death's door, yet you still talk big."],[1992,2072,"Do you really think knowing"],[2072,2232,"a little fighting makes you invincible?"],[2262,2458,"Yeah, has this kid lost his mind?"],[2488,2552,"He actually threatened"],[2556,2720,"to kill KOS right here."],[2788,2888,"Even the Capital's top fighter"],[2890,3078,"couldn't last a single round against KOS."],[3104,3212,"Who does he think he is?"],[3258,3322,"Son,"],[3422,3546,"take your wife and Evie and leave."],[3572,3656,"I'll hold them off here."],[3728,3820,"Dad,"],[3864,3972,"can you actually stop them?"],[4072,4212,"I'll hold them back whether I can or not."],[4252,4428,"My son finally acknowledged me today,"],[4432,4572,"and I have such a wonderful daughter-in-law"],[4580,4680,"and granddaughter."],[4712,4876,"I'll put my life on the line today,"],[4876,4980,"I won't let anything happen to you."],[4996,5332,"Grandpa, I won't let you die!"],[5368,5488,"I still want to play"],[5488,5740,"hide-and-seek with Grandpa!"],[5872,6036,"All of this started because of me."],[6120,6252,"They're targeting me."],[6304,6412,"If there really must be"],[6412,6516,"someone to sacrifice,"],[6612,6728,"then let me stay behind."]],"84":[[8,144,"Let me be the one."],[156,236,"Ethan,"],[284,456,"take good care of our daughter."],[484,636,"Mommy, Evie doesn't"],[636,888,"want to leave you!"],[1148,1224,"Enough."],[1320,1388,"Cut the melodrama."],[1524,1624,"Don't cry, Evie."],[1668,1752,"Grandpa and Mommy"],[1752,1852,"aren't going anywhere."],[1872,1952,"Trust Daddy,"],[1952,2060,"I can definitely handle the bad guys."],[2084,2220,"Oh, you brat."],[2220,2304,"You probably haven't realized"],[2304,2432,"the gravity of the situation."],[2460,2604,"What have you done in the last two years?"],[2604,2748,"Besides delivering takeout and selling fruit,"],[2752,2884,"look what a mess you've become."],[2884,2956,"You simply"],[2956,3048,"cannot handle KOS."],[3084,3200,"Listen to me, take them and go."],[3200,3312,"But what if"],[3416,3520,"I can actually beat"],[3520,3628,"this bullsh*t KOS?"],[3628,3864,"Haha! Who do you think you are?"],[3868,4068,"Daring to claim you can beat KOS?"],[4124,4248,"In this world,"],[4248,4544,"only the Dragon Lord can defeat KOS."],[4564,4836,"That's right. The most mysterious power,"],[4872,5004,"the Hall Master of Dragon Hall."],[5004,5156,"If the Dragon Lord were here,"],[5176,5316,"he could surely defeat KOS."]],"85":[[0,152,"If the Dragon Lord were here,"],[172,312,"he could surely defeat KOS."],[332,564,"Supreme in the world, the KOS Alliance."],[600,708,"Unless the Dragon Lord appears,"],[708,832,"who can challenge us?"],[844,1002,"What a pity."],[1002,1200,"Haven't heard of Dragon Hall's news for years."],[1232,1412,"And the Dragon Lord has vanished."],[1444,1648,"The old Dragon Lord is probably dead by now."],[1672,1764,"So today,"],[1828,1980,"none of you will escape."],[2020,2104,"Is that so?"],[2184,2348,"Cut the crap."],[2348,2544,"Lord KOS, make your move!"],[2644,2752,"Step aside."],[4980,5164,"- Dragon Lord! - Dragon Lord!"]],"86":[[608,772,"- Dragon Lord! - Dragon Lord!"],[816,952,"Th-this is…"],[1008,1124,"The Dragon Guard!"],[1540,1776,"Wow, so cool!"],[1820,2004,"No, no."],[2004,2120,"How could you be him?"],[2336,2440,"I'm done pretending."],[2484,2584,"I'm putting my cards on the table."],[2660,2864,"I am the Dragon Lord you speak of."],[3068,3148,"Lord KOS."],[3200,3316,"What do we do now?"],[3380,3488,"You can't do anything right,"],[3488,3636,"you good-for-nothing idiot!"],[3636,3720,"Get lost!"],[4332,4428,"It wasn't easy."],[4452,4592,"I've been looking for you for five whole years."],[4640,4816,"My plan to lure the snake out of its hole,"],[4860,4976,"pretty slick, huh?"],[5072,5232,"D*mn it."],[5272,5476,"In the end, I was still"],[5476,5656,"outsmarted by you, brat."],[5736,6244,"But the winner hasn't been decided yet!"]],"87":[[16,556,"We'll see who dies today!"],[3160,3388,"I can't believe"],[3400,3660,"you've actually cultivated to"],[3660,3868,"the Infinite Realm."],[3960,4400,"I've lost."],[4692,4796,"Done."],[4796,4996,"Thunder, Blaze, clear the area."],[4996,5108,"- Yes, sir. - Yes, sir."],[5672,5788,"Daddy,"],[5796,6056,"you're so amazing!"],[6096,6368,"Son, you're really the Dragon Lord?"],[6500,6628,"You bet, Dad."],[6812,6920,"All these years,"],[6920,7120,"I thought you were a failure."],[7168,7248,"Who knew"],[7476,7720,"you were hiding this from me the whole time?"]],"88":[[20,264,"You really kept me in the dark too!"],[432,640,"Tell me, how will you make it up to me?"],[696,964,"How about we have a second child?"],[1012,1176,"What are you saying? There are people watching."],[1176,1320,"Mom, Dad,"],[1320,1428,"are you going to make"],[1428,1540,"a little brother or sister"],[1540,1684,"and forget about me?"],[1876,1956,"No, that won't happen."],[1956,2076,"Grandpa will always spoil you"],[2076,2200,"and love you forever."],[2384,2500,"Of course not, Evie."],[2520,2668,"Mom and Dad were just"],[2668,2792,"joking with you."],[2820,2900,"How could we ever"],[2900,2976,"not want Evie?"],[2976,3048,"Besides, we don't want"],[3048,3136,"a little brother or sister."],[3152,3372,"Exactly, don't listen to your dad's nonsense."],[3384,3544,"I'm certainly not going to…"],[4400,4592,"Honey, you're pregnant!"],[4992,5104,"It's all your fault!"],[5224,5576,"Grandpa! Mom and Dad lied to me!"]]}