16,516,"with hand-sewed beads"],[516,641,"since sophomore year of high school."],[691,791,"Yeah, ever since you saw"],[791,929,"that prom picture of your mom"],[929,1116,"wearing that beaded dress."],[1416,1537,"That's what this is, isn't it?"],[1616,1704,"You remember that?"],[1791,1929,"I know it's hard for you to understand,"],[1929,2041,"but you're a pretty hard person"],[2041,2079,"to forget."],[2079,2291,"Even ask Dominic, fucking pizza boy,"],[2404,2479,"who hasn't had a feeling"],[2479,2616,"that's non AI-generated,"],[2616,2700,"he even knows it."],[2700,2741,"Okay,"],[2741,3054,"you're being really weird and jealous."],[3054,3166,"I don't know what's going on,"],[3187,3387,"but why do you just get to tell me"],[3404,3537,"who I'm allowed to go out with?"],[3537,3616,"We're just friends."],[3616,3766,"Friends don't tell each other that."],[3791,3941,"So that's why you called us friends"],[4025,4091,"when you're my date"],[4091,4200,"to my sister's wedding?"],[4250,4329,"He thinks I'll blow"],[4329,4450,"our fake dating cover."],[4475,4641,"Of course he's not actually jealous."],[4675,4791,"Okay, well, you know what?"],[4829,4941,"You have nothing to worry about"],[4941,5066,"because tomorrow's the wedding"],[5075,5179,"and we're gonna put on"],[5179,5266,"the best performance."],[5266,5354,"Everyone's gonna think"],[5354,5516,"I'm the best fake girlfriend ever."],[5545,5591,"But..."],[5637,5766,"I want it to be real."],[5841,5900,"No one will know"],[5900,6004,"that it's all pretend"],[6004,6116,"just for the wedding."],[6241,6387,"And I'll introduce you to Lana Winter."],[6625,6737,"Have fun on your real date,"],[6854,6929,"fake girlfriend."],[7050,7104,"I will,"],[7304,7391,"fake boyfriend."],[9133,9254,"I knew following Grayson"],[9254,9341,"would be worth it."],[9341,9475,"Now everyone at the wedding will know"],[9475,9575,"just how pathetic"],[9575,9795,"friend-zone Reese really is."]],"46":[[433,508,"Is he saying"],[508,658,"he doesn't just wanna be friends?"],[1091,1158,"Even though I'm supposed"],[1158,1304,"to be focused on Dominic,"],[1333,1495,"I can't stop thinking about Grayson."],[1579,1620,"You're still thinking"],[1620,1708,"about that hockey jock?"],[1783,1908,"Am I that easy to read?"],[1995,2033,"You know,"],[2033,2283,"maybe you just need a distraction."],[3483,3570,"You know, Grayson says"],[3570,3783,"that I'm a klutz when I drink,"],[3783,4116,"so I don't think that's a good idea."],[4191,4241,"You know what?"],[4316,4429,"We left on a really weird note."],[4429,4570,"I'm just gonna check in on him"],[4570,4641,"really quick."],[4733,4791,"I mean,"],[4879,4991,"if he was such a great guy,"],[4991,5108,"he, he wouldn't be"],[5158,5245,"texting you though, right?"],[5245,5279,"I mean,"],[5279,5504,"he would be here sitting with you."],[5554,5620,"I, I'm just saying,"],[5620,5733,"are you really gonna let a meathead"],[5733,5808,"like him control you"],[5808,5920,"when he's not even in the room?"],[6583,6620,"You know what?"],[6620,6720,"Yeah, yeah, yeah."],[6754,6804,"Yeah."],[6833,6883,"I mean,"],[6904,7141,"Grayson might be in charge on the ice,"],[7141,7483,"but he's not gonna ruin my fun."],[7520,7691,"So, cheers."],[7691,7745,"Cheers."]],"47":[[1866,1991,"The only person I ever needed to"],[1991,2116,"cheer me on was Reese."],[2195,2370,"She was there for me from the start."],[2441,2587,"I can't lose her again."],[3162,3291,"She has to know how I feel,"],[3291,3441,"before it's really too late."],[3966,4154,"Dominic, I wanna go home."],[4250,4341,"No, no, Reese."],[4416,4491,"You're gonna do something"],[4491,4579,"for me first."],[5537,5612,"What are you doing?"],[5837,5979,"Don't be like that, Reese."],[5991,6125,"I mean, I helped you out at school."],[6204,6337,"I even bought you a nice meal."],[6366,6412,"Don't you think"],[6412,6566,"it's time for you to pay me back?"],[6633,6779,"No, stop, stop!"],[6887,6979,"Get off of me!"]],"48":[[4,100,"Get off of me!"],[279,425,"You're, you're so weird,"],[425,529,"and so creepy."],[579,675,"You bitch!"],[716,879,"The only reason I helped you"],[887,979,"was because I took a bet"],[991,1116,"to see if I could have the girl"],[1116,1229,"who's never had a boyfriend"],[1254,1425,"spread her legs."],[1425,1537,"So stop resisting."],[1537,1616,"We both know"],[1641,1804,"you're not giving up anything special."],[2033,2137,"Did I really drive her"],[2137,2308,"into the arms of another guy?"],[2337,2462,"Someone help!"],[2587,2641,"Do you think"],[2641,2812,"anybody cares about you, Reese?"],[2841,3025,"Grayson doesn't want you."],[3041,3212,"Nobody wants you."],[3429,3529,"At least this way,"],[3541,3737,"your body's useful for something."],[4091,4141,"No!"],[4191,4279,"No!"],[4591,4704,"I'm coming, Reese."],[4729,4845,"Don't tell me I'm too late."],[5041,5179,"Now I've been honest with you,"],[5237,5304,"so it's time for you"],[5304,5391,"to spread your legs."],[5641,5787,"Get your hands off my girl!"]],"49":[[41,208,"Get your hands off my girl!"],[408,575,"He saved me again?"],[962,1004,"Stop!"],[1029,1104,"I'm sorry!"],[1120,1208,"I'm sorry!"],[1379,1629,"If you ever talk to her again,"],[1645,1708,"if you so much"],[1708,1895,"as even try to contact Reese again,"],[2004,2158,"I will fucking kill you!"],[3258,3404,"You like bondage so much, huh?"],[3683,3729,"Here."],[3970,4016,"No, you,"],[4016,4116,"you can't leave me here!"],[4129,4216,"You can't leave me!"],[4241,4345,"Don't worry, I'm not."],[4404,4541,"The police will find you in the morning."]],"50":[[33,208,"No, no, no!"],[208,266,"Please!"],[270,308,"No!"],[308,383,"It's okay, Reese."],[429,475,"Alright."],[541,616,"I'm here, Reese."],[666,716,"I'm here."],[2441,2579,"I'm such an idiot."],[2754,2933,"I don't know why I didn't listen to you."],[3191,3316,"Don't worry about that prick."],[3383,3520,"You deserve the entire world."],[4191,4395,"I don't want the world, Gray."],[4629,4729,"I just want you."]],"51":[[37,87,"Wait."],[95,145,"Wait."],[270,366,"No, Dominic drugged you."],[366,445,"We can't do this."],[458,554,"You're not in your right mind."],[654,704,"No, no, no."],[704,783,"My, my mind is,"],[795,970,"is completely clear right now,"],[979,1033,"okay?"],[1195,1420,"I, I, I want,"],[1420,1520,"I want this. - No."],[1545,1654,"I won't let you do something"],[1654,1758,"that you're gonna regret."],[2008,2079,"You mean something"],[2079,2204,"that you're going to regret?"],[2266,2408,"Like the last time you kissed me."],[2433,2570,"You're the one that pushed me off."],[2645,2779,"Because I was falling back"],[2779,2895,"in love with you again."],[3179,3229,"What?"],[3233,3404,"You know, I am, I'm such an idiot"],[3404,3566,"for just throwing myself at you"],[3566,3783,"over and over when you don't even-"],[3783,3966,"Kit, the only thing that I regret"],[4079,4120,"is telling you"],[4120,4245,"that that kiss was a mistake."],[4383,4458,"Because the truth is"],[4458,4533,"I've wanted to kiss you"],[4533,4608,"since high school."],[4716,4933,"Since high school?"],[5016,5120,"Kit, I'm trying to tell you"],[5120,5283,"that I'm completely in love with you."],[5379,5466,"I always have,"],[5545,5629,"always will."],[5791,5916,"You're in love with me?"],[6616,6708,"Cross my heart."]],"52":[[3645,3775,"I need you, Gray."],[3912,3987,"Please."],[4175,4225,"Don't beg."],[4225,4362,"You don't know what that does to me."],[5162,5225,"Gray."],[5783,5825,"I feel like"],[5825,5970,"I've been waiting centuries for this,"],[5970,6020,"Kit."],[6070,6133,"Me too."],[7033,7137,"Tonight we ain't leaving"],[7137,7233,"until we explore"],[7233,7358,"every inch of each other."]],"53":[[775,829,"Gray?"],[937,1050,"Special delivery."],[1358,1525,"My fashion school decision."],[1616,1741,"I'll finally know if I can fulfill"],[1741,1833,"mom's dream."],[2637,2704,"I got in."],[2825,2975,"Oh my god, I got in!"],[3200,3291,"Oh my gosh."],[3291,3387,"I knew it, Kit."],[3425,3466,"I knew it."],[3466,3554,"You deserve it."],[3566,3712,"You deserve this more than anyone."],[3787,3866,"I can't believe"],[3866,3979,"that both of my dreams"],[3991,4125,"are finally coming true."],[4154,4316,"You and London."],[4550,4620,"Gray..."],[4679,4783,"and London?"],[4820,4983,"I, I can't have both."],[5300,5350,"Shit."],[5479,5529,"Hey."],[5666,5716,"Hey."],[5841,5929,"This is big news."],[6012,6125,"We should be celebrating."],[6212,6329,"But what are we gonna do?"],[6425,6541,"We'll figure something out."],[6562,6654,"This isn't fair."],[6666,6875,"We finally get to be together and now,"],[6954,7141,"now we have half the world between us."],[7304,7462,"Kit, I've waited four years."],[7525,7600,"I'll wait again."],[7616,7800,"No, I don't want you to wait again."],[7841,7950,"Then what, Kit?"],[7979,8037,"What, does that mean"],[8037,8175,"this is the end of the road for us?"]],"54":[[8,112,"Maybe we were just supposed"],[112,212,"to be together for"],[350,420,"one night."],[475,625,"So you're just going to give up on us?"],[625,787,"No, I don't want to."],[875,1025,"I, I, I just,"],[1025,1162,"I just don't know what to do."],[1233,1345,"I mean, for what it's worth,"],[1345,1575,"being with you for one day is like"],[1725,1825,"the most perfect thing"],[1825,1958,"I could have ever imagined."],[2100,2312,"Even if it was just for a few hours."],[4170,4262,"I mean, I know we're supposed"],[4262,4387,"to break up after the wedding."],[4475,4575,"What if we're just"],[4737,4837,"together for real,"],[5000,5062,"until then?"],[5783,5862,"Reese Foster,"],[5958,6075,"will you be my girlfriend"],[6175,6262,"for just one day?"],[6487,6550,"Yes."],[6683,6775,"Grayson, if..."],[6875,7012,"if we only have one day, then"],[7162,7312,"we'll make it last a lifetime."]],"55":[[1408,1620,"I see Reese is late again."],[1695,1841,"First the bridal shower,"],[1841,1958,"now the rehearsal dinner."],[1991,2179,"Should we push the entire wedding"],[2179,2316,"to accommodate her inability"],[2316,2408,"to read a clock?"],[2454,2566,"You know, Mom, it's funny."],[2595,2658,"When are you just gonna"],[2658,2754,"quit icing her out"],[2754,2891,"and accept the fact that we're together?"],[2908,3029,"She's on her way, so drop it."],[3158,3220,"I swear,"],[3283,3470,"if she shows up in another one"],[3470,3641,"of her homemade rags-"]],"56":[[8,87,"Excuse me, Mother."],[162,325,"My date has arrived."],[691,775,"You need to stop"],[775,900,"looking at me like that, Gray."],[933,1033,"Like what?"],[1037,1183,"Like you're stuck in a desert"],[1183,1345,"and there's no water for"],[1408,1637,"miles and miles and miles and miles."],[1970,2087,"You calling me thirsty?"],[3312,3387,"Is that better?"],[3437,3637,"Not even fucking close."]],"57":[[16,116,"You're so stunning."],[200,275,"It's crazy."],[579,700,"I do have some bad news, though."],[729,862,"Lana Winter said she couldn't make it."],[862,975,"She cancelled last minute."],[1154,1379,"She's not, she's not coming at all?"],[1416,1466,"No."],[1550,1629,"I'm so sorry."],[1629,1750,"I know you only agreed to do this"],[1750,1804,"because I told you"],[1804,1937,"I'd introduce you to her, but..."],[1966,2087,"I swear I'm going to make it up to you,"],[2087,2141,"okay?"],[2179,2275,"Why are you laughing-"],[2275,2366,"Are you listening to me,"],[2416,2466,"Reese?"],[2566,2666,"Gray, I don't care."],[2829,2891,"I mean, yeah,"],[2891,2979,"it would have been really cool"],[2979,3062,"to meet her, but"],[3191,3316,"I'm doing this for you."],[3841,4000,"Can I please have everyone's attention?"],[4312,4487,"I really hate to ruin the mood"],[4487,4729,"on such a beautiful celebration, but"],[4816,5104,"I have some disturbing news"],[5104,5216,"to share with everyone."],[5291,5391,"I have proof"],[5429,5666,"that Reese and Grayson's relationship"],[5700,5791,"is fake."]],"58":[[500,587,"I'll be the best"],[587,725,"fake girlfriend you've ever had,"],[725,900,"that your family will never know that"],[900,1050,"we're just pretending for the wedding."],[1079,1283,"And I'll introduce you to Lana Winter."],[1387,1500,"So as you can hear,"],[1537,1666,"Reese doesn't actually care"],[1666,1741,"about Grayson."],[1766,1929,"She's just manipulating him"],[1929,2066,"to get close to Lana Winter."],[2116,2237,"And I really hate"],[2237,2404,"that you all had to find out this way,"],[2462,2650,"but I just couldn't sit there"],[2650,2854,"and watch Reese deceive everyone"],[2854,3012,"that Grayson really cares about,"],[3091,3166,"his family."],[3204,3312,"Grayson, is this true?"],[3341,3550,"Did Reese make you lie to us?"],[3591,3954,"So, Grayson never actually liked Reese?"],[3975,4054,"Of course not."],[4087,4225,"Why would a hockey All-Star"],[4225,4329,"want a nobody like her?"],[4387,4487,"The jig is up."],[4541,4654,"So why don't you leave"],[4654,4712,"before you keep"],[4712,4841,"embarrassing yourself,"],[4887,5029,"friend-zone Reese?"],[5066,5229,"Friend-zone Reese!"],[5254,5404,"Friend-zone Reese!"],[5425,5575,"Friend-zone Reese!"],[5604,5750,"Friend-zone Reese!"],[5779,5925,"Friend-zone Reese!"],[5950,6087,"Friend-zone Reese!"],[6366,6525,"Let me clear this up for everyone."],[6525,6616,"My feelings for Kit"],[6616,6825,"have always been real."],[6854,7091,"In fact, I've been so damn whipped"],[7091,7154,"over this girl"],[7154,7229,"that I've kept this"],[7229,7329,"from my senior prom."],[8250,8354,"After four years,"],[8479,8637,"you really still have it?"]],"59":[[54,116,"Grayson,"],[154,229,"you don't need to keep"],[270,366,"covering for her."],[366,500,"I mean, we all know"],[500,712,"that you see her as a little sister."],[779,887,"You're wrong, Piper."],[937,1016,"The last four years"],[1016,1116,"I've been so desperate"],[1116,1254,"to keep any scrap of Reese."],[1325,1429,"And now that I have the real thing,"],[1429,1529,"I'm not letting her go."],[2154,2237,"Cross my heart."],[3541,3604,"Eight years ago,"],[3604,3775,"I met my best friend at the ice rink."],[3804,3904,"She, uh,"],[3904,4004,"she saved my favorite"],[4004,4158,"chocolate bar from the evil"],[4208,4291,"vending machine."],[4341,4416,"But four years ago,"],[4416,4554,"I made the biggest mistake of my life"],[4554,4654,"by letting her walk out."],[4691,4800,"I'm not letting her go."],[4987,5029,"Kit,"],[5154,5312,"erase any doubt in your mind."],[5425,5575,"You have been and always will be"],[5750,5816,"the only girl."],[6112,6262,"I love you, Gray."],[7000,7066,"No!"],[7312,7404,"I should have destroyed"],[7404,7579,"that scrap fabric years ago"],[7579,7679,"when I had the chance."],[7691,7791,"I guess it's never too late"],[7791,7929,"to take out the trash."]],"60":[[408,558,"Amy, what are you doing?"],[587,662,"Security!"],[1075,1200,"I was only trying to help."],[1233,1350,"And yet all you've done"],[1350,1483,"is embarrass yourself,"],[1500,1575,"my family,"],[1587,1712,"and made it crystal clear"],[1712,1950,"that you do not deserve my son."],[2025,2150,"I can't believe I made him"],[2150,2233,"take you to the prom"],[2233,2325,"all those years ago."],[2725,2912,"You didn't ask Piper"],[2912,3012,"to go to the prom with you?"],[3083,3237,"Have you not been listening to me, Kit?"],[3287,3450,"You still are and always have been"],[3450,3537,"the only one."],[3900,3950,"This woman"],[3950,4087,"is causing a public nuisance"],[4087,4245,"at my daughter's rehearsal dinner."],[4287,4383,"I want her gone."],[4520,4570,"Let go!"],[4570,4725,"Get your hands off me!"],[4775,4962,"All right, that was pretty badass, Mom."],[5112,5300,"Thank you, Mrs. Hayes."],[5300,5358,"I mean,"],[5487,5620,"I don't, I don't even know what to say."],[5637,5687,"I do."],[5750,5825,"You lied."]],"61":[[8,104,"You lied."],[158,270,"And you helped Grayson"],[270,379,"lie to his family."],[379,433,"And"],[633,745,"you are the only person"],[745,1045,"that makes my son truly happy."],[1133,1270,"Ever since you came back,"],[1320,1570,"Grayson is smiling on the ice again."],[1683,1908,"And I know I haven't always approved,"],[2054,2204,"but I also know that the two of you"],[2291,2404,"have a special connection."],[2858,2908,"Thank you,"],[3033,3083,"Amy."],[3179,3245,"Don't push it."],[3745,3858,"Hayes family group hug?"],[5804,5887,"Come with me."]],"62":[[41,116,"All right."],[229,350,"So since we were kids,"],[350,475,"we've always been celebrating"],[475,591,"my wins on the ice."],[1375,1429,"But now I think"],[1429,1562,"it's time to celebrate yours."],[1766,1941,"One for every dream"],[1962,2104,"that came true this week."],[2191,2337,"Getting into graduate school"],[2391,2504,"and giving me a chance."],[2729,2866,"Thank you, Gray."],[3466,3579,"I don't want this to end."],[3629,3729,"Kit, I've-"],[3729,3791,"You know what?"],[3866,4004,"We don't have that much time left."],[4104,4154,"So"],[4337,4391,"let's just make"],[4391,4516,"the most of the time we do have."]],"63":[[1387,1575,"You look beautiful."],[1758,1900,"Are you sure this dress is okay?"],[1900,2037,"It was a last minute buy."],[2037,2112,"I wasn't sure."],[2158,2212,"Reese, I'm pretty sure"],[2212,2325,"you could wear a garbage bag"],[2325,2437,"and you'd still look gorgeous."],[2570,2720,"Who told you about my thesis?"],[2983,3037,"Ready?"],[3108,3175,"I want to talk to you"],[3175,3262,"about something first."],[3400,3470,"I'm not,"],[3520,3633,"I'm not gonna go to London."],[3758,3850,"I want to stay here."],[3912,4008,"What are you talking about?"],[4225,4362,"Reese, it was your mom's dream"],[4362,4450,"and it's yours too."],[4587,4658,"I know."],[4837,4950,"But dreams change."],[5120,5233,"And you're my dream now."],[5400,5475,"And I already know"],[5475,5595,"what life is like without you."],[5758,5862,"I don't want to experience that"],[5862,5925,"ever again."],[6037,6095,"Well,"],[6200,6295,"I was going to wait"],[6295,6487,"until after the ceremony to do this,"],[6537,6595,"but..."],[6812,6925,"You're going to London, Kit."],[7025,7170,"Does he not want me around?"],[7216,7345,"Is he sending me away?"]],"64":[[8,95,"You're the most talented"],[95,179,"fashion designer"],[179,258,"I've ever met."],[283,433,"You deserve to go learn from the best."],[520,595,"In London."],[700,829,"It's okay, Reese."],[829,995,"We both said we'd break up today."],[995,1225,"He's just honoring our agreement."],[1241,1283,"Yeah."],[1429,1604,"Yeah, I guess I should go to London."],[1670,1758,"And you know what?"],[1929,2008,"I'm coming with ya."],[2391,2458,"Wait, what?"],[2483,2645,"What about the, what about the Hawks?"],[2645,2783,"What about your hockey career?"],[2854,2995,"Well, I talked to a hockey academy"],[2995,3033,"over there"],[3033,3095,"and they're going to let me"],[3095,3216,"coach underprivileged kids."],[3283,3370,"Kids with big dreams,"],[3370,3445,"but they don't have anyone"],[3445,3520,"by their side."],[3895,3966,"Like me."],[4141,4229,"I spoke to coach"],[4229,4345,"and he said he's going to hold my"],[4345,4433,"captain seat."],[4483,4620,"And after you graduate in two years,"],[4620,4745,"it's going to be sitting right there"],[4745,4820,"waiting for me,"],[4895,5020,"like I never left."],[5091,5191,"Are you serious?"],[5291,5366,"About you?"],[5583,5725,"Always and forever."],[5970,6083,"We're going to London."],[6145,6254,"We're going to London!"],[6254,6383,"We're going to London!"],[6895,6995,"All right."],[7041,7266,"Now that we have that taken care of,"],[7308,7445,"I need your help with one more thing."],[8141,8245,"Can you help me put this on?"],[8595,8679,"Of course."],[10933,11058,"I'll see you at the altar?"],[11158,11279,"And every day after."]]}