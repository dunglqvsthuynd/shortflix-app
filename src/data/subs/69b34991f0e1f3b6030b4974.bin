{"1":[[62,166,"Ladies and gentlemen,"],[187,304,"this is the biggest night"],[304,429,"of Maple High season,"],[441,566,"the championship game."],[600,750,"All eyes are on star player,"],[750,850,"Grayson Hayes."],[962,1075,"This is it, folks."],[1075,1166,"Only five seconds"],[1166,1387,"for Maple High to break that tie."],[1404,1554,"Can our legendary captain"],[1562,1691,"Grayson Hayes make it?"],[1704,1779,"Come on, Gray."],[1875,1979,"Come on, you can do it."],[2037,2116,"Five!"],[2141,2250,"Four!"],[2266,2366,"Three!"],[2437,2516,"Two!"],[2625,2704,"One!"],[3416,3516,"Grayson Hayes,"],[3554,3650,"my best friend"],[3650,3812,"and the one constant in my life"],[3812,3954,"since the first day of high school."],[4004,4166,"The pairing of popular jock"],[4166,4404,"and invisible nerd seems unlikely."],[4450,4612,"But he's seen me at my best"],[4716,4841,"and my worst."],[5837,5987,"But it's all the moments in-between"],[5987,6170,"that makes me certain of one thing,"],[6308,6391,"I love him."],[6508,6666,"I've carried this love for years."],[6666,6845,"And tonight, at prom,"],[6845,7016,"I'll finally tell him how I feel."],[7241,7291,"What?"],[7441,7537,"God Reese,"],[7541,7704,"I didn't know you were so obsessed"],[7704,7837,"with my boyfriend."],[7904,8029,"Your, your boyfriend?"],[8029,8066,"What?"],[8079,8262,"No, I, I eat lunch with Grayson"],[8262,8316,"every day"],[8316,8379,"and he's never even"],[8379,8491,"mentioned you before."],[8537,8687,"Grayson's hockey captain."],[8712,8829,"Piper's head cheerleader."],[8829,8900,"Obviously"],[8900,9004,"they're meant for each other."],[9029,9166,"Not like you have a chance"],[9166,9491,"with this fugly homemade outfits."],[9741,9962,"Aw, did Friend-zone Reese"],[9962,10179,"make a little tie for Grayson?"],[10229,10316,"Do you really think"],[10316,10416,"he's gonna ask you out"],[10416,10541,"because you made this?"],[10741,10779,"Okay,"],[10779,10954,"you don't know anything about him."],[10995,11291,"I know that he doesn't want you."],[11366,11554,"Do you know why Grayson and you"],[11554,11654,"are still friends?"],[11750,11829,"Because the thought"],[11829,11941,"of fucking you"],[11979,12150,"literally disgusts him."],[12291,12604,"Just like this tie disgusts me."],[13037,13091,"No."],[13229,13291,"No!"]],"2":[[0,54,"No!"],[87,179,"Piper, he's coming!"],[1012,1216,"Enjoy the attention while it lasts."],[1241,1387,"I'm going to prom with Grayson"],[1412,1679,"and I'm kissing him tonight."],[2500,2591,"Three KitCats"],[2604,2729,"for your three goals today."],[2741,2891,"My KitCats from Kit."],[3516,3641,"Grayson's called me Kit"],[3641,3741,"since the day we met"],[3837,3941,"when he said KitCats"],[3941,4104,"taste way better than Reese's."],[4554,4612,"And the way"],[4612,4741,"it makes my stomach turn."],[4816,5016,"I hate it and I love it."],[5041,5154,"So tonight's prom."],[5216,5404,"Does he look nervous?"],[5466,5541,"Oh my God,"],[5575,5712,"is he gonna ask me to be his date?"],[5766,5879,"You still gonna ride with me?"],[6000,6204,"Yeah, yeah, of course,"],[6204,6350,"friends ride with friends."],[6487,6541,"Yeah."],[6625,6679,"Anyway,"],[6691,6745,"um..."],[6954,7075,"to thank you for the ride."],[7187,7379,"I made you this to, to match your suit."],[7391,7541,"Oh my God, I'll be damned."],[7612,7716,"My own Kit couture!"],[7766,7862,"And you even remember"],[7862,7941,"the hockey stick."],[8100,8179,"Let's put it on."],[9429,9500,"Don't worry."],[9616,9691,"I'll bill you."],[9754,9854,"It's perfect, Kit."],[9950,10016,"I love it."],[10112,10216,"I wanna kiss him."],[10266,10429,"And from the way he's looking at me,"],[10429,10566,"it feels like he wants it too."],[10937,11054,"Grayson, team photo!"],[11150,11216,"I gotta run."],[11254,11320,"Um..."],[11366,11479,"But tonight, Kit,"],[11575,11691,"it's gonna be unforgettable."],[11887,11966,"Cross my heart."],[12366,12504,"Tonight I'll tell Grayson"],[12504,12641,"he's more than just a friend."],[12679,12779,"He's everything."],[12816,12941,"Then maybe I'll finally get"],[12941,13100,"my perfect first kiss at prom,"],[13100,13237,"just like I've always dreamed."],[13612,13754,"It's finally prom night"],[13791,13941,"and I'm gonna tell my best friend,"],[13941,14054,"the boy of my dreams,"],[14054,14166,"that I'm in love with him."],[14479,14675,"All right, just one more, sweetie."],[14679,14741,"Okay."],[14779,14891,"Wish you were here, Mom,"],[14962,15041,"but it's okay."],[15091,15191,"Everything you taught me"],[15191,15266,"about sewing"],[15266,15379,"is in this dress."],[15437,15550,"You're with me here."],[16041,16129,"Hey Gray,"],[16129,16237,"I got ready early"],[16237,16391,"so I thought I'd come find you."],[17204,17329,"This can't be happening."],[17375,17604,"Is Grayson taking my bully to prom?"]],"3":[[791,950,"Hey, sorry I'm gonna be a little late."],[1025,1091,"It's true,"],[1166,1329,"my best friend, my crush,"],[1329,1504,"is taking another girl to prom."],[1629,1704,"It's fine."],[1804,1862,"You don't have to"],[1862,1962,"pick me up anymore."],[1962,2091,"My date is gonna bring me."],[2112,2262,"Wait, what, you have a date?"],[2300,2341,"What?"],[2879,2966,"Just get this over with."],[2966,3029,"Grayson,"],[3066,3216,"I raised you to be a gentleman."],[3262,3387,"It's not Piper's fault"],[3387,3512,"that she sprained her ankle."],[3529,3762,"Besides, she is a sweet girl"],[3762,3941,"and she comes from a good family."],[3979,4141,"She is a perfect prom date."],[4262,4375,"I'm only giving her a ride"],[4375,4500,"as a favor to you, Mom."],[4504,4579,"Don't push me."],[4754,4916,"I have a date waiting for me."],[4954,5050,"She's the only girl"],[5050,5150,"that I wanna be with."],[5412,5591,"We'll see, Grayson Hayes."],[5875,5975,"By the end of the night,"],[5991,6075,"you'll be mine."],[6766,7116,"Oh, thanks for saving me tonight."],[7191,7300,"What are friends for?"],[7362,7416,"Cheers."],[7950,8004,"You okay?"],[9495,9595,"She really came with - He really came with"],[9595,9675,"with another guy? - with another girl?"],[10012,10162,"He got her a corsage."],[10266,10362,"I'm an idiot."],[12166,12370,"Did I just bump into Grayson?"],[12420,12545,"Or did I drink too much?"],[13091,13241,"God, Reese, have you been drinking?"],[13441,13570,"The warmth in his eyes."],[13670,13775,"Maybe it's not too late,"],[13833,13929,"maybe he does care."],[13995,14095,"Come on, Reese,"],[14095,14262,"tell him before you lose him forever."],[14329,14450,"I'm in love with someone."],[14725,14854,"And he's right here."]],"4":[[866,1020,"She's in love with Nate?"],[1079,1304,"I just confessed my feelings to Gray."],[1345,1504,"Why isn't he saying anything?"],[1758,1891,"I'm sorry, I have to go."],[1962,2066,"Wait, Grayson, wait."],[2087,2145,"What?"],[2545,2804,"Oh, TikTalk is going to love this."],[2854,2933,"I have to go."],[2995,3058,"What?"],[3241,3404,"Wow, Friend-zone Reese."],[3433,3545,"You poured your heart out"],[3545,3608,"to Grayson"],[3608,3783,"and then he couldn't have run away"],[3783,3904,"any faster."],[3916,4045,"But I guess that's what happens"],[4045,4191,"when a reject orphan"],[4191,4320,"forgets her place."],[4383,4545,"You know, even if he doesn't love me,"],[4620,4795,"he's still my best friend and"],[4879,5033,"he's never gonna want you."],[5183,5245,"Really?"],[5329,5458,"Watch and learn, bitch."],[5583,5641,"What?"],[5666,5695,"What?"],[5695,5808,"Stop, stop!"],[6008,6295,"And this year's prom King and Queen are"],[6345,6566,"Grayson and Piper!"]],"5":[[0,62,"Let go of me."],[62,125,"Stop!"],[162,220,"Gray!"],[1275,1425,"A King should dress the part."],[2450,3012,"Kiss!"],[3520,3650,"I'm in love with someone."],[4095,4183,"She doesn't love me."],[4183,4320,"She never did."],[4487,4870,"Kiss!"],[5287,5362,"This is it."],[5412,5570,"This is my nightmare come true."],[6270,6487,"Still think Grayson cares about you?"],[6537,6683,"Go on, tell him to stop."],[6700,6750,"Go."],[6950,7025,"I can't."],[7087,7270,"He proved to me how he really feels."],[7270,7433,"I'm not gonna play the fool anymore."],[7987,8237,"Oh, Friend-zone Reese strikes again."],[8470,8775,"Friend-zone Reese!"]],"6":[[0,133,"Friend-zone Reese!"],[141,262,"Friend-zone Reese!"],[262,300,"Wait!"],[300,416,"Friend-zone Reese!"],[454,504,"Kit."],[650,791,"Don't pretend like you care."],[825,966,"You just sucked face"],[966,1104,"with the queen bee in front of me"],[1104,1216,"and everyone here."],[1229,1345,"What is your problem?"],[1404,1550,"I don't tell you who to go to prom with."],[1550,1650,"You don't tell me who to kiss."],[1650,1712,"We're friends."],[1712,1841,"Fuck, we're practically family."],[1841,2041,"I don't wanna be your fucking family!"],[2054,2179,"Then what do you wanna be then?"],[2283,2341,"Nothing!"],[2412,2541,"I don't wanna be anything!"],[2579,2666,"I hate you!"],[3025,3266,"That night, I lost my best friend,"],[3304,3504,"the only guy I've ever loved."],[3537,3600,"And I didn't think"],[3600,3837,"I'd see him ever again, ever."],[4475,4537,"Enjoy."],[5229,5304,"No way."],[5766,5954,"Grayson and Piper are getting married?"]],"7":[[20,204,"I once dreamed of wearing white"],[204,316,"and walking down the aisle"],[316,395,"to Grayson,"],[445,620,"but dreams don't always come true."],[729,816,"I have to move on."],[1404,1470,"Grayson Hayes"],[1470,1583,"of the Maple City Hawks"],[1583,1770,"is the youngest three-peat MVP"],[1770,1895,"in NHL history."],[1916,2033,"And he's got the Stanley ring"],[2033,2104,"to prove it."],[2920,3058,"That's Grayson Hayes."],[3070,3254,"The hottest player in the NHL."],[3254,3341,"What a hot guy!"],[3341,3408,"Hi!"],[4208,4279,"It's been four years,"],[4279,4366,"but seeing Reese's name"],[4366,4495,"still makes me feel..."],[4587,4645,"Forget it,"],[4725,4770,"she was clear"],[4770,4879,"she didn't want me around."],[4879,5016,"I just hope wherever she is,"],[5016,5154,"she's happy."],[5691,5745,"Reese."],[6233,6329,"Can I help you?"],[6445,6533,"I'm so sorry."],[6541,6691,"I thought you were someone else."],[6870,7016,"I have to forget about Reese."],[7083,7191,"She's my past,"],[7229,7312,"not my future."],[8558,8679,"Hey, Miss, are you all right?"],[9545,9745,"Are you fucking kidding me?"],[10495,10570,"Grayson?"],[10633,10820,"Wait, what the hell is my ex-best friend"],[10820,10979,"and my crush doing here?"]],"8":[[150,200,"Reese."],[229,329,"Oh my God, I'm so sorry."],[329,391,"Here, let me."],[445,516,"No, no, no. - Let me."],[516,587,"It's, it's fine."],[587,675,"I, I got it."],[866,912,"Pilsner?"],[912,1179,"I, I, I thought you liked stout?"],[1262,1337,"You remember."],[1462,1541,"Couldn't forget,"],[1579,1766,"no matter how hard I tried."],[1779,2029,"Hey, congrats on the wedding."],[2062,2216,"I saw your, your post."],[2229,2391,"Your mom must be thrilled"],[2441,2575,"that you're marrying the girl"],[2575,2687,"she likes so much."],[2716,2775,"What?"],[2812,2975,"Oh, oh, Reese,"],[2975,3041,"no, no, no, no, no."],[3062,3091,"I see-"],[3091,3154,"Grayson!"],[3266,3341,"Baby!"],[3545,3816,"Isn't this your friend Reese?"],[3954,4037,"It's been a while."],[4366,4529,"Reese, you remember Piper?"],[4787,4879,"How could I forget?"],[4916,4987,"So,"],[5100,5254,"are you coming to the wedding?"],[5291,5404,"Of course she's inviting me"],[5404,5462,"to their wedding"],[5462,5616,"to rub it in that she won,"],[5650,5829,"like I'd care after four years."],[5862,5979,"Stop caring, Reese."],[6025,6166,"I don't, I don't think I-"],[6166,6204,"Of course"],[6204,6304,"she's coming to the wedding."],[6854,7091,"It's, it's my sister's wedding,"],[7091,7166,"so obviously"],[7166,7291,"my girlfriend's gonna be there."],[7391,7466,"Girlfriend?"],[7516,7787,"Did, did he just call me his girlfriend?"],[7845,8041,"Oh, Piper, I thought you knew"],[8041,8204,"that Reese and I are dating now."]],"9":[[166,220,"Play along."],[220,295,"Please."],[595,741,"Yeah, yes,"],[770,983,"me and Grayson are dating."],[1008,1108,"So, obviously"],[1108,1508,"she's gonna come to Josie's wedding."],[1579,1766,"So, it's Grayson's sister"],[1766,1833,"getting married,"],[1833,1916,"not him."],[1941,2008,"Thank God."],[2370,2458,"You're so funny."],[2516,2683,"Here, let me buy you a pilsner"],[2683,2758,"for the joke."],[2770,2870,"I prefer stout."],[2958,3054,"Thank you very much."],[3129,3241,"But we should get going."],[3495,3583,"See you at the wedding."],[4004,4108,"That sneaky bitch"],[4108,4241,"shows up out of nowhere"],[4245,4395,"and is with Grayson now?"],[4458,4533,"Something's up."],[4595,4683,"I'll find out what."],[4883,4995,"Why the hell did you just go"],[4995,5066,"and tell your ex"],[5066,5191,"that I'm your girlfriend?"],[5316,5445,"You better explain yourself,"],[5479,5570,"Grayson Hayes."],[5616,5745,"Look, I'm sorry."],[5745,5854,"I panicked, all right?"],[5929,6045,"Piper and I have been on and off"],[6045,6133,"for the last few years,"],[6133,6258,"but I ended it a while back."],[6383,6520,"And she did not take it well,"],[6520,6616,"and neither did my mom."],[6720,6808,"And with Josie's wedding"],[6808,6883,"around the corner,"],[6883,6941,"she's desperate"],[6941,7033,"to get us back together."],[7033,7195,"So, you're trying to get rid of her"],[7245,7379,"by saying that I'm your girlfriend."],[7379,7429,"Okay, well,"],[7429,7558,"I don't, I don't wanna be a part"],[7558,7695,"of this family drama, okay,"],[7695,7758,"so can you just go"],[7758,7879,"and find someone else?"],[8183,8279,"What if I don't wanna deal"],[8279,8391,"with anyone else, Reese?"]],"10":[[8,162,"I used to be Kit to him,"],[187,350,"and now I'm just Reese."],[400,437,"Look,"],[437,620,"I know things ended weird between us,"],[683,770,"but if I'm gonna do this,"],[770,850,"I don't wanna do this"],[850,970,"with anyone else but you."],[1012,1070,"Okay,"],[1162,1200,"all right,"],[1200,1300,"say I pretend to be"],[1300,1383,"your fake girlfriend,"],[1383,1425,"then"],[1550,1645,"what's in it for me?"],[1808,1908,"Your dream's still to become"],[1908,2025,"a fashion designer, right?"],[2087,2137,"Well,"],[2262,2350,"Lana Winter is gonna be"],[2350,2412,"at the wedding."],[2512,2633,"Lana Winter?"],[2637,2695,"Yeah."],[2700,2837,"The Lana Winter?"],[2845,3058,"So, you'd introduce me"],[3058,3262,"to the top fashion designer"],[3262,3362,"in the whole world?"],[3862,3950,"Cross my heart."],[4050,4125,"Cross my heart."],[5058,5108,"Okay,"],[5262,5320,"deal."],[5562,5820,"I will be the best fake girlfriend"],[5833,5995,"at your sister's wedding."],[6050,6225,"Grayson Hayes."],[6262,6487,"All right, Reese Foster,"],[6520,6762,"I'll introduce you to Lana Winter."],[6887,6962,"Look at us,"],[6962,7175,"just friends helping out friends,"],[7237,7370,"just like the old days."],[7458,7700,"Friends playing pretend."],[7745,7962,"That's all this is, okay?"],[7962,8112,"Don't give him your heart, Reese,"],[8112,8225,"you know how this ends."],[8275,8470,"Speaking of friendly favors."],[9100,9345,"What, what, what are you doing?"]],"11":[[50,300,"Friends don't let friends walk around"],[312,550,"with clothes drenched in beer."],[695,787,"Go ahead and put this on."],[837,912,"I'll stand guard."],[925,987,"Okay."],[2004,2054,"Oh no,"],[2054,2208,"if Piper sees us like this..."],[3575,3670,"Grayson?"],[3987,4095,"Are you in the car?"],[4337,4525,"We can't let Piper blow our cover."],[4550,4687,"So, so we're gonna pretend"],[4687,4820,"to do it in the car?"],[5433,5637,"Sent your friend Reese packing yet?"],[6208,6320,"We're dating, Reese."],[6395,6512,"That means we can't"],[6600,6787,"keep our hands off each other."],[7120,7225,"Come on, Grayson,"],[7250,7375,"I know you still want me."],[7383,7520,"I'll show you a good time."],[7558,7662,"She's gonna find out"],[7662,7775,"that we're faking this"],[7812,7962,"and I'm gonna die from shame."],[8183,8300,"Please don't punch me."],[10025,10100,"Oh my God!"]],"12":[[37,125,"Are you really in there"],[125,287,"with Friend-zone Reese"],[287,425,"to make me jealous?"],[612,666,"Don't worry."],[754,850,"I got this."],[958,1125,"Yeah, Grayson!"],[1212,1333,"Oh, yeah!"],[1550,1625,"Reese."],[1745,1858,"This isn't over,"],[1858,1925,"Reese. - Oh yeah."],[1925,2070,"You'll never have Grayson."],[2100,2162,"Never!"],[2704,2850,"I told you, I got this."],[3220,3287,"We did it."],[3375,3458,"That was incredible."],[3662,3762,"You know, you're..."]],"13":[[12,145,"You're always going the extra mile"],[145,237,"for your friends."],[375,525,"Some things never change, huh?"],[562,633,"Of course."],[645,725,"It doesn't matter"],[725,837,"how much time has passed,"],[862,1037,"I'll always be stuck in the friend zone."],[1150,1287,"It's been four years."],[1333,1500,"Things, things have changed"],[1575,1695,"and, and you don't know me"],[1695,1775,"one damn bit."],[2358,2545,"Hey, then I'll tell you what I remember."],[2587,2775,"Your favorite juice is cranberry juice."],[2837,2933,"Used to get stomachaches"],[2933,3075,"before all your math quizzes"],[3100,3187,"and your dream was to be"],[3187,3320,"a fashion designer in London"],[3320,3462,"just like your mom wanted to."],[3495,3570,"You always wanted"],[3570,3683,"to win the Stanley Cup."],[3683,3787,"And now I've won three."],[3825,4037,"Used to wake up early in the morning"],[4037,4137,"for practice"],[4175,4270,"and you'd pick me up"],[4270,4375,"on the way to school."],[4375,4575,"And then we'd eat lunch together"],[4600,4720,"every day."],[4775,4850,"And I gave you"],[4850,5037,"that really, really bad haircut"],[5037,5125,"junior year."],[5500,5625,"And then you made me that tie"],[5625,5720,"for senior prom."],[5783,5975,"And you kissed Piper at senior prom."],[6725,6887,"That was four years ago, Reese."],[6945,7095,"What are you gonna do about it now?"]],"14":[[704,804,"Wake up, Reese."],[820,920,"He didn't want you then"],[920,1033,"and he doesn't want you now."],[1091,1254,"That's why he only asked you"],[1254,1408,"to be his fake girlfriend."],[1520,1591,"I think"],[1658,1816,"I'm not gonna do anything about it"],[1870,2045,"because we're just friends"],[2083,2208,"helping friends, right?"],[2304,2354,"Right."],[2420,2558,"Right, of course."],[2995,3170,"Hey, there's a wedding shower"],[3170,3279,"at my beach house tomorrow."],[3454,3516,"Be my date?"],[3579,3658,"There it is,"],[3691,3745,"the question"],[3745,3920,"I've been waiting for him to ask"],[3920,4120,"but he's four years too late."],[4433,4495,"Yes,"],[4608,4745,"I guess I'll be your date."],[4779,4983,"All right, see you there, Kit."],[5270,5420,"We're just friends, fake dating."],[5420,5558,"It doesn't mean anything."],[5704,5883,"We don't mean anything."],[5970,6045,"Never did."],[6383,6454,"Never will."]],"15":[[858,958,"Grayson,"],[991,1108,"stop being a hermit"],[1108,1258,"and go keep Piper company."],[1295,1445,"Are you really trying to still organize"],[1445,1529,"my playdates?"],[1595,1716,"I told you I'm seeing someone."],[1783,1995,"Sure, but I know you, son."],[2045,2208,"You always go back to Piper."],[2245,2391,"I'm gonna go check on Josie."],[2425,2533,"Maybe you should focus less"],[2533,2616,"on my love life"],[2616,2695,"and more about your daughter"],[2695,2795,"getting married next week."],[2820,3004,"Well, if this new girl is so perfect,"],[3004,3133,"then why is she late?"],[3866,4004,"Don't worry about us, Amy."],[4033,4204,"I respect Grayson's decision."],[4241,4358,"Even if we're not together,"],[4479,4620,"I still think of you as family."],[4666,4720,"I don't care"],[4720,4879,"who Grayson's new girlfriend is."],[4904,5120,"I know you are the only one for him."],[5583,5795,"Reese Foster, right on time."],[6495,6604,"Grayson, I'm here."],[7962,8129,"Reese Foster?"],[8254,8470,"You're my son's new girlfriend?"]],"16":[[8,220,"I'm, I'm so sorry, Mrs. Hayes."],[229,366,"I'll clean this up right away."],[441,570,"The maids will get it, honey."],[608,795,"Amy, don't be mad at her."],[795,1033,"I mean, she's just clumsy."],[1145,1295,"I know the hottest bakery in town,"],[1295,1416,"so I'll call her"],[1416,1566,"and have everything fixed."],[1604,1770,"Piper, you are an angel,"],[1845,2045,"unlike my son's new girlfriend,"],[2070,2166,"who obviously doesn't know"],[2166,2233,"the first thing"],[2233,2408,"about being a hockey star's wag."],[2454,2608,"Why don't I have the chauffeur"],[2608,2745,"drive you home, Reese?"],[2783,2970,"You, you, you're kicking me out?"],[2979,3029,"No,"],[3066,3283,"I'm politely offering you a ride home"],[3283,3333,"after you"],[3333,3445,"embarrassed yourself"],[3454,3683,"and ruined hours of my hard work"],[3683,3758,"in the kitchen."],[3916,4045,"With all due respect,"],[4095,4170,"Mrs. Hayes,"],[4216,4320,"your son invited me,"],[4320,4433,"and you can't just kick me out"],[4433,4495,"like this."],[4529,4654,"With all due respect,"],[4720,4791,"I'd appreciate it"],[4791,4908,"if you did not speak back to me"],[4908,4983,"in my own home."],[5108,5320,"But what manners can I expect"],[5320,5495,"from a unwanted orphan?"],[5708,5970,"I'm not unwanted, Mrs. Hayes."],[5995,6095,"You know, if you don't agree,"],[6095,6220,"why don't you go ask your son?"],[6420,6633,"Piper, would you and your friends"],[6633,6758,"please show Reese the door?"],[6883,6983,"I'd be happy to."],[7195,7316,"No, no, no."],[7320,7491,"Gray, Grayson, Grayson!"],[7566,7683,"She's not going anywhere."],[9016,9120,"Sweet cupcakes, Mom."],[9395,9445,"Oh,"],[9516,9604,"hello, everybody."],[9633,9766,"I see you've met my new girlfriend"],[9766,9829,"Reese."]],"17":[[487,591,"Grayson, what are you doing?"],[641,775,"I'm taking care of my girl, Mom,"],[779,891,"because clearly you're not being"],[891,979,"a very good host."],[1004,1141,"And since Reese is with me now,"],[1141,1179,"she's gonna be"],[1179,1300,"one of Josie's bridesmaids."],[1475,1529,"What?"],[1541,1650,"Bridesmaid?"],[1691,1854,"Grayson, are you sure about this?"],[1854,1904,"I mean,"],[1912,2054,"Reese just disappeared"],[2054,2116,"for four years"],[2116,2229,"and then popped up out of nowhere,"],[2229,2404,"and you're not the least bit concerned?"],[2429,2650,"You just won MVP of the NHL."],[2666,2766,"You don't think she's"],[2804,2937,"here for your fame and money?"],[2975,3116,"Not that it's any of your business,"],[3150,3212,"Piper."],[3454,3512,"But Reese and I"],[3512,3612,"actually met two months ago"],[3612,3725,"at Macy's bakeshop."],[3741,3891,"We fought over the last piece of,"],[3904,3966,"what was it?"],[3979,4079,"A lemon raspberry cake?"],[4254,4379,"And I just knew I had to ask her out"],[4379,4462,"because I haven't been able"],[4462,4579,"to stop thinking about her."],[4700,4866,"And I'll be damned if I lose her again."],[4925,5083,"I know we're fake dating,"],[5083,5266,"but why does this feel so real?"],[5279,5429,"They're the cutest couple ever."],[5629,5704,"No, no."],[5737,5929,"I know that Reese and Grayson"],[5962,6054,"are up to something."],[6900,7041,"My, my dress!"],[7050,7166,"My face!"],[7212,7437,"Crazy ex-girlfriend alert."],[8004,8129,"Oh my God!"],[8325,8475,"I know you're up to something."],[8487,8591,"When I find out what it is,"],[8591,8654,"it's gonna be the end"],[8654,8791,"of your freaking little fairy tale."],[9287,9379,"Let's get you cleaned up."],[9854,9937,"Holy fuck,"],[9937,9991,"I can't believe"],[9991,10104,"they actually bought that."],[10304,10366,"Grayson,"],[10450,10641,"what you said back there,"],[10712,10825,"it sounded so real."],[10966,11066,"Almost like you meant it"],[11066,11137,"or something."],[11254,11350,"Well, Reese."]],"18":[[16,104,"Well, Reese."],[579,683,"Remember prom?"],[683,820,"Reese picked Nate over you."],[820,975,"The only reason she is helping you now"],[975,1120,"is so to meet her fashion idol,"],[1120,1179,"Lana Winter."],[1179,1241,"I know, right?"],[1241,1354,"I can't believe they bought that."],[1429,1562,"It's all in your head, Reese."],[1562,1754,"You're fake dating, nothing more."],[1779,1837,"Yeah."],[1887,1966,"Yeah, they did."],[1991,2116,"It's been a while, but"],[2300,2429,"your room hasn't really changed."],[2816,2891,"Twilight?"],[2979,3037,"Really?"],[3141,3300,"You've always hated vampires."],[3479,3654,"That's actually Piper's."],[3704,3762,"Oh."],[3891,4012,"Okay, what about this?"],[4287,4391,"Pumpkin spice?"],[4416,4504,"Seriously?"],[4504,4616,"You've always shitted"],[4616,4779,"on that artificial bullshit."],[4804,4904,"That's also Piper's."],[5016,5079,"Hmm."],[5225,5275,"Red."],[5312,5466,"You never wear red."],[5504,5662,"Oh my God, that's maroon."],[5766,5979,"Oh, is that what Piper told you too?"],[5979,6154,"So I have a few of her things."],[6154,6300,"It's not about having a few"],[6300,6416,"of her things, okay?"],[6416,6641,"She's, she's changed you a lot"],[6654,6854,"and you can clearly see that this is-"],[6854,6979,"Well, if you didn't want me to change,"],[6979,7062,"then where the hell were you"],[7062,7175,"the last four years?"]],"19":[[45,204,"No call, no text, nothing."],[279,320,"So yeah,"],[320,441,"I went off and dated Piper"],[441,516,"for a little bit"],[516,629,"because she was actually there."],[679,720,"Unlike you,"],[720,920,"you just ran off without a word."],[1495,1629,"You know I missed you, right?"],[1833,1908,"And I'm back,"],[2129,2195,"for you."],[2508,2570,"Someone's coming."],[2583,2625,"Someone's coming."],[2633,2733,"Grayson?"],[2808,2883,"Take your clothes off!"],[2895,2945,"Take them off!"],[2945,3029,"Take my clothes off?"],[3029,3083,"Yeah."],[3241,3354,"What are you doing?"],[3354,3433,"Do what I say,"],[3433,3516,"unless you want your ex"],[3516,3641,"finding out what we're doing, okay?"],[3795,3879,"Are you there?"],[4108,4158,"Okay."],[4216,4291,"Oh, oh."],[4741,4837,"I'm pressed"],[4837,5012,"right against Grayson's abs?"],[5012,5245,"Oh, God, this is not a part of my plan!"]],"20":[[258,345,"Seriously, Grayson,"],[345,445,"that girl is a mess."],[445,583,"What do you see in Re-"],[1162,1237,"Oh my God!"],