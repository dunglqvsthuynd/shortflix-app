n"],[675,779,"and you never will be."],[829,941,"So take this deal,"],[975,1166,"because this is more money"],[1166,1250,"than you will ever see"],[1250,1354,"in your peasant life."],[1354,1516,"You know, last time that I checked,"],[1516,1675,"your son is a grown adult,"],[1675,1816,"so I think he can decide"],[1816,1929,"if he wants me here."],[1950,2279,"You are nothing but a roach."],[2312,2437,"How many times do I have to kill you"],[2437,2579,"before you stop coming back?"],[2587,2654,"Okay, well,"],[2691,2766,"I'm here"],[2787,2954,"because I care about Grayson."],[2954,3029,"Well, if you do,"],[3079,3254,"you will let Piper win the tennis match."],[3262,3379,"Piper will stay the night,"],[3404,3516,"Grayson will be back with her"],[3516,3591,"by morning,"],[3629,3791,"and my daughter will enjoy"],[3791,4041,"her wedding week without pests."],[4075,4412,"Don't forget, we are his family."],[4529,4600,"Who are you?"],[4641,4779,"Well, I'm not gonna stand here"],[4779,4962,"and make Grayson pick sides,"],[5012,5237,"because I'm here for him, not you."],[5275,5375,"No amount of money"],[5412,5504,"that you try to give me"],[5504,5629,"is gonna make me abandon him."],[6575,6637,"Game time."],[7079,7216,"Reese can serve first."],[7225,7329,"She played in high school."],[7379,7504,"She'll show us how it's done."],[8391,8500,"Good luck, Reese."],[9291,9379,"You'll need it."]],"23":[[629,691,"Reese."],[1054,1216,"Are you sure you can still play, Reese?"],[1229,1400,"That was a pretty nasty fall."],[1400,1475,"Yeah, it was gonna take"],[1475,1562,"more than a little fall"],[1562,1650,"to keep me down."],[2466,2641,"You will let Piper win the tennis match."],[3325,3462,"You're not good enough for my son,"],[3462,3566,"and you never will be."],[4041,4266,"You are nothing but a roach."],[4312,4441,"How many times do I have to kill you"],[4441,4579,"before you stop coming back?"],[4591,4675,"Match point."],[4741,4854,"Piper team scores."],[4920,5041,"Don't feel bad, Reese.