m sacrificing so much of my time"],[3337,3475,"to be here for you."],[3512,3775,"I could be at home working on my thesis,"],[3775,3908,"working on my fashion design,"],[3920,4008,"going to make money"],[4008,4162,"to pay my own fucking rent,"],[4162,4358,"but I'm here for you!"],[4366,4445,"Don't you sit there"],[4445,4575,"and pretend like you're here for me."],[4920,5037,"I remember the bargain."],[5062,5112,"You're gonna get"],[5112,5225,"your precious face time"],[5225,5387,"with your idol Lana at the wedding,"],[5387,5487,"and then you're gonna be off"],[5487,5608,"to London in a plane"],[5625,5770,"before you can say bloody hell."],[5775,6025,"You seriously think that I'm only here"],[6062,6225,"to kiss up to Lana Winter?"],[6225,6375,"Then why else are you here?"],[6400,6475,"You've disappeared"],[6475,6608,"for the last four years."],[6625,6725,"What other business"],[6725,6850,"do you have being here?"],[6912,7045,"Go on, say it."],[7137,7237,"Say it, Kit."],[7279,7366,"Say you want me too."],[7366,7520,"I've been waiting for four years."]],"33":[[70,225,"I'm here because of my mom,"],[225,325,"you asshole."],[495,587,"Wow, I can't believe"],[587,687,"you don't remember that."],[762,825,"Reese, I..."],[837,962,"So you do remember,"],[1020,1175,"and you just don't care!"],[1358,1387,"Reese,"],[1387,1508,"your mom taught you how to sew"],[1508,1637,"when you were five years old."],[1687,1833,"Remember that pink sewing machine"],[1833,1920,"you got for Christmas?"],[1920,2008,"That basically I had to pry it"],[2008,2100,"out of your hands."],[2175,2258,"Your mom's dream"],[2258,2387,"was to study fashion in London."],[2387,2570,"She gave all that up to raise you."],[2608,2845,"And then you going to grad school"],[2845,2937,"at London School of Fashion"],[2937,3050,"became her new dream."],[3095,3250,"It became both of your dreams."],[3358,3525,"And I just, I just applied"],[3575,3687,"for next semester."],[3812,3908,"Wow, I, I can't believe"],[3908,3987,"you r