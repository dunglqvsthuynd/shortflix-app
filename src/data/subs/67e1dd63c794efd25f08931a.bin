5,5050,"No."],[5075,5246,"You can just watch."],[5355,5409,"No!"],[5409,5530,"No! No! No!"],[5563,5676,"No! No!"],[7440,7503,"Trap?"],[7632,7707,"What the hell?"],[9359,9580,"Not bad for a guy who hates romance."],[9914,9993,"I hope you don't mind."],[9993,10130,"I wanted our first time"],[10130,10260,"to be special, Harper."],[10326,10493,"Before you sleep with my daughter,"],[10560,10677,"you should probably know"],[10677,10823,"where she is first."]],"62":[[141,191,"Okay, crap."],[191,296,"I can explain."],[296,404,"You're gonna explain."],[521,625,"But first,"],[863,946,"you know my daughter"],[946,1034,"better than I do."],[1067,1209,"Is that text a prank?"],[1426,1501,"Harper's in trouble."],[1501,1559,"We need to go."],[1914,2056,"Should we have some fun with you"],[2056,2302,"after we kill lover-gramps?"],[2515,2665,"Should we make him watch?"],[3215,3340,"Looks like he's here."],[3411,3616,"Are you ready to see"],[3645,3858,"your boyfriend die, Harper?"],[4079,4179,"Get ready boys."],[5509,5643,"I'm going to make you regret"],[5643,5747,"you ever touched her."],[6310,6431,"That's what happens, Chris!"],[6431,6506,"When you mess around"],[6506,6606,"with my shit!"],[8345,8454,"What's the matter, tough guy?"],[8500,8541,"What?"],[8579,8662,"You can't talk without"],[8662,8779,"your little bodyguards?"],[9421,9480,"Let me go!"],[9480,9634,"I'll leave Harper-"],[9634,9755,"I already told you once."],[9776,9901,"You should have listened to me then."]],"63":[[116,216,"I'm gonna kill you,"],[216,321,"you god damn prick."],[1092,1167,"Calling all units,"],[1167,1355,"A-211 at 675 Main."],[1401,1463,"Backup needed."],[2177,2243,"Are you okay?"],[2318,2419,"Did he hurt you?"],[2535,2598,"Chris,"],[2669,2877,"I put you in... in danger."],[2877,2948,"You should run,"],[2948,3111,"far away from me and my baggage."],[3182,3303,"When it comes to you, Harper."],[3340,3503,"I'm willing to take my chances."],[4108,4220,"Would someone"],[4291,4400,"like to tell me"],[4400,4583,"what the fuck is going on?"]],"64":[[75,137,"Oh my God!"],[137,171,"Dad!"],[171,250,"What the hell?"],[250,321,"It's okay."],[408,479,"I'll handle it."],[479,613,"I want to hear it from my daughter."],[667,763,"Why are you making out"],[763,900,"with my best friend, Harper?"],[921,1084,"I want an answer now before I..."],[1084,1163,"before I kill him!"],[1163,1267,"No, Dad!"],[1267,1347,"Look..."],[1451,1555,"I know we don't have the most"],[1555,1689,"warm and fuzzy relationship."],[1735,1822,"But..."],[1851,2077,"Deep down, I know that..."],[2273,2419,"you just want me to be safe."],[2836,2982,"Chris makes me feel safe."],[3098,3190,"Please don't be mad."],[3357,3478,"You're wrong about that."],[3682,3791,"It's not deep down."],[3883,4054,"It is the most important thing"],[4054,4104,"to me."],[4104,4212,"Your happiness."],[4487,4679,"If that means being with Chris,"],[4717,4954,"then he better not screw this up."],[5021,5192,"Or I will make him regret it."],[5321,5401,"I believe you."],[5551,5630,"You..."],[5680,5797,"keep her safe."],[6047,6197,"With my goddamn life."]],"65":[[963,1121,"Do you remember my instructions?"],[1209,1292,"Yes."],[2427,2560,"Yes, Daddy."],[2823,2886,"Say it."],[3069,3161,"Yes, Daddy."],[3674,3807,"I want you to beg for it."],[4175,4262,"I want you..."],[4375,4529,"to fuck me, Daddy."]],"66":[[479,613,"Stop teasing."],[688,813,"I want you now..."],[1426,1534,"Daddy."],[1584,1639,"Say it."],[1730,1851,"Or I'll punish you."],[3069,3174,"Don't stop, Daddy."]],"67":[[1497,1601,"Are you sure about that?"],[3165,3253,"You have two choices"],[3253,3365,"Mr. Collins."],[3574,3787,"You can either uncuff me"],[3920,3999,"or fuck me."]],"68":[[779,905,"You know I'm dangerous."],[1113,1247,"I'll eat you alive."],[1543,1685,"Do your worst, Daddy."],[3849,4024,"Once I start, I'm not stopping."],[4416,4479,"I thought..."],[4529,4775,"you only fucked girls from behind."],[5176,5246,"You're different."]],"69":[[1197,1317,"Ready for round five?"],[1409,1580,"Stop it, I’m sore."],[1605,1697,"Now let me out,"],[1697,1826,"so I can go pee."],[2014,2102,"What if I don’t?"],[2394,2460,"Who is that?"],[2460,2610,"Crap, it's my dad."],[2723,2819,"Honey, you home?"],[2819,2927,"Dad, I'm kind of busy"],[2927,2990,"right now. -That’s ok I’ll"],[2990,3048,"just come in- - Stop."],[3048,3128,"I'm coming for... Oh!"],[3486,3632,"I told you I was busy."],[3653,4016,"This is my home, Harper Reeves."],[4016,4158,"If you want to get up to adult stuff,"],[4158,4291,"you need to move out."],[4291,4437,"Okay I will, I..."],[4475,4579,"Can you get out?"]],"70":[[408,600,"I think I've had enough surprises"],[600,746,"to last a lifetime, Chris."],[746,905,"Can I please just open my eyes?"],[905,1071,"No, please keep them covered."],[1230,1351,"I want to give a speech."],[1363,1447,"And I can't look at you"],[1447,1559,"while you're giving a speech?"],[1559,1851,"I get nervous when I open up."],[1872,2072,"You literally carry around a gun."],[2093,2252,"But, whatever."],[2314,2410,"Just get on with it."],[2519,2635,"What I do for a living,"],[2811,2948,"the not-so-legal part,"],[3115,3311,"it's dangerous for me"],[3311,3557,"to let people into my life."],[3695,3853,"And for me to be..."],[3953,4037,"Vulnerable?"],[4166,4216,"Yeah."],[4262,4333,"But I knew,"],[4396,4562,"when I was in charge of keeping you safe,"],[4562,4662,"I was doomed."],[4833,4979,"You're like a magnet, Harper."],[5005,5171,"And I want to be around you,"],[5292,5359,"forever."]],"71":[[604,684,"So you're moving into"],[684,809,"the Empire State Building?"],[1117,1234,"I'm moving you in there."],[1409,1568,"As a graduation present,"],[1697,2010,"and also I love you"],[2010,2273,"and want you to be my girlfriend present."],[2540,2644,"Only if you want to."],[2769,2848,"Either way..."],[2952,3057,"the apartment's yours."],[3157,3265,"Are you serious?"],[3428,3499,"What's wrong?"],[3532,3611,"Is it tacky?"],[3753,3832,"I liked it."],[3832,3945,"I thought- -Deal!"],[4425,4600,"But on one condition, boyfriend."],[4738,4817,"Which is?"],[4875,5009,"You have to move in there with me."],[5196,5242,"Deal."]]}