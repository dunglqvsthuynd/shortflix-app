"],[13655,13817,"The desperate mistress"],[13876,14034,"trying to rewrite a story"],[14034,14185,"you were never a part of."]],"19":[[4,154,"Nice try but..."],[154,362,"I came here on my own."],[367,500,"And let's be real,"],[500,650,"in any relationship"],[650,779,"the one who's no longer"],[779,913,"loved is the third wheel."],[946,1076,"So do you really think"],[1076,1272,"Easton still wants you?"],[1351,1547,"And I mean what have"],[1547,1743,"you ever done for him?"],[1805,1922,"I was there"],[1976,2152,"building that empire with him,"],[2152,2285,"day and night,"],[2302,2477,"pitch by pitch."],[2477,2552,"With me,"],[2552,2786,"he gets investors,"],[2786,2907,"headlines,"],[2932,3036,"profit."],[3111,3482,"And you with that birthmark,"],[3687,3762,"he won't even take"],[3762,3970,"you to a damn gala."],[4083,4258,"You're dead way, Nina."],[4300,4441,"And you always have been."],[5005,5121,"One hundred million."],[5305,5572,"Take it, walk the hell away."],[5784,6026,"A hundred million? Candice,"],[6126,6306,"Easton is worth billions."],[6381,6585,"You think 100 million can"],[6585,6694,"pay me off?"]],"20":[[0,116,"Don't be greedy."],[421,521,"Relax."],[684,900,"I'm not gonna chase after him."],[900,1042,"I want the divorce."],[1272,1372,"Can't wait to see how your"],[1372,1480,"little fairy tale turns out"],[1480,1593,"in the real world."],[1664,1839,"Well then thanks for"],[1839,2060,"stepping aside, sweetheart."],[5238,5480,"Doctor Johnson? It's Nina."],[5588,5668,"I wanna come in"],[5668,5822,"for the trial."],[5822,6043,"Mrs. Jones as I said before,"],[6043,6160,"we don't allow test"],[6160,6310,"trials for pregnant women."],[6310,6418,"I'm not pregnant."],[6610,6752,"My babies um..."],[6952,7102,"they're gone."],[7111,7353,"Oh, I'm so sorry for your loss."],[7469,7632,"That said, if you're"],[7632,7761,"sure about this,"],[7761,7928,"you can start anytime."],[7928,8041,"That's great."],[8049,8191,"Let's start as soon as possible."],[8204,8379,"Just know t