],[4170,4441,"are you and the babies,"],[4512,4604,"are they okay?"],[4675,4821,"We'll talk when you get here."]],"24":[[279,454,"If I bring all this home,"],[454,604,"she'll see I'm serious."],[621,738,"She'll forgive me."],[796,888,"She has to."],[3874,3958,"Easton..."],[4016,4195,"You'll never see me again."],[4517,4654,"Hey Nina look,"],[4654,4738,"hey,"],[4788,4854,"I know I went"],[4854,4938,"overboard but I got"],[4938,5180,"I got the shoes and I got..."],[5180,5296,"the rattle that you bookmarked,"],[5296,5376,"I remembered..."],[5488,5568,"Nina!"],[6556,6635,"Nina?"],[6906,7015,"Uh, the babies..."],[7874,7974,"Where are the babies?"]],"25":[[91,171,"Nina,"],[216,375,"where are the babies?"],[375,533,"They're gone."],[533,671,"Our babies are gone."],[796,955,"No, no,"],[955,1067,"I don't believe you."],[1067,1247,"You went to the hospital right?"],[1276,1518,"Saw the post doc report, chart?"],[1539,1664,"I'm sure you've put"],[1664,1780,"it together by now."],[1797,1868,"And yes,"],[1868,1951,"Easton,"],[2031,2102,"that voice you"],[2102,2198,"heard on the plane?"],[2277,2435,"It was me."],[2435,2515,"No, you're lying."],[2619,2761,"No, you're mad that"],[2761,2836,"I wasn't there."],[2836,2911,"You're just trying"],[2911,2986,"to get back at me."],[2994,3061,"I mean come on,"],[3061,3240,"I mean even if something"],[3240,3349,"did happen to the babies"],[3349,3457,"they were full term!"],[3457,3528,"The doctors would"],[3528,3611,"have saved them,"],[3611,3720,"they had to!"],[3807,3924,"Well that's what this is..."],[4095,4229,"You're hiding them on me,"],[4229,4387,"because you wanna punish me."],[4387,4471,"Because I wasn't there"],[4471,4550,"when you gave birth."],[4696,4788,"You're hiding them,"],[4946,5067,"to punish me."],[6664,6848,"Hey Nina... stop."],[6936,7069,"Please stop."],[7349,7465,"Where are the kids?"],[7540,7711,"They died, Easton."],[7778,8120,"Our babies died. Because of you."],[8158,8383,"Because you weren't there,"],[8383,8575,"becau