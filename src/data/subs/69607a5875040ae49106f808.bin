{"1":[[621,746,"Happy 1 year anniversary,"],[746,809,"Easton."],[875,988,"I love you."],[988,1055,"Nina..."],[1117,1247,"I've got nothing."],[1413,1764,"I'm just a broke lab rat,"],[1764,1926,"hauling bricks by day,"],[1939,2077,"testing samples by night."],[2202,2323,"In this marriage,"],[2414,2548,"it's not a fairy tale,"],[2635,2848,"and it kills me that,"],[2848,3032,"you had to settle for me."],[3044,3244,"You never made me."],[3303,3424,"You don't look at me like"],[3424,3495,"I'm broken."],[3495,3603,"So don't be ashamed"],[3603,3691,"of where we are."],[3766,3870,"We've made it through"],[3870,4012,"everything since high school,"],[4012,4154,"and we're still standing."],[4212,4337,"The best days,"],[4375,4525,"they're still ahead."],[4942,5055,"You're the most beautiful girl"],[5055,5238,"I've ever laid my eyes on."],[6064,6264,"I, Easton Jones."],[6264,6385,"Promise to only love you"],[6385,6498,"for the rest of my life,"],[6498,6727,"if I ever lie, or cheat, or"],[6869,7044,"break your heart in any way."],[7140,7244,"Just once."],[7428,7582,"I walk away with nothing."],[7707,7962,"No money, no excuses,"],[7962,8108,"you get everything."],[8174,8387,"You better mean that,"],[8387,8554,"cause if you ever"],[8554,8683,"break my heart."],[8767,9067,"I'll vanish like I was never here."],[9104,9309,"That day is never coming."],[10493,10573,"Easton!"],[10668,10814,"I know it it's not much,"],[10814,10915,"but it's better than the one"],[10915,11002,"that you have now."],[11265,11428,"And one day I'll get you that one."],[11611,11715,"I'll buy you the biggest"],[11715,11799,"rock that they have,"],[11799,11895,"and one day you'll be,"],[11895,12037,"you'll be dripping in diamonds."],[12833,12967,"Well, put it on."],[17300,17442,"Please welcome"],[17442,17600,"the CEO of Jones Corp."],[17609,17746,"Mr.Easton Jones,"],[17746,17884,"and his business partner,"],[17884,18059,"Ms.Candice Black."]],"2":[[900,990,"Today,"],[1110,1303,"Jones Corp goes public."],[2120,2290,"But but..."],[2363,2440,"None of this would"],[2440,2510,"have happened,"],[2510,2733,"if it were not for the true MVP..."],[2863,2943,"Candice."],[3280,3683,"The truth is no her, no me..."],[3820,3970,"no Jones Corp."],[4270,4360,"Easton, if you"],[4360,4480,"hadn't trusted me"],[4480,4563,"none of this would"],[4563,4633,"have happened!"],[4660,4813,"We built this empire"],[4813,4973,"together side by side."],[5630,5720,"This"],[5903,6013,"is for Candice..."],[6360,6486,"to thank her for"],[6486,6630,"all the work she's done."],[6943,7023,"Nina"],[7100,7270,"do you see this?"],[7320,7526,"Easton's giving it to me"],[7526,7713,"tonight... on stage,"],[7730,7850,"under the lights."],[8123,8570,"You still don't get it do you?"],[8623,8773,"He hides you,"],[8773,9003,"because he's ashamed of"],[9003,9223,"that Mark on your face."],[9450,9590,"If it weren't for the twins"],[9640,9763,"he would have dumped"],[9763,9880,"your ass years ago."],[9960,10190,"I'm the one he wants beside him."],[10300,10420,"Not you."],[10793,10883,"Easton,"],[10970,11096,"do you even remember"],[11096,11223,"what you promised me?"],[11680,11790,"Thank you Easton,"],[11790,11930,"it's beautiful."],[11930,12053,"As Plato once said,"],[12053,12176,"“We are like two halves"],[12176,12270,"of the same whole.”"],[12460,12633,"Finally back together again."],[12693,12780,"Yeah,"],[12960,13040,"soulmates."],[13100,13213,"Soulmates huh?"],[13223,13363,"I guess Candice really"],[13363,13510,"is your better half now."],[13643,13753,"And me?"],[13900,14106,"And our babies? We’re just"],[14106,14320,"the part that you deleted."]],"3":[[738,867,"Miss Black, the world"],[867,967,"is dying to know..."],[967,1046,"What kind of guy gets"],[1046,1151,"your heart racing?"],[1176,1334,"Hmm let me think..."],[1380,1476,"6 foot,"],[1534,1655,"blue eyes,"],[1730,1935,"crushing it in the pharma world,"],[1976,2131,"smile that could melt steel..."],[2198,2385,"Sounds a lot like Mr Jones."],[2389,2565,"You two are even dressed to match."],[2577,2686,"Straight up power"],[2686,2761,"couple vibes."],[2786,2927,"Seriously, you're like the"],[2927,3069,"King and Queen of pharma."],[3094,3140,"You two"],[3140,3294,"should be the one saying I do!"],[3294,3495,"But Mr Jones, if you"],[3495,3666,"are still single,"],[3678,3757,"would you ever consider"],[3757,4029,"marrying someone like Miss Black?"],[4646,4754,"It'd be an honor."],[4821,4959,"I'd be lucky to have her."],[8295,8462,"If you two love each"],[8462,8658,"other that much... fine."],[8687,8829,"I'll sign the papers."],[8904,8996,"Hell, I'll walk you"],[8996,9100,"down the aisle myself."],[9205,9371,"Make sure you soulmates"],[9371,9526,"get your happy ending."]],"4":[[2944,3040,"Hi."],[3107,3211,"Evermore Weddings?"],[3328,3616,"Yeah, I need to change a booking."],[3745,3841,"It was booked for an"],[3841,3970,"anniversary dinner next week."],[4149,4366,"Make it a wedding instead."],[4554,4637,"Groom?"],[4817,4946,"Easton Jones."],[5117,5196,"Bride..."],[5388,5509,"Candice Black."],[7987,8070,"Babies..."],[8258,8358,"Please,"],[8608,8767,"don't hate me for this."],[8925,9025,"Okay?"],[9955,10035,"Nina..."],[10318,10372,"What's going on,"],[10372,10447,"why are you packing?"]],"5":[[0,75,"What's going on,"],[75,158,"why are you packing?"],[241,417,"It's just the hospital bag."],[454,579,"I just thought I'd get it ready."],[579,658,"You know, due date's"],[658,729,"around the corner."],[855,938,"You don't have to"],[938,1021,"worry about that, I..."],[1046,1184,"got that covered."],[1184,1276,"It's fine I..."],[1347,1443,"just need something"],[1443,1551,"to keep my hands busy."],[1555,1676,"I couldn't sleep."],[1676,1789,"Can't sleep?"],[1847,2010,"Are the twins kicking again?"],[2022,2260,"Hey! You guys in there!"],[2535,2719,"You be nice to your mama, okay?"],[2844,2944,"It's not them."],[3032,3148,"They've been angels."],[3420,3528,"Then it's me."],[3816,3966,"Look, Nina I I'm I'm"],[3966,4149,"sorry I've been drowning"],[4170,4320,"in IPO stuff. I didn't"],[4320,4458,"mean to shut you out."],[4537,4625,"Just, just give me a"],[4625,4779,"couple more days, and"],[4800,5034,"when I'm done, I'm all yours."],[5034,5238,"You, me, the twins."],[5288,5505,"That's the plan. Hey, hey..."],[5576,5680,"Thank you..."],[5839,5985,"For carrying them for me."],[6056,6143,"This everything"],[6143,6247,"you're doing for me?"],[6377,6464,"Is it just because"],[6464,6569,"I'm carrying your kids?"],[6577,6698,"What? No no, God."],[6698,6806,"Isn't it though?"],[6835,6981,"I'm not here because"],[6981,7140,"of the babies. I I want..."],[7144,7219,"the babies"],[7219,7349,"because I love you."],[8108,8191,"Easton,"],[8266,8408,"I remember how it felt"],[8408,8558,"when you used to love me."],[8629,8750,"That kind of fire,"],[8837,9004,"you can't fake it."],[9555,9659,"Then how come you never"],[9659,9776,"take me to your big events?"],[9847,10010,"Is it because of my face?"],[10076,10297,"No, Nina, no, I I never"],[10297,10414,"thought your birthmark was"],[10414,10535,"ugly, not even for a second."],[10548,10648,"But..."],[10760,10919,"I can't control what the rest of the world"],[10919,11040,"thinks, I don’t want them"],[11040,11106,"tearing you apart."],[11106,11177,"I was trying to protect..."],[11177,11327,"Protect me?"],[11515,11628,"Or hide me?"],[12208,12287,"Nina,"],[12399,12650,"your birthmark, it's part"],[12650,12867,"of you. It's beautiful."],[12975,13079,"I could have the entire"],[13079,13184,"world and it would mean"],[13184,13288,"nothing without you."],[13475,13630,"Easton actually, I..."],[13755,13868,"I'd like to..."]],"6":[[316,425,"Sorry, you..."],[425,558,"You were saying..."],[558,638,"Forget it."],[709,825,"Take your call. Okay,"],[825,955,"just give me one second,"],[955,1055,"I'll be right back."],[1096,1188,"No..."],[1276,1405,"No, take it here."],[1797,1989,"Easton, I just found this"],[1989,2231,"dreamy little spot in Honolulu."],[2277,2560,"Fly out with me pretty please?"],[2585,2686,"Yeah, alright alright."],[2686,2802,"Um, I'll catch the"],[2802,2907,"next flight out."],[2936,3144,"Just... I'll meet you at the gate."],[3595,3766,"That was work."],[3816,3987,"There's a big mess and"],[3987,4170,"I need to catch a flight."],[4170,4308,"I won't be long."],[4308,4475,"You think if you look away,"],[4508,4646,"I won't see the truth."],[4654,4771,"But I've seen your"],[4771,4888,"face for too long."],[4938,5096,"And the man behind it?"],[5125,5267,"He doesn't live here anymore."],[5326,5434,"Do you have to go?"],[5451,5534,"It's a..."],[5534,5626,"It's an emergency."],[5626,5718,"I can't get out of it."],[5718,5826,"So, um..."],[6026,6168,"You stay here and,"],[6168,6310,"and rest up and, I"],[6310,6435,"I don't wanna worry about"],[6435,6585,"you more than I already do so..."],[9801,9918,"Wanna see just how"],[9918,10039,"sweet he is to me?"],[10039,10189,"When no one's watching..."],[11661,11853,"Easton,I need to see"],[11853,12037,"it with my own eyes."],[12070,12162,"To see if you're really"],[12162,12241,"that tender with her,"],[12241,12408,"when no one is watching."],[12408,12575,"The way you used to be with me."],[13021,13146,"Your flight has been"],[13146,13267,"successfully booked."],[14301,14501,"So a 3 hour flight,"],[14501,14727,"two hours in traffic,"],[14777,14998,"all this for an overpriced meal?"],[14998,15131,"Oh come on,"],[15135,15190,"don't tell me"],[15190,15298,"you never pulled out the"],[15298,15407,"stops like this for Nina?"]],"7":[[20,225,"Nina and I, when we were together,"],[275,387,"we had nothing."],[454,625,"I mean fast food was a luxury."],[625,717,"we didn't even think"],[717,809,"of a place like this,"],[838,959,"even when we had money,"],[959,1105,"and things got complicated,"],[1188,1326,"she never asked for any more."],[1326,1438,"She never complained,"],[1459,1551,"she just rolled with"],[1551,1647,"it like she always did."],[1676,1889,"That's not love, Easton."],[2018,2097,"Love isn't"],[2097,2235,"surviving the storm."],[2235,2515,"It's standing in it with someone."],[2565,2673,"Sounds to me like you've"],[2673,2798,"done a whole lot more for me"],[2798,2940,"than you ever did for her."],[3019,3128,"Maybe..."],[3365,3536,"your love for her..."],[3536,3766,"isn't so deep after all."],[5255,5409,"Yeah, don't twist this okay?"],[5605,5776,"I love Nina."],[5793,5905,"Do you?"],[5968,6101,"Then why is she never by"],[6101,6231,"your side when it counts?"],[6297,6385,"I mean what's the"],[6385,6489,"real problem Easton?"],[6489,6619,"Is it that she didn't go"],[6619,6748,"to some Ivy League school,"],[6856,7057,"or is it that birthmark..."],[7094,7307,"that you just can't stand to"],[7307,7440,"be seen with?"],[7490,7636,"Her birthmark?"],[7799,7924,"It's tough, OK?"],[7978,8108,"I'm trying to build a brand,"],[8108,8224,"a face for the company,"],[8224,8337,"and that's just not it..."],[8337,8475,"Not for the brand."],[8475,8558,"I know."],[8938,9054,"You're the most beautiful"],[9054,9238,"girl I've ever laid my eyes on."],[9551,9718,"And that's just it. Trying"],[9718,9876,"to fix Nina's birthmark,"],[9876,10047,"that's how this all started,"],[10047,10281,"that's why I built Jones"],[10281,10464,"Pharma from scratch."],[10564,10677,"So please don't"],[10677,10806,"bring it up again."],[10869,10948,"Okay,"],[10998,11077,"okay."],[11148,11294,"But hear me out..."],[11411,11619,"What if you’ve outgrown her?"],[11795,11953,"You're not that guy"],[11953,12107,"scraping by anymore."],[12208,12291,"You deserve a"],[12291,12408,"woman on your level."],[12470,12587,"Nina's solid."],[12600,12746,"And she worked her ass"],[12746,12900,"off picking up a double"],[12900,13046,"just so I could finish school."],[13108,13213,"Even if she's not"],[13213,13325,"helping me grow now."],[13388,13576,"But you've got me now."]],"8":[[100,180,"You know first"],[180,290,"time that I saw you,"],[340,460,"I thought, ‘Wow,"],[600,703,"she looks"],[703,900,"exactly like Nina..."],[1080,1250,"‘If only she had that face.’"],[2003,2190,"So that's how you really feel..."],[2210,2323,"You promised you’d"],[2323,2460,"never be ashamed of me."],[2460,2540,"And I..."],[2640,2723,"God..."],[2790,2940,"I believed you."],[3270,3360,"Easton,"],[3533,3650,"you're drunk."],[3773,3950,"Let's go back to the hotel."],[3960,4070,"We've got a big meeting"],[4070,4180,"in the morning remember?"],[7433,7686,"I know how trapped you"],[7686,7923,"felt in that marriage."],[8073,8263,"Let me set you free tonight."],[8370,8476,"Let me show you"],[8476,8610,"what it feels like..."],[8793,8913,"to be wanted."],[9120,9213,"You look so good"],[9213,9340,"without that birthmark."],[10770,10850,"See?"],[11020,11133,"He's mine."],[11833,11970,"Easton!"],[13530,13690,"We're done Easton."]],"9":[[950,1230,"Easton.. what’s wrong?"],[1230,1526,"So last night was a mistake."],[1526,1685,"I was drunk, and I thought"],[1685,1826,"you were someone else."],[1876,2177,"You don't need to apologize."],[2339,2556,"You were incredible."],[2556,2761,"Besides,"],[2761,2973,"it's not like I left empty handed."],[3920,4074,"Candice."],[4074,4141,"Okay, let's get"],[4141,4200,"one thing straight."],[4200,4258,"Last night"],[4258,4325,"only happened"],[4325,4391,"because for a split"],[4391,4479,"second, I thought you"],[4479,4554,"were someone else."],[4554,4817,"I thought I saw Nina in you."],[4817,5017,"She's the only woman I love,"],[5017,5255,"and I'm not divorcing her."],[5255,5384,"Relax."],[5384,5526,"I'm not trying to screw up"],[5526,5684,"your perfect little marriage."],[5726,5876,"Last night was fun."],[5876,6039,"That's all. We're"],[6039,6177,"still friends."],[6177,6448,"Just the kind who..."],[6448,6635,"scratch each other's backs,"],[6635,6990,"and, a few other places."],[7841,8141,"Easton, can you come zip me up?"],[10014,10080,"What's wrong,"],[10080,10214,"Darling?"],[10214,10339,"You're looking at me like"],[10339,10468,"you haven't eaten in days."],[10573,10656,"If Nina didn’t have"],[10656,10873,"that birthmark..."],[10948,11115,"She'd look exactly like you."],[11528,11790,"Then pretend I’m her."],[11790,11870,"Whisper her name"],[11870,12074,"if it helps."],[12074,12312,"I’m not wearing any panties..."],[12312,12612,"Now take me."],[13792,13951,"I’m Exhausted."],[13951,14076,"Your fault, by the way."],[14101,14139,"Kept me up"],[14139,14218,"all night and"],[14218,14330,"again this morning."],[14401,14535,"If I pass out at that shareholder"],[14535,14731,"meeting, it's your fault."],[14818,14969,"All right,"],[14969,15144,"we'll take the hit."],[15173,15473,"Then be useful."],[15790,16049,"Candice, listen."],[16049,16191,"Nobody can know what"],[16191,16349,"happened in Honolulu."],[16441,16741,"Especially not Nina."],[16741,16941,"Relax."],[16941,17042,"I love having"],[17042,17171,"secrets with you."],[17171,17471,"It makes things way hotter in bed."],[19365,19561,"What the hell?"],[19561,19782,"That wasn't turbulence."],[19782,19978,"That bump was serious!"],[19978,20095,"God I hate"],[20095,20241,"flying. I hate this."],[20241,20328,"Ladies and gentlemen,"],[20328,20399,"due to a"],[20399,20478,"bird strike,"],[20478,20699,"the left engine has failed."],[20699,20808,"Please remain calm"],[20808,20908,"and stay seated."],[21388,21421,"Wait."],[21421,21500,"What did she just say?"],[21500,21596,"Engine failure?"]],"10":[[437,554,"The engine failed? What"],[554,658,"the hell is going on?"],[775,888,"Hey, hey,"],[896,996,"look at me,"],[1076,1188,"I've got you. Everything's"],[1188,1297,"gonna be fine, I promise."],[1338,1455,"Okay."],[1634,1789,"Oh, it's okay babies,"],[1835,1931,"We're okay."],[2027,2189,"Mommy's not going anywhere,"],[2189,2285,"we're okay."],[2339,2519,"This can't be happening, I"],[2519,2698,"don't wanna die like this!"],[2698,2869,"I didn't even call my mom!"],[2940,3086,"I should have called her."],[3107,3194,"I swear if we make"],[3194,3265,"it through this,"],[3265,3445,"I'm never flying again ever!"],[3628,3791,"Please remain calm, the crew"],[3791,3945,"is trained for emergencies."],[4020,4124,"We are handling it."],[4124,4208,"You're not alone."],[4358,4446,"We're okay."],[4629,4846,"It's okay, it's okay, it's okay."],[6135,6214,"Ah!"],[6297,6498,"Ah something's not right..."],[6827,6998,"Oh, it hurts!"],[7048,7161,"She's bleeding!"],[7248,7399,"She's pregnant!"],[7399,7595,"Someone, please help!"]],"11":[[196,346,"Ma'am is everything okay?"],[567,717,"Easton what are you looking at?"],[930,1009,"Nothing."],[1117,1242,"I just got this"],[1242,1426,"gnarly pit in my chest,"],[1555,1626,"feels like"],[1626,1726,"something's really off."],[1751,1881,"Hey, we've made it through"],[1881,2018,"hell and out the other side."],[2018,2281,"This? This is just turbulence,"],[2318,2510,"planes are built for this."],[2648,2752,"We'll land in"],[2752,2890,"one piece, I swear."],[2977,3144,"Yeah, Yeah."],[3161,3265,"Yeah you're right."],[3265,3386,"Nina..."],[3407,3486,"The twins..."],[3561,3661,"They're waiting for me."],[3661,3749,"I gotta make it home."],[4596,4758,"with this storm and the delay,"],[4758,4938,"traffic is gonna be insane."],[4946,5025,"If we miss that"],[5025,5125,"shareholder meeting,"],[5138,5255,"we're screwed."],[5338,5530,"Don't worry, I've got a plan."],[6047,6185,"Don't worry, everything's"],[6185,6264,"gonna be fine."],[6264,6406,"I'm I'm right here."],[6831,6936,"Excuse me?"],[7007,7144,"My name is Easton"],[7144,7336,"Jones, CEO of Jones Corp."],[7336,7503,"If is there any way"],[7503,7716,"that me and my... associate"],[7716,7916,"and I can disembark first?"],[7916,8120,"I understand sir,"],[8137,8262,"but we have passengers"],[8262,8400,"with medical emergencies."],[8400,8546,"They'll need priority."],[9121,9534,"Please save my babies!"],[9534,9651,"Ma’am, hang in there we're"],[9651,9805,"beginning our descent now"],[9805,9884,"there's an ambulance"],[9884,9976,"waiting on the ground."],[9976,10093,"We'll be in the hospital"],[10093,10197,"in just a few minutes."],[10197,10318,"I promise."],[10360,10481,"Please..."],[10577,10748,"I'm begging you!"],[10814,11048,"Save my babies..."]],"12":[[804,967,"Mr. Jones, I get it."],[967,1088,"I really do."],[1088,1217,"But tensions back there"],[1217,1326,"are through the roof."],[1326,1488,"There's a pregnant woman"],[1488,1618,"in serious trouble."],[1618,1747,"And if I bump you two up,"],[1747,2047,"it's going to cause a scene."],[2857,2977,"Jones Corp keeps"],[2977,3115,"thousands employed."],[3115,3261,"We pump billions into the"],[3261,3345,"economy. If we"],[3345,3449,"miss this meeting,"],[3457,3578,"everything we've built"],[3578,3678,"goes up in flames."],[3678,3820,"All right, here's the deal."],[3820,3891,"I will dump 10"],[3891,3974,"million into your"],[3974,4049,"airport’s fund,"],[4049,4137,"to just make sure"],[4149,4383,"we get off this plane first."],[4383,4475,"Sir, I..."],[4475,4717,"I really don't know if I can."],[4717,4808,"Listen, she's got"],[4808,4925,"an ambulance, right?"],[4925,5050,"Medics, sirens."],[5050,5305,"All of it... she’ll be fine."],[5305,5380,"We're talking"],[5380,5467,"ten minutes here."],[5467,5563,"It could really"],[5563,5668,"make or break us."],[5668,5830,"All right,"],[5830,5930,"I'll see what I can do."],[5930,6039,"Thank you so much."],[7340,7465,"Easton!"],[7465,7678,"I'm not scared of dying."],[7678,7841,"What I am scared of..."],[7841,7941,"Is not telling you..."],[7941,8058,"before it's too late."],[8058,8208,"Ladies and gentlemen, we're"],[8208,8329,"preparing for landing."],[8329,8458,"Please stay calm and"],[8458,8575,"keep your seatbelt fastened."],[8575,8871,"What? What are you saying?"],[8871,9054,"I love you, Easton!"],[9054,9205,"Even if you only see me as"],[9205,9367,"your stand in, I don't care."],[9426,9726,"I still love you."],[10076,10781,"Ahhhh!"],[13158,13396,"Oh my God."],[13396,13517,"Oh my God."],[13517,13705,"We’re alive!"],[13705,13859,"Honey, we landed!"],[13859,13934,"We're safe."],[13934,14235,"We made it."],[15807,15895,"What the hell was that?"]],"13":[[43,140,"Easton don't"],[140,240,"don't think too much of it,"],[240,340,"I thought we were gonna die!"],[340,450,"It was a joke! Candice,"],[450,540,"don't say anything"],[540,640,"like that ever again."],[660,816,"What, are you afraid"],[816,993,"that I'll replace her?"],[993,1083,"That I'll shove Nina"],[1083,1160,"out of the picture?"],[1160,1333,"I told you before, there's"],[1333,1513,"only one woman in my heart,"],[1513,1690,"my wife, Nina."],[1840,1940,"Whatever was between"],[1940,2043,"us it was never real."],[2090,2170,"Right."],[2223,2310,"Got it."],[2360,2446,"I’m just useful to you"],[2446,2550,"cause I've got her face."],[2873,2986,"I'm not dying on"],[2986,3103,"this metal coffin."],[3150,3310,"I'm not going out like this."],[3443,3646,"Everybody, stop! We haven't"],[3646,3820,"deployed the slide yet."],[3820,4003,"Do not push forward!"],[4313,4400,"Mister Jones?"],[4440,4540,"There's a pregnant woman"],[4540,4620,"crashing in economy."],[4620,4770,"The ambulance is stuck in traffic."],[4780,4850,"Can we use your"],[4850,4960,"helicopter to get her out?"],[5240,5350,"A pregnant woman?"],[5593,5746,"Don't do this! If you"],[5746,5873,"lose that chopper,"],[5873,5950,"we'll miss the meeting,"],[5950,6070,"and you'll lose everything"],[6070,6150,"that you've built."],[6370,6470,"They said the traffic"],[6470,6570,"clears in ten minutes."],[6573,6653,"Ten."],[6703,6780,"If I'm not there,"],[6780,6860,"the deal crumbles."],[6860,7063,"I mean we're talking billions."],[7093,7270,"People's jobs the market,"],[7333,7413,"everything."],[7493,7630,"Sir, this can't wait,"],[7630,7760,"she's hemorrhaging!"],[8460,8573,"Easton Jones,"],[8703,8823,"he's..."],[8830,8943,"What's wrong with you people?"],[8943,9000,"Let us out!"],[9000,9130,"He's my husband."],[9163,9450,"Wait what? Please call him."]],"14":[[29,258,"Easton Jones is your husband?"],[258,412,"Please call him."],[412,525,"Emily, Emily!"],[525,692,