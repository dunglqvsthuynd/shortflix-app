{"1":[[988,1059,"Beg me."],[1172,1263,"Please me."],[1313,1459,"Show me how far you'll go."],[1572,1735,"Impress your future king."],[1876,1964,"I used to be the guy"],[1964,2093,"everyone stayed away from."],[2206,2373,"How the hell did I end up here?"],[4029,4137,"Yeah, Grandma?"],[4245,4295,"Yeah."],[4295,4371,"I got the scarf."],[4471,4617,"Alright, I gotta get to class."],[4646,4717,"I'll talk to you later."],[4750,4821,"Love you."],[4833,4888,"Bye."],[5021,5142,"Hey, I'm a student here!"],[5142,5271,"I have to get to class."],[5296,5355,"Back up."],[5380,5463,"The prince is here."],[8416,8458,"No!"],[8458,8529,"My scarf!"],[8717,8783,"I said,"],[8812,8896,"back it up!"],[8904,9046,"You can go when the prince leaves."],[9426,9496,"Oh my God!"],[9496,9588,"He's so handsome."],[9601,9663,"I can't believe"],[9663,9780,"he's going to our school."],[9809,9947,"My prince, over here!"],[9976,10080,"We love you."],[10168,10260,"Your Highness,"],[10260,10393,"what an honor to have you"],[10393,10514,"at St. George High."],[10514,10627,"The pleasure,"],[10627,10698,"is all mine."],[10710,10835,"These rich bastards couldn't care"],[10835,10994,"less about ordinary folks."],[10994,11173,"Every smile, every gesture,"],[11207,11315,"it's all a performance."],[11323,11423,"Your Highness,"],[11423,11569,"many have rumored that"],[11569,11690,"you're here for marriage."],[11711,11895,"I'm sorry, no interviews today."],[11920,12062,"I'm just here as a regular student."],[12070,12132,"Of course,"],[12132,12299,"how humble, Your Majesty."],[13271,13480,"Oh my God, I love you so much."],[13484,13601,"Can I get a autograph?"],[14155,14272,"This arrogant prick."],[14301,14393,"This weird punk."],[14435,14531,"What's his problem?"],[14531,14589,"Thank you again,"],[14589,14668,"I need to go to class now."],[14668,14856,"Yeah, real humble,"],[14885,14981,"for someone who's never looked at"],[14981,15119,"anyone but themselves."],[15686,15769,"You can go now."],[15799,15886,"I'm going to class."],[15932,16024,"Yes, Your Highness,"],[16024,16274,"but don't forget Her Majesty's words."],[16341,16562,"You must marry Alice Newton."],[16587,16770,"Her family's fortune and influence"],[16770,16950,"will rally Parliament behind us."],[16991,17192,"More than your Uncle Dolan ever could."],[17233,17434,"Without it, he will seize power,"],[17434,17609,"and our nation will suffer."],[17655,17901,"You are the Prince of Entrada."],[17901,18013,"My only heir."],[18063,18314,"But with that crown, comes sacrifice."],[18697,18822,"That's Alice Newton."],[18881,18993,"Perfect time to say hello,"],[18993,19085,"Your Highness."],[19206,19348,"What the hell is Prince Charming"],[19348,19473,"trying to pull with Alice?"],[19494,19615,"He better stay the hell away"],[19615,19740,"from my best friend."],[19807,19894,"My only friend."],[20787,20891,"Don't touch her!"]],"2":[[79,179,"Oh my God!"],[321,513,"Lucas is kissing the prince?"],[533,625,"No pictures."],[1005,1109,"Get off me!"],[1201,1330,"You think I wanna be on top of you?"],[1330,1426,"Who the hell are you?"],[1459,1514,"Get off!"],[1514,1572,"Now!"],[1972,2022,"I'm the guy"],[2022,2177,"whose scarf you stepped on today."],[2189,2273,"What scarf?"],[2277,2352,"Exactly."],[2414,2573,"Listen up, prince boy."],[2602,2769,"The name is Lucas Wilder,"],[2811,2894,"remember that."],[2940,3028,"And Alice,"],[3148,3319,"she's my best friend."],[3319,3465,"So whatever you've got planned,"],[3507,3586,"I won't allow it."],[3599,3687,"First off,"],[3737,3858,"don't call me prince boy."],[3949,4033,"Second of all,"],[4033,4371,"Alice will make a wonderful princess."],[4404,4533,"It's what the nation needs,"],[4533,4921,"and it's not for you to decide."],[4921,5046,"Stop it, you two."],[5046,5171,"Everyone's staring."],[5330,5497,"You think what this nation needs"],[5497,5613,"is a little marriage pact?"],[5613,5739,"Why don't you start a little tea party"],[5739,5847,"to save the economy too?"],[5855,5960,"Wake up and smell the coffee,"],[5960,6047,"Prince Charming,"],[6081,6197,"this isn't a fairy tale."],[6197,6264,"You have no idea"],[6264,6364,"what you're talking about."],[6377,6606,"Listen up, Lucas Wilder."],[6619,6760,"Nobody gets in my way."],[6886,6956,"Nobody."],[7061,7152,"Watch me."],[7298,7428,"Your Highness."],[7753,7832,"Your Highness,"],[7878,7999,"your shirt is dirty."],[8049,8145,"Let's go change."],[8195,8262,"Run along."],[9117,9238,"Get me everything you can"],[9238,9342,"on Lucas Wilder."],[9371,9476,"I want a full report."]],"3":[[4,125,"You can't really tell me you wanna"],[125,258,"marry that arrogant jerk."],[271,367,"Of course I don't."],[379,525,"My dad mentioned something"],[525,621,"about the royal family"],[621,742,"wanting a marriage alliance."],[742,913,"But you know me,"],[913,1067,"I hate all that political stuff."],[1092,1159,"Don't worry."],[1192,1305,"I'll make sure he leaves you alone."],[1351,1401,"And screw that"],[1401,1534,"political marriage bullshit."],[1572,1643,"Is that so?"],[1701,1810,"Because it kinda seemed like"],[1810,1972,"that fight wasn't about me at all."],[2093,2231,"A lot of sparks were flying"],[2231,2306,"between you two."],[2398,2502,"Hell no."],[2527,2577,"No way."],[2577,2648,"Yes way."],[2907,3090,"Maybe you should marry him."],[3178,3299,"It'll get him off my back."],[3319,3390,"Shut up."],[3449,3561,"We're late for class."],[4491,4567,"It's him."],[4792,4917,"No freaking way."],[4938,5042,"Class, settle down."],[5055,5351,"This is His Royal Highness,"],[5405,5518,"Prince Nicholas."],[5559,5689,"He's your new classmate."],[5784,5855,"It's my pleasure."],[5914,5985,"Your Highness."],[5985,6068,"We've prepared this seat"],[6068,6177,"for you here. - Oh, thank you."],[6177,6314,"That's fine, actually."],[6314,6456,"Uh, I prefer the back."],[7023,7119,"What the hell is he doing?"],[7178,7294,"He's not about to sit next to me,"],[7294,7369,"is he?"],[8837,8950,"It's nice to meet you,"],[9054,9121,"neighbor."],[9296,9405,"You have my attention now."],[9459,9588,"Every damn day."]],"4":[[342,500,"He definitely has a thing for you."],[1026,1167,"A thing?"],[1167,1430,"What is she talking about?"],[2223,2444,"Sure, he looks good"],[2569,2711,"for an arrogant jerk."],[3661,3699,"Wait,"],[3766,3916,"what the hell am I thinking?"],[3987,4124,"Snap out of it, Lucas,"],[4175,4270,"he's the enemy!"],[4358,4450,"I'll teach you what happens"],[4450,4637,"when you mess with a prince, commoner."],[4988,5192,"Lucas Wilder is a top racer"],[5192,5317,"in the underground circuit."],[5317,5518,"He rides fast and reckless."],[5543,5726,"People call him the Black Jackal."],[5743,5872,"Figures."],[5918,6018,"I was right."],[6122,6310,"He's just a street rat"],[6310,6556,"who thinks he's above the law."],[6635,6740,"Your Highness, is that,"],[6806,6965,"Lucas Wilder, right there?"],[8266,8454,"Is Wilder giving them a shakedown?"],[8575,8654,"Black Jackal?"],[8737,8863,"More like a rabid dog."],[8888,9025,"He needs to be put on a leash"],[9025,9150,"and taught some manners."],[9271,9509,"Prepare a gift in my name."]],"5":[[354,458,"You fuckers try to steal"],[458,579,"Billy's lunch money again,"],[663,725,"it'll get worse"],[725,855,"than just a few bruises."],[892,934,"Got it?"],[1001,1188,"Yes, yes, Lucas."],[1209,1305,"It won't happen again."],[2131,2206,"You okay?"],[2631,2857,"Thank, thanks, Lucas."],[2957,3011,"Yeah."],[3244,3328,"Call the others."],[3407,3528,"This isn't over, asshole."],[3870,3941,"Yeah, Grandma,"],[3958,4074,"everything's going good."],[4133,4220,"School's great."],[4220,4437,"I made a ton of new friends this year."],[4437,4696,"I'm like, really popular."],[4738,4996,"Oh, sweetheart, that's good to hear."],[5088,5276,"And make sure you stay out of trouble."],[5326,5492,"I don't wanna hear you race anymore,"],[5492,5576,"you hear me?"],[5584,5714,"It's too dangerous."],[5901,6010,"I have to race to make money"],[6010,6106,"to stay in school."],[6302,6393,"Yeah, you know I got"],[6393,6498,"that new delivery gig."],[6594,6748,"I won't ride anymore, I promise."],[6831,7007,"Alright, honey, you take care."],[7007,7069,"Love you."],[7236,7344,"I love you too."],[8174,8395,"A gift for my dear neighbor?"],[8433,8679,"That posh jerk sent me a gift?"],[8775,9059,"Is this some kind of trick, or..."],[9788,9868,"Did Nicholas"],[9939,10055,"just smile at me?"],[10201,10356,"Wish I could stay to see him open it."],[10368,10560,"The look on his face must be hilarious."],[10568,10639,"Your Highness,"],[10714,10839,"the reporters are waiting."],[12374,12529,"I've never gotten a gift before."],[12529,12708,"Not from anyone at school, at least."],[12729,12841,"Does this mean Nicholas"],[12850,12925,"wants to be"],[13058,13146,"friends?"]],"6":[[41,212,"Maybe this is some kind of prank?"],[254,304,"Or maybe"],[367,563,"this is his way of saying truce?"],[604,684,"I should give him the benefit"],[684,759,"of the doubt."],[896,1046,"He definitely has a thing for you."],[1180,1305,"I wanna see what's inside."],[1343,1443,"Well, well."],[1480,1634,"What do we have here?"],[1739,1801,"Give it back!"],[1851,1968,"Come and get it, asshole."],[2014,2164,"Last time you got me off guard,"],[2164,2348,"but this time I came prepared."],[2369,2494,"We're gonna beat your ass"],[2494,2669,"and make you pay for what you did."],[2698,2756,"Oh yeah?"],[2869,2948,"Try me."],[2998,3061,"I'll mess you up"],[3061,3169,"worse than the last time,"],[3211,3324,"then you can go running home"],[3324,3399,"to Mommy."],[3470,3541,"Get him, boys."],[3849,3945,"Stop right there!"],[4066,4216,"Or I'll smash your gift to pieces."],[4233,4379,"Put it down, you son of a bitch!"],[4446,4562,"Oh."],[4625,4688,"Boys, he actually"],[4688,4850,"cares about this thing."],[4909,4984,"Aww."],[5013,5180,"Are you nervous over a little gift?"],[5226,5317,"No one ever got you"],[5317,5459,"something nice before?"],[5880,5976,"Teach him a lesson!"],[6022,6072,"Yeah."],[6664,6861,"Okay, you've had your payback."],[6877,6973,"Now give me the box."],[6973,7152,"I'm not done having fun yet."],[7778,7836,"Stop!"],[7903,8037,"Don't touch my shit!"],[8241,8308,"No!"],[9125,9255,"Thank God I caught it."],[10460,10593,"What the hell?"],[10831,10898,"Lucas,"],[10952,11144,"the prince's good boy?"],[11344,11569,"A dog leash?"],[11957,12012,"Leash up and"],[12012,12199,"wag your tail for me, doggy."]],"7":[[41,154,"This is the precious gift"],[154,271,"you're freaking out over?"],[316,592,"A dog leash with your name on it."],[592,709,"Oh my God!"],[838,1013,"Lucas Wilder's into collars?"],[1051,1130,"You know, I didn't take you"],[1130,1288,"for the kinky type, bro."],[1455,1726,"You son of a bitch, Nicholas Valeheart."],[1726,1918,"Who's your master, doggy?"],[1931,2060,"Woof, woof!"],[2331,2410,"Woof, woof."],[2410,2535,"Doggy's got a new owner."],[2573,2694,"I'm not done with you yet."],[2694,2957,"Unless you want a broken nose, Mark,"],[3028,3203,"stay the fuck away from me!"],[3928,3987,"Your Highness,"],[4012,4225,"today's livestream starts in 15 minutes."],[4225,4408,"The Royal PR team has prepared"],[4408,4504,"some key top- - Vivian,"],[4558,4617,"please."],[4617,4817,"Can I just have 15 minutes of peace?"],[4967,5030,"Yes."],[5030,5184,"I'll come collect you in 15."],[5430,5518,"Finally."],[5626,5768,"Some peace and quiet."],[5814,5926,"I wonder if that hothead"],[5926,6056,"opened my present yet."],[6122,6210,"I'd give anything"],[6210,6343,"to see the look on his face."],[6514,6639,"That wasn't 15 minutes."],[6719,6810,"Leave me alone."],[6823,6886,"Too bad."]],"8":[[141,241,"Explain!"],[321,475,"Why did you send me a dog collar?"],[542,663,"That's what they call you, isn't it?"],[738,842,"The Black Jackal?"],[930,1009,"You need a dog collar"],[1009,1167,"just to keep you away from me."],[1172,1259,"Shut up!"],[1343,1430,"I thought you sent it to me"],[1430,1505,"because you-"],[1522,1597,"Because what?"],[1735,1789,"Oh."],[1851,1935,"Because you,"],[1989,2102,"you actually thought"],[2102,2252,"I wanted to be your friend?"],[2369,2569,"I stopped playing house when I was 5."],[2648,2752,"Only an idiot"],[2781,2927,"would think that a prince"],[2973,3178,"would want to be friends with you."],[3340,3495,"Wag your tail, good boy."],[3566,3712,"Maybe I'll throw you a bone."],[3778,3874,"And who said"],[3891,4074,"I want to be friends with you?"],[4108,4204,"All I want"],[4220,4446,"is to take off your perfect mask"],[4446,4783,"in front of the whole damn country."],[4909,4975,"They're waiting for you"],[4975,5117,"on the livestream right now,"],[5117,5192,"aren't they?"],[5288,5359,"Your Highness?"],[5380,5451,"Please open up."],[5513,5663,"Our livestream starts in 2 minutes."],[5663,5726,"Yeah."],[5726,5885,"We've got billions of viewers waiting."],[5910,5980,"Get the key."],[6377,6481,"What are you doing?"],[6606,6731,"Let go of me."],[6731,6861,"I'm fine with the whole world"],[6861,6961,"seeing us like this."],[7027,7132,"Are you?"],[7132,7336,"How dare you!"],[7424,7507,"I'm the future king."],[7607,7795,"My, my guards will come arrest you."],[8145,8370,"Then scream for help."],[8395,8583,"Let the whole world see you like this."],[8583,8683,"Hands tied."],[8696,8917,"Struggling under me."],[8946,9075,"This is your last warning."],[9134,9217,"Let"],[9250,9334,"me"],[9376,9459,"go."],[9547,9676,"Do you know why they call me"],[9676,9797,"the Black Jackal?"],[9884,10105,"It's because I bite back."],[10306,10435,"Oh God."]],"9":[[87,162,"I've got the key."],[287,358,"Finally."],[383,450,"Our viewers,"],[450,613,"we're live at St. George's High."],[613,742,"Are you ready for a sneak peek"],[742,900,"into His Highness's spicy"],[900,1059,"and wild high school life?"],[1288,1405,"You actually fucking bit me."],[1576,1739,"You are a fucking dog."],[2173,2235,"Get off me."],[2235,2373,"Say dog one more time,"],[2373,2565,"and I swear I'll show the whole world"],[2565,2781,"exactly how I bite."],[2781,2857,"Lucas Wilder,"],[2857,2982,"you cannot threaten me."],[3044,3161,"You have no sway over me."],[4200,4371,"Are you hard right now?"],[4466,4533,"Your Highness"],[4533,4754,"can't seriously be turned on by this."],[4754,4850,"Well, I'm not."],[5292,5380,"Stop looking!"],[5580,5651,"Stop looking."],[5651,5722,"Get off me."],[5793,5943,"What am I doing?"],[6010,6189,"I thought I was just proving a point, but,"],[6189,6331,"this is starting to make me feel"],[6377,6493,"weird too."],[6794,6961,"I can't let the world see me like this."],[7002,7119,"The royal family's reputation"],[7119,7198,"will be ruined."],[8033,8124,"Listen,"],[8208,8362,"you little-"]],"10":[[16,108,"My God!"],[129,204,"I can already see"],[204,321,"tomorrow's headlines,"],[321,500,"Prince Nicholas Goes for a Ride..."],[521,621,"on a Boy!"],[621,709,"Wait! - Your Highness!"],[709,763,"Your Highness!"],[763,896,"Is this you coming out of the closet?"],[896,980,"No photos!"],[980,1109,"That's it for today's livestream."],[1109,1238,"Thank you very much."],[1238,1284,"Thank you!"],[1284,1434,"What about an heir, Your Highness?"],[1434,1509,"How will you secure"],[1509,1584,"the royal bloodline?"],[1584,1764,"Huge misunderstanding."],[1764,1868,"They're just friends."],[1868,2006,"It was an accident."],[2006,2081,"Is it true?"],[2081,2206,"Is His Highness your friend?"],[2423,2531,"Is he gonna help me?"],[2994,3161,"We're not friends."],[3294,3453,"Not in a million years."],[3707,3778,"His Highness"],[3778,3933,"doesn't deserve my friendship."],[4408,4542,"I hurt his feelings."],[4721,4813,"Did I go too far?"],[4846,4900,"Your Highness,"],[4900,5000,"any response?"],[5000,5105,"Hey, that's it. - Prince Nicholas!"],[5105,5159,"Thank you, look this way."],[5159,5246,"thank you very much."],[5284,5376,"No more photos!"],[5376,5463,"Thank you!"],[5476,5601,"Please, Your Highness!"],[5601,5726,"Thank you very much."]],"11":[[621,880,"Get this fucking dog leash off me!"],[880,967,"Easy."],[1109,1209,"You want me to let you go?"],[1472,1530,"Beg me."],[1668,1735,"Please me."],[1918,2056,"Show me how far you'll go."],[2202,2414,"Every dirty trick."],[2414,2648,"Every secret move."],[2677,2815,"Impress your future king."],[2882,3098,"In your dreams."],[3098,3203,"In my dreams?"],[3365,3478,"Look around, Lucas."],[3611,3728,"You're in my palace."],[3916,4045,"At my mercy."],[4120,4241,"I make the rules here."],[4366,4608,"So, until I'm satisfied,"],[4713,4929,"you're not going anywhere."],[5038,5138,"Don't be so sure."],[5138,5246,"Get off me."],[5296,5409,"Isn't this what you wanted,"],[5501,5618,"Your Highness?"],[5672,5801,"For me to please you?"],[5818,5985,"I'm not supposed to like this..."],[6043,6122,"but...."],[6177,6289,"Quit denying it!"],[6364,6477,"We both know"],[6477,6769,"you got hard for me today, Nicholas."],[6785,6931,"Don't flatter yourself."],[7336,7469,"Just as I thought."],[7557,7691,"Hard as a rock."]],"12":[[2460,2577,"Who's the dog now?"],[2577,2690,"Fuck off."],[2773,2894,"Stop pretending."],[2936,3094,"We both know you want me."],[3211,3261,"Badly."],[3332,3495,"Don't flatter yourself."],[3582,3691,"I'm a prince,"],[3799,3883,"and you're just..."],[4016,4066,"you."],[4137,4275,"Why would I ever want you?"],[4300,4504,"We're in your dream, aren't we?"],[4658,4771,"You want me here."],[4863,5067,"My body against yours."],[5163,5271,"Kissing you."],[5392,5734,"Doing all the bad things you yearn for."],[5889,6039,"You don't wanna wake up,"],[6093,6147,"do you?"],[6406,6544,"You love boys,"],[6577,6648,"don't you?"],[6769,6844,"No way."],[6927,7048,"I'm the heir to the throne."],[7173,7228,"I can't."],[7311,7394,"Oh, I get it."],[7532,7649,"It's not boys you want."],[7816,7907,"It's just..."],[8028,8116,"me."]],"13":[[1785,1835,"What the hell - What the hell"],[1835,1943,"was that? - was that?"],[1964,2022,"Ugh."],[2056,2227,"Why did I dream about Nicholas?"],[2243,2352,"He's supposed to be the enemy."],[2398,2627,"Not, whatever this is."],[3470,3632,"Why on earth did I dream about"],[3632,3770,"hooking up with Lucas?"],[3858,4162,"And why did it feel so good?"],[4346,4425,"Oh my God."],[4733,4817,"I like boys?"],[4817,5030,"What the fuck?"],[5030,5276,"I like Lucas Wilder?"],[5434,5488,"Mother!"],[5518,5618,"You could've knocked."],[5705,5910,"Explain these to me at once."],[6097,6214,"Why are all of the headlines"],[6214,6339,"saying that you are gay?"],[6364,6539,"Do you realize the disgrace"],[6539,6644,"you could bring upon your name,"],[6644,6769,"upon the throne?"],[6769,6840,"The last few months"],[6840,6927,"before the coronation"],[6927,7044,"are the most important,"],[7057,7157,"and I've thrown myself"],[7157,7303,"into a media death spiral."],[7323,7432,"Mom, it was an accident."],[7499,7595,"It won't happen again."],[7661,7711,"I promise."],[7866,8158,"Thankfully, we can still salvage this."],[8216,8329,"We're hosting a big party"],[8329,8408,"on New Year's Eve."],[8408,8604,"I've invited all of your classmates."],[8679,8829,"It would help you appear more"],[8829,8950,"relatable to the public."],[9059,9146,"And I'll make sure to give you"],[9146,9296,"plenty of alone time with Alice"],[9296,9501,"to squash these rumors."],[9743,9859,"All my classmates?"],[9980,10068,"Lucas Wilder's"],[10068,10181,"coming to my palace?"]],"14":[[567,725,"Take a break, sweetheart."],[900,980,"Hey, Grandma."],[1343,1714,"I squeezed you some fresh orange juice."],[1789,1868,"All fixed, Grandma."],[1943,2060,"It was just a loose throttle wire."],[2085,2235,"Oh, well I don't know"],[2235,2356,"what those things are,"],[2389,2573,"but I'm glad you do."],[2635,2686,"Thank you."],[2711,2911,"You get this from your Dad, you know?"],[2911,2982,"Car stuff."],[3119,3257,"He would be so proud of you,"],[3257,3374,"if he were still here."],[3532,3645,"Your mama, too."],[3728,3916,"Yeah, I know, Grandma."],[3962,4041,"Yeah."],[4041,4108,"Lucas."],[4237,4308,"Hey,"],[4341,4471,"the prince invited us"],[4471,4700,"to a New Year's Eve party at the palace."],[4713,4788,"Are you going?"],[4850,4979,"Now, what party is this-"],[4979,5080,"It's just some stupid party"],[5080,5184,"the prince is throwing."],[5246,5326,"I'm not going,"],[5442,5547,"and neither should you."],[5751,6047,"I bit him, tied him up against a door..."],[6047,6185,"This invite feels like a setup."],[6210,6322,"I wish it were different."],[6423,6577,"But my father has always said,"],[6664,6848,"privilege comes with a price."],[6865,7136,"And now is my time to pay."],[7286,7332,"My marriage"],[7332,7490,"was never mine to choose,"],[7532,7707,"and I know the same goes for Nicholas."],[7778,7853,"Turns out the prince boy"],[7853,7970,"can't have everything,"],[8066,8195,"I guess he's trapped too,"],[8274,8458,"maybe that's why he acts like a jerk."],[8708,8762,"He..."],[8854,8925,"I can't let you go"],[9159,9230,"alone."],[9376,9471,"I'll go with you."],[9492,9547,"Really?"],[9559,9663,"Not because you secretly"],[9663,9763,"wanna see him yourself?"],[9776,9834,"No."],[9868,9926,"Of course not."],[9926,10014,"That's, no."],[10043,10164,"You know, I heard"],[10164,10310,"that he actually passed out"],[10310,10447,"from a panic attack"],[10481,10627,"from that little stunt you pulled."],[10627,10698,"He, is he okay?"],[10698,10764,"What happened?"],[10769,10956,"See, you are worried about him."],[11106,11327,"But I'm serious, he passed out."],[11361,11569,"He built his whole life"],[11611,11882,"on strength and composure."],[11928,12112,"The fact that he's cracking now,"],[12157,12333,"the pressure must be eating him alive."]],"15":[[775,884,"Is that why it looked like"],[884,992,"he was going to cry?"],[1130,1276,"First time I've seen him like this."],[1359,1413,"Fragile."],[1522,1630,"Why do I feel"],[1705,1776,"guilty?"],[1910,2143,"You can't wear this to the royal palace."],[2268,2389,"Let's get you suited up."],[2973,3069,"Your Highness."],[3474,3561,"She's alone?"],[3641,3741,"Lucas isn't here?"],[3828,3908,"Ms. Newton."],[4037,4120,"Welcome."],[4254,4396,"Why isn't Lucas here?"],[4416,4550,"Did he not get the invitation?"],[4612,4679,"Whatever."],[4704,4808,"It's better this way."],[4867,4979,"He'd only mess with my head."],[5055,5134,"Your Highness."],[5213,5359,"The party's about to begin."],[7586,7640,"He's here,"],[7720,7811,"in a tux,"],[7878,7962,"on a bike."],[8103,8266,"Why is my heart racing?"]],"16":[[500,667,"Is that the guy the prince was..."],[729,784,"riding?"],[888,988,"Sir! Sir!"],[988,1101,"The whole nation thinks that"],[1101,1172,"you're dating."],[1172,1276,"Do you have any comments?"],[1372,1459,"They're just friends."],[1505,1651,"Please, step back."],[1751,1797,"Yes."],[1843,1906,"That's right."],[1931,2143,"We are just good friends."],[2143,2285,"It was a complete misunderstanding."],[2302,2402,"Isn't that right, Lucas?"],[2544,2602,"Lucas."],[2786,2936,"Actually, we-"],[3086,3219,"If you ruin this for me,"],[3324,3440,"I will kick you the hell out."],[3474,3591,"I will be furious,"],[3607,3745,"and then Alice will have to spend"],[3762,3924,"the rest of the night with me."],[3978,4029,"Okay?"],[4116,4270,"So I would choose your next words"],[4312,4454,"very carefully."],[4596,4642,"Great."],[4817,4946,"Sir, are you dating?"],[4946,5071,"Please, tell us."],[5588,5647,"Dating?"],[5659,5855,"No, you guys are hilarious."],[5964,6060,"We're good friends."],[6164,6318,"Best buddies, even."],[6398,6481,"Isn't that right,"],[6527,6614,"Your Highness?"],[6781,6898,"Absolutely right."]],"17":[[938,1038,"Welcome"],[1088,1317,"to the Royal New Year's Eve Ball."],[1393,1497,"In Entrada,"],[1501,1618,"it is tradition"],[1639,1893,"to ask a loved one to the first dance."],[1972,2147,"I'm sure all of you"],[2147,2498,"have the perfect partner in mind."],[3424,3478,"Who do you think"],[3478,3595,"the prince will dance with?"],[3595,3778,"His boyfriend, obviously."],[3816,3891,"No, the royal family"],[3891,3999,"shut that rumor down."],[4054,4179,"My money's on Alice."],[5426,5576,"He shouldn't be kissing Alice."],[5747,5818,"No, I meant,"],[5860,6026,"I can't let that freak near Alice."],[6364,6460,"May I have the honor"],[6481,6598,"of this first dance?"],[6777,6894,"Your Highness,"],[6923,7023,"asked me to dance?"],[7549,7661,"The honor's all mine."]],"18":[[283,408,"Oh my God."],[408,471,"His Highness"],[471,658,"really asked Lucas to dance?"],[800,925,"Well, I was asking Alice, so-"],[934,1096,"I know, you can't wait."],[1134,1234,"Let's dance."],[1893,1968,"Stop it! - Just let"],[1968,2047,"let me lead! - me lead."],[2206,2339,"Dance with me, Your Highness."],[2502,2690,"Or should I make an even bigger scene?"],[3595,3762,"What is Nicholas thinking?"],[3887,3970,"This won't do."],[4058,4129,"Plan B."],[4204,4262,"Now."]],"19":[[79,191,"Give her the note."],[850,934,"From His Higness."],[1234,1405,"Dear Alice, meet me under the"],[1405,1659,"palace garden tree after the party."],[1680,1747,"Nicholas."],[2256,2398,"Hey, watch where your hand is going."],[2431,2498,"Sorry."],[2540,2698,"Dancing's not really my thing."],[2698,2790,"You should let me lead."],[2798,2840,"Yeah?"],[2865,2919,"Watch out-"],[3132,3219,"Oh my God!"],[4033,4166,"I'm supposed to hate him."],[4279,4421,"But why can't I?"]],"20":[[742,817,"Nice, um..."],[930,1001,"nice dance."],[1121,1205,"Yeah."],[1801,2277,"Ten, nine, eight, seven, six,"],[2277,2781,"five, four, three, two, one."],[2786,3023,"Happy New Year!"]],"21":[[321,371,"Hey."],[475,575,"What are you thinking?"],[692,855,"You get that look on your face,"],[900,992,"you know, the one like"],[992,1146,"you're about to do something drastic."],[1184,1343,"Perfect chance to set them up."],[1434,1484,"Nope."],[1534,1597,"No, no."],[1597,1689,"Nothing at all."],[1772,1839,"I'm just,"],[1939,2043,"a little tired."],[2164,2248,"And, um,"],[2369,2481,"Queen Victoria told me"],[2481,2560,"Nicholas wants to meet me"],[2560,2619,"in the garden."],[2619,2698,"And I'm..."],[2756,3032,"I don't feel comfortable going."],[3148,3215,"Don't worry."],[3294,3386,"I'll meet him."],[3461,3570,"I'll figure out what he's planning,"],[3624,3737,"and put a stop to it."],[4158,4254,"Thank you, Lucas!"],[4254,4379,"You're a life-saver!"],[5697,5822,"A heart?"],[5939,6093,"So corny."],[6844,7036,"I have no desire to marry Alice,"],[7102,7203,"but this is my duty,"],[7273,7394,"and I will see it through."],[7670,7707,"Alice?"]],"22":[[225,354,"My God."],[446,629,"This grand gesture for Alice,"],[725,880,"it's so cliché."],[1001,1101,"What are you doing here?"],[1238,1330,"Where's Alice?"],[1714,1797,"What's this?"],[2448,2573,"A proposal?"],[2635,2715,"For me?"],[2852,2944,"Well, we've only known each other"],[2944,3019,"for like a month."],[3019,3098,"Don't you think"],[3098,3215,"you're moving a little too fast?"],[3215,3345,"It's none of your business."],[3541,3641,"Give it back."],[3732,3832,"What, this?"],[3953,4054,"Give it back to me."],[4212,4287,"Give it back!"],[4396,4462,"Let me go."],[4479,4554,"Let go?"],[4796,4959,"We both know you want me."],[5105,5176,"Badly."],[5380,5601,"We both know you want me."],[5714,5780,"What?"],[5822,5980,"He said the exact same thing"],[5980,6076,"in my dream."]],"23":[[133,266,"Alice is the future princess."],[337,446,"She's the one I have to marry."],[475,546,"So back off!"],[855,905,"What?"],[950,1096,"Have to marry?"],[1142,1313,"Do you want to marry her?"],[1551,1655,"Do you love her?"],[1693,1801,"I'm a prince!"],[2072,2189,"I don't have the luxury"],[2223,2406,"of questioning my duty."],[2882,2969,"A commoner like yourself"],[2969,3086,"could never understand."],[3203,3253,"Yeah."],[3370,3424,"You know what?"],[3424,3490,"You're right."],[3624,3741,"I'm a commoner."],[3757,3862,"But even a commoner knows"],[3862,3991,"if you don't love someone,"],[4012,4141,"you don't marry them!"],[4350,4458,"And Alice deserves someone"],[4458,4592,"who loves her wholeheartedly."],[4592,4738,"You think I don't know that?"],[5017,5109,"You think I don't,"],[5217,5363,"I don't wanna marry for love?"],[5780,5922,"You think I don't dream of"],[6122,6281,"just being myself?"]],"24":[[37,179,"You think I don't dream of"],[379,542,"just being myself?"],[804,905,"Being free?"],[1205,1301,"Just like you?"],[1772,1914,"I can't, Lucas."],[2185,2277,"I'm the prince."],[2519,2761,"The fate of the nation is at stake."],[2815,2965,"If I don't marry Alice,"],[2965,3144,"my uncle will take power and"],[3144,3336,"everything my family has built"],[3336,3474,"will fall apart!"],[3595,3853,"He looks so sad."],[3945,4024,"Why does my heart"],[4024,4145,"ache seeing him like this?"],[4279,4421,"What does that even mean?"],[4491,4567,"What does your uncle"],[4567,4679,"have to do with any of this?"],[4679,4838,"I don't expect you to understand,"],[4913,5080,"but I just want you to leave me alone."],[5722,5830,"Just go away."],[5922,6035,"I'm not going anywhere."]],"25":[[925,1017,"Lucas."],[3169,3382,"I can't believe I kissed the prince,"],[3495,3603,"and liked it."],[3908,3958,"Do I have - Do I have"],[3958,4062,"feelings for him? - feelings for him?"],[4337,4425,"Even if I do,"],[4763,4854,"it has to stop."],[5784,5876,"Nicholas,"],[6318,6468,"I just got back from Briarvale."],[6594,6835,"Heard you straddled a boy at school."]],"26":[[58,141,"Uncle Dolan."],[350,479,"We're just friends."],[508,558,"Oh."],[913,1021,"Just friends, huh?"],[1280,1384,"Probably for the best."],[1505,1647,"Entrada would never accept a"],[1726,1839,"gay king."],[2260,2456,"Only three months till coronation."],[2577,2715,"If another scandal breaks out,"],[2715,2769,"you can"],[2844,2998,"kiss that thrown goodbye, nephew."],[3128,3219,"Well, of course."],[3403,3486,"I understand."],[3720,3899,"Anything else, Uncle Dolan?"],[3928,3983,"Yes."],[4108,4304,"Prince Farlen of Briarvale is here,"],[4341,4471,"and he wants a school tour."],[4612,4733,"So you better not keep him waiting."],[5288,5409,"Of course, Uncle Dolan."]],"27":[[129,237,"So Prince Farlen,"],[258,404,"what do you think of my proposal?"],[446,675,"You know, I'm definitely intrigued."],[675,779,"But the foreign subsidy"],[779,967,"that your Uncle Dolan offered"],[967,1084,"is very generous."],[1117,1217,"It's twenty percent higher"],[1217,1297,"than what we have now."],[1326,1426,"Twenty percent?"],[1451,1589,"Dolan's selling out the nation"],[1589,1693,"to line his pockets!"],[1743,1810,"From what I gather,"],[1810,1956,"you want a long and stable"],[1956,2060,"relationship with Entrada."],[2110,2189,"Dolan's offer doesn't"],[2189,2306,"benefit either of our countries"],[2306,2369,"in the long run."],[2444,2690,"I trust the Prince of Briarvale"],[2727,2898,"won't be so short-sighted."],[3048,3190,"Nicholas, Nicholas, Nicholas."],[3286,3390,"Take a chill pill, man."],[3470,3524,"Alright."],[3561,3641,"You'll have my answer"],[3641,3745,"before the tour's over."],[3870,4029,"Now tell me more about this place."],[4112,4254,"Well, to continue the tour."],[4287,4421,"The student loan paperwork's done."],[4429,4500,"Gorgeous."],[4504,4654,"I just need to give it to Mr. Johnson."],[4729,4821,"Hopefully now Grandma"],[4821,4942,"won't have to work so hard."],[5038,5096,"Whoa."],[5155,5221,"Prince Nicholas"],[5221,5326,"brought another prince?"],[5359,5513,"Oh my God."],[5513,5655,"They look so hot together."],[5684,5747,"How's a girl"],[5747,5855,"supposed to choose?"]],"28":[[50,125,"Who's that?"],[233,346,"He and Nicholas seem..."],[454,533,"close."],[679,763,"Hi, Nicholas."],[829,1101,"Entrada would never accept a gay king."],[2185,2323,"Hey, that's the guy you were riding"],[2323,2410,"on the news, right?"],[2510,2556,"No."],[2711,2794,"He's nobody."],[2873,2923,"Hey."],[3019,3103,"Nobody?"],[3332,3428,"Well, you still got time to"],[3428,3553,"go to dinner with me then, right?"],[3578,3636,"Right?"],[3845,3953,"And here I was,"],[3953,4070,"thinking something had changed"],[4070,4145,"between us."],[4233,4304,"I guess that kiss"],[4304,4421,"meant nothing to him."]],"29":[[2031,2122,"Oh, uh."],[2168,2277,"Mr. Johnson,"],[2360,2460,"let me go."],[2756,2861,"Want your scholarship,"],[2861,2936,"don't you?"],[3136,3378,"Now, one kiss"],[3436,3591,"and you'll have it."],[3753,3858,"What the fuck."],[4087,4220,"Get your hands off her!"],[4617,4675,"Oh my God!"],[4725,4783,"Lucas."],[4796,4867,"Thank you!"],[4879,4975,"I got you, Elena."],[5134,5305,"You fucking scumbag!"],[5338,5405,"How dare you"],[5405,5538,"lay your disgusting hands"],[5538,5689,"on one of your own students?"]],"30":[[229,329,"You bastard!"],[471,575,"What's going on?"],[646,704,"Dean!"],[721,792,"Lucas,"],[817,909,"Lucas Wilder."],[930,1017,"He attacked me because"],[1017,1163,"I didn't approve his student loan."],[1238,1351,"You attack and grope"],[1351,1447,"one of your students,"],[1447,1559,"and then you have the gall"],[1559,1668,"to lie about it?"],[1793,1847,"I swear,"],[1847,1976,"I'll beat you to a fucking pulp!"],[2227,2352,"He's attacking a teacher."],[2352,2473,"Has he gone insane?"],[2544,2681,"He hangs out with street punks."],[2681,2786,"We're not surprised."],[2811,2973,"That's Lucas Wilder for you."],[3307,3495,"Is that how Nicholas sees me too?"]],"31":[[371,504,"Wow, you guys really do allow"],[504,638,"violence at this school."],[775,855,"But I'm sure you're not gonna let"],[855,992,"your feelings affect your judgment,"],[992,1051,"right?"],[1109,1222,"I'll get to the bottom of this."],[1255,1334,"Uh huh."],[1384,1463,"Dean."],[1601,1676,"Your Highness,"],[1751,1864,"you saw him hit me."],[1918,2081,"You have to expel Lucas Wilder."],[2110,2198,"It's not true!"],[2414,2502,"I walked in on him"],[2502,2656,"sexually harassing Elena!"],[2844,3007,"I had to beat his creepy ass!"],[3132,3299,"If you don't believe me, just ask her."],[3386,3449,"Elena?"],[3624,3682,"Oh my God."],[3874,4012,"No, no, nothing happened."],[4045,4187,"Uh, Mr. Johnson"],[4187,4329,"didn't do anything wrong."],[4404,4458,"What?"],[4500,4571,"Elena."],[4650,4704,"See?"],[4779,4913,"Lucas Wilder's lying."],[4996,5042,"Wow."],[5067,5188,"Dragging an innocent girl,"],[5188,5342,"hoping to save himself?"],[5405,5451,"No."],[5451,5576,"I'm not lying!"],[5643,5747,"You have to believe me!"]],"32":[[0,154,"Apologize to me, Lucas."],[171,325,"And maybe I'll ask the Dean"],[325,437,"to show you mercy."],[437,638,"In your dreams, creep."],[667,825,"I didn't do anything wrong,"],[825,1051,"and I will never apologize."],[1092,1180,"He's hopeless."],[1180,1322,"They should expel him."],[1518,1639,"Do the right thing."],[1668,1826,"Expel him and I'll sign your trade deal"],[1826,1935,"instead of your uncle's."],[2027,2139,"How's that sound?"],[2185,2352,"I wonder what you want more,"],[2427,2635,"the deal that could secure your crown,"],[2773,2936,"or your little crush?"],[2977,3098,"He would never choose me"],[3098,3199,"over the crown."],[3228,3324,"Lucas Wilder,"],[3357,3561,"your behavior is unacceptable,"],[3561,3774,"and unbecoming of a St. George student."],[3816,4074,"We are left with no choice but to ex-"],[4074,4154,"Wait."],[4446,4587,"I believe Lucas Wilder."],[4675,4779,"He's not lying."]],"33":[[0,129,"I believe Lucas Wilder."],[241,312,"He's not lying."],[400,592,"He said he trusts me?"],[625,717,"Sexual harassment"],[717,842,"rarely happens just once,"],[925,1092,"and not every victim"],[1092,1213,"feels empowered to speak up."],[1530,1634,"If you've got nothing to hide,"],[1634,1730,"you won't mind us speaking to"],[1730,1860,"your former students, will you?"],[1860,1956,"I..."],[2039,2206,"I, I..."],[2314,2373,"I..."],[2373,2460,"Oh my God,"],[2460,2540,"he's scared!"],[2585,2719,"Lucas wasn't lying?"],[2986,3182,"Oh, Mr. Johnson's a creep."],[3203,3290,"Coward!"]],"34":[[45,191,"Mr. Johnson's reaction"],[250,387,"speaks louder than words."],[454,575,"Wouldn't you say, Dean Devers?"],[704,934,"You two, release Mr. Wilder."],[1021,1180,"Take this scumbag"],[1180,1292,"to the police station."],[1384,1438,"No!"],[1455,1530,"I didn't do any-"],[1530,1580,"No!"],[1601,1651,"No!"],[1989,2031,"No."],[2164,2331,"Nobody believed me except Nicholas."],[2394,2506,"If not for him,"],[2548,2702,"I'd be expelled right now."],[2761,2848,"I really owe him."],[3144,3345,"I'm so sorry, Lucas."],[3374,3474,"I panicked."],[3474,3636,"I, I thought he would cancel my"],[3653,3741,"my loan if I-"],[3741,3824,"No, it's okay."],[3916,4041,"I got really worked up too."],[4617,4771,"So you threw a trade deal away"],[4771,4879,"for this commoner?"],[4917,5046,"You must really care about that"],[5046,5159,"Lucas Wilder."],[5176,5351,"Well, I am the future king."],[5409,5576,"And I look out for all my commoners."],[5584,5655,"Oh, really?"],[5776,5864,"Because looks like you're"],[5864,6018,"falling pretty hard for this one."]],"35":[[37,279,"None of your business, Farlen."],[496,558,"Fine."],[617,771,"You just blew the biggest trade deal"],[771,850,"of your life."],[1067,1163,"Hope you don't regret it."],[1830,1893,"Vivian,"],[1939,2031,"please make sure that"],[2031,2110,"Lucas' student loans"],[2110,2227,"are taken care of properly."],[2268,2406,"Oh, and..."],[2502,2665,"I need you to do one more thing for me."],[4371,4454,"Your Highness."],[5059,5138,"Something you need?"],[5238,5367,"I just wanted to say thank you."],[5455,5559,"For the help with my loan,"],[5588,5743,"and for sticking up for me earlier."],[6018,6151,"I thought you hated me."],[6260,6356,"I don't hate you."]],"36":[[8,62,"But..."],[221,329,"if people see us together,"],[483,658,"it'd mean trouble for the both of us."],[905,1026,"So if no one's watching,"],[1155,1230,"we're good?"],[1376,1505,"What are you suggesting?"],[1789,1872,"Come with me."],[2097,2160,"Just us."],[2293,2373,"I can't."],[2494,2623,"My schedule's full tonight."],[2648,2731,"Just an hour."],[2957,3036,"I promise."],[4888,4992,"Hold on, Your Highness."],[5013,5150,"We're about to pick up some speed."],[5559,5676,"Your Highness!"],[5693,5739,"No!"]],"37":[[1413,1459,"So,"],[1593,1705,"why did you bring me here?"],[2043,2147,"It's nice, right?"],[2260,2381,"It's my secret spot."],[2523,2652,"Never brought anyone here."],[2827,2936,"When my parents died,"],[3048,3165,"my grandma took me in."],[3390,3507,"Raised me all by herself."],[3595,3728,"So when things got heavy,"],[3866,3949,"I'd come here,"],[4141,4225,"to breathe,"],[4362,4433,"relax."],[4550,4708,"I thought maybe you could use that too."],[5088,5150,"I, uh,"],[5226,5326,"I got you something."],[5497,5647,"It's not another dog collar, is it?"],[5743,5809,"No."]],"38":[[8,87,"A gift?"],[237,296,"For me?"],[513,579,"Open it."],[1418,1484,"But how did..."],[1559,1630,"I wanted to know"],[1630,1785,"why you hated me so much."],[1864,1947,"I remembered you said"],[1947,2047,"something about a scarf."],[2064,2127,"So,"],[2256,2419,"I had Vivian pull the security footage"],[2419,2515,"from the day we met."],[2548,2719,"I'm sorry I stepped on your scarf."],[2819,2936,"I really didn't see it."],[3044,3165,"The first thing that they teach you"],[3165,3290,"in the Royal Family is"],[3365,3474,"never look down."],[3741,3895,"Keep your head high they'd always say,"],[4104,4262,"or your crown will fall."],[4542,4629,"I, I mean,"],[4700,4763,"do you like it?"],[4833,5059,"I, I know it's not exactly..."],[5505,5618,"You're looking down now."],[5776,5885,"You don't have to keep your head"],[5885,6035,"held high around me, Nicholas."],[6101,6239,"You can just be yourself."]],"39":[[1509,1576,"Thank you,"],[1647,1785,"for the gift."],[1830,1910,"I love it."],[2089,2239,"You really saved me out there today."],[2277,2335,"Huh?"],[2377,2444,"Just..."],[2556,2677,"stay out of trouble next time."],[2752,2811,"Please."],[2907,2986,"You're brave."],[3144,3269,"But you are also hot-headed."],[3357,3457,"What would have happened"],[3457,3532,"if I wasn't there?"],[3636,3749,"Who would've looked out for you?"],[3862,3941,"Who would've"],[4049,4129,"protected you?"],[4433,4554,"Protected me?"],[4754,4892,"Are you worrying about me?"],[5130,5263,"Don't get carried away."],[5413,5538,"As future king,"],[5697,5955,"looking out for all of my citizens"],[6089,6160,"is my duty."],[6310,6381,"Right."],[7123,7286,"I am gonna swim."]],"40":[[533,604,"Damn."],[642,842,"He looks like a Greek God."],[4341,4462,"Come on, Your Highness!"],[4517,4675,"Don't tell me you're too shy to get naked."]],"41":[[0,137,"Come on, Your Highness!"],[196,358,"Don't tell me you're too shy to get naked!"],[437,492,"No."],[629,750,"Prince just doesn't skinny dip."],[867,946,"Sure you do."],[1864,1918,"See?"],[1956,2056,"Not so hard."],[2160,2339,"How dare you!"],[2452,2627,"I'm still your prince."],[2731,2802,"Give up."],[2836,2986,"You're never gonna win this one."],[3007,3061,"Oh really?"],[3073,3107,"Mhm."],[3119,3153,"Uh huh."],[3157,3190,"Yeah."],[3203,3240,"Yeah."],[3269,3378,"Sounds like someone needs"],[3378,3557,"to be reminded of his place."],[3891,3945,"Ow!"],[4187,4304,"Payback, huh?"],[4304,4346,"Yeah."],[4354,4396,"Mhm?"],[4396,4458,"Yeah."],[4521,4942,"Because I remember every single thing,"],[5013,5117,"that you've done to me."],[6264,6398,"Oh, I, I'm, I'm sorry."],[6398,6468,"I thought..."]],"42":[[1885,2018,"That's a handful."],[2544,2715,"God, Lucas, that feel so good."],[2873,3036,"You're so damn hot."],[3144,3290,"Your voice makes me throb."],[3449,3541,"Hint taken."],[4667,4783,"You're pretty nice too."],[4934,5050,"Pretty nice?"],[5267,5417,"I said what I said."]],"43":[[0,50,"Slow down!"],[50,183,"You're the Jackal, aren't you?"],[183,266,"Catch up. - Yeah."],[967,1172,"You know, maybe we could uh,"],[1247,1351,"go out again sometime."],[1501,1593,"I'll check my schedule."],[2285,2385,"Ah, shit!"],[2515,2640,"Look what we've got!"],[2752,3019,"The Jackal being gay as fuck!"],[3111,3253,"Oh, don't be shy."],[3253,3395,"Let's see your pretty face."],[3595,3666,"Shit."],[3732,3816,"Mark and his gang."],[3883,4029,"I can't let them see Nicholas with me."],[4187,4254,"Run!"]],"44":[[262,316,"Hurry."],[350,475,"We can't let them catch us."],[759,842,"Isn't he supposed to be"],[842,992,"the big, bad tough guy?"],[1042,1163,"Why is he so scared now?"],[1201,1292,"Nicholas would die"],[1292,1405,"to protect his reputation."],[1438,1547,"I have to protect him."],[1584,1722,"I can't let anyone see him with me."],[2289,2348,"Fuck!"],[2389,2477,"Why the hell is Lucas"],[2477,2590,"running off like a coward?"],[2748,2836,"Something's off."],[2873,2919,"Go."],[2948,3023,"Chase him."],[3090,3207,"We'll deal with him tonight."],[3578,3666,"Stay here."],[3695,3795,"I'll draw them away."],[3807,3874,"Don't."],[3887,3974,"You're outnumbered."],[4079,4175,"Keep giving me those eyes"],[4175,4291,"and I'm kissing you again."]],"45":[[4,125,"Okay, now is not the time."],[208,275,"I just..."],[342,450,"you looked really nervous"],[450,529,"back there and"],[588,679,"and I'm just worried you won't"],[679,829,"be able to handle them all by yourself."],[905,1026,"So you are worried."],[1109,1188,"Relax."],[1230,1451,"I can handle these clowns blindfolded."],[1501,1618,"I'm not letting you face them alone."],[1618,1701,"I'm coming with you."],[1751,1847,"You're the Crown Prince."],[1864,2014,"You can't be caught in a fistfight!"],[2014,2097,"I don't care."],[2310,2394,"I've got your back."],[2944,3028,"No matter what."],[3516,3778,"Aw, two love birds,"],[3778,3874,"how sweet."],[3941,4087,"Tonight, I'm gonna break"],[4087,4308,"every fucking bone you've got."]],"46":[[8,95,"Honestly,"],[120,246,"I've been wanting to beat you fuckers"],[246,379,"into the ground for ages."],[379,517,"Let's fucking go."],[542,608,"Bring it on."],[1760,1843,"Lucas!"],[2056,2131,"Damn it!"],[2556,2631,"Ow!"],[2777,2840,"Ah!"],[2840,2973,"You dare touch what's mine?"],[3299,3465,"You have a fucking death wish."],[3465,3611,"Prince Nicholas!"],[3632,3816,"Why the hell are you with Lucas?"],[4029,4108,"You said you wanted to"],[4108,4220,"teach us a lesson, right?"],[4316,4433,"How about I teach you one?"],[4525,4600,"Right - No, please don't."],[4646,4721,"fucking"],[4721,4808,"now."]],"47":[[225,304,"Hold still."],[367,450,"This will sting."],[546,671,"It's just a scratch."],[846,900,"Ah!"],[917,971,"Mhm."],[1026,1092,"Ow."],[1105,1159,"Sorry."],[3799,3920,"I'm surprised with"],[4016,4120,"how many times"],[4149,4233,"this has happened"],[4233,4316,"you haven't learned how to wrap"],[4316,4408,"your own hand yet."],[4517,4692,"Maybe I just wanted you to do it for me."],[5309,5392,"Nice and tight."],[5563,5643,"How's that feel?"],[5701,5747,"Good."],[5805,5855,"Yeah?"],[5897,5951,"Yeah."],[6039,6089,"Good."],[6247,6352,"Now it's your turn."],[6523,6648,"What are you doing?"]],"48":[[100,196,"What are you doing?"],[392,529,"It's my turn to play nurse."],[621,721,"But I'm not injured."],[784,875,"Don't be shy."],[1051,1192,"It's just a quick check."]],"49":[[45,187,"You're just as hard as I am."],[308,396,"Shut up."],[696,784,"I need you."],[971,1084,"As you wish."],[1167,1255,"Your Majesty."],[4074,4304,"This is so fucking hot."],[4346,4416,"God."],[4450,4550,"Lucas."],[4754,4817,"Nicholas?"],[4946,5146,"Nicholas, I know you are in there."],[5146,5359,"Open this door at once."]],"50":[[437,517,"Your Majesty."],[975,1055,"Mother?"],[1493,1626,"So this is the reason"],[1626,1764,"you abandoned your duties"],[1764,1839,"this evening?"],[1872,1997,"Mother, I can explain."],[1997,2206,"Explain what, exactly?"],[2223,2381,"Why my son was brawling"],[2381,2540,"in the alley like a thug?"],[2594,2698,"Why the Crown Prince"],[2698,2882,"is consorting with a street punk"],[2882,3015,"in the middle of the night?"],[3161,3215,"Look at you."],[3286,3470,"You call yourself a prince?"],[3666,3816,"Your Majesty, it's my fault."],[4108,4175,"I took him to the-"],[4175,4320,"No, no, it, it was my fault."],[4320,4525,"Yes, it was your fault, all right."],[4575,4671,"But him?"],[4733,4846,"He's worse."],[5025,5125,"Guards."],[5150,5313,"Arrest Lucas Wilder"],[5313,5472,"for abducting the prince."],[5472,5643,"And take him to the police station."]],"51":[[91,158,"No."],[246,425,"No, you, you..."],[475,600,"you can't do this to him."],[1676,1718,"Mother!"],[1989,2127,"It was my decision to go out."],[2164,2298,"Lucas had nothing to do with it."],[2310,2456,"You are a prince."],[2515,2598,"Why do you keep"],[2598,2748,"defending this commoner?"],[2790,2890,"Do you have"],[3032,3169,"feelings for him?"],[3641,3757,"That boy is nothing but trouble."],[3841,3953,"I will have him expelled and"],[3953,4074,"make him disappear from Entrada."],[4074,4187,"That's not fair!"],[4254,4354,"You can't do that to him!"],[4354,4504,"I can and I will."],[4537,4633,"You want to bargain?"],[4646,4796,"You wait until you are king."],[4917,5021,"I won't let you hurt him."],[5021,5213,"Then stop seeing him."],[5213,5359,"None of this would have happened"],[5359,5501,"had you just stayed away."],[5889,6072,"Last night was the freest"],[6072,6247,"and happiest I've ever been."],[6247,6348,"But being with me"],[6348,6485,"will only bring him trouble."],[6548,6652,"I have to let him go."],[6856,6923,"Okay."],[7165,7294,"I understand."]],"52":[[754,850,"Oh honey,"],[875,1038,"you look like you've been through hell."],[1092,1226,"Are you okay?"],[1263,1359,"I'm fine, Grandma."],[1559,1714,"Thanks for bailing me out, Grandma."],[1714,1830,"It won't happen again."],[1830,1901,"I promise."],[1989,2110,"It's the prince, huh?"],[2260,2477,"He's who this is all about."],[2510,2598,"I've raised you"],[2598,2748,"since you were knee high."],[2831,2948,"You think I don't see it?"],[3061,3286,"He's damn lucky he caught your eye."],[3345,3445,"Oh, sweetheart."],[3549,3807,"Loving royalty is no fairy tale."],[3878,3974,"Are you sure"],[3999,4154,"you know the weight of a crown?"],[4637,4746,"Grandma's right."],[4821,4942,"Am I ready for this?"],[5080,5163,"Is he?"]],"53":[[1322,1388,"Nicholas."],[1497,1564,"Ms. Newton,"],[1689,1910,"would you like to have lunch with me?"],[2068,2122,"Oh."],[2210,2469,"Uh, sure."],[2786,2886,"I will hold off on"],[2886,3023,"doing anything to Lucas."],[3111,3299,"But in exchange,"],[3349,3490,"you will marry Alice Newton."],[3536,3657,"And you will do it soon."],[4141,4362,"That night was amazing."],[4658,4758,"So why is he acting like"],[4758,4867,"someone else today?"],[4946,5042,"I'm sorry, Lucas."],[5121,5288,"It's the only way I can protect you."],[5584,5726,"I swear I'm not lying."],[5776,6006,"I saw Prince Nicholas and Lucas"],[6006,6156,"kissing by the lakeside."],[6185,6306,"How very interesting."]],"54":[[608,725,"What the hell is this?"],[754,859,"This is the most awkward"],[859,963,"dinner of my life."],[1184,1267,"I'm just gonna say it."],[1301,1409,"Your Highness,"],[1551,1810,"you really don't need to be doing this."],[1835,2022,"We both know that I'm not the person"],[2022,2131,"that you wanna be here with."],[2198,2277,"Oh, no, I'm sorry."],[2277,2310,"I didn't-"],[2310,2448,"You have your heart"],[2448,2581,"set on someone else."],[2798,3023,"It's Lucas, right?"],[3061,3153,"I know you transferred to"],[3153,3274,"St. George because of me."],[3307,3424,"But Lucas,"],[3545,3703,"he's the one that you danced with,"],[3778,3887,"went on dates with,"],[3945,4212,"swam with, and fought with."],[4245,4333,"He's the one you're truly"],[4333,4429,"meant to be with."],[4512,4658,"But that, that doesn't mean anything."],[4688,4829,"Of course it does."],[4859,5038,"What if you lose him because"],[5071,5234,"you didn't admit your feelings?"],[5255,5413,"Think of how badly you'll regret it."],[5480,5584,"Follow your heart."],[7240,7336,"Go to Lucas."],[7440,7561,"He's waiting for you."],[7841,7928,"You're right."],[8158,8324,"I can't deny my feelings anymore."],[8562,8717,"Thank you, Alice."],[8758,8846,"Do you mind if I go now?"],[8846,8933,"I, I can have my"],[8933,9009,"driver take you home."],[9050,9163,"Don't worry about me."],[9180,9275,"Just go."]],"55":[[1818,1906,"Why are you here?"],[1976,2085,"Shouldn't you be on your date?"],[2118,2298,"There's nothing between Alice and I."],[2331,2427,"There never was."],[2544,2615,"Whatever."],[2748,2894,"What do you want, Your Highness?"],[2952,3040,"You're the one who's been"],[3040,3194,"distancing yourself from me."],[3340,3482,"And maybe it's best you keep at it,"],[3490,3620,"and stay the hell away from me."],[3657,3712,"What?"],[3832,3903,"No way."],[3953,4041,"You, you wanna draw"],[4041,4158,"a line between us now?"],[4233,4312,"What about the lake?"],[4421,4525,"Does that mean nothing to you?"]],"56":[[0,129,"I thought you wanted me to forget it."],[237,383,"You've been avoiding me ever since."],[458,529,"And I hear you,"],[592,667,"loud and clear."],[763,900,"You wanna end things."],[1042,1197,"No, I don't wanna end things."],[1292,1426,"I want you by my side."],[1751,1830,"What do you mean?"],[2002,2056,"Nicholas,"],[2085,2210,"what am I to you?"],[2456,2590,"You're everything to me."],[2673,2748,"My heart,"],[3069,3161,"beats for you, Lucas."],[3386,3461,"What are you saying?"],[3557,3628,"Lucas."],[4120,4166,"I-"],[4579,4642,"Your Highness,"],[4642,4813,"it's all over social media."],[4854,4954,"You and Lucas."],[5013,5155,"It's everywhere."]],"57":[[0,129,"OMG, isn't that the guy"],[129,279,"the prince kissed before?"],[287,417,"He totally denied it at the time,"],[429,538,"and now they're caught together?"],[575,642,"No way!"],[650,754,"Perfect Prince."],[775,859,"I wonder if he cries"],[859,992,"if he takes it in the ass!"],[1021,1155,"Look at him brawling in the streets"],[1155,1238,"like a thug."],[1247,1330,"He's an embarrassment"],[1330,1413,"to the monarchy."],[1413,1530,"His Uncle Dolan would never"],[1530,1622,"pull this crap."],[1639,1751,"The throne should be his!"],[1818,1943,"I am so screwed."],[2285,2414,"I need to get back to the palace."],[2452,2640,"And deal with this now."],[2748,2790,"No."],[2940,3036,"I'm going with you."],[3161,3232,"I'll stand by you"],[3232,3349,"no matter what happens."],[3624,3753,"Oh, she's Channel 7. - You know..."],[3816,3878,"No, you guys are-"],[3883,3966,"Oh, oh- - Right there!"],[4041,4158,"Oh shit."],[4195,4270,"Reporters."],[4295,4437,"How did they get here this fast?"],[4537,4667,"It has to be Uncle Dolan."],[4771,4896,"He's been trying to ruin me"],[4896,4967,"for a long time."],[4984,5055,"Your Highness!"],[5055,5163,"Are you really gay?"],[5171,5355,"Is the royal family covering it up?"],[5355,5417,"Your Highness,"],[5417,5597,"you are here at Lucas Wilder's place."],[5613,5743,"Are you sleeping together?"]],"58":[[0,129,"That's none of your business!"],[175,300,"And stay away from my house."],[300,392,"Prince Nicholas,"],[412,513,"don't you think the public"],[513,633,"deserves the truth?"],[796,955,"I can't hide this forever,"],[1009,1130,"and I don't want to."],[1217,1363,"The people deserve the truth."],[1526,1618,"As you can see,"],[1701,1789,"Lucas and I-"],[1797,1881,"Enough!"],[2047,2131,"The Queen..."],[2631,2844,"My son and Mr. Wilder"],[2844,2977,"are close friends."],[3015,3219,"As for the fight, they were only"],[3219,3319,"defending themselves"],[3319,3453,"against school bullies."],[3478,3616,"As a matter of fact,"],[3641,3803,"Nicholas is here today"],[3803,4012,"to appoint Mr. Wilder"],[4012,4245,"as the prince's personal bodyguard."],[4475,4596,"Isn't that right, Nicholas?"],[4713,4838,"Don't disappoint me"],[4838,4992,"more than you already have, Son."],[5380,5430,"Yes."],[5588,5680,"Mr. Wilder,"],[5730,5889,"do you accept the appointment,"],[5914,6143,"and will you move into the palace"],[6143,6381,"to be the prince's personal bodyguard?"],[6552,6623,"Of course."],[6785,6865,"It would be my honor."],[7061,7282,"There is the truth you are looking for."],[7332,7390,"Now,"],[7449,7711,"to whomever spreads false rumors"],[7720,7941,"that threaten the royal reputation,"],[8012,8128,"we will hunt you down."],[8212,8358,"No matter what it takes."]],"59":[[0,250,"There is the truth you are looking for."],[271,546,"To whomever spreads false rumors"],[546,788,"that threaten the royal reputation,"],[825,963,"we will hunt you down."],[1230,1305,"Fuckers!"],[1568,1634,"God!"],[1743,1860,"I can't believe you two are"],[1860,1981,"getting away with this."],[2702,2827,"Oh, it doesn't matter."],[2919,3078,"I'll expose your weakness."],[3219,3370,"And in next week's coronation,"],[3370,3507,"you're going down for good."],[4204,4262,"Whoa."],[4337,4446,"I didn't know bodyguards"],[4446,4558,"got rooms like this."],[4637,4838,"It is specially arranged, Mr. Wilder."],[4850,5000,"From now on, you will accompany"],[5000,5142,"His Highness everywhere."],[5184,5267,"Public events,"],[5321,5538,"meetings, bedtime checks."],[5609,5739,"What's this other entrance?"],[5834,5993,"This is Prince Nicholas' chamber."],[6398,6535,"So we're just a door apart?"],[6577,6765,"Are we living together now?"],[6869,7032,"I can't wait to see his sleeping face."]],"60":[[429,525,"Your Majesty,"],[525,700,"Lucas's arrangement has been made"],[717,800,"per your instruction."],[859,917,"Well done."],[1188,1309,"But I don't understand."],[1372,1539,"You were always against Lucas"],[1539,1672,"getting close to the prince."],[1780,1893,"Why the change of heart?"],[2077,2235,"Since Nicholas was a child,"],[2235,2348,"I've been strict."],[2414,2552,"I've raised him to be a king."],[2648,2736,"He's smart,"],[2806,2902,"and intelligent."],[2990,3098,"But I have always sensed"],[3098,3215,"a deep sorrow."],[3336,3524,"With Lucas, he's"],[3695,3837,"truly happy."],[3970,4054,"I wonder,"],[4262,4391,"was I wrong?"],[4750,4829,"Never mind."],[4884,4946,"You may go."],[4975,5067,"Your Majesty."],[6781,6869,"Like what you see?"],[7032,7119,"The sash is supposed to"],[7119,7236,"go under the uniform."],[7736,7807,"You tried."],[8124,8245,"Would you get over here and help me,"],[8291,8383,"Your Highness?"]],"61":[[204,371,"You're telling me you've never"],[371,529,"worn a royal sash before?"],[529,600,"Yeah, I don't know."],[600,725,"This is my first time. - Wow."],[771,1001,"Well, not bad for your first time."],[1017,1096,"Thank you."],[1117,1226,"But this does not go here."],[1234,1288,"Okay."],[1309,1397,"This needs to come off."],[1430,1614,"Oh, right."],[1659,1801,"I must have forgotten about that."],[1801,1856,"Hmm."],[1943,2027,"And this"],[2218,2306,"underneath."],[2306,2464,"Oh, right."],[3178,3361,"This isn't about"],[3415,3549,"helping me get dressed,"],[3607,3678,"is it?"],[3753,3816,"You..."],[3970,4112,"just need patience,"],[4145,4254,"because this uniform"],[4312,4500,"is very hard"],[4579,4679,"to put on."]],"62":[[41,241,"Forget the uniform."],[279,383,"I want you."],[462,717,"Right now."],[2473,2631,"Show me how much you want me."],[3148,3253,"The way"],[3290,3415,"you're looking at me right now"],[3490,3620,"is killing me."],[4929,5050,"Keep your eyes open."],[5263,5347,"I want you to remember"],[5347,5447,"this moment."],[5559,5676,"Just you and me."],[6352,6456,"Lucas."],[6644,6710,"Don't stop."]],"63":[[417,496,"Lucas."],[2248,2364,"What round are we on?"],[2402,2540,"I thought you'd be tired by now."],[2619,2786,"I could never get enough of you,"],[2873,3015,"unless you're implying that"],[3090,3307,"you're tired, Your Highness?"],[3365,3470,"Not a chance."],[3470,3545,"Good."],[3624,3745,"Because I plan on wringing"],[3745,4108,"every last bit out of you."],[4170,4421,"Until you're begging for me to stop."],[4421,4542,"You'll be the one begging long"],[4542,4637,"before I do."],[5889,6043,"Uh oh, Your Highness?"],[6097,6168,"How did you end up"],[6168,6310,"in your bodyguard's bed?"],[6527,6614,"Well,"],[6727,6890,"my guard dragged me into it."],[7090,7182,"How's a helpless prince"],[7182,7273,"supposed to resist?"]],"64":[[25,229,"Waking up to you feels so good, I..."],[487,600,"I honestly can't picture my life"],[600,742,"without you anymore."],[742,846,"Then don't."],[1163,1259,"Stay with me."],[1313,1559,"Lucas, I can't hide it anymore."],[1839,1918,"I love you."],[2081,2177,"I love you too."],[2481,2544,"I,"],[2606,2694,"I think I loved you"],[2694,2852,"before I even realized it."],[4116,4329,"Prince Nicholas kissing a man?"],[4379,4579,"Lord Dolan will be very pleased."]],"65":[[54,191,"I don't wanna hide us anymore."],[362,462,"I need to tell Mother."],[679,788,"I'll go with you."],[842,900,"No."],[963,1092,"Stay here and wait for me."],[1251,1347,"I'll tell her myself."],[2594,2698,"Perfect timing."],[2740,2861,"Your robes have arrived for your"],[2861,2977,"coronation tomorrow."],[3028,3103,"Try them on."],[3186,3261,"Mother."],[3395,3495,"I need to tell you something."],[3591,3687,"It's, it's about, um..."],[3791,3908,"It's about Lucas and I."],[4083,4212,"I don't want to talk about it now."],[4308,4450,"Tomorrow you become king."],[4500,4667,"Let's save any personal matters"],[4667,4767,"for after that, shall we?"],[4767,4850,"Yea, yes, but-"],[4850,5005,"No buts, Nicholas."],[5067,5226,"You know how important this is."],[5321,5463,"Do not let our country down."]],"66":[[563,813,"After everything, it's finally happening."],[850,1001,"He's going to be king."],[1001,1101,"By the grace of God,"],[1176,1284,"and the will of the people,"],[1347,1589,"we crown you, Nicholas Valeheart,"],[1664,1881,"rightful heir and sovereign."],[1943,2131,"May your rule be just,"],[2160,2310,"wise, and merciful."],[2606,2719,"Oh my God!"],[2723,2940,"Prince Nicholas is kissing a guy?"],[2965,3090,"He's gay!"],[3153,3328,"Oh, the nation is gonna lose it."],[3382,3478,"Turn that off!"],[3520,3586,"Wait!"],[3603,3774,"That man is Lucas Wilder."],[3812,3949,"No wonder he made him his guard,"],[3970,4074,"so they can fuck each other"],[4074,4225,"behind the palace walls!"],[4629,4867,"Bravo, bravo."],[4879,5071,"Look at the king that you've chosen,"],[5105,5467,"a pansy who bends over for other men."],[5509,5568,"Okay?"],[5593,5730,"He doesn't deserve the crown!"]],"67":[[20,112,"Disgraceful!"],[133,221,"A future king"],[221,300,"bedding a-"],[308,429,"another man?"],[429,667,"This royal family is ruined."],[729,813,"That's right."],[913,1038,"We'll never accept a king"],[1067,1184,"who brings us such shame."],[1301,1447,"Is that how my people see me?"],[1576,1668,"Shameful?"],[1780,1856,"No!"],[1931,2093,"He's given everything he has"],[2093,2173,"for this country!"],[2268,2385,"Protected its people,"],[2456,2565,"fought for justice,"],[2602,2711,"that's what makes a king!"],[2836,2936,"Not who he loves."],[3078,3161,"Lucas..."],[3224,3370,"I'm not gonna hide in the dark anymore."],[3632,3766,"There's been some talk recently"],[3791,3970,"about my sexuality."],[4166,4371,"Today, I want to give a clear"],[4425,4571,"and honest statement."]],"68":[[141,229,"I am gay."],[642,804,"Lucas Wilder is my boyfriend."],[863,992,"I'm not ashamed of who I am."],[1184,1284,"But before Lucas,"],[1380,1514,"I never truly"],[1514,1655,"understood happiness,"],[1743,1856,"and freedom."],[2214,2331,"I know there are some that will"],[2331,2494,"struggle to accept this."],[2719,2936,"But I will remain committed,"],[2977,3174,"and loyal to all of my people."],[3215,3282,"However,"],[3282,3482,"if my people cannot accept me,"],[3545,3649,"I will abdicate."]],"69":[[20,133,"Oh my goodness!"],[166,241,"Prince Nicholas is"],[241,412,"openly admitting that he's gay?"],[412,579,"That's insane..."],[742,942,"and very brave."],[1113,1192,"Being a good king"],[1192,1359,"has nothing to do with being gay,"],[1359,1547,"only one's loyalty to the kingdom."],[1718,2006,"And no one is as loyal as Nicholas."],[2127,2185,"Hey."],[2260,2373,"Shut the fuck up!"],[2410,2481,"Both of you."],[2565,2652,"He just admitted it."],[2736,2944,"He needs to step down!"],[3703,3912,"True love is never a crime!"],[4133,4258,"He's gonna be the greatest king"],[4258,4383,"anyone has ever seen."],[4721,4909,"Long live King Nicholas."],[4934,5113,"We stand with King Nicholas."],[5476,5555,"Well, Dolan."],[5634,5789,"This is the will of the people."],[5830,6060,"They want Nicholas as their king."]],"70":[[33,175,"What the fuck is wrong with you?"],[254,337,"All of you!"],[362,454,"Are you insane?"],[487,604,"How can our kingdom"],[604,784,"have a gay king?"],[930,1109,"It is best you stop, Lord Dolan."],[1313,1501,"The maid has confessed."],[1501,1664,"She filmed them in secret,"],[1664,1818,"and was trying to ruin the coronation"],[1818,2010,"under Lord Dolan's order."],[2056,2181,"And he's been cutting deals"],[2181,2268,"with foreign countries"],[2268,2398,"for his own gain!"],[2673,2773,"Fuck you, Nicholas."],[2790,2907,"That crown right there"],[2923,3036,"belongs to me,"],[3136,3224,"and you know it."],[3290,3415,"All of you do!"],[3453,3557,"It's mine!"],[3691,3762,"Orders,"],[3841,3953,"Your Majesty?"],[4154,4250,"Bring him to the police."],[4400,4525,"We'll deal with this properly."],[4583,4675,"This isn't right."],[4675,4854,"Okay, this crown belongs to me!"],[4854,4913,"You all know!"],[4913,5080,"Don't you fucking touch me!"],[5080,5188,"God damn it!"],[5217,5259,"No!"],[5321,5372,"No!"]],"71":[[3148,3244,"Woo!"],[3311,3382,"As king,"],[3474,3795,"I swear by my crown and my family"],[3924,4058,"that I will never let you down."],[4479,4546,"So grateful"],[4546,4662,"to have you here with me."],[4725,4796,"We'll rule together."],[5021,5105,"There's no one else"],[5105,5226,"I'd rather have by my side."]]}