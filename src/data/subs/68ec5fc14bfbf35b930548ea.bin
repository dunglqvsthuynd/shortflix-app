531,"I'll be yours."],[6531,6644,"Just leave him alone!"],[6644,6710,"Wow."],[6710,6861,"You must really love him."],[6861,7027,"This will be fun."],[7027,7240,"Now, let's see what we're working with."],[7240,7315,"Let me go!"]],"87":[[75,187,"Guys, there coming from the East."],[187,304,"Lead them here or we’re screwed-"],[304,496,"No, he’s right- - You have to have-"],[496,646,"If we block the road- - You need to listen!"],[646,759,"at 24th Street- - He’s telling you-"],[759,909,"Everyone shut the fuck up!"],[946,1121,"The Russians will not win."],[1121,1230,"Okay, we have more men."],[1247,1368,"We have stronger men."],[1380,1459,"I have a plan."],[1459,1647,"But first, we need to get my wife"],[1647,1772,"on a plane out of New York."],[1872,2077,"Boss, she's gone."],[2243,2364,"Get my fucking car, right now."],[2381,2444,"You go, too."],[2444,2606,"But boss, what about the Russians?"],[2615,2790,"Nothing matters as much as Aria!"],[2790,2911,"And we need to go find her."],[2911,2961,"Yes, sir."],[3649,3720,"Hold on, Aria."],[3770,3899,"I wont rest until I save you,"],[3899,3962,"and bring you back home,"],[3962,4037,"where you belong."],[4070,4120,"With me."],[5538,5672,"Don't fucking touch me!"],[5997,6156,"Ooh, feisty."],[6160,6393,"You're going to make a fun little toy."],[6393,6685,"Maybe I won't wait for Luca to get here."],[6719,6861,"Guys, stay alert."],[6981,7107,"Cry if you want,"],[7127,7278,"it just makes it more fun for me."],[7328,7382,"Stop!"],[7653,7824,"Don't fucking touch my wife!"]],"88":[[0,66,"Luca!"],[187,475,"Luca, you're just in time for the show."],[500,608,"You're going to watch me"],[608,688,"please your wife"],[688,855,"in ways you can't imagine."],[900,992,"You could never!"],[1059,1263,"Fine, then she will please me."],[1280,1401,"Either way, Luca,"],[1401,1568,"you will learn a thing or two."],[1568,1730,"The only thing I'll learn"],[1730,1931,"is how fast it takes for you to bleed out"],[1931,2039,"after I gut you."],[2273,2477,"You're outnumbered, my friend."],[2544,2677,"Here how it’s going to go."],[2698,2827,"First, you're gonna watch me"],[2827,2911,"fuck your wife."],[2911,3065,"Then my men will kill you."],[3098,3319,"Aria will come with us to Russia."],[3349,3490,"After, I will take control"],[3490,3570,"of The Familia."],[3574,3774,"Soon, your entire Mafia will be mine."],[3774,3920,"And so will your wife."],[3941,4020,"Guys, get him!"],[5776,5885,"Take your shot, Luca."],[5897,6006,"If you shoot her,"],[6006,6202,"the bullet will surely go through her"],[6202,6277,"and kill me."],[6318,6489,"So, what it's going to be?"],[6519,6606,"Your wife,"],[6635,6735,"or The Familia?"],[6794,6881,"Your legacy."]],"89":[[16,79,"Go ahead."],[112,233,"Shoot her and kill me."],[233,304,"Do it, Luca!"],[304,358,"Do it!"],[379,467,"It's okay, Luca."],[496,567,"You can do it."],[709,829,"Born in blood, sworn in blood."],[829,888,"Remember?"],[959,1067,"The only way out is death."],[1351,1422,"I'm ready."],[1447,1505,"I..."],[1555,1710,"I love you, Luca."],[1885,1976,"I love you, too."],[2198,2318,"Remember everything, Aria."],[2389,2452,"Remember."],[4175,4254,"Are you okay?"],[4279,4366,"I am now."],[4800,4954,"But she won't be for long."],[6156,6214,"Luca!"]],"90":[[12,120,"Luca, are you okay?"],[187,329,"It's nothing, Princess."],[346,442,"It's the price I pay"],[442,529,"for keeping you safe."],[529,600,"And for you,"],[709,829,"I'd do it any day."],[1105,1226,"You're an asshole."],[1259,1393,"Don't die on me now."],[1393,1576,"Not after we finally fell in love."],[1672,1822,"I have been in love with you"],[1868,1989,"for a while now."],[2177,2243,"It looks like you're"],[2243,2373,"stuck with me, Princess."],[2535,2635,"I really am."],[2961,3040,"It's handled."],[3073,3274,"Boss, what do we do now?"],[3353,3465,"Now you go in there"],[3465,3603,"and you clean that mess up."],[3632,3716,"And tomorrow,"],[3920,3978,"Aria"],[4012,4124,"will help me lead a meeting"],[4141,4245,"to discuss the next steps"],[4245,4383,"to keep the Bratva away"],[4383,4450,"for good."],[4450,4558,"What about tonight?"],[4558,4775,"Tonight, I'm taking my wife home."]],"91":[[900,984,"Did you mean it,"],[984,1113,"what you said, back there?"],[1180,1263,"That I love you?"],[1263,1317,"Yes."],[1347,1522,"I know you don't do love, never have."],[1697,1785,"But I meant it."],[1976,2039,"You're right."],[2110,2214,"I've never been in love."],[2285,2352,"Until now."],[3207,3286,"But Aria,"],[3503,3570,"there's one more thing"],[3570,3770,"that we need to talk about, okay?"]],"92":[[442,592,"Luca, I know I fucked up."],[633,796,"I left when you told me to stay."],[813,959,"I'm not a good Mafia wife."],[1017,1155,"I don't follow orders."],[1155,1351,"I don't turn a blind eye when I should."],[1351,1593,"But I meant it when I said,"],[1630,1830,"Born in blood, sworn in blood."],[2444,2623,"I know that we're already married."],[2640,2744,"Okay? But you never"],[2744,2857,"got a proper proposal."],[2886,2977,"And you never got a say"],[2977,3082,"in the engagement."],[3094,3382,"I promise to always bleed for you."],[3420,3728,"I will protect you, and I will love you."],[4400,4491,"Will you marry me?"]],"93":[[275,563,"So will you stay married to me"],[563,725,"on your terms?"],[950,1046,"Yes, of course!"],[1096,1217,"Now and forever."],[1384,1488,"Until death."],[1551,1630,"Until death,"],[1672,1726,"baby."]]}