{"1":[[387,617,"Daddy, shiny shoes bring shiny moods!"],[1071,1151,"What did you call me?"],[1297,1355,"Daddy?"],[1568,1614,"How many times"],[1614,1676,"have I told you?"],[1739,1906,"Do not call me Daddy,"],[1906,2043,"it's Uncle Marcus."],[2306,2385,"Sweetie?"],[2498,2577,"If you have a problem,"],[2577,2665,"take it out on me,"],[2665,2761,"not our daughter."],[3178,3324,"Have you been drinking again?"],[3445,3628,"Marcus, I told you"],[3628,3720,"to not show up drunk"],[3720,3812,"around our daughter."],[3816,3999,"Oh please, our daughter?"],[4049,4141,"I never wanted a daughter"],[4141,4220,"with a gold digger"],[4220,4291,"like you anyway."],[4316,4416,"Delilah's who I wanted to"],[4416,4479,"have a daughter with."],[4479,4662,"I am your wife, Marcus,"],[4662,4829,"and Aria is just a kid."],[4875,4988,"If you really love Delilah"],[4988,5100,"that much, then go to England"],[5100,5184,"and be with her."],[5230,5317,"Please don't fight."],[5426,5513,"I promise not to"],[5513,5626,"call you daddy again."],[5693,5776,"I'm sorry."],[5968,6064,"I just had a little too much"],[6064,6189,"to drink, okay?"],[6235,6322,"Go play with your mom."],[6427,6564,"Wait, Uncle Marcus..."],[6664,6815,"Are you still eating cake with me?"],[6911,7023,"Aria's birthday?"],[7411,7599,"We booked dinner at Nobu."],[7599,7732,"You promised you'd come."],[7753,7807,"She's been looking"],[7807,7928,"foward to it the whole month."],[8179,8233,"I'll be there."],[8858,9004,"Maybe we can still fix this."],[9063,9113,"Maybe Marcus"],[9113,9200,"will come around."],[9759,9872,"Sweetie, go finish"],[9872,9955,"making your stars."],[9955,10076,"Mommy will be right there."],[10130,10160,"Okay."],[10614,10764,"Theo, I told you,"],[10764,10852,"never call this number-"],[10852,11065,"Sherry, turn on the news now."]],"2":[[45,204,"Once I have a thousand stars,"],[250,371,"I can make a wish."],[471,546,"My wish is for"],[546,671,"Daddy to love me."],[1117,1230,"I am standing in front of the"],[1230,1376,"Royal London Hospital,"],[1376,1559,"where the Duke of Westminster was"],[1559,1668,"admitted last night."],[1693,1780,"The doctors have yet to"],[1780,1935,"release any official information"],[1935,2060,"about his condition."],[2118,2210,"His eldest son..."],[2210,2273,"Oh my gosh."],[2323,2402,"What's wrong, Mommy?"],[2406,2540,"Who is next in line for the title..."],[2540,2794,"No, nothing, sweetie. It's okay."],[2836,2977,"His daughter, however,"],[2977,3199,"Sherry Grosvenor, who disappeared"],[3199,3307,"from public view,"],[3307,3461,"is yet to be seen."],[3653,3824,"My real name is Sherry Grosvenor,"],[3845,3949,"daughter of the Duke."],[4012,4133,"Seven years ago, I got"],[4133,4245,"pregnant with Aria."],[4291,4441,"I decided to leave everything"],[4441,4650,"behind and marry Marcus,"],[4679,4792,"the man that I love."],[4875,4934,"But now..."],[5209,5376,"Father is stable for now,"],[5376,5488,"but he wants to talk."],[5530,5593,"Sherry, you need"],[5593,5709,"to come back to England."],[7015,7140,"Mommy, I don't"],[7140,7236,"think daddy's coming."],[7303,7407,"Sweetie, daddy's..."],[7424,7603,"Daddy's probably just stuck in traffic."],[7716,7803,"Don't worry,"],[7853,7941,"he said he'd come."],[8950,9059,"Come on, Marcus."],[9542,9809,"Marcus, hey, where are you?"]],"3":[[4,241,"I'm busy, stop calling me."],[375,433,"Okay."],[1234,1372,"I'm sorry, ma'am,"],[1372,1484,"but we're closing."],[1505,1584,"Here's the check."],[1685,1747,"Thank you."],[2135,2256,"Mommy, what's wrong?"],[2369,2410,"Baby,"],[2640,2719,"Daddy, he's..."],[2815,2877,"he's just..."],[2882,2977,"It's okay, Mommy."],[3032,3128,"I know it's because I don't"],[3128,3257,"have a thousand stars yet."],[3465,3536,"Daddy will love me"],[3536,3674,"once I make my wish."],[3782,3958,"Mommy, can we go back home so"],[3958,4087,"I can make more stars?"],[4212,4291,"Yes, baby."],[4383,4466,"Let's go home."],[5301,5392,"That's Delilah,"],[5413,5534,"his first love."],[5559,5680,"She's back and..."],[5784,5822,"They have a"],[5822,5910,"daughter together?"],[6076,6168,"What's wrong, mommy?"],[6327,6452,"Nothing, sweetie."],[6481,6548,"Nothing at all."],[6627,6756,"Mommy, why are you crying?"],[6798,6869,"It's okay."],[7027,7107,"I'm not sad."],[7232,7298,"Daddy will love me"],[7298,7407,"once I make my wish."],[7574,7670,"This is all my fault."],[7724,7866,"Forcing myself to stay in a"],[7866,7953,"loveless marriage."],[7970,8037,"Hoping one day"],[8037,8179,"Marcus will love me back."],[8245,8383,"Hurting Aria along the way."],[8429,8508,"Depriving her of"],[8508,8604,"a happy childhood."],[8679,8754,"I can't let this"],[8754,8863,"go on any longer."],[9013,9205,"Aria, what do you say?"],[9205,9396,"We move somewhere new."],[9467,9551,"Like England."],[9601,9730,"With a new family."],[9972,10076,"Will daddy be there?"],[10310,10377,"No, sweetie."],[10489,10652,"Daddy will stay in Chicago."],[10756,10844,"Can we give daddy"],[10844,10998,"three more chances?"],[11048,11198,"I'll try three more times."],[11236,11307,"If he still won't"],[11307,11503,"love us, we can leave."]],"4":[[4,66,"If he still won't"],[66,262,"love us, we can leave."],[913,996,"Yeah, okey."],[1509,1593,"I'm so happy to"],[1593,1751,"finally see you again."],[1822,1922,"After all these years,"],[1922,1997,"Marcus."],[1997,2060,"I can't believe you didn't"],[2060,2177,"tell me we have a daughter."],[2214,2298,"I missed out on the first"],[2298,2402,"eight years of her life."],[2756,2969,"You're not her father, idiot."],[2990,3199,"Her real father is rotting in jail."],[3236,3390,"But now that you're rich."],[3411,3566,"I don't mind for you to play daddy."],[3928,4070,"It's...It's been"],[4070,4212,"really hard, Marcus."],[4212,4287,"And I just..."],[4346,4466,"I didn't want to burden you."],[4546,4721,"But after being away for so long,"],[4750,4879,"it just made me realize"],[4879,5092,"you're the only man for me."],[5251,5301,"That's why I moved"],[5301,5442,"back here with Brielle."],[5530,5634,"So we can finally be"],[5634,5764,"together as a family."]],"5":[[387,517,"Marcus, what's wrong?"],[583,633,"Nothing."],[717,804,"Nevermind,"],[804,909,"I thought I saw someone."],[1418,1576,"Three more chances, Marcus."],[1618,1735,"That's all you get."],[2936,3123,"Long time no see, baby sis."],[3378,3465,"Seriously, Theo?"],[3478,3553,"Did you really have"],[3553,3645,"to be this flashy?"],[3666,3778,"Oh relax, mate."],[3816,3974,"I flew all the way here to"],[3974,4145,"this unsophisticated bloody"],[4145,4262,"country to see you."],[4279,4358,"And you won't even give"],[4358,4483,"your dear old brother a hug."],[4512,4596,"America has really"],[4596,4692,"rubbed off on you."],[4817,4900,"How's father?"],[5059,5117,"He's stable."],[5150,5263,"We got lucky this time."],[5296,5426,"It wasn't a full blown stroke,"],[5426,5634,"it was a TIA, or mini-stroke,"],[5634,5709,"they call it."],[5743,5797,"But he wants you to"],[5797,5914,"come back right away."],[5935,5976,"Yeah."],[6068,6185,"I should have listened to father."],[6277,6539,"He was right, all along."],[6744,6835,"Marcus,"],[6919,7136,"he had a daughter with Delilah."],[7228,7273,"I saw them"],[7273,7378,"together last night."],[7407,7503,"That cheater!"],[7515,7653,"After all you've done for him,"],[7661,7799,"after you forced me to help him"],[7799,7862,"with his company"],[7862,7945,"and make him rich?"],[8078,8162,"You need to"],[8162,8304,"divorce him right away."],[8420,8521,"Yes, Theo."],[8608,8700,"Can we give daddy"],[8700,8850,"three more chances?"],[8900,9050,"I'll try three more times."],[9129,9292,"But Aria wants to give him"],[9330,9492,"three more chances."],[9588,9638,"Three more?"],[9638,9793,"Just three more, Theo."],[9864,9980,"And then I will bring Aria"],[9980,10126,"back to England where he will"],[10126,10435,"never find us, ever again."]],"6":[[312,496,"I fucking knew it!"],[538,675,"Well, good thing I hired a"],[675,763,"private investigator"],[763,892,"to look into Marcus."],[984,1096,"Turns out he's married to"],[1096,1247,"some dumb bitch"],[1247,1355,"with a daughter."],[1543,1655,"What's wrong, mommy?"],[1743,1826,"Hi, sweetheart."],[1868,2056,"If you want to continue to"],[2056,2289,"live the rich life, you know,"],[2323,2423,"the good life."],[2498,2681,"Mommy needs you to help win"],[2681,2794,"daddy Marcus over."],[2823,3003,"But Marcus is not my daddy."],[3003,3178,"Well, from now on, he is."],[3224,3336,"Otherwise we'll go broke."],[3386,3490,"No more nice things."],[3528,3603,"Do you understand?"],[3762,3845,"Yes, mommy."],[4346,4454,"Wait, mommy."],[4517,4612,"I know this girl."],[4688,4800,"Her name is Aria."],[4859,4909,"And we're in"],[4909,5034,"the talent show together."],[5180,5246,"Really?"],[5292,5326,"Huh."],[5438,5488,"Oh."],[6406,6585,"I'm saving this seat for Daddy."],[6740,6898,"I think I've heard you say daddy"],[6898,7057,"about eight hundred times today,"],[7057,7182,"I think my ears might fall off."],[7261,7419,"This is the first time he's ever come"],[7419,7549,"to see me perform!"],[8312,8370,"Hello?"],[8383,8458,"Miss Williams,"],[8458,8575,"could you stop by the office?"],[8600,8658,"Of course."],[8666,8758,"Yeah, I'll be right there."],[8808,8933,"Sweetie, hang tight."],[8933,9063,"Mommy'll be right back, okay?"],[9838,9964,"Seriously?"],[9964,10143,"You saved a whole seat for a dad"],[10143,10260,"who's not even coming?"],[10301,10435,"Don't touch that seat!"],[10506,10614,"It's for my dad!"],[10885,11123,"Mommy, I know this girl."],[11182,11277,"Her name is Aria."],[11390,11444,"Brielle?"],[11490,11540,"Yes?"],[11582,11661,"Mommy needs you to do"],[11661,11786,"something, okay?"],[11891,12016,"Mommy has the perfect plan."],[12228,12354,"Oww! Stop it."],[12399,12508,"That hurts!"]],"7":[[175,300,"Oww! Stop it."],[346,454,"That hurts!"],[475,596,"I do have a dad!"],[600,729,"And he's coming today."],[784,859,"You'll see!"],[859,992,"Yeah right, loser."],[1017,1138,"Everybody knows you were raised"],[1138,1251,"by a single mom."],[1910,1997,"Rumor is..."],[1997,2152,"Your mom had so many boyfriends,"],[2152,2260,"she doesn't even know"],[2260,2385,"who your dad is!"],[2548,2640,"Like mother,"],[2652,2731,"like daughter."],[2761,2932,"Just stay away from her, sweetie."],[2965,3011,"You don't wanna"],[3011,3161,"pick up her bad habits."],[3190,3365,"You too, honey, don't play"],[3365,3503,"with her, ever."],[4062,4162,"Your dad left"],[4162,4295,"cause your mom's trash."],[4325,4504,"No wonder he doesn't want you."],[4542,4775,"Don't talk about my mom like that!"],[4913,4979,"Liar!"],[5080,5201,"Loser!"],[5226,5317,"He's real..."],[5447,5555,"My daddy's real..."],[5647,5776,"He will come."],[6765,6915,"Excuse me, is this where the"],[6915,7011,"talent show's happening?"],[8683,8863,"Daddy! You're here!"]],"8":[[8,166,"Her dad actually showed up."],[200,271,"We were wrong."],[304,525,"Aria's dad is so handsome!"],[554,642,"Wait, is that"],[642,792,"Marcus Williams?"],[838,1051,"The CEO of the Williams Group?"],[1071,1247,"No wonder he never came."],[1280,1443,"He's probably drowning in a"],[1443,1609,"billion dollar deals."],[1705,1926,"Daddy, this is your new seat!"],[2060,2127,"What did you call me?"],[2277,2360,"I…"],[2456,2523,"I'm sorry."],[2523,2594,"You know you're not supposed"],[2594,2652,"to call me that."],[2907,2990,"Uncle Marcus?"],[3211,3420,"Wait, he's not her dad?"],[3666,3803,"Told you all she was lying."],[3837,3987,"She made up a fake dad,"],[4004,4124,"cause she was too embarrassed"],[4124,4287,"to admit she didn't have one."],[4517,4600,"I'm not lying."],[4646,4750,"You so are!"],[4800,4900,"This's my dad."],[4929,4992,"And the only woman"],[4992,5171,"he loves is my mom."],[5430,5593,"Sherry, I'm gonna erase"],[5593,5722,"both you and your daughter"],[5734,5843,"from Marcus's life."],[5893,6031,"I'm the only one who can be"],[6031,6210,"the future Mrs. Williams."],[6456,6623,"No, no,"],[6690,6852,"he's not your dad."],[6961,7082,"He's my dad."],[7102,7194,"Stop lying!"],[9259,9630,"No, my stars, my wishing jar!"],[9751,9784,"Aria!"]],"9":[[0,70,"Aria!"],[275,421,"No, stop!"],[421,525,"Those are my wishing stars!"],[592,642,"Ow!"],[663,784,"Ow, it hurts!"],[792,913,"That hurts!"],[917,1038,"Baby, are you okay?"],[1080,1142,"Cry more, remember"],[1142,1234,"what mommy told you."],[1317,1534,"Mom, she pushed me!"],[1580,1810,"My arm's broken and hurt!"],[1947,2177,"Aria, apologize to Brielle."],[2193,2252,"Now!"],[2640,2865,"No, you are my daddy."],[2902,2990,"I'm not lying."],[3011,3073,"I don't want to"],[3073,3165,"say sorry to her."],[3194,3374,"She stepped on me first."],[3762,3899,"You did nothing wrong, sweetie."],[3991,4095,"Really, Marcus?"],[4133,4254,"Bullying an eight-year-old!"],[4483,4658,"So it's true then Marcus?"],[4775,4888,"That's your daughter and..."],[4963,5100,"she's your mistress?"],[5459,5522,"No."],[5601,5739,"No, she's just my employee."],[5797,5868,"That's her daughter,"],[5868,5926,"not mine."],[6502,6589,"Aria,"],[6589,6694,"I didn't come to watch you."],[6715,6856,"I came to watch Brielle perform."],[7102,7157,"What?"]],"10":[[12,70,"What?"],[116,225,"You're just confused because"],[225,316,"you go to the same school."],[358,542,"Apologize to Brielle, now!"],[984,1134,"My stars got crushed."],[1184,1247,"That's why my"],[1247,1355,"wish didn't work."],[1555,1710,"I'm sorry, Brielle."],[1843,2056,"Uncle Marcus is your dad."],[2156,2327,"I'm just a girl with no dad."],[2744,2923,"Was I…too harsh?"],[3015,3136,"You do not need to"],[3136,3240,"apologize to her."],[3336,3503,"Marcus, I swear to God-"],[3503,3611,"It's okay, mommy."],[3645,3732,"It's my fault."],[3816,3912,"I couldn't protect"],[3912,4041,"my wishing stars."],[4287,4341,"That's why my"],[4341,4437,"wish didn't work."],[4646,4846,"Oh my God, it's just stars."],[4846,4996,"We'll buy you some new ones."],[4996,5059,"Money?"],[5109,5188,"Do you really think"],[5188,5276,"this is about money?"],[5472,5568,"No, Aria, stop!"],[5568,5655,"You're bleeding!"],[5889,5993,"Here, Uncle Marcus."],[6072,6243,"I made these for you."],[7107,7190,"You made these for me?"],[7645,7707,"Yes!"],[7774,7836,"Aria folded"],[7836,7978,"every single one of these."],[7982,8074,"Over a thousand!"],[8074,8183,"Do you know"],[8183,8454,"how many days and nights"],[8454,8558,"it would take to"],[8558,8666,"fold all of those?"],[8666,8704,"Huh?"],[8754,8783,"No."],[8867,9038,"And she only had one wish,"],[9109,9196,"and that was for you"],[9196,9309,"to love her back!"],[10406,10523,"I'm so sorry, Aria."],[10881,11044,"That was the first chance."],[11373,11507,"Two more chances, Marcus."],[11561,11678,"Better not mess that up."],[11732,11820,"Two more chances, what are"],[11820,11895,"you talking about?"],[12078,12170,"Mommy,"],[12191,12387,"when his three chances are up,"],[12404,12579,"I want to leave with you."],[12750,12812,"Are you sure you"],[12812,12904,"won't regret it?"],[13013,13088,"I'm sure."],[13400,13584,"Hey, where are you going?"],[13584,13688,"And what are you talking about,"],[13688,13767,"two chances?"]],"11":[[4,75,"Where are you going?"],[75,141,"And what are you talking"],[141,254,"about two chances?"],[316,387,"Well, that's for me to know"],[387,529,"and you to find out, Marcus."],[667,713,"Come on,"],[750,792,"let's go take"],[792,884,"care of your hands."],[1368,1551,"You are going to love London,"],[1551,1655,"I promise."],[1801,2022,"I can't wait for you to meet"],[2022,2106,"Uncle Theodore"],[2106,2214,"and Grandpa Edmund."],[2273,2389,"Will they like me?"],[2448,2581,"Or will they be like Daddy"],[2581,2673,"and hate me too?"],[2802,2852,"Sweetheart,"],[2969,3178,"they love you already."],[3290,3407,"They haven't even met you yet."],[3549,3699,"That's what family means."],[3720,3820,"I promise."],[3920,4020,"But not Daddy."],[4346,4567,"Ms. Sherry, you're leaving?"],[4587,4758,"Ms. Moreau came into town just to"],[4758,4896,"hear Aria play live."],[4909,4967,"Wait,"],[5000,5142,"you're Ms. Evelina!"],[5155,5330,"The famous pianist?"],[5367,5530,"You're my idol!"],[5605,5776,"And I'm a fan of yours, Aria."],[5805,5905,"If your live performance"],[5905,6068,"matches the video I saw,"],[6110,6177,"I've got a little"],[6177,6314,"surprise waiting for you."],[6552,6773,"Mommy, can I play just one"],[6773,6952,"last song, please?"],[7048,7140,"Of course."],[7782,7932,"Welcome everyone to our"],[7932,8153,"Nova Elementary Talent Show!"],[8174,8408,"First up, Brielle Smith."],[9726,10026,"Oh dear God, that piano did"],[10026,10160,"not deserve this."],[10181,10372,"No skill, no soul."],[10456,10648,"She's not meant for music."],[11861,12045,"Up next, Aria."],[12741,12862,"She's a liar!"],[12879,12950,"Nobody wants to"],[12950,13108,"hear her perform!"],[13284,13421,"She's a liar!"],[13421,13492,"She's fake!"],[13492,13634,"Get off the stage!"],[13634,13876,"Boo!"],[13876,14243,"Boo!"],[14243,14305,"No,"],[14305,14368,"this is a school"],[14368,14535,"talent show, not a riot."],[14560,14685,"Anyone throwing anything else"],[14685,14806,"will be escorted out."],[14848,14969,"I wasn't lying."],[15031,15152,"Marcus is my dad."],[15252,15331,"I'm about to play"],[15331,15427,"this song for him."],[15511,15628,"I hope..."],[15761,15857,"he likes it."],[16362,16524,"This one's for you, daddy."]],"12":[[2260,2364,"Such talent!"],[2419,2502,"That's what a piano"],[2502,2615,"prodigy sounds like."],[4045,4187,"That was amazing, baby."],[4187,4316,"I'm so proud of you."],[4721,4842,"Was I…"],[4900,5055,"Was I too cruel to Aria?"],[5184,5321,"I am proud to announce,"],[5321,5397,"today's first"],[5397,5497,"place winner"],[5543,5626,"is Aria."],[6377,6427,"Thank you."],[6502,6627,"Aria, I would like to"],[6627,6765,"personally invite you to a"],[6765,6852,"three week summer"],[6852,6981,"program at Juilliard."],[7019,7127,"You'll train with the best"],[7127,7228,"and brightest."],[7298,7374,"What do you say?"],[7494,7549,"Yes!"],[7578,7736,"Yes, that's my dream!"],[7882,7962,"No, mommy,"],[7962,8103,"I should be the one to go."],[8103,8237,"I want to go!"],[8262,8391,"I'm sorry, sweetheart."],[8425,8529,"Marcus, is there"],[8529,8637,"something you can do?"],[8654,8779,"Some strings you can pull?"],[8842,8896,"Aria's been"],[8896,9050,"privileged her whole life."],[9079,9192,"Okay, Brielle's had nothing."],[9192,9288,"What do you want me to do?"],[9421,9509,"You know what?"],[9580,9647,"I guess you don't"],[9647,9730,"care about Brielle."],[9743,9780,"No,"],[9851,9947,"of course not."],[10193,10297,"Brielle's my daughter too."],[10347,10456,"I will handle it."],[10648,10714,"Thank you."],[11653,11820,"Sweetie, that was amazing!"],[11953,12007,"Are you happy?"],[12007,12070,"Mm-hmm."],[12224,12366,"Hey, Aria."],[12458,12708,"Sweetheart, you did so good."],[12708,12975,"That was a fantastic performance."],[13021,13063,"Really?"],[13100,13192,"You like my song,"],[13192,13275,"Uncle Marcus?"],[13275,13367,"I loved it."],[13459,13601,"And from now on,"],[13692,13817,"you can call me dad."]],"13":[[8,133,"Oh my God."],[158,321,"Marcus just admitted it."],[396,517,"Aria is his daughter?"],[617,750,"Which means Delilah"],[750,875,"is a home wrecker?"],[913,959,"What are you"],[959,1092,"pulling now, Marcus?"],[1213,1272,"It's okay."],[1313,1405,"Go on, say it."],[1947,2010,"Daddy!"],[2072,2168,"Thanks, daddy!"],[2202,2414,"You are a great"],[2414,2569,"little piano player."],[2652,2794,"And I know I messed"],[2794,2977,"up and I hurt you."],[3048,3186,"And I am so sorry."],[3257,3457,"Daddy saw how talented I am,"],[3465,3607,"and now he loves me."],[3641,3745,"And even though I wasn't at"],[3745,3837,"your birthday,"],[3908,4024,"I did"],[4116,4270,"get these cupcakes for you."],[4700,4767,"Go on, try it."],[4767,4842,"See if you like it."],[4842,5009,"Daddy loves me now because I"],[5009,5063,"played well at"],[5063,5150,"the talent show."],[5568,5638,"This is the best"],[5638,5784,"cupcake I've ever had!"],[5910,5997,"I