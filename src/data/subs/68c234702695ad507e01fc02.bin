Teaching our daughter to lie?"],[3511,3628,"Are you out of your mind?"],[3724,3849,"The truth is standing right"],[3849,3928,"in front of you, but you"],[3928,4054,"refuse to look at it."],[4283,4550,"Aria, I'm your dad, and I have"],[4550,4587,"to teach you"],[4587,4683,"right from wrong."],[4746,4800,"It's not okay to"],[4800,4909,"lie about who we are."],[4909,4992,"I didn't lie."],[5038,5180,"You just never believe me no"],[5180,5301,"matter what I say."],[5739,5893,"Stop this nonsense."],[6160,6222,"Grandpa!"]],"58":[[8,95,"Grandpa!"],[137,233,"Stop, Aria."],[342,454,"You can't just run up to the Duke,"],[454,529,"it's not polite."],[579,621,"And don't just"],[621,759,"call anyone Grandpa."],[884,1034,"It's the Duke of Westminster."],[1284,1526,"Please escort Aria and my daughter"],[1526,1689,"to their changing rooms."],[2027,2106,"Come on,"],[2143,2273,"let's go get you cleaned up."],[3194,3232,"Wait!"],[3265,3507,"Don't bring attention to us."],[3507,3566,"They're already being"],[3566,3699,"escorted off the premises."],[3883,4033,"They don't belong here anyways."],[4129,4262,"I'll find them after the banquet."],[4504,4683,"Your Grace, I am so sorry"],[4683,4829,"about all of this chaos,"],[4829,4884,"but,"],[4884,5055,"you must understand this girl,"],[5075,5159,"she was trying to"],[5159,5251,"impersonate your"],[5251,5309,"granddaughter."],[5551,5634,"I mean,"],[5634,5714,"we tried to help by"],[5714,5801,"getting rid of them,"],[5801,5893,"and we don't even know"],[5893,6014,"how they got in here."],[6093,6202,"No one asked you"],[6202,6352,"for your opinion."],[6585,6798,"Sir, I am so sorry."],[6915,6994,"Aria is my daughter and I"],[6994,7132,"take full responsibility,"],[7152,7236,"but please forgive her,"],[7236,7332,"she's only a child."],[7353,7486,"Marcus Williams."],[7561,7682,"I know you."],[7899,8033,"Your Grace, it's great to"],[8033,8174,"finally meet you in person."],[8525,8679,"You're the horrendous man"],[8679,8875,"who married my daughter."]],"59":[[12,137,"Wait, did he just say"],[158,262,"Sherry is his daughter?"],[342,454,"No, there's no way"],[454,529,"I heard that right."],[650,775,"And you,"],[788,888,"you're nothing but a"],[888,1071,"mound of horseshit."],[1267,1355,"Excuse me?"],[1384,1493,"Why do you think we invited"],[1493,1651,"you and Marcus here, Delilah?"],[1768,1830,"You think getting an"],[1830,1922,"invitation from the Royal"],[1922,2022,"family is easy?"],[2173,2339,"We have proof of everything"],[2339,2452,"you've ever done."],[3328,3420,"This is impossible."],[3432,3578,"Oh, it's all in there."],[3674,3782,"How you framed your last"],[3782,3908,"husband in England for"],[3908,4004,"corporate fraud."],[4129,4241,"And we had to get you back on"],[4241,4416,"British soil somehow."],[4483,4617,"How do the Americans say it?"],[4733,4817,"Oh yes."],[4850,4934,"Gotcha!"],[5113,5246,"You lied to me again."],[5288,5438,"No, no, I didn't!"],[5509,5593,"Don't believe them!"],[5655,5693,"They're…"],[5747,5860,"They're in this together!"],[6231,6356,"That's Sherry's lover."],[6393,6439,"Oh,"],[6514,6652,"disgusting."],[6690,6806,"Sherry is my sister."],[6856,7002,"Anyone with half a brain"],[7002,7127,"can Google it."],[8058,8128,"He really is the"],[8128,8224,"son of the Duke."],[8387,8479,"Oh no, I've had"],[8479,8558,"this all wrong."],[8621,8729,"Sit tight, mate."],[8771,8913,"The show is just"],[8913,9038,"getting started."]],"60":[[16,145,"Ladies and gentlemen."],[450,617,"Tonight we gather"],[663,821,"to celebrate family,"],[867,1005,"truth, and honor."],[1084,1317,"Many of you know that eight years ago,"],[1317,1468,"my daughter"],[1468,1655,"married an American,"],[1751,1939,"and left England behind."],[2089,2177,"At the time,"],[2293,2540,"my pride and stubborn ego"],[2665,2773,"caused me"],[2823,3011,"to not speak with her."],[3261,3420,"I regret that every day."],[3553,3641,"But,"],[3757,4008,"life has given me a"],[4008,4166,"second chance."],[4325,4575,"My daughter has returned home"],[4629,4838,"and has brought with her."],[4909,5125,"one of the greatest joys"],[5125,5292,"I could ever imagine."],[5455,5543,"My granddaughter."],[5739,5922,"So it is my deepest honor"],[6051,6277,"that I present to you for the"],[6277,6460,"very first time,"],[6577,6790,"Lady Aria Grosvenor"],[6815,6977,"of Westminster,"],[7107,7244,"and her mother,"],[7369,7457,"my daughter,"],[7578,7699,"Lady Sherry..."],[7749,7887,"Grosvenor."],[10118,10243,"It really is them,"],[10264,10439,"Sherry and Aria."]],"61":[[1005,1146,"This means I got it all wrong."],[1205,1242,"Sherry never"],[1242,1330,"married me for money."],[1413,1509,"She married me..."],[1568,1693,"because she loved me."],[1772,1856,"No, no, no,"],[1856,2002,"this is not happening."],[2414,2548,"Her birthday was last month."],[2640,2857,"This celebration is simply"],[2857,3023,"fashionably late."],[3086,3332,"Dear God, we just insulted a"],[3332,3395,"real life"],[3395,3524,"duchess-in-the- making!"],[3636,3787,"From now on, every birthday"],[3787,3858,"you have,"],[3933,4037,"I will be there"],[4058,4175,"right by your side."],[4241,4437,"You are the greatest treasure"],[4546,4758,"of the Grosvenor legacy."],[5351,5455,"Thank you, Grandpa."],[5563,5797,"That crown, it's bespoke."],[5885,6072,"Only ancient noble"],[6072,6202,"bloodlines have access"],[6256,6335,"to things like that."],[6352,6477,"It's worth over a million!"],[6660,6794,"No, no, no!"],[6794,6894,"Mommy, you said I"],[6894,7007,"could have everything if I"],[7007,7098,"listened to you."],[7127,7215,"You even made me call that"],[7215,7340,"loser my daddy!"],[7378,7461,"What's that supposed to mean,"],[7461,7553,"you little brat?"],[7561,7640,"I don't care,"],[7640,7824,"I want that crown!"],[7845,7920,"Guards!"],[8812,9013,"Apologies for the intrusion."],[9013,9142,"I really do hate"],[9142,9309,"interrupting a party."],[9355,9421,"I'm here to"],[9421,9584,"arrest Delilah Smith."]],"62":[[0,145,"No, let me go!"],[229,337,"But I'm an"],[337,475,"American citizen!"],[563,696,"You can't arrest me here!"],[713,846,"Oh, but we can."],[975,1101,"You see, you lived in London"],[1101,1322,"for eight years in which you"],[1322,1447,"married a British citizen."],[1526,1614,"After your company went"],[1614,1797,"bankrupt, you framed your"],[1797,1889,"husband and ran"],[1889,2002,"back to America."],[2052,2198,"It was very difficult to have"],[2198,2323,"you extradited, but,"],[2394,2523,"thank you to the Duke."],[2786,2873,"You are now under"],[2873,2977,"my jurisdiction."],[3065,3207,"Allegedly, of course,"],[3249,3345,"but I do think I have"],[3345,3436,"the proof I need."],[3903,4024,"So that's why you came back."],[4066,4141,"You lied to me"],[4141,4279,"over and over again."],[4279,4333,"I never should"],[4333,4421,"have trusted you!"],[4466,4608,"You took everything from me."],[4608,4750,"You took my company, my wife,"],[4750,4821,"and even my daughter!"],[4833,5088,"Shut up, Marcus, shut up!"],[5296,5422,"I'm done with you anyway."],[5463,5584,"I never loved you"],[5584,5759,"and I never will!"],[5809,6026,"All you do is abuse women and"],[6026,6118,"break their hearts."],[6156,6256,"I mean, look at Sherry."],[6348,6464,"You even broke her heart."],[6564,6723,"My ex-husband, who is"],[6723,6915,"dumb as fuck,"],[6915,7027,"is even better than you!"]],"63":[[0,150,"My ex-husband, who is"],[150,342,"dumb as fuck,"],[342,454,"is even better than you!"],[529,734,"Enough of this nonsense!"],[771,905,"Security, take them out."],[967,1071,"No, no!"],[1280,1447,"Thank you, your Grace,"],[1459,1543,"for all your help."],[1580,1726,"I hope you all have a"],[1726,1847,"wonderful evening."],[1897,2010,"Oh, we will."],[2477,2765,"Sherry, I am so, so sorry."],[2815,2902,"I have it all wrong."],[2923,2957,"Can…"],[3048,3144,"Can you please forgive me?"],[3253,3382,"It'll be a cold day in hell"],[3382,3516,"the day I forgive you."],[4012,4179,"Aria, sweetheart, look, look"],[4179,4262,"what I've got for you."],[4742,4884,"I folded these for you."],[5059,5176,"They're the same shape,"],[5176,5255,"the same color,"],[5284,5338,"just like the ones"],[5338,5422,"you used to make."],[5547,5622,"Aria."],[5722,5801,"Sweetheart."],[5834,6014,"I’m so sorry, daddy knows"],[6014,6131,"he messed up."],[6131,6247,"But we can fix this,"],[6293,6435,"if you, and me,"],[6435,6514,"and mommy,"],[6531,6639,"we go back to Chicago,"],[6639,6777,"we can be a family again."],[6973,7073,"You're not my daddy."],[7198,7273,"You're just…"],[7344,7461,"Uncle Marcus."],[7482,7595,"No, no, no, no, no, please."],[7686,7745,"Please don't call"],[7745,7828,"me Uncle Marcus."],[8116,8158,"I'm your dad,"],[8158,8262,"I'm your real dad."],[8262,8350,"Just, can you...."],[8404,8487,"can you call me daddy"],[8487,8579,"one more time?"]],"64":[[0,116,"You were the one who never"],[116,258,"let me call you daddy."],[342,458,"Don't you remember?"],[521,667,"Do not call me dad!"],[717,855,"It's Uncle Marcus."],[984,1063,"It's all my fault."],[1146,1197,"I'm the worst"],[1197,1288,"father who's ever lived."],[2031,2143,"Did you also forget all the"],[2143,2210,"other mean things"],[2210,2285,"you did to me?"],[2515,2652,"Please, stop."],[3524,3599,"Aria,"],[3624,3732,"sweetheart,"],[3820,4020,"daddy knows he messed up, but"],[4095,4195,"I want to change."],[4195,4237,"Can…"],[4287,4341,"Can you give me"],[4341,4425,"another chance?"],[4587,4721,"You had three chances,"],[4721,4854,"but you lost them all!"],[5055,5113,"You broke every"],[5113,5246,"promise you made me."],[6452,6556,"No!"],[6685,6911,"No, no, no, no!"],[7724,7811,"Aria,"],[7941,8058,"please forgive me."],[8312,8491,"Aria, Sherry,"],[8575,8717,"I'm so sorry."],[8854,9092,"Cut the performance, Marcus."],[9175,9321,"You are out of chances."]],"65":[[33,183,"Show's over, mate."],[216,483,"You had it all once,"],[483,567,"Marcus."],[663,842,"Your daughter adored you,"],[842,1088,"your wife sacrificed everything"],[1088,1326,"to help build your empire."],[1434,1626,"Your pride and ignorance"],[1647,1797,"destroyed it."],[1881,2077,"Now you will repent alone."],[2168,2419,"Pray that God brings you"],[2444,2631,"some kind of forgiveness."],[2798,2894,"Security,"],[3019,3140,"show him the way."],[3353,3645,"No, no, no!"],[5401,5501,"I'm so sorry."],[5613,5722,"It's all my fault."],[5851,5951,"Aria, Sherry,"],[6076,6243,"I've lost you both forever."],[6306,6427,"What's the point of living?"],[6443,6573,"I have nothing left."]]}