,[5618,5764,"I cut ties with my family so"],[5764,5864,"that we could get married."],[5864,5947,"She's lying."],[5947,6035,"She's not some"],[6035,6126,"secret duchess."],[6172,6293,"She's a slum girl who hopped"],[6293,6335,"into bed with"],[6335,6443,"me for a payday."],[6489,6669,"Your money, Marcus."],[6806,6986,"You don't know anything about"],[6986,7094,"who I really am."]],"33":[[33,137,"What status could you"],[137,241,"possibly have?"],[333,442,"You were so broke when we"],[442,529,"first met, you were selling"],[529,600,"your own blood."],[788,838,"Marcus,"],[988,1071,"all those years"],[1071,1180,"that we spent together,"],[1317,1426,"did you ever,"],[1455,1559,"even for a second,"],[1718,1860,"actually love me?"],[2781,2865,"Dammit, Marcus!"],[2882,3011,"What is this nonsense about"],[3011,3182,"becoming an architect, huh?"],[3294,3378,"Why don't you just go to"],[3378,3474,"dental school"],[3474,3591,"like I told you to?"],[4237,4329,"Hey..."],[4479,4587,"I support you."],[4650,4863,"You are going to be the"],[4863,5021,"greatest architect this world"],[5021,5171,"has ever seen,"],[5338,5434,"and I'm gonna be with you"],[5434,5643,"every step of the way."],[5897,5939,"I don't know what"],[5939,6026,"I'd do without you."],[6748,6819,"Hey, watch out!"],[6961,6990,"Oh!"],[7361,7428,"Are you okay?"]],"34":[[50,125,"Are you okay?"],[133,212,"Yeah, it's just,"],[246,358,"it's just my arm."],[529,571,"What were you"],[571,638,"thinking, silly?"],[1856,1914,"She sure is good"],[1914,2006,"at playing innocent."],[2089,2223,"I did admire you once,"],[2252,2364,"but after that night,"],[2364,2460,"after you tricked me into"],[2460,2565,"sleeping with you,"],[2565,2727,"that admiration turned to disgust."],[2886,2944,"We were both"],[2944,3053,"drunk that night."],[3111,3253,"It wasn't about money for me."],[3319,3432,"It wasn't about your wealth."],[3528,3591,"I wanted you,"],[3691,3791,"your love."],[3841,3962,"Let's bring this back to the"],[3962,4045,"matter at