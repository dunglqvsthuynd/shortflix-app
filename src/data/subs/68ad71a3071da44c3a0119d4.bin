{"1":[[1017,1309,"We have Mr. Giovanni Cavolini,"],[1347,1597,"CEO of leading fashion corporation,"],[1597,1722,"LVWH."],[1751,1976,"Is he opening the car door for her?"],[2018,2223,"That man's got so much power,"],[2256,2394,"even Forbes magazine"],[2394,2523,"is at his beck and call."],[2565,2690,"Look who's stepping out,"],[2823,2944,"Eve Corbelle!"],[2982,3161,"Acclaimed editor-in-chief of"],[3161,3282,"ROGUE magazine,"],[3290,3445,"the world's most influential"],[3445,3553,"fashion publication."],[3586,3774,"She is also the visionary founder"],[3774,3883,"of the Maple Gala,"],[3912,4091,"the largest and most prestigious"],[4091,4195,"fashion festival."],[4212,4270,"Simply put,"],[4308,4496,"Eve stands at the very pinnacle"],[4496,4625,"of the fashion world."],[4654,4713,"Queen Corbelle,"],[4796,4917,"may I have the pleasure of a dance"],[4917,4954,"tonight?"],[4992,5055,"Oh my God!"],[5084,5242,"Leonardo Harrington,"],[5251,5367,"who won Best Male Lead"],[5367,5568,"at the past three Academy Awards"],[5568,5814,"is also vying for the opportunity"],[5814,5897,"to dance with her."],[5926,6085,"A favor for a knight."],[6147,6277,"It suits you well, Giovanni."],[6414,6477,"You're the best."],[6940,7119,"I would like to thank everyone"],[7119,7244,"for coming this evening."],[7323,7532,"Fashion is art,"],[7607,7678,"and art..."],[7741,7870,"is ultimately play."],[7970,8183,"So, welcome to my playground."],[8475,8637,"Long live the Queen!"],[8650,8812,"And her fashion empire!"],[9659,9809,"I do have one other announcement"],[9809,9889,"I'd like to make."],[10001,10035,"I..."],[10093,10193,"have fallen in love."],[10297,10456,"And for the one I love,"],[10456,10614,"and for my family,"],[10798,10944,"I'm stepping away from fashion."],[14464,14535,"Ah..."],[15269,15361,"You idiot!"],[15790,15915,"Ruined my shoes!"],[15995,16136,"You're gonna pay for this damage!"],[16166,16199,"Here."]],"2":[[41,141,"Here, is this enough to cover it?"],[354,454,"And watch your mouth!"],[1217,1251,"Eve,"],[1359,1555,"it's been 16 years and I finally"],[1555,1605,"found you."],[1664,1739,"Come back to ROGUE."],[1805,1851,"We miss you."],[1910,2022,"And the Grand Maple Gala"],[2022,2081,"needs you."],[2218,2348,"Giovanni, that's..."],[2348,2506,"water under the bridge."],[2556,2715,"My daughter and my husband,"],[2715,2819,"they need me way more than"],[2819,2915,"ROGUE magazine."],[2927,2957,"Eve,"],[2998,3036,"you were the"],[3036,3194,"Queen of the Red Carpet,"],[3240,3365,"not just someone's wife."],[3461,3574,"Are you really happy like this?"],[4195,4275,"I know you don't"],[4275,4458,"understand what it's like to be a mother."],[4562,4600,"But..."],[4637,4842,"all this spotlights on the stage..."],[4917,5046,"it doesn't really compare to"],[5046,5180,"what a candlelit dinner is"],[5180,5292,"with my family."],[5388,5584,"And to see a genuine smile"],[5584,5672,"by my daughter,"],[5714,5868,"it makes me so happy."],[5939,6085,"I mean all the accolades"],[6085,6177,"in the world,"],[6177,6360,"it..it doesn't even compare."],[6715,6769,"Oh, I do..."],[6923,7032,"have a favor to ask."],[7032,7065,"It's a..."],[7094,7178,"pretty big favor."],[7432,7640,"Your wish is my command,"],[7665,7732,"Queen Corbelle."],[7753,7786,"Well."],[7899,8070,"I would like the Grand Maple Gala"],[8095,8295,"to extend a belated invitation"],[8295,8445,"to my husband, Shawn Rockwell."],[8596,8804,"Look, his company, it could really use"],[8804,8908,"the exposure."],[9196,9359,"I...I want the editor-in-chief of"],[9359,9446,"ROGUE magazine"],[9488,9609,"to write up a contract,"],[9667,9851,"and present it to him at the gala."],[10076,10243,"Uh, yeah, I mean that's easy enough."],[10276,10339,"Obviously."],[10414,10452,"But..."],[10543,10589,"Eve,"],[10664,10814,"you've really done so much for him."],[10923,10985,"Is he really worth..."],[11061,11144,"your time and your..."],[11177,11227,"Giovanni,"],[11277,11448,"you have a fashion empire to run,"],[11532,11682,"and I have my daughter's"],[11682,11790,"birthday party to set up."],[11828,11899,"Till next time."],[12975,13096,"Yeah, Mike, it's me."],[13246,13380,"Need you to draw up a contract,"],[13496,13592,"for Shawn Rockwell,"],[13634,13726,"of Rockwell Intimates."],[14126,14176,"Now, Eve..."],[14239,14414,"I know you wanted it to be a surprise."],[14497,14585,"Little do you know..."],[14639,14731,"it's gonna be a countdown"],[14731,14798,"to extinction."],[14973,15165,"Welcome back to our empire, Queen."],[15519,15707,"I bet Lily's cake is done."],[16212,16291,"Shawn..."],[17317,17346,"What?"],[17346,17392,"Stop!"],[17392,17492,"Your wife is home!"]],"3":[[20,66,"Shawn!"],[204,246,"You're..."],[362,462,"you're cheating on me!"],[563,679,"This?"],[679,900,"Oh...no, this doesn't count."],[959,1351,"I was just fulfilling a biological need."],[1797,1947,"Yeah, I mean, don't get your panties"],[1947,2097,"in a twist, Eve."],[2114,2398,"I was just helping your husband out."],[2515,2719,"He's been bored out of his mind"],[2719,2848,"with missionary."],[2861,3107,"Said it's like fucking an old ugly cow."],[3123,3382,"No, Karen, I didn't actually say that."],[3382,3436,"Aren't you?"],[3511,3557,"Oh!"],[3649,3803,"What I said was..."],[3849,3991,"I haven't had missionary with..."],[4045,4195,"that...in a year."],[4245,4379,"In fact, I haven't even touched her"],[4379,4521,"since I met you."],[4738,4775,"Shawn!"],[4859,5042,"We've been married for 16 years."],[5075,5167,"Is this how you were gonna"],[5167,5309,"talk about me behind my back?"],[5309,5355,"Because you're..."],[5397,5455,"old and..."],[5551,5597,"ugly."],[5618,5809,"Look how young and beautiful"],[5809,5939,"Karen is, and she is."],[5968,6060,"What do you got?"],[6168,6327,"Wrinkles on your hands and"],[6327,6523,"disgusting stretch marks"],[6523,6639,"like a circus show."],[7428,7507,"And that apron..."],[7691,7745,"gross."],[7878,7991,"Queen Corbelle!"],[8008,8187,"Long live Queen Corbelle!"],[9334,9384,"Shawn,"],[9409,9567,"did you forget what you said to me,"],[9567,9693,"when I was pregnant with Lily?"],[9747,9914,"You said those stretch marks..."],[9914,10080,"they were a sign of motherhood and..."],[10089,10243,"that I shouldn't be ashamed of,"],[10243,10372,"that they were war wounds."],[10443,10485,"What?"],[10539,10648,"Okay, just..."],[10648,10769,"stop bringing up all these"],[10823,11069,"old drama from 10 years ago, okay?"],[11081,11227,"Look, we've gone separate ways."],[11227,11336,"I think it's obvious."],[11353,11461,"I run a fashion brand!"],[11461,11540,"And look at you!"],[11565,11644,"You're just a beat-up old"],[11644,11749,"disgusting housewife"],[11749,11953,"who cleans and kind of cook."],[11953,12103,"Shall not worthy of me!"],[12258,12341,"Me?"],[12341,12504,"I...I don't deserve you?"],[12683,12900,"If it wasn't for my quiet support,"],[12921,12987,"do you even thin...think"],[12987,13079,"you would be standing here,"],[13079,13133,"right now?"],[13133,13254,"Don't talk the brags!"],[13254,13425,"Don't blow your housewife thing"],[13425,13513,"out of proportion!"],[13546,13697,"You're just some beat-up old hag,"],[13722,13801,"compared"],[13801,14026,"to Karen from the fashion world,"],[14051,14297,"who is beautiful and sleek and amazing!"],[14326,14439,"She's the one..."],[14476,14735,"who can take me places."],[14768,14843,"Industry?"],[14931,15152,"She is just a third-rate model!"],[15206,15290,"I'm, I...after all,"],[15290,15461,"I'm the one that created the..."],[15682,15861,"Shawn, darling!"],[15870,16066,"We get great news!"],[16082,16358,"You can finally divorce Eve!"]],"4":[[8,287,"You can finally divorce Eve!"],[429,604,"Look what I have, Shawn!"],[625,754,"Someone just dropped off"],[754,859,"an invite for you,"],[859,1063,"for the Grand Maple Gala!"],[1222,1326,"Grand Maple Gala?"],[1359,1418,"Now..."],[1418,1647,"you can say bye-bye"],[1647,1751,"to this bitch!"],[2010,2181,"I would like the Grand Maple Gala"],[2185,2394,"to extend a belated invitation"],[2394,2464,"to my husband,"],[2464,2556,"Shawn Rockwell."],[2602,2802,"The Grand Maple Gala?"],[2806,2877,"Wow!"],[2877,3044,"Yes, and you can take Karen!"],[3073,3203,"She is such a sweetheart!"],[3203,3390,"We get our nails done every week."],[3420,3524,"She is so beautiful"],[3524,3724,"with such social graces."],[3770,4079,"She is the perfect fit for my darling son."],[4750,4796,"Karen?"],[4854,4929,"You guys..."],[4929,5013,"You know each other?"],[5142,5255,"Of course they know each other!"],[5296,5392,"Karen's been helping me"],[5392,5530,"for quite a while now."],[5651,5768,"Look, it says right here."],[5843,5918,"Invitation..."],[5968,6160,"from someone who's given her all"],[6177,6227,"for you."],[6227,6377,"There is only one person"],[6377,6448,"that could be."],[6685,6802,"Yes!"],[6844,6977,"Of course!"],[7057,7140,"I just..."],[7198,7407,"wanted to keep it a surprise."],[7436,7469,"But..."],[7582,7611,"But..."],[7653,7899,"I guess the jig is up."],[7903,8062,"You are so thoughtful!"],[8124,8270,"She didn't invite you to that gala."],[8533,8583,"I did."],[9205,9363,"Are you psychotic?"],[9396,9480,"You..."],[9480,9768,"are a stupid dumb little housewife."],[9797,9868,"Okay?"],[9893,9951,"You have no idea"],[9951,10055,"what you've been talking about."],[10068,10256,"No idea about some prestigious,"],[10297,10497,"high-society gala like this!"],[10497,10731,"So, just please shut up!"],[10777,10873,"Shawn Rockwell!"],[10956,11061,"You asked me to give up"],[11061,11136,"on my career"],[11136,11294,"so that I could raise a family."],[11348,11498,"For me, do you have any idea"],[11498,11636,"what I had going on for me,"],[11636,11745,"during ROGUE magazine,"],[11745,11803,"during that time?"],[11803,11891,"Do you have any idea..."],[12016,12120,"ROGUE magazine?"],[12141,12208,"As if!"],[12299,12445,"Only a stupid whore like you"],[12445,12520,"would make up such a"],[12550,12608,"fanciful"],[12629,12729,"Cinderella story!"],[12783,12925,"You know why my son married you?"],[12979,13104,"He'd have a free housewife,"],[13117,13221,"and a house-whore!"],[13475,13621,"You don't deserve to be part of"],[13626,13742,"the Rockwell family,"],[13784,13847,"anymore!"],[14339,14435,"Excellent point, mother!"],[14814,14927,"A divorce paper."],[14927,15027,"Right here, okay?"],[15144,15223,"Well, you just sign it."],[15294,15340,"And we're done right now."],[15903,15990,"You want a divorce?"]],"5":[[62,166,"You want a divorce?"],[454,533,"And what about Lily?"],[642,713,"Mom?"],[713,754,"Dad?"],[896,1076,"Are you guys getting a divorce?"],[1121,1288,"Lily, sweetheart!"],[1288,1447,"Oh my God, you're all I have left..."],[1801,1901,"Good riddance!"],[2085,2239,"You finally divorced Mom!"],[2239,2298,"I did it!"],[2406,2464,"Proud of you!"],[2569,2727,"Mom, I'm staying with Dad."],[2811,2886,"Sweetheart..."],[2927,3065,"I gave birth to you!"],[3065,3290,"I...I've given you breakfast, lunch and dinner"],[3290,3336,"and dinner."],[3336,3436,"And when you were sick,"],[3436,3507,"who took care of you?"],[3507,3603,"I took care of you!"],[3691,3874,"You're gonna leave me for your dad?"],[3974,4054,"What?"],[4054,4220,"No one asked you to do that."],[4308,4537,"You're just Dad's live-in slut."],[4600,4708,"All my friends at school,"],[4708,4804,"their moms are like"],[4842,5071,"models, and CEOs, and celebrities."],[5071,5100,"And..."],[5117,5342,"you just clean up juice spills all day."],[5384,5555,"I want someone who is stylish,"],[5555,5638,"and beautiful,"],[5638,5784,"like Karen, to be my mother."],[5834,6014,"Not some old hag like you,"],[6014,6164,"who reeks of cooking grease."],[6535,6577,"Lily..."],[6656,6827,"you...you don't really mean that."],[7082,7257,"How... how could you..."],[7328,7482,"hurt your mother like that?"],[7603,7803,"Mom, you're such a drag,"],[7803,7874,"you know?"],[7907,8058,"And stop being so naive."],[8108,8208,"I don't even mention you"],[8208,8258,"at school,"],[8258,8345,"because I'm so"],[8345,8450,"ashamed of you."],[8558,8654,"A poor bitch like you"],[8654,8737,"doesn't deserve to be"],[8737,8817,"anyone's mother."],[8883,8971,"Go back to the kennel"],[8971,9059,"where you belong!"],[9092,9117,"Shoo!"]],"6":[[104,154,"Ah!"],[746,821,"You see that?"],[971,1192,"That's your own flesh and blood,"],[1192,1418,"your own daughter saying that to you."],[1443,1676,"I, I guess you're just as much of a failure"],[1714,2002,"as a mother, as you are a wife."],[2615,2669,"Oops!"],[2827,3107,"Oh, my poor Lily,"],[3144,3374,"if you want me to be your new mom,"],[3374,3511,"I...I can do that."],[3703,3816,"I love you, mommy."],[3866,4024,"Just the perfect happy ending!"],[4237,4358,"There's still hope in the world."],[4546,4654,"Just how it's supposed to be."],[5117,5217,"No, this...this..."],[5313,5438,"This can't be, I mean..."],[5497,5693,"after all that I have given up"],[5693,5768,"for you guys."],[6035,6126,"I want a divorce."],[6235,6281,"Yeah..."],[6343,6414,"Yeah, definitely."],[6452,6510,"I'd love that."],[6569,6610,"Wait!"],[6660,6894,"You can divorce Shawn, but.."],[7011,7152,"you're not getting a single cent."],[7549,7649,"So smart, baby!"],[7649,7761,"I love the way you think!"],[7799,8020,"I...built this family"],[8020,8170,"brick by brick!"],[8254,8395,"You wouldn't even have a house,"],[8395,8487,"if it wasn't for me."],[8512,8662,"Shut up!"],[8696,8812,"Oh my gosh..."],[8846,8975,"I'm with Karen on this one."],[9042,9117,"You don't get"],[9159,9246,"a single"],[9309,9467,"little scent!"],[9542,9642,"In fact,"],[9701,9813,"we'll see how well you do"],[9813,9989,"as a divorced,"],[10035,10155,"stupid housewife,"],[10214,10289,"with no money,"],[10347,10493,"and no skills."],[10694,10794,"You know what, Miss Bradley?"],[11015,11098,"I should thank you."]],"7":[[8,108,"I should thank you."],[154,237,"Miss Bradley."],[387,433,"Thank you."],[525,625,"For showing me,"],[625,767,"who my husband really is."],[921,1121,"A lying, no-good"],[1172,1222,"cheat,"],[1284,1447,"who would rather have his head"],[1447,1568,"in someone's skirt,"],[1601,1739,"than having a conversation"],[1739,1901,"with me and telling me the truth."],[2056,2118,"Trash..."],[2206,2252,"like him,"],[2356,2565,"deserves to be with buzzing houseflies"],[2565,2615,"like you."],[2744,2819,"Have a nice life."],[2877,2911,"How..."],[2977,3119,"dare you insult me?"],[3119,3165,"You"],[3165,3232,"bitch!"],[3691,3820,"You slut!"],[3820,4029,"Don't you call my son things like that!"]],"8":[[2306,2352,"Eve..."],[2423,2469,"Eve!"],[2540,2610,"Who is that..."],[2635,2731,"who's that guy, huh?"],[2915,2961,"No, no..."],[3069,3161,"Tell me who he is!"],[3311,3365,"Loser!"],[3470,3545,"Think you're forgetting"],[3545,3595,"something."],[3678,3762,"Our wedding ring."],[3795,3849,"Oh, yeah!"],[3849,3928,"The ring, that's right!"],[4041,4287,"I paid $500,000"],[4287,4446,"to that ring, so give it back!"],[4921,4959,"Yeah!"],[5405,5438,"No!"],[5634,5668,"Damn!"],[5668,5718,"Look for it here!"],[5759,5851,"I need it!"],[5855,5914,"It's the last..."],[5980,6031,"Idiot!"],[6235,6289,"Where is it?"],[6927,7019,"Like I said..."],[7228,7290,"Trash."],[7640,7711,"Stupid!"],[7862,8012,"Give it right back at you!"]],"9":[[596,746,"Get out of here, you dumb hoe!"],[746,800,"Son of a..."],[871,950,"This isn't over!"],[1051,1105,"Shawn!"],[1151,1197,"Who..."],[1226,1313,"is that?"],[1322,1526,"His car is fancier than yours!"],[1526,1601,"Hey, shut up!"],[1601,1668,"It's not!"],[2298,2352,"Get us a drink?"],[2398,2431,"Yeah."],[2740,2886,"I guess I thought that if I just"],[2886,3011,"gave them all the love,"],[3011,3090,"you know,"],[3199,3340,"they would give the same thing back."],[3407,3499,"Instead, they just..."],[3611,3741,"left me on the streets."],[4016,4108,"That's their fault, Eve."],[4170,4245,"Not yours."],[4312,4408,"And it's their loss."],[4554,4688,"It's time to stop giving all your time"],[4688,4788,"and attention to them."],[4879,4946,"There are things that are"],[4946,5021,"so much more important and..."],[5188,5234,"people,"],[5334,5409,"that are more important."],[6193,6318,"Looking for media attention?"],[6427,6468,"Come on!"],[6523,6656,"You must be the richest guy"],[6656,6802,"on the side of the Atlantic."],[7098,7190,"I'm old news."],[8341,8400,"What's this?"],[8704,8821,"It's a unique piece."],[8975,9125,"Where did you get this idea anyway?"],[9205,9305,"You gave me that rose."],[9517,9576,"You don't remember?"],[9759,9838,"16 years ago..."],[9922,9972,"A favor"],[10035,10105,"for a knight."],[10151,10226,"Grand Maple Gala..."],[10243,10377,"It suits you well, Giovanni."],[10706,10739,"I'm..."],[10785,10860,"So brought it home..."],[10985,11161,"I kept it for all these years, because..."],[11202,11290,"every time I look at it..."],[11524,11582,"reminds me of you."],[11682,11778,"Well, Giovanni,"],[11807,11878,"you know you've..."],[11895,12074,"become a really sweet talker."],[12145,12212,"Not really."],[12312,12379,"I just realized,"],[12495,12629,"some things just need to be said."],[12725,12837,"I think you should know about it."],[13038,13113,"I think I'm gonna..."],[13196,13250,"freshen up,"],[13279,13350,"take a shower."],[13638,13697,"You don't mind, right?"],[13788,13838,"No."],[13868,13913,"Please."],[14902,15098,"I need to take your measurements."],[15190,15244,"Okay."],[15311,15419,"I just got off the phone with"],[15419,15528,"Alex Constantia."],[15594,15678,"He's a very prominent"],[15678,15824,"new designer in the industry."],[15878,16053,"He happens to have a dress,"],[16061,16161,"beautiful evening gown."],[16178,16291,"Said he could have it fitted"],[16291,16458,"and delivered by next week."],[16783,16937,"Right in time for the Grand Maple Gala."],[17288,17342,"Wow..."],[17471,17559,"That's perfect,"],[17559,17638,"because I'm..."],[17684,17859,"ready to come back as ROGUE's"],[17859,17959,"new editor-in-chief."],[18376,18435,"You'll really do it?"],[18514,18568,"You'll come back?"],[18643,18706,"Yeah."],[18706,18847,"I'm gonna side with you this time."],[18952,19089,"I mean it's time for me to show them"],[19089,19306,"that I'm not some poor, subservient"],[19306,19373,"housewife."],[19540,19686,"It's time for Queen Corbelle"],[19686,19886,"to take back her empire."]],"10":[[371,408,"Shawn,"],[492,554,"they said,"],[567,688,"the Queen of the Red Carpet"],[688,800,"is gonna be here tonight."],[934,1051,"She is been out of the public eye"],[1051,1138,"for years."],[1247,1351,"If I can get my hands on her,"],[1380,1526,"my company will be set for life!"],[1539,1584,"Karen!"],[1584,1730,"If you can get an invite here,"],[1826,1914,"you can do anything."],[2010,2102,"I'm sure she's already heard"],[2102,2198,"all about you."],[2360,2419,"Yeah!"],[2444,2627,"I...I bet she does!"],[2665,2711,"Yeah."],[2907,2998,"I'm gonna need your help though."],[3057,3107,"Okay?"],[3169,3361,"You're the head of Rockwell Intimates."],[3403,3503,"It's up and coming."],[3516,3611,"I'm sure even"],[3649,3774,"the Queen of the Red Carpet"],[3774,3924,"would love to talk to you!"],[3953,4049,"Excuse me,"],[4079,4191,"Shawn Rockwell?"],[4191,4233,"Yeah!"],[4262,4416,"Rockwell intimates?"],[4579,4713,"You look stunning."],[4713,4804,"And my compliments"],[4804,4896,"to the lady as well."],[4921,5046,"Wait, you...you know my name?"],[5092,5201,"Of course!"],[5201,5313,"It caused quite a stir,"],[5313,5397,"when they added your name"],[5397,5455,"to the guest list,"],[5455,5676,"after everyone else already RSVP'd."],[5764,5830,"I heard..."],[5876,6006,"it was Giovanni Cavolini,"],[6006,6164,"head of LVWH himself"],[6164,6285,"who added you to the list."],[6356,6468,"You must be quite the favorite."],[6639,6781,"How did you manage this?"],[6931,6994,"Don't tell me..."],[7073,7194,"You're the one who arranged"],[7194,7357,"for Mr. Rockwell's invite?"],[7469,7582,"Beg your pardon, miss."],[7595,7728,"May I please have the pleasure"],[7728,7832,"of an introduction?"],[7949,8078,"Karen Bradley."],[8133,8320,"You probably don't know me."],[8375,8679,"I keep a very low profile."],[8721,9046,"But, I'm also very close with Giovanni,"],[9046,9205,"so, if you need anything..."],[9501,9630,"Yes, I'm gonna tell you soon..."],[9984,10122,"That's Giovanni's car!"],[10548,10819,"Oh, and those, those sunglasses..."],[10819,10856,"Ah!"],[10923,11086,"She must be Queen Corbelle!"],[11119,11227,"She's the founder"],[11227,11386,"of the Grand Maple Gala."],[11407,11486,"That must be her!"],[11549,11728,"That's ROGUE's new editor-in-chief?"],[11790,11849,"Finally..."],[11903,12041,"I've been waiting to catch"],[12041,12224,"a glimpse of her for so long!"],[12308,12462,"She is gorgeous!"],[12525,12566,"It appears"],[12566,12675,"the Queen of the Red Carpet"],[12675,12833,"has made her triumphant return."],[12850,12967,"Long live Queen Corbelle!"],[13254,13300,"Wait a minute."],[13321,13446,"You're wearing the same dress"],[13446,13546,"as Queen Corbelle!"],[13588,13655,"Couldn't believe you tryna"],[13655,13722,"upstage her?"],[13722,13755,"I'm sorry,"],[13755,13834,"what is your name again?"],[14022,14089,"Queen Corbelle!"],[14097,14326,"I...I'm so sorry."],[14326,14397,"I'm new."],[14422,14552,"I had no idea"],[14552,14698,"you'd be wearing this dress today."],[14798,14952,"If it's okay, I can go and change,"],[14952,15002,"right now."],[15398,15565,"Karen Bradley..."],[15623,15799,"What a joy to hear you"],[15836,15970,"beg for forgiveness."],[16270,16324,"Eve?"]],"11":[[25,83,"What?"],[333,400,"Eve!"],[483,746,"You had me fooled there for a second."],[850,900,"Now tell me,"],[921,1063,"whose bed did you crawl into"],[1063,1159,"to get an invite"],[1159,1297,"to the Grand Maple Gala?"],[1405,1601,"And how dare you show up"],[1601,1697,"to a fashion gala,"],[1697,1897,"in a fake of my bespoke dress?"],[1976,2027,"What?"],[2052,2093,"Karen,"],[2093,2231,"Giovanni's friend said that"],[2231,2302,"this woman is"],[2302,2431,"wearing a fake dress!"],[2464,2577,"Maybe that wasn