."],[9630,9693,"I gotta run."]],"20":[[4,125,"Do you really think that"],[125,354,"she's the Queen of the Red Carpet?"],[371,400,"I mean"],[400,608,"Mike is notorious for only taking her"],[608,700,"direct orders."],[700,838,"No way."],[938,1088,"How would she even know"],[1088,1201,"Mike Bernard?"],[1242,1305,"She's"],[1305,1459,"a no-name housewife,"],[1459,1559,"and um..."],[1559,1672,"she's obviously just"],[1672,1881,"trying to get more time in the spotlight."],[1881,1985,"Okay, okay, look,"],[1985,2064,"Mike"],[2122,2289,"is a very common name."],[2364,2477,"So there's no way"],[2477,2590,"she's working with Mike Bernard."],[2852,2911,"Why not?"],[3015,3107,"Because"],[3107,3228,"Mike Bernard"],[3228,3486,"is Queen Corbelle's direct underling."],[3486,3611,"He takes orders from her."],[3670,3812,"He's her editor in chief"],[3812,3916,"of ROGUE magazine."],[3958,4070,"He listens to her."],[4070,4133,"That's it."],[4183,4287,"He'll listen to me."],[4412,4487,"You'll see."],[4487,4671,"Yeah, talk that big talk"],[4671,4763,"while he's not here."],[5046,5150,"You guys will find out"],[5184,5255,"soon enough."],[5689,5747,"There."],[5747,5868,"This is my personal missive"],[5868,5985,"from the Queen herself."],[6039,6139,"I need to make sure it goes off"],[6139,6247,"without a hitch."],[6331,6527,"Tell the reporters to roll the cameras."],[6560,6623,"Yes, sir."]],"21":[[809,905,"It's Mike Bernard."],[905,975,"It's really him."],[1101,1201,"Oh my God,"],[1226,1292,"I guess Eve was"],[1292,1426,"really telling the truth all along."],[1668,1714,"Wait,"],[1747,1931,"is she actually Queen Corbelle?"],[1981,2139,"On behalf of Queen Corbelle,"],[2139,2323,"I'm looking for a Shawn Rockwell?"],[2489,2565,"That's..."],[2627,2702,"that's me."],[3040,3169,"Pleasure to meet you, Shawn."],[3324,3432,"I'm Mike Bernard."],[3520,3611,"I work under our dear"],[3611,3707,"Queen Corbelle."],[3795,3891,"And I can see"],[3891,4041,"why she's got her eye on you."],[4195,4250,"Really?"],[