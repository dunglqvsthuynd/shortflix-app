Karen,"],[4729,4971,"I'm just trying to give a speech."],[5000,5171,"You're my ex husband's mistress."],[5171,5242,"I think that"],[5242,5363,"you pretty much have the market"],[5363,5476,"cornered on things"],[5476,5580,"to be ashamed of."],[5580,5647,"Shut up!"],[5647,5768,"You stupid stupid woman!"],[5943,6031,"I was married to you"],[6051,6147,"for sixteen"],[6147,6256,"God awful years!"],[6277,6393,"And I know that you"],[6393,6573,"would never be invited"],[6573,6790,"to an amazing place like this!"],[6961,7002,"Come on,"],[7002,7169,"get lost before the Dean shows up!"],[7203,7361,"Don't make me get security!"],[7607,7728,"Actually, that's a great idea."],[7728,7816,"Why don't we just..."],[7853,7932,"get security"],[7932,8091,"and we'll see who they side with."],[8746,8879,"Eve should be here by now."],[8879,9017,"I should go check on things."]],"49":[[20,79,"Stop it, Eve."],[175,258,"Are you really gonna wait until"],[258,350,"Dean Marlett comes and"],[350,412,"throws you out?"],[492,538,"Hmm?"],[567,613,"Get out!"],[638,675,"Really,"],[734,784,"you're still gonna"],[784,875,"believe these little lies"],[875,971,"that Karen's been telling you?"],[1017,1092,"I mean, even now..."],[1213,1343,"Shut up, Eve!"],[1526,1743,"The Dean is gonna be so upset"],[1743,1793,"with you!"],[1810,2127,"Oh my God, I'm wasting my breath,"],[2127,2198,"aren't I?"],[2198,2243,"What?"],[2277,2410,"Do you wanna hear it from her?"],[2627,2773,"You're too...funny, Eve."],[2819,3040,"Lily, why don't you tell us..."],[3090,3215,"do you think..."],[3261,3661,"that your stupid ugly useless mom,"],[3699,3878,"is the real Queen Corbelle?"],[3966,4004,"Ugh!"],[4066,4216,"Stop calling her my mom!"],[4262,4379,"And no way!"],[4379,4491,"She is an old hag."],[4696,4813,"What fuck?"],[4871,4938,"Hear that, Eve?"],[5096,5267,"Even your own daughter"],[5267,5430,"doesn't believe you could be the real"],[5430,5518,"Queen Corbelle."],[5538,5593,"It's a pity."],[5718,5897,"I guess she got her father's intelligence."],[6093,6151,"You..."],[6214,6431,"stupid...stupid woman."],[6556,6610,"Security!"],[6627,6694,"Where is security?"],[6723,6798,"Come up here, come up here!"],[6852,6911,"What are you waiting for?"],[6911,6956,"You big oaf!"],[6956,7065,"Get up here and take her out of here!"],[7065,7136,"She is terrible!"],[7361,7415,"Stop!"],[7624,7741,"No one lays a hand"],[7741,7882,"on my special guest."],[8070,8183,"Special guest?"]],"50":[[20,83,"So..."],[104,200,"she is..."],[200,321,"she is really the s..."],[346,487,"special guest?"],[871,955,"My dear,"],[971,1076,"it's been too long. -I'm not buying it."],[1076,1138,"No way!"],[1155,1309,"So happy to have you back"],[1309,1393,"at your alma mater."],[1685,1868,"I should have had tighter security."],[1868,2135,"I can't believe they treated you like this."],[2143,2335,"Don't say that, Dean Marlett."],[2364,2577,"And it's an honor to be back here again."],[2752,2919,"I think I owe everyone an"],[2919,3015,"explanation."],[3098,3278,"This is Eve Corbelle,"],[3311,3465,"an outstanding alumnus of"],[3465,3624,"Avenir Art School,"],[3699,3766,"and..."],[3845,3991,"the Queen of the Red Carpet."],[4441,4767,"What did you do this time, Eve, huh?"],[4804,4921,"How much you pay"],[4967,5100,"off the Dean to do all this?"],[5100,5159,"Huh, you're a..."],[5180,5292,"special friend."],[5313,5455,"Mr. Rockwell,"],[5538,5618,"I've been the Dean of"],[5618,5839,"the Avenue Art School for 30 years."],[5864,6006,"I can vouch for Eve,"],[6126,6285,"as well as my wonderful,"],[6285,6406,"outstanding students."],[6723,7027,"No...so...so you're saying ...that"],[7027,7161,"that bitch..."],[7261,7328,"I mean,"],[7357,7457,"that woman,"],[7578,7782,"Eve is Queen Corbelle?"],[7870,7962,"Of course."],[8074,8320,"She is the Queen of the Red Carpet."],[9238,9313,"You!"],[9334,9409,"Me?"],[9409,9476,"Right!"],[9476,9563,"You..."],[9567,9647,"You snake..."],[9751,9859,"Ah! -suck woman!"],[10168,10256,"I could have been the husband of"],[10256,10381,"the Queen of the Red Carpet!"],[10502,10560,"I'm..."],[10614,10673,"I'm..."],[10673,10798,"the one and only daughter,"],[10827,10919,"of Queen Corbelle!"]],"51":[[104,196,"Mom."],[596,717,"I thought you said you didn't want me"],[717,809,"to be your mom."],[867,917,"Please..."],[938,1059,"I mean actually, you..."],[1059,1259,"you guys are a perfect family."],[1505,1722,"I want someone who is beautiful and"],[1722,1885,"stylish like Karen,"],[1918,2010,"to be my mom."],[2039,2235,"Not some old hag like you"],[2235,2389,"who smells like cooking grease!"],[2456,2694,"Please...I don't wanna leave you!"],[2715,2815,"I love you!"],[2827,2944,"Don't leave me!"],[2969,3148,"You are a picture of your father!"],[3374,3541,"You stopped being my daughter,"],[3541,3661,"the day you kicked me out of"],[3661,3724,"the house!"],[3903,3966,"Eve..."],[4004,4104,"I never wanted you to leave,"],[4104,4200,"and none of this was..."],[4270,4329,"was my idea."],[4329,4404,"It was her!"],[4408,4466,"What?"],[4466,4587,"I never wanted you to go..."],[4817,5075,"No, he...it isn't..."],[5096,5246,"He hated you..."],[5255,5522,"He called you old and ugly..."],[5543,5638,"I didn't say that!"],[5638,5739,"Please don't, don't be mad."],[5747,5872,"I didn't, I didn't say that!"],[5893,5964,"He said that!"],[6089,6193,"I will do anything!"],[6231,6398,"Please, please, please!"],[6448,6544,"Sorry about that..."],[6581,6639,"Dean Marlett,"],[6639,6769,"I think that they've overstayed"],[6769,6819,"their welcome."],[6827,6902,"Yes, absolutely."],[6902,6965,"Sorry."],[6965,7023,"Security!"],[7023,7086,"Security, out."],[7165,7232,"I'm the stu... Not overstay."],[7232,7298,"We'll be calm."],[7307,7382,"Out instantly and..."],[7503,7549,"Hey!"],[7549,7620,"Hey..."],[7657,7795,"This is my bad arm!"],[7853,7924,"I'm sorry, darling."],[8028,8162,"Eve, don't let me out here..."],[8179,8241,"We will work those out..."],[8583,8696,"So sorry about that."]],"52":[[846,913,"Eve!"],[971,1038,"A little gift."],[1297,1413,"For finally putting the past"],[1413,1459,"behind you."],[1539,1589,"Thank you."],[1772,1839,"To the future."],[2585,2665,"Have you..."],[2765,2844,"thought about your future?"],[3040,3111,"Because I'm thinking..."],[3303,3365,"maybe we could..."],[3470,3699,"My plan is to make ROGUE magazine"],[3699,3828,"bigger and better than ever."],[3895,4058,"I wanna expand the empire,"],[4137,4287,"and in order to do that..."],[4287,4441,"I...I will need you both."],[4838,4913,"I mean, after all..."],[5067,5134,"ROGUE..."],[5372,5497,"wouldn't be the same,"],[5497,5593,"without you both."],[5918,6039,"Happy to do anything for you,"],[6039,6076,"Eve."],[6356,6414,"It's always a pleasure"],[6414,6527,"to serve you, Queen."]],"53":[[1080,1155,"Fashion"],[1259,1351,"is for everyone."],[1397,1455,"Yes!"],[1476,1601,"In the span of a year,"],[1601,1714,"Queen Corbelle proved..."],[1751,1943,"just what she was capable of."],[1968,2235,"ROGUE stocks are at an all time high."],[2252,2356,"And they've secured"],[2385,2489,"their footing in the European"],[2489,2648,"and Asian market... -Turn that shit off,"],[2648,2819,"Shawn, and get a job!"],[2873,3107,"Your company is long gone!"],[3107,3157,"And you..."],[3186,3353,"need to start supporting us!"],[3382,3578,"We can't live off of Lily's money"],[3578,3632,"forever!"],[3632,3849,"You useless piece of shit!"],[3849,3933,"Shut up, hole!"],[4041,4124,"Wasn't it for you, I..."],[4200,4366,"I'd still be married to her!"],[4437,4604,"Living off the fat of the land,"],[4604,4721,"making pennies!"],[4763,4921,"God, what have I done..."],[4925,5059,"Shut up!"],[5071,5167,"Ah...the humanity..."],[5246,5426,"Go away, both of you..."],[5426,5576,"before I make you."],[5759,5814,"Fucking..."],[5893,6081,"If only I hadn't done that back then..."],[6131,6360,"maybe we'd still be a happy family now."]]}