{"1":[[254,367,"Where are you?"],[383,588,"Desmond, I've been waiting"],[588,729,"for fifteen minutes already."],[892,1088,"I mean, you probably can't be too far."],[1305,1434,"You've reached Desmond Belmont."],[1434,1530,"Leave a message."],[1530,1668,"Desmond, hey!"],[1710,1868,"Uh, I got the pizza."],[1964,2056,"It's pouring now."],[2056,2143,"Where are you?"],[2560,2648,"Okay, nevermind,"],[2648,2715,"I'll call you back."],[2715,2794,"I see you."],[4959,5050,"Desmond?"]],"2":[[233,433,"I suspected he was having an affair."],[487,692,"The last minute business trips."],[725,850,"The late nights."],[913,1117,"The smell of a stranger's perfume"],[1117,1222,"clinging to his shirt"],[1222,1434,"when he thought I wouldn't notice."],[1505,1680,"His mom warned me he would cheat."],[1697,1901,"Men never stay faithful, she said."],[1981,2168,"But I didn't want to believe her."],[2460,2602,"It was on a rainy night,"],[2602,2736,"just like this one,"],[2761,3007,"when Desmond promised me forever."],[3007,3098,"Desmond, hey,"],[3098,3182,"hey, where are you?"],[3182,3228,"Um."],[3294,3382,"There's this creep"],[3382,3557,"following me, I'm really scared."],[3787,3853,"Okay."],[3937,4029,"Come on, baby."],[4079,4191,"Don't run from me."],[4204,4337,"I'll show you a good time."],[4354,4491,"Don't touch me!"],[4583,4662,"No!"],[4662,4817,"Get your hands off my girl!"],[6931,7040,"Fucking psycho!"],[7357,7424,"Are you okay?"],[7436,7511,"Are you okay?"],[7524,7615,"I'm fine, your hand,"],[7615,7661,"you're bleed-"],[7682,7745,"you're bleeding."],[7745,7799,"I'm fine,"],[7799,7912,"it's just a scratch."],[7928,8008,"I'm sorry."],[8191,8299,"I should have come sooner."],[8324,8387,"But from now on,"],[8387,8562,"I promise I will always show up."],[8579,8683,"I will protect you,"],[8733,8800,"forever."],[9234,9346,"But forever..."],[9538,9626,"was a lie."],[10055,10272,"How did we let this happen, Desmond?"],[10314,10431,"Once upon a time,"],[10452,10623,"you'd risk your life for me."],[10694,10885,"Now you won't even pick up my call."],[11040,11177,"Funny how love dies,"],[11211,11298,"quietly,"],[11344,11482,"on a night just like this."],[11553,11682,"His mom was right."],[11957,12137,"We were never meant to last."],[12946,13000,"Beatrice,"],[13000,13133,"I'm surprised you're calling."],[13296,13413,"I'm ready to talk."],[13763,14001,"Madam, Ms. Lawson has arrived."],[14014,14109,"Send her in."],[14664,14906,"Beatrice, you look like a wet dog."],[14952,15081,"But that's not surprising,"],[15081,15231,"given your background."],[15248,15361,"Which of these do you think"],[15361,15569,"would be nice for Miss Fairfax?"],[15578,15824,"She's marrying Desmond, after all."],[15824,15982,"Why in the world he chose"],[15982,16174,"to marry someone like you"],[16174,16291,"is beyond me."],[16299,16566,"She's much more a lady of class."],[16587,16725,"Sleeping with a married man,"],[16725,16845,"very classy."],[16845,16996,"Don't you get sarcastic"],[16996,17108,"with me, Beatrice."],[17150,17354,"I encouraged him to stay silent"],[17354,17442,"about the marriage."],[17450,17646,"The Fairfax family would be ashamed"],[17646,17788,"if they knew he was married to someone"],[17788,18051,"with your lowly background."],[18172,18418,"So, you will get a divorce"],[18418,18493,"from Desmond."],[18505,18743,"You will stay quiet about the marriage."],[18772,18956,"And then, I don't want to see you"],[18956,19173,"around Desmond anymore."],[19223,19310,"Understood?"],[19386,19456,"Yes."],[19682,19878,"But I want fifty million dollars."]],"3":[[4,125,"Excuse me?"],[175,333,"Are you trying to rob me?"],[333,533,"Please, fifty million million is nothing"],[533,633,"once Desmond marries"],[633,796,"the Fairfax heiress."],[817,971,"But that will only happen"],[971,1226,"if I divorce him and stay silent."],[1255,1334,"That's what you want."],[1418,1468,"Right?"],[1580,1639,"Fine."],[1680,1876,"You get the divorce agreement."],[1885,2014,"And I'll get you your money."],[2068,2252,"Fifty million exactly,"],[2277,2369,"or the deal's off."],[2907,3086,"We've been married for ten years,"],[3190,3299,"but no one knows."],[3399,3532,"I'm gonna go talk to Mr. Belmont."],[3561,3661,"Yeah, bye."],[3782,3887,"I'm your wife,"],[3920,4041,"but you hide me"],[4041,4325,"like I'm just some dirty, secret lover."],[4400,4542,"But once we're divorced,"],[4596,4725,"you won't have to be embarrassed"],[4725,4821,"by me anymore."],[5751,5830,"How was your trip?"],[5972,6022,"Fine."],[7119,7169,"I, uh,"],[7265,7428,"I just need you to sign these reports."],[7428,7515,"They're due tomorrow."],[8888,9009,"Are you gonna be home for dinner?"],[9075,9121,"No,"],[9121,9200,"I'll probably be late,"],[9200,9334,"so just eat without me."],[9918,9955,"You know,"],[9955,10097,"sometimes I don't even think"],[10097,10352,"you're trying to hide your mistress."],[10377,10514,"The way you so openly"],[10514,10664,"let her leave her things around."],[10694,10785,"I'm your wife,"],[10802,10994,"yet I'm the one you chose"],[10994,11102,"to keep secret."],[11415,11519,"Goodbye, Desmond."],[11578,11628,"Mhm."],[11628,11669,"See ya."],[12341,12412,"But now,"],[12479,12537,"you won't have to"],[12537,12683,"keep me a secret anymore."],[13284,13388,"Do you have news for me?"],[13772,13842,"He signed."]],"4":[[4,91,"Really?"],[91,200,"Just like that?"],[250,437,"I guess he doesn't love you anymore."],[875,950,"This is it."],[1030,1151,"My ticket to freedom."],[1217,1338,"I'm finally moving on."],[2027,2110,"I brought you a gift."],[2381,2510,"It's one-of-a-kind."],[2535,2619,"I even hand-picked"],[2619,2740,"the diamonds myself."],[2894,2973,"I don't need any more"],[2973,3073,"expensive jewelry."],[3115,3199,"Maybe you should give that"],[3199,3307,"to Madeline Fairfax."],[3307,3403,"She'd enjoy it."],[3403,3541,"Why would I give the gift to her?"],[3603,3716,"I just think the Fairfax family"],[3716,3874,"would like an expensive gift"],[3874,3958,"like that one."],[4008,4108,"What's this all about?"],[4179,4358,"I don't owe the Fairfax family"],[4358,4433,"any gifts."],[4433,4567,"Yes, Madeline and I are working on"],[4567,4713,"the Z-Star project together."],[4713,4771,"That's it."],[4909,4984,"There's nothing going on"],[4984,5088,"between the two of us."],[5217,5388,"Desmond, if you love someone else,"],[5388,5543,"you can go be with her."],[5647,5768,"We can get a divorce."],[6114,6414,"We are not getting divorced."]],"5":[[20,321,"We are never getting divorced,"],[321,442,"do you understand?"],[467,679,"It's a little too late for that, Desmond."],[734,921,"You already signed the divorce papers."],[1463,1514,"Hello?"],[1576,1626,"Hold on."],[1668,1726,"What's wrong?"],[1810,1889,"Hi, yeah."],[1926,2002,"Just stay put."],[2002,2077,"I'm coming."],[2510,2573,"I'm sorry,"],[2748,2802,"but don't ever"],[2802,2915,"mention divorce again."],[3036,3115,"Get some sleep."],[3282,3453,"Desmond, we're already divorced."],[3536,3649,"You just don't know it yet."],[4175,4237,"OK."],[4300,4379,"You sure you want me"],[4379,4517,"to sell all of these?"],[4521,4629,"Yeah, I don't want them anymore."],[4742,4913,"Then you can just donate the money"],[4913,5021,"to charity or something."],[5184,5296,"Sell this one too, please."],[5451,5718,"This has to be worth at least a million."],[5759,5880,"Is Desmond really okay"],[5880,5972,"with the divorce?"],[6056,6210,"He doesn't know about it."],[6402,6452,"I tricked him"],[6452,6577,"into signing the divorce papers."],[6577,6669,"You what?"],[6669,6752,"Aren't you afraid of"],[6752,6831,"what Desmond will do"],[6831,7019,"when he finds out he already signed?"],[7019,7082,"No, no."],[7082,7123,"With the money"],[7123,7228,"I'm getting from his mom,"],[7228,7403,"I can disappear to anywhere"],[7403,7461,"in the world."],[7461,7716,"I could hire added security protection"],[7716,7862,"if I really wanted to."],[7862,7928,"I'll be fine"],[7928,8066,"and I'm not staying in this marriage"],[8066,8133,"any longer."],[8133,8249,"It doesn't matter what he thinks."],[8287,8412,"Um, I'm gonna go ahead"],[8412,8483,"and I'm gonna take this"],[8483,8562,"to my new apartment."],[8596,8700,"Let me know when you sell the jewelry."],[8712,8762,"I will."],[9180,9275,"Go ahead and sell this one too."],[9438,9580,"I have no use for it anymore."],[11565,11644,"What is she doing?"],[11840,11920,"She just got in her car"],[11920,12012,"with a box of clothes."],[12037,12082,"Follow her."],[12082,12187,"Don't let her out of your sight."]],"6":[[571,663,"What the hell?"],[2110,2348,"Miss, I do apologize."],[2369,2502,"I, I do hope that we can"],[2502,2660,"settle this matter privately."],[2660,2857,"My boss is in a hurry."],[2865,2957,"Privately?"],[3003,3190,"Is he trying to get out of this somehow?"],[3224,3324,"Absolutely not."],[3353,3557,"No, um, I think I'd rather"],[3557,3774,"just wait for the cops to arrive."],[3774,3862,"Are you sure?"],[3891,4079,"I promise we will cover"],[4079,4195,"all the damages."],[4195,4362,"I'd rather do this the proper way"],[4362,4483,"with all the right documentation."],[5630,5847,"Sir, please."],[5872,5997,"It's better to remain in the car"],[5997,6076,"with the rain."],[6076,6214,"I have an important meeting to get to."],[6214,6339,"I can't sit here and wait all day."],[6339,6439,"Killian is already on his way"],[6439,6502,"to give me a ride."],[6502,6589,"What did the girl say?"],[6589,6715,"She'd prefer to go through"],[6715,6819,"the police, sir."],[6819,6869,"Why?"],[6931,7061,"Did you tell her that we'd pay extra?"],[7119,7286,"Why the hell is she being so difficult?"],[7374,7494,"I want you to go over there and tell-"],[8341,8391,"Sir?"],[8616,8671,"Sir?"],[8933,9004,"Go give it to her."],[9100,9250,"Give her the contact info as well."],[9363,9442,"About the car."],[9597,9676,"Miss!"],[9955,10130,"My boss sent this for you."],[10510,10685,"It's okay, I have clothes in my car."],[10706,10935,"You could further damage your head"],[10935,11077,"by moving around too much."],[11077,11219,"Please, take the jacket."],[11248,11302,"Thank you."],[11407,11469,"I'll return it,"],[11469,11532,"I promise."],[11999,12145,"Who is that?"]],"7":[[496,625,"Beatrice was in an accident."],[1380,1472,"Excuse me, sir."],[1472,1572,"This is a private room."],[1572,1614,"It's okay."],[1614,1664,"He's my hu-"],[1805,1876,"boss."],[1876,1972,"He's my boss."],[2035,2143,"Is her injury serious?"],[2143,2235,"She'll be okay."],[2256,2327,"Just make sure"],[2327,2452,"she doesn't get this bandage wet."],[3803,3924,"Let me make you some soup."],[3974,4029,"Thanks."],[4483,4592,"Who's jacket is that?"],[4971,5025,"No one's."],[5100,5213,"And why were you wearing it?"],[5401,5492,"Okay, fine."],[5518,5638,"Desmond, it's a friend's."],[5684,5818,"Am I not allowed to have friends?"]],"8":[[279,337,"I'm sorry."],[337,396,"Hey,"],[421,638,"it just hurts hearing you"],[638,775,"say things like that."],[804,905,"I'm your husband."],[963,1076,"I care, that's all."],[1117,1309,"Yeah, you say you care about me."],[1309,1459,"But you're having an affair"],[1484,1576,"with Madeline."],[1601,1751,"What happened to your phone earlier?"],[1805,1885,"I couldn't reach it."],[1914,2060,"I probably shouldn't let him know"],[2060,2164,"I blocked his number."],[2189,2439,"Yeah, the battery died."],[2464,2515,"That's all."],[2715,2740,"You know,"],[2740,2877,"if my call would have went through,"],[2898,2998,"I would have known that"],[2998,3123,"you were in an accident."],[3161,3278,"I don't like being left"],[3278,3440,"in the dark, Beatrice,"],[3503,3616,"especially when it comes"],[3616,3687,"to your safety."],[3770,3983,"I noticed all your clothes and jewelry"],[3983,4054,"were missing."],[4087,4337,"Closet, vanity, fully empty."],[4366,4458,"Since when did he start"],[4458,4612,"noticing things like that?"],[4625,4842,"I took the clothes to the cleaner"],[4871,5009,"and jewelry to get detailed."],[5042,5121,"All of them?"],[5146,5242,"At the same time?"],[5355,5451,"I want to resign."],[5584,5643,"Resign?"],[5730,5918,"Yeah, yeah, I think it'd be good for me."],[5926,6164,"You know, have some time off, relax,"],[6164,6297,"maybe travel a little bit."],[6364,6464,"You know, that's actually"],[6464,6569,"not a bad idea."],[6698,6898,"It is time that we start"],[6898,7040,"having children anyway."],[7148,7336,"He thinks I'd want to have his children."],[7474,7570,"Once upon a time,"],[7570,7732,"that's all I ever wanted."],[7791,7891,"Not anymore."],[8479,8625,"I want you to put a baby in me."],[9129,9225,"Not right now."],[9280,9367,"Work's busy."],[9396,9476,"Maybe next year."],[11594,11695,"You get some sleep."],[11695,11786,"You had a long day."],[11886,11974,"And tomorrow,"],[12016,12166,"we can finalize your resignation."]],"9":[[867,934,"Please send me"],[934,1076,"your boss's suit measurements."],[1835,1968,"Oh, wow!"],[2014,2310,"Beatrice, this is really nice."],[2310,2373,"Thanks."],[2398,2573,"Yeah, it just feels so good"],[2581,2694,"having a place of my own."],[2694,2790,"Now I can leave"],[2815,2894,"for good."],[3023,3194,"Would you mind, please,"],[3215,3319,"unpacking this box"],[3319,3411,"while I grab the rest of the stuff"],[3411,3536,"from my office, please?"],[3561,3641,"Of course."],[3649,3699,"Go."],[3699,3807,"Thank you, you're the best."],[4525,4696,"May I ask what you require"],[4696,4813,"his measurements for?"],[4900,4971,"Why can't he just"],[4971,5067,"send the measurements"],[5067,5209,"and not ask so many questions?"],[5267,5342,"What floor?"]],"10":[[871,967,"The lobby, I assume."],[1105,1159,"Yeah."],[1255,1309,"Thanks."],[1768,1868,"Are you really stalking me"],[1868,2014,"to get my suit measurements?"],[2064,2139,"No."],[2152,2306,"No, no, I, I actually,"],[2306,2423,"I just moved in upstairs."],[2448,2681,"I'm sorry if it's weird that I asked."],[2681,2740,"Um,"],[2740,2919,"I just, I, I need your measurements"],[2936,3324,"to replace your suit jacket."],[3357,3415,"Sure."],[3528,3645,"She must be into me."],[3753,3845,"If you want my measurements"],[3845,3887,"so bad,"],[3887,3995,"I'll just have my assistant"],[3995,4062,"send them over."],[5568,5734,"So, it's official."],[5818,6001,"You're really leaving us?"],[6001,6110,"Yeah, I am."],[6172,6235,"But it'll be okay."],[6235,6310,"Just make sure you lean on"],[6310,6460,"your new team lead for support."],[6477,6556,"That's not gonna happen."],[6581,6773,"She's completely unqualified"],[6773,6969,"and a total bitch."],[6969,7040,"Yeah."],[7040,7140,"Who's the new team lead?"],[8174,8270,"Beatrice!"],[8270,8370,"You left this."]],"11":[[8,58,"There."],[79,145,"Now we can finally"],[145,304,"have some taste in the office."],[383,671,"I know all about girls like you."],[704,846,"You sleep your way to the top."],[888,930,"And then think"],[930,1142,"you'll snag a billionaire husband."],[1163,1309,"But you're just a plaything,"],[1326,1484,"no respectable man would ever"],[1484,1593,"marry someone like you."],[1626,1676,"Well, and you think"],[1676,1797,"you're so much better"],[1797,2018,"because you have my sloppy seconds?"],[2565,2623,"Keep it."],[2715,2857,"Think of it as a parting gift."],[2869,2990,"You bitch!"],[3015,3186,"You made my nose bleed!"],[3611,3816,"She is definitely going to"],[3816,3933,"drown us in work now."],[3933,4083,"But seeing her run off like that"],[4083,4204,"definitely made it worth it."],[4204,4316,"Hey guys, don't be afraid to quit"],[4316,4429,"if she makes your life hell."],[4450,4604,"There are plenty of other jobs out there."],[4617,4671,"Trust me."],[4700,4867,"Oh, did you find one yet?"],[4867,5067,"I heard Damian Crowley"],[5067,5196,"is looking for a new assistant"],[5196,5309,"if you're interested."],[5326,5438,"He just flew in from Europe,"],[5438,5597,"so he's been over there for ten years."],[5605,5805,"Neil, she's a Project Director."],[5805,5947,"She can't just drop down"],[5947,6101,"to be someone's secretary."],[6122,6231,"And not to mention,"],[6231,6364,"Damian Crowley is like"],[6364,6527,"mortal enemies with Desmond."],[6527,6619,"Why do you think our boss"],[6619,6765,"has been so stressed lately?"],[6777,6994,"It's because Damian Crowley is in town."],[7019,7152,"Yeah, being a secretary"],[7152,7328,"would be a major demotion,"],[7328,7478,"but Damian is Desmond's"],[7478,7582,"biggest competitor."],[7657,7728,"It'd be good to make"],[7728,7853,"my own business connections"],[7853,7916,"instead of only"],[7916,8033,"dealing with Desmond's."],[8053,8120,"You know what?"],[8158,8258,"It's actually a great idea."],[8429,8500,"I'll think about it."],[8804,8983,"Uh, Mr. Belmont's in a meeting."],[9388,9555,"Uh, you- - No."],[9693,9797,"Look what she did."],[9847,9926,"Wow."],[9955,10160,"Isn't this a productive meeting?"],[10356,10606,"How dare you show your face here?"],[10694,10935,"Desmond, I want you to punish her."],[11131,11353,"Beatrice, why'd you hit Madeline?"],[11398,11457,"I didn't."],[11574,11703,"She threw something at me"],[11703,11874,"and I tossed it back."],[11874,12007,"You liar!"],[12007,12082,"You totally-"],[12082,12191,"Madeline, that's enough!"],[12316,12479,"Can you leave Beatrice and I alone?"],[12499,12645,"I'd like to speak to her in private."],[12746,12975,"I'm telling my brother about this!"],[13530,13667,"Her family is a very important"],[13667,13797,"business partner of mine."],[13847,13959,"You shouldn't have done that."],[14151,14264,"It won't happen again."],[14543,14652,"My resignation."],[15365,15507,"My mother never calls you."],[15582,15707,"Why is she calling you now?"],[16078,16141,"Crap!"],[16141,16237,"She's gonna talk about"],[16237,16332,"the divorce agreement."],[16378,16420,"I don't know,"],[16420,16554,"maybe she couldn't get ahold of you."],[16966,17250,"Beatrice, I'm ready to talk next steps"],[17250,17359,"about our agreement."],[17438,17500,"Mother?"],[17538,17801,"What agreement do you have"],[17801,17892,"with my wife?"]],"12":[[16,145,"Desmond, uh, son,"],[145,329,"I, I, I, I did not know"],[329,433,"that you two were together."],[492,675,"What agreement are you talking about?"],[675,779,"Desmond, please."],[892,950,"I..."],[950,1026,"it's um,"],[1026,1101,"it's um..."],[1101,1151,"uh."],[1176,1330,"The postnuptial agreement."],[1589,1643,"For what?"],[1710,1785,"For us."],[1856,2018,"Yeah, your mom made me sign it"],[2018,2093,"a while ago,"],[2093,2348,"so I didn't, uh, deplete your assets."],[2348,2406,"Yes!"],[2406,2515,"Exactly!"],[2515,2756,"You are entitled to your full inheritance,"],[2756,2798,"Desmond."],[2798,2911,"I just wanted to make sure"],[2911,2994,"it was protected."],[2994,3086,"Mother, I don't need"],[3086,3253,"your involvement in this."],[3253,3378,"Beatrice is my wife."],[3378,3520,"We don't need a postnup."],[3541,3653,"I want it cancelled."],[4320,4504,"You're already divorced, Desmond."],[4533,4600,"Cancelling the"],[4600,4713,"postnuptial agreement"],[4713,4863,"won't make any difference at all."],[4959,5030,"My phone,"],[5080,5159,"please?"],[5467,5551,"I'm going home."],[5885,5955,"Beatrice."],[6089,6139,"I feel like"],[6139,6268,"you're hiding something from me."],[6802,6848,"I'm not."],[6881,7011,"I'm not hiding anything."],[7052,7127,"You're tired."],[7223,7311,"Get some rest."],[7311,7394,"See you later."],[7920,7995,"Roland."],[8033,8091,"Sir?"],[8174,8387,"I need you to keep an eye"],[8387,8575,"on Beatrice and my mother."],[8616,8725,"I feel like"],[8762,8871,"something's going on."]],"13":[[425,487,"Hello?"],[513,604,"Autumn, I'm alone."],[642,759,"What next steps"],[759,863,"did you want to talk about?"],[863,988,"I want us to sign"],[988,1263,"a written contract in person."],[1263,1430,"One that's more legally binding."],[1459,1597,"I'll call you with more details about it"],[1597,1680,"next week."],[1680,1739,"Fine."],[1822,1968,"But the fifty million needs to be in there."],[1989,2152,"That needs to be in writing as well,"],[2152,2206,"okay?"],[2327,2452,"This might be an extra step."],[2469,2648,"But once I sign this agreement,"],[2665,2857,"I'll finally be done with this marriage."],[3920,4083,"Did Desmond accept your resignation?"],[4158,4216,"Yeah."],[4300,4383,"Yeah, he did."],[4383,4441,"It's..."],[4441,4504,"finally done."],[4646,4733,"Now we can focus on"],[4733,4859,"planning our trip to Paris"],[4859,4975,"that we've been dreaming about."],[4975,5025,"Yes."],[5025,5167,"I'm going to look at flights right now."],[5167,5251,"Okay."],[5559,5668,"Maybe I should look into"],[5668,5768,"that secretary job"],[5768,5914,"before making any travel plans."],[5960,6172,"Violet, since you know"],[6172,6373,"just everybody in the city,"],[6385,6514,"have you heard of this new guy,"],[6514,6656,"Damian Crowley?"],[6706,6852,"Of course."],[6852,7086,"It's Damian fucking Crowley,"],[7086,7207,"for crying out loud."],[7207,7407,"Actually, funny story."],[7699,7820,"Damian's company hires"],[7820,7953,"Scott's law firm for a case,"],[7953,8103,"so I see him around all the time."],[8103,8158,"Why?"],[8362,8433,"Wait."],[8491,8658,"Are you interested in him?"],[8762,8833,"Aren't you afraid"],[8833,8963,"Desmond will be jealous?"]],"14":[[8,296,"Desmond's jealousy is his problem,"],[358,425,"not mine."],[454,613,"Besides, this is strictly for work."],[642,930,"I do not need another man in my life."],[946,1001,"Okay."],[1142,1247,"Lucky for you,"],[1255,1484,"Scott and Damian are golfing tomorrow."],[1530,1705,"Let's join, so you two can meet."],[2869,3019,"Beatrice said she was going home."],[3073,3249,"So why isn't she here?"],[3636,3712,"Where is she?"],[3753,3828,"Uh, sir, she went to"],[3828,3903,"an apartment complex"],[3903,3970,"on Main Street."],[3970,4116,"Looks like she rented an apartment there."],[4154,4341,"The building is owned by the CEO"],[4341,4425,"of the NobleQuest Group,"],[4425,4521,"Damian Crowley."],[4521,4625,"He lives in a penthouse there."],[5347,5430,"Beatrice,"],[5467,5672,"why are you keeping secrets from me?"],[6031,6114,"Yeah, I think I should change back"],[6114,6189,"into my other outfit."],[6189,6352,"Uh, absolutely not."],[6352,6493,"It made you look like a grandma."],[6573,6781,"This shows off your figure so much more."],[6794,6956,"Damian won't be able to resist you."],[6956,7132,"Okay, but I'm not trying to seduce him."],[7132,7273,"I'm trying to work for him."],[7273,7357,"This isn't a good idea."],[7357,7415,"I think..."],[7415,7570,"Oh, well, it's too late for that."],[7570,7645,"There he is."],[7645,7736,"Come on, let's go."],[9259,9471,"That's Damian Crowley?"],[9547,9726,"The guy from the car accident?"]],"15":[[0,108,"Oh shit, Scott."],[150,291,"Who's that next to your wife?"],[321,475,"She's got a rockin' hot bod."],[496,579,"That's Beatrice."],[579,700,"She's been my wife's bestie"],[700,788,"since high school."],[825,909,"Who's she getting you"],[909,996,"all dressed up for?"],[1042,1121,"Hi, honey."],[1284,1347,"Damian."],[1347,1480,"I'd like to introduce you"],[1480,1609,"to Beatrice Lawson."],[1609,1739,"She was a Project Director"],[1739,1826,"at Summit Group."],[1872,2064,"Nice to meet you, Mr. Crowley."],[2131,2223,"What are you doing here?"],[2248,2381,"If this is about the suit jacket,"],[2381,2473,"you can forget about it."],[2506,2594,"Suit jacket?"],[2644,2790,"Wait, do they know each other?"],[2790,2952,"No, she wanted to meet him."],[2969,3065,"It's not about the jacket,"],[3103,3253,"although I do still want to return that."],[3269,3399,"I'm actually here because I heard"],[3399,3528,"you're hiring a new secretary."],[3624,3720,"I'd like to apply."],[3774,3933,"Oh, she dressed up for me."],[3978,4058,"I knew it."],[4104,4179,"I see."],[4229,4412,"You know, my secretary job's"],[4412,4517,"very tough."],[4550,4667,"Are you sure you can handle it?"],[4717,4863,"I can assure you, Mr. Crowley,"],[4863,5055,"I will give this job my one hundred percent."],[5063,5209,"I can handle any task you throw my way."],[5255,5321,"Really?"],[5392,5543,"Can't tell by the way you dressed."],[5739,5805,"You know, if you really"],[5805,5901,"want the secretary job,"],[5901,6022,"you should approach me in private."],[6081,6189,"You shouldn't look this pretty"],[6189,6302,"in front of everyone."],[6339,6418,"Jerk."],[6431,6510,"I see."],[6544,6727,"Thank you, Mr. Crowley,"],[6760,6852,"for your time."],[7023,7102,"Wait, I..."],[7273,7503,"Wow, you are such a prick."]],"16":[[20,158,"Beatrice is one of the most"],[158,308,"competent people I know"],[308,525,"and she'd be taking a major demotion"],[525,625,"to be your secretary."],[625,713,"Don't write her off"],[713,804,"just because she wore"],[804,896,"workout clothes"],[896,1005,"to a golf meeting."],[1034,1163,"You know, she was in a suit"],[1163,1242,"when we got here"],[1242,1363,"and I told her to change"],[1363,1509,"because this was supposed to be"],[1509,1601,"a fun outing,"],[1601,1705,"and you ruined it."],[1730,1872,"I'll see you at home."],[1872,1968,"But I'm starting to think"],[1968,2064,"who you're hanging out with"],[2064,2181,"is rubbing off on you."],[2448,2644,"Great, thanks a lot, Damian."],[2665,2786,"I'm gonna hear about this all night."],[2786,2944,"Violet begged me to join you"],[2944,3115,"so you can meet Beatrice."],[3115,3174,"She just left"],[3174,3315,"the Summit Group yesterday."],[3315,3365,"Why?"],[3386,3453,"No clue."],[3495,3620,"She's the best Project Director"],[3620,3682,"they had."],[3707,3849,"Close eight out of the twelve"],[3849,3928,"of the company's"],[3928,4087,"multi-million-dollar deals."],[4087,4183,"Why doesn't she just"],[4183,4304,"continue working with them?"],[4304,4416,"Between us,"],[4462,4612,"Beatrice and the Summit CEO"],[4612,4696,"used to date."],[4767,4900,"The word on the street is"],[4900,4988,"he's going to marry"],[4988,5155,"Madeline Fairfax now."],[5226,5317,"I don't think Beatrice"],[5317,5422,"wants to work for a company"],[5422,5568,"that associates with him at all."],[5609,5826,"So she used to date Desmond Belmont?"],[6135,6231,"Interesting."],[6569,6815,"Desmond, I want you to explain exactly"],[6815,6952,"what happened with my sister"],[6952,7023,"at your company."],[7023,7082,"She got injured"],[7082,7207,"and you didn't do anything about it?"],[7286,7369,"She's okay."],[7465,7611,"What exactly did you want me to do?"],[7624,7732,"You need to make Beatrice"],[7732,7857,"apologize to me!"],[7907,7978,"Desmond."],[8241,8316,"Come on, my nose,"],[8316,8437,"it still hurts from yesterday."],[8437,8516,"And not only that,"],[8516,8671,"but that bitch publicly"],[8671,8796,"humiliated my sister."],[8796,8925,"How do you expect her to run a team?"],[9009,9121,"This looks bad on you too."],[9238,9355,"You swear that actually happened?"],[9563,9647,"You didn't do anything"],[9647,9751,"to provoke her?"]],"17":[[8,166,"No, no, of course I didn't."],[166,216,"No."],[262,513,"She insulted me in front of everybody"],[513,571,"out of nowhere."],[571,721,"It was completely uncalled-for."],[721,963,"You know how much I hate liars,"],[963,1042,"Madeline."],[1042,1213,"Why are you still on her side?"],[1230,1309,"Okay, well fine,"],[1309,1438,"if she doesn't want to return"],[1438,1555,"and formally apologize to me,"],[1555,1689,"then you need to fire her team."],[1705,1768,"Agreed."],[1789,1847,"We can't have"],[1847,1931,"Madeline's employees"],[1931,2093,"think they can just walk all over her."],[2118,2306,"Her team is going nowhere."],[2423,2556,"Beatrice was one of our"],[2556,2777,"best Project Directors here."],[2786,3065,"And that team was a part of it."],[3098,3307,"If Madeline can't handle the job,"],[3307,3424,"then she can just quit."],[3428,3599,"And I'll hire someone that can."],[3778,3970,"Okay, I see what this is now."],[3999,4170,"Listen, if you haven't completely"],[4212,4320,"moved on from her,"],[4400,4471,"I'm gonna have no choice"],[4471,4617,"but to cancel this partnership,"],[4617,4725,"Mr. Belmont."],[4750,4867,"Cancel our partnership."],[4959,5050,"I'll see you in court."],[5063,5196,"Do you understand?"],[5313,5501,"You don't want to piss me off, Quentin."],[5864,5951,"Alright, I'm done here."],[6135,6335,"I have more important business"],[6398,6464,"to handle."],[7303,7465,"Don't think you've won, Beatrice."],[7486,7624,"I'll be getting my revenge."],[7724,7924,"I'm sorry again about earlier."],[7945,8028,"I didn't realize"],[8028,8183,"Damian was so stuck up."],[8199,8304,"It's fine."],[8387,8533,"Now we can focus on planning our trip."],[8579,8796,"I honestly have no idea."],[8837,8921,"That's fair."],[9092,9184,"42L."],[9184,9455,"Uh, Gordon just texted me"],[9455,9580,"Damian's suit size."],[9676,9755,"That's great."],[9755,9884,"I mean, maybe that means"],[9884,9984,"he's changed his mind"],[9984,10143,"and wants to talk about the job."],[10206,10310,"I'm just going to give him his jacket back"],[10310,10422,"and forget about the job completely."],[10493,10610,"So, I'm gonna go ahead"],[10610,10710,"and text him back,"],[10710,10802,"figure out when he wants to meet."],[10802,10890,"Okay, I'll talk to you later?"],[11131,11327,"Mr. Crowley will be at the Rowe Hotel"],[11327,11403,"this weekend"],[11403,11540,"for a client conference."],[11565,11786,"You can deliver the jacket to us then."],[11953,12141,"I do have to meet Autumn at the hotel"],[12141,12191,"to discuss"],[12191,12408,"my divorce agreement anyways."],[12412,12508,"At least this way"],[12508,12666,"I can kill two birds with one stone."],[13029,13096,"Coming!"]],"18":[[1230,1322,"You said that"],[1322,1480,"you were coming home last night."],[1547,1655,"But you didn't."],[1680,1764,"And clearly,"],[1772,2010,"your stuff is not at the cleaners."],[2414,2581,"What are you doing here, Desmond?"],[2690,2781,"Why'd you move out?"],[2844,2957,"And why'd you lie about it?"],[3019,3278,"The apartment that we lived in is yours."],[3361,3436,"With the postnup"],[3436,3561,"your mom made me sign,"],[3561,3657,"I have no claim to it."],[3657,3724,"So I moved out"],[3724,3878,"so I could have my own space, okay?"],[3878,4004,"Forget the postnup."],[4012,4137,"It's being canceled."],[4158,4270,"If you wanted your own apartment,"],[4270,4358,"you could have asked me."],[4358,4433,"I would have gone."],[4433,4462,"We could have"],[4462,4571,"looked for it together."],[4571,4713,"I would have bought it for you."],[4713,4929,"That is not the point, Desmond."],[5013,5159,"We're married, Beatrice."],[5159,5221,"I don't understand"],[5221,5292,"why you're keeping"],[5292,5409,"all these secrets from me."],[5409,5543,"I'm keeping secrets?"],[5543,5597,"Me?"],[6131,6272,"You've been seeing Madeline"],[6272,6414,"for months now."],[6414,6573,"Everyone knows you plan to marry her."],[6573,6706,"Yet you have the nerve"],[6706,6981,"to accuse me of keeping secrets?"],[7027,7194,"I don't know what you're thinking,"],[7240,7328,"but you're wrong."]],"19":[[183,329,"I want you to come home with me."],[425,542,"You can trust me."],[671,809,"I don't know that I can."],[1347,1455,"I noticed..."],[1614,1751,"you weren't wearing yours."],[1785,1947,"You were due for an upgrade anyway."],[2344,2431,"And..."],[2911,2998,"Are we done now?"],[3153,3278,"I'd like some time alone."],[3486,3549,"Okay."],[3824,3866,"But,"],[3953,4137,"I will see you at home."],[4195,4258,"One way"],[4337,4421,"or another."],[5242,5509,"You can't buy real love, Desmond."]],"20":[[358,500,"You haven't touched your coffee."],[596,692,"It's not poisoned,"],[692,809,"if that's what you're worried about."],[888,980,"Not thirsty."],[1038,1213,"Poison is tacky, Beatrice."],[1338,1463,"Not that you could be expected"],[1463,1518,"to know that"],[1518,1622,"with your background."],[1689,1926,"Can we just skip the small talk, please?"],[2014,2097,"We don't like each other."],[2097,2156,"That's okay,"],[2156,2231,"let's just move on."],[2519,2740,"Here is the legal agreement."],[2831,2982,"Your breakup fee"],[2982,3136,"of fifty million dollars"],[3157,3253,"is in there."],[3336,3399,"Sign it."],[3528,3649,"Breakup fee?"],[3666,3895,"Why is she suddenly saying breakup fee?"],[3895,4208,"And this document is oddly long."],[4216,4366,"There are so many sections."],[4387,4521,"And a lot of weird clauses"],[4521,4600,"about payment."],[4675,4800,"She must be up to something."],[4971,5167,"I don't have all day, Beatrice."],[5230,5321,"Okay, um..."],[5321,5434,"I'm just gonna need to check this"],[5434,5509,"with my lawyer."],[5559,5663,"So I'm gonna give her a call right now."],[5851,5901,"Fine."],[6493,6564,"Did you hear that?"],[6564,6677,"She's calling her lawyer."],[6715,6781,"I heard."],[6823,6890,"Don't worry."],[6915,7052,"That agreement is foolproof."],[7069,7127,"So you can get me"],[7127,7269,"out of this, darling, yes?"],[7282,7386,"I won't have to pay a thing."],[7386,7524,"I'm positive."],[7549,7628,"The Belmont family"],[7628,7699,"will never be extorted"],[7699,7816,"by Beatrice Lawson again."],[7870,7945,"Trust me."],[8137,8295,"Beatrice, you won't be the same"],[8295,8437,"when you leave the hotel today."],[8454,8579,"That is, if you leave at all."]],"21":[[237,291,"Sir,"],[350,421,"Beatrice has gone"],[421,517,"to the Rowe Hotel"],[517,617,"to meet with your mother."],[625,750,"Why the hell would she do that?"],[821,900,"Get the car ready,"],[900,1005,"we're going there now."],[1005,1067,"Yes, sir."],[1138,1292,"I knew there was something wrong"],[1292,1401,"with this document."],[1409,1568,"I'd have to be crazy to sign that."],[1589,1710,"Okay, it's clear I'm the only one"],[1710,1856,"who's serious about my payment."],[2135,2177,"Let me check"],[2177,2302,"if Damian's available now"],[2302,2394,"to receive the jacket."],[2781,2957,"Miss, do you need any help"],[2957,3065,"with your belongings?"],[3182,3495,"Uh, no, no, I'm good, thanks."]],"22":[[137,354,"Mr. Crowley, if I may ask,"],[354,542,"why do you insist on"],[542,734,"picking up the jacket directly"],[734,813,"from Ms. Lawson?"],[880,1255,"Um, it's because it's an expensive jacket."],[1426,1584,"And you're a billionaire."],[2064,2156,"Curious."],[2181,2323,"Ms. Lawson just sent me"],[2323,2523,"a half-written message."],[2907,3086,"I'm at the hotel, where should we..."],[3215,3340,"She got interrupted."],[3499,3595,"Something's not right."],[3653,3724,"Let's go!"],[3816,3937,"Madame Belmont reserved"],[3937,4058,"the meeting room on this floor."],[4646,4804,"This is Beatrice's stuff."],[4954,5059,"She wouldn't just leave them"],[5059,5105,"sprawled out"],[5105,5221,"in the middle of the hallway."],[5292,5505,"What are you up to?"],[5518,5588,"Something's off."],[5701,5822,"Search all the rooms."]],"23":[[129,179,"Oh!"],[271,362,"She's awake."],[433,521,"Hey, sweetheart."],[709,846,"You like your new jewelry?"],[996,1117,"I wouldn't do that."],[1217,1326,"That knot won't budge."],[1451,1605,"We've been paid a lot of money"],[1605,1685,"for this job."],[1697,1939,"Someone must really hate you, huh?"],[1976,2072,"Turn on the camera."],[2293,2344,"Stop."],[2394,2444,"No."],[2444,2527,"They said,"],[2527,2711,"we can do whatever we wanted to you."],[2756,2961,"As long as we scared you senseless."],[3011,3090,"You know what?"],[3165,3244,"I think"],[3286,3453,"we should play Russian Roulette."]],"24":[[396,563,"She's gotta be in one of these rooms."],[1146,1242,"Beatrice!"],[1347,1434,"Keep looking!"],[1630,1751,"You said you saw a bellhop"],[1751,1851,"help her into a room?"],[1856,1993,"Yes, about twenty minutes ago."],[2364,2444,"It's gonna be fun."],[3174,3232,"Damn it!"],[3687,3791,"Where's Beatrice?"]],"25":[[291,342,"Kevin!"],[433,496,"Oh God."],[529,617,"Is she injured?"],[617,692,"I'm not sure."],[713,829,"It looks like they drugged her"],[829,896,"with something."],[905,980,"Oh no."],[1163,1259,"Take them out of here."],[1305,1401,"Figure out who did this."],[1401,1539,"Beat it out of them if you have to."],[1910,1993,"You're okay now."],[2214,2339,"You better keep this between us,"],[2339,2477,"otherwise you can kiss the partnership"],[2477,2627,"between me and your hotel goodbye."],[2660,2786,"Of course, Mr. Crowley."],[3115,3178,"Oh no."],[3215,3265,"Oh no."],[3795,3916,"I'm gonna take you to the hospital."],[4083,4170,"It's gonna be alright."]],"26":[[4,95,"Where's Beatrice?"],[158,266,"How should I know?"],[308,429,"She came here to meet you."],[446,542,"I figured to cancel"],[542,663,"the postnuptial agreement?"],[725,800,"Yes."],[800,1063,"And I gave her the cancellation contract"],[1063,1217,"and then she just disappeared."],[1288,1359,"You know, Desmond,"],[1359,1530,"I don't think it's wise"],[1547,1697,"to cancel an agreement"],[1697,1881,"that's protecting your assets."],[1981,2102,"Your opinion means nothing"],[2102,2235,"to me, Mother."],[2264,2373,"This is the Belmont"],[2373,2510,"family name at stake!"],[2527,2765,"Of course my opinion matters."],[2786,2948,"Desmond, please."],[2990,3253,"Just think about"],[3253,3432,"marrying Madeline Fairfax."],[3432,3616,"I'm not marrying Madeline."],[3691,3878,"She's, she's just entertainment."],[3928,4225,"And her family still has some use to me."],[4404,4571,"What if Beatrice finds out"],[4571,4683,"about your affair?"],[4683,4859,"Then I'll, I'll leave Madeline."],[4892,5080,"I'm not gonna end my marriage"],[5080,5134,"with someone"],[5134,5330,"who just offers me simple pleasures."],[5359,5555,"Stop trying to get Beatrice"],[5555,5659,"to divorce me."],[5726,5901,"Or else I'll tell everyone"],[5997,6231,"that Beatrice is my wife."],[6423,6610,"That would ruin our relationship"],[6610,6715,"with the Fairfax family."],[6715,6840,"The Fairfax family"],[6840,6973,"means no importance to me"],[6973,7136,"if it means losing Beatrice."],[7144,7211,"There are so many"],[7211,7319,"other companies out there"],[7319,7436,"that I can partner with."],[7436,7674,"But there's only one Beatrice."],[7703,7853,"Do you understand?"],[7932,8153,"This is the last time I'm telling you."],[8229,8437,"I will not stand for this!"],[8516,8737,"Beatrice is not a fit wife,"],[8758,8954,"and you will not stay married to her!"],[9388,9613,"If I don't stay married to that woman,"],[9613,9726,"I will tell Cullen!"],[9738,9943,"I will tell everyone on this staff"],[9955,10114,"that you no longer reside"],[10114,10260,"on the Belmont Estates!"],[10314,10364,"I'll put you"],[10364,10535,"in a fucking retirement home!"],[10573,10681,"Are we clear?"]],"27":[[29,112,"Think about it."],[337,483,"I'm not having this conversation"],[483,558,"with you again."],[1255,1338,"You've already"],[1338,1514,"signed the divorce, Desmond."],[1514,1705,"You might not care about my opinion,"],[1705,1797,"but this is happening"],[1797,1943,"whether you like it or not."],[2239,2410,"So her vitals are stable."],[2435,2577,"The drug was just a sedative,"],[2577,2790,"so there is no long-term damages."],[2790,2907,"Thank you. - Of course."],[3328,3382,"Good."],[3449,3520,"You're awake."],[3636,3707,"Yeah..."],[3870,3916,"Hi."],[3916,4016,"You're in the hospital."],[4220,4325,"Do you remember what happened?"],[4458,4508,"Yeah."],[4621,4708,"The hotel."],[4842,5034,"I thought those guys were gonna kill me"],[5034,5125,"and you saved me."],[5125,5205,"Thank you."],[5205,5259,"I don't..."],[5301,5392,"I don't know how I can ever"],[5392,5451,"repay you. - That's not"],[5451,5522,"necessary."],[5597,5668,"You're alive."],[5668,5780,"That's all that matters."],[6089,6210,"However, I thought you should know that"],[6210,6281,"the armed men"],[6281,6418,"said that they were hired by someone"],[6418,6573,"associated with the Belmont family."],[6735,6835,"I have the records."],[6865,6906,"Let me know"],[6906,7015,"if you want to press charges."],[7077,7232,"Someone involved with Desmond?"],[7424,7482,"Also,"],[7607,7736,"you should come in and interview."],[7770,7907,"You wanted to be my secretary, right?"],[8049,8112,"Really?"],[8141,8183,"Yeah."],[8441,8608,"Thank God, Beatrice, you're okay."]],"28":[[62,158,"Mr. Crowley,"],[233,325,"what are you doing here?"],[371,496,"Beatrice and I had a meeting."],[621,734,"I was the one who found her."],[788,871,"Beatrice?"],[934,1113,"You guys are on a first name basis?"],[1722,1797,"Here's my number."],[2464,2602,"Go ahead and reach out to me directly"],[2602,2719,"once you made your decision."],[4283,4366,"What happened?"],[4433,4558,"I was attacked."],[4838,4967,"I'm gonna make sure to find them."],[4967,5034,"I will."],[5034,5125,"I've already contacted"],[5125,5221,"hotel security"],[5221,5367,"to get the surveillance footage."],[5409,5543,"I'm not gonna let them get away."],[5613,5697,"That's funny,"],[5697,5826,"because someone close to you"],[5826,6010,"hired those men to begin with."],[6373,6443,"Desmond, wait."],[6468,6531,"Desmond!"],[6539,6614,"Put me- - Stop."],[6631,6694,"Where are we going?"],[6748,6798,"Home."],[6852,6906,"Desmond."],[6952,7023,"Desmond!"],[7048,7132,"Stop!"],[8216,8345,"Did you get the security footage?"]],"29":[[25,104,"Yes, but unfortunately"],[104,200,"the cameras on the floor"],[200,350,"she was taken to were turned off"],[375,492,"before the incident occurred."],[492,596,"We were unable to see anything."],[663,779,"The attackers were thorough."],[863,959,"How would you like us to proceed,"],[959,1026,"Mr. Belmont?"],[1101,1217,"Don't bother with anything."],[1255,1355,"Beatrice will recover"],[1355,1443,"and then this whole thing"],[1443,1543,"will just blow over."],[1584,1647,"Understood."],[1647,1722,"Anything else?"],[1789,1835,"Yeah."],[1926,2039,"I need you to fire"],[2068,2214,"Madeline Fairfax tomorrow."],[2256,2548,"This whole thing is becoming a hassle."],[2615,2673,"Understood."],[2986,3115,"Where's the rest of the footage?"],[3178,3249,"Those guys should have"],[3249,3386,"bruised her up pretty badly,"],[3395,3541,"but they barely sent anything."],[3620,3774,"I wonder if they actually killed her."],[3807,3974,"That would be the best case scenario."],[4033,4091,"Then I wouldn't have to"],[4091,4145,"deal with her"],[4145,4300,"annoying antics anymore."],[4942,5150,"Um, hello?"],[5217,5426,"I don't see any work being done."],[5488,5668,"It's 12.30."],[5751,5826,"It's lunchtime."],[5876,5985,"I don't care."],[5985,6047,"Let's go."],[6047,6139,"Chop chop!"],[6147,6322,"You can't force us to work through lunch."],[6322,6402,"That's illegal."],[6414,6519,"Yes, I can."],[6548,6690,"I'm the Project Manager now,"],[6690,6823,"so you have to do what I say."],[6823,7048,"No, they don't."],[7048,7152,"Madeline Fairfax,"],[7152,7290,"uh, you are no longer employed"],[7311,7357,"by Summit Group."],[7357,7520,"Please leave the office immediately."],[7528,7649,"What are you talking about?"],[7703,7799,"Of course I am."],[7870,8166,"I replaced Beatrice, so I'm in charge now."],[8254,8433,"Desmond gave me the job himself."],[8433,8596,"And now he's taking it away."],[8641,8708,"You're no longer welcome"],[8750,8846,"on Summit Group property."],[8846,8954,"Your privileges have been revoked."]],"30":[[0,108,"Excuse me?"],[145,283,"You can't do that!"],[291,383,"Yeah, I can."],[404,538,"This gentleman will escort you out."],[679,742,"Whatever."],[784,905,"Now that Beatrice is gone,"],[909,984,"Madame Belmont can"],[984,1117,"finally announce my engagement"],[1117,1184,"to Desmond."],[1217,1317,"Her charity banquet"],[1317,1447,"will be the perfect occasion."],[1480,1618,"I'll make sure Desmond attends"],[1618,1685,"as my date,"],[1685,1801,"so the whole community knows"],[1801,2002,"that I am the future Mrs. Belmont."],[3219,3361,"I can't remember the last time"],[3361,3474,"he made me pancakes."],[3511,3570,"Eat up."],[3620,3766,"You need to regain your strength."],[3949,4024,"How are you feeling?"],[4112,4241,"Do I need to call the doctor?"],[4241,4404,"We can get an at-home visit going."],[4454,4587,"No, I am perfectly fine."],[4738,4792,"Okay."],[4925,4984,"Just so you know,"],[4984,5221,"I did call off work this entire week."],[5317,5451,"That way I can be here for you"],[5451,5555,"whenever you need me."],[5555,5684,"What's the point of acting like"],[5684,5793,"you're in love with me now?"],[5947,6060,"It's too late, Desmond."],[6210,6264,"It's okay."],[6297,6385,"You don't have to do that."],[6439,6539,"Like I said, I'm fine."],[6602,6673,"I want to."],[6735,6840,"I'm your husband."],[6952,7065,"I care about you."],[7261,7349,"I was thinking,"],[7474,7545,"maybe,"],[7661,7770,"after you recover,"],[7924,8091,"we'll start trying for a baby."],[8358,8437,"We're both home,"],[8437,8625,"I think it would be the perfect time."],[8683,8762,"What do you think?"]],"31":[[304,404,"Once upon a time,"],[404,517,"all I ever wanted"],[517,646,"was to have a baby with him."],[663,955,"But now, it would be my worst nightmare."],[996,1159,"I'm not ready for a baby."],[1226,1284,"I'm not."],[1359,1422,"Violet and I"],[1422,1547,"were planning a trip to Paris."],[1547,1622,"I want to travel."],[1622,1730,"I want to be alone"],[1780,1981,"for a little while first."],[2198,2248,"Okay."],[2423,2602,"The process takes nine months."],[2665,2777,"We could start now."],[2798,2919,"And then you have all the time"],[2919,2982,"in the world"],[2982,3244,"to travel before the baby's born."],[3269,3370,"It's important that"],[3370,3561,"the Belmont family has an heir."],[3599,3983,"We could even start it right now."],[5684,5755,"Where were we?"],[6043,6189,"Why didn't you answer her call?"],[6260,6356,"I already told you."],[6385,6535,"I'm not going into work this week."],[6535,6748,"Roland will handle any office concerns."],[6773,6831,"You know,"],[6865,6936,"we're both home."],[6956,7140,"Why don't we call a designer,"],[7157,7273,"convert one of the bedrooms"],[7273,7369,"into a nursery?"],[7570,7691,"You know, I'm uh,"],[7791,7878,"I'm getting a headache."],[7878,7970,"I should go lay down."],[8049,8124,"You should make sure"],[8124,8241,"your employees know"],[8241,8345,"when you're out of office."],[9225,9355,"Roland already terminated"],[9355,9426,"your position."],[9426,9484,"What do you want?"],[9484,9563,"Desmond."],[9617,9672,"Hi."],[9738,9930,"Madeline, I don't have time for this."],[10039,10176,"If you have anything,"],[10176,10368,"just have Roland handle it."],[10368,10443,"I'm busy."],[10443,10497,"Wait!"],[10560,10673,"Uh, I, I left the company"],[10673,10752,"like you requested,"],[10752,10956,"but perhaps we could see each other"],[10956,11061,"one last time."],[11123,11202,"To say goodbye?"],[11269,11453,"I think you owe me that, at least."],[11649,11703,"Fine."],[11778,11828,"When?"],[11920,12007,"This weekend."],[12045,12120,"Your mother is hosting"],[12120,12216,"a charity banquet."],[12270,12362,"We can go together."],[12449,12504,"Alright."],[12595,12683,"I'll, I'll be there."],[12754,13054,"But Madeline, don't try anything funny."],[13100,13192,"I have one line."],[13304,13380,"Don't cross it."],[13726,13838,"Now everyone will finally know"],[13838,14014,"we're getting engaged, Desmond."]],"32":[[229,400,"This is insane, Beatrice."],[400,467,"Mhm."],[525,696,"I mean, I'm glad you're okay now,"],[717,921,"but who do you think was behind this?"],[984,1130,"I have my suspicions."],[1217,1363,"Okay, I can't prove it,"],[1468,1835,"but I think it was Madeline Fairfax."],[1872,2018,"Madeline Fairfax."],[2089,2185,"That reminds me,"],[2218,2335,"Desmond is supposed to be"],[2335,2423,"at Madame Belmont's"],[2423,2552,"charity gala this weekend."],[2585,2627,"Yeah."],[2627,2740,"I mean, it's his mom's gala."],[2740,2840,"I'm sure he'd be there."],[2865,2932,"Yes."],[2973,3228,"But Madame Belmont is planning"],[3228,3290,"to announce"],[3290,3374,"Desmond's engagement"],[3374,3507,"to Madeline Fairfax."],[3595,3749,"I actually think it makes a lot of sense"],[3749,3858,"if Madeline is the one"],[3858,3958,"behind your attack."],[3999,4124,"She wants to get rid of you"],[4124,4225,"once and for all."],[4329,4483,"Wait, how do you know all of that?"],[4562,4704,"She sent invitations out."],[5384,5509,"They're going public."],[5784,5922,"This is actually perfect."],[6235,6335,"I think I'm going to"],[6335,6594,"pay my husband a visit"],[6594,6740,"to his engagement party."],[6798,6906,"But I'm gonna need your help."],[6981,7048,"Of course."],[7903,7966,"Yes?"],[8204,8295,"You look nice."],[8491,8550,"Thank you."],[8600,8675,"This is for my mother's"],[8675,8758,"charity banquet."],[8808,8854,"Oh."],[9163,9263,"I didn't realize"],[9263,9396,"she was hosting an event today."],[9659,9755,"Are you going to bring a date?"]],"33":[[100,145,"No."],[291,425,"I'd only want to attend the event"],[425,471,"with you."],[546,658,"But I figured it'd be best"],[658,742,"if you stayed home"],[742,913,"to recover for a little bit while longer."],[1051,1142,"More lies."],[1559,1614,"Well..."],[1739,1860,"I appreciate your concern."],[2389,2531,"You'll be okay tonight while I'm gone?"],[2777,2819,"Of course."],[2877,3053,"Well get some sleep, some actual rest."],[3053,3111,"You need it."],[3144,3236,"Don't wait up for me."],[3666,3803,"One day you'll understand."],[3845,3941,"I wasn't waiting."],[3983,4200,"No, I was learning to live without you."],[4300,4371,"And now,"],[4429,4529,"I don't need you."],[4608,4692,"I never did."],[5284,5447,"Lovely to see you again."],[5467,5638,"This is quite the turnout, Madam."],[5659,5759,"It really is."],[6777,7132,"That's Mr. Belmont and Miss Fairfax."],[7132,7286,"They make such a beautiful couple."],[7294,7424,"I heard their engagement"],[7424,7691,"is being formally announced tonight."],[7811,8091,"Madeline, always a pleasure to see you."],[8425,8579,"You look stunning."],[8600,8779,"Oh, thank you, Madam Belmont."],[8817,9013,"Anything for this fantastic gala"],[9013,9104,"you've arranged."],[9209,9342,"Desmond, you look dashing."],[9517,9759,"Madeline, could I have a quick word"],[9759,9880,"privately with you?"],[9905,10064,"I want to talk about some of the jewelry"],[10064,10164,"that's up for auction."],[10201,10272,"Of course."],[10839,10969,"Beatrice never returned"],[10969,11156,"with her finalized breakup agreement."],[11244,11386,"Have you been in contact with her?"]],"34":[[58,125,"Madame Belmont"],[125,216,"doesn't know about my stunt"],[216,312,"with those attackers,"],[337,496,"and that I almost had that bitch killed."],[855,1030,"Yes, she contacted me."],[1059,1197,"She signed it earlier today."],[1230,1338,"Well, that's wonderful."],[1351,1468,"I'm so looking forward"],[1468,1689,"to having you as my daughter-in-law."],[1718,1843,"You're so reliable."],[1843,1968,"Thank you, Madame Belmont."],[1968,2077,"I try my best."],[2077,2277,"Please, we're about to be family."],[2277,2473,"No need to stand on formalities."],[2502,2598,"Call me Autumn,"],[2619,2765,"or Mom if you prefer."],[2802,2932,"Okay, Mom it is then."],[3670,3749,"Desmond?"],[3870,3941,"What do you think?"],[3962,4074,"The diamond ring"],[4074,4254,"by Mrs. Nelson is stunning,"],[4270,4421,"but the emeralds from Mrs. Smith,"],[4421,4542,"they're so unique."],[4567,4654,"They both sound fine."],[4671,4792,"Oh, what about this one?"],[4792,5009,"A one-of-a-kind diamond necklace."],[5009,5109,"Wow."],[5117,5263,"It says the diamonds were handpicked"],[5263,5359,"by the original owner."]],"35":[[771,959,"This is Beatrice's necklace."],[980,1151,"The one I just gave her."],[1188,1322,"And those are her pink diamonds"],[1322,1443,"from our anniversary."],[1468,1672,"And her wedding ring."],[1718,1847,"She sold them all."],[1847,1931,"That's why she wasn't"],[1931,2052,"wearing her wedding ring."],[2072,2218,"You guys enjoy the rest of the gala."],[2231,2314,"I have something important"],[2314,2419,"I need to take care of."],[2494,2560,"Wait, what?"],[2585,2669,"You can't leave now."],[2669,2823,"This is an important night for us."],[2823,2886,"For us?"],[2886,3011,"What are you talking about?"],[3136,3203,"Everyone."],[3203,3311,"Thank you so much"],[3311,3436,"for coming here today."],[3445,3666,"I have a fantastic announcement"],[3666,3803,"before the auction."]],"36":[[0,266,"My son, Desmond Belmont,"],[300,638,"is engaged to Miss Madeline Fairfax"],[638,855,"of the Fairfax family."],[855,917,"Yes,"],[917,1001,"thank you."],[1017,1084,"Thank you."],[1368,1580,"This is fantastic news."],[1580,1772,"They make the perfect couple."],[1772,2093,"And I will personally be bidding"],[2118,2318,"on the most expensive"],[2318,2414,"piece of jewelry"],[2414,2652,"to offer Madeline as a wedding gift."],[2694,2952,"I'm not marrying Madeline Fairfax!"],[3311,3524,"Desmond, honey, we can talk about this."],[3524,3578,"No."],[3586,3678,"No, we can't."]],"37":[[658,900,"Isn't that Desmond's ex-girlfriend?"],[900,1067,"What is she doing here?"],[1067,1197,"Do you think she's here"],[1197,1284,"to make a scene?"],[1284,1505,"She's just going to embarrass herself."],[1505,1626,"Desmond and Madeline"],[1626,1760,"already announced their engagement."],[1760,1881,"There's nothing she can do."],[1926,2093,"What is this bitch doing here?"],[2731,2957,"Desmond and I are getting engaged."],[2973,3148,"So why don't you quit bothering us"],[3148,3299,"and leave us alone!"],[3299,3403,"Shut your mouth."],[3474,3545,"We're not."],[3545,3670,"We're not getting engaged."],[4058,4129,"Let go."],[4129,4220,"Desmond, honey,"],[4220,4366,"let's talk about this later."],[4366,4471,"No! - Desmond."],[4471,4612,"Do not embarrass Madeline"],[4612,4725,"for this woman."],[4729,4871,"Hey, why don't you just escort her out"],[4871,4963,"and then we can continue"],[4963,5050,"the engagement party."],[5050,5263,"This is not an engagement party!"],[5401,5488,"It's not!"],[5876,6064,"What if she's here to reveal her marriage?"],[6089,6189,"I have to get her out"],[6189,6331,"before she says anything."],[6423,6585,"Beatrice, you need to leave."],[6585,6869,"This is a charity event"],[6869,7065,"and you are causing a scene."],[7186,7232,"Hey,"],[7286,7394,"hey, let's just,"],[7419,7486,"let's go home."],[7486,7670,"Let's talk about this at home."],[7753,7836,"Are you planning"],[7836,8045,"to take another wife, Desmond?"],[8166,8316,"You know, bigamy is illegal"],[8395,8571,"in all fifty states, right?"]],"38":[[241,333,"She's lying."],[383,525,"Desmond's never been married before."],[525,692,"There was no wedding or anything."],[692,967,"She is just a jealous ex-girlfriend."],[992,1084,"The Belmont family"],[1084,1197,"would never let Desmond"],[1197,1380,"marry someone of her kind."],[1380,1547,"You're shameless!"],[1597,1810,"Desmond is marrying me, okay?"],[1810,1881,"Me!"],[1889,1981,"He would never go for"],[1981,2077,"someone like you."],[2093,2189,"You're not even worth"],[2189,2344,"the shoes on his feet."],[2344,2431,"Shut up!"],[2594,2756,"Madeline, don't bother"],[2756,2852,"arguing with her."],[2852,2965,"Beatrice is not worth it."],[2965,3048,"No, no, no, no."],[3048,3199,"Don't stop her now."],[3199,3315,"She clearly has a lot to say."],[3315,3440,"Let her get it off her chest, yeah?"],[3440,3695,"How dare you come to my charity gala"],[3695,3853,"and cause a scene like this."],[3853,4045,"You and your family are shameless!"],[4062,4170,"Shameless,"],[4208,4375,"is announcing an engagement"],[4375,4579,"for a man who's not even on the market."],[4579,4721,"That is shameless."],[4721,4788,"Enough!"],[4821,4942,"You say one more word,"],[4942,5050,"and I will make sure"],[5050,5125,"that you don't see"],[5125,5280,"a dime of your breakup fee."],[5338,5438,"What breakup fee?"]],"39":[[75,291,"Madame Belmont must have paid her"],[291,400,"to break up with Desmond."],[400,546,"She's shameless."],[546,658,"Asking for more money"],[658,800,"after she's already been paid?"],[800,1005,"She's trying to extort the Belmont family."],[1017,1134,"What breakup fee?"],[1134,1222,"Calm down."],[1284,1418,"Look, I'm sure that Ms. Lawson"],[1418,1589,"just came here to cause a commotion."],[1589,1680,"So we should be"],[1680,1810,"gearing our anger towards her"],[1818,1989,"and not towards Madame Belmont."],[2010,2068,"Uh, no, no."],[2068,2185,"I did not do anything wrong."],[2231,2373,"You shouldn't be mad at me."],[2414,2540,"Miss Fairfax here, is the one"],[2540,2752,"who's engaged to my husband."],[2752,2857,"Husband?"],[2882,3061,"She must be crazy."],[3061,3182,"Your husband?"],[3236,3324,"You're delusional!"],[3324,3499,"You're just a clingy ex-girlfriend!"],[3499,3624,"I am the only one"],[3624,3770,"getting to marry Desmond!"],[3807,3941,"You do love"],[3941,4095,"my sloppy seconds, huh?"],[4120,4279,"You're insane."],[4287,4400,"Being his ex-girlfriend"],[4400,4542,"does not mean you're married."],[4542,4667,"You need a marriage certificate"],[4667,4721,"to be married."],[4721,4804,"But you wouldn't know that"],[4804,4971,"because you are so uncultured!"],[4971,5030,"Am I?"],[5251,5296,"Hm?"]],"40":[[1013,1088,"Read it."],[1234,1284,"No."],[1422,1468,"No."],[1484,1559,"No, no, no, no, no, no."],[1559,1643,"This can't be true."],[1676,1789,"Since Miss Fairfax"],[1789,1935,"seems to have lost her voice,"],[1935,2039,"let me fill you all in."],[2052,2243,"This is a marriage certificate."],[2306,2519,"Desmond and I have been married"],[2519,2736,"for ten years."],[3178,3278,"Which means,"],[3319,3461,"Desmond cheated on me."],[3616,3912,"Miss Fairfax seduced a married man"],[3912,4083,"and my mother-in-law"],[4112,4183,"had the guts"],[4183,4391,"to flaunt their illicit engagement"],[4391,4617,"right here at a charity gala."],[4704,4800,"What did I say before?"],[4825,4884,"Right."],[4913,5163,"Bigamy is illegal."],[5213,5384,"You knew about this."]],"41":[[12,171,"You knew Desmond was married"],[171,296,"and you pushed for an engagement"],[296,383,"to my daughter."],[383,533,"Madam Fairfax,"],[533,663,"Desmond and Beatrice"],[663,846,"are getting divorced soon."],[925,1201,"Madeline is a much better fit for him."],[1230,1463,"I just, I wanted to hurry things along."],[1476,1705,"At the expense of my daughter?"],[1785,1901,"What will everyone think"],[1901,2072,"when news of this disaster"],[2072,2147,"gets around?"],[2352,2431,"She's right."],[2456,2594,"Madame Belmont should have waited"],[2594,2752,"until the divorce was finalized."],[2752,2890,"She knew Desmond was married"],[2890,3003,"and still had the nerve"],[3003,3144,"to announce a new engagement."],[3144,3224,"Desmond,"],[3224,3357,"I want to hear it from you, okay?"],[3357,3545,"Are you really married to her?"],[3545,3778,"Yes, yes, yes, I'm fucking married."],[3824,4162,"I've been married for the last ten years."],[4446,4567,"To my first love."],[4779,4934,"To my last love."]],"42":[[41,154,"Y'all hear that?"],[316,608,"Beatrice Lawson, is my wife."],[2869,3123,"Are, are you happy now?"],[3148,3378,"Let's, let's go home."],[3499,3732,"Talk about all of this."],[3824,3945,"Oh, Desmond,"],[4012,4162,"did I forget to mention?"],[4487,4646,"We're already divorced."]],"43":[[120,196,"We're not."],[321,396,"Don't say that."],[517,725,"Do you think I only recently"],[725,855,"found out about you cheating?"],[913,971,"No."],[1009,1272,"I've known for a long time."],[1297,1447,"All those work trips."],[1447,1710,"Those late nights at the office."],[1751,1947,"Come on, you were never subtle."],[1997,2143,"You flaunted her."],[2193,2369,"Like she was some sort of prize"],[2369,2573,"while you just tied me down,"],[2573,2836,"refusing to get a divorce from me."],[2861,3169,"Do you have any idea what that felt like?"],[3249,3440,"It felt like a knife"],[3440,3678,"was being drove into my chest,"],[3678,3908,"over and over again."],[3908,4262,"But somehow, my heart kept beating,"],[4262,4587,"kept loving you through every lie."],[4692,4788,"Not anymore."],[4842,4942,"That ends today."]],"44":[[462,617,"Refusing to get a divorce,"],[617,846,"do you have any idea what that felt like?"],[930,1030,"She's brave."],[1084,1180,"That's my girl."],[1230,1368,"Yes, she is, sir."],[1388,1522,"Let's go check out the live show."],[1918,2097,"Madeline, honey, let's go."],[2097,2147,"This is enough"],[2147,2273,"embarrassment already."],[2273,2339,"No!"],[2360,2494,"They are getting divorced."],[2494,2631,"We can still be together."],[2727,2915,"Wow, Beatrice."],[2927,3161,"That was a sad, pitiful story."],[3186,3324,"But since you don't want Desmond,"],[3324,3390,"you can go ahead"],[3390,3478,"and pack up and leave."],[3511,3641,"I'm surprised you're still alive"],[3641,3720,"after the other night."],[4029,4104,"Other night?"],[4483,4600,"What did you do to her?"]],"45":[[133,233,"Nothing, I um,"],[279,337,"I..."],[638,875,"Then why did you stay the other night?"],[921,1121,"What did you do to her?"],[1197,1355,"So it was her, after all."],[1397,1497,"I was right."],[1618,1797,"My, my friend said she saw"],[1797,1906,"Beatrice going to a hotel"],[1906,2027,"with two random men."],[2060,2131,"And who knows what"],[2131,2218,"could have happened,"],[2218,2314,"They could have killed her."],[2348,2427,"Or worse."],[2460,2510,"Here."],[2811,2940,"I have evidence to prove it."],[3228,3420,"Thank you, Madeline."],[3420,3595,"Now I have all the proof I need."],[3595,3803,"How did you get that photo, Madeline?"],[3878,4016,"My friend took the picture."],[4037,4145,"After she saw you"],[4145,4233,"go into that hotel room"],[4233,4316,"with those men."],[4333,4533,"But if your friend saw me"],[4533,4650,"go in to the hotel room,"],[4650,4750,"how did she get the picture"],[4750,4942,"from inside the hotel room?"]],"46":[[12,225,"Unless your friend"],[225,371,"was one of the attackers"],[371,492,"in the room with me."],[504,621,"The attackers confessed"],[621,721,"pretty immediately."],[721,813,"They just wouldn't admit"],[813,967,"who specifically hired them."],[967,1197,"All they would say was that"],[1197,1301,"it was someone"],[1380,1543,"connected to the Belmont family."],[1589,1676,"Since you're the person"],[1676,1793,"they sent the picture to,"],[1851,1910,"that means you're the one"],[1910,1976,"who hired them."],[2189,2268,"Liar!"],[2285,2369,"She's lying!"],[2369,2506,"I didn't hire anyone!"],[2519,2773,"Then how did you get the photo, Madeline?"],[2902,3040,"We have all the proof we need."],[3040,3174,"The authorities should be here soon"],[3174,3253,"to arrest you."],[3253,3566,"I really, really hope you enjoy jail."],[3620,3707,"You set me up."],[3753,3974,"They must have done something to you."],[3974,4041,"You couldn't have fought"],[4041,4179,"three men off by yourself."],[4179,4316,"No, no, you're right."],[4316,4542,"I was drugged and I was tied up."],[4608,4850,"Thankfully, someone rescued me."],[4979,5121,"Someone saved you?"],[5121,5201,"Well, where's your knight"],[5201,5288,"in shining armor now?"],[5301,5351,"Huh?"],[5367,5451,"You're a liar!"],[5451,5580,"Nobody saved you!"],[5718,5780,"I did."]],"47":[[959,1030,"I did."],[2635,2765,"I saw what you did back there."],[2882,2977,"It was pretty cool."],[3174,3336,"Beatrice, it's so good to see you."],[3353,3561,"Oh my God, that's Damian Crowley."],[3599,3745,"What is he doing here?"],[3774,3924,"And it looks like he's really"],[3924,4079,"close to Beatrice Lawson."],[4079,4212,"I heard he never attends"],[4212,4366,"formal events like this."],[4391,4604,"So is he here just for Beatrice?"],[4654,4750,"I can't believe it."],[4817,4963,"She's married to Desmond"],[4963,5150,"and close to Damian,"],[5163,5388,"the two richest men in L.A.?"]],"48":[[0,125,"Mr. Crowley."],[125,204,"Well, I thought we were"],[204,291,"on a first-name basis"],[291,408,"after what happened last time."],[446,546,"Just call me Damian."],[663,788,"I was just having dinner next door"],[788,892,"and I heard some commotion."],[892,984,"Figured I'd drop by."],[984,1042,"I hope you don't mind"],[1042,1142,"if I crash the party."],[1234,1380,"Sorry for disturbing your dinner."],[1388,1522,"No, it's not your fault."],[1555,1630,"Besides, I feel like"],[1630,1764,"I could be of assistance here."],[1764,1851,"You see, I was there"],[1851,1960,"the night of the attack."],[1960,2056,"Ms. Lawson was taken"],[2056,2147,"by two assailants"],[2147,2260,"into a hotel room."],[2298,2419,"Luckily, we got there in time"],[2419,2523,"before the situation"],[2523,2640,"escalated any further."],[2656,2723,"It's true."],[2756,2861,"Mr. Crowley intervened"],[2861,3019,"and Ms. Lawson was unharmed"],[3019,3203,"except for the injuries to her wrist."],[3365,3486,"How would Damian Crowley"],[3486,3582,"happen to be at the hotel"],[3582,3778,"at the right time to rescue Beatrice?"],[3799,3912,"What makes her so lucky?"],[3945,4070,"So now that that's settled,"],[4070,4233,"I would like to speak to you in private."],[4625,4746,"I have a proposal for you."],[5134,5397,"Thank you, truly, for saving my wife."],[5480,5751,"Unfortunately, she's not going anywhere"],[5751,5910,"with you privately."]],"49":[[112,233,"That's for her to decide."],[367,450,"Enough!"],[654,880,"You have no right to thank anyone"],[880,980,"on my behalf."],[1101,1259,"I was serious about the divorce."],[1259,1343,"You made your choice."],[1343,1472,"I'm just making it official."],[1497,1576,"Beatrice."],[1689,1789,"Our marriage is over."],[1839,1939,"You don't mean that."],[2097,2168,"I love you."],[2402,2665,"Love is sacred."],[2752,2923,"You don't get to use those words to me."],[2986,3123,"Now go be a good little son"],[3123,3253,"like your mom always wanted."],[3357,3465,"Go marry Madeline."],[4083,4212,"Madeline Fairfax."],[4233,4316,"Madame Belmont,"],[4316,4542,"I'm placing you both under arrest."],[4542,4708,"You have the right to remain silent."]],"50":[[129,162,"What the-"],[175,208,"No!"],[208,329,"No, you don't have the right!"],[329,433,"You can't do this to me!"],[433,513,"Madeline, Madeline,"],[513,642,"I'll contact the lawyer."],[642,759,"Don't be afraid!"],[759,938,"We will get you out of this."],[938,1055,"Madeline did everything,"],[1055,1201,"I had nothing to do with that."],[1201,1351,"Ma'am, Ms. Lawson"],[1351,1451,"was seen at the hotel"],[1451,1547,"meeting with you."],[1547,1622,"Now we believe"],[1622,1722,"you're an accomplice,"],[1722,1814,"and we will be"],[1814,1947,"looking into this further."],[1968,2031,"Let's go guys,"],[2031,2085,"get them out of here."],[2085,2160,"No!"],[2356,2423,"Desmond!"],[2464,2581,"You're not seriously"],[2581,2686,"choosing this low-life"],[2686,2794,"over your mother!"],[2836,2907,"I'm your mother,"],[2907,3028,"you can't do this to me!"],[3098,3265,"I can't let my own mother go to jail."],[3274,3386,"I'm gonna fix that,"],[3399,3482,"and then we'll talk,"],[3495,3570,"we'll talk."],[4300,4396,"Now that that's done,"],[4425,4525,"and since we're already here,"],[4525,4604,"can I buy you a drink?"]],"51":[[346,500,"That's a strong drink for a girl."],[617,779,"Strong women"],[825,963,"deserve a strong drink."],[1242,1301,"Cheers,"],[1380,1493,"on your victory tonight."],[2114,2202,"So,"],[2289,2344,"what did you want to"],[2344,2427,"speak with me about?"],[2469,2552,"I was just wondering"],[2552,2648,"if you were still interested"],[2648,2756,"in being my secretary."],[2790,2857,"Really?"],[3015,3174,"I thought my outfit choices"],[3174,3294,"weren't up to your standards."],[3315,3407,"That's not what I meant."],[3561,3653,"Then what did you mean?"],[3707,3824,"I just meant that..."],[4066,4116,"You should only"],[4116,4258,"dress like that for me."],[4421,4471,"Mmm."],[4525,4575,"Never mind."],[4604,4721,"So about the job,"],[4746,4946,"your base salary's gonna start at 400k."],[4967,5067,"And then I'm gonna give you"],[5067,5184,"a bonus of 100k,"],[5184,5347,"bringing your total to 500k."],[5367,5551,"Plus, I'm gonna offer you stock options,"],[5551,5672,"so if you stay with the company"],[5672,5784,"for the first three years,"],[5801,5930,"your total compensation's"],[5930,6072,"gonna be a million."],[6101,6185,"Over a million."]],"52":[[33,287,"That's a very generous offer,"],[325,412,"Mr. Crowley."],[479,558,"Damian."],[709,759,"Sorry,"],[850,930,"can't call you that."],[1209,1255,"Why?"],[1330,1393,"Because,"],[1409,1564,"from now on, you're my boss."],[2093,2156,"Okay."],[2973,3069,"How about in the office"],[3069,3194,"you call me Mr. Crowley,"],[3194,3278,"but in private,"],[3541,3641,"you call me Damian?"],[3724,4041,"Is he flirting with me?"],[4320,4383,"You got it,"],[4525,4587,"boss."],[4700,4746,"Great,"],[4838,4975,"and since we live in the same building,"],[4975,5046,"how about I give you"],[5046,5125,"a ride home tonight?"]],"53":[[554,892,"I'm sorry about all of this, Desmond."],[921,1126,"I should never have tried"],[1126,1284,"to get you to marry Madeline."],[1313,1401,"I didn't know"],[1401,1697,"she was capable of something so vile."],[1697,1864,"Clearly, she's not a fit"],[1864,2035,"for the Belmont family after all."],[2077,2277,"And the way she tried to throw me"],[2277,2498,"under the bus at the police station,"],[2498,2702,"saying it was my idea"],[2727,3007,"to hire those men to assault Beatrice?"],[3007,3190,"What a wicked accusation to make."],[3399,3628,"You should relax."],[3653,3891,"Tomorrow, we will start the search"],[3891,4041,"for a suitable wife for you,"],[4041,4204,"once we get all this nonsense"],[4204,4320,"with Beatrice sorted."],[4320,4396,"You didn't seem to"],[4396,4637,"understand me before, Mother."]],"54":[[241,633,"Beatrice and I are not getting divorced."],[788,1151,"But, son, you already are."],[1151,1276,"Then we'll get remarried."],[1426,1701,"You can have any woman you want,"],[1701,1805,"why her?"],[1805,2064,"I had one line, Mother."],[2160,2352,"And you crossed it."],[2389,2540,"Therefore, first thing"],[2540,2640,"in the morning tomorrow,"],[2640,2740,"you'll be moving into"],[2740,2898,"the retirement home I mentioned."],[2902,2990,"What?"],[2990,3161,"You have tonight to pack your things,"],[3161,3370,"and Cullen will have a car ready for you"],[3370,3449,"in the morning."],[3449,3557,"I'm your mother!"],[3574,3703,"You can't do this to me!"],[3703,3837,"Because you're my mother,"],[3837,4012,"you're not in jail."]],"55":[[100,387,"Beatrice is my wife."],[500,583,"Till death"],[646,759,"do us part."],[1134,1247,"OMG!"],[1247,1413,"Congrats on the new job!"],[1413,1522,"I for real think"],[1522,1672,"Damian has the hots for you."],[1672,1814,"He does not!"],[1814,1910,"He's my boss."],[1947,2106,"Okay, but he showed up"],[2106,2264,"at the gala just for you,"],[2289,2452,"took you for drinks after,"],[2452,2585,"and then offered you"],[2585,2665,"a huge"],[2665,2915,"compensation package in person"],[2915,3044,"when he's the CEO."],[3044,3278,"Girl, just marry him already."],[3357,3566,"Okay, I clearly remember"],[3566,3824,"someone saying he's an asshole."],[3832,3999,"Hey, people can change."],[4070,4254,"Besides, he's so hot."],[4254,4304,"I know."],[4304,4400,"And you're single."],[4571,4633,"Stop."],[4850,4896,"So, who?"],[4896,5034,"Okay, uh, Gordon's calling me."],[5309,5359,"Hello?"],[5359,5568,"Ms. Lawson, good morning."],[5593,5739,"I realize your first day of work"],[5739,5847,"isn't until next week."],[5847,6072,"However, if you're available tomorrow,"],[6072,6327,"Mr. Crowley would like to take you"],[6327,6506,"on an emergency business trip."],[6527,6760,"He would greatly appreciate your help."]],"56":[[12,100,"I mean, of course."],[100,208,"It's my job, after all."],[208,316,"Bravo."],[337,529,"I'll provide all the details shortly."],[554,596,"Okay,"],[596,658,"thank you."],[859,913,"Spill."],[984,1217,"I am leaving tomorrow"],[1217,1351,"to go on a business trip."],[1501,1705,"Okay, we are so packing you"],[1705,1856,"matching lingerie"],[1856,1997,"and sexy clothes. - Hm?"],[2002,2056,"Mhm."],[2919,3003,"Thank you."],[3269,3345,"This is the schedule"],[3345,3474,"for the next few days."],[3532,3611,"Got it, thank you."],[3645,3841,"Beatrice, what's my agenda for the day?"],[3853,3978,"Well, tonight, you have cocktails"],[3978,4049,"with Mr. Murphy"],[4049,4220,"from Quantum Technology at seven."],[4270,4366,"And then tomorrow,"],[4366,4537,"you have a lunch with Senator Owens."],[4554,4750,"And then you have planned dinner"],[4750,4863,"with your executive team."],[4921,5034,"You memorized all that?"],[5034,5084,"Yes,"],[5084,5155,"on the plane."]],"57":[[0,158,"What's my agenda for the week?"],[175,241,"You're just visiting"],[241,312,"NobleQuest Group's"],[312,425,"subsidiary companies"],[425,525,"doing inspections."],[558,621,"Thank you."],[1021,1084,"Alright."],[1151,1238,"I'm gonna go lie down."],[1288,1443,"Wake me up in fifteen, alright?"],[1443,1530,"I'll take you guys out"],[1530,1597,"for some good food"],[1597,1697,"before cocktail hour."],[1743,1826,"Of course."],[2118,2214,"Well, it's so great"],[2214,2318,"to have you here, Beatrice."],[2318,2398,"Normally, the boss would be"],[2398,2473,"working us to death."],[2473,2594,"But now he's taking us out"],[2594,2711,"for some good food."],[2711,2836,"Never seen that happen before."],[2836,2998,"I'm sure it's not because of me."],[3232,3403,"No, no, certainly not."],[3457,3616,"But you do need to rest a little too,"],[3616,3703,"Ms. Lawson."],[3762,3912,"Your room is over there."],[4016,4108,"Get settled in."],[4208,4433,"We'll be back in fifteen."],[4612,4679,"Thank you."],[4792,4913,"Wait, Damian and I"],[4913,5088,"are sharing this suite alone?"]],"58":[[750,842,"She arrived at the airport"],[842,950,"this morning, Mr. Belmont."],[975,1067,"It's unclear where she went,"],[1067,1184,"but it seems she traveled"],[1184,1288,"with Mr. Crowley."],[1401,1597,"What is he doing with my wife?"],[1851,1901,"What in the-"],[1901,2006,"I'm coming in!"],[2097,2177,"Come on!"],[2581,2644,"Desmond."],[2711,2798,"Where is she?"],[2965,3078,"I don't know what you're talking about."],[3078,3269,"No, don't play dumb with me, Violet."],[3336,3478,"Where is Beatrice?"],[3478,3541,"I know."],[3541,3682,"I know she went to the airport."],[3699,3774,"So where?"]],"59":[[16,171,"Oh, so you're stalking now."],[241,400,"You know, this will make great evidence"],[400,533,"when your divorce is finalized."],[533,704,"I'm not getting a divorce."],[750,975,"You don't even want to be with her."],[975,1117,"You were having an affair."],[1117,1313,"Don't torture her any longer."],[1330,1418,"My personal life"],[1418,1559,"is none of your concern."],[1559,1647,"Out of my way."],[1876,2010,"Desmond, what are you doing?"],[2202,2264,"Stop!"],[3019,3107,"If you don't stop,"],[3107,3286,"I'm gonna call the police right now."],[3837,3912,"What are you doing?"],[4029,4112,"Cincinnati?"],[4162,4316,"What is she doing there?"]],"60":[[325,387,"Desmond!"],[638,804,"Oh, crap."],[1864,1989,"It's been 15 minutes."],[1989,2068,"Time to get up."],[2640,2744,"Please leave your message"],[2744,2848,"after the tone."],[2861,3032,"Hey, heads up."],[3128,3303,"I think Desmond's coming to Cincinnati."],[3561,3636,"Mr. Crowley?"]],"61":[[100,233,"Okay, I need to wake him."],[233,396,"I just was not expecting him"],[396,546,"to be shirtless."],[579,684,"But this is my job."],[721,829,"I just, I'll have to get over it."],[875,1005,"Uh, Mr. Crowley,"],[1005,1192,"it's, it's been 15 minutes."],[1192,1276,"It's time to wake up."],[1522,1618,"Mr. Crowley?"],[1826,1926,"Wake up."],[2006,2181,"Now I see why Killian and Gordon"],[2181,2310,"ran out of here so quickly."],[2469,2527,"Okay."],[3003,3203,"Uh, Mr. Crowley, hey, it's time..."],[4112,4191,"Wake up."],[4291,4404,"Wake up."],[4633,4750,"Wake up!"],[4821,4950,"Wake up!"],[5463,5593,"This is just a dream,"],[5663,5730,"right?"]],"62":[[838,967,"No, no, no, no, no, no, no, no."],[967,1159,"I cannot be kissing my boss."],[1201,1359,"No! On my first day of work?"],[1359,1405,"No!"],[1455,1526,"Um..."],[1785,1935,"It's been 15 minutes, Damian."],[2064,2139,"Mr. Crowley?"],[2160,2373,"I, uh, I hung up your suit,"],[2373,2727,"and I'm gonna go get your car, now."],[2748,2836,"So yeah..."],[3048,3157,"What just happened?"],[3215,3411,"How did that turn into me kissing him?"],[3411,3687,"Well, us kissing each other."],[3920,4083,"Are you quite well, Ms. Lawson?"],[4083,4283,"Your face looks rather red."],[4429,4587,"I, yeah, I'm fine."],[4587,4704,"Yeah, everything's fine."],[4746,4846,"I know it can be difficult"],[4846,4988,"adjusting to Mr. Crowley's needs,"],[4988,5096,"but you'll get used to it."],[5138,5238,"His needs?"],[5251,5417,"What is Killian talking about?"],[5438,5513,"Oh, God."],[5530,5672,"Beatrice, get your mind"],[5672,5780,"out of the gutter."],[5797,5960,"The car is ready, sir."],[6010,6068,"All right."],[6177,6285,"Let's go, guys."],[6539,6656,"Let's do it."]],"63":[[930,1176,"Mr. Crowley, so glad you could make it."],[1209,1334,"Allow me to introduce you"],[1334,1476,"to my niece, Isabelle."],[1534,1655,"I think you'll find you two"],[1655,1776,"are very well matched."],[2122,2202,"If Mr. Crowley knew"],[2202,2310,"he was gonna be set up tonight,"],[2310,2419,"he wouldn't have attended."],[2565,2623,"Oh, why's that?"],[2623,2736,"Is he seeing someone?"],[2748,2798,"No."],[2798,2919,"He's just not into dating."],[2973,3174,"Ah, I understand."],[3449,3570,"After this marriage,"],[3570,3624,"we'll have a nice spot"],[3624,3728,"for you at my company."],[4333,4517,"If, uh, if he's not into dating,"],[4575,4708,"who is that?"],[4788,4909,"Oh, that's Harper."],[4909,4971,"She and Mr. Crowley"],[4971,5059,"used to date years ago,"],[5059,5171,"but that's over now."],[5301,5388,"Mmm."],[5643,5747,"Anybody want a drink?"],[5776,5839,"Yeah."]],"64":[[300,367,"Really?"],[404,529,"He's a player, too?"],[613,729,"Men, they're all the same."],[767,834,"Whatever,"],[834,909,"it was just a mistake."],[909,996,"He's my boss,"],[1046,1126,"nothing else."],[1201,1330,"I don't understand."],[1384,1426,"What,"],[1426,1547,"are you dating her?"],[1589,1643,"No."],[1718,1885,"Not yet, but I'm going to soon."],[1885,1960,"I'm working on it."],[2060,2223,"I am so much better, though."],[2302,2581,"Look, come to my room and..."],[2640,2811,"let me remind you"],[2811,2915,"how good we were."],[3073,3174,"That's not happening."],[3257,3390,"Killian's gonna take you home."],[3420,3566,"We were good together."],[3678,3762,"You're not going to be able"],[3762,3866,"to replace me."],[3920,3962,"Just..."]],"65":[[200,362,"Hey, heads up."],[454,638,"I think Desmond's coming to Cincinnati."],[734,900,"Why won't he just leave me alone?"],[2548,2673,"I know you're not asleep."],[3094,3174,"How'd you know?"],[3215,3307,"Because if you were asleep,"],[3307,3382,"you'd be in the other room"],[3382,3507,"in your actual bed."],[3720,3845,"How was the rest of your evening?"],[3945,4016,"It's fine."],[4079,4149,"Mine too."],[4637,4975,"It's late, so I'm going to head to bed."]],"66":[[29,171,"I saw you watching me and Harper."],[342,400,"I wasn't."],[483,671,"No, I was standing there, and then I..."],[738,809,"I saw you."],[821,930,"But, don't worry,"],[930,1034,"I turned away before I saw you..."],[1180,1297,"Before you saw me what?"],[1443,1584,"Before you kissed her."],[1701,1789,"We didn't kiss."],[1960,2010,"Okay."],[2106,2202,"You don't believe me?"],[2289,2385,"You don't have to lie."],[2439,2515,"I'm used to my ex-husband"],[2515,2606,"lying to me all the time."],[2606,2857,"Trust me, the truth is much less painful."],[2869,2994,"Well, I'm telling the truth."],[3073,3207,"Harper and I didn't kiss."],[3290,3374,"I'm not in the business of"],[3374,3541,"entertaining my ex-girlfriends."],[3595,3703,"And trust me,"],[3766,3999,"I'm nothing like your ex-husband."],[4095,4141,"Oh."],[4275,4396,"When I'm in a relationship,"],[4504,4596,"I'm loyal."],[4688,4900,"So are you in a relationship?"],[4954,5000,"No."],[5088,5230,"But there is a girl that I like."],[5305,5397,"A girl that I want to be in a"],[5397,5572,"fully committed relationship with."],[5801,5876,"I see."]],"67":[[362,446,"I see it's late."],[446,638,"Like I said earlier, um..."],[809,863,"Goodnight,"],[967,1071,"Mr. Crowley."],[1505,1568,"Goodnight."],[2619,2777,"Ms. Lawson headed to the factory early"],[2777,2911,"to investigate a discrepancy."],[2911,3019,"She should return shortly."],[3161,3303,"Oh, I'm not"],[3303,3415,"concerned about that."],[3457,3516,"Oh."],[3941,3999,"Yeah."],[3999,4049,"Thank you."],[4170,4279,"Where the hell is my wife?"]],"68":[[0,62,"Apologies, sir."],[62,145,"I tried to prevent them"],[145,221,"from barging in."],[221,291,"Your wife?"],[312,433,"Your wife ain't here."],[462,571,"My assistant, however,"],[571,717,"is on-site dealing with a client."],[734,867,"She's not your assistant."],[880,1042,"She's way too overqualified-"],[1042,1080,"You're right,"],[1080,1197,"she is overqualified,"],[1197,1334,"and she still accepted the job."],[1426,1522,"I heard her last boss"],[1522,1634,"was a bit of a headache."],[1689,1789,"You're gonna tell me"],[1789,1947,"where my wife is, right now."],[2506,2715,"Huh, payroll sends thirty paychecks"],[2715,2886,"each week, but the manager did say"],[2886,3086,"there are only 28 employees"],[3086,3178,"on the team."],[3186,3307,"If he's cashing checks"],[3307,3470,"under two fake employees,"],[3536,3699,"he could be stealing thousands"],[3699,3795,"from the company."],[5067,5117,"So,"],[5163,5284,"do you guys believe the rumors"],[5284,5397,"that this place is haunted?"],[5442,5518,"Haunted?"],[5547,5659,"Who told you that?"],[5697,5776,"Well, the manager."],[5834,5943,"He was giving me a tour earlier,"],[5943,6114,"and he told me there are two employees"],[6114,6272,"who clock in every day"],[6302,6402,"but never show up for work."],[6489,6598,"Spooky, right?"],[6652,6823,"Are their names Jack and Emily Bates?"],[6856,6919,"Yes."],[6919,6973,"Yeah, yeah, yeah."],[6973,7052,"That is what he said."],[7052,7102,"Yeah."],[7127,7311,"I've been working here a long time,"],[7311,7499,"and I've never seen either of them."],[7511,7691,"But every day,"],[7716,7920,"their time cards are punched."],[7945,8095,"We asked our manager about it,"],[8116,8241,"but he said to drop it."],[8283,8412,"They haven't said anything since."],[8470,8550,"I see."]],"69":[[8,187,"Everything okay here, Ms. Lawson?"],[291,392,"Yes, fine."],[542,621,"But I would like to"],[621,775,"meet Jack and Emily Bates."],[900,1076,"That won't be a problem, will it?"],[1151,1276,"Of course."],[2177,2281,"The Bates"],[2402,2489,"are in here."],[3415,3874,"Ms. Lawson, I've been waiting for you."]],"70":[[116,179,"Sir,"],[279,350,"it appears that"],[350,425,"Ms. Lawson's phone"],[425,546,"has been disconnected."],[633,692,"What do you mean"],[692,792,"it's been disconnected?"],[792,921,"Well, call the factory then."],[921,1001,"I'm calling now, sir."],[1380,1488,"The line is busy."],[1584,1685,"Yo, what kind of business"],[1685,1789,"you running here, huh?"],[1789,1968,"Where is my wife?"],[2027,2118,"Killian, let's go."],[2394,2464,"Which factory?"],[2965,3140,"Beatrice."],[3286,3532,"Is it okay if I call you that?"],[3782,4108,"I'm glad you paid us a visit today."],[4533,4625,"I must say,"],[4625,4900,"you are a very attractive woman."],[4992,5276,"You've got a lot of fight in you as well."],[5505,5588,"Oh yeah."]],"71":[[62,171,"Smells so"],[241,337,"good."],[767,804,"Well,"],[867,1001,"it's too bad you kept asking"],[1001,1172,"all those questions."],[1209,1313,"Now I'll have to figure out"],[1313,1422,"what to do with you."],[1438,1760,"Or how to dispose of you, I should say."],[2844,3044,"Mm, come on now."],[3111,3157,"We can't have you"],[3157,3445,"bruising that pretty skin of yours."],[3545,3799,"So soft."],[3874,3995,"I bet Mr. Crowley's"],[3995,4212,"having the time of his life with you."],[4308,4579,"I wonder if he's willing to share."]],"72":[[154,266,"Call the factory again."],[287,383,"Tell them if they don't tell us"],[383,479,"Beatrice's whereabouts"],[479,579,"in the next 15 minutes,"],[579,684,"then I'm closing that place down"],[684,796,"and firing everyone."],[817,921,"On what grounds?"],[930,1076,"The workers would think that's extreme."],[1084,1192,"Well, I don't care."],[1192,1284,"If they don't respect her,"],[1284,1393,"they don't respect me."],[1405,1534,"I'm the CEO,"],[1534,1676,"and I can fire everyone there"],[1676,1747,"if I want."],[1776,1843,"Are you sure?"],[1872,1981,"We still don't have confirmation"],[1981,2114,"Ms. Lawson is actually missing."],[2143,2293,"perhaps she was just in the restroom."],[2331,2456,"If she was in the restroom,"],[2456,2610,"then she would have called back by now."],[2635,2773,"I trust my intuition."],[2802,2911,"They tell us where she is"],[2911,3044,"or that factory shuts down."],[3044,3123,"That's final."],[3553,3657,"So, do you think"],[3657,3895,"he's willing to share you with me?"],[3945,4016,"Or"],[4070,4170,"are you telling me"],[4170,4391,"I'm not good enough?"],[4425,4583,"Some men really think"],[4583,4742,"they can have whatever they want."],[4808,4925,"Disgusting."],[5000,5392,"Could it be that you like CEOs?"],[5426,5638,"Well, I can be a CEO too."],[5659,6172,"Once Mr. Crowley is out of the picture."]],"73":[[83,250,"With the money I'm getting"],[250,454,"from these ghost paychecks,"],[471,621,"soon I'll have his job."],[658,1121,"Maybe then, I'll be more to your liking."],[1272,1397,"If you agree,"],[1518,1722,"you can get out of this alive."],[1885,1964,"What do you say?"],[2227,2381,"Good girl."],[2690,2831,"What do you say"],[2865,3132,"we get this affair"],[3186,3541,"started right now?"],[4049,4183,"Let's go upstairs."],[4287,4512,"There's a bed in the break room up there,"],[4567,4767,"workers use on the night shift."],[4792,4988,"Oh, that perv actually thinks"],[4988,5121,"he has a chance."],[5155,5238,"Not today."],[5296,5576,"I will not be taken advantage of."],[7561,7674,"Are, are you mad?"]],"74":[[221,300,"Ms. Reed,"],[367,513,"Mr. Crowley threatened"],[513,654,"to shut down the factory"],[671,746,"unless I told him"],[746,980,"the whereabouts of Ms. Lawson."],[996,1146,"Well, where is she?"],[1209,1292,"I don't know."],[1292,1359,"I haven't seen her"],[1359,1463,"since the tour this morning."],[1497,1601,"Why should we be punished"],[1601,1780,"because his assistant ran off?"],[1780,1981,"Yeah, what's so special about her?"],[1981,2122,"This is our livelihoods."],[2139,2231,"We shouldn't be responsible"],[2231,2381,"for some woman we don't even know."],[2419,2481,"Ms. Reed,"],[2502,2665,"you and Mr. Crowley"],[2665,2777,"are pretty tight, right?"],[2848,2923,"Maybe you could talk to him?"],[2923,2986,"Enough!"],[3078,3299,"Mr. Crowley will be here any minute."],[3332,3415,"And you can ask him"],[3415,3545,"your questions directly."],[3620,3678,"Okay."],[3874,3953,"Damian."],[3962,4095,"Where the hell is Ms. Lawson?"],[4241,4354,"I, I don't know."],[4508,4717,"Which one of you is Daniel Ward?"],[4771,4921,"Mr. Crowley, I am."],[4946,5080,"You're the manager here, right?"],[5080,5130,"Correct."],[5171,5238,"Then why the hell"],[5238,5359,"did my assistant go missing"],[5359,5451,"under your watch?"]],"75":[[12,70,"I don't know."],[70,191,"I gave her a tour this morning"],[191,383,"and nowhere to be found."],[779,913,"Sounds like a pretty good story,"],[913,1013,"but I don't buy it."],[1013,1101,"Where is she?"],[1146,1276,"Mr. Crowley, who is this?"],[1363,1434,"I don't know."],[1434,1630,"I saw her at the tour this morning, okay?"],[1826,1989,"Where is my wife?"],[1989,2085,"You better start talking"],[2085,2285,"unless you want to fucking die."],[2831,2948,"Do I need to count?"],[3019,3136,"Ten seconds."],[3203,3299,"Nine."],[3353,3428,"Eight."],[3478,3566,"Seven."],[3607,3687,"Six."],[3687,3799,"Damian, enough!"],[3841,3995,"You can't just have people come in here"],[3995,4162,"harassing your employees."],[4187,4362,"These people put in good work for you."],[4383,4517,"Yeah, why are you punishing us"],[4517,4629,"over some random woman?"],[4642,4708,"What makes you think"],[4708,4808,"we'd even want to work for you"],[4808,4879,"after this?"],[4904,4975,"You're putting some woman"],[4975,5084,"you barely know over people"],[5084,5251,"who've worked for you for years."],[5280,5401,"You said you're not into her,"],[5401,5568,"yet here you are causing a scene?"],[5634,5722,"Why do you care so much"],[5722,5826,"about a married woman?"],[6306,6448,"Are you involved with her?"]],"76":[[25,112,"Harper, just because"],[112,200,"I don't want to be with you"],[200,287,"doesn't mean I'm involved"],[287,375,"with another woman."],[592,742,"You want to know why I care so much?"],[779,917,"It's because she's diligent."],[975,1105,"She's focused on the details,"],[1105,1222,"unlike you, who's only focused"],[1222,1305,"on my love life."],[1343,1472,"In Beatrice's first day,"],[1472,1547,"she's discovered"],[1547,1751,"over hundreds of ghost payroll checks."],[1785,1856,"Maybe if you'd been"],[1856,1985,"more focused on your job"],[1985,2152,"and less on my personal affairs,"],[2173,2260,"then you would have caught it"],[2260,2377,"and brought it to me sooner."],[2489,2715,"You've barely known her for a day?"],[2827,2965,"How do you know she's not lying?"],[2986,3261,"Ms. Lawson has no reason to lie to me."],[3261,3332,"You don't know that."],[3357,3490,"She's a stranger."],[3490,3682,"You had your associates"],[3682,3791,"assault us"],[3791,3920,"without any proof"],[3920,4124,"that Ms. Lawson was telling the truth."],[4813,4954,"Who says there's no proof?"]],"77":[[279,458,"Oh my god, you're injured."],[458,521,"We need to get you"],[521,654,"to a hospital right now."],[654,846,"No, no we've got to deal with this first."],[1760,1997,"Thank God, the fall was only one story."],[2097,2285,"And some workers outside helped me."],[2327,2489,"But Mr. Ward,"],[2602,2773,"is there something you would like to admit"],[2773,2907,"to Mr. Crowley?"],[3211,3290,"Admit what?"],[3365,3490,"I've been running this factory"],[3490,3549,"for years,"],[3549,3678,"never had any issues,"],[3678,3799,"till you showed up."],[3807,3970,"She's accusing us of being liars"],[3970,4137,"and trying to ruin our reputations."]],"78":[[0,162,"This is a nice little act,"],[162,258,"but you can't just show up"],[258,450,"with all these false accusations"],[450,604,"just to impress Damian."],[663,880,"I'm not trying to impress anyone."],[880,1042,"I'm doing my job."],[1138,1280,"Unlike some people here."],[1380,1455,"You little..."],[2043,2156,"Let Ms. Lawson finish"],[2156,2264,"what she was about to say"],[2264,2348,"unless you don't want to work"],[2348,2464,"at this company anymore."],[2698,2927,"Mr. Ward and Mr. Lewis"],[2927,3148,"have been cashing ghost paychecks"],[3178,3294,"for years,"],[3357,3445,"stealing upwards of"],[3445,3595,"five-hundred- thousand dollars."],[3782,3937,"And if you don't believe me,"],[4141,4233,"here's the proof."],[4308,4391,"With the money I'm getting"],[4391,4625,"from these ghost paychecks,"],[4667,4783,"soon I'll have his job."]],"79":[[692,829,"You two will be dealt with."],[1981,2056,"Hey,"],[2081,2156,"Beatrice."],[2352,2494,"Desmond, what are you doing here?"],[2560,2752,"We're divorced, remember?"],[2752,2873,"You signed the paperwork."],[2923,2998,"I'm sorry."],[3103,3203,"It's all my fault."],[3203,3265,"Please."],[3319,3449,"Please give me another chance."],[3449,3666,"I swear I'll do right by you this time."],[3753,3849,"No, you won't."],[3958,4141,"I didn't want to be with her."],[4191,4496,"I, I always loved you, Beatrice."],[4504,4575,"Just stop."],[4575,4708,"There's nothing you can say"],[4708,4825,"that's going to change my mind."],[4892,5025,"Hey, we're getting divorced"],[5025,5171,"so both of us can move on."],[5171,5230,"Okay?"],[5313,5380,"With who?"],[5463,5538,"Damian?"],[5568,5659,"It's not like that,"],[5659,5726,"I'm his assistant."],[5726,5943,"You could be anyone else's assistant."],[5943,6164,"You can get a job anywhere else."],[6368,6443,"You're leaving it."],[6443,6606,"I'm not quitting that job."],[6606,6648,"I'm not."],[6648,6790,"I happen to like my job."],[6844,6890,"Really?"],[7102,7232,"What is he doing here?"],[7278,7336,"Yeah,"],[7403,7457,"really."],[7511,7682,"I mean, the work's a nice change of pace"],[7682,7795,"and I get travel."],[7828,7870,"So..."],[7912,8145,"I could pay for your travels."],[8195,8400,"You don't need to be keeping this job"],[8400,8529,"when you can be at home"],[8529,8671,"preparing for our family."],[8879,8967,"She's leaving."]],"80":[[29,70,"I don't think"],[70,196,"that's your decision to make."],[279,362,"She got injured"],[362,513,"on the job working for you."],[513,667,"She's not in the right headspace"],[667,788,"to make her own decisions."],[788,975,"Stop speaking for me!"],[1096,1213,"I can make my own decisions."],[1213,1355,"I don't need you making them for me."],[1355,1405,"Okay?"],[1476,1568,"I agree with that."],[1714,1868,"Beatrice, what do you want to do?"],[2540,2644,"I'm keeping my job."],[2719,2786,"That's great."],[2957,3107,"But first you need to recover."],[3144,3190,"Alright?"],[3190,3319,"So I'm giving you the next week off."],[3319,3411,"And second thing,"],[3449,3570,"you're not going into the field"],[3570,3682,"by yourself anymore."],[3682,3807,"I can't have any more mishaps."],[3853,3949,"I'll prepare the private jet"],[3949,4066,"for you to come back with us."],[4095,4179,"We came here together"],[4179,4233,"on business."],[4233,4316,"We'll be leaving"],[4391,4458,"together."],[4642,4813,"Killian will contact you shortly"],[4813,4892,"with details."]],"81":[[120,221,"What the hell was that?"],[275,517,"You got some nerve flirting with him"],[517,571,"in front of me."],[571,767,"Oh, Desmond."],[767,867,"Wow, your insecurities"],[867,1042,"are showing just a little bit."],[1084,1192,"Damian's my boss."],[1192,1334,"And no matter what you think,"],[1334,1530,"I'm not quitting my job."],[1555,1768,"You have no control over me."],[1814,1881,"Okay?"],[1897,2047,"So stop trying to make me do"],[2047,2118,"whatever you want to do."],[2118,2239,"Now please, will you just leave"],[2239,2385,"so I can finally get some rest?"],[4212,4279,"Ready to go?"],[4483,4654,"She's not going anywhere with you."],[4867,5034,"Yes, I am."]],"82":[[25,262,"You visited her every single day."],[296,433,"You expect me to believe"],[433,633,"that you don't have ulterior motives?"],[684,825,"Ms. Lawson's my client."],[863,905,"She got injured"],[905,1051,"on a work-related accident."],[1051,1172,"I take my employee's"],[1201,1343,"well-being very seriously."],[1376,1438,"That includes"],[1438,1580,"listening to their desires."],[1730,1989,"My wife and I will be leaving here today"],[1989,2043,"together."],[2043,2089,"No, we won't."],[2177,2327,"You're not my husband anymore."],[2327,2439,"Did you forget we got divorced?"],[2489,2548,"Honey."],[2585,2635,"Honey."],[2644,2686,"We can,"],[2736,2865,"we can take my jet."],[2944,3061,"Talk about this more"],[3111,3169,"at home."],[3169,3328,"I'm not going home with you."],[3328,3436,"I'm not doing that."],[3436,3516,"When are you going to realize"],[3516,3599,"it's too late?"],[3732,3987,"I don't want to be with you anymore."],[4049,4220,"I will not be forced"],[4220,4341,"to stay in a relationship"],[4341,4454,"where I am treated poorly."],[4700,4771,"It's over."],[4996,5046,"Let's go."],[5718,5797,"Beatrice,"],[5880,6093,"I don't care what you think."],[6118,6256,"We're not done."]],"83":[[342,454,"It's been five days"],[454,563,"and I haven't heard anything"],[563,633,"from Desmond."],[792,980,"Well, I suppose he finally understood"],[980,1151,"what I meant when I said it was over."],[2444,2510,"Let's go."],[2619,2660,"Hey!"],[3315,3420,"Look, Desmond, please."],[3420,3461,"Please."],[3461,3520,"We can just,"],[3520,3599,"we can go somewhere"],[3599,3661,"and talk about this"],[3661,3795,"like civilized people inside."],[3795,3832,"No,"],[3832,3912,"we can't."],[3966,4095,"You don't listen to me."],[4183,4316,"You just keep insisting"],[4316,4450,"that we get divorced."],[4871,4992,"Please, please, please, please."],[5451,5505,"Help!"],[6398,6439,"Okay,"],[6443,6489,"okay."],[6493,6539,"Look,"],[6539,6698,"our relationship faded."],[6706,6785,"That's all."],[6819,6848,"All right?"],[6848,6931,"I appreciate the years"],[6931,7011,"we had together."],[7032,7098,"I do."],[7123,7240,"I do, it's just, it's time."],[7269,7378,"It's just time for us to move on."],[7394,7424,"Mm."],[7424,7461,"Okay?"],[7465,7494,"Mm."],[7503,7536,"Stop!"],[7536,7636,"Stop, if you drive right now,"],[7636,7732,"you're gonna kill us."],[7807,7857,"Please,"],[7857,8033,"we have one life and that's it."],[8033,8099,"Please."],[8212,8287,"You're right."],[8366,8546,"We can't die now because,"],[8562,8729,"because then there'd be no,"],[8729,8883,"there'd be no Belmont heir."],[8883,8933,"Stop."],[8933,9059,"Maybe a child,"],[9075,9288,"a child will finally make you love me."],[9317,9384,"Stop."]],"84":[[1051,1121,"I'm sorry."],[1176,1226,"I'm so sorry."],[1226,1255,"No."],[1255,1313,"I'm so sorry."],[1313,1422,"Please, please, please, please,"],[1422,1451,"Stop!"],[1451,1501,"forgive me!"],[1501,1555,"No."],[1847,1918,"You know what?"],[2018,2173,"There's nothing to forgive,"],[2331,2414,"because we don't have"],[2414,2640,"anything anymore."],[2886,2998,"We were in love."],[3549,3724,"But you fell out of love with me."],[3766,3883,"You did, you did."],[4004,4112,"You hurt me."],[4262,4362,"You lied to me."],[5301,5472,"You betrayed our marriage."],[5472,5689,"There's no coming back from that."]],"85":[[25,150,"You will always be"],[196,358,"the boy I once loved."],[425,542,"But from now on,"],[754,855,"we are strangers."],[934,1055,"And if you can't accept that,"],[1055,1184,"I'll get a restraining order."],[1184,1493,"I will use everything I have"],[1509,1630,"to fight you,"],[1664,1785,"to get away from you,"],[1785,1964,"to hate you."],[1964,2110,"Is that what you want?"],[2256,2335,"No,"],[2335,2502,"leave us with the good memories."],[2569,2644,"Please,"],[2761,3086,"it is time for us to both move on."],[3261,3361,"Babe, Beatrice wait."],[3361,3436,"Beatrice..."]],"86":[[713,863,"Damian, what the fuck?"],[880,975,"I deserve that."],[1313,1451,"What are you doing here?"],[1497,1559,"I just thought that"],[1559,1697,"you might need some help,"],[1697,1801,"but I guess you don't."],[1893,2081,"No, I don't need your help."],[2168,2356,"I, I can handle that on my own."],[2356,2448,"I'm perfectly capable."],[2569,2606,"Wait."],[2727,2798,"Where are you going?"],[3103,3269,"Honestly, after all that?"],[3357,3432,"Anywhere."],[3549,3624,"I'm single."],[3691,3774,"I'm rich."],[3924,4016,"The world is my oyster."],[4104,4200,"Well, what about me?"],[4354,4433,"What about you?"],[4612,4700,"You're my boss..."],[4775,4829,"for now."],[4871,4942,"Yeah, and I want to be"],[4942,5021,"more than your boss."],[5021,5171,"I have feelings for you, Bea."],[5171,5342,"You're the girl that I was talking about."],[5451,5509,"I know."],[5580,5676,"I can't,"],[5676,5910,"I can't be with my boss again."],[5910,5980,"I mean, I've been there,"],[5980,6064,"I've done that."],[6089,6177,"I'm sorry."],[6177,6393,"I can't go there again, I can't."],[6685,6752,"Well, how about I give you"],[6752,6856,"my company, then?"],[7307,7365,"What?"]],"87":[[20,75,"Bea,"],[208,291,"you and I both know"],[291,425,"you are overqualified"],[425,567,"for this job, alright?"],[700,846,"And you could be my boss,"],[955,1088,"and I'll be your boyfriend."],[1217,1322,"How does that sound?"],[2619,2773,"That sounds perfect."],[5075,5184,"Our marriage is over."],[5663,5797,"Beatrice wasn't lying,"],[5922,6081,"she really has moved on."],[6177,6477,"I suppose I was just too selfish"],[6527,6623,"to believe it."]]}