{"1":[[1268,1468,"These ladies were specifically chosen for you,"],[1468,1644,"Mr. Haverbrook."],[2652,2840,"I'm not interested in this kind of service."],[3616,3828,"Since Mr. Haverbrook doesn't want you,"],[3840,3968,"then you'll have to strip naked"],[3976,4256,"and entertain the drunks and homeless outside."],[4292,4344,"No!"],[5528,5664,"I changed my mind."],[6632,6696,"So..."],[6868,7040,"You make a habit of this kind of work?"],[7088,7208,"It's not what you think."],[7212,7288,"Really?"],[7304,7516,"I thought this must be your normal gig."]],"2":[[340,420,"What?"],[420,556,"You thought you could satisfy me"],[556,716,"with the vanilla stuff?"],[716,820,"I changed my mind."],[820,924,"Can you please let me go?"],[924,1004,"Let you go?"],[1072,1180,"You came here by yourself."],[1180,1264,"Now you want to leave?"],[1380,1532,"I won't do it again..."],[1648,1800,"Please just let me go."],[3644,3792,"What, you having second thoughts?"],[4488,4588,"You sure, boss?"],[4604,4664,"Yeah,"],[4712,4840,"just giving her a warning."],[4872,5088,"So she doesn't try this risky shit again."],[5608,5776,"If you don't make the payment soon,"],[5776,5904,"we'll have to stop treatment."],[5932,6144,"Your mother's condition is not good."],[6716,6796,"Let's go."],[7508,7664,"You can do whatever you want, sir."]],"3":[[84,164,"Please..."],[248,384,"I've been begged before."],[452,592,"What makes you so different?"],[2456,2640,"Can I get paid first?"],[2756,2976,"I need twenty thousand dollars."],[3412,3540,"Now show me what you worth."],[4192,4280,"So quick."],[4396,4532,"Do I have to teach you how to do this?"],[4552,4712,"It's my first time."],[5680,5876,"Now let me show you..."],[6164,6300,"who's in control."],[7996,8116,"Good girl..."]],"4":[[488,744,"Sir, this is way more than I asked for."],[812,908,"Once we're out of here,"],[932,1088,"we're done, we never met."],[1148,1288,"Understood?"],[2512,2724,"Boss never brought girls home overnight."],[2744,2952,"Did he make an exception for her?"],[3192,3284,"What are you looking at?"],[3296,3468,"Do your job, or lose your pay."],[3480,3620,"Just get us back to the office."],[3644,3728,"Yes, sir."],[4360,4620,"With this, I'll be able to save Mom."],[5176,5316,"Give me that money!"]],"5":[[156,272,"Give me that money!"],[284,460,"No! I need that for Mom's surgery."],[460,528,"Give it back!"],[528,684,"Mom's gonna die anyway."],[696,888,"I will make better use of the money."],[1960,2108,"I can't give up..."],[2108,2260,"Mom needs me."],[2796,3044,"Deliver this to VIP room 2,"],[3044,3116,"and hurry up."],[3384,3544,"She never learns."],[3652,3772,"See that blonde over there?"],[3816,4032,"Oh, she, a curly little fox right there!"],[4092,4212,"Go out there, man!"],[4268,4352,"Oh..."],[4476,4548,"Clara."],[4576,4736,"I didn't expect to see you in here."],[4760,4868,"You're good at hiding."],[5280,5368,"What do you want?"],[5384,5480,"Relax."],[5532,5664,"I just want to talk."],[6112,6296,"Don't you need money?"],[6596,6680,"Pick it up."],[7608,7724,"I just thought of a fun game."],[7760,7952,"One drink, one hundred bucks."],[7984,8064,"What do you say?"],[8256,8356,"If I play your game,"],[8360,8452,"can I leave?"],[8476,8592,"Of course."],[9304,9500,"No, not like that."]],"6":[[724,900,"Damn it, you got my shoes dirty."],[904,1048,"These cost twenty grands."],[1048,1288,"No, that wasn't me, that wasn't my fault, I..."],[1484,1628,"Looks like you wanted more."],[2028,2148,"Such a pretty gal."],[2232,2460,"I should've had fun with you so much sooner."],[2468,2576,"Stay away from me."],[2612,2720,"Help, somebody!"],[2768,2888,"Help!"],[3036,3160,"Looks like you wanted more."],[3160,3276,"Stay away from me."],[3276,3352,"Help!"],[3520,3656,"Sir, I think that's Miss Wilson."],[3756,3832,"Should we go help her?"],[3832,3908,"No."],[4088,4228,"She brought this upon herself."],[4608,4728,"Help, somebody!"],[4804,4876,"Help!"]],"7":[[6,134,"Help, somebody!"],[134,240,"Help!"],[252,312,"Let her go!"],[904,1000,"Mr. Haverbrook,"],[1028,1144,"this is personal."],[1176,1272,"Let me settle it."],[1472,1588,"She came to me."],[1604,1800,"She said she couldn't pay her debts,"],[1812,1940,"and wanted other ways to settle it."],[1956,2064,"I was just helping."],[2072,2224,"It's not true. He's lying."],[2224,2324,"You're just a damn..."],[2324,2436,"Shut it!"],[2644,2696,"Here."],[2720,2828,"Her debts are paid."],[2852,3000,"And never bother her again."],[3068,3244,"All of this, over a bitch like her?"],[3520,3648,"Oh, you want trouble,"],[3980,4104,"and you got it."],[4484,4612,"Bring in the drinks."],[5152,5308,"Since you like drinking so much,"],[5324,5480,"I decided to treat you."],[5664,5756,"So, drink it."],[5852,5932,"All of it."],[5996,6104,"Mr. Haverbrook,"],[6120,6196,"that will kill me..."],[6196,6320,"Well, you got a choice then."],[6380,6636,"The liquor, or the lead."],[7504,7592,"Good."],[7592,7732,"Now just remember,"],[7812,8040,"she's under my protection."],[8204,8312,"Make sure he drinks it,"],[8376,8480,"every last drop."],[8484,8616,"You got it, boss."]],"8":[[672,752,"So..."],[864,988,"What happened to all your money?"],[1012,1112,"Why are you still broke?"],[1116,1292,"It's my mother's medical bills."],[1296,1488,"Why don't you get a real job?"],[1560,1732,"Or, was Andrew telling the truth?"],[1812,2044,"No, it's not like that..."],[2136,2276,"I just need money now."],[2296,2572,"My mom is really sick, she can't wait."],[2948,3196,"Yeah, Miss Wilson's mother's medical bills,"],[3212,3372,"charge to my account, please."],[3416,3468,"Yeah."],[4572,4736,"Thank you, Mr. Haverbrook."],[5072,5192,"How are you going to thank me?"],[5612,5736,"I have to go to work."],[6108,6292,"Why are you always running away?"],[7652,7744,"Not here..."],[7812,7892,"Why not?"],[7964,8088,"It's perfect."],[8176,8300,"You don't find this exciting?"],[8608,8732,"Mr. Haverbrook..."],[8748,8812,"Someone is here."],[8812,8964,"Your drink is here."],[9004,9228,"Don't worry, she won't come in."],[9280,9440,"Do you need me to bring your drink in?"],[9524,9588,"Please..."],[9724,9840,"What's going on?"],[9868,9960,"Are you alright?"]],"9":[[88,204,"What's going on?"],[252,348,"Are you alright?"],[464,532,"No one comes in"],[532,652,"without my permission!"],[744,920,"Understood, Mr. Haverbrook."],[960,1140,"Let me know if you need anything."],[1920,2124,"We won't be interrupted anymore."],[5016,5180,"I'll find a way to pay you back."],[5336,5460,"I don't need it."],[5624,5864,"It's better that we don't see each other again,"],[5900,5996,"and..."],[5996,6160,"I don't want to owe you anything."],[6160,6256,"So..."],[6256,6428,"I'll pay you back when I can..."],[7368,7640,"Boss, it seems like you just got dumped."],[8528,8612,"Clara?"],[8636,8752,"What are you doing here?"],[8768,8972,"Ryan, it's been a while."],[9148,9232,"You look tired."],[9260,9340,"How have you been?"],[9388,9576,"Had some rough days, but..."],[9636,9744,"Doing better now."],[9828,9972,"Still looking for a job."],[9988,10096,"That's great."],[10176,10368,"My father's been working at the Stark Group."],[10380,10576,"There's openings for junior positions."],[10584,10688,"The pay is decent."],[10688,10820,"Wanna give it a try?"],[10828,10936,"Really?"],[10992,11080,"Stark Group?"],[11104,11284,"That would be a dream."],[11284,11348,"Of course."],[11432,11544,"Weren't you the valedictorian"],[11544,11632,"in college?"],[11756,11864,"You'd be a great fit."],[11956,12096,"Thank you, Ryan."],[13348,13536,"You're the new janitor, right?"],[13568,13732,"Why are you just standing there?"],[13744,13888,"Clean the shit up!"]],"10":[[28,200,"Why are you just standing there?"],[220,332,"Clean that shit up."],[368,436,"I'm not..."],[436,484,"Shut it!"],[528,684,"Clean it up, now."],[1456,1696,"Clara is our new employee,"],[1720,1828,"not a janitor."],[1844,2032,"You guys are being really rude."],[2096,2380,"Mr. Levine, we were totally just joking..."],[2380,2460,"Were you?"],[2564,2676,"Respect is a basic"],[2676,2828,"workplace requirement."],[3060,3140,"Remember that."],[3952,4064,"Ignore them."],[4200,4324,"Let me show you around."],[4688,4816,"You're gonna love it here."],[4860,5012,"This company's really resourceful."],[5032,5188,"We have our meeting rooms over there"],[5196,5388,"and fantastic things you'll see in the..."],[5760,5840,"Clara!"],[6760,6828,"Clara,"],[6908,7004,"are you okay?"],[7116,7268,"Yeah, I'm fine."],[7792,7948,"Clara, this is Mr. Haverbrook,"],[7948,8088,"my father's business partner"],[8088,8284,"and CEO of Stark Company."],[8284,8436,"There's no need to introduce us."],[8736,8848,"You two know each other?"],[9016,9248,"No, I mean, why would I know someone as..."],[9316,9444,"powerful as him..."],[9604,9764,"This is my first time meeting Miss Wilson"],[9764,9924,"in this... attire."],[10380,10460,"Don't mind him."],[10472,10636,"He's always this cold to everyone."],[11568,11664,"Clara,"],[11828,11940,"you're blushing."]],"11":[[32,248,"Clara, you're blushing."],[364,432,"No."],[432,680,"I know it's just really really hot in here."],[700,876,"I'm gonna go to work."],[952,1072,"My office? This way?"],[1072,1220,"Yeah, yeah, that way."],[2312,2480,"Finish these today."],[2532,2696,"Don't slack off."],[2880,3056,"This isn't part of my job."],[3076,3204,"If you don't finish them,"],[3240,3488,"don't bother coming into work tomorrow,"],[3488,3552,"okay?"],[5096,5232,"Mr. Haverbrook."],[5652,5824,"This isn't part of your job."],[5924,6004,"I know."],[6868,6948,"Beg me,"],[7120,7260,"I can help you out."],[7384,7504,"No, I can do it."],[7884,7960,"Are you ignoring me"],[7960,8080,"because you have Ryan now?"],[8204,8284,"What?"],[8332,8512,"Ryan's father will never accept you."],[8856,9024,"So instead of wasting your time with him,"],[9232,9388,"why not try your luck..."],[9428,9544,"with me."],[9784,9960,"I don't want to marry into wealth."],[9964,10160,"I can do this by myself, sir."],[10416,10560,"Good, Clara."],[10692,10860,"I'll be waiting..."],[11192,11380,"when you can no longer hold on."]],"12":[[340,596,"This is what you did overnight?"],[636,880,"Our interns can do better than this."],[988,1196,"I'm gonna give you another chance though."],[1240,1336,"Have these all done"],[1336,1436,"by the end of the day,"],[1436,1536,"okay?"],[3236,3456,"Katherine, are you trying to get fired?"],[3456,3588,"These files are blank."],[3724,3836,"That's impossible."],[3840,3996,"If you can't do your job right,"],[3996,4092,"then quit."],[4152,4304,"Stop wasting our time."],[4428,4532,"Clara Wilson,"],[4588,4704,"you did this."],[4732,4912,"You're trying to sabotage me."],[4932,5200,"Sorry, isn't that your job?"],[5240,5340,"Wait a second."],[5464,5636,"Did you pass off your work to others?"],[5652,5800,"No, no I just um..."],[5800,5864,"Katherine,"],[5892,6024,"if this happens one more time,"],[6024,6124,"You're fired."],[6152,6288,"No excuses here."],[6288,6384,"Good job."],[6876,7104,"I underestimated you, Clara Wilson."],[7220,7404,"Don't get too full of yourself."]],"13":[[256,388,"Mr. Haverbrook."],[404,540,"You impressed me today."],[704,880,"I just want to work in peace."],[1048,1212,"You have better options."],[1308,1372,"What?"],[1848,1956,"Be my lover."],[2164,2300,"And you can have everything."],[2664,2764,"Tempting offer."],[2880,3024,"Interested?"],[3104,3176,"No."],[3812,3908,"You sure?"],[3940,4100,"What can be earned with my body"],[4100,4252,"can easily be taken away."],[4324,4480,"I appreciate your help."],[4500,4600,"I'll get everything I want"],[4600,4712,"through hard work."],[5340,5520,"You think you can get rid of me that easily?"],[5896,6020,"What are you doing?"],[6196,6356,"Spend one more night with me."],[6564,6704,"And we'll be even."],[6928,7048,"You promise?"],[8004,8120,"What are you waiting for?"],[11620,11708,"Samantha."],[11776,11880,"Give me some money."],[11880,11992,"I need to get some drugs."],[11992,12048,"No."],[12048,12136,"I just got a job."],[12136,12284,"I don't have any money for you."],[12284,12468,"Fine. I'll go to the hospital"],[12468,12568,"and I'll ask mom."],[12568,12732,"And if she's triggered or something,"],[12768,12880,"that's on you."],[13536,13652,"If you go near mom,"],[13684,13812,"I will kill you."],[15108,15384,"From now on, I'm gonna start fresh."],[16052,16164,"Clara Wilson?"],[16944,17100,"You stole my bracelet."]],"14":[[32,160,"You stole my bracelet!"],[188,300,"What are you talking about?"],[300,416,"What bracelet?"],[448,572,"Stop lying!"],[572,808,"I left my bracelet on my desk last night,"],[808,900,"and now it's gone."],[916,1048,"Who else could have taken it but you?"],[1080,1144,"That's not true."],[1144,1364,"I didn't steal any of your things."],[1364,1464,"Okay, then why don't we"],[1464,1596,"check your desk, shall we?"],[1596,1652,"Okay, Catherine,"],[1652,1820,"you can't just go through my stuff."],[1836,1952,"Why, are you afraid"],[1952,2116,"we're gonna find it, or what?"],[2148,2224,"If she didn't do it,"],[2224,2428,"then why is she so nervous?"],[2496,2560,"Let's see."],[2704,2804,"Well, look!"],[2996,3128,"Here it is!"],[3884,4064,"What do you have to say for yourself now?"],[4140,4256,"I didn't take your bracelet."],[4256,4420,"I don't know why that was in my desk."],[4420,4528,"We have evidence now,"],[4528,4704,"and you're still lying?"],[4704,4820,"Wow!"],[4832,5104,"I never pegged the new girl as a thief."],[5104,5264,"She's broke."],[5288,5520,"People like her do this kind of thing."],[5552,5692,"Shameless."],[5696,5888,"I lost my headphones a couple days ago."],[5888,6000,"Could it be her?"],[6064,6160,"What are you talking about?"],[6160,6300,"I didn't steal anything!"],[6372,6600,"Maybe she has other stolen things on her."],[6668,6768,"What are you waiting for?"],[6800,6892,"Check her stuff."],[6892,6964,"What?"],[7168,7276,"Okay, stay away from me!"],[7276,7384,"No, don't touch me!"],[7412,7476,"Stop!"]],"15":[[92,140,"Stop!"],[420,672,"Manager, Clara stole my bracelet."],[672,848,"You have to give me justice."],[848,1032,"Clara, did you really steal it?"],[1056,1164,"No, I didn't steal it."],[1164,1324,"I don't know how it got in my desk."],[1324,1500,"Well, the evidence is right here."],[1540,1652,"You're fired."],[1864,1928,"Wait!"],[2032,2192,"Clara would never do that."],[2244,2452,"Mr. Levine, why are you defending her?"],[2452,2632,"We have evidence!"],[2704,2836,"Manager, you can't fire someone"],[2836,3016,"without theproper investigation."],[3016,3184,"The bracelet was in the drawer."],[3184,3320,"What more do you need?"],[3336,3524,"Katherine is the victim here."],[3524,3692,"And I need to do justice by her."],[3692,3860,"Look, I didn't steal the bracelet."],[3860,3964,"If you don't believe me,"],[3964,4036,"call the police"],[4036,4176,"and have them investigate."],[4196,4364,"Calling the police?"],[4364,4572,"Are you trying to ruin the company?"],[4588,4824,"Katherine's bracelet was stolen last night."],[4836,4956,"Where were you last night?"],[5352,5544,"I... I was..."],[5644,5744,"Oh, see?"],[5744,5896,"She can't even answer that."],[5932,6088,"What else is there to explain?"],[6088,6284,"She's definitely guilty."],[6284,6500,"She can't even speak for herself."],[6500,6600,"OMG!"],[6600,6868,"I can't believe I've been working with a thief."],[6928,7076,"Clara, I trust you."],[7140,7220,"Don't be scared."],[7312,7476,"Prove you're innocence and show them."],[7528,7640,"Tell them where you were."],[7764,7920,"If you don't have an alibi,"],[7928,8056,"pack up your stuff,"],[8056,8300,"and get out of the office right now."],[8300,8540,"She needs to be fired right away."],[8540,8748,"I feel ashamed for her."],[8748,8810,"Clara,"],[8810,8912,"prove your innocence"],[8912,9020,"and tell them where you were."],[9192,9356,"Who says she doesn't have an alibi?"],[9520,9604,"Clara..."],[9748,9908,"was with me last night."]],"16":[[444,680,"Mr. Haverbrook, what do you mean?"],[896,1008,"Last night,"],[1208,1384,"she was with me."],[1480,1776,"Why was the new girl with the CEO last night?"],[1776,1964,"Was she throwing herself on him?"],[1964,2180,"Trying to take a shortcut."],[2180,2268,"So ambitious."],[2268,2364,"Enough!"],[2404,2552,"That's defamation."],[2552,2700,"Do you want to get sued?"],[2700,2864,"Last night, Clara was working overtime"],[2864,3064,"in my office."],[3064,3352,"She's both capable and dedicated."],[3468,3712,"So I'll be promoting her as my secretary."],[3740,3892,"Your secretary?"],[3892,3976,"Why?"],[4008,4164,"Sir, are you sure?"],[4237,4376,"Since when do I need your permission"],[4376,4484,"to make decisions?"],[4532,4656,"That's not what I meant."],[4860,4928,"So..."],[5028,5094,"What are we gonna do"],[5094,5236,"about the stealing?"],[5296,5496,"It's just a misunderstanding since..."],[5536,5800,"Clara wasn't really here last night."],[5892,5968,"I believe her."],[6120,6568,"I think I might have maybe accidentally..."],[6568,6740,"left my bracelet in her desk."],[6740,6856,"Accidentally?"],[6856,6948,"Yes."],[7192,7300,"Clara,"],[7356,7456,"I'm sorry."],[7564,7700,"Check the security footage."],[7768,7912,"Fire who you should."],[7912,8020,"And if you can't even handle this,"],[8020,8148,"pack your bags as well."],[8184,8300,"Manager, you have to help me."],[8300,8364,"Shut up!"],[8364,8504,"Or I'll call security."],[9512,9712,"Come to my office later."],[9976,10156,"You left something there last night."]],"17":[[272,372,"Congratulations."],[404,556,"I heard about the promotion."],[660,744,"Thank you."],[744,916,"It's a great opportunity."],[964,1148,"Why don't we celebrate?"],[1172,1304,"Let's go to dinner."],[1308,1416,"Sorry, Ryan."],[1480,1704,"The boss wants to meet with you."],[1824,1928,"Now."],[3564,3636,"What?"],[3768,3864,"You are leaving?"],[3936,4132,"Sir, is there anything else?"],[4824,5040,"Did you not get any rest last night?"],[5136,5308,"You don't look too well today."],[5404,5596,"Somebody left this in my office."],[5656,5828,"Any idea whose this might be?"],[5860,6160,"Should I put out a lost-and-found notice?"],[6428,6564,"I didn't get a good look at them."],[6648,6732,"Oh, nice."],[6792,6900,"You like this style?"],[6900,7048,"Stop joking. Give them back."],[7048,7168,"I'll give them back,"],[7220,7392,"you need to prove your sincerity."],[7556,7672,"Perhaps..."],[7728,7928,"Mr. Haverbrook, may I come in?"],[8264,8348,"Yes."]],"18":[[84,188,"Perhaps..."],[232,436,"Mr. Haverbrook, may I come in?"],[604,664,"Yes."],[1580,1648,"Clara..."],[1760,1844,"are you okay?"],[1844,1968,"Yeah, I was just..."],[2000,2184,"finishing the report, so..."],[2380,2544,"I'll leave you two alone."],[3876,4068,"This ain't a homeless shelter, miss."],[4068,4364,"You're three months behind on your rent."],[4384,4552,"I'm just waiting on my next paycheck."],[4552,4688,"Please give me a few more days."],[4688,4840,"Don't give me that!"],[4852,5100,"I should have kicked you out sooner."],[5100,5384,"Now get the hell out!"],[5492,5788,"Get the hell out of my place!"],[5844,6004,"And don't ever come back!"],[6296,6432,"Nowhere to go, huh?"],[6448,6628,"You can always stay with me, toots."],[6648,6840,"You got a nice face, too."],[6892,7056,"And a nice body."],[7128,7204,"Is that a no?"],[7264,7392,"I'm rejected."],[8048,8200,"What? Are you sleep on the street?"],[8228,8312,"Come with me."],[8328,8524,"I don't like wasting my time."],[9056,9264,"This is what you meant by earning a living."],[9300,9464,"Doesn't look like you're doing too well."],[9532,9636,"You're stubborn."],[9636,9768,"Where were you gonna sleep tonight?"],[9784,9884,"Under a bridge?"],[9968,10128,"Do you have to humiliate me?"],[10132,10320,"If I wanted to humiliate you,"],[10432,10580,"I'd do much worse."],[11632,11768,"I can't stay here."],[11768,11940,"Who said to stay for free?"],[11992,12088,"After work, you'll cook,"],[12088,12220,"clean, and manage the house."]],"19":[[356,508,"So late again."],[1884,1964,"Clara?"],[2200,2404,"Are you trying to get yourself sick?"],[2492,2640,"I wasn't sure if you ate yet."],[3936,4132,"Did he take care of me all night?"],[4428,4556,"Looks like you're better."],[4664,4768,"Thank you."],[4768,4984,"You wanna thank me, don't get sick again."],[4984,5168,"Are you worried about me?"],[5168,5292,"You're my housekeeper."],[5324,5376,"If you get sick,"],[5376,5488,"who's gonna clean the house?"],[5652,5840,"Get up, don't be late for work."],[6992,7132,"I'll be home late tonight."],[7176,7264,"Where are you going?"],[7332,7488,"Getting something to eat,"],[7488,7728,"some necessities for the house."],[7764,7820,"Fine."],[7876,8056,"I'll meet you in the parking lot after work."],[8068,8196,"You're coming with me?"],[8312,8432,"Wasn't I clear?"],[8528,8584,"Okay."]],"20":[[480,564,"What are you doing?"],[656,816,"You are throwing yourself at me already?"],[840,964,"No, Ryan is coming."],[964,1044,"Do you want the whole company"],[1044,1164,"to know about us?"],[1164,1280,"I don't care about him, but I..."],[1280,1380,"do have some thoughts"],[1380,1540,"about this position."],[1644,1760,"Stop screwing around."],[1844,1920,"Mr. Haverbrook."],[2280,2352,"Staying late?"],[2432,2604,"No, I was just about to leave."],[2700,2780,"What about you?"],[2820,3000,"I came back to pick up some files."],[3080,3240,"Have you seen Clara by any chance?"],[3432,3484,"What's wrong?"],[3600,3712,"Nothing, a kitten..."],[3740,3824,"scratched me."],[3852,3916,"You have a cat?"],[3964,4072,"Oh, I have one, too."],[4212,4320,"Ryan, I gotta go."],[4408,4484,"All right."],[4584,4672,"Drive safe."],[5052,5220,"Was there a woman in his car?"],[5328,5450,"You're gonna stay down there all day?"],[5450,5550,"Or you're actually comfortable"],[5550,5652,"in this position?"],[5744,5900,"You did that on purpose."]],"21":[[276,444,"This place is pure chaos."],[524,644,"It's real life."],[644,876,"Not your private members-only club."],[908,1064,"Hey folks, what can I get for you today?"],[1208,1364,"People actually eat this?"],[1372,1616,"Yeah, not everyone has a private chef."],[1680,1916,"We will take one cheeseburger combo"],[1916,2060,"and..."],[2232,2404,"something that won't traumatize him."],[2428,2512,"Coming right up."],[2812,2960,"And here you go."],[2968,3044,"Enjoy."],[3332,3428,"Don't tell me you don't know"],[3428,3532,"how to eat a cheeseburger."],[3532,3692,"Yes, I know how to eat it. It's just..."],[3772,3964,"It's poorly constructed,"],[4020,4100,"okay?"],[4196,4364,"Oh, I love seeing young couples"],[4364,4524,"sharing a meal."],[4556,4708,"So heartwarming."],[4764,4860,"Yeah."],[4912,5036,"Yeah, I work so hard."],[5036,5272,"My lovely wife likes to take me out to dinner."],[5340,5504,"Such a lovely couple."],[5564,5800,"Wishing you a lifetime of happiness."],[5840,6028,"Elliott, why did you just lie?"],[6076,6140,"Why?"],[6192,6328,"You think we don't look good together?"],[6392,6512,"I didn't say that."],[6512,6596,"So then you are saying"],[6596,6724,"we do look good together."],[7940,8080,"So I heard the new girl"],[8080,8292,"is from a really wealthy family,"],[8292,8492,"and her background is quite impressive."],[8532,8716,"And the rumor is that she might be"],[8716,8944,"the future Mrs. CEO."],[8944,9060,"Really?"],[9232,9304,"Clara,"],[9304,9512,"you're the CEO's secretary."],[9556,9720,"You must know something, right?"]],"22":[[40,216,"You must know something, right?"],[288,476,"I don't. I just..."],[548,700,"work on documents."],[1132,1212,"Mr. Haverbrook,"],[1212,1400,"these documents need your signature."],[2048,2252,"Elliott is handling some business,"],[2276,2384,"but he'll be back soon."],[2644,2892,"Wait. You're Clara, right?"],[2896,3036,"Elliott's secretary?"],[3036,3200,"I heard you're doing a good job."],[3232,3308,"Thanks."],[3364,3564,"Just... try my best."],[3584,3688,"That's so great to hear."],[3760,3984,"Oh, could you do me a small favor?"],[4016,4100,"What is it?"],[4124,4192,"You know,"],[4192,4328,"wealthy men like Elliott"],[4328,4432,"always has some skanks"],[4432,4620,"running after him, so..."],[4620,4752,"Could you help me keep an eye out?"],[4792,4864,"Oh, and..."],[4864,4944,"you do know"],[4944,5136,"my relationship with Elliott."],[5140,5208,"Sorry."],[5208,5420,"No, I don't, really..."],[5420,5556,"He hasn't mentioned it."],[5560,5700,"I thought he trusted you."],[5764,5836,"Elizabeth,"],[5900,5996,"what are you doing here?"],[6076,6236,"I came to see you."],[6236,6408,"Not happy to see me?"],[6748,6836,"You need something?"],[7056,7108,"No."],[7140,7240,"Then leave."],[8156,8400,"Who is she?"]],"23":[[32,176,"Looks like Miss Green is about to be"],[176,372,"Mr. Haverbrook's fiancée."],[396,512,"Really?"],[516,656,"They're a perfect match."],[676,840,"She's from a powerful family."],[840,988,"He's rich and hot."],[1032,1256,"That's why she has such an elegant aura."],[1256,1392,"How is any normal person"],[1392,1520,"supposed to compete with that?"],[1596,1732,"Well, I saw Miss Green"],[1732,1928,"go into the CEO's office."],[1928,2092,"I wonder what they're doing in there."],[2468,2716,"Clara, are you okay?"],[2796,3000,"I'm sorry, I'm just... I'm distracted."],[3348,3460,"Looks like somebody's plan"],[3460,3580,"is falling apart."],[3844,3956,"Clara, are you okay?"],[4104,4200,"You're bleeding."],[4264,4372,"Don't be stubborn."],[4376,4469,"If you're going through something,"],[4469,4584,"you can tell me."],[4600,4704,"You don't have to do it alone."],[4752,4824,"Thanks."],[4924,5004,"I'm fine."],[5984,6236,"Miss Green, you look absolutely stunning."],[6236,6384,"Are you going to an event tonight?"],[6848,6964,"A proposal."]],"24":[[1108,1248,"What was I thinking..."],[1388,1600,"He's been lying all along."],[3732,3812,"You are back?"],[3892,4024,"Why did you drink so much?"],[4244,4404,"Elliott, is it true?"],[4460,4584,"What true?"],[4584,4672,"What are you talking about?"],[4728,4800,"The proposal."],[4888,5024,"It's true, isn't it?"],[5212,5324,"This place will do."],[5392,5604,"Make sure it's decorated with fresh flowers."],[5604,5688,"Well, well,"],[5688,5964,"look who finally got their romantic act together."],[6032,6232,"Miss Wilson's gonna love this confession."],[6232,6312,"And you know what?"],[6312,6520,"She might even say yes if you..."],[6600,6716,"pop the question."],[7240,7392,"Victor's got a big mouth."],[7640,7752,"So it is true."],[7928,8016,"Clara, actually..."]],"25":[[768,924,"I'm sorry. I shouldn't have done that."],[924,1056,"Hey, what's wrong?"],[1124,1256,"Look, if you don't like me..."],[1632,1704,"Clara, you..."],[1880,1964,"Are you asleep?"],[2536,2616,"Elliott."],[4052,4132,"Katherine."],[4212,4308,"Why are you..."],[4308,4468,"I'm Miss Green's new assistant now."],[4600,4672,"Miss Wilson,"],[4672,4824,"as the CEO's secretary,"],[4824,4932,"don't you think it's a little"],[4932,5208,"inappropriate to arrive later than your boss?"],[5276,5352,"My apologies."],[5352,5548,"but I wasn't feeling well last night."],[5556,5676,"No excuses."],[5712,5923,"The CEO's secretary is not a job"],[5923,6076,"for just anyone."],[6088,6196,"Remember your place."],[6220,6576,"And don't upset the future Mrs. CEO."],[6576,6776,"Oh, Katherine, don't say that."],[6776,6896,"It's best if the company doesn't know"],[6896,7084,"about my relationship with Elliott."],[7148,7248,"You know, Elliott and I,"],[7248,7424,"we are keeping our relationship very..."],[7424,7556,"low-key."],[7676,7840,"You'll keep our secret, right?"],[7840,7948,"Miss Wilson?"]],"26":[[28,176,"You'll keep our secret, right?"],[224,316,"Miss Wilson?"],[600,700,"Of course."],[1760,1836,"Clara,"],[1860,2056,"you should watch out."],[3264,3320,"Thanks."],[3340,3420,"Of course."],[3496,3696,"I mean, you're an important employee of Elliott's."],[3696,3844,"I wouldn't want you to get hurt."],[3844,4028,"Miss Green is so kind."],[4028,4100,"Oh, also,"],[4100,4213,"I'm hosting a party"],[4213,4352,"at my mansion this weekend,"],[4352,4536,"and I invited some colleagues, and..."],[45