between them"],[6180,6296,"when they were fighting."],[6316,6420,"Exactly."],[6436,6540,"Otherwise, why would"],[6540,6728,"Mr. Haverbrook protect her?"],[6888,7116,"Clara, just you wait."],[7144,7384,"I won't let you get away with this."]],"30":[[800,956,"You should take a hot bath."],[964,1056,"Or you'll catch a cold."],[1828,1996,"I can't go on like this."],[2052,2140,"No matter what,"],[2192,2340,"I won't be a homewrecker."],[3024,3116,"Feeling better?"],[3164,3380,"Mr. Haverbrook, I wanna move out."],[3568,3624,"Why?"],[3664,3892,"I appreciate everything that you've done for me."],[3924,3988,"I just..."],[4076,4268,"I can't accept your kindness anymore."],[4404,4496,"Give me a reason."],[4592,4712,"I got paid."],[4780,4928,"I can afford rent now."],[4928,4988,"And..."],[5084,5404,"I don't want any more misunderstandings."],[5420,5616,"Misunderstandings about what?"],[5648,5832,"Do I have to spell it out for you?"],[5860,6056,"I don't want to live with you anymore."],[6404,6460,"Okay."],[6660,6800,"I hope you don't regret it."],[6840,6996,"I'm sorry, Elliott,"],[7012,7176,"but this is for the best."]],"31":[[912,1016,"Mind if I join you?"],[1124,1224,"Not at all."],[1224,1324,"You look down."],[1336,1464,"Something sweet will help."],[1624,1748,"Thank you, Ryan."],[1872,2000,"Come on, brighten up."],[2128,2264,"Your food's gonna get depressed."],[2536,2792,"Clara, is this why you left?"],[3012,3140,"You two having a good time?"],[3176,3300,"Mr. Haverbrook."],[3300,3420,"The schedule's changed."],[3468,3656,"You're coming with me on this business trip."],[3656,3808,"Prepare the files, we're leaving now."],[3808,3888,"You and me?"],[3932,4036,"Is there a problem?"],[4312,4404,"Not at all."],[5640,5780,"Boss, about this trip."],[5780,5868,"Be quiet."],[6952,7016,"Elliott!"],[7160,7244,"Finally."],[7368,7456,"Elizabeth?"],[7492,7696,"So, Mr. Haverbrook is seeing her."],[7832,7896,"Clara,"],[7976,8112,"why don't you go up ahead of me?"],[8212,8364,"I'm just bothering them."],[8420,8556,"I shouldn't be here."]],"32":[[52,196,"I'm just bothering them."],[240,376,"I shouldn't be here."],[832,924,"What are you doing here?"],[924,1080,"I was just walking by."],[1148,1256,"Didn't think I'd run into you."],[1256,1400,"Just walking by."],[1480,1652,"Stay away from Clara."],[1652,1840,"Is she really that important to you?"],[1996,2136,"It's none of your business."],[3192,3440,"I don't want that woman near him anymore."],[3492,3584,"Understood?"],[3636,3896,"Clara, let's see if Elliott will still protect you"],[3896,4152,"when he finds you in another man's bed."],[4688,4868,"Elliott was so cold today."],[4932,5120,"Maybe he made up with Elizabeth."],[5960,6032,"Miss."],[6160,6240,"Thank you."],[8832,9012,"Miss, do you need help?"]],"33":[[296,452,"Oh, sweetheart,"],[484,588,"you feeling sick?"],[660,788,"I can help with that."],[1140,1240,"Get away from me."],[1556,1744,"Elliott, where are you?"],[1744,1968,"You bitch! How dare you kick me."],[1968,2072,"I'll make sure everyone knows"],[2072,2176,"what a slut you're."],[2176,2236,"Go away!"],[2448,2500,"Elliott."],[3376,3604,"Elliott, help me."],[3672,3764,"Clara, what's wrong?"],[3832,3952,"So hot."],[5044,5204,"Do you know what you're doing?"]],"34":[[1176,1348,"Thank God, it was him."],[1448,1672,"What am I thinking? He has a fiancé."],[1728,1836,"I'd better leave now."],[1900,1984,"Leaving already?"],[2084,2260,"You were so eager last night."],[2268,2384,"Why the shy act now?"],[2384,2532,"No, that was an accident."],[2532,2616,"Accident?"],[3120,3208,"You need me to remind you"],[3208,3336,"how passionate you were."],[3336,3436,"No, I didn't mean to."],[3704,3760,"Clara,"],[3796,3920,"what are you so afraid of?"],[4124,4279,"I don't want to ruin your relationship"],[4279,4396,"with Elizabeth."],[4420,4544,"You two are engaged."],[4544,4640,"Engaged?"],[4676,4812,"Who told you that nonsense?"],[4880,4960,"Aren't you?"],[4996,5028,"I mean,"],[5028,5216,"she's so affectionate towards you."],[5216,5336,"Everyone at the company is..."],[5336,5400,"Elizabeth?"],[5440,5572,"Her father's just my business partner."],[5572,5672,"We're not engaged."],[5824,5936,"Why don't you come to me"],[5936,6084,"instead of believing a rumor?"],[6376,6628,"So, you're single."],[6648,6848,"No. No, I'm not single."],[6900,6996,"What?"],[7484,7540,"Clara,"],[7676,7864,"you really don't know who I'm with."]],"35":[[252,480,"I heard the CEO"],[480,656,"had a woman in his bedroom,"],[656,808,"on his business trip."],[940,1124,"Maybe it was Miss Green."],[1148,1278,"I heard that they were together"],[1278,1456,"at the hotel that night."],[1548,1732,"Elliott doesn't like gossip"],[1732,1864,"in the company."],[1884,2160,"So let's keep this to ourselves, okay?"],[2196,2320,"Of course."],[2360,2644,"You and Mr. Haverbrook are such a perfect match."],[3148,3288,"Elliott, it's me."],[3812,3944,"Are you jealous, Clara?"],[3996,4212,"Not everyone gets this opportunity."],[4268,4340,"Let's see how long"],[4340,4508,"she can keep up this attitude."],[5696,5876,"I thought you were meeting with a client."],[5924,6068,"Well, I wanted to get home early."],[6104,6256,"My girlfriend is waiting for me."],[6332,6464,"You're gonna spill the soup."],[6584,6652,"So."],[6700,6817,"When do you wanna go public"],[6817,6936,"with our relationship?"]],"36":[[24,76,"So."],[132,219,"When do you wanna go public"],[219,368,"with our relationship?"],[628,756,"I don't want to."],[772,864,"Not yet."],[908,1072,"Why not? Because of Elizabeth?"],[1072,1288,"No, it's not because of that. It's..."],[1432,1596,"I just don't want my colleagues to"],[1596,1736,"treat me differently."],[1792,1948,"It would make me uncomfortable."],[2148,2384,"So, I'm your little secret now, huh?"],[2384,2452,"I'm sorry."],[2548,2616,"What?"],[2728,2812,"You don't think this is hot?"],[2812,2948,"I thought you'd be into this sort of thing?"],[2968,3088,"Dinner is almost ready."],[3088,3212,"Go wash your hands."],[6292,6396,"Why so tense?"],[6396,6520,"This is not the place."],[6944,7128,"You could stand a little bit closer."]],"37":[[1056,1156,"Sir,"],[1156,1356,"you've been smiling a lot more lately."],[1356,1536,"And you've been talking a lot more lately."],[1536,1700,"Seems like you don't got enough work to do."],[1812,1864,"Clara."],[2032,2160,"Wanna go grab lunch with me?"],[2236,2324,"Yeah,"],[2324,2584,"I actually wanted to tell you something."],[2804,2928,"Victor, take care of it."],[3508,3688,"Ryan, my guy."],[3688,3940,"So, unfortunately, a little bit of bad news."],[3940,4052,"There's an emergency"],[4052,4200,"and you're gonna have to deal with it."],[4208,4308,"No lunch break."],[4396,4472,"Sorry."],[4476,4520,"Okay."],[4600,4796,"Looks like I'm gonna have to cancel our lunch."],[4824,4900,"Sorry, Clara."],[4940,5008,"It's okay."],[5060,5164,"We'll find another time."],[5268,5332,"Let's go, Ryan."],[5344,5400,"Come on."],[5652,5756,"It's too much."],[5784,5872,"Not at all."],[5904,6052,"Just don't want you to waste your time."]],"38":[[356,404,"Elliott,"],[404,592,"these documents need your signature."],[908,972,"What are you doing?"],[972,1080,"We're in the office."],[1132,1200,"Clara,"],[1200,1356,"have you forgotten what we've done here?"],[1448,1560,"You need to stop talking."],[1616,1716,"Why so shy?"],[1716,1852,"You weren't like this before."],[1864,1968,"Stop it."],[2228,2356,"Very clever of you."],[2512,2644,"Miss Wilson..."],[2704,2928,"Why are you sitting in the CEO's chair?"],[2936,3036,"I was just..."],[3472,3660,"organizing files."],[3704,3800,"Um, okay."],[3832,4008,"Well, next time you see Mr. Haverbrook,"],[4008,4088,"just let him know"],[4088,4224,"that we have to go over the schedule."],[4232,4284,"Yep."],[4284,4324,"Okay."],[4324,4536,"Yeah, I will let him know."],[4688,4752,"Clara,"],[4828,4968,"you don't look so good."],[4968,5048,"Are you okay?"],[5092,5172,"I'm fine, you know."],[5264,5412,"You can just go back to work."],[5412,5512,"Okay, yeah."],[5864,5976,"What were you doing?"],[6264,6384,"You're cute when you're nervous."],[6384,6548,"Okay, get up now."],[6640,6820,"Maybe we should find a safer way to"],[6820,6984,"keep our secret next time."]],"39":[[116,208,"Clara,"],[208,436,"your face looks red like a tomato."],[448,576,"Work gets you stressed?"],[1500,1588,"Samantha,"],[1680,1880,"I'll give you a hundred thousand"],[1880,2048,"as long as you..."],[2676,2848,"Why do I always end up looking"],[2848,3084,"so messy after being around him?"],[4064,4284,"Samantha, I'm not giving you any more money."],[4304,4568,"Clara, I know I was wrong."],[4568,4696,"I'm leaving town."],[4696,4884,"Can we meet one last time?"],[5460,5564,"When are you leaving?"],[5596,5704,"Have you visited mom?"],[5744,5840,"Clara,"],[5932,6076,"I've been waiting for you."],[6504,6604,"Don't try to run."],[7104,7320,"Did I upset her earlier? Or..."],[7320,7464,"Is she ignoring me?"],[7684,7856,"Samantha, why are you doing this?"],[7876,7956,"Why?"],[7968,8204,"You pissed off someone rich."],[8204,8348,"Jerry, bring your friend now."],[8504,8548,"Hey."],[8756,8968,"We'll make sure she learns her lesson."],[9320,9420,"Have you seen Clara?"],[9492,9620,"I think she already went home."],[9632,9800,"I just saw her leave the office."],[9856,9984,"She went home."],[10068,10204,"She really is mad at me."],[10464,10572,"Take your time, bro."],[10664,10816,"She's all ours tonight."],[11120,11168,"No..."]],"40":[[284,356,"Clara!"],[432,536,"She must not be home."],[904,1056,"Find Clara's location now."],[1348,1400,"No..."],[1416,1464,"No!"],[1744,1800,"Back off!"],[1884,1948,"Back off!"],[1960,2104,"Don't struggle, sweetheart."],[2120,2252,"Just embrace it."],[2368,2544,"Is this how it all ends for me?"],[2832,2896,"Clara."],[3852,3932,"You okay?"],[4376,4453,"Come on."],[4453,4540,"Come on, let's go."],[5240,5356,"Make them pay."],[6276,6452,"Thank you for saving me today."],[6476,6540,"Stop."],[6656,6772,"I should've protected you."],[6884,6948,"Does it hurt?"],[6984,7056,"No."],[7076,7172,"It's just that..."],[7220,7524,"I've been dealing with everything by myself"],[7524,7692,"since my mom got sick."],[7776,7932,"And I'm really tired."],[8012,8204,"But I don't feel so alone anymore."],[8328,8484,"Lucky to have met you."],[8804,8888,"Clara,"],[8920,9192,"I'll always be here for you."],[9776,9968,"I wanna take you to meet my mother."]],"41":[[404,512,"Clara,"],[576,864,"you've been smiling a lot more lately."],[880,944,"Really?"],[1524,1572,"Mom,"],[1572,1680,"this is the person"],[1680,1796,"I've been telling you about."],[1912,1964,"Elliott."],[1980,2116,"Hello, ma'am. I'm Elliott."],[2184,2304,"It's a pleasure to meet you."],[2320,2516,"Nice to meet you too, Elliott."],[2544,2662,"Clara's told me"],[2662,2820,"how much you've helped her."],[2908,3120,"I'm lucky to have met her as well."],[3284,3436,"She's a wonderful girl."],[3492,3660,"I just want her to be happy."],[3756,3944,"But my poor health has been"],[3944,4084,"such a burden on her."],[4084,4220,"Mom, don't say that."],[4220,4304,"Don't worry."],[4336,4452,"Mr. Haverbrook has talked to"],[4452,4572,"the director of the hospital,"],[4632,4752,"and we've arranged for the best"],[4752,4888,"medical treatment available."],[5200,5364,"Thank you, Elliott."],[6512,6688,"Looks like someone's in a good mood today."],[6720,6800,"Any good news?"],[6848,6976,"I got my paycheck."],[7004,7104,"Oh, wow."],[7128,7176,"Well."],[7220,7332,"Since you just got your paycheck"],[7332,7448,"and you're so happy,"],[7468,7632,"can I take you to dinner after work?"],[7740,7852,"I have something really important"],[7852,7920,"to tell you."]],"42":[[48,151,"I have something really important"],[151,260,"to tell you."],[636,848,"Ryan, there you are."],[864,1063,"So yeah, the CEO needs you to leave"],[1063,1288,"immediately for Chicago,"],[1288,1380,"for a..."],[1416,1532,"a business trip."],[1556,1604,"Now?"],[1700,1792,"Why so urgent?"],[1844,1904,"I don't know."],[1904,2028,"But the sooner the better."],[2028,2200,"Yeah, he says it's top priority."],[2216,2300,"Something like that."],[2436,2528,"Looks like..."],[2648,2738,"our dinner's gonna have to be"],[2738,2860,"when I get back."],[2900,3064,"I really have to talk to you."],[3112,3228,"It's really important, but..."],[3300,3440,"I have to tell you in person."],[3644,3740,"Okay, let's go."],[4784,4956,"Ryan departed for Chicago,"],[5024,5160,"but before he left, he said"],[5160,5312,"he had something important to tell..."],[5344,5432,"to Miss Wilson."],[5456,5540,"Something important?"],[5592,5636,"Yeah."],[5696,5824,"He's really pushing it, huh?"],[5884,6004,"Maybe we should reassign Ryan"],[6004,6200,"to the Africa branch for a long-term post,"],[6200,6428,"since he's so capable, we should put him to use."],[6480,6556,"Sir,"],[6556,6804,"you're using your position for personal ideation."],[7076,7168,"You can go."],[7240,7312,"Yes, sir."],[8128,8264,"Great, you're back just in time."],[8276,8356,"Dinner's ready."],[8500,8596,"What's the occasion?"],[8692,8776,"You'll see."],[9576,9696,"That's delicious."],[9912,10084,"I got you a gift."],[10120,10168,"Funny,"],[10292,10428,"I have a gift for you too."]],"43":[[72,232,"I got you a gift."],[264,328,"Funny,"],[436,584,"I have a gift for you too."],[1448,1528,"What is this?"],[1572,1696,"There's a banquet next week."],[1752,1876,"I want you to go with me."],[1876,1984,"And this is for you."],[2204,2288,"I thought that we agreed"],[2288,2468,"to keep things low key."],[2476,2596,"Going to this banquet with me"],[2596,2792,"is part of your job as my secretary."],[2868,2932,"Understood."],[2992,3064,"Boss."],[4212,4312,"Good tie."],[4400,4596,"I spent a lot of time picking it out."],[4600,4736,"I think it really suits you."],[5124,5224,"Elliott, what are you doing?"],[5224,5308,"I have to work."],[5352,5552,"Work can wait until tomorrow."],[6392,6440,"Wait."],[6568,6716,"I have to do something first."],[7528,7620,"Clara,"],[7708,7828,"what are you doing?"],[8200,8264,"Well,"],[8404,8556,"do you remember how you used a tie"],[8556,8780,"to intimidate me the first time we met?"],[8904,9028,"Are you challenging me now?"],[9040,9112,"No."],[9204,9332,"This is my revenge."]],"44":[[124,260,"Are you challenging me now?"],[260,312,"No."],[432,536,"This is my revenge."],[700,900,"I don't think you can handle the consequences."],[1340,1416,"Clara?"],[1812,1912,"Like I said,"],[1996,2164,"this is my revenge."],[2248,2432,"Clara, untie me, right now."],[2548,2680,"What are you going to do?"],[3020,3184,"I have to go do some work, so..."],[3232,3496,"Take some time here to reflect on yourself."],[3615,3695,"Clara, I swear to God,"],[3695,3797,"when I get my hands free,"],[3797,4000,"you are going to regret it."],[4072,4284,"You'll have to get your hands free first, then."],[4336,4452,"Good night, boss."],[4900,4988,"Come on."],[5700,5988,"Is that Elliott's secretary?"],[6012,6188,"She's looking stunning tonight."],[6204,6448,"This is Elliott's first time"],[6448,6832,"actually bringing a guess on an event."],[6832,7028,"Clara, you shouldn't be here."],[7028,7176,"Leave immediately."],[7176,7328,"Did you hear that, Clara?"],[7328,7592,"The CEO's fiancé told you to leave."],[7656,7756,"Fiance?"],[7756,7804,"Yes."],[7812,7984,"My wedding is just a matter of time now."],[8028,8248,"So you can stop fantasizing about it."],[8292,8328,"It's funny."],[8392,8612,"Elliott has never mentioned being engaged."],[8632,8848,"Clara, Elizabeth is the only one"],[8848,9040,"worthy of being with Elliott."],[9040,9220,"Who do you think you are?"],[9220,9392,"Who I am is none of your concern."],[9412,9532,"I do know one thing."],[9592,9740,"Whoever is with Elliott"],[9756,9984,"didn't get there by lying or faking it."]],"45":[[28,200,"Who I am is none of your concern."],[224,336,"I do know one thing."],[360,524,"Whoever is with Elliott"],[524,744,"didn't get there by lying or faking it."],[832,1056,"Oh, you think throwing yourself at Elliott"],[1056,1264,"through your job gets you anywhere?"],[1264,1416,"You're so naive."],[1416,1604,"Elizabeth, instead of disparaging me,"],[1604,1828,"perhaps you should focus on your own manners."],[1864,1980,"What did you just say?"],[1996,2068,"Well,"],[2100,2255,"you humiliated me at the party,"],[2255,2415,"you set me up with that ring story,"],[2415,2644,"and you constantly antagonized me."],[2644,2752,"Isn't that unethical?"],[2780,2928,"Shut up, you bitch!"],[2948,3116,"How dare you talk to me like that!"],[4084,4196,"Do you have a death wish?"],[4228,4476,"Elliott, she is a gold-digging manipulator."],[4476,4600,"Don't be fooled."],[5144,5296,"You should learn some respect."],[5320,5564,"Otherwise, I'll exploit all of your secrets."],[5600,5776,"How dare you slap me?"],[5832,5960,"And you like a woman like that?"],[5960,6076,"Aren't you embarrassed?"],[6076,6288,"Clara's been far too kind to you."],[6376,6444,"Victor!"],[6656,6732,"Get her out of here."],[6784,7028,"Miss Green, please leave."],[7228,7364,"No, Elliott, you can't do that."],[7740,7892,"Clara, we are not done yet."],[7912,8040,"You'll pay for this."],[8988,9068,"You okay?"],[9240,9312,"Elliott,"],[9476,9708,"I don't want to be your secretary anymore."]],"46":[[272,508,"I want to transfer to the marketing department."],[560,620,"Marketing?"],[684,787,"But your role as my secretary"],[787,916,"is very important."],[948,1068,"Why do you want to transfer?"],[1100,1304,"Marketing is my area of expertise."],[1380,1616,"I want to prove myself through my own hard work."],[1916,2048,"You're trying to get away from me?"],[2092,2144,"No."],[2348,2620,"I want to stand beside you on my own terms."],[3192,3312,"I'll approve it."],[3828,3992,"I won't let you down."],[4640,4800,"Isn't she Elliott's secretary?"],[4860,4968,"Why is she here?"],[5000,5224,"I guess she is our CEO's favor."],[6328,6548,"Elliot, I did it! I signed a major deal!"],[6756,6864,"Clara, I don't get it."],[6868,7004,"You've been exhausting yourself,"],[7004,7156,"waiting outside their offices for hours,"],[7156,7292,"stopping their cars."],[7340,7468,"Why have you been pushing yourself so hard?"],[7468,7628,"I can give you everything that you want."],[8104,8284,"This is a portion of the company's shares."],[8568,8672,"It's yours."]],"47":[[40,328,"Elliott, I can't accept that."],[572,668,"But this is my bonus"],[668,860,"from the project I just completed."],[888,1088,"I want to repay what you did for me."],[1216,1340,"I never asked you to."],[1372,1432,"I know."],[1628,1764,"But it matters to me."],[2176,2272,"Clara,"],[2332,2548,"I could give you everything that you want."],[2584,2968,"Money, status, a better life."],[3006,3195,"But I want to stand beside you,"],[3195,3334,"through my own hard work,"],[3334,3492,"not your favor."],[3492,3680,"Only then can I love you as an equal."],[3764,3904,"As an equal?"],[4072,4216,"Do I not treat you well?"],[4344,4516,"Do I really make you feel inferior?"],[5160,5312,"You need to understand."],[5664,5796,"I'm not your pet."],[6548,6720,"Oh Clara, I've been looking for you."],[6720,6963,"You and Ryan need to head to Newfort now"],[6963,7148,"to follow up on an important project."],[7148,7360,"Okay. Do my best."],[8012,8420,"Sir, are you and Miss Wilson doing okay?"],[8448,8576,"Mind your own business."],[8612,8704,"Well,"],[8712,8868,"the head of the marketing department"],[8868,8964,"just assigned"],[8964,9240,"Ryan and Clara to go on a business trip,"],[9312,9420,"together."],[9564,9664,"Does he want to get fired?"],[9768,9892,"Book me a flight, now!"],[9968,10012,"Yes, sir."],[10540,10760,"I can't believe the deal went so smoothly."],[10868,11084,"I've actually been meaning to tell you something."],[11212,11300,"What is it?"],[11412,11528,"I have feelings for you,"],[11676,11808,"since college, actually."]],"48":[[32,152,"I have feelings for you,"],[180,352,"since college, actually."],[540,672,"Ryan, are you serious?"],[672,776,"I'm serious."],[808,956,"I didn't tell you before"],[956,1100,"because I didn't have the guts."],[1132,1308,"But I don't want to miss a chance anymore."],[1388,1576,"Ryan, I..."],[1600,1652,"Clara."],[2144,2280,"What are you two talking about?"],[2280,2348,"Mr. Haverbrook,"],[2348,2528,"this is a private conversation."],[2668,2836,"Private conversation, Ryan."],[2896,3060,"I had no idea you two were this close."],[3060,3176,"Elliott, don't."],[3180,3296,"Mr. Haverbrook,"],[3296,3468,"please respect Clara's choice."],[3468,3688,"She has the right to choose who she likes."],[4036,4176,"Elliott, what are you doing?"],[4508,4656,"Clara..."],[4664,4772,"is mine."],[5300,5464,"Elliott, you have gone too far."],[5472,5536,"Too far?"],[5600,5724,"You think I shouldn't have stopped him?"],[5732,5884,"You shouldn't resort to violence."],[5892,6096,"I am so disappointed in you."],[6316,6396,"Look,"],[6464,6680,"I think we both need to cool down."],[6892,7092,"We need to take a break from each other."]],"49":[[32,232,"We need to take a break from each other."],[340,420,"Cool down?"],[540,660,"Are you leaving me because of Ryan?"],[660,795,"No, no, it's not because of"],[795,924,"what just happened in there."],[988,1140,"Our relationship..."],[1364,1532,"It's... it's imbalanced."],[1564,1732,"I need time to find myself again."],[1764,1868,"Why can't you see?"],[2000,2140,"I've changed so much for you."],[2268,2348,"Elliott."],[2464,2608,"I need respect."],[2960,3100,"You're really leaving me."],[3512,3660,"I hope you don't regret it."],[3776,3944,"Goodbye, Elliott."],[5500,5780,"I'm sorry I didn't give you an answer yesterday."],[5992,6156,"Thank you, Ryan."],[6372,6520,"I can't be with you."],[6800,6996,"I already like someone else."],[7128,7384,"I understand, Clara."],[7492,7628,"Thanks for being honest."],[9440,9544,"What is it?"],[9576,9788,"Mr. Haverbrook, I'm here to submit my resignation."],[9912,9996,"Why?"],[10076,10228,"Since I can't win Clara's heart."],[10264,10432,"The least I can do is"],[10432,10572,"not be a burden to her."],[10728,10848,"Mr. Haverbrook,"],[10956,11132,"if you really love Clara,"],[11132,11276,"stop forcing her."],[11292,11520,"Learn how to respect what she wants."],[11520,11640,"You can leave."],[11692,11764,"Now."],[12312,12364,"Sir."],[12484,12532,"Sir."],[12668,12828,"Miss Wilson just went on a business meeting."],[12836,12880,"But,"],[12912,13068,"the representative that she's meeting with,"],[13100,13340,"just got exposed in a huge harassment scandal."],[13352,13428,"What?"]],"50":[[780,880,"Miss Wilson,"],[916,1080,"the price seems a bit too high."],[1108,1340,"Well, we offer the highest quality service."],[1340,1572,"We guarantee that every penny will be worth it."],[1648,1944,"Other firms offer much lower prices."],[1944,2080,"Why should we choose you?"],[2164,2240,"Unless..."],[3168,3276,"Unless what?"],[3320,3552,"Miss Wilson, you're quite attractive."],[3552,3836,"If you go out for a drink with me tonight,"],[3836,4140,"I'm sure our deal will go very smoothly."],[4604,4740,"Apologies."],[5020,5164,"I recorded what you just said."],[5188,5368,"I'm sure your boss would be..."],[5368,5608,"very interested in hearing this."],[5608,5732,"Please don't."],[5788,5948,"Miss Wilson, I'm sorry."],[6000,6080,"So,"],[6200,6332,"how about our deal?"],[6332,6468,"Of course I want to work with you."],[6468,6620,"I'll sign the deal right away."],[8520,8612,"Sir, should I"],[8612,8804,"remind Miss Wilson to take a break?"],[8804,8884,"No."],[8984,9092,"She knows what she's doing."],[11392,11500,"Is this for me?"]],"51":[[204,308,"Is this for me?"],[1776,1964,"Victor, your idea sucks."],[2876,3030,"How is making a sandwich more difficult"],[3030,3252,"than closing billion dollar deals?"],[3288,3356,"Boss,"],[3356,3572,"I think small gestures like this is really"],[3572,3800,"going to show how much you love Miss Wilson."],[3800,3912,"It would be a miracle"],[3912,4132,"if she was actually moved by this."],[5364,5484,"Not bad."],[5704,5852,"You deserve a raise."],[5852,5992,"I'll talk to your boss."],[6492,6664,"Hey, you actually ate that?"],[6664,6728,"Yeah."],[6808,7144,"The taste was unique, but..."],[7144,7320,"I appreciated the effort."],[7320,7444,"Miss Wilson, you didn't have to"],[7444,7628,"force yourself to eat the sandwich."],[7628,7884,"I didn't."],[7884,8092,"I actually liked it."],[8092,8192,"Good."],[8428,8600,"Is this the power of love?"],[9156,9420,"Clara, this is a major project."],[9420,9648,"I'm putting you in charge."],[9648,9872,"That's a huge project."],[9872,10072,"Why are they giving it to her?"],[10072,10356,"She has special treatment from the CEO."],[10356,10572,"What else does she have besides her looks?"],[10964,11020,"Elliott."]],"52":[[84,196,"Elliott."],[196,296,"What's wrong?"],[296,430,"I shouldn't even have access to"],[430,648,"this kind of job under normal procedures."],[648,888,"You think I need your extra help to do my job?"],[888,1016,"Clara, what are you talking about?"],[1016,1196,"Look, I have told you so many times."],[1196,1268,"When you do this,"],[1268,1488,"it makes it harder for me to do my job."],[1488,1696,"Please, calm down."],[1709,1778,"We're running late, sir."],[1778,2000,"We really have to go like right now."],[2000,2136,"Look, I don't know what's going on,"],[2136,2276,"but I didn't interfere with your work."],[2276,2392,"We can talk about it when I get back,"],[2392,2460,"alright?"],[2564,2616,"Let's go."],[3892,3964,"I'm sorry, sir."],[3964,4132,"You're gonna have to find someone else."],[4200,4452,"Tell Mr. Haverbrook I can't do this project."],[4452,4636,"What does the CEO have to do with it?"],[4808,4963,"I'm not qualified."],[4963,5121,"Clara, you have to forget about"],[5121,5300,"what other people say about you."],[5300,5524,"Your work has already proven itself."],[5660,5780,"And I won't let you down."],[5972,6064,"Did you hear?"],[6064,6296,"The CEO got into a car crash."],[6296,6468,"A car crash?"],[6468,6580,"Where? Is he okay?"],[6580,6773,"Someone saw him crash at the intersection"],[6773,6876,"in front of the company."],[6892,6964,"He hit a truck."]],"53":[[496,720,"Victor, how is Elliott?"],[720,908,"Claire, you're gonna have to calm down."],[908,1040,"Elliott is..."],[1748,1860,"It can't be."],[2016,2148,"It can't be."],[2212,2412,"Elliott, I'm so sorry."],[2428,2620,"I should have apologized to you."],[2732,2904,"I shouldn't have left you."],[2948,3060,"Victor,"],[3060,3200,"we fixed the meeting schedule yet?"],[3576,3664,"Clara?"],[3844,3952,"What are you doing here?"],[4032,4140,"Elliott."],[4288,4372,"You're not..."],[5056,5132,"What's going on?"],[5132,5228,"Why are you crying?"],[5352,5496,"I'm glad you're okay."],[5676,5784,"I have to go."],[6208,6360,"What just happened?"],[6360,6492,"Did somebody give her a hard time?"],[6532,6628,"Oh, boss."],[6692,6876,"Sometimes you can be really clueless."]],"54":[[753,830,"I'm sorry that"],[830,1056,"I haven't been visiting lately."],[1056,1232,"I'm glad that you're feeling better."],[1232,1556,"Elliott's been visiting me often."],[1556,1756,"The things he's brought me"],[1756,1964,"have been so thoughtful."],[1964,2140,"Elliot's been visiting?"],[2140,2280,"Yes."],[2280,2480,"He's a good man, Clara."],[2480,2748,"I can tell he truly cares about you."],[2944,3244,"Some things you can't keep running from."],[3244,3500,"You have to be true to your heart."],[3936,4300,"The doctor said I'll be fully recovered soon."],[4300,4696,"Now, I want you to focus on your own happiness."],[4828,5244,"Elliott, this time I won't run away."],[5828,5988,"Stop. Invitation."],[5988,6094,"Oh, I don't have one."],[6094,6264,"I'm here to see Mr. Haverbrook."],[6276,6368,"No invitation?"],[6368,6452,"You think anyone can just walk"],[6452,6612,"in here and see Mr. Haverbrook?"],[6612,6668,"Get lost."],[6728,6768,"Okay."],[6768,6948,"Well, can you tell him that I'm here,"],[6948,7076,"and he'll come out to see me?"],[7204,7348,"Who do you think you are?"],[7404,7576,"Mr. Haverbrook won't come here to see you."],[7720,7812,"Are you deaf?"],[7848,8048,"This place is not for someone like you."],[8076,8212,"Stop embarrassing yourself here."],[8212,8312,"Someone like me?"],[8312,8402,"You're a security guard."],[8402,8568,"What makes you so superior?"],[8568,8684,"What did you just say?"],[8712,8956,"You think you could talk to me like that?"],[8956,9048,"Get lost."],[9164,9396,"Clara, what a surprise!"]],"55":[[76,384,"Clara, what a surprise!"],[504,592,"Get out of the way."],[592,788,"Stop blocking Miss Green."],[788,872,"Oh my god."],[872,1156,"Are you seriously arguing with the security guard?"],[1156,1300,"Guess you're not feeling too well."],[1300,1516,"Did Elliott lose interest already?"],[1628,2036,"Oh my god, that's just so sad."],[2036,2228,"Do you really think you belong here?"],[2228,2392,"Aren't you embarrassed at all?"],[2392,2480,"Embarrassed?"],[2480,2628,"Aren't you afraid that I'll go in there"],[2628,2744,"and expose your lies?"],[2744,2848,"Watch your mouth."],[2848,3012,"Show some respect for Miss Green."],[3012,3096,"Get lost!"],[3276,3304,"Really,"],[3304,3456,"you never change, Elizabeth."],[3456,3756,"Still manipulating others to do your dirty work."],[3799,3900,"You're useless."],[3900,4048,"Can't even handle a woman?"],[4048,4168,"You're fired."],[4268,4367,"Honestly, Clara,"],[4367,4708,"I can't believe how stupid you are."],[4708,4956,"Do you really think Elliott likes you?"],[4956,5188,"He's just pitying you because you're poor."],[5304,5504,"I have to give you credit, Elizabeth."],[5504,5732,"Despite all of your wealth and status,"],[5732,6000,"you still can't get Elliott to look at you without disgust."],[6000,6160,"Shut up, bitch!"],[6160,6284,"You should learn some manners."],[6284,6476,"Is this how you would behave at a banquet?"],[6548,6620,"Fine."],[6628,6848,"Since you're so eager to embarrass yourself,"],[6848,6976,"let me help you with that."],[7604,7828,"Take a good look around, Clara."],[7900,8120,"This is Elliott's world, and you..."],[8204,8356,"you don't belong here."],[8476,8664,"Ladies and gentlemen,"],[8664,8876,"let me introduce you a woman"],[8876,9120,"who likes to climb the social ladder."],[9120,9376,"Isn't that Elliott's secretary?"],[9376,9712,"What is she wearing?"],[9748,9908,"Does she really not know"],[9908,10156,"what to wear to these occasions?"],[10156,10362,"So, Clara, do you think you can get any of these"],[10362,10568,"rich people to like you?"],[10584,10659,"Where is Elliott?"],[10659,10768,"I need to talk to him."],[10828,10984,"Seriously,"],[10984,11256,"how on earth did she get in?"],[11412,11556,"She has a nice face."],[11676,11828,"We could have some fun with that."],[13256,13368,"What's going on here?"],[13412,13716,"Elliott, I was just reminding Clara"],[13716,13888,"that she doesn't belong here."],[13888,14000,"She doesn't have manners."],[14000,14116,"Manners?"],[14146,14335,"You could learn some yourself."],[14338,14484,"No, I didn't mean that."],[14484,14640,"I was just helping you"],[14640,14820,"to teach her a lesson."],[14928,15144,"I'll be canceling all business with your father's firm."],[15437,15488,"What?"],[15488,15624,"No, you can't do that."],[15808,16084,"You have ruined everything!"],[16128,16340,"You of all people, you should know"],[16340,16656,"how important this partnership is to us."],[16656,16816,"But dad, I just wanted to..."],[16816,17030,"Just shut up! Shut it!"],[17116,17262,"I warned you."],[17262,17452,"Over and over again!"],[17452,17656,"Don't upset him."],[17656,17968,"And now you have destroyed our business."],[17968,18112,"I hope you're happy with yourself."],[18256,18356,"Everyone."],[18540,18692,"I have an announcement."]],"56":[[24,100,"Everyone."],[248,408,"I have an announcement."],[1176,1244,"Clara."],[1480,1760,"I know I'm not perfect."],[1892,2060,"But I want to be better for you."],[2344,2740,"Will you let me build a future with you?"],[3708,3788,"Yes."],[5272,5488,"Thank you, Clara."],[5840,5988,"You're my whole world."],[7984,8148,"When do we get to mark our wedding date on that,"],[8148,8224,"huh?"],[8412,8528,"Just need a little time."],[8592,8868,"There's something I have to finish first."],[8868,8976,"I can wait."],[9040,9256,"Just don't make me wait too long."],[9420,9584,"I want to stand beside you"],[9584,9732,"without any burdens."],[9812,9920,"I understand."],[11176,11372,"They don't deserve happiness."],[11640,11756,"Teach them a lesson."]],"57":[[504,780,"Finally. No more debt."],[840,964,"It's still early."],[964,1224,"I guess I'll make something special for dinner."],[1732,1836,"Elizabeth?"],[1948,2116,"You destroyed me."],[2116,2296,"I'll never let you be happy."],[2476,2532,"No!"],[3268,3408,"Have you lost your mind?"],[3408,3600,"If I can't have you, she can't have either."],[4026,4135,"You'll regret this!"],[4135,4304,"She doesn't deserve you!"],[4532,4632,"You okay?"],[5064,5128,"Clara."],[5196,5284,"You alright?"]],"58":[[412,528,"Congratulations."],[528,712,"Clara, you are seven weeks pregnant,"],[712,888,"and everything looks very good."],[1024,1188,"I'm pregnant."],[1388,1644,"We're going to be parents."],[1644,1764,"Yes, Mr. Haverbrook."],[1880,2076,"Elliott. We're having a baby."],[2632,2780,"Why can't I hear anything?"],[2914,3044,"Because you're an idiot."],[3044,3144,"That's why."],[3840,3916,"Okay,"],[3972,4208,"so we need to get started on the nursery right away."],[4208,4333,"And then we got to find a nutritionist."],[4333,4501,"We're going to get the best diet plan for you"],[4501,4588,"while you're pregnant."],[4588,4636,"Elliott,"],[4636,4920,"are you training our baby to be the next CEO?"],[4920,5084,"Clara, there's no room for mistakes"],[5084,5232,"when it comes to our kid."],[5232,5396,"Also, you're the number one priority now,"],[5396,5520,"so no overworking."],[5520,5692,"I can take care of myself."],[5700,5784,"No."],[5784,6064,"You've gotta rest for the baby."],[6064,6316,"Elliott, you think I'm gonna be a bad mom?"],[6332,6448,"Don't you know a pregnant woman"],[6448,6664,"needs to stay in a good mood?"],[6884,6985,"Fine."],[7036,7240,"Fine. You win."],[8168,8364,"Thank you, Clara,"],[8476,8720,"for filling my life with so many surprises."],[8784,8940,"And thank you, Elliott,"],[8968,9112,"for making me so happy."]]}