{"1":[[275,383,"Mommy, Mommy."],[433,654,"Help me, help me."],[1522,1747,"Help me, help me."],[1793,1943,"No."],[2890,2965,"Oh my God."],[3011,3086,"Oh my God."],[3086,3136,"Captain,"],[3161,3244,"she's crashing."],[3265,3332,"We need to get her to"],[3332,3436,"a hospital right now."],[3511,3557,"Ma'am,"],[3607,3732,"the ambulance won't make it in time."],[3782,3866,"We'll need to drive your daughter"],[3866,3928,"in the fire truck."],[3937,4049,"Oh, she's not my daughter."],[4049,4179,"I was just out on a jog."],[4212,4266,"Doesn't matter."],[4304,4421,"We'll need someone with her."],[4471,4533,"Can you ride along?"],[4617,4667,"Yes, yes."],[4667,4742,"Just please."],[4742,4917,"Anything you can do to save her, please."],[5134,5213,"Come on, sweetheart."],[5246,5292,"Come on."],[5326,5380,"Come on."],[6769,6831,"Jack,"],[6919,7069,"you outdid yourself today."],[7094,7219,"I'm still tingling."],[7273,7369,"You think that was good?"],[7428,7599,"Wait until you see the big surprise"],[7599,7703,"I have for you tomorrow."],[7741,7807,"I can't wait."],[7937,8103,"Ugh, Jack."],[8141,8274,"My husband's calling."],[8370,8466,"Gotta go."],[8587,8641,"Honey,"],[8641,8687,"I just heard"],[8687,8808,"there's a fire on our street."],[8808,8958,"Someone said a little girl got hurt."],[8996,9113,"Is Anna okay?"],[9113,9192,"Relax."],[9275,9396,"Anna's fine."],[9396,9522,"She's just napping."],[9605,9793,"I just ran to go get her some snacks."],[11232,11378,"She's in critical condition."],[11436,11524,"We're low on gear,"],[11524,11640,"but if we get her to the hospital"],[11640,11728,"in ten minutes,"],[11740,11845,"she's got a chance."],[11874,12062,"No stops, no delays."],[12074,12187,"Can you go any faster?"],[12604,12654,"Shit!"],[13129,13158,"What,"],[13158,13217,"what happened?"],[13968,14168,"Are you fucking blind?"],[14777,14881,"Get out!"],[14935,15065,"And look what you did"],[15065,15281,"to my fucking car!"]],"2":[[45,133,"What, what happened?"],[258,325,"I'm going to go check."],[325,375,"Okay."],[375,437,"You stay with the girl."],[437,487,"Yeah."],[508,575,"It's gonna be fine."],[613,663,"Hang in there."],[696,754,"Shh."],[779,855,"I'm gonna go check."],[884,988,"Get out!"],[1038,1163,"And look what you did"],[1163,1380,"to my fucking car!"],[1455,1568,"I stopped the second I saw you."],[1593,1710,"You were speeding. This is on you."],[1897,2035,"Excuse me?"],[2152,2206,"You"],[2223,2506,"are the one who smashed into my car."],[2690,2740,"You're blaming me"],[2740,2840,"because I'm a woman."],[2890,2957,"Is that it?"],[2969,3007,"What?"],[3036,3069,"No."],[3157,3215,"Don't twist this"],[3215,3311,"into something it's not."],[3374,3511,"Watch your attitude."],[3636,3832,"You think you're hot shit"],[3832,4024,"just because you're in uniform."],[4079,4333,"Your broke ass needs to apologize"],[4358,4592,"and pay up for what you did."],[4750,4804,"Ma'am,"],[4854,4925,"please just-"],[4925,5034,"There's an injured child"],[5034,5125,"in the back of this truck,"],[5125,5259,"and she's barely hanging on"],[5259,5321,"from the fires."],[5321,5463,"We need to get her to the ER now,"],[5463,5630,"so if you could just please,"],[5668,5830,"please, just let us through."],[5855,6093,"You think because you have a hurt kid"],[6118,6202,"that you can just"],[6227,6473,"smash my car and drive off?"],[6581,6781,"Who do you think you are?"],[6881,6977,"Lady, they're trying to save"],[6977,7090,"a kid's life."],[7111,7236,"Get out the damn way."],[7278,7378,"It's your fault."],[7453,7586,"What kind of an asshole"],[7624,7761,"argues with a firefighter"],[7782,7887,"in the middle of an emergency?"],[7887,7995,"Shut up!"],[8312,8712,"I have lived here for over ten years."],[8846,9059,"These homes are worth more"],[9059,9267,"than any of you make in a lifetime."],[9451,9680,"I belong here."],[9868,9997,"You're all just"],[10072,10164,"out of place."],[10172,10306,"Ma'am, this is your final warning."],[10347,10493,"Blocking an emergency vehicle"],[10493,10568,"is a crime."],[10610,10648,"Oh,"],[10710,10777,"please."],[10906,11111,"My husband is a top attorney."],[11177,11357,"He makes over a thousand dollars"],[11357,11428,"in an hour."],[11453,11661,"He will bury you in paperwork"],[11661,11786,"before your shift is over."],[11815,12103,"So don't you quote the law to me."],[12137,12174,"Ma'am,"],[12258,12324,"please."],[12354,12550,"Just imagine if it were your child"],[12570,12691,"in the back of this truck."],[12833,12875,"Ah!"],[13046,13284,"Don't you dare jinx my daughter,"],[13284,13371,"you bitch!"],[13438,13726,"My daughter is good and kind,"],[13755,13980,"unlike your stupid brat"],[13980,14130,"who runs into danger."],[14564,14622,"Alright."],[14735,14802,"You're gonna be okay."],[14802,14981,"Mama, it hurts."],[15019,15140,"You're gonna be okay, baby."]],"3":[[150,304,"I am not the child's mother."],[404,525,"I was just taking a jog."],[588,696,"But I think"],[725,942,"any reasonable human being"],[942,1021,"would try"],[1021,1213,"to at least save a child's life!"],[1263,1418,"Oh, I get it."],[1455,1685,"You're playing hero to dodge the bill."],[1710,2143,"My car is totaled and I am the villain?"],[2281,2623,"I don't care if some stupid brat dies."],[2669,2873,"If you want me to move it,"],[2965,3144,"then you need to apologize"],[3174,3303,"and pay up."],[3682,3753,"Oh, God."],[3791,3895,"No, no, no, no, no."],[3945,4004,"No."],[4145,4245,"She's crashing!"],[4270,4408,"She's going into shock."],[4408,4587,"We need to move now!"],[4650,4754,"We don't have time for this."],[4950,5138,"What if something happens to her, huh?"],[5255,5363,"What are you gonna say when her parents"],[5363,5447,"come looking for answers?"],[5488,5609,"If her own parents"],[5609,5705,"can't even be bothered"],[5705,5793,"to stick around,"],[5793,6026,"then why should I give a damn"],[6026,6156,"if she lives or dies?"],[6156,6243,"We haven't been able"],[6243,6356,"to reach her parents yet,"],[6356,6414,"but,"],[6414,6560,"but that's besides the point."],[6623,6831,"She's all alone now and she needs help."],[6911,6981,"Please."],[6998,7219,"If her own parents don't even care,"],[7219,7419,"why the hell should I?"],[7440,7511,"What the hell is wrong"],[7511,7595,"with this woman?"],[7611,7665,"Jesus."],[7691,7862,"Someone shut her up before I do."],[7924,8087,"Say whatever you want about me."],[8170,8237,"I don't care."],[8337,8608,"But please, I am begging you."],[8696,8783,"Move your car"],[8804,8988,"so we can save this child's life."],[9013,9054,"Mm."],[9138,9296,"Now we're talking."],[9388,9459,"Tell you what."],[9613,9730,"give me a hundred grand"],[9730,9864,"for the damages, and"],[9905,9984,"I'll move it."],[9984,10147,"You're putting a price tag"],[10147,10289,"on a child's life?"],[10360,10506,"Clock's ticking."],[10606,10731,"Pay up or"],[10777,10927,"let the little brat die."],[11065,11131,"Your call."],[11165,11227,"Let's go!"],[11227,11307,"Move your car!"],[11307,11373,"Come on!"],[11453,11557,"She's just a little girl."],[11557,11682,"Move your car now!"],[11695,11765,"Enough!"],[11886,12157,"We are moving the car ourselves."],[12187,12241,"Yeah."],[12241,12337,"Come on! - Let's go!"],[12575,12666,"Touch my car"],[12666,12833,"and I'll bash your brains in."]],"4":[[54,116,"Back up."],[166,258,"Touch my car"],[258,417,"and I'll make you regret it."],[454,633,"She's lost her mind."],[738,880,"A five-year-old is dying"],[880,967,"because of you!"],[967,1092,"That little brat is dying"],[1092,1180,"because of you!"],[1242,1472,"I am just defending what is mine."],[1543,1697,"God won't forgive you for this."],[1697,1818,"You're shameless."],[2006,2068,"Please."],[2147,2331,"You are just a bunch of"],[2331,2590,"self-righteous nobodies."],[2623,2927,"Maybe if you spent less time judging,"],[2977,3182,"and more time parenting,"],[3219,3332,"your kid"],[3332,3549,"wouldn't end up in the damn street."],[3757,3812,"Enough!"],[3887,3999,"Her pulse is fading."],[4024,4112,"She won't make it"],[4112,4266,"unless we get to the hospital"],[4266,4387,"in five minutes!"],[4450,4500,"Ma'am."],[4562,4667,"Please, I'm begging you."],[4788,4859,"Let us through."],[4954,5246,"Still refusing to pay up."],[5538,5588,"Fine."],[5626,5809,"Let's see how your truck runs"],[5809,5939,"without windows."],[5964,6026,"Stop!"],[6297,6464,"Oh my gosh, she's completely unhinged."],[6489,6639,"Everyone, look."],[6664,6806,"This madwoman is stopping"],[6806,7065,"a fire truck from saving a child,"],[7077,7190,"and wrecking"],[7190,7353,"emergency properties."],[7353,7428,"Someone stop her!"],[7428,7615,"Get the camera out of my face!"],[7820,8070,"My husband is a top lawyer,"],[8070,8387,"he is going to send you all to jail."],[8450,8529,"You know, we gotta do"],[8529,8633,"something about this."],[8921,9000,"Hi. Honey?"],[9054,9196,"Alright, look, it's a little loud over there."],[9280,9409,"Are you still near that fire?"],[9442,9513,"Did they figure out"],[9513,9655,"whose poor kid that was?"],[9697,9934,"Who cares about some dying brat?"],[9968,10168,"I was hit by a fire truck"],[10181,10314,"and now I'm being ambushed"],[10314,10510,"by a bunch of lunatics."],[10510,10639,"You got hit by a fire truck?"],[10656,10827,"Okay listen, you need to calm down"],[10827,10881,"and listen to me."],[10881,11023,"I will not calm down."],[11044,11136,"They are trying to"],[11161,11294,"hit and run your wife."],[11307,11407,"You are a lawyer."],[11448,11519,"Do something."],[11519,11640,"Alright, alright, I'm coming."],[11640,11724,"Just calm down."],[11724,11799,"Just stall them."],[11836,11999,"Get the fire fighter's badge number"],[12032,12149,"and get the dispatch code."],[12666,12779,"You heard my husband."],[12833,12987,"Badge, now."],[13480,13521,"Here."],[13697,13847,"Can you please just let us by?"],[13922,14001,"I apologize."],[14064,14205,"I'll pay for all of the damages."],[14401,14572,"I need to just verify"],[14572,14789,"that this is dispatch first."],[14831,14923,"Make sure you're even"],[14969,15115,"authorized to be here?"],[15131,15215,"I said I apologize."],[15215,15298,"I offered to pay."],[15365,15452,"What more do you want?"],[15582,15765,"What I want?"],[15886,16132,"What I want?"],[16216,16341,"What I want"],[16474,16808,"is for each one of you to grovel"],[16929,17137,"and beg for my forgiveness."]],"5":[[8,321,"You, you, and you."],[367,529,"Every single one of you"],[529,763,"peasants owes me an apology."],[763,855,"Are you serious?"],[930,1076,"Why the hell should I apologize"],[1076,1180,"to some psycho?"],[1197,1347,"I used to think people like you"],[1347,1472,"only existed in movies."],[1514,1672,"You're a whole new level of evil."],[1672,1835,"Is your heart made of stone?"],[1860,1993,"How could you be so cruel?"],[2006,2110,"Shut up."],[2139,2560,"You're all just a bunch of losers."],[2615,2840,"This man hit my car"],[2848,3028,"and thinks he can get away with it."],[3053,3228,"You're all accomplices."],[3244,3553,"Apologize or the brat dies."],[3620,3728,"Right here,"],[3820,3903,"right now."],[4279,4429,"She needs to make it to the hospital soon."],[4675,4775,"Go ahead."],[4775,4896,"Keep pretending"],[4896,5059,"that you're the good guys."],[5088,5351,"If that brat dies, it's on you."],[5380,5459,"All of you."],[5551,5626,"Not me."],[5714,5868,"She's losing blood, Captain."],[5868,6014,"If we don't get her out now,"],[6014,6131,"she won't make it."],[6318,6431,"Alright, alright, fine."],[6464,6560,"Okay, fine."],[6577,6627,"Mhm?"],[6685,6802,"I apologize."],[6973,7090,"Just please let us through."],[7336,7457,"For the kid, I'm sorry, too."],[7511,7574,"I'm sorry."],[7686,7799,"I apologize."],[7832,7928,"Please move the car."],[7995,8041,"Here."],[8133,8229,"We've all said it."],[8279,8429,"Can you please just let us pass now?"],[8483,8550,"There."],[8850,9075,"Now, was that so hard?"],[9096,9275,"You know, you all could have just"],[9275,9484,"saved a lot of time,"],[9484,9693,"if you just swallowed your pride."],[9718,9976,"I'm the one who got hit, remember?"],[10014,10218,"That's not my kid bleeding out in there."],[10218,10585,"So why should I pay the price?"],[10723,10819,"Come on, sweetie."],[10819,10915,"Just hang in there."],[10973,11077,"We're gonna save you, okay?"],[11077,11136,"Just,"],[11215,11323,"just a little bit longer."],[11457,11540,"Ma'am, please."],[11615,11695,"Just move the car."],[11799,11891,"Okay."],[11961,12087,"Fine, fine, I'll move it."],[12087,12157,"Sure."],[12341,12449,"For a million bucks."],[12504,12766,"You know, for the emotional trauma"],[12766,12871,"that you have caused me."],[12933,13175,"My time is very precious, you know."],[13188,13229,"Enough."],[13254,13421,"We put up with your shit for too long."],[13434,13546,"Since you won't move,"],[13563,13734,"we'll move your car for you."],[13742,13805,"Exactly."],[13855,13913,"Come on, everyone."],[13913,13997,"Let's move this car."],[13997,14093,"Let's save the child."],[14093,14155,"Let's go."],[14189,14230,"Let's go."],[14230,14289,"Don't you dare touch it."],[14289,14343,"You hear me?"],[14372,14506,"Over my dead body."]],"6":[[120,237,"Enough of your bullshit."],[262,354,"The kid's out of time."],[367,504,"We're moving the car."],[525,613,"Get out the way."],[888,984,"Let's move this car."],[1005,1088,"Let's save the kid."],[1121,1180,"Push."],[1197,1263,"Let's go."],[1455,1689,"Get away from my car, you bastards!"],[1818,1872,"Push."],[1935,1997,"We got it."],[1997,2077,"Right this way."],[2118,2185,"Keep going."],[2193,2239,"Here we go."],[2239,2323,"Pull a bit more that way."],[2323,2423,"Good, good, almost."],[2907,2977,"That's good."],[3015,3073,"Good job, y'all."],[3073,3153,"Good job, good job."],[3365,3424,"Good job, y'all."],[3436,3486,"Good job."],[3528,3757,"You're all going to regret this."],[3766,3816,"No!"],[3878,3916,"No."],[3970,4049,"What are you doing?"],[4083,4195,"You all moved my car"],[4195,4275,"without permission."],[4275,4521,"Now no one is going anywhere."],[4604,4675,"Captain!"],[4721,4850,"I have her stable for now,"],[4850,4921,"but,"],[4921,5092,"but we have to move, okay?"],[5121,5280,"I can't hold her much longer."],[5380,5551,"Give me back the damn keys."],[5576,5684,"Have you lost your mind?"],[5714,5818,"She is literally"],[5818,5980,"the worst person I've ever seen."],[6156,6352,"Give it back, you psycho."],[6352,6552,"I am done playing nice with you."],[6569,6648,"Give it!"],[6848,6981,"I don't care where you shove them."],[7023,7136,"I'll rip them out myself!"],[7148,7399,"Don't you dare touch me, bitch."],[8120,8162,"No!"],[8299,8350,"Oops."],[8437,8654,"I guess we're all stuck now."],[8792,9013,"Captain, we are running out of time."],[9013,9154,"We need a car, any car now."],[9263,9313,"Okay."],[9459,9522,"Eve!"],[9592,9667,"Carry her out."],[10477,10581,"You all need some help?"],[10581,10681,"I can give you guys a ride"],[10681,10760,"to the hospital."],[11102,11190,"Come on, hurry up!"],[11215,11323,"Get the kid in the car!"],[11386,11448,"Go, go,go."],[11448,11549,"You're not going anywhere"],[11549,11720,"until someone pays for my car."],[12404,12696,"Wait, this kid looks familiar."],[12754,12825,"Is that?"],[13038,13092,"Anna?"]],"7":[[20,154,"That couldn't have been Anna."],[287,412,"She's not wearing her"],[412,596,"favorite scrunchie."],[667,704,"Ah!"],[1021,1197,"You pushed me, you bitch!"],[1238,1409,"Where do you think you're going?"],[1780,1860,"Let her go!"],[1868,1976,"That kid is dying"],[1976,2122,"and you're still getting in the way!"],[2373,2452,"What do I care?"],[2452,2581,"She's not my kid."],[2673,2794,"Everyone, grab her now!"],[2907,2973,"Hold her back."],[2973,3107,"We've got to save the girl."],[3328,3486,"Let go of me!"],[3486,3632,"What the hell is wrong with you?"],[3632,3770,"They're trying to save a little girl!"],[3770,3812,"Go."],[3820,3874,"Drive."],[3883,3970,"Get us to the hospital."],[3970,4033,"Now!"],[4191,4266,"She's evil!"],[4295,4471,"We can't let her near anyone else."],[4471,4704,"Get your filthy paws off of me."],[4796,4988,"My husband is a top lawyer."],[4988,5180,"He'll throw you all in jail!"]],"8":[[404,542,"She's still in critical condition,"],[542,696,"and she's lost a lot of blood."],[713,863,"We've got less than ten minutes"],[863,925,"to save her."],[942,1055,"If it weren't for that lunatic,"],[1055,1188,"we'd be in the hospital by now."],[1188,1251,"Who would hurt"],[1251,1372,"a five-year-old like that?"],[1539,1722,"Captain, we're running out of time."],[1764,1830,"Please,"],[1885,1939,"go faster."],[1939,2056,"We've got less than ten minutes."],[2093,2198,"I'll take the hit for the tickets."],[2198,2235,"Just,"],[2264,2348,"just drive."],[2348,2414,"Yes, sir."],[2969,3086,"My kid's around the same age."],[3119,3311,"Any parent, anyone with a heart,"],[3365,3503,"would do whatever it takes to save her."],[3591,3703,"That woman was out of her mind."],[3987,4162,"Out of my way, you useless idiots,"],[4162,4275,"or I'll run you down."],[5530,5693,"You bitch."],[5747,5939,"You think hiding behind a dying kid"],[5939,6035,"is gonna save you?"],[6097,6289,"Not a chance."],[6610,6702,"We'll make it in time."],[6810,6906,"The kid's got a chance."],[6944,7002,"Thank God."],[7002,7094,"We got you, sweetie."],[7152,7240,"Oh shit!"],[7432,7499,"It's the crazy woman."],[7499,7561,"She's back!"]],"9":[[62,137,"It's the crazy woman."],[137,208,"She's back!"],[337,425,"Out of the car."],[487,546,"Now!"],[759,880,"Sir, please, don't stop."],[880,967,"If she gets to us,"],[967,1021,"we won't make it"],[1021,1105,"to the hospital in time."],[1130,1180,"Go around her."],[1180,1255,"Use the side lane."],[1914,2077,"You bastards."],[2127,2210,"First a hit-and-run,"],[2210,2419,"and now you're trying to kill me?"],[3753,3903,"Obstructing a fire truck wasn't enough?"],[3903,3999,"Now she's chasing us?"],[3999,4074,"What the hell is wrong"],[4074,4133,"with this woman?"],[4133,4237,"She's insane."],[4767,4946,"Sir, please, you have to go faster."],[4946,5117,"We can't let her stop us again."],[5117,5226,"The kid's running out of time."],[5234,5392,"I'm going as fast as I can."],[5430,5588,"It's hard to outrun a sports car."],[7411,7520,"You morons think"],[7520,7636,"you can dodge the bill,"],[7636,7736,"just because you've got some"],[7736,7874,"dying kid in there?"],[7912,8083,"Pull over!"],[8149,8216,"Just ignore her,"],[8216,8304,"we've got to get the girl"],[8304,8383,"to the hospital."],[8383,8429,"Okay."],[8487,8529,"You,"],[8571,8708,"you will pay for what you've done."],[8717,8925,"So you're not gonna pay up, huh?"],[9017,9071,"Fine."],[9092,9213,"I am not gonna stop"],[9234,9359,"until I get what I want."],[9413,9588,"You are gonna watch that kid"],[9588,9705,"die in your arms"],[9705,9809,"and you are gonna know"],[9809,10085,"that it is all your fault!"],[11578,11715,"Don't, stop! - She's crazy."],[12216,12274,"Just continue-"],[12308,12404,"Oh my God."],[12454,12491,"Listen to me,"],[12491,12533,"just continue."],[12533,12641,"Just drive this way. - Fucking crazy bitch."],[12641,12721,"Go, go, go."],[13225,13367,"Fuck, crazy fucking bitch."],[13367,13446,"This way, just drive this way."]],"10":[[304,400,"What the heck is wrong with her?"],[408,504,"Isn't she a mother too?"],[529,625,"How can she be this cruel"],[625,734,"to someone's dying kid?"],[734,788,"She's heartless."],[788,863,"She won't understand"],[863,921,"until it's her own."],[946,1084,"Captain, the girl's got less than"],[1084,1192,"five minutes left."],[1388,1534,"Oh shit, she's behind us."],[2373,2498,"Please, just stop."],[2552,2698,"The poor girl needs a hospital."],[2698,2769,"We'll take care of"],[2769,2894,"everything else later."],[2894,3073,"Don't give me that crap."],[3073,3207,"You're just trying to run."],[3253,3511,"Stop the car!"],[3941,4004,"You,"],[4058,4208,"you are insane."],[4258,4383,"What you're doing is putting a"],[4383,4550,"five-year-old's life at danger."],[4733,4884,"You will pay for what you've done."],[4950,5067,"You're recording me?"],[5125,5242,"You bitch!"],[5271,5388,"Get out of the car."],[5426,5492,"Now!"],[5780,5814,"Go."],[5814,5864,"Turn left."],[5880,5947,"She'll spin out."],[7244,7344,"This isn't over!"],[7394,7561,"You're not getting away with this!"],[7628,7741,"Taxi!"]],"11":[[296,462,"Doctor, doctor, please."],[462,575,"We need help with this little girl."],[621,738,"Help me get her to the elevator."],[738,829,"Third floor O.R."],[829,884,"Okay."],[884,934,"You're good."],[2594,2660,"Where are you?"],[2660,2769,"Why aren't you here yet?"],[2857,2894,"Hey, babe."],[2894,3011,"I'm still wrapping up a case."],[3011,3061,"Where are you?"],[3165,3294,"I'm at the hospital."],[3336,3507,"That bitch rammed into my car."],[3507,3624,"I'm not letting this go."],[3670,3737,"The hospital?"],[3820,3866,"What happened?"],[3866,3941,"Is Anna okay?"],[4054,4195,"Are you deaf?"],[4229,4462,"I said I am at the hospital"],[4462,4600,"because of that bitch!"],[4650,4708,"Get here now."],[4708,4842,"You have ten minutes."],[4871,4925,"Okay, Babe."],[4942,5009,"Don't be mad."],[5009,5055,"It's just,"],[5075,5217,"I'm a little worried about our daughter."],[5226,5313,"Can you call Anna?"],[5342,5422,"Is she alright?"],[5497,5801,"The kid from the fire isn't even Anna."],[5872,6118,"Can you care about me, for once?"],[6168,6297,"Just once!"],[6527,6610,"Okay, well."],[6610,6731,"Well, if you're not coming here"],[6731,6977,"to help me, then we are done."],[7040,7273,"You're never gonna see Anna again."],[7294,7357,"I'm on my way,"],[7369,7494,"but please just call her."],[7511,7632,"I need to know she's okay."],[7653,7824,"Fine, I'll call her."],[7862,7991,"Anna, Anna, Anna."],[7991,8199,"All you ever care about is Anna."],[9250,9321,"Hang in there."],[9826,9909,"Easy, easy."]],"12":[[100,183,"Fuck!"],[638,771,"You're not getting away!"],[1242,1309,"Okay, let's go."],[1438,1534,"I got it. I got it."],[2235,2298,"Okay."],[2544,2627,"Hemostat."],[2890,2998,"Her pulse is weakening."],[3816,3903,"I think I want some water."],[3903,3995,"Do you guys want some water?"],[4004,4079,"Yeah, thank you."],[4079,4149,"I'll take one."],[4149,4200,"I'll get some."],[4437,4579,"Dear God, please have mercy."],[4654,4788,"She's only five years old."],[4925,5084,"She has to make it, please."],[5338,5388,"Oh."],[5563,5843,"Bunch of worthless bums."],[5918,6051,"You thought you could trick me"],[6051,6222,"by hiding in the hospital?"],[6293,6569,"Your truck crashed into my car"],[6569,6719,"and now it's totaled."],[6790,6936,"Two million won't even cover it."],[7007,7065,"Five million."],[7082,7178,"Not a penny less."],[7248,7298,"You."],[7399,7469,"You again."],[7620,7728,"You won't get a cent from me,"],[7728,7824,"you piece of shit."],[7849,7966,"You blocked a fire truck,"],[8008,8162,"and you obstructed first responders."],[8233,8333,"You've broken the law."],[8487,8604,"Your broke ass"],[8604,8771,"wants to talk about the law."],[8825,9029,"My husband is one of the most"],[9029,9200,"well-known lawyers here."],[9230,9342,"He is an expert"],[9342,9522,"on dealing with scum like you."],[9588,9797,"Pay up and apologize,"],[9834,10110,"or you're going straight to jail."],[10268,10414,"You've been trying to get in our way"],[10414,10548,"since we've been on the road."],[10568,10744,"We told you again and again."],[10760,10940,"This kid's life is in danger,"],[10960,11065,"but you didn't care."],[11090,11236,"Now she's fighting for her life,"],[11236,11478,"so can't you just shut up for once?"],[11728,11832,"What the hell"],[11857,12024,"does this have to do with you?"]],"13":[[4,100,"Why did you do that?"],[158,300,"She was just trying to save a kid."],[362,513,"Give me a break."],[513,642,"You are just trying to"],[642,813,"use an injured child"],[813,988,"to get out of paying me."],[988,1113,"She would have been fine"],[1113,1242,"in a few minutes anyway."],[1430,1668,"She is literally in the O.R. right now."],[1685,1810,"The doctors are doing everything"],[1810,1943,"they can to save her."],[1972,2106,"They said she could die any minute,"],[2106,2231,"and how dare you"],[2231,2364,"say something like that?"],[2435,2652,"So what?"],[2694,2907,"Who cares if the brat dies?"],[2944,3111,"Not my problem."],[3182,3503,"Your problem is you need to pay up."],[3620,3753,"Have you no conscience?"],[3903,4045,"You rammed us on the road."],[4045,4204,"You blocked the fire truck."],[4204,4295,"Without you,"],[4304,4391,"she would have gotten her"],[4391,4579,"here way, way sooner,"],[4579,4725,"and you're still blaming us?"],[4971,5055,"Look, everyone."],[5075,5284,"Look how this crazy bitch"],[5296,5655,"is trying to kill a poor little girl."],[5935,6022,"A few minutes"],[6022,6177,"wouldn't have killed anyone anyway."],[6302,6585,"Besides, even if the brat dies,"],[6585,6827,"maybe it was meant to be."],[6856,6898,"God,"],[6927,7152,"stop pretending like you're a saint."],[7240,7390,"You're not even the kid's mother."],[7432,7557,"Why do you care?"],[7707,7916,"You seriously make me sick."],[8012,8108,"I've held back"],[8108,8187,"because we were trying to"],[8187,8333,"save the kid first."],[8441,8600,"But I've had enough of you."],[8600,8821,"You are not getting away with this."],[9042,9146,"You bitch."],[9180,9376,"You think you can threaten me?"],[9567,9726,"Even if you have proof,"],[9751,10026,"my husband will do everything"],[10026,10364,"to get me out and put you all in jail."],[10389,10447,"Enough."],[10581,10685,"How do you not have"],[10685,10814,"even just a little bit of guilt?"],[10923,10985,"I'm a father."],[11011,11152,"Had that been my kid in the car,"],[11152,11240,"I'd have done whatever it took"],[11240,11327,"to get past you."],[11348,11678,"I don't care whose kid it was."],[11720,11840,"Bunch of broke,"],[11878,12062,"useless bottom feeders."],[12149,12291,"Whoever dies,"],[12454,12629,"I'll just cover it with money."],[12917,13004,"Are you even human?"],[13158,13259,"You can't put a price tag"],[13259,13350,"on someone's life."]],"14":[[33,116,"What are you doing?"],[354,504,"My husband will be here any minute."],[521,700,"If you touch me,"],[784,963,"he will make you rot in jail"],[963,1084,"for the rest of your life"],[1084,1172,"and he 'll bankrupt"],[1172,1292,"your entire family."],[1292,1376,"I'm not scared of you,"],[1376,1501,"or your lawyer husband."],[1614,1701,"Because you know what?"],[1701,1993,"Once I post this video,"],[1993,2189,"everyone is going to see"],[2189,2439,"that you are a cold, heartless bitch"],[2439,2581,"who would let a child die!"],[2665,2748,"And guess what?"],[2802,2961,"Your husband is going to be the one"],[2961,3082,"who's gonna lose his job."],[3111,3228,"Don't you dare."],[3240,3411,"That is an invasion of privacy."],[3482,3611,"Just stop now,"],[3636,3812,"apologize, and leave us alone."],[3841,3916,"Or everyone you know"],[3916,4033,"is gonna turn against you."],[4141,4287,"You think that I care?"],[4362,4483,"My husband"],[4508,4742,"just closed a huge case."],[4775,4979,"We're moving to Billionaire Row"],[4979,5167,"to get away from bums like you."],[5234,5476,"None of this is gonna affect me."],[5643,5889,"Oh my God, look what's trending."],[5918,6139,"That crazy bitch smashed a fire truck"],[6139,6268,"trying to save a kid."],[6302,6364,"Whoa."],[6364,6610,"A five-year-old's life is on the line,"],[6610,6723,"and instead of helping,"],[6723,6936,"she just starts harassing the people"],[6936,7090,"trying to save the kid."],[7090,7286,"And now this crazy bitch has"],[7286,7453,"followed them to the hospital."],[7549,7636,"Shut up!"],[7957,8099,"That kid dying"],[8099,8266,"has nothing to do with me."],[8312,8466,"My car is worth more than"],[8466,8637,"all of you put together."],[8637,8842,"So don't you talk to me"],[8842,9025,"about owing anybody anything."],[9092,9346,"Give me the fucking phone."],[9864,9980,"Babe, what's going on?"],[10372,10556,"Babe, what took you so long?"],[10556,10806,"These bums are ganging up on me."]],"15":[[254,513,"Babe, where have you been?"],[546,721,"They're all ganging up on me."],[734,846,"So, are these the people"],[846,930,"that hit your car?"],[930,1055,"Yes, it's them."],[1121,1334,"They hit my car, crashed into me,"],[1334,1463,"and now they're trying to make me"],[1463,1597,"look like the bad guy."],[1826,1989,"Babe, arrest them"],[1989,2135,"and send them to jail."],[2431,2594,"I'm a partner at a top law firm."],[2635,2761,"You've committed serious crimes"],[2761,2857,"against my wife."],[2857,2986,"We will be pressing charges."],[3165,3278,"So you're the husband, huh?"],[3378,3432,"Do you even know"],[3432,3541,"what your wife has done?"],[3599,3737,"If you would call the cops,"],[3787,3958,"I want to see who they arrest."],[3991,4216,"Miss, you hit my wife's car first."],[4225,4312,"I wouldn't be so sure"],[4312,4375,"you're in the clear."],[4462,4550,"Captain Bob Clarke,"],[4579,4646,"fire department."],[4729,4808,"You're a father, right?"],[4967,5113,"Had that been your kid in the car,"],[5138,5221,"would you really be"],[5221,5342,"talking about laws right now?"],[5405,5476,"Kid in danger?"],[5613,5797,"Babe, don't listen to them."],[5797,5972,"I wasn't trying to stop anyone"],[5972,6051,"from saving a kid."],[6051,6156,"I just wanted them"],[6181,6364,"to pay for the damages."],[6523,6627,"You're blaming us?"],[6660,6765,"You rammed our car."],[6827,6969,"You were throwing stuff at our truck"],[6969,7190,"as we were trying to go to the hospital."],[7198,7278,"Because of you,"],[7278,7478,"a child is in critical condition."],[7565,7678,"You're a monster."],[7770,7853,"Is it true?"],[7920,8070,"You delayed the rescue of a child?"]],"16":[[0,133,"They're lying."],[158,337,"I wasn't trying to stop them"],[337,467,"from saving anybody."],[475,671,"I just wanted an apology"],[671,742,"before moving,"],[742,884,"but they wouldn't."],[913,1088,"And they tried to have people"],[1088,1155,"beat me up."],[1155,1305,"It is their fault"],[1305,1388,"and they are just trying to"],[1388,1564,"blame it all on me."],[1564,1676,"We weren't trying to blame it on you."],[1676,1755,"We apologized."],[1776,1893,"I apologized."],[1918,2056,"You just didn't budge."],[2085,2227,"My car was trash."],[2227,2419,"Of course an apology is not enough."],[2460,2669,"You all need to pay up."],[2711,2752,"Babe."],[2802,2848,"What?"],[2973,3119,"Even if they hit your car first,"],[3144,3278,"they were trying to save a child."],[3303,3395,"You shouldn't have blocked them"],[3395,3490,"and you certainly"],[3490,3595,"and definitely shouldn't have"],[3636,3712,"chased them."],[3737,3820,"You were wrong."],[3870,3983,"You owe them an apology."],[4120,4358,"Are you out of your mind?"],[4379,4650,"Why should I apologize to them?"],[4683,4796,"They wrecked my car."],[4817,5038,"They hurt me and I,"],[5080,5209,"I'm the victim."],[5263,5355,"You're the victim?"],[5388,5480,"A five-year-old is in"],[5480,5651,"critical condition because of you."],[5693,5918,"Well then, that brat deserves it."],[5926,6101,"She is not worth millions."],[6101,6256,"My car is."],[6256,6356,"She deserves it?"],[6410,6535,"My God, what are you talking about?"],[6690,6731,"Look,"],[6731,6898,"since this was all about saving a child,"],[6948,7052,"we can let everything go."],[7102,7265,"You hit my wife, we're even."],[7269,7357,"It's over now."],[7411,7528,"You think you're being generous."],[7611,7749,"Here, take a look at what your wife did."],[7832,7891,"Go ahead."],[8412,8550,"Nothing is over."],[8654,8808,"Babe, listen,"],[8854,9034,"this is all part of their plan."],[9034,9213,"They are just trying to set me up."],[9530,9605,"Wait a second."],[9755,9947,"Isn't that Anna's smartwatch?"]],"17":[[33,187,"Isn't that Anna's smartwatch?"],[250,362,"Don't be ridiculous."],[379,604,"One in ten kids has a smartwatch."],[617,813,"Do not let them trick you."],[875,963,"You stopped them"],[963,1067,"from trying to save a child,"],[1067,1180,