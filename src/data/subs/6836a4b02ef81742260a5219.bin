,"Have you lost your mind?"],[2560,2719,"She's not even your daughter."],[2727,2815,"Why do you care?"],[2848,3123,"If she dies, that's on them"],[3123,3299,"for not getting her here on time."],[3365,3486,"We have a daughter, too."],[3541,3649,"What if it were Anna?"],[3653,3803,"You'd want someone to save her too,"],[3803,3858,"wouldn't you?"],[3866,4083,"Don't you dare curse our daughter."],[4141,4250,"Anna is fine."],[4266,4421,"And even if she wasn't,"],[4433,4629,"we wouldn't ask for their help."],[4717,4917,"Since when have you become like this?"],[4967,5125,"Open your eyes, Tom."],[5217,5422,"That is your darling wife."],[5467,5634,"She would hurt a five-year-old"],[5634,5797,"and she still doesn't care."],[6243,6322,"I said,"],[6322,6498,"I've had enough of your bullshit."],[6498,6581,"You bitch!"],[6627,6681,"Tom!"],[6744,6890,"Man up."],[6890,7036,"You're just gonna stand there"],[7069,7286,"and let someone hit your wife?"],[7699,7766,"Doctor."],[7895,7970,"The child, - The child,"],[7970,8049,"is she okay? - is she okay?"],[8108,8287,"We tried everything possible."],[8345,8425,"If she'd been here"],[8433,8566,"five minutes sooner,"],[8612,8725,"we could have saved her."],[8725,8775,"No."]],"19":[[187,271,"My God."],[279,354,"She's gone?"],[412,471,"Damn it!"],[779,905,"We did everything we could to"],[905,1017,"get her here on time but..."],[1167,1309,"we were still five minutes late."],[1397,1530,"Gosh, she was only five."],[1626,1760,"Same age as my little girl."],[1868,2027,"She never even had a chance to live."],[2056,2206,"This is all on you."],[2210,2381,"If you hadn't wasted our time,"],[2398,2527,"we could have saved the girl."],[2544,2715,"And she might have still be alive!"],[2756,3073,"Not my fault she didn't make it."],[3199,3457,"You all wasted time arguing,"],[3474,3653,"instead of just paying me."],[3757,3832,"You're sick."],[3832,3933,"A child is dead."],[3945,4116,"A child is dead."],[4141,4304,"And her parents couldn't even be"],[4312,4462,"bothered to be here."],[4512,4746,"Clearly no one cares."],[4808,4988,"Plus, she's just a drain"],[4988,5159,"on public resources anyway."],[5201,5347,"I mean, you should all be grateful."],[5401,5551,"I saved you taxpayer money."],[5605,5730,"Shut up!"],[5864,5939,"Tom!"],[6022,6185,"You are supposed to be helping me,"],[6197,6343,"I am your wife!"],[6343,6423,"That's enough."],[6510,6614,"The child is dead."],[6690,6835,"We need to contact her parents."]],"20":[[16,154,"Even your husband is sick of you,"],[154,304,"and you still wouldn't take the blame,"],[304,346,"huh?"],[446,684,"A child is dead because of you,"],[750,846,"and I will make sure that"],[846,938,"you pay for it."],[955,1017,"Oh?"],[1017,1209,"What are you gonna do about it?"],[1718,1785,"You know what?"],[1889,2010,"I figured it out."],[2106,2193,"You all"],[2210,2402,"found some dying brat in the street,"],[2427,2548,"wrecked my car"],[2548,2702,"and then pinned me for it,"],[2702,2827,"because I have money."],[2957,3123,"This whole thing was a setup."],[3161,3294,"How dare you talk about"],[3294,3403,"a dead girl like that."],[3507,3616,"Now I know"],[3645,3858,"why none of you wanted to pay,"],[3920,4179,"this was all a scam from the start."],[4191,4308,"I'm really sorry for everything."],[4408,4487,"I'll cover all the bills"],[4487,4592,"and any other damages."],[4621,4729,"And we won't be pressing charges"],[4729,4796,"about the car."],[4867,5009,"I'm just gonna take her home now."],[5613,5655,"Who was that?"],[5655,5793,"It's just spam."],[5805,5951,"What are you waiting for?"],[5976,6101,"Use your connections."],[6101,6373,"And get them arrested now."],[6393,6481,"Why are you so nervous?"],[6481,6539,"What's wrong?"],[6556,6664,"Was it Anna?"],[6685,6815,"She's home safe, right?"],[6831,7107,"Of course she is."],[7136,7290,"I was at home all day."],[7290,7520,"I just ran out to get her some snacks,"],[7532,7711,"and then I ran into them."],[7761,7891,"I've already contacted"],[7891,7995,"the building manager."],[8012,8095,"He'll be reaching out"],[8095,8320,"to every family affected by the fire."],[8412,8508,"I'll need you all to"],[8508,8662,"provide a witness statement."],[8717,8812,"If you're so brave,"],[8892,8988,"why don't you stay here?"],[9063,9171,"And see how tough you are,"],[9238,9305,"when you have to face"],[9305,9409,"that little girl's parents."],[9776,9893,"It's the building manager."],[9968,10022,"Hello?"],[10160,10226,"What's going on?"]],"21":[[16,196,"Sir, there was a fire in your building."],[229,312,"It's been contained"],[312,437,"but a young child was injured."],[450,575,"We're checking in all the residents,"],[575,642,"please make sure"],[642,763,"your family is accounted for."],[763,925,"Wait, wait, our building?"],[967,1109,"What do you mean a child was hurt?"],[1180,1338,"We're still confirming identities."],[1338,1551,"So far we know the girl is about 5,"],[1597,1747,"around 3-feet tall,"],[1776,1881,"and was wearing a white dress"],[1881,1943,"at the time."],[2298,2402,"Tom?"],[2456,2531,"What's wrong?"],[2648,2831,"Why are you looking at me like that?"],[2831,3103,"It's just a scam call, ignore it."],[3103,3157,"Karen,"],[3257,3324,"where is Anna?"],[3445,3620,"She is at home."],[3632,3757,"I told you,"],[3782,3987,"I just ran to the store"],[3987,4095,"to get her some snacks,"],[4104,4350,"and then I ran into these losers."],[4416,4517,"What about the fire?"],[4575,4692,"Did you see her after it happened?"],[4733,5046,"Yes, of course I did."],[5067,5246,"I went home first"],[5255,5330,"to check on her,"],[5330,5538,"before I chased them."],[5559,5818,"And she was just sleeping"],[5826,5918,"before I left."],[5955,6056,"Are you serious?"],[6143,6285,"You were tailing us the whole time."],[6297,6464,"There's no way you had time to go home."],[6510,6669,"You shut the fuck up."],[7107,7219,"Who keeps calling you?"]],"22":[[375,479,"Who keeps calling you?"],[504,734,"It's just scammers."],[763,867,"That building manager"],[867,1013,"was probably faked too."],[1059,1292,"Right, the same scammers spoofed"],[1292,1426,"both of you and pretended to be"],[1426,1534,"your building manager?"],[1589,1735,"That is one hell of a coincidence,"],[1735,1801,"isn't it?"],[1801,1889,"Wait, wait, wait."],[1956,2127,"That was the building manager."],[2177,2323,"Our apartment was on fire?"],[2352,2773,"No, I told you, everything is fine."],[2790,2977,"Anna is alright."],[3032,3178,"The building we reported earlier,"],[3236,3353,"it was on Grove Lane."],[3449,3528,"What was the number again?"],[3595,3782,"Grove Lane, that's our street."],[3807,3912,"Karen, give me your phone!"],[3912,4166,"You are being paranoid."],[4195,4500,"I told you, it's just scammers."],[4529,4654,"I cannot believe"],[4671,4871,"you are taking their side over mine?"],[4892,5025,"Stop blaming it on others."],[5025,5180,"No one is trying to scam you."],[5192,5547,"Oh, of course, it is a scam."],[5572,5755,"You found some dying brat,"],[5768,5876,"wrecked my car,"],[5897,6160,"and now you're pinning it on me."],[6227,6381,"You guys planned this."],[6406,6552,"That brat deserves it,"],[6564,6702,"whatever happens."],[6727,7144,"So now you need to pay me for my car."],[7378,7449,"Tom?"]],"23":[[0,179,"Tom, what the hell?"],[279,371,"You're supposed to be"],[379,500,"backing me up and"],[521,700,"now you're accusing me?"],[738,825,"How could you?"],[829,1034,"I don't care about the money."],[1055,1217,"I just want to make sure Anna's safe."],[1267,1476,"What's with that tone?"],[1530,1705,"I am your wife,"],[1739,1881,"not some suspect"],[1881,2018,"you're interrogating."],[2035,2118,"It's not what I mean."],[2173,2264,"The building manager said"],[2264,2331,"there was a fire."],[2352,2489,"I just want to make sure Anna is okay."],[2489,2690,"Tom, I swear."],[2740,2857,"If you go through my phone,"],[2857,2948,"we are done."],[3003,3236,"I'm divorcing you and taking Anna."],[3386,3465,"I won't."],[3474,3520,"Good."],[3524,3578,"Okay?"],[3674,3762,"Let's just go home."],[3774,3858,"Do you really think"],[3858,3991,"going away will fix this?"],[3991,4179,"She's not getting off that easy."],[4333,4517,"Give me my phone."],[4571,4717,"You're supposed to be helping me,"],[4717,4921,"and making those bottom feeders"],[4921,4996,"pay up."],[5017,5188,"Now you're accusing me?"],[5334,5593,"You are fucking useless."],[6164,6247,"Go back, go back."],[6460,6702,"Karen, please, I just wanna go home."],[6706,6827,"I need to see Anna."],[6861,7023,"You keep cursing her"],[7023,7248,"when I have told you so many times"],[7248,7344,"that she is alright."],[7403,7607,"Go ahead, look for yourself,"],[7624,7899,"see if this kid lying here is Anna."]],"24":[[16,200,"Look, see for yourself,"],[200,358,"if this is Anna."],[1146,1226,"Oh. - Oh."],[1313,1359,"Okay."],[2060,2139,"Let me get her."],[2298,2364,"It's okay."],[2731,2877,"Are you out of your mind?"],[2927,3065,"A child is dead!"],[3078,3232,"How dare you do that to her."],[3290,3628,"Like you said, the child is dead."],[3657,3874,"Stop acting like you care."],[3903,4029,"You might have tricked my husband,"],[4029,4204,"but you are not fooling me."],[4204,4391,"Now pay up."],[4462,4537,"That's enough."],[4587,4679,"A child is dead."],[4733,4854,"Stop bothering her and let's go."],[4909,5155,"You're the one trying to say that"],[5155,5397,"this dead brat is Anna."],[5434,5618,"I'm just trying to prove to you"],[5618,5714,"that it's not."],[5759,5964,"Why are you stopping me?"],[6106,6235,"Can you give us a moment?"],[6293,6343,"Sure."],[6660,6752,"Rest well, little one."],[6906,7023,"I'm sorry you had to run into"],[7023,7136,"a madwoman like that."],[7248,7378,"You didn't deserve this."],[7686,7736,"Tom."],[7761,7887,"You are a lawyer."],[7887,8020,"And more importantly,"],[8053,8308,"my husband and a father."],[8308,8512,"You are supposed to be helping me."],[8533,8683,"Not snatching my phone,"],[8683,8921,"yelling at me and taking their side."],[9029,9150,"Oh my God."],[9175,9238,"How?"],[9267,9355,"How did I end up"],[9355,9526,"marrying someone like this?"],[9626,9872,"Nobody leaves until I say so."],[9939,10047,"Nobody."],[10668,10727,"Anna!"]],"25":[[116,166,"Anna."],[479,558,"My baby."],[583,692,"What are you doing here?"],[784,946,"No, no, no, please."],[946,1088,"Oh my god, please."],[1222,1280,"Daddy's here."],[1280,1434,"Please look at daddy, please."],[1505,1680,"It can't be Anna."],[1739,1830,"It's not Anna."],[1889,1981,"It's not."],[2556,2631,"Anna?"],[2865,2923,"Wake up."],[3186,3353,"Oh, you're just playing with mommy,"],[3382,3424,"right?"],[3570,3799,"Open your eyes, you're okay."],[3953,4004,"Now you know what"],[4004,4137,"it's like to lose someone."],[4270,4429,"Maybe if you hadn't stopped us,"],[4479,4688,"your daughter wouldn't have died."],[4738,4929,"You said Anna was fine!"],[5113,5301,"You said she was at home, safe."],[5438,5626,"Tell me why she's lying here."],[5630,5701,"I didn't,"],[5780,5926,"I didn't know it was you."],[5926,6014,"I didn't know."],[6110,6385,"Please, just wake up, baby."],[6519,6669,"God, what did I do?"],[6819,6944,"What did I do?"],[6944,7036,"I'm sorry."],[7090,7232,"Mommy's sorry, okay?"],[7294,7515,"Mommy's really, really sorry."],[7703,7749,"No."],[7828,8058,"I don't know, please believe me."],[8666,8712,"Tom."],[8729,8833,"You killed our daughter."]],"26":[[75,212,"I didn't know that that was"],[212,342,"our kid in the firetruck."],[379,667,"If I knew, I wouldn't have stopped them."],[754,863,"So would it have mattered,"],[863,1013,"if it was anyone else's kid?"],[1113,1217,"Is it only your daughter"],[1217,1351,"that deserves to survive?"],[1397,1514,"We told you over and over"],[1514,1664,"that there was a dying kid on board."],[1668,1755,"And you didn't care."],[1968,2068,"Now you're sorry?"],[2256,2323,"You."],[2535,2681,"This is all your fault."],[2769,3028,"My daughter made it to the hospital."],[3119,3303,"You were supposed to save her."],[3411,3524,"Why didn't you?"],[3620,3782,"You let my daughter die."],[3820,3941,"You killed her!"],[4145,4208,"You know"],[4225,4408,"deep down better than anyone else,"],[4408,4521,"why she didn't make it."],[4708,4767,"Admit it."],[4959,5150,"You know who there is to blame."],[5159,5384,"Oh you fucking, you bitch."],[5467,5576,"You killed my daughter."],[5593,5901,"And now I'm gonna kill you!"],[5914,5947,"No."],[6185,6348,"Alright, bitch."],[6410,6477,"Fuck you!"],[6810,7194,"Tom, babe, I am so sorry."],[7198,7453,"I should have never stopped that car."],[7565,7661,"You have to believe me."],[7661,7937,"I would never hurt our daughter."],[8141,8199,"Okay?"],[8420,8621,"Consider this an official notice."],[8742,8871,"I'm divorcing you."],[8963,9009,"No."],[9013,9196,"and I swear on my name as a lawyer,"],[9234,9392,"you won't see a single penny."],[9442,9830,"No, honey, you can't do this."],[9914,10014,"I'm your wife."],[10114,10214,"I'm Anna's mom."],[10281,10410,"If she were alive,"],[10410,10643,"she would not want you to do this."],[10852,10994,"Our daughter is dead."],[11077,11236,"She's dead because of you."],[11340,11386,"No."],[11478,11511,"No."],[11703,11820,"She deserves it."],[12074,12137,"Tom."],[12249,12320,"Tom."],[12408,12499,"We have been married"],[12499,12645,"for ten years."],[12679,12775,"Are you gonna"],[12841,12912,"let all that go,"],[12912,13050,"just because of a five year old?"],[13275,13371,"Our marriage is worth"],[13371,13480,"more than that."]],"27":[[8,175,"Don't answer that."],[337,433,"Oh, right."],[542,721,"The scam call from earlier, right?"],[1222,1309,"Hey, babe,"],[1413,1530,"why weren't you picking up?"],[1543,1659,"Did your husband come home early?"],[1701,1797,"I could still give you"],[1805,1964,"a good time over the phone."],[1993,2085,"What are you wearing?"],[2131,2193,"So,"],[2323,2373,"you're the man"],[2373,2515,"who's been sleeping with my wife?"],[2560,2740,"Oh sorry, wrong number."],[3436,3782,"No, no, honey, just let me explain."],[3937,4024,"Fuck off."],[4867,4938,"Babe, listen,"],[5017,5167,"I'm, I'm sorry, but"],[5209,5392,"he came on to me."],[5434,5547,"It's all his fault."],[5547,5809,"He seduced me and I didn't even want it."],[5880,5985,"You have to trust me."],[6010,6106,"You cheated on me."],[6106,6272,"Because of you, our daughter is dead."],[6322,6448,"She's five, Karen."],[6485,6560,"She's just five."],[6560,6731,"What did she ever do to deserve this?"],[6777,6898,"You're a fucking demon."],[6898,6948,"No."],[7007,7140,"I didn't do anything."],[7223,7294,"I swear,"],[7319,7595,"I don't know why there was a fire."],[7615,7932,"I, I, I, I 100% turned the stove off."],[7953,8124,"She, she must have done it herself."],[8179,8299,"It wasn't me."]],"28":[[254,312,"Okay, okay."],[312,362,"Easy, easy."],[362,471,"You're good. It's fine."],[471,579,"Easy. - Look at me."],[604,754,"Calm down, calm down."],[784,846,"Okay."],[846,946,"You’re gonna be fine. - Easy"],[967,1038,"Are you okay?"],[1067,1117,"Yeah."],[1230,1322,"It's too late,"],[1363,1459,"and you're still trying to"],[1459,1551,"blame our daughter?"],[1614,1780,"It should have been you who died."],[1872,2039,"We just have each other left."],[2173,2256,"And..."],[2314,2494,"She'll finally get what she deserves."],[2540,2573,"Hello?"],[2581,2623,"Police?"],[2635,2677,"No."],[2731,2919,"I'd like to report a murder for my wife"],[2919,3036,"for killing my daughter."],[3053,3098,"Please."],[3098,3261,"I have witnesses and proof."],[3278,3428,"Please get here as soon as you can."],[3524,3732,"You can't do this, please don't."],[3741,3891,"Just don't do this to me."],[3912,4020,"She had it coming. - She had it coming."],[4037,4154,"Tom? - Sweetheart."],[4225,4266,"Sweetheart,"],[4266,4408,"Daddy's gonna take you home."],[4596,4929,"Tom, honey, we can try again."],[5009,5209,"I know that our daughter is dead,"],[5209,5405,"but we can have another one."],[5451,5505,"Or two."],[5538,5743,"Just please don't do this to me."],[5830,5989,"Fuck off."],[6398,6456,"Anna,"],[6527,6635,"you love mommy, right?"],[6710,6827,"You forgive mommy."],[6869,6977,"If you don't say no,"],[7007,7119,"then that means yes."],[7232,7278,"See?"],[7378,7499,"She forgave me."]],"29":[[45,196,"Don't you touch my daughter."],[196,266,"You murderer."],[383,421,"No."],[513,729,"I, I just need another chance."],[1280,1401,"The cops will be here soon."],[1543,1609,"It's over."],[1722,1830,"This is all your fault."],[1830,1931,"You bitch!"],[1989,2131,"Why didn't you get my daughter"],[2131,2202,"here faster?"],[2202,2289,"You killed her."],[2356,2560,"And now I'm gonna kill you."],[2831,2948,"Don't you say another word."],[3019,3178,"Who are you trying to blame?"],[3236,3349,"It was you"],[3395,3586,"who made your own daughter die."],[3753,3983,"Babe, you see that?"],[4016,4208,"They're bullying me."],[4316,4462,"I, I just lost control,"],[4462,4679,"I, I really didn't mean it."],[4821,4879,"Please,"],[4938,5100,"honey, honey."],[5530,5680,"No, Tom, please, please."],[5726,5885,"Please just give me another chance."],[5885,5939,"Please."],[6031,6227,"Please, don't leave me."],[6247,6393,"Ma'am, you're under arrest"],[6393,6506,"for the murder of your child."],[6556,6644,"Please come quietly."],[6644,6794,"Don't leave me here."],[6835,6931,"Come quietly."],[7148,7190,"Wait."]],"30":[[942,1009,"Poor girl."],[1151,1276,"May she rest in peace."],[1363,1476,"I heard the lawyer moved away."],[1714,1793,"And that lunatic"],[1793,1868,"actually lost her mind"],[1868,1951,"after being locked up."],[2002,2052,"Yeah."],[2147,2239,"Well, she only felt sorry"],[2239,2323,"after she realized"],[2323,2423,"she lost everything."],[2544,2706,"Maybe if she had just listened,"],[2706,2773,"that little girl"],[2773,2890,"would still be alive today."],[3178,3303,"She got what she deserved."],[3370,3411,"Yeah."],[3607,3678,"At the end of the day,"],[3691,3816,"everyone's responsible"],[3816,3920,"for their own actions."],[3937,3983,"Mm."],[4562,5055,"Hush, little baby, don't say a word."],[5167,5434,"Mama's gonna buy you"],[5434,5672,"a mocking bird."],[5709,5864,"Hey, what's her deal?"],[5985,6072,"They say she caused"],[6072,6227,"her own daughter's death."],[6281,6481,"Lost her mind after they locked her up."],[6481,6706,"Mama’s gonna buy you..."],[7015,7178,"We’ll always be together."]]}