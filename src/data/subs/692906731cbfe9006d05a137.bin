{"1":[[988,1067,"Um well."],[1101,1288,"Can we trade for something else?"],[1426,1526,"And I'm all yours."],[1584,1714,"You're killing the vibe."],[1935,2018,"Please."],[2081,2235,"I need you to take my case."],[2435,2581,"My father is being interrogated"],[2581,2648,"by the police,"],[2723,2927,"and Mateo's the one framing him."],[2973,3057,"Wow."],[3111,3299,"The \"I need your help\" speech."],[3403,3482,"Classic."],[3661,3812,"But you're way too pretty"],[3812,3974,"to be asking me to do something."],[3991,4074,"So,"],[4137,4216,"boring."],[4346,4425,"You're the best"],[4446,4558,"lawyer in the country."],[4662,4813,"You've never lost a case."],[4963,5121,"If I can't count on you,"],[5155,5255,"I have no one."],[5372,5559,"Mateo is marrying my sister"],[5559,5718,"in two months actually."],[5843,6064,"So you have asked the absolute"],[6064,6218,"worst person for help."],[6664,6748,"Please,"],[6915,7019,"I'll do anything."],[7098,7365,"I'm not in the mood to play superhero today."],[7478,7561,"Excuse me."],[8454,8533,"Dad."],[8608,8746,"What do I do now?"],[9159,9250,"Mateo?"]],"2":[[66,145,"Mateo."],[542,621,"You're here."],[800,921,"Are you looking for me?"],[1272,1351,"You know what?"],[1472,1572,"You can join us."],[1714,1814,"It's quite big."],[1906,2068,"Get your filthy hands off me!"],[2206,2289,"We're done."],[2298,2369,"Oh."],[2423,2494,"I get it."],[2606,2727,"Maybe you're more of a"],[2752,2865,"one on one type."],[2961,3040,"Cute."],[3123,3240,"Take this and get lost."],[3324,3407,"I'm done with you."],[4137,4220,"Hey."],[4337,4521,"Let's relive the good old days."],[4629,4708,"Sure."],[4758,4971,"I mean I'm engaged now."],[5042,5201,"But you,"],[5397,5656,"yeah perfect little mistress."],[5889,6047,"You scumbag!"],[6089,6289,"How dare you even speak of that?"],[6348,6485,"You destroyed my family,"],[6623,6760,"I just wish you'd die."],[7428,7507,"Family?"],[7578,7720,"You mean those people who aren't"],[7720,7816,"even your real parents?"],[7982,8103,"Come on Leilani!"],[8249,8370,"If you want a real family,"],[8491,8633,"we can make one."],[8762,8904,"Right here,"],[8963,9109,"right now."],[10406,10531,"Mateo's trash."],[10581,10723,"Jasmine's blind to it."],[10773,10910,"If he's targeting her family,"],[11052,11144,"good."],[11165,11298,"Now I can use her to break him"],[11298,11386,"and my sister apart."],[11469,11603,"It's, it's not what you think."],[11703,11782,"She's my ex."],[11820,11928,"I ended with her a long,"],[11945,12003,"long time ago."],[12003,12178,"But she won't let go."],[12191,12245,"She, she,"],[12245,12383,"she just keeps chasing me."],[12629,12758,"I don't give a damn about"],[12758,12867,"your little soap opera."],[12962,13158,"If you do anything to hurt my sister,"],[13263,13355,"I will kill you."]],"3":[[967,1088,"Thank you."],[1109,1284,"Frostwell golf club tomorrow."],[1363,1559,"If you insist, show up."],[1647,1760,"You changed your mind?"],[1830,1964,"I had a moment of inspiration,"],[2173,2268,"still haven't decided whether"],[2268,2381,"or not to take your case."],[2690,2786,"But it's always"],[2873,3061,"about what you're willing to offer."],[3674,3749,"Well well,"],[3749,3895,"you actually followed me here."],[3978,4104,"Can't get enough of me huh?"],[4216,4312,"This damn charm of mine."],[4396,4521,"Don't flatter yourself!"],[4629,4721,"I have an appointment"],[4788,4929,"with your future brother-in-law."],[5050,5201,"Please, a guy like him,"],[5217,5334,"he's booked out for a year."],[5438,5518,"Miss Holmes!"],[5609,5743,"You still up for that round?"],[5868,6039,"Of course, I actually"],[6068,6272,"have no idea how to play though."],[6318,6598,"Good it means i can be a very hands on teacher."],[6894,7178,"No way. If Diego takes her case,"],[7211,7290,"I'm finished."],[7353,7486,"I won't let that happen."]],"4":[[70,233,"Relax... I got you."],[287,492,"You're holding too tight, loosen up.."],[717,984,"So you're gonna let the swing flow through you."],[1989,2093,"Did I just?"],[2118,2223,"Hole in one."],[2268,2410,"Told you I'm a great teacher."],[2769,2861,"Oh my god."],[3378,3557,"I have some work I have to do right now."],[3641,3782,"Go wait for me in the lounge."],[3887,3933,"Okay."],[5292,5388,"What you’ve become?"],[5422,5522,"Throwing yourself at Diego"],[5538,5622,"like a cheap prize?"],[5701,5834,"It's none of your damn business."],[5951,6051,"You could have had it easy,"],[6064,6143,"Leilani."],[6202,6281,"Just be my mistress,"],[6293,6373,"no one has to know."],[6477,6715,"Be easier for you to cling on to"],[6719,6798,"the Malone family"],[6802,7007,"and stay their obedient little lapdog."],[7545,7728,"You think Diego gives a damn about you?"],[7778,7903,"You're just a new toy to him!"],[7978,8095,"Yeah I'm getting married."],[8237,8304,"But what we had?"],[8370,8445,"It was real,"],[8483,8562,"and don't lie."],[8646,8762,"You felt it too."],[8875,8971,"Let go of me!"]],"5":[[154,358,"Well Leilani just wanted me to talk to her."],[1355,1522,"What the hell?"],[1805,1926,"You're about to get married."],[1926,2085,"You should know where the line is."],[2218,2423,"Don't make Jasmine regret choosing you."],[2456,2602,"Right, I'm leaving."],[3528,3620,"Ms. Holmes."],[3870,4137,"What exactly do you have to offer in this deal?"],[4220,4308,"I-"],[4471,4642,"I can do whatever you want."],[4813,4959,"Are you trying to save your dad?"],[4959,5005,"Or..."],[5046,5150,"Just looking for an excuse"],[5150,5259,"to sleep with me?"],[6556,6639,"Jump in."],[6740,6831,"Can..."],[6940,7011,"Can I not?"],[7086,7236,"You said you'd do whatever I want."],[7290,7369,"Anything."],[7524,7682,"Just not this."],[8387,8629,"I guess that was just all talk after all."],[8771,8958,"You know it's not too late to back out,"],[8992,9134,"why don't we just call off our deal?"]],"6":[[784,1076,"What took you so long? The food's getting cold."],[1076,1280,"I'm actually not here to celebrate."],[1280,1393,"I'm here to say goodbye."],[1409,1509,"Your dad's company."],[1555,1672,"I drained it months ago."],[1672,1743,"Also,"],[1793,1960,"I'm getting married to Jasmine."],[1981,2218,"Now that's power."],[2423,2548,"Benjamin Holmes?"],[2652,2852,"No! you can't just take him like that."],[3011,3094,"Mateo..."],[3303,3395,"Why?"],[3403,3699,"Because you and your pathetic family"],[3762,3887,"are no longer useful"]],"7":[[216,283,"So,"],[412,550,"is our deal still on?"],[575,679,"You can't swim."],[763,855,"Why didn't you say so?"],[880,971,"I told you."],[1109,1322,"I would do anything for my father."],[1901,2027,"These little things"],[2139,2298,"always look better than they taste."],[5572,5951,"Shy as hell, still trying so hard to look brave."],[6118,6227,"Mateo’s been sniffing around."],[6227,6302,"What does he want?"],[6302,6389,"He,"],[6523,6773,"he wants me to be his side chick."],[6790,6848,"And?"],[6961,7027,"Tempted?"],[7052,7157,"What do you think?"],[7186,7323,"Well you're here with me."],[7323,7457,"So I guess I win."],[7545,7636,"But you tell me."],[7728,7849,"You turned down Mateo"],[7849,8116,"but you're still here doing the same thing."],[8241,8425,"Trading your body for a deal."],[8454,8562,"I'd rather die"],[8658,8837,"than be with the man who destroyed me."]],"8":[[250,362,"Wow Leilani."],[425,579,"Straight to Diego's house?"],[617,771,"I guess you're not as innocent as you act."],[930,988,"Let's be real."],[1067,1205,"You're probably just as stiff in bed"],[1205,1317,"as you are in real life."],[1322,1443,"Dont touch me!"],[1772,1843,"You!"],[2206,2302,"Diego."],[2348,2419,"Who's this?"],[2469,2556,"Ms. Holmes."],[2786,2869,"My girlfriend."],[2907,3132,"What the hell is he doing?!"],[3144,3194,"Damn!"],[3265,3386,"Fucking Diego!"],[3395,3428,"Hi."],[3465,3628,"I'm Jasmine, Diego's sister."],[3628,3728,"It's nice to meet you"],[3766,3858,"Ms. Malone."],[3916,4062,"Nice to meet you too."],[4087,4175,"Actually,"],[4212,4300,"I was thinking."],[4371,4458,"I'm supposed to go wedding dresses"],[4462,4642,"shopping with Jasmine tomorrow."],[4708,4792,"Come with me?"],[4879,5105,"You have way better taste than I do."],[5409,5563,"You look amazing in it."],[6060,6197,"I wanna make you the happiest"],[6197,6302,"woman in the world."],[6956,7019,"Mateo,"],[7102,7265,"Power meant more to you than"],[7290,7378,"I ever did."]],"9":[[41,87,"Mateo,"],[196,350,"power meant more to you than"],[392,517,"I ever did."],[567,675,"That's true."],[692,804,"Diego dresses like someone's"],[804,938,"Retired grandfather."],[1230,1301,"Thanks,"],[1326,1455,"but I, I gotta get going."],[1534,1597,"Enjoy your"],[1630,1705,"day."],[1864,2060,"Am I dreaming Diego"],[2060,2206,"Malone off the market?"],[2285,2398,"Cut it out, Kiddo."],[2452,2494,"Alright."],[2498,2569,"Alright."],[2648,2698,"I'm starving."],[2719,2819,"I'm going in to make dinner."],[3294,3386,"Just so you know,"],[3445,3653,"me and Ms. Holmes had a great time."],[3682,3795,"So in case you were thinking"],[3795,3983,"she's boring in bed,"],[4062,4225,"maybe the problem wasn't her."],[4617,4771,"What are you two whispering about?"],[4817,4979,"Just some guy talk."],[5042,5196,"Diego, I don't know"],[5196,5347,"what game you're playing."],[5388,5547,"But don't get too comfortable."],[5622,5751,"Once I marry your sister,"],[5793,6031,"I'll bleed your family dry."],[6110,6293,"Sooner or later."]],"10":[[867,1038,"Why are you so cold to me?"],[1105,1217,"Weren't we together once?"],[1247,1338,"Leilani."],[1363,1434,"Who is it?"],[1484,1676,"It's nothing, just a package."],[1860,1968,"You should leave."],[2431,2540,"You like it?"],[2635,2773,"This necklace is worth a lot."],[2794,3003,"If you really want to make it up to me,"],[3040,3269,"drop the lawsuit against my dad!"],[3420,3486,"Come on."],[3557,3699,"He's not even your real father."],[3699,3878,"Why are you so hung up on this?"],[4112,4204,"Be with me,"],[4225,4337,"and you'll never have to"],[4337,4491,"struggle for anything again."],[4525,4604,"You ruined"],[4646,4846,"everything Mateo."],[4979,5146,"I mean you didn't just betray me,"],[5146,5330,"you wrecked my whole family."],[5380,5438,"Don't you dare"],[5438,5538,"just stand there and"],[5538,5705,"act like you're doing me a favor!"],[7027,7198,"You can fight all you want."],[7211,7286,"Leilani."],[7378,7486,"But in the end,"],[7578,7728,"you'll still be mine."],[9267,9380,"This would look good on you."],[9592,9747,"It's way too over the top."],[9826,9968,"I'm not the star of the show."],[9968,10189,"Your sister is the one getting married."],[10197,10452,"Mateo, can you help me pick out dresses?"],[10602,10810,"I’ll leave you two lovebirds to it."],[11232,11344,"Did you say that"],[11344,11544,"I was your girlfriend yesterday?"]],"11":[[104,296,"Because man like Mateo."],[429,579,"Once their pride takes a hit,"],[588,721,"they stop thinking straight."],[804,913,"That's when they slip up."],[1001,1130,"That's when we win."],[1172,1301,"Calculating."],[1351,1455,"Dangerous."],[1564,1672,"But God,"],[1735,1810,"he's smart."],[1810,1931,"Too smart."],[2002,2089,"Maybe,"],[2160,2331,"that's what scares me the most."],[3545,3699,"The thing I asked you to prepare,"],[3824,3941,"it's time to move."],[3991,4158,"You are doing better than I thought."],[4229,4441,"I almost forgot this was just an act."],[4808,4850,"Don't"],[4900,5067,"blur the line too much."],[5647,5780,"I haven't stopped Jasmine"],[5780,5885,"from marrying Mateo"],[5914,6126,"even though I know what kind of man he is."],[6343,6523,"She tried to take her life more than once."],[6619,6769,"I just want her to be happy."],[6785,7057,"There's danger in everything about him."],[7057,7223,"But when it comes to Jasmine,"],[7303,7553,"he's the kind of brother anyone would wish for."],[8233,8437,"It's $300,000 on this."],[8462,8608,"Use it for whatever you want."],[8942,9059,"What's this for?"],[9117,9217,"For my girlfriend."]],"12":[[12,150,"For his girlfriend."],[216,383,"The way he said it,"],[404,692,"like it was real like I was his..."],[738,800,"Diego,"],[800,938,"what do you think about this one?"],[1276,1343,"Alright."],[1393,1509,"Swing by my office"],[1509,1622,"after work tomorrow."],[2452,2523,"Leilani."],[2627,2702,"Your dad,"],[2740,2786,"he..."],[2873,3023,"he tried to kill himself!"],[3140,3236,"It was Mateo!"],[3278,3403,"Wait, what?"],[3482,3595,"He submitted more evidence."],[3670,3916,"And your dad just couldn't take it."],[4020,4124,"Mom, calm down."],[4145,4291,"I'm coming home right now."],[4325,4517,"I swear I'll make Mateo pay."],[4537,4721,"Even if it means risking my life!"],[5601,5680,"Arrgh!"],[6060,6210,"Mom stop it!"],[6281,6435,"Mateo, my parents treated you"],[6435,6556,"like family."],[6564,6735,"You ungrateful snake!"],[6815,6898,"Leilani."],[7419,7574,"If you want my help,"],[7653,7782,"come to my villa tonight."],[7916,8008,"And I'll drop the charges"],[8008,8099,"against your mom."],[8279,8370,"Otherwise,"],[8475,8654,"we'll see if she lasts longer in jail"],[8654,8746,"than your dad did."],[8850,9038,"Leilani, don't fall for his crap!"]],"13":[[1034,1101,"Wait,"],[1121,1267,"you mean Benjamin tried to kill himself"],[1267,1343,"yesterday?"],[2348,2481,"Your call has been forwarded"],[2481,2715,"to an automatic voice message system."],[2894,2969,"Damn it."],[3048,3186,"This reeks of Mateo."],[3249,3399,"He's pulling something."],[3912,4037,"About time you show up."],[4062,4250,"I was starting to think you forgot about me."],[4337,4579,"Why can't you just leave me the hell alone?"],[4779,5021,"I gave you a choice, remember?"],[5080,5376,"Obey me, and none of this would’ve happened."],[5434,5492,"What's!"],[6076,6239,"You're disgusting!"],[6289,6427,"What do you think Jasmine would say"],[6427,6531,"if she saw this?"],[6531,6848,"Or Diego, you think they won't find out?"],[7248,7394,"Don't bring up Diego!"],[7453,7578,"You think you know him?"],[7611,7732,"We call him a living hell!"],[7903,8008,"You don't tell me"],[8008,8153,"you fell in love with him"],[8208,8270,"Come on."],[8324,8504,"You're smarter than that, Leilani"],[8516,8704,"Get off me you bastard!"]],"14":[[950,1176,"Get off me you bastard!"],[2156,2193,"Diego."],[2223,2260,"Diego."],[2302,2339,"Please,"],[2364,2448,"don't hurt me."],[2573,2660,"Pliers!?"],[2719,2961,"What the hell is he gonna do with those?!"],[2990,3119,"Choke that down."],[3148,3211,"No!"],[3236,3303,"No!"],[3353,3415,"Arrgh!"],[3440,3624,"Arrgh!"],[4529,4608,"Diego."],[4683,4838,"I’ve taken your punishment."],[4913,5059,"Just don't tell Jasmine."],[5125,5196,"Alright?"],[5201,5467,"You don't want her to hurt herself, right?"],[5647,5814,"You should be grateful that"],[5814,5955,"Jasmine still loves you."],[6085,6222,"Otherwise, you would be dead a"],[6222,6322,"hundred times over."],[6819,6906,"Overall."],[7007,7248,"Most of the evidence total fake."],[7290,7436,"Planted by Mateo."],[7515,7770,"So once it gets out, it all falls on him."],[7878,8003,"Your dad's gonna be okay."],[8274,8441,"I recorded my conversation"],[8441,8575,"With Mateo tonight."],[8754,8946,"If he keeps coming after my family,"],[9025,9205,"I'm gonna give the recording to Jasmine."]],"15":[[20,166,"I recorded my conversation"],[166,283,"With Mateo tonight."],[467,679,"If he keeps coming after my family"],[725,930,"I'm gonna give the recording to Jasmine."],[1205,1347,"You really think a recording"],[1347,1459,"will stop Mateo?"],[1493,1768,"I know, you care about your sis."],[1956,2177,"But I can't let Mateo ruin my life."],[2907,3136,"Don't overplay your hand."],[3274,3436,"Thing I hate the most"],[3474,3720,"is people interfering with my work."],[3824,4008,"So if you don't trust me,"],[4058,4212,"don't ask me to handle it."],[4308,4396,"Understood?"],[4571,4637,"Okay."],[5167,5347,"Leilani, your dad's in tough shape."],[5363,5488,"Don't worry, Mom."],[5576,5693,"Dad's a fighter."],[5822,5976,"I'll go grab some of his stuff"],[5976,6197,"and come back this afternoon, okay?"],[6227,6277,"Okay."],[6289,6423,"Okay thank you."],[6639,6752,"Leilani."],[6877,7098,"You got Diego to investigate"],[7098,7190,"Garrison Group?"],[7236,7378,"He brought this on himself."],[7469,7615,"You little hussy!"],[7632,7857,"If anything happens to my son"],[7878,7999,"or the Garrison Group?"],[7999,8158,"I will make you pay!"]],"16":[[221,287,"Arrgh!"],[450,508,"Arrgh!"],[521,759,"You touch my daughter again and I will show"],[759,946,"you just how far a mother will go."],[1076,1159,"Ladies."],[1280,1455,"Leave the drama somewhere else."],[1480,1605,"This is a hospital."],[1630,1776,"Who do you think you are?"],[1793,1960,"Mind your own business!"],[1989,2077,"Excuse me?"],[2110,2227,"I'm sorry sir."],[2293,2502,"I didn't mean to drag you into this."],[2773,2940,"I don't have time to argue."],[3007,3094,"Let me through."],[3257,3461,"This isn't over!"],[3541,3620,"Hey!"],[4058,4149,"Honey. Are you okay?"],[4245,4320,"Yeah."],[4396,4479,"Thank you."],[4988,5100,"Ms. Holmes."],[5155,5263,"What are the odds?"],[5276,5438,"What are you doing here?"],[5467,5538,"Diego."],[5663,5780,"You two know each other?"],[5814,5960,"You two are my clients."],[6101,6285,"It's funny running into you here"],[6373,6477,"Maybe it's fate."],[6635,6773,"You're being ridiculous."],[6944,7002,"Thanks,"],[7048,7136,"for earlier."],[7219,7353,"I'm gonna head out."],[8370,8500,"So,"],[8671,8837,"any update on the investigation"],[8837,8888,"we talked about?"]],"17":[[41,137,"Here's a report."],[333,450,"It's DNA samples I've collected"],[450,600,"over the past six months."],[692,971,"Potential matches for your daughter."],[1130,1305,"This all just feels like a dead end."],[1847,2002,"About that charity event,"],[2185,2381,"do you mind inviting that girl from earlier?"],[2544,2627,"Wait,"],[2765,2873,"may I ask why?"],[2973,3065,"Do you think that she's-"],[3065,3157,"I don't know."],[3240,3353,"She just feels"],[3520,3616,"familiar."],[3737,3874,"Like I know her somehow."],[4029,4187,"I think I want to talk to her more."],[4454,4721,"Diego, it's been ages."],[4821,4950,"Let's grab a coffee."],[5000,5063,"Catch up."],[5113,5167,"Can't."],[5280,5388,"Swamp today."],[5593,5764,"Got it, I'll head out now."],[5885,5955,"Sure you don't want me to"],[5993,6118,"put you in a VIP suite?"],[6160,6235,"I mean technically"],[6235,6377,"you do own the whole hospital."],[6381,6452,"It's alright."],[6519,6669,"I don't want any special treatment."],[6685,6756,"I see,"],[6815,6915,"wanna see how your staff does"],[6915,7052,"when they think no one's watching."],[7073,7236,"That's why I trust you, Diego."],[8279,8362,"Maya."],[8558,8733,"You really ought to let go of Diego."],[9034,9096,"Hey."],[9154,9275,"Take it from a man."],[9517,9768,"His heart isn’t with you anymore."]],"18":[[4,120,"Dad, are you,"],[233,387,"are you also ashamed"],[387,500,"I'm just an adopted daughter?"],[575,650,"Maya"],[834,1063,"That has nothing to do with it."],[1113,1255,"Easy for you to say."],[1347,1493,"Once your real daughter shows up,"],[1493,1589,"I'll be nothing."],[1697,1864,"I won't let her show up"],[2802,2915,"By court order,"],[2915,3140,"all property under Benjamin Homes"],[3140,3328,"is now under legal seizure."],[3378,3682,"Including this villa and all transferable assets."],[3720,3828,"This can't be!"],[3887,4041,"My dad was just hospitalized,"],[4041,4087,"you can't."],[4099,4312,"The law doesn't ask for hospital visits."],[4416,4562,"So you better start packing."],[4767,4884,"Of course,"],[4950,5167,"if you decide to come back to me,"],[5213,5472,"I might just have the order reversed."],[5718,6051,"No place to stay? Why not just live with me?"],[6523,6639,"Stay out of this Diego,"],[6660,6794,"it has nothing to do with you."],[6794,7069,"She's my client and my girlfriend."],[7107,7232,"So go ahead and tell me again why"],[7232,7390,"this isn't my business."],[7415,7670,"Diego took her case, shit."],[7691,7870,"If that's true, I'm screwed."],[7891,8083,"Take your filthy hands off of her."],[8220,8412,"I've already filed an emergency appeal."],[8458,8612,"So whatever paper you got there"],[8612,8800,"doesn't give you the right to bargain."],[8833,8979,"Let alone harassing at her."],[9384,9522,"You might want to take that call."]],"19":[[0,137,"You might want to take that call."],[617,700,"Yes."],[892,984,"Understood."],[1222,1368,"The property is officially"],[1368,1480,"under court seizure."],[1497,1664,"But until the appeal ruling is made,"],[1664,1860,"we won't proceed with a full lockdown."],[1901,2064,"We will return in three days"],[2064,2202,"to enforce the seizure."],[2260,2344,"Be prepared."],[2565,2727,"You can stall all you want, Diego."],[2748,2923,"But that court order still stands."],[2940,3019,"Good."],[3061,3236,"All I need is some time."],[3294,3557,"Just enough for someone like you"],[3557,3636,"to slip up."],[4466,4633,"Could you tone down the sobbing a little?"],[4650,4829,"It's giving me anxiety."],[4833,5013,"I just lost my house,"],[5084,5263,"what do you expect me to do?"],[5263,5321,"Laugh?"],[5392,5484,"Alright fair."],[5526,5613,"Cry it out."],[5851,5930,"Still,"],[6093,6297,"thanks for kicking those jerks out."],[7278,7465,"Actually I"],[7536,7720,"came to invite you to a gala."],[7791,7966,"I had no idea what was going on"],[7966,8058,"when I got here."],[8058,8149,"Too bad."],[8233,8441,"I'm busy going bankrupt."],[8550,8683,"Considered a.."],[8783,8879,"thank-you gift"],[8979,9100,"for the stunning legal performance"],[9100,9200,"free of charge."],[9471,9588,"Wait."],[9701,10043,"So the whole \"emergency appeal\"."],[10089,10214,"It's all improvised."],[10293,10493,"Except for a quick call to a friend at court."]],"20":[[0,120,"It's all improvised."],[204,404,"Except for a quick call to a friend of the court."],[454,558,"That file?"],[767,946,"Just grabbed whatever was in my car."],[1234,1347,"Oh my God."],[1418,1543,"What was that?"],[1543,1601,"Nothing."],[1764,1931,"Doesn't seem like nothing."],[2218,2298,"Alright."],[2394,2590,"You swear you won't tell anyone."],[2673,2806,"Cross my heart."],[3908,4108,"You are hereby fined"],[4187,4379,"$500 for"],[4483,4637,"poop and run?"],[4637,4825,"It's Jasmine's dog."],[4900,5000,"Okay I-"],[5000,5238,"I help walk it sometimes and how-"],[5242,5334,"How am I supposed to know"],[5334,5430,"that thing's a poop machine?"],[5551,5714,"You're not just a lawyer."],[5714,5905,"You're a terrible neighbor."],[6264,6389,"Miss Dyer,"],[6410,6698,"that dress looks stunning on you."],[6723,6898,"Snap your fingers and half the city"],[6902,7098,"would line up to spoil you."],[7161,7336,"You sure know how to sweet talk."]],"21":[[997,1274,"Only touch what you're actually going to buy."],[1374,1695,"Do you have anything that's under $10,000?"],[1808,1961,"Clearance rack's over there."],[1978,2125,"Knock yourself out."],[2595,2992,"Mr. Malone, Ms. Dyer is changing."],[3006,3169,"Please have a seat."],[3690,3963,"Ms. Dyer snagged our top-tier dress."],[4000,4317,"With this necklace, it’s the cherry on top."],[4317,4474,"Wanna surprise her with it?"],[4651,4778,"This one's okay I guess."],[4934,5181,"Excuse me, how much is this dress?"],[5251,5375,"50 grand."],[5485,5679,"$50,000?"],[5729,5899,"For last season's leftovers?"],[5972,6196,"Miss, please lower your voice."],[6212,6566,"This isn't a flea market, the price is what it is."],[6583,6740,"If you can't afford it,"],[6750,6930,"maybe rethink your life's choices"],[6936,7103,"instead of blaming it on the dress."],[7147,7277,"I wasn't blaming anything."],[7290,7490,"I just didn't see a tag."],[7514,7674,"Be honest with yourself, sweetheart."],[7687,7904,"This place isn't for girls like you."],[7944,8048,"There's a forever 22,"],[8048,8198,"10 minutes down the block."],[8208,8401,"You'll feel right at home there."],[8421,8528,"She's with me."]],"22":[[76,133,"Oh."],[150,243,"Mr Malone."],[253,350,"I, I didn't know."],[370,497,"Ring that up."],[530,674,"And get your the manager now."],[690,897,"Maybe they can start by teaching you some basic"],[1027,1094,"manners."],[1124,1237,"Of course sir."],[1301,1428,"I didn't mean to offend anyone."],[1438,1584,"I'll get the manager right away."],[1811,1905,"Wait..."],[1935,2085,"What are you doing here?"],[2202,2342,"My superpower is showing up"],[2355,2589,"exactly when beautiful women need saving."],[2819,2949,"Has anyone ever told you your jokes"],[2949,3066,"are really lame?"],[3229,3306,"Well,"],[3316,3436,"lame or not,"],[3490,3623,"you'd still look more beautiful"],[3626,3773,"than half the woman I've ever met."],[3773,3913,"Even in a trash bag."],[4144,4364,"You don't have to do this..."],[4414,4611,"I'll just go somewhere else,"],[4611,4774,"it's not worth it."],[4794,4878,"Come on."],[4941,5085,"Let me spoil my girlfriend."],[5131,5258,"We're only pretending,"],[5348,5428,"remember?"],[5498,5652,"What if I changed my mind?"],[5709,5849,"Let me handle the rest."],[5889,6129,"You go ahead and start settling"],[6129,6356,"into your new home."],[6373,6436,"Okay."],[6589,6649,"Bye."]],"23":[[63,310,"Would you like to see our emerald necklaces?"],[330,577,"It's perfect for the woman you love."],[620,717,"Wrap it up."],[884,994,"I knew it."],[1001,1164,"He still has feelings for me."],[1181,1267,"So..."],[1277,1424,"How's the search going?"],[1554,1721,"My dad's mystery daughter."],[1795,2008,"You called me here just to ask me that?"],[2168,2318,"My dad promised your mother that"],[2318,2379,"you would marry"],[2379,2515,"his real daughter."],[2615,2696,"Diego."],[2789,2872,"Do you really want to marry somebody"],[2872,3033,"you barely know?"],[3173,3343,"That's none of your concern, Maya."],[4070,4167,"Diego."],[4197,4320,"You didn't have to."],[4334,4481,"It's not for you."],[4521,4627,"What?"],[4671,4848,"Maya, that ship has sailed."],[4868,5048,"Your grandmother was the reason we broke up."],[5055,5201,"And she's gone now."],[5231,5375,"What's stopping you?"],[5435,5628,"You were more the reason, Maya."],[5655,5859,"And I'm not making the same mistake twice."]],"24":[[236,447,"It's not exactly ideal."],[513,730,"But given the situation,"],[737,904,"I don't have many options."],[967,1057,"Might as well try"],[1057,1251,"to be a decent house guest."],[1508,1578,"You know,"],[1601,1781,"maybe it would be safer if you"],[1821,1985,"came and stayed at my place."],[2028,2162,"Until things settle down."],[2609,2839,"What a waste of a good kitchen."],[2862,3056,"The grocery store should still be open."],[4037,4084,"Huh."],[4137,4280,"Did she make this for me?"],[5231,5378,"Oh my God."],[5412,5612,"What did I get myself into?"]],"25":[[1394,1554,"Ever heard of knocking?"],[1644,1815,"Pretty sure this is my bed."],[1955,2048,"Oh."],[2065,2178,"Oh my God I'm so sorry."],[2192,2355,"I thought this was the guest room."],[2372,2459,"I'll go."],[2609,3009,"Since we're already in the same bed."],[3153,3357,"How about we..."],[3386,3550,"Is, is this happening?"],[3550,3713,"Should I say something?"],[3713,3863,"Push him off?"],[7504,7584,"Mateo."],[7654,7834,"What are you doing here?"],[7977,8228,"I'm sorry I messed up."],[8324,8548,"I know I messed up."],[8568,8888,"But I know that you're the only one I love."],[8965,9195,"I'll do whatever it takes to make it right."],[9943,10196,"Oh god Diego’s in here too!?"],[11931,12058,"What kind of messed-up"],[12058,12162,"dream was that?"]],"26":[[323,437,"Oh my God."],[493,590,"I haven't even brushed"],[590,757,"my teeth or washed my face."],[937,1057,"Thanks for the pasta."],[1351,1501,"I just wish the"],[1508,1778,"noodles and sauce had been packed separately."],[1871,2035,"Oh, right."],[2055,2285,"I'm sorry it must've gone mushy!"],[3343,3486,"Wear this to the gala tonight."],[4084,4287,"Are you out of your mind?"],[4317,4434,"You pervert!"],[5191,5291,"Jasmine?!"],[5325,5508,"Why would you just shove this in here?!"],[5679,5832,"Shit."],[5905,6142,"she probably thinks I’m some kind of freak..."],[7397,7644,"Leilani open the door, I can explain."]],"27":[[657,947,"He looks kind of charming"],[950,1087,"when he's focused."],[1127,1251,"Looks good on you."],[1581,1798,"Mr. Malone, so good to see you"],[1961,2148,"Uh, did you have a minute?"],[2225,2395,"I have a case for you to look at."],[2412,2492,"Give me a sec."],[2942,3033,"Leilani?"],[3119,3229,"Ruby?"],[3313,3523,"Wow. it's been ages, how have you been?"],[3530,3790,"Great, actually been modeling"],[3790,4000,"full time since graduation."],[4027,4124,"Got picked up by"],[4124,4304,"the Dyer Group last year."],[4344,4481,"What brings you here?"],[4491,4637,"I'm so happy for you."],[4651,4911,"Um I'm just here with friend."],[5021,5261,"You've seriously upgraded, huh?"],[5291,5568,"That necklace's stunning."],[5622,5735,"Thank you."],[5742,5945,"Mind if I take a closer look?"],[6052,6132,"Um."],[6152,6239,"Sure."],[6800,7050,"Wow what gorgeous."],[7143,7400,"Let me borrow it for a quick Instagram shot?"],[7417,7784,"Just need to find a nice background."],[7867,8024,"I'm not sure."],[8038,8311,"Oh come on! Don't be such a grandma."],[8334,8478,"I'll be right back, promise."],[8538,8865,"Okay, just don't take forever!"]],"28":[[527,710,"That's the diamond necklace Diego bought."],[794,900,"Where did you get this necklace?"],[904,1041,"I I don't know."],[1054,1154,"You don't know?"],[1314,1441,"Or you're too scared to say?"],[1675,1838,"I swear it's not mine."],[1848,2078,"It belongs to a friend from college."],[2092,2308,"I I just wore it for a photo!"],[2322,2389,"Who?"],[2542,2699,"Don't take it out on her."],[2719,2816,"The necklace is mine."],[2899,2962,"Her?"],[2979,3069,"Seriously?"],[3186,3299,"She looks like she bought that dress"],[3299,3393,"with store credit."],[3466,3583,"Diego's just bored"],[3663,3713,"I'm sorry,"],[3713,3803,"Maya please."],[3823,3877,"Stop!"],[3903,3983,"I was wrong."],[4170,4237,"Maya?"],[4327,4421,"That name."],[4421,4517,"Give me the necklace."],[5248,5355,"If I can't have it,"],[5385,5505,"what makes you think you can?"],[5538,5645,"It's her."],[5645,5799,"I finally found you."]],"29":[[16,180,"You're Leilani, right?"],[183,270,"I'm Maya."],[313,513,"I know the truth about your real parents."],[523,633,"Come with me."],[1548,1691,"Maya, Maya?"],[1691,1815,"Where are my parents?"],[1825,1951,"Open the door!"],[1991,2132,"Maya it's you again."],[2135,2285,"This time I'll get an answere."],[2292,2602,"I was locked in a room for 3 days."],[2919,3063,"If it gets dirty, toss it."],[3520,3753,"I didn't know you had country friends, Diego."],[3823,3877,"I always thought"],[3880,3980,"real elegance had nothing"],[3980,4090,"to do with fabric"],[4094,4170,"or price tags."],[4170,4397,"I don’t understand this feeling/"],[4397,4647,"But being with Diego makes me feel safer."],[4694,4761,"Leilani."],[4884,5035,"I'm so glad you could make it."],[5051,5105,"Andrew."],[5118,5278,"I didn't expect to see you here."]],"30":[[66,156,"Andrew."],[210,390,"I didn't expect to see you here."],[473,630,"Actually I'm the one"],[630,750,"hosting tonight's banquet."],[797,947,"You're the president of the Dyre Group?"],[1011,1124,"Guilty as charged."],[1177,1304,"And this is my daughter Maya."],[1311,1441,"Maya, meet Miss Holmes."],[1448,1534,"Our guest."],[1541,1648,"Guest?"],[1661,1745,"Daughter?"],[1761,1941,"I want you to meet a few business partners."],[1991,2082,"Maya."],[2095,2235,"Take good care of Miss Holmes."],[2238,2369,"Welcome Miss Holmes."],[2505,2609,"So glad you could join"],[2609,2676,"us in this meeting."],[2759,2859,"Apologies"],[2872,2976,"I need to go take care"],[2976,3046,"of a guest right now."],[3056,3173,"But let's find a moment later"],[3173,3289,"to have a proper chat."],[3433,3510,"I'll be there in a minute."],[3693,3933,"If you lay a finger on her, I won’t let it slide."],[4150,4300,"Who is she to you anyway?"],[4314,4431,"Why are you so protective?"],[4574,4728,"Can I speak with you privately?"],[4831,4954,"I have something to ask you."],[5068,5291,"I've just met you, what's so private?"],[5445,5602,"You don't remember me?"],[5769,5902,"We met in 6th grade."],[6066,6206,"I don't know what you're talking about."],[6259,6363,"Try harder to remember."],[7203,7283,"What happened?"]],"31":[[674,884,"You still have feelings for me, don't you?"],[937,1137,"Don't ask stupid questions."],[1227,1468,"I know I was never truly part of the Dyer family."],[1668,1891,"To them not, even to your grandmother."],[1925,2105,"But at least when"],[2105,2355,"I'm with you, I feel like I belong..."],[2525,2706,"Please, don't take that away from me."],[2806,2889,"Maya."],[2976,3176,"You were my girlfriend."],[3196,3306,"Not are."],[3416,3583,"And don't take it out on Leilani."],[4724,4921,"Maya, are you in there?"],[4948,5065,"Bitch."],[5091,5235,"Still darling to come to me."],[6156,6353,"Did she kiss Diego?"],[6406,6706,"I'm sorry I was rude earlier."],[6823,6906,"It's just,"],[6926,7143,"I feel like we've met before"],[7220,7447,"a long time ago."],[7470,7597,"When I was a kid."],[7640,7854,"Someone came looking for me."],[7904,7987,"She said she knew something"],[7987,8121,"about my real parents."],[8168,8244,"I'm not really sure"],[8244,8328,"what you're talking about."],[8488,8578,"Drop the act,"],[8645,8738,"it was you."]],"32":[[13,80,"You said"],[93,213,"you wanted to help me."],[223,290,"But somehow,"],[310,523,"that ended up with me being locked in a cabin"],[547,660,"for three days."],[690,790,"That's ridiculous."],[807,974,"Why would I?"],[1187,1294,"Fine."],[1501,1738,"Some things happened back then."],[1738,1908,"Things I can't really explain."],[2065,2275,"Your parents went overseas,"],[2352,2492,"haven’t heard from them since."],[2502,2642,"How did you know all this?"],[2716,2852,"The Dyer Group has a fund"],[2852,2972,"for missing children."],[3009,3149,"My father, he..."],[3306,3443,"He lost someone too."],[3563,3713,"I have a question for you."],[3823,3957,"You and Diego,"],[3980,4134,"are you two together?"],[4371,4467,"No.."],[4527,4748,"I'm just a client of his."],[4774,4861,"Then why did he give you such"],[4861,4968,"an expensive necklace?"],[4974,5065,"He just,"],[5138,5221,"he handed it to me"],[5221,5352,"before he left, said to wear it."],[5395,5528,"So you're living together now?"],[5552,5769,"For certain reasons,"],[5842,6052,"I'm temporarily staying at his place."],[6102,6226,"Living with Diego,"],[6246,6413,"invited as Andrew's guest."],[6433,6556,"Is she his real daughter?"],[6586,6710,"He's announcing something big tonight."],[6736,6800,"The heir?"],[6860,6950,"No, it can't be."],[6963,7080,"I gotta destroy her,"],[7100,7253,"before she destroys me!"]],"33":[[46,136,"Leilani,"],[163,283,"about earlier."],[440,537,"I was out of line."],[620,690,"I feel bad about"],[690,857,"ruining your necklace."],[874,1087,"Here, let me make it up to you.."],[2752,2889,"Come on, try it."],[2919,3033,"You'll love it."],[3103,3216,"Let me help you."],[3346,3620,"No, it's too much. I, no need."],[4821,4968,"Maya, open the door."],[5108,5291,"Enjoy your last moments, Leilani."],[5291,5558,"I am the only Ms. Dyer and Mrs. Malone."],[5575,5668,"Where's Leilani?"],[5692,5789,"She's been gone too long."],[5805,5912,"Something's not right."],[5995,6229,"I'm getting anxious, really anxious."],[6379,6619,"Now we're at 2.8 million."],[6740,6996,"Jasmine, our budget is three million."],[7160,7350,"I don't care. I want the earrings!"],[7454,7684,"What a spoiled woman."],[7707,7887,"You're not even officially married yet,"],[7887,8111,"and she's already spending like a queen."],[8194,8241,"Mom..."],[8308,8421,"I can handle it,"],[8421,8518,"okay?"],[8742,8872,"I'll get you the earrings,"],[8895,9022,"just give me a second."],[9175,9325,"Diego's damn investigation"],[9332,9486,"froze most of my assets."],[9542,9739,"If Jasmine didn't hold Malone stock,"],[9753,9929,"I wouldn't be here pretending to care."],[11151,11444,"The west side guest room is on fire,"],[11444,11628,"alright, so the auction is canceled!"],[11634,11825,"Please, evacuate in an"],[11825,11958,"orderly manner right now."]],"34":[[460,560,"Where is she?"],[627,707,"Leilani."],[774,887,"How should I know?"],[914,1034,"Maybe she went home already."],[1184,1247,"It's impossible."],[1267,1327,"She wouldn't just leave without"],[1327,1434,"saying anything."],[1484,1681,"It seems like Leilani and Diego are a thing."],[1848,2072,"Keep calling Diego, that restroom."],[2088,2238,"I chose it on purpose."],[2252,2359,"Thick walls."],[2385,2599,"Terrible reception, you won't find her."],[2776,2902,"Come on, pick up."],[3156,3289,"Diego where are you going?"],[3323,3420,"I'm looking for Leilani."],[3446,3576,"She might be trapped in the fire."],[3713,3777,"Leilani!"],[4030,4100,"Leilani!"],[4277,4320,"Diego!"],[4351,4494,"We’ve already checked."],[4494,4674,"Leilani, she’s not in there!"],[4701,4801,"Come on, Leilani."],[4824,4934,"I’m not losing you now."],[4934,5021,"Not like this."],[5101,5301,"Then you guys go, I'm not leaving."],[5725,5859,"Hold on, Leilani"],[5859,5965,"I wish you safe."]],"35":[[326,493,"It sounds strange but..."],[563,677,"It was instinct,"],[824,937,"Maya and I were"],[980,1094,"heading back home."],[1124,1408,"And I suddenly had a sharp pain in my chest."],[1448,1621,"So I turned around and went"],[1621,1818,"back to the fire alone."],[1908,2192,"It was as if something was guiding me."],[2332,2499,"The second I pulled you out,"],[2542,2672,"I probably sound crazy."],[2862,2986,"No Andrew,"],[3033,3186,"I've heard of cases like this before."],[3329,3423,"Telepathic connection."],[3523,3857,"Usually between people who share a blood bond."],[3990,4070,"You mean?"],[4087,4180,"Dad, are you okay?"],[4220,4310,"I was worried sick"],[4310,4381,"Yeah."],[4698,4751,"I'm fine."],[5505,5655,"Once she wakes up,"],[5725,5889,"She'll tell Diego I started the fire."],[5929,6026,"I can't let her wake up."]],"36":[[1988,2135,"How're you feeling?"],[2215,2278,"I'm ok."],[2352,2529,"Any news on my dad?"],[2639,2732,"He's doing well."],[2809,2992,"Benjamin just got discharged."],[3169,3276,"I've put together a lot of evidence"],[3276,3446,"to clear his name."],[3560,3670,"You're the one in the hospital."],[3687,3907,"But you're worried about others."],[4060,4197,"That’s my family for him"],[4210,4330,"Can’t seem to stay"],[4330,4447,"away from hospitals."],[4504,4804,"They really should give us a lifetime VIP card."],[4824,4938,"I saw the uh,"],[5018,5168,"get well card that you made for him"],[5185,5278,"at your place."],[5422,5615,"That's something I can never pull off."],[5662,5765,"Why?"],[5849,5939,"My father and I,"],[6046,6166,"we were never close."],[6226,6523,"While all the other kids were playing outside,"],[6523,6820,"I was stuck with law books at home."],[6920,7120,"One bad grade and I'd get a beating."],[7267,7530,"One hit gave me a retinal detachment."],[7614,7901,"I never imagined he'd had it so hard."],[8011,8104,"All this time,"],[8104,8271,"I thought he was just cold."],[8405,8485,"Swallowing pain"],[8485,8752,"I couldn't even begin to understand."],[8822,8905,"That bitch!"],[8985,9149,"Even I never knew this about Diego."],[9202,9319,"And he tells her?"],[9356,9586,"I guess I have to thank him for who I am now."],[9743,9833,"Actually,"],[10036,10093,"Benjamin."],[10093,10310,"Benjamin isn't my biological father."]],"37":[[50,153,"I remember"],[290,413,"one day at the park,"],[503,737,"my parents started yelling out of nowhere."],[937,1087,"My mom was crying."],[1171,1294,"She put me in the car,"],[1344,1564,"said we were going someplace new."],[1728,1898,"We drove for hours."],[2035,2202,"We went to a gas station."],[2308,2432,"She told me to wait."],[2649,2812,"And she never came back."],[2869,3013,"The rest is just a blur."],[3079,3249,"I ended up in the orphanage."],[3319,3503,"Benjamin and Grace adopted me."],[3573,3777,"Could this really tie back to Andrew?"],[3820,3937,"And him asking me to bring Leilani"],[3937,4044,"to the gala?"],[4067,4260,"Yeah that was off."],[4270,4367,"Oh my god."],[4377,4497,"She's really his daughter."],[4521,4601,"Andrew once told me"],[4607,4821,"he and his wife had a huge fight in that park."],[4831,5028,"She's going to take everything I worked for."],[5081,5145,"Diego."],[5178,5258,"Do you mind getting me"],[5258,5375,"some tea with honey?"],[5435,5612,"My throat's killing me."],[5679,5842,"It's 3:30 AM."],[5912,6002,"Seriously?"],[6036,6186,"You say you have superpowers."],[6296,6546,"Next time let's not test my powers like that."],[6566,6676,"You scared me today."],[6780,6860,"Get some rest."],[7407,7644,"She’s making Diego run errands for her?"],[7697,7761,"Bitch!"],[9736,9796,"Maya?"],[9923,10050,"You're not getting out of here."]],"38":[[6,76,"Maya."],[203,330,"You're not getting out of here."],[797,980,"This is just a misunderstanding."],[987,1101,"I'm just checking on you."],[1151,1317,"You're not answer everything honestly."],[1504,1621,"Why did you lock me in there?"],[1798,1965,"And where are my real parents?"],[2068,2222,"Maybe you're better off not knowing the truth."],[2362,2502,"Sometimes the truth hurts."],[2559,2702,"Just answer me."],[2782,2929,"Let me go first and I'll"],[2929,3066,"explain everything tomorrow."],[3133,3179,"Forget it,"],[3430,3536,"looks like I'm calling the police."],[3536,3620,"No no, wait."],[3703,3763,"I'm serious."],[3853,4010,"Hey meet me at the Blue Finch Cafe."],[4050,4094,"Tomorrow."],[4230,4334,"I'll explain everything."],[4361,4447,"Why a cafe?"],[4637,4701,"There's just,"],[4891,4984,"there's a lot you need to know."],[5065,5165,"It'll be easier to talk it through"],[5165,5348,"in a more relaxed setting."],[5348,5425,"Trust me."],[5615,5842,"Blue Finch Cafe, 10:00 am."],[5955,6002,"Come on,"],[6002,6082,"and you'll get all the answers"],[6082,6179,"you've been looking for."],[8138,8248,"My dad promised your mother"],[8248,8311,"that you would marry"],[8324,8421,"his real daughter."],[8491,8665,"If she’s Andrew’s daughter,"],[8765,8915,"does that mean I’m supposed to"],[8915,8998,"to marry her?"]],"39":[[53,160,"So..."],[163,280,"Your parents,"],[350,473,"they're the reason I'm an orphan."],[680,940,"Your father was drunk driving and,"],[1107,1247,"and he killed my family."],[1301,1344,"You mom,"],[1358,1458,"she ran away."],[1468,1624,"And later died in an accident."],[1634,1755,"And you,"],[1845,2015,"you ended up in foster care."],[2068,2278,"But you said they immigrated."],[2392,2505,"A white lie."],[2592,2722,"You weren't ready for the truth back then."],[2762,2996,"That's more than just a lie."],[3006,3173,"That's rewriting my life."],[3216,3396,"I was trying to protect you."],[3506,3630,"Or maybe,"],[3640,3850,"you were just trying to protect yourself."],[3937,4074,"Believe what you want."],[4157,4270,"But these are the facts whether you"],[4270,4364,"accept them or not."],[4431,4601,"Now if there's nothing else,"],[4607,4741,"You're free to go, Miss Holmes."],[4798,4931,"I've got work to do."],[4941,5041,"Her eyes,"],[5051,5135,"her tone."],[5185,5345,"None of it adds up."],[5412,5525,"She's lying."],[5585,5735,"You're just in time."],[6189,6296,"Leilani."]],"40":[[190,363,"Maya and I have a lot of work ties."],[383,517,"So whether I like it or not,"],[530,704,"I have to deal with her."],[737,990,"Given her foster father Mr Andrews"],[1054,1194,"is one of my long term clients."],[1915,2078,"Let's talk about your father's case."],[2515,2622,"It's a shell company."],[2676,2959,"Mateo used it to move money and frame him."],[3033,3126,"Now this isn't enough to"],[3126,3233,"get Mateo arrested yet,"],[3253,3413,"But it'll clear your father's name."],[3603,3790,"He's out now and"],[3803,3910,"this will keep him free"],[4014,4114,"Also..."],[4154,4294,"Your house is no longer under seizure."],[4661,4794,"You’re officially home again."],[4931,5158,"So I gues it's time for me to go back now."],[5789,5959,"I was just getting used to having you around."],[6169,6209,"That's all."],[6236,6339,"I won’t walk you out."],[6356,6463,"I have works piling up."],[6569,6830,"He said it so casually"],[6873,6993,"like it meant nothing."],[7043,7150,"But for some reason,"],[7177,7367,"it hurt a little more than I expected."],[7650,7834,"Just let her go, Diego."],[7854,8074,"It's not like she was ever yours to begin with."],[8148,8281,"And the whole couple act."],[8398,8525,"It's over now."],[8775,8878,"Is that why you're always"],[8878,9012,"so careful with me?"],[9109,9205,"Cause I'm just some"],[9315,9362,"guest."],[9456,9629,"And Maya's the one who belongs here."],[10970,11091,"Your photo with her"],[11277,11398,"it’s still in your bedroom."]],"41":[[313,570,"That photo is so old."],[623,790,"Well you didn't throw it away,"],[837,970,"that says something."],[1057,1197,"It's personal."],[1374,1681,"Right, I mean who am I to ask anyway?"],[1878,2072,"We're nothing after all."],[2155,2335,"Just two people pretending"],[2335,2465,"to be a couple, right?"],[2519,2655,"Hey Leilani look."],[2679,2789,"I'm sorry."],[2842,3039,"I just haven't had time to clean"],[3039,3153,"everything out yet."],[3199,3380,"If you're still in"],[3380,3520,"love with her,"],[3640,3793,"just say it."],[4007,4154,"It's complicated."],[4367,4474,"You know,"],[4537,4698,"that's what people say when they"],[4698,4811,"don't want to hurt you."],[4918,5141,"But they don't want to tell you the truth either."],[5258,5445,"I'm gonna go pack my things."],[5759,5995,"Say something, stop her."],[6419,6553,"There's a glass of veggie juice"],[6553,6649,"on the counter."],[6913,7053,"It's good for your eyes."],[7887,8211,"God damn it Diego. You idiot!"],[8675,8875,"I'm so sorry to bug you."],[8965,9175,"I know this is super last minute."],[9179,9549,"I'm just short of one model for today's event."],[9549,9766,"No, it's okay. I'm happy to help."],[9873,10053,"You know this garage looks familiar."],[10053,10170,"It kind of reminds me of"],[10170,10283,"that modeling showcase"],[10283,10390,"we crashed in sophomore year."],[10417,10547,"You mean the one where"],[10547,10663,"we pretended to be interns?"],[10677,10734,"Isn't it?"],[10754,10974,"Yeah and you stuffed 5 macarons"],[10974,11141,"in your purse for \"later\"."],[11141,11211,"Survival."],[11211,11498,"Those catering cakes never feed us."],[11601,11715,"Time flies."],[11781,11938,"I still can't believe you"],[11938,12078,"actually became a model."],[12332,12555,"Anyway, so what is this event for?"],[12882,13346,"This one is designed just for you."]],"42":[[43,106,"What?"],[1057,1217,"Ruby, why are you doing this?"],[1217,1401,"You only have yourself to blame,"],[1401,1581,"you mess with the wrong people."],[2298,2405,"She's been secured."],[2562,2682,"Good job Ruby!"],[3450,3603,"I want this Ruby necklace."],[3623,3753,"You've already bought enough."],[3753,3910,"Please Mateo."],[3973,4144,"You're the sweetest."],[4197,4461,"I just have to wear this on our wedding day."],[4477,4654,"Don't you want your bride to sparkle?"],[4731,4901,"Jasmine once we're married,"],[4901,5045,"you'll regret this."],[5085,5138,"Fine."],[5869,6056,"Please check and try again."],[7057,7293,"Please check and try again!"],[7434,7534,"Use mine."],[7674,7857,"4 million in total."],[8398,8518,"I'll pay you back."],[8571,8692,"I don't want your money."],[8692,8802,"I need a favor."],[8915,9162,"Something about your ex, Leilani."]],"43":[[313,407,"No!"],[470,553,"No!"],[824,904,"No!"],[1294,1374,"Run?"],[1414,1521,"Why did you stop?"],[1895,2122,"So it's just one last time huh?"],[2162,2375,"Why are you acting so shy now?"],[2415,2522,"Getting used to being alone?"],[2615,2706,"Diego."],[2846,2882,"What?"],[2966,3086,"You're calling for your hero?"],[3143,3289,"He's not coming."],[3303,3526,"It's just you and me now"],[3733,3867,"You thought you could touch her"],[3867,3957,"and get away with it?"],[4124,4257,"It's not what it looks like."],[4294,4487,"Look I didn't do anything to her at all."],[4491,4751,"You really think I'd fall for that crap?"],[4754,4921,"Don’t insult my intelligence!"]],"44":[[153,410,"Stay the hell away from Leilani,"],[417,570,"or Garrison Group collapses."],[583,750,"Now get the hell out!"],[1401,1608,"You really do have superpowers."],[1751,1958,"Every time I’m in dangers,"],[2018,2122,"you show up."],[2402,2525,"Actually I-"],[2665,3046,"After the fire, I put a tracker in your phone,"],[3103,3303,"and I, I know I shouldn't have,"],[3303,3523,"but couldn't shake this fear that"],[3523,3713,"something might happen to you."],[3923,4064,"Our partnership should have been done"],[4064,4170,"when your father was cleared."],[4217,4591,"But I keep bringing you back into my life."],[4591,4931,"I like being in your life."],[5105,5418,"People say you're living hell but"],[5555,5679,"to me,"],[5859,6019,"you're my knight in shining armor."],[6463,6573,"Wow."],[6639,6720,"How touching!"],[6726,6810,"Show's over."],[6843,6910,"Get out!"],[7023,7237,"You knew, didn't you? About the affair."],[7307,7490,"But you still kept Leilani around."],[7604,7684,"Why?"],[7857,8011,"That's Maya."],[8081,8194,"She planned this."],[8254,8368,"Leilani’s everything"],[8368,8561,"you pretended to be..."],[8565,8725,"That's why she's the one I’d marry."],[8732,8935,"Marry? You're serious?!"],[9289,9366,"We're going home."]],"45":[[844,930,"You,"],[1101,1294,"you really meant what you said?"],[1498,1648,"About marrying me?"],[1735,1815,"Yeah."],[1951,2298,"But you always said you were against marriage,"],[2495,2709,"and we're not even together."],[2762,2969,"And most of the reason I was against marriage"],[2969,3063,"was because of Maya."],[3113,3249,"Speaking of Maya,"],[3420,3620,"she told me that her parents"],[3620,3907,"died in a car crash when she was little."],[4050,4441,"She said it was my biological father,"],[4501,4771,"that he was the one who was drunk driving."],[4774,4914,"She's been twisting stories"],[4914,5065,"her whole life to get sympathy."],[5221,5358,"And she was abandoned as a baby,"],[5358,5582,"her real parents left her at an orphanage."],[5655,5915,"No wonder I always felt like she was lying."],[7333,7490,"Maya's my daughter,"],[7524,7650,"but you care more about Leilani,"],[7650,7737,"don't you?"],[7737,7891,"She hurt Leilani."],[7994,8178,"Leilani could be your daughter too."],[9065,9159,"Leilani"],[9195,9346,"isn't your daughter?"],[9422,9599,"I was gonna change my will."],[9793,9933,"Now I don't need to."]],"46":[[46,203,"I have leukemia."],[403,587,"I was gonna make an announcement"],[587,694,"at the charity gala."],[857,1017,"But now I just wanna make sure"],[1017,1147,"that Maya is protected."],[1428,1538,"Maya's in jail."],[1601,1735,"I know you had something"],[1735,1815,"to do with it."],[2976,3069,"Come in."],[3313,3533,"Maya's been calling, she wants to talk."],[3613,3783,"I'm not taking her case."],[3857,4017,"But she's the Dyer heir."],[4024,4190,"I know exactly what I'm doing."],[4237,4494,"Understood. I'll leave you to it."],[4551,4901,"The test is clear she's not his daughter"],[4911,5118,"Something doesn't add up."],[5118,5455,"Feels like someone wanted it buried. Maya."],[5505,5755,"So this is one of your tricks too."],[6429,6509,"Diego."],[7250,7330,"Dissapointed?"],[7454,7714,"Expect to see you here, Miss..."],[7814,7891,"Dyer."]],"47":[[43,180,"If you're just here to mock me,"],[180,290,"you can leave."],[350,527,"Weren't we partners?"],[557,707,"Why the cold shoulder?"],[787,1011,"Partners are supposed to support each other"],[1101,1217,"like we used to."],[1274,1381,"Cut the crap."],[1501,1581,"Fine."],[2325,2479,"The board wants your name"],[2479,2589,"off the Dyre Group."],[2679,2862,"They're investigating you,"],[2899,3183,"which will lead to me, that giant hole"],[3183,3370,"in Andrew's company books."],[3400,3613,"I'm the one who filed"],[3626,3723,"company funds"],[3727,3847,"through Benjamin's account,"],[3847,4010,"to cover your ass."],[4010,4174,"That was the price."],[4287,4427,"I helped you climb your way"],[4427,4557,"into Jasmine's life,"],[4614,4761,"into the Malone family."],[4978,5101,"If I fall,"],[5175,5352,"I'm dragging you down with me."],[5418,5532,"That's right."],[5582,5725,"I don't deny it."],[5819,6129,"That's why I'm here to help."],[6316,6479,"You, need to leave."],[6546,6770,"Get things under control,"],[6840,7013,"for both our sakes."],[8054,8218,"How'd you get Ruby to take the fall?"],[8338,8418,"Few threats."],[8515,8605,"Don't get too excited."],[8658,8725,"Once you're back in control,"],[8725,8945,"you owe the Garrison Group 20 million."],[8978,9102,"Of course"],[9159,9259,"And Leilani?"],[9329,9469,"I've got a plan"]],"48":[[333,510,"Dad, are you okay?"],[593,707,"How's your case?"],[777,1067,"Diego's handling it. Everything's fine."],[1181,1321,"I need a favor."],[1601,1718,"Marry Maya."],[2052,2178,"Take care of her."],[2258,2342,"Andrew."],[2379,2582,"The hospital found a bone marrow donor."],[2609,2846,"You just focus on recovery right now."],[2866,3069,"Even with the transplant,"],[3106,3249,"I need assurance."],[3289,3513,"Otherwise I won't go through with surgery."],[3603,3683,"Dad,"],[3767,3883,"if you die,"],[3957,4087,"I'll go with you."],[4104,4147,"Maya."],[4207,4411,"The board wants to remove you."],[4527,4821,"Marrying Diego will secure the Dyer Group."],[4848,5011,"I don't even care about finding"],[5011,5138,"my real daughter anymore."],[5362,5458,"Maya is enough."],[5535,5602,"Mr. Dyer,"],[5602,5785,"your bone marrow donor has arrived."]],"49":[[273,353,"Leilani?"],[477,637,"What a coincidence!"],[697,954,"I'm just happy I could help."],[1538,1688,"Andrew has leukemia,"],[1841,1985,"and he needs a transplant."],[2145,2402,"They've looked everywhere"],[2435,2559,"for a match."],[2575,2659,"Wait..."],[2739,2806,"Me?"],[2862,3106,"Look, I don't ask you for much,"],[3106,3370,"but this time I need your help."],[3573,3670,"Andrew."],[3757,3973,"He' the one who gave me my first shot"],[3973,4090,"right after law school."],[4117,4250,"He saw something in me"],[4250,4387,"before anyone else did."],[4514,4607,"And without him,"],[4622,4828,"I probably wouldn't be sitting"],[4828,4894,"behind this desk."],[4941,5185,"Then I'll do it,"],[5185,5518,"for him and for you."],[5685,5859,"It is no small thing."],[5925,6202,"I owe you deeply."],[6319,6513,"If you ever need anything at all,"],[6513,6730,"please just say the word."],[6733,6850,"Money, obviously."],[6873,6963,"Shut up!"],[6990,7103,"Miss Holmes."],[7117,7337,"We need to prep you for the transplant."],[8098,8221,"When this is over,"],[8314,8498,"we're getting married."],[8498,8675,"We haven't even dated"],[8745,8905,"and this will be day one."]],"50":[[244,432,"Why is it taking so long?"],[720,892,"Worried about your little sweetheart?"],[960,1048,"Back off!"],[1064,1240,"I'm not in the mood to talk to you."],[1260,1300,"Fine."],[1388,1484,"Just don't come crawling"],[1484,1552,"back to me after."],[3000,3088,"Shit."],[4300,4504,"Where the hell is she?!"],[4600,4724,"You want answers?"],[4796,4876,"Fine."],[4960,5068,"Let's trade."],[5276,5416,"Tell me why you really dumped me."],[5416,5580,"You know exactly what you did."],[5580,5768,"Did Savannah say something to you?"],[5800,6012,"I was gonna propose to you that night."],[6108,6308,"I sat in front of your house with a ring,"],[6384,6544,"saw you flirting with another man"],[6544,6660,"like I didn't exist."],[6828,6988,"You know the worst part?"],[7196,7384,"Right then, my phone rang."],[7508,7672,"She had a heart attack"],[7672,8068,"and I didn't make it to see her one last time,"],[8080,8428,"and you dare ask me why I hate you?"],[8436,8500,"Diego."],[8580,8720,"I messed up, okay?"],[8788,8920,"I know what I did was wrong."],[8932,9000,"Just,"],[9040,9392,"just tell me what I need to do to fix this."],[9440,9560,"You can't fix it."],[9732,10144,"Now tell me where is Leilani?"]],"51":[[33,313,"Maya said Mateo had a surprise for me?"],[1548,1678,"Leilani?"],[1678,1875,"You? And Mateo?"],[1938,2118,"Jasmine, wait."],[2118,2238,"I can explain."],[2305,2479,"Don't touch me!"],[2479,2836,"If Jasmine tells Diego, I'm done."],[3033,3113,"Jasmine."],[3233,3319,"I love you."],[3319,3440,"I never hurt you."],[3480,3546,"Stop lying!"],[3546,3817,"Think, she's your brother's girlfriend,"],[3817,3983,"why would I touch her?"],[4087,4324,"She came up to me. You know,"],[4324,4497,"she's my ex. She's never"],[4497,4641,"stopped clinging to me"],[4647,4774,"She tricked me."],[4838,4958,"Just, she drugged me."],[4958,5058,"I, I..."],[5058,5198,"I thought she was you."],[5261,5422,"Mateo, don't lie to me."],[5578,5658,"Never."],[5819,5939,"If you ever got hurt,"],[5939,6082,"I'd never forgive myself."],[6693,6780,"Stay here."],[6820,6990,"You drop your bracelet. I'll get it for you."],[7003,7093,"Forget it."],[7107,7263,"Let's just buy 10 more."],[7317,7570,"Jasmine, the Garrison Group’s is broken."],[7727,7907,"You need to be smart with your money."],[8078,8254,"I want to spoil you, really."],[8575,8682,"But."],[8738,8972,"You still have those Malone shares, right?"],[9119,9262,"Maybe you can help me out a little?"],[9419,9579,"I gave them all to Diego."],[9873,9983,"Mateo..."],[10093,10503,"I know you don't really love me."],[10677,10844,"But I love you,"],[10957,11354,"and that's why I can be so sad."],[11414,11514,"So insecure."],[11678,11845,"But when you buy me things,"],[11961,12335,"at least it makes pain a little easier to live with."],[12619,12699,"Just..."],[12796,12936,"Show me a little love."],[13079,13239,"That's all I ever need."],[13293,13560,"So I get nothing."],[13727,13803,"You stupid woman."]],"52":[[397,443,"Mateo!"],[490,660,"She's your fiance, how could"],[660,787,"you do this to her!?"],[2245,2339,"Jasmine."],[2489,2686,"Please tell me she's gonna make it."],[2739,2869,"Mateo won’t be."],[3400,3480,"Jasmine?"],[3616,3710,"Diego."],[3907,3993,"Leilani."],[4197,4307,"Where's Mateo?"],[4347,4431,"Jasmine."],[4577,4778,"Mateo did this to you."],[4898,4954,"No!"],[5108,5201,"I fell."],[5288,5432,"It wasn't his fault!"],[5468,5505,"I-"],[5618,5692,"Okay, okay."],[5692,5825,"I believe you, just breathe."]],"53":[[180,393,"I feel bad about your sister."],[480,623,"None of this is on you."],[643,777,"Okay, you were framed too."],[900,1101,"I wish I'd gotten there sooner."],[1217,1454,"Maybe if I had, she wouldn't have gotten."],[1685,1811,"Go get some rest."],[1865,1898,"Okay,"],[1898,2075,"You're still recovering from surgery."],[2162,2228,"Don't worry."],[2262,2449,"I’ve all I need to take Mateo down."],[2465,2505,"How?"],[2609,2722,"Let's just say I have"],[2779,2946,"a very special guest."],[3496,3603,"Relax."],[3690,3833,"Jasmine hasn't said anything."],[3917,4034,"Not officially."],[4164,4290,"She didn't report you."],[4310,4411,"Can I let that slide?"],[4417,4571,"Because you hurt his sister."],[4671,4818,"But that's his problem."],[4931,5088,"Ours is getting you out of here"],[5088,5235,"before things get messy"],[5478,5615,"I gave you 20 million."],[5709,5885,"Should be enough to disappear for a while."],[5939,6052,"You shouldn't have let Jasmine"],[6052,6146,"show up that night!"],[6246,6329,"Have you forgotten?"],[6329,6406,"We stick together."],[6423,6589,"If I sink, you sink!"]],"54":[[50,156,"Who pulled the strings to get you in"],[156,373,"With the Malone family in the first place?"],[417,590,"You wanna talk about sinking ships?"],[603,837,"Don't forget who built the goddamn boat!"],[934,1037,"Pack your bags."],[1181,1351,"I've arranged a place for you in Vegas."],[1458,1671,"Lie low, let me handle the rest."],[1731,1868,"If I go down for this."],[1868,1958,"You won't!"],[2225,2379,"Not if you follow my lead."],[2555,2919,"Congratulations. I heard the surgery went well."],[2946,3219,"It's, just this anesthesia."],[3299,3473,"It's making me a little lightheaded."],[3807,3930,"Thank you Leilani"],[3997,4254,"You've been incredibly generous."],[4351,4607,"I’m just glad I could help."],[4904,5151,"Would you give me and Mr. Dyer a moment?"],[5382,5465,"Of course."]],"55":[[83,220,"What's this about?"],[283,357,"Turns out,"],[450,543,"Leilani,"],[600,724,"she is your daughter."],[1428,1534,"What?"],[1725,1881,"But, the previous test?"],[4537,4647,"What are you doing?"],[4948,5071,"Just dropping these off"],[5699,5895,"After you told me Leilani"],[5895,5999,"isn't your daughter."],[6199,6339,"After you told me Leilani"],[6346,6479,"isn't your biological daughter,"],[6479,6529,"I-"],[6593,6840,"I had my secretary run another DNA test."],[6953,7093,"Turns out Maya,"],[7253,7414,"she switched hair samples."],[7440,7524,"What?"],[7617,7694,"No."],[7801,7927,"That's impossible."],[8011,8228,"Maya would never do something like that."],[8248,8368,"I get it."],[8518,8628,"You raised her for years."],[8628,8778,"You love her like your own."],[8952,9122,"But you know me Mr. Dyer."],[9212,9366,"I wouldn't bring this up unless"],[9366,9529,"I was absolutely sure."],[9793,9903,"Trust me."],[9963,10166,"Maya is not who you think she is."],[10323,10587,"You just focus on resting right now."],[10617,10740,"And when the time is right,"],[10740,10834,"I will make sure that"],[10834,10937,"you know the full truth."]],"56":[[897,1231,"A toast to Mr. Dyer's recovery."],[1721,1921,"Thank you everyone."],[2068,2172,"And actually,"],[2202,2382,"I'd like to take this opportunity,"],[2409,2539,"with everyone here,"],[2612,2819,"to make a very special announcement."],[3006,3196,"I found my biological daughter."],[3436,3643,"And I'm gonna officially naming her heir"],[3687,3800,"to the Dyer Group."],[3920,4007,"Leilani."],[4284,4367,"That's impossible!"],[4411,4554,"You already did a DNA test!"],[4594,4828,"Falsifying results isn't exactly hard"],[4828,4931,"for someone like you."],[5011,5118,"You've got no proof!"],[5205,5435,"Oh, but I do."],[5622,5742,"Bring in the witness."]],"57":[[1027,1107,"You let her out?"],[1124,1231,"Deal with the DA."],[1287,1504,"In exchange for full cooperation"],[1568,1685,"and the truth."],[1765,2082,"I have the evidence, wire transfers,"],[2082,2218,"phone calls, everything."],[2322,2559,"I cleaned up all of your messes,"],[2595,2746,"like a loyal little sidekick."],[2872,2976,"But I can't believe that you"],[2976,3093,"would be heartless enough"],[3093,3343,"to send me to jail and take the fall for you!"],[3406,3453,"Wait"],[3536,3626,"What evidence?"],[3673,3790,"Wire transfers?"],[3843,3963,"What the hell's going on here?"],[3963,4064,"Mr. Dyer."],[4134,4290,"Please take a look."],[4467,4938,"Maya and Mateo set up the whole thing,"],[5018,5261,"framing Leilani's father,"],[5405,5655,"Llundering money through the"],[5655,5762,"Holmes Group,"],[5782,6192,"to cover the massive loss she caused at Dyer."],[6272,6509,"Mateo orchestrated the whole thing,"],[6533,6716,"manipulating the finances,"],[6750,7007,"so the funds went back to Maya."],[7073,7290,"Mateo has been arrested."],[7761,7861,"Mr. Garrison."],[8031,8131,"Mr. Garrison."],[8588,8818,"Under investigation for financial crimes,"],[8818,8968,"you're gonna have to come up with us."],[9319,9362,"Hey!"],[9406,9442,"Hey!"],[9462,9516,"Slow down."],[9569,9649,"Come on."],[10186,10283,"Oh no."],[10336,10423,"Mateo."]],"58":[[150,253,"These numbers."],[360,530,"Where the hell did the money go?"],[543,677,"Maya used the money"],[677,850,"to open up exclusive clubs"],[850,987,"staffed with models,"],[1001,1154,"catering to wealthy clients."],[1277,1468,"You destroyed my life!"],[1588,1931,"The banquet fire? You locked Leilani inside,"],[1945,2068,"attempted murder."],[2145,2305,"You switched paternity tests."],[2382,2649,"I can keep going. Do you really want me to?"],[2669,2759,"I did what I had to do."],[2772,2819,"No!"],[2936,3093,"You did what served you."],[3106,3243,"Take her away!"],[3356,3456,"Dad please."],[3463,3610,"Please I don't wanna go to prison."],[3700,4024,"I've done all I can for you,"],[4024,4174,"you still broke everything."],[4661,4748,"You only want me gone"],[4748,4828,"because of her!"]],"59":[[520,674,"You think Diego loves you?"],[674,804,"You don't even know his secret!"],[854,970,"He only got close to you"],[970,1164,"to tear apart with Mateo and Jasmine"],[1271,1408,"That was the plan from day one!"],[1471,1594,"That's enough."],[1658,1775,"Take her away!"],[3553,3636,"Leilani,"],[3810,4124,"I'm sorry for everything."],[4394,4597,"You have nothing to apologize."],[4604,4711,"Oh sweetheart."],[5538,5642,"Hi Miss Holmes."],[5712,5782,"Is uh,"],[5782,5892,"Leilani here?"],[5969,6099,"Mr. Malone."],[6182,6386,"She's been up in her room all day."],[6403,6593,"Not sure what she's been up to."],[6593,6746,"She hasn't come down much."],[6876,7003,"Evening Diego."],[7007,7117,"Everything alright?"],[7150,7230,"I hope so."],[7290,7430,"Well go on up,"],[7470,7674,"and sometimes it takes the one"],[7674,7901,"who stirred at the mess to fix it."]],"60":[[433,710,"Why... why didn't you text me back?"],[804,934,"I went to bed early."],[1004,1207,"Not everyone's a night owl like you."],[1351,1451,"Wait, is this?"],[1524,1671,"Because of what Maya said yesterday?"],[1825,1951,"Look, I wasn't trying to hurt you."],[1951,2002,"I was,"],[2062,2175,"I was gonna tell you everything."],[2342,2645,"Of course I knew you were using me at first"],[2662,2892,"to break up Mateo and Jasmine."],[3113,3243,"That obvious, huh?"],[3243,3353,"It's fine."],[3443,3570,"I wasn't exactly"],[3570,3763,"an innocent little lamb either."],[3853,4007,"I have my reasons too."],[4110,4464,"So what are you packing for?"],[4824,4988,"Well yeah."],[4991,5105,"I mean..."],[5105,5325,"Since we're not pretending anymore,"],[5325,5675,"I figured I move in for real this time."],[5715,5882,"I mean wasn't that the point"],[5882,5999,"to end a marriage?"],[5999,6166,"So you just wanna"],[6229,6456,"skip over the whole dating part?"],[6730,6866,"Who says we can't date"],[6866,7067,"after the wedding?"],[7477,7757,"No complaints here. I'm in."],[7761,7847,"At least you didn't"],[7847,7984,"skip the wedding part."],[8098,8281,"Better not skip the honeymoon either."],[8458,8725,"Never. I'm counting the days."]]}