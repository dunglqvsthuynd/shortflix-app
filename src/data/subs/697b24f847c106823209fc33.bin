 cheating bastard"],[12854,12975,"and a home wrecking bitch."],[14118,14247,"I guess this is a farewell to her."],[14301,14335,"You know,"],[14335,14397,"I never thought that"],[14397,14493,"the gifts that I got us"],[14493,14614,"for our reunion would turn"],[14614,14718,"into her wedding gifts,"],[14718,14752,"but..."]],"12":[[1096,1263,"Grandpa, what are you doing here?"],[1305,1422,"I heard via the family"],[1455,1584,"grapevine you're"],[1584,1647,"about to propose"],[1672,1822,"to your childhood sweetheart."],[1843,1993,"It's about time, kid."],[2043,2268,"These cars are full of a ton of gifts"],[2298,2481,"for my future granddaughter-in-law."],[2506,2585,"Well, you know, Grandpa,"],[2669,2802,"the wedding was actually today,"],[2802,2907,"so it doesn't really matter."],[2994,3207,"Bella's his childhood sweetheart?"],[3286,3324,"What?"],[3349,3457,"She married somebody else?"],[3570,3649,"You know what they say?"],[3666,3778,"You snooze, you lose."],[3858,3978,"Hey, don't worry, kid."],[4045,4191,"There's more fish in the sea."],[4266,4350,"Your old grandpa"],[4371,4621,"will show you how to find a real keeper."],[4700,4813,"Well, you know what, Grandpa?"],[4813,4946,"I've actually already decided that"],[4946,5138,"I'm going to die single and alone,"],[5150,5217,"so I don't care."],[5263,5367,"You're not getting married?"],[5367,5409,"No."],[5543,5580,"But-"],[5580,5609,"No."],[5705,5764,"From now on,"],[5776,5910,"I'm going to dedicate my life"],[5951,5993,"to my work."],[6101,6256,"Now I need to get back to the office."],[6368,6456,"See you later, Grandpa."],[6498,6602,"But, but..."],[6685,6781,"But what about my"],[6840,6981,"future great grandbabies?"],[7007,7190,"Hey, hey, Chris."],[7215,7344,"You're my only grandchild,"],[7374,7457,"my only heir."],[7478,7603,"Who's going to give me great"],[7603,7728,"grandbabies now?"],[7799,8120,"Who's gonna give me great grandchildren?"],[8375,8441,"Oh, God."],[8491,8533,"Sir."],[8725,8796,"Are you okay?"],[9267,937