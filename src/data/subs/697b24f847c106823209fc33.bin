hat I have"],[362,450,"everybody's attention,"],[521,600,"I would like to make a"],[650,771,"quick announcement."],[834,1026,"The woman to my left is"],[1105,1197,"my wife."],[1280,1422,"Does he mean it?"],[1655,1735,"OMG,"],[1735,1826,"is Chris siding with"],[1826,1960,"the country bumpkin?"],[1964,1989,"Yeah,"],[1989,2135,"didn't Bella say he was"],[2135,2231,"forced to marry her?"],[2231,2277,"When she..."],[2277,2344,"Oh, what?"],[2344,2410,"What?"],[2410,2610,"No, Chris, you're bluffing."],[2610,2723,"Your marriage is fake."],[2761,2902,"Didn't you only marry her"],[2902,3023,"because you needed a doctor"],[3023,3144,"to cure your grandpa?"],[3157,3278,"You're planning a divorce."],[3303,3591,"Chris, is what she said true?"],[3649,3687,"Grandpa?"],[3707,3787,"Grandpa?"],[3787,3849,"Grandpa!"],[3912,3937,"Grandpa?"],[3937,4066,"Oh! Oh!"],[4083,4241,"Okay, everybody step aside."],[4241,4312,"Give me room."]],"54":[[700,771,"He's awake."],[821,863,"Grandpa."],[975,1046,"Dad's awake!"],[1238,1305,"Chris,"],[1380,1559,"are you divorcing your wife?"],[1609,1685,"No, she..."],[1714,1839,"Grandpa, she's lying."],[1868,1897,"No,"],[1922,2189,"No, I know you worry about your grandpa."],[2231,2339,"You know you love me, right?"],[2339,2485,"I'm your childhood sweetheart."],[2598,2690,"Enough, Bella."],[2740,2794,"You're not his"],[2794,2886,"childhood sweetheart."],[2894,2982,"I am."],[3098,3194,"What did you just say?"],[3474,3524,"Chris."],[3595,3699,"I am Hailey."]],"55":[[50,87,"You are?"],[417,567,"Then how do you not remember?"],[629,704,"I can't."],[813,892,"That summer when"],[913,1080,"we were going from your house to mine,"],[1163,1288,"we got into a car accident"],[1326,1455,"and I lost all my memories."],[1480,1534,"Really?"],[1722,1810,"Is that why you never"],[1810,1956,"responded to any of my letters?"],[2014,2210,"Because I sent you like 500 letters."],[2281,2398,"I started to, uh..."],[2460,2602,"Never mind. Everything..."],[2648,2748,"The only thing that matters"],[2777,2911,"is that you remember now."],[3203,3282,"Since when did this"],[3282,3424,"bitch regain her memories?"],[3445,3549,"She must be lying."],[3557,3603,"What?"],[3620,3732,"No, she's lying!"],[3795,3878,"I'm the real Hailey."],[3878,3899,"I..."],[3920,3995,"I have all your letters."],[4412,4491,"Chris, see,"],[4491,4529,"these are all"],[4529,4617,"the letters you wrote me."],[4671,4721,"Wow."],[4788,4938,"You really did send a lot of letters."],[4938,5075,"You have the letters."],[5096,5176,"Of course, Chris."],[5176,5288,"Do you believe me now?"],[5467,5659,"Okay, then why did you marry Hardy?"],[5709,5780,"And how did you never"],[5780,5947,"respond to any of my letters?"],[6172,6214,"Boss,"],[6231,6293,"we found out who"],[6293,6402,"was behind the car crash."],[6402,6514,"It's Bella Parker."],[6519,6706,"This woman right before you."]],"56":[[58,104,"No."],[133,166,"No, Chris."],[166,216,"I'm innocent."],[241,316,"Trust me."],[379,508,"Save it for the judge."],[508,567,"Please!"],[567,713,"I'm innocent! Please! Please!"],[713,842,"Chris, Chris, please!"],[842,942,"Please, I'm innocent!"],[996,1051,"Chris!"],[1259,1338,"Hey."],[1413,1501,"I want you to know something."],[1501,1655,"I am so sorry that I did not know"],[1655,1739,"about the car crash."],[1739,1893,"And I am extremely sorry"],[1947,2097,"that I mistook you for your sister."],[2118,2160,"Okay?"],[2160,2210,"I never meant"],[2210,2314,"for any of that to happen."],[2369,2435,"It's okay."],[2519,2640,"At least we're together now."],[2736,2894,"And you found your way back to me."],[2952,3028,"I did."],[3140,3261,"Thank you for waiting for me."],[3607,3728,"That's my daughter-in-law"],[3728,3807,"right there."],[3862,3987,"Ladies and gentlemen,"],[3987,4112,"time for a kiss."]],"57":[[204,392,"Good night, you two lovebirds."],[392,596,"Make me some grandbabies."],[863,963,"I'm gonna go shower."],[1155,1297,"Why don't we shower together?"],[1426,1551,"Shower together?"],[1568,1626,"Mm-hmm."],[1697,1768,"You perv?"],[1839,1906,"Perv."],[2002,2093,"I'm your husband."],[2202,2243,"Yeah,"],[2243,2281,"but..."],[2281,2523,"Shall I remind you that you literally"],[2523,2756,"pulled down my pants three times?"],[2756,2873,"How does that make me the perv?"],[2919,3040,"And when did I do that?"],[3215,3336,"Once when we were ten,"],[3357,3486,"and you spanked me."],[3520,3603,"And then again when you were"],[3603,3862,"Dr. Elixir and you gave me that shot."],[4029,4175,"And then there was a third time."],[4175,4391,"Okay, I remember the third time."],[5146,5201,"What..."],[5326,5417,"What are you doing?"]],"58":[[145,221,"What are you doing?"],[258,379,"Taking off my belt."],[400,483,"Why?"],[542,704,"Because after three times I assumed"],[704,867,"that you wanted me to do it myself."],[1488,1551,"Well, I..."],[1568,1647,"How else do you want"],[1647,1785,"to consummate our marriage?"],[2014,2064,"How else"],[2064,2173,"are we going to make a baby?"],[2439,2477,"How"],[2602,2723,"do I make you mine?"],[2898,3023,"I...Chris..."],[3028,3090,"Hailey,"],[3236,3303,"I love you."],[3440,3545,"And even when I didn't know"],[3545,3616,"it was you,"],[3661,3732,"my heart knew."],[3862,3958,"It was always you."],[4162,4371,"And it will always be you."],[4546,4617,"I love you too."],[4788,4934,"No matter where life takes us,"],[4934,5105,"I'll always find my way back to you."]]}