{"1":[[663,855,"Welcome back, Mr. Robinson."],[1351,1497,"It's been 18 years."],[1543,1672,"Hailey, where have you been?"],[1701,1735,"Now,"],[1735,1843,"you'll be happy to know"],[1843,1976,"that I've kept my promise."],[1989,2060,"I've worked hard,"],[2106,2223,"made a name for myself,"],[2260,2318,"but you haven't"],[2335,2506,"responded to any of my letters."],[2527,2610,"I hope you and your grandma"],[2610,2673,"are doing okay."],[3707,3803,"Get my son out of"],[3803,3949,"the car and bring him to me."],[3953,4029,"Yes, ma'am."],[4396,4562,"Mr. Robinson, please,"],[4571,4688,"allow me to help your way out."],[5697,5864,"I don't need anyone's help."],[5885,5943,"Of course."],[6001,6189,"You're so mature for your age."],[7057,7198,"Bring me the gift I've prepared"],[7198,7307,"for my son."],[7645,7799,"Mom, what's this for?"],[7891,7966,"I've spent"],[7966,8120,"hundreds of thousands of dollars"],[8120,8308,"sending you to the top prep schools,"],[8341,8454,"and every year you come home"],[8454,8558,"with straight F's."],[8604,8721,"If you're not going to study,"],[8721,8846,"you're going to need to learn some"],[8846,8967,"useful life skills,"],[8996,9109,"which include..."],[9300,9392,"mowing the lawn."],[9451,9734,"Chris Robinson, this is your last chance."],[9751,9855,"Do you want to study,"],[9884,10030,"or do you want to mow the lawn?"],[10239,10360,"I pick..."],[10556,10656,"mowing the lawn."],[11115,11161,"Chris,"],[11202,11307,"you actually rather"],[11307,11444,"mow lawns than study?"],[11678,11753,"Don't worry, ma'am."],[11807,11886,"He'll come around."],[11920,12007,"Give him an hour."],[12045,12107,"Tops."],[12191,12249,"Fine."],[12270,12383,"I'll call his bluff."],[12466,12645,"We'll wait for him to give up first."],[12946,13058,"It's been over an hour and he's"],[13058,13213,"still out there having fun."],[13213,13321,"He's never going to take"],[13321,13434,"his studies seriously."],[13455,13526,"Dear Lord,"],[13559,13734,"send me an angel to help whip my son"],[13734,13834,"into shape."],[14039,14093,"Oh no!"],[14180,14326,"Why is this flower uprooted?"],[14343,14422,"Hey!"],[14435,14577,"Someone get me a plant pot!"],[14577,14743,"We have to keep these flowers alive!"],[14743,14827,"Stop right there!"],[15056,15152,"Stop right there!"],[15152,15219,"Stop!"],[15853,15903,"Aw!"]],"2":[[79,241,"Yeah, serves you right."],[241,412,"Is that how your mama raised you?"],[412,579,"To rob from a poor old lady?"],[608,717,"You ought to be ashamed."],[779,896,"Oh, you little brat."],[1009,1130,"I'm gonna beat your ass."],[1388,1459,"Wow!"],[1468,1668,"Look at that amazing little girl."],[1697,1826,"She put that thief"],[1826,1972,"in his place like a boss."],[2114,2314,"If she were watching over Chris,"],[2314,2498,"I bet she could set him straight."],[2556,2677,"Learned your lesson yet,"],[2677,2773,"you stupid thief?"],[2811,2890,"I'm sorry."],[2894,2952,"I'm sorry."],[2952,3036,"Please, have mercy."],[3098,3286,"Sweetie, I called the cops."],[3286,3461,"I'll see to it that he's arrested."],[3507,3582,"Hailey."],[3636,3749,"Hailey, are you hurt?"],[3782,3912,"No, I'm fine, Granny."],[3945,3999,"Look here."],[4024,4149,"I got your money back."],[4175,4275,"Thank you, Hailey."],[4291,4517,"I'll need every cent for my surgery."],[4529,4637,"How could that wallet"],[4637,4721,"fit enough cash"],[4721,4808,"for surgery?"],[5142,5192,"Hey,"],[5205,5251,"um,"],[5263,5434,"real sorry I broke your flower pot."],[5434,5480,"Ew."],[5480,5576,"Stay away from me,"],[5576,5693,"you country bumpkin."],[5701,5901,"You're all dirty and gross."],[5918,6031,"I'm dirty and gross?"],[6051,6172,"You're the one covered in mud."],[6193,6352,"You look like a sticky hobo."],[6352,6556,"Hailey, remember what I said."],[6627,6748,"We don't judge people"],[6748,6877,"by their appearances."],[6898,6986,"Sorry, Granny,"],[7007,7148,"I shouldn't have said that."],[7148,7215,"Come on,"],[7215,7349,"we gotta get you to the hospital."],[7753,7862,"Take Chris home."],[8053,8141,"I'm going to see"],[8141,8304,"about getting my son a tutor that can"],[8304,8404,"set him straight."],[9096,9205,"How much is it?"],[9250,9476,"The upfront cost is $200,000."],[9496,9738,"I'll be fine without surgery."],[9809,9964,"I'll pay the $200,000."],[10110,10172,"Oh,"],[10214,10372,"you're the nice lady from earlier."],[10460,10493,"But..."],[10589,10752,"why do you want to help us?"],[10785,10844,"Well,"],[10856,11031,"I'd actually like a little help from you"],[11031,11136,"in return."],[11136,11240,"I'd like you to whip my"],[11240,11432,"bratty little son into shape."],[11874,11949,"Homework?"],[11961,12049,"No thanks."],[12066,12128,"I'll rip it"],[12128,12245,"all up so there's nothing you"],[12245,12333,"can do about it."],[12333,12466,"Mr. Robinson, please stop."],[12466,12583,"These books are brand new."],[12616,12687,"Shut up."],[12746,12862,"One more word and I'll"],[12862,13000,"tell my mom to fire you."],[13067,13188,"I can do whatever I want."],[13221,13400,"So long as I make him behave, right?"]],"3":[[8,75,"Of course, miss."],[104,200,"But be warned,"],[200,342,"he's already driven off a dozen tutors"],[342,425,"with his antics."],[483,563,"You're our last hope."],[621,775,"Relax, I got this."],[829,867,"Now,"],[896,988,"get me a belt"],[1001,1184,"and make sure it's real leather."],[1430,1539,"Yeah, that's right."],[1576,1697,"I'd rather mow the lawn"],[1697,1797,"than do my homework."],[3186,3269,"You again?"],[3282,3407,"The country bumpkin?"],[3407,3516,"How'd you even get in here?"],[3545,3716,"I'm not a country bumpkin."],[3716,3787,"I'm Hailey."],[3812,3912,"And starting right now,"],[3924,4016,"I'm your new tutor."],[4058,4154,"So are you going to study"],[4183,4250,"or am I going to have"],[4250,4346,"to beat some sense"],[4346,4408,"into you?"],[4450,4587,"I'm never going to study."],[4621,4733,"Yeah, you heard me."],[4733,4821,"What you going to do, huh?"],[4867,4909,"Hit me?"],[5025,5105,"I dare you."],[5251,5401,"No one's ever dared me that before."],[5434,5480,"But sure."],[5518,5605,"Gladly."],[6218,6456,"You...You actually hit me?"],[6610,6706,"This girl hit me."],[6715,6802,"Call the cops."],[6802,6919,"You really think the cops"],[6919,7007,"are going to care that you"],[7007,7136,"got whipped by a little girl?"],[7190,7374,"You are not getting out of this."],[8041,8091,"Aw."],[8650,8858,"I'll ask you one more time."],[8892,9100,"Are you going to do your homework?"],[9396,9484,"Fine, fine!"],[9505,9605,"I'll do my homework!"],[9605,9672,"I'll do it!"],[10802,10965,"How's that for a lesson?"],[10985,11111,"Chris, how could you?"],[11215,11332,"You asked for this!"],[12170,12341,"Ow, mom!"],[12362,12458,"Do something!"],[12458,12566,"I'm your only child,"],[12566,12775,"don't let this lunatic kill me!"],[12837,12900,"Well,"],[12925,12979,"you should have"],[12979,13092,"listened to Hailey and"],[13092,13163,"ate your dinner like"],[13163,13259,"a good boy and maybe"],[13259,13417,"she wouldn't have to break out the belt."],[13509,13567,"Yeah,"],[13567,13730,"now are you going to eat your steak"],[13730,13780,"or am I going to have"],[13780,13913,"to beat you some more?"],[14122,14243,"Fine, I'll eat it."],[14835,15035,"I've never been so humiliated"],[15035,15140,"in my life!"],[15148,15365,"Hailey, you're going to regret this."]],"4":[[400,504,"Where's Chris?"],[521,621,"He's in the study, miss."],[675,771,"Really?"],[779,875,"Since when is he such a"],[875,963,"good student?"],[1714,1780,"Ha-Ha-Ha!"],[1818,1997,"Hailey's a scaredy-cat."],[2043,2231,"Chris, you little brat!"],[2748,2794,"Haha!"],[2840,2990,"You're the biggest dummy"],[2990,3107,"I've ever seen!"],[3153,3315,"I hate spiders."],[3378,3536,"You're dead meat, Chris!"],[4859,5038,"How dare you put down my pants!"],[5084,5238,"What's going on in there?"],[5246,5405,"This is what you get for pranking me!"],[5417,5551,"A good old beating!"],[5618,5655,"Ah!"],[5680,5868,"How dare you hit my butt!"],[5935,5985,"Ah!"],[6081,6197,"I'm sorry!"],[6322,6489,"Mom, she's beating me!"],[6594,6698,"Carry on, Hailey."],[6873,6923,"Ah!"],[7007,7036,"Ma'am,"],[7044,7190,"Ms. Hailey isn't going to break him,"],[7190,7236,"is she?"],[7307,7424,"Nonsense."],[7449,7578,"Hailey's a kind young lady."],[7636,7761,"She'll know when to stop."],[7970,8033,"Ah!"],[8091,8187,"Trying to bully me,"],[8204,8350,"so you can get out of study?"],[8370,8554,"No, no, no, I'm not, I'm not."],[8554,8721,"I'm sorry, I'll study, I'll study!"],[10272,10406,"Chris really finished all this"],[10406,10468,"on his own?"],[10527,10564,"Yeah,"],[10568,10739,"he's actually a pretty fast learner"],[10739,10869,"when he puts his heart to it."],[11027,11236,"Whoa, it's been one month of tutoring."],[11269,11386,"That's the first time she said"],[11386,11498,"something nice about me."],[11699,11811,"Thank you, Hailey."],[11840,11999,"You really saved Chris."],[12675,12721,"Wow,"],[12771,12971,"are you giving me the whole universe?"],[13046,13196,"This is truly magical."],[13309,13434,"What's in your cookie tin?"],[13475,13596,"I can't tell you now."],[13621,13717,"It's a surprise."],[13747,13922,"We'll have to wait till we're grown up."],[14172,14222,"Okay."],[15598,15761,"Since when do you work out?"],[15769,15861,"I want to get it buff"],[15870,16007,"and strong so I can protect"],[16007,16116,"the people I care about."],[16278,16424,"I want to get buffer strong too."],[16441,16562,"Then I can protect Granny."],[17050,17092,"Hailey,"],[17179,17313,"you'll protect your Granny"],[17313,17409,"and I'll protect you."],[17438,17492,"Deal?"]],"5":[[1476,1847,"Wow, Chris, you aced your practice exam."],[1881,1947,"At this rate,"],[1947,2031,"you'll be top of your"],[2031,2135,"class next year."],[2281,2385,"Hailey,"],[2410,2506,"did you see all the pretty"],[2506,2619,"dresses I got you?"],[2631,2748,"Why don't you go try them on?"],[2781,2857,"Auntie Donna,"],[2857,3019,"you've already done so much for me."],[3032,3132,"I can't take anything"],[3132,3190,"else from you."],[3386,3503,"Hailey, head home?"],[3507,3553,"Where?"],[3553,3653,"Is it far away from here?"],[3674,3887,"Yeah, Oregon's pretty far away."],[3924,4083,"We just came to LA so that"],[4108,4254,"granny could see a better doctor."],[4441,4504,"Hailey,"],[4504,4596,"I can't thank you enough"],[4596,4754,"for tutoring Chris all summer."],[4783,4963,"You really changed him for the better."],[4992,5096,"I'm so grateful."],[5313,5372,"Listen,"],[5422,5501,"would you like to stay"],[5501,5597,"with us and go to school"],[5597,5697,"with Chris next year?"],[5747,5801,"Yeah!"],[5801,5889,"Hailey, stay!"],[5889,6001,"We can go to school together!"],[6022,6110,"You can have your own room"],[6110,6197,"at our house,"],[6231,6448,"you can wear pretty dresses every day,"],[6519,6648,"and I'll make sure we cook"],[6648,6773,"all your favorite foods."],[7111,7148,"Yeah,"],[7148,7286,"but the cow back at the farm's"],[7286,7390,"about to have her baby."],[7419,7628,"So, we gotta go take care of them."],[7711,7741,"So,"],[7782,7874,"you're just gonna leave me"],[7887,7966,"just like that?"],[8133,8249,"We could write letters."],[8279,8391,"I'll talk to you next summer."],[8416,8462,"Really?"],[8487,8550,"Promise?"],[8583,8750,"I'm gonna write you letters every day."],[9914,10097,"Mom, you can't let Hailey leave."],[10097,10201,"You can't let her go."],[10210,10406,"Chris, I know you're sad to see her go,"],[10406,10506,"but we have to respect"],[10506,10602,"Hailey's decision."],[10639,10723,"I don't care, Mom."],[10723,10827,"You can't let her go."],[10990,11040,"Chris,"],[11073,11215,"you gotta work hard in school,"],[11244,11332,"then you can be super"],[11332,11457,"successful when you grow up."],[11473,11528,"I promise."],[11561,11599,"I will."],[11599,11686,"Just don't leave."],[11720,11786,"Chris!"],[11811,11886,"Hailey!"],[11999,12082,"Chris!"],[12132,12212,"Hailey!"],[13046,13133,"I'm gonna work hard,"],[13175,13271,"just like I promised."],[13367,13596,"And when I grow up, I'm gonna marry you."],[14368,14556,"Welcome back, Mr. Robinson."],[15069,15198,"It's been 18 years."],[15252,15373,"Hailey, where have you been?"],[15494,15540,"Boss,"],[15569,15707,"are your sinuses acting up again?"],[17087,17142,"Boss,"],[17142,17258,"I got the best doctor"],[17258,17400,"in the country to take a look at you."],[17400,17525,"She's cured so many patients,"],[17525,17625,"people started calling her"],[17625,17738,"Dr. Elixir."],[17746,17834,"Dr. Elixir?"],[17997,18189,"It's a pretty lofty title, huh?"]],"6":[[813,1021,"Those eyes seem familiar."],[1530,1622,"Please, sit."],[2068,2339,"Could she be Hailey?"],[2377,2414,"So,"],[2444,2515,"I looked over your"],[2515,2577,"blood work and there's"],[2577,2690,"nothing too serious going on."],[2702,2819,"You just need an allergy shot and you"],[2819,2865,"should be fine"],[2865,2927,"in a few days."],[2982,3107,"I'm sorry, hold on one second."],[3107,3224,"Did you say a few days?"],[3478,3520,"See,"],[3536,3641,"I've had seasonal"],[3641,3749,"allergies my entire life,"],[3749,3899,"so how are you going to cure it"],[3908,4029,"in a few days?"],[4091,4262,"Just give it a shot, okay?"],[4291,4354,"You never know."],[4550,4671,"Now please, stand up."],[5180,5321,"And pull down your pants."],[5384,5522,"I'm sorry, pull down my pants."],[5522,5655,"Yeah, that's not gonna happen."],[5693,5730,"Yes,"],[5730,5843,"the shot needs to be administered"],[5843,5926,"to the gluteal muscle"],[5926,6026,"for the best impact."],[6068,6131,"What?"],[6156,6239,"No, I don't."],[6268,6368,"Sir, I don't have all day."],[6418,6456,"I..."],[6464,6544,"Okay."],[6815,6861,"Ah!"],[6998,7161,"She's only the second girl"],[7161,7282,"to pull down my pants."],[7394,7461,"All done."],[8070,8291,"Your fiancé sent you flowers again."],[8316,8420,"The wedding's coming up soon,"],[8420,8466,"isn't it?"],[8487,8662,"Lucy, I'm still with the patient."],[8721,8867,"Oh, sorry."],[8896,9050,"Pardon my intrusion."],[9234,9363,"Now, she reminds me of Hailey,"],[9363,9555,"but there is no way"],[9555,9659,"this brute is my Hailey!"],[9830,9934,"Just come back next year"],[9934,10005,"for another shot."],[10085,10226,"I ain't coming back here."],[10865,10977,"Hey, who was that?"],[11081,11194,"I feel like I've seen his"],[11194,11286,"face somewhere."],[11357,11415,"Beats me."],[11436,11498,"He's probably just"],[11498,11590,"another tech founder."],[11590,11707,"They're everywhere these days."],[11836,11941,"Sure seems like it."],[12007,12195,"Oh, and about your granny."],[12233,12291,"We looked"],[12291,12491,"into the reasons behind her relapse,"],[12516,12796,"and it looks like your stepmom"],[12796,12954,"and stepsister paid her a visit"],[12954,13150,"and something they said to her"],[13158,13254,"sent her into a fit."],[13254,13300,"What?"],[13417,13563,"I can't believe they would rile her"],[13563,13646,"up like that."],[13705,13822,"I'm gonna find them and..."],[13847,13997,"I'm gonna give them a piece of my mind."]],"7":[[1789,1851,"Hello?"],[2010,2072,"Hailey!"],[2081,2181,"Where the heck are you?"],[2181,2356,"Is your granny all better now?"],[2865,3023,"Boss, we found Hailey."],[3048,3144,"She's here in LA."],[3199,3274,"You found Hailey?"],[3328,3407,"Hold on a second."],[3486,3607,"She hasn't contacted me,"],[3607,3766,"so are you sure that it's actually Hailey?"],[3766,3866,"As sure as it gets."],[3878,3999,"She used the card you gave her"],[4024,4133,"at a local mall."],[4137,4312,"She... From 18 years ago,"],[4312,4391,"that card that I gave her?"],[4425,4471,"She used it?"],[4562,4637,"Okay!"],[4746,4808,"Where does she live?"],[4808,4917,"I want to go see her right now."],[4938,5100,"I'm confirming her address right now."],[5100,5196,"I'll have an update soon."],[5230,5276,"Great."],[5397,5484,"I can't believe that"],[5505,5634,"this is finally happening."],[5705,5809,"Hailey, I found you."],[6556,6635,"Mom, we did it."],[6673,6881,"We just had to ask Hailey's grandmother"],[6881,6948,"for her birthday"],[6969,7073,"and now we're millionaires."],[7273,7444,"But I really wonder where that bitch"],[7444,7636,"found such a cozy rich benefactor."],[7674,7795,"I mean, the guy's been sending"],[7795,7941,"her money every year."],[7999,8120,"Good thing she lost her memories"],[8120,8199,"in that car accident."],[8237,8366,"She probably doesn't even know herself."],[8529,8596,"It's her loss."],[8979,9259,"But Mom, that's Hailey's card, right?"],[9263,9459,"Isn't that like fraud?"],[9889,10022,"Time to go home, granny."],[11932,12020,"How that little brat"],[12045,12132,"gets some rich family"],[12162,12228,"to support her?"],[12278,12337,"Whatever."],[12420,12554,"Now that she's lost her memory,"],[12604,12733,"all this money is ours."],[13225,13405,"Oh, Bella, don't fret."],[13434,13521,"She doesn't even know where"],[13521,13634,"the money's coming from."],[13663,13830,"If she can't prove who the donor is,"],[13872,14026,"no one's going to believe her."],[14164,14243,"Bella?"],[14397,14535,"What did you say to my granny?"],[14535,14693,"Whatever you did made her relapse."],[14969,15077,"Hailey, you're just going to come"],[15077,15169,"in here and start yelling?"],[15198,15294,"I thought you'd finally"],[15294,15373,"grow some manners"],[15373,15457,"after all these years."],[15502,15623,"Save the temper tantrum."],[15648,15790,"We probably spent more than a million"],[15790,15949,"bucks on your old granny's surgeries."],[16011,16145,"Yeah, I'd rather your granny just"],[16166,16224,"kick the bucket"],[16262,16366,"so we stop wasting our money."],[16458,16508,"Shut up."],[16537,16612,"I've already told you"],[16612,16674,"I'm going to pay you"],[16674,16745,"back and that's exactly"],[16745,16820,"what I'm going to do."],[16841,16900,"Yeah, right."],[16954,17121,"You're just a useless farm girl"],[17146,17233,"living off food"],[17233,17346,"stamps and scholarships."],[17379,17530,"Okay, so we used to get financial help,"],[17555,17609,"so what?"],[17625,17721,"Now I'm the best doctor"],[17721,17884,"in town and I'll pay back that debt"],[17884,17934,"in no time."],[17963,18101,"Oh my God, Hailey,"],[18101,18234,"if wearing a fancy coat"],[18234,18314,"makes you a doctor,"],[18314,18380,"then what do"],[18380,18489,"these designer clothes make me?"],[18522,18664,"The richest woman on earth?"],[18868,18939,"Come on,"],[18964,19044,"just be a good girl"],[19044,19210,"and marry Davis and do it quickly"],[19210,19340,"before your granny kills over."],[19365,19481,"I already promised Davis'"],[19481,19577,"family that you'd marry him."],[19594,19652,"In return,"],[19669,19832,"he'll pay Edith's medical bills."],[19861,19928,"Can we quit it"],[19928,20040,"with this whole Davis thing?"],[20070,20224,"I'm already engaged to Hardy."],[20424,20495,"You really think"],[20495,20599,"you're going to marry Hardy?"],[20633,20774,"Hailey, he's in love with me."],[20833,20950,"I'm the one marrying him."],[21029,21229,"Just face it and tie the knot"],[21229,21325,"with that cripple Davis."],[21513,21705,"Be a good girl and marry that cripple."],[21721,21855,"Or your granny's dead."]],"8":[[1351,1526,"Boss, it's been confirmed."],[1526,1680,"This is Hailey’s address."],[1768,2006,"Hailey, it's been 18 years."],[2006,2181,"I am so excited to see you again."],[2210,2335,"Are you gonna feel the same way"],[2335,2410,"about me?"],[2756,2952,"Arthur, how do I look?"],[2965,3111,"Dashing, successful."],[3224,3319,"Need to make sure I make"],[3319,3415,"a good impression."],[3453,3591,"He's the richest man in the world,"],[3624,3782,"and he's blushing like a little boy"],[3824,3937,"about to talk to his crush."],[3966,4137,"Boss, you look dashing as always."],[4429,4471,"But-"],[4471,4550,"She's not gonna like"],[4637,4725,"reject me or anything."],[4725,4838,"I'm not gonna be disappointed."],[4950,5000,"Of course not."],[5134,5372,"But sir, it has been 18 years."],[5497,5630,"Are you sure Ms. Hailey"],[5630,5751,"still remembers you?"],[5839,5993,"What if she's already married?"],[5993,6168,"No, no."],[6193,6260,"She wouldn't get married."],[6260,6360,"We made a promise"],[6435,6514,"long time ago."],[6569,6673,"Not gonna happen."],[6906,7061,"Hailey, I'm back."],[7090,7219,"I can't wait to see you."],[7678,7757,"Boss,"],[7832,8016,"we might be too late."],[8546,8596,"No,"],[8692,8792,"that's impossible, Hailey."],[8792,8913,"Hailey would ever get married."],[8967,9150,"So the girl Mr. Robinson's"],[9150,9250,"had his heart set"],[9250,9484,"on for 18 years is getting married?"],[9505,9592,"Don't tell me he's"],[9592,9697,"about to crash the wedding."],[9780,9838,"Now,"],[9838,9918,"if anyone present"],[9951,10005,"would object"],[10005,10143,"to this happy couple's union,"],[10197,10414,"speak now or forever hold your peace."],[10481,10648,"If not, you may kiss the bride."],[11077,11148,"I object!"],[11574,11653,"Hailey,"],[11757,11857,"do you remember me?"]],"9":[[25,91,"I object!"],[917,1013,"Do you remember me?"],[1117,1184,"Who are you?"],[1201,1288,"I'm Chris."],[1463,1597,"We spent summer vacation"],[1597,1647,"together when we"],[1647,1718,"were ten years old."],[1760,1960,"I sent you like a hundred"],[1960,2093,"letters and I gave you money"],[2093,2168,"for your grandmother's"],[2168,2243,"medical bills."],[2423,2569,"You don't remember me?"],[2619,2677,"Chris?"],[2777,2869,"Chris, who?"],[3003,3236,"Oh, so you're Chris."],[3244,3382,"This must be the rich sucker"],[3382,3541,"who's been sending Hailey money!"],[3578,3824,"Holy shit, he's good-looking and"],[3824,4037,"loaded. But why's a guy like him so down"],[4037,4200,"bad for that skank Hailey?"],[4250,4354,"Hold on a second."],[4396,4596,"You don't recognize me at all."],[4683,4833,"You got nothing to say to me?"],[5226,5363,"Look, I don't give two fucks"],[5363,5442,"who you are."],[5472,5605,"Okay, this is my wedding day."],[5647,5789,"So get the hell out before you make"],[5789,5864,"a damn scene."],[5880,5972,"Okay, hold on a second."],[5989,6122,"Just give me a minute, all right?"],[6439,6569,"You got nothing to say to me."],[6719,6823,"You don't remember me at all?"],[7386,7469,"All right, I'm sorry,"],[7469,7599,"but I didn't mean to interrupt."],[8579,8717,"Your mom's a home wrecker who"],[8717,8879,"seduced my sleazeball father."],[8900,9042,"And now you've taken my spot as"],[9042,9180,"heiress and stolen my fiancé."],[9205,9284,"Did you just think I was"],[9284,9363,"going to sit back and let"],[9363,9459,"you enjoy your happy day?"],[9505,9580,"Fat chance."]],"10":[[4,95,"That face..."],[95,312,"I could swear I've seen her before."],[362,483,"But where?"],[838,875,"Crap."],[875,992,"Why is that bitch Hailey here?"],[1038,1117,"I can't let Chris"],[1117,1222,"find out that's his"],[1222,1284,"childhood sweetheart."],[1292,1422,"Excuse me, what are you doing here?"],[1443,1543,"No one invited you."],[1543,1651,"My fiancé's getting"],[1651,1747,"married and not to me."],[1772,1876,"Why do you think I'm here?"],[1964,2027,"So Hailey stole another"],[2027,2114,"woman's man?"],[2156,2314,"When did she become like this?"],[2652,2752,"Everybody knows that"],[2752,2827,"my mother arranged"],[2827,3003,"this marriage when she was still alive."],[3065,3249,"The deal was that Hardy"],[3249,3378,"would marry the family heiress,"],[3407,3503,"and that's not you."],[3616,3791,"Don't worry, I'm not a home wrecker."],[3816,3903,"I didn't realize"],[3903,3953,"stealing other"],[3953,4049,"people's husbands ran"],[4049,4116,"in the family."],[4287,4371,"Not my fault."],[4371,4554,"You and your stupid mom are useless."],[4608,4754,"If you can't satisfy your men,"],[4792,4938,"you've only got yourselves to blame."],[4942,4996,"Yeah."],[5030,5196,"Look, I know you like me,"],[5251,5388,"but I was only being nice to you"],[5388,5509,"on account of your mom dying."],[5555,5601,"Okay?"],[5613,5718,"Once I saw your sister,"],[5739,5860,"we fell in 