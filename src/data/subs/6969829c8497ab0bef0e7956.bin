{"1":[[429,550,"Tonight is the night Sean"],[550,713,"and I renew our blood oath."],[713,813,"I've been Sean's thrall"],[813,984,"for the last three years,"],[984,1172,"ever since he saved me from the grasp of"],[1172,1284,"rogue vampires."],[1805,1885,"Sean is back."],[2485,2569,"Oh, hey, Freddie."],[2569,2698,"I'm pretty sure Sean is back."],[2719,2836,"His car just pulled up."],[2961,3053,"Scarlett, dear,"],[3053,3215,"maybe it's best if you"],[3215,3349,"just go to your room tonight"],[3349,3457,"and rest."],[3511,3561,"Why?"],[3561,3620,"What's wrong?"],[4129,4208,"Give me your umbrella."],[4208,4304,"I'll go greet him."],[5809,5926,"I've suspected he has taken"],[5926,6051,"on a new lover."],[6072,6168,"The truth has whispered"],[6168,6272,"to me for weeks."],[6272,6331,"I..."],[6385,6544,"just didn't want to believe it."],[6544,6623,"But, Sean..."],[6752,6898,"why tonight of all nights?"],[7102,7165,"Sean,"],[7190,7265,"it's so good."],[7323,7374,"I'm coming."],[7419,7499,"Sean."],[7691,7770,"Chelsea?"],[7870,8008,"Hey, Chelsea."],[8579,8646,"Chelsea."],[8687,8733,"Chelsea!"],[8733,8825,"Chelsea, wake up!"],[8825,8888,"Sean, wait!"],[8888,8963,"Don't just sit there!"],[8963,9054,"Call an ambulance!"],[9129,9188,"No!"],[9446,9626,"Did you forget what today is?"]],"2":[[917,1046,"I'm running out of time."],[1076,1163,"I have to get to Sean"],[1163,1280,"before the curse strikes."],[1668,1743,"What? No-"],[1780,1856,"What are you doing?"],[2398,2485,"Wait, open up!"],[2485,2598,"I need to talk to Sean!"],[2598,2723,"It's almost midnight!"],[2861,2944,"Sean!"],[3244,3378,"Did Scarlett just call my name?"],[3832,3924,"No, no,"],[3962,4083,"no!"],[4141,4245,"Sean."],[4546,4654,"Sean,"],[4679,4796,"Sean, baby..."],[4909,5025,"Chelsea, you're awake."],[5121,5238,"You scared me."],[5588,5780,"I didn't know it was possible to pass"],[5780,5930,"out from an orgasm."],[6285,6360,"Sean."],[7228,7303,"Please,"],[7574,7741,"Sean isn't coming."],[7907,8108,"Is Sean gonna let me die?"],[10377,10502,"I know Sean is my master,"],[10556,10756,"and he's entitled to taking on as many"],[10756,10881,"lovers as he wants."],[10952,11232,"But Sean, even if you love another,"],[11232,11403,"I never thought you'd forget the night"],[11403,11519,"of our blood oath."],[11586,11803,"When my life hangs in the balance."]],"3":[[500,592,"No, please!"],[625,675,"Please!"],[684,796,"Someone save me!"],[1443,1564,"Disgusting."],[3165,3294,"What are your manners?"],[3357,3582,"I just saved your life, you say thank you."],[3745,3799,"Thank..."],[3891,4029,"Thank you, Mr. Vampire."],[4187,4366,"I don't know how to repay you."],[4508,4646,"Then become my thrall."],[4829,4992,"Join a blood oath with me,"],[4992,5130,"and you'll be under my protection."],[5276,5380,"As long as I'm around,"],[5380,5501,"no one can hurt you again."],[6427,6519,"Master,"],[8049,8170,"what does that hurt?"],[8241,8391,"It's just a taste of what will happen"],[8516,8591,"if you break the oath."],[8783,8858,"Every year,"],[8929,9063,"on the same day that I mark you,"],[9096,9225,"by the stroke of midnight,"],[9309,9446,"we'll have to renew the blood oath,"],[9446,9505,"okay?"],[9676,9788,"What happens if we don't?"],[9939,10122,"Then you will suffer unimaginable pain"],[10122,10210,"for three days."],[10276,10389,"Every day worse than the last."],[10810,10873,"You might die,"],[10990,11048,"but if you don't,"],[11048,11202,"you might wish that you did."],[11348,11532,"Did you change your mind, Scarlett?"],[11953,12007,"You..."],[12091,12212,"you saved my life."],[12249,12320,"In return,"],[12416,12512,"I'll become your thrall."],[12629,12746,"I won't leave you..."],[12808,13017,"Unless, you don't want me anymore."],[13813,13909,"And from now on,"],[13909,14030,"you will be mine"],[14251,14364,"and mine alone."],[21379,21554,"You no longer want me, Sean."],[21654,21821,"So I'll no longer be yours."],[22188,22263,"Prince Alaric,"],[22368,22464,"I agree to your terms."],[22555,22651,"In three days time,"],[22701,22910,"the bond can be broken, and..."],[22981,23123,"I will become your thrall."]],"4":[[496,588,"Scarlett,"],[621,813,"what made you change your mind?"],[859,1051,"Three years after my blood oath to the"],[1051,1217,"vampire lord Sean Bathory,"],[1255,1343,"he left me for dead."],[1476,1647,"All because a new human lover he had"],[1647,1789,"brought home had fainted."],[1889,2060,"Now, I come to you,"],[2060,2135,"Prince Alaric,"],[2202,2302,"to be my new protector."],[2761,2973,"What do you mean he left you for dead?"],[3048,3111,"Meaning,"],[3199,3319,"he forgot about our blood oath."],[3382,3511,"In order to break our bond,"],[3545,3620,"I need to endure"],[3620,3766,"the curse three times."],[3849,3995,"Last night was the first."],[4058,4187,"I only have two more,"],[4187,4404,"so I'm closer than you think."],[4875,5017,"Then we have a deal."],[5050,5180,"When the bond is broken,"],[5180,5288,"I will be your new protector."],[5380,5593,"No vampire will ever hurt you then."],[5780,5860,"Thank you,"],[5893,5997,"Prince Alaric."],[6131,6277,"But can I ask you a question?"],[6423,6481,"You may."],[6602,6681,"Why me?"],[6802,6977,"You're the most powerful vampire"],[6977,7057,"on the west coast."],[7098,7173,"You can have any"],[7173,7319,"human you want, so..."],[7424,7499,"why me?"],[7570,7678,"That's for me to know"],[7678,7799,"and for you to find out."],[7841,7920,"I will send a car"],[7920,8066,"to you in two nights' time."],[8562,8754,"Survive this, Scarlett."],[8804,8875,"Alright?"],[8908,9079,"You're stronger than this curse."],[9184,9238,"I will."],[9417,9496,"There's still so much"],[9522,9634,"that I want to do with my life."],[9755,9943,"I won't give up that easily."],[11257,11348,"Scarlett Russell."],[11440,11599,"She really doesn't remember me."],[13221,13309,"I want you,"],[13380,13513,"I want you to be my one and only,"],[13513,13613,"Chelsea."],[14009,14147,"And from now on, you are mine,"],[14285,14368,"and mine alone."],[15094,15190,"Tell me,"],[15219,15377,"who pleases you more?"],[15411,15444,"Me,"],[15565,15669,"or that slave?"],[15794,15874,"Don't mention her."],[15920,16057,"She doesn't even compare."],[16116,16266,"You're the one I'm going to turn."],[16291,16416,"She's just my thrall."],[16458,16649,"The curse burned through my veins."],[16712,16896,"But your betrayal cut deeper."],[16966,17162,"I loved you once, Sean."],[17162,17275,"But now,"],[17275,17500,"I'll do whatever it takes to leave."],[17555,17726,"Or I'll die trying."]],"5":[[66,120,"Hey, thrall."],[229,308,"I see you."],[383,458,"Come over here."],[1872,1935,"Shit."],[1935,2047,"I only have ten minutes"],[2047,2156,"until the curse hits."],[2210,2264,"Babe,"],[2285,2464,"I've never seen you drink blood before."],[2464,2560,"What happens when you do?"],[2869,2923,"Well,"],[3023,3207,"you will see me at my full potential."],[3286,3461,"But you're already so big and strong."],[3461,3603,"I can't imagine what you'll feel like"],[3603,3691,"when you're full."],[3724,3782,"Drink her blood."],[3782,3874,"I want to watch."],[3970,4112,"I can't let Sean drink my blood."],[4166,4346,"Not if I want to be free."],[4433,4512,"As you wish."],[5009,5088,"-No! -No."],[5201,5242,"Uh,"],[5276,5405,"don't drink from her neck."],[5459,5576,"Make her cut herself like"],[5576,5722,"the blood slave she is."],[5730,5893,"Biting is reserved for me."],[6214,6356,"A vampire's bite is a strong"],[6356,6452,"aphrodisiac, okay?"],[6452,6519,"I don't want"],[6519,6660,"Scarlett to feel any of the pain."],[6835,6973,"And I don't want you that close to her."],[7061,7111,"I'm your mate"],[7111,7244,"and she's just your thrall."],[7311,7394,"That's what you said."],[7937,7991,"Please,"],[7991,8112,"Sean, not tonight."],[8112,8233,"I'll do it first thing tomorrow."],[8904,8950,"Chelsea,"],[9092,9205,"why did you just hit Scarlett?"],[9242,9467,"How dare she reject her master's request"],[9467,9538,"for blood?"],[9576,9730,"You told me it was against the rules."],[10564,10627,"Scarlett,"],[10739,10844,"have I spoiled you..."],[10919,10994,"too much?"],[12570,12754,"The old Sean is gone, Scarlett."],[12825,12921,"Even if he's standing"],[12921,13038,"right in front of you,"],[13071,13242,"his heart has already moved on."],[15778,15844,"Here,"],[15899,16011,"let me heal you."],[16136,16191,"It's fine."],[16316,16487,"Please enjoy the rest of your evening."]],"6":[[600,700,"Scarlett is in trouble."],[713,821,"I gotta go check on her."],[821,884,"No."],[921,1105,"She's just trying to get your attention."],[1151,1238,"Don't fuss over it."],[1301,1376,"Scissors."],[1430,1526,"Where's my scissors?"],[1526,1593,"Ah!"],[1747,1826,"Sean,"],[1868,1918,"drink."],[1960,2143,"I want to see you at your strongest,"],[2243,2385,"and then I want you to fuck me."],[4483,4596,"I can take it."],[4642,4771,"It'll be over soon."],[5801,5880,"I can do this."],[5922,6006,"There's one more strike"],[6006,6101,"with the curse."],[6131,6235,"Then I'm free."]],"7":[[1822,1918,"My lady,"],[1918,2047,"the bitch is still alive."],[2189,2285,"Sean promised to"],[2285,2398,"turn me in one month."],[2460,2590,"He insists that her blood is"],[2590,2719,"especially potent,"],[2748,2894,"and my first drink as a vampire"],[2894,3040,"must be from her."],[3094,3194,"Which means,"],[3194,3374,"that bitch will be around for"],[3374,3507,"another damn month."],[3603,3670,"No,"],[3712,3824,"that's too long."],[3874,3933,"I'm not gonna"],[3933,4054,"let that bitch seduce him."],[4346,4421,"Alice,"],[4529,4717,"I can tell you hate her too."],[4800,4884,"Any chance we can"],[4884,5030,"get rid of her sooner?"],[5067,5134,"What if..."],[5271,5438,"there was an accident today..."],[5513,5701,"forcing Master Sean to turn you sooner?"],[5910,5993,"Here's the idea."],[7102,7198,"Just one more night,"],[7336,7407,"and then I'm gone."],[7770,7836,"Gone where?"],[7953,8020,"Why are you packed?"],[8020,8124,"Scarlett, where are you going?"]],"8":[[12,62,"Why are you packed?"],[62,150,"Scarlett, where are you going?"],[663,792,"So Chelsea was telling the truth?"],[850,905,"You shoved her"],[942,996,"down the stairs"],[1017,1096,"and that's why you're running"],[1096,1176,"away from from me."],[1176,1247,"What?"],[1330,1488,"I did no such thing!"],[1518,1630,"Sean!"],[1639,1751,"Help me."],[2002,2189,"She almost died because of you."],[2189,2344,"I had to turn her ahead of schedule."],[2344,2427,"This is all your fault."],[2427,2489,"You're coming with me."],[2527,2656,"No, Sean, wait."],[3048,3174,"Your little act of jealousy"],[3211,3340,"almost cost Chelsea her life."],[3374,3449,"If I didn't get there in time,"],[3449,3541,"she'd be dead."],[3541,3620,"So you are"],[3620,3741,"giving her your blood."],[3791,3903,"Act of jealousy?"],[4008,4187,"Do you not know me at all?"],[4350,4466,"All I have ever wanted was"],[4466,4633,"for you to be happy."],[4692,4833,"I would never hurt anybody,"],[4833,4913,"let alone someone"],[4913,4992,"you care about."],[5050,5138,"Then why"],[5138,5280,"are you running away from me?"],[5280,5463,"Because I'm not the one you want."],[5597,5718,"I'm not going to stay here"],[5718,5847,"and watch you love someone else."],[6160,6227,"Let go."],[6435,6514,"Stop."],[7111,7236,"Scarlett, I'm sorry."],[7236,7340,"Sean,"],[7353,7449,"help me."],[7532,7607,"Help me."],[8158,8233,"You're lying to me..."],[8329,8500,"You are lying to try to get away from me!"],[8500,8600,"Sean, please!"],[8621,8708,"Let me go!"],[8950,9029,"No."],[9484,9567,"No!"],[10097,10214,"She's a newborn vampire."],[10281,10406,"I'm going to die!"],[10431,10564,"Please don't do this!"]],"9":[[1184,1297,"You aren't gonna die,"],[1343,1434,"Scarlett."],[1476,1564,"Not while I'm here."],[1564,1643,"I'll make sure of it."],[1768,1826,"Sean,"],[1847,1935,"look at me."],[2035,2235,"Feel how cold my body is."],[2310,2410,"I've already given you"],[2410,2548,"so much blood last night."],[2594,2740,"I can't do this."],[2932,3011,"Sean,"],[3044,3203,"I need her blood."],[3228,3315,"She pushed me."],[3315,3411,"She caused this."],[3432,3712,"Sean, please believe me."],[3712,3853,"After everything I have"],[3853,4020,"done for you these past three years,"],[4079,4191,"I am begging you."],[4237,4354,"Please don't do this."],[4771,4884,"She can have animal blood."],[4992,5146,"All draining me will do is relieve her"],[5146,5230,"thirst faster."],[5267,5380,"But if she drinks me dry,"],[5430,5609,"even you can't save me."],[5885,5976,"Give me her blood."],[5997,6068,"Hold her down,"],[6089,6160,"Sean."],[6231,6331,"Why are you stopping me?"],[6402,6519,"What are you doing, Sean."],[6694,6810,"No,"],[6873,7036,"please, Sean, let me out."],[7044,7148,"You promised."],[7148,7357,"You swore that if you were around,"],[7357,7507,"nobody would ever hurt me again."],[7582,7682,"You don't remember?"],[8212,8316,"Then become my thrall."],[8362,8516,"Join a Blood Oath with me,"],[8516,8637,"and you'll be under my protection."],[8679,8775,"And no other vampire"],[8775,8846,"can touch you."],[9071,9271,"It hurts, it's driving me crazy!"],[9321,9438,"Didn't you say you love me?"],[9567,9709,"How can you just watch me suffer?"],[9738,9868,"She did this to me!"],[10239,10331,"Is this how you treat"],[10331,10414,"somebody who loves you?"],[10506,10585,"Please."],[10648,10735,"I'm begging you."],[10856,10994,"Please, Sean!"],[10994,11077,"Save me!"]],"10":[[946,1005,"Oh, no"],[1017,1134,"no..."],[1163,1247,"No!"],[1718,1785,"Scarlett."],[1851,2056,"You're just gonna have to bear it, okay?"],[2110,2235,"You shouldn't have hurt Chelsea."],[2531,2610,"I win, bitch."],[3824,4004,"Sean, you're a liar."],[4058,4187,"I hate you."],[4250,4341,"What did you just say?"],[4679,4813,"Well, darling,"],[4842,5000,"you're one of us now."],[5059,5230,"Welcome to the world of vampires."],[5271,5384,"I can feel it."],[5488,5597,"I'm full of power."],[5926,6068,"Full of need."],[7699,7845,"Sean, tell her to get out."],[7845,7974,"I don't want her to watch"],[7974,8095,"while you fuck me."],[8166,8258,"No, you stay."],[8416,8633,"She needs to know who her masters are."],[9367,9584,"Sean, please don't make me stay."],[10356,10477,"Sean..."],[10915,11023,"I'm running out of time."],[11795,11861,"I said stay!"],[12103,12174,"That's an order."],[12687,12829,"Even if I die tonight,"],[12879,13008,"I'm leaving you, Sean."],[13063,13242,"At least I'll finally be free."],[13304,13542,"Loving you was the slowest death of all,"],[13571,13684,"and I wish I'd never"],[13684,13826,"laid eyes on you."]],"11":[[2239,2385,"Had I been a minute late,"],[2385,2494,"you would have drowned."],[2531,2590,"You are"],[2631,2723,"very lucky to be alive."],[3678,3770,"They're gone."],[3941,4054,"I'm finally free."],[4491,4537,"Thank you"],[4637,4754,"for saving me, your highness."],[4825,4954,"Just Alaric is fine."],[5238,5392,"Like we agreed upon..."],[5609,5726,"I'm now your thrall."],[7611,7724,"We can talk about that later."],[7782,7941,"For now, you need rest."],[9250,9392,"She still doesn't remember."],[9484,9597,"She still doesn't know."],[9705,9813,"She's my mate."]],"12":[[1126,1209,"Good morning, darling."],[1334,1397,"How are you feeling?"],[1505,1747,"Last night was amazing."],[1889,2010,"I feel like I've been born again."],[2097,2156,"But,"],[2206,2335,"maybe because I've turned,"],[2364,2464,"my body still hurts."],[2686,2781,"Could I..."],[3023,3140,"You wanna call Scarlett again?"],[3566,3678,"She must be weak..."],[3787,3895,"Okay, after last night-"],[4175,4258,"Please."],[4637,4754,"Alright, princess."],[4800,4900,"Whatever you want."],[5030,5125,"Frederick."],[5555,5647,"Yes, Master."],[5684,5772,"How's Scarlett doing?"],[5834,5939,"She had all night to recover."],[5993,6189,"Master, I apologize,"],[6189,6322,"but Ms. Scarlett has"],[6439,6510,"disappeared."],[6589,6744,"All her things are gone, too."]],"13":[[87,145,"What?"],[200,308,"She's my thrall."],[308,429,"How dare she go anywhere"],[429,567,"without my permission?"],[567,734,"Master, when you first brought"],[779,934,"Ms. Scarlett to this castle,"],[992,1184,"you would have never called her"],[1226,1305,"your thrall."],[1334,1434,"What changed?"],[1514,1651,"Good day, sir."],[1693,1743,"Hey!"],[1910,2056,"How dare you talk to us like that?"],[2364,2444,"Hey."],[2523,2581,"She'll be back."],[2665,2761,"She can't go anywhere"],[2806,2907,"without my protection."],[3003,3078,"By tomorrow,"],[3153,3257,"she will have learned her lesson,"],[3307,3365,"and she'll come crawling"],[3365,3486,"back to me for forgiveness."],[3549,3595,"You're right."],[3699,3858,"A slave that doesn't know her place?"],[3941,4074,"If she dies, who cares."],[4346,4504,"Let's not talk about her."],[4717,4821,"Let me show you"],[4921,5017,"some real pleasure."],[5305,5413,"I just remembered."],[5505,5697,"I have some matters to attend to."]],"14":[[450,704,"Sean, you've been in here all day."],[1484,1576,"What are you staring at?"],[1722,1868,"Oh, you must be tired."],[1868,2014,"I've drawn you a bath and prepared"],[2014,2085,"some fresh blood."],[2139,2218,"Tell me when you're done,"],[2218,2335,"I'll help you get dressed."],[2460,2606,"Scarlett, you don't have to do all that,"],[2606,2644,"okay?"],[2736,2836,"Just leave it for the maids."],[2836,2977,"I know, but I want to."],[3032,3190,"That's what we silly humans do."],[3294,3445,"This is how we show our love."],[4216,4291,"Hello?"],[4396,4483,"Did you hear me?"],[4600,4662,"I didn't."],[4733,4804,"What did you say?"],[4904,5113,"I said I'm starving."],[5221,5321,"I want blood."],[5321,5413,"Fresh blood."],[5413,5551,"None of that animal crap."],[5851,5910,"Yeah, I got it."],[5910,5993,"I'll go order some from"],[5993,6106,"the Royal Blood Lab, okay?"],[6181,6222,"Okay."]],"15":[[392,471,"Damn it."],[1413,1539,"Allow me to help you."],[2677,2844,"You can put me down now, Prince."],[2923,3007,"I mean, Alaric."],[3536,3636,"What are you doing up and about?"],[3699,3770,"You're still weak."],[3770,3845,"You need rest."],[3945,4116,"I was just trying to make myself useful."],[4187,4237,"Why?"],[4283,4371,"You're my guest here."],[4371,4500,"You do not need to do any work."],[4608,4700,"Can I be frank?"],[4842,5025,"I'm just a little confused."],[5025,5226,"You first asked me to become your thrall,"],[5246,5426,"but now it's been a week and you"],[5426,5543,"still won't mark me."],[5605,5789,"Are you having second thoughts?"],[5830,5976,"The Blood Oath is sacred,"],[5976,6072,"and you're not ready."],[6202,6352,"And I can tell in your heart you do not"],[6352,6448,"want to be my thrall."],[6519,6602,"I'm a human."],[6660,6785,"What choice do I have?"],[6831,6981,"Without a Vampire master,"],[6981,7094,"I can't go anywhere."],[7127,7294,"I can't even walk out of your castle."],[7382,7444,"I see."],[7553,7678,"Is there somewhere you want to go?"],[7732,7811,"Something you want to do?"],[8103,8262,"You can tell me anything, Scarlett."],[8391,8429,"Well,"],[8516,8600,"I've always wanted to"],[8600,8717,"work at the Blood Lab."],[8833,9004,"I feel like there's so much I can learn"],[9004,9192,"about vampires and humans,"],[9305,9451,"but humans aren't allowed"],[9451,9505,"to work there."],[9505,9580,"Consider it done."],[9672,9722,"Wait, what?"],[9751,9830,"Really?"],[9884,9997,"Under one condition."],[10155,10281,"Of course, I'm ready."],[10685,10777,"No, Scarlett."],[11015,11194,"I want you to come to the ball with me"],[11290,11344,"as my date."]],"16":[[87,187,"It's been a week."],[362,437,"Where is she?"],[684,759,"What the hell is that?"],[850,1076,"The Venture family has invited you to"],[1076,1242,"a banquet tomorrow night."],[1242,1359,"You tell them I'm busy, okay?"],[1472,1697,"The Venture family has become"],[1697,1906,"increasingly powerful with their"],[1906,2085,"allegiance to Prince Alaric."],[2085,2210,"It will be a bad"],[2210,2435,"idea to turn them down at this time."],[2435,2481,"All right, fine."],[2481,2560,"Go wake Chelsea up."],[2560,2669,"You tell her to prep my outfit."],[2719,2769,"I guess I'll go."],[2840,3144,"Ms. Chelsea has left to go shopping."],[3278,3428,"She said she won't be back"],[3453,3553,"until morning."],[3670,3791,"Shopping again?"],[3816,3978,"Fuck, she spent three million dollars"],[3978,4045,"this week."],[4045,4124,"Three million."],[5284,5355,"Sean."],[5634,5839,"I've organized your clothes by color."],[5839,6035,"Now it'll be much easier for you to pick"],[6035,6189,"an outfit for different occasions."],[6214,6306,"Scarlett."],[7557,7774,"Scarlett, how could this have happened?"],[8016,8149,"Please come back."],[8195,8283,"Please come back."]],"17":[[2314,2360,"You look..."],[2360,2452,"Do I look okay?"],[2690,2773,"You look beautiful."],[3236,3382,"I've never attended something"],[3382,3490,"this fancy before."],[3528,3674,"I'm worried I'll embarrass you."],[3712,3816,"Embarrass me?"],[3866,3916,"No."],[3958,4112,"You are going to make every man"],[4112,4204,"wish they were me."],[5284,5572,"Sorry, I've never worn heels before."],[5793,5922,"Then let me carry you to the car."]],"18":[[2072,2218,"Watch your etiquette, Chelsea."],[2243,2456,"Okay, do not embarrass me."],[2456,2515,"Yeah, sure."],[2535,2594,"Whatever."],[3044,3123,"Look who's here."],[3144,3274,"Darling, let's greet our guest."],[3340,3478,"Count."],[3507,3578,"Hi."],[3787,4012,"Oh, the great Lord Bathory"],[4058,4312,"finally graces us with his presence."],[4362,4579,"Did the first twenty invitations get lost in"],[4579,4650,"the mail?"],[4650,4754,"But darling,"],[4754,4854,"he's not here for you."],[4900,5084,"It's because Prince Alaric is coming."],[5084,5255,"Isn't that right, Lord Bathory?"],[5347,5417,"Of course not."],[5447,5580,"We are delighted-"],[5580,5655,"We're here."],[5655,5789,"What more do you want from us?"]],"19":[[133,166,"What a"],[275,437,"wonderful mate you have there,"],[437,504,"Lord Bathory."],[504,667,"Very classy."],[1142,1317,"Chelsea, what the hell are you doing?"],[1355,1413,"What?"],[1484,1639,"They were rude to you first."],[1639,1705,"Who cares?"],[1705,1801,"You're a lord."],[1856,1947,"So are they."],[2214,2327,"Oh my gracious,"],[2327,2494,"I believe Prince Alaric's car just"],[2494,2535,"pulled up."],[2585,2690,"He's so hot."],[2777,2919,"I'd give up human blood for a year if"],[2919,2973,"he'd marry me."],[3048,3211,"You don't stand a chance."],[3211,3440,"My sources says he has a date tonight."],[3461,3703,"A real human girl named Scarlett."],[3703,3795,"Can you believe that?"],[3849,3987,"Wait, a human girl named Scarlett?"],[4045,4254,"Oh no, it's probably just a coincidence."],[4421,4483,"Here they come."],[6181,6285,"Scarlett?"]],"20":[[763,900,"Thank you for hosting,"],[900,1092,"Count and Countess Venture."],[1092,1251,"Your home is lovely,"],[1251,1447,"especially the Chocolate Cosmos"],[1447,1522,"in the garden."],[1564,1722,"You notice my precious flowers?"],[1785,1906,"My husband spent a"],[1906,2085,"fortune moving them here from Mexico."],[2139,2231,"Prince Alaric,"],[2231,2389,"your date has good taste."],[2427,2552,"Much better than the"],[2552,2765,"broad Sean Bathory brought."],[2790,2911,"Darling, don't be vulgar."],[3737,3803,"He's here?"],[3803,3870,"I'm-"],[3870,4045,"I'm sorry, I didn't know he'd be here."],[4487,4558,"Scarlett?"],[4650,4746,"What the hell are you doing here?"],[4746,4817,"Where have you been?"],[4817,4925,"I just wanted to talk."],[4925,4979,"Okay?"],[5050,5163,"Please, let me go."],[5276,5430,"I'm only gonna ask once."],[5488,5559,"Let"],[5559,5651,"her"],[5651,5705,"go."],[5797,5926,"You let her go."],[5955,6026,"She's mine!"],[6093,6181,"Not anymore."],[6239,6322,"You lost her."],[7161,7248,"Oh shit!"],[7273,7394,"Is Lord Bathory kissing"],[7394,7486,"Prince Alaric's date?"],[7536,7736,"A prince and a lord fighting over a"],[7736,7811,"human girl?"],[7811,7891,"What the hell?"]],"21":[[75,104,"Let-"],[104,145,"Sean!"],[942,1134,"Let me remind you of your place,"],[1180,1326,"Lord Sean Bathory."],[1363,1488,"You touch my woman again,"],[1518,1680,"and I will personally drive a stake"],[1680,1760,"through your heart."],[1876,1956,"Guards!"],[1985,2102,"Get him out of my sight."],[2773,2844,"This isn't over,"],[2877,2977,"Prince Alaric."],[3011,3119,"I wonder how the King would feel,"],[3194,3340,"you stealing another man's thrall."],[3832,3903,"Are you okay?"],[3945,4095,"I'm so sorry about this mess."],[4158,4216,"I'm fine."],[4308,4450,"It's not your fault at all."],[4633,4729,"Okay, come on."],[4733,4825,"Let's go get some food."]],"22":[[16,95,"Sean!"],[200,325,"Why are you so worked up over that"],[325,433,"Scarlett bitch?"],[433,504,"She's obviously"],[504,588,"found a new master now,"],[588,667,"so just let it go."],[696,746,"Shut up!"],[855,975,"She is still my thrall,"],[996,1134,"and I'm still her master."],[1184,1351,"Aw, did she hurt your feelings"],[1351,1451,"by leaving?"],[1509,1676,"Is that why you can barely keep it up"],[1676,1751,"anymore?"],[1860,2018,"You keep talking and you're not gonna"],[2018,2131,"like the consequences."],[2189,2268,"Just face it, Sean."],[2335,2444,"I'm all you have left."],[2569,2669,"After what you did to her,"],[2669,2777,"she's never coming back."],[2815,2890,"Shut up!"],[3144,3290,"She is bonded to me"],[3324,3457,"and she must return to renew"],[3457,3561,"the Blood Oath."],[3728,3824,"And she loves me."],[3978,4208,"I will get her back from Prince Alaric."],[4254,4320,"Just you watch."],[4662,4725,"And as for you,"],[4838,4971,"you go back to the castle"],[4984,5096,"and you stay in your room."],[5246,5321,"You must repent"],[5355,5505,"until you grasp the gravity"],[5530,5643,"of your disrespect."]],"23":[[1217,1330,"Prince Alaric,"],[1380,1480,"Fancy seeing you here."],[1601,1739,"This must be the human girl you were"],[1739,1801,"telling me about."],[1889,2289,"Yes, this is my friend, Scarlett."],[2356,2469,"Scarlett, this is Rosie."],[2523,2727,"Head Scientist of the Royal Blood Lab."],[2756,2840,"She'll be taking care of you."],[2886,2961,"Friend."],[3053,3123,"Right."],[3261,3399,"Welcome to the Blood Lab, Scarlett."],[3474,3628,"You'll be the first human working here."],[3674,3732,"But don't worry,"],[3770,3895,"you're safe under my watch."],[4783,4900,"It's always been a dream"],[4900,4996,"of mine to work here."],[4996,5063,"I..."],[5096,5246,"I can't believe it's actually happening."],[5301,5351,"My"],[5355,5518,"father has called me back to the Capital"],[5518,5563,"for a meeting."],[5638,5672,"I believe"],[5693,5809,"Sean had something to do with it."],[5893,6026,"I'll be back as soon as I can."],[6131,6293,"Rosie, keep her safe."],[6381,6423,"I mean it."],[6485,6564,"Of course, your highness."],[6606,6664,"After what happened"],[6664,6848,"at the Countess's ball,"],[6848,6944,"I'm sure everyone knows"],[6944,7073,"how special she is."],[7123,7261,"Who would dare come after her?"],[7340,7440,"I have to go now."],[7565,7661,"But, Rosie,"],[7761,7853,"I'm counting on you."],[7853,7907,"Okay, okay."],[7928,7966,"Just go."],[8033,8183,"I have lots to teach Scarlett."],[8249,8329,"I can't wait to show you"],[8329,8433,"my latest prototype."],[8546,8650,"Bye Alaric!"],[8696,8779,"Bye."],[9154,9209,"The little brat"],[9209,9321,"didn't even give me a hug."],[9542,9701,"Your father is furius."],[9701,9784,"Hurry back."]],"24":[[125,196,"So right now,"],[241,396,"she's drawing blood."],[396,471,"And then we do testing."],[613,809,"Welcome to the Sanguine Room."],[855,980,"Here's where all the magic happens."],[1038,1184,"We've also come up with the newest"],[1184,1401,"formula for synthetic blood."],[1401,1593,"Our goal is to eventually replace"],[1622,1789,"drinking human blood altogether."],[1818,2064,"This is even cooler than I imagined."],[2118,2139,"Come on."],[2177,2235,"Let me show you"],[2235,2344,"what we do over here."],[2577,2656,"Safety first."],[2802,2861,"And..."],[7386,7557,"Why is everybody staring at us?"],[7603,7745,"It's because I'm human, isn't it?"],[7799,7941,"Oh, sweetie, no."],[7941,8091,"It's not about you being human."],[8149,8350,"It's because you're the girl two very"],[8350,8579,"powerful vampires fought over."],[8579,8654,"Everyone wants to see"],[8654,8767,"what you look like."]],"25":[[54,233,"I'm sure they're disappointed."],[233,275,"Oh, come on."],[275,346,"That's not true."],[412,663,"You're so tiny and adorable."],[850,884,"So,"],[1038,1180,"I have to know."],[1180,1384,"What's Prince Alaric like in bed?"],[1463,1551,"Not so loud."],[1697,1851,"I wouldn't know, we're just friends."],[1906,2122,"We've never actually slept together."],[2185,2268,"Yeah, right."],[2423,2627,"There's no way Prince Alaric would"],[2627,2815,"go through all the trouble of getting"],[2815,2882,"you to work here,"],[2932,3015,"fight over you,"],[3015,3244,"protect you, just to be your friend."],[3324,3420,"He may be a vampire,"],[3420,3578,"but he is still a man."],[3636,3716,"To be honest,"],[3853,3991,"I don't know why he's being so kind"],[3991,4062,"to me either."],[4175,4337,"We met when he pulled me out of a"],[4337,4462,"blood freezer and"],[4533,4667,"then he asked me to be his thrall."],[4688,4792,"So are you his thrall?"],[4792,4846,"No."],[4929,5055,"Well, I agreed,"],[5055,5230,"but for some reason he's been"],[5321,5459,"holding out for some reason."],[5680,5814,"Gosh, men are so weird."],[5993,6202,"Very weird, indeed."],[6439,6539,"There you are, Scarlett."]],"26":[[41,133,"There you are, Scarlett."],[646,729,"Lord Bathory,"],[779,905,"this is the Royal Blood Lab."],[905,1051,"You're not authorized to be here."],[1322,1530,"I'm just here for Scarlett, okay?"],[1530,1639,"You give her to me and I'll go."],[1689,1851,"I'm not going anywhere with you."],[1939,2206,"You will come home with me, Scarlett."],[2206,2268,"That's an order."],[2306,2419,"I'm never taking an order"],[2419,2515,"from you again."],[2560,2698,"The bond between us,"],[2806,2869,"it's gone."],[2869,2969,"You are my thrall!"],[2994,3148,"You cannot just leave me, okay?"],[3240,3428,"We are bound by a Blood Oath."],[3545,3641,"Not anymore."],[3953,4033,"What did you say to me?"],[4120,4408,"I said, I'm not your thrall anymore."],[4500,4700,"And I'm no longer bonded to you."],[4700,4833,"Without me, you will die, Scarlett."],[4854,4938,"Even dying"],[4967,5163,"is better than being bonded to you."],[5163,5242,"Security!"],[5305,5409,"You may be a lord,"],[5455,5626,"but Scarlett is under the protection of"],[5626,5714,"Prince Alaric."],[5714,5818,"And let me remind you,"],[5818,5968,"you're on government property."],[5993,6106,"I could have you arrested for"],[6106,6177,"trespassing."],[6427,6585,"I'll be back, Scarlett."],[6610,6810,"You can't hide from me forever."],[6810,6894,"Get off me!"]],"27":[[425,608,"Your ex is a crazy psycho."],[692,734,"I'm fine."],[788,896,"I'm not scared of him anymore."],[934,1051,"I have to tell Alaric."],[1151,1263,"Wait, please don't."],[1347,1455,"The king called him back."],[1455,1559,"He has to be busy."],[1559,1614,"I"],[1639,1722,"don't want to bother him"],[1722,1835,"with trivial matters."],[1847,1918,"Nobody said if"],[1918,2014,"anything were to happen,"],[2052,2122,"to call him..."],[2122,2193,"Nothing happened."],[2260,2335,"I'll be fine."],[2381,2444,"I promise."],[2652,2740,"Alaric has already done"],[2740,2823,"so much for me."],[2944,3094,"I can take care of this on my own."],[3111,3165,"Okay."],[3244,3432,"But if he ever shows up again..."],[3432,3566,"I'm calling Alaric."],[4154,4229,"My king!"],[4333,4629,"Look what a good son you raised."],[5246,5363,"Father, mother,"],[5467,5668,"nothing you say will change my mind."],[5793,6001,"Scarlett is my mate and I am going to"],[6001,6101,"marry her."],[6101,6373,"She's a lowly human!"],[6481,6623,"We were all humans once."],[6656,6852,"Before we traded our souls for"],[6852,6931,"immortality."],[6986,7052,"Fine."],[7182,7399,"Then I will lock you in this castle"],[7399,7582,"until you've changed your mind."],[7632,7707,"Guard!"],[7824,7907,"Keep him locked up"],[7953,8049,"and don't give him"],[8087,8133,"blood"],[8166,8366,"until you've admitted your mistake."],[8366,8445,"Father."],[8487,8562,"Mother!"]],"28":[[525,621,"You don't have to drop me off,"],[621,675,"you know."],[729,900,"Alaric's castle is two miles away,"],[900,996,"I'll just walk."],[1026,1213,"No way I'm letting you walk alone"],[1213,1263,"at night."],[1292,1493,"Besides, Alaric's orders."],[1514,1685,"I pick you up every morning and I drop"],[1685,1772,"you off every night."],[2139,2235,"Rosie!"],[2389,2489,"Shh."],[2565,2777,"I told you I'd be back, Scarlett."],[2819,2898,"You're coming with me."],[2932,3107,"Just let me go. Rosie!"],[3236,3307,"She's fine."],[3340,3474,"She'll wake up in a couple hours."],[3507,3636,"But if you don't want anything bad to"],[3636,3691,"happen to her,"],[3691,3812,"you'll come with me right now."],[3883,4008,"Alaric's not going to let this go."],[4312,4446,"Don't you dare"],[4446,4567,"mention his name again,"],[4625,4746,"and trust me,"],[4779,4929,"he'll be busy for a while."],[5059,5209,"What do you want from me, Sean?"],[5251,5397,"You already have Chelsea."],[5397,5505,"Just let me go."],[5626,5826,"I don't want Chelsea."],[5885,6060,"I haven't spoken to her since the party."],[6060,6181,"She won't be a problem."],[6277,6460,"Do you hear yourself, Sean?"],[6564,6698,"Last week she was your mate,"],[6698,6852,"and now you don't care about her?"],[6881,7065,"What kind of man are you?"],[7098,7194,"God damn it!"],[7194,7290,"Scarlett!"],[7323,7482,"Just come home with me."],[7803,7932,"And if you don't,"],[7962,8220,"I will kill a servant every day."],[8274,8441,"I will drag their lifeless corpse"],[8441,8562,"to your doorstep,"],[8562,8725,"and I'm gonna start with your favorite,"],[8754,8833,"Frederick."]],"29":[[95,175,"You wouldn't."],[225,425,"That's low even for you, Sean-"],[433,567,"Oh, I fucking would."],[633,863,"You've spent years among them."],[1005,1101,"You don't want their blood"],[1101,1213,"on your hands, do you?"],[1543,1634,"Sean, do you realize"],[1634,1801,"how pathetic you sound?"],[1826,2031,"I don't care, Scarlett."],[2168,2352,"I realized that I went through hell"],[2356,2410,"last week."],[2560,2690,"I miss your blood."],[2752,2873,"I want you back."],[3003,3153,"I just want things to go back to how"],[3153,3265,"they used to be."],[3294,3520,"He only misses me for my blood."],[3674,3791,"Find another thrall."],[3841,3941,"I don't want a thrall!"],[3941,4033,"I want you!"],[4241,4391,"I have to stall him until Alaric"],[4400,4466,"comes back."]],"30":[[588,654,"Fine."],[717,829,"I'll return."],[1146,1180,"But,"],[1284,1434,"only to be your maid."],[1468,1555,"Aside from that,"],[1555,1693,"there's nothing between us."],[1768,1906,"Yeah, we'll figure out the details later,"],[1906,1947,"okay?"],[1947,2052,"As long as you come back to me"],[2077,2139,"right now!"],[2352,2398,"What?"],[2460,2548,"Give me your phone."],[2573,2619,"Hurry."],[3357,3411,"Don't worry."],[3436,3549,"When this is all settled,"],[3549,3661,"I'll get you a new one."],[3661,3732,"Let's go."],[3916,4054,"Come on, Rosie."],[4054,4116,"Wake up."],[4149,4283,"I'm counting on you."],[5718,5822,"Back again"],[5847,5951,"to this place."],[6026,6206,"Welcome home, Scarlett."]],"31":[[20,175,"Welcome home, Scarlett."],[383,521,"I thought I told you to be prepared."],[684,784,"Well? bring them out."],[1926,2077,"What is the meaning of this?"],[2740,2911,"They have all been gathered from the"],[2911,2998,"human world."],[3028,3215,"It's the best of the best for you."],[3837,3887,"I know"],[3949,4116,"that I should have treated you better."],[4149,4396,"Okay, hey, but I can change now."],[4533,4658,"I've returned..."],[4717,4821,"as a maid."],[4921,5063,"Thanks to your little feast,"],[5092,5221,"I have more to clean up."],[5255,5367,"Now if you'll excuse me,"],[5367,5484,"I have work to do."]],"32":[[150,254,"Sorry, I've caused you"],[254,354,"extra work."],[392,558,"Please leave this to me."],[588,742,"Go get some rest."],[2635,2727,"Scarlett,"],[2848,2957,"I told you"],[2998,3119,"that I've changed, why..."],[3182,3357,"why won't you give me a chance?"],[3541,3678,"You haven't changed, Sean."],[3741,3845,"Not one bit."],[4287,4375,"That bitch."],[4396,4587,"I bet you're feeling so smug"],[4587,4708,"to be showered in gifts."],[4746,4850,"Sean has made my life"],[4863,4971,"a living hell for you."],[5159,5284,"It's been a while, bitch."],[5455,5605,"Oh, babe, you're the best."],[5630,5726,"I only know you were gone"],[5726,5772,"for so long"],[5772,5860,"because you were hunting me"],[5860,6001,"a tasty treat!"]],"33":[[0,108,"Like I said, Sean,"],[221,375,"you haven't changed."],[479,558,"That is not true."],[579,750,"I did not bring you back for her."],[813,1005,"Of course, it's for me, babe."],[1038,1276,"You must know I'm starving."],[1701,1764,"Are you okay?"],[1764,1830,"Are you hurt?"],[2627,2731,"You are useless!"],[2765,2940,"You can't even keep her in her bedroom!"],[2973,3061,"Scarlett,"],[3078,3161,"you're pathetic."],[3236,3382,"He's treated you like a slave,"],[3382,3611,"and you still come crawling back."],[3678,3845,"You think he loves you?"],[3908,4054,"What a joke."],[4108,4254,"Don't think you've won, bitch."],[4279,4471,"He's like a dog in heat that humps the"],[4471,4671,"leg of every pretty girl he meets."],[4700,4867,"Soon you'll be in the dungeon with me"],[4867,4946,"in no time."]],"34":[[29,66,"You know what?"],[187,354,"I changed my mind."],[579,692,"Take her to the dungeon."],[692,800,"Get her out of my sight!"],[884,980,"No! No!"],[980,1051,"Sean!"],[1051,1096,"No!"],[1096,1180,"What are you doing?"],[1180,1276,"I'm your mate!"],[1276,1393,"I have rights!"],[1393,1455,"No!"],[1488,1555,"No!"],[1956,2085,"That was an accident."],[2114,2177,"Okay?"],[2177,2410,"I swear, she will pay for her lies."],[2477,2610,"Please don't be bothered by the"],[2610,2740,"ramblings of a mad woman,"],[2740,2827,"Scarlett."],[3224,3440,"What part do you think bothers me?"],[3474,3553,"If anything,"],[3586,3795,"her words have upset you."],[3841,3916,"Why?"],[3937,4033,"Because she's ruined your"],[4033,4099,"reputation,"],[4120,4275,"or because she's truthfully listed the"],[4275,4412,"ways you've hurt me."],[4692,4904,"Sean, I won't let it bother me."],[5005,5150,"Not a single bit."]],"35":[[529,583,"Why?"],[583,675,"Because she's ruined your"],[675,767,"reputation"],[767,909,"or because she's truthfully listed"],[909,1051,"the ways you've hurt me."],[1113,1197,"Hurt?"],[1255,1409,"How have I hurt her?"],[1539,1743,"Sean, save me!"],[1926,1976,"Scarlett,"],[2064,2256,"you're just gonna have to bear it."],[2289,2448,"You shouldn't have hurt Chelsea."],[3520,3687,"So what if I drank her blood?"],[3720,3895,"That's her duty as my thrall."],[3928,4095,"How could that count as hurting her?"],[4771,4904,"Does she mean Chelsea?"],[4959,5088,"But it was that woman's fault for"],[5088,5159,"manipulating me."],[5201,5434,"It's not like I set out to hurt her."],[5647,5751,"I did nothing wrong."],[5776,5905,"I'm her master."],[5905,5997,"I haven't even punished her"],[5997,6106,"for running away yet."],[6151,6335,"She's just a lowly human thrall."],[7607,7728,"So then, why"],[7807,8024,"am I so afraid of losing her?"],[9192,9346,"Does this mean that I love her?"]],"36":[[287,350,"Scarlett!"],[921,1034,"Did Scarlett sends you?"],[1101,1380,"Um, Miss Scarlett is preparing."],[1797,2043,"I will graciously accept her invitation."],[2093,2223,"Coming back with me is proof"],[2223,2339,"Scarlett still loves me."],[2385,2502,"Everything else is an excuse."],[3028,3161,"Frozen blood needs to be kept"],[3161,3282,"in precise conditions."],[3315,3445,"This bowl is ruined."],[3465,3628,"We can only take out small portions at a"],[3628,3749,"time to keep from exposure."],[3928,4008,"Okay."],[4746,4875,"Why are you here?"]],"37":[[4,125,"Aren't you preparing dinner"],[125,183,"for me?"],[358,425,"Master,"],[554,642,"this is your dinner."],[667,746,"It was in your room,"],[746,892,"but you weren't in there."],[1146,1226,"But why aren't you preparing"],[1226,1280,"your own blood?"],[1280,1330,"You should be-"],[1330,1397,"Why should I?"],[1426,1697,"I told you, I'm not your thrall anymore."],[1730,1864,"Our bond has been severed."],[2002,2077,"See?"],[2489,2706,"I'm no longer bonded to you."],[2961,3053,"This is a trick"],[3053,3153,"you're trying to play to"],[3153,3228,"cover it up."],[3257,3370,"Because once the curse strikes-"],[3403,3561,"You're still in denial?"],[3620,3724,"I'm tired of"],[3724,3866,"indulging in your tantrums."],[3920,4004,"Listen, the blood oath"],[4004,4099,"has been broken..."],[4141,4212,"by you!"],[4283,4396,"No, no, no, no, no."],[4396,4466,"That's impossible."],[4466,4554,"I would never do that."],[4579,4721,"Our blood oath binds us"],[4746,4971,"so long as I mark you once a year-"],[5342,5434,"Today's..."],[5593,5647,"Yeah."],[5726,5843,"Check your calendars."],[5930,5980,"It's the cure to"],[5980,6135,"your fucking delusions."],[7265,7328,"SOS!"],[7361,7503,"Scarlett has been taken!"],[7503,7645,"Need Help ASAP!"],[7682,7736,"Fuck!"],[7870,8008,"I need to get out of here."]],"38":[[362,479,"No, no, no, no, no."],[479,571,"Did I forget the date"],[571,650,"of our blood oath?"],[704,850,"It's impossible! I wouldn't make"],[850,992,"such a pathetic mistake!"],[1530,1655,"March 21st."],[1743,1889,"It was the day of our blood oath that was"],[1889,1993,"over a week ago."],[2711,2802,"Does that mean there's nothing"],[2802,2894,"between us?"],[3028,3144,"The bond is broken."],[3165,3282,"Oh, no, no,no."],[3570,3674,"How can this happen?"],[3762,3874,"How did this happen?"],[4763,4817,"No."],[4854,5025,"No, it's Chelsea's fault."],[5055,5180,"It's her fault things turned out"],[5180,5234,"this way."],[5313,5463,"I just have to get rid of her."],[5513,5609,"Then everything will go back"],[5609,5751,"to the way that it used to be."],[6439,6664,"Sean, what are you doing?"],[6919,7123,"Execution or banishment?"],[7290,7411,"You will pay for what you've done"],[7411,7474,"to Scarlett."]],"39":[[4,137,"You can't do this to me!"],[162,304,"Even a vampire lord can't"],[304,387,"execute their mate."],[412,588,"The punishment fits the crime."],[617,825,"You led me to hurt Scarlett,"],[825,996,"seducing me into forgetting the day of"],[996,1101,"our blood oath."],[1363,1547,"You were the reason why our bond"],[1547,1768,"was destroyed and Scarlett suffered."],[2260,2485,"I'm the reason your bond is over?"],[2865,2994,"You've got real feelings"],[2994,3065,"for that bitch."],[3098,3211,"Of course I do."],[3465,3553,"I love her,"],[3578,3803,"and I'm realizing now that you are the"],[3803,4033,"temptress that ruined everything!"],[4129,4220,"You love her?"],[4375,4466,"Well that didn't stop you"],[4466,4579,"from fucking me."],[4633,4842,"That didn't stop you from handing her"],[4842,5050,"over like a tasty snack."],[5163,5276,"You think she left because"],[5276,5442,"I stopped you from loving her?"],[5601,5730,"You shut up."],[5793,5972,"Nothing would have happened if you"],[5972,6114,"didn't get between us."],[6243,6402,"I should never have turned you."],[6435,6602,"I should have let you die."],[6669,6785,"You think that killing me"],[6785,6911,"would bring her back to you?"],[7019,7178,"You think you love her?"],[7386,7528,"You know, the day you turned me"],[7528,7682,"was the day of your blood oath, right?"],[7882,8099,"And you still let me drain her blood."],[8187,8345,"You would have let me kill her!"],[8475,8604,"Is that how you love?"]],"40":[[8,58,"What the hell?"],[91,204,"The day that I turned you?"],[625,771,"Was that the last day of our bond?"],[1251,1363,"Yeah, that's right."],[1459,1643,"The day you turned me was the last day"],[1643,1793,"you had a chance to keep the bond."],[2106,2256,"Even I knew that."],[2289,2464,"That's why she said she hated you,"],[2464,2560,"remember?"],[2831,3111,"Sean, you're a liar."],[3111,3203,"I hate you."],[3257,3345,"Oh, no, no, no,"],[3345,3428,"no, no, no."],[3553,3649,"No, no, no, no, no."],[3682,3737,"No!"],[4145,4291,"No, Sean, don't leave me here."],[4320,4546,"Sean, please don't leave me."]],"41":[[266,383,"That day when she was suffering"],[383,487,"from the blood oath."],[529,675,"God, I made her cut her own wrists."],[675,763,"How could I have done that?"],[880,1080,"Is this what she means by hurt?"],[1209,1401,"How could I have treated her like that?"],[1463,1609,"I need to make it up to her."],[1672,1730,"But how?"],[1730,1906,"How can I make it up to her?"],[2410,2481,"So why?"],[2569,2777,"Why do you insist on becoming a vampire?"],[3194,3290,"Sean, for you,"],[3290,3507,"a human life is too short."],[3595,3874,"I want to be yours forever."],[4475,4625,"That's what she wants."],[4767,4909,"She wants to be turned"],[4988,5096,"and then she'll be my bride."],[5163,5347,"And then we can be together forever."],[5563,5680,"Frederick!"],[5834,6026,"Prepare a royal wedding ceremony."],[6026,6168,"It'll be the best anyone's ever seen."],[6168,6306,"It'll be the most lavish wedding"],[6306,6448,"ceremony ever."],[6481,6639,"Send wedding invitations"],[6639,6744,"to every family,"],[6744,6915,"and in three days I will hold a grand"],[6915,7027,"wedding for Scarlett."],[7027,7111,"I will turn her into a"],[7111,7248,"full-fledged vampire,"],[7282,7432,"and everyone will know that she is my"],[7432,7528,"one and only."],[7649,7778,"Are you sure"],[7807,8024,"this is what Ms. Scarlett wants?"],[8024,8153,"Of course I'm sure."],[8312,8425,"And I will prepare her"],[8425,8675,"the perfect wedding gift."]],"42":[[1476,1555,"Scarlett,"],[1693,1755,"I..."],[1860,2047,"I discovered the source of your pain"],[2052,2210,"and the hurt that you have suffered."],[2285,2410,"What are you up to now and"],[2410,2548,"what are you wearing?"],[2836,2957,"I'm sorry, Scarlett."],[3098,3269,"I forgot the day of our blood oath,"],[3269,3374,"and I forced you to feel"],[3374,3528,"unimaginable pain."],[3628,3828,"Okay, but I will reward you"],[3874,4083,"with heavenly bliss and everything that"],[4083,4162,"you've ever wanted."],[4162,4354,"Just give me three days, okay?"],[4354,4450,"Three days to prepare."],[4475,4571,"Prepare what?"],[4637,4842,"I don't need anything from you."],[4875,4996,"Just leave me alone."],[4996,5109,"I have work to do."],[5138,5263,"Still no sign of Alaric."],[5330,5434,"Where is he?"],[5755,5885,"I'll make you happy."],[6035,6172,"Okay, it'll be everything that"],[6172,6306,"you've ever hoped for."],[6402,6589,"What are you talking about?"],[7002,7157,"I'll make you my bride."],[7307,7482,"Okay, and then I'll turn you,"],[7549,7820,"and you will be Lady Bathory."],[8028,8187,"It's everything you've wanted, right?"],[8245,8412,"I'm giving it to you now, Scarlett."]],"43":[[4,166,"I'm giving it to you now, Scarlett."],[788,900,"Say something, please."],[1126,1267,"It hit me just now."],[1418,1555,"You never truly knew me."],[1735,1847,"Not once."],[1922,2106,"You really think becoming a vampire"],[2106,2210,"is what I want?"],[2231,2431,"That some glittering title could fix"],[2431,2585,"what broke between us?"],[2727,2873,"This proves you still don't understand"],[2873,3015,"why I left you."],[3148,3269,"Okay, then tell me,"],[3303,3474,"and tell me, Scarlett, why?"],[3916,3995,"I left"],[4016,4141,"because I couldn't handle the"],[4141,4262,"disappointment anymore."],[4416,4558,"Three years, Sean."],[4629,4708,"Three years"],[4721,4875,"I stood beside you and gave you"],[4875,5050,"everything I had."],[5092,5313,"Forgave every wound you dealt me."],[5376,5430,"Hoping,"],[5459,5634,"praying that one day,"],[5659,5897,"you'd learn how to love me back."],[5964,6097,"But waiting for you"],[6106,6343,"is like waiting for rain in a drought,"],[6427,6573,"useless and disappointing."],[6681,6781,"Disappointed that"],[6781,6990,"my devotion was taken for granted."],[7032,7178,"Disappointed that I had to"],[7178,7311,"bear the pain alone."],[7378,7494,"Disappointed that"],[7494,7732,"I was rejected and left to die alone"],[7732,7912,"by the one I loved."],[8033,8153,"If I hadn't left,"],[8195,8329,"you never would have known."],[8375,8596,"Because a great vampire lord like you"],[8596,8787,"wouldn't remember something like this."],[8846,9021,"All you have ever cared about..."],[9117,9209,"is yourself."],[9359,9488,"It's not true, Scarlett."],[9534,9626,"That is not true."],[9626,9759,"I don't hate Chelsea,"],[9838,9989,"even though she framed me."],[10022,10143,"I hate myself"],[10160,10293,"for giving my love to someone"],[10293,10460,"who didn't believe me."],[10489,10668,"You don't know what love is."],[10852,11011,"I should have seen it sooner."],[11261,11407,"I pity you."]],"44":[[25,104,"Wait."],[116,279,"What did Scarlett mean"],[279,425,"by Chelsea framed her?"],[859,930,"I want you"],[967,1080,"to get it out of Chelsea"],[1080,1213,"what she did to Scarlett."],[1234,1409,"There's no need for that, my lord."],[1447,1559,"I've already captured"],[1559,1659,"the maid Alice."],[1685,1847,"She confessed everything."],[1981,2118,"What are you talking about?"],[2277,2448,"Sir, there are some things"],[2502,2677,"I think you should hear for yourself."],[3211,3345,"I don't want to die!"],[3436,3541,"I don't want to..."],[3574,3657,"Chelsea!"],[3728,3799,"Chelsea!"],[3841,3933,"Do something!"],[4137,4191,"Bitch!"],[4287,4479,"It's your fault I'm gonna die!"],[5705,5797,"Speak."],[5914,6047,"Now, tell me what happened!"],[6056,6235,"Sir, it's not my fault."],[6247,6406,"I swear it was..."],[7040,7119,"Milord."],[7232,7432,"I never wanted to hurt Scarlett."],[7499,7595,"The turning..."],[7607,7766,"It was Chelsea's idea."],[7853,7962,"She threatened me."],[9288,9384,"Sorry."],[9446,9547,"I'm sorry."],[9613,9780,"I...I'll tell the truth."]],"45":[[50,212,"I...I'll tell the truth."],[375,487,"That was our plan."],[550,734,"Everything that Chelsea and I did,"],[771,913,"I shoved Chelsea down"],[913,1176,"the stairs and told you it was Scarlett."],[1205,1305,"Then you were forced to"],[1305,1493,"turn Chelsea ahead of schedule."],[1597,1730,"You fucking bitches."],[3261,3415,"Please, please..."],[3432,3737,"Please, Milord, have mercy on me."],[3874,3974,"I just did it because"],[3974,4104,"it was Chelsea's orders."],[4120,4241,"I never wanted to..."],[4320,4458,"I never wanted to."],[4775,4846,"It's okay."],[6431,6560,"It's over, Scarlett."],[6660,6748,"It's over now."],[6815,6936,"I got her back for you."],[7032,7136,"And you'll see that."],[7232,7378,"I never meant to hurt you."],[7444,7599,"And I'm a victim too."],[7665,7732,"Okay?"],[7820,8012,"You'll forgive me, right?"],[8575,8725,"Death is too good for her."],[8796,8938,"I'll deal with her later."]],"46":[[863,975,"It's me, it's me!"],[1013,1130,"Alright, come here."],[1463,1559,"Oh my goodness!"],[1584,1697,"You're finally here!"],[1785,1960,"Wait, how did you even get in?"],[2022,2177,"I told the guards I was delivering"],[2177,2298,"blood samples to Sean."],[2352,2552,"I can get away with a lot with my badge."],[2673,2761,"Where's Alaric?"],[2781,2915,"He's under lockdown from the king,"],[2915,3082,"but I know he's trying to get out."],[3103,3265,"I've been tasked with your extraction."],[3286,3328,"But..."],[3390,3536,"if I leave, Sean says he'll kill"],[3536,3603,"his servants."],[3624,3782,"Alaric will take care of it."],[3791,3883,"We need to get out of here"],[3883,3999,"before that creep marries you"],[3999,4120,"and turns you into a vampire."],[4137,4250,"Yeah, you're right."],[4279,4429,"He's been prepping the wedding"],[4429,4521,"and my turning,"],[4558,4708,"it's freaking me out."],[4754,4792,"Hurry."],[4859,4946,"Put this on"],[4946,5080,"and let's get you out of here."],[5380,5434,"Hey boys,"],[5434,5622,"I'm leaving, done with my delivery."],[5918,5972,"Wait."]],"47":[[20,75,"Wait."],[287,442,"You came here by yourself."],[575,696,"Who's this leaving with you?"],[709,842,"Oh, uh, she's a maid,"],[842,1013,"but she accidentally contaminated"],[1013,1151,"herself with my things, so,"],[1176,1297,"I have to take her back to the lab to"],[1297,1405,"give her a vaccine."],[1488,1584,"Show me your face."],[1634,1705,"Are you sure?"],[1739,1947,"She's super contagious"],[1947,2014,"right now."],[2168,2256,"It's a new strain,"],[2264,2423,"a virus we made at the lab."],[2456,2610,"It will make all vampires have"],[2610,2857,"explosive diarrhea for one week."],[2948,2994,"Ew."],[3090,3182,"Go, go."],[3253,3386,"Why would you even bring that here?"],[3415,3616,"Oh, um, it's because..."],[4070,4220,"Master Sean is very,"],[4233,4341,"very constipated."],[6156,6277,"That was smooth."],[6302,6406,"I've done this a lot."],[6406,6556,"Come on, my car's parked over here."],[6556,6619,"Okay."]],"48":[[25,120,"I told you,"],[145,212,"if you left,"],[212,296,"I would kill everyone"],[296,371,"in this castle."],[450,608,"That's fucked up, Sean."],[871,959,"The wedding's tomorrow."],[1051,1192,"I'm not marrying you."],[1380,1434,"Then,"],[1459,1639,"your friend here's gonna die, Scarlett."],[2018,2131,"You've gone mad."],[2164,2293,"She's the head scientist at the"],[2293,2377,"Royal Blood Lab."],[2385,2552,"Killing her would be treason."],[2715,2806,"I have gone mad."],[2848,2961,"Okay, losing you"],[2994,3103,"has made me go crazy."],[3123,3211,"And I realize now,"],[3253,3361,"even if you hate me,"],[3420,3578,"I'm going to make you stay by my side,"],[3578,3611,"okay?"],[3611,3699,"I have changed"],[3699,3849,"and I can do right by you now."],[3920,4070,"I killed Alice."],[4070,4145,"I killed her"],[4145,4283,"because she tricked us."],[4325,4612,"Don't blame this on Alice or Chelsea."],[4662,4854,"This is your fault, not theirs."],[4925,5013,"Shh."],[5242,5380,"By tomorrow, we will have all of"],[5380,5555,"eternity to fix this, okay?"],[5764,5980,"Frederick, you take her to the dungeon."],[6001,6231,"You can release her after the ceremony."],[6527,6635,"Freddie!"],[6835,6898,"Please."]],"49":[[425,496,"Alaric!"],[875,1005,"Why have you done this?"],[1030,1188,"Is it all for that human girl?"],[1263,1509,"I have given you and father"],[1589,1760,"everything you've ever asked of me."],[1893,1981,"Every duty."],[2031,2077,"Every..."],[2139,2248,"expectation."],[2406,2544,"I have fulfilled them all"],[2544,2623,"without question."],[2711,2840,"I've become the prince"],[2861,2977,"you've always wanted."],[3065,3253,"The son you've always wanted."],[3399,3528,"So for once in my life,"],[3528,3682,"can you let me choose"],[3682,3828,"the girl that I love?"],[3962,4074,"What if I say no?"],[4466,4725,"Then eternity is too long,"],[4800,4917,"too unbearable,"],[4921,5113,"and that is not a life worth living."],[5409,5543,"I'll prep some blood."],[5584,5680,"You need to heal."],[5968,6143,"And then I'll let you go."],[6694,6798,"Thank you, mother."]],"50":[[763,900,"I cannot believe this."],[938,1080,"Lord Bathory is marrying"],[1080,1180,"Prince Alaric's girl."],[1180,1347,"I mean, I'm so confused."],[1376,1559,"Ah, she must be a ho."],[1601,1634,"Yeah."],[1730,1914,"I can still save this relationship."],[1947,2085,"Once she becomes my bride,"],[2097,2252,"no one can take her away from me."],[3774,3941,"I used to dream about this day."],[4166,4279,"Now it's a nightmare."],[4425,4500,"I know."],[4612,4738,"And I'm so sorry."],[5434,5547,"Sean's gonna turn me into"],[5547,5663,"a vampire tonight."],[5885,6043,"What's it like to live forever?"],[6264,6335,"A blessing..."],[6406,6498,"at first."],[6627,6790,"Then a slow,"],[6823,6936,"quiet ache."],[6986,7136,"And with the wrong person,"],[7186,7349,"eternity becomes"],[7424,7578,"cruel and unbearable."],[7745,7957,"I refuse to let that be my fate."]],"51":[[120,337,"I refuse to let that be my fate."],[563,684,"Have faith."],[3044,3190,"My beautiful bride."],[3299,3370,"Today,"],[3407,3674,"we celebrate the joining of the union"],[3674,3832,"between Lord Sean Bathory"],[3908,4087,"and Lady Scarlett Russell."],[4112,4279,"Where are you Alaric?"],[4279,4408,"I'll kill myself"],[4408,4675,"before I'm bonded to Sean forever."],[5146,5392,"Alaric, Scarlett is being forced to"],[5392,5476,"marry Sean!"],[5492,5668,"Good news, his butler Frederick"],[5668,5793,"set me free, I'll find a way"],[5793,5868,"to knock out the guards,"],[5868,5985,"but you need to get here"],[5985,6106,"as soon as you can!"],[6131,6256,"Okay, I'm on my way."]],"52":[[4,125,"Love for our kind"],[125,283,"is not a fleeting spark."],[329,579,"It is vows carved into centuries."],[921,1063,"You know, I'd rather die"],[1101,1272,"than be stuck with you for an eternity,"],[1288,1322,"right?"],[1530,1647,"It's okay, Scarlett."],[1843,1981,"I have all of eternity..."],[2085,2181,"to win you back."],[2394,2527,"You fell in love with me once."],[2602,2723,"I think you could do it again."],[2861,3069,"There's no going back from betrayal."],[3123,3236,"Love withers,"],[3244,3345,"trust breaks,"],[3365,3461,"and neither of them"],[3461,3636,"can ever return to be the same."],[3799,3945,"The power vested in me"],[3945,4104,"in the Vampire Council."],[4195,4291,"Lord Sean."],[4358,4437,"Lady Scarlett."],[4733,4884,"I now pronounce you..."],[5885,5972,"I object."]],"53":[[437,613,"For the love of darkness,"],[613,688,"it just keeps getting"],[688,767,"better and better."],[784,867,"I can't believe this."],[867,1009,"Why can't two rich and powerful"],[1009,1172,"men fight over me like this?"],[1309,1409,"Step aside."],[1447,1551,"She is not your bride,"],[1551,1730,"not now, not ever."],[2239,2373,"I, Prince Alaric,"],[2385,2606,"command this wedding to end now."],[2644,2840,"Sean Bathory will be trialed"],[2840,3036,"in a court of law for all of his crimes."],[3211,3294,"Scarlett."],[3470,3566,"Come home with me."],[4179,4295,"No, Scarlett!"],[4371,4471,"You stay with me."],[4491,4629,"You belong to me, please!"],[5467,5572,"You finally came."],[5588,5768,"I am so sorry it took so long."],[5914,5972,"Scarlett,"],[6089,6160,"watch out."],[6210,6272,"Rosie."],[7444,7524,"Gah!"],[8954,9200,"Royal blood runs through my veins."],[9221,9317,"Older and stronger"],[9317,9463,"than your entire lineage,"],[9471,9630,"you will never be my match."],[10164,10268,"For what you've done,"],[10297,10447,"I should have your head."]],"54":[[54,158,"For what you've done,"],[187,333,"I should have your head."],[392,450,"Please..."],[583,709,"Spare my master."],[1101,1197,"You betrayed me?"],[1251,1430,"You left me no choice, Milord."],[1530,1685,"I had to do the right thing."],[2056,2118,"Alaric!"],[2160,2268,"Please don't kill him."],[2310,2515,"He deserves a proper trial."],[3174,3240,"Are you okay?"],[3240,3353,"You're not hurt, are you?"],[3365,3440,"I'm okay."],[3566,3703,"Come, let's go home."],[3703,3782,"Wait, wait, wait."],[3824,3941,"Don't be his thrall, please..."],[4008,4104,"Please don't go with him."],[4162,4300,"Look how pathetic you are."],[4300,4441,"Barely able to stand."],[4496,4679,"You are lucky I didn't take your life."],[4783,4884,"No, it's my fault."],[4988,5100,"Okay, but the thought of you with"],[5100,5159,"another man,"],[5188,5288,"I can't bear it."],[5334,5463,"I know I don't deserve"],[5484,5563,"your forgiveness,"],[5605,5697,"let alone your love,"],[5697,5739,"but..."],[5755,5864,"you can't be his thrall"],[5864,5968,"because I love you."],[6076,6235,"You still don't get it, do you?"],[6297,6423,"The biggest difference between"],[6423,6506,"you and I."],[6544,6669,"I never wanted Scarlett"],[6669,6760,"to be my thrall."],[6965,7186,"I wanted her to be my mate."],[7307,7378,"My wife."],[7424,7528,"And my equal."],[7699,7799,"Alaric..."],[8554,8737,"Throw this man in the royal dungeon."],[8783,8896,"He is not to be released"],[8896,8979,"until his trial."],[9063,9134,"I'm sorry."],[9180,9317,"I did love you, Scarlett."],[9367,9509,"I fucked it up, didn't I?"],[9542,9688,"I'm sorry, Scarlett!"]],"55":[[1305,1372,"Good morning."],[1409,1514,"Oh, hey."],[1576,1680,"Good morning, Alaric."],[1680,1793,"I'm making breakfast."],[1805,1901,"It'll be done soon."],[1922,2081,"I thought I told you there's no need for"],[2081,2210,"you to cook and clean here."],[2218,2327,"We have hundreds of maids"],[2327,2419,"at this castle."],[2435,2694,"Yeah, but I want to make myself useful."],[2715,2882,"I can't just stay here for free."],[2977,3107,"Do you not feel at home here?"],[3169,3386,"No, of course I do, Alaric."],[3445,3549,"I like it here."],[3574,3741,"Thank you for taking me in."],[3849,4058,"But I refuse to be a burden."],[4517,4637,"Well, what are you doing?"],[4675,4850,"After everything we've been through"],[4850,4963,"and after everything I've said,"],[4963,5113,"you still don't know what I'm doing."],[5213,5301,"Scarlett,"],[5355,5513,"do you remember the first time we met?"],[5618,5684,"Of course."],[5743,5872,"I was buying something"],[5872,5980,"at the store and,"],[5980,6143,"well, I accidentally locked myself in"],[6143,6256,"the blood freezer."],[6293,6389,"You saved me."],[6427,6585,"I was going to thank you and,"],[6652,6690,"well,"],[6723,6890,"you asked me to enter a blood oath"],[6890,6952,"with you."],[7036,7123,"I panicked."],[7161,7323,"I didn't know quite what to say,"],[7353,7499,"but that isn't quite right."],[7536,7695,"We'd met once before then."]],"56":[[20,171,"We'd met once before then."],[575,729,"Do you recognize this?"],[834,996,"It's very important to me."],[1013,1113,"It was my grandmother's"],[1113,1226,"before she, um..."],[1334,1493,"Before she set her soul free."],[1539,1710,"Eternity was heavy on her without"],[1710,1797,"my grandfather,"],[1797,1897,"and I didn't understand"],[1897,1968,"at the time."],[2002,2131,"But she told me one day"],[2139,2302,"when I find the right girl I would."],[2427,2548,"I almost lost it."],[2652,2719,"You were the one"],[2719,2836,"who returned it to me."],[2940,3069,"The day we first met,"],[3069,3240,"you became that girl, Scarlett."],[3478,3649,"Sorry, I don't remember it."],[3666,3728,"No."],[3807,3966,"There's no need to apologize."],[4079,4237,"The reason I fell for you"],[4312,4421,"is because you're kind"],[4425,4533,"and caring and thoughtful"],[4537,4671,"to everyone you meet."],[4721,4904,"I'd be a fool not to see that."],[6022,6181,"And I meant what I said."],[6385,6535,"I don't want you to be my thrall,"],[6535,6602,"Scarlett."],[6802,6990,"Instead, I want you to be my mate."],[7052,7219,"So I'm giving this to you."],[7866,7966,"To be mates,"],[8016,8224,"we need love and trust."],[8316,8358,"I..."],[8379,8437,"I understand."],[8633,8837,"I will wait as long as you need."]],"57":[[792,980,"I am so excited to be back."],[1034,1242,"Thank you, Alaric, truly."],[1359,1509,"Why are you thanking me?"],[1609,1714,"The lab was eager to have"],[1714,1810,"you back, alright?"],[1810,1910,"You earned your spot here"],[1910,1993,"through hard work,"],[2035,2202,"and no one can take that away from you."],[2252,2510,"But I couldn't have done it without you."],[2573,2677,"I swear I will-"],[2686,2802,"Fall for me?"],[3541,3636,"Oh, please."],[3670,3770,"For the love of darkness,"],[3770,3891,"would you two get a room?"],[4466,4592,"Take care of her, Rosie."],[4592,4667,"Yeah, yeah."],[4692,4900,"You've said that like a bazillion times."],[4992,5059,"Now go."],[5113,5267,"We ladies have work to do."],[5451,5509,"Okay."],[5605,5689,"Bye, Alaric."]],"58":[[104,166,"Ew."],[308,433,"Have fun at work, honey."],[963,1138,"In a landmark ruling today,"],[1138,1292,"the notorious vampire lord,"],[1292,1380,"Sean Bathory,"],[1405,1576,"was sentenced to eight centuries"],[1576,1643,"in prison"],[1659,1772,"after being convicted"],[1772,1885,"of kidnapping and murder."],[1910,2031,"His accomplice Chelsea,"],[2039,2198,"was convicted and banished to the"],[2198,2360,"Badlands where she will face"],[2360,2485,"the unruling creatures"],[2485,2594,"that roam the wastes."],[4412,4500,"Food!"],[4646,4800,"New food is here."],[4954,5063,"No! No!"],[5075,5196,"Hey, let go of me!"],[5226,5263,"No!"],[5413,5451,"No!"]]}