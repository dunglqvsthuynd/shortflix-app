{"1":[[221,383,"Someone call 911!"],[458,617,"911, what's your emergency?"],[700,809,"Everyone, this way!"],[1046,1155,"Go! Go! Go!"],[3895,4024,"Let's go! Let's go! Let's go!"],[4024,4137,"Move it! Move it! Move it!"],[5000,5188,"Cap! Only one nurse is remaining!"],[5242,5321,"Cindy White!"],[7207,7278,"Jackson...?"],[7349,7461,"Am I dreaming?"],[7520,7736,"It's been nearly a decade."],[7791,7903,"Cindy!"]],"2":[[20,107,"Okay, come on."],[187,296,"Come on, Jackson!"],[296,475,"Let's go! Let's go!"],[475,575,"Come on!"],[688,788,"You got this!"],[925,1038,"Come on, let's go!"],[1476,1676,"Yes! 22'33''!"],[1730,1835,"You got it!"],[3108,3336,"Here you go. You did amazing."],[3386,3436,"Thank you."],[3436,3541,"For sure, you're gonna ace that"],[3541,3700,"firefighter aptitude test."],[3791,3949,"Why are you leaving me for New York?"],[3991,4137,"Why is summer already over?"],[4287,4441,"Well, I'm not leaving you, Cindy."],[4587,4850,"Look, I know it's only been one summer, but"],[4888,5196,"I'm for sure that you're the love of my life."],[5568,5884,"I'm glad I stole you away from that loser Gary."],[5922,6068,"Yeah, now I only have eyes for you."],[6247,6535,"Seriously, wait for me. I'll come back for you."],[6731,6802,"OK."],[6936,7083,"I love you, Cindy White."],[7232,7395,"I love you too, Jackson Carter."],[8124,8195,"One more thing!"],[8233,8287,"Ahhhhh!"],[8700,8850,"You ass!"],[9284,9447,"I can't be pregnant."],[9547,9657,"I have to tell Jackson."]],"3":[[621,669,"Lorraine."],[955,1130,"You shameless little tramp!"],[1163,1405,"Are you trying to trap my son with a baby?"],[1443,1601,"No! No, that's not what that is."],[1601,1785,"Jackson has a bright future ahead of him,"],[1785,2001,"and I will not let you ruin it."],[2072,2389,"Get rid of the baby and disappear from his life."],[2389,2786,"Or I swear I will destroy everything you have."],[2898,3009,"But I love him!"],[3236,3324,"We love each other."],[3607,3975,"If you really love him, then walk away."],[4029,4202,"My son deserves better."],[4963,5148,"Alright, this is it."],[5171,5239,"I'm gonna put a ring"],[5239,5363,"on your finger before I leave."],[5492,5679,"If he knew about the baby, he'd stay."],[5747,5827,"For me."],[5855,5937,"For us."],[7219,7303,"Whoa!"],[7761,7876,"Uh, hey!"],[7987,8091,"What are you doing in here?"],[8362,8479,"I'm here to break up with you."]],"4":[[133,196,"Wait, what?"],[350,499,"Break up? Why?"],[1543,1651,"What the fuck?"],[1722,1868,"Is this a fucking joke?"],[1868,1951,"I haven't even left. And you're"],[1951,2079,"back with this fucking asshole!?"],[2079,2143,"Hey! Watch your mouth!"],[2173,2394,"Yes. Gary and I are back together."],[2502,2649,"He's thinking about it and"],[2698,2836,"his family's money can give me"],[2836,2990,"the life I've always dreamed of."],[3094,3199,"And I don't want to worry about"],[3199,3383,"losing my partner in a fire or something."],[3516,3798,"But you've always been supportive of my dream."],[4029,4099,"Goodbye, Jackson."],[6118,6220,"That was hilarious!"],[6220,6307,"Did you see his face?"],[6307,6368,"It was priceless!"],[6448,6673,"Gary, go home."],[6744,6873,"We're not getting back together."],[6886,6948,"What?"],[7052,7198,"Well, first you begged me to come out here,"],[7198,7290,"and now you push me away?"],[7403,7499,"You psycho bitch!"],[8045,8258,"I'm sorry, Jackson."],[8400,8540,"I'm so sorry."],[8996,9142,"Captain Jackson, you have proven"],[9142,9369,"yourself to be a hero once again."],[9409,9667,"But reports are saying that you've stayed inside"],[9667,9822,"the blaze 30 minutes longer"],[9822,9943,"than protocol allows."],[9984,10170,"What was your reason for staying inside?"],[10247,10501,"Well, I was just doing my job."],[10531,10585,"Well, it's wonderful-"],[10585,10710,"Captain Jackson,"],[10794,10906,"I just wanted to say"],[10906,11158,"on behalf of my father's hospital,"],[11211,11435,"thank you for saving our lives."],[11463,11599,"You are truly a hero."],[11632,11757,"It's no problem."],[11757,12007,"If you must be tired after all that,"],[12007,12087,"you could use a little rest."],[12116,12345,"Why don't we go back to my VIP lounge"],[12345,12520,"and have a little fun?"],[12631,12773,"Thanks, but no thanks."],[12773,12899,"I actually have to check on a patient."],[12899,12992,"Thank you for your time."],[12992,13070,"Oh, no problem."],[13100,13200,"I'll come with you."],[13530,13699,"Time to get back to work, Cindy White."],[13699,13799,"Clock's ticking."],[13868,13959,"Okay, Vanessa."]],"5":[[37,70,"Jackson?"],[141,225,"Excuse me?"],[312,629,"That is Captain Jackson Carter to you."],[704,939,"He's L.A.'s hottest,"],[942,1205,"bravest, most badass firefighter."],[1297,1437,"And he just saved your worthless life."],[1437,1557,"Vanessa, please."],[1565,1801,"That's not necessary."],[1801,1920,"Where is his thank you?"],[2118,2213,"You know, he could've died"],[2213,2345,"pulling your ass out of that fire."],[2498,2731,"And if something had happened to him,"],[2731,2960,"I would have made you pay for it, trust me."],[3019,3259,"I wasn't in the fire by choice, Vanessa."],[3353,3574,"Don't talk back to me, Cindy!"],[3704,3817,"I'm your boss."],[3817,3983,"My dad owns this hospital."],[4058,4153,"I'm well aware."],[4262,4544,"I am so sick of your temper."],[4633,4727,"You know what?"],[4783,4919,"You're fired."]],"6":[[16,91,"You know what?"],[150,292,"You're fired."],[375,422,"What?"],[508,718,"Come on, Vannassa. I need this job."],[813,981,"Well, maybe you should have thought about that"],[981,1231,"before you talked back to the boss's daughter."],[1334,1388,"Come on."],[1447,1614,"Let's go somewhere more private."],[1614,1685,"You know,"],[1739,1943,"now that I think about it, there is a new opening"],[1943,2110,"for a paramedic in my department."],[2156,2323,"I would be so honored."],[2323,2491,"If someone's just became available."],[2590,2679,"Cindy!"],[2861,2992,"How would you like to join my team?"],[3019,3115,"What?"],[3215,3341,"A paramedic job?"],[3373,3493,"What's the catch, Jackson?"],[3493,3583,"What game is this?"]],"7":[[141,321,"Thank you so much, but"],[367,564,"I can't accept. I'm sorry."],[692,831,"I would be so..."],[831,984,"Mommy! Mommy!"],[1034,1099,"Hi baby."],[1099,1263,"I'm sorry. I just ran out of space."],[1263,1313,"That's okay."],[1530,1919,"Great. Just what I need. More nobodies."],[1939,2043,"Alright, I'm almost ready."],[2043,2237,"Thank you for saving my mom."],[2237,2268,"Oh."],[2515,2715,"Just doing my job."],[2869,2980,"You have a son?"],[3061,3321,"Uh, yeah. This is Noah."],[3357,3569,"Hi, my name is Noah. Nice to meet you."],[3703,3939,"Hey. Nice to meet you."],[4012,4157,"I'm Jackson."],[4300,4497,"Wait. You're my dad!"],[4604,4669,"Noah?"],[4717,4813,"You didn't tell him-"],[4813,4854,"No."],[5004,5114,"That's not funny."],[5217,5332,"I'm so sorry."],[5417,5569,"We have to go get ice cream."],[5569,5680,"- Yeah! - Right? Let's go!"],[5680,5797,"I love ice cream!"],[6343,6525,"Noah, why did you call Jackson dad?"],[6539,6762,"He looks like my dad from my dream."],[7369,7535,"So, after she broke up with me,"],[7561,7762,"she had a kid with Gary?"]],"8":[[846,1081,"So your love life is a disaster."],[1267,1393,"Tell me something I don't know."],[1497,1576,"But,"],[1576,1676,"but, but, but, but,"],[1676,1818,"your soul mate's here"],[1856,2008,"and true love follows."],[2093,2268,"Is there anything in here about money?"],[2356,2551,"Love's not paying the rent, honey."],[2577,2723,"Jackson's job would."],[2848,2957,"That's not gonna happen."],[3040,3241,"Okay, well, argue with the cards, honey."],[3257,3442,"You're fated to take this gig."],[3474,3620,"Marry the love of your life"],[3620,3836,"and live happily ever after."],[3958,4079,"Okay, see, this is why I"],[4079,4258,"don't believe in tarot."],[4258,4426,"My life has never been this neat."],[4487,4580,"Okay, well, good thing"],[4580,4716,"you don't have to believe in it"],[4716,4890,"for it to be true."],[5000,5180,"Jackson loves you and I don't"],[5180,5330,"need the cards to know that."],[5509,5799,"Okay, we're done conversation."],[5879,5987,"Run all you want."],[5987,6119,"Fate comes for us all."],[6119,6238,"Goodnight."],[6289,6416,"Mark my words, honey."],[6416,6552,"You two are not over."]],"9":[[782,895,"Uh-hem."],[1063,1162,"What do you want, Vanessa?"],[1188,1383,"Just making sure you're not stealing anything."],[1514,1596,"Strip search her."],[1739,1830,"What? Excuse-"],[1847,1942,"No, are you kidding?"],[1964,2239,"What is, excuse- Are we in high school?"],[2335,2454,"Wait, what?"],[2485,2602,"- Hey! - Good, strip or top?"],[2602,2715,"She might be hiding medicines under it."],[2715,2907,"Vanessa, what is this?"],[3199,3232,"Let's go."],[3303,3511,"No, no! Wait, no!"],[3557,3694,"Enjoy the chill time, bitch."],[3832,3887,"Come on."],[4029,4226,"Fuck, Vanessa."]],"10":[[20,154,"Thanks for implementing the new"],[154,299,"safety measures, Captain Carter."],[308,396,"For the last time."],[450,542,"Call me Jackson."],[575,663,"I'm just doing my job."],[734,901,"You're too modest, Jackson."],[1144,1230,"Help!"],[1259,1422,"Somebody help, please!"],[1589,1664,"Cindy!"],[1760,1847,"Hello?"],[1914,1970,"Cindy!"],[2041,2083,"Jackson!"],[2092,2148,"Hey!"],[2148,2256,"Hi, can you help me?"],[2535,2585,"Alright, stand back."],[2619,2648,"Okay."],[3257,3299,"Oh my God!"],[3349,3478,"- Wait, turn around! - Okay."],[3570,3623,"Here."],[3741,3788,"Jackson."],[3828,3897,"I'm not looking."],[3916,3981,"Wait, the door!"],[3981,4084,"I'm not looking! Oh shit!"],[4260,4336,"Fuck."]],"11":[[0,56,"Wait, the door!"],[56,173,"I'm not looking! Oh shit!"],[319,381,"Fuck!"],[496,558,"Great!"],[658,846,"Now we're both stuck in here."],[1568,1605,"Damn."],[1634,1826,"Is he sexier than I remember?"],[2022,2165,"You know it's rude to stare."],[2239,2319,"Jerk."],[2573,2727,"So, when did you have a kid?"],[2777,2886,"When did you come back?"],[2940,3150,"Captain Jackson Carter."],[3269,3319,"Why are you here?"],[3407,3511,"What do you want from me?"],[3545,3711,"Well, I always said I'd come back."],[3870,3964,"That was years ago."],[4003,4074,"We were kids."],[4124,4235,"Doesn't make it not true."],[4608,4703,"What about you?"],[4771,4850,"No ring?"],[4879,5004,"No Gary in sight?"],[5004,5204,"I guess that happily ever after didn't work out."],[5213,5242,"Hey."],[5251,5351,"You just got fired."],[5351,5467,"Just take my job."],[5518,5623,"Okay? It's a good offer."],[5634,5681,"No!"],[5730,5830,"I don't need your offer."],[5893,6026,"I don't need you to rescue me."],[6068,6117,"Again."],[6151,6291,"What are you so afraid of?"],[6398,6507,"Think about your son."],[6614,6705,"He's got a point."],[6735,6821,"I do need a job."],[6856,6925,"And money."],[7220,7296,"Fine."],[7378,7461,"I'll take your offer."],[7503,7590,"And I'll be the best"],[7590,7716,"paramedic therapist on the team."],[7795,7957,"It'll be your ass getting saved by mine."],[8041,8269,"I saw her sneak into storage."],[8269,8379,"She's up to something."]],"12":[[26,245,"I saw her sneaking to the storage room."],[265,393,"She's up to something."],[393,727,"Probably stealing meds or case files or worse..."],[804,892,"I'm sorry to think she's"],[892,998,"the one who started to fire."],[1130,1287,"You're finished, thief."],[1577,1757,"What? What is it?"],[1964,2041,"Jackson?"],[2327,2512,"But I only locked her in here."],[2531,2728,"Oh. Thanks for the confession."],[2752,2838,"You bitch!"],[2838,2902,"Enough."],[2965,3174,"Stop embarrassing yourself, Vanessa."],[3224,3465,"I am so sorry for my daughter's behavior."],[3516,3657,"Ms. White, Mr. Carter..."],[3657,3812,"You're apologizing to her?"],[3812,3874,"Shut up!"],[3937,3974,"Let's go."],[4702,4758,"Well."],[4900,5294,"Thank you for saving me again."],[5323,5535,"Well, I wouldn't call getting us both trapped"],[5535,5718,"in that room much of a rescue."],[5801,5855,"But I take it."],[6001,6127,"Excited to see you at work?"],[6247,6300,"Whatever."],[6900,6961,"Hello?"],[6981,7087,"Hello, Miss White."],[7087,7248,"It's Principal Colin."],[7248,7381,"Your son got into a fight."],[7381,7523,"You need to come. Now."],[7545,7600,"What?"]],"13":[[133,353,"Noah, are you hurt? Let me see."],[363,475,"Is he hurt?"],[509,724,"He's the one who attacked my son!"],[804,1033,"Oh, I'm sorry. If-"],[1059,1305,"If your son needs a doctor, I can cover it."],[1305,1543,"I don't need your money. I have money."],[1618,1866,"What I want is this animal,"],[1866,2054,"or what you call a son,"],[2160,2264,"expelled."],[2398,2460,"What?"],[2615,2781,"You're not gonna do that, right?"],[2781,2980,"Well, per school policy,"],[2980,3232,"serious violence does warrant expulsion."],[3236,3374,"But he started it!"],[3395,3556,"He called me a bastard."],[3556,3879,"He said... He called my mom a-"],[3903,3997,"A slut!"],[4195,4327,"My mom says the kids like you"],[4327,4444,"don't know your dad"],[4444,4756,"because your mom's a total slut."],[4767,4829,"Shut up!"],[4850,4971,"Hey! Don't!"],[4971,5059,"You little-"]],"14":[[0,80,"Shut up!"],[80,196,"Hey! Don't!"],[196,321,"You little-"],[846,960,"Jackson!"],[975,1060,"You okay, kiddo?"],[1076,1292,"Let go of me! How dare you!"],[1322,1542,"Mr. Carter, hero of the city!"],[1601,1770,"You know the White family?"],[1888,1988,"I do."],[2032,2293,"President Colin, I didn't know you"],[2293,2523,"allowed such bad decorum."],[2635,2823,"Excuse me? You little son of a-"],[2840,2891,"Enough!"],[3061,3407,"Mr. Carter, I apologize for this incident, and"],[3407,3733,"you, you, you, apologize to Noah!"],[3789,3903,"No way!"],[3903,4141,"This bastard attacked my son!"],[4149,4345,"This man has saved our school"],[4345,4457,"and countless others,"],[4457,4635,"and it's a price we could never hope to repay."],[4846,5035,"Actually, there is a way to pay it back."],[5067,5132,"Really?"],[5159,5356,"Well, just tell me how."],[5556,5649,"Expel that boy."]],"15":[[16,87,"Expel that boy."],[229,273,"Alright."],[291,346,"Son, you are-"],[346,423,"Wait, wait, wait, wait."],[471,707,"No, we don't want to expel him."],[709,771,"We don't?"],[771,809,"We don't?"],[829,867,"We don't?"],[930,984,"No, we don't."],[1017,1075,"No."],[1130,1259,"Both boys were in the wrong."],[1276,1343,"- No, I wasn't! - No, I wasn't!"],[1522,1810,"You said extremely rude things to Noah and me,"],[1810,1939,"and you need to apologize."],[2010,2230,"And Noah, you can't hit someone,"],[2230,2401,"no matter what they say, okay?"],[2406,2518,"You need to say sorry."],[2523,2821,"My son will not be apologizing for it."],[2821,3138,"I just saved your son from expulsion."],[3353,3392,"Son?"],[3486,3553,"Say you're sorry."],[3591,3626,"But?"],[3838,3931,"I'm sorry."],[4012,4094,"What was that?"],[4191,4275,"I'm sorry."],[4329,4400,"Good."],[4466,4527,"Noah?"],[4642,4764,"I'm sorry, I guess."],[4946,5165,"I think you owe Miss White an apology, too."],[5442,5664,"I am sorry, Miss White."],[6477,6575,"See?"],[6623,6723,"Your mom's a smart cookie."],[6798,6898,"I shouldn't have tried to expel that boy,"],[6970,7165,"the same way you shouldn't have tried to fight him."],[7228,7533,"Next time, just come to us or the principal, okay?"],[7565,7612,"OK."],[7612,7674,"Okay."],[7836,7901,"Nice."],[8145,8330,"Why does Captain Carter know the Whites?"],[8337,8387,"Is-"],[8479,8749,"Is he Noah's dad?"]],"16":[[0,190,"How does Captain Carter know the White family?"],[190,226,"Was..."],[291,448,"Is he Noah's dad?"],[579,633,"Noah, come here."],[742,876,"Uh, Principal Colin,"],[876,1013,"this isn't what it looks like."],[1013,1200,"Oh, no, no, no. Do not worry, Miss White."],[1217,1298,"Mum's the word."],[1393,1511,"You won't get a peep out of me."],[1568,1705,"But there's nothing to..."],[1705,1804,"Oh, no, do not fret."],[1956,2144,"We're gonna take very special care of Noah."],[2164,2307,"Both for you and for..."],[2650,2737,"Just for you."],[3044,3207,"So, what were you and"],[3207,3394,"Principal Colin whispering about?"],[3461,3540,"Nothing."],[3695,3799,"Really?"],[3799,3931,"It seemed like something."],[4016,4070,"Nothing."],[4191,4315,"For you to know about."],[4346,4588,"Ah, excellent qualifier."],[4663,4775,"Hey! You wanna race?"],[4775,4821,"Yes."],[4821,4915,"Yeah? Alright, go."],[4934,5127,"Come on. Come on, beating you."],[5163,5256,"Come on, hurry up."],[5459,5636,"Maybe I should tell him he's the father."],[5672,5806,"He's so good with him."]],"17":[[0,177,"Go! Go! Go! Go! Go!"],[212,316,"Hi."],[329,387,"Hey."],[387,487,"Can we take a selfie?"],[487,705,"I love your fire safety TikTok videos."],[717,937,"And I adore your calendars."],[959,1107,"No, those are bad."],[1163,1311,"Yeah, let's do it."],[1497,1547,"Nice!"],[1609,1823,"Jackson, could I have your phone number?"],[1864,1978,"If I'm ever feeling"],[1978,2149,"lightheaded in the bath,"],[2152,2369,"could I call you for a personal rescue?"],[2402,2477,"Wow, she's bad."],[2477,2505,"Hey!"],[2598,2740,"Before you play with your little fan club,"],[2740,2890,"can you make sure my kid's okay?"],[3082,3157,"He was just right here."],[3220,3301,"Yeah, he almost just"],[3301,3420,"ran in the middle of the street."],[3549,3722,"Nope. I can't tell him he's a father."],[3722,3925,"I can't flip Noah's world upside down like that."],[3961,4035,"Here."]],"18":[[175,362,"Hey, you never answered my question!"],[362,501,"Oh, uh, in case of emergency,"],[501,624,"just call 911."],[624,675,"Okay."],[729,821,"Cindy, hold on! Wait up!"],[938,1152,"Sorry about that, that, uh, never happens."],[1184,1407,"What now, superstar hero?"],[1437,1738,"Well, you know, with your new job,"],[1738,1970,"it actually comes with a company house."],[2077,2143,"I don't care."],[2152,2236,"No, thanks."],[2248,2300,"It's free."],[2577,2986,"Well, then I guess we can move in."],[3032,3261,"Great! Awesome! Okay."],[3261,3423,"What's... where you at now?"],[3423,3500,"I can help you move."],[3524,3645,"That's not necessary."],[3645,3832,"47-Pine Lane apartment 4B."],[3858,3979,"Boom! See?"],[4079,4229,"That's why you're the man of the house."],[4250,4405,"You little conspirator."]],"19":[[892,967,"Whoa!"],[1076,1235,"My new room is so huge."],[1255,1438,"Can I go unpack my toys and go play?"],[1447,1532,"Absolutely."],[1701,1789,"You got it?"],[2506,2560,"Well,"],[2635,2773,"now that we're all alone..."],[3490,3589,"It's time to get sweaty."],[3616,3677,"Excuse me."],[3782,3895,"I'm packing, Cindy."],[3941,4049,"Mind out of the gutter."],[4241,4445,"That was definitely on purpose."],[4705,4769,"Oh, hey."],[5050,5103,"Let me."],[5538,5597,"Oh!"],[5672,5768,"I got it."],[5839,5940,"Die, die, die!"],[6919,6969,"What?"],[7076,7132,"Come here."],[7194,7333,"She's finally giving me a shot?"]],"20":[[399,492,"- Ow! - Ow!"],[734,900,"What was that for?"],[917,1062,"I was trying to kiss you."],[1105,1141,"What?"],[1213,1278,"Why?"],[1278,1419,"You said come here."],[1430,1634,"There's something on your face."],[1893,2082,"Sorry, I'm not swooning over you"],[2082,2217,"like all the other moms."],[2423,2516,"Okay."],[2594,2775,"Well, I guess I'll get going,"],[2865,3047,"but be sure to say hi to your neighbor."],[3103,3182,"I heard he's a"],[3182,3536,"great, handsome, charming, athletic,"],[3557,3895,"fun, smart, intelligent guy."],[4008,4154,"What?"],[4804,4929,"Wait, you're my neighbor?"],[5234,5305,"Guess so."],[5484,5520,"Huh."],[5686,5814,"How convenient."]],"21":[[325,387,"Dude!"],[759,892,"Why the long face, Jackson?"],[988,1088,"The one that got away"],[1088,1291,"is now in reaching distance."],[1343,1518,"Yeah, except she's got a kid"],[1559,1683,"with Gary."],[1764,1921,"The trust fund kid she left before?"],[1989,2035,"Yep."],[2193,2319,"Except she's broke."],[2352,2414,"Yeah, right."],[2481,2541,"He's loaded."],[2619,2745,"No, it doesn't make any sense."],[2815,2877,"Whatever."],[2877,2989,"I don't even care."],[2989,3196,"You know what? I'm over her, actually."],[3228,3398,"I'm Jackson Carter."],[3436,3687,"Alright, town hero. I can get whoever I want."],[3757,3823,"Right."],[3866,3987,"Get down on yourself, Jackson."],[4266,4382,"Hello, boys."],[4412,4502,"Party's arrived."],[4625,4804,"Vanessa, what are you doing here?"],[4863,4953,"You're acting all mopey,"],[4953,5097,"so I thought some company"],[5097,5184,"would do you some good."],[5230,5308,"Okay."],[5905,6117,"I'm sure that I'm much more fun"],[6117,6247,"than whoever she is, anyway."],[6247,6318,"Mm-hmm."],[6410,6533,"Let's get this party started."]],"22":[[241,283,"Cindy!"],[283,329,"Cindy!"],[829,921,"Cindy! Hi!"],[1092,1205,"Would you like to come in?"],[1309,1497,"Um, I just wanted to say thank you."],[1518,1626,"And now you have."],[1665,1715,"Bye!"],[1947,2081,"Would you like to come in?"],[2081,2206,"That's really sweet of you."],[2293,2398,"We'd love to have you."],[2469,2544,"About to play a game."],[2656,2719,"It'd be fun."],[3641,3820,"See? It's simple."],[3853,3991,"Even Cindy's brat could do it."],[4124,4208,"Get up. Let's play."],[4583,4650,"Hey."],[4658,4816,"You actually mind switching with Cindy?"],[5638,5720,"- Hey. - Hey."]],"23":[[79,181,"What the fuck?"],[333,399,"Oops!"],[450,546,"Guess I've got a little too much to do."],[546,664,"Vanessa, what's your problem?"],[671,821,"Don't yell at me, Jackson!"],[867,963,"I'm just having a little fun."],[1026,1139,"Is that too much for Cindy?"],[1272,1393,"I'm so sorry. Here."],[1647,1705,"Cin-"],[1801,1871,"Nice."],[2198,2344,"What are you two looking at?"],[2811,2865,"Hey."],[2965,3112,"Don't worry. I'm leaving."],[3140,3286,"I just don't want Noah to see me like this."],[3286,3403,"No, no, no, I'm sorry."],[3403,3527,"I don't know what that was."],[3532,3588,"Are you okay?"],[3803,3886,"What do you think?"],[4212,4251,"Sorry."],[4346,4399,"For that."],[4521,4689,"And for crashing your little party."],[4725,4829,"Looks like you and your fangirls"],[4829,4952,"were having fun without me."],[5167,5259,"Wait, hold on."],[5259,5450,"Do I sense a hint of jealousy?"],[5555,5623,"Do you like me?"]],"24":[[16,145,"Don't flatter yourself."],[171,333,"I'd never like an arrogant ass like you."],[454,683,"Oh, so you'd like a rich prick like Gary."],[813,980,"Gary, go home."],[980,1127,"We're not getting back together."],[1127,1274,"You psycho bitch!"],[1480,1614,"What are you talking about?"],[1630,1730,"Oh, stop, Cindy!"],[1764,1864,"Don't play dumb."],[1926,2014,"Alright, you dumped me"],[2014,2123,"for him eight years ago,"],[2123,2266,"and he's Noah's dad, right?"],[2698,2977,"You have no idea what you're talking about."],[3174,3274,"Okay, then tell me."],[3274,3457,"Cindy, please just tell me then."],[3745,4049,"Get rid of the baby and disappear from his life."],[4049,4437,"Or I swear I will destroy everything you have."],[4489,4579,"It's better he thinks"],[4579,4792,"Noah is Gary's kid than the truth."],[4885,5003,"It was over a decade ago."],[5055,5221,"Just let it go, Jackson."]],"25":[[83,216,"Maybe you want to forget about it"],[291,371,"because you don't want to"],[371,618,"come to terms that you traded love,"],[618,855,"real love, for money."],[938,1075,"You know,"],[1075,1257,"we could've had something together,"],[1257,1347,"we could've had a future together."],[1347,1418,"Jackson, please."],[1710,1897,"You know what? Fine. Here."],[1985,2084,"I don't want you to catch a cold."],[2727,2806,"Is that?"],[3232,3303,"Yeah, the ring?"],[3490,3620,"I've had it since the beginning."],[3895,4024,"Maybe this is stupid, but"],[4149,4325,"it's like my good luck charm."],[4391,4625,"Every time I have it with me, I..."],[4625,4825,"I can always make it through."],[4921,5093,"Jackson, stop."],[5372,5526,"Thank you for saving me."],[5680,5779,"For the job,"],[5779,6010,"for the house, the rescue... but"],[6056,6331,"let's just leave this, us, in the past."],[6418,6540,"We're colleagues now."],[6589,6778,"It's best that we keep it professional."],[7336,7453,"If that's what you want."],[7716,7799,"It is."]],"26":[[575,673,"Wow."],[767,1038,"Look, it's our new paramedic."],[1134,1223,"Can I help you guys?"],[1251,1505,"Yeah, I actually hurt myself on the last job."],[1539,1705,"I was wondering if you could take a look at it."],[1751,1776,"Oh."],[1889,2032,"You pulled your groin?"],[2160,2410,"Every night before bed, we were actually hoping"],[2410,2569,"that you might help us out with that."],[2581,2622,"Yeah."],[2656,2886,"Or is that just exclusively for Captain Carter?"],[3111,3240,"Do you guys have any real injuries?"],[3286,3396,"Yeah, yeah, yeah. Sorry."],[3595,3674,"You broke my heart?"],[3799,3858,"Wait, wait."],[3878,4003,"You broke my heart, too."],[4129,4166,"Alright."],[4173,4242,"Leave my station"],[4242,4375,"before I give you something to cry about."],[4421,4496,"Ooh."],[4637,4792,"Look, I don't think you know who"],[4792,4903,"you're dealing with, little girl."],[5000,5086,"But I do."]],"27":[[8,83,"But I do."],[513,596,"Jackson,"],[596,750,"we were just looking for you right now."],[750,937,"We couldn't find you, so we came over here."],[1134,1251,"We were just joking."],[1559,1705,"We were just hazing the new guy!"],[1710,1839,"Okay, it was all the good fun."],[1901,2001,"What do you think, Cindy?"],[2035,2134,"Is it all in good fun?"],[2310,2342,"Well."],[2402,2460,"You heard her."],[2489,2560,"Hey, hey, hey, please..."],[2598,2669,"Look look."],[2748,2852,"We're sorry, boss."],[2852,2894,"Alright?"],[2898,3017,"- We're sorry. - We're sorry, Cindy."],[3282,3332,"Go."],[3737,3797,"Hey, you okay?"],[3807,3908,"I'm sorry about that."],[4045,4111,"Yeah, I'm fine."],[4183,4288,"Thanks to you."],[4358,4437,"Just doing my job."],[4550,4662,"Well, you're a man making it"],[4662,4796,"impossible for me to do mine,"],[4796,4939,"so I'm going to quit."],[5009,5059,"Wait, what?"]],"28":[[7,57,"Wait, what?"],[57,179,"No, no, no, you can't quit."],[179,340,"You just started."],[375,600,"If I wanted to be mocked every day, then I would"],[600,789,"just beg Vanessa for my job back."],[817,950,"This will never happen again."],[950,1125,"It's a one-time occurrence, I promise."],[1180,1288,"If it ever happens again..."],[1801,1957,"That was a pretty gnarly punch."],[2093,2135,"Let me see."],[2285,2532,"It's a pretty gnarly swelling."],[2635,2703,"It's nothing."],[2756,2877,"Yeah, whatever."],[3236,3420,"You saving me for once."],[3557,3661,"Just doing my job."],[3945,4049,"You know you're different now."],[4158,4262,"When we were younger,"],[4262,4554,"you are stronger and tougher."],[4788,5169,"Well, being a single mother will do that to anyone."],[5194,5267,"You should try it."],[5509,5634,"You've been alone this whole time?"],[6214,6389,"Just make sure that your hand is dry"],[6389,6513,"for about three hours."],[6513,6656,"I gotta go get organized."],[6819,6981,"I guess I'm staying."],[7599,7845,"So, Gary just abandoned her?"],[7924,8028,"I need to know more."],[8095,8324,"Cindy won't tell me. I'll go to Gary."]],"29":[[229,442,"I can't believe the dweeb I used to know"],[442,613,"has become the hometown hero."],[650,809,"Man, it's been too long."],[838,892,"How you been?"],[892,988,"What brings you in today?"],[1109,1372,"You have no idea what you're talking about."],[1572,1698,"Just got some questions."],[1856,1905,"About Cindy."],[2001,2075,"Oh, that broad."],[2147,2306,"Oh, she's got issues, man."],[2364,2385,"Yup."],[2406,2569,"She begged me to come back to her."],[2635,2694,"And then"],[2694,2932,"after she dumped you, she told me that"],[2932,3040,"she didn't even want to be with me."],[3336,3463,"What about Noah?"],[3495,3623,"Who the fuck is Noah?"],[3732,3799,"Come on, man."],[3799,3878,"It's been years."],[3895,4079,"Let's talk about something that matters."],[4079,4200,"Forget that psycho bitch."],[4200,4366,"Like, I got something real for you."],[4387,4483,"Oh, fuck!"],[4483,4585,"Insult her again!"],[4854,4892,"Fuck."],[4988,5113,"Yo, you're loco, man."],[5150,5331,"You two deserve each other."],[5438,5650,"If Gary's not the father, then who is?"],[5834,5961,"What the hell is going on, Cindy?"]],"30":[[358,491,"Mom, this is disgusting."],[579,613,"Noah."],[625,813,"Hey, Cindy, I need to-"],[825,891,"Save us."],[1076,1142,"What's up, little man?"],[1180,1326,"Mom can't cook to save her life."],[1430,1516,"Excuse me."],[1547,1655,"Yeah, he's not lying."],[1822,1843,"Fine."],[1935,2116,"Last time I did everything nice for you people."],[2227,2348,"Okay, tell me, how do you"],[2348,2425,"like your burger cooked?"],[2477,2544,"Medium rare."],[2677,2778,"No way."],[2806,2876,"Me too."],[2969,3082,"You know what that makes us?"],[3082,3107,"What?"],[3186,3259,"Taste buds."],[3453,3649,"Oh my gosh, how you guys share all those"],[3649,3812,"similarities, you two are not related?"]],"31":[[216,279,"You alright?"],[304,350,"Mm-hmm."],[362,383,"Yeah."],[458,502,"Wrong pipe."],[742,1023,"Listen, can you watch Noah for a second"],[1023,1095,"while we-"],[1109,1250,"we clean up the plates."],[1280,1426,"There're only two plates, so-"],[1447,1505,"Amanda."],[1580,1693,"Help me clean up the plates."],[1730,1764,"Okay."],[1901,2043,"I'll help you clean up the plates."],[2312,2419,"I, um..."],[2469,2594,"Actually, I'm gonna go"],[2594,2698,"talk to your mom real quick,"],[2698,2841,"but you stay here, okay?"],[2852,2892,"Okay."],[2898,3015,"Yeah, hold down the fort for me."],[3061,3211,"Alright. I'll be right back."]],"32":[[246,311,"What are you doing?"],[442,625,"It's already as difficult as it is."],[671,798,"Jackson isn't stupid."],[817,884,"He's gonna find out"],[884,1008,"eventually that he's not the father,"],[1008,1172,"and then what are you gonna do about it?"],[1172,1263,"Hey, what you guys talking about?"],[1472,1539,"What did you hear?"],[1664,1727,"Nothing."],[1897,2010,"You mind if I talk to Cindy"],[2010,2096,"for a second alone?"],[2227,2391,"Yeah, I have to use the bathroom anyway."],[2761,3007,"You and Noah are getting along great."],[3007,3137,"Oh yeah, he's a great kid."],[3240,3439,"You know, I'd love to help out more"],[3439,3549,"if you'd let me."],[3578,3671,"Take him to school,"],[3671,3798,"pick him up from soccer practice,"],[3798,3866,"whatever you need."],[4312,4407,"Ice cream!"],[4542,4652,"You wanna babysit?"],[4804,4954,"You're a fire captain, right?"],[4954,5092,"That's a little blow if you pay great-"],[5096,5185,"No, no, no."],[5234,5504,"I just want to be part of your guys' lives."],[5860,5959,"You know, and-"],[6076,6146,"Noah?"],[6156,6228,"Where's Noah?"],[6264,6285,"Shit."]],"33":[[684,802,"He lost a lot of blood."],[809,1036,"Is anyone a negative for a transfusion?"],[1046,1256,"I am, but I can't. I'm his mother."],[1305,1370,"Anyone else?"],[1397,1505,"I'm a universal donor."],[1509,1597,"Perfect, come with me."],[1597,1634,"Great."],[1634,1697,"No, no, no, no, no, no."],[1697,1785,"There has to be someone else."],[1793,1906,"Cindy, stop! There's no time."],[1906,2031,"No, it can't be you."],[2035,2113,"Why?"],[2127,2252,"Why won't you let me help him?"],[2252,2314,"No!"],[2339,2457,"Okay, I don't need your help."],[2519,2565,"Leave."],[3182,3269,"I'm sorry."],[3707,3922,"Cindy, I know you're scared."],[3953,4116,"But the longer you keep this a secret,"],[4116,4208,"the more pain it's gonna"],[4208,4332,"cause for both of you."],[4429,4568,"I just don't know what to do right now."],[4568,4612,"I know."],[4846,4917,"Good news."],[4984,5112,"We've located thermoplasma."],[5130,5296,"I just need your signature, okay? Right here."]],"34":[[200,246,"You know, it's just..."],[400,583,"Every time I feel like we're finally getting closer,"],[583,678,"she shuts me out."],[678,750,"I don't get it."],[779,958,"I mean, she's been alone for so long,"],[958,1155,"and we can't really end up well last time."],[1209,1333,"What if she's just scared?"],[1393,1508,"What, and I'm not?"],[1508,1652,"Well, she's the one who dumped me."],[1676,1810,"Yeah, I know. I know."],[1830,1910,"How about she wouldn't even"],[1910,2027,"let me donate blood to Noah?"],[2106,2250,"Luckily, we found a plasma donor,"],[2250,2338,"but what if we didn't?"],[2423,2560,"Why won't she let me help?"],[2577,2785,"Wait, they didn't let you donate?"],[2836,3037,"No! That's crazy, right?"],[3103,3288,"Wait, didn't you say Gary wasn't the father?"],[3336,3550,"Yeah. And?"],[3603,3762,"Direct relatives can't give blood"],[3762,3941,"to other direct relatives, so..."],[4029,4224,"Yo, what if you're Noah's dad?"],[4909,4990,"You're my dad!"],[5055,5129,"Taste buds."],[5201,5363,"Who the fuck is Noah?"]],"35":[[525,617,"Amanda's right."],[617,777,"I can't keep hiding this."],[777,1038,"Jackson deserves to know, and Noah does too."],[1509,1559,"How's he doing?"],[1659,1710,"Good."],[1910,1930,"Hey."],[2010,2089,"We need to talk."],[2302,2389,"I talked to Gary."],[2527,2560,"What?"],[2660,2769,"You had no right to do that."],[2773,2865,"You wouldn't tell me anything,"],[2865,2973,"I needed answers."],[3236,3269,"Cindy."],[3482,3579,"Is Noah my son?"],[4225,4462,"I mean, that's the only thing I can think of"],[4462,4614,"why you wouldn't let me donate blood."],[4713,4903,"I mean, when I first met him,"],[4903,5038,"we had an instant connection."],[5109,5229,"And every time I've seen him since,"],[5296,5543,"I've realized that he eats like me,"],[5609,5830,"he talks like me. Hell, he even looks like me."],[5980,6114,"Why won't you tell me?"],[6189,6340,"Is Noah my son?"],[6456,6706,"Cindy, just tell me, is Noah my son?"],[6715,6787,"Yes!"],[7065,7157,"Noah is your son."]],"36":[[417,542,"Why wouldn't you just say that?"],[679,955,"How could you hide this from me for eight years?"],[955,1034,"What could I have possibly"],[1034,1188,"done to you that was so bad?"],[1251,1576,"Did you know when you broke up with me?"],[1714,1830,"Get rid of the baby,"],[1893,2031,"and disappear from his life."],[2031,2427,"Or I swear I will destroy everything you have."],[2540,2610,"But I love him!"],[2877,2993,"We love each other."],[3249,3604,"If you really love him, then walk away."],[3670,3812,"My son deserves better."],[4354,4643,"Jackson, I was so young, and I was scared."],[4758,4927,"And you had all these big dreams"],[4927,5030,"that you had to go do."],[5113,5278,"The stupid firefighter program?"],[5278,5410,"You thought I cared more about that"],[5410,5613,"than him, than you?"],[5613,5752,"No, no."],[5809,6011,"I knew that you didn't."],[6093,6186,"That's why I left,"],[6186,6352,"because I knew that you wouldn't."],[6464,6610,"But Jackson,"],[6760,6902,"you didn't fight me on it."],[6940,7289,"You never asked me to stay."],[7289,7340,"Well, because you said"],[7340,7491,"you didn't love me anymore."],[7532,7598,"What?"],[7607,7791,"I never stopped loving you."],[7949,8341,"Jackson, for every second of every day"],[8341,8493,"for the last eight years,"],[8516,8683,"I've been waiting for you,"],[8758,8926,"hoping that you'd call"],[8926,9084,"or you'd text."],[9175,9315,"Something! Anything!"],[9718,9897,"I've dreamed about telling you about Noah."],[9989,10101,"I wasn't strong enough."],[10314,10534,"I just... I wish I had been brave"],[10534,10677,"and I didn't let your mother–"]],"37":[[383,600,"Looks like the cat's finally out of the bag."],[700,826,"Um, it's just-"],[855,967,"We were just, uh-"],[967,1150,"I thought I said no more lies."],[1438,1493,"There's no more."],[1918,2014,"Hey, you know what?"],[2147,2275,"Noah's birthday is tomorrow."],[2448,2581,"You know what he's always wanted?"],[3098,3219,"A Dad?"],[3349,3445,"Bingo."],[3712,3836,"I know just what to do."],[4959,5021,"So,"],[5021,5205,"what kind of cake would the birthday boy like?"],[5501,5651,"Honestly, I have no idea."],[5776,5918,"New to this whole dad thing, huh?"],[5922,6111,"Yeah, just found out 20 minutes ago."],[6122,6202,"He doesn't even know."],[6252,6361,"Oh, wow."],[6381,6614,"OK, well, let's just start with his name, then."],[6715,6826,"Noah, I do know that."],[6869,6902,"Gotcha."],[7057,7106,"Thanks."],[7640,7799,"Noah is Jackson's son?"],[8078,8356,"I am going to mess you up, Cindy White."],[8608,8693,"Wait, sir."],[8796,8873,"I need an address."],[9150,9204,"I'll tell you."],[9367,9421,"Don't worry."],[9421,9520,"I'm a friend of the family."]],"38":[[120,225,"Cake for Jackson?"],[246,400,"That's me. Thank you, sir."],[412,462,"No problem."],[1030,1119,"Are you nervous?"],[1234,1364,"Isn't that obvious?"],[1438,1539,"Don't be. You'll be great."],[1618,1741,"Don't worry. Once you're out of here,"],[1741,1926,"I'm gonna throw you the biggest party ever."],[1951,2056,"Who says we have to wait?"],[2314,2489,"Surprise! Happy birthday!"],[2544,2660,"You remembered!"],[2660,2761,"How could I forget the"],[2761,2940,"coolest kid in town's birthday?"],[3007,3107,"There you go."],[3153,3309,"Can I open it, Mom?"],[3315,3376,"Yes."]],"39":[[487,684,"I don't know what happened to this."],[684,759,"I'm so sorry."],[800,942,"It must have been some kind of mistake."],[942,1026,"Don't worry about that."],[1071,1222,"Why does everyone call me a bastard?"],[1280,1409,"Why don't I have a dad?"],[1856,1964,"No, you do have a dad."],[2014,2104,"I do?"],[2719,2838,"I'm your father."],[3161,3245,"Is that true?"],[3465,3750,"It's the best that I could possibly imagine."],[3912,4170,"But where have you been all my life?"],[4170,4346,"Did you not want to be my dad?"],[4508,4734,"Of course I wanted to be your dad."],[4792,5116,"I was... I was just scared."],[5163,5258,"Why?"],[5438,5660,"You know, every day I put my life"],[5660,5834,"out on the line, fighting fires."],[5889,6040,"I was just afraid that maybe one day"],[6040,6151,"I wouldn't be able to come home."],[6314,6510,"But, uh, you know, thanks to your mom,"],[6735,6952,"I'm finally brave enough to be here for you."],[7190,7307,"Can you forgive me?"],[7361,7432,"Of course."],[7494,7557,"Dad."]],"40":[[50,99,"Yeah?"],[99,185,"Are you excited?"],[216,253,"Yeah."],[404,604,"Noah, you're alive!"],[633,775,"Yes, and I have a dad."],[829,985,"Whoa, is that him?"],[1084,1182,"That's me."],[1280,1497,"You're the firefighter from the news."],[1497,1638,"Hey, nice to meet you."],[1668,1769,"I'm Noah's dad."],[1868,1989,"Can we take a selfie?"],[2052,2176,"Um, yes."],[2210,2300,"We can."],[2356,2410,"Here we go."],[2731,2798,"Beautiful."],[2819,2936,"Thank you."],[3007,3203,"Your dad is so cool."],[3203,3250,"I know."],[3261,3357,"You wanna hear some firefighting"],[3357,3465,"stories he told me?"],[3503,3666,"He was totally showing off."],[3699,3771,"Yeah?"],[4187,4258,"What a great kid."],[4421,4475,"Oh, who's it?"],[4646,4771,"Harry at the station."],[4771,4860,"Let me take this."],[4954,4996,"Hey."],[5171,5246,"It's ready?"],[5313,5397,"Okay, great."],[5397,5488,"I'll be there as soon as I can."],[5526,5743,"I thought we were done with the lies."]],"41":[[358,486,"Jackson has a son?"],[621,788,"Out of all people, it's Cindy."],[788,842,"I know."],[842,1042,"But I taught brat a lesson."],[1130,1301,"Wrote bastard on his birthday cake."],[1455,1543,"Genius."],[1672,1726,"Show me that."],[1768,1884,"That's a personal order."],[1976,2052,"Did I ask?"],[2627,2698,"It's stunning."],[2994,3078,"It's engraved."],[3148,3330,"Says it's for..."],[3578,3656,"Cindy White?"],[3778,3888,"Whose order is this?"],[3920,3990,"Jackson Carter."],[4079,4221,"The Jackson Carter."],[4258,4363,"The fire captain?"],[4671,4942,"She's baby-trapping him and he's falling for it."],[5030,5212,"Not on my watch."]],"42":[[433,475,"It's ready?"],[542,729,"Okay, great. I'll be there as soon as I can."],[1238,1300,"Hey, baby."],[1514,1594,"What's on your mind?"],[1764,2116,"Um, the call you got earlier..."],[2223,2431,"I kind of overheard it."],[2635,2750,"Thought there was gonna be no secrets,"],[2750,2802,"remember?"],[3549,3666,"You may have noticed I'm not"],[3666,3849,"wearing my necklace."],[3970,4308,"Yeah. That seems, um, strange."],[4391,4754,"It's because I took it to a jeweler and..."],[4846,5100,"La la la la la. Not listening, not listening."],[5125,5176,"You asked!"],[5209,5292,"- I... - What?"],[5292,5380,"Sorry, whatever you're saying,"],[5380,5476,"I can't hear you."],[5509,5647,"La la la la la la la la."],[5872,6068,"I should've never doubted the tarot."],[6068,6197,"I'm sorry."],[6297,6414,"I've accepted my fate."],[6414,6499,"Can you please just tell me"],[6499,6598,"if he's gonna propose?"],[6710,6840,"Amanda, please!"],[6840,6919,"Cindy White?"],[7052,7199,"Yes? Can I help you?"],[7199,7378,"Yeah, I was actually looking for a gas station."]],"43":[[0,162,"I was actually looking for a gas station."],[412,487,"Cindy, are you still there?"],[517,592,"No!!!"],[613,713,"You! Go in there!"],[1297,1351,"Hey!"],[1772,1839,"Jackson!"],[1964,2093,"These guys just kidnapped Cindy,"],[2093,2198,"and put her in their van."],[2198,2270,"- What? - Yeah."],[2270,2360,"Pull up the security cam footage!"],[2360,2427,"I'll call 911."],[2427,2510,"Yeah, yeah!"]],"44":[[0,133,"Let's go."],[646,675,"Buckle up."],[717,827,"You got a GPS location?"],[1380,1463,"Stay here."],[2198,2447,"Not so sassy now, are you?"],[2560,2666,"Vanessa, stop!"],[2998,3110,"Don't do something you'll regret."],[3240,3416,"Trust me, I'm not."],[3511,3726,"Don't do this. Let's just... Let's just talk."],[3820,3903,"About what?"],[3999,4200,"About you marrying the slut?"],[4262,4387,"Or about you crawling back to"],[4387,4526,"your family to get the location?"],[4587,4715,"I thought that you were never"],[4715,4838,"gonna go back to them, remember?"]],"45":[[0,237,"I know you're hurt, Vanessa."],[237,438,"It's just between me and you, okay?"],[438,579,"Just leave Cindy out of this."],[608,856,"This is a big misunderstanding, okay?"],[856,927,"What do you say?"],[1013,1149,"I say..."],[1338,1463,"Leave Cindy and marry me."],[2097,2240,"I can take that as a no."],[2323,2511,"God, you really love her, don't you?"],[2982,3044,"It's too bad."],[3194,3438,"Because I really didn't want to do this."],[3465,3720,"You're not really leaving me a choice."],[3724,3895,"Put the lighter down, let's just talk."],[4016,4237,"If I can't have you,"],[4279,4387,"she certainly can't."],[4387,4500,"Vanessa, no no no no!"]],"46":[[300,400,"Jackson is still in there!"],[421,492,"Go, go, go!"],[1505,1618,"Jackson, you're alive!"],[2072,2114,"Jackson!"],[2239,2285,"Jackson!"],[2360,2477,"Somebody help, please!"],[2635,2811,"Let go of me, you pig!"],[2911,3015,"Jackson is mine!"],[3065,3219,"Do you hear me? He is mine!"],[3219,3423,"Vanessa Reed, you're under arrest!"],[3478,3520,"Please."],[3657,3928,"Jackson, please hold on. Don't leave me."],[3991,4012,"Jackson."],[4279,4412,"You can't get rid of me that eas-"],[4491,4512,"No!"],[4596,4655,"Jackson!"],[4688,4779,"No, please!"],[4942,4998,"Please!"],[5159,5238,"Jackson!"]],"47":[[558,600,"Cindy."],[617,713,"Hi, Jackson."],[750,813,"Hi, I'm here."],[980,1038,"No, no, no."],[1088,1155,"Easy, easy."],[1192,1298,"I don't wanna push anything."],[1418,1544,"Can I get some water?"],[1555,1609,"Yeah. Please."],[1634,1714,"Yeah, sure, Dad."],[2027,2064,"Here you go."],[2152,2342,"Don't worry, we'll take good care of you."],[2915,3019,"Come here."],[3128,3353,"You're the best kid a guy could ask for."],[3411,3545,"I'll go grab your medicine!"],[3787,3945,"He's really stepping up."],[4029,4133,"It's amazing."],[4275,4379,"I can't believe I miss"],[4379,4529,"so much with his life, can you?"],[4633,4692,"I know."],[4829,4899,"Cindy."]],"48":[[0,45,"Mom?"],[179,322,"That must be your son."],[371,492,"He's so beautiful."],[608,730,"What are you doing here?"],[771,960,"How do you know about Cindy's son?"],[1130,1401,"Because I paid her to leave you."],[1447,1628,"So she wouldn't trap you with a baby."],[1885,2066,"I told her I'd ruin her life"],[2066,2189,"if she didn't leave you."],[2246,2302,"Wh-"],[2302,2511,"Is that what you're doing here now?"],[2531,2631,"To threaten her again?"],[2631,2656,"No."],[2740,2781,"Is that what..."],[2890,2940,"Mom?"],[2969,3007,"Get out."],[3061,3115,"No."],[3115,3132,"Mom?"],[3178,3292,"Get the fuck out of here!"],[3292,3349,"Go!"],[3349,3403,"Jackson."],[3403,3553,"I'm sorry, son."],[3553,3687,"I'm so sorry."],[3837,3858,"Cindy."],[3962,4018,"Why?"],[4095,4183,"Why didn't you just tell me?"],[4262,4409,"I thought you said no more lies."],[4717,4829,"I'm a mother now."],[5105,5308,"And even though I would never"],[5308,5480,"make the choices that you did,"],[5643,5780,"I can understand them."],[6035,6185,"I forgive you."],[6348,6491,"You're a strong woman, Cindy."],[6585,6760,"And an excellent mother."],[6886,6944,"Thank you."]],"49":[[62,279,"Jackson, I'm so sorry for everything."],[362,487,"When Cindy broke up with you,"],[487,667,"I saw how heartbroken you were,"],[721,809,"I immediately knew"],[809,963,"I'd made a terrible mistake."],[1155,1361,"But I knew you'd never stop fighting for her."],[1547,1655,"I truly want nothing"],[1655,1822,"but the best for both of you."],[2423,2623,"Dad, who's the crying lady?"],[2761,2844,"It's your grandma."],[2873,3019,"Why don't you give her a hug?"],[3274,3467,"Hi, Grandma. I'm Noah."],[3489,3589,"Hi, Noah."],[3799,3949,"Don't worry. It's okay."],[4162,4366,"Yes, it is now."]],"50":[[1026,1117,"Wow."],[1376,1493,"Where is the uniform?"],[1522,1594,"I got it."],[1604,1689,"Do you get the ring?"],[1818,1878,"I got it."],[1878,1922,"Alright."],[1989,2147,"Speaking of, how's Cindy getting here?"],[2147,2287,"Only the best is bringing her."],[2288,2481,"Mom, could you please go to dad's photo shoot,"],[2481,2694,"please, please, please, please?"],[2841,2907,"Fine."],[3023,3174,"You're actually so amazing."],[4008,4170,"What is going on?"],[4170,4283,"Surprise!"],[4416,4479,"What?"],[4546,4685,"What is all of this?"],[5213,5366,"I wanna make up for all the lost time."],[5497,5701,"Give Noah a home."],[5701,6060,"And a wedding you always deserve."],[6214,6281,"Cindy White."],[6527,6607,"Will you marry me?"],[6625,6701,"Yes!"],[6897,7121,"Yes, a million times, yes."]]}