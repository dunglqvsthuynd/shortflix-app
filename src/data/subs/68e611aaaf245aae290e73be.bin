{"1":[[0,160,"Can I have more coffee, please?"],[160,284,"Yeah, sure."],[1232,1324,"Simon."],[1372,1568,"The owner of the restaurant."],[1568,1714,"In his presence,"],[1714,1917,"my brain flies away somewhere,"],[1917,2066,"and my body feels like"],[2066,2220,"it's being electrocuted."],[2436,2644,"A brown three-piece suit."],[2644,2888,"Snow-white shirt. Perfect."],[3188,3288,"Hello, Claire."],[3440,3819,"Saffron. Amber. Rough leather."],[3852,4009,"Unsurpassed."]],"2":[[1460,1572,"Careful with hot coffee."],[1992,2092,"Thank you."],[2588,2716,"Did you see that?"],[2800,2952,"Boiling hot coffee…"],[3044,3216,"How did he hold it?"],[3272,3416,"You have something here."],[3652,3852,"I need to do laundry. See you."],[4320,4636,"Yeah… How did he hold it?"],[4650,4866,"You're a walking disaster, Claire…"],[5044,5191,"Always getting splashed."],[5249,5325,"God..."],[6408,6636,"Such a perfect body"],[6636,6748,"should be illegal."],[6796,6956,"You could wash laundry"],[6956,7101,"on those abs."],[7101,7209,"And his skin…"],[7244,7434,"Does he bathe in almond milk"],[7434,7652,"and the blood of angels? God…"],[7652,7772,"Are you spying?"]],"3":[[212,400,"No, I'm not a pervert, Sheila."],[464,645,"We're out of coffee. Arabica."],[720,944,"Yeah. I just wanted—"],[944,1040,"You wanted"],[1040,1176,"to complain to Simon…"],[1232,1341,"that I can't keep track"],[1341,1472,"of our coffee supply?"],[1472,1768,"What? No! I was looking for you."],[1816,1996,"We'll have coffee in 15 minutes."],[2256,2356,"But that…"],[2420,2687,"will be our little secret. Got it?"],[2784,2868,"Yes."],[3452,3536,"She scolded me"],[3536,3776,"while I was spying on Simon"],[3776,4082,"while he was… undressing."],[4188,4304,"Cerberus already knows"],[4304,4464,"that you're head over heels in love"],[4464,4540,"with him. So..."],[4704,4839,"Someone else will hear!"],[4864,4956,"Too late."]],"4":[[64,160,"You heard?"],[296,396,"And what exactly?"],[444,544,"That you are…"],[608,720,"head over heels in love."],[1192,1312,"Tonic with lime, please."],[1740,1884,"Well, \"head over heels\""],[1884,2092,"is clearly an exaggeration."],[2095,2295,"I'm not really in love."],[2336,2520,"Just a little bit."],[2628,2804,"And who is the lucky guy?"],[2910,3015,"Oh..."],[3260,3360,"Oh, it's…"],[3444,3540,"Michael."],[3624,3708,"Michael?"],[3756,3840,"Yeah, Michael."],[3840,3996,"A food blogger. Hi!"],[4956,5132,"Hi, Michael."],[5132,5332,"I know it's still 15 minutes"],[5332,5416,"before your birthday,"],[5416,5608,"but I thought—"],[5608,5760,"You know? You're incredible."],[5843,6063,"-Yeah? -Yeah!"],[6628,6720,"Yeah, uh—"],[7220,7340,"And what gift did your…"],[7412,7504,"boyfriend get you?"],[7552,7636,"You won't even look at it?"],[7968,8168,"And why are you so interested in me?"],[8168,8288,"What? Do you like me?"],[8544,8656,"Oh, Claire…"],[8820,8956,"That's a very,"],[8956,9198,"very dangerous game you're playing now."]],"5":[[0,128,"Oh, Claire…"],[297,422,"That's a very,"],[422,660,"very dangerous game you're playing now."],[896,1048,"Because if I say yes…"],[1208,1360,"I'll have to get rid of Michael."]],"6":[[168,268,"I'm sorry."],[440,764,"What? No! Why did he stop?"],[3412,3552,"Even the light condemns you…"],[3608,3700,"Pompous turkey."],[4244,4391,"Simon knew for sure…"],[4428,4617,"that I was talking about him."],[4652,4852,"And he was just mocking me."],[5220,5390,"What is this?"]],"7":[[1096,1480,"It's for me. But from whom?"],[2484,2636,"The Day of Inheritance?"],[2788,2888,"What?"],[3976,4288,"Okay, Claire. Just not today. Yeah."],[5220,5312,"Wonderful."],[6088,6362,"Happy birthday, Claire."]],"8":[[148,338,"I had to climb through my window"],[338,441,"this morning."],[616,728,"You should be flattered."],[880,1079,"Anonymous fans sending you"],[1079,1384,"birthday gifts? That's the dream."],[2176,2276,"Where did you get that?"],[2820,2912,"That's nothing."],[3024,3392,"I just had a little fun last night"],[3392,3700,"with, um… someone."],[3700,3792,"Never mind."],[4672,4776,"Nice."],[5660,5760,"Thank you, Michael."],[6504,6604,"Hello, Claire."],[6784,6996,"My eyes! My eyes!"]],"9":[[652,748,"I'm sorry."],[840,976,"I didn't want to scare you."],[1076,1320,"You wanted to. I'm sure of it."],[1508,1812,"Let's go. We need to rinse it off."],[1956,2068,"Is it getting better?"],[2140,2252,"Yeah."],[2376,2648,"So, what were you doing in the…"],[2748,2908,"women's locker room?"],[2908,3020,"I was looking for…"],[3212,3308,"you."],[3374,3532,"What? For me?"],[3580,3704,"To ask for forgiveness."],[3816,3971,"I almost crossed the line yesterday."],[4240,4612,"But I don't mind at all."],[4736,4836,"It's just lines."],[4836,4920,"Who invented them"],[4920,5032,"in the first place?"],[5136,5236,"So?"],[5284,5508,"You can cross the line…"],[6188,6328,"Trust me. You don't want this."],[6528,6627,"I want this."]],"10":[[124,216,"I want this."],[684,996,"May I? So, here's the new menu."],[996,1224,"Just let us kiss!"],[1868,2152,"My nose! I broke my nose!"],[2200,2302,"Call an ambulance. Now."],[2556,2648,"Let me see."],[2720,2820,"Come on, let me see."],[3116,3216,"What a draft."],[3504,3776,"I think it's tilted to the left!"],[4312,4448,"He almost kissed me"],[4448,4568,"for a second time."],[4616,4808,"God, I could feel his breath"],[4808,4910,"on my lips."],[4984,5120,"One more moment,"],[5120,5220,"and we would have—"],[5304,5584,"No, no more \"almost\"."],[5768,5911,"I'll just come in and say…"],[5944,6144,"\"I want this. You want this.\""],[6192,6504,"\"Yes? So, just let's go for it.\""]],"11":[[1144,1328,"So, that's him you were havin' fun with"],[1328,1428,"last night."],[1512,1870,"Traitor. Hypocrite."],[1944,2152,"May you break out in pimples!"],[2480,2564,"May they"],[2564,2748,"cover your entire perfect body."],[2748,2860,"Those hips that he kissed."],[2860,2952,"Those silicone tits."],[2952,3044,"And even your feet."],[3044,3220,"Yeah, especially your feet."],[3220,3332,"May they grow and grow"],[3332,3424,"and grow together"],[3424,3660,"until you become one big pimple!"],[4876,4996,"My God…"],[5088,5260,"What is wrong with me?"]],"12":[[0,300,"No… No, no, no…"],[668,808,"No… How—"],[856,1056,"How could this happen to me?"],[1104,1272,"Did I do that?"],[1272,1400,"No, no, no…"],[1716,1800,"No…"],[1800,1900,"No, no, no…"],[1900,2092,"No, no, no… That's impossible."],[2140,2336,"It's just a coincidence."],[2336,2480,"A common allergy."],[2480,2676,"Not another one! No, please!"],[2772,2932,"Please stop growing!"],[2932,3052,"The damn pimples!"],[3324,3452,"Why is she looking at me"],[3452,3564,"with such suspicion?"],[3628,3847,"It's like she already knows about Molly."],[3856,3988,"I'm finished."],[3988,4243,"I need to break up with him today."],[4320,4472,"Oh, it's so tasty."],[4472,4592,"What you looking at?"],[4664,4840,"Why am I doing this?"],[4840,4924,"I wanna hunt."],[4924,5128,"Where's that cake gonna fit,"],[5128,5252,"you cow?"],[5252,5364,"I need a drink."],[6748,6908,"Everyone, shut up!"]],"13":[[502,689,"I apologize, everyone, for that."],[689,792,"Everything's okay."],[792,888,"It's just fatigue."],[1224,1441,"Please continue enjoying yourselves."],[1497,1583,"Thank you."],[2180,2284,"What happened?"],[2348,2448,"It's nothing."],[2448,2588,"You just broke my heart,"],[2588,2752,"and then I started cursing people"],[2752,2869,"and reading minds."],[2948,3092,"Just a normal Saturday."],[3092,3228,"It's just fatigue."],[3812,3908,"Are you okay?"],[4628,4796,"Go home. Don't scare the visitors."],[4928,5060,"I fucking hate you!"],[5568,5696,"Finally…"],[5904,6108,"My nose is back in place."],[6332,6460,"My nose!"]],"14":[[0,176,"What the hell is happening to me?"],[484,712,"No, no, no…"],[712,832,"No shit!"],[1888,1988,"Who am I?"],[2116,2276,"Maybe this is a dream…"],[2468,2796,"Maybe I died… and this is hell."],[2860,3076,"Don't talk nonsense, Claire."],[4552,4636,"Who are you?"],[4684,4872,"That is not important."],[4928,5252,"What matters is who you are."]],"15":[[84,184,"And who am I?"],[496,739,"Hey! Hey, where are you?"],[884,996,"Hey!"],[1940,2143,"Okay, Claire. The main thing is"],[2143,2316,"to be absolutely calm."],[2316,2452,"Because since yesterday,"],[2452,2628,"I have realized one thing…"],[2660,2844,"I must not lose my temper."],[2884,2996,"Claire?"],[2996,3252,"Darling, didn't they tell you?"],[3340,3452,"About what?"],[3452,3612,"You're on vacation."],[3660,3752,"Two weeks."],[3800,3989,"Starting this minute."],[5356,5508,"I'm sure you are delicious…"],[5776,5868,"Let's go."],[6812,6932,"Oh, dear…"],[7028,7241,"What is it? You look like"],[7241,7324,"you're about to have"],[7324,7461,"another meltdown."],[7508,7609,"Your blood sugar"],[7609,7743,"must be really low."],[7776,7976,"Breathe in. Breathe out."],[7996,8092,"Breathe in…"],[8092,8400,"Happy birthday to you…"],[8448,8592,"Happy birthday…"],[8592,8816,"Here. You need something sweet."],[8864,8992,"Breathe, Claire."],[8992,9140,"I order you to breathe."],[9188,9456,"Eat your own sweets!"],[10640,10740,"I don't understand."],[10740,10840,"What's going on?"]],"16":[[0,172,"No. no, no! Not in the nose!"],[872,972,"Oh my God."],[1024,1184,"It wasn't me! I swear!"],[1232,1432,"My hands… They did it."],[1536,1708,"I'll fix everything. I'm sorry."],[1872,2048,"It wasn't me. I swear."],[2048,2332,"Well, I definitely have powers."],[2332,2536,"And I absolutely do not know"],[2536,2680,"how to control them."],[2680,2884,"Because I still have no idea"],[2884,2996,"who I am."],[2996,3124,"She's a witch."],[3388,3532,"Fuck, she heard me."],[3680,3780,"Michael?"],[3908,4020,"She's coming this way."],[4020,4156,"Stop thinking about it."],[4156,4280,"Stop thinking about it!"],[4328,4428,"I'm a witch?"]],"17":[[48,160,"You're not just a witch."],[208,364,"You're from a lineage of witches."],[1184,1268,"Michael?"],[1400,1500,"Michael, stop!"],[1624,1736,"Let's talk!"],[1736,1896,"I'm sorry, Claire. I'm in a hurry."],[2152,2320,"Michael, you're running away!"],[2320,2516,"No, that's not what you think."],[2516,2612,"Hey!"],[2804,2928,"Stop!"],[3268,3424,"I won't hurt you. I just want to talk."],[3628,3728,"Reverse that."],[3860,4004,"Oh my God, I'm sorry."],[4004,4177,"I didn't mean to do that."],[4288,4416,"Break the spell."],[4472,4624,"My neck is going to break."],[4680,4784,"But I don't know how."],[4960,5160,"Okay. Okay. I'll try."]],"18":[[1356,1452,"My eyes…"],[1716,1852,"I'm sorry. I can't."],[2040,2132,"Fuck."],[2216,2472,"Alright. Uh, in the car…"],[2536,2840,"there is a box with a ring"],[2840,2992,"in the glove compartment."],[3040,3140,"Bring it to me."],[3232,3388,"I hope you're not gonna propose to me."],[3780,3906,"Okay. It was a joke."],[3956,4044,"A bad one."],[4140,4256,"I'll be right back."],[6195,6271,"Wow."],[6444,6632,"Just don't touch the ring."]],"19":[[3780,3872,"Oh my God."],[4016,4208,"What? What the hell?"],[4230,4427,"What the hell is that?"],[4736,4836,"It almost killed me!"],[4884,5164,"An amulet against witchcraft."],[5264,5532,"I need to put it on."],[5588,5898,"What? No, Michael."],[5898,6040,"I'm not touching it again, okay?"],[6276,6446,"Put it near my mouth."]],"20":[[692,792,"Oh, damn."],[856,956,"Let me help you."],[1156,1256,"Shit."],[1436,1604,"That's why I ran away."],[1728,1876,"Because I knew"],[1876,2056,"something like this would happen."],[2056,2156,"Okay, I'm sorry."],[2212,2352,"You need to learn"],[2352,2528,"how to control your powers now."],[2584,2855,"Otherwise, you'll kill someone."],[2855,3016,"Okay. And how can I learn?"],[3016,3197,"Buy an online course?"],[3368,3649,"That's your witch's obligation."],[3816,4016,"What do you mean, my witch's?"],[4284,4539,"You're from a lineage of witches, Claire."],[4627,4716,"And that's…"],[4848,5064,"an inherited witch's mark."],[5296,5471,"Who else in your family had one?"],[5988,6084,"I don't know my family."],[6084,6192,"I'm an orphan."],[6296,6579,"They just left me a house…"],[6616,6760,"in the woods, and that's it."],[6924,7024,"Fuck."],[7124,7348,"That's bad. Very bad."],[7620,7789,"Someone had to pass…"],[7789,7972,"their knowledge on to you."],[7972,8251,"Otherwise, your powers"],[8251,8376,"will get the better of you."],[8376,8476,"And you—"],[8668,8780,"And I, what?"],[8956,9116,"What's gonna happen to me?"],[9592,9765,"You'll lose your mind."]],"21":[[896,980,"At least try"],[980,1132,"to find out your parents' last name."],[1180,1323,"That gives us a better chance"],[1323,1432,"of finding your witch."],[1572,1788,"You don't have much time, Claire."],[1836,1936,"Okay."],[2572,2656,"It suits you."],[2940,3132,"Yeah, thank you for the gift."],[3336,3436,"And thank you for everything."],[3980,4080,"Do you want some tea?"],[4192,4504,"You know? I still have work to do."],[4628,4896,"Well, my blog."],[4896,5192,"Yeah, of course. Your food blog."],[5240,5383,"-Yeah. -Yeah."],[5732,5896,"Did you find treasure"],[5896,6008,"under your house?"],[6008,6188,"Almost. They were delivered"],[6188,6288,"right outside the door"],[6288,6388,"the day before yesterday."],[6388,6548,"But I have no idea who sent them"],[6548,6688,"or what's inside."],[6944,7104,"Can you help me open them?"],[7268,7368,"Yeah."],[7424,7508,"Cool."],[8344,8444,"Oh, my God."],[8592,8852,"Should we try sawing it?"],[8900,8984,"I don't know."],[9128,9252,"What can I do with you?"],[10528,10785,"Is that what I think it is?"]],"22":[[316,562,"These are clearly my witch's things."],[1016,1299,"It means she found you herself."],[2076,2160,"Do you want me"],[2160,2280,"to turn you into a frog?"],[2356,2524,"\"Spin the amphibious,"],[2524,2648,"change your body,"],[2648,2772,"take a nap—\""],[2772,2864,"Claire, stop it."],[2864,2972,"What?"],[2972,3088,"Don't mess with magic."],[3212,3368,"It has a bad sense of humor."],[3440,3596,"Yours is not very good either."],[4496,4608,"Oh my God…"],[4728,4896,"Is that a real coven?"],[5188,5460,"It seems so. One of them is…"],[5508,5648,"probably your witch."],[5980,6212,"Judging by how old this photo is,"],[6212,6356,"she's probably your…"],[6440,6556,"great-grandmother."],[6640,6960,"Yeah. And I wonder which one she is."],[7900,8128,"Here she is. Yeah."],[8436,8536,"Nina…"],[8684,8932,"My great-grandmother Nina."],[8940,9032,"Finally."],[9344,9472,"What is it?"]],"23":[[136,256,"Do you see her too?"],[372,656,"Who? I don't see anyone."],[704,841,"Of course he can't."],[972,1084,"He is just a man."],[1560,1672,"Told you."],[1672,1780,"So..."],[1840,2124,"You're my great-grandmother, right?"],[2252,2372,"Who's there?"],[2476,2576,"Who are you talking to?"],[2688,2844,"Did you send all these boxes?"],[2892,3107,"Well, factually, yes."],[3107,3216,"But technically, no."],[3264,3392,"I died 70 years ago."],[3448,3516,"Oh."],[3520,3741,"But with a little bit of magic"],[3741,3940,"and a proper courier service,"],[3940,4044,"you got them"],[4044,4226,"right on the Day of Inheritance."],[4260,4508,"Very precise delivery."],[4592,4872,"What is the Day of Inheritance?"],[4872,5072,"On your 23rd birthday…"],[5136,5336,"at the hour and minute"],[5336,5436,"of your birth,"],[5436,5604,"your powers awaken…"],[6468,6552,"Wow."],[6552,6792,"That is the Day of Inheritance."],[6840,6952,"By the way,"],[6952,7072,"happy belated birthday."],[7184,7296,"Thank you."],[7296,7400,"Today, you learned"],[7400,7524,"about who you are…"],[7644,7900,"and whose power is in you."],[8112,8212,"So…"],[8772,8908,"That is why I'm standing"],[8908,9044,"in front of you right now."],[9120,9264,"I gave you strength…"],[9360,9540,"and the key to knowledge."],[9880,9972,"Congratulations"],[9972,10124,"on your initiation…"],[10180,10280,"my witch."]],"24":[[1296,1400,"Claire!"],[1480,1576,"Claire? Claire?"],[1728,1816,"Are you okay?"],[1864,2124,"Michael… It's you…"],[2564,2680,"You're so cute."],[2740,2832,"Let's go inside."],[2924,3044,"You're so strong…"],[3736,3896,"I can feel it inside."],[4008,4232,"Such a pleasant tremor."],[4544,4636,"You know?"],[4732,4832,"Yeah, right here."],[4944,5040,"Give me your hand."],[5376,5488,"Can you feel it?"]],"25":[[60,172,"Can you feel it?"],[296,408,"Yeah."],[548,810,"Claire, the floor is cold."],[844,972,"Maybe you should sit down?"],[972,1236,"You know, it was like something…"],[1284,1436,"unlocked inside me."],[1504,1604,"Just…"],[1604,1784,"Click, and that's it."],[1924,2236,"And now… I can feel…"],[2536,2808,"like I know that I know something…"],[2872,3008,"but I don't know what."],[3072,3184,"Do you understand?"],[3268,3428,"I'm trying to."],[3640,3740,"Listen, Claire."],[3848,4000,"Why don't you get some rest?"],[4116,4216,"Get some sleep."],[4320,4420,"How do you know so much"],[4420,4544,"about witches?"],[4708,4828,"It's a hobby."],[4828,4940,"Hobby?"],[4940,5148,"Yeah, I'm—"],[5148,5320,"I'm just a bit of a weirdo."],[5508,5636,"There's no arguing with that."],[5684,5976,"And you know? I love weirdos."],[6596,6680,"Shit."],[6680,6868,"Shit, shit, shit…"],[6868,6980,"Where is it?"],[6980,7236,"Now, she's going to read me."],[7236,7392,"She's going to know everything."],[7392,7540,"She's gonna know the truth!"]],"26":[[160,304,"She's going to find out the truth."],[352,484,"Stop thinking. Stop thinking."],[484,568,"Stop thinking."],[568,704,"Shut my thoughts off"],[704,848,"and look for that damn ring!"],[896,996,"Are you okay?"],[1064,1164,"Yeah."],[1628,1748,"It's so late…"],[1996,2136,"I'd better get going, Claire."],[2184,2448,"Yeah? And you… get some rest."],[2620,2788,"And good luck with your studies."],[2788,2904,"Yeah, thank you."],[2904,2996,"See ya!"],[2996,3096,"See ya."],[3500,3692,"What are you hiding, Michael?"],[4200,4516,"Dang it. Where are you?"],[4664,4824,"Shit, I can't see a thing."],[5824,5977,"I'll come back in the morning."],[5977,6059,"Fuck."],[7668,7936,"I'll find a way around your charms,"],[7936,8028,"Michael."],[8028,8312,"And I'll find out who you are."]],"27":[[2644,2744,"Claire…"]],"28":[[300,457,"Claire, we can't find"],[457,627,"your friend, Nicol."],[627,761,"Tell that truant that"],[761,935,"if she doesn't show up tomorrow,"],[935,1096,"she'll be fired."],[1103,1357,"Oh, and have a nice vacation."],[1480,1730,"Please, Nicol. Pick up the phone."],[1908,2042,"It looks like the pimples"],[2042,2172,"haven't disappeared yet."],[2272,2449,"Shit, what have I done?"],[2524,2686,"I need to break this spell."],[3880,4078,"I looked all night for a spell."],[4108,4316,"I went through eight notebooks"],[4316,4452,"and found nothing."],[4960,5104,"Come on, baby."],[5400,5512,"Come to Daddy."],[6160,6252,"Bingo."],[6444,6544,"Good morning!"]],"29":[[56,156,"Hey!"],[156,240,"Hey."],[240,352,"You're awake."],[552,708,"You know? I thought…"],[792,892,"maybe I could help you"],[892,1016,"with your studies."],[1088,1456,"It might be more fun together."],[1504,1656,"Yeah, great idea."],[1656,1836,"You read my mind. Yeah."],[2056,2156,"Can we talk?"],[2628,2720,"Shit."],[2848,2985,"I really do wanna help you"],[2985,3099,"with your studies."],[3144,3309,"That's why I had to find this ring."],[3309,3460,"It protects me."],[3460,3552,"From me?"],[3552,3652,"Yes."],[3724,3856,"I mean… no."],[3920,4016,"I mean—"],[4284,4380,"Take it off."],[4512,4680,"I want to know that I can trust you."],[4764,4856,"Then you can wear it"],[4856,4961,"as much as you want."],[5256,5456,"I'm not taking it off, Claire."]],"30":[[192,376,"Everyone has something to hide."],[432,628,"People learn to trust each other"],[628,772,"without your abilities."],[772,908,"Then tell me who you are."],[1008,1216,"We both know that your…"],[1340,1440,"food blog is…"],[1524,1644,"some kind of…"],[1692,1891,"culinary misunderstanding."],[2004,2081,"Yup."],[2312,2424,"What is your connection"],[2424,2524,"to witches?"],[3720,3944,"My wife…"],[4084,4184,"was a witch."],[4540,4624,"Was?"],[4804,4904,"She died."],[5280,5408,"I killed her."],[5704,5804,"Oh my God…"],[6460,6668,"Michael, please…"]],"31":[[0,120,"Michael, please."],[352,464,"This isn't you."],[620,833,"Michael, it's still me…"],[916,1038,"It wasn't me."],[1120,1272,"I was being controlled"],[1272,1421,"by another witch."],[1450,1560,"Michael, look at me."],[1772,1884,"Michael…"],[1884,1984,"Michael, please."],[2040,2212,"It's still me, Michael."],[2444,2580,"Your wife, Michael…"],[2660,2948,"She took my will and…"],[3104,3232,"used me as a weapon"],[3232,3347,"against my Anna."],[3900,4036,"This is my wedding ring."],[4152,4236,"Anna…"],[4308,4454,"put a protective spell on it"],[4454,4532,"because…"],[4596,4796,"she was worried about my life…"],[4960,5044,"not hers."],[5424,5668,"I took my ring off that day."],[6028,6180,"You're a witch, Claire."],[6388,6484,"Someday you'll meet"],[6484,6580,"people like you,"],[6580,6937,"and not all of them will be kind."],[7136,7312,"So, please…"],[7488,7712,"don't ask me to take it off again."],[8368,8515,"I'm glad you're helping me"],[8515,8626,"with my studies."],[8724,8873,"Because I can trust you."],[9352,9648,"Just cover it up, okay?"],[9683,9824,"Oh, yeah."],[9824,9924,"Yeah."],[11820,11904,"You won't run away"],[11904,12056,"when you see what I'm capable of,"],[12056,12156,"will you?"],[12212,12304,"I've already seen…"]],"32":[[0,160,"Have I ever dreamed of"],[160,413,"spending my vacation like this?"],[448,681,"Most definitely not."],[740,863,"No one ever told me"],[863,1052,"it could be like this."],[1632,1784,"Come on! Float!"],[2050,2157,"Oops."],[2704,2788,"I'm sorry."],[2960,3060,"It's okay."],[3248,3504,"Let's just try again."],[3560,3644,"Yeah, okay."],[5532,5628,"Obsidian…"],[5876,6084,"And this…"],[6576,6780,"How about now?"],[7040,7172,"Disgusting!"],[7498,7638,"Okay. And..."],[8436,8590,"Please, Michael. Michael. It's not funny."],[8590,8664,"Take it away!"],[8664,8788,"For the last time."],[8872,9176,"Let the sleeping roots grow strong again."],[9224,9416,"And let the flower be reborn."],[9416,9632,"Let the earth be filled with dew."],[9980,10084,"…so be it!"],[10416,10544,"Shit."],[10830,10906,"Oh, no."],[11164,11236,"I don't feel it."],[11236,11492,"Not that vase, Claire."],[13256,13376,"As I command!"],[13376,13576,"As I command, so be it!"],[14624,14832,"Oh my God. Michael, look at this."],[14888,15112,"I did it! I did it!"]],"33":[[0,240,"I thought I had learned everything."],[240,368,"But it turned out"],[368,581,"I wasn't ready for the exam."],[581,800,"Now, make it move."],[980,1080,"Okay."],[1172,1272,"Come on."],[2480,2584,"Hey."],[3136,3264,"What's wrong with me?"],[3348,3448,"Michael…"],[3668,3820,"I'll never do that."],[3820,4036,"Hey, hey. What are you saying?"],[4244,4356,"You can do this."],[4488,4588,"Because you're strong."],[4756,5024,"You can't even imagine"],[5024,5136,"how strong you are."],[5536,5788,"You are the best, okay?"],[5836,5936,"Okay."]],"34":[[108,244,"Oh, no, no, no."],[244,380,"Claire, stop this."],[380,648,"Why? Just why did you do that?"],[740,916,"I'm sorry if I crossed a line."],[916,1040,"Fuck yeah, you crossed a line!"],[1040,1240,"You crossed all the fucking lines!"],[1696,1839,"You destroyed everything"],[1839,1936,"between us."],[1936,2104,"Just tell me. Why did you—"],[2104,2296,"Claire. Claire, the car."],[2516,2772,"Now, stop it."],[2772,2872,"No, I can't."],[2920,3076,"Come on, Claire. You can do it."],[3076,3252,"No. Just let me go, okay?"],[3252,3404,"No. You're strong."],[3532,3676,"The strongest I've ever seen."],[3694,3764,"Come on."],[5284,5496,"You did it! You did it, Claire."],[5608,5820,"Hey, Claire? Claire?"]],"35":[[924,1116,"Hey…"],[1164,1276,"You're awake."],[1276,1376,"Yeah."],[1568,1668,"What happened?"],[1768,1920,"You fainted."],[2020,2284,"You've been asleep for two days."],[2284,2384,"Two days?"],[2432,2532,"Yeah."],[2532,2632,"Oh my God."],[2700,2820,"I found something"],[2820,3004,"about your condition."],[3348,3432,"Here."],[3432,3784,"Your etheric thread is broken."],[3968,4152,"It happened due to overload."],[4152,4280,"Have I lost my strength?"],[4328,4544,"No, no, no. You lost…"],[4644,4808,"touch with your witch."],[4828,4972,"I mean, with Nina."],[4972,5056,"Forever?"],[5104,5442,"Well, it says that…"],[5472,5628,"it can be sewn back together,"],[5628,5728,"but…"],[5800,6048,"only by the mentor herself."],[6164,6264,"So…"],[6348,6524,"to reconnect with Nina,"],[6524,6825,"I need Nina's help, right?"],[6916,7016,"Yeah."],[7116,7364,"But how do I find her?"],[8148,8276,"You need to go there."],[8896,8996,"A coven?"]],"36":[[904,988,"Found it."],[1096,1392,"Well, let's get acquainted, baby."],[2348,2480,"This is not a baby."],[2564,2836,"More like an old hag."],[2884,3028,"Wanna give it a little tuneup?"],[3172,3256,"Yes, please."],[3256,3400,"Make it run like a Ferrari."],[3528,3664,"I'll find some motor oil."],[4816,4928,"Flying cream?"],[5536,5688,"I need to lubricate myself"],[5688,5792,"with this?"],[6066,6124,"Eww..."],[8232,8496,"Well, hello, my baby."],[8680,8816,"Harry Potter"],[8816,9056,"didn't have to take off his clothes"],[9056,9167,"to fly."],[9167,9480,"I wonder if this is really part"],[9480,9624,"of the flying ritual."],[9672,9988,"Or was my great-grandmother"],[9988,10152,"from the Slavic lands?"],[10200,10456,"You're marked with magic blood."],[10504,10768,"By my will, take off and fly."],[10832,11098,"As I have spoken, so shall it be."],[11136,11416,"So shall it be! So shall it be!"]],"37":[[508,608,"Shit."],[1056,1294,"Why did my vacation end like this?"],[1332,1492,"My knee is broken,"],[1492,1628,"the thread is torn,"],[1628,1828,"and I have to go to work tomorrow."],[2000,2164,"Tomorrow, I'll see him."],[2212,2396,"The pompous turkey."],[2600,2728,"I hate him…"]],"38":[[1192,1292,"Where am I?"],[2152,2236,"Hello?"],[2488,2588,"Is anybody here?"],[4444,4564,"Is this a coven?"]],"39":[[5708,5808,"Well, hi, Claire."],[6444,6536,"Come here."],[7230,7376,"It hasn't been a month yet,"],[7376,7620,"and you're already tearing the thread?"],[8016,8320,"Yeah, I've always been so clumsy…"],[8440,8540,"Okay then."],[8736,8888,"Let's sew it back together."],[8888,8988,"Okay."]],"40":[[3976,4068,"How do you feel?"],[4116,4420,"Unreal. Ecstatic. Just wow."],[4708,5164,"Can I come to your place again sometime?"],[5212,5324,"To this party of yours."],[5416,5620,"But I don't have a broom."],[5704,5868,"By the way, can you tell me"],[5868,6128,"where to buy one?"],[6440,6532,"A broom?"],[6532,6648,"Yeah, a broom."],[6696,6840,"You plan to come here…"],[6888,6972,"on a broom?"],[7572,7736,"I didn't plan. I just—"],[7784,8072,"Listen, a dream travel is the fastest way here."],[8175,8310,"Oh."],[8404,8504,"Oh, I see."],[8504,8612,"Protect the thread."],[8668,8860,"And by the way, on a full moon…"],[8916,9116,"your blood gains special power."],[9296,9408,"To revive the dead."],[9608,9800,"And now… wake up!"]],"41":[[92,192,"How did you get here?"],[304,496,"Are you and Michael…"],[604,688,"really together?"],[760,1024,"What? I'm not going to answer you."],[1124,1307,"Tell me. What are you doing"],[1307,1396,"in my bedroom?"],[1444,1560,"Do you love him?"],[1644,1756,"Why all these questions?"],[1804,1924,"We're just friends."],[1924,2044,"Why do you care?"],[3580,3688,"Sleep."],[4264,4364,"What a dream…"]],"42":[[108,260,"I'm in a great mood today."],[360,560,"Even Simon and his dream"],[560,672,"didn't spoil it."],[940,1160,"Finally. Neither you nor Nicol"],[1160,1344,"has been here for two weeks."],[1344,1484,"What? Nicol didn't show up?"],[1484,1560,"No."],[1616,1800,"Now, this is really alarming."],[1800,1943,"Welcome back."],[1971,2134,"I hope you're not planning on"],[2134,2332,"scaring our customers anymore."],[2332,2492,"What? No."],[2492,2608,"I'm gonna make them laugh."],[3440,3568,"What? What's going on?"],[3568,3652,"Someone—"],[3652,3800,"Can someone please help me?"],[5184,5304,"Having fun?"],[5304,5404,"Don't be a bore."],[6920,7028,"What's going on?"],[7316,7408,"Stop."],[7484,7568,"I can't!"]],"43":[[948,1100,"Pull yourself together, Claire."],[1156,1340,"Your knees aren't shaking"],[1340,1540,"because you're still in love."],[1540,1624,"They're shaking"],[1624,1800,"because you're pissed off"],[1800,1996,"at this arrogant turkey."],[2284,2424,"Stop!"],[3200,3300,"Did you call?"],[3384,3484,"Come in."],[3540,3660,"And close the door behind you."],[4164,4248,"Well…"],[4248,4468,"you can't play with me anymore."],[4496,4680,"Because I can read your mind."],[4728,4972,"How about that, Simon?"],[5316,5548,"Great. Just great."],[6156,6378,"Saffron. Amber."],[6420,6520,"Rough leather."],[6624,6771,"Why the hell does he smell"],[6771,6868,"so good?"],[7368,7479,"Will you go out with me?"]],"44":[[88,225,"So, what do you think?"],[340,424,"I don't know."],[480,724,"If I could find the time…"],[904,1004,"You know?"],[1152,1267,"I can find the time."],[1392,1492,"Well."],[1632,1771,"This is not a date."],[1800,2024,"This is revenge."],[2024,2372,"Cold and calculated revenge."],[2372,2456,"I don't care"],[2456,2540,"if my heart"],[2540,2708,"is jumping out of my chest."],[2740,2964,"In fact, I hate him."],[4244,4356,"Sorry."],[4660,4760,"Wow."],[4912,5040,"How beautiful…"],[5148,5248,"Thank you."],[5320,5512,"Wait. How did you find out?"],[5612,5770,"Did you somehow get past"],[5770,5873,"my defenses?"],[5948,6068,"Did you read my mind?"],[6140,6284,"What did I find out about?"],[6284,6452,"About the date."],[6452,6564,"The date?"],[6564,6740,"I wanted to ask you out."],[6872,7032,"Isn't that why you're dressed"],[7032,7148,"like that?"],[7220,7348,"The date…"]],"45":[[56,288,"I'm sorry, Michael. I didn't know."],[288,400,"I wish I did, but—"],[580,784,"Because now, I feel really, really bad."],[932,1032,"I'm sorry."],[1148,1252,"Yeah…"],[3108,3192,"Simon?"],[3276,3392,"Yes."],[3956,4216,"Well… hello, Michael."],[4384,4576,"Are those flowers for me?"],[4860,4984,"They're for me."],[5060,5188,"They're great."],[5236,5352,"Well…"],[5524,5636,"Have a good time."],[5724,5844,"Thank you."],[6084,6220,"I'm sorry."],[6220,6412,"Don't worry about it. Really."],[6468,6568,"Yeah."],[7088,7212,"I thought it was a joke"],[7212,7312,"about you and Michael."],[7784,7884,"It was a joke."],[9164,9292,"Oh my God, it's Nicol."]],"46":[[488,605,"Is this your house?"],[660,760,"Are you impressed?"],[760,860,"Oh yeah."],[1008,1092,"Please."],[1092,1192,"Thank you."],[2284,2428,"Yeah, thank you."],[2852,2941,"Wow."],[3516,3636,"Do you live in a museum?"],[3924,4200,"Consider me the oldest exhibit"],[4200,4316,"in this museum."],[4440,4540,"How old are you?"],[4640,4812,"One hundred eighty-nine?"],[4968,5120,"Three hundred seventeen."],[5556,5668,"Funny."],[6256,6475,"Your blogger's persistent."],[6564,6736,"I wonder what you two have in common."],[6984,7052,"It's food."],[7052,7111,"Food?"],[7111,7288,"He's a food blogger."],[7344,7456,"And I'm like that…"],[7504,7648,"voracious caterpillar."],[7648,7880,"I keep eating and eating…"],[7928,8208,"You know? I could eat you too."],[8420,8520,"Or myself…"],[8568,8712,"if I don't shut up right now."],[8712,8864,"I'm sure you are delicious."]],"47":[[100,184,"Okay…"],[268,368,"Now…"],[432,580,"we are going to test your…"],[728,845,"gastronomic skills."],[1136,1236,"Okay."],[2772,2892,"Don't be afraid."],[2964,3084,"Just the floor creaking."],[3156,3256,"Okay."],[3500,3600,"Or not…"]],"48":[[768,880,"Open your mouth."],[2940,3092,"Dark Belgian."],[4500,4620,"Isabella grapes."],[4820,5024,"Could you try something harder?"],[5140,5240,"As you wish."]],"49":[[924,1100,"To hell with everything."],[1148,1332,"To hell with revenge."],[1380,1532,"To hell with plans."]],"50":[[2432,2552,"Sleep."]],"51":[[1224,1324,"Simon?"],[1680,1816,"Just great."],[1816,1976,"I had a foolproof plan"],[1976,2116,"to fall in love with him,"],[2116,2228,"play around with him,"],[2228,2408,"break his heart, and leave."],[2408,2520,"Instead,"],[2520,2709,"my panties are on his bed."],[4904,5004,"Nicol?"],[5132,5238,"Oh my God."]],"52":[[476,700,"Claire, listen carefully…"],[876,976,"Shit."],[1060,1160,"Shit."],[1244,1444,"Great. The phone decided"],[1444,1605,"to die right now."],[2684,2812,"Simon?"],[2996,3096,"Simon?"],[3740,3840,"Where are you?"],[4888,5032,"Don't go in there."],[5116,5233,"People like you…"],[5264,5376,"are the first to die"],[5376,5515,"in a horror story."],[5836,6204,"Don't… go."]],"53":[[1108,1204,"What?"],[1288,1424,"1842?"],[1856,2080,"1954?"],[2252,2366,"How's that possible?"],[3708,3808,"Blood?"]],"54":[[48,148,"Calm down, Claire."],[240,440,"It's just cherry ice cream."],[440,648,"Or red champagne."],[732,957,"Or Nicol's body…"],[1672,1792,"Is this blood?"],[2268,2368,"Real blood?"],[3076,3188,"Sorry for the mess."],[3340,3504,"Sometimes I'm so clumsy."],[3584,3712,"Just like you."],[3776,3904,"Why do you need blood?"],[3952,4124,"Because I like to eat too."]],"55":[[244,514,"So, you're a vampire?"],[932,1140,"Is that Nicol's blood?"],[1456,1624,"What do you want from me, Claire?"],[1624,1748,"Nothing."],[1825,2028,"I thought it was just an ordinary date."],[2240,2424,"A witch going out with a vampire—"],[2424,2592,"it can hardly be called"],[2592,2699,"an ordinary date."],[2699,2888,"I didn't know you were a vampire."],[2888,3060,"You are lying, Claire."],[3212,3352,"I don't like liars."],[3524,3904,"Their blood tastes… bitter."]],"56":[[1744,1888,"What was this in your pocket?"],[2080,2232,"I have no idea what it is."],[2232,2356,"Don't fucking lie to me!"],[2488,2800,"It's silver, Claire. It kills vampires."],[2800,2900,"And you…"],[2992,3132,"wanted to kill me with it."],[3150,3256,"No."],[3320,3420,"Goodbye, Claire."]],"57":[[0,199,"The only thing I'm guilty of is"],[199,344,"falling in love with you."],[2340,2484,"Do you work in my restaurant?"],[2620,2720,"What?"],[2852,3012,"You were the one who hired me."],[3012,3104,"Answer me."],[3152,3252,"Yes."],[3252,3360,"Do you know…"],[3460,3600,"where you got this silver from?"],[3648,3924,"No. No, I promise."],[4432,4552,"You're telling the truth."],[5096,5208,"And the bracelet?"],[5308,5408,"What does…"],[5456,5628,"the bracelet have to do with it?"],[5628,5764,"Just tell me."],[5828,5948,"Oh my God… It's a gift…"],[6064,6160,"from Michael."],[6576,6672,"So…"],[6736,6952,"now, your turn to tell the truth."],[7128,7264,"Is that Nicol's blood?"]],"58":[[96,216,"Did you kill her?"],[424,544,"No."],[616,728,"It's synthetic blood."],[980,1108,"I don't eat people, Claire."],[1276,1376,"Okay."],[1548,1648,"Claire, I…"],[1872,1964,"Your smell…"],[2108,2260,"awakens my vampire nature."],[2500,2628,"But at the same time…"],[2852,3080,"I can't stop thinking about you."],[3152,3280,"Okay."],[3328,3476,"I fell in love with you."],[3556,3668,"Wow."],[3668,3828,"Like a teenager falls in love."],[4096,4380,"Claire, I'm so sorry. I tried to—"],[4428,4708,"You know? I need to go home."],[4708,5008,"Yeah, we'll talk later. Call someday."],[5008,5104,"Goodbye!"],[5208,5336,"Simon loves me…"],[5384,5560,"No, that's not right."],[5560,5720,"Simon is the vampire"],[5720,5864,"who just tried to kill me"],[5864,5992,"and loves me."],[6040,6132,"I need my bed"],[6132,6308,"and a chocolate bar right now."]],"59":[[188,448,"Claire, Claire, calm down. It's me."],[560,644,"Why the hell"],[644,736,"didn't you pick up the phone?"],[736,856,"What are you doing here?"],[920,1040,"What?"],[1040,1220,"I wrote you that I was coming."],[1220,1412,"Why? Why did you come here?"],[1412,1576,"I was worried about you!"],[1624,1726,"I didn't even know"],[1726,1924,"if you were wearing the bracelet."],[1972,2087,"Why is everyone talking"],[2087,2205,"about my bracelet?"],[2316,2408,"Oh God…"],[2408,2604,"Clearly, you haven't read anything."],[2852,2952,"Claire…"],[3044,3172,"that bracelet…"],[3236,3632,"protects its wearer from vampires."],[3840,4008,"I gave it to protect you from…"],[4108,4384,"Simon. Just in case."],[4384,4592,"Because I suspected"],[4592,4704,"he was a vampire."],[4860,5100,"So, did you plant…"],[5148,5316,"that silver vial on me?"],[5372,5492,"Have a good time."],[5492,5628,"Yeah, thank you."],[6364,6657,"So, you are a vampire hunter?"]],"60":[[136,392,"I thought that if something happened,"],[392,612,"you could kill him with this vial."],[612,772,"Just put it in the wine, or—"],[772,1024,"So, that's why you were afraid…"],[1072,1172,"I'd read your mind."],[1268,1368,"Not because of your wife."],[1368,1468,"It was Simon."],[1532,1732,"You were afraid I'd find out"],[1732,1972,"who you really are and tell him."],[2388,2520,"I don't need your protection"],[2520,2716,"anymore, Michael."],[2952,3052,"Claire…"],[3544,3640,"Take it."],[4748,4868,"Well…"],[4968,5068,"Hello, hunter."]],"61":[[0,152,"Today is the third day"],[152,252,"that I've been trying"],[252,364,"to avoid Simon."],[412,558,"It's really exhausting."],[604,688,"I just don't know"],[688,840,"if I can trust him."],[840,968,"And when I see him,"],[968,1157,"-I stop trusting myself. -Claire?"],[1241,1323,"We need to talk."],[1568,1704,"Fuck."],[2724,2816,"Talk."],[3048,3196,"No, no, no. Stop it."],[3292,3384,"What do you want?"],[3448,3542,"Why are you running away"],[3542,3652,"from me?"],[3700,3820,"Why are you driving me crazy?"],[3820,3964,"Because I can't trust you"],[3964,4124,"after everything I've learned."],[4124,4323,"And I can't read your thoughts."],[4852,4952,"Okay."],[5144,5236,"Vampires…"],[5284,5417,"can let people inside their heads"],[5417,5500,"themselves."],[5628,5728,"How?"],[7388,7469,"Trust me."]],"62":[[4376,4476,"What did you see?"],[4596,4696,"You."],[4916,5016,"All the suffering…"],[5128,5228,"you've been through."],[5388,5472,"I'm sorry."],[5636,5756,"I didn't want to scare you."],[5910,6013,"I've never opened up"],[6013,6152,"to anyone before."],[6328,6432,"Thank you."]],"63":[[3020,3148,"I'm not letting you go today."],[3728,3864,"I'll take you back to my place."],[5316,5416,"Nicol?"]],"64":[[1036,1136,"Oh my God, Nicol."],[1136,1232,"What's happened?"],[1328,1412,"Oh my God."],[1492,1624,"Oh my God. What happened?"],[1688,1828,"Where have you been, Nicol?"],[2092,2192,"Nicol!"],[2760,2896,"I'm hungry, Simon."],[3144,3437,"Give me some real blood."],[3552,3834,"You know the rules. Only synthetic."],[3834,3944,"To hell with the rules."],[4064,4216,"Fake blood isn't enough."],[4456,4568,"I've already run out of it."],[4568,4804,"Please, please, please."],[5308,5408,"I'll get you some more."],[5488,5588,"Okay."],[5824,5984,"Did he do this to you?"],[6800,7181,"I'm so hungry, Claire."]],"65":[[0,168,"No, no, no. No, it's me."],[168,272,"It's me, Nicol."],[464,620,"Nicol, it's me, Claire."],[620,1100,"Your blood… smells so good…"],[1820,2036,"No! Let me go!"],[2768,2868,"Let me go!"],[2992,3128,"It's all because of you!"],[3220,3332,"You did this!"],[3416,3544,"I'm dead now…"],[3672,3776,"Let me go…"],[3888,3984,"I can't—"],[4116,4276,"No! No! No!"]],"66":[[484,604,"He'll come for me."],[604,740,"He's going to drink my blood."],[3104,3204,"Come on…"],[3252,3404,"Please, please, please…"],[3404,3504,"Pick up the phone."],[4348,4460,"Simon!"],[4608,4711,"Show yourself"],[4711,4860,"and fight me like a man!"],[5000,5100,"Not now, hunter."],[7296,7432,"Open the door, Claire. It's me."]],"67":[[64,164,"Open it."],[384,540,"I'm closing this passage…"],[588,672,"Closing it"],[672,836,"from dark magical forces."],[1064,1164,"It worked."],[1212,1312,"He can't get in."],[1576,1688,"I know you are scared…"],[1792,1884,"but please listen to me."],[1932,2024,"You killed Nicol!"],[2024,2257,"No. No, I didn't."],[2300,2420,"I didn't kill her."],[2468,2614,"I just knocked her out."],[2614,2713,"To protect you."],[2736,2960,"You killed Nicol. When you bit her."],[3044,3156,"When you turned her…"],[3156,3247,"into..."],[3308,3431,"into someone like you."],[3508,3608,"You're right."],[3708,3800,"I lied."],[3940,4032,"I lied to you."],[4176,4288,"I lied about Nicol."],[4472,4572,"I bit her."],[4756,4916,"But trust me, you have no idea…"],[5036,5117,"what it is to live"],[5117,5320,"on this synthetic diet."],[5460,5606,"Especially when it's forever."],[5644,5756,"But, Claire…"],[5856,5956,"I swear…"],[6080,6224,"I haven't bitten anyone…"],[6316,6500,"without their consent in years."],[6564,6648,"You—"],[6648,6924,"You think she wanted this herself?"],[7120,7204,"Yes."],[7452,7572,"She was giving me her blood…"],[7644,7773,"for more than six months."],[8032,8152,"What? How?"],[8400,8578,"I didn't suspect anything at all."],[8633,8702,"I..."],[8844,8928,"I thought"],[8928,9057,"you were having an affair."]],"68":[[56,156,"I turned her…"],[212,329,"only because she asked me."],[384,488,"She begged me"],[488,616,"once she got those pimples"],[616,716,"on her face."],[832,1016,"I know you don't trust me anymore."],[1296,1424,"But I love you."],[1764,1876,"I love you, Claire."],[1940,2256,"No. I don't believe you."],[2648,2930,"Let me in… and I'll prove it."],[3020,3148,"What? No…"],[3260,3500,"I'm not stupid, Simon. I know…"],[3564,3701,"what you want to do with me."],[3760,3960,"Just let me prove it, alright?"],[4116,4244,"I'll let you inside my head…"],[4364,4568,"and you will see for yourself…"],[4732,4898,"how I feel about you."],[5003,5104,"Please."]],"69":[[0,184,"Don't do this, Claire."],[232,424,"He's manipulating you."],[472,572,"Again."],[630,697,"But..."],[740,892,"But he gave me a choice,"],[892,996,"didn't he?"],[1044,1316,"I wanna see the truth for myself."],[2192,2309,"Here it is."],[2337,2435,"Sorry for calling you"],[2435,2575,"an impulse purchase."],[2664,2793,"I hope you're silver."],[4160,4272,"I open this passage…"],[4416,4552,"Remove the protection."],[6100,6184,"May I come in?"],[6516,6608,"Yes."]],"70":[[164,264,"If necessary…"],[328,468,"I'll stab you right here."],[568,668,"Do you understand?"],[1472,1556,"Give me your hand."]],"71":[[384,620,"I saw everything and nothing"],[620,720,"at the same time."],[768,936,"It was a naked emotion"],[936,1048,"that grew in him…"],[1104,1246,"and pulsed to the rhythm"],[1246,1336,"of my heart."],[1400,1588,"And I knew exactly what it was."],[1624,1708,"Something that"],[1708,1952,"even he could not understand."],[1960,2116,"But I understood."],[2164,2389,"His love wasn't a manipulation."],[2412,2671,"It wasn't a game. I knew it…"],[2700,2904,"just like I knew my own name."],[3580,3766,"I love you, Simon."],[6180,6264,"Simon, please."]],"72":[[96,196,"Simon, please."],[206,348,"Simon, it's me, Claire."],[398,509,"I love you."],[545,646,"Simon?"],[1572,1684,"Knife!"],[2092,2192,"Your blood…"],[2340,2480,"smells so strong."],[2528,2684,"I can't control myself."],[2912,3048,"Must be because of the whole moon."],[4032,4132,"I have to go..."]],"73":[[1256,1441,"Michael, help Claire."]],"74":[[856,1008,"I'm closing this passage!"],[1128,1268,"I'm closing it"],[1268,1408,"from the dark forces!"],[1448,1564,"Close!"],[1564,1692,"Let me in."],[1692,1816,"I'm closing it!"],[1816,1956,"Close!"],[1956,2056,"I'm hungry."],[2172,2268,"Close!"]],"75":[[396,532,"Simon, please."],[2644,2736,"No..."],[4232,4332,"No..."]],"76":[[300,400,"No."],[552,676,"No, Simon."],[676,866,"Don't you dare die on me."],[866,976,"Please."],[1060,1277,"Claire, he's dead."],[1448,1616,"He's finally dead."],[1688,1829,"No, there has to be a way."],[1872,2024,"There has to be a way."],[2224,2324,"Protect the thread."],[2324,2432,"On a full moon…"],[2480,2704,"your blood gains special power."],[2752,2856,"To revive the dead."],[3200,3320,"I can heal him."],[3608,3764,"No, no, no. Claire!"],[3779,3920,"Claire, what are you doing?"],[3920,4004,"Let me go."],[4004,4128,"-He almost killed you! -Let me go."],[4128,4240,"He's going to die!"],[4240,4472,"Yes. That's how it has to be."],[4520,4697,"He's just like the rest."],[4736,4856,"They're all the same."],[4869,4955,"People like him"],[4955,5136,"turned my wife into a monster."],[5268,5452,"She became a vampire."],[5500,5615,"And I had to kill her."]],"77":[[332,532,"Not because of a dark witch."],[580,772,"Michael… Michael…"],[820,976,"Don't leave me, Michael!"],[2220,2508,"Michael! Michael! Michael!"],[2684,2804,"I had to kill her…"],[2944,3184,"because of a bastard just like him."],[3672,3796,"She was your wife."],[4016,4116,"Not anymore."],[4404,4630,"Just like the girls he turned."],[4904,5064,"I destroyed them all."],[5290,5392,"And finally…"],[5592,5880,"I destroyed it."]],"78":[[172,284,"I don't care."],[336,432,"No, no, no!"],[432,532,"Stop!"],[3536,3636,"Come on."],[3684,3917,"Wake up, Simon. Wake up."],[3960,4080,"Please wake up."]],"79":[[0,203,"Come on, Simon. Wake up."],[308,425,"Come on, wake up."],[1716,1816,"What is happening?"],[2284,2444,"Did you heal me with your blood?"],[3572,3664,"I'm sorry."],[3992,4144,"I don't want to hurt you anymore."]],"80":[[108,280,"It's such a strange feeling."],[360,616,"I have an incredible gift"],[616,844,"that saves other people's lives."],[916,1076,"And at the same time…"],[1124,1252,"it destroys mine."],[1314,1400,"Thank you."],[2216,2322,"Does it hurt?"],[2365,2447,"Oh."],[2520,2620,"It's nothing."],[2848,2932,"Give me your hand."],[4292,4564,"Saving him was pointless."],[4672,4824,"He won't forget the smell"],[4824,4924,"of your blood."],[4950,5021,"Shh."],[5110,5202,"Please."],[5312,5556,"I don't want to talk about it. Okay?"],[5788,5932,"Thank you for saving me."],[6068,6168,"Claire…"],[6316,6480,"I will always be there"],[6480,6580,"to protect you."]],"81":[[72,197,"I'm sorry, Michael."],[480,580,"From now on…"],[664,834,"I'll be protecting myself."],[3588,3708,"Hello."],[3792,3920,"Why are you so early?"],[4212,4370,"Stop. Stay away from me, please."],[4572,4708,"I need more time…"],[4756,4856,"to control my hunger."],[4960,5060,"It's okay."],[6356,6470,"I love you, Simon."],[6928,7028,"Goodbye."],[7100,7258,"Wait. What do you mean,"],[7258,7360,"goodbye?"],[7436,7554,"Don't say goodbye, Claire."],[7692,7792,"We'll think of something."],[7980,8064,"We'll find a way."],[8064,8304,"No, we won't. 'Cause every second,"],[8304,8402,"we will live in fear"],[8402,8484,"that one day,"],[8484,8652,"you will lose control of yourself."],[8892,9071,"Your thirst is stronger than you."],[9220,9340,"I'm sorry, Simon."],[9816,9916,"Goodbye."],[11248,11422,"I am a witch."],[11464,11768,"And my journey is just beginning."],[11834,12116,"Without him. Without fear."],[12172,12448,"I am no longer afraid of my gift."],[12516,12883,"I accept it. I accept myself."],[12960,13244,"And this world had better be ready for it."]]}