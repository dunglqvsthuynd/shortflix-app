{"1":[[84,196,"Hey, honey!"],[304,416,"I'm home!"],[416,528,"It's our anniversary."],[640,856,"I suppose… you forgot."],[1288,1456,"Mike, is it your stupid jokes again?"],[1992,2160,"Please, honey…"],[2360,2678,"I had a very difficult shift."],[2780,2887,"I could use a warm bath"],[2887,3004,"right now…"],[3004,3104,"a glass of wine…"],[3392,3492,"Mike?"],[3584,3688,"Mike?"],[3688,3784,"God."],[3784,3920,"Mike, what's going on?"]],"2":[[75,156,"Listen up."],[167,262,"Listen up, thug."],[316,439,"I took karate at school."],[520,664,"One more move in my direction,"],[664,796,"and I'll make you impotent."],[796,1012,"At school? That's cute."],[1112,1244,"Does that sweater come"],[1244,1344,"from those days too?"],[1392,1520,"Or… maybe"],[1520,1656,"you took it off some grandma"],[1656,1792,"at the nursing home?"],[1792,1904,"How do you know where I work?"],[1976,2104,"Why were you spying on me?"],[2220,2332,"I know people."],[2332,2524,"Oh, how pretentious."],[2602,2659,"Is that a line"],[2659,2757,"from Fast & Furious?"],[3104,3228,"Listen to me, kitty."],[3292,3460,"Stop pissing me off."],[3620,3724,"Or I swear—"],[3724,3820,"Or what?"],[3996,4096,"I…"],[4480,4600,"Stop."],[4656,4756,"Stop."],[4924,5008,"Listen to me."],[5160,5296,"You came to my home."],[5396,5523,"You beat up my husband"],[5596,5732,"on our anniversary."],[5900,5984,"Husband?"],[6032,6160,"Yes."],[6160,6352,"I had no idea Mike had a wife."],[6400,6500,"What?"],[6628,6728,"Alright."],[7250,7319,"Get up."],[7372,7429,"Move!"]],"3":[[1640,1724,"Let your husband"],[1724,1836,"explain it for me."],[1892,2091,"Well, I owe him money."],[2120,2220,"What?"],[2473,2669,"Okay, how much do you owe, $50K?"],[2804,2952,"$100K?"],[2952,3080,"$200K?"],[3080,3164,"Are you crazy?"],[3164,3264,"Enough!"],[3348,3540,"Mike owes me $1M."],[3696,3796,"So…"],[3860,4148,"I'm leaving you exactly 12 hours…"],[4196,4296,"from now."],[4508,4644,"Or—look at me—"],[4976,5136,"I will take her instead."],[5532,5632,"Sir…"],[5784,5884,"I think…"],[5948,6072,"that's crossing all the lines."],[6072,6234,"I draw the fucking lines here…"],[6316,6412,"not you!"],[6580,6720,"She will be my servant…"],[7028,7128,"for one year."],[8204,8304,"I'm done."]],"4":[[1000,1096,"Careful, darling."],[1204,1304,"So?"],[1388,1600,"What did you spend $1M on?"],[1623,1704,"On?"],[1716,1816,"Don't play dumb."],[1948,2032,"Do I need…"],[2080,2324,"to remind you of your infertility?"],[2488,2588,"Seriously?"],[2732,2800,"What does it have"],[2800,2892,"to do with anything?"],[2909,2992,"Remember the words"],[2992,3083,"of our doctor?"],[3228,3392,"Your case is too complicated."],[3476,3560,"And I just wanted"],[3560,3694,"to fulfill our dream…"],[3712,3875,"whatever the cost."],[4116,4292,"You could've talked to me first."],[4388,4596,"It's $1M."],[5172,5272,"I could've..."],[5412,5638,"But that greedy bastard Jeremy…"],[5660,5826,"is a very dangerous man."],[5896,6008,"And I know you, darling."],[6008,6128,"I know you."],[6176,6268,"You'd never agree"],[6268,6392,"to borrow money from him."],[6482,6616,"I wouldn't."],[7300,7376,"I'm sorry."],[7376,7464,"It's..."],[7684,7854,"It's all because of me. Because…"],[7900,8132,"I cannot give you a normal family."],[8592,8692,"Okay."],[8756,8856,"We—"],[8976,9076,"We can mortgage…"],[9132,9252,"our apartment and car…"],[9416,9560,"and pay part of the money."],[9852,10016,"Honey, where do you think we got"],[10016,10180,"our first failed treatment?"],[10584,10684,"So…"],[10964,11084,"our apartment and car…"],[11150,11379,"are mortgaged already?"],[11432,11516,"Unfortunately,"],[11516,11724,"I think we are trapped."]],"5":[[548,648,"Hey."],[856,953,"Chin up."],[1080,1200,"I have no regrets."],[1272,1512,"This risk was justified. Okay?"],[1680,1768,"And after all…"],[1860,1972,"all I want is"],[1972,2076,"for you to be happy"],[2076,2176,"and complete."],[2390,2449,"It sounds like"],[2449,2544,"you're saying goodbye."],[3240,3376,"You don't know that man."],[3552,3728,"That Jeremy is a greedy bastard."],[3728,3900,"And he'll do anything for money,"],[3900,4001,"even murder."],[4124,4224,"So…"],[4280,4468,"live for both of us."],[4628,4748,"This is my will."],[4996,5164,"Wait. Wait with the will."],[5280,5624,"I will take care of us."]],"6":[[1472,1584,"Hey, hey, stop!"],[1633,1716,"I'm sorry."],[1716,1764,"Are you sure"],[1764,1912,"you've come to the right place?"],[1912,2066,"Yes. This is exactly where"],[2066,2157,"I need to go."],[2166,2220,"Thank you."],[2220,2404,"Uh, wait. I don't think so."],[2464,2652,"This is our CEO's office."],[2652,2896,"He doesn't hire cleaners or servants."],[2896,3068,"That's strange because I'm here"],[3068,3204,"to get a job as a servant"],[3204,3404,"on his personal invitation. So..."],[3404,3504,"Wait."],[4532,4716,"Mr. Allen, there's a visitor here."],[4780,4955,"Says you're expecting her…"],[4988,5112,"to hire her as a clean—"],[5324,5452,"Please wait! Wait!"],[5452,5580,"Please back off."],[5580,5687,"What do you think you're doing?"],[5736,5860,"–Hey. –Oh, Mr. Allen."],[5860,5996,"Don't you disturb me."],[6068,6168,"And cancel all the meetings"],[6168,6260,"for the next hour."]],"7":[[828,948,"First…"],[948,1076,"How did you find me?"],[1076,1212,"And second…"],[1212,1367,"Why the hell did you come here?"],[1368,1632,"First off, I know how to google."],[1680,1812,"Second, you were the first"],[1812,1920,"to barge into my place."],[1920,2107,"So, what's got you so nervous?"],[2368,2476,"Oh…"],[2476,2644,"This is the office"],[2644,2756,"for your clean business."],[2756,2964,"And no one here has a clue"],[2964,3092,"you're just laundering money"],[3092,3236,"for your dirty business."],[3352,3452,"But I promise…"],[3552,3680,"my lips are sealed."],[3812,3964,"You are so cheeky. You know that?"],[4280,4464,"But I don't see your bag of money."],[4680,4800,"That amount is impossible."],[4972,5092,"I'll work it off…"],[5160,5272,"for a year."],[5272,5384,"Not a year…"],[5520,5632,"Two."],[5836,5936,"What?"],[6076,6188,"That wasn't the deal."],[6188,6364,"You're late by…"],[6564,6657,"seven minutes now,"],[6657,6840,"and I gave you 12 hours. So..."],[6884,7011,"Maybe if you weren't so rude,"],[7011,7155,"I'd forgive you, but…"],[7232,7297,"Mm-hmm."],[7705,7808,"Okay."],[7972,8072,"You've got the power."],[8172,8284,"I've got no choice."],[8460,8572,"So…"],[9820,9937,"That's a huge sacrifice."],[9980,10100,"Is your husband worth it?"],[10512,10612,"I trust Mike."],[11044,11272,"Well… there you go."],[11772,11837,"Here."],[12452,12548,"Now you are mine."],[13484,13584,"Take off your clothes."],[13760,13860,"What?"]],"8":[[416,560,"You wanted me as a servant."],[560,652,"Relax."],[700,828,"I just hate your clothes."],[856,982,"You're making yourself ugly"],[982,1068,"on purpose."],[1508,1636,"Yes, Christie."],[1636,1800,"Yes, do we have…"],[1800,1936,"a servant's uniform?"],[2144,2256,"It's up to you."],[2628,2728,"Mr. Allen."],[3100,3219,"For real or for fun?"],[3568,3652,"I'm sorry."],[3652,3788,"It's impossible to clean in it."],[3788,3880,"And…"],[3928,4052,"I won't fit in it."],[4052,4152,"My advice, dear."],[4152,4280,"Cut down on croissants,"],[4280,4508,"and this problem will go away."],[4772,4872,"If you enjoy"],[4872,4956,"wearing stuff like that,"],[4956,5124,"the problem definitely isn't me."],[5124,5227,"That's enough."],[5227,5412,"Being rude is not part of your job."],[5512,5596,"Thank you, Christie."],[6244,6328,"What am I supposed to do"],[6328,6432,"in these clothes?"],[6432,6532,"All in due time."],[6580,6756,"Tonight is your last free evening."],[6872,6972,"Get ready."],[7020,7120,"Pack your stuff."],[7272,7376,"My driver will pick you up"],[7376,7441,"in the morning."],[7568,7668,"Pack my stuff?"],[8020,8120,"Yes."],[8212,8319,"You will live with me."]],"9":[[2152,2344,"How am I gonna live without you?"],[2604,2664,"Hey."],[2788,2972,"It's our last night together, so…"],[3064,3340,"let's… dedicate it to us."],[3340,3440,"Right?"],[3488,3600,"Mm-hmm."],[3636,3777,"–For us. –For us."],[4656,4800,"A small present for you."],[5020,5292,"No matter how hard it gets…"],[5292,5392,"remember…"],[5464,5596,"what this is all for."],[5984,6084,"Oh…"],[6556,6656,"Mike…"],[6936,7064,"Jesus."],[7868,8004,"One day, this belly"],[8004,8200,"will be a home for our little one."],[8288,8374,"We'll look back"],[8374,8477,"on all the struggles"],[8477,8576,"like a nightmare."],[8664,8800,"Yeah."],[8800,8892,"Yeah?"],[10075,10123,"Sorry."],[10308,10408,"Change of plans."],[10476,10576,"I need you now."]],"10":[[3124,3217,"So?"],[3262,3336,"It was supposed to be"],[3336,3456,"my last night with my husband…"],[3524,3608,"but you ruined that too."],[3608,3776,"So… I hope…"],[3776,3912,"you have a good reason for it."],[3912,4047,"I do. Uhm..."],[4112,4224,"My father is disabled."],[4328,4456,"He became ill suddenly."],[4456,4724,"And the nurse, as if on purpose…"],[4724,4824,"isn't responding."],[4888,5056,"I know you have experience… So..."],[5252,5352,"Please…"],[5416,5512,"check on him."],[6076,6192,"No, that's for me."],[6348,6432,"This way."],[8296,8424,"Is everything okay?"],[8536,8636,"Lewis."],[8720,8876,"My name is Mr. Lewis."],[8876,8992,"Mr. Lewis…"],[8992,9128,"I think…"],[9128,9228,"you're just nervous."],[9324,9448,"Get some rest."],[11124,11183,"Hey."],[11356,11484,"Thank you."],[11484,11824,"And I'm sorry for your last night."],[11824,11908,"Wow."],[11956,12056,"I'm surprised."],[12168,12252,"So, there is actually"],[12252,12388,"something human left in you."],[13144,13392,"Stop being a jerk."],[13544,13704,"I'm not always this gentle"],[13704,13800,"and patient."],[14684,14860,"You are mine for two years."],[15040,15152,"Anything can happen"],[15152,15252,"during this time."]],"11":[[48,148,"Scared?"],[296,440,"Now you've learned your lesson."],[508,608,"Good girl."],[1040,1140,"Now, go to bed."],[1260,1372,"Your room is ready for you."],[5484,5568,"I'm sick of you"],[5568,5708,"and your goddamn fucking ideas!"],[5756,5840,"I can't wait for the day"],[5840,5952,"you finally die."]],"12":[[1388,1516,"Please forgive my son."],[1616,1744,"He's just not himself."],[1792,1892,"He still can't get used to"],[1892,2096,"taking responsibility for me"],[2096,2232,"because of my illness."],[2232,2332,"It's not an excuse."],[2428,2556,"He's way too cruel to you."],[2649,2735,"And I would give everything"],[2735,2896,"to see my dad… again."],[3176,3288,"I'm sorry for this."],[3356,3496,"I will make you a new breakfast."],[3496,3596,"Anna, come here!"],[3880,4056,"Don't judge him too harshly."],[4188,4272,"He doesn't know"],[4272,4364,"how to treat women."],[4364,4488,"He doesn't trust them"],[4488,4588,"because of his mother."],[5276,5376,"What happened to her?"],[5508,5608,"His mother left us…"],[5692,5788,"for her lover."],[5912,6040,"He thinks I kicked her out."],[6168,6288,"Let's keep it that way."],[6364,6508,"I don't wanna break his heart."],[6546,6594,"Okay."],[6603,6733,"Anna!"]],"13":[[622,710,"Ahem."],[856,992,"Why did it take so long?"],[992,1159,"I can't teleport at your command."],[1208,1345,"I see you haven't learned"],[1345,1458,"your yesterday's lesson."],[1568,1668,"Do I need to remind you?"],[1680,1824,"You too could use some lessons"],[1824,1956,"on communicating with people."],[2016,2208,"Neither your father nor I…"],[2256,2392,"deserve to be treated like that."],[2392,2536,"You have no idea…"],[2620,2756,"what he deserves…"],[2756,2876,"and what he doesn't."],[2972,3100,"I feel sorry for you."],[3100,3307,"Oh. You feel sorry for me?"],[3307,3388,"That's funny."],[3476,3636,"You know what? I'm sorry for you too."],[3864,4018,"Because you're gonna spend the night with me."]],"14":[[140,239,"You're going to the mob dinner"],[239,332,"with me."],[484,604,"What is it? Some…"],[604,744,"kind of Godfather party?"],[744,856,"Exactly."],[1072,1224,"This is not a very pleasant dinner,"],[1224,1392,"with not-so-very pleasant people."],[1508,1592,"But it's important"],[1592,1676,"for our business."],[1676,1828,"So, my father insisted I be there."],[1828,1956,"And one of the conditions"],[1956,2116,"is to come with a plus one."],[2116,2256,"Get yourself an escort."],[2256,2462,"Do not fucking interrupt me again."],[2608,2864,"Usually, I go to such events"],[2864,2992,"with my secretary, Christie."],[2992,3092,"But tonight…"],[3192,3332,"it might be dangerous for her."],[3332,3456,"Dangerous?"],[3636,3736,"Yeah."],[3848,3940,"She's too attractive."],[4016,4116,"So, I'm not?"],[4272,4372,"What does it mean?"],[4372,4483,"The dinner is organized"],[4483,4616,"by Dimitri Cherny."],[4616,4716,"The mafia boss."],[4800,4928,"He's a known womanizer."],[4928,5040,"If he wants a woman…"],[5180,5280,"nothing can stop him."],[5356,5456,"So…"],[5556,5736,"he wouldn't want me, right?"],[5812,5924,"You don't…"],[5924,6052,"catch men's eyes, so…"],[6168,6304,"no."],[6304,6404,"Probably not."],[6480,6600,"What if I refuse?"],[7108,7200,"You keep forgetting"],[7200,7336,"that you have no choice."],[8272,8372,"Buy an evening dress."],[8440,8664,"In your… style."],[8864,8972,"Now, get the fuck out."]],"15":[[480,550,"Oh."],[648,792,"You look convincing."],[936,1036,"Well done."],[1104,1280,"Dimitri has a great impact"],[1280,1384,"on our cause."],[1484,1640,"So, don't let us down…"],[1640,1764,"because of your hot temper."],[1764,1884,"I won't let you down."],[1948,2048,"Well, I hope so."],[2192,2368,"I'm glad Christie's coming."],[2368,2568,"Dimitri likes girls like that."],[2748,2876,"She'll be able to, you know…"],[4100,4236,"Have you gone mad?"],[4568,4720,"You're not going with a servant."],[4784,4920,"Today, she's not a servant."],[5104,5224,"She's my plus one."],[6228,6328,"Is she starting to mean"],[6328,6411,"something to you?"],[6411,6538,"Don't talk nonsense."]],"16":[[168,296,"What the hell, Anna?"],[452,596,"I told you to keep it low-key."],[596,732,"And now, you are too—"],[732,832,"What?"],[1012,1108,"Attractive?"],[1264,1376,"Anna…"],[1700,1784,"You're gorgeous."],[1912,1996,"Thank you."],[1996,2228,"Dimitri has probably never seen"],[2228,2364,"such a beautiful woman."],[2640,2740,"Have a good evening."],[3172,3299,"You're not leaving my side"],[3299,3407,"for the rest of the evening."],[3407,3504,"Do you understand me?"],[3708,3820,"Otherwise…"],[3952,4072,"you will regret this."]],"17":[[3368,3452,"I'm like on the set"],[3452,3588,"of a mafia movie."],[3616,3677,"Thank you."],[3836,3988,"Yes, but they are not actors."],[3988,4088,"This is for real."],[4204,4297,"So, stay close to me."],[4548,4640,"Jeremy!"],[4768,4932,"My friend."],[4932,5064,"Dimitri, my friend."],[5224,5384,"You're looking good, as always."],[5384,5500,"You too."],[5500,5656,"But don't scare your beauty."],[5656,5808,"Better introduce us."],[5868,6017,"You already have your own beauty."],[6100,6268,"That's right!"],[6268,6400,"That's right."],[6400,6536,"But what a jealous partner"],[6536,6648,"you have, uh…"],[6772,6856,"Anna."]],"18":[[688,912,"I can't take my eyes off you, Anna."],[912,1096,"Oh, someone told me"],[1096,1180,"a man's eye"],[1180,1348,"would never rest on me."],[1460,1660,"What asshole dared to say that?"],[1708,1844,"Dimitri, you have devoted"],[1844,1968,"so much time to us."],[2024,2160,"The other guests are…"],[2160,2244,"probably bored."],[2244,2328,"Yeah…"],[2328,2464,"Excuse us."],[2464,2608,"Of course, my friend. Of course."],[2608,2708,"This way."]],"19":[[652,820,"Anna, sunshine. Please, have a seat."],[1024,1124,"Don't you dare."],[1172,1256,"It's impolite."],[1256,1356,"I don't care."],[1460,1560,"Hey, hey, hey."],[1560,1688,"I don't bite. Come on."],[1932,2092,"You need to take some lessons"],[2092,2260,"on communicating with people."],[2476,2576,"Yeah."],[3332,3432,"So?"],[3544,3656,"What is your connection…"],[3740,3873,"to our friend Jeremy?"],[3936,4184,"Oh, it's a funny story actually."],[4184,4276,"Yeah?"],[4276,4416,"He beat up my husband"],[4416,4560,"and made me his slave"],[4560,4736,"for two years."],[5240,5324,"I love women"],[5324,5436,"with a sense of humor."],[5492,5632,"Dimitri, I'm bored."],[5728,5828,"Entertain yourself."],[5828,5940,"You're a big girl."],[6052,6152,"Whatever you say."],[6496,6604,"Uhm. But..."],[6604,6740,"I'm sorry for this."],[7164,7264,"How do you..."],[7376,7504,"entertain yourself?"],[7912,7996,"What do you mean?"]],"20":[[408,508,"Stop."],[556,668,"Dimitri, you misunderstood."],[668,768,"Quiet, quiet."],[768,964,"Calm down. Quiet…"],[964,1064,"Hands off!"],[1292,1416,"Hey."],[1416,1612,"I kinda like that information."],[1612,1780,"Really? Yeah?"],[1960,2044,"What do you want to do"],[2044,2180,"with this information?"],[2180,2352,"I'm pretty sure I'm gonna use it."],[2352,2472,"I like this idea."],[3136,3272,"Yeah…"],[3272,3472,"A whore needs to play like a virgin."],[6336,6436,"Well…"],[6528,6688,"We're finally alone, doll."]],"21":[[176,296,"Dimitri?"],[296,404,"Yeah?"],[516,648,"I'm here with Jeremy."],[648,748,"Yeah, of course."],[900,1020,"You know he doesn't share."],[1148,1248,"Jeremy doesn't share"],[1248,1360,"only what he values."],[1416,1556,"It doesn't apply to girls."],[1624,1752,"They're the ones we exchange."],[1856,1956,"Mine's now working."],[2104,2196,"Now is your turn."],[2288,2380,"I'll scream."],[2380,2492,"Yes, please."],[2840,2940,"Stop!"],[2940,3032,"You all say that…"],[3032,3144,"and then moan under me."],[3220,3320,"No! No!"],[3320,3404,"Yes, come on…"],[3404,3492,"Stop!"],[3492,3608,"Spread your legs."],[3708,3808,"Spread your legs, bitch."],[3920,4004,"Help!"]],"22":[[0,92,"No!"],[92,192,"What the hell?"],[732,824,"What the fuck are you doing?"],[872,1006,"I'm just trying to have fun with your girl."],[1006,1090,"Get the fuck out!"],[1196,1320,"No."],[1320,1420,"No?"],[1684,1784,"Okay."],[1868,1976,"Look…"],[1976,2208,"she will be mine."],[2208,2424,"Or your family…"],[2424,2624,"will be without my support."],[3412,3524,"Yeah, that's right."],[3892,4044,"Your father trained you well."],[4248,4314,"No!"]],"23":[[232,344,"I said no!"],[1152,1252,"Jeremy."],[1308,1420,"Jeremy, Jeremy…"],[1820,2028,"You will regret all this."],[2076,2184,"You wish."],[2240,2340,"Jeremy."],[2408,2508,"Jeremy…"],[2888,3088,"Anna. Are you okay?"],[3088,3180,"Yeah."],[3228,3328,"Did he hurt you?"],[3328,3456,"No."],[3456,3592,"It's okay."],[3592,3720,"Son of a bitch."],[3788,4020,"I will fuck you and your whore."]],"24":[[636,768,"It's okay. It's over."],[768,924,"He won't hurt you again."],[924,1068,"I won't let him."],[1256,1356,"I'm sorry."],[1424,1580,"Really, that's my fault."],[1747,1924,"I should've been here for you and..."],[2188,2296,"Why did I bring you here?"],[2296,2428,"I'm such a fucking idiot."],[2764,2868,"No."],[3084,3184,"You warned me."],[3388,3508,"But I didn't listen."],[3716,3824,"I'm so stupid."],[3824,4016,"No, no."],[4092,4192,"It's okay."],[4564,4720,"Thank you for defending me."],[4824,4924,"Always."],[4924,5044,"I'm so sorry."],[5576,5676,"Your hand."]],"25":[[232,316,"It's wounded."],[316,436,"It's nothing. It's okay."],[436,536,"Where's the emergency kit?"],[536,644,"Forget about it. It's okay."],[644,728,"Where is it?"],[920,1030,"In the glove compartment."],[1348,1490,"You don't have to do that."],[1490,1552,"Please."],[2112,2212,"I'm so sorry."],[2428,2528,"No, it's okay."],[4087,4182,"Oh."],[4220,4340,"Might be something important."]],"26":[[268,400,"It's your husband. Okay."],[448,584,"Just take the call. It's okay."],[976,1060,"Mike?"],[1108,1208,"Yeah."],[1476,1560,"We need money now."],[1640,1724,"What?"],[1724,1988,"For a new experimental treatment."],[2068,2284,"The chance of getting…"],[2284,2460,"pregnant is very high."],[2532,2756,"The price is 100 grand, but…"],[2832,2940,"the money's needed now."],[2988,3160,"What do you mean, now?"],[3316,3448,"It's nighttime."],[3448,3580,"Anna, just…"],[3648,3784,"listen to me carefully, okay?"],[3868,4061,"There is a waiting list for this treatment."],[4061,4240,"And there are only three places left."],[4240,4370,"And one of them is ours."],[4370,4460,"Can you imagine?"],[4620,4756,"But if we don't show up"],[4756,4928,"in three hours, we'll miss out."],[5008,5108,"Mike…"],[5176,5344,"we already mortgaged…"],[5436,5556,"everything…"],[5556,5684,"And I'm sold for two years."],[5684,5796,"Where am I supposed"],[5796,5888,"to get the money?"],[6064,6192,"And I found a million for our baby."],[6291,6352,"A million!"],[6680,6800,"By the way, I…"],[6876,7012,"risked my life doing it."],[7096,7196,"Anna…"],[7196,7348,"are you really gonna let…"],[7348,7540,"100 grand stop you?"],[7888,8000,"Or you just don't need"],[8000,8112,"this child anymore?"],[8540,8632,"That's my dream."],[8760,8860,"Anna…"],[9052,9164,"You live in a house"],[9164,9352,"where silverware costs"],[9352,9472,"three times more…"],[9580,9680,"than this treatment."],[9820,9964,"We have only three hours."],[10108,10252,"Only three hours."],[10732,10824,"What is your dream?"]],"27":[[368,496,"To have a child."],[976,1088,"But I can't be pregnant."],[1340,1584,"I'm an incomplete woman."],[1584,1704,"No. No, no. Stop."],[1852,1996,"That's not true, Anna."],[2044,2204,"That is not what determines"],[2204,2320,"if you are a woman or not."],[2384,2504,"No, that's true."],[2672,2772,"I can't give my husband"],[2772,2872,"a normal family."],[3052,3188,"He stays with me."],[3256,3356,"He…"],[3356,3476,"already got into debt"],[3476,3560,"because of me,"],[3560,3694,"because of my treatment."],[3928,4056,"What does he want now?"],[4200,4300,"$100K."],[4848,4968,"But it's too late."],[4968,5068,"What if you're wrong about him?"],[5280,5429,"What if he'd be a terrible father?"],[5628,5728,"I mean…"],[5788,5908,"my mother gave birth to me"],[5908,5992,"from a bastard."],[6216,6328,"Just look at who I am."],[6696,6816,"I trust Mike."],[7180,7280,"Okay."],[7344,7444,"Alright."],[7584,7684,"I will help you."]],"28":[[72,236,"No, you don't have to."],[236,336,"I will do…"],[384,496,"what I think is right."],[496,596,"That's all."],[1568,1668,"Here."],[1840,1940,"Compensation for tonight."],[2120,2204,"Don't worry."],[2204,2304,"You don't have to pay it back."],[2456,2592,"And you can take a day off"],[2592,2764,"for this… procedure."],[2900,3000,"Okay?"],[3496,3688,"Go. Before I change my mind."],[3688,3788,"Just go."],[4028,4120,"Thank you so much."]],"29":[[5044,5144,"I'm such a fool…"]],"30":[[368,480,"That fool will hesitate…"],[528,640,"for a very long time…"],[704,848,"before stealing something."],[960,1080,"We definitely have, like…"],[1128,1212,"two hours."],[1212,1312,"And I bet…"],[1368,1460,"she'll be…"],[1544,1884,"here in half an hour."],[1884,1976,"You both lost!"],[2208,2292,"Didn't they teach you"],[2292,2388,"to knock first?"],[2448,2548,"I'm sorry…"],[2548,2724,"to interrupt your betrayal."],[2772,2876,"Oh…"],[2876,3060,"Let's cut the drama here, sweetheart."],[3060,3160,"Sweetheart?"],[3324,3424,"Or maybe a fool?"],[3544,3644,"A fool…"],[3728,3828,"to believe you."],[3828,3948,"To believe your lies."],[4052,4164,"Just…"],[4164,4332,"don't play the victim."],[4404,4548,"Was my infertility a lie too?"],[4596,4696,"Honey…"],[4696,4888,"It's probably the one real thing"],[4888,5008,"about our marriage."],[5080,5416,"That you are 100% infertile…"],[5516,5740,"An incomplete woman."],[5944,6120,"Was there any treatment at all?"],[6468,6588,"You're such an idiot."],[6784,6868,"What was the point"],[6868,7020,"of spending money on you?"],[7304,7404,"I'm sick of you."],[7452,7724,"Yeah. I've been sick of you"],[7724,7852,"for a very long time."],[7972,8152,"Sick of your sacrifices."],[8208,8360,"Sick of your holiness."],[8472,8572,"I…"],[8572,8740,"still have to say thank you"],[8740,8972,"for… freeing me from my debts."],[9188,9388,"Though you'll be a slave"],[9388,9612,"for the next two years."]],"31":[[1756,1956,"Anna? What happened?"],[2184,2304,"The problem with the money?"],[3340,3500,"Anna, wait. What are you doing?"],[5944,6044,"Anna…"],[6216,6344,"I know you like me."],[6460,6560,"I know you want it."],[6732,6832,"If you don't…"],[6968,7068,"just pretend."],[8044,8144,"Fuck…"],[10972,11092,"You're driving me crazy."]],"32":[[956,1052,"Stop."],[1124,1236,"Oh, fuck."],[1620,1768,"We almost did something stupid."],[1768,1868,"Hey."],[2060,2144,"What if I wanted"],[2144,2244,"to do something stupid?"],[2292,2420,"Believe me, I want it too."],[2652,2820,"But not when you're so upset."],[3260,3360,"Anna…"],[3436,3536,"I'm sorry."],[3804,3885,"It's okay."],[3900,4030,"Come on, talk to me."],[4396,4496,"Hey…"],[5132,5292,"I don't know where to start."],[5340,5512,"Maybe start from the beginning."],[5588,5688,"Okay."],[5996,6096,"First…"],[6388,6559,"I was nearly raped."],[6724,6856,"And then, it turned out"],[6856,6956,"that my marriage…"],[7104,7188,"was a lie…"],[7288,7432,"and so was my treatment."],[7672,7772,"And I rushed here."],[7944,8120,"I wanted to see you so badly…"],[8352,8464,"It turned out…"],[8572,8700,"you didn't wanna see me either."],[8700,8800,"Hey."],[8984,9141,"You're right about everything."]],"33":[[0,176,"You're right about everything."],[332,444,"Except for me."],[644,750,"I've dreamed of kissing you"],[750,900,"since the first moment we met."],[1056,1196,"Why didn't you kiss me?"],[1372,1456,"Because you knew"],[1456,1624,"I'd smack you right away…"],[1752,1936,"How did an asshole like Mike"],[1936,2059,"get lucky enough to marry"],[2059,2252,"such an incredible woman like you?"],[2252,2364,"I don't understand."],[2496,2632,"I was too trusting."],[2912,3012,"How do you know Mike?"],[3260,3360,"Um…"],[3536,3664,"He used to work for me…"],[3664,3776,"as an errand boy."],[3776,3838,"What?"],[3888,4048,"And every day he had a new woman."],[4320,4424,"God."],[4424,4540,"I'm sorry."],[4824,4936,"That's disgusting."],[5356,5504,"Why did you lend him a million?"],[5504,5604,"I didn't."],[5808,6004,"Mike slept with the governor's wife."],[6104,6197,"When it all came out,"],[6197,6324,"they blamed it all on me."],[6448,6592,"It cost me a million. That's it."],[6756,6876,"He's pathetic."],[6932,7032,"Anna…"],[7408,7560,"You can get out of your contract…"],[7836,7972,"if I kill Mike."]],"34":[[328,428,"What?"],[588,680,"How can you want someone"],[680,764,"to be killed?"],[940,1039,"No."],[1097,1262,"I'd rather work here for two years."],[1262,1403,"I'm so sorry. I'm..."],[1462,1555,"Fuck."],[1636,1720,"I'm just a fool"],[1720,1832,"for offering you this."],[1832,1916,"Hey, hey."],[1916,2016,"Just forget about this."],[2064,2164,"Hey."],[2308,2408,"Come here."],[2604,2704,"Please."],[3164,3264,"I'm sorry."],[3324,3424,"Please hold me."],[3500,3584,"Come on."],[3584,3668,"Please."],[3716,3816,"So sorry."],[3944,4044,"Never let me go."],[4288,4488,"I think I can't let you go anymore."],[4668,4768,"Ever."],[5328,5440,"I'm so tired."],[5440,5540,"Okay."],[5872,5956,"Come on."]],"35":[[2340,2460,"Hey."],[2624,2724,"Please stay."],[2982,3060,"Okay."]],"36":[[3300,3382,"Jeremy?"],[5412,5556,"Can't you see we're busy?"],[6268,6352,"Jeremy?"],[6556,6720,"Let's have fun."],[6720,6804,"Who was it?"],[6912,7012,"Cleaning lady."],[7188,7302,"And now…"],[7342,7532,"What the fuck are you doing, Christie?"],[7600,7700,"Get off my desk."]],"37":[[1092,1228,"\"It hurts too much"],[1228,1388,"to see you with someone else.\""],[1436,1580,"\"I loved you, Jeremy.\""],[1740,1832,"\"But I have to learn"],[1832,1932,"to love myself.\""],[2284,2384,"\"Goodbye.\""]],"38":[[0,100,"Get off my desk."],[260,344,"Now."],[484,584,"And go away."],[1808,2008,"Jeremy, be careful."],[2008,2160,"Dimitri's now after you."],[2332,2432,"What do you know?"],[2488,2572,"You humiliated him"],[2572,2684,"at the mob dinner,"],[2684,2828,"in his own home."],[2828,2972,"Now, he wants revenge."],[3020,3260,"I'll take care of it. Just get out."],[3308,3504,"Seems this girl put a spell on you."],[3600,3812,"You basically gave up on business."],[3812,3928,"You have not even received"],[3928,4112,"your parents' inheritance yet."],[4360,4460,"Jeremy…"],[4544,4772,"Is this gray mouse really worth"],[4772,4972,"such sacrifices?"],[5152,5252,"Jeremy…"],[5300,5492,"A successful man must have"],[5492,5620,"the right woman with him."],[5896,6008,"The one who knows"],[6008,6232,"that she has to make sacrifices"],[6232,6384,"for the sake of her family."],[6728,6880,"The one you're not ashamed"],[6880,7056,"to go out in public with."],[7540,7740,"And who's ready to do anything"],[7740,7852,"for success."],[7992,8076,"You need someone"],[8076,8228,"who will never turn away,"],[8228,8356,"no matter how horrible"],[8356,8500,"or dirty things can get."],[8912,9080,"Christie, Christie, Christie…"],[9396,9536,"You're not worth even a hair"],[9536,9648,"of Anna's head."],[9928,10100,"I'd sacrifice 100 people like you"],[10100,10192,"for her."],[11645,11734,"You're right."],[11734,11928,"This girl is his biggest weakness."],[12044,12144,"It's time to act."]],"39":[[0,120,"Anna, we need to talk."],[3156,3240,"Pick up the phone."],[3360,3444,"I'm begging you."],[3444,3544,"Pick up the phone, please."],[4024,4184,"Something happened to Anna."],[4184,4268,"It looks like"],[4268,4416,"Dimitri started his revenge."],[4544,4712,"Oh God, poor Anna."],[4760,4908,"I'm gonna kill that son of a bitch."]],"40":[[864,1016,"Get out! Now!"],[1900,2044,"John Wick in the flesh!"],[2092,2212,"Don't play dumb with me."],[2328,2412,"Where is she?"],[2700,2792,"Where is who?"],[2792,2896,"Anna!"],[2896,3052,"I don't know where your whore is."]],"41":[[520,604,"Hey."],[768,916,"Calm down. I can handle it."],[964,1076,"But, boss…"],[1528,1720,"Get out of here!"],[2180,2300,"Fuck off!"],[3208,3336,"Well, well, well."],[3488,3600,"Humiliated me"],[3600,3760,"in my own house again…"],[3888,4080,"I hate such coincidences."],[4080,4180,"I swear…"],[4228,4348,"if something happened to her…"],[4440,4552,"you are a dead man."],[4696,4840,"Don't cut off your dick."],[4968,5160,"What? You didn't get it, did you?"],[5236,5428,"I said I wanted to pour myself"],[5428,5540,"a shot of vodka."],[5932,6068,"You want some?"],[6360,6460,"How strange…"],[6584,6752,"to see you in this state."],[7028,7228,"Love… shakes the ground"],[7228,7340,"under your feet."],[7772,7940,"That's why I prefer…"],[8088,8264,"to fuck, not to love."],[8732,8844,"Calm down, Romeo."],[8952,9148,"And then, we'll talk like real men…"],[9212,9384,"not hysterical women."]],"42":[[296,512,"I don't have your Juliet."],[864,1024,"I know the way you take revenge."],[1264,1432,"My revenge is different."],[1592,1772,"I'll tear your business apart…"],[1864,1988,"piece by piece…"],[2036,2352,"both the shady and the legit one."],[2400,2484,"I won't even leave"],[2484,2700,"your Crystal Spring standing."],[2792,2965,"So… get ready"],[2965,3115,"for some serious threat."],[3764,3856,"To your health."],[4752,4880,"So, where the fuck is she?"]],"43":[[332,508,"I don't recognize you, Jeremy."],[604,756,"You've become so, uh…"],[884,984,"Fuck, yes…"],[1068,1188,"…soft-hearted."],[1244,1344,"Soft-hearted."],[1544,1644,"The heir of a…"],[1800,1992,"large business empire…"],[2108,2234,"is a wimp."],[2260,2389,"And because of who?"],[2428,2556,"Because of woman!"],[2556,2714,"A piece of meat with three holes"],[2714,2819,"for a man's pleasure."],[2856,2984,"You fucking serious?"],[3228,3340,"I wonder what your father"],[3340,3460,"thinks of all of this?"],[3696,3796,"What do you mean?"],[4032,4132,"Nothing."],[4284,4452,"Just thinking."],[4764,4864,"Alright."],[4988,5116,"Thank you, Dimitri. But…"],[5116,5228,"you've got what you deserved."],[5444,5556,"As for the business…"],[5712,5824,"we'll figure it out later."],[6132,6255,"Not so fast."]],"44":[[72,172,"I just have…"],[236,362,"a little business with you."],[580,756,"Bring this faggot here."],[1916,2020,"What is he doing here?"],[2068,2196,"So, do you know him?"],[2376,2512,"He claims he has some…"],[2628,2728,"debt with you."],[2792,2960,"He really disappointed me."],[3100,3228,"And then he disappeared."],[3328,3420,"And after that…"],[3468,3568,"he showed up…"],[3624,3776,"yesterday, out of nowhere."],[4168,4391,"Brought me a pack full of cash…"],[4468,4660,"and saying that this is…"],[4764,4864,"was…"],[4940,5024,"the whole debt."],[5136,5220,"And I asked…"],[5268,5396,"where is my interest?"],[5508,5652,"Where's my moral compensation,"],[5652,5780,"fucking asshole?"],[6100,6174,"Jeremy."],[6240,6364,"Jeremy, tell Dimitri…"],[6364,6504,"I know how to pay my debts."],[6748,6868,"Even with interest."],[6868,7012,"You liked our deal, didn't you?"],[7124,7224,"My ex…"],[7224,7392,"I know my ex isn't gorgeous,"],[7392,7576,"but in bed, she's always up for it."],[7576,7672,"Jeremy."],[7728,7828,"Get off!"],[8128,8228,"How much is in the wad?"],[8320,8432,"$100K?"],[8488,8608,"Yeah, something like that."],[8608,8708,"How do you know?"],[8944,9072,"That son of a bitch is lying."],[9188,9288,"He hasn't paid me back."],[9408,9536,"And he won't pay you either."],[10164,10324,"Jeremy! Jeremy! Jeremy!"],[10528,10690,"Guys! Guys!"],[10690,10936,"Dimitri, I'll explain everything. Please."],[10936,11060,"Yeah, I know."]],"45":[[1392,1492,"Help!"],[1644,1728,"Somebody!"],[2828,2928,"Thank God!"],[3036,3120,"Mr. Lewis!"],[3200,3320,"Anna, what happened?"],[3384,3496,"Why are you here?"],[3496,3580,"I don't know."],[3580,3732,"Someone kidnapped me,"],[3732,3860,"but I didn't see his face."],[3924,4032,"Please help me."],[4088,4188,"We need to cut the rope."],[6658,6799,"I look at you…"],[6825,6930,"and I don't get it."],[7016,7220,"What did my son see in you?"]],"46":[[292,392,"So, it was you…"],[2744,2888,"You've been pretending"],[2888,3104,"to be sick all the time."],[3260,3396,"Anna, Anna…"],[3568,3712,"I used your weapon…"],[3768,3852,"Weakness."],[3940,4156,"You manipulated us."],[4156,4364,"You controlled us like puppets."],[4464,4572,"Isn't that so?"],[4572,4676,"No, I didn't."],[4856,4956,"Well, now…"],[5048,5176,"I'll use my weapon…"],[5288,5388,"in my hand."]],"47":[[836,936,"Do you wanna kill me?"],[1144,1280,"Yes, I wanna kill you."],[1764,1876,"But not right now."],[2144,2368,"I want a slow death…"],[2492,2584,"so my son…"],[2892,3068,"won't miss the spectacular act."],[3428,3593,"Do you think he'll ever forgive you?"],[3612,3856,"I hope so. If he grows up—"],[4628,4728,"Bitch."],[4892,5036,"I should've killed you right now."],[6328,6464,"Have you calmed down?"],[6724,6824,"Can we go on?"]],"48":[[0,136,"Search the entire house."],[236,348,"Garages, basements."],[432,552,"She's gotta be here somewhere."],[700,863,"Just don't let my father find out."],[988,1084,"Go."],[1740,1840,"She is here…"],[2076,2176,"I can feel it."],[2832,3024,"Son, is something wrong?"],[3288,3388,"You look stressed."],[3612,3724,"Yes, um…"],[3888,3972,"Something happened"],[3972,4056,"at the mob dinner."],[4236,4336,"Some problems."],[4442,4594,"But you probably already know."],[4594,4687,"Yeah."],[4744,4851,"Yeah, I know."],[4936,5104,"I wouldn't have forgiven Dimitri"],[5104,5204,"for that either."],[5360,5528,"Going after a woman like that."],[5628,5800,"Trying to use force on her."],[6152,6252,"Poor Anna…"],[6416,6500,"I think I know"],[6500,6628,"why she had that attack."],[6628,6728,"An attack?"],[6868,6952,"What attack?"]],"49":[[372,468,"Anna?"],[580,680,"Honey, can you hear me?"],[1180,1308,"Call an ambulance now."],[1308,1484,"That's what I did immediately, son."],[1656,1828,"They told me it was stress-related."],[1912,2016,"And they gave her…"],[2064,2248,"glucose through an IV…"],[2248,2396,"and told her to rest."],[2856,3000,"She fainted right there."],[3096,3224,"But why is her room a mess"],[3224,3336,"if she fell here?"],[3560,3720,"She probably fainted there as well."],[3812,3896,"I mean…"],[3896,4048,"when she came to me already,"],[4048,4208,"she looked as pale as a ghost."],[4572,4684,"And then, she came here…"],[4752,4852,"with a tray and fell."],[5052,5152,"Poor little bird."],[5500,5612,"Everything's gonna be alright,"],[5612,5716,"honey, okay?"],[5916,6016,"I promise you."],[6728,6828,"He can—"],[7288,7388,"What?"],[7492,7664,"He can walk."],[7844,7956,"What did she say?"]],"50":[[0,100,"What did she say?"],[300,400,"She said…"],[536,696,"it was hard for her to breathe."],[1332,1432,"Hey, what are you doing?"],[1480,1688,"Put her down. She needs to rest."],[1688,1788,"She needs air."],[1848,1948,"We're going outside."],[2048,2160,"Come on."],[2464,2564,"Damn it."]],"51":[[84,204,"I'll get you to the hospital."],[368,520,"So sorry about that bastard."],[520,784,"Don't apologize for your parents."],[1728,1956,"I didn't plan this climax."],[2064,2164,"But you ran away."],[2248,2360,"I had no choice."],[2360,2592,"Dad, put the gun down."],[2592,2736,"You're not going to shoot me."],[2784,2884,"Unless I have to."]],"52":[[312,396,"Put her down."],[444,572,"No."],[572,672,"Put her down, I said!"],[2828,2940,"Raise your hands…"],[3060,3160,"so I can see them."],[3328,3496,"And don't do anything stupid."],[3692,3792,"What do you want?"],[3960,4104,"What a pathetic sight."],[4216,4328,"Are you my son?"],[4416,4516,"What have you become?"],[4688,4896,"Women are your weakness."],[5028,5188,"First, it was your mother."],[5260,5392,"And now, she."],[5596,5772,"It's amazing how they look alike."],[6216,6408,"Look, I understand"],[6408,6552,"why you hated her so much."],[6700,6828,"She reminds you of someone"],[6828,6920,"who hurt you before,"],[6920,7072,"but she's not Mom."],[7164,7296,"She will never leave her son."],[7296,7380,"She'll nev—"],[8500,8600,"She never left."],[8776,9116,"I got rid of her once and for all."],[9212,9312,"No, no. You're lying."],[9456,9540,"You're fucking lying."],[9540,9776,"There! There."],[9872,10000,"That's what I'm talking about."],[10208,10320,"She's your weakness."],[10712,10856,"She made you vulnerable."],[10956,11132,"And you need to get rid of her."],[11540,11640,"Kill her."]],"53":[[172,276,"What?"],[276,460,"I pumped her…"],[608,824,"a certain amount of tranquilizers."],[1320,1440,"But not enough…"],[1496,1624,"to remove her."],[1672,1824,"Inside, there's another syringe…"],[1908,2052,"with the same dose."],[2188,2272,"Give it to her."],[2492,2644,"You fucking son of a bitch."],[2800,2920,"I will never kill her."],[3004,3124,"She's gonna die anyway."],[3216,3300,"You could do it"],[3300,3412,"with a gentle dose…"],[3480,3580,"from your hand…"],[3716,3800,"or I could do it"],[3800,3992,"with a piercing bullet from mine."],[4104,4204,"Fuck…"],[5668,5812,"And if I do what you want…"],[5976,6152,"you'll sign the business over to me?"],[6308,6567,"Of course. We're family."],[6684,6784,"One blood."]],"54":[[364,476,"Hurry up!"],[1028,1156,"You're right, Father."],[1344,1456,"She's my weakness…"],[1716,1800,"but she's the one"],[1800,1912,"who makes me happy."],[2680,2792,"I don't care…"],[2900,3012,"about your business…"],[3972,4072,"inheritance…"],[4176,4288,"or empire."],[4704,4816,"Because the hole…"],[4900,4984,"you made in me"],[4984,5068,"by killing my mother"],[5068,5216,"was filled by Anna."],[5880,5992,"You wanna make another hole,"],[5992,6092,"killer?"],[6196,6316,"Come on."],[6572,6672,"Do it."],[6792,6912,"You can't hurt me anymore."],[7364,7568,"Do it! Do it!"],[9460,9560,"I'm sorry."]],"55":[[28,150,"Jeremy, look at me."],[228,321,"I'm here."],[366,452,"Jeremy, look at me."],[552,692,"Look at me. Look at me."],[772,964,"Please. Don't sleep."],[964,1084,"Wake up."],[1084,1184,"It's gonna be alright."],[1244,1344,"I'm here with you."],[1408,1508,"I'm with you, alright?"],[1620,1704,"Look at me."],[1752,1984,"Let me go! Let me go!"],[2040,2140,"Let me go!"]],"56":[[1996,2100,"Hey."],[2100,2200,"Hey…"],[2656,2740,"My love."],[2788,2888,"Finally."],[3032,3132,"Finally, you're home."],[3296,3416,"If it wasn't for you…"],[3464,3560,"I wouldn't be here."],[3886,3995,"The bullet would've hit me"],[3995,4104,"right in the heart."],[4140,4204,"Thank you."],[4964,5064,"So?"],[5260,5372,"What about your dad?"],[5372,5508,"Did you visit him in prison?"],[5592,5692,"No."],[5908,5992,"Let him feel"],[5992,6152,"what loneliness is like."],[6152,6252,"Time to pay for everything"],[6252,6380,"he's done. Okay?"],[6588,6672,"I'm not asking you"],[6672,6784,"to forgive him, but…"],[6996,7140,"at least try to let him go."],[7304,7456,"He took my mother away from me."],[7780,7900,"He took my chance…"],[7984,8084,"to be normal…"],[8276,8360,"to be someone"],[8360,8504,"who is not afraid of love."],[8736,8848,"Now you're not afraid of it…"],[9044,9204,"not afraid to be vulnerable…"],[9247,9323,"and weak."],[9323,9393,"Yeah."],[9444,9536,"Because you know"],[9536,9636,"I'll be there for you."],[10128,10248,"I'm not afraid."],[10564,10664,"Not anymore."],[10896,10996,"Thanks to you."],[11165,11237,"Your arm."],[11237,11376,"I don't care."],[11460,11560,"You're my painkiller…"],[11688,11788,"my drug."]],"57":[[3480,3580,"I love you."],[3696,3832,"I love you so much."]],"58":[[816,952,"What are we gonna do now?"],[952,1176,"Well… we'll get married"],[1176,1316,"and be very happy."],[1364,1464,"Sound good to you?"],[3152,3252,"I can't have children."],[3584,3684,"And…"],[3880,4000,"you won't be happy"],[4000,4084,"with such an incomplete—"],[4084,4184,"Stop that."],[4280,4448,"You're the most complete woman"],[4448,4552,"for me."],[4700,4836,"And nothing else matters."]],"59":[[1132,1232,"Guess who."],[1280,1372,"Well, I don't know."],[1372,1540,"Maybe the one who promised"],[1540,1640,"to make me breakfast."],[1640,1740,"Good morning."],[1908,2008,"Good morning."],[2092,2212,"Stop!"],[2296,2444,"How did you guess?"],[2444,2572,"Because I will always recognize"],[2572,2672,"your scent."],[2780,2880,"Wait."],[2924,3031,"I have something for you."],[3091,3145,"Yes, I know"],[3145,3258,"you have something for me."],[3258,3484,"Hey! Jeremy…"],[3552,3652,"Maybe here."],[3716,3828,"Stop."],[3964,4048,"Look."],[4580,4680,"Is this—"],[4852,4964,"Is this what I think it is?"],[4964,5068,"Yeah."],[5116,5212,"Wow."],[5416,5500,"You remember"],[5500,5600,"what the doctors said?"],[5760,5880,"It's a miracle."],[5880,5988,"Anna, my love…"],[6104,6204,"Miracles become real"],[6204,6316,"when you believe in them."],[6496,6592,"You are my miracle."]]}