{"1":[[1830,2002,"Mr. Baron. - Mr. Baron."],[2002,2110,"Excuse me. - Mr. Baron."],[2110,2248,"Excuse me, Mr. Baron."],[2248,2298,"Rumor says"],[2298,2410,"you've returned from abroad"],[2410,2573,"to start a family and produce an heir."],[2573,2627,"Any comment?"],[2665,2706,"Your family"],[2706,2861,"has quite a legacy to uphold."],[2894,2982,"Any pressure to continue"],[2982,3098,"the Baron bloodline?"],[3115,3224,"Have you found someone special"],[3224,3299,"to continue on the"],[3299,3403,"Baron family name?"],[3524,3607,"Just one statement."],[3636,3728,"Please, tell us."],[3741,3820,"The people want to know."],[4145,4262,"It's Daddy!"],[4404,4529,"Guys, my cousin Matt Baron"],[4529,4621,"has returned to take over"],[4621,4717,"the Baron Group."],[4746,4796,"However,"],[4838,4913,"it is true that"],[4913,5059,"my cousin is an only child,"],[5075,5171,"and his parents told me"],[5171,5238,"to ask the media"],[5238,5380,"to help him find a wife."],[5409,5613,"So any single woman"],[5613,5843,"who'd be willing to date Matt,"],[5864,6035,"or potentially have a child,"],[6035,6185,"you are welcome to reach out."],[6222,6285,"Whoever produces"],[6285,6389,"the next Baron heir,"],[6389,6485,"we promise to treat you"],[6485,6619,"just like family"],[6619,6740,"and to give you everything"],[6740,6852,"you've ever dreamed of."],[6861,6973,"Sean, what are you doing?"],[7007,7165,"Just following your parents' orders."],[7165,7215,"What's the big deal."],[7223,7286,"Daddy!"],[8295,8362,"Daddy."],[8658,8721,"Daddy."],[8721,8829,"It's me, Joyce."],[8829,9009,"I finally found you."],[9038,9138,"Did she just say Daddy?"],[9167,9205,"Daddy?"],[9217,9267,"Daddy?"],[9405,9476,"Daddy?"]],"2":[[66,208,"Mr. Baron already has a daughter?"],[237,296,"Who's the mother?"],[296,425,"And why don't we know about this?"],[809,934,"You made a mistake, little girl."],[934,1051,"I'm not your Daddy."],[1109,1322,"But Mommy showed me your picture."],[1322,1493,"She said you're my Daddy."],[1885,1968,"Matt, isn't that your"],[1968,2143,"college senior yearbook photo?"],[2256,2377,"How did this kid have that?"],[2485,2610,"I don't know your Mommy."],[2656,2761,"She stole my photo"],[2761,2894,"and she put you up to this."],[2990,3073,"You should leave now,"],[3103,3236,"or I'm not gonna be so nice"],[3236,3345,"to you anymore, okay?"],[3503,3603,"You're quite the little liar,"],[3603,3691,"aren't you?"],[4033,4141,"Whose child is this?"],[4204,4275,"Joke's over."],[4316,4441,"Come get your daughter."],[4504,4679,"My Mommy is not a thief,"],[4679,4867,"and I'm not a liar."],[4942,5088,"Check it and you'll see."],[5263,5467,"I don't have time to play games, okay?"],[5526,5672,"Now go run on back to your mom."],[6222,6302,"How about this?"],[6427,6514,"I'll take this."],[6560,6681,"But if you and your Mommy are lying,"],[6681,6815,"you're gonna be in a lot of trouble."],[6898,7027,"You sure you want me to test it?"],[7077,7119,"Yes."],[7136,7194,"I'm sure."]],"3":[[1109,1188,"Hi babies."],[1263,1334,"Mommy,"],[1343,1518,"Daddy didn't recognize me and"],[1526,1651,"called me a liar."],[1659,1805,"Does he hate me?"],[1847,1897,"No, sweetie."],[1981,2031,"He just doesn't know"],[2031,2122,"you're his daughter."],[2189,2281,"Once he finds out the truth,"],[2281,2394,"he will love you more than anything"],[2394,2494,"in this entire world."],[2544,2690,"But all the other kids"],[2690,2852,"have daddies who know them."],[2882,3098,"Why doesn't Daddy know me?"],[3203,3336,"I'm so sorry, sweetheart,"],[3411,3511,"this is all my fault."],[3632,3724,"But don't give up."],[3799,3899,"Your father is the only person"],[3899,4020,"outside these walls."],[4037,4170,"And you need to go back to him."],[4220,4312,"Okay."],[4312,4483,"I'll go find Daddy again."],[4508,4646,"This time I'll tell him"],[4646,4813,"you didn't do anything wrong,"],[4859,5096,"I'll ask him to save you, Mommy."],[5146,5226,"No, Joyce."],[5309,5359,"I don't want you"],[5359,5518,"to mention me to him ever, okay?"],[5555,5651,"All I care about is that"],[5651,5759,"you're safe and happy."],[5784,5876,"But Mommy,"],[5876,6101,"Daddy is a super big boss now,"],[6151,6318,"bigger than your family."],[6356,6523,"He can protect me and you."],[6606,6685,"When I met your father,"],[6685,6810,"he was a poor college student."],[6902,7090,"Even if he is doing better now,"],[7194,7282,"it's nothing compared to"],[7282,7386,"what we're up against."],[8028,8208,"Mommy doesn't believe daddy"],[8208,8600,"is a super big boss, what should I do?"],[8646,8792,"Matt, I know you resent me,"],[8904,9009,"but please,"],[9042,9175,"don't take that anger and hatred"],[9175,9305,"on our daughter."],[9392,9492,"You murderers."]],"4":[[29,125,"Your father is dead,"],[221,396,"and you have no proof against us."],[521,629,"Now that my"],[717,938,"dear brother isn't around anymore,"],[971,1046,"the Abell Group"],[1046,1184,"will have to answer to me."],[1263,1334,"And you"],[1459,1685,"will obey everything I say."],[1805,1951,"Like a tamed dog,"],[2018,2093,"Or,"],[2256,2398,"it would be a shame"],[2431,2590,"if the same fate fell on that"],[2590,2752,"little college sweetheart of yours."],[3770,3883,"Matt, forgive me."],[3941,4083,"It's the only way to keep you safe"],[4083,4175,"from my family."],[4500,4554,"Linda."],[4646,4758,"It's your favorite dessert."],[4771,4871,"I made it myself."],[4900,4938,"Try it."],[4954,5080,"I'm breaking up with you, Matt."],[5184,5246,"What?"],[5359,5422,"Why?"],[5609,5743,"Did I make you feel pressured"],[5743,5847,"by bringing up marriage?"],[5939,5980,"Pressured?"],[5980,6031,"No."],[6181,6322,"I feel sorry for you, Matt."],[6402,6498,"My family owns one of the"],[6498,6614,"biggest corporations in the city,"],[6614,6685,"and you?"],[6756,6894,"You're broke, you're nothing."],[7007,7102,"Did something happen"],[7102,7194,"with your family?"],[7219,7386,"Linda, tell me, I can help you."],[7453,7578,"Look, I never told you this before,"],[7578,7711,"but I'm actually a Ba-"],[8329,8458,"I'm with Toby now."],[8475,8641,"He's the heir to the Lawson family."],[8837,8942,"Being with him made me realize"],[8942,9059,"how worthless you are."],[9622,9772,"So save your precious dessert,"],[9805,9926,"it's garbage to me now."],[9930,9993,"Linda!"],[10122,10260,"Just stay out of my life, Matt."],[10331,10472,"I never wanna see you again."],[10994,11086,"How you doing?"],[11653,11795,"I hate you, Linda!"],[11924,12070,"I never wanna see you again,"],[12074,12237,"and I will never forgive you!"]],"5":[[8,158,"I never wanna see you again,"],[166,329,"and I will never forgive you!"],[375,529,"I hate you, Linda!"],[1155,1280,"After all these years,"],[1280,1468,"why am I suddenly dreaming of her?"],[1735,1789,"Mom?"],[1835,1906,"Dad, what are you,"],[1906,2010,"what are you doing here?"],[2027,2248,"Well, we heard a little girl showed up"],[2248,2389,"claiming to be your child."],[2402,2506,"Well, where is she?"],[2519,2640,"We, well, we want, we want to see her."],[2669,2840,"Matt didn't believe her story,"],[2840,3019,"so he sent her away."],[3019,3178,"Sent her away? - Sent her away?"],[3186,3370,"I have a meeting in ten minutes."],[3378,3424,"And please,"],[3424,3616,"don't encourage Sean's nonsense."],[3674,3828,"Don't you run away from us, young man."],[3828,3958,"We are not finished."],[4029,4112,"And you."],[4158,4371,"You let him send her away?"],[4400,4525,"You're Matt's cousin."],[4525,4675,"When he does something stupid,"],[4675,4884,"it's your job to stop him."],[4896,5013,"We've been waiting years"],[5013,5155,"for Matt to settle down."],[5163,5321,"After that girl broke his heart,"],[5342,5388,"he hasn't even"],[5388,5501,"looked at another woman."],[5526,5647,"That little girl could be our"],[5647,5905,"only hope of having a grandchild,"],[5918,6122,"the sole heiress of our family."],[6168,6343,"You know, I'm always one step ahead."],[6723,6923,"Look at what I have."],[7052,7161,"I'll take this."],[7178,7319,"But if you and your Mommy are lying,"],[7319,7461,"you're gonna be in a lot of trouble."],[7524,7686,"You sure you want me to test it?"],[7720,7766,"Yes."],[7778,7853,"I'm sure."],[7999,8195,"This is the little girl's hair."],[8516,8621,"And this is Matt's."],[8650,8762,"One DNA test,"],[8762,8871,"and we'll know the truth."]],"6":[[308,454,"You're such a poor little girl."],[467,663,"I'm not a poor little girl."],[713,938,"My Mommy said I have a Daddy."],[950,1213,"And we're gonna be together real soon."],[1226,1301,"Alright,"],[1326,1472,"I'll pray that your wish comes true,"],[1472,1547,"little Joyce."],[1668,1822,"Thank you, Auntie Ana."],[1830,1947,"Be careful going home."],[1956,2102,"I'll see you next time, okay?"],[2965,3157,"I was born in prison."],[3274,3499,"My Mommy and the other ladies,"],[3499,3624,"they raised me."],[3703,3916,"But Mommy had a really hard life."],[4750,5021,"The nice lady next door gave me a pie."],[5038,5176,"Thank you, Mrs. Smith."],[5367,5472,"Oh, no."],[6418,6635,"Mm, so tasty."],[6648,6806,"I wish Mommy was here with me"],[6806,6923,"so she could try it."],[7048,7228,"Ah! There you are, you little brat."]],"7":[[37,183,"Ah! There you are, you little brat."],[254,446,"Did you think you could hide from us?"],[533,613,"Dad, dad!"],[684,796,"She's just a little girl."],[796,930,"You're scaring her."],[967,1080,"I'll handle this."],[1201,1313,"Hi, Joyce."],[1355,1530,"Do you remember Grand-Uncle Bill"],[1530,1659,"and Auntie Cindy?"],[1701,1835,"We just have to ask you something"],[1835,1939,"very important."],[1989,2039,"Do you know"],[2039,2214,"where Mommy hid the special key?"],[2310,2481,"You mean the key I put there?"],[3007,3119,"No, not this one."],[3265,3345,"Sweetie,"],[3395,3616,"we're looking for a bigger key."],[3620,3778,"A key to a safe."],[3824,3983,"Have you seen something like that?"],[4241,4383,"Your mom would have told you."],[4396,4529,"The safe has your grandpa's"],[4529,4738,"top secret technology in it."],[4796,4863,"Now tell me,"],[4967,5213,"where is the key?"],[5276,5380,"Answer her."],[5413,5488,"Now!"],[5522,5705,"The technology belongs to"],[5705,5826,"Grandpa and Mommy."],[5826,5960,"You can't take it."],[5985,6197,"You stubborn little brat!"],[6285,6352,"I know what you're thinking,"],[6352,6448,"but I've already looked over"],[6448,6523,"the numbers twice."],[6523,6627,"It's Matt's!"],[6669,6756,"It's Matt's."],[6756,6865,"Why are you shouting?"],[6898,7023,"What's mine?"],[7036,7186,"That little girl."],[7219,7353,"She is your daughter."]],"8":[[16,141,"She is your daughter."],[316,450,"Quit the nonsense."],[946,1096,"But I've never been with..."],[3169,3232,"Linda?"],[3319,3470,"Could it really be her?"],[3666,3787,"She is a Baron."],[3841,4012,"Oh Henry, look."],[4049,4237,"We have a grand daughter."],[4266,4466,"We need to find this girl immediately."],[4487,4754,"She is the 10th heiress of our family,"],[4771,4909,"she cannot be left out there alone."],[4909,5005,"Yes, and her mother must be"],[5005,5201,"made a proper Baron as well."],[5251,5409,"She'll be the lady of the house."],[5905,5976,"Dad,"],[6014,6131,"the key's not here."],[6160,6277,"We've looked everywhere."],[6606,6760,"Joyce, sweetie."],[6798,6998,"Tell Auntie Cindy where the key is."],[7040,7140,"You help, I'll make sure"],[7140,7278,"you live in a beautiful house"],[7278,7382,"with pretty dresses"],[7382,7557,"and all the toys you could want."],[7607,7728,"What does that sound?"],[7782,7916,"I really don't know."],[7916,8033,"Please don't hurt me,"],[8033,8191,"and don't hurt my Mommy."]],"9":[[8,158,"I really don't know."],[166,300,"Please don't hurt me,"],[300,471,"and don't hurt my Mommy."],[563,667,"Like mother, like daughter."],[696,900,"Stubborn and ungrateful like Linda."],[942,1042,"We should've let you die"],[1042,1159,"in that jail with your mom"],[1159,1284,"when we had the chance."],[1305,1514,"You're the one who hurt my Mommy."],[1743,1856,"So what if I did?"],[1926,2002,"I'm telling you,"],[2002,2214,"the Abell Group is my family company."],[2235,2423,"It has nothing to do with your mother."],[2852,2994,"Oh, go ahead and cry."],[3048,3115,"I'm telling you,"],[3115,3282,"your mother will not come out"],[3282,3390,"from that jail."],[3440,3624,"What's with this stupid photo?"],[3787,3966,"What? Saved it for your mom's funeral?"],[4383,4462,"There it is."],[4554,4621,"The key to the safe."],[4713,4796,"It's my mommy's."],[4796,4904,"You can't take it."],[5184,5342,"Give me the key."],[5576,5659,"Hand it over."],[5672,5726,"Now."],[5797,5989,"Or I swear I'll kill you."]],"10":[[834,963,"This is where the little girl lives."],[975,1042,"Oh sweetheart,"],[1042,1159,"come home with grandma."],[1451,1534,"Hand it over."],[1584,1655,"Now."],[1697,1755,"Ah!"],[1826,1931,"You bit me."],[1964,2097,"God! You animal!"],[2156,2310,"Give me the key now."],[2594,2652,"Dad."],[2852,2902,"She,"],[2932,3128,"she's not dead, right?"],[3253,3415,"We kept this little bastard alive"],[3415,3528,"just to get the key."],[3545,3678,"Now that we have what we want."],[3945,4104,"It's time to get rid of her."],[4429,4517,"For good."],[4909,5013,"Don't touch her!"]],"11":[[321,429,"Don't touch her!"],[1142,1197,"Joyce."],[1355,1409,"Joyce."],[1505,1559,"Hey, come here."],[1576,1680,"Come here, you're ok."],[2035,2085,"Daddy,"],[2114,2268,"I told you the truth."],[2268,2489,"My Mommy and I were not liars."],[2498,2560,"I know."],[2652,2694,"I know."],[2694,2777,"I'm gonna keep you safe"],[2777,2877,"from now on, okay?"],[3003,3086,"I promise."],[3199,3365,"A pinky promise."],[3374,3440,"Okay?"],[3566,3649,"Take the girl,"],[3728,3849,"but the key stays here."],[3874,3945,"What key?"],[3953,4049,"The key in her hands."]],"12":[[8,83,"Daddy,"],[112,212,"Grandpa and Mommy"],[212,358,"said to keep this safe."],[358,592,"Please don't let anyone take it."],[642,792,"Hey, if your grandpa and your mommy"],[792,871,"left it with you,"],[871,1026,"then it stays with you, okay?"],[1092,1226,"No one else gets to take it."],[1380,1476,"Who are you to interfere with"],[1476,1568,"our family's business?"],[1572,1751,"That key belongs to Abell heir."],[1768,1931,"She's stealing what's ours."],[1956,2027,"That's right."],[2314,2477,"Anyone who touches my daughter"],[2477,2598,"won't live to regret it."],[2790,2932,"You harmed our granddaughter,"],[2936,3065,"and now you pay the price."],[3132,3219,"We need to leave now."],[3249,3361,"Joyce needs us."],[3674,3832,"What are you waiting for?"],[3912,4045,"Show them what happens to"],[4045,4254,"bastards who dare defy us."],[4487,4583,"Oh, no."],[4746,4842,"Don't hit me."]],"13":[[8,70,"Okay."],[75,166,"Mr. Baron,"],[175,325,"there's nothing to worry about here."],[400,513,"It's just a surface wound."],[538,717,"However, her overall health"],[759,975,"is a different story."],[1055,1138,"Is she sick?"],[1213,1317,"Whatever it is,"],[1355,1568,"we'll, we'll do anything to help her."],[1589,1722,"Money is not an issue."],[1805,1935,"Joyce is malnourished."],[1993,2114,"She hasn't been eating"],[2122,2239,"or sleeping properly"],[2239,2369,"for far too long now."],[2523,2602,"She needs to be on a"],[2602,2761,"carefully monitored diet plan"],[2761,2848,"to recover."],[2919,2969,"Oh."],[3069,3232,"Poor sweet child."],[3311,3432,"What you've gone through"],[3499,3620,"breaks my heart."],[3653,3812,"Linda, you abandoned me and"],[3812,3962,"abused our child."],[3962,4083,"How could you do this?"],[4083,4237,"Just stay out of my life, Matt."],[4304,4458,"I never wanna see you again."],[4713,4808,"Is this how your mom"],[4808,4909,"took care of you?"],[5013,5142,"In that tiny apartment"],[5142,5321,"with barely enough food to survive?"],[5413,5684,"Mommy loves me very much."],[5743,5955,"Your Mommy let you starve."],[6068,6218,"You still think she loves you?"],[6222,6297,"Mommy didn't,"],[6297,6527,"she tried to take care of me."],[6569,6660,"That's enough, Matt."],[6698,6898,"She's been through so much today."],[6902,6986,"What matters is that"],[6986,7173,"she's safe now with us."],[7469,7599,"Remember this, Joyce."],[7695,7757,"From now on,"],[7757,7891,"you're gonna stay with Daddy."],[7945,8103,"And you no longer have a Mommy."],[8103,8204,"You understand?"],[8612,8846,"Daddy doesn't seem to like Mommy."],[8846,9146,"How can I get him to save her from jail?"]],"14":[[54,116,"From now on,"],[116,258,"you're gonna stay with Daddy."],[316,471,"And you no longer have a Mommy."],[471,563,"You understand?"],[704,809,"That's enough, Matt."],[842,992,"Can't you see you're scaring her?"],[1005,1092,"For heaven's sakes."],[1113,1172,"You have no idea"],[1172,1292,"how to talk to a child."],[1384,1472,"Sweetheart,"],[1572,1626,"come home with"],[1626,1705,"Grandma and Grandpa."],[1718,1780,"Hmm?"],[1847,1993,"We have a giant room"],[1993,2198,"filled with so many toys."],[2210,2306,"Would you like that?"],[2344,2527,"Thank you, Grandma and Grandpa."],[2535,2744,"All this money you spend on me,"],[2773,2998,"I'll pay it back when I grow up."],[3144,3203,"Silly."],[3253,3345,"You're a Baron,"],[3361,3503,"the entire family fortune"],[3503,3641,"belongs to you, little one."],[3682,3858,"Spend as much as you want."],[3999,4141,"Come on, let's go home now."],[4175,4241,"I got it."],[4487,4629,"Careful, now."],[5113,5205,"You okay?"],[6281,6373,"What are you staring at?"],[6552,6627,"Let's go."],[6856,7127,"Says one thing, does another."],[7332,7540,"His tough guy act won't last long."],[7707,7791,"Not a chance."],[8917,9004,"Welcome home - Welcome home"],[9004,9096,"Miss Baron. - Miss Baron."],[9096,9284,"Show her everything we prepared."],[10272,10406,"I didn't know what you'd like,"],[10406,10543,"so I got you,"],[10610,10714,"well, everything."],[10844,10906,"If something's missing,"],[10906,11031,"you just tell Daddy, okay?"],[11036,11198,"Mommy was right."],[11198,11357,"Daddy does love me."],[11361,11636,"Maybe he will help Mommy if I ask him?"]],"15":[[12,83,"What's wrong?"],[83,221,"You don't like any of the gifts?"],[291,396,"I like them."],[425,663,"I promised Mommy I wouldn't talk about"],[663,850,"her in front of Daddy."],[850,1021,"I need to be patient."],[1055,1230,"Luncheon is served."],[1280,1388,"Come, sweetheart."],[1401,1568,"Let's get some food into you."],[1593,1680,"Okay, come on."],[1689,1755,"I got you."],[2139,2248,"I'm hiring the best nanny"],[2248,2410,"and nutritionist for Joyce."],[2448,2606,"They'll take care of all of her needs."],[2702,2769,"That's right,"],[2806,3036,"only the best for my granddaughter,"],[3053,3299,"spare absolutely no expense."],[3336,3415,"Agreed."],[3453,3607,"Our little Joyce deserves"],[3628,3807,"nothing less than perfection."],[3891,3970,"I'll arrange it."],[4054,4116,"Our little princess"],[4116,4254,"will have everything she needs."],[4479,4783,"Apple pie? That's mommy's favorite."],[4813,4846,"Daddy,"],[4846,5105,"can we pack some of the leftovers?"],[5209,5330,"Why would you wanna do that?"],[5355,5467,"Because I want to bring"],[5467,5651,"some apple pie to Mommy."],[5680,5935,"Apple pie is Mommy's favorite."],[6147,6268,"It's your favorite dessert."],[6277,6360,"I made it myself."],[6539,6694,"So save your precious dessert,"],[6727,6877,"it's garbage to me now."],[6911,7057,"Apple pie is still Linda's favorite,"],[7173,7290,"how could I forget?"]],"16":[[4,120,"Because I want to bring"],[120,304,"some apple pie to Mommy."],[604,729,"Pack whatever you like."],[1105,1155,"From now on,"],[1155,1284,"make all decisions about your mom"],[1284,1334,"on your own."],[1334,1434,"I don't need to know."],[1835,1918,"Have lunch without me."],[1918,1997,"I've got some business"],[1997,2077,"to take care of."],[2982,3094,"I should go with him."],[3228,3353,"We can play with your new toys"],[3353,3490,"tomorrow, okay, Joyce?"],[4583,4833,"Apple pie is Mommy's favorite,"],[4854,5034,"she'll be so happy."],[5192,5422,"You're such a good girl, Joyce."],[5484,5651,"Now, the driver will take you"],[5651,5739,"to see your Mommy."],[5739,5784,"Hmm?"],[6664,6831,"That kid really loves her mother."],[6852,6902,"Oh."],[6977,7161,"Every child does."],[7203,7403,"Oh, Matt is so stubborn,"],[7428,7599,"holding on to that hatred for Linda"],[7615,7795,"after all of these years."],[7882,8041,"This is your doing, you know."],[8158,8404,"Forcing him to hide his wealth."],[8462,8546,"If you hadn't,"],[8587,8796,"he and Linda might still be together."],[8796,8946,"Linda left Matt"],[8963,9129,"because she thought he was poor."],[9163,9380,"Her snobbery led them here,"],[9401,9471,"not me."],[9638,9747,"But I will admit,"],[9809,9976,"Linda did raise a good daughter."],[10110,10297,"Her character must not be too bad."],[10406,10598,"Something's off here."],[10735,10927,"What if we've been wrong about Linda"],[10927,11056,"this whole time?"]],"17":[[308,500,"I thought you had business to handle."],[542,688,"And here you are stalking"],[688,779,"your own daughter."],[779,838,"Shut up."],[1030,1159,"You know, you act like"],[1159,1292,"you don't care about Linda,"],[1372,1618,"yet, here you are following Joyce"],[1618,1843,"just to get a glimpse of her mother."],[1856,2006,"One more word and you're walking."],[2356,2435,"Now follow her."],[2548,2648,"As you wish."],[3457,3532,"A prison?"],[3657,3795,"Why would Joyce come here?"],[4633,4788,"Is, is Linda in jail?"]],"18":[[150,279,"Auntie Ana."],[346,492,"Joyce, you got hurt?"],[517,613,"I'm okay,"],[613,817,"but please don't tell mommy,"],[842,946,"she'll worry."],[1051,1272,"Please give this to Mommy."],[1272,1493,"I got it from Daddy's house."],[1564,1726,"So you really found your daddy?"],[1772,1843,"Yes."],[1843,1993,"Please tell Mommy,"],[2010,2210,"Daddy, Grandma and Grandpa"],[2243,2519,"and Uncle Sean are super nice to me."],[2535,2669,"And I'm keeping everything"],[2669,2894,"that Mommy told me to protect safe."],[3032,3207,"Joyce, you are such a good girl."],[3253,3349,"I know your Mommy is"],[3349,3478,"super proud of you."],[3478,3712,"Please tell Mommy to wait for me."],[3741,3941,"I'll get Daddy to help her."],[4204,4266,"Joyce?"],[4362,4404,"Daddy."]],"19":[[112,162,"Joyce?"],[596,734,"You must be Joyce's father."],[975,1222,"Mommy told me not to tell Daddy"],[1222,1351,"she's in jail yet."],[1388,1639,"Auntie Ana is Mommy's friend."],[1639,1801,"She always looks after me."],[1801,1989,"The apple pie is for her."],[2093,2177,"Mm-hmm."],[2218,2310,"Joyce is right."],[2414,2494,"That's strange because"],[2494,2577,"I didn't know"],[2631,2823,"Linda had friends working in a prison."],[2986,3111,"There's a lot about Linda's life"],[3111,3186,"you don't know."],[3365,3440,"Come on."],[3678,3845,"You tell Linda it's irresponsible"],[3845,4016,"to have others looking after her kid."],[4045,4162,"And if she wants to see Joyce"],[4162,4208,"from now on,"],[4208,4320,"she's gonna have to come to me."],[4625,4704,"You're only saying that"],[4704,4783,"so you have the chance"],[4783,4875,"to see Joyce's mother."],[4892,5096,"Zip it, Sean, I'm serious."],[5851,5897,"Daddy,"],[5955,6081,"If mommy was in trouble,"],[6081,6214,"would you help her?"],[6297,6410,"Look, if Mommy is in trouble,"],[6410,6523,"that's her problem now."],[6569,6639,"Not mine."],[6723,6898,"Do you still love Mommy?"],[7111,7223,"Joyce, I've told you-"],[7223,7386,"Not to talk about Mommy"],[7386,7486,"in front of you."],[7486,7574,"I know."],[7590,7695,"Then why ask?"],[7720,7853,"Because all the other kids"],[7853,8070,"live with their Mommy and Daddy."],[8087,8237,"I want that too."],[8883,8992,"Your mom is the only woman"],[8992,9104,"I've ever loved."],[9200,9421,"It was her who stopped loving me."]],"20":[[462,579,"Apple pie,"],[633,713,"my favorite."],[1368,1501,"Save your precious dessert,"],[1609,1747,"it's garbage to me now."],[1772,1889,"Linda, this isn't you."],[1985,2139,"Just stay out of my life, Matt."],[2202,2356,"I never wanna see you again."],[2836,2986,"I hate you, Linda!"],[3007,3140,"I never wanna see you again,"],[3157,3311,"and I will never forgive you!"],[3395,3465,"Never!"],[3582,3866,"I broke your heart to protect you Matt."],[3866,4058,"You were the only thing I cared about."],[4187,4270,"Matt, you must..."],[4346,4487,"you must really hate me."],[4729,4817,"I'm sorry."],[7115,7282,"If you hadn't betrayed me, Linda,"],[7457,7586,"our daughter would be growing up"],[7586,7770,"in a loving home with you and me."],[7903,8003,"I'm gonna give our daughter"],[8003,8174,"all the love that she deserves."],[8283,8508,"But I will never forgive you, Linda."]],"21":[[54,133,"Joyce!"],[183,271,"Come see Grandma."],[404,709,"Look what Grandma got you."],[742,921,"Mommy always said you won't know"],[921,992,"unless you try."],[992,1151,"Maybe today I can talk to Daddy"],[1151,1217,"about her."],[1217,1451,"Can I take this to Daddy?"],[1497,1655,"Of course you can, sweetheart."],[1747,1893,"You're such a little angel."],[1981,2027,"Bye."],[2769,2848,"Daddy."],[3028,3123,"Come here, princess."],[3224,3415,"Grandma gave me this cake,"],[3415,3549,"but I didn't eat any."],[3549,3732,"I saved it all for you."],[3953,4049,"You came all this way"],[4049,4162,"just to bring me a cake?"],[4204,4245,"Yes."],[4245,4366,"Daddy works so hard."],[4366,4546,"I'll give you a massage too."],[4679,4796,"What did you do?"],[4867,4963,"Are you in trouble?"],[5009,5217,"Daddy, are you in good mood today?"],[5351,5413,"I am."],[5492,5543,"Why?"],[5593,5718,"Can I tell you something"],[5718,5839,"about Mommy?"],[5905,5968,"Can I?"]],"22":[[8,112,"Can I tell you something"],[112,237,"about Mommy?"],[304,362,"Can I?"],[679,825,"Did your mom put you up to this?"],[909,1030,"What does she want now?"],[1063,1280,"My Mommy loves me very much,"],[1280,1472,"she wouldn't make me do anything."],[1497,1710,"And she doesn't want anything."],[1722,1835,"What did she make you do"],[1835,1947,"to defend her like this?"],[2068,2231,"She treated you terribly, Joyce."],[2231,2406,"She doesn't deserve to be your mom."],[2531,2748,"Don't talk about my Mommy like that."],[2748,2977,"Or else I won't call you Daddy anymore."],[3215,3311,"What did you just say?"],[3357,3666,"I said I won't call you Daddy anymore."],[3807,3908,"What's going on here?"],[4325,4366,"Hey."],[4408,4579,"Don't cry princess."],[4625,4721,"If Grandma and Grandpa"],[4721,4813,"see you like this,"],[4817,4975,"they'll tear your dad apart."],[5030,5167,"He's a bad Daddy."],[5171,5334,"He's mean to Mommy"],[5355,5584,"just like all those bad people."],[5584,5722,"I don't want him."],[5747,5901,"I want my Mommy."],[5910,6018,"Okay, you want your Mommy?"],[6035,6068,"Fine."],[6068,6135,"Tell me where she is"],[6135,6277,"and I'll take you to her right now."],[6281,6443,"My Mommy is in jail."],[6514,6560,"What?"],[6623,6690,"Jail?"]],"23":[[100,233,"My Mommy is in jail."],[233,454,"But she didn't do anything wrong."],[483,663,"So why did your mom leave your dad?"],[696,842,"Did she find someone else?"],[880,1046,"I was born in prison."],[1076,1305,"My Mommy and the other ladies,"],[1313,1426,"they raised me."],[1438,1580,"Your mom was in prison"],[1622,1751,"before you were born?"],[1868,2035,"I don't know what happened."],[2035,2268,"But Mommy had a really hard life."],[3140,3194,"What do you..."],[3757,3845,"Stop!"],[3870,3958,"Wait!"],[4437,4558,"Bill said we only had to get married,"],[4558,4621,"nothing else."],[4775,4879,"You think I wanna marry"],[4879,4971,"someone like you?"],[5630,5743,"What are you doing with that?"],[7248,7344,"You killed him."],[7699,7799,"Murderer!"],[7916,8145,"No, no, no, wait, wait."]],"24":[[600,688,"After being framed"],[688,771,"and thrown in prison,"],[771,880,"I discovered the truth."],[1121,1213,"Toby Lawson"],[1213,1443,"had massive gambling debts."],[1826,1926,"My uncle promised to"],[1926,2072,"clear those debts,"],[2260,2385,"but only if Toby found a way"],[2385,2506,"to send me to prison."],[3691,3878,"Then Joyce came into my life."],[4162,4300,"She brought me hope,"],[4300,4466,"and she was the only light in this"],[4466,4596,"dark world."],[4750,4892,"I was granted house arrest"],[4892,5055,"to raise my child."],[5280,5513,"All I cared about was keeping her safe."],[5876,6039,"Bill couldn't find the key to the safe"],[6039,6197,"containing the core technology."],[6218,6389,"Without it, the shareholders never"],[6389,6481,"fully trusted him."],[6489,6544,"Dad."],[6577,6698,"Dad, is this the key?"]],"25":[[12,137,"Ugh! That's not it."],[250,400,"We need to find that damn key."],[408,475,"I know!"],[538,734,"As long as they never find that key,"],[838,980,"Joyce and I have a chance."],[1259,1397,"Now that the house arrest ends,"],[1397,1576,"Joyce must find her dad."],[1993,2181,"Mommy, don't go."],[2310,2427,"Mommy loves you, okay?"],[2531,2640,"She'll live on,"],[2719,2940,"with dignity, with her head held high."],[3236,3340,"My only wish,"],[3374,3649,"that her dad give her the life I never could."]],"26":[[83,275,"Mommy isn't a bad guy."],[275,475,"She just wanted me to find you"],[496,633,"to keep me safe."],[663,880,"Don't blame her, please."],[1038,1142,"Take Joyce home."],[1180,1309,"I'm gonna get to the bottom of this."],[1397,1472,"Let's go, Joyce."],[1497,1710,"Daddy, will you help Mommy?"],[1830,1968,"I believe in one thing."],[2052,2139,"That my daughter's mom"],[2139,2268,"is not a criminal."],[3470,3620,"I pulled every file I could find."],[3916,4004,"Linda was charged"],[4004,4104,"with attempted murder"],[4104,4216,"against Toby Lawson,"],[4258,4450,"the eldest son of the Lawson family."],[4517,4637,"I'm with Toby now."],[4667,4850,"He's the heir to the Lawson family."],[4979,5155,"The man she left me for?"],[5221,5317,"Her cousin and uncle"],[5317,5430,"testified against her."],[5455,5572,"Bill and Cindy Abell"],[5597,5689,"said she demanded"],[5689,5822,"ten million from Toby,"],[5834,6047,"he refused and she stabbed him."],[6089,6235,"Something doesn't add up."],[6297,6485,"Ten million is nothing to the Abells."],[6502,6652,"The other strange thing is,"],[6715,6810,"Linda never appealed."],[6844,6994,"So she wanted to go to jail."],[7077,7173,"Was the outside world"],[7173,7244,"more dangerous?"],[7244,7369,"Or was she hiding from someone?"]],"27":[[8,129,"You think that the person"],[129,258,"she was hiding from was me?"],[325,387,"So that I wouldn't"],[387,496,"find out about Joyce?"],[579,654,"It's possible."],[709,763,"Think about it."],[788,871,"She leaves you"],[884,984,"because she thinks you're poor."],[996,1084,"And then she's charged"],[1084,1172,"with attempted murder."],[1192,1280,"Who was the last person"],[1280,1376,"she'd want to see?"],[1393,1614,"Her ex, who she betrayed."],[1785,1918,"What I find interesting,"],[1968,2168,"Toby was deep in gambling debt."],[2189,2323,"And his injury was minor,"],[2369,2590,"yet it was rated severe enough"],[2590,2786,"to get Linda a ten-year sentence."],[2869,2973,"This reeks of a setup."],[3098,3249,"A pregnant girl never stood a chance"],[3249,3440,"against those scheming monsters."],[3503,3574,"Poor Linda."],[3816,3962,"Contact the Baron legal team."],[3991,4120,"We're reopening the case."],[4950,4979,"Dad,"],[5105,5213,"we've got a problem."],[5292,5426,"Linda's getting out of prison."],[5459,5509,"What?"]],"28":[[37,162,"Linda's getting out of prison."],[196,241,"What?"],[287,362,"The injury report"],[362,487,"was exposed as fraudulent."],[513,646,"Toby's being interrogated now"],[646,900,"and Linda's release is being processed."],[917,980,"You tell that boy to"],[980,1096,"keep his mouth shut!"],[1305,1405,"If he betrays us,"],[1480,1630,"he'll regret surviving that knife."],[1710,1839,"There's someone looking out for her."],[1851,1997,"Like someone of influence."],[2114,2177,"Exactly."],[2264,2314,"Alone."],[2360,2510,"She'd still be rotting in that prison."],[2560,2819,"She's found someone with power"],[2844,2982,"that's pulling strings for her."],[3044,3182,"Oh, I knew I should have buried"],[3182,3311,"that bitch years ago!"],[3336,3415,"We still haven't found"],[3415,3507,"the safe key yet."],[3511,3632,"So if Linda gets out now,"],[3632,3803,"the shareholders can turn against us."],[3812,3978,"We're running out of time, Cindy."],[3995,4237,"Either Linda hands over that key"],[4258,4491,"or we pry it from her cold, dead hands."]],"29":[[1710,1818,"Joyce, Mommy could finally"],[1818,1918,"watch you grow up."],[3611,3670,"Matt?"],[3720,3824,"Look how far have you fallen"],[3824,3941,"since leaving me."],[3958,4145,"After all these years,"],[4175,4287,"he still hates me."],[4863,4929,"I know you're the one"],[4929,5021,"that found the evidence"],[5021,5155,"that released me from prison."],[5246,5317,"Thank you."],[5376,5501,"I just didn't want my daughter's"],[5501,5643,"mother labelled a murderer."],[5755,5872,"Don't think I did it for you."],[5901,5964,"No."],[6056,6147,"Not at all."],[6189,6356,"Still, you helped me"],[6356,6481,"when no one else did."],[6544,6652,"I'll find a way to repay you."],[6690,6810,"There's no need to wait."],[6856,6973,"You can repay me right now."],[7978,8103,"You want me to sign over"],[8103,8249,"full custody of Joyce?"]],"30":[[0,216,"You hid my daughter from me, Linda."],[250,358,"You're a convicted felon"],[358,462,"who's lost everything."],[462,746,"The Abell name, your reputation,"],[746,846,"your fortune, all of it."],[896,955,"You really think"],[955,1084,"you're fit to raise a child?"],[1113,1192,"He's right."],[1259,1409,"I have nothing left."],[1543,1722,"Bill won't stop hunting me"],[1743,1901,"and I won't stop fighting him,"],[1906,1976,"Joyce"],[2068,2135,"would be in a"],[2135,2360,"constant state of danger with me."],[2423,2706,"Matt can give her safety, stability."],[2915,3123,"What do I have to deny her that?"],[3161,3240,"What are you thinking"],[3240,3332,"so hard about?"],[3374,3470,"Look, if you don't wanna sign it,"],[3470,3507,"that's fine."],[3507,3632,"As long as you and I agree-"],[3636,3699,"I'll sign it."],[5063,5184,"Just like that?"],[5226,5280,"You're not afraid"],[5280,5355,"you'll never gonna see"],[5355,5459,"your daughter again?"],[5488,5622,"I know you'll never hurt Joyce."],[5668,5751,"And she's not gonna"],[5751,5885,"forget who her mother is."],[5914,6047,"And despite everything,"],[6101,6268,"there's still some trust between us."],[6473,6556,"Trust?"]],"31":[[196,266,"Trust?"],[316,412,"Like how I trusted you"],[412,517,"would never leave me?"],[521,583,"Let me go."],[809,1026,"I kept you here, Linda."],[1042,1280,"Right here, in my heart."],[1305,1488,"Before you kissed another man,"],[1522,1622,"before you got into"],[1622,1760,"another man's car."],[2127,2214,"I trusted that"],[2214,2344,"you would never leave me."],[2406,2519,"But trust doesn't mean anything"],[2519,2640,"to you, does it, Linda?"],[2727,2798,"I'm sorry."],[3011,3161,"I never wanted to leave you."],[3199,3282,"I thought that you would,"],[3282,3520,"you would just move on and forget me."],[3578,3699,"I just wanted to keep you safe."],[4245,4387,"You're not allowed to see Joyce"],[4387,4500,"without my permission."],[4742,4825,"Now leave."]],"32":[[145,279,"Matt, I know you hate me,"],[316,483,"and you have every right to."],[542,646,"But please,"],[729,892,"take care of our little girl."],[946,1021,"Mommy."],[1263,1434,"Why do you look sad?"],[1822,1901,"Hi sweetie,"],[1901,1981,"do you still have the key"],[1981,2068,"Mommy gave you?"],[2135,2185,"Yes."],[2635,2702,"Joyce,"],[2756,2848,"you'll have to listen to"],[2848,2965,"everything Daddy says, okay?"],[3061,3165,"Whatever happens to Mommy"],[3165,3261,"is not your concern."],[3332,3465,"Mommy, don't go."],[3478,3628,"Please stay."],[3999,4283,"I'll ask Daddy to let you stay."],[5976,6101,"Mommy, please."],[6106,6235,"Don't go."],[6468,6594,"Your loyalty to this company"],[6594,6698,"for the past two years"],[6698,6815,"hasn't gone unnoticed."],[6919,7123,"So in memory of my father,"],[7140,7228,"I thank you both."],[7369,7424,"Thank you."],[7811,7899,"Going behind my back"],[7899,7974,"with the shareholders"],[7974,8049,"now, Linda?"],[8066,8224,"My, my, Linda."],[8249,8366,"Traded the orange jumpsuit"],[8366,8512,"for designer clothes."],[8525,8671,"Prison whore to corporate whore."],[8717,8863,"At least you're consistent."]],"33":[[0,125,"What are you doing here?"],[179,262,"Just wanted to see"],[262,462,"your latest manipulation tactics."],[483,617,"So you've already got these two"],[617,709,"board members wrapped"],[709,829,"around your little finger."],[925,1055,"That's ridiculous."],[1096,1213,"This is a legitimate"],[1213,1330,"business discussion."],[1343,1413,"Oh, I'm sure"],[1413,1576,"you two are honest gentlemen."],[1685,1764,"It's my cousin Linda"],[1764,1885,"I'm so concerned about."],[1901,2056,"What exactly are you implying?"],[2093,2223,"Is there something we should know?"],[2285,2385,"Isn't it convenient?"],[2427,2531,"Six years in prison,"],[2531,2706,"then all of a sudden, she's free."],[2719,2806,"Someone powerful"],[2806,2957,"must have pulled some strings."],[3007,3086,"What did you offer"],[3086,3203,"in exchange like that?"],[3349,3511,"Same thing you always traded?"],[4079,4250,"You psycho."],[4279,4408,"You keep your filthy accusations"],[4408,4475,"to yourself."],[4533,4675,"Have you lost your mind?"],[4775,4850,"Daddy."],[4975,5046,"Gentlemen,"],[5075,5192,"putting a convicted criminal"],[5192,5342,"in charge of this company"],[5355,5505,"would destroy its reputation."],[5576,5801,"Not to mention her character."],[5830,5972,"I was wrongfully convicted,"],[5993,6118,"and I cleared my name"],[6118,6310,"on my own with evidence."],[6343,6427,"If you think I truly"],[6427,6527,"had those kind of connections,"],[6527,6614,"do you think I would let you two"],[6614,6681,"still be walking?"],[6936,7023,"Are you threatening us?"],[7057,7127,"Enough."],[7323,7561,"I trusted old Mr. Abell's judgment."],[7590,7882,"He gave the safe key to his daughter."],[7891,8166,"Making her the rightful CEO"],[8179,8274,"of the Abell Group."],[8287,8633,"However, we do have one proposal."]],"34":[[25,91,"The Abell Group"],[91,266,"has lost many partners recently."],[342,554,"Whoever brings in more investment"],[596,746,"gets our support."],[767,846,"Both of us"],[892,1213,"will chip in 5% of our shares."],[1242,1472,"We hope the new CEO"],[1472,1739,"will lead us back to our peak."],[1864,1935,"Alright."],[1985,2127,"We'll make this a competition then."],[2164,2452,"My shares plus 10%"],[2464,2590,"would be more than what you have,"],[2590,2652,"Linda."],[2702,2781,"That makes me"],[2806,2915,"the largest shareholder"],[2936,3078,"and in charge of the Abell Group."],[3123,3249,"Do you know what that means?"],[3307,3611,"That means you can't win against me."],[3649,3845,"The key doesn't matter anyway."],[3853,3920,"I doubt"],[3920,4158,"anyone would invest in a murderer."],[4233,4320,"Come on, Dad."],[4379,4450,"Let's go."],[5422,5513,"Mr. Raven."],[5647,5714,"Mr. Raven-"],[5855,5918,"When you messed up"],[5918,5989,"all those years ago"],[5989,6101,"and almost got fired,"],[6126,6272,"my father stood by your side."],[6318,6410,"Now, I'm asking you"],[6410,6523,"to do the same for me."],[6552,6681,"Help me protect what he built."]],"35":[[312,487,"Your father's gone, Linda."],[521,692,"Stop clinging to the past."],[704,846,"Mr. Raven doesn't care"],[846,1051,"what favors your father did him."],[1484,1760,"I told you I don't work with ex-cons."],[1780,1856,"I don't care"],[1856,2047,"if you are Mr. Abell's daughter."],[2047,2235,"Mr. Davidson, I was wrongly accused."],[2243,2339,"My name has been cleared."],[2339,2481,"If you would just look at the project,"],[2481,2544,"you would see-"],[3132,3194,"Dad,"],[3349,3536,"I'm so sorry I failed you."]],"36":[[58,183,"I couldn't protect the company,"],[183,275,"or Joyce."],[596,775,"God am I really that useless?"],[1272,1338,"No."],[1522,1626,"No, I can't give up."],[1814,1968,"Joyce is depending on me."],[2018,2160,"How can I face her if..."],[2198,2318,"if I give up now?"],[2414,2481,"Did you hear?"],[2515,2581,"The Baron Group"],[2581,2765,"is worth over a trillion now."],[2811,2865,"It's become"],[2865,3061,"one of the world's top 10 companies."],[3065,3261,"Yeah, all because of Matt Baron's"],[3261,3449,"brilliant strategies and charisma."],[3478,3586,"Meeting him just once"],[3586,3762,"would be a dream come true."],[3770,3858,"Matt Baron?"],[4091,4212,"No, that can't be right."],[4300,4387,"If he really is Mr. Baron,"],[4387,4500,"then why would he have needed"],[4500,4654,"part-time jobs back in college?"],[4654,4758,"Why would I have fallen"],[4758,4854,"for Bill's tricks and"],[4854,4984,"sacrificed everything to"],[5034,5180,"protect Matt when he didn't need it?"]],"37":[[4,233,"Mr. Baron's company is valued at over"],[233,396,"a trillion dollars."],[421,504,"If I could get him"],[504,600,"to invest in the Abell Group,"],[600,650,"that would be"],[650,767,"a complete game-changer."],[996,1059,"I will."],[1134,1205,"Okay, bye."],[1305,1447,"That was Linda"],[1463,1685,"asking about Mr. Baron's schedule."],[1722,1872,"I think she wants him to invest."],[1926,2027,"She's finally coming to me"],[2027,2118,"for help, huh?"],[2181,2323,"Well, she was reaching out"],[2323,2577,"to Mr. Baron, not Matt specifically."],[2635,2890,"You tell her that this Mr. Baron"],[2890,2994,"would like to meet her"],[2994,3111,"at the Obsidian Night Club"],[3111,3328,"tonight at 8 pm."],[3349,3432,"You're gonna help her?"],[3449,3561,"Where's the fun in that?"],[3599,3699,"I'm gonna sit back and"],[3699,3858,"enjoy every second she waits around"],[3858,3999,"like a sad puppy, for this"],[4041,4212,"Mr. Baron to show up."],[4742,4846,"It doesn't make any sense."],[5167,5238,"It's past 8."],[5255,5372,"Linda must be at the club already."],[5372,5472,"Don't you wanna head out?"],[5509,5630,"I don't need to rush."],[5659,5780,"Let her wait a bit longer."],[5839,5993,"But you miss her like crazy."],[6060,6177,"Why are you so tough?"],[6569,6631,"Yeah?"],[6927,6986,"What?"]],"38":[[333,421,"Mommy."],[592,684,"Miss Baron, come back."],[696,788,"Mommy."],[934,1042,"Miss Baron, come back."],[1609,1747,"Little Miss Baron is missing."],[1776,1830,"What?"],[1951,2085,"Get everyone searching for Joyce,"],[2093,2143,"immediately."],[2143,2339,"If anything happens to her, it's on you."],[2348,2414,"Yes, sir."],[2573,2627,"Let's go."],[2773,2852,"Room A10."],[2927,3182,"Seems like Mr. Baron has expensive tastes."],[3236,3299,"Hello."],[3465,3607,"Are you here to meet with Mr. Baron?"],[3678,3908,"Yes, that's correct."],[3908,4070,"Has Mr. Baron arrived yet?"],[4099,4279,"Ah, my apologies."],[4291,4391,"It seems that Mr. Baron"],[4391,4537,"is actually in room 102."],[4596,4679,"102?"],[4804,4917,"Room 102?"],[4992,5071,"No, I could of sworn it"],[5071,5130,"was supposed to be"],[5130,5234,"room 105."],[5363,5563,"Please follow me, I'll show you the way."],[5613,5680,"Lead the way."],[6477,6577,"Hi, Linda."],[6623,6723,"Looking for someone?"]],"39":[[54,120,"Cindy?"],[638,725,"You know,"],[742,921,"I heard from one of my informants"],[921,992,"that you were planning to"],[992,1117,"meet with Mr. Baron tonight."],[1226,1363,"I hate to break it to you,"],[1388,1514,"that's not gonna happen."],[1584,1739,"Oh, how rude of me."],[1768,1885,"This is Mr. Johnson"],[1885,2022,"from the Johnson Group."],[2047,2189,"He's been ignoring your calls."],[2206,2268,"My father wanted me"],[2268,2394,"to pass along a message,"],[2423,2598,"old Mr. Abell was a friend."],[2648,2702,"But you?"],[2777,2877,"You mean nothing."],[2898,3086,"The group won't invest a penny"],[3115,3269,"if it's run by a murderer."],[3319,3407,"Give it up, Linda."],[3432,3507,"The Abell Group"],[3507,3682,"belongs to me and my dad now."],[3707,3870,"Don't get ahead of yourself, Cindy."],[3908,4070,"I'm not gonna quit that easy."],[4333,4391,"The Johnson Group"],[4391,4550,"has already invested 100 million"],[4550,4688,"into Bill's venture."],[4700,4825,"What do you have?"],[4854,4904,"Nothing."],[5013,5109,"You've lost."],[5138,5246,"What are you talking about?"],[5417,5605,"You see, in this city,"],[5634,5755,"only the Baron Group and I"],[5755,5814,"have the power to"],[5814,5960,"invest that kind of capital."],[6010,6243,"So if you want my investment,"],[6264,6339,"you can either"],[6339,6548,"get on your knees and beg,"],[6581,6631,"or..."],[6861,7011,"can have a couple drinks with me."],[7061,7278,"Then maybe, I'll consider it."]],"40":[[241,337,"Mr. Johnson."],[408,671,"Your father gave his word to my dad."],[688,938,"The Johnson Group likes to invest"],[938,1163,"where we see sincerity."],[1205,1330,"The choice is yours, Linda."],[1568,1634,"Fine."],[1805,1918,"There we go."],[2102,2147,"Wait."],[2239,2352,"Mr. Johnson,"],[2352,2477,"I've got something more"],[2573,2744,"entertaining for you."],[2811,2861,"Hold her."],[2923,2969,"No."],[2994,3061,"Let me go."],[3624,3741,"What did you just put in there?"],[3824,3953,"Something that will make the men"],[3953,4166,"in this room very happy."],[4212,4258,"Let me go."],[4258,4371,"Now, let me go!"],[4425,4550,"After they're done with you,"],[4600,4738,"the perfect little daughter"],[4738,4833,"of Mr. Abell"],[4833,4992,"will be all over the internet"],[4992,5121,"for everyone to see."],[5484,5580,"I'll be the first one to"],[5580,5684,"make her famous."]],"41":[[20,95,"You're despicable."],[95,179,"All of you!"],[225,312,"Fight all you want."],[321,421,"The drug works better"],[421,558,"when your heart rate's up."],[855,1001,"You crazy bitch."],[1121,1217,"Mommy."],[1426,1539,"Joyce, what are you doing here?"],[1576,1739,"Stay away from my mommy."],[1910,2039,"Didn't you say your father's"],[2039,2160,"been wanting to get his hands"],[2160,2352,"on the Abell Groups core technology?"],[2402,2502,"Well, guess what?"],[2548,2648,"It's locked in a safe,"],[2648,2798,"and this little brat"],[2802,2907,"is holding the key."],[2973,3061,"She doesn't have it,"],[3061,3119,"I do."],[3265,3445,"There's only one way to find that out,"],[3445,3507,"isn't there?"]],"42":[[0,171,"Nobody leaves this room"],[171,375,"until I have that key."],[417,625,"Get me that key."],[667,804,"Get your hands off me."],[829,967,"Don't hurt my mommy!"],[1301,1393,"Joyce, no."],[1639,1830,"Get me the key,"],[1868,1951,"and maybe we can still have"],[1951,2039,"a little fun tonight."],[2052,2156,"Let go of me."],[2464,2706,"Ah, you stupid little bitch!"],[2823,2886,"Mr. Johnson."],[2886,2982,"Are you okay?"],[3003,3169,"I'm so sorry baby, I'm so sorry,"],[3169,3290,"Mommy couldn't protect you."],[3545,3716,"I'll end this right now."]],"43":[[145,246,"Get away from them!"],[513,550,"Daddy."],[550,679,"Help Mommy."],[713,842,"I'm taking her to the hospital"],[1237,1363,"Come on, come on, I got you."],[1651,1776,"Please forgive me."],[1776,1939,"I, I was just trying to"],[1939,2043,"teach them a lesson-"],[2185,2289,"Who gave you permission"],[2289,2398,"to teach anyone anything?"],[2464,2506,"Hey."],[2548,2644,"You're the one who got Linda"],[2644,2752,"out of prison, aren't you?"],[2806,2944,"Who the hell do you think you are"],[2944,3103,"laying hands on Mr. Johnson?"],[3123,3249,"What are you idiots waiting for?"],[3249,3403,"He just assaulted Mr. Johnson."],[3428,3474,"Go!"],[3482,3536,"Take him."],[3807,3853,"That,"],[3945,4104,"is Matt Baron,"],[4154,4346,"the CEO of Baron Group,"],[4346,4525,"you dumb bitch."]],"44":[[16,275,"Matt is the CEO of Baron Group?"],[325,554,"No, please, please don't hurt me."],[554,746,"It was, it was that woman's fault,"],[754,846,"wasn't mine."],[959,1076,"Sir no no, no."],[1409,1543,"No, please don't hurt me."],[1559,1651,"Please, please!"],[1668,1730,"Forgive me."],[1805,1860,"Do it."],[1918,2022,"No no no. - Let me."],[2552,2736,"Miss, Miss Abell, please."],[2765,2819,"Please."],[2869,2911,"Miss,"],[2940,3044,"Misses Abell, I messed up."],[3082,3128,"Please."],[3211,3311,"Please don't hurt me."],[3399,3507,"Anyone who comes after"],[3507,3628,"my father's work..."],[3720,3770,"Ah."],[4008,4208,"Pays the price dearly for it."]],"45":[[41,254,"Pays the price dearly for it."],[938,1013,"And you."],[1180,1272,"When you and Bill set me up,"],[1272,1401,"did you think about this moment?"],[1476,1543,"Did you think about"],[1543,1664,"how I would crawl out"],[1664,1805,"from the grave that you put me in"],[1897,2043,"and then I would come back"],[2068,2210,"and then I would take what's mine?"],[2243,2364,"I'm sorry, I'm sorry."],[2398,2510,"I was wrong."],[2652,2840,"It's too late now for apologies."],[3257,3353,"Get everyone out."],[3399,3499,"Make sure no one catches"],[3499,3616,"wind of what happened here today."],[4208,4258,"You alright?"],[4562,4679,"You're a liar, Matt."]],"46":[[8,83,"You lied to me"],[150,246,"after all these years"],[246,321,"that we were together."],[458,604,"Did you know what that means?"],[738,804,"That means"],[821,984,"that no one could touch you"],[1142,1251,"or hurt you."],[1388,1493,"That you were,"],[1576,1780,"you were never in any danger."],[1789,1876,"Why did you want me"],[1876,1997,"to be in danger, Linda?"],[2047,2093,"God."],[2256,2302,"Why?"],[2523,2627,"Why didn't you say anything?"],[2627,2736,"Why, why didn't you just,"],[2756,2919,"just tell me who you really were?"],[2923,3057,"What has gotten into you?"],[3411,3499,"You were the only person"],[3499,3611,"I ever truly loved."],[3678,3933,"And I broke up with you to save you."],[4254,4366,"To protect you."],[4675,4808,"And it cost me"],[4892,4963,"Everything."],[5092,5176,"My life,"],[5267,5513,"my freedom, my daughter."]],"47":[[175,250,"I hate you."],[1351,1488,"What just happened?"],[1634,1722,"Where's Joyce?"],[1785,1839,"She's fine,"],[1839,1972,"she'll be discharged soon."],[1972,2081,"The doctor said she only got"],[2102,2198,"one scratch."],[2260,2348,"What's wrong with you?"],[2690,2840,"She said that she loved me,"],[2890,2969,"and that the only reason that"],[2969,3069,"she broke up with me"],[3069,3203,"was to save my life,"],[3269,3374,"to protect me."],[3482,3549,"I'll have some people"],[3549,3620,"look into her story."],[3828,3937,"I need to know the truth."],[4079,4137,"All of it."]],"48":[[41,108,"Dad,"],[216,308,"the shareholders' meeting"],[308,392,"is tomorrow."],[692,884,"Oh, I hope you're watching over me."],[980,1138,"She's been to 12 companies today,"],[1151,1272,"all of them turned her away."],[1334,1430,"Really not gonna help her?"],[1551,1730,"She said she hated me, Sean."],[1810,1951,"I doubt she'd accept my help."],[2018,2147,"And how have you still not found out"],[2147,2248,"what she was protecting me"],[2248,2352,"from all those years ago?"],[2394,2489,"Records from that time"],[2489,2565,"are hard to find."],[2656,2773,"We need to investigate deeper."],[2815,2948,"Okay, well, do everything you can"],[2948,3065,"because I need to know the truth,"],[3136,3203,"fast."],[3603,3703,"Excuse me, Miss?"],[3703,3887,"I really like your hairpin."],[3887,4116,"Do you mind if I trade you my scarf?"],[4225,4325,"If you really want,"],[4325,4404,"you can have it."],[4433,4537,"No, my mom says"],[4537,4700,"I shouldn't take things for free."],[4746,4896,"Well, in that case."],[5234,5296,"Thank you."],[5309,5376,"Thank you."],[6423,6535,"Here you go, mister."],[6865,6940,"Thanks."]],"49":[[2373,2448,"Selling your body"],[2448,2615,"to save your father's company, Linda?"],[3028,3207,"I wonder what your precious lover"],[3207,3332,"would think of this."]],"50":[[91,208,"I would have preferred for us"],[208,329,"to meet in my office,"],[350,550,"but I have a flight in two hours,"],[563,646,"and my hotel room"],[646,746,"was more convenient."],[754,925,"Bob, the Abell Group is falling apart."],[1167,1317,"And I know you're retired, but"],[1463,1547,"I know that you were"],[1547,1685,"my father's most trusted advisor,"],[1685,1780,"and the only person left"],[1780,1897,"that I could ask for help."],[2018,2139,"When your father died"],[2143,2285,"and they locked you away,"],[2339,2452,"I abandoned you,"],[2502,2585,"and that's been"],[2590,2786,"eating me alive forever."],[3174,3294,"Everything Bill has"],[3294,3520,"done in the Abell Group is in here."],[3607,3862,"Evidence to bury him once and for all."],[4187,4320,"This is my only chance"],[4320,4429,"to do what's right."],[5714,5818,"Linda,"],[5880,5968,"how could you?"]],"51":[[346,387,"Matt?"],[462,546,"What are you doing here?"],[1151,1280,"Why are you in a hotel room"],[1280,1372,"with an old man, Linda?"],[1372,1468,"You think I'd find out"],[1468,1543,"about this shit?"],[1551,1634,"That is not your concern."],[1634,1739,"We're not together anymore."],[1797,1856,"Oh yeah?"],[1989,2114,"That's not for you to decide."],[3178,3269,"What the hell is wrong with"],[3269,3332,"you, Matt?"],[3395,3524,"Well, you'll sneak around"],[3524,3661,"with other men, but not me?"],[3687,3803,"What are you worried I won't give you"],[3803,3878,"the money you want?"],[3883,4033,"Oh yes, exactly."],[4087,4262,"Because all I want is money."],[4300,4350,"Happy?"],[4391,4462,"How much you want?"],[4479,4596,"A billion dollars."]],"52":[[12,87,"How much you want?"],[108,225,"A billion dollars."],[387,479,"You're not worth it."],[575,734,"Then please, just leave me alone."],[900,1013,"Where do you think you're going?"],[1038,1121,"I'm gonna go find someone"],[1121,1276,"who will give me a billion dollars."],[1451,1547,"I dare you"],[1576,1730,"to walk out of that door, Linda."],[1822,1981,"I'm the only one that can help you."],[2006,2164,"So why not just ask me directly?"],[2610,2756,"Because I don't want to see you anymore."],[2823,2948,"Because we can't just go back"],[2948,3040,"to the way that things were."],[3040,3111,"So why don't we just"],[3190,3357,"end things and move on with our lives?"],[3807,3945,"Well, this isn't over, Linda."],[3966,4166,"I'll die before I let this go!"]],"53":[[12,120,"Matt, listen."],[187,258,"Today's the showdown"],[258,367,"between Bill and Linda."],[371,546,"She didn't get any investors."],[709,817,"You're really not gonna help her?"],[855,900,"Help?"],[1017,1076,"That's what I said."],[1251,1434,"I already invested 500 million"],[1434,1564,"into Bill's venture."],[1768,1881,"You're backing Bill?"],[1964,2047,"Against Linda?"],[2056,2168,"She made it pretty clear that"],[2168,2327,"she wants nothing to do with me."],[2406,2469,"Okay?"],[2540,2665,"I mean, I'm gonna sit back"],[2736,2836,"and relax"],[2848,2961,"and make her eat her words"],[2961,3098,"while everything around her"],[3098,3211,"is falling apart."],[3332,3520,"Have you lost your mind?"],[3545,3732,"After everything he did to Joyce."],[3962,4187,"Look, she betrayed me, Sean."],[4275,4458,"If she had just asked me for help,"],[4458,4562,"I would have given it to her."],[4562,4650,"But instead, she went into"],[4650,4738,"a hotel room"],[4758,4846,"with another man."],[4938,5013,"Yeah, I,"],[5021,5117,"I checked in on that."],[5217,5334,"That old man"],[5359,5563,"is her dad's financial advisor."]],"54":[[0,120,"That old man"],[141,321,"is her dad's financial advisor."],[337,450,"They were in the room for"],[496,688,"five minutes, tops."],[834,980,"And who sent you that video?"],[1026,1092,"Cindy."],[1184,1343,"She's manipulating you-"],[1343,1463,"Look, it doesn't matter."],[1534,1693,"She went into a hotel room"],[1701,1797,"with another man."],[1805,1926,"That's all I need to know."],[2031,2193,"Don't do something you're gonna regret."],[2285,2406,"I'm still investigating."],[2502,2615,"There's more about the story"],[2615,2690,"you don't realize."],[2698,2836,"Then why won't she just tell me?"],[2990,3078,"She doesn't trust me."],[3078,3224,"She never has, and she never will."],[3524,3636,"You're gonna regret this, Matt."],[3766,3962,"Regret is not in my vocabulary."],[4049,4095,"Hey."],[4095,4241,"What's up, guys?"],[4291,4375,"Toby."],[4421,4500,"Man, I didn't think"],[4500,4617,"we'd ever see you again."],[4625,4738,"Toby Lawson,"],[4783,5000,"the man Linda left me for years ago?"]],"55":[[8,83,"Toby."],[154,246,"Man, I didn't think"],[246,375,"we'd ever see you again."],[408,513,"Figured that Linda chick"],[517,679,"finally got you cornered this time."],[846,1009,"Oh, the doctor"],[1055,1322,"tampered with the injury report."],[1401,1580,"Bill bribed the doctor to do so."],[1580,1872,"I am a clueless victim, - Shit."],[1872,1993,"what are the cops gonna do?"],[1997,2181,"Wait, wait, what are you talking about?"],[2181,2281,"You don't know?"],[2535,2677,"Five years ago,"],[2723,2861,"Bill threatened Linda"],[2861,3028,"that he'd kill her little boyfriend"],[3028,3274,"if she didn't agree to marry our boy"],[3274,3345,"Toby here."],[3420,3624,"She had no choice but to agree."],[3645,3837,"Went through the whole engagement"],[3841,3899,"and then-"],[3941,4091,"She lost it and stabbed you?"],[4124,4183,"No."],[4204,4387,"The whole thing was a setup."]],"56":[[0,179,"But Toby stabbed himself"],[187,367,"and made it look like she did it."],[379,458,"Perfect plan to"],[458,642,"get her locked up for years."],[663,800,"Just like what Bill wanted."],[821,955,"Damn, that's cold."],[1005,1146,"Poor girl didn't see it coming."],[1226,1301,"Oh man."],[1338,1547,"Oh, I bet her little boyfriend lost it"],[1555,1651,"and ran away the second"],[1651,1760,"they slapped the cuffs on."],[2139,2277,"My biggest regret is"],[2277,2473,"I didn't get a chance to taste her"],[2477,2656,"before I sent her to prison."],[2690,2882,"I was too focused on Bill's money"],[2882,2965,"back then."],[3007,3182,"I can still remember her face,"],[3203,3328,"and her body."],[3432,3528,"What a shame."],[3561,3661,"Word is"],[3661,3778,"she's gonna get kicked out of"],[3778,3899,"Abell Group today."],[3924,3974,"Good."],[3999,4091,"When she's broke,"],[4104,4279,"I'll throw her a few bucks"],[4295,4500,"and then I'll have her"],[4500,4692,"all night long."],[4979,5096,"Get out."]],"57":[[504,663,"Hey uh, uh, Toby."],[692,779,"Toby, right?"],[846,1055,"Yeah, we went to college together."],[2135,2256,"You guys know him?"],[2302,2352,"Shit."],[2360,2469,"You fucking know this guy?"],[2477,2631,"No no no no, no."],[2698,2777,"No, we're good."],[2819,2886,"No?"],[2902,3032,"Have a nice night, fellas."],[3403,3532,"Let's get the check, come on."],[3599,3641,"Let's go."],[4220,4337,"Have a nice night, Toby."]],"58":[[204,312,"Before my father passed,"],[312,408,"he gave me the safe"],[408,538,"with clear instructions"],[546,684,"not to use the key to open it"],[684,829,"until I become CEO."],[971,1026,"Excellent."],[1105,1255,"The core technology"],[1255,1413,"will finally be revealed again."],[1434,1534,"Old Mr. Abell"],[1697,1856,"trusted his daughter completely."],[1926,2043,"Seems only right"],[2122,2218,"that Miss Abell"],[2243,2485,"should assume the position of CEO"],[2523,2656,"after six years."],[2744,2811,"Wait!"],[3103,3249,"We should decide the CEO"],[3290,3457,"after the results of our bet are in."],[3490,3557,"What bet?"],[3728,3799,"We agreed that"],[3799,3974,"whoever brings more investment"],[4016,4220,"to the Abell Group will receive"],[4220,4412,"5 percent shares from both of us"],[4425,4533,"and help lead the company"],[4533,4658,"back to its former glory."],[4700,4838,"That's a total of 10 percent."],[4879,4996,"That's quite significant."],[5021,5125,"I've secured"],[5125,5276,"a billion dollar investment"],[5301,5451,"from the Johnson Group CEO"],[5451,5580,"to help this company grow."],[5672,5834,"With support from a powerhouse"],[5834,5943,"like the Johnson Group,"],[5951,6143,"the Abell Group will surely thrive."],[6214,6414,"Linda, what about your investment?"]],"59":[[41,246,"Linda, what about your investment?"],[279,429,"I didn't get any investment."],[608,875,"Oh, you didn't get an investment?"],[1101,1276,"Then according to our contract,"],[1317,1438,"that 5 percent of shares,"],[1451,1672,"10 percent actually, is mine."],[1705,1876,"Now I'm the largest shareholder"],[1881,1968,"of the Abell Group."],[2264,2406,"I'd like to take this moment"],[2448,2573,"to announce myself"],[2594,2865,"as the new CEO of the Abell-"],[2865,2919,"Hold on."],[2990,3098,"Oh, what now?"],[3294,3403,"I didn't get the investment,"],[3403,3541,"but I haven't lost yet."],[3866,4037,"I know this is really difficult for you,"],[4037,4099,"Linda,"],[4141,4304,"but arguing won't change anything."],[4337,4496,"You've been away for six years."],[4517,4625,"You don't know the first thing"],[4625,4775,"about running a company anymore."],[4833,4917,"What do you all think?"],[4992,5096,"Would you agree with me?"],[5142,5351,"I'm sorry, Miss Abell,"],[5355,5513,"this company's been our life's work"],[5543,5605,"and affects"],[5605,5734,"thousands of employees."],[5776,5947,"Bringing you back as CEO"],[6072,6247,"is a risk we can't afford to take."]],"60":[[41,221,"Bringing you back as CEO,"],[358,529,"is a risk we can't afford to take."],[554,625,"The dividends"],[625,771,"from your father's shares"],[775,896,"should be enough for you."],[984,1138,"Perhaps it's best to"],[1230,1305,"step aside."],[1426,1555,"If I were you, Linda,"],[1564,1693,"I would focus on finding"],[1693,1876,"another rich old man to sleep with."],[1926,2035,"Seems like the only way you know"],[2035,2173,"how to make money these days."],[2181,2264,"Disgraceful."],[2310,2502,"Your father built this company"],[2502,2681,"with integrity and honor."],[2736,2915,"If old Mr. Abell could hear this,"],[2936,3111,"he'd be turning in his grave."],[3157,3265,"Don't celebrate so soon."],[4004,4099,"Take a look at these."],[4170,4250,"What is this?"]],"61":[[20,87,"What is this?"],[271,400,"Since my father died,"],[442,629,"Bill has been embezzling millions."],[729,813,"Under his leadership,"],[813,921,"we are drowning in debt"],[921,1080,"while he and his daughter, Cindy,"],[1134,1259,"drive luxury cars"],[1259,1376,"and live in mansions."],[1401,1472,"How did you know?"],[1526,1651,"Because I know everything, Bill."],[1714,1943,"Including, that the Johnson Group"],[1968,2131,"will invest when you"],[2160,2281,"get the core technology"],[2281,2389,"from our company"],[2406,2548,"after you become CEO."],[2798,2869,"The Johnson Group"],[2869,2952,"is foreign-owned."],[3003,3090,"Do you all understand"],[3090,3174,"what that means?"],[3186,3265,"It means"],[3311,3482,"Mr. Abell's core technology"],[3570,3678,"would leak overseas."],[3737,3782,"Bill,"],[3828,4008,"this is an absolute betrayal."],[4037,4162,"Who's betraying anything?"],[4216,4329,"I didn't betray anybody."],[4416,4462,"Bill,"],[4504,4708,"you sold out the company,"],[4750,4913,"disregarded everyone here,"],[4942,5213,"and plotted to betray us all."],[5246,5476,"Return whatever money you've taken"],[5526,5709,"and get out of the Abell Group."]],"62":[[0,208,"You sold out the company,"],[237,417,"disregarded everyone here,"],[446,704,"and plotted to betray us all."],[742,984,"Return whatever money you've taken"],[1005,1222,"and get out of the Abell Group."],[1280,1359,"Please,"],[1426,1526,"let me explain-"],[1543,1614,"Great news."],[2002,2110,"The Baron Group has invested"],[2110,2302,"$500 million in our company."],[2402,2464,"Shit."],[2515,2590,"We're finished."],[2631,2786,"If Baron invested-"],[2786,2852,"Shh."],[3553,3607,"The Baron Group"],[3607,3766,"would like to congratulate..."]],"63":[[0,70,"The Baron Group"],[70,208,"would like to congratulate..."],[504,742,"Bill Abell on becoming CEO."],[1055,1105,"What?"],[1726,1814,"I can't believe it."],[1876,2035,"Ah, Mr. Baron wants me to be"],[2035,2177,"the new CEO of the Abell Group."],[2314,2394,"Me!"],[2656,2765,"Guess your little affair"],[2765,2990,"with the old man disgusted Mr. Baron."],[3007,3265,"So what, you were once with Mr. Baron?"],[3378,3465,"In the end,"],[3465,3628,"everything always works out for us."],[3628,3745,"It sure does."],[3862,4008,"Soon you'll be nothing more"],[4008,4208,"than another homeless nobody"],[4208,4387,"asking for money on the streets."],[4429,4587,"Matt, how could you do this to me?"],[4671,4829,"Do you really hate me that much?"],[4854,5000,"Anyone wants to remove me now?"],[5142,5230,"That's what I thought."],[5259,5384,"Ms. Abell, for"],[5397,5609,"the sake of the company's future,"],[5668,5789,"surrender the safe key"],[5830,6022,"and leave the premises"],[6022,6114,"immediately."]],"64":[[16,141,"Surrender the safe key"],[187,358,"and leave the premises"],[383,467,"immediately."],[513,663,"This company is my father's life work."],[663,809,"I won't just hand it over."],[1001,1101,"You have no choice."],[1130,1301,"I brought in 1.5 billion"],[1301,1372,"to this company."],[1422,1488,"What have you brought"],[1526,1680,"besides failure?"],[1993,2110,"Isn't it poetic, Linda?"],[2189,2318,"That the man you once sacrificed"],[2318,2402,"everything for"],[2402,2535,"is the one destroying you."],[2665,2769,"How does it feel"],[2852,2969,"when the person you loved"],[2969,3098,"becomes your executioner?"],[3244,3319,"Enough games."],[3415,3520,"Give us that key now."],[3520,3641,"I would rather die"],[3666,3791,"than see you destroy everything"],[3791,3887,"my father built."],[4062,4137,"Those keys are just"],[4137,4270,"worthless metal in your hands."],[4295,4396,"Hand it over now!"],[4396,4525,"It may be worthless to me,"],[4546,4671,"but I won't let his technology"],[4671,4746,"go overseas."],[4746,4900,"He would have never wanted that."],[4921,5080,"Bill and the Johnson Group"],[5084,5138,"gave their word,"],[5138,5267,"it would stay domestic."],[5288,5351,"His word?"],[5384,5459,"Since when does his word"],[5459,5530,"mean anything?"],[5626,5730,"You are selling yourselves out"],[5730,5834,"for 1.5 billion."],[5834,5993,"What happened to your principles, huh?"],[6093,6239,"Don't say I didn't warn you."],[6348,6448,"Don't touch me."],[6531,6589,"Dad."],[6723,6806,"She hit me."],[6940,7048,"Why are you all just sitting there?"],[7107,7198,"Get the safe key."],[7265,7344,"Whoever gets it"],[7361,7507,"will become a billionaire for life."]],"65":[[8,112,"What are you waiting for?"],[120,187,"Grab her."],[233,408,"Miss Abell, please, I'm sorry."],[521,608,"Let me go."],[608,692,"You guys don't understand."],[692,829,"If Bill takes over the company,"],[838,909,"he will destroy"],[909,1013,"everything that we've built."],[1021,1142,"Oh, shut your mouth."],[1434,1568,"My father will make this company"],[1568,1655,"greater than your"],[1655,1814,"pathetic father ever could've."],[2444,2548,"The key's not in her bag."],[2690,2907,"She had her child while in prison,"],[3003,3123,"could the little girl have it?"],[3178,3307,"But she's back with the Barons."],[3315,3507,"No, think about it."],[3549,3728,"Linda didn't come here to negotiate."],[3778,3903,"She came here to win."],[3937,4004,"So she would have"],[4004,4162,"everything with her today,"],[4187,4325,"which means the key's on her."],[4487,4579,"Hand it over,"],[4621,4775,"or I'll search for it myself."],[4821,4934,"Over my dead body."],[4938,5084,"That can be arranged."],[5205,5351,"Let me go! Stop!"],[5430,5543,"Get off."],[5734,5814,"I got it."]],"66":[[0,158,"That can be arranged."],[229,375,"Let me go! Stop!"],[479,583,"Get off."],[788,900,"I got it."],[1551,1685,"The key is mine now."],[1705,1931,"This company is mine now."],[2494,2598,"But someone like you,"],[2660,2806,"is too dangerous to keep alive."],[3324,3490,"Say hello to your father for me."],[4408,4458,"Linda?"]],"67":[[45,112,"Linda?"],[191,300,"Hey, hey."],[350,400,"Linda?"],[433,483,"Matt."],[525,633,"Oh fuck."],[692,729,"Hey."],[846,942,"Hey, stay with me."],[959,1030,"You're okay."],[1197,1259,"Matt."],[1388,1522,"Why did you hurt me?"],[1622,1755,"Look, I was wrong."],[1797,1964,"Linda, I'm so sorry."],[2127,2198,"I..."],[2323,2494,"I gotta get you to a hospital, okay?"],[2519,2565,"Hey."],[2585,2660,"Hey, come on."],[2673,2761,"Come on, let's go."],[2769,2844,"It's gonna be okay."],[2844,2898,"Come on."],[2932,3065,"Come on, stay with me."],[3507,3657,"Was Mr. Baron's investment"],[3657,3795,"meant for Linda all along?"],[3832,4058,"No, it, it says right here."],[4141,4229,"It's for Bill."],[4233,4496,"If Matt backs out, I'm finished."],[4758,4871,"Come on, let's get out of here."],[4996,5071,"Stay right there."]],"68":[[12,70,"Bill Abell,"],[70,208,"you just plunged a knife"],[208,404,"into the woman Mr. Baron has loved"],[404,521,"since the day he met her."],[529,592,"Love?"],[675,804,"Don't be ridiculous."],[867,1026,"Baron just gave me five hundred million"],[1026,1159,"to crush her company."],[1205,1309,"Would a man in love do that?"],[1347,1626,"Mr. Baron was blinded by revenge"],[1647,1881,"and made the worst mistake of his life."],[1910,2139,"And now, he'll make everyone"],[2164,2385,"who deceives him pay dearly for it."],[2523,2623,"Starting with you."],[2723,2777,"Take them."],[2898,2952,"No."],[2994,3140,"No, this is insane!"],[3165,3257,"Let go of me!"],[3265,3328,"Wait."],[3770,3828,"No."],[3999,4079,"Oh no."],[4079,4141,"Take him."],[4200,4262,"No!"],[4304,4379,"Cindy!"],[4404,4479,"No."],[4542,4621,"Cindy!"],[4642,4721,"Help me!"],[4838,4913,"No."],[5547,5809,"Everyone who harmed Linda today"],[5826,5993,"just signed away their freedom."],[6064,6285,"Baron Group owns judges,"],[6306,6448,"prisons, politicians,"],[6448,6577,"and Mr. Baron will not rest"],[6577,6773,"until each one of you is destroyed."]],"69":[[1071,1155,"You were the only person"],[1155,1267,"I ever truly loved."],[1322,1555,"And I broke up with you to save you."],[1614,1751,"Because we can't just go back"],[1751,1860,"to the way that things were."],[1860,1943,"So why don't we just"],[1943,2152,"end things and move on with our lives?"],[2448,2677,"Linda, I was so wrong."],[2727,2990,"Please, just give me another chance"],[3023,3140,"to make things right."],[3549,3607,"Hey."],[3799,3874,"How are you feeling?"],[3912,4016,"You okay?"],[4312,4400,"Here, let me help you."],[4517,4629,"Easy, easy."],[5246,5309,"Matt,"],[5380,5551,"when I broke up with you back then,"],[5601,5743,"I didn't have a choice."],[5901,5960,"Please,"],[6360,6473,"don't help them give over"],[6473,6639,"what's left of my father's company."],[6644,6681,"No."],[6819,6877,"No."],[6977,7065,"Not ever again."],[7157,7332,"Your father's company is yours."],[7403,7603,"No one is gonna take it from you."]],"70":[[300,467,"The Abell Group board"],[467,633,"has already approved you as CEO."],[796,971,"This was my father's life's work"],[971,1046,"thank you."],[1284,1609,"Look, I know that I failed you, Linda."],[1634,1760,"I had no idea that"],[1760,1843,"they were threatening you"],[1843,1997,"with my life all those years ago."],[2106,2214,"If I would have told you"],[2214,2352,"who I really was back then,"],[2360,2515,"none of this would have happened."],[2736,2831,"This is all my fault."],[3078,3249,"In the six years that I was in prison,"],[3249,3345,"I never once regretted"],[3345,3415,"protecting you."],[3611,3720,"But when I found out"],[3841,4012,"who you really were, a Baron."],[4562,4621,"I just..."],[5146,5242,"I just felt like I,"],[5401,5505,"like I was a punchline of"],[5505,5634,"a cruel joke."],[6247,6381,"I gave up everything,"],[6514,6794,"I gave up everything to save you."],[6898,6944,"And you,"],[6944,7119,"and, and then the whole time that you"],[7136,7207,"you could have just"],[7207,7319,"protected yourself."]],"71":[[342,546,"I can't undo those six years,"],[713,888,"but I swear that I will spend"],[888,1026,"the rest of my life trying."],[1088,1201,"Linda, please."],[1313,1426,"Please just give me a chance to"],[1426,1530,"prove that I'm worthy of"],[1530,1643,"what you gave up for me."],[2068,2147,"No need."],[2452,2515,"I'm tired."],[2515,2594,"You can leave."],[3140,3186,"Alright."],[3674,3774,"Rest well, Linda."]],"72":[[892,984,"Daddy!"],[1088,1234,"Is Mommy okay?"],[1238,1409,"Mommy is awake and resting."],[1480,1580,"Don't worry, sweetheart."],[1605,1814,"She doesn't like being hurt."],[1839,1985,"I'm wanna go see her."],[2022,2293,"Joyce, Daddy made a big mistake"],[2385,2590,"and Mommy is really upset with me."],[2715,2802,"Do you think you could ask her"],[2802,2902,"to forgive me?"],[2911,3132,"Mommy said if you make mistakes,"],[3140,3290,"you have to say sorry"],[3299,3499,"and fix it yourself."],[3532,3682,"Your mom taught you well."],[3749,3887,"But don't you blame Daddy?"],[4033,4154,"You had to grow up in a prison"],[4154,4241,"because of me."],[4266,4416,"I don't blame Daddy."],[4421,4696,"Auntie Ana was nice to me in prison."],[4729,4909,"And Mommy never said bad things"],[4909,5009,"about Daddy."],[5075,5192,"That was before."],[5305,5413,"Now Mommy doesn't want"],[5413,5534,"Daddy around anymore."],[5622,5743,"Daddy must have made"],[5743,5905,"Mommy really sad."],[5939,6089,"I'll go see her now."]],"73":[[633,692,"Joyce."],[800,859,"Come here."],[1042,1113,"Come sit with me."],[1785,2039,"Mommy, are you still in pain?"],[2314,2456,"Not anymore, sweetheart."],[2531,2606,"I'm feeling much better."],[2606,2727,"Don't you worry about me."],[2823,3028,"Did Daddy make you sad again?"],[3186,3340,"Daddy hurt Mommy's feelings."],[3703,3807,"If things don't work out"],[3807,3949,"between Daddy and Mommy,"],[4041,4175,"we might have to live apart."],[4387,4512,"If that happens,"],[4725,4842,"who do you want to stay with?"],[4884,5030,"I can stay with you."],[5071,5259,"And see Daddy on weekends."],[5259,5472,"Or, we can live with Grandma"],[5497,5726,"or Grandpa, or Sean."],[5759,5980,"Sean always gives me cookies."],[6139,6277,"I love you so much."],[6339,6489,"I love you too, Mommy."],[6502,6690,"Please don't cry."],[6977,7082,"Weekends?"],[7132,7248,"That's all I get?"],[7440,7578,"You did break her mother's heart."],[7691,7757,"And you."],[7816,7974,"With your damn cookies."],[8149,8270,"I warned you not to go through"],[8270,8383,"the revenge plan, Matt."],[8441,8541,"Your exact words were,"],[8546,8725,"regret isn't in my vocabulary."],[8758,8808,"Remember?"],[8817,8871,"Yeah."],[8933,9004,"I remember."]],"74":[[784,829,"Hey."],[942,1021,"Are you okay?"],[1130,1209,"Are you thirsty?"],[1267,1347,"Are you hungry?"],[1380,1447,"Or you probably need to"],[1447,1539,"use the restroom, right?"],[1568,1655,"Come on, I got you."],[1668,1735,"Here we go."],[1793,1943,"Easy, easy."],[1943,2018,"I got you."],[2027,2077,"Aw."],[2097,2160,"Put me down."],[2168,2302,"What? Oh, okay, okay."],[2327,2389,"Ow."],[2431,2489,"Look,"],[2590,2656,"the doctor said"],[2656,2761,"you can't get up on your own."],[2761,2902,"It can reopen your wound."],[2940,3044,"You don't need to do that."],[3140,3257,"Look, it's the middle of the night,"],[3257,3328,"would you just"],[3449,3582,"will you let me help you, please?"],[3691,3812,"It's the least I can do."],[3916,4058,"She's been on her feet all day,"],[4058,4245,"she must be exhausted."],[4446,4583,"Come on, I got you."],[4637,4708,"Nice and easy."],[4708,4796,"I know, I know."],[4804,4892,"Easy, shh."],[5647,5780,"Nice and slow, careful."],[6769,6881,"Thank you for your help,"],[6915,7061,"but I don't need you here."],[7073,7257,"I can hire a nursing aid tomorrow."],[7315,7432,"No, you won't."],[7586,7753,"I'm your nursing aid from now on."],[7836,7937,"What are you trying to do?"],[8091,8166,"I won't forgive you,"],[8166,8254,"no matter what you do."],[9054,9230,"Whether you forgive me or not,"],[9300,9501,"I won't abandon you again, Linda."]],"75":[[0,108,"Your mom will be back"],[108,200,"on her feet in no time"],[200,346,"after taking all this medicine."],[454,588,"You know, you didn't save me"],[588,709,"any cookies yesterday,"],[800,884,"but I forgive you."],[963,1101,"It's pretty nice of me, right?"],[1910,2014,"Alright kiddo."],[2014,2106,"Let's-"],[2323,2402,"Joyce?"],[2656,2727,"Joyce?"],[3474,3586,"Guys, Joyce is gone!"],[3603,3661,"What?"],[3862,3916,"Come on!"],[3995,4087,"Your Daddy"],[4220,4350,"left me crippled."],[4412,4466,"Now,"],[4533,4683,"it's time I get even"],[4683,4863,"with his precious little princess."]],"76":[[45,95,"Now,"],[150,316,"it's time I get even"],[316,471,"with his precious little princess."],[471,517,"Stop!"],[604,813,"If we kill her, we have no leverage."],[825,1009,"No ransom, no money."],[1042,1096,"Money?"],[1155,1255,"I'm crippled"],[1288,1530,"because of what your dad did."],[1576,1747,"No amount of cash will fix this."],[1947,2064,"Pull yourself together."],[2064,2218,"We need to stick to the plan."],[2431,2569,"Once we get Matt's money,"],[2631,2727,"we'll disappear,"],[2748,2877,"get the best medical advice,"],[2877,3032,"and your leg will be as good as new."],[3061,3161,"I'm crippled."],[3215,3340,"Who would want to marry me?"],[3453,3541,"You owe me."],[3586,3728,"You'll take care of me forever."],[3749,3924,"Alright, fine."],[4020,4137,"I'll take care of you."],[4220,4291,"After all,"],[4291,4446,"we have little Miss Baron here."],[4521,4608,"She's our ticket"],[4608,4758,"to everything we want."],[4771,4904,"Please, let me go."],[4904,5071,"I'll tell you where my Daddy"],[5092,5263,"keeps all of his money."],[5313,5455,"You know where the money is?"],[5555,5722,"We can take it and get it right now."],[5739,5847,"Are you stupid?"],[5918,6006,"How would a kid know"],[6006,6097,"where Matt's money is?"],[6097,6227,"She's playing you."],[6277,6477,"If we let her go, we're both finished."],[6498,6610,"You little brat!"],[6619,6769,"You think you can trick me?"]],"77":[[8,112,"You little brat!"],[125,266,"You think you can trick me?"],[458,538,"Joyce! - Joyce!"],[880,1142,"Mommy, Daddy, I'm scared."],[1222,1455,"Not another step, or she dies."],[1634,1755,"Please, don't hurt my baby."],[1830,1906,"What is it you want?"],[1951,2064,"Release my father,"],[2072,2264,"bring us ten million in cash,"],[2339,2460,"and arrange a safe passage"],[2460,2544,"out of the country."],[2569,2681,"If you don't,"],[2698,2806,"your precious daughter"],[2806,2927,"pays the price."],[2998,3078,"Mommy."],[3169,3278,"Give them whatthey want."],[3378,3428,"Do it."],[3432,3520,"Please, just..."],[3557,3616,"Please, Matt."],[3682,3753,"Bring him in."],[3791,3887,"Let go of me."]],"78":[[62,175,"Alright, you have what you asked for."],[175,291,"Now, release my daughter."],[312,392,"Not yet."],[450,558,"Free my father"],[558,688,"and toss over the money."],[746,821,"Go on."],[1438,1505,"Give them money."],[2748,2952,"It's all here, just like they promised."],[3103,3182,"Okay, you have everything"],[3182,3261,"you asked for."],[3261,3374,"Now, release my daughter,"],[3374,3461,"as we agreed."],[3474,3557,"You didn't really think"],[3557,3716,"it'd be that simple, did you?"]],"79":[[0,79,"You didn't really think"],[79,246,"it'd be that simple, did you?"],[325,417,"If I release Joyce,"],[417,492,"what's to stop you"],[492,592,"from breaking your word"],[592,709,"and coming after us?"],[888,975,"What more do you want?"],[1001,1113,"Your daughter will come with us"],[1113,1230,"until we're out of the country."],[1242,1288,"Then maybe"],[1288,1434,"she'll find her way back home,"],[1472,1609,"if we're feeling generous."],[2323,2439,"No!"],[2477,2602,"You can't take her!"],[2619,2723,"You don't get to bargain."],[2794,2919,"I still control"],[2919,3057,"if your daughter lives or dies."],[3086,3174,"She's just a child."],[3311,3374,"She's just gonna"],[3374,3436,"slow you down, just..."],[3883,3928,"Take me."],[4062,4233,"We're in this mess because of Linda."],[4300,4512,"Once we're safe, then we'll kill her."],[4767,4829,"Come here."],[5226,5422,"I am the CEO of Baron Group."],[5492,5609,"Take me, and you'll increase"],[5609,5714,"your leverage tenfold."],[6014,6101,"Do we have a deal?"],[6151,6202,"What?"],[6214,6548,"That's the guy who made me crippled."],[6581,6656,"Get over here."],[6715,6911,"I'll pay you back double this time."],[6994,7111,"No, no, don't."],[7182,7319,"Listen to me, Linda."],[7407,7490,"If I don't come back,"],[7490,7545,"you and Joyce"],[7545,7649,"will still have each other."],[7732,7912,"This is my chance to make things right."],[7982,8062,"For everything."]],"80":[[0,179,"This is my chance to make things right."],[254,337,"For everything."],[392,425,"No!"],[425,487,"Please don't!"],[487,579,"Stay back, Linda."],[625,734,"Matt!"],[2085,2214,"I'm gonna keep you safe."],[2243,2348,"I promise."],[2414,2523,"Promise."],[2740,2890,"I know, I'm gonna keep you safe"],[2890,3019,"from now on, okay?"],[3119,3199,"I promise."],[3240,3299,"Here."],[3340,3586,"A pinky promise, okay?"],[3653,3703,"Okay?"],[3732,3895,"You go run back to your mom, okay?"],[3920,3970,"Go."],[4012,4099,"Mommy."],[4533,4642,"You're ok."],[4729,4804,"Mommy's here."],[5455,5584,"Get her somewhere safe now."],[6231,6297,"Matt!"],[6760,6877,"Mr. Baron! - Stay back!"],[6961,7027,"Back."],[7211,7261,"Yes sir."],[7711,7891,"Time to die, Baron."],[8012,8120,"Watch out. No!"]],"81":[[250,342,"You fool."],[450,625,"Kill him now, and we'll never escape!"],[875,980,"You want revenge?"],[1009,1151,"Save it in for the afterlife!"],[1305,1372,"Cindy."],[1397,1463,"Yes, Dad."],[1526,1626,"Grab the money and let's go."],[1630,1697,"On it!"],[1755,1814,"Get up."],[1868,1964,"Get up!"],[1981,2110,"Matt..."],[2110,2231,"Stay back, Linda."],[2544,2644,"Toby's still alive."],[2694,2748,"What?"],[3103,3157,"Dad!"],[3207,3274,"Cindy!"],[3307,3395,"Kill Linda!"],[3495,3628,"Don't wait. Kill her, now!"],[3757,3807,"Do it!"],[3807,3887,"Kill her!"],[4275,4454,"I'm gonna fucking kill you!"],[4454,4529,"Linda!"],[5146,5196,"Matt."]],"82":[[0,45,"Matt."],[120,183,"Matt!"],[212,283,"Matt? - No."],[342,375,"Matt."],[408,471,"Matt?"],[487,679,"Matt, stay with us!"],[763,825,"Somebody please..."],[909,1092,"Somebody please call an ambulance!"],[1347,1447,"Hurry, please!"],[1447,1534,"Somebody!"],[1985,2027,"Linda?"],[2122,2210,"Matt will be fine."],[2306,2573,"He's strong, he'll pull through."],[2827,2869,"Yeah."],[2936,2990,"He'll make it."],[2990,3061,"He has to."],[3119,3178,"Sean."],[3353,3436,"Where's my son?"],[3557,3703,"The doctors are working on him now."],[3782,3891,"Try not to worry."],[4033,4154,"How is Joyce?"],[4200,4279,"She's okay."],[4337,4429,"Our security team is keeping"],[4429,4617,"a tight surveillance on her."],[4700,4788,"Good."],[5034,5100,"This is Linda."],[5150,5259,"Joyce's mother."]],"83":[[4,120,"Mr. and Mrs. Baron."],[696,759,"Matt got hurt,"],[905,1009,"trying to save me."],[1059,1134,"And I never wanted it"],[1134,1230,"to happen and I..."],[1284,1405,"I'm so sorry."],[1405,1447,"No."],[1514,1601,"I know what happened"],[1601,1726,"between you two, years ago."],[1818,2085,"You sacrificed your life to save his."],[2143,2285,"Just like he saved yours today."],[2435,2573,"Maybe this is his way of"],[2594,2635,"showing you"],[2635,2777,"how much that meant to him."],[2890,3032,"You mustn't blame yourself."],[3353,3586,"Oh, Dr. Jenkins, how's my son?"],[3670,3787,"We managed to save him,"],[3874,3987,"but he is in a coma."],[4054,4099,"And,"],[4129,4220,"as for when he wakes up,"],[4220,4341,"that could be tomorrow,"],[4354,4450,"or next month,"],[4608,4688,"or he may never"],[4688,4763,"regain consciousness"],[4763,4838,"again."]],"84":[[16,83,"Or he may never"],[83,154,"regain consciousness"],[154,225,"again."],[287,329,"No."],[458,533,"No, no. - Edith."],[533,608,"Edith."],[2852,2973,"Where are Edith and Henry?"],[3023,3132,"I finally convinced them"],[3132,3257,"to go home and rest."],[3445,3599,"This hit them hard."],[3720,3866,"Matt's their only child."],[4108,4216,"I'm worried about their health."],[4483,4550,"He should've never"],[4550,4646,"tried to save me."]],"85":[[212,279,"He should have never"],[279,396,"tried to save me."],[558,813,"Matt has always loved you, Linda."],[963,1092,"That's the truth."],[1297,1434,"With or without him,"],[1526,1676,"Bill and Cindy would have come for you."],[1830,2114,"But he's been protecting you,"],[2114,2252,"even when you didn't know it."],[2381,2448,"Everything"],[2448,2565,"you've managed to get back."],[2652,2836,"Your company, your life."],[3115,3203,"He'll make it happen."],[3345,3415,"Yes."],[3511,3599,"It was wrong of him"],[3599,3753,"to hide who he was from you."],[3945,3983,"But,"],[4124,4287,"if you had trusted him enough"],[4304,4383,"to talk with him"],[4383,4491,"when you were in trouble,"],[4567,4729,"maybe things would be different now."],[5263,5405,"You both made mistakes."],[5509,5663,"Don't put all the blame on him."],[6981,7040,"Where are you going?"],[7344,7465,"I need to check on Joyce."],[7636,7716,"I'll be back soon."],[7824,7966,"Please watch over Matt for me."],[9054,9163,"Was I too harsh?"]],"86":[[525,684,"If my son doesn't wake up,"],[725,821,"I don't want to live."],[888,1117,"Son, I faced countless hardships"],[1117,1205,"when I was young."],[1288,1488,"But thinking of you and your mother"],[1493,1589,"gave me strength."],[1693,1797,"Think of Joyce now."],[1847,2006,"Can you really let her grow up"],[2006,2089,"without a father?"],[2210,2377,"Linda, she hasn't forgiven you yet."],[2523,2823,"What if, what if she gives up waiting?"],[2898,3090,"Oh, what if she remarries"],[3123,3286,"and she takes Joyce with her?"],[3411,3461,"We don't know"],[3461,3599,"what kind of stepfather"],[3628,3778,"Joyce would end up with."],[3866,3999,"What if he mistreated her?"],[4079,4208,"Wouldn't that upset you?"],[4220,4387,"Uh, maybe we should talk"],[4387,4454,"about something else?"],[4458,4529,"Hush."],[4629,4725,"With Matt's temper,"],[4871,4971,"just the thought"],[5046,5188,"of his daughter being raised"],[5188,5347,"by another man that might be"],[5363,5576,"what he needs to get up and fight."],[6156,6222,"Linda and Joyce are here."],[6235,6452,"Let's get them some family alone time."],[6977,7169,"Daddy, look what I made for you."],[7186,7336,"This is you, this is me,"],[7336,7449,"and this is Mommy."],[7478,7649,"We're at the fun park."],[7678,7866,"Mommy said when you wake up,"],[7866,8041,"we can all go together."],[8229,8379,"Matt, if you wake up,"],[8433,8629,"I'm ready to start over with you."]],"87":[[333,417,"Mommy,"],[475,596,"what are you making?"],[671,750,"Apple pie."],[850,946,"Your Daddy made it for me once,"],[946,1034,"I never got to try it."],[1134,1217,"It's your favorite dessert,"],[1217,1297,"I made it myself."],[1359,1405,"Try it."],[1539,1626,"So today,"],[1689,1814,"Mommy's made it for Daddy,"],[1881,2027,"and you get to give it to him."],[2694,2748,"Hello?"],[2823,2994,"Linda, Matt's awake!"],[3011,3115,"He's really awake."],[3224,3307,"Mommy."],[3307,3486,"Daddy's awake."]],"88":[[692,746,"Daddy!"]]}