{"1":[[709,938,"Come on Micah, where are you?"],[1347,1476,"Oh my God, don't make me"],[1476,1547,"walk again."],[1643,1801,"My mom really needs me to help"],[1801,1864,"with the thrift store"],[1864,1951,"today, and my"],[1951,2177,"boyfriend promised to drive me."],[2177,2293,"Oh my God."],[3290,3486,"Handcuffs are the new black"],[3486,3703,"for Miss Whitmore after she's framed"],[3703,3862,"for luxury laundering."],[3928,4116,"Who set her up?"],[4300,4537,"What is this?"],[4733,4850,"Who made this account?"],[4850,4954,"What?"],[5084,5280,"This is AI, I just talked to her."],[5488,5659,"Caught in 4K."],[5659,5801,"Zoe's boyfriend Micah"],[5801,5985,"getting hands on with queen bitch"],[5985,6139,"Tiffany in the science lab."],[6264,6427,"Why is a spam account"],[6427,6594,"telling me my mom is in jail"],[6594,6731,"and my boyfriend's hooking up with"],[6731,6835,"my bully?"],[7369,7469,"Hey!"],[7553,7640,"Do you think that you could give me a"],[7640,7724,"ride after school?"],[7724,7816,"My mom just really needs"],[7816,7882,"me at the shop."],[7953,8053,"Whatever."],[8053,8145,"If I have to."],[8208,8312,"Just..."],[8350,8512,"meet me after school, babe."],[11440,11619,"What was that?"],[11619,11686,"What?"],[11686,11790,"Tiffany just touched you."],[11790,12028,"She bumped me as she walked past."],[12028,12141,"That is, that's not what that looked"],[12141,12183,"like. She --"],[12183,12324,"Whatever. Okay."],[12366,12550,"This is the problem with dating a virgin"],[12550,12741,"who never wants to go past kissing."],[12787,12996,"You think eveything is sexual."],[13079,13200,"I'll see you after school."],[13200,13350,"Don't believe me Zoey?"],[13350,13538,"Go check the science lab."],[13538,13613,"Right."],[13613,13722,"Now."],[16237,16387,"My boyfriend is cheating with my"],[16387,16495,"bully."],[17283,17513,"Which means this account isn't spam!"],[18043,18130,"Someone knows what's gonna"],[18130,18193,"happen in my life"],[18193,18314,"and is trying to warn me."]],"2":[[0,221,"Micah!"],[221,412,"You're cheating on me?"],[412,671,"How could you do this to me?"],[671,913,"With her?"],[913,980,"You know how she treats me,"],[980,1096,"are you kidding?"],[1096,1263,"So, it was time for an upgrade."],[1430,1618,"Really?"],[1618,1789,"You don't think I at least deserve"],[1789,1885,"an apology?"],[1885,1985,"Or anything?"],[1985,2039,"Eww, no!"],[2039,2114,"He got tired of dating the"],[2114,2185,"quota kid."],[2218,2377,"You're only here so that way"],[2377,2435,"the school can check"],[2435,2535,"off the charity box."],[2673,2861,"I gave you my paycheck..."],[2861,3044,"Week after week, after your dad cut"],[3044,3161,"you off."],[3303,3390,"What did I..."],[3390,3595,"What did I do to deserve this?"],[3595,3724,"A girl like you"],[3724,3970,"doesn't land a guy like me"],[3970,4149,"without paying somehow."],[4149,4266,"You wouldn't put out."],[4329,4500,"Honestly..."],[4500,4592,"You're lucky I slummed it with you as long"],[4592,4696,"as long as I did."],[4767,4900,"Being this close to broke Barbie is"],[4900,5025,"making me itchy."],[5025,5142,"Can we go?"],[7957,8078,"Mom, hi."],[8133,8304,"Oh my God, you will not believe"],[8304,8416,"what just happened!"],[8416,8475,"Honey."],[8475,8700,"I'm being arrest for theft."],[8700,8812,"But I'm innocent."],[8946,9117,"They found stolen designer bags in"],[9117,9225,"-What?! -Our storage closet."],[9225,9296,"What are you..."],[9296,9434,"What are you talking about?"],[9434,9647,"They blocked off our apartment, you"],[9647,9759,"can't come home."],[9759,9943,"But I need $10,000 for bail."],[9943,10072,"But, oh God-"],[10172,10472,"No, mom!"],[10860,11156,"Stolen handbags in Zoey's thrift store?"],[11198,11386,"How'd those get there?"],[11386,11603,"The only other person with access"],[11603,11786,"is her cheating boyfriend."],[11832,12066,"My boyfriend planted stolen bags"],[12066,12220,"in our storage so my mom would"],[12220,12312,"get arrested?"]],"3":[[688,867,"Micah! Hey!"],[921,992,"You set my mom up?"],[992,1105,"You put stolen bags in the"],[1105,1226,"storage closet?"],[1343,1413,"Prove it!"],[1714,1893,"You are such an asshole!"],[2056,2202,"Back up, bitch."],[2202,2310,"Your discount ass has no right to"],[2310,2385,"come for us!"],[2652,2786,"I earned my place in this school!"],[2786,2865,"You just bought your way in."],[3111,3190,"Get off of me!"],[3378,3411,"Hey!"],[3411,3595,"Get off of me! Get off!"],[3782,4049,"You're a cockroach under my shoe."],[4049,4145,"I could crush you and the school"],[4145,4245,"would thank me."],[4425,4550,"Keep her eyes open, boys."],[4683,4779,"I want her to watch."],[5889,6101,"Keep her down until the crowd leaves."],[6101,6197,"She needs to be humbled."],[6356,6485,"You guys won't get away with this!"],[6485,6673,"I swear to God!"],[7144,7290,"Who needs a fairy godmother"],[7290,7528,"when you've got a gossip godmother?"],[7549,7703,"Hit follow and change your fatal"],[7703,7816,"fate."],[7816,7966,"It's our little secret."],[7966,8224,"If you tell, the magic ends."],[8224,8287,"Let her go!"],[8470,8575,"That's Finn Hawthorne!"],[8575,8775,"Nephew of the royal family!"]],"4":[[70,183,"Don't make me repeat myself."],[183,266,"I make one call and"],[266,462,"your lives are over."],[1034,1217,"I've got you."],[1580,1693,"It's nice to see you without your nose in"],[1693,1881,"a book."],[1910,2068,"You know who I am?"],[2068,2160,"Try to stay out of trouble from"],[2160,2198,"now on."],[2198,2285,"Yeah?"],[2369,2569,"Finn Hawthorne..."],[2569,2865,"nephew of the royal family,"],[2865,2994,"noticed me?"],[3236,3378,"This gossip godmother"],[3378,3478,"told me to follow her page"],[3478,3678,"if I want to change my fate."],[3753,4016,"Once I do, I'll have the cheat code"],[4016,4116,"to my life."],[4187,4337,"Breaking news."],[4337,4533,"Resident Royal Finn Hawthorne"],[4533,4738,"struck by speeding car March 5th"],[4738,4904,"at 3:17 p.m."],[4934,5100,"R.I.P Maple Grove's"],[5100,5355,"finest import."],[5355,5563,"That's today!"],[5563,5714,"Oh my God."],[5901,6035,"I have to save Finn's life!"],[6035,6106,"Finn!"],[6106,6243,"This is why I tell you not to be kind to"],[6243,6377,"your lessors."],[6377,6493,"Now you've got some rando"],[6493,6585,"chasing after you."],[6585,6752,"No, don't talk about people like that."],[6752,6886,"We're all made of the same stuff."],[6886,7036,"Oh, how eloquent."],[7036,7186,"You learn that in the Royal School?"],[7186,7278,"Matter of fact, I did."],[7278,7353,"Really?"],[7353,7432,"Yes!"],[7511,7703,"Finn! Wait come back Finn!"],[7703,7811,"Finn!"],[8053,8124,"Finn!"],[8295,8375,"Come back!"]],"5":[[742,1042,"You saved my life."],[1280,1580,"How can I repay you?"],[1701,1885,"Well,"],[1885,2043,"you saved mine earlier from"],[2043,2185,"those jocks so I..."],[2243,2469,"guess we're even."],[2469,2635,"Yeah."],[2965,3261,"Um, you can get off me now."],[3261,3428,"Right. Right. Yes."],[3428,3528,"Okay. Yeah."],[3528,3661,"Not how I imagined getting close to you,"],[3661,3724,"but um,"],[3837,3995,"It'll do."],[4104,4258,"Hey! What are you doing?"],[4258,4429,"You could have killed him!"],[4429,4525,"Killed him?"],[4567,4771,"I just saved his life."],[4771,4979,"I know you're that scholarship kid."],[4979,5159,"You set this whole thing up so that"],[5159,5288,"you could get close to a royal!"],[5288,5367,"Right."],[5367,5459,"I'm so broke"],[5459,5584,"that I'm trying to scam a royal,"],[5584,5693,"but I just had enough money to"],[5693,5759,"rent a car."],[5784,5889,"Make that make sense."],[5889,6018,"Then you explain it."],[6018,6131,"How did you know Finn was"],[6131,6210,"in danger?"],[6210,6381,"If I show them that I'm getting posts"],[6381,6594,"about my future, it all ends."],[6664,6840,"No more magic."],[6840,6952,"No more clues about my fate."],[7065,7286,"No saving my mom."],[7286,7586,"I knew..."],[7595,7786,"because of my, uh, amazing"],[7786,7891,"observation skills."],[8141,8295,"You can't even pay for your own"],[8295,8379,"schooling."],[8379,8512,"What could you possibly know"],[8512,8641,"that the rest of us don't?"],[8641,8821,"What does money have anything to do"],[8821,8917,"with it?"],[8917,9071,"Okay, prove that you're some master"],[9071,9213,"observer,"],[9250,9380,"or I'm calling the cops."]],"6":[[79,337,"I can't help my mom if I get arrested."],[337,521,"I need Tate to back off!"],[521,638,"See?"],[646,909,"You're nothing but a fraud."],[909,984,"Let's go, Finn."],[984,1113,"Maybe you're right."],[1234,1409,"Years of working at my mom's"],[1409,1534,"thrift shop has taught me a thing"],[1534,1593,"or two."],[1659,1960,"That vest isn't fresh off the shelves."],[1960,2156,"It's been mended."],[2156,2268,"Tate,"],[2268,2427,"what's this?"],[2427,2548,"Looks like your sweater was"],[2548,2665,"mended."],[2665,2781,"Why wouldn't you just buy"],[2781,2819,"another one"],[2819,3019,"if you're so rich?"],[3324,3461,"Spot on."],[3578,3691,"Good eye, Zoey."],[3757,3878,"You want to put those observation"],[3878,4016,"skills to real use?"],[4016,4129,"Join me at the school fundraiser"],[4129,4204,"later."],[4287,4396,"Casino Night?"],[4396,4475,"Yeah!"],[4608,4688,"I..."],[4688,4821,"I don't have anything I can"],[4821,4909,"wear to that."],[4909,4984,"Oh, don't worry, I'll,"],[4984,5142,"I'll have a dress sent over."],[5534,5739,"I'll be there."],[5739,5901,"Great."],[6644,6748,"Zoey beats the odds at"],[6748,6940,"Casino Night, to earn bail money"],[6940,7019,"for Mom."],[7019,7136,"And catches the eye of a"],[7136,7257,"royal romeo."],[7386,7524,"My gossip godmother hasn't"],[7524,7624,"been wrong yet."],[7624,7920,"If I go, I could win that ten grand mom"],[7920,8003,"needs for bail."],[9859,9934,"How do I look?"],[10068,10206,"Zoey you're..."],[10464,10627,"so beautiful."],[11252,11394,"They're gonna be shocked when I"],[11394,11503,"walk in."],[11503,11590,"I,"],[11590,11745,"never can afford to go to these things."],[11745,11895,"Well, just stay with me. I'll protect you"],[11895,12128,"from the trust fund zombies."],[13225,13355,"Let's see those observation skills."],[13709,13817,"Pick any color."],[13943,14084,"Black 15."],[14084,14293,"All on one number?"],[14293,14385,"Okay Vegas."],[17017,17150,"I'm pretty good, huh?"],[17150,17221,"Not bad."],[17250,17304,"Not bad."],[17317,17392,"Not bad."],[17609,17938,"A special gold chip for our sexy import."],[18126,18426,"No, don't touch that!"]],"7":[[16,125,"Don't touch that!"],[312,412,"Do you want it? Because you did"],[412,513,"pick the colour."],[583,713,"No..."],[917,1080,"Zoey chose black 15 to give"],[1080,1322,"Finn the win, but that gold chip is"],[1322,1397,"killer."],[1459,1605,"Don't believe me?"],[1605,1735,"Drop it in the aquarium"],[1735,1906,"and see what happens next."],[1931,2139,"You can always tell mercury poisoning"],[2139,2318,"by that slight blue shimmer."],[2581,2656,"Back off, klepto!"],[2656,2744,"It's his chip."],[2744,2952,"Is she actually trying to steal"],[2952,3044,"from him?"],[3086,3265,"That's so embarassing."],[3265,3403,"No, okay"],[3403,3541,"you guys don't understand, I -"],[3541,3699,"I am student body president"],[3699,3816,"and the one who organized this"],[3816,3933,"whole event. Of course I"],[3933,4041,"understand!"],[4041,4212,"He put the money down, so even"],[4212,4379,"if you chose the right color,"],[4379,4487,"he gets the winnings."],[4487,4713,"I warned you, she's only"],[4713,4821,"chasing the bag."],[4888,5034,"You know what?"],[5034,5288,"I didn't realize Broke Bitch"],[5288,5438,"was a sponsor!"],[5626,5730,"Good thing no one knows"],[5730,5930,"my mom got arrested for theft."],[5930,6139,"They'd really come after me then."],[6139,6256,"I'm not stealing from him."],[6327,6464,"I'm trying to save his life."],[6560,6752,"Girl, it's a poker chip, not poision."],[6752,6873,"It IS poison!"],[7082,7207,"I know that sounds crazy, but I can-"],[7207,7315,"I can prove it."]],"8":[[37,262,"No! You're ruining the vibe."],[262,433,"Finn, please."],[433,579,"Finn,"],[579,813,"just trust me, okay?"],[813,971,"I promise this is real."],[971,1259,"Zoey, if this poker chip can kill me,"],[1259,1409,"I honestly might deserve to die!"],[1672,1772,"I was right about the car in the"],[1772,1876,"crosswalk."],[1960,2189,"And I know I'm right about this."],[2189,2285,"Give up,"],[2285,2410,"tryhard!"],[2410,2523,"Finn doesn't believe you."],[2523,2619,"You've officially embarrassed"],[2619,2706,"yourself."],[2706,2894,"Congrats! Now leave before I drag"],[2894,3007,"you out."],[3028,3199,"That chip could kill Finn."],[3199,3328,"And I'm going to prove it."],[3457,3616,"She really won't give up, will she?"],[3616,3837,"Why do we even let her into this school?"],[3837,4137,"Being broke rots your brain."],[4195,4358,"She doesn't flinch, even with the whole"],[4358,4521,"room against her."],[4521,4721,"She's not like any other girl I've met."],[4721,4821,"Alright then,"],[4821,4917,"Could you show me?"]],"9":[[29,58,"Yeah."],[58,216,"Show us all how deadly this"],[216,358,"tiny circle is."],[367,567,"And when you fail, you have to be my"],[567,821,"personal slave until graduation."],[963,1051,"And if I'm right?"],[1051,1192,"Then I'll strip right now."],[1192,1359,"And you can have my one of a kind"],[1359,1493,"couture dress."],[1543,1714,"It'd go for at least $10,000"],[1714,1910,"at that trashy thrift shop of yours."],[1947,2047,"Good one."],[2047,2168,"Every gossip post predicting"],[2168,2331,"my future has been right."],[2331,2510,"It said I'd win mom's bail money here."],[2510,2640,"Maybe this is how?"],[2640,2790,"Okay, genius. Come on."],[2790,2886,"Come on show me."],[3966,4166,"Come on Gossip Godmother!"],[4166,4283,"Your posts about my future keep"],[4283,4396,"coming true!"],[4396,4521,"I'm betting everything on you"],[4521,4733,"being right again!"]],"10":[[3499,3599,"How did you?"],[3599,3695,"How did you know that was going to"],[3695,3899,"happen?"],[3962,4187,"The mercury plating shimmers blue in"],[4187,4262,"the light."],[4262,4433,"It killed the fish instantly."],[4433,4654,"Yeah. The ammonia from the tank,"],[4654,4954,"It set the mercury off. So."],[5005,5138,"It worked."],[5138,5330,"Holy Shit!"],[5330,5476,"Zoey was right."],[5476,5663,"I can't even believe it."],[5663,5697,"I'll"],[5697,5997,"I'll never doubt you again."],[6318,6506,"How long was I holding it?"],[6506,6589,"Oh, you'll be fine."],[6589,6727,"It was just a contact trace,"],[6727,6810,"so it won't hurt you."],[6810,7111,"But, I mean, if you held it longer."],[7115,7307,"Well, but you, you held it, too."],[7307,7536,"And you're much smaller than me."],[7724,7899,"I barely had it."],[7899,8033,"I'll be fine."],[8033,8078,"Don't worry."],[8078,8208,"Okay."],[8208,8308,"Alicia."],[8308,8470,"Zoey saved your ass."],[8470,8612,"I mean, if a royal got sick"],[8612,8742,"because of you."],[8742,8983,"Maybe we should listen to poor"],[8983,9117,"people more."],[9175,9296,"I didn't know, okay?"],[9296,9459,"I bought them online."],[9459,9509,"Fine."],[9509,9651,"But you did make a deal with Zoey."],[9651,9830,"And you do owe her your dress."],[9830,10130,"So hand it over."]],"11":[[283,383,"Come on Alicia."],[383,596,"Don't switch it up now."],[596,1322,"Take it off! Take it off!"],[1322,1463,"I'm student body president!"],[1463,1626,"I can't get naked at a school event!"],[1626,1839,"I'll never live this down."],[1897,2114,"Alicia was awful to me."],[2114,2314,"But I'm not a bully."],[2314,2552,"I can't go through with this."],[2552,2852,"Zoey doesn't need that used dress."],[2852,3015,"She gets bail money for mom with a bet that takes down the house. To get the green, bet on green."],[3015,3153,"with a bet that takes down the house. To get the green, bet on green."],[3153,3286,"house."],[3286,3603,"To get the green, bet on green."],[3816,4116,"No, no, just keep your dress,"],[4141,4287,"okay?"],[4287,4333,"Don't do that."],[4333,4592,"Just give me a thousand in chips."],[4592,4913,"That that dress is worth ten grand."],[4984,5100,"Why are you only taking a grand"],[5100,5171,"in chips?"],[5171,5284,"Ya know what?"],[5284,5463,"Maybe that's why she's poor."],[5463,5764,"She doesn't know how money works."],[5885,5997,"I'll earn double that."],[5997,6143,"Okay?"],[6293,6431,"Watch."],[6431,6589,"Trust me."],[6589,6694,"I do."],[7378,7524,"That's an impossible bet."],[7524,7707,"Ya, know what, she's delulu."],[7707,7870,"I mean, there's no way that ball is"],[7870,8049,"going to land in that little green square."],[8179,8466,"If it does hit the odds are,"],[8466,8596,"35 to 1."],[8767,9067,"I think I think she's got it."],[9196,9346,"If any of them knew I was trying"],[9346,9642,"to get bail money for my mom, they eat me alive."],[9734,9868,"Yeah."],[9868,10101,"Let it ride."]],"12":[[1167,1422,"Yes, yes!"],[1422,1543,"Did you see that?"],[1543,1605,"Oh my God!"],[1605,1780,"Never bet against Zoey!"],[1876,2089,"You cheated."],[2089,2277,"No I didn't, you literally dropped the"],[2277,2344,"ball yourself."],[2344,2452,"How would I cheat?"],[2452,2752,"If she was actually smart, she'd be rich."],[2773,2865,"But she's not."],[2865,3136,"She's poor."],[3136,3319,"Look, just give me the money and"],[3319,3407,"I'll go."],[3407,3486,"No!"],[3486,3645,"Not until you prove that you didn't"],[3645,3724,"cheat!"],[3724,3841,"I can't prove something"],[3841,3937,"I didn't do."],[3995,4129,"Make another bet."],[4129,4320,"If you win again, I'll back off."],[4320,4496,"My Gossip Godmother did say"],[4496,4654,"I can't lose,"],[4658,4817,"and every other prediction"],[4817,4959,"she's made has been right."],[5084,5384,"Okay, fine."],[5509,5663,"You choose the challenge"],[5663,5822,"and pick something you think requires"],[5822,5964,"more skilled then luck."],[6010,6181,"And I will win."],[6181,6381,"And you will give me the money."],[6381,6493,"Blackjack."],[6493,6719,"If you can even count to 21 that is."],[7353,7494,"Wait, wait, wait."],[7494,7653,"You want her to lose."],[7653,7782,"somebody, somebody else"],[7782,7862,"should deal."],[7887,7974,"Step aside."],[7974,8049,"Thank you."],[8767,9042,"So those cards are 18, right?"],[9042,9246,"And, she can't go over 21 to win."],[9338,9371,"Yes."],[9371,9547,"If she goes over 21 she loses."],[9547,9751,"And if the dealer gets closer to 21"],[9751,9901,"than she does she loses."],[10085,10285,"Hit, or stay?"],[10285,10443,"Of course she's gonna stay."],[10810,10915,"Wait."]],"13":[[275,446,"The game isn't over yet."],[446,709,"Time to hit it before you quit it."],[1146,1259,"Hit."],[1259,1376,"You can't be serious."],[1376,1589,"That is so risky."],[1589,1780,"Give me another card."],[3115,3299,"Oh, 20!"],[3299,3503,"He won."],[3503,3578,"Wait,"],[3578,3674,"not yet."],[3674,3770,"What?"],[3928,4070,"21."],[4204,4350,"I win."],[4733,4950,"$100,000."],[4950,5134,"All the money we raised..."],[5134,5326,"I am so dead!"],[5326,5472,"Mom's in jail because my"],[5472,5609,"douchey ex-boyfriend"],[5609,5684,"set her up."],[5789,5960,"Gossip Godmother led me here"],[5960,6097,"and gave me the chance to bail"],[6097,6151,"her out."],[6289,6560,"But I only need ten grand to do that."],[6831,7007,"Keep it."],[7007,7161,"Keep the money, I don't need all of it."],[7161,7378,"I just-"],[7557,7674,"I'll just take this."],[7674,7903,"Wait... really?"],[7903,8078,"Thank you."],[8220,8329,"I guess,"],[8329,8504,"Zoey's not as greedy as I thought."],[8521,8721,"She really needs the money"],[8721,8854,"more than us,"],[8854,9100,"and she's not taking it?"],[9100,9259,"Maybe now everyone will"],[9259,9401,"stop looking down on me."],[9642,9772,"Why don't you tell everyone"],[9772,9959,"what you're using that ten grand for?"],[9993,10306,"To bail your thief mother out of jail."]],"14":[[41,296,"Wait, what did you say?"],[296,487,"Zoey's mom is in jail?"],[579,821,"Oh, she didn't tell you?"],[821,963,"Her mom just got arrested"],[963,1322,"for stolen purses worth millions."],[1351,1497,"That's what the ten grand is for?"],[1497,1797,"To bail your criminal mother out of jail?"],[1881,2156,"You lost your mom, your house,"],[2156,2456,"and your man all in the same day."],[2498,2694,"There's a reason you're poor, Zoey."],[2694,2994,"You suck at life."],[3007,3115,"Well, I would rather be poor"],[3115,3249,"than be either one of you."],[3249,3465,"Oh, but do you want to be stupid?"],[3465,3603,"You gave back all your winnings."],[3603,3849,"How are you going to afford a lawyer?"],[3849,4037,"I don't need a lawyer."],[4037,4337,"My mom's innocent."],[4341,4425,"Wait,"],[4425,4617,"so you think you're just going to bail"],[4617,4825,"your mom out of jail and that's it?"],[4913,5100,"She's going to trial, bitch,"],[5100,5288,"and she's going to lose."],[5288,5467,"It's tragic how dumb you are."],[5467,5584,"Zoey's not dumb."],[5684,5955,"She saved my life twice today."],[5955,6106,"And she just won 100 grand"],[6106,6256,"on one round of blackjack."],[6302,6531,"Anyone can cheat at these games."],[6589,6710,"Especially if you're used to"],[6710,6890,"stealing from people."],[6906,7007,"I mean, Zoey would know a lot"],[7007,7140,"about that."],[7140,7294,"Apple doesn't fall far from the tree,"],[7294,7386,"does it?"],[7386,7549,"Zoey's mom is looking at life in"],[7549,7670,"prision, because she pissed off the"],[7670,7874,"wrong people."],[7874,8120,"Good thing Zoey got her ex to confess after"],[8120,8420,"winning one last game against Tiffany."],[8437,8625,"Time to kiss and tell."],[8625,8762,"Mom will go to jail for life"],[8762,8863,"unless I beat Tiffany"],[8863,9042,"at something?"],[9096,9196,"Gossip Godmother has proven"],[9196,9342,"she can see the future,"],[9342,9530,"so I have to believe her now."],[9530,9563,"Fine."],[9772,10014,"I'm such a loser..."],[10014,10110,"yeah?"],[10110,10281,"Prove it."],[10281,10443,"Try to beat me."],[10443,10589,"I'll even let you pick the game."]],"15":[[33,150,"You think I'm such a loser."],[150,387,"Okay, let's make a bet."],[387,538,"You pick the game, see if you can"],[538,684,"beat me."],[754,884,"If I win."],[884,988,"Micah."],[988,1121,"You call the cops, you turn yourself in"],[1121,1272,"and tell everyone that you framed"],[1272,1338,"my mom."],[1397,1501,"Okay?"],[1501,1722,"And what do you have to offer if"],[1722,1805,"I win?"],[1805,2010,"Oh, spoiler."],[2010,2310,"Nothing."],[2389,2510,"I'll drop out."],[2510,2615,"You'll never see me again."],[2694,2756,"Zoey!"],[2756,2844,"No, don't."],[2844,2982,"Don't let her get in your head."],[2982,3098,"She's not worth risking your"],[3098,3157,"future over."],[3157,3232,"It's fine."],[3232,3420,"I got this. Just trust me."],[3420,3770,"You said I can pick anything I want?"],[4070,4300,"I pick"],[4496,4796,"a kissing contest."],[4829,5013,"It's a perfect practice for a"],[5013,5130,"prude like you."],[5238,5480,"And about the purses."],[5480,5759,"I'm the one who put Micah up to it."]],"16":[[108,308,"A kissing contest?"],[308,458,"A kissing contest"],[458,608,"I'll do whatever I have to do to take"],[608,738,"this bitch down."],[804,975,"We need a game where skill matters."],[975,1209,"And Zoey can't cheat."],[1209,1518,"I'm proposing we blindfold three guys."],[1518,1693,"Zoey and I will take turns kissing"],[1693,1818,"all three."],[1818,2014,"They choose which one's the best."],[2014,2185,"Winner takes all."],[2185,2339,"Tiffany's right."],[2339,2494,"That bitch can't cheat at a"],[2494,2610,"kissing game."],[2610,2786,"I understand if you're scared,"],[2786,2890,"okay?"],[2890,3119,"I mean, no one expects a virgin"],[3119,3244,"to know what they're doing."],[3370,3470,"Don't do it."],[3470,3624,"Tiffany's experienced."],[3624,3741,"It's not a fair fight."],[3741,3878,"Exactly."],[3878,4049,"Gossip godmother said I have to go"],[4049,4195,"against Tiffany to free my mom."],[4229,4325,"When someone proves"],[4325,4471,"they can see your future,"],[4471,4533,"you listen."],[4533,4583,"You're on."],[4717,4800,"Zoey, you,"],[4800,4909,"you don't have to do this."],[4909,5063,"One call and I can have your mother"],[5063,5138,"released right now."],[5138,5263,"No. Having her released isn't"],[5263,5380,"enough."],[5380,5547,"I need to clear her name."],[5547,5634,"And the only way to do"],[5634,5834,"that is for the real villain to step"],[5834,5872,"forward."],[5922,6089,"You're royalty."],[6089,6281,"Why are you helping her?"],[6281,6481,"Okay, she's a purity pledge."],[6481,6623,"If you insult her one more time,"],[6623,6798,"I will have you banned from my country."],[6886,6948,"It's okay."],[7336,7436,"I got this."],[7436,7640,"The win is mine."],[7640,7782,"Well, then let me back"],[7782,7941,"you with my own bet."],[8012,8204,"If you win,"],[8204,8504,"I'll take you on a date."]],"17":[[33,333,"Finn! Her mom is in jail."],[367,542,"Think about your family's reputation."],[542,617,"No, I believe Zoey."],[617,855,"Her mother is innocent."],[855,1005,"And honour matters more than"],[1005,1155,"reputation."],[1251,1401,"So, who are the guys you'll"],[1401,1551,"be kissing?"],[1593,1893,"I pick Micah."],[1926,2156,"I pick Finn."],[2156,2344,"I approve."],[2344,2498,"And for"],[2498,2560,"third..."],[2694,2798,"You."],[3148,3265,"Consider this your lucky night,"],[3265,3449,"big boy."],[3903,4095,"The rules are simple."],[4095,4262,"Zoey and I will kiss Micah,"],[4262,4416,"but he won't know in which order."],[4491,4583,"And then he'll choose which one"],[4583,4717,"he likes better."],[4783,4904,"Obviously me."],[5739,5885,"Then on to Tate."],[6168,6277,"Then on to Finn."],[6594,6702,"Got it?"],[6702,6873,"Okay, Gossip Godmother, you've"],[6873,6981,"told me what move"],[6981,7111,"to make every step of the way"],[7111,7282,"and it's gotten me this far."],[7332,7557,"So, how do I win this?"],[7691,7991,"Give Micah a bite, Tate a quick taste."],[7991,8141,"And Finn?"],[8141,8308,"He's already half in love, so"],[8308,8454,"just let the chemistry speak"],[8454,8537,"for itself."],[8600,8796,"Tiffany will try to steal the win"],[8796,8988,"with a threat, but it all comes out"],[8988,9246,"once the blindfolds are off."],[9300,9476,"I know how to win and save my mom!"],[9718,9897,"Time for round one, bitch."]],"18":[[1376,1505,"Okay!"],[1505,1668,"Go girl!"],[2506,2806,"Micah likes a bite."],[4212,4329,"Well, Micah."],[4329,4542,"Who do you pick?"],[4975,5092,"What the hell!"],[5092,5234,"How is that even possible?"],[5234,5405,"Oh, looks like your body count is high,"],[5405,5534,"but your skill level's low."],[5801,6014,"How could Micah not choose me?"],[6014,6097,"Clearly, I've been"],[6097,6272,"underestimating this brat."],[6272,6468,"Time to fight dirty."],[6685,6911,"Game's not over yet, bitch."],[6911,7094,"Round two."],[8220,8387,"Tate only wants a taste."],[8508,8637,"I'll keep this quick."],[9759,9884,"What an amature."],[11436,11590,"Pick two, or I'll tell everyone that your"],[11590,11745,"family went BROKE!"],[12629,13021,"Well Tate, who do you pick?"]],"19":[[33,333,"Well, Tate, who do you pick?"],[796,1126,"Was my Gossip Godmother wrong?"],[1230,1388,"Now it's your turn."],[4675,5000,"My turn, bitch!"],[6765,6815,"Number one."],[6815,6927,"Number one, I choose number"],[6927,7007,"one."],[7953,8254,"How bad of a kisser is Tiffany?"],[8304,8429,"She picked this challenge to"],[8429,8554,"embarrass Zoey, but got totally"],[8554,8754,"humiliated instead."],[8871,9067,"Finn didn't even kiss me."],[9067,9217,"It doesn't count."],[9217,9334,"She cheated!"]],"20":[[29,233,"Finn didn't even kiss me."],[233,371,"It doesn't count."],[371,513,"She cheated."],[513,667,"He did turn his head away."],[763,809,"Wait."],[825,1126,"So if Zoey cheated,"],[1142,1443,"that means Tiffany won by default."],[1455,1584,"The only way Zoey could win is"],[1584,1722,"by cheating."],[1722,1881,"Really?"],[1881,2181,"Because my kiss is the one you picked."],[2206,2302,"Just admit it."],[2302,2423,"Zoey."],[2423,2565,"You and Finn had some secret"],[2565,2698,"code so he knew it was you."],[2819,2961,"Finn turned his head away"],[2961,3036,"from me."],[3036,3190,"Why else would he do that?"],[3190,3490,"Zoey's a dirty little cheater."],[3536,3803,"I say we kick her out of the school."],[3803,3974,"Yeah!"],[3974,4241,"You heard them, you piece of trash."],[4241,4446,"You lost the bet, so you have to"],[4446,4542,"disappear."],[4879,4984,"Actually, Tiffany is the one who"],[4984,5105,"cheated!"]],"21":[[154,287,"Actually, Tiffany's the one who"],[287,433,"cheated."],[492,633,"Shut your mouth nerd before I"],[633,734,"start talking."],[779,1005,"What does she mean by that?"],[1005,1255,"Tiffany threatened me."],[1255,1555,"She whispered, if I didn't choose her,"],[1580,1718,"she would reveal to everyone"],[1718,1864,"that my family"],[1864,1914,"went broke."],[1985,2256,"Tate's poor?"],[2256,2410,"Yeah."],[2410,2623,"I'm poor."],[2623,2869,"and I'm not ashamed anymore!"],[2869,3169,"Zoey owns who she is."],[3203,3465,"So should I."],[3465,3645,"Looks like you're the loser after all."],[3749,3916,"And I would have won every single"],[3916,4070,"round if you hadn't cheated."],[4129,4521,"Oh my God, Tiffany is such a bad kisser"],[4521,4838,"that she had to blackmail"],[4838,4979,"Tate to pick her."],[5009,5142,"And her breath stinks."],[5142,5238,"Oh my God."],[5355,5463,"I'm richer."],[5463,5680,"And Micah wanted me more than you."],[5680,5980,"Oh, well speaking of Micah..."],[6014,6256,"Micah, it's time to confess."],[6256,6406,"And get my mom out of jail."]],"22":[[900,1130,"I'm calling to turn myself in."],[1130,1234,"I was the one who put the"],[1234,1363,"stolen handbags in the Whitmore thrift"],[1363,1455,"shop."],[1651,1718,"Okay."],[1885,2035,"I have to go in for questioning."],[2060,2114,"But..."],[2218,2348,"They're gonna release your mom."],[2477,2565,"Hope you're a better boyfriend to"],[2565,2665,"your cellmate than you ever were to"],[2665,2740,"me."],[2740,2965,"Just because your mom got released,"],[2965,3199,"doesn't