3,"More like royal ass."],[4829,4988,"We need to talk in private."],[4988,5105,"Zoey, you're not going with"],[5105,5221,"him anywhere."],[5321,5501,"Okay, Jax, look, whatever you have to"],[5501,5547,"say to me,"],[5547,5847,"you can say to me right here, okay?"],[6243,6356,"What?"],[6527,6610,"Oh, Jax!"],[6610,6727,"Oh my God!"],[6727,6756,"Hey!"],[6856,6944,"Follow me,"],[6944,7107,"and it's you verse my guys."],[7294,7378,"British prick."],[7482,7686,"Jax put me down!"]],"25":[[0,154,"Jax put me down!"],[225,379,"Jax, stop it!"],[379,542,"What are you doing?"],[563,729,"Hey! Hey, I don't appreciate that,"],[729,1026,"like, caveman routine back there."],[1026,1134,"What was that?"],[1134,1284,"You didn't mind when we were kids."],[1555,1755,"I don't have time for this."],[2081,2260,"I heard your mom got arrested."],[2515,2644,"She was framed."],[2644,2815,"Yeah?"],[2831,2932,"Well, my dad gave her something to"],[2932,3065,"hold on to."],[3190,3432,"And I can't let you go until I get"],[3432,3503,"it back."],[3641,3778,"Are you threatening me?"],[4045,4295,"Depends."],[4400,4533,"Can you be a good girl"],[4533,4829,"and give me what I want?"],[5734,5834,"Is it kidnapping"],[5834,6068,"if you want him to tie you up?"],[6072,6264,"Either way, Zoe saves the day"],[6264,6406,"when she reveals someone's"],[6406,6589,"been using Jax's nut allergy to"],[6589,6706,"poison him."],[6844,7098,"Someone's been poisoning Jax?"],[7098,7257,"Everything Gossip Godmother has told"],[7257,7374,"me happened just like she said!"],[7411,7540,"So, it must be true."],[7711,7878,"I can save your life."],[7878,8012,"But you need to let me go."],[8020,8266,"This one needs to learn some respect."],[8266,8437,"I say we teach her the hard way."],[8554,8721,"Let her go."],[9184,9392,"What, is private school that fancy?"],[9392,9693,"You a doctor now?"],[9693,9797,"Let me guess. Has it been hard to"],[9797,9914,"breath lately?"],[9972,10118,"Maybe a little itchy in the back of"],[10118,10272,"your throat?"],[10276,10356,"What if it has?"],[10356,10539,"Then I can help you."],[10539,10710,"But if I do, then you let me go."],[10710,10769,"Okay."],[10769,11069,"Deal?"],[11311,11507,"Show me."],[11507,11599,"I don't like liars,"],[11599,11720,"so you better not be playing me."]],"26":[[37,337,"I'm not lying."],[362,529,"Okay, I need to check"],[529,658,"your breathing."],[713,850,"If you wanted to put your hands on me,"],[850,925,"you could have just asked me."],[925,1096,"It's medical!"],[1096,1267,"You are an idiot."],[1326,1484,"Boss, she's playing you. Don't-"],[1484,1785,"-You two. Car. NOW."],[1847,1981,"She was with a Hawthorne."],[1981,2143,"I said go."],[2806,2894,"Why do you hate Finn's family"],[2894,3107,"so much?"],[3169,3253,"They blamed a robbery on"],[3253,3415,"my cousin."],[3415,3507,"And when the Hawthornes point,"],[3507,3666,"everyone listens."],[3666,3933,"That's not Finn."],[3933,4045,"Okay? You don't know him."],[4045,4346,"I'm not here to talk about him."],[4537,4838,"Check my breathing."],[4896,5084,"Okay."],[5230,5367,"He's wheezing."],[5367,5568,"Gossip Godmother was right."],[5568,5701,"Jax, you're sick."],[5701,5814,"Something's wrong."],[5814,5855,"Okay."],[5855,6156,"I think I can help you."],[6277,6577,"I like this dress..."],[6581,6660,"But I think it would look better on"],[6660,6856,"my floor."],[6856,7019,"Okay, umm..."],[7019,7169,"So life or death,"],[7169,7469,"and you're still shooting your shot."],[7570,7695,"If you heal me,"],[7695,7774,"you can go free."],[8028,8329,"But if you fail me,"],[8345,8646,"you stay the night with me."]],"27":[[125,367,"That's a deal with the devil."],[367,633,"I've been called worse."],[633,934,"It's your only option."],[1197,1497,"You have a nut allergy, right?"],[1543,1743,"Yeah. Why?"],[1743,1843,"Someone's been slipping"],[1843,2039,"something into your food."],[2039,2143,"Enough to weaken you,"],[2143,2339,"but not enough for you to notice."],[2360,2602,"Breathe again for me."],[3115