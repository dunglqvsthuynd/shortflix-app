I didn’t knock enough sense"],[3178,3403,"into that dense ass head of yours."],[3457,3611,"If you fuck with Maddie,"],[3611,3728,"you’re fucking with me!"],[3828,3924,"I’m gonna tell Coach."],[3974,4154,"Yeah, yeah, you’ll get kicked off"],[4154,4291,"the team for trying to hurt me."],[4337,4521,"The backup quarterback?"],[4521,4587,"What?"],[4646,4717,"I don’t think so."],[4717,4796,"Breaking News."],[4796,4963,"The new starting quarterback"],[4963,5092,"of Central University Knights,"],[5096,5271,"Cameron Carter is seen"],[5271,5430,"in a rough, one-sided"],[5430,5576,"physical altercation"],[5584,5822,"with former starting QB,"],[5822,5930,"Brett Pierson,"],[5930,6089,"here on this campus parking lot."],[6164,6281,"What the hell did he call me?"]],"21":[[75,171,"Oh my God."],[246,346,"Now, Cameron Carter"],[346,446,"and the news"],[446,504,"are gonna see me"],[504,621,"living in my car."],[658,696,"What the hell"],[696,817,"did he call me?"],[2289,2485,"Mr. Carter? Hello? Mr. Carter."],[3153,3203,"Mr. Carter,"],[3203,3286,"is this your girlfriend?"],[3286,3370,"Is she the reason"],[3370,3482,"why you and Mr. Pierson"],[3482,3553,"have bad blood?"],[3603,3745,"Alright, everybody."],[3820,3966,"This is Maddie Malone."],[3966,4062,"She’s a cheerleader here"],[4062,4204,"at Central University,"],[4204,4279,"and she is the most"],[4279,4416,"important person in my life."],[4533,4637,"And I'm here hoping"],[4763,4859,"that she would become"],[4859,4929,"my girlfriend."],[4984,5184,"Starting with this."],[5280,5447,"Cameron, I can't..."],[5447,5572,"I can't possibly..."],[5572,5622,"Maddie, I know"],[5622,5705,"you barely know me,"],[5705,5801,"but I transferred"],[5801,5901,"to Central University"],[5901,6018,"so that you will."],[6114,6193,"Cameron."],[6218,6277,"Maddie,"],[6385,6493,"will you be my girlfriend?"]],"22":[[0,79,"Alright, everybody."],[79,150,"Thank you."],[150,233,"Can you give us some space?"],[525,671,"Hi, Mrs. Carter."],[734,846,"This is Veronica."],[921,963,"Yeah,"],[963,1067,"Trent's daughter."],[1117,1151,"Listen,"],[1151,1201,"you might want to"],[1201,1322,"watch the news."],[1322,1413,"Cameron seems to"],[1413,1505,"have gotten himself"],[1505,1584,"into trouble."],[1651,1735,"Don't worry,"],[1805,1939,"I know how to fix it."],[2060,2131,"Let's meet up"],[2131,2181,"before this"],[2181,2281,"gets any worse."],[2640,2686,"I don't know"],[2686,2802,"what Cameron Carter"],[2802,2890,"sees in you, Maddie,"],[2952,3086,"but I'm taking him from you."],[3111,3253,"Just like I took Brett."],[3632,3749,"That was crazy."],[3749,3837,"I don't understand"],[3837,3874,"why you would"],[3874,3937,"do that for me,"],[3937,4029,"but it was a"],[4029,4229,"hell of a show."],[4233,4396,"Here."],[4396,4567,"Thank you."],[4567,4688,"Mads."],[4688,4800,"That wasn't a show."],[4888,4984,"Yeah, right!"],[4984,5071,"Cameron Carter,"],[5071,5155,"football prodigy,"],[5155,5217,"in love with"],[5217,5309,"Maddie Malone,"],[5309,5401,"nobody cheerleader"],[5401,5538,"who lives in her car."],[5538,5609,"Hey."],[5784,5901,"You're not a nobody."],[5901,5976,"Alright?"],[6106,6202,"Oh. You're serious?"],[6360,6418,"But why?"],[6418,6548,"We've just met."],[6614,6702,"Maybe to you."],[6810,6898,"What do you mean?"],[7298,7386,"Mads, I think it's time"],[7386,7482,"I tell you the truth."],[7520,7603,"The truth?"],[7649,7732,"Let me show you."],[7807,7878,"Okay?"],[7899,7982,"But first..."],[8116,8183,"I’m going to go put my"],[8183,8258,"new jersey"],[8258,8400,"in my new locker room."]],"23":[[946,1067,"You..."],[1126,1267,"you live here?"],[1267,1422,"I know it’s not much, but"],[1451,1526,"It’s the best I could find"],[1526,1605,"on short notice."],[1605,1810,"You call this not much?"],[1872,2002,"This is like the nicest place"],[2002,2131,"I’ve ever seen."],[2152,2310,"Well, thank you, I’m glad you think so."],[2531,2686,"Why did you bring me here?"],[2915,3057,"When we grow up, Mads,"],[3065,3165,"I’m gonna get you a house..."],[3232,3349,"this big."],[3461,3591,"We’ll have our own rooms."],[3620,3691,"Mine will be blue."],[3703,3816,"Mine will be pink."],[3845,3991,"Yeah, pink."],[3991,4116,"With an ice cream machine."],[4154,4320,"All-you-can-eat ice cream!"],[4446,4517,"Because I promised"],[4517,4587,"you a home."],[4604,4667,"And I can finally"],[4667,4750,"give one to you."],[4792,4875,"Oh, sorry."],[4904,5021,"I was thinking that maybe,"],[5021,5130,"and no pressure,"],[5180,5430,"but I was thinking maybe you could"],[5438,5518,"stay here."],[5588,5668,"With me."],[5764,6047,"You mean, like move in with you?"],[6147,6339,"Yeah, that’s exactly what I mean."]],"24":[[116,279,"We hardly know each other."],[404,496,"Mads..."],[529,654,"That’s not true."],[738,971,"We stayed the night together last night..."],[1034,1142,"You saw me."],[1818,1993,"You saw plenty of me actually -"],[1993,2114,"Oh, oh, Cameron."],[2306,2414,"Mads. Hey, Mads."],[2423,2652,"I’ve thought this through, okay?"],[2660,2806,"You need a place to stay."],[2806,2927,"And I have this whole place"],[2927,2986,"to myself."],[2990,3090,"It makes sense."],[3182,3420,"And what are going to tell people?"],[3453,3561,"I mean, as far as they’re concerned,"],[3561,3670,"we’re the next Taylor Swift"],[3670,3795,"and Travis Kelce. So...."],[3962,4054,"Come on, Mads."],[4062,4195,"Every single thing I’ve seen you do"],[4195,4300,"has been for someone else."],[4354,4437,"Don’t you think it’s time to do"],[4437,4500,"something for yourself"],[4500,4571,"for a change?"],[4587,4700,"Thank you, Cameron, but..."],[4783,4954,"I can’t possibly afford the rent"],[4954,5021,"to a place like this."],[5021,5105,"Whoa!"],[5134,5280,"Who said anything about rent?"],[5355,5422,"Huh?"],[5472,5534,"Look."],[5593,5722,"I’m new to the city, alright?"],[5726,5826,"And I’m the star player."],[5826,5918,"I get busy."],[6081,6139,"And I get lonely."],[6256,6327,"So..."],[6348,6535,"I just want a roommate, okay?"],[6639,6798,"I just...I don’t understand."],[6798,6931,"Why are you doing all of this"],[6931,7094,"for someone you just met?"],[7148,7257,"Mads, we didn’t just meet."],[7374,7449,"What?"],[7457,7682,"I brought you here, because..."],[7882,8024,"I need to tell you that..."],[8116,8249,"Cam Cam!"]],"25":[[12,120,"Are you in there?"],[425,525,"I’ve been calling!"],[563,629,"Mom?"],[817,863,"Mom?"],[875,967,"Why haven’t you answered"],[967,1021,"your phone?"],[1063,1192,"I guess I haven’t been checking it."],[1192,1284,"What are you doing here?"],[1368,1551,"I just wanted to see you. That’s all."],[1564,1685,"Everyone’s been very..."],[1772,1914,"shocked by your..."],[1943,2135,"big decision to transfer."],[2135,2231,"Looks like your maid could"],[2231,2364,"use a little more attention to detail,"],[2364,2398,"darling."],[2481,2540,"Maid?"],[2565,2740,"This is Maddie. She’s not my maid."],[2815,2927,"It’s a pleasure to meet you."]],"26":[[25,120,"Maddie..."],[129,158,"Maid..."],[158,246,"What's the difference?"],[246,342,"Mom!"],[383,492,"What is your problem?"],[538,717,"My problem here, Cam,"],[717,796,"is that you ditched"],[796,888,"years of planning"],[888,1080,"and a perfectly good opportunity"],[1109,1272,"just to chase after some girl."],[1301,1422,"She’s not just some girl."],[1497,1576,"Okay?"],[1755,1864,"Maddie’s my girlfriend."],[2002,2097,"Girlfriend?"],[2177,2268,"Maddie, is it?"],[2348,2506,"Yes, ma'am."],[2548,2640,"Cameron, I left my"],[2640,2744,"reading glasses in the car."],[2752,2806,"Would you be a dear"],[2806,2873,"and get them for me?"],[2898,2973,"No..."],[2973,3065,"Cameron. It’s..."],[3132,3232,"It's fine."],[4850,4921,"I want you to know"],[4921,4979,"that I see"],[4979,5105,"right through you."],[5255,5351,"Excuse me?"],[5351,5522,"Just another broke college girl"],[5522,5722,"trying to get her claws into my son."]],"27":[[33,83,"No."],[83,179,"No, that's not"],[179,262,"what's happening here."],[262,412,"He's, he’s just helping me out."],[446,496,"Oh!"],[554,709,"I’m sure he's helping you."],[775,913,"Cameron's been through a lot."],[921,1059,"And he has a big heart"],[1059,1126,"for girls like you."],[1126,1213,"But I will be damned"],[1213,1305,"if I let my son"],[1305,1397,"get weighed down"],[1397,1530,"with a ghetto piece of crap"],[1530,1647,"when he has an NFL future"],[1647,1705,"ahead of him."],[1785,1889,"Maybe we should wait"],[1889,2043,"for Cameron to explain."],[2081,2185,"Did you hear me?"],[2256,2356,"Whatever the two of you"],[2356,2456,"have going on,"],[2552,2648,"it is over."],[2702,2761,"Today."],[2777,2961,"With all due respect,"],[2990,3169,"Cameron is an adult."],[3169,3290,"He can make his own decisions."],[3424,3516,"You know, when he told me"],[3516,3561,"that he wanted"],[3561,3678,"to transfer to Central,"],[3678,3712,"I thought"],[3712,3874,"that was a foolish idea."],[3924,4079,"But it turns out,"],[4079,4233,"that was just you."],[4233,4300,"And I'm here"],[4300,4375,"to fix that."],[4425,4475,"What?"],[4542,4592,"How?"],[4763,4838,"Mom?"],[4913,4984,"Mom."],[5171,5355,"Mom, can you please explain"],[5355,5430,"why she was waiting"],[5430,5497,"in your car?"],[5555,5601,"Hi, Maddie."]],"28":[[112,250,"What is she doing here?"],[304,396,"I invited her."],[408,479,"Why?"],[617,742,"Look, I know you like to help"],[742,875,"the less... fortunate."],[913,1096,"But you need to be making decisions"],[1096,1209,"that are best for the family."],[1309,1459,"After all, if it wasn’t for us,"],[1459,1705,"you’d still be rotting in the orphanage."],[1768,1864,"I don’t think you understand"],[1864,1968,"what you’re doing right now."],[1968,2052,"You’d better watch it!"],[2081,2273,"You are to marry Veronica."],[2364,2494,"Engaged within the week."],[2635,2727,"That should cover up"],[2727,2873,"whatever it was the two of you did there"],[2873,2948,"quite sufficiently."],[2977,3069,"Can’t you just imagine"],[3069,3228,"how beautiful and rich"],[3228,3336,"our babies will be?"],[3382,3503,"Babies?"],[3503,3666,"I thought you were with Brett now."],[3824,3974,"I ended that yesterday."],[3999,4091,"I do not date"],[4091,4204,"backup quarterbacks."],[4308,4537,"So, Veronica has informed me"],[4537,4688,"that there is a football banquet"],[4688,4733,"this evening,"],[4733,4838,"and get this."],[4879,5030,"She has agreed to be your date."],[5071,5226,"We’re gonna look so good together."],[5288,5430,"My daddy owns the best boutique"],[5430,5563,"in the city for custom suits."],[5634,5718,"How do you guys feel"],[5718,5847,"about emerald green?"],[5951,6001,"You’re gonna have to"],[6001,6085,"find someone else."],[6085,6177,"What? Why?"],[6393,6519,"Because I already have a date."],[6619,6685,"Wait."],[6723,6806,"Does he mean..."],[6944,7007,"Maddie."],[7069,7140,"Me?"]],"29":[[279,354,"Maddie?"],[354,417,"Yes!"],[433,504,"Cameron Carter!"],[504,696,"You are not bringing some stray"],[704,754,"to the party of your future-"],[754,863,"A stray?"],[913,1051,"Kind of like me, huh?"],[1121,1263,"Or did you forget or do you simply"],[1263,1372,"just not want to remember?"],[1372,1418,"Cameron."],[1418,1614,"Or because before I was your Cameron"],[1614,1780,"I was also a stray?"],[1914,2039,"And don’t you forget"],[2039,2189,"that I’m the star player here."],[2485,2540,"Come on, Maddie."],[2540,2644,"Let’s get out of here."],[3115,3211,"We’re..."],[3361,3495,"going shopping in your new car."],[3586,3712,"We’ve got a banquet to attend."],[3757,3862,"What?"],[4696,4788,"After the banquet,"],[4846,4959,"I’ll tell her everything."]],"30":[[967,1113,"Hey, Cameron!"],[1113,1146,"Over here."],[1146,1192,"Come on."],[1238,1301,"Go."],[1301,1405,"I'll meet you over there."],[1939,2081,"Happy to be a part of the team."],[2573,2711,"Are you fucking kidding me?"],[2719,2840,"Are you checking her out?"],[2886,2998,"Calm down, dude."],[2998,3128,"Not checking her out."],[3128,3290,"Did you just call me dude?"],[3319,3507,"I need a fucking drink."],[4012,4124,"What a fucking bitch."],[4195,4308,"She thinks she's the shit now"],[4308,4400,"just because she’s clinging"],[4400,4500,"on to Cameron."],[4546,4708,"Boy, if I don't ruin her tonight."],[4808,4875,"She thinks she can"],[4875,5075,"just take what I want."],[5155,5288,"Not tonight."],[5309,5509,"I'm Veronica fucking Steele."]],"31":[[54,145,"What you on about?"],[183,333,"She’s not going to take what you want."],[383,513,"I'm right here, baby."],[513,713,"Just shut up, Brett."],[971,1088,"Shut up, Brett!"],[1284,1355,"You shut up."],[1509,1572,"Maddie."],[1768,1872,"I love this song."],[2248,2344,"Maddie Malone."],[2431,2573,"Will you have this dance with me?"],[2610,2794,"Of course, Cameron Carter."],[3278,3328,"Mads,"],[3328,3445,"you’re the most gorgeous girl"],[3445,3490,"here tonight."],[6406,6544,"Aww!"],[6940,7002,"Dance with me,"],[7002,7152,"you stupid jock."],[7278,7344,"Fine."],[7920,7987,"Chill."],[8141,8208,"Ow!"],[8600,8666,"Ahh!"],[8746,8812,"Haha!"]],"32":[[25,104,"Haha!"],[333,412,"Shit."],[412,521,"I'm sorry."],[746,817,"What was that?"],[892,996,"Who knows?"],[1030,1109,"Who cares?"]],"33":[[133,216,"Alright everybody, everybody."],[216,346,"Hey, hey, remain calm!"],[350,471,"We’re just gonna head to the exits,"],[471,525,"alright?"],[1267,1434,"That was crazy!"],[1443,1547,"What was that?"],[1547,1739,"I didn’t even smell smoke or see fire."],[1743,1814,"I don’t know."],[2072,2243,"You are soaking wet."],[2310,2381,"I mean..."],[2431,2515,"So are you."],[2961,3123,"You know, Mads."],[3186,3332,"I, uh..."],[3528,3666,"Shut up and kiss me."]],"34":[[112,204,"Mads..."],[225,279,"Shh."],[287,458,"Mads, Maddie..."],[462,533,"What?"],[558,617,"I don’t think we"],[617,717,"should be doing this."],[767,809,"Why?"],[1134,1167,"Oh my god,"],[1167,1301,"you don’t actually want me."],[1305,1397,"No! No, no."],[1401,1534,"All I want is you, but..."],[1647,1747,"You know what?"],[1826,1918,"Nevermind."],[2181,2389,"There’s something he’s not telling me."],[2452,2627,"What does he want with me?"],[2886,2982,"I do want you..."],[3011,3136,"It doesn't feel right"],[3136,3211,"when you don't remember"],[3211,3265,"who I am."],[3303,3361,"And you don't remember"],[3361,3486,"how much you mean to me."]],"35":[[1664,1793,"Well, hey, Maddie."],[1851,1889,"I see you're"],[1889,2047,"just as clumsy as ever."],[2356,2481,"You better be careful."],[2510,2631,"You don't have a big,"],[2631,2769,"strong man"],[2769,2873,"like me around anymore"],[2873,2961,"to protect you."],[3007,3069,"Right."],[3107,3186,"As if you're not"],[3186,3269,"the exact thing"],[3269,3332,"that I need to be"],[3332,3432,"protected from."],[4037,4154,"What did you say to me?"],[4320,4437,"You never would have dreamed of"],[4437,4487,"saying something like that to me."],[4546,4633,"Yeah."],[4704,4833,"Well, I was scared of you."],[4884,4954,"And I was scared"],[4954,5063,"because I cared."],[5125,5271,"I don't anymore."],[5326,5426,"Please move."],[5613,5718,"You're going to come back."],[5839,5960,"Cameron Carter?"],[5989,6093,"He's just intrigued by this"],[6093,6164,"little orphan act"],[6164,6243,"that you got going on."],[6243,6410,"Much like I was."],[6619,6744,"And one day,"],[6744,6844,"he’s gonna get sick of you."],[6902,6965,"Brett?"],[7057,7127,"What's going on here?"]],"36":[[4,62,"Hey!"],[237,400,"I was just telling Maddie here that,"],[462,529,"I’m with you now."],[1034,1134,"Brett and I are entering"],[1134,1234,"the Campus Clash"],[1234,1363,"charity competition together."],[1405,1484,"People are even saying"],[1484,1614,"we’re the new power couple."],[1639,1751,"Like Taylor and Travis."],[2181,2243,"Okay."],[2448,2515,"You know,"],[2515,2698,"if Cameron was truly with you"],[2706,2873,"he would’ve told you about it."],[2994,3086,"Unless, of course,"],[3132,3278,"he’s embarrassed to be seen with you."],[3903,3999,"We’ll..."],[4062,4170,"We’ll attend."],[4291,4375,"Hmm?"],[4437,4650,"I didn’t see your name on the roster."],[4688,4842,"And sign-ups over."],[4896,4971,"I’m pretty sure they can"],[4971,5046,"make an exception for"],[5046,5171,"the starting quarterback."],[5213,5422,"You are the backup now, right?"],[5663,5722,"Hey. Shut up."],[6206,6314,"I guess we’ll see about that."],[6627,6769,"Come on, what are you doing?"],[7073,7194,"You better keep your mouth shut"],[7194,7248,"about what I said"],[7248,7369,"at Cameron’s yesterday."],[7507,7611,"Can’t you just imagine"],[7611,7753,"how beautiful and rich"],[7753,7887,"our babies will be?"],[7924,8053,"Babies?"],[8053,8204,"I thought you were with Brett now?"],[8316,8404,"I do not date"],[8404,8533,"backup quarterbacks."],[8696,8808,"One word"],[8808,8933,"and you’re dead."],[9705,9793,"Now, I just have"],[9793,9918,"one problem."],[9918,9984,"I haven't even"],[9984,10072,"spoken to Cameron"],[10072,10143,"since last night,"],[10143,10331,"and I'm 99% sure"],[10331,10414,"that he has no idea"],[10414,10573,"that the Campus Clash competition"],[10573,10673,"even exists."]],"37":[[646,725,"What the hell, Carter?"],[804,863,"Think you can just"],[863,963,"show up on campus..."],[1005,1126,"copy all my moves..."],[1184,1305,"take Maddie..."],[1317,1438,"take my starting job..."],[1493,1614,"now, the Campus Clash?"],[1622,1676,"Hmm?"],[1718,1789,"The what?"],[1964,2139,"Come on man, don’t act stupid with me."],[2177,2293,"It’s the Campus Clash!"],[2377,2439,"Maddie said you guys"],[2439,2515,"are entering together."],[2711,2844,"She did, did she?"],[2998,3103,"Me and Veronica are supposed to be"],[3103,3257,"the favorites to win this year."],[3340,3461,"Is she not mad at me anymore?"],[3545,3641,"She said she signed us up?"],[3666,3757,"No shit?"],[3807,3883,"So, she just..."],[3908,3995,"She lied?"],[4087,4241,"To make me jealous."],[4241,4312,"No."],[4379,4491,"All I know is Maddie and I"],[4491,4604,"are gonna kick your ass."],[4967,5167,"So, you better fucking watch it."],[5413,5501,"What are you guys looking at?"]],"38":[[154,237,"Hey, Carter!"],[258,383,"Some girl’s looking for you."],[792,913,"Hey, hit the weights."],[1172,1284,"The campus clash, right?"],[1284,1393,"Look. I know should have"],[1393,1493,"asked you first, but"],[1493,1568,"Veronica was there!"],[1568,1685,"And Brett was acting like a jerk."],[1685,1735,"I just..."],[1764,1847,"I wanted to wipe that"],[1847,2002,"stupid smirk off of his face."],[2056,2106,"I'm sorry."],[2106,2168,"You don’t have to do it."],[2168,2248,"It, it was stupid."],[2385,2494,"You should’ve told me."],[2494,2590,"I know."],[2590,2677,"I'm sorry."],[2723,2769,"No,"],[2769,2848,"you should have told me"],[2848,2977,"so I could have signed us both up."],[3303,3403,"Let's kill them."],[4450,4587,"You two actually showed up."],[4658,4758,"I'm impressed."],[4792,4879,"Cameron."],[4942,4996,"Bitch."],[5067,5171,"Let me know when you come up"],[5171,5301,"with something original."],[5317,5409,"I don't think there's any reason"],[5409,5538,"to do too much more talking."],[5576,5663,"Let’s get this over with."],[5759,5880,"You two are very confident."],[5910,5997,"I like that."],[6039,6093,"So what do you say"],[6093,6235,"we raise the stakes?"],[6402,6535,"Winner stays."],[6585,6702,"And the loser"],[6715,6840,"leaves Central for good."]],"39":[[158,246,"So the loser transfers"],[246,291,"out of here?"],[342,429,"The loser"],[517,592,"never shows their face"],[592,704,"on campus again."],[863,934,"Do we have a deal?"],[1059,1134,"Cam."],[1134,1213,"You can’t trust him."],[1368,1434,"It’s okay."],[1764,1856,"We got a deal."],[2740,2869,"Welcome to"],[2869,3019,"the campus clash."],[3019,3249,"Today we’re testing teamwork,"],[3249,3495,"strength, and brains."],[3503,3649,"The rules are simple."],[3649,3849,"The best couple wins."],[5284,5388,"Damn it!"],[5392,5430,"Come on!"],[5430,5538,"What are you doing?"],[5538,5618,"Are you trying to -"],[6585,6719,"Let’s go! Yes!"],[6719,6840,"Are you going to help?"],[6898,7019,"There’s one final competition"],[7019,7123,"to decide the winner."],[7123,7244,"It all comes down to this"],[7244,7449,"one final challenge."]],"40":[[446,529,"What do you say we throw some..."],[642,738,"throw some footballs?"],[775,900,"Do what we do best,"],[905,980,"QB one, right?"],[1071,1126,"Sure."],[1155,1188,"Okay."],[1226,1280,"One throw..."],[1372,1430,"settles all of this."],[2260,2352,"You use those."],[2410,2502,"I got my own."],[2548,2610,"You can go first."],[2673,2727,"My pleasure."],[3336,3407,"Let’s go, Brett!"],[3407,3657,"Brett! Brett! Brett!"],[3657,3724,"Boy, does it feel good"],[3724,3895,"to be with the winning man."],[3924,4016,"Here it comes."],[4900,5025,"Great job, Brett!"],[5100,5188,"Guess he was good for something"],[5188,5263,"after all."],[5497,5618,"Come on, Cameron."],[5885,6010,"There’s no way he can throw"],[6010,6147,"that oily piece of shit."]],"41":[[1480,1559,"Ooh!"],[1822,1939,"Looks like we won."],[1985,2077,"Sorry."],[2089,2206,"And we have a winner!"],[2210,2489,"Cameron Carter and Maddie Malone!"],[2540,2702,"How is that possible?"],[2702,2848,"Nice try."],[2848,2923,"But a good quarterback"],[2923,3073,"can throw balls in any condition."],[3478,3561,"Damn it!"],[3737,3820,"Wait."],[3832,3899,"Look at the balls"],[3899,3999,"Brett gave Cameron."],[4020,4083,"They’re oily."],[4104,4204,"Oh my God."],[4204,4312,"Did Brett cheat?"],[4312,4483,"Wasn't he our QB for years?"],[4692,4775,"Oh, yeah?"],[4788,4959,"I didn’t want to be here anyway!"],[5125,5201,"Veronica!"],[5651,5830,"What the fuck is your issue?"]],"42":[[4,125,"You, Veronica!"],[171,291,"You were the problem."],[342,442,"But not anymore."],[521,625,"You know, you may be richer"],[625,692,"than me,"],[729,863,"and prettier than me-"],[863,975,"Oh! Nah, that’s not true."],[1063,1126,"Continue though."],[1126,1384,"But you’re just an insecure bully."],[1480,1530,"And no"],[1530,1647,"cheerleading uniform,"],[1647,1776,"or amount of botox,"],[1847,1947,"is gonna change that."],[2027,2131,"Maddie!"],[2177,2323,"Maddie! Maddie!"],[2352,2861,"Maddie! Maddie!"],[3036,3157,"That was so badass."],[5042,5150,"Good toss, Carter!"],[5242,5292,"But you’ve been spending"],[5292,5376,"way too much time"],[5376,5509,"throwing that ball all by yourself."],[5513,5613,"You wanna tell me what the hell"],[5613,5659,"is going on?"],[5818,5918,"It’s just some personal stuff,"],[5918,5960,"coach."],[6051,6189,"Personal stuff doesn’t win games."],[6277,6310,"Look."],[6414,6468,"Whatever it is,"],[6527,6573,"fix it."],[6631,6735,"You’re the leader of this team."],[6735,6831,"I need a leader"],[6831,6931,"with his eyes on the future -"],[6931,7069,"not dwelling in the past."],[7140,7261,"You got this, Carter."],[7520,7645,"I’ll handle it, Coach."]],"43":[[20,120,"Who knew I'd get used"],[120,321,"to being with Cameron?"],[342,521,"Living with him so fast?"],[642,804,"It all feels right except..."],[900,988,"sometimes there's"],[988,1146,"this sadness in his eyes."],[1309,1368,"I know"],[1368,1539,"there's something he's not telling me."],[1901,1960,"Is Cameron home"],[1960,2085,"from practice already?"],[2623,2715,"Where's my son?"],[2715,2773,"Cam Cam?"]],"44":[[112,200,"Where’s my son?"],[200,279,"Cam Cam?"],[304,408,"He’s not here."],[408,483,"Good."],[863,938,"I heard what you did"],[938,1092,"to that sweet girl, Veronica."],[1163,1263,"I won’t let you do that"],[1263,1330,"to my son."],[1668,1755,"So what’s it going to take"],[1755,1835,"for you to disappear"],[1835,1922,"out of our lives for good?"],[1976,2131,"There’s $500,000"],[2160,2348,"in each of these briefcases."],[2523,2627,"You can’t just pay me off."],[2702,2806,"I don’t believe that."],[2852,2957,"A girl like you?"],[2998,3136,"You all have your price."],[3240,3324,"Give me a number"],[3324,3445,"so we can be done with this."],[3449,3524,"No!"],[3607,3707,"I’m not gonna be done"],[3707,3745,"with Cameron."],[3820,3945,"Will another briefcase"],[3945,3995,"be enough?"],[4325,4450,"I said no!"],[4683,4833,"I’m not with him for money."],[4867,4934,"Right."],[4979,5071,"Of course not."],[5138,5242,"Well, if you don’t want to do things"],[5242,5326,"the easy way,"],[5359,5484,"we can do it my way."],[5484,5568,"Grab her!"]],"45":[[4,58,"Grab her!"],[112,241,"No! Let go of me!"],[337,500,"I have the perfect facility"],[500,554,"ready for her."],[608,750,"Somewhere someone like her"],[750,846,"can go get help."],[884,980,"I don’t need any help!"],[1851,1897,"Mom!"],[2214,2260,"Mom!"],[2331,2377,"Mom!"],[2473,2602,"Mom! Roll the window down."],[2794,2940,"Stop this! Where are you taking her?"],[2952,3090,"Cam Cam! Listen dear."],[3132,3182,"I am doing"],[3182,3328,"what any good mother do."],[3336,3465,"I’m protecting you from this"],[3465,3574,"nasty gold digger."],[3636,3732,"She’s not a gold digger!"],[3732,3803,"Let her go!"],[3812,4041,"Honey, you are not thinking straight."],[4091,4216,"She’s just an orphan."],[4216,4358,"She’s ruining your life!"],[4358,4479,"I was just an orphan."],[4537,4650,"Did I ruin your life?"],[4713,4796,"That’s different."],[4854,4984,"When we adopted you,"],[4984,5150,"you completed our perfect family."],[5150,5213,"But her..."],[5276,5384,"Nobody wanted her."],[5434,5543,"Nobody loved her."],[5618,5726,"That’s not true!"],[5789,5868,"I want her!"],[6352,6460,"And I love her."],[6610,6719,"Is that so?"],[6865,6931,"Drive."],[6944,7032,"You can’t do this!"],[7044,7094,"Mom!"]],"46":[[1488,1589,"Mrs. Carter,"],[1589,1764,"Mrs. Carter, please don’t do this."],[1910,2085,"I'm not going to let this happen again."],[2143,2235,"Just stop."],[2344,2473,"I'm not going to lose you again,"],[2473,2565,"Maddie Malone."],[2577,2698,"Stop the car!"],[2940,3140,"Cameron!"],[4412,4475,"Maddie!"],[4621,4688,"Maddie!"],[4942,4996,"Cameron!"],[5234,5288,"Cameron!"],[5405,5480,"Cameron!"],[5547,5672,"Cameron, please wake up."],[5814,5897,"Mads."],[5976,6047,"Mads, I..."],[6227,6306,"promise..."],[6352,6493,"I'll always keep you safe."],[6619,6681,"I'll..."],[7453,7570,"You're gonna drop me!"],[7590,7757,"I'm never going to let anything happen"],[7757,7845,"to you, Mads."],[8170,8229,"Jack."]],"47":[[1413,1493,"Cameron."],[1814,1897,"Cam?"],[1976,2097,"Maddie."],[2198,2298,"Mads, you’re safe."],[2502,2565,"Are you okay?"],[2619,2736,"Am I okay?"],[2815,2927,"You’re the one who risked your life"],[2927,3007,"to save me."],[3186,3290,"Why would you do that?"],[3328,3399,"So stupid."],[3470,3620,"I’d do it over again, Mads."],[3641,3778,"I had the weirdest dream."],[3949,4074,"When I passed out, I..."],[4154,4304,"I think I saw you."],[4358,4479,"I heard your voice,"],[4479,4646,"but it wasn’t now. It was..."],[4913,5042,"It felt like a memory."],[5317,5405,"What? Wait. Hey!"],[5405,5501,"No, lie back down."],[5893,6022,"It wasn’t a dream, Maddie."],[6548,6631,"It had to be."],[6710,6819,"You didn’t go by Cameron."],[6819,6906,"You went by..."],[6973,7019,"Jack."],[7307,7428,"But that means..."],[7711,7832,"My name’s not Cameron."],[7903,8003,"It's Jack."],[8262,8304,"We grew up"],[8304,8454,"at the same orphanage together."],[8554,8646,"And when they separated us,"],[8646,8767,"you chased me down."],[8983,9084,"You got hit by a car,"],[9084,9209,"and I wasn't there to protect you."],[9363,9480,"Everything that happened to you"],[9480,9547,"is my fault."]],"48":[[29,104,"And you knew?"],[200,312,"This entire time?"],[325,487,"I'm sorry, Mads."],[600,658,"Really."],[667,800,"I've looked everywhere for you,"],[846,917,"even when the Carters"],[917,988,"took me overseas."],[988,1071,"I looked everywhere,"],[1071,1109,"but..."],[1167,1317,"I knew you didn't remember."],[1405,1476,"And I didn't know"],[1476,1593,"how to tell you about..."],[1785,1901,"about the accident."],[2056,2223,"Everything that’s happened to you"],[2223,2423,"is my fault, okay?"],[2477,2515,"And you don’t want"],[2515,2619,"to remember any of it,"],[2619,2719,"because it's too painful."],[2719,2836,"And you're right, Mads."],[2990,3148,"I abandoned you..."],[3203,3399,"after I promised I’d keep you safe."],[3399,3557,"After I told you that I would never let"],[3557,3712,"anything bad happen to you."],[3841,4008,"I know you wouldn't forgive me."],[4074,4158,"I knew you'd never"],[4158,4262,"want to speak to me again."],[4633,4800,"Can you say something please?"],[5096,5201,"I'll give you some space."],[5989,6093,"Cameron, wait!"],[6135,6197,"Cameron!"],[6256,6297,"Cameron!"],[6389,6443,"Jack!"],[7540,7778,"Don’t you dare leave me ever again."],[7816,7966,"I’m telling you right now..."],[8091,8266,"that I don’t blame you for anything."],[8395,8479,"It was an accident."],[8479,8633,"We were just kids."],[8729,8796,"I remember..."],[8883,8954,"all of it now."],[8954,9004,"I..."],[9117,9267,"There was nothing that you could do."],[9346,9496,"You’ve always fought for me."],[9542,9734,"You’ve always protected me."],[9872,9939,"Jack or..."],[10039,10105,"Cameron."],[10197,10306,"It’s always been you."],[10568,10648,"You were the one"],[10648,10764,"that I’ve been missing"],[10764,10831,"this whole time."],[10860,10981,"And you came back to me"],[10981,11106,"just like you promised."]],"49":[[1718,1918,"Take me home."],[8508,8575,"Jack."],[8700,8758,"I need you."]],"50":[[825,905,"Going over plays?"],[1059,1163,"You were sleeping so peacefully,"],[1163,1259,"I didn’t want to wake you."],[1347,1526,"I don’t want"],[1526,1685,"to miss another moment with you."],[1776,1864,"You’re not mad at me?"],[1951,2039,"For keeping it from you?"],[2243,2402,"You did what you thought you had to."],[2540,2610,"And..."],[2652,2786,"now that I think about it,"],[2861,2936,"there were so many times"],[2936,3019,"where you tried telling me"],[3019,3069,"and..."],[3115,3199,"I wouldn’t listen."],[4637,4721,"I forgive you."],[5476,5559,"What’s wrong?"],[5926,6047,"There’s something I need to show you."]],"51":[[342,529,"This is crazy to be back here."],[529,638,"Wow."],[938,988,"Here we are."],[1101,1192,"Where it all started."],[1280,1372,"This place was so different"],[1372,1434,"when you left."],[1539,1622,"I remember feeling"],[1622,1722,"there was something missing,"],[1722,1764,"but..."],[1868,1931,"I couldn’t remember"],[1931,2035,"what it was."],[2527,2748,"It’s been so many years!"],[2840,2890,"Jack!"],[3048,3232,"Or shall I call you Cameron now?"],[3249,3319,"Jack’s fine."],[3332,3382,"Maddie!"],[3382,3486,"Sister Elizabeth."],[3486,3624,"You look amazing."],[3762,3887,"Shall we go talk in my office?"],[3928,4024,"You’ll be okay, yeah?"],[4738,4871,"I am not surprised"],[4871,5034,"that the two of you found one another."],[5096,5217,"You were inseparable."],[5271,5397,"I hope you’ll understand"],[5397,5601,"why we gave him to the Carter family."],[5709,5797,"They wanted a boy."],[5855,5997,"We tried to get them"],[5997,6076,"to take the both of you."],[6076,6222,"But they had made their minds up."],[6252,6343,"It’s okay."],[6377,6577,"Cameron and I are actually curious"],[6577,6660,"what we can do"],[6660,6777,"to help the other kids here."],[6794,6948,"Where is she? She owes me money."],[7019,7102,"She’s in a meeting!"],[7111,7169,"I don’t care."],[7169,7294,"Tell her I want to see her now."]],"52":[[250,371,"I'm so sorry."],[371,525,"He wouldn't take no for an answer."],[525,633,"It's okay."],[696,804,"It’s the landlord."],[804,909,"Thank you, Kiara."],[921,1088,"Mr. Thompson, how can I help?"],[1117,1238,"You owe me rent, Liz."],[1238,1309,"I told you."],[1309,1418,"If you didn't pay me,"],[1418,1530,"I was going to evict you"],[1530,1689,"and all these stinking kids."],[1701,1826,"I don't owe you anything."],[1826,1926,"What about the repairs"],[1926,2031,"I did last month?"],[2031,2164,"You never paid me for that."],[2173,2298,"The hot water heater"],[2298,2398,"is still broken."],[2398,2439,"Enough!"],[2439,2494,"Pay me,"],[2494,2635,"or I'm shutting this place down."],[2660,2761,"Give me my money!"],[2761,2869,"Is everything okay?"],[2869,3015,"Stay out of it."],[3115,3261,"I remember you."],[3357,3490,"You’re all grown up now."],[3490,3595,"Don't touch me."],[3620,3737,"Give me one night with her,"],[3737,3945,"and we’ll consider your debts paid."],[3970,4208,"Want to help Sister Liz out of a jam?"],[4491,4571,"You’re breaking my arm!"]],"53":[[33,133,"What's going on here?"],[133,262,"This bitch owes me money!"],[375,500,"Cameron Carter?"],[558,709,"I don't owe him anything."],[709,834,"He's the slumlord who"],[834,942,"owns this building."],[942,1113,"He's been doing this for years."],[1434,1568,"How much is this place worth?"],[1597,1689,"Why?"],[1689,1793,"Because I want to buy it."],[1876,1972,"What?"],[1972,2110,"Jack, I can’t ask you to do that."],[2110,2331,"It would cost $1,000,000"],[2331,2402,"to buy him out."],[2494,2652,"No need to ask, Sister."],[2761,2894,"You said $1,000,000?"]],"54":[[16,70,"I’ll have my agent"],[70,158,"wire you the money."],[250,304,"Hey!"],[383,538,"And then you sign the deed."],[538,617,"And you get out of here,"],[617,796,"and you never show your face again."],[834,934,"Got that?"],[992,1063,"It's either that"],[1063,1151,"or you roll out of here"],[1151,1209,"in a wheelchair."],[1209,1284,"You decide."],[1338,1522,"You got a deal."],[1522,1547,"Yeah."],[1547,1697,"I'm sorry."],[1760,1910,"I'm a huge fan."],[2281,2352,"You alright?"],[2352,2414,"Yeah."],[2414,2506,"Thanks to you."],[2565,2702,"You're just always on time"],[2702,2815,"when I need you."],[2894,2927,"Oh my god,"],[2927,3061,"speaking of time,"],[3061,3123,"I got warm ups."],[3123,3244,"Let’s get out of here."],[3269,3407,"I'll send you guys tickets."],[3407,3507,"I hope you guys can make it."],[3507,3595,"It’s going to be a good one."],[3624,3687,"Let’s go."]],"55":[[204,333,"Now introducing..."],[333,617,"Your starting Quarterback!"],[625,1005,"Cameron “Jack” Carter!"],[1322,1430,"There he is."],[1493,1659,"My knight in shining armor."],[1810,1943,"They say knights only exist"],[1943,2027,"in fairytales,"],[2056,2223,"and that heroes like Cameron Carter,"],[2223,2314,"belong in books,"],[2314,2419,"not real life."],[2427,2615,"I transferred to Central University,"],[2648,2752,"to bring a championship"],[2752,2823,"to this school."],[2836,2948,"Knights on three!"],[2957,3136,"One! Two Three! Knights!"],[3178,3324,"But watching him out there,"],[3324,3436,"I know they're wrong."],[3595,3728,"He’s more than a quarterback."],[3832,3891,"He's the boy"],[3891,3962,"who was there for me"],[3962,4116,"when no one else was."],[4116,4216,"He's the man"],[4216,4275,"who showed me"],[4275,4354,"what it was like"],[4354,4508,"to truly be seen."],[4571,4629,"And no matter"],[4629,4746,"what comes next,"],[4813,4875,"I'll be there"],[4875,4984,"cheering him on."],[5067,5217,"Me and a couple of friends."],[5326,5413,"To everyone else,"],[5413,5559,"he's Cameron Carter,"],[5559,5722,"the superstar quarterback."],[5730,5893,"The Knights win!"],[6151,6239,"To me,"],[6531,6635,"he's just Jack."]]}