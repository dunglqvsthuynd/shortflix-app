're still going to say"],[6014,6189,"the same thing, I still don't know."],[6189,6373,"Then you should have left with her."],[6373,6527,"Has anything changed?"],[6527,6727,"You know what hasn't changed?"],[6756,6956,"Is you keep fighting with me."],[6990,7065,"Are we done here?"],[7065,7173,"I don't like this."],[7173,7290,"I don't like drama."],[7290,7419,"If this is how you roll,"],[7419,7578,"I don't like drama."],[7578,7707,"There is no one else in here"],[7707,7778,"that I want."],[7803,7903,"But you are right."],[7903,8166,"If we can't, like, get the toxic"],[8166,8366,"things under control, like"],[8395,8571,"we can't be together."],[8571,8700,"What do you want to do?"],[8829,9029,"I want to stop fighting."],[9029,9225,"I want to stop being toxic."],[9225,9459,"I think Cru is my soulmate."],[9488,9613,"But after he refused to"],[9613,9688,"choose me over"],[9688,9838,"Symantha, I don't know if I can"],[9838,10001,"be with him anymore."],[10001,10080,"You’re making me feel like"],[10080,10214,"I'm being so confusing."],[10402,10656,"I'm just asking what you want."],[10656,10719,"Because I already told you"],[10719,10802,"what I want."],[10956,11056,"You're just like."],[11056,11177,"I feel like you're refusing to"],[11177,11236,"give it to me."]],"92":[[70,162,"The girls and I feel"],[162,291,"pretty off about Brynn."],[291,479,"Like her vote for Ty"],[479,646,"is a vote against Savannah."],[675,796,"I had told Brynn"],[796,1046,"that if my guy Ty goes home,"],[1046,1242,"I'm leaving with him."],[1288,1447,"Okay, so"],[1447,1584,"we don't want you to feel like"],[1668,1760,"you're not welcome."],[1760,1851,"We don't want to feel like"],[1851,1960,"you're crazy."],[2027,2081,"We just."],[2081,2181,"We wish you would have"],[2181,2248,"voted differently"],[2248,2327,"because it felt like a"],[2327,2510,"vote against Savannah."],[2519,2615,"It hurts to see people"],[2615,2736,"upset by your actions,"],[2736,2819,"but ultimately,"],[2836,2915,"you know somebody wa