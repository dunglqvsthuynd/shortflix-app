itely realized I hurt Sav"],[9567,9672,"a lot more than I thought"],[9672,9780,"was going to be the case,"],[9784,9893,"that was not my intention"],[9893,10010,"by any means."],[10010,10143,"You want to go fuck Toni?"],[10143,10247,"Is that your soulmate?"],[10247,10322,"You want to keep him"],[10322,10422,"in the house so bad?"],[10422,10543,"At the end of the day,"],[10543,10714,"girls should pick girls."]],"93":[[304,450,"We made it."],[450,658,"I told you."],[658,729,"Even though I know"],[729,909,"a lot of people voted for me,"],[909,1055,"and I almost went home,"],[1055,1134,"But I'll be honest,"],[1134,1301,"I think for me, it hurts."],[1301,1426,"I mean it obviously doesn't feel great"],[1426,1680,"to be one of two."],[1685,1876,"When somebody who is new"],[1876,2085,"and just got here and"],[2085,2198,"doesn't really"],[2198,2273,"necessarily seem to have"],[2273,2389,"a connection from what I"],[2389,2473,"understand, you know."],[2473,2569,"And then"],[2569,2711,"I've been here all week"],[2711,2840,"and to potentially have"],[2840,2961,"gone home."],[2994,3057,"You know,"],[3057,3148,"that would have sucked."],[3148,3203,"Everyone's entitled to"],[3203,3290,"their own opinion,"],[3290,3403,"their own vote, and someone"],[3403,3545,"had to get voted off."],[3545,3620,"But she was real close"],[3620,3716,"to going home."],[3716,3841,"And that was scary."],[3841,3966,"Seeing you up there with"],[3966,4141,"just you and Symantha,"],[4141,4250,"I was worried."],[4250,4366,"I had confidence."],[4366,4458,"I know."],[4458,4575,"I said that from the beginning"],[4575,4742,"but I was kind of worried."],[4859,5084,"And to be truthful,"],[5084,5150,"a couple, I don’t know"],[5150,5317,"about the girls, but"],[5317,5422,"a couple of the guys"],[5422,5518,"there told me that they,"],[5518,5709,"they voted you."],[5709,5822,"It was definitely a lot of chatter,"],[5822,5872,"and, like,"],[5872,5960,"strategizing."],[5960,6081,"Ty said he was voting for me,"],[6081,6235