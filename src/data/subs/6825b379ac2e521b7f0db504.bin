{"1":[[1088,1146,"Mommy?"],[1305,1388,"Mommy!"],[1522,1601,"Mommy!"],[3407,3545,"Drink up, bitch."],[3603,3741,"Oh, Nicole..."],[3741,3962,"always the perfect mother?"],[3962,4179,"Now you’re just a drunk bitch."],[4179,4354,"Sorry, bestie."],[4354,4533,"Your man’s about to get the biggest deal"],[4533,4633,"of his life,"],[4667,4817,"so now I want him."],[4879,5163,"You left his kid to roast in a car."],[5163,5417,"I wonder what Ethan will think."],[5417,5492,"Ethan?"],[5543,5609,"Oh my God!"],[5643,5868,"You have to come home right away."],[5914,6056,"Nicole is drunk,"],[6056,6256,"and she locked Grace in the car,"],[6256,6489,"and I can't find the key anywhere!"],[8258,8441,"Thanks, Elaine, if you didn’t"],[8441,8596,"break the car window in time,"],[8679,8783,"Grace could have died."],[9009,9113,"Sorry you got hurt."],[9209,9305,"It doesn't matter."],[9342,9505,"As long as Gracie is okay."],[9701,9959,"I still have use of this little brat,"],[9959,10172,"but once I become her stepmother,"],[10172,10310,"I'll get rid of her."],[10377,10464,"Gracie."],[10598,10694,"Gracie, oh my God."],[10694,10806,"Hey, mommy's here."],[10806,10881,"Mommy can-"]],"2":[[275,592,"How dare you have the fucking audacity"],[592,713,"to show up here, Nicole?"],[754,959,"You almost killed our daughter!"],[1071,1121,"What?"],[1172,1363,"You forgot our daughter"],[1363,1514,"in this fucking heat,"],[1605,1714,"while you were passed out"],[1714,1847,"on the couch, drunk."],[2060,2114,"No."],[2185,2264,"I didn't."],[2323,2481,"We've been married for seven years."],[2481,2644,"You know that I barely drink."],[2644,2694,"I didn't."],[2694,2706,"I didn't."],[2777,3011,"No, I, I, I went to the grocery store"],[3011,3082,"with Grace."],[3115,3315,"And then we came home and Elaine..."],[3641,3724,"It was you."],[3832,3958,"You drugged me."],[4024,4154,"That glass of water that you gave me,"],[4154,4291,"that's the last thing I remember."],[4291,4416,"Why would you do this?"],[4446,4688,"Nicole, I'm your best friend."],[4729,4792,"I just,"],[4813,4925,"I just came by to bring you"],[4925,5042,"some documents."],[5042,5284,"That's why I saw Nicole on the couch"],[5430,5563,"and Gracie in the car."],[5593,5759,"I couldn't find the keys anywhere."],[5759,5880,"I just broke the window."],[5880,5972,"I don't know what to do."],[6227,6393,"You get off of my husband!"],[6431,6506,"You're lying."],[6514,6602,"You're a liar."],[6690,6765,"Ethan, you can see"],[6765,7023,"that I'm being set up right now, right?"],[7449,7545,"You're my husband."],[7545,7795,"Why, why are you believing her"],[7795,7882,"over me?"],[7882,7945,"Enough."],[8083,8195,"I can smell the alcohol"],[8195,8270,"in your breath."],[8299,8462,"Why would Elaine wanna frame you?"],[8495,8712,"What does she have to gain from this?"],[9117,9388,"See, you have nothing to say."],[9434,9605,"Please, Ethan."],[9684,9980,"I love Gracie with my whole heart,"],[9980,10126,"with everything that I have."],[10172,10247,"You know me."],[10276,10485,"I would never do something like that."],[10485,10714,"Gracie, I, I love you, baby."],[11081,11215,"I only believe what I see."],[11336,11490,"I already called the cops, Nicole."],[11532,11674,"I want you to repent in jail"],[11740,11857,"and learn your lesson."],[11924,12224,"What you did is not only a crime,"],[12295,12466,"but also unforgivable"],[12587,12679,"as a mother."],[12896,13079,"You're sending me to jail right now?"],[13079,13317,"Away, away from you and Gracie?"],[13546,13617,"No."],[13667,13751,"You have to listen to me."],[13751,13826,"You have to believe me."],[13826,13926,"I didn't do this."],[13951,14018,"Gracie, baby."],[14018,14105,"I'm right here!"],[14126,14197,"Gracie!"],[14385,14451,"Ethan."],[14493,14564,"No."],[15561,15694,"I gave up everything"],[15694,15861,"to be with you, Ethan."],[15970,16095,"Was my dad right?"],[16216,16295,"Was this..."],[16412,16491,"was us"],[16583,16712,"just a big mistake?"]],"3":[[58,183,"It's been a long day."],[208,387,"Here, drink this."],[392,504,"It'll help you sleep."],[538,667,"I'm gonna check on Gracie,"],[667,775,"and then I'll head home."],[813,875,"Thanks, Elaine."],[955,1096,"I don't know what I'd do without you."],[1130,1230,"Hey, you're my boss."],[1247,1355,"Anything for you."],[1359,1484,"Don't sell yourself short."],[1547,1676,"You know you're more like family."],[2464,2523,"Wait."],[2927,3023,"No, I’m just, don’t."],[3023,3136,"No, no."],[3290,3370,"I'm innocent."],[3378,3445,"I swear."],[3445,3561,"Save it for the judge."],[4295,4508,"I stopped talking to my own father"],[4508,4604,"because of Ethan."],[4742,4938,"The man who put me behind bars."],[4988,5213,"What should I do?"],[5680,5822,"Good afternoon, Mr. Carrington."],[6031,6076,"Yep."],[6243,6293,"What?"],[6406,6581,"My daughter's in jail?"],[6664,6815,"Sara, get me Damon Hawthorne."],[6815,6952,"He's the best lawyer in LA."],[6977,7169,"And find out what jail she's in."],[7182,7257,"Now!"],[8412,8495,"Mr. Hawthorn,"],[8521,8633,"I'm Sara Sandoval,"],[8633,8754,"executive assistant"],[8754,8875,"to Max Carrington."],[8896,9046,"It seems Nicole has found her way"],[9046,9142,"into prison,"],[9142,9296,"by way of Mr. Ethan Carter."],[9321,9421,"Had I known your husband"],[9421,9555,"was a prick, Nicole,"],[9555,9713,"I never would have let you go."],[9722,9797,"Do you think you can help us"],[9797,9859,"bring her home?"],[10022,10097,"I'm on it."]],"4":[[592,633,"Ethan."],[633,746,"No touching."],[746,871,"Sit your ass down."],[1142,1222,"Ethan,"],[1409,1568,"will you please just pay my bail?"],[1680,1860,"I'm gonna go home to Gracie, okay?"],[1943,2035,"Come on, you've had time"],[2035,2106,"to think about this."],[2106,2243,"You know I didn't do this."],[2243,2360,"What I know, Nicole,"],[2406,2711,"is that our daughter almost died."],[2790,2890,"Because you"],[2952,3178,"were passed out on the couch, drunk."],[3328,3511,"Tell me how else it happened, huh?"],[3591,3916,"Elaine, she drugged and she framed me."],[4095,4379,"Stop blaming Elaine."],[4450,4558,"She has been nothing"],[4558,4671,"but kind to you"],[4671,4788,"all these years."],[4817,4896,"While she and I"],[4896,5034,"were slaving away at work,"],[5034,5109,"you've been living as this"],[5109,5205,"picture-perfect"],[5205,5342,"Beverly Hills housewife."],[5376,5472,"You had one job,"],[5505,5609,"take care of Gracie."],[5647,5801,"And you couldn't even do that right."],[6010,6193,"That's really what you think of me?"],[6569,6702,"Nicole, I just want to-"],[6702,6840,"Why did you bring Elaine here?"]],"5":[[483,554,"Nicole,"],[613,788,"I’m really worried about you."],[880,1026,"Ethan and I both have."],[1222,1326,"And I should have known"],[1326,1459,"you're a home-wrecker."],[1509,1584,"What?"],[1664,1826,"I would never do that."],[1922,2114,"Nicole, what did I ever do"],[2114,2293,"to make you hate me this much?"],[2410,2577,"What happened to you, Nicole?"],[2635,2777,"You used to be so kind,"],[2877,2969,"so gentle."],[3019,3328,"This past year, you've changed."],[3599,3678,"You have no idea"],[3678,3770,"what kind of sacrifices"],[3770,3891,"I've made for you."],[4104,4233,"It's Carrington Enterprise."],[4312,4454,"I have to take this."],[4617,4725,"Carrington Enterprise?"],[4783,4950,"That's my family's business."],[4950,5096,"Why are they calling Ethan?"],[5347,5572,"I fucked your husband last night."],[5751,5872,"Just thought you should know."],[5985,6143,"And you know what Ethan said?"],[6306,6635,"He said I was the best he's ever had."],[6744,6940,"You know, I'm a better woman, right?"],[6990,7077,"Not you."],[7524,7728,"You took my husband"],[7728,7899,"and my daughter from me!"],[7916,8108,"You were my best friend, bitch!"]],"6":[[667,829,"Here, drink this."],[855,959,"It'll help you sleep."],[1601,1664,"Wait."],[1755,2077,"Do you think I was too harsh on Nicole"],[2077,2177,"to send her to jail?"],[2531,2781,"I think we should let the court decide."],[2852,3015,"I love Nicole."],[3107,3286,"But what she did was a crime."],[3374,3499,"Nicole has no money."],[3591,3724,"She can't even afford an attorney."],[4058,4158,"Maybe I should"],[4279,4354,"pay her bail and"],[4504,4625,"drop the case."],[4846,5025,"I knew this was going to happen."],[5050,5251,"That's why there's always a plan B."],[6794,6906,"Troy Poe."],[6973,7082,"What a jerk."],[7720,7799,"Board's office."],[7974,8070,"Mr. Hawthorne."],[8103,8170,"Yes, sir."],[8320,8375,"What?"],[8441,8662,"The Mr. Carrington's daughter"],[8662,8792,"is in my jail?"],[8946,9000,"Fuck!"],[9180,9300,"Help!"],[9442,9555,"Nicole, stop it."],[10439,10539,"Ethan, don't."],[10585,10748,"Let the guards deal with her."],[10810,11036,"Nicole, have you lost your damn mind?"],[11152,11211,"Yeah."],[11323,11444,"Yeah, I lost my mind."],[11586,11686,"I married you."],[11870,12045,"The biggest mistake of my life."],[12070,12128,"That's it."],[12141,12337,"I'm taking you to solitary confinement"],[12337,12391,"right now."],[12391,12433,"Up!"],[12433,12516,"On your feet. - No."],[12545,12708,"Get your fucking hands off her!"],[13542,13609,"Nicole."],[13697,13792,"I’m sorry I'm late."],[13909,13980,"Damon?"],[14039,14143,"Let's get you up."],[14297,14447,"Uncuff my client now."]],"7":[[25,183,"Uncuff my client now."],[371,496,"What are you waiting for?"],[554,696,"Did you not just hear"],[696,863,"what Mr. Hawthorne said?"],[988,1088,"I'm sorry, boss."],[1101,1176,"I'm sorry, ma'am."],[1217,1276,"Sorry?"],[1338,1488,"Why are you uncuffing her?"],[1488,1589,"She's a criminal."],[1651,1805,"And who is this rando?"],[1835,2043,"You're just letting him waltz in here"],[2043,2147,"and you're listening to him?"],[2147,2323,"Don't talk to me like that."],[2323,2544,"This is my fucking turf, okay?"],[2544,2606,"And don't call"],[2606,2798,"Mr. Hawthorne a rando."],[2798,2911,"Show some respect."],[2977,3098,"One more strike"],[3107,3178,"and you two will"],[3178,3345,"get the fuck out of my jail."],[3378,3520,"What is happening?"],[3561,3670,"Who is this guy?"],[3720,3770,"What?"],[3770,3953,"Showing your true colors, Elaine?"],[4200,4304,"No, I just..."],[4433,4517,"I wanna make sure"],[4517,4675,"everyone's following procedure,"],[4717,4879,"or else it would hurt you more otherwise."],[4879,5017,"Drop the act."],[5092,5296,"Aren't you tired of pretending yet?"],[5438,5638,"Whoa, step away from my client."],[5709,5826,"She's my wife!"],[5826,5955,"You lost that privilege"],[5955,6043,"the moment you called"],[6043,6126,"the cops on her."],[6156,6277,"Now you're the plaintiff"],[6277,6398,"and she's the defendant."],[6435,6514,"And I said,"],[6577,6952,"step the fuck away from my client."],[7194,7261,"Nicole,"],[7323,7436,"can I please talk to you"],[7436,7540,"in private, please?"],[7665,7745,"You know what?"],[7745,7832,"I'm exercising"],[7832,7966,"attorney-client privilege."],[7966,8053,"The only person"],[8053,8329,"speaking to Nicole privately is me."]],"8":[[325,521,"What are you doing here, Damon?"],[679,880,"How'd you even find out I was in jail?"],[946,1034,"Your father called me."],[1463,1505,"I,"],[1622,1772,"I thought he hated me."],[1939,2047,"I broke his heart."],[2097,2239,"Damon, I shouldn't have done that."],[2239,2318,"I regret that-"],[2318,2481,"Nicole, you are his daughter."],[2569,2706,"He could never not love you."],[2819,2944,"He's waiting for you."],[2973,3094,"He asked me to bring you home."],[3553,3636,"Please don't cry."],[3837,3966,"I can't stand to see you cry."],[4279,4341,"I don't know how"],[4341,4491,"I'm gonna face him again."],[4512,4579,"Damon,"],[4579,4637,"I can't."],[4650,4700,"I can't."],[4700,4758,"You can."],[4758,4842,"No, I can't."],[4842,4979,"You can and you will."],[5088,5367,"You were born a queen, Nicole."],[5472,5618,"It's time to take back what's yours."],[6039,6106,"You're right."],[6327,6418,"You're right."],[6906,7148,"And queens never cry."],[7253,7386,"This marriage"],[7386,7670,"was the biggest mistake of my life."],[7741,7945,"I'm going to take back my daughter."],[7957,8174,"And I'm going to take back my name."],[8254,8366,"It's time for Ethan to find out"],[8366,8475,"who I really am."]],"9":[[3453,3570,"Who are these people?"],[3620,3753,"What is happening?"],[3812,4016,"How is she getting out so soon?"],[4074,4258,"How does she even afford all of this?"],[5184,5296,"I want a divorce."],[5330,5380,"You what?"],[5409,5522,"And I want sole custody"],[5522,5605,"of my daughter."],[5718,5855,"She deserves better than you."],[5876,5997,"You have no job."],[6010,6101,"No money."],[6151,6281,"Without me, you have nothing."],[6356,6418,"You think you're going to win"],[6418,6489,"just because you got yourself"],[6489,6652,"some fancy attorney with my money?"],[6752,6815,"Wow."],[6890,7127,"You really are my biggest mistake."],[7486,7603,"Have fun with the snake."]],"10":[[1130,1226,"Nicole."],[1530,1672,"Oh, my baby girl."],[2106,2198,"I'm sorry."],[2277,2385,"You're home now."],[2452,2581,"That's all that matters."],[2698,2802,"I'm so sorry."],[2932,3078,"I shouldn't have told you to go."],[3094,3219,"No, no, no."],[3219,3382,"You were right about Ethan, Dad."],[3432,3636,"I should never have left you for him."],[3636,3732,"I'm sorry."],[3841,3970,"That Ethan Carter."],[4012,4158,"I knew he was trouble."],[4225,4325,"To mend our differences,"],[4325,4429,"I was already drafting"],[4429,4654,"a ten-billion-dollar investment"],[4654,4742,"into his company."],[4833,4938,"And then,"],[4938,5025,"I heard he,"],[5100,5255,"he sent you to prison?"],[5347,5397,"Is that why"],[5397,5538,"you called him earlier today?"],[5638,5764,"It's Carrington Enterprise."],[5780,5889,"I have to take this."],[5955,6068,"This is unforgivable."],[6181,6243,"Sara,"],[6297,6531,"cancel that contract immediately."],[6531,6648,"Yes, sir, Mr. Carrington."],[6673,6723,"Dad."],[6869,6990,"I got this."],[7069,7236,"I just need to cut ties with Ethan."],[7315,7503,"And I have to get Grace back."],[7590,7724,"Nicole's right, Mr. Carrington."],[7824,7899,"I'll go with her."],[8008,8116,"And I won't let her get hurt."]],"11":[[800,1034,"I'm basically the lady of this house now."],[1071,1201,"And I will be soon."],[1347,1443,"And Ethan,"],[1534,1655,"he'll be my husband."],[1939,2014,"Thanks, Elaine."],[2114,2218,"I don't know what I would've done"],[2218,2310,"with Grace's birthday party"],[2310,2394,"if you weren't here."],[2464,2615,"Nicole could never pull this off."],[2756,2802,"She couldn't even"],[2802,2923,"take good care of our daughter."],[2961,3140,"Loopy, it's your birthday today."],[3161,3278,"Let's go find Mommy."],[3278,3345,"By the way,"],[3345,3449,"do you know where Grace is?"],[3449,3578,"She's just in her room."],[3578,3682,"I'll go check on her."],[3716,3795,"Alright."],[4471,4658,"Did I hear you say Mommy?"],[4767,4996,"Your Mommy is a criminal."],[5017,5163,"And you'll never see her."],[5184,5334,"My Mommy is a good person."],[5367,5580,"I'm taking Loopy to find Mommy."],[5580,5747,"I want Mommy here, not you."],[5747,5876,"This is my home."],[5897,5997,"Well, guess what?"],[6031,6310,"Soon, this is going to be my house."],[6339,6523,"And I'm going to be your new Mommy."],[6523,6723,"No, you're not my Mommy."],[6798,6931,"You little bastard."],[7015,7173,"What's the name of your toy?"],[7236,7307,"Loopy?"],[7524,7636,"No, Loopy!"],[7799,7978,"Now you stay right here,"],[8003,8220,"or every toy of yours"],[8237,8429,"is going to end up like Loopy."],[8875,9067,"I have to save Loopy,"],[9100,9363,"and we're gonna go find my mommy!"],[11369,11553,"Daddy, save me!"]],"12":[[41,191,"Love this dress."],[191,325,"It’s so pretty."],[483,642,"Ethan, what's the matter?"],[684,767,"Where's Grace?"],[809,992,"Oh, I told you she's in the room."],[992,1076,"I checked on her."],[1151,1263,"You two are a better match."],[1322,1447,"Elaine is a career woman,"],[1447,1639,"but also takes great care of Grace."],[1726,1876,"Ethan, you should consider"],[1876,2052,"making Elaine Grace's new Mommy."],[2173,2377,"Elaine and I just work together."],[2377,2502,"There's nothing between us."],[2765,2827,"Hello, dear."],[2836,2965,"Oh, hi."],[3044,3211,"Ethan, this is my mom."],[3224,3361,"You know, her boyfriend"],[3361,3553,"is the Chief Investing Director"],[3553,3682,"of the Carrington Group."],[3682,3812,"Mr. Owen Rook."],[3853,3908,"Wait."],[3953,4066,"So the ten-billion-dollar"],[4066,4124,"contract deal"],[4124,4216,"with the Carringtons? -Yes."],[4287,4387,"Elaine urged me"],[4387,4587,"to pull some strings with Owen."],[4696,4833,"She did that all for you."],[4859,4921,"Oh."],[4921,5080,"The Carringtons had decided"],[5080,5192,"to invest in Ethan"],[5192,5388,"even before my mom got together"],[5388,5488,"with that man."],[5543,5676,"But that's not important."],[5705,5843,"I'll do whatever it takes"],[5843,5993,"to make you mine, Ethan."],[6977,7086,"Excuse me."],[7411,7561,"You got some nerve to show"],[7561,7640,"to our daughter's"],[7640,7757,"birthday party, Nicole."],[7757,7857,"Where is Grace?"],[7916,8012,"Why isn't she here with you?"],[8012,8191,"She's safe in her room."],[8245,8450,"And who are you to stride in here"],[8450,8571,"questioning how I take care"],[8571,8666,"of our daughter?"],[8666,8767,"I'm her mother,"],[8904,9042,"and I'm taking her with me today."],[9063,9125,"Mommy."],[9146,9221,"Mommy!"],[9242,9396,"Save me!"]],"13":[[16,87,"Mommy!"],[133,237,"Is that Grace?"],[354,504,"Mommy!"],[538,825,"Save me!"],[825,900,"Grace!"],[3078,3144,"I got you."],[3165,3228,"I got you."],[3257,3311,"Okay."],[3457,3507,"Okay."],[3545,3591,"Oh my God."],[3591,3682,"You're okay."],[3707,3816,"Mommy's here."],[3912,3966,"Hey, what were you doing"],[3966,4083,"in the water, sweetheart-"],[4083,4187,"I'm sorry, Mommy."],[4220,4416,"Loopy fell in the pool because of me."],[4479,4583,"But I saved him."],[4583,4667,"You did? - And you're back."],[4717,4817,"Yeah I did."],[4846,4996,"Yeah, Mommy's back, baby."],[5117,5213,"I'm so sorry."],[5338,5513,"Grace?"],[6193,6302,"What the hell happened here?"]],"14":[[333,546,"Why the hell was Grace by herself?"],[571,679,"You know she can't swim."],[679,992,"Do you have any idea how scared she was?"],[1005,1059,"I-"],[1092,1226,"Ethan, I'm so sorry."],[1255,1363,"I have no idea"],[1363,1509,"how Grace ended up in the pool."],[1509,1580,"She promised"],[1580,1726,"she'd stay in her room, I-"],[1872,1972,"Nicole!"],[1972,2056,"What are you doing?"],[2056,2189,"You put my daughter in danger"],[2189,2331,"and this is the second time"],[2331,2402,"you've done so."],[2402,2515,"That is not okay!"],[2515,2606,"What?"],[2660,2886,"Why is she accusing me like this?"],[2898,3040,"You need to stop the act."],[3040,3203,"Elaine is making me sick."],[3203,3332,"I'm gonna throw up right now."],[3699,3883,"I'm taking Grace with me today."],[3920,4008,"You're crazy!"],[4029,4154,"She's my daughter too."],[4208,4316,"One more step"],[4316,4441,"and then I'm gonna call the police"],[4441,4554,"and they're gonna send your wet ass"],[4554,4646,"back to jail."],[4808,4938,"I'd like to see you try."],[5092,5309,"Ethan Carter!"],[6577,6669,"What the hell is this?"],[6669,6777,"Divorce papers."],[6835,6898,"Sign it."],[7032,7228,"Also, I am getting full custody of Grace."],[7286,7340,"What?"],[7444,7565,"I'm not getting a divorce."],[7582,7674,"Mr. Carter,"],[7674,7816,"my client has made her decision."],[7853,7982,"We're informing you of it,"],[8020,8099,"not discussing."],[8299,8450,"I have nothing else to say to you."],[8558,8650,"Don’t sign the papers."],[8650,8754,"Fine, we'll take it to court,"],[8754,8846,"but I am taking Grace"],[8846,8942,"with me right now."],[8942,9455,"I let you leech onto me for seven years!"],[9484,9584,"What have you done for me"],[9584,9667,"all these years?"],[9697,9914,"Who are you to leave me?"],[10014,10060,"And who are you"],[10060,10218,"to take my daughter away from me?"],[10293,10535,"Seven years of marriage"],[10535,10648,"and that's seriously"],[10648,10748,"what you think of me?"],[10764,10906,"Tell me, am I wrong?"],[10944,11194,"Even Elaine, my assistant,"],[11194,11336,"did more for this family"],[11369,11473,"than you ever did."],[11515,11695,"She helped me secure"],[11695,11815,"the billion-dollar contract"],[11815,11911,"with the Carringtons."],[12074,12116,"Wow."],[12116,12258,"I really cannot wait for you"],[12258,12354,"to understand this."],[12354,12537,"Everything that you have right now,"],[12558,12629,"all of it."],[12758,12879,"I gave it to you."]],"15":[[45,166,"I gave it to you."],[367,442,"You?"],[500,709,"You gave me everything I have?"],[800,871,"How?"],[946,1059,"By cooking?"],[1105,1317,"By doing my laundry?"],[1384,1509,"By taking care of Grace?"],[1664,1893,"I can easily throw some money"],[1893,2102,"at service to do all of that for me."],[2168,2327,"I put a roof over your head."],[2356,2560,"What else do you want from me?"],[2727,2902,"Stop insulting Nicole,"],[2932,3019,"or you'll regret it."],[3069,3194,"How dare you hit me?"],[3812,3903,"Very well, Nicole."],[3937,4037,"You're leaving me, huh?"],[4058,4191,"Spending all my money"],[4191,4379,"on some hot shot lawyer against me."],[4608,4738,"Divorce me and I'll sign it."],[4929,5105,"I can't wait to see"],[5105,5263,"what your life looks like without me."],[5321,5638,"Soon, I'll have the Carrington contract."],[5663,5747,"And you"],[5914,6001,"will have nothing!"],[6335,6731,"Nicole, you could wash all the dishes,"],[6731,6856,"scrub all the toilets"],[6856,6990,"for the rest of your life."],[6990,7223,"And you won't even make a crumb"],[7223,7403,"of what Ethan's going to make."],[7428,7565,"Are you going to have Grace"],[7565,7699,"live in the ghetto with you?"],[7699,7832,"She's just a kid."],[7853,7887,"Okay,"],[7887,8003,"it's just a ten-billion-dollar"],[8003,8062,"contract."],[8062,8133,"You can stop gloating."],[8133,8283,"Besides, you're not going to get it."],[8345,8554,"Just a ten-billion-dollar"],[8554,8621,"contract?"],[8637,8796,"Did you lose your mind"],[8796,8908,"when you were in prison?"],[8929,9046,"Do you have any idea"],[9046,9196,"how much money that is?"],[9275,9367,"When this contract"],[9367,9505,"doesn't work out, when,"],[9542,9626,"not if,"],[9701,9868,"don't come crying to me for my help."],[9980,10064,"You're not gonna get any."],[10598,10681,"Wait!"],[10773,11031,"I didn't say you could take Grace."],[11765,11874,"Congrats, Mr. Carter."],[11932,12070,"You just lost the one person"],[12070,12178,"who will ever love you."],[12741,12858,"Who is that guy?"],[12908,13121,"He seems so powerful."],[13192,13317,"I know who that is."],[13363,13467,"That's Damon Hawthorne."],[13521,13646,"The country's best lawyer."],[13688,13755,"What?"],[13788,13926,"How could Nicole afford"],[13926,14022,"someone like him?"],[14185,14272,"Oh my God."],[14326,14514,"That is how she got out of jail"],[14514,14610,"so easily."],[14714,14864,"She's sleeping with him."],[14902,14960,"Nicole."],[15048,15169,"How dare you betray me."],[15256,15452,"Once I sign the Carrington contract,"],[15452,15590,"you'll regret leaving me."]],"16":[[204,283,"Grandpa!"],[554,863,"Oh, it's just my sweet granddaughter,"],[863,930,"Grace."],[1080,1213,"This is wonderful."],[1242,1384,"My dream has come true."],[1405,1576,"My daughter and my granddaughter"],[1576,1685,"have come back."],[1797,1901,"Let's put you down."],[2097,2202,"And since you're back,"],[2268,2352,"you can check over"],[2352,2535,"as CEO of the Carrington Group."],[2652,2748,"Effective immediately."],[2819,2865,"Well..."],[3161,3215,"Now?"],[3228,3299,"That's right."],[3332,3457,"I've decided to retire"],[3457,3595,"and spend more time"],[3595,3766,"with my precious granddaughter."],[3787,3824,"I..."],[3883,3974,"Thank you."],[3974,4091,"I promise, Dad,"],[4091,4154,"I won't let you down."],[4154,4225,"I swear."],[4462,4713,"I suppose you're my boss"],[4713,4829,"starting from now on then,"],[4888,4967,"Ms. Carrington."],[5038,5113,"Hmm."],[5563,5643,"And to celebrate"],[5643,5805,"my princess's coming home,"],[5805,6014,"let's plan a grand Carrington banquet"],[6014,6093,"for next week."],[6093,6268,"Invite everybody who's anybody."],[6268,6368,"I want them here."],[6414,6589,"It's time they met the one and only,"],[6673,6806,"Carrington Heiress."]],"17":[[1076,1167,"This is it."],[1192,1322,"The world I belong to."],[1434,1655,"Soon, I'll be one of them."],[1768,1964,"You see those men over there?"],[1989,2260,"Some of the highest ranking politicians"],[2260,2389,"in the country."],[2456,2644,"And you see those people over there?"],[2711,2898,"Some of the wealthiest families"],[2898,3078,"from each and every state."],[3724,3837,"And there it is."],[3837,4012,"Sitting right there."],[4083,4333,"The ten-billion-dollar contract"],[4333,4412,"we'll be signing"],[4412,4529,"with the Carrington Group."],[4529,4904,"I can't thank you enough"],[4934,5088,"for getting us this contract, Elaine."],[5142,5334,"You really are the best family"],[5334,5459,"Nicole and I can ask for."],[5543,5734,"They're already divorced."],[5734,5922,"Why is he hung up on Nicole?"],[5955,6185,"She's just a worthless housewife."]],"18":[[4137,4229,"Ms. Carrington,"],[4270,4433,"the guests are arriving soon."],[4433,4512,"You may head down"],[4512,4604,"whenever you're ready."],[4746,4825,"Okay."],[4967,5030,"Let's go."]],"19":[[108,271,"I can't believe this."],[271,425,"This party is so luxurious."],[425,487,"Of course."],[487,638,"Mr. Carrington is the richest man"],[638,734,"in the country."],[734,892,"And he held this grand party"],[892,1051,"to welcome back his sole heiress"],[1051,1280,"who's been away for seven years."],[1280,1455,"I heard Mr. Carrington"],[1455,1589,"is announcing her"],[1589,1780,"as the new CEO tonight."],[1814,1956,"And she's going to be the one"],[1956,2135,"signing the contract with us."],[2135,2227,"Really, Elaine?"],[2227,2298,"So your,"],[2298,2427,"ten-billion-dollar business"],[2427,2565,"that's settled?"],[2565,2660,"That's right."],[2690,2798,"You know, and I heard it"],[2798,3019,"from Mr. Rook himself,"],[3019,3199,"the chief investing director"],[3199,3332,"of the Carrington family."],[3349,3549,"I wonder where this heiress is."],[3549,3678,"Be patient, Ethan."],[3762,3912,"You know, I'm sure Mr. Carrington"],[3912,4175,"is preparing a grand entrance for her."],[4258,4429,"But you know, I'm curious too."],[4429,4487,"But you know, I'm curious too."],[4487,4746,"Who is this secret heiress"],[4746,4971,"that gave up this family fortune"],[4971,5071,"for seven years?"],[5071,5113,"for seven years?"],[5226,5317,"Seven years?"],[5372,5438,"That was how long"],[5438,5551,"Nicole and I were married."],[5576,5714,"Well, no matter what,"],[5714,5880,"we should toast to your success"],[5910,5960,"and that"],[5960,6118,"ten-billion-dollar contract."],[6118,6193,"Thank you."],[6285,6343,"Look!"],[6343,6468,"It must be the heiress."],[8404,8546,"How could it be her?"]],"20":[[934,1017,"How the hell"],[1017,1159,"did you sneak in here, Nicole?"],[1317,1393,"Sneak in?"],[1501,1630,"I was escorted in"],[1730,1822,"with respect."],[1868,2093,"You're just here to get Ethan back"],[2093,2189,"since he's closing"],[2189,2360,"a ten-billion-dollar deal."],[2406,2489,"Wow."],[2523,2819,"You even bought this fake designer dress."],[2844,2952,"Please, you're just gonna"],[2952,3136,"embarrass yourself and Ethan."],[3136,3349,"You really think I want Ethan back?"],[3641,3753,"Take a look around this room."],[3803,3933,"Every person in there"],[3933,4179,"makes Ethan look like nothing."],[4358,4454,"Like this rug."],[4471,4546,"It looks expensive,"],[4546,4671,"but it's actually just there"],[4671,4754,"to be mocked on."],[4879,4975,"Go back to your"],[4975,5134,"pathetic housewife life, Nicole."],[5134,5180,"Oh."],[5201,5330,"This is my first time"],[5397,5584,"breaking into real high society."],[5739,5805,"Nicole."],[5918,5972,"If you're here"],[5972,6106,"to talk about getting back together,"],[6156,6352,"at least wait until I sign the contract"],[6352,6418,"with the heiress."],[6531,6669,"Oh, Ethan."],[6798,6915,"You still don't get it."],[6973,7228,"If I leave, this entire event"],[7298,7386,"would be over."],[7440,7503,"Oh."],[7503,7607,"Sweetheart."],[7645,7949,"Mr. Rook invited us personally to close"],[7949,8078,"the ten-billion-dollar deal."],[8116,8237,"So just leave now"],[8237,8425,"before you embarrass yourself."],[8450,8650,"Or we have to have security"],[8650,8712,"kick you out."],[8712,8800,"Oh no."],[8842,9021,"You mean Owen Rooks?"],[9021,9138,"Chief Investment Officer"],[9138,9238,"at the Carrington Group?"],[9238,9255,"Wow."],[9255,9384,"You even did your homework"],[9384,9517,"just to get Ethan back."],[9601,9667,"You even know the name"],[9667,9738,"of the Carrington's"],[9738,9864,"Chief Investment Director."],[10543,10602,"Hi."],[10652,10744,"Have Owen Rooks"],[10744,10873,"meet me here immediately."],[10935,11102,"If he's not here in one minute,"],[11223,11282,"fire him."]],"21":[[617,700,"Have Owen Rook"],[700,834,"meet me here immediately."],[859,1030,"If he's not here in one minute,"],[1055,1121,"fire him."],[1142,1201,"Understood."],[1284,1405,"Damon Hawthorne?"],[1405,1584,"The famous lawyer and lover of Ethan’s"],[1584,1659,"ex-wife?"],[1659,1797,"What is he doing here?"],[1797,2056,"Mr. Hathorne, I've been looking for you."],[2097,2231,"I hear the heiress, Miss Carrington,"],[2231,2389,"has taken over as CEO at the party."],[2419,2473,"I was hoping you"],[2473,2598,"could introduce us beforehand."],[2619,2665,"Oh."],[2665,2811,"What a coincidence, Owen."],[2811,2923,"I actually just got off the phone"],[2923,3028,"with Ms. Carrington."],[3028,3123,"She wants to see you down"],[3123,3228,"in the main hall."],[3253,3349,"And, let’s see here,"],[3349,3536,"you've got 40 seconds"],[3536,3636,"before you're fired."],[3728,3849,"I, I'm on my way."],[3849,3903,"Yeah."],[4245,4429,"Mr. Rook is about to be promoted"],[4429,4542,"by the Carringtons."],[4571,4683,"One deal with him"],[4683,4754,"could turn someone"],[4754,4934,"into a millionaire overnight."],[5000,5171,"Who are you to fire him?"],[5284,5384,"One word"],[5538,5643,"is all it takes."],[7440,7607,"How dare you sit there?"],[7645,7741,"That is reserved"],[7741,7957,"for the heiress of the Carrington family."],[7957,8016,"Yes."],[8133,8204,"Move!"],[8204,8312,"Move out of my way!"],[8504,8812,"There's no need to panic, Owen."],[8812,8963,"You don't know a damn thing."],[8979,9117,"Ms. Carrington is the sole heir"],[9117,9188,"to this empire."],[9271,9363,"Her word is law."],[9563,9622,"Get up."],[9622,9718,"You can't sit there."],[9901,10047,"What the hell do you think you're doing?"]],"22":[[25,183,"Ms. Carrington?"],[204,454,"Ms. Carrington, yeah, right."],[454,650,"Don't let her fool you, Owen."],[650,871,"She is just a troublemaker."],[900,1038,"You won't believe this."],[1059,1263,"She said that she could fire you."],[1372,1476,"Seriously?"],[1559,1668,"Look what you did, Nicole."],[1760,2006,"You're gonna pay for your stupid lies."],[2006,2273,"Oh, I can guarantee it, Owen."],[2273,2414,"She just got in here"],[2414,2598,"with the help of Mr. Hawthorne."],[2598,2723,"She's his mistress,"],[2723,2936,"and she's trying to fool you."],[2936,3061,"We're telling the truth."],[3061,3211,"I swear it, Mr. Rook."],[3378,3465,"Even Ms. Carrington's"],[3465,3570,"most trusted staff"],[3570,3699,"wouldn't say something like that."],[3741,3866,"Who exactly are you"],[3866,3974,"to the Carrington family?"],[3987,4104,"She's a nobody."],[4104,4358,"A worthless piece of trash."],[4379,4521,"She was dumped by her husband."],[4546,4729,"and in jail until last week."],[4729,4888,"She hurt her own daughter"],[4888,5071,"and ended up behind bars."],[5071,5267,"And the only reason that she got out"],[5267,5422,"is because she's sleeping"],[5422,5555,"with Mr. Hawthorne."],[5855,5926,"Ethan!"],[5960,6147,"She's making all this mess"],[6147,6281,"to get back at you."],[6302,6443,"She wants to ruin your"],[6443,6606,"ten-billion-dollar deal."],[6631,6844,"Nicole, I never thought"],[6844,6994,"you'd pull a despicable scheme"],[6994,7065,"like this."],[7098,7219,"Why hasn't security"],[7219,7349,"thrown this tramp out yet?"],[7461,7590,"Get out of that throne now."],[7611,7761,"That is reserved for Ms. Carrington."],[7761,7874,"Owen,"],[8099,8287,"are you really that stupid?"],[8299,8608,"Did she just insult"],[8608,8792,"Owen Rook?"]],"23":[[41,162,"What are you all waiting for?"],[212,379,"Someone take care of this bitch now."],[404,563,"We can't have Ms. Carrington see this."],[583,779,"You idiots, kick her out now."],[842,1026,"Crawl back into the sewer"],[1026,1101,"where you belong."],[1101,1347,"You disgusting fucking rat."],[1451,1572,"Woo, okay."],[1572,1730,"Owen Rook."],[1730,1856,"Chief Investment Director,"],[1856,2031,"and you can't even think for yourself."],[2198,2285,"Pathetic."],[2285,2394,"Do you have any idea"],[2394,2489,"how important I am"],[2489,2594,"to the Carrington Group?"],[2594,2681,"I was the head"],[2681,2932,"of this billion-dollar contract before you."],[3011,3140,"Who the hell are you?"],[3161,3215,"Yeah."],[3249,3349,"Head of Investments"],[3349,3453,"at the Carrington Group."],[3628,3716,"And you're making what?"],[3716,3903,"You said billion-dollar deals"],[3903,4070,"with a company that lacks integrity."],[4333,4425,"Are you serious?"],[4441,4587,"How dare you touch"],[4587,4733,"our contract with your dirty hands."],[4788,4913,"Put it down."],[5613,5764,"Throw her out now!"]],"24":[[300,429,"She just threw garbage at me"],[429,567,"and you two idiots stood there."],[567,663,"Get her out of here."],[692,813,"Open your eyes, Owen."],[884,1059,"See exactly who I am."],[1247,1530,"Now, am I going to have to fire you"],[1530,1634,"or are you going to resign?"],[1634,1860,"You crazy bitch."],[1889,2089,"Have you lost your damn mind"],[2089,2239,"when you were in that prison?"],[2277,2498,"You think tearing up some paper"],[2498,2594,"is going to cancel"],[2594,2744,"a ten-billion-dollar deal?"],[2744,2927,"Fooling a stunt like this"],[2927,3061,"at such a classy event."],[3090,3203,"How dare you?"],[3203,3345,"And insulting the very man"],[3345,3486,"who invited us here?"],[3545,3699,"You oughta be ashamed."],[3724,3787,"Wrong."],[3803,4049,"This entire event had nothing to do"],[4049,4166,"with this idiot."],[4225,4462,"You're all here because I allowed it."],[4462,4629,"Oh, really?"],[4654,4833,"If you're so powerful,"],[4867,5046,"then how did you end up in prison?"],[5088,5171,"Nicole,"],[5226,5380,"have you really lost your goddamn mind"],[5380,5480,"because I sent you to jail?"],[5505,5618,"You called me an idiot?"],[5651,5705,"Fine."],[5764,5914,"I'll teach you a lesson myself."],[6389,6514,"I'd like to see you try."]],"25":[[241,342,"Mr. Hawthorne."],[458,550,"You got here just in time."],[550,842,"This lunatic crashed the event"],[842,1005,"and tore up our contract."],[1055,1109,"Please,"],[1209,1272,"you need to make sure"],[1272,1376,"she gets arrested."],[1468,1701,"See how angry Mr. Hawthorne is?"],[1818,1889,"You're done."],[1943,2081,"You arrogant little-"],[2081,2206,"Watch your mouth, Owen."],[2523,2602,"Mr. Rook."],[2640,2819,"My mother and I just told you,"],[2836,2944,"that woman"],[2944,3144,"is Mr. Hawthorne's mistress,"],[3157,3361,"and that is why he's siding with her."],[3403,3511,"Mr. Hawthorne,"],[3591,3699,"you can't keep defending"],[3699,3762,"this woman."],[3845,3912,"I know you're"],[3912,3995,"the most powerful attorney"],[3995,4070,"in the country,"],[4070,4229,"but you still work for the Carringtons."],[4229,4416,"She ruined the gala"],[4416,4500,"and tore up our"],[4500,4696,"ten-billion-dollar contract."],[4708,4879,"We all saw it."],[4959,5192,"Stop protecting this bitch"],[5192,5434,"or Ms. Carrington will not forgive you"],[5434,5572,"when she arrives."],[5597,5676,"That's right."],[5714,5