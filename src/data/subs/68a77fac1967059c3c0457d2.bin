f honor"],[7978,8120,"for the pep rally."],[8120,8262,"All right, let's go."],[9188,9334,"Time to show them exactly"],[9334,9467,"who the real heiress is."],[9509,9584,"What does she think"],[9584,9672,"she's doing?"],[9709,9876,"She's not sitting in the heiress' seat,"],[9876,9930,"is she?"],[9997,10055,"You asked for the"],[10055,10172,"Lancaster heiress."],[10172,10235,"Well,"],[10381,10477,"here I am."]],"24":[[296,404,"Are you insane?"],[404,475,"That seat is"],[475,663,"for the Lancaster heiress."],[663,738,"I know you're desperate"],[738,850,"for attention, Sierra."],[850,950,"This is a whole new low."],[950,1084,"Some girls will do anything"],[1084,1172,"for attention."],[1409,1559,"Sierra."],[1559,1664,"Get off the chair"],[1664,1789,"now!"],[1789,1881,"Why?"],[1881,2031,"It's mine."],[2031,2218,"Dude, you're the quarterback."],[2218,2323,"This is your pep rally, too."],[2323,2523,"And she's totally hijacking it."],[2552,2677,"You should talk to her."],[2677,2777,"Tell her to come down."],[2777,2936,"Nah, nah."],[2936,3053,"She knows what she's doing."],[3053,3107,"Oh."],[3311,3428,"I have no idea"],[3428,3536,"if Sierra really is"],[3536,3703,"Lancaster heiress."],[3703,3933,"But either way, this is badass."],[3933,4083,"Get her off!"],[4083,4233,"Get her off!"],[4233,4391,"Get her off!"],[4391,4637,"Get her off!"],[4637,4821,"Get her off!"],[4821,4867,"Coach!"],[5005,5105,"Isn't"],[5105,5226,"that a portrait"],[5226,5359,"of the Lancaster heiress?"],[5359,5492,"Why don't we"],[5492,5609,"show it to everyone?"],[5609,5726,"She's bluffing, coach."],[5726,5847,"There's no way this delinquent"],[5847,6035,"is the Lancaster heiress."],[6035,6089,"Yeah."],[6089,6202,"Fallon's right."],[6202,6277,"If Sierra’s ugly"],[6277,6393,"face is on that portrait-"],[6393,6452,"Then what?"],[6556,6710,"Streak across the field?"],[6710,6802,"Are you sure you want"],[6802,6948,"to do that again today?"],[7157,7194,"Coach,"],[7194,7290,"how long are we going"],[7290,7407,"to let her drag the Lancaster"],[7407,7536,"name through the mud?"],[7536,7661,"She's an embarrassment."],[7661,7778,"She's ruining everything"],[7778,7816,"this school"],[7816,7991,"stands for. -Yeah!"],[7991,8103,"And we can end it all."],[8141,8283,"If we prove that she's lying,"],[8283,8350,"then you can send"],[8350,8437,"her back to juvie"],[8437,8596,"where she belongs."],[8596,8812,"Go on, do it."]],"25":[[16,191,"Go on."],[191,271,"Do it."],[646,754,"Do it!"],[754,867,"Do it!"],[867,1017,"Whoa, whoa, whoa, whoa."],[1017,1222,"Hands off the Lancaster portrait."],[1222,1359,"I spoke with Mr. Lancaster"],[1359,1497,"this morning."],[1497,1609,"It's not to be revealed"],[1609,1760,"till homecoming next week."],[1956,2064,"But sir, if we could just-"],[2064,2135,"I said"],[2135,2293,"hands off."],[2293,2477,"What Mr. Lancaster wants,"],[2540,2756,"Mr. Lancaster gets."],[2756,2819,"Fine!"],[2932,3011,"But we can't let"],[3011,3148,"her breathe the same air"],[3148,3274,"as the Lancaster heiress,"],[3274,3474,"let alone sit in her seat."],[3499,3599,"Principal Gordon."],[3599,3799,"We have to expel her now"],[3799,3887,"before she ruins"],[3887,4087,"the reputation of this school."],[4104,4170,"Yeah."],[4266,4333,"Fine!"],[4400,4637,"Expel me, but you'll regret it,"],[4637,4825,"when my grandfather stops"],[4825,5046,"donating millions to this school."],[5071,5201,"Come on, Sierra."],[5201,5388,"You're broke and irrelevant."],[5422,5484,"No one would miss you"],[5484,5605,"if you left the school."],[5605,5701,"In fact,"],[5701,5868,"I think we'd all celebrate right?"],[6018,6114,"Quiet!"],[6197,6364,"Sierra."],[6364,6564,"Where are your clothes?"],[6589,6777,"You have been nothing but trouble"],[6777,6835,"since you've walked"],[6835,6965,"through the door."],[6965,7136,"I have no choice but to expel you."],[8888,9021,"Who the hell are you people?"],[9021,9154,"Lancaster guard."],[9154,9300,"We're here for the heiress."],[9300,9380,"Uh... but sir,"],[9380,9538,"she didn't show up yet."],[9538,9705,"Are you blind?"],[9705,9793,"She's right there."]],"26":[[154,354,"OMG, is it, is it really her?"],[433,504,"Could she really be"],[504,563,"the heiress?"],[875,946,"But,"],[959,1255,"but that actually isn't her."],[1401,1501,"Miss Lancaster,"],[1501,1647,"it's time to go home."],[1647,1705,"We'll be outside"],[1705,1810,"when you're ready."],[2986,3065,"Is she really"],[3065,3265,"the heiress after all?"],[3353,3553,"Hey, can I get your Snapchat?"],[3566,3712,"Whoa!"],[3712,3853,"She must really be the heiress."],[3853,3978,"Sierra is no heiress."],[3978,4045,"She probably just"],[4045,4112,"called in a favor"],[4112,4245,"from some mafia thug son"],[4245,4446,"she sucked off in juvie."],[4496,4696,"I don't see your convoy, Fallon."],[4696,4725,"Yeah..."],[4725,4850,"You promised us we could ride with"],[4850,5046,"the heiress to your party."],[5050,5146,"Yeah, well, I was just like-"],[5146,5221,"Sierra!"],[5221,5363,"Are you coming to the party?"],[5363,5563,"Miss Lancaster."],[5789,5989,"Have fun at your party, Fallon."],[6022,6160,"I sure do hope that the heiress"],[6160,6252,"shows up."],[6252,6452,"It would be so embarrassing"],[6452,6527,"if she didn't come to"],[6527,6652,"her own birthday party."],[7027,7148,"Oh, that bitch is"],[7148,7349,"ruining everything."],[7382,7499,"But I refuse to let"],[7499,7590,"her ruin my party."]],"27":[[450,538,"All right then."],[738,825,"Here we are."],[1117,1317,"Right this way."],[1451,1501,"Please,"],[1501,1580,"after you."],[2339,2540,"I seriously live here now?"],[2598,2736,"Yes, Miss Lancaster."],[2736,2831,"Your bedroom spans"],[2831,2969,"the entire fourth floor."],[3094,3190,"You have a private chef"],[3190,3378,"available to you 24/7."],[3378,3570,"Fresh cut flowers every day."],[3570,3724,"And your own private driver"],[3724,3924,"on standby at all times."],[3941,4008,"Oh, and I've taken"],[4008,4062,"the luxury"],[4062,4166,"of stocking your vanity"],[4166,4279,"with the finest