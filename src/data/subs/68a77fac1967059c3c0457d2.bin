s..."],[2990,3048,"good."],[3107,3236,"Different is very good."],[3294,3557,"You're different too."],[3791,4008,"A football player who’s sweet,"],[4008,4062,"and not,"],[4195,4512,"an arrogant jock idiot."],[4654,4717,"It's..."],[4804,4879,"It's weird."],[5013,5142,"Is that a good thing?"],[5171,5334,"Weird's good."],[5501,5638,"Weird's very good."],[6360,6493,"Sierra."],[6493,6644,"It's time you met your grandfather."],[6702,6810,"I have a car waiting for you."]],"37":[[83,233,"I'll see you tomorrow."],[892,984,"Finally,"],[1042,1234,"my granddaughter is home."],[1267,1359,"Grandpa?"],[1714,1856,"Let me look at you."],[2014,2181,"You have your father's eyes"],[2260,2460,"and your mother's smile."],[2485,2610,"We have a lot to catch up on."],[2610,2756,"It’s been 12 years."],[2894,2940,"So."],[2982,3078,"How's school?"],[3503,3578,"It's..."],[3716,3812,"an adjustment."],[4049,4270,"Would this Blakely girl"],[4316,4466,"have anything to do with that?"],[4521,4646,"Because she is a"],[4646,4754,"horrible person."],[4808,4950,"Her father is horrible."],[4979,5084,"Grandpa."],[5163,5321,"Sweetheart, if you ever need"],[5321,5459,"me to make a phone call,"],[5484,5726,"I can ruin them like that!"]],"38":[[258,337,"Thanks,"],[458,596,"but no,"],[663,809,"this is something that I have"],[809,946,"to handle myself."],[975,1092,"Look at you."],[1092,1251,"You're just like your mother."],[1251,1455,"You're smart and you’re strong"],[1455,1555,"and you're tough."],[1589,1885,"If you ever need anything,"],[1964,2089,"you ask me."],[2147,2298,"Because now that you're here,"],[2402,2556,"I'm never going to let you go."],[2952,3003,"Oh."],[3203,3399,"I believe this"],[3440,3553,"belongs to you."],[3995,4091,"Happy birthday."],[4124,4233,"Thanks, Grandpa."],[4479,4575,"So, to sum it up."],[4612,4804,"A squared plus B squared"],[4808,5009,"will always equal C squared."],[5075,5167,"Any questions?"],[5226,5321,"Yes, Fallon."],[5334,5409,"Thank you for the"],[5409,5601,"riveting lesson, Mrs. Nolan."],[5626,5693,"I actually want"],[5693,5822,"to take a moment to remind"],[5822,5935,"everybody that voting"],[5935,6031,"for homecoming opens"],[6031,6122,"this afternoon."],[6131,6222,"I know I don't have"],[6222,6318,"any competition-"],[6318,6431,"Actually you do."],[6431,6556,"Thanks for reminding me."],[6585,6635,"What?"],[6635,6785,"We have a new nominee"],[6785,6911,"for homecoming court."],[7002,7102,"Sierra!"],[7286,7361,"Whoa!"]],"39":[[296,396,"As if anyone would"],[396,500,"actually vote for you."],[542,709,"Once the heiress finally arrives"],[709,834,"and endorses me"],[834,963,"as homecoming queen,"],[975,1176,"your campaign will be dead."],[1188,1305,"We'll see about that."],[1376,1497,"Oh, face it, Sierra."],[1497,1618,"Everybody knows"],[1618,1739,"you're just a desperate"],[1739,1926,"wannabe clinging on to a fantasy."],[1943,2102,"This school is mine now."],[2102,2206,"You really think so?"],[2302,2364,"Well,"],[2423,2615,"when I win homecoming queen"],[2615,2727,"and my portrait"],[2727,2873,"is revealed at the dance,"],[2902,3048,"everyone will know you"],[3048,3211,"for the liar that you really are."],[3211,3278,"Well, what about when"],[3278,3403,"I'm crowned queen"],[3403,3524,"and that portrait looks"],[3524,3611,"nothing like you?"],[3641,3732,"Well then,"],[3795,3983,"I'll tell everyone that I lied"],[4012,4108,"and"],[4124,4270,"and I'll leave Hawthorne,"],[4270,4337,"for good."],[4387,4629,"Oh, Sierra. Heiress or not,"],[4629,4754,"I have this school"],[4754,4892,"wrapped around my finger."],[4959,5138,"So you better start packing."]],"40":[[254,379,"Mrs. Nolan."],[433,554,"How could Sierra run"],[554,638,"for homecoming queen"],[638,775,"without a date?"],[850,1009,"Yes, Fallon's right."],[1009,1192,"Sierra, you need a running partner"],[1192,1338,"to qualify for homecoming"],[1338,1405,"court."],[1480,1680,"What is this,1955?"],[1693,1885,"This is tradition, young lady."],[1885,2006,"You need to submit your running mate"],[2006,2089,"by the end of today"],[2089,2231,"or I'm afraid you will be"],[2231,2318,"disqualified."],[3999,4079,"You need to make sure"],[4079,4166,"that bitch doesn't get a date"],[4166,4245,"to homecoming."],[4325,4441,"Don't worry, my queen."],[4466,4587,"I know just what to do."],[4617,4817,"Nobody is coming for my crown."],[4863,4988,"Especially not her."],[5930,6043,"That desperate skank"],[6043,6168,"should've never come back here."],[7499,7615,"And now, no one will touch you."]],"41":[[346,458,"Hey, what’s going on?"],[629,709,"Yo!"],[709,821,"Check it out."],[850,984,"Damn, I knew she was shady,"],[984,1163,"but that's crazy."],[1188,1288,"Bro, no wonder"],[1288,1430,"Jake dumped her ass."],[1430,1676,"Dude dodged a fucking bullet!"],[1676,1768,"Bro, bro."],[1789,2039,"Yo, dude, you gotta post that."],[2227,2293,"Oh, shit."],[3123,3282,"Oh, shit!"],[3282,3495,"It's the chlamydia queen!"],[3532,3770,"You juvie girls really do get around."],[3782,3858,"Holy shit."],[3858,3895,"I'm sorry,"],[3895,3970,"what did you just call me?"],[3970,4020,"Yo, yo!"],[4020,4145,"Stay back up! Stay back up!"],[4145,4300,"I'm not trying to be your next victim."],[4375,4425,"What the hell"],[4425,4517,"are you talking about?"],[4517,4650,"Oh, you know."],[4771,4879,"Check the bathroom."],[6068,6268,"I know Jake's writing anywhere."],[6293,6389,"Sierra, please."],[6389,6506,"If I go to juvie,"],[6506,6635,"then I'm off the team."],[6639,6731,"Oh, come on. Sierra,"],[6861,6948,"you're smart."],[6948,7036,"Oh. Come on."],[7036,7152,"You can get through this."],[7499,7624,"We're gonna join homecoming court"],[7624,7703,"next year,"],[7703,7786,"I promise."],[7786,7941,"I can't wait to make you my queen."],[8008,8087,"Jake."],[8170,8308,"All I wanted was to go to the"],[8308,8391,"homecoming dance"],[8391,8583,"and show Jake who I really am."],[8604,8737,"Who he betrayed."],[8737,8942,"To show Fallon that the heiress"],[8942,9104,"she's so desperate to buddy"],[9104,9246,"up to was me all along."],[9317,9517,"Now no one will believe me."],[9567,9768,"No one will go anywhere near me."],[9976,10072,"Sierra?"]],"42":[[120,271,"What are you doing?"],[429,529,"Who the hell wrote that?"],[671,846,"I, I swear it's not true."],[846,1101,"I've never even slept with anyone"],[1101,1197,"and Jake,"],[1197,1376,"just forget I ever said that."],[1539,1639,"Hey, hey, hey."],[1685,1776,"It's forgotten."],[1805,1868,"All right?"],[2031,2139,"All right."],[2256,2364,"I'll talk to the other guys on"],[2364,2469,"the football team."],[2535,2581,"Make sure we get this rumor"],[2581,2744,"squashed before it even gets started."],[2911,3086,"All right?"],[3086,3319,"You know, even if it was true,"],[3465,3561,"you shouldn't be crucified"],[3561,3628,"for this."],[3678,3807,"Athlete's foot ran rampant"],[3807,3895,"through the wrestling"],[3895,4012,"team of my old high school,"],[4012,4112,"but you didn't see the girls"],[4112,4266,"writing that shit on the walls."],[4404,4546,"Jake's a fucking idiot."],[4637,4754,"You're so nice to me and"],[4754,4884,"no one else is."],[5000,5063,"Why?"],[5259,5455,"You, uh, probably don't remember"],[5455,5559,"this, but"],[5668,5747,"we actually went to"],[5747,5876,"the same middle school."],[6006,6260,"I was this huge nerd and"],[6373,6443,"these kids were always"],[6443,6627,"threatening to kick my ass."],[6769,6944,"The one time they almost did you, uh,"],[7136,7248,"you saved me."],[7707,7899,"Help me! Help me! Help me!"],[7899,8020,"Hug me quickly!"],[8020,8195,"They won't see you."],[8571,8658,"Get out!"],[8658,8737,"Move!"],[9163,9205,"You're a good"],[9205,9330,"person, Sierra."],[9601,9680,"That's why I like you."]],"43":[[233,350,"Say that again."],[554,629,"I like you,"],[742,809,"Sierra."],[1030,1151,"I want to ask you something."],[1301,1401,"Something I've been thinking about"],[1401,1526,"ever since you almost tackled me"],[1526,1643,"outside of the school."],[2519,2694,"You're never going to let me forget it."],[2706,2806,"It's one of"],[2806,2948,"my favorite memories now."],[3053,3111,"Sierra."],[3332,3361,"Would you go"],[3361,3440,"to Homecoming with me?"],[3678,3816,"Are you sure you want to go with"],[3816,3945,"the “chlamydia queen”"],[3966,4091,"straight out of juvie?"],[4245,4295,"I wouldn't have it"],[4295,4354,"any other way."]],"44":[[513,600,"I think somebody found"],[600,709,"her homecoming dress."],[821,892,"Last week,"],[892,1059,"I was in a juvie jumpsuit,"],[1059,1230,"and now, this."],[1230,1343,"It's perfect."],[1397,1463,"I'll take it."],[1522,1601,"Excellent choice."],[1605,1747,"I'll be at the register when you're ready."],[2515,2598,"Oh, you've got to be"],[2598,2711,"fucking kidding me."],[2840,2957,"If you think you're wearing"],[2957,3082,"my dress to homecoming,"],[3082,3249,"you've completely lost your mind."],[3249,3390,"Your dress? I don't,"],[3516,3611,"I don't see your name"],[3611,3716,"anywhere on it."],[3770,3870,"Luca Devereaux"],[3870,4070,"only designed two of these dresses,"],[4129,4270,"and one of them is for the heiress."],[4320,4458,"We're going to match."],[4458,4637,"Well then, why isn't the heiress"],[4637,4808,"here with you trying it on?"],[4888,5088,"She doesn't need to be here, you idiot."],[5109,5317,"As the heiress’ bestie and her new"],[5317,5442,"personal stylist,"],[5463,5647,"I handle things like that for her."],[5647,5784,"Can you even afford to be here"],[5784,5847,"right now, Sierra?"],[5872,5976,"Yeah, did you get lost"],[5976,6081,"on the way to the Goodwill?"],[6231,6352,"Take the dress off,"],[6410,6468,"now."],[6519,6644,"Over my dead body."],[6660,6861,"Oh, that can be arranged."],[7315,7436,"Everything okey in there?"]],"45":[[175,279,"Everything's fine."],[279,387,"Thank you."],[454,567,"Okey, have fun."],[942,1034,"Get up!"],[1330,1430,"Ow!"],[1868,2043,"Are you going to take that dress off?"],[2060,2164,"Or are we going to have to"],[2164,2273,"take it off for you?"],[2318,2406,"You know, it's insane how"],[2406,2544,"much better you look in it, Fallon."],[2606,2723,"Is it surprising?"],[2731,2932,"Only Sierra can make a $5,000 dress"],[2932,3032,"dress look like it came from"],[3032,3119,"Forever 21."],[3294,3382,"Take it off."],[3403,3532,"Yeah, take it off."],[3991,4149,"Get your hands off of me!"],[4158,4254,"Excuse me?"],[4254,4383,"We don't take orders from low"],[4383,4587,"class skanks, like you."],[4637,4788,"You are not leaving in that dress."],[4821,5000,"If Luca Devereaux knew"],[5000,5167,"that a sewer rat like you"],[5167,5301,"even touched it,"],[5301,5430,"they would be disgusted."],[5613,5714,"Let me introduce you to Luca Devereaux,"],[5714,5797,"Luca Devereaux,"],[5797,5980,"celebrity stylist to the stars."],[6039,6143,"What do you think?"],[6193,6272,"You’re ready."],[6297,6418,"Maybe I should call her"],[6418,6544,"and ask who she thinks"],[6544,6627,"looks better in the dress?"]],"46":[[70,183,"Oh my God,"],[183,437,"again with your delusional lies."],[471,638,"You seriously want us to believe"],[638,867,"that you know Luca Devereaux?"],[934,1021,"Please,"],[1021,1201,"she dresses stars for the Met Gala."],[1222,1347,"Why would she waste time"],[1347,1522,"with a washed-up juvie reject"],[1522,1589,"like you?"],[1626,1680,"I don't know."],[1680,1797,"Why don't you ask her?"],[2081,2185,"Excuse me."],[2444,2544,"Can you get Luca Devereaux"],[2544,2606,"on the phone?"],[2673,2911,"Seriously, who even are you?"],[3165,3261,"Fine."],[4525,4679,"Hi Miss Devereaux."],[4763,4859,"You are?"],[4950,5038,"Okey, I will."],[5221,5363,"She's on her way now."],[5513,5622,"Enjoy wearing that dress"],[5622,5772,"while you can Fallon."],[5830,5914,"Shit."],[5930,6089,"I made up that story about the dress."],[6143,6322,"If Luca ever actually shows up,"],[6322,6456,"my entire reputation"],[6456,6581,"is going up in flames."]],"47":[[271,396,"Forget it."],[396,450,"I've had enough"],[450,567,"with your game, Sierra."],[600,729,"Besides, who wants a cheap dress"],[729,813,"like that anyways?"],[921,1101,"You did like five minutes ago."],[1101,1222,"Are you nervous?"],[1222,1355,"Try insane."],[1359,1401,"Who calls"],[1401,1518,"a Devereaux dress cheap?"],[1530,1626,"Zendaya wore a dress"],[1626,1689,"from this collection"],[1689,1826,"to the Golden Globes."],[5409,5505,"Ok, you're all set."],[5505,5601,"Have a wonderful day."],[5601,5693,"Thank you."],[6093,6185,"Stop right there."],[6331,6377,"I swear I -"],[6377,6589,"I'm gonna need to see your purse."]],"48":[[0,216,"I, I didn't steal anything. I swear -"],[229,417,"I'm gonna need to see your purse."],[442,667,"I don't know why that went off. I, I -"],[721,842,"I didn't take any..."],[909,1030,"What are these doing"],[1030,1101,"in your purse?"],[1372,1430,"I didn't,"],[1459,1618,"I didn't put them in there. I,"],[1630,1710,"I swear."],[1710,1810,"Security!"],[1826,1960,"This thief just tried to steal"],[1960,2072,"a hundred and twenty five"],[2072,2168,"thousand dollar earrings."],[2214,2302,"I'm not a thief."],[2302,2398,"I swear, I-"],[2398,2527,"You do realize that's a felony,"],[2527,2577,"don’t you?"],[2581,2694,"I didn't steal anything."],[2869,3011,"Can I get a security camera check"],[3011,3186,"at Devereaux Boutique?"],[3361,3453,"The security cameras"],[3453,3528,"will show you that"],[3528,3774,"this is all a big misunderstanding."],[3795,3920,"I have no reason to"],[3920,3978,"steal anything. - Oh!"],[3978,4074,"Excuse me."],[4074,4237,"Sorry to interrupt,"],[4270,4433,"but I couldn't just stand by"],[4433,4558,"and not say anything."],[4575,4675,"We were in the dressing room"],[4675,4767,"earlier, and"],[4808,4959,"we saw her put the earrings"],[4959,5034,"into her bag."],[5059,5230,"I mean, I tried telling everyone"],[5230,5334,"that she was a criminal."],[5334,5555,"Maybe the whole school will finally"],[5555,5726,"believe me once you're locked up."],[5784,5847,"Again."],[5960,6051,"No."],[6081,6227,"You're lying. Fallon."],[6227,6360,"Once Luca Devereaux"],[6360,6498,"gets here, she'll tell you that"],[6506,6681,"I have no reason to steal."],[6681,6819,"I don't need one hundred and"],[6819,6906,"twenty five thousand dollar"],[6906,6952,"earrings."],[6961,7111,"We've got visual confirmation from"],[7111,7211,"the Devereaux footage."],[7211,7407,"Subject appears to be a teenage girl"],[7424,7532,"in a blue dress."]],"49":[[0,125,"She was in a blue dress too."],[125,233,"I swear it wasn't me."],[233,354,"It must have been her."],[354,450,"You're coming with me."],[450,533,"I swear. - You don’t need"],[533,583,"to lie."],[583,684,"I didn't do it. I -"],[684,804,"Oh no."],[834,1013,"I'm so sorry that happened."],[1084,1176,"Where do you get off?"],[1176,1376,"You're just some mall cop."],[1393,1534,"Let go of me."],[1534,1576,"Sit down."],[1689,1826,"I'm telling you, Fallon and I"],[1826,1956,"were wearing the same dress."],[1985,2143,"You're making a huge mistake."],[2143,2281,"The only mistake"],[2281,2427,"is you trying to steal from"],[2427,2569,"the Luca Devereaux."],[2590,2660,"When she gets here,"],[2665,2781,"you are so dead."],[2781,2886,"We've got video evidence,"],[2886,2982,"you little fucking brat."],[2994,3119,"Yeah and if you would just look-"],[3119,3174,"Don't even try"],[3174,3286,"to talk your way out of this one."],[3345,3474,"Will the store be pressing charges?"],[3474,3553,"Of course."],[3553,3682,"My manager's on her way,"],[3682,3791,"and when she gets here-"],[3791,3866,"Is this her?"],[3912,4004,"Is this the little shit"],[4004,4099,"who tried to steal from us?"],[4099,4258,"I did not try to steal from you."],[4258,4346,"That's the one."],[4346,4508,"I want her prosecuted"],[4508,4771,"to the fullest extent of the law."],[4821,4963,"I want jail time."],[4979,5105,"I'll make sure they lock her up"],[5105,5180,"and throw away the key."],[5188,5292,"If we could just"],[5359,5480,"double check the footage"],[5505,5622,"one more time."],[5643,5705,"Why?"],[5726,5901,"So you can post it to your"],[59