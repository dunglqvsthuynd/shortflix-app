073,3165,"Maids?"],[3224,3390,"Everyone knows Fallon's family"],[3390,3486,"can't afford that."],[3716,3824,"Listen up, you pathetic,"],[3824,3924,"wannabe bitch."],[3924,4008,"You may think you're hot shit"],[4008,4166,"at school, but this is my house"],[4166,4245,"and my party."],[4254,4454,"So, act right or get the fuck out!"],[4596,4683,"Yikes."],[4746,4934,"Someone's feeling feisty today."],[5321,5388,"That's it."],[5534,5743,"Oh, baby, she's beneath you, okay?"],[5780,5864,"Don't waste your time on this"],[5864,5960,"two dollar slut."],[6001,6089,"She'll get what's coming."],[6172,6277,"I promise."],[6277,6439,"Careful, Fallon."],[6485,6573,"Girl to girl,"],[6627,6740,"Jake's not very good"],[6740,6906,"at keeping his promises."],[7002,7144,"What are you even doing here, Sierra?"],[7173,7286,"You know you're not wanted."],[7357,7403,"I'm,"],[7494,7640,"here to see the heiress."],[7661,7895,"Just like everyone else, right?"],[8241,8341,"By the way,"],[8420,8512,"where is she?"],[8512,8625,"She wouldn't,"],[8625,8721,"She wouldn't miss her own"],[8721,8850,"birthday party, would she?"]],"30":[[383,462,"She,"],[517,663,"actually texted me earlier."],[784,921,"She's stuck in traffic."],[959,1021,"So,"],[1021,1146,"I think it's time"],[1172,1305,"that we take some shots!"],[1309,1484,"Yeah!"],[1505,1605,"Let’s go!"],[3132,3228,"I got the heiress"],[3228,3420,"a jar of La Mer moisturizer."],[3420,3536,"All the celebrities are using it."],[3536,3703,"It's like five hundred dollars."],[3728,3824,"That's cute."],[3858,4074,"I got her VIP tickets to Coachella."],[4099,4325,"Five thousand dollars."],[4371,4446,"Aww."],[4446,4546,"Your gift for the heiress"],[4546,4746,"only cost five thousand dollars?"],[4788,4867,"That's nothing."],[4904,5134,"I got the heiress a Cartier choker."],[5301,5376,"Holy shit."],[5376,5572,"Isn’t that like ten grand?"],[5572,5659,"Try twenty."],[5805,5893,"How about you, Sierra?"],[5930,6072,"You crashed my party. Surely, you"],[6072,6239,"didn't show up empty handed."],[6256,6339,"Of course she did."],[6339,6456,"Being pathetic and tacky is"],[6456,6560,"like her whole personality."],[6560,6694,"What would she even bring?"],[6694,6886,"A bus card and a prison jumpsuit?"],[7115,7240,"Fallon’s so desperate"],[7240,7340,"to make me look bad."],[7357,7486,"Guess I'll just have to give her"],[7486,7615,"a taste of her own medicine."],[7628,7941,"Actually, I did bring a gift."],[8320,8475,"Oh my God!"],[8475,8625,"Is that a Birkin?"],[8725,8787,"That's like"],[8787,8971,"a hundred thousand dollar bag."]],"31":[[171,225,"Wait."],[246,383,"You're telling me the girl"],[421,508,"with no money,"],[546,746,"no boyfriend, and no hope"],[746,888,"has a Birkin?"],[1005,1084,"Yeah, right."],[1084,1213,"Clearly it's fake."],[1426,1543,"Oh my God, you're so right."],[1543,1685,"I mean, it's fake as hell,"],[1685,1768,"and she didn't even try"],[1768,1843,"to get a good fake."],[1914,2039,"You really thought you could fool us"],[2039,2177,"with that Walmart dupe, huh?"],[2360,2510,"This bag was passed down"],[2510,2573,"through my mother,"],[2573,2773,"and I assure you, it's very real."],[2865,2932,"Wait."],[3315,3415,"Of course."],[3415,3524,"You brought the heiress"],[3524,3770,"a fake, dirty hand-me-down."],[3832,3941,"Be careful, Fallon, OK?"],[3941,3995,"You don't know"],[3995,4087,"what kind of disease"],[4087,4225,"from a flea market that has."],[4225,4304,"Disgusting."],[4329,4466,"Of course, the fake ass heiress"],[4466,4596,"brought a fake ass bag"],[4596,4713,"to the party."],[4750,4888,"Wow, Fallon."],[4917,5009,"You pretend like"],[5009,5176,"you're the queen of luxury,"],[5176,5234,"and yet"],[5267,5359,"you don't even know"],[5359,5451,"a real Birkin bag"],[5451,5651,"when you're holding it in your hands."],[5726,5801,"Awkward."],[6285,6356,"Bitch!"],[6373,6489,"I know more about luxury"],[6489,6614,"than you ever will."],[6835,6886,"And,"],[6977,7169,"I know exactly where this belongs."],[7657,7820,"Fallon, where are you going with that?"],[7945,8037,"Give it back."],[8383,8429,"No."],[8637,8700,"You want it?"],[8779,8850,"No!"],[9997,10080,"You just threw"],[10080,10226,"a priceless Lancaster"],[10226,10326,"heirloom in the pool."],[10347,10489,"Oh, really?"],[10602,10748,"Then why don't you go get it?"]],"32":[[2314,2385,"It’s OK."],[2423,2494,"Grayson!"],[2777,2919,"You came to my party."],[2944,3061,"I'm sorry you got all wet."],[3061,3224,"Sierra is so clumsy."],[3224,3282,"Yeah."],[3374,3495,"I learned that in juvie."],[3557,3666,"Want to see what else I learned?"],[3787,3824,"OK."],[3832,3945,"Grayson, I'm telling you,"],[3945,4104,"this bitch is a no one."],[4137,4216,"Once the real heiress"],[4216,4416,"shows up and kicks her ass to the curb,"],[4421,4504,"then you'll see."],[4504,4654,"And you'll regret ever defending"],[4654,4771,"this lowlife loser."],[4796,4850,"No."],[5000,5088,"Don't think I will."],[5180,5251,"And I came because"],[5251,5401,"I heard that Sierra was coming."],[5522,5593,"I'll get you a towel."],[6264,6381,"See, that's what's so great"],[6381,6460,"about Grayson."],[6498,6606,"He doesn't care about"],[6673,6802,"money or status."],[6994,7136,"He doesn't have anything to"],[7228,7428,"overcompensate for."],[8204,8404,"Enjoy this moment while it lasts, Sierra."],[8404,8516,"Grayson, may be stupid enough"],[8516,8646,"to fall for your act now,"],[8650,8767,"but I'll make sure he sees you"],[8767,8871,"for the poor, pathetic"],[8871,8942,"fraud you are."],[9446,9496,"Hello?"],[9522,9634,"Sierra."],[9634,9722,"I just landed,"],[9772,9893,"and I want to see"],[9893,10039,"my long lost granddaughter"],[10039,10151,"on her birthday."],[10210,10268,"Where are you?"],[10318,10472,"I'm at 101 Birch Lane."],[10527,10702,"Can you get here in ten minutes?"],[10744,10873,"I can be there in five."],[11015,11102,"Stirling."],[11198,11332,"Take me to see my granddaughter."],[11390,11453,"Of course, sir."]],"33":[[0,95,"Who was that, Sierra?"],[95,233,"Your fave juvie lunch lady"],[233,308,"you're trying to pass off"],[308,487,"as your Auntie Lancaster?"],[496,688,"And I thought the Wirkin was bad."],[779,817,"Wait."],[900,967,"Look at that."],[1021,1101,"M.L."],[1117,1197,"Those are the initials"],[1197,1359,"of the Lancaster heiress' mom."],[1376,1518,"Melody Lancaster?"],[1572,1718,"And it's gold lettering."],[1718,1793,"How did Sierra"],[1793,1951,"get her hands on that bag?"],[1981,2110,"Oh my God, the same way"],[2110,2223,"she got her grubby little hands"],[2223,2285,"on the uniform"],[2285,2427,"and the Lancaster bracelet."],[2448,2598,"She stole them."],[2623,2727,"That's why the heiress"],[2727,2823,"didn't show up tonight."],[2836,3015,"She was scared that Klepto Sierra"],[3015,3153,"was going to strike again."],[3178,3324,"Get out of my house."],[3345,3428,"I'm not leaving"],[3428,3557,"without my mom's bag."],[3803,3912,"Everyone knows"],[3912,4079,"you're a sad little orphan"],[4079,4216,"whose parents abandoned her."],[4275,4379,"I'm sure your mom traded you"],[4379,4558,"for a dime bag and never looked back."],[4804,4938,"Face it, Sierra."],[4946,5084,"You were born trash,"],[5084,5188,"raised trash,"],[5188,5334,"and you'll die trash,"],[5334,5463,"just like your mother."],[5989,6181,"Cat fight! Cat fight!"],[6777,6894,"Get her, Jake!"],[7032,7148,"Let go of me!"],[7148,7286,"You psychotic bitch!"],[7444,7586,"It's over."]],"34":[[133,271,"Cops! Cops!"],[387,492,"Go! Go!"],[825,1038,"All right, I need you guys to settle down."],[1059,1167,"There was a noise complaint."],[1167,1284,"We need to see some ID."],[1309,1397,"Don't come near me, ok?"],[1397,1572,"My dad knows the chief of police."],[1572,1680,"Whose house is this?"],[1680,1797,"And I need to see some ID."],[1797,1910,"No, please. - It's not us."],[1910,1993,"She's the one you want."],[2052,2131,"She's already gone."],[2131,2198,"And you guys are here."],[2198,2327,"So, I'm gonna need to see something."],[2377,2444,"Sir."],[2590,2748,"Tha