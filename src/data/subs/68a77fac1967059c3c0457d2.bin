rp walk?"],[9250,9367,"Sorry to disappoint."],[9751,9909,"Turn around, skank!"],[10160,10226,"Luca came"],[10226,10339,"and sorted out"],[10339,10577,"the whole misunderstanding."],[10585,10785,"I told you, she's a friend."],[10835,10952,"Oh, she actually made me"],[10952,11061,"a custom dress"],[11061,11161,"for homecoming too."],[11161,11194,"So,"],[11319,11490,"I don't need this one anymore."],[11644,11711,"Do you want it?"],[11945,12120,"That is a Luca Devereaux."],[12846,12937,"Oh my God."],[12958,13088,"Oh my God. Oh my God. Oh my God."]],"51":[[304,629,"B squared minus 4 AC"],[629,850,"all over 2C. - All hail the"],[850,1042,"chlamydia queen."],[1534,1664,"Enjoy your crown."],[1664,1964,"It's the only one you’re going to get."],[2198,2243,"Jake."],[2243,2369,"Get out!"],[2410,2523,"Whoops."],[2523,2781,"Hope those weren't your court papers."],[3837,4137,"Is there anything I can do?"],[5017,5226,"Hey, Sierra."],[5230,5330,"I think there's"],[5330,5630,"something you should see."],[6076,6260,"How did you get this?"],[6260,6377,"I filmed it myself."],[6377,6519,"Being a nerd has its perks."],[6519,6614,"Like being"],[6614,6719,"completely invisible"],[6719,6861,"to the popular kids."],[6952,7086,"I can send it to you if it helps."],[7190,7332,"Why are you helping me?"],[7332,7574,"Fallon has a big mouth,"],[7574,7791,"but not everyone's on her side."]],"52":[[487,558,"What do you have to say"],[558,642,"for yourself, Jake?"],[821,900,"You bitch!"],[925,959,"Hey!"],[1001,1076,"We don't tolerate"],[1076,1151,"that kind of language"],[1151,1217,"here at Hawthorne."],[1259,1397,"And we certainly don't allow for"],[1397,1543,"the destruction of school property."],[1576,1647,"But it wasn't me."],[1676,1747,"I didn't do it."],[1747,1860,"Oh, well, you can't argue"],[1860,1968,"with proof, Jake."],[1985,2081,"Shut up, you-"],[2081,2164,"Mr. Walker!"],[2264,2431,"You're suspended for two weeks."],[2439,2544,"What? No."],[2544,2577,"I-"],[2577,2798,"And banned from homecoming."],[2882,3053,"Try anything like this again,"],[3078,3290,"and I will expel you."],[3415,3470,"Got it?"],[3620,3737,"You better be careful."],[4024,4137,"Bye, Principal Gordon."],[4312,4441,"Baby, where are you going?"],[4454,4617,"We need to campaign at lunch."],[4646,4708,"Home."],[4763,4921,"This bitch got me suspended"],[4921,5042,"and banned from the dance."],[5130,5192,"What?"],[5342,5438,"Oh, no."],[5522,5672,"It looks like you don’t have a date"],[5672,5789,"to homecoming now."],[5855,5918,"Neither do you,"],[5918,6039,"chlamydia queen."],[6068,6147,"Actually,"],[6302,6356,"I'm her date."],[6535,6648,"Isn't it funny?"],[6664,6731,"Just last week,"],[6731,6902,"you were dating a football player"],[6902,7019,"and bragging to everyone"],[7019,7144,"about how you were besties"],[7144,7219,"with the heiress."],[7219,7311,"And now,"],[7311,7428,"Jake's suspended."],[7432,7624,"I'm dating the star quarterback, and..."],[7720,7862,"you're about to be exposed"],[7862,8003,"for the liar that you are."],[8195,8312,"I'll see you at the dance."],[8646,8746,"Yes, you will."],[8829,8975,"This isn't over. Sierra."]],"53":[[1013,1213,"Girl, I love playing with this skirt, girl."],[2790,2869,"Wow."],[3641,3745,"Sierra."],[3824,3928,"Wow."],[4024,4120,"You look amazing."],[4275,4433,"You don't look too bad yourself."],[5422,5472,"I can't believe"],[5472,5593,"you showed up after what you did"],[5593,5663,"to Jake."],[5693,5822,"Nice dress, Fallon."],[5822,5968,"My leftovers look good on you."],[6022,6151,"At least I don't have to lie"],[6151,6243,"about who I am"],[6243,6418,"just to get a date to the dance."],[6452,6610,"At least I have a date to the dance."],[6610,6731,"Where's Jake again?"],[6752,6940,"Doing community service?"],[7169,7286,"Gather round, gather round."],[7286,7424,"We're about to announce the"],[7424,7761,"homecoming King and Queen."],[8187,8341,"I know you think your stunt to Jake"],[8341,8466,"put me out of the running,"],[8466,8604,"but I don't need