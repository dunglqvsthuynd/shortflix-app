8892,9029,"This is criminal."],[9029,9129,"You should send her back"],[9129,9271,"to Saint Mary's right now."],[9376,9522,"Fallon, the only one"],[9522,9613,"who should be worried"],[9613,9784,"about their criminal record is you."],[9809,9968,"What do you even mean?"],[10347,10447,"I think there's something"],[10447,10518,"you all need to see."]],"55":[[129,250,"Ever since I got"],[250,417,"to Hawthorne Prep,"],[417,675,"Fallon has called me a liar,"],[675,909,"a cheat, and a criminal."],[909,1217,"She has turned the entire school"],[1217,1317,"against me."],[1317,1397,"All while"],[1397,1568,"acting like a perfect little"],[1568,1735,"prep school princess."],[1735,1860,"As it turns out,"],[1860,1976,"the so-called princess"],[1976,2264,"isn't so perfect after all."],[2264,2352,"Try and lie your way"],[2352,2515,"out of this one, Fallon."],[3103,3261,"Oh shit, there’s Fallon."],[3837,4029,"Isn’t that Sierra’s purse?"],[4187,4258,"What the hell, dude?"],[4258,4350,"What the fuck?"],[4458,4629,"I'm no criminal, Fallon."],[4767,4896,"But you are."],[5134,5205,"No."],[5205,5630,"And now everyone knows it."],[5889,6039,"She framed Sierra."],[6039,6281,"That's straight up evil."],[6331,6427,"What the fuck?"],[6427,6644,"I used to look up to Fallon."],[6685,6856,"No, no, she,"],[6856,6977,"she is lying."],[6977,7082,"I mean, that video was a fake."],[7082,7198,"She's been trying"],[7198,7336,"to ruin my"],[7336,7436,"name ever since"],[7436,7678,"she came to the school."],[7678,7899,"Who's smearing who again?"],[7899,8058,"You guys are seriously going"],[8058,8133,"to trust this"],[8133,8420,"bargain bin bullshit heiress over me?"],[8420,8500,"Every word that"],[8500,8708,"comes out of her mouth is a lie."],[8708,8879,"Yeah. - She is no Lancaster."],[8921,8954,"She's"],[8954,9042,"not even fit"],[9042,9255,"to scrub their floors."],[9255,9330,"Oh my God,"],[9330,9438,"Fallon, you've lied"],[9438,9609,"so much that even you're starting"],[9609,9701,"to believe it."],[9701,9813,"I'm not a liar."],[9813,9984,"You're a liar."],[9984,10147,"And you're not even a Lancaster."],[10256,10589,"You're just a dirty, jealous whore."],[11307,11503,"That is enough."]],"56":[[25,225,"So... it's you again."],[296,542,"Did Reginald Lancaster seriously"],[542,709,"just walk into our homecoming?"],[717,946,"Whoa! He looks pissed!"],[1013,1134,"You're the heathen that’s"],[1134,1338,"been picking on my granddaugher?"],[1338,1409,"Sir."],[1476,1584,"No, no."],[1589,1668,"No, I -"],[1668,1885,"I, of course, I would never do that."],[1901,2052,"Mr. Lancaster, Fallon's only ever"],[2052,2177,"tried to protect your granddaughter."],[2248,2373,"She's been nothing but loyal"],[2373,2448,"to your family."],[2448,2489,"Mmhmm."],[2535,2598,"It's her!"],[2615,2761,"She's the one that you want."],[2761,2915,"She is nothing but a wannabe"],[2915,3053,"impostor, pretending to be"],[3053,3132,"the heiress."],[3132,3299,"So, she's an impostor, huh?"],[3299,3340,"Yes!"],[3357,3549,"And I've been trying to send her to juvie,"],[3549,3678,"but none of these idiots here"],[3678,3737,"here would listen to me."],[3737,3878,"How dare you!"],[4366,4533,"She is no impostor."],[4750,4888,"She is -"],[4967,5150,"my granddaughter."],[5534,5672,"She is,"],[5672,5834,"always has been"],[5834,5947,"a Lancaster."],[5947,6114,"The sole heir"],[6181,6314,"to my empire,"],[6314,6514,"my fortune, and my legacy."],[6514,6685,"Oh, shit!"],[6731,6848,"Yeah."],[6848,7040,"Fallon really fucked with the wrong girl."],[7311,7411,"Now, you"],[7540,7674,"will pay for how you treated"],[7674,7774,"my grandaughter."],[7832,7949,"Stirling,"],[8033,8216,"I want to press full charges."],[8308,8412,"I want her"],[8412,8612,"and her family discredited."],[8616,8779,"Expose them."],[8792,8871,"Right away, sir."],[8871,8950,"What? No."],[8950,9042,"No, please! Please!"],[9042,9163,"You don't have to do this."],[9163,9363,"Don't you touch me!"],[9434,9580,"Gentlemen, please."],[9738,9776,"Wait!"],[9797,9868,"No, please, just -"],[9876,9997,"Just let me explain."],[9997,10047,"Sierra!"],[10068,10231,"Sierra, we used to be friends."],[10264,10322,"Right?"],[10385,10510,"Don't let them do this to me."],[10510,10564,"Please."]],"57":[[333,575,"You look stunning tonight."],[642,725,"How did you find out"],[725,821,"about all this, Grandpa?"],[821,1063,"Well, I may have asked Stirling"],[1067,1201,"to keep an eye on you."],[1326,1472,"Look, I know"],[1509,1614,"you wanted to handle this"],[1614,1705,"in your own way,"],[1705,2014,"but I think it is time the world got to see"],[2047,2323,"the real Sierra Lancaster."],[2352,2477,"Thanks, Grandpa."],[2477,2602,"So, how do you want to"],[2602,2706,"handle that?"],[2811,2944,"I'll take it from here."],[2944,3036,"I think you do."],[3140,3261,"Sierra."],[3261,3395,"Sierra, I’m sorry."],[3407,3511,"I'm so sorry."],[3549,3728,"I didn't want any of this to happen,"],[3728,3858,"and then it all just blew up."],[3858,4037,"And, I mean, this is high school."],[4058,4200,"You know what I mean? It’s -"],[4429,4508,"Fallon."],[4583,4717,"You risked everything"],[4717,4825,"to make me look bad."],[4938,5042,"Was it worth it?"],[5105,5209,"Well,"],[5209,5384,"it wasn't what I was trying to do."],[5384,5442,"I was just -"],[5522,5572,"Jake?"],[5689,5801,"You betrayed me"],[5801,5947,"for a chance at popularity."],[5989,6168,"How's that turning out for you?"],[6448,6614,"Babe, please. I -"],[6635,6731,"She made me do it."],[6948,7077,"Sierra, I love you."],[7086,7236,"I never stopped loving you."],[7236,7353,"I was just -"],[7444,7561,"- scared of her!"],[7603,7745,"Are you fucking kidding me?"],[7774,7899,"He was cheating on you with me"],[7899,8049,"before you even went to St. Mary’s."],[8049,8083,"No, don’t -"],[8083,8137,"Don't listen to her!"],[8137,8224,"OK, look,"],[8224,8337,"there's still time for us"],[8337,8450,"to get together, Sierra."],[8487,8575,"Oh my God, Sierra."],[8575,8721,"Forget about him!"],[8779,8858,"What about us?"],[8892,9000,"We were best friends."],[9000,9079,"Remember?"],[9092,9225,"All those sleepovers?"],[9242,9434,"That had to mean something, right?"],[9434,9547,"I've heard enough."],[9788,9884,"I've heard enough."],[9884,9984,"On your feet."]],"58":[[12,150,"On your feet."],[150,316,"You are banned from this dance."],[316,433,"Your presence here is a direct"],[433,583,"violation of my order."],[583,742,"Please, sir, I... -No!"],[759,838,"And you?"],[884,963,"I just saw the"],[963,1142,"security footage from the mall."],[1142,1276,"What a disgrace."],[1276,1422,"No, if I could just explain."],[1422,1518,"Shut it."],[1593,1672,"Save it for the"],[1672,1839,"guards at Saint Mary's."],[2043,2218,"You’re both expelled."],[2218,2310,"St. Mary’s?"],[2310,2419,"Get them out of here."],[2419,2527,"Are you kidding me?"],[2527,2648,"I was framed."],[2681,2852,"Let me go!"],[2852,2961,"My dad is going to sue"],[2961,3144,"each and every one of you."],[3144,3315,"This isn't the end, Sierra."],[3315,3574,"Sierra, I’m coming for you!"],[3645,3828,"All right, Hawthorne Prep,"],[3828,4175,"let’s get this party back on track!"],[4408,4550,"May I?"],[5209,5392,"How's it look?"],[5480,5680,"Like it was made for you."]]}