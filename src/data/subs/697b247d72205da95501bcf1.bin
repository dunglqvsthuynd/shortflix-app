tell him."],[2781,2836,"Ivy?"],[2894,2977,"You taking a bath?"],[3086,3211,"Why don't you let me come in?"],[3386,3428,"Ivy?"],[3541,3720,"You got a vampire in front of you."],[3770,3899,"Is everything okay?"],[3912,4033,"And your werewolf boyfriend"],[4033,4141,"standing outside the door."],[4141,4254,"What are you gonna do, Ivy?"]],"61":[[400,533,"Wait, don't come in."],[613,742,"I'm taking a bath."],[813,900,"Okay, I'm sorry."],[938,1009,"I'm sorry."],[1046,1230,"His hand is freezing cold."],[1326,1514,"But why does it set my body on fire?"],[1584,1693,"You sure everything's okay?"],[1847,1939,"You sound a little off."],[1985,2039,"I'm-"],[2202,2348,"No, I'm, I'm fine."],[2373,2460,"I'm good."],[2485,2585,"I'm totally fine."],[2623,2744,"You're a liar."],[2790,2844,"Alright."],[2936,3048,"Well, when you're done, um,"],[3115,3194,"come look for me."],[3236,3311,"I wanna talk to you."],[3324,3370,"Mhm."],[3378,3432,"Okay."]],"62":[[629,696,"Zane,"],[759,880,"you crossed the line."],[1063,1130,"Okay."],[1463,1543,"But you didn't tell him"],[1543,1676,"that I was in here with you."],[1843,1972,"And I'm a vampire, Ivy."],[1972,2127,"I can feel your heartbeat."],[2173,2331,"I know that you want me too."],[2652,2719,"Zane, I-"],[2927,3023,"I can't do this."],[3244,3361,"Okay, you know I'm"],[3449,3566,"going out with Seb."],[3603,3661,"I don't"],[3862,3966,"don't wanna hurt him."],[4116,4270,"I don't wanna hurt you either."],[4358,4475,"Oh my God."],[4533,4633,"This is so awful."],[4633,4808,"I'm, I'm so terrible."],[5217,5263,"No."],[5376,5463,"You're right, get out."],[6694,6748,"Hey."],[7023,7069,"Ivy."],[7215,7315,"Are you a witch?"],[7786,7841,"What?"]],"63":[[37,120,"A witch?"],[262,316,"Ivy."],[571,646,"You carry this book"],[646,767,"with you every single day."],[846,938,"Right by your side."],[1067,1209,"And you never said anything."],[1330,1384,"I don't-"],[1384,1493,"Why didn't you tell me?"],[1597,1710,"I trusted you, Ivy."],[1735,1793,"I, I don't know"],[1793,1856,"what that book is. - Why didn't you"],[1856,1901,"tell me?"],[1901,2010,"Don't lie to me!"],[2252,2377,"I can't take it."],[2435,2527,"Ivy, I can't!"],[2652,2790,"First, my mate is a human."],[2831,2940,"And now she's a witch."],[2986,3098,"Why is this happening to me?"],[3098,3207,"Seb, Seb,"],[3219,3336,"please calm down- - Don't touch me!"],[3724,3795,"Ivy."],[3858,3924,"Come here."],[4429,4525,"I can't calm down."],[4738,4854,"Witches, they came in,"],[4950,5105,"they destroyed my entire pack."],[5171,5259,"They killed my mother"],[5259,5351,"right in front of me."],[5376,5547,"Why are you a witch, Ivy?"]],"64":[[12,183,"Why are you a witch, Ivy?"],[688,829,"Please, Seb, it's, it's me."],[829,930,"Please."],[942,980,"Just Ivy-"],[980,1088,"Stay away from me!"],[1172,1322,"Ivy, Ivy, run!"],[1334,1430,"Ivy, run!"],[1430,1689,"Ivy, Ivy, I-"],[2781,2873,"No, no, please..."],[3140,3215,"It's me."],[3274,3395,"It's me, I-Ivy."],[3453,3528,"It's me."],[3678,3820,"Sebastian stop!"],[4633,4683,"It's okay, Ivy."]],"65":[[709,871,"You almost fucking killed her!"],[1042,1213,"How dare you show your face here?"],[1213,1338,"I didn't mean to!"],[1338,1455,"I lost control."],[1455,1551,"It was because of the blood moon!"],[1551,1630,"I told you!"],[1668,1722,"Your recklessness"],[1722,1830,"is gonna get her hurt!"],[1851,1943,"Get off of me!"],[2135,2248,"What about you, huh?"],[2293,2381,"Did you know?"],[2444,2590,"Did you know that Ivy was a witch?"],[2590,2640,"No."],[2656,2756,"I had my suspicions,"],[2756,2882,"but I didn't know until last night."],[2882,2952,"Same as you."],[3086,3232,"Why is this happening to me?"],[3249,3324,"You know as well as I do"],[3324,3378,"that your kind"],[3378,3470,"doesn't tolerate witches,"],[3470,3561,"so what are you gonna do,"],[3586,3716,"Sebastian Moonflame?"],[3745,3845,"You gonna keep her secret"],[3845,3916,"or you gonna send her"],[3916,4016,"to death yourself?"],[4149,4258,"We don't like witches"],[4258,4371,"because they're deceitful,"],[4371,4504,"manipulative hags!"]],"66":[[60,145,"We don't like witches"],[145,254,"because they're deceitful,"],[254,404,"manipulative hags!"],[554,663,"Ivy's not like that."],[671,863,"Stop bullshitting me."],[871,934,"I'm not!"],[946,1059,"What are you gonna do?"],[1334,1422,"I don't know."],[1518,1609,"That's what I thought."],[1805,2010,"Even you know you can't keep her safe."],[2056,2152,"I've already mobilized"],[2152,2223,"my entire clan"],[2223,2302,"to protect her,"],[2318,2460,"because I don't trust you."],[2677,2781,"And I don't trust"],[2781,2986,"your mangy pack of mutts."],[4070,4158,"Elder Rufus."],[4287,4366,"We need to talk."]],"67":[[12,91,"Your Highness,"],[137,262,"you're the future Alpha"],[275,387,"of the Moonfire Pack."],[450,558,"You cannot be with her."],[738,967,"The pack will not accept a human"],[1063,1180,"as a future Luna."],[1242,1347,"Yeah, but you know what?"],[1614,1755,"You can't tell me what to do."],[1780,1931,"I will do anything for this pack."],[2022,2072,"If that means"],[2072,2193,"getting blood on my hands,"],[2331,2452,"or angering you,"],[2590,2656,"so be it."],[2698,2777,"Stop."],[3219,3294,"This is-"],[3319,3378,"Wait."],[3486,3595,"Just wait."],[3603,3712,"I can't let anyone in the pack"],[3712,3824,"know that she's a witch."],[3845,3920,"They'll kill her."],[4012,4112,"Okay, Elder Rufus."],[4145,4229,"I will take everything"],[4229,4375,"that you're saying into consideration."],[4375,4479,"No, Your Highness."],[4479,4688,"You must cut ties with her, now."]],"68":[[87,221,"If I get any closer to her,"],[275,379,"the pack will discover that"],[379,475,"she's a witch."],[475,621,"And her life will be in danger."],[867,930,"You're right."],[1051,1151,"You're absolutely right."],[1213,1292,"I was blinded."],[1388,1530,"But I have to put the pack first."],[1951,2081,"But you don't need to hurt her."],[2135,2206,"She's innocent."],[2264,2369,"You keep your word."],[2419,2498,"Otherwise,"],[2540,2702,"I'm taking this to the council."],[3003,3098,"I hate to admit it,"],[3169,3274,"but Zane is right."],[3336,3520,"Keeping Ivy close will destroy her."],[3549,3661,"I have to protect her,"],[3707,3803,"even if it means..."],[3924,3999,"hurting her."]],"69":[[150,254,"Seb vanished"],[254,421,"the day after he lost control."],[421,579,"And we have no idea where he is."],[704,813,"Is he avoiding me?"],[1843,1901,"Seb!"],[2235,2289,"Sup."],[2427,2460,"What?"],[2531,2615,"What is he doing?"],[2698,2781,"Uh, Seb."],[3157,3361,"Are you avoiding me or something?"],[3386,3528,"Uh, no, I'm not avoiding you."],[3528,3578,"I'm-"],[3703,3849,"I'm not interested in you anymore."]],"70":[[62,158,"What do you mean?"],[175,258,"Uh, I think I made it"],[258,375,"just very fucking clear."],[454,529,"We had our fun,"],[592,663,"and now I'm bored."],[767,875,"No, you're, you're lying."],[905,959,"I'm not lying."],[959,1063,"Listen, you wanna get real?"],[1101,1146,"Huh?"],[1330,1443,"Ivy, you're a witch."],[1505,1718,"An evil fucking witch."],[1776,1864,"Okay, you're the creature"],[1864,2018,"that I hate most in this entire world."],[2043,2156,"You disgust me, Ivy."],[2256,2369,"I will never be with you."],[2527,2581,"Get it?"],[3040,3132,"Seb, you don't-"],[3315,3428,"You don't mean that."]],"71":[[37,145,"You don't mean that."],[316,392,"Yes, I do."],[408,521,"Ivy, we're done."],[567,638,"Okay?"],[742,867,"Now, who wants to be my girlfriend?"],[871,959,"Me, me. Me."],[1146,1309,"You're just a homeless trash girl."],[1326,1397,"And you thought"],[1401,1580,"you could get with the Moonflame Heir?"],[1659,1918,"You'll always be an unwanted,"],[1939,2093,"nobody loser."],[2173,2268,"You hear that, Ivy?"],[2356,2419,"We're done."],[4116,4254,"Oh my God, babe, are you okay?"],[4270,4387,"I can't believe she hit you."],[4500,4571,"Don't touch me."]],"72":[[221,362,"Hey, hey."],[450,521,"What's wrong?"],[550,604,"What's wrong?"],[604,684,"Hey, hey, hey."],[975,1063,"Oh, it's fucking you."],[1213,1284,"You hurt her?"],[1572,1659,"You're fucking done!"],[1776,1835,"I don't give a fuck"],[1835,1901,"what your reason is."],[1901,2035,"You're never going near her again."],[2089,2168,"Good, why don't you"],[2168,2264,"go take care of her, huh?"],[2302,2360,"Go take care of her."],[2360,2460,"Get her out of my fucking face,"],[2460,2552,"I never wanna see her again."],[2765,2890,"Zane, I, I wanna go."],[2940,3015,"I wanna leave."],[3086,3186,"You fucking piece of shit."],[3511,3632,"Ivy, if I didn't leave you,"],[3632,3766,"your life would be in danger."],[3858,3949,"I had to do this"],[4004,4099,"to protect you."],[4888,5080,"Sebastian hates me."],[5155,5355,"He doesn't wanna accept who I am."],[5647,5701,"Hey."],[6181,6281,"If he can't accept you,"],[6281,6377,"then he's a fool."],[6652,6802,"I don't care if you're a witch, Ivy."],[7048,7140,"If you were mine,"],[7194,7319,"I'd never let you go."]],"73":[[358,408,"Zane."],[692,829,"I can't stop feeling this pull"],[829,925,"between us, Ivy."],[992,1142,"I know you feel it too."],[1297,1347,"May I?"],[1584,1630,"Ivy,"],[1693,1826,"I will still protect you,"],[1897,2068,"even if I can't be by your side."],[2106,2193,"Zane."],[2452,2535,"I'm sorry."],[2548,2794,"It's just, everything happened"],[2811,3028,"so sudden today, and"],[3157,3244,"I don't know, I feel like"],[3244,3415,"Sebastian's hiding something from me."],[3561,3666,"No, no, no, it's okay."],[3883,3949,"Come here."],[4158,4312,"Just know that whatever happens,"],[4550,4654,"I'm always gonna be here,"],[4654,4783,"and I'm always gonna protect you."],[4871,4925,"Okay?"],[5271,5651,"Ivy, choose before it's too late."],[5651,5876,"One heart, one mate."],[5914,6314,"Delay, and danger will claim you all..."]]}