our best engineers"],[8304,8383,"couldn't even do."],[8400,8483,"A fluke."],[8525,8608,"You cannot win"],[8608,8754,"a multi-billion dollar contract"],[8771,8904,"with this college dropout"],[8925,9071,"as your chief technologist"],[9084,9217,"while Leon Hearst"],[9238,9351,"is over here with the"],[9355,9446,"Doctor Nova."],[9551,9734,"If Doctor Nova is what it takes"],[9734,9876,"to win that contract,"],[9930,10043,"then I've made the right choice."]],"47":[[62,225,"You're comparing this slut"],[275,483,"to the genius Doctor Nova?"],[525,675,"And insulting our intelligence"],[675,813,"by making us work for this"],[813,1005,"bottom feeding piece of shit."],[1034,1205,"If you were really intelligent,"],[1205,1376,"you wouldn't leave AlphaTech simply"],[1376,1463,"because the Lamberts"],[1463,1651,"are dangling a bone in front of your face."],[1676,1805,"How dare you!"],[1805,1835,"You..."],[1864,1931,"You know what?"],[1993,2164,"I'm glad you guys are leaving."],[2231,2360,"Because I would have fired you"],[2360,2435,"anyway"],[2448,2602,"for insulting my wife"],[2660,2811,"and using abusive language"],[2811,2998,"against a fellow employee."],[3032,3178,"You'll regret this, Roy."],[3261,3411,"This broad will lead you"],[3411,3561,"and your company off a cliff."],[3641,3724,"You know what, Roy?"],[3753,3841,"You're finished."],[3866,3924,"You're never going to get that"],[3924,4054,"multi-billion dollar contract"],[4054,4129,"without us."],[4187,4283,"Wait and watch."],[4366,4483,"It's not over, Roy."],[4512,4650,"You know you, you've lost all my"],[4650,4884,"investments and also your top guys."],[4884,5117,"But I'm just gonna stay around"],[5117,5338,"to watch you complete your ruin."],[5405,5505,"Don't worry, Roy,"],[5534,5601,"I'll take you back"],[5601,5730,"once you trash the skank"],[5730,5918,"when she loses the contract next week."],[6631,6810,"So I know I just let our top guys go,"],[6894,7011,"but we are going to need people"],[7040,7169,"if we're going to