is office building"],[5209,5384,"in the next five minutes."],[6481,6652,"Strip them naked."],[6673,6798,"Make sure these leeches"],[6798,6986,"haven't stolen any company property."],[7040,7186,"I'm going to make this viral."],[7186,7303,"A warning for losers"],[7303,7403,"who dare go against me and"],[7403,7486,"Doctor Nova."],[7507,7661,"Whoa, whoa."],[7691,7807,"Think you could sneak this out"],[7807,7920,"from under my nose,"],[7920,8016,"Grandpa?"],[9421,9563,"Get your hands off of him!"]],"50":[[700,767,"Elle!"],[784,984,"Back to beg for your assistant job?"],[1042,1192,"We don't hire losers,"],[1201,1255,"Elle."],[1297,1355,"In fact,"],[1438,1584,"we just fired a bunch of them."],[1626,1818,"Let them go, or I will have you arrested"],[1818,2010,"for attacking your employees."],[2106,2189,"And you're going to regret"],[2189,2339,"firing your best people, Leon."],[2364,2540,"I knew Elle would come to our rescue."],[2585,2723,"Best people?"],[2781,2865,"These losers"],[2948,3032,"who couldn't even make"],[3032,3165,"a working demo for me?"],[3274,3420,"You can have them, Elle."],[3628,3887,"Why, you poor thing."],[3933,4037,"You know, until today,"],[4037,4237,"you just had loser Elle on your team."],[4270,4371,"Oh, but don't worry."],[4387,4475,"Now you have a whole"],[4475,4621,"army of losers."],[4658,4700,"I mean, it's"],[4700,4817,"obvious who's going to be winning"],[4817,4967,"that multi-billion dollar contract"],[4967,5021,"next week."],[5080,5196,"You know, if only you were taken the"],[5196,5330,"time to get to know your"],[5330,5409,"employees or even"],[5409,5568,"read their résumés, Leon."],[5851,6047,"Will, who Natasha just had at her feet"],[6085,6268,"is a Nobel Prize winner."],[6418,6585,"Rita has two"],[6585,6740,"national science medals."],[6902,7073,"Fareed has a double Ph.D."],[7073,7273,"in engineering from Harvard,"],[7365,7461,"and Sheila"],[7461,7691,"is the world's leading AI expert."],[8512,8671,"Welcome to AlphaTech."],[8850,8954,"Let the battle begin."]],"51":[[3278,3403,"That feels good."],[3849,3970,"You need some rest."],[3970,4070,"Doctor Nova."],[4149,4237,"Why don’t we go home?"],[4287,4387,"I can’t."],[4429,4521,"I have to get this up"],[4521,4629,"on the mainframe overnight."],[4629,4667,"But,"],[4750,4800,"you should go,"],[4800,4925,"you should go get some rest."],[5092,5271,"I can't sleep without my wife."],[5384,5534,"Why does my heart race so fast"],[5534,5651,"when I’m near him?"],[5839,5872,"Elle,"],[6122,6206,"I love you."],[6360,6502,"I've loved you from the moment"],[6502,6652,"I first saw you."],[6827,6948,"I know things have been"],[7032,7107,"uneasy."],[7240,7315,"I know you thought"],[7315,7474,"I was engaged to Bianca"],[7611,7778,"but that was a misunderstanding."],[7849,7987,"Our families, they wanted us to."],[9205,9275,"No!"],[9396,9509,"Digitech just got wind of our"],[9509,9630,"new AI based program,"],[9651,9718,"and they're planning to build"],[9718,9793,"one too."],[9884,10043,"Using their in-house framework."],[10135,10222,"Novasafe."],[10285,10364,"Novasafe?"],[10435,10560,"I wrote that framework."]],"52":[[20,112,"Novasafe?"],[166,271,"I wrote that framework."],[446,592,"Elle, I wasn’t worried before."],[679,759,"But I am now."],[846,946,"Leon having something"],[946,1017,"you built"],[1113,1151,"that"],[1159,1317,"is going to give him the edge over us."],[1343,1480,"No, no, I wouldn't worry."],[1576,1659,"I wrote Novasafe"],[1659,1814,"years ago as just a trial."],[1839,1981,"It’s not AI compatible"],[1981,2139,"and it's going to fail eventually."],[2231,2323,"Leon and Natasha"],[2323,2460,"have no idea what they're dealing with."],[2773,2957,"We're here outside City Hall,"],[2957,3111,"where the stage is set"],[3111,3253,"for Silicon Valley's"],[3253,3390,"biggest battle."],[3407,3553,"In just a few moments,"],[3586,3720,"leading tech icons"],[3720,3887,"Leon Hearst, Digitech"],[3916,4129,"and Roy Grant's AlphaTech"],[4162,4333,"will be submitting their final bids"],[4333,4487,"for a whopping"],[4533,4729,"multi-billion dollar"],[4746,4896,"federal security contract."],[6685,6835,"City Hall is my lucky charm."],[6956,7132,"Divorced my loser ex-wife here,"],[7161,7382,"to be with the genius Doctor Nova"],[7469,7578,"and in a few minutes,"],[7645,7778,"I'll be signing the world's"],[7795,7866,"biggest"],[7866,7970,"contract here."],[7991,8116,"City hall is where Leon will"],[8116,8266,"realize what he's lost"],[8266,8400,"when the real Doctor Nova"],[8400,8500,"reveals herself."]],"53":[[1167,1326,"Our algorithm is crashing."],[1347,1447,"I haven't told Mr. Leon,"],[1447,1522,"he'll kill me."],[1564,1655,"You did the right thing."],[1985,2185,"You've come too far to fail now"],[2185,2260,"Natasha."],[2327,2427,"Do something."],[2494,2635,"Our test was a success."],[2652,2815,"We're going to win, thanks to Ms. Elle."],[2986,3090,"Elle,"],[3215,3324,"hopefully we’ll never"],[3324,3440,"see each other again."],[3591,3707,"How about a group picture?"],[3737,3774,"You know,"],[3816,3916,"for the grandkids?"],[4004,4054,"Um,"],[4070,4162,"Sure."],[4162,4279,"If you must have one"],[4279,4383,"with Doctor Nova."],[4746,4817,"Good luck,"],[4817,4867,"Elle."],[4975,5121,"May the best player win."]],"54":[[554,642,"Look at those"],[642,784,"majestical golden thrones"],[817,921,"made for winners"],[921,996,"for our nation's"],[996,1138,"historical contracts."],[1172,1292,"I've heard the greatest"],[1292,1355,"of the greats"],[1355,1480,"like Henry Ford and"],[1480,1651,"Thomas Edison once sat on them."],[2723,2773,"Barry?"],[2915,3007,"What are you doing here?"],[3032,3161,"Surprised Roy boy?"],[3244,3390,"Barry's joined hands with Digitech."],[3449,3541,"As their newest,"],[3557,3670,"and biggest investor."],[3745,3862,"Those billions of dollars"],[3862,3949,"you said no to,"],[4083,4187,"he’s giving them to me."],[4220,4371,"I'm here to watch the spectacle"],[4371,4529,"of your ruin Roy Grant."],[4579,4717,"You'll pay a heavy price"],[4717,4867,"for rejecting my Bianca"],[4888,5013,"and marrying that worthless"],[5013,5096,"piece of shit."],[5192,5267,"Just,"],[5313,5417,"go feed your own ego"],[5417,5480,"Mr. Lambert."],[5538,5626,"As you can see"],[5626,5714,"we're kind of busy here."],[5768,5914,"Shut up, you skank!"],[5972,6101,"Roy will divorce you tonight"],[6101,6239,"after you lose that contract."],[6239,6423,"And then he'll beg to marry me."],[6481,6569,"Let's go. Dad."],[7369,7499,"Hello, all."],[7553,7695,"I’m Digitech’s"],[7695,7811,"Chief Technologist"],[7811,7920,"Natasha Wilson,"],[7937,8108,"or better known as"],[8108,8204,"Doctor Nova."],[8295,8441,"and I will be presenting"],[8441,8650,"Supernova 1.0."],[8679,8808,"The world's most nuanced"],[8808,8979,"and first AI based"],[8996,9117,"cybersecurity"],[9117,9192,"framework."],[9242,9330,"Designed by me."]],"55":[[4404,4521,"Supernova."],[4642,4942,"That's Elle's design."],[5025,5134,"She stole our presentation."]],"56":[[50,91,"Elle,"],[137,254,"check if you have a hard drive."],[342,396,"I don't."],[517,600,"It was stolen."],[642,809,"But you don't seem concerned about it."],[900,1038,"Don't worry about it, guys."],[1117,1226,"Just wait and watch."],[1305,1472,"You naughty girl."],[1509,1597,"If Natasha thinks"],[1597,1685,"she can get away with"],[1685,1768,"stealing my work,"],[1847,1985,"clearly she does not know"],[1985,2139,"what Doctor Nova is capable of."],[2198,2398,"Well done, Ms. Natasha."],[2485,2581,"After that fabulous"],[2581,2673,"presentation,"],[2694,2815,"there can be no doubt"],[2815,2948,"that you are the one,"],[2948,3040,"the true,"],[3111,3178,"Doctor Nova."],[3211,3274,"Ms. Elle,"],[3365,3432,"it’s your turn now,"],[3507,3561,"please"],[3620,3695,"present your work."],[3870,3966,"Good luck, Elle."],[4024,4141,"I can't wait"],[4141,4316,"to see what you've got."],[4479,4587,"Sorry, everyone."],[4696,4850,"I don't have anything to present."]],"57":[[0,271,"Pathetic Elle has nothing to present."],[271,379,"Why am I not surprised?"],[492,767,"Loser assistant with no college degree"],[817,1071,"can never compete with a true genius."],[1167,1222,"Leon,"],[1301,1447,"that means we won the multi-billion"],[1447,1572,"dollar contract."],[1714,1818,"I didn't finish."],[2022,2168,"I don't have anything to present"],[2168,2231,"because,"],[2331,2506,"well, Natasha just presented my work."],[2857,2952,"How dare you?"],[2994,3136,"Of course I stole Elle’s work."],[3203,3361,"But she'll never be able to prove that."],[3415,3557,"You're disgusting, Elle."],[3557,3674,"Blaming your incompetence on"],[3674,3749,"Natasha."],[3782,3845,"Roy,"],[3845,3991,"you rejected me."],[3991,4162,"A Lambert heiress"],[4162,4371,"for a pathetic pickpocket."],[4371,4508,"It still isn't late Roy."],[4508,4621,"divorce that woman,"],[4621,4717,"marry Bianca,"],[4717,4846,"and I'll invest"],[4846,5017,"twice as much in your company."],[5063,5280,"Barry at the risk of repeating myself,"],[5305,5488,"I'm never leaving my wife."],[5522,5630,"You're gonna have to shop elsewhere"],[5630,5751,"for your daughter's groom."],[5843,5993,"No, Leon, you are right, though."],[6122,6297,"Natasha is a genius"],[6393,6493,"at stealing."],[6527,6585,"Ms. Elle,"],[6639,6806,"this is a very serious accusation."],[6840,6952,"Do you actually have proof,"],[6952,7040,"Ms. Natasha"],[7040,7123,"stole from you?"],[7152,7223,"I do,"],[7311,7407,"but before"],[7494,7657,"I expose her for being a thief."],[7753,7899,"I'd like to prove to you guys"],[7899,8028,"why she is the fake"],[8049,8145,"Doctor Nova."]],"58":[[33,162,"Empty words, Elle,"],[179,291,"because I just proved"],[291,387,"I'm Doctor Nova"],[408,521,"by presenting a framework"],[521,671,"that could only be designed"],[671,767,"by a genius."],[779,834,"You're right."],[913,1021,"Doctor Nova did design"],[1021,1096,"that framework."],[1126,1247,"And Doctor Nova is"],[1247,1347,"going to have to fix it"],[1426,1488,"in about"],[1530,1659,"three seconds."],[1743,1793,"One,"],[1906,1964,"two,"],[1997,2097,"Firewall breached."],[2243,2318,"Natasha?"],[2452,2569,"What's going on?"],[2656,2740,"I don't know."],[2790,2915,"Ms. Natasha, the test code"],[2915,2998,"is connected to our"],[3003,3069,"company's database."],[3073,3203,"If we don't fix this now!"],[3203,3357,"Mr. Leon, all of our data"],[3357,3465,"is about to be erased!"],[3474,3570,"What the hell, Natasha?"],[3611,3695,"You're the genius."],[3695,3795,"Do something!"],[3816,3920,"I can't!"],[4074,4149,"I can't."],[4212,4350,"Of course you can't."]],"59":[[1889,1976,"How could Elle"],[1993,2131,"fix this when Natasha could not?"],[2218,2339,"Doctor Nova does it again."],[2381,2506,"What do you mean, Mr. Vice President?"],[2515,2610,"He means Natasha"],[2610,2694,"couldn’t use the framework"],[2694,2836,"she presented to fix the breach"],[2836,2994,"because she did not design it."],[3040,3244,"She stole Doctor Nova's work."],[3432,3724,"No, she just got lucky again."],[3770,3899,"Another desperate attempt"],[4016,4191,"to sabotage me and Natasha."],[4258,4341,"Because losers"],[4341,4504,"Elle and Roy have nothing to show."],[4525,4642,"Yeah, I agree."],[4662,4800,"Elle is insecure."],[4854,4884,"Oh, yeah."],[4884,5030,"She’s a divorcee"],[5030,5117,"that what?"],[5117,5301,"She's jealous of doctor"],[5305,5497,"Doctor Nova's God given talent."],[5513,5701,"Once a thief, always a thief."],[5722,5864,"She stole Roy from me,"],[5897,6010,"and now she's trying to steal"],[6010,6122,"Doctor Nova's credit."],[6247,6460,"My God, you guys are so predictable."],[6564,6681,"Well, it's a good thing I brought"],[6681,6765,"tonight's entertainment."],[6852,6998,"Elle must be about to announce"],[6998,7073,"her defeat."],[7086,7215,"Which means that I"],[7232,7457,"will be crowned as Doctor Nova."]],"60":[[20,221,"Is Natasha, not Doctor Nova?"],[250,342,"Security."],[400,583,"Search Natasha's belongings."],[596,775,"That's not my bag."],[913,1092,"Elle is framing me because"],[1092,1292,"she wants to crawl back into her"],[1292,1397,"ex-husband's bed."],[1472,1551,"Really?"],[1584,1722,"The thing with your name on it"],[1722,1818,"doesn't belong to you?"],[1843,1906,"Natasha?"],[2047,2127,"How could you?"],[2152,2285,"If I don't disown Natasha now,"],[2339,2469,"my company could be ruined."],[2515,2723,"Me and my company, Digitek,"],[2723,2827,"have nothing"],[2827,2990,"to do with Natasha Wilson."],[3178,3257,"Natasha,"],[3370,3474,"you're fired."],[3670,3795,"You're abandoning me?"],[3853,3962,"Leon divorced me,"],[3962,4104,"his wife who supported him,"],[4104,4229,"for money and status."],[4262,4441,"You really think he'd be faithful to you?"],[4475,4525,"Leon,"],[4571,4713,"that footage is fake."],[4729,4900,"Elle is trying to sabotage me"],[4900,5155,"because I'm Doctor Nova."],[5271,5388,"After all that,"],[5388,5509,"you still have the nerve"],[5509,5755,"to call yourself Doctor Nova?"],[5801,6006,"That footage certainly proves"],[6006,6210,"Natasha is a thief and a liar."],[6235,6510,"But if Natasha isn't Doctor Nova,"],[6510,6581,"does that mean..."],[6698,6794,"does that mean Elle?"]],"61":[[4,104,"Does that mean Elle"],[125,225,"is Doctor Nova?"],[291,417,"General McArthur,"],[458,579,"just because Natasha"],[579,750,"might have stolen Elle’s drive"],[754,988,"doesn't prove Elle is Doctor Nova."],[1017,1096,"How do we know"],[1130,1409,"Elle didn't steal it from Doctor Nova?"],[1443,1518,"That's right."],[1551,1630,"I mean, we're talking about"],[1630,1843,"a multi-billion dollar contract here,"],[1868,1893,"and"],[2068,2252,"come on, a desperate,"],[2252,2377,"low class assistant"],[2377,2439,"like Elle,"],[2473,2577,"and let's be honest,"],[2577,2740,"she's never really seen any money."],[2840,2952,"She's capable of anything."],[3019,3157,"Never seen any money?"],[3211,3386,"I've seen more money in my crib"],[3386,3549,"than you have seen in your entire life."],[3570,3799,"And where was this money hiding"],[3870,3949,"when I married you?"],[4041,4154,"When we got married,"],[4187,4383,"I hid my identity and talent"],[4383,4504,"to make you feel better"],[4504,4558,"Leon."],[4596,4729,"Because I loved you."],[4879,5013,"I supported your company"],[5013,5100,"for three years,"],[5100,5267,"anonymously fixing every hurdle"],[5267,5363,"you faced"],[5430,5518,"only to be cheated and"],[5518,5626,"divorced by you."],[5647,5772,"And then I married Roy."],[5797,5951,"A kind and caring husband"],[5951,6118,"who I love very much."],[6210,6327,"I love you, too, Elle."],[6585,6677,"No one wants to hear"],[6677,6948,"your sugar daddy fantasies, Elle."],[7057,7140,"General MacArthur,"],[7140,7357,"we cannot assign this contract"],[7361,7645,"until we find the real Doctor Nova."],[7707,7903,"That won't be necessary."],[8020,8083,"Dad?"]],"62":[[16,137,"That's Victor Vanderbilt,"],[175,325,"the richest man in the country."],[329,454,"What is he doing here?"],[538,638,"There were rumors"],[646,763,"that Doctor Nova"],[767,892,"is the Vanderbilt heiress and"],[905,1071,"Victor Vanderbilt’s daughter."],[1105,1159,"What?"],[1167,1297,"Looks like he's finally going to"],[1297,1484,"reveal Doctor Nova's identity."],[1593,1714,"Mr. Vanderbilt."],[1722,1860,"What an absolute honor."],[1885,1981,"Mr. Vanderbilt,"],[1993,2118,"Dad says you're going to invest"],[2118,2206,"in the company that wins"],[2206,2306,"the contract tonight."],[2352,2481,"We're supporting Leon Hearst’s"],[2481,2606,"company and we look forward"],[2606,2677,"to our partnership."],[2740,2819,"Mr. Vanderbilt,"],[2877,3040,"what an absolute honor."],[3098,3199,"I'm Leon Hearst,"],[3236,3411,"CEO of Digitek."],[3499,3578,"So you're the creep,"],[3578,3657,"who my daughter's been supporting"],[3657,3774,"for three years."],[3908,3999,"There have been rumors"],[3999,4170,"that Doctor Nova could be an heiress,"],[4191,4291,"and Doctor Nova supported me"],[4291,4396,"for three years, but"],[4408,4529,"I thought it was Natasha."],[4567,4692,"Roy, thanks for calling me."],[4725,4959,"I believe I've arrived just in time."],[4984,5134,"Roy called my father."],[5188,5255,"Does he know I'm"],[5255,5384,"the Vanderbilt heiress?"]],"63":[[158,379,"You called Victor Vanderbilt?"],[400,492,"My..."],[492,542,"Your dad."],[608,671,"Yes,"],[734,829,"I did."],[896,1076,"I found this, uh, photo"],[1076,1343,"on your desk this morning."],[1368,1634,"And that cipher wheel pendant,"],[1676,1881,"a Vanderbilt’s heirloom."],[1935,2014,"I,"],[2060,2223,"had my suspicions for a while."],[2414,2569,"Roy, I wanted to tell you."],[2610,2702,"I just wanted to make sure"],[2702,2815,"you loved me for me."],[3019,3157,"Elle Vanderbilt,"],[3244,3407,"I've loved you from the moment"],[3424,3561,"I laid my eyes on you."],[3749,3799,"Victor,"],[3858,4020,"what a pleasant surprise."],[4116,4237,"We were just going to reveal"],[4237,4404,"the identity of Doctor Nova."],[4404,4587,"And your presence is perfect."],[4675,4796,"Victor's known Doctor Nova"],[4796,4892,"since she was a child."],[4959,5067,"And I think it's time"],[5067,5213,"that the real Doctor Nova"],[5230,5501,"took her place on that golden throne."],[5572,5764,"Yes, yes, please, Mr. Vanderbilt."],[5789,6031,"I'm dying to see this woman who"],[6047,6247,"selflessly supported me all these years."],[6281,6514,"And if I may say so,"],[6585,6735,"I’ve always been in love"],[6735,6852,"with your daughter."],[6852,6923,"Doctor Nova."],[7077,7228,"I think you're incapable of love,"],[7228,7307,"Leon Hearst."]],"64":[[75,350,"Ignore this woman, Mr. Vanderbilt."],[350,437,"Just my ex-wife"],[437,613,"desperately trying to get back with me."],[709,834,"Good thing she's your ex."],[867,975,"You don't seem to deserve"],[975,1117,"a smart woman."],[1234,1397,"You know how all these low class"],[1397,1626,"leeches always try to suck"],[1626,1697,"money out of us"],[1697,1772,"elites."],[1885,2002,"I wouldn't consider someone with"],[2002,2256,"your foul language to be an elite."],[2348,2452,"What my father meant,"],[2452,2540,"Mr. Vanderbilt,"],[2540,2777,"is that we shouldn't waste time"],[2777,2969,"on such nobodies."],[3140,3232,"Oh, Bianca,"],[3307,3482,"I wish money could buy you a brain."],[3482,3557,"Shut up"],[3557,3599,"Elle."],[3641,3774,"You tried everything from"],[3774,3903,"marrying my competitor,"],[3903,4016,"Roy Boy"],[4054,4237,"to stealing Doctor Nova’s work"],[4283,4421,"and even sabotaging"],[4421,4592,"my company's presentation."],[4629,4704,"Guards!"],[4808,4959,"Get this lowlife out of here!"],[4971,5055,"That's right."],[5109,5171,"It's about time"],[5171,5309,"someone threw this bitch out."],[6093,6423,"Don't you dare touch my daughter."],[6627,6710,"Elle is"],[6710,6856,"Victor Vanderbilt's daughter?"],[6877,6948,"Does that mean she's..."]],"65":[[12,104,"Your daughter?"],[129,241,"Mr. Vanderbilt,"],[275,429,"you must be mistaken."],[521,600,"Elle’s just a"],[625,713,"worthless assistant."],[713,817,"That's why I divorced her."],[946,1092,"You’re not just a selfish man"],[1092,1272,"blinded by wealth and power."],[1363,1584,"You're also an absolute idiot."],[1622,1785,"Elle is not just my daughter,"],[1785,1960,"she's much more than that."],[2072,2127,"Elle,"],[2189,2273,"I think it's time you took your"],[2273,2348,"rightful place"],[2348,2419,"on that throne."],[2898,3028,"I am Elle Vanderbilt,"],[3048,3232,"daughter of Victor Vanderbilt,"],[3265,3461,"heir to the Vanderbilt empire."],[3499,3691,"And I am Doctor Nova."],[3795,3903,"I'm proud of you, my girl."],[3924,4041,"You're a true genius"],[4095,4187,"because you didn't use your name"],[4187,4320,"or your status to get ahead."],[4362,4437,"Bravo."],[4512,4558,"Elle,"],[4754,4846,"I am so sorry."],[4875,5042,"If only I had known"],[5042,5205,"that you were Doctor Nova."],[5209,5288,"I, um,"],[5338,5426,"Well in fact,"],[5476,5638,"in fact, I kept thinking about"],[5689,5780,"getting back with you"],[5780,5872,"this whole while."],[5976,6189,"Come back to me, Elle,"],[6277,6377,"I love you."],[6468,6677,"You didn't divorce a worthless assistant,"],[6677,6769,"Leon."],[6810,7032,"I divorced a genius heiress."]],"66":[[112,308,"Congratulations, Doctor Nova."],[333,492,"You're rightfully deserved"],[492,642,"multi-billion dollar"],[646,800,"government contract."],[1042,1180,"Thank you, general McArthur."],[1238,1343,"However, my husband Roy"],[1343,1405,"and his team deserve"],[1405,1547,"just as much as I do."],[2248,2406,"Miss Elle Vanderbilt,"],[2464,2740,"Doctor Nova, thousand apologies."],[2857,2965,"I never would have made the decision"],[2965,3111,"if it wasn't for the lies of"],[3111,3211,"Leon and Natasha."],[3211,3507,"So good for you for exposing them."],[3541,3712,"Governor Smith."],[3712,3903,"Now, I almost forgot."],[3903,4045,"I actually have a special video"],[4045,4204,"starring you too."],[4800,4942,"$1 million."],[4979,5059,"Yours if you vote"],[5059,5255,"for my project to win the contract."],[5388,5663,"And here's 50 million for us"],[5663,5772,"getting all the government"],[5772,5964,"contracts in your state."],[6056,6135,"Yes, sir."],[6427,6598,"Governor Smith,"],[6598,6740,"you were eager to see me"],[6740,6844,"in a federal prison."],[6948,7094,"Well, now you're going to live there."],[7173,7278,"And Mr. Lambert,"],[7332,7453,"you betrayed Roy"],[7453,7574,"when he didn't want to leave me."],[7624,7849,"But now he has $1 billion contract, and"],[7987,8070,"you just have several"],[8070,8183,"lawsuits waiting for you."]],"67":[[37,354,"Guards arrest these corrupt buffoons."],[909,1026,"I'm sorry."],[1184,1247,"Okay,"],[1247,1343,"okay."],[1343,1397,"Elle,"],[1397,1643,"I was just following my dad's orders."],[1676,1776,"And, Roy,"],[1776,1947,"we've been friends since childhood."],[1947,2135,"I mean, I've always considered you"],[2135,2235,"a sibling."],[2235,2364,"Really, B?"],[2435,2540,"I thought you wanted me"],[2540,2673,"to leave Elle"],[2731,2848,"and marry you."],[2940,3057,"You know, Bianca,"],[3057,3153,"I actually think"],[3153,3311,"I have the perfect guy for you."],[3403,3528,"My ex-husband Leon."],[3599,3791,"See, he divorced me for Natasha"],[3791,3958,"when he thought she was Dr. Nova."],[3991,4162,"But then left her too"],[4162,4262,"the second she wasn't any"],[4262,4387,"use to him anymore."],[4437,4533,"He changes colors"],[4533,4713,"just as fast as you do."],[5217,5518,"Elle, I mean Dr. Nova."],[5518,5734,"You know, Leon never deserved"],[5734,5922,"a genius like you."],[6051,6210,"Good on you for divorcing him."],[6268,6360,"Really?"],[6677,6819,"Didn't you say I deserved"],[6819,6969,"the divorce because I'm worthless?"],[7169,7424,"No. Leon actually seduced me."],[7424,7586,"So, you know, I would have never"],[7586,7720,"broken up your marriage."],[7778,7945,"Okay. You're good to go, Natasha."],[8012,8166,"Stupidity isn't a crime."],[8404,8616,"Maybe you're not that smart, Elle."],[8692,8850,"Because I did seduce Leon"],[8850,8929,"for money."],[8971,9150,"But she'll never be able to prove that."],[9163,9259,"However, impersonating"],[9259,9384,"someone and stealing"],[9384,9463,"intellectual property"],[9463,9688,"certainly are big crimes."],[9797,9876,"Guards!"],[9959,10047,"Arrest her!"],[10151,10360,"Elle, doctor, I mean doctor."],[10360,10418,"Doctor."],[11044,11136,"Ugh!"],[11444,11549,"Elle, um,"],[11590,11644,"I"],[12103,12199,"Elle, I..."]],"68":[[95,158,"I know you"],[187,387,"married Roy, only to get back"],[400,467,"at me."],[588,709,"But I forgive you."],[792,892,"You still love me."],[975,1063,"And divorcing you was"],[1096,1234,"the biggest mistake"],[1234,1338,"of my life."],[1539,1651,"And marrying you"],[1651,1839,"was the biggest mistake in mine."],[2081,2168,"You only want me back"],[2168,2335,"because I'm a genius heiress."],[2464,2698,"Roy loved me when I was nobody."],[2836,2898,"I love him,"],[2898,3090,"and I am never going to leave him."],[3415,3574,"There is one thing I'm taking back"],[3574,3649,"from you, though."],[3782,3928,"Your company."],[3928,4162,"Or rather, my company"],[4162,4270,"that I built from the ground up"],[4270,4371,"while you were cheating on me."],[4596,4692,"Thank you."],[4996,5100,"I'm buying you out."],[5184,5267,"You'll never do business"],[5267,5376,"with anyone ever again."],[5509,5568,"No."],[5684,5747,"No."],[6097,6260,"First, I"],[6260,6385,"lost my genius"],[6385,6498,"heiress wife,"],[6602,6869,"and now I'm losing my, my company?"],[7891,8137,"How about a romantic"],[8137,8287,"candlelit dinner"],[8287,8458,"to celebrate your success?"],[8491,8575,"Dr. Nova."],[8587,8692,"Would you prefer the Ferrari"],[8692,8821,"or the Rolls-Royce?"],[8988,9129,"How about hot dogs?"],[9171,9325,"On Dr. Nova’s ride."],[9526,9642,"Your wish is my command."]]}