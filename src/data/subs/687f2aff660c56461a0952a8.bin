{"1":[[279,417,"My name is Elle Vanderbilt."],[417,596,"Three years ago, I left everything"],[596,775,"behind to marry the love of my life"],[775,884,"and become an assistant"],[884,955,"at his company."],[975,1217,"And today, on our third anniversary,"],[1230,1380,"I'm finally ready to tell him"],[1380,1543,"my biggest secret."],[3078,3219,"Elle, it's a disaster."],[3219,3403,"Digitek’s server has been hacked."],[3403,3495,"Our system's about to"],[3495,3536,"collapse"],[3536,3653,"in the next five minutes."],[3653,3841,"Calm down, I got this."],[3841,3903,"How?"],[3903,4062,"Even our best engineers are lost."],[4062,4250,"Doctor Nova saved us during the last"],[4250,4425,"attack, but no one knows who she is."],[4425,4575,"I said, I got this."],[4604,4704,"But are you even carrying"],[4704,4825,"your laptop with you?"],[5000,5205,"Oh I’m never without a laptop."],[5205,5321,"Excuse me, sir?"],[5321,5463,"Can I get a hot dog, please?"],[5463,5555,"Certainly, miss."],[5555,5651,"Be out in just a minute."],[5818,5922,"That’s all I need."],[9430,9551,"Your hot dog’s ready, miss."],[10902,11148,"$10,000 approved."],[11148,11357,"Miss."],[11357,11511,"This is."],[11511,11811,"The best hotdog I've ever had."],[12183,12341,"Elle! The system's back up."],[12341,12424,"How did you do it?"],[12424,12558,"Did you find Doctor Nova?"],[12616,12679,"The big secret"],[12679,12862,"I'm going to tell my husband tonight."],[12862,13029,"I am Doctor Nova."],[13067,13209,"Youngest Stanford, PhD in the world's"],[13209,13363,"top cyber security tech."]],"2":[[66,158,"City Hall."],[233,425,"I can't believe it was three years ago"],[425,613,"today that Leon and I got married here."],[2189,2439,"No, I told you, find me Doctor Nova."],[2439,2535,"I don't care how much,"],[2535,2665,"I need her at my company."],[2802,2836,"Got to go."],[2836,3003,"My contract bride is here."],[3319,3411,"Hey there."],[3507,3632,"I suppose an introduction"],[3645,3757,"is in order."],[3828,3941,"I'm Roy Grant,"],[3941,4091,"Yale PhD"],[4091,4208,"and sole heir"],[4208,4333,"to the second"],[4333,4504,"wealthiest family in the country."],[4688,4754,"Hi."],[4854,4938,"Elle Vanderbilt."],[4938,5067,"High school diploma."],[5067,5163,"Executive assistant."],[5163,5438,"Just a normal girl."],[5447,5601,"None of that matters to me."],[5759,5893,"Now, let's get married."],[5951,6081,"I'm sorry. Excuse me?"],[6126,6331,"No, I'm already married."],[6485,6606,"Married? I..."],[6673,6765,"I thought we agreed"],[6765,6919,"on half a million dollars"],[6919,7077,"for a no hassle contract"],[7077,7148,"marriage."],[7236,7311,"I'm sorry."],[7311,7449,"I think you're mistaking me"],[7449,7570,"for someone else."],[8779,8800,"Look,"],[8800,8913,"I’ve got to go, but"],[8983,9225,"good luck with your contract marriage."],[9488,9672,"Happy anniversary, my love."],[10744,10865,"Leon, what is this?"],[11015,11086,"Sign this,"],[11086,11131,"Elle."]],"3":[[0,104,"What is that?"],[108,237,"Isn’t it obvious?"],[237,467,"I’m divorcing you, Elle."],[650,704,"What?"],[800,896,"Well,"],[930,1059,"Digitek"],[1059,1180,"just won a"],[1180,1292,"billion dollar"],[1292,1463,"government contract."],[1509,1597,"Which means,"],[1597,1730,"that Leon here"],[1789,1993,"is the number one tech CEO"],[1993,2147,"in the country."],[2147,2285,"He can’t have an assistant"],[2285,2406,"who is a lowlife"],[2406,2485,"as a wife."],[2531,2711,"Uh, look, honey I was just coming"],[2711,2852,"Don’t call me that."],[3007,3128,"I should have never married a worthless"],[3128,3232,"woman to begin with."],[3299,3407,"Worthless?"],[3474,3599,"I wrote the prototype"],[3599,3674,"that got you that"],[3674,3828,"billion dollar contract."],[3862,3958,"Because I am the real..."],[3958,4179,"You are nothing, Elle."],[4275,4366,"Natasha’s the one who"],[4366,4479,"wrote that prototype."],[4592,4650,"Ten minutes back"],[4650,4804,"she single-handedly saved"],[4804,4971,"Digitek’s sytems from collapsing."],[4971,5096,"Because she"],[5238,5355,"is Dr. Nova."],[5467,5559,"That is a lie."],[6126,6210,"Truth is,"],[6210,6289,"Elle."],[6352,6481,"I am the greatest tech genius"],[6481,6552,"in the world."],[6602,6673,"And you"],[6886,6994,"you’re just an assistat"],[6994,7065,"with no money"],[7065,7190,"and no college degree."],[7265,7382,"Are you really surprised"],[7382,7524,"that Leon is leaving you"],[7524,7574,"for me?"],[7574,7728,"Leon this woman is a liar."],[7728,7849,"Are you calling this"],[7849,7937,"humble"],[7957,8028,"genius"],[8045,8116,"a liar?"],[8237,8458,"Natasha is the Dr. Nova,"],[8479,8750,"who secretly helped me for three years"],[8779,8963,"without seeking recognition."],[9034,9104,"Unlike you"],[9109,9334,"who has been leeching off me."],[9484,9601,"She will help Digitek"],[9613,9801,"achieve success you can never"],[9801,9914,"imagine, Elle."],[9959,10139,"That is a lie."],[10139,10268,"I'm the one that sacrificed"],[10268,10452,"three years of my life"],[10452,10543,"to build this company"],[10543,10727,"because I am Dr. Nova."]],"4":[[0,54,"Are you sure,"],[70,120,"Leon?"],[162,237,"That Natasha"],[237,346,"is this tech genius"],[346,442,"you’ve been looking for?"],[517,621,"Because from where I stand,"],[621,763,"she seems pretty fake."],[834,938,"How dare you."],[938,1005,"You Bitch!"],[1272,1376,"Leon, did you see that?"],[1376,1514,"She just attacked me!"],[1543,1626,"How dare you!"],[1655,1797,"Apologize to Natasha."],[1826,1893,"Now!"],[1956,2035,"Seriously?"],[2093,2239,"You saw what she just did,"],[2239,2348,"and now you’re asking me,"],[2348,2444,"your wife,"],[2485,2702,"to apologize to this homewrecker?"],[2715,2869,"Time to face the truth, Elle."],[3003,3094,"You are nothing"],[3128,3249,"compared to Natasha."],[3795,3928,"Will you be my date tonight"],[3928,3987,"at the banquet?"],[3987,4079,"Dr. Nova."],[4479,4621,"Here’s a million dollars."],[4637,4808,"Sign the divorce papers"],[4808,4946,"and you get it."],[5150,5276,"Just take it, Elle."],[5330,5451,"You know you want it."],[5497,5613,"You won’t make that much money"],[5613,5755,"in two lifetimes."],[5993,6160,"Don’t let them see you cry, Elle."],[6281,6423,"Leon doesn’t deserve the love"],[6473,6619,"or the energy I put into this"],[6619,6702,"company for him."],[7691,7799,"We’ll see how long it takes"],[7799,7916,"for you to regret this."],[8312,8441,"Oh, and as for the money?"],[9188,9263,"I don’t need it."],[9438,9547,"Suit yourself."],[9651,9772,"Don’t come crying back to me"],[9772,9859,"when you’re dying,"],[9897,9943,"broke,"],[10005,10110,"and all alone."],[10226,10343,"Yeah, we’ll see about that."],[11236,11282,"Hi."],[11482,11574,"You need a wife, right?"],[11669,11782,"Well, uh..."],[11840,11911,"I'll marry you."],[11999,12037,"For free."]],"5":[[258,437,"Are you sure?"],[567,625,"What about"],[625,746,"your husband back there?"],[821,863,"That's"],[921,1051,"Leon Hearst,"],[1096,1142,"the lizard."],[1163,1322,"Hotshot tech CEO, right?"],[1338,1484,"Ex husband."],[1543,1685,"He means nothing to me anymore."],[1701,1776,"Um,"],[1910,1972,"Well."],[1972,2068,"Allright."],[2202,2268,"Just so you know,"],[2268,2310,"it’s"],[2381,2527,"a contract marriage."],[2565,2748,"Just to get my family off my back."],[2756,2865,"Sounds perfect."],[2969,3048,"Shall we?"],[3148,3274,"There’s something about her."],[3315,3420,"Why am I so"],[3436,3528,"intrigued?"],[4237,4320,"Hello,"],[4387,4450,"Boss,"],[4450,4579,"we have a massive data breach"],[4579,4658,"on our mainframe."],[4679,4817,"All our data will be wiped out"],[4817,4909,"if it isn't fixed now."],[4938,5117,"My God, I'll be right there."],[5159,5292,"I'm sorry, I got to run."],[5301,5417,"There's an emergency at work."],[5417,5522,"I'll go with you."],[5593,5714,"I mean, we're married now."],[5714,5864,"I'd like to see what you do."],[5997,6106,"Besides,"],[6189,6302,"maybe I could help."],[6493,6623,"Ladies first."],[7841,7982,"You work for AlphaTech?"],[8053,8224,"No, I don’t work for AlphaTech."],[8283,8495,"I own AlphaTech."],[9317,9501,"Alphatech is the biggest player"],[9501,9613,"in cyber security."],[9613,9830,"If I wasn’t helping Leon,"],[9830,9968,"Alphatech would’ve wiped him out"],[9968,10047,"and they would’ve landed the"],[10047,10147,"billion dollar contract."],[10147,10285,"Interesting."],[10356,10460,"My new husband is my"],[10460,10535,"ex husband’s"],[10535,10719,"biggest business nemesis."]],"6":[[246,479,"Attention, everyone."],[479,692,"As you know, we just beaten our"],[692,804,"biggest competitor"],[913,1017,"Alphatech."],[1071,1309,"To secure the billion dollar contract."],[1413,1514,"Which I"],[1564,1651,"will be signing,"],[1693,1739,"tonight,"],[1814,1947,"at the prestigious tech gala"],[1947,2064,"hosted by the government."],[2064,2118,"Yeah."],[2118,2210,"Come on."],[2473,2540,"Also,"],[2540,2648,"at the banquet,"],[2731,2840,"I'll be announcing,"],[2848,3044,"Digitech’s new chief technologist"],[3044,3178,"Natasha Wilson"],[3178,3240,"aka"],[3249,3461,"the legendary Doctor Nova."],[3620,3678,"Yeah."],[3678,3837,"Let's hear it."],[4133,4279,"Natasha’s Doctor Nova?"],[4279,4379,"I thought Elle would be"],[4379,4508,"our Chief Technologist."],[4579,4688,"She may have been an assistant,"],[4688,4792,"but she built this company"],[4792,4963,"from the ground up for Leon."],[4963,5071,"You haven't heard?"],[5117,5301,"Dude, Leon kicked her to the curb."],[5301,5367,"What?"],[5367,5463,"How is she supposed to"],[5463,5601,"compete with the Doctor Nova?"],[5676,5789,"Well done. Natasha."],[5789,5939,"You've tricked them into"],[5939,6139,"believing that you are the genius"],[6139,6214,"Doctor Nova."],[6214,6335,"Fame and fortune."],[6335,6414,"Here I come."],[7069,7136,"Boss,"],[7136,7269,"we've tried everything."],[7269,7378,"These hacker viruses"],[7378,7453,"are too strong."],[7478,7599,"We only have ten minutes"],[7599,7707,"before we lose all our data"],[7707,7782,"permanently."],[7828,7966,"All right, keep it cool."],[7966,8091,"We've got this."],[8091,8145,"I'm going to go check"],[8145,8283,"mainframe."],[8391,8500,"It's over."],[8500,8608,"It would take an Einstein"],[8608,8800,"to fix something like this in ten minutes."],[9230,9313,"I can fix this."]],"7":[[200,262,"Lady,"],[262,371,"this isn’t Candy Crush."],[371,442,"Do you even know how to"],[442,521,"start a computer?"],[546,596,"Yeah,"],[596,679,"why don’t you go touch up"],[679,788,"on your makeup or something."],[825,917,"Don’t waste our time."],[930,1046,"You’re wasting more time by"],[1046,1138,"arguing."],[1138,1230,"Who even are you?"],[1230,1326,"How did you get in here?"],[1326,1388,"You don’t even..."],[1455,1555,"What’s going on here?"],[1597,1735,"Roy, I can fix this."],[1856,1922,"Elle,"],[1922,2010,"this requires"],[2010,2152,"advanced coding skills."],[2198,2360,"These folks have been at it for years."],[2360,2452,"It’s the hashing algorithm."],[2452,2581,"They haven’t been looking at it."],[2873,2957,"Trust Me."],[3065,3207,"I won’t let you fail."],[3290,3407,"Why do I want to believe her?"],[3607,3724,"You have five minutes."],[6881,6994,"System back online."],[6994,7107,"All functions nominal."],[7107,7223,"That’s impossible."],[7319,7444,"I’ve been in cyber security"],[7444,7549,"for twenty years"],[7549,7645,"and I couldn’t crack it."],[7699,7795,"Only the best of the best"],[7795,7878,"could’ve done this."],[8028,8091,"Elle,"],[8166,8245,"come with me,"],[8337,8387,"we,"],[8387,8458,"need to talk."],[8658,8787,"There’s only one person"],[8787,8933,"in the country that could’ve done that."],[8996,9100,"I’ve been looking"],[9100,9188,"for her for years."],[9255,9338,"Are you..."],[9476,9613,"Doctor Nova?"]],"8":[[16,116,"Are you,"],[191,312,"Doctor Nova?"],[325,479,"Even my ex-husband of three"],[479,617,"years couldn't figure out that"],[617,771,"I was Doctor Nova."],[955,1167,"This man really sees me."],[1288,1397,"Actually,"],[1472,1530,"I--"],[1609,1768,"Sir."],[1776,1901,"Digitech just announced its new"],[1901,2039,"Chief Technologist"],[2039,2185,"is Doctor Nova."],[2489,2677,"Elle’s prick ex-husband Leon"],[2677,2790,"got Doctor Nova."],[2840,2990,"I guess Elle isn’t Doctor Nova"],[2990,3140,"after all."],[3174,3407,"But she did fix that system back there."],[3536,3611,"Elle,"],[3661,3787,"I would like you to be Alphatech’s"],[3787,3866,"new,"],[3916,4087,"chief technologist."],[4483,4612,"That's an interesting"],[4612,4725,"proposal, Roy."],[4725,4871,"You have a brilliant mind"],[4871,4938,"Elle,"],[5021,5138,"and you know it."],[5180,5405,"Alpha Tech's been top player for years"],[5442,5576,"until Leon Hearst"],[5576,5759,"got the billion dollar contract."],[5818,5901,"But together,"],[5960,6118,"we can take him down."],[6139,6218,"Plus,"],[6247,6327,"don't you want to see the look"],[6327,6443,"on your cheating ex-husband's"],[6443,6489,"face"],[6548,6735,"when he's defeated by his business"],[6735,6810,"nemesis"],[6844,6927,"and his ex-wife?"],[6973,7119,"The only reason Leon even has"],[7119,7215,"this contract"],[7215,7357,"is because of a prototype"],[7357,7440,"that I wrote."],[7440,7553,"What he doesn't know"],[7553,7724,"is that I've written a new and enhanced"],[7724,7874,"AI based prototype"],[7874,8003,"that will take down"],[8003,8141,"Leon’s tech empire."],[8375,8437,"Alright,"],[8458,8575,"I'm in."],[8575,8808,"Let’s do this."],[8808,8921,"Welcome to AlphaTech."]],"9":[[592,734,"Please tell me that's not what you're"],[734,859,"wearing to your meeting."],[859,930,"I thought about it,"],[1063,1130,"but"],[1176,1334,"I think it will suit you better."],[1484,1555,"This,"],[1634,1718,"is tonight."],[1789,1881,"The biggest gala"],[1881,2027,"for the top tech CEOs"],[2027,2135,"in the country."],[2231,2352,"I heard your"],[2352,2427,"ex-husband"],[2427,2573,"will not only be signing"],[2590,2723,"the billion dollar contract there,"],[2723,2786,"but"],[2865,2936,"also introducing"],[2936,3053,"Doctor Nova to the world."],[3269,3361,"Roy, what if I"],[3440,3549,"told you I'm the real"],[3549,3649,"Doctor Nova?"],[3799,3883,"Hey."],[3966,4062,"You don't need to pretend"],[4062,4250,"to be someone else to impress me."],[4250,4300,"Elle."],[4416,4571,"I'm already impressed by you."],[4662,4838,"And I like you for who you are."],[4954,5088,"He really means that."],[5242,5380,"Being with him just"],[5518,5597,"feels right."],[5714,5764,"Now,"],[5847,5947,"let's go and have some fun"],[5947,6068,"at this party tonight, shall we?"]],"10":[[175,204,"Hey,"],[221,254,"Elle."],[291,396,"I'm stuck in traffic,"],[396,483,"and it's pretty bad."],[492,579,"I'll have to meet you at the banquet"],[579,638,"directly."],[684,742,"Don't worry."],[821,913,"I'm already here."],[1009,1092,"Alright."],[1092,1334,"Well, I'll be there as soon as I can."],[1359,1426,"Sorry."],[2861,2977,"All these elites,"],[2998,3111,"here to see me."],[3186,3374,"The genius Doctor Nova."],[3465,3561,"These are the country's"],[3561,3720,"top tech CEOs."],[3837,3937,"Watch their faces burn"],[3937,4033,"when they see me"],[4045,4170,"sign the billion"],[4170,4329,"dollar contract tonight."],[4567,4662,"That’s Governor Smith"],[4813,4942,"coming to suck up to us."],[4984,5150,"Future rulers of the world."],[5292,5384,"Doctor Nova."],[5488,5530,"Wow."],[5609,5768,"Stanford's youngest PhD."],[5797,5864,"World's top"],[5864,6026,"cybersecurity expert."],[6160,6281,"Geniuses like yourself are"],[6281,6389,"our country's greatest treasures."],[6473,6531,"Thank you for coming"],[6531,6602,"to the banquet."],[6606,6694,"Governor Smith."],[6744,6881,"We can't wait to sign the contract."],[6898,6952,"Of course, of course."],[6961,7048,"And we'll get to all that."],[7082,7194,"Once Roy Grant,"],[7211,7336,"Alphatech CEO arrives."],[7353,7449,"He's our only other"],[7520,7640,"gold VIP attendee"],[7640,7682,"here tonight"],[7682,7786,"besides"],[7786,7874,"yourself."],[7991,8124,"So in the meantime,"],[8137,8216,"why don't I go ahead"],[8216,8274,"and get the introduction"],[8274,8320,"started?"],[8483,8541,"Cheers."],[8754,8833,"I can't believe it."],[8871,8929,"Roy Grant,"],[8929,9021,"my biggest nemesis,"],[9021,9113,"is going to be here."],[9129,9225,"Can't wait to see his face"],[9225,9367,"when he realizes I found you."],[9380,9434,"The real"],[9434,9509,"Doctor Nova"],[9509,9601,"before he could."],[9738,9909,"Ha ha! Welcome, everyone."],[9922,10026,"Welcome, welcome."],[10055,10176,"I want to start tonight off"],[10176,10272,"by giving a huge"],[10272,10389,"congratulations"],[10389,10497,"to Digitech"],[10497,10623,"and its CEO,"],[10623,10785,"Mr. Leon Hearst."],[10831,10935,"He is the winner"],[10935,11048,"of the government's prestigious"],[11048,11123,"multi-billion"],[11123,11223,"dollar contract."],[11286,11357,"Put your hands together"],[11357,11415,"ladies and gentlemen."],[11561,11661,"Now I know, I know."],[11661,11803,"We're all curious and eager"],[11803,11840,"to"],[11878,12012,"find out who the tech genius is"],[12012,12137,"behind all of this success."],[12216,12320,"Ladies and gentlemen."],[12328,12437,"Without further ado,"],[12437,12595,"the brilliant, the beautiful"],[12616,12708,"Doctor Nova."],[14180,14268,"Did the party already"],[14268,14347,"start without me?"]],"11":[[187,300,"Elle Vanderbilt?"],[358,513,"That's Mr. Leon's ex-wife."],[571,721,"She used to be his assistant."],[779,900,"Look at her now."],[959,1059,"I bet she scored a huge"],[1059,1163,"alimony check."],[1197,1234,"No way"],[1234,1288,"a bottom dwelling"],[1288,1409,"assistant could afford that"],[1409,1468,"dress."],[1655,1726,"Excuse us."],[1976,2018,"Elle,"],[2081,2164,"what are you doing here?"],[2202,2273,"You tore up that"],[2273,2385,"million dollar alimony check"],[2385,2494,"I generously offered you,"],[2494,2556,"remember?"],[2594,2686,"Are you crawling back"],[2686,2736,"because"],[2773,2869,"you want the money now?"],[2886,2973,"Oh, Leon,"],[3065,3211,"you can afford what I'm worth."],[3286,3319,"Oh."],[3353,3415,"Elle,"],[3445,3557,"did you come back to collect"],[3557,3661,"that ugly little cactus"],[3661,3828,"you left on your office desk?"],[3941,3974,"Well,"],[3974,4129,"cactus can thrive anywhere."],[4191,4233,"Unlike,"],[4233,4304,"parasites"],[4304,4487,"who mooch off others."],[4512,4600,"You!"],[4854,4892,"Elle,"],[4929,5080,"you're a pathetic loser"],[5080,5192,"who's just jealous"],[5192,5338,"of Natasha's brilliance."],[5409,5530,"Oh, Leon, the only thing"],[5530,5659,"Natasha has on me"],[5718,5814,"is thick skin to"],[5814,5914,"be a home wrecker."],[5980,6022,"Okay,"],[6022,6114,"how did a peasant"],[6114,6272,"like you even get into an elite"],[6272,6331,"event like this"],[6331,6439,"without an invitation?"],[6439,6506,"Elite?"],[6548,6639,"Is that what they're calling"],[6639,6744,"trash these days?"],[6802,6919,"How dare you,"],[6919,7044,"you little skank!"],[7057,7178,"Is there a problem?"],[7219,7286,"Governor."],[7303,7390,"This lowlife"],[7415,7565,"is here without an invitation."],[7620,7724,"Governor Smith, is it?"],[7741,7791,"Yes, ma'am."],[7878,7974,"I heard the government"],[7974,8112,"organized this entire banquet"],[8112,8141,"for the"],[8141,8199,"top tech"],[8199,8333,"tycoons and the famous"],[8333,8412,"Doctor Nova."],[8445,8596,"Well, that's exactly why I'm here."]],"12":[[66,133,"I'm sorry."],[133,258,"Are you saying you’re"],[258,433,"Doctor Nova?"],[646,775,"I'm sorry lady."],[775,917,"I literally just introduced"],[917,1076,"the real Doctor Nova to everyone."],[1076,1213,"Well you didn't let me finish."],[1272,1380,"I'm here because"],[1380,1564,"I'm Roy Grant’s date."],[1589,1676,"Does she mean?"],[1676,1743,"The"],[1743,1830,"Roy Grant."],[1830,1939,"Billionaire"],[1939,2102,"and CEO of Alpha Tech."],[2135,2364,"The second richest man in the country."],[2456,2623,"Outside of Mr. Vanderbilt."],[2623,2673,"I heard"],[2673,2923,"he's super smart and super hot."],[2948,3111,"He's the golden bachelor."],[3140,3265,"He's gotten proposals"],[3265,3403,"from all the richest heiresses,"],[3403,3532,"and he's rejected them all."],[3574,3632,"I'm sorry"],[3632,3753,"Mr. Grant is the only"],[3753,3924,"other gold VIP attendee"],[3924,4029,"here tonight besides"],[4029,4104,"Leon Hearst."],[4145,4225,"Leon,"],[4270,4450,"Elle’s trying to make you jealous"],[4487,4575,"because you're with me."],[4721,4917,"The genius Doctor Nova."],[4917,5084,"You really expect us to believe"],[5084,5301,"that the hottest and richest man"],[5301,5367,"in the city"],[5367,5472,"would bring a low life"],[5472,5643,"like you to an event like this?"],[5651,5747,"Well, he,"],[5797,5943,"he is not that hot."],[6035,6218,"Roy Grant is the hottest"],[6218,6335,"bachelor in town."],[6335,6485,"Everybody knows that."],[6702,6815,"He would never,"],[6911,6961,"ever"],[6961,7111,"go for a low life like you."],[7115,7236,"You are out of his league."],[7269,7432,"I wouldn't be so sure."],[7432,7582,"I'm way out of Leon's league,"],[7582,7632,"and"],[7632,7774,"I still got with him."],[7870,8003,"Anything's possible."],[8091,8229,"Do you see that prestigious signing"],[8229,8274,"table"],[8274,8391,"over there?"],[8412,8521,"I'm about to sign"],[8521,8779,"a billion contract on it."],[9050,9192,"Get your filthy presence"],[9192,9334,"away from that table."],[9438,9655,"Don't be so dramatic, Natasha."],[9705,9805,"I have more right than"],[9805,9934,"anybody to be here."],[9934,10060,"Because this contract,"],[10060,10206,"Leon only has it because"],[10206,10356,"of the prototype that I wrote."],[10402,10468,"I know you're desperate"],[10468,10585,"to have me back Elle,"],[10648,10719,"but claiming that"],[10719,10973,"an uneducated assistant like you"],[10973,11056,"got me"],[11077,11236,"a billion contract"],[11311,11382,"is delusional."],[11465,11586,"Everyone knows"],[11611,11736,"that Doctor Nova helped"],[11736,11870,"Leon get that contract."],[11911,12007,"Is that so?"]],"13":[[45,108,"I gave up"],[133,237,"three years of my life"],[237,337,"loving 