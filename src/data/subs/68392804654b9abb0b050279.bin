{"1":[[41,184,"There are moments in our lives"],[184,342,"that seem to change us."],[383,571,"Moments we keep going back to,"],[571,817,"but never in the world did I imagine"],[817,1084,"I'd be kissing Fabian Winston,"],[1146,1388,"LA's most famous golden bachelor."],[1422,1589,"To make sense of how we got here,"],[1589,1764,"let's go back three days ago."],[1843,2043,"I was ready to get married that time."],[2369,2469,"What the hell?"],[2489,2631,"What a buzzkill!"],[2648,2852,"Nichole, just relax, okay?"],[2852,2965,"It's not what it looks like."],[2965,3157,"So you're not cheating on me with my bridesmaid?"],[3157,3332,"Three days before our wedding."],[3461,3545,"How could you?"],[3678,3812,"You're my best friend."],[3878,4087,"I invited you to be my bridesmaid, Chelsey."],[4129,4237,"Why would you do that?"],[4608,4796,"Don't be so emotional, Nichole."],[4815,5016,"You should thank me for giving your fiancée"],[5016,5255,"one last unforgettable night as a single man."],[5384,5547,"You are a cheap whore."],[5634,5801,"How dare you say that to me?"],[5872,6047,"Jason deserves a real woman,"],[6131,6185,"like me."],[6264,6356,"And, Nichole,"],[6356,6556,"not to point fingers or anything, but...."],[6556,6673,"it's kind of your fault."],[6706,6827,"I mean, you have been working all the time."],[6877,7045,"I have been working so hard because"],[7045,7202,"you wanted a luxury apartment"],[7202,7311,"and a nice car to show...."],[7311,7453,"Okay. Stop. Okay?"],[7486,7857,"I never asked for you to pay anything, especially my bills."],[7870,8084,"And don't pretend that you writing crap"],[8084,8191,"makes you a big deal."],[8204,8287,"It doesn't!"],[8416,8483,"Get out."],[8612,8700,"Oh, come on."],[8729,8842,"Out! Now!"]],"2":[[179,379,"Jason proposed to me yesterday"],[379,621,"with this absolutely stunning ring."],[696,798,"Isn't it huge?"],[798,1059,"Harry Winston, six carat."],[1121,1359,"Oh my god, look at that diamond."],[1426,1480,"Oh!"],[1630,1726,"Hi, Nichole."],[1789,2122,"You know, that Harry Winston six carat diamond"],[2122,2193,"you're wearing,"],[2252,2423,"that was paid for with my writer's fee."],[2527,2648,"Nonsense."],[2648,2815,"Jason bought this for me."],[2882,3119,"Oh, just got dumped by your fiancé?"],[3119,3345,"If I were in your shoes,"],[3345,3520,"I think I would be crying myself"],[3520,3645,"to death in bed right now."],[3728,3928,"Yeah, well, I had to leave my room"],[3928,4132,"because I'm meeting my new boyfriend here."],[4141,4367,"Oh my god, Nichole."],[4367,4512,"Hooking up with some random?"],[4567,4725,"How pathetic."],[4725,4996,"Well, he did very well in the tech industry, so...."],[5042,5259,"Oh, so that's how he has the money"],[5259,5347,"to sleep with you, then?"],[5451,5643,"Okay, you know what? Cut the crap, Chelsey."],[5643,5893,"We all know that you were the one that cheated here."],[5922,6171,"Oh, we actually don't know anything about that."],[6171,6283,"If you have some sort of"],[6283,6427,"Elon Musk type of boyfriend,"],[6464,6634,"then prove it."],[6634,6669,"Yeah."],[6802,6869,"Prove it."],[6898,7061,"Aren't you here to meet him anyway?"],[7123,7248,"Otherwise, you'll just be proving"],[7248,7461,"you're nothing more than a lying,"],[7461,7661,"desperate bitch."],[8408,8470,"He's coming."],[9113,9175,"Help me!"],[9388,9571,"From this moment on,"],[9571,9743,"my world changed"],[9807,9901,"forever."]],"3":[[1468,1509,"Yeah."],[1509,1680,"This is my fiancé."],[1680,1776,"We're engaged."],[1868,2114,"Do you even know what you're talking about?"],[2164,2281,"Fabian Winston."],[2319,2432,"Their family could afford,"],[2432,2602,"like three countries—like Korea."],[2702,2827,"You're marrying him?"],[2827,2919,"You know what?"],[2941,3082,"Picking up random people"],[3082,3249,"to prove that you're loved"],[3249,3370,"just makes you look pathetic."],[3428,3607,"A total clown."],[3636,3757,"Yeah, Chelsey?"],[3845,3983,"Go on, don't look back."],[4029,4225,"You're just showing how jealous you are."],[4293,4390,"At least I don't have to"],[4390,4600,"invent fairy tales to prop up"],[4600,4788,"my pathetic self-esteem."],[4808,4900,"Nichole,"],[4979,5096,"you look ridiculous."],[5163,5251,"Miserable even."],[5334,5380,"Don't"],[5476,5580,"touch my fiancée."]],"4":[[2302,2427,"Good morning."],[2498,2652,"Or should I say good afternoon?"],[3249,3353,"How long did I sleep?"],[3411,3574,"Long enough that you could have"],[3574,3682,"caught the sunset by now."],[3770,3895,"What exactly happened last night?"],[4183,4425,"Well, what do you remember?"],[4554,4667,"Well, for your information,"],[4667,4875,"I tend to forget everything when I drink."],[4875,5149,"I do remember humiliating Chelsey"],[5149,5301,"quite thoroughly."],[5392,5507,"Cuzz like I said, I forget everything"],[5507,5588,"when I drink."],[5588,5930,"Like, even, like a little bit of alcohol."],[5968,6129,"I.... I just..."],[6368,6648,"Anyway, I will see you around."],[6735,6881,"You're leaving your fiancé?"],[6923,6986,"What?"],[7057,7244,"You are my fiancée now."],[7298,7336,"What?"]],"5":[[20,104,"What?"],[200,329,"My son's engaged?"],[329,409,"This can't be true."],[409,525,"It's probably just rumors."],[550,663,"Let me see that."],[1059,1184,"You announced"],[1184,1443,"our engagement last night to the public."],[1534,1697,"The video went viral."],[1726,1797,"Number one."],[1797,1893,"Who is this girl?"],[1893,2024,"Well, I checked her out."],[2024,2177,"She's from a small town in Ohio."],[2206,2360,"And she graduated from Columbia"],[2360,2460,"with a journalism degree."],[2460,2635,"She's been a freelance writer since."],[2677,2752,"Interesting."],[2802,2890,"Oh my God."],[2890,3032,"Notify the press."],[3090,3232,"I'm having a press conference."],[3282,3378,"A press conference?"],[3436,3503,"What for?"],[3536,3703,"This comes at a perfect time."],[3841,3978,"And it's time to remind"],[3978,4162,"Fabian that he is a Winston."],[4600,4725,"Good afternoon."],[4725,4846,"Thank you all for coming."],[4888,5144,"I am pleased to announce the engagement of"],[5144,5480,"my son Fabian Winston to Nichole Anderson."],[5488,5647,"They will marry at the end of the month,"],[5647,5889,"and Fabian will be returning"],[5922,6106,"to lead the Winston family business."],[6206,6295,"Welcome back to the"],[6295,6439,"Winston family business, son."]],"6":[[33,119,"Welcome back to the"],[119,283,"Winston family business, son."],[775,984,"I told you to stay out of my life."],[992,1105,"Yeah, well,"],[1105,1276,"you've had your time to indulge"],[1276,1443,"in your little fantasies."],[1480,1564,"Now it's time to take"],[1564,1735,"responsibility for this family."],[1797,1972,"Now, this is not up for discussion."],[2348,2619,"And since you got yourself engaged"],[2665,2798,"without informing me,"],[2857,3153,"as your father, I must make a gesture,"],[3153,3436,"so I will arrange a proper wedding for you."],[5442,5593,"I need you to"],[5643,5730,"marry me."]],"7":[[70,229,"What? What? Why would you want to do that?"],[266,387,"Let me make this simple."],[387,804,"My dad saw that video, and now he's announced"],[804,980,"that our wedding will be at the end of this month."],[1034,1130,"What? Wedding?"],[1213,1301,"Let's make a deal."],[1359,1451,"While we're married,"],[1451,1603,"you can write as much about me"],[1603,1675,"as you want."],[1714,1885,"I'll only accept interviews from you."],[1935,2127,"The public will eat it up."],[2143,2339,"Plus, you can get back at all the haters."],[2339,2488,"Look, marriage is not"],[2488,2644,"some casual arrangement, okay?"],[2644,2727,"It is serious."],[2727,2932,"It means something."],[2973,3186,"I'll have my attorneys draft a contract."],[3215,3300,"In three years,"],[3300,3457,"the marriage will end automatically,"],[3541,3682,"and you'll get a settlement."],[3682,3753,"I...."],[3870,4008,"Think about it, Nichole."],[4083,4166,"20 minutes."],[4258,4421,"Come downstairs when you've decided."],[5192,5347,"Jason deserves a real woman."],[5397,5663,"Oh, just got dumped by your fiancé?"],[5720,5768,"Marry me."],[6702,6744,"Okay."],[6744,6819,"I accept your offer."]],"8":[[58,175,"Okay, I accept your offer."],[271,342,"But I have a few strict"],[342,533,"non-negotiables in the contract."],[583,692,"Okay. What are they?"],[692,813,"Number one,"],[838,955,"no meddling in my life."],[980,1046,"Noted."],[1046,1155,"Number two,"],[1155,1242,"I can have an interview"],[1242,1322,"with you anytime."],[1380,1476,"Like I said."],[1539,1626,"And number three,"],[1626,1747,"no touching at all."],[1914,2147,"Nichole, if we're 30ft apart,"],[2147,2277,"no one's gonna believe this marriage."],[2348,2381,"Okay."],[2381,2527,"Well, what's your plan?"],[2548,2615,"I might need to"],[2615,2783,"have some physical interaction"],[2783,2894,"with you in public."],[2919,2961,"Okay."],[2961,3082,"Public is fine."],[3190,3311,"What kind of physical"],[3407,3528,"interaction, exactly?"],[3595,3712,"Well."],[3753,3832,"I might"],[3949,4037,"do this."],[4316,4341,"Yeah."],[4341,4496,"Yeah, that's fine."],[4579,4863,"And I might do this."],[5380,5555,"So, Nichole, are you"],[5634,5730,"ready to fake marry me?"]],"9":[[75,375,"Yeah, Fabian Winston. I will marry you."],[1338,1476,"- What are you doing here? - What are you doing here?"],[1488,1572,"Wait."],[1572,1714,"Do you guys know each other?"],[1714,1818,"- She's my cousin. - He's my cousin."],[1818,1881,"Yeah."],[1893,2056,"Aren't you in Africa?"],[2056,2118,"What?"],[2210,2281,"Hi."],[2385,2552,"What?"],[3132,3219,"Fabian Winston,"],[3257,3478,"do you take Nichole Anderson"],[3524,3737,"to be your lawful wedded wife?"],[3820,3903,"I do."],[3916,4283,"And you, Nichole Jean Anderson,"],[4358,4592,"do you take Fabian Sean Winston"],[4629,4833,"to be your lawful wedded husband?"],[4950,4971,"I–"],[4971,5088,"I object."]],"10":[[8,150,"I object."],[316,396,"Tell me,"],[421,558,"you two screwing around"],[558,700,"behind my back?"],[742,838,"Get the fuck out of here"],[838,975,"before I lose my patience."],[996,1172,"I am her fiancé."],[1209,1301,"We're engaged."],[1338,1376,"Yeah."],[1427,1551,"We were"],[1551,1685,"before you betrayed me"],[1685,1835,"and cheated on me with my bridesmaid."],[1981,2068,"And now I'm going to marry"],[2068,2210,"the only love of my life."],[2335,2469,"And you weren't invited."],[2477,2590,"So leave."],[2798,2940,"Your heard her."],[3140,3319,"You're going to regret this, Nichole."],[3403,3503,"This isn't over."],[3899,3983,"Hey, are you alright?"],[4004,4033,"Yeah."],[4033,4170,"Let's just uhhh...."],[4170,4320,"Let's just get the ceremony going, okay?"],[4450,4512,"It's kind of important"],[4512,4654,"to you and our marriage."],[4679,4917,"I'm asking you, are you okay?"],[5088,5146,"Yeah."],[5263,5380,"Fabian, yeah. I am."],[5559,5689,"Let's just do this, okay?"],[5689,5826,"There's kind of..."],[5930,6068,"just kind of a lot of people here."],[6452,6594,"You should move in with me."],[6673,6744,"What?"],[6802,6869,"No, no, no."],[6869,7069,"You promised you wouldn't meddle in my life."],[7165,7282,"I need to make sure you're safe."],[7419,7515,"It's non-negotiable."]],"11":[[558,775,"Take a nap. You know where the room is."],[884,963,"Wait. Where are you going?"],[963,1017,"I can...."],[1109,1272,"Also, I can just sleep on the couch."],[1347,1505,"To my studio."],[1689,1847,"Oh, by the way,"],[1951,2102,"nothing happened that night."],[2102,2281,"Oh, okay."],[2364,2594,"And if it did,"],[2706,2811,"you'd remember."],[2865,2948,"I promise."],[3132,3244,"Hey, you want to see my studio?"],[3486,3603,"It's really beautiful."],[3645,3707,"Thank you."],[3837,4020,"Do you want to try?"],[4054,4099,"Me?"],[4166,4291,"No, no, no."],[4333,4429,"I'll ruin it."],[4479,4558,"Oh, come on."],[4700,4783,"Sit."],[4867,4971,"I'll guide you."],[5121,5230,"Here we go."],[5451,5563,"Alright, hold it."],[5643,5780,"Relax your hand."],[5947,6110,"Relax a little bit more."],[6598,6664,"It's beautiful."],[7574,7665,"Very nice."]],"12":[[125,229,"You're a pro."],[642,679,"Okay."],[709,838,"Since we have stepped"],[838,1071,"into this fake marriage that you have proposed,"],[1113,1438,"it is time for your interview, Mr. Winston."],[1476,1550,"Okay."],[1550,1789,"Miss journalist, but"],[1968,2118,"only if the post includes you."],[2152,2198,"Me?"],[2227,2285,"Sure."],[2335,2473,"I mean, you are my wife."],[2510,2600,"Okay, well,"],[2600,2798,"who would want to read about me?"],[2802,2934,"I mean, the Chalk Press will read it"],[2934,2986,"and it'll be–"],[3082,3195,"coffee stain material"],[3195,3340,"before you can say rejection letter."],[3712,3966,"Do you remember the first time we met?"],[4045,4195,"Yeah, of course. We met at that bar."],[4262,4346,"Yeah."],[4412,4512,"Good memory."],[4587,4792,"By the way, I bought the Chalk Press."],[4792,4946,"So, write what you want."]],"13":[[79,229,"He bought Chalk Press?"],[232,283,"Mhm."],[283,365,"You know he's never done that"],[365,546,"for any girl like ever, right?"],[546,750,"Yeah, and I posted my first article about him,"],[779,984,"and it's like blowing up right now."],[1030,1184,"Yeah. Congrats girl!"],[1201,1359,"Oh, you're getting exactly what you want"],[1359,1493,"out of this marriage."],[1618,1801,"Just don't fall for him,"],[1860,1960,"Okay?"],[1960,2093,"No, just trust me."],[2214,2344,"You're only gonna end up getting hurt."],[2510,2694,"What is with that face?"],[2694,2748,"Don't–"],[2794,2986,"Don't tell me you've already fallen for him."],[2990,3119,"No, just...."],[3240,3374,"he makes me feel safe."],[3732,3895,"So I heard it was a nice ceremony,"],[4004,4133,"but there was some drama."],[4237,4458,"So, are you ready to dive into the business now?"],[4583,4717,"I said I'd come back,"],[4813,4896,"and I will,"],[5005,5134,"at my own pace."],[5434,5563,"I'm waiting."],[5784,5872,"Fabian?"],[6235,6343,"Lucy, I love you."],[6343,6564,"You are the best part of my day."],[6690,6819,"What's this?"],[6973,7102,"Happy graduation."],[7107,7173,"Lucy."],[7357,7469,"I'm moving to France"],[7469,7599,"to pursue art."],[7691,7791,"Will you come with me?"],[7845,7928,"Fabian?"],[7928,8162,"Stop being so childish."],[8241,8429,"We were just a college fling."],[8541,8671,"Now that it's over,"],[8779,8908,"so are we."],[9025,9154,"Happy graduation to you."],[9259,9346,"What?"],[9405,9488,"I'm done"],[9488,9676,"with your stupid artist's dreams."],[9788,9939,"I won't waste my best time on it."],[10944,11127,"If I'd known you were a Winson,"],[11144,11273,"things could have been different."]],"14":[[567,704,"Nothing will change."],[2535,2610,"Hey. What's wrong?"],[2652,2752,"Are you thinking of me?"],[2831,2894,"Well."],[2940,3069,"Not really."],[3069,3274,"Oh, that's stings a little."],[3311,3390,"Hey, look, I just...."],[3390,3649,"I really wanted to thank you for the article."],[3649,3791,"Everyone's like really buying it."],[3841,3928,"No more thank you."],[3928,4074,"Being my wife is more than that."],[4116,4333,"I'm opening the gallery tonight."],[4354,4571,"Perfect opportunity for a certain journalist"],[4571,4679,"to get an exclusive."],[4725,4867,"Well, count me there."],[4875,4946,"My pleasure."],[5593,5751,"Nicole, don't be stupid."]],"15":[[613,784,"He's been working on this piece for years."],[792,913,"They say it's his favorite."],[934,1063,"And it's priceless."],[1076,1197,"He refuses to sell it."],[1197,1426,"But I wonder who is the woman in the painting is."],[2193,2285,"Thank you,"],[2318,2464,"everyone for being here."],[2548,2815,"Tonight, I unveil a piece"],[2815,3082,"that holds profound meaning to me."],[3136,3303,"This painting isn't just art."],[3407,3528,"It's a reflection"],[3641,3820,"of someone who has inspired me,"],[3903,4020,"challenged me,"],[4024,4266,"and reminded me what it"],[4375,4491,"means to truly feel."]],"16":[[325,429,"Do you like it?"],[500,646,"When did you paint this?"],[688,921,"I started the day I met you."],[1084,1188,"Now you finally get to see it."],[1388,1574,"So you've been hiding in corners"],[1574,1714,"and sketching all this time?"],[1822,1981,"This is my last exhibition."],[2039,2106,"What? Wait."],[2106,2214,"You're giving up painting?"],[2356,2544,"I am a Winston, after all."],[2598,2852,"No, you've got real talent, Fabian."],[2882,2994,"You're meant to be an artist."],[2994,3098,"Don't give it up."],[3349,3557,"You really do believe in me, don't you?"],[4275,4362,"Excuse me."],[5255,5409,"What an ugly face, huh?"]],"17":[[12,183,"What an ugly face, huh?"],[316,404,"Excuse me."],[458,558,"I'm Lucy Bishop."],[613,742,"Should I know you?"],[742,875,"So, he didn't mention me."],[967,1051,"Figured."],[1105,1197,"I'm his ex."],[1230,1263,"Ahhh."],[1351,1455,"Fabian's ex."],[1547,1705,"I'm Nichole Anderson, his wife,"],[1747,1814,"legally."],[1897,2060,"That's only to make me jealous."],[2156,2273,"He never got over me."],[2318,2502,"And that's why he married me."],[2565,2723,"Save your breath,"],[2740,3040,"you little pathetic ugly mouse."],[3194,3353,"You're just my replacement."],[3453,3611,"He'll come back to me"],[3670,3832,"sooner or later."],[3832,3995,"Oh, right."],[4033,4195,"And how are you planning that, exactly?"]],"18":[[216,329,"Where'd you go?"],[412,533,"Didn't answer my calls."],[575,763,"I met your first love, Lucy."],[913,1063,"She introduced herself to me."],[1138,1260,"Quite the romantic history"],[1260,1368,"you two have."],[1468,1576,"Yeah, that's a story"],[1576,1701,"from a long time ago."],[1730,1847,"She's gorgeous."],[1964,2152,"Body that most guys would dream of."],[2210,2323,"Surprised she's your type."],[2744,2894,"You're worried about her, aren't you?"],[3036,3140,"Of course not."],[3345,3445,"Why would I be?"],[3495,3670,"No, I'm not worried. Why do...."],[3670,3816,"What do I have to be worried about?"],[3816,3845,"What?"],[3845,3995,"No, I don't care at all."],[4120,4208,"Not at all?"],[4229,4358,"No, of course not."],[4416,4496,"Okay?"],[4554,4629,"Look,"],[4704,4867,"we are just a contract marriage."],[4867,4959,"Who or what"],[4959,5134,"or whatever you like, it does not...."],[5171,5301,"It means nothing to me."],[5643,5793,"I like it when you're jealous."],[5901,6106,"And， for the record."]],"19":[[2181,2264,"Here it is."],[2344,2519,"These just came for you."],[2627,2769,"Are they from Fabian?"],[2781,2919,"Probably."],[3148,3215,"I got you."]],"20":[[942,1018,"Jason?"],[1018,1222,"What the hell is that creep up to?"],[1651,1726,"Lexi,"],[1789,1922,"I need to tell you something."],[2027,2089,"What is it?"],[2185,2243,"Okay."],[2402,2599,"I kind of crossed the line with Fabian last night,"],[2599,2769,"and I know what you're going to say, okay?"],[2773,3144,"I just get really completely lost in his case."],[3165,3452,"Nichole, I warned you so many times"],[3452,3587,"not to fall for Fabian."],[3587,3795,"I mean, he's a player."],[3812,3933,"He changes girls"],[3933,4047,"more than he changes outfits."],[4047,4210,"I mean, like, it's Fabian."],[4210,4325,"Just think about it, Nichole. He's...."],[4546,4700,"What are you ladies talking about?"],[4750,4825,"Yeah,"],[4888,5030,"I'll give you two some privacy."],[5872,5993,"Okay, we have to stop this."]],"21":[[0,95,"We have to stop this."],[221,287,"What happened?"],[287,357,"No sex."],[357,550,"That is the first rule of this agreement."],[550,633,"Okay, well, it's the third."],[633,746,"But look, if...."],[859,1001,"if either of us crossed the line again,"],[1001,1138,"we'll file for divorce."],[1180,1372,"But it's not just sex."],[1372,1559,"I mean, we have chemistry."],[1559,1739,"Look, I lost control last night, and I'm sorry."],[1739,1835,"It won't happen again."],[1960,2252,"So, that's all this is to you?"],[2252,2385,"Just sex?"],[2573,2919,"Fabian, you are a Winston, we're not gonna make it."],[3073,3186,"Greg wants to see you."],[3286,3336,"Me?"],[3378,3415,"No."],[3528,3603,"You, Ms. Winston."]],"22":[[125,308,"Welcome, welcome."],[308,358,"Come on in."],[358,517,"Welcome to the family, Nichole."],[542,738,"Mr. Winston, it's so great to meet you."],[738,834,"You too."],[834,963,"I'm sorry I missed the ceremony."],[963,1067,"I heard it was lovely."],[1071,1188,"But I have to tell you,"],[1209,1514,"I'm so inpressed with your articles."],[1534,1651,"They're insightful."],[1651,1780,"They're profound."],[1797,1931,"It's my favorite read these days."],[1964,2110,"Thank you. Seriously."],[2168,2310,"Fabian's been so supportive."],[2364,2402,"Oh...."],[2473,2590,"Cut to the chase."],[2623,2736,"Why do you want to see us?"],[2773,2869,"I wanted to say hello"],[2869,2998,"to my new daughter-in-law."],[3090,3240,"And to introduce you to someone."],[3324,3374,"Who?"],[3407,3499,"My fiancée."],[3582,3636,"What?"],[3687,3753,"Fiancée...."],[3845,3924,"Hi everyone."],[3924,4024,"Hi, darling."]],"23":[[41,112,"Fuck. Okay."],[112,241,"Are you out of your mind?"],[421,550,"Mr. Winston, are you all right?"],[583,759,"I'm fine, I'm fine, I'm fine."],[759,813,"Thank you."],[913,1042,"We met at a golf"],[1067,1197,"club recently."],[1284,1472,"Well, I just feel like the luckiest man."],[1543,1676,"I'm the luckiest one"],[1739,1826,"to have met you."]],"24":[[12,95,"Seriously?"],[154,300,"You need to be this much of an asshole?"],[371,500,"Since when did you...."],[921,1038,"Since when did you think"],[1038,1180,"that you could judge my life?"],[1830,1964,"Are you sick?"],[1972,2102,"Like you actually care."],[2214,2302,"How bad is it?"],[2302,2431,"It's cancer."],[2544,2652,"The doctors say I have"],[2652,2781,"maybe a year left."],[2898,3028,"Why didn't you tell me?"],[3040,3086,"Just...."],[3199,3411,"I need you to take over the company."],[3445,3586,"Effective immediately."],[3616,3745,"The fucking company?"],[3762,4008,"No. We need to get you the best treatment, alright?"],[4008,4325,"I need you to keep this company intact."],[4391,4562,"I plan to enjoy"],[4604,4750,"what time I have left."],[4846,4975,"Now I am marrying Lucy."],[5196,5326,"Save your breath."],[5326,5459,"I've already tried everything."],[5522,5764,"It's time for me to enjoy the rest of my life."],[5968,6060,"I told you,"],[6172,6318,"if I knew you're a Winston,"],[6456,6564,"things could have been different."]],"25":[[37,183,"If I knew you're a Winston,"],[321,450,"things could have been different."],[467,596,"Of all the men in the world,"],[617,754,"you chose my dying father?"],[792,934,"He was the one who begged me"],[934,1021,"to marry him."],[1105,1213,"You wouldn't want to ruin us,"],[1213,1455,"or our happiness, would you?"],[1480,1609,"I'm warning you."],[1626,1797,"Stay away from him."],[2035,2164,"Are you jealous?"],[2281,2410,"If you want me back,"],[2498,2627,"I'll drop him right now."],[2786,2948,"You have no shame, Lucy."],[3007,3224,"I can't believe I ever loved you."],[3244,3374,"But I know what you're after."],[3470,3599,"I'm taking over Winston Corp."],[3599,3728,"You're not gonna get a damn thing."],[3895,4158,"You're even sexier when you're angry."]],"26":[[133,408,"You're even sexier when you're angry."],[1689,1822,"Oh, sorry."],[1822,2060,"You know how it is when people are in love."],[2060,2149,"I mean, we just can't keep"],[2149,2256,"our hands off each other."],[2877,3169,"So, we're in love now."],[3169,3324,"Well, I was just helping you out,"],[3324,3516,"so you are welcome."],[3874,4012,"I haven't"],[4112,4258,"thanked you yet."]],"27":[[454,667,"You should dress like this more often."],[704,746,"You know what?"],[746,925,"You should dress like this less often."],[925,1076,"It's so tight!"],[1076,1342,"Why do rich people always wear things like"],[1342,1454,"throat-hugging thin string?"],[2615,2723,"A toast,"],[2873,2973,"to Nichole."],[3207,3370,"My future daughter-in-law."],[3649,3720,"Oops."],[3795,3858,"Sorry."]],"28":[[162,229,"Oops."],[304,375,"Sorry."],[475,600,"How clumsy of me!"],[692,884,"Looks like your dress is ruined!"],[946,1209,"You should probably go to the bathroom, Nichole."],[1267,1330,"I'll be back."],[2694,2777,"Listen carefully,"],[2827,3023,"stay away from Fabian Winston."],[3449,3520,"Hey. Hey. Hey."],[3541,3616,"You okay?"],[3646,3707,"Hey. Hey."],[3770,3841,"Nichole?"],[3841,3908,"Oh! Hey, hey!"],[3966,4016,"Nichole!?"]],"29":[[266,371,"She's fine."],[446,567,"Just in shock."],[596,725,"Thank you, doctor."],[779,871,"Thanks, doc."],[992,1092,"See? It's gonna be all right."],[1284,1368,"Hey, Nichole!"],[1463,1518,"Are you alright?"],[1580,1689,"Jason. I'm fine."],[1768,1864,"What are you doing here?"],[1864,2014,"I was just here for an interview."],[2039,2185,"Oh, yeah? What a coincidence."],[2260,2365,"What the hell's that supposed to mean?"],[2365,2523,"You know exactly what I mean."],[2677,2755,"Look, Nichole,"],[2755,2840,"I heard about what happened."],[2840,2961,"Did you get a good look at the guy?"],[3036,3257,"No. He had a mask on."],[3361,3516,"Yeah, he was your height."],[3599,3678,"Your body build."],[3720,3883,"I dare you say that again."],[3970,4062,"Stop! Stop it!"],[4087,4162,"Okay, just get out."],[4225,4262,"Look,"],[4316,4546,"Nichole, I'm gonna find this guy for you, okay?"],[4546,4808,"But just please, take care of yourself."],[4967,5150,"Now if you don't leave, I'm gonna make you."],[5150,5367,"Remember, this happened on your watch, buddy."]],"30":[[1121,1217,"Could it be Jason?"],[1217,1380,"I mean he showed up at the perfect time,"],[1380,1518,"like he has planned."],[1518,1605,"No, it's not Jason."],[1605,1747,"How can you be so sure?"],[1793,1926,"He crashed our wedding."],[1956,2039,"And he hurts you."],[2235,2348,"I don't trust him."],[2348,2385,"Look,"],[2473,2736,"I know what his voice sounds like and his body, I..."],[2777,2831,"Wait."],[2848,2998,"You heard the man's voice."],[3111,3240,"No, no, no, no, nothing."],[3240,3307,"Nothing like that."],[3407,3578,"What are you hiding, Nichole?"],[3695,3807,"I think I'm just..."],[3807,3920,"I'm really tired."],[3920,4120,"Can we just, like, go to sleep?"],[4254,4462,"You still in love with Jason?"],[4637,4771,"Fabian Winston,"],[4796,4938,"that's your conclusion?"],[4984,5150,"After everything we've been through together."],[5150,5380,"You think that I'm still in love with Jason?"],[5522,5630,"I'm..."],[5822,5897,"Jealous."],[6206,6352,"I'm not just jealous, I'm..."],[6448,6535,"I'm scared."],[6706,6852,"Scare Jason's right that"],[6898,7012,"I won't be able to protect you."],[8091,8141,"You know what?"],[8141,8600,"This makes me feel better and safe."]],"31":[[600,759,"What are we doing out here?"],[909,1051,"What?"],[1272,1388,"I have to show you something."],[1785,1839,"Oh my godness."],[1839,1931,"Where did you get it?"],[1931,2035,"It's a gift,"],[2122,2248,"from my grandmother"],[2248,2389,"to her granddaughter-in-law."],[3382,3516,"That's precious."],[3591,3712,"Just like you."],[4016,4104,"Listen, I'm..."],[4162,4337,"sorry for yelling yesterday."],[4829,5034,"This necklace is yours,"],[5096,5271,"until the day you stop loving me."],[5363,5522,"Apology accepted."],[6097,6231,"Did you do this?"],[6402,6498,"Only for you."]],"32":[[66,258,"He gave you his grandmother's necklace?"],[258,437,"You know, that's a big deal, right?"],[437,567,"Mhm."],[567,604,"Yeah."],[679,938,"I don't know, last night, I just kind of felt like..."],[1130,1347,"Like I was at Disneyland."],[1347,1589,"Oh, he made you feel like a princess?"],[1718,1906,"And he had fireworks for me."],[1906,1981,"I can't–"],[2318,2373,"Wait."],[2373,2414,"What?"],[2414,2489,"Nichole?"],[3219,3349,"Has it been two minutes?"],[3382,3457,"Almost."],[3591,3641,"Let me check."],[3883,3999,"Nichole, Nichole!"],[3999,4112,"What, what! What is it?"],[4320,4433,"Oh my God!"],[4550,4650,"Oh my God!"],[4683,4808,"Nichole, you're going to be a mother!"],[4888,5059,"Fabian is gonna be so excited."],[5313,5547,"Do you really think he's gonna be excited?"],[5601,5701,"Absolutely."],[5843,6064,"Whole family is going to love this baby."],[6177,6231,"Yeah."],[6368,6481,"Oh my God."]],"33":[[458,571,"Why are you here?"],[821,967,"Why can't I be here?"],[1126,1259,"What are you doing here?"],[1334,1393,"You know,"],[1497,1701,"after all these years,"],[1718,1828,"he's still as good as"],[1828,2060,"when we first together."],[2114,2171,"Oh!"],[2171,2377,"What the hell are you doing here, Lucy?"],[2410,2477,"Honey!"],[2519,2677,"That's not what you just said."],[2911,2998,"Get out of my house."],[3028,3111,"Alright."],[3194,3303,"Don't be so harsh."],[3465,3586,"I'll see you next time."]],"34":[[33,158,"I'll see you next time."],[596,658,"Nichole,"],[738,880,"I swear I didn't know she was here."],[917,1013,"You have to believe me."],[1013,1121,"And how did she get in?"],[1201,1368,"She's crazy."],[1368,1509,"I don't know. Maybe..."],[1622,1860,"Maybe she stole the keys from Greg."],[1860,1964,"You know what? Save it, Fabian."],[1964,2102,"You were just a piece of work."],[2660,2731,"Nichole!"],[3428,3716,"This necklace is yours,"],[3716,3882,"until the day you stop loving me."]],"35":[[1076,1247,"How can such a talented artist"],[1247,1572,"create such a gorgeous masterpiece?"],[1693,1872,"But when it comes to comforting a woman,"],[1872,2072,"he has completely lost."],[2414,2510,"He..."],[2619,2752,"He loves her"],[2815,2923,"very much."],[3420,3561,"I was really angry."],[3753,3924,"Lucy is crazy."],[3924,4054,"Yeah, she is."],[4262,4408,"I need her to leave my dad."],[4704,4838,"What are you thinking about?"],[5684,5764,"You."]],"36":[[12,158,"What are you thinking about?"],[1005,1084,"You."],[1338,1413,"I want"],[1534,1593,"you."],[1751,1897,"And what's stopping you?"],[2210,2310,"What do you want?"],[2510,2560,"You."],[2852,2952,"I want you."],[3912,4133,"Someone has been leaking sensitive info."],[4133,4272,"Our shipments are being delayed"],[4272,4396,"on purpose."],[4637,4758,"Do we have any leads?"],[5100,5213,"Check the pattern."],[5213,5488,"The attackers are targeting our key partners."],[5547,5726,"It's happening at an alarming rate."],[5726,5918,"So Nichole's attack is related."],[6356,6502,"So I've been thinking about baby names."],[6502,6606,"I know it's really early,"],[6606,6752,"but if it's a girl,"],[6752,6941,"I'm kind of thinking Riley."],[6941,7098,"That'd be cute!"],[7098,7198,"I know! Isn't it?"],[7215,7369,"So, did you tell Fabian?"],[7561,7649,"Why?"],[7841,8024,"We were in the fight about something,"],[8024,8074,"and,"],[8141,8466,"I'm just waiting till the right moment, you know?"],[8508,8558,"Yeah."],[8558,8645,"And I don't want it to be"],[8645,8834,"overshadowed by drama."],[8858,8967,"Okay, I get that."],[9184,9371,"Just tell him soon, okay?"],[9421,9505,"I will!"],[9505,9588,"He should know."],[9738,9889,"I will!"],[10548,10681,"I knew you'd come to see me."]],"37":[[554,717,"I knew you'd come to see me."],[717,838,"Whatever game you're playing."],[909,996,"It stops here."],[996,1088,"Play?"],[1188,1292,"What do you mean?"],[1393,1551,"I know you approach with"],[1551,1693,"my father is all about money,"],[1789,2052,"but you shouldn't drag Nichole through this."],[2352,2635,"You can't just leave me for this nobody."],[2706,2765,"Get out!"]],"38":[[804,912,"Oh, looks like you're back"],[912,1013,"just in time."],[1071,1192,"Do you care to explain this?"],[1343,1463,"That's not what it looks like."],[1630,1793,"Then why are you with her all alone?"],[1947,2031,"Look at this."],[2281,2402,"Are they working together?"],[2569,2686,"It's all staged."],[2736,2923,"Someone's trying to make it look like that because"],[3069,3219,"the truth is someone's hell-bent"],[3219,3311,"to underming my life."],[3436,3520,"I really need to"],[3520,3628,"tell you something."],[3732,3866,"The night I was attacked,"],[3866,4020,"he told me something. I lied."],[4108,4175,"Okay."],[4175,4295,"What did he say?"],[4425,4592,"He told me to stay away from you."],[4704,4733,"But...."],[4792,5000,"I didn't tell you because I was...."],[5167,5255,"I just thought you would"],[5255,5376,"leave me to protect me."]],"39":[[187,283,"Nichole."],[400,529,"I will never leave you."],[579,759,"And I will always protect you. I promise."],[1943,2018,"Fabian."],[2268,2410,"I need to tell you something."],[2494,2666,"But you have to promise not to freak out"],[2666,2798,"because I'm kind of freaking out."],[2848,3007,"I mean, as long as I'm with you,"],[3007,3144,"there's nothing to freak out about."],[3199,3286,"Okay. Don't joke."],[3286,3386,"I'm serious."],[3386,3432,"Alright."],[3486,3570,"What is it, babe?"],[3883,3958,"Fabian, I...."],[4300,4487,"Mr. Winston, you're under arrest."],[4500,4583,"Hey. What's happening?"],[4596,4691,"I'm taking Winston in"],[4691,4829,"for the murder of Lucy Bishop."],[4854,4909,"Wait."],[5017,5130,"Lucy is dead?"],[5167,5226,"Yeah."],[5413,5530,"I didn't do it."],[5530,5626,"Let's go."],[5701,5789,"Nichole...."],[5860,5897,"Wait."]],"40":[[408,546,"I mean, they won't even let me see him."],[546,663,"It's ridiculous."],[663,813,"We need to get Fabian out on bail."],[813,996,"The police have gathered enough evidence"],[996,1151,"to prove that Fabian had a motive"],[1205,1317,"to murder Lucy."],[1317,1564,"But we know that isn't true, right?"],[1764,1901,"Wait, you guys don't think that"],[1901,2102,"Fabian killed Lucy, do you?"],[2214,2323,"She was hurting you"],[2323,2556,"and he wanted her to break up with Greg."],[2706,2827,"I don't know, but it"],[2907,3096,"seems like pretty good motive"],[3096,3228,"to off someone to me."]],"41":[[112,300,"I don't know, but it"],[300,488,"seems like pretty good motive"],[488,629,"to off someone to me."],[1184,1238,"Hello?"],[1509,1572,"Okay. Thank you."],[1572,1672,"Thank you so much. Bye."],[1718,1897,"They just let Fabian out on bail, and I have to go."],[1897,1976,"I'll drive you."],[1976,2043,"And I'm coming with you."],[2043,2147,"No. Stay!"],[2460,2627,"You should probably stay."],[2694,2844,"It's okay. We'll be right back. Okay?"],[2890,2965,"Okay."]],"42":[[379,442,"Hey."],[533,613,"Hi."],[821,925,"Where is Nichole?"],[925,1061,"She and Sam went to the station"],[1061,1159,"to go meet you."],[1201,1292,"You didn't see them?"],[1292,1363,"No."],[2127,2268,"How did you get out?"],[2268,2498,"I gave my lawyer access to my phone."],[2498,2656,"The GPS shows I was at home"],[2765,2873,"when Lucy was killed."],[3048,3115,"You know,"],[3224,3336,"she's not answering."],[3490,3624,"Something's wrong."]],"43":[[112,250,"That's... Something's wrong."],[500,583,"She's in danger."],[583,754,"You don't know what it could be..."],[800,863,"Okay, Fabian,"],[863,1064,"there's something important"],[1064,1155,"that I need to tell you."],[1313,1418,"Nichole is pregnant."]],"44":[[41,183,"Nichole is pregnant."],[746,975,"Oh. Oh!"],[1647,1760,"Why are you doing this?"],[2014,2235,"You realize this is all your fault."],[2323,2527,"If you hadn't found the evidence"],[2527,2665,"and bailed Fabian out,"],[2723,2969,"the family business would be in my hands."],[2969,3136,"Fabian believed in you."],[3294,3465,"You betrayed him?"],[3641,3908,"You destroyed everything that he ever stood for."],[3933,4037,"Oh Fabian?"],[4116,4216,"The golden boy?"],[4283,4454,"The boy that could do no wrong."],[4562,4654,"But me?"],[4738,5096,"I am actually the adopted son of this family."],[5134,5376,"I can do nothing,"],[5409,5555,"if he still exists."],[5613,5897,"I'll just be a mere shadow in the Winston family."]],"45":[[33,442,"I can do nothing if he still exist."],[508,838,"I'll just be a mere shadow in the Winston family."],[909,1113,"You're blinded by jealousy."],[1297,1572,"Madness is going to destroy you."],[1935,2156,"Now it's time to break"],[2206,2339,"my dear brother's heart."],[2702,2811,"Listen carefully."],[2894,3007,"I have Nichole,"],[3086,3386,"if you want her back alive,"],[3520,3716,"then I need you to bring me the signed"],[3716,3858,"equity transfer agreement"],[3908,4095,"to the dock warehouse."],[4225,4354,"Oh, and Fabian."],[4391,4637,"Don't forget about that child she's carrying."],[4721,4779,"Wait, how do you–"],[4871,4971,"How do you know about that?"],[5034,5163,"Fabian, don't believe him."],[5163,5259,"Shut up! Bitch!"],[5313,5513,"I found your pregnancy test."],[5547,5747,"Maybe you should hide it better next time."],[5789,5868,"Leave her alone!"],[5868,5989,"I'll do whatever you want!"],[5989,6160,"Oh! Stop nagging."],[6218,6458,"Just bring the equity agreement"],[6458,6589,"to the dock warehouse."],[6627,6677,"Now."]],"46":[[1547,1647,"What are you doing here?"],[1647,1826,"I told you not to come unannounced."],[1839,1960,"We agreed:"],[1960,2277,"Frame Fabian, you get the money, I get Nichole."],[2277,2402,"But now you've kidnaped her."],[2402,2556,"And you're planning on hurting her."],[2556,2660,"That's not gonna fly with me."],[2677,2827,"Don't you dare ruin this for me."],[2840,3073,"You are the one who broke the deal."],[3094,3265,"Nobody hurts Nicole!"],[3837,3916,"No!"],[4062,4175,"Oh my God. Nichole!"],[4175,4229,"You're okay?"],[4270,4358,"It's alright. I got you, alright?"],[4491,4567,"Jason, behind you!"],[4575,4604,"What?"],[4888,4925,"Jason?"],[5000,5050,"Jason!"]],"47":[[8,87,"Jason, behind you!"],[91,120,"What?"],[404,471,"Jason?"],[513,579,"Jason!"],[633,763,"You killed Jason!"],[905,1084,"Fabian's bringing me the contract."],[1180,1347,"Looks like I have no use for you anymore."],[1347,1572,"You can say goodbye to you,"],[1572,1668,"and that baby."]],"48":[[12,179,"Looks like I have no use for you anymore."],[179,508,"You can say goodbye to you and that baby."],[992,1117,"You were like a brother to me"],[1117,1197,"and you betrayed me!"],[1205,1326,"I won't let you hurt her."],[1326,1405,"I hate you!"],[1405,1499,"You took everything"],[1499,1622,"that were supposed to be me!"],[2252,2323,"Nichole!"],[2414,2606,"Nichole, you're safe now!"],[2652,2719,"I'm here."],[2848,2894,"No!"]],"49":[[95,187,"No!"],[225,291,"Fabian!"],[321,621,"No. No. No."],[742,871,"Come out with your hands up!"],[1042,1201,"No!"],[1906,2002,"Fabian..."],[2093,2206,"Wake up."],[2377,2552,"The baby and I need you..."],[2669,2765,"I love you."],[2777,2923,"Please don't leave me."],[4191,4262,"Hey..."],[4454,4629,"Ugh, don't cry, silly"],[4859,4992,"I'm not going anywhere."]],"50":[[166,316,"Greg's cancer is in remission."],[329,475,"Wow, that's great!"],[1480,1780,"I have owned you a proper proposal"],[1805,1910,"for so long."],[2314,2423,"Nicole Anderson."],[2502,2615,"Will you marry me?"],[3032,3161,"On one condition."],[3319,3386,"What is it?"],[3470,3615,"You promise to stand by me"],[3615,3774,"until death do us part."],[4004,4179,"Not even death can divide us."],[4225,4429,"And Nicole, I will always love you!"],[4554,4708,"Yes, I do."],[6606,6777,"You make me the happiest man."]]}