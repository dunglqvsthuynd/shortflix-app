"Are you Jasmine Hart?"],[1393,1522,"Did you know that your mother's stalker"],[1522,1651,"was working on the same set?"],[1676,1714,"Come on."],[1714,1772,"Can we get a picture?"],[1772,1835,"Hey, please. - Come on, come on."],[1835,1889,"Come on. - come on."],[1889,1976,"Give us a minute."],[2356,2527,"You know, you really have your co-star"],[2527,2585,"to thank."],[2615,2723,"She's the one who tipped us off"],[2723,2857,"and that's what led us here."],[2894,2986,"Now, I am going to need you"],[2986,3094,"to come down to the station"],[3094,3219,"to give the full statement."],[3274,3315,"Are you sure"],[3315,3461,"you don't need any medical attention?"],[3532,3682,"I just want to go home, Dom."],[3682,3737,"Please."],[3832,3895,"Okay."],[4033,4187,"I'll make sure she gets to the station."],[4187,4329,"Do you mind if I just get her out of here,"],[4329,4454,"away from these vultures?"],[6322,6398,"I've got you."],[6489,6585,"You're safe with me."],[6690,6798,"You don't understand."],[6844,6927,"Everything. It's..."],[7165,7240,"It's over."]],"59":[[717,792,"Some reporters"],[792,955,"were lingering around outside."],[1009,1101,"I sent them packing."],[1188,1376,"Everyone knows who I am now."],[1447,1572,"I can't hide anymore."],[1572,1685,"Not from the world."],[1801,1914,"Not from my dad."],[2352,2423,"I was never a fan"],[2423,2560,"of keeping secrets."],[2573,2773,"That guy drove my mom crazy."],[2773,2869,"He stalked her"],[2869,3019,"and spread rumors about her"],[3019,3182,"that even my dad believed in."],[3274,3407,"I know she would never"],[3407,3553,"hurt me on purpose, Dom."],[3553,3620,"Never."],[5964,6114,"I was so scared."],[6202,6377,"I never thought I'd see you again."],[6460,6577,"Never get to tell you."]],"60":[[3586,3766,"The new star of the upcoming project"],[3766,3941,"from Hollywood's hottest director,"],[3941,4062,"Phoenix Rising,"],[4087,4220,"is now confirmed to be"],[4220,4371,"the daughter of beloved actress"],[4371,4471,"Ingrid Hart."],[5100,5159,"Yes."],[5259,5376,"I'm watching it now."]],"61":[[633,704,"Board of directors"],[704,829,"are holding a special meeting."],[905,988,"They're going to be voting"],[988,1067,"for the morality clause-"],[1067,1130,"They can't."],[1130,1205,"They can."],[1267,1330,"They will."],[1468,1543,"They should."],[1622,1755,"Dom, don't say that."],[1793,1889,"You saved me."],[1893,2056,"But your father doesn't seem to care."],[2114,2160,"If anything,"],[2160,2302,"he's more convinced now than ever"],[2302,2423,"that you shouldn't be an actress."],[2423,2569,"Well, I don't care what he thinks."],[2569,2673,"Well, you should care."],[2736,2798,"He's threatening"],[2798,2932,"to cancel this whole deal."],[2994,3107,"I shouldn't have touched you again"],[3107,3240,"once I found out who you were."],[3349,3490,"It's not just on you."],[3641,3803,"I chose this too."]],"62":[[137,241,"Well, this was a mistake."],[354,450,"Not for me."],[450,679,"Jayne, your father will lose everything"],[713,880,"that he's ever worked for in his life,"],[900,1030,"because I can't control myself."],[1030,1209,"That's his choice, Dom."],[1247,1343,"All he has to do"],[1343,1451,"is vote against the clause"],[1451,1639,"and he gets whatever he wants."],[1672,1822,"He wants you to stop acting."],[1885,2089,"Well, he doesn't get to decide"],[2089,2293,"what I do with my life or who I love."],[3161,3249,"Did you hear me?"],[3249,3353,"Yes, I heard you."],[3532,3745,"You told me once that if I wanted to fly,"],[3745,3895,"all I had to do was say so."],[4020,4108,"Are you saying so?"]],"63":[[83,179,"If you want me to leave,"],[179,304,"then you'll have to tell me to go."],[367,496,"Tell me to stay."],[579,796,"And I'll take the damn VP job"],[796,892,"and convince him"],[892,1084,"to go against the morality clause."],[1084,1151,"I'm not going to let you"],[1151,1280,"ruin yourself over this, Jayne."],[1280,1530,"Without you, I am ruined."],[2035,2131,"You don't have to be."],[2177,2273,"But I am."],[2273,2356,"I am."],[2356,2477,"Enough, okay?"],[2544,2627,"I won't allow it."],[2656,2769,"You asked me to teach you."],[2769,2873,"I taught you everything."],[3007,3094,"That's all this..."],[3482,3603,"That's all this was."],[3845,4099,"That's really all this ever was to you?"]],"64":[[37,212,"I can't let her give up her dreams."],[266,483,"I would never be able to forgive myself."],[896,996,"Goldfish, Jayne."],[2135,2256,"If that's what you want."],[2848,2927,"Marcus?"],[2957,3094,"I wanna make a deal with you."],[3803,3899,"If you support Jayne"],[3899,4004,"with all of her dreams,"],[4066,4149,"I'll make sure you get"],[4149,4262,"what you want in the deal."],[4371,4479,"I'll go back to London."],[4504,4596,"I'll never see her again."]],"65":[[129,316,"So damn glad you're okay, Jayne."],[383,450,"That's all that"],[450,575,"ever really mattered to me."],[650,825,"You can call me Jasmine now, Dad."],[855,896,"There's no need"],[896,1042,"to keep it a secret anymore."],[1305,1501,"I'm sorry this happened to you."],[1555,1626,"All of it."],[1647,1710,"I'm not."],[1910,2014,"But I thought that-"],[2014,2156,"We know the truth now."],[2206,2394,"That Doug was stalking Mom."],[2444,2544,"Threatening her."],[2640,2752,"He was unhinged."],[2752,2927,"She was just trying to protect us."],[2998,3132,"No matter what happened,"],[3194,3399,"I'm happy you can stop hating her now."],[3461,3753,"And I never hated your mother, Jayne."],[3874,3941,"I loved her."],[4529,4592,"Thank you."],[4646,4763,"Was it really worth it?"],[4900,5088,"Loving her through all the heartbreak?"],[5167,5292,"Of course it was."],[5313,5413,"Love is always worth"],[5476,5597,"the heartbreaks, Jayne."],[5747,5860,"You know, listen, listen."],[6056,6197,"I have something I want to tell you."]],"66":[[62,187,"I'm going to stop pestering you"],[187,316,"about joining the company."],[396,492,"You're a grown woman."],[492,600,"If you want to be an actress,"],[600,667,"be an actress."],[667,804,"I'm just, I'm going to stop trying"],[804,913,"to talk you out of it."],[934,1092,"Dad, are you sure?"],[1092,1234,"You, you're for real about it?"],[1267,1330,"Really."],[1426,1701,"I've just been in the way of you"],[1701,1822,"following your dreams."],[1843,1993,"And your dreams are important, Jayne."],[2089,2164,"More than that,"],[2164,2310,"your dreams need to come true."],[2323,2402,"You don't know"],[2402,2535,"how much that means to me."],[2598,2802,"But are you sure about it?"],[2823,2932,"I know how important"],[2932,3044,"this company is to you."],[3044,3257,"And I know that you hate the feeling that"],[3257,3365,"I'm not going to be"],[3365,3482,"taking over the company."],[3536,3653,"I guess I'll just have to let"],[3653,3874,"the warm Caribbean breeze of air"],[3874,4008,"dry my tears while"],[4054,4183,"I'm sitting on the beach at the house"],[4183,4316,"I just bought with the bonus"],[4316,4450,"that Ansel negotiated"],[4450,4529,"at the last meeting."],[4696,4829,"I do have to tell you something."],[4954,5030,"About Dom."],[5184,5234,"Ansel."],[5234,5301,"Oh, you don't have to"],[5301,5451,"worry about him anymore, honey."],[5451,5626,"He's halfway to London by now."],[5797,5839,"Wait."],[5885,6018,"He's not coming back?"],[6114,6164,"No."],[6181,6322,"He's, he's not, Jayne."],[6364,6569,"He's, he's gone for good."],[6706,6794,"I have to go."]],"67":[[37,91,"Dom!"],[196,279,"Answer the door!"],[279,362,"I'm here."],[492,638,"Please don't be gone."],[1238,1343,"I hate you."],[1384,1547,"I really hate you."],[2419,2573,"And I could never hate you."],[6986,7148,"No matter what happens,"],[7336,7457,"I'll never take it off."]],"68":[[2419,2477,"Jayne."],[2627,2769,"I just wanted to say"],[2769,2965,"that I'm sorry for everything."],[2994,3144,"I never meant to put you in danger."],[3219,3328,"I was just jealous."],[3474,3536,"Thanks."],[3653,3762,"You were right about Theo."],[3803,3991,"Turns out if he cheats with you,"],[3991,4074,"he'll cheat on you."],[4124,4250,"I got what I deserved."],[4275,4408,"Even you don't deserve"],[4408,4491,"a guy like him."],[4625,4704,"What about you?"],[4746,4909,"That guy that put stars in your eyes?"],[4909,5105,"I never saw you look at Theo like that."],[5138,5209,"What happened?"],[5326,5388,"Nothing."],[5643,5722,"Do you want to go grab a drink?"],[5805,5868,"I'm okay."],[6252,6297,"Dom."],[6331,6418,"That's what happened."],[6498,6548,"Him."]],"69":[[1284,1380,"God, I'm an idiot."],[1564,1714,"But I'd do it all over for her."],[2314,2389,"Are you nervous?"],[2598,2648,"Yes."],[2836,2932,"You got this."],[2973,3123,"Your first movie premiere."],[3219,3324,"I'm so proud of you."],[3453,3507,"That's something"],[3507,3670,"I never thought I'd hear you say."],[3753,3978,"You know, I've been holding on to this"],[3978,4175,"for a long time."],[4175,4383,"Now it's time to give it to you."],[4567,4721,"That's Mom's."],[4742,4838,"Yes, I gave it to her"],[4838,4975,"at her first movie premiere."],[5013,5230,"And now, it's yours."]],"70":[[25,104,"Beautiful, isn't it?"],[104,154,"Yeah."],[216,375,"I think it's going to look great."],[1943,2114,"Okay, let's see how that looks."],[2435,2506,"Perfect."],[2610,2827,"You know, if Ansel hadn't negotiated"],[2827,2923,"that great deal for me"],[2923,3011,"at the last meeting,"],[3061,3119,"I'd have to"],[3119,3274,"sell this necklace to pay bills."],[3324,3445,"What are you talking about?"],[3532,3682,"He agreed to all the terms"],[3682,3816,"of the morality clause."],[3862,4033,"In exchange for me keeping everything"],[4033,4120,"I was meant to get."],[4295,4425,"All he asked was"],[4487,4662,"I keep supporting your dreams"],[4704,4909,"and stop asking you to quit acting."]],"71":[[0,158,"He was still protecting me."],[191,287,"Even at the end."],[346,442,"They're waiting for you."],[558,638,"You ready, kiddo?"],[717,800,"Movie star?"],[1001,1130,"Your mom would be so proud."],[1226,1297,"I hope so."],[1380,1447,"Let's go."],[2035,2156,"Dad, you can go."],[2519,2577,"Babe!"],[2602,2794,"Oh my god, you look amazing."],[2840,2961,"Are you ready to knock them dead?"],[2961,3023,"Because, honey,"],[3023,3132,"these people are not going to know"],[3132,3174,"what hit them."],[3174,3219,"Oh, yeah."],[3737,3807,"I need a minute."],[4129,4229,"Please come back."],[4270,4371,"I want you to be here."],[5568,5768,"Whoever that is, kindly fuck off."]],"72":[[162,237,"So?"],[321,437,"Have you heard from"],[517,575,"him?"],[738,825,"Not a word."],[892,942,"But"],[1005,1159,"that's just how I prefer it to stay."],[1226,1426,"I don't need to waste my time on someone"],[1426,1593,"who's not willing to put in the effort."],[1726,1893,"Amen to that."],[2206,2248,"Oh."],[2306,2377,"That's me."],[2398,2448,"Bye!"],[3490,3649,"I came as soon as I got your text."],[3795,3899,"I would have been here sooner,"],[3899,4049,"but I was trying to book a flight."],[4270,4433,"I'm afraid that I don't know"],[4433,4533,"how to fly solo."],[5067,5163,"I'll teach you,"],[5284,5397,"if you want to learn."]],"73":[[709,863,"I thought I could leave you behind."],[996,1113,"That I could make it all right."],[1146,1251,"I hated you"],[1322,1401,"for leaving me."],[1576,1797,"But my dad told me what you did for me."],[1847,1981,"I couldn't live with myself"],[1981,2102,"if he lost his retirement."],[2323,2431,"And I was a fool to think"],[2431,2540,"I could live without you."],[2665,2836,"This might be asking too much."],[2936,3023,"Can you forgive me?"],[3178,3303,"Of course I can."],[3395,3490,"I'm yours."],[3490,3670,"I've always been yours."],[3703,3953,"You own me, if you want me."],[4112,4229,"Don't you know, Jayne?"],[4362,4471,"I belong to you."],[4763,4821,"Kiss me."],[5601,5672,"I love you."],[5730,5864,"Jasmine Jayne Hart."],[6001,6139,"I love you, too,"],[6185,6385,"Ansel Dominick Dugray."]]}