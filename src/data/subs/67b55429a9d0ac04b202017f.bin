e,"],[5622,5805,"and the women are"],[5805,5930,"shooting me daggers."],[6081,6151,"Jealousy."],[6243,6377,"You look stunning tonight, Fay."],[6456,6552,"Um, well,"],[6585,6756,"that's thanks to your father."],[7440,7636,"Introductions are in order."],[7807,7887,"Please."],[7957,8112,"After how disloyal you've been?"],[8220,8354,"If you give a shit about me,"],[8379,8533,"you would have found me years ago."]],"18":[[0,154,"If you give a shit about me,"],[154,312,"you would have found me years ago."],[342,458,"It's not her fault."],[492,567,"She didn't know."],[663,750,"Matter of fact, she's..."],[804,980,"she's still adjusting to all of this."],[1088,1188,"Everybody knew."],[1242,1380,"You expect me to believe"],[1409,1514,"that you really thought"],[1514,1659,"that, that schlub,"],[1659,1818,"David Thompson-"],[1818,1918,"Don't speak of-"],[1964,2039,"Um..."],[2122,2198,"Um, don't,"],[2198,2377,"don't speak about him that way."],[2377,2477,"He's a great man."],[2510,2727,"How dare you defend that jamoke,"],[2740,2940,"who stole my only child from me."],[3036,3090,"Shameful."],[3123,3274,"That's enough, old man."],[3365,3470,"How dare you talk about"],[3470,3657,"your long-lost daughter that way,"],[3678,3812,"and my son's fiancée."],[4045,4112,"Let's get out of here."],[4175,4229,"Let's go."],[5263,5330,"You’re mine."],[5526,5593,"So..."],[5676,5789,"we're really doing this?"],[5814,5914,"Look at the bright side."],[5935,6072,"Your family's protected."],[6218,6402,"You're helping me realize my birthright."],[6431,6544,"There was a time"],[6544,6785,"when I thought we'd be together forever."],[6981,7061,"Prove to me that"],[7061,7152,"there's still something"],[7152,7236,"between us."],[7378,7436,"Kiss me."],[7887,7945,"Oh!"],[8070,8158,"Oh yeah, right."],[8158,8237,"It's okay."],[9200,9334,"What the hell is going on here?"],[9509,9647,"What's your problem?"]],"19":[[250,396,"What the hell is going on here?"],[479,604,"What's your problem?"],[646,779,"You told me to marry him."],[779,875,"You wanted this."],[892,971,"What I want"],[1021,1126,"is for Daniel"],[1172,1276,"to go to his room."],[1338,1459,"Look, you two aren't married yet."],[1459,1509,"Why don't you"],[1509,1672,"show some respect for yourselves?"],[1672,1830,"Are you serious?"],[1830,2010,"She's my fiancée."],[2010,2181,"Don't make me say it again, Daniel."],[2181,2243,"Go."],[2952,3073,"Kent's jealous."],[3073,3178,"It's obvious."],[4108,4241,"Sorry about my dad."],[4275,4371,"He's being weird."],[4412,4517,"Hopeful that kiss proved"],[4517,4625,"we still have a spark."],[4625,4688,"Night."],[4750,4863,"All it proved is that"],[4863,5050,"I feel nothing for you anymore."],[5163,5230,"Fay?"],[5251,5359,"It's Fiona."],[5376,5430,"Come."],[5463,5572,"Let's have a drink."],[5609,5730,"Get to know each other."],[5764,5889,"A chance to learn more"],[5889,6035,"about Kent's lover?"],[6035,6206,"I can't pass that up."],[6393,6502,"Seriously."],[6527,6673,"Kent's a sweetheart."],[7011,7248,"What- I'm sorry if I don't believe you."],[7290,7449,"Kent's an asshole."],[7449,7607,"I mean, him and Daniel"],[7607,7703,"are nothing alike."],[7703,7795,"It's strange."],[8012,8291,"If this rock is any indication..."],[8333,8504,"they're more alike than you think."],[8591,8829,"So, how are things with you"],[8829,8967,"and your new fiancé?"],[9280,9367,"What is it?"],[9547,9672,"Don't be shy."],[9672,9768,"You can trust me."],[9984,10122,"I like Daniel."],[10301,10402,"I'm just not sure"],[10402,10727,"if we're meant to be together."],[10756,11002,"Is the physical connection lacking?"],[11023,11140,"Is he no good in bed?"],[11311,11482,"We haven't, um..."],[11870,11961,"I mean, I..."],[12049,12153,"I've never..."],[12253,12303,"Fay,"],[12349,12541,"you're not a virgin, are you?"],[12875,13117,"Oh my god, wow!"],[13521,13792,"Don't worry, I have just the thing."]],"20":[[367,592,"If you want your marriage to work,"],[663,821,"you have to keep your man happy"],[821,930,"in the bedroom."],[1126,1284,"What is this place?"],[1297,1384,"Let's call it,"],[1384,1480,"Kent's lair."],[2907,3119,"Oh, um, I don't think that I need to-"],[3119,3211,"Come on, Fay,"],[3211,3370,"you're in the big leagues now."],[3420,3482,"You don't wanna go into"],[3482,3545,"this arrangement"],[3545,3670,"with your eyes closed."],[3691,3753,"Porn?"],[3787,3903,"Let's call it..."],[3903,4020,"inspiration,"],[4045,4158,"for you and Daniel."],[4525,4713,"Watch and learn."],[7520,7682,"Just a frightened little girl."],[10026,10105,"I want you."],[10185,10272,"I need you."],[10560,10685,"Do you see anything you like?"],[10685,10748,"No!"]],"21":[[283,417,"Do you see anything you like?"],[417,475,"No!"],[508,617,"Um, Fiona,"],[617,763,"Fiona brought me in here to..."],[1142,1226,"Don't be shy."],[1376,1459,"You can watch it."],[1893,2031,"Your shirt is telling on you again."],[2790,2923,"I was a little rough with her."],[3069,3182,"Does that scare you?"],[3695,3791,"No."],[4391,4454,"I told you."],[4579,4717,"This can never happen again."],[4854,4921,"Get out."],[4963,5038,"Don't come back."],[6619,6681,"Where's my phone?"],[7453,7645,"Tell me what Ivan's planning!"],[9530,9580,"Hey!"],[9655,9780,"I thought I told you"],[9780,9939,"not to come back down here."],[10468,10577,"You can't stay away."],[10623,10806,"You like the danger."],[11111,11198,"Admit it, Fay."],[11340,11423,"The danger"],[11503,11653,"makes you wanna fuck."]],"22":[[125,300,"Dad, let go of her!"],[333,462,"She's your fiancée."],[483,638,"She's your responsibility."],[650,825,"If you don't keep an eye on her,"],[930,1001,"I will."],[1059,1155,"Now both of you,"],[1155,1292,"get the fuck out of here!"],[1651,1755,"He's a monster!"],[1755,1801,"I..."],[1801,2022,"my psych eval at the prison proved that."],[2022,2135,"He kidnapped me,"],[2135,2310,"he's manipulating me to marry you."],[2310,2489,"I'm sorry you had to see that, Fay."],[2489,2615,"Sorry about everything."],[2615,2773,"Then why don't you do something?"],[2811,2869,"You know?"],[2869,2961,"Get me out of here."],[2961,3061,"Help me escape."],[3061,3315,"I already told you, there isn't escape."],[3386,3486,"Don't even try."],[3557,3687,"If you think what he did to that bad..."],[3687,3753,"Daniel!"],[3799,3983,"He was torturing that man"],[3983,4262,"and, and you don't seem shaken at all."],[4262,4366,"I'm used to it."],[4562,4658,"Oh my God,"],[4658,4829,"you are no better than him."],[4867,5100,"I can't believe I ever liked you."],[6481,6627,"It's obvious that Fay needs something"],[6627,6844,"to keep her busy and out of my hair."]],"23":[[45,196,"It's obvious that Fay needs something"],[196,408,"to keep her busy and out of my hair."],[408,462,"Dad."],[462,617,"Daniel, shut up."],[667,925,"I can't trust you to keep her occupied."],[980,1046,"So maybe we should"],[1046,1255,"put that bullshit psychology to use."],[1313,1480,"It isn't bullshit."],[1522,1597,"You know what?"],[1605,1764,"You need therapy, Kent."],[1780,1868,"You're not well."],[1918,2022,"I can help you."],[2068,2239,"You couldn't handle me, Fay."],[2264,2431,"But my bodyguard Jerome..."],[2431,2594,"maybe you can do him a solid,"],[2594,2765,"and confirm his loyalty."],[2794,3007,"I don't work for you."],[3023,3207,"You are a part of this family."],[3224,3478,"And in this family, what I say goes."],[3778,3870,"And one more thing."],[4074,4325,"Don Alden extended an olive branch,"],[4366,4542,"and he's asking us"],[4542,4679,"to come over for dinner tonight."],[4717,4767,"Maybe you can make"],[4767,4875,"a better first impression."],[5009,5105,"Enjoy your cannoli."]],"24":[[538,646,"I'd like to toast"],[675,842,"my beautiful daughter, Fay..."],[842,1063,"and Daniel, my future son-in-law."],[1163,1259,"To family."],[1259,1347,"Salute."],[1355,1413,"Salute."],[1843,1910,"Fay,"],[1981,2027,"I uh,"],[2085,2243,"I'd like to apologize again"],[2243,2352,"for the way I treated you"],[2352,2423,"the other night."],[2423,2519,"It was out of line."],[2519,2610,"It's fine."],[2610,2756,"I accept your apology."],[2790,2873,"I'd like to..."],[2873,3023,"I'd like to get to know you, Fay."],[3065,3169,"If you would let me."],[3261,3328,"If you would..."],[3415,3524,"if you would allow me to."],[3645,3707,"Sure."],[3832,3908,"I mean, yes."],[3928,4045,"Yes, I would like that."],[4145,4220,"So, Daniel,"],[4283,4366,"what do you, uh..."],[4371,4550,"what do you plan on doing after you,"],[4612,4721,"you marry my daughter?"],[4954,5100,"Plan to take over"],[5100,5288,"more family responsibilities."],[5288,5359,"Is that right?"]],"25":[[91,171,"I plan to um..."],[171,225,"take over"],[225,404,"more family responsibilities."],[429,504,"Is that right?"],[700,821,"I'll hold you to that."],[896,946,"And,"],[1001,1209,"make Fay happy, of course."],[2202,2356,"He hasn't said two words"],[2356,2464,"to me all night."],[2464,2581,"I should be relieved,"],[2660,2706,"but..."],[2852,2936,"Excuse me."],[3090,3148,"Oh."],[3148,3261,"Excuse me, I've got a call."],[4158,4396,"I was thinking about what you said earlier."],[4408,4483,"You're right."],[4504,4633,"I'm no better than my father."],[4675,4850,"Daniel, I'm sorry."],[4909,5096,"What I said earlier was cruel."],[5109,5334,"You are nothing like your father."],[5355,5459,"And in many ways,"],[5463,5609,"you're just as much a prisoner"],[5609,5722,"in this life as me."],[5955,6297,"My father and Fiona seem close."],[6485,6614,"You know it's rude to whisper"],[6614,6690,"in mixed company."],[6719,6815,"Is there something you want to share?"],[6848,6906,"No."],[6906,7052,"Just chatting about school."],[7232,7357,"You know, Daniel..."],[7378,7511,"I hope you're serious about"],[7511,7607,"wanting to take on"],[7607,7720,"more family business."],[7736,7912,"As it stands now, I can't even get you"],[7912,8074,"to manage our family's accounts."],[8112,8199,"Hey asshole!"]],"26":[[279,346,"Dad!"],[346,437,"Protect Fay!"],[1197,1288,"Sorry, boss."],[1292,1388,"He got the jump on me."],[1388,1488,"Just take him out of here."],[1488,1580,"You know what to do."],[1839,1885,"Fay!"],[2031,2127,"You've been shot."],[2135,2181,"I..."],[2273,2352,"It's okay, it’s okay."],[2352,2456,"It's just a flesh wound."],[2456,2519,"I'm fine."],[2519,2610,"Just breathe."],[2706,2798,"Kent,"],[2798,2936,"I'll get my people to find out"],[2936,3023,"who was behind this."],[3023,3148,"I know who did this."],[3207,3311,"No, no, no, no."],[3311,3499,"Not Ivan Kozlov."],[3499,3636,"No, he would never make a move"],[3636,3782,"on a made man like you."],[3782,3866,"Once again,"],[3866,4041,"I'm leaving your house pissed off."],[4041,4191,"Set up the meeting with Ivan,"],[4191,4391,"or I'll really start to question your loyalty."]],"27":[[4,208,"Or I'll really start to question your loyalty."],[208,258,"Done."],[980,1172,"It's nice to officially meet you, Jerome."],[1172,1317,"Kent said that you"],[1317,1476,"needed someone to talk to."],[1476,1605,"He told me to be here,"],[1605,1776,"so I'm here."],[1830,1939,"You should know,"],[1939,2081,"anything that you tell me"],[2081,2227,"during these sessions"],[2227,2402,"will remain between us."],[2477,2598,"Are you really a therapist?"],[2598,2656,"Yes."],[2673,2765,"I'm in grad school,"],[2831,2969,"but I'm taking a break."],[3032,3236,"Until after my sham wedding."],[3319,3566,"Um, why don't you tell me"],[3591,3820,"how you first began working for Kent?"],[3891,4183,"My parents died when I was a kid."],[4183,4329,"I ended up on the street,"],[4329,4592,"and Kent took a chance on me."],[4592,4754,"Kent recruited you as a child?"],[4754,5000,"No, he saved me."],[5030,5184,"Kent's a good man."],[5184,5342,"He's helped a lot of other people, too."],[5355,5618,"The Mafia King helps people?"],[6018,6126,"I need to take care of this."]],"28":[[4,162,"Kent likely intended it"],[162,333,"as some kind of punishment,"],[333,650,"but speaking with Jerome felt good."],[650,846,"I felt like my old self again."],[1267,1384,"How's the arm?"],[1384,1472,"It's fine."],[1522,1605,"Never better."],[1605,1755,"How was your session?"],[1818,1918,"Learn anything good?"],[1947,2106,"My professional vows forbid me"],[2106,2227,"to answer that question."],[2318,2410,"Come on, Doc."],[2623,2690,"Give me something."],[2731,2798,"We both know"],[2798,2923,"you like bending the rules."],[2944,3153,"Not when it comes to my clients."],[3153,3345,"I agreed to speak with Jerome"],[3345,3428,"to help him."],[3432,3553,"It's all I'm going to do."],[3774,3862,"Whatever you say."],[4642,4771,"You smell so good."]],"29":[[37,100,"What are you wearing?"],[100,208,"I want to buy you a bottle."],[316,433,"You can't buy it."],[504,629,"It's an oil."],[629,754,"Janeen makes it."],[754,825,"Ooh."],[880,1026,"Well, she's very talented."],[1046,1117,"Mm-hmm."],[1117,1205,"She is."],[1251,1388,"And she hates me now"],[1388,1463,"because of you."],[2047,2114,"What is it?"],[2114,2206,"Something on your mind?"],[2756,2873,"It might be nothing,"],[2986,3107,"but before you got shot,"],[3107,3340,"I noticed Alden and Fiona"],[3340,3549,"talking together pretty closely."],[3666,3757,"Thanks for telling me."],[4375,4604,"This world is so confusing to me."],[4604,4679,"In some ways,"],[4679,4804,"I understand the allure,"],[4804,4979,"but Kent could have been killed"],[4979,5063,"last night."],[5084,5301,"What a dangerous way to live."]],"30":[[37,296,"Get your fucking hands off me!"],[375,492,"Fay, get out of here."],[492,608,"This doesn't concern you."],[608,704,"What, you don't want her to see"],[704,896,"how heartless you really are?"],[896,992,"What's going on here?"],[992,1126,"This paranoid bastard"],[1126,1259,"doesn't trust anyone."],[1276,1418,"Won't let anyone get close!"],[1418,1622,"Enough of your lying and scheming!"],[1651,1801,"Get the fuck out of my house."],[1843,1931,"You should consider me"],[1931,2131,"sparing your life a parting gift."],[2477,2573,"Fuck this shit."],[2777,2857,"This must be about"],[2857,2973,"what I told him earlier."],[3557,3628,"What happened?"],[3661,3891,"Kent thinks I'm a spy for Don Alden."],[4108,4183,"Are you?"],[4229,4379,"Fay, I'm your cousin."],[4379,4546,"And Don Alden is my uncle."],[4546,4646,"It's complicated."],[4658,4779,"You're my cousin?"],[4779,4838,"Does Kent know?"],[4838,4963,"I don't have time to explain"],[4963,5071,"and I need to get out of town."],[5071,5159,"You're family."],[5159,5330,"I need you to do something for me."],[5417,5555,"I need you to give this to your father,"],[5555,5622,"to Don Alden."],[5680,5809,"I can't, because if I-"],[5809,5930,"I... Fay I wouldn't have asked"],[5930,6018,"if it wasn't important,"],[6018,6168,"and I have to get out of town."],[6306,6498,"Stay on Kent's good side."],[6498,6635,"Do whatever he says,"],[6635,6806,"whatever it takes to survive."],[6848,6936,"Make him think"],[6936,7102,"he always has the upper hand."],[7874,8003,"Should I give it to Kent?"],[8003,8149,"Don Alden is an ass,"],[8149,8299,"but he is my father."],[8299,8391,"And Kent hasn't"],[8391,8550,"proven himself trustworthy."],[8612,8712,"What do I do?"]],"31":[[208,271,"Come in."],[467,600,"Fay, your father is here to see you."],[842,934,"Do you want to see him?"],[1042,1201,"Do you want me to see him?"],[1372,1463,"Seriously, Kent,"],[1463,1609,"I don't know what to think."],[1609,1751,"Like, do you want me to see him?"],[1751,1910,"Do you not think it is a good idea?"],[1910,1985,"I don't know what to do"],[1985,2097,"after that attempt on your life"],[2097,2198,"at dinner, and..."],[2198,2306,"It's fine, Fay."],[2339,2431,"It's not a test."],[2431,2577,"You can talk to him if you want to."],[2577,2648,"It’s, it’s..."],[2648,2831,"He's your father, after all."],[3436,3507,"Daughter."],[3903,4074,"I'm so sorry about the other night."],[4091,4170,"I can promise you"],[4170,4350,"that whoever's responsible for this,"],[4350,4433,"they're gonna pay."],[4433,4579,"I'm just glad you're okay."],[4587,4808,"He actually seems genuine."],[4838,4988,"You look so much like your mother."],[5030,5138,"What happened..."],[5205,5313,"between you and my mother,"],[5313,5384,"I mean?"],[5397,5451,"Well, I was with"],[5451,5584,"my former wife at the time,"],[5584,5643,"and I couldn't be"],[5643,5755,"what Victoria needed."],[5776,5885,"So, uh,"],[6010,6097,"she left."],[6156,6406,"So, you never saw either of us again?"],[6423,6544,"Well, she disappeared."],[6544,6715,"After she died ten years later."],[6715,6769,"I, uh,"],[6890,6990,"I searched for you,"],[7002,7119,"but I came up empty."],[7198,7353,"But I am so glad"],[7374,7503,"that you're back in my life."],[7511,7695,"Should I give him Fiona's message?"],[7732,7866,"Would my mother want me to?"],[7953,8012,"You know, Fay,"],[8012,8208,"you can come back to my house with me."],[8312,8412,"You know that, right?"],[8554,8666,"I should probably stay here"],[8666,8783,"with my fiancé."],[8825,8992,"If I leave, there's no way"],[8992,9171,"Kent will keep protecting my family."],[9325,9496,"Do you love... Daniel?"],[9605,9684,"Of course."],[9855,9918,"Well, you don't sound"],[9918,10039,"too convincing, daughter."],[10055,10135,"You know, you're young"],[10135,10297,"and you got options."],[10297,10385,"I mean, maybe we could"],[10385,10510,"find somebody better."]],"32":[[4,100,"I don't understand."],[100,308,"I thought I am betrothed to Daniel"],[308,387,"since birth."],[387,542,"Yeah, but that was a long time ago,"],[542,596,"you know?"],[638,729,"Things change."],[925,1005,"No, thank you."],[1046,1155,"I'm, I’m happy."],[1180,1247,"Okay."],[1247,1301,"Well, just let me know"],[1301,1393,"if you change your mind."],[1488,1605,"I wanted to come by"],[1605,1705,"and, uh, make sure"],[1705,1872,"you were all squared away."],[1872,1968,"Now that I see that,"],[1968,2056,"I think I'm going to head out..."],[2252,2318,"Unless there's something"],[2318,2427,"that you want to give me."],[2473,2581,"Fiona's note."],[2581,2648,"No!"],[2706,2844,"Um, no."],[2844,2898,"I..."],[2898,3019,"I don't have anything for you."],[3073,3144,"Okay, dear."],[4287,4433,"Tell me everything Alden said."],[4533,4658,"Are my conversations"],[4658,4854,"with my own father not private?"],[4854,4900,"No."],[4900,5009,"Not when you're in my house"],[5009,5163,"talking to my potential enemies."],[5176,5388,"I thought you and Don Alden are allies."],[5388,5467,"I mean, isn't that"],[5467,5601,"what this is all about?"],[5634,5776,"Need I remind you"],[5776,5935,"that I was shot in the arm"],[5935,6076,"on his territory?"],[6076,6281,"Our alliance is shaky at best."],[6297,6377,"Tell me everything."],[6535,6664,"There's not much to tell."],[6706,6911,"He came to check on me."],[6911,7073,"And I told him I was fine."],[7102,7157,"And then he asked"],[7157,7298,"if I wanted to come live with him"],[7298,7453,"and if I loved Daniel."],[7494,7586,"What did you say?"],[7607,7682,"I told him that"],[7682,7899,"I wanted to stay here with Daniel"],[7978,8062,"who I love."],[8220,8287,"That's it."],[8571,8675,"This will prove"],[8675,8817,"whether I can trust you or not."]],"33":[[16,275,"You were recording our conversation?"],[296,379,"Of course."],[425,579,"Is there anything else you want to add..."],[696,859,"before I listen for myself?"],[996,1146,"The only other thing I can think of"],[1146,1430,"is he asked if I had anything"],[1430,1501,"to give to him."],[1522,1772,"And you conveniently left that part out?"],[1772,1910,"I'm sorry."],[1910,2081,"This is my first interrogation."],[2306,2410,"What did he mean by that?"],[2502,2598,"No idea."],[2711,2836,"I told him that I didn't"],[2836,2948,"have anything to give him."],[2990,3090,"And then he left."],[3178,3319,"Okay. You can go."],[3361,3457,"I'll call for you"],[3457,3699,"if I have any other concerns."],[3949,4054,"Well..."],[4054,4158,"I'm, I’m happy."],[4183,4241,"Okay."],[4312,4462,"Looks like I can trust her after all."],[4542,4633,"Unless there's something"],[4633,4738,"that you want to give me."],[4821,4950,"No. I..."],[4950,5109,"I don't have anything for you."],[5926,6018,"Jerome, go upstairs."],[6018,6131,"Search Fay's room."],[6197,6356,"I think we may have another rat."]],"34":[[0,91,"Jerome,"],[187,250,"go upstairs"],[250,362,"and search Fay's room."],[421,508,"We might have another rat"],[508,575,"on our hands."],[625,767,"I'm getting out of this house."],[784,975,"And you are going to help me."],[992,1092,"What did he do now?"],[1121,1272,"Hasn't he done enough?"],[1317,1405,"So are you going to help me"],[1405,1480,"get out or what?"],[1664,1893,"Yes, I'll do what I can to help."],[2081,2206,"I found your little secret."],[2273,2439,"A list of my holdings,"],[2439,2594,"my financial statements?"],[2594,2723,"Dad, don't do this."],[2773,2877,"Stay out of it."],[2977,3228,"If you can't keep her in line, I will."],[3336,3395,"Let's go."],[3507,3595,"Daniel!"],[3912,3999,"Let me go!"],[3999,4133,"I will as soon as you tell me"],[4133,4237,"what I need to hear."]],"35":[[129,212,"Let me go!"],[429,521,"Don't move."],[2027,2164,"Don't you touch me with that."],[2181,2331,"If you didn't want to be punished,"],[2523,2648,"you wouldn't have misbehaved."],[3420,3578,"Oh, what's the matter, Kent?"],[3595,3682,"You can't punish me"],[3682,3795,"with your mother's ring?"],[3795,3924,"I ask the questions."],[4387,4496,"Where did you get the note?"],[4700,4808,"I can't tell you."],[5976,6043,"Am I..."],[6139,6297,"enjoying this?"]],"36":[[70,141,"Am I..."],[241,396,"enjoying this?"],[563,746,"Let me tell you how this is gonna go."],[1263,1426,"I ask the questions."],[1514,1685,"And if I don't like the answers,"],[1747,1826,"you get the whip."],[2460,2635,"This is a trust exercise."],[4066,4191,"Do you want me to trust you?"],[5409,5497,"Let's get back to it."],[6569,6685,"Where did you get the note?"],[6931,7065,"Fiona gave it to me."],[7086,7157,"And what did she want you"],[7157,7244,"to do with it?"],[7557,7653,"Give it to Alden."],[7653,7824,"But obviously I didn't!"],[8016,8145,"That was for not telling me."],[8212,8379,"After all that I've done for you."],[8470,8608,"All that you've done for me?"],[8608,8904,"I am chained to a table in your garage."],[9380,9492,"If you keep something"],[9492,9592,"from me again,"],[9830,10039,"you'll see just how bad it can get."],[10481,10598,"I won't do it again."],[10827,11123,"I’ll be good for you, Kent."],[11261,11327,"Good girl."],[11782,11974,"You like to be punished, don't you?"],[12132,12287,"Yes, punish me."]],"37":[[417,583,"I can't lose control like that!"],[617,709,"Fay's gonna marry Daniel"],[709,800,"and have his child."],[800,900,"It's the way it has to be."],[1176,1280,"You crossed the line."],[1334,1505,"Taking Fay into the basement?"],[1534,1630,"She's mine."],[1668,1814,"Then go take her,"],[1856,1993,"if she's yours."],[2686,2823,"You like this a little, don't you?"],[2886,3090,"I’ll be good for you, Kent."],[3424,3490,"Good girl."],[3591,3666,"Fuck."],[4341,4433,"Hey, get here now."]],"38":[[216,283,"Kent?"],[283,362,"Is that you?"],[408,479,"No, it's me."],[521,596,"Did he hurt you?"],[700,779,"I'm fine,"],[779,842,"Daniel."],[875,1017,"You seem shockingly okay."],[1126,1188,"Usually when Dad"],[1188,1276,"brings someone down here,"],[1276,1434,"they don't leave with everything intact."],[1472,1618,"I'm better than okay."],[1718,1897,"I want more."],[2177,2314,"Daniel, he didn't hurt me."],[2394,2560,"He scared me, more than anything,"],[2560,2677,"but, um..."],[2677,2786,"I can kind of understand"],[2786,2865,"his anger."],[2982,3111,"I kept something from him"],[3111,3224,"that I shouldn't have."],[3311,3465,"Just know it'll never happen again."],[3499,3603,"You're my fiancée, Fay."],[3603,3699,"I'll protect you,"],[3699,3807,"even from my father."],[5730,5789,"Come here."]],"39":[[4875,4967,"Is the mob world"],[4967,5163,"always this complicated?"],[5163,5301,"Well at least I’m done"],[5301,5447,"hiding from stuff from Kent."],[5480,5613,"You're important to me, Fay."],[5630,5776,"And I only want the best for you."],[5801,5976,"Come to my place tomorrow evening"],[5976,6060,"to discuss."],[6131,6227,"Don't tell Kent."]],"40":[[567,629,"Daughter,"],[717,850,"I'm so glad you could make it."],[930,996,"Thank you."],[1042,1188,"Hopefully it wasn't too difficult"],[1188,1288,"for you to get out."],[1301,1438,"Kent can be a tyrant."],[1530,1805,"It was nearly impossible."],[1805,1881,"I had to wait"],[1881,2127,"until Jerome, Daniel, and Kent"],[2127,2323,"were out before I could even leave."],[2385,2494,"It was a piece of cake."],[2594,2761,"Um, so what did you want"],[2761,2898,"to discuss with me?"],[3161,3236,"Apologies."],[3282,3328,"There's something"],[3328,3440,"I need to take care of,"],[3440,3591,"and, and we'll talk in a few."],[3828,3995,"Daniel or Kent are gonna call"],[3995,4175,"looking for me any second now."],[4175,4295,"I shouldn't have come."],[4308,4450,"But he's my father."],[4450,4621,"I should at least try to build"],[4621,4758,"a relationship with him."]],"41":[[462,667,"Do you realize that every guy here"],[667,788,"is working up the nerve to talk to you?"],[988,1063,"Are they?"],[1130,1330,"Actually, I don't understand"],[1330,1555,"why there are so many guys here."],[1576,1701,"I mean, it's a meat market."],[1885,1976,"Don Alden invited"],[1976,2106,"every mover and shaker in town."],[2164,2264,"I mean, do you really think"],[2264,2344,"anyone's gonna miss their chance"],[2344,2531,"to woo the gorgeous daughter"],[2531,2610,"of Don Alden?"],[2702,2798,"Seriously?"],[2852,3069,"My father is bacheloretting me?"],[3069,3203,"I'm engaged."],[3353,3445,"Where's the, uh..."],[3611,3670,"ring?"],[3732,3803,"Kent took it"],[3803,4066,"while he was interrogating me."],[4542,4642,"Oh, um,"],[4804,4946,"must have left it at home."],[5063,5196,"That is convenient."],[5313,5447,"How do you expect us"],[5447,5689,"to honor your engagement"],[5689,5855,"if you don't have a friendly reminder?"],[6010,6068,"Us?"],[6197,6289,"So you're..."],[6356,6381,"one of"],[6381,6514,"my dad's candidates?"],[6606,6731,"Only if you want me to be."],[6906,6973,"Pleasure to meet you."],[6973,7127,"I’m Ivan."],[7215,7286,"Ivan Kozlov."],[7357,7424,"Ivan?"],[7540,7695,"Kent's sworn enemy?"]],"42":[[4,66,"Ivan?"],[187,354,"Kent's sworn enemy?"],[529,658,"I see that my name"],[696,817,"precedes my reputation."],[863,938,"I'm sorry."],[938,1151,"Um, it's just,"],[1151,1238,"I haven't heard"],[1238,1438,"many pleasant things about you."],[1472,1597,"Don't believe everything you hear."],[1893,2018,"I shouldn't be talking to you."],[2018,2227,"I am engaged to Daniel Lippert."],[2227,2348,"Oh, so the, uh,"],[2369,2477,"Lipperts are in your ear?"],[2531,2731,"You know, I think it would be best"],[2731,2882,"if you drew your own conclusions"],[2882,2944,"about me."],[3007,3128,"That depends."],[3282,3436,"Did you have anything to do"],[3436,3670,"with the attempt on Kent Lippert's life?"],[3891,4095,"There is a lot about this world"],[4095,4371,"that you haven't learned about."],[4529,4667,"I can teach you..."],[4667,4775,"if you want me to."],[4833,4896,"Fay!"],[4896,5042,"What the hell are you doing with him?"]],"43":[[0,58,"Hey!"],[58,204,"What the hell are you doing with him?"],[237,346,"Daniel,"],[346,458,"you're misunderstanding"],[458,504,"what's happening"],[504,558,"here. -No,"],[558,775,"I see exactly what's going on."],[817,959,"Fay, let's go."],[992,1051,"Now."],[1355,1468,"I don't like him, boss."],[1609,1676,"We're gonna kill him."],[1931,2031,"Fay, you're standing on"],[2031,2202,"very dangerous ground."],[2293,2423,"Keeping secrets,"],[2460,2606,"fraternizing with the guy"],[2606,2727,"who put a hit on me?"],[2811,3032,"I only went there to see my father."],[3073,3307,"I had no idea that Ivan would be there,"],[3307,3478,"or anyone else for that matter."],[3478,3674,"Alden is using you"],[3674,3812,"to prove that your engagement"],[3812,4037,"to Daniel means nothing,"],[4070,4200,"and that you're available"],[4200,4387,"to the highest bidder, Ivan."],[4387,4587,"Alden is using you as a pawn."],[4587,4713,"He's trash."],[4713,4925,"And how are you any different?"],[4925,5125,"I give a shit about you, okay?"],[5238,5347,"But cross me again,"],[5380,5588,"and you will deeply regret it."]],"44":[[175,325,"Hopefully this meet I arranged"],[325,487,"will clear the air between us."],[855,967,"Nice of you to show up."],[1046,1138,"Sorry I'm late."],[1213,1267,"Duty called."],[1267,1380,"I'm sure you can understand, Kent."],[1526,1597,"Honestly, I'm surprised"],[1597,1680,"you wanted to see me."],[1860,1968,"I guess that shot in your arm"],[1968,2085,"really brought you to your senses."],[2310,2448,"Hey, watch it, pal."],[2448,2556,"Watch it, kiddo."],[2602,2652,"Kent!"],[2681,2765,"Calm down!"],[2823,2965,"So you admit it was you"],[2965,3098,"that planned that attack?"],[3140,3232,"Not exactly."],[3232,3319,"Is he my guy?"],[3319,3399,"Yes."],[3490,3616,"But you tortured him."],[3620,3716,"He was trying to seek revenge."],[3716,3807,"Can you blame him?"],[3874,4074,"Look, he acted alone."],[4154,4241,"It's being handled."],[4270,4325,"All right, now that"],[4325,4446,"we got this out of the way,"],[4446,4625,"maybe we can do some business?"],[4671,4808,"You expect me to believe him?"],[4884,5025,"You two are in cahoots."],[5205,5271,"And you..."],[5417,5513,"Stay the hell away"],[5513,5668,"from my son's fiancée."],[5714,5793,"Sorry."],[5834,5939,"No can do."],[6039,6156,"I think I'll be meeting Fay"],[6156,6243,"sooner than later."]],"45":[[179,233,"All right."],[233,283,"Watch it."],[283,375,"I'll bury you."],[471,688,"Kent, my daughter conducted herself"],[688,813,"with class last night."],[813,909,"No harm done."],[1046,1163,"Now why don't we just behave"],[1163,1380,"like the civilized men that we are?"],[1443,1493,"All right?"],[1580,1701,"Ivan here, he's running"],[1701,1830,"the Russian syndicate now."],[1830,1985,"He's smart, he's hungry."],[1985,2160,"He reminds me of you at his age."],[2252,2314,"He's considering"],[2314,2444,"doing business with us."],[2494,2660,"So you thought you'd use Fay"],[2706,2852,"as a bargaining chip"],[2915,3094,"to secure your half of the deal?"],[3303,3453,"You two can both go to hell."],[4362,4466,"What are you doing here?"],[4600,4854,"Fay is my trump card,"],[4917,5050,"the only thing keeping"],[5050,5213,"Alden and Ivan at bay."],[5246,5342,"I need to keep her happy"],[5342,5476,"so she stays on my side."],[5588,5751,"I’m actually here to see you, Janeen."]],"46":[[930,996,"What is this?"],[996,1038,"A bribe?"],[1159,1222,"Kind of."],[2002,2047,"There must be"],[2047,2168,"a thousand dollars here."],[2227,2281,"It's your payment"],[2281,2431,"for Jerome's therapy session."],[2531,2702,"Kent's paying me for that?"],[2794,2973,"Dad throws money at his problems."],[3011,3115,"Honestly, I'm surprised"],[3115,3190,"you haven't taken off"],[3190,3307,"in the dead of night by now."],[3478,3657,"You said escape wasn't an option."],[3724,3803,"It isn't."],[3916,4070,"I'm still shocked you haven't tried."],[4396,4529,"And why haven't I?"],[4621,4875,"Is it because this life intrigues me?"],[4925,5184,"Or because in some sick way"],[5296,5480,"I don't want to let Kent down?"],[5651,5860,"I’ll be good for you, Kent."]],"47":[[104,237,"You sound disappointed in me."],[417,558,"Yes, I'm hoping it means"],[558,684,"you'll go through with the marriage."],[1030,1267,"I know you're not sold on the idea,"],[1267,1497,"but I really think it could work."],[1668,1735,"Daniel,"],[1951,2068,"I care about you"],[2168,2327,"as a friend."],[2348,2581,"The only reason I'm doing any of this"],[2581,2723,"is to protect my family."],[2811,2948,"As soon as I earn enough money"],[2948,3073,"to pay off Janeen's debts-"],[3073,3157,"You'll leave me."],[3265,3399,"Fay, you, you can't."],[3399,3478,"I need you."],[3574,3749,"We were good together before."],[3749,3858,"Before?"],[3858,3916,"I caught you"],[3916,4154,"making out with a guy in a bathroom?"],[4266,4521,"Why don't you tell your father the truth?"],[4537,4700,"I already told you, I can't."],[5526,5659,"You and Kent have both"],[5659,5818,"hijacked my existence."],[5818,5947,"Between your begging"],[5947,6064,"and his threats..."],[6064,6164,"He threatened you?"],[6431,6464,"I mean,"],[6464,6639,"I'm not surprised after that shit"],[6639,6802,"you pulled with Ivan last night..."],[6802,6994,"I didn't do anything wrong!"],[7040,7111,"What?"],[7148,7253,"He's gonna kill me"],[7253,7369,"if I have a conversation"],[7369,7499,"with the wrong person?"],[7574,7716,"It wouldn't be the first time."],[7970,8045,"Fay?"],[8145,8316,"Be downstairs in five."],[8316,8495,"Kent wants me to take you for a ride."]],"48":[[4,175,"Be downstairs in five."],[175,362,"Kent wants me to take you for a ride."],[775,859,"Fay!"],[892,1051,"Fay, I'm so happy to see you!"],[1130,1326,"Um, Kent said he'd be bringing you by,"],[1326,1551,"but I thought he was bullshitting."],[1614,1735,"Kent arranged this?"],[1768,1830,"Yeah!"],[1868,2022,"Yeah, he... he said you missed me"],[2022,2185,"and I told him I missed you too."],[2235,2339,"Just the other day"],[2339,2456,"he was making threats,"],[2456,2544,"whipping me,"],[2590,2769,"and now he's mending things"],[2769,2902,"between me and Janeen."],[2940,3061,"I'm actually surprised"],[3061,3161,"you wanted to see me."],[3278,3407,"Last time we spoke,"],[3457,3582,"you said I was dead to you."],[3787,3920,"I was just angry."],[3995,4095,"Confused."],[4137,4291,"You were acting like Kent's puppet,"],[4291,4500,"saying things that you would never say."],[4642,4721,"I'm sorry."],[4808,4959,"I was saying whatever it took"],[4959,5188,"to keep you and Dad safe from Dean."],[5263,5455,"Kent is protecting you both."],[5563,5680,"So that's why Dean let me go?"],[5851,5960,"I guess I should thank him."],[6068,6189,"Well, thank me too."],[6214,6306,"Because I'm the one"],[6306,6414,"who has to marry Daniel"],[6414,6573,"in order to keep you protected."],[6656,6781,"Oh, Jesus."],[6810,6977,"What the fuck are you doing here, huh?"],[7007,7094,"I already promised Kent"],[7094,7169,"I would lay off your"],[7211,7332,"slut of a sister."],[7540,7636,"What do you-"],[7816,8058,"Consider that a first payment, asshole."]],"49":[[0,241,"Consider that a first payment, asshole."],[367,538,"You touch her, you're dead."],[579,742,"Mafia King's orders."],[971,1046,"What is this?"],[1046,1146,"A thousand bucks?"],[1234,1480,"This bitch owes me sixty times that."],[1480,1551,"Sixty!"],[1780,1860,"Oh, come on,"],[1860,2014,"please don't look at me like that."],[2052,2147,"Stripping in this dump"],[2147,2235,"doesn't pay the bills"],[2235,2348,"and Dad's car business"],[2348,2419,"is struggling."],[2464,2635,"I, I did what was best for all of us."],[2635,2706,"That's right."],[2706,2815,"She owes me."],[2890,2973,"And, you two..."],[3103,3328,"You can't hide behind Kent forever!"],[3737,3891,"I'll get you your money."],[3908,4124,"But if you threaten me again,"],[4183,4375,"Kent will be the least of your troubles."]],"50":[[200,346,"Fay is engaged to me,"],[358,429,"not you."],[496,704,"Don Alden wants the Bianci bloodline."],[717,855,"My mother's bloodline,"],[855,909,"not yours."],[909,1034,"Wrong, Daniel."],[1076,1213,"Don Alden wants power."],[1284,1405,"He thought that aligning with us"],[1405,1514,"was one way to get it."],[1593,1772,"But he's weighing out other options now."],[1968,2114,"Is engagement off the table?"],[2114,2202,"Not yet."],[2268,2394,"Something is brewing, though."],[2448,2590,"I feel exposed."],[2660,2769,"You should, too."],[2948,3111,"Am I interrupting something?"],[3199,3265,"No."],[3837,3920,"I'll be brief."],[4024,4124,"I wanted to thank you,"],[4124,4216,"Kent, for today,"],[4291,4400,"for arranging a meeting"],[4400,4512,"between me and Janeen."],[4667,4767,"What the hell is going on"],[4767,4846,"between you two?"],[4879,4971,"Nothing. -Nothing."],[5059,5201,"Fay, you're welcome."],[5230,5326,"I hope that you and Janeen"],[5326,5413,"had a nice visit."],[5530,5680,"And that my payment for Jerome's session"],[5680,5764,"proves that I can"],[5860,5947,"be generous."],[6468,6602,"That's what I'm talking about."]],"51":[[20,175,"That is what I'm talking about."],[216,375,"The lingering glances."],[375,475,"You touching her."],[475,671,"Jealousy doesn't suit you, Daniel."],[671,784,"Can you blame me?"],[813,871,"Look, if you're not"],[871,971,"going to stop our enemies"],[971,1155,"from circling her like sharks,"],[1217,1301,"I will."],[1301,1359,"Don't worry."],[1418,1514,"From here on out,"],[1514,1664,"I'll be the one to take care of her."],[1701,1797,"Okay, fine."],[1893,2031,"I'll take care of the wedding prep."],[2135,2331,"Make sure she stays loyal to us."],[2873,3057,"I hate lying to him."],[3140,3224,"What kind of father"],[3224,3449,"wants to steal his son's fiancée..."],[3449,3649,"even when it could cost him everything?"]],"52":[[638,750,"So, Jerome..."],[804,896,"would you tell me more"],[896,1172,"about your early days working for Kent?"],[1388,1693,"Well, there was a steep learning curve."],[1760,2018,"Kent can be ruthless."],[2056,2302,"And he expects a lot from his men."],[2581,2740,"And how about now?"],[2819,2990,"Now it's better."],[2990,3240,"I mean, Kent's tough, but fair."],[3449,3516,"And I'm..."],[3541,3687,"I'm happier than I've ever been."],[3766,3887,"Especially since I..."],[4183,4316,"since I started"],[4316,4446,"seeing someone special."],[4646,4721,"Well tell me more."],[5017,5113,"I have to take this."],[5434,5584,"I love helping Jerome,"],[5584,5668,"but at this rate,"],[5668,5830,"it'll take me over 60 sessions"],[5830,5951,"to pay off Janeen's debts."],[6056,6260,"I have to figure something else out."]],"53":[[383,442,"Ivan?"],[604,700,"What are you doing here?"],[759,884,"I come here all the time."],[942,1088,"You're trying to tell me"],[1088,1288,"that this is just a coincidence?"],[1343,1584,"It is dangerous for us to be seen together."],[1685,1868,"Well, there's someone"],[1868,1931,"that strikes me"],[1931,2043,"that likes a little danger."],[2560,2677,"Aren't you curious to know"],[2677,2869,"what I'm all about?"],[2944,3165,"What is it about this guy?"],[3257,3424,"I should steer clear, but..."],[3541,3737,"it's not like I owe the Lipperts any more"],[3737,3891,"than I'm already giving."],[3983,4229,"I deserve a little fun and spontaneity."],[4291,4425,"Come on, have one drink with me,"],[4508,4621,"then I'll take you home."],[5668,5797,"I could listen to you laugh all night."],[6081,6189,"I want you, Fay."],[6377,6443,"You're funny."],[6685,6748,"You're beautiful."],[7036,7144,"Do you..."],[7144,7211,"want me?"],[7286,7378,"What the fuck?"]],"54":[[0,83,"What the fuck?"],[137,304,"What the fuck do you think you're doing?"],[333,375,"Stop!"],[375,462,"Stop fighting!"],[855,963,"Do you know what you're doing, grunt?"],[1101,1209,"Pulling a gun on me?"],[1209,1363,"Consider this a final warning."],[1643,1743,"You stay away"],[1743,1847,"from the Mafia King's"],[1847,1943,"future daughter-in-law."],[2127,2214,"Make me."],[2239,2352,"Fay, come."],[2352,2414,"Let's go."],[3286,3374,"I'm an adult!"],[3374,3428,"Why can't I"],[3428,3486,"go out for a drink-"],[3486,3599,"Fay, just stop it!"],[3616,3699,"Stop!"],[3699,3770,"And listen!"],[3878,3983,"This is serious."],[4083,4191,"You want my advice?"],[4350,4462,"Be honest with him."],[4583,4679,"Apologize."],[4704,4779,"And just hope that"],[4779,4909,"he's in a merciful mood."]],"55":[[171,300,"He looks so good."],[454,579,"What was I doing with Ivan"],[579,788,"when this was here waiting for me?"],[867,1038,"No, I can't go there."],[1038,1217,"What the hell were you thinking today?"],[1393,1530,"Ivan showed up at my"],[1530,1630,"session with Jerome"],[1630,1718,"and I just..."],[1935,2114,"I just wanted to feel free."],[2243,2394,"Like I can make my own decisions"],[2394,2485,"like I used to."],[2485,2635,"Fucking around with Ivan Kozlov"],[2635,2819,"is your version of feeling free?"],[2819,2944,"Your carelessness,"],[2944,3065,"your games."],[3111,3311,"They're threatening our future."],[3332,3616,"If I go down, you go down, Fay."],[3657,3770,"Do you get that?"],[3974,4141,"I think I'm beginning to."],[4179,4295,"Ivan played you."],[4295,4479,"It was a mob bar he took you to."],[4517,4592,"I've been getting calls"],[4592,4700,"about it all night."],[4700,4833,"Kent, I'm sorry."],[4833,5034,"Your sorry means nothing to me."],[5180,5301,"You're jealous."],[5609,5714,"You claim to be"],[5714,5880,"protecting your family?"],[5880,6018,"Protecting Daniel?"],[6072,6189,"But the truth is..."],[6352,6485,"you want me."],[6548,6673,"Don't you, Kent?"]],"56":[[41,162,"But the truth is..."],[350,462,"you want me."],[525,658,"Don't you, Kent?"],[2052,2122,"Jealous?"],[2260,2310,"No."],[2439,2489,"Never."],[2648,2711,"But you're right."],[3003,3161,"It's not about Daniel anymore."]],"57":[[1096,1142,"Kent."],[1355,1422,"Please."],[1626,1726,"You're so easy."],[1839,1931,"Look at you."],[2193,2318,"It's just like I thought."],[2360,2540,"Cavorting around with Ivan all day"],[2540,2715,"just to get my attention."],[3019,3144,"That isn't true!"],[3161,3240,"Isn't it?"],[3324,3557,"All this just to get a rise out of me."],[3557,3766,"So I kiss you or punish you."],[3766,3866,"Just like in the garage"],[3866,4033,"when I had you bent over the desk."],[4145,4233,"And your ass"],[4300,4458,"was stinging from my whip."],[4458,4617,"You were begging me"],[4642,4717,"for more."],[4717,4796,"Fuck you!"],[4946,5034,"Fuck me?"],[5163,5226,"No."],[5367,5451,"Not yet."],[5534,5668,"We have to get to know each other"],[5668,5814,"a little bit better first."]],"58":[[45,120,"Fuck me?"],[166,241,"Not yet."],[342,467,"We have to get to know each other"],[467,608,"a little bit better first."],[717,888,"I am done being toyed with."],[1151,1297,"What a feisty"],[1297,1393,"little"],[1