is agreement between us,"],[2723,2944,"very clearly outlines the boundaries"],[2944,3078,"that we must keep in mind."],[3186,3307,"Daniel was right."],[3470,3611,"You have been using me."],[3699,3858,"Just like Don Alden."],[3858,3983,"Just like Ivan."],[3983,4149,"Just like Daniel before."],[4204,4391,"And now you're trying to buy"],[4391,4517,"my virginity."],[4571,4833,"Fay, you're overreacting."],[4975,5155,"Men in my position make agreements"],[5155,5309,"like this all of the time."],[5538,5714,"Take the night, okay?"],[5784,5885,"Just think it over."],[6110,6247,"I've thought it over."],[6360,6510,"The answer is no."]],"68":[[467,550,"Just when I thought"],[550,696,"things can't get any worse,"],[725,1021,"Kent tries to turn me into his concubine."],[2198,2285,"Hi, Janeen."],[2344,2460,"Do you have a minute to talk?"],[2544,2635,"It's about Kent."],[2686,2827,"I don't know how to tell you this,"],[2827,2969,"but, he just asked"],[2969,3140,"if I would be his mistress?"],[3219,3307,"A contract?"],[3361,3436,"Seriously?"],[3461,3495,"Yeah."],[3495,3595,"He offered me a contract"],[3595,3674,"and everything."],[3703,3899,"Well, these mob guys are a different breed."],[3899,3974,"All business."],[3974,4149,"Why do you sound so matter-of-fact?"],[4216,4333,"I, I'm pissed!"],[4333,4487,"I can't believe Kent,"],[4487,4633,"like, what is he thinking?"],[4738,4984,"I mean, okay, don't bite my head off,"],[5030,5138,"but I think you should take it."]],"69":[[0,150,"Don't bite my head off,"],[196,308,"but I think you should take it."],[429,496,"Kent's hot,"],[496,654,"and five million dollars"],[654,759,"is fuck-you money."],[792,909,"You really think I should?"],[946,1088,"I mean, yeah."],[1088,1242,"Unless you're not attracted to the guy,"],[1242,1330,"in which case..."],[1330,1443,"I am!"],[1480,1564,"Yeah, I thought so."],[1593,1676,"And do it, Fay."],[1689,1776,"Sign the contract."],[1805,1951,"You'll be a very rich woman,"],[1951,2085,"and you'll get some hot mob boss loving"],[2085,2160,"while you're at it."],[2181,2268,"Thanks, Janeen."],[2364,2610,"You've given me a lot to think about."],[2844,2902,"Bye."],[3616,3703,"Can I do it?"],[3832,3949,"This isn't how I imagined"],[3949,4083,"losing my virginity..."],[4162,4287,"under contract."],[5647,5739,"Got a pen?"]],"70":[[1238,1426,"Fay, here's a little something for you"],[1426,1601,"to wear to my room tonight."],[1626,1722,"Meet me in an hour."],[1805,2035,"Am I really doing this?"],[3411,3549,"Did anyone see you come here?"],[3991,4162,"If you're having any second thoughts"],[4162,4245,"about this..."],[5601,5697,"You look sinful."],[6510,6631,"Do a little spin for me."],[8420,8529,"The contract..."],[8621,9009,"mentioned sex and other things."],[9009,9213,"Something like what you did to me"],[9213,9409,"in the garage..."],[9409,9547,"with..."],[9547,9622,"the crop?"],[9826,9889,"Yeah."],[10126,10226,"BDSM."]],"71":[[62,150,"BDSM."],[400,533,"But I promise..."],[734,829,"I'll go slow..."],[975,1076,"and I'll be gentle."],[1472,1697,"I don't want you to be gentle."],[2844,3036,"I've been waiting for this moment..."],[3094,3190,"for so long."],[3874,4058,"I need to make sure you're ready for me."],[5526,5622,"Are you ready for me?"],[5743,5793,"Yes."],[5980,6118,"I'm ready for you, Kent."]],"72":[[25,162,"I'm ready for you, Kent."],[684,750,"Does this hurt?"],[829,921,"Please don't stop."],[1480,1580,"How does this feel?"],[1868,2018,"It feels really good."]],"73":[[0,125,"You need to rest."],[337,404,"You have your dinner"],[404,508,"with Ivan tomorrow."],[775,884,"That's what you say to me"],[884,1005,"right after we have sex"],[1005,1101,"for the first time?"],[1130,1284,"After taking my virginity?"],[1330,1393,"I'm sorry."],[1422,1618,"Business is always on my mind."],[1705,1822,"No, obviously."],[1856,2072,"Fay, we have two contracts."],[2110,2218,"And as much as I..."],[2598,2744,"favor one of them,"],[2773,2944,"they're both equally important."],[3103,3253,"I understand."],[3282,3340,"Okay."],[3395,3616,"I assume that you and Ivan"],[3616,3712,"exchange numbers?"],[3778,3849,"Yes."],[4033,4154,"Can you arrange the dinner?"],[4320,4571,"Are you sure you won't get jealous?"],[4625,4721,"Of Ivan?"],[4817,4950,"I know who you want."],[5117,5255,"Ivan's just business."],[5326,5417,"You"],[5417,5513,"are my"],[5513,5655,"sexy,"],[5655,5864,"hot"],[5864,5968,"secret weapon."],[6535,6614,"And right now..."],[6927,7036,"you're all mine."]],"74":[[3853,4074,"The dress is for dinner with Ivan,"],[4220,4350,"the lingerie is for me,"],[4396,4458,"later."],[5480,5705,"Thank you for wearing this dress."],[6202,6314,"Is everything okay?"],[6314,6502,"The engagement's off, right?"],[6502,6548,"Yeah."],[6548,6677,"It's just..."],[6731,6823,"complicated."],[6977,7077,"You know I care about you."],[7182,7336,"I just want to make sure that you're safe."],[7399,7449,"Safe?"],[7615,7716,"What do you mean?"],[7782,7978,"Kent's life is in danger."],[7978,8058,"He's not going to be in power"],[8058,8120,"much longer."],[8174,8291,"And as long as you live with him..."],[8375,8450,"so are you."]],"75":[[442,629,"Kent's life is in danger."],[629,709,"He's not going to be in power"],[709,775,"much longer."],[967,1138,"Was Ivan telling the truth?"],[1205,1372,"Or was he just trying to drive a wedge"],[1372,1526,"between me and the Lipperts?"],[1680,1826,"Are we really in danger?"],[3161,3274,"You..."],[3378,3445,"look..."],[3574,3678,"magnificent."],[3837,3987,"Do you want to hear about the date?"],[4062,4158,"Ivan said-"],[4158,4241,"Tomorrow."],[4375,4512,"Tomorrow we can talk about that."],[4554,4667,"Tonight's about us."],[6389,6477,"What are we doing?"],[7019,7119,"You’ll find out."]],"76":[[12,125,"Where are you taking me?"],[367,521,"Somewhere very private."],[684,763,"Somewhere"],[796,934,"I've wanted to take you"],[934,1146,"since the day I laid eyes on you."],[1455,1718,"It's too bad I can't see it."],[1856,1956,"Just wait."],[2135,2381,"When you remove vision..."],[2473,2715,"all of the other senses..."],[2777,2869,"are heightened."],[3119,3211,"Do you trust me?"],[3420,3495,"Yes."],[6126,6247,"You told me"],[6389,6581,"you don't want me"],[6581,6685,"to be gentle."],[6965,7077,"Did you mean that?"],[7273,7378,"Mhm."],[7524,7699,"You need to choose a safe word."]],"77":[[29,204,"You need to choose a safe word."],[729,817,"Barbecue."],[1076,1205,"Barbecue it is."],[9113,9192,"How long have you been"],[9192,9305,"fucking my dad?"]],"78":[[0,83,"How long have you been"],[83,191,"fucking my dad?"],[308,450,"Fucking your dad?"],[450,554,"What are you talking about?"],[663,717,"You know he doesn't"],[717,867,"give a shit about you, right?"],[917,1080,"He's just using you for sex,"],[1080,1201,"like he did the others."],[1222,1418,"And then he'll throw you away like Fiona."],[1459,1580,"This paranoid bastard"],[1580,1718,"doesn't trust anyone!"],[1718,1864,"Won't let anyone get close!"],[2060,2268,"I know I'm gay, but if we get married,"],[2268,2394,"I would respect you."],[2394,2469,"And I would treat you"],[2469,2548,"better than he ever could."],[2548,2660,"Daniel, stop!"],[2690,2948,"And I'm not sleeping with your father!"],[2977,3069,"You're lying!"],[3136,3274,"You don't think I see the way"],[3274,3374,"you two look at each other?"],[3374,3536,"The little gifts he leaves you?"],[3536,3737,"So you're spying on me now, is it?"],[3737,3887,"I don't need to spy."],[3933,4058,"It's as plain as day."],[4133,4250,"You're an idiot if you think-"],[4250,4366,"Who I sleep with"],[4366,4521,"is none of your business."],[4521,4688,"We are no longer engaged."],[4725,4850,"And that's a good thing."],[4896,5063,"Because you were just on your knees"],[5063,5238,"in the kitchen with Jerome."],[6464,6589,"I thought you'd still be resting."],[6852,7044,"I pushed you to your limits last night."],[7157,7261,"We've got a problem."]],"79":[[66,162,"We've got a problem."],[191,312,"Several, actually."],[433,504,"Lay it on me."],[68