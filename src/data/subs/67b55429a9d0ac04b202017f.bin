you forget that."],[8066,8162,"Now go to your room."]],"85":[[521,613,"Fay, wait."],[884,1005,"Can we talk, please?"],[1276,1426,"I'm sorry about the other day."],[1426,1580,"I shouldn't have said those things."],[1680,1801,"No, Daniel."],[1801,1872,"I lied to"],[1872,1985,"to you and- -Don’t"],[2068,2139,"It's fine."],[2218,2560,"My dad can be very alluring."],[2652,2794,"The money, the power..."],[2852,2919,"I get it."],[3028,3261,"Not to mention his good looks,"],[3315,3399,"and how good he looks"],[3399,3536,"in a suit..."],[3536,3674,"and naked."],[3712,3816,"Forget the past."],[4062,4170,"All I care about now"],[4170,4308,"is mending our relationship."],[4504,4700,"You mean our friendship?"],[4763,4821,"Sure."],[4871,4954,"We're friends,"],[4954,5155,"but I want us to be more."],[5259,5388,"I'll take care of you, Fay."],[5630,5739,"Marry me, Fay."],[5739,5847,"Be my wife."],[5935,6172,"Daniel, this again?"],[6214,6423,"But what about living in your truth?"],[6468,6594,"What about Jerome?"],[6664,6798,"Jerome and I are through."],[6827,6877,"No."],[6936,7002,"Really?"]],"86":[[54,179,"Jerome and I are through."],[212,275,"No."],[325,392,"Really?"],[704,804,"That's news to me."],[1176,1276,"Kent wants to see you both"],[1276,1359,"in the living room."],[2936,3044,"What's going on here?"],[3115,3294,"Alden, why don't you tell your daughter"],[3294,3365,"why you're here?"],[4037,4279,"I want to apologize, daughter,"],[4371,4496,"for the way I treated you"],[4496,4658,"the last time we spoke."],[4892,4996,"I was out of line."],[5267,5492,"Thank you for that, Dad."],[5672,5805,"Ivan, why are you here?"],[5855,6047,"I'm here because Don and I"],[6047,6122,"are worried about you."],[6235,6339,"We think that you're being kept here"],[6339,6410,"against your will."],[6648,6794,"Fay's a big girl, alright?"],[7032,7136,"She wouldn't be here if"],[7207,7298,"she didn't want to be."],[7419,7474,"Tell them."],[7636,7870,"I'm here because I want to be."],[7974,8062,"That's no