{"1":[[5217,5405,"Oh. Thank you."],[5709,5901,"Oh, I'm sorry, Miss Miller,"],[5901,5963,"but you don't meet"],[5963,6160,"the criteria to adopt Sarah."],[6160,6448,"I told you she wasn't fit to be a mother."],[6577,6735,"Please."],[6735,6873,"I love Sarah, okay?"],[6873,7132,"I can provide her with a loving home."],[7132,7311,"Our policies are clear."],[7311,7432,"Without a stable marriage"],[7432,7564,"and financial security,"],[7564,7661,"there's no way they're going"],[7661,7953,"to let me approve this application."],[8875,9029,"Yeah, I'll be right there."],[9451,9601,"Where is this guy?"],[9601,9776,"We've been waiting for over an hour."],[9834,9972,"Mr. Rodriguez is known for"],[9972,10155,"his fashionably late entrances."],[10276,10493,"Well, I hope he comes in good spirits."],[10493,10602,"This deal is crucial"],[10602,10710,"for our expansion."],[10865,11065,"Speaking of companies' expansions,"],[11127,11227,"your family has been pressuring"],[11227,11302,"you to get married."],[11348,11478,"To June, right?"],[11599,11711,"That's never going to happen."],[11886,11970,"You know what, Jason?"],[11970,12070,"Go back to the office."],[12070,12195,"I'll wait for Mr. Rodriguez myself."],[12516,12670,"Yes, Robert."],[12837,13029,"Hi. I am so sorry I'm late."]],"2":[[54,191,"I'm sorry, who are you?"],[191,404,"Oh, I'm Alison Miller."],[404,633,"I am a handmade jewelry designer."],[633,738,"So you saw my ad online"],[738,867,"for contract marriage?"],[1071,1176,"Oh, is that for me?"],[1176,1251,"Thanks."],[1789,1951,"I like mine with a bit more sugar."],[2139,2277,"I'm Robert Johnsons."],[2277,2356,"Yeah, I know your name,"],[2356,2469,"Robert Johnson."],[2506,2731,"I just didn't know you'd be so hot."],[2777,3019,"Anyway, so are you down for this?"],[3019,3165,"I mean, I know it's crazy."],[3165,3249,"I mean, I won't really"],[3249,3328,"cause you any trouble."],[3328,3486,"It's just a formality, really."],[3757,3799,"Would you be"],[3799,3928,"willing to marry me today?"],[4521,4658,"Well, that's a bold proposal,"],[4746,4875,"but an interesting one."],[4967,5063,"This might also be a way for me"],[5063,5134,"to push back against the"],[5134,5288,"pressure from my family."],[5409,5559,"Well,"],[5559,5722,"Alison,"],[5722,5935,"it's definitely a first."],[6118,6277,"But I accept your proposal."],[6360,6414,"Really?"],[6502,6602,"Let's get married."],[6656,6765,"Let's get married."],[7427,7490,"Excuse me."],[7490,7661,"Is there a woman named Allison"],[7661,7770,"looking for Bob Johnson?"]],"3":[[556,671,"I can't believe this is happening."],[671,754,"Yeah."],[905,1021,"Ready?"],[1021,1126,"Ready."],[1605,1697,"Alison, don't"],[1697,1931,"take this the wrong way, but"],[1931,2022,"why were you so willing"],[2022,2231,"to marry a guy you've just met?"],[2431,2665,"There's this little girl, Sarah,"],[2665,2765,"and she's only five."],[2765,3115,"But her foster parents abuse her,"],[3115,3328,"so I want to adopt her."],[3357,3461,"Give her the loving home"],[3461,3566,"that she deserves."],[3691,3891,"But the adoption agency keeps"],[3891,4058,"denying me because I'm single."],[4058,4258,"So I put up an ad"],[4258,4504,"for a contract marriage, and"],[4504,4625,"Bob Johnson responded."],[4625,4783,"Well, that's you."],[4825,5121,"That's why when you heard my name..."],[5263,5397,"Thanks for marrying me."],[5437,5507,"Yeah."],[5922,6035,"You,"],[6035,6160,"CEO of MJ Group,"],[6160,6289,"got married just like that."]],"4":[[20,196,"You, CEO of MJ Group,"],[196,350,"got married just like that?"],[446,592,"What about June?"],[592,750,"She's been pining for you for years."],[750,1026,"June and I are ancient history."],[1026,1159,"It's none of her business."],[1488,1530,"Jason,"],[1530,1601,"I need you to purchase a"],[1601,1755,"small place for me."],[1755,1906,"Something to downplay"],[1906,2018,"my CEO status."],[2018,2060,"Don't you think"],[2060,2139,"you should tell Alison"],[2139,2306,"the truth about who you are?"],[2377,2448,"Not yet."],[2610,2736,"Any news on Kevin Rodriguez's"],[2736,2811,"recent move?"],[2857,3019,"He's been quite active lately."],[3019,3165,"Seems to be planning something."],[3374,3445,"Kevin Rodriguez"],[3445,3582,"is no match for me."],[3716,3874,"Alison,"],[3874,4012,"you actually married"],[4012,4187,"someone to adopt Sarah?"],[4187,4254,"Yeah."],[4316,4371,"Hi."],[4517,4621,"I'm Robert,"],[4621,4721,"Alison's husband."],[5776,5834,"I'm sorry"],[5834,5972,"the house isn't that big."],[6031,6114,"Oh, no."],[6114,6181,"Don't worry about it."],[6181,6260,"I'm just thankful"],[6260,6431,"you were willing to marry me."],[7453,7507,"How did you get"],[7507,7674,"such a nice place in the hills?"],[7749,8070,"Oh, I've been renting it for years."],[8237,8487,"Well, I'll have to move in."],[8487,8571,"The adoption agency"],[8571,8654,"is going to be stopping by"],[8654,8846,"for a home visit in a few days."],[8846,8904,"So we'll have to play"],[8904,9067,"the happy couple until they come."],[9067,9309,"And then after that, we can get a divorce."],[9367,9492,"Until then I'll be a good wife."],[9638,9693,"Deal."],[9805,9855,"The arrangements"],[9855,9939,"are really thorough."],[10218,10347,"So..."],[10518,10602,"I mean, you seem to"],[10602,10827,"be pretty well off."],[10894,10994,"You're"],[10994,11073,"quite handsome"],[11073,11244,"if you don't mind me saying."],[11244,11315,"Why would you even"],[11315,11478,"agree to a contract marriage?"],[11624,11749,"Is this, like, a scam?"]],"5":[[37,241,"Is this, like, a scam?"],[241,454,"No, no, not a scam."],[508,600,"Promise."],[788,1030,"Look, I wanted to give you this."],[1030,1197,"Any living expenses you may have."],[1197,1330,"Oh..."],[1384,1555,"No, we'll split everything equally."],[1555,1726,"It's a partnership, remember?"],[1847,1914,"You're right."],[2577,2702,"Hi, Sarah."],[3011,3098,"Hi, honey."],[3098,3203,"Hi."],[3203,3403,"So, this is Robert."],[3403,3520,"The man I was telling you about."],[3520,3557,"Hi."],[3557,3645,"Hi."],[3645,3724,"What do you think?"],[3724,3849,"You want him to be your new dad?"],[3849,3908,"Yes."],[3949,4033,"Oh, look at this."],[4033,4120,"What's this?"],[4166,4308,"And Robert, this is Sarah."],[4479,4612,"It's nice to meet you, Sarah."],[4612,4717,"You too."],[4800,4950,"Who are these guys?"],[5088,5276,"This one's actually my favorite."],[5338,5476,"Wait, this is only $10?"],[5476,5562,"Mm-hmm."],[5634,5755,"Alison, your talent is worth"],[5755,5864,"far more than $10."],[6460,6623,"Could you help me try this on?"],[6715,6777,"Yeah."],[7236,7390,"All right."],[7570,7636,"Okay."]],"6":[[0,114,"Okay."],[462,684,"Actually, I'll get that for you."],[684,813,"Oh."],[955,1076,"Cool."],[1810,2014,"I don't know, maybe not this time."],[2131,2327,"I mean, I think you look beautiful."],[2869,3003,"I'll take it."],[3082,3203,"Thank you."],[3682,3885,"You know, my company"],[3885,4083,"is actually hiring jewelry designers."],[4083,4158,"Really?"],[4158,4233,"Yeah."],[4295,4450,"I'll think about it."],[4450,4550,"Robert."],[4596,4682,"How come you didn't tell me you were"],[4682,4792,"going to be here today, dude?"],[4884,5113,"This is my cousin, Peter."],[5176,5305,"So nice to meet you."],[5305,5442,"It's lovely to meet you, too."],[5555,5705,"You know, it's-it's funny."],[5751,6051,"Peter actually loves jewelry."],[6139,6235,"Really?"],[6414,6585,"Yeah, I do."],[6585,6760,"Oh, great."],[6760,6856,"And..."],[6973,7198,"you want to buy all of this."]],"7":[[25,325,"You want to buy all of this."],[325,417,"Right?"],[550,654,"How much?"],[750,880,"It'll be $8,000."],[1092,1209,"Of course."],[1209,1317,"It's beautiful."],[1430,1564,"$8,000."],[1659,1805,"$8,000."],[1822,1935,"Great."],[1997,2131,"I'll take the whole lot."],[2189,2273,"Thank you."],[2273,2431,"Yeah, yeah."],[2431,2615,"Wish I had more hands."],[2615,2798,"Can't wait to wear it all."],[3048,3140,"Oh my God."],[4133,4229,"Alison,"],[4229,4387,"these are incredible."],[4454,4608,"You are a real gift."],[4996,5067,"But I only have a"],[5067,5238,"high school diploma."],[5238,5347,"Do you really think your company"],[5347,5484,"is going to accept my resume?"],[5638,5676,"Well."],[5747,5893,"I know the CEO of my company"],[5893,6018,"values talent"],[6018,6214,"above all else."],[6214,6418,"With your skills and creativity,"],[6418,6619,"I have no doubt you'll succeed."],[6652,6752,"Thanks."]],"8":[[608,742,"Hi there."],[742,855,"Are you interviewing"],[855,1038,"for the design position, too?"],[1038,1284,"Yeah, I am. I'm Alison."],[1284,1393,"Olivia. Just came"],[1393,1539,"back from studying in France."],[1539,1634,"Oh, wow."],[1839,1985,"I hear that most people here"],[1985,2056,"are actually more"],[2056,2214,"interested in the hot CEO"],[2214,2398,"than the job itself."],[2398,2515,"Really?"],[2515,2706,"I didn't know that."],[2706,2773,"Olivia."],[2773,2969,"They're ready for you."],[2969,3048,"Wish me luck."],[3048,3161,"Good luck."],[4325,4471,"You're gonna do great."],[4471,4575,"Just be yourself."],[4808,4904,"Mr. Johnsons."]],"9":[[58,216,"Mr. Johnsons."],[496,592,"Robert."],[592,667,"Have you finished"],[667,829,"those reports I asked for?"],[829,900,"Yes, sir."],[900,988,"They will be on your desk"],[988,1117,"first thing in the morning."],[1830,1956,"Alison Miller?"],[1997,2131,"We're ready for you."],[2210,2335,"So you only completed your high school"],[2335,2540,"education, Miss Miller."],[2540,2677,"That's hardly impressive."],[2740,2948,"Well, I was accepted into CalArts."],[2948,3119,"But I had to drop out due to"],[3119,3269,"some medical issues."],[3269,3357,"Do you really think you have"],[3357,3435,"what it takes to work"],[3435,3591,"at a company like this?"],[3591,3849,"These designs are amateur at best."],[3849,4066,"You're wasting our time here."]],"10":[[496,642,"Alison, wait."],[679,800,"I'm so sorry."],[896,1025,"I thought I had a chance,"],[1025,1192,"but maybe I'm just not good enough."],[1192,1305,"Don't say that."],[1438,1722,"You have an incredible talent, Alison."],[1768,1864,"Don't let anyone make you"],[1864,1976,"question that."],[2360,2494,"Let's go get a coffee."],[2794,2865,"Ms. Davis."],[2923,3007,"I couldn't help but overhear"],[3007,3207,"your interaction with Ms. Miller."],[3207,3361,"I was just doing my job."],[3361,3403,"Weeding out"],[3403,3561,"the unqualified candidates."],[4041,4190,"I suggest you take a closer"],[4190,4350,"look at Ms. Miller's work."],[4471,4559,"She has an extraordinary"],[4559,4675,"gift for design."]],"11":[[2627,2727,"Something wrong,"],[2727,2836,"Ms. Davis?"],[2911,3028,"No."],[3069,3182,"Nothing."],[5672,5901,"Alison is married?"],[5901,6051,"To Robert?"],[6139,6297,"How is that possible?"],[6898,6961,"I need you to figure out"],[6961,7044,"everything you can about"],[7044,7178,"Alison Miller and her connection"],[7178,7319,"to Robert Johnsons."],[7394,7532,"Immediately."]],"12":[[308,454,"Alison."],[454,567,"Hi."],[567,746,"Oh my gosh."],[788,930,"It's good to see you."],[1117,1180,"Ava."],[1222,1497,"We worked together at the Crown Hotel."],[1497,1797,"Hi. Ava, I'm so sorry."],[1805,1960,"I kind of had some"],[1960,2089,"memory issues in college,"],[2089,2189,"and it's all kind of fuzzy."],[2189,2310,"I don't..."],[2310,2427,"I don't actually remember working"],[2427,2569,"at the Crown Hotel."],[2665,2744,"Okay."],[2840,3036,"Yeah, it was a long time ago, I guess."],[3332,3436,"-Bye. -Bye."],[4116,4300,"Hey, Meg."],[4300,4642,"So, I ran into somebody today"],[4642,4715,"who said that"],[4715,5046,"we worked at the Crown Hotel together, but"],[5142,5230,"I don't remember"],[5230,5392,"working there at all."],[5530,5718,"What happened in college?"],[6010,6151,"Well, um..."],[6339,6493,"your mom got sick,"],[6614,6840,"and you had to pay her medical bills."],[6931,7140,"So you took a job"],[7140,7340,"at the Crown Hotel for a while."],[7494,7720,"I just wish I could remember."],[7720,7937,"I just feel like there's this big"],[7937,8145,"chunk of my life. It's just"],[8274,8437,"missing."],[8725,9025,"Don't worry, Alison."],[9046,9163,"What's important"],[9163,9408,"is that you made it through,"],[9408,9613,"and you're here now."],[10301,10414,"Please, Alison,"],[10452,10543,"you have to make it"],[10543,10643,"through this."],[10643,10806,"I can't lose you."],[11611,11653,"Meg?"]],"13":[[253,389,"-Thank you. -Mm-hmm."],[763,829,"What do you think?"],[963,1042,"Looks good."],[1343,1393,"Oh."],[1484,1597,"You okay?"],[1693,1747,"Yeah."],[2627,2744,"I'll get that."],[3190,3365,"Hi. You must be the adoption officer."],[3365,3495,"I'm here for the home visit,"],[3495,3561,"and the interview"],[3561,3745,"for Sarah's potential adoption."],[3787,3916,"Thank you so much for coming."],[3916,4004,"Appreciate it."],[4095,4258,"And you must be Alison."],[4546,4608,"Nice to meet you."],[4608,4758,"So nice to meet you."],[4758,4900,"Shall we?"],[4900,5030,"-Yeah. -Yeah."],[5955,6076,"So why is it important"],[6076,6210,"that you adopt Sarah?"],[6285,6470,"Well, we just feel like"],[6470,6619,"we have a lot of love to give."],[6619,6727,"And we want to"],[6727,6823,"provide a safe"],[6823,6956,"and nurturing home"],[6956,7082,"for a child in need."],[7303,7357,"And how long"],[7357,7490,"have you two been married?"],[7515,7632,"A whole month."],[7678,7820,"Best decision of my life."],[7966,8141,"That's quite a short time."],[8166,8229,"What made you guys"],[8229,8324,"get married so quick?"],[8437,8737,"Well, we..."],[8742,8892,"I'll be honest."],[8892,9038,"This is really suspicious."],[9163,9255,"Are you sure you're not just"],[9255,9375,"in an arranged marriage?"]],"14":[[1084,1297,"Alison is my soulmate."],[1297,1343,"I couldn't wait"],[1343,1534,"another day to make her my wife."],[1643,1714,"Well, I could tell that"],[1714,1960,"the love you guys share is very real."],[1960,2022,"And I have a great"],[2022,2214,"feeling about all of this."],[2214,2494,"So expect good news very soon."],[2494,2677,"Oh. Thank you."],[2869,2994,"Thank you so much."],[2994,3115,"Of course."],[3332,3424,"Bye."],[4054,4191,"Oh, gosh."],[4191,4300,"You were amazing."],[4300,4421,"So were you."],[4550,4600,"Okay."],[4600,4675,"Alison."],[5034,5326,"Have you ever thought about us"],[5326,5501,"being more than just a contract?"],[5980,6231,"I'm sorry, I don't know what to say."],[6231,6373,"No. It's okay."],[6373,6427,"Take all the time"],[6427,6548,"you need to think about it."],[6606,6861,"I actually made a reservation for us."],[6906,7007,"I'll wait for you at the restaurant."],[7874,8062,"Listen, I called for 8:00, alright?"],[8062,8187,"So why don't you check your little book"],[8187,8383,"and find my table, please?"],[8383,8450,"Check it."],[8450,8565,"What, you don't know how to read?"],[8804,8938,"Alison."],[8983,9067,"Adam."],[9142,9413,"Well, it's been a really long time."],[9413,9567,"Yeah, it has been a long time."],[9567,9697,"Too long."],[9697,9793,"You look..."],[9889,9951,"amazing."],[9951,10072,"Just like always."],[10168,10310,"You know, I was thinking..."],[10310,10369,"this is going to sound"],[10369,10472,"completely out of nowhere,"],[10472,10543,"but I just bought this"],[10543,10756,"new big mansion down the street,"],[10756,10872,"and it's like the one"],[10872,11044,"that we always used to talk about."],[11277,11327,"What do you say we"],[11327,11453,"give it another shot, huh?"],[11473,11557,"You and me?"]],"15":[[58,104,"What do you say we"],[104,258,"give it another shot?"],[258,396,"You and me?"],[396,529,"Seriously?"],[529,608,"Yeah."],[709,938,"You abandoned me five years ago."],[938,1063,"Oh my God."],[1063,1146,"And I'm married now,"],[1146,1206,"so you know what?"],[1206,1341,"You can get lost, Adam."],[1430,1559,"Oh, you're married now, huh?"],[1559,1622,"Yeah."],[1622,1730,"Really?"],[1730,1964,"Who would marry you knowing your past?"],[1964,2043,"Jason,"],[2118,2223,"I need you to find out everything"],[2223,2356,"about Alison's past."],[2356,2473,"Tell me."],[2473,2573,"I would."],[2573,2681,"Jesus Christ."],[2681,2756,"Let's go."],[2857,2944,"Hey. Hey."],[2944,3073,"Not so fast."],[3178,3399,"You know, I own part of this restaurant, right?"],[3486,3712,"And I say that you two"],[3712,3903,"aren't welcome to eat here."],[3903,4016,"So take a hike."],[4016,4129,"Very sorry, sir,"],[4129,4211,"but I'm afraid I have to"],[4211,4329,"ask you to leave."],[4533,4621,"Let's just go."],[4621,4725,"It's Robert Johnsons."],[4763,4904,"I need to speak to the manager."],[4904,4971,"Now."],[5034,5230,"Wow. Tough guy. Picks up his phone."],[5338,5463,"Who's that? You call your mom?"],[5613,5714,"Mr. Johnsons,"],[5714,5797,"I'm so sorry."],[5797,5935,"Please. Right this way."],[5951,6018,"Thank you."],[6018,6097,"What, are you kidding me?"],[6097,6247,"You're going to let them in?"],[6247,6406,"Well, then. Fine. Give me the table."],[6406,6527,"Sorry, sir, we can't let you in."]],"16":[[20,158,"So Robert,"],[283,450,"I heard you got married."],[646,740,"When am I going to meet"],[740,921,"my daughter-in-law?"],[992,1105,"Soon, Mom."],[1141,1251,"I promise."],[1343,1509,"This just..."],[1509,1668,"all happened really fast."],[1668,1876,"Oh, that's all right, dear."],[1876,2027,"Take your time."],[2085,2323,"But don't keep me waiting too long."],[2460,2531,"I won't."],[2673,2790,"I gotta run."],[2790,2940,"I'll talk to you later. Okay?"],[5488,5634,"What are you doing?"],[5634,5793,"Making us dinner."],[6164,6277,"Bon appétit."],[6439,6556,"So sweet."],[6556,6648,"Thank you."],[6673,6790,"You're very welcome."],[7098,7269,"You don't like mushrooms?"],[7269,7403,"Not really my thing."],[8053,8137,"Oh my God, Robert!"]],"17":[[0,150,"Oh my God, Robert."],[150,204,"What?"],[204,342,"I got the job."],[354,433,"Oh my gosh."],[433,542,"Congratulations."],[592,742,"I'm so proud of you."],[842,980,"How about I take you out tomorrow night"],[980,1188,"after your medical screening to celebrate?"],[1222,1380,"That would be great."],[2118,2260,"Meg, what are you doing here?"],[2260,2364,"I have the day off,"],[2364,2498,"so I thought, why not spend it"],[2498,2665,"with my best friend."],[2665,2748,"I can accompany you"],[2748,2836,"to your medical exam"],[2836,2932,"if you want."],[2932,3040,"Oh, um..."],[3094,3161,"That's fine."],[3161,3357,"I'll just catch up with you later."],[3357,3440,"Okay, great."],[4266,4379,"Alison Miller."],[4491,4546,"It's okay."],[4546,4633,"I got it."],[4842,4992,"Here are the results of your medical exam."],[4992,5092,"Thank you."],[6744,6873,"Here you go, Alison."],[6873,7044,"Everything's perfect."],[7044,7144,"Great."],[7307,7499,"Alison."],[7499,7624,"I know you and Robert"],[7624,7820,"are getting close,"],[7853,8083,"but I think that you should not"],[8083,8304,"tell him about the memory loss."],[8304,8437,"At least not yet."],[8500,8537,"Why not?"],[8537,8700,"I really don't want to lie to him."],[8821,9004,"I just don't want you getting hurt."],[9004,9116,"You know, people can be so"],[9116,9300,"judgmental about these things, so..."],[9409,9572,"I just want you to be careful."],[9601,9680,"All right?"],[9793,9864,"Okay."]],"18":[[95,283,"Well, it's like I didn't even eat."],[283,362,"What a pleasure"],[362,542,"to have you dine with us tonight."],[542,684,"We prepared a special dish"],[684,834,"just for you."],[834,971,"And of course, we've reserved the"],[971,1142,"presidential suite for you tonight."],[1142,1259,"I've arranged"],[1259,1413,"a lot of company events here."],[1413,1455,"That's"],[1455,1643,"why they're being so accommodating."],[1747,1851,"Try it."],[1851,1951,"I bet it's good."],[2598,2744,"Wow."],[2932,3090,"Well, they've gone"],[3090,3219,"through the trouble."],[3219,3374,"Might as well enjoy it."],[3636,3870,"I'm going to take a quick shower."],[3870,4016,"Make yourself at home."],[9367,9459,"Alison?"]],"19":[[12,162,"Alison?"],[162,350,"Robert, stop!"],[721,804,"I'm afraid I might"],[804,955,"do something inappropriate."],[1084,1148,"Good night."],[1555,1793,"Inappropriate?"],[1793,1993,"Mrs. Johnson, are you having impure"],[1993,2198,"thoughts about your husband?"],[3345,3486,"I want you, Alison."],[3549,3682,"I've always wanted you."],[4571,4729,"Robert, we shouldn't."]],"20":[[196,333,"What are you doing here?"],[333,550,"I couldn't wait any longer."],[717,825,"Well, aren't you going"],[825,1005,"to introduce me?"],[1434,1551,"Nice to meet you."],[1551,1685,"Call me Sheila."],[1851,2027,"Or better yet,"],[2027,2277,"call me Aunt Sheila."],[2585,2740,"I have something for you."],[2961,3119,"It's a family heirloom."],[3403,3603,"Oh. It's beautiful."],[3716,3912,"I couldn't possibly accept it."],[3912,4016,"Nonsense."],[4058,4216,"It's a tradition for the women"],[4216,4366,"in our family to pass it down."],[4366,4491,"I want you to have it."],[5455,5638,"You know what?"],[5638,5714,"Why don't you"],[5714,5847,"keep it safe for me?"],[5901,6035,"I would hate for something to happen"],[6035,6193,"to such a precious heirloom."],[6664,6748,"All right, well."],[6748,6915,"I should get ready for work."],[6915,7086,"So nice to meet you, Aunt Sheila."],[7086,7232,"Nice to meet you, too."],[8024,8133,"Well."],[8358,8641,"She's not like the others, is she?"],[8717,8821,"Not interested"],[8821,8979,"in material things."],[9096,9280,"She's special, Mom."],[9338,9463,"I never met anyone like her."],[9580,9663,"When are you going to tell"],[9663,9889,"her who you really are, Robert?"]],"21":[[4,62,"When are you going to"],[62,354,"tell her who you really are, Robert?"],[517,700,"I'll tell her the truth"],[700,796,"when I know for sure"],[796,971,"that she loves me for who I am."],[1021,1213,"Not for my wealth or status."],[1547,1676,"I need you to make 50 copies"],[1676,1755,"and have them stapled"],[1755,1926,"and collated within the hour."],[1926,2064,"Sure. Yeah, I'll get right on that."],[2377,2540,"Do you believe the incompetence?"],[2565,2644,"I don't know why they hire"],[2644,2761,"these entry-level nobodies."],[2827,2952,"You are so right, June."],[2952,3115,"You should be running this place."],[3199,3249,"Exactly."],[4270,4333,"Hey."],[4416,4500,"Hey."],[4567,4738,"I saw what happened out there."],[4738,4859,"June can be really tough."],[4934,5016,"I'm trying my best"],[5016,5106,"but nothing seems to be"],[5106,5192,"good enough for her."],[5217,5338,"Listen, I know it's tough,"],[5338,5538,"but you just have to bear it."],[5663,5726,"Rumor has it"],[5726,6010,"June is the CEO's fiancée."],[6010,6139,"They've been together for six years."]],"22":[[16,141,"Rumor has it June is"],[141,321,"the CEO's fiancée."],[349,527,"They've been together for six years."],[625,754,"The CEO?"],[838,913,"No wonder everyone's"],[913,1030,"sucking up to her."],[1564,1714,"Jesus Christ."],[2456,2598,"Where have you been, Alison?"],[2598,2665,"Can't leave work"],[2665,2773,"without my permission."],[2773,2827,"No, I didn't."],[2827,2948,"I was just doing my job."],[2948,3148,"I don't care. You took too long."],[3148,3236,"I'm writing you up for"],[3236,3407,"an unauthorized absence."],[3407,3507,"June, that's not fair."],[3507,3624,"I've just completed every task-"],[3624,3803,"I don't want to hear your excuses."],[3803,3941,"Pack up your things."],[4033,4141,"You're fired."],[4266,4333,"No."],[4416,4483,"I can do this."],[4483,4621,"Give me a chance, okay?"],[4621,4688,"All you've given me"],[4688,4808,"is menial tasks."],[4808,4867,"Fine."],[4917,5092,"If you think you're so capable,"],[5092,5146,"prove it."],[5209,5301,"Land the big client"],[5301,5401,"we've been pursuing,"],[5401,5488,"and I'll consider letting"],[5488,5618,"you keep this job."],[6790,6848,"Oh, no."]],"23":[[684,955,"Robert, did you do this?"],[955,1046,"No."],[1146,1284,"This must have been Aunt Sheila."],[2068,2181,"Cheers to her."],[9242,9342,"Alison."],[9409,9513,"I hope you're making progress"],[9513,9601,"with the client."],[9672,9751,"Remember,"],[9751,9864,"if you can't seal the deal,"],[9909,10060,"don't bother coming back."],[10060,10172,"I'm going to close this deal, June."],[10172,10301,"You can count on it."],[10406,10506,"Sure you are."],[10652,10744,"Adam."],[10823,10877,"How am I supposed to"],[10877,10998,"face him after everything"],[10998,11169,"that's happened between us?"],[11169,11257,"What if he refuses"],[11257,11348,"to sign a contract?"]],"24":[[0,304,"Cheers. 22. Rebecca, pretty fucking crazy."],[304,487,"Have any birthday wishes?"],[613,750,"Adam."],[750,825,"Can we talk about"],[825,950,"the business proposal?"],[950,1172,"Oh my God. Look who it is."],[1255,1338,"Yeah, we can talk business"],[1338,1480,"if you want, but"],[1480,1564,"I don't know."],[1564,1647,"Why don't we make it"],[1647,1785,"a little more fun, right?"],[2081,2227,"What do you mean?"],[2494,2702,"I was thinking,"],[2702,2827,"if you win,"],[2827,2994,"I'll sign your little contract."],[3069,3307,"But if I win,"],[3307,3478,"I think"],[3478,3541,"we're going to have to be"],[3541,3628,"a little more private"],[3628,3762,"for me to explain that."],[3983,4045,"Fine."],[4129,4233,"What's the game?"],[4429,4529,"Whoo!"],[4667,4767,"Looks like I win."],[4838,4950,"Now about the contract."],[4984,5163,"You think you're pretty cool, huh?"],[5292,5401,"I know what you really want."],[5401,5480,"Stop, Adam."],[5480,5634,"That's not part of the deal."],[5634,5689,"You know what, maybe"],[5689,5834,"I don't care what the deal is."],[5834,6101,"Stop! Adam, get off of me!"],[6101,6206,"Get off of me!"],[6206,6297,"Get your hands off"],[6297,6385,"of her, you bastard!"]],"25":[[16,108,"Get your hands off"],[108,241,"of her, you bastard!"],[504,650,"Who is that gorgeous guy?"],[650,809,"I've never seen him before."],[809,996,"Is that Robert Johnsons?"],[996,1180,"What is he doing here?"],[1180,1263,"And what's his connection"],[1263,1368,"with Alison?"],[1368,1534,"Are they together?"],[1534,1668,"This is my bar."],[1739,1906,"Why don't you just get the fuck out?"],[1993,2369,"Oh, Mr. big tough businessman."],[2369,2540,"What you gonna do, huh?"],[2540,2706,"You gonna hit me?"],[2986,3123,"You're not gonna do shit."],[3970,4120,"This ain't fucking over."],[4304,4425,"Fuck you guys!"],[4633,4750,"Alison, are you okay?"],[4788,4904,"Sorry I didn't get here sooner."],[4904,5025,"No, thank you."],[5025,5238,"But what if he tries to retaliate?"],[5238,5280,"What if he tries"],[5280,5518,"to get you fired or something?"],[5518,5613,"I wish him luck."],[5722,5864,"All that matters is that you're safe."]],"26":[[796,884,"June."],[988,1021,"Listen."],[1096,1255,"The deal with MJ Group is off."],[1388,1451,"I don't give a shit"],[1451,1597,"what you have to do, alright?"],[1626,1777,"Just make sure that"],[1777,2060,"that bitch Alison pays for it."],[2744,2819,"Hey."],[2882,2957,"What the hell happened"],[2957,3032,"to your face?"],[3090,3290,"It was that fucking loser Johnsons."],[3290,3382,"Hey."],[3382,3557,"You mean the CEO of the MJ Group?"],[3557,3641,"Yeah, Dad."],[3641,3824,"Listen, he's gonna regret it, alright?"],[3824,3895,"I swear to God."],[3958,4120,"Him and that stupid bitch wife of his."],[4120,4241,"Well, what happened?"],[4241,4350,"I just told you."],[4350,4521,"He hit me in the face, and it hurts, alright?"]],"27":[[145,375,"The moment the stock market opened,"],[375,483,"Rodriguez's assets"],[483,617,"took a pretty huge hit."],[717,875,"They lost over $4 billion."],[1142,1276,"I suppose they'll be paying us"],[1276,1388,"a visit soon."],[1534,1593,"They're here."],[2022,2152,"Mr. Rodriguez."],[2198,2252,"The reason"],[2252,2419,"your assets took such a hit"],[2419,2606,"is because of your son, Adam."],[2648,2773,"Adam?"],[2773,2927,"What's he got to do with any of this?"],[2927,3044,"Last night, he attempted"],[3044,3157,"to assault my wife,"],[3199,3378,"and he's been harassing her at work."],[3432,3528,"You're serious?"],[3653,3745,"Is this true?"],[3795,3916,"You assaulted his wife?"],[3916,4124,"We were just fucking dancing, alright?"],[4162,4279,"No one"],[4279,4404,"will threaten or harm"],[4404,4587,"my wife without consequence."],[4587,4742,"How could you do this? Look."],[4742,4871,"Look at the mess you caused."],[4913,5116,"You know, you will apologize"],[5116,5330,"to Mrs. Johnsons and ask her forgiveness."],[5330,5392,"Immediately!"],[5392,5524,"Let this serve as a reminder"],[5524,5686,"to you, Mr. Rodriguez."],[5805,5976,"The Johnsons protect their own."],[6093,6227,"I'll handle this, Robert."],[6277,6393,"You have my word."],[7578,7724,"Dancing with her?"],[7841,7962,"$4 billion worth of dancing."]],"28":[[792,913,"Robert."],[1080,1151,"Can I sleep in"],[1151,1297,"your room tonight?"],[1626,1735,"Of course."],[5405,5572,"Robert."],[5739,5818,"Is there a reason"],[5818,6068,"you haven't... I mean..."],[6168,6410,"Is there a reason you don't want to..."],[6539,6840,"It's not that I don't want to."],[6969,7044,"I just didn't want to"],[7044,7148,"pressure you into anything."],[8425,8579,"I'm ready, Robert."],[8992,9192,"I want you in every way."],[12504,12737,"That was incredible."],[12858,13033,"You're incredible."],[13192,13350,"I love you so much."],[13538,13713,"I love you too."],[13780,13980,"More than I ever thought possible."]],"29":[[196,312,"Robert."],[312,417,"I found some information"],[417,571,"about Alison's past."],[629,930,"It's not good."],[1626,1730,"She had a child?"],[1797,1893,"According to the records,"],[1893,2056,"she gave birth during college."],[2131,2344,"Her boyfriend at the time was"],[2439,2569,"Adam Rodriguez."],[2715,2857,"After Adam abandoned her,"],[2857,3057,"she suffered from severe depression."],[3103,3299,"She even dropped out of college."],[4141,4208,"I heard you failed"],[4208,4283,"to secure the deal"],[4283,4404,"with Mr. Rodriguez."],[4441,4537,"You're fired."],[4537,4704,"Effective immediately."],[5180,5259,"May we speak with"],[5259,5363,"Miss Alison Miller?"]],"30":[[37,120,"May we speak with"],[120,258,"Miss Alison Miller?"],[258,429,"I'm Alison."],[429,538,"Oh, Miss Miller."],[646,845,"I want to extend my most sincere apology"],[845,1105,"for my son's inappropriate behavior."],[1180,1256,"What he did to you"],[1256,1413,"was totally unacceptable."],[1413,1505,"I want to assure you that"],[1505,1685,"it will never happen again."],[2631,2777,"Please accept this gift"],[2777,3011,"as a token of our regret."],[3244,3407,"Mr. Rodriguez, I..."],[3407,3536,"I don't know what to say."],[3536,3624,"You don't have to say anything,"],[3624,3691,"Miss Miller."],[3732,3820,"Just know that you have"],[3820,3895,"the full support"],[3895,4045,"of the Rodriguez family."],[6068,6177,"Look at you, brother."],[6177,6322,"Head over heels in love."],[6393,6480,"That's a far cry"],[6480,6623,"from your Playboy days."],[6681,6861,"Those days are long gone, Peter."],[6981,7194,"Alison's the only woman I want."],[7494,7557,"Hey, did you ever"],[7557,7686,"think about that one night stand"],[7686,7811,"you had five years ago?"],[7899,8003,"At the Crown Hotel?"],[8078,8199,"Vaguely."],[8262,8416,"I was so drunk that night."],[8500,8671,"I don't even remember her name."],[8671,8896,"I mean, aren't you curious?"],[8963,9088,"What if she was someone important?"],[9380,9451,"You know what?"],[9567,9634,"I am curious."]],"31":[[20,229,"You know, Alison, believe it or not,"],[229,300,"I was taller than"],[300,404,"Robert at one point."],[404,462,"Oh."],[462,546,"Really?"],[596,675,"Robert, darling."],[675,838,"What a surprise to see you here."],[934,1059,"She knew you were here"],[1059,1155,"and insisted on coming."],[1155,1272,"Alison, dear."],[1272,1401,"Did you know that Robert and I"],[1401,1518,"used to date?"],[1551,1626,"We were quite the couple"],[1626,1697,"back in the day."],[1697,1835,"June, that was a long time ago."],[1881,1968,"Things have changed."],[1968,2068,"Of course."],[2068,2164,"I just thought Alison"],[2164,2281,"should know about our history."],[2431,2535,"June."],[2535,2640,"Maybe we should get out of here?"],[2744,2831,"Robert and Alison are trying"],[2831,2969,"to enjoy their evening."],[3424,3570,"What the hell was that?"],[3570,3657,"Are you trying to ruin"],[3657,3774,"Robert and Alison's marriage?"],[3820,3916,"Oh, please."],[3937,4020,"She deserves to know the truth"],[4020,4133,"about her little husband."],[4133,4216,"The truth?"],[4266,4337,"You mean, like how"],[4337,4404,"you dumped Robert"],[4404,4458,"because he wasn't"],[4458,4512,"good enough for you?"],[4683,4790,"You had no idea he was"],[4790,4925,"CEO of the company, did you?"],[5055,5130,"You were too busy"],[5130,5276,"chasing some rich executive,"],[5276,5426,"trying to find something better."],[5580,5693,"But Robert was the exec"],[5693,5780,"the whole time."],[5818,5980,"You don't deserve Robert, June."],[6093,6168,"You never did."]],"32":[[56,146,"It's good."],[260,383,"My favorite restaurant."],[386,463,"Yeah?"],[496,570,"Bob?"],[573,683,"Bob Johnson?"],[873,943,"Must be someone"],[943,1036,"with a similar name."],[1073,1150,"Let's go."],[2710,2813,"Checkmate."],[2813,2883,"No."],[2883,2956,"Yes."],[3170,3303,"Every time you win."],[3306,3516,"Every single time."],[3516,3693,"Oh, years of practice."],[3776,3880,"You wanna play again?"],[3896,4016,"Uhh, yes."],[4076,4246,"Can you set up? I need water."],[4246,4353,"Yes."],[4356,4483,"Okay, but you're not"],[4486,4623,"going to win this time."],[4623,4796,"Well, you are making it harder."],[4796,5063,"All right, well, that's good at least."],[5066,5223,"Oh, no."],[5450,5750,"The sink is full of water,"],[5750,5926,"and it's not going down."],[5930,6023,"Really?"],[6023,6183,"It's like a bathtub in there."],[6313,6380,"Okay, that's okay."],[6380,6470,"I'll just call maintenance"],[6470,6636,"to let the owner know."],[7103,7286,"Hi, this is Alison Miller."],[7286,7460,"At 1334 Alta."],[7566,7600,"Yeah."],[7600,7800,"Our sink is not sinking."],[7800,7950,"So I was hoping you could"],[7950,8090,"let the owner know."],[8213,8513,"Oh, okay,"],[8826,8860,"Meg,"],[8860,8936,"they just let me know that"],[8940,9100,"the owner is Robert Johnsons."]],"33":[[53,90,"Meg,"],[90,166,"they just let me know that"],[170,360,"the owner is Robert Johnsons."],[493,553,"What?"],[756,910,"I thought he said"],[910,1100,"he only rents this place."],[1103,1226,"Yeah, that's what he told me."],[1226,1376,"Why would he lie about that?"],[2113,2200,"Hello?"],[2466,2566,"Wait, really?"],[2566,2693,"Oh, my God."],[2760,2820,"Wait, seriously."],[2820,2990,"This means, like, so much to me."],[3096,3236,"Yeah, yeah, yeah, thank you."],[3236,3343,"Thank you again."],[3346,3453,"Bye."],[3623,3780,"What is it? What happened?"],[3780,3930,"I got approved."],[3976,4033,"For?"],[4080,4266,"I'm adopting Sarah."],[4270,4456,"Oh, my God."],[4646,4723,"Oh, my God."],[4726,4843,"I can't believe it's happening."],[4843,4960,"I'm so happy for you."]],"34":[[1290,1493,"What do you want, June?"],[1493,1586,"I have some information"],[1590,1696,"that may be of interest to you"],[1700,1856,"and Mr. Johnsons."],[1946,2023,"What kind of information"],[2023,2090,"you got?"],[2123,2276,"The kind that could ruin Alison Miller's"],[2280,2420,"perfect little life."],[2420,2523,"Maybe give you the leverage"],[2526,2713,"you need to get back at Robert."],[3383,3533,"I'm listening."],[4273,4416,"Listen up, hot shot."],[4420,4523,"I got some information"],[4523,4710,"that you might be interested in."],[4710,4970,"And it's kinda do with your new wife."],[4973,5016,"Don't worry."],[5020,5190,"I'll make it easy for you, all right?"],[5190,5373,"You give me $50 million,"],[5373,5560,"and I'll make sure that"],[5560,5783,"her little secret stays safe with me."],[5970,6076,"What secret?"],[6130,6370,"Have a look for yourself, but"],[6370,6506,"looks like she might have had a kid"],[6506,6626,"in college."],[6736,6943,"Yeah, I got copies of that, too."],[6946,7163,"So, if you need more..."],[7236,7423,"Think about it, buddy."],[8090,8256,"Jason,"],[8256,8350,"I need you to transfer"],[8353,8490,"$50 million into"],[8490,8700,"Adam Rodriguez's account."],[8703,8770,"Immediately."]],"35":[[296,350,"Hey."],[496,606,"Robert,"],[610,716,"why did you lie to me"],[720,776,"and tell me that you"],[776,853,"rented this place"],[856,1000,"when you actually own it?"],[1780,1850,"Look, I'm"],[1970,2073,"really sorry I haven't been"],[2073,2256,"completely honest with you."],[2370,2476,"I originally bought the house"],[2480,2596,"for myself,"],[2786,2953,"but with you, it's become a home."],[3076,3153,"A home that I want to"],[3153,3290,"share with you forever."],[3666,3833,"I don't know what to say."],[4290,4560,"I know we've been through a lot,"],[4673,4766,"and I'm sorry"],[4770,4940,"there are parts of my past"],[4940,5113,"that I've kept from you."],[5253,5396,"But trust me,"],[5400,5543,"when I say that I love you"],[5606,5826,"and that all I want is what's best for you."],[6830,6928,"I'm sorry."],[7293,7375,"What?"],[7643,7786,"I thought it was all settled."],[7976,8066,"Well, no."],[8066,8226,"I'll handle it."],[8406,8533,"Wait, what is it?"],[8663,8850,"That was Jason."],[8853,8910,"There's a problem"],[8910,9027,"with Sarah's adoption."],[9266,9383,"Her foster mom doesn't want"],[9383,9500,"to give the approval."],[9560,9696,"Wait, what do you mean? I thought"],[9696,9813,"everything was settled."],[9816,9906,"What are we going to do?"]],"36":[[60,160,"Don't worry."],[160,236,"I won't let anything stand"],[240,440,"in the way of you adopting Sarah."],[440,530,"I promise."],[1166,1276,"Do we have a deal?"],[1520,1696,"All you have to do"],[1700,1876,"is sign away your rights."],[1880,1946,"And Sarah gets the"],[1946,2080,"loving home she deserves."],[2213,2353,"She's all yours."],[2836,3046,"Just make sure this check clears."],[4273,4496,"They adopt this kid together."],[4496,4686,"It'll ruin everything."],[4690,4760,"I won't let her"],[4760,4896,"take Robert away from me."]],"37":[[190,316,"Doctor."],[320,423,"My wife's been in a car accident."],[423,523,"Alison Miller."],[523,600,"Where is she?"],[603,673,"She's being prepped"],[673,866,"for surgery, Mr. Johnsons."],[870,976,"We have our best team"],[976,1050,"working on her."],[1786,1906,"Alison."],[2000,2120,"My love."],[2246,2413,"I know you can hear me."],[2546,2773,"I need you to fight"],[2776,2939,"to come back to me."],[3070,3193,"I can't imagine my life"],[3196,3296,"without you."],[3296,3573,"Well, isn't this sweet?"],[3576,3713,"A devoted husband keeping"],[3713,3920,"vigil by his wife's side."],[3963,4023,"Who are you?"]],"38":[[36,106,"I'm the one you should"],[106,243,"be with, Robert,"],[273,406,"not her."],[430,653,"After all, you did sleep with me"],[656,773,"five years ago."],[1076,1266,"Marry me, Robert,"],[1270,1376,"or I will tell everyone"],[1376,1520,"about our tryst."],[1523,1610,"Enough."],[1610,1686,"Leave now, before"],[1690,1780,"I have security called"],[1783,1890,"and you're thrown out."],[3783,3936,"Robert,"],[4013,4190,"you two have similar eyes."],[4486,4603,"Actually,"],[4710,4976,"the resemblance is quite remarkable."],[5800,5936,"I have some news"],[5936,6186,"about Alison's condition."],[6186,6313,"The accident caused"],[6316,6516,"significant trauma to her abdomen,"],[6516,6703,"and I'm afraid"],[6703,6836,"it's unlikely she'll be able"],[6836,7076,"to have children in the future."],[7150,7283,"I'm sorry."],[8050,8203,"Let's go over here."],[8453,8663,"Alison, can you hear me?"]],"39":[[23,100,"Alison,"],[103,170,"can you hear me?"],[410,476,"You."],[540,626,"You need to divorce him."],[693,813,"He's supposed to be with me."],[986,1120,"When are we getting married, Robert?"],[1120,1206,"Never."],[1206,1280,"You psycho."],[1523,1613,"Our team just confirmed"],[1616,1710,"she was in her hometown"],[1713,1833,"five years ago."],[2116,2250,"Nice try, Sophia."],[2333,2420,"I was just informed you were"],[2420,2593,"in your hometown five years ago."],[2596,2770,"Not at the Crown Hotel."],[2770,2826,"This whole thing was"],[2830,2936,"a poorly executed scam."],[2936,3040,"I know what you're talking about."],[3043,3143,"Get out."],[3143,3320,"Or I'll have you arrested for fraud"],[3320,3423,"and extortion."],[3983,4106,"Stupid bitch!"],[4110,4293,"Couldn't handle one simple task?"],[4413,4480,"I'm sorry, June."],[4480,4533,"I tried to-"],[4536,4643,"Get out of my face before"],[4643,4780,"I make you regret it for crossing me."],[5773,5850,"What does this mean?"],[5853,6103,"Difficulty conceiving in the future?"],[6103,6186,"It appears that"],[6186,6360,"you suffered some damage"],[6363,6633,"during a previous childbirth."],[6633,6760,"It may make it harder"],[6763,6920,"for you to get pregnant again."],[7030,7120,"No, I-"],[7163,7330,"I've never given birth before."],[7330,7423,"You're mistaken."]],"40":[[123,316,"Alison, there's something"],[320,593,"that I should have told you."],[593,936,"You did give birth, Alison,"],[940,1210,"five years ago,"],[1210,1386,"to a baby girl."],[1623,1806,"A little girl?"],[1956,2010,"Where is she?"],[2013,2166,"What happened to her?"],[2330,2520,"We put her up for adoption."],[2600,2736,"Your mom"],[2736,2810,"thought that it would"],[2813,2980,"be for the best."],[3086,3236,"Wait, you guys gave her away"],[3236,3420,"without telling me?"],[3806,3883,"I'm going to find her."],[3883,4033,"I'm going to bring her home."],[4310,4420,"Alison,"],[4423,4580,"I think that you should consider"],[4580,4806,"how this might affect Robert"],[4810,4946,"and your marriage."],[5073,5206,"Why should Robert have to bear the"],[5206,5356,"burden of my past?"],[5466,5629,"No, it's not fair to him."],[5900,6103,"I think we should get a divorce."],[7020,7106,"Robert."],[7650,7706,"There's something"],[7710,7943,"I need to tell you, and it's-"],[8126,8350,"It's going to change everything."],[8603,8743,"Okay,"],[8823,9123,"well, whatever it is,"],[9126,9336,"we'll face it together."],[9340,9573,"I love you. No matter what."],[9963,10112,"I have a daughter."],[10203,10363,"Robert."],[10366,10536,"A little girl"],[10536,10746,"that I gave birth to five years ago."]],"41":[[276,553,"I didn't know about her until now."],[556,700,"My family, they-"],[873,1130,"They gave her away without telling me."],[1340,1600,"I'm going to find her,"],[1603,1653,"Robert."],[1653,1813,"I'm going to bring her home."],[2016,2350,"And if you can't handle that, then..."],[2500,2700,"I think we should get a divorce."],[3036,3196,"Alison,"],[3433,3623,"I made a vow"],[3626,3863,"to stand by you no matter what."],[3980,4056,"If finding your daughter"],[4060,4253,"is what you need to do,"],[4306,4500,"then I'll be right by your side."],[4720,4850,"No, you don't have to do that."],[4853,5023,"This is just a contract marriage."],[5023,5100,"I do."],[5193,5403,"I see a future"],[5406,5566,"where we raised Sarah"],[5570,5840,"and your daughter together."],[5840,6110,"Where we grow old side by side."],[6113,6350,"I want that more than anything."],[6463,6563,"I want that too."]],"42":[[660,783,"Alison."],[786,1013,"Hi. It's so good to see you."],[1073,1206,"Sarah and I were just having"],[1206,1306,"a little playtime."],[1306,1383,"I see that."],[1386,1486,"Looks like you guys are having"],[1486,1586,"a great time."],[1683,1906,"You know, I was thinking,"],[1950,2043,"if you and Robert"],[2046,2173,"have children of your own,"],[2173,2230,"do you think that"],[2233,2450,"you still have time for Sarah?"],[2596,2736,"It appears that you suffered"],[2736,2853,"some damage"],[2853,3063,"during a previous childbirth."],[3066,3193,"It may make it harder"],[3196,3390,"for you to get pregnant again."],[3606,3760,"Actually,"],[3760,3886,"Alison and I may not be able"],[3890,4123,"to have children of our own."],[4123,4283,"What do you mean, dear?"],[4286,4643,"I had some medical tests done and..."],[4643,4843,"I can't father children."],[5010,5136,"I can't believe"],[5140,5356,"that you didn't tell me about this."],[5356,5580,"But is it true?"],[5643,5910,"It's okay, Aunt Sheila."],[5913,6063,"Sarah's more than enough for us."]],"43":[[230,433,"I just can't believe it."],[506,639,"You're infertile."],[910,976,"I just can't"],[976,1246,"wrap my mind around this."],[1286,1443,"Robert, you've always"],[1443,1710,"wanted children of your own."],[1713,1906,"I know, Aunt Sheila, but"],[1906,2123,"he's been handling it really well."],[2170,2270,"Well,"],[2356,2603,"that's my Robert."],[3330,3630,"Robert, about the medical report."],[3763,3963,"Are you really infertile?"],[4080,4230,"Yeah."],[4230,4400,"The doctor confirmed."],[4510,4570,"It just seems like"],[4573,4816,"such a coincidence, doesn't it?"],[4890,4956,"Especially when"],[4956,5350,"I'm dealing with my own issues."],[5486,5653,"It does seem strange, right?"],[6106,6346,"But life works in mysterious ways."],[6440,6546,"Maybe this is the universe's"],[6550,6640,"way of telling us that"],[6640,6776,"we are meant for each other."],[7433,7666,"Yeah, you're right."],[7666,7850,"We have each other."],[7850,8060,"We have Sarah."],[8240,8433,"We don't need anything else."],[9370,9603,"Mommy, Daddy, I'm hungry."],[10050,10140,"I guess we should go."]],"44":[[6,190,"-Catch me. -I'm the broccoli boy."],[190,300,"I'm going to go after you."],[303,373,"Oh, no."],[373,513,"And it eats you."],[590,722,"Okay."],[886,1063,"This looks amazing."],[1133,1256,"I wanted to make something special"],[1256,1396,"for my two favorite people."],[2106,2170,"Sarah?"],[2253,2356,"Sarah, are you okay?"],[2490,2590,"Mushrooms."],[2693,2810,"I'm allergic."],[2846,2973,"Hold on, I have medicine."],[3033,3156,"Maybe we should go to the hospital."],[3160,3213,"No, no."],[3250,3376,"Hey, honey, are you okay?"],[3443,3553,"You're gonna take this pill"],[3556,3726,"with a little bit of water, okay?"],[3730,3870,"Here we go."],[4060,4166,"Good."],[4373,4490,"Oh, God. I'm so sorry, Sarah."],[4490,4600,"I had no idea."],[4603,4773,"No, it's okay, Alison."],[4773,4890,"You couldn't have known."],[4940,5040,"She's safe now."],[5306,5406,"You don't like mushrooms?"],[5503,5603,"Not really my thing."],[5913,6040,"Feeling better?"],[6066,6120,"Yeah."],[6233,6366,"Okay. Good."]],"45":[[843,1013,"Alison Miller."],[1016,1226,"I never thought I'd see you again."],[1600,1653,"I know you were"],[1653,1790,"never my biggest fan,"],[1790,1966,"but I truly believe that Robert and I"],[1970,2090,"were meant to be together."],[2090,2183,"Oh, June."],[2186,2473,"Let's cut to the chase, shall we?"],[2480,2570,"I never thought"],[2570,2826,"that you were right for Robert."],[2830,2873,"Sure."],[2876,3086,"He was infatuated with you once,"],[3086,3290,"but based on my observations,"],[3293,3346,"you don't have"],[3346,3516,"nearly the amount of talent"],[3516,3716,"that you thought you once had."],[3716,3876,"How can you say that?"],[3880,3953,"Robert loved me"],[3956,4116,"for my skills and creativity."],[4120,4296,"I'm warning you, June."],[4296,4613,"Do not mess with this marriage."],[4643,4893,"Especially now that Robert has found"],[4893,5000,"true love."],[5003,5196,"You think Alison is so perfect?"],[5200,5390,"Well, let me tell you something, Sheila."],[5390,5573,"Your precious Alison"],[5573,5633,"has been hiding"],[5636,5763,"something from all of you."],[5766,5923,"What are you talking about?"],[5923,6246,"Alison gave birth to a child years ago."],[6250,6376,"Before she met Robert."],[6380,6473,"And now she's been told"],[6473,6676,"she can't have any more kids."],[6680,6836,"How do you think Robert will feel"],[6836,6956,"when he finds out his perfect"],[6960,7116,"wife has been lying to him?"]],"46":[[43,283,"Robert, how could you"],[286,490,"give up your chance to have children"],[490,766,"on your own, all for Alison?"],[770,1013,"You faked that fertility test too,"],[1016,1086,"didn't you?"],[1183,1460,"Mom, Alison is my wife."],[1460,1563,"I love her."],[1566,1710,"I've made my choice."],[1713,1900,"And Sarah is our daughter."],[1900,1986,"That's all that matters."],[1986,2210,"What about your future?"],[2213,2520,"What about your legacy?"],[3433,3550,"Alison."],[5183,5320,"Come on, Alison. Pick up."],[5940,6076,"Something's wrong."],[6080,6170,"She should have been home by now."]],"47":[[756,848,"God."],[1746,1853,"Hello, Alison."],[2050,2170,"Remember me?"],[2250,2436,"The man you were supposed to marry."],[2650,2753,"What are you talking about?"],[2753,2846,"I don't know who you are."],[2850,3086,"You're a liar, Alison."],[3220,3320,"You're meant to be mine."],[3320,3470,"And then you betrayed me."],[3543,3650,"Ran off"],[3716,3950,"with that rich pretty boy."],[4203,4260,"I don't know what you're"],[4260,4320,"talking about."],[4323,4460,"Let me go!"],[4926,5243,"Oh. You're not going anywhere."],[5460,5760,"Because you-"],[5770,6040,"you're going to be my new wife."],[6040,6150,"Jason, do something."],[6153,6360,"She's still not answering."],[6363,6453,"I'll hack into the city"],[6453,6590,"surveillance system,"],[6590,6840,"see if I can track her movements."],[6843,7143,"Okay."],[7203,7336,"Hold on, Alison."],[7416,7600,"I'm coming for you."],[7680,7853,"You know,"],[7856,8066,"I've been watching you."],[8143,8330,"Seeing you play house"],[8330,8603,"with that rich bastard."],[8693,8843,"Well, it made me sick."],[8843,8963,"Wait."],[9250,9356,"You're Bob Johnson."],[9356,9416,"The guy"],[9573,9723,"who responded to my ad."]],"48":[[20,213,"Look, you don't have to do this, okay?"],[213,266,"We could-"],[320,436,"We could talk about it."],[436,506,"Find a solution."],[506,546,"No, no."],[546,833,"Talking is over."],[950,1126,"You're mine, Alison."],[1236,1363,"All mine."],[1453,1580,"And if I can't have you."],[1583,1703,"Well,"],[1846,2016,"I don't think anybody can."],[2333,2503,"Boss, I've got a name."],[2503,2646,"The man who took Alison."],[2650,2773,"It's Bob Johnson."],[2776,2943,"Bob Johnson?"],[2943,3033,"That's the guy Alison was supposed"],[3033,3133,"to marry from her ad."],[3510,3720,"You're so"],[3723,3890,"beautiful,"],[3963,4100,"Alison."],[4290,4423,"I've been waiting a long time"],[4423,4623,"for this moment."],[4960,5083,"And now"],[5236,5390,"I'm going to make you mine"],[5510,5616,"forever."],[5620,5870,"No, please stop."],[5966,6056,"Please."]],"49":[[6,290,"No, please stop."],[353,473,"Please."],[553,646,"Please."],[743,826,"That's enough, Bob."],[1066,1200,"Robert."],[2433,2510,"Are you okay?"],[2513,2623,"Did he hurt you?"],[2743,2863,"Robert, be careful."],[3333,3570,"Robert, stop!"],[4286,4496,"Alison, are you okay?"],[4496,4566,"It's okay."],[4570,4736,"I'm here. I'm here."],[4736,4910,"You are safe now."],[6570,6696,"Okay."],[6766,6890,"Robert."],[6893,7033,"What is this place?"],[7383,7676,"This is my home."],[7826,7933,"Our home."],[7983,8120,"Wait, I'm sorry."],[8123,8250,"I don't understand. I thought"],[8313,8490,"you were just an employee."],[8643,8946,"Yeah, I need to tell you the truth."],[9040,9200,"I'm not an employee"],[9203,9293,"at MJ Group."],[9493,9600,"I'm the CEO."],[9750,9920,"Wait, so you've been lying to me"],[9920,10020,"this whole time?"]],"50":[[40,176,"Alison, when I"],[176,450,"first saw you at the coffee shop,"],[453,670,"I was captivated."],[670,1030,"You were so beautiful, so special."],[1120,1286,"I fell for you instantly."],[1370,1556,"I wanted to tell you sooner."],[1556,1650,"I did."],[1653,1856,"But you sat down before"],[1856,1996,"I had the chance."],[2000,2146,"Why didn't you just trust me enough"],[2150,2303,"to tell me the truth?"],[2403,2586,"Because I was afraid."],[2736,2793,"I know."],[2796,2896,"I should have told you sooner."],[2896,3083,"And I am sorry for that."],[3220,3380,"I just wanted you to love me"],[3383,3543,"for who I am."],[3726,3833,"Robert."],[3943,4116,"I love you for your heart."],[4180,4390,"Not your bank account, okay?"],[4463,4583,"You should have known that."],[4710,4836,"I love you for everything"],[4840,4943,"that you are."],[4976,5133,"You're never gonna lose me."],[5190,5300,"Okay?"],[5933,6033,"Robert."],[6033,6140,"Alison,"],[6280,6520,"I am so happy that you're safe."],[6520,6673,"Aunt Sheila, I'm so happy you're here."],[6766,6906,"Yeah, a couple other things."],[7046,7390,"Sheila is my mom, not my aunt."],[7433,7690,"And Peter is my brother."],[7830,8040,"Well, I'm so happy to meet you guys"],[8043,8343,"as Robert's family."],[8356,8466,"Alison,"],[8526,8613,"I realize that"],[8613,8773,"you've been through a lot."],[9290,9516,"But we need to have a conversation"],[9520,9686,"about MJ Group."],[9936,10120,"With a company this large,"],[10120,10320,"it is essential"],[10320,10480,"that we have an heir."]],"51":[[670,820,"Robert, if you continue to"],[820,1036,"prioritize this marriage"],[1036,1160,"over your family,"],[1160,1420,"I simply cannot support it."],[1666,1860,"I cannot accept Alison"],[1863,2153,"as your wife."],[2646,2680,"Look,"],[2680,2920,"I understand where she's coming from."],[3020,3096,"I mean, she just wants"],[3100,3340,"what's best for you and the company."],[4160,4260,"Peter,"],[4340,4406,"I need you to start"],[4406,4490,"preparing to take over"],[4490,4696,"as the heir of the MJ Group."],[4710,4800,"What?"],[4810,4916,"Are you seriously giving up"],[4920,5030,"your birthright,"],[5033,5156,"your legacy,"],[5250,5310,"for Alison?"],[5310,5436,"She means everything to me."],[5570,5636,"I won't let anything"],[5636,5803,"come between us."],[5803,5936,"Not even the company."],[6003,6070,"I hope you know"],[6070,6236,"what you're doing, brother."],[6280,6416,"This is a huge sacrifice."],[6713,6746,"Okay."],[6746,6787,"We're going to have"],[6787,6976,"so much fun today."],[6980,7150,"Alison."],[7150,7350,"Come here, I want to show you something."],[7350,7493,"Okay, how about you go play outside"],[7496,7620,"and I'll go meet you in a second?"],[7620,7773,"-Yeah. -Okay, have fun."],[8260,8380,"Robert"],[8380,8590,"always had such a kind heart,"],[8593,8726,"even as a little boy."],[9126,9453,"But the wife of a wealthy CEO"],[9456,9666,"is not an easy path."],[9920,10053,"I want to give you something."],[10156,10460,"This was handed down"],[10463,10803,"through generations of Johnsons' women."],[11700,11843,"Alison,"],[11846,12066,"if you truly love him,"],[12123,12226,"you might need"],[12226,12433,"to think about letting him go,"],[12526,12739,"so he can fulfill his destiny"],[12739,12893,"to the MJ Group."]],"52":[[2030,2199,"It's all in here, Peter."],[2240,2373,"The transfer of power,"],[2373,2576,"corporate structure."],[2580,2633,"You're officially"],[2633,2793,"the heir of the MJ Group."],[2796,2980,"Are you sure about this, Robert?"],[2980,3140,"Once done, there's no going back."],[3143,3363,"I've never been more sure of anything."],[3363,3513,"Alison is my life."],[3780,3889,"Robert,"],[3993,4120,"what have you done?"],[4260,4466,"Alison has already agreed to leave you"],[4470,4743,"so you can fulfill your destiny."],[4743,4916,"What?"],[4920,5073,"She can't."],[5073,5146,"I have to find her."],[5150,5206,"No, Robert."],[5206,5280,"Robert."],[5533,5653,"Alison?"],[6200,6253,"Alison."],[6336,6423,"What's wrong?"],[6596,6653,"Are you sick?"]],"53":[[453,476,"Here."],[476,633,"This will settle your stomach."],[2130,2353,"I can't do this anymore."],[2400,2523,"I can't be the reason that you"],[2526,2650,"give up everything."],[2903,3136,"Just promise me one thing, okay?"],[3316,3453,"Promise me that you'll let me"],[3453,3640,"keep Sarah, okay?"],[3700,3853,"I mean, you can still have children"],[3856,4006,"with someone else."],[4066,4273,"Don't do this."],[4276,4416,"Alison, I can't imagine my life"],[4420,4556,"without you."],[4696,5006,"I love you more than anything,"],[5126,5336,"but I cannot be a burden to you."],[5896,6116,"And this belongs"],[6116,6373,"to you and your family"],[6463,6630,"and your future wife."],[6730,6946,"I can't keep it."],[7780,7973,"Maybe it's better this way,"],[8060,8193,"in the dark."],[8340,8443,"So we can't see the pain"],[8443,8603,"in each other's eyes."],[9090,9283,"I'll never stop loving you, Alison."],[9453,9553,"Never."]],"54":[[746,890,"Here's my resignation."],[1286,1390,"I guess that's what happens"],[1390,1623,"when you cross the future CEO's wife."],[1623,1726,"She should have known better than"],[1730,1883,"to go up against June."],[2543,2680,"I will pack my things"],[2680,2803,"and be out by the end of the day."],[2803,2870,"Great."],[3220,3460,"Mom, I know you"],[3463,3680,"care about the company,"],[3680,3813,"but can't you see how in love"],[3813,4056,"Robert and Alison are with each other?"],[4060,4163,"Isn't that what you come first?"],[4163,4266,"I don't know what to do."],[4300,4363,"Alright?"],[4363,4606,"I want Robert to be happy."],[4610,4670,"I do."],[4706,4873,"But I also want to ensure"],[4873,5056,"the future of MJ Group."],[5606,5773,"Not so fast, Alison."],[5846,5986,"I know what you're trying to do."],[5986,6136,"What are you talking about?"],[6136,6206,"You think you can just"],[6206,6256,"walk out of here"],[6256,6400,"with company property?"],[6403,6543,"I won't let you get away with it."],[6880,6996,"Company property?"],[6996,7063,"No, I haven't taken"],[7063,7163,"anything that isn't mine."],[7163,7316,"Oh, but you have."],[7316,7406,"And until you return"],[7410,7533,"what you stole,"],[7533,7666,"you're not going anywhere."]],"55":[[429,517,"Oh."],[753,863,"This."],[950,1073,"This is the necklace"],[1073,1346,"that she stole from our client,"],[1350,1586,"Adam Rodriguez."],[1586,1723,"No. Adam gave that to me"],[1723,1833,"for his bad behavior."],[1836,1923,"I didn't steal it."],[1923,2066,"I promise."],[2070,2123,"She's just trying to"],[2123,2226,"cover her tracks."],[2230,2463,"Once a thief, always a thief."],[2463,2563,"We can't trust her."],[2563,2753,"She's probably been stealing all along."],[3170,3470,"Wow. What do we have here?"],[3476,3613,"Little Miss Allison"],[3613,3873,"caught stealing red-handed."],[3876,4036,"Can't say I'm surprised,"],[4230,4366,"Jason."],[4370,4510,"Perfect timing."],[4510,4670,"Alison has just been caught"],[4673,4873,"stealing from my client."],[4873,4990,"I trust that you'll handle this"],[4990,5123,"matter appropriately."],[5190,5326,"Actually, June,"],[5326,5510,"this is all a big misunderstanding,"],[5510,5700,"and I have evidence to prove it."],[5850,6133,"These are designs created by Alison,"],[6133,6286,"dated seven years ago."],[6400,6483,"And these are"],[6483,6623,"the designs June submitted"],[6623,6806,"as her own, six years ago."],[7000,7126,"That is absurd."],[7130,7236,"Alison must have stolen them"],[7236,7280,"from me."],[7283,7376,"Dates don't lie, June."],[7380,7503,"No, but Alison does lie."],[7506,7706,"Alison's designs predate yours."],[7706,7780,"It's clear that you're"],[7780,7903,"the one who's been stealing."],[7906,7946,"Not her."],[7946,8113,"This is ridiculous, Jason."],[8113,8236,"When I am the CEO's wife,"],[8240,8393,"you will pay for your insolence."],[8420,8573,"I'm afraid that won't be happening, June."]],"56":[[690,913,"I'm actually glad each of you were here,"],[916,950,"because I have an"],[950,1076,"important announcement to make."],[1203,1330,"Alison and I are married."],[1410,1500,"She's my wife."],[1556,1800,"And the future of MJ Group."],[2086,2230,"Robert, how could you?"],[2250,2420,"You cruel bastard."],[2420,2506,"I loved you!"],[2510,2550,"You want to talk to me"],[2550,2683,"about cruelty, June?"],[2776,3053,"You don't know what cruelty truly is."],[3530,3650,"She deserved it."],[3700,3876,"And you, Adam."],[3880,4003,"Don't think you're getting off so easy."]],"57":[[10,96,"And you, Adam."],[196,356,"Don't think you're getting off so easy."],[403,490,"What are you talking about?"],[490,730,"The $50 million you extorted from me."],[730,780,"Did you really think"],[780,963,"you could get away with it?"],[966,1060,"Blackmail and extortion"],[1060,1226,"are serious crimes."],[1293,1476,"You'll be in prison for a long time."],[1476,1626,"-I'd like to see you try. -Please."],[1890,2040,"Adam Rodriguez and June Davis."],[2040,2150,"You're under arrest"],[2153,2246,"for attempted murder,"],[2250,2420,"blackmail and extortion."],[2936,3063,"This is ridiculous."],[3340,3440,"You ruined everything."],[3440,3613,"You little bitch!"],[3613,3680,"Alison."],[4000,4043,"Are you okay?"],[4046,4170,"Oh, my God. My stomach."],[4220,4293,"Something's wrong."],[4293,4426,"Someone call an ambulance."],[4470,4543,"Now!"]],"58":[[713,806,"Meg?"],[1076,1236,"What happened?"],[1240,1417,"You fell, dear."],[1473,1656,"But you're going to be okay."],[2023,2260,"Oh, Mrs. Jonhsons, you're awake."],[2263,2356,"I have some wonderful news"],[2356,2426,"for you."],[2486,2613,"Congratulations."],[2616,2766,"You're pregnant."],[2933,3156,"Wait, I'm-"],[3160,3226,"I'm pregnant?"],[3226,3363,"I'm going to have a baby?"],[3523,3780,"Alison, this is amazing."],[3856,4026,"I can't believe it."],[4126,4313,"Alison, are you okay?"],[4313,4463,"Meg says something about a growth?"],[4676,4750,"A growth?"],[4753,4924,"Yes, but not the kind"],[4924,5126,"you're thinking of, Robert."],[5836,6036,"I'm pregnant."],[6036,6190,"We're going to have a baby."],[6313,6386,"A baby?"],[6520,6643,"Our baby?"],[7243,7436,"I love you so much."],[7436,7596,"You made me the happiest man alive."]],"59":[[30,120,"Everyone,"],[270,376,"Alison and I have some"],[376,496,"incredible news."],[736,846,"We're expecting a baby."],[950,1173,"Oh, what? Really?"],[1173,1300,"Yeah."],[1303,1523,"Oh, what a miracle."],[1600,1653,"Robert."],[1690,1876,"Alison, it's Sarah."],[1920,1996,"There's been an accident"],[2000,2090,"at the daycare."],[2090,2163,"What? What happened?"],[2166,2260,"Is she's going to be okay?"],[2263,2423,"She's in critical condition and needs"],[2423,2583,"an immediate blood transfusion."],[2586,2846,"But her blood type is RH Negative."],[2850,2933,"The hospital's struggling"],[2933,3073,"to find a match."],[3233,3326,"I'm RH negative."],[3433,3550,"I can donate blood."],[3646,3773,"Let's get to the lab right now."],[3973,4100,"Oh, my God."],[4193,4316,"Mr. Johnsons."],[4320,4570,"According to the test results,"],[4570,4853,"you're not just a match for Sarah."],[5073,5213,"You're a direct relative."],[5373,5456,"What?"]],"60":[[553,613,"Hey."],[660,733,"Robert."],[736,796,"Is everything okay?"],[800,926,"Is everything okay with Sarah?"],[1010,1116,"Can we talk?"],[1173,1276,"Yeah."],[1486,1720,"Alison, there's"],[1720,1853,"something I need to tell you."],[1936,2113,"About five years ago,"],[2116,2260,"at Crown Hotel,"],[2450,2656,"I slept with someone I didn't know."],[2826,3036,"Five years ago..."],[3130,3346,"It's the night I can't remember."],[3416,3716,"Do you think it's possible that we-"],[3816,4056,"There's only one way to find out."],[5120,5330,"I don't know how to explain this, but..."],[5333,5453,"Mrs. Johnsons,"],[5453,5680,"you're the biological mother."],[6256,6423,"Robert,"],[6423,6630,"Sarah's our daughter."],[6686,6910,"We adopted our own child."],[7076,7243,"All this time,"],[7243,7396,"she was ours."],[7460,7563,"Piece of us."]],"61":[[393,507,"Alison,"],[570,660,"my love."],[843,983,"Even though our journey"],[986,1130,"started by chance,"],[1190,1426,"with everything we've been through,"],[1426,1568,"I know we're meant to be."],[1683,2033,"You've loved me unconditionally,"],[2130,2270,"even when I didn't deserve it."],[2500,2710,"And now I want to ask you"],[2713,2940,"properly, this time."],[3163,3320,"Alison Miller."],[3320,3370,"Will you do me"],[3373,3560,"the honor of becoming my wife?"],[3716,3783,"Yes. Yes."],[3783,3923,"A thousand times, yes."],[3963,4056,"Mommy and Daddy are"],[4056,4216,"getting married again."],[4220,4393,"That's right, Princess."],[4393,4563,"And this time, it's forever."]]}