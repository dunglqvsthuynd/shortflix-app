926,2022,"I don't know what you want,"],[2022,2160,"but if it's for me to shower you"],[2160,2289,"in gratitude like I used to,"],[2289,2398,"then you can think again."],[2398,2481,"What if"],[2615,2715,"what I want to say"],[2944,3036,"is that I love you"],[3174,3253,"and I want to get back"],[3253,3345,"together with you?"],[3553,3678,"What did he mean by that?"],[3720,3837,"Why is he always messing"],[3837,3966,"with my feelings?"]],"49":[[421,613,"Zoe, what are you doing over here"],[613,709,"all by yourself?"],[709,800,"Where's Marcus?"],[896,1017,"What's going on"],[1017,1151,"between you and Marcus?"],[1172,1368,"I haven't seen you two together"],[1368,1463,"much recently."],[1547,1714,"We just got into a little fight."],[1843,1885,"Phew."],[1918,2018,"I saw him bringing your dress"],[2018,2127,"up the stairs earlier."],[2127,2289,"I bet it was a surprise for you."],[2289,2352,"What?"],[2352,2423,"A dress?"]],"50":[[1685,1768,"I'm sorry, Ethan."],[1768,1906,"The dress just didn't fit."],[1951,2052,"You don't have to explain."],[2072,2152,"I understand."],[2152,2248,"Yeah, sure you do."],[2627,2802,"Hazel, there's something"],[2802,2898,"I want to tell you."],[3178,3240,"What is it?"],[3407,3616,"I've never given you anything"],[3616,3770,"that was meaningful,"],[3895,3933,"but..."],[4183,4233,"Marcus."],[4233,4279,"There you are."],[4350,4500,"The CEO of Time is looking for you."],[4525,4575,"Yeah."],[4608,4688,"Come on, let's not keep him waiting."],[4688,4733,"Let's go."],[4925,4992,"Wait for me."],[6006,6227,"Why is that bitch wearing your dress?"],[6293,6356,"I don't know."],[6385,6594,"Maybe Marcus gave it to her."],[6673,6740,"What do you mean?"],[6877,7169,"Well, actually, um, Marcus married her"],[7169,7336,"because she drugged him"],[7336,7528,"and got into his bed"],[7528,7682,"and now she's pregnant, so..."],[7786,7878,"Oh, hell no."],[7937,8053,"Let's go teach her a lesson."]],"51":[[145,254,"You look beautiful tonight."],[517,571,"Look Ethan,"],[571,763,"I know that you care about me a lot,"],[792,988,"but I can't take that for granted anymore."],[988,1113,"I don't have anything"],[1113,1267,"to give you in return."],[1330,1455,"You don't need to give me anything."],[1455,1514,"That's not why I-"],[1514,1622,"But I care."],[1647,1826,"And you're a kind person, Ethan."],[1826,1956,"You shouldn't waste"],[1956,2085,"any more time on me."],[2223,2335,"Is it because of Marcus?"],[2656,2769,"I'm out of the picture, aren't I?"],[2769,2986,"Ethan, it has nothing to do with Marcus."],[3061,3128,"It's just..."],[3345,3649,"I've always seen you as a little brother."],[4024,4154,"Hey, relax."],[4220,4358,"I'm fine with being your little brother."],[4371,4450,"Besides, it would be fun"],[4450,4554,"to put some pressure on Marcus,"],[4554,4612,"wouldn't it?"]],"52":[[458,579,"What the hell is the matter with you?"],[579,696,"That bitch deserved it."],[763,880,"What's your problem?"],[909,1059,"First you tried to take her boyfriend"],[1059,1230,"and now you're taking her dress too?"],[1247,1409,"I don't know what you're talking about."],[1430,1522,"Don't play dumb."],[1564,1760,"Just looking at you makes me sick."],[1760,1881,"Did you really not know"],[1881,2035,"that dress was meant for Zoe?"],[2331,2385,"I don't..."],[2444,2548,"I don't know what you mean."],[2765,2852,"Are you saying that"],[2852,3019,"Marcus bought this dress for Zoe?"],[3128,3178,"Duh."],[3232,3299,"Did you really think"],[3299,3449,"this dress was meant for you?"],[3486,3553,"You're the reason"],[3553,3687,"Marcus and Zoe are fighting."],[3687,3845,"You pushed him into marrying you."],[3912,4133,"Marcus and Hazel are married?"],[4145,4270,"Must have been a secret wedding"],[4270,4341,"or something."],[4391,4592,"Hazel probably did something shady"],[4592,4738,"to make him dump Zoe."],[4829,4921,"That's bullshit."],[4942,5071,"Ethan, let them finish."],[5138,5288,"Is Marcus saying that"],[5288,5430,"I forced him to marry me?"],[5430,5530,"Of course."],[5559,5714,"He's saying you drugged him"],[5714,5885,"and are blackmailing him with this baby."],[6235,6314,"What the heck?"],[6368,6560,"She's pregnant with Marcus's baby?"],[6635,6810,"Better keep an eye on my husband,"],[6810,6990,"in case she tries to take him next."],[6990,7219,"Why would she go after your husband?"],[7219,7369,"She's got Marcus!"],[7386,7570,"Still, it's disgusting"],[7570,7686,"to be around people like that."],[7686,7928,"I never went after Marcus."],[7957,8116,"And I made that clear to Zoe."],[8116,8224,"Here, just ignore them."],[8224,8299,"Let's get out of here."],[8329,8508,"If you didn't go after Marcus first,"],[8508,8641,"why would he choose you"],[8641,8733,"over Zoe?"],[8938,9067,"And you're Marcus's cousin."],[9067,9225,"Don't you think it's a little weird"],[9225,9392,"hanging all over your cousin-in-law"],[9392,9455,"like that?"]],"53":[[0,129,"Hey, don't say that about him."],[129,246,"Ethan is my friend."],[325,400,"Look at you."],[458,596,"Getting all defensive."],[663,834,"What do you think Marcus would think"],[834,963,"if he knew you were cheating on him"],[963,1042,"with his cousin?"],[1076,1230,"Kick you both out, maybe?"],[1255,1359,"Ava, that's enough."],[1359,1493,"Marcus will be here any minute."],[1518,1643,"What are you so scared of?"],[1643,1830,"It's clear Marcus is clueless."],[1835,1922,"He doesn't appreciate"],[1922,2039,"what's right in front of him."],[2081,2164,"He never will."],[2198,2327,"He's going to regret it someday."],[2327,2515,"If he were here, I would tell everyone."],[2648,2723,"Listen up."],[2786,2873,"You all better keep an eye"],[2873,2965,"on this bitch."],[3003,3103,"Because she's gonna come around"],[3103,3203,"one day"],[3203,3315,"and say that your husband"],[3315,3436,"got her pregnant."],[3461,3524,"But really,"],[3524,3682,"who knows who the real father is?"],[4104,4233,"Say what you want about me,"],[4233,4396,"but leave my baby out of it."],[4412,4517,"How dare you?"],[4517,4600,"I would have done the same thing"],[4600,4662,"if she didn't."],[4662,4879,"Ethan, I think you misunderstood Ava."],[4900,5013,"She isn't saying anything bad"],[5013,5105,"about Hazel's baby."],[5105,5196,"Just calm down."],[5221,5388,"Could Ethan be the baby's dad?"],[5388,5488,"Just look at her."],[5501,5568,"Pregnant?"],[5576,5718,"Still dressing like that?"],[5718,5885,"Who is she trying to impress?"],[5951,6135,"I can't watch this anymore."],[6135,6385,"Can't we just kick her out already?"],[6569,6698,"Don't touch her!"]],"54":[[0,112,"Don't touch her!"],[233,362,"Who called my child a bastard?"],[450,575,"I did."],[638,738,"What's the problem?"],[771,896,"I was just trying to help."],[896,992,"How do you even know"],[992,1184,"that baby's yours and not Ethan's?"],[1205,1368,"You are lucky that you are a woman,"],[1397,1647,"or I would put you in your place."],[1647,1826,"You should get out of this club now."],[1826,1972,"Marcus, calm down."],[1972,2156,"How many times do I have to say it?"],[2156,2252,"We're done!"],[2323,2531,"That was three years ago, Zoe."],[2531,2673,"What do you not understand?"],[2865,3061,"Marcus, you promised my mom..."],[3061,3219,"Stop guilt-tripping me"],[3219,3353,"about your mother,"],[3353,3503,"or I'm going to regret everything"],[3503,3624,"that I've done for you."],[3687,3883,"Wait, so she's the one clinging to him?"],[4004,4141,"Let me make this clear"],[4141,4266,"to everyone here."],[4391,4654,"Hazel is my wife."],[4683,4871,"And the baby that she is carrying"],[4900,5046,"is proof of our love."],[5622,5855,"I have made a lot of mistakes"],[5855,5980,"in the last three years."],[6001,6151,"But I want to make everything right."],[6573,6664,"I love you."],[7069,7152,"Will you marry me?"]],"55":[[358,425,"You okay?"],[604,734,"Fuck, fuck, fuck!"],[734,884,"Hazel, I swear I'll make you"],[884,992,"pay the price for everything"],[992,1092,"you've ever done!"],[1180,1514,"So, Zoe is the real homewrecker."],[1514,1655,"Not surprised her friends are"],[1655,1860,"spreading rumors out there, too."],[1897,2139,"I told you to leave the club."],[2139,2310,"Get out now!"],[2310,2489,"Marcus, you can't fire me."],[2531,2648,"Zoe's family owns"],[2648,2786,"majority shares in the company."],[2786,2932,"She won't let you get rid of me."],[2932,3119,"Zoe's family only owns"],[3119,3249,"the majority of the shares"],[3249,3407,"so that she can stay in the club."],[3453,3636,"As far as firing you,"],[3687,3828,"that is my decision."],[3828,3991,"And nobody can stop me."],[4129,4233,"Security!"],[4233,4379,"Get her out of here now!"],[5347,5613,"I meant every word I said."],[5860,6010,"I'll see you at the church tomorrow."],[6539,6706,"I don't know anymore, Marcus."],[6706,6856,"Were you really proposing to me"],[6856,6915,"just now?"],[6956,7036,"But why?"],[7090,7161,"Let's go."]],"56":[[350,525,"Should I give him another chance?"],[754,892,"Can I trust him again?"],[1071,1255,"Hazel, haven't you been hurt enough?"],[1313,1522,"If it happens again, it'll ruin you."],[2377,2485,"If you can't move,"],[2585,2715,"then give it another shot."],[3457,3553,"Will she come?"],[6377,6569,"How dare you smile like that, Hazel?"],[6610,6731,"You don't deserve to be happy."],[6731,6894,"First, you took Marcus,"],[6894,6998,"and you ruined everything."],[6998,7144,"Now it's my turn to ruin you."],[8833,8958,"Is she really not coming?"]],"57":[[237,329,"What are you doing here?"],[350,412,"Zoe."],[479,575,"Zoe's in the hospital."],[692,779,"Look, I can't leave."],[779,905,"This is a big day for me."],[930,1005,"Zoe's got the doctor."],[1005,1101,"She'll be fine without me."],[1192,1234,"Hey."],[1280,1347,"This is for real."],[1426,1488,"Trust me."],[1559,1693,"She's refusing to get treatment, okay?"],[1693,1805,"If you don't go right now,"],[1805,1897,"she could probably die."],[1964,2014,"Come on."],[2089,2164,"We're wasting time."],[2164,2298,"Let's just explain everything"],[2298,2385,"to Hazel later."],[3215,3365,"Were you able to contact her family?"],[3415,3453,"No."],[3453,3541,"Her phone is broken"],[3541,3578,"and we don't have"],[3578,3653,"an emergency contact"],[3653,3732,"for her on file."],[3749,3824,"We don't have time."],[3874,3966,"Prep her for surgery."],[7653,7724,"She's pregnant."],[7757,7849,"It's not looking good."],[7849,8008,"We might not be able to save the baby."],[8091,8254,"Connect the electrodes."],[8400,8508,"One, two, three."]],"58":[[967,1013,"Ethan."],[1055,1117,"Hazel..."],[1226,1359,"Hazel, thank God you're awake."],[1438,1547,"What? What happened?"],[1810,1951,"Am I in a hospital?"],[1951,2077,"Hazel, some bad things"],[2077,2143,"have happened."],[2373,2477,"No, no, no."],[2477,2556,"My baby?"],[2844,2915,"My baby."],[3094,3274,"No, no, stop!"],[3716,3849,"Calm down, you're not recovered yet."],[5267,5367,"Where's Marcus?"],[5467,5563,"I haven't been able"],[5563,5676,"to reach him these days."],[5960,6076,"Did you hear about the other girl"],[6076,6185,"in the accident?"],[6214,6356,"She's staying in a private ward"],[6356,6464,"with her fiancé."],[6485,6652,"That's Zoe, the sports star, right?"],[6685,6861,"And isn't Marcus her fiancé?"],[6915,7057,"They're such a perfect match."],[7090,7257,"Honestly, he's so devoted to her."],[7282,7357,"He stayed with her"],[7357,7503,"and took care of her all day and night"],[7503,7574,"without a break."],[7682,7799,"So cute."],[7932,8099,"She said Zoe and Marcus are here."]],"59":[[62,241,"Marcus, it's all my fault."],[241,333,"Please don't leave me."],[375,529,"Zoe, relax."],[575,738,"I've forgiven you already."],[838,946,"Marcus, you love me"],[946,1038,"more than anything, right?"],[2635,2719,"I'll teach him a lesson."],[2740,2827,"No, Ethan."],[2961,3015,"No."],[3061,3115,"No."],[3307,3553,"Hazel, don't cry for this bastard."],[4145,4337,"Just get me out of here."],[4542,4675,"Just get me out."],[5826,5889,"I got a take this."],[5889,5964,"It might be Hazel."],[6418,6527,"Marcus, where are you?"],[6602,6669,"Hazel?"],[6669,6752,"Where are you?"],[6810,6923,"I've been looking for you all day."],[6923,7027,"Did you end up going to the church?"],[7027,7152,"I, I could never find you."],[7173,7399,"When did the church become a hospital?"],[7478,7653,"You were looking for me in a private ward?"],[7882,7982,"Let's get a divorce."]],"60":[[16,112,"Marcus, it's me."],[187,291,"Let's get a divorce."],[329,425,"Okay, wait, Hazel."],[425,487,"No, no, no, no."],[487,563,"You don't understand."],[563,658,"Zoe was..."],[675,792,"Marcus, don't go."],[792,884,"If you leave, I'll die."],[1130,1255,"Without her, I'll die."],[1730,1864,"Hazel, please pick up!"],[1931,2035,"Hazel, please pick up!"],[2177,2327,"Marcus, is your fiancée alright?"],[2327,2452,"I need you to look up a patient."],[2489,2644,"Hazel Miller."],[2752,2844,"Hazel?"],[2944,3032,"You mean the woman"],[3032,3178,"from the same car accident?"],[3395,3495,"Car accident?"],[3545,3611,"Yeah."],[3678,3778,"She and your wife"],[3778,3887,"were brought in together."],[3908,4112,"I heard that Zoe lost control"],[4112,4270,"of her brakes and hit Hazel..."],[4642,4717,"Where is she?"],[4717,4792,"Which ward?"],[4871,4967,"Do you know her?"],[5030,5180,"She's already been discharged."]],"61":[[571,642,"I love you."],[1146,1230,"Will you marry me?"],[2748,2936,"Baby, mommy's giving up on daddy"],[2936,3044,"for good this time."],[3841,4004,"Is it really that difficult to leave him?"],[4396,4487,"You sure you don't want to tell him"],[4487,4587,"about going to the Netherlands?"],[4696,4821,"He's been losing his mind looking for you."],[4821,4904,"No, no."],[5038,5176,"I'm done with him for good."],[5355,5480,"I just need to get away."],[5618,5705,"Away from..."],[5814,5901,"all of this."],[6197,6247,"Okay."],[6402,6464,"Let's go."],[6652,6802,"Ethan, you don't have to-"],[6802,6915,"I'll stay"],[6915,7061,"until you and the baby are settled."],[7123,7173,"Okay?"],[7432,7524,"Thank you, Ethan."]],"62":[[967,1013,"Hey."],[1151,1226,"You sure about this?"],[1551,1618,"Yeah."],[1851,1931,"Yeah, let's go."],[2022,2072,"Okay."],[3224,3349,"I've been here so many times today,"],[3349,3440,"but you were never home."],[3470,3528,"What..."],[3566,3661,"is going on?"],[3712,3803,"Are you moving?"],[3908,3995,"Hazel, listen."],[3995,4074,"About the hospital-"],[4074,4195,"I don't want to hear it!"],[4354,4421,"Listen to me-"],[4421,4471,"Stop."],[4625,4754,"Stay out of this!"],[4754,4934,"This is between me and my wife!"]],"63":[[0,66,"Why don't you ask Hazel"],[66,216,"if she wants to be your wife?"],[216,379,"As long as we are still married,"],[379,538,"you are just her cousin!"],[980,1021,"Where were you"],[1021,1167,"when Zoe hit Hazel with her car?"],[1184,1230,"Where were you"],[1230,1343,"when she almost died in surgery?"],[1343,1480,"And where were you"],[1480,1680,"when she was in the hospital bed alone?"],[2177,2289,"You were fooling around with Zoe,"],[2289,2344,"weren't you?"],[2423,2585,"Ethan, let's not waste any more time."],[3132,3244,"What do you mean Zoe hit you?"],[3507,3611,"Wasn't it the brakes?"],[4004,4145,"Hazel, please talk to me."],[4195,4350,"Tell me what is going on, or..."],[4350,4454,"or I'm not gonna let go."],[4909,5009,"Just wait outside for me."],[5009,5196,"I'll, I'll sort this out with him."],[5459,5513,"Okay."],[5593,5663,"I'll wait outside."]],"64":[[29,100,"Hazel."],[383,517,"Let me explain, okay?"],[558,863,"I was at the church waiting for you"],[863,975,"when Oscar came,"],[988,1063,"and he told me"],[1063,1226,"that Zoe had been in an accident"],[1255,1397,"and, and she was refusing treatment."],[1397,1497,"I really didn't know-"],[1497,1655,"I don't care anymore, Marcus."],[1785,1901,"I don't care who you love"],[1901,1997,"or who you take care of"],[1997,2135,"or what promises you've made."],[2156,2268,"I don't care anymore,"],[2268,2398,"so you don't need to explain."],[2494,2565,"There are three things"],[2565,2698,"that I need to tell you today."],[2777,2852,"First,"],[2977,3107,"whether you believe it or not,"],[3253,3370,"this is the police report"],[3461,3603,"on the car investigation."],[3807,3874,"Zoe says that"],[3874,4012,"the crash was an accident,"],[4012,4062,"but..."],[4145,4312,"the car was in perfect condition,"],[4312,4529,"there's no way that it wasn't intentional."],[4633,4729,"I think that Zoe planned"],[4729,4783,"this whole thing"],[4783,4888,"to try and kill me."]],"65":[[33,129,"I think that Zoe planned"],[129,191,"this whole thing"],[191,308,"to try and kill me."],[688,750,"I swear..."],[871,950,"I didn't know."],[950,1038,"That's what I thought."],[1092,1167,"Just like,"],[1209,1317,"for the last three years,"],[1317,1463,"you didn't know anything about me."],[1488,1555,"Second,"],[1668,1789,"this is a divorce agreement."],[1830,1956,"I'm leaving with nothing, read it."],[1956,2106,"If it's fine, then sign it."],[2189,2256,"No, no, no, no..."],[2256,2352,"Please, wait, I..."],[2540,2615,"I don't..."],[2656,2823,"I don't want a divorce."],[2944,3182,"We have a baby together, Hazel."],[3219,3428,"Let's give our child a real family."],[3507,3636,"Let me fix this."],[3687,3712,"Okay?"],[3712,3766,"I..."],[3928,4079,"That's the third and final thing."],[4341,4425,"Our baby's gone."],[4688,4771,"Zoe killed it."]],"66":[[58,150,"Zoe killed it."],[400,542,"She aimed right for my stomach,"],[542,742,"I felt its life slip away inside of me."],[1076,1309,"For three years, I have suffered"],[1347,1468,"because I loved you."],[1551,1618,"And now,"],[1751,2002,"I regret ever having those feelings."],[2052,2160,"Remember how you asked"],[2160,2310,"if I had any conditions"],[2310,2452,"for our marriage contract?"],[2523,2606,"I didn't then."],[2781,2907,"I want a divorce."],[3086,3165,"I want"],[3274,3357,"a life"],[3420,3603,"without you, Marcus."],[4037,4112,"We're over."]],"67":[[1151,1263,"I'm so lucky to have"],[1263,1380,"this handsome man in my life."],[1380,1534,"Marcus won the race, as usual."],[1534,1664,"God, he's such a talented man!"],[1664,1805,"I know this was something special"],[1805,1976,"and different from the first day we met."],[2043,2231,"I can't believe Marcus asked me"],[2231,2369,"for a photo today!"],[3745,3820,"Do you like me?"],[4354,4512,"I've liked you for a long time."],[5647,5709,"Good."],[5897,6006,"You passed."],[6181,6293,"She remembers."],[6443,6589,"She remembers everything."],[6756,6931,"Your birthday gift is on the table."],[7082,7211,"The past three birthdays,"],[7211,7357,"you've given me the same bag."],[8337,8508,"So I've been hurting you all this time."]],"69":[[558,684,"Marcus, you're finally here."],[1192,1259,"Miss Carter,"],[1313,1376,"you are under arrest"],[1376,1443,"for attempted murder."],[1443,1534,"Put your hands behind your back"],[1534,1609,"and interlace your fingers."],[1772,1872,"This must be"],[1872,1993,"some kind of misunderstanding."],[2031,2198,"Marcus, what are they doing here?"],[2198,2289,"Tell them to let me go!"],[2448,2548,"What are you doing?"],[2548,2665,"Is this because of that bitch, Hazel?"],[2665,2752,"Did she say something?"],[2773,2919,"You tried to run Hazel over"],[2919,2990,"in your car."],[2990,3111,"I've got proof."],[3203,3478,"When did you become so evil, Zoe?"],[3566,3670,"You're calling me evil"],[3670,3778,"because of that bitch?"],[3807,3878,"Do you not remember"],[3878,3991,"what you promised my mom,"],[3991,4070,"you asshole?"],[4250,4316,"If there's nothing else,"],[4316,4446,"I'll take her with me, Mr. Stark."],[4658,4796,"I should've killed that bitch."],[4796,4892,"And you too, Marcus."],[4892,5021,"I should've killed everyone!"]],"70":[[850,942,"Bro, I've called you like"],[942,1109,"a hundred times tonight!"],[1109,1205,"Where the hell are you?"],[1255,1359,"Hazel and Ethan are flying"],[1359,1518,"to the Netherlands tonight."],[1518,1705,"You've still got time!"],[1705,1801,"It's too late."],[1851,2018,"What do you mean?"],[2135,2264,"Hazel already divorced me."],[2373,2402,"Why?"],[2402,2515,"Because of Zoe?"],[2648,2711,"I've already explained"],[2711,2852,"everything to her."],[2948,3019,"Hazel..."],[3349,3461,"She lost the baby."],[3536,3603,"I'm..."],[3641,3745,"sorry, man."],[3762,3841,"I didn't know."],[3920,4033,"She's never gonna forgive me."],[4099,4241,"If I were you, man..."],[4291,4412,"I'd take my last shot."],[4475,4671,"You know, what if?"],[4779,4925,"You've got nothing to lose here."],[5084,5138,"I know."],[5305,5359,"Bye."],[6619,6677,"You ready?"],[6865,6927,"Let's go."],[7520,7574,"Hazel."]],"71":[[58,129,"Hazel."],[842,888,"Hazel."],[917,984,"Open up!"],[996,1055,"Hazel!"],[1134,1234,"Hazel, open up."],[1288,1443,"Hazel, Hazel, open up."],[1505,1605,"Hazel, please!"],[1634,1697,"Hazel."],[1726,1789,"Open up!"],[1801,1901,"Are you sure you want to go?"],[1939,2039,"Hazel, open up!"],[2093,2152,"Drive."],[2152,2223,"Now - Hazel, please!"],[2239,2348,"Hazel, please, open up."],[2394,2460,"Hazel, come on."],[2460,2535,"Please, open up."],[2535,2594,"Hazel."],[2619,2698,"Hazel, open up."],[2698,2769,"Please."],[3157,3228,"Hazel!"],[3365,3436,"Should we stop?"],[4692,4746,"Hazel..."],[4917,5080,"I really lost you this time."]],"72":[[421,592,"Please watch your luggages."],[625,759,"Hold the handrail."],[804,930,"Mind your steps."],[1172,1309,"This is my home, sweetie."],[1343,1459,"Is this your home?"],[1459,1509,"Yeah."],[1522,1597,"You've gotta be a good girl,"],[1597,1672,"sweetie, okay?"],[1701,1801,"I am!"],[2010,2114,"Once this conference is over,"],[2114,2227,"you can finally take a breather."],[2248,2293,"Yeah."],[2310,2469,"Spend more time with Bianca."],[2694,2798,"Looks like you're taking home the gold"],[2798,2932,"at the Olympics again this year."],[2977,3040,"Come on, man."],[3040,3148,"You gotta give it your best shot."],[3165,3365,"If you beat me, I'm gonna retire."],[3420,3507,"You'll retire?"],[3703,3795,"I wanna find Hazel."],[3845,3903,"Hazel's one of"],[3903,4037,"the top orthopedic surgeons"],[4037,4133,"in the world right now."],[4162,4258,"I saw this video online"],[4258,4354,"that went viral."],[4354,4537,"She's like a whole different person."],[4537,4621,"She's..."],[4621,4708,"more confident."],[5025,5117,"Marcus, where are you going?"],[5117,5213,"We're gonna miss our flight!"],[5885,5980,"Daddy!"],[6118,6218,"Daddy!"],[8304,8400,"I miss you..."],[8562,8650,"so much."]]}