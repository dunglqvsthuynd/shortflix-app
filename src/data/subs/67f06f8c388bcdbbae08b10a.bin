shots as punishment."],[1251,1363,"What are they doing here?"],[1363,1463,"Trust me, we wouldn't be here"],[1463,1547,"if he didn't drag us."],[1622,1772,"Well, since you're here,"],[1772,1860,"let's make it fun."],[1931,2002,"Let's kick it up a notch."],[2002,2072,"Hell yeah."],[2598,2681,"Oh yeah."],[2740,2861,"How about Never Have I Ever?"],[2923,2990,"Alright."],[3028,3123,"Okay, I'll go first."],[3169,3332,"Never have I ever"],[3361,3495,"given first aid to anyone."],[3595,3687,"Uh-oh..."],[3703,3937,"Looks like Dr. Miller and Ethan..."],[3991,4058,"have been caught."],[4058,4262,"Well, punishment you two."],[4262,4429,"One shot each, or..."],[4462,4521,"kiss each other."],[5000,5075,"I'm pregnant,"],[5075,5230,"Marcus knows I can't drink."],[5739,5843,"Come on, Marcus."],[5893,5972,"Let's switch it up."],[6051,6126,"Let's go!"],[6126,6214,"He's had enough."],[6235,6364,"Who are you to say?"],[7966,8033,"Happy now?"],[8395,8445,"Let's go."],[10689,10785,"Do you like me?"],[11265,11307,"Yeah."],[11628,11778,"I've liked you for a long time."]],"13":[[646,709,"Good."],[884,971,"You passed."],[1630,1830,"Come on Hazel, kiss or drink."],[2886,2965,"All right."],[3178,3249,"There, that's two."],[3294,3445,"Hey, that's cheating."],[3445,3486,"Okay?"],[3486,3586,"She needs to take one shot."],[3728,3874,"Stop being so dramatic."],[3874,3974,"It's just one shot."],[3974,4041,"Come on, Hazel."],[4041,4137,"Stop being a buzzkill."],[4137,4216,"It's just a game."],[4813,4946,"I'll drink. -I'll take her drink."]],"14":[[4,100,"I'll take her drink."],[454,575,"Marcus, what are you doing?"],[809,938,"My stomach's been acting up"],[938,1167,"and they saw me throwing up earlier."],[1317,1418,"Thank you, Marcus."],[1518,1618,"It's just a drink."],[1935,2006,"Alright, alright."],[2077,2135,"Who's next?"],[2285,2448,"Never have I ever..."],[2506,2577,"dated Zoe."],[2831,2886,"Come on Marcus,"],[2886,2986,"you're the only one that's dated Zoe,"],[2986,3053,"so..."],[3148,3236,"take