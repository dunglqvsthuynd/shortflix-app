{"1":[[1109,1226,"Marcus..."],[1267,1301,"It's my-"],[1301,1384,"Shh"],[5472,5588,"It's my birthday."],[5672,5864,"Three years of being your secret lover,"],[5864,5993,"yet you still forgot."],[6327,6418,"Marcus,"],[6489,6552,"I always thought"],[6552,6731,"if I stayed by your side,"],[6731,6831,"you'd notice me."],[6977,7119,"Eight years have passed,"],[7232,7328,"you still haven't."],[7486,7674,"Your birthday gift is on the table."],[7757,7874,"He remembered?"],[8579,8700,"For the past three birthdays,"],[8700,8850,"you've given me the same bag."],[10422,10652,"Hey, I'm flying back to LA soon."],[10652,10785,"Remember Palm Springs?"],[10785,10977,"You were amazing."],[10977,11102,"Can't wait to swim with you again."],[11144,11240,"Wake up, Hazel."],[11361,11549,"It's time to give Marcus back to Zoe."],[13075,13154,"Marcus, wait."],[13154,13259,"I need to talk to you."],[13467,13596,"You pack my things for competition?"],[13717,13767,"No."],[13851,13959,"This is my suitcase."],[14172,14297,"Marcus, I'm breaking up with you."]],"2":[[45,171,"Marcus, I'm breaking up with you."],[325,379,"Okay."],[604,725,"Or maybe it's not a breakup,"],[725,825,"because we were never"],[825,917,"officially together."],[1105,1197,"Either way, I'm leaving."],[1622,1668,"Fine."],[2052,2218,"I knew you'd never turn around."],[2356,2481,"Not even once."]],"3":[[275,379,"Do you hear Zoe's back?"],[538,596,"I know."],[717,834,"Yeah, yeah, she came back"],[834,963,"for my cousin, Marcus."],[1046,1151,"Apparently they're back together."],[2569,2744,"I scraped my arm during practice."],[2857,2952,"I told him it was nothing,"],[2952,3123,"but he had to bring me here."],[3991,4062,"You get some rest,"],[4062,4141,"I got this."],[4191,4316,"That's fine, I'll handle it."],[4767,4825,"I hope this doesn't"],[4825,4946,"affect my competition."],[5046,5201,"I'll disinfect the wound with alcohol."],[5221,5351,"You should be fine, Miss Carter."],[5455,5613,"This cut is very..."],[5613,5759,"Don't worry, it's a minor injury."],[6227,6310,"Ouch!"],[6389,6510,"Could you be a little more gentle?"]],"4":[[25,116,"Hazel, be easy."],[354,508,"I barely put on any pressure."],[604,759,"It's normal for the alcohol"],[759,834,"to sting a little."],[875,971,"Please, bear with me."],[971,1151,"Wow, that is a serious scrape."],[1242,1309,"If it came by any later,"],[1309,1405,"it would have healed already."],[1405,1501,"What's that supposed to mean?"],[1501,1589,"It means making a big deal"],[1589,1826,"out of this tiny scratch is ridiculous."],[1885,2010,"Don't you think you're being overdramatic?"],[2052,2248,"I told Marcus I was fine,"],[2298,2435,"but he was just so worried."],[2469,2540,"What could I do?"],[2644,2786,"Besides, Dr. Miller,"],[2786,3015,"isn't it your job to care for us athletes?"],[3115,3194,"It is."],[3324,3428,"Let's go, Marcus."],[3470,3611,"I think they need some alone time."],[4379,4529,"Looks like my cousin likes you."],[4675,4813,"Let's hope you stick around this time."],[5017,5105,"What is your problem?"],[5434,5534,"What's that all about?"],[5597,5676,"Marcus slowly turned himself"],[5676,5747,"into an alcoholic"],[5747,5814,"when Zoe dumped him"],[5814,5897,"for that rich European"],[5897,5980,"three years ago."],[6001,6289,"And now, she's back, divorced."],[6393,6477,"He's back with her."],[6477,6631,"It's pathetic."],[6710,6777,"Shit."],[6777,6869,"Not this again!"],[7169,7278,"I haven't had my period"],[7278,7386,"since last month."],[7457,7515,"Am I..."],[7607,7707,"pregnant?"],[8466,8541,"Oh my God."],[8641,8729,"I'm pregnant."],[8933,8983,"No."],[9034,9134,"I have to be sure."]],"5":[[0,254,"Congratulations!"],[254,412,"You're about two months pregnant."],[1180,1338,"Will the father be joining you"],[1338,1472,"on your future checkups?"],[1539,1730,"It's important for him to be involved."],[1976,2072,"There is no father."],[2218,2302,"I'll give you a moment."],[2619,2823,"Marcus won't wanna be a daddy,"],[2823,2965,"but we can make a happy family,"],[2965,3082,"little guy."],[4166,4441,"Marcus I'm pregnant."],[4441,4662,"We need to talk."],[4888,4946,"Wow."],[5372,5442,"Did you hear?"],[5459,5668,"Marcus Stark, the Olympian swimmer..."],[5701,5893,"he threw this entire fireworks show"],[5893,5972,"for his first love,"],[5972,6056,"Zoe Carter."],[6076,6222,"Who hasn't heard about them?"],[6368,6523,"When am I going to find a"],[6523,6760,"loyal, rich, gorgeous guy like him?"],[6915,6944,"Let's go."],[6944,6973,"Come on."],[8241,8562,"So, he does know how to be romantic."],[8679,8796,"Just not with me."],[9000,9188,"Will he allow me to keep this child?"]],"6":[[492,642,"The fireworks were beautiful."],[863,955,"Yeah, I saw them."],[980,1059,"I thought you were with Ethan"],[1059,1167,"and wouldn't bother coming."],[1372,1451,"Called so late,"],[1451,1580,"our usual spot was full."],[2002,2093,"There's a hotel nearby"],[2093,2152,"with an open room."],[2152,2373,"He just sees me as a free sex doll."],[2444,2506,"Should I book it?"],[2869,2969,"Marcus..."],[3816,3862,"What?"],[3899,4162,"Maybe, it's not good news for you."],[4283,4358,"I'm pregnant."]],"7":[[0,70,"I'm pregnant."],[1451,1551,"The baby..."],[1551,1618,"It's yours."],[1755,1843,"If you don't believe me then..."],[1843,1964,"I haven't doubted you yet."],[2364,2469,"So what are you going to do?"],[2957,3132,"You know that I grew up in an orphanage."],[3265,3457,"This baby is my only family now."],[3728,3832,"I'm going to keep it."],[3966,4112,"I want to give it a real home with..."],[4175,4308,"a dad and a mom."],[5176,5242,"Alright."]],"8":[[300,400,"It's been a month."],[483,642,"No call, no text."],[738,950,"He really doesn't care about the baby."],[1443,1488,"Hey."],[1580,1676,"What's been up with you lately?"],[1676,1793,"You've been so distracted."],[1860,1947,"Did you go see a doctor?"],[2027,2085,"I'm fine."],[2189,2260,"Is it because my cousin"],[2260,2364,"and Zoe got engaged?"],[2410,2489,"Engaged?"],[2523,2569,"Yeah."],[2569,2673,"Zoe's parents are our"],[2673,2794,"club's biggest sponsor."],[2977,3082,"That's your answer?"],[3207,3286,"I hear it."],[3319,3411,"Loud and clear."],[3545,3616,"What's this?"],[3657,3712,"Oh, that's..."],[3920,3978,"Hazel."],[4120,4195,"You're pregnant?"]],"9":[[33,108,"Does Marcus know?"],[179,337,"Do you have a plan of action?"],[433,487,"I don't know."],[821,867,"But..."],[917,1042,"Marcus doesn't want the baby."],[1142,1201,"Prick!"],[1409,1493,"It doesn't matter."],[1593,1697,"It's my baby, and..."],[1839,1993,"I don't care what Marcus wants."],[2323,2456,"I'm going to raise the baby"],[2456,2556,"as a single mother."],[2669,2761,"I'll figure it out."],[2781,2861,"I always do."],[2902,3036,"It was too intense."],[3036,3169,"I'm still so sore."],[3941,4045,"Hazel, I've been in love with you"],[4045,4129,"since high school."],[4175,4325,"And not a thing has changed since then."],[4350,4437,"Not for a minute."],[4596,4692,"Why the long face?"],[4996,5071,"You've been my reason"],[5071,5188,"to keep pushing forward."],[5205,5301,"And I know your heart's"],[5347,5447,"been with Marcus."],[5447,5659,"But mine's always been with you."],[5876,6106,"Wait, what I'm trying to say, is..."],[6189,6368,"I can be the kid's dad."],[6452,6564,"We can raise the baby together."],[6731,6815,"I'll be there for you."],[7457,7561,"She doesn't want that!"],[7862,7937,"Marcus?"]],"10":[[45,116,"Marcus?"],[200,258,"We need to talk."],[304,346,"Now."],[1451,1555,"You couldn't even wait a month"],[1555,1634,"and you're already looking for"],[1634,1722,"a new baby daddy?"],[1722,1860,"I couldn't get a hold of you."],[1943,2118,"It was a damn month."],[2189,2435,"I was in Baltimore for swim training."],[2435,2594,"No calls, no texts."],[2715,2802,"You could've said something."],[2886,2994,"Okay, what is this about?"],[3036,3094,"Just tell me."],[3336,3411,"This is about me"],[3411,3611,"wanting to give my baby a home."],[3670,3812,"A home that I never had."],[3812,3995,"A father, a mother,