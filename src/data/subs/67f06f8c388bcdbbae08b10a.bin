ce..."]],"27":[[800,984,"I want a photo with the champ too!"],[2143,2277,"Dr. Miller, come here."],[4375,4546,"How did we become like this?"],[4800,4863,"Ha- - What are you doing?"],[4863,4909,"You can't-"],[4909,4984,"I'm sorry, I..."]],"28":[[50,116,"I'm sorry, I..."],[175,329,"I wanna apologize about yesterday."],[504,650,"Apology received."],[813,896,"Can I go?"],[1096,1205,"I made a mistake, Hazel."],[1276,1359,"Can we talk?"],[1555,1643,"Today is our"],[1643,1730,"three-year anniversary,"],[1730,1914,"so I booked a reservation"],[1914,2031,"at your favorite restaurant."],[2243,2298,"I can pick you up"],[2298,2419,"after work tonight, okay?"],[2452,2715,"He remembered our anniversary?"],[3190,3286,"Do you like me?"],[3737,3787,"Yeah."],[4016,4175,"I've liked you for a long time."],[5163,5242,"You passed."],[6085,6339,"I want to give you another chance."]],"29":[[1422,1547,"Embarrassed to be seen with me?"],[1639,1743,"Something like that."],[1914,2143,"Just go before anyone notices."],[2377,2485,"I can do it myself."],[2994,3123,"What did you think I was doing?"],[3290,3507,"Very long drive to the restaurant."],[3507,3566,"Just wanted you"],[3566,3678,"to have something to munch on."],[3737,3774,"Oh."],[4029,4074,"Okay."],[4437,4550,"Why am I overthinking?"],[4550,4700,"That was so embarrassing."]],"30":[[412,504,"Hazel..."],[604,784,"there's been a lot of things"],[784,896,"going on lately."],[1222,1284,"Okay."],[1493,1680,"Anything you wanna talk about?"],[1993,2052,"No."],[2344,2414,"I actually have something"],[2414,2531,"I wanna talk about."],[2852,2973,"Zoe and I are done."],[3319,3428,"I've been thinking a lot"],[3428,3561,"and I know what I want."],[3778,4091,"What I feel with Zoe is responsibility,"],[4091,4333,"but with you..."],[4567,4633,"it's love."]],"31":[[2143,2227,"You're awake?"],[4058,4237,"Come on, let's get dinner."]],"32":[[554,642,"Don't worry,"],[684,767,"this is our night."],[1126,1197,"Just answer it."],[1197,1301,"What if it's an emergency?"],[2047,2198,"Alright, I'll be right there."],[2506,2669,"Zoe fell down the stairs."],[2719,2811,"She's in the hospital."],[2811,2932,"I gotta go see her."],[2986,3048,"Don't worry."],[3128,3240,"Just go wait inside the restaurant,"],[3240,3357,"I'll be right back."],[3465,3620,"But I thought tonight was our night."],[3674,3753,"I don't want to have to"],[3753,3870,"share you with anyone."],[4016,4129,"Marcus, I don't want you to go."]],"33":[[20,150,"Marcus, I don't want you to go."],[191,400,"Hey, I promise I'll be right back."],[400,600,"Zoe needs a doctor, not you."],[1247,1401,"This will be the last time."],[1401,1497,"I promise."],[1576,1668,"When I come back,"],[1730,1826,"I'll tell you everything."],[2006,2060,"Okay."],[2306,2456,"Okay Marcus, I'll wait for you."],[2519,2619,"I'll wait for you."],[2644,2790,"Like I've always done"],[2790,2923,"for the past three years."],[2965,3098,"But this is the last time."],[3132,3244,"Don't let me down again."]],"34":[[1234,1401,"I'll take every recommended dish."],[1401,1534,"Bring one every half hour."],[1614,1668,"Oh."],[1772,1856,"Okay then."],[2581,2652,"How is she?"],[2652,2736,"Any updates?"],[2765,2840,"Nothing yet."],[2840,2932,"Zoe is still in there."],[5392,5522,"She seriously injured?"],[5522,5655,"It's been taking them forever in there."],[5751,5993,"Marcus, don't be mad."],[6060,6185,"It's really not that serious."]],"35":[[70,141,"What do you mean?"],[229,408,"Well, Zoe saw"],[425,567,"Hazel getting in the car today and..."],[921,992,"Marcus."],[1276,1393,"You think this is funny?"],[1434,1505,"What do you mean?"],[1505,1651,"I fell down the stairs today,"],[1651,1793,"and Oscar drove me here."],[1814,1893,"I told him not to tell you"],[1893,2052,"because I knew you'd be worried"],[2052,2218,"and... looks like you did anyway."],[2239,2302,"Oh yeah?"],[2356,2519,"Well, you look fine, so I'm leaving."],[2581,2644,"Oh,"],[2644,2773,"I almost forgot to tell you."],[2815,2998,"I came here to let you know"],[2998,3148,"that I'm in love with Hazel."],[3215,3361,"She's the one I'm gonna be with."]],"36":[[0,179,"I came here to let you know"],[179,333,"that I'm in love with Hazel."],[408,533,"She's the one I'm going to be with."],[629,788,"What does she have that I don't?"],[809,880,"She's just some slut"],[880,959,"you let into your bed"],[959,1063,"when I wasn't around!"],[1981,2227,"Ma'am, this is the last one."],[2344,2402,"Really?"],[2556,2711,"Shows how long I've been waiting."],[4504,4608,"It's already cold."],[5326,5526,"Ma'am, are you still waiting?"],[5555,5680,"We're closed."],[5734,5880,"It's clear, Hazel."],[5935,6110,"You're just the person he ditches"],[6110,6218,"again and again."],[6748,6831,"It's spicy."],[6831,6915,"Have some water."],[7077,7207,"It's not spicy at all."]],"37":[[171,262,"Excuse me, ma'am."],[262,429,"There was a woman waiting in a dress."],[429,529,"Did she leave already?"],[542,725,"You mean that lady that waited here"],[725,800,"the whole night?"],[800,921,"She left a while ago."],[921,1121,"She ordered a table full of food,"],[1121,1280,"but she didn't touch any of that."],[2385,2456,"It's fine."],[2456,2565,"Everything's fine."],[3415,3524,"What's there to cry about?"],[3532,3720,"Zoe always comes before Hazel."],[3816,3928,"Zoe's..."],[4350,4441,"not the homewrecker."],[4604,4708,"Guess I should be used to it."],[4779,4917,"The number you have dialed..."],[5426,5492,"I'll just..."],[5492,5588,"throw this dress out..."],[5588,5751,"There's plenty of nice dresses out there."],[6468,6569,"Hazel, where are you?"],[6569,6619,"Listen,"],[6619,6748,"I have something I wanna tell you."],[6748,6790,"No."],[6923,7023,"I go first this time."],[7344,7428,"Marcus, I..."],[7494,7615,"I want a divorce."]],"38":[[4,154,"I want a divorce."],[629,721,"Fuck!"],[1793,1910,"Are you sure you still wanna go?"],[1910,1968,"If you're sick,"],[1968,2064,"you should get some rest."],[2122,2193,"I'm okay."],[2298,2406,"It's just a cold."],[2414,2523,"But 