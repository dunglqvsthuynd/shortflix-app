[1255,1334,"What do you want?"],[1522,1593,"Well, well."],[1655,1776,"Look who it is."],[1797,2068,"Dr. Miller, our sweet little angel."],[2068,2277,"Or should I say, homewrecker."],[2431,2531,"What are you talking about?"],[2531,2652,"Oh, don't play dumb."],[2711,2840,"Marcus told me he's sick of you,"],[2840,3086,"and he asked me to tell you to back off."],[3215,3340,"Marcus said that?"],[3340,3482,"Oh, so you admit it."],[3516,3645,"There is something going on with him."],[3737,3987,"So the rumor is true!"],[4037,4187,"Hazel's the one coming"],[4187,4412,"between Marcus and Zoe."],[4450,4571,"What a slut."],[4608,4696,"I thought she'd be"],[4696,4846,"as innocent as she looks."],[5017,5130,"I never came"],[5130,5338,"between you and Marcus."],[5384,5492,"You were literally married"],[5492,5689,"to someone else just a few months ago."],[5705,5764,"Oh, really?"],[5764,5822,"Then why are you"],[5822,5943,"sending Marcus nudes"],[5943,6051,"in the middle of the night?"],[6076,6177,"I never did that."],[6177,6281,"You have no proof."],[6348,6652,"Oh, she's playing innocent."],[6802,7040,"Well, probably that's how she gets"],[7040,7169,"what she wants."],[7223,7261,"Why?"],[7261,7503,"You like taking nudes, huh?"],[7503,7724,"Well, let's take some nudes for her."],[7782,7832,"Stop!"],[7832,7887,"Stop it!"],[7887,7987,"Let go of me!"],[8433,8575,"Why are you covering your stomach?"],[8796,8996,"Oh my God, are you pregnant?"]],"18":[[70,271,"Oh my God, are you pregnant?"],[342,442,"Are you insane?"],[487,596,"Let go of me!"],[621,696,"Why aren't you"],[696,821,"answering the question?"],[821,980,"Are you really pregnant?"],[1096,1172,"Who's the father?"],[1472,1514,"No!"],[1514,1584,"Please stop!"],[1584,1634,"Help!"],[1634,1697,"Help!"],[1755,1851,"Let go!"],[1960,2031,"Stop!"],[2031,2068,"Help!"],[2068,2173,"Somebody help me!"],[2214,2335,"What the fuck are you doing?"],[2902,3019,"What are you doing here?"],[3019,3107,"Stopping this madness"],[3107,3194,"before it goes any further."],[3194,3328,"God knows what you're about to do."],[3440,3578,"Zoe, you have crossed a line."],[3578,3695,"I want you to apologize"],[3695,3807,"to Hazel now."],[3924,4033,"Oh, come on."],[4112,4266,"I was just teaching her a lesson."],[4304,4408,"She is a homewrecker"],[4408,4462,"after all."],[4521,4637,"The only homewrecker here"],[4637,4700,"is you."],[4700,4792,"What the hell, Ethan?"],[4792,4925,"Just because you like Hazel"],[4925,5075,"doesn't mean you have to lie about me."],[5075,5117,"Lie?"],[5188,5276,"You must know better than I do"],[5276,5342,"if I'm lying."],[5384,5434,"Fine."],[5509,5622,"Let's ask you then."],[5680,5918,"Marcus, who's the real homewrecker?"],[5918,5972,"Me"],[6097,6181,"or Hazel?"]],"19":[[0,120,"Who's the real homewrecker?"],[120,171,"Me"],[279,362,"or Hazel?"],[725,905,"Remember, you told my mom"],[905,1009,"you'd protect me forever."],[1213,1280,"Marcus,"],[1393,1576,"Zoe is all I have."],[1710,2131,"Her dad gave his life to save your father."],[2223,2494,"It wasn't easy raising her on my own."],[2690,2986,"Please, promise me."],[3090,3278,"You will always look after her."],[3486,3632,"I promise, Mrs. Carter."],[4079,4250,"I will take care of Zoe."],[5125,5238,"Zoe is..."],[5526,5613,"not the homewrecker."]],"20":[[83,196,"Zoe is..."],[304,396,"not the homewrecker."],[592,696,"We're married,"],[709,946,"but he's still standing up for her."],[1005,1146,"I guess the homewrecker"],[1146,1322,"is the one that gets no love."],[1363,1443,"But there's a"],[1443,1576,"misunderstanding here."],[1630,1780,"Yes, Marcus is right."],[1780,1926,"There has been a misunderstanding."],[2085,2210,"Well, we were never together."],[2227,2352,"Not now, not before."],[2515,2627,"Happy now, Miss Carter?"],[2673,2790,"Looks like I was wrong."],[2940,2994,"Let's go."],[3382,3536,"Aww, how sweet."],[3620,3732,"I hope Ethan doesn't judge her"],[3732,3812,"because of me."],[3853,4008,"Stop acting like"],[4008,4195,"we didn't break up three years ago."],[4229,4266,"From now on,"],[4266,4425,"I want you to stay away from Hazel."]],"21":[[104,175,"Doing better?"],[367,437,"I'm fine."],[600,721,"By the way, I still have to sort through"],[721,900,"all those athlete profiles."],[921,1026,"Let me take care of it."],[1067,1172,"Just get some rest, okay?"],[1776,1989,"Don't get your hopes up, Hazel."],[2002,2223,"You mean nothing to Marcus."],[2452,2544,"What are you doing here?"],[2569,2665,"Hazel, let me explain."],[2665,2727,"Save it,"],[2740,2815,"and get out."],[2957,3078,"Your Zoe is never gonna"],[3078,3165,"stop harassing me,"],[3165,3328,"so just leave or I'll go."],[3428,3490,"Wait!"],[3778,3941,"I pulled a muscle in training."],[4124,4229,"I need a massage."],[4458,4621,"Ethan can do it, when he gets back."],[4688,4733,"No."],[5034,5109,"I want you."]],"22":[[62,154,"Why so shy?"],[304,429,"You've had your hands all over me"],[429,538,"the last three years."],[1605,1680,"How's this?"],[1897,1960,"Lower."],[2786,2840,"Here?"],[3311,3370,"Lower."],[4120,4216,"Hazel, look at me."],[4408,4542,"There's something I wanna tell you..."]],"23":[[37,171,"There's something I wanna tell you..."],[721,863,"Um, Ethan, now that you're back,"],[863,1013,"you can take over for Marcus."],[1247,1418,"Scared he'll get the wrong idea?"],[2439,2531,"What's his problem?"],[2569,2794,"What did Marcus want to tell me?"],[3382,3507,"Why did you tell everyone at the bar"],[3507,3670,"that we broke up three years ago?"],[3757,3874,"Was it for that bitch, Hazel?"],[3920,4062,"You don't need to worry about her."],[4099,4295,"You looked me in the eyes"],[4295,4416,"and called me her name!"],[4421,4517,"You jerk!"],[4650,4713,"Hazel..."]],"24":[[116,233,"You promised my mom"],[233,408,"that you would take care of me for life."],[429,554,"And now you're ganging up on me"],[554,654,"with another woman?"],[763,817,"Okay, you're right."],[817,992,"I did promise your mom."],[992,1142,"And I did love you."],[1201,1280,"But you were the 