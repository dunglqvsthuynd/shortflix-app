the chance."],[1480,1530,"No."],[1697,1893,"The one who wants your life isn't me."],[1964,2231,"It's your beloved husband."],[2515,2606,"That can't be true."],[5259,5367,"Killian..."],[5534,5643,"I want you."],[5834,5943,"Make love to me."],[6423,6598,"Are you sure you wanna do this now?"],[6994,7069,"Yes."],[7269,7344,"I'm positive."]],"58":[[1426,1622,"I won't be able to stop this."],[1676,1764,"Will I die?"],[2031,2152,"The High Priestess has said that"],[2168,2344,"if you apply this to Luna's birthmark"],[2344,2444,"before you two mate,"],[2444,2535,"it will save her life."],[2706,2756,"No."],[3053,3174,"I won't let that happen."],[4170,4308,"You are still lying to me."],[4408,4558,"If this is what you want, Killian,"],[4629,4767,"then I'll pay you back with my life."],[4884,5150,"But there will never be another girl"],[5213,5347,"who loves you like I did."]],"59":[[16,183,"Adrian dared to lay hands"],[183,291,"on his own brother,"],[291,404,"the Alpha King."],[475,608,"According to the law of the pack,"],[608,804,"he will be cast out as a rogue."],[838,946,"Thank you, Alpha Blair."],[984,1138,"What about my son Killian?"],[1138,1213,"How is he?"],[1238,1422,"Fortunately, Luna arrived in time."],[1484,1559,"They're still in the room"],[1559,1634,"and should have completed"],[1634,1764,"the mating process by now."],[1822,1956,"Naomi Summers is officially"],[1956,2139,"the first human Luna."],[2218,2419,"How the powerful Storm Pack"],[2419,2598,"could allow a human Luna?"],[2656,2744,"It's insulting."],[2861,3086,"But as long as,"],[3132,3299,"Killian's curse is lifted,"],[3299,3582,"I suppose she died with some purpose."],[3724,3799,"Died?"],[4024,4083,"High Priestess,"],[4083,4187,"didn't you tell me the potion"],[4187,4316,"will protect Luna Naomi?"],[4525,4617,"That was-"],[4662,4825,"A white lie."],[4925,5080,"I came up with a plan"],[5080,5296,"to ensure that Killian lives."],[5422,5497,"Oh shit."],[5597,5647,"Oh shit!"],[5647,5697,"No!"],[5697,5780,"No, no, no, no!"]],"60":[[1455,1551,"I love you, Naomi."],[1914,2006,"I'd give my life"],[2006,2143,"to protect you and the pack."],[2352,2439,"I always will."],[2702,2761,"Alpha!"],[2852,2898,"Alpha!"],[2898,2977,"What?"],[2977,3057,"What is it?"],[3190,3253,"Alpha."],[3916,3966,"Alpha."],[4058,4200,"The potion that the High Priestess"],[4200,4258,"gave you..."],[4462,4579,"It's a fake."]],"61":[[796,863,"Naomi."],[1151,1230,"Naomi."],[1384,1455,"Wake up."],[1488,1551,"Fuck."],[1701,1785,"Call a doctor!"],[1889,1956,"Hey."],[2056,2114,"Naomi..."],[2164,2227,"Naomi!"],[4187,4258,"No!"],[4475,4688,"You said that it would work, Joey!"],[4788,4888,"You said!"],[4979,5080,"I'm sorry."],[5609,5726,"Naomi, wake up."],[5968,6210,"My name is Naomi Summers."],[6510,6752,"I got you this good luck charm."],[6877,6994,"Happy birthday, Killian."],[7073,7152,"Make a wish."],[7182,7311,"I think I'm in love with you."],[7390,7474,"Will I die?"],[7615,7670,"No."],[7887,7999,"Naomi, wake up."],[8124,8195,"Wake up."]],"62":[[8,120,"Naomi, wake up."],[179,321,"You're the Alpha King!"],[354,654,"How can you cry over some human?"],[1167,1259,"She's dead."],[1326,1468,"Bury her and leave it at that."],[1564,1697,"She should feel honored"],[1697,1906,"that she died for a noble cause."],[1947,2060,"She's not dead."],[2289,2360,"She's not dead."],[2360,2456,"She's just sleeping."],[2848,2990,"Fucking pull yourself together."],[3040,3178,"I taught you better than this!"],[3382,3524,"I taught you better than this."],[3832,3933,"This is your fault."],[4070,4195,"And this is your fault."],[4408,4550,"And you guys are gonna pay"],[4596,4721,"for what you did!"]],"63":[[1009,1222,"Alpha Blair has been severely injured,"],[1222,1372,"but is expected to live."],[1526,1672,"As for the High Priestess,"],[1672,1851,"she has been stripped of her title,"],[1851,1926,"and..."],[2006,2164,"will be kicked out of the pack."],[2756,2781,"Alpha!"],[2781,2836,"Alpha!"],[2836,2886,"Alpha!"],[3828,3920,"Alpha, you're awake."],[4333,4404,"Where is she?"],[4667,4900,"We... we've returned her body"],[4900,4984,"back to her grandmother"],[4984,5067,"for burial."],[5351,5497,"Her, her grandmother says that"],[5497,5647,"you cannot attend, so..."],[5772,5947,"so that Naomi may rest in peace."],[6118,6243,"She's fucking dead."],[6423,6527,"And it's my fault."],[6639,6715,"It's my fault."],[6936,7011,"Naomi!"],[7386,7511,"Naomi, please!"],[7511,7645,"Just stay!"],[7645,7757,"Don't leave me!"],[7757,7836,"Please!"]],"64":[[329,513,"I should never have let you"],[513,696,"accept his help."],[763,1105,"That man is a monster,"],[1105,1297,"and it cost you your life."],[1422,1597,"Oh, please, God."],[1701,1822,"If you're listening,"],[1860,2047,"please take care of my granddaughter."],[2047,2152,"Make her safe."],[2210,2435,"And I'll give anything."],[2435,2652,"I'll, I'll trade my life for hers."],[2711,2890,"Your God can't save her."],[2994,3132,"But maybe I can."],[3274,3357,"Who are you?"],[3670,3878,"I used to be the High Priestess."],[3933,4308,"I'm Cordelia Ostara, the last of my name."],[4429,4725,"I swore an oath to protect my pack,"],[4813,4950,"but went back on my promise"],[4950,5230,"and lied to my Alpha."],[5326,5518,"This cost your granddaughter's life."],[5601,5693,"I'm here,"],[5843,5972,"to right my wrong."]],"65":[[734,875,"A baby is forming..."],[967,1101,"the first of its kind."],[1213,1488,"Half-Alpha, half-human."],[1530,1739,"Naomi's pregnant?"],[1810,2085,"With a werewolf forming in her belly."],[2227,2398,"This might just work."],[2727,2798,"Live!"],[2927,3161,"Naomi, live!"]],"66":[[421,538,"It's been seven years."],[621,696,"I dream about you"],[696,809,"every time I go to bed."],[884,1046,"And when I wake up, you're never there."],[1176,1376,"If you're trying to punish me, Naomi,"],[1376,1455,"it's working."],[1534,1634,"Once I find someone"],[1634,1780,"to replace me as the Alpha,"],[1843,2102,"I'll join you and apologize myself."],[2135,2227,"Just wait for me."],[2706,2819,"Alpha,"],[2819,2936,"your meeting has started."],[3319,3378,"Hi!"],[3378,3532,"Wolfie-cart delivery!"],[3532,3699,"Seriously, a kid?"],[3970,4095,"Hey, kid!"],[4204,4283,"Watch it!"],[4387,4575,"Annie, I told you not to run around, okay?"],[4725,4888,"Listen, um, I'm really sorry."],[4904,4992,"She was just trying to help."],[4992,5113,"She didn't mean any harm, okay?"],[5392,5463,"Single mom?"],[5647,5739,"Don't bring your kid around here"],[5739,5814,"causing trouble."],[5880,5939,"We don't need you"],[5939,6064,"delivering for the company anymore."],[6064,6114,"No."]],"67":[[8,221,"No, um, this is all just"],[221,325,"a big misunderstanding."],[325,412,"I'm really sorry."],[625,771,"I'm sorry, Mommy."],[771,934,"I didn't mean to."],[1172,1276,"Annie, no."],[1322,1380,"It's okay."],[1501,1668,"I'll be sure to leave you a bad review"],[1668,1768,"and get you fired."],[1768,1826,"No, no."],[1826,1968,"I really need this job."],[2027,2164,"I have nothing."],[2248,2352,"We have no one."],[2402,2456,"Okay."],[2456,2569,"Not my problem."],[2590,2644,"Maybe you shouldn't have"],[2644,2723,"gotten knocked up."],[2723,2777,"No!"],[3357,3536,"That's the CEO's car!"],[3570,3682,"Killian Storm is here?"],[3724,3816,"Oh my God."],[3849,3962,"Excuse me, ma'am."],[3983,4158,"What is a CEO?"],[4158,4433,"A CEO is the most powerful man"],[4433,4504,"in the company."],[4550,4650,"He calls all the shots."],[4650,4821,"And Killian Storm"],[4842,5075,"is the most powerful CEO of them all."],[5100,5292,"So he can help Mommy."],[5292,5401,"I have five meetings today."],[5401,5467,"Then you can"],[5467,5568,"go to your- - Go."],[5568,5663,"You can go to your meetings."],[5663,5709,"I just, I just."],[5709,5776,"I can."],[5776,5847,"I'm allowed."],[5864,5985,"You're telling me, the boss?"],[5985,6056,"Yes, I-"]],"68":[[1284,1534,"Please, please don't get my mommy"],[1534,1647,"into trouble."],[1668,1772,"What's a kid doing here?"],[1772,1947,"Please, please don't get my mommy"],[1947,1989,"into trouble."],[1989,2085,"Is this some sort of new scam?"],[2085,2131,"Please, sir."],[2131,2218,"Please!"],[2268,2398,"Help my mommy."],[2419,2552,"I'll do anything."],[2569,2781,"Just don't take her job away."],[4738,4829,"Please, sir."],[4829,4875,"Please."],[4875,5021,"I'm begging you."],[5321,5634,"Why does it hurt when I see her cry?"]],"69":[[0,45,"You okay?"],[45,104,"Please."],[104,279,"It was all my fault."],[316,554,"Mommy didn't do anything wrong."],[638,842,"You're the CEO, right?"],[842,971,"You can help her."],[1005,1117,"Please."],[1397,1472,"What's your name?"],[1568,1622,"Annie."],[1664,1797,"My name is Annie."],[1885,1956,"Come on, Annie."],[2068,2189,"Let's go inside over here, alright?"],[3257,3345,"Killian Storm?"],[3432,3528,"Oh crap."],[3599,3745,"I can't let him know we have a daughter."],[3782,3937,"He'll take her away from me for sure."],[4020,4095,"Mommy!"]],"70":[[246,325,"Daddy!"],[863,930,"What was that?"],[988,1176,"I think you're my daddy."],[1255,1459,"I see you in my dreams."],[1526,1580,"Wow, sir."],[1580,1730,"I didn't know you had a daughter."],[1768,1922,"Daddy, what's your name?"],[2072,2156,"Killian Storm."],[2281,2414,"Alpha of the Storm Pack"],[2414,2610,"and CEO of this company."],[2610,2690,"Wow."],[2711,2890,"So you're a werewolf."],[2915,3078,"I'm a werewolf, too."],[3103,3207,"But Mommy says"],[3207,3445,"I'm a special kind of werewolf."],[3566,3641,"Is that right?"],[3782,3845,"You know what, sir?"],[3845,3908,"She actually..."],[3995,4145,"she looks a lot like you."],[4237,4304,"No, no."],[4304,4366,"That's not..."],[4366,4496,"Annie, can you please come here?"],[4871,4925,"I told you not to"],[4925,5038,"watch too much TV, okay?"],[5075,5171,"That's not your daddy."],[5238,5580,"Then where's Annie's daddy?"],[5618,5730,"I'm sorry, Annie."],[5751,5910,"I can't let you know he's your dad."],[5955,6264,"Why does her voice sound so familiar?"],[6815,6873,"Naomi."],[7244,7307,"Naomi."],[7540,7599,"Is that you?"]],"71":[[29,87,"Naomi."],[208,266,"Is that you?"],[517,759,"No, um, no."],[784,871,"I'm just a..."],[913,1059,"a normal delivery person."],[1101,1197,"That's right, Alpha."],[1226,1443,"A useless delivery person"],[1443,1622,"who made a mess at the company."],[1630,1805,"A useless single mother"],[1826,1993,"and a troublemaker kid."],[1993,2064,"Hey!"],[2210,2248,"You know what?"],[2248,2335,"I'm not going to sit here"],[2335,2464,"and watch you be disrespectful"],[2464,2552,"to a mother and daughter"],[2552,2702,"who are simply trying to"],[2702,2840,"deliver some packages."],[3007,3098,"Apologize to her."],[3140,3190,"Now."],[3528,3595,"I'm sorry."],[3628,3674,"We've been having"],[3674,3816,"a lot of issues with you, Selina,"],[3816,3874,"haven't we?"],[3958,4049,"Now that I think about it,"],[4049,4204,"I don't really want a receptionist"],[4204,4283,"that thinks she's better"],[4283,4366,"than everyone else."],[4533,4592,"Security!"],[4725,4804,"Let's get her out of here."],[4863,5009,"No, you're fired, Selina."],[5038,5230,"Alpha, I'm sorry."],[5230,5317,"I can do better."],[5317,5417,"Give me another chance."],[5943,6001,"Hey, kid."],[6210,6289,"How old are you?"],[6360,6406,"I'm-"],[6406,6460,"Five."],[6581,6635,"She is..."],[6677,6735,"She's five."],[6735,6915,"But, um, we really do have"],[6915,7019,"some important deliveries,"],[7019,7178,"so if you could excuse us."],[7261,7349,"She's five."],[7399,7536,"Even if Naomi were still alive,"],[7536,7674,"my daughter would be six."],[7741,7887,"Maybe I am really losing it."],[7974,8045,"All right, Joey."],[8045,8145,"Prepare for the next meeting."],[8145,8229,"We've got a lot to do."],[8229,8291,"Yes, sir."],[9042,9317,"Mommy, I'm six, not five."],[9351,9459,"Why did you lie?"],[9534,9605,"I know, sweetie."],[9667,9751,"I know you're six."],[9788,9972,"Just, um, please don't ever talk"],[9972,10072,"to that man again, okay?"],[10101,10210,"Okay."],[10243,10352,"I can feel it."],[10352,10518,"He's my wolf dad."],[10518,10698,"Mommy got so strange"],[10698,10831,"after seeing him."],[10831,11031,"Mommy, don't cry."],[11061,11265,"Is it because work's too hard?"],[11348,11628,"Annie's a strong little wolf, too."],[11649,11782,"I can help you."],[11824,11866,"Thank you."],[11928,12003,"Thank you, baby."],[12066,12157,"Let's go, okay?"]],"72":[[400,546,"Hi, great-grandmama."],[571,638,"Mommy and I"],[638,846,"got all the deliveries done today."],[888,975,"We sure did."],[1017,1130,"It is all thanks to Annie"],[1130,1247,"for being such a good helper."],[2085,2235,"Grandma, I wish you could've"],[2235,2331,"seen her grow up."],[2427,2531,"You would've loved her."],[2744,2815,"Hey, Annie?"],[2886,3107,"Since you did such a great job today,"],[3140,3203,"why don't we go to"],[3203,3370,"your favorite burger spot for a dinner?"],[3395,3490,"No, Mommy."],[3511,3666,"I don't need a reward."],[3666,3916,"We have to save up to pay rent, don't we?"],[3949,3999,"Oh."],[4054,4175,"Oh, no, Annie, no."],[4258,4333,"I don't, I don't want you"],[4333,4496,"to have to focus on things like that."],[4558,4704,"You just focus on being"],[4704,4875,"the happiest little kid in the world, okay?"],[4896,5092,"I am the happiest kid, Mommy,"],[5092,5238,"because I have you."],[5409,5526,"Mommy, a bunny!"],[5526,5722,"No, Annie, please stay close."],[5751,5834,"Maybe I shouldn't be"],[5834,5955,"hiding things from Annie."],[6060,6177,"If she lived with Killian,"],[6177,6314,"she wouldn't have to live in poverty."],[6452,6752,"She could have anything she wants."],[6944,7007,"Huh?"],[7040,7211,"Isn't that Mommy's photo?"],[7244,7428,"Why is there a grave for her?"],[7490,7611,"Mommy, come here!"],[7611,7786,"I found your grave!"]],"73":[[383,529,"He made a fake headstone"],[529,646,"to make himself feel better."],[1780,1839,"Mommy!"],[1860,1931,"Mommy!"],[1931,1997,"Um, can you,"],[1997,2064,"can you please"],[2064,2173,"get Mommy's medicine?"],[2736,2882,"It's not here."],[3795,3858,"Naomi?"],[4054,4116,"Naomi!"]],"74":[[346,412,"Naomi?"],[980,1067,"Where did you go?"],[1326,1530,"Where did you go all these years?"],[1847,1976,"Why couldn't I find you?"],[2752,2827,"What's wrong with her?"],[2861,3003,"I'm afraid I don't know, sir."],[3003,3190,"I've never seen anything like it."],[3415,3465,"You don't know"],[3465,3545,"what's wrong with her?"],[3570,3699,"And you call yourself a doctor,"],[3699,3741,"and you don't know"],[3741,3820,"what's wrong with her?"],[3837,3928,"If something happens to her"],[3928,4024,"in this hospital"],[4024,4137,"because of your incompetence,"],[4137,4237,"I'm going to make sure"],[4237,4366,"this building goes under."],[4408,4462,"And you're going to be"],[4462,4562,"out of a fucking job,"],[4562,4654,"do you understand me?"],[4654,4825,"I'll recheck the results"],[4825,4917,"immediately, sir."],[5267,5397,"Is this because of my curse?"],[5626,5768,"Is Naomi sick because of me?"],[6177,6256,"Hey..."],[6377,6456,"you're safe."],[6456,6539,"You're in a hospital."],[6952,7019,"You feel okay?"],[7107,7178,"Where is Annie?"],[7365,7453,"Where is my daughter?"]],"75":[[29,87,"Killian,"],[187,371,"where is my daughter?"],[371,467,"Give her back to me!"],[467,563,"I know the truth."],[600,813,"Because Joey and I did a DNA test."],[834,959,"And she's my daughter too."],[1209,1297,"What happened?"],[1351,1443,"I don't understand."],[1443,1530,"Where have you been?"],[1559,1659,"Where did you go?"],[1659,1718,"Please."],[1801,1922,"I am begging you."],[1985,2135,"Please just give her back to me."],[2185,2331,"Haven't I done enough for you?"],[2389,2481,"I died for you."],[2719,2982,"Annie is all that I have left"],[2982,3061,"in this world."],[3061,3211,"Please just give her back to me."],[3211,3328,"I don't understand."],[3328,3420,"I love you."],[3474,3603,"There hasn't been a single minute"],[3603,3699,"that I haven't thought about you."],[3699,3795,"Not a single day."],[3795,3853,"And I..."],[3899,3995,"I..."],[4108,4166,"I mean, I thought, I thought"],[4166,4225,"you were dead."],[4225,4425,"Because you killed me, Killian!"],[4625,4729,"You've lied to me."],[4971,5134,"You knew I was gonna die."],[5146,5292,"And you let me go through with it."]],"76":[[66,158,"You didn't even have the courage"],[158,262,"to tell me the truth."],[279,542,"That's not what happened."],[579,629,"Okay?"],[671,754,"The High Priestess,"],[754,967,"she tricked me into lying to you."],[967,1084,"No, that's not true."],[1326,1409,"She saved me."],[1543,1634,"What are you talking about?"],[1664,1822,"She gave up her life for mine."],[1910,1997,"And for Annie."],[2110,2227,"The side effect is that"],[2227,2414,"I now bear the weight of your curse."],[2540,2727,"So believe me when I say"],[2794,3003,"that I have done enough for you,"],[3003,3053,"Killian."],[3182,3328,"I gave up everything for you."],[3436,3545,"I died for you."],[3611,3849,"And every day I go through your pain,"],[3849,3937,"your curse."],[3991,4145,"And now I raise our daughter"],[4145,4262,"all by myself,"],[4262,4366,"with no one's help."],[4833,4946,"So please,"],[5038,5259,"please just give me back my daughter."],[5259,5397,"And go away!"]],"77":[[37,187,"You haven't changed a bit, have you?"],[642,775,"You feel better now, don't you?"],[775,963,"That's how I felt every single time"],[963,1096,"you kissed me all those years ago."],[1359,1501,"Look, I didn't know"],[1501,1597,"that you were gonna die."],[1659,1739,"My father came up"],[1739,1881,"with a plan to trick me."],[1981,2143,"He somehow got the High Priestess"],[2143,2419,"to lie to me about the potion."],[2489,2623,"I thought that that potion"],[2765,2890,"would keep you alive."],[3098,3186,"That's why I put it"],[3186,3319,"on your birthmark that night."],[4054,4166,"Why should I believe you?"],[5221,5326,"Why would I keep this"],[5397,5505,"all of these years"],[5638,5739,"if I didn't love you?"]],"78":[[145,229,"Is it-"],[350,454,"After what happened,"],[625,838,"I imprisoned Adrian and my father."],[921,1121,"I didn't know that the Priestess saved you."],[1359,1447,"Had I known that,"],[1447,1584,"we wouldn't have lost"],[1584,1718,"these last seven years."],[1764,1872,"We already have a daughter."],[1939,2031,"Are you going to make her grow up"],[2031,2106,"without a father?"],[2302,2389,"Where is Annie?"],[2510,2569,"She's safe."],[2569,2640,"She's with Joey."],[2640,2752,"She's at Wolfland."],[2973,3082,"I rented out the whole park"],[3082,3244,"so that she wouldn't have to wait in line."],[3244,3303,"Because I know that she's,"],[3390,3524,"she's always wanted to go there."],[3712,3782,"It's late."],[3824,3908,"I wanna see her."],[3987,4066,"It's past her bedtime."],[4066,4187,"She's gonna be back soon."],[4258,4404,"You think Annie's better off with you"],[4404,4533,"because you can give her everything?"]],"79":[[16,58,"No."],[116,258,"I think she's better with both of us."],[354,479,"Just give me another chance."],[479,538,"One more."],[1351,1434,"Mommy!"],[1468,1551,"Daddy!"],[1551,1609,"Annie."],[1968,2202,"Mommy, Uncle Joey took me on"],[2202,2398,"all the rides at Wolfland."],[2431,2619,"Even the Princess Moon ride."],[2619,2911,"Even got two ice creams."],[2927,3199,"I tried to save you one, but it melted."],[3357,3474,"Luna Naomi, it's..."],[3695,3812,"It's just been so long."],[3974,4154,"The Alpha cries every night"],[4154,4266,"since you left."],[4550,4658,"Sometimes he breaks down"],[4658,4833,"and grabs my hand and cries."],[4913,4971,"Please."],[4992,5084,"One time, this girl"],[5084,5150,"tried to hit on him,"],[5184,5384,"and he ugly cried right in front of her"],[5384,5476,"and she got disgusted"],[5476,5559,"and ran away."],[5559,5676,"It was crazy."],[5705,5814,"Basically what I'm trying to say"],[5814,5955,"is he cries everywhere."],[5955,6001,"It's-"],[6001,6060,"Joey."],[6122,6189,"It's enough."]],"80":[[487,571,"Do you believe me?"],[880,955,"Do you forgive me?"],[1309,1388,"I..."],[1643,1730,"I'll think about it."],[1730,1918,"Then while you think about it,"],[1931,2173,"can we go see Daddy's house?"],[2198,2444,"Uncle Joey said it's huge."],[2573,2640,"With your permission,"],[2640,2711,"of course."],[2806,2894,"If you'd allow me."],[3098,3232,"I'd like to take both of you"],[3261,3315,"home."],[3820,3874,"What do you say?"],[4362,4429,"Yes."],[4604,4654,"Yes."]]}