{"1":[[129,325,"It's the year 2028."],[350,546,"Humans and werewolves"],[546,729,"live together in harmony."],[900,1096,"But a dark secret looms"],[1096,1292,"in the werewolf world."],[1409,1693,"The Alpha King is cursed."],[2540,2594,"Alpha,"],[2723,2898,"new she-wolves will be arriving soon."],[3795,3845,"Let's go."],[4229,4346,"Alpha Killian,"],[4450,4662,"these are the five she-wolves"],[4662,5075,"born under full moon from various packs."],[5459,5726,"Turn around and remove your robes."],[6373,6481,"None of these girls"],[6481,6664,"have the Polaris birthmark."],[7007,7082,"Everybody out."],[7127,7198,"Now."],[7545,7645,"I'm running out of time here."],[7686,7786,"Turn 30 next month,"],[7786,7874,"you realize that, right?"],[7899,8049,"We will find her, sir."],[8078,8254,"We will find your mate before-"],[8254,8295,"Before what..."],[8295,8366,"I, uh..."],[8366,8533,"violently die from this curse?"],[8612,8742,"Find me my fated mate,"],[8804,8954,"or find me a fucking coffin."],[9534,9638,"I thought Alpha Killian"],[9638,9747,"brought us here to,"],[9747,9918,"you know, have an orgy."],[9926,10010,"Seriously?"],[10030,10164,"If the Alpha King Killian Storm"],[10164,10272,"wanted to fuck she-wolves,"],[10272,10439,"he certainly wouldn't pick you."],[10489,10635,"Don't you guys think it's weird?"],[10677,10789,"Alpha Killian has brought"],[10789,10973,"hundreds of girls to his packhouse."],[10998,11136,"And no one is allowed to talk about"],[11136,11244,"what happens here."],[11244,11453,"And all he does is look at our asses?"],[11478,11615,"Something must be wrong with him."],[13363,13455,"Oh, Grandma,"],[13455,13555,"please don't worry."],[13563,13713,"I will come visit you in the hospital."],[13759,13905,"And don't worry about medical bills,"],[13905,14047,"I will make sure that I-"]],"2":[[909,975,"Sir?"],[1076,1209,"Sir, are you alright?"],[1484,1609,"I need an ambulance!"],[2168,2235,"Oh, crap."],[2235,2348,"I hope he's okay."],[2394,2485,"He didn't look hurt."],[2494,2623,"I wonder why he passed out."],[3019,3057,"Oh."],[3123,3253,"Um, sir, you're awake."],[3269,3382,"Listen, you passed out"],[3382,3499,"and I brought you to the hospital."],[4175,4266,"No, no, no, no, no, no."],[4266,4371,"She can't be my fated mate."],[4371,4458,"She's human."],[4521,4621,"Why is this happening?"],[4700,4850,"From the looks of it, he's a werewolf."],[5213,5288,"What's your name?"],[5334,5618,"Um, my name is Naomi Summers."],[5705,5843,"You almost hit me with your car."],[5897,6068,"Well, she clearly smells like a human."],[6076,6172,"How's that possible?"],[6222,6335,"A human is my mate."],[6481,6656,"Sir, I really think you should sit down."],[6723,6869,"Remove your shirt and turn around."],[6915,6990,"Excuse me?"],[7436,7528,"She's the one."],[7615,7699,"She's my mate."]],"3":[[33,112,"She's the one."],[158,229,"She's my mate."],[734,867,"I should have just left you there."],[913,1009,"I just saved your life,"],[1009,1192,"and this is the kind of shit that you pull?"],[1605,1693,"Wait, wait."],[1931,2022,"What's wrong with you now?"],[2022,2114,"You're almost 30."],[2114,2210,"That's why these things"],[2210,2439,"are so much more frequent."],[2439,2527,"He's burning up."],[2527,2590,"Maybe there's something"],[2590,2690,"really wrong with him."],[2690,2848,"Hey, let's get you back to bed, okay?"],[2848,2957,"Whenever she touches me,"],[2957,3203,"the pain just disappears."],[5351,5526,"Nobody's ever bitten me like that before."],[5739,5885,"That was my first kiss."],[5993,6131,"You are an asshole!"],[6435,6623,"I need to learn more about you,"],[6681,6902,"Naomi Summers."]],"4":[[50,141,"What a prick."],[141,279,"How's he just gonna kiss me like that?"],[588,663,"Hey, Grandma."],[721,800,"Sweetheart,"],[800,950,"your phone call got disconnected."],[950,1076,"Is everything okay?"],[1155,1201,"Yeah."],[1242,1438,"Yeah, um, everything's fine."],[1526,1576,"I'm..."],[1576,1701,"I'm actually in the hospital right now,"],[1701,1768,"so I'll just..."],[1768,1856,"I'll come over and see you."],[1951,2027,"It's okay."],[2027,2110,"He's a werewolf."],[2177,2331,"I'll just pretend I got licked by a dog."],[2364,2498,"It's not like I'll ever see him again."],[2952,3115,"Grandma, how are you?"],[3136,3228,"Did they finally schedule"],[3228,3349,"your heart bypass surgery?"],[3403,3582,"I don't plan on having surgery."],[3603,3674,"What?"],[3707,3774,"Why?"],[3774,3837,"Why not?"],[3849,4029,"You start college in a few days,"],[4029,4212,"and the tuition is due,"],[4212,4391,"and we can't afford to be in debt"],[4391,4529,"any more than we already are."],[4529,4758,"And I don't wanna be your burden."],[4758,4846,"No, no, Grandma."],[4846,4992,"You can never be my burden."],[5059,5234,"You're the only family I have left."],[5597,5734,"If you don't get the surgery,"],[5751,5897,"then I'm not going to college."],[5964,6177,"Naomi, you graduated"],[6177,6398,"valedictorian in your class."],[6460,6623,"You have to go to college."],[6664,6890,"That is not up for discussion."],[6940,6990,"Grandma,"],[7027,7232,"your heart is not up for discussion."],[7278,7407,"If you get the surgery,"],[7407,7536,"then I will go to college."],[7607,7670,"Deal?"],[8875,9009,"Sorry for the wait, sir."],[9079,9221,"Did you at least find some information"],[9221,9288,"on this girl?"],[9288,9363,"Yes, sir."],[9392,9538,"The folder is in the car for you to review."],[10047,10172,"Naomi Summers."],[10260,10377,"Let's see who you are."]],"5":[[1046,1092,"Hello?"],[1092,1188,"Hello, Ms. Summers."],[1230,1330,"Just calling to let you know"],[1330,1430,"that your tuition has been"],[1430,1576,"fully paid by a sponsor."],[1601,1651,"You can now - Yes!"],[1651,1743,"register for class."],[1843,1989,"Oh my God, really?"],[1989,2277,"Also, a scholarship of $20,000"],[2277,2423,"has been deposited into your account."],[2469,2677,"I cannot express how grateful I am."],[2677,2727,"Thank you."],[2781,2831,"Um,"],[2907,2948,"can I please"],[2948,3044,"have the name of the sponsor?"],[3044,3190,"I would love to thank them in person."],[3424,3549,"Naomi Summers."],[3766,3883,"Let's see what you're made of."],[4200,4304,"Hello, everyone,"],[4304,4454,"and welcome to orientation."],[4475,4604,"My name is Naomi Summers,"],[4604,4667,"and I am your"],[4667,4746,"student representative"],[4746,4892,"for the class of 2028."],[5205,5326,"I heard that girl Naomi"],[5326,5526,"is a country bumpkin hillbilly."],[5526,5626,"It is my great honor"],[5626,5747,"to be with you all here today."],[5747,5901,"She got in on a scholarship."],[5914,6047,"I can't believe the school asked her"],[6047,6177,"to do the opening speech."],[6218,6368,"She looks so ratchet."],[6385,6439,"Yeah."],[6477,6560,"Ella should have been the one"],[6560,6656,"to give the speech."],[6677,6773,"You're so much better"],[6773,6886,"than that ugly loser."],[6886,7007,"The school probably picked her"],[7007,7190,"to represent poor people."],[7223,7340,"You know, diversity."],[7561,7636,"Thank you so much,"],[7636,7799,"and I hope you have a great school year."],[7932,8033,"Everyone, please"],[8033,8137,"give a round of applause"],[8137,8224,"for our next guest,"],[8224,8383,"our school's biggest donor,"],[8383,8533,"Mr. Killian Storm."],[8812,8921,"Remember to smile"],[8921,9046,"and give him your warmest welcome."],[9117,9321,"Mr. Storm is the Werewolf Alpha King,"],[9321,9488,"the sponsor of your tuition."],[9488,9563,"Of course, sir."]],"6":[[1751,1843,"What's going on here?"],[1856,1956,"Pick up the flowers."],[2248,2394,"Um, Mr. Storm."],[2477,2544,"Thank you."],[2602,2798,"And on behalf of all of the students"],[2798,2952,"in the scholarship program,"],[2952,3132,"I would like to extend my gratitude."],[3520,3670,"And I will pay you back"],[3703,3820,"every penny that I owe you,"],[3820,3970,"once I graduate and find a job."],[4058,4179,"That's not what I want,"],[4191,4291,"and you know that."],[4354,4508,"Apologies, Mr. Storm."],[4529,4654,"But I'm not that kind of girl."],[4692,4775,"I want to pay you back."],[4775,4863,"I'm really not interested"],[4863,4996,"if you're after anything else."],[5017,5163,"Oh, so I guess you're interested"],[5163,5292,"in getting kicked out of college"],[5292,5392,"on your very first day."],[5392,5526,"And getting blacklisted"],[5526,5672,"from every major university"],[5672,5730,"in the country."],[5955,6068,"I wonder what your grandma's"],[6068,6151,"gonna think of that."],[6151,6281,"She's a sweet woman."],[6322,6427,"Wouldn't wanna disappoint her."],[6564,6727,"You have three seconds to decide."],[6777,6844,"Three."],[7165,7223,"Two."],[7394,7474,"Check one."]],"7":[[33,100,"Check one."],[108,158,"Okay."],[246,337,"Okay, you win."],[538,667,"I will do whatever you want."],[813,863,"Good."],[900,1009,"Meet me at the dean's office"],[1009,1113,"after this ceremony."],[1113,1230,"Don't be fucking late."],[1497,1597,"She's a human."],[1659,1743,"How's this possible?"],[1743,1893,"It's exceedingly rare,"],[1893,2002,"but it happens."],[2002,2177,"Sometimes a werewolf"],[2177,2331,"will be mated to a human."],[2331,2569,"If she has the mark, she is the one."],[2627,2765,"Once you mate with her,"],[2786,2982,"your curse will be broken."],[2982,3144,"But there's just one catch."],[3144,3211,"What is it?"],[3244,3445,"There has never been a case"],[3445,3549,"of a human girl"],[3549,3657,"mating with an Alpha."],[3657,3849,"With a normal werewolf, maybe,"],[3849,4120,"but Alphas are too strong."],[4162,4425,"The truth is, if you mate with her,"],[4466,4554,"she'll die."],[4629,4788,"So only one of us can live."],[5363,5501,"Help me find a nice grave for her then."]],"8":[[37,291,"Mr. Storm, here is the acknowledgement"],[291,354,"of my debt."],[412,546,"It is signed and dated."],[583,721,"If I don't pay you back,"],[754,871,"you can sue me with this."],[1130,1205,"I..."],[1343,1418,"Mr. Storm,"],[1501,1672,"I am just a broke college student."],[1672,1755,"What do you want from me?"],[2106,2231,"I want your first time."],[2565,2677,"No, no, no,"],[2677,2777,"I'm not that kind of girl."],[2957,3228,"Here's a check for one million dollars."],[3228,3274,"Take it."],[3274,3345,"You're never gonna see"],[3345,3432,"money like this again."],[3599,3720,"It is not about the money."],[3816,3945,"Fine, I'll make it five."],[3945,4149,"Don't be fucking greedy, Naomi."],[4646,4800,"I would not sell my body to you"],[4800,4959,"if you gave me a billion dollars."],[5505,5555,"Hi, Joey,"],[5613,5784,"please find Naomi's grandmother for me"],[5784,5897,"and bring her here ASAP."],[5897,5939,"No!"],[6719,6898,"I will give you my virginity."],[6994,7173,"Please do not hurt my grandmother."],[7211,7290,"Never mind, Joey."],[9584,9680,"I'll go slow."]],"9":[[1630,1685,"What now?"],[1860,1914,"What..."],[1960,2056,"what... here?"],[2143,2352,"No, this is the dean's office."],[2352,2502,"We cannot just have sex in here."],[2502,2635,"Fine, we'll go get a hotel then."],[2711,2815,"I need to stall him,"],[2815,2948,"then take grandma and run."],[2982,3107,"Quick, Naomi, think."],[3340,3478,"Well, it is my first time,"],[3511,3678,"so I would like it to be special."],[3741,3812,"Besides,"],[3870,4041,"I don't even believe in sex"],[4041,4158,"until after marriage anyway."],[4200,4304,"Okay, we'll go get married"],[4304,4404,"and then we can have sex."],[4537,4646,"You wanna marry me?"],[4646,4829,"Yeah, you said sex after marriage, right?"],[4904,4975,"Unless you're bullshitting"],[4975,5046,"about that, too."],[5142,5259,"I'll pick you up at 10 o'clock tomorrow."],[5259,5342,"We'll go to City Hall"],[5342,5417,"and we'll go get married."],[5417,5484,"Um, no."],[5618,5684,"I have class."],[6035,6164,"Fine, after class."],[6218,6327,"Listen to me, Naomi."],[6327,6489,"I'm running thin on patience here."],[6535,6802,"I do not have time to play around with you,"],[6827,7002,"so I need you to behave."],[7069,7182,"Don't try anything."],[7357,7524,"I bought myself some time,"],[7561,7653,"now I just need to find grandma"],[7653,7836,"and get her somewhere safe."],[8450,8504,"Grandma!"],[8504,8554,"There you are."],[8579,8671,"We really need to go."],[9300,9392,"Where are you guys headed?"],[9601,9676,"Need a ride?"]],"10":[[517,563,"Hi there."],[638,713,"Killian Storm."],[713,796,"It's great to meet you."],[900,996,"Oh, Naomi."],[996,1180,"This is your generous sponsor."],[1259,1309,"Yeah."],[1376,1497,"I'm glad I caught you out here,"],[1497,1559,"because I heard you had"],[1559,1676,"some heart problems."],[1726,1843,"I know the best doctor in town."],[1843,1935,"I'm gonna give him a call."],[1935,2043,"You're gonna be in great hands."],[2043,2189,"Oh, no need to do that."],[2210,2381,"Obviously, you've done so much for us,"],[2381,2548,"and you've been such a great help"],[2548,2648,"to my family."],[2673,2819,"And I'm so grateful."],[2865,3107,"You must remember Mr. Storm's kindness"],[3107,3207,"after you graduate,"],[3207,3328,"and pay him back."],[3407,3532,"Please, let us give you a ride"],[3532,3707,"so Naomi can get back to her studies."],[3707,3832,"Oh, heavens."],[3841,4012,"Well, if it's not too much trouble."],[4012,4112,"It's no trouble at all,"],[4129,4208,"Ms. Summers."],[4225,4308,"Oh."],[4329,4437,"Grandma, no,"],[4437,4558,"I really don't think it's such a good..."],[4558,4650,"Are you sure your grandma's heart"],[4650,4783,"can handle that version of the story,"],[4783,4863,"or why don't you just"],[4863,4942,"keep your mouth shut?"],[5055,5213,"Well, goodbye, sweetheart,"],[5213,5334,"and good luck with your studies,"],[5334,5634,"and thank you very much, Mr. Storm."],[5676,5759,"It was great to meet you."],[5759,5876,"Oh, okay, thank you."],[6106,6252,"Where are you taking my grandmother?"],[6289,6381,"I'm taking her home for now,"],[6381,6485,"but that depends on you."],[6610,6677,"You weren't trying to"],[6677,6798,"just get away right now, were you?"],[6894,6936,"No."],[7094,7182,"No, I was not."],[7182,7219,"Good."],[7219,7365,"Don't try anything stupid."],[8425,8508,"I'll see you tomorrow."],[8616,8696,"Don't be late."],[8725,8846,"There's no other way."],[8846,8963,"I have to protect Grandma."]],"11":[[558,617,"I'm here."],[646,713,"Come now."],[796,855,"Jerk."],[1226,1330,"See that girl over there?"],[1509,1589,"Hm."],[1630,1751,"I need the three of you"],[1780,1914,"to rough her up real good."],[2006,2102,"Teach her a lesson."],[2281,2323,"Got it."],[2773,3003,"I don't want to see her back on campus."],[3165,3236,"Is that clear?"],[3299,3415,"This bitch is crazy."],[3465,3536,"I love that."],[4079,4166,"Come on boys, let's go."],[4496,4717,"This is for stealing my spotlight,"],[4738,4808,"bitch."],[5276,5338,"Don't move."],[5463,5559,"keep your mouth shut,"],[5559,5638,"and walk with me."]],"12":[[141,291,"Your call has been forwarded"],[291,371,"to an automated-"],[371,513,"Where the fuck is she?"],[2173,2327,"Killian, where are you?"],[2327,2414,"Naomi."],[2702,2765,"What do you want?"],[2831,2882,"Money?"],[2940,3053,"I don't have any money."],[3053,3123,"We don't want money,"],[3123,3199,"sweet cheeks."],[3236,3361,"We just wanna have some fun."],[3541,3712,"You bitch, don't try to run from us."],[3807,4008,"My boyfriend, Killian Storm."],[4066,4154,"He, he's waiting for me."],[4154,4283,"If, if he doesn't see-"],[4433,4504,"Liar!"],[4575,4667,"You expect me to believe"],[4667,4717,"your boyfriend"],[4717,4938,"is the Alpha King Killian Storm?"],[4967,5075,"Just let me go."],[5138,5234,"If Killian comes,"],[5234,5355,"you won't like what happens."],[5463,5580,"Yo, what if she's telling the truth?"],[5634,5676,"We can't afford"],[5676,5755,"to run from Killian Storm."],[5755,5855,"Don't be stupid."],[5901,5964,"Look at her."],[6043,6131,"She's bluffing."],[6218,6398,"Killian, where are you?"],[6727,6802,"Get that bitch!"],[7086,7140,"Help!"],[7157,7198,"Help!"],[7198,7257,"Somebody help!"],[7257,7411,"No one's coming to save you, bitch."],[7457,7599,"And you really pissed me off."],[7645,7799,"I was gonna go easy on you."],[7878,7962,"Not anymore."]],"13":[[221,383,"Put your hands off my fucking girl!"],[4049,4154,"No, no."],[5985,6043,"You okay?"],[6197,6293,"I'm here now."],[6293,6373,"You're safe."]],"14":[[50,145,"Do you know these men?"],[250,387,"No.... no."],[475,658,"No, I've never seen them before."],[729,880,"But they didn't seem to want money."],[880,934,"They just..."],[988,1088,"They wanted to hurt me."],[1514,1593,"Stay right here."],[2310,2389,"Who hired you?"],[2427,2594,"Listen to me, you fuck!"],[2652,2765,"You have two choices."],[2765,2844,"You're either going to tell me"],[2844,2915,"who hired you,"],[2936,3111,"or I'm gonna break your arm off"],[3111,3269,"and I'm gonna shove it up your ass."],[3349,3411,"Okay."],[3415,3461,"Okay."],[3461,3528,"Tell me!"],[3528,3611,"I've got a name."],[3611,3720,"Ella Sutton."],[3720,3841,"She put us up to this!"],[4483,4550,"Joey,"],[4592,4788,"look into an Ella Sutton."],[6026,6076,"Kneel."],[6181,6281,"I said kneel!"],[6594,6664,"Apologize to her."],[6702,6844,"We're sorry, sorry! - Sorry!"],[6844,6919,"Don’t kill us."],[6981,7065,"You guys are gonna stay"],[7065,7228,"in that position until sundown."],[7332,7474,"My guys will come check on you."],[7474,7578,"If they don't find you,"],[7611,7778,"each of you will be in a bodybag."],[7866,7941,"Is that clear?"],[8712,8779,"Where are we going?"],[8917,9021,"We're gonna go get married."]],"15":[[554,671,"Did we teach her a lesson?"],[859,917,"What?"],[1013,1163,"You let her get away?"],[1167,1226,"Ella!"],[1564,1634,"Daddy?"],[1659,1726,"You..."],[1739,1822,"What did I do?"],[1822,1876,"I was wondering"],[1876,2031,"the same damn thing, Ella."],[2031,2185,"What the fuck did you do?"],[2231,2364,"I mean, who'd you piss off?"],[2364,2540,"Why is Alpha Killian Storm"],[2540,2665,"blacklisting me"],[2665,2865,"for every single government bid?"],[2865,2973,"Daddy, I didn't do-"],[2973,3019,"Yeah, well,"],[3019,3169,"you better get your shit together,"],[3169,3274,"or I'm kicking you out."],[4579,4767,"I can't believe we're really married."],[4788,4934,"And I'm living here from now on."],[5943,6056,"Come on, I'll show you to your room."],[6089,6247,"He has a room for me?"]],"16":[[429,521,"Whoah."],[571,663,"This bedroom is bigger"],[663,842,"than my entire apartment."],[1226,1317,"Sit still."],[1405,1526,"It's gonna help with the bruising."],[3032,3144,"Can I ask you a question?"],[3382,3520,"Well, why..."],[3770,3841,"Why me?"],[3933,4200,"I mean, why do you want my first time?"],[4220,4487,"I'm just like a normal human girl."],[4537,4662,"I don't, I don't think"],[4662,4821,"there's anything special about me."]],"17":[[362,421,"Why don't you just"],[421,508,"get some sleep tonight?"],[1463,1526,"Killian!"],[1559,1605,"Killian!"],[1676,1755,"Are you okay?"],[1830,1931,"You're burning up!"],[1931,1976,"I..."],[2039,2177,"Are, are you alright?"],[2323,2439,"I have to kiss her."],[2877,2990,"Killian, why?"],[2990,3136,"Why are you doing this?"],[3486,3528,"I..."],[3528,3682,"I know we're married, but I'm..."],[3703,3816,"I'm just not ready yet."],[3816,3887,"Naomi!"],[3908,3987,"Naomi, please!"],[4304,4400,"Just let me hold you."],[4587,4654,"Please."]],"18":[[1922,2097,"Grandma, is everything okay?"],[2131,2223,"Oh, sweetheart."],[2243,2364,"I just called to let you know"],[2364,2556,"that Dr. Shapiro called me."],[2556,2648,"Dr. Shapiro?"],[2686,2890,"Isn't, isn't he like the best renowned"],[2890,3011,"heart surgeon in L.A.?"],[3086,3199,"I, I thought he wasn't taking"],[3199,3286,"any new patients."],[3286,3453,"He personally called me"],[3453,3632,"to schedule my surgery."],[3695,3845,"And it's free!"],[3845,3995,"How is that possible?"],[3995,4220,"I, I mean, that is amazing."],[4237,4341,"But, but how?"],[4341,4450,"Mr. Storm."],[4450,4604,"He said that he would follow through"],[4604,4688,"and he did."],[4696,4929,"Oh, he's such a good man, sweetheart."]],"19":[[33,141,"We have to remember"],[141,321,"to be appreciative of him."],[521,675,"Naomi, where are you?"],[675,817,"You're not in your dorm."],[817,913,"Um, I'm,"],[988,1113,"I'm at a sorority house."],[1167,1284,"I'm thinking about joining a sorority."],[1347,1455,"I really have to go now,"],[1455,1593,"but I'll talk to you later, okay?"],[1593,1659,"Oh, yes."],[1659,1856,"Oh, have fun, sweetheart."],[2548,2631,"Lying to your grandma"],[2631,2731,"about your whereabouts."],[2819,2923,"That's real smart of you."],[3036,3132,"Mr. Storm,"],[3244,3311,"thank you."],[3415,3549,"Thank you for helping my grandma."],[3586,3678,"You don't need to thank me."],[3703,3816,"It's all part of our deal."],[3891,3958,"And remember,"],[3958,4066,"I'm giving you three days."],[4133,4350,"And then I want what I came for."]],"20":[[104,354,"Get those disgusting things out of here."],[417,533,"It's such an eyesore."],[896,1051,"You must be Miss Summers."],[1096,1163,"The Alpha said"],[1163,1280,"to take good care of you."],[1338,1518,"I am the head maid, Regina."],[1580,1755,"If you need anything, please let me know."],[1793,2022,"Um, why are there funeral wreaths"],[2022,2135,"out for Mr. Storm?"],[2164,2302,"He's very much alive."],[2323,2556,"Alpha Killian is strong and powerful."],[2635,2677,"But..."],[2827,2961,"he carries a curse."],[3015,3211,"His half-brother Adrian sent those"],[3211,3282,"to remind him"],[3282,3474,"that he will not live past 30"],[3474,3657,"and that he's next in line"],[3657,3753,"for the Alpha title."],[3753,3807,"What?"],[3878,4054,"He won't live past his 30th birthday?"],[4079,4237,"I know I should keep my mouth shut,"],[4304,4421,"but Miss Summers,"],[4421,4592,"you are Alpha's only hope."],[4671,4821,"If you remain by his side,"],[4821,4975,"he might have a chance to live."],[5021,5125,"You have to help him."],[5155,5296,"What does this have to do with me?"],[5321,5526,"The curse is only broken"],[5630,5864,"when the Alpha find his fated mate."],[5955,6022,"It's you."],[6564,6694,"I thought he was a perv."],[6773,6873,"But it turns out..."],[6965,7082,"he just wants to live."],[7207,7432,"The Alpha wanted me to give you this."],[7486,7636,"It's five million dollars."],[7916,8033,"He paid for my tuition,"],[8033,8133,"helped my grandmother."],[8287,8354,"I should do something"],[8354,8420,"for him too."]],"21":[[633,767,"Did she take the money yet, Joey?"],[809,867,"Yes, sir."],[888,1001,"Regina reported that the Luna"],[1001,1155,"took the money and left right after."],[1230,1355,"She's not the Luna yet, Joey."],[1355,1468,"We gotta mate first."],[1609,1710,"And then she'll be dead."],[1793,1910,"I thought she didn't want money."],[1910,2085,"Looks like she was lying about that, huh?"],[2398,2556,"It's ready, my Alpha."],[2627,2898,"Take this during tonight's full moon."],[3003,3107,"It will tide you over"],[3107,3294,"until your 30th birthday."],[3486,3520,"But..."],[3599,3753,"I must remind you, sir."],[3774,4037,"This is only a temporary antidote"],[4037,4158,"to your curse."],[4158,4387,"You must mate with Naomi soon."],[4617,4688,"Understood."],[4979,5084,"High Priestess."],[5105,5188,"High Priestess."],[5238,5397,"A young girl, human"],[5397,5534,"named Naomi Summers insisted on"],[5534,5597,"speaking to you."],[5634,5718,"She said she won't leave"],[5718,5805,"until she sees you."],[6114,6160,"Send her in,"],[6160,6252,"see what she wants."],[6360,6431,"Let's go, Joey."],[6452,6506,"Yes, sir."]],"22":[[75,333,"What are you here for, human girl?"],[421,475,"Um..."],[709,913,"I heard you were the high priestess"],[913,992,"for the werewolves?"],[1067,1280,"And you're a council member"],[1280,1418,"for the United Nations?"],[1472,1543,"And?"],[1655,1718,"And..."],[1897,2160,"And I was wondering if you could help me?"],[2185,2406,"Humans often come to me"],[2469,2711,"either in search of good fortune"],[2748,2857,"or longevity."],[2982,3098,"Some for love."],[3236,3445,"Tell me, human,"],[3570,3657,"what do you seek?"],[3828,4004,"Do you know Alpha Killian Storm?"],[4216,4258,"Um..."],[4320,4592,"He's cursed and I'd like to help him."],[4767,4846,"I have money."],[4867,4917,"Um..."],[4979,5113,"Here, I think it's..."],[5113,5217,"I think it's five million."],[5426,5576,"Alpha Killian..."],[5668,5776,"Who is he to you"],[5776,6039,"that you would spend five million?"],[6106,6193,"He's my husband."],[6293,6406,"And he's a good man."],[6560,6744,"Will you please help me find a way"],[6744,6840,"to break his curse?"],[6840,7111,"Your husband turns thirty next week."],[7144,7378,"You must mate with him before then."],[7378,7494,"And you will live"],[7561,7645,"a long"],[7791,7920,"and healthy life."],[8028,8420,"It's the only way to break his curse."],[8537,8700,"Do you understand?"],[8742,8846,"Mhmm."],[9025,9138,"Give me your hand."],[9880,9964,"What is that?"],[9993,10080,"This"],[10247,10393,"will hurt a little."],[11870,12024,"This is a blood charm."],[12328,12458,"Give it to your husband."],[12558,12766,"It will help him ward off"],[12871,12992,"bad things."]],"23":[[283,375,"Oh my gosh Ella,"],[375,496,"what happened to your face?"],[575,771,"My dad slapped me last night."],[896,992,"He thinks that"],[992,1163,"I pissed off Killian Storm."],[1209,1317,"And now he's putting pressure"],[1317,1468,"on my family business."],[1468,1614,"I didn't do anything."],[1639,1772,"What could I have possibly done"],[1772,1910,"to piss off the Alpha King?"],[1993,2043,"Joey,"],[2097,2289,"look into an Ella Sutton."],[2356,2477,"Did Killian do something"],[2477,2560,"to Ella's family?"],[2602,2756,"It's not because of me, is it?"],[2802,2969,"Alright class, settle down."],[3036,3190,"Settle down please."],[3407,3582,"Welcome to Etiquette 101."],[3653,3795,"Now this is an elective class,"],[3795,4008,"but it is very important."],[4008,4154,"This semester I will teach you"],[4154,4241,"how to behave"],[4241,4429,"in different social settings,"],[4429,4679,"which will help you in the future"],[4679,4817,"when you need to network"],[4817,4929,"or attend events."],[4950,5109,"Now this Friday,"],[5109,5305,"you must all attend"],[5305,5409,"the homecoming dance"],[5409,5588,"if you wish to pass my class."],[5643,5855,"And you must bring a plus one."],[5914,6147,"So, feel free to pair up"],[6147,6318,"with your classmates if you'd like."],[6414,6481,"Alright?"],[6531,6614,"Oh crap."],[6656,6781,"That's in two days."],[6781,6886,"I don't have a dress,"],[6886,6994,"and I don't have a date."],[7065,7261,"Maybe I can try asking Killian?"]],"24":[[538,604,"Killian!"],[750,821,"What is it?"],[930,1001,"I, um..."],[1159,1226,"I..."],[1322,1480,"got you this good luck charm."],[2052,2102,"Thank you."],[2448,2577,"Is there anything else you need?"],[2877,3007,"I was wondering"],[3007,3174,"if you were doing anything on Friday?"],[3382,3474,"Alpha, everything is ready"],[3474,3570,"for the Global Summit meeting"],[3570,3624,"this Friday."],[3624,3741,"Do you need anything else?"],[3991,4062,"You were saying?"]],"25":[[12,83,"You were saying?"],[271,325,"Nothing."],[371,479,"Nothing important at all."],[550,613,"I, um..."],[675,930,"I'm gonna go do school work"],[1005,1076,"in my room."],[1322,1476,"Oh, I think the university is having"],[1476,1593,"a formal dance this Friday."],[1689,1789,"Maybe Miss Summers was trying"],[1789,1889,"to ask you to be her plus one?"],[2022,2047,"Okay,"],[2047,2181,"cancel my Global Summit meeting."],[2243,2431,"Sir, you're going to go to a school dance"],[2431,2544,"over the Global Summit meeting?"],[2585,2702,"I don't want her leaving this world"],[2702,2802,"with any regrets."],[2961,3107,"It's the least I can do, Joey."],[4717,4833,"Oh."],[4833,5038,"What is she wearing?"],[5038,5138,"Ugh."],[5138,5363,"I think she got it from the thrift store."],[5434,5555,"I can smell it from here."],[5572,5730,"Poor people stench."],[6106,6331,"Well, yee-haw!"],[6439,6548,"Where do you think you're going?"]],"26":[[0,129,"She can't wait for Ms. Sullivan"],[129,296,"to see that dress of hers."],[333,483,"And she doesn't have a date either."],[483,729,"She's for sure gonna flunk this class."],[788,1142,"Well, a try-hard with a 4.0 GPA..."],[1238,1292,"I guess that really"],[1292,1380,"doesn't help you much"],[1380,1601,"with the etiquette, does it?"],[1768,1893,"Didn't anyone ever tell you"],[1893,2072,"you're supposed to wear a gown"],[2072,2168,"to a ball?"],[2565,2644,"What is that?"],[2815,2957,"Beans from your farm?"],[3345,3516,"Are you heading to the farmer's market"],[3516,3636,"with those sandals?"],[3878,3937,"Ow!"],[4066,4158,"I have an idea."],[4254,4320,"No!"],[4654,4825,"Let's make an unboxing video."],[4833,5067,"A hillbilly's grocery list."],[5263,5392,"Farm girl!"],[5538,5643,"Aw! - Loser!"]],"27":[[0,129,"Farm girl!"],[275,379,"Aw! - Loser!"],[454,567,"Ladies"],[621,717,"and gentlemen."],[846,1013,"Please proceed to the ballroom."],[2585,2652,"Hey."],[2736,2819,"Killian?"],[2890,2998,"What are you doing here?"],[3828,3899,"What happened?"],[4333,4408,"What are you wearing?"],[5634,5689,"Joey?"],[5755,5876,"Get Fabiano on the line."],[5955,6093,"We need to do a makeover."]],"28":[[95,175,"Ugh."],[275,354,"Oh my."],[650,729,"Ugh!"],[813,859,"Okay."],[1067,1413,"Fabiano is going to need"],[1463,1814,"a double shot espresso martini."],[2231,2277,"Vamos!"],[2281,2348,"Vamos!"],[4124,4433,"Fabiano is exhausted."],[4454,4617,"Fabiano is a genius."],[4646,5105,"Only Fabiano could take this thing"],[5167,5309,"and this thing, ugh,"],[5363,5505,"and turn it into"],[5505,5651,"a lady."]],"29":[[362,433,"Is she ready?"],[1685,1755,"Do I..."],[1939,2043,"Do I look okay?"],[2097,2193,"You look beautiful."]],"30":[[1234,1330,"Is that Naomi?"],[1347,1476,"She looks so different."],[1476,1593,"Holy shit, she's hot."],[1643,1751,"I want to dance with her."],[1805,1910,"Don't even think about it, man."],[1910,2068,"That's Killian Storm next to her."],[2110,2214,"The Alpha King."],[3265,3449,"He really came here with Naomi?"],[3641,3845,"Oh my God, he's dancing with her."],[4708,4838,"Look at Professor Sullivan."],[4838,5000,"I've never seen her smile before."],[5046,5180,"Perfect attire."],[5242,5463,"Outstanding dance moves."],[5513,5714,"Superb male physique."],[5747,5805,"I mean,"],[5876,6006,"superb etiquette."],[6093,6172,"A plus."],[6644,6810,"This is the worst night ever!"]],"31":[[100,233,"Thank you, Killian."],[458,525,"For what?"],[671,750,"For tonight."],[838,1151,"It was the best night of my life."],[1197,1405,"It was so perfect and magical."],[1534,1593,"So..."],[1810,1897,"So thank you."],[4471,4783,"Take this during tonight's full moon."],[4783,4909,"It will tide you over"],[4909,5080,"until your 30th birthday."],[5080,5392,"But this is only a temporary antidote"],[5392,5501,"to your curse."],[5501,5734,"You must mate with Naomi soon."],[6727,6831,"Fuck."],[6894,7023,"I'm running out of time."],[7161,7269,"What do we do, Naomi?"]],"32":[[383,542,"Made your favorite omelette."],[759,855,"Thank you, Regina."],[980,1101,"Killian's been on a business trip"],[1101,1176,"for a week."],[1259,1397,"I wonder when he's coming home."],[1480,1614,"It seems like he's avoiding me."],[1843,1889,"Do you know"],[1889,2006,"when Killian's coming back?"],[2039,2231,"I'm guessing... soon."],[2281,2452,"Tomorrow is his 30th birthday."],[2452,2573,"Tomorrow's his birthday?"],[2623,2727,"We should celebrate!"],[2727,2852,"Absolutely not."],[2994,3144,"We don't celebrate birthdays"],[3144,3219,"around here."],[3361,3586,"It's been said, because of the curse,"],[3666,3862,"Alpha Killian will not make it to 30."],[4408,4525,"When are you coming back?"],[5480,5601,"I want to make him a cake."],[5759,5897,"And give him a surprise."]],"33":[[354,429,"Alpha Killian?"],[542,600,"What is it?"],[629,784,"Well, sir, tomorrow is your birthday,"],[784,1026,"and you still haven't mated with Naomi."],[1105,1192,"I know it's not my place"],[1192,1292,"to tell you what to do, but..."],[1418,1551,"Sir, you're running out of time."],[1609,1755,"Please don't drag this out any longer."],[4346,4450,"Happy birthday, Killian."],[4758,4829,"Make a wish."],[5171,5309,"I don't believe in birthday wishes."],[5355,5513,"I know, but um..."],[5684,5826,"What if I could promise you"],[5826,5951,"this year it would come true?"],[6206,6277,"Okay, fine."],[6373,6439,"I'll do it."],[6644,6815,"I wish Killian Storm"],[6886,7190,"have a long, healthy, and happy life."],[8391,8512,"Happy birthday, Killian."],[8600,8833,"I actually got you another present."],[8883,9025,"Why don't you open it yourself?"]],"34":[[37,187,"Why don't you open it yourself?"],[684,771,"You understand"],[771,1172,"what this would mean, right?"],[1226,1288,"Mm-hmm."],[1372,1514,"And that once I start,"],[1664,1789,"there's no turning back."],[9501,9597,"You're burning up."],[9718,9838,"It's because I want you."],[10114,10264,"I think I'm in love with you..."],[10518,10589,"What did you say?"],[10819,10894,"Killian, I..."],[10894,11006,"Don't ever say that again."],[11090,11140,"Ever."],[11553,11661,"Killian, I..."],[11811,11870,"Killian..."]],"35":[[1005,1092,"Alpha."],[1188,1380,"Your condition is critical."],[1397,1551,"My potion won't be able"],[1551,1739,"to keep you alive much longer."],[1885,2031,"Why are you holding back"],[2031,2177,"mating with Naomi?"],[2177,2285,"Just find a way."],[2402,2656,"Find a way to make her live, too."],[2748,2894,"It's impossible."],[2894,2990,"She's a human."],[3119,3211,"Humans"],[3290,3570,"can't handle mating with an Alpha."],[3620,3749,"You don't think I know that already?"],[3749,3832,"I know that!"],[3912,4024,"I'm not asking you."],[4037,4237,"I'm ordering you, Priestess."],[4412,4504,"Find a way."],[5255,5363,"Alpha Killian,"],[5476,5693,"you have fallen for that human girl."],[5793,5968,"If you won't listen to me,"],[6089,6252,"I will have to ask your father,"],[6252,6464,"old Alpha, for help."]],"36":[[483,625,"Since Killian hates me so much,"],[625,684,"there's no reason"],[684,796,"to stay married to him."],[846,963,"After we sleep together"],[963,1071,"and I save his life,"],[1105,1201,"we can divorce."],[2581,2711,"What if I end up pregnant?"],[2761,2902,"I don't want a werewolf baby."],[3182,3428,"Um, I'll take those ones."],[3474,3541,"What size?"],[3657,3724,"Size?"],[3762,3962,"Yeah, we have medium, large..."],[4020,4108,"Oh, um..."],[4295,4479,"I'll take the smallest size."],[6619,6710,"What is it, Killian?"]],"37":[[20,62,"Hey."],[125,287,"Today's my father's birthday dinner."],[308,458,"You have to be there as my wife."],[496,625,"I'm going to send a driver to you"],[625,704,"to pick you up"],[704,792,"and I'll join you"],[792,946,"after my board meeting, okay?"],[1159,1217,"Jerk."],[1326,1493,"Now he remembers I'm his wife."],[1776,1885,"Oh, by the way, everyone."],[1885,1976,"I forgot to mention."],[1976,2106,"Third quarter financial report"],[2106,2168,"came out."],[2168,2402,"Total revenue increased by 86%,"],[2402,2585,"so, congratulations to you all."],[2602,2681,"Our net profit..."],[2786,2886,"Alpha Killian?"],[2952,3019,"Alpha Killian?"],[3228,3328,"I, uh, shouldn't have"],[3328,3445,"let her go alone, Joey."],[3486,3628,"You know how my family is."],[3749,3832,"Ladies and gentlemen,"],[3832,3924,"I think you guys"],[3924,4095,"can handle this yourself, right?"],[4095,4208,"Joey, you're leading."],[4208,4329,"You do have a Zoom meeting"],[4329,4462,"scheduled with the human president"],[4462,4567,"after this meeting."],[4567,4662,"Reschedule it."],[4804,4859,"Yes, sir."],[5059,5209,"I think it's beautiful."],[5647,5772,"Oh, hi."],[5885,6106,"So, you're Killian's new wife."],[6268,6435,"Well, I don't know what he sees"],[6435,6602,"in a mere human girl."],[6731,6869,"It's nice to meet you."],[7152,7223,"And you are?"]],"38":[[37,141,"Oh, well,"],[141,392,"I am Killian's stepmother, Karen."],[417,654,"And this is Adrian, my son."],[684,792,"And he is also"],[792,955,"Killian's younger brother,"],[955,1138,"and in line to be Alpha"],[1138,1288,"when Killian dies."],[1559,1643,"Never mind."],[1697,1785,"No wonder Killian"],[1785,1897,"never mentioned them."],[1897,2081,"Well, you're part of the family now."],[2181,2302,"Make yourself at home."],[2398,2802,"Here, this is our special family treat."],[2840,2911,"Try some."],[3115,3178,"Okay."],[3219,3353,"Yeah, thank you."],[3799,4033,"Why does this taste so strange?"],[4062,4225,"Sweetheart, how does it taste?"],[4225,4308,"Do you like it?"],[4329,4375,"Yeah!"],[4437,4525,"Yeah, it's, uh..."],[4667,4746,"It's not bad."],[5059,5171,"Mom, I told you."],[5171,5376,"She wouldn't be able to tell the difference"],[5376,5693,"between dog food and real food."],[5759,5822,"What?"],[5843,6035,"You... You gave me dog food?"]],"39":[[133,279,"Well, what's wrong with dog food?"],[312,542,"This costs $100 per pound."],[542,667,"I'm sure your grandmother and you"],[667,788,"haven't eaten anything"],[788,975,"this expensive in all of your lives."],[1226,1334,"Luna Naomi,"],[1355,1564,"please try not to stir trouble for Alpha"],[1564,1689,"when you meet his family."],[1714,1864,"He has enough on his plate."],[2231,2469,"Father, this hillbilly is the wife"],[2469,2573,"that my brother married?"],[2594,2706,"Dinner hasn't even started"],[2706,2923,"and she's stuffed her face with dog food."],[2973,3111,"Anyone walking in might think"],[3111,3269,"that Killian married a dog."],[3294,3420,"Or should I say, bitch?"],[3553,3653,"I hope you are house trained."],[3653,3732,"Enough."],[3853,4037,"Well, go make yourself useful"],[4037,4112,"in the kitchen."],[4175,4329,"Dinner won't prepare itself."],[4533,4692,"Well, why are you just standing there?"],[4717,4929,"Get into the kitchen and start working."],[5601,5747,"These oysters"],[5747,5918,"are my husband's favorite."],[5943,6056,"Shuck them."],[6197,6435,"I've never shucked oysters before."],[6602,6756,"But, um, I can try."],[7073,7173,"Not with the knife!"],[7173,7298,"Are you insane?"],[7298,7503,"A knife will bruise the flesh,"],[7528,7699,"ruin the taste."],[7699,7907,"These premium oysters"],[7907,8120,"have to be handled delicately."],[8128,8262,"You have to use your bare hands."],[8971,9071,"Any day now."],[9672,9897,"Don't stop from a mere scratch."],[9897,10039,"Keep shucking."]],"40":[[200,262,"Alright."],[312,446,"Now that we're all here,"],[479,600,"let us make a toast."],[654,1013,"To fortune, family, and father's birthday."],[1547,1622,"Where's my wife?"],[1705,1797,"Your wife?"],[1851,1914,"Yes."],[1956,2022,"My wife."],[2122,2277,"Oh, he means that hillbilly."],[2414,2656,"She's in the kitchen with the servants,"],[2686,2865,"where she belongs."],[3916,4020,"I'm really sorry."],[4145,4262,"I'm not very good at this."],[4304,4429,"Did I cause you trouble?"],[4612,4667,"No."],[6006,6147,"I'm only going to ask this one time."],[6348,6464,"Who put her up to this?"]],"41":[[137,216,"It was me."],[316,575,"You know how your father loves oysters."],[608,725,"Was it wrong of me"],[725,855,"just to want her to..."],[905,988,"shuck a few?"],[1313,1451,"Oh, my God!"],[1451,1605,"You have ruined"],[1605,1780,"a whole plate of oysters!"],[1805,1864,"What if you have"],[1864,2010,"some disease and infect us?"],[2323,2414,"You like oysters so much,"],[2414,2531,"why don't you just take them all?"],[2531,2602,"How about that?"],[2627,2823,"I am your stepmother, Killian."],[2823,2961,"I deserve respect."],[3003,3169,"Killian, what's your problem?"],[3169,3349,"You're throwing things at my mother"],[3349,3511,"for this fucking nobody?"],[3511,3636,"A lowly human like her"],[3678,3899,"should be doing this kind of dirty work."],[3899,4045,"You should have seen her earlier."],[4045,4208,"She even ate the dog food"],[4208,4300,"that I gave her."],[4350,4508,"And she said it was good."],[4542,4637,"What'd you say, huh?"],[4637,4708,"What'd you say?"],[4708,4879,"I didn't know it was dog food."],[4896,4996,"Please, I'm so sorry."],[4996,5155,"I didn't mean to em