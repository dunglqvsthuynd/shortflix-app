racing again."]],"66":[[1017,1126,"I love you, Emma,"],[1159,1276,"but do you love me?"],[1434,1589,"I love you, William,"],[1639,1793,"but I'm just a poor country girl."],[1830,1931,"And you're the richest man"],[1931,2027,"in this country."],[2306,2331,"I'll stop"],[2339,2435,"if you want me to."],[2673,2761,"I want..."],[3011,3090,"you."]],"67":[[1247,1380,"So it was just a dream."],[2831,2882,"Good Morning, - Good Morning,"],[2882,2957,"Miss Adams. - Miss Adams."],[3019,3061,"Wow!"],[3061,3228,"You are absolutely glowing today,"],[3228,3299,"Emma!"],[3307,3440,"She is, isn't she?"],[3845,3949,"Time for a little chat,"],[3958,4074,"Miss Adams."]],"68":[[554,688,"Half a million dollars."],[871,946,"It's yours,"],[1013,1130,"if you divorce William."],[2364,2531,"I appreciate the generous offer,"],[2560,2635,"but no thank you."],[2681,2798,"I have to get back to work now."],[2861,2969,"You skank!"],[3011,3128,"Do you even know what it would mean"],[3128,3257,"if William and I got married?"],[3319,3453,"Do we really have to rehash"],[3453,3490,"everything"],[3490,3595,"that happened yesterday?"],[3611,3670,"Clearly,"],[3670,3778,"your memory sucks."],[3816,3933,"So let me enlighten you."],[3953,4029,"William currently"],[4029,4120,"owns 40%"],[4120,4162,"of the share"],[4162,4308,"of the Irving Corporation,"],[4337,4421,"which makes him the biggest"],[4421,4550,"shareholder of the company."],[4604,4771,"But another 15% is"],[4771,4884,"owned by William's father."],[4996,5096,"And the rest"],[5171,5234,"is in the hands of a"],[5234,5347,"mystery shareholder."],[5376,5522,"Do you know what any of this means,"],[5522,5618,"you daft cow!"],[5672,5772,"William will lose control"],[5772,5897,"of the company if he doesn't"],[5897,5980,"listen to his father"],[5980,6076,"and marry me."],[6147,6256,"It's a ticking time bomb."],[6544,6669,"If William marries me,"],[6731,6877,"he gets the 15%."],[6977,7102,"And if he marries you,"],[7178,7319,"he loses everything."],[7899,7962,