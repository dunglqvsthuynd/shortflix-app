and, William."],[3390,3499,"This divorce agreement"],[3499,3699,"is between you and your wife,"],[3699,3841,"Mrs. Irving."],[3958,4070,"She wants nothing to do"],[4070,4175,"with a scheming and"],[4175,4329,"unfaithful husband like you."]],"83":[[342,383,"Woah,"],[383,546,"so Lynda and Mark Irving"],[546,684,"are the ones getting divorced?"],[838,992,"Holy shit."],[992,1176,"If they get divorced, Mark's"],[1176,1272,"share in the Irving"],[1272,1509,"Corporation becomes half."],[1509,1743,"Only 7.5%."],[1743,1835,"He'll have no"],[1835,2102,"power over his son or wife."],[2227,2381,"This can't be happening."],[2606,2819,"What the hell is going on here?"],[3820,4037,"I think Emma made it clear."],[4037,4120,"I don't want a husband"],[4120,4258,"who cheats on me."],[4258,4400,"And forces his son to marry"],[4400,4642,"the daughter of his mistress"],[4642,4829,"to fulfill his broken dream."]],"84":[[20,75,"Lynda,"],[75,291,"now is not the time for your antics."],[346,538,"You still don't get it, do you?"],[538,696,"We're getting divorced, Mark."],[1209,1276,"Rupert."],[1276,1426,"You and Mark have been close"],[1426,1568,"friends for years."],[1593,1726,"I'm sure you know,"],[1751,1972,"he's always had eyes for your wife."],[2043,2344,"Rupert, honey, this bitch is lying."],[2410,2477,"Rupert,"],[2477,2581,"nothing ever happened"],[2581,2660,"between us."],[2727,2790,"Hello."],[2790,2923,"The plot thickens."],[3194,3345,"I've heard enough."],[3345,3557,"We're going home. Now."]],"85":[[20,241,"My own wife and son,"],[296,342,"teaming up"],[342,496,"against me with some nobody."],[646,763,"Well, you'll be happy to know,"],[800,859,"today marks"],[859,1046,"the end of Irving Corporation."],[1167,1401,"You're forgetting something, Mark."],[1426,1601,"After we're divorced"],[1601,1789,"the 15% of your shares,"],[1851,2077,"half of it goes to me."],[2077,2248,"You stupid woman."],[2268,2369,"Have you forgotten about"],[2369,2498,"the anonymous shareholder?"],[2565,2823,"Once I give my 7.5% to them,"],[2877,3073,"they will have more than 50% ownership"],[3073,3178,"in Irving Corporation."],[3386,3420,"Let me"],[3420,3611,"spell it out to your tiny little brain."],[3720,3933,"If you divorce me, I give my shares"],[3949,4074,"to the anonymous shareholder"],[4129,4183,"and they will have"],[4183,4416,"complete control of Irving Corporation."],[4483,4646,"And you won't stand a chance in hell."],[4763,5063,"So you're giving me your 7.5%?"],[5150,5234,"How generous."]],"86":[[120,208,"What the hell are you talking"],[208,300,"about, girl?"],[329,429,"Check the shareholders"],[429,521,"database."],[963,1109,"This is impossible."],[1217,1451,"This country hick owns 45% of"],[1451,1584,"Irving Corporation."],[1676,1881,"There must be some kind of mistake."],[2385,2531,"William, I never wanted to be"],[2531,2711,"the owner of Irving Corporation."],[2744,2898,"I only accepted those shares to help"],[2898,3103,"you get the company back."],[3103,3244,"All I care about is-"],[3244,3315,"Shh..."],[3365,3436,"All I care about"],[3436,3566,"is taking you home tonight."],[3645,3770,"Shall we?"],[3770,3887,"Wife."]],"87":[[2335,2581,"Let's toast to a successful evening."],[2581,2686,"To my husband,"],[2686,2802,"for getting his company back."],[3028,3103,"To us."],[4850,4938,"What is it?"],[4979,5105,"Are you still mad that I asked"],[5105,5259,"for a divorce the other day?"],[5292,5397,"I'm sorry."],[5480,5701,"Thing is, I'm just a poor"],[5701,5830,"nobody, William."],[5830,5880,"And you're"],[5880,5955,"the richest man"],[5955,6089,"in the country."],[6089,6177,"I really never"],[6177,6285,"thought we'd work out,"],[6381,6468,"until I..."],[6519,6635,"Until you what?"],[6731,6915,"Until I fell in love with you."],[6981,7111,"Hey, you know what?"],[7165,7394,"I finally found the one."],[7457,7615,"The one you'll like."],[7661,7928,"Jesus, not again."],[7928,7966,"Can't believe"],[7966,8108,"she's ruining a romantic moment"],[8108,8312,"by talking about finding other men."],[8562,8683,"You'll approve."],[8717,8821,"Promise."],[8933,8992,"Don't worry."],[8992,9217,"I chose very carefully."],[9409,9542,"If you don't believe me,"],[9542,9638,"I can go get it."],[9638,9776,"Are you seriously"],[9776,9826,"going to bring your"],[9826,9959,"new boy toy into this?"],[10143,10226,"What?"]],"88":[[16,112,"A toy?"],[162,283,"Ew, no."],[325,471,"What are you talking about?"],[592,717,"Let me just show you."],[767,825,"It's called"],[934,1163,"Urban Cowboy."],[1163,1347,"She's paying for men now?"],[1409,1522,"You ordered?"],[1555,1735,"You paid for it. You know..."],[1735,1893,"Wait, you know that's illegal, right?"],[1972,2106,"Illegal?"],[2106,2239,"Who's the prude now?"],[2310,2389,"You know"],[2389,2556,"the good things in life are never free,"],[2556,2635,"William."],[2944,3023,"Don't worry."],[3078,3203,"I got one for you, too."],[3282,3390,"It's a couple's package."],[3390,3553,"What the, a package?"],[3553,3611,"Just wait."],[4959,5025,"This is what you were"],[5025,5109,"talking about?"],[5196,5351,"Yes, what else would"],[5351,5451,"I be talking about?"],[5743,5864,"If you didn't like the vibe,"],[5864,6001,"I'll look for others,"],[6039,6172,"more like your type."],[6235,6418,"So that night."],[6464,6639,"The night in the car."],[6639,6802,"When we ran into your friend, Timothy,"],[6906,6986,"you were,"],[7027,7173,"you were talking about lingerie?"],[7173,7211,"Yeah."],[7211,7290,"What else?"]],"89":[[0,116,"You look so disgusted,"],[116,492,"but, deep down inside, I bet"],[492,754,"you're into this kind of stuff."],[754,971,"You know, you looked so good"],[971,1117,"last night with nothing on."],[1251,1347,"But I think you'll look"],[1347,1543,"even better as..."],[2160,2298,"Urban cowboy."],[3991,4216,"Nothing can come between us now,"],[4216,4283,"wife."]],"90":[[237,408,"I just love that Steve Buscemi."],[408,500,"He's so sexy."],[925,1017,"I'm telling you, this beer"],[1017,1226,"and broccoli diet is the best."],[1226,1401,"Doing real good, sweetie."],[1751,1805,"Your daughter's"],[1805,1881,"a slut."],[2360,2494,"Look at these gluttons."],[2494,2606,"I barely escaped being"],[2606,2640,"bussed off"],[2640,2798,"to some godforsaken place,"],[2798,2952,"and they won't bat an eyelid."],[3036,3078,"Mr. and Mrs."],[3078,3132,"Adams,"],[3132,3253,"I can't believe you're living"],[3253,3361,"in these conditions."],[3386,3545,"Especially when your daughter,"],[3545,3862,"Emma, married a billionaire CEO."],[4283,4437,"What the fuck?"],[4437,4775,"Oh, that ungrateful girl can't get away"],[4775,4896,"this time."]],"91":[[1251,1359,"I love you, Emma."],[1388,1530,"I'm never gonna let you go."],[1589,1743,"I love you, too, William."],[3703,3970,"Hey, you, bring me your best wine."],[3970,4162,"The costliest one."],[4162,4225,"I'm sorry."],[4225,4387,"We are not allowed to serve alcohol"],[4387,4533,"during office hours."],[4533,4696,"Office hours?"],[4696,4788,"We don't work here."],[4954,5046,"My sister's the vice"],[5046,5142,"president of this company."],[5221,5309,"And the wife"],[5309,5459,"of Irving Corporation's CEO."],[5534,5622,"So that means our family"],[5622,5680,"pretty much runs"],[5680,5793,"things around here now."],[5847,5935,"Seems quite okay for you"],[5935,5997,"to bend the rules"],[5997,6093,"for the owners now, eh?"],[6168,6239,"Yes!"],[6260,6393,"And call your press guy."],[6448,6585,"This is my son, George."],[6610,6794,"He's the CEO's brother-in-law,"],[6819,7002,"and he's going to be your boss very soon."],[7052,7178,"Have him photographed."],[7178,7232,"And put it up"],[7232,7298,"on your company"],[7298,7419,"spreadsheet, or whatever"],[7419,7578,"they call that damn thing."],[7578,7741,"Socials, Dad, socials."],[7741,7874,"He means a photo op"],[7874,7966,"for Irving Corporation"],[7966,8074,"social media pages."],[8362,8437,"Ma'am,"],[8437,8533,"there are some people here"],[8533,8696,"claiming that they're your family."],[8712,8833,"They're causing quite a stir"],[8833,8992,"in the Irving family lounge."],[9067,9167,"I'll take care of it."]],"92":[[4,141,"Bring me the wine,"],[175,429,"or my daughter fires every single one"],[429,475,"of you."],[571,621,"I'm sorry."],[621,834,"This is our company policy."],[834,942,"I'm just a worker."],[942,1105,"Did I tell you my sister is the Vice"],[1105,1172,"President?"],[1172,1284,"What the fuck is wrong with you"],[1284,1355,"clowns?"],[1438,1568,"What are you doing?"],[1618,1851,"Emma, there you are."],[1851,2093,"Tell these fools we're your family."],[2160,2289,"Mrs. Adams... I-"],[2289,2515,"I apologize on their behalf."],[2515,2581,"Are you hurt?"],[2857,2898,"Don't worry,"],[2898,3015,"I'll take it from here."],[3061,3303,"Oh, acting like a hotshot V.P."],[3303,3395,"now, are we?"],[3465,3545,"All I wanted was to"],[3545,3670,"taste some fine wine"],[3670,3807,"for once in my life."],[3807,3903,"Is that too much to ask"],[3903,4020,"for your own father?"],[4020,4120,"Exactly,"],[4120,4170,"Emma."],[4225,4291,"Kim told us"],[4291,4466,"you're the Vice President here."],[4554,4704,"Your brother just graduated"],[4704,4763,"from college"],[4763,4992,"so he can work here now, too."],[4992,5217,"Hey sis, you know how it is."],[5242,5384,"Men bring home the money,"],[5409,5601,"women cook and clean."],[5601,5647,"You probably got wife"],[5647,5743,"duties now anyway."],[5976,6231,"How about letting me take over as Vice"],[6231,6448,"President of Maple Media, huh?"]],"93":[[37,133,"Is that all you want, then?"],[171,283,"To be Vice President?"],[350,408,"Of course"],[408,588,"that's not all he wants."],[788,867,"Kim told us"],[867,1063,"you married a billionaire,"],[1063,1176,"and never even"],[1176,1401,"bothered to inform us."],[1543,1885,"I'm expecting a few mansions,"],[1897,2072,"some luxury cars,"],[2114,2289,"preferably a Rolls Royce."],[2310,2481,"One for each of us."],[2506,2740,"And since we spent so much raising you,"],[2740,2907,"you can repay us by transferring"],[2927,3094,"half your assets to us."],[3148,3332,"And half your husband's assets"],[3332,3415,"to your brother."],[3470,3636,"He's really good at money,"],[3682,3912,"finance, shit like that."],[3933,4154,"Half? That's not enough."],[4154,4371,"No. It's fine. It's fine."],[4371,4483,"Half is plenty."],[4533,4688,"Half isn't really enough."],[4758,4942,"I think all of my husband's"],[4942,5075,"wealth is more appropriate."],[5105,5226,"Don't you think?"],[5317,5513,"Oh, it's perfect."],[5513,5755,"Oh, Emma you are such a good sister."],[5893,6039,"Don't worry, sis."],[6039,6139,"I know what I'm doing."],[6139,6218,"Your husband's wealth"],[6218,6302,"will be in good hands."],[6364,6452,"Wow."],[6485,6631,"You guys haven't changed a bit."],[6740,6844,"I would have thought my brother"],[6844,6961,"would have grown up by now."],[6981,7119,"But clearly, college"],[7119,7336,"can't fix ignorance and greed."],[7369,7515,"Watch your tone, girl."],[7536,7615,"That's your own brother,"],[7615,7749,"you're talking to."],[7849,8053,"George is our family heir."],[8170,8420,"I don't care how successful you are."],[8458,8721,"Don't you ever talk down to him again."],[8742,8837,"I'm gonna do a lot"],[8837,9000,"more than talk down to him."]],"94":[[154,237,"Why the fuck are you"],[237,412,"siding with fucking servants?"],[892,1130,"You crazy bitch."],[1180,1351,"Who do you think you are?"],[1351,1455,"Really, Mama?"],[1455,1568,"It's come to this?"],[1668,1730,"If you want to fight,"],[1730,1868,"let's fight to the death."],[1993,2081,"Get it over with."],[2081,2181,"George,"],[2181,2281,"bring the papers."],[2869,2973,"Sign all your assets and half"],[2973,3069,"your husband's wealth"],[3069,3207,"right now, sis."],[3207,3328,"Or we're taking you home"],[3328,3478,"and selling you to the first man who"],[3478,3616,"will pay a price."],[3616,3837,"Do any of you have hearts?"],[3837,4020,"I've sacrificed so much for you."],[4162,4208,"And it still"],[4208,4337,"doesn't mean anything."],[4508,4688,"You made me drop out of high school."],[4688,4792,"Forced me into odd jobs"],[4792,4954,"just to pay for George's college."],[5042,5163,"I was cleaning houses,"],[5163,5313,"picking up trash every day."]],"95":[[1343,1434,"You name it,"],[1434,1685,"I did it all because I loved you."],[1785,1931,"But you'll never love me back."],[1956,2035,"Big whoops."],[2072,2198,"You're just doing your duty."],[2356,2427,"Right."],[2452,2573,"My duty."],[2573,2765,"And what about your duty as my parents?"],[2915,2965,"You tried to"],[2965,3186,"sell me to a man twice my age."],[3186,3299,"You knew that man had already"],[3299,3445,"beat two ex-wives to death."],[3445,3553,"And you still fed me"],[3553,3628,"to the wolves."],[3795,3870,"Why?"],[3899,3991,"Because I'm your daughter"],[3991,4074,"and not your son?"]],"96":[[87,333,"Husbands beat their wives all the time."],[333,404,"What makes you think"],[404,525,"you're so special?"],[525,621,"That's right,"],[621,771,"drama queen."],[771,1001,"Fed you to the wolves."],[1021,1184,"We were looking out for you."],[1201,1334,"And all those odd jobs"],[1334,1434,"that you worked"],[1434,1518,"made you tough enough"],[1518,1680,"to get you to where you are today."],[1743,1881,"I am where I am today"],[1881,2097,"because of my hard work."],[2097,2210,"And because I was lucky enough"],[2210,2344,"to meet William and his mother."],[2406,2535,"They showed me real love,"],[2581,2673,"and I was just starting"],[2673,2806,"to forget my own family"],[2806,2898,"and what they put me through."],[2969,3023,"But now..."],[3182,3303,"you have the nerve to show up"],[3303,3470,"here and harass my employees?"],[3607,3707,"I won't stand back"],[3707,3828,"and let it happen anymore."],[3953,4129,"The cops should be on their way."],[4233,4341,"Heartless woman."],[4433,4550,"You're out of line, Emma."],[4562,4675,"I'm gonna post a TikTok video"],[4675,4733,"and get your ungrateful"],[4733,4817,"ass canceled!"],[4859,5038,"Big companies like Irving Corporation"],[5075,5209,"hate drama."],[5209,5313,"I'm gonna expose you,"],[5313,5451,"and the stock's are gonna drop,"],[5451,5526,"and then your big shot"],[5526,5622,"husband's going to throw"],[5622,5797,"you out in the streets where you belong."],[5822,5872,"So sign these"],[5872,5989,"goddamn papers, Emma."],[5989,6189,"Like I said, right now!"]],"97":[[83,175,"What did you say?"],[208,367,"You'll throw my wife out on the street?"],[400,479,"You got some nerve to say that"],[479,646,"to the owner of the Irving Corporation."],[1180,1267,"If you weren't Emma's family,"],[1267,1430,"I'd kill you for what you did to her."],[1881,1993,"This guy."],[1993,2043,"He and Emma have"],[2043,2198,"been together the whole time."],[2248,2335,"He was shacking up"],[2335,2423,"with her when we tried"],[2423,2527,"selling her to Morris."],[2527,2631,"You've said enough."],[2673,2794,"All of our offices are equipped"],[2794,2857,"with state-of-the-art"],[2857,2982,"surveillance cameras."],[2982,3036,"You attacking"],[3036,3153,"the employees and Emma."],[3153,3290,"Everything's been recorded."],[3315,3378,"And if you try"],[3378,3561,"to harass my wife online,"],[3561,3611,"there's hell"],[3611,3695,"waiting for you."],[4279,4391,"Cops are waiting for you."],[4421,4537,"Hey, you can't do that."],[4558,4637,"Let me go!"],[5367,5413,"I'm sorry"],[5413,5551,"you all had to witness this."],[5551,5764,"No, it wasn't your fault."],[5764,5914,"Thank you, Miss Adams."],[5914,6031,"Thank you for having our backs."],[6031,6151,"You're amazing."],[6940,7015,"I had no idea"],[7015,7152,"you lived such a difficult life."],[7207,7286,"You spent so much time"],[7286,7411,"living in the darkness, Emma."],[7507,7661,"That changes today."],[7661,7770,"From this moment on, I promise"],[7770,7949,"to fill all your days with happiness."],[8095,8233,"I promise the same."]],"98":[[2047,2097,"Come on."],[2127,2206,"Wake up, Emma."],[2419,2502,"Call"],[2615,2736,"my husband."]],"99":[[37,183,"Mom, take an Uber home."],[287,333,"All right."],[375,571,"Make sure you get home on time."],[571,646,"Your father's already"],[646,746,"pretty pissed"],[767,846,"that you ruined"],[846,963,"your opportunity to marry the"],[963,1113,"CEO of Irving Group."],[1155,1401,"Don't do anything to upset him further."],[2590,2669,"Congratulations!"],[2669,2736,"Your wife?"],[2736,2890,"She, she's not my wife."],[2907,2990,"She's pregnant."],[3040,3136,"Here are the test results."],[3328,3545,"Wait. She's pregnant?"],[3716,3816,"Holy shit."],[3816,3999,"Did this dude really get Emma pregnant?"],[3999,4087,"Now I see why he looked"],[4087,4204,"so freaked out back there."],[4320,4387,"Sorry."],[4387,4504,"Um, the man"],[4504,4600,"accompanying the woman in"],[4600,4817,"there, is that her... - Husband?"],[4884,5063,"Yes, can I go now?"],[5192,5309,"Uhm, and the woman"],[5309,5472,"is pregnant, right?"],[6051,6085,"Just when"],[6085,6222,"I was starting to accept my fate,"],[6268,6481,"a golden opportunity presents itself."]],"100":[[116,183,"William, here."],[183,250,"Hey, William,"],[291,421,"are you free right now?"],[446,583,"I'm at the hospital downtown,"],[583,721,"and I wanted to see if you-"],[738,800,"I'm busy-"],[825,950,"Emma cheated on you."],[984,1155,"She's pregnant with another man's baby."],[2318,2389,"Emma."],[2473,2565,"You're pregnant."],[2656,2736,"Really?"]],"101":[[37,129,"So we meet again,"],[129,233,"Mr. Timothy."],[784,905,"I'll take it from here."],[1735,1793,"My love,"],[1793,1885,"you're pregnant."],[1910,2093,"Yes, we're gonna have a baby."],[2164,2260,"I'm going to be a father."],[2656,2790,"I'm already three months in."],[3261,3390,"We have to break the news to your mom,"],[3390,3524,"she's going to be so happy."],[4487,4725,"Mom, you're going to be a grandma."],[4804,4979,"Oh, wonderful news, Lynda."],[4979,5134,"Congratulations."],[5134,5330,"What splendid news."],[5330,5426,"Bring me your"],[5426,5655,"most expensive piece of jewelry."],[5739,5860,"My daughter-in-law"],[5860,5955,"is having her first"],[5955,6089,"child, and I need to"],[6089,6331,"congratulate her with a perfect gift."]],"102":[[1359,1426,"William,"],[1455,1551,"I can't believe you're still"],[1551,1647,"doting on your wife"],[1647,1764,"after she cheated on you."],[1805,1885,"Don't you know she slept"],[1885,1985,"with another man?"],[2890,3090,"If you're here to see a doctor, Beth,"],[3090,3161,"go check in."],[3269,3486,"My wife is pregnant with my child."],[3553,3653,"She doesn't need some psycho"],[3653,3816,"like you stressing her out."],[3903,4099,"Really? Your child?"],[4099,4200,"How do you even know that?"],[4241,4320,"This is the guy"],[4320,4421,"who brought her to the hospital."],[4421,4579,"I saw it with my own eyes."],[4608,4771,"And I saw you spying"],[4771,4863,"on them by the door."],[4992,5167,"Why are you trying to frame me?"],[5167,5242,"Frame you?"],[5292,5359,"Are you telling me"],[5359,5497,"you and Emma don't know each other?"],[5509,5701,"Yeah, we know each other, but-"],[5730,5780,"Ah ha!"],[5822,5897,"He admits it."]],"103":[[16,141,"Admit what?"],[179,379,"I know her because we grew up together."],[433,571,"You're just trying to distract us"],[571,679,"from the fact that you're the one"],[679,792,"who brought her to the hospital."],[846,967,"I brought her here"],[1030,1105,"because I saw her"],[1105,1222,"pass out on the street"],[1222,1359,"while I was riding my bike."],[1476,1614,"What a sweet coincidence."],[1614,1793,"You really trust this man, William?"],[1893,1976,"I do."],[2189,2464,"Actually, I don't need to trust him."],[2631,2744,"I trust my wife."],[2806,2902,"My mom always told me"],[2902,3023,"good looking rich boys fall"],[3023,3153,"for elegant, rich girls."],[3203,3349,"I wonder what a hotshot CEO"],[3349,3486,"like Williams sees in a country"],[3486,3591,"hick like Emma."],[3641,3787,"I guess love is blind huh?"],[4291,4333,"Emma."],[4366,4471,"I brought these for you."],[4542,4671,"Glad you're feeling better."],[4871,5171,"Well, then I guess I'll be heading out."],[5196,5263,"Thank you,"],[5276,5376,"Timothy."],[5947,6131,"Hey you, wait up."]],"104":[[141,296,"What is it now, Miss?"],[296,450,"Clearly you like Emma."],[450,504,"So why didn't"],[504,650,"you go along with it back there?"],[650,821,"What are you talking about?"],[917,963,"I don't want to"],[963,1059,"discuss this with you."],[1101,1167,"Okay,"],[1167,1255,"I saw the way you were"],[1255,1363,"looking at her back there."],[1397,1597,"Are you from a poor family like she is?"],[1655,1814,"None of your business."],[1897,2193,"I am from a rich family like William's."],[2331,2506,"How about you and me?"],[2556,2690,"Love is blind and all."],[2781,2923,"Fine, I lied."],[2923,2961,"My family's"],[2961,3123,"not quite as rich as the Irvings,"],[3123,3282,"but we're still very rich."],[3282,3407,"And I can give you a"],[3407,3482,"comfortable life."],[3653,3753,"Miss,"],[3753,3887,"you really need to"],[3887,4037,"get your head checked out."],[4083,4191,"Good news for you,"],[4237,4533,"you're in just a place to do so."],[4742,4833,"Hey, country boy!"],[4833,4913,"Wait up!"],[6740,6835,"Your bath is waiting."],[6873,6948,"You ready?"],[7007,7173,"I'm always ready for you,"],[7173,7240,"my CEO."]]}