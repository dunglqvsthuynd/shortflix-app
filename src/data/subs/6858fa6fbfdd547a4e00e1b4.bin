{"1":[[663,759,"Got you, jerk!"],[1972,2127,"For cheating on my bestie!"],[2235,2435,"He knew he was cheating on me,"],[2435,2515,"Emma!"],[2544,2673,"Tell me where that jerk is."],[2744,2840,"He's on a date."],[2869,3065,"At the Southside Lounge."],[3065,3249,"I saw him leave wearing his"],[3249,3453,"favorite red tie."],[3511,3595,"Can't keep it in your pants,"],[3595,3641,"can you?"],[3641,3753,"You red flag!"],[3782,3891,"Who the hell are you?"],[4095,4212,"I'm just a country gal."],[4212,4287,"But I know how to fix"],[4287,4425,"city slickers like you."],[4700,4929,"And you, ma'am, are beautiful."],[4929,5084,"You can do way better than him."],[5084,5238,"He's engaged."],[5238,5309,"That's enough!"],[5309,5609,"Get her out, now!"],[5855,6010,"Isn't that William Irving,"],[6010,6222,"CEO of Irving Corporation?"],[6222,6352,"I can't believe that crazy girl"],[6352,6418,"just flung a shoe"],[6418,6644,"at the richest man in the country."],[6644,6740,"My best friend deserves"],[6740,6856,"better than a cheater."],[6856,7027,"Rot in hell, Clyde Richards."],[7490,7682,"Someone called me?"],[7778,7866,"Shit."],[7907,8037,"I got the wrong guy."],[8174,8291,"Um, uh..."],[8366,8483,"And who are you?"],[8483,8737,"He's my son, William."],[8837,9159,"Oh, I am so sorry."],[9209,9346,"William."],[9346,9426,"I really thought"],[9426,9601,"you were Clyde Richards."],[9601,9884,"I'm your man, sweetie."],[9964,10193,"And who is this sexy, old wine"],[10193,10381,"I'd like to taste?"],[10727,10844,"Cheating asshole!"],[10844,10956,"Insult this lady again"],[10956,11077,"and you'll get more."],[11077,11194,"This girl,"],[11194,11403,"she's perfect!"],[11828,11953,"Don't bother."],[11953,12103,"I'll see you in court."],[12103,12199,"Hey! Let go!"],[12199,12287,"Leave her!"],[12516,12725,"She's perfect for you, son."],[12725,12929,"You two should get married."],[12929,13054,"What? - What?"]],"2":[[0,120,"Marry him? - Marry her?"],[120,237,"No way. - No way."],[237,316,"See?"],[316,487,"You're already in sync."],[487,633,"Sorry, but I'd rather die"],[633,763,"than marry a stranger."],[763,871,"Like I'm dying to marry you."],[871,1055,"In fact, I am suing you for"],[1055,1176,"slander and assault."],[1176,1434,"Call the cops. Now!"],[1434,1630,"Don't touch her."],[1630,1747,"Marry my son,"],[1747,1910,"and it's all forgotten."],[1910,1976,"But Mom..."],[1976,2218,"My son is very stubborn."],[2218,2381,"He will sue you and he"],[2381,2519,"will send you to jail."],[2623,2715,"Jail?"],[2715,2869,"I can't afford that."],[2869,3048,"I can always get a divorce."],[3048,3148,"Yes, ma'am."],[3269,3386,"I'll marry him."],[3436,3595,"I never said yes. But Mom,"],[3595,3787,"you can't do this."],[3816,4033,"Yes, I can."],[4358,4433,"Smile."],[4496,4592,"You're married."],[5121,5321,"Great, just sold my soul."],[5655,5759,"I can't believe"],[5759,5930,"I just married a stranger."]],"3":[[291,396,"Emma,"],[396,563,"what are you doing here?"],[563,638,"Kim,"],[738,834,"you married him?"],[917,1005,"Why?"],[1005,1109,"You said you were going to break up"],[1109,1201,"with Creepy Clyde."],[1201,1322,"You call me Creepy Clyde?"],[1322,1501,"No, no, of course not, baby."],[1501,1651,"You know how much I love you."],[1651,1768,"It's just Emma."],[1768,1830,"She's jealous"],[1830,1914,"I married an amazing man"],[1914,1997,"like you."],[2043,2118,"But Kim..."],[2118,2189,"Shut up Emma!"],[2356,2435,"You and I belong"],[2435,2569,"to different worlds now."],[2569,2715,"Clyde's going to buy me a car,"],[2715,2907,"a house, and you,"],[2907,3148,"after all these years in the city,"],[3148,3315,"you're still just a pathetic"],[3315,3503,"country loser."],[3599,3707,"Go back to the dumpster"],[3707,3841,"you came from."],[4058,4116,"I'm scared, Emma."],[4208,4358,"The city is huge."],[4358,4408,"Don't worry."],[4408,4529,"I got your back."],[4529,4708,"We'll work hard and we'll make it."],[4708,4817,"Whatever happens,"],[4817,5000,"you'll always be my family here."],[5000,5142,"And I'll be yours, Emma."],[5205,5355,"You've changed, Kim."],[5355,5476,"Well, I've changed for the better."],[5476,5588,"Unlike you,"],[5588,5659,"you've always been"],[5659,5868,"a despicable hillbilly."],[5897,6051,"God, I can't believe I was ever friends"],[6051,6202,"with somebody like you."],[6252,6314,"Here."],[6506,6614,"Take this,"],[6648,6823,"and go back to your rotten town,"],[6823,6894,"loser."],[7077,7378,"Oh, you got married too, huh?"],[7444,7741,"Where'd you find this gentleman?"],[7741,7811,"Let me guess."],[7811,7949,"Was he on sale at the discount"],[7949,8103,"store in the call boy aisle?"],[8103,8370,"And you, Mr. Gigolo?"],[8370,8537,"How much do you charge per night?"],[8537,8671,"I have some rich friends I"],[8671,8825,"could send your way."],[8975,9084,"Say whatever you want about"],[9084,9267,"me, but leave him out of this."],[9267,9459,"Don't tell me what to do, you cow!"],[9459,9592,"Baby, do something."],[9592,9688,"Put this bitch and her man-toy"],[9688,9763,"in their place."],[9909,9968,"Sup, dude?"]],"4":[[750,817,"Wow,"],[817,934,"what a feisty girl."],[934,1109,"Oh, you fucking bitch!"],[1276,1426,"You're going down, Emma."],[1426,1547,"Clyde's dad is senior vice"],[1547,1689,"president at Irving Corporation."],[1689,1760,"The Irving family"],[1760,1872,"owns this city,"],[1906,2143,"and they just bought Maple Media."],[2143,2310,"Remember, the company"],[2310,2419,"we work for?"],[2419,2590,"Your ass is going to be fired, Emma."],[2590,2711,"Stop lying."],[2711,2802,"She's right."],[2869,2961,"Irving Corporation"],[2961,3136,"does own Maple Media."],[3240,3336,"I don't care."],[3336,3470,"I'm not bending to parasites"],[3470,3578,"like you for a job."],[3578,3745,"Well guess what, bitch?"],[3745,3912,"With our money and power,"],[3912,4058,"we own this city."],[4149,4258,"What if I told you that we can"],[4258,4337,"make sure that your husband"],[4337,4508,"never works a day in this town?"],[4508,4604,"You sure you can do that?"],[4825,4884,"Fine."],[4884,4992,"I'll apologize."],[4992,5134,"Just leave him out of it."],[5134,5263,"He didn't do anything."],[5263,5434,"All right, then, let's"],[5434,5584,"see if you really mean your apology,"],[5584,5714,"Emma."],[5922,6035,"Kneel in the glass"],[6035,6218,"and beg for our forgiveness."],[6256,6352,"Do it now."],[6393,6544,"We'll make sure that he rots in hell."],[6727,6840,"Emma don't!"],[6877,6994,"It's okay, William."],[6994,7169,"I'm not giving in to someone like her."],[7253,7419,"I can't drag you into this."]],"5":[[279,371,"You think it's fun"],[371,517,"bullying my wife?"],[725,888,"It's your turn to apologize."],[888,934,"Go on."],[934,1030,"If you love your wife,"],[1030,1155,"you'll get down on the glass."],[1155,1192,"Now!"],[1317,1418,"Oh, fuck off."],[1418,1493,"I ain't doing that."],[1493,1589,"No. - Thought so."],[1589,1735,"A bully and a coward."],[1735,1910,"You two are match made in hell."],[1951,2081,"Oh my God!"],[3028,3178,"You come near me or my wife"],[3178,3282,"again and you'll regret it."],[3461,3570,"Have fun on your honeymoon"],[3570,3720,"with Creepy Clyde, Kim."],[3787,3908,"What the fuck?"],[3958,4129,"Clyde, that's a Rolls Royce."],[4129,4291,"Yeah, I know, I'm not blind."],[4291,4366,"Wait, hold on."],[4366,4454,"License plate..."],[4454,4746,"I... one one...one."],[4746,4800,"That car belongs"],[4800,5013,"to the CEO of Irving Corporation."],[5726,5780,"Thank you"],[5780,6022,"for what you did."]],"6":[[617,696,"Wait."],[750,896,"This can't be your car."],[896,955,"That's right."],[955,1063,"Yeah, I stole it."],[1063,1180,"You what?"],[1197,1334,"You're going to end up in jail."],[1334,1476,"Why would you do that?"],[1514,1647,"She's gutsy."],[1647,1797,"No one speaks to boss like that."],[1830,1960,"I barely know this girl."],[1960,2085,"What if she finds out I'm"],[2085,2243,"the CEO of Irving Corporation"],[2243,2406,"and refuses to get a divorce?"],[2406,2523,"I'm just kidding."],[2523,2656,"I rented this car."],[2656,2823,"You rented it?"],[2823,2952,"What about him?"],[2952,3178,"We're coworkers."],[3178,3382,"We're Uber drivers."],[3382,3678,"You drive a Rolls Royce for Uber?"],[3712,3845,"Weddings and exclusive"],[3845,3974,"events only."],[3974,4045,"Right, Timothy?"],[4045,4216,"Oh."],[4216,4412,"Yeah, exactly."],[4483,4554,"Aw."],[4562,4633,"My best friend from"],[4633,4742,"back home is Timothy."],[4792,4859,"Oh."],[4879,5042,"Well, no one actually calls me that."],[5084,5284,"Unless that they're pissed."],[5284,5409,"But you can call me Bubba."],[5480,5734,"Anyway, Emma,"],[5818,5976,"marriage should be consensual."],[5976,6093,"Don't you think?"],[6093,6168,"It should be between"],[6168,6468,"two people who love each other deeply?"],[6552,6644,"And then you're forced to marry."],[6644,6906,"So I agree"],[6906,7057,"to divorce you."],[7057,7207,"Really?"],[7207,7332,"Thank you."],[7332,7461,"Let's do it."],[7578,7645,"No."],[7645,7753,"No, you can't."]],"7":[[45,137,"Boss."],[137,258,"I mean,"],[258,321,"William,"],[321,467,"if your Mom finds"],[467,679,"out, she's going to be pissed."],[679,855,"Well we're not telling mom."],[925,1117,"Miss Adams, do you mind taking"],[1117,1326,"a step out so we can talk?"],[1943,2068,"Poor William."],[2068,2156,"Bet his Mom's worried"],[2156,2260,"he'll never find a wife"],[2260,2406,"with his Uber job."],[2406,2452,"You better have"],[2452,2627,"a good explanation for this."],[2627,2811,"Your mother, Mrs. Irving."],[2836,2907,"She's giving"],[2907,3015,"20 percent of the company"],[3015,3178,"shares to your wife. - What?"],[3178,3286,"Yeah, well,"],[3286,3445,"she thinks she's a good girl."],[3445,3553,"Marrying her"],[3553,3624,"would keep"],[3624,3749,"Miss Carnegie off of your back."],[3749,3845,"How is this any different"],[3845,3903,"from the arranged"],[3903,4049,"marriage with some heiress?"],[4049,4245,"I'm still marrying a total stranger."],[4245,4341,"Think about it, boss."],[4341,4429,"You're hot."],[4458,4642,"Girls throw themselves at you."],[4642,4888,"You know, just be sweet to her."],[4888,5092,"I bet she'll melt into your arms."],[5092,5184,"Before you know it,"],[5184,5330,"we'll have the shares back."],[5330,5422,"You know what I'm saying?"],[5422,5551,"Do you even hear yourself?"],[5563,5618,"Yeah."],[5668,5764,"It's worth it if she gives"],[5764,5839,"you the shares back."],[6006,6252,"I want to trust you, Emma,"],[6252,6343,"but I can't give"],[6343,6452,"20 percent of my family"],[6452,6610,"company to a stranger."],[6790,6877,"Sorry, Emma."],[6877,7032,"We'll have to stay married,"],[7032,7140,"for now."],[7432,7486,"Dad said"],[7486,7686,"the CEO of Irving Corporation"],[7686,7932,"is to marry Beth Carnegie"],[7932,8116,"of the Carnegie family heiress."],[8116,8237,"I knew it."],[8237,8350,"There's no way loser"],[8350,8391,"Emma could"],[8391,8692,"have married into the Irving family."],[8692,8929,"I have a feeling he's the CEO's driver."],[8979,9017,"I'm just worried."],[9017,9163,"What if he ends up being-"],[9163,9275,"Oh, don't worry, honey."],[9275,9459,"Yeah. - I'll deal with Emma."],[9647,9805,"Remember how I told you that we ran away"],[9805,9951,"from Kansas after her parents"],[9951,9997,"tried to sell her"],[9997,10114,"to some guy who murdered"],[10114,10256,"his two ex-wives?"],[10331,10652,"Well, if I tell them where she is now,"],[10652,10839,"I bet they'll come and convince her"],[10839,10919,"to go back."]],"8":[[1063,1138,"All right, so"],[1213,1267,"Mom said,"],[1267,1443,"since you're married now, you and"],[1443,1643,"Miss Emma have to live together."],[1643,1722,"But don't worry."],[1722,1818,"You'll be a free man"],[1818,1901,"once you seduce her"],[1901,2022,"and get the shares back."],[2077,2168,"And for that,"],[2268,2398,"I got you a"],[2398,2598,"little success tool right in here."],[2598,2673,"Uh-huh."],[2719,2819,"All right, bye!"],[3803,3895,"You live..."],[3895,4024,"here."],[4024,4124,"If you don't like it,"],[4166,4300,"you know where the door is."],[4525,4629,"Come on, William,"],[4629,4746,"for the shares."],[5230,5392,"No way, Emma Adams."],[5492,5751,"I'm staying."],[5751,5876,"Didn't you want a divorce?"],[5876,6018,"Why are you still here?"],[6018,6318,"I'm here because of you."],[6435,6493,"Because of you"],[6493,6635,"holding my company's shares."],[6635,6806,"Because of me?"],[6806,6981,"Are you falling for me or something?"],[7203,7440,"In your dreams."],[7440,7490,"Thing is,"],[7490,7540,"I am here"],[7540,7607,"because you have"],[7607,7807,"given me a lot of stress."],[7807,7962,"And it's my turn now."],[7962,8049,"So I get to choose,"],[8049,8183,"when we get a divorce."],[8237,8324,"Got it?"],[9084,9384,"He is kinda hot."],[9609,9705,"Oh my God."],[9705,9864,"I must be crazy."],[10076,10293,"You know, just be sweet to her."],[10293,10485,"I bet she'll melt into your arms."],[10485,10581,"Before you know it,"],[10581,10719,"we'll have the shares back."],[13580,13834,"Why am I so drawn to her?"],[13850,14026,"Why am I falling for him?"]],"9":[[191,325,"William, focus."],[325,400,"You're just doing this"],[400,521,"to get your shares back."],[1217,1276,"Oh my God."],[1276,1422,"I'm so sorry."],[1488,1589,"You okay?"],[1589,1680,"With her touch,"],[1701,1814,"it doesn't even hurt."],[2464,2635,"You uh..."],[2694,2857,"want to hang it up?"],[2894,3078,"What? - Your shirt."],[3153,3311,"You were going to hang it up, right?"],[3445,3545,"I can do it for you."],[3628,3762,"Are you really naive?"],[3787,3937,"Or just a good tease?"],[4437,4583,"What am I doing?"],[4671,4767,"Get out, please."],[4767,4875,"Excuse me."],[4875,5000,"This is my room."],[5063,5134,"Not anymore,"],[5134,5276,"it's mine now."],[5296,5384,"Goodbye."],[5722,5897,"What is wrong with me?"],[5997,6181,"I see why no one wants to marry you."],[6181,6314,"Lucky me, huh?"],[6635,6777,"Morning, Miss Adams."],[6777,6873,"Oh. Are you okay?"],[6873,7090,"What's with the dark circles?"],[7090,7286,"Didn't get much sleep last night."],[7732,7770,"Looks like"],[7770,7853,"you made your move on"],[7853,7966,"Miss Emma, boss."],[8087,8270,"Shut up and drive."],[8495,8675,"Now, as we know, our sales manager"],[8675,8787,"resigned last week."],[8787,8946,"But I'm here to announce"],[8946,9092,"our new appointment."],[9092,9200,"It's got to be Emma."],[9225,9346,"Yeah, for sure."],[9346,9471,"I mean, she's worked so hard for this,"],[9471,9609,"she even got a college degree."],[9609,9747,"No one deserves it more than her."],[9747,9939,"Let's give a warm welcome to our"],[9939,10239,"new sales manager, Kim Cox."]],"10":[[187,383,"Kim is the new manager?"],[383,500,"Wasn't she fired for trying"],[500,684,"to seduce a client?"],[842,971,"Emma,"],[971,1272,"you look dreadful."],[1347,1505,"As a senior sales associate,"],[1505,1697,"you should really lead by example."],[1697,1981,"And this is"],[1981,2089,"unacceptable."],[2114,2323,"Skibidi, why is she going after Emma?"],[2569,2677,"You're right,"],[2677,2831,"manager Kim."],[3057,3207,"I know I'm right."],[3207,3411,"And it's really not safe"],[3411,3666,"for you to work when you look tired."],[3666,3908,"So you're dismissed for the day."],[3908,4020,"I'm fine."],[4020,4149,"I can work. - I said no."],[4225,4358,"Because unlike you,"],[4391,4587,"I have high standards."],[4637,4733,"Oh, by the way,"],[4733,4850,"you won't be paid for today."],[4850,4946,"And you can say goodbye"],[4946,5080,"to this month's bonus."],[5121,5267,"That's totally unfair."],[5534,5651,"Meeting adjourned."],[5651,5801,"Everybody get back to work."],[5960,6072,"This is just a preview"],[6072,6181,"of what happens"],[6181,6306,"when you mess with me."],[6556,6669,"Go home, loser."],[6710,6810,"And watch out!"],[6861,6936,"I've got another"],[6936,7061,"surprise waiting for you."],[7795,8095,"Thank you, Miss Cox."],[8108,8304,"Now- - Don't worry."],[8304,8483,"Now that I have my promotion,"],[8483,8608,"I'll put in a good word with you"],[8608,8758,"for my father-in-law,"],[8758,8863,"who reports directly"],[8863,9163,"to the CEO of Irving Company."]],"11":[[104,271,"You sure this is the right address?"],[271,425,"I ain't stupid."],[425,642,"Kim gave me this address herself."],[679,800,"Let's just wait here."],[1338,1547,"Gotcha, you sneaky little rabbit!"],[1547,1714,"Mama, let me go!"],[1714,1818,"Somebody help!"],[1901,2052,"Help, somebody help!"],[2894,3174,"You ungrateful girl!"],[3174,3249,"This is how you"],[3249,3370,"treat your parents,"],[3428,3486,"huh?"],[3511,3649,"We raised you."],[3649,3937,"And you repay us by running away."],[3937,4083,"If it wasn't for Kim,"],[4083,4137,"we would have"],[4137,4287,"never found you."],[4358,4450,"Kim?"],[4491,4550,"I can't believe"],[4550,4721,"I once called her my best friend."],[4754,4829,"She knew what Mom"],[4829,4904,"and Dad would do to me"],[4904,5021,"if they found me."],[5050,5180,"I sent you money, Mama."],[5355,5501,"You call that money?"],[5530,5626,"It barely covered"],[5626,5805,"my drinks at the casino."],[5834,5989,"But don't worry, sweetie."],[5989,6185,"Morris owns you now."],[6185,6352,"He'll fix you good."],[6381,6485,"Ten grand."],[6485,6627,"Like we agreed."],[6685,6873,"Not a penny less."],[6923,7102,"You can't do that, that's illegal."],[7102,7228,"Illegal?"],[7228,7340,"You're our daughter."],[7365,7703,"We can do whatever we want with you."],[9805,9964,"Boss never forgets his phone."],[9964,10118,"Last night must have been wild."]],"12":[[225,371,"Stay away from me!"],[371,492,"Relax, sugar pie."],[492,617,"I'll treat you right."],[700,917,"Once you give me a few healthy babies,"],[917,967,"that is."],[980,1180,"Now, where do I start from?"],[2068,2239,"What if she calls the cops?"],[2264,2335,"Mmm."],[2389,2515,"She wouldn't dare."],[2581,2706,"We'll take her back to Kansas"],[2706,2877,"as soon as Morris is done with her."],[2894,3086,"Once Morris pays up the ten grand,"],[3098,3169,"we'll have enough"],[3169,3328,"for our son's new