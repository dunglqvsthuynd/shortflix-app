],"75":[[350,425,"Boss are you sure"],[425,508,"you should be attending this"],[508,621,"engagement party?"],[663,692,"What if"],[692,796,"Miss Emma finds out?"],[859,1009,"She won't mind."],[1076,1151,"But Sir you"],[1151,1222,"and Miss Emma"],[1222,1309,"are married."],[1347,1447,"And here you are now,"],[1530,1639,"going to announce that you're engaged"],[1639,1747,"to another woman."],[1818,1889,"Who said I was getting"],[1889,1997,"engaged to another woman?"],[2156,2281,"I have to attend this party"],[2281,2394,"to set the record straight once"],[2394,2473,"and for all."],[2510,2627,"to tell my father and Beth"],[2627,2815,"that I'm not going to divorce my wife,"],[2848,3015,"that they need to leave me alone."],[5905,6047,"It's an excellent sign"],[6047,6143,"that he made it."],[6227,6331,"So until then,"],[6418,6531,"let's go talk to him."],[6898,7052,"Is Emma Adams here?"],[7290,7411,"Country bumpkin finally"],[7411,7520,"got the message."],[7549,7607,"She"],[7607,7745,"doesn't belong here."],[7761,7841,"She's smarter"],[7841,8020,"than I gave her credit for."]],"76":[[83,262,"This is a huge responsibility."],[316,450,"Should I have signed this?"],[554,746,"Emma, I want you to sign this."],[809,871,"It'll give you"],[871,1013,"25% of the stake"],[1017,1184,"in the Irving Corporation."],[1255,1343,"You may not know this,"],[1343,1397,"but I"],[1401,1659,"transferred 20% of the shares to you"],[1676,1826,"the day you married William."],[1901,1985,"And now I'm giving"],[1985,2106,"you the rest of my shares."],[2327,2439,"I can't sign this."],[2519,2723,"Emma, you're a wonderful girl."],[2765,2969,"I knew that the day I met you."],[2969,3107,"The way you stand up for others."],[3240,3319,"I can see why"],[3319,3453,"William fell in love with you."],[3486,3653,"We're family now, okay?"],[3699,3883,"William really needs you."],[4508,4642,"I won't let you down."],[4896,5009,"Mom."],[6481,6585,"She's stunning."],[6585,6740,"Who is she?"]],"77":[[216,296,"Everyone,"],[354,475,"thank you all for coming."],[525,596,"As you all know,"],[604,738,"my son and the heir, William,"],[775,934,"is getting engaged tonight,"],[984,1105,"to Beth Carnegie."],[1455,1626,"That's William Irving,"],[1639,1772,"the CEO of Irving."],[1830,1989,"Oh, he's a hottie."],[2022,2139,"I heard he didn't want to"],[2139,2327,"be engaged to Beth Carnegie."],[2348,2548,"Guess that was just empty gossip."],[2581,2660,"Welcome, son."],[2736,2790,"I knew"],[2790,2882,"you wouldn't let your father down."],[2952,3073,"So you've finally decided to"],[3073,3261,"let go of that low class girl,"],[3294,3353,"and marry the girl"],[3353,3453,"I've chosen for you."],[3557,3691,"I won't be so sure, Dad."]],"78":[[4,108,"Now, William,"],[125,262,"before you start acting up."],[337,417,"You might want to know"],[417,500,"who's here today."],[704,809,"William,"],[809,1038,"congratulations on your engagement."],[1430,1509,"This created"],[1509,1672,"quite a stir on Wall Street."],[2031,2139,"I agree."],[2139,2223,"Our shareholders are"],[2223,2414,"very excited about this"],[2414,2594,"excellent news."],[2907,3082,"Did you pay him to say this, Dad?"],[3307,3516,"Before he died, my stubborn"],[3516,3699,"father, passed me over"],[3699,3787,"and made you owner"],[3787,3920,"of Irving Corporation."],[3933,4087,"No, I didn't mind at first."],[4124,4204,"But, now,"],[4216,4425,"so sick and tired of having such"],[4425,4650,"a disobedient son as you."],[4650,4775,"You are going to marry Beth."],[4775,4934,"And that's how it's going to be."],[4959,5155,"And when you do I'll transfer you"],[5155,5321,"my shares in the company."],[5359,5476,"And these three will help"],[5476,5718,"you keep Irving Corporation running."],[5751,5897,"Stop pushing it, son."],[5935,6164,"I'm warning you. - William."],[6164,6260,"Your father's doing"],[6260,6360,"what's best for you."],[6360,6456,"My daughter Beth will"],[6456,6602,"make a perfect wife."],[6635,6723,"Don't you want to keep"],[6723,6886,"Irving Corporation in the family?"]],"79":[[0,229,"I'm not marrying Beth."],[1121,1267,"What kind of spell has this"],[1301,1493,"low class country witch put on you?"],[1530,1630,"If you don't marry Beth,"],[1630,1772,"you don't get my shares."],[1810,1926,"Then you will lose control"],[1926,2056,"of Irving Corporation."],[2068,2331,"You're saying no to billions of dollars,"],[2419,2527,"all for some low class"],[2527,2736,"girl that crawled out of the gutter?"],[2902,3211,"Your money means nothing to me, Dad."],[3282,3570,"I'm not leaving the girl that I love."],[3703,3774,"William,"],[3841,3962,"your obsession with Emma"],[3962,4099,"is just a phase."],[4120,4237,"Girls like her trap"],[4237,4396,"rich men all the time."],[4425,4517,"You're smart enough to know"],[4517,4654,"when enough's enough."],[4963,5071,"You're right, Beth."],[5142,5305,"Enough is enough."],[5930,6114,"Because I'm married."]],"80":[[538,746,"I happen to love my wife, Emma,"],[746,850,"very much."],[850,921,"So if you're on the"],[921,1105,"look for a husband,"],[1105,1205,"look elsewhere."],[1368,1564,"Surely you must be joking, William."],[1643,1768,"If he's already married,"],[1785,1835,"what the hell is this"],[1835,1972,"engagement party for?"],[2014,2106,"It's obvious."],[2106,2223,"His dad is thrusting"],[2223,2381,"desperate Beth on him."],[2439,2577,"He's willing to throw away"],[2577,2677,"his billion dollar"],[2677,2831,"company for his wife?"],[2852,2898,"Hello."],[2898,3036,"I need me a husband like that."],[3190,3332,"Mark, your son needs"],[3332,3503,"to pull his act together."],[3582,3682,"If this leaks to the press"],[3682,3853,"Beth will never hear the end of it."],[3924,4029,"Yes, Mark."],[4029,4183,"Do something."],[4183,4270,"All right, William,"],[4270,4412,"here's what's going to happen."],[4479,4596,"You're going to divorce that country"],[4596,4763,"wife of yours immediately."],[4783,4900,"And marry Beth."],[4942,4992,"Or else"],[4992,5105,"the entire board of Irving"],[51