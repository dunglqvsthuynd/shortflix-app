d get out."]],"48":[[20,162,"Oh, and we both know"],[191,300,"Mr. William's father"],[329,500,"can't make decisions on his behalf."],[667,729,"Guards!"],[1071,1192,"Put these two on a bus"],[1213,1343,"and take them to the remotest"],[1372,1597,"dead town in the wilds of Alaska."],[1614,1780,"Oh, and when they get there,"],[1835,1960,"make sure they never come back."],[3057,3178,"I'll go get ready."],[3707,3795,"I believe in you."],[3903,3949,"Wife."],[5063,5125,"There he is."],[5159,5230,"Good to see you boss."],[5234,5284,"Thank you."],[5301,5405,"You are welcome."],[5701,5751,"This?"],[5955,5993,"Fine."],[6594,6710,"Welcome, Mr. Irving."],[6844,7115,"And you must be Miss Beth Carnegie."],[7165,7365,"So when is the big day?"],[7399,7482,"There won't be one."],[7503,7611,"I'm already married."]],"49":[[8,70,"William."],[133,254,"You think Beth feels when you say"],[254,337,"you won't marry her"],[337,400,"in front of everyone?"],[400,538,"I won't say it again, Dad."],[550,696,"Emma is my wife,"],[717,813,"and I'll never leave her."],[955,1017,"Don't worry."],[1096,1209,"I'm quite sure that after Emma's"],[1209,1343,"little performance today,"],[1426,1589,"I will be Mrs. William Irving."],[3887,3978,"And the next speaker,"],[3995,4141,"delivering their report for Maple"],[4141,4266,"Media is the director"],[4266,4433,"of sales, Emma Adams."],[4512,4671,"The media has a new director of sales?"],[4754,4808,"I had no idea."],[4808,4875,"It's the first time"],[4875,4950,"I'm hearing about it."]],"50":[[1205,1355,"Oh my God, she's"],[1355,1413,"stunning."],[1530,1559,"No wonder"],[1559,1722,"she's a director at such a young age."],[1805,1931,"Putting those looks to good use,"],[1931,2027,"if you know what I mean."],[2064,2135,"If you're going to sit around"],[2135,2218,"and dirty gossip,"],[2218,2431,"I suggest you leave now."],[2631,2740,"Emma might be pretty,"],[2761,2948,"but she's still a trashy countryside"],[2948,3019,"redneck."],[3044,3119,"What really rings"],[31