{"1":[[246,354,"Kaitlyn Sinclair,"],[354,487,"today is gonna be the best day"],[487,575,"of your life."],[629,759,"You worked two shifts all summer,"],[759,875,"and finally got this gift"],[875,992,"for your high school sweetheart."],[1017,1146,"You're starting college tomorrow,"],[1146,1222,"and you're moving in"],[1222,1330,"with the man you love."],[2060,2277,"He's gonna be so excited to see me."],[3365,3407,"Brent,"],[3465,3528,"how could you?"],[3557,3732,"Kaitlyn, what are you doing here this early?"],[3799,3974,"I left my shift early to surprise you"],[3974,4091,"and this is what I find?"],[4145,4229,"You're cheating on me?"],[4287,4341,"I mean,"],[4375,4475,"is it even cheating"],[4475,4587,"if you never even put out?"],[4963,5092,"You got a gift for Brent?"],[5188,5338,"Take your hands off of that!"],[5388,5509,"Who the hell are you?"],[5534,5593,"I'm Maddy,"],[5618,5722,"Theta Gamma president."],[5747,5955,"The hottest sorority on campus."],[6068,6214,"Thank you for the gift, Kaitlyn."],[6277,6352,"You can go now."],[6373,6519,"But this is our apartment."],[6519,6660,"It's my apartment,"],[6660,6827,"since you did make me sign"],[6827,6915,"for the both of us."],[6940,7140,"Yeah, because I trusted you."],[7586,7670,"Look at those."],[7691,7749,"No wonder you couldn't"],[7749,7887,"satisfy your man."],[8103,8141,"Hey,"],[8166,8266,"hey, give it back!"],[8266,8329,"It's mine!"],[8362,8562,"I got it for you and I can take it back!"],[9067,9196,"A cheater and a slut."],[9230,9317,"Have fun with that."],[9626,9688,"Ryan,"],[9755,9864,"Brent cheated on me."],[9914,10043,"I need some place to stay."],[10093,10193,"Oh, Katie,"],[10293,10372,"I'm sorry."],[10439,10489,"Hey,"],[10489,10560,"you're lucky though."],[10581,10668,"I'm in London"],[10668,10748,"all semester,"],[10748,10877,"so you can stay at my place."],[10919,11069,"Oh, Ryan, you're a life saver."],[11069,11186,"You should probably know-"],[11294,11361,"Ryan?"],[11398,11507,"Cole moved in!"],[11561,11665,"Ryan, I can't understand"],[11665,11732,"a word you're saying."],[11732,11861,"I'll text you when I'm settled, okay?"],[12245,12370,"This was supposed to be"],[12370,12520,"the happiest day of my life,"],[12562,12625,"and instead,"],[12662,12746,"I'm standing alone"],[12746,12871,"in my brother's apartment,"],[12912,13075,"smelling like milkshake."],[13788,13876,"This cologne doesn't smell"],[13876,14005,"like the one Ryan uses."],[14752,14827,"Who are you,"],[14827,14927,"and what are you doing in my shirt?"],[15248,15386,"No way."],[15411,15540,"My brother's best friend,"],[15540,15694,"and my childhood crush"],[15694,15819,"just caught me half-naked,"],[15819,15974,"sniffing his shirt."]],"2":[[621,750,"Those mean girls upset you again?"],[804,867,"Cole, they said that"],[867,971,"they're gonna tell everyone"],[971,1105,"that I never had my first kiss"],[1105,1188,"because I'm ugly."],[1213,1380,"That's because boys your age are idiots."],[1443,1534,"Okay, they can't see beauty"],[1534,1643,"when it's right in front of them."],[1685,1801,"I'm never gonna get kissed."],[1801,1951,"And you're not ugly, Katie."],[1972,2064,"Never have been,"],[2097,2173,"you never will be."],[2339,2481,"We've known each other forever,"],[2519,2648,"so this probably doesn't count."],[2648,2690,"But..."],[3695,3757,"Now they can't say"],[3757,3841,"you've never been kissed."],[3916,4049,"But please keep it a secret"],[4049,4195,"or your brother will kill me."],[4604,4796,"Cole is like another big brother to me."],[4833,4967,"I always looked up to him."],[5155,5234,"But deep down,"],[5263,5384,"I wish he didn't look at me"],[5384,5497,"like a little sister."],[5968,6056,"Deep down,"],[6056,6151,"I wished for more"],[6151,6285,"from his kindness."],[6598,6702,"Katie, what are you doing here?"],[6756,6894,"My brother said I could stay here"],[6894,7006,"while he's abroad this semester."],[7040,7165,"I'm a freshman at the university."],[7261,7349,"What are you doing here?"],[7369,7457,"I live here."],[7511,7653,"I moved in with your brother."],[7653,7745,"Haven't you heard?"],[7786,7845,"So..."],[7903,8016,"You staying here is actually"],[8058,8116,"up to me."],[8233,8375,"What are you gonna do to convince me?"],[8521,8683,"When did he get this hot?"],[8729,8888,"Life is so unfair."],[9075,9280,"Okay, I'm glad this is funny to you, Cole."],[9280,9330,"But"],[9330,9501,"I just had the worst day of my life and-"],[9542,9597,"Wait,"],[9659,9755,"has she been crying?"],[9793,9855,"Nevermind,"],[9914,9964,"I'll leave."],[9993,10114,"Sorry for the intrusion."],[10306,10368,"Hey."],[10527,10610,"You're not going anywhere."],[10668,10781,"Just stay here with me."],[10781,10852,"Wait, really?"],[10906,11002,"Of course, we've known each other"],[11002,11086,"for years, Katie."],[11106,11232,"I'm not leaving you homeless."],[11348,11436,"As long as you don't distract me"],[11436,11503,"from my studies."],[11565,11640,"Thanks, Cole."],[11690,11820,"I promise I won't distract you."],[12007,12074,"Excuse me,"],[12157,12220,"my shirt."],[12487,12608,"I'm just messing with you."],[12670,12721,"Keep it."],[12783,12900,"Looks better on you anyway."],[13050,13229,"It's gonna be a long semester."],[13438,13630,"By the way, I'm going to a party later."],[13659,13747,"Don't wait up."],[13963,14013,"So,"],[14013,14122,"how do I look for the party?"],[14435,14518,"Oh my God,"],[14568,14710,"when did she get this hot?"],[15073,15165,"Do I look okay?"],[15298,15382,"You look..."],[15482,15548,"Come on Cole,"],[15548,15694,"she's like a little sister to you."],[15694,15819,"You can't look at her like that."],[15949,16066,"You can't wear that dress."],[16066,16136,"It's too short."],[16182,16253,"Go change."],[16266,16357,"You can't tell me what to wear."],[16391,16516,"You are not my older brother."],[16570,16620,"Kaitlyn,"],[16620,16708,"if you go out like that,"],[16708,16795,"I swear to God I'll-"],[16795,16850,"You'll..."],[16933,16983,"What?"],[17112,17229,"What exactly are you"],[17229,17367,"gonna do to me, Cole?"]],"3":[[8,75,"Kaitlyn,"],[262,367,"I need you to be a good girl,"],[392,454,"and go change."],[504,625,"What will you give me if I do?"],[846,896,"Go"],[921,988,"change."],[1109,1301,"I do have a dress that's"],[1347,1480,"a little bit shorter."],[1564,1747,"Do you wanna watch me change into it?"],[1964,2114,"I'm going to that party, Cole."],[2202,2285,"Don't wait up."],[2982,3157,"Stop looking, Nat."],[3157,3261,"There's no way Cole Hart is"],[3261,3378,"coming to an undergrad party."],[3386,3503,"He's the hottest guy on campus."],[3503,3582,"If he's not coming,"],[3616,3699,"why did I get dressed up?"],[3732,3812,"What are you talking about?"],[3862,3970,"Are you serious man?"],[3970,4099,"Everyone knows about Cole Hart."],[4141,4287,"He's the hottest guy on campus."],[4320,4375,"But the rumors say"],[4375,4533,"he just moved in with a freshman."],[4758,4829,"I don't care."],[4863,4946,"He's hot,"],[4988,5050,"ripped,"],[5084,5163,"and smart."],[5163,5276,"He's the whole package."],[5834,5905,"Oh my God,"],[5905,5993,"who's that?"],[5993,6139,"That's the girl with Cole Hart."],[6139,6235,"She's so hot!"],[6235,6322,"Is she new here?"],[6481,6544,"Kaitlyn!"],[6598,6815,"She's already living with somebody else?"]],"4":[[70,175,"After all these years"],[175,316,"waiting for her V-card,"],[367,533,"I'm not just gonna give this virgin bitch"],[533,613,"to that Cole dude."],[696,900,"If anyone's gonna be her first fuck,"],[946,1046,"it's gonna be me."],[1426,1539,"Whoops, sorry girl."],[1576,1634,"You okay?"],[1701,1780,"Don't worry about it."],[2081,2235,"Brent, you bastard."],[2318,2402,"I see, Brent."],[2656,2765,"I'm Kaitlyn Sinclair."],[2765,2915,"Lydia, and this is Nat."],[3023,3082,"Come on,"],[3123,3203,"drink up."],[3299,3395,"To new friends."],[3407,3453,"Cheers."],[3474,3541,"Cheers."],[3695,3962,"Go, go, go, go, go, whoo!"],[4058,4137,"Let's go."],[4575,4625,"What's up, man?"],[4742,4783,"Hey Cole,"],[4783,4