get"],[6398,6519,"my dream internship"],[6519,6623,"and prove to everyone"],[6623,6823,"that I'm not some dumb little freshman."],[7219,7432,"Maddy, you have a question."],[7432,7549,"Professor Calloway,"],[7549,7745,"Kaitlyn Sinclair switched our papers."],[7745,7841,"She should be disqualified"],[7841,7928,"from the internship."],[7928,8024,"It should be mine."]],"39":[[0,187,"Kaitlyn Sinclair switched our papers."],[187,258,"She's lying."],[258,437,"I saw you leave the bar with Cole."],[437,604,"If you don't go along with this,"],[604,767,"he'll get fired, and you'll be disqualified"],[767,971,"for sleeping with the TA,"],[971,1071,"whore."],[1234,1380,"He won't be able to graduate."],[1893,2085,"Do you really wanna ruin his life too?"],[2085,2189,"Kaitlyn,"],[2189,2310,"is Maddy lying?"],[2957,3203,"I can't believe I have to give up my dream."],[3203,3399,"As much as I hate Maddy,"],[3399,3499,"I love Cole more."],[3828,3924,"No,"],[3924,4020,"she's telling the truth."],[4020,4120,"I switched our papers."],[4120,4162,"See?"],[4162,4220,"I told you."],[4220,4446,"Kaitlyn Sinclair is not a good student."],[4446,4604,"She can't write an A-plus paper."],[4604,4725,"She goes around telling everyone"],[4725,4859,"that Brent's a cheater,"],[4859,4925,"when really,"],[4967,5171,"it looks like she's the cheater."],[5171,5280,"Say it, Kaitlyn."],[5280,5434,"Say, I'm a liar and a cheater."],[5651,5772,"I'm a liar"],[5772,5834,"and a cheater."],[5876,6010,"That's enough, Maddy."],[6156,6239,"Kaitlyn,"],[6318,6427,"you can leave my class."],[6506,6669,"Go and explain to the dean"],[6669,6756,"that you"],[6756,6869,"are being dropped"],[6869,7040,"from my class for cheating."],[7094,7232,"I will leave it up to him whether or not"],[7232,7374,"you get expelled altogether."],[7494,7632,"I'm so sorry, Professor."],[7699,7795,"Wait."],[7795,7887,"Kaitlyn didn't cheat."],[8041,8162,"Then why is she telling me"],[8162,8241,"that she did?"],[8320,8429,"Because,"],[8429,8521,"she's protecting me."]],"40":[[4,120,"Cole, what do you mean by that?"],[166,316,"I know Kaitlyn didn't cheat."],[367,529,"She's only protecting me because-"],[529,600,"Cole,"],[600,663,"don't."],[792,988,"What is the meaning of this, Mr. Hart?"],[988,1146,"Professor, I can explain."],[1192,1292,"Kaitlyn stole my paper,"],[1292,1443,"and Cole's covering for her."],[1443,1589,"I mean, he's only on her side because-"],[1589,1743,"I can prove that she wrote the paper."],[1743,1851,"Well, someone better show me"],[1851,1939,"some evidence now,"],[1939,2052,"or all three of you"],[2052,2177,"will report to the Dean's Office"],[2177,2281,"and face expulsion."],[2302,2414,"That's not fair."],[2414,2573,"Kaitlyn is a cheater and a pathetic slut"],[2573,2723,"that will do anything for a good grade."],[2794,2927,"Professor, listen to me."],[2927,3036,"Business ethics in law"],[3036,3182,"are applied through creation"],[3182,3328,"and enforcement of regulations."],[3374,3482,"This is important because"],[3482,3591,"it fosters trust"],[3591,3824,"between businesses and consumers,"],[3824,3945,"creating a fair marketplace."],[4045,4212,"How did you know that was in her paper"],[4212,4375,"when I'm the one who graded it?"],[4416,4550,"Because I was there when she wrote it."],[4850,4950,"Kaitlyn is my girlfriend."],[4988,5080,"Girlfriend?"]],"41":[[4,104,"Kaitlyn is my girlfriend."],[133,208,"Girlfriend?"],[229,316,"Girlfriend?"],[396,600,"Cole, this is highly inappropriate."],[671,763,"Yeah, I mean, how do we know"],[763,859,"you didn't write the paper?"],[871,984,"The paper goes on to say"],[984,1109,"that upholding business ethics"],[1109,1213,"in law helps prevent"],[1213,1355,"corruption and exploitation."],[1443,1551,"Professor Calloway,"],[1551,1680,"why on earth would I cheat"],[1680,1797,"on an ethics paper?"],[1797,1851,"She's lying!"],[1851,1951,"That's my paper!"],[1951,2052,"Okay, Maddy,"],[2052,2160,"then please explain to us"],[2160,2302,"what the paper does say."],[2502,2