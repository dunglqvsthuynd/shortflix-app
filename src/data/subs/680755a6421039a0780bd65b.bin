{"1":[[37,271,"Grandma, I'm sorry I couldn't save you."],[500,604,"Bye!"],[800,925,"Grandma's no longer here,"],[925,1096,"to stick up for you."],[1217,1338,"I'm her sister."],[1338,1526,"Her fortune is mine."],[1672,1847,"Grandma's just passed away and..."],[1881,2039,"and money is all you care about."],[2122,2389,"Get out of our God damn lives already."],[2535,2756,"She should have never adopted you."],[2815,2898,"Well, you no longer have"],[2898,3002,"to worry about me."],[3140,3257,"I'm leaving."],[3345,3532,"Just don't regret it in the future."],[3728,3820,"Grandma,"],[3858,3966,"I'm sorry."],[4049,4225,"This place is no longer my home."],[4554,4717,"Boss, I can't believe they kicked you out"],[4717,4879,"after everything you've done for them!"],[4904,4988,"Grandma took me in"],[4988,5084,"and cared for me like family."],[5134,5234,"Everything I did was for her."],[5242,5305,"Now that she's gone,"],[5305,5405,"there's no reason for me to stay."],[5497,5638,"You're nicer than me, boss."],[5693,5805,"I'm not letting them"],[5805,5985,"get away without a little payback."],[7820,7974,"Our mansion!"],[7995,8241,"Time to rejoin my real family."],[8641,8775,"I'll send the coordinates."],[8787,8988,"No need, I know how to find them."],[10285,10464,"Welcome home, Miss Patton!"],[10585,10668,"Looks like this family isn't"],[10668,10777,"short on cash after all."],[10789,10890,"Indeed, Miss Patton."],[10910,11002,"Your father is the"],[11002,11148,"richest man on the East Coast."],[11690,11832,"Isabella!"],[11991,12170,"Is that really you?"],[12183,12291,"I'm your mother."],[12408,12487,"Izzy..."],[12525,12641,"welcome home."],[13071,13234,"This is your eldest brother, Brian."],[13250,13417,"He runs the family company."],[13463,13592,"The Patton Group."],[13805,13888,"Go ahead."],[13951,14126,"This is your second brother, Sean."],[14151,14297,"He's a medical genius now."],[14339,14489,"He's saving lives overseas."],[14593,14668,"And Josh,"],[14702,14848,"he's a big time movie star."],[15035,15165,"Shortly after this photo,"],[15165,15286,"someone took you."],[15340,15432,"I failed you."],[15490,15699,"Not a day goes by that she hasn't cried."],[15774,15878,"Evie, you need to rest."],[15878,15970,"Izzy's home now."],[16028,16166,"This is a happy day."],[16195,16299,"With all this wealth,"],[16299,16453,"they must have security."],[16453,16591,"How did I get taken?"],[16641,16745,"Baby cousin!"],[16875,16983,"Welcome home."],[17525,17659,"And stay gone,"],[17659,17759,"you stupid brat!"],[17826,17967,"We don't need you here!"],[18234,18309,"You think you could just"],[18309,18376,"waltz back in here"],[18376,18518,"and take what's mine?"],[18526,18643,"You should have died where I left you"],[18643,18756,"all those years ago!"]],"2":[[421,542,"Here it is."],[725,850,"I love it, Mom."],[867,992,"Thank you."],[1005,1130,"You've had a long day sweetheart."],[1226,1276,"Rest up."],[1297,1376,"Good night, Mom."],[1797,1922,"Boss, we've got a lead."],[1947,2056,"The gang that stole your research is"],[2068,2193,"holed up at Club Deluxe."],[2243,2285,"Gear up."],[2356,2498,"We're getting those documents back tonight."],[2965,3082,"Sir."],[3098,3207,"Your grandmother called again."],[3240,3332,"She is thrilled"],[3370,3490,"about the Patton family finding"],[3490,3574,"their lost daughter."],[3641,3753,"She's gonna be your fiancée."],[3820,3891,"Fiancée?"],[3949,4024,"How old is she again?"],[4112,4208,"21, sir."],[4300,4379,"Pass!"],[4400,4479,"I'm not a babysitter."],[4500,4575,"Pass?"],[4608,4679,"If Miss Bates"],[4679,4842,"finds out that you rejected her."],[4846,4979,"Then make sure she doesn't."],[8208,8291,"Uh, Mr. Bates?"],[8320,8370,"What?"],[8425,8529,"It's your grandmother again."],[8587,8717,"Handle it, make something up!"],[9180,9309,"Don't let her get that shit!"],[9947,10105,"Boss, left turn. Now!"],[10214,10331,"Shoot, dead end!"],[10598,10781,"She's nearby, find out!"],[11344,11444,"That's the girl!"]],"3":[[513,546,"Where'd she go?"],[934,1021,"Can't you see we're busy?"],[1121,1201,"That's Oliver Bates."],[1201,1372,"Head of the Bates family."],[1380,1497,"The richest guy in the city."],[1597,1697,"Sorry to bother you, sir."],[2027,2181,"Appreciate it."],[2218,2260,"Wait."],[2802,2948,"You think you can just use me without"],[2957,3028,"returning the favor?"],[3478,3524,"What do you want?"],[3636,3678,"Nothing."],[3832,3924,"But you still owe me dinner."],[4358,4525,"There, can I go now?"],[4738,4859,"I'll see you around, kiddo."],[6214,6310,"Boss, are you okay?"],[6360,6435,"Wasn't that Oliver Bates"],[6435,6548,"who just stopped you?"],[6556,6639,"Don't worry about it."],[6756,6856,"Take this to the lab and start"],[6856,6952,"production on the medication."],[6990,7027,"Got it."],[7374,7503,"Let me know when you're home, Kiddo."],[7607,7661,"Kiddo?"],[7732,7891,"Seriously, do I look like a kid?"],[8049,8258,"She left me on read?"],[8416,8462,"Bold."],[8495,8708,"Isn't she the same age as the Patton heir?"],[8742,8850,"Funny he just said he"],[8858,8996,"wasn't interested in babysitting."],[9025,9230,"That's a quick turn around."]],"4":[[246,400,"Aunty, I was worried"],[408,542,"Izzy might not sleep well"],[550,696,"in a new place like this."],[784,896,"I guess I was wrong."],[921,1059,"She's really sleeping in."],[1117,1217,"It's so late."],[1326,1476,"Calling me lazy to my own parents."],[1634,1797,"Even worse than my old stepsister."],[2302,2594,"Aunty, Uncle, I have great news."],[2660,2798,"I won first place in the"],[2798,2940,"nationwide piano contest."],[3082,3249,"Congratulations, Eliza."],[3315,3407,"I heard this year's"],[3415,3545,"contest was super competitive."],[3628,3828,"Our Eliza got first place."],[3883,3987,"How amazing."],[4175,4275,"Keep this up and"],[4283,4379,"you'll be internet famous."],[4408,4608,"Just like that Celeste 47."],[4875,4971,"Celeste 47?"],[5000,5092,"You know her?"],[5142,5259,"My piano teacher went to"],[5267,5359,"school with her apparently."],[5447,5630,"I'm surprised you even know who that is."],[5768,5822,"Wow."],[5880,6114,"My reputation as a pianist precedes me."],[6193,6247,"Who knew?"],[6368,6535,"By the way, Izzy,"],[6535,6685,"I doubt you ever even"],[6694,6877,"touched a piano where you grew up."],[6944,7082,"You don't know how to play, do you?"],[7140,7307,"Sorry, sis, you grew up on a farm."],[7349,7432,"It's not your fault you"],[7440,7520,"never learned how to play."],[7536,7615,"Izzy, you had a tough"],[7624,7724,"childhood, I'm sure."],[7770,7866,"It's okay if you don't know"],[7874,7953,"how to play an instrument."],[7974,8145,"If Izzy hadn't disappeared, she would"],[8153,8274,"have been just as good of a player as"],[8283,8429,"Eliza, I'm sure of it."],[8491,8612,"If you want to learn how to play the"],[8621,8854,"piano, Mom and Dad will get you the best"],[8863,8979,"teacher we can find."],[9100,9271,"It's okay, Mom."],[9271,9421,"Don't worry about it."],[9421,9659,"Aw, Izzy, don't be so hard on yourself."],[9718,9930,"Anyone can learn the piano, even you."],[9993,10151,"It might be a little harder for you than"],[10160,10372,"normal people, but"],[10381,10493,"I would be happy to help."],[10865,10965,"Who said I needed to learn?"]],"5":[[41,141,"Who said I needed to learn?"],[375,471,"After breakfast."],[513,617,"We eat first."],[633,742,"You must be starving."],[867,1063,"I really hope we can bond, Isabella."],[1092,1255,"I've always wanted us to be close."],[1317,1451,"Like real sisters."],[1526,1780,"So you're saying we're not real sisters?"],[2035,2114,"No."],[2152,2385,"Let's save the chatter for later."],[2410,2552,"Let's eat before it gets cold."],[2681,2815,"This little hick"],[2815,2973,"thinks she can one-up me?"],[3186,3349,"Mr. and Mrs. Patton,"],[3361,3436,"the Bates family"],[3436,3566,"just sent over a marriage proposal."],[3636,3737,"The Bates?"],[4112,4362,"After all these years, their grandmother"],[4379,4579,"still remembers the arrangement."],[4633,4833,"Marriage arrangement?"],[4875,4992,"Before you disappeared,"],[4992,5071,"it was decided"],[5088,5192,"you'd marry the eldest son"],[5192,5301,"of the Bates family."],[5367,5476,"You know, the most dangerous"],[5476,5605,"family in the country."],[5747,5947,"Why does that name sound so familiar?"],[6823,6986,"They say Mr. Bates is violent."],[7061,7173,"Oh, and every one of his"],[7182,7298,"eight previous engagements"],[7340,7444,"all broke off suddenly."],[7449,7574,"Guess you're lucky number nine."]],"6":[[41,95,"Good to know."],[179,250,"Don't worry, Izzy."],[287,542,"This arrangement was made ages ago."],[563,671,"If you don't want to go through with it,"],[684,792,"we can cancel the whole thing."],[821,938,"At risk of offending the Bates?"],[996,1084,"They could kill us or"],[1084,1205,"bankrupt our company."],[1230,1288,"Doesn't matter."],[1397,1497,"If Isabella doesn't want this."],[1597,1680,"It's not happening."],[1835,2173,"It's ok, Mom and Dad."],[2214,2410,"I am curious to meet this man"],[2414,2648,"my cousin is just so afraid of."],[2902,2977,"Cassie,"],[2977,3073,"do a background check on the Bates"],[3094,3199,"family's eldest son."],[3240,3365,"I want to know if he's as ruthless and"],[3374,3482,"cold-hearted as they say."],[3482,3557,"On it, boss."],[3603,3782,"Sir, we just got intel."],[3795,3920,"Someone's looking into your background."],[3995,4041,"Who's behind it?"],[4137,4304,"The Patton family, sir."],[4316,4404,"Your new in-laws."],[4462,4587,"But don't worry."],[4600,4779,"Your files are still encrypted."],[4788,4879,"They won't even know what you look like."],[5025,5180,"Feed them the fake profile."],[5180,5351,"Make it extra evil."],[5376,5513,"Let's hope my in-laws are smart enough to"],[5513,5630,"call off engagement once"],[5638,5834,"they realize how evil I am."]],"7":[[16,225,"But sir, you've been invited to the"],[233,367,"family dinner to meet their daughter."],[421,621,"If the rumors don't scare them off first,"],[629,771,"I'll go in person"],[784,900,"and break things off once and for all."],[2298,2556,"Busy. Preparing for a party."],[2673,2773,"A party, huh?"],[2794,2952,"If only it was yours I was going to."],[3194,3345,"Isn't this banquet supposed to be for"],[3353,3478,"your sister?"],[3486,3616,"You know, the country bumpkin?"],[3653,3724,"Cousin."],[3803,3987,"Whatever, I heard she smells like hay."],[4304,4512,"How rude of her to be late to her own party."],[4575,4813,"See? She might be the real daughter."],[4859,4996,"But she's not a true Patton."],[5063,5217,"You can't teach class."]],"8":[[425,617,"Ah, she's gorgeous."],[1280,1388,"This,"],[1393,1597,"is the lost Patton's daughter?"],[1739,1872,"Wow."],[2077,2231,"She's even more stunning than Eliza."],[2915,3044,"What? No!"],[3061,3194,"They like that rat?"],[3440,3545,"Everyone,"],[3553,3737,"it is our honor to introduce"],[3737,3862,"our daughter,"],[3862,4104,"the Patton family's heiress,"],[4104,4225,"Isabella."],[4888,5105,"Finally, our family is complete."],[5192,5288,"And to celebrate,"],[5292,5484,"Isabella has prepared"],[5484,5568,"a piano performance"],[5609,5697,"for all of you."],[6043,6106,"Piano?"],[6126,6272,"Isabella doesn't play the piano."],[6314,6498,"Eliza, what are you thinking?"],[6506,6685,"You're the piano star around here,"],[6685,6777,"not your sister."],[6777,6915,"Why don't you play something instead?"],[6998,7098,"Sorry, sis."],[7098,7278,"I forgot they don't have pianos"],[7286,7407,"where you come from."],[7428,7520,"Well, if you want,"],[7540,7670,"you can tell everyone here"],[7695,7836,"you don't know how to play"],[7841,7966,"and I can take over."],[8395,8550,"Remind everyone here"],[8554,8696,"you're not the real, cultured heiress."],[8754,8854,"I am."]],"9":[[20,100,"It'll be my pleasure."],[1347,1426,"You don't have to, Isabella."],[1480,1568,"It's okay, Mom."],[2139,2318,"This is going to be hilarious."],[4270,4396,"How is this possible?"],[4466,4587,"She even plays better than you,"],[4604,4688,"Miss Eliza."],[5843,6106,"This next piece is meant for two."],[6131,6218,"Care to join me, cousin?"],[6343,6456,"Of course."],[6514,6685,"Anything for family."],[7586,7649,"What's wrong?"],[7786,7849,"Nervous?"],[7978,8091,"You know you could still back out."],[9325,9426,"What is she doing?"],[9442,9551,"She sounds awful."],[9551,9805,"She won first place in a competition?"],[9826,9964,"Looks like her parents paid for that."],[10005,10235,"You planned this, you set me up!"],[10264,10418,"I simply gave you the spotlight"],[10427,10560,"you so desperately wanted."],[10927,11177,"Cross me again and you'll wish"],[11190,11302,"that this was the worst of it."]],"10":[[87,171,"Sir,"],[216,287,"are you sure you want to"],[287,412,"call the engagement off?"],[517,638,"Grandma won't let it go,"],[679,855,"unless I put my foot down."],[1480,1634,"Uncle Jack, Aunt Evie,"],[1647,1822,"I know Isabella doesn't like me,"],[1847,1931,"but I never thought she'd"],[1931,2056,"stoop so low as to change"],[2085,2268,"the sheet music just to humiliate me."],[2335,2519,"That doesn't sound like Isabella."],[2527,2623,"Maybe one of the staff"],[2640,2794,"accidentally switched the score."],[4612,4804,"It's him, the Bates family heir."],[4917,5080,"Looks like my revenge has arrived."],[5109,5180,"Time to meet your nasty new"],[5180,5321,"husband, cuzzo."],[5814,5930,"Is that the Patton family's"],[5930,6076,"youngest daughter?"]],"11":[[254,371,"Is that the Patton family's"],[371,517,"youngest daughter?"],[1130,1309,"Mom, I need to take this, I won't be long."],[1351,1543,"Hurry back, your fiancé's here."],[1801,1947,"That's the Bates heir."],[1976,2093,"He's handsome."],[2173,2277,"He would have been mine if it weren't for"],[2285,2369,"that bitch showing up"],[2377,2469,"and ruining everything."],[2823,2948,"Oliver, it's been a while."],[3002,3111,"Mr. and Ms. Patton,"],[3153,3274,"I'm here to discuss the engagement."],[3449,3528,"Of course."],[3528,3670,"We were just talking about it."],[3707,3820,"I'm no longer interested."],[4408,4491,"What did you say?"],[4575,4654,"You're rejecting our"],[4662,4854,"daughter in front of everyone?"],[4921,5063,"Did he just publicly"],[5071,5246,"embarrass the Patton family?"],[5276,5397,"Mr. and Mrs. Patton,"],[5442,5572,"I can't marry someone I don't love."],[5634,5684,"My family will"],[5693,5818,"compensate yours for your time."]],"12":[[196,337,"Uncle Jack, Aunt Evie,"],[371,492,"maybe he thinks Isabella"],[513,642,"coming from the countryside"],[654,813,"isn't suitable for him."],[884,996,"After all, the Patton family"],[1005,1117,"has more than one daughter."],[1176,1234,"We shouldn't ruin"],[1242,1363,"relations with the Bates family"],[1372,1455,"over this."],[1522,1722,"Don't speak about Isabella that way."],[1730,1810,"Watch your mouth."],[1951,2027,"My daughter can"],[2035,2118,"and will do better than him."],[2181,2281,"Oliver Bates is never to"],[2289,2402,"set foot in this house again,"],[2410,2485,"even if he comes begging."],[2857,2961,"Is that the girl from the club?"],[3044,3161,"Sir, we should go."],[3490,3649,"Mom, what's wrong?"],[3699,3799,"It's nothing sweetheart."],[3816,3908,"Don't worry about it."],[3953,4116,"We'll find you someone much better."],[4233,4391,"This is all your fault."],[4441,4517,"Oliver called the"],[4525,4654,"engagement off because of you."],[4717,4842,"Way to humiliate us."],[5155,5213,"She needs a rest,"],[5221,5326,"this is too much for her."]],"13":[[87,229,"I'm going to make sure Oliver Bates"],[237,371,"regrets making this decision."],[417,554,"Oh please!"],[563,842,"You're a nobody, Isabella."],[850,980,"You don't know who you're up against."],[1017,1213,"Do yourself a favor and leave it alone"],[1222,1288,"before you make"],[1297,1447,"things even worse for mom."],[1501,1647,"Back off, Eliza."],[1780,1843,"I will take care of"],[1851,1926,"this, Mom, don't worry."],[1976,2077,"Be careful, Izzy."],[3228,3324,"You head back."],[3332,3428,"I got something I'm gonna take care of."],[3645,3757,"Follow Mr. Bates's car."],[3770,3945,"When he gets out, beat him senseless."],[3983,4054,"Remember me?"]],"14":[[112,221,"Hey kiddo,"],[233,312,"remember me?"],[333,433,"What's he doing here?"],[458,684,"Yeah, you're the old guy from the club"],[704,788,"who won't leave me alone."],[909,1013,"Old guy?"],[1021,1155,"You still owe this grandpa dinner then."],[1301,1372,"You busy right now?"],[1618,1868,"Let's just get this over with."],[2364,2519,"Here's a message from the Pattons."],[2927,3019,"Fucking Doctor Who!"],[3169,3261,"Who's that?"],[4358,4575,"Oliver, on a date."],[4708,4763,"Weird."],[5000,5292,"Donny, you have three seconds to get lost,"],[5347,5568,"before I permanently make you lost."],[6093,6235,"I have to get this."],[6902,7006,"Aren't you a little young"],[7019,7152,"to be dating Ollie?"],[7453,7720,"Wait, don't tell me you're underage."],[7799,8033,"Do I look underage?"],[8433,8704,"Well, the milk doesn't help."],[8717,8817,"Don't you want a cocktail"],[8817,8896,"or something?"],[9075,9129,"I'm not paying."],[9613,9751,"Well,"],[9751,9947,"cheers to new friends."],[10652,10810,"Oh, my back."]],"15":[[37,166,"Oh my back!"],[254,412,"Grandma, I gotta go."],[508,633,"Oh Oliver,"],[688,809,"you gotta help me."],[829,892,"She looked like she had"],[892,984,"too much to drink"],[1046,1192,"and when I tried to take her glass away,"],[1205,1305,"she attacked me."],[1330,1426,"Why were you giving her"],[1434,1551,"alcohol in the first place?"],[1597,1672,"Why was I supposed to"],[1680,1755,"know she's a lightweight?"],[1918,2031,"A violent lightweight."],[2131,2189,"No, don't!"],[2690,2840,"It is funny though."],[2948,3028,"What the..."],[3211,3261,"Izzy?"],[3349,3420,"It's Izzy!"],[3478,3632,"It's my name!"],[3682,3782,"That's a nice necklace."],[4208,4337,"You gotta be kidding me."],[4350,4500,"You walk in and now she's all cuddly?"],[4600,4675,"It's not fair."],[5167,5267,"What the hell happened to you?"],[5347,5438,"The Patton family sends"],[5438,5551,"their regards."],[5597,5651,"Ouch."],[5718,5780,"Sorry, Martin."],[5839,5922,"I'll increase security"],[5930,6031,"until they finally accept"],[6039,6177,"that I'm not interested in their daughter."],[6531,6685,"Wait, stay."],[6781,6915,"I'm not going anywhere, Kiddo."],[7365,7432,"Never seen you let"],[7432,7603,"anyone ride with you before."]],"16":[[717,804,"Uh..."],[804,938,"should we clean her up?"],[988,1088,"I'll take care of it."],[1226,1405,"Don't let my grandma know about this."],[1434,1722,"Sir, not a word."],[3065,3211,"I've worked here for years."],[3294,3428,"Well, I've never seen Mr. Bates"],[3436,3561,"bring anybody home."],[3603,3753,"I mean, let alone a girl."],[4291,4454,"Oliver has a woman over."],[5059,5167,"What's wrong, kiddo?"],[5338,5430,"My head hurts."],[5572,5701,"You have a nasty headache."],[5793,5897,"Happens to newbies."],[5972,6101,"I'm not a kid."],[6218,6418,"And I'm certainly not a newbie."],[6573,6669,"Stop fighting."],[6727,6852,"I'm gonna have to punish you."],[6865,6965,"Punish me?"],[7486,7649,"Looks like the tables have turned."],[7732,7845,"You're a feisty one."],[8191,8279,"What the hell was that for?"],[8295,8445,"Just give up."],[8721,8842,"I was going too easy on you."]],"17":[[2886,2994,"Good morning."],[3090,3132,"Eat."],[3132,3232,"It will help with the hangover."],[3274,3449,"W-Where am I?"],[3507,3599,"What am I doing here?"],[3632,3720,"You're at my place."],[3832,4012,"Seems like last night was a blur for you."],[4195,4316,"I don't,"],[4333,4466,"really remember what happened."],[4554,4675,"Let me jog a memory for you."],[4896,5000,"Are you saying I did that?"],[5055,5109,"What,"],[5109,5230,"you don't want to take responsibility?"],[5292,5568,"I don't mind claiming a face like his."],[5634,5926,"I guess I owe you another dinner date."],[6051,6118,"Date?"],[6118,6243,"But not tonight."],[6385,6452,"My family's probably wondering"],[6452,6523,"where I am."],[6598,6648,"But..."],[7745,7803,"Eliza."],[8045,8249,"Hey, what's wrong?"],[8533,8600,"Who made you cry?"],[8641,8758,"Our sister Isabella."],[8825,8963,"I don't think she likes me."],[9059,9171,"Last night at the banquet,"],[9213,9321,"she switched the sheet"],[9321,9434,"music so I'd mess up."],[9488,9622,"Now everyone's laughing at me,"],[9622,9738,"and they're saying I'm,"],[9738,9872,"I'm,"],[9872,10051,"I'm a terrible piano player!"],[10118,10201,"Where is she?"],[10201,10285,"I'll set her straight."],[10356,10427,"Set who straight?"],[10785,10910,"Stand up when I'm talking to you."],[11348,11428,"I'm older than you."],[11561,11678,"Don't tell me what to do."]],"18":[[208,316,"Brian, just let it go."],[450,533,"I don't wanna come between"],[542,658,"you and your real sister."],[850,1009,"Isabella, let me put your helmet away."],[1017,1096,"You've been gone all night."],[1138,1226,"You must be exhausted."],[1255,1322,"Don't,"],[1355,1426,"touch it."],[1634,1710,"See, big brother?"],[1881,2002,"I never imagined Isabella"],[2010,2152,"would dislike me this much."],[2256,2339,"I'm so annoying."],[2344,2444,"Maybe I should just leave."],[2498,2577,"You know what?"],[2727,2836,"You are really annoying."],[2957,3044,"Maybe you should leave."],[3591,3678,"Eliza,"],[3741,3891,"this is your home too."],[3903,3978,"Nobody,"],[4004,4108,"is pushing you out."],[4124,4166,"Come here."],[4412,4491,"I'll make sure"],[4491,4562,"everyone in this family"],[4575,4692,"turns against you, Isabella."],[5009,5071,"And you."],[5117,5159,"Don't think you"],[5167,5234,"can just come back here"],[5242,5317,"after 10 years and act"],[5326,5392,"like you own the place."],[5426,5559,"You keep treating Eliza like this,"],[5584,5647,"don't expect me to"],[5655,5726,"consider you my sister."],[5805,5864,"Well,"],[5939,5985,"if you're too"],[5993,6151,"stupid to see through her act,"],[6160,6268,"I don't think I'm missing"],[6268,6339,"out on much."],[6452,6519,"Hey!"],[6519,6594,"Get back here!"],[7232,7311,"What's going on?"],[7403,7461,"How could you let"],[7469,7582,"Isabella get away with this?"],[7653,7703,"Last night,"],[7720,7807,"she tore Eliza’s"],[7807,7903,"sheet music at banquet"],[7903,7999,"and humiliated her."],[8053,8124,"I mean, Isabella doesn't"],[8133,8216,"even come home at night."],[8249,8299,"What does she think,"],[8299,8383,"we're running a motel?"],[8450,8566,"Watch your mouth, son."],[8625,8687,"How could you speak"],[8696,8821,"about your sister like that?"],[8875,8946,"You know nothing about"],[8954,9034,"what she's been through."],[10014,10060,"Hey."]],"19":[[183,304,"Evie, Evie!"],[304,404,"What's wrong? Wake up!"],[1305,1388,"Let me examine her."],[1434,1543,"What do you know?"],[1609,1701,"Aunt Evie's health has"],[1710,1818,"always been delicate."],[1885,2047,"She was fine until you came back."],[2202,2352,"Are you saying this is my fault?"],[2394,2456,"Yesterday when the Bates"],[2464,2585,"family called off the engagement"],[2602,2702,"because of you,"],[2711,2811,"it nearly broke her heart."],[2840,2907,"You're cursed."],[2932,3011,"Just leave already."],[3353,3511,"What the hell do you think you're doing?"],[3520,3599,"Get away from her."],[3624,3707,"Get out of my way."],[3770,3849,"What the fuck do you"],[3858,3953,"even know about medicine?"],[3978,4112,"You're just a bum, who's here for money."],[4145,4200,"If you have an ounce of"],[4208,4329,"decency, you'll stay away from her."],[4446,4558,"Dad, please just"],[4567,4683,"trust me this once, okay?"],[4692,4733,"I'll take full"],[4742,4867,"responsibility for what happens."],[4934,5088,"All right, do it."],[5171,5246,"Uncle Jack! - Dad!"],[5392,5438,"Stop!"]],"20":[[83,154,"Stop!"],[191,254,"Didn't you hear him?"],[258,325,"He said stop!"],[421,521,"Let go of me!"],[709,779,"Who the hell do you"],[779,846,"think you are?"],[850,934,"I said stop!"],[963,1067,"Are you trying to kill my mother?"],[1096,1159,"Shawn, stop!"],[1205,1388,"This is your sister, Isabella."],[1543,1618,"Isabella, I..."],[1710,1780,"I'm sorry."],[1835,2031,"But I can't let anyone just treat her."],[2127,2189,"Well, if you don't trust"],[2193,2323,"me, then help her yourself."],[3144,3249,"I can't hear her pulse."],[3340,3420,"It's too faint."],[3524,3632,"We need to call an ambulance,"],[3666,3778,"but there's not enough time."],[3803,3891,"W-What the hell do you mean?"],[3966,4083,"You can't help her, let me."]],"21":[[104,171,"Izzy,"],[171,283,"I get that you want to prove"],[291,475,"yourself, but even Shawn, the"],[483,650,"medical genius said there's no solution."],[717,859,"Please don't make this worse."],[892,963,"Haven't you done"],[963,1038,"enough damage already?"],[1092,1172,"Showing off your shady"],[1180,1343,"remedies trying to experiment on mom?"],[1401,1572,"Sean, keep an eye on her."],[1584,1714,"If anything looks wrong, step in."],[1864,1964,"Go on, Izzy."],[2060,2143,"Give me space."],[2631,2786,"First, a syringe, now a pill from"],[2786,2894,"God knows where?"],[2894,3011,"Are you trying to poison her?"],[3086,3278,"You almost just made me drop the one pill"],[3286,3390,"that's gonna save my mother."],[3403,3591,"Ow, let me go, you're hurting me!"],[3591,3803,"That pill is not even FDA approved."],[3866,3966,"Nobody can afford it."],[3974,4054,"How did you get this?"],[4133,4166,"What?"],[4671,4779,"She's coughing up blood!"],[4850,5009,"I told you she would make things worse!"],[5017,5080,"Look what you've done!"]],"22":[[0,87,"Look what you've done!"],[87,191,"Wait, look!"],[312,504,"Evie, you're awake."],[700,792,"What happened?"],[809,896,"You fainted."],[1209,1351,"Your body couldn't handle stress."],[1463,1609,"If it wasn't for Isabella,"],[1764,1885,"I might have lost you."],[1951,2135,"My sweet girl,"],[2156,2281,"you saved me."],[2544,2619,"That's what I'm here for."],[2861,2907,"I'm gonna get you"],[2907,3002,"back to health, okay?"],[3090,3207,"I promise."],[3737,3774,"Izzy. - Izzy."],[4170,4300,"This is how you treat your sister?"],[4400,4512,"How dare you?"],[4662,4854,"If Isabella walks away from this family"],[4863,5130,"because of your behavor, I swear,"],[5176,5359,"I'll never forgive either of you."],[5480,5613,"Mom, we didn't know."],[5764,5860,"What are you waiting for?"],[5943,5964,"Go!"],[6076,6222,"Bring Isabella back here."],[6314,6439,"If you don't,"],[6544,6744,"don't even think about calling me mom."]],"23":[[1117,1226,"Boss, here's more of"],[1234,1363,"the serum you requested."],[1438,1626,"That was quick. Good work."],[1726,1856,"Well, you created this formula."],[1901,1985,"I mean, I still don't know"],[1993,2110,"how you devised this stuff."],[2122,2281,"You could be making millions, you know."],[2385,2519,"Oh, ma'am, speaking of..."],[2585,2736,"the Bates family requested"],[2744,2932,"this formula from our pharmacy."],[2990,3119,"Should I approve the sale?"],[3261,3378,"The Bates family?"],[3474,3653,"Do not approve any requests from them."],[3661,3799,"They are no longer our clientele."],[3841,4074,"Oh, I'm sorry. Yes."],[4746,4913,"After what you did to my mother,"],[4984,5184,"good luck, Bates family."],[5459,5555,"You're gonna need it."]],"24":[[104,171,"Help!"],[171,237,"Somebody!"],[254,387,"We need a doctor!"],[1263,1430,"A heart attack?"],[1447,1543,"If had been by my own"],[1543,1618,"grandma's side during"],[1618,1697,"her heart attack,"],[1697,1868,"she wouldn't have passed."],[1935,2027,"Hey, kid!"],[2047,2143,"Stay back!"],[2173,2285,"You don't know what you're doing!"],[2331,2448,"We called an ambulance."],[2448,2527,"Let them handle it."],[2535,2590,"Move!"],[3361,3536,"These are supposed to be for Mom."],[3595,3687,"What are you doing?"],[3724,3828,"You're not a doctor!"],[3899,3987,"I'm just as good as one."],[5726,5759,"Oh."],[5885,5960,"Oh, oh."],[6026,6139,"Oh, oh."],[6147,6277,"Am I in heaven?"],[6331,6377,"No, ma'am."],[6423,6481,"Oh. - You're very"],[6481,6539,"much alive."],[6569,6623,"Oh."],[6631,6748,"Thanks to this young lady."],[6748,6798,"Oh."],[6806,6952,"Oh, you don't know,"],[6952,7032,"how much"],[7032,7278,"what you just did means to me."],[7311,7349,"See,"],[7369,7494,"I still need,"],[7494,7599,"to see,"],[7611,7874,"my grandson married."],[7953,8103,"Well, I'm just glad you're okay."],[8204,8425,"So beautiful."],[8425,8554,"Oh,"],[8571,8758,"and kind-hearted."],[8821,8983,"If only,"],[9034,9217,"you could be,"],[9238,9459,"my grandaughter-in-law."],[9743,9864,"Oh."],[10264,10443,"Oh, no, no, I can't possibly-"],[10472,10581,"Oh, sweetheart,"],[10602,10723,"take this."],[10760,11023,"If ever you need anything,"],[11106,11411,"you come and find me."],[11786,11920,"Let's get you up, okay?"],[11999,12074,"Two... - Okay..."],[12078,12141,"Oh! - Three..."],[12195,12270,"Oh, Oh!"],[12708,12779,"Guess I'll have to return"],[12779,12871,"this ring another time."]],"25":[[137,300,"Sir, your grandmother was"],[308,421,"admitted to the hospital."],[458,487,"What?"],[838,942,"I feel fine."],[1021,1130,"I'm going home,"],[1134,1230,"and there's nothing"],[1230,1376,"that you can do to stop me."],[1730,1889,"Grandma, you had a heart attack."],[1922,2006,"Stop fussing."],[2014,2135,"I'm not fussing."],[2285,2481,"I feel better than I ever have."],[2535,2836,"This, this girl, this angel in the street,"],[2836,2973,"she saved me."],[2994,3169,"I have to find her."],[3257,3365,"Your job is to rest."],[3415,3595,"Not track that girl down."],[3712,3824,"I'll have someone find her."],[3858,4083,"Oliver, wait till you see how she's"],[4091,4350,"beautiful and kind-hearted."],[4416,4529,"Without her,"],[4537,4738,"your grandmother would be in"],[4746,5025,"a casket instead of a hospital bed."],[5100,5209,"Bet she doesn't compare"],[5209,5292,"to my kiddo."],[5338,5455,"Oh, right."],[5472,5622,"When are you going to"],[5630,5855,"introduce me to your fiancée?"],[5926,6056,"I don't have a fiancée."],[6164,6235,"I'm..."],[6331,6485,"I'm not going through with my engagement"],[6493,6606,"to the Patton heiress."],[6660,6781,"Oh goodness, Oliver."],[6894,7157,"My heart was just starting to improve."],[7190,7382,"And now, you tell me this."],[7440,7557,"You're going to kill me"],[7565,7732,"before this heart attack does."],[7841,8008,"Don't be so dramatic, Grandma."],[8062,8229,"Take, take a nap, okay?"],[8316,8600,"I'll go look for this angel of yours."],[8658,8879,"Well, she has the family ring."],[8929,9221,"That's how you know that she's the one."],[9271,9380,"And you give her"],[9380,9605,"anything she asks for."],[9672,9738,"Come here."],[10389,10639,"Sir, about the engagement-"],[10652,10781,"Just worry about finding the girl"],[10789,10885,"who saved my grandmother."],[10952,11161,"Satisfy any demand she might have."],[11194,11311,"We're indebted to her."],[11365,11461,"Sure thing, Mr. Bates."],[12620,12816,"What are the odds?"],[12937,13058,"The girl who saved"],[13058,13304,"my life is the Patton heiress."],[13329,13463,"Oh!"]],"26":[[625,684,"How are you, Mom?"],[842,930,"You're finally back."],[1067,1238,"Izzy, I'm so sorry about"],[1247,1338,"what happened last time."],[1388,1476,"It won't happen again."],[1601,1726,"Izzy, I apologize too."],[1860,1985,"I never should have doubted you."],[2118,2285,"From now on, you have our full support."],[2369,2594,"I'm working on some new meds for you now."],[2681,2836,"They should be ready soon."],[4487,4625,"Boss, we have a new request"],[4625,4704,"on the database."],[4738,4959,"Someone's offering you two million"],[5013,5117,"for a prescription of your"],[5125,5238,"heart disease medication."],[5309,5367,"Two million?"],[5501,5626,"Well, weren't you saying"],[5634,5739,"the lab is low on funds."],[5747,5805,"Let's accept it."],[5843,6081,"Uh, there's just one thing."],[6131,6264,"The request is from the Bates family."],[6348,6418,"The Bates family?"],[6585,6669,"Then forget it."],[6702,6852,"Ask them to double the"],[6861,6973,"price and then reject them."],[7011,7069,"If they agree."],[7173,7236,"As you wish, boss."],[8041,8208,"Mr. Bates, we're offering way"],[8216,8312,"more than the other bidders,"],[8320,8425,"but this dealer is still"],[8433,8554,"asking us to double the price."],[8583,8671,"Greedy bastard."],[8675,8758,"It's fine."],[8804,8846,"Double it."],[8946,9050,"Nothing else matters"],[9059,9184,"other than my grandma's health."],[9513,9592,"They still rejected it."],[9693,9755,"They're saying they're"],[9763,9847,"not gonna work with us"],[9859,9951,"under any condition."],[9984,10097,"If the money doesn't work,"],[10168,10301,"we'll have to resort to other methods."],[10435,10610,"Get me a meeting with this dealer."],[10673,10814,"Have our men surround the area."],[10902,11015,"He'll give up this recipe."],[11136,11311,"If not, we'll take it."],[11386,11448,"Copy."]],"27":[[367,517,"My necklace from grandma."],[704,775,"Izzy!"],[2147,2202,"This it?"],[2223,2302,"Yes, that’s it!"],[2318,2419,"Oh, my God!"],[2427,2523,"Oh, my God!"],[2540,2602,"Oh, shoot!"],[2715,2777,"I was,"],[2798,2927,"not expecting a show."],[3015,3098,"But thank you."],[3128,3174,"Hmm hmm."],[3182,3274,"Yeah, shut it and"],[3294,3415,"hand over my necklace ASAP."],[3528,3607,"Fine."],[3649,3774,"Next time I see you."],[4371,4450,"Her name is,"],[4500,4567,"Izzy."],[4725,4771,"Ready, boss?"]],"28":[[12,66,"Mr. Bates,"],[75,216,"you're telling me this dealer,"],[233,342,"denies our request"],[342,517,"after we offer him two million,"],[517,667,"and now he wants to meet?"],[675,779,"Something's not right."],[788,942,"Anyone who tries to screw with me,"],[942,1084,"is gonna get what's coming to them."],[1209,1259,"Hold."],[1388,1484,"We need to pat you down."],[1551,1601,"Hell no."],[1601,1760,"Mr. Bates doesn’t do security checks."],[1772,1881,"Well, if you don't comply,"],[1881,1939,"you can leave."],[1943,2018,"And that's the deal."],[2081,2164,"You two are acting pretty"],[2164,2289,"tough for a couple of doormen."],[2344,2423,"Rules are rules."],[2498,2736,"Follow them, or piss off."],[3319,3357,"Oh!"],[3361,3382,"Woah!"],[3386,3440,"What the..."],[3440,3495,"Stop, stop, hey-"],[3507,3566,"Shit! - No, no, no, not the-"],[3566,3641,"No, no, no!"],[3878,3928,"Jesus."],[3966,4058,"You let ‘em in!"],[4087,4208,"You know, we-we were"],[4216,4404,"supposed to rough them up a little bit."],[4446,4479,"Shit,"],[4479,4567,"it's too late now."],[4612,4637,"Quick."],[4637,4721,"Better let the boss know that"],[4721,4783,"they're coming."],[4850,4925,"Shit!"],[5155,5221,"Boss."],[5267,5388,"Mr. Bates just entered the"],[5397,5488,"building, the guards are"],[5497,5609,"leading him to the secret room."],[5668,5784,"The plan is..."],[5789,5918,"to lock them inside,"],[5943,6039,"and set it off."],[6114,6222,"They'll have no way out."],[6227,6335,"Good work."],[6335,6573,"Now sit back and watch, boss."],[6644,6760,"Mr. Bates,"],[6760,6877,"screwed with the wrong family."],[7023,7165,"When is this dealer showing up?"],[7173,7228,"Quiet!"],[7265,7411,"Her schedule is none of your business."],[7474,7532,"Your job is to"],[7532,7636,"sit here and wait patiently."],[8233,8270,"Her?"]],"29":[[650,859,"This asshole is really asking for it..."],[925,946,"You? - You?"],[1130,1255,"Izzy, what are you doing here?"],[1334,1434,"Deactivate the bomb, Cassie."],[1943,2060,"Boss, get out of there!"],[2060,2127,"Get out of there!"]],"30":[[246,321,"You're hurt."],[392,513,"You're worse."],[750,842,"Oh my God, does that hurt?"],[992,1046,"If I say it hurts,"],[1121,1222,"will you blow on it for me?"],[1422,1484,"Yeah."],[2414,2456,"Thanks, kiddo."],[2565,2640,"Feels better already."],[2865,3140,"So, uh, you being an"],[3148,3311,"international drug dealer,"],[3319,3386,"what you're doing when"],[3395,3495,"you're not texting me back?"],[3566,3636,"No comment."],[3695,3858,"I'll take my necklace back now."],[3920,3999,"Boss, are you..."],[4116,4270,"Izzy, what are you doing here?"],[4400,4542,"Is the dealer scamming you too?"],[4633,4742,"Tell the sniper to go home."],[4904,5005,"Looks like I wasn't the"],[5005,5105,"only one with a back up plan."],[5159,5263,"B-but Mr. Bates,"],[5263,5317,"don't you want to"],[5317,5376,"catch the dealer?"],[5397,5526,"Everything's in place."],[5563,5755,"Once we catch him, we'll lock him up,"],[5764,5826,"and we can give him"],[5826,5939,"the beating he deserves."],[6131,6185,"Wow."],[6227,6289,"Harsh."],[6339,6423,"He doesn't mean that."],[6473,6560,"Wait a minute."],[6581,6644,"Izzy..."],[6777,6902,"Are you the dealer?"],[6994,7107,"We'll talk about it when we get home."],[7161,7211,"Get the car."],[7720,7782,"Who would have thought"],[7782,7891,"that the random guy"],[7891,8003,"I kissed at a club was..."],[8041,8137,"gonna have a sniper"],[8137,8237,"pointed at me?"],[8295,8466,"And the man I was engaged to."],[8558,8591,"Kiddo,"],[8671,8725,"what do I have to do"],[8733,8817,"to make it up to you?"]],"31":[[58,316,"Izzy, don't blame Mr. Bates."],[316,437,"He just wanted the medication"],[437,500,"for his grandma."],[533,650,"She needs it to stay alive."],[692,913,"However, all of this cost,"],[996,1080,"I'll pay you back"],[1126,1355,"ten-fold, okay?"],[1376,1580,"You called off your engagement to me."],[1593,1718,"You humiliated my family"],[1718,1835,"and almost killed my mother"],[1835,2006,"with your carelessness."],[2006,2177,"I won't make it that simple for you."],[2193,2364,"No matter how much I like you."],[2535,2644,"Cash up front."],[2736,2823,"Your words not mine."],[2927,3128,"Hey, it's fine, I owe you."],[4091,4191,"Five?"],[4233,4387,"Five million dollars?"],[4604,4679,"The money will be in your account"],[4679,4767,"by tomorrow morning."],[4788,4934,"Good Lord!"],[4954,5109,"Anyone who thinks they're a big spender"],[5109,5263,"has never seen Mr. Bates"],[5263,5430,"when he's trying to please his girl."],[5518,5568,"Perfect."],[5622,5780,"So, how are you going to"],[5789,5918,"spend your five million?"],[6010,6239,"Relax, I'm not going to waste it."],[6247,6322,"We'll put it towards"],[6322,6381,"your grandma's treatment."],[6439,6535,"Really?"],[6577,6690,"Wa-wow."],[6781,6961,"That's really kind of you, Isabella."],[7032,7173,"Maybe you should meet her yourself."],[7236,7298,"If you want."],[7494,7590,"Alright."],[7670,7849,"We'll visit her tomorrow, and"],[7857,7974,"I'll stay at your place tonight."]],"32":[[504,700,"Mr. Bates, everything has been arranged"],[709,809,"according to your wishes."],[900,1017,"Perfect, Kiddo."],[1017,1117,"The room's all ready for you."],[1172,1251,"Wanna take a shower first?"],[1413,1501,"Yes, I'd like that."],[2723,2898,"This is what he gave me?"],[2977,3044,"Ugh."],[3115,3207,"That man whore."],[3420,3557,"It looks kinda nice."],[3895,3937,"Dressed?"],[4379,4575,"If that's what you wanna call it."],[4767,4863,"Milk before bed."],[4900,4979,"And lingerie."],[5075,5192,"You seriously need to"],[5201,5305,"figure out how you see me."],[5488,5718,"Lingerie was a bit of an overstep"],[5739,5834,"on behalf of my maid."],[5901,6018,"I don't bring women"],[6026,6222,"around, so our protocol is..."],[6648,6710,"nonexistent."],[7169,7328,"No touching, Izzy."],[7453,7611,"Jeez, it's just your neck."],[7736,7824,"Don't be so sensitive."],[7907,8016,"Where else were you gonna touch?"],[8400,8441,"Nowhere."],[9188,9280,"Sure you weren't."]],"33":[[1288,1351,"Morning, kiddo."],[1426,1518,"I went to visit my"],[1526,1626,"grandma at the hospital."],[1701,1810,"There's breakfast downstairs."],[1868,1943,"Meet me when you're done."],[2748,2898,"Oliver, when you called off the"],[2907,3169,"engagement at the Patton's banquet,"],[3219,3524,"you made your whole family look bad."],[3574,3799,"I want you to meet the Patton heiress."],[3828,4029,"Give her a chance, okay?"],[4099,4270,"And stop being so stubborn."],[4300,4471,"Grandma, I'm not going to marry her."],[4558,4596,"I'm sorry."],[4654,4979,"I had her parents send me a photo of her."],[5050,5130,"Take a look."],[5430,5572,"I met her myself."],[5689,5826,"And she's a catch."],[5935,6206,"And if you don't marry her,"],[6206,6327,"you will make the biggest"],[6335,6527,"mistake of your whole life."],[6639,6881,"I'm in love with someone else, okay?"],[6998,7223,"Nonsense, you're just saying that."],[7303,7590,"If someone else has your heart, then you"],[7599,7932,"bring her to me and I will see her."],[7945,8074,"Okay, okay."],[8153,8266,"I'll let you meet her, Grandma."],[8287,8575,"She should be here at"],[8583,8675,"the hospital by now."],[8683,8725,"Yeah."],[8737,8829,"I'll go grab her."]],"34":[[337,442,"Oh, there she is."],[550,642,"Mrs. Bates."],[671,746,"Oh!"],[759,855,"It's you! - Oh!"],[863,1080,"My sweet little angel."],[1101,1188,"Oh!"],[1209,1263,"Oh!"],[1276,1480,"My prayers came true."],[1501,1722,"You're going to be my future"],[1722,1914,"granddaughter-in-law."],[2031,2135,"You know who I am?"],[2181,2419,"Well, when you get to be my age,"],[2452,2665,"you get pretty good at finding out"],[2665,2840,"a bit of gossip or two."],[3098,3165,"Um,"],[3211,3461,"Mrs. Bates, the ring"],[3461,3591,"you gave me last time,"],[3591,3653,"it's..."],[3716,3841,"it's too valuable."],[3841,3983,"I feel bad keeping it."],[3999,4120,"Oh, it's okay."],[4120,4300,"I want you to keep it."],[4325,4696,"I plan to pass it on to my future"],[4696,4946,"granddaughter-in-law."],[5071,5484,"Well, that is if you'd like my Oliver."],[5980,6081,"Oliver?"],[6256,6360,"Yeah, he's um..."],[6389,6498,"he's all right, I guess."],[6635,6890,"Does he know you're the Patton heiress?"],[6977,7178,"Actually, he doesn't."],[7244,7382,"Not-not yet, at least."],[7382,7444,"Oh."],[7515,7657,"Kiddo, what are you doing here?"]],"35":[[200,521,"I met this nice girl out in-in"],[521,596,"the hallway,"],[596,809,"and she walked me to my room."],[930,1001,"Grandma, that's..."],[1017,1159,"that’s the girl I told you about."],[1192,1267,"You've met her!"],[1422,1568,"So about my marriage with"],[1568,1655,"with the Patton heiress."],[1718,1864,"Oh, call it off."],[1864,2018,"Call it off right now."],[2027,2252,"And when I get out of the hospital,"],[2260,2377,"I'll go to the house with you."],[2385,2460,"Okay, one..."],[2489,2573,"once you’re feeling"],[2573,2648,"better, we'll both go."],[2673,2836,"Oh, Oliver, um,"],[2844,3040,"could you get me my meds?"],[3082,3140,"Okay."],[3224,3336,"Isabella, um,"],[3345,3532,"let's not blow your cover yet."],[3595,3949,"This fool is always going off about how"],[3958,4191,"he's calling off a marriage."],[4275,4558,"I can't wait to see his face when he"],[4558,4925,"finds out he's engaged to you."],[5013,5134,"Yes, it will be great."],[5330,5430,"Okay, let's uh,"],[5430,5472,"get to that"],[5472,5547,"checkup we were talking about."],[5547,5609,"Yes."],[5680,5793,"Okay, my future"],[5801,5947,"granddaughter-in-law."],[6581,6785,"Thanks for saving my grandma."],[6802,6873,"Wanna grab lunch?"],[6873,6969,"I-I owe you."],[7023,7123,"Mom almost died,"],[7123,7211,"because of this asshole."],[7332,7520,"I can't be too nice to him."],[7578,7795,"Oliver, I only came to visit Mrs. Bates."],[7820,7924,"Don't get any ideas."],[8020,8153,"You know that bite mark"],[8153,8287,"on my chest still hurts."],[8329,8508,"Aren't you ever gonna repay me?"],[8637,8725,"And just how do you"],[8733,8875,"expect me to repay you?"],[8963,9104,"Well, with lunch first,"],[9129,9292,"then we'll go from there?"],[9634,9776,"There's just one problem."],[9897,10001,"I'm engaged."]],"36":[[0,62,"I'm engaged."],[187,283,"You're engaged but"],[291,412,"you're still leading me on."],[471,571,"Since when was I ever"],[588,675,"leading you on?"],[704,779,"Oh, it must have been"],[779,871,"another girl who"],[892,1009,"pushed me down and bit me."],[1030,1188,"I was blacked out drunk."],[1197,1280,"That does not count."],[1330,1422,"Drunk or not,"],[1434,1530,"you still owe me."],[1843,1993,"So when are you calling off"],[1993,2110,"the engagement?"],[2185,2218,"I'm not."],[2335,2515,"Stop playing games with me, Kiddo."],[2552,2581,"What?"],[2581,2677,"It's not like"],[2681,2802,"you're not engaged too."],[2827,2998,"Oh, I see."],[3019,3111,"You're jealous."],[3199,3336,"That girl and I..."],[3449,3541,"Our families paired us"],[3549,3645,"up when we were kids."],[3682,3837,"I don't even know her."],[3874,4041,"Plus, you heard what I told grandma."],[4049,4170,"We're calling off the engagement."],[4525,4646,"So when I call off my engagement,"],[4750,4917,"you'll do the same, right?"],[5050,5171,"Now who's the jealous one?"],[5251,5351,"I-I told you I-I"],[5351,5467,"don't plan to call it off."],[5484,5526,"No."],[5684,5818,"So you really love this guy?"],[6039,6202,"You don't want to know who he is?"],[6310,6352,"Fine."],[6410,6477,"Who is he?"],[6765,6806,"Sir?"],[6890,6973,"The car's ready."],[7111,7290,"To be honest, I'm a little mad right now."],[7328,7386,"Martin will take you"],[7394,7478,"somewhere to get food, and"],[7528,7615,"I'll meet you later."],[7782,7953,"Thanks, but I've got things to do."],[8291,8387,"Take me to Club Deluxe."],[8808,8971,"Sir, want me to figure"],[8979,9096,"out who her fiancé is?"],[9167,9250,"Then we can pressure him"],[9259,9346,"into calling off the wedding."],[9380,9446,"No, Martin."],[9463,9538,"If she's truly"],[9538,9642,"in love with her fiancé,"],[9667,9784,"she's gonna hate me even more"],[9793,9997,"if I try to meddle with her engagement."],[10297,10393,"Oliver,"],[10502,10585,"you're a busy man."],[10702,10769,"Surprised you're in here."],[10931,11048,"There's gotta be a better way,"],[11048,11169,"for her to fall for me."],[11227,11340,"What lady scorns my"],[11348,11490,"devilishly handsome friend?"],[11611,11678,"Mr. Bates, you can have"],[11686,11790,"any woman in the city."],[11874,11941,"Why go after someone"],[11949,12012,"who's already engaged?"]],"37":[[166,337,"Come on, hurry up, let's go."],[529,550,"Oh!"],[575,613,"Oh!"],[633,754,"Is the giraffe okay?"],[796,829,"Oh!"],[859,988,"It's okay, it's unharmed."],[1013,1096,"It's okay."],[1105,1192,"The giraffe is unharmed."],[1272,1372,"Come on, get the door."],[1405,1468,"Ugh!"],[1722,1856,"Brian, is this for me?"],[1910,2027,"I love it."],[2581,2694,"Long time no see, Izzy."],[2756,2886,"This is from Shawn and I."],[2915,3090,"Your stupid brothers."],[3157,3240,"We're sorry."],[3557,3674,"She just got here"],[3674,3774,"and he's already showering"],[3774,3849,"her with gifts."],[3916,3991,"Unbelievable."],[4275,4504,"Brian, why didn't you say hi to me?"],[4729,4859,"Sorry, Eliza,"],[4871,5046,"I just was excited to give Izzy her present."],[5159,5209,"Izzy, why don't we"],[5209,5296,"shopping tomorrow?"],[5321,5434,"I'll buy you whatever you like."],[5463,5584,"I'd love that."],[5630,5826,"Izzy, you wouldn't mind, would you?"],[5847,5976,"If you don't want me to go,"],[5976,6114,"of course I won't impose."],[6177,6335,"Eliza, I think just Izzy and I should go."],[6339,6435,"I want to get to know her after"],[6435,6514,"all these years."],[6564,6635,"Have Charlie take you"],[6635,6710,"shopping later."],[6748,6840,"I'll pay for everything."],[6902,7061,"Oh, okay."],[7132,7211,"No problem."]],"38":[[79,183,"Here you go Brian."],[246,425,"I remember you said you liked chamomile."],[592,646,"Thanks."],[684,863,"And some lemon tea for you."],[980,1163,"Izzy, you did that on purpose!"],[1188,1259,"What?"],[1272,1384,"No, I didn't."],[1393,1509,"You just spilled that on yourself."],[1584,1714,"Is that a bad burn, Eliza?"],[1780,1960,"I'll tell the maid to bring a cold washcloth."],[1968,2131,"Izzy wouldn't burn you on purpose."],[2223,2385,"You know what makes even less sense?"],[2419,2548,"Me spilling it on myself."],[2669,2952,"Izzy, I can accept you not saying sorry,"],[2952,3103,"but I can't accept you accusing me"],[3103,3199,"of hurting myself."],[3207,3324,"Eliza,"],[3378,3553,"I want you to think very carefully."],[3599,3832,"Are you sure it was Izzy?"],[4141,4191,"Forget it."],[4283,4400,"I don't want to cause an argument."],[4575,4683,"We're family after all."],[5497,5613,"I saw it with my own two eyes."],[5718,5834,"Eliza spilled tea on herself"],[5834,5968,"and started a fight with Izzy."],[6076,6181,"I didn't think she would be"],[6189,6318,"so hostile towards her sister."],[6464,6539,"Jack,"],[6610,6752,"why don't we send Eliza to live"],[6760,6865,"at our grandfather's house?"],[7065,7198,"He'll make sure she's taken care of."],[7399,7545,"I think you're right."],[7686,7741,"Let's find a"],[7741,7862,"good time to sit down with Eliza"],[7862,7957,"and break the news."],[8037,8120,"Gently."],[8445,8533,"You think you're kicking me out"],[8533,8608,"Aunt Evie?"],[8712,8888,"I don't care if I have to get rid of you"],[8888,8983,"or your daughter."],[9038,9154,"I'm staying in this family!"]],"39":[[462,513,"What is it?"],[600,704,"I heard you got a crush"],[704,796,"on a 21-year-old."],[834,909,"What do you want?"],[909,984,"I'm busy."],[1013,1263,"I'm talking about my little sister."],[1443,1547,"Now, if she's the one that you're"],[1559,1626,"trying to get with,"],[1685,1856,"I'll beat your goddamn skullin,"],[1856,1960,"you fucking creep."],[2039,2173,"What the hell did you just say to me?"],[2231,2339,"Look man,"],[2352,2552,"I'm back in town for a bit."],[2560,2681,"You wanna get to my sister?"],[2690,2798,"You gotta go through me first."],[2873,2977,"Don't start some shit"],[2977,3103,"you can't handle, Patton."],[3207,3365,"I don't want your sister anyway."],[3620,3745,"The fuck did you just say to me?"],[3858,3941,"Hey, big bro."],[4037,4258,"Why did that sound like Kiddo's voice?"],[4262,4400,"We'll work out the details later."],[4500,4629,"I gotta go shopping with my sister."],[4808,4967,"Who are you talking to?"],[5059,5138,"Just a junk call."],[5201,5301,"Now hurry up and get some food,"],[5309,5392,"so we can head to the mall."]],"40":[[216,304,"Are you still stressing"],[304,371,"over that girl?"],[462,554,"Is she leaving you on read?"],[646,734,"Get out of my office."],[925,1009,"Come on, man."],[1076,1113,"I'm busy."],[1205,1267,"Don't you have a job"],[1267,1334,"you should be at anyway?"],[1580,1639,"Whatever, man."],[1751,1901,"Ever since you fell in love with this chick,"],[2001,2056,"you're kinda lame."],[3199,3278,"Sir,"],[3299,3420,"why exactly are we here?"],[3503,3632,"I'm getting Kiddo a gift"],[3661,3724,"to thank her"],[3724,3837,"for saving my grandma's life."]],"41":[[1034,1176,"Hey, could you do me a favor?"],[1230,1397,"Oh, um, I'm good, thank you."],[1418,1509,"Hey, it's me."],[1564,1651,"You don't recognize me?"],[1751,1964,"No, who are you?"],[1997,2072,"Really?"],[2135,2210,"You don't know who I am?"]],"42":[[29,91,"Really?"],[162,225,"You don't know who I am?"],[383,446,"Wait up."],[563,625,"Ah!"],[771,834,"I'll pay you."],[988,1030,"How much?"],[1071,1151,"Name the price."],[1176,1276,"I'm trying to get home to see my sister"],[1284,1384,"but I'm stuck in this mall."],[1455,1534,"I need you to pretend"],[1543,1622,"to be my girlfriend"],[1622,1701,"and help me sneak out."],[1714,1764,"Okay."],[1851,1989,"How about five grand?"],[2064,2122,"What?"],[2147,2214,"That's straight robbery."],[2310,2348,"Too much?"],[2406,2519,"Okay, do not worry about it."],[2527,2581,"No big deal."],[2606,2715,"Fine, five grand it is."],[3336,3524,"Boss, isn't that Ms. Isabella?"]],"43":[[37,175,"Ah, I wouldn't, Mr. Bates."],[246,400,"She's obviously close with that guy, you'd"],[408,521,"just embarrass yourself."],[546,754,"You want me to sit here and watch her"],[763,880,"walk off with another man?"],[938,1076,"Mr. Bates, let her go."],[1176,1247,"Let's focus on finding"],[1255,1393,"her a good gift for now."],[2022,2102,"Oliver."],[2248,2389,"You're buying a gift too."],[2527,2635,"Must be someone special"],[2635,2690,"if you made the"],[2690,2773,"trip down here yourself."],[2861,3178,"Just getting something for a... a friend."],[3274,3411,"Well, good luck with that."],[3424,3507,"See you around."],[3770,3862,"A friend, huh?"],[4037,4129,"Must be another young"],[4137,4266,"woman he's preying on."]],"44":[[1017,1155,"I just transferred you the money."],[1372,1580,"Hmm, pleasure doing business with you."],[1618,1726,"Call me next time you need me."],[1793,1885,"There won't be a next time."],[1943,2052,"You're breaking my bank over here."],[2118,2218,"Really?"],[2239,2494,"Who knew celebrities could be so stingy."],[2502,2673,"Hey, we work hard for money you know?"],[2786,2998,"Wait, I thought you didn't recognize me."],[3111,3190,"Did I say that?"],[3332,3420,"You knew I was rich."],[3482,3549,"You used me."],[3603,3670,"You're a con artist."],[3824,3920,"Look, it's him."],[3953,4062,"Oh my God, it's Josh!"],[4066,4149,"Josh!"],[4149,4225,"You got lucky this time."],[4287,4383,"I'll make you pay me back later."],[5280,5376,"Guess being famous isn't"],[5384,5480,"all it's chopped up to be."],[5814,5885,"What are you doing?"]],"45":[[33,100,"Done with me already,"],[100,171,"Kiddo?"],[233,425,"I thought you were mad at me."],[467,809,"Well, that may be true, but that doesn't"],[817,975,"mean I can't give you this."],[1743,1876,"Thank you."],[1939,2156,"So, w-where are you off to next?"],[2156,2302,"I can give you a ride."],[2344,2485,"Actually, I'm gonna stay here."],[2494,2577,"I'm waiting for my brother."],[2698,2744,"Brother?"],[2802,3003,"Mr. Bates, your grandma relapsed."],[3065,3186,"She didn't like the meds her nurse gave"],[3199,3274,"her, and she was secretly"],[3274,3349,"spitting them out."],[3374,3424,"What?"],[3474,3586,"Oh, we have to go check on her."],[3607,3661,"Let's go."],[3812,3974,"Dr. Evans, Mrs. Bates' condition is"],[3983,4104,"deteriorating rapidly."],[4112,4283,"If we can't turn things around soon,"],[4291,4383,"her life may be in danger."],[4425,4533,"There's no time to waste."],[4546,4608,"We need to operate,"],[4629,4713,"and prepare for surgery."],[4729,4771,"Stop!"]],"46":[[0,50,"Stop!"],[70,145,"We're prepping the patient."],[154,308,"You can't be in here."],[316,421,"No, she doesn't need surgery."],[429,517,"You guys are gonna kill her!"],[550,671,"You can't just come in"],[679,809,"here and override us."],[829,955,"This is Dr. Evans, the top"],[963,1092,"heart surgeon in this city."],[1121,1280,"The longer you stand here arguing with"],[1288,1372,"us, the lower her"],[1380,1509,"chances are of surviving."],[1518,1564,"That's right."],[1564,1655,"And if she doesn't go under"],[1664,1810,"the knife now, she's finished."],[1847,2014,"So please get out and quit interfering."],[2043,2185,"No, she doesn't need the surgery."],[2193,2273,"It's not going to help her."],[2281,2364,"You little shit!"],[2364,2456,"What do you know?"],[2464,2560,"You're barely old enough to drink."],[2644,2702,"Security!"],[2740,2831,"What's all the commotion?"],[2840,3053,"Mr. Bates, this psychotic woman is"],[3061,3244,"getting in the way of our surgery and"],[3253,3361,"endangering your grandmother."],[3399,3465,"Tell her to get out."],[3490,3620,"No, tell them to get out."],[3628,3712,"I'll handle this."],[3741,3832,"You're out of your mind."],[3891,3953,"I've been a surgeon"],[3962,4124,"longer than you've been alive."],[4320,4379,"You know, you have a lot"],[4387,4491,"of nerve talking like this."],[4558,4675,"You heard what she said."],[4675,4767,"Get out!"],[4896,4975,"Unbelievable."],[5580,5714,"What was Mr. Bates thinking,"],[5722,5843,"putting his grandmother's life"],[5851,6005,"in the hands of a college student?"],[6014,6206,"I know, she's in critical condition."],[6214,6335,"That novice could kill her."],[6343,6393,"Yeah."],[6402,6648,"If she dies, that girl is to blame."]],"47":[[658,825,"Mrs. Bates is in a stable condition now."],[859,967,"Get her these meds and make sure"],[975,1151,"she actually takes them this time."],[1242,1330,"Following my treatment plan,"],[1338,1426,"she should see gradual"],[1434,1568,"improvement over the next few weeks."],[1676,1881,"And once she's good enough for surgery,"],[1889,2018,"I'll be back to oversee the operation."],[2252,2335,"Sure."],[3274,3449,"I guess old men aren't the only ones"],[3457,3561,"that can be medical experts."],[3862,3983,"Miss, when you come"],[3991,4099,"back for the operation,"],[4108,4166,"you wouldn't happen to"],[4175,4266,"need a surgical assistant."],[4316,4529,"I'm also available if you need any help."],[4654,4713,"Thanks, Kiddo."],[4775,4888,"You sure are full of"],[4896,4988,"surprises, aren't you?"],[6652,6785,"You think Izzy's going to like me?"],[7023,7102,"Not sure."],[7273,7399,"What I can tell you is"],[7586,7720,"I'm her favorite brother."],[7791,7949,"She loved the giraffe I got her."],[8037,8141,"That's just because I wasn't here."],[8187,8283,"Give it a few weeks, and"],[8291,8400,"I'll be her new favorite."],[8437,8562,"Are you trying to challenge me?"],[8612,8708,"Bring it on, dork."],[8975,8996,"Izzy."],[9125,9180,"I'm Josh."],[9305,9367,"Didn't you just call"],[9376,9526,"me a con artist earlier?"]],"48":[[116,291,"It's... you?"],[291,387,"Shit, Izzy."],[429,583,"Uh... I'm sorry, I didn't mean that."],[617,725,"Let's not bring that up again, okay?"],[763,859,"Wait."],[859,959,"You two have met?"],[1530,1622,"Izzy, let's take a selfie."],[1710,1814,"Hey, I want to be in it, too."],[1935,2143,"Uh, Eliza, could you take this for us?"],[2460,2519,"Come on."],[3578,3699,"Bro, I wanted one of me and Izzy."],[3753,3849,"Stop photobombing us."],[3858,3958,"She's my sister too."],[4029,4141,"I didn't want to be the third wheel."],[5155,5376,"Yo, Ollie, did you know that Josh"],[5397,5530,"is friends with your girl?"],[5672,5759,"Or maybe more than friends"],[5768,5876,"by the looks of this photo."],[6197,6364,"Do you think Josh is her fiancé?"],[6531,6606,"They look pretty comfortable"],[6606,6660,"together."],[6956,7044,"Oh, shit!"],[7207,7282,"And with you being"],[7290,7424,"engaged to Josh's sister,"],[7490,7565,"oh, my gosh."],[7599,7661,"You've got to admit,"],[7670,7795,"it would look pretty bad"],[7803,7891,"if you went and stole"],[7899,8028,"his fiancé from him, too."],[8291,8391,"So she was meeting up"],[8391,8521,"with her fiancé?"],[8800,8863,"Where are they now?"],[8871,9054,"Josh's last post says Club Deluxe."],[9117,9280,"Looks like they're in a private room."],[9597,9667,"Dude, that's my phone."],[9722,9809,"Martin, grab the car."],[9893,9980,"We're going to Club Deluxe."],[10039,10085,"Yes, sir."]],"49":[[300,525,"Oh, Mr. Bates, Mr. Bates,"],[554,704,"your family and the Pattons"],[713,909,"have been close for generations, okay?"],[917,1130,"Now, if word got out that you"],[1138,1280,"fought with Josh over a girl,"],[1313,1468,"it would be a bad look for you."],[1476,1543,"I really think you"],[1551,1639,"should reconsider this."],[1693,1751,"Step aside."],[2097,2152,"What the hell?"],[2181,2298,"Yeah, what kind of asshole-"],[2318,2439,"Oh, Oliver Bates."],[2531,2694,"Um, how's it going, man?"],[2781,2844,"Long time no see."],[2932,3007,"She's not here."],[3078,3144,"Oh, my bad."],[3182,3274,"I forgot you were a germaphobe."],[3420,3470,"Ah."],[3503,3641,"You would think not to touch"],[3687,3753,"what isn't yours!"],[3807,3870,"Ah."],[4079,4145,"Jesus, I thought he was"],[4154,4287,"about to snap my hand right off."],[4295,4379,"What did you take from him?"],[4416,4471,"No clue."],[4533,4662,"Good thing Izzy wasn't here to see that."],[4717,4800,"Oliver would have really"],[4800,4850,"freaked her out."],[5017,5105,"What are you doing here?"]],"50":[[0,108,"What are you doing here?"],[233,387,"You shouldn't be out so late, Kiddo."],[487,558,"I'm going home soon."],[638,696,"Bullshit."],[696,784,"I know Josh."],[796,942,"He's a bad influence."],[971,1055,"What are you doing?"],[1730,1826,"I'm sorry, Kiddo."],[1860,1993,"Uh, I-I guess I"],[2002,2093,"thought we should be together."],[2239,2352,"No, it's-it’s..."],[2352,2469,"it’s just you bit my lip."],[2535,2585,"Ow."],[2585,2794,"I'm really sorry, I shouldn't have."],[2811,2894,"Izzy."],[3257,3495,"Kiddo, what would your fiancé think of..."],[3557,3616,"if he saw us?"],[3707,3782,"My fiancé?"],[3899,3978,"Izzy!"],[4008,4083,"Izzy!"],[4133,4195,"Weird."],[4208,4312,"Where'd she run off to?"],[4346,4441,"I have to go."],[4608,4750,"In a rush to see your fiancé?"]],"51":[[45,150,"You do not know what"],[158,237,"you're talking about."],[383,487,"Kiddo, I will,"],[513,663,"do anything,"],[675,863,"if you, call off your engagement."],[1263,1534,"Okay, fine, I'll call it off."],[1651,1701,"For real?"],[1797,1868,"Yes."],[1918,2060,"Just don't forget,"],[2085,2181,"you asked for it."],[2235,2293,"Izzy!"],[2477,2560,"I really need to go."],[2948,3003,"You're really anxious"],[3011,3132,"to see him, aren't you?"],[5851,5964,"Just don't get too jealous."]],"52":[[45,312,"I can't believe that I, Donnie Maxwell,"],[316,521,"am an accomplice to a home wrecker."],[617,709,"What happened to my principles?"],[800,963,"She agreed to call off the engagement."],[1134,1222,"No way."],[1263,1363,"Seriously?"],[1447,1643,"Now I have to break off my engagement."],[1885,1989,"I'll go to the Patton House,"],[2014,2060,"the moment"],[2068,2239,"Grandma's discharged from the hospital."],[3791,3853,"Yes?"],[3937,4024,"You sound cold."],[4116,4262,"Don't tell me you regret earlier"],[4291,4366,"your decision to"],[4375,4479,"break off the engagement."],[4521,4633,"No, I'm just a little mad"],[4637,4750,"about what you did at the club."],[4796,4946,"Because I kissed you suddenly?"],[5004,5092,"I'm sorry."],[5201,5280,"You can kiss me next time"],[5284,5430,"as payback, okay?"],[5492,5630,"I'm not talking about that."],[5672,5860,"I'm mad because you broke Josh's hand."],[6022,6056,"Ah."],[6131,6214,"I would think not to"],[6218,6385,"touch what isn't yours."],[6448,6581,"So don't try to see me until you're ready"],[6585,6685,"to apologize to him."],[6727,6815,"I'm not doing that."],[6873,6923,"Then you can forget"],[6931,7023,"our previous agreement."]],"53":[[129,200,"Fine."],[262,371,"I'll apologize."],[425,467,"But you better"],[467,646,"break things off with your fiancé."],[700,788,"I will."],[1426,1514,"Just don't regret it when you"],[1518,1676,"find out who I'm engaged to."],[2273,2406,"Wait, that's Oliver's car."],[2452,2544,"Shit, he's gonna see us."],[2544,2577,"Run!"],[2577,2644,"Stop!"],[3232,3265,"Hey!"],[3353,3445,"Sorry about yesterday."],[3520,3591,"That's the first time"],[3595,3699,"I've heard him apologize."],[3737,3845,"He really will do anything"],[3845,3908,"for that girl."],[4062,4183,"Is this a trap?"],[4308,4475,"Oh, you don't have to apologize."],[4529,4667,"My hand's all better now."],[5839,6001,"Who did this to you?"],[6089,6172,"It was..."],[6318,6364,"Tell me!"],[6493,6581,"Oliver Bates."],[6598,6685,"We don't know why."],[6856,7052,"I'm gonna make that asshole apologize."]],"54":[[792,859,"I said I was sorry."],[934,1113,"I even said it to Josh, like you asked."],[1226,1359,"Stop ignoring me."],[1522,1559,"Fine."],[2573,2715,"All right, let's go Martin."],[3274,3420,"Dude, did he just drive off with a girl?"],[3532,3586,"Damn."],[3695,3799,"I wonder what kind of girl"],[3803,3916,"Oliver would be into."],[3966,4024,"She must be..."],[4095,4133,"cuckoo."],[4208,4316,"Yeah, she'd have to be like insane."],[4412,4592,"Wait, why do I feel like that girl"],[4600,4700,"looked a little bit like Izzy?"],[4750,4833,"Are you serious?"],[4921,5046,"There's no way that was Izzy."],[5055,5134,"She just moved back to the city."],[5134,5196,"She probably doesn't"],[5196,5301,"even know who Oliver is."],[5338,5417,"Yeah, you're right."],[5451,5543,"They've never even met."],[5613,5705,"And if Oliver ever as"],[5714,5805,"got so much near her,"],[5872,6010,"I'd beat his fucking ass."],[6126,6235,"Yeah, with your left hand?"],[6285,6335,"Okay."]],"55":[[446,625,"So this is what it's come to, Izzy."],[709,829,"Auntie may have raised me,"],[834,1034,"but if she's gonna let you take my place,"],[1155,1242,"I'll have to kill her."],[1668,1810,"Which drug has the most lethal"],[1818,1997,"interaction with this serum?"],[2410,2489,"Ma'am, what are you"],[2494,2656,"planning on using this drug for?"],[2765,2902,"If anyone finds out I'm assisting"],[2911,2986,"criminal activities,"],[2994,3128,"I could lose my license."],[4066,4216,"Well, now that I think about it,"],[4220,4337,"I did just receive a"],[4346,4562,"shipment of a new stimulant called"],[4754,4829,"MitaFlex."],[4996,5109,"Mix it with that serum,"],[5150,5217,"It could put somebody"],[5221,5301,"to a coma,"],[5409,5518,"permanently."]],"56":[[392,458,"Don't get out, I don't"],[467,608,"want my parents to see us."],[679,855,"Am I that grotesque to your parents?"],[984,1272,"No, I just, I haven't told them yet."],[1351,1509,"And they're gonna need"],[1518,1597,"some time to process."],[1655,1810,"If Mom and Dad saw this guy with me,"],[1818,1918,"they'd probably chase him"],[1926,2052,"off with a baseball bat."],[2156,2206,"Or a gun."],[2331,2389,"Both, honestly."],[2494,2556,"I get it."],[2627,2806,"I'll see you tomorrow then."],[3002,3069,"See you tomorrow."],[3787,4008,"Mr. Bates, this is the"],[4016,4083,"West Hills neighborhood."],[4229,4308,"Doesn't the Patton heiress"],[4312,4391,"live around here too?"],[4508,4688,"Who cares about the stupid Patton heiress?"],[5638,5730,"You two look ridiculous"],[5739,5868,"always fighting for her attention."],[6043,6197,"Darling, you must be exhausted"],[6206,6331,"from dealing with these two."],[6381,6539,"There's a bowl of popcorn on the table."],[6544,6623,"Sit down and have some."],[6652,6744,"Mom, you never made me"],[6748,6869,"popcorn when I got home."],[6890,7040,"Stop acting like a child."],[7207,7294,"Oh, I picked up another"],[7303,7394,"batch of the Z-Boost pills"],[7403,7507,"that I gave you earlier."],[7561,7807,"Oh, Izzy, what would I do without you?"],[7849,8058,"I'm feeling so much better these days."],[8078,8145,"I can even play"],[8153,8258,"tennis with the neighbors."],[8283,8375,"Yes, just make sure to"],[8383,8462,"keep taking your doses."],[8500,8696,"And then maybe you'll win some matches."],[9822,9964,"And to think, I wouldn't"],[9968,10060,"have had to do this to you"],[10064,10226,"Aunt Evie, if you hadn't have picked"],[10231,10460,"that stupid country pest over me."],[10598,10731,"Can't ignore me when you're dead, bitch."],[11332,11469,"Should've never let that bitch Isabella"],[11478,11565,"back into our lives."]],"57":[[316,504,"Mrs. Patton, are you okay?"],[996,1117,"Izzy, quick!"],[1117,1176,"Come help Mom."],[1180,1276,"Get away from her!"],[1322,1447,"She took the pills you gave her,"],[1451,1518,"now she's unconscious"],[1526,1639,"and throwing up blood!"],[1672,1805,"What did you do to Auntie?"],[1835,1914,"Move aside,"],[1914,1993,"nothing I gave her"],[1993,2093,"would ever hurt her."],[2102,2206,"You think we're stupid?"],[2231,2335,"You did this to her,"],[2344,2481,"we are not trusting you anymore."],[2506,2594,"What happened to her?"],[2598,2660,"Evie!"],[2756,2907,"Sh-She took the pills Izzy gave her"],[2911,3048,"and passed out right after"],[3061,3194,"the maid saw everything."],[3228,3361,"It's true, Mr. Patton."],[3378,3461,"Are you, are you,"],[3482,3657,"saying this is my fault?"],[3674,3807,"I never said that, but"],[3816,3953,"she passed out right after"],[3962,4158,"taking the pills Isabella gave her,"],[4162,4329,"that can't just be a coincidence."],[4350,4412,"Enough!"],[4542,4671,"Izzy's pills were helping Evie."],[4692,4763,"There's gotta be another"],[4763,4867,"reason behind this."],[4892,5025,"There's no time to argue."],[5055,5167,"You go get Dr. Lang."],[5205,5367,"Izzy, if there's anything"],[5367,5459,"you can do, please."],[5513,5622,"I've never seen a"],[5630,5751,"reaction like this before."],[5822,5951,"What are you doing?"],[5976,6147,"The last thing she needs is your help."],[6210,6331,"Out of my way."],[7248,7332,"Look what you did Izzy,"],[7332,7374,"you're making it"],[7382,7520,"worse than it already is."]],"58":[[79,266,"Izzy, what's happening?"],[283,404,"Looks like she took a stimulant that"],[412,563,"interacted with the Z-boost pills."],[579,688,"What could it have been?"],[709,834,"Dr. Lang is here!"],[1001,1134,"Dr. Lang, you have to"],[1142,1272,"save my Mom from her."],[1317,1393,"What the hell do you think"],[1397,1472,"he's here for?"],[1472,1551,"Move aside!"],[1601,1868,"Who, who gave her this injection?"],[1893,2014,"It was my sister, Izzy."],[2056,2227,"I told her not to, but she didn't listen."],[2289,2402,"Now Mom looks worse."],[2481,2644,"Who says her condition is worse?"],[2681,2831,"If she hadn't received this injection,"],[2836,3011,"she would not be alive right now."],[3215,3311,"Dr. Lang, is she okay?"],[3390,3516,"When will my wife wake up?"],[3645,3941,"I'm afraid that Mrs. Patton has ingested"],[3949,4208,"a lethal combination of drugs."],[4279,4416,"The injection that Isabella"],[4416,4533,"administered is the"],[4533,4675,"best available combatant"],[4675,4733,"that we have."],[4771,4921,"So now all we can do is..."],[4996,5080,"wait and pray."],[5430,5505,"I'm not done yet."],[6035,6235,"Now is not a time for games, young lady."],[6289,6389,"Mrs. Patton is in a"],[6398,6531,"very sensitive condition."],[6548,6619,"No, doctor."],[6844,6898,"Let her try."],[6973,7036,"We trust Izzy."],[7161,7290,"Suit yourself Izzy."],[7311,7428,"When you kill her you'll be disowned"],[7432,7524,"by the Patton family."],[7582,7728,"This is EXP-6."],[7874,8033,"It's even stronger than EXP-5,"],[8037,8204,"and I haven't tested it on humans yet,"],[8208,8333,"but it's the only chance."],[9492,9726,"Honey, you're okay."],[9889,9968,"You're awake."],[10014,10097,"-Oh my God! -You're okay,"],[10097,10222,"you're awake!"]],"59":[[79,129,"Now that she's awake,"],[129,179,"let's figure out"],[187,250,"why she passed out"],[250,325,"in the first place."],[392,517,"What are you looking at me for?"],[525,592,"She passed out because"],[600,709,"of the pills you gave her."],[738,817,"The maid and I saw it"],[825,942,"with our own two eyes."],[950,996,"That's right."],[1005,1192,"Like I said, she took her pills and then"],[1201,1326,"literally fell right to the ground."],[1347,1455,"I trust you, Izzy."],[1514,1672,"Your medicine would never hurt me."],[1722,1793,"No."],[1872,1922,"Mom, mom,"],[1922,2039,"is there anything you could have"],[2039,2210,"taken that would cause this reaction?"],[2377,2448,"Let me think."],[2477,2698,"Uh, oh yeah."],[2756,2898,"I did drink a cup of tea"],[2902,3078,"before I took the Z-Boost pills."],[3094,3165,"That's right."],[3199,3415,"First she drank that cup of tea, then she"],[3424,3599,"had those pills, and then she passed out."],[3657,3770,"Get me that cup of tea."],[3962,4049,"Izzy, don't try to shift"],[4054,4208,"the blame onto someone else."],[4266,4350,"Mom loves you."],[4387,4517,"I'm sure if you apologize to her,"],[4517,4662,"she'll be willing to forgive you."],[4700,4788,"Here you go, ma'am."]],"60":[[216,429,"There's MitaFlex added to this tea."],[479,592,"Uh, if you combine that with"],[600,750,"Z-Boost pills, it could be fatal."],[1005,1230,"She's right, this is a very large dose"],[1230,1305,"of Mitaflex."],[1376,1476,"Large enough to kill."],[1576,1685,"Who?"],[1768,1868,"Who is responsible?"],[1901,2006,"Who gave her the tea?"],[2018,2131,"It was Miss Eliza."],[2206,2256,"I was going to give"],[2256,2339,"her the tea myself,"],[2339,2427,"but, she wanted to"],[2427,2531,"show Mrs. Patton how good of a"],[2531,2627,"daughter she was,"],[2627,2761,"so, I let her do it."],[2927,2998,"Eliza."],[3086,3153,"I'd..."],[3253,3374,"It wasn't me!"],[3395,3541,"You have to believe me."],[3616,3737,"You cared for me and raised me like I"],[3737,3824,"was your daughter."],[3824,3933,"You've, always been"],[3937,4079,"like a real mother to me."],[4120,4320,"How could I ever try to harm you?"],[4371,4450,"Oh yeah?"],[4500,4629,"You would never harm her?"],[4637,4738,"Of course not!"],[4896,4967,"You guys are the only"],[4967,5063,"family I have."],[5084,5130,"I would never"],[5130,5284,"do anything to hurt any of you."],[5422,5597,"Hey, give me that!"]],"61":[[12,196,"This is MitaFlex!"],[196,321,"What's your excuse now?"],[467,533,"She's right."],[629,784,"That woman treated her like her own"],[784,909,"daughter for years and,"],[917,1051,"this is how she repays her?"],[1096,1192,"With attempted murder?"],[1201,1255,"Shut up!"],[1280,1347,"Shut up!"],[1459,1547,"Eliza!"],[1593,1735,"How could you do this?"],[1785,1947,"You've been like a daughter to us all"],[1951,2135,"these years and that never changed."],[2156,2318,"I didn't think you were capable of this."],[2348,2464,"Bullshit!"],[2481,2635,"All this talk about treating me"],[2635,2794,"like your daughter, but it's all bullshit!"],[2848,2957,"Ever since Izzy came back,"],[2957,3078,"you've all been constantly"],[3078,3190,"competing for her love."],[3232,3370,"You forgot all about me!"],[3399,3691,"Eliza, Izzy had a tough childhood,"],[3745,3903,"and you were here, and you had"],[3903,4154,"everything you could ever ask for."],[4275,4425,"We were just trying to compensate for all"],[4433,4646,"the love we couldn't give to her before."],[4717,4808,"But that didn't change"],[4817,4929,"how we feel about you."],[4959,5030,"Shut up!"],[5188,5255,"Don't you know what"],[5263,5392,"happened 15 years ago?"],[5434,5714,"If I hadn't have made that bitch disappear,"],[5722,5793,"you never would have"],[5801,5951,"accepted me into this home."],[5993,6085,"And now that you got Izzy back,"],[6101,6243,"I mean nothing to you."],[6297,6439,"Now I have to get rid of her again, or else"],[6439,6644,"I’ll be completely abandoned!"],[6735,6906,"Are you saying you're the reason Izzy"],[6915,7044,"disappeared 15 years ago?"],[7407,7661,"And stay gone, you stupid rat."],[8583,8696,"I'm only sorry I didn't"],[8696,8833,"kill you instead."]],"62":[[41,145,"You're a monster."],[145,250,"All those years,"],[266,504,"raising you, loving you, what a waste."],[629,734,"Izzy call security."],[775,846,"Eliza's gonna pay"],[850,971,"for this for the rest of her life."],[1076,1209,"You can't do this."],[1292,1413,"I'm a Patton."],[1497,1568,"I have no other family"],[1568,1676,"to take care of me."],[1697,1751,"Well, you should have"],[1751,1801,"thought of that"],[1801,1910,"before you betrayed us."],[2035,2143,"You're not a Patton."],[2231,2456,"You never were."],[2494,2769,"I am a Patton, I'll be back."],[2777,2965,"I'm the only Patton there is, Izzy."],[3265,3315,"Deep down,"],[3315,3436,"she never got over the death"],[3436,3549,"of her birth parents."],[3741,3878,"Don't feel bad for her."],[4045,4141,"After all this time,"],[4283,4429,"you never got to know yours."],[4562,4717,"And you turned out wonderful."]],"63":[[225,325,"Mr. Bates, is your grandmother"],[325,450,"leaving the hospital today?"],[504,633,"Yeah, she's pretty much recovered now."],[667,788,"We're going straight to the Patton's house"],[800,900,"to call off the engagement."],[905,955,"Got it."],[1005,1209,"Don't believe those silly rumors."],[1251,1434,"I never agreed for Oliver to"],[1434,1551,"call off the wedding"],[1584,1751,"with the Patton heiress."],[1835,2022,"I just said it to fool him."],[2122,2256,"Never in a million years"],[2256,2427,"would I actually tell him"],[2435,2531,"to call it off."],[2677,2798,"Yes, that's right."],[2932,3044,"I was just playing a"],[3044,3278,"little trick on Oliver."],[3378,3636,"Of course he's still gonna marry her."],[3691,3908,"I'll see you at the wedding."],[4058,4166,"Oliver's pissed."],[4237,4366,"What is his grandmother thinking?"],[4366,4466,"She knows he only has feelings"],[4466,4529,"for that other girl."]],"64":[[41,158,"So Grandma's been playing me"],[158,266,"this whole time?"],[312,496,"I'm just a pawn in her games!"],[675,779,"Martin, we're going to the"],[779,871,"Patton's house immediately."],[925,1013,"Screw this shit!"],[2293,2435,"We need to convince the Bates family"],[2439,2544,"to call off the marriage."],[2560,2765,"I do not want Izzy marrying Oliver."],[2844,2998,"The guy is not husband material."],[3011,3086,"I agree."],[3111,3257,"Just look how he humiliated her"],[3257,3370,"at the banquet."],[3457,3545,"We should sever ties"],[3545,3649,"with the Bates family."],[3682,3803,"That man doesn't"],[3803,3916,"deserve my daughter."],[3953,4062,"Sir, ma'am,"],[4133,4195,"Mr. Bates is here."],[4233,4358,"What on earth is he doing here?"],[4358,4475,"Do not let him in."]],"65":[[905,959,"You."],[1046,1117,"First you,"],[1117,1234,"humiliate our daughter"],[1234,1292,"at the banquet,"],[1292,1355,"now you,"],[1355,1455,"disrespect us by coming"],[1455,1543,"back to our house?"],[1609,1697,"Mr. and Ms. Patton,"],[1743,1972,"let's not force what's not meant to be."],[2014,2093,"I'm sorry."],[2131,2302,"I don't have feelings for your daughter."],[2339,2431,"I, I don't know"],[2431,2527,"what my grandma told you,"],[2531,2665,"I’m-I'm not interested."],[2857,2977,"Hey guys, what's going on?"],[3232,3294,"Kiddo?"]],"66":[[154,221,"Kiddo?"],[296,396,"Why did he call you that?"],[763,838,"The Patton heiress?"],[980,1067,"Could it be?"],[1155,1301,"Oliver, you just said"],[1301,1380,"it wasn't meant to be."],[1434,1518,"You came here"],[1518,1693,"to call off the arrangement, right?"],[1772,1835,"Uh,"],[1889,2106,"actually, no..."],[2160,2256,"That's not why I'm here."],[2318,2360,"Uh."],[2410,2469,"I just wanted to say"],[2469,2585,"hi to my new in-laws."],[2698,2756,"Your new in-laws?"],[2965,3069,"What the hell are you talking about?"],[3078,3240,"You heard right, brother-in-law."],[3958,4154,"Dad, why don't you and Mom"],[4158,4262,"go back to your room?"],[4350,4496,"Mom, you should take it easy"],[4496,4608,"after your health scare."],[4692,4763,"I'll handle this."],[5109,5234,"Take care, yeah!"],[5234,5367,"Take care, Mr. and Mrs. Patton."],[5492,5613,"Or should I say Mom and Dad?"],[5643,5689,"No."],[5759,5860,"You shouldn't say that."],[5976,6035,"Talk."],[6035,6097,"Why are you here?"],[6310,6410,"I'm not calling it off."],[6652,6802,"You're with another girl."],[6802,6865,"We saw you."]],"67":[[133,225,"That girl"],[225,412,"is the reason I'm not calling it off."],[684,759,"What do you mean?"],[992,1059,"He means..."],[1388,1505,"That girl is me."],[1643,1743,"Bingo."],[1906,2001,"I'm gonna kill you."],[2114,2198,"No, not his face!"]]}