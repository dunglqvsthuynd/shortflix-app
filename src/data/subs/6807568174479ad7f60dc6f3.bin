the food bank started,"],[462,625,"your boss was in charge."],[625,717,"You don't know me."],[746,834,"I get it."],[850,967,"But I'm sure you know Bennett."],[996,1059,"Bennett?"],[1101,1234,"Maple Group's VP?"],[1284,1359,"What about him?"],[1380,1476,"He's way out of your league."],[1476,1651,"There's no way someone like you"],[1651,1801,"could have a connection to him."],[1830,2022,"No, she doesn't have a connection."],[2039,2268,"She's just his little girlfriend."],[2277,2364,"Sure."],[2385,2540,"Let him tell you exactly"],[2540,2673,"who I am then."],[2994,3053,"Bennett-"],[3090,3253,"Oh, come on, Audrey."],[3269,3403,"You're just a fling to him!"],[3420,3532,"He wouldn't back you up,"],[3532,3728,"let alone remember you in a month."],[3795,3978,"She's definitely full of it."],[3999,4120,"No way Bennett has time for"],[4120,4245,"someone like her."],[4275,4483,"Who the hell do you think you are?"],[4483,4683,"Making a scene here in Maple Group?"],[4733,4838,"Get her out of here!"],[4975,5167,"Maple Group doesn't need people like this."],[5501,5568,"No,"],[5601,5693,"not enough."],[5776,5893,"This video is going to"],[5893,6006,"the whole company,"],[6047,6227,"and the CEO."],[6306,6506,"Let them see what a thief looks like."],[6773,6856,"Here we go."],[6919,7048,"Just one click away."],[7090,7194,"What the hell?"],[7399,7553,"What gives you the right to humiliate her"],[7553,7603,"like this?"],[7603,7720,"She stole my bracelet!"],[7720,7828,"It wasn't us."],[7828,7949,"She fell on her own."],[8003,8124,"She, she tripped."],[8137,8324,"Nobody did anything to her."]],"48":[[25,154,"I'm so sorry."],[183,417,"I just need the money so badly."],[475,583,"Cornell,"],[583,771,"she stole the gift that you gave me."],[771,838,"She..."],[896,1013,"You have to throw her out of"],[1013,1113,"Maple Hotel."],[1263,1301,"No."],[1393,1476,"No, you've got this wrong."],[1476,1680,"Audrey would not do something like this."],[1680,1735,"No, just..."],[1793,1889,"watch this video."],[1914,2068,"The bracelet was a custom gift"],[2068,2164,"from you."],[2214,2314,"She's just"],[2348,2510,"jealous of me."],[2548,2694,"She wants to take from me what"],[2694,2823,"matters the most."],[2940,3011,"Listen,"],[3044,3228,"if this is about the bracelet I got for her,"],[3228,3307,"I will get you something"],[3307,3432,"so much better."],[3474,3670,"All you have to do is apologize,"],[3687,3782,"and we'll sort this out."],[3782,3870,"Cornell!"],[3870,4108,"You can't just cover for her like this!"],[4108,4254,"That bracelet,"],[4279,4542,"why would I want something so tacky?"],[4704,4775,"Enough."],[4775,4900,"I will not stand here and watch you"],[4900,4984,"bully her like this."],[4984,5138,"She stole from me!"],[5138,5317,"Why don't you believe me?"],[5509,5601,"You're not leaving."]],"49":[[83,191,"You're not leaving."],[212,358,"Not until we fix this."],[412,508,"I..."],[508,571,"She..."],[571,750,"Think very carefully"],[750,925,"before you say another word."],[1071,1167,"Listen,"],[1167,1413,"I'm about to be the Maple Hotel CEO."],[1459,1664,"If you're in trouble ever, I can help you."],[1714,1914,"I just need you to be honest with me."],[2118,2202,"She did it."],[2302,2485,"She told me to put the bracelet in"],[2485,2598,"Audrey's pocket."],[2865,3057,"Promised me a raise if I did it."],[3278,3349,"You liar!"],[3349,3461,"Do you even hear yourself"],[3461,3591,"talking right now?"],[3845,3912,"Let her talk."],[3941,4175,"You paid me to set her up."],[4316,4437,"Give me back my card."],[4437,4575,"You don't deserve this."],[4596,4788,"You paid me to lie!"],[4863,5121,"I only did it so that I could pay for my"],[5121,5259,"child's treatment."],[5326,5663,"I would never hurt someone like Audrey."]],"50":[[25,150,"Cecilia,"],[254,333,"I thought you were so much"],[333,446,"better than this."],[471,663,"Here's your truth, Cecilia."],[663,813,"So what's your excuse this time?"],[884,1013,"What do you mean?"],[1080,1209,"This was all you."],[1242,1401,"You framed me."],[1455,1618,"Cornell, you have to believe me."],[1618,1797,"I'm the victim here."],[1868,1989,"I tried to"],[1989,2052,"help her,"],[2052,2135,"and she's just throwing it"],[2135,2277,"back in my face."],[2306,2327,"What?"],[2327,2448,"Is she hooking up with the VP"],[2448,2519,"or something?"],[2560,2623,"Mr. Clement,"],[2623,2748,"she's crossed the line with"],[2748,2811,"the higher-ups."],[2811,2986,"I really think we should fire her."],[3061,3140,"Hear that?"],[3190,3282,"You're fired."],[3328,3420,"You're firing me?"],[3420,3507,"Yes."],[3549,3695,"So pack your stuff,"],[3695,3795,"and get out of here."],[3883,4091,"We don't have all the details yet."],[4091,4237,"Let's not rush through this."],[4237,4391,"The CEO of Maple Group"],[4391,4637,"started this food bank to help people."],[4637,4725,"Don't you think treating"],[4725,4846,"those in need like that kind of"],[4846,4950,"defeats the whole purpose?"],[4950,5117,"Excuse me, who do you think you are?"],[5117,5213,"She didn't mean it like that."],[5213,5347,"Mr. Clement, please,"],[5384,5522,"do not defend her."],[5543,5709,"I am in charge of the food bank now,"],[5709,5822,"and I've made my decision."],[5910,6006,"She's out."],[6035,6160,"Well, too bad."],[6172,6339,"I think you're the one who should leave."],[6535,6610,"Bennett,"],[6610,6802,"come by the food bank in three."],[6835,7002,"And fire Jonas Boyd."],[7061,7236,"Put him on the blacklist."],[7236,7349,"He's not allowed to work for"],[7349,7461,"Maple Group anymore."],[7461,7628,"Why is she talking to Bennett like that?"],[7678,7782,"That doesn't sound like a girlfriend,"],[7782,7870,"that sounds more like"],[7870,7978,"a boss."]],"51":[[12,95,"She's just"],[129,191,"bluffing it."],[191,337,"She's always pretending to be"],[337,487,"someone that she's not."],[546,809,"And isn't Bennett's boss the CEO?"],[859,984,"You've probably seen her just"],[1001,1213,"around the office or something."],[1213,1292,"All right,"],[1292,1426,"let me handle this."],[1426,1543,"She's out today."],[1647,1735,"Audrey,"],[1776,1943,"Bennett's just the VP."],[1960,2077,"If this gets out,"],[2077,2281,"and becomes a public scandal,"],[2281,2469,"the CEO will have to step in."],[2552,2660,"Let me help you with this."],[2660,2777,"I don't need your help."],[2852,3061,"This is all a big misunderstanding."],[3061,3157,"I know it's not fair,"],[3157,3215,"but..."],[3253,3361,"Let's go home,"],[3390,3511,"talk about this."],[3545,3753,"Our VP keeps his business life"],[3753,3941,"separate from his personal life."],[3941,4049,"And there's no way he'd ever"],[4049,4170,"risk his job for you,"],[4170,4333,"even if you were his girlfriend."],[4404,4525,"So how about this?"],[4617,4808,"If Bennett fires me for you,"],[4808,4967,"I'll apologize."],[4984,5100,"If not,"],[5121,5242,"you're the one to leave,"],[5296,5447,"and you can beg on your knees"],[5447,5522,"while you're at it."],[5522,5605,"Sure."],[5618,5726,"Let's wait for Bennett."],[5751,5834,"He'll clear this up."],[5834,5905,"Okay,"],[5930,6056,"let's not make this a bigger deal"],[6056,6160,"than it already is."],[6160,6373,"Stop defending her!"],[6393,6598,"I'm not backing down until she's fired!"],[6598,6719,"Jonas Boyd,"],[6785,6886,"do you even know who you're"],[6886,6977,"talking to?"]],"52":[[8,108,"Jonas Boyd,"],[183,300,"do you even know who you're"],[300,383,"talking to?"],[462,500,"Bennett?"],[500,596,"The VP?"],[629,829,"I didn't realize the Charity Division"],[829,1105,"had the authority to challenge the CEO."],[1380,1488,"Here's your notice."],[1501,1601,"You're fired."],[1639,1805,"You're really the CEO?"],[1843,2077,"Didn't you say you'd kneel and apologize"],[2077,2181,"if Bennett fired you?"],[2256,2335,"Well?"],[2427,2502,"We're waiting."],[2610,2731,"I'm sorry, I,"],[2798,2911,"I didn't mean to throw my weight"],[2911,2990,"around like that. -No."],[3053,3153,"Not to me."],[3199,3411,"Apologize properly to Ms. Warburton."],[3632,3728,"Ms. Warburton,"],[3782,3912,"I am really sorry,"],[3912,4004,"I didn't know that- -Yeah, it's"],[4004,4166,"too late, pack your stuff and get out."],[4258,4295,"Go!"],[4295,4354,"Now!"],[4354,4500,"Please forgive me!"],[4500,4571,"Bennett,"],[4608,4767,"how dare you mess around with a"],[4767,4904,"married woman."],[4942,5067,"Aren't you afraid that the CEO is"],[5067,5217,"gonna fire you for this?"]],"53":[[25,204,"Cornell and I are splitting up."],[246,421,"I can date whoever I want now."],[446,529,"Audrey,"],[529,567,"are you-"],[567,679,"Let's prep for the meeting with"],[679,746,"Mr. Adam."],[746,971,"I don't have time for this nonsense."],[996,1109,"You stay away from her!"],[1134,1280,"You don't tell me what to do."],[1313,1434,"I only listen to Audrey."],[1989,2077,"Audrey,"],[2223,2410,"are you really leaving me for this guy?"],[2494,2640,"I meant what I said to you at the bar"],[2640,2711,"that night."],[2731,2786,"Oh,"],[2823,3053,"has Mr. Clement finally fallen for me?"],[3053,3194,"Can we talk about this?"],[3282,3336,"When are you coming home-"],[3336,3415,"Never."],[4187,4250,"Why?"],[4312,4416,"Why would you frame her for"],[4416,4525,"stealing the bracelet?"],[4525,4583,"I didn't."],[4583,4650,"I..."],[4675,4704,"You..."],[4704,4859,"She set up the whole thing."],[4859,4938,"I don't even know who you are"],[4938,5005,"anymore."],[5092,5176,"I really don't."],[5246,5271,"Wait!"],[5271,5359,"Cornell, don't..."],[5413,5513,"don't leave me."],[5634,5776,"Why did we break up?"],[5776,5955,"Is it really because of your family?"],[5955,6010,"I..."],[6072,6126,"I..."],[6126,6181,"Yeah."],[6277,6410,"Your face tells me everything."],[6677,6802,"Audrey, just wait."],[6802,6948,"I'll expose your little game."],[6948,7069,"You'll pay for this."],[7378,7419,"Huh,"],[7436,7499,"Boss."],[7528,7670,"The Wilson family has invited you"],[7670,7799,"to their networking event."],[7811,7882,"Shall I decline?"],[7882,7966,"Why would I?"],[7999,8070,"I'll go."],[8124,8266,"I want to see what else Cecilia's"],[8266,8350,"cooking up."],[8391,8470,"Yes, Boss."]],"54":[[784,867,"Audrey,"],[917,1151,"I will destroy you so completely"],[1151,1330,"you will never recover."],[1943,2027,"Thank you."],[2210,2314,"This is what you get when you"],[2314,2419,"mess with me."],[2719,2827,"Everybody look!"],[2844,3019,"See how nasty Audrey Warburton is"],[3019,3098,"during her marriage."],[3395,3516,"Isn't that the same Warburton who"],[3516,3695,"caused such a stir at the charity ball?"],[3716,3791,"I didn't expect her to be that"],[3791,3883,"kind of woman."],[4116,4316,"This is a Wilson family event."],[4366,4658,"Pulling a stunt like this is beyond stupid."],[4708,4879,"She just wants to ruin me."],[5138,5226,"Oh,"],[5226,5434,"Audrey, it's all over the internet now."],[5447,5643,"Everyone's accusing you of cheating."],[5672,5764,"Please,"],[5764,5872,"it's time to go public."],[5872,6006,"Reveal your identity,"],[6006,6206,"and let the truth ring out."]],"55":[[25,112,"Not yet."],[221,362,"If Cecilia and Miranda know"],[362,446,"who I really am,"],[446,592,"they will stop at nothing to fight"],[592,796,"for my assets during the divorce."],[871,938,"Okay,"],[938,1034,"so what's the plan?"],[1226,1334,"Go to that bar,"],[1355,1568,"and pull all the surveillance footage."],[1580,1714,"And I'll take care of everything here."],[1714,1797,"Yes, Boss."],[2394,2452,"Audrey!"],[2502,2598,"You have been messing with"],[2598,2665,"my son,"],[2665,2827,"and now you're flaunting your affairs"],[2827,2982,"with other men in front of him."],[3011,3182,"You have brought nothing but shame"],[3182,3299,"to the Clement family name."],[3299,3428,"And I swear to God I'm gonna-"],[3499,3611,"Cornell!"],[3611,3728,"You've seen everything that"],[3728,3828,"she's done."],[3828,4008,"Why are you still defending her?"]],"56":[[16,196,"Mrs. Clement, watch your words."],[216,417,"We are negotiating a divorce now."],[417,554,"So if you keep this up,"],[567,692,"I won't hesitate"],[692,763,"to burn"],[788,875,"every bridge."],[875,1017,"Think you can threaten me?"],[1051,1263,"You're nothing but a penniless nothing."],[1322,1451,"Everybody, listen up!"],[1609,1697,"This woman,"],[1697,1939,"this pathetic food bank worker,"],[1997,2210,"she not only cheated on my son,"],[2252,2427,"but she climbed her way to the top"],[2427,2577,"by selling herself!"],[2681,2806,"How embarrassing."],[2815,2869,"If I were her,"],[2869,2952,"I'd leave immediately."],[3011,3123,"I will handle this."],[3140,3203,"Oh,"],[3203,3357,"and make it worse for me?"],[3378,3520,"That night at the bar,"],[3557,3828,"there was only the dancers and Bennett,"],[3828,4004,"and they wouldn't do this."],[4004,4129,"That leaves you."],[4179,4308,"You think I did this?"],[4308,4437,"Ruining my reputation to"],[4437,4558,"please Cecilia..."],[4679,4738,"kind of seems like"],[4738,4846,"something you would do."]],"57":[[150,304,"I would never stoop this low."],[304,404,"What are you doing?"],[404,500,"Let go!"],[517,558,"Cornell,"],[638,809,"we don't want to make this worse."],[905,1071,"I know you want to protect Audrey,"],[1071,1146,"but..."],[1146,1276,"saying anything else is just"],[1276,1451,"gonna make her look more guilty."],[1514,1622,"What if we just..."],[1659,1722,"leave?"],[1722,1876,"Is this just some elaborate act"],[1876,1956,"between the two of you?"],[1956,2106,"All right, all right, enough."],[2160,2277,"Ladies and gentlemen,"],[2277,2398,"can I have your attention please?"],[2485,2565,"I'd like to address the"],[2565,2681,"video you've just seen."],[2802,2869,"My wife,"],[2869,2973,"Audrey,"],[2973,3073,"was trying to make me jealous"],[3073,3157,"that night."],[3211,3307,"And yes,"],[3399,3541,"I was aware of the male models."],[3695,3782,"In fact,"],[3782,3874,"I let it happen."]],"58":[[83,158,"It's done."],[212,321,"The whole video is online,"],[321,429,"and the truth is out."],[429,538,"I also released a divorce"],[538,633,"statement for you."],[646,750,"So you and he are officially"],[750,846,"nothing to each other."],[846,1046,"No one can accuse you of cheating now."],[1076,1146,"Wait..."],[1188,1401,"Ms. Warburton is Mr. Clement's wife?"],[1497,1584,"I thought the Wilson heiress"],[1584,1676,"was his fiancée."],[1689,1876,"Looks like Cecilia's the one who's"],[1876,1989,"been interfering."],[2014,2152,"Cecilia Wilson,"],[2206,2419,"what do you have up your sleeve now?"],[2882,2927,"No!"],[2994,3036,"No!"],[3040,3186,"It's, it's all lies!"],[3286,3445,"Mrs. Clement, tell them."],[3524,3620,"You know, I-"],[3687,3841,"I'm his true love!"],[3841,4066,"I, I'm his real fiancée!"],[4266,4391,"Can we talk about this?"],[4412,4600,"I shouldn't have assumed it was you."],[4600,4721,"That's on me."],[4721,4842,"What do you wanna talk about?"],[4859,4909,"Us."],[4971,5130,"If this is you trying to convince me"],[5130,5263,"not to divorce you,"],[5263,5380,"don't bother."],[5413,5526,"There's nothing left to say."],[5534,5584,"Listen."],[5626,5722,"There's nothing between"],[5722,5789,"Cecilia and I."],[5822,5972,"That doesn't matter to me."],[6006,6081,"It's over."],[6694,6856,"You can't leave her alone, can you?"],[6873,6940,"Let me make something"],[6940,7069,"very clear to you."],[7098,7215,"I'm grateful for everything you've"],[7215,7298,"done for me,"],[7336,7432,"but I don't love you."],[7570,7749,"I cannot keep giving that impression"],[7749,7824,"to Audrey."],[8212,8366,"I've got more surprises waiting"],[8366,8475,"for Audrey."],[8516,8725,"You'll finally belong with me."]],"59":[[996,1084,"Come on, come on!"],[1084,1163,"Get up!"],[1167,1263,"Get up! -No!"],[2131,2239,"Audrey's earring..."],[2369,2548,"She's not a careless person."],[2577,2740,"She wouldn't just leave this behind."],[3157,3286,"When I get out of here,"],[3286,3461,"you're all gonna pay!"],[3528,3624,"You're not getting out of here,"],[3624,3728,"sweetheart."],[4033,4124,"Cornell!"],[4537,4646,"Cornell!"],[4662,4804,"Hero complex, huh? -Cornell!"],[4867,4959,"That didn't work out."],[4959,5055,"So..."],[5055,5234,"I guess I'm gonna have to kill you both."],[5317,5480,"No!"],[5697,5830,"Cornell! -That's my wife."],[6331,6431,"Cornell!"],[6544,6656,"Cornell."],[7011,7136,"Looks like you got lucky today,"],[7136,7215,"sweetheart."],[7311,7436,"Cornell!"],[7494,7632,"Cornell!"]],"60":[[1835,1893,"Audrey,"],[2118,2243,"you've been here all night."],[2506,2660,"He doesn't even love me."],[2711,2919,"Why would he risk his life to save me?"],[3032,3228,"You saved his life five years ago."],[3228,3374,"So maybe,"],[3374,3599,"this is his way of repaying that debt."],[3770,3937,"Your leg hasn't fully healed yet."],[4008,4108,"You should go get it checked out."],[4108,4254,"He's in good hands now."],[5534,5676,"Five years ago..."],[5718,5843,"Audrey saved me?"],[5876,6010,"Not Cecilia?"]],"61":[[529,613,"Cornell,"],[717,850,"I was so worried."],[896,1130,"I, I just saw Audrey leaving."],[1142,1255,"After everything you did"],[1255,1368,"to save her, and she's..."],[1388,1559,"already running off with Bennett."],[1559,1705,"Five years ago..."],[1864,1997,"was it you who saved me?"],[2118,2168,"Well..."],[2252,2473,"Why are you asking that all of a sudden?"],[2606,2773,"Because I know the truth now."],[2819,2927,"It wasn't you."],[2990,3103,"Stop trying to come between"],[3103,3174,"Audrey and I."],[3357,3449,"Get out."],[3486,3603,"This is Audrey,"],[3628,3703,"isn't it?"],[3757,3870,"The liar, I-"],[3962,4091,"You can't"],[4091,4233,"trust her."],[4504,4738,"Am I interrupting something?"]],"62":[[0,229,"Am I interrupting something?"],[579,650,"Audrey,"],[692,759,"don't go."],[963,1055,"I..."],[1063,1180,"need my pain meds."],[1405,1480,"Really?"],[1488,1534,"Look,"],[1534,1655,"I know you're mad,"],[1697,1872,"and I'll accept any punishment you"],[1872,1968,"think I deserve."],[2127,2198,"Please."],[3499,3678,"You love her so much"],[3678,3766,"that you're okay with her"],[3766,3916,"being with another person?"],[4104,4191,"Spread another lie,"],[4191,4346,"and I'll sue you for defamation."],[4796,4913,"Don't even look at me."],[5317,5405,"Did that hurt?"]],"63":[[112,183,"Did that hurt?"],[342,442,"Shouldn't you be more worried"],[442,563,"about your first love?"],[596,746,"She means nothing to me."],[950,1076,"I only care about you."],[1518,1668,"Here are your medical records."],[1705,1772,"The doctor said"],[1772,2006,"your leg injury might not fully heal."],[2006,2189,"Even so, I'd do it all again."],[2298,2456,"Because you are the one I truly love."],[2510,2619,"Even if that's true,"],[2619,2802,"that doesn't mean I'll forgive you."],[3611,3674,"I..."],[3695,3787,"I should go."],[3824,3912,"Audrey, wait."],[4095,4183,"Don't go."],[5668,5826,"I've invested too much in Cornell"],[5826,5943,"to let it go to waste."],[5976,6118,"The upcoming Maple Group project"],[6118,6243,"bidding is my chance."],[6690,6773,"Rumor has it,"],[6773,6827,"the CEO of"],[6827,6973,"Maple Group will attend."],[6986,7190,"If I can secure the Maple Hotel deal,"],[7219,7357,"Cornell will have no choice"],[7357,7507,"but to see me in a new light."]],"64":[[266,429,"Mr. Adam, you're here too?"],[429,571,"It's a pleasure to have you here."],[613,800,"It's Maple Group's project."],[821,921,"How can I miss it?"],[955,1038,"Audrey,"],[1055,1430,"you are the best CEO I have ever met."],[1430,1501,"Hear, hear."],[1605,1785,"The Barton Group is handling the bidding"],[1785,1893,"for the hotel project."],[1893,1960,"This is our first"],[1960,2068,"collaboration with them."],[2068,2210,"And it's an excellent opportunity to"],[2210,2348,"evaluate if they're good partners"],[2348,2439,"for the future."],[2848,2936,"Today,"],[2952,3119,"I am proud to announce"],[3119,3307,"that the Maple Group project"],[3307,3445,"goes to..."],[3474,3649,"Cecilia Wilson!"],[4220,4416,"Why did Barton give the project"],[4416,4575,"to the Wilson family?"],[4596,4717,"I saw the proposal."],[4763,4879,"It was the weakest of them all."],[4925,4996,"I agree."],[5209,5388,"The Wilson family's proposal"],[5388,5576,"isn't qualified to manage"],[5576,5739,"the Maple Hotel project."],[5755,5951,"Maple Group refuses to hand it over"],[5951,6010,"to them."]],"65":[[125,216,"Audrey,"],[291,425,"what makes you think"],[425,588,"you can speak here?"],[621,779,"This is no place for your antics!"],[829,975,"Can somebody call security?"],[975,1013,"Get this"],[1013,1155,"troublemaker out of here!"],[1447,1589,"The security guard"],[1589,1722,"bows to her?"],[1810,2077,"The CEO of Maple Group is rumored"],[2077,2193,"to be a woman."],[2214,2306,"Could it..."],[2377,2469,"be her?"],[2469,2669,"Audrey, how many people did you pay"],[2669,2890,"to play in your ridiculous act?"],[2911,3061,"What are you doing standing there?"],[3061,3174,"Remove her!"],[3174,3495,"I'd like to see you try."],[3536,3666,"Mr. Adam,"],[3666,3966,"the most famous and respectful tycoon."]],"66":[[8,100,"Mr..."],[100,208,"Mr. Adam,"],[250,467,"Audrey is just Bennett's mistress."],[517,650,"Disrupting the Maple Group project"],[650,800,"deserves an explanation!"],[800,938,"Explanation?"],[967,1059,"What"],[1059,1192,"explanation?"],[1297,1388,"You've been using"],[1388,1584,"Maple Group's CEO's name"],[1609,1793,"to intimidate others."],[1856,1943,"Maybe"],[1943,2102,"you should ask her"],[2102,2231,"what she thinks."],[2289,2398,"Her?"],[2469,2602,"The CEO..."],[2698,2819,"is a woman?"],[2819,2969,"Audrey Warburton."],[3007,3111,"She is"],[3111,3328,"Maple Group's real CEO."],[3415,3624,"Mr. Adam, are you serious?"],[3632,3837,"With my reputation,"],[3883,4124,"do you think I'd joke about something"],[4124,4220,"like this?"],[4262,4396,"Do you think I didn't see"],[4396,4529,"the selfish intentions"],[4529,4671,"behind your proposal?"],[4700,4817,"Starting today,"],[4838,5030,"Maple Group will cut all ties with"],[5030,5130,"the Wilson family."],[5213,5347,"You're on your own now."]],"67":[[291,392,"Ms. Warburton,"],[392,496,"please!"],[500,604,"Mr. Barton,"],[604,750,"you've proven incapable of"],[750,900,"making fair judgements."],[921,1026,"I no longer trust the"],[1026,1159,"Barton Group's integrity."],[1209,1363,"And any future collaborations"],[1363,1501,"between us are off the table."],[1501,1622,"This wasn't me!"],[1622,1714,"That, that woman"],[1714,1868,"told me you were just a nobody!"],[2335,2444,"It's over."],[2556,2681,"You ruined it."],[2827,3023,"You've destroyed me!"],[3023,3136,"You're mistaken."],[3174,3357,"I didn't destroy you."],[3411,3574,"You destroyed yourself."],[3845,4062,"Due to the previous unfair decision,"],[4062,4216,"the Maple Hotel project"],[4216,4383,"is back open for bidding."],[4458,4525,"This time,"],[4525,4746,"I will personally announce the winner."],[5005,5055,"Bravo!"],[5372,5442,"Audrey,"],[5442,5555,"this isn't over!"]],"68":[[1238,1309,"Audrey,"],[1384,1514,"I know everything now."],[1751,1872,"I know it wasn't Cecilia"],[1872,2060,"that got me the Maple Hotel job."],[2118,2193,"It was you."],[2298,2398,"So?"],[2627,2769,"So I know that you're the one that"],[2769,2848,"saved me."],[2969,3098,"Why didn't you tell me?"],[3161,3328,"You saved me once before."],[3328,3499,"I was just returning the favor."],[3699,3757,"What?"],[3866,4112,"It seems like you've already forgotten."],[4696,4867,"There you are, stop!"],[4867,4967,"Cornell!"],[5176,5292,"Cornell!"],[5426,5551,"Cornell, stay with me!"],[5551,5643,"Cornell!"],[5743,5839,"Cornell!"],[6106,6247,"Listen, listen to me."],[6264,6423,"I love you, okay?"],[6468,6639,"And I don't want any regrets."],[6769,6894,"Just tell me..."],[6998,7178,"That guy you were talking about,"],[7244,7311,"is it Bennett?"],[7349,7432,"No!"],[7453,7549,"It's you!"],[7578,7720,"It's always been you."],[8153,8337,"Someone call an ambulance!"]],"69":[[704,804,"We found the"],[804,1013,"mastermind behind the kidnapping."],[1476,1618,"She's gone too far."],[1735,1868,"Call the police."],[1868,2039,"Let her face justice in prison."]],"70":[[2535,2623,"Cornell!"],[2660,2744,"Cornell."],[2794,2877,"Cornell."],[3724,3866,"Thank God, you're okay."],[3945,4070,"You took the knife for me."],[4070,4233,"How could I possibly be hurt?"],[4487,4621,"Cecilia was arrested"],[4621,4742,"for attempted assault,"],[4779,4971,"and conspiracy to kidnapping."],[5050,5138,"You have anything you want to"],[5138,5209,"say to her?"]],"71":[[20,166,"I don't wanna talk about her."],[262,387,"She deserves to deal with"],[387,517,"everything she's done."],[563,621,"Then,"],[629,700,"then tell me,"],[700,796,"why were you at that"],[796,971,"hotel room with her that day?"],[971,1117,"And why were you showering?"],[1180,1326,"She wanted me to come by to"],[1326,1468,"deliver a gift for you."],[1488,1693,"And when I got there,"],[1693,1864,"she immediately spilled red wine"],[1864,1956,"all over me."],[1989,2039,"And"],[2064,2231,"I had to wash my clothes,"],[2231,2477,"and shower, and clean myself up, and-"],[2544,2606,"Weren't you afraid"],[2606,2794,"Miranda would force you to marry her?"],[2802,2915,"Listen,"],[2915,3023,"I sent my mother back to the"],[3023,3144,"family estate."],[3207,3365,"She's not gonna bother us anymore."],[3461,3632,"Before I lost consciousness,"],[3657,3753,"I heard something."],[3787,3916,"I heard you say that boy."],[4008,4099,"You were talking about me,"],[4099,4183,"weren't you?"],[4350,4454,"You were, weren't you?"],[4617,4696,"I knew it."],[4842,5025,"I'm the only one you've ever loved."],[5109,5221,"Audrey, listen,"],[5284,5376,"I didn't know."],[5467,5663,"I know I hurt you and..."],[5776,5851,"I just..."],[5872,6072,"I don't deserve your forgiveness."],[6072,6122,"But..."],[6189,6389,"just please let me be close to you."],[6493,6652,"And why'd you save me, anyway?"],[6802,6948,"Do you remember volunteering at the"],[6948,7094,"food bank as a child?"],[7190,7290,"You gave a piece of bread"],[7290,7440,"to a starving girl."],[7469,7545,"That bread"],[7545,7665,"saved her life."],[7728,7849,"And from then on,"],[7878,8024,"she fell in love with you."],[8091,8266,"And promised to follow you,"],[8299,8425,"no matter what."],[8566,8646,"So,"],[8658,8854,"you working at the food bank..."],[8975,9079,"wasn't about Bennett?"],[9109,9275,"It was never about Bennett."],[9330,9467,"You've always loved me."],[9584,9667,"Don't get too excited."],[9667,9805,"I haven't forgiven you yet."],[10176,10322,"Then I'll do whatever it takes to win"],[10322,10406,"you back."]],"72":[[417,521,"Cornell,"],[521,654,"what are you doing?"],[2056,2143,"Audrey,"],[2248,2439,"today is our wedding anniversary."],[2481,2669,"I know what's in my heart now."],[2740,2852,"I love you."],[2890,3028,"So let me ask you again."],[3386,3490,"Will you marry me?"],[3549,3636,"I..."],[3720,3837,"I will!"]]}