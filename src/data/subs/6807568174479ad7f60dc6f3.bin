{"1":[[2122,2181,"Boss,"],[2214,2268,"allow me."],[2389,2460,"No!"],[2631,2736,"Never thought I'd see"],[2736,2961,"the CEO of Maple Group"],[2990,3086,"carrying"],[3086,3244,"crates of food at a food bank."],[3319,3624,"I gave the Maple Hotel project file"],[3624,3707,"to your husband, Cornell,"],[3707,3812,"like you asked."],[3824,4029,"The project signing's in three days."],[4029,4116,"By the way,"],[4116,4254,"his family's company stock"],[4254,4412,"has already tripled."],[4446,4571,"Right on time."],[4600,4829,"It's our third wedding anniversary today."],[4829,5059,"He's gonna love this surprise."],[5088,5238,"I still can't believe"],[5238,5447,"he still doesn't know who you really are."],[5447,5597,"And now you're giving a great"],[5597,5751,"big old project to his family."],[5789,5905,"When I was a kid,"],[5930,6026,"I had nothing."],[6043,6202,"Cornell was volunteering here"],[6202,6339,"and gave me a piece of bread."],[6427,6552,"And he saved me."],[6552,6669,"And after his accident"],[6669,6740,"three years ago,"],[6740,7057,"his family's company just fell apart."],[7057,7152,"Helping him now"],[7152,7228,"feels like"],[7228,7328,"paying him back."],[7486,7603,"Saving the whole world,"],[7603,7774,"and your husband at the same time."],[7862,7978,"And he still thinks"],[7978,8028,"you're just some"],[8028,8166,"low-level employee here."],[8166,8299,"Any woman who works hard to"],[8299,8454,"get ahead deserves respect,"],[8454,8583,"plain and simple."],[8583,8654,"Anyway,"],[8675,8808,"I'm gonna see Cornell"],[8808,8892,"after work today,"],[8892,9034,"and tell him who I really am."],[9054,9117,"Okay."],[9309,9471,"That's Cornell Clement."],[9484,9701,"His wife even looks like a movie star."],[10185,10360,"Who's that woman with Cornell?"],[11336,11436,"Cecilia?"],[11478,11586,"She's back?"],[11649,11778,"What's she doing with Cornell?"],[12871,12975,"Who is it?"],[13584,13722,"What are you doing here,"],[13722,13868,"in my husband's suite?"]],"2":[[104,216,"Not now!"],[216,354,"I've been planning this for too long."],[354,583,"I haven't even touched Cornell yet."],[583,688,"But..."],[688,825,"wait a second,"],[825,996,"maybe this is my chance,"],[996,1105,"a chance to drive a wedge"],[1105,1209,"between them."],[1276,1455,"Yeah, I can totally see why he"],[1455,1622,"doesn't want you anymore."],[1622,1893,"You can't make him happy, Audrey."],[1893,2010,"Only I can."],[2081,2218,"That's why I'm here."],[3190,3345,"Isn't it obvious?"],[3395,3532,"Cornell's in the shower."],[3595,3766,"We were about to have some fun"],[3766,3937,"before you barged in"],[3937,4116,"and ruined everything."],[4116,4275,"You bailed the second he had his"],[4275,4400,"accident three years ago."],[4437,4579,"There's no way Cornell would ever"],[4579,4704,"take you back."],[4704,4942,"Oh, you really think he loves you."],[5059,5205,"You're just like this uniform,"],[5205,5484,"cheap, dirty, and disposable."],[5513,5680,"You'll never be part of his world."],[5718,5826,"I..."],[5868,6060,"am the Wilson heiress,"],[6081,6439,"perfect for Cornell in bed or out in public."],[6443,6606,"Cornell would never cheat on me."],[6606,6731,"Are you sure?"],[6769,6965,"Because he was very passionate"],[6965,7094,"a couple minutes ago."],[7094,7336,"He's never kissed you like this, has he?"]],"3":[[763,834,"Bitch,"],[834,971,"don't even think about touching me"],[971,1105,"with those dirty hands."],[1347,1463,"Soon enough,"],[1484,1597,"I'll be Mrs. Clement,"],[1597,1730,"and then we'll see who the real"],[1730,1835,"home-wrecker is."],[1835,2072,"You left him after he had his accident,"],[2072,2231,"even when his family was on the"],[2231,2377,"verge of bankruptcy."],[2410,2560,"I'm the one who stood by him,"],[2560,2752,"and helped him build everything back."],[2765,2940,"And now that he's a rising star,"],[2940,3044,"you're acting like you've"],[3044,3174,"been there all along?"],[3307,3407,"So what?"],[3436,3566,"He loves me."],[3774,3928,"Haven't you ever wondered,"],[3962,4083,"why he hasn't talked about having"],[4083,4312,"kids with you in three years?"],[4346,4491,"He doesn't want kids"],[4491,4608,"because he doesn't wanna be stuck"],[4608,4800,"with you after the divorce."],[4821,5000,"He's been waiting for me"],[5000,5092,"all along."],[6485,6606,"Cornell, I,"],[6706,6869,"I tried to talk with her,"],[6869,6931,"but I..."],[7019,7140,"She wouldn't listen."],[7140,7223,"Please don't"],[7223,7315,"blame her."],[7369,7461,"It's"],[7461,7503,"my fault."],[7503,7615,"I, I, I shouldn't"],[7615,7699,"upset her."],[7757,7862,"She's lying."],[8020,8187,"Three years, Audrey,"],[8220,8324,"and you're still holding onto"],[8324,8400,"that grudge?"],[8425,8579,"Do you really feel like you should treat her"],[8579,8637,"this way?"],[8641,8733,"I didn't touch her!"],[8733,8871,"She did it to herself."],[8871,9013,"Do I look stupid to you?"],[9084,9196,"No one in their right mind"],[9196,9296,"cuts their own wrist,"],[9296,9451,"especially someone who faints at the"],[9451,9538,"sight of blood."],[9542,9638,"Cornell it's..."],[9651,9788,"I, I shouldn't have come."],[9788,9847,"It's"],[9847,9934,"my fault."],[9934,9980,"I'll,"],[9980,10047,"I'll go."],[10060,10151,"She's lying!"],[10151,10335,"She's not even afraid of blood!"],[10335,10422,"Cornell,"],[10422,10548,"I'm your wife."],[10577,10739,"Why won't you believe me?"],[10769,10856,"Stop!"],[10881,10998,"I've heard enough."],[11098,11265,"Cecilia saved my life."],[11403,11482,"If it weren't for her,"],[11482,11624,"I wouldn't be here right now."],[12604,12796,"When did she ever save you?"],[12796,12983,"I'm the one who did twice."],[13008,13129,"But it doesn't matter,"],[13129,13204,"does it?"],[13242,13359,"Because you'll always choose"],[13359,13492,"her over me."]],"4":[[767,905,"Oh, there you are."],[1030,1134,"Here."],[1155,1351,"Divorce papers with Cornell."],[1409,1589,"Sign them, get the hell out of here."],[1651,1768,"He's cheating on me,"],[1768,1989,"and now he's the one asking for a divorce?"],[1989,2110,"So what?"],[2122,2323,"You are nothing but a food bank worker."],[2323,2477,"Did you ever really believe"],[2477,2669,"that you were good enough for my son?"],[2690,2777,"Three years ago,"],[2777,2886,"when I married Cornell,"],[2886,3040,"he was stuck in a hospital bed,"],[3040,3132,"and your family was"],[3132,3261,"five million in debt."],[3294,3420,"Where were those high standards"],[3420,3503,"back then?"],[3511,3616,"Watch your mouth."],[3657,3878,"If Cecilia had not left the country,"],[3903,3987,"Cornell would've"],[3987,4137,"never ended up with you."],[4158,4362,"I've done everything for this family."],[4425,4600,"I've been the perfect wife."],[4600,4767,"I've stood by Cornell through it all,"],[4767,5021,"and I've worked myself to the bone."],[5059,5242,"When will that ever be good enough?"],[5255,5338,"You?"],[5338,5484,"The perfect wife?"],[5584,5697,"Please."],[5714,5843,"Cornell's business would've been"],[5843,6018,"ten times more successful if"],[6018,6181,"you weren't holding him back!"],[6181,6306,"Say whatever you want."],[6331,6452,"If he wants a divorce,"],[6481,6619,"he can ask me himself."],[6648,6760,"Don't waste my time,"],[6760,6902,"you pathetic little leech!"],[6902,7061,"Sign the damn papers!"],[7173,7298,"You worthless-"],[7344,7444,"Let go."],[7507,7574,"Give it."],[7661,7736,"Give me that."],[7736,7824,"What the-"],[7924,8083,"What the hell are you doing?"],[8099,8258,"I come back to take you to the hospital,"],[8258,8354,"and you're picking a fight with"],[8354,8433,"my mother?"]],"5":[[20,191,"This crazy woman,"],[191,304,"she tried to hit me,"],[304,417,"and in public!"],[421,633,"No, look at those scratches."],[654,775,"They're all red."],[813,900,"Do they hurt?"],[900,992,"Yeah."],[992,1096,"Let me see."],[1197,1322,"How could you do this to"],[1322,1459,"Cornell's mom?"],[1501,1718,"Cecilia, you're such a kind person,"],[1785,1960,"unlike some other people."],[2006,2093,"Audrey,"],[2139,2285,"apologize to my mother."],[2302,2369,"Why should I?"],[2369,2489,"I didn't even touch her."],[2489,2690,"How dare you lie right to my face!"],[2886,2936,"Listen,"],[2936,3069,"I know Cecilia's return's been"],[3069,3132,"hard on you."],[3190,3353,"I just need you to apologize,"],[3353,3470,"and we'll move on."],[3511,3632,"Three years,"],[3678,3916,"I stood by you when no one else would."],[3945,4141,"I helped you get back on your feet,"],[4141,4266,"start your company,"],[4266,4341,"build your company"],[4341,4496,"back up from scratch."],[4512,4738,"And you never believed in me."],[4738,4854,"Not even once."],[4854,4950,"You?"],[4950,5105,"Rebuilt his company?"],[5117,5271,"You must have hit your head harder"],[5271,5367,"than I thought."],[5367,5530,"Cecilia has been working"],[5530,5764,"day and night on the hotel project,"],[5764,5918,"getting things done without"],[5918,6056,"making a fuss."],[6056,6310,"And yet here you are acting like the hero."],[6327,6443,"Are you crazy?"],[6443,6519,"I'm the one who gave"],[6519,6669,"the project to Cornell!"],[6669,6873,"Cecilia's got nothing to do with it."],[6873,7077,"Don't you dare talk to her like that."],[7107,7278,"Apologize to my mother."],[7278,7374,"Now."],[7374,7586,"No, I'm not apologizing!"],[7586,7766,"The Maple Group project is mine!"],[7766,7941,"Are you saying that you gave that project"],[7941,8045,"to my son?"],[8095,8262,"You're either out of your damn mind,"],[8262,8537,"or so completely jealous of Cecilia"],[8537,8750,"for having what you'll never have."],[8750,8971,"This is just sad, Audrey."],[8971,9034,"I..."],[9088,9205,"You don't have to lie"],[9205,9305,"just because you're"],[9305,9538,"embarrassed about your background."],[9538,9713,"I never thought you'd stoop this low."],[9768,9901,"I don't even know this woman."],[9901,10101,"Cecilia knows the CEO of"],[10101,10247,"Maple Group personally."],[10456,10552,"I am"],[10552,10727,"the CEO of Maple Group."]],"6":[[262,442,"Did you hear that?"],[442,579,"This lunatic"],[579,759,"thinks she runs the Maple Group."],[759,967,"Yet she makes $3,000 a month,"],[967,1042,"and spends all of her"],[1042,1188,"time with the homeless people."],[1197,1372,"When your family was drowning in debt"],[1372,1468,"three years ago,"],[1468,1643,"I'm the one who called investors."],[1676,1914,"I saved your family from going bankrupt!"],[1931,2018,"The investors that-"],[2018,2202,"Don't let her fool you."],[2202,2352,"The signing ceremony is in"],[2352,2448,"three days."],[2448,2715,"You will find out who the real CEO is then."],[2748,2836,"Now Cornell,"],[2848,3078,"you've given Cecilia the key aspects"],[3078,3186,"of the project."],[3207,3440,"Let her introduce you to the CEO."],[3516,3687,"And as for you,"],[3699,3858,"get lost."],[3945,4091,"Cornell and I have talked."],[4091,4225,"After the signing,"],[4245,4412,"I'll be leading the key"],[4412,4491,"divisions."],[4708,4867,"You're giving it to Cecilia?"],[4996,5134,"Is this why you fought so hard"],[5134,5251,"for this project?"],[5259,5292,"Why not?"],[5292,5492,"Cecilia's perfect for Cornell."],[5534,5668,"She's his equal,"],[5693,5818,"his lifesaver,"],[5839,5930,"and someone he"],[5930,6072,"actually cares about."],[6072,6151,"Mom,"],[6181,6260,"stop!"],[6260,6360,"Cornell's"],[6360,6502,"still shy,"],[6502,6639,"even after all these years."],[6794,6919,"I get it now."],[7002,7102,"I get it now."],[7236,7378,"So this is it, huh?"],[7482,7636,"You've had the divorce papers"],[7636,7745,"ready all along."]],"7":[[12,162,"You've had the divorce papers"],[162,279,"ready all along."],[633,734,"Divorce?"],[838,1026,"Is this how you plan on threatening me?"],[1059,1209,"Your mom hit me."],[1209,1334,"Your so-called girlfriend"],[1334,1476,"humiliated me,"],[1476,1576,"and now you're blaming me"],[1576,1689,"for this divorce?"],[1701,1843,"They wouldn't treat you this way,"],[1843,1922,"if they didn't think you were"],[1922,2043,"part of the problem."],[2089,2177,"You're right."],[2218,2323,"It's all my fault."],[2398,2548,"I deserve this."],[2565,2640,"You know,"],[2640,2769,"you trust everyone,"],[2786,2873,"your mom,"],[2890,3015,"Cecilia,"],[3015,3178,"everyone except me,"],[3199,3311,"your wife!"],[3311,3490,"Some people just don't realize"],[3490,3641,"how lucky they are to be part of"],[3641,3766,"the Clement family."],[3832,3899,"Cornell,"],[3899,4045,"stop wasting time."],[4087,4258,"Just sign the paperwork,"],[4258,4433,"and be done with this useless"],[4433,4537,"leech already."],[4537,4637,"Enough!"],[5534,5659,"I've given you everything the"],[5659,5730,"past three years,"],[5730,5876,"and this is how you repay me?"],[5951,6139,"Let me make one thing clear to you,"],[6139,6302,"we are not getting a divorce."],[6322,6427,"Everything?"],[6456,6594,"You mean your mom's insults?"],[6610,6752,"Cecilia parading around like"],[6752,6840,"she owns you?"],[6840,6906,"It's not"],[6906,6936,"what- -What"],[6936,7111,"exactly am I supposed to be"],[7111,7223,"grateful for?"],[7223,7382,"It's not what you think."],[7382,7490,"And why do you always assume"],[7490,7561,"the worst?"],[7561,7695,"Have you stopped for a second"],[7695,7799,"to look at yourself?"],[7803,7912,"Is it my fault they keep"],[7912,8008,"coming after me?"],[8008,8145,"You really think I wronged you,"],[8145,8183,"don't you?"],[8270,8354,"If it weren't for me,"],[8354,8445,"you would've been homeless"],[8445,8537,"the past three years."],[8537,8637,"And if it were for me,"],[8637,8808,"you'd still be in a hospital bed,"],[8808,8954,"and your mom would've ended up in"],[8954,9142,"jail for unpaid debts!"],[9150,9346,"Listen, I realize what you've done for me,"],[9346,9467,"and I do appreciate it."],[9480,9663,"But haven't I made your life better too?"],[9697,9793,"Better?"],[9859,10060,"Staying up until three AM to take"],[10060,10226,"care of you when you were sick?"],[10226,10389,"Getting up at seven every morning to"],[10389,10560,"make your mom breakfast?"],[10577,10739,"And all of that,"],[10764,10881,"just for you to see it as"],[10881,11031,"taking advantage of you?"],[11065,11182,"That's not what I meant-"],[11182,11323,"Three years, Cornell!"],[11323,11428,"Three years, and I never"],[11428,11615,"spent a single cent of your money."],[11615,11770,"And now you're calling me a liar"],[11770,11957,"for calling you out on your affair?"],[11957,12024,"It's not"],[12024,12053,"what you- -I"],[12053,12208,"literally saw Cecilia"],[12208,12320,"walk out of your room."],[12320,12520,"She already told you why she was here!"],[12520,12696,"There's nothing going on between us!"],[12696,12854,"And what would count?"],[12854,13004,"Do I really need to catch you two in"],[13004,13113,"bed together?"],[13275,13329,"I get it."],[13380,13467,"You don't wanna leave."],[13484,13596,"You want my love,"],[13609,13730,"my attention,"],[13792,13909,"my touch."],[13943,14093,"That's why you're jealous of Cecilia."]],"8":[[62,112,"Stop!"],[304,492,"Stop, I said stop!"],[629,788,"Have you lost your mind?"],[950,1042,"Sign it!"],[1084,1259,"I'm done with you, your family,"],[1259,1447,"and this whole miserable life!"],[1493,1593,"What's your rush?"],[1655,1735,"Have you found yourself a new"],[1735,1805,"sugar daddy?"],[1814,1931,"No!"],[2014,2106,"But even if I did,"],[2106,2293,"you wouldn't believe me, would you?"],[2314,2423,"You don't care."],[2452,2552,"You never did."],[2590,2723,"All these years, Cornell,"],[2781,3011,"have you ever even loved me?"],[3282,3432,"You can't even lie about it."],[3465,3582,"So why?"],[3595,3774,"Why won't you just let me go?"],[3774,3949,"Because divorce is not acceptable in"],[3949,4041,"the Clement family."],[4079,4149,"Ever!"],[4149,4237,"Of course."],[4266,4416,"Why was I even expecting anything"],[4416,4496,"different from you?"],[4525,4583,"Love?"],[4604,4675,"Compassion?"],[4675,4825,"God, I'm such a joke!"],[5455,5547,"It's done."],[5634,5734,"Haven't I done enough for you"],[5734,5834,"the past three years?"],[5834,5926,"If by enough"],[5926,6047,"you mean your mom's insults,"],[6047,6197,"and your cold shoulder, then yes."],[6218,6297,"You've given me more"],[6297,6439,"than I ever asked for."],[6677,6802,"You won't be able to afford a"],[6802,6998,"studio apartment without me."],[7086,7127,"Thanks,"],[7127,7186,"but..."],[7186,7328,"that's none of your business."],[7374,7503,"Don't forget to sign."],[7895,8045,"If you're thinking about apologizing,"],[8045,8149,"now's your chance."],[8245,8420,"I'll give you to the count of three."],[8546,8604,"Three,"],[8842,8913,"two,"],[9004,9059,"one."]],"9":[[312,442,"Audrey Warburton,"],[475,658,"you really can't wait, can you?"],[717,875,"To run off with some other guy?"],[888,1005,"You still"],[1005,1105,"don't believe me,"],[1105,1167,"do you?"],[1267,1363,"I'm done."],[1397,1543,"This whole marriage and everything I've"],[1543,1730,"given you these past three years..."],[1760,1918,"was just one big joke."],[1960,2110,"You're nothing without me."],[2143,2243,"We're over,"],[2243,2331,"Cornell."],[2394,2489,"Whatever I do now is"],[2489,2598,"none of your business."],[2719,2861,"You're still wearing the ring I got you."],[3261,3357,"Take it back."],[3920,4012,"You got what you wanted."],[4012,4116,"We're divorced."],[4116,4229,"Stop!"],[4283,4396,"Where do you think you're going?"],[4433,4521,"My son bought you"],[4521,4675,"everything you're wearing today."],[4758,4921,"Give it all back before you leave."],[4971,5084,"Of course."],[5109,5217,"Just like your son."],[5309,5401,"If you want it,"],[5455,5513,"take it."],[6427,6573,"Is she the mistress?"],[6623,6765,"Probably married rich and got"],[6765,6861,"kicked out."],[6881,6994,"How sad."],[7565,7657,"Stop."]],"10":[[70,171,"That's enough."],[191,325,"I don't need your help."],[342,483,"I've done what you asked."],[483,621,"Can I go now?"],[946,1059,"I said stop!"],[1163,1230,"Listen,"],[1251,1347,"I know there's been a big"],[1347,1497,"misunderstanding right now."],[1522,1743,"Can we just go home and talk about this?"],[1743,1956,"For God's sake, just give me this."],[1997,2077,"Let her go!"],[2135,2273,"Let her embarrass herself if that's what"],[2273,2360,"she wants."],[2360,2590,"As if anyone's gonna believe her little tale."],[2861,2986,"Listen, I know you're broke."],[3032,3094,"Okay?"],[3182,3349,"You don't have to be tough right now."],[3390,3549,"Just get yourself some clothes."],[3566,3661,"Alright?"],[4412,4592,"Save your useless charity."],[9184,9300,"Audrey, what happened?"],[9801,9872,"Nothing."],[9880,9976,"Let's just go."],[10047,10097,"Okay."],[11682,11786,"He's..."],[11878,12112,"the VP of Maple Group."],[12162,12341,"Could she really be..."]],"11":[[183,291,"Did you see that?"],[350,483,"She had another man lined up"],[483,588,"this entire time!"],[600,663,"That guy..."],[696,779,"is that Bennett?"],[867,992,"The VP of the Maple Group?"],[1026,1167,"Could she really be the CEO?"],[1247,1351,"The CEO?"],[1351,1438,"Come on."],[1459,1622,"At best, she's his mistress!"],[1622,1722,"No wonder she agreed to the"],[1722,1843,"divorce so quickly."],[1881,1951,"Cornell,"],[2056,2256,"are you sure she hasn't moved on?"],[2344,2427,"I knew it."],[2427,2569,"She left me for someone."],[3645,3774,"I can't believe"],[3807,3953,"his family treats you like this after"],[3953,4074,"everything you've done for them."],[4087,4220,"You are the one who saved Cornell."],[4241,4350,"You even injured yourself"],[4350,4471,"carrying him out of the burning house."],[4471,4600,"How could they do this to you?"],[5209,5301,"Cornell!"],[5709,5780,"Cornell!"],[5939,6014,"Cornell!"],[6031,6160,"Can you hear me?"],[6160,6256,"Cornell!"],[7624,7707,"It's over."],[7757,7853,"We're divorced."],[7928,8091,"The past doesn't matter anymore."],[8174,8254,"Well,"],[8308,8470,"then let's focus on the present."],[8550,8679,"I'm pulling the plug on the"],[8679,8775,"Maple Hotel project"],[8775,8842,"with Cornell"],[8842,8904,"right now."],[8904,9000,"Not now."],[9050,9134,"Let's wait,"],[9180,9426,"and let them find out in a more"],[9426,9538,"public way."],[9555,9726,"Like at the signing ceremony"],[9726,9813,"in three days?"],[9930,10026,"Cornell always"],[10026,10193,"thought I married him for money."],[10222,10422,"He's gonna see just how wrong he was"],[10422,10477,"soon."],[10543,10643,"Yes, Ma'am."]],"12":[[158,312,"Oh my gosh."],[1263,1405,"Oh, that Cecilia"],[1405,1630,"sure knows how to handle herself"],[1630,1739,"like a lady."],[1805,2006,"She wouldn't even stay in the hospital"],[2006,2152,"after cutting her wrist."],[2202,2360,"And Audrey,"],[2377,2552,"well, she's the complete opposite."],[2590,2752,"Always whining about nothing,"],[2752,2882,"and seeking attention."],[2915,3094,"I just wanted to be here for Cornell."],[3174,3345,"I can't imagine how hard Audrey's"],[3345,3507,"betrayal must be for him."],[3553,3620,"She's"],[3620,3741,"just upset with me."],[3762,3887,"When she cools down,"],[3920,4008,"she'll come back."],[4429,4496,"Oh,"],[4496,4592,"Cornell,"],[4592,4646,"my"],[4646,4867,"injury I got five years ago from"],[4867,5034,"saving you in that fire,"],[5034,5167,"acting up again."],[5167,5226,"I think I,"],[5226,5376,"I twisted it this time."],[5451,5492,"You know,"],[5492,5643,"you should get some rest."],[5643,5868,"Once we secure the hotel project,"],[5868,5935,"we can start"],[5935,6039,"planning your wedding."],[6081,6222,"Mom, stop."],[6268,6439,"Audrey and I are not getting a divorce."],[6473,6669,"She's just upset with me right now."],[6740,6827,"I'm confident she'll come"],[6827,6936,"back after the signing."],[6998,7094,"I know you promised"],[7094,7248,"you'd put me in charge of a"],[7248,7353,"major division."],[7353,7507,"Why don't I take over HR?"],[7524,7728,"I know the CEO personally."],[7757,7836,"Leave it to me."],[7853,7957,"Yeah, sure."],[8033,8195,"And what about the"],[8195,8316,"signing ceremony?"],[8345,8466,"Are you gonna take me?"],[8654,8721,"You know,"],[8775,8875,"I think that's"],[8892,9021,"a place for my wife."],[9088,9242,"I don't know if that'd be appropriate."],[9296,9376,"Excuse me."],[9722,9889,"I'll take you there if he won't."],[9934,9997,"Soon enough,"],[9997,10164,"you two will be married anyway."],[10164,10251,"Besides,"],[10293,10439,"as the HR director,"],[10506,10735,"you can fire Audrey before the wedding."],[10773,10902,"Cornell won't have a choice"],[10902,10994,"but to choose you."],[11040,11186,"I'm gonna be the one standing next to"],[11186,11315,"Cornell at the ceremony."],[11340,11473,"But I'll have to make sure Audrey's"],[11473,11607,"out of the way first."]],"13":[[621,658,"Hi."],[1355,1430,"Audrey,"],[1443,1559,"why aren't you at the hospital?"],[1622,1730,"It's just a scratch."],[1730,1856,"Two days off was enough."],[1872,1968,"The signing's today,"],[1968,2214,"and I want everything to be perfect."],[2243,2306,"Audrey"],[2306,2402,"Always-On-Duty"],[2402,2473,"Warburton."],[2711,2802,"Here you are!"],[2886,2994,"What are you doing here?"],[3007,3207,"Skipping out on your food bank duties?"],[3274,3370,"Sure,"],[3370,3449,"whatever."],[3478,3595,"I don't have to explain myself"],[3595,3674,"to you."],[3695,3795,"Oh, really?"],[3828,4004,"Then maybe you can help me understand"],[4004,4049,"how"],[4049,4120,"this"],[4141,4212,"garbage"],[4225,4358,"ended up in the hotel."],[4358,4429,"Looks like it came"],[4429,4558,"straight from your food bank."],[4608,4775,"I don't have time for this nonsense."],[4783,4950,"I only stepped away from the food bank"],[4950,5042,"for ten minutes."],[5059,5176,"There's no way that bread"],[5176,5334,"could have ended up on the shelves."],[5413,5526,"Then what's this?"],[5605,5659,"Look."],[5726,5993,"Your food bank's a joke, Audrey,"],[5993,6151,"and it's ruining the Maple Hotel's"],[6151,6243,"reputation."],[6256,6385,"You planted this, didn't you?"],[6385,6498,"You're in charge of inventory."],[6498,6652,"Don't try to pin this on me."],[6677,6769,"As..."],[6781,6919,"HR director,"],[6973,7107,"it's my responsibility"],[7107,7269,"to deal with negligence like this."],[7269,7353,"Starting"],[7353,7449,"with firing you."],[7453,7540,"So..."],[7540,7770,"Cornell made you the HR director,"],[7770,7907,"just so you could fire me?"],[7920,7999,"Aww."],[8024,8133,"Don't be jealous."],[8153,8308,"HR is just one of my duties,"],[8308,8475,"but it's enough to get you kicked out."],[8512,8612,"All I need to do"],[8629,8825,"is call Michael Davis, the head of HR."],[8833,8917,"When he's here,"],[8917,9109,"your career will be so over."],[9109,9213,"After today,"],[9213,9355,"you'll be back out on the streets,"],[9355,9476,"begging for scraps."],[9476,9601,"I wouldn't be so sure."],[9626,9738,"Let me guess,"],[9755,9905,"your little boyfriend, Bennett,"],[9905,10110,"is gonna swoop in and save you?"],[10118,10260,"Who said I needed Bennett?"],[10281,10364,"Maybe I could"],[10385,10489,"fire you myself?"],[10539,10614,"You?"],[10623,10744,"Fire me?"],[10852,10965,"You must be kidding?"],[11473,11565,"Fine."],[11615,11770,"If you're so desperate,"],[11786,11924,"here's your chance."],[12003,12120,"Pick up the bread and eat it."],[12153,12354,"Then maybe I'll reconsider firing you."],[12374,12529,"Abusing your position?"],[12550,12754,"Aren't you afraid of being fired yourself?"],[12758,13121,"Cecilia has no idea her boss’ boss is me!"],[13158,13259,"What's going on here?"],[13259,13400,"Oh my god, it's her!"]],"14":[[8,125,"Michael,"],[125,275,"you're just in time."],[275,392,"You're head of HR."],[392,492,"How are you gonna handle her"],[492,550,"negligence?"],[550,654,"You're HR?"],[671,721,"Great."],[729,846,"Fire her now."],[996,1084,"Who do you think you are,"],[1084,1163,"giving me orders?"],[1163,1276,"Ms. Wilson here is"],[1276,1488,"Mr. Clement's fiancée."],[1488,1564,"Do you even know"],[1564,1751,"who Mr. Cornell Clement is?"],[1751,1835,"He's Maple Group's"],[1835,1993,"first choice for this deal."],[2027,2093,"Oh, right,"],[2093,2285,"this Micael hasn't met me in person."],[2339,2498,"No wonder he doesn't recognize me"],[2498,2690,"as the CEO of Maple Group."],[2715,2911,"Michael, don't waste your energy on her."],[2911,3073,"Just fire her already."],[3103,3194,"And Cornell and I will"],[3194,3332,"make sure that you're rewarded."],[3411,3516,"Fiancée?"],[3549,3624,"Wow!"],[3670,3778,"We've only been divorced for"],[3778,3987,"two days, and you're already engaged?"],[4020,4091,"So,"],[4091,4195,"you're Mr. Clement's"],[4195,4375,"ex-wife."],[4400,4517,"Get lost."],[4529,4683,"You don't belong here."],[5359,5472,"Get out, bitch."],[5472,5555,"You don't"],[5555,5684,"belong here."],[5697,5930,"I started this charity to help people,"],[5930,6076,"and Cornell just straight up gave it"],[6076,6197,"to someone like you."],[6231,6364,"Greedy and out for yourself."],[6364,6719,"God, just shut up and fuck off!"],[7365,7474,"Hell is this?"],[7474,7557,"Cornell,"],[7557,7686,"I caught her bringing"],[7686,7891,"moldy bread into the hotel."],[7907,8041,"I tried to confront her,"],[8041,8116,"but..."],[8166,8283,"she attacked me."],[8283,8387,"Mr. Clement,"],[8387,8537,"we were just handling the issue,"],[8537,8800,"making sure she knows her place."],[8800,8858,"Audrey,"],[8858,8979,"this is all your mess."],[8979,9104,"You've caused all these problems"],[9104,9188,"yourself."],[9209,9321,"Why do you have to keep throwing it"],[9321,9421,"back at Cecilia?"]],"15":[[25,112,"No matter what I say,"],[112,304,"you're always gonna take her side, right?"],[346,408,"Cornell,"],[421,567,"she's made such a mess."],[567,796,"Don't you think she deserves to be..."],[817,938,"let go?"],[938,1034,"Yes,"],[1046,1155,"fire her."],[1155,1317,"Effective immediately."],[1334,1468,"I'm the CEO now."],[1497,1626,"And I understand people mess up,"],[1626,1726,"and because you're my wife,"],[1726,1860,"I will let this slide."],[1922,2010,"You just have to promise me"],[2010,2152,"this will never happen again,"],[2173,2310,"and I will secure your job."],[2419,2560,"I assigned you this project,"],[2560,2752,"and you're gonna take Cecilia's side?"],[2752,2919,"They're the ones who should be fired."],[2998,3132,"Stop lying!"],[3303,3365,"I already told you,"],[3365,3482,"you are nothing without me."],[3482,3557,"Nothing?"],[3557,3724,"You may not see me much,"],[3724,3891,"but I'm sure you know Bennett,"],[3891,4008,"your dear VP."],[4058,4145,"Let me call him."],[4633,4700,"Bennett,"],[4750,4925,"meet me at the hotel in three."],[4925,4992,"Yes, Boss,"],[4992,5059,"be right there."],[5063,5205,"Bennett Woods,"],[5205,5326,"Maple Group's VP?"],[5326,5463,"Give me a break."],[5463,5551,"People like you don't"],[5551,5701,"make those kinds of calls."],[5734,5901,"The VP has more important"],[5901,6014,"things to do."],[6089,6318,"Do you really think a little mistress"],[6318,6535,"like you can just boss him around?"],[6535,6610,"All right, stop."],[6610,6702,"That's enough."],[6802,6915,"You're causing a scene."],[6956,7007,"And frankly,"],[7007,7152,"you're embarrassing yourself."],[7157,7278,"And if Bennett shows up?"],[7278,7424,"If he actually shows up,"],[7424,7528,"I'll eat that bread,"],[7528,7745,"and resign on the spot."],[7811,7882,"Deal."],[8174,8312,"Audrey, what is going on here?"],[8320,8437,"He actually came?"]],"16":[[33,171,"Audrey, what's going on here?"],[204,271,"Mr. Woods-"],[271,367,"Not talking to you."],[367,650,"This HR director abused his authority."],[650,750,"Fire him."],[750,896,"Mr. Woods, she's lying!"],[896,1084,"She neglected the food bank inventory."],[1084,1146,"I was just"],[1146,1280,"doing my job- -All right, stop."],[1322,1422,"Let's just take a look at the"],[1422,1555,"security cameara footage."],[1918,1947,"Yeah,"],[1947,2093,"send me the security camera footage"],[2093,2273,"from earlier from the food bank area."],[2273,2344,"Now, thanks."],[2640,2731,"Care to explain this?"],[2873,2998,"It, it wasn't me!"],[2998,3115,"It, it was her!"],[3115,3199,"I wouldn't risk my job"],[3199,3290,"for something like this!"],[3290,3470,"I have a family to feed."],[3486,3716,"Have you lost your mind?"],[3716,3858,"How could you do this?"],[3858,3899,"I,"],[3899,4049,"I trusted you!"],[4079,4195,"Why do I feel like someone's"],[4195,4295,"pulling his strings?"],[4295,4425,"Stay out of this!"],[4425,4521,"Then fire him."],[4562,4696,"I'd love to see how the person"],[4696,4888,"behind this plans to buy him off."],[4913,5009,"It was her."],[5167,5280,"A million dollars."],[5313,5484,"I'll pay you a million dollars"],[5484,5593,"to just go."],[5597,5693,"Now!"],[5709,5793,"It was me."],[5801,5918,"I take"],[5918,6151,"full responsibility for everything."],[6202,6281,"Good enough."],[6289,6373,"Security,"],[6373,6514,"get this rapscallion out of here."],[7140,7182,"Yes, Ma'am."],[7603,7636,"Wait,"],[7653,7728,"Cornell,"],[7782,7857,"just let her go."],[7857,7937,"She's not worth it."],[7937,8053,"Let go of me."],[8124,8233,"I have to talk to her."],[8583,8650,"What are you doing?"],[8650,8758,"Let me go!"]],"17":[[50,175,"We have to talk about this."],[237,304,"It's fine."],[379,467,"Let me handle this."],[483,567,"Are you sure?"],[567,613,"Yeah."],[700,855,"I have to finish this on my own."],[855,1005,"What's the matter with you?"],[1005,1138,"Michael worked so hard to get me"],[1138,1197,"this project,"],[1197,1355,"and you just go and get him fired?"],[1368,1484,"So you'd rather believe some"],[1484,1651,"stranger's lies than trust me."],[1651,1772,"You betrayed me."],[1835,2022,"Why are you so quick to cut ties with me?"],[2072,2147,"Because of Bennett?"],[2210,2377,"Do you really think everyone's as shady"],[2377,2515,"as you and Cecilia?"],[2535,2623,"It's not what you think about"],[2623,2748,"Cecilia and I."],[2886,3053,"Let's go home, and talk about this."],[3065,3119,"Okay?"],[3128,3261,"We're divorced, Cornell!"],[3261,3420,"That's your home, not mine."],[3461,3528,"Let her go,"],[3528,3603,"Cornell."],[3695,3812,"She's got Bennett now."],[3837,3908,"Why would she still"],[3908,4066,"care about the Clement family?"],[4312,4400,"Is that true?"],[4487,4683,"Since you only listen to Cecilia,"],[4733,4833,"why don't you go ahead and"],[4833,4988,"follow whatever she says."],[5088,5167,"I'm done."],[5459,5618,"So the love you had for me for the"],[5618,5801,"past three years was all fake, huh?"],[5826,5889,"Well, I hope the money"],[5889,6068,"I gave you was worth the performance."],[6252,6297,"Bennett,"],[6418,6506,"bring me the check."],[7649,7795,"Ten million dollars."],[7836,8003,"That's twenty times what you gave me."],[8078,8170,"Keep your money."],[8262,8345,"I don't need it."],[8800,8871,"See?"],[8979,9092,"She's with Bennett now."],[9192,9359,"You never loved me, Audrey."],[9380,9526,"It was all about the money."]],"18":[[8,266,"What a huge ceremony!"],[275,446,"The CEO of Maple Group"],[446,654,"sure thinks highly of Cornell."],[675,850,"And it's all because of you, sweetheart,"],[850,1001,"for using your sister's connections"],[1001,1109,"with the Maple Group."],[1151,1297,"Cornell would not be running"],[1297,1480,"the Maple Hotel without you."],[1522,1622,"It's nothing."],[1668,1843,"He is my fiancé after all."],[1864,2056,"Cornell not marrying you back then was a"],[2056,2198,"huge mistake."],[2198,2260,"But now that he's"],[2260,2439,"divorcing that worthless woman,"],[2489,2602,"it's time for the two of you to"],[2602,2715,"set things right."],[2781,2969,"As far as she's concerned,"],[3003,3123,"I don't care if she rots."],[3144,3236,"Alright, stop."],[3290,3465,"Audrey and I are not divorced yet."],[3987,4095,"Cornell Clement."],[4183,4341,"Why does he seem so distant?"],[4350,4567,"You don't think he's actually..."],[4621,4783,"falling for Audrey, do you?"],[4859,5009,"Don't be ridiculous."],[5050,5163,"How could someone like her even"],[5163,5280,"compare to you?"],[6635,6760,"Excuse me."],[6760,6977,"I am Cecilia Wilson,"],[7002,7203,"of the Wilson family."],[7203,7290,"I don't care who you are."],[7290,7449,"My job's to protect my client."],[7457,7611,"Such a grand entrance."],[7640,7862,"Could that be the CEO of Maple Group?"],[7874,8003,"Must be some heiress."],[8024,8158,"Someone powerful."],[8174,8333,"I should make a good impression."],[9009,9134,"It's you?"]],"19":[[20,171,"Audrey Warburton."],[250,392,"What a surprise."],[417,567,"Thought you'd be at home crying after"],[567,709,"Cornell dumped you."],[709,829,"What's with the little party dress,"],[829,946,"and the personal bouncer?"],[1026,1213,"Hunting for a new sugar daddy?"],[1222,1317,"No matter"],[1317,1593,"how hard you try to fit in,"],[1618,1780,"you will never belong here."],[1922,2097,"Leave before Cornell sees you."],[2118,2298,"I know that you're here for Cornell."],[2298,2394,"Too bad."],[2419,2540,"He's moved on."],[2569,2727,"And he's never coming back to you."],[2756,2898,"So just stop!"],[2977,3098,"Oh my God!"],[3098,3303,"I have heard so much about you,"],[3303,3507,"and I'm so excited to finally meet you."],[3528,3607,"I practically begged"],[3607,3707,"Bennett to let me be here,"],[3707,3807,"so I could greet you"],[3807,3878,"in person."],[3916,4037,"The Chambers heiress"],[4037,4175,"managing a guest list?"],[4250,4341,"Impressive."],[4354,4529,"As always, Cecilia,"],[4529,4754,"living up to the Wilson family name."],[4783,4896,"Even Ms. Chambers"],[4896,5063,"couldn't resist your charm."],[5138,5326,"And once we're both inside,"],[5326,5422,"we'll both get to meet"],[5422,5584,"the CEO of Maple Group."],[5897,6114,"Thank you so much for the support."],[6189,6252,"I've been out of the"],[6252,6385,"country for a couple years"],[6385,6502,"under the radar."],[6519,6639,"Once I see the CEO,"],[6639,6735,"I'll make sure to put in a"],[6735,6848,"good word for you."],[6894,6973,"But first,"],[6973,7107,"can we make sure to get rid"],[7107,7240,"of this intruder?"],[7240,7290,"I'm sorry,"],[7307,7353,"who"],[7353,7415,"are you?"]],"20":[[45,137,"Ms. Chambers,"],[166,312,"this doesn't make any sense."],[333,417,"My son,"],[417,504,"Cornell Clement,"],[504,654,"is the reason for this event."],[684,796,"Why would you let her in?"],[796,1084,"Excuse me, I don't make mistakes."],[1084,1197,"And for the record,"],[1197,1288,"you better start treating"],[1288,1376,"Ms. Warburton with the"],[1376,1514,"respect she deserves."],[1551,1584,"But- -Do you still"],[1584,1676,"want to enter?"],[1676,1747,"If not,"],[1789,1839,"leave."],[1839,2010,"Yes, yes, here's our invitation."],[2164,2277,"This is the"],[2277,2444,"VIP entrance."],[2456,2606,"If you'd still like to enter,"],[2606,2752,"you'll have to use the general entrance,"],[2752,2927,"and wait in line with everyone else."],[3044,3161,"Oh, I..."],[3549,3657,"This is bad."],[3699,3928,"She was so respectful to Audrey."],[3991,4258,"Could Audrey actually be the CEO?"],[4258,4504,"You are overthinking it, Mrs. Clement."],[4546,4692,"Audrey has always been good at"],[4692,4934,"sucking up to people, even in college."],[4954,5063,"I'm sure Ms. Chambers"],[5063,5121,"just..."],[5142,5230,"fell for it."],[5255,5459,"Plus, we all know the Chambers family"],[5459,5701,"is all about their Maple Group deal."],[5768,5997,"And let us not forget her whole"],[5997,6118,"thing"],[6118,6214,"with Bennett."],[6314,6406,"You're right."],[6464,6573,"Oh, that liar!"],[6573,6715,"She almost had me."],[6731,6886,"I forgot that she's the type of person to"],[6886,7019,"sleep her way to the top."],[7073,7286,"We have to expose all of the nasty"],[7286,7374,"things that she's done"],[7374,7503,"once we're inside."]],"21":[[1034,1222,"Mr. Clement is impressive,"],[1272,1443,"securing a deal with Maple Group"],[1472,1605,"at such a young age."],[1605,1743,"They're known for being super selective"],[1743,1856,"with partnerships."],[1893,2122,"Well, Cornell is talented,"],[2139,2264,"but we couldn't have done it without"],[2264,2444,"Cecilia and the Wilson family"],[2444,2623,"connecting us to the Maple Group."],[2690,2790,"And soon,"],[2831,3003,"she'll be my daughter-in-law."],[3015,3286,"But isn't Mr. Clement married already?"],[3286,3478,"Oh, please, don't get me started."],[3553,3737,"His business wasn't prospering at all"],[3737,3862,"while those two were married."],[3903,4020,"Mrs. Clement, look,"],[4041,4145,"isn't that Audrey?"],[4229,4346,"That bitch!"],[4404,4500,"I can't believe she's"],[4500,4717,"latched onto another man already."],[4717,4896,"We can't let her get away with this."],[5130,5271,"We're really excited to team up with the"],[5271,5338,"Maple Group."],[5367,5505,"Here's to making it a success."],[5901,5964,"So,"],[6014,6122,"how about we go out sometime,"],[6122,6277,"grab some dinner to celebrate?"],[6318,6414,"Thank you, Mr. Shrute,"],[6414,6569,"but ever since I got married,"],[6569,6785,"I've made it a habit to keep things simple"],[6785,6840,"and,"],[6840,7032,"you know, avoid any misunderstandings."],[7032,7132,"You're married?"],[7132,7253,"I don't see a ring."],[7307,7399,"Well, I-"],[7949,8174,"You are still married to my son,"],[8174,8279,"and yet you're hanging all over"],[8279,8366,"this guy?"],[8383,8537,"He the catch of the day?"]],"22":[[12,191,"Just so you know, Mr. Shrute,"],[204,342,"this woman was kicked out of the"],[342,567,"Clement family for cheating on my son."],[600,784,"She's just clinging to the rich lifestyle"],[784,950,"she can't let go of anymore."],[971,1180,"She is nothing but a gold digger."],[1180,1317,"Don't let her fool you!"],[1343,1539,"She's Mr. Clement's ex-wife?"],[1555,1768,"All dressed up just to reel in a new target."],[1793,1860,"The CEO's gonna"],[1860,2006,"throw her out when they find out."],[2006,2110,"That's enough."],[2110,2318,"Audrey doesn't need anyone's money."],[2331,2464,"She could buy my company"],[2464,2644,"ten times over and not even try."],[2719,2781,"Gosh."],[2819,2994,"Is she paying you to say that?"],[3028,3186,"How broke were you when she found you?"],[3228,3328,"I mean, honestly,"],[3328,3390,"how much is she"],[3390,3516,"paying for this little show?"],[3516,3574,"You-"],[3603,3853,"Someone like her will never have a place"],[3853,3933,"here- -Stop!"],[3933,4120,"Give it a rest, Audrey."],[4170,4241,"Here,"],[4275,4429,"since we were college classmates,"],[4429,4550,"let me do you a favor."],[4604,4813,"My family's bar needs dancers,"],[4829,4925,"three grand a night."]],"23":[[12,296,"Who knows, maybe I'll even come by."],[383,471,"Cheer you on."],[1559,1693,"How dare you?"],[2335,2494,"Since you like money so much,"],[2502,2681,"why not take the job yourself?"],[2706,2823,"Ms. Warburton,"],[2823,2969,"don't waste your time."],[2969,3111,"She's not worth it."],[3132,3294,"I have to make this clear,"],[3332,3536,"Maple Hotel isn't their playground."],[3536,3716,"Cornell runs this place!"],[3716,3837,"Once he sees what you've done,"],[3837,3970,"he'll make you regret it!"],[4441,4587,"Audrey, what the hell are you doing?"],[4662,4846,"The knight in shining armor is here."],[4875,4971,"So,"],[4971,5117,"what's the lecture about this time,"],[5117,5176,"Cornell?"],[5176,5338,"This is a formal event."],[5338,5442,"Do you really have to start a fight"],[5442,5522,"right now?"],[5555,5655,"This, Cornell,"],[5701,5968,"is what you'd call starting a fight."]],"24":[[79,246,"What is the matter with you?"],[346,454,"You've changed,"],[454,558,"something's not right with you."],[558,667,"Changed?"],[667,825,"Of course I did."],[825,996,"I loved you Cornell,"],[996,1159,"more than anything."],[1159,1326,"And what did that get me?"],[1334,1459,"We're done, Cornell."],[1459,1639,"I'm done begging for your love."],[1664,1810,"Get these two out of here."],[1810,1985,"Maple Hotel doesn't tolerate this"],[1985,2097,"kind of nonsense."],[2331,2556,"I am the CEO of this company."],[2556,2623,"You can't just kick"],[2623,2723,"my guests out like that."],[2723,2773,"Do you know what"],[2773,2923,"that'll do to my reputati