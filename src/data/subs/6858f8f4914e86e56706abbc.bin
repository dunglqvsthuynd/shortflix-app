{"1":[[738,884,"Happy birthday, sweetheart."],[925,1046,"Thank you, grandpa."],[1051,1109,"Get in!"],[1121,1234,"I'm throwing a big party for"],[1234,1380,"the world's best granddaughter."],[1668,1760,"You know how much"],[1760,1893,"I love you, grandpa."],[1910,2089,"Seriously, but,"],[2223,2335,"I really want to spend the day with"],[2335,2448,"my biological brothers."],[2502,2673,"I'll see you soon, okay?"],[2673,2761,"Okay."],[2761,2865,"I love you."],[2865,2965,"I love you too."],[3586,3695,"My name's Oriana."],[3724,3841,"When I was 6,"],[3849,3966,"my stepmother abandoned me"],[3966,4083,"at a trailer park."],[4120,4212,"Lucky for me,"],[4212,4379,"the richest man on earth,"],[4379,4483,"Murray Morel,"],[4483,4546,"adopted me."],[4608,4696,"Three years ago,"],[4696,4884,"I found my biological family again."],[4896,4971,"They have no idea"],[4971,5155,"I'm now the Morel family heiress."],[5201,5363,"While keeping my identity a secret,"],[5384,5547,"I've been helping my brothers"],[5547,5659,"chase their dreams."],[6010,6131,"How'd my eldest brother end up as"],[6131,6264,"student body president?"],[6373,6602,"Let's just say I pulled some strings."],[6810,6965,"The new president for"],[6965,7315,"Morel Academy’s student council is"],[7315,7536,"Easton Sullivan!"],[7766,7966,"My second brother getting first place"],[7966,8124,"at the national jewelry design"],[8124,8204,"competition."],[8279,8370,"You're welcome, Sheldon."],[9567,9701,"Oh, wow."],[9705,9859,"Sheldon Sullivan,"],[9864,9997,"congratulations!"],[9997,10143,"You're the winner of this year's"],[10143,10289,"national jewelry design."],[10890,11061,"And by now, you can probably guess"],[11061,11194,"how my youngest brother became"],[11194,11302,"the star quarterback."],[11365,11503,"Yeah, also me."],[11578,11628,"Yeah."],[11661,11803,"Coach, I'm donating"],[11803,11966,"50 million to your program."],[12020,12149,"Please train my brother to become"],[12149,12228,"the best quarterback"],[12228,12349,"the school's ever seen."],[12366,12424,"Warren!"],[12437,12508,"You and me."],[12525,12783,"Everyday one-on-one training at 7 AM!"],[12821,12917,"Thank you, Coach!"],[13088,13242,"These Sullivan kids are insane."],[13246,13317,"They're not only from"],[13317,13446,"the richest family in LA,"],[13446,13576,"but they're talented too."],[13576,13701,"Hey guys over here!"],[13705,13776,"Over here!"],[13792,13880,"Alright! Alright!"],[13918,14005,"Everyone listen up."],[14114,14226,"This weekend,"],[14226,14385,"I'm throwing a huge party."],[14385,14610,"But not just any party."],[14647,14898,"It's a surprise party for my sister!"],[15102,15252,"Oh my god, who's their sister?"],[15252,15432,"Whoever she is, she's so lucky."],[15473,15640,"I wish I had brothers like them!"],[16111,16191,"Grandpa."],[16199,16307,"My brothers are throwing me"],[16307,16441,"a surprise birthday party."],[16487,16729,"Ori, honey, you spent what?"],[16729,16908,"30 million on them?"],[16908,17079,"And all you're getting in return"],[17079,17192,"is a birthday party?"],[17192,17367,"Are they really worth it?"]],"2":[[183,533,"Happy birthday to you."],[571,984,"Happy birthday to you."],[1217,1363,"Of course, it was worth it."],[1393,1493,"My mom's last wish"],[1493,1643,"before she died was for all of her kids"],[1643,1780,"to love and support each other."],[1780,1885,"But sweetheart,"],[1885,2022,"they should at least know"],[2022,2122,"you're the one helping them-"],[2122,2239,"No, grandpa."],[2268,2410,"That'll put too much pressure on them."],[2444,2573,"Families support each other."],[2594,2656,"That's what we do."],[2656,2723,"Hey let's go."],[2723,2790,"Party time."],[2886,2965,"Okay."],[3307,3386,"Coming!"],[3891,3983,"That's her!"],[4054,4162,"That's their sister!"],[4183,4350,"The luckiest girl in the world!"],[5338,5480,"This has got to be worth"],[5480,5622,"at least fifty grand."],[5797,5864,"What are you doing with"],[5864,5960,"Sheldon's necklace?"],[5960,6085,"Stay out of my business!"],[6769,7057,"Give me Sheldon's necklace!"],[7057,7207,"Make me, bitch."],[8558,8762,"Why do you keep following us?"],[8825,9084,"You poor people are like cockroaches."],[9109,9242,"First my mom dropped you off"],[9242,9405,"at a trailer park 10 years ago."],[9463,9584,"Then I push you down"],[9584,9813,"a whole damn flight of stairs."],[9813,9959,"But no matter what we do,"],[9968,10181,"you just don't die."],[10206,10331,"Sheldon's"],[10331,10477,"necklace…"],[10514,10656,"Give it back!"],[11494,11603,"You should've stayed in that"],[11603,11665,"trailer park."],[11665,11815,"The Sullivan name,"],[11815,12103,"everything, belongs to me now."],[12103,12266,"I don't care about the money."],[12333,12545,"I only care about my brothers."],[12545,12650,"Your brothers?"],[12679,12850,"They're my brothers."],[12879,12946,"They don't give a shit"],[12946,13079,"about gutter rats like you."],[13088,13196,"They love me."],[13246,13455,"They threw this whole party for me!"],[14347,14589,"Happy birthday,"],[14589,14689,"Vicki?"],[14689,14773,"Surprise!"],[14773,15052,"This is my party, not yours."],[15106,15252,"You're nothing, Oriana."],[15306,15457,"Nothing but a worthless piece"],[15457,15582,"of street trash."],[15653,15769,"You think Vicki’s gonna like"],[15769,15911,"the present I got her?"],[16166,16274,"Shit, they're coming."],[16579,16750,"Let's see who they blame for this one."],[17125,17208,"Oriana."]],"3":[[75,175,"Oriana,"],[175,275,"what are you doing?"],[504,692,"I was trying to stop Oriana"],[700,859,"from stealing Sheldon's necklace"],[859,959,"and she threw me against"],[959,1067,"the bleachers."],[1067,1238,"Are you serious right now?"],[1305,1514,"You're the one that stole the necklace."],[1514,1651,"Really, Oriana?"],[1705,1893,"You used to be such a good kid."],[1935,2018,"Now you steal,"],[2068,2177,"you lie,"],[2235,2402,"everywhere you go,"],[2402,2498,"you stir up trouble."],[2610,2752,"Just a few days ago,"],[2752,2844,"we caught you trashing"],[2844,2894,"mom's dress."],[2919,2965,"Mom?"],[3019,3165,"Eason, stop calling that"],[3165,3307,"homewrecker Mom!"],[3332,3516,"Our mom's name is Bianca!"],[3757,3845,"Dad!"],[3845,3983,"Watch your mouth!"],[3991,4120,"Whether you like it or not,"],[4120,4433,"your stepmom is part of our family now."],[4433,4508,"And where did you learn"],[4508,4637,"how to talk like that?"],[4637,4733,"The trailer park?"],[4733,4888,"And you should never treat"],[4888,4984,"your sister like that!"],[5230,5518,"Oriana, grew up in a trailer park?"],[5518,5663,"Eww, gross."],[5680,5809,"I better not catch"],[5809,5964,"her poor people germs!"],[6151,6264,"You married that woman"],[6264,6435,"the day after mom died."],[6523,6660,"If she could see you right now,"],[6660,6802,"she would be sick!"],[6802,6886,"Shut up!"],[6977,7144,"Don't mention her!"],[7161,7303,"She's nothing compared"],[7303,7374,"to Kimberly."],[7394,7586,"That woman left me in a trailer park"],[7586,7766,"when I was 6 years old."],[7778,7945,"I was separated from my family"],[7945,8112,"for 8 whole years!"],[8387,8562,"Trailer park trash."],[9175,9280,"No, where are you going?"],[9280,9405,"Don't leave me!"],[9476,9651,"Oriana, sweetheart."],[9705,9851,"It was an accident."],[9884,10147,"We were playing and you wandered off."],[10164,10393,"I searched for you for years."],[10756,10965,"You apologize to Vicki right now,"],[10977,11127,"or you're no longer a Sullivan."],[11190,11277,"And I'll go home"],[11277,11353,"and I'll remove you from"],[11353,11494,"the house myself."],[11494,11578,"And I'll make sure you"],[11578,11728,"never see a nickel"],[11728,11857,"of the family fortune."],[11857,11970,"No."],[11982,12070,"Okay, you heard dad."],[12137,12224,"Say sorry."],[12399,12479,"Easton."],[12575,12733,"Even you don't believe me?"],[13083,13146,"Face it."],[13250,13413,"You've been gone too long."],[13467,13601,"Now you're just a"],[13601,13792,"black sheep of the family."],[13863,14064,"Now, apologize."],[14606,14814,"Easton, why are you siding with her?"],[14885,15044,"I'm your real sister!"],[15135,15265,"I'll handle this, Easton."],[15728,15799,"There."],[15799,15920,"That should clear your mind."],[15920,16078,"I suggest you start talking."],[16149,16362,"Soon there will be no time for apologies."],[16362,16466,"Sheldon!"],[16624,16875,"I had three sleepless nights"],[16875,17104,"revising your design for the competition."],[17104,17258,"Stop trying to take credit"],[17258,17400,"for my award."],[17459,17634,"That was my design!"],[17642,17734,"My work!"],[19310,19419,"Last chance."],[19452,19590,"Tell Vicki you're sorry."],[19765,19874,"Move out of the way!"],[20028,20107,"Warren."],[20174,20341,"You believe me, right?"]],"4":[[0,41,"Warren…"],[66,154,"Believe you?"],[212,279,"No."],[300,442,"I'm here to teach you a lesson."],[700,784,"Warren!"],[971,1088,"When the fire broke out"],[1088,1280,"in the football arena,"],[1280,1472,"I was the one that dragged you out."],[1514,1705,"And now you're siding with Vicki?"],[1705,1839,"What are you talking about?"],[1876,1935,"It was Vicki"],[1935,2047,"who saved me."],[2047,2160,"You're delusional."],[2410,2560,"That's for hurting Vicki."],[3157,3345,"You three are my brothers."],[3407,3574,"My own flesh and blood."],[3636,3903,"And the second Vicki accuses me,"],[3903,4162,"you don't question it or hesitate?"],[4792,4925,"There are security cameras"],[4925,5059,"all over the school."],[5134,5263,"Check the footage and we'll see"],[5263,5388,"who stole the necklace."],[5522,5605,"Security."],[5651,5730,"Check the footage."],[5935,6197,"Shit, I can’t let them see that!"],[6773,6861,"Here, Ori."],[6861,6956,"Let me help you."],[7453,7620,"Oriana, what?"],[7620,7741,"Oriana."],[7795,7949,"Stealing a necklace is one thing."],[7978,8078,"But this,"],[8133,8287,"this is attempted murder!"],[8345,8400,"What?"],[8437,8616,"No, I didn't. I…"],[8737,8971,"I won't have a lunatic for a daughter."],[9034,9142,"Get her out of here!"],[9209,9317,"Now!"],[9751,9893,"I wish you never came home."],[9926,10093,"I wish you were never my sister!"],[10226,10364,"I'm embarrassed"],[10410,10564,"to share the same DNA."],[10564,10727,"You disgust me, Oriana!"],[10752,10881,"Go back to your trailer park"],[10881,10977,"and rot there."],[11553,11886,"Happy birthday to you."],[11903,12262,"Happy birthday to you."],[12287,12691,"Happy birthday, dear Vicki."],[12716,13025,"Happy birthday to you."]],"5":[[1322,1405,"Mom."],[1576,1668,"You always said"],[1668,1839,"family is supposed to be everything."],[2039,2202,"But what happens when the people"],[2202,2327,"who are supposed to love you,"],[2435,2556,"hurt you the most."],[2852,2932,"Mommy!"],[3111,3194,"Ori, baby."],[3428,3607,"When I'm gone, it's just going to be you"],[3607,3712,"and your brothers, okay?"],[3849,3995,"I need you to make me a promise"],[3995,4062,"that you're going to"],[4062,4229,"take care of each other, okay?"],[4312,4458,"You're going to look after each other"],[4458,4550,"no matter what."],[4625,4763,"I promise, mom."],[4771,4946,"I'll always look after them,"],[4979,5084,"no matter what."],[5155,5251,"My baby."],[5442,5576,"Just one last…"],[6202,6335,"Mommy…"],[7874,7957,"What do you want?"],[8708,8804,"My brothers told me"],[8804,8900,"to teach you a lesson"],[8900,9063,"you'd never forget."],[9351,9430,"No!"],[9451,9588,"Get away from me!"],[9943,10047,"They said make sure"],[10047,10193,"you're really sorry."],[13292,13396,"Grandpa was right."],[13571,13688,"None of this was worth it."],[13688,13855,"I wish you never came home."],[13897,14043,"I wish you were never my sister!"],[14059,14356,"I'm embarrassed to share the same DNA."],[14356,14514,"You disgust me, Oriana!"],[14535,14664,"Go back to your trailer park"],[14664,14752,"and rot there."],[14802,14989,"If I make it out of this alive,"],[15035,15215,"I'm taking back everything"],[15215,15315,"I ever gave them."],[15398,15469,"Every,"],[15515,15598,"last,"],[15719,15799,"thing."]],"6":[[162,316,"She has internal bleeding."],[316,446,"She needs a transfusion."],[487,563,"Damn it!"],[617,700,"We don't have enough in the"],[700,784,"blood bank."],[784,946,"What? Then get more!"],[963,1084,"I don't care what it takes."],[1084,1205,"You send a damn helicopter"],[1205,1251,"if you have to!"],[1251,1422,"You just save my granddaughter!"],[2719,2798,"I'm…"],[2890,3007,"I'm alive?"],[3094,3261,"Ori, you’re awake!"],[3311,3399,"Thank God!"],[3478,3536,"I didn't know if"],[3536,3674,"you were going to make it."],[4408,4554,"You’d better have some rest."],[4667,4746,"Grandpa."],[4934,5021,"I messed up."],[5192,5263,"I never should have"],[5263,5426,"gone back to the Sullivan's."],[5559,5722,"I never should have given all that money"],[5722,5893,"to my ungrateful brothers."],[5893,6039,"What they did to you"],[6076,6247,"is unforgivable."],[6364,6510,"And I will not let them"],[6510,6623,"get away with this."],[6623,6881,"No, grandpa."],[7011,7136,"Let me handle this."],[7399,7536,"I'm going to take back"],[7590,7836,"everything I ever gave them."],[8003,8295,"Until they have nothing."],[8996,9084,"Oriana?"],[9163,9417,"How dare you show your face back here?"],[9651,9805,"My brothers are back!"],[10143,10231,"Oriana!"],[10301,10497,"Look at what you did to mom's painting!"],[10539,10623,"This again?"],[10668,10819,"How many times are you going to keep"],[10819,11027,"framing me before this gets old?"],[11027,11269,"That painting cost me fifty grand!"],[11298,11444,"You better pay me back."],[11444,11690,"Oriana, you are unbelievable!"],[11690,11836,"Doing this to your own family."],[12103,12203,"Family?"],[12270,12354,"Please."],[12437,12629,"She's a glorified mistress,"],[12629,12758,"and you're a shit dad."],[12796,12921,"Neither of you are my family."],[12983,13092,"What did you just say?"],[13092,13213,"You shameless bitch."],[13254,13455,"No one talks to my mom like that!"],[13834,14014,"That's for stealing my family."],[14276,14468,"That's for slandering me."],[14823,14989,"And that's for almost killing me!"],[15044,15206,"Oriana, you are out of line!"],[15206,15402,"This is what you wanted, right?"],[15402,15511,"You always accuse me"],[15511,15607,"of bullying her."],[15607,15715,"So fine,"],[15715,15807,"I'll show you what"],[15807,15953,"real bullying looks like."],[15982,16066,"I'm done."],[16153,16249,"No more lies,"],[16282,16424,"no more obligations."],[16449,16591,"From this moment on,"],[16900,17050,"we're no longer family."]],"7":[[0,108,"We're no longer family."],[291,392,"Disowning your family"],[392,433,"isn't something"],[433,525,"you can come back from your own,"],[525,592,"Oriana."],[633,692,"You know this means"],[692,825,"I'm going to cut you out of my will."],[825,917,"Go ahead."],[938,1063,"Like I give a damn."],[1092,1205,"She's bluffing."],[1255,1434,"I bet she has heirlooms in her bag."],[1434,1493,"Check it!"],[1555,1785,"Oriana, you know stealing's a crime."],[1835,1939,"Do you want to go to prison?"],[1968,2043,"Move."],[2798,2936,"It's just full of junk."],[3182,3261,"See?"],[3311,3449,"Nothing to worry about."],[3486,3611,"Like you said,"],[3611,3741,"it's just a bunch of junk."],[3741,3899,"I bet there's more expensive stuff"],[3899,3958,"in there."],[3958,4037,"Check again!"],[4074,4208,"I have a better idea."],[4237,4408,"Let's go through it together."],[4821,5100,"This bear was a gift from Easton."],[5676,5772,"And this doll,"],[5918,6014,"was from Sheldon."],[6356,6502,"And this pillow,"],[6819,6923,"that's from when Warren"],[6923,7027,"and I went camping."],[7332,7428,"And this picture,"],[7499,7678,"it's our last family picture,"],[7716,7928,"from my sixth birthday."],[9071,9213,"You have enough yet?"],[9263,9371,"You want to keep searching?"],[9526,9634,"From this moment on,"],[9688,9872,"I'm no longer a Sullivan."],[10235,10335,"Oriana!"],[10381,10518,"You're going to regret this."],[10548,10639,"No."],[10694,10785,"You will."],[10935,11061,"You all have no idea"],[11061,11194,"who I really am."],[11227,11382,"You think you got where you are"],[11382,11482,"without me?"],[11611,11836,"Easton’s student council presidency,"],[11903,12128,"Sheldon's design award,"],[12195,12412,"Warren's football championship,"],[12545,12675,"none of it would have"],[12675,12791,"happened without me."],[12942,13029,"And now,"],[13133,13275,"I'm taking it all back."],[13671,13859,"What the fuck is she talking about!"],[14130,14210,"Oriana!"],[14297,14376,"Oriana!"],[14593,14827,"Ori, I’m giving you one last chance."],[14827,14973,"You’d better…"],[14973,15119,"Let go!"],[18259,18380,"What the hell?"],[18380,18476,"Who are these people?"],[19119,19285,"You took everything from me."],[19285,19469,"Now, I’m taking it all back."]],"8":[[850,1005,"Welcome back, Ms. Oriana."],[1184,1267,"Thanks."],[1697,1776,"Grandpa,"],[1864,1964,"I'm home."],[2223,2348,"My beautiful Ori."],[2377,2515,"It’s so good to have you home."],[3311,3382,"You know,"],[3382,3532,"Ori, now that you're home."],[3545,3657,"There’s no need to dress"],[3657,3770,"like a commoner."],[3870,4091,"Amber, bring her something new,"],[4116,4237,"something special."],[4258,4358,"We need to celebrate"],[4358,4512,"her homecoming properly."],[4575,4671,"Right away, sir."],[5451,5709,"A limited edition Cartier brooch,"],[5709,5939,"ten million dollars."]],"9":[[4,208,"A Mouawad 1001 Nights"],[208,325,"diamond purse,"],[325,467,"twenty million dollars."],[513,667,"The Nightingale of"],[667,855,"Kuala Lumpur dress,"],[855,1113,"thirty million dollars."],[1138,1222,"Wow."],[1422,1501,"Grandpa,"],[1551,1701,"I'm still in high school."],[1718,1993,"You really expect me to show up to class"],[2077,2160,"in this?"],[2252,2473,"Oh, fine, fine, fine."],[2473,2598,"I won't force you,"],[2698,2756,"for now,"],[2756,2915,"but I want you to do me a favor."],[3090,3240,"I want you to meet somebody,"],[3257,3424,"an old friend's grandson."],[3424,3603,"He's your age."],[3603,3682,"You'll like him."],[3924,4129,"Hey kill ,kill ,kill ,kill."],[4129,4200,"Omaha!"],[4200,4270,"Omaha!"],[4270,4358,"Rep 33!"],[4404,4483,"Set hut!"],[4842,5071,"Hunter, you got a call."],[5555,5655,"Hey, this is Hunter."],[5814,5980,"Aren't you the mysterious owner"],[5980,6122,"of the Morel Football Club?"]],"10":[[29,179,"Wait, hold on,"],[225,392,"Aren't you the mysterious owner"],[392,533,"of the Morel Football Club?"],[658,771,"Yep, that's me."],[863,1076,"I'm Oriana, nice to meet you."],[1096,1176,"No way."],[1259,1363,"I'm flattered but"],[1372,1501,"what are you calling me for?"],[1547,1659,"I heard you're transferring"],[1659,1755,"to Morel Academy."],[1868,1964,"How would you"],[1964,2022,"like to be"],[2022,2127,"the new quarterback"],[2127,2289,"of the Morel football team?"],[2489,2569,"I still don't get it."],[2598,2681,"How the hell is Oriana leaving"],[2681,2831,"in a chauffeur- driven car?"],[2940,3040,"She's cutting ties with us."],[3040,3136,"This family used to"],[3136,3207,"mean everything to her."],[3228,3332,"Who even knows if"],[3332,3445,"that was her chauffeur?"],[3482,3566,"For all we know,"],[3566,3707,"he could be her sugar daddy."],[3728,3807,"Eww."],[3820,3899,"Just watch,"],[3899,4129,"she'll have an STD in no time."],[4149,4396,"Like mother, like daughter, I guess."],[4504,4642,"Shame on her mother,"],[4700,4829,"and shame on her!"],[4846,4959,"They're stained"],[4959,5142,"to the Sullivan family name."],[5288,5397,"What the hell is she thinking?"],[5442,5534,"Getting with that guy"],[5534,5647,"three times her age,"],[5743,5872,"he's probably some pedophile."],[5885,5964,"No one,"],[6072,6289,"and I mean no one"],[6306,6606,"is to give her a cent of financial support."],[6619,6802,"Let's see how long she lasts on her own"],[6806,6981,"before she comes running back."]],"11":[[91,183,"Everyone,"],[183,262,"move!"],[283,404,"Warren's coming through."],[1251,1380,"Oh my God."],[1380,1543,"I'm, I'm so sorry."],[1543,1701,"Are you fucking blind?"],[1701,1814,"This jacket cost more than"],[1814,1997,"your entire pathetic life."],[1997,2231,"I, I'm sorry, I didn't see you, I..."],[2298,2389,"Let her go."],[2527,2656,"Well, well,"],[2656,2831,"look who decided to play hero."],[2831,2907,"Oriana,"],[2907,3128,"we told everyone to clear the way."],[3148,3257,"She didn't."],[3257,3403,"She broke the rules."],[3424,3553,"Are you sure you want to stick"],[3553,3666,"your neck out for her?"],[3832,3962,"The rules?"],[4024,4170,"Who do you think you are?"],[4183,4287,"The principal?"],[4304,4446,"You can't just bark orders"],[4446,4654,"at people and expect them to listen."],[4846,4925,"Oriana,"],[4950,5088,"the Sullivan's aren't people"],[5088,5209,"you want to go up against."],[5326,5530,"Warren, please just tell me"],[5530,5668,"what I can do to fix this."],[6014,6131,"I got an idea."],[6147,6293,"How about a temperature check?"],[6464,6589,"Please, no."],[6694,6827,"Hey, that's enough."],[6881,7011,"Stop bullying her."]],"12":[[4,212,"Oriana, back the fuck off!"],[212,333,"You think you're a hero,"],[350,417,"but you're nothing"],[417,604,"without the Sullivan family backing you."],[650,771,"Oriana, that dumb bitch"],[771,875,"just spilled her drink"],[875,1001,"on your brother,"],[1034,1247,"and you're acting like we're the bad guys?"],[1259,1455,"She just never fucking learns."],[2627,2748,"Oriana, heroes are heroes"],[2748,2873,"because they're rich."],[2898,3136,"Just look at Batman, but trailer trash you."],[3182,3286,"Your only superpower is"],[3286,3474,"smelling like a fucking dumpster"],[3474,3578,"wherever you go."],[3678,3757,"Fine."],[3837,4016,"Maybe I'm not a hero,"],[4070,4291,"but at least I'm not a sadistic bully."],[4546,4617,"You know,"],[4617,4783,"since I'm feeling nice,"],[4825,5017,"I'm gonna give you one more chance."],[5017,5184,"Lap up that spilled juice"],[5184,5317,"with little friend of yours,"],[5376,5451,"or I'll show you"],[5451,5559,"the definition of bullying."]],"13":[[742,934,"Let's just do as they say."],[980,1142,"Fighting back only feeds their evil."],[1167,1301,"Rich people like them they don't"],[1301,1413,"face any consequences"],[1413,1559,"for their actions."],[3023,3199,"That's fucking hot!"],[3207,3490,"Oriana, I’m lactose intolerant!"],[3490,3657,"This time I'm really gonna kill you."],[3657,3791,"Oriana, you bitch!"],[3791,3920,"Just wait until mom and dad"],[3920,4004,"hear about this."],[4004,4366,"Hey, I'm just giving you bullies a taste"],[4366,4471,"of your own medicine."]],"14":[[4,145,"Oh, you're dead."],[579,667,"Lucky you,"],[725,829,"saved by the bell."],[896,1005,"This isn't over."],[1835,1914,"You okay?"],[1914,2081,"Oh my God,"],[2093,2298,"Oriana is really cool."],[2306,2473,"She's like some kind of"],[2527,2686,"anti-bully Queen."],[2786,2852,"I never thought"],[2852,2957,"anyone would stand up to"],[2957,3086,"the Sullivans like that."],[3449,3574,"Thanks for that."],[3641,3791,"I... The last time"],[3799,3908,"Warren bullied someone"],[3908,3999,"they had to drop out"],[3999,4149,"of school because it got so bad."],[4208,4287,"That was gonna be me"],[4287,4450,"and then you stepped in."],[4717,4992,"Do you think maybe we could be friends?"],[5113,5305,"I'm Oriana, nice to meet you."],[5426,5572,"I'm Amy, you're actually"],[5572,5739,"the first friend I've made here."],[5755,5910,"You're the first friend I've made here too."],[6289,6514,"SAT registration forms are here."],[6931,7052,"Oriana, what school"],[7052,7152,"do you want to go to?"],[7244,7394,"My top choice is Harvard."],[7791,7937,"Did you guys hear that?"],[7941,8174,"This loser thinks she can get into Harvard."],[8220,8441,"That's the funniest shit I've ever heard."],[8466,8566,"This is gonna be so good."],[8566,8687,"Totally going TikTok."],[8787,8904,"Give it back!"]],"15":[[0,95,"Give it back!"],[104,304,"You really think a Jane Doe"],[304,458,"can just waltz into Harvard?"],[475,638,"Plus, aren't you a sophomore?"],[638,754,"These SAT forms are"],[754,946,"for seniors only, bitch."],[971,1117,"So what if I'm a sophomore?"],[1163,1334,"I'm graduating two years early."],[1363,1480,"I took summer school classes"],[1480,1618,"to get ahead on my credits."],[1634,1830,"Whatever, some stupid"],[1830,1981,"summer school courses."],[1981,2110,"Don't get you into an"],[2110,2268,"Ivy League institution."],[2381,2669,"Harvard is for crème de la crème."],[2744,2961,"Trailer trash like you"],[3040,3228,"could never afford the tuition."],[3499,3616,"Keep talking shit,"],[3674,3807,"but I'm getting into Harvard."],[3958,4108,"Oh my God, I can't."],[4200,4308,"How about this?"],[4387,4600,"Since you're so sure of yourself,"],[4600,4738,"let's make a little bet,"],[4796,4900,"you and me."],[4946,5042,"Whoever gets into the shittier"],[5042,5176,"college has to take"],[5176,5317,"the winner's punishment."]],"16":[[108,187,"Deal."],[354,467,"Let's go, ladies."],[671,750,"Oriana,"],[813,909,"I don't know about this."],[909,1021,"Vicki’s super rich."],[1021,1180,"Her parents probably have connections"],[1180,1368,"with admissions officers."],[1651,1735,"I guess I'm just gonna have to"],[1735,1843,"work harder, then."],[4525,4633,"Sorry, Grandpa."],[4863,5217,"Oriana's early action application"],[5217,5363,"results came back."],[5405,5551,"You're going to Harvard."],[6101,6222,"Oh my God,"],[6252,6364,"I did it."]],"17":[[0,116,"Well done, Ori!"],[116,254,"You're the first ever Morel"],[254,467,"Academy student to get into Harvard."],[500,700,"This is a cause for celebration."],[700,867,"Today, we're gonna have a party"],[867,992,"in your honor at the school."],[992,1121,"That's a grand idea."],[1142,1368,"You pull out all the stops, Mr. Atkins."],[1451,1735,"Let's show those Sullivan idiots"],[1735,1893,"what fools they were"],[1906,2122,"to abandon someone like Ori."],[2248,2314,"Thanks for always"],[2314,2464,"having my back, Grandpa."],[2756,2836,"Yes."],[3098,3219,"Okay, I'll be right there."],[3349,3486,"Something came up, Ori."],[3520,3628,"I'm afraid."],[3678,3820,"I won't be able to attend the party,"],[3820,3958,"but how about this?"],[3958,4087,"I'll throw an after-party"],[4087,4241,"on my yacht later tonight."],[4471,4567,"Sounds great."],[4612,4750,"Your yacht parties are the best."]],"18":[[521,717,"Vicki just got into NYU."],[734,917,"She'll be the star of the show today,"],[917,1067,"I'm sure of it."],[1138,1393,"Dad, I can't thank you enough."],[1401,1593,"You spent so much on my education,"],[1593,1751,"and now I finally done something"],[1751,1901,"to make the family proud."],[1901,2118,"You give yourself a little credit also."],[2181,2293,"You studied hard,"],[2293,2544,"you stayed in school, stayed out of trouble,"],[2577,2727,"unlike that Oriana."],[2744,2873,"Now that she disowned us,"],[2873,3098,"she'll never taste success like this."],[3098,3224,"I'm so jealous."],[3240,3465,"Vicki is pretty and smart."],[3561,3720,"Well, it's only natural."],[3732,3858,"I'm a Morel Academy's"],[3858,4024,"Queen Bee, after all."],[4187,4379,"Hey, who's that girl?"],[4391,4567,"She's prettier than the Queen Bee."],[5985,6243,"Whoa, she's beautiful."],[6335,6431,"Oriana?"]],"19":[[855,1059,"That's Oriana? That nerdy girl?"],[1067,1121,"God."],[1121,1267,"She must have gotten makeover."],[1272,1401,"Well, at least she finally"],[1401,1539,"learned how to dress herself."],[1551,1668,"She'd always cramp my style"],[1668,1793,"every time we went out together."],[1810,1997,"She probably looks extra today"],[1997,2177,"because she regrets what she did."],[2189,2373,"She's here to apologize to us."],[2456,2631,"Oriana, over here."],[2773,2898,"Hey guys."],[2977,3194,"Oriana, why don't you come on over here,"],[3194,3353,"be a good girl and tell Vicki"],[3353,3495,"you're sorry for everything you did."],[4250,4354,"Congrats, girl."],[4354,4546,"Thank you, Amy."],[4587,4792,"And thanks for coming to my party."],[4909,4988,"Oriana."],[5134,5271,"I was just calling you, didn't hear me?"],[5309,5551,"Sorry, I must have had"],[5551,5676,"assholes set to mute."],[5730,5897,"You think you're so clever, huh."],[5960,6076,"What do you mean my party?"],[6076,6210,"This whole event"],[6210,6310,"is for Vicki."]],"20":[[150,271,"Yeah, this school planned"],[271,371,"this whole party"],[379,563,"to celebrate her getting into NYU,"],[588,863,"and where did you get into school, USI?"],[863,1138,"University of stupid idiots?"],[1626,1747,"And as Vicki's father,"],[1780,1868,"I'm sure I'll be asked"],[1868,1951,"to give a speech later."],[2006,2143,"I'll make sure everyone knows"],[2143,2302,"how proud I am,"],[2302,2444,"and not of you."],[3211,3386,"You guys seem pretty certain that"],[3386,3570,"Vicki got into the better school."],[3891,4016,"Hello, everyone."],[4029,4149,"I'd like to welcome each"],[4149,4250,"and every one of you"],[4250,4446,"to our college acceptance party."],[4767,4925,"Time to get this party started."],[4925,5092,"Oriana, it's just a matter of time"],[5092,5238,"before you have to face the truth."],[5321,5522,"Vicki is a real pride and joy"],[5522,5626,"of Morel Academy."],[5630,5709,"You,"],[5751,5943,"just a jealous underachiever."],[6097,6202,"We'll see about that."]],"21":[[0,212,"We are here today to celebrate"],[212,446,"the unprecedented achievement"],[446,679,"of one extraordinary student-"],[704,863,"someone who through their"],[863,1092,"hard work and perseverance,"],[1096,1184,"has been accepted"],[1184,1363,"into one of the toughest"],[1363,1505,"most competitive schools"],[1505,1659,"in the nation."],[2131,2243,"This student"],[2323,2585,"is the daughter of the most prestigious"],[2585,2719,"family in LA-"],[2723,2840,"the Sullivans!"],[2923,3119,"Please welcome them to the stage."],[3299,3420,"Congratulations, Vicki."],[3424,3595,"I'm so lucky to have a daughter like you."],[3928,4083,"Thanks so much, everyone."],[4083,4245,"Thank you all for being here."],[4283,4458,"But most importantly,"],[4458,4763,"I need to thank my No. 1 supporter,"],[4763,4846,"my dad."],[4896,4979,"Thank you, honey."],[5105,5184,"You know,"],[5238,5338,"as a father,"],[5397,5501,"the future of my children"],[5501,5643,"is my No. 1 priority."],[5663,5860,"So, when one of my kids succeeds,"],[5893,6085,"it's a success for the entire family."],[6164,6297,"But by the same token,"],[6393,6493,"when one of them goes down"],[6493,6606,"the wrong path"],[6660,6835,"biting the hand that feeds her,"],[6856,7023,"abandoning her own kin."],[7040,7190,"Well, that's an act of betrayal"],[7232,7424,"that I and the rest of the Sullivans"],[7424,7570,"will not forget."]],"22":[[0,171,"You're so cooked, Oriana."],[171,367,"Vicki blew you out of the water."],[367,646,"Good luck scrubbing all of those toilets."],[959,1113,"There's gonna be some mistake..."],[1126,1355,"I mean that should be you up there."],[1355,1539,"Your school makes NYU look like"],[1539,1668,"a community college."],[1739,1818,"Yeah, right."],[1818,1997,"Oriana's just brainwashing you."],[2010,2152,"Her school's probably ranked like"],[2152,2314,"2,000th in the country."],[2435,2556,"2,000th?"],[2677,2819,"Try first."],[3032,3274,"Wait, what's going on here?"],[3549,3724,"This is supposed to be a celebration"],[3724,3828,"for Oriana."],[3895,4104,"Shoot! Oriana and Vicki"],[4104,4229,"have the same last name."],[4229,4375,"I must have mixed them up."],[4412,4600,"My mistake, sorry."],[4617,4913,"Let's welcome Oriana to the stage!"],[6006,6072,"Move."],[6172,6281,"No way in hell"],[6289,6398,"your college is better than mine."],[6464,6635,"Display the offer letter."],[6927,7032,"Oriana has been"],[7032,7198,"accepted into Harvard!"],[7494,7686,"Oriana got into Harvard?"]],"23":[[0,166,"I don't believe it."],[166,283,"Trailer trash like you"],[283,467,"could never get into Harvard."],[550,654,"And why not?"],[721,900,"I volunteered at an orphanage."],[925,1063,"I organized a parade"],[1063,1234,"for environmental awareness,"],[1234,1430,"and I got a perfect score on my SAT."],[1463,1643,"I'm a model Harvard student."],[1643,1730,"And you?"],[1864,2039,"All you do is talk on"],[2039,2147,"and on about how much"],[2147,2260,"money you have."],[2293,2435,"Because money's all you got."],[2464,2631,"You're just a rich,"],[2644,2936,"basic bitch."],[3787,3991,"So, this is real?"],[4070,4200,"Oriana actually got"],[4200,4425,"into a better college than Vicki?"],[4612,4758,"Well, at the end of the day,"],[4758,4925,"Oriana is still a Sullivan."],[4967,5084,"And I am her father,"],[5130,5267,"so I'll go ahead with the speech..."],[5351,5580,"Yeah dad, just swap a few lines."],[5580,5730,"It's still a win for the Sullivan family."],[5868,5955,"Oriana,"],[5955,6131,"is there anything you'd like to say?"],[6460,6602,"I want to thank my family."],[6677,6852,"Without all of their love and support,"],[6852,7023,"I never would have made it this far."],[7123,7261,"And does Oriana's family"],[7261,7374,"have anything to add?"],[7482,7707,"Yes, ladies and gentlemen,"],[7707,7832,"I'd like to say this is"],[7832,7949,"the proudest moment of my..."],[8024,8224,"I wasn't talking about you."],[8320,8487,"I disowned you guys, remember?"],[8512,8633,"I'm still your father."],[8654,8775,"I'm still your brother."],[8871,9067,"So now you want to be my family?"],[9142,9334,"All you've ever done is side with Vicki"],[9334,9517,"and try to kick me out of the house."],[9613,9747,"Families are built on love"],[9747,9897,"and there's not a single iota"],[9897,10030,"of love between us."]],"24":[[0,100,"Ms. Swanson,"],[100,250,"my family can't make it today."],[250,412,"So we can just skip this part."],[450,567,"Yes, of course."],[613,813,"I'll have to kindly ask the two of you"],[813,996,"to return to your seats."],[1142,1351,"God, she's such a badass!"],[1376,1480,"They tried to kick Oriana"],[1480,1580,"out of the house."],[1597,1768,"The coolest girl in the school?"],[1772,1922,"The Sullivans can suck it."],[1922,2085,"Oh my god, see how"],[2085,2268,"embarrassed her dad looks?"],[2535,2640,"We had it all wrong."],[2694,2811,"Oriana's the real pride"],[2811,2919,"and joy of this family."],[3269,3395,"All that money I spent on your"],[3395,3557,"education, for what?"],[3574,3641,"So you could be"],[3641,3820,"one-upped by Oriana?"],[3832,3962,"You useless slacker,"],[3978,4141,"you humiliated this family."],[5075,5171,"Oh dear,"],[5213,5359,"trouble in paradise?"],[5522,5701,"Oriana, you're gonna pay for this."],[5839,5918,"Vicki,"],[6010,6189,"you're the one that's gonna pay."]],"25":[[196,329,"This is just the beginning."],[375,529,"Like I said, I'm taking back"],[529,729,"everything I ever gave you."],[800,950,"Easton's presidency,"],[1159,1326,"Sheldon's Design Award,"],[1359,1509,"Warren's football title."],[1601,1751,"Everything."],[1968,2089,"Stop acting so tough."],[2089,2198,"I'm not acting tough,"],[2198,2306,"Easton."],[2306,2435,"I mean business."],[2498,2615,"Is what happened to Vicki today"],[2615,2719,"not proof enough?"],[3499,3649,"So sure of yourself?"],[3657,3778,"Let's make a little bet."],[3862,3941,"You and me..."],[3999,4104,"You lose, Vicki."],[4154,4333,"It's time to keep your side of the bargain."],[4396,4579,"Wear granny panties in the cafeteria"],[4579,4713,"in front of everyone"],[4713,4833,"and give a speech"],[4833,4967,"about how awesome I am."],[5042,5121,"Oh,"],[5134,5296,"I need to put it on Instagram Story too."],[5359,5401,"No."],[5492,5597,"No."],[5651,5843,"So you want everyone to see"],[5860,5960,"that you're a coward"],[5960,6114,"who doesn't keep their word?"]],"26":[[166,321,"Get ready to be the laughingstock of"],[321,404,"Morel Academy."],[487,625,"Keep your word."],[642,800,"Keep your word."],[809,971,"Keep your word."],[980,1151,"Keep your word."],[1159,1305,"Keep your word."],[1313,1468,"Keep your word."],[1693,1951,"Oriana is the smartest"],[1951,2193,"coolest and prettiest girl"],[2193,2377,"at Morel High School."],[2406,2711,"She got into Harvard at 16,"],[2727,2831,"which is something I could"],[28