ng-ass bitch!"],[7545,7653,"You sure about that?"],[7741,7845,"All I know"],[7878,8091,"is that Vicki saved me from that fire,"],[8120,8179,"and Oriana"],[8179,8258,"keeps saying"],[8258,8383,"that it was her."],[8412,8475,"I'm not falling"],[8475,8604,"for her lies."],[8616,8746,"I have one sister"],[8746,8900,"and her name is Vicki."]],"42":[[350,450,"I'll be honest,"],[450,550,"when you said you wanted to"],[550,617,"celebrate me"],[617,738,"winning the election."],[784,896,"I didn't expect"],[896,1021,"us to play golf."],[1059,1163,"I just figured a party"],[1163,1255,"might attract"],[1255,1355,"too much attention."],[1355,1418,"And"],[1418,1501,"on the other hand,"],[1501,1572,"golf,"],[1584,1659,"is"],[1697,1856,"nice and lowkey."],[2143,2210,"There we go."],[2248,2385,"There we go now."],[2439,2510,"All right look."],[2623,2719,"The grip"],[2719,2786,"has to be nice"],[2786,2902,"and loose,"],[2902,2982,"don't beat your tee."],[3244,3303,"Ori,"],[3440,3503,"hey, I..."],[3532,3591,"baked you"],[3591,3670,"a strawberry shortcake."],[3816,4004,"I know it's kind of falling apart but,"],[4062,4204,"it's the thought that counts, right?"],[4683,4704,"look,"],[4704,4738,"I'm"],[4750,4821,"sorry for"],[4821,4900,"how I've been acting."],[4971,5042,"I want to make it up to you."],[5096,5205,"Strawberry shortcake"],[5205,5321,"is Vicki's favorite dessert."],[5376,5397,"Plus,"],[5397,5534,"I'm allergic to strawberries."],[5534,5689,"Are you trying to poison me?"],[5914,5993,"Sorry,"],[6110,6185,"I don't know how I forgot."],[6239,6348,"I'll make you something else."],[6610,6681,"Oriana,"],[6748,6819,"Easton baked"],[6819,6873,"you a cake"],[6873,6927,"and you don't even"],[6927,7023,"say thank you."],[7157,7248,"I don't owe a"],[7248,7499,"thank you to any of you for anything."],[7549,7674,"Security,"],[7674,7782,"get these uninvited"],[7782,7907,"guests out of here!"],[8008,8078,"This is student"],[8078,8187,"council office,"],[8375,8429,"not a men's"],[8429,8495,"lock