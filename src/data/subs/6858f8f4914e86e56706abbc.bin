and"],[1981,2168,"dollar allowance every month"],[2173,2389,"while Oriana can't even take snacks"],[2389,2485,"from the pantry?"],[2527,2761,"Warren, don't fall for this."],[2794,2986,"Oriana must be spreading lies"],[2986,3190,"to sow discourse among us."],[3265,3365,"Can't you see?"],[3365,3411,"She's trying to"],[3411,3520,"tear us apart!"],[3616,3716,"No, dad,"],[3749,3924,"that's not it at all."],[3962,4108,"Not only is Oriana your daughter,"],[4108,4262,"but she's our sister."],[4262,4475,"She's been looking out for us 24/7"],[4475,4579,"all of these years."],[4642,4854,"We're clearly in the wrong here."],[4996,5080,"I'm with Easton."],[5146,5209,"We failed to see"],[5209,5372,"Oriana for who she truly is,"],[5417,5580,"and now it's too late."],[5905,6047,"Those damn boys!"],[6106,6231,"Talking back to me?"],[6268,6435,"This isn't how I raised them!"],[6498,6644,"They don't love me anymore."],[6719,6890,"Sheldon, you still love me, right?"],[6911,7007,"You trust me?"],[7077,7261,"Promise you won't get duped like"],[7261,7461,"our stupid brothers by Oriana."],[7494,7640,"That will never happen, Vicki."],[7640,7903,"You'll always be my one and only sister."],[8608,8712,"We need to talk."]],"56":[[95,229,"You're always talking about"],[229,379,"how I only won my design award"],[404,504,"thanks to you."],[529,696,"Let's see how special you really are."],[696,846,"Compete against me in this year's"],[846,1017,"Morel Academy Design Competition."],[1076,1301,"Sure, why not?"],[1301,1497,"Don't look so sure of yourself."],[1530,1647,"If I lose,"],[1647,1856,"which I won't,"],[1881,2014,"you can punish me however you like."],[2052,2156,"But if I win,"],[2198,2323,"you have to apologize to Vicki"],[2323,2469,"in front of the whole school."],[2727,2806,"Deal."],[3190,3311,"I have to use the bathroom."],[3737,4029,"Mom, I hate Oriana so much it hurts."],[4029,4291,"She literally took everything from me!"],[4291,4437,"Then let's take her out,"],[4437,4617,"wipe her right off the map."],[4725,4879,"Just how I took out her mother"],[4879,5100,"by injecting her with HIV virus."],[5201,5288,"What?"],[5388,5559,"Kimberley killed my mom?"],[5864,5947,"Who's there?"],[6031,6243,"Someone's spying on us, go get them!"]],"57":[[187,241,"Hunter!"],[496,533,"Hunter,"],[633,725,"someone's chasing me."],[1564,1680,"Sorry about this."],[3253,3374,"The hell are you looking at?"],[3440,3474,"Oh!"],[3474,3541,"My bad."],[4992,5071,"Kimberley,"],[5292,5422,"she murdered my mother."],[5734,5930,"I have to find a way to prove she's guilty."],[6473,6577,"Let me help you."],[6706,6877,"This is a murderer you're dealing with."],[6936,7061,"We have to be careful."],[7119,7336,"I know a top notch private investigator."],[7603,7686,"Thanks, Hunter."],[7791,7912,"It's nice having you around."],[8383,8462,"Oriana,"],[8608,8721,"I really like you."],[8879,9054,"I don't ever want to leave your side,"],[9109,9288,"no matter what happens to us."]],"58":[[934,1159,"That's just not gonna get it done."],[1939,2181,"Now this is what I'm looking for!"],[2494,2719,"The winner of the 45th Annual"],[2719,2990,"Morel Academy Design Awards is..."],[3290,3449,"Oriana Sullivan!"],[3495,3732,"Let's welcome her up to the stage!"],[4521,4625,"Oriana won?"],[4650,4825,"How the fuck does she keep doing that?"],[4934,5080,"My inspiration for this design"],[5080,5292,"came on one chilly autumn day."],[5351,5463,"I was going for a walk and"],[5463,5709,"I saw the beautiful leaves falling-"],[5709,5772,"No!"],[5772,5935,"I reject the judge's decision!"],[5968,6172,"My design is easily better than hers!"],[6373,6539,"Your design is too safe,"],[6556,6644,"too plain."],[6752,6965,"Oriana is a true artist,"],[6965,7236,"a future trailblazer in the design world."],[7278,7361,"To be honest,"],[7361,7511,"after your performance today,"],[7532,7711,"I wonder how you ever managed to win"],[7711,7882,"any of those awards before."],[8929,9034,"You lost."],[9084,9184,"Now hand over the document"],[9184,9292,"I was asking for."],[10356,10531,"Sheldon’s design fucking blows."],[10568,10660,"Did he plagiarize other"],[10660,10789,"designers to win those awards"],[10789,10852,"or something?"],[10881,10960,"I know right?"],[10960,11077,"I feel like such an idiot for"],[11077,11186,"rooting for him today."],[11549,11653,"It all makes sense now."],[11699,11807,"Those awards I won."],[11853,12028,"It was all because of Oriana."]],"59":[[16,75,"Sheldon,"],[87,233,"you can't cave to that bitch!"],[258,400,"She must have bribed the judge."],[400,483,"You were supposed to win."],[1242,1292,"Easton,"],[1330,1468,"I need to see Oriana's diary."],[1972,2068,"I just want Sheldon to be"],[2068,2198,"able to do what he loves."],[2268,2364,"He might not be the most"],[2364,2481,"gifted jewelry designer,"],[2515,2635,"but if he wins some awards,"],[2665,2811,"maybe he can make a career out of it."],[2840,2969,"There has to be a way for me to"],[2969,3115,"help him without hurting his ego."],[3390,3545,"How could I be such a fool!"],[3770,3941,"Ori’s bear toy was her favorite"],[3941,4037,"when she was growing up,"],[4124,4262,"but Vicki bullied her into leaving"],[4262,4308,"it behind,"],[4329,4446,"dusty and dirty."],[4533,4717,"But I finally found the online supplier"],[4750,4867,"that sells the material"],[4867,4971,"to make it shine."],[5017,5188,"Soon the bear will look like new!"],[5392,5451,"I can help,"],[5472,5538,"I can help too!"],[5563,5643,"I can paint it blue."],[5643,5730,"It's her favorite color."],[5776,5893,"Guys we're gonna make this right."],[5893,6022,"We're gonna be a family again."]],"60":[[300,437,"What the hell are we doing here anyway."],[525,684,"Come on guys this is her favorite store,"],[684,779,"of course she's gonna come."],[859,1046,"It's gonna be all right."],[1130,1201,"It’ll work out."],[1676,1739,"There she is."],[1926,2006,"All right guys,"],[2035,2110,"big moment."],[2527,2569,"Ori!"],[2731,2827,"Tell them to leave."],[3190,3228,"Ori,"],[3236,3332,"you remember your favorite toy"],[3332,3411,"from when you were little?"],[3586,3724,"The one you left behind because"],[3782,3891,"we were being ungrateful?"],[4016,4049,"Well,"],[4083,4175,"we brought it back for you."],[4412,4600,"It's specially polished,"],[4625,4704,"just like new."],[4746,4929,"Ori, please just come home."],[5005,5067,"We don't just want to"],[5067,5171,"give you a new bear."],[5217,5372,"We want to give you a new life."],[5451,5684,"A life fit for the best sister in the world."],[7545,7695,"I wish you were never my sister."],[7716,7995,"I'm embarrassed to share the same DNA."],[8003,8170,"You disgust me, Oriana."],[8179,8295,"Go back to your trailer park"],[8295,8391,"and rot there."],[8637,8721,"It's too late."],[8913,9092,"The girl you used to have as a sister?"],[9163,9246,"She's dead."],[9584,9801,"You killed her with your bare hands!"],[10431,10510,"No!"],[12404,12541,"It's all our fault."],[12691,12871,"It's all our fault."],[12883,12987,"Why?"],[13784,13884,"Why! Oriana!"]],"61":[[1180,1276,"Who did this?"],[2364,2510,"What are you doing,Vicki?"],[2548,2623,"What,"],[2640,2852,"don't sluts like taking their clothes off?"],[2911,3153,"We all know you slept with Mr. Morel"],[3174,3345,"so that he’d tell the judge"],[3345,3541,"to let you into the design competition."],[3553,3678,"Now the whole world sees you as"],[3678,3791,"the gold digger you are!"],[3791,3933,"Oriana, you're sick."],[3941,4112,"Mr. Morel is almost 80."],[4129,4258,"You'd really fuck anything with"],[4258,4425,"a pulse just to get ahead."],[4466,4579,"When the whole school finds"],[4579,4792,"out that student council president"],[4817,5038,"is just a little dirty sugar baby,"],[5055,5184,"they'll have you impeached!"],[5201,5276,"Holy shit,"],[5276,5522,"she banged Murray Morel?"],[5701,5759,"Hold her down."],[6902,7040,"God damn it, Vicki!"],[7582,7757,"You'll be expelled for this,Vicki!"],[7991,8037,"Vicki,"],[8091,8187,"did you not get the memo?"],[8254,8304,"We don't bully"],[8304,8383,"Oriana anymore."],[9534,9726,"Warren, are you crazy?"],[9747,9864,"I'm your sister!"],[9884,9947,"No, you're not."],[10105,10222,"I only have one sister,"],[10268,10385,"and her name is Oriana."],[10456,10660,"Let me set the record straight, Vicki."],[10719,10940,"Murray Morel is not my sugar daddy,"],[11006,11165,"he's my grandfather."],[11248,11473,"And this is the last time you'll ever"],[11473,11549,"bully me."]],"62":[[25,191,"Still sticking to that story, huh?"],[221,283,"Attention."],[325,496,"All students of Morel Academy,"],[521,588,"please come to"],[588,763,"the auditorium in 5 minutes."],[784,938,"We'll be holding an assembly"],[938,1105,"to thank one of our donors"],[1105,1276,"for his generous new gift."],[1372,1430,"Oh."],[1459,1622,"That must be my dad."],[1651,1805,"He said he was donating"],[1805,1964,"some computers to the new lab."],[2039,2248,"It's not your loser of a dad."],[2285,2352,"You'll see soon"],[2352,2473,"who the real donor is."],[2656,2748,"This morning,"],[2773,2936,"our most cherished donor"],[2973,3103,"announced funding for"],[3103,3294,"three new projects"],[3294,3457,"starting with construction"],[3478,3666,"of a brand new library,"],[3732,3924,"a science technology building,"],[3962,4200,"a multimedia art center."],[4212,4362,"Let me introduce to you,"],[4387,4654,"the founder of the Morel Academy."],[4700,4963,"Mr. Murray Morel!"],[5889,5972,"Thank you."],[5997,6327,"I'm humbled by your support."],[6427,6502,"However,"],[6569,6677,"there's one more person"],[6677,6865,"we need to thank for this donation."],[6956,7077,"My granddaughter,"],[7077,7148,"Oriana."],[7228,7273,"Ori."],[8220,8475,"Ori has made a mark here"],[8516,8721,"with her strong leadership skills"],[8721,8888,"and academic prowess."],[8954,9079,"She was recently elected"],[9079,9230,"president of the student council"],[9230,9384,"and not long before that,"],[9405,9651,"she was accepted into"],[9651,9838,"Harvard University."],[9922,10176,"I have decided to dedicate"],[10201,10339,"these three new buildings"],[10339,10468,"at Morel Academy"],[10468,10648,"in her honor."],[10760,10835,"In the hope that"],[10860,10960,"all of you"],[11081,11282,"will be as successful as Oriana."],[11770,11874,"She’s really"],[11874,12028,"Mr. Morel’s granddaughter?"]],"63":[[20,125,"She’s really"],[125,279,"Mr. Morel’s granddaughter?"],[291,437,"I'd like to take this moment"],[504,646,"to clear up some rumors."],[750,917,"I adopted Oriana"],[967,1134,"when her biological family"],[1134,1338,"abandoned her as a young girl."],[1455,1643,"She may not be Morel by blood,"],[1701,1906,"but she is the perfect"],[1926,2018,"successor"],[2052,2210,"for the business empire that I've built."],[2306,2590,"I plan to give Oriana my fortune"],[2627,2752,"and hand over the reins"],[2752,2944,"of my company to her."],[3561,3716,"That explains those pictures!"],[3766,3903,"We had it all wrong."],[3920,4120,"I told you she wasn't a gold digger!"],[4266,4408,"This right here"],[4408,4525,"is evidence"],[4525,4675,"of Vicki's smear"],[4675,4800,"campaign against me."],[5451,5547,"Vicki Sullivan,"],[5563,5680,"you're expelled!"],[5814,6010,"You think you can destroy her future?"],[6026,6139,"Don't be so naive."],[6177,6281,"I'm just going to send her to"],[6281,6410,"another elite private school."],[6443,6564,"With the type of money we have,"],[6564,6694,"Vicki's invincible."],[6748,6861,"Watch this."],[6969,7040,"Then we can talk."],[7937,8120,"This is HIV virus."],[8266,8404,"You're done,Bianca."],[8579,8754,"And once you kick the bucket,"],[8858,9046,"I'll be the new Mrs. Sullivan."],[9505,9555,"Wait,"],[9605,9797,"so Kimberley gave her AIDS?"],[9830,9972,"She never cheated on me?"],[10110,10306,"Kimberley killed mom?"]],"64":[[784,855,"What?"],[905,967,"Mom!"],[992,1113,"Dad knows the truth!"],[1142,1305,"He knows what you did to Bianca!"],[1384,1459,"Fuck!"],[1514,1605,"Where are you?"],[1685,1768,"We have to go."],[1797,1872,"Now!"],[1897,2043,"I'll be home in five minutes!"],[3286,3370,"You killed her,"],[3386,3499,"you killed Bianca!"],[3541,3611,"Honey,"],[3620,3762,"she cheated on you!"],[3799,3970,"She fucked some guy with AIDS"],[3970,4091,"and got what she deserved!"],[4091,4141,"No!"],[4154,4229,"No more lies!"],[4229,4375,"The police are already on their way,"],[4391,4508,"and you're going to get arrested"],[4508,4617,"for murder!"],[4617,4746,"I was a failure as a husband,"],[4767,4925,"and I was a failure as a father."],[5593,5743,"You miss your Bianca?"],[5776,5935,"Then go see her in hell!"],[6135,6214,"Vicki."],[7319,7378,"Dad?"],[7403,7536,"You're not my fucking dad."],[7603,7786,"I hope you die a slow painful death,"],[7811,7949,"right here in your own home."],[7999,8274,"This is enough to keep us rich forever."],[8316,8441,"Now let's get out of here!"],[9213,9246,"Officer,"],[9284,9321,"that's her."],[9772,9830,"Vicki!"],[9876,9934,"Go!"],[10898,10948,"Sir,"],[10990,11111,"you need to catch that girl!"]],"65":[[58,191,"Ladies and gentlemen,"],[246,442,"the moment you've all been waiting for,"],[492,713,"the announcement of the prom"],[721,821,"King and Queen!"],[1017,1121,"The Prom King,"],[1121,1234,"he's a star"],[1234,1397,"of the Morel football team,"],[1397,1530,"who just brought us back"],[1530,1735,"another state championship."],[1743,1830,"Ladies and gentlemen,"],[1830,1960,"I introduce to you,"],[1960,2131,"Hunter Hawkins!"],[2131,2231,"Yeah!"],[3299,3411,"Thank you, Thank you."],[3449,3566,"I'd just like to say,"],[3599,3728,"I would not be standing here"],[3728,3903,"right now if it wasn't for..."],[4279,4454,"a very special person."],[4679,4783,"And next,"],[4817,4967,"our beautiful Prom Queen."]],"66":[[8,95,"Our beautiful"],[95,187,"Prom Queen,"],[237,508,"the extraordinary Oriana Morel!"],[1067,1146,"Oriana"],[1209,1334,"is our beloved"],[1351,1547,"student council president,"],[1601,1776,"our fearless bully fighter,"],[1835,2064,"our founder of the scholarship fund,"],[2102,2239,"and last but not least,"],[2256,2444,"soon to be a Harvard alumni."],[2469,2736,"She is a model of excellence"],[2736,3028,"that we should all aspire to emulate."],[3962,4062,"Thanks everyone."],[4266,4346,"A few years ago,"],[4346,4475,"I was so focused"],[4475,4612,"on helping out my brothers,"],[4671,4909,"that I forgot to take care of myself."],[5055,5192,"So if I can pass off one"],[5192,5313,"piece of wisdom to you"],[5313,5438,"before I graduate,"],[5505,5743,"it's to always practice self-care"],[5776,5897,"and self-kindness."],[5976,6202,"None of you are losers,"],[6227,6310,"failures,"],[6310,6510,"or so-called trailer trash."],[6589,6698,"You're all winners,"],[6752,6911,"and you deserve to be the heroes"],[6911,7032,"of your own stories."],[7123,7182,"So,"],[7273,7432,"go out there and live your best lives!"],[8153,8850,"Ori! Ori! Ori!"],[9184,9359,"Oriana, Oriana,"],[9384,9480,"Oriana."],[9496,9705,"It's always fucking Oriana."],[9809,9918,"Guess what."],[9959,10076,"Not anymore."],[10923,10985,"Ori, no!"]],"67":[[454,496,"Oriana!"],[1192,1297,"Easton! Easton!"],[1497,1551,"Easton!"],[1639,1760,"I was trying to kill her!"],[1768,1951,"Somebody hold her back now!"],[1951,2156,"Oriana, you evil bitch!"],[2164,2239,"You're wrong."],[2260,2364,"You are trailer trash"],[2364,2431,"still."],[2444,2606,"I'm the only winner in this family!"],[2690,2798,"I'm going to Harvard,"],[2798,2940,"and you're going to rot in jail for"],[2940,3036,"the rest of your life."],[3036,3178,"Who's the real villain here?"],[3199,3286,"Jail?"],[3299,3374,"No."],[3420,3445,"No."],[3445,3570,"I can't go to jail!"],[3649,3691,"You,"],[3691,3841,"you took everything from me."],[3841,4049,"My property title, Harvard,"],[4074,4291,"my brother's support, my family fortune!"],[4320,4483,"It was all supposed to be mine!"],[4696,4758,"You okay?"],[4896,4950,"It hurts."],[5292,5372,"Is Oriana okay?"],[5372,5442,"What do we do?"],[6765,6815,"Ori."],[6977,7057,"Please, just"],[7115,7190,"tell us what we can do to"],[7190,7294,"make you forgive us."]],"68":[[12,75,"It's been"],[100,237,"hard lately, Ori."],[350,412,"Dad died."],[492,642,"We lost our fortune,"],[642,754,"we’re barely getting by."],[763,850,"And who was it"],[867,955,"that killed your dad,"],[955,1076,"and ran off with your money."],[1267,1518,"Wasn't it your darling stepsister Vicki?"],[1576,1668,"And your beloved"],[1668,1772,"stepmother Kimberley?"],[1922,1981,"It's not my fault"],[1981,2110,"you didn't kick them out sooner."],[2139,2277,"Ori, I know a lot's happened recently"],[2277,2389,"but you're still a Sullivan."],[2423,2515,"No, I'm not."],[2648,2744,"I'm a Morel now,"],[2869,3094,"and I want nothing to do with you three."],[3132,3199,"Ori."],[3269,3453,"You can change your last name,"],[3524,3749,"but family is family forever."],[3774,3883,"That's not true."],[4074,4195,"The Oriana Sullivan"],[4195,4291,"you once knew,"],[4291,4387,"is gone."],[4496,4875,"She was tortured and killed by her family!"],[4942,5059,"The girl you see now,"],[5167,5334,"is Oriana Morel."],[5430,5618,"And unlike you Sullivans,"],[5709,5805,"the Morel family"],[5805,5951,"will always have her back,"],[6010,6135,"and will protect her"],[6147,6181,"from"],[6239,6322,"any harm."],[7728,7845,"Today is my first day back"],[7845,7957,"with my real family."],[8078,8204,"It's so great to finally"],[8204,8366,"be reunited with my brothers."],[8433,8596,"They're all so funny and nice."],[8616,8775,"They're like my Guardian angels."],[8858,8913,"Mommy,"],[8925,9042,"I promise I'll take good"],[9042,9150,"care of them like you asked."],[9209,9388,"I love my brothers so much."]]}