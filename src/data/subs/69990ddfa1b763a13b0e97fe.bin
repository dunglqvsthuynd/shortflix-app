{"1":[[185,371,"My name is Isaac Kane."],[371,542,"I was put on this earth"],[542,696,"to punish the wicked."],[813,892,"I was the nightmare"],[892,1080,"every gangster dreamt about."],[1080,1176,"The monster"],[1176,1343,"underneath their beds."],[1343,1434,"Russian mobsters"],[1434,1568,"called me the Chernobog,"],[1568,1793,"after their black god of death."],[1793,1931,"To them, I was a demon,"],[1931,2085,"sent to earth to drag them back"],[2085,2198,"down to hell."],[2235,2331,"Untouchable."],[2410,2494,"Unkillable."],[2644,2790,"But I had one weakness,"],[2844,2944,"my family."],[3269,3390,"Mya, I got the diapers,"],[3390,3465,"but they didn't have-"],[3674,3732,"Mya?"],[3916,4020,"Hey, hey!"],[4020,4087,"What, what the hell?"],[4087,4124,"What happened?"],[4124,4220,"Who did this to you?"],[4237,4429,"The Russians came for you."],[4441,4496,"No."],[4550,4596,"No."],[4596,4750,"But I protected our baby girl."],[4821,4971,"I did everything you taught me."],[4971,5042,"Hey, hey, hey."],[5042,5138,"Don't speak, okay?"],[5146,5259,"Everything's gonna be fine, alright?"],[5259,5409,"I'm, I'm gonna get you some help, okay?"],[5409,5538,"I'm not gonna make it, honey."],[5638,5734,"But promise me,"],[5809,5893,"promise me that"],[5930,6051,"you'll keep Natalie safe,"],[6131,6252,"away from all the blood,"],[6318,6439,"from your killings,"],[6556,6644,"your enemies."],[6690,6806,"This is all my fault."],[6856,7098,"Natalie needs you to be a father,"],[7182,7261,"not a killer."],[7319,7503,"I'm so sorry I can't be here."],[7595,7711,"No, don't say that."],[7774,7874,"Swear to me"],[7903,8058,"you'll never pick up a gun again."],[8137,8220,"Swear to me"],[8266,8491,"that you'll never kill again."],[8704,8792,"Swear it."],[8837,8904,"Swear it."],[8971,9059,"Honey, I swear."],[9146,9192,"I swear."],[9192,9242,"Hey, hey."],[9242,9363,"I'll, I'll never kill again."],[9430,9488,"Mya, Mya,"],[9488,9613,"I'll never pick up a gun again,"],[9613,9734,"but you gotta stay with me"],[9734,9797,"please."],[9880,9922,"Mya, hey,"],[9922,10035,"we, we can move away."],[10035,10172,"We can be a normal family."],[10214,10322,"Mya, please."],[10322,10468,"Please, Mya, come on."],[10543,10777,"Oh God."],[10894,10998,"I swear, Mya."],[11106,11227,"I won't kill anymore."],[11336,11423,"I swear it."]],"2":[[725,779,"Hey!"],[900,1005,"This ain't a hotel."],[1063,1142,"No sleeping."],[1251,1418,"Hey, you deaf?"],[1551,1697,"Get your bum ass out of here."],[2882,3094,"Hey, there's no homeless camping"],[3094,3165,"out in this-"],[3257,3307,"Oh."],[3357,3420,"Hey, neighbor."],[3503,3607,"You look like shit."],[4404,4496,"Another bender?"],[4567,4633,"I'm fine."],[4713,4788,"Dad, you've been drunk"],[4788,4863,"every single day,"],[4863,4963,"since the day Mom died"],[4963,5092,"eighteen years ago."],[5176,5313,"Eighteen years."],[5401,5572,"Sometimes I thought it sucked"],[5572,5680,"to grow up without a mom."],[5739,5893,"But you know what really sucks?"],[5951,6068,"I didn't have a dad either."],[6076,6156,"Natalie-"],[6481,6589,"I'm right here."],[6635,6706,"Sometimes I wish"],[6706,6815,"you were the one who died."],[7169,7298,"Natalie, where are you going?"],[7298,7407,"It'll be dark soon."],[7461,7674,"Like you care!"],[7757,7862,"I'm sorry."],[8041,8216,"Look it isn't safe for you out there."],[8266,8333,"Natalie!"],[9192,9305,"I wish that I were the one"],[9305,9380,"who died too,"],[9380,9446,"Natalie."],[9613,9713,"Should've been me."],[9926,10172,"Natalie needs you to be a father."],[10764,10827,"Natalie?"],[10869,10927,"Hey."],[10948,11031,"Daddy, help!"],[11031,11169,"I'm so scared!"]],"3":[[29,145,"I'm so sorry,"],[175,287,"I messed up and I-"],[308,408,"I went to this club"],[408,554,"and they, they're chasing me!"],[554,717,"Natalie, I need you to listen to me"],[717,804,"very carefully."],[829,938,"Your pupils are dilated"],[938,1005,"and you're slurring."],[1005,1109,"I need you to tell me exactly"],[1109,1172,"where you are."],[1326,1376,"Natalie!"],[1376,1430,"Natalie!"],[1455,1543,"Daddy!"],[1564,1685,"Oh, little puppy."],[1705,1889,"You'll never see your daddy again."],[1931,2143,"She belongs to the Russian mob now."],[3094,3319,"You can't just keep apologizing"],[3319,3524,"and not do shit better."],[3720,3803,"Daddy, help!"],[3803,3941,"I'm so scared!"],[4304,4366,"Sometimes I wish"],[4366,4479,"you were the one who died."],[4950,5005,"Boss,"],[5005,5138,"we have a new shipment of women"],[5138,5217,"coming in soon."],[5505,5613,"You'll sell for a lot."],[5622,5784,"You, you can't do this."],[5809,5935,"You can't just keep us in-"],[6022,6172,"I can do whatever I want."],[6352,6473,"No one can stop me."],[6519,6614,"That's not true."],[6673,6785,"There is one who could."],[6915,7011,"The Chernobog."],[7019,7257,"The Chernobog is gone, old bitch."],[7419,7532,"He will return."],[7561,7678,"He will save us."],[10143,10218,"Natalie's last"],[10218,10402,"known location was this club."],[10702,10839,"Looks like you've had a rough night."],[10898,10977,"Time to go home."],[11257,11428,"You don't belong here."],[11490,11582,"I agree."],[11736,11836,"The women have already"],[11836,11999,"been taken off to the dungeons."],[11999,12112,"Time to load up the men."],[12128,12208,"Bring them in."],[12262,12458,"Natalie's probably in those dungeons,"],[12495,12579,"which means..."],[13325,13446,"Hurry up, dickbag."],[13780,13855,"I could take that"],[13855,13997,"and end this, right now."],[14022,14105,"Swear to me"],[14176,14347,"you'll never pick up a gun again."],[14635,14698,"Yes sir."],[14785,14843,"Sorry."]],"4":[[171,283,"Where, where am I?"],[375,425,"One moment"],[425,642,"I was feeding pigeons in the park,"],[679,796,"and the next moment"],[796,892,"I wake up here."],[1584,1664,"Is this..."],[1705,1860,"Are they human trafficking?"],[1901,2064,"Then what am I doing here?"],[2072,2239,"I'm of no use to anybody."],[2260,2373,"But your organs are."],[2410,2552,"They'll cut this old man open"],[2552,2702,"and sell him on the black market,"],[2752,2848,"piece by piece."],[2861,2932,"What's your name?"],[2969,3165,"Walter, Walter Smithers."],[3186,3328,"I didn't do anything wrong."],[3328,3532,"I was just feeding some pigeons."],[3532,3712,"Can you keep your head down, Walter?"],[3757,3862,"I'm gonna get you out of here."],[3870,3974,"No offense, son,"],[4033,4112,"but I don't think"],[4112,4216,"you're in any condition"],[4216,4379,"to get anybody out of here."],[4508,4554,"Where do they keep"],[4554,4658,"the women prisoners?"],[5559,5651,"Hey, hey, please."],[5655,5780,"I was supposed to be at home."],[5797,5901,"My parents are waiting."],[5910,6018,"You have to let me go."],[6243,6373,"We don't have to do shit."],[7107,7228,"You'll only get yourself killed."]],"5":[[0,204,"If you disrespect your masters,"],[233,325,"well..."],[529,725,"Stop that now!"],[1163,1355,"I tried to warn him."],[1355,1418,"Brave."],[1522,1614,"What's your name?"],[1639,1926,"My, my name is Walter Smithers."],[1931,2097,"Okay, Walter Smithers,"],[2097,2243,"and why are you here?"],[2273,2348,"I don't know."],[2373,2573,"I was just feeding some pigeons."],[2635,2773,"You were feeding pigeons?"],[2781,2836,"Yes."],[3261,3457,"Your name is number 42."],[3490,3545,"You are here"],[3545,3691,"because you are my property."],[3716,3853,"42, I'll ask again."],[3903,3999,"Why are you here?"],[4049,4237,"Because I'm your property."],[4283,4425,"Please don't-"],[4637,4896,"42, property cannot make requests."],[4921,5096,"Don't get involved."],[5117,5271,"You need to find your daughter."],[5292,5417,"That's what's important."],[5422,5689,"42, I want you to stop crying."],[5897,5968,"42."],[6122,6243,"Walter."],[6272,6410,"If you don't stop crying,"],[6431,6552,"I'm going to smash your head"],[6552,6702,"like a soft boiled egg."],[6886,6940,"Now,"],[7036,7119,"last chance."]],"6":[[0,145,"He's just an old man."],[183,354,"You're here for Natalie."],[583,671,"Leave him alone!"],[734,834,"He didn't do anything."],[959,1138,"And what is your name, brave boy?"],[1518,1601,"My name is-"],[1901,1951,"You."],[2031,2135,"What was your name again?"],[2193,2273,"42."],[2273,2427,"Right, good boy."],[2489,2765,"42, what did I say about crying?"],[2957,3090,"He leaves me no choice."],[3699,3845,"Ask me what my name is."]],"7":[[45,120,"I said,"],[158,375,"ask me what my name is."],[462,542,"What an idiot."],[588,734,"He's going to kill that dumbass."],[738,900,"Dead bodies don't have names."],[1313,1388,"Swear to me"],[1468,1589,"that you'll never kill again."],[2323,2515,"There's no need for dead bodies."],[2556,2681,"You took my daughter today."],[2727,2777,"Give me her"],[2777,2865,"along with the old man,"],[2865,2940,"and I'll leave."],[2969,3053,"No one dies."],[3178,3257,"The slave"],[3257,3440,"that reeks of cheap whiskey,"],[3461,3641,"gonna try to make some demand?"],[3649,3782,"Run away slave,"],[3828,3966,"back to whatever gutter"],[3966,4087,"you crawled out of,"],[4124,4291,"before we rip out your throat."],[4291,4350,"Please."],[4379,4592,"He, he was just sticking up for me."],[4629,4725,"Let him go."],[5084,5167,"Old 42,"],[5167,5313,"I haven't forgotten about you."],[5380,5451,"You're next."],[5605,5680,"And as for you,"],[5784,5864,"you are nothing,"],[5922,6039,"you are less than nothing."],[6185,6281,"Look at those eyes."],[6352,6544,"You really want to kill me, don't you?"],[6610,6677,"Too bad."],[6777,6869,"You will never get the chance."],[6869,6961,"I don't have to."],[7027,7190,"When your boss, Vasile Ivanovich"],[7190,7332,"finds out you spat in my face,"],[7332,7457,"he's gonna kill you himself."],[7478,7611,"How does this low-life"],[7611,7749,"know Vasile?"]],"8":[[83,241,"How this bum know Vasile?"],[262,342,"It doesn't matter."],[450,546,"He's already dead."],[1284,1363,"The only thing"],[1363,1509,"keeping you alive right now"],[1551,1643,"is a promise"],[1655,1785,"that I made to my wife."],[1931,2002,"Get him!"],[3324,3403,"Swear to me"],[3440,3682,"that you'll never kill again."],[3891,3966,"Swear it."],[4037,4079,"I swear."],[4079,4129,"Hey, hey."],[4129,4250,"I'll, I'll never kill again."],[4512,4667,"Stupid move, dumbass."],[4729,4796,"Pussy."],[5176,5292,"Do it, you coward."],[5476,5609,"Just give me my daughter"],[5630,5701,"and I'll leave."],[6573,6669,"I told you"],[6710,6881,"that you didn't belong here."]],"9":[[141,246,"Look at you."],[304,500,"Disgusting waste of flesh."],[571,692,"You, come here."],[934,1113,"At least this meat is good enough"],[1113,1226,"to sell for sex."],[1438,1501,"But you,"],[1580,1768,"you're a dried up impotent drunk."],[1793,1935,"We're going to kill you,"],[1968,2189,"cut you open and sell your organs."],[2243,2419,"Alex, pick up whatever's left"],[2419,2519,"of your shriveled manhood"],[2519,2644,"and break this bastard."],[2656,2773,"I don't like to be talked to"],[2773,2840,"in that manner."],[2840,2986,"And I don't give a fuck."],[3028,3215,"Do what your superior says."],[3244,3311,"Break him."],[3524,3595,"Ah, ah, ah."],[3632,3695,"Fight back,"],[3707,3812,"I shoot you in the head."],[4450,4608,"Not such a big guy now,"],[4608,4667,"are you?"],[4900,4979,"Last chance."],[5071,5267,"Give me my daughter back."]],"10":[[133,325,"Listen to this piece of shit."],[367,437,"Last chance."],[437,588,"Give me my daughter back?"],[596,767,"You don't make the rules,"],[767,900,"you worthless little bitch!"],[1159,1463,"You are nothing compared to me."],[1605,1676,"See this?"],[1822,1939,"In our world,"],[1939,2089,"you get one of these tattoos"],[2089,2352,"for each man you kill."],[2394,2523,"You think you're a big man?"],[2565,2794,"You're nothing but my next tattoo."],[2811,2923,"Yeah, I don't think so."],[3003,3082,"Still."],[3144,3257,"He keeps going."],[3499,3595,"After we kill you,"],[3624,3887,"I'm going to kill the old man badly."]],"11":[[0,75,"It would only take me"],[75,233,"five seconds to kill them all."],[233,437,"Then, I'm going to find your daughter."],[458,663,"And when she cries out in pain"],[663,846,"and maybe a little pleasure,"],[875,1101,"and ask why this is happening to her,"],[1121,1343,"I will tell her it was because her daddy"],[1343,1388,"didn't know"],[1388,1572,"how to keep his mouth shut!"],[2185,2293,"I'm sorry my love."],[2414,2489,"I tried."],[3269,3541,"I told you to ask me my name."],[3632,3716,"You didn't listen."],[4137,4287,"Those tattoos..."],[4300,4441,"It can't be."]],"12":[[0,66,"Please."],[129,237,"We didn't know."],[250,437,"It can't be."],[571,675,"The Chernobog."],[684,771,"What are you waiting for?"],[771,838,"Kill him!"],[880,955,"Kill him!"],[3007,3194,"Who, who the fuck are you?"],[3374,3486,"You know who I am."],[3545,3724,"You can still leave this building alive."],[3807,3874,"Run."],[3991,4079,"Wrong choice."],[4975,5092,"Last chance to live."],[6343,6398,"Please."],[6410,6535,"This is for our daughter."],[7015,7069,"Run."],[7115,7178,"Tell your boss"],[7178,7319,"that the Chernobog is awake"],[7365,7461,"and that if he doesn't bring me"],[7461,7536,"my daughter,"],[7565,7753,"I'm going to burn everything he loves"],[7753,7832,"to the ground."]],"13":[[917,1092,"You were supposed to be a myth."],[1101,1192,"Where's my daughter?"],[1614,1705,"Back at the club."],[1726,1864,"They keep them at the dungeon"],[1864,1964,"in the basement."],[1972,2110,"I didn't know it was you."],[2185,2298,"You gotta believe me."],[2385,2477,"I didn't know."],[2502,2594,"I believe you."],[3407,3490,"Grab their guns."],[3557,3678,"Shoot anyone that you see."],[3745,3878,"And get as far away from here"],[3878,3949,"as you can."],[4004,4062,"Now!"],[4700,4875,"So now what are you gonna do?"],[5109,5226,"Reign down hell."]],"14":[[208,262,"And then,"],[308,383,"he killed them all."],[550,771,"I gave you one job,"],[800,875,"and somehow"],[905,1034,"you managed to let in"],[1034,1276,"the most dangerous man on earth."],[1309,1514,"No sir, you don't understand."],[1514,1614,"He's coming back for us"],[1614,1693,"because we killed-"],[2072,2185,"No excuses."],[2752,2915,"Boss, we have a problem."],[2940,3073,"The Chernobog, Isaac Kane,"],[3115,3199,"is back."],[3303,3407,"Shut everything down."],[3428,3507,"Wartime rules."],[3516,3599,"We're under attack."],[3641,3712,"From one man?"],[3753,3853,"He is no man."],[3933,4058,"He's the angel of death."],[4120,4245,"I once saw him kill a man"],[4245,4387,"with a plastic water bottle."],[4450,4525,"If he arrives,"],[4592,4708,"give him whatever he wants."],[4792,4888,"And beg for mercy."],[4938,5021,"I'm on my way."],[5768,5889,"Alright, party's over."],[5889,5968,"We're closed!"],[5993,6114,"Get the fuck out!"]],"15":[[41,158,"What the fuck."],[233,392,"One of the rats got out of his cage."],[458,621,"Get down on your knees, slave."],[646,788,"You're going back to the dungeons."],[809,950,"Oh, I'm not going anywhere."],[1013,1113,"I'm here for someone."],[1197,1259,"A girl."],[1639,1772,"Pretty soon, you're gonna be the girl."],[2089,2256,"Bring her to me and no one has to die."],[2515,2581,"She's five two,"],[2581,2694,"brown hair, brown eyes."],[2761,2806,"I think I know"],[2806,2923,"which one you're talking about."],[2932,3061,"I saw her in here earlier."],[3136,3336,"Dancing like the little slut she is."],[3720,3837,"No, no, no."],[3916,3999,"Naughty boy."],[4041,4145,"Give me one good reason,"],[4145,4287,"why I don't end your pathetic life"],[4287,4346,"right now."],[4387,4525,"Quit playing around with the slave."],[4575,4683,"Isaac Kane is coming."],[4721,4813,"And we need to prepare."],[4892,5071,"Look, I'm sure you think you're tough."],[5092,5184,"But I promise you,"],[5213,5326,"I'm a different breed."],[5409,5547,"Look in my eyes, bitch."],[5697,5834,"These are the eyes of a killer."],[5960,6018,"You know what I see"],[6018,6114,"when I look in your eyes?"],[6164,6235,"Fear."],[6343,6398,"Hey!"],[6473,6564,"Are you listening to me?"],[6610,6756,"I own you."],[6798,7023,"I dominate you."],[7261,7432,"I'm the alpha."],[7461,7624,"You're the slave."],[7661,7745,"In fact,"],[7995,8083,"get on your knees."],[8091,8179,"I don't think so."],[8291,8375,"Did you not hear me?"],[8412,8504,"Get rid of the slave."],[8537,8675,"Isaac Kane is coming."],[8712,8796,"Bad news."],[9180,9271,"He's already here."]],"16":[[304,500,"Now give me the girl"],[525,650,"and no one dies."],[734,884,"Oh, that's where you're wrong."],[967,1263,"You're a weak, pathetic nobody!"],[1488,1751,"I've seen Boris beat up UFC fighters."],[1764,1830,"He's going to kill"],[1830,1922,"this nobody."],[2010,2139,"You disrespect us"],[2227,2394,"by being alive!"],[2406,2494,"Kill him, Boris."],[2694,2844,"You think you can get the shot off"],[2844,2948,"before I kill you?"],[2994,3249,"I trained under Isaac Kane himself."],[3278,3340,"Did you?"],[3374,3549,"He doesn't realize I'm Isaac Kane."],[3595,3682,"Isaac Kane taught me"],[3682,3778,"everything he knew."],[3841,3933,"I was the only man"],[3933,4095,"he considered an equal."],[4187,4325,"I guess I should be scared then."],[4725,4904,"I'm going to cave in your skull"],[4988,5230,"with my bare hands."]],"17":[[212,283,"All you had to do"],[283,375,"is give me the girl."],[442,517,"Still talking."],[538,629,"After I'm done with you,"],[663,771,"I'm going to find that girl"],[817,1117,"and keep her as my personal whore!"],[1213,1351,"I'll keep her in a closet."],[1397,1559,"Only take her out for pleasure."],[1626,1710,"Maybe I'll call up"],[1764,1860,"my old friend Isaac,"],[1914,2068,"and we can take turns with her."],[2147,2273,"You've never met Isaac Kane"],[2273,2373,"once in your life."],[2631,2740,"But you're about to."],[3307,3390,"Get him, Boris!"],[3395,3449,"Kill him!"],[3461,3599,"Finish that piece of shit!"],[4529,4612,"Oh shit,"],[4612,4738,"it didn't even knock him out."],[4775,4854,"Who is this guy?"],[4996,5092,"Time to end this."]],"18":[[838,984,"Holy shit!"],[1468,1530,"It's him."],[1634,1714,"It's Isaac Kane."],[1780,1864,"The Chernobog."],[2293,2423,"I just broke your trachea."],[2515,2577,"You're going to slowly"],[2577,2686,"suffocate to death."],[2919,2982,"Now you can say"],[2982,3123,"you trained under Isaac Kane."],[3453,3532,"Lesson one."],[3591,3862,"Don't ever fuck with my family."],[4679,4808,"Now bring me the girl,"],[4850,4938,"or you die."]],"19":[[542,596,"You."],[784,838,"You!"],[925,1046,"Good girl."],[1105,1488,"You are going to be my new pet."],[1997,2135,"Was I not clear?"],[2164,2323,"Bring me the girl,"],[2335,2439,"or you die!"],[2469,2673,"You mean this girl?"],[2673,2836,"Oh my God, Dad-"],[2969,3053,"Put down the gun,"],[3115,3286,"or the explosion will blow her head"],[3307,3649,"right off her sexy little body."]],"20":[[45,104,"Boss,"],[120,187,"be careful."],[187,296,"That's Isaac Kane."],[392,479,"You fools."],[533,642,"That's not Isaac Kane."],[667,804,"Isaac Kane is most feared man"],[804,863,"on earth."],[884,1067,"That is just a prisoner"],[1088,1205,"who does not realize"],[1205,1330,"how fucked he is."],[1368,1534,"But he, he, he killed Boris"],[1534,1643,"with his bare hands!"],[1672,1760,"Lucky punch."],[1830,2047,"It won't happen again."],[2110,2189,"Let her go,"],[2218,2293,"or you'll see."],[2427,2494,"Why her?"],[2565,2673,"What do you want with her?"],[2752,2831,"Let me guess."],[2898,3161,"You like girls who are young,"],[3228,3357,"barely eighteen,"],[3424,3516,"innocent."],[3566,3745,"Someone you can defile, right?"],[3974,4049,"Love you, Dad."],[4124,4250,"Love you too, Smiley."],[4329,4412,"Daddy!"],[4437,4558,"Oh, little puppy."],[4579,4758,"You'll never see your daddy again."],[4821,4954,"That's not it, is it?"],[5005,5138,"I mean, she's hot,"],[5155,5347,"but not worth dying over."],[5434,5522,"Little girlie,"],[5597,5772,"is that prisoner your daddy?"],[5818,5885,"No."],[5935,6056,"Don't lie to me!"],[6206,6277,"Uh, uh, uh."],[6318,6406,"You shoot me"],[6443,6652,"and your precious little daughter dies."]],"21":[[95,175,"I swear to God,"],[175,271,"if you don't let her go-"],[271,371,"You swear to me!"],[408,592,"I am your God now."],[650,750,"Look at what you're wearing."],[838,1009,"You belong to me."],[1071,1159,"You are my property"],[1159,1368,"and property does not make demands!"],[1468,1618,"Who the fuck do you think you are?"],[1643,1881,"I'm the one who hands out judgment."],[1931,2152,"Now get your hands off my daughter."],[2877,3194,"Do you have any idea who I am?"],[3211,3357,"The power I have?"],[3382,3478,"What I can do to you?"],[3595,3695,"Do you see this ring?"],[3862,4112,"It means I am boss,"],[4162,4275,"a man of power,"],[4358,4671,"a man to be feared."],[4884,4988,"You should be honored"],[5096,5180,"that your daughter"],[5180,5321,"is now my sex slave."],[5476,5547,"Oh look,"],[5609,5772,"the cuck of a father's gonna cry."],[5784,5847,"Aw."],[5880,5989,"Are you going to cry"],[5993,6106,"over your slut daughter?"],[6302,6402,"I tell you what,"],[6439,6539,"you can take her back"],[6723,6902,"under one condition."]],"22":[[37,367,"See, you are both my property."],[379,542,"I don't just give away property"],[542,617,"for free."],[654,896,"But you may both have your freedom"],[992,1234,"for three million dollars."],[1526,1593,"Come on,"],[1618,1693,"all you have to do"],[1693,1835,"is pay me my three mil"],[1897,1976,"and you can have"],[1997,2189,"your precious little daughter back."],[2273,2473,"But, if you can't,"],[2515,2698,"well, she bleeds out"],[2748,2990,"right in front of your eyes."],[3140,3219,"I take it"],[3378,3461,"three mil is a little"],[3461,3616,"out of your price range."],[3695,3866,"How about two?"],[4008,4058,"One?"],[4216,4346,"A hundred thousand?"],[4546,4617,"Oh, come on."],[4671,4746,"You're not telling me"],[4746,4942,"that you are so pathetic"],[4959,5084,"that you can't even come up"],[5084,5246,"with a hundred thousand dollars"],[5267,5417,"to save your daughter's life."]],"23":[[29,129,"Jesus Christ,"],[129,204,"are you really telling us"],[204,283,"you're that poor?"],[308,408,"I've had bar tabs"],[408,525,"that were more than that."],[700,788,"Pathetic."],[880,1155,"Weak and pathetic."],[1297,1484,"Don't worry, little girlie."],[1651,1797,"Now you'll finally have a man"],[1797,1918,"who can provide for you..."],[1960,2143,"for the short time she has left."],[2606,2669,"Natalie,"],[2773,2923,"Natalie, I'm gonna get you out of here."],[2957,3165,"No, you won't."],[3261,3390,"How do you not realize"],[3411,3557,"that against someone like me,"],[3570,3824,"you are nothing, less than nothing."],[3858,4045,"A castrated half-man, a woman."],[4241,4400,"Not worthy"],[4450,4592,"of having such a"],[4871,5184,"fine pet as your daughter."],[5513,5601,"Would you like to know"],[5601,5780,"how your daughter tastes?"],[5930,6060,"Dad, help!"],[6101,6343,"Oh, come on, Daddy."],[6393,6456,"Help."]],"24":[[0,212,"Oh, Daddy can't help you."],[287,379,"But don't worry."],[404,679,"I'm your new daddy now."],[704,813,"And do you want to know"],[888,1005,"how your new daddy"],[1013,1226,"knew that you were the perfect prey?"],[1472,1614,"Because she ordered"],[1643,1864,"a strawberry daiquiri."],[2052,2248,"Who orders a strawberry daiquiri"],[2248,2344,"at the club?"],[3215,3307,"You like that?"],[3357,3499,"You like Daddy's drink?"],[4479,4542,"Take it."],[4550,4688,"Lap it up, bitch."],[4925,5017,"Oh, shit."],[5196,5338,"How does it feel to be totally powerless"],[5338,5476,"against real men like us?"],[5501,5588,"Now sit!"],[5805,5985,"Good little doggie."],[6473,6556,"That's enough!"]],"25":[[183,304,"Did you really think"],[304,412,"that you stood a chance"],[412,721,"against us titans, us gods?"],[892,959,"Don't worry."],[1001,1105,"I'm not gonna let anything"],[1105,1205,"happen to you, okay?"],[1347,1463,"Yeah, Natalie."],[1534,1689,"Your weak daddy,"],[1693,1926,"who is also my slave,"],[1972,2206,"is going to somehow save you."],[2331,2402,"Smiley,"],[2489,2560,"I promise."],[2606,2765,"Just go, Dad!"],[2836,2898,"What?"],[2961,3140,"Just run!"],[3174,3286,"They're gonna kill you!"],[3328,3432,"No, not without you."],[3436,3611,"You stop being an idiot!"],[3624,3778,"You can't do anything!"],[3807,3991,"These are mobsters"],[3991,4170,"and you're just a drunk!"],[4258,4396,"How can't you see that?"],[4491,4600,"Face it, Dad."],[4629,4821,"You can't do anything right."],[4900,5005,"The only thing you can do"],[5005,5150,"is make things worse!"]],"26":[[33,104,"Please."],[112,166,"Dad,"],[221,308,"sorry,"],[383,583,"but you're just worthless."],[692,804,"You can't help me."],[955,1009,"Wow."],[1142,1313,"Couldn't have said it better myself."],[1438,1530,"Worthless."],[1580,1760,"Any last words before they shoot?"],[1830,1976,"I'm not totally worthless."],[2248,2364,"I noticed you didn't have these,"],[2364,2523,"so I brought your backup glasses."],[2598,2702,"Natalie, I'm sorry."],[2765,2811,"I'm sorry"],[2811,2944,"that I haven't been there for you."],[3115,3161,"I'm sorry"],[3161,3257,"that I've been so caught up"],[3257,3336,"in the past that,"],[3424,3482,"I haven't seen"],[3482,3603,"what's right in front of me."],[3666,3762,"The perfect daughter."],[3862,3974,"I love you, Dad,"],[4154,4350,"which is why I have to do this!"],[4554,4642,"Natalie, no!"]],"27":[[408,487,"What have you done?"],[487,658,"I won't let you die for me, Dad."],[688,754,"Run!"],[884,1096,"I can shut off the bomb at any time."],[1201,1259,"Do it!"],[1297,1493,"First, drop the gun."],[1864,1931,"Chair!"],[2556,2623,"Strip him!"],[2673,2769,"Make sure he doesn't have"],[2769,2865,"any more on him."],[3148,3211,"Oh,"],[3269,3390,"nice tattoos."],[3432,3507,"I'd be impressed"],[3507,3703,"if they weren't so obviously fake."],[3745,3849,"Aw, look."],[3908,3995,"Tie his hands!"],[4396,4537,"Look at him, pathetic."],[4583,4683,"Shoot him, boss."],[4692,4775,"No, no, no."],[4854,5305,"I want this to be up close and personal."],[5330,5397,"Don't!"],[5480,5584,"Let him go!"],[5609,5776,"Don't worry, my little puppy."],[5843,5951,"You're next."],[6035,6289,"Turn off the bomb."],[6318,6423,"Oh, I will..."],[6473,6610,"once you're dead."]],"28":[[4,141,"Please don't kill him!"],[141,212,"Oh, I'm not."],[262,454,"I'm just going to cut out his eyes"],[458,671,"so he can hear everything"],[671,838,"I'm going to do to his daughter."],[1005,1121,"I don't know, boss."],[1126,1242,"I think he'd like that."],[1276,1330,"Gross."],[1372,1447,"Is that true?"],[1455,1572,"You sick fuck!"],[1614,1718,"Would you like to hear"],[1735,1918,"what we're doing to your daughter?"],[2193,2268,"Look at me."],[2306,2389,"Look at me!"],[2464,2681,"I want my face to be the last thing"],[2681,2823,"you ever see."],[2823,2936,"Turn off the bomb."],[2957,3061,"I'll do whatever you say."],[3094,3307,"Do whatever I say right now!"],[3511,3599,"Now."],[3707,3949,"Beg me to fuck your daughter."]],"29":[[91,162,"You heard me?"],[183,262,"Beg me."],[329,517,"Beg me to fuck your daughter."],[554,788,"Turn off the bomb."],[888,996,"Come on, say it."],[1001,1063,"Say it."],[1067,1222,"Say Dmitri Dragovich,"],[1230,1463,"please do my family the honor"],[1488,1609,"of taking my daughter"],[1609,1743,"for your pleasure."],[1764,1872,"Last chance."],[1885,2081,"Turn off the bomb!"],[2097,2344,"You stupid peasant."],[2385,2489,"She pulled the cord."],[2519,2640,"I can't just stop it."],[2665,2773,"You need a bomb squad"],[2773,2873,"to save her now."],[3148,3328,"Your daughter will be obliterated"],[3328,3399,"in..."],[3449,3691,"one minute and thirty-two seconds,"],[3699,3974,"which is one minute and thirty seconds"],[3974,4112,"more than you have."],[4500,4583,"You fools!"],[4629,4725,"Do you know who that is?"]],"30":[[0,87,"You fools!"],[112,229,"Do you know who that is?"],[296,350,"Boss,"],[412,554,"this is just a slave."],[558,667,"I'm taking care of him"],[696,817,"before Isaac Kane shows up."],[825,950,"You fucking morons!"],[980,1096,"That is Isaac Kane!"],[1701,1780,"Kill him now!"],[2615,2748,"Natalie, close your eyes."],[3065,3219,"Dad's about to hurt some people."],[3336,3503,"Isaac, please."],[3536,3624,"Isaac's gone."],[3883,4062,"All that's left is the Chernobog."],[5789,5834,"Please."],[5880,5964,"Mercy."],[6097,6239,"None left to give."],[6852,6902,"Dad?"]],"31":[[54,129,"Okay, Smiley."],[187,229,"Now I'm gonna need you"],[229,333,"to open your eyes,"],[350,433,"but just look at me."],[433,517,"Don't look anywhere else,"],[517,604,"just at me, okay?"],[825,959,"Just at me, okay?"],[980,1142,"Hey, Smiley, just at me."],[1251,1422,"Dad, what's, what's happening?"],[1434,1543,"I'll explain everything later,"],[1543,1589,"but right now"],[1589,1701,"I need you to listen to me, okay?"],[1789,1931,"Now there's a kill switch on the collar."],[1931,2072,"If we can get to it, we can turn it off."],[2177,2227,"Do it."],[2227,2344,"Okay, it's not that easy."],[2385,2498,"It's right next to your artery"],[2498,2619,"and I'm gonna have to shoot it off."],[2694,2731,"What?"],[2731,2844,"Natalie, Natalie, listen to me."],[2844,2973,"We've got fifteen seconds, okay?"],[2973,3036,"Pay attention."],[3048,3115,"I need you to remain"],[3115,3186,"perfectly still."],[3186,3253,"Don't move."],[3265,3382,"If you do, you could push the switch"],[3382,3445,"in the wrong direction"],[3445,3516,"and we'll both be dead."],[3516,3599,"Do you understand me?"],[3636,3724,"I think I do."],[3728,3845,"Okay, okay, close your eyes."],[4141,4187,"Dad,"],[4262,4404,"just in case we don't make it,"],[4446,4558,"I just want you to know-"],[4583,4688,"We'll make it, Smiley."]],"32":[[909,1101,"Hey, hey, hey, you're okay, okay?"],[1130,1217,"You did great, alright?"],[1217,1330,"But right now we gotta go, okay?"],[1330,1376,"Come on."],[1676,1751,"Who are you?"],[1964,2047,"I'm your dad."],[2168,2335,"No, I just watched a guy"],[2335,2460,"who's too much of a drunk"],[2481,2590,"to find a job,"],[2598,2752,"kill a whole crowd of mobsters"],[2752,2923,"like it was nothing."],[2940,3036,"Who are you?"],[3036,3178,"Natalie, it's me."],[3232,3357,"I'm still just your dad."],[3357,3465,"I'll explain everything later,"],[3465,3611,"but right now we have to go, okay?"],[3611,3641,"Come on."],[3641,3807,"I'm not moving a fucking inch"],[3807,3953,"until you tell me who you are."],[4179,4354,"My name is Isaac Kane."],[4396,4479,"Before you were born,"],[4479,4633,"I was a Tenth Degree Master"],[4667,4783,"and the Fifty-Seventh Reaper"],[4783,4913,"of the guild of Assassins."],[4950,5025,"I'm responsible"],[5025,5238,"for the death of 627 men,"],[5413,5497,"and one woman."]],"33":[[241,300,"Your mother."],[479,579,"Before you were born,"],[579,684,"I was invincible."],[742,859,"No one could touch me."],[905,975,"So they targeted"],[975,1059,"your mother instead."],[1059,1217,"They killed her as a message to me."],[1413,1543,"I'm the reason that she's dead,"],[1543,1618,"it's my fault."],[1864,1956,"I'm so sorry."],[2022,2164,"Look, it's not safe for you here."],[2231,2335,"I've called in some favors."],[2335,2394,"In three minutes,"],[2394,2527,"a black Mercedes is gonna pull up"],[2527,2640,"and take you to a private airport."],[2640,2702,"And from there,"],[2731,2831,"you're gonna go to a safe house"],[2831,2919,"I own in Paris."],[3007,3111,"If you never wanna see me again,"],[3111,3199,"I understand."],[3365,3495,"But I have to keep you safe."],[3553,3607,"Go."],[4037,4091,"Dad."],[4212,4475,"You know that thing I needed to tell you"],[4475,4600,"before the bomb went off?"],[4808,4992,"I'm lucky to have you as my father."],[5288,5413,"After I've done what I need to do,"],[5413,5551,"I'm gonna be the father"],[5551,5647,"that you deserve."],[5672,5768,"What do you need to do?"],[5876,5968,"Bad things."]],"34":[[258,325,"My son,"],[404,567,"there is nothing to do"],[592,742,"but wait for our deaths."],[763,892,"Shut up, old man."],[1526,1630,"Dmitri, it's done?"],[1935,2039,"It is not."],[2139,2289,"You broke the holy rule, Igor."],[2360,2485,"You came for my family."],[2548,2594,"Isaac,"],[2648,2902,"this is just a, a clear misunderstanding."],[2911,3090,"You took my daughter, Igor."],[3174,3428,"You were gonna sell my daughter, Igor."],[3499,3570,"You moron,"],[3570,3716,"I told you not to deal"],[3716,3832,"in human trafficking."],[3866,3928,"Isaac,"],[4024,4208,"tell us what we must do"],[4208,4320,"to make this right."],[4358,4475,"Shut down your slave trade."],[4929,5000,"Release everyone."],[5000,5096,"And give me your word"],[5096,5159,"that you'll leave me"],[5159,5263,"and my daughter alone."]],"35":[[20,137,"You have my word."],[221,283,"And mine."],[379,538,"Your word isn't worth shit, Igor."],[654,829,"Vasile, your son will go into exile,"],[875,971,"back to the motherland."],[971,1130,"Give him a factory or a farm"],[1130,1230,"or a shoeshine box."],[1230,1338,"I don't really give a shit."],[1413,1576,"But if he ever steps foot"],[1576,1680,"in my country again,"],[1680,1755,"I take his head"],[1755,1947,"and burn your entire organization"],[1947,2018,"to the ground."],[2018,2147,"You think you can beat me?"],[2218,2314,"I beat you before."],[2314,2435,"I can do it again."],[2502,2681,"Oh, you didn't know?"],[2694,2765,"Igor, no."],[2831,2932,"Who do you think it was"],[2932,3040,"that killed your wife?"],[3082,3119,"You know,"],[3119,3290,"she whimpered like a dog"],[3290,3428,"as she bled out on the floor."],[3995,4195,"I'm gonna take everything from you."],[4245,4300,"How?"],[4333,4450,"You are one man."],[4475,4617,"You think you can come for me?"],[4625,4746,"I have an army."],[4763,4954,"I will burn you to the ground."],[5030,5130,"Not even Isaac Kane"],[5130,5301,"can take down an entire army."],[5334,5384,"No,"],[5463,5526,"he can't."],[5626,5705,"But The Reaper"],[5709,5864,"of the Assassin Guild can."],[6089,6206,"What have you done?"]],"36":[[29,208,"You have killed us all, my son."],[304,433,"What does he mean, Reaper?"],[538,688,"Hundreds of years ago,"],[688,925,"the world's most powerful killers"],[925,1142,"formed the Assassin's Guild,"],[1155,1267,"an organization"],[1292,1580,"filled with codes, laws, rituals,"],[1609,1735,"created to make sure"],[1735,1906,"they did not plunge the world"],[1906,2014,"into chaos."],[2060,2302,"But there was just one problem."],[2318,2398,"What would happen"],[2452,2652,"if one of these killers"],[2652,2781,"broke their rules?"],[2790,3032,"Who could punish these men?"],[3065,3215,"Who could control these men"],[3236,3478,"who had dedicated their entire lives"],[3532,3807,"to becoming the perfect killers?"],[3824,3941,"So they created"],[3953,4116,"the mantle of The Reaper,"],[4149,4325,"the best of the best,"],[4358,4575,"the man even the most"],[4575,4825,"hardest killer feared."],[4875,4988,"And then they gave him"],[5005,5171,"everything he needed"],[5196,5334,"to become unstoppable."],[5417,5709,"That man was Isaac Kane."],[5772,5860,"So that means-"],[5860,5960,"That means"],[6060,6235,"that eighteen years later,"],[6264,6468,"Isaac Kane has come"],[6477,6765,"to take back the mantle of Reaper"],[6765,7023,"just so he can kill us all."]],"37":[[625,742,"How can I help you, son?"],[796,921,"I'm here to make a confession."],[946,1101,"We don't offer confessions"],[1101,1192,"at this church."],[1197,1297,"Well, for me, you do."],[1351,1547,"St. Thomas's is right up the road."],[1572,1747,"It might be better for a believer"],[1747,1851,"such as yourself."],[1947,2064,"Well, I'm not a believer,"],[2147,2377,"and this is not a church."],[5280,5513,"Please, come with me, sir."]],"38":[[1130,1242,"You'll find everything you need"],[1242,1355,"in here, sir."],[2656,2894,"Oh God, a peasant just wandered in."],[2919,3098,"I don't think you belong here, boy."],[3228,3319,"He's lost."],[3478,3607,"Turn your tight ass around"],[3607,3778,"and walk out before you get hurt."],[3828,3949,"Afraid I can't do that."],[4133,4241,"I need to go in that room."],[4441,4583,"Not gonna happen, handsome."],[4642,4771,"Only The Reaper's allowed in there."],[4817,4909,"No one stepped in there"],[4909,5009,"for twenty years."],[5017,5088,"Eighteen."],[5163,5213,"What?"],[5230,5392,"Eighteen years, three months,"],[5392,5509,"and fourteen days."],[5576,5643,"But I'm back."],[5784,5868,"You're The Reaper?"],[6373,6527,"You look like you would get beat up"],[6527,6619,"by a little girl."],[6639,6790,"Someone get this delusional asshole"],[6790,6848,"out of here."],[6902,7007,"I don't like liars."],[7069,7169,"I hurt liars."],[7219,7328,"Give me one good reason"],[7328,7453,"why I shouldn't chop you up"],[7453,7636,"into tiny bite-sized pieces."]],"39":[[45,112,"Here's one."],[821,946,"That's the amulet of The Reaper."],[946,1038,"Where did you get that?"],[1059,1209,"Sir, we had no idea."],[1242,1359,"You know what this means, right?"],[1422,1555,"I'll tell you what it means."],[1922,2014,"Holy shit."],[2052,2152,"That's Cassius Crowley."],[2181,2273,"He's a ninth degree member"],[2273,2339,"of the guild."],[2427,2677,"So what it means is that Isaac Kane"],[2690,2794,"is finally dead."],[2861,2915,"What?"],[2940,3036,"So that's his amulet."],[3040,3136,"Now he wouldn't take it off"],[3136,3236,"unless he was dead."],[3336,3420,"So where did you find it?"],[3436,3490,"Some alleyway?"],[3490,3549,"A drug den?"],[3670,3757,"You see the body?"],[3799,3903,"What makes you so sure"],[3903,4041,"I'm not Isaac Kane?"],[4458,4512,"Isaac Kane"],[4512,4654,"is the deadliest man on earth."],[4721,4808,"Why, he's so feared"],[4808,4909,"he's become a myth,"],[4929,4992,"a nightmare,"],[5071,5150,"the Chernobog."],[5284,5351,"But see you?"],[5422,5476,"Oh no."],[5476,5613,"You're weak, pathetic."],[5676,5751,"Sheep."],[5851,5968,"You should run away, sheep."],[6089,6235,"Why, you're in the den of the wolves."],[6310,6423,"I don't have time for this."],[7082,7186,"You're gonna make time."]],"40":[[75,187,"You don't wanna do this."],[258,396,"Oh, I think I do."],[450,575,"Poor, pathetic guy."],[629,771,"Stumbled into the wrong place"],[771,900,"and messed with the wrong guy."],[900,988,"This is what happens"],[988,1076,"when you don't respect"],[1076,1209,"your betters, boy."],[1284,1380,"I don't know exactly"],[1380,1514,"how a piece of shit like you"],[1514,1609,"got that amulet, but"],[1639,1718,"I sure as fuck know"],[1718,1864,"you didn't kill Isaac Kane for it."],[1997,2085,"So where did you find it?"],[2135,2260,"I'm gonna go through that door."],[2456,2569,"You do what you need to do."],[3207,3390,"What is going on in here?"],[3661,3712,"It's the leader"],[3712,3820,"of The Assassin's guild."]],"41":[[45,254,"What is going on in here?"],[287,350,"My Lord,"],[421,538,"this nobody has the amulet"],[538,613,"of The Reaper."],[638,717,"It's confirmation"],[717,825,"Isaac Kane is dead."],[896,996,"Is this true?"],[1972,2052,"It's real."],[2089,2273,"Where did you get this?"],[2298,2364,"Does it matter?"],[2385,2506,"With Isaac Kane gone,"],[2506,2648,"the guild is without its enforcer."],[2656,2744,"It's time for the trials"],[2744,2861,"to determine the next Reaper."],[2952,3290,"Are you sure this man isn't Isaac?"],[3499,3611,"Sir, if you could see him,"],[3695,3816,"you'd know there's no way"],[3816,3912,"he'd be Isaac Kane."],[4012,4225,"Then let the trials begin."]],"42":[[37,175,"Who will stand"],[200,358,"for the position of Reaper?"],[500,563,"Well, I will."],[621,729,"You'd have to be fucking nuts"],[729,863,"to take on Cassius Crowley."],[880,1059,"He'll kill anyone who goes against him."],[1184,1313,"Then there is no one."],[1493,1559,"Well then,"],[1676,1851,"the new Reaper"],[1943,2173,"of The Assassin's guild is-"],[2173,2227,"I will."],[2444,2552,"You gotta be kidding me."],[2669,2823,"He's a normal from the streets."],[2840,2902,"Should let me kill him"],[2902,3015,"just for suggesting it."],[3044,3165,"Are you scared, Cassius?"],[3224,3353,"Worthless ant like you?"],[3386,3436,"No."],[3524,3707,"See, I will eat your spleen."],[3737,3995,"Let the stranger join the trials."],[4074,4204,"But if you fail,"],[4337,4471,"you will be killed."]],"43":[[517,688,"The amulet has been found,"],[713,771,"meaning that"],[771,955,"the legendary Isaac Kane"],[955,1055,"must be dead."],[1092,1372,"We need a new killer of killers."],[1413,1601,"We need a new Reaper."],[1643,1714,"Two men"],[1755,1964,"have decided to take the trial."],[2047,2239,"One of them will ascend"],[2293,2577,"to become our judge, jury,"],[2577,2886,"and executioner of our organization."],[2915,2990,"The other"],[3153,3253,"dies."],[3269,3632,"Our first challenger is Cassius Crowley."],[3649,3874,"Ninth level member of our guild."],[3903,4049,"Of course it would be Cassius."],[4049,4179,"He's the most dangerous man"],[4179,4287,"since Isaac Kane."],[4291,4441,"He's too brutal for my taste,"],[4533,4696,"but I can't deny his abilities."],[4738,4925,"The other is the man"],[4925,5155,"who brought us the amulet."],[5180,5309,"He has no name"],[5338,5559,"and he is not one of us."],[5584,5739,"This is an outrage!"],[5759,5897,"Why are we letting commoners"],[5897,6051,"into our inner sanctum?"],[6060,6197,"We need to kill him now."],[6227,6481,"Patience, esteemed elders."],[6481,6740,"If he fails, then he dies."],[6769,7052,"Once I've beaten and humiliated you,"],[7077,7232,"I'll personally slit your throat."],[7232,7298,"Then I'm gonna go out"],[7298,7457,"and find your family and kill them,"],[7545,7632,"so that your bloodline"],[7632,7736,"can never disrespect"],[7736,7824,"our guild again."],[8274,8450,"I do have a name."],[8554,8721,"And once I take my rightful place,"],[8721,8946,"I'll remind you all exactly what it is."]],"44":[[8,296,"The first trial will test your ability"],[296,458,"to take down a target."],[575,663,"The target will be"],[663,804,"at the end of the room."],[842,988,"You'll have 30 seconds"],[988,1101,"to get a headshot."],[1142,1201,"Easy."],[1351,1609,"Without killing a civilian."],[2035,2127,"Mr. Crowley,"],[2189,2327,"choose your weapon."],[2569,2673,"At that distance,"],[2673,2831,"he has to go with a sniper."],[2877,3090,"Anything else would be near impossible."],[3140,3224,"It's too easy."],[3707,3803,"I choose pistol."],[4120,4220,"That is only accurate"],[4220,4350,"to half that range."],[4354,4471,"Are you sure?"],[4475,4600,"These are live rounds."],[4600,4692,"If you miss-"],[4708,4825,"I won't miss."],[4859,4942,"Take your mark."],[5543,5622,"Begin!"]],"45":[[709,792,"Cassius did it."],[980,1167,"Cassius Crowley moves on."],[1355,1589,"Stranger, choose a weapon."],[1943,2077,"Well, now don't be a pussy."],[2147,2235,"Pick up the pistol."],[2773,2840,"Yeah,"],[2907,2961,"I think I'll go"],[2961,3065,"in a different direction."],[3999,4187,"What is this fool talking about?"],[4225,4375,"That relic is from World War One."],[4416,4587,"It's not even as accurate as a pistol."],[4788,4896,"Take your mark."],[4921,5034,"You have 30 seconds"],[5034,5138,"to kill your target."],[5155,5242,"If you can't,"],[5276,5513,"or if you hit a civilian and fail,"],[5551,5643,"you die."],[5709,5805,"And as the new Reaper,"],[5805,5918,"I'll kill him myself."],[6014,6227,"Oh, and I will make it painful."],[6239,6377,"He should just quit now"],[6377,6514,"and save himself."],[6519,6602,"Does this commoner"],[6602,6781,"really think he can be the successor"],[6781,6877,"to Isaac Kane?"],[6906,7098,"Stranger, are you ready?"],[7161,7211,"Ready."],[7465,7532,"Begin!"]],"46":[[20,204,"You only have 25 seconds!"],[204,287,"You were impressive,"],[316,437,"but you made one mistake."],[487,542,"Really?"],[633,704,"And what was that?"],[742,817,"You made a scene."],[842,934,"In a real scenario,"],[934,992,"everyone would've heard"],[992,1084,"the pistol shots."],[1105,1247,"They would've seen your face."],[1555,1785,"Please tell me, oh great killer of men,"],[1822,1876,"what would you"],[1876,1968,"have done different?"],[1985,2106,"Fifteen seconds."],[2210,2352,"Practiced discretion."],[2385,2515,"He can't be serious."],[2515,2598,"What is he doing?"],[2781,2882,"Ten seconds."],[3215,3286,"Five."],[3286,3574,"Only a child needs a gun at this range."],[3574,3657,"Four."],[3812,3903,"Three."]],"47":[[738,855,"Oh my God."],[959,1076,"Who are you?"],[1113,1322,"Soon you'll know exactly who I am."],[1468,1534,"Lucky throw."],[1618,1835,"Both challengers will move on"],[1835,1956,"to the next round."],[2185,2477,"Agony is the constant companion"],[2477,2565,"of the Reaper."],[2640,2748,"This next test"],[2802,2961,"will test your control"],[3028,3199,"over the pain in your body."],[3249,3407,"Inside that basket"],[3420,3582,"is a black-mouthed viper,"],[3649,3812,"whose bite contains"],[3828,3966,"the most painful"],[3966,4079,"venom known to man."],[4145,4316,"You will stick your hand"],[4316,4571,"into the basket for ten seconds,"],[4637,4804,"allowing it to bite you"],[4804,4975,"over and over again."],[5034,5171,"If you remove it"],[5171,5334,"before the time is up,"],[5392,5547,"we take your head."],[5755,5830,"Cassius,"],[5910,5976,"you're up."],[6594,6765,"Now see how a real man does it."],[7215,7298,"Are you ready?"],[7332,7444,"Let's get it over with."],[7553,7615,"Begin!"]],"48":[[412,475,"Time!"],[884,975,"He actually did it."],[1247,1343,"Only Isaac Kane"],[1343,1476,"has ever lasted that long."],[1584,1668,"Incredible."],[2218,2406,"See, you're weak, pathetic."],[2473,2619,"There's no way you'll survive."],[2727,2802,"Yeah, we'll see."],[2865,3003,"Once he cuts your head off,"],[3103,3224,"I'm going to hang it on a pike."],[3315,3382,"Stranger."],[3461,3532,"You're up."],[3807,3970,"You don't have to do this."],[4099,4229,"You can still walk out."],[4304,4358,"No."],[4421,4479,"I can't."],[4521,4688,"I need to get my title back,"],[4842,4913,"for Natalie."],[4992,5063,"Love you, Dad."],[5109,5230,"I love you too, Smiley."],[5422,5480,"Ready."],[5576,5647,"Begin."]],"49":[[367,508,"Why is he not screaming?"],[546,638,"There's no way."],[667,825,"He's not even breathing hard."],[892,1051,"No one has that level of mastery"],[1051,1121,"over pain."],[1418,1484,"Time!"],[1901,1981,"He cheated."],[2018,2085,"He had to."],[2102,2160,"There's no way"],[2160,2223,"he could have done that"],[2223,2302,"without screaming."],[2327,2431,"Cassius is right."],[2464,2527,"He must have switched"],[2527,2606,"the baskets."],[2644,2752,"There's no snake in there."],[2798,2857,"Really?"],[2957,3028,"Is that so?"],[3065,3148,"We know so."],[3182,3282,"A common peasant like you"],[3282,3411,"could never withstand"],[3411,3499,"that level of pain."],[3553,3636,"We kill him now."],[3636,3712,"He cheated!"],[3728,3866,"There's nothing in that basket."],[4091,4200,"Are you sure about that?"],[4358,4483,"Oh my God!"]],"50":[[8,91,"Antidote!"],[375,433,"How?"],[487,596,"What is your name?"],[667,792,"Who are you, really?"],[863,1026,"You'll all know soon enough."],[1113,1409,"For the first time in over 300 years,"],[1463,1705,"two men have passed the trials"],[1705,1889,"to become the Reaper."],[1964,2039,"What does that mean?"],[2122,2256,"Will we have two Reapers?"],[2293,2381,"You old fool."],[2381,2498,"There can only be one."],[2577,2669,"He is correct."],[2761,2990,"The two challengers shall face off"],[2990,3111,"against one another"],[3136,3286,"in a duel to the death!"],[3762,3903,"See, after I break your neck,"],[3983,4137,"I hope you're alive just long enough"],[4137,4245,"to see me anointed."],[4312,4446,"So my first order of business"],[4446,4554,"is gonna be to piss"],[4554,4696,"on your worthless dead body."],[4867,5046,"Men, prepare yourselves."],[5105,5205,"It is time."]],"51":[[4,266,"You will be fighting inside this ring."],[316,533,"Step out, and you forfeit,"],[571,788,"and will be executed."],[850,1080,"You will be chained together."],[1134,1255,"Nowhere to run."],[1330,1459,"Nowhere to hide."],[1522,1755,"You will each be given a blade."],[1801,1914,"Your only weapon."],[2006,2243,"Surrendering will do nothing."],[2310,2560,"Tapping out will do nothing."],[2610,2802,"You will both fight"],[2823,3061,"until one of you is dead."],[3153,3244,"Now those tattoos"],[3244,3340,"supposed to scare me?"],[3403,3507,"Say what on earth"],[3545,3649,"possibly made you think"],[3649,3712,"you'd have a chance"],[3712,3816,"against someone like me?"],[3858,4066,"See, I'm your better in every way."],[4120,4175,"So I could take"],[4175,4270,"whatever I want from you,"],[4270,4400,"at any point I feel like it."],[4446,4550,"And see, right now,"],[4596,4779,"oh, I feel like taking your pathetic,"],[4842,4992,"insignificant little life."],[5025,5100,"See, now you"],[5188,5267,"are going to die"],[5334,5613,"a violent, humiliating death."],[5672,5734,"Maybe."],[5839,5922,"But not today."],[5964,6035,"Begin!"]],"52":[[8,120,"May the best Reaper win."],[813,892,"See, you know what the difference"],[892,984,"between someone like you"],[984,1092,"and someone like me is?"],[1263,1355,"You're a house cat."],[2202,2293,"See you prance around"],[2293,2414,"like you're the king of the jungle."],[2414,2489,"But the truth is,"],[2489,2556,"you've never left"],[2556,2669,"your quaint little home."],[2740,2819,"You have no idea"],[2819,2940,"the dangers in my world."],[3470,3591,"Oh my gosh."],[3628,3753,"How did he land a blow like that"],[3753,3841,"on Cassius?"],[4408,4521,"What a cheap move."],[4525,4600,"Shut up!"],[4642,4696,"The Reaper does"],[4696,4800,"what he needs to do to win."],[4888,4954,"Look at you,"],[4988,5059,"I bet for a second"],[5059,5150,"you thought you had a chance"],[5150,5251,"against someone like me."],[5292,5376,"How does it feel?"],[5422,5476,"How does it feel"],[5476,5580,"to know you're about to die?"]],"53":[[16,100,"How does it feel"],[154,296,"to know that you've failed"],[383,487,"whoever was out there,"],[487,575,"depending on you?"],[621,692,"Love you, Dad."],[771,850,"No."],[850,1059,"Natalie, I will not fail you today."],[1059,1142,"Say goodbye."],[1922,1989,"Oh."],[2231,2310,"Who are you?"],[2752,2902,"My name is Isaac Kane."],[3069,3240,"And I'm here to take back what's mine."]],"54":[[1213,1284,"Isaac,"],[1422,1514,"I knew it was you."],[1601,1655,"I'm surprised"],[1655,1776,"you didn't recognize me sooner,"],[1776,1839,"old man."],[2047,2202,"I think I have a pass."],[2252,2331,"Mr. Kane,"],[2377,2502,"we're so sorry."],[2548,2669,"If we'd have known it was you,"],[2681,2752,"we'd never-"],[2752,2819,"Enough."],[2902,2982,"I didn't come back"],[2982,3199,"to listen to you grovel like children."],[3224,3357,"Why did you come back?"],[3403,3549,"The Russian mob kidnapped"],[3549,3682,"and tortured my daughter."],[3703,3803,"I can't have that."],[3828,3887,"So you're gonna"],[3887,3983,"teach them a lesson?"],[4020,4070,"No."],[4371,4471,"I'm gonna burn them"],[4479,4608,"to the fucking ground."],[4671,4763,"I need my gear."],[4850,4925,"It's time"],[4954,5146,"for the return of the Reaper."],[6018,6101,"Everything you need"],[6101,6252,"to launch a one-man war"],[6272,6439,"is through that door."]],"55":[[796,959,"Want to make a good entrance?"],[1071,1338,"It looks like a simple throwing hatchet,"],[1351,1509,"but a second after impact,"],[1672,1772,"it detonates."],[1926,2131,"Italian craftsmanship,"],[2198,2314,"hand finished,"],[2314,2477,"with canvas interlining."],[2573,2640,"Classic."],[2677,2861,"Oh, it's anything but classic."],[2907,3144,"This suit has carbon composite padding"],[3174,3311,"which can take a direct hit"],[3324,3415,"from a 50 cal."],[3532,3603,"Normal rounds"],[3603,3716,"won't even leave a bruise."]],"56":[[62,129,"And"],[162,367,"for the piece de resistance,"],[400,563,"we call this the angel of death."],[592,817,"It took over five years to develop."],[855,1067,"Looks like a regular high-caliber rifle."],[1096,1176,"Well, it is,"],[1255,1422,"until you flip the switch this way."],[1922,2022,"Dragon's breath."],[2043,2139,"It's impressive."],[2214,2289,"It is,"],[2339,2569,"but not compared to what happens"],[2569,2719,"when you flip the switch this way."],[2731,2869,"Liquid acoustic grooves"],[2873,2994,"modulate to create"],[2994,3186,"a newtonian centrifugal force"],[3211,3403,"that can change the trajectory."],[3440,3561,"In layman's terms,"],[3670,3828,"it bends bullets."],[4258,4529,"Is everything up to your standards, sir?"],[4783,4859,"This'll do."]],"57":[[262,442,"You cannot kill a demon, son."],[475,633,"We have but one option."],[675,792,"You will be sent back"],[813,909,"to the motherland"],[909,1117,"to live a quiet life."],[1222,1380,"My men are coming for you now."],[1497,1630,"I am sorry, my son."],[1797,1901,"It's the only way"],[1901,2022,"to keep you alive."],[2640,2702,"Igor?"],[2994,3144,"What are you doing?"],[3219,3361,"Taking what's mine."],[4625,4746,"My father is dead."],[4904,4975,"Heart attack."],[5376,5530,"Bow before your new leader."],[5789,5868,"Bow!"]],"58":[[179,312,"We await your command, sir."],[646,784,"Our enemy is only as strong"],[784,900,"as his weakest point."],[1051,1192,"Prepare to go to Paris."],[2218,2298,"Tonight,"],[2394,2531,"we will be under attack"],[2635,2794,"by a lone man."],[2823,3111,"This man believes he is unstoppable."],[3232,3353,"But he is wrong!"],[3516,3782,"For he is just one man!"],[4829,4917,"Retreat!"],[4942,5050,"He's going to kill us!"],[5071,5192,"He's going to kill us all!"],[5605,5947,"Where is my daughter?"],[6114,6206,"She's right here."],[6289,6343,"Dad!"],[6431,6502,"Let her go."],[6535,6589,"Now!"]],"59":[[0,70,"You're in no position"],[70,171,"to be making demands."],[208,287,"Put the gun down."],[358,471,"Natalie, close your eyes."],[600,646,"Four."],[692,767,"Daddy!"],[834,967,"Shh, it'll be okay."],[988,1042,"Three."],[1142,1192,"Two."],[1217,1313,"Just trust me."],[1380,1434,"One."],[1488,1593,"In layman's terms,"],[1593,1751,"it bends bullets."],[2719,3036,"My name is Isaac Kane."],[3061,3140,"As children,"],[3140,3307,"you were told stories about me."],[3365,3461,"Nightmares."],[3549,3670,"They were all true."]],"60":[[500,621,"Hello, Igor."],[750,829,"So you live."],[967,1021,"For now."],[1067,1134,"No matter."],[1451,1634,"My men will scour the world for you."],[1659,1747,"They will find you,"],[1805,1910,"and they will kill you."],[1910,2035,"I just have one question."],[2035,2164,"Are you not listening?"],[2327,2456,"You do not question me."],[2489,2569,"You are one man."],[2590,2686,"You have no power."],[2690,2877,"I am the entire Russian mob."],[2919,3073,"There's nothing you can say"],[3082,3232,"that will make me afraid of you."],[3286,3374,"There's nothing."],[3566,3720,"How's the tea?"],[5142,5321,"How's the tea?"]],"61":[[596,654,"Mya,"],[729,804,"I'm sorry."],[855,950,"I broke my vow."],[1247,1459,"I tried to leave this life behind but,"],[1547,1680,"there's something inside of me,"],[1760,2010,"something dark and wrong."],[2206,2439,"No matter what I do, it finds a way out."],[3274,3420,"But I'm trying, Mya."],[4016,4087,"It's okay."],[4283,4404,"You did what you had to do."],[4521,4596,"Do you mean that?"],[4783,4896,"Do you really mean that?"],[4925,5000,"Of course."],[5063,5134,"I love you."],[5330,5488,"I understand, Dad."],[5814,6001,"And mom would understand too."],[6218,6348,"I know that you want to know"],[6398,6481,"who I really am."],[6481,6610,"I know who you really are."],[6756,6815,"You do?"],[6898,6952,"Yeah."],[7107,7203,"You're my dad."],[8112,8287,"Hey, let's go home."],[8287,8341,"Come on."]]}