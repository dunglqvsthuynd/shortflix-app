{"1":[[84,256,"Baby, you smell so good."],[282,374,"It's so hot!"],[374,486,"Jakey."],[486,576,"I can't do it."],[581,674,"Don't take it off."],[674,728,"What I want"],[728,848,"is you being in the teddy bear!"],[1276,1344,"Miss James,"],[1394,1622,"you really treat Mrs. Parker so well."],[1622,1801,"This jade necklace is priceless,"],[1836,1942,"but you didn't even blink"],[1942,2024,"when you bought it."],[2039,2218,"It's just a little trinket."],[2222,2336,"As long as you like it, Luna."],[2360,2412,"Mom,"],[2412,2530,"you shouldn't have."],[2530,2604,"By the way, Mom,"],[2604,2758,"there's an emergency at the company"],[2758,2912,"and a meeting I need to attend."],[2912,3062,"Alright, you go take care of that."],[3078,3142,"Okay."],[3290,3528,"Why did you take it off, baby?"],[3534,3642,"Stay safe."],[3642,3792,"I will, Mom."],[4238,4358,"Baby, you smell so good."],[4688,4832,"Jakey!"],[4832,4972,"When can I"],[4972,5196,"openly be with you?"],[5196,5384,"Just be patient."],[5384,5588,"Right now, I can't let my mom see you."],[5588,5724,"That's why I had to resort to"],[5724,5876,"hiding you inside this teddy bear."],[5884,6058,"How dare you, Jake!"],[6058,6124,"You promised me"],[6124,6332,"you would kick this homewrecker out!"],[6332,6482,"But you lied to me"],[6482,6668,"and didn't listen to a single word I said."],[6706,6854,"Luna must never know about this."],[6854,6966,"She developed heart disease"],[6966,7120,"while saving my life back then,"],[7120,7258,"so she can't handle any shock."],[7258,7364,"I will personally"],[7364,7502,"clean up this mess for her!"],[7628,7740,"Baby."],[7810,7922,"Who is there?"]],"2":[[75,162,"Who is there?"],[562,608,"Mom?"],[612,750,"You shameless vixen,"],[754,875,"hiding inside a teddy bear, huh?"],[879,1020,"Just watch how I teach you a lesson"],[1025,1108,"for my daughter-in-law."],[1145,1220,"Jake,"],[1237,1345,"what is going on here?"],[1400,1500,"Luna isn't home,"],[1504,1783,"so why did you get such a huge teddy bear?"],[1798,2045,"Mom, why did you come back so suddenly?"],[2049,2183,"Since Luna isn't home,"],[2187,2300,"I felt a little lonely,"],[2304,2545,"so I got a teddy bear to keep me company."],[2596,2704,"Why is this bear"],[2753,2903,"so filthy?"],[2905,3088,"Mom, what does that mean?"],[3441,3633,"Since it's dirty, it needs to be washed."],[3637,3762,"Take it to the laundry room,"],[3766,3912,"put it on the tumble cycle,"],[3916,4058,"and give it a good wash!"],[4360,4474,"No!"],[4479,4558,"Mom,"],[4562,4695,"this bear is made of special material."],[4700,4816,"It can't be machine-washed."],[4820,4935,"It'll break if we wash it."],[5025,5125,"If it breaks, it breaks."],[5171,5283,"It's just a bear, isn't it?"],[5287,5441,"I'll buy you a new one."],[5445,5537,"No, no, no."],[5541,5604,"No need for that."],[5608,5683,"Mom,"],[5700,5841,"I just want this one."],[5851,6108,"I'm attached to it after all this time."],[6111,6229,"Attached, huh?"],[6233,6362,"Yeah."],[6716,6883,"Since you like it so much,"],[7375,7481,"then forget it."],[7581,7650,"Okay."],[7999,8074,"But..."],[8241,8516,"Something this dirty"],[8520,8708,"really shouldn't stay in the house."],[8712,8808,"Since it can't be washed,"],[8820,8945,"let's just throw it away."],[8954,9037,"Someone!"],[9048,9148,"Throw it out."],[9187,9337,"Mom, what are you doing?"],[9479,9591,"Trash"],[9595,9762,"belongs in the trash can."]],"3":[[446,590,"Eww!"],[614,860,"It's disgusting!"],[954,1056,"Oh no."],[1283,1432,"Baby, are you okay?"],[1432,1536,"Jakey!"],[1682,1750,"Baby."],[1750,1946,"Baby, you're too dirty."],[1968,2120,"You think I'm gross?!"],[2164,2356,"The smell of this trash is killing me!"],[2356,2488,"Baby, don't be mad."],[2532,2706,"You've had a hard time,"],[2706,2828,"but I had no choice."],[3124,3202,"Look,"],[3202,3354,"I got you a new one."],[3366,3512,"Just bear with it a little longer."],[3512,3680,"This crappy teddy bear again?!"],[3696,3896,"When will this finally come to an end?!"],[3896,3980,"Soon, soon."],[3980,4120,"I'm my mom's only son,"],[4120,4204,"and what my family owns"],[4204,4334,"will be mine sooner or later."],[4334,4502,"Once I fully secure the inheritance,"],[4502,4660,"I'll immediately make Luna leave with nothing!"],[4660,4830,"Then I'll marry you in style"],[4830,5008,"and make you the wife of the richest man."],[5016,5120,"How does that sound?"],[5120,5232,"The wife of the richest man?"],[5329,5416,"Jakey,"],[5416,5539,"then you'd better hurry up."],[5544,5680,"I don't want to wait anymore!"],[5768,5902,"Cici Barnes."],[5902,5990,"For the suffering"],[5990,6146,"you caused my daughter-in-law,"],[6146,6382,"I'll make you pay it back with interest"],[6382,6690,"and settle every single score."]],"4":[[0,108,"Luna,"],[120,368,"for the sake of this family and the company,"],[368,528,"you've worked so hard you've lost weight."],[528,720,"It breaks my heart to see you like this."],[720,866,"I'm fine, Mom."],[866,1014,"It's all part of my duty."],[1014,1264,"Rest assured, as long as I'm here,"],[1264,1516,"no one can take away what belongs to you."],[1560,1634,"Jakey,"],[1634,1800,"that wicked Luna is back."],[1800,1950,"What should we do?"],[1988,2222,"Don't panic. Let me think."],[2394,2536,"Say,"],[2536,2846,"if we take a confidential file"],[2846,2966,"and stuff it into the book"],[2966,3162,"Luna reads all the time,"],[3162,3376,"then bring people to search for it..."],[3376,3622,"Will that work?"],[3622,3732,"What if Mom doesn't believe it?"],[3732,3930,"She cares about company profits most."],[3939,4078,"I'm sure she'll..."],[5130,5256,"Where is my confidential file?"],[5256,5368,"Has anyone seen it?"],[5368,5528,"That's top secret company information!"],[5605,5716,"What file?"],[5716,5830,"I didn't see anything."],[5830,5984,"You were the only one in the study last night."],[5984,6126,"Did you take it?"],[6189,6366,"I went to bed very early last night."],[6366,6538,"I didn't go to the study at all."],[6908,7002,"Mom!"],[7006,7126,"This file is critical to the company's"],[7126,7234,"next major project."],[7234,7330,"If it gets leaked,"],[7344,7494,"the consequences will be unimaginable!"],[7554,7808,"Don't panic. You'll find it."],[7940,8038,"I must find it now."],[8038,8244,"Mom, for the sake of the company,"],[8244,8426,"I demand to search everyone's room."],[8472,8740,"Let's start with Luna's room!"],[9320,9540,"Jake, what's that supposed to mean?"],[9540,9700,"Why did you get so worked up?"],[9774,9922,"Do you have a guilty conscience?"],[9922,10054,"Search all you want."],[10054,10268,"I have nothing to hide!"],[10268,10484,"Really? We'll see about that."],[10568,10638,"Mr. Parker,"],[10638,10730,"we found the file."],[10730,10916,"It was in the book Mrs. Parker reads the most."],[10994,11090,"Impossible!"],[11092,11220,"I don't even know the file exists!"],[11646,11796,"I knew it!"],[11796,11948,"You've been caught red-handed."],[11948,12032,"The Parkers"],[12032,12234,"will never tolerate a backstabber like you!"],[12288,12502,"Mom, I want to divorce her"],[12502,12626,"and make her leave with nothing!"]],"5":[[70,166,"You b**tard!"],[166,310,"Kick Luna out with nothing?"],[310,382,"She secured several"],[382,494,"of the company's projects."],[500,626,"Do you take me for a senile old fool?"],[642,682,"Mom,"],[716,782,"but the file"],[832,1008,"was found right in Luna's possession."],[1026,1192,"Does that prove she took it?"],[1200,1318,"There is a mole in this house"],[1318,1426,"trying to frame Luna!"],[1568,1646,"Mom."],[1954,2058,"You had better pray"],[2294,2576,"that I don't find out who the mole is."],[2640,2726,"Or else..."],[3050,3176,"To catch this traitor,"],[3188,3374,"from now on, without my permission,"],[3380,3530,"no one is allowed to take a step"],[3530,3630,"in or out of the house."],[3642,3682,"Mom,"],[3716,3796,"how can you do this?"],[3854,3948,"Take him to his room."],[3988,4074,"Don't let him out."],[4221,4285,"Mom,"],[4304,4380,"lock me up if you want,"],[4380,4488,"but please give me my bear!"],[4512,4566,"In your dreams!"],[4580,4694,"You're a grown man."],[4700,4794,"Can't you live"],[4794,4886,"without a toy bear?"],[4900,4968,"Take him away!"],[4968,5034,"Yes, Miss James."],[5062,5108,"Mom!"],[5594,5700,"Miss James, as you instructed,"],[5700,5836,"Mr. Parker has been locked in his room."],[5857,5990,"What should be done with this bear?"],[6200,6312,"Take it to the storage room."],[6312,6486,"A grown man is weirdly attached"],[6486,6598,"to a toy bear."],[6652,6752,"It's absolutely shameless!"],[6802,6860,"Yes, ma'am."],[7092,7193,"It's quite heavy."],[7252,7354,"It's just an inanimate object."],[7354,7468,"Don't so gentle with it."],[7468,7528,"Just drag it away!"],[7546,7598,"Yes."],[7642,7864,"Just you wait, you b**ch!"],[7872,8000,"Once I'm in charge,"],[8004,8174,"I'll make you kneel and beg me!"]],"6":[[316,464,"You old hag!"],[470,592,"How dare you treat me like this!"],[630,760,"When I become the richest man's wife,"],[792,942,"you'll be the first one I destroy!"],[1222,1316,"Water..."],[1392,1482,"Water..."],[1538,1650,"I need water."],[1984,2078,"Water..."],[2324,2382,"Cici."],[2406,2500,"Are you okay?"],[2606,2766,"Jakey!"],[2880,3064,"I'm tired and hungry."],[3140,3346,"It's all that b**ch Luna's fault!"],[3346,3520,"She did this to me!"],[3596,3685,"Shh."],[3745,3836,"Keep your voice down."],[3958,4038,"Get up."],[4410,4508,"Come with me."],[5321,5486,"I'll take you to get something to eat."],[5486,5598,"Okay."],[6756,6818,"Here."],[6837,6928,"Slow down."],[6928,6998,"Don't choke."],[6998,7118,"When I become the richest man's wife,"],[7162,7258,"the first thing I'll do is"],[7258,7384,"kick that b**ch Stella out of the house!"]],"7":[[1030,1098,"Jake,"],[1124,1254,"why are you still up at this hour?"],[1258,1338,"What are you doing?"],[1372,1436,"Mom."],[1436,1570,"I was hungry,"],[1570,1680,"so I came down for a snack."],[1970,2086,"For a snack?"],[2120,2242,"Why did you bring that with you?"],[2342,2468,"Is there"],[2628,2820,"something special"],[3118,3288,"inside this teddy bear?"],[3772,3834,"Forget it."],[3870,3972,"It's just a bear."],[4016,4118,"Keep it if you like."],[4150,4272,"Get some rest after you eat."],[4300,4430,"We have important business tomorrow."],[4432,4560,"Mom, what is it?"],[4596,4916,"It's about the mole in our family, obviously."],[4950,5122,"Who is it? Is it Luna?"],[5250,5312,"What do you think?"],[5366,5622,"You'll find out tomorrow."],[6856,6980,"That scared me to death!"],[6980,7160,"Cici, did you hear that?"],[7172,7270,"My mom is finally going to"],[7270,7382,"kick Luna out of our house!"],[7382,7492,"We're finally going to make it!"],[7492,7630,"My family fortune will soon be ours!"]],"8":[[66,142,"Luna,"],[154,299,"there's a company meeting tonight."],[316,391,"Come with me."],[429,525,"Okay."],[529,702,"Jake, you come along too."],[787,862,"Mom,"],[866,1041,"do I really have to go?"],[1051,1271,"I'm not feeling well."],[1300,1446,"Others can skip it,"],[1470,1591,"but you must go."],[1929,2087,"Mom, wait for me."],[3185,3287,"Gone?"],[3347,3460,"Are they all gone?"],[3641,3733,"Great!"],[3737,3981,"This big house is all mine!"],[4620,4779,"The richest wife's bed"],[4783,4983,"sure is nice!"],[6670,6868,"I left the mole's information and evidence"],[6875,7019,"on the study desk."],[7050,7116,"Jake,"],[7120,7266,"go to the office first."],[7270,7337,"I'll wait here"],[7341,7466,"and have Carter come pick me up."],[7525,7595,"Mom,"],[7605,7829,"can't we just have Carter bring it over?"],[7837,7904,"There's no time."],[7908,7987,"Luna,"],[7991,8063,"go back with me."],[8125,8191,"Mom,"],[8209,8313,"I'll go back and get it."],[8325,8418,"You guys go to the office."],[8437,8579,"Do you even know which document it is?"],[8620,8704,"Let's go, Luna."],[10412,10638,"Pick up!"],[10746,10862,"Cici, answer the phone!"],[10866,11013,"Pick up!"],[12310,12604,"It's time to wrap up this show."],[13602,13696,"You..."]],"9":[[0,196,"It's time to wrap up this show."],[754,818,"You..."],[818,952,"Why did you come back?"],[976,1070,"Who are you?"],[1070,1220,"You... you..."],[1220,1360,"Luna, stay calm."],[1600,1694,"Here,"],[1694,1788,"take your medicine."],[2233,2324,"Don't get worked up."],[2324,2372,"I've got you."],[2836,3032,"Miss Smith, I'm sorry."],[3056,3254,"I didn't mean to scare you."],[3308,3484,"I just love Jakey too much."],[3542,3660,"Luna,"],[3664,3792,"look at your health,"],[3804,3934,"you have an episode at the slightest thing."],[4016,4109,"Jakey is currently"],[4113,4328,"in the prime of his life right now."],[4332,4456,"In your condition,"],[4456,4580,"how could you possibly take care of him?"],[4588,4847,"Why don't you just let me take your place?"],[5472,5570,"Mom,"],[5570,5690,"one doesn't simply walk into"],[5690,5892,"this house just because they want to,"],[6000,6088,"right?"],[6192,6264,"Yes."],[6264,6430,"If you want to join the Parkers,"],[6430,6552,"you're welcome to."],[6764,6852,"However,"],[6852,7060,"you have to pass Mom's evaluation."],[7060,7190,"If you are successfully acknowledged"],[7190,7294,"as a daughter-in-law,"],[7294,7436,"I'll divorce him immediately."],[7436,7536,"I won't even look back."],[7544,7676,"How will you evaluate me?"]],"10":[[0,179,"The Parker daughter-in-law test."],[183,379,"As long as you pass,"],[429,599,"you will be the future mistress"],[625,716,"of the Parker family."],[754,845,"Are you serious?"],[865,958,"Of course."],[1003,1157,"The Parker family isn't a marketplace"],[1195,1379,"where just any riffraff can waltz in."],[1416,1587,"If you want to marry into our family,"],[1604,1720,"you have to be tested."],[1721,1816,"What kind of test?"],[1838,1950,"I can definitely pass it!"],[2063,2129,"Mom,"],[2133,2287,"why don't you properly explain"],[2291,2499,"the rules of the house to her?"],[2947,3233,"First, etiquette and class."],[3259,3420,"Looking at you right now,"],[3431,3539,"you can't even manage"],[3554,3774,"the basics of being neat and presentable."],[3791,3945,"Well..."],[3950,4174,"I can clean myself up right away!"]],"11":[[41,129,"Mom!"],[158,258,"You..."],[791,912,"What's going on?"],[925,1011,"Jakey."],[1016,1167,"Your mom just promised me"],[1170,1304,"that as long as I pass the assessment"],[1308,1417,"to be a Parker daughter-in-law,"],[1420,1585,"I can properly marry you!"],[1700,1758,"Mom,"],[1762,1983,"is this true?"],[2112,2236,"I, Stella James,"],[2287,2441,"always keep my word."],[2612,2654,"Yes."],[3329,3441,"Luna,"],[3445,3646,"you're finally getting out of our house!"],[3841,3949,"Then I hope"],[3954,4362,"Miss Barnes passes the assessment."],[4391,4499,"Just you wait!"],[4504,4715,"The position of Mrs. Parker"],[4720,4899,"is as good as mine!"],[4995,5216,"Mom, when does the assessment start?"],[5258,5366,"We'll do our best!"]],"12":[[91,209,"If you want to join our family,"],[225,404,"you must follow our rules."],[492,734,"This is Mrs. Parker's Duties Handbook."],[1000,1108,"Thank you, Auntie."],[1112,1245,"I'll study it carefully!"],[1425,1595,"Get up at 5:00 AM"],[1600,1762,"and prepare breakfast for the whole family?"],[1900,2017,"There must be three Chinese"],[2017,2125,"and three Western dishes,"],[2129,2320,"with no repeats for a week."],[2691,2804,"All floors must be cleaned"],[2808,3042,"by kneeling and wiping with a rag."],[3046,3404,"The household budget is $2,000?!"],[3537,3874,"Auntie, there must be a mistake here!"],[3879,4066,"What can you do with $2,000?"]],"13":[[0,116,"We built our fortune"],[120,262,"on diligence and thrift."],[266,483,"If you can't even manage this budget,"],[584,689,"how can you be the lady of the house?"],[1150,1354,"I have to hand-wash all the clothes?"],[1360,1632,"That's right. Especially..."],[1650,1829,"Mom's traditional silk dresses."],[1890,2027,"You will face the consequences"],[2094,2264,"if you ruin even one."],[2286,2483,"Mom, don't think it's too..."],[2487,2633,"What?"],[2638,2829,"Do you think a Parker daughter-in-law"],[2833,3033,"shouldn't have these basic skills?"],[3109,3162,"Cici."],[3255,3470,"As long as I become the richest wife,"],[3475,3637,"this is nothing!"],[3757,3914,"No problem, Auntie."],[3946,4203,"I can do all of this."],[4317,4429,"Very good."],[4563,4649,"Luna."],[4654,4741,"Mom."],[4805,5108,"As the winner of the last assessment,"],[5118,5274,"you have plenty of experience."],[5310,5420,"So this time,"],[5425,5691,"you will serve as the chief examiner"],[5720,5862,"to supervise the entire process"],[5866,5970,"of Miss Barnes's evaluation."],[5975,6137,"What did you say?"]],"14":[[100,195,"Miss Barnes,"],[229,445,"I will judge strictly by the book."],[495,574,"I won't play favorites."],[695,862,"Then I'll rely on you, Miss Smith."],[866,1087,"Please guide me well."],[1118,1222,"Of course."],[1233,1412,"I will make sure to teach you"],[1416,1524,"very thoroughly."],[1597,1672,"B*tch."],[1718,1873,"Just you wait!"],[2109,2234,"It's 5:05."],[2267,2358,"You're late."],[2379,2616,"Breakfast must be ready by 7:00 a.m."],[2625,2787,"Three Chinese and three Western dishes."],[2791,2945,"And none of them can be repeated."],[2956,3087,"It's all in the handbook."],[3100,3229,"I know, I know."],[3233,3370,"What stupid rules."],[3719,4049,"There are shells in the eggs. Redo it."],[4329,4566,"So demanding."],[5053,5216,"You're wasting ingredients."],[5228,5308,"Points deducted."],[5312,5412,"You!"],[5826,5912,"Mom."],[5916,6229,"Looks like Miss Barnes is working very hard."]],"15":[[1042,1204,"Is this the breakfast you prepared?"],[1204,1522,"I... I'm not very good at this."],[1522,1696,"Our daughter-in-law should know nothing"],[1696,1810,"of the phrase \"not good at.\""],[1810,2000,"You failed the breakfast task."],[2000,2172,"Next task: Cleaning."],[2172,2306,"Get on your knees and use a rag"],[2306,2404,"to wipe all the floors."],[2404,2632,"On... on my knees?!"],[3624,3714,"You missed the corners."],[3744,3824,"Do it again."],[3824,4074,"Luna Smith, you're doing this on purpose!"],[4074,4300,"The test judges the work, not the person."],[4300,4400,"Please continue."],[4674,4800,"Next task:"],[4800,4936,"Hand-washing the laundry."]],"16":[[626,774,"Why can't I use the washing machine?"],[1146,1304,"The clothes aren't clean."],[1304,1404,"Wash them again."],[1404,1566,"I quit!"],[1589,1753,"You're deliberately making things difficult."],[1766,1948,"Forfeiting the assessment is considered"],[1948,2064,"voluntarily giving up your right"],[2064,2202,"to become the Parkers' daughter-in-law."],[3022,3324,"Luna Smith, just you wait!"],[3606,3770,"How did she do today?"],[3928,4032,"She's hanging in there."],[4032,4146,"She is quite resentful,"],[4146,4274,"but she didn't dare to walk away."],[4274,4422,"It seems the promise of being a wealthy wife"],[4422,4524,"is quite the lure."],[4577,4754,"Let's see how much longer she lasts."],[4776,4928,"Mom, don't worry."],[4928,5084,"We control the assessment standards."],[5084,5318,"It won't be easy for her to pass."]],"17":[[240,466,"I'm exhausted."],[700,874,"Jakey!"],[877,1160,"I can't take it anymore."],[1296,1444,"I have to scrub the floors on my knees"],[1444,1600,"and wash the curtains by hand."],[1600,1796,"My back is breaking,"],[1796,1996,"and my hands are raw."],[2190,2406,"My poor baby."],[2406,2574,"This is inhumane!"],[2594,2780,"Your mom and Luna"],[2780,2948,"are just torturing me on purpose!"],[2948,3134,"Just bear with it until you pass."],[3134,3192,"But..."],[3200,3300,"Cici,"],[3344,3480,"once you become Mrs. Parker,"],[3480,3644,"servants will do all this work."],[3644,3810,"Then you can buy as many bags"],[3810,3918,"as you want."],[3918,4028,"You'll be able to enjoy life"],[4028,4112,"however you please."],[4112,4198,"In all of Heatherfield,"],[4212,4344,"no one would dare disrespect us."],[4364,4448,"By then,"],[4448,4576,"even my mom and Luna"],[4576,4730,"will have to answer to us."],[4730,4988,"Just endure this for a little longer."],[4988,5118,"Is that true?"],[5118,5256,"You're not lying to me?"],[5324,5416,"I promise."],[5416,5614,"As long as you get through this,"],[5614,5728,"I'll immediately find a way"],[5728,5862,"to make sure you pass."],[6020,6262,"Fine, I'll wait a bit longer."],[6282,6516,"All to be the wife of the richest man."],[6964,7080,"Jake Parker,"],[7080,7238,"how dare you betray me."],[7238,7422,"I'll make you and your little mistress"],[7534,7680,"pay for this."]],"18":[[848,982,"Dishwashing standards:"],[982,1144,"No grease, no water marks."],[1144,1348,"Wash these again."],[1468,1596,"I'll endure it."],[1632,1794,"It's almost over."],[1794,1966,"Once that old bat announces the results,"],[1966,2138,"Jakey and I will rule the Parker family!"],[2316,2464,"Don't worry, Miss Smith."],[2524,2682,"I'll do a good job."],[2682,2806,"Miss Barnes,"],[2806,3022,"if you drop the ball at the last minute,"],[3022,3226,"all your efforts will be wasted."],[3297,3575,"Don't worry, I won't."],[4034,4354,"Finally, I've made it through."],[4354,4490,"Tomorrow,"],[4490,4820,"I'll officially be Mrs. Parker!"],[4826,5066,"That's right. Mom said before"],[5066,5172,"that once you pass the test,"],[5172,5268,"she'll officially accept you."],[5268,5492,"By then, our family assets..."],[5539,5704,"Once you secure the inheritance,"],[5704,5922,"the first thing to do is kick Luna out!"],[5922,6072,"Shh, keep it down."],[6117,6220,"After tomorrow,"],[6220,6432,"we'll call the shots in the family."],[6432,6506,"By then,"],[6506,6634,"you can buy whatever you want."]],"19":[[274,392,"Time is almost up."],[392,566,"Mom should be back soon"],[566,700,"to announce the results."],[835,884,"It's fine."],[1016,1352,"I'm about to become Mrs. Parker."],[1424,1670,"Mrs. Parker, Mr. Parker, bad news!"],[1670,1872,"What's the matter? Why the panic?"],[1872,1952,"Miss James..."],[1952,2116,"Miss James got into a serious car accident"],[2116,2254,"on her way back!"],[2254,2436,"What? What happened to Mom?"],[2440,2556,"She has been rescued,"],[2578,2704,"but she is seriously injured and in a coma."],[2724,2882,"Dr. Young has already been called."],[2884,3062,"A coma? How is that possible?"],[3062,3148,"Take me there now!"],[3662,3806,"Old hag!"],[3806,4098,"Of all the times, why did she have to fall"],[4098,4254,"into a coma right at this critical moment?"],[4274,4482,"What about my evaluation?!"],[4482,4606,"No,"],[4606,4772,"I can't just let this go."],[4772,4930,"Now that the old hag is in a coma,"],[4940,5142,"maybe this is actually my chance."]],"20":[[70,172,"Miss Smith,"],[274,444,"these documents need your signature now."],[444,670,"Also, regarding the board..."],[915,1241,"Tell them that Miss James is out of danger"],[1250,1366,"and business will continue as usual."],[1369,1493,"Ask them to stay calm."],[1734,1868,"Yes."],[2028,2164,"I wonder how Mom"],[2164,2308,"is doing right now."],[2308,2452,"Miss James is out of danger,"],[2452,2574,"but Dr. Young says"],[2574,2716,"she still needs to stay for observation."],[3520,3721,"Mom, you're awake."],[5002,5084,"Mom."],[5550,5732,"Auntie, how are you feeling?"],[5799,6082,"Luna, my dear daughter-in-law."],[6262,6430,"Mom, what are you saying?"]],"21":[[0,120,"What are you saying?"],[120,212,"Dr. Young,"],[230,354,"what's wrong with her?"],[354,490,"Why doesn't she recognize me?"],[490,666,"The test results show"],[666,858,"she has selective amnesia."],[886,1002,"Amnesia?"],[1002,1160,"Yes."],[1160,1364,"It's hard to say when she'll recover."],[1364,1472,"It could be a few months,"],[1472,1582,"or maybe even longer."],[1582,1674,"In the meantime,"],[1674,1794,"do not agitate her."],[1794,1888,"Try to play along"],[1888,2006,"with her reality and the people in it."],[2010,2188,"That will help her recover."],[2594,2876,"Luna, don't worry. I'm fine."],[3008,3088,"Mom."],[3158,3242,"I'm your..."],[3242,3350,"Miss Smith,"],[3350,3578,"please do as the doctor tells you."],[3598,3838,"Mom, I'm just glad you're okay."],[3838,3976,"I was worried sick."],[3976,4214,"Don't worry. I'm fine."],[4214,4380,"Mom."],[4516,4684,"Mom, I'm here too."],[4684,4790,"I'm Jake."],[4790,4930,"Jake?"],[4930,4978,"Yes, Mom."],[4996,5134,"You're a grown man now."],[5134,5316,"You must treat Luna right, okay?"],[5316,5558,"I know. I'll take good care of her."],[6026,6192,"Is she the new maid?"]],"22":[[0,190,"Is she the new maid?"],[190,516,"Mom, she's the new maid we just hired."],[516,588,"Just call her Smith."],[588,684,"Smith."],[684,828,"Go get me a glass of water."],[960,1220,"Yes, Miss James."],[1220,1446,"So, how is the company?"],[2108,2214,"Miss James,"],[2220,2316,"here is your water."],[2522,2680,"Luna, you're the thoughtful one."],[2710,2886,"Mom, if you're tired,"],[2886,3034,"just get some rest."],[3034,3208,"I'll handle things at home."],[4040,4224,"Yes, my mom is awake."]],"23":[[150,334,"Yes, my mom is awake."],[334,470,"She's stable."],[534,642,"The company?"],[714,912,"Don't worry, I'm handling the company."],[1102,1238,"Sleep a while if you're tired."],[1238,1384,"We're all here with you."],[1384,1524,"That's right, Mom."],[1524,1734,"Stay with me then."],[1734,1912,"Yes, we'll stay with you."],[3198,3362,"You're done here."],[3362,3460,"Get out."],[3506,3732,"Don't be an eyesore to Mom."],[3950,4088,"When Mom recovers her memory,"],[4110,4252,"I will settle this score"],[4252,4520,"and make you pay with interest."]],"24":[[272,360,"Luna,"],[390,482,"did you hear me?"],[512,728,"You're just the Parkers' maid now."],[728,818,"If you know what's good for you,"],[824,930,"stay out of my sight."],[932,1076,"Don't get between Jakey and me."],[1111,1188,"Cici,"],[1196,1352,"don't celebrate too early."],[1366,1500,"Her amnesia is only temporary."],[1597,1688,"So what?"],[1688,1768,"Right now,"],[1792,2186,"I'm rightful Mrs. Parker now."],[2268,2358,"Enough, Cici."],[2385,2506,"Why waste your breath on her?"],[2532,2736,"You, hurry back and pack my mom's things."],[2740,2874,"We're taking her home to recover."],[2939,3065,"Do your job as a maid."],[3238,3420,"Just quit acting all high and mighty."],[3672,3742,"Jakey,"],[3800,4048,"the house is finally peaceful now."],[4074,4224,"Just thinking about that b**ch Luna"],[4252,4356,"ending up as a maid"],[4362,4506,"makes me so happy!"],[4520,4594,"Of course."],[4630,4842,"Now, you call the shots in this house."],[4992,5142,"That b**ch Luna!"],[5192,5346,"How dare you she still stay here!"],[5418,5514,"Every time seeing her"],[5514,5636,"acting all high and mighty"],[5664,5746,"makes me sick!"],[5754,5820,"Just bear with it."],[5820,5954,"We can't just kick her out right now."],[5994,6074,"Once things settle down..."],[6074,6192,"I'm running out of patience!"],[6194,6310,"I have to find a way"],[6310,6494,"to make her leave on her own."]],"25":[[1560,1666,"Luna Smith."],[1926,2074,"Let's see how you"],[2090,2274,"show your face after it's ruined!"],[3250,3340,"Perfect."],[3429,3674,"Just wait until tomorrow."]],"26":[[88,178,"I sneaked back home"],[178,334,"to prepare a surprise for Luna."],[580,722,"This maid is so bold."],[808,956,"She's using better things than her master."],[1876,1990,"My dear Luna,"],[2022,2214,"why is she using such a plain facial mask?"],[2236,2424,"This is beneath her status."],[2446,2670,"No, I have to swap them."],[4606,4734,"There, that's better."],[4764,4886,"My dear daughter-in-law Luna"],[4898,5018,"deserves to use the best!"],[5062,5164,"I really am such a"],[5164,5324,"thoughtful and caring mother-in-law!"]],"27":[[576,700,"This isn't my mask."],[804,1018,"Whatever, maybe Mom bought it for me."],[4604,4802,"Oh, Luna."],[4846,5024,"The mask I spiked"],[5024,5266,"should be on your face by now."],[5280,5474,"When you find your face ruined,"],[5504,5644,"I'll enjoy watching you suffer."],[5693,5778,"Why..."],[5794,5980,"Why does this mask feel so strange?"],[6048,6222,"Maybe it's just really potent?"],[6868,6936,"Well, well."],[6994,7096,"Miss Smith,"],[7096,7236,"you sure know how to pamper yourself."],[7236,7500,"But if you use things that aren't yours,"],[7500,7812,"it might just ruin your face."],[7842,7958,"I'll give that advice right back to you."],[7974,8040,"What isn't yours"],[8040,8178,"was never meant to be yours."],[8178,8258,"You!"],[8272,8400,"Tell you what, Luna."],[8400,8544,"Everything the Parkers own"],[8586,8684,"belongs to me now."],[8718,8952,"Including Jakey."],[9026,9106,"You..."],[9244,9324,"No way."],[9382,9462,"Your face..."],[9516,9602,"How is your face...?"]],"28":[[35,280,"Wait, something feels wrong."],[500,580,"This..."],[592,726,"This isn't my mask!"],[732,910,"You know exactly what you added"],[920,1042,"to the mask, don't you?"],[1440,1700,"My face! Luna Smith!"],[1720,1866,"I'm not done with you!"],[1876,2086,"Go make me a cup of hand-ground coffee."],[2094,2198,"We have a coffee machine."],[2230,2342,"Machine-ground coffee is not"],[2342,2480,"as good as hand-ground coffee."],[2482,2724,"Now that I am Mrs. Parker,"],[2724,3002,"I deserve the highest quality service!"],[3014,3088,"Cici,"],[3128,3278,"it's fine to realize your act in front of Mom,"],[3286,3440,"but do you really think you're Mrs. Parker?"],[3468,3678,"Luna, you b*tch!"],[3833,4016,"You don't have to make me hand-ground coffee."],[4055,4228,"Give me a shoulder massage."],[4245,4340,"Do you hear me?"],[4344,4564,"I am Mom's favorite daughter-in-law now!"],[4568,4700,"So you ought to give me a massage."],[4703,4742,"Luna."],[4742,4826,"What's the matter?"],[4852,4980,"Who's giving you a hard time?"],[4990,5258,"Mom, my shoulders are a bit sore."],[5258,5400,"I wanted Smith to massage them for me,"],[5400,5628,"but she seems unwilling."],[5790,5874,"Smith,"],[5874,5996,"that is not right."],[6008,6146,"When your master asks for a massage,"],[6146,6266,"you should serve them well."]],"29":[[22,152,"Yes, Miss James."],[700,786,"Ouch!"],[804,952,"Why are you so clumsy?"],[952,1044,"Smith,"],[1044,1256,"you're too unprofessional."],[1262,1380,"I can't believe our servants"],[1380,1506,"can't even do massages properly."],[1514,1560,"Luna,"],[1578,1682,"let me show you"],[1682,1812,"what a professional massage is."],[1848,1984,"I learned this back in the day."],[1984,2200,"Mom, I can't let you do that."],[2234,2344,"Don't be polite with me."],[2388,2522,"You work so hard for this family."],[2544,2676,"It's only right that I give you a massage."],[2906,2994,"Relax, Luna."],[3048,3206,"For a professional massage,"],[3206,3324,"the pressure must go deep."],[3354,3414,"Mom!"],[3452,3544,"Mom, be gentle!"],[3584,3700,"You're going to break my bones!"],[3764,3936,"I've barely started."],[4014,4144,"Pain means there's a blockage,"],[4146,4264,"and a blockage causes pain."],[4264,4470,"Your shoulders are way too stiff!"],[4472,4622,"Mom, that's enough, that's enough!"],[4710,4804,"Okay, okay."],[4820,4970,"Why can't you handle a little pain?"],[5022,5092,"Just bear with it."],[5228,5390,"Mom!"]],"30":[[10,112,"How is it, Luna?"],[132,270,"Do you feel more relaxed now?"],[270,346,"Yes,"],[356,690,"much better. Thanks, Mom."],[719,846,"Oh, right, there's coffee too."],[852,930,"Mom."],[958,1032,"Mom,"],[1042,1126,"don't bother."],[1126,1222,"It's no trouble."],[1222,1306,"Coming right up."],[1782,1859,"Here."],[1866,1910,"Luna,"],[1910,2050,"I just brewed this for you."],[2058,2212,"It's absolutely fresh and aromatic!"],[2225,2490,"Ah! I'm sorry!"],[2542,2614,"It burns!"],[2618,2665,"My hand slipped."],[2731,2830,"I didn't mean to!"],[2830,2936,"Are you okay?"],[2942,3080,"Mom, stop wiping!"],[3080,3178,"It hurts! It hurts!"],[3192,3376,"Why am I so clumsy?"],[3376,3515,"Are you okay?"],[3520,3682,"Hurry up to the third floor and get changed."],[3682,3800,"Rinse it with cold water."],[4567,4672,"I'm getting old."],[4796,4942,"I can't do anything right."],[5010,5070,"Smith,"],[5136,5248,"please clean this up."],[5248,5340,"Yes, Miss James."]],"31":[[260,372,"There's so much to do at the company."],[472,562,"I'm exhausted."],[1220,1320,"What happened?"],[1320,1468,"Look what your mother did!"],[1486,1580,"How did this happen?"],[1586,1700,"You ask how?"],[1706,1800,"Your mom splashed me."],[1800,1942,"She said she was pouring me coffee,"],[1942,2080,"but she spilled it all over me!"],[2080,2208,"And my shoulder,"],[2208,2322,"it's sore and hurting now."],[2322,2446,"Mom has amnesia."],[2446,2532,"She didn't mean to."],[2532,2610,"Keep your voice down."],[2610,2672,"Don't let her hear you!"],[2682,2762,"Jake Parker!"],[2762,2892,"I thought since she had amnesia,"],[2892,3050,"I could finally live a comfortable life."],[3050,3281,"But look, have I had a single peaceful day?"],[3296,3390,"Why are you yelling at me?"],[3400,3502,"Can't you just bear it?"],[3502,3592,"I've had enough!"],[3592,3720,"I failed the assessment,"],[3720,3846,"and now I have to grovel"],[3846,3952,"and suffer like this."],[3952,4056,"The richest man's wife?"],[4056,4250,"I'm treated worse than a maid!"],[4250,4320,"Cici Barnes!"],[4320,4480,"Are you crazy? Walls have ears!"],[4480,4586,"I am crazy!"],[4586,4730,"You people drove me crazy!"],[4730,4828,"It must be Luna"],[4828,4922,"pulling the strings!"],[4922,5046,"Your mom gave me massages"],[5046,5186,"and served me coffee."],[5186,5342,"Luna must have put her up to it!"],[5342,5486,"Mom just wants the best for you."],[5492,5632,"What does this have to do with Luna?"],[5640,5728,"It is Luna's doing."],[5728,5880,"It must be!"],[5886,6062,"I'm gonna make her pay!"],[6120,6226,"Hey, where are you going?"],[6262,6382,"Don't try to stop me!"],[6382,6432,"Today,"],[6432,6652,"I'm going to ruin b**ch's face!"]],"32":[[216,288,"Well, well."],[288,406,"Instead of sleeping at night,"],[406,536,"you're out here wandering around."],[568,630,"What kind of trouble"],[630,728,"are you looking to stir up now?"],[865,918,"Move aside."],[918,1018,"I'm not moving."],[1018,1122,"Luna Smith,"],[1146,1388,"don't think I don't know what you're up to."],[1398,1616,"You play the victim in front of Stella,"],[1616,1798,"but sow discord behind my back!"],[1798,1888,"Am I right?"],[1928,2076,"I don't know what you're talking about."],[2076,2186,"Drop the act!"],[2186,2456,"That old hag splashed coffee on me"],[2456,2546,"and gave me a massage today."],[2546,2666,"Did you put her up to it?"],[2666,2798,"Well, you insisted on being so pretentious."],[2798,2858,"You b**ch!"],[2858,3036,"Who do you think you are?"],[3244,3422,"Cici, remember your place!"],[3422,3616,"I'm the lady of the Parker family."],[3616,3764,"You're nothing but a servant."],[3764,3896,"So what if I hit or scold you?"],[3896,4004,"Stop!"],[4004,4130,"What are you doing?"],[4164,4208,"Mom,"],[4208,4336,"she talked back to me!"],[4336,4490,"She's just a maid."],[4490,4546,"Luna,"],[4546,4666,"how can you behave like this?"],[4674,4790,"She is a maid."],[4790,4902,"If she does something wrong,"],[4902,5030,"you can just tell me."],[5030,5164,"Why do you have to hit her?"],[5164,5236,"Mom,"],[5236,5406,"you're yelling at me over a maid?"],[5406,5574,"I'm your daughter-in-law!"],[5584,5716,"I know you're my daughter-in-law,"],[5724,5866,"but as a Parker,"],[5866,5976,"you can't be so unruly."],[5976,6056,"Bullying servants"],[6056,6236,"would be a disgrace if word got out."],[6236,6316,"Apologize to her."],[6366,6478,"Does she deserve it?"],[6478,6604,"You old fool!"],[6604,6750,"You don't remember anything anyway."],[6750,6906,"I've had enough of you!"],[7144,7254,"Mom!"]],"33":[[726,980,"Look what you've done!"],[986,1100,"I didn't mean to."],[1122,1286,"It's her fault for taking sides."],[1340,1452,"I barely touched her!"],[1472,1626,"If anything happens to Mom,"],[1626,1749,"you'll pay for this!"],[1942,2052,"You should leave."],[2090,2190,"She needs to rest."],[2330,2412,"Go, get out."],[2412,2507,"Don't get in the way here!"],[3384,3464,"Mom,"],[3560,3659,"you're awake?"],[4028,4125,"Luna,"],[4244,4354,"it's been hard on you."],[4580,4660,"Mom,"],[4720,4912,"you remember me?"],[5498,5628,"I remember everything."],[5654,5818,"Thanks to that shove from Cici."],[5938,6018,"That's great."],[6094,6202,"Do they still think"],[6202,6330,"that I'm confused?"],[6378,6450,"Yes."],[6450,6548,"When you fainted earlier,"],[6558,6670,"they were terrified."],[6770,7000,"Then we'll play along."],[7214,7390,"Jake and Cici"],[7390,7594,"are plotting to take over the company."],[7594,7824,"Here's what we'll do."],[7987,8047,"Okay."],[8060,8116,"I understand."]],"34":[[60,142,"Jakey,"],[142,280,"now that Mom is awake,"],[290,474,"do you think she'll remember anything?"],[516,614,"It was just a bump on the head."],[623,722,"She can't be."],[752,832,"Think positive."],[880,930,"Jakey,"],[930,1052,"this is our chance."],[1120,1210,"What chance?"],[1250,1342,"While she's just woken up"],[1342,1448,"and her mind is still foggy,"],[1460,1602,"get her to transfer the shares to you."],[1620,1764,"Then we can take over the company!"],[1780,1980,"Will that work?"],[1990,2068,"Mom used to guard"],[2068,2172,"against me like I was a thief."],[2186,2350,"Things are different now."],[2362,2514,"We'll sweet-talk her"],[2520,2712,"and say it's to stabilize the company."],[2724,2840,"And that once she recovers,"],[2840,2960,"we'll give it back to her."],[2960,2996,"Right."],[3052,3148,"Once we get the shares,"],[3166,3327,"we'll call the shots for the family!"],[3327,3480,"Right. Only with real power"],[3480,3706,"can we truly be in charge."],[3706,3744,"Good."],[3744,3932,"I'll have Carter prepare the documents,"],[3934,4040,"and we'll tell Mom tomorrow."],[4040,4074,"Okay."]],"35":[[167,266,"Mom,"],[274,382,"how are you feeling?"],[398,564,"You scared me yesterday."],[699,824,"It's all my fault."],[842,972,"Luna,"],[978,1128,"I know you didn't mean to."],[1448,1724,"Mom, don't worry about the company."],[1724,1804,"I'm taking care of it."],[1862,1998,"It's just that a few major shareholders"],[1998,2132,"are worried about your health,"],[2144,2258,"so everyone is on edge."],[2374,2482,"Then what should we do?"],[2534,2616,"How about"],[2616,2736,"you transfer some of the shares"],[2736,2842,"to my name for now?"],[2878,3012,"I'll exercise your authority for you"],[3032,3132,"to reassure them."],[3164,3274,"Once you recover,"],[3274,3358,"I'll transfer them back."],[3394,3450,"Sure."],[3450,3582,"Jake, you've grown up."],[3582,3722,"You can share my burden now."],[3844,3974,"Mom, you agreed?"],[3980,4024,"Yes."],[4028,4134,"Where's the contract?"],[4429,4614,"Here, sign here."],[4870,4916,"Mom,"],[4916,5024,"sign here!"]],"36":[[172,372,"Come on, Mom, sign here."],[1658,1732,"How's that?"],[1800,1868,"Looks good, right?"],[1868,2002,"Doesn't it look like that pig"],[2002,2128,"you raised when you were little?"],[2178,2258,"Mom,"],[2308,2440,"what on earth did you draw?"],[2458,2638,"This is a share transfer agreement."],[2670,2808,"You need to sign your full name!"],[2848,2968,"But this pig is so cute!"],[2968,3196,"It represents wealth flowing into our family."],[3198,3318,"A fat pig brings good fortune!"],[3324,3468,"The contract is ruined."],[3508,3644,"What kind of signature is this?"],[3688,3778,"What's wrong?"],[3880,4008,"Does my signature not count?"],[4038,4176,"Well then, let's not transfer anything."]],"37":[[6,86,"Wait,"],[138,332,"Mom, of course your drawing counts!"],[352,526,"It's just that legally, we need"],[526,668,"something a bit more formal."],[981,1128,"I'm sleepy."],[1146,1298,"I'm tired."],[1316,1428,"You should get out now."],[1514,1608,"Mom."],[2532,2668,"You're really something."],[2678,2796,"That pig's head"],[2796,2886,"has pissed them off."],[2984,3112,"They want to take my shares?"],[3146,3226,"No way!"],[3256,3384,"This is just the beginning."],[3434,3508,"Mom,"],[3508,3570,"I don't think"],[3570,3730,"they'll give up easily."],[3730,3959,"They must be planning their next move."],[3982,4134,"So, should we do something?"],[4140,4220,"It's fine."],[4224,4352,"Let them bring it on."],[4382,4508,"I'll deal with them all at once."],[4534,4584,"Luna."],[4590,4778,"Just play along with me."],[4786,4926,"I will, Mom."],[5048,5206,"The real show is just beginning."]],"38":[[312,392,"Mom,"],[442,652,"Cici really did tamper with your medicine."],[700,806,"I've already swapped out"],[806,950,"the vitamins she sends over every day."],[986,1120,"Since she couldn't get the shares,"],[1120,1286,"she wanted to make sure I never woke up."],[1310,1446,"She is truly vicious."],[1509,1657,"So, what's our next move?"],[1715,1883,"Since she wants to deliver the medicine,"],[1885,1990,"let her do it."],[2060,2202,"Go find Carter,"],[2226,2356,"and have him bring two bodyguards"],[2356,2460,"we can trust."],[2552,2720,"You want to"],[2720,2868,"catch her red-handed?"],[2902,3010,"I'm going to make sure"],[3028,3246,"she is completely exposed."],[3257,3337,"Okay."],[3714,3832,"Mom, it's time for your medicine."],[3930,4054,"You're truly thoughtful."],[4414,4530,"What are you doing?"],[4532,4726,"Mom, what is the meaning of this?"],[4732,4834,"The meaning?"],[4872,5046,"I'm catching the murderer"],[5046,5162,"who tried to poison me."],[5320,5464,"Luna discovered the medicine"],[5464,5610,"you tampered with long ago."],[5620,5750,"You got your memory back."],[5768,5844,"Oh, no,"],[5880,5966,"it wasn't me!"],[6014,6144,"It was Jake."],[6144,6238,"Jake made me do it!"],[6238,6304,"What's going on?"],[6304,6412,"What's all the noise?"],[6416,6494,"Jakey,"],[6494,6576,"tell Mom right now"],[6576,6738,"that you made me switch the medicine."],[6768,6868,"Tell her!"],[6898,7026,"What nonsense are you talking about?"]],"39":[[12,136,"When did I ever ask you to do"],[136,260,"something so heartless?"],[290,462,"Mom, I had no idea about this!"],[580,742,"Miss James! No, Auntie,"],[742,820,"I was wrong!"],[820,946,"I truly know I was wrong!"],[972,1106,"I was blinded by greed."],[1126,1306,"I shouldn't have coveted your assets."],[1350,1500,"Please, spare me just this once!"],[1520,1626,"Enough!"],[1760,2012,"Jake, I am so disappointed in you."],[2030,2140,"You are stupid and unfaithful!"],[2230,2384,"Mom, I'm sorry."],[2386,2532,"I didn't know she'd do something like that!"],[2532,2646,"Please forgive me this once."],[2649,2780,"From now on,"],[2780,2950,"you are no longer the General Manager."],[2950,3134,"All our assets under your name"],[3134,3230,"are being taken back."],[3230,3318,"Mom, don't!"],[3323,3506,"From now on, all family assets"],[3506,3670,"will be under my control."],[3686,3828,"Eventually, I will find"],[3828,3982,"someone worthy to entrust them to."],[4000,4132,"And that person is Luna."],[4192,4273,"Mom."],[4274,4546,"Take this woman to the police."],[4551,4712,"And throw Jake out too."],[4712,4810,"There is no longer a Jake"],[4810,4912,"in the Parker family."],[4940,5060,"No!"],[5061,5255,"Mom, don't! Mom!"]],"40":[[744,816,"Mom."],[995,1102,"Luna,"],[1208,1304,"I'd like to formally apologize"],[1304,1402,"for all the wrong things"],[1486,1608,"we did in the past."],[1628,1708,"I'm sorry."],[1936,2102,"It's good that you realize your mistakes."],[2164,2336,"We'll live an honest life from now on."],[2382,2546,"We plan to do long-term volunteer work"],[2561,2645,"to atone for our sins."],[2838,3068,"Just stay grounded and be an honest person."],[3677,3806,"Here, Luna."],[3907,4147,"Let's keep checking out your baby photos."],[4219,4369,"Mom, you're teasing me again."]]}