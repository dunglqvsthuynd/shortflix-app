17,"who was trying to leech off Dr. Dunce."],[842,984,"Now, Jasmine Bloom."],[992,1180,"Yeah, the legendary CEO"],[1180,1372,"isn't a whiny failure like yourself."],[1397,1480,"Discharged after"],[1480,1643,"getting one little boo-boo."],[1689,1931,"The CEO general is a hero."],[1931,2127,"He sacrificed his arm for this country."],[2164,2339,"God, what a boss."],[2398,2531,"Nothing like the little conniving"],[2531,2706,"sewer rat you are, huh?"],[2723,2898,"I don't know why Jasmine Bloom"],[2898,3023,"chose you, but hey,"],[3023,3153,"different strokes for different folks."],[3182,3399,"Doesn't matter what his background is."],[3415,3657,"Tobias is just as brave as the CEO."],[3695,4008,"Ah, so this is Jasmine Bloom."],[4112,4308,"How did a loser like you"],[4308,4521,"land a fine woman like this?"]],"65":[[54,221,"Ignore her."],[275,392,"She's still my sister,"],[392,521,"but we disowned her."],[542,604,"We're not"],[604,788,"related to her or her stupid"],[788,880,"husband any longer."],[913,1105,"Disowned, huh? Good, you'll make a"],[1105,1247,"fine widdow once I kill your"],[1247,1330,"darling husband."],[1384,1484,"She'll be all mine."],[1518,1597,"It's my granddaughter's"],[1597,1839,"honor to be appreciated by a fine"],[1839,1972,"gentleman as you, Mr. Baker."],[2010,2218,"Please, do whatever you like with her."],[2318,2435,"Just don't forget about us."],[2489,2698,"Yeah, Ken. Once we're done here,"],[2698,2781,"I'll wrap her up and"],[2781,2869,"send her to your room."],[2952,3103,"Yeah, she's all yours, my man."],[3157,3299,"How could you?"],[3353,3520,"I'm your sister, Joseph."]],"66":[[984,1134,"How dare you slap my grandson?"],[1201,1343,"What the hell was that?"],[1468,1651,"Be glad that wasn't my right hand."],[1651,1764,"You will pay for this."],[1976,2156,"I don't hurt senior citizens,"],[2177,2268,"but I don't like Jasmine"],[2268,2377,"being treated that way."],[2406,2485,"She's your family."],[2569,2723,"They may be afraid of you,"],[2723,2873,"but I'm not."],[2898,3065,"Oh, please, you don't have the guts"],[3065,3211,"to take me on one-on-one."],[3249,3319,"Is that a challenge?"],[3616,3678,"I'll take you down"],[3678,3832,"before my boss gets here."],[4250,4371,"That hurts, you psycho."],[4521,4575,"You all want to know"],[4575,4671,"who I really am?"],[4729,4804,"I'll show you."],[5142,5288,"I'm your CEO General,"],[5359,5438,"Toby Stark."],[5860,5976,"Holly, fuck."]],"67":[[187,342,"This is the marine emblem."],[462,521,"The mechanical arm?"],[521,583,"It, it, it..."],[629,792,"Are you Toby freaking Stark?"],[792,1030,"Is, is Tobias Toby Stark?"],[1146,1272,"No, no, no, no, no."],[1322,1518,"I dated this man for five years,"],[1518,1755,"and man is a very generous term."],[1793,1881,"But the CEO's"],[1881,2056,"signature mechanical arm."],[2085,2289,"There are plenty of veterans that"],[2289,2560,"have artificial arms, you know?"],[2598,2694,"But only the CEO"],[2694,2790,"has a marine emblem."],[2827,2911,"That has to be a fake."],[2936,3107,"I'm not dumb enough to insult the"],[3107,3244,"most powerful man in the world."],[3290,3424,"Yeah, the CEO wouldn't sink down"],[3424,3545,"to leeching off women either."],[3599,3666,"You're a fraud."],[3712,3895,"Tobias must have just gone mad from"],[3895,4095,"all that crazy military propaganda."],[4095,4266,"That's, that's all this is."],[4287,4441,"The truth is right in front of you,"],[4441,4596,"but you refuse to believe it"],[4642,4704,"because it would be"],[4704,4833,"too devastating for you."],[4888,5121,"He is delusional and completely"],[5121,5292,"unaware of reality."],[5292,5447,"He thinks that just because he has"],[5447,5651,"the same last name as the CEO General,"],[5651,5822,"that he's some sort of hero."],[5839,5997,"I mean, yeah, Stark is a super"],[5997,6114,"common last name, right?"],[6135,6352,"Just please don't be fooled by him."],[6352,6556,"He's literally nothing."],[6589,6660,"Daniella, you have"],[6660,6890,"insulted me time and time again."],[6944,7111,"Now it is time to end this."]],"68":[[0,112,"Quit pretending."],[137,241,"I know you're nothing"],[241,383,"and you can do nothing to me."],[383,542,"Identity theft is a serious crime."],[588,658,"Even worse,"],[658,855,"impersonating the CEO General,"],[934,1046,"Toby Stark."],[1055,1176,"I'm pretty sure the government will"],[1176,1334,"have your head for impersonating a"],[1334,1459,"five-star general."],[1468,1526,"Oh, yeah."],[1584,1772,"He's beyond dead when General Evans"],[1772,1993,"from the Marine Corps arrives."],[1997,2173,"General Evans, isn't he friends"],[2173,2302,"with the Stark CEO?"],[2373,2548,"He'll surely recognize him then."],[2560,2615,"Correct."],[2615,2686,"And then your blatant"],[2686,2836,"lies will be exposed."],[2873,2986,"You asked for this."],[3003,3086,"Security!"],[3111,3224,"Break his other arm!"],[3557,3653,"Who dares"],[3653,3962,"impersonate the CEO General?"]],"69":[[0,104,"Attention!"],[108,262,"General Evans arrives!"],[271,450,"It's General Evans, the member of"],[450,563,"the U.S. Marine Corps"],[563,842,"and the Stark CEO's good friend, too."],[1071,1330,"So many Marines."],[1330,1484,"General Evans,"],[1551,1701,"my business partner,"],[1714,1826,"it's so good that you're here."],[1843,1943,"Some bum is trying to"],[1943,2185,"impersonate the CEO general."],[2185,2264,"Toby Stark."],[2285,2719,"Who on Earth would have the balls"],[2719,3086,"to impersonate General Stark?"],[3090,3178,"That's him."],[3178,3290,"That loser right there."],[3336,3536,"He's a jobless, penniless vet"],[3536,3766,"who just leeches off of women to survive."],[3837,3933,"Punish him, General."],[4200,4362,"How infuriating."],[4404,4567,"You see that, you bum?"],[4567,4708,"You've managed to piss off the"],[4708,4929,"general of the Marine Corps."],[4929,5005,"You're lucky if you"],[5005,5192,"come out of here one piece."],[5192,5305,"General, do it."],[5342,5497,"Show this moron what happens when"],[5497,5651,"you piss off the Marines."]],"70":[[817,930,"General Evans,"],[950,1042,"he's over there."],[1042,1138,"Why'd you hit me?"],[1484,1701,"Yeah, General, you should have shot"],[1701,1906,"Tobias on the spot, not punish us-"],[1906,2147,"So, you're the ex-girlfriend that"],[2147,2423,"my pal ditched the president for."],[2423,2535,"What?"],[2560,2660,"What are you talking?"],[2660,2823,"You know my ex-boyfriend?"],[2823,2919,"Are you sure you're not confusing"],[2919,3019,"him with someone else?"],[3019,3203,"Babe, do you have any other exes"],[3203,3345,"involved in the government?"],[3345,3528,"Not that I know of."],[3782,3891,"General Stark."],[3912,4029,"What the hell is going on?"],[4029,4245,"That there is the CEO"],[4245,4562,"of Stark Enterprises, Toby Stark."],[4587,4733,"Evening General!"],[4750,4821,"What?"],[4859,4888,"No."]],"71":[[350,608,"He's the all-powerful CEO General?"],[704,855,"I'm so screwed."],[1017,1176,"Tobias is Toby Stark,"],[1217,1401,"the legendary CEO General?"],[1459,1597,"He's the Iron Marine"],[1597,1764,"with the mechanical arm?"],[1810,1910,"Hello."],[1976,2231,"I thought he was an unemployed veteran,"],[2323,2464,"a deadbeat cripple."],[2510,2677,"You mean to tell me that"],[2761,2973,"the richest man on the planet"],[2973,3140,"could have been my son-in-law?"],[3157,3328,"No, no, no, no, no, no, no."],[3328,3470,"I did not give him"],[3470,3607,"away to Jasmine Bloom."],[3649,3757,"Tobias,"],[3757,3987,"you're Toby Stark?"],[3991,4175,"My husband is the American hero"],[4175,4308,"who saved our nation"],[4308,4429,"from the airstrikes?"],[4500,4804,"My ex, the hobbled jobless vet,"],[4804,4950,"is the richest man in America?"]],"72":[[1001,1071,"I'm bored."],[1105,1238,"It's time to clean house."],[1317,1363,"No."],[1685,1797,"What are you gonna do?"],[1818,1931,"Who knew, right?"],[1951,2164,"That I, Tobias, Toby Stark,"],[2214,2331,"the unemployed,"],[2331,2489,"penniless, crippled vet,"],[2535,2644,"who you ridiculed,"],[2686,2848,"is actually a billionaire"],[2848,2982,"and a wartime hero."],[3028,3094,"Daniella!"],[3094,3349,"Do something! Make up with him!"],[3365,3436,"Toby."],[3470,3699,"Toby, I, I was so, so wrong."],[3774,3912,"Please just give me another chance,"],[3920,4070,"and we can be happy."],[4112,4195,"No, thank you."],[4270,4416,"I already have a wonderful"],[4508,4583,"fiancée,"],[4608,4696,"Jasmine Bloom."],[4800,4992,"And not only did you insult me, but"],[4992,5146,"you insulted every brother and"],[5155,5326,"sister who fought to protect you."],[5392,5467,"That's why I'm"],[5476,5618,"taking everything back."],[5684,5822,"No, please, please."],[5872,6043,"I will do anything, Tobias."],[6076,6197,"Your job offer has already been"],[6197,6343,"taken away. And seeing as though"],[6343,6506,"I've funded your schooling,"],[6581,6706,"I'm revoking your degrees as well."],[6706,6823,"No, you, you can't!"],[6865,6981,"I'll have to start all over!"],[6994,7157,"Oh, if you're really that talented,"],[7169,7294,"you wouldn't rely on me"],[7294,7461,"to pull the strings behind the scenes."],[7561,7711,"Let's see what you're capable of."]],"73":[[16,275,"No, no. Tobias, I need you!"],[321,450,"As for the rest of you..."],[450,704,"Mr. Stark, I'm so sorry."],[725,875,"I didn't know it was you."],[875,1046,"Please, forgive me."],[1046,1142,"You're fired."],[1205,1284,"And all of the shares"],[1284,1480,"and stock you made with my company,"],[1509,1626,"I'm donating that money"],[1626,1793,"to Veterans Affairs."],[2039,2173,"They deserve it."],[2193,2302,"I messed up!"],[2302,2452,"We're like family now."],[2452,2535,"You're like my brother."],[2535,2681,"You're like my brother-in-law."],[2681,2806,"Right, bro?"],[2806,2890,"Yeah, my uh..."],[2944,3036,"Grandson-in-law."],[3090,3290,"Didn't you just disown Jasmine?"],[3332,3578,"You know what? I'm gonna buy all of"],[3578,3732,"Bloom Tech's shares from you."],[3787,3987,"Jasmine will continue as CEO."],[4066,4170,"And all you buffoons"],[4170,4295,"will be kicked off the board."],[4512,4562,"What?"],[4596,4767,"Why? Why did I listen"],[4767,4879,"to you over Jasmine?"],[4879,4954,"She's the real"],[4954,5092,"business mind in this family."],[5109,5221,"Now throw the blood-sucking,"],[5230,5296,"cowardly,"],[5296,5384,"veteran-insulting"],[5384,5526,"trash out of here."],[5605,5651,"Wait."],[5989,6056,"No."],[6072,6202,"No, no, no, no, no."],[6202,6235,"No!"],[6247,6285,"Daniella!"],[6293,6431,"This is so dramatic."],[6535,6664,"No, no, no."],[6765,7002,"Tobias, I, I didn't know it was you."],[7002,7094,"I didn't know you were the"],[7094,7248,"Toby Stark the Iron Marine"],[7248,7349,"the CEO General."],[7365,7565,"I need another chance, please!"]],"74":[[8,120,"Oh, it's too late."],[145,300,"I know who truly values me."],[354,567,"And I have a very good woman,"],[567,767,"and my future wife, Jasmine Bloom."],[804,913,"Daniella,"],[913,1067,"you could've had everything."],[1105,1313,"A kind and caring husband."],[1343,1497,"But you drove him away"],[1539,1634,"with your arrogance."],[1651,1889,"No, no, I was young, and I was dumb."],[1889,2027,"I never should have thrown you away."],[2027,2131,"Please!"],[2143,2364,"Thank you. You were utterly blind"],[2364,2510,"to Tobias's greatness."],[2548,2719,"And now him and I are together."],[2736,2806,"Thank you"],[2806,2961,"for showing me your true colors."],[3015,3236,"So that I might find true love."],[3328,3440,"No, what have I done?"],[3453,3674,"No! No, my Gucci! Please!"],[4975,5150,"I think it's time we plan our wedding."],[5188,5284,"Absolutely."]]}