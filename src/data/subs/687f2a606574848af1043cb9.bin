{"1":[[1259,1438,"Thank you for saving this country."],[1505,1701,"No, the world, Stark."],[2147,2352,"The President of the United States"],[2360,2573,"is promoting Tobias Stark to"],[2573,2727,"Five Star General"],[2740,2861,"in honor of his service."],[2894,2982,"He shall now be"],[2990,3174,"named the Iron Marine."],[3203,3432,"In celebration, the entire country"],[3507,3687,"gets a whole week off."],[3737,3832,"Extending"],[3841,3978,"the Fourth of July holiday."],[4091,4216,"Thank you, General Evans."],[4308,4400,"And God bless America."],[4429,4512,"Congratulations, - Congratulations,"],[4512,4562,"General! - General!"],[4788,4884,"At ease!"],[5409,5526,"General Stark,"],[5538,5643,"I understand you're"],[5643,5801,"taking over Stark Enterprises from"],[5801,5985,"your father. I wish you the best."],[6039,6135,"Now, how about that"],[6143,6239,"after Banquet Party?"],[6289,6381,"Sorry, General."],[6410,6548,"But with all due respect,"],[6594,6735,"I've got a date."],[6815,6881,"But..."],[6919,7048,"this is with the President and"],[7057,7161,"all the generals."],[7190,7369,"Who could possibly be more important?"],[7540,7665,"My future wife."]],"2":[[800,950,"I've said it a thousand times,"],[959,1021,"I'm not marrying that"],[1030,1151,"evil monster David Lang."],[1213,1351,"I don't care if he's rich."],[1418,1522,"But, Ms. Bloom,"],[1522,1710,"the Langs say if you don't marry David"],[1710,1835,"they'll make sure Bloom Tech AI"],[1835,1901,"won't get funding from"],[1901,2022,"any other investors."],[2085,2243,"There's no way to shut them up."],[2293,2385,"Unless you could get"],[2385,2481,"married to someone else?"],[3253,3432,"Hey you, what's your name?"],[3574,3712,"Tobias, Tobias Stark."],[3845,3912,"Age?"],[3978,4020,"30."],[4095,4175,"Occupation?"],[4208,4283,"I just fulfilled my"],[4291,4404,"service with the Marine Corps."],[4483,4654,"Kind of in between jobs right now."],[4754,4975,"Ah, so you're a military grunt."],[5059,5159,"Must mean you don't make a lot of money."],[5255,5296,"You married?"],[5313,5438,"Not yet, but I-"],[5447,5513,"I'm in a rush, so"],[5522,5593,"let me just be quick."],[5693,5801,"My name is Jasmine Bloom."],[5839,5964,"I'm 25 years old."],[6014,6081,"My net worth is"],[6089,6260,"around a few billion,"],[6293,6456,"and I am the CEO of the largest AI"],[6464,6581,"tech company in America,"],[6652,6727,"Bloom Tech AI."],[6936,6994,"Good for you."],[7232,7319,"Let's get married."],[7415,7465,"Get what?"],[7520,7570,"Get married."],[7653,7820,"Think of it as a business deal."],[7870,7999,"You play my husband and"],[8008,8195,"I give you $100K a month."],[8233,8458,"Miss, I'm sorry, I can't marry you."],[8541,8729,"$200K, plus a mansion."],[8837,8963,"Miss, I'm sorry I can't."],[9138,9205,"I'm engaged."],[9275,9338,"Oh, sorry."],[9451,9547,"Am I really gonna have to"],[9555,9701,"marry that evil David Lang?"],[9738,9914,"So you're the CEO of BloomTech?"],[9980,10005,"Yes."],[10047,10126,"I like what you guys"],[10135,10210,"are doing down there."],[10289,10347,"It would be a"],[10356,10472,"shame if it went under."],[10485,10552,"Maybe I can help you"],[10560,10627,"out with something."],[10685,10735,"Give me your phone."],[10965,11011,"Okay."],[11561,11628,"Hi, David Lang?"],[11711,11778,"It's Toby."],[11778,11840,"Yeah, that Toby."],[11878,11961,"Listen, stop bothering"],[11961,12016,"Miss Bloom"],[12024,12132,"or else I'm gonna cancel my"],[12141,12212,"contracts with you."],[12245,12354,"What the hell are you doing?"],[12383,12454,"Don't piss him off,"],[12462,12537,"he's rich and powerful."],[12633,12725,"Not as powerful as me."],[12787,12854,"You're making it worse."],[12904,12946,"He won't be"],[12946,13025,"bothering you anymore."],[13079,13179,"He says he'll apologize"],[13179,13221,"to you too."],[13413,13450,"Oh!"]],"3":[[183,371,"I'm sorry, I didn't mean to."],[379,479,"Do you know how much trouble"],[479,533,"you've caused?"],[625,700,"I need to fix this,"],[709,796,"I need these investments."],[838,913,"Don't worry about the Langs."],[942,1059,"They won't be a problem anymore."],[1126,1217,"I've taken care of it."],[1259,1426,"In fact, you'll be receiving a"],[1434,1509,"considerable grant"],[1518,1605,"from Stark Enterprises."],[1755,1872,"I hope that you can take Bloom Tech AI"],[1881,1968,"to the top."],[2022,2097,"You're lying."],[2173,2323,"Stark Enterprises is the number one"],[2331,2394,"arm tech company"],[2402,2523,"in the entire world."],[2565,2719,"They have billions of equity"],[2727,2890,"invested in dozens of industries."],[3011,3111,"Who do you think you are?"],[3219,3403,"She doesn't need to know I'm CEO"],[3403,3549,"of Stark Enterprises."],[3586,3707,"Stay low key."],[3724,3787,"You know what?"],[3787,3878,"Screw you!"],[3887,3983,"Get off my boat."],[4012,4129,"Oh, this is my boat."],[4537,4771,"Man, she's a feisty girl."],[4909,5038,"I can see why she's taken"],[5046,5159,"Bloom Tech AI to the top."],[5334,5376,"I think I'm gonna"],[5384,5476,"invest in her company."],[5880,6093,"Daniella is so much nicer than her."],[6235,6373,"I bet she's excited to see me."],[7661,7724,"Oh!"],[7724,7862,"I cannot believe the caliber"],[7862,7970,"of this banquet."],[7999,8128,"And it's all just for me."],[8153,8433,"Bloom Tech is so lucky to have you."],[8445,8550,"Is their CEO,"],[8550,8671,"Jasmine Bloom coming?"],[8742,8858,"Jasmine Bloom"],[8858,9059,"is number one on the Forbes list."],[9059,9267,"I'm obsessed with her, but she's"],[9275,9371,"super mysterious."],[9426,9467,"I don't even know"],[9476,9572,"what she looks like."],[9868,10030,"Now that I finished my service"],[10030,10155,"in the Marine Corp,"],[10155,10331,"I can finally come home to my girlfriend."],[10431,10581,"Daniella will be so moved"],[10581,10731,"when she learns I've been financing"],[10731,10865,"her behind the scenes"],[10865,10956,"all these years."],[11006,11240,"Time to make her big day even better."],[11507,11682,"Tobias is here?"],[11853,12062,"I thought he was deployed."],[12062,12195,"Daniella, I'm back."],[12195,12354,"Toby, you're back."],[12391,12499,"Why?"]],"4":[[25,154,"I've returned from active duty."],[221,266,"Big day."],[300,387,"Can't miss my girl's"],[437,621,"welcome banquet with Bloom Tech."],[725,800,"I got you some flowers."],[1597,1664,"You're mad, aren't you?"],[1693,1789,"You know, being long distance for"],[1797,1918,"three years, we've had it tough."],[1943,2102,"But I'm not leaving you again."],[2131,2369,"Oh no, please. Leave."],[2369,2485,"I have no interest"],[2494,2585,"in seeing you anymore."],[2631,2731,"You're really this mad?"],[2798,3115,"Oh my God. I thought you were poor,"],[3153,3315,"but you're stupid too."],[3365,3445,"But that's alright."],[3445,3561,"I can spell it out for him."],[3599,3920,"Tobias, you and I? Breaking up."],[3958,4087,"You're breaking up with me?"],[4149,4245,"But I just got back."],[4254,4287,"I'm not going to"],[4295,4383,"get deployed anymore."],[4454,4596,"I've returned to civilian life."],[4633,4892,"Yeah, coincidentally, just as I've"],[4900,5017,"gotten this amazing new"],[5025,5159,"job with Bloom Tech AI."],[5221,5317,"And I'm making millions."],[5593,5651,"See that up there?"],[5801,6068,"Yeah. That's what real money, real"],[6076,6189,"power looks like."],[6252,6623,"You are just an uneducated pig that"],[6631,6719,"is trying to leech"],[6727,6840,"off of my daughter."],[6873,7032,"I'm not trying to leech off anyone."],[7111,7182,"Daniella, we've been"],[7190,7328,"together for five years,"],[7344,7482,"and I've given you everything."],[7545,7595,"Why would you want"],[7603,7682,"to toss that away?"],[7749,7895,"Grow up, Toby."],[7957,8137,"Happily ever after is for children."],[8183,8379,"In the real world, what matters is"],[8379,8629,"status, power, and money."],[8671,8833,"You're blinded by money."],[8975,9150,"And to think that I was going to"],[9159,9263,"reveal my true identity."]],"5":[[0,87,"That I am..."],[125,221,"That you are"],[221,316,"an ex-marine"],[316,554,"with no degree and no job."],[604,796,"No car and no house."],[850,1001,"And I promise you these fake"],[1001,1113,"medals, yeah they're"],[1113,1242,"not gonna cover up your deceit."],[2577,2777,"Yeah I think it's time to move your"],[2777,2907,"filthy existence"],[2994,3073,"out of our presence."],[3148,3332,"My existence is what protected you"],[3332,3490,"and this country from an airstrike."],[3741,4008,"Go play soldier boy someplace else."],[4045,4270,"You do not deserve my daughter."],[4308,4458,"Weren't you discharged?"],[4504,4587,"Had an accident?"],[4708,4800,"You know"],[4800,4938,"PTSD or"],[4938,5088,"being crippled."],[5201,5305,"It's really not"],[5305,5484,"something I want to deal with."],[5864,6060,"Daniella you have now gone too far."],[6097,6256,"I might have returned a hero but"],[6256,6398,"you've insulted my brethren."],[6418,6577,"We put our lives on the line to"],[6577,6777,"protect you and this country."],[6856,6969,"You idiots sold your"],[6969,7102,"soul for our government."],[7178,7428,"We are honorable men and women."],[7511,7636,"Tobias look around you."],[7670,7891,"You are at the number one AI"],[7891,8045,"company in Silicon Valley."],[8083,8350,"Surrounded by the top of the top 1%."],[8366,8575,"And you are a dirtbag"],[8575,8712,"unemployed vet,"],[8712,8913,"simply here to embarrass me."],[8971,9063,"All the superficial"],[9063,9230,"glory has gone to your head."],[9309,9509,"I can see your true colors Daniella."],[9509,9655,"Yeah and they're glimmering gold."],[9709,9851,"I was always too good for you."],[9893,10105,"You think the posters, the piles of"],[10105,10314,"cash, the banquets,"],[10406,10497,"put you on a pedestal?"],[10573,10660,"But I'm the one who"],[10660,10773,"got you this job offer."]],"6":[[133,383,"Dream on, Toby! You couldn't even"],[392,525,"be bothered to put something on"],[533,700,"that wasn't given to you for free."],[771,963,"Okay, you'd be fortunate to get a"],[971,1071,"job here as the janitor."],[1101,1376,"He is so beneath us. He doesn't"],[1384,1468,"even understand how"],[1476,1614,"powerful Bloom Tech is."],[1659,1939,"Bloom Tech AI is the number one AI"],[1947,2039,"company in the nation."],[2102,2356,"Their CEO, Jasmine Bloom, aka Lady"],[2364,2469,"Bloom, she's number"],[2477,2573,"one on the Forbes list."],[2715,2790,"She's my idol."],[2890,3019,"Bloom Tech might be big,"],[3057,3128,"but they need"],[3128,3282,"my investment to go global."],[3340,3545,"Mmm, do they now? They're just"],[3553,3645,"desperate for your"],[3653,3778,"dirty hand-me-downs?"],[3874,4054,"You're a clown, Tobias."],[4154,4312,"You know, the Bloom Tech that was"],[4320,4625,"supposedly so hard to get into..."],[4938,5050,"...it's because I made the call."],[5693,5751,"Hi."],[5860,5914,"What?"],[6001,6160,"Miss Bloom, David Lang just issued"],[6168,6335,"a public apology. He said he won't"],[6343,6410,"bother you anymore."],[6485,6544,"No way."],[6560,6706,"And I have better news."],[6706,6815,"Stark Enterprises"],[6823,6923,"just sent us a"],[6931,7061,"ten-billion-dollar deal."],[7140,7236,"The largest military"],[7244,7390,"supplier wants to invest in us."],[7536,7628,"Oh my God."],[7753,7903,"That man from the boat."],[8028,8128,"He wasn't lying."],[8128,8216,"What's going on?"],[8408,8650,"Esther, you have to find him right away."],[8650,8921,"That ex-marine, Tobias Stark,"],[8929,8971,"I need to know"],[8979,9138,"everything about this man ASAP."],[9200,9355,"A vet, Miss Bloom? Why?"],[9463,9576,"I want to marry him."],[9797,9864,"Marry him?"],[9901,9934,"Yes."],[10256,10481,"Tobias? You're mine."]],"7":[[58,241,"Daniella, did you hear him?"],[325,546,"He thinks he's above Bloom Tech."],[608,717,"You go ahead and break his heart"],[725,859,"and now he's lost his mind."],[934,1263,"Tobias, please just leave."],[1330,1468,"I understand you're squatting"],[1476,1651,"around, feeling as though I owe you"],[1659,1785,"something for these last"],[1793,1897,"few years, is that it?"],[1997,2093,"I'm a generous girl."],[2127,2248,"How's a hundred thousand sound?"],[2264,2323,"Okay?"],[2389,2560,"Go ahead, help yourself."],[2594,2769,"Pennies to me, but you know,"],[2844,2998,"for the likes of you, I'm sure"],[3007,3086,"it'll make a huge"],[3094,3148,"difference."],[3624,3828,"One, I don't care about the money."],[3924,4037,"And two, you're right."],[4154,4291,"This is just pennies to me."],[4333,4500,"Oh, he just wants more."],[4629,4679,"Fine."],[4700,4917,"$200,000 is a long way for"],[4925,4988,"someone like you."],[5042,5096,"You know what?"],[5121,5367,"$300,000 is a lot more likely to"],[5376,5459,"get you that farm"],[5467,5518,"in the middle of"],[5526,5684,"nowhere, that toothless bimbo"],[5693,5809,"you're always dreaming about."],[5818,5893,"Come on, Tobias."],[5939,6022,"What's it gonna take?"],[6185,6277,"All of it's for you."],[6385,6598,"Geez, Tobias, I swear, there is"],[6598,6744,"endless amounts of"],[6752,6944,"money for you to have, okay?"],[6981,7111,"$500,000."],[7144,7253,"Take what you want."],[7394,7444,"Fine, Tobias."],[7507,7782,"You take as much as you need, okay?"],[7811,7907,"Get prepared to be on"],[7916,8008,"your hands and knees."],[8028,8133,"Take what you need,"],[8158,8362,"and then get out of my life."],[9071,9196,"This is a lot of money,"],[9238,9380,"but it means nothing to me."],[9501,9634,"You can't even afford to buy a"],[9642,9784,"drone with this meager amount."]],"8":[[41,116,"Quit pretending."],[200,358,"Daniella, he's just messing with you."],[400,529,"Cut ties with this loser"],[538,625,"and get him out of here"],[633,725,"before Rick gets here."],[734,804,"No, you're right."],[859,1001,"Toby could never compare to Rick."],[1021,1088,"I wouldn't want Rick to"],[1096,1197,"catch me with this filth."],[1272,1330,"Rick?"],[1351,1409,"Who's Rick?"],[1505,1564,"Who's Rick?"],[1593,1705,"I'll tell you who Rick is."],[1747,1793,"Rick is the"],[1801,1990,"wealthiest man in California."],[2006,2268,"His dad is the VP at Bloom Tech,"],[2323,2473,"Jasmine Bloom's right-hand man."],[2506,2573,"He's got money."],[2606,2677,"He's got wealth."],[2723,2781,"You have neither."],[2877,3044,"And, if you know what's good for you,"],[3053,3203,"I'd leave before he gets here and"],[3211,3324,"throws you out himself."],[3390,3536,"He's not one to be trifled with."],[3645,3716,"You cheated on me?"],[3812,3937,"And now you're dumping me for"],[3945,4012,"someone you think"],[4020,4141,"is more powerful than me."],[4187,4350,"When I'm the Stark CEO"],[4400,4512,"The true source behind"],[4512,4608,"any of their wealth."],[4671,4800,"Yes, Tobias."],[4884,5063,"I got with someone who could get me"],[5071,5171,"to where I wanted to be."],[5201,5313,"He got me the job."],[5321,5505,"He makes ten million dollars a year."],[5513,5672,"And he actually knows people."],[5805,5989,"She doesn't realize she only got that"],[5989,6243,"offer because I called Bloom Tech."],[6243,6460,"I don't have any desire to spend"],[6468,6690,"the rest of my days at home with an"],[6698,6777,"unemployed veteran"],[6785,6919,"eating beans for dinner."],[7002,7086,"I think I deserve"],[7094,7219,"better than that, don't you?"],[7323,7432,"Daniella, what makes you think that"],[7440,7549,"I can't give you what you want?"],[7628,7691,"That I can give you"],[7699,7799,"more than Rick can."],[7849,7916,"One hundred"],[7916,8120,"thousands times more."]],"9":[[0,100,"Who? You?"],[191,325,"Maybe we'll have to keep him around."],[371,533,"So then he can see how low he is"],[533,629,"compared to Rick?"],[742,917,"Yeah, I'm here for that."],[992,1146,"He's nothing compared to me."],[1301,1605,"Did I just hear a welfare king say"],[1605,1735,"he's a thousand times"],[1735,1810,"better than me?"],[2173,2344,"Rick, baby, welcome, welcome."],[2344,2548,"We've been waiting just for you."],[2761,2861,"Oh."],[2936,3169,"You must be the broke GI Joe"],[3169,3361,"ex-boyfriend Daniella told me about."],[3390,3574,"Don't worry, Mr. Dickson,"],[3574,3732,"Daniella already broke up with him."],[3762,3974,"He just won't leave her alone."],[3974,4099,"He's such a creep."],[4195,4550,"Yeah. I gotta ask, what's this?"],[4600,4913,"Some creepy BDSM leather glove?"],[4938,5034,"I'll tell you what."],[5084,5238,"I'm gonna ruin your uniform for you."],[5342,5501,"I suggest you let go before you"],[5501,5626,"hurt yourself."],[6335,6431,"Oh sh-"],[6802,6994,"Is that a mechanical arm?"],[6994,7273,"I thought only the Stark CEO had one."]],"10":[[29,246,"CEO? In his dreams."],[279,521,"Alright, turns out he's not just a creep,"],[521,642,"but he's a cripple too."],[704,930,"A worthless cripple vet wants"],[930,1051,"to marry my daughter?"],[1126,1184,"Dream on!"],[1217,1388,"He's not even a whole man."],[1697,1868,"Yeah. Oh oh oh oh!"],[1868,2010,"Let me guess how it happened."],[2043,2168,"Um, you were messing around"],[2168,2277,"with your own grenade and you"],[2277,2385,"accidentally popped your own"],[2385,2485,"arm off, didn't you?"],[2519,2715,"My comrades and I risk our lives on"],[2715,2948,"the line to protect civilians like you."],[3019,3194,"You're just stuck up cowards"],[3194,3324,"wasting space."],[3436,3895,"Oh, well, excuse me, Mr. Expendable."],[3912,4058,"You know why the rich don't join"],[4058,4149,"the military?"],[4149,4379,"Because unlike you, uh, low-class"],[4379,4458,"hillbillies,"],[4517,4721,"our lives are actually worth something."],[4763,4900,"I'd like to see you prove that."],[4954,5113,"Daniella never even loved you."],[5134,5267,"So stop stalking her and I will"],[5267,5417,"consider not kicking your ass."],[5472,5739,"Sure, go ahead and fight me."],[5768,5860,"You'll just get your ass"],[5860,5955,"handed back to you."],[6456,6527,"Don't risk it."],[6564,6690,"What if he's a bloodthirsty"],[6690,6848,"killer from his time at war?"],[6936,7015,"Yeah, psychosis."],[7094,7261,"Nah, I, I wouldn't fight you anyway."],[7261,7424,"I'm, I'm