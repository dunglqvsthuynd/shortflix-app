1317,"You're fucking delusional."],[1317,1393,"Tell them all"],[1418,1589,"how you wanted to burn me alive,"],[1589,1701,"your own girlfriend!"],[1760,1906,"No, no, no, no way."],[1906,2010,"I would never hurt you,"],[2010,2139,"no matter how pissed I am."],[2177,2394,"Because you were blackout drunk,"],[2431,2540,"you knocked over a candle,"],[2540,2665,"and it was a horrible accident."],[2702,2736,"Okay?"],[2761,2819,"Wrong."],[2923,3007,"What do you know?"],[3040,3165,"I loved Ashlyn,"],[3165,3257,"the real Ashlyn,"],[3257,3499,"the sweet, caring Ashlyn. You,"],[3520,3674,"I don't know who the fuck you are."],[3741,3862,"That's a pretty twisted"],[3862,3970,"definition of love."],[4033,4108,"Did you know,"],[4149,4250,"burning someone,"],[4291,4508,"is one of the most painful ways to go?"],[4988,5159,"Does that sound like love to all of you?"],[5251,5397,"You remember everything?"],[5422,5559,"I remember,"],[5634,5722,"everything."]],"47":[[20,158,"I remember,"],[233,321,"everything."],[754,850,"You, you are lying."],[850,955,"Where's your scars?"],[1001,1284,"I came back from my death"],[1384,1634,"to make your life miserable."],[2022,2085,"Get away!"],[2131,2452,"I want you to burn so bad,"],[2485,2585,"that you beg,"],[2631,2706,"for death."],[2923,3036,"You are crazy."],[3061,3153,"I'm crazy?"],[3215,3269,"You're the one"],[3269,3436,"who murdered his own girlfriend!"],[3611,3666,"That's enough,"],[3666,3787,"it's time for you to go, Ashlyn."],[3795,3841,"Come on."],[4112,4287,"She's not Ashlyn Wadsworth."]],"48":[[4,191,"She's not Ashlyn Wadsworth."],[1038,1259,"I am Ashlyn Wadsworth."],[1739,1889,"She doesn't even look like her at all."],[2027,2198,"Ashlyn's literally right here."],[2398,2485,"I told you all,"],[2531,2610,"she's a fake."],[2936,3007,"Who are you?"],[3098,3257,"Is this really my sister?"],[3286,3403,"Is she still alive?"],[3432,3528,"If you're really Ashlyn,"],[3607,3666,"then prove it."],[3803,3933,"If they find out I've been lying,"],[3949,4054,"they'll crucify me."],[4058,4204,"Mckenna, do you think we're stupid?"],[4245,4375,"Watch your mouth, fake bitch."],[4396,4496,"Looks like someone's still"],[4496,4708,"upset about losing the Sorority Games."],[4750,4879,"We're not blind, Mckenna."],[4904,4992,"It's me."],[5050,5176,"You know what, let's finish this."],[5251,5376,"I knew you guys wouldn't trust me,"],[5447,5522,"so I did this."],[5780,6060,"A DNA test, and it's a 100% match."]],"49":[[0,258,"Oh my God, she really is my sister."],[296,417,"Wait, so this fake Ashlyn"],[417,583,"has been lying to us the entire time?"],[608,813,"So how did she fake the first DNA test?"],[1368,1422,"Brian."],[1497,1630,"You're really Ashlyn Wadsworth."],[1685,1751,"My love."],[1797,1889,"How much do you remember?"],[2085,2135,"What?"],[2185,2310,"You think he loves you?"],[2331,2498,"You don't realize he tried to kill you."],[2544,2640,"No offense, Ashlyn,"],[2640,2802,"but what's wrong with your face?"],[2836,2936,"I'm glad you asked."],[3148,3228,"It was her."],[3370,3516,"Everything is because of"],[3516,3616,"this imposter."]],"50":[[12,137,"What, what are you talking about?"],[158,354,"You soaked me in alcohol."],[387,529,"You lit the match,"],[529,721,"and you left me to burn!"],[817,925,"You tried to destroy me"],[925,1071,"so you could steal my life."],[1317,1501,"Good girl, blame the fake."],[1572,1659,"Thanks, amnesia."],[1676,1839,"Scapegoat the fuck out of that bitch."],[1847,1910,"No, Ashlyn,"],[1910,2110,"I would never do anything to hurt you."],[2698,2844,"I'm sorry this happened."],[2861,2994,"I wasn't there to protect you."],[3053,3190,"You can't blame yourself."],[3190,3336,"No, no, let, let go of him."],[3340,3436,"I mean, he doesn't care about you."],[3436,3570,"Hey, you stay away from us,"],[3570,3653,"you liar."],[3720,3816,"Why are you doing this?"],[3920,4091,"She's honestly been so mean to us."],[4337,4421,"Monster!"],[4508,4604,"Why are you trying to hurt"],[4604,4708,"my Ramma family?"],[4725,4875,"Time to remember you have a twin."],[4900,5021,"Listen, okay?"],[5134,5309,"I can explain everything."],[5430,5513,"Explain what?"],[5563,5726,"That you destroyed my reputation"],[5726,5851,"and Brian's future?"],[5968,6047,"What did she do to you?"],[6168,6272,"I was trying to protect your"],[6272,6327,"trust fund,"],[6327,6473,"but she wanted it all for herself."],[6481,6585,"So I broke up with her,"],[6610,6694,"and now she's threatening"],[6694,6931,"to leak all these fake AI photos of me."],[7057,7140,"We're broken up?"]],"51":[[8,162,"Why are you so hell-bent"],[162,312,"on trying to ruin my life?"],[362,513,"Trust me, Ashlyn,"],[513,729,"Brian is not a good thing in your life."],[734,779,"Okay?"],[905,967,"Ashlyn,"],[1146,1292,"I want you, okay?"],[1301,1409,"I never wanted to break up."],[1409,1522,"She was just so convincing,"],[1522,1680,"and I didn't want to admit I was conned,"],[1714,1793,"and maybe I just wanted"],[1793,1876,"her to be you."],[1931,2110,"I wanted you to be alive, Ash."],[2189,2256,"Okay, Ash?"],[2256,2331,"I'm sorry."],[2369,2577,"Okay, that, that is such bullshit."],[2577,2744,"He put photos of me on the projector,"],[2769,2952,"and he was trying to humiliate me"],[2952,3040,"in front of everyone."],[3061,3140,"You all saw it!"],[3174,3261,"But you've been lying to us"],[3261,3319,"the whole time."],[3336,3486,"You're just a fake plastic bitch."],[3670,3812,"If that's all you have to say"],[3812,3887,"for yourself,"],[3920,4008,"then leave."],[4433,4554,"Get the hell out of my life"],[4554,4671,"and never come back!"]],"52":[[20,191,"They don't deserve you, okay?"],[191,329,"He doesn't deserve your love."],[567,617,"Who are you"],[617,775,"to decide who gets my love?"],[1918,2047,"Let's be the power couple"],[2047,2198,"we were always meant to be."],[2306,2439,"I just want to do philanthropy"],[2439,2540,"like you said we would."],[2577,2660,"That's what I was trying to do"],[2660,2752,"with your trust fund."],[2790,2915,"And then that scammer,"],[2915,3128,"she, she sabotaged everything."],[3253,3307,"Hey,"],[3403,3465,"don't worry."],[3616,3724,"I'll reinstate you."],[4262,4412,"You were meant to be a leader."],[4429,4562,"Whatever you wanna do"],[4562,4692,"with my father's fortune,"],[4742,4817,"I trust you."],[4979,5146,"I trust you with my life, Brian."],[5176,5292,"Sweet Ashlyn."],[5305,5497,"Like taking candy from a baby."]],"53":[[87,200,"Thank you so much for this."],[233,375,"That just means so much to me,"],[383,563,"but, I really hate to be that guy."],[563,713,"Can I get that in writing? Because,"],[713,796,"I wanna start - Yeah."],[796,888,"as soon as possible."],[909,1055,"Mckenna kind of filled me in"],[1055,1146,"before we got here, - Yeah."],[1146,1317,"so, we came prepared."],[1593,1747,"Will you co-president my charity?"],[1805,1881,"Co-president?"],[1964,2097,"We're kind of a dream team."],[2852,2940,"What do you say, Brian?"],[2986,3036,"No, wait!"],[3174,3240,"I object."],[3749,3883,"Who the hell do you think you are?"],[3949,4124,"I'm an heir to the Wadsworth fortune."]],"54":[[41,95,"What?"],[158,300,"I'm an heir to the Wadsworth fortune."],[350,487,"If you wanna make any changes,"],[487,638,"you have to run them by me first."],[671,725,"No,"],[846,971,"that's not possible."],[992,1201,"I'm the only living Wadsworth heiress."],[1292,1397,"That's not true,"],[1601,1714,"because I'm your sister."],[2298,2356,"Huh? What?"],[2356,2406,"What?"],[2686,2786,"This one is coming with me."],[2786,2911,"No, Ashy!"],[3190,3269,"No!"]],"55":[[1267,1355,"My sister."],[1564,1664,"I can't believe it."],[1676,1722,"I-"],[1735,1856,"I promised I'd find you."],[1881,2056,"I'm so sorry that it wasn't sooner."],[2077,2143,"I'm sorry. - No."],[2143,2189,"No."],[2281,2402,"I'm sorry. I,"],[2556,2652,"I thought I dreamt you."],[3374,3553,"Ash, what the hell are we doing?"],[3553,3682,"Why are you hugging this psycho?"],[4437,4608,"It's you and me against the world."],[4667,4775,"As it was meant to be."],[5226,5284,"Everyone,"],[5380,5467,"this is June,"],[5501,5730,"my identical twin sister."]],"56":[[41,229,"We were separated a long time ago,"],[229,316,"when we were kids."],[350,462,"Now that we're reunited,"],[517,613,"we'll decide what we do"],[613,729,"with our inheritance"],[946,1001,"together."],[1105,1334,"What the actual fuck?"],[1376,1543,"She never mentioned a sister."],[1589,1680,"This can't be happening."],[1680,1818,"How do I get out of this?"],[1826,1872,"Look, baby,"],[1881,2135,"there's literally no record of her."],[2189,2268,"I was passed"],[2268,2435,"from foster to foster family."],[2677,2836,"Well yeah, I mean, it's clearly that"],[2836,2923,"nobody wants you."],[2944,2994,"Brian!"],[3119,3169,"Look,"],[3257,3349,"I'm trying to protect you."],[3349,3516,"She has been pretending to be you"],[3541,3616,"for weeks."],[3653,3807,"And baby, let me remind you,"],[3807,3916,"you have billions,"],[3945,4049,"billions of dollars,"],[4049,4108,"in the bank"],[4108,4191,"and you're just gonna,"],[4220,4325,"blindly trust her?"],[4325,4396,"It's a bit,"],[4396,4529,"it's a bit idiotic."],[4529,4571,"I mean,"],[4683,4825,"I mean, it's, its..."],[4846,4934,"Yes, ridiculous."],[4984,5034,"Look,"],[5096,5221,"you are nothing like her,"],[5267,5309,"okay?"],[5309,5405,"And you owe her nothing."],[5405,5513,"You are kind,"],[5543,5638,"and you are pure."],[5676,5826,"You don't owe her anything."],[5826,5955,"Ashlyn, don't listen to him."],[5985,6202,"I know I don't owe her anything"],[6256,6398,"but I know she's my sister."],[6460,6535,"Ashlyn just,"],[6594,6760,"just think about it for a sec, okay?"],[6760,6931,"Her plan only works,"],[6977,7082,"if you're dead."],[7111,7244,"Ash come on, you can't,"],[7290,7411,"you can't be that stupid."],[7411,7549,"Can you just think?"],[7962,8041,"It was you."],[8291,8462,"You and Mckenna tried to murder me."],[8929,8996,"Oh my God."]],"57":[[116,187,"You're not serious."],[187,400,"Ash, why would you even say that?"],[417,517,"I've had this,"],[588,850,"infuriating black hole in my memory but,"],[950,1059,"the night of the crossing it,"],[1151,1255,"it's coming back to me."],[1280,1443,"I was trashed when you locked me"],[1443,1580,"in that storage room with him."],[1630,1789,"No, no, no, no, no."],[1801,1956,"You were so drunk,"],[1956,2081,"you were about to throw up everywhere."],[2081,2210,"I was trying to protect you,"],[2210,2268,"okay? - No,"],[2281,2410,"you forced me"],[2427,2598,"to drink a handle of vodka."],[2615,2740,"And then you locked me in there"],[2740,2915,"with my so-called boyfriend"],[2915,2982,"and you said..."],[2998,3078,"You're not leaving here"],[3078,3211,"until he gets his happy ending."],[3257,3332,"And you,"],[3395,3478,"you told me,"],[3499,3661,"you wanted to be with me forever."],[3741,3820,"And then you tied me"],[3820,3962,"to a shelf with your belt."],[4312,4458,"Oh, Mckenna did it. Oh my,"],[4496,4567,"Mckenna did it."],[4567,4683,"And she forced me to do it,"],[4683,4788,"and she wants all the money."],[4788,5000,"She, she forced me to do this because,"],[5030,5109,"you know, if I didn't,"],[5109,5201,"she'd ruin my life."],[5205,5351,"Brian, shut the hell up!"],[5380,5455,"You wanted her dead"],[5455,5551,"just as much as I did."],[5914,6010,"Oh my God."],[6064,6122,"Whoa."],[6293,6381,"So you admit it?"],[6523,6627,"You did try to kill her."]],"58":[[16,100,"If I'm going down,"],[120,275,"I'm dragging that useless meathead"],[275,325,"with me."],[342,387,"Yeah."],[467,575,"Yeah, so what?"],[600,679,"Yeah, I did it."],[679,842,"And Brian, you fucking helped!"],[842,913,"Hey, you're lying!"],[938,1005,"You are lying!"],[1188,1267,"Okay, I'm lying."],[1422,1551,"Then why do I have these texts"],[1572,1705,"from us the day of?"],[1751,1876,"Is the plan still on for tonight?"],[1901,2056,"She'll finally get what she deserves."],[2093,2168,"Did you get the rope?"],[2168,2231,"Oh, it's cool."],[2231,2352,"We can just use my belt."],[2377,2548,"Can't wait for her to be gone forever!"],[2873,2940,"Mickey,"],[3007,3061,"B."],[3199,3357,"How could you do this to me?"],[3420,3478,"Oh, sweetie,"],[3478,3607,"you really thought we were friends?"],[3636,3837,"You're so pretty, so rich."],[3837,3937,"I've always hated you."],[3974,4099,"Then why come clean now?"],[4158,4266,"Because I can't stand,"],[4275,4404,"a fucking manchild,"],[4416,4504,"who won't take accountability"],[4504,4617,"for his own actions!"],[4696,5046,"And I am a ride or die Ramma for life."],[5096,5455,"One heart, one way, one sisterhood."],[5709,5868,"Mckenna Halsey and Brian Bingham,"],[5910,5976,"you're under arrest"],[5976,6060,"for the attempted murder"],[6060,6160,"of Ashlyn Wadsworth."],[6260,6293,"Brian."],[6293,6360,"No, no, no!"],[6360,6460,"This is a mistake. - Brian!"],[6485,6873,"Ashlyn, my love for you is real, okay?"],[6890,7002,"I want to be better."],[7065,7144,"Fuck, I can,"],[7144,7336,"I can be better, okay?"],[7336,7403,"And don't listen to her"],[7403,7561,"because she is nothing!"],[7574,7728,"You are nothing, okay? Just,"],[7786,7862,"don't leave me."],[8041,8195,"I survived for a reason,"],[8241,8429,"to finish what my sister started."],[8483,8616,"Brian will finally know"],[8616,8762,"what real pain feels like."]],"59":[[408,546,"You tried to burn me to death,"],[546,671,"you evil motherfucker!"],[850,1013,"You will never talk about my sister"],[1013,1092,"like that again."],[1121,1192,"Drop your weapon!"],[1192,1343,"Drop your weapon or we'll shoot."],[1434,1576,"Ash, Ash!"],[1826,1885,"Drop it!"],[1885,1960,"What are you doing?"],[3753,3807,"June?"]],"60":[[25,70,"No!"],[104,254,"June, no, no."],[358,433,"I love you,"],[529,633,"and I'm sorry."],[1255,1514,"No, no, no."],[1518,1568,"June."],[1710,1856,"I'll find you, I swear."],[1856,2089,"We'll be together again someday."],[2181,2264,"No!"],[2519,2594,"I'm sorry."],[4984,5050,"Sister,"],[5196,5288,"if you're really dead,"],[5488,5643,"why do I feel like you're still alive?"]]}