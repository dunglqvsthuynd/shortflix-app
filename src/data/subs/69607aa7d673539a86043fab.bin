{"1":[[1155,1205,"Hey."],[1297,1468,"As Velta Tau president,"],[1484,1647,"I have to date the hottest Ramma Phi,"],[1647,1714,"you know that."],[1730,2035,"So, it's going to be you and me, forever."],[2264,2460,"Only if you survive tonight's crossing."],[2806,2948,"Stop scaring my Little, Brian."],[2973,3053,"I have really high"],[3053,3174,"hopes for you, bestie..."],[3303,3445,"Don't disappoint me tonight, okay?"],[3953,4062,"You and me forever, baby."],[4546,4717,"After the crossing, I'll surprise Brian"],[4717,4854,"with half of my inheritance."],[4892,5017,"And then we can start that charity"],[5017,5121,"we've been dreaming about."],[5805,5910,"One more night of hell,"],[5976,6122,"then I'm a sister for life."],[6131,6277,"You worthless,"],[6406,6510,"unlovable,"],[6790,6865,"freaks."],[7002,7115,"You all look like"],[7132,7273,"cheap whores."],[7432,7511,"Time to strip."],[7711,7766,"Now!"],[8362,8550,"Okay, it's time to choose."],[8587,8654,"Chug,"],[8779,8837,"or blow?"],[9351,9530,"So what will it be, Ashlyn?"],[10018,10101,"Mckenna,"],[10126,10272,"I would never cheat on Brian-"],[10276,10331,"Oh!"],[10414,10535,"What the Frat King doesn't know"],[10535,10606,"won't hurt him."],[10677,10731,"Come on."],[10931,11015,"Okay fine."],[11920,11978,"Sit."],[12028,12153,"Now, if you fall,"],[12153,12237,"or quit,"],[12320,12395,"you're all out!"],[12641,12783,"Maybe you didn't choose blow,"],[12871,12992,"but you're no virgin."],[13021,13113,"Oh my God."],[13367,13459,"You got this, Little."],[13509,13592,"Don't let me down."],[14030,14205,"I'm so close to being one of them."],[14280,14627,"All I have to do is get through the night."]],"2":[[141,433,"It's gonna be you and me, forever."],[621,925,"I'm sorry, Brian. I can't do it."],[963,1076,"You failed!"],[1096,1155,"You really"],[1155,1292,"disappointed me today, Ash."],[1309,1443,"If you want to wear these letters,"],[1509,1643,"then you're not getting out of here"],[1643,1785,"until he gets his happy ending."],[2193,2248,"What?"],[2281,2331,"No."],[2369,2431,"Mckenna!"],[2460,2523,"No, stop!"],[2523,2640,"Don't leave me in here!"],[3261,3311,"Brian."],[3390,3440,"Brian."],[3457,3499,"Come on."],[3499,3553,"Brian, you won't,"],[3566,3678,"you won't do this to me."],[3720,3770,"Please."],[3824,3945,"Ash, no."],[4079,4200,"I have a surprise for you."],[4204,4300,"What? - So you..."],[4312,4412,"What are you doing?"],[4429,4475,"wanna be a"],[4475,4546,"Ramma, right? - Stop."],[4804,4925,"You want to be together forever?"],[5463,5526,"Oh, fuck."],[5609,5663,"Mickey?"],[5747,5822,"Mckenna, please."],[5843,5964,"I thought you were like my sister."],[6026,6122,"Why are you doing this?"],[6147,6310,"Oh, Ash,"],[6310,6452,"I've always hated you"],[6498,6619,"and your stupid face,"],[6619,6752,"with your perfect pores."],[6815,6906,"You were never,"],[6906,7015,"fit to be a Ramma."],[7015,7132,"The only good thing about you"],[7132,7198,"is your money."],[7757,7836,"You know,"],[7836,7987,"you're worth more to us"],[8024,8116,"dead than alive."],[8137,8237,"That's the surprise?"],[8299,8416,"You wanted to kill me?"],[8475,8529,"Brian,"],[8529,8717,"I just bought you your dream car."],[8779,8888,"And I was going to give you"],[8892,9042,"half of my inheritance today."],[9042,9104,"We were gonna"],[9104,9221,"save the world together."],[9221,9388,"You're really that stupid?"],[9442,9613,"I thought you were my best friend."],[9818,10014,"You thought wrong."],[10043,10105,"It's okay."],[10151,10285,"I don't want to be a Ramma anymore."],[10314,10510,"Can you please just let me go?"],[10523,10652,"I'm sorry, babygirl."],[10719,10819,"It's just too late."],[10944,11006,"What?"],[11069,11148,"What are you doing?"],[11478,11557,"Goodbye, my love."],[13388,13450,"Are the rumors about"],[13450,13559,"Ashlyn Wadsworth true?"],[13621,13767,"She's been depressed"],[13767,13888,"ever since her dad died."],[13901,14009,"And I've tried to help her,"],[14018,14093,"but she,"],[14093,14185,"she pushed me away."],[14185,14285,"And now she's uh-"],[14285,14397,"She's been struggling with alcohol,"],[14489,14581,"for a long time."],[14585,14739,"It was a terrible accident."],[14739,14902,"My God, Ashlyn was an alcoholic?"],[14902,15031,"Good girls have bad sides too."]],"3":[[8,129,"Did they say Ashlyn?"],[183,291,"Is my sister here?"],[346,475,"Sadly, we just confirmed that"],[475,642,"SMU freshman Ashlyn Wadsworth,"],[675,846,"the sole heir to the Wadsworth fortune,"],[892,1055,"was trapped in a sorority house fire"],[1055,1159,"and is presumed dead."],[1213,1263,"No."],[2010,2114,"No, Ashy!"],[2114,2168,"Junie!"],[2168,2369,"Let go of my sister!"],[2456,2656,"Say goodbye, forever."],[2786,2932,"I'll find you, I swear!"],[3269,3407,"After eleven years,"],[3457,3645,"I finally found you, Ashlyn,"],[3670,3807,"just like I promised."],[3908,4045,"But I was one day too late."],[4425,4571,"Why does she have your necklace?"],[4608,4788,"Did she do this to you?"],[4884,5030,"She was my Little and I,"],[5071,5205,"I was supposed to protect her."],[5209,5388,"I feel like I should die, I-"],[5430,5613,"Someone please put me out of my misery."],[5613,5684,"Hey, you know what?"],[5684,5826,"Can we, can we, no more questions."],[5847,5930,"Please just say a prayer"],[5930,6043,"for our Ramma family, okay?"]],"4":[[287,337,"Ashlyn?"],[475,571,"It's impossible."],[600,792,"We saw her burn in that fire."],[938,1026,"She looked at me"],[1026,1176,"like I was Ashlyn's ghost,"],[1226,1384,"like she doesn't know I had a twin."],[1476,1534,"What would she do"],[1534,1672,"if I brought her back to life?"],[1847,1947,"And I think people"],[1947,2135,"believe every word we said."],[2143,2239,"I mean clearly."],[3098,3194,"Wait, wait, wait, wait."],[3257,3361,"I need to shower first."],[3378,3461,"No, no, no."],[3461,3545,"But I like you dirty."],[3582,3645,"Hey."],[5084,5184,"You know, I thought I saw her"],[5184,5276,"at the press conference."],[5497,5547,"Ashlyn."],[5864,5947,"Yeah, that's impossible,"],[5947,6031,"because if she managed to"],[6031,6172,"escape the fire, her face,"],[6181,6297,"would be burnt to a crisp."],[6356,6506,"You got her to unlock"],[6506,6681,"her Ramma Phi legacy chest, right?"],[6723,6823,"That's where she put all the codes"],[6823,6894,"to her trust?"],[6940,7065,"Shit, no, I thought you did."],[7215,7303,"I thought you did,"],[7303,7415,"but you have the necklace, right?"],[7461,7570,"Yes, I have the necklace,"],[7570,7799,"but the chest is sealed with blood,"],[7816,7891,"Ashlyn's blood!"],[7891,7970,"And in case you forgot,"],[7970,8041,"she's dead now."],[8045,8204,"Hey, it was your idea to kill her"],[8204,8320,"and steal her inheritance."],[8400,8483,"Keep your mouth shut."],[8571,8700,"You never know who could be listening."],[9780,9914,"My sister was murdered,"],[10068,10135,"by the people"],[10135,10310,"she loved and trusted the most."]],"5":[[25,83,"Relax."],[158,229,"She's dead."],[1209,1280,"Hey."],[1881,2031,"I have to become my sister,"],[2081,2256,"and make them pay for what they did."],[3224,3336,"We never would have worked out,"],[3382,3624,"but I promise to take really good care"],[3624,3720,"of your inheritance."],[3924,3999,"Sorry Little,"],[4029,4129,"but this necklace looks"],[4129,4220,"way better on me."],[5017,5138,"So now that her family's gone,"],[5138,5238,"who gets all the billions?"],[5301,5463,"Ashlyn was the most important person"],[5463,5522,"in my life."],[5622,5759,"But, her father,"],[5759,5872,"left her a fortune,"],[5910,6006,"to his only daughter."],[6043,6252,"And before she passed,"],[6256,6381,"she said that she wanted me"],[6381,6552,"to use all her money to start a charity,"],[6594,6677,"to help,"],[6677,6844,"girls struggling with substance abuse."],[6861,7011,"I just wish she could be here today,"],[7011,7102,"and we could have saved her."],[7182,7357,"Wait, so because you're banging her,"],[7357,7461,"you get to keep all the money?"],[7515,7574,"Oh, no."],[7645,7778,"I will be co-chairing,"],[7816,7887,"the charity,"],[7887,7982,"to keep him honest."],[8128,8279,"I mean, she was my best friend and,"],[8345,8445,"my Little, so,"],[8454,8571,"it's what she would have wanted."],[8658,8963,"If no one's opposed, I-"],[8963,9034,"I object!"]],"6":[[1184,1388,"I'll never be reunited with my sister,"],[1388,1484,"but with her name,"],[1484,1568,"I'll get my revenge."],[1568,1718,"Ashlyn, thank God you're alive!"],[1760,1893,"Bro, what the fuck?"],[1926,1993,"Where were you?"],[2035,2198,"Oh my God,"],[2198,2352,"you scared us, girlie."],[2352,2448,"We didn't know if you"],[2448,2569,"made it out of that house."],[2677,2815,"She's back from the dead."],[2882,2977,"That's not possible."],[3107,3215,"Look who's scared now."],[3257,3311,"Brian,"],[3395,3532,"baby, didn't you miss me?"],[3745,3828,"Oh, Mickey."],[3895,4045,"How is she not even burned?"],[4070,4216,"I lit her on fire myself."],[4362,4567,"That is not Ashlyn."],[4863,5005,"Come on, Brian."],[5005,5055,"Really?"],[5121,5192,"It's me,"],[5251,5363,"your loving girlfriend."],[5847,6014,"Did you miss me, bestie?"],[6919,7015,"I'm, I'm confused,"],[7015,7248,"you guys are here crying over my grave,"],[7265,7340,"but I'm alive."],[7340,7394,"I'm here."],[7407,7549,"Aren't you happy to see me?"],[7649,7820,"The real Ashlyn Wadsworth is dead."],[7932,8053,"So who the hell are you?"]],"7":[[16,283,"She's so sure my twin sister is dead,"],[291,450,"because she killed her."],[483,533,"Baby,"],[667,779,"aren't you happy to see me?"],[817,1046,"Look, I wish more than anyone here"],[1076,1184,"that she would be back."],[1217,1322,"You may have the same face,"],[1322,1422,"but you are not Ashlyn."],[1476,1526,"Really?"],[1643,1822,"August 4th, 2024,"],[1822,1935,"the first day we met."],[1976,2056,"We were at school and,"],[2093,2227,"you asked me where the library was and,"],[2235,2293,"I showed you"],[2293,2394,"even though you knew exactly"],[2394,2452,"where to go."],[2610,2677,"And then, you know,"],[2677,2777,"September 9th,"],[2777,2869,"first time we kissed."],[2882,3098,"We were at that Velta Tau party and,"],[3098,3199,"it was really fun."],[3203,3345,"That Charli song was playing."],[3365,3424,"And then, you know,"],[3424,3570,"last week at the crossing"],[3620,3716,"for Ramma Phi- - Okay!"],[3716,3774,"That's enough!"],[3987,4062,"Wait, hold on."],[4062,4170,"If Ashlyn's alive,"],[4179,4275,"then is this whole funeral"],[4275,4379,"just like a marketing ploy"],[4379,4504,"for the new Wadsworth charity?"],[4667,4763,"How did this happen?"],[4767,4909,"We covered all our tracks."],[4959,5125,"I'm sorry, the Wadsworth charity?"],[5184,5342,"Well, I am here and I'm alive,"],[5342,5447,"so why don't I decide"],[5447,5563,"what I get to do with my money?"],[5572,5663,"Okay, so you,"],[5663,5826,"memorized some basic facts"],[5826,5964,"off of Ashlyn's Instagram."],[6056,6160,"Good job, stalker."],[6197,6277,"Do you really remember"],[6277,6352,"what happened?"],[6368,6489,"Like a week ago when you,"],[6535,6677,"drank yourself to death?"],[6702,6756,"Liar."],[6781,6886,"There's no way my sister"],[6886,6961,"would have done that."],[6990,7090,"Maybe I can scare her"],[7090,7219,"into spilling the truth."],[7620,7711,"Oh, what the..."],[8187,8237,"Sorry."],[8341,8475,"My lungs are still a little,"],[8583,8708,"smokey. But,"],[8754,8837,"they wouldn't be that way"],[8837,8929,"if someone didn't leave me"],[8929,9013,"there to die."],[9059,9104,"Right?"]],"8":[[387,479,"Okay, okay."],[713,779,"So then you,"],[888,1034,"you don't remember what happened."],[1071,1130,"That makes sense,"],[1130,1263,"because you were blackout drunk."],[1322,1409,"No, no."],[1409,1622,"No one left you anywhere."],[1639,1810,"You threw yourself a fit and"],[1810,1943,"locked yourself in a closet."],[2085,2210,"And then you got so drunk"],[2210,2327,"that you passed out and,"],[2360,2485,"and knocked over a candle."],[2656,2790,"By the time me and Brian found you,"],[2790,2886,"it was just too late."],[2932,3115,"So, they were at the scene of the crime."],[3153,3211,"I knew it."],[3232,3349,"I knew they killed her."],[3424,3557,"I'm still really,"],[3636,3816,"tired and fuzzy."],[3991,4200,"But, I survived the night."],[4225,4425,"And that means I'm officially a Ramma."],[4466,4583,"So, woo!"],[4917,5009,"What the fuck?"],[5092,5205,"I think this one belongs to me."],[5626,5726,"Gorgeous necklace."],[6035,6085,"Alright,"],[6122,6239,"I'll see you all back at the house."],[6785,6981,"That, that wasn't actually"],[6981,7048,"Ashlyn, right?"],[7048,7165,"She was never that bold."],[7190,7332,"No, no, no, no."],[7428,7549,"I don't know who the fuck that is,"],[7549,7636,"but she's going down."]],"9":[[183,287,"Rushing Ramma Phi"],[287,442,"was my twin sister's dream."],[542,604,"What are you doing?"],[671,825,"Until it became her nightmare."],[1009,1121,"Ashlyn's bestie and"],[1121,1255,"her frat bro boyfriend"],[1255,1355,"hazed her to death,"],[1388,1559,"so they could steal her inheritance."],[1568,1693,"Time to take this place over"],[1693,1843,"and tear it down from the inside."],[1881,1989,"You know only real Rammas"],[1989,2089,"can enter this house."],[2168,2323,"And even though you look like Ashlyn,"],[2331,2456,"we all know that you're a fake."],[2540,2640,"No, I,"],[2640,2723,"I rushed."],[2769,2907,"So, I belong here."],[2944,3036,"Oh, you did?"],[3082,3194,"You rushed Ramma?"],[3194,3240,"Really?"],[3265,3319,"Okay,"],[3353,3524,"then you must have one of these, right?"],[4441,4592,"Every girl gets hers during hell week"],[4592,4758,"to prove her loyalty to Ramma Phi."],[4825,4946,"And if you don't have a tattoo,"],[4946,5117,"then there's no entry."],[5259,5301,"Get her."],[5497,5534,"Stop."],[5534,5593,"Let go!"],[5593,5676,"Listen, we all know"],[5676,5759,"you don't belong here."],[5809,5922,"But if you want to fit in, then"],[5922,6026,"maybe we can give you a"],[6026,6101,"mark of your own."],[6481,6564,"This is what happens when"],[6564,6698,"fake bitches try to scam their way"],[6698,6777,"into Ramma Phi."],[6911,7127,"They get scarred for life."]],"10":[[33,154,"She has the tattoo."],[241,354,"She must be Ashlyn."],[567,679,"How the hell do you have that?"],[1643,1801,"I'm doing this for you, sister."],[2064,2210,"Well, I am in the sorority."],[2243,2364,"So I clearly belong here."],[2644,2690,"Argh!"],[3011,3111,"Play with fire,"],[3111,3244,"and get burned, Mckenna."],[3595,3674,"I don't know who the hell"],[3674,3757,"you think you are,"],[3816,3953,"but the real Ashlyn,"],[3953,4004,"is dead."],[4095,4216,"And she's never coming back."],[5288,5397,"Where am I?"],[5518,5597,"I blacked out"],[5597,5789,"the night of my sorority crossing."],[5947,6060,"What happened to me?"]],"11":[[112,200,"So why don't we all give"],[200,333,"a big Ramma Phi welcome"],[333,462,"to our newest sister!"],[467,517,"Yeah?"],[1580,1655,"This bitch is storming"],[1655,1797,"my sorority like she owns it."],[1818,1910,"We all know she can't"],[1910,2006,"really be Ashlyn, and"],[2006,2102,"I'm not going to let her steal"],[2102,2160,"our blood money."],[2260,2318,"Yeah..."],[2323,2460,"Okay then, what are we gonna do?"],[2565,2686,"I'm gonna call a house meeting"],[2686,2815,"and expose her in front of everyone."],[3853,4029,"Was this your life, sister?"],[4066,4266,"A boyfriend who murders for money?"],[4325,4525,"A bestie who hazed you to death?"],[5192,5367,"I'm taking back everything,"],[5413,5522,"they stole from you."],[5780,5851,"As you all know,"],[5868,6031,"we are using Ashlyn's inheritance,"],[6043,6235,"to start the Wadsworth Charity"],[6235,6377,"for college girls struggling"],[6377,6473,"with substance abuse."],[6493,6639,"Yes, this is a"],[6639,6794,"very important topic,"],[6794,6986,"that affects thousands,"],[7015,7173,"of high potential young women."],[8437,8491,"Don't worry,"],[8537,8637,"I'll take it from here."]],"12":[[287,358,"I mean, I am,"],[358,454,"Ashlyn Wadsworth."],[479,517,"First of all,"],[517,654,"I just want to say, I am"],[654,813,"so sorry if I scared"],[813,913,"any of you guys"],[921,1042,"when you all thought I had,"],[1084,1159,"passed away."],[1259,1409,"I'm truly sorry for that,"],[1459,1643,"but I would also like to thank my love,"],[1672,1906,"Brian, for trying to honor my wishes,"],[1939,2089,"by creating this charity."],[2122,2235,"As some of you may know,"],[2235,2402,"my father has left me with..."],[2498,2660,"billions. And so I,"],[2694,2773,"Ashlyn Wadsworth,"],[2861,2944,"would like to,"],[2969,3107,"decide what I want to do with it."],[3132,3190,"So you're keeping"],[3190,3315,"all that money to yourself?"],[3365,3432,"The Ashlyn I knew,"],[3432,3557,"was never this selfish."],[3561,3607,"Yeah."],[3636,3766,"And everyone's saying she"],[3766,4012,"died in a fire, eight days ago."],[4024,4183,"Why should we believe the crook,"],[4183,4295,"claiming to be her?"],[4517,4667,"It's super sus."],[4692,4788,"I mean, are you trying to steal"],[4788,4884,"the Wadsworth fortune?"],[4996,5180,"Wow, tough crowd."],[5209,5351,"You guys are all so desperate"],[5351,5472,"for me to prove myself."],[5743,5839,"Well, go ahead."],[5922,5968,"Try me."],[6043,6151,"I know how you can prove it."]],"13":[[58,158,"Is that,"],[158,279,"Ashlyn's legacy chest?"],[342,446,"As you all know,"],[458,608,"each new potential member"],[608,742,"puts their most valued possession"],[742,829,"into the legacy chest"],[829,1005,"to prove their loyalty to Ramma Phi."],[1067,1209,"All the passwords"],[1209,1438,"into this chest on that night."],[1497,1730,"So, only the true heiress"],[1760,1851,"of the Wadsworth fortune"],[1910,1976,"could unlock it."],[2043,2127,"You unlock the chest,"],[2181,2360,"You prove your identity."],[2360,2510,"It's, it's pretty simple."],[2581,2681,"They're setting a trap,"],[2761,2869,"but I won't fall for it"],[2869,2982,"like my sister did."],[2998,3061,"What's wrong?"],[3132,3228,"I thought you wanted to prove"],[3228,3278,"that you're not"],[3278,3428,"a bottom-feeding scammer."],[3490,3657,"Says the pathetic bitch that"],[3657,3853,"steals from her best friends."],[4124,4212,"The Ashlyn I knew"],[4212,4375,"would never dish burns like that."],[4408,4612,"Yeah, especially not to her Big."],[4637,4788,"Well, people change."],[4996,5205,"What are we waiting for, you know? Just,"],[5326,5372,"unlock it."],[5372,5430,"What's wrong?"],[5434,5572,"We're, we're all waiting, right?"],[5601,5672,"Yeah, we don't have all day."],[5672,5755,"Prove yourself."],[5755,5809,"Come on!"],[5814,5860,"Okay."],[5926,5985,"We're waiting."],[6006,6097,"If I fail,"],[6168,6239,"the monsters"],[6239,6356,"who hazed my twin to death"],[6356,6514,"will steal my family's fortune."],[6577,6731,"I have to open that chest."],[7261,7407,"How does she have the same necklace?"]],"14":[[229,350,"Why won't it open?"],[496,542,"Yup."],[567,746,"Surprise, surprise, right guys?"],[771,846,"She's a fraud."],[1084,1213,"Get the fuck out, imposter."],[1230,1326,"I can't give up."],[1355,1488,"I have to open this chest."],[1626,1693,"Don't bother."],[1789,1901,"You clearly have a fake one."],[2031,2139,"Because I have the real one."],[2256,2427,"The real Ashlyn gave it to me."],[2498,2598,"Because she wants me to"],[2598,2656,"have the money."],[2748,2890,"Because she trusts her Big,"],[2898,2973,"more than anyone."],[3028,3199,"Mckenna stole that necklace"],[3199,3274,"from my sister,"],[3319,3440,"the night that she killed her."],[4225,4300,"What the hell?"],[4362,4433,"Sorry, Mickey."],[4475,4558,"I changed my mind."],[4909,5005,"You don't even know"],[5005,5142,"how to open a legacy box, do you?"],[5263,5484,"Yeah, I don't remember exactly"],[5484,5676,"because my brain is still really fuzzy,"],[5676,5809,"you know, from the accident."],[5822,5905,"Oh, okay."],[5905,5964,"Well,"],[6060,6177,"let me help remind you."],[6222,6377,"It's not the key that opens it."],[6594,6660,"It's blood."],[6906,7044,"Ashlyn Wadsworth's blood,"],[7044,7127,"to be specific."],[7173,7344,"And you only get one more chance"],[7344,7453,"to open this box,"],[7474,7720,"until it locks up forever."],[7778,7828,"Then,"],[7999,8112,"why don't we make a little bet?"],[8179,8291,"With a random psycho"],[8291,8483,"pretending to be our dead friend?"],[8491,8591,"Yeah, no way."],[8616,8679,"Oh, I mean,"],[8679,8783,"are you scared"],[8783,8967,"that I am the real Ashlyn?"],[9009,9063,"Fine."],[9221,9342,"But if I'm in, we're all in."],[9371,9463,"Let's hear it, Rammas."],[9505,9617,"One heart,"],[9617,9726,"one way,"],[9726,9847,"one sisterhood."],[10026,10072,"Fuck it,"],[10072,10164,"Veltas are in too."],[10201,10339,"So, what are the stakes"],[10339,10431,"in this little bet, huh?"],[10460,10652,"Okay, well, if I open the box,"],[10702,10773,"then I become"],[10773,10894,"Ramma Phi President."]],"15":[[8,108,"Oh, and then one more thing,"],[108,179,"I know,"],[196,367,"how you like to haze your girls,"],[396,492,"Madam President."],[1042,1180,"When I prove that I'm Ashlyn, then,"],[1230,1322,"I get to do it to you."],[1359,1443,"But let's see, what,"],[1443,1534,"what would I write?"],[1614,1701,"Well, liar,"],[1785,1864,"clout-chaser,"],[1997,2110,"best friend that"],[2110,2218,"fucked my boyfriend?"],[2569,2660,"Oh my God."],[2723,2852,"Ashlyn was my Little."],[2869,2927,"I can't believe"],[2927,3086,"you would even accuse me"],[3086,3182,"of doing such a thing."],[3203,3253,"Ashlyn never"],[3253,3374,"doubted our relationship."],[3403,3566,"How much does this bitch know?"],[3703,3891,"She's turning them all against me."],[3891,4120,"I can't let that happen."],[4383,4542,"I am Ramma Phi President."],[4704,4804,"You don't want to cross me."],[4842,4934,"Well, are you,"],[4984,5134,"scared that I might treat you"],[5134,5271,"like a new potential member?"],[6018,6089,"And what happens"],[6089,6206,"if you don't open the box?"],[6239,6502,"Then I'll drop out of Ramma Phi,"],[6527,6664,"and I won't stop you"],[6664,6785,"from using my trust"],[6785,6923,"to fund your Wadsworth Charity."],[6973,7007,"Fuck it,"],[7007,7127,"I'll give you the passwords as well."],[7169,7315,"There's no way she'll open it."],[7382,7524,"She'll be exposed as a fraud,"],[7570,7761,"and Brian and I will be filthy rich."],[8600,8654,"You're on."],[8842,8917,"She's not actually going to"],[8917,9021,"do this, right?"],[9109,9159,"Hell no."],[9196,9371,"Look, you can steal a face."],[9376,9534,"You can steal a key."],[9622,9722,"But to open this box,"],[9722,9818,"you're going to need blood."],[9843,9943,"And you can't steal that."],[9989,10097,"And it only flows"],[10130,10243,"through Ashlyn's veins."],[10285,10356,"Last chance."],[10489,10543,"Do it now."],[10769,10994,"Sister, I can't lose this bet."],[11073,11261,"If you really are my long-lost twin,"],[11290,11428,"then I bleed the same as you."],[12633,12716,"One heart."],[12800,12892,"One way."],[13246,13342,"One sisterhood."]],"16":[[1201,1388,"Twin blood, same DNA."],[1434,1539,"I knew it would work."],[1672,1768,"There's no fucking way."],[1847,1972,"This, this isn't her."],[2014,2193,"So, she's Ramma Phi President now?"],[2193,2335,"Wait, you said she was an imposter."],[2352,2552,"She is an imposter, there's..."],[2648,2781,"No, she's, she's conning us"],[2794,2907,"to become the president."],[2948,3098,"Well, if I was an imposter,"],[3098,3228,"how would I open this blood seal?"],[3249,3424,"This is my vault, my chest,"],[3424,3541,"and I just proved myself."],[3812,4020,"Do you believe me now, B?"],[4358,4483,"Look, you must have fucked up the seal."],[4483,4650,"I didn't fuck up anything, Brian."],[4688,4800,"Didn't you just say"],[4800,4938,"that the blood that opens this"],[4984,5096,"is Ashlyn's?"],[5363,5405,"It's her."],[5467,5534,"No, it's not."],[5538,5609,"Shh. Shut up."],[5626,5718,"Ashlyn, we're so sorry"],[5718,5797,"we doubted you."],[5818,5910,"Can you ever forgive us?"],[5997,6114,"You're a woman and I believe you."],[6168,6318,"Great, I'm glad you all believe me."],[6352,6548,"Well, sisterhood isn't anything"],[6569,6706,"without trust, right?"],[6861,7073,"Anyone that questions"],[7073,7161,"my identity,"],[7178,7236,"will be stripped"],[7236,7323,"from their membership,"],[7357,7428,"immediately."]],"17":[[37,120,"We only doubted you"],[120,200,"because Mckenna said"],[200,271,"you were faking it."],[300,392,"Then listen to me,"],[421,571,"and stop following Mckenna,"],[613,734,"or find a new sorority."],[788,855,"What the hell, Mckenna?"],[855,942,"You know if I get dropped,"],[942,1026,"I have to transfer."],[1026,1138,"Why'd you tell us she was a fake?"],[1163,1351,"Right, and without this sisterhood,"],[1368,1514,"my ten-year plan is like,"],[1514,1639,"totally fucked."],[1689,1918,"And you and Brian dragged us into this."],[1993,2052,"Fix it."],[2056,2223,"My family will legit disown me"],[2223,2335,"if I lose the Rammas."],[2385,2523,"Are you guys forgetting who I am?"],[2569,2773,"I'm your Ramma Phi President,"],[2781,2915,"and she's stealing my power."],[2915,3011,"Can't you guys see?"],[3257,3365,"She's ruining my life,"],[3424,3557,"and she's going to destroy"],[3557,3641,"my senior year."],[3749,3874,"I'm over all this shit."],[3924,3999,"Let's go, Brian."],[4020,4079,"Wait, wait, Brian."],[4204,4454,"Don't you want to stay here and,"],[4525,4625,"run the charity with me?"],[4721,4875,"Just like we've always talked about?"],[4921,5038,"You still want to do that with me?"],[5171,5255,"No way in hell."],[5313,5497,"I'll rip you and Mckenna apart,"],[5497,5622,"and you won't get a cent"],[5622,5743,"of my family's money."],[5822,5943,"I've always loved you."],[6014,6177,"It made me, like, really sad"],[6177,6243,"that you didn't,"],[6352,6489,"believe that I was Ashlyn."],[6531,6727,"I'm pretty heartbroken about it,"],[6727,6840,"honestly, because,"],[6840,6981,"it's always been me and you."],[7027,7186,"Let's do this together, baby."],[7219,7328,"Take the bait, dipshit."],[7353,7503,"Betray Mckenna, just like you"],[7503,7611,"betrayed my sister."],[7695,7845,"Even if this bitch is a fraud,"],[7887,8020,"I get more money sticking with her"],[8020,8153,"than walking away with Mckenna."],[8425,8562,"Of course I will, baby."],[8729,8842,"Look, I'm just so happy"],[8842,8908,"that you're alive,"],[8908,9021,"and, oh!"],[9050,9180,"I'm so sorry I ever doubted you."],[9180,9246,"I just-"],[9246,9380,"But Brian, what about us?"],[9426,9542,"You said you wanted to dump her"],[9542,9630,"and that you wanted me."],[10097,10151,"Shut up!"],[10606,10668,"She's lying."],[10685,10806,"Oh, yeah, really?"],[10848,10910,"After all that - Yes."],[10910,10965,"we've done?"],[11227,11315,"You said it yourself"],[11340,11444,"that she should have died."]],"18":[[258,371,"Was that a confession?"],[433,475,"I, I-"],[483,571,"No, no, no,"],[571,771,"I mean that his relationship with her"],[771,930,"should have died a while ago."],[975,1117,"Come on, Brian. You know that"],[1117,1334,"ever since you two got together,"],[1426,1497,"we've been-"],[2089,2193,"Everyone is listening,"],[2193,2556,"so I need you to shut the fuck up."],[2602,2644,"Hm?"],[2723,2882,"Hey, what, what the fuck is going on?"],[3053,3107,"Nothing."],[3140,3240,"Oh, nothing?"],[3274,3403,"You don't just plan a murder?"],[3411,3486,"And then just-"],[3853,3924,"She's crazy."],[3933,4024,"I'm crazy?"],[4041,4183,"You are such a hypocrite."],[4216,4350,"Mckenna, I love you."],[4375,4491,"You're the best I ever had."],[4491,4625,"I want to marry you."],[4671,4733,"We never..."],[4829,4925,"Ash, I swear. - Oh?"],[4925,5009,"Oh, really?"],[5034,5150,"You never, okay."],[5280,5384,"Then why did you ditch her"],[5413,5547,"and give me this promise ring?"],[5689,5893,"This asshole cheated on my sister"],[5893,5980,"with her best friend"],[5980,6106,"the whole time they were dating?"],[6177,6297,"They deserve everything"],[6297,6398,"that's coming to them."],[6477,6527,"Brian, I-"],[6569,6719,"I didn't know that you,"],[6719,6848,"broke up with me and,"],[6861,6931,"now you're,"],[6969,7061,"just with her, like-"],[7061,7161,"No."],[7211,7257,"I,"],[7311,7449,"look, she's just trying to hurt you."],[7465,7595,"Brian, you wanted me first,"],[7595,7670,"don't you remember?"],[7670,7811,"You came on to me, begging."],[7853,7903,"Go, hey-"],[7999,8120,"Back off! She's"],[8120,8220,"freaking me out."],[8241,8454,"You're supposed to be Ash's big sister."],[8487,8554,"Okay, you're supposed to"],[8554,8629,"look out for her."],[8629,8708,"You're supposed to,"],[8729,8787,"and, and"],[8787,8858,"and how does it feel"],[8858,9004,"to just, you know, betray her like that?"],[9059,9138,"I can't,"],[9163,9280,"trust a sister"],[9280,9376,"that's going to go after"],[9376,9480,"another girl's boyfriend."],[9480,9659,"Or a sister that would haze her"],[9659,9813,"best friend to death."],[9813,9914,"It's time to take you down."],[9968,10089,"You're kicked out of Ramma Phi."]],"19":[[112,287,"Okay, yeah, you can't do that."],[287,358,"Yes, I can."],[442,533,"I'm the president now,"],[625,688,"remember?"],[875,959,"Wait, no, no."],[1034,1130,"A bet's a bet."],[1730,2068,"This is for everything you did to my sister."],[2168,2369,"You should be so ashamed of yourself."],[2439,2594,"She hazed you all."],[2631,2790,"She humiliated you."],[2844,2994,"Don't you want to fight back?"],[3094,3399,"This is for giving me alcohol poisoning!"],[3495,3828,"And this is for calling me worthless!"],[4045,4137,"Oh my God."],[5276,5367,"You set this up!"],[5643,5734,"Get outta my way!"],[5747,5805,"Hey, everyone,"],[5809,5880,"well, I'm here"],[5880,5997,"to set the record straight."],[6022,6135,"The rumors are true."],[6143,6348,"And I, Ashlyn Wadsworth,"],[6364,6456,"am still alive."],[6514,6627,"And I'm starting a charity,"],[6685,6840,"with my boyfriend, Brian."],[7987,8116,"The Wadsworth family heiress."],[8149,8329,"Everyone thought she died in a fire, but,"],[8354,8550,"I guess, she's risen from the dead."],[8583,8746,"Try to focus on something nicer,"],[8804,8858,"like you'll get your"],[8858,8963,"stitches out tomorrow."],[9050,9159,"You'll be back to your old life"],[9159,9234,"before you know it."],[9250,9384,"My old life?"],[9384,9492,"But somebody already"],[9492,9597,"took my place."],[9768,9884,"Who is she?"]],"20":[[825,888,"Okay, girls,"],[942,1034,"the Rammas have never won,"],[1034,1076,"so this year,"],[1076,1201,"we're gunning for number one, okay?"],[1397,1526,"Hey, are you sure about this, Ash?"],[1526,1639,"Because you're not the most"],[1639,1735,"athletic, you know."],[2010,2223,"Ashlyn, you look tired."],[2268,2335,"Trouble sleeping"],[2335,2469,"after stealing my sisterhood?"],[2535,2669,"Don't tell me you're competing, too."],[2694,2781,"You know, last time I checked,"],[2781,3036,"I stole all your Ramma girls, so-"],[3036,3153,"I found a new sorority."],[3349,3432,"And when we win,"],[3440,3603,"I'm taking back Ramma Phi, too."],[3649,3724,"You're that confident"],[3724,3812,"that you're going to win?"],[3820,3958,"Sweetheart, I've seen you run to class"],[3999,4183,"like a three-legged cow."],[4354,4487,"You might as well just quit,"],[4517,4650,"and save yourself the embarrassment."],[4800,4892,"You're worthless,"],[4921,4996,"unlovable."],[5572,5651,"She's kinda right,"],[5651,5747,"you might get hurt."],[6639,6790,"My sister wasn't strong enough"],[6790,6848,"to fight back,"],[6848,6952,"so they killed her."],[7011,7069,"But this time,"],[7069,7207,"they fucked with the wrong twin."],[7432,7607,"I won't stop until they both go down."]],"21":[[12,83,"How about this?"],[120,175,"You win,"],[233,350,"you get your Rammas back."],[375,475,"And if you lose,"],[513,625,"you have to tell me the truth"],[625,709,"about what happened"],[709,813,"the night of my crossing."],[938,1001,"You're on."],[1422,1530,"All contestants,"],[1543,1655,"make your way to the front."],[1655,1889,"The games are about to begin!"],[1893,2014,"This is gonna be so fun."],[2198,2339,"All right, let's do this, Rammas!"],[2402,2552,"Mckenna's right about one thing."],[2619,2748,"Winning will be fun."],[2840,2986,"This is the Frat Pack relay."],[3032,3261,"And the first leg, CPR Shots."],[3470,3566,"Pick your man,"],[3628,3732,"and go!"],[4950,5084,"This is the perfect chance"],[5084,5180,"to break his heart."],[5776,5947,"After what you did to my sister,"],[6031,6110,"you deserve it."]],"22":[[154,283,"And they're off, okay."],[300,608,"Next stop, the Pop N' Grind."],[1693,1747,"Harder!"],[2077,2281,"And now we're down to our last round,"],[2289,2364,"Whip N' Lick."],[2381,2515,"First two to lick their man clean"],[2515,2598,"go to the finals."],[2736,2840,"Don't take it personal, B."],[2852,2923,"We all do bad things"],[2923,3028,"to get what we want, right?"],[4074,4320,"And we have our final competitors,"],[4337,4667,"Mckenna Halsey and Ashlyn Wadsworth!"],[4667,4733,"What did you say about me"],[4733,4850,"embarrassing myself?"]],"23":[[191,241,"That,"],[304,383,"was close."],[383,588,"So, your big takeover might backfire."],[625,759,"I've got her right where I want her."],[1001,1134,"Did you get the jello shots ready?"],[1142,1201,"Yeah but,"],[1259,1443,"isn't Ashlyn like, deathly allergic"],[1443,1522,"to gelatin?"],[1530,1626,"If she drops dead,"],[1668,1755,"the Rammas are mine."],[1822,1956,"And no one will ever know the truth"],[1956,2060,"about what happened that night."],[2097,2260,"Ladies and gentlemen,"],[2260,2510,"I give you our top two competitors."],[2544,2719,"And now for the final event,"],[2731,2802,"the terrible,"],[2844,2902,"the horrible,"],[2948,3053,"the legendary,"],[3094,3265,"Drunk Girl Dash!"],[3382,3486,"Pay attention girls,"],[3490,3566,"the Drunk Girl Dash"],[3566,3728,"is SMU Sorority tradition."],[3745,3878,"First, you do one-two-three shots,"],[3887,3995,"and then you race through the course"],[3995,4091,"as fast as you can."],[4108,4254,"Nine out of ten attempts"],[4254,4371,"results in vomit,"],[4391,4525,"and humiliation."],[4546,4637,"Consider this payback"],[4637,4763,"for stealing my sorority."],[4763,4975,"It's not payback, it's karma."],[5013,5150,"She thinks she has a chance,"],[5284,5467,"but she's about to go down for good."]],"24":[[266,446,"Oh, jello shots, your favorite."],[513,596,"Take your mark."],[621,721,"Winner takes all."],[867,992,"In this case, Ramma Phi."],[1059,1176,"May the best Ramma win."],[1184,1242,"Oh, I will."],[1259,1347,"Drunk Girl Dash."],[1347,1447,"Let's fucking go!"],[1463,1630,"Ready, and,"],[1630,1926,"three, two, one, drink!"],[2794,2915,"Woo!"],[3053,3136,"Are you feeling okay?"],[3190,3265,"Why wouldn't I be?"],[3294,3399,"I knew you were a fraud."],[3457,3532,"The real Ashlyn"],[3532,3678,"is deathly allergic to gelatin."]],"25":[[179,262,"You're an imposter."],[291,412,"You don't deserve my sorority."],[417,563,"You knew I was allergic to jello."],[575,692,"Are you trying to kill me?"],[871,1063,"Wait, how is Ashlyn still moving?"],[1334,1509,"Thank God I took my allergy pill today,"],[1530,1643,"or else I could have dropped dead"],[1643,1697,"right here,"],[1697,1814,"but that's what you would have wanted,"],[1814,1856,"isn't it?"],[1856,1985,"You can't hijack my sorority"],[1985,2102,"and expect to get away with it."],[2102,2164,"Watch me."],[2369,2485,"Ready? Go, go, go."],[2531,2706,"Let's go Ashlyn!"],[2723,2840,"You got this!"],[2840,2907,"You go girl!"],[3123,3236,"Yeah, Ashlyn."]],"26":[[0,83,"I can't let that bitch"],[83,196,"win and expose me."],[1184,1313,"Brian, come save your girl."],[1363,1484,"Mckenna's trying to get me"],[1484,1605,"to give up and lose,"],[1651,1760,"but I'm one step ahead."],[1764,1864,"Brian, come help me!"],[2331,2460,"Brian, come help me!"],[2840,2919,"Legendary!"],[2919,3036,"Oh my God."],[3078,3199,"Ashlyn, what the hell?"],[3294,3357,"I hate her."],[3407,3499,"Why isn't she dead?"],[3570,3782,"Ramma Phi, until we die!"],[4141,4295,"Woo!"],[4295,4471,"Woo, woo, woo..."],[4471,4629,"What the fuck was all that about, huh?"],[4650,4779,"We're on the same team, remember?"],[4792,4938,"You said the same thing to my"],[4938,5105,"twin sister before you murdered her."],[5142,5217,"Don't be mad."],[5267,5342,"Don't..."],[5372,5526,"I thought you wanted to date"],[5526,5630,"the hottest Rammas,"],[5722,5801,"right? I mean,"],[5801,5893,"aren't you excited"],[5893,6051,"to be the president of my charity?"],[6089,6218,"I can't say no to that money,"],[6218,6368,"no matter how shady this bitch is."],[6373,6435,"Of course I am."],[6948,7102,"So we had a deal, remember?"],[7248,7344,"Are you gonna tell me now?"]],"27":[[54,137,"Forget about her."],[166,258,"Let's party."],[312,529,"Toga party at the Velta Tau house!"],[738,792,"Fine."],[888,988,"Tonight at the party,"],[1042,1126,"I'll tell you what really happened"],[1126,1222,"the night of your crossing."],[1297,1351,"Hm?"],[2022,2114,"The only person"],[2114,2239,"who really knows what happened"],[2239,2348,"is my twin sister."],[2427,2623,"Why do I feel like she's still here?"],[3136,3203,"Are you ready?"]],"28":[[8,237,"But, it's not me."],[258,371,"When you were brought in,"],[371,533,"you were burnt beyond recognition."],[963,1092,"We had to completely"],[1092,1251,"reconstruct your face."],[1280,1463,"I know I'm Ashlyn Wadsworth,"],[1505,1668,"but I can't remember what happened."],[1747,1822,"It was the night of my"],[1822,1943,"sorority crossing."],[2027,2139,"Who started the fire?"],[2227,2344,"I was stuck in there,"],[2377,2452,"but why?"],[2510,2673,"I have to get back to my life,"],[2690,2848,"my bestie, and my love."],[2940,3115,"Brian, Mckenna,"],[3203,3311,"I'm coming back to you."],[4692,4829,"I didn't expect you to show up."],[4859,4904,"Oh, well,"],[4904,5055,"I feel like I owe you the truth."],[5121,5217,"And an apology."],[5317,5384,"Liar."],[5434,5555,"You hazed my twin to death,"],[5555,5722,"and now you'll do anything to avoid"],[5722,5860,"being exposed as a murderer."],[5889,6085,"And what is that, exactly?"],[6114,6222,"For betraying my Little,"],[6256,6435,"and also desperately clinging on"],[6435,6539,"to my Ramma Phi title,"],[6539,6606,"I just..."],[6810,6927,"You have this billion-dollar"],[6927,7048,"safety net, and I,"],[7094,7219,"all I had was the sisterhood."],[7636,7695,"But,"],[7761,7878,"I really am so sorry."],[7878,8024,"I feel like I should die."],[8124,8400,"Then you should try burning to death."]],"29":[[250,329,"I'm just kidding."],[400,471,"I'm just kidding."],[471,638,"I, I forgive you, okay?"],[679,767,"But only,"],[796,913,"only if you tell me"],[913,1038,"what actually happened,"],[1113,1188,"the night of the crossing."],[2293,2481,"Yes, yes, Ashlyn,"],[2489,2635,"of course I will tell you."],[2644,2786,"But first, you know what?"],[2811,2932,"I think we should take a shot."],[3115,3286,"All right, cheers."],[3294,3349,"Cheers."],[4183,4379,"The truth is, that you should have died."],[4446,4629,"Tell me, Ash, how did you survive"],[4658,4783,"burning alive in a fire?"],[5255,5363,"You drugged me."],[5447,5538,"Sorry, babygirl."],[5597,5734,"But I learn from my mistakes."],[5814,5864,"Oh."],[5964,6089,"I tried to kill you once,"],[6131,6243,"and I'm not gonna fail again."],[6297,6402,"And this time,"],[6402,6614,"you're gonna die a disgraced whore,"],[6631,6715,"like you deserve."],[7136,7215,"Basement in ten."],[7311,7382,"Tell everyone."]],"30":[[546,638,"You're the heiress to"],[638,804,"a multi-billion-dollar fortune."],[842,980,"You've never known hard work,"],[1030,1117,"and you never will."],[1351,1480,"Lucky duck."],[1772,1847,"But Mckenna,"],[1922,2106,"my family basically funds"],[2106,2227,"SMU Greek life,"],[2273,2435,"and I've always paid for your dinner."],[2469,2615,"One, fuck you!"],[2698,2748,"Two,"],[2781,2919,"the only interesting thing about you"],[2940,3040,"is your fortune!"],[3132,3207,"But me,"],[3232,3365,"I am a goddamn delight."],[3503,3666,"Why couldn't I be the heiress?"],[3728,3832,"Because, Mckenna,"],[3899,4070,"life is not fair."],[4191,4250,"Oh, I know."],[4358,4487,"I know life isn't fair."],[4592,4696,"Because if it was,"],[4713,4788,"your pretty face"],[4788,4925,"would have been burned to a crisp,"],[4946,5050,"and I would have gotten everything"],[5050,5255,"that I worked so fucking hard for!"],[5926,6035,"I love when you cry."],[6081,6243,"Like when you were begging for mercy"],[6306,6402,"the night of the crossing."],[6464,6664,"You looked so goddamn pathetic."],[6961,7077,"I almost let you go."],[7207,7390,"I should have just finished it off myself."],[7532,7599,"But this time,"],[7757,7974,"I have my own little surprise for you."],[8425,8512,"Surprise."]],"31":[[116,179,"How did you?"],[183,304,"I switched the shots,"],[492,575,"because I knew you'd"],[575,700,"pull some shit like this."],[788,930,"No, that's impossible."],[1901,2293,"You and Brian tried to burn me,"],[2373,2456,"to death."],[2523,2635,"What more do you want?"],[2677,2781,"You already have all the money"],[2781,2848,"in the world."],[2907,3019,"Oh, it's not about the money."],[3165,3378,"It's about revenge."],[3649,3749,"You are all weak,"],[3870,3995,"but I'm here to make you stronger."],[4212,4391,"And if you ever step out of line,"],[4537,4617,"then I'll have dirt on you"],[4617,4725,"for the rest of your life."],[5672,5730,"Aw."],[5851,5951,"Poor little girl."],[6039,6139,"What are you gonna do to me?"],[6331,6406,"I don't know."],[6606,6715,"What should I do to you?"],[6735,6894,"Because you brought me here."],[6894,6940,"No."],[7011,7098,"Basement in ten."],[7219,7294,"Tell everyone."],[7378,7457,"No, no, no, no."],[7494,7590,"That was all Brian."],[7599,7699,"All of it was his idea"],[7699,7820,"and he made me go through with it."],[7895,8024,"Please, I know you're a good person."],[8045,8091,"Oh."],[8199,8287,"It's too late."],[8383,8458,"They're already here."]],"32":[[579,688,"I can't promise you'll look pretty"],[688,779,"once we're done with you."],[967,1021,"Ash,"],[1101,1226,"Ash, just listen to me, okay?"],[1251,1343,"I'm sorry and"],[1347,1422,"please forgive me,"],[1422,1543,"just don't leave me down here."],[1647,1822,"You made your bed, babygirl."],[2160,2256,"Please don't leave me!"],[2506,2556,"Stop."],[2723,2806,"You guys can go."],[3449,3591,"Now you know what it feels like"],[3649,3916,"to be tortured by your best friend."],[3991,4141,"You deserve much worse."],[4216,4358,"But this is just the beginning."],[4567,4621,"Wait."],[4662,4708,"Wait."],[4758,4884,"Wait, wait, wait!"],[4892,4963,"Help!"],[5063,5176,"Help me, please!"],[5522,5714,"For all the pain you suffered, sister,"],[5789,5901,"she will suffer more."]],"33":[[41,87,"Hey,"],[150,200,"Brian."],[296,421,"Brian, Brian, you gotta help me."],[529,629,"Ashlyn did this to me."],[629,729,"She's psychotic!"],[742,817,"We have to actually kill her"],[817,917,"for real this time!"],[921,1034,"Yeah, look."],[1121,1309,"Ashlyn is about to make me"],[1309,1493,"head of the Wadsworth Charity."],[1509,1618,"Now you know what that means"],[1618,1693,"for my future."],[1768,1830,"And you know,"],[1931,2060,"I wanna be president one day."],[2077,2135,"And baby,"],[2164,2293,"this is exactly how I get there."],[2293,2498,"So, she cannot die right now."],[2498,2644,"She needs to sign some paperwork."],[2681,2781,"Because I want her money,"],[2827,2923,"and I want her power."],[2923,2994,"And if that means"],[2994,3123,"choosing her over you,"],[3182,3249,"I'll do it."]],"34":[[91,191,"You are such,"],[241,346,"an asshole."],[367,575,"Oh, oh, come on!"],[625,775,"You act like you didn't try to"],[775,863,"go behind her back"],[863,942,"and murder her."],[967,1080,"Look, you tried to set her up."],[1092,1209,"She was a step ahead."],[1292,1447,"Tough shit, baby. But,"],[1480,1672,"listen, nobody likes a sore loser."],[1768,1897,"Hey, Brian!"],[1926,2031,"What happened to us,"],[2093,2218,"being a team, huh?"],[2398,2552,"Us being a team, oh my gosh."],[2552,2644,"You should hear yourself."],[2644,2715,"I liked you more"],[2715,2811,"when you were,"],[2811,2940,"a stone cold bitch,"],[2948,2998,"you know?"],[3023,3132,"Not whatever this,"],[3161,3507,"this weak woman, victim bullshit,"],[3532,3574,"It, it,"],[3574,3695,"that's what you got going on"],[3695,3770,"right now, baby."],[3803,4004,"So, if you wanna be useful to me,"],[4070,4175,"you know where to find me."],[4216,4291,"Otherwise..."],[4312,4366,"Brian."],[4412,4483,"Leave me alone."],[4533,4587,"Brian!"],[4771,4833,"Brian, you better - Oh,"],[4833,4950,"undo me right now! - oh,"],[4963,5021,"oh."],[5050,5180,"I fucking hate you!"],[6614,6765,"I can't wait to see you, Brian."],[7107,7323,"Hey, hey, this party's invite only."],[7407,7599,"My boyfriend, Brian Bingham,"],[7599,7736,"is the president of Velta Tau."],[8008,8062,"Nice try,"],[8070,8216,"but Brian Bingham"],[8262,8416,"is dating Ashlyn Wadsworth."],[8429,8616,"I know, I'm Ashlyn Wadsworth."]],"35":[[145,241,"If you're Ashlyn,"],[241,400,"then I'm way drunker than I thought."],[521,684,"I swear, it's me, okay?"],[725,875,"My face was burned in an accident"],[875,1005,"and they had to reconstruct it"],[1005,1088,"and now some girl,"],[1105,1201,"who looks just like me"],[1201,1330,"is trying to steal my life,"],[1334,1468,"and pretending to be me."],[1488,1618,"I've heard of thirsty bitches"],[1618,1705,"trying to party crash,"],[1705,1897,"but this is a whole new level of psycho."],[1951,2164,"I know it sounds crazy, okay?"],[2193,2306,"But you have to believe me."],[2619,2698,"Please, let me in."],[2698,2831,"I swear, I know Brian."],[2957,3065,"Look, that's his room."],[3082,3290,"Second floor, third door on the left."],[3328,3541,"Okay, stalker, you're not getting in."],[3541,3616,"So leave or we're gonna have to"],[3616,3687,"make you."],[3807,3924,"Jessica, thank God."],[3941,4079,"It's me, Ashlyn."],[4095,4175,"Tell them you know me."],[4216,4333,"Ew, no, get off of me