{"1":[[279,487,"I'm going to be crowned Luna today."],[508,604,"The day I've been waiting for"],[604,750,"my entire life."],[816,1062,"And I get to do it all with Jax by my side."],[1137,1291,"My loving, doting husband"],[1291,1400,"of three years."],[1800,1920,"Oh, have you seen Jax?"],[1920,1975,"Nope."],[1975,2091,"I have not."],[3066,3129,"Jax?"],[3204,3341,"What the hell are you doing"],[3341,3441,"with my sister?"],[3600,3829,"We're barely sisters, Diana."],[3866,4004,"Don't pretend we're blood."],[4016,4191,"No, I considered you family."],[4216,4325,"And you're my mate."],[4325,4454,"How could you do this to me?"],[4466,4525,"You might have been"],[4525,4625,"my chosen mate,"],[4641,4754,"but I can no longer deny"],[4754,4941,"that Ivy is my fated mate."],[4966,5116,"You really had no idea"],[5116,5279,"we've been doing it for years?"],[5304,5354,"I always thought"],[5354,5466,"you were just spineless."],[5466,5516,"I didn't think"],[5516,5654,"you were actually just stupid."],[5737,5841,"So, that's what you think of me."],[5879,6012,"Well, don't hold back now."],[6050,6237,"I'm pregnant with Jax's baby."],[6600,6729,"And I will not let my child"],[6729,6825,"be a bastard."],[6900,7191,"Diana, I reject you as my mate."],[7191,7225,"No."],[7225,7416,"And strip you of your title as Luna."],[7437,7504,"No!"],[7562,7641,"No!"],[8379,8654,"I accept Ivy as my true mate"],[8687,8916,"and Luna of the Bonehaven Pack."],[9854,10112,"You understand how vital family is."],[10150,10237,"Well, I can't have you"],[10237,10350,"tampering with mine."],[10387,10566,"So start running, sissy,"],[10650,10841,"because I am going to kill you,"],[10875,10962,"and I plan on"],[10962,11154,"enjoying every second."]],"2":[[220,333,"Why can I not transform"],[333,420,"into my wolf?"],[454,620,"Rhea, where did you go?"],[2045,2254,"Ivy, you don't have to do this."],[2254,2370,"I've spent my whole life"],[2370,2495,"watching you get status,"],[2516,2633,"wealth, even the Alpha,"],[2633,2795,"but you never deserved it."],[2816,2933,"So I'm gonna be Luna"],[2933,3033,"while you're a blood bag"],[3033,3170,"at the bottom in this mountain."],[3183,3283,"No, Ivy, please."],[3545,3608,"Moon Goddess,"],[3608,3758,"I wish I could do it all over."],[3779,3895,"I'd change everything."],[6950,7045,"I'm not dead."],[7100,7204,"What just happened?"],[7208,7304,"We have to hurry."],[7304,7420,"If we don't have the wedding cake"],[7420,7533,"prepared before noon,"],[7545,7683,"Madam Edith will kill us all."],[7770,7829,"Wedding?"],[7854,7945,"This can't be real."],[8120,8233,"It's three years ago,"],[8233,8420,"the day of my wedding to Jax?"],[8500,8670,"Was I reborn?"]],"3":[[312,470,"More, Jax, more."],[470,554,"Harder."],[595,704,"Keep your voice down."],[741,904,"I don't want Diana to find out."],[904,1016,"Oh, please."],[1045,1250,"That dumb bitch is over the moon today,"],[1250,1433,"getting ready to be your bride."],[1462,1662,"Like she'll ever catch on to anything."],[1695,1854,"Now give it to me harder, baby."],[1887,1979,"So, it's true."],[2025,2104,"They've been fucking"],[2104,2179,"behind my back"],[2179,2291,"for three years."],[2375,2500,"I was given another chance,"],[2562,2766,"and this time I won't be manipulated."],[2800,2954,"I won't make the same mistakes."],[3204,3254,"I don't remember"],[3254,3400,"how my life became like this,"],[3454,3650,"but I've made peace with my reality."],[3866,3941,"Hey, you!"],[3991,4216,"Get off the property, you filthy freak."],[4241,4379,"I'm just looking for leftovers, man."],[4379,4491,"Please, I'll take anything."],[4525,4716,"This isn't a food bank, beggar."],[4729,4862,"Scram before I get back,"],[4887,5016,"or I'm calling pest control."],[5429,5616,"I haven't eaten in days."],[6391,6512,"The Lycan King is close."],[6541,6687,"You two, go that way."],[6716,6875,"But King Alexander lost his memory"],[6875,6966,"from the last battle."],[6966,7091,"Would he even recognize us?"],[7116,7216,"Look for his necklace."],[7241,7366,"It's the mark of the Lycan King."],[8200,8275,"Diana!"],[8479,8554,"Think this through."],[8554,8737,"You cannot call off the wedding!"],[8741,8837,"Better hope Jax"],[8837,8979,"forgives this little prank"],[8979,9104,"before it's too late."],[9300,9400,"I've never seen someone"],[9400,9479,"so beautiful."],[9550,9641,"She's like an angel."],[9887,9979,"Was I not clear?"],[10025,10125,"There is nothing you can do."],[10125,10250,"I am not marrying him,"],[10266,10362,"and that is final."],[10516,10604,"All right, Diana."],[10637,10816,"You've had your fun playing bridezilla,"],[10816,10966,"but you can give that up now."],[11004,11129,"We will be getting married"],[11137,11254,"whether you like it or not."],[11283,11466,"I really will not miss you belittling"],[11466,11616,"every single thing that I say,"],[11616,11737,"but if there was ever a time"],[11737,11800,"to hear me,"],[11825,11904,"let it be now."],[11966,12291,"I, Diana Bonehaven, reject you,"],[12337,12479,"Jax Fenric, as my mate!"]],"4":[[37,350,"I, Diana Bonehaven, reject you,"],[375,533,"Jax Fenric, as my mate!"],[1312,1375,"Get off me!"],[1487,1670,"How dare you reject me,"],[1670,1800,"you entitled bitch!"],[1870,1937,"Forgive me."],[1950,2108,"She's not in her right mind."],[2108,2225,"Stupid daughter."],[2270,2362,"You better take this back"],[2370,2570,"before your life is ruined for good!"],[2770,2887,"This is perfect."],[2900,3045,"Now Jax can be my mate."],[3062,3162,"I'll become Luna,"],[3175,3333,"and no one will even remember"],[3350,3475,"Diana exists."],[3500,3575,"Well,"],[3633,3770,"maybe one of our other"],[3770,3850,"lovely guests"],[3850,4045,"would like to marry Diana."],[4087,4462,"I know she's a bit of an older model,"],[4462,4658,"but she's still reliable."],[4704,4787,"Any takers?"],[5025,5283,"Taking Jax's Luna's leftovers?"],[5325,5470,"Absolutely not!"],[5508,5750,"I have self-respect."],[5750,5912,"Hey, I'm the one that rejected him."],[5950,6108,"I am getting softer"],[6108,6225,"just thinking about her."],[6225,6350,"And that flat chest?"],[6350,6445,"Please!"],[6470,6562,"I have a rule that says"],[6600,6733,"no getting with dumb bitches."],[6945,7212,"Diana, you have to marry today."],[7212,7408,"The Moon Goddess decreed it!"],[7408,7475,"That's right."],[7512,7600,"We're not leaving"],[7600,7737,"until you've found a mate."],[7737,7875,"You can't make me do anything."],[7887,8062,"And I will never marry"],[8062,8287,"this sad, pathetic excuse of a man."],[8300,8395,"You watch your mouth,"],[8395,8550,"you worthless little bitch."],[8600,8745,"Without me, you're nothing."],[8795,8920,"I make you important!"],[8962,9100,"Don't get ahead of yourself, Jax."],[9120,9225,"You're not even Alpha yet,"],[9225,9375,"and I doubt you ever will be."],[9387,9595,"You're nothing but the pack's lapdog."],[9766,9983,"You fucking bitch!"]],"5":[[187,354,"His face looks familiar."],[412,541,"Where have I seen him before?"],[616,829,"Diana of the Bonehaven Pack,"],[870,1041,"I've granted your wish, little one."],[1062,1175,"In your past life,"],[1175,1325,"your stepsister killed you"],[1325,1429,"and became the Luna."],[1487,1662,"This time, you must stop her"],[1662,1800,"from taking your Luna title"],[1800,1912,"to change your fate."],[1945,2112,"Choose correctly the partner"],[2112,2237,"you want by your side,"],[2266,2429,"for he will be the one to help you."],[2466,2591,"Prevent your death."],[2616,2841,"Do not let Ivy become the Luna."],[2879,3075,"Do not throw away this chance."],[3350,3579,"I promise, Moon Goddess,"],[3629,3700,"I'll choose a man"],[3700,3800,"who will fight by my side"],[3800,3912,"in order to survive."],[3954,4075,"I won't let Ivy win."],[4216,4279,"You okay?"],[4341,4429,"You saved me."],[4516,4575,"Why?"],[4629,4766,"No one deserves to be treated like that,"],[4766,4862,"rich or poor."],[4916,5004,"You deserve to be treated"],[5004,5087,"with kindness."],[5104,5212,"I couldn't just sit back"],[5212,5366,"and watch him abuse you like that."],[5404,5512,"If I wanna prevent my death"],[5512,5604,"in this life,"],[5629,5762,"I have to change my fate."],[5804,5954,"I can't let Ivy become the Luna."],[5991,6162,"I won't start this new life"],[6162,6300,"making the wrong choices."],[6337,6416,"I refuse."],[6604,6779,"Diana, are you even listening?"],[6804,7000,"You must marry somebody today."],[7000,7204,"Fine, but it won't be Jax."],[7254,7304,"Him."],[7454,7529,"I'll marry him."]],"6":[[8,70,"Him."],[191,270,"I'll marry him."],[350,445,"Are you sure you want me,"],[445,595,"even if it means a life of poverty?"],[629,729,"I don't care about that."],[770,916,"I just care if you're a good person."],[1016,1108,"Are you a good person?"],[1858,1945,"Will you marry me?"],[2133,2191,"Him?"],[2220,2308,"A homeless rogue"],[2308,2383,"is the man you're choosing"],[2383,2470,"to marry over me?"],[2500,2708,"I would marry anybody over you,"],[2708,2779,"Jax."],[2808,2941,"I was just lucky that..."],[3070,3120,"Alex."],[3120,3241,"Alex happened to be here."],[3258,3358,"Come on, sissy."],[3383,3483,"If you truly wanna bounce"],[3483,3633,"on some dirty dick,"],[3633,3720,"be my guest,"],[3720,3820,"but don't come crawling"],[3820,3904,"back when- - Hey, watch it."],[3904,4008,"Watch yourself."],[4033,4145,"You better take a step back"],[4145,4254,"before I- - Before what?"],[4670,4770,"No, no."],[5041,5091,"Ivy."],[5170,5241,"Let me go."],[5241,5333,"Oh, but this is gonna be"],[5333,5458,"so much fun."],[5483,5658,"Jax, don't."],[5720,5804,"Oh, Diana."],[5862,6041,"I need to teach this scum a lesson"],[6041,6204,"in stealing what's mine."],[7366,7508,"I'll take him as my mate!"]],"7":[[295,383,"I choose him."],[550,650,"I will mate with him."],[650,750,"That is my decision."],[783,987,"A homeless rogue?"],[1012,1183,"You can't throw away everything"],[1183,1308,"our family has achieved"],[1308,1500,"for some filthy bum!"],[1520,1633,"Maybe you should care less"],[1633,1758,"about other people's wealth"],[1770,1825,"and more about"],[1825,1962,"your own daughter's happiness."],[1975,2162,"Diana, you will not be happy"],[2162,2300,"living on the streets"],[2325,2500,"begging for food."],[2512,2587,"It's too late."],[2612,2737,"Her declaration is binding."],[2862,2987,"I don't accept that."],[3025,3162,"If you marry him,"],[3187,3375,"you are no longer our daughter"],[3437,3583,"or part of the pack."],[3625,3845,"Think this through carefully, Diana."],[3875,3983,"You'll be packless"],[3983,4150,"while I'm the next Luna."],[4200,4287,"You'll spend your life"],[4287,4412,"living underneath me."],[4462,4525,"Look at them."],[4575,4708,"Two pieces of trash."],[4750,4850,"They deserve each other."],[4870,5000,"Well, I felt safer with Alex"],[5000,5150,"than I ever have with you, Jax."],[5183,5312,"Ivy, he is not worth it."],[5312,5512,"Don't disgrace him."],[5537,5662,"He's the next Alpha."],[5683,5812,"That is my decision."],[5875,5962,"And it's final."]],"8":[[175,275,"Come on, Jax."],[308,437,"I'm much better for you."],[445,570,"Some kids just..."],[691,883,"...don't know how good they've got it."],[1020,1075,"Thank you,"],[1225,1387,"for agreeing to be my chosen mate."],[1458,1583,"I've never met anyone like her,"],[1637,1800,"so kind, but strong as steel"],[1800,1887,"against her family."],[1945,2012,"And her smile..."],[2287,2333,"Come on,"],[2333,2425,"we need to get you cleaned up"],[2425,2495,"for tomorrow."],[2587,2737,"What's, what's tomorrow?"],[2775,2920,"Tomorrow's when you take me home"],[2920,3000,"to meet your pack."],[3200,3287,"Oh my God."],[3779,3870,"I can't believe"],[3870,4012,"I really chose to marry"],[4012,4112,"this homeless rogue."],[4150,4245,"The Moon Goddess gave me"],[4245,4362,"the second chance at life"],[4362,4437,"for a reason."],[4475,4575,"I decide my fate."],[4604,4795,"I choose how my story goes."],[4858,5100,"And I choose the kind, noble man"],[5100,5258,"that defended and protected me"],[5295,5483,"before he even knew who I was."],[5520,5612,"That's the kind of man"],[5612,5733,"I want by my side."]],"9":[[266,450,"Oh my Goddess,"],[479,566,"is this really"],[566,666,"the same homeless man"],[666,787,"that rescued me earlier?"],[829,891,"Do I look okay?"],[937,1079,"You, you look good."],[1079,1150,"You look great."],[1200,1266,"Can you help me"],[1366,1454,"heal some of these wounds?"],[1454,1729,"It kind of stings doing it myself."],[1800,1941,"Yeah, yes."],[2129,2179,"Of course."],[2287,2441,"Way to be subtle, Diana."],[4075,4141,"Here first."],[5379,5537,"Diana, I..."]],"10":[[595,695,"I feel a lot better now."],[1095,1204,"How did he heal so quickly?"],[1279,1420,"I haven't been able to summon my wolf"],[1420,1520,"since I was reborn."],[1591,1841,"This spring, um, it's always had such"],[1929,2045,"magical healing properties."],[2216,2329,"Just thinking about tomorrow."],[2533,2595,"Will you tell me"],[2595,2766,"what is so special about tomorrow?"],[2845,2908,"Tomorrow's the day"],[2908,2995,"you take me to your pack"],[2995,3091,"as your chosen mate."],[3195,3279,"I don't have a pack."],[3391,3441,"Right."],[3741,3808,"I'm sorry."],[3933,4045,"That must be really hard."],[4120,4183,"You don't have anyone"],[4183,4258,"to support you."],[4458,4608,"I used to have a really tough time"],[4608,4670,"being alone."],[4733,4808,"You know, I always"],[4891,5079,"wanted to belong somewhere."],[5154,5270,"I wanted a pack of my own."]],"11":[[95,175,"Now I have you."],[625,675,"I know"],[820,900,"this isn't a ring,"],[916,945,"but..."],[962,1137,"I hope it's adequate enough for you."],[1212,1387,"It's really special to me, so"],[1575,1662,"please keep it safe."],[1775,1875,"I have no idea"],[1875,1983,"where this necklace came from"],[1995,2070,"or what it means,"],[2075,2195,"but she deserves"],[2195,2320,"a symbol of my loyalty."],[2425,2508,"It's beautiful."],[2600,2658,"Thank you."],[2737,2812,"I'll treasure it."],[2862,3112,"And I will treasure you"],[3150,3262,"and keep you safe."],[5100,5375,"I am Alexander, the Lycan King."],[5412,5575,"And Diana is my fated mate?"]],"12":[[195,262,"You know what?"],[291,400,"I am so lucky"],[487,608,"that you're just a simple man"],[608,675,"and I don't have to worry"],[675,762,"about your secrets."],[925,1037,"Unlike Jax,"],[1062,1300,"whose secrets literally killed me."],[1350,1458,"Doesn't she feel it too?"],[1512,1575,"Our bond?"],[2162,2208,"Um,"],[2295,2362,"I totally forgot."],[2362,2425,"I need to"],[2470,2708,"go sort, sort some things out at home."],[2712,2787,"Why don't you meet me here"],[2787,2950,"tomorrow at noon, okay?"],[2987,3058,"I'll see you then."],[3275,3450,"So finding my fated mate"],[3450,3595,"gave me my memory back."],[3658,3745,"I have to tell her."],[3812,3962,"Lycan King Alexander,"],[3987,4158,"you've remembered your true identity."],[4162,4245,"Oh, Moon Goddess,"],[4245,4358,"I can, I can hear you again."],[4412,4612,"You cannot tell Diana who you are."],[4645,4675,"What?"],[4675,4750,"Why, why not?"],[4791,4933,"Unveiling your identity"],[4933,5095,"will put Diana in harm's way."],[5125,5250,"After your disappearance,"],[5250,5345,"opposing packs"],[5345,5537,"had sworn to kill your mate to ensure"],[5537,5708,"that you'd never return to the throne."],[5745,5812,"You may tell her"],[5812,5925,"when the time is right."],[5962,6062,"I will tell you when."],[6083,6137,"I understand,"],[6137,6395,"but why can't she feel our mate bond?"],[6425,6600,"Focus on the tasks at hand."],[6683,6775,"I'll return soon."],[7487,7625,"My King, we finally found you."],[7858,8000,"Rest easy, Beta Julian."],[8058,8170,"Your Alpha has returned."],[8200,8283,"Now we can go home."],[8345,8587,"Actually, I still have some business."],[8712,8825,"I found my fated mate."],[8850,8937,"But the pack house"],[8937,9062,"is in disarray without you."],[9100,9175,"You have to go back"],[9175,9262,"before it gets worse,"],[9262,9387,"even for just a moment."],[9445,9487,"Fine,"],[9550,9650,"but you watch over her,"],[9662,9725,"Beta Julian."],[9775,9937,"Bring her gifts in my absence."],[9975,10100,"I'll be back, Diana."],[10158,10220,"Wait for me."],[10512,10637,"He should be here by now."],[10695,10883,"Aw, did your new mate"],[10883,11058,"forget about you already?"]],"13":[[41,229,"Or did you tell him not to show up"],[229,412,"because he's a homeless rogue?"],[475,629,"I wouldn't blame you if you did."],[679,729,"I mean,"],[762,816,"it must've been"],[816,916,"embarrassing enough"],[929,1066,"to announce your relationship."],[1112,1179,"He'll be here soon."],[1629,1700,"Jax!"],[1700,1779,"Hey, sweetheart."],[1854,1950,"I got this for ya."],[2091,2254,"Oh,"],[2254,2491,"my man brought me a car"],[2491,2754,"and a diamond necklace."],[2791,3000,"Looks like Diana's moronic decision"],[3000,3116,"is paying off for me."],[3141,3337,"At this rate, she'll be on the streets"],[3337,3529,"with her trash mate in no time."],[3562,3650,"Poor Diana."],[3712,3787,"Not even the homeless"],[3787,3875,"nobody rogue"],[3875,4004,"bothered to show up for you."],[4037,4225,"Jax, you should've at least"],[4225,4312,"got her a new necklace"],[4312,4441,"instead of stealing your mom's."],[4487,4591,"How did you know that?"],[4604,4829,"I mean, I didn't steal this."],[4866,4925,"Don't worry."],[4925,5091,"His mother was so upset"],[5100,5166,"when he gave it to me"],[5166,5254,"in my past life."],[5279,5404,"I can't believe her."],[5429,5562,"That snake's spreading lies"],[5562,5704,"just because she's jealous."],[5754,5879,"Ah, well."],[5879,6241,"Oh, my darling mother and father,"],[6250,6491,"I'm so happy to see you both."],[6500,6716,"Look what Jax brought me."],[6716,7000,"Wow, very impressive, Jax."],[7041,7175,"At least one of our daughters"],[7175,7400,"had the good sense to marry well."],[7441,7604,"Diana's mate didn't even bother"],[7604,7725,"to show his face."],[7754,7975,"I wonder if he owns a mirror."],[8137,8241,"What could he give her anyways?"],[8266,8379,"A half-eaten sandwich?"],[8516,8629,"I already told all of you,"],[8691,8829,"material things don't matter to me"],[8829,8991,"as long as my mate is a decent person."],[9041,9104,"These are gifts"],[9104,9291,"from the Lycan King for Diana."],[9854,9941,"The Lycan King?"]],"14":[[20,83,"Did you say"],[83,320,"the Lycan King for Diana?"],[370,433,"Yes."],[458,691,"Oh, please, that's impossible."],[720,966,"The Lycan King died in battle"],[1004,1170,"and Diana doesn't have"],[1170,1283,"any other connections"],[1295,1458,"beyond that dirty rogue."],[1495,1670,"These must be from Jax."],[1970,2145,"But I was explicitly told"],[2145,2270,"that these were from-"],[2283,2483,"Of course these are from me,"],[2533,2720,"as a token of my appreciation"],[2720,2858,"for bonding with Ivy."],[2920,2991,"You may go."],[3170,3429,"Babe, you really shouldn't have."],[3429,3595,"You brought gifts for me?"],[3620,3770,"Diana probably already feels bad"],[3770,3833,"because she doesn't"],[3833,3929,"have anything."],[3966,4083,"It's not fair to her."],[4133,4366,"Gifts are about quality, not quantity."],[4416,4633,"Diana, you better fix your attitude"],[4633,4933,"while Ivy's mate is being so generous."],[4933,5045,"Haven't you disgraced"],[5045,5145,"this family enough?"],[5158,5245,"You should all be ashamed"],[5245,5354,"of yourselves."],[5433,5504,"I have never seen"],[5504,5633,"such shallow people in my-"]],"15":[[79,370,"I'm sorry, Diana, but father's right."],[420,508,"There's no place"],[508,620,"in the Bonehaven Pack"],[633,745,"for a homeless rogue."],[762,841,"But, Father,"],[866,983,"you should give him another chance."],[983,1058,"Enough! - He's-"],[1133,1266,"He is nothing."],[1320,1504,"And now, neither are you."],[1579,1795,"Well, what if we compromise?"],[1983,2145,"Diana did choose a lowlife,"],[2154,2295,"but maybe he could"],[2333,2491,"join the Bonehaven Pack"],[2495,2741,"if he passes the initiation ritual."],[2770,2904,"No, he's not gonna be put through that."],[2933,3041,"We'll parade him"],[3045,3233,"to the town square for all to see,"],[3258,3470,"and I'll whip him fifteen times"],[3470,3608,"in accordance with the law."],[3625,3745,"I won't let you hurt him."],[3775,4029,"And if he proves his strength,"],[4045,4220,"he can live in the Bonehaven Pack"],[4258,4329,"in peace."],[4358,4420,"And if not,"],[4420,4620,"it's bye-bye to the homeless rogue,"],[4620,4883,"and bye-bye to you, Diana."],[5208,5358,"I used to have a really tough time"],[5358,5420,"being alone."],[5479,5658,"You know, I always wanted to belong."],[5716,5845,"I wanted a pack of my own."],[5966,6133,"Alex promised to keep me safe."],[6191,6308,"I have to take care of him, too."],[6395,6441,"Fine,"],[6495,6595,"we'll do the ritual,"],[6645,6704,"but I won't let you"],[6704,6841,"lay a finger on Alex."],[6858,6958,"I'll take his place."],[7004,7108,"Whip me instead."]],"16":[[70,270,"My King, we have to go now."],[295,366,"The Luna's family"],[366,495,"is about to whip her from the pack."],[504,554,"Hurry!"],[570,695,"If anyone touches her,"],[733,858,"I will rip them apart."],[879,1033,"They'll fucking beg for mercy"],[1033,1183,"if she has so much as a paper cut."],[1216,1283,"Guards,"],[1316,1408,"strip her down!"],[1429,1466,"No!"],[1466,1720,"Strip, strip!"],[1858,1958,"I'll do it myself."],[2383,2541,"Please, Moon Goddess,"],[2570,2683,"help me endure this pain"],[2729,2929,"for my fate, for Alex."],[4504,4629,"I've been waiting to do this"],[4629,4745,"since we were kids."],[5104,5195,"This is for Alex,"],[5220,5370,"for a chance at a future together."],[5550,5616,"I'm ready."]],"17":[[466,554,"Diana's hurt."],[579,691,"We have to move faster."],[1425,1525,"I'm coming, Diana."],[1662,1766,"Hold on a little longer!"],[2404,2550,"I promise, Diana."],[2579,2670,"I'm coming for you."],[2704,2866,"I won't stop until I find you."],[3550,3675,"This pain is nothing"],[3675,3766,"compared to the years"],[3766,3891,"I suffered with Jax."],[3916,4075,"Alex will never hurt me like he did."]],"18":[[133,233,"Poor Diana."],[295,520,"She chose kindness over status."],[583,733,"But would a kind mate"],[741,920,"really let you go through this?"],[995,1208,"Would he do the same thing for you?"],[1295,1441,"I did the fifteen lashes."],[1466,1670,"Ivy, just please let me go."],[1795,1895,"I wish I could, but"],[1983,2066,"we're not done yet."],[2633,2758,"In accordance with law,"],[2804,3020,"any rogue entering the pack"],[3020,3179,"must be branded."],[3245,3370,"Since your mate isn't here,"],[3416,3533,"you'll have to bear the mark."],[3895,3933,"Rhea,"],[3933,4033,"if there's even a sliver of you"],[4033,4070,"still there,"],[4070,4183,"I need you more than ever."],[4195,4308,"Please come back to me."],[4541,4645,"My wolf is gone."],[4708,4808,"Maybe for good."],[4895,4979,"I'm alone."]],"19":[[20,304,"This brand reminds you of the truth."],[358,608,"Once a rogue, always a rogue."],[1091,1208,"I know you're gonna spend"],[1208,1291,"your entire life"],[1291,1379,"catering to the whims"],[1379,1470,"of that asshole."],[1541,1583,"This,"],[1666,1795,"this won't make it better."],[1845,1983,"You're such a bitch."],[2095,2158,"You always thought"],[2158,2341,"you were so much smarter than me,"],[2379,2504,"but you're going to suffer"],[2504,2683,"while I'm the next Luna."],[2845,3033,"I hope you think back to this moment"],[3033,3191,"and wish you'd begged for mercy"],[3204,3370,"instead of this pitiful attempt"],[3379,3470,"at a rebellion."],[5420,5483,"Alex?"],[5529,5695,"I'm here, Diana."],[5695,5820,"I'm so sorry I'm late."],[5933,6091,"Is that the dirty homeless man?"],[6129,6245,"He shouldn't have power."],[6270,6391,"How did he glow gold?"],[6395,6483,"The only other person"],[6483,6616,"who could glow gold like that"],[6616,6716,"was the Lycan King."],[6779,6966,"Who is the coward responsible for this?"],[7558,7670,"I said who hurt my mate?"],[7670,7733,"Alex."]],"20":[[0,62,"Alex."],[150,208,"Alex."],[300,358,"I did it"],[512,575,"for us,"],[637,783,"so you could be part of the pack."],[1050,1162,"You sacrificed yourself"],[1162,1237,"in my place?"],[1408,1520,"How did you do this?"],[1545,1612,"You're a rogue."],[1662,1795,"It's impossible to have"],[1795,2025,"that kind of strength in your eyes."],[2045,2162,"You glowed gold."],[2220,2362,"Who do you think you are,"],[2387,2500,"using cheap tricks"],[2500,2625,"to pretend to be powerful!"],[2633,2725,"How dare you come here"],[2725,2875,"and make a mockery of us."],[3562,3662,"Only the Lycan King"],[3662,3770,"has that kind of power."],[3787,3912,"How can that trashy beast"],[3925,4037,"emanate that kind of power?"],[4050,4195,"The Lycan King is dead."],[4208,4350,"He's been missing for years."],[4375,4462,"Oh, please."],[4483,4650,"Diana with the Lycan King?"],[4675,4837,"I'll believe it when I'm dead."],[4875,5025,"This man is nothing"],[5025,5220,"more than my idiot sister's"],[5237,5325,"dead beat mate. - Ivy."],[5720,5787,"Oh my God."],[5958,6062,"I will burn down"],[6075,6187,"every inch of this place"],[6212,6337,"and rip off the skin"],[6350,6450,"of whoever hurt her."],[6550,6645,"So let me ask again"],[6645,6775,"and this better be the last time."],[6845,6933,"Who hurt her?"],[6950,6995,"She did it."],[6995,7062,"It was Ivy."]],"21":[[29,233,"You are gonna suffer!"],[270,408,"Diana wanted this."],[475,629,"I was just trying to help my sister"],[629,779,"so you could enter the pack."],[779,954,"This is no ritual, this is abuse!"],[979,1145,"And I will not stand for it."],[1166,1329,"You will not stand for it?"],[1341,1520,"I'm sorry, you are no one."],[1541,1641,"And you better speak to me"],[1641,1741,"with some respect"],[1741,1916,"because once Jax is crowned Alpha"],[1916,2045,"and I'm the ultimate Luna,"],[2054,2270,"I can have you and my foolish sister"],[2283,2470,"executed in an instant."],[2508,2633,"What kind of audacity"],[2633,2695,"do you have"],[2704,2916,"as a homeless rogue to come here"],[2916,3029,"and start making demands?"],[3045,3241,"I would really watch what you say next."],[3262,3391,"You don't know who you're talking to."],[3454,3508,"Funny,"],[3533,3695,"because last time I distinctly remember"],[3695,3833,"standing over your limp body"],[3833,4008,"after beating you to a pulp."],[4708,4783,"After this,"],[4845,5020,"we'll see who's beaten to a pulp."],[5183,5383,"Guards, grab them!"]],"22":[[75,229,"Hey, hey, hey, hey."],[241,316,"Who is this"],[316,404,"homeless piece of shit"],[404,562,"and how does he have an entourage?"],[587,650,"It's probably just"],[650,804,"a bunch of other homeless rogues"],[804,887,"playing dress up."],[887,954,"There's no way"],[954,1112,"this man is the Lycan King."],[1129,1279,"She needs to heal, fast."],[1316,1466,"You let this be a lesson to you."],[1500,1679,"If someone so much as touches"],[1679,1800,"a stray hair on her head,"],[1804,1929,"you'll really see how far I'll go"],[1929,2012,"to protect my mate."],[2054,2112,"Trust me,"],[2154,2304,"I don't care what the laws say."],[2316,2391,"Beta Julian,"],[2454,2600,"remind the pack of their place."],[2633,2691,"Yes, sir."],[3404,3466,"No!"],[3500,3554,"No!"],[3591,3641,"No!"],[3687,3754,"Oh no! - No!"],[3812,3854,"Oh no!"],[3854,3916,"Oh my God!"],[4425,4562,"God, no!"],[4579,4716,"Who are you people?"],[4729,4875,"How can you do this?"],[5333,5408,"I wont never let anyone"],[5408,5466,"hurt you again,"],[5466,5541,"I promise."],[5616,5662,"Come on."],[5879,6062,"No one comes into my territory"],[6062,6179,"and disrespects me."],[6212,6350,"I don't care who you are."],[6387,6541,"You and your little slut"],[6554,6654,"will pay for this."]],"23":[[395,483,"Where am I?"],[1929,2004,"I'm healed?"],[2158,2270,"But how is that possible"],[2270,2358,"if Rhea's gone?"],[3341,3483,"My shirt suits you better than me."],[4616,4766,"My back is healed completely."],[4970,5058,"How did that happen?"],[5125,5395,"Oh, shit, only alphas can heal others."],[5445,5554,"What do you mean, your wolf"],[5566,5633,"didn't heal you?"],[6658,6716,"Right."],[7070,7258,"Um, I don't, I don't mean to be rude,"],[7258,7408,"but I thought you were homeless."],[7408,7533,"Why are we in such a nice place?"]],"24":[[145,208,"I got a buddy"],[258,395,"and he, uh, owed me a favor."],[429,533,"I thought it was a good time"],[533,641,"to cash in on that"],[641,945,"since I wanna care for you."],[1120,1270,"Hey, speaking of caring of,"],[1270,1495,"can we talk about earlier?"],[1591,1741,"I told you that I'd protect you,"],[1841,2004,"but the moment I left,"],[2233,2341,"you put yourself in danger."],[2479,2566,"I did it for you..."],[2845,2979,"so you could be part of the pack."],[3183,3270,"I know you wanted to"],[3304,3395,"belong to something."],[3558,3795,"Thank you for sacrificing yourself"],[3795,3858,"for me, really."],[3916,3966,"But you don't need"],[3966,4058,"your old pack anymore."],[4233,4295,"You have me."],[5441,5670,"You did all this for me?"],[6366,6458,"Now let me show you"],[6666,6783,"just how much of myself"],[6783,6933,"that I wanna give back to you."]],"25":[[2370,2570,"Diana, you are so"],[2679,2754,"beautiful."],[2833,3020,"I need an altar to worship your body."],[3100,3283,"No one's ever treated me like this."],[3362,3420,"All he wants"],[3420,3583,"is to make me feel good."],[3658,3745,"Desired."],[3783,3879,"Now let's make sure"],[4004,4104,"that you are properly"],[4145,4291,"compensated for your efforts."],[4791,4945,"Maybe she can't feel our mate bond,"],[4945,5133,"but I will make her feel my devotion."],[5241,5495,"I've never wanted anyone so bad."],[6695,6808,"Now I'm gonna take you"],[6920,7008,"into my bedroom."],[7120,7208,"You're gonna show me"],[7216,7345,"exactly how to repay you."]],"26":[[587,654,"Alex."],[754,829,"Yeah, what is it?"],[1000,1116,"Have I ever told you"],[1187,1279,"how grateful I am"],[1279,1454,"that you accepted my mate bond?"],[1912,1962,"Well,"],[2050,2154,"have I ever told you"],[2241,2362,"how in awe I am of you?"],[2429,2566,"I have never met anyone"],[2641,2737,"with the strength"],[2737,2891,"to stand up to their entire family"],[2891,2975,"like you have."],[3162,3291,"All I wanna do is protect you"],[3491,3641,"against anyone and anything"],[3641,3750,"that comes in our way."],[3929,4050,"At the very least, I just,"],[4266,4379,"I pray that you'll still have me"],[4379,4454,"at your side."],[6037,6091,"You know,"],[6150,6266,"we haven't celebrated"],[6266,6379,"our mate bond yet,"],[6400,6616,"and I have some ideas."],[6741,6862,"Not now."],[6887,7016,"Today was a fucking mess."],[7512,7604,"That slut Diana"],[7604,7804,"and her vermin of a mate cannot win."],[7837,8004,"I'm going to finish what I started,"],[8016,8229,"even if that means killing the bitch."]],"27":[[591,679,"Oh, you have a letter."],[1366,1445,"The Alpha Ball,"],[1495,1579,"one of the worst nights"],[1579,1670,"of my past life."],[1683,1733,"It was the night"],[1733,1858,"that Ivy dropped the act."],[1870,2008,"She began her war against me."],[2341,2395,"How could you forget"],[2395,2545,"what red means at the Alpha Ball?"],[2554,2658,"You're telling everyone you're"],[2695,2808,"open for business."],[2820,2866,"No."],[2908,3091,"No, Ivy, you told me to wear this."],[3120,3245,"Trying to flag someone down"],[3245,3416,"for a quick fuck, huh, Diana?"],[3466,3566,"How can you be a Luna"],[3566,3754,"if you've run through half the pack?"],[3954,4095,"You're humiliating me."],[4379,4516,"Don't worry, Diana."],[4570,4720,"I'll help you cover it up."],[5870,6020,"That's what happens to sluts"],[6054,6204,"who like to have their cake"],[6220,6320,"and eat it too."]],"28":[[91,262,"It's an invitation to the Alpha Ball."],[354,466,"That's a big deal, isn't it?"],[525,725,"It's a really important event,"],[725,866,"second only to the Alpha"],[866,954,"and Luna Ceremony."],[1004,1179,"If I want to change my fate,"],[1216,1341,"I can't let Ivy win this time."],[1466,1516,"Hey,"],[1637,1729,"you want me to go with you?"],[2454,2525,"Then I'm there,"],[2612,2762,"and it's gonna be the best night ever."],[3179,3212,"Hey,"],[3212,3362,"bring me your most expensive gowns."],[3387,3512,"Money's not a problem, all right?"],[3512,3654,"Just as long as no one is able"],[3654,3750,"to look away from her."],[4679,4766,"What's all of this?"],[4854,5037,"I'm here to style you for the Alpha Ball"],[5054,5179,"as a favor to Alex."],[5237,5366,"How could Alex afford this?"],[6116,6300,"Hey, sissy, can I come in?"]],"29":[[112,162,"I,"],[229,354,"I wanted to check in on you."],[379,579,"I know the other day was crazy,"],[587,804,"and I never wanted to hurt you,"],[812,975,"but laws are laws."],[1041,1179,"You can understand that, right?"],[1354,1412,"Yeah."],[1591,1654,"Of course."],[1791,1891,"I would never blame you."],[2154,2454,"You know, it's really strange."],[2500,2691,"Your mate shouldn't have been able"],[2691,2850,"to fight off my guards like that."],[2850,2887,"I mean,"],[2887,3100,"he's just a weak, measly rogue."],[3166,3291,"It doesn't make any sense."],[3529,3704,"Yeah, Alex, he may be a rogue,"],[3704,3816,"but he really seemed to fight off"],[3816,3929,"your soldiers with ease."],[3950,3991,"He was just"],[3991,4054,"throwing them around"],[4054,4137,"like they were nothing."],[4279,4341,"It's kind of,"],[4441,4591,"I mean, it was kind of pathetic."],[4966,5166,"Well, I guess we'll never know."],[5275,5341,"Thank Goddess,"],[5341,5441,"we've cleared the air."],[5512,5579,"Just curious,"],[5579,5804,"are you going to the Alpha Ball?"],[5854,5904,"I don't care"],[5904,6050,"if she brings her loser mate,"],[6050,6179,"but my plan will only work"],[6179,6287,"if she shows."],[6337,6387,"Yes."],[6487,6554,"With Alex."],[6841,6937,"What's going on in there?"],[7379,7516,"Oh my goodness!"],[7704,7929,"This dress would look perfect on me."],[8016,8091,"This time she's the one"],[8091,8216,"who doesn't know what red means."],[8291,8466,"You should wear this one, Diana."],[8504,8654,"It'll look perfect on you."],[8679,8750,"Really?"],[8941,9012,"Thank you."],[9066,9141,"You're welcome."],[9316,9437,"Ivy made me wear this dress"],[9437,9529,"to prove to everyone"],[9529,9650,"I'm not Luna material."],[9741,9850,"I won't let that happen again."],[9916,10041,"Well, if you like the dress,"],[10041,10116,"you should take it."]],"30":[[41,104,"I don't want any"],[200,304,"bad blood between us."],[304,429,"I mean, we're sisters after all."],[479,625,"You should take it as a peace offering."],[891,1104,"Diana's even more naive than I thought."],[1150,1279,"Taking her down is going to be"],[1279,1400,"a piece of cake."],[1441,1537,"Thanks, sissy."],[1566,1754,"I'm so relieved we're friends again."],[1904,1975,"Me too."],[2091,2229,"Ivy thinks she can dupe me,"],[2266,2529,"but she has no idea what I'm capable of."],[2575,2654,"Only one of us knows"],[2654,2775,"what the future holds,"],[2804,2904,"and it's not her."]],"31":[[737,862,"Everyone finally sees"],[862,941,"that me and Jax"],[954,1112,"make the perfect Alpha and Luna."],[1175,1325,"Nothing can ruin tonight."],[2766,2987,"That upstaging bitch!"],[3216,3262,"Fine."],[3337,3429,"If she's that desperate"],[3429,3504,"for the spotlight,"],[3516,3704,"I'll give her exactly what she wants."]],"32":[[500,650,"Love the dress, girl."],[704,791,"You look amazing."],[929,1050,"Who knew rogues could turn into"],[1050,1154,"such a delectable piece"],[1154,1229,"of arm candy?"],[1241,1316,"Lucky you."],[1350,1429,"I'm the lucky one,"],[1475,1537,"actually."],[1566,1737,"Diana saw past my looks"],[1737,1912,"and chose me to be her mate."],[2225,2291,"You've always known"],[2291,2404,"how to beg for attention."],[2479,2691,"That dress is so you."],[2912,2979,"Thanks, Ivy."],[3125,3241,"I had some help shopping."],[3662,3725,"Oh, no."],[3766,3829,"Ivy."],[3854,4029,"Don't you know you can't wear red"],[4029,4154,"to the Alpha Ball?"],[4475,4637,"She's saying she's trying to get fucked"],[4637,4754,"at the Alpha Ball."],[4879,5016,"You're humiliating me."],[5054,5125,"Jax, wait."],[5150,5325,"Guess you'd rather spread your legs"],[5325,5416,"than become a Luna."],[5454,5516,"Don't worry."],[5616,5704,"We'll help you get ready."],[5725,5791,"No, no, no, wait!"]],"33":[[54,291,"No!"],[1054,1191,"Are you fucking kidding me?"],[1229,1366,"That evil bitch tricked me."],[1425,1579,"Well, she might've fired the first shot,"],[1579,1716,"but I'm winning this war."],[1991,2104,"You should've dressed like this"],[2104,2179,"when we were together."],[2229,2329,"I might've kept you around."],[2816,2954,"Jax, don't forget"],[2962,3087,"that I'm the one who rejected you,"],[3125,3241,"plus I already have a date."],[3275,3325,"Him?"],[3350,3466,"Oh, come on, Diana."],[3512,3641,"Can't really be into this bum."],[3679,3800,"He's a packless loser."],[3837,3929,"Your Highness."],[4329,4558,"Oh, shit, Diana's gonna find out."]],"34":[[20,91,"Alexander."],[179,370,"Such an honor to meet you again."],[404,641,"Such an honor to see you again?"],[670,770,"He's a nobody."],[783,858,"No offense."],[904,966,"Excuse me."],[983,1091,"If I want pastries"],[1091,1208,"for my next food fight,"],[1220,1379,"I'll ask for your recommendations."],[1408,1516,"Know your place."],[1570,1704,"I'm sorry, Mr. Alexander."],[1733,1808,"I'm Charles,"],[1820,1945,"Summerwind Alpha."],[1983,2070,"We met a few years ago."],[2070,2220,"Yes, nice to meet you, Charles."],[2254,2358,"I think you got me confused"],[2358,2429,"with someone else."],[2483,2633,"I'm Alex, just Alex."],[2666,2820,"Why is this powerful Alpha"],[2820,2970,"acting like he knows Alex?"],[3083,3170,"Diana!"],[3241,3433,"That dress is a stunner."],[3470,3533,"Thank you."],[3545,3695,"I have to know everything about it."],[3733,3833,"Come to the bathroom with me?"],[4304,4354,"So,"],[4508,4633,"are you really undercover?"],[4708,4866,"Direct orders from the Moon Goddess,"],[4866,5033,"so I'd appreciate some discretion."],[5079,5158,"Absolutely, sir."],[5408,5495,"I just wanna say,"],[5520,5645,"I really admire you"],[5645,5779,"for choosing a poor mate."],[5783,5995,"Fuck anyone who tries to shame you."],[6358,6433,"Excuse me."],[6470,6570,"You can't be in here."],[6608,6816,"Surprise!"]],"35":[[625,775,"She's all yours."],[1037,1162,"You don't have to do this."],[1212,1370,"Okay, we'll talk about it."],[1400,1462,"Call me."],[2020,2070,"Ivy."],[2095,2262,"Listen here, you little freak."],[2287,2433,"I'm done messing around,"],[2433,2558,"so listen closely."],[2737,2850,"Everything you treasure,"],[2875,3000,"everyone in your life,"],[3008,3212,"every last strip of happiness"],[3212,3287,"in your life..."],[3375,3454,"it's mine now."],[3454,3508,"Ivy."],[3520,3562,"Ivy."],[3604,3737,"Even if you do become Luna,"],[3737,3820,"you're still gonna have to"],[3820,3937,"answer to Jax."],[4187,4245,"Boys,"],[4325,4462,"do with her what you want."],[4483,4587,"I know you're looking for"],[4600,4737,"new body parts"],[4737,4950,"for your little black market scheme."],[5033,5162,"Nowhere to run now."],[5225,5375,"She deserves to be violated"],[5375,5450,"in every way"],[5450,5645,"by these disgusting freaks."],[5825,5962,"I'm finally on top again."],[6233,6400,"Rhea, I need to shift."],[6412,6595,"Come back, please!"]],"36":[[45,104,"Don't!"],[391,475,"You're a pretty girl."],[529,579,"Hey,"],[687,741,"listen."],[775,1079,"It is, is a real shame"],[1125,1341,"that we have to chop you up tonight."],[1491,1562,"What are you doing?"],[1566,1654,"You're gonna chop me?"],[1654,1704,"Yeah,"],[1775,1866,"nice and fine."],[1929,2029,"Then we're gonna gouge out"],[2029,2125,"your eyeballs."],[2129,2266,"Boss' orders, babe."],[2329,2550,"But first, we gotta do this."],[2587,2612,"Come."],[2612,2650,"No."],[2804,2916,"Deep breath now."],[2945,3012,"And..."],[3491,3604,"Any last words?"],[3637,3712,"Fuck you!"],[3741,3841,"Oh, man."],[3904,4025,"I tried to change my fate,"],[4025,4212,"but I only led myself to danger faster."],[4229,4291,"Or maybe this night"],[4291,4450,"was always meant to end in tragedy."],[4479,4675,"But at least this life led me to Alex."],[4691,4779,"He gave me a warmth"],[4791,4925,"I hadn't felt in years."],[4995,5191,"I like a full-bodied red-"],[5191,5275,"Alex!"],[5354,5412,"Diana?"]],"37":[[33,154,"Now sit tight, darling."],[158,291,"We're gonna make this"],[320,520,"short and sweet."],[583,691,"We're just gonna carve out"],[691,795,"some of your organs"],[808,929,"for our side business."],[941,1058,"You understand, right?"],[1104,1508,"How about we start with her eyes?"],[1520,1704,"Let's see if her man still wants her"],[1704,1795,"when they're gone."],[1966,2108,"No see, here it comes."],[2504,2720,"Keep your fucking hands off of her!"],[2833,2916,"How is he so strong?"],[2916,3070,"He's a fucking rogue!"],[3220,3295,"Oh, Diana,"],[3333,3445,"please tell me you're not hurt."],[3504,3608,"You're gonna regret that,"],[3608,3729,"you homeless fuck!"],[3758,3908,"I'm gonna make you my bitch."],[4183,4245,"His eyes."],[4337,4366,"Is he?"],[4366,4445,"He can't be."],[4458,4608,"I thought the Lycan King was dead."],[4645,4691,"How?"],[4758,4883,"I'm gonna kill both of you"],[4908,5083,"one by one, and quickly,"],[5133,5258,"but not because you deserve it,"],[5295,5429,"because my fated mate"],[5458,5558,"should not have to endure"],[5558,5645,"another second"],[5670,5833,"to you two pieces of shit!"],[5854,5983,"Please, show, show mercy!"],[8016,8116,"What did they just call him?"],[8250,8333,"The Lycan King?"],[8341,8470,"Hey, hey, hey, hey."],[8495,8566,"Oh, baby."],[8608,8654,"Hey."],[8695,8741,"Hey."],[8787,8845,"Hey."]],"38":[[362,408,"Hey."],[662,733,"How are you doing?"],[825,912,"He must have been sitting here"],[912,1025,"with me for hours."],[1254,1412,"You fought off two men."],[1612,1712,"You fought off two"],[1791,1904,"really strong men."],[2062,2150,"How did you do that?"],[2175,2325,"Well, when you're a rogue like me,"],[2350,2383,"you learn"],[2383,2420,"how to fight - But"],[2420,2512,"for yourself, so."],[2520,2662,"you could have gotten really hurt."],[2662,2733,"You don't understand."],[2925,2962,"Me?"],[3087,3187,"You're worried about me?"],[3345,3462,"If you are afraid"],[3525,3600,"when you're with me,"],[3675,3837,"that means I'm doing my job wrong."],[4083,4220,"She still can't feel our mate bond."],[4220,4275,"Fuck."],[4350,4437,"I want her so bad"],[4437,4545,"and she doesn't even know."],[4637,4695,"Diana,"],[4775,4833,"you know"],[4933,5125,"that we are each other's fated mates."],[5225,5320,"How come sometimes I,"],[5470,5533,"I feel like you act"],[5533,5637,"like we're just roommates?"],[6108,6212,"Do all roommates"],[6383,6475,"sit like this?"],[6650,6775,"Only the ones bold enough"],[6795,6920,"to act on their desires."],[7020,7145,"But you can have me like this"],[7145,7262,"any time you want."],[7383,7437,"Prove it."]],"39":[[1016,1150,"I need her so bad."],[1291,1362,"Thorne is in heat"],[1362,1491,"and it's driving me insane."],[1625,1741,"No one's ever pleased me"],[1754,1804,"like him."],[1841,1925,"I've been going crazy"],[1925,1991,"without more."],[2433,2604,"Your mate... I can feel him."],[2666,2737,"He's out there."],[2762,2812,"What's wrong?"],[2854,2979,"I just heard, I heard Rhea."],[3050,3141,"I heard my wolf."],[3266,3391,"Rhea, what do you mean"],[3391,3500,"you can feel my mate?"],[3525,3679,"Talk to me, please."],[3687,3754,"I need you."],[3966,4075,"I'm so confused."],[4162,4229,"I, I,"],[4304,4400,"I wanna be with you,"],[4404,4566,"but I just heard my wolf"],[4566,4729,"and she was calling for my fated mate."],[4804,4891,"Another mate?"],[4937,5050,"Maybe he could lead to Rhea."],[5062,5191,"Then I could become the Luna"],[5216,5354,"and prevent Ivy from killing me."],[5404,5500,"My fate will be changed"],[5500,5566,"once and for all."],[5691,5754,"I have to go."],[5800,5841,"I'm sorry,"],[5850,6066,"I need to know what she meant."],[6454,6554,"This doesn't make sense."],[6579,6729,"Diana is my fated mate,"],[6729,6941,"but could hers be someone else?"]],"40":[[483,575,"How could the Moon Goddess"],[575,650,"give me another mate"],[650,775,"when this man exists?"],[887,987,"He's perfect."],[1125,1258,"Thank you for cooking for me."],[1325,1475,"I really appreciate everything you do."],[1562,1625,"And you tell me"],[1625,1712,"whenever you're hungry,"],[1758,1887,"and I'll make whatever you want."],[2000,2087,"My staff doesn't let me"],[2087,2195,"take care of any chores,"],[2195,2420,"but I would clean toilets every day"],[2420,2475,"if it means that"],[2475,2583,"she'll look at me like that."],[2825,3062,"So, you wanna talk about last night?"],[3233,3312,"Last night, I mean,"],[3312,3387,"there was so much to,"],[3487,3625,"Uh, uh, so much happened last night."],[3625,3675,"It's hard to-"],[3912,3970,"Shit!"],[3975,4050,"Wait, don't move."],[4058,4120,"I got it."],[4350,4391,"Ow."]],"41":[[241,291,"The last time"],[291,437,"he put me on this counter..."],[1062,1150,"Hey, hold still."],[2004,2075,"Is he..."],[2212,2287,"healing me?"],[2741,2829,"As good as new."],[3166,3229,"Alex?"],[3279,3341,"Diana."],[3466,3541,"How did you do this?"],[3604,3754,"Shit, what should I tell her?"]],"42":[[100,170,"I was taught,"],[333,400,"by an Alpha."],[600,758,"Why couldn't you heal yourself?"],[837,962,"You were next up to be Luna."],[1087,1137,"And last night"],[1137,1229,"you seemed pretty distant"],[1229,1312,"from your wolf."],[1425,1541,"I know she can't even feel"],[1541,1604,"the mate bond,"],[1604,1700,"but what if she doesn't even"],[1700,1775,"have a wolf?"],[1904,2004,"Well, I'm not the only one"],[2004,2091,"with secrets."],[2179,2250,"Well, I'm not the one"],[2250,2316,"who's making out"],[2316,2412,"with someone one day,"],[2441,2491,"and then saying"],[2491,2604,"they have a mate bond the next."],[2604,2666,"Alex!"],[2804,2862,"Diana."],[3012,3091,"I truly"],[3179,3291,"want what's best for you,"],[3379,3500,"but you have to make a decision."],[3591,3679,"I need you to,"],[3729,3804,"to want me."],[4391,4454,"If you really"],[4454,4566,"have another fated mate,"],[4966,5066,"then I'll respect that."],[5312,5404,"And if you want me to stop..."]],"43":[[50,158,"If you want me to stop..."],[525,587,"then I will."],[995,1112,"The ball's in your court."],[1362,1520,"I don't want to let go of him either."],[1625,1750,"But if I find my fated mate,"],[1750,1875,"I could get Rhea back."],[1950,2000,"And with her"],[2000,2158,"I could change my fate for good,"],[2195,2275,"become Luna,"],[2337,2508,"and provide a better life for Alex."],[2645,2737,"I have to figure this out."],[3312,3487,"Please, Moon Goddess,"],[3487,3612,"let me reveal my true identity"],[3612,3745,"as Diana's fated mate,"],[3770,3875,"so we can mark each other"],[3875,4000,"and finally seal our bond."],[4395,4483,"I'm out of options."],[4550,4650,"I have to find Rhea."],[4695,4862,"For me, Alex,"],[4983,5112,"for my second chance at life."]],"44":[[133,287,"Can you come out so we can talk?"],[358,487,"You spoke to me yesterday."],[637,725,"Please."],[820,937,"Please, I have to know."],[950,1070,"Do I have a fated mate?"],[1112,1225,"Who is the Lycan King?"],[1620,1708,"I guess I'm just wondering,"],[1708,1825,"what if I stayed with Alex?"],[1912,2020,"Would that be enough for you?"],[2150,2275,"What if I need to transform?"],[3170,3250,"Moon Goddess,"],[3425,3487,"why did you give me"],[3487,3558,"a second chance"],[3558,3675,"if everything's just gonna stay"],[3675,3737,"the same?"],[3862,3975,"I lost my wolf."],[4083,4187,"Ivy's after me."],[4650,4775,"Just when I'm finally,"],[4933,5037,"finally happy,"],[5112,5287,"you're telling me I can't be with Alex."],[5337,5545,"I never wanted to be Luna."],[5637,5737,"How am I supposed to choose"],[5737,5900,"between Alex"],[6012,6095,"and survival?"],[6262,6325,"Diana."],[6387,6450,"Alex?"]],"45":[[4,66,"Diana."],[195,254,"Baby."],[470,529,"Diana."],[1745,1816,"Diana."],[2033,2095,"Diana."],[2420,2479,"Diana?"],[2633,2770,"Shit, he saw me."],[3166,3316,"How does he always see me?"],[3366,3466,"To be honest, I,"],[3704,3770,"I need you."],[3995,4066,"Please,"],[4158,4245,"can you strip for me?"]],"46":[[12,100,"Can you strip for me?"],[545,595,"Please?"],[3720,3812,"Good girl."],[4245,4350,"You know I can't think straight"],[4350,4458,"when you look at me like that."],[5162,5350,"Diana, you are a goddess."],[5487,5620,"And I am just praying"],[5620,5783,"that you put me out of my misery."]],"47":[[29,141,"Is this what it feels like"],[154,279,"to have all the power?"],[454,562,"To be in control?"],[662,841,"Diana, you are a goddess."],[1016,1150,"And I am just praying"],[1216,1354,"that you put me out of my misery."],[1475,1566,"I can't take it anymore."],[1637,1729,"Is this what it's like"],[1729,1875,"to have a man burn for you?"],[1912,1987,"Rhea might have told me"],[1987,2087,"to search for my mate."],[2166,2254,"But how could I deny"],[2254,2366,"what I feel for Alex?"],[2441,2554,"I'm finally with someone"],[2554,2641,"who's kind."],[2704,2854,"Someone strong but gentle."],[2975,3041,"I know I told you"],[3041,3154,"that I might have another mate"],[3154,3212,"out there."],[3229,3279,"But,"],[3404,3454,"the truth is"],[3466,3579,"I don't want anyone else."],[3641,3716,"I want you."],[3887,4000,"I want to be yours."],[4075,4187,"Someone I want."],[4304,4362,"I can handle"],[4362,4487,"whatever else comes"],[4487,4600,"as long as I have you."],[4779,4875,"I choose you."],[4966,5041,"Every day,"],[5237,5316,"until we die."],[5429,5529,"Surviving isn't enough"],[5529,5654,"if I actually want to live."],[5729,5862,"Isn't it worth taking a risk"],[5862,5962,"to be with each other?"]],"48":[[437,529,"I think about you"],[675,791,"from the moment I wake up,"],[950,1079,"until the moment I go to bed."],[1841,1979,"I've never had anybody"],[1979,2129,"take care of me like this before."],[2350,2554,"There are so many more ways"],[2691,2841,"that I need to take care of you."],[3125,3204,"Show me."],[3579,3716,"Oh, fuck, Diana."],[3791,3925,"You are so perfect."],[4112,4225,"It's like you were meant for me."]],"49":[[333,437,"Alex, it's me."],[462,545,"You have a letter."],[591,691,"You can leave it by the door."],[2179,2304,"Looks like Jax and Ivy"],[2304,2441,"are hosting some Luna Games."],[2604,2825,"It should be the last event"],[2825,2929,"before the Crowning Ceremony."],[3004,3066,"We should go."],[3304,3466,"You're not worried Ivy's gonna plant"],[3479,3566,"more traps for you?"],[3600,3679,"Now that I've decided"],[3691,3779,"to stay with Alex,"],[3779,3904,"it's more important than ever"],[3904,4041,"to make sure I become the Luna."],[4091,4241,"It's not just my fate on the line now."],[4279,4379,"It's both of ours."],[4491,4666,"I'm not allowed to be afraid anymore."],[4779,4891,"Not when I have you."],[5187,5266,"That's my girl."]],"50":[[58,275,"Welcome to the Luna Games,"],[308,395,"where we'll see"],[400,708,"who's fit to be the Ultimate Luna."],[825,912,"Yeah!"],[1187,1350,"Not to have any spoilers,"],[1350,1545,"but so many of you have said"],[1545,1695,"that you're imagining me"],[1695,1812,"and Jax"],[1812,2000,"at the Crowning Ceremony."],[2120,2200,"Yeah!"],[2375,2462,"Oh look,"],[2500,2687,"it's my darling sister"],[2687,2883,"and her low-class husband."],[2925,3062,"Isn't she so cute"],[3062,3237,"for choosing such a pitiful mate?"],[3320,3475,"He's a filthy rogue bottom feeder."],[3500,3708,"I can't believe that packless loser"],[3708,3825,"would show his face here."],[4037,4158,"Those pieces of shit"],[4158,4283,"deserve to be knocked out."]],"51":[[4,100,"Hey, hey, hey, hey."],[241,337,"Don't worry about them."],[416,500,"All I see is you."],[566,754,"You, and a bunch of bullshit"],[754,862,"that I don't care about."],[862,916,"Fine."],[1050,1204,"But if they say one more thing,"],[1229,1379,"I will go over there and I will-"],[1379,1616,"I will be cheering you on"],[1616,1725,"from the sidelines,"],[1766,2087,"watching you kick their asses."],[2179,2241,"Sissy,"],[2304,2466,"I'm so glad you and your homeless,"],[2529,2716,"I mean, your husband"],[2716,2791,"could make it."],[3025,3191,"Those dumbasses failed to mess up"],[3200,3350,"your pretty face at the Alpha Ball."],[3391,3550,"Guess it's up to me now, Diana,"],[3566,3716,"to make sure that you stay down,"],[3729,3837,"as always."],[3925,4037,"I'll play along for now,"],[4104,4241,"but I'm not letting down my guard."]],"52":[[29,133,"Wouldn't miss it for the world."],[170,320,"These games are important to Ivy."],[366,458,"She needs to show everyone"],[458,658,"that she's Ultimate Luna material."],[691,820,"We might not be together anymore,"],[829,1029,"but your little sister is still my mate."],[1058,1195,"It's only right for you to let her win."],[1316,1458,"Last time I did let Ivy win."],[2454,2570,"What a mess, Diana."],[2620,2733,"Is this what you consider"],[2733,2891,"Ultimate Luna material?"],[2958,3083,"Since your mate's a rogue,"],[3083,3258,"you're not even in the running"],[3258,3383,"for Ultimate Luna anyway,"],[3383,3591,"so you might as well just let me win."],[3733,3920,"She really thinks I'll fold that easily?"],[4016,4083,"Sure."],[4229,4366,"Anything for my baby sister."],[4433,4545,"You're the best, sissy."]],"53":[[4,108,"Well, that was easy."],[154,245,"Hanging around the rogue"],[266,354,"has probably given her"],[354,470,"a loser's mentality."],[520,583,"Tragic."],[620,733,"Too bad I don't care."],[1558,1729,"Okay, go ahead and underestimate me."],[1845,2029,"You have no idea what I'm capable of."],[2733,2820,"You better not mess this up"],[2820,2933,"and throw it for your sister."],[3004,3095,"Excuse me?"],[3145,3220,"Come on, Diana."],[3291,3420,"Everyone knows you're a pushover."],[3458,3608,"You might not be with Jax anymore,"],[3633,3704,"but we've all watched you"],[3704,3929,"bend to Ivy's will for years."],[3991,4104,"So that's how people saw me"],[4104,4195,"in my past life?"],[4245,4308,"Just a sucker"],[4308,4495,"for Ivy and Jax's manipulation."],[4533,4583,"I wanna win"],[4583,4716,"just as much as everyone else."],[4733,4795,"If we lose,"],[4795,4933,"I will rip your fucking throat out."],[4945,5129,"If we lose, I'll give you the knife."],[5545,5758,"I'm going to drag her, literally."],[5820,5920,"Sorry, Ivy,"],[5979,6083,"but your reign's over."]],"54":[[350,437,"Let's go, Diana."],[850,987,"One point to Team Ivy."],[1208,1408,"Hey, I warned you once."],[1458,1583,"Are you still Little Miss Pushover"],[1587,1645,"or are you gonna pull"],[1645,1720,"your fucking weight?"],[1720,1787,"Switch with me."],[1837,1900,"Are you kidding? - I'll be better"],[1900,1950,"from the back."],[1950,2020,"Do you wanna argue"],[2020,2095,"or do you wanna win?"],[2150,2208,"Okay,"],[2275,2337,"fine."],[2387,2508,"But don't fuck it up."],[2625,2733,"Round two."],[3237,3350,"Ivy, don't let her push you."],[3600,3687,"Come on, come on, come on."]],"55":[[491,662,"One point for Team Diana."],[687,804,"The score is one to one."],[854,966,"What the fuck?"],[1004,1154,"She's supposed to let me win."],[1216,1354,"Don't let her get under your skin, Ivy."],[1404,1554,"Yes, hell yeah, Diana."],[1604,1662,"Let's go."],[2641,2779,"And we're back at a tie."],[2816,2950,"This is the final round."],[3154,3237,"Prove to your Alpha"],[3237,3379,"that you're worthy of being his Luna."],[3437,3604,"Rhea, Moon Goddess,"],[3604,3691,"please give me the strength"],[3691,3891,"to win this, to change my fate."]],"56":[[312,375,"Yes!"],[687,787,"Are you, are you okay?"],[850,1050,"Obviously I'm not okay."],[1087,1195,"Diana glowed."],[1245,1350,"I've never seen her glow"],[1362,1408,"like that before."],[1408,1595,"I mean, she doesn't even have a wolf."],[1620,1737,"She clearly cheated."],[1787,2037,"And she needs to be disqualified."],[2100,2225,"It's just a game, Diana."],[2245,2283,"How could you"],[2283,2383,"injure your baby sister?"],[2383,2520,"You heartless bitch."],[2520,2650,"I didn't cheat, Ivy."],[2675,2800,"Maybe if she can't pull her weight,"],[2800,2887,"she's not Ultimate Luna"],[2887,2975,"material after all."],[2995,3087,"How dare you tell me"],[3087,3162,"something like that."],[3170,3225,"Enough!"],[3300,3445,"Ivy, this is how the game works."],[3495,3625,"Heal yourself if you want to be"],[3625,3725,"the best candidate."],[3775,3850,"Otherwise,"],[3875,4025,"maybe being a Luna isn't for you."],[4258,4387,"Diana and Katie win!"]],"57":[[29,154,"Diana and Katie win!"],[216,300,"Yes, baby!"],[354,412,"Good job!"],[429,491,"Yes!"],[929,1016,"I misjudged you."],[1041,1091,"I'm sorry"],[1091,1229,"for threatening your trachea."],[1254,1316,"It's okay."],[1416,1541,"I think I needed the honesty."],[1841,2000,"I can feel you take charge of"],[2000,2137,"your destiny, Diana."],[2137,2283,"Your strength proves to me that"],[2283,2458,"you're ready to change your fate."],[2470,2675,"When the time is right, I will enlighten"],[2675,2858,"you of all your frustrations."],[2887,3041,"All of the things you feel you are"],[3041,3158,"in the dark about."],[3191,3416,"You will know everything, my child."],[3487,3554,"Soon."],[3579,3737,"I will become the Luna before Ivy."],[3775,3900,"I will prevent my death."],[3916,4041,"I will change my fate."],[4554,4666,"You did so good!"],[4987,5050,"For him."],[5116,5216,"I'll do it all for him."]],"58":[[33,233,"You kicked her ass."],[308,383,"Well, I mean,"],[470,520,"I don't know."],[520,608,"Someone had to do it."],[758,829,"Ew."],[891,1045,"Does anybody smell that?"],[1066,1291,"It smells like a dirty cheater"],[1295,1470,"and her trash mate."],[1570,1641,"This is where people"],[1641,1741,"with actual money"],[1741,1883,"wait for their drivers, idiots."],[1933,2133,"You get lost trying to hitchhike home?"],[2158,2220,"Oh."],[2241,2345,"They're probably waiting for us"],[2345,2383,"to leave"],[2383,2579,"so they can go sleep in the woods."],[2645,2833,"Isn't that what you do to survive?"],[2870,3066,"You know, I'm really surprised evolution"],[3070,3254,"hasn't weeded out you pests."],[3291,3366,"Ignore them."],[3420,3533,"They have nothing better to do"],[3533,3645,"than hurl insults."],[3654,3770,"Why even bother"],[3770,3920,"showing your face around here?"],[3920,4120,"Everyone else is from a good family,"],[4129,4320,"but you, you're lower than dirt"],[4333,4416,"and you're dragging her"],[4416,4529,"into the grave with you."],[4545,4633,"I suggest you choose"],[4633,4791,"your next words very carefully."],[4808,4858,"You never know"],[4858,4991,"who you could be talking to."],[5220,5520,"Are those Rolls Royce keys?"],[5558,5741,"He probably found them in the trash"],[5741,5845,"while digging for food."],[5983,6045,"Enough!"]],"59":[[0,62,"Guys,"],[75,245,"stop embarrassing yourselves."],[287,462,"This is clearly Jax's car."],[495,633,"Uh, yeah."],[687,837,"Yeah, of course this is mine."],[875,995,"Ivy and I are gonna be"],[995,1095,"Alpha and Luna."],[1125,1275,"We deserve a nice car."],[1312,1425,"At least one of my daughters"],[1433,1562,"did something right."],[1608,1833,"Of course this car is for Ivy and me."],[1862,1962,"It's the kind of car"],[1962,2087,"successful people drive."],[2133,2312,"For people with actual money,"],[2350,2408,"like us."],[2458,2637,"Alex, what is going on?"],[2683,2758,"Don't worry."],[2858,3020,"I'm here to pick up Diana and Alex."],[3062,3208,"How is this happening?"],[3208,3420,"Jax, you said this car is yours."],[3470,3650,"I don't know what's happening."],[4058,4245,"He is a homeless rogue."],[4287,4408,"A homeless rogue!"],[4433,4600,"This is clearly not your car."],[4758,4833,"Right, Jax?"],[5050,5262,"Why don't we all take the bus?"],[6087,6162,"Who are you?"],[6270,6320,"Really."]],"60":[[12,116,"Maybe I should just tell her."],[391,441,"Um,"],[512,591,"well Julian likes"],[591,704,"really expensive cars,"],[704,937,"so when he rented this one,"],[1062,1116,"I thought it'd be fun"],[1116,1237,"to give your parents a scare."],[1554,1691,"You two are really close, huh?"],[2129,2175,"Yeah,"],[2175,2229,"we've, um,"],[2254,2379,"we've been through war and back."],[3387,3466,"These are gifts"],[3466,3654,"from the Lycan King for Diana."],[3950,4116,"I'm here to style you for the Alpha Ball"],[4141,4266,"as a favor to Alex."],[4704,4779,"Alexander,"],[4875,5062,"such an honor to meet you again."],[5504,5641,"I need to know what he's hiding."],[5704,5879,"Is he really who he says he is?"]],"61":[[387,450,"What the...?"],[1037,1262,"Lycan King Laws and Testaments?"],[1295,1408,"Why would a rogue"],[1408,1595,"need so many legal documents?"],[2104,2275,"So, Alex did meet him before"],[2275,2375,"the Alpha Ball."],[2375,2475,"What is going on?"],[2958,3008,"Wait."],[3125,3212,"I've seen this."],[3787,3875,"It's the same."],[4025,4133,"What do you think you're doing?"],[4333,4383,"I..."]],"62":[[75,187,"I was curious and I..."],[345,408,"I'm sorry."],[450,537,"I won't do it again."],[675,725,"It's okay."],[808,875,"I'm not mad."],[970,1025,"You're not?"],[1125,1200,"The Lycan King,"],[1400,1608,"he ruled over all the wolves."],[1995,2050,"And I am-"],[2050,2150,"It's not time yet!"],[2220,2400,"Look, I don't wanna lie to her anymore."],[2454,2600,"Moon Goddess, please."],[3000,3120,"Well, I am not allowed"],[3120,3200,"to tell you yet."],[3350,3437,"You're not allowed?"],[3650,3800,"Diana, please trust me"],[3837,3925,"when I say that one day"],[3925,4150,"I will spill everything to you."],[4237,4320,"But right now, you,"],[4408,4525,"you're just safer not knowing."],[4675,4800,"I'd be a hypocrite if I pretended"],[4800,4945,"he was the only one with secrets."],[4987,5058,"I trust you."],[5162,5220,"Thank you."],[5808,5858,"Diana."],[5912,5975,"Diana, hey!"],[5975,6062,"Diana, hey, hey, hey!"],[6083,6175,"Hey, Diana."]],"63":[[1445,1570,"I think most of the pain's gone."],[1645,1683,"Yeah, well,"],[1683,1795,"we should go see a doctor,"],[1816,1908,"figure out what's going on."],[1941,2066,"I think I know what's going on."],[2220,2316,"You can do this."],[2395,2491,"Just be honest."],[2891,3045,"I, I think I lost my wolf."],[3220,3329,"And every single day since,"],[3329,3470,"I've been in more and more pain."],[3520,3658,"I haven't been able to heal myself,"],[3658,3879,"and I haven't been able to talk to her."],[3995,4170,"I think the Alpha Games had"],[4229,4345,"pushed me past my limit."],[4458,4666,"The worst part is I have no idea"],[4666,4754,"how to get her back."],[4833,4920,"So when you heard her"],[4920,5058,"talking about your fated mate"],[5058,5120,"the other night- - Yeah, that was"],[5120,5241,"the first time I've heard her"],[5245,5345,"in a really long time."],[5400,5479,"But I have no idea"],[5479,5570,"what she was trying to say,"],[5570,5629,"and I haven't been able"],[5629,5745,"to talk to her since."],[5820,5920,"That's why she doesn't know"],[5920,6016,"we're fated mates."],[6120,6241,"Why she can't feel our bond."],[6345,6579,"I am so sorry"],[6583,6695,"that you've been in so much pain."],[6695,6820,"Thank you for telling me."],[7091,7204,"I would've told you sooner."],[7266,7320,"I just didn't know"],[7320,7420,"what you'd think about me."],[7445,7529,"It doesn't matter"],[7583,7683,"if you have a wolf or not."],[7791,7954,"Okay, I will always be here for you."],[8058,8133,"I promise."]],"64":[[387,458,"And I can take away"],[458,550,"the pain that's left."],[700,745,"Here,"],[808,912,"show me where it hurts."],[1125,1245,"Can he really heal me?"],[1300,1425,"I mean, a cut finger is one thing,"],[1425,1620,"but this is completely different."],[1700,1762,"You probably have to"],[1762,1850,"take your top down."],[3970,4062,"Okay, show me where."],[4520,4575,"Right here?"]],"65":[[2141,2216,"Is it okay?"],[2225,2291,"Does it feel better?"],[2354,2566,"No more problem spots?"],[2566,2662,"Just one more."],[2791,2862,"Really, where?"],[2900,2954,"Where?"],[4400,4500,"Well, in that case,"],[4554,4629,"maybe I should do"],[4629,4762,"a full body inspection,"],[4891,4975,"just to be safe."]],"66":[[1337,1420,"There's no way she's had"],[1420,1550,"a massive change of heart."],[1595,1837,"But the sooner the rivalry ends,"],[1837,2000,"the sooner I can finally move on"],[2000,2158,"from the ghost of my past life."],[2862,2975,"Would you like some tea?"],[3087,3150,"Sure."],[4000,4137,"You know, I've been thinking a lot"],[4137,4300,"about how things used to feel"],[4300,4387,"between us."],[4525,4595,"We used to feel like"],[4595,4712,"we were real sisters."],[4895,4945,"Really?"]],"67":[[95,162,"We used to feel like"],[162,275,"we were real sisters."],[358,395,"What?"],[458,512,"Really?"],[650,720,"You know, I,"],[825,950,"I don't remember it that way"],[1012,1070,"at all."],[1112,1283,"Why isn't she falling for my words"],[1283,1470,"like her usual moronic self?"],[1537,1683,"Is she really still trying to pull"],[1683,1800,"the nice girl act?"],[2025,2200,"Aw, don't be silly."],[2300,2358,"Ivy,"],[2470,2550,"let's be real."],[2662,2737,"What do you want?"],[2812,2850,"I don't know"],[2850,2970,"what's gotten into you lately."],[3033,3187,"I mean, it's not my fault that your mate"],[3187,3475,"is some homeless loser."],[3562,3737,"I've always been nice to you"],[3737,3875,"even though you constantly"],[3875,3975,"embarrass me and"],[4075,4250,"you've never once thanked me for that."],[4320,4450,"And there she is,"],[4537,4625,"the real Ivy."]],"68":[[170,320,"I'm sorry, I'm not following."],[412,487,"You need to start"],[487,625,"taking some accountability."],[687,783,"I mean, you keep acting"],[783,858,"like you're someone,"],[858,912,"but really,"],[920,1137,"it's me who will be crowned Luna,"],[1175,1258,"and you are no one."],[1362,1483,"Please tell me more about myself."],[1525,1570,"You're nothing"],[1570,1737,"more than a miserable little brat"],[1737,1900,"who embarrassed our fucking family"],[1900,2045,"by marrying a fucking loser."],[2095,2250,"And no matter how hard you try,"],[2258,2458,"you will always be a bottom-feeding,"],[2458,2595,"groveling little bitch!"],[2687,2833,"So that's what it takes for her"],[2833,2970,"to finally let it all out."],[3045,3104,"Oh."],[3150,3275,"I'm sorry you feel that way."],[3312,3462,"I really am, but you need help."],[3487,3675,"You need professional help."],[3675,3762,"I'm worried about you."],[3762,3912,"You're showing signs of psychosis."],[3987,4070,"I see right through"],[4070,4170,"her pathetic attempts"],[4170,4262,"at making everyone think"],[4262,4362,"she's better than me."],[4420,4525,"Well, I'll show them all"],[4525,4662,"who she really is."],[4895,4950,"Okay?"],[5525,5583,"Ivy!"],[5712,5775,"Ivy?"]],"69":[[20,95,"What are you doing?"],[145,237,"I don't know, sissy."],[270,350,"What are you doing?"],[900,1083,"No, Diana, stop it."],[1087,1212,"You're hurting me."],[1750,1800,"No."],[1920,1970,"No."],[2000,2062,"No, Ivy."],[2100,2187,"Ivy, no!"],[2962,3137,"This definitely did not happen"],[3137,3212,"in my past life."],[3225,3270,"Ivy,"],[3387,3450,"are you okay?"],[3525,3675,"What the hell is going on?"],[3962,4050,"Jax."],[4337,4525,"Are you fucking crazy?"],[4695,4875,"I always knew you were jealous of Ivy,"],[4912,5045,"but you've gone completely feral,"],[5045,5162,"you psychotic bitch!"],[5312,5470,"I'm going to kill you."]],"70":[[154,291,"I can't do this without Rhea."],[316,429,"Why, Diana?"],[516,629,"Why would you do this"],[629,791,"to your own sister?"],[841,1037,"Are you really that jealous of me"],[1037,1204,"becoming the Luna?"],[1237,1450,"How can someone be so horrible?"],[1479,1591,"Kicking her out of the pack"],[1591,1675,"wasn't enough."],[1704,1862,"She should be executed!"],[2562,2654,"Finally,"],[2691,2929,"everything is finally going my way."],[3004,3254,"I can't wait for you"],[3312,3554,"to be a rotting piece of flesh."],[3629,3729,"And Jax and I"],[3729,3966,"will be crowned Alpha and Luna,"],[4025,4200,"and no one will care about you."],[4866,4991,"Do you want to do the honors?"],[5041,5112,"Obvi."],[5154,5325,"But I want to see you"],[5325,5454,"rough her up first"],[5537,5704,"before the grand finale."]],"71":[[179,291,"How is he glowing golden?"],[325,500,"Only the Lycan King Alexander"],[500,604,"can glow like that."],[1654,1766,"I'm so sorry."],[1816,1879,"I was late."],[2029,2175,"Why were you glowing gold?"],[2475,2662,"There is no way"],[2666,2816,"this disgusting wretch"],[2816,2929,"is the Lycan King."],[3004,3104,"And I'll prove it."],[3562,3754,"I should have done this a long time ago."],[3837,3991,"Forgive me for trying to make"],[3991,4075,"a good impression,"],[4104,4175,"brother-in-law."],[4266,4429,"Wait, wait, wait."],[4441,4575,"We can talk this out."],[4650,4716,"What do you want?"],[4766,4925,"You think I want anything from you?"],[4958,5000,"Huh?"],[5062,5179,"You want the truth, Jax?"],[5275,5366,"I pity you."],[5416,5537,"So did everybody else."]],"72":[[1562,1700,"If any of you heathens"],[1750,1983,"so much as breathe near my mate,"],[2045,2120,"I will hear of it."],[2208,2325,"I will track you down"],[2400,2562,"and I will claw your skin off"],[2575,2687,"strip by strip"],[2725,2887,"until there's nothing left but a puddle!"],[2970,3083,"The time has come."],[3112,3212,"You may tell everyone"],[3212,3275,"who you are."],[3550,3675,"You want to live past tomorrow?"],[3712,3833,"Then you will never threaten"],[3862,3995,"Lycan King Alexander's"],[3995,4070,"mate again."],[4683,4850,"Lycan King Alexander?"]],"73":[[512,612,"What do you need, my love?"],[662,750,"Take me home."],[1000,1066,"Of course."],[1179,1241,"Let's go home."],[1541,1900,"This is not the end."],[2162,2416,"So, this is my real bedroom."],[2550,2654,"This is crazy."],[2979,3054,"So now you know."],[3154,3412,"I am Alexander, the Lycan King."],[3479,3666,"The most powerful wolf there is."],[3904,4004,"I mean this is beautiful,"],[4004,4191,"but I kind of preferred"],[4191,4266,"our old bedroom."],[4266,4354,"I kind of miss it."],[4512,4554,"You do?"],[4579,4616,"Yeah."],[4837,4929,"I mean, don't get me wrong."],[5025,5104,"You're incredible."],[5179,5266,"But I didn't fall in love"],[5266,5366,"with the Lycan King."],[5454,5575,"I fell in love with Alex."],[6041,6116,"And I love you,"],[6225,6279,"Diana."],[6379,6529,"With everything that I am,"],[6662,6716,"I love you."],[7791,7941,"He's finally being honest with me."],[8116,8225,"It's time I did the same."]],"74":[[241,358,"Wait, what, what's wrong?"],[658,733,"Whatever it is, we,"],[791,920,"we can get through it together."],[1041,1108,"I just haven't been"],[1108,1241,"completely honest with you."],[1433,1483,"Do you remember"],[1483,1633,"how I told you I lost my wolf?"],[1829,1858,"I think"],[1858,2058,"it's because this isn't my first life."],[2158,2204,"What,"],[2295,2358,"what do you mean?"],[2495,2608,"I was mated to Jax."],[2708,2795,"And he was horrible"],[2820,2920,"and he was abusive."],[2920,3008,"And when I found out"],[3008,3141,"he was cheating on me with Ivy,"],[3245,3516,"she pushed me off a cliff."],[3729,3795,"I died."],[3983,4066,"And as I was falling,"],[4066,4179,"I begged the Moon Goddess"],[4179,4295,"for a second chance"],[4295,4433,"to do everything differently."],[4545,4595,"And,"],[4741,4808,"I died."],[4904,4983,"And I woke up."],[5083,5204,"And it was the day"],[5204,5345,"I was supposed to marry Jax."],[5408,5495,"And the Moon Goddess told me"],[5495,5629,"that I had to become Luna"],[5641,5708,"instead of Ivy"],[5708,5816,"or she would kill me again."],[5845,5970,"So I broke off the engagement."],[6008,6108,"That's when you found me."],[6254,6341,"You saved me."],[6445,6595,"You didn't even know who I was."],[6741,6895,"I'll always be grateful to you."],[7083,7208,"You came into my life"],[7320,7420,"right when I needed you."]],"75":[[25,79,"Diana,"],[162,404,"you are the one that saved me."],[475,566,"Before I was just"],[566,700,"Alexander, the Lycan King"],[700,825,"and everyone just knew my name."],[854,1129,"But you really know me."],[1229,1291,"For the first time"],[1291,1425,"I feel like I can feel the sun"],[1425,1504,"on my skin."],[1600,1729,"I will spend the rest of my life"],[1729,1812,"working hard"],[1825,2075,"so that you will always see me."],[2212,2429,"I am so sorry"],[2591,2775,"that you spent your past life alone."],[2791,2862,"But I'll make sure"],[2862,2991,"for the rest of this life"],[3012,3129,"and any life after,"],[3262,3379,"I will always find you."]],"76":[[816,945,"Today is the Alpha and Luna"],[945,1041,"Crowning Ceremony."],[1108,1308,"By night, I'll have changed my fate"],[1370,1458,"or died trying."],[1958,2058,"Good morning, beautiful."],[2170,2308,"You know, today is the day I died"],[2370,2470,"in my first life."],[2658,2716,"Hey, it's okay."],[2816,2933,"No fear, remember?"],[3045,3195,"You are gonna stay alive"],[3241,3395,"for a long, long, long, long,"],[3395,3520,"long, long, long, long time."],[3633,3695,"Hey."],[4470,4533,"With you gone,"],[4545,4708,"I'm gonna have to find another Alpha"],[4708,4845,"and start all over."],[4958,5033,"Useless!"],[5183,5416,"I'm going to kill Diana"],[5416,5641,"before she can ever be crowned Luna."],[5758,6095,"I'm going to rip her limb from limb."],[6158,6416,"Slowly and painfully."],[6458,6683,"And finally, she'll be gone."]],"77":[[962,1100,"I didn't survive this day last time."],[1175,1250,"But this time"],[1250,1412,"I'm being crowned next to Alex."],[1475,1520,"We'll make it"],[1520,1620,"through the day together."],[1695,1758,"We have to."],[1808,2025,"You look beautiful."],[2200,2345,"We do look pretty good together,"],[2345,2400,"don't we?"],[2437,2500,"Oh, yeah."],[2562,2800,"But you are carrying us for sure."],[2887,3008,"Everything will be okay."],[3295,3550,"Make way for Lycan King Alexander"],[3550,3708,"and his Luna, Diana."],[4137,4270,"This is so strange."],[4375,4450,"I know it's a lot."],[4508,4612,"But in my defense,"],[4625,4800,"you, more than anyone,"],[4837,4995,"deserve to be treated like royalty."],[5175,5325,"Oh, darling Diana."],[5362,5550,"It is so wonderful to see you."]],"78":[[33,208,"It is so wonderful to see you."],[233,495,"And look at your handsome mate."],[545,733,"We always trusted you had a plan."],[783,891,"You can't be serious."],[895,1083,"Oh, we are so thankful"],[1083,1270,"to be part of the royal family."],[1270,1341,"Yes."],[1366,1445,"Thank you"],[1445,1633,"for taking care of our daughter,"],[1720,1808,"Your Highness."],[2104,2258,"You two are spineless leeches."],[2295,2558,"So don't expect to get a cent from us,"],[2583,2683,"because unless your daughter"],[2683,2795,"has a very generous"],[2795,2870,"change of heart,"],[3016,3108,"I'm not as forgiving."],[3358,3566,"Diana, reason with him."],[3595,3691,"Anyone would have made"],[3691,3829,"the same mistake."],[3845,3970,"And it never would have happened"],[3970,4116,"if he hadn't deceived us."],[4116,4158,"Right."],[4191,4245,"Mother,"],[4320,4370,"Father,"],[4458,4545,"you said you wanted nothing"],[4545,4616,"to do with us."],[4754,4820,"We're giving you what you"],[4820,4887,"always wanted."],[5020,5270,"Wait, you can't do this."],[5279,5358,"Diana!"],[5358,5483,"I wouldn't do that if I were you."],[5508,5608,"Diana!"],[5816,5904,"Diana!"],[5904,6079,"No, just, okay, okay."],[6079,6158,"No pushing, no."]],"79":[[58,212,"So, Diana,"],[350,512,"since I am the Lycan King,"],[600,775,"you will absolutely be crowned"],[775,870,"the Ultimate Luna."],[962,1012,"Really?"],[1095,1158,"Yeah."],[1187,1333,"Then I don't have to worry anymore."],[1400,1512,"This is my life now."],[1575,1683,"No one can take it away."],[1712,1837,"I better go get some air."],[1862,1912,"This is,"],[2062,2150,"this is amazing."],[2150,2300,"I just need a moment by myself."]],"80":[[566,766,"Good morning, Sleeping Beauty."],[829,879,"Ivy."],[945,1016,"What the hell,"],[1016,1133,"are you kidnapping me now?"],[1241,1370,"You have been a fucking thorn"],[1370,1491,"in my side, Diana."],[1558,1708,"You embarrass me at the Alpha Ball,"],[1708,1845,"screw me over in the Luna Games,"],[1845,1979,"and then your psycho husband"],[1979,2070,"kills Jax."],[2083,2304,"And now you're living the fairy tale"],[2304,2395,"while I suffer?"],[2620,2695,"Well, guess what?"],[2745,3008,"Your little princess games end now."],[3141,3308,"Ivy, why are you so obsessed with me?"],[3316,3458,"I'm not obsessed with you!"],[3466,3620,"Maybe if you focused on yourself"],[3620,3741,"instead of everything I do,"],[3741,3833,"you'd have a life."],[3920,3970,"I'm sorry,"],[4033,4158,"did I book you for a TED Talk?"],[4245,4304,"No,"],[4345,4395,"I dragged you"],[4395,4495,"into the middle of the woods,"],[4533,4633,"tied you up to a tree,"],[4654,4770,"and you still won't stop"],[4770,4883,"fucking lecturing me."],[4891,4970,"So what will it take"],[4970,5079,"to get you to shut up?"],[5108,5158,"This?"],[5445,5545,"Should I start by"],[5595,5745,"digging out your vocal chords or..."],[5883,6079,"do I want to hear you scream first?"]],"81":[[54,104,"You know,"],[275,400,"I've been dreaming of this moment."],[504,600,"I've always wanted to see"],[600,704,"the look in your eyes"],[704,787,"when you realize"],[787,954,"you're never gonna take another breath."],[1041,1129,"So how does it feel"],[1129,1329,"facing your own mortality, Diana?"],[1341,1475,"Why don't you ask Jax?"],[1475,1654,"You have no right to say his name!"],[1666,1916,"I was this close"],[1941,2054,"to being crowned Luna,"],[2054,2225,"and you took that away from me."],[2225,2350,"Alex did you a favor, Ivy."],[2387,2454,"Now you don't have to live"],[2454,2566,"under that man's thumb."],[2641,2804,"I wonder if Alex will feel the same way"],[2804,2929,"once I get rid of you."],[3141,3254,"Rhea, if there was ever a time"],[3254,3416,"for you to finally show up, it's now."],[3691,3879,"You are an exhausting,"],[3937,4116,"manipulative bitch."],[4141,4329,"Who never deserved to live."],[4350,4466,"Rhea, I need you!"],[5929,6083,"I'm here, Diana."]],"82":[[325,537,"You think I'm scared of your wolf?"],[662,762,"Oh, boys!"],[1200,1341,"This is the first time I've been back"],[1341,1475,"since you were reborn."],[1475,1570,"I don't have the strength"],[1570,1645,"to beat them."],[1712,1795,"We have to try."],[2362,2420,"Ivy."],[2475,2525,"Ivy."],[2587,2662,"Ivy, listen to me."],[2725,2950,"Ivy, listen to me, listen to me."],[2970,3050,"You don't have to do this."],[3050,3100,"Whatever you think"],[3100,3262,"this is gonna fix inside,"],[3262,3325,"it's not."],[3325,3408,"We can talk about it,"],[3408,3470,"Oh, now - okay?"],[3470,3612,"you wanna braid each other's hair"],[3612,3762,"and have a little heart to heart?"],[3825,3937,"It's too late, sissy."],[3975,4108,"The only thing I care about"],[4133,4258,"is you being a blood bag"],[4283,4425,"at the bottom of the mountain."],[5125,5208,"Oh, no!"],[6187,6300,"You're my fated mate."]],"83":[[308,395,"Kill him!"],[454,533,"Now!"],[620,720,"Alex!"],[766,816,"Ivy!"],[916,1033,"No, no!"],[2233,2279,"I don't care"],[2279,2408,"if it's the last thing I do,"],[2408,2570,"but I will be the one to kill you."],[2754,2895,"He might not make it to me in time."],[2920,3070,"You've always had it all, Diana,"],[3070,3170,"but not this time."],[3216,3345,"This time it'll be me"],[3358,3495,"who basks in the glory."],[3516,3720,"I'll be Luna while the rogues feast"],[3741,3870,"on your obliterated organs"],[3870,3995,"at the bottom of this cliff."],[4008,4241,"Oh, I have prayed for this moment."],[4266,4395,"I have prayed for your death"],[4395,4545,"because it's the only thing"],[4570,4695,"I have left!"],[4695,4845,"I guess this is my fate after all."],[4908,5020,"Maybe the Moon Goddess lied"],[5020,5145,"and I never truly even had"],[5145,5233,"a second chance."],[5295,5395,"But at least this time,"],[5479,5566,"I got to experience"],[5566,5683,"even a sliver of happiness"],[5683,5745,"with Alex."],[5795,5945,"He made this life worth it."],[6345,6420,"Diana!"],[6420,6579,"This may be how my story ends."],[6645,6695,"No!"],[6766,6933,"But I'll still finish what I started."]],"84":[[2116,2354,"I am so sorry, Diana."],[2479,2579,"I was almost too late."],[2604,2687,"If I'd lost you-"],[2687,2741,"Don't say it."],[3100,3166,"We did it."],[3279,3366,"We changed it."],[3429,3579,"This isn't the day I die anymore."],[3579,3629,"This is"],[3741,3816,"just the first day"],[3816,3925,"of the rest of our lives."],[4029,4129,"My true mate,"],[4229,4316,"the Lycan King,"],[4441,4554,"my dear Alexander."],[4666,4754,"The signs were all there."],[4754,4841,"How could I have missed it?"],[4916,4991,"We're here now."],[5104,5291,"We will never have to say goodbye."]],"85":[[391,550,"All rise for the bride."],[3291,3516,"You look radiant."],[3550,3604,"I can't believe"],[3604,3729,"I get to look at your face"],[3737,3812,"every single day."],[4037,4091,"Diana,"],[4200,4266,"I love you"],[4375,4475,"for as many lifetimes"],[4475,4541,"as we can have."],[4691,4829,"I don't need a second chance."],[4962,5291,"I just want this one with you forever."]]}