4,"Or maybe the way"],[684,824,"you blinded me,"],[860,972,"controlled me,"],[976,1088,"and made me a slave"],[1088,1212,"to your family."],[1384,1452,"Fiona."],[1616,1682,"Come on."],[1712,1788,"Take it easy."],[1796,1893,"Poor baby."],[1976,2116,"When would you learn?"],[2216,2376,"This is just the beginning."],[2516,2660,"I want your family"],[2692,2828,"to witness the same"],[2828,2972,"suffering that I did."],[3024,3096,"Fiona,"],[3096,3176,"come on."],[3232,3288,"Don."],[3300,3452,"Don, you promised."],[3532,3609,"Who said anything"],[3609,3684,"about him?"],[3836,3966,"I can handle you idiots"],[3966,4076,"all on my own."],[4272,4352,"Fiona."],[4500,4594,"How can I miss out"],[4594,4736,"on such a juicy deal?"]],"78":[[52,216,"Sterling has a new head."],[244,349,"Jeff looks damn good"],[349,456,"in that shot."],[528,628,"Yeah, that's because"],[628,740,"you exposed"],[740,828,"all their flaws."],[920,984,"Without you,"],[984,1021,"he wouldn't have"],[1021,1164,"taken over so easily."],[1260,1428,"I heard Gabe's hospitalized."],[1504,1708,"What about his baby Henry?"],[1956,2064,"Missing your ex?"],[2176,2220,"No."],[2340,2424,"Just curious."],[2434,2512,"Well..."],[2720,2782,"I never wanna"],[2782,2892,"hear you say that name,"],[2892,2980,"ever again."],[3124,3228,"Hmm. Not now."],[3404,3452,"Still?"],[3564,3664,"It's been two days."],[3704,3764,"Look at him."],[3852,3924,"Poor guy."],[4032,4132,"He's craving your touch."],[4216,4292,"Look, look, look."],[4448,4532,"Don't do it for me."],[4680,4748,"Do it for him."],[4904,4980,"I said..."],[5060,5124,"No!"],[5308,5388,"Tell me why."],[5428,5616,"Just not now."],[5672,5952,"The doctor said the baby's still unstable."],[5964,6148,"I'll tell him when the time is right."],[6252,6320,"I gotta go."],[6512,6612,"Not allowed."]],"79":[[78,200,"Stop it."],[404,484,"I'll give you a surprise"],[484,556,"when I get back."],[634,728,"A surprise?"],[902,975,"Is it the same one"],[975,1064,"I'm thinking of?"],[1172,1268,"I