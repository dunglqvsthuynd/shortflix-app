y? Fuck the money!"],[868,972,"Whatever you want."],[996,1088,"Just please..."],[1204,1360,"Please, don't leave me."],[1444,1588,"Don't be ridiculous!"],[1844,1944,"Don't touch me."],[3100,3180,"Jeff,"],[3352,3472,"tonight we are going to"],[3472,3644,"acquire Daya Quant."],[4688,4768,"Fiona!"],[4856,5004,"So, none of this was real."],[5128,5264,"Not even for a moment?"],[5460,5540,"Mom."],[5644,5792,"I really do love him."],[7104,7168,"Fiona,"],[7168,7272,"you need to open your laptop."],[7272,7392,"Now! Hurry!"]],"61":[[632,828,"Oh my God."],[828,1024,"Daya Quant's stop price"],[1024,1164,"is going crazy."],[1212,1317,"Can you look into this"],[1317,1412,"and tell me what's going on?"],[1444,1500,"I got it."],[1524,1584,"Oh my God."],[1584,1673,"Daya Quant was just"],[1673,1848,"acquired by the Gambino family."],[1976,2096,"Acquired"],[2096,2236,"by the Gambino family?"],[2296,2352,"Vivi,"],[2396,2600,"I'm gonna be a billionaire."],[2876,3044,"I just need to share my stocks,"],[3044,3123,"and then I can"],[3123,3216,"pay off my debt"],[3248,3376,"to the Sterling family."],[3412,3564,"And then if I divorce Henry,"],[3564,3672,"then maybe I can..."],[3936,3992,"No..."],[4244,4308,"Look,"],[4308,4408,"then forget about the money."],[4452,4580,"Okay? Fuck the money!"],[4644,4764,"Whatever you want."],[4776,4872,"Just please..."],[4968,5152,"Please, don't leave me."],[5460,5563,"Can't think about that now."],[5563,5666,"I just need to"],[5666,5800,"focus on finding someone"],[5800,5900,"with enough cash flow"],[5900,5996,"to buy my shares."],[6800,6882,"I got it."]],"62":[[592,652,"Jeff."],[738,802,"Fiona."],[822,962,"Long time no see."],[1058,1232,"I heard you're divorcing Henry."],[1252,1424,"No need to act so close anymore."],[1532,1592,"Alright, well,"],[1592,1670,"if you're not interested"],[1670,1846,"in playing a family card..."],[2458,2624,"Let's cut right to the chase."],[2754,2906,"I have a deal for you."],[2958,3066,"I'm well aware"],[3066,3178,"that your re