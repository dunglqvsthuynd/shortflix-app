{"1":[[652,800,"I've got you North America's"],[800,991,"top 6 escorts."],[1030,1126,"Let's go."],[1470,1550,"Have fun."],[1912,1992,"Choose me?"],[4872,4972,"That's right."],[5634,5960,"1, 2, 3, 4, 5."],[5982,6210,"Where's number six?"],[7622,7692,"So,"],[7746,7892,"you're No. 6?"],[7952,8066,"I'm impressed!"],[8100,8150,"Look,"],[8150,8246,"I..."],[8420,8726,"Be mine for $100,000,"],[8806,8972,"no strings attached."],[9282,9442,"Your husband's cool with this?"],[9542,9730,"He's the one who sent me here."]],"2":[[18,152,"Your husband cool with this?"],[194,382,"He's the one who sent me here."],[540,646,"Stop it!"],[2088,2188,"You did this?"],[2212,2498,"My mom needs a kid ASAP."],[2544,2618,"What?"],[2664,2884,"Do you think I could just do it all by myself?"],[2914,3074,"Stop daydreaming, Fiona."],[3120,3272,"Don't touch me!"],[3322,3402,"Listen,"],[3468,3694,"if I didn't have a marriage contract with you,"],[3724,3872,"I would've never married you."],[3876,4018,"Let's get one thing straight,"],[4032,4184,"I only love Louis."],[4214,4452,"Let's get a divorce then."],[4476,4690,"You're in no position to divorce me."],[4790,4916,"Or have you forgotten?"],[4976,5276,"Your family still owes Sterling $500 million"],[5276,5418,"and we're fronting the bill."],[5418,5742,"So, you better listen to what I have to say"],[5744,5874,"and give me a baby."],[5892,6050,"So you'll get the fortune,"],[6062,6220,"or your family's doomed."],[6262,6362,"Listening?"],[6554,6634,"Fine."],[6702,6782,"I'll do it,"],[6806,7005,"not with some random man you pick out."],[7005,7146,"I'll find him myself."],[7336,7400,"Good."],[8438,8590,"So, that's why you're keeping me."],[8680,8818,"You want cash,"],[8850,8974,"and I want a good time."],[9048,9230,"Sounds like a great deal to me."],[9288,9390,"You think I'm broke?"],[9460,9540,"Aren't you?"],[9850,10010,"I hope you won't regret this."],[10174,10378,"I don't regret anything."]],"3":[[1660,1740,"Hold on."],[1792,1872,"Let me get a condom."],[1916,2026,"No need."],[2092,2196,"I'm on the pill."],[6192,6286,"Did I wake you up?"],[6326,6406,"No."],[6460,6646,"Let's call it a day."],[6706,6852,"I'll let you know if I need you."],[7120,7212,"One more round."]],"4":[[26,120,"One more round."],[260,392,"I'm busy today."],[680,776,"Last night,"],[786,1056,"you said you can go all day long."],[1106,1210,"What's the matter?"],[1326,1416,"Can't hang?"],[1610,1746,"I'm wiped, baby."],[1786,2052,"How about 200,000?"],[2132,2236,"Just for you."],[2316,2492,"200,000 a month?"],[2596,2676,"That's it."],[2756,2926,"You know, with your body,"],[2926,3176,"how about 500,000?"],[3192,3436,"Although having sex with me isn't exactly a loss,"],[3436,3506,"is it?"],[3850,3996,"1 million a month,"],[4116,4256,"not a penny less."],[4370,4420,"Well,"],[4470,4726,"considering your behavior last night..."],[4746,4796,"Okay."],[4796,4992,"I'm off to go get the money out."],[5580,5656,"You'll be good."],[5656,5850,"And I'll come back and spoil you."]],"5":[[256,372,"Miss me already?"],[395,455,"Huh?"],[900,1022,"My God, Don."],[1026,1266,"Is that the lucky girl who spent a night with you?"],[1266,1400,"No, no, no..."],[1480,1586,"I'm the lucky one."],[1712,1872,"You gotta be kidding me."],[1932,2182,"Don, you're the head of Gambino family."],[2182,2402,"Everyone in North America looks up to you."],[2402,2486,"And you're telling me"],[2486,2646,"you let the woman run the show?"],[6542,6696,"In the office?"],[6712,6816,"I guess you don't care about"],[6816,7112,"embarrassing the entire Sterling family."],[7200,7300,"What are you doing here?"],[7342,7562,"I need $5 million."],[7616,7814,"So, pay up."],[7814,8032,"And I'll leave you two alone to do"],[8032,8220,"whatever it is you're doing."]],"6":[[362,460,"What for?"],[470,562,"Same as you,"],[592,742,"I have my eye on a man,"],[742,916,"and I want to keep him for three months."],[916,1072,"So, it'll cost 5 million."],[1210,1472,"5 million for three months."],[1496,1736,"Fiona, let's get one thing straight."],[1760,1992,"I'm your husband, not your daddy."],[2002,2130,"You already have a man,"],[2130,2320,"and you come to me for money."],[2336,2476,"That's ridiculous!"],[2476,2536,"Henry,"],[2536,2832,"you already used your last drop on your baby"],[2832,2976,"Louis over here."],[2990,3229,"I can't really make a baby by myself now,"],[3229,3306,"can I?"],[3400,3480,"Honey,"],[3540,3682,"even without me,"],[3732,3950,"Henry would never date an old"],[3982,4150,"ugly woman like you."],[4192,4332,"If I give you a baby,"],[4332,4510,"then you inherit millions."],[4512,4696,"So, paying for my little fling"],[4696,4832,"sounds like a fair bargain,"],[4832,4940,"don't you think?"],[4970,5102,"If not, that's fine."],[5106,5312,"I can always just tell the whole world"],[5312,5452,"that Henry Sterling"],[5452,5778,"likes to screw his little boyfriend in the office."],[6350,6430,"Get out."],[6620,6700,"Go!"]],"7":[[660,900,"Fine, I'll give you the money."],[910,990,"See?"],[1096,1266,"I may not have your heart,"],[1266,1452,"but I still have your wallet."],[1606,1790,"When did you become so sharp-tongued?"],[1866,2010,"Get used to it."],[2010,2152,"This is the new me now."],[2152,2352,"I'd make that check out quickly,"],[2352,2616,"unless you're offering your own body."],[2780,2862,"Jealous,"],[2862,2936,"are we?"],[2936,3172,"Seeing me and Louis got you all"],[3190,3270,"worked up?"],[3546,3736,"I don't know what game you're trying to play,"],[3750,3866,"luring me into bed."],[3866,4074,"But let me save you the trouble."],[4252,4472,"I can't even get a hardon looking at you."],[5036,5164,"Take the money and get out."],[5392,5486,"Thanks."],[5536,5636,"Bye."],[6326,6570,"Meet me at Moonlight Bar tonight."],[6600,6706,"Don't be late."],[7686,7770,"Fuck!"]],"8":[[370,458,"What kind of person"],[458,652,"keeps their sugar daddy waiting?"],[730,910,"What is wrong with this world?"],[1122,1262,"It's only been 5 hours."],[1316,1432,"And you're thirsty again."],[2582,2662,"What?"],[2800,2970,"Can't recognize me with clothes on?"],[3592,3680,"Now I do."],[4060,4330,"Oh, so handsome."],[4330,4552,"Oh my God, he is hot."],[4580,4762,"Is he a model or something?"],[4776,4950,"Look at his jawline."],[4950,5206,"He'd look like a sugar date to you."],[5330,5476,"Good afternoon, ladies."],[5480,5680,"Oh, yes, I am her personal male model,"],[5722,5792,"on-call."],[5792,5970,"No, he's just joking."]],"9":[[682,886,"Why would you say that?"],[1180,1260,"Okay."],[1320,1400,"Let's go."],[1786,2020,"What, do you need me to buckle you up now too?"],[2020,2182,"After everything last night,"],[2270,2386,"damn right I do."],[4490,4646,"This is my place."],[4696,4860,"From now on, we meet here."],[5010,5116,"Going to hotels..."],[5116,5232,"a relationship like ours"],[5232,5482,"is just asking to get caught."],[5700,5846,"Relationship like ours?"],[5996,6056,"Tell me,"],[6106,6420,"what kind of relationship exactly?"],[6496,6600,"My cash"],[6736,6840,"for your body."]],"10":[[850,1121,"Everything is laid out in this contract,"],[1121,1262,"and this card..."],[1280,1360,"is your pay."],[1420,1500,"Oh yeah."],[1562,1666,"Night shifts only."],[1700,1790,"Work for me."],[1840,2032,"You know, I have daytime clients, too."],[2170,2436,"You're not really seeing other people, are you?"],[2520,2682,"You know, that's just..."],[2716,2876,"Let's just forget I said that."],[2930,3102,"If we're gonna make this work,"],[3130,3420,"then you need to cut off all your other customers."],[3500,3696,"I'm paying a lot and I don't share."],[3722,3850,"So, if that works for you,"],[3882,3976,"you can sign."],[4460,4570,"You know, I was thinking,"],[4800,4930,"we talk too much."],[4962,5170,"Doesn't seem like you're in much of a hurry."],[6156,6236,"Well,"],[6360,6500,"I have work tomorrow."],[6560,6732,"So I think it's time for you to leave."],[6776,6952,"You really want me to go that soon?"],[7110,7190,"Come on."],[7250,7380,"Don't you want me tonight?"],[7542,7820,"Too much indulgence does no good."],[7876,8112,"It's better to wait for tomorrow."],[9436,9630,"You know, I'm the one that craves this."]],"11":[[1592,1692,"Not bad."],[3220,3336,"Oh, look at that."],[3336,3466,"Looks like your husband's calling."],[3466,3562,"Give me that."],[3806,3920,"What do you want?"],[3976,4042,"Me?"],[4116,4200,"What?"],[4260,4340,"Listen,"],[4396,4732,"my mother's having a charity gala tomorrow and"],[4740,4846,"you're coming with."],[4889,4971,"Um..."],[5076,5156,"Alright."],[5396,5442,"What..."],[5442,5542,"What are you doing?"],[5542,5676,"What's that sound?"],[5736,6152,"I'm just working on your future inheritance."],[6156,6440,"Aren't you excited to have a kid that isn't yours?"],[6460,6510,"What?"],[6510,6636,"You think this would make me jealous?"],[6696,6882,"You know, if Louis wasn't a man,"],[6882,7062,"I would've never married you."],[7062,7122,"Okay."],[7122,7312,"I'm hanging up now."]],"12":[[260,391,"So,"],[391,650,"you're really hiding the affair from your husband."],[676,830,"I'm not hiding anything."],[900,1000,"We signed the divorce papers"],[1000,1180,"the day we got married."],[1220,1360,"He's not into women."],[1376,1486,"He's into men,"],[1580,1660,"like you."],[1686,1790,"He's into men?"],[1800,1930,"Yeah, so don't be surprised"],[1932,2076,"if he ends up coming after you next."],[2300,2380,"Not a shot."],[2766,2906,"Be gentle."],[3372,3510,"So you like it gentle."],[3546,3826,"I just mean, not the neck."],[3886,4052,"I have a charity event tomorrow."]],"13":[[260,402,"Where's your girlfriend?"],[402,602,"You don't get to worry about her."],[602,780,"You can just worry about yourself, sweetheart."],[792,970,"I'm not worried about her."],[1250,1466,"Why did you wear a scarf to a charity event?"],[1466,1652,"That is none of your concern."],[1920,2080,"Fiona, look at you."],[2080,2232,"You look great."],[2232,2306,"Mom."],[2590,2852,"Seems like you two are making progress."],[2912,3080,"Let's not talk about this tonight."],[3080,3206,"Mom, it's about the charity."],[3252,3402,"Really? Why can't we?"],[3410,3630,"Your dad is not doing well lately,"],[3640,3830,"and if you don't bring a kid,"],[3842,4030,"your half-brother will get everything."],[4140,4300,"This charity event is meant to"],[4310,4470,"hook up with the Gambino family,"],[4486,4692,"and you better to help your father tonight."],[4692,4830,"He will appreciate it."],[4910,5206,"Don't worry, the Sterling's fortune is safe."],[5230,5420,"They won't end up in that bastard's hands."],[5486,5566,"Hope so."],[5646,5746,"Okay, Don is coming."],[5746,5872,"I have to prepare something."],[6086,6266,"Who in the Gambino family is worth"],[6266,6412,"all this effort from Dad?"],[6460,6570,"Some big shot."],[6610,6742,"They call him the Don."],[6830,7142,"But no one's really seen him before."],[7160,7280,"Maybe tonight's the night."]],"14":[[20,170,"You're dressed very plain today."],[170,312,"Trying to keep a low profile?"],[486,746,"Exactly, it might be your family."],[756,942,"Look, I need to find out exactly"],[942,1096,"who we are dealing with."],[1136,1392,"So tonight, I'm just your assistant."],[1472,1552,"Yes, Boss."],[1646,1739,"Cut the act."],[1739,1836,"Let go of me."],[1880,1960,"Gladly."],[2650,2692,"Henry."],[2692,2772,"Baby."],[2796,2916,"What are you doing here?"],[2920,3120,"If my father sees us, we're ruined."],[3126,3232,"Relax, okay?"],[3232,3446,"I came in tonight as someone else's date."],[3500,3590,"No one's gonna"],[3660,3856,"suspect anything about us."],[3992,4082,"Louis,"],[4106,4370,"why do you look like more of a woman than I do?"],[4376,4460,"Watch your mouth."],[4520,4568,"Please,"],[4568,4796,"don't act like you're some Mother Teresa."],[4816,4940,"Don't you have a man as well?"],[4940,5256,"The only difference is I'm the one paying him,"],[5260,5452,"not the one being paid."],[5452,5636,"That's enough, you too."],[5880,6050,"And a word to the wise,"],[6092,6272,"next time you leave the house,"],[6272,6470,"you might wanna check the mirror."],[6500,6646,"I said that's enough."],[6820,6890,"Bitch."]],"15":[[16,96,"Fiona."],[276,416,"Go inside and mingle."],[430,622,"Keep an eye out for me and I'll be right back."],[3610,3840,"Right under his father's nose."],[3840,4036,"Guess he's not worried about embarrassing"],[4036,4206,"the Sterling family."],[5420,5600,"What a small world!"]],"16":[[160,296,"What are you doing here?"],[296,360,"What?"],[422,522,"Can I not be here?"],[550,662,"You should go."],[1022,1176,"There you go, gorgeous."],[1432,1556,"Let me light that for you."],[2290,2390,"You should go."],[2456,2536,"Now."],[2576,2702,"Fine by me."],[2702,2850,"But smoking kills."],[2870,2982,"You know, if your lips crave something,"],[2982,3142,"I am happy to help."],[3576,3666,"Oh."],[3706,3990,"So the son of the Sterling family is your husband."],[4020,4280,"You should leave. Go."],[4280,4360,"I mean,"],[4442,4530,"by the looks of it,"],[4530,4772,"doesn't seem like it's his first time kissing a man."],[4800,5030,"I mean, you've tasted me before."],[5052,5250,"Why the hell would you be with that guy?"],[6790,6920,"Feeling something stiff?"],[6980,7200,"This is not the place for that."],[7322,7452,"What are you talking about?"],[7600,7720,"I'm in, derailing."],[7790,8010,"You're from the infamous Sterling family."],[8030,8092,"Why?"],[8146,8350,"Are you scared now?"],[8512,8680,"I'm not the one who should be scared."],[9502,9596,"Henry, look."],[9602,9692,"What?"],[9742,9822,"Look!"],[9840,9920,"What is it?"]],"17":[[2,72,"What?"],[72,146,"Look!"],[192,266,"What is it?"],[266,392,"I think I saw Fiona with a man."],[470,540,"You kidding?"],[716,816,"She's with a man?"],[956,1082,"Even if she's with a man,"],[1082,1246,"she can't be outside the party."],[1296,1446,"Whe was even smirking at me."],[2340,2516,"The Don is arriving any moment."],[2516,2651,"Where the hell are you?"],[2651,2786,"Get back here now."],[4162,4300,"She's not answering her phone."],[4360,4546,"The charity gala is very important."],[4566,4650,"Where's she gone?"],[4650,4756,"God. I've told you."],[4976,5112,"Come on, we have to go."],[5460,5602,"Licking my hand?"],[5632,5732,"what are you?"],[5732,5822,"A dog?"],[5842,5956,"I'm your dog."],[6106,6260,"Well, I have to go"],[6292,6562,"impress the Sterling family's big shot."],[6682,6836,"So you better behave yourself,"],[6860,6986,"and we'll catch up later."],[7540,7696,"Why impress others"],[7716,7842,"when you can impress me?"],[7862,8202,"Be good and find us a better place to meet."]],"18":[[560,640,"Don,"],[690,1002,"are you seriously falling for my brother's wife?"],[1222,1406,"Your parents didn't disappear with them."],[1406,1536,"You have to pay it all."],[1606,1700,"This house"],[1700,2006,"is the last thing my parents left me before they died."],[2010,2116,"If you take it from me,"],[2146,2346,"then I will die with them."],[2356,2402,"You?"],[2402,2602,"You're just a kid. How could you?"],[2626,2756,"Give me three days,"],[2770,3056,"and I promise I will pay everything back."],[3786,3886,"Do you need a hand?"],[4960,5156,"I won't be attending tonight's event."],[5170,5316,"I need you to..."],[5682,5760,"I understand."]],"19":[[550,656,"You didn't answer your phone."],[656,756,"Why are you late?"],[763,826,"Don't you know that"],[826,972,"Don's coming here tonight?"],[980,1072,"That's funny,"],[1096,1190,"coming from a man"],[1190,1370,"who was making out with his secretary"],[1370,1490,"in the garden."],[1500,1726,"You're in no position to lecture me."],[2620,2856,"Welcome to you all."],[3960,4010,"Mom."],[4010,4219,"I think my dress is caught in the chair."],[4219,4324,"Would you mind checking it for me?"],[4324,4481,"Let me check it for you."],[5176,5280,"What's wrong?"],[5474,5532,"It's okay."],[5532,5730,"—What? Let me check. Is it- —No, no, no."],[5730,5886,"Your dress is absolutely fine."],[5886,6046,"It's absolutely fine, yeah."],[6230,6362,"My, my, my."]],"20":[[12,290,"Such a shame I have to disturb this"],[290,402,"touching moment."],[552,806,"Jeff, what are you doing here?"],[942,1040,"Father."],[1142,1252,"Let me show you something."],[1272,1382,"You, stop!"],[1510,1620,"Look at you son"],[1620,1732,"you're so proud of."],[1872,1980,"What's wrong, Father?"],[2012,2072,"Get out!"],[2180,2376,"The Don's having something..."],[2412,2602,"The Sterling family is"],[2626,2960,"pushing the charity dinner back two weeks."],[2960,3272,"I will send cars to bring all of you home."],[3272,3346,"Henry,"],[3346,3722,"can I see you in my study please, with Fiona?"],[4926,5132,"You're an absolute disgrace."],[5132,5331,"How on earth did the Sterling family"],[5331,5412,"wind up with a"],[5412,5572,"fuckup like you?"]],"21":[[40,172,"Dad, what's going on?"],[336,550,"Dad, what happened?"],[676,756,"And you."],[760,890,"You dare ask?"],[1030,1308,"You dare pull this filth thing"],[1308,1476,"in front of the Don himself?"],[1672,1820,"And on the day of the most"],[1820,2156,"important Sterling family banquet of the year."],[2252,2340,"Honey,"],[2352,2436,"this is why"],[2436,2730,"you've been clocking in long hours at the office?"],[2732,3192,"You've been fraternizing with your secretary Louis!"],[3456,3730,"The Gambino family controls everything now."],[3732,3953,"How can the Sterling family"],[3953,4246,"expand their media empire now?"],[4340,4420,"Henry,"],[4506,4646,"I'm disappointed in you."],[4772,5232,"And Fiona, is this how you control your husband?"],[5232,5390,"I didn't know he was..."],[5576,5680,"gay!"],[6352,6472,"Bring him in."]],"22":[[182,350,"Henry, please, help me."],[370,437,"Please!"],[437,512,"Dad."],[970,1160,"You filthy little slut."],[1200,1340,"You shut your damn mouth."],[1402,1650,"You ruined my son!"],[1790,1970,"All of that ends today."],[2080,2172,"Get off of him."],[2436,2496,"Louis,"],[2530,2610,"you okay?"],[2726,2926,"You forced me to marry Fiona,"],[2942,3280,"and the only one I ever truly loved was Louis!"],[3546,3830,"Are you trying to destroy the Sterlings?"],[3870,4066,"You, kneel along with him!"],[4150,4422,"Everything I've ever done is for the Sterling family."],[4440,4572,"But loving Louis,"],[4572,4742,"that's a personal choice."],[4742,4932,"Why can't you understand that?"],[4962,5146,"You would cut off ties with him,"],[5162,5282,"immediately."],[5390,5546,"You go home with Fiona,"],[5580,5732,"and you give me a grandson."],[5762,5810,"Dad,"],[5870,5996,"you're losing your mind!"],[6060,6136,"I'm leaving."],[6312,6480,"Henry, wait!"],[6560,6722,"Don't leave!"]],"23":[[22,102,"You okay?"],[166,246,"I'm so sorry."],[522,624,"Wow."],[656,952,"Looks like the Don really has an eye for drama."],[952,1202,"You didn't even miss out on your little slut show."],[1206,1286,"The Don?"],[1376,1526,"I know this is your doing."],[1540,1746,"If you think you can get between Louis and me,"],[1746,1872,"you have another thing coming."],[1892,2100,"I know you're trying to pull some tricks,"],[2146,2296,"and I'm not gonna fall for you."],[2436,2552,"You better not."],[2580,2776,"You're nothing, but dirty."],[3262,3342,"Fiona."],[3536,3616,"Where is Henry?"],[3846,4046,"They said they went to a hotel."],[4046,4200,"Fiona, what's wrong with you?"],[4246,4376,"You have a face and body,"],[4376,4480,"and with me helping,"],[4480,4692,"now you still lost to a guy."],[4692,4842,"I can't believe it!"],[4862,4936,"Maybe..."],[4982,5146,"Maybe Henry's just..."],[5192,5312,"not into women."],[5536,5616,"God..."],[5949,6042,"Okay, sweetheart."],[6042,6160,"We have a deal, right?"],[6186,6350,"Once you give Henry a child,"],[6366,6696,"your debts to the Sterling family are clear."],[6752,6806,"So,"],[6838,6925,"just go for it."],[6925,7116,"Just work a little harder for it."],[7146,7242,"You're right, Mom."],[7322,7472,"I just need to have a baby."],[7480,7553,"Okay."],[7553,7648,"That's the spirit."],[7648,7776,"I'll get right on that."],[7952,8050,"That's the spirit."],[8100,8180,"I like it."]],"24":[[250,450,"Did you find the better place yet?"],[470,550,"Damn right."],[630,712,"Right here."],[832,1066,"By \"better place\", you mean in my"],[1066,1210,"husband's dining room?"],[1222,1302,"What?"],[1366,1462,"Are you afraid?"],[1482,1722,"I'm not afraid of anything."],[2262,2426,"So you better work hard tonight."],[4042,4226,"Stop, that's enough."],[4302,4446,"Stop what?"],[4510,4632,"You have three minutes to get up."],[4632,4812,"What are you doing here?"],[4852,5016,"Louis was hurt because of you."],[5016,5206,"So I'm taking him to Philly to relax,"],[5210,5310,"and you're our cover."],[5322,5436,"Yeah, no."],[5470,5772,"The prenup says I have to appease your parents."],[5782,6026,"So what is Louis, your dad?"],[6226,6352,"50,000 a day."],[6610,6792,"50,000 an hour."],[7130,7210,"Deal?"],[7410,7490,"Deal."],[7592,7892,"For the money, it'll be just like walking a dog."]],"25":[[1616,1680,"What?"],[1712,1862,"It's only been a few hours."],[1906,2010,"Miss me already?"],[2026,2216,"I'm not that addicted to you."],[2252,2320,"Yeah,"],[2330,2550,"I'm going into town, just wanted to let you know."],[2580,2750,"I'll call you when I get back."],[3442,3516,"Don."],[3516,3720,"Morgan from Philadelphia wants to see you."],[3742,3896,"Your family's auction, they need you."],[3976,4116,"Set it up but keep it short."],[4210,4356,"I'm not in for a long stay."],[4456,4540,"Yes, Boss."],[4780,5020,"Thanks Louis for inviting us."],[5026,5170,"Yeah, I've never ever been in"],[5170,5322,"Philadelphia before."],[5322,5616,"You're the best sister we girls could have."],[5652,5960,"Well, you should thank Henry."],[5986,6246,"He planned this whole trip just to make me happy."],[6250,6476,"Anything for my true love."],[6506,6750,"Alright, let's get going."],[6750,6996,"Don't forget I'm being paid by the hour."],[7002,7186,"50 grand an hour."],[7350,7496,"50 grand an hour?"]],"26":[[42,176,"50 grand an hour?"],[176,384,"Yeah, he might love you,"],[384,622,"but his wallet sure does love me,"],