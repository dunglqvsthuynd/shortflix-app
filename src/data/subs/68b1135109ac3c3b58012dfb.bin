u're brilliant, sharp."],[5664,5840,"Yet, too innocent."],[5858,5960,"That foolish debt"],[5960,6084,"has stolen four years"],[6084,6184,"of your life."],[6184,6352,"What exactly do you mean by that?"]],"68":[[156,248,"Drink up, darling."],[304,416,"There is more to say."],[428,596,"Heidi, that's enough."],[1100,1167,"Are you trying to"],[1167,1256,"get her drunk?"],[1472,1556,"If I really could"],[1556,1644,"get her drunk,"],[1672,1785,"wouldn't that just make"],[1785,1944,"things easier for you?"],[1952,1996,"William,"],[1996,2136,"what are you doing here?"],[2168,2292,"Wait, you didn't"],[2320,2496,"know who he was?"],[2600,2804,"I thought he was just an escort"],[2804,2912,"that you got for me."],[2980,3080,"No!"],[3104,3180,"I assumed you didn't"],[3180,3284,"get any of them."],[3516,3576,"Don."],[3728,3796,"Don?"],[3930,4022,"Yes."],[4076,4276,"Don from Gambino family."],[4412,4576,"I have to go."],[4748,4868,"Okay, you two talk,"],[4868,4992,"and I'll be like"],[5036,5128,"anywhere right here."],[5176,5248,"Bye."],[5628,5688,"Where do you think"],[5688,5748,"you're going?"],[5788,5864,"Miss me?"],[6148,6228,"No, I..."],[6312,6448,"I didn't miss you."],[6548,6648,"But I miss you."]],"69":[[44,148,"But I miss you."],[524,616,"Vivi said that"],[616,764,"you wanted to buy my shares,"],[764,868,"and since you've already"],[868,940,"acquired Daya Quant,"],[940,1092,"I guess that makes sense, so..."],[1120,1208,"I'm willing to sell them"],[1208,1332,"at five hundred million."],[1388,1500,"You give me the money,"],[1576,1684,"I'll give you the shares."],[1880,1984,"Market is a product"],[1984,2172,"of social relations."],[2180,2264,"Without Sterling"],[2264,2332,"behind you,"],[2496,2560,"these shares mean"],[2560,2628,"nothing to me."],[2696,2760,"You're loaded."],[2836,2936,"Five hundred million"],[2936,3084,"is pocket change for you."],[3196,3244,"No,"],[3336,3412,"I won't do it."],[3488,3640,"What do you want then?"],[3780,3852,"I want"],[4072,4188,"you to call me Don."],[4248,4316,"Fine."],[4400,4460,"Don."],[4564,4619,"Are you gonna"],[4619,4776,"buy my shares or what?"],[5344,5412,"You lied."],[5580,5720,"You lied again."],[5820,5944,"I won't buy the shares,"],[6100,6172,"but you..."],[6320,6408,"I want you."]],"70":[[484,600,"Has five hundred million"],[600,716,"dollars on it."],[716,772,"I wanna pay for"],[772,904,"five months of your time."],[988,1044,"Please."],[1316,1436,"Just give me a chance."],[1584,1692,"What are you saying?"],[1820,1939,"You think you can buy me"],[1939,2040,"with your money?"],[2044,2148,"No, my love."],[2224,2280,"No."],[2320,2404,"Daya Quant's future"],[2404,2496,"is boundless."],[2620,2752,"It's gonna help you earn more."],[2844,2912,"But you..."],[3124,3220,"I want you."],[3364,3448,"Look, you're smart."],[3612,3671,"I know you wouldn't"],[3671,3760,"sell it so soon"],[3760,3883,"if it wasn't necessary."],[3964,4080,"Just give me a chance."],[4232,4352,"A chance to love you."],[4556,4640,"What are you doing?"],[4752,4964,"Why are you doing this?"],[5012,5076,"Please,"],[5160,5268,"don't cry, baby."],[5524,5632,"Don't cry anymore."],[5884,6064,"Why did you lie to me?"],[6092,6200,"Why are you being"],[6200,6320,"so nice to me?"],[6356,6500,"Because I wasn't sure."],[6520,6603,"Because I didn't want to"],[6603,6672,"be a burden"],[6672,6750,"if I wasn't sure of"],[6750,6852,"your true feelings."],[6940,7000,"Okay?"]],"71":[[54,132,"You love me."],[296,396,"Look, you lied too."],[456,508,"Right?"],[756,844,"But now, we're clear."],[2336,2408,"Don't cry."],[2492,2600,"Don't cry anymore."],[2870,2918,"You know..."],[3220,3320,"What if I'm not Don?"],[3580,3740,"What if I'm just a paid escort?"],[3936,4004,"Then I would be"],[4004,4152,"foolish enough to sell"],[4152,4284,"all of my shares,"],[4336,4460,"spend my money on you"],[4460,4556,"until I have none."],[4654,4722,"Then I'd be-"],[5616,5744,"Gabe and his stupid ass son"],[5744,5832,"are waiting in the hall."],[5928,5976,"There's something"],[5976,6056,"I wanna show you."],[6132,6168,"Ready?"]],"72":[[23,110,"Don."],[110,208,"I'm sure that"],[208,345,"Jeff has already told you"],[345,568,"about the predicament"],[580,808,"that the Sterling family is in."],[828,956,"Yes, he has."],[1100,1210,"And what exactly do you"],[1210,1340,"expect me to do about it?"],[1372,1588,"Well, I was hoping that"],[1592,1796,"on behalf of the Gambino family,"],[1820,2028,"you could show the Sterlings a way out."],[2148,2228,"Alright, then."],[2732,2860,"But I did hear"],[2924,3075,"the Sterling family is"],[3075,3140,"on the top of"],[3140,3240,"the business game."],[3320,3416,"I'm curious."],[3528,3641,"Tell me, how exactly"],[3641,3752,"did you make that happen?"],[3856,3972,"Four years ago..."],[4096,4192,"if you want to talk about"],[4192,4308,"real power,"],[4316,4420,"you've got to talk"],[4420,4556,"about the legendary"],[4556,4676,"Shaw family."],[4676,4756,"Exactly."],[4804,4972,"My father schemed for years"],[4976,5172,"to acquire all their holdings, and..."],[5224,5348,"That's how we rose to power."],[5636,5710,"I don't like to"],[5710,5816,"brag about my business"],[5816,5916,"in front of the Don."],[5968,6052,"You'll have to forgive"],[6052,6164,"my son Henry here."],[6188,6327,"He likes to embarrass"],[6327,6476,"his father in public."],[6596,6692,"You know, I also heard"],[6692,6784,"Henry's wife"],[6816,6881,"is the daughter of"],[6881,6984,"the Shaw family."]],"73":[[0,72,"Well."],[136,328,"Fiona showed her talents"],[328,436,"for business"],[436,552,"from a young age."],[632,916,"Ever since the Shaw family collapsed,"],[984,1172,"I decided to have Fiona"],[1172,1284,"and Henry engaged."],[1300,1428,"Well, that's impressive."],[1600,1725,"I've always been"],[1725,1892,"so successful in business."],[1948,2060,"Except for one thing,"],[2120,2240,"my son, Henry,"],[2268,2448,"a complete and total"],[2448,2540,"embarrassment."],[2652,2748,"That's why"],[2748,2860,"I was completely shocked"],[2860,3020,"when you decided to"],[3020,3156,"make my overlooked"],[3156,3240,"eldest son"],[3256,3404,"the Don's right-hand man."],[3432,3500,"Really?"],[3612,3680,"You know, I think"],[3680,3772,"you misplayed"],[3772,3880,"one more move."],[4088,4168,"What do you mean?"],[4232,4364,"You failed to realize"],[4364,4488,"Fiona isn't just"],[4488,4644,"a kind, naive girl."],[5040,5112,"What are you doing here?"],[5112,5232,"You're not allowed to be here."],[5232,5360,"Don't touch me!"],[5564,5644,"You-"],[5740,5820,"You heard everything?"],[5924,6040,"For four years,"],[6040,6232,"your family bound me"],[6232,6384,"with fake kindness."],[6412,6560,"I worked like a fool."]],"74":[[256,340,"Fiona."],[360,549,"The Don is right here."],[664,712,"What are you"],[712,800,"talking about?"],[872,952,"It's cold here."],[1160,1232,"It's cold."],[1304,1348,"Don?"],[1448,1520,"What-"],[1612,1756,"What exactly"],[1788,1888,"is the nature of your"],[1888,2052,"relationship with Fiona?"],[2112,2240,"I have her back."],[2880,2940,"You-"],[3048,3204,"You are that sleazeball?!"],[3252,3448,"Henry, shut up!"],[3632,3688,"Fiona,"],[3724,3770,"they know you're a"],[3770,3920,"gold-digging bitch."],[3940,4016,"Shut up!"],[4280,4372,"Can't you see?"],[4412,4572,"You're so interested"],[4572,4652,"in the rise"],[4652,4792,"of the Sterling family."],[4812,4932,"You've been telling Fiona"],[4932,5068,"everything from the start."],[5640,5742,"Four years of truth"],[5742,5848,"has been uncovered."],[6016,6085,"I don't think your marriage"],[6085,6224,"is gonna last any longer."],[6276,6340,"Gabe."],[6504,6616,"Get your son to sign it."]],"75":[[76,152,"Impossible."],[276,318,"There's no way"],[318,404,"I'm gonna sign that,"],[404,528,"even if it kills me."],[532,576,"Fine."],[732,814,"Then wait until"],[814,902,"the Sterling business"],[902,972,"falls overnight."],[1020,1144,"Then come and beg me."],[1292,1356,"Heidi."],[1444,1572,"Show them the way out."],[1816,1896,"If he signs it,"],[1900,2015,"will you show