"]],"39":[[722,830,"Don, are you okay?"],[920,1080,"Not a word about tonight."],[1116,1228,"Not to anyone."],[1228,1336,"Are we clear?"],[1350,1450,"Yes, sir."],[1622,1702,"Don,"],[1702,1912,"are we gonna keep her in the dark, forever?"],[1922,2132,"If she knew, she'd leave me."],[3740,3872,"Where's that sleazeball?"],[3916,4126,"That's none of your damn business."],[4126,4342,"You know, to tell you the truth,"],[4402,4610,"it was me who called the police last night."],[4672,4942,"Until you apologize to Louis..."],[4956,5036,"Yeah."],[5070,5140,"I'm waiting."],[5186,5312,"You're not going anywhere."],[5332,5642,"Well, then I guess we're gonna be here for a very"],[5672,5890,"long time."],[5996,6182,"—You little —Face it, Henry."],[6212,6376,"Before I even touched another man,"],[6376,6580,"you had been through a small army."],[6600,6816,"How dare you compare yourself to me?"],[6822,6950,"Why all the anger?"],[6962,7096,"Are you jealous?"],[7100,7332,"Do you wanna sleep with me now, too?"],[7510,7670,"I wanna sleep with you?"],[7692,7850,"I feel nothing for you."],[7932,8192,"And until you apologize to me and Louis,"],[8242,8376,"I'm not bailing you out."],[8422,8572,"And what if I just don't?"]],"40":[[212,330,"Oh, Fiona."],[642,820,"Looks like you have a rough time."],[830,940,"Take some coffee."],[1106,1386,"We already sorted it out and you are free now."],[1850,1942,"Is this how you"],[1942,2160,"run the Philadelphia Police Department?"],[2160,2282,"They should be imprisoned!"],[2290,2380,"What prison?"],[2380,2612,"We already made sure they are truly in love."],[2742,2926,"You two, get out now."],[3030,3212,"What are you two still doing here?"],[4086,4217,"Sweetie, did you just see her smug face?"],[4217,4332,"Enough!"],[4332,4462,"Stop annoying me."],[4530,4686,"And why are you angry at me?"],[5226,5460,"Did he really manage to seduce her?"],[5566,6020,"Oh yes, she is gorgeous."],[6020,6100,"You?"],[6180,6260,"What?"],[6346,6460,"Are you jealous?"],[6470,6712,"