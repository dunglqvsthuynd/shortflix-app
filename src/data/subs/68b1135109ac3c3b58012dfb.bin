1056,"one of the city's biggest names."],[1106,1230,"Thanks, Louis."],[1232,1436,"We really got a chance to see the world."],[1470,1546,"Of course."],[1596,1676,"You know me."],[2046,2170,"Oh, poor thing."],[2180,2346,"Henry never gave you a thing, huh?"],[2386,2730,"Oh, how about I fix that today? For him."],[2746,2982,"Henry may not have given me any gifts,"],[2982,3130,"but his money..."],[3130,3276,"I got plenty of it."],[3401,3916,"Oh no, I feel so terrible..."],[3916,4132,"You have Henry's love and"],[4136,4592,"I have nothing but his cold hard cash."],[4745,4874,"Alright, alright."],[4874,5000,"Don't be upset."],[5270,5350,"Don,"],[5370,5752,"this mall's annual sales exceeded 30 billion dollars."],[5806,5956,"Its peak daily revenue reaches-"],[5956,6036,"Wait a minute."],[6100,6260,"Fiona, stop talking."],[6292,6392,"I'm not paying you by your words."],[6562,6660,"Shh."],[6736,7072,"Oh baby, can I get my friends each a bag?"],[7140,7220,"Please."],[7236,7356,"Thanks, Louis."],[7356,7530,"You're so sweet."],[7530,7706,"Yes, of course."],[7716,7916,"Anything you guys want, it's on the house."],[7916,8066,"Thank you, Henry. Thank you."],[8340,8452,"Anything for my babe."],[8766,8976,"Oh, and you're not included, okay?"],[8976,9272,"Remember, you are here to carry our bags."],[9610,9770,"I need you to do something for me."]],"29":[[396,556,"What are you looking at?"],[630,801,"You are just Louis's shopping"],[801,910,"tag-along."],[956,1072,"This is not your scene."],[1292,1566,"If you can't afford it, don't touch it."],[1566,1972,"You'll smash it and I won't even want it."],[2370,2496,"Could you keep an eye on her?"],[2496,2652,"She's a bit crazy,"],[2690,2826,"and she's botherless."],[2848,2914,"Please."],[3110,3350,"Miss, if you're not going to buy anything,"],[3350,3532,"please don't touch the products."],[4206,4312,"Oh my God."],[4556,4660,"Henry, baby."],[4830,4992,"This pink one is so elegant."],[5056,5216,"It looks like it was just made for me."],[5676,59