o, these belong"],[6656,6785,"to Ronan Osufo,"],[6785,6923,"captain of the Howler's hockey team"],[6923,7107,"over at Crescent College?"],[7107,7236,"A colleague who works with that"],[7236,7353,"team sent it."],[7353,7578,"It's identical to Enzo's sample."],[8646,8742,"It's the Lupo Virus,"],[8742,8808,"all over again."]],"39":[[79,125,"Stop!"],[125,221,"Who the fuck are you?"],[241,296,"Enzo!"],[342,379,"Lisa!"],[379,408,"Not now!"],[408,496,"I don't have time!"],[496,550,"No, no, no."],[550,588,"Please."],[588,746,"Why did you break up with me over"],[746,809,"text?"],[809,900,"Is it because of the threat?"],[900,984,"Because I didn't mean that."],[984,1038,"I was bluffing."],[1038,1080,"I'm sorry."],[1080,1209,"I shouldn't have said that, right?"],[1209,1238,"Fuck!"],[1238,1451,"Lisa, leave me the hell alone!"],[1451,1693,"Our farce of a relationship is over,"],[1693,1780,"okay?"],[1780,1951,"Is this because of Nina?"],[1951,2039,"Because I can change."],[2039,2102,"I can look like her."],[2102,2135,"I can get,"],[2135,2202,"I can get braids."],[2202,2302,"I can wear glasses. I can,"],[2302,2406,"I can pass a class or two."],[2406,2452,"I promise"],[2452,2515,"I'll do anything."],[2515,2640,"There's nothing"],[2640,2811,"you can do."],[2823,2932,"You..."],[2932,3078,"You're just"],[3078,3157,"not her,"],[3290,3378,"okay?"],[3378,3545,"No, I love you."],[3574,3745,"I love you!"],[3753,3828,"I love you!"],[3828,3978,"I promise I do."],[3978,4083,"Lisa, stop."],[4083,4137,"Please."],[4237,4320,"Please, no."],[4320,4446,"Please."]],"40":[[125,287,"I love you, I promise I do."],[454,658,"Please..."],[658,700,"Nina!"],[779,959,"Nina!"],[2544,2740,"You want me to help you synthesize an"],[2740,2961,"antidote for the Lupo Virus, that"],[2961,3207,"I haven't even heard of before today?"],[3207,3307,"That's exactly what I want."],[3361,3536,"I need a fresh set of eyes on my formulas"],[3536,3649,"if I'm going to find a cure."],[3674,3916,"I don't know that I can do this."],[3916,4062,"I chose you"],[4062,4200,"for this internship"],[4200,4408,"because all signs point to you being a genius."],[4446,4550,"Prove it,"],[4550,4650,"and I'll talk to your professors"],[4650,4729,"about your grades."],[4892,4988,"The Lupo Virus"],[4988,5171,"is mysterious,"],[5184,5276,"presenting as skewed"],[5276,5476,"biomarkers, hyper strength,"],[5518,5697,"and elevated aggression."],[7223,7332,"I need to get some sleep"],[7332,7524,"and put this fucked up day behind me."],[8308,8445,"You stole my boyfriend, you tramp!"],[8921,9100,"Run, Nina. Now!"],[9100,9275,"Something's not right!"],[9480,9630,"I am going to"],[9630,9830,"finish you, once and for all."],[9830,9993,"Enzo is mine!"]],"41":[[483,642,"Who are you?"],[650,759,"It's nice to finally"],[759,917,"meet you in person, Nina."],[934,1042,"I am Cora."],[1105,1267,"Cora?"],[1276,1438,"You look just like me."],[1463,1626,"Because I am you..."],[1672,1818,"or the part of you that was born"],[1818,1976,"when you lost your virginity."],[2027,2189,"I am your wolf."],[2298,2460,"Am I a werewolf, too?"],[2460,2581,"Yes and no."],[2652,2840,"You are a human and a wolf."],[2886,3048,"The best of both worlds."],[3065,3224,"A hybrid."],[3257,3407,"A hybrid?"],[3532,3561,"Wait, you're"],[3561,3607,"the one who's"],[3607,3720,"been talking to me!"],[3745,3841,"And protecting you"],[3841,3999,"when I can."],[4074,4108,"Give us"],[4108,4291,"a kiss, pretty girl."],[4295,4458,"No, get off me!"],[4617,4696,"Oh!"],[5388,5543,"Nina, you need to wake up."],[5543,5647,"You're in danger!"]],"42":[[104,183,"Ah, you got to be kidding me."],[183,250,"Lisa, stop!"],[250,667,"No, no, no, no, no!"],[675,742,"Grab Lisa."],[742,846,"Stop!"],[846,988,"No!"],[988,1096,"That's not fair!"],[1096,1247,"You were mine!"],[1301,1459,"I hate you!"],[1493,1584,"A rogue bite."],[1584,1730,"That must be why Lisa has been"],[1730,1881,"crazier than usual."],[1881,1985,"Get off me!"],[2143,2310,"If Lisa's going to jail,"],[2310,2623,"we have to be the ones who get her out."],[4133,4241,"How are you feeling?"],[4333,4408,"I'm okay."],[4491,4587,"Feel a little out of it,"],[4587,4708,"but I'm just"],[4708,4833,"happy to be home."],[4900,5063,"Did you watch over me all night?"],[5092,5117,"I mean,"],[5117,5288,"it was the least I could do after everything"],[5288,5438,"you went through."],[5593,5759,"I cannot believe that your girlfriend"],[5759,5901,"tried to kill me,"],[5901,6001,"twice."],[6206,6314,"She's in jail,"],[6314,6481,"and she's not going to be able to harm you"],[6481,6569,"anymore."],[6569,6723,"Also, she's"],[6723,6810,"not my girlfriend."],[6865,7019,"But I saw you two kissing?"],[7082,7278,"Well, she took a page out of Justin's book"],[7278,7411,"and forced herself upon me."],[7449,7607,"I broke up with her"],[7607,7728,"the night that I saved you from"],[7728,7836,"that creep at the club."],[7966,8066,"She's taking it well."],[8437,8562,"Thank you, Enzo."],[8629,8704,"For what?"],[8804,8958,"For always being there for me."],[9104,9259,"I guess that's a plus"],[9351,9471,"for having a werewolf"],[9471,9584,"as a boyfriend."],[9709,9876,"I'll always know how to find you."],[9909,10018,"What did you just say?"],[10247,10347,"I said,"],[10493,10643,"how about we make things official?"]],"43":[[129,258,"Don't look so shocked."],[258,546,"I mean, it's obvious that I'm into you."],[613,754,"Are you"],[754,817,"into me?"],[1013,1113,"If I wasn't,"],[1113,1297,"I'd be running right now."],[1297,1359,"You are"],[1359,1547,"all drama, Enzo."],[1551,1680,"Okay."],[1680,1826,"You are too."],[1931,2122,"I guess,"],[2139,2281,"we're meant"],[2281,2473,"for each other?"],[3578,3695,"Wait, wait, wait, wait, wait."],[3699,3933,"No, you said that sex could kill me..."],[3933,4045,"if I wasn't your..."],[4045,4233,"Your fated mate?"],[4279,4421,"What does that even mean?"],[4533,4704,"It's the person that the Goddess Luna"],[4704,4938,"declares a werewolf's forever love."],[4954,5142,"It's a feeling,"],[5401,5588,"in here."],[5626,5839,"You're all I think about, Nina."],[5885,5993,"And I know that you're"],[5993,6181,"my fated mate."],[6181,6385,"But there's a risk, and I understand"],[6385,6573,"if that's..."],[6844,6952,"I'm willing to take that risk"],[6952,7048,"for you, Enzo."],[8842,8958,"I'm so sorry,"],[9000,9121,"but I have to do this."]],"44":[[83,321,"I am about to risk my life here for you,"],[321,450,"and you're just going to leave?"],[633,792,"Pack business."],[792,942,"Dating a werewolf isn't all perks."],[2556,2615,"I came as soon"],[2615,2723,"as I heard you bailed her out."],[2748,2827,"Thank you."],[2844,2982,"You were right. Rogue bites."],[2982,3161,"Unlike anything I've ever seen."],[3165,3311,"Edward's trying to put her in a trance"],[3311,3440,"so we can get some info."],[3495,3611,"You bastard!"],[3620,3699,"Let me go!"],[3712,3895,"Is this how you get your rocks off?"],[3908,4083,"Tying up innocent girls and put them"],[4083,4233,"under your spell?"],[4266,4454,"I didn't know Edward work for us."],[4471,4579,"Full Moon pack has eyes and"],[4579,4679,"ears everywhere."],[4708,4863,"Edward is instrumental in keeping"],[4863,5063,"our existence under wraps."],[5150,5326,"You can try to resist me,"],[5326,5447,"but it's pointless."],[5505,5718,"You will give in to the sound of my voice."],[5864,5968,"Your eyes are"],[5968,6151,"feeling very heavy."],[6297,6485,"Let go."],[7057,7236,"Damn, he is good."],[7236,7415,"Got her."],[7499,7711,"Lisa, who bit you?"],[7832,8049,"One of the Sister's soldiers."],[8179,8333,"Who is the Sister?"],[8475,8646,"The one that wants to cross from"],[8646,8825,"the Lycan World to ours."],[9121,9330,"Do you have anything else to tell us?"],[10264,10422,"What are you doing?"],[10422,10552,"It's a sedative."],[10552,10731,"Just until they can cure her."],[11482,11644,"Edward worked on Nina."],[11678,11820,"She was confused about the things"],[11820,11949,"she was seeing."],[12020,12195,"So Edward wiped her memory."],[12195,12399,"But it always came back."],[12479,12687,"Even more proof she's not a normal human."],[12775,13021,"If Dalton of the Raven pack was her father..."],[13108,13221,"It won't matter."],[13325,13513,"She's not my son's fated mate."]],"45":[[50,120,"Dad?"],[187,246,"I thought you weren't"],[246,316,"supposed to come home"],[316,437,"until next month!"],[437,608,"I came home early."],[621,771,"There's an issue that has arisen"],[771,942,"that needs my attention."],[980,1146,"What issue?"],[1146,1309,"Edward, get rid of the girl."],[1405,1651,"My son and I need this room."],[1651,1830,"Lewis, go get our surprise."],[2293,2423,"Dad, if you're about to start in"],[2423,2548,"on the whole fated mate thing,"],[2548,2623,"save it."],[2623,2748,"I already found her."],[2790,2952,"How could you have met her?"],[2952,3174,"Your fated mate was handpicked by the"],[3174,3278,"Goddess Luna,"],[3307,3536,"and resides in the Lycan Realm."],[3586,3666,"The Lycan Realm?"],[3666,3745,"Dad! No!"],[3745,3816,"Enough!"],[3995,4112,"You've done enough damage."],[4112,4262,"I've seen pictures of you,"],[4262,4437,"gallivanting around with that human."],[4525,4754,"Your carelessness almost cost us"],[4754,4867,"everything."],[4913,5150,"I, I don't understand."],[5442,5622,"Thank God you have me here to"],[5622,5730,"clean up your messes."],[6126,6281,"It was Ronan?"],[6306,6364,"You were the one"],[6364,6544,"that was stalking us the entire time?"],[6623,6890,"He's out to destabilize us in this world"],[6890,7111,"so the Crescent pack can take over."],[7111,7286,"You gave him all the ammunition"],[7286,7436,"he needs."],[7436,7632,"Dad, if you would just meet Nina."],[7632,7686,"Talk to her."],[7699,7816,"Shut up, Enzo!"],[7924,8237,"You and these floozies are souring our name."],[9317,9496,"Your fated mate, Selena, is making"],[9496,9713,"arrangements to come to the human world."],[9776,9947,"And when she does,"],[9997,10089,"you're gonna marry her."]],"46":[[675,788,"What are you doing here?"],[788,942,"I thought you had pack business."],[1117,1226,"It can wait."],[1334,1534,"All I can think about"],[1584,1785,"is having you again."],[2035,2235,"Can I"],[2235,2352,"have you again?"],[2448,2648,"Yes, you can."],[6131,6293,"Are you sure about this?"],[6322,6414,"I am sure."],[7282,7394,"Nina!"],[7394,7582,"Oh God, Nina! No!"],[7620,7691,"No!"],[8049,8266,"God, no chill,"],[8266,8466,"even in my dreams."],[9501,9609,"It's a quarter 'til."],[9609,9738,"If I go now,"],[9738,9922,"I might make it."],[9939,10139,"But I'm not going alone."],[10343,10422,"Haven't you had enough"],[10422,10618,"adventure already, Nina?"],[10635,10794,"Like, you've been attacked"],[10794,10848,"more times"],[10848,10973,"than a scream queen."],[10973,11169,"Like, if I were you, I would"],[11169,11240,"never go out."],[11240,11348,"Like, ever."],[11361,11440,"Shh..."],[11469,11553,"I think I see somebody."]],"47":[[79,179,"James?"],[179,358,"You're K?"],[367,417,"Yeah."],[417,596,"For my last name, Korbel?"],[821,900,"Oh!"],[900,1067,"Wait, you two know each other?"],[1067,1201,"We work together."],[1251,1363,"Oh, good."],[1363,1447,"Well, at least you know"],[1447,1551,"you're not going to get killed"],[1551,1730,"by someone, right?"],[1780,1872,"What?"],[1872,1989,"Of course not."],[2027,2097,"Well,"],[2097,2248,"I'm going to bed, Nina."],[2248,2464,"Just call me if you need anything."],[2748,2911,"So, you prowl"],[2911,3090,"around werewolf forums?"],[3090,3278,"A hobby of mine."],[3278,3411,"But there's something you need to see."],[3616,3778,"We better do this quick."],[4091,4245,"This is the man who drugged me."],[4446,4625,"Enzo did this."],[4642,4704,"He's dangerous."],[4704,4838,"You have to stay away from him."],[4838,4934,"No, Enzo didn't do that."],[4934,4996,"He would never."],[4996,5150,"You saw the test results."],[5150,5234,"He's a werewolf."],[5234,5397,"They kill for sport!"],[5397,5530,"Or did he not share that tidbit with you"],[5530,5647,"while you were fucking him?"],[5897,6064,"I'm sorry, James, I don't know"],[6064,6197,"my own strength sometimes."],[6197,6343,"It's okay."],[6343,6431,"I understand this is"],[6431,6581,"a lot to take in about Enzo,"],[6581,6760,"but, Tiffany has proof."],[6794,6952,"She's waiting for us in the infirmary."],[7073,7194,"Where are you going?"],[7194,7261,"A shortcut."],[7261,7436,"Come on. She's waiting."],[7628,7811,"James,"],[7891,8083,"isn't the infirmary that way?"],[8141,8333,"Nina? I don't like this."],[8379,8445,"Run!"]],"48":[[0,133,"Cora, if you're real,"],[133,241,"help me!"],[241,500,"No, no, no."],[921,1013,"Stop fighting,"],[1013,1059,"bitch!"],[1059,1267,"It'll be over faster if you just relax!"],[1313,1484,"Nina, don't give up!"],[1514,1651,"Fight him off!"],[2006,2093,"I can't."],[2093,2122,"I can't."],[2122,2323,"I'm still sore from my fight with Lisa."],[2323,2527,"My, my head hurts."],[2811,2948,"Sister,"],[2948,3048,"I've brought you your link to"],[3048,3148,"the human world"],[3148,3278,"and our deal is done."],[3620,3787,"Grant me the power."],[3820,3962,"Make me into a werewolf."],[3999,4079,"Nina,"],[4079,4341,"you have to dig deep and knock him out"],[4341,4600,"before the portal to the Lycan World opens."],[4679,4846,"Come to us, Sister."],[4846,5017,"Come to us!"]],"49":[[204,383,"Enzo!"],[392,596,"Enzo, are you in here?"],[596,700,"Please."],[1593,1693,"I went to your dorm,"],[1693,1814,"and they told me that you were here."],[1814,1885,"I just..."],[1885,2031,"I really needed to see you."],[2031,2089,"Young lady,"],[2089,2214,"surely you have someone that you"],[2214,2352,"can harrass at this hour?"],[2352,2439,"I am so sorry."],[2439,2590,"You must be Enzo's father."],[2590,2761,"I'm, I'm Nina."],[2819,2915,"It's nice to meet you."],[3007,3148,"Enzo,"],[3148,3303,"calm this girl down and send her"],[3303,3407,"on her way."],[3595,3757,"We have an important business meeting"],[3757,3820,"this morning."],[3899,3966,"You alright?"],[3966,4049,"I don't know, I,"],[4058,4154,"I just thought,"],[4154,4316,"you know, you're my boyfriend."],[4316,4421,"And I was really scared,"],[4421,4512,"so..."],[4592,4758,"About that..."],[4758,4867,"I'm sorry, Nina."],[4963,5096,"But we can't"],[5096,5150,"be together."],[5263,5397,"What?"],[5397,5513,"What are you saying?"],[5638,5793,"I'm saying"],[5793,5943,"that you're not"],[5943,6047,"my fated mate."],[6306,6539,"So for your safety and mine,"],[6539,6681,"we have to go our separate ways."],[6681,6752,"I'm sorry."],[6752,6890,"I can't believe you."],[6931,7098,"Can I at least call you a car?"],[7098,7186,"No!"],[7186,7273,"No, fuck you."],[7273,7469,"I don't need anything from you."],[7536,7649,"Don't ever speak to me."],[7649,7686,"Don't,"],[7686,7786,"don't come save me."],[7786,7987,"Don't even look at me, okay?"],[7987,8078,"I hate you."]],"50":[[450,688,"I'm glad we're in agreement"],[688,859,"that this can be resolved"],[909,1059,"without violence..."],[1059,1222,"unlike in the past."],[1584,1755,"We aren't savages."],[1764,1935,"Werewolves have come a long way."],[1972,2106,"We can resolve our issues"],[2106,2218,"without"],[2218,2298,"bloodshed."],[2389,2552,"It's true that the Crescents favor"],[2552,2686,"stalking these days."],[2686,2857,"My son did what he had to do."],[2890,3090,"It's time the Crescents have their place"],[3090,3261,"as the Alpha in the human world."],[3307,3474,"We're more suited for it."],[3486,3653,"We can live without"],[3678,3774,"frolicking"],[3774,3945,"with the lowly humans."],[4066,4275,"My son cut those attachments."],[4341,4512,"He also has an idea on"],[4558,4729,"how to resolve this rift"],[4758,4917,"between the Crescents"],[4917,5088,"and the Full Moon."],[5313,5522,"I'm willing to take that risk for you, Enzo."],[5822,5947,"Enzo?"],[5947,6114,"Enzo."],[6139,6310,"Are you listening?"],[6348,6464,"Bet he's too busy thinking"],[6464,6619,"about his nerdy human."],[6681,6852,"She's not my type, but,"],[7123,7248,"I wouldn't kick her out of bed."],[8650,8821,"Stop it!"],[10372,10531,"Enzo,"],[10531,10635,"don't let the enemy"],[10635,10806,"know that they've got you shaken."],[10852,11023,"Now pull yourself together."],[11023,11123,"Take the lead."],[11853,12012,"Ronan and I will face off in the"],[12012,12149,"Ice Reign hockey tournament."],[12216,12399,"And I propose that the winner takes home"],[12399,12570,"more than the championship cup."],[12575,12708,"So,"],[12708,12892,"if the Howler's win,"],[12892,13096,"we get to take our place"],[13184,13484,"as the pack Alphas in the human world?"],[13513,13684,"And the loser..."],[13788,13909,"Well,"],[13909,14047,"the loser"],[14047,14176,"takes his pack"],[14176,14381,"back to the Lycan Realm"],[14381,14639,"and agrees to never step foot"],[14639,14793,"on this human world"],[14793,14914,"ever again."]],"51":[[4,166,"The bitter rivalry between"],[166,283,"the Bayside Howlers"],[283,400,"and the Mountainview Fangs"],[400,696,"comes to a head today in game one of three"],[696,859,"in the Ice Reign Tournament."],[859,992,"You're going down this time."],[992,1030,"You don't got"],[1030,1197,"blackmail on your side anymore."],[1197,1288,"It's not my fault you didn't have"],[1288,1430,"the guts to call my bluff."],[3136,3211,"Enzo!"],[3357,3524,"Enzo Rivers misses a sweet pass,"],[3524,3757,"giving up control of the puck to the Howlers."],[3757,3928,"I have to keep my head in the game."],[3928,4041,"I just wish I could"],[4041,4191,"talk to Nina and explain"],[4216,4358,"that I didn't have a choice."],[4425,4554,"Don't ever speak to me."],[4554,4692,"Don't come save me."],[4692,4863,"Don't even look at me, okay?"],[4892,5034,"I hate you."],[5075,5184,"That can't be"],[5184,5342,"how things end with us."],[5392,5530,"There's still so much"],[5530,5647,"we didn't get to say."],[5651,5705,"Enzo!"],[5755,5872,"Get your head in the game"],[5872,5964,"or I will bench your ass!"],[7553,7741,"The Howlers win game one of the"],[7741,7803,"tournament."],[7820,8078,"The Fangs must win the next two to"],[8078,8254,"bring home the cup!"],[9605,9747,"Nina, watch out!"]],"52":[[0,150,"What the fuck?"],[258,358,"It is infected!"],[358,475,"It's got the Lupo Virus, Nina!"],[917,1021,"Help!"],[1172,1238,"Nina!"],[1301,1426,"Please get off!"],[1551,1685,"Get off me!"],[1780,1826,"Stop!"],[2064,2214,"Oh my god, no!"],[2494,2669,"You've got to fight, Nina."],[2669,2748,"The Sister,"],[2748,2857,"whoever she is,"],[2857,2973,"is getting desperate"],[2973,3094,"and throwing everything"],[3094,3165,"she has at you."],[3253,3365,"Oh my..."],[3745,3895,"Oh my gosh."],[3999,4129,"What is happening?"],[4149,4212,"My god."],[4416,4450,"No!"],[4967,5096,"No! No!"],[5213,5271,"Lori."],[5271,5380,"Jessica."],[5497,5576,"Where am I?"],[5930,6026,"Did I do that to you?"],[6026,6089,"Oh my God!"],[6089,6147,"Oh my God!"],[6147,6277,"Oh my God, you're bleeding."],[6277,6368,"We have to get you to the infirmary."],[6368,6435,"What's going on?"],[6435,6556,"Nina, are you okay?"],[6556,6706,"Stay away from me, Enzo."],[6706,6856,"I can take care of myself."],[6856,7027,"Nina, you need my help"],[7027,7236,"fighting these things."],[7236,7369,"These rogues are working for"],[7369,7515,"someone called the Sister."],[7528,7603,"What do you know about"],[7603,7678,"the Sister?"],[7716,7820,"We don't have time for this."],[7820,7974,"Nina, we have to disinfect your wounds."],[7974,8095,"No, if you want to help me,"],[8095,8245,"get Jessica and Lori."],[8245,8320,"No, Nina,"],[8320,8470,"they're infected!"],[8571,8779,"No, I think I know how to cure them."],[8779,8871,"Come on. Hey."],[9205,9355,"Please."],[9734,9793,"I got her!"]],"53":[[175,291,"Nina, are you sure?"],[291,479,"There's only one way to find out."],[479,608,"Please do it."],[871,950,"If you're wrong..."],[950,1076,"I'm not."],[1076,1247,"Tell us again what you remembered."],[1247,1405,"I was walking to class,"],[1405,1647,"and then this crazy person just came"],[1647,1810,"out of the darkness and bit me."],[1810,2085,"And the next thing I knew when I woke up,"],[2085,2268,"I had your blood in my mouth,"],[2268,2444,"and I was just lying on the ground."],[2515,2656,"My blood cured him."],[2656,2919,"Tiffany, your notes on a possible antidote"],[2919,3132,"suggested destabilizing the virus."],[3132,3365,"I think my blood can do that."],[3365,3453,"We have to try."],[3553,3661,"Here goes nothing."],[5063,5150,"Is everyone all right?"],[5176,5280,"We rounded up and subdued"],[5280,5388,"the other rogues."],[5388,5538,"We brought Lisa too, for the cure."],[5547,5689,"Is that why Lisa has been so"],[5689,5772,"out of her mind?"],[5868,6035,"Are rogues the same as werewolves?"],[6189,6364,"Not quite."],[6364,6506,"Werewolves are descendants of an"],[6506,6623,"ancient werewolf pack."],[6648,6852,"Rogues aren't descendants."],[6852,7023,"They're victims of werewolf bites"],[7023,7136,"that have been untreated."],[7257,7365,"The Lupo Virus."],[7365,7557,"Cora says I'm a hybrid."],[7557,7786,"But there are rogues and pure werewolves"],[7786,7987,"descended from ancient packs?"],[7987,8179,"This is so much to process."],[8241,8408,"How do you know all of this?"],[8646,8883,"Wait, is Tiffany a werewolf?"]],"54":[[4,154,"Oh my god."],[154,358,"Oh, what have I done?"],[1401,1551,"Did the Fangs win?"],[2202,2323,"I better get this antidote to the rest"],[2323,2452,"of the infected."],[2786,2969,"If any of you are having difficulty"],[2969,3178,"processing tonight's attack, or if you just"],[3178,3303,"don't feel like yourself,"],[3328,3436,"please come see me."],[3436,3636,"My office is always open."],[3661,3795,"My wolf Cora said that Edward"],[3795,3962,"could be dangerous."],[4037,4208,"She was just being overprotective"],[4208,4379,"like any good wolf guide should be."],[4475,4546,"How's the arm?"],[4567,4688,"It's okay."],[4746,4879,"Hurts a little bit."],[4879,5067,"I guess it's too bad I'm just a hybrid."],[5100,5234,"If I was a pure werewolf like you,"],[5234,5313,"I'd be healed already."],[5392,5492,"And James."],[5555,5647,"He called a few days ago"],[5647,5780,"and said he was going away for a while."],[5851,5968,"Now I know why."],[6060,6214,"I called the cops and informed them that"],[6214,6293,"he was dangerous."],[6539,6635,"A werewolf groupie?"],[6760,6869,"I thought I knew him."],[6869,7019,"I'm learning that people are rarely"],[7019,7157,"who or what they say to be."],[7248,7411,"Yeah. Tell me about it."],[7528,7686,"And,"],[7686,7816,"good job on finding a cure for the"],[7816,7987,"Lupo Virus, by the way."],[7991,8174,"You more than earned that extra credit."],[9392,9563,"Just leave me alone, Enzo"],[9647,9788,"I just want to make sure you're okay."],[9955,10181,"You dumped me hours after we"],[10181,10268,"made it official."],[10281,10431,"You don't give a shit about me."],[10477,10627,"That's not true, Nina."],[10664,10773,"Hey, at least let me take you back"],[10773,10844,"to your dorm."],[10844,10969,"It's not safe out here."],[10969,11127,"Especially with that Sister out here..."],[11165,11344,"Just go, Enzo!"],[11419,11565,"I'm not some weak human."],[11603,11836,"I'm a hybrid. I can take care of myself."]],"55":[[346,408,"You know,"],[408,579,"hockey is the one thing I can"],[579,704,"count on you to do well."],[721,825,"And you blew it."],[867,1026,"Don't fuck this up."],[1034,1180,"I can't run our companies from"],[1180,1301,"the Lycan Realm."],[1301,1434,"I'll be ruined."],[1459,1572,"I'll win the next two games,"],[1572,1735,"I won't let you down."],[1789,1910,"See that you don't."],[2035,2118,"Wait."],[2118,2218,"You're staying away from that"],[2218,2348,"human girl, right?"],[2369,2523,"I don't want to hear it."],[2523,2719,"Selena isn't my fated mate."],[2748,2840,"Nina is!"],[2877,3090,"And she's not human, she's hybrid."],[3144,3357,"She's a daughter of a Raven Alpha!"],[3382,3486,"Not sanctioned"],[3486,3645,"by the goddess Luna."],[3661,3824,"You know, I did some digging."],[3837,3962,"Nina is a bastard."],[4066,4250,"Dalton's illegitimate daughter"],[4250,4371,"from some witch."],[4408,4579,"Unfitting for our bloodline."],[4579,4838,"I don't care about any of that."],[4879,5092,"All I want is Nina."],[5209,5367,"And nothing will ever"],[5367,5434,"change that."],[6331,6464,"What do you think, sis?"],[6506,6644,"Do I look the part?"],[6677,6835,"Sis?"],[6915,7048,"Are you my twin sister?"],[7123,7203,"Twin?"],[7203,7361,"Oh, please."],[7432,7657,"I'm a few days older and much"],[7657,7774,"hotter than you."],[7774,8033,"But we are nearly identical, which is why"],[8033,8283,"my plan will work perfectly."],[8495,8658,"What plan?"],[8967,9025,"My plan"],[9025,9196,"to take your place in the human world,"],[9196,9355,"of course."],[9371,9588,"Your witch mother imprisoned me"],[9588,9755,"here in the Lycan World,"],[9755,9968,"so I could never enter the human world"],[9968,10097,"while you were there."],[10151,10322,"But now you're not."],[10322,10464,"Welcome home, Nina!"],[10581,10781,"My mother was a witch?"],[10781,10981,"I guess she took that secret to her grave."],[11052,11219,"Why would my mother curse you?"],[11273,11428,"Ours mothers were in love with the same"],[11428,11574,"man and hated each other."],[11574,11724,"Simple as that."],[11724,12087,"What matters is I'm finally going to go"],[12087,12303,"to the human world and snag that"],[12303,12725,"tasty Alpha and live happily ever after."],[12829,12983,"No, no, this won't work."],[12983,13175,"Enzo is my fated mate!"],[13175,13371,"He'll come after me."]],"56":[[91,187,"Listen up, boys."],[187,396,"It was a solid win last game."],[396,500,"One more win,"],[500,592,"and the cup is ours."],[675,754,"Get out there and"],[754,867,"make it happen."],[900,1017,"And get the puck to Enzo."],[1017,1113,"He's on fire tonight."],[3107,3228,"Your time is over, Rivers."],[3253,3428,"It's the Crescent pack's time now."],[3495,3599,"He's trying to kill me."],[3599,3820,"Not sure what Ronan is doing but it looks"],[3820,4070,"dangerous and the refs don't like it."],[4813,4896,"And that's it."],[4896,5096,"The Fangs win the cup!"],[6823,6936,"Wow, Nina."],[7023,7269,"You actually look happy to see me."],[7269,7457,"That's because I am."]],"57":[[479,579,"Blonde?"],[579,638,"Really?"],[638,750,"You don't like it?"],[750,975,"No. Not that I don't like it."],[975,1201,"It's, it's just, it's different, you know."],[1472,1614,"You smell different."],[1614,1826,"I just don't remember you wearing"],[1826,1935,"perfume before."],[2002,2156,"I needed a change."],[2610,2781,"I'm also surprised that you even"],[2877,3044,"wanted to come over here and talk to me."],[3094,3261,"Last time we spoke..."],[3349,3520,"You were quite angry."],[3691,3912,"I guess I got over it."],[4304,4567,"I'm gonna tell my dad that I want you,"],[4567,4642,"Nina."],[4696,4875,"Not Selena."],[4904,5155,"I don't care if he disowns me."],[5467,5597,"Enzo."],[5597,5697,"Great day today,"],[5697,5772,"son."],[5830,6035,"That heathen Ronan and his father,"],[6035,6114,"and their"],[6114,6389,"Crescent minions are in the Lycan Realm,"],[6389,6473,"where they belong."],[6523,6681,"Thank you, dad."],[6681,6806,"Good riddance."],[6806,6898,"Oh, and,"],[6898,7007,"I see that you and Selena are"],[7007,7115,"still getting along great!"],[7273,7349,"Selena?"]],"58":[[33,233,"I was going to tell you, Enzo."],[233,287,"When?"],[287,442,"After we fucked?"],[442,542,"Sure."],[621,679,"What?"],[679,809,"What's going on here?"],[809,900,"Dad."],[900,1055,"She's pretending to be Nina."],[1055,1309,"This imposter is my fated mate?"],[1363,1514,"Yes."],[1514,1626,"The goddess"],[1626,1768,"showed me,"],[1768,1901,"spoke to me,"],[1901,2081,"like she has for her faithful,"],[2081,2252,"for centuries."],[2256,2414,"Selena is yours."],[2535,2761,"She spoke to me too, Richard."],[2761,2944,"And I am so happy"],[2944,3098,"to be your new daughter-in-law."],[3140,3257,"Fuck this."],[3257,3378,"I'm going to see Nina."],[3774,3970,"No, no, you can't."],[4008,4129,"Don't go."],[4129,4300,"Get the fuck out of my way, liar!"],[4458,4608,"I am better"],[4608,4683,"than Nina."],[4683,4850,"No, you're not."],[4859,5000,"You may look like her,"],[5034,5180,"but Nina is smart."],[5234,5405,"Nina is fierce."],[5447,5576,"Nina is beautiful."],[5576,5743,"She is one of a kind."],[5851,5947,"Well,"],[5947,6139,"you're never going to find her."],[6231,6302,"She's probably"],[6302,6389,"dead by now."]],"59":[[229,304,"Where is she?"],[304,454,"What did you do to her?"],[454,608,"Only what she deserved."],[625,813,"Her mother imprisoned me"],[813,925,"in the Lycan World."],[925,1051,"Nina had the life that"],[1051,1217,"was supposed to be mine!"],[1230,1401,"She stole you from me."],[1401,1576,"She deserves to die!"],[1605,1714,"Wait a minute."],[1714,1914,"I didn't want that girl harmed?"],[2106,2185,"Where is she?"],[2185,2344,"You better not touch a single"],[2344,2510,"goddamn hair on her head."],[2548,2748,"She's in the Lycan Realm."],[2969,3140,"What are you doing here?"],[3157,3311,"You owe me!"],[3311,3432,"I did everything you asked and now"],[3432,3570,"the cops are after me, and I have to hide"],[3570,3741,"out like some kind of fugitive?"],[3741,3916,"I want my reward."],[3958,4104,"Get the fuck out!"],[4104,4270,"I am done with you."],[4487,4654,"Make me into a werewolf,"],[4654,4817,"or I'll kill you."],[4817,4942,"And not into one of those"],[4942,5046,"deranged rogues."],[5050,5284,"A full, pure blood werewolf."],[5330,5488,"That can never happen."],[5518,5734,"You are not of the bloodline."],[5734,6014,"I cannot make you a true werewolf,"],[6014,6093,"you idiot!"],[6660,6781,"No!"],[6781,6940,"No, no, no, no, no, no!"],[7924,8174,"How am I supposed to ever find Nina?"]],"60":[[813,984,"I'll help you find her, son."],[992,1126,"I promise."],[2056,2206,"Let's go."],[2631,2773,"Nina!"],[2961,3082,"Nina!"],[3328,3445,"This is hopeless, dad."],[3445,3474,"We've been"],[3474,3645,"searching for an hour!"],[3653,3887,"You know, if truly she's your fated mate,"],[3887,4091,"let the Goddess Luna guide you."],[5634,5734,"Nina."],[5893,6010,"This way."],[6460,6510,"Nina."],[6627,6706,"Nina!"],[8279,8450,"You came for me?"],[8546,8712,"Of course I came for you."],[8833,8942,"I love you,"],[8942,9017,"Nina."],[9084,9280,"I love you too, Enzo."],[9864,9997,"Let's go."],[9997,10130,"Let's get you home."]],"61":[[442,746,"So, how does it feel to be a hybrid?"],[834,1159,"Feels exactly the same as being human,"],[1159,1384,"except I can open jars of pickles a lot"],[1384,1534,"easier, and"],[1534,1630,"I have a friend in my head."],[1943,2072,"Enough talking."],[2143,2302,"I have some other ideas."],[2752,2790,"Are you..."],[2790,2923,"Are you sure?"],[2923,3178,"I mean, it's been like a week since we"],[3178,3290,"rescued you and everything"],[3290,3395,"that you went through."],[3395,3595,"I have waited long enough."],[3595,3728,"It's time."],[3941,3991,"Well,"],[4120,4179,"what if..."],[4179,4341,"What if you die?"],[4341,4450,"What if something goes wrong?"],[4450,4604,"What if..."],[4604,4750,"What if we break the rule and"],[4750,4779,"you-"],[4867,4996,"Do you trust me?"],[5572,5751,"Do you want me?"],[5759,5889,"Yeah."],[5926,6060,"Then have me."],[9188,9330,"Oh, thank god you're alive."],[9517,9747,"So alive, my fated mate."],[10710,10823,"I have one more rule."],[10898,11027,"What?"],[11090,11340,"I am so sick of your rules,"],[11340,11419,"Enzo Rivers."],[11519,11594,"I'm serious."],[11745,11924,"New rule"],[11936,12116,"is no more sex."],[12370,12550,"Until..."],[12871,13050,"Marry me."],[13100,13213,"I will."],[13213,13367,"Oh my..."],[13688,13868,"I will."],[14280,14339,"Put it on?"],[14339,14451,"Yeah."]]}