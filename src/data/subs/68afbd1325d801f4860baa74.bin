{"1":[[1138,1292,"Tonight's the night."],[1292,1514,"I'm finally going to lose my virginity"],[1514,1597,"to Justin,"],[1626,1772,"my first love."],[1772,1939,"And he's going to tell everyone that"],[1939,2135,"we are officially dating."],[2135,2281,"Let's go, baby!"],[2373,2585,"Bro, shit, bro."],[2585,2748,"Now I gotta go change."],[2748,2911,"Be back in a second."],[4533,4679,"I wouldn't normally wear something"],[4679,4746,"like this,"],[4746,4992,"but I hope Justin likes it."],[4992,5188,"I want tonight to be special."],[5651,5751,"Oh!"],[5751,5868,"Get out!"],[5897,6035,"Can't you see that we're busy?"],[6035,6231,"Justin, how could you do this to me?"],[6231,6348,"And in my room!"],[6348,6431,"This is your room?"],[6544,6635,"I thought it was Lauren-"],[6635,6760,"Lisa's."],[6831,6919,"Oops."],[7086,7215,"Oh, God."],[7486,7582,"Okay."],[7582,7724,"Get out, loser!"],[7724,7907,"Justin plays hockey,"],[7907,8078,"and you play the trombone."],[8212,8387,"He's out of your league."],[8387,8529,"Nina, Nina, let me explain."],[8529,8662,"No, fuck you, Justin."],[8662,8758,"We are done!"],[10618,10685,"Hey, wait."],[10685,10794,"Hold on, let me"],[10794,10965,"just double check something."],[11152,11273,"I don't think it's a good idea"],[11273,11411,"to go out there alone, Nina."],[11490,11699,"There is wolves on the prowl tonight."],[11699,11778,"Huh?"],[11778,11911,"How does the captain"],[11911,12003,"of the hockey team"],[12003,12141,"know my name?"]],"2":[[12,196,"What are you talking about, Enzo?"],[196,383,"Wolves? On campus?"],[383,558,"They're always around."],[558,663,"You just don't know it."],[663,779,"Yeah, well, I think I'd rather take"],[779,888,"my chances with the wolves"],[888,1030,"than stay here another second."],[1071,1146,"Yo, hold on."],[1242,1393,"Let me get you a beer."],[1422,1530,"Grab you a soda."],[1530,1672,"Anything you like."],[2331,2573,"Hey, are you okay?"],[2819,3078,"No, no, I just caught my boyfriend"],[3078,3215,"banging Lisa Sloane"],[3215,3453,"in my bed on my birthday."],[3453,3574,"Nina!"],[3749,3795,"You left these."],[3795,3924,"Justin, leave me alone!"],[3995,4104,"Look, everything that hap-"],[4104,4237,"She said"],[4237,4396,"leave her alone."],[4437,4587,"This is none of your business, all right?"],[4587,4804,"You're not the captain in my personal life."],[4804,5025,"No, but you stumbling around campus"],[5025,5159,"smashed ain’t a good look for the team,"],[5159,5230,"is it?"],[5342,5476,"Go home."],[5522,5651,"Sober up."],[5680,5801,"Or I'll bench your ass."],[6760,6906,"You really didn't have to do that."],[6906,7215,"Yeah, I did."],[7215,7319,"For the record,"],[7382,7553,"you are"],[7553,7795,"so much prettier than Lisa."],[7857,8016,"Are you flirting with me?"],[8016,8158,"I just broke up with my boyfriend."],[8158,8370,"When I want something,"],[8420,8521,"I go for it."],[8521,8579,"Yeah, I know."],[8579,8762,"You go for everything you want."],[8762,8896,"And you never sleep"],[8896,9038,"with the same girl twice."],[9196,9417,"So my reputation precedes me,"],[9417,9513,"I see."],[9513,9647,"And you act like it's a good thing"],[9647,9743,"to be known for that."],[9743,9922,"If I could change it, I would."],[9968,10101,"Put it this way."],[10114,10339,"All that practice"],[10339,10589,"could be put to good use."],[10652,10898,"Maybe he's just what I need right now."],[10898,11173,"A no-strings-attached hookup."],[11173,11340,"So, Nina,"],[11340,11507,"what's it going to be?"]],"3":[[892,1055,"I'm surprised all the campus gossip"],[1055,1126,"didn't scare off"],[1126,1313,"a good girl like you."],[1584,1772,"Who says I'm a good girl?"],[2081,2306,"Oh..."],[2385,2594,"Yeah, I know a good girl"],[2594,2723,"when I see one."],[2723,2952,"You don't know the first thing about me."],[2952,3069,"You haven't even spoken a word"],[3069,3169,"to me before tonight."],[3169,3386,"Biggest mistake I've ever made."],[3536,3716,"Something about your scent"],[3716,3933,"drives me crazy."],[3933,4175,"So,"],[4175,4400,"what is it, Nina,"],[4621,4775,"that made you"],[4775,5138,"want to hang out with me?"],[5138,5221,"Because you're"],[5221,5451,"Justin's captain."],[5451,5730,"And revenge tastes sweet."],[5730,5855,"And besides,"],[5855,5947,"all the girls"],[5947,6085,"always rave about"],[6085,6264,"how good you are in bed."],[6264,6427,"You're not into commitment."],[6427,6606,"So this won't get messy."],[6606,6785,"No love."],[6827,6986,"Just sex."],[6986,7244,"No strings attached."],[7574,7791,"Show me what all the fuss is about."],[7791,7903,"Oh, I knew you were"],[7903,8012,"hiding something delicious"],[8012,8153,"under that coat."],[9630,9909,"I... I want this, but"],[9909,10085,"you should know that I'm a virgin."],[10347,10543,"It's okay."],[10543,10681,"I'll take it slow."],[10681,10935,"I'll be gentle."],[10935,11119,"I'll make sure"],[11198,11457,"that you come first."],[11682,11840,"It'll be"],[11840,12020,"my birthday gift"],[12228,12399,"for you."],[14347,14568,"What's happening to me?"],[14656,14814,"I've heard about this feeling."],[14814,15023,"But it can't be, can it?"],[15515,15794,"Is Nina my fated mate?"],[16066,16128,"Hey."],[16128,16232,"You need to get out."],[16232,16341,"What's going on?"],[16341,16453,"Get out now!"]],"4":[[12,191,"I said get out!"],[437,604,"Wow."],[604,754,"You take cold blooded player"],[754,988,"to a whole new level, Enzo."],[988,1092,"You know what?"],[1092,1326,"You're actually just an asshole!"],[2544,2619,"Where were you?"],[2619,2811,"We missed you at the party last night."],[2811,2919,"Yeah, we asked Justin"],[2919,2982,"where you were."],[2982,3103,"And he"],[3103,3207,"didn't know."],[3207,3370,"Some boyfriend he is."],[3370,3586,"He's not my boyfriend anymore."],[3616,3891,"No, I don't want to talk about it."],[3924,3999,"Any news on your"],[3999,4129,"pre-med internship?"],[4129,4208,"No."],[4208,4291,"All the rich kids"],[4291,4425,"with connections got placed first,"],[4425,4483,"so,"],[4483,4658,"who knows where that leaves me."],[4658,4758,"Oh my God!"],[4758,4875,"Enzo's here!"],[5609,5668,"Oh my gosh."],[5668,5755,"I was so sad"],[5755,5989,"I didn't see him at the party last night."],[5989,6122,"He's such a delicious"],[6122,6285,"eye candy."],[6381,6493,"Oh my God, he's coming this way!"],[6493,6652,"Calm down, Jessica."],[6652,6719,"You're embarrassing"],[6719,6815,"yourself."],[6815,6902,"Morning, ladies."],[6902,7019,"Morning."],[7019,7257,"Are you ready for the game today?"],[7336,7515,"I'm ready."],[7528,7607,"Actually, I'm"],[7607,7720,"heading over for warm ups now."],[7720,7907,"But, Nina, I just"],[7907,8133,"wanted to apologize for last night."],[8170,8241,"About..."],[8241,8358,"about what?"]],"5":[[29,171,"Think fast, Nina."],[171,333,"I'm not ready to tell anybody"],[333,513,"what happened with Enzo last night."],[625,771,"Enzo stumbled onto me"],[771,867,"on the quad last night."],[867,946,"He..."],[946,1084,"stepped on my foot."],[1084,1263,"Really hurt."],[1263,1413,"Yeah, I was a"],[1413,1539,"real klutz."],[1539,1710,"Almost knocked her down."],[1747,1885,"But I'm sorry"],[1885,2031,"again, Nina."],[2118,2239,"Anyways,"],[2239,2419,"that's all I wanted."],[2481,2665,"Better get going."],[2973,3111,"Wow."],[3111,3215,"Did you guys see the way that he"],[3215,3378,"was looking at me?"],[3378,3507,"At you? No."],[3507,3703,"From what I saw, he was"],[3703,3949,"laser focused on Nina."],[3949,4012,"Seems like Enzo"],[4012,4179,"might have a little crush."],[4179,4304,"So what?"],[4304,4496,"I mean, Enzo changes girls"],[4496,4621,"like he changes underwear."],[4621,4792,"He's so not my type."],[4888,5063,"Enzo may be a player,"],[5063,5288,"but he's everyone's type."],[5367,5501,"Now, let's get to the rink."],[5501,5663,"I want to get good seats."],[5663,5780,"Good seats!"],[6406,6560,"Oh my God! Yay!"],[6560,6698,"He's back on the ice!"],[6902,6986,"Makes some noise!"],[6986,7090,"Let's go!"],[7090,7678,"Enzo!"],[8145,8295,"Yeah!"],[8295,8375,"Come on, Fangs!"],[8375,8454,"You got this!"],[9096,9167,"Watch out!"],[9167,9271,"Watch your back!"],[9918,10093,"Oh!"],[10093,10197,"Nice!"],[10360,10560,"I know we said no strings attached."],[10560,10668,"But Enzo was"],[10668,10839,"really good in bed."],[10839,11006,"Another round couldn't hurt."],[11061,11248,"Timeout on the ice with just"],[11248,11428,"over two minutes remaining."],[11428,11519,"Oh my gosh."],[11519,11657,"Fangs are in the lead!"],[11657,11728,"Nina!"],[11728,11882,"Why are you so low energy?"],[11882,12012,"Come on, this is exciting."],[12012,12099,"What are you talking about?"],[12099,12299,"I am so pumped."],[12399,12520,"Go Fangs!"],[13530,13621,"If you have sex"],[13621,13893,"with Enzo again, you could die!"]],"6":[[0,171,"Nina! What the hell?"],[171,350,"You spilled soda all over my boots!"],[350,442,"I'm so sorry, Lori. I-"],[442,533,"I don't know what happened."],[533,679,"It was an accident, I swear."],[696,813,"What was that voice?"],[813,1067,"Is it anxiety over losing my virginity"],[1067,1142,"last night,"],[1142,1288,"or am I so hungover that"],[1288,1388,"I’m hearing things?"],[2106,2281,"So, uh, are you ever going to tell us"],[2281,2394,"what happened with Justin?"],[2394,2548,"I caught him having sex with Lisa"],[2548,2635,"in my bedroom"],[2635,2819,"during the party, and..."],[2819,2961,"I couldn't get out of there fast enough"],[2961,3015,"after that."],[3015,3232,"Wait, in your room?"],[3232,3390,"On your fucking birthday?"],[3390,3474,"Yeah."],[3474,3582,"What a fucking asshole!"],[3582,3816,"I tried to tell you he was a piece of shit!"],[3816,4074,"Boo! Justin Thurlow sucks!"],[4074,4341,"Boo!"],[4341,4500,"Thank you guys. I'm really-"],[4500,4562,"I'm fine."],[4562,4783,"It's just... It wasn't meant to be,"],[4783,4913,"obviously."],[5030,5255,"Enzo! Enzo! Enzo!"],[6969,7182,"Yo! You coming to the Bonfire later?"],[7207,7365,"Gotta celebrate!"],[7365,7507,"Oh my gosh, yes!"],[7507,7724,"I'll totally be