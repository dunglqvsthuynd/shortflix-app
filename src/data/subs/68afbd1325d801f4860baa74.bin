her"],[5818,5922,"so that she can help him"],[5922,6022,"with his coursework."],[6022,6164,"I don't want to hear it."],[6164,6306,"You and I will never"],[6306,6443,"be anything more."],[6468,6635,"Get that through your head!"],[6898,7119,"I know who you are,"],[7119,7240,"okay?"],[7240,7386,"And I know"],[7386,7678,"that you can never love a human."],[7678,7857,"You'll only kill them."],[8850,8975,"So think about that!"]],"8":[[809,988,"Why do you keep defending her?"],[988,1138,"I don't want to hear it."],[1138,1288,"You and I will never"],[1288,1401,"be anything more!"],[1534,1605,"Enzo?"],[1605,1705,"Enzo?"],[1705,1793,"Since when did you cozy up"],[1793,1968,"to the captain?"],[1968,2077,"Oh..."],[2077,2243,"This is your..."],[2243,2352,"your revenge."],[2352,2535,"For the love of God, Justin,"],[2535,2656,"just leave me alone."],[2656,2852,"I made a mistake, okay?"],[2852,2923,"I was drunk,"],[2923,3073,"and I accidentally fucked Lisa."],[3098,3349,"You accidentally fucked Lisa?"],[3349,3507,"Do you even hear yourself?"],[3582,3649,"Stop!"],[3649,3757,"No!"],[3837,4016,"We're done when I say we're done."],[4016,4087,"Stop!"],[4087,4170,"Look, I'm the best thing"],[4170,4237,"that ever happened to you."],[4237,4341,"Don't you get that?"],[4341,4462,"You'll never get someone as good"],[4462,4600,"as me to pay attention to you."],[4600,4746,"You should count yourself lucky."],[4746,4946,"I noticed a nobody like you."],[5138,5317,"Get your hands off of her!"],[5651,5772,"Wait, Enzo's eyes..."],[5772,5839,"They're red."],[5839,5964,"Did I imagine that?"],[5964,6047,"I thought I told you"],[6047,6168,"never to touch her again!"],[6168,6243,"Let me go, man!"],[6243,6364,"What is wrong with you?"],[6364,6514,"What? Do you like Nina or something?"]],"9":[[0,183,"This isn't about me right now."],[183,275,"I'll show him what happens"],[275,396,"when he disrespects you."],[850,1059,"Stop him before he goes too far"],[1059,1230,"and drags you down with him."],[1230,1434,"Enzo's not what he seems."],[1434,1559,"This voice again!"],[1559,1626,"Who are you?"],[1626,1797,"And why are you in my head?"],[1797,1864,"There'll be time"],[1864,2010,"for introductions later."],[2010,2160,"You have to stop him now!"],[2293,2464,"Hey, Nina."],[2481,2627,"Should we teach him a lesson?"],[2627,2690,"Let me go, man."],[2690,2798,"I can't breathe."],[2798,2923,"Enzo, stop."],[3257,3399,"Now, Nina!"],[3499,3691,"Enzo, let him go."],[3691,3816,"He's not worth it."],[4183,4325,"You should thank your lucky stars"],[4325,4441,"Nina stopped me."],[4441,4604,"She just saved your sorry ass"],[4604,4758,"and your hockey season."],[4925,5075,"I said say thank you!"],[5075,5125,"Now!"],[5125,5292,"Th... Thank you, Nina."],[5292,5426,"Get out of here."],[5426,5580,"I'll see you at practice."],[5759,5885,"First I'm hearing voices,"],[5885,6093,"and now I'm seeing things?"],[6093,6247,"I'm sorry I lost control."],[6247,6343,"I just hate seeing him"],[6343,6452,"treat you that way."],[6452,6602,"That's okay."],[6602,6752,"Thank you for protecting me."],[7157,7294,"What did I tell you about"],[7294,7611,"pushing up on my man, skank?"],[7636,7836,"Play along and I won't tell her"],[7836,7995,"your real identity."],[8012,8078,"Damn it!"],[8078,8191,"What do I do..."],[8191,8425,"or maybe this is for the best."],[8466,8579,"Enzo?"],[8579,8858,"I asked Lisa to be my girlfriend."],[8867,9009,"He did."],[9009,9167,"He's mine."],[9167,9371,"And we belong together."],[9392,9609,"So stay away."],[9609,9776,"God, I'm so stupid."],[9776,9930,"Giving my virginity to Enzo"],[9930,10051,"of all people."],[10051,10130,"Let alone thinking"],[10130,10310,"he might actually like me."],[10314,10493,"You two deserve each other."]],"10":[[775,875,"How did you..."],[875,963,"Why are you here?"],[963,1096,"How did you even find me?"],[1096,1267,"I followed your scent."],[1267,1430,"Justin mentioned it to me once,"],[1430,1526,"that you work here."],[1526,1714,"You know, whatever. You need