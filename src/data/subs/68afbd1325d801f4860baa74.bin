?"]],"11":[[254,350,"Damn it!"],[350,508,"I can't. I'm sorry."],[583,746,"I can't break the rule."],[746,871,"I wish things were different."],[871,971,"But they're not."],[971,1030,"And you know what?"],[1030,1130,"Maybe that's for the best."],[1130,1242,"Just..."],[1242,1368,"just go, please."],[1368,1480,"Leave me alone."],[1518,1655,"I'll see you around campus."],[1655,1822,"No, not if I can help it."],[1822,1951,"Just go, please."],[1951,2106,"I have to get back to work."],[2202,2260,"Go!"],[2481,2740,"God, I have shit taste in men!"],[2740,2811,"Nina?"],[2811,2898,"What are you doing in here?"],[2898,3003,"We have customers."],[3003,3123,"I was just changing. I'm sorry."],[3123,3328,"I don't pay you to hide out in the locker room"],[3328,3470,"necking with your boyfriend!"],[3470,3607,"Necking?"],[3607,3737,"I'm his hardest worker,"],[3737,3937,"and he never gives me a break."],[3937,4004,"I would quit,"],[4004,4208,"but I need this job to pay for school."],[4208,4383,"Sorry, Phil, it won't happen again."],[4383,4521,"See that it doesn't."],[4575,4934,"Because next time, I'll have to punish you."],[5509,5718,"Oh, God."],[6619,6781,"Almost time to go."],[6781,6931,"Finally!"],[6944,7040,"Hey, girl!"],[7040,7115,"Hey."],[7115,7240,"Did you check your e-mail?"],[7286,7382,"The pre-med internship"],[7382,7565,"assignments are in."],[7874,7995,"Oh my gosh."],[7995,8195,"So? Where did they place you?"],[8195,8383,"This can't be for real. The..."],[8383,8550,"The medical support intern"],[8550,8712,"on the Fangs hockey team!"],[8712,8837,"Oh..."]],"12":[[346,571,"You must be my new intern, Nina."],[571,767,"I'm Dr. Tiffany Berry, your mentor."],[767,980,"Um, I actually wanted to talk"],[980,1067,"to you about something."],[1067,1230,"I really appreciate"],[1230,1330,"you agreeing to mentor me."],[1330,1434,"I just don't think"],[1434,1605,"that I'm going to be able to..."],[1605,1672,"Doctor Berry,"],[1672,1743,"there's a fight on the ice,"],[1743,1851,"and it's getting pretty bad."],[1851,1943,"We're going to need you."],[1943,2064,"Come on."],[2198,2252,"Come on, Nina."],[2252,2410,"Duty calls."],[3941,4116,"You're going to pay for that, Rivers."],[4116,4237,"Stand down, Ronan,"],[4237,4333,"before I put you down"],[4333,4441,"like the dog you are."],[4850,5050,"Yeah! Fuck him up! Woo!"],[5388,5618,"It almost looked like Ronan had claws..."],[5818,5939,"Hey."],[5939,6031,"Enzo!"],[6031,6143,"Are you okay?"],[6310,6431,"I am now."],[6681,6919,"Get Enzo to the infirmary!"],[7082,7169,"Okay, I'm gonna go grab some more"],[7169,7282,"bandages. Nina,"],[7282,7361,"disinfect his wounds."],[7361,7461,"Mm-hmm."],[8441,8587,"Um..."],[8587,8737,"This might sting a little bit."],[9722,9859,"What the hell?"]],"13":[[129,225,"Nina,"],[225,458,"I can explain."],[558,642,"Rivers."],[684,759,"You okay?"],[759,896,"Never better, Coach."],[896,1013,"Barely a scratch."],[1055,1188,"Good."],[1188,1313,"I need your help stopping the chaos"],[1313,1438,"on the ice."],[1438,1568,"The Fangs and the Howlers are at"],[1568,1672,"each other's throats."],[1672,1772,"I'm on it, Coach."],[1772,1956,"I'm coming!"],[2531,2656,"You okay, Nina?"],[2694,2844,"You look like you saw a ghost."],[2869,2932,"No,"],[2932,3069,"I'm not okay."],[3069,3215,"I think I need to talk to someone."],[3215,3482,"I'm hearing things, seeing things..."],[3482,3553,"Sorry, Dr. Berry."],[3553,3620,"I have to go."],[4554,4667,"I'm sorry, I..."],[4667,4808,"I don't have an appointment."],[4808,4879,"It's okay."],[4879,5017,"No appointment needed."],[5017,5075,"Have a seat."],[5075,5230,"Nina, is it?"],[5230,5338,"How do you know my name?"],[5338,5559,"It's my job to know my students."],[5739,5947,"Now, how can I help?"],[5989,6160,"Please don't think that I'm crazy."],[6160,6356,"I won't. I'm here to help."],[6356,6481,"Tell me what's been going on."],[6523,6723,"I've been..."],[6723,7007,"hearing a strange voice."],[7019,7248,"And I've been seeing really strange things..."],[7248,7303,"like..."],[7303,7553,"like wounds healing right before my eyes."],[7553,7816,"I mean, nothing is making any sense."],[7866,8078,"You know, stress can do"],[8078,8270,"crazy things to our minds."],[8270,8379,"It's..."],[8779,8950,"Nina, don't let him do this!"],[8950,9059,"Leave now!"],[9059,9242,"He can't be trusted!"]],"14":[[0,108,"It's happening again."],[108,237,"Please. Please help me."],[237,329,"Please make it stop."],[329,483,"What's the voice saying, Nina?"],[500,633,"Get out of there!"],[633,867,"Don't let him tamper with your mind!"],[867,1013,"It's telling me to leave."],[1013,1138,"I can help."],[1138,1276,"My methods have helped countless"],[1276,1443,"students through stress-related"],[1443,1564,"hallucinations."],[1564,1701,"It's 100% safe."],[1701,1785,"Would you like to try?"],[1785,1843,"Yes, please."],[1843,1989,"If you think it's going to help, anything,"],[1989,2039,"please."],[2039,2202,"Absolutely."],[2202,2414,"Look into the crystal and listen to the sound"],[2414,2569,"of my voice."],[2569,2898,"Your eyes are feeling very heavy..."],[2898,3119,"Your mind is clearing..."],[3319,3415,"Nina!"],[3486,3574,"Nina!"],[3745,3845,"Dr. Williams?"],[3845,4033,"Please, call me Edward."],[4033,4137,"How are you feeling?"],[4145,4295,"Still hearing those voices?"],[4295,4425,"Voices?"],[4425,4617,"I was hearing voices?"],[4617,4738,"Is that why I'm here?"],[4738,4909,"No. You were here because you needed"],[4909,5046,"help managing your course load."],[5046,5213,"And I gave you some techniques."],[5255,5513,"Thank you, Dr. Edward."],[5513,5655,"It's my pleasure, okay?"],[5655,5834,"Stop by any time you need to..."],[5834,5951,"talk."],[6564,6769,"Dr. Williams gives me the creeps."],[6769,6969,"Oh, he's not so bad."],[6969,7140,"I was really nervous about my internship"],[7140,7257,"placement, but"],[7269,7394,"now I feel better."],[7394,7486,"Good!"],[7486,7570,"Okay."],[7590,7732,"Cheers!"],[8245,8320,"Hey!"],[8320,8433,"You mind if I speak to Nina alone"],[8433,8504,"for a second?"],[9488,9630,"I don't want anything to do with you"],[9630,9730,"after what you did to me."],[9730,9901,"I know, but I still love you."],[9901,10114,"Please, take me back. I'm sorry."]],"15":[[784,888,"I should have known."],[888,1126,"I was nothing but a rebound."],[1126,1276,"Fuck this."],[1372,1501,"Where have you been?"],[1501,1685,"I've been looking for you everywhere."],[1685,1785,"Not now, Lisa."],[1785,1893,"Are you mad at me?"],[1893,2022,"Are you ignoring me?"],[2022,2097,"I sent you, like,"],[2097,2293,"a billion text messages."],[2293,2419,"Yeah, I know."],[2419,2552,"And I don't care."],[2552,2698,"You see, that's what happens"],[2698,2823,"when you blackmail"],[2823,2982,"someone into a relationship."],[2982,3194,"You better treat me right, Enzo,"],[3194,3328,"or I'm going to tell"],[3328,3524,"everyone your secret,"],[3595,3741,"that you blew that"],[3741,4049,"hockey tournament game last year,"],[4049,4275,"and your hockey career"],[4275,4425,"is going to be over."],[4425,4533,"Got it?"],[4533,4708,"I only threw the game so Ronan"],[4708,4788,"wouldn't tell everyone"],[4788,4900,"I'm a werewolf."],[4900,5050,"I've gotta go-"],[5050,5171,"practice early tomorrow."],[5171,5267,"I need sleep."],[5267,5338,"Well,"],[5338,5505,"I'm just looking for a little bit"],[5505,5684,"of attention, so..."],[6318,6493,"Now I really gotta go."],[6652,6823,"Asshole!"],[6823,6952,"You lost the right to do that!"],[6952,7044,"But don't you miss me?"],[7044,7173,"I miss you."],[7599,7811,"My arm! Fuck!"],[8024,8212,"You broke his arm,"],[8212,8299,"freak!"]],"16":[[0,75,"Oh my God."],[75,258,"I'm so sorry. I didn't mean to..."],[258,346,"Liar!"],[346,458,"You did this"],[458,588,"because he chose"],[588,746,"me over you!"],[746,846,"I didn't mean... I didn't..."],[846,1026,"She pushed him!"],[1051,1251,"She's a jealous,"],[1251,1343,"evil"],[1343,1463,"psycho!"],[1743,1868,"Nina, what gives?"],[1910,2031,"If he can't play in the game tomorrow"],[2031,2114,"because of you—"],[2210,2327,"Why won't everyone just"],[2327,2448,"leave me alone?"],[2656,2886,"So what if your ex is on the team?"],[2886,3028,"You can't quit the best internship"],[3028,3190,"in the program because of it."],[3190,3307,"Figure out a way to deal."],[3307,3457,"I wish it were that simple..."],[3457,3586,"Let me guess,"],[3586,3666,"you have a thing going on with"],[3666,3845,"Enzo Rivers, too?"],[3845,3933,"How did you..."],[3933,4049,"I saw the way you two looked at"],[4049,4170,"each other yesterday."],[4170,4254,"Oh..."],[4254,4462,"Well, but there is nothing going on"],[4462,4504,"between us."],[4504,4592,"At least..."],[4592,4654,"not anymore."],[4654,4783,"Okay."],[4783,4996,"Nina, I’m not about to let"],[4996,5263,"two hockey jocks ruin this for you."],[5263,5334,"Okay? Just"],[5334,5434,"keep things professional"],[5434,5538,"from here on out,"],[5572,5668,"and you'll be fine."],[5668,5843,"So you're not going to let me quit?"],[5843,6031,"Nope."],[6031,6143,"But I do want to see how professional"],[6143,6306,"you can be no matter the situation."],[6406,6489,"So..."],[6489,6619,"Go get Enzo."],[6619,6794,"He's up first for team physicals."],[7511,7628,"Enzo?"],[7628,7807,"Are you in here?"],[7845,7907,"Shit!"],[7907,8012,"I shouldn't be in here!"]],"17":[[0,79,"Ah... I just..."],[79,175,"Oh my God, I'm so sorry."],[175,342,"I swear I am not looking at you."],[437,558,"Calm down, Nina."],[558,767,"It's nothing you haven't seen before."],[809,963,"Look, about what you saw in the"],[963,1038,"infirmary the other day..."],[1038,1192,"What? The... what?"],[1192,1280,"The other day... What are you..."],[1280,1355,"What are you talking about?"],[1355,1634,"It's not why you came to look for me?"],[1634,1751,"No, I..."],[1751,1856,"I'm here to bring you in"],[1856,1939,"for your physical."],[1939,2160,"But I'm gonna let you get dressed, okay?"],[2160,2235,"I..."],[2998,3224,"You smell so fucking good."],[3486,3561,"Stop it."],[3561,3703,"You can't do this."],[3703,3958,"You have a girlfriend, remember?"],[3958,4037,"I have to go."],[4062,4200,"Not"],[4200,4287,"until you tell me"],[4287,4504,"why I saw you kissing Justin."],[4504,4646,"I thought you were done with him!"],[4646,4854,"What I do and who I do it with"],[4854,4975,"is none of your business."],[4975,5259,"You see, that's where you're wrong."],[5259,5501,"Nina, ever since I slept with you,"],[5501,5714,"you're all I think about."],[5755,5830,"Fuck"],[5830,5976,"Justin."],[5976,6143,"I want you, Nina."],[6143,6322,"Choose me."],[7365,7565,"I want him, he wants me."],[7565,7811,"And I'm tired of being the good girl."],[7811,7999,"It's time I do what I want."],[7999,8199,"Fuck the consequences."],[8596,8721,"I want you, Nina."],[8800,8979,"Right here,"],[8979,9067,"right now."],[9067,9209,"What about your rule?"],[9209,9392,"Nina, you got me"],[9392,9572,"want to break my rule."],[9617,9934,"But there's something you need to know."],[10043,10110,"Shit."],[10110,10247,"Wow."]],"18":[[20,62,"Shit."],[62,183,"Wow."],[183,279,"I can't believe you're making out"],[279,425,"with Justin's ex after what she"],[425,525,"did to him last night."],[525,725,"This is none of your business."],[725,817,"And what do you mean?"],[817,975,"What happened"],[975,1084,"with Justin yesterday?"],[1084,1172,"Nina went crazy"],[1172,1284,"and attacked him at the party."],[1284,1388,"That's a lie!"],[1388,1568,"Justin kissed me without my consent,"],[1568,1693,"and I pushed him."],[1693,1801,"That's all."],[1997,2102,"Good girl."],[2352,2448,"Get out?"],[2448,2602,"Whatever, dude."],[2660,2765,"I will see you"],[2765,2898,"in the infirmary"],[2898,3078,"for your physical."],[3399,3616,"Oh, I'm so"],[3616,3674,"stupid!"],[3674,3845,"What was I thinking?"],[3845,3912,"I'm sure that"],[3912,3978,"whatever it is,"],[3978,4145,"you're being too hard on yourself."],[4145,4225,"Who are you?"],[4225,4354,"I'm James Korbel,"],[4354,4454,"one of Doctor Berry's"],[4454,4583,"grad students."],[4583,4771,"You're Nina, right?"],[4771,4850,"Nice to meet you."],[4850,4992,"It's nice to meet you, too."],[4992,5109,"Where's Tiffany?"],[5109,5176,"She was called away"],[5176,5271,"to a faculty meeting"],[5271,5363,"and asked me to step in"],[5363,5555,"to help you with the physicals."],[5805,5947,"Looks like the great Enzo Rivers"],[5947,6106,"is our first of the afternoon."],[6106,6239,"Do you know Enzo?"],[6239,6493,"Not really, but I know his type."],[6493,6598,"Rich kid."],[6598,6735,"Big man on campus."],[6735,6944,"Your typical privileged asshole."],[6944,7102,"Privileged asshole,"],[7102,7269,"reporting for his physical."],[7323,7474,"Apologies, Enzo."],[7474,7657,"Have a seat on the exam table, please."],[8316,8537,"Nina, you take the lead."],[8537,8671,"I'm here if you need help."],[13067,13158,"Oh my God!"],[13158,13288,"Enzo!"],[13288,13396,"Your blood pressure is"],[13396,13463,"through the roof."],[13463,13651,"We've got to get you to a hospital!"],[13651,13805,"You're in cardiac arrest!"]],"19":[[116,262,"Relax. I'm fine."],[262,471,"I typically run hot."],[567,717,"I have a condition."],[717,842,"What kind of condition?"],[842,913,"I'm not going to"],[913,1055,"discuss that with you."],[1217,1309,"But..."],[1309,1455,"I..."],[1455,1626,"would love to tell you, Nina."],[1743,1918,"In private later."],[1918,2118,"Let's meet after the game."],[2139,2306,"Tonight, I tell her the truth"],[2306,2523,"about my rule and about what I am."],[2527,2686,"Yeah, sure."],[2686,2827,"Where can I meet you?"],[2827,3023,"Don't worry about it."],[3023,3190,"I always find you."],[4308,4512,"I'm gonna go."],[5021,5180,"Leaving so soon?"],[5180,5276,"Ugh. Yeah."],[5276,5501,"I've got an anatomy and physiology lab"],[5501,5601,"I've got to get to."],[5601,5676,"Got it."],[5676,5789,"It was nice working with you."],[5789,5939,"Yeah."],[6139,6243,"What is it?"],[6243,6398,"Enzo's muscle mass, strength"],[6398,6631,"and reflexes are off the chart."],[6631,6748,"And you saw his crazy resting"],[6748,6785,"heart rate."],[6785,7007,"His results are..."],[7007,7115,"superhuman."],[7298,7511,"Enzo's not what he seems."],[7586,7686,"Make it stop."],[7686,7820,"What's the matter? What's wrong?"],[7820,7907,"Oh no... no... nothing."],[7907,7995,"I'm sorry."],[7995,8149,"I thought I heard something."],[8149,8312,"I... I gotta go."],[8312,8450,"I'll see you."],[9818,10018,"Hmm... That's weird."],[10018,10310,"He's got very sharp canine teeth."],[10310,10402,"I've never seen anything"],[10402,10514,"like that before."],[11261,11436,"What the hell?"]],"20":[[1393,1668,"Ah, no, no!"],[1793,2027,"It's time for you to come home, Nina."],[3966,4062,"Who are you?"],[4062,4162,"Who sent you?"],[4162,4295,"Thank you for revealing her"],[4295,4421,"to us, Enzo."],[4421,4608,"Now that we've found her,"],[4608,4750,"we won't stop until we take her"],[4750,4863,"where she belongs."],[4863,5080,"You're not taking her anywhere!"],[5597,5689,"Shit!"],[5689,5834,"If I'm gonna protect Nina from"],[5834,6001,"whoever is after her,"],[6001,6264,"she has to know the truth about me."]],"21":[[421,563,"Edward..."],[563,667,"Edward, I don't think that"],[667,759,"what I just saw was real."],[759,925,"This thing... this..."],[925,1121,"It rose from the dead,"],[1121,1301,"and it tried to kidnap me."],[1305,1501,"I don't think it was human."],[1501,1609,"It's okay, Nina."],[1609,1868,"I'm here to help, okay?"],[1868,2043,"Listen to my voice"],[2043,2298,"and gaze into the crystal."],[2298,2627,"Your eyes are getting very heavy."],[2706,2873,"Good."],[3478,3678,"Enzo's not what he seems."],[3678,3832,"If you have sex with Enzo"],[3832,4154,"a second time, you could die."],[4154,4295,"Ugh."],[4904,5080,"What was that?"],[5355,5451,"Have I ever told you"],[5451,5726,"how good you look in your"],[5726,5876,"little uniform?"],[6085,6222,"Give me a kiss,"],[6222,6385,"pretty girl."],[6385,6573,"Get off me!"],[6573,6685,"What the?"],[6969,7090,"You crazy bitch!"],[7090,7223,"You're fired!"],[7411,7636,"How the hell did I do that?"],[7636,7882,"Phil's like three times my size!"],[7882,8020,"I told you."],[8020,8145,"You're stronger now."],[8145,8299,"And this is only the beginning."],[8299,8429,"Ugh, you again?"],[8429,8558,"Fuck off!"],[8650,8717,"At least"],[8717,8863,"let me ask you to hang out"],[8863,9017,"before you tell me to fuck off."]],"22":[[8,154,"I wasn't talking to you."],[154,271,"Who were you talking to?"],[316,371,"No one!"],[371,542,"I was just letting off some steam"],[542,692,"since Phil just fired me."],[692,821,"What an asshole!"],[913,1001,"Come with me."],[1001,1126,"You can tell me all about it."],[1126,1242,"I know just a spot."],[1634,1755,"Sounds like you gave your boss"],[1755,1856,"what he deserved."],[1856,1993,"But now I'm jobless."],[1993,2060,"I don't know how I'm going to"],[2060,2181,"pay for school."],[2181,2356,"You're incredibly smart, Nina."],[2356,2527,"You'll figure something out."],[2577,2665,"Well, I appreciate your"],[2665,2761,"vote of confidence."],[2890,3094,"This is beautiful."],[3094,3232,"Do you come here a lot?"],[3353,3574,"This is one of my favorite spots."],[3574,3774,"It's private."],[3774,3866,"Quiet."],[4062,4141,"You know,"],[4175,4279,"I've never taken anyone else"],[4279,4354,"here before."],[4475,4583,"Not even Lisa?"],[4704,4842,"Especially not her."],[4888,4988,"Mm-hmm?"],[4988,5080,"Look, I didn't come here to"],[5080,5196,"talk about Lisa."],[5305,5388,"I wanted to check on you"],[5388,5472,"after what happened in the"],[5472,5559,"anatomy lab."],[5559,5663,"Anatomy lab?"],[5663,5768,"What are you talking..."],[6056,6185,"Wait, the cadaver!"],[6185,6327,"It attacked me!"],[6327,6456,"That really happened?"],[6456,6610,"Don't worry."],[6610,6835,"I won't let anything hurt you anymore."],[6835,7019,"But I don't get it."],[7019,7207,"You don't remember what happened?"],[7232,7390,"I saw Edward for hypnosis"],[7390,7457,"because I thought that I was"],[7457,7524,"hallucinating."],[7524,7699,"And the next thing I knew, I was at work."],[7716,7870,"Edward wiped your memory?"],[7870,8120,"He tried to, I think. He's done it before."],[8120,8304,"It usually lasts a few days, but,"],[8304,8450,"it always comes back."],[8450,8575,"Only powerful werewolves"],[8575,8700,"can wipe memories."],[8700,8837,"And if Edward's a werewolf,"],[8837,8938,"Nina shouldn't be able to"],[8938,9075,"resist his power."],[9096,9188,"Nina..."],[9188,9288,"what are you?"]],"23":[[16,104,"I guess I should thank you."],[216,316,"You're my hero."],[684,950,"There is nothing I wouldn't do"],[992,1142,"to keep you safe, Nina."],[1372,1451,"All right. So..."],[1451,1572,"what was that thing?"],[1572,1768,"And how did you show up so fast?"],[1768,1906,"And..."],[1906,2110,"And also, there's something else."],[2256,2310,"Um..."],[2310,2494,"Please don't think that I'm crazy."],[2494,2677,"How could I think you're crazy?"],[2723,2877,"I've been hearing"],[2877,2944,"a voice."],[3123,3282,"It warns me about you."],[3303,3424,"It says that if we"],[3424,3516,"sleep together again,"],[3516,3611,"not that we will..."],[3732,3832,"I could die."],[3853,4062,"Nina, I can explain"],[4175,4270,"why I can't sleep"],[4270,4462,"with the same person twice."]],"24":[[208,387,"What the fuck are you doing?"],[575,696,"Enzo?"],[1497,1564,"What was that?"],[1564,1735,"Why were they taking our picture?"],[1768,1881,"I have no clue."],[1935,2052,"I think I've had enough excitement"],[2052,2139,"for one day."],[2223,2377,"Can you take me back to my dorm?"],[2406,2498,"Sure."],[2498,2615,"Let's get you home."],[2615,2727,"I want to tell her,"],[2727,2965,"but maybe now's not the time."],[3912,4120,"Prodigal son returns."],[4129,4237,"If you're looking for your father,"],[4237,4383,"he's away on business."],[4383,4713,"No, I actually came to see you, Lewis."],[4713,4817,"How are you doing?"],[4842,4917,"Good."],[4917,5009,"But better now that I've"],[5009,5184,"got eyes on 