{"1":[[875,1067,"Adam, you're finally awake."],[1108,1364,"Where am I?"],[1383,1500,"Young Master!"],[1744,1851,"Young Master!"],[1851,2107,"You've been in a stupor for three years,"],[2107,2335,"but you've finally recovered."],[2351,2503,"Young Master?"],[2555,2707,"Wasn't I just at Yobor?"],[2819,2964,"This is Yobor, with an annual throughput"],[2964,3096,"of over a hundred million tons."],[3096,3260,"It holds at least"],[3260,3415,"tens of billions of tons of food,"],[3415,3532,"daily necessities,"],[3532,3671,"and even munitions."],[3992,4115,"What is that?"],[4223,4281,"Look!"],[4361,4497,"Quick, take a picture!"],[4593,4758,"W-What is that?"],[4758,4853,"What the hell is that?"],[4947,5184,"Run!"],[5500,5656,"I'm a champion sprinter."],[5656,5784,"How can I not outrun you guys?"],[5815,6020,"Sh*t."],[6084,6207,"I've time-traveled."],[6207,6371,"I'm in Pekon"],[6371,6484,"during the Everett Era of Menolia."],[6484,6668,"My father crossed Prince Hans and was fired."],[6668,6812,"He died of grief."],[6812,7012,"I sold our assets to pay for his funeral."],[7012,7251,"My fiancée stayed by my side,"],[7251,7420,"but I died of sheer despair."],[7431,7487,"Sigh"],[7487,7600,"Young Master."],[7656,7771,"Young Master."],[7807,7892,"Uh"],[8004,8123,"Barry,"],[8123,8295,"why don't you both step out for now?"],[8295,8387,"I want to"],[8387,8535,"be alone."],[8635,8707,"But"],[8856,9100,"The confiscators are already on their way."],[9100,9300,"Talk about starting on \"Hell\" difficulty."],[9431,9584,"What am I going to do?"],[10043,10231,"Wait, isn't this the warehouse from Yobor?"],[10231,10531,"I brought the warehouse with me to Menolia."],[10531,10812,"With the billion-ton Yobor warehouse backing me,"],[10812,10923,"my life in Menolia"],[10923,11076,"is about to take off!"]],"2":[[316,395,"Holy crap."],[420,566,"This is incredible."],[750,912,"With these modern weapons,"],[962,1137,"I'll be invincible in Menolia!"],[1429,1504,"My god."],[1508,1633,"The quality of this beef is"],[1637,1833,"frozen at the exact moment I time-traveled."],[1841,1941,"That means"],[1975,2120,"everything in the warehouse"],[2125,2266,"will stay perfectly fresh."],[2287,2391,"This is amazing!"],[2612,2875,"This is Thai Jasmine rice,"],[2883,3112,"and there are millions of tons of it."],[3116,3208,"With all this,"],[3220,3412,"I'll never go hungry in Menolia."],[3429,3662,"And once I gain some power,"],[3691,3929,"I can trade for even more strategic resources."],[4098,4220,"This is just too good!"],[4225,4400,"With this warehouse at my disposal,"],[4437,4633,"I'm going to soar in Menolia."],[4716,4791,"Just as I thought."],[4816,4883,"With a single thought,"],[4887,5012,"I can take things out"],[5016,5112,"or put them back in."],[5116,5212,"I've hit the jackpot."],[5229,5308,"Young Master!"],[5408,5554,"Young Master! Young Master!"],[5558,5633,"Bad news!"],[5645,5783,"The confiscators are here!"],[5837,5925,"They're finally here."],[5983,6062,"But luckily,"],[6095,6141,"I'm backed by"],[6145,6275,"the massive Yobor warehouse."],[6287,6441,"Even if I'm penniless,"],[6445,6600,"I can make a comeback."],[6625,6704,"Let's go"],[6712,6787,"meet them."]],"3":[[40,187,"By the will of Heaven,"],[187,339,"the Emperor decrees:"],[352,612,"Former Pekon Minister Gregory Forster"],[612,744,"has betrayed my trust and the law."],[744,851,"His crimes are evident."],[867,1000,"His property shall be confiscated."],[1000,1088,"His son Adam"],[1088,1208,"is stripped of his titles."],[1208,1380,"All assets are seized"],[1403,1548,"as a warning to others."],[1660,1864,"Adam Foster receives the edict."],[2019,2244,"Adam, His Majesty said"],[2271,2387,"you are talented,"],[2387,2512,"so you may retake the exams."],[2523,2632,"If you wish to do business,"],[2644,2744,"he will not interfere."],[2787,3060,"This is an act of extraordinary mercy."],[3128,3400,"I thank His Majesty for his grace."],[3432,3503,"Raid the house!"],[3532,3628,"Yes, sir!"],[6179,6260,"Adam,"],[6371,6500,"please don't be too sad."],[6592,6764,"I have a bank note for a thousand taels."],[6848,6931,"Take your time,"],[7000,7131,"and you'll get back on your feet."],[7212,7292,"Grace."],[7348,7492,"I didn't think that even after the raid,"],[7564,7728,"you would still stand by me."],[8028,8123,"Grace!"],[8879,9020,"You haven't married into the Fosters yet,"],[9031,9156,"but you're using your dowry to support Adam."],[9231,9395,"You're such a disappointment."],[9731,9976,"Pete, Dad gave this to me."],[9995,10104,"You can't take it away."],[10104,10276,"Dad gave you two choices."],[10279,10548,"Either sign this severance letter and fend for yourself,"],[10587,10792,"or come back with me"],[10792,10971,"and continue living as a high-born lady."],[10984,11064,"It's your choice."],[11100,11179,"I..."],[11843,11948,"I want to be with Adam."]],"4":[[48,160,"I want to be with Adam."],[343,440,"My God."],[440,596,"How can I let down a woman"],[596,720,"who is so devoted to me?"],[720,827,"I must succeed with her by my side"],[827,943,"and make our names known to the world."],[943,1075,"He's been stripped of his titles."],[1075,1219,"What is worth clinging to?"],[1259,1348,"You're hopeless!"],[1944,2028,"I don't care what trick"],[2028,2151,"Adam has used on you,"],[2187,2351,"but you'll regret this sooner or later."],[3756,3888,"Thirty taels in banknotes."],[4020,4224,"Adam, we have money!"],[4647,4747,"This is"],[4839,5064,"the deed to a cottage in Westfall Village."],[5252,5492,"Pete has a sharp tongue but a soft heart."],[5528,5660,"Even if it's just a cottage,"],[5679,5764,"it's still a home."],[5864,6024,"When I make it big,"],[6024,6143,"I certainly will repay him."],[6267,6367,"The Fosters have fallen on hard times,"],[6407,6568,"but you haven't abandoned me."],[6604,6687,"I swear,"],[6740,6876,"I will never turn my back on you."],[6968,7068,"I will make you happy"],[7192,7384,"and restore our family's honor."],[7451,7548,"Mm-hm."],[7840,8020,"I didn't expect that after the raid,"],[8020,8148,"my fiancée would stay by my side,"],[8200,8328,"and the butler would follow me too."],[8368,8464,"The problem now is"],[8464,8604,"how to make money."],[8643,8835,"Crafts or food?"],[8895,9051,"With such a huge warehouse at my disposal,"],[9051,9187,"it's a happy problem to have."],[9223,9304,"Master!"],[9440,9551,"Master, bad news!"],[9695,9823,"Barry, what's wrong?"],[9823,10007,"Simon Sutton, Grain Warden of Westfall Village,"],[10007,10151,"is here to demand grain!"],[10179,10271,"Demand grain?"]],"5":[[23,126,"Demand grain?"],[126,220,"Yes."],[273,560,"Hahahaha!"],[923,1003,"Adam."],[1003,1111,"You used to own"],[1111,1340,"vast fertile lands in Westfall Village."],[1340,1530,"You were exempt from taxes due to your title."],[1586,1793,"But now that your title is gone,"],[1883,2025,"according to the laws of Menolia,"],[2025,2201,"the tax rate is one in thirty."],[2231,2367,"So you must hand over"],[2623,2820,"a total of 18 thousand catties of grain."],[3030,3097,"What?"],[3143,3323,"Our lands have been confiscated,"],[3323,3506,"and you still want so much grain?"],[3506,3646,"This is robbery!"],[3793,3960,"Save your breath."],[3980,4220,"If you don't produce the grain in three days,"],[4220,4386,"get the hell out of Westfall Village."],[4413,4536,"I'm telling you, not asking."],[4536,4600,"You"],[4843,4960,"I have the grain in my warehouse,"],[4962,5050,"so it isn't an issue."],[5090,5240,"But letting him rob me?"],[5240,5320,"That's not gonna happen."],[5330,5623,"Sir Sutton, it's better to make friends than enemies."],[5670,5803,"Why not sit down, have some tea,"],[5810,5920,"and get to know each other?"],[6026,6200,"Don't f**king try to cozy up to me."],[6213,6390,"I'll be back in three days."],[6410,6753,"Short one catty and say goodbye to your legs."],[6840,6938,"Let's go."],[6954,7013,"Hmph."],[7453,7706,"Master, what are we going to do?"],[7753,7893,"18 thousand catties of grain"],[7893,8123,"We can't possibly gather that in three days."],[8166,8400,"And we don't have that kind of money."],[8423,8570,"I won't give him a single grain of rice."],[8603,8813,"If he pushes me, I'll draw my gun."],[8833,8931,"Let's see if his bones"],[8931,9088,"are harder, or my bullets."],[9186,9406,"Don't worry. I'll handle the grain issue."],[9440,9623,"Look at this."]],"6":[[312,425,"Adam,"],[458,629,"is this a mirror?"],[639,810,"Why is the reflection so clear?"],[884,1037,"A friend of mine from overseas"],[1041,1154,"found it in Yukyu."],[1208,1312,"It's worth a fortune."],[1379,1466,"Master,"],[1470,1675,"it captures every detail."],[1687,1795,"It's a real treasure."],[1800,1933,"Hahaha."],[2000,2079,"Master,"],[2096,2175,"we"],[2179,2329,"we're going to be rich!"],[2333,2433,"Hahaha!"],[2600,2679,"Barry,"],[2710,2850,"I'll go sell this"],[2854,2912,"makeup box."],[2945,3050,"Your job is to stay home"],[3054,3158,"and protect Grace."],[3162,3229,"Yes, sir."],[3400,3487,"Barry,"],[3525,3683,"pick a lucky date."],[3687,3754,"I'm planning"],[3787,3883,"to marry Grace."],[4129,4270,"But keep it a secret."],[4291,4504,"Grace waited three bitter years for me."],[4525,4620,"I want to surprise her."],[4995,5070,"Alright, Master."],[5075,5237,"I'll go pick a date right now."],[5260,5329,"Also,"],[5400,5500,"Grace's dowry"],[5504,5675,"was snatched by her brother."],[5679,5820,"Once I sell this cosmetic case,"],[5854,5957,"I want you to prepare"],[5957,6083,"a huge dowry for her."],[6215,6280,"Yes, Master."],[6331,6482,"Just you wait and see."],[6487,6775,"Haha."],[7008,7220,"Is it done?"],[7335,7612,"I've forbidden all merchants and farmers from selling grain."],[7625,7833,"Even if Adam has mountains of gold,"],[7837,8000,"he won't be able to buy a single grain."],[8058,8133,"But, sir,"],[8187,8316,"why are we doing this?"],[8516,8637,"Because his father stole"],[8641,8775,"my father's position as Vice Prefect."],[8904,8995,"Besides,"],[9054,9291,"his father dared to offend Prince Hans."],[9320,9629,"Who wouldn't want to kick him while he's down?"],[9712,9908,"I understand."],[10658,10783,"I wonder how beautiful"],[10787,10912,"Grace would look"],[10916,11008,"in modern clothes."]],"7":[[608,716,"Actually, forget it."],[741,866,"If I gave this to her,"],[870,1029,"she'd jump down a well the next day."],[1116,1245,"Feudal ethics"],[1250,1351,"really ruin lives."],[1633,1712,"Not bad."],[1762,1883,"I can bring these back"],[1887,1970,"for Grace to eat."],[2979,3137,"These makeup cases are"],[3154,3325,"ordinary crafts in modern times."],[3358,3466,"But back in the past,"],[3470,3645,"they are rare treasures that not even"],[3650,3833,"the entire kingdom could produce."],[3879,4125,"Today, I'll open your eyes!"],[4189,4325,"Step right up and take a look!"],[4495,4632,"Folks from near and far!"],[4632,4753,"Come and have a look!"],[4887,4991,"Check these out!"],[5012,5125,"These are rouge cases"],[5129,5325,"my friend brought back from Yukyu."],[5329,5458,"Ten taels of silver each."],[5500,5679,"They are absolutely worth it."],[5754,5879,"Ten taels?"],[5887,5983,"Is this made"],[5987,6070,"of gold"],[6075,6191,"or silver?"],[6195,6316,"Ten taels for one?"],[6320,6479,"That's daylight robbery!"],[6495,6570,"Miss,"],[6587,6695,"have a look,"],[6700,6816,"you'll see if it's worth it."],[7337,7466,"Oh my god."],[7470,7650,"How is this mirror polished?"],[7654,7783,"It's so clear!"],[7833,8112,"This... this is definitely a rare treasure."],[8370,8591,"It's a pity I can't afford it."],[8645,8770,"Let me see."],[8868,9095,"Oh... Oh my"],[9129,9212,"Young man,"],[9216,9350,"these three rouge cases,"],[9354,9429,"I'll take them all."],[9470,9641,"I'm the owner of the Rouge House."],[9662,9737,"Let's talk."],[9845,10050,"The Rouge House belongs to Sir Lawson."],[10108,10245,"In my memory, Sir Lawson"],[10250,10337,"is not a bad person,"],[10341,10441,"so he is worth trusting."],[10445,10525,"Okay."]],"8":[[60,143,"Have a seat."],[356,440,"Young man,"],[440,596,"judging by your clothes,"],[596,787,"you must be a nobleman."],[787,991,"Has your family fallen on hard times?"],[1111,1316,"My father was the Vice Governor of Pekon."],[1316,1508,"I can't hide my identity anyway,"],[1508,1635,"so I might as well be honest."],[1664,1767,"To be honest,"],[1803,1892,"my name is Adam Foster."],[2083,2267,"No wonder you look so familiar."],[2276,2412,"You're Vice Prefect Foster's son."],[2501,2692,"Forgive my lack of manners."],[3056,3215,"Please, I don't deserve such courtesy."],[3215,3467,"Pekon Academy is flourishing,"],[3467,3671,"and your father's contribution was immense."],[3688,3928,"Every student holds him in high regard."],[4088,4228,"It's a pity."],[4271,4447,"He offended Prince Hans,"],[4447,4584,"and met such a tragic end."],[4628,4775,"It is truly heartbreaking."],[4956,5035,"Tell you what."],[5035,5184,"If you have similar items"],[5184,5267,"in the future,"],[5288,5479,"I'll buy them all"],[5479,5567,"for ten taels apiece."],[5667,5760,"In three days,"],[5775,5864,"I'll have a batch of"],[5888,6060,"rare items as good as this rouge case."],[6088,6220,"You can come to Westfall Village to pick them up."],[6243,6296,"OK?"],[6335,6443,"No problem."],[6443,6656,"I'll definitely be there myself."],[6684,6931,"Simon is giving me a tough time,"],[6931,7120,"demanding 18 thousand catties of grain."],[7120,7348,"Manager Walker will visit in three days."],[7348,7523,"He has Sir Lawson backing him."],[7556,7720,"If Walker stands up for me,"],[7720,7935,"I wonder if Simon will wet his pants?"],[8120,8207,"Now that I'm making money,"],[8207,8343,"I can openly bring out"],[8343,8487,"the goods from my warehouse."],[8528,8735,"Tonight, we're eating marbled beef."],[8979,9068,"You are back."],[9368,9456,"Adam,"],[9456,9612,"did you sell"],[9612,9692,"the rouge case?"],[9728,9835,"Guess how much I got for it?"],[9940,10048,"Four taels?"],[10348,10428,"Three taels?"],[10476,10548,"Too low."],[10548,10731,"Thirty taels?"],[10828,10930,"That's right."],[10946,11020,"Here,"],[11020,11207,"this is the meat I bought on the way back."],[11412,11495,"Oh my heavens,"],[11548,11676,"thirty taels."],[11759,11995,"Master, did you see this?"],[12031,12148,"Mr. Adam can make money now."],[12148,12320,"He even bought meat."],[12459,12595,"Barry, stop crying."],[12607,12731,"Go cook this meat."],[12771,12852,"Okay."],[13419,13531,"This is the money"],[13531,13600,"I earned today."],[13647,13715,"I'm giving it to you."]],"9":[[39,293,"We aren't married yet,"],[320,463,"so letting me manage the money"],[473,566,"isn't appropriate."],[970,1143,"You were kicked out of your home for me."],[1157,1270,"How could I ever let you down?"],[1303,1463,"All the money I earn"],[1503,1600,"is yours to manage."],[1920,2101,"Now, look at this."],[2420,2810,"Wow."],[2810,3066,"This fabric is amazing."],[3083,3173,"Of course it is."],[3186,3363,"It's from a thousand years in the future."],[3570,3650,"Put it on,"],[3786,3946,"and let me take a look."],[5204,5576,"Adam, do I look good?"],[5576,5700,"Beautiful."],[6330,6593,"Like a fairy descending from the heavens."],[6663,6853,"Adam, don't tease me."],[6880,7090,"Adam, I didn't expect"],[7126,7300,"this grain crisis to be solved"],[7313,7486,"just by selling rouge cases."],[7526,7700,"It's not just about three rouge boxes."],[7720,8033,"This is a crushing blow from the industrial chain in the future."],[8050,8180,"A simple glass mirror couldn't"],[8197,8310,"be produced in Menolia,"],[8312,8450,"no matter what methods were used."],[8450,8551,"But in the future,"],[8551,8771,"it's just a cheap trinket sold on the street."],[8793,8903,"We've finally taken the first step"],[8926,9050,"toward revitalizing our family."],[9090,9170,"Not bad."],[9250,9433,"Barry, is the meat ready?"],[9470,9570,"I'm starving."],[9580,9703,"It is ready, Young Master."]],"10":[[125,225,"Young Master, the meat is ready."],[291,366,"Let's eat."],[570,645,"Okay."],[704,941,"Young Master, this outfit looks really good."],[1385,1425,"Barry,"],[1462,1554,"sit down and join us."],[1587,1670,"Young Master,"],[1675,1795,"I'm just a servant."],[1800,1879,"I shouldn't sit."],[1973,2054,"Barry,"],[2079,2225,"the Fosters lost everything in the raid."],[2229,2366,"There is no master or servant."],[2400,2566,"We're all family now."],[2570,2637,"Sit down."],[2662,2762,"But..."],[2854,3050,"Don't make me angry."],[3054,3195,"Alright, alright."],[3437,3512,"By the way, Barry,"],[3554,3612,"our business"],[3616,3745,"is getting bigger,"],[3766,3908,"so it's time to hire some help."],[3912,4054,"Grace, give Barry some money."],[4170,4316,"Hire a dozen helpers later."],[4320,4441,"Okay, no problem."],[4462,4551,"Also,"],[4752,4916,"go into town later and find a craftsman"],[4920,5054,"to build these cabinets"],[5058,5200,"according to this blueprint."],[5229,5354,"Make sure it's done within 3 days."],[5421,5474,"Okay."],[5567,5642,"Let's eat."],[5812,5945,"I assume you all know"],[5950,6075,"what the pay is here."],[6079,6229,"For delivering goods to Pekon,"],[6270,6391,"each person will receive"],[6416,6512,"two taels of silver a month."],[6529,6629,"Two taels?"],[6633,6714,"That much?"],[6800,7013,"Boss, I'm afraid we'll risk"],[7091,7245,"our lives earning the money"],[7275,7383,"and won't live to spend it."],[7416,7529,"With the pay being so high,"],[7554,7691,"it's normal for you to be worried."],[7712,7816,"To be honest,"],[7858,8045,"my father was the former Vice Prefect of Pekon."],[8050,8212,"He offended Prince Hans,"],[8216,8316,"so our home was raided."],[8379,8537,"Fortunately, His Majesty allowed me"],[8545,8637,"to do business."],[8658,8820,"But Prince Hans is powerful,"],[8825,8920,"and I can't stand alone."],[8962,9141,"That is why I must recruit capable men."],[9179,9337,"So you are"],[9341,9483,"Sir Foster's only son?"],[9529,9741,"Your father loved the people like his own children."],[9750,9829,"He did so much"],[9833,9941,"for Pekon over the years."],[9975,10120,"We would follow you"],[10133,10241,"even without pay!"],[10295,10479,"The pay will remain exactly as I said."],[10512,10662,"I'll even add another clause."],[10695,10829,"For every delivery,"],[10842,11133,"each person gets a bonus of a tenth of a tael of silver,"],[11166,11262,"with no upper limit."],[11356,11391,"Great!"],[11395,11645,"We pledge our lives to serve you, Mr. Foster!"],[11710,11937,"We pledge our lives to serve you, Mr. Foster!"],[12104,12354,"But earning so much money is"],[12375,12512,"bound to make some people jealous,"],[12535,12735,"especially those sucking up to Prince Hans."],[12760,12877,"So what should we do?"],[13016,13125,"Raise our fists"],[13129,13220,"and fight them!"],[13225,13479,"-Fight! -Fight!"],[13483,13570,"Barry,"],[13575,13729,"give everyone an advance"],[13733,13841,"of one month's wages."],[13845,13920,"Yes, sir."],[13950,14025,"Adam."],[14158,14266,"The three days are up."],[14270,14420,"Where is your grain?"]],"11":[[176,256,"Sir Sutton,"],[308,467,"you really have a nose like a bloodhound."],[504,567,"I assume the news"],[567,724,"that I've been making money"],[748,859,"has reached your ears."],[959,1035,"Of course."],[1103,1208,"Everyone in Westfall Village"],[1227,1335,"works for me."],[1383,1491,"I know exactly what"],[1511,1639,"you're up to, kid."],[1671,1744,"Let me tell you,"],[1772,1919,"don't think making a little money"],[1944,2028,"can cover"],[2028,2232,"the shortage of 18,000 catties of grain."],[2248,2287,"Oh?"],[2371,2532,"What do you mean by that?"],[2619,2760,"I'll be straight with you."],[2839,2939,"Three days ago,"],[2948,3112,"the higher-ups demanded the grain."],[3144,3288,"Too bad you didn't have it."],[3324,3439,"Out of the kindness,"],[3467,3575,"I paid it for you."],[3607,3784,"Now, with compound interest,"],[3807,3900,"when you add it all up,"],[3932,4047,"you owe me a total of"],[4079,4292,"180,000 catties of grain."],[4328,4464,"180,000 catties of grain?"],[4475,4535,"Simon,"],[4552,4679,"who gave you the nerve"],[4711,4920,"to try and extort my young master?"],[4971,5056,"Young master?"],[5239,5307,"Adam,"],[5360,5552,"your father defied Prince Hans,"],[5567,5700,"lost his position, and committed suicide."],[5724,5847,"You were stripped of your titles"],[5864,5984,"and are hiding out here."],[5992,6024,"Tsk."],[6047,6156,"Does a stray dog like you"],[6203,6320,"deserve to be called \"Young Master\"?"],[6320,6352,"You"],[6564,6712,"Adam, let me tell you something."],[6731,6959,"If you can't hand over the grain today,"],[6976,7104,"get the hell out of Westfall Village!"],[7156,7223,"Sir Sutton,"],[7287,7420,"why burn your bridges?"],[7435,7556,"We might cross paths again."],[7576,7751,"Do you really have to be this aggressive?"],[7751,7790,"Hmph."],[7912,8035,"I AM being aggressive."],[8082,8131,"So what?"],[8159,8243,"You got a problem with that?"],[8279,8412,"Right now, in all of Menolia,"],[8420,8551,"who doesn't want you dead"],[8584,8715,"to gain favor with Prince Hans?"],[8748,8823,"I'm telling you,"],[8868,9068,"if you don't produce 180,000 catties today,"],[9100,9220,"no one can save you."],[9224,9304,"Is that so?"],[10123,10223,"Simon,"],[10243,10387,"you talk a big game!"]],"12":[[80,172,"Simon,"],[227,364,"you talk a big game!"],[508,620,"Who do you think you are,"],[636,724,"daring to lecture our Chief?"],[732,783,"Shut up!"],[1024,1111,"Manager Walker,"],[1135,1240,"what brings you here?"],[1280,1375,"How has His Honor,"],[1391,1503,"Adjudicator Lawson, been lately?"],[1603,1644,"My, my."],[1664,1725,"To think that he"],[1725,1855,"is one of the Adjudicator's men."],[2103,2264,"If His Honor knew that"],[2319,2548,"you were extorting Mr. Foster"],[2548,2680,"for 180,000 catties of grain,"],[2692,2992,"he probably wouldn't be too happy."],[2992,3128,"Oh, Manager Walker,"],[3148,3279,"this is all a misunderstanding."],[3324,3415,"I just..."],[3415,3524,"Get lost, now!"],[3824,3871,"Alright."],[4760,4864,"Thank you for the help."],[4871,4960,"If you hadn't come,"],[4996,5111,"I would have been kicked out."],[5143,5271,"Please, no need for formalities."],[5424,5524,"In Pekon,"],[5524,5656,"those who received your father's help"],[5667,5824,"number in the hundreds, if not thousands."],[5871,6007,"I am just one of them."],[6052,6224,"This was the least I could do."],[6367,6456,"It's just a pity that"],[6515,6643,"Prince Hans is so powerful."],[6692,6771,"Troubles like this"],[6812,6895,"will happen often later."],[6943,7004,"The road ahead"],[7043,7151,"of you is very difficult."],[7195,7292,"Thank you for the warning."],[7343,7412,"Alright,"],[7479,7607,"let's not talk about it."],[7635,7707,"It's been three days,"],[7740,7931,"so I'm here to collect the goods."],[7979,8044,"Mr. Foster,"],[8071,8171,"what other good stuff do you have?"],[8223,8276,"Mr. Walker,"],[8304,8368,"come with me."],[8392,8440,"This way, please."],[8440,8479,"Okay."],[8987,9040,"Mr. Walker,"],[9076,9164,"come take a look."]],"13":[[37,87,"Mr. Walker,"],[129,212,"look at this."],[241,333,"Oh, this"],[400,470,"Let me give you"],[483,579,"a detailed introduction."],[745,870,"This is Tone-up"],[975,1108,"Tone-up Cream."],[1250,1291,"Look,"],[1306,1485,"you just apply a thin layer,"],[1508,1583,"and it instantly"],[1608,1692,"covers any blemishes."],[2508,2679,"The fragrance is surprisingly rich."],[2716,2866,"The effect is indeed impressive."],[3016,3104,"However,"],[3145,3325,"this cream is so white."],[3391,3554,"Is there too much lead powder in it?"],[3600,3750,"That stuff is poisonous."],[3775,3816,"Mr. Walker,"],[3820,3912,"you have a sharp eye."],[3925,4012,"Can't you tell whether"],[4016,4141,"this has lead mixed in or not?"],[4162,4216,"This is"],[4258,4412,"an essence extracted from plants"],[4431,4632,"by experts in Yukyu."],[4650,4725,"It is very safe."],[4987,5030,"Oh,"],[5095,5300,"it really does have a natural botanical scent."],[5366,5441,"If we supply this"],[5450,5650,"to the noble ladies of the capital,"],[5704,5879,"it will definitely be a huge hit."],[5931,5995,"Besides,"],[6016,6091,"the design"],[6116,6233,"is so exquisite."],[6266,6470,"It is simply heavenly."],[6712,6750,"Here,"],[7000,7058,"look."],[7075,7208,"This is lipstick from Yukyu."],[7304,7391,"Our local rouge is"],[7450,7533,"mostly made of cinnabar"],[7558,7600,"and dyes."],[7620,7691,"It fades easily"],[7702,7770,"and isn't healthy."],[7816,7879,"But this one"],[7916,8083,"contains plant extracts"],[8104,8195,"and honey."],[8216,8320,"It's cheaper,"],[8342,8450,"and works even better."],[8608,8637,"Look,"],[8758,8833,"it doesn't smudge at all."]],"14":[[20,68,"Whoa!"],[115,204,"Oh my god."],[260,320,"This... this"],[353,405,"This item"],[420,571,"should only exist in heaven."],[587,659,"It is hardly"],[671,880,"ever seen in the mortal world."],[1148,1232,"The design is"],[1280,1356,"even more exquisite"],[1372,1491,"than the beauty cream."],[1543,1700,"The noble ladies of the capital"],[1719,1964,"are going to go crazy over this."],[2235,2264,"Here,"],[2551,2644,"this last item"],[2716,2807,"is a facial cleanser."],[2900,2935,"Barry,"],[2976,3071,"go get some clear water."],[3087,3123,"Sure."],[3607,3715,"Here is the water."],[5424,5460,"See?"],[5779,5952,"Oh my god!"],[6015,6164,"It works so well!"],[6215,6284,"And the scent"],[6339,6523,"is so rich."],[6756,6871,"Mr. Foster,"],[6964,7079,"are there only"],[7112,7187,"these three types?"],[7207,7312,"Do you only have this many?"],[7371,7468,"Rare things are precious."],[7487,7615,"I can't bring out too many at once."],[7756,7912,"This is all I have for now."],[7948,8028,"But as long as I'm here,"],[8031,8104,"you can count on"],[8112,8276,"a steady supply of these goods."],[8351,8420,"Adam,"],[8464,8551,"name your price."],[8564,8756,"In the future, however much stock you have,"],[8756,8831,"I'll buy it all."]],"15":[[36,136,"Mr. Walker, you must be joking."],[172,291,"If you hadn't stepped in today,"],[308,383,"never mind"],[383,476,"being here doing business,"],[500,620,"I would have lost this house already."],[636,667,"Look,"],[667,716,"Mr. Walker,"],[767,903,"you said earlier that you'd buy"],[935,1075,"my goods for ten taels apiece."],[1116,1211,"Honestly, I think"],[1240,1327,"ten taels is too high."],[1375,1456,"For my stock,"],[1488,1580,"especially standard items like these,"],[1660,1716,"five taels apiece."],[1803,1851,"Five taels?"],[1855,1935,"No, no, no."],[1967,2087,"These are top-quality goods."],[2103,2167,"Selling them"],[2167,2303,"for five taels would be giving them away."],[2351,2400,"Say no more."],[2419,2471,"Ten taels."],[2483,2544,"Ten taels it is."],[2571,2739,"Once we open up the market for these,"],[2748,2816,"I'll raise the price."],[2907,2964,"Mr. Walker,"],[3039,3203,"you've already done enough for me."],[3235,3256,"This is"],[3307,3388,"Adam,"],[3428,3579,"I appreciate your kindness,"],[3603,3692,"but business is business."],[3732,3788,"As for this deal"],[3820,3988,"I'll speak to Sir Lawson about this."],[4032,4067,"From now on,"],[4103,4235,"you just do business here in Pekon."],[4239,4332,"No one will dare to cross you."],[4760,4888,"That's exactly what I wanted."],[5020,5111,"Pack everything up."],[5132,5167,"Please"],[5220,5271,"accept the money."],[5484,5539,"I'll be going now."],[5624,5711,"See you around."],[5856,5924,"In my previous life,"],[5939,6079,"these were bargain-bin cleansers,"],[6100,6220,"tone-up creams, and lipsticks."],[6247,6328,"But in this era,"],[6343,6528,"they easily sold for 150 taels."],[6628,6687,"Good heavens!"],[6723,6835,"Ten taels a piece!"],[6871,7035,"We made a total of 150 taels!"],[7043,7220,"One hundred and fifty taels!"],[7387,7579,"The Master's annual salary back then"],[7579,7748,"was less than a hundred taels."],[7928,8020,"Master,"],[8048,8204,"did you see that?"],[8231,8384,"The Young Master made in a single day"],[8387,8656,"what you earned in a whole year!"],[8676,8992,"You can finally rest in peace."],[9179,9235,"Adam,"],[9276,9423,"I knew I picked the right man."],[9464,9500,"From now on,"],[9551,9692,"we'll live like kings"],[9720,9840,"and have a wonderful life."],[9864,9887,"Mhm."],[10064,10107,"Barry,"],[10131,10271,"Sir Sutton couldn't win openly."],[10287,10356,"He may play dirty."],[10384,10535,"Let's go to buy"],[10551,10612,"an estate."],[10648,10728,"We're moving tomorrow."]],"16":[[68,180,"We really should move."],[204,383,"This is Sir Sutton's turf, after all."],[428,483,"If"],[500,651,"he brings a gang to wipe us out,"],[655,755,"we'd be finished."],[972,1035,"Grace,"],[1096,1172,"you were kicked out"],[1191,1272,"because of me."],[1356,1540,"I've always wanted to give you a proper title,"],[1607,1728,"but we never had the money before."],[1751,1807,"Now,"],[1832,1903,"everything is ready."],[1976,2023,"Let's"],[2051,2144,"get married in three days."],[2483,2560,"Okay."],[2603,2712,"I'll do whatever you say."],[2919,2983,"Grace,"],[3044,3135,"this wedding"],[3151,3264,"might not be very grand."],[3335,3407,"But I promise,"],[3467,3632,"I will work hard for the rest of my life."],[3688,3764,"One day,"],[3815,3943,"I promise you a phoenix crown and robes,"],[4003,4092,"an eight-bearer sedan chair,"],[4124,4220,"and a huge dowry."],[4792,4856,"D*mn it!"],[4915,5060,"I was so close to succeeding."],[5103,5307,"Once Adam's family was kicked out of the village,"],[5367,5603,"I had many ways to drive him to death."],[5743,5824,"But he actually"],[5875,6088,"He actually latched onto Sir Lawson."],[6279,6367,"How did this happen!"],[6476,6564,"Mr. Mercer,"],[6571,6592,"I"],[6635,6748,"I don't know either."],[6807,6859,"What's more,"],[6904,7076,"Sir Lawson's butler, Manager Walker,"],[7095,7240,"spent one hundred and fifty taels"],[7264,7443,"buying Adam's cosmetics."],[7795,7848,"Go on!"],[8035,8151,"My men also learned that"],[8187,8407,"Adam is going to the Pekon government office."],[8420,8531,"to buy an estate."],[8559,8692,"Once he secures that property,"],[8704,8868,"he'll be out of our control."],[8887,9076,"Mr. Mercer, what should we do now?"],[9500,9604,"Simple."],[9643,9935,"If we stop him from going there,"],[9951,10084,"won't that solve everything?"]],"17":[[320,491,"I'm going to buy the estate and"],[551,712,"prepare for the wedding today."],[1019,1127,"But I can't shake the feeling"],[1127,1248,"that whoever backs Sir Sutton"],[1291,1408,"won't just let this go."],[1583,1735,"I need a weapon for protection."],[2319,2507,"Should I take an AK-47,"],[2639,2800,"or a Kukri?"],[2919,3019,"I'll go with the AK-47."],[3048,3107,"It packs a punch."],[3520,3643,"Everyone, grab some water."],[3656,3728,"We're heading out soon."],[3728,3784,"Alright!"],[4047,4107,"Barry,"],[4132,4235,"on this trip to Pekon,"],[4247,4315,"I'll handle buying the estate,"],[4324,4479,"and you prepare Grace's dowry."],[4535,4611,"For this wedding,"],[4647,4771,"we'll make it as grand as possible."],[4796,4871,"Don't worry."],[4892,5007,"I'll make sure it's done right."],[5203,5271,"Later on,"],[5296,5400,"when the new estate is built,"],[5400,5492,"you can all move in."],[5543,5692,"I'll raise your monthly wages,"],[5720,5892,"so you'll never have to worry about food or drink."],[5892,5939,"Great!"],[6064,6103,"Boss,"],[6124,6200,"you have no idea."],[6228,6375,"When I take my pay home every month,"],[6388,6531,"my wife has been so happy."],[6540,6679,"She puts in a whole lot more effort"],[6692,6792,"when we get intimate at night."],[6792,6879,"Quite your mouth."],[7004,7100,"When I took my pay home,"],[7104,7195,"my mom was so happy,"],[7195,7340,"she started arranging a marriage for me."],[7359,7412,"I thought"],[7431,7571,"I was gonna be single for life."],[7795,7876,"I promise that"],[7884,8004,"as long as I have food on my table,"],[8007,8168,"you'll never go hungry."],[8231,8276,"Great!"],[8292,8364,"Don't worry, Boss."],[8387,8520,"From now on, my life"],[8540,8592,"belongs to you."],[8607,8731,"Anyone dares to stand in your way,"],[8740,8876,"they'll have to step over my dead body first."],[9148,9251,"Grab your weapons!"],[9251,9387,"D*mn, they got here fast."],[10600,10676,"Are you Adam?"]],"18":[[326,423,"Are you Adam?"],[423,526,"Who are you?"],[526,626,"How dare you commit robbery"],[626,843,"outside Pekon in broad daylight?"],[843,983,"Aren't you afraid of the authorities?"],[1123,1363,"Cut the crap. Either kill yourselves,"],[1373,1550,"or I'll kill you myself."],[1556,1710,"If you want to kill our boss,"],[1710,1873,"you'll have to get through us first."],[1920,1971,"Fine."],[1971,2090,"Let's put that to the test."],[2090,2292,"Protect the Boss with your lives!"],[2304,2342,"Yes!"],[2342,2398,"Yes!"],[2438,2636,"I can't believe my hunch was right."],[2706,2799,"Sir Sutton and his men"],[2799,2898,"really haven't given up."],[2960,3086,"Since you refuse to cooperate,"],[3100,3200,"I'll kill you all!"],[3283,3420,"Boss, get out of here!"],[3443,3497,"Brothers,"],[3497,3597,"attack!"],[3597,3669,"Kill!"],[4217,4340,"Nate, move!"],[4403,4606,"I'm taking on ten of them today!"],[4700,4817,"Take on ten?"],[4853,4951,"Just you?"],[4952,4988,"Hmph."],[4991,5071,"Get him!"],[5620,5710,"What is that thing?"],[5710,5800,"How is it so powerful?"],[5800,5950,"There's something wicked about it."],[5950,6133,"Is it a legendary firearm from the West?"],[6173,6303,"Sh*t. Retreat!"],[6326,6417,"Trying to run?"],[6423,6477,"Too late!"]],"19":[[6,88,"Trying to run?"],[94,153,"Too late!"],[1183,1370,"The recoil on this AK-47 is a bit much."],[1375,1454,"My arms are sore."],[1633,1683,"Boss,"],[1708,1762,"they're all dead."],[1766,1858,"These assassins hid deadly poison"],[1862,1929,"under their tongues."],[1944,2037,"Not one was left alive."],[2095,2200,"It must be Simon."],[2241,2329,"He held a grudge over"],[2337,2416,"the grain collection failure,"],[2425,2545,"so he sent men to ambush us."],[2562,2620,"Let's report him."],[2795,2925,"Sir Sutton is just a pawn."],[2954,3020,"The person behind him"],[3058,3129,"is the mastermind."],[3183,3229,"Barry,"],[3279,3408,"did my father have any political rivals?"],[3758,3833,"There actually is one."],[3854,3995,"Before he was promoted to Vice Prefect,"],[4058,4283,"he and Thomas were both officials in Pekon."],[4312,4429,"After Thomas lost the competition,"],[4458,4579,"he's been against the Master at every turn."],[4629,4750,"Rumor has it that"],[4773,4879,"the Master's offense"],[4883,4962,"against Prince Hans"],[4979,5154,"were also orchestrated by Thomas."],[5177,5345,"It seems the real culprit has surfaced."],[5416,5504,"Is Thomas Mercer"],[5537,5666,"still an official in Pekon?"],[5700,5729,"Yes."],[5950,6083,"As the Administrator,"],[6125,6325,"he oversees all government affairs in Pekon."],[6362,6437,"Theoretically,"],[6441,6579,"buying this estate is under his control too."],[6641,6729,"That makes things difficult."],[7070,7145,"Sir Lawson"],[7183,7312,"might be on the Master's side"],[7354,7475,"and owes him a debt of gratitude,"],[7512,7729,"but his rank is too low"],[7775,7925,"to stand up to Sir Mercer."],[7966,8054,"Baby steps."],[8075,8220,"I'll buy the estate and get married first."],[8266,8416,"We'll deal with the rest after that."],[8508,8570,"Okay."],[8687,8775,"One of them"],[8779,8850,"acted strangely."],[9062,9195,"Better safe than sorry."],[9241,9320,"I'll test them out."],[9400,9512,"If we bring this with us,"],[9541,9612,"we'll all get caught."],[9654,9804,"I'll bury it here for now."],[9856,9966,"Alright."],[10308,10383,"Load up."]],"20":[[604,720,"The weapon is buried."],[748,811,"Let's go."],[956,1019,"Yes, Boss."],[1622,1671,"Ouch."],[1751,1819,"Boss."],[1971,2023,"Boss."],[2076,2200,"My stomach hurts a bit."],[2232,2344,"You guys can go first."],[2348,2423,"I need to relieve myself."],[2492,2532,"Okay."],[2829,2938,"Just as I suspected."],[3025,3239,"He's trying to leak the secret of the AK-47."],[3243,3300,"Hmph."],[3335,3535,"I've stored the AK-47 in the warehouse."],[3571,3652,"Good luck finding it."],[3796,3852,"Let's go."],[3892,3935,"Okay."],[3979,4056,"Let's move."],[4396,4464,"Mr. Mercer!"],[4535,4611,"Big news!"],[4664,4764,"I have big news!"],[4900,4975,"What news?"],[5056,5115,"Speak."],[5128,5171,"I"],[5392,5488,"Mr. Mercer."],[5496,5643,"Adam knows about you."],[5664,5760,"The assassins you sent"],[5760,5867,"have all been taken out by him."],[5884,5947,"What?"],[6024,6056,"This"],[6100,6184,"How is that possible?"],[6267,6400,"They don't have firearms."],[6435,6533,"How could they"],[6533,6640,"possibly kill the assassins?"],[6684,6764,"Mr. Mercer,"],[6804,6920,"the firearm Adam is hiding"],[6920,7059,"are extremely light,"],[7076,7128,"but"],[7151,7256,"its power is terrifying."],[7448,7568,"Are you sure about that?"]],"21":[[6,100,"Positive."],[100,156,"Also,"],[156,343,"to enter the city unnoticed,"],[343,436,"he deliberately hid the firearms"],[436,548,"in the woods."],[548,659,"But before I came here,"],[659,800,"I made sure someone was watching him."],[800,856,"He definitely hasn't had a chance"],[856,959,"to move them yet."],[1372,1564,"Sir Lawson, oh Sir Lawson."],[1635,1760,"You are in charge of military affairs."],[1828,2100,"Now that Adam is hiding firearms,"],[2119,2248,"let's see how you handle this!"],[2380,2496,"I'm heading into the city right now"],[2496,2596,"to report this to my father."],[2651,2723,"Adam,"],[2764,2916,"you're finished."],[3051,3123,"Move."],[3492,3545,"Young man,"],[3615,3739,"are you buying an estate for your wedding?"],[3860,3947,"State your name."],[3984,4039,"Adam."],[4396,4579,"Officer, what is the meaning of this?"],[4579,4639,"Are you the Adam of Westfall Village"],[4639,4732,"who is set to marry"],[4732,4907,"Grace of the Bennetts"],[4907,5039,"in three days?"],[5079,5184,"That would be me."],[5184,5235,"Hmph."],[5496,5632,"Then we've got the right person."],[5688,5896,"You've been reported for hiding firearms."],[5932,6075,"Men, arrest him!"],[6456,6612,"Boss, I'll go tell the Madam!"],[6612,6671,"Freeze!"],[6751,6887,"You're not going anywhere either."],[7012,7104,"I strongly suspect"],[7156,7276,"that this was a conspiracy"],[7276,7364,"between master and servant."],[7407,7551,"Arrest them both!"],[7551,7635,"Yes, sir!"],[7635,7695,"Hold it!"]],"22":[[6,84,"Stop!"],[504,571,"Sir Lawson."],[591,675,"What brings you here?"],[708,832,"Nothing has been proven yet."],[848,964,"Who authorized you"],[964,1056,"to arrest Adam?"],[1075,1116,"Let him go."],[1188,1240,"But"],[1855,2123,"Sir Lawson, you manage military affairs,"],[2176,2416,"and considering your ties to Adam's father, Gregory,"],[2416,2551,"and your mentor-student relationship,"],[2555,2676,"I suspect"],[2716,2928,"that the firearms Adam is hiding"],[2928,3064,"were given to him by you."],[3128,3211,"Bullshit!"],[3275,3343,"How could I possibly"],[3435,3584,"have given Adam firearms?"],[3584,3700,"Whether you did or not,"],[3735,3867,"we'll find out"],[3867,3992,"once we go take a look."],[4056,4339,"I have my witnesses ready anyway,"],[4339,4500,"all I need is the physical evidence."],[4628,4824,"My wedding really is full of drama."],[4824,4979,"Good thing the AKs are in the warehouse."],[5028,5200,"Old Man Meng,"],[5220,5360,"now it's my turn to strike back."],[5392,5471,"Old Man Meng,"],[5524,5660,"I heard that when my father was alive,"],[5660,5747,"you never once beat him"],[5747,5864,"in a bet."],[5864,6043,"Why don't you make a bet with me?"],[6120,6448,"Let's bet on whether his claims are true."],[6448,6764,"Adam, the evidence is solid."],[6807,6956,"You want to bet against me?"],[6956,7104,"Are you joking?"]],"23":[[24,84,"What?"],[112,272,"Is Old Man Meng afraid to bet?"],[379,491,"What are the stakes?"],[512,600,"If I win,"],[624,800,"you'll approve my estate purchase,"],[824,1008,"and apologize to Mr. Lawson in public."],[1056,1175,"And if you lose?"],[1175,1289,"If I lose, punish me however"],[1289,1377,"the law requires."],[1391,1573,"Whether it's the Imperial Prison or execution,"],[1603,1723,"I'm at your mercy."],[1744,1819,"Sir!"],[2023,2283,"You're at death's door, yet still so arrogant?"],[2283,2348,"Take him away."],[2348,2423,"Stop right there!"],[2835,2980,"Adam, are you all right?"],[2980,3151,"Grace, what are you doing here?"],[3151,3203,"Go back, quickly."],[3252,3347,"When you are in danger,"],[3347,3471,"how can I stand idly by?"],[3611,3692,"Mr. Mercer,"],[3752,3843,"Adam would never"],[3843,3932,"possess illegal firearms."],[3992,4095,"Grace,"],[4115,4271,"the evidence is irrefutable."],[4324,4475,"My hands are tied."],[4556,4764,"I advise you to stay away from this boy."],[4788,4939,"If your family gets implicated,"],[4939,5043,"it won't end well."],[5043,5188,"Save your concern, Mr. Mercer."],[5215,5392,"I have nothing to do with the Bennetts."],[5500,5671,"Then let's look at the evidence."],[5975,6067,"Adam, don't worry."],[6067,6235,"I won't let anything happen to you."],[6271,6379,"With a wife like her,"],[6379,6476,"what more could I ask for?"],[6507,6695,"I must give Grace a good life"],[6768,6928,"and clear my father's name."]],"24":[[16,132,"Sir, we found it."],[644,779,"Come on, bring it over."],[1080,1196,"Sir Lawson,"],[1256,1359,"Grace,"],[1388,1603,"we have both the witnesses and the evidence."],[1627,1775,"What else do you have to say?"],[2080,2151,"Sir Mercer,"],[2180,2376,"I was the one who hid the firearms."],[2376,2544,"It has nothing to do with Adam."],[2580,2751,"Arrest me if you must."],[2751,2932,"Grace, have you lost your mind?"],[2932,3051,"Possessing firearms"],[3051,3183,"is a capital offense."],[3224,3460,"Do you want to die for him?"],[3647,3843,"Meeting Adam in this life"],[3924,4035,"is my greatest blessing."],[4128,4296,"I would gladly die for him."],[4347,4428,"I would do so willingly."],[4443,4596,"Grace, stop talking nonsense."],[4596,4715,"Just because you found a box,"],[4715,4820,"does that mean I'm hiding firearms?"],[4820,4971,"Mr. Mercer has plenty of boxes at home."],[4992,5096,"Does that mean he's planning a rebellion?"],[5096,5196,"You insolent brat!"],[5235,5360,"Still stubborn at death's door."],[5375,5464,"Write this down."],[5464,5700,"I will personally go to the capital to report this,"],[5700,5871,"and have the entire family of the Fosters executed."],[5888,5960,"Open the box!"]],"25":[[24,76,"Open it!"],[76,119,"Yes, sir."],[483,575,"Adam,"],[575,651,"you're finished."],[671,840,"Your whole family is finished."],[2364,2455,"Inside this box,"],[2476,2607,"it's actually stones!"],[2607,2683,"Now,"],[2723,2916,"it seems the Mercers are the ones who are finished."],[2916,3103,"Mr. Lawson, I hold no office,"],[3123,3328,"so I'm not familiar with the law of Menolia."],[3356,3560,"What is the penalty for falsely accusing someone"],[3579,3688,"of possessing firearms?"],[3788,4020,"In this dynasty, possessing firearms"],[4020,4243,"is treated as treason."],[4264,4396,"A false accusation increases the penalty by three degrees."],[4396,4524,"The principal offender faces death by a thousand cuts,"],[4524,4807,"and accomplices are exiled three thousand miles."],[4807,5032,"Three thousand miles, Old Man Mercer"],[5079,5224,"I wonder if your old bones"],[5224,5307,"can survive the journey?"],[5564,5756,"Adam, don't say that."],[5775,5875,"From the very beginning,"],[5875,6003,"I have always believed in you."],[6003,6184,"But since this matter is of grave importance,"],[6228,6343,"I insisted on opening the box"],[6343,6464,"just to prove your innocence!"],[6528,6631,"It was all him!"],[6684,6804,"Lord Mercer, you"],[6804,6923,"You can't just abandon me!"],[6923,7012,"I was just following"],[7359,7423,"Old Man Mercer,"],[7492,7640,"you sure know how to save your own skin."],[7679,7871,"Fine, I'll let it slide."],[7979,8087,"Apologize to Mr. Lawson."],[8771,8835,"Sir Lawson,"],[8856,8904,"I'm sorry."],[8904,8943,"I was wrong."],[8971,9048,"I shouldn't have said you"],[9048,9195,"secretly gave weapons to Adam."],[9220,9284,"I was wrong."],[9300,9520,"Louder! I can't hear you!"]],"26":[[12,200,"Louder! I can't hear you!"],[220,343,"Louder! Louder!"],[343,475,"None of us can hear you!"],[475,577,"Can't hear you!"],[755,843,"I was wrong!"],[875,975,"That's more like it."],[1019,1240,"Since the official in charge of"],[1240,1319,"estate land is here,"],[1364,1475,"let's settle the matter"],[1475,1535,"regarding my estate."],[1596,1667,"Are you deaf?"],[1680,1792,"Hurry up and handle it"],[1792,1883,"for Adam!"],[2107,2139,"But..."],[2432,2539,"Adam,"],[2539,2632,"did they really"],[2644,2812,"wrongly accuse you?"],[2907,3100,"But knowing Thomas's style,"],[3123,3232,"he wouldn't have gone to such extremes"],[3232,3388,"without hard evidence."],[3428,3520,"Who knows?"],[3520,3692,"Maybe he suddenly lost his mind."],[3984,4100,"You rascal."],[4107,4335,"You may not be as literary as your father,"],[4335,4492,"but your ability to get things done"],[4524,4711,"certainly surpasses him."],[4896,5060,"Us, the Lawsons, in Pekon"],[5071,5196,"deal in more than"],[5196,5324,"just cosmetics."],[5324,5460,"We also have clothing stores"],[5492,5620,"and grain shops."],[5711,5935,"Since you plan to go into business,"],[5960,6064,"I'll have them"],[6064,6200,"collaborate closely with you."],[6215,6464,"The rates are negotiable."],[6648,6859,"Thank you, Mr. Lawson."],[7007,7187,"Thomas has joined Prince Hans's faction."],[7248,7448,"His revenge won't stop here."],[7520,7764,"My official rank is too low to act"],[7804,7912,"as a shield for you."],[7971,8068,"From now on,"],[8084,8215,"you must be careful."],[9171,9256,"Grace,"],[9312,9476,"we finally have a home of our own."],[9551,9623,"With me,"],[9668,9787,"you won't have to live in fear anymore."],[9876,9992,"Darling,"],[9992,10104,"meeting you"],[10104,10248,"has been the greatest blessing."],[10248,10376,"I'm already content."],[10528,10615,"This is just the beginning."],[10664,10728,"Wait here for me."],[10748,10940,"Darling, what are you doing?"],[11020,11084,"It's a secret."],[11751,11871,"Grace was willing to"],[11871,12007,"give up her life for me."],[12040,12159,"How could I ever let her down?"],[12300,12484,"I'll pick the biggest diamond ring this time."],[13028,13112,"This is the one."],[13112,13200,"Grace will definitely love it."]],"27":[[843,1019,"Grace, will you marry me?"],[1088,1172,"I'll make you happy."],[1519,1607,"Yes, I will."],[1807,1976,"Darling, get up, quickly."],[2003,2071,"The ground is cold."],[2164,2296,"Here, let me put this on for you."],[3660,3747,"It's wonderful."],[3911,4075,"You good-for-nothing!"],[4139,4264,"Today, the Mercers"],[4264,4424,"were almost exiled three thousand miles!"],[4460,4571,"Simon,"],[4600,4752,"I think you have a death wish."],[4779,4879,"Just to take credit,"],[4888,5015,"you dared to falsely accuse Adam"],[5015,5115,"of honoring firearms."],[5196,5352,"Sir, Young Master,"],[5384,5592,"my insider really did see"],[5592,5696,"Adam hiding the firearms"],[5696,5839,"in the woods."],[5864,5932,"Otherwise,"],[5932,6107,"the assassins wouldn't have failed."],[6156,6243,"It's just"],[6243,6392,"I don't know how they"],[6392,6500,"managed the switch"],[6500,6668,"and replaced the firearms with rocks."],[6695,6804,"You still dare make excuses!"],[6840,6892,"Hold on."],[7112,7279,"Did the spy you planted"],[7384,7504,"really see it?"],[7528,7576,"Sir,"],[7607,7700,"it is absolutely true."],[7715,7876,"They described it so vividly,"],[7876,7951,"it doesn't seem fake."],[8212,8404,"Father, what are you thinking?"],[8607,8756,"I'll trust you one more time."],[8915,9112,"Since Adam really has firearms,"],[9223,9334,"we'll try again."],[9456,9695,"Next to Adam's assigned estate,"],[9695,9795,"there is a mountain,"],[9795,10023,"home to about a hundred bandits."],[10023,10300,"Pay them to attack the estate."],[10431,10615,"Once we confirm Adam possesses firearms,"],[10779,10948,"I'll send troops"],[11104,11384,"to wipe him off the face of the earth!"]],"28":[[808,880,"Boss,"],[880,1003,"we've got everything ready."],[1003,1111,"I've also fully vetted"],[1111,1200,"all the hired hands."],[1224,1272,"There won't be any spies"],[1272,1416,"among us this time."],[1416,1516,"Good work."],[1632,1860,"Young Master, the wedding is ready."],[1860,1996,"I've even prepared"],[2019,2135,"the Madam's dowry myself."],[2151,2216,"Good."],[2332,2512,"Let the wedding begin!"],[2523,2607,"Great!"],[3592,3796,"First bow to Heaven and Earth!"],[4688,4796,"Bow!"],[5132,5260,"Rise!"],[5520,5743,"Second bow to the parents!"],[7343,7431,"Barry,"],[7571,7640,"stop crying."],[7743,7848,"Go take the seat."]],"29":[[56,187,"Young Master, I"],[187,335,"I am just a servant."],[396,563,"How could I sit in the seat of honor?"],[587,712,"It goes against tradition."],[712,803,"Tradition may not recognize you,"],[843,932,"but I do."],[1188,1264,"But"],[1283,1388,"Barry,"],[1424,1567,"you've managed our estate"],[1644,1800,"since my grandfather passed the exams."],[1844,1992,"You are my grandfather's cousin,"],[2076,2207,"my father's uncle,"],[2244,2376,"and my granduncle."],[2376,2448,"In my heart,"],[2516,2635,"you and I"],[2635,2732,"were never master and servant,"],[2816,2935,"but grandfather and grandson."],[3092,3360,"Now that my parents are gone"],[3435,3600,"and Grace's parents aren't coming,"],[3735,3835,"if you don't take the seat of honor,"],[3892,3947,"who will?"],[4056,4120,"Barry."],[4167,4279,"To me,"],[4279,4500,"you aren't a butler, but a grandfather."],[4535,4620,"If you don't take the seat,"],[4628,4815,"how can the ceremony continue?"],[4884,4984,"Yes, Barry."],[4984,5060,"Go on up."],[5100,5232,"Don't keep the bride and groom waiting."],[5596,5684,"Young Master,"],[5739,5911,"then I will take the seat."],[6848,7059,"Second bow to the elders."],[7700,7795,"Bow."],[8204,8348,"Rise."],[8559,8740,"The Young Master has really grown up."],[8740,8823,"It's wonderful."],[8851,8951,"Truly wonderful."],[8971,9187,"Husband and wife, bow to each other."],[10007,10107,"Bow."],[10576,10687,"Rise."],[11056,11323,"Groom, please remove the fan."],[11343,11548,"Come on, Sir. She's been waiting."],[12595,12792,"May your wishes come true."],[13191,13424,"Grace, I'm sorry for this humble wedding."],[13531,13615,"I swear,"],[13675,13896,"someday I'll repay you with a phoenix crown,"],[13940,14024,"an eight-bearer sedan chair,"],[14091,14180,"and ten miles of dowry."],[14375,14575,"I believe you. I always have."],[14575,14700,"The ceremony is complete!"],[14728,14863,"To the bridal chamber!"],[14870,15049,"Wonderful!"],[15231,15396,"Boss, Underboss."],[15463,15636,"Here is a banknote for one thousand taels."],[15663,15747,"Once the job is done,"],[15747,15856,"there's another thousand!"]],"30":[[0,80,"Once the job is done,"],[92,204,"there's another thousand!"],[604,736,"Two thousand taels?"],[883,1011,"This sum"],[1011,1167,"is earth-shattering."],[1327,1419,"Speak."],[1488,1671,"You want us to attack Foster Manor?"],[1739,1819,"How many should we kill?"],[1964,2112,"That depends on your mood."],[2180,2319,"You can kill them all,"],[2339,2532,"or kill none at all."],[2548,2728,"We have only one requirement."],[2764,2832,"Speak!"],[2896,3107,"Just prove that Adam"],[3107,3239,"is in possession of firearms."],[3243,3479,"Don't let them escape the manor,"],[3507,3700,"and the job is done!"],[3715,3824,"Is it that simple?"],[3824,3960,"Yeah, that simple!"],[4296,4375,"Deal!"],[5188,5315,"Once we catch Adam"],[5315,5424,"with evidence of hiding firearms,"],[5475,5552,"we won't need to shed any blood."],[5575,5692,"The law of Menolia"],[5692,5896,"will send them all to hell."],[6156,6428,"The wedding is done, and Foster Manor is secure."],[6504,6692,"Thomas won't dare to make a move."],[6728,6904,"The partnership documents from the Lawsons"],[6904,6987,"have also arrived."],[7040,7220,"The platform for making money is set."],[7259,7451,"Now it's time for me to shine."],[7535,7604,"To the warehouse."],[7876,8040,"The Lawsons happen to own clothing shops,"],[8076,8212,"and their clientele"],[8231,8335,"are high-class ladies."],[8359,8479,"If I bring the silk stockings,"],[8507,8623,"they'll be an instant hit."],[8631,8804,"I can let my wife model them first."],[8864,8984,"I couldn't do it before"],[8984,9064,"because of feudal customs,"],[9112,9340,"but now that we're married"],[10112,10184,"Let's go."],[10195,10331,"I'll have her try them on."],[10404,10504,"She'll definitely look great."],[10864,10968,"Everything is ready."],[11020,11123,"Just waiting for her to come back."],[11168,11215,"Master!"],[11415,11540,"Master, bad news!"],[11540,11648,"Something terrible has happened!"],[11659,11807,"Someone is attacking the estate!"],[11807,11864,"What?"]],"31":[[119,300,"Let's see how the Barrett handles."],[304,412,"Thomas."],[412,528,"I'm a peaceful man by nature,"],[532,651,"but things have come to this,"],[667,811,"and you've forced my hand!"],[903,1011,"Hey, inside there!"],[1088,1211,"Don't be afraid."],[1256,1448,"We're just passing through and got thirsty."],[1464,1632,"We just want some water."],[1644,1739,"Good sirs,"],[1776,1907,"we are busy with the harvest,"],[1907,2028,"so we have no water for you."],[2064,2135,"Another day,"],[2135,2335,"I'll send someone up the mountain with gold and silver."],[2367,2471,"Please leave now."],[2648,2855,"It doesn't matter if there's no water."],[2916,3064,"You come up the mountain with us,"],[3064,3267,"keep the brothers company for three days,"],[3307,3596,"and our trip won't be in vain."],[3596,3724,"Exactly!"],[4052,4211,"Open the damn door right now!"],[4243,4343,"Otherwise,"],[4343,4492,"don't blame us for getting rough!"],[4492,4656,"Open up! Yeah, open up!"],[4656,4828,"Open the door!"],[4828,4884,"Open it!"],[4884,4988,"Getting rough, huh?"],[5011,5096,"Fine."],[5120,5252,"I'll play with you then!"]],"32":[[364,536,"Boss! Boss!"],[751,975,"You... what kind of sorcery is this?"],[1003,1208,"How can you kill from a distance?"],[1227,1416,"Why don't you try it and find out?"],[1551,1603,"I"],[2000,2080,"I get it."],[2103,2328,"Firearms! It must be firearms!"],[2328,2532,"If we just surround them without attacking,"],[2532,2635,"they're dead meat."],[2635,2803,"Everyone, take cover!"],[2803,2871,"Take cover!"],[2871,2951,"Run!"],[3051,3264,"With a Barrett in hand, the world is mine."],[3288,3420,"How could you possibly survive?"],[4335,4511,"The recoil on this Barrett is insane."],[4528,4660,"My body can barely handle it."],[4839,4920,"Good thing"],[4920,5039,"none of them escaped."],[5575,5656,"Husband."],[5728,5807,"My dear."],[5860,5947,"These people"],[5947,6088,"have all been taken care of."],[6096,6320,"Husband, how did you do that?"],[6367,6564,"I'll explain it to you later."],[6640,6804,"Burn all these bodies immediately."],[6859,6940,"Yes, sir."],[6940,7020,"Let's go."],[7143,7264,"Constantly playing defense"],[7300,7459,"isn't the way to survive."],[7479,7548,"Barry."],[7584,7692,"Go look into the daily routine"],[7692,7820,"of Thomas's only son,"],[7820,7943,"Henry."],[7964,8023,"On it."],[8151,8231,"Husband,"],[8279,8387,"what are you planning?"],[8428,8551,"We just got married,"],[8579,8764,"and Thomas already hired hitmen to kill us."],[8764,8923,"If I hadn't stepped in today,"],[8923,9104,"no one in our estate would have survived."],[9156,9256,"So,"],[9256,9364,"we have to strike back!"]],"33":[[40,156,"So you're saying"],[191,383,"all those bandits are dead?"],[383,532,"Not a single survivor?"],[532,736,"And you don't even know what Adam used?"],[951,1127,"Reliable intel just confirmed that"],[1175,1291,"there are no firearms missing"],[1291,1443,"from the armory whatsoever."],[1443,1635,"If I hadn't watched that kid grow up,"],[1635,1855,"I'd suspect he had superpowers."],[1876,2023,"It's just too freaky."],[2023,2148,"If worse comes to worst,"],[2148,2239,"I'll have to beg my mentor"],[2239,2428,"in Capitarrea for help."],[2428,2492,"Right, right."],[2492,2583,"Dad,"],[2583,2703,"your mentor"],[2703,2912,"is a favorite of Prince Hans."],[2932,3076,"You just have to say the word,"],[3096,3296,"and Adam is dead meat."],[3296,3384,"Heh heh heh."],[3384,3484,"Unless it's absolutely necessary,"],[3535,3703,"we shouldn't use that connection."],[3715,3828,"Investigate him."],[3892,4043,"I want to know everything about Adam."],[4043,4120,"Yes, sir."],[4224,4492,"Thomas is a powerful official in Pekon."],[4492,4635,"To fight him,"],[4635,4956,"we must fortify our base and stockpile resources."],[5303,5467,"Honey, what is this?"],[5715,5828,"Why does it smell like soybean meal"],[5828,5939,"and wheat bran?"],[5960,6111,"It smells delicious."],[6124,6215,"Can I eat it?"],[6215,6279,"Wait!"],[6375,6504,"My friend from overseas"],[6504,6576,"sent me this."],[6576,6712,"It's pig feed."],[6928,7120,"Is 'overseas' some kind of wonderland?"],[7120,7268,"Even the pigs eat so well there!"],[7268,7420,"Grace, let's not talk about that now."],[7448,7604,"Tell all the shops in our estate"],[7604,7720,"to start raising pigs."],[7720,7828,"Raise as many as they can."],[7856,8007,"We'll provide the feed."],[8040,8092,"Mmh."],[8107,8212,"Okay, darling."],[8212,8279,"Also,"],[8279,8387,"pick a few children from the estate"],[8387,8479,"who show promise for studying."],[8479,8587,"I'll tutor them personally."],[8587,8820,"We'll be staying here for a long time,"],[8820,8964,"so we need to build a solid foundation."],[8964,9035,"Okay."],[9068,9148,"Young Master."],[9212,9276,"Barry,"],[9312,9404,"did you find out about Henry's"],[9404,9468,"daily routine?"]],"34":[[0,163,"Thomas's son, Henry,"],[163,372,"drinks at the Carefree Tower every night,"],[391,604,"then visits a brothel."],[644,724,"What else?"],[744,916,"One of Henry's lackeys"],[916,1040,"is Simon!"],[1208,1403,"No wonder Simon acts so arrogant."],[1411,1707,"Henry has been pulling the strings all along."],[1728,1839,"The Mercers"],[1871,2071,"drove my father to his death,"],[2107,2248,"stripped me of my title,"],[2248,2328,"and even tried to assassinate me"],[2328,2487,"twice."],[2487,2671,"Do they really think I'm a pushover?"],[2671,2764,"Young Master,"],[2776,2887,"killing someone in broad daylight"],[2903,3064,"is a capital crime."],[3135,3247,"He's right, darling."],[3339,3496,"Who said I was going to kill anyone?"],[3520,3696,"Honey, give me some money."],[3752,3856,"Tonight,"],[3856,4020,"I'm going to pay Henry a visit."],[4047,4164,"As the saying goes:"],[4196,4303,"'Antibiotics with wine,"],[4303,4424,"is the end of the line.'"],[4424,4511,"My dear Henry,"],[4511,4707,"you'll get to enjoy something from six hundred years in the future."],[4707,4803,"Medical advancements."],[4835,4971,"Consider yourself lucky."],[5035,5324,"Handsome, come up for a drink!"],[5324,5524,"We have some fresh beauties today!"],[5524,5628,"Hurry up and come in!"],[5681,5756,"Come check us out!"],[5854,5947,"Step right up, hurry!"],[5947,6152,"Ancient brothels sure are kick-ass!"],[6459,6548,"Yeah."],[6600,6687,"This is exactly the vibe."],[6723,6871,"Nate, let's go!"],[7028,7164,"- Wait for me, Boss! - Come on in, sir!"]],"35":[[352,463,"Ouch!"],[816,927,"Oh, sorry about that."],[975,1100,"Weak kidneys... oh my."],[1356,1448,"Hmph."],[1917,2012,"That way, over there."],[2374,2461,"Sir,"],[2477,2646,"let me feed you."],[2964,3035,"Boss,"],[3035,3144,"it's done."],[3155,3228,"Good job."],[3307,3407,"Thomas,"],[3407,3575,"my counterattack starts now."],[3575,3771,"I hope you can handle it!"],[4339,4420,"What are you looking at?"],[4464,4611,"Don't get attached to this place when you're rich."],[4635,4807,"This isn't a place for decent people."],[4807,5003,"Boss, you don't know,"],[5003,5132,"my wife,"],[5132,5307,"if she knew I came to a place like this,"],[5307,5435,"she'd skin me alive."],[5603,5679,"Let's go."],[5996,6143,"Boss! Boss! Boss!"],[6224,6431,"Isn't that Adam, Mr. Foster?"],[6431,6604,"He doesn't usually come here."],[6604,6735,"What's going on?"],[6840,7000,"That son of a b*tch Adam,"],[7023,7176,"I don't know what spell he's under,"],[7176,7315,"but he's suddenly completely different!"],[7348,7504,"He not only took out the assassins I sent,"],[7504,7584,"but also wiped out"],[7595,7779,"the bandits attacking the city."],[7820,7871,"Humph."],[7992,8204,"Don't be angry, Sir."],[8268,8340,"Come,"],[8340,8456,"have a drink!"],[8676,8776,"That Adam,"],[8776,8995,"gained such glory passing the exams so young,"],[8995,9251,"but his father actually dared to oppose Prince Hans."],[9284,9420,"He really has a death wish!"],[9440,9540,"But,"],[9540,9715,"he won't be strutting around much longer."],[9759,9968,"Once my father handles things on his end,"],[9968,10156,"I'm going to humiliate Grace"],[10156,10292,"right in front of his face."],[10595,10764,"This... This Grace,"],[10764,10876,"is truly a rare"],[10876,10995,"beauty."],[11104,11335,"Sir, is she prettier than me?"],[11387,11507,"Of course not."],[11528,11687,"You're much prettier."],[11712,11792,"Well,"],[11807,11948,"enough talk."],[11948,12151,"I've got business to attend to."],[12276,12412,"Let's go, beautiful!"],[12819,12875,"Fill it up!"],[12984,13119,"Bad news!"],[13119,13203,"Mr. Mercer,"],[13203,13384,"Mr. Mercer had a stroke in bed!"],[13463,13559,"What?"]],"36":[[375,479,"Th-This"],[479,624,"How did this happen?"],[624,796,"Mr. Mercer was fine just a moment ago."],[796,956,"How could he suddenly have a stroke?"],[956,1056,"I don't know!"],[1056,1183,"What on earth is going on?"],[1183,1372,"I... I don't know either!"],[1435,1551,"Before we came in,"],[1551,1676,"we only drank one glass of wine."],[1676,1783,"It was just one glass,"],[1783,1939,"there couldn't have been anything wrong with it!"],[2000,2160,"Sir Mercer only has this one son."],[2187,2276,"Now that Mr. Mercer is dead,"],[2323,2483,"the sky is falling over Pekon!"],[2483,2612,"Hurry, go investigate"],[2635,2755,"who visited the brothel tonight."],[2823,2996,"I... I think I just saw"],[2996,3135,"Adam, Mr. Foster."],[3160,3300,"Adam?"],[3332,3647,"Could he be the one responsible?"],[3700,3956,"The wine in Menolia's brothels is terrible."],[3956,4164,"I'd rather drink my 'happy juice'."],[4796,4939,"Coke is the best."],[5003,5100,"Boss,"],[5100,5284,"this water is so black."],[5284,5428,"Is it safe to drink?"],[5428,5556,"Just drink it since I gave it to you."],[5556,5632,"If you don't like it, give it back."],[5632,5720,"Hey, hey, hey!"],[5720,5800,"If you gave it to me, Boss,"],[5800,5964,"I'm definitely going to drink it!"],[7084,7287,"Whoa,"],[7312,7423,"Boss,"],[7456,7679,"this stuff is sweeter than sugar water."],[7728,7828,"I didn't lie to you,"],[7979,8059,"did I, Andre?"],[8087,8300,"Confucius said, 'The way of the superior man"],[8300,8443,"is concealed yet grows brighter daily,"],[8512,8659,"while the way of the petty man"],[8659,8895,"is showy yet perishes daily!'"],[8895,9140,"A bunch of idiots who only know how to quote texts."],[9148,9240,"What did you say?"]],"37":[[20,124,"I said,"],[139,239,"you are a bunch of idiots who only"],[239,404,"know how to quote texts!"],[428,487,"What?"],[508,604,"Did I say something wrong?"],[632,835,"You talk big, kid."],[843,956,"Do you hold an academic title?"],[988,1111,"My master here"],[1111,1219,"used to be a famous"],[1219,1459,"teenage Graduate!"],[1591,1664,"Are you Adam,"],[1680,1832,"the young Graduate?"],[1860,1971,"And is your father Gregory,"],[2016,2267,"the former Vice Prefect of Beiping?"],[2271,2355,"That is exactly who I am."],[2435,2555,"How do you know who I am?"],[2571,2783,"I, Adrian Everett, am the Imperial Grandson."],[2783,2976,"Revealing that would surely cause a scene."],[2976,3135,"To avoid unnecessary trouble,"],[3135,3303,"I'll just make up an identity."],[3315,3396,"Mr. Foster,"],[3424,3535,"my name is Andre."],[3535,3703,"May I ask what that is"],[3703,3779,"in your hand?"],[3796,3920,"Maritime trade is banned right now."],[3960,4139,"These men clearly have high status."],[4160,4324,"I can't say it's from an overseas friend."],[4324,4371,"Oh,"],[4400,4596,"this was brewed personally by my father."],[4639,4779,"I happen to have another bottle."],[4784,4867,"Here, try some!"],[5211,5400,"How do you open this?"],[5424,5503,"Let me help you!"],[6328,6396,"Here,"],[6848,6928,"Your Hig—"],[7007,7095,"uh, Sir."],[7095,7179,"Let me take a sip first."],[7179,7387,"If it's safe, you can try it."],[7707,7923,"Someone has to taste his food first?"],[7931,8168,"Is this kid a big shot or something?"],[8287,8507,"Wow, this is delicious!"],[8507,8740,"It's even better than the fruit wine"],[8740,8859,"at Best Taste in Capitarrea!"],[8859,8940,"Really?"],[8943,9148,"Sir, it's safe."],[10095,10240,"This truly tastes like something from heaven."],[10323,10420,"Is there a recipe for this?"],[10420,10515,"How is it brewed?"],[10584,10735,"Even if I gave you the recipe,"],[10759,10948,"you wouldn't be able to make Cola."],[10968,11176,"Only my late father knew the secret,"],[11176,11343,"and since he has passed away,"],[11343,11551,"even I can't brew it."],[11564,11620,"I didn't expect you to be"],[11620,11815,"the former child prodigy of the Fang family."],[11856,12107,"Let me test you tonight"],[12107,12228,"to see if you have neglected"],[12228,12456,"your studies all these years."],[12500,12676,"Fine. Bring it on!"]],"38":[[0,80,"Let me ask you,"],[148,475,"what do you think of Menolia's capital relocation?"],[475,628,"It is a good thing."],[628,708,"Nonsense!"],[716,883,"Why abandon the fertile South"],[908,1088,"for this barren, frigid wasteland?"],[1088,1203,"How is that a good thing?"],[1419,1567,"The Son of Heaven guards the gates,"],[1588,1732,"and the sovereign protects the realm."],[1776,1835,"This alone"],[1835,2100,"is the unyielding backbone of Menolia."],[2255,2328,"Excellent."],[2367,2507,"There truly are hidden talents in the wild."],[2528,2739,"I didn't expect a few words from this kid"],[2739,2839,"to actually win the favor of"],[2839,3080,"the Imperial Grandson of Menolia, Adrian Everett!"],[3151,3224,"Sir,"],[3235,3392,"how can this boy's arrogant nonsense"],[3392,3543,"be considered good?"],[3543,3771,"Menolia's external threats lie in the North,"],[3771,3964,"yet Capitarrea is far in the South."],[4000,4103,"If a crisis arises,"],[4124,4324,"may I ask you learned scholars,"],[4343,4447,"who will be there to defend us?"],[4479,4611,"Menolia has the Nine Garrisons,"],[4611,4720,"with generals as numerous as clouds"],[4720,4835,"and soldiers like rain."],[4835,5015,"How would barbarians dare to encroach?"],[5032,5175,"We'll just send a fierce general when the time comes."],[5175,5296,"How could we fail?"],[5356,5432,"(Sighs)"],[5432,5575,"Why are you sighing?"],[5575,5707,"You bunch of idiots."],[5788,6007,"The Founding Emperor of Menolia"],[6043,6164,"expelled the barbarians"],[6164,6275,"and restored our civilization."],[6275,6471,"Even he considered the North vital."],[6471,6531,"Do you really think"],[6556,6812,"you have more foresight"],[6812,6971,"than the Founding Emperor?"],[7031,7268,"Our land has always faced Northern threats."],[7284,7487,"Must we wait for another Yamen"],[7487,7620,"before we learn our lesson?"],[7620,7679,"You scoundrel!"],[7768,7887,"Menolia has already driven the Yuan"],[7887,7995,"to the barren wastelands."],[7995,8100,"Where is the crisis?"],[8151,8348,"You claim the North is a constant threat,"],[8351,8520,"but did the Tyrannical Qin fall to the North?"],[8520,8692,"Did the Mighty Han perish because of the North?"],[8692,8923,"Did the Sui Dynasty end due to the North?"],[9064,9159,"Don't you see?"],[9192,9400,"Emperors Wen and Jing saved for 39 years,"],[9423,9584,"giving Emperor Wu the resources"],[9584,9768,"to launch 15 campaigns against the Xiongnu."],[9787,10015,"Do you think you have more vision"],[10015,10179,"than Emperor Wu, Emperor Wen,"],[10179,10312,"and Emperor Jing?"],[10440,10679,"Do you know why the Song Dynasty was rich"],[10679,10856,"yet still lost its kingdom?"],[10871,10964,"Because they believed,"],[11007,11259,"\"Only the scholars named at Donghua Gate"],[11259,11428,"are true men!\""],[11659,11771,"Let's go, Nate."],[11771,11856,"Hey, Boss."],[11856,11968,"Which one is mine?"],[11968,12092,"Hey, Boss, wait for me."],[12140,12295,"This man has great talent."],[12295,12531,"You must investigate everything about him!"],[12559,12651,"Yes, sir."]],"39":[[0,220,"Oh, my son!"],[372,496,"Sir Lawson."],[520,724,"Don't you think it's too much of a coincidence?"],[724,903,"When my son died in the act,"],[903,1096,"Adam was right there?"],[1235,1348,"My son"],[1348,1667,"must have been killed by Adam!"],[1667,1728,"Exactly."],[1760,1916,"I also heard from the madam"],[1932,2100,"that Adam never visits brothels."],[2132,2235,"So why is it so coincidental"],[2255,2387,"that he went tonight?"],[2387,2607,"And the moment he arrived, the Young Master"],[2639,2876,"I want Adam dead."],[2903,3139,"I want him dead!"],[3176,3296,"Without evidence,"],[3296,3435,"how can you make such a claim?"],[3435,3564,"It was definitely Adam!"],[3735,3888,"As long as you have no evidence,"],[3907,4092,"I will risk my official post"],[4092,4228,"to fight you on this!"],[4260,4328,"Humph."],[4524,4628,"Fine."],[4696,4871,"A mere magistrate"],[4952,5139,"dares to speak to me like this!"],[5364,5539,"Go find a witness,"],[5588,5679,"then arrest Adam"],[5679,5832,"and drag him to court."],[5884,6171,"I will make sure Adam dies!"],[6371,6451,"Reporting, Your Highness."],[6507,6671,"We have investigated Adam's background."],[6684,6831,"Adam's father, Gregory,"],[6831,7104,"was dismissed and his home confiscated for impeaching Prince Hans."],[7151,7379,"Adam's academic title was revoked as well."],[7440,7556,"What did his father accuse Prince Hans of?"],[7628,7784,"He accused Prince Hans of harboring"],[7784,7879,"assassins in Pekon."],[8135,8356,"The Imperial Guard investigated it last year."],[8368,8535,"Prince Hans was indeed hiding assassins in Pekon."],[8576,8656,"The evidence is irrefutable."],[8692,8871,"But Grandfather suppressed the matter."],[8979,9059,"It seems now that"],[9059,9287,"Adam's family was falsely accused."],[9379,9512,"He is a man of great talent."],[9543,9643,"Even with his grievances,"],[9700,9868,"he still cares about the country."],[9992,10071,"He could be of use to me."],[10268,10471,"Prepare the carriage. I'll visit him today."],[10507,10607,"If he manages to"],[10607,10764,"impress me,"],[10787,11000,"I will help restore his academic title."],[11051,11112,"Yes, Your Highness."]],"40":[[372,451,"Honey,"],[659,832,"what are these things?"],[832,935,"Some friends from overseas"],[935,1024,"sent them to me."],[1024,1180,"By the way, honey,"],[1180,1340,"every household on the estate"],[1340,1443,"is raising pigs now."],[1443,1540,"As for the pig feed,"],[1540,1651,"I've had Nate"],[1651,1732,"distribute it to everyone."],[1771,1855,"Also,"],[1883,1980,"I found a child on the estate"],[1980,2128,"who shows promise as a scholar."],[2180,2296,"With a wife like you,"],[2296,2416,"what more could I ask for?"],[2516,2683,"Come here. Let me hug you."],[2883,2976,"Mr. Foster"],[3119,3187,"Oops!"],[3187,3303,"I didn't see anything!"],[3611,3800,"Uh, honey"],[3800,3964,"You and Manager Walker talk."],[3964,4028,"I'll be going now!"],[4028,4084,"Hey"],[4520,4603,"Mr. Foster,"],[4603,4743,"I didn't interrupt anything important, did I?"],[4784,4875,"What do you think?"],[5107,5188,"Just kidding."],[5207,5307,"Are you here to stock up?"],[5367,5584,"Yes, thanks to you."],[5639,5860,"I'm now the manager for"],[5860,6007,"all the Lawsons' properties."],[6007,6115,"That's great news!"],[6120,6220,"Come look at this!"],[6564,6679,"Wow."],[6779,7007,"How is this flour so snow-white?"],[7007,7164,"Is this meant for the gods?"],[7164,7268,"You're exaggerating, Manager Walker."],[7268,7443,"My overseas friends brought this."],[7471,7692,"People overseas eat this kind of flour."],[7751,7848,"This time,"],[7848,7951,"my friend brought"],[7951,8120,"plenty of good things for you!"]],"41":[[80,187,"That's wonderful."],[227,372,"You have no idea, Mr. Foster."],[420,520,"Ever since our rouge shop"],[520,667,"started stocking your products,"],[712,843,"the noble ladies of Capitarrea"],[851,980,"have gone wild!"],[1008,1080,"They"],[1088,1211,"have given our products"],[1211,1488,"rave reviews!"],[1519,1660,"As long as you didn't lose money."],[1660,1703,"Oh,"],[1783,1907,"how could I lose money?"],[1948,2023,"Let me tell you,"],[2055,2176,"Duchess Saxon,"],[2207,2351,"a top-tier noble,"],[2403,2500,"didn't manage to get"],[2500,2632,"our first batch,"],[2655,2755,"so she lost face"],[2767,2864,"among the socialites."],[2900,2960,"So this time,"],[2980,3044,"she ordered ten"],[3071,3203,"in one go."],[3243,3356,"Duchess Saxon"],[3384,3500,"is Caleb Carver's granddaughter."],[3571,3747,"They are the pillars of Menolia's nobility."],[3843,4039,"These ten lip balms came just in time."],[4156,4303,"This is perfect."],[4339,4507,"Now I can finally fulfill my duty."],[4596,4667,"As for this batch,"],[4703,4796,"at fifty taels apiece,"],[4820,4903,"I'll take them all."],[5043,5107,"Here is"],[5111,5232,"fifteen hundred taels of silver."],[5243,5284,"Please take it."],[5284,5460,"Oh my, this is far too much."],[5496,5632,"Take it, please."],[5692,5739,"In that case,"],[5800,5871,"I will accept it."],[5932,5996,"Wow."],[6052,6164,"Thirty pieces of cheap junk"],[6192,6356,"sold for fifteen hundred taels."],[6388,6504,"We made a fortune."],[6571,6620,"Young Master,"],[6668,6715,"bad news!"],[6740,6807,"The officers are here!"],[7235,7304,"Adam,"],[7359,7479,"you committed murder."],[7523,7640,"Your crime has been exposed."],[7671,7751,"Seize him!"]],"42":[[20,100,"Seize him!"],[119,187,"Simon,"],[252,375,"you're just a petty Grain Captain."],[391,483,"Who gave you the right"],[504,583,"to bring these officers"],[583,663,"straight to my door?"],[755,948,"The Assistant Prefect, of course."],[996,1064,"Manager Walker,"],[1100,1208,"if you have a problem with it,"],[1232,1380,"you can go find him"],[1380,1480,"and argue your case!"],[1503,1535,"You"],[1664,1728,"May I ask,"],[1783,1883,"what happened?"],[1935,2087,"Why are you taking me to court?"],[2116,2235,"Stop playing dumb."],[2328,2467,"You poisoned Mr. Mercer,"],[2467,2580,"which is a capital crime!"],[2612,2707,"Arrest him!"],[2771,2867,"Ahhh!"],[2896,2935,"Stop!"],[3271,3420,"My husband didn't kill anyone!"],[3520,3647,"You're falsely accusing an innocent man!"],[3760,3796,"Honey,"],[3884,3947,"put down the rake,"],[3967,4043,"don't hurt yourself."],[4200,4332,"I can't let them take you."],[4375,4479,"If they try to drag you away,"],[4500,4592,"I'll go straight to the Emperor!"],[4628,4647,"Hmph."],[4735,4820,"Appeal to the Emperor?"],[4835,4964,"You'd have to face a hundred strokes first!"],[5039,5160,"With that tiny frame of yours,"],[5188,5279,"could you even survive that?"],[5296,5403,"I'd take five hundred strokes if I had to!"],[5403,5515,"None of your business!"],[5632,5664,"Honey,"],[5715,5752,"listen to me."],[5800,5888,"Give me the rake."],[6339,6400,"I'll go with them."],[6443,6564,"You stay here at home."],[6607,6692,"I'll be fine."],[6735,6771,"Take him away."]],"43":[[40,80,"Move it!"],[156,235,"No need for that."],[327,400,"I can walk by myself."],[455,475,"Hmph."],[1159,1232,"Sir!"],[1296,1324,"Oh no."],[1356,1408,"Madam."],[1451,1559,"Hey, Nate,"],[1559,1648,"follow them, quick."],[1671,1800,"Let me know immediately if anything happens!"],[1812,1867,"Yes, Madam."],[2035,2176,"Now that he's left Foster Manor"],[2187,2244,"Now,"],[2260,2344,"I'm the pillar of this family."],[2387,2448,"I cannot panic."],[2492,2571,"I must hold down the fort"],[2592,2692,"for my husband."],[3767,3835,"I am Andre."],[3871,3928,"May I ask where"],[3947,4024,"the master of Foster Manor,"],[4035,4120,"Mr. Foster, is right now?"],[4160,4260,"My husband has been"],[4279,4364,"falsely accused"],[4379,4464,"of poisoning Henry."],[4539,4632,"Without a shred of evidence,"],[4643,4752,"he was taken by the authorities!"],[4979,5032,"Sir,"],[5092,5179,"last night,"],[5220,5332,"the Assistant Prefect of Pekon,"],[5360,5532,"Thomas's son, Henry,"],[5575,5747,"was drinking in a brothel"],[5747,5856,"and died in the saddle."],[5892,5952,"Now,"],[5956,6096,"the whole city knows about it."],[6152,6296,"The son of an imperial official"],[6332,6487,"dying in a brothel like that"],[6523,6631,"It's a huge joke!"],[6715,6792,"I'd really like to see"],[6840,6948,"how they plan to judge this!"],[7092,7131,"Madam,"],[7223,7295,"I will take my leave."],[7651,7692,"No."],[7723,7815,"I can't just sit here and wait for the end."],[7868,7948,"Go and tell Barry"],[7948,8023,"to come to the main hall."],[8059,8107,"Yes, Madam."]],"44":[[167,296,"That savage Thomas"],[391,540,"has driven us into a corner."],[651,696,"I"],[755,951,"will follow my husband in death."],[1032,1303,"I regret not leaving an heir for the Fosters."],[1403,1559,"If I must die, then so be it."],[1692,1919,"But Prince Hans' lackeys run wild,"],[1983,2103,"and without seeing their downfall,"],[2216,2360,"I cannot rest in peace."],[2528,2560,"Your Sister,"],[2623,2716,"Farewell."],[3220,3271,"Madam,"],[3300,3320,"you"],[3356,3488,"what are you doing?"],[3564,3624,"Barry."],[3703,3920,"My husband treats you like family,"],[3996,4192,"and I consider you my closest kin, too."],[4267,4307,"However,"],[4424,4588,"if my husband doesn't return,"],[4667,4756,"I beg you,"],[4815,4952,"after I take my own life,"],[5039,5152,"deliver this letter"],[5235,5507,"to Duke Rory's Manor in Capitarrea."],[5656,5703,"Du"],[5764,5879,"Duke Rory's Manor?"],[6448,6520,"I won't explain"],[6531,6679,"the details to you now."],[6715,6907,"But once you deliver this farewell letter,"],[7023,7164,"they will naturally reveal"],[7164,7231,"the truth to you!"],[8107,8223,"Madam,"],[8287,8551,"for the Young Master to have a wife like you,"],[8551,8876,"it is a blessing of three lifetimes."],[8987,9084,"For the Fosters"],[9084,9284,"to have a mistress like you,"],[9387,9692,"is a fortune for three generations."],[9712,9771,"Madam,"],[9851,10112,"please accept my humble bow!"],[10487,10564,"Go now."],[10723,10868,"Madam!"],[12087,12164,"My husband,"],[12287,12468,"you must come back safely!"],[13184,13263,"Let's see"],[13284,13447,"if this young scholar's skills"],[13463,13571,"are as sharp"],[13580,13675,"as his mouth!"]],"45":[[104,163,"Court is in session."],[180,579,"Order!"],[663,767,"Who stands before the court?"],[791,919,"Former Scholar, Adam."],[959,1075,"The audacity!"],[1140,1280,"You have already been stripped of your titles,"],[1296,1432,"yet you still dare to act so arrogant!"],[1472,1524,"On your knees!"],[1632,1696,"Prefect,"],[1764,1944,"although my nephew has lost his titles,"],[1976,2151,"thanks to His Majesty's mercy,"],[2216,2351,"he is allowed to retake the exams."],[2416,2600,"Even if he can retake them,"],[2635,2732,"do you really think"],[2800,2987,"he can pass again?"],[3144,3164,"Hmph."],[3311,3379,"Thomas,"],[3443,3588,"you didn't pass until you were forty."],[3624,3735,"Naturally, you wouldn't understand the talent"],[3743,3935,"of my nephew, who passed at fifteen."],[3971,4032,"I believe that"],[4067,4164,"if my nephew is given"],[4164,4239,"another chance,"],[4300,4428,"he will definitely pass again!"],[4688,4779,"Henry is already dead,"],[4800,4900,"and Adam is a genius who passed the exams"],[4900,4979,"at fifteen."],[5039,5184,"Why am I still kissing the Mercers' ass?"],[5220,5347,"Besides, last night,"],[5356,5507,"I really didn't see Adam."],[5635,5720,"Ahem, well,"],[5760,5928,"let's stick to the facts."],[5971,6032,"Adam,"],[6071,6147,"let me ask you."],[6188,6252,"Last night,"],[6275,6396,"did you go to the brothel?"],[6451,6535,"Last night,"],[6584,6631,"I was"],[6720,6776,"Prefect,"],[6823,6940,"I don't think we need to question him further."],[6971,7123,"My son had a deep grudge against Adam,"],[7123,7235,"so he had a motive."],[7248,7364,"I'm certain Adam poisoned"],[7364,7459,"and killed my son."],[7648,7700,"Adam,"],[7731,7856,"what do you have to say for yourself?"],[7904,8015,"Your son Henry"],[8015,8200,"died in the act at the brothel."],[8228,8392,"Just because I was there too,"],[8404,8540,"does that make me the killer?"],[8615,8712,"Is it not true?"]],"46":[[88,176,"Then, Mr. Mercer, if you were to"],[176,331,"drop dead right here in this court,"],[356,524,"would that mean all of us"],[544,612,"murdered you?"],[667,771,"Menolia law mandates that"],[819,896,"for any conviction,"],[908,1108,"there must be both witnesses and physical evidence."],[1180,1251,"May I ask,"],[1283,1380,"where are the witnesses?"],[1424,1500,"And where is the evidence?"],[1644,1732,"Witnesses?"],[1800,1860,"I have one."],[2151,2323,"Did you see this man last night?"],[2380,2455,"My good man,"],[2519,2671,"are you aware that under Menolia law,"],[2700,2748,"the penalty for false accusation"],[2755,2848,"is tripled?"],[2900,3003,"Lord Mercer had me arrested"],[3003,3183,"without any physical evidence,"],[3203,3384,"based entirely on unfounded rumors."],[3467,3535,"Are you sure"],[3535,3688,"you want to be his accomplice?"],[3764,3803,"Your Honor,"],[3832,3911,"last night,"],[3992,4084,"I definitely did not see Mr. Foster."],[4084,4115,"You"],[4220,4271,"Mr. Mercer,"],[4356,4496,"don't ask me to commit perjury!"],[4547,4715,"Mr. Foster passed the provincial exam at fifteen."],[4743,4928,"Although His Majesty stripped him of his title,"],[4952,5000,"he also gave him"],[5000,5107,"a chance to retake the exam."],[5135,5243,"If he passes again,"],[5279,5400,"I'd be done for if I committed perjury!"],[5411,5443,"You"],[5788,5856,"Mr. Foster"],[5884,6011,"really is the prodigy"],[6011,6100,"who passed the exam at fifteen."],[6175,6292,"Even stripped of his rank,"],[6347,6451,"standing here in court,"],[6507,6684,"he remains so calm and composed."],[6715,6787,"I never expected"],[6800,6868,"to encounter such a genius"],[6868,7004,"in my lifetime."],[7087,7148,"Indeed."],[7168,7312,"He critiques current affairs"],[7328,7428,"with such incisive sharpness."],[7479,7579,"Even on trial,"],[7604,7720,"he maintains his grace."],[7784,7859,"This proves"],[7876,8064,"he is definitely not just a pretty face."],[8259,8320,"Your Highness,"],[8368,8487,"you've found a real treasure!"],[8579,8704,"Go and put an end to this farce."],[8720,8851,"I will go ask my Imperial Grandfather"],[8892,9012,"to restore Mr. Foster's title."],[9131,9171,"Yes, Your Highness."],[9231,9331,"Hahaha"]],"47":[[16,187,"Hahaha"],[455,536,"Who are you?"],[571,691,"How dare you barge into the court?"],[867,935,"My goodness,"],[948,1083,"why is the Grand Tutor here?"],[1108,1219,"He is the Emperor's"],[1235,1396,"hand-picked teacher for the Imperial Grandson."],[1424,1535,"Isn't that one of the scholars"],[1535,1639,"who was with that young master"],[1639,1707,"the other night?"],[1939,2019,"Sir Summers."],[2051,2187,"Why have you come in person?"],[2219,2355,"Why is this fourth-rank official"],[2364,2483,"so respectful to him?"],[2512,2616,"Who exactly is"],[2628,2751,"that young master?"],[2803,2871,"Magistrate,"],[2916,3032,"is the trial finished?"],[3328,3428,"Oh,"],[3428,3635,"yes, yes, it's finished."],[3647,3803,"And the verdict?"],[3860,3915,"Uh,"],[4003,4188,"the verdict is"],[4188,4284,"insufficient evidence."],[4284,4411,"Acquitted and released immediately."],[4439,4471,"You"],[4507,4571,"Good."],[4652,4800,"Dismiss the court, then."],[4800,4835,"Yes, right away."],[4888,4956,"Court dismissed!"],[5232,5275,"Magistrate,"],[5320,5456,"my son's death hasn't been investigated."],[5456,5560,"How can you dismiss the court now?"],[5575,5632,"Shut up!"],[5647,5767,"I said dismissed, so it's dismissed."],[5779,5871,"You think you can tell me what to do?"],[5892,5932,"Get lost!"],[6412,6531,"This isn't over."],[6540,6620,"Just you wait."],[6651,6692,"Hmph."],[6956,7043,"Thank you for your help, Sir Summers."],[7095,7156,"Well,"],[7176,7256,"that was all you."],[7312,7387,"It had little to do"],[7415,7531,"with me."],[7587,7664,"I'm leaving."],[7707,7840,"Take care, Sir Summers."],[8484,8515,"Boss,"],[8535,8635,"you're not dead?"],[8704,8807,"Can't you wish me well?"],[9020,9079,"Thomas."],[9112,9171,"You're right."],[9195,9328,"This is far from over."],[9395,9504,"You've brought such misery to my family."],[9535,9587,"If you don't die,"],[9612,9700,"I will never find peace."]],"48":[[312,348,"You"],[379,428,"Just now,"],[444,544,"why did you adjourn the court?"],[575,620,"Obviously,"],[636,755,"I still had several moves left."],[767,864,"If you had just held on,"],[867,935,"we definitely could have"],[935,1059,"pinned the guilt on Adam."],[1059,1132,"And then,"],[1132,1324,"Adam would have been done for!"],[1383,1459,"Thomas,"],[1475,1612,"are you out of your mind?"],[1619,1655,"Do you"],[1680,1748,"have any idea"],[1760,1896,"who the official who came in last"],[1896,1983,"actually works for?"],[2107,2180,"My mentor"],[2180,2316,"is a favorite of Prince Hans."],[2316,2392,"With him on our side,"],[2392,2500,"you don't need to fear anyone!"],[2703,2780,"You"],[2819,2960,"You really are confused."],[2996,3112,"Let me tell you the truth."],[3144,3296,"The official who came in last"],[3303,3496,"is the Imperial Grandson's teacher!"],[3496,3539,"What?"],[3700,3864,"The Imperial Grandson's teacher!"],[3924,4011,"Does that mean"],[4067,4224,"Adam has the Imperial Grandson's backing?"],[4335,4415,"I don't care."],[4447,4547,"He killed my son,"],[4596,4692,"and I must take revenge!"],[4760,4971,"Your son spent his days drinking and whoring."],[5003,5192,"Whether he actually died of poison"],[5192,5311,"is still up for debate!"],[5356,5415,"My son"],[5428,5556,"Adam definitely killed him!"],[5584,5611,"You...!"],[5756,5796,"Ugh,"],[5984,6079,"forget it."],[6147,6256,"But right now,"],[6275,6339,"we are tied together"],[6339,6471,"like grasshoppers on a rope."],[6515,6592,"So,"],[6600,6735,"we need to figure out a plan together."],[6823,6864,"Hey,"],[6948,7048,"don't you forget"],[7084,7192,"to put in a good word for me"],[7204,7343,"with the Mentor."],[7392,7468,"Don't worry,"],[7492,7604,"I'll handle it."],[7804,7876,"Adam,"],[7948,8100,"I will make sure you die!"],[9815,9871,"Grace,"],[10023,10095,"marrying you"],[10228,10348,"is the greatest blessing of my life."]],"49":[[36,80,"Grace,"],[184,256,"marrying you"],[335,459,"is the greatest blessing of my life."],[555,636,"Husband,"],[740,880,"are you dead?"],[940,1116,"Is your spirit here to see me one last time?"],[1135,1259,"I'll come with you right now."],[1291,1403,"We'll walk the road to the afterlife"],[1427,1535,"together!"],[1607,1683,"Silly girl,"],[2007,2103,"I have a shadow."],[2148,2248,"How could I be a spirit?"],[2771,2907,"Husband, you're not dead!"],[3012,3096,"That's wonderful!"],[3116,3171,"I thought I"],[3171,3288,"would never see you again."],[3711,3792,"Your husband is"],[3847,3971,"blessed with great fortune."],[4011,4120,"How could I possibly die?"],[4232,4356,"I still have to protect you for the rest of my life."],[4556,4600,"Husband."],[4664,4820,"We promised a lifetime,"],[4867,4996,"and I won't settle for a day less."],[5243,5324,"Pinky swear."],[5324,5443,"It can't change for a hundred years!"],[5739,5864,"Come on, pinky swear!"],[6043,6096,"Okay,"],[6164,6239,"whatever you say."],[6303,6388,"You big baby."],[6640,6835,"Pinky swear,"],[6835,7023,"forever and ever."],[7515,7568,"Husband,"],[7628,7759,"are you hungry?"],[7776,7900,"I'll go make you some noodles."],[7964,7987,"Good."],[8064,8131,"Use the flour I brought back"],[8131,8204,"from overseas today."],[8243,8271,"Mhm."],[8343,8379,"Okay."],[8807,8915,"With a wife like her,"],[8935,9043,"what more could I ask for?"],[9079,9184,"How did I get so lucky"],[9184,9251,"to marry a wife"],[9251,9400,"who stands by me through life and death?"],[9464,9587,"I must make a name for myself"],[9615,9707,"in this era,"],[9784,9851,"and make Grace"],[9851,9987,"the happiest woman alive!"],[10164,10292,"This era is too dangerous."],[10387,10456,"I need to go to the warehouse"],[10495,10579,"and pick up a few things."],[10751,10935,"This bulletproof vest and pistol are nice."],[10971,11104,"I'll give them to Grace for protection."],[11123,11292,"I'll show this era"],[11364,11584,"what true firepower looks like!"]],"50":[[227,312,"Wow."],[448,496,"Husband,"],[512,567,"eat up."],[683,779,"Come, let's eat together."],[872,964,"I'm not hungry."],[1567,1664,"I knew you couldn't resist."],[1687,1760,"Hurry up and eat."],[1783,1855,"Look how thin you've gotten."],[1955,1992,"Okay."],[2192,2223,"By the way,"],[2464,2539,"look at this."],[2612,2671,"Husband,"],[2703,2807,"what is this?"],[2819,2960,"It's called a bulletproof vest."],[2983,3139,"I got it from a friend overseas."],[3203,3284,"He said"],[3296,3403,"it's extremely tough"],[3424,3543,"and can even withstand firearms."],[3600,3732,"It's also very thin and light,"],[3747,3811,"so it's easy to carry."],[3871,4015,"Really? Let me see."],[4292,4347,"Husband,"],[4375,4552,"this vest really is light."],[4688,4711,"Then,"],[4724,4803,"what is this?"],[4967,5120,"Now this thing is powerful."],[5132,5235,"At close range,"],[5307,5492,"a single shot can kill a man."],[5620,5675,"These"],[5675,5779,"are all for your protection."],[5820,5856,"Put them away,"],[5924,6032,"and make sure to keep them hidden."],[6088,6147,"Remember,"],[6207,6292,"it is easy to dodge a spear in the open,"],[6315,6415,"but hard to guard against a hidden arrow."],[6468,6512,"Mhm."],[6600,6679,"Husband,"],[6735,6876,"whenever you have something good,"],[6884,6987,"you always give it to me."],[7084,7176,"You're so good to me."],[7356,7451,"You're my wife."],[7500,7659,"Who else would I be good to?"],[7923,7979,"Sir,"],[7995,8140,"do you mean for me to start from"],[8151,8276,"the tenant farmers and hired hands,"],[8284,8423,"and select ten able-bodied men"],[8440,8543,"for you to personally train"],[8559,8640,"and groom?"],[8700,8740,"Yes."],[8759,8851,"I'll be using"],[8864,8979,"the special methods a friend"],[8979,9051,"from overseas taught me."],[9095,9184,"Get it done quickly."],[9207,9292,"Yes, Sir."],[9420,9495,"In this era,"],[9504,9564,"I need a group of subordinates"],[9564,9687,"who are loyal only to me"],[9704,9771,"to ensure my safety."],[9840,9915,"Thomas,"],[9943,10020,"our battle"],[10043,10148,"has only just begun!"],[10207,10323,"Get ready!"]],"51":[[56,260,"Adam definitely killed my son."],[316,420,"Since the Capital Prefect"],[420,640,"is too afraid to show his face,"],[675,883,"I'll take revenge myself!"],[1196,1219,"Is"],[1300,1435,"is that Adrian Everett?"],[1459,1535,"Damn it."],[1591,1671,"That kid actually managed"],[1671,1816,"to find a royal patron."],[1903,2064,"If Adrian Everett intervenes,"],[2132,2248,"avenging my son"],[2303,2451,"will be impossible!"],[2703,2876,"In that case,"],[2916,3123,"don't blame me for betraying Menolia"],[3123,3232,"and siding with the Oirets!"],[3288,3332,"Let's go."],[3524,3639,"I'll keep this brief."],[3692,3771,"Starting today,"],[3800,3935,"there's enough food for everyone,"],[3967,4060,"and meat at every meal."],[4124,4300,"Now, start training!"],[4360,4403,"Sir!"],[4443,4520,"What are we training?"],[4596,4667,"Take this,"],[4700,4767,"and shoot at the targets."],[4815,4992,"Whoever gets the highest score"],[5015,5160,"wins a roasted whole lamb."],[5203,5364,"There will be daily assessments."],[5467,5547,"Really, Sir?"],[5700,5871,"Roasted whole lamb is delicious."],[5871,5967,"I want some, too."],[5992,6075,"Me too."],[6456,6543,"I mean,"],[6568,6712,"I want to practice shooting, too."],[6712,6823,"Hehe."],[6879,6923,"Alright, enough."],[6956,7020,"Take this,"],[7043,7092,"and get started."],[7092,7123,"Yes, Sir."],[7348,7392,"Sir,"],[7464,7615,"there's a man named Andre outside"],[7615,7684,"who has come to visit."],[7776,7843,"Why is he here?"],[7904,7940,"Show him in, quickly!"],[7992,8023,"Yes, Sir."]],"52":[[128,204,"Everyone, remember."],[239,327,"When shooting,"],[372,440,"the stock"],[471,636,"must be pressed tightly against your shoulder."],[667,704,"This way, please."],[732,903,"Align the three points when aiming,"],[948,1024,"just like this."],[1308,1375,"Bullseye!"],[1427,1491,"Wow!"],[1516,1564,"Sir,"],[1616,1716,"right in the center!"],[1716,1903,"Your marksmanship is incredible!"],[2012,2060,"Alright,"],[2071,2151,"stop the flattery."],[2167,2212,"Get back to training!"],[2212,2248,"Yes, Sir."],[2480,2655,"The individual firearms of the Menolia Army"],[2667,2767,"can only reach one hundred paces,"],[2807,2932,"while your firearm, Mr. Foster,"],[2932,3044,"can actually reach three hundred."],[3279,3360,"May I ask, Mr. Foster,"],[3403,3488,"what kind of weapon is this?"],[3539,3807,"This is a divine weapon I forged myself,"],[3852,3992,"named the AK-47."],[4188,4247,"Mr. Foster,"],[4279,4343,"to be honest,"],[4415,4592,"I am Adrian Everett, the Imperial Grandson of Menolia."],[4656,4764,"May I take you as my mentor"],[4767,4875,"to learn the mastery of this weapon?"],[4896,5000,"I wish to sweep away the Oirets"],[5035,5124,"and secure peace for our borders and people."],[5215,5271,"Adrian Everett"],[5307,5367,"I never expected"],[5424,5503,"this man to be Menolia's"],[5503,5643,"future Emperor Adrian."],[5671,5784,"As a proud son of this land,"],[5800,5920,"since I've traveled back in time,"],[5943,6052,"I can't bear to see"],[6052,6115,"our civilization fall into ruin."],[6124,6264,"I might as well start now"],[6288,6495,"and lead Menolia to the peak of its power step by step."],[6728,6807,"Your Highness is truly benevolent."],[6956,7068,"As long as the border threats remain,"],[7112,7215,"the people of Menolia"],[7215,7323,"will never be able to live"],[7323,7404,"in peace and stability."],[7435,7607,"Menolia's glory today"],[7651,7807,"exists because countless heroes"],[7807,7904,"stepped forward, one after another."],[7968,8028,"Although I, Adam,"],[8059,8164,"am merely a humble citizen,"],[8212,8371,"I am willing to pass the secrets of this firearm"],[8371,8464,"on to you, Your Highness,"],[8492,8568,"to repel the Oirets"],[8587,8735,"and save the people of Menolia"],[8735,8835,"from the depths of their suffering."],[8940,9020,"Thank you, Mr. Foster!"],[9064,9151,"You serve the nation and the people,"],[9176,9323,"and are truly a hero of the highest order."],[9504,9612,"Please accept my bow!"],[9648,9707,"Rise, Your Highness!"]],"53":[[28,163,"Since you acknowledge me as your mentor,"],[187,304,"I won't hold anything back."],[348,420,"This"],[420,524,"is a globe."],[551,655,"We are right here."],[744,911,"And all these other places"],[1051,1290,"are already home to humans and civilizations."],[1324,1459,"A globe?"],[1500,1603,"Humans?"],[1648,1723,"Civilizations?"],[1828,1951,"Listening to your words, Teacher,"],[1951,2064,"is worth more than a lifetime of reading."],[2167,2239,"Your Highness,"],[2283,2460,"an immortal once visited my dream."],[2483,2619,"He told me"],[2676,2783,"that this place"],[2796,3044,"has endless gold and grain."],[3071,3200,"If we can break through the Oirets"],[3200,3315,"and lead our troops there,"],[3343,3475,"we can certainly build"],[3488,3696,"an empire greater than the ancients."],[3952,4115,"Endless"],[4115,4232,"gold?"],[4264,4352,"If I said 'petroleum,'(Oil)"],[4352,4452,"you wouldn't understand."],[4452,4592,"So I had to say gold."],[4656,4747,"Your Highness,"],[4747,4843,"after you ascend the throne,"],[4856,4928,"don't you want to"],[4928,5060,"surpass the emperors of history"],[5084,5235,"and become the greatest ruler of all time?"],[5247,5360,"Having you by my side"],[5360,5488,"is like a king finding his greatest strategist,"],[5520,5632,"a meeting destined by fate."],[5664,5843,"I wish to build on my ancestors' legacy"],[5856,6056,"and achieve eternal glory."],[6056,6128,"To do that,"],[6139,6296,"we must first understand this world."],[6320,6384,"Right."],[6443,6507,"Come."],[6756,6856,"Here are some"],[6856,6931,"biology, geography,"],[6931,7120,"and chemistry papers."],[7120,7287,"I'll walk you through them one by one."],[7351,7464,"Okay."],[9292,9404,"Mm-hmm."],[9476,9595,"Oh."],[11123,11300,"Hydrogen, Helium, Lithium, Beryllium, Boron,"],[11300,11476,"Carbon, Nitrogen, Oxygen, Fluorine, Neon,"],[11479,11635,"Sodium, Magnesium, Aluminum, Silicon, Phosphorus,"],[11668,11876,"Sulfur, Chlorine, Argon, Potassium, Calcium."],[12000,12200,"Have you memorized the periodic table"],[12212,12295,"I taught you?"],[12307,12384,"Yes."],[12400,12468,"Good."],[12476,12543,"Write it out from memory."],[13652,13752,"We can't wait any longer."],[13759,13887,"Adam has already latched onto"],[13887,13975,"the Imperial Grandson."],[14000,14184,"To avenge my son,"],[14208,14359,"I must bring in outside help."],[14440,14636,"Why hasn't the Oirets' messenger arrived?"],[14684,14771,"Thomas,"],[15003,15112,"I trust you've been well."]],"54":[[8,128,"Messenger,"],[128,287,"no need for formalities."],[308,428,"Give it to me straight."],[459,651,"Do the Oirets really have a cavalry unit"],[651,755,"bypassing all checkpoints"],[767,843,"that will reach Pekon"],[843,980,"in ten days?"],[996,1127,"It is absolutely true."],[1135,1264,"I've laid all my cards"],[1264,1348,"on the table."],[1356,1435,"Thomas,"],[1456,1632,"isn't it time you were honest too?"],[1660,1848,"Menolia's Imperial Grandson, Adrian Everett,"],[1855,2000,"is currently staying at Foster Manor."],[2132,2316,"I want Adam's head,"],[2364,2544,"and you can take the Imperial Grandson's."],[2571,2648,"Do we have a deal?"],[2671,2764,"Of course!"],[2876,3032,"Pleasure doing business!"],[3200,3375,"Hahaha!"],[3692,3864,"To avenge my son,"],[3864,3996,"I haven't hesitated to betray Menolia"],[4007,4111,"and collude with the Oirets."],[4120,4247,"I've paid a huge price for this."],[4275,4356,"So this operation"],[4356,4420,"must succeed."],[4420,4500,"Failure is not an option!"],[4535,4692,"Adam, just you wait!"],[4984,5075,"For the past ten days,"],[5075,5207,"Adrian Everett has actually been"],[5207,5279,"attending classes dutifully"],[5279,5360,"and training hard!"],[5375,5547,"Truly fitting for the future Emperor Adrian."],[5571,5700,"He's quite impressive!"],[5707,5847,"Whatever, enough about that."],[5856,6028,"I should get some skincare for my wife first."],[6188,6332,"This must be a warehouse"],[6332,6515,"for high-end skincare products."],[7012,7156,"These things"],[7156,7248,"six hundred years from now,"],[7248,7407,"they'd be considered top-tier luxury!"],[7415,7500,"Ha!"],[8176,8243,"My dear,"],[8387,8484,"guess what I've"],[8484,8579,"brought for you?"]],"55":[[56,172,"Don't tell me"],[172,296,"you got even better goods"],[296,444,"from your overseas friend again?"],[532,667,"You're too smart, honey."],[687,808,"You've ruined the surprise."],[1035,1143,"It smells wonderful!"],[1164,1335,"And the scent is so elegant."],[1335,1432,"It's not pungent at all."],[1443,1651,"It looks like top-quality skincare."],[1703,1816,"In that case, this time,"],[1819,1967,"we can make another fortune!"],[1996,2083,"Actually,"],[2116,2219,"we aren't selling any of this."],[2283,2392,"Why not?"],[2439,2512,"Honey,"],[2512,2592,"this is clearly better"],[2592,2712,"than the previous batch."],[2732,2892,"We could sell it for a sky-high price."],[3288,3447,"Because no amount of money"],[3484,3688,"can buy your happiness, my dear."],[3947,4071,"By the way, Hubby,"],[4071,4196,"do you know how much money"],[4196,4328,"we've earned in the last two weeks?"],[4407,4575,"A full five thousand taels."],[4664,4743,"That much?"],[4764,4820,"Yes."],[4835,4907,"We've taken over"],[4928,5032,"full management"],[5032,5171,"of Sir Lawson's businesses."],[5171,5328,"We didn't just sell rouge,"],[5352,5439,"snacks,"],[5452,5552,"and clothes,"],[5552,5643,"we also sold"],[5752,5911,"especially those"],[5928,6011,"black silk stockings,"],[6011,6075,"pantyhose,"],[6096,6279,"and sexy lace lingerie."],[6315,6471,"The noble ladies went crazy for them."],[6507,6664,"Word is that Duchess Saxon"],[6679,6768,"bought up"],[6768,6892,"ten whole pairs of black silk stockings!"],[7076,7140,"So,"],[7420,7500,"my dear,"],[7528,7640,"do you like these"],[7676,7756,"black silk stockings"],[7792,7928,"and lace items?"],[8056,8123,"I"]],"56":[[16,154,"I usually turn my nose up"],[158,295,"at such things,"],[308,462,"but Heaven treats me well,"],[495,708,"letting me bring a warehouse to Menolia."],[741,812,"So,"],[858,1020,"I must let the people of Menolia"],[1025,1133,"have a chance to 'critique'"],[1137,1229,"these scandalous items!"],[1416,1466,"My dear,"],[1504,1612,"a friend from overseas"],[1616,1737,"brought me some high-end clothes."],[1779,1866,"They say the noble ladies overseas"],[1870,2004,"are going crazy for them!"],[2116,2191,"Well then, my dear,"],[2195,2312,"hurry up and show me."],[2987,3050,"This"],[3085,3129,"This"],[3195,3375,"This is simply too scandalous!"],[3412,3483,"My dear,"],[3491,3608,"people overseas are very open-minded."],[3612,3687,"They all dress like this."],[3916,3987,"My dear,"],[4083,4254,"just wear it once for me."],[4300,4412,"Please?"],[4525,4612,"Alright then."],[4691,4770,"But first,"],[4787,4858,"you can't look."],[4979,5016,"Okay,"],[5020,5112,"I won't look."],[5470,5562,"My dear,"],[5583,5708,"I'm ready."],[5745,5825,"Okay."],[6533,6612,"My dear,"],[6758,6850,"you look so beautiful!"]],"57":[[331,420,"My dear,"],[512,651,"can I"],[651,779,"'critique' this"],[843,1032,"scandalous item again tonight?"],[1132,1240,"My dear,"],[1259,1388,"anything you like."],[1488,1607,"I'm willing to do anything."],[2296,2403,"This AK-47"],[2403,2492,"is incredible."],[2519,2603,"Teacher says"],[2603,2719,"it has a range of four hundred yards"],[2735,2883,"and can fire thirty rounds continuously."],[2912,3051,"If used on the battlefield,"],[3051,3160,"one full clip"],[3160,3303,"would wipe out the enemy."],[3303,3464,"This truly is a divine weapon for the nation!"],[4115,4203,"Not bad!"],[4347,4400,"Teacher,"],[4400,4452,"you're here."],[4535,4624,"You've worked hard"],[4624,4692,"these past ten days."],[4728,4788,"Teacher,"],[4796,4924,"what are you saying?"],[4932,5020,"Here with you,"],[5024,5124,"I've rediscovered the world."],[5164,5275,"I never feel tired,"],[5284,5371,"so how could it be hard work?"],[5460,5515,"He really lives up to the name"],[5515,5628,"of the legendary monarch"],[5628,5711,"who ushered in the golden age."],[5756,5932,"Adrian Everett is truly impressive."],[5939,6015,"It's a pity"],[6015,6135,"that his life was so short."],[6147,6288,"I should check the warehouse later"],[6288,6396,"to see if there's anything"],[6396,6528,"that can extend his life."],[6571,6664,"Keep practicing."],[6687,6771,"I have some work to do."],[6843,6900,"Yes,"],[6915,6992,"okay, Teacher."]],"58":[[24,163,"It's said in his later years, Adrian Everett"],[163,320,"weighed over three hundred catties,"],[352,508,"and drank a lot of water every day."],[600,744,"That's clearly diabetes!"],[767,916,"Also, the Menolia palace"],[916,1035,"had high levels of lead."],[1059,1151,"This might be what gave Adrian Everett"],[1151,1256,"lead poisoning."],[1283,1364,"I need to find a remedy"],[1364,1511,"to flush out the lead."],[2223,2328,"Teacher, are you saying"],[2328,2432,"that if I eat more of this,"],[2471,2592,"I can avoid lead poisoning?"],[2628,2687,"Yes."],[2723,2844,"You've been studying chemistry with me,"],[2876,2976,"so you must have realized"],[2983,3135,"that the lead levels in the palace are too high."],[3183,3243,"You should share this"],[3243,3352,"with your family as well;"],[3379,3528,"it can effectively prolong life."],[3628,3756,"I trust you completely, Teacher."],[3767,3839,"I will make sure"],[3847,3947,"to eat this every day from now on."],[4011,4079,"Good."],[4100,4167,"Master!"],[4167,4228,"Master!"],[4284,4379,"Master!"],[4547,4607,"Master!"],[4639,4703,"Bad news!"],[4732,4896,"Something terrible has happened!"],[4952,5032,"What happened?"],[5047,5132,"It's the Oirets!"],[5152,5275,"The Oirets are attacking!"],[5279,5328,"And they"],[5332,5475,"brought a large army!"]],"59":[[20,231,"His Majesty just returned from the northern campaign last year."],[248,368,"The Oirets didn't take time to recover,"],[368,496,"and they actually dare to attack?"],[500,575,"Do they have a death wish?"],[596,667,"Hmm."],[712,843,"It's likely a small cavalry unit"],[859,964,"that bypassed the pass."],[991,1140,"But instead of going elsewhere,"],[1140,1288,"they came straight to attack the estate."],[1348,1403,"Teacher,"],[1443,1600,"they are clearly coming for me!"],[1635,1771,"But my itinerary was confidential,"],[1812,1944,"how could it have leaked?"],[2080,2216,"There must be a traitor in Pekon!"],[2300,2360,"Teacher,"],[2432,2503,"we really are"],[2503,2583,"on the same wavelength!"],[3032,3076,"Your Highness,"],[3076,3151,"let's not talk about that now."],[3183,3292,"You hold the line outside,"],[3311,3384,"while I go get my gear."],[3400,3435,"Okay."],[3435,3564,"Yes, Boss!"],[3847,3928,"Chief Barton,"],[3964,4064,"that is Foster Manor!"],[4107,4192,"Right now,"],[4207,4352,"Menolia's Imperial Grandson, Adrian Everett,"],[4352,4435,"is right inside!"],[4500,4596,"Good."],[4615,4700,"Haha."],[4707,4856,"Let's stick to the plan."],[4871,5056,"I'll take Adrian Everett's head,"],[5084,5239,"and you take Adam's."],[5311,5388,"Adam"],[5388,5443,"this time,"],[5443,5584,"let's see how you survive."],[5600,5652,"Haha."],[5696,5775,"Get them!"],[5884,5956,"Kill!"]],"60":[[0,200,"Kill!"],[200,287,"Charge inside!"],[308,420,"Kill!"],[651,771,"Isn't that the Administrator of Pekon,"],[771,848,"Thomas?"],[951,1011,"I understand now."],[1011,1083,"Your Highness,"],[1108,1272,"Thomas is targeting my husband,"],[1288,1416,"while the Oirets are after you."],[1464,1527,"General,"],[1540,1635,"escort His Highness"],[1644,1748,"out through the back mountain."],[1787,1864,"What about you, Mrs. Foster?"],[1896,1992,"Even if we have to shed"],[1992,2080,"our last drop of blood,"],[2103,2164,"we will buy time"],[2164,2244,"for Your Highness."],[2280,2376,"I only ask that"],[2376,2480,"when you return to the capital,"],[2503,2651,"you clear my father-in-law's name"],[2692,2767,"and restore my husband's"],[2767,2867,"honors and titles."],[2903,2976,"Your Highness,"],[3007,3103,"Mrs. Foster is right."],[3116,3224,"If we don't leave now, it'll be too late."],[3256,3320,"No."],[3343,3420,"How can I let Mrs. Foster"],[3420,3484,"stay behind to cover me?"],[3511,3575,"Your Highness"],[3707,3788,"Victor, listen to my order."],[4064,4192,"Take my badge,"],[4228,4315,"go to Pekon,"],[4339,4439,"and bring reinforcements."],[4456,4503,"Your Highness,"],[4503,4575,"I'm staying with everyone"],[4620,4724,"to fight to the bitter end."],[4775,4815,"Your Highness,"],[4832,4924,"you must not do this!"],[4935,5007,"That is an order!"],[5147,5200,"Yes, sir!"],[5432,5496,"Brothers,"],[5552,5603,"Fire!"],[5656,5724,"Kill!"],[6856,6995,"Damn it! We're out of ammo!"],[7040,7135,"Charge!"],[7551,7623,"Brothers,"],[7656,7731,"Foster Manor"],[7731,7895,"is the legacy my Master worked hard to build."],[7931,8048,"We cannot retreat a single step!"],[8076,8159,"If you aren't afraid to die,"],[8176,8243,"follow me!"],[8279,8415,"Kill!"]],"61":[[196,352,"The Oirets are storming the Manor."],[364,487,"Thomas, just to kill me,"],[487,596,"you actually acted as their guide."],[740,808,"Fine."],[851,959,"Then today, I'll gun you down"],[959,1067,"along with them."],[1419,1491,"Brothers, charge!"],[1540,1616,"Push the Oirets"],[1635,1696,"back!"],[1739,1876,"Charge!"],[2176,2244,"Nate."],[2251,2303,"Here!"],[2303,2371,"Protect His Highness."],[2383,2483,"His Highness is of noble blood,"],[2483,2600,"we cannot let any harm come to him."],[2607,2651,"Yes, ma'am."],[2748,2807,"Barry,"],[2828,2903,"don't worry about me."],[2903,3003,"Go get dry straw,"],[3007,3076,"pour oil on it,"],[3076,3148,"and prepare the flints."],[3160,3239,"On my command,"],[3267,3364,"throw it all at the Oirets."],[3396,3567,"Madam, you really live up to your noble heritage."],[3567,3684,"You command like a general."],[3688,3803,"Master Adam is truly fortunate"],[3803,3939,"to have married you."],[3996,4064,"On it!"],[4911,5052,"I don't see Adam."],[5052,5128,"Let's capture"],[5128,5252,"Adam's wife first."],[5579,5752,"My husband's gun is powerful,"],[5752,5892,"but there's too little ammo."],[5892,5960,"If they charge,"],[5984,6092,"we won't be able to hold them off!"],[6115,6175,"Adam,"],[6175,6296,"where are you?"],[6628,6740,"Hey, little lady."],[6756,6900,"Nice body."],[6907,6987,"How about it?"],[7012,7179,"Come back with me,"],[7187,7343,"and show the boys a good time."],[7368,7440,"You"],[7707,7800,"have a death wish!"]],"62":[[16,104,"You're asking for it!"],[567,708,"How dare you insult my master's wife!"],[708,803,"You're a dead man!"],[827,908,"Hmph!"],[927,1000,"Ma'am,"],[1035,1127,"I will protect you."],[1167,1259,"Save your ammo."],[1280,1359,"My blade is enough"],[1400,1500,"to kill him."],[1511,1575,"Hmph!"],[1687,1780,"If you want to take her,"],[1807,1939,"you'll have to step"],[1948,2035,"over my dead body."],[2044,2128,"Fine."],[2139,2216,"Let's see if you"],[2216,2332,"actually have the skill"],[2364,2503,"to protect her."],[2767,2816,"Your Highness!"],[3051,3200,"You overestimate yourself!"],[3235,3343,"Die!"],[3411,3492,"Your Highness!"]],"63":[[1272,1316,"Adam!"],[1316,1367,"Master!"],[1367,1424,"What is that thing"],[1424,1519,"you're holding?"],[1527,1628,"Darling,"],[1655,1764,"watch closely."],[1780,1923,"Your husband is about to"],[1955,2132,"slaughter them all!"],[2176,2303,"I believe in you, Adam!"],[2360,2423,"Master,"],[2444,2564,"the Oirets' martial arts"],[2564,2648,"are rare in this world,"],[2648,2792,"yet you struck him down so easily."],[2803,2880,"Master,"],[2883,2987,"you really are a god!"],[3003,3100,"With a Gatling in hand,"],[3100,3235,"even the world's best fighter"],[3252,3388,"would be instantly killed by me."],[3396,3460,"Brother,"],[3460,3539,"times have changed."],[3628,3700,"Disciple,"],[3728,3839,"escort my wife"],[3843,3939,"to a safe place."],[4000,4032,"Yes, Master!"],[4032,4079,"Master"],[4415,4532,"Thomas,"],[4560,4756,"you cowardly old turtle!"],[4771,4903,"I, Adam,"],[4939,5100,"stand right here today."],[5120,5239,"If you have the guts,"],[5260,5443,"come and kill me!"]],"64":[[52,204,"You cowardly old turtle,"],[220,360,"come and kill me!"],[459,544,"Master wants to"],[544,636,"use himself as bait"],[663,755,"to draw away the main force"],[755,856,"so that I can escape."],[943,1011,"No!"],[1040,1143,"I can't let Master take that risk."],[1356,1480,"I am the Imperial Grandson of Menolia!"],[1500,1588,"If you have the guts,"],[1596,1687,"come and kill me!"],[1903,1983,"Adrian Everett."],[1983,2080,"Adam."],[2123,2216,"Brothers,"],[2219,2416,"whoever captures the Imperial Grandson of Menolia"],[2419,2603,"will be rewarded with a hundred taels of gold"],[2628,2755,"and a thousand steeds!"],[2783,2903,"Charge with me!"],[3220,3352,"Hahaha!"],[3379,3452,"Brothers,"],[3479,3639,"capture the Imperial Grandson of Menolia alive"],[3652,3767,"and I'll grant you gold!"],[3767,3884,"And white horses!"]],"65":[[48,115,"Adam."],[180,300,"I'm coming for your head!"],[320,463,"Charge!"],[487,575,"Kill them all!"],[755,851,"Your Highness! Boss!"],[867,932,"You two need to retreat!"],[943,1000,"We'll hold them off!"],[1000,1032,"Yes!"],[1075,1111,"No."],[1156,1227,"Staying behind is suicide."],[1232,1311,"We'll split up."],[1340,1459,"Nate, don't worry about me."],[1459,1580,"I know martial arts."],[1664,1748,"Just protect Master."],[1751,1819,"Nate, Owen."],[1839,1887,"Get down."],[3400,3535,"What era is this,"],[3571,3671,"to still be using cold steel?"],[3739,3807,"Do you have any idea"],[3807,4003,"what a \"dimensional strike\" is?"]],"66":[[88,216,"Master single-handedly"],[235,383,"defeated the entire Oirat cavalry."],[404,483,"Our Boss"],[483,659,"is truly the God of War incarnate!"],[704,740,"Indeed."],[740,787,"Hahaha."],[988,1083,"How is this possible?"],[1108,1211,"Has the Eternal Heaven"],[1227,1308,"abandoned us,"],[1308,1396,"abandoned the Oirets?"],[1396,1535,"Th-this"],[1559,1655,"Retreat!"],[1655,1767,"Trying to run?"],[2483,2548,"Adam, all by himself,"],[2548,2655,"wiped out the Oirets."],[2828,3048,"Then my son died for nothing."],[3080,3187,"Brothers,"],[3187,3320,"clean up the battlefield."],[3328,3396,"Yes, sir."],[3464,3796,"No!"]],"67":[[196,291,"Thomas!"],[304,412,"How have you been?"],[432,579,"A... Adam"],[579,704,"Are you a man or a ghost?"],[767,867,"How did you manage"],[911,1048,"to kill all the Oirets"],[1051,1159,"single-handedly?"],[1167,1291,"I don't have time to waste on you."],[1372,1416,"Your Highness,"],[1483,1596,"this man is treacherous."],[1596,1683,"He colluded with the Oirets"],[1692,1812,"and plotted against you."],[1832,1960,"His entire clan should be executed."],[2048,2083,"Guards,"],[2160,2264,"take him into custody."],[2332,2448,"I'm taking him back to Capitarrea"],[2480,2580,"for a public execution!"],[2600,2692,"Yes, sir!"],[2792,2980,"Hahahaha!"],[3035,3112,"Adam,"],[3164,3311,"do you think you've won?"],[3343,3471,"Haven't I?"],[3584,3752,"Come closer."],[3815,3867,"- Teacher. - Sir."]],"68":[[16,80,"It's fine."],[132,239,"Someone like him"],[239,348,"can't hurt me."],[683,779,"I know"],[779,983,"you're going to Capitarrea with the Imperial Grandson."],[1035,1116,"That's right."],[1164,1335,"I've prepared a big surprise for you"],[1408,1623,"on your way to Capitarrea."],[1667,1780,"When the time comes,"],[1780,1923,"be sure to accept it!"],[1955,2223,"Hahahaha!"],[2264,2396,"You're really too kind."],[2555,2635,"Huh?"],[2732,2792,"Your Highness,"],[2844,2948,"take him away!"],[2960,3012,"Take him away."],[3035,3067,"Yes, sir."],[3628,3688,"Master,"],[3724,3835,"it's too dangerous here."],[3852,3967,"We shouldn't travel separately."],[3967,4071,"Come back to Capitarrea with me!"],[4111,4179,"Your Highness,"],[4215,4339,"I will certainly go to Capitarrea."],[4388,4492,"Only by going there"],[4535,4692,"can I clear my father's name"],[4732,4915,"and no longer fear Prince Hans's treacherous faction."],[4935,5039,"But before that,"],[5120,5220,"I need to settle affairs at home first."],[5367,5447,"In that case,"],[5507,5547,"I will leave"],[5547,5656,"General Victor Carver here with you, Master."],[5707,5828,"I'll return to Capitarrea as soon as possible"],[5856,6007,"and report everything that happened to the court."],[6047,6124,"Someday,"],[6135,6220,"we'll meet in Capitarrea!"],[6328,6407,"See you in Capitarrea!"]],"69":[[52,227,"This world is so harsh."],[252,379,"To protect Grace"],[391,496,"and keep those I love"],[496,600,"safe from harm,"],[663,791,"I must settle everything here"],[824,935,"and then go to Capitarrea."],[1040,1124,"What?"],[1143,1303,"You're saying my protege Thomas,"],[1316,1435,"to avenge his son,"],[1448,1532,"colluded with the Oirets cavalry"],[1532,1644,"to attack Foster Manor?"],[1660,1739,"And in the end,"],[1767,1912,"the Oirets cavalry were wiped out,"],[1935,2100,"and he was captured by Adrian Everett?"],[2112,2235,"Yes, Commander."],[2235,2360,"We can't wait any longer."],[2360,2432,"Once Adrian Everett"],[2432,2548,"takes Thomas back to Capitarrea,"],[2571,2651,"Prince Hans"],[2660,2792,"will surely be attacked by the Crown Prince's faction!"],[2807,2928,"We must destroy this evidence."],[2948,3112,"Thomas won't talk."],[3200,3292,"What we need to do"],[3352,3552,"is eliminate the other witness."],[3715,3784,"Adam?"],[3788,3860,"Everyone, listed up."],[3947,4056,"Deploy troops to Pekon."],[4084,4115,"Yes, sir!"]],"70":[[204,368,"Young Master, look at them."],[536,600,"Is this the legendary"],[600,700,"hero's welcome"],[704,816,"with baskets of food and drink"],[816,935,"for the royal army?"],[943,1008,"Master,"],[1008,1075,"we heard you are following"],[1075,1219,"His Highness back to Capitarrea."],[1251,1383,"We were worried you might get hungry,"],[1411,1564,"so every family prepared some food"],[1575,1664,"for you to take"],[1664,1764,"and eat on the road."],[1860,1987,"What are you all doing?"],[2039,2123,"Take it back, quickly."],[2123,2239,"You barely have enough for yourselves."],[2264,2348,"Master,"],[2396,2555,"the Oirets were terrible."],[2592,2716,"They harassed our border every year,"],[2755,2851,"stole our cattle,"],[2860,2964,"slaughtered our sheep,"],[2983,3151,"and destroyed our homes."],[3167,3300,"You killed the Oirets"],[3307,3411,"and avenged us."],[3424,3584,"This is the least we could do."],[3620,3679,"I originally planned"],[3679,3756,"to just hold onto my warehouse"],[3756,3839,"and live as a rich man."],[3871,3939,"But now,"],[3956,4007,"I want to fight for"],[4007,4200,"these 'weeds' in the eyes of the powerful."],[4203,4279,"I'm going to give it my all!"],[4375,4456,"Truth be told,"],[4515,4720,"I've gotten too entangled with Prince Hans's faction."],[4735,4839,"If we stay here,"],[4860,4935,"we're in grave danger."],[5015,5132,"So I've decided"],[5147,5252,"to leave tomorrow morning"],[5267,5375,"and start over in Capitarrea."],[5415,5528,"If you're willing to come with me,"],[5556,5643,"I'll double your wages."],[5703,5784,"If you'd rather not,"],[5835,6011,"I'll give you fifty taels as severance."],[6056,6164,"It's your decision."],[6196,6252,"I won't force anyone."]],"71":[[72,139,"Master,"],[180,327,"you gave us back our dignity."],[327,412,"You led us"],[412,504,"to victory against the Oirets."],[536,679,"I, Owen, have never respected anyone,"],[679,759,"but I respect you!"],[827,924,"Master,"],[924,1064,"as long as you don't think I'm useless,"],[1064,1172,"even if I can't do much,"],[1172,1291,"I'll follow you to the very end."],[1291,1644,"Count me in, too!"],[1832,1980,"Good man, Owen."],[2023,2119,"From now on,"],[2128,2339,"you're the Deputy Manager of New Foster Manor."],[2371,2483,"You'll assist Nate"],[2483,2616,"in managing the guards"],[2623,2700,"at the new manor."],[2760,2839,"Thank you, Master!"],[3071,3167,"Manager Walker,"],[3192,3279,"I trust you've been well."],[3339,3396,"Mr. Foster,"],[3435,3628,"you've made quite a name for yourself"],[3647,3828,"among the nobles of Menolia."],[3843,4024,"They say you were a young scholar,"],[4060,4115,"and now,"],[4115,4311,"you've single-handedly beaten the Oirets."],[4320,4511,"You're a master of both pen and sword!"],[4575,4684,"Word is,"],[4700,4852,"everyone wants to get to know you!"],[4903,5011,"Manager Walker,"],[5024,5171,"I can't take all the credit."],[5184,5492,"Mr. Foster, your future is limitless!"],[5547,5879,"It's just a pity that as you head to Capitarrea,"],[5879,6003,"I won't be able to purchase"],[6032,6260,"any of your goods anymore."],[6364,6484,"Manager Walker,"],[6484,6615,"wait here a moment."]],"72":[[32,115,"Ah,"],[160,327,"Manager Walker has shown me great kindness."],[364,512,"Since I'm heading to Capitarrea,"],[551,691,"I should leave him some extra stock."],[1700,1844,"Oh my! Good heavens!"],[1900,2035,"The quality of this rouge"],[2048,2151,"every single piece"],[2151,2312,"is up to your usual standard,"],[2328,2416,"maybe even superior."],[2451,2555,"Mr. Foster,"],[2567,2712,"you really were holding out on me."],[2732,2844,"You waited until you were leaving"],[2851,3012,"to bring out this inventory."],[3012,3119,"Hahaha."],[3119,3239,"You're joking, Manager Walker."],[3271,3335,"If it weren't for you,"],[3352,3528,"I'd have died in Westfall Village long ago."],[3575,3656,"All these goods"],[3692,3764,"are yours for free!"],[3767,3911,"Oh, no, no, no."],[3947,4056,"Business is business."],[4079,4184,"With the quality of this rouge,"],[4211,4320,"taking just a single piece"],[4320,4492,"to the noble ladies in Pekon"],[4503,4732,"would cause quite a sensation."],[4743,4811,"I can't take these"],[4811,4932,"for nothing... I really can't."],[5215,5303,"Mr. Foster,"],[5384,5543,"believe it or not,"],[5632,5800,"hearing you were returning to Capitarrea,"],[5847,5935,"I put together"],[5935,6047,"two thousand taels of silver."],[6096,6196,"as travel expenses."],[6256,6352,"But using this money"],[6356,6484,"to buy such fine rouge"],[6484,6579,"that would be"],[6579,6695,"taking advantage of you!"]],"73":[[0,176,"Keep the travel money for now,"],[187,327,"and I'll go home to fetch the rest."],[335,424,"It's a deal, then."],[428,591,"These goods are mine,"],[591,748,"so don't sell them to anyone else."],[808,867,"Manager Walker,"],[924,1043,"you give me travel expenses,"],[1048,1119,"and I give you the goods."],[1159,1256,"Isn't that a fair trade?"],[1272,1364,"You're a good man."],[1419,1535,"In the days to come,"],[1548,1639,"take good care of yourself."],[1700,1851,"When I return to Pekon,"],[1871,1923,"we will"],[1948,2039,"drink and celebrate!"],[2071,2144,"Great!"],[2228,2328,"I'll wait for you."],[2335,2483,"I'll wait for you back in Pekon."],[2500,2548,"Alright."],[3096,3224,"Report to General Keane immediately."],[3224,3264,"Tell him"],[3264,3447,"Adam leaves tomorrow morning."],[3447,3560,"I'll stay here to keep watch."],[3588,3652,"Yes, sir."],[4120,4207,"This trip to Capitarrea"],[4207,4328,"won't be easy."],[4356,4439,"I'd better prepare"],[4439,4528,"a few more things."]],"74":[[32,200,"Before Thomas was taken away,"],[200,331,"he told me he had a gift waiting for me"],[331,412,"on the road to Capitarrea."],[444,587,"There are no landmines in this era,"],[651,791,"and to me, bandits and robbers"],[791,908,"are just cannon fodder."],[924,1032,"Surely he knows that?"],[1211,1372,"Thomas is merely a minor official,"],[1372,1540,"yet he joined Prince Hans's faction."],[1564,1660,"This suggests he has a backer"],[1660,1751,"within their ranks."],[1796,1876,"And the primary military force"],[1876,1983,"in Prince Hans's hands"],[2003,2103,"is the Blackfang Army."],[2187,2276,"So,"],[2276,2455,"the gift Thomas mentioned must be"],[2696,2864,"an ambush by the Blackfang Army."],[3596,3720,"Is the luggage packed?"],[3728,3811,"Don't worry, Sir."],[3820,3920,"Everything is ready."],[3928,3988,"Good."],[4067,4132,"Then we head to Capitarrea."],[4152,4224,"We leave immediately."]],"75":[[0,64,"Honey,"],[128,196,"I'll take a few men"],[196,304,"and go ahead in the first carriage."],[352,477,"You leave an hour later."],[555,644,"Nate, Owen,"],[720,759,"you stay close to"],[759,851,"the Madam and Barry."],[867,975,"You must keep them safe!"],[1008,1075,"Do you understand?"],[1259,1332,"Husband,"],[1335,1424,"this isn't a good plan."],[1443,1508,"Honey,"],[1556,1671,"I'm just leaving first with the men."],[1712,1755,"What's wrong with that?"],[1851,1919,"This time,"],[1919,2071,"if Prince Hans's faction is really"],[2071,2144,"lying in ambush on the road,"],[2167,2251,"their target"],[2251,2351,"will definitely be you."],[2376,2512,"Let's switch carriages."],[2544,2723,"That way, if there is an ambush,"],[2787,2996,"you can escape safely."],[3081,3196,"But... what about you?"],[3384,3515,"It's already come to this."],[3543,3656,"there's no need to hide it anymore."],[4547,4615,"Honey,"],[4728,4788,"are you from"],[4832,4939,"Duke Rory's Manor?"]],"76":[[36,139,"Duke Rory Bennett"],[152,235,"is my eldest brother."],[296,391,"And Pete Bennett, who tried to stop us"],[440,587,"when we got married,"],[604,708,"is my second brother."],[883,948,"Honey,"],[991,1048,"I'm sorry."],[1103,1283,"I never told you the truth."],[1300,1400,"So that's how it is."],[1400,1503,"I married a wife,"],[1503,1548,"only to find out she's"],[1548,1696,"Duke Rory Bennett's sister."],[1696,1796,"I took in a student,"],[1796,1896,"who turns out to be Menolia's"],[1907,2039,"Imperial Grandson, Adrian Everett."],[2039,2123,"If I told anyone,"],[2123,2235,"who would believe me?"],[2412,2544,"Put that token away."],[2544,2648,"I won't agree"],[2648,2739,"to switch carriages with you."],[2776,2860,"What kind of husband"],[2887,3019,"lets his wife scout the path first?"],[3160,3215,"Barry,"],[3235,3288,"Nate,"],[3288,3332,"Owen,"],[3364,3507,"stay here and guard the Madam."],[3515,3632,"Wait half an hour"],[3632,3752,"before letting her leave."],[3956,3992,"Yes, sir!"],[4096,4152,"Honey"],[4447,4524,"Don't worry,"],[4571,4671,"I'll be fine!"],[4947,5011,"Let's go!"],[5035,5111,"To Capitarrea!"],[5488,5539,"Honey,"],[5692,5807,"you must come back safely."],[5960,6184,"Madam"],[6523,6656,"As the Mistress of Foster Manor,"],[6668,6731,"I order you to"],[6748,6928,"catch up with the Master's carriage at once."],[6948,7031,"I don't need your protection"],[7031,7107,"back here."]],"77":[[235,296,"Do you want to get kicked out"],[296,387,"of Foster Manor?"],[528,567,"Yes, Ma'am!"],[608,648,"Yes!"],[648,696,"Madam"],[1124,1172,"Honey,"],[1280,1448,"please be safe."],[2080,2144,"Commander,"],[2176,2248,"we've been waiting here all day."],[2248,2392,"Adam is finally coming."],[2392,2483,"Why aren't we attacking?"],[2567,2655,"Prince Hans said"],[2676,2764,"the women of Duke Rory's Manor"],[2776,2864,"are the most cunning."],[2896,2980,"I bet"],[3023,3107,"she's the one in"],[3107,3196,"this first carriage."],[3267,3347,"Let's wait for the next one."],[4611,4764,"Adam is here!"],[4811,4864,"Brothers,"],[4935,5003,"kill them!"],[5011,5103,"Kill!"],[5128,5220,"Kill!"]],"78":[[396,448,"Mr. Foster,"],[528,651,"why haven't they arrived yet?"],[696,740,"Do you think"],[767,867,"something happened?"],[983,1091,"Kill!"],[1111,1256,"Kill!"],[1403,1451,"Oh no!"],[1456,1508,"Grace!"],[1807,1900,"I miscalculated."],[1923,2032,"I didn't expect the one bringing up the rear"],[2032,2164,"to be you, the Bennett girl."],[2207,2239,"Speak!"],[2271,2348,"Where is Adam?"],[2648,2716,"I'd rather die"],[2716,2792,"than tell you"],[2792,2876,"where my husband is."],[2923,3028,"I'm warning you."],[3064,3180,"My husband holds evidence"],[3180,3311,"of Thomas's crimes."],[3360,3496,"Once he reaches Capitarrea,"],[3532,3652,"half of Prince Hans's faction will crumble."],[3703,3767,"I suggest you"],[3811,3947,"switch sides while you still can!"],[4128,4292,"Switch sides?"],[4367,4456,"You really"],[4456,4571,"overestimate yourselves."],[4607,4684,"Let me tell you,"],[4747,4907,"the entire Blackfang Army is here today,"],[4907,5047,"three thousand strong."],[5047,5196,"Even if you don't talk,"],[5196,5292,"I'll turn this place upside down"],[5364,5503,"to drag Adam out."],[5552,5707,"How is this possible?"],[5743,5820,"Honey,"],[5900,6020,"you must escape!"]],"79":[[12,112,"Even if Adam has"],[112,224,"superhuman powers,"],[256,360,"he dies here today."],[404,471,"Kill them all!"],[504,579,"Attack!"],[704,744,"Stop!"],[775,851,"Everyone, stop!"],[2735,2844,"The Young Master is here!"],[2844,2960,"Make way!"],[3211,3292,"It's the Young Master!"],[3307,3396,"The Young Master is back!"],[3471,3584,"Wielding that piece of junk,"],[3584,3656,"do you really think you're"],[3656,3747,"the reincarnation of Lu Bu?"],[3771,3879,"I'll take you on myself!"],[4588,4688,"Child's play."],[4688,4775,"You dare show off your amateur skills"],[4775,4852,"in front of a master?"],[4875,4988,"Brothers!"],[4988,5067,"Get him!"],[5067,5135,"Kill him!"],[5147,5220,"Crit!"],[6605,6871,"Are you... a man or a ghost?"],[6879,7171,"I... refuse to accept this!"],[7456,7520,"General Carver,"],[7520,7600,"clean up the battlefield."],[7635,7692,"Yes, sir!"],[8328,8379,"My dear,"],[8428,8476,"are you alright?"],[8564,8607,"Husband,"],[8679,8728,"I thought"],[8728,8823,"I would never see you again."]],"80":[[0,196,"I really thought I'd lost you."],[196,364,"Don't say such unlucky things."],[364,455,"From now on, as long as I'm here,"],[500,583,"no one will dare lay"],[583,708,"a finger on you."],[811,867,"Mr. Foster,"],[867,1000,"the battlefield is cleared."],[1056,1140,"We're ready to move out."],[1159,1183,"Good."],[1283,1324,"My dear,"],[1367,1491,"we wiped out the Blackfang Army this time,"],[1496,1567,"so our trip to Capitarrea"],[1588,1667,"will be fraught with peril."],[1732,1800,"You shouldn't come."],[1860,1992,"Just stay here in Pekon"],[1992,2132,"and hold down the fort."],[2139,2203,"Alright?"],[2239,2303,"Husband,"],[2360,2523,"we share our glory and disgrace together."],[2544,2632,"Besides,"],[2632,2764,"I am Duke Rory's sister."],[2812,2883,"If necessary,"],[2883,3007,"I can still lend you a hand."],[3135,3211,"Please, Husband."],[3247,3379,"Stop trying to talk me out of it!"],[3411,3588,"Even if mountains of blades and fire await,"],[3632,3692,"I am determined"],[3711,3835,"to go with you!"],[4020,4103,"With a wife like you,"],[4160,4232,"what more could a husband ask for?"],[4307,4332,"Alright."],[4403,4503,"Then let's go to Capitarrea together!"],[4592,4639,"Let's see"],[4639,4703,"if Prince Hans really"],[4711,4775,"has"],[4775,4847,"three heads and six arms."],[5124,5279,"Get on this Jeep horse."],[5428,5539,"An iron horse?"],[5635,5688,"Let's go!"],[5715,5760,"Move out!"],[5852,6003,"Move out!"]]}