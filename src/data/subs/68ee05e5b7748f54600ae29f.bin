{"1":[[500,674,"My goodness, get off."],[674,886,"Caroline, you're gonna get yourself killed."],[886,960,"No!"],[960,1125,"Not unless you promise"],[1125,1338,"my husband gets the 10 billion dollar"],[1338,1554,"investment at your banquet, tomorrow."],[2302,2495,"Fine, just hit the damn brake."],[3216,3430,"I recorded every word, BIG brother."],[4044,4271,"Caro, I don't understand."],[4287,4423,"You ditched your last name,"],[4423,4539,"your trust fund,"],[4547,4684,"your entire life to"],[4684,4854,"marry Liam Foster?"],[4878,5031,"For three years you pumped"],[5031,5102,"Harrington money"],[5102,5238,"into the Foster Group,"],[5255,5384,"helped take it public."],[5445,5568,"And what did you get for it?"],[5602,5759,"A crappy haircut,"],[5759,5999,"a beat-up scooter, and"],[6015,6221,"these cheap clothes."],[6259,6433,"I love him,"],[6433,6600,"and supporting him is what I do,"],[6600,6713,"and I'm proud of doing it."],[6713,6892,"Okay, but word is,"],[6892,7079,"your mother-in-law is hunting"],[7079,7190,"for a new bride for Liam."],[7243,7504,"Some trust fund princess."],[7637,7720,"Natty Parker."],[7720,7864,"Oh please, Jeffery."],[7904,8032,"Those are just rumors."],[8061,8240,"Eileen is strict,"],[8240,8398,"but she would never do that to me."],[8478,8636,"Oh, it's Liam."],[8636,8735,"I gotta go."],[8735,8896,"Eileen's birthday party's today."],[8922,9015,"And don't forget,"],[9192,9372,"you promised me the investment."],[11230,11403,"That's Connor Foster,"],[11403,11573,"the useless bastard"],[11573,11758,"who hangs around street gangs."],[12402,12699,"Oh, clumsy me."],[12699,12890,"Let me take you to the bathroom."],[13246,13415,"Liam says he's gonna meet me here."],[14524,14755,"What the hell is going on here?"]],"2":[[103,264,"No, Liam, I swear it's not-"],[293,441,"Sleeping with my son's uncle?"],[453,555,"You little slut."],[607,774,"No, Liam, it wasn't-"],[774,860,"You know what, Liam?"],[920,1023,"Maybe it's not all"],[1023,1158,"Caroline's fault."],[1181,1370,"You are really busy and"],[1370,1605,"a lonely housewife can get desperate."],[1605,1858,"No, the only reason why I came here"],[1858,2084,"was because Liam texted me."],[2091,2145,"Wait, I didn't-"],[2145,2250,"So let me get this straight."],[2275,2375,"You told me to wait,"],[2375,2502,"promised clean clothes,"],[2502,2672,"then sent Caroline in."],[2672,2759,"What were you hoping for?"],[2759,2828,"A scene?"],[2828,2991,"So you're telling me you were set up?"],[2991,3093,"Cut the crap."],[3149,3236,"Everyone in LA knows"],[3236,3370,"that you're a notorious bastard."],[3406,3632,"And now you're sleeping with my son's wife?"],[4070,4196,"Divorce papers."],[4227,4480,"You had these ready to go?"],[4521,4721,"You... You set me up?"],[4721,4768,"No, I..."],[4774,4934,"We've tolerated you long enough."],[4984,5168,"Unlike Natty, she's gonna bring a"],[5168,5396,"$10 billion deal into the Fosters."],[5418,5526,"And what have you done?"],[5542,5615,"You haven't brought a"],[5615,5744,"dime into this company."],[5782,5973,"And now you're sleeping with my son's uncle?"],[6002,6148,"Ugh, disgusting."],[6148,6461,"No, I- I was gonna get Liam a"],[6461,6743,"$10 billion investment deal"],[6743,6926,"and I am not sleeping around"],[6926,7025,"with his damn uncle."],[7057,7144,"$10 billion?"],[7210,7375,"Are you insane, Caroline?"],[7640,7768,"You know what, Caroline?"],[7794,7921,"I believe you."],[8038,8266,"Even if there's no proof of it."],[8289,8451,"Okay, you?"],[8478,8604,"You set me up."],[8724,8849,"You just hit me."],[8920,9042,"It wasn't my fault"],[9042,9189,"I caught you two cheating."],[9222,9532,"I- I did not touch you, you diva!"],[9532,9592,"Enough!"],[9780,9969,"Caroline, I want a divorce."],[9970,10031,"Now."]],"3":[[36,214,"I want a divorce. Now."],[330,559,"You want to divorce me?"],[699,838,"My- My back!"],[844,951,"You should go to the hospital."],[1033,1155,"I'm fine."],[1155,1260,"I'm just really worried"],[1260,1405,"about the Foster name."],[1444,1716,"Your wife caught cheating with your uncle"],[1716,1944,"on your mother's birthday."],[2072,2242,"What a scandal."],[2419,2561,"Sign those damn papers."],[2590,2796,"I want you and that bastard out of this house."],[2802,2971,"I don't want to see you ever again."],[3030,3139,"You heard my son."],[3139,3429,"Sign them. And you won't get a dime."],[3440,3586,"Cheaters get nothing."],[3666,3958,"Just know, I could have given you everything."],[3958,4195,"But fine. I'll sign it."],[4280,4379,"You and your bastard"],[4379,4544,"get out of the Foster house."],[5090,5188,"Fine!"],[5229,5328,"But first..."],[5952,6063,"Let's get out of this dump."]],"4":[[120,163,"Hold on."],[253,400,"What now, Eileen?"],[410,576,"You leech off this family for three years"],[576,690,"and you think you can just leave?"],[794,1010,"I'm a leech? That's your story?"],[1017,1141,"If it wasn't for my son's"],[1141,1291,"foolish obsession with you,"],[1291,1487,"a parasite like you would never step foot"],[1487,1598,"in the Foster house."],[1644,1811,"That's Liam Foster's wife?"],[1825,1948,"I've seen better-dressed maids."],[2001,2093,"I've heard that"],[2093,2215,"she's from the slums."],[2245,2402,"Probably seduced her way in."],[2419,2577,"Foster Group went public"],[2577,2699,"because I funneled"],[2699,2856,"Harrington capital into it."],[2962,3088,"But not today."],[3088,3237,"No more Harrington money."],[3243,3428,"Not now. Not ever."],[3493,3638,"Did she say Harrington?"],[3652,3863,"As in LA's richest family?"],[3950,4170,"You brought Harrington money into the Fosters?"],[4180,4294,"Who do you think you are?"],[4371,4506,"The Harrington heiress?"],[4660,4735,"What if I am?"],[4784,4937,"Then I'd get down on one knee and"],[4937,5100,"call you Your Majesty."],[5430,5649,"Now take off those Foster bought clothes!"],[5649,5762,"Take it off, you parasite."],[5762,5928,"Let go of me, you psycho!"],[5937,6035,"That's enough."]],"5":[[3,113,"Take it off, you parasite!"],[113,272,"Let go of me, you psycho!"],[290,363,"That's enough!"],[503,600,"Let go, you bastard."],[600,677,"How dare you?"],[720,857,"You ungrateful mutt."],[865,1066,"Crawl to the gutter you came from."],[1074,1207,"This is between you and me."],[1241,1351,"Leave him out of it."],[1490,1554,"Housewife playing"],[1558,1685,"savior to a bastard?"],[1791,1851,"Fine."],[1880,2119,"Take off those clothes my son paid for."],[2245,2323,"You don't have to do that."],[3390,3570,"From now on, I owe the"],[3570,3885,"Foster family nothing."],[4010,4137,"Out! both of you!"],[4824,4934,"What are you doing?"],[4961,5065,"I thought you wanted my..."],[5071,5126,"Your..."],[5126,5217,"My shirt."],[5410,5585,"It's not exactly clean, but"],[5596,5729,"it's better than nothing."],[6142,6349,"You know, I'm sorry that you got"],[6349,6463,"kicked out because of me."],[6493,6652,"If it ruined your life,"],[6661,6873,"let me know and I'll make it up to you."],[6900,6971,"Sweet."],[6971,7037,"I'm actually glad"],[7037,7134,"I'm out of that dump."],[7247,7405,"And hey, if you don't have anywhere to stay,"],[7410,7474,"I've got a..."],[7474,7791,"With my ex-husband's uncle?"],[7857,7924,"Please."],[7941,8101,"Also, aren't you"],[8101,8418,"living with street friends?"],[8525,8721,"No, I actually run a solid company."],[8755,8862,"Just-"],[8862,8987,"No one in that house knows it."],[9062,9161,"Right."],[9182,9461,"Well, if you're into investing at all,"],[9482,9684,"you could come to a banquet tomorrow."],[9713,10213,"I will be sitting at the big table"],[10213,10373,"because I'm the daughter"],[10373,10540,"of the richest guy there."],[10540,10637,"Princess of Harrington?"],[10650,10715,"You have a real"],[10715,10815,"sense of humor, don't you?"]],"6":[[213,437,"Oh, that's my ride."],[463,906,"I will see you tomorrow, ex-uncle."],[1460,1526,"Wow,"],[1526,1664,"Uber does Bentley now."],[1705,1828,"L.A. is insane."],[3666,3886,"Welcome home, Princess Caroline."],[4190,4367,"It's my favorite bunny."],[4427,4561,"You remembered."],[4564,4651,"Of course I did."],[4958,5087,"You were right, Jeff."],[5135,5325,"They framed me for cheating."],[5345,5549,"Just to force me out with nothing."],[5549,5842,"And Liam, he didn't even trust me."],[5842,6117,"My whole marriage was a lie."],[6117,6381,"Those assholes! I'll make him pay!"],[6423,6493,"No."],[6525,6710,"Get me into that banquet tomorrow."],[6736,6875,"Let's see how they think"],[6875,6942,"they're gonna get that"],[6942,7135,"$10 billion without me."]],"7":[[817,977,"Look who crawled back."],[1061,1225,"Got no shame, do you, Caroline?"],[1335,1428,"You just can't"],[1428,1609,"stay away from Liam, huh?"],[1644,1761,"This place isn't meant"],[1761,1865,"for someone like you,"],[1865,2045,"so why not leave"],[2045,2205,"before someone has to drag you out?"],[2205,2282,"This event is"],[2282,2415,"sponsored by my brother,"],[2415,2662,"so if anyone is out of place here,"],[2662,2808,"it certainly isn't me."],[2809,2899,"You're telling me"],[2899,3023,"that Jeffrey Harrington,"],[3043,3221,"the heir to the richest family in L.A.,"],[3221,3320,"is your brother?"],[3400,3517,"Are you delusional?"],[3540,3681,"Believe it or don't."],[3707,3840,"I really couldn't care less."],[3843,3983,"What I do care about is this."],[4003,4144,"You are not leaving here"],[4144,4360,"with that $10 billion investment."],[4487,4680,"Oh, the divorce must have really"],[4680,4806,"hit you hard."],[4806,4926,"Is that why you've lost it?"],[4960,5088,"Save it, Natty."],[5101,5217,"At least, Liam and I"],[5217,5326,"loved each other."],[5338,5513,"You were just a side piece"],[5513,5633,"he never claimed."],[5680,5774,"You bitch!"]],"8":[[750,859,"Connor, you're really here?"],[877,1057,"You invited me yesterday, remember?"],[1127,1248,"Yes, yes, everyone."],[1284,1473,"This is my son's ex-wife,"],[1478,1648,"and the man standing next to her"],[1648,1785,"is my son's uncle."],[1861,2007,"And they're having an affair."],[2042,2420,"Oh, poor Liam is out there"],[2420,2642,"working so hard..."],[2686,2838,"and she's here just living"],[2838,2973,"on his dime?"],[3013,3175,"Ungrateful."],[3209,3367,"What a performance."],[3373,3478,"Now it's my turn."],[3516,3935,"That so-called affair was a setup."],[3964,4067,"Watch this."],[4317,4576,"Nattie Parker set up Foster's wife."],[4601,4768,"Isn't that like, home-wrecking?"],[4844,4973,"You might not know this,"],[4973,5158,"but I still have access to the"],[5158,5328,"Foster House security."],[5335,5442,"I guess being a housewife"],[5442,5582,"isn't all that bad after all."],[5652,5719,"That's a scam."],[5759,5865,"She's faking it."],[5939,6052,"She made it all up."],[6089,6256,"I mean, you can analyze it"],[6256,6326,"if you want."],[6359,6413,"Let's see what the"],[6413,6489,"truth really says."]],"9":[[357,413,"Now how are you"],[416,546,"gonna analyze anything?"],[1034,1221,"People are begging for scraps,"],[1221,1355,"and you're smashing phones"],[1355,1504,"like they grow on trees."],[1530,1620,"What's next? Are you gonna"],[1620,1826,"set fire to a Gucci bag for fun?"],[1865,2021,"How dare you, you bitch?"],[2045,2170,"Caroline, I'm gonna make sure"],[2170,2355,"you crawl out of the city with nothing!"],[2372,2535,"Make me pay? Oh, no."],[2535,2612,"That's my line."],[2640,2730,"And that slap"],[2730,2833,"was just the beginning."],[2899,2951,"Caroline!"],[3299,3426,"What did you do to my mother?"],[3472,3578,"Look at her."],[3578,3789,"First in your uncle's bed, and..."],[3789,3997,"and now she's slapping your mother?"],[4057,4174,"She's out of control!"],[4217,4364,"Apologize, Caroline."],[4401,4523,"-Or I'll... -Or what?"],[4557,4628,"You gonna threaten my date"],[4628,4694,"right in front of me?"],[4731,4813,"Your date?"],[4813,5024,"You're actually flaunting your affair to my face."],[5024,5211,"Connor is way better than you, Liam."],[5211,5337,"I knew it."],[5352,5510,"You two are screwing around."],[5540,5620,"Shut up, Eileen."],[5620,5739,"Why don't you try being a decent mother"],[5739,5880,"and stop bullying your ex-daughter-in-law"],[5880,6019,"like a damn high school mean girl?"],[6022,6138,"Why don't you shut up?"],[6149,6294,"Just because you have the Foster name"],[6294,6435,"doesn't mean you're one of us."],[6456,6583,"You're such a bastard."],[6606,6731,"Well, if the Foster family includes"],[6731,6875,"someone as disgraceful as you,"],[6916,7037,"then thank God I'm not one."],[7037,7200,"What could be more disgraceful"],[7200,7405,"than sleeping with your nephew's wife?"],[7454,7534,"Stop making a scene"],[7534,7645,"and get out of here."],[7650,7774,"Well, the banquet was hosted by me"],[7774,7945,"for Jeffrey Harrington's investments,"],[7981,8113,"so if anyone's gonna be leaving,"],[8150,8264,"sure as hell it's not gonna be me."]],"10":[[223,410,"Please! You're just a bastard child"],[410,520,"of the Foster family."],[550,607,"You've barely"],[607,759,"scratched by with our money."],[797,901,"How did you put"],[901,1050,"this banquet together?"],[1081,1233,"It's all making sense."],[1237,1358,"They must have met at some"],[1358,1538,"Delusional Support Group."],[1695,1788,"Sweetie, we need to"],[1788,1881,"get them out of here"],[1881,1998,"before Harrington finds out"],[1998,2181,"that they are part of the Foster family."],[2212,2292,"He might just pull"],[2292,2447,"the billion-dollar investment."],[2645,2739,"Can we talk privately?"],[2922,3099,"Alright, but don't touch me again."],[3530,3620,"You need to leave."],[3620,3694,"The scene you're making,"],[3694,3813,"it's gonna cost me the investment."],[3820,3882,"Oh, believe me,"],[3882,4013,"you're not getting that investment,"],[4013,4140,"and I'm not going anywhere."],[4245,4434,"Caroline, tell me you still love me."],[4434,4614,"That's why you came here, to win me back."],[4634,4714,"Connor's just your way of"],[4714,4858,"making me jealous, right?"],[5342,5455,"We're done!"],[5455,5567,"Touch me again,"],[5567,5797,"and you'll lose everything you have."]],"11":[[5,255,"Liam, did that psycho hurt you?"],[286,527,"No, Caroline's just lost it."],[527,670,"She actually threatened me."],[670,837,"Look, she's not the woman"],[837,1001,"that you used to love, Liam."],[1011,1114,"But don't worry."],[1129,1318,"I've already notified security."],[1349,1414,"She won't be"],[1414,1554,"getting into that banquet."],[1581,1702,"I won't let her"],[1702,1847,"mess with your investments."],[1896,2064,"Thanks, Natty. Really."],[2145,2219,"You go ahead."],[2219,2373,"I just need to hit the bathroom real quick."],[2595,2779,"I can't believe who Liam's become."],[2796,2920,"He'd sell his soul"],[2920,3051,"for that investment."],[3066,3164,"That's who he really is."],[3193,3331,"Honestly, the whole family's like that."],[3376,3426,"Glad we both"],[3426,3585,"escaped that toxic mess."],[3623,3697,"Well, we didn't"],[3697,3881,"exactly escape the same way."],[3890,4060,"I mean, I'm a Harrington."],[4090,4261,"I'll be fine, but you..."],[4261,4370,"poor Connor."],[4426,4495,"Don't worry."],[4495,4663,"I'm here for you if you need anything."],[4674,4783,"You can stop the bluffing."],[4808,4900,"I don't need your help."],[4954,5075,"I'm the CEO of CF Group."],[5075,5146,"Oh, you're still"],[5146,5266,"going with that joke?"],[5291,5384,"You don't believe me."],[5447,5505,"How about this?"],[5505,5650,"When I told Liam you were my date,"],[5665,5758,"you didn't deny it."],[6059,6175,"Would you like to be my real date?"],[6280,6514,"I think this is a distraction"],[6514,6711,"to excuse your bad lie."],[6763,6847,"Not exactly."],[6916,7100,"You seem pretty happy with my body, so..."],[7130,7195,"Connor!"],[7350,7480,"The banquet is about to start."],[7480,7571,"We should go."],[7844,8088,"You two need to leave. Now!"]],"12":[[30,243,"You two need to leave. Now!"],[246,415,"What? Why?"],[420,522,"This is a private event."],[533,620,"Invitation only."],[640,785,"Clearly, you do not have one."],[1698,1864,"What the hell are you doing?"],[2028,2108,"That's a fake invite."],[2108,2152,"What?"],[2152,2221,"Someone like you"],[2221,2311,"would not have one."],[2325,2458,"Do you want to lose your job over this?"],[2629,2842,"This is what a real invitation looks like."],[2886,3053,"Not that trash."],[3070,3203,"One phone call."],[3203,3425,"That is all it will take to get you fired."],[3450,3597,"Oh, so we're bluffing now."],[3597,3776,"Okay. Do you know who my cousin is?"],[3810,3870,"No."],[3880,4053,"He's the VP of CF Group."],[4097,4236,"So how are you gonna get me fired?"],[4250,4360,"Then I think you should call your cousin"],[4360,4507,"and ask him who his boss is."],[4604,4765,"Because I'm the CEO of CF Group."]],"13":[[1,134,"I'm the CEO of CF Group."],[390,578,"You? The CEO of CF Group?"],[600,922,"The biggest tech company in the Bay Area?"],[1011,1111,"Miss Parker told me that"],[1111,1287,"you are clearly nothing"],[1287,1424,"but the bastard"],[1432,1548,"of the Foster family."],[1604,1664,"You know what?"],[1685,1793,"I'll handle this."],[1818,1916,"I'll call Jeffrey"],[1916,2057,"and he'll get rid of this idiot."],[2070,2209,"No need. I'll call the VP."],[2247,2369,"AKA his cousin."],[2422,2686,"Okay, this is your final warning."],[2702,2835,"There are important guests in there."],[2869,2936,"I don't have time"],[2936,3086,"to deal with trash like you."],[3086,3331,"I am one of those important guests."],[3980,4060,"Idiot!"],[4074,4244,"What the hell have you done?"]],"14":[[30,155,"Peter, you're here!"],[265,341,"He's saying"],[341,525,"he's the CEO of CF Group."],[667,774,"What a joke!"],[787,1045,"Do you even realise what you've done, you idiot?"],[1107,1180,"My job?"],[1199,1355,"They're trying to crash the banquet."],[1360,1453,"I stopped them."],[1481,1521,"He attempted..."],[1590,1662,"Damm it!"],[1699,1905,"Do you know who he is, moron?"],[2008,2074,"Yeah!"],[2074,2215,"The Foster Family bastard!"],[2310,2413,"Shut up!"],[2575,2709,"That's Mr. Foster!"],[2720,2954,"The CEO of CF Group."],[2954,3053,"He's your boss!"],[3073,3239,"No, our boss!"],[3253,3376,"-What? -No way!"],[3526,3799,"Sir, I sincerely apologize"],[3799,3936,"on behalf of my cousin."],[4037,4160,"I will contact HR"],[4160,4333,"and have them remove this idiot."],[4385,4591,"You! Apologize now!"],[4597,4803,"I'm truly sorry. I didn't know."],[4834,5022,"If you ever disrespect Miss Harring again,"],[5110,5298,"I'll make sure no company in the city hires you."],[5367,5435,"You got it?"]],"15":[[0,178,"I'll make sure no company in this city hires you."],[191,249,"You got it?"],[407,658,"You're really the CEO of CF Group."],[707,797,"Told you that more than once,"],[797,921,"as far as I can remember."],[1000,1150,"Boss, is this your girlfriend?"],[1214,1267,"Would you like me to"],[1267,1402,"arrange an extra invitation?"],[1458,1534,"Not quite yet."],[1568,1657,"I'm still working on it."],[1657,1739,"Um..."],[1780,1958,"What are you talking about?"],[1958,2126,"I'm your nephew's ex-wife."],[2242,2313,"You did kiss me"],[2313,2402,"and you've seen me naked."],[2429,2509,"Okay."],[2509,2599,"I'm sure that puts us"],[2599,2716,"past the friend stage."],[2766,2819,"Don't you think?"],[3360,3403,"Got it."],[3456,3525,"I'll be right there."],[3580,3648,"Are you gonna be okay"],[3648,3725,"for a bit on your own?"],[3737,3843,"Something urgent just came up."],[3847,4034,"Go. I'll see you at the banquet."],[4079,4126,"Okay."],[5465,5638,"Are you feeling better now that that..."],[5822,5976,"How did that bitch get in here?"],[6022,6156,"One hell of a sneaker!"],[6179,6379,"She better not screw up Liam's investment!"],[6659,6693,"Dad!"],[6756,6839,"Listen, Natty."],[6863,6995,"We're not getting that billion-dollar"],[6995,7103,"investment for Liam."]],"16":[[3,153,"What are you talking about, Dad?"],[153,280,"I promised Liam"],[280,467,"that $10 billion dollar investment."],[513,590,"I don't know."],[597,759,"Did something happen at the banquet?"],[817,985,"Well, Liam's ex-wife"],[985,1146,"has stirred up some drama."],[1324,1528,"Wait. It's her."],[1554,1672,"It has to be her!"],[1751,1840,"What is it, Natty?"],[1868,2125,"That bitch has already ruined Liam's investment."],[2135,2240,"Then do something!"],[3113,3262,"What the hell are you doing?"],[3262,3362,"Let go of me!"],[3386,3481,"You damn whore!"],[3481,3683,"You ruined Liam's investment!"],[3683,3831,"I warned you."],[3831,4020,"Liam was never getting that deal."],[4030,4140,"It's Harrington money."],[4170,4442,"And I am the Harrington heiress."]],"17":[[30,308,"And I am the Harrington heiress."],[330,601,"What idiot let this nutcase"],[601,749,"crash this banquet?"],[807,1033,"Face it, Caroline Harring."],[1117,1171,"You're nothing"],[1171,1293,"without the Foster's name."],[1307,1512,"No. My name is actually"],[1512,1727,"Caroline Harrington."],[1778,2121,"And it's my name that got the Foster's"],[2121,2327,"billions of dollars for their company."],[2379,2628,"But today, it ends."],[2642,2737,"You bitch."],[2737,2832,"It really was you"],[2832,3008,"who sabotaged Liam's investment."],[3013,3195,"Yeah, what did you do, Caroline?"],[3236,3353,"Did you sleep with"],[3353,3546,"the CEO of the CF Group?"],[3570,3800,"Or was it someone from Harrington?"],[3820,3910,"How many men did you"],[3910,4024,"climb over to ruin us?"],[4047,4256,"No, I didn't sleep with anyone"],[4256,4380,"to get in this room."],[4427,4521,"I earned it."],[4521,4760,"But you're clinging on to a guy"],[4760,4887,"who doesn't even want you."],[4911,5085,"That must burn, doesn't it?"],[5120,5333,"Oh, you arrogant slut!"],[5425,5496,"Touch her,"],[5545,5730,"and I swear I'll bury the entire Parker family."]],"18":[[40,95,"Touch her,"],[95,293,"and I swear I'll bury the entire Parker family."],[333,449,"You bastard."],[467,583,"You have no idea"],[583,698,"who you're messing with."],[698,800,"Is this your"],[800,959,"knight in shining armor?"],[994,1205,"A bastard who has nothing?"],[1261,1419,"One phone call to my father"],[1419,1533,"and you'd be out of here"],[1533,1656,"before you can blink."],[1671,1740,"No need."],[1795,1933,"Mm-hmm, okay, well maybe"],[1933,2095,"beg me and I won't do it."],[2118,2209,"Get Kevin Parker."],[2288,2369,"Tell him I have a deal"],[2369,2450,"he'll want to hear."],[2542,2605,"Your father's gonna"],[2605,2676,"be here any minute."],[2679,2797,"You're bluffing."],[2829,2929,"My father wouldn't"],[2929,3046,"even breathe the same air"],[3046,3229,"as a bottom feeder like you."],[3246,3360,"Even let alone do a"],[3360,3493,"business deal with you."],[3506,3556,"Watch your mouth."],[3613,3721,"Oh, Caroline."],[3740,3847,"Defending your lover?"],[3877,4022,"That was fast."],[4077,4120,"You know what?"],[4120,4360,"Actually. It's kind of cute."],[4387,4618,"A gold digger and a bastard."],[4644,4745,"How poetic."],[4754,4933,"I suggest you apologize to Caroline"],[4933,5052,"before your father gets here."],[5060,5185,"Apologize"],[5185,5478,"to a gold-digging charity case?"],[5500,5655,"I'd rather die."],[5730,5802,"What's going on?"],[5870,5975,"Oh, Liam."]],"19":[[16,300,"Oh, Liam, they're ganging up on me."],[300,446,"Caroline, what the hell are you trying to do?"],[457,550,"Are you blind?"],[550,673,"She started it."],[690,857,"How dare you even question me?"],[857,935,"This shameless woman"],[935,1095,"will never apologize."],[1114,1222,"She brought her lover here"],[1222,1330,"like a trophy,"],[1341,1478,"stirred up trouble,"],[1478,1835,"and ruined our $10 billion investment."],[1835,1902,"What?"],[1925,2056,"It's all her fault."],[2072,2275,"My father had everything lined up,"],[2275,2422,"and as soon as they came in here,"],[2422,2588,"they just wrecked everything."],[2609,2667,"Natty!"],[2756,3064,"Oh, Dad, you're finally here."],[3090,3293,"This asshole is bullying me."],[3328,3451,"Poor Caroline."],[3476,3652,"And that pathetic Connor."],[3670,3779,"You two are finished."],[3830,3957,"Dead. Buried."],[4027,4255,"No one messes with the Parkers and walks out."],[4290,4527,"Caroline, apologize right now,"],[4527,4646,"or you'll ruin everything."],[4646,4824,"Daddy, if you let them"],[4824,4983,"stay in L.A.,"],[4983,5087,"I'll leave."],[5087,5130,"I..."],[5130,5302,"I cannot breathe the same air"],[5305,5434,"as these two."],[5490,5577,"God!"],[5625,5813,"You stupid brat!"],[5840,5942,"Do you have any idea"],[5942,6058,"who you're talking to?"],[6096,6443,"This is the CEO of CF Group."],[6556,6666,"Connor Foster."],[6680,6773,"#NAME?"]],"20":[[3,210,"That is Connor Foster,"],[210,426,"the CEO of the CF Group?"],[487,634,"No, that's impossible."],[650,829,"You watch your mouth."],[845,1058,"The CF Group is our biggest client."],[1348,1510,"You mentioned a deal earlier."],[1524,1655,"I think it was about the"],[1655,1836,"DreamStar fiber project."],[1845,1985,"Well, I can assure you,"],[2058,2229,"I can make those deliveries on schedule."],[2262,2371,"The deal is this:"],[2371,2568,"Your daughter, Natalie Parker,"],[2589,2752,"apologizes to Caroline."],[2779,2868,"And in return,"],[2868,3026,"I won't press charges"],[3026,3302,"for staging those fake affairs to frame us."],[3323,3535,"I'm not apologizing to that slut."],[3727,4096,"Peter, cancel every active Parker contract."],[4096,4210,"Effective immediately."],[4254,4381,"No, no, you wouldn't dare."],[4381,4532,"You'll lose everything."],[4534,4617,"You're right."],[4617,4704,"I will lose a fortune."],[4811,4907,"But for Caroline?"],[4984,5095,"Any price is fair."]],"21":[[30,101,"But for Caroline?"],[176,289,"Any price is fair."],[440,524,"He's bluffing."],[588,728,"He wouldn't. He's bluffing."],[780,863,"Sir, bad news."],[863,954,"The market found out"],[954,1088,"CF Group pulled the plug."],[1114,1211,"Our stock is crashing."],[1211,1341,"At this rate, we're done."],[1374,1490,"Dad, what's happening?"],[1790,1978,"You idiot!"],[1978,2210,"You apologize right now!"],[2399,2663,"I'm so sorry, Caroline."],[2663,2871,"I'm so sorry."],[2902,3312,"So, now we can reinstate that contract."],[3312,3475,"I mean, after all,"],[3493,3592,"a deal is a deal."],[3593,3703,"I think you misunderstood."],[3747,3935,"The deal was for your daughter to"],[3935,4050,"apologize to Caroline"],[4050,4220,"and I won't press charges."],[4240,4322,"Canceling the contract."],[4322,4454,"That was just a business decision."],[4544,4625,"And after seeing what kind of"],[4625,4712,"daughter you raised,"],[4730,4910,"I no longer see you as a suitable partner."],[4960,5009,"What?"],[5208,5346,"We can't do anything."],[5402,5492,"No, please, please."],[5492,5647,"Our stock is crashing."],[5702,5810,"If this continues,"],[5810,5933,"we're gonna go bankrupt."],[6022,6106,"You!"],[6125,6345,"You ruined everything."],[6351,6460,"I'll kill you!"]],"22":[[93,173,"Security, get them out of here."],[527,661,"Why would you do all that for me?"],[661,774,"I mean, we"],[774,934,"barely know each other."],[1009,1068,"No."],[1068,1165,"Years ago,"],[1165,1316,"when I was at my lowest,"],[1360,1476,"you were the only one who saw me."],[1980,2151,"Sir, are you okay?"],[2308,2494,"Go away."],[2710,2775,"Here."],[2859,3026,"Look, I don't know"],[3026,3119,"what you're going through."],[3163,3337,"Buy some dry clothes and food."],[3380,3516,"The rain won't last forever"],[3516,3652,"and neither will rock bottom."],[3895,3954,"Here."],[4920,5118,"Hey! What's your name?"],[5261,5367,"From that day on,"],[5402,5559,"that girl stayed in my heart."],[5635,5727,"After I made it,"],[5785,5883,"I tried to find you."],[5950,6077,"But I didn't expect to see you again"],[6077,6188,"at my nephew's wedding."],[6533,6696,"I thought you were happy."],[6696,6813,"So I stayed away."],[6813,6970,"Then I heard Eileen treated you like dirt."],[6990,7083,"So you showed up"],[7083,7198,"at that birthday party?"],[7210,7330,"I meant to warn her."],[7413,7515,"But instead..."],[8221,8303,"This time,"],[8323,8484,"I'm not going to miss my shot with you."],[8640,9047,"I... I need a second."]],"23":[[363,541,"Enjoying the view, bitch?"],[650,762,"That's all you got?"],[773,881,"Bad words?"],[882,1173,"I underestimated you, didn't I?"],[1194,1575,"First Liam, then Connor Foster."],[1604,1797,"You really did sleep your way"],[1797,1918,"to the top."],[1945,2099,"Your cheap scandal"],[2099,2268,"cost me the investment."],[2285,2448,"It cost me Liam."],[2479,2656,"You have taken everything from me."],[2656,2812,"It is all your fault."],[2812,2970,"Oh, don't touch me."],[2970,3158,"I have no idea what you're talking about."],[3158,3300,"razy person."],[3375,3455,"Crazy?"],[3466,3727,"You wanna see how crazy I can get?"],[3770,3832,"Ah!"],[3886,3952,"Ah!"],[4070,4167,"-Ah! -Ah!"]],"24":[[350,460,"Help! I..."],[460,535,"I can't swim!"],[557,653,"Lifeguard, move!"],[653,715,"Caroline!"],[1751,1846,"I got you, Caroline."],[1880,1961,"I got you."],[2549,2685,"Come on, Caroline."],[2685,2744,"Wake up."],[4017,4164,"You saved me."],[4350,4434,"You!"],[4484,4629,"You pushed me!"],[4644,4849,"Please don't flatter yourself."],[4860,5014,"You pushed me first."],[5045,5228,"And Jeffrey Harrington is gonna be here"],[5228,5435,"to kick you out of the banquet for good."],[5542,5598,"Caroline?"],[5863,6040,"Is that Jeffrey Harrington,"],[6040,6201,"heir of the Harrington family?"]],"25":[[16,196,"Is that Jeffrey Harrington,"],[196,356,"heir of the Harrington family?"],[400,490,"I thought he only showed up"],[490,633,"for billion dollar deals."],[633,745,"I wouldn't be surprised"],[745,951,"if that Caroline fell on purpose."],[994,1077,"Some women will do"],[1077,1274,"anything for a rich man's gaze."],[1293,1402,"Did you hear that?"],[1419,1598,"That tramp is greedier than we thought."],[1624,1717,"And now she's angling"],[1717,1843,"for the Harrington fortune."],[1868,1976,"Mom, shut up."],[2292,2533,"My uncle, CF Group CEO."],[2562,2672,"The Harrington heir."],[2699,2797,"How many men were you seeing"],[2797,2924,"behind my back, Caroline?"],[3033,3143,"Caroline, look at me."],[3223,3317,"Any dizziness?"],[3330,3412,"I'm fine."],[3430,3510,"Easy, man."],[3510,3619,"She just needs some rest."],[3690,3811,"Thank you for saving her."],[3913,4057,"So she says she's your sister, huh?"],[4167,4320,"Yeah, she's my, um..."]],"26":[[43,206,"Yeah, she's my, um..."],[243,374,"Mr. Harrington,"],[374,550,"what an honor it is to meet you."],[607,805,"I'm Eileen Foster, Liam's mom,"],[834,1022,"and a board member of the Foster Group."],[1022,1133,"Foster family?"],[1133,1267,"Ah, yes, I know."],[1296,1381,"A family known for"],[1381,1510,"tormenting their own..."],[1578,1661,"pardon me..."],[1691,1841,"former daughter-in-law."],[1918,2144,"I've seen street rats treat family drama"],[2144,2244,"with more class than you."],[2258,2343,"Those were all lies"],[2343,2499,"spread by that spiteful woman."],[2519,2714,"She cheated on my son,"],[2714,2928,"and he had no choice but to divorce her."],[2955,3133,"Then she married into our family,"],[3149,3273,"and did nothing but spend our money"],[3273,3405,"for three whole years."],[3405,3509,"Spend your money?"],[3570,3715,"You do realize that"],[3715,3970,"every penny in the Foster Group is from my..."]],"27":[[23,230,"You do realize that every penny"],[230,389,"in the Foster Group comes from my..."],[389,498,"Your family, I know,"],[498,617,"and thank you so much."],[617,787,"I really appreciate it, Mr. Harrington."],[800,884,"Mr. Harrington,"],[884,999,"we really need to talk."],[1034,1107,"The Foster family-"],[1107,1197,"Let me be clear."],[1237,1405,"I don't like the Foster family."],[1424,1620,"And I don't work with people I don't like."],[1670,1735,"Guard!"],[1749,1860,"Escort her away!"],[1930,1983,"Come on."],[2308,2469,"She's not my sister."],[2515,2767,"She's just one I have to protect."],[2920,2989,"Um."],[3015,3139,"May I speak with you privately?"],[3190,3267,"Sure."],[3268,3403,"It's funny, there's a whole party here"],[3403,3472,"full of women,"],[3485,3623,"yet you seem interested in mine."],[3697,3860,"Mind explaining yourself, Mr. Harrington?"],[3897,4124,"Um, Mr. Harrington is..."],[4124,4314,"Is that so hard to understand?"],[4377,4638,"I'm trying to win Caroline over."],[4705,4794,"Ew!"]],"28":[[8,273,"I'm trying to win Caroline over."],[299,421,"Ew!"],[427,566,"Jeffrey Harrington and Caroline?"],[620,753,"When did that even start?"],[801,857,"Idiot."],[887,955,"I should've asked her out"],[955,1154,"the second she signed those divorce papers."],[1165,1288,"She just went through a shock."],[1341,1434,"She needs rest."],[1471,1587,"Is that what she wants?"],[1651,1837,"Or just what you decided for her?"],[1925,1994,"Um..."],[2015,2189,"Guys, can we not be"],[2189,2318,"tomorrow's headline?"],[2650,2781,"Ladies and gentlemen,"],[2802,2972,"my father is interested in finding"],[2972,3136,"a suitable match for my sister."],[3226,3409,"I'll be hosting a ball with some of"],[3409,3589,"high society's finest"],[3620,3801,"and most eligible bachelors."],[3837,4022,"Is that really necessary?"],[4080,4195,"Mr. Foster,"],[4256,4442,"I've shown your photo to my sister."],[4540,4645,"She'd like you to attend."],[4654,4726,"Thank you,"],[4731,4891,"but I already asked Caroline on a date,"],[4904,5147,"so I think I'll skip this invitation."],[5230,5467,"Just come, you won't regret it."],[5574,5700,"And Connor,"],[5769,5925,"thanks for taking care of Caroline."],[6167,6330,"You should go to the ball with Miss Harrington."],[6335,6528,"Caroline, you know I'm serious about you."],[6539,6721,"You have nothing to worry about, just..."],[6787,6867,"go."]],"29":[[316,430,"What was that?"],[437,525,"Why are you saying"],[525,648,"I'm not your sister?"],[687,846,"And why the hell"],[846,954,"are you telling Connor"],[954,1150,"you're trying to win me over?"],[1167,1294,"Because someone's making a move"],[1294,1420,"on my kid sister."],[1490,1634,"Announcing some competition"],[1634,1777,"tends to scare guys like that off."],[1840,1989,"I was testing him for you."],[2015,2217,"Okay, Connor isn't that bad, Jeff."],[2220,2419,"And there's nothing going on between us."],[2420,2532,"I know him."],[2539,2725,"He's sharp in business, but love?"],[2812,2930,"That I'm not so sure about."],[2979,3110,"After everything you went through"],[3110,3190,"with your marriage,"],[3213,3316,"you should be careful,"],[3354,3472,"with everyone."],[3575,3699,"All right, big brother."],[3970,4051,"What was that?"],[4094,4227,"Don't tell me you're crushing on the guy."],[4227,4340,"Of course not."],[4461,4627,"I just have a little pool water"],[4627,4714,"stuck in my throat."],[4714,4780,"That is all."],[4793,5005,"Hospital, first thing tomorrow,"],[5015,5093,"got it?"],[5125,5225,"Yes, sir."]],"30":[[363,561,"Why did you push Caroline, Natty?"],[580,661,"Listen."],[737,898,"She was in the way."],[917,1153,"You need somebody more like me"],[1153,1263,"who understands you."],[1263,1385,"Answer the damn question."],[1401,1591,"Do not talk to me like that, Liam."],[1604,1650,"I'm-"],[1730,1803,"Eileen."],[1945,2125,"Please tell your son that"],[2125,2317,"I am meant to be his wife."],[2328,2468,"I wouldn't be so sure, Natty."],[2564,2634,"What?"],[2642,2801,"I thought that you said"],[2801,3043,"I was the ideal daughter-in-law."],[3049,3258,"Not after your family went bankrupt."],[3263,3390,"You're just a liability—"],[3390,3526,"worse than Caroline."],[3526,3615,"So she's..."],[3615,3739,"She's your favorite now?"],[3805,3877,"Funny,"],[3877,3997,"you didn't like her very much"],[3997,4166,"when we were framing her and Connor."],[4166,4214,"Wait."],[4214,4307,"You framed my wife?"],[4320,4387,"She's just lying."],[4387,4454,"Lying?"],[4571,4740,"What about the three years"],[4740,5000,"that you made Caroline be your maid,"],[5000,5126,"scrub the floors,"],[5126,5262,"do your dirty laundry?"],[5262,5397,"Shut your mouth, you idiot!"],[5822,5922,"I did everything for you."],[5922,6042,"To save this company."],[6042,6164,"By torturing my wife?"],[6219,6353,"You crossed the line, Mom."],[6389,6495,"Ex-wife."],[6778,6968,"The Harringtons are having a banquet."],[7007,7144,"Their heiress needs a husband."],[7150,7260,"That's your last shot."],[7377,7483,"You really think"],[7483,7645,"Harrington will let a Foster"],[7645,7773,"into their bloodline?"],[7827,7973,"I would look after your own house."],[8001,8081,"I hear the bank is"],[8081,8183,"seizing it next month."],[8210,8274,"Pack your stuff"],[8282,8365,"and get out of here."],[8371,8492,"You smug bitch!"],[8775,8830,"Enough!"],[9300,9370,"Liam?"]],"31":[[0,106,"Get out of my house"],[106,258,"or I'm gonna call the police."],[557,754,"You will regret this."],[837,970,"I swear it."],[1317,1384,"I don't care about"],[1384,1482,"the Harrington heiress."],[1524,1641,"I'm gonna take my wife back."],[1681,1768,"From now on,"],[1768,1903,"stay out of my love life."],[2108,2203,"The Foster Group is"],[2203,2300,"leaking money, Liam."],[2422,2548,"Win that heiress"],[2548,2664,"and build this company."],[2723,2847,"Or chase your ex-wife"],[2847,2951,"and lose everything."],[2999,3083,"Your choice."],[3633,3796,"Fresh start after the divorce."],[3903,4024,"Thought this place suited you."],[4154,4360,"Mr. Foster made me show him"],[4360,4552,"50 listings before he chose this one."],[4611,4694,"You know, you're really lucky to"],[4694,4889,"have such a devoted husband, Mrs. Foster."],[4921,5097,"Actually, he's not my husband."],[5201,5297,"Modern couples."],[5328,5405,"Totally get it."],[5430,5552,"Marriage isn't for everybody."],[5572,5676,"Yeah, I'm still trying to get her to"],[5676,5790,"change her mind."],[5842,5968,"But thank you for the blessings."],[6092,6280,"So, should we finalize things?"],[6302,6490,"Absolutely, let's sign."],[7360,7683,"So, the CEO of CF Group"],[7683,7930,"is helping me shop for apartments."],[7952,8098,"Shouldn't you be private jetting"],[8098,8181,"around the world?"],[8195,8275,"I always make time"],[8275,8402,"for the people who matter most."],[8445,8635,"How should I thank you for this?"],[8880,8980,"How about..."]],"32":[[690,814,"Is that how you"],[814,969,"want me to thank you?"],[2002,2185,"Didn't you ask me before how to thank me?"],[2349,2475,"I thought I already did that."],[2475,2592,"Don't be greedy."],[2734,2839,"Keep me company."],[2882,3068,"Protect me from the heiresses' advances."],[3081,3174,"How's that sound?"],[3370,3683,"Fine. One night. That's it."],[3757,3961,"Deal. I'll pick you up this weekend."],[3979,4145,"I have some surprises planned for you."],[4300,4402,"I've gotta go."],[4402,4497,"I'll see you this weekend."],[5910,6019,"That must be Connor."]],"33":[[30,100,"Liam?"],[136,303,"I heard you got a new place."],[303,445,"I thought I'd bring you a housewarming gift."],[490,613,"You always loved the smell of fresh"],[613,714,"espresso in the morning."],[714,961,"Um, we get divorced,"],[961,1124,"and now you finally remember"],[1124,1241,"that I like coffee."],[1297,1464,"Isn't it a little late for that?"],[1464,1623,"Please, Caroline, I only recently"],[1623,1715,"found out the truth."],[1735,1795,"It was Natty."],[1901,1963,"Caroline."],[2010,2070,"Wait!"],[2112,2159,"Whoa!"],[2178,2258,"Are you crazy?"],[2258,2383,"You're gonna hurt yourself."],[2392,2505,"This pain is nothing compared to"],[2505,2575,"what you went through."],[2632,2793,"Three years of abuse in my house"],[2806,2916,"from the woman who was supposed to"],[2916,3036,"treat you like family."],[3056,3135,"Yeah."],[3146,3203,"I heard what my mom"],[3203,3289,"and Natty did to you."],[3329,3631,"I was to blind, to caught up in work,"],[3646,3823,"and I just stood there while you drowned."],[3860,3932,"I failed you."],[4481,4611,"Remember our first date?"],[4647,4801,"You said the aroma of fresh coffee"],[4801,4914,"and roses felt like home."],[4964,5095,"I want to be that home again."],[5108,5174,"Please."],[5215,5368,"Give me the chance to make things right."],[5555,5755,"Um, Liam,"],[5779,5979,"I- I forgive you..."],[5979,6320,"But there is something I need to talk to you."]],"34":[[16,103,"There is something"],[103,315,"I need to talk to you."],[530,595,"Crap."],[595,893,"If Connor shows up now and sees Liam,"],[893,1094,"this is gonna look so bad."],[1141,1433,"Um, actually I don't think this is a good time."],[1433,1530,"Uh, you should go."],[1542,1634,"I‘ll talk to you later."],[1945,2014,"You can shut the door,"],[2014,2095,"but I'm not leaving."],[2352,2434,"Hey."],[2439,2604,"So you ready for a weekend of surprises?"],[2604,2780,"Actually, something came up. I'm"],[2780,2940,"busy this weekend now."],[2940,3152,"Uh, could we possibly reschedule?"],[3152,3224,"Too late."],[3224,3350,"I'm just a couple minutes away."],[3350,3480,"I'm not leaving until we talk."],[3520,3603,"What's that noise?"],[3680,3951,"Um, it's... it's just the TV."],[3967,4151,"Alright. See you in a few."]],"35":[[413,471,"Hey."],[480,568,"Where'd you come from?"],[593,622,"Um..."],[637,730,"I've been staring at your front door."],[804,890,"Um, well..."],[1491,1656,"Caroline, please come talk."],[1738,1898,"I'm not leaving till you talk to me."],[2118,2210,"A magician never"],[2210,2346,"reveals her tricks."],[2762,2917,"And this one just landed"],[2917,3034,"off the runway yesterday."],[3059,3116,"Would you like me to put it"],[3116,3263,"in the dressing room for you, Ma'am?"],[3596,3680,"Caroline?"],[3800,3983,"Oh, um, yeah."],[4000,4123,"It's beautiful. Thank you."],[4137,4246,"Can you give us a minute, please?"],[4297,4351,"Thank you."],[4562,4624,"All right."],[4708,4835,"What's going on in that head of yours?"],[4863,4924,"What is it?"],[4924,5035,"Am I pushing too hard?"],[5060,5125,"Just tell me."],[5125,5248,"I don't want you to feel uncomfortable."],[5248,5388,"No, Connor. You're..."],[5428,5572,"doing everything right."],[5572,5669,"It's just..."],[5712,5829,"I want to be that home again."],[5845,5914,"Please."],[5949,6096,"Give me a chance to make things right."],[6175,6236,"Um, earlier..."],[6259,6311,"Oh!"],[6343,6519,"Mr. Harrington, you should've told us"],[6519,6632,"you were stopping by today."]],"36":[[56,240,"The bracelet I ordered for my sister."],[266,367,"I am so sorry."],[367,487,"We didn't know you were coming by,"],[487,632,"so we haven't cleared the floor yet,"],[632,746,"but I will..."],[837,1034,"I'll escort these customers out right away."],[1181,1364,"Connor! Caroline!"],[1424,1562,"What a coincidence."],[1562,1776,"Yep, and Caroline's still my plus one."],[1870,1956,"You're late again."],[1975,2089,"Plus one?"],[2141,2328,"Plus one to what?"],[2335,2446,"The Harrington gala?"],[2550,2675,"So I guess we'll be seeing you there."],[2832,2983,"You agreed to be his date?"],[2996,3129,"Again?"],[3129,3269,"What a surprise!"],[3269,3470,"Yes, Mr. Harrington."],[3493,3640,"It is a surprise,"],[3640,3931,"and I will see you at the gala."],[3931,4090,"Apologies, ma'am. Uh..."],[4090,4358,"The Harringtons always shop privately."],[4396,4600,"Um, store policy."],[4617,4703,"Of course."],[4806,4918,"I'll be on my way."],[5151,5287,"We're not leaving until this lady"],[5287,5426,"finds something she likes."],[5727,5901,"The unlimited black card?"]],"37":[[70,213,"The ultimate black card?"],[257,495,"Uh, sir, maybe there's a way"],[495,544,"that we can-"],[544,637,"It's fine."],[681,774,"They can stay."],[794,966,"Uh, I will go and get that"],[966,1135,"custom bracelet for Miss Harrington."],[1164,1239,"No rush."],[1381,1536,"You're attending the Harrington gala."],[1584,1811,"Well, allow me to buy you a dress."],[1856,2227,"Something worthy of the night."],[2295,2504,"No, Mr. Harrington, I- It's-"],[2504,2580,"No need."],[2661,2762,"She's my date."],[2816,3009,"I'll make sure she gets nothing but the best."],[3036,3177,"The best? Really?"],[3260,3433,"Harrington is the top of the list at"],[3433,3608,"every couture house."],[3670,3784,"First access."],[3827,3985,"Custom palettes."],[4044,4217,"You think you can really compete with that?"],[4420,4540,"I'll buy every gown in the store."],[4617,4737,"Rack, back of the room,"],[4824,4933,"anything on a mannequin."],[5011,5136,"Go and swipe it, please."]],"38":[[13,337,"No, that is not necessary."],[337,462,"I mean, every gown?"],[462,587,"I can't wear every-"],[593,690,"Princess deserves"],[690,804,"everything beautiful in the world."],[880,964,"And you, Caroline,"],[1021,1124,"you deserve everything."],[1292,1358,"Hold on."],[1541,1680,"I just bought every gown in the store."],[1722,1839,"You're a little late to the party again,"],[1839,1898,"aren't you?"],[1898,2157,"Bring out that jewelry I reserved."],[2198,2403,"Let Ms. Harring"],[2422,2561,"choose whatever she likes."],[2579,2672,"But sir,"],[2763,3000,"that collection is for Harrington's only."],[3060,3212,"I'm Harrington,"],[3313,3438,"and I get to choose"],[3438,3570,"whoever the hell I want."],[3740,3797,"Now go."],[3830,3868,"Okay."],[4147,4275,"No outfit is complete"],[4275,4481,"without a little sparkle."],[4550,4724,"Wouldn't you agree, Mr. Foster?"],[4794,4995,"Guys, let's not fight."],[5018,5165,"Look, weather's lovely,"],[5165,5259,"don't you think?"],[5291,5377,"Absolutely."],[5445,5520,"Perfect weather"],[5520,5671,"for a top-down drive."],[5770,5880,"Speaking of which,"],[5933,6093,"picking up a new convertible today."],[6152,6237,"Care to join me?"],[6289,6439,"You're crossing the line, Jeffrey Harrington."],[6453,6539,"Calm down."],[6570,6810,"Mr. Foster, thank you for your"],[6810,6981,"generous patronage."],[7000,7098,"These are just a"],[7098,7200,"portion of your order."],[7200,7292,"The rest will be delivered"],[7292,7437,"to your residence this afternoon."],[7437,7534,"If anything doesn't fit,"],[7534,7670,"just have them tailor it immediately."],[7813,7874,"I'm sorry, what?"],[7891,8076,"Let's see how your fabric compares"],[8076,8331,"to 16 carats of Kashmiri sapphire."]],"39":[[30,114,"Two billionaires"],[114,235,"fighting over one girl?"],[246,337,"I thought that only"],[337,436,"happened in movies."],[483,668,"God, I'd kill for that kind of luck."],[680,804,"Mr. Harrington,"],[804,937,"the jewels..."],[937,1037,"It's too much."],[1084,1153,"Come on."],[1177,1322,"Just try it."],[1374,1504,"See it sparkle."],[1654,1791,"You may have the money and the power,"],[1812,1898,"but Caroline's not some"],[1898,2020,"trophy for you to flaunt."],[2195,2265,"Have all the gowns"],[2265,2397,"delivered to Ms. Harring's place."],[2950,3242,"Caroline, I know this might seem sudden, but..."],[3295,3389,"I have to say it,"],[3516,3634,"I like you."],[3718,3812,"A lot."],[3847,3973,"Jeffrey Harrington might have"],[4022,4172,"all the power and money in the world,"],[4190,4302,"but I'll give you all of me."],[4391,4494,"Give me a chance and I'll prove to you"],[4494,4641,"that I'm the man who deserves you."],[4838,5008,"Thank you, Conner,"],[5008,5136,"for saying all of that."],[5215,5302,"That was brave."],[5360,5570,"Jeffery's status, Liam's past."],[5642,5781,"None of that scares me off."],[6007,6157,"I like you, Caroline Harring."]],"40":[[647,790,"This is about Conner, isn't it?"],[827,1051,"That little boutique showdown?"],[1174,1287,"I gotta say,"],[1320,1422,"pretty impressive."],[1494,1660,"Took more guts than Liam's ever shown."],[1735,1861,"Yeah, it's pretty"],[1861,1961,"damn clear he's into you."],[2092,2268,"It's not just about that."],[2325,2465,"Liam was my first love."],[2465,2697,"You can't just erase that"],[2697,2833,"with divorce papers."],[2833,2959,"Don't tell me you still have feelings"],[2959,3103,"for that spineless brat."],[3103,3343,"No, Liam came by,"],[3383,3587,"he brought up things"],[3587,3744,"from when we were happy,"],[3752,3960,"and it hit me."],[4000,4250,"What if, no matter who I end up with,"],[4287,4496,"it just all ends the same way?"],[4521,4671,"Disappointment,"],[4671,4803,"divorce,"],[4985,5085,"heartbreak."],[5135,5295,"Yeah, Liam hurt you,"],[5318,5502,"but not every guy will."],[5538,5712,"If Conner means something to you,"],[5799,5969,"don't let fear hold you back."],[6249,6336,"Thank you."],[7170,7299,"Straighten up and smile."],[7380,7563,"We need this heiress to say yes."],[8628,8846,"I won't let you get away with this."],[8860,9137,"Liam is mine, and mine alone."]],"41":[[407,487,"Who is she?"],[517,750,"That's a fresh-off-the-runway piece."],[1004,1148,"Relax, I don't steal"],[1148,1254,"another man's date."],[1270,1411,"Oh really? That's new."],[1591,1850,"Caroline, you look radiant."],[1868,1992,"The true star of the night."],[2165,2345,"Excuse me, I have"],[2345,2561,"to use the restroom."],[2800,3039,"Well, I've gotta go into host mode."],[3063,3136,"Excuse me."],[3433,3579,"Dammit, he hasn't"],[3579,3677,"given up yet, has he?"],[4457,4601,"I can't do it, Jeff."],[4641,4844,"I've been Caroline Harring for so long,"],[4844,4978,"what if I don't know how to be"],[4978,5125,"Caroline Harrington anymore."],[5181,5379,"And what if Conner thinks I lied?"],[5379,5499,"Then be both."],[5685,5965,"Harring or Harrington,"],[5965,6129,"I'll support you either way."]],"42":[[787,928,"Thank you for everything."],[1408,1517,"Is that-"],[1517,1627,"The Harrington heirloom."],[1738,1801,"Passed down through"],[1801,1957,"every heiress since 1920."],[2060,2335,"Tonight, the world sees it shine"],[2385,2612,"where it belongs on a princess."],[2762,2839,"You ready?"],[3063,3206,"Let's give them a show."],[3520,3632,"Ladies and gentlemen,"],[3632,3853,"Mr. Jeffery Harrington presents his sister."],[3875,4047,"The heiress to the Harrington legacy,"],[4058,4204,"Miss Caroline Harrington."],[4597,4842,"Look! That's the hidden heiress."],[4884,5008,"Did you see that bracelet?"],[5045,5148,"It's worth millions."],[5160,5249,"Go charm her."],[5249,5333,"If she picks you,"],[5362,5537,"Foster Group just might stay afloat."],[5675,5886,"Why does the heiress feel so familiar?"]],"43":[[253,400,"Look who slithered back in."],[470,617,"Didn't take you long to trade that"],[617,790,"pathetic little Caroline"],[820,965,"for someone with a title, huh?"],[980,1074,"Guess you really are a"],[1074,1237,"social-climbing fraud."],[1257,1330,"I don't date women"],[1330,1454,"for status, Eileen."],[1504,1590,"Unlike your son here"],[1590,1661,"who threw away his wife"],[1661,1815,"the moment someone shinier walked in."],[1815,1933,"I didn't throw her away."],[1955,2128,"I'm gonna win her back, I swear it."],[2135,2188,"You?"],[2270,2354,"Please."],[2392,2510,"Caroline's on a date with me tonight."],[2522,2623,"What, she's here?"],[2712,2776,"I need to find her."],[2802,2856,"Liam!"],[2882,3005,"Don't even think about it, Liam."],[3043,3177,"I'm not gonna let you near her again."],[3420,3507,"Come back here."],[3540,3645,"Tell me where she is."],[3980,4097,"She's taken too long."],[5065,5145,"Caroline, where are you?"]],"44":[[70,166,"Caroline, where are you?"],[240,504,"Um, I... I got lost."],[527,710,"This place, it is enormous."],[710,813,"It... It's like..."],[813,908,"like a maze."],[937,1064,"Guess I better stick by your side."],[1070,1281,"Oh! You know what?"],[1281,1428,"I found a door."],[1438,1529,"Mm-hmm. Yeah, I'll-"],[1529,1700,"I'll see you soon. Okay, bye."],[1815,1875,"Gosh."],[3572,3683,"#NAME?"],[3683,3751,"Caroline, listen."],[3777,3916,"I didn't come here for the Harrington heiress."],[3927,4052,"My mom put me up to this, I swear."],[4090,4221,"Liam, this really is not the time."],[4267,4458,"Please, Caroline. I miss you."],[4491,4641,"I miss us. Just come back to me."],[4741,4951,"Where is Liam? I swear I saw him"],[4951,5138,"come this... way."],[5198,5384,"That filthy little bitch!"],[5412,5490,"She's still trying"],[5490,5636,"to steal Liam from me."],[5753,5826,"Hey."]],"45":[[19,90,"Hey."],[153,270,"Ahhh! Hi."],[270,363,"Have you seen Caroline?"],[457,553,"Blonde blue dress,"],[553,637,"about your height?"],[727,905,"Um... no."],[1234,1365,"Why the hell do all these"],[1365,1603,"stupid men keep falling for you?"],[1634,1735,"You manipulative"],[1735,1900,"little whore, Caroline."],[2302,2502,"Face it, Liam. We're done."],[2539,2721,"From the moment you stopped believing me,"],[2751,2858,"we were done."],[3270,3348,"Caroline."],[3680,3823,"Father wants to see you."],[3873,3983,"You need to change back"],[3983,4134,"Full Harrington mode."],[4156,4274,"Come here right now."],[4497,4757,"Um, it's so good to run into you, Conner,"],[4757,4999,"but I have to"],[4999,5260,"use the restroom again."],[5325,5579,"Caroline, I can recognize Jeffery's voice by now."],[5775,5940,"Is she really choosing Jeffery?"]],"46":[[93,227,"Is she really choosing Jeffery?"],[323,427,"Also earlier,"],[460,720,"I saw you and Jeffery leaving one after another."],[720,807,"Does he-"],[807,1047,"It's- It's not what it looks like."],[1047,1148,"It's okay."],[1169,1339,"If you've chosen Jeffery,"],[1444,1554,"I'll respect it."],[1609,1807,"But I'm not stepping aside without telling you"],[1817,2155,"I like you Caroline. So damn much."],[2175,2321,"It's getting hard to keep it in."]],"47":[[273,483,"Um, that, that, that,"],[483,634,"that was just impulse, okay?"],[657,857,"I had too much to drink."],[857,1037,"I'm gonna go get some air."],[1064,1197,"I mean, I mean freshing..."],[1244,1282,"Uh."],[1282,1373,"I gotta go!"],[1735,1895,"Caroline, your bag!"],[3094,3176,"It's her."],[3372,3510,"It's Caroline"],[3526,3604,"Harrington."],[3633,3773,"And Jeffery's only her brother."],[4936,5051,"Oh, my bag."],[5555,5707,"Natty, what are you-"]],"48":[[357,457,"Help me!"],[473,670,"Quiet, I'm on the phone."],[1370,1504,"Come on."],[1540,1698,"Pull yourself together, Liam."],[1715,1857,"The Foster Group won't survive a quarter"],[1857,1972,"without this match."],[1972,2145,"Mom, I told you, I don't wanna..."],[2605,2792,"Natty, I said to stop calling me."],[2800,3038,"Liam? Liam, is that you?"],[3043,3129,"Help me!"],[3130,3199,"Caroline?"],[3230,3322,"Caroline, are you okay?"],[3430,3524,"Where are you going?"],[3800,3855,"Caroline!"],[4167,4337,"Easy, you don't wanna do this."],[4337,4404,"Shup up."],[4404,4563,"Do not take one more step"],[4563,4686,"or she'll die."],[4694,4748,"Let her go."],[4794,4906,"Whatever it is you want,"],[4906,4992,"I'll make it happen."],[5000,5056,"Me too."],[5098,5218,"Please, just put the knife down."],[5248,5335,"We can figure this out."],[5360,5422,"Liam."],[5475,5677,"Two birds, one stone."],[5879,6113,"I didn't think I'd get so lucky."],[6149,6426,"You, Mr. Mystery CEO,"],[6426,6758,"I want half of the CF Group,"],[6758,6913,"and I want it now!"],[6913,6970,"Deal,"],[6970,7107,"I'll have my lawyers draft the papers up."],[7190,7501,"And you, I want you"],[7501,7721,"to marry me tonight."],[7740,7787,"That's..."],[7802,7904,"Absolutely not."],[7961,8081,"This lunatic isn't marrying into"],[8081,8196,"the Foster family."]],"49":[[76,214,"Don't listen to her."],[214,390,"Focus on the Harrington heiress."],[390,545,"This is a matter of life and death."],[545,630,"Mom, I can't just-"],[630,760,"So is the Foster family."],[760,858,"The only thing that's gonna save us"],[858,964,"is the Harrington marriage."],[1007,1141,"Tick tock!"],[1191,1519,"Liam, marry me tonight"],[1519,1686,"or she will die!"],[1686,1729,"Stop!"],[1798,1961,"You desperate little bitch."],[1961,2118,"The Parker family's gone bankrupt"],[2118,2238,"and now you're trying to crawl your way"],[2238,2370,"back into my family?"],[2370,2543,"Over my dead body!"],[2549,2850,"Then she will die!"],[2850,2922,"No!"],[3198,3290,"Grab her!"],[3574,3663,"Ah!"],[3701,3780,"No!"],[3878,3942,"Are you okay?"],[4203,4381,"Hey! God damn it!"],[4556,4718,"Caroline, are you hurt?"],[4931,5121,"Why is everybody fawning over her?"],[5121,5291,"She's a goddamn nobody."],[5305,5416,"A nobody?"],[5422,5565,"She's my sister!"],[5580,5749,"Blood of the Harrington Line,"],[5781,5964,"heiress to the Harrington empire."],[5964,6056,"-What? -What?"]],"50":[[417,537,"Caroline,"],[537,676,"Miss Harrington,"],[683,800,"please forgive me."],[837,927,"I didn't know-"],[927,1110,"My name doesn't matter, Eileen."],[1174,1250,"What matters is"],[1250,1479,"that you don't deserve forgiveness."],[1521,1695,"Not from me, not ever."],[1891,2028,"Three years."],[2028,2163,"I used Harrington"],[2163,2318,"funds and contracts"],[2318,2511,"to keep Foster Group afloat,"],[2545,2812,"but today, all deals are off."],[2859,2950,"Sorry, Liam."],[2952,3162,"Please, Caroline, we can fix this."],[3186,3395,"I spent so much energy,"],[3395,3589,"trying to make you into a real man."],[3606,3755,"That was my first mistake."],[3767,3861,"I received"],[3861,4007,"disrespect from your family"],[4007,4147,"and you didn't trust me."],[4187,4318,"We're over."],[4318,4435,"But come on,"],[4435,4565,"the night's not over yet."],[4624,4907,"Maybe we'll end up family after all."],[4934,5011,"Who knows?"],[6160,6272,"Thank you all for"],[6272,6439,"celebrating my homecoming."],[6479,6729,"I know my brother invited"],[6729,7051,"every eligible bachelor in L.A.,"],[7097,7434,"but tonight, I won't be picking a husband."],[7480,7714,"I already have someone in mind."],[7837,8029,"Go on, don't be a coward."],[8671,8745,"I know this is a"],[8745,8940,"perfect moment for a proposal."],[8982,9135,"I just never planned on marrying a"],[9135,9246,"Harrington heiress,"],[9284,9411,"so I didn't bring you a ring."],[9572,9889,"This is the Harrington family ring."],[9913,10023,"You've earned it, Conner."],[10085,10246,"Now ask my sister the right way."],[10500,10595,"Caroline Harrington?"],[10700,10793,"Caroline Harring?"],[10850,10980,"I don't care what the world calls you."],[11064,11137,"To me, you're the woman"],[11137,11249,"who changed everything."],[11660,11773,"Will you marry me?"],[11900,12154,"Yes, of course."],[13032,13146,"To Caroline,"],[13146,13269,"the Harrington Heiress."]]}