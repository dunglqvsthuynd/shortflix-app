,[6865,6965,"Can someone please"],[6965,7094,"help me find our son?"],[7294,7432,"This is for us, Wyatt."],[8324,8383,"Hey, hey."],[8621,8854,"Are you my dad?"],[8979,9054,"Yeah, kid."],[9138,9263,"I'm your dad now, okay?"],[9359,9563,"Your name is Wyatt."],[9651,9759,"Got it, you little shit?"],[9763,9801,"Come here."],[10276,10402,"Now we just gotta get you out of here"],[10402,10523,"without anyone seeing."],[11207,11282,"It's all my fault."],[11382,11494,"I let him out of my sight."],[11615,11720,"What kind of mother am I?"],[12116,12191,"This isn't on you."],[12258,12354,"We'll find Asher."],[12412,12491,"I promise you."],[12645,12712,"I'll never give up."],[12833,12875,"Okay?"],[13038,13188,"We managed to stabilize the boy."],[13242,13284,"But,"],[13329,13521,"since we can't find his parents,"],[13626,13767,"we'll have to call Child Services."],[13822,13863,"No."],[13963,14043,"The poor boy's been through"],[14043,14114,"too much already."],[14114,14226,"You can't put him in the system."],[14668,14735,"We'll foster him"],[14735,14839,"until his parents are found."],[14839,14869,"Yeah."],[14939,15077,"You Bradshaws are angels."],[15315,15482,"Where are you, Asher?"]],"4":[[325,437,"What'd you say, bitch?"],[454,592,"If you wanna mess with little guys,"],[638,729,"you'll have to go through me."],[2260,2373,"Get back in your cell, man."],[2873,2915,"Come on."],[2948,3032,"It's your lucky day."],[3069,3169,"You're being released."],[4800,4988,"I'm hoping you learned a lesson."],[5059,5226,"Stealing tools from a store."],[5226,5351,"That's not the kid I raised."],[5405,5501,"It's his fifth time."],[5576,5659,"If he does this again,"],[5659,5780,"he'll be tried as an adult,"],[5780,5918,"so make sure he stays out of trouble."],[6106,6185,"I wish you the best."],[6197,6302,"You seem like a good dad."],[6431,6560,"More like a lousy thief."],[6890,6944,"Don't let me catch you"],[6944,7023,"in here again, kid."],[7119,7173,"Alright, now."],[7173,7311,"Alright, so fill this out."],[7332,7478,"Sign the last couple pages."],[7494,7528,"Got it."],[7528,7578,"Yeah."],[8020,8116,"You listen to me."],[8199,8337,"You good for nothing little shit."],[8450,8566,"If anybody finds out"],[8662,8783,"that you took the fall for me,"],[8812,8975,"I will bash your fucking brains in."],[8975,9092,"Do you understand me?"],[9355,9438,"Put your vest on."],[9542,9743,"We fell behind at work without you,"],[9743,9868,"so you're gonna have to miss school"],[9868,10014,"for a couple days."],[10026,10135,"Wait, what about the football?"],[10135,10331,"If I have to hear one more thing"],[10331,10410,"about any fucking"],[10518,10631,"football tryouts,"],[10731,10835,"I'm gonna kick your teeth in."],[10969,11102,"This is an opportunity"],[11144,11319,"for me to get a football scholarship,"],[11327,11428,"go to college and- - You"],[11578,11720,"are never gonna be anything."],[11840,11974,"Anything, you stupid punk."],[12178,12233,"Now let's go."],[12245,12316,"Come on, let's go."]],"5":[[83,304,"Mr. Bradshaw, we found your son."],[1205,1288,"No, Chris."],[1355,1476,"How many times do I have to tell you?"],[1484,1618,"Asher's scar is jagged"],[1618,1718,"and on the right side."],[1847,1885,"I..."],[1939,2006,"I'm sorry, sir."],[2127,2181,"You can go."],[2231,2285,"Yes, ma'am."],[2627,2673,"Trent,"],[2723,2877,"we can't keep doing this."],[2986,3144,"Asher's been gone for twelve years."],[3144,3265,"If he was going to be found,"],[3265,3365,"it would have happened by now."],[3365,3453,"No, Mom, please,"],[3453,3624,"we can't stop looking for him."],[3661,3728,"Sweetheart,"],[3791,3870,"he's my son."],[3945,4129,"I love him more than my own life."],[4204,4408,"But I can't keep watching my family"],[4408,4583,"lose a bit of itself every day."],[4700,4817,"We have to let him go."],[5150,5238,"Don't worry, sweetheart."],[5451,5572,"I'll never stop looking for Asher"],[5572,5655,"until he's found."],[5943,6039,"New helmet."],[6064,6126,"New gear."],[6126,6285,"You'