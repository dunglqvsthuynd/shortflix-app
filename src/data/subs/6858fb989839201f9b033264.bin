{"1":[[654,792,"As an NFL quarterback"],[792,950,"for nearly two decades,"],[992,1155,"I know the importance of family,"],[1155,1309,"whether on the field or at home."],[1363,1539,"So I'm honored to be up here today"],[1539,1739,"with my beautiful wife and kids"],[1772,1926,"to celebrate the grand opening"],[1964,2198,"of Bradshaw Sporting Goods!"],[3862,4108,"Mommy, can we go play?"],[4141,4195,"Alright."],[4229,4404,"Dad's got a few more autographs to do,"],[4404,4483,"but how about this?"],[4542,4696,"You can go play in the back, okay?"],[4696,4763,"But Isabella,"],[4788,4917,"you gotta watch your little brother."],[4954,5025,"And make sure"],[5025,5138,"that you listen to your sister,"],[5138,5205,"okay, Asher?"],[5284,5326,"Yeah?"],[5326,5359,"Okay."],[5376,5451,"Alright, go ahead."],[5451,5488,"Have fun."],[6026,6164,"Dad, can I go play too?"],[6268,6322,"Play?"],[6389,6481,"Wyatt, I told you."],[6506,6556,"It's him."],[6585,6727,"Trent Bradshaw,"],[6727,6919,"five-time Super Bowl champion,"],[6919,7011,"a living legend."],[7061,7144,"That could have been me"],[7182,7315,"if it wasn't for this damn knee."],[7386,7490,"But you're gonna change all that."],[7620,7724,"I'm gonna make sure he sees you,"],[7724,7849,"I'm gonna make sure he trains you,"],[7866,8028,"and you're gonna be the next champion."],[8112,8262,"We are gonna do big things."],[8863,8913,"Nothing."],[8913,9084,"It's just a scratch."],[9142,9259,"But you're bleeding!"],[9438,9547,"I'll get you a Band-Aid."],[9563,9738,"I won't let anything happen to you."],[9801,10051,"You're the best big sister ever."],[10694,10940,"The Mr. Trent Bradshaw,"],[10977,11073,"it is an absolute"],[11073,11165,"pleasure to meet you."],[11165,11257,"You have no idea"],[11257,11344,"what this means to me."],[11365,11515,"I am your number one fan."],[11619,11728,"If you wouldn't mind if you could,"],[11749,11811,"if you could make"],[11811,11991,"one of these out to my son, Wyatt."],[12057,12116,"Wyatt!"],[12166,12270,"He is an amazing"],[12270,12328,"quarterback. - Dad!"],[12362,12525,"Every time he throws a ball, it's like-"],[13046,13104,"Isabella,"],[13150,13217,"where's your brother?"],[13254,13342,"He's over there."],[14293,14351,"Dad!"],[14618,14731,"How amazing would it be"],[14731,14802,"if you could train him?"],[14802,14877,"Don't worry about us."],[14885,14960,"Go find Asher."],[14994,15094,"Go save our little boy."],[15127,15181,"I could pay you."],[15252,15327,"Where are you going?"],[15361,15452,"Get off of me."],[15728,15832,"I deserve this!"],[16207,16316,"Mom!"],[16328,16374,"Asher!"],[16374,16420,"Wyatt!"],[16441,16570,"I have to get to my son!"],[16570,16670,"You'll get to him later!"],[16670,16720,"Go!"],[16946,17029,"Dad!"],[18647,18868,"Dad!"]],"2":[[487,538,"Excuse me,"],[563,617,"they told me"],[617,709,"that they brought my son here."],[759,834,"Asher Bradshaw."],[846,888,"He's five,"],[888,967,"he's wearing my jersey,"],[967,1030,"number fourteen."],[1030,1163,"He has a scar on his right shoulder."],[1205,1297,"A boy in a green jersey"],[1297,1463,"was just admitted to room 309"],[1472,1522,"down the hall."],[1543,1634,"Room 309 down the hall,"],[1634,1710,"thank you so much."],[1710,1755,"Come on, sweetheart."],[1810,1856,"Come on."],[2102,2173,"309."],[2256,2306,"Asher!"],[2410,2452,"Asher?"],[2623,2669,"No."],[2702,2794,"That's not our son."],[2819,2869,"Damn it."],[2911,2973,"Where is he?"],[3023,3144,"Trent, you don't think Asher-"],[3144,3186,"No!"],[3232,3307,"Don't give up hope."],[3307,3370,"We'll find him."],[3461,3636,"Mommy, I'm scared."],[3687,3782,"I know, sweetheart."],[3828,3891,"Me too."],[3928,3970,"Isabella,"],[3970,4054,"it's gonna be okay."],[4112,4170,"Alright?"],[4270,4308,"Alright."],[4383,4487,"You two go back to the lobby."],[4487,4608,"I'll make better time searching alone."],[5434,5522,"With Trent here,"],[5559,5743,"I still have a chance to corner him."],[5797,5980,"I just need to find Wyatt first."],[6231,6289,"Wyatt?"],[6352,