't have a need"],[5000,5150,"for an adopted son like me!"],[5213,5292,"I'll be nothing."],[5359,5472,"I have to stop this."],[6936,6969,"Mom,"],[7182,7303,"are we going to be using the pool"],[7303,7394,"for Izzy's party?"],[7394,7553,"Because the filter is broken."],[7607,7670,"Since when?"],[7828,7928,"Do you want me to call a handyman?"],[8016,8091,"That would be great."],[8133,8195,"You're the best."],[8212,8304,"I am the best."],[8625,8804,"And tonight, Wyatt Lewis,"],[8812,9067,"aka the lost son of the Bradshaws,"],[9084,9321,"will be back in juvie, where he belongs."]],"23":[[12,95,"You look tired, bro."],[141,221,"Staying up late"],[221,346,"partying with those cheerleaders?"],[404,450,"Yeah, no."],[450,583,"I picked up a second job"],[583,746,"to pay for my new equipment."],[1042,1368,"Two jobs, school and practice?"],[1447,1514,"When do you sleep?"],[1718,1776,"I'll be fine."],[1943,1985,"Yes, sir."],[2006,2060,"We're on our way."],[2510,2681,"We have a house call at six o'clock."],[2702,2873,"A new client's pool filter died."],[3007,3103,"Yeah, but what about practice?"],[3103,3211,"I have to be there at six o'clock."],[3470,3561,"Well that's too damn bad."],[3603,3749,"This job comes first."],[3916,3999,"I could do it, sir."],[4062,4179,"I can use the extra money-"],[4179,4371,"Did you hear me ask for volunteers?"],[4379,4454,"No, you didn't."],[4487,4600,"Mind your fucking business"],[4600,4721,"or I will sack your ass."],[4763,4879,"I'm ready now!"],[5196,5234,"Fuck!"],[5292,5380,"Jesus."],[5442,5597,"Your dad is messed up, man."],[5684,5718,"Yeah."],[5793,5935,"But he's the only family I've got."]],"24":[[1447,1614,"This party is insane!"],[1614,1726,"Yeah, that's my mom."],[1726,1901,"She has to make, like, a big show"],[1901,1993,"out of everything."],[1993,2152,"Okay, smiles, everyone!"],[2152,2243,"Smiles."],[2243,2306,"Get in there."],[2314,2377,"Get in there."],[2439,2523,"Bigger smiles."],[2540,2748,"Yes, yes, yes!"],[3178,3211,"Mom?"],[3415,35