8404,8558,"so they'll never take him back."]],"26":[[0,116,"Skipping practice"],[116,266,"to crash my sister's party?"],[312,396,"Wait, hold up!"],[396,525,"Are you the fucking help now?"],[588,663,"Oh my God."],[663,867,"Every time I see him, he hits a new low."],[938,1021,"It's honest work."],[1055,1242,"Unlike you, living off your dad's name."],[1272,1359,"Too bad you don't have an ounce"],[1359,1426,"of his talent."],[1614,1760,"You don't get it, loser."],[1839,1993,"Doesn't matter how good you are,"],[1993,2235,"you will always be a nobody."],[2260,2398,"The peak of your existence"],[2423,2644,"will be watching me win the Super Bowl"],[2669,2790,"while you, uh,"],[2898,2998,"scrub toilets for a living."],[3307,3370,"You know, you don't win a lot of"],[3370,3516,"Super Bowls the way you throw the ball."],[3557,3591,"Yeah?"],[3607,3653,"Yeah."],[4183,4212,"Stop!"],[4212,4287,"Bring it on, then!"],[4308,4387,"Guys, stop!"],[4396,4446,"Stop!"],[4450,4537,"Guys, stop it!"],[4558,4600,"Stop!"],[4654,4692,"Stop!"],[4700,4733,"Guys!"],[4733,4813,"I'm not done with him yet!"],[4904,4979,"Bring it on, then!"],[5000,5176,"Police, yes, this is Krista Bradshaw."],[5226,5334,"There is a maniac here"],[5334,5417,"attacking my son."],[5417,5559,"I need officers right away."],[5568,5605,"Stop!"],[5626,5693,"Oh my God!"],[5734,5830,"Oh my God, he's an animal."],[5834,5885,"Please!"],[5905,5976,"Please hurry!"],[6097,6139,"Pierce!"],[6164,6214,"Stop!"],[6247,6289,"Stop!"],[6289,6360,"You're killing him!"],[6360,6435,"Please stop! - Stop it!"],[6439,6468,"Get off!"],[6485,6523,"Please!"]],"27":[[95,141,"Stop!"],[237,275,"Get off!"],[287,329,"Please!"],[396,429,"Stop!"],[604,642,"Pierce!"],[650,692,"Pierce!"],[692,721,"Stop!"],[721,792,"You're killing him!"],[796,834,"Stop!"],[846,888,"Stop!"],[917,959,"Pierce!"],[959,988,"Stop!"],[988,1055,"You're killing him!"],[1105,1151,"Pierce!"],[1305,1347,"Stop!"],[1551,1589,"Wyatt!"],[1605,1668,"Stop, stop!"],[5422,5463,"Alright."],[5680,5755,"Oh my God!"],[5784,5901,"Oh my God, Isabella!"],[5951,6089,"Thank you for pulling me out."],[6139,6252,"I was scared."],[6452,6498,"Don't worry,"],[6498,6652,"I won't let anything happen to you."],[7007,7211,"I won't let anything happen to you."],[7528,7628,"What did you just say?"]],"28":[[0,162,"Get your hands off my sister."],[208,254,"Oh God."],[291,329,"Oh God."],[362,421,"Isabella,"],[458,500,"honey,"],[542,608,"are you okay?"],[654,729,"Did he hurt you?"],[738,763,"What?"],[771,884,"No, Mom, he-"],[896,1063,"What the hell is going on out here?"],[1217,1488,"This delinquent and his freak father,"],[1509,1659,"they showed up here to cause a scene."],[1659,1730,"Mr. Bradshaw,"],[1730,1822,"I was called here to fix your-"],[1822,1872,"I don't want to hear"],[1872,1956,"another God damn word"],[1956,2027,"out of your mouth."],[2402,2515,"I took a chance on you."],[2606,2719,"What do you have to say for yourself?"],[2719,2790,"What does it matter?"],[2806,2944,"You're not going to believe me anyway."],[2977,3065,"We've done this before."],[3119,3353,"I tried to stop him, but he attacked me."],[3374,3507,"He shoved Isabella in the pool."],[3524,3670,"She almost drowned."],[3670,3699,"What?"],[3699,3724,"No."],[3724,3766,"What?"],[3766,3928,"You put your hands on my little girl?"],[3978,4016,"Dad!"],[4045,4124,"Dad, stop!"],[4129,4233,"It was an accident."],[4596,4704,"It was an accident"],[4704,4838,"that he skipped practice"],[4838,4896,"and showed up"],[4896,5055,"at your birthday uninvited?"],[5075,5221,"Total fucking creep!"],[5296,5392,"Is this the kind of person"],[5392,5501,"you want on your team?"],[5526,5655,"Someone who shows up here"],[5655,5822,"and endangers our children?"],[5822,5926,"Trent, this has to stop."],[6060,6110,"You're right."],[6122,6247,"I'm done with this shit."],[6318,6360,"No!"],[6393,6519,"Trent's looking right at him."],[6531,6660,"He'll see that stupid scar"],[6673,6902,"and know he's Asher, his real son."]],"29":[[358,533,"Take your fucking mess with you."],[1117,1163,"Officer!"],[1209,1259,"Over here."],[1597,1730,"We got a call about an intruder."],[1810,1872,"Yes, yes,"],[1872,1931,"yes, him."],[1947,1976,"Him."],[2027,2147,"He crashed my daughter's party"],[2147,2268,"and then attacked my kids."],[2281,2406,"I didn't do anything."],[2406,2506,"Didn't do anything?"],[2556,2640,"You rushed me"],[2648,2836,"and almost killed my sister!"],[2836,2940,"That's not true-"],[2940,3019,"Don't listen to her."],[3019,3086,"She's in shock."],[3128,3253,"Time to seal his fate"],[3253,3386,"with the evidence I planted."],[3424,3591,"Good luck getting out of this, juvie."],[3636,3753,"Somebody check his pockets."],[3791,3937,"I saw him snooping around our mansion"],[3937,4008,"before the party."],[4024,4091,"That is a lie."],[4129,4254,"I was with my dad the whole time."],[4329,4400,"Arms up, kid."],[6147,6252,"Does this belong to anybody?"],[6765,6919,"Punk stole my Super Bowl ring!"],[7027,7127,"That's worth 80 grand."],[7240,7307,"No, that's not,"],[7332,7474,"I was with my dad the whole time."],[7474,7557,"That is not true."],[7557,7670,"Yeah, that doesn't mean shit."],[7691,7853,"He's probably just as guilty as he is."],[7874,8078,"No, I've already done my time."],[8091,8224,"I'm not going back."],[8408,8550,"He's a troubled kid."],[8737,8858,"I've been trying to get him some help,"],[8858,8988,"but he's out of control!"],[9146,9267,"Alright, hands behind your back."],[9388,9492,"You can't let them do this."],[9905,10022,"No, you can't let them do this."],[10168,10272,"Dad, you weren't there."],[10318,10418,"You have to take pity on him."],[10418,10539,"Please, take pity on him, Dad."],[10573,10648,"It's my birthday!"],[11678,12045,"Officer, we'll drop any charges."],[12320,12483,"Wyatt, you're off the team."],[12554,12658,"I don't want you anywhere"],[12658,12829,"near my family or my field."],[12887,13142,"If I see you, I'll make you regret it."],[13338,13455,"Now get the fuck out of here!"],[13980,14168,"Sir, ma'am, have a great evening."],[14222,14285,"Let's go, guys."]],"30":[[1034,1117,"It's the detective."],[1188,1259,"I'm gonna let him in."],[1818,1901,"I'm sorry, honey."],[1939,2035,"We can throw you another party"],[2035,2077,"if you want."],[2139,2193,"Yes."],[2210,2285,"A bigger one."],[2348,2489,"We'll roll out a red carpet."],[2577,2673,"Even get a better cake."],[2748,2927,"And if that asshole, Wyatt, shows up,"],[2957,3044,"I'll break his nose."],[3044,3282,"Please, stop fighting with Wyatt."],[3282,3440,"God, all I want is just to pretend"],[3440,3586,"none of this ever happened."],[3628,3795,"I'm sorry to disturb all of you."],[3958,4049,"Tell me you found our son."],[4166,4250,"We narrowed it down."],[4396,4546,"There's just one boy we haven't checked."],[4625,4658,"Who?"]],"31":[[0,70,"Wyatt Lewis."],[200,375,"You can't be serious."],[538,583,"No."],[875,946,"Wyatt's my brother."],[946,1017,"I can feel it."],[1163,1201,"No."],[1301,1334,"No."],[1388,1447,"It can't be."],[1472,1559,"There must be others."],[1576,1626,"Well, of course"],[1626,1743,"we're not ruling anything out."],[1793,1876,"But right now,"],[1947,2072,"Wyatt is our best lead"],[2072,2189,"for your lost son, Asher."],[2373,2469,"You mean to tell me"],[2544,2711,"that I just threatened my own son?"],[2957,3057,"What the hell have I done?"],[3157,3315,"But he's a criminal."],[3315,3511,"Wyatt could be our long lost brother."],[3536,3657,"Dad, we have to go find him now."],[3816,4029,"No, I think Pierce is right."],[4091,4124,"What?"],[4216,4396,"Krista, for the past twelve years"],[4396,4441,"you've been mourning"],[4441,4546,"the loss of our little boy"],[4546,4679,"to every journalist and reporter"],[4679,4742,"that'll listen."],[4754,4796,"Yes."],[4888,5055,"Because I thought we would find Asher."],[5159,5255,"But all it did was attract"],[5255,5388,"every scumbag"],[5388,5518,"and con artist to our door."],[5601,5814,"All they wanted was our money, our fame."],[5885,5935,"All they wanted"],[5935,6081,"was to prey on our grief."],[6147,6218,"And that Wyatt?"],[6302,6398,"With his background?"],[6506,6648,"Odds are, he's just like the others."],[6690,6956,"I can't keep hoping anymore, Trent."],[6956,7044,"I just can't."],[7073,7236,"If there's even a chance"],[7261,7344,"that he's Asher."],[7440,7507,"I think about the moment"],[7507,7645,"that we lost him every single day."],[7661,7749,"Mom's right."],[7749,7999,"We can't bring a vicious thug"],[7999,8099,"into this house!"],[8333,8391,"Excuse me."],[8404,8445,"Don't worry."],[8529,8608,"We're going to go talk to him"],[8608,8683,"first thing today."],[9134,9213,"This can't be happening."],[9255,9325,"If they find out that"],[9325,9488,"Wyatt is actually their long lost son,"],[9505,9634,"they'll replace me with him."],[9667,9759,"I need to get to"],[9759,9964,"my dirtbag real dad first."],[9997,10193,"I need to end Wyatt Lewis."]],"32":[[145,187,"Donny."],[275,325,"Donny!"],[625,721,"What are you doing here?"],[967,1092,"Wyatt's already out back."],[1092,1172,"I don't want you getting"],[1172,1242,"caught, son."],[1242,1347,"Don't call me that."],[1388,1551,"I may be your biological son,"],[1551,1764,"but I am a Bradshaw through and through."],[1818,1897,"That's what you wanted."],[1964,2077,"But all that's about to end."],[2143,2177,"What?"],[2231,2281,"What happened?"],[2335,2456,"That damn detective"],[2456,2565,"put the pieces together."],[2606,2798,"Trent is on his way right now to see"],[2798,3007,"if Wyatt has the same jagged scar"],[3007,3111,"as his missing son."],[3236,3303,"Oh shit."],[3445,3520,"This is bad."],[3641,3745,"He's going to know I kidnapped him"],[3828,3941,"and send me back to prison."],[3941,4070,"But more importantly,"],[4070,4225,"he's going to toss me aside!"],[4275,4412,"Who needs their adoptive son,"],[4412,4587,"when their real heir returns?"],[4637,4850,"You wanted me to have this life, right?"],[4867,4942,"Of course."],[4979,5084,"More than anythi