lright, kid."],[4354,4433,"Let's finish this."],[7253,7290,"Dad!"]],"53":[[229,262,"Dad!"],[1376,1430,"Oh, fuck."],[1430,1505,"Oh, no."],[1505,1539,"Okay."],[1593,1664,"Alright, come on, come on."],[1685,1722,"Let's get up."],[1743,1780,"Okay."],[1780,1814,"Come on."],[1851,1885,"Come on."],[1931,1981,"Come on, stay up."],[2002,2064,"You gotta keep your eyes open."],[2064,2102,"Come on."],[2131,2210,"Come on, keep moving."],[2231,2318,"Keep moving, come on."],[2339,2373,"Come on."],[2402,2527,"Isabella, call 911!"],[2706,2740,"You're alright."],[2882,2919,"You're alright."],[2919,3111,"I heard what you called me back there."],[3249,3361,"It's not gonna matter if you're dead."],[3399,3432,"Come on."],[3474,3511,"Come on."],[4187,4266,"I'm sorry to see you"],[4266,4408,"back in my hospital so soon,"],[4412,4458,"young man."],[4479,4542,"It's fine."],[4604,4662,"And you."],[4754,4888,"You're old enough to know better"],[4888,5109,"not to get into a fight, Mr. Bradshaw."],[5192,5276,"They had it coming."],[5355,5492,"Did you see that son of a bitch"],[5547,5626,"hit the ground?"],[5693,5843,"I dropped him like a ragdoll."],[5880,5922,"Boom!"],[6018,6118,"Ouch! - Easy."],[6235,6368,"Yeah, they were tough for like"],[6368,6464,"five seconds."],[6523,6573,"They did get"],[6573,6715,"a decent slice in, though."],[6806,6865,"Decent?"],[6902,6944,"More like-"],[6986,7082,"Twenty stitches."],[7169,7269,"Twenty stitches."],[7340,7424,"Damn."],[7457,7545,"You did hold your own."],[7795,7836,"Trent!"],[7882,7966,"Honey, are you okay?"]],"54":[[25,187,"Honey, are you okay?"],[216,275,"I'm fine."],[300,342,"Ow!"],[362,479,"Oh, God!"],[546,629,"Who did that to you?"],[629,696,"Was it you?"],[709,796,"You dirty hoodlum."],[817,917,"Krista, Krista, stop."],[992,1088,"He stuck by my side."],[1155,1217,"I don't know if I could have"],[1217,1334,"kicked their asses without his help."],[1380,1451,"Isn't that nice?"],[1514,1601,"Are you okay, Wyatt?"],[1726,1801,"Yeah, I'm fine."],[1801,20