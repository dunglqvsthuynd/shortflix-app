{"1":[[909,975,"Alpha,"],[988,1084,"you should be preparing"],[1084,1222,"for your Luna's Coronation"],[1222,1288,"this afternoon."],[1313,1380,"I'm your Beta,"],[1430,1584,"it's my job to fetch your guest."],[1618,1693,"Yes, but she's not just"],[1693,1805,"any guest, is she?"],[2002,2160,"The Bloodveil pack is the strongest"],[2160,2260,"in the werewolf kingdom,"],[2268,2318,"feared across"],[2318,2402,"packlands everywhere."],[2464,2556,"Who could be so important"],[2556,2690,"that the Wolf King himself,"],[2711,2882,"goes out of his way to pick her up?"],[2907,2977,"My sister,"],[3078,3119,"Mari."],[3199,3307,"She's the only family that I've got"],[3307,3411,"left in the whole wide world."],[3457,3507,"She raised me,"],[3507,3591,"she protected me."],[3670,3732,"Hell, without her,"],[3732,3841,"there wouldn't even be a me,"],[3841,3916,"let alone a pack."],[3983,4062,"She's three months pregnant"],[4062,4145,"with her own pup now."],[4204,4312,"It's my turn to protect her."],[4400,4508,"I understand, sir."],[4838,4917,"There she is."],[5380,5447,"Sister!"],[5680,5739,"Cas!"],[6302,6393,"Oh, careful,"],[6402,6489,"careful, the pup."],[6535,6677,"Oh, uh, I'm so sorry."],[6677,6815,"I promise I will be more careful."],[6835,7011,"I'm so glad you're here, I..."],[7115,7240,"I've missed you so much."],[7307,7399,"I've missed you, too."],[7570,7661,"Well, now that you're here,"],[7661,7736,"I can,"],[7820,7887,"give you both a home"],[7887,7970,"and keep you safe."],[9125,9334,"My little brother has really grown up."],[9572,9693,"Well, I'm the Alpha now,"],[9734,9864,"which also means I can"],[9951,10276,"protect you and my new nephew."],[11011,11131,"Who is that?"],[11169,11236,"What is she doing"],[11236,11403,"with my daughter's mate?"],[11799,11920,"To Willow!"],[11941,12162,"I'm so excited to be Caspian's Luna."],[12208,12383,"That's probably him."],[12658,12708,"Willow?"],[12746,12937,"Your mate is cheating on you."]],"2":[[4,154,"Your mate is cheating on you."],[200,342,"I see him right now!"],[358,529,"He is with another she-wolf"],[529,658,"right in front of me, right now."],[709,788,"Mom, you need to get your"],[788,867,"eyes checked."],[900,1080,"Caspian would never betray me like that."],[1347,1497,"My daughter hangs up on me?"],[1572,1655,"Just being silly."],[1655,1710,"Do my hair."],[1818,1901,"Marina, listen."],[1968,2093,"I can tell that you traveling"],[2093,2168,"without an Alpha"],[2168,2260,"has made you weaker."],[2289,2464,"I heard that you can't even"],[2464,2552,"shift anymore?"],[2552,2635,"I just don't like it"],[2635,2744,"that you're traveling alone"],[2769,2840,"with just the pup."],[2840,2919,"I would hate if something"],[2919,3011,"happened to the two of you."],[3057,3119,"Hey,"],[3165,3282,"just because I can't shift,"],[3286,3449,"doesn't mean I'm totally helpless."],[3461,3657,"Besides, my little brother"],[3666,3812,"has finally found his Luna."],[3891,4058,"And I wouldn't miss her Coronation"],[4070,4141,"for the world."],[4212,4279,"When we were little"],[4295,4354,"and we were growing up"],[4354,4462,"and Mom and Dad died,"],[4483,4596,"I've always looked up to the way"],[4596,4700,"that you clawed your way"],[4700,4788,"to the top of the pack"],[4788,4867,"and led the pack,"],[4867,5034,"just so I could go to"],[5034,5134,"the werewolf academy."],[5159,5259,"Now I'm the Alpha."],[5305,5417,"I will never be able to"],[5417,5526,"thank you enough for that."],[5572,5647,"We're family."],[5772,6014,"I would do anything for family."],[6581,6794,"Is she pregnant with his pup?"],[6927,7077,"Oh, I have to tell Willow."],[7432,7490,"No."],[7549,7941,"No, no, no, no, no no, no, no, no."],[8053,8120,"Oh my God, Willow"],[8120,8220,"that's horrible."],[8241,8450,"On the day of your Luna coronation?"],[8479,8596,"What are you gonna do now?"],[8975,9150,"Oh, hold on."],[9188,9238,"Oh, it's Willow."],[9309,9346,"Hey, honey."],[9380,9484,"Caspian, you bastard,"],[9484,9592,"you're cheating on me?"]],"3":[[37,150,"Willow, what are you talking about?"],[158,316,"Don't play dumb with your mate."],[367,487,"Caspian, I'm gonna make myself"],[487,558,"very clear."],[600,675,"If you bring"],[675,825,"that she-wolf mistress"],[825,909,"anywhere near our home,"],[921,1001,"I will tear her"],[1001,1155,"and that bastard pup to shreds!"],[1163,1213,"Willow,"],[1347,1443,"listen, you're my mate."],[1484,1626,"I'm faithful to you and only you."],[1626,1668,"Okay,"],[1676,1751,"please, stop this"],[1751,1830,"we'll talk about it later."],[1830,1964,"Caspian, my mom literally just saw-"],[2769,2965,"That mutt is pregnant with your"],[2973,3144,"pup of your mate."],[3161,3370,"What if he crowns her instead of you?"],[3445,3570,"Your dreams of becoming Luna"],[3570,3687,"will be crushed."],[3807,3991,"This cannot fucking happen."],[4170,4441,"Caspian is my fated mate."],[4483,4713,"And no she-wolf seductress,"],[4717,4804,"mistress, bitch"],[4804,4909,"is gonna take him from me."],[4929,5113,"Even if she has a bastard pup,"],[5113,5284,"I'm gonna rip them both to shreds!"],[5709,5764,"Mom,"],[5809,5905,"I need you to follow around"],[5905,5997,"Alpha Caspian"],[6018,6135,"and see what he's up to."],[6339,6510,"Is everything okay with Willow?"],[6531,6648,"Yes, uh, she's probably"],[6648,6760,"just upset that, uh,"],[6777,6923,"I didn't bring her here to meet you."],[6952,7048,"You know, if you hadn't insisted"],[7048,7248,"on arriving early and surprising her,"],[7269,7361,"then I probably wouldn't be"],[7361,7436,"in trouble right now."],[7465,7645,"Cas, she's gonna be your Luna."],[7703,7841,"You need to be more gentle with her,"],[7949,8041,"more understanding."],[8133,8262,"You've always been way wiser"],[8262,8362,"beyond your years."],[8487,8583,"Let's get you home."],[8783,8975,"Let’s see what you're up to."]],"4":[[367,467,"Are you sure"],[475,579,"that Willow won't mind me"],[579,650,"staying here?"],[688,742,"I mean,"],[750,888,"it is the Alpha's mansion."],[888,1067,"No, this is our home."],[1067,1142,"This is your home."],[1142,1267,"Our parents raised us here,"],[1267,1372,"you raised me."],[1418,1505,"Yes, but"],[1543,1680,"it belongs to you and Willow now."],[1730,1810,"And, I can just,"],[1822,1935,"I can get a room at the pack house."],[1935,1972,"It's..."],[1976,2060,"No, I'm sorry."],[2160,2227,"The pack house?"],[2381,2510,"I'm not gonna send my sister"],[2510,2631,"to go sleep on a tiny bunk"],[2631,2765,"with a bunch of warrior wolves."],[2831,2927,"Plus, Alpha David"],[2927,3053,"would kill me if he knew"],[3053,3140,"I was even considering"],[3140,3228,"something like that."],[3299,3415,"I miss him, Cas."],[4104,4170,"He was"],[4291,4383,"the best brother-in-law"],[4383,4454,"and the kindest Alpha"],[4454,4546,"I've ever known."],[4742,4892,"And now he's watching over us"],[4946,5025,"from the Moon realm."],[5088,5355,"But he would be so happy"],[5409,5668,"to see our little Cas crown his Luna."],[6239,6310,"Willow,"],[6398,6510,"Alpha Caspian"],[6531,6677,"brought that scruffy mutt"],[6677,6748,"into the mansion!"],[6748,6819,"He what?"],[6911,7044,"Caspian, that bastard."],[7044,7132,"I can't believe he brought his"],[7132,7298,"dirty mistress to our new home."],[7332,7436,"Come on, she-wolves."],[7457,7553,"It's time to tear that"],[7553,7686,"home wrecker to shreds."]],"5":[[29,166,"It's exactly as I remember it."],[291,437,"I haven't touched a thing"],[437,525,"since you left."],[567,650,"I meant it when I said that"],[650,767,"this will always be home."],[913,1034,"My old room!"],[1188,1347,"My sister has sacrificed"],[1347,1572,"a lot for me since our parents died."],[2389,2464,"Sister,"],[2485,2640,"I don't have a mommy"],[2640,2815,"or a daddy anymore."],[2840,2902,"It's okay,"],[2961,3061,"you still have me."],[3111,3182,"From now on,"],[3257,3353,"I'll take care of you."],[3470,3616,"She's my only family now."],[3645,3745,"No one can harm"],[3745,3903,"my sister and her pup anymore"],[3928,4016,"Are you sure,"],[4037,4166,"Willow won't mind me living here"],[4166,4300,"after she's officially your Luna?"],[4300,4437,"No, she's gonna be thrilled."],[4437,4608,"You are one of the kindest,"],[4608,4717,"most generous,"],[4717,4909,"strongest Lunas I've ever known."],[4909,4979,"I think Willow wants to be"],[4979,5059,"just like you."],[5088,5146,"Okay."],[5184,5251,"If you're sure."],[5259,5342,"No, I'm sure."],[5376,5580,"But, um, I have to go get some"],[5584,5684,"things done for the pack,"],[5684,5797,"just some pack business."],[5797,5893,"So if you need anything,"],[5947,6001,"you call me."],[6039,6126,"I'm glad you're here."],[6172,6218,"Me too."],[6498,6577,"Years ago,"],[6598,6769,"I had to sell our mother's necklace."],[6794,6911,"The Bloodveil Moonstone,"],[6956,7086,"to pay off our enemies"],[7090,7211,"and keep the pack in power."],[7286,7524,"I spent 3 billion to get it back,"],[7599,7753,"but it'll be worth every penny"],[7753,7849,"to see Willow smile"],[7849,7966,"when I give it to her today."],[8233,8283,"Cas?"],[8375,8458,"Are you back already?"],[8913,9021,"You dirty mutt!"],[9209,9305,"Hold her down!"],[9751,9855,"Who are you?"],[9926,10035,"What are you doing?"],[10051,10160,"Showing you what happens"],[10160,10322,"when you try and seduce my mate."],[10422,10472,"What?"],[10514,10560,"Wait."],[10598,10694,"Let go of me!"]],"6":[[321,404,"What do you want?"],[417,521,"What do I want?"],[542,775,"I want my mate back, you mangy whore!"],[938,1121,"This, this has to be a misunderstanding."],[1151,1259,"Misunderstanding?"],[1309,1451,"Do you think I'm blind?"],[1518,1685,"You want Caspian to reject me"],[1685,1822,"so he can mark you instead?"],[1851,1989,"You want to take my place"],[1989,2164,"as Luna of the Bloodveil pack."],[2181,2277,"No, I-"],[2431,2523,"Alpha Caspian"],[2523,2656,"is good at keeping secrets,"],[2656,2744,"I'll give him that."],[2773,2861,"Or maybe,"],[2902,3061,"you're just really good at hiding?"],[3203,3261,"Wait."],[3332,3499,"You must be Willow, right?"],[3520,3620,"You're confused."],[3632,3724,"Alpha Caspian-"],[3724,3866,"Oh, so you know me?"],[3949,4120,"Caspian told you everything?"],[4233,4329,"Well, he conveniently"],[4329,4462,"forgot to mention to me,"],[4462,4550,"his future Luna,"],[4550,4625,"that he's been fucking"],[4625,4717,"another she-wolf!"],[5080,5192,"You smell like dirty"],[5192,5317,"home wrecking rogue."],[5438,5522,"Tie her up!"],[5588,5659,"Time to show her"],[5659,5805,"the consequences of seducing"],[5805,5926,"another woman's mate."],[5955,6110,"Please, you can't do this!"],[6131,6277,"No, don't you know who I am?"],[6285,6406,"You're a snaky slut"],[6406,6523,"who's hell-bent on ruining"],[6523,6702,"my Luna coronation!"],[6740,6815,"Take her!"],[6835,6881,"No."],[6944,7065,"Stop, let me go."],[7582,7632,"Willow,"],[7716,7870,"do you know what Alpha Caspian"],[7870,7949,"will do to you"],[7949,8120,"when he knows how you've treated me?"],[8120,8224,"He'll kill you!"],[8295,8383,"I'm his mate."],[8462,8558,"You're nobody."],[9117,9217,"Stop, stop,"],[9217,9305,"stop!"],[9438,9622,"I'm Caspian's sister!"]],"7":[[12,191,"I'm Caspian's sister!"],[300,375,"You're Marina?"],[454,600,"Sister of Alpha Caspian?"],[642,750,"Luna of Alpha David,"],[750,842,"the strongest wolf"],[842,963,"in the European pack lands?"],[1042,1088,"Yes!"],[1810,1939,"You lying mutt!"],[1972,2022,"How dare"],[2022,2160,"home wrecking trash like you"],[2160,2352,"impersonate Caspian's big sister?"],[2473,2519,"Wait,"],[2519,2581,"Willow,"],[2656,2857,"what if she's actually Caspian's sister?"],[2927,3094,"He will tear our throats out."],[3186,3336,"Caspian and his sister"],[3395,3524,"both have the most unique"],[3524,3691,"and powerful white wolf."],[3732,3874,"Prove you're his sister."],[3903,3966,"Shift."],[4087,4208,"I can't shift."],[4241,4304,"I'm pregnant."],[4308,4466,"The most powerful white wolf"],[4466,4542,"Luna in the kingdom"],[4542,4733,"can't shift because she's pregnant?"],[4804,5013,"You expect us to believe this bullshit?"],[5075,5234,"I've never heard such a thing."],[5422,5559,"I bet you can shift."],[5634,5759,"And you just don't want to"],[5759,5972,"because you're the weakest kind of wolf."],[6006,6202,"A rogue trying to steal my place."],[6393,6485,"Or maybe,"],[6539,6702,"you don't have a wolf at all."],[6760,6890,"A fangless mutt like you"],[6890,6986,"should keep Marina's name"],[6986,7090,"out of her mouth."],[7111,7152,"See?"],[7190,7323,"She's not Luna Marina."],[7349,7565,"Besides, Willow obviously knows"],[7565,7741,"what her mate's sister looks like."],[7811,7870,"Right?"],[7962,8149,"I've never actually seen Marina,"],[8233,8370,"but this bitch can't be her."],[8437,8717,"You're going to regret this, Willow."],[9067,9142,"Hold her down."],[9180,9230,"What?"],[9230,9275,"No!"],[9309,9405,"No, please, no!"],[9405,9534,"Don't, don't, stop, Stop!"],[9559,9688,"No, please, no, stop!"],[9713,9780,"My pup!"],[9959,10030,"My pup!"],[10051,10101,"Stop!"],[10114,10155,"No."],[10185,10226,"Please!"],[10251,10314,"My pup!"],[10452,10506,"Ah!"],[10794,10940,"If the bastard pup dies,"],[10940,11148,"just consider it natural selection."],[11273,11403,"Pup or no pup,"],[11415,11519,"you're not using it"],[11519,11669,"to become Caspian's Luna."],[11699,11782,"No!"],[11790,11861,"Stop!"],[12087,12199,"If you hurt my pup,"],[12199,12395,"I swear I'll rip you all apart!"]],"8":[[208,296,"Nice try."],[329,471,"But we know you can't shift"],[471,571,"while you're pregnant."],[608,754,"You fangless homewrecker."],[784,875,"You obviously love to"],[875,1101,"spread your legs for mated wolves."],[1109,1172,"How do we even know"],[1172,1301,"the pup is Caspian's?"],[1326,1468,"You're just some ran-through rogue,"],[1480,1589,"using your bastard baby"],[1589,1714,"to get to the Alpha, aren't you?"],[1718,1772,"No!"],[1847,2047,"I'm not who you think I am."],[2068,2139,"I'm- - Don't."],[2139,2323,"you dare say Marina's name again."],[2406,2531,"If you don't believe me,"],[2531,2652,"then call Caspian."],[2652,2781,"Get him here, please."],[2786,2998,"Oh, I bet you would love that"],[3019,3186,"if the big, bad Alpha came howling"],[3186,3311,"through that door to save you."],[3324,3445,"You think you can claw"],[3445,3532,"your way to relevancy"],[3532,3616,"by sleeping with"],[3616,3749,"other people's mates?"],[3749,3812,"Come on,"],[3824,3924,"look at her now."],[3924,4058,"Thinking she could play the poor,"],[4058,4179,"helpless victim."],[4375,4562,"Is that how you seduced my mate?"],[4571,4704,"Is that how you became pregnant"],[4704,4817,"with his bastard pup?"],[4871,4979,"Is that your grand plan"],[4979,5146,"to replace me as Luna?"],[5563,5814,"You will not get away with this."],[6560,6710,"What, is it?"],[7065,7136,"Caspian?"]],"9":[[95,175,"Caspian?"],[241,329,"Caspian-"],[592,679,"Hey, Willow, honey."],[709,792,"Are you still getting ready?"],[821,896,"I'm taking care of"],[896,1009,"some pack business so,"],[1030,1130,"I'm gonna be a little bit late."],[1163,1267,"Also, honey, my sister's"],[1267,1401,"getting in in about an hour."],[1443,1501,"I knew it."],[1501,1701,"This desperate bitch isn't Marina."],[1718,1822,"Welcome her for me, would you?"],[1939,1993,"Okay."],[2031,2093,"Got it,"],[2177,2252,"mate."],[2423,2548,"Caspian, please-"],[2665,2744,"Wait, what was that?"],[2744,2819,"I hear screaming."],[2840,2886,"Are you okay?"],[3048,3111,"Nothing,"],[3111,3286,"it's just a stray mutt in heat."],[3319,3386,"Stray mutt?"],[3436,3545,"I'm taking care of it."],[3624,3782,"Don't worry, Cas."],[3791,3933,"I'll treat my new sister-in-law"],[3933,4037,"like royalty."],[4283,4346,"Hear that?"],[4596,4779,"Caspian's sister gets in, in an hour,"],[4788,5017,"which means you're a dirty liar."],[5067,5121,"No."],[5201,5359,"No, I'm telling the truth."],[5426,5509,"If you don't believe me,"],[5509,5714,"just get Caspian here, please!"],[5764,5839,"Of course."],[5843,6043,"Let's all go to my Luna coronation."],[6076,6193,"That way, you can tell"],[6193,6418,"Marina herself who you really are."],[6514,6623,"Caspian is the Alpha."],[6673,6777,"I can't embarrass him like this"],[6777,6886,"at his Luna's coronation."],[7032,7082,"No."],[7107,7157,"Please."],[7190,7390,"Just, just let me go."],[7403,7574,"Oh, so now you're ashamed."],[7574,7720,"Too bad it's not up to you."],[7816,7912,"Drag her out."],[8149,8241,"Let go!"],[8291,8354,"No!"]],"10":[[408,521,"Ivy,"],[525,654,"once your daughter becomes Luna"],[654,813,"of the Bloodveil pack,"],[813,996,"you'll be a part of the elite Wolves."],[1013,1121,"It's only a matter of time"],[1121,1230,"before the Hale family"],[1230,1347,"becomes pack royalty."],[1347,1501,"No one deserves to be"],[1501,1747,"mated with the most powerful Alpha"],[1755,1876,"more than Willow."],[1947,2102,"What can I say?"],[2156,2323,"My daughter certainly inherited"],[2323,2485,"my grace and beauty."],[2548,2677,"Alpha Caspian is"],[2677,2898,"quite lucky to be mated to her."],[2944,3232,"Today is going to be perfect."],[3269,3420,"As long as Willow deals"],[3420,3574,"with that mistress mutt."],[3820,3891,"Everyone!"],[3908,4012,"Thank you all for coming"],[4012,4179,"to my daughter's coronation."],[4179,4295,"I'd like to make a toast"],[4295,4512,"to Willow and Alpha Caspian."],[4583,4650,"To love."],[4696,4804,"To wealth."],[4829,4988,"To power!"],[5055,5121,"Cheers."],[5134,5184,"Cheers."],[6606,6731,"Who's that?"],[6994,7057,"Willow,"],[7123,7244,"where did you drag this"],[7244,7365,"stray mutt in from?"],[7365,7411,"Ah!"],[7549,7716,"Why is she beaten all bloody?"],[7836,8008,"Who in the Moon Goddess's name"],[8008,8091,"is this?"],[8116,8254,"Such an eyesore."],[8279,8470,"Mother, you know her."],[8525,8604,"I do?"],[8641,8837,"This woman is Caspian's shameless"],[8837,8958,"she-wolf slut."]],"11":[[4,54,"Willow?"],[112,200,"Is that true?"],[237,308,"Of course it is."],[325,475,"Mother saw her with her own eyes"],[475,567,"with Caspian."],[608,809,"He even brought her to our new mansion."],[829,1067,"She's that Alpha-baiting bitch."],[1146,1230,"You beat her so well"],[1230,1384,"I didn't even recognize her."],[2014,2102,"Ah!"],[2135,2277,"You bitch!"],[2740,2877,"Let go of me!"],[3299,3370,"Let..."],[3682,3874,"Hurts, doesn't it?"],[3899,4008,"You should've been thinking about"],[4008,4149,"the consequences before you start"],[4149,4341,"fucking around with my sister's mate!"],[4362,4496,"Let go!"],[4496,4658,"Why are you struggling?"],[4708,4929,"You deserve to suffer."],[5797,6047,"What is that?"]],"12":[[717,763,"It..."],[821,925,"It's stunning!"],[942,1076,"A necklace like this must be"],[1076,1263,"very expensive."],[1368,1472,"I've seen this before"],[1488,1614,"in our pack's history books."],[1651,1851,"This is the Bloodveil Moonstone!"],[1897,2122,"It's worth $3,000,000,000!"],[2202,2352,"$3,000,000,000?"],[2364,2527,"Our entire bloodline"],[2527,2711,"isn't even worth $100,000,000."],[2761,2819,"What?"],[2882,3115,"This necklace is really worth billions?"],[3157,3315,"You flea-ridden bitch!"],[3370,3486,"Why did you get him to buy you"],[3486,3632,"something so expensive?"],[3707,3799,"I didn't."],[3903,4008,"It's mine."],[4029,4104,"Yours?"],[4141,4304,"Caspian told me the Brooks family"],[4304,4483,"spent a fortune on this necklace."],[4500,4642,"It's a family heirloom,"],[4654,4775,"passed down to the Luna"],[4775,4921,"of their first born."],[4988,5146,"And he gave it to you,"],[5184,5451,"his rogue bitch, instead of his mate?"],[5505,5609,"Caspian's Luna"],[5609,5780,"does deserve this moonstone."],[5814,5939,"But if he chooses to give it"],[5939,6110,"to some home wrecking bitch,"],[6135,6272,"then we must destroy it."],[6331,6385,"Yeah."],[6418,6539,"If you can't have it,"],[6569,6706,"then this useless mutt"],[6723,6902,"definitely doesn't deserve to have it!"],[6911,6965,"No!"],[6994,7107,"You can't destroy it."],[7215,7311,"You'll regret it."],[7311,7403,"Oh, shut up!"],[7424,7520,"And then what?"],[7632,7757,"We let you have it"],[7778,7882,"and then what do you do?"],[7882,8012,"You sell it off,"],[8012,8128,"live out the rest of your days"],[8128,8208,"in luxury?"],[8212,8462,"You stole my daughter's mate!"],[8466,8629,"You don't deserve to know peace!"],[8641,8883,"You know with a jewel worth billions,"],[8883,9050,"it'd be a shame to just smash it."],[9059,9088,"Dad,"],[9100,9305,"it could be worth three trillion dollars"],[9305,9451,"and it still would be useless"],[9471,9584,"if it's in the hands"],[9584,9751,"of Caspian's little mutt!"],[9818,9934,"No, no, no, no, no."],[9943,10026,"Once Willow"],[10026,10172,"becomes Caspian's Luna,"],[10181,10402,"she'll have all the gems she wants."],[10402,10618,"Oh, Rowen is right, sweetie."],[10652,10719,"Go ahead,"],[10731,10827,"destroy it."],[10981,11148,"Destroy it!"],[11407,11465,"Don't!"],[11745,11853,"Get off!"],[11936,12037,"Get off of her!"],[12787,12946,"Aww, are you sad to lose"],[12946,13133,"Caspian's little token of affection?"],[13163,13246,"Well, let's see how loving"],[13246,13342,"he feels when he finds out that"],[13342,13484,"you're the one who destroyed it!"]],"13":[[917,1226,"I guess you've made your choice, Willow."],[1226,1393,"You were never meant to wear"],[1393,1572,"the Bloodveil Moonstone."],[1718,1972,"Are you still acting so high and mighty?"],[1981,2031,"Ah!"],[2031,2118,"What's wrong?"],[2173,2256,"Angry that your"],[2256,2414,"three billion dollar necklace"],[2414,2623,"is nothing but worthless trash now?"],[2706,2777,"Listen up."],[2806,2869,"You don't take"],[2869,2994,"what doesn't belong to you."],[3015,3278,"Or else I'm gonna take it right back."],[3424,3465,"No."],[3520,3628,"Please don't hurt my pup."],[3674,3766,"Don't hurt my pup!"],[3778,3866,"Help!"],[3883,4066,"Please, don't let her hurt my pup!"],[4112,4316,"Should we do something?"],[4416,4487,"Hell no."],[4500,4750,"That mutt needs to be taught a lesson."],[4792,5046,"They used to hunt down strays like her"],[5063,5171,"with silver bullets."],[5171,5251,"You're right."],[5280,5543,"Willow is Caspian's Luna,"],[5597,5826,"not some flea-bitten mistress."],[5968,6197,"Look, how desperate she is"],[6197,6322,"to be the Alpha's pet,"],[6322,6581,"but I bet that he wishes"],[6581,6840,"that bastard pup would just disappear."],[6856,6956,"Hmm, see?"],[7023,7165,"No one's gonna help you, hon."],[7244,7340,"I thought Willow Hale"],[7340,7532,"was a smart, kind she-wolf."],[7578,7686,"A deserving Luna."],[7824,7924,"How wrong I was."],[8049,8212,"And this so-called family?"],[8283,8375,"They're all just foolish"],[8375,8504,"petty power-chasers."],[8566,8742,"Willow, you better not"],[8742,8863,"let this wicked bitch"],[8863,9050,"give birth to that bastard."],[9113,9167,"We're gonna have to"],[9167,9309,"get rid of it ourselves."],[9338,9384,"No!"],[9434,9505,"No, please!"],[9505,9638,"Just, just let me go and"],[9638,9772,"I, I'll pretend none of this"],[9772,9843,"ever happened."],[9843,9989,"You really think it's up to you?"],[10010,10181,"This is not about Caspian."],[10231,10456,"This pup has nothing to do with him."],[10635,10685,"Oh!"],[10773,10856,"Thank God!"],[10969,11115,"I mean, he really might have lost it"],[11115,11261,"if we got rid of his pup, but"],[11273,11473,"if the pup isn't Caspian's"],[11519,11632,"then there's really no reason"],[11632,11715,"to keep it,"],[11803,11886,"is there?"],[11961,11999,"No!"],[12020,12145,"Don't you dare hurt my pup!"],[12157,12303,"If you do, you'll regret it!"],[12303,12470,"How dare you threaten me?"],[12525,12620,"Hold her down."],[12821,12867,"No!"]],"14":[[66,125,"Wait!"],[216,408,"Willow, darling."],[550,663,"It's your big day."],[688,788,"You don't wanna get your dress"],[788,892,"all dirty."],[913,1038,"Leave this,"],[1142,1267,"to your brother."],[1292,1334,"No."],[1380,1430,"No."],[1505,1580,"No!"],[1839,1910,"Stop!"],[2761,2982,"You ruined my coronation."],[3678,3774,"My mother's right."],[3820,3995,"I can't get my dress all bloody."],[4383,4504,"But I don't mind my shoes"],[4504,4612,"getting a little dirty."],[4733,4817,"My pup."],[5434,5601,"I lost my pup."],[6177,6277,"Someone drag her out."],[6360,6439,"I don't want the floors"],[6439,6535,"getting all dirty."],[7119,7311,"I'll make you pay for this!"],[7903,8012,"Give me back my pup!"],[8041,8128,"I'll kill you!"],[8128,8270,"Give me back my pup!"]],"15":[[25,95,"I'll kill you!"],[108,241,"Give me back my pup!"],[279,321,"No."],[367,487,"You'll pay for this."],[1810,1956,"You rabid bitch!"],[1997,2097,"Somebody get a silver cage"],[2097,2210,"and lock her up!"],[2256,2373,"Yes, my Luna. - Yes, my Luna."],[2427,2544,"Are you alright?"],[2615,2698,"Oh, darling."],[2752,2823,"Don't you worry."],[2865,2969,"Caspian and his sister"],[2969,3044,"will be here soon."],[3090,3219,"They will help you get rid of her."],[4041,4095,"Are you sure"],[4095,4245,"Caspian will be okay with all this?"],[4254,4295,"Duh."],[4304,4371,"He'd never stick up"],[4371,4491,"for some rogue mistress."],[4529,4629,"He's the Alpha."],[4654,4704,"The whole pack"],[4704,4808,"would turn against him."],[5192,5342,"You tried to choke me."],[5397,5505,"Once Caspian gets here,"],[5505,5588,"you're the one who's gonna be"],[5588,5755,"begging for your life, not me."],[6322,6481,"You're just a worthless mutt."],[6531,6794,"My sister is the Alpha's mate,"],[6877,7178,"the future Luna of the Bloodveil pack."],[7253,7403,"And you will pay"],[7419,7607,"for everything that you did to her."],[8445,8658,"I'll make you pay for this."],[8746,8879,"You'll regret it."],[9013,9209,"When Caspian gets here,"],[9280,9463,"you're all dead."],[9463,9667,"This bitch is still yapping."],[9747,9926,"But she's all bark and no bite."],[10368,10481,"Once Caspian gets here,"],[10481,10614,"he's not gonna kill me."],[10769,10898,"He's gonna thank me"],[10944,11052,"for getting rid of the stain"],[11052,11198,"on his reputation."],[11511,11745,"The Alpha of the Bloodveil pack,"],[11745,11953,"Caspian Brooks, is here."],[13188,13430,"What the hell is going on?"]],"16":[[0,204,"Caspian Brooks is here."],[1121,1217,"Have you seen my sister?"],[1247,1313,"Where's Mari?"],[1451,1501,"No."],[1568,1797,"Willow, your mate is here,"],[1797,1918,"go greet him."],[1939,2052,"After everything he's done?"],[2052,2135,"I don't want to."],[2135,2243,"Right now is not the best time"],[2243,2356,"to throw a tantrum."],[2373,2444,"Ah,"],[2489,2610,"Alpha Caspian."],[2635,2756,"You've kept us waiting."],[2756,2815,"Oliver."],[2886,2977,"Pack emergency."],[2977,3053,"I'm very sorry."],[3053,3140,"I came as soon as I could."],[3549,3695,"Willow, honey, you look beautiful."],[3974,4033,"Have you had a chance"],[4033,4154,"to meet my, uh, sister?"],[4154,4233,"In fact, where is she?"],[4233,4300,"Is she here?"],[4350,4508,"Why don't you ask her yourself?"],[4525,4637,"You said she'd be here by now."],[4637,4729,"Is she ever gonna show?"],[4742,4833,"Of course she will."],[5009,5125,"Hey, listen, I'm,"],[5138,5251,"I'm sorry I'm late."],[5251,5309,"I'm sorry."],[5359,5442,"Don't touch me."],[5497,5622,"I don't know where those dirty paws"],[5622,5680,"have been."],[5847,5885,"I'm sorry,"],[5885,5960,"what are you talking about?"],[5960,6026,"What's wrong?"],[6135,6210,"Look, Willow,"],[6235,6339,"if you're gonna be my Luna,"],[6431,6544,"you can't talk to me like that."],[6560,6652,"Why shouldn't I?"],[6719,6827,"You know what you did."],[6965,7165,"What are you talking about? I-"],[7290,7524,"Cas, she's going to be your Luna."],[7574,7716,"You need to be more gentle with her,"],[7816,7907,"more understanding."],[8133,8291,"I'm not sure what I did, but"],[8375,8445,"whatever it is,"],[8445,8554,"would you please forgive me?"],[8683,8771,"Alpha Caspian,"],[8771,8933,"my darling daughter"],[8933,9113,"has always been our princess."],[9129,9280,"If you're going to be her mate,"],[9321,9438,"you have to treat her better."],[9438,9759,"Yes, our Willow is a real beauty."],[9801,9955,"She's a thousand times prettier"],[9955,10114,"than any gold-digging stray"],[10114,10260,"you'd pick up in the woods."],[10306,10531,"You need to be taking care of her."],[10543,10593,"Yeah,"],[10618,10785,"so no more slimy home-wreckers"],[10785,10944,"scamming their way into our family."],[10944,11086,"I will not allow anything else"],[11086,11194,"to happen to my sister."],[11194,11307,"I'm sorry, uh,"],[11378,11440,"Willow, honey?"],[11465,11565,"Home wreckers?"],[11640,11711,"Strays?"],[11715,11849,"What the hell are they talking about?"]],"17":[[25,154,"Stop denying it."],[212,346,"Everyone here knows about"],[346,529,"your trashy she-wolf side piece, okay?"],[529,629,"Congratulations,"],[667,729,"you've humiliated"],[729,771,"me. - Okay, okay"],[771,867,"Side piece?"],[963,1009,"Look at me."],[1067,1201,"You're the love of my life."],[1238,1397,"You're, you're my mate."],[1518,1584,"It's you."],[1584,1655,"It's only you."],[1655,1830,"I, I would never cheat on you."],[1830,1918,"In a million years,"],[1918,2022,"I never would or will."],[2106,2235,"So you're not even gonna admit it?"],[2477,2677,"Just wait until your sister gets here,"],[2702,2861,"and I tell her that her brother"],[2861,3011,"broke his sacred vow to his mate."],[3011,3165,"She's gonna be so disappointed in you."],[3165,3290,"Okay, that's enough."],[3361,3474,"Now, my patience is starting to"],[3474,3632,"wear really thin on this issue"],[3661,3728,"with all of you."],[3807,3903,"I haven't done anything,"],[3928,3999,"and that's final."],[4024,4183,"Have I not made myself clear?"],[4291,4425,"You've been running around"],[4425,4567,"with some other she-wolf."],[4654,4763,"What are you, gaslighting me?"],[4763,4900,"Are you telling me I'm crazy?"],[4900,4984,"Like- - Willow,"],[4992,5055,"deep breath."],[5055,5213,"You've already handled the problem."],[5259,5317,"I'm sorry,"],[5413,5484,"handled what?"],[5626,5726,"I locked that bitch up."],[5743,5897,"Yeah, you did what?"]],"18":[[0,100,"I need you to tell me right now,"],[100,158,"and be honest."],[158,241,"Who did you lock up?"],[333,521,"So this is what it's come down to?"],[588,784,"My own mate talking down to me?"],[888,1051,"After everything you've done to me?"],[1051,1263,"This has nothing to do with us."],[1284,1443,"Okay, this is not how the pack runs."],[1443,1593,"This is not how I run the pack."],[1622,1705,"So whoever you locked up,"],[1705,1801,"you need to release them."],[1843,1889,"Now."],[1889,1960,"Why, are you scared"],[1960,2043,"something is gonna happen"],[2043,2139,"to your secret lover?"],[2139,2298,"Oh, I swear on the Goddesses,"],[2298,2481,"I have never,"],[2481,2723,"nor will I ever, cheat on you."],[2744,2886,"But this is not how things work."],[2886,3040,"They go through the council first."],[3128,3211,"So I need you to release"],[3211,3315,"whoever this is."],[3403,3453,"Now."],[3474,3541,"No!"],[3557,3661,"I know you're lying."],[3661,3724,"You..."],[3820,3912,"You are unbelievable."],[3924,4037,"Alpha Caspian,"],[4095,4304,"I know it's not all your fault."],[4375,4521,"Willow wouldn't let you mark her"],[4521,4667,"before her coronation."],[4767,4884,"Of course you were tempted."],[4929,5192,"A powerful Alpha like you has needs."],[5234,5296,"Exactly."],[5388,5563,"There's absolutely nothing wrong"],[5593,5747,"with admitting to your mistakes."],[5747,5918,"You just have to learn from them."],[6126,6335,"Yes, we're all wolves here."],[6335,6493,"We understand the temptation."],[6610,6760,"Just come clean."],[6773,6865,"Alpha Caspian,"],[6886,7077,"all of us pack sisters don't blame you."],[7123,7232,"It's that rogue bitch's fault"],[7232,7328,"for seducing you."],[7394,7545,"Just apologize to Willow,"],[7565,7682,"and we'll all forgive you."],[8183,8274,"Okay, everyone."],[8299,8375,"I'm the Alpha,"],[8425,8566,"which means it's my responsibility"],[8566,8662,"to tell the truth."],[8683,8808,"I haven't done anything,"],[8821,8938,"so why should I apologize"],[8938,9034,"for something I haven't done?"],[9050,9188,"Is it really that hard for you"],[9188,9355,"to just admit your mistakes?"],[9363,9626,"My sister is a very kind"],[9642,9763,"and patient woman."],[9830,9880,"What?"],[9934,10030,"You think she's just throwing"],[10030,10151,"a tantrum for nothing?"],[10239,10510,"She is just asking for an apology."],[10627,10781,"I'm a reasonable person."],[10823,10985,"All I need is an apology,"],[11065,11177,"and then we can move on."],[11236,11307,"For the last time,"],[11444,11574,"I can't apologize"],[11574,11736,"for something that I haven't done."],[11807,11882,"It's that simple."],[12053,12145,"Do you have proof?"],[12303,12366,"Fine."],[12591,12654,"Here."],[12696,12787,"Recognize this?"],[12929,13046,"It's the necklace that you"],[13046,13204,"gave to your skanky mutt."],[13772,13918,"This is the Bloodveil Moonstone."],[14134,14255,"How do you have this?"]],"19":[[0,91,"How do you have this?"],[145,271,"So you do recognize it?"],[308,421,"The Bloodveil Moonstone"],[421,613,"is a powerful totem passed down"],[633,788,"to the Luna of the firstborn"],[817,934,"in the Bloodveil pack."],[942,1063,"So why was it in the hands"],[1063,1172,"of some other she-wolf"],[1172,1384,"instead of me, your mate?"],[1547,1622,"Well?"],[1693,1768,"Explain."],[1826,1947,"The Bloodveil Moonstone"],[1947,2143,"was my sister's favorite necklace."],[2156,2206,"She sold it"],[2206,2310,"when our pack was crumbling."],[2310,2535,"I never thought I'd see it again,"],[2540,2673,"in pieces."],[2690,2840,"Are you finally out of excuses?"],[3011,3115,"I always thought you were going to"],[3115,3236,"give me that necklace"],[3278,3453,"on the day of my Luna Coronation."],[3566,3712,"So why was it in the hands"],[3712,3874,"of some gold-digging bitch?"],[3924,4012,"When did I ever say"],[4012,4158,"the moonstone was gonna be yours?"],[4929,5009,"Alpha Caspian,"],[5084,5209,"you commanded me to win"],[5234,5326,"the Bloodveil Moonstone"],[5326,5392,"at an auction."],[5476,5622,"You said you wanted to buy it as a gift,"],[5651,5730,"but I was beat out"],[5730,5843,"by a mysterious buyer."],[5855,6031,"Do you think Willow could be confused?"],[6297,6373,"The facts are right"],[6373,6485,"in front of our faces."],[6535,6639,"Are you saying I'm blind?"],[6639,6773,"Are they all blind too?"],[6802,6898,"I have told you the truth."],[6911,7094,"I went to go buy this for my sister,"],[7203,7298,"and someone beat me to it."],[7298,7390,"That's impossible."],[7486,7549,"The necklace sold"],[7549,7691,"for three billion dollars."],[7728,7803,"What other Alpha has"],[7803,7857,"that kind of money"],[7857,7974,"to blow on a necklace?"],[8033,8145,"3 billion."],[8237,8316,"Could it be"],[8316,8395,"my sister?"],[8412,8495,"Willow, this is the last time"],[8495,8600,"I'm gonna ask you, honey."],[8746,8846,"Where did you get this?"]],"20":[[16,137,"Where did you get this?"],[175,358,"It doesn't matter where I got it."],[358,433,"What matters is that"],[433,571,"you gave it to some other she-wolf"],[571,784,"instead of me, your mate."],[834,905,"Now I'm telling you the truth."],[905,996,"Don't throw a fit over this."],[1009,1176,"You think I'm throwing a fit?"],[1217,1288,"Jesus."],[1343,1430,"Caspian,"],[1480,1722,"all I want is your commitment to me."],[1810,2052,"Your devotion to me, and only me."],[2118,2252,"I mean, all I'm asking for"],[2252,2364,"is a simple promise,"],[2364,2477,"a simple apology."],[2477,2519,"I mean,"],[2519,2631,"why is it really that hard?"],[2631,2798,"What am I apologizing for?"],[2840,2936,"I've said the truth"],[2961,3115,"over and over and over."],[3144,3261,"I can't apologize for something"],[3261,3361,"that I haven't done."],[3457,3707,"You are a coward, Alpha Caspian."],[3799,3941,"You'd rather humiliate me"],[3941,4062,"in front of the entire pack"],[4062,4158,"than admit you were wrong?"],[4175,4270,"Okay, that's enough."],[4454,4642,"If my sister hadn't made me"],[4658,4921,"promise to be patient with you,"],[5034,5230,"there's no way in hell I'd stand here"],[5230,5397,"and let you humiliate and shame me"],[5397,5518,"in front of our entire pack."],[5588,5714,"So now you're ashamed?"],[5814,5918,"You weren't embarrassed"],[5926,6010,"when you were cheating on me"],[6010,6114,"with some flea-ridden bitch"],[6114,6172,"in heat?"],[6477,6606,"My sister should be here by now."],[6606,6694,"Please go find her."],[6869,7019,"What are you calling for backup?"],[7073,7190,"If your sister were here,"],[7190,7323,"she'd stand with me."],[7941,8103,"The mate bond is sacred."],[8170,8274,"She would never let you"],[8274,8379,"hurt me like this."],[8804,8883,"Hurt you?"]],"21":[[0,79,"Look around you."],[120,200,"Look what you're doing."],[216,308,"You're hurting me."],[462,542,"You?"],[554,604,"Willow."],[638,709,"Willow, look at me."],[742,900,"Don't lose sight of the big picture."],[900,1146,"Who cares about a rogue bitch or two?"],[1180,1317,"That's what all Alphas like."],[1363,1472,"Once you marry him,"],[1472,1718,"all that is his will be yours too."],[1805,1943,"You'll be the one calling the shots"],[1943,2060,"for the Bloodveil pack."],[2072,2331,"And no skanky she-wolf"],[2331,2448,"can change that."],[2452,2585,"That's right, Willow."],[2640,2852,"Alpha Caspian is a rare catch."],[2902,3007,"Plenty of she-wolves"],[3007,3086,"would kill for the chance"],[3086,3224,"to crawl into his bed."],[3249,3420,"Just lock him down first"],[3420,3507,"and then deal with"],[3507,3620,"his stray bitch later."],[3749,3883,"Listen to your mother."],[3937,4049,"But Mom,"],[4091,4216,"he's still protecting that bitch."],[4216,4329,"I can't let this go."],[4329,4554,"Sis, don't lose your head over this."],[4621,4808,"Once he marks you as his Luna,"],[4838,5034,"his sister's gonna have no choice"],[5034,5196,"but to be in love with you."],[5259,5442,"And once that happens,"],[5476,5622,"all of his fortune"],[5622,5914,"and his entire pack will be yours."],[6998,7073,"Caspian."],[7461,7578,"Let's put this all aside."],[7649,7757,"Today's my Luna Coronation-"],[7757,7836,"Wait, what?"]],"22":[[112,212,"Alpha Caspian,"],[225,316,"I checked your sister's"],[316,417,"bedroom personally."],[529,613,"She isn't there."],[688,784,"Pull the security footage"],[784,867,"and you find her."],[880,925,"Now."],[1155,1238,"Wait, Caspian."],[1238,1330,"Where are you going?"],[1418,1497,"My sister is missing."],[1497,1589,"We'll figure this out later."],[1664,1814,"Are you calling off the coronation?"],[1856,1931,"Do you even still wanna"],[1931,2047,"crown me as your Luna?"],[2844,2969,"Is that a locket?"],[3107,3299,"Did that slimy skank drop it?"],[3924,4004,"Mari?"],[4358,4517,"There's a picture of two people inside."],[4525,4679,"Is it Alpha Caspian and his mutt?"],[4717,4833,"It doesn't look like him."],[4833,4992,"The wolf in the photo is older."],[5050,5255,"Maybe that's that skank's mate."],[5321,5451,"That makes Alpha Caspian"],[5459,5555,"the bond-breaker."],[5601,5722,"That bitch had to be the one"],[5722,5847,"that seduced my son-in-law."],[5880,5964,"Of course she is."],[5972,6143,"She's after his power and rank."],[6143,6231,"That's enough!"],[6310,6339,"What?"],[6339,6406,"Are we not allowed to"],[6406,6581,"talk down to your rogue bitch?"],[6598,6802,"Willow, I'm gonna ask you one time."],[7052,7223,"Where is the owner of this locket?"],[7323,7361,"Why?"],[7361,7528,"So you can save your secret mate?"],[7578,7745,"No, not in a thousand moons."],[7778,7924,"I'm not asking."],[7995,8087,"It's a command."],[8187,8404,"Where, is she?"]],"23":[[45,250,"Where, is she?"],[346,442,"Alpha Caspian,"],[492,688,"let's discuss this reasonably."],[696,825,"You are scaring her."],[875,1038,"You can't speak to your future Luna"],[1038,1113,"like this."],[1184,1292,"Alpha Caspian,"],[1313,1443,"I know you're afraid of"],[1443,1651,"this rogue she-wolf but,"],[1772,2018,"you can't harm your Luna."],[2064,2160,"Abusing her"],[216