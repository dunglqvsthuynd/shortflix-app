was-"],[4833,4888,"Willow."],[5092,5263,"No one heard you."],[5351,5568,"Just like you didn't hear me"],[5638,5772,"when I was begging"],[5872,5985,"for my pup's life."]],"35":[[0,141,"I'm sorry Luna Marina."],[141,225,"Please forgive me."],[225,304,"I didn't know."],[304,400,"I was jealous."],[400,604,"I, I'll punish myself!"],[604,729,"See ,I'll punish myself!"],[729,859,"Please, just please!"],[884,1005,"Please, let me go."],[1101,1309,"I gave you plenty of chances,"],[1380,1447,"didn't I?"],[1472,1518,"I..."],[1534,1668,"And you threw every single"],[1668,1780,"one of them away."],[1822,1881,"No, I don't."],[1881,1972,"I don't know."],[1989,2035,"You don't realize"],[2035,2168,"how foolish you've been."],[2202,2335,"So let me spell it out for you."],[2410,2473,"First,"],[2598,2673,"you didn't believe"],[2673,2836,"that I was Caspian's sister."],[2944,2998,"Fine."],[3073,3215,"But the second time was"],[3261,3390,"when Caspian called."],[3478,3561,"If you don't believe me,"],[3561,3757,"just get Caspian here, please."],[3774,3866,"And you had the chance"],[3866,3995,"to find out the truth."],[3999,4166,"But you wouldn't let me speak to him."],[4216,4337,"And for the third,"],[4400,4558,"it was a Luna coronation."],[4612,4717,"I brought the"],[4717,4884,"Bloodveil Moonstone,"],[5042,5180,"as a gift to you."],[5305,5426,"And you shattered it."],[5722,5805,"What?"],[5868,5964,"The Bloodveil Moonstone"],[5964,6039,"was supposed,"],[6076,6197,"was supposed to be mine?"]],"36":[[29,137,"The Bloodveil Moonstone"],[137,196,"was supposed,"],[250,367,"was supposed to be mine?"],[496,692,"The three-billion dollar moonstone,"],[692,800,"was supposed to be mine!"],[842,921,"You!"],[1013,1142,"It was your shitty idea"],[1142,1247,"to smash the moonstone!"],[1247,1313,"If we didn't do that,"],[1313,1405,"three billion dollars"],[1405,1493,"would have been mine!"],[1493,1576,"Are you"],[1576,1701,"fucking crazy?"],[1739,1901,"You talk like it was only my idea!"],[1901,1956,"Mom 