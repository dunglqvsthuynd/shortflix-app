{"1":[[1213,1413,"Oh, Sir Blackwater, you saved me!"],[1430,1551,"How can I ever repay you?"],[1568,1664,"With a kiss?"],[2110,2202,"Only two moons"],[2202,2339,"until you leave for the Knights Order."],[2473,2627,"Our time together is ending so soon."],[2656,2719,"That doesn't mean"],[2719,2827,"our love has to end, Freya."],[3040,3086,"You..."],[3128,3240,"are the most important thing"],[3240,3294,"to me."],[3495,3586,"I'm making a vow to you"],[3624,3666,"now."],[3799,3887,"I will come back for you."],[4141,4195,"So,"],[4487,4562,"will you marry me?"],[4696,4746,"Yes,"],[4783,4925,"absolutely I will."],[5689,5734,"Tristan,"],[5805,5897,"I want to give you"],[5905,6018,"my most precious thing."],[6272,6335,"My virginity."],[6398,6460,"Freya..."],[8737,8904,"I've been sick every morning."],[9092,9209,"And my belly is swollen."],[9288,9426,"Could I be pregnant?"],[9597,9684,"Madam Blackwater."],[9701,9788,"Lies!"],[9859,10047,"I've seen you and Tristan"],[10047,10272,"sneaking around at night for months!"],[10335,10585,"When is the last time you bled?"],[10639,10852,"Are you pregnant with Tristan's child?"],[10890,11065,"You dirty little harlot!"],[11327,11453,"You're weak and useless,"],[11453,11590,"but Tristan is destined"],[11590,11661,"for greatness!"],[11678,11790,"Madam, please."],[11820,12012,"Tristan loves me, I love him."],[12124,12358,"Look at this summoning letter!"],[12420,12650,"The Knights Order leaves tonight!"],[12716,12896,"If Tristan stays behind,"],[12896,13100,"you will ruin his only chance"],[13100,13204,"to become a knight."],[13296,13471,"If you truly love him,"],[13559,13747,"you will break his heart"],[13759,13984,"and vow to never see him again."],[14005,14055,"No!"],[14251,14376,"Do as I say, Freya,"],[14389,14527,"or I swear to the Gods,"],[14577,14798,"I'll kill you and your bastard child!"]],"2":[[66,262,"If I tell Tristan I'm with child,"],[300,417,"he'll abandon the Knights Order"],[417,550,"and give up on his dream."],[613,725,"His mother is right."],[817,934,"He deserves a chance"],[934,1142,"to become a great knight."],[1543,1680,"This is my promise to you, Freya,"],[1760,1826,"that I love you,"],[1897,1989,"that I will return to you."],[3328,3361,"Freya,"],[3361,3490,"why are you with the Blacksmith?"],[3603,3712,"Are you betraying me?"],[3820,3891,"Betraying you?"],[4158,4241,"Who are you to me then,"],[4258,4312,"Tristan?"],[4329,4416,"No one, really."],[4446,4671,"Baron makes a much better fit for me."],[4738,4817,"I mean, Baron here,"],[4817,4938,"he forges weapons more powerful"],[4938,5080,"than you could dream of wielding."],[5134,5217,"He..."],[5280,5367,"will pleasure me"],[5367,5547,"and protect me like you never could."],[5705,5839,"Freya, I love you."],[5864,5926,"Okay?"],[6143,6227,"Just give me a chance."],[6227,6314,"Let me show you that I can-"],[6314,6398,"Let go of me!"],[6569,6627,"Just leave!"],[6652,6798,"Tristan, just leave, okay?"],[6911,7044,"Go off, join the Knights Order."],[7044,7140,"Make a man out of yourself!"],[7140,7323,"Because you are clearly not one yet."],[7565,7649,"I don't want you."],[7987,8095,"Tristan, I never did."],[8199,8274,"You heard the lady,"],[8274,8337,"Squire."],[8395,8475,"You lost this battle."],[8508,8612,"Why don't you go off and"],[8612,8696,"die in another?"],[8917,9088,"You’re gonna regret this, Freya Swann."],[9914,10030,"Alone at last..."],[10068,10206,"Say we go back to my place."],[10343,10393,"You know how much"],[10393,10527,"my cock's been aching for you?"],[10593,10710,"What's the matter with you, anyway?"],[10710,10814,"You practically begged for me!"],[10814,10915,"I thought you were coming"],[10915,10990,"to your senses."],[11086,11115,"No."],[11190,11219,"Baron,"],[11236,11394,"I was just using you"],[11407,11574,"so that Tristan would leave me."],[11753,11853,"Now he's gonna go join"],[11853,11945,"the Knights Order,"],[12024,12145,"and he's going to become"],[12145,12249,"something great."],[12645,12716,"Unlike you."],[13234,13300,"Filthy whore!"],[13300,13421,"You've been stupider than I thought."],[13421,13475,"You think"],[13475,13634,"after Tristan becomes a knight"],[13634,13738,"he'll still want you?"],[13809,13863,"He won't even"],[13863,13951,"remember your name."],[14014,14222,"No man in this town will want you now."],[14264,14356,"I'll make sure of it!"],[14894,14944,"Goodbye,"],[14977,15023,"Tristan."],[15135,15277,"Even if you will hate me,"],[15344,15465,"even if you forget me,"],[15615,15749,"this is what's best for you."]],"3":[[45,162,"The dragon Nydros"],[162,400,"flies closer to our kingdom every day."],[450,558,"Many have tried to slay him,"],[650,746,"all have failed."],[796,959,"The man among you who succeeds"],[996,1201,"will become the head of my Royal Guard"],[1255,1422,"and the most respected knight"],[1422,1543,"in this kingdom."],[2848,3107,"Baron is a much better man than you."],[3357,3449,"You will regret the day"],[3449,3582,"you walked away from me, Freya."],[4074,4241,"Push harder, Freya."],[4241,4320,"I can't..."],[4320,4412,"The baby is stuck!"],[4454,4679,"Push harder for both of your lives!"],[5013,5109,"It's a boy!"],[5301,5397,"It's a boy."],[5472,5538,"Hi baby..."],[5597,5709,"Hi, my love."],[5747,5847,"What will you name him?"],[6072,6189,"If we ever have a son,"],[6256,6348,"we should name him Milo,"],[6402,6510,"since he's gonna represent"],[6510,6614,"all my love for you."],[6802,6869,"Milo."],[7102,7219,"I'll name him Milo."],[7415,7486,"The baby."],[7615,7703,"It's Tristan's."],[7724,7841,"Why didn't you tell me sooner?"],[7903,7966,"I could sign for him-"],[7966,8108,"No, no, no, no."],[8108,8149,"Please,"],[8195,8416,"Tristan must never know"],[8416,8546,"that he has a child."]],"4":[[91,171,"The beast!"],[1205,1347,"Tristan, save us!"],[3966,4162,"Hail the Dragon Slayer!"],[4195,4391,"Hail the Dragon Slayer!"],[4429,4621,"Hail the Dragon Slayer!"],[4667,4859,"Hail the Dragon Slayer!"],[4884,4988,"Hail the Dragon Slayer!"],[4988,5109,"This is for you, Freya."],[5505,5730,"The dragon Nydros hath been slain!"],[5759,5989,"Our hero shall arrive by nightfall!"],[6031,6202,"Your gown for tonight's celebration,"],[6202,6289,"Your Grace."],[6289,6389,"It's perfect!"],[6577,6702,"Our hero, the Dragon Slayer,"],[6702,6881,"won't be able to resist me."],[7069,7140,"Ow!"],[7203,7332,"Softer, you idiot!"],[7382,7478,"Yes, Your Grace."],[7490,7590,"Gods have mercy on me."],[7607,7732,"You're worthless, Freya."],[7757,7882,"Can't do anything right."],[7937,8145,"They say he's gorgeous"],[8187,8308,"and strong, too."],[8308,8445,"I heard he throttled Nydros"],[8445,8571,"with his bare hands."],[8587,8742,"I know some things that I'd like him to do"],[8742,8842,"with those hands."],[8863,9021,"He was only a squire five years ago"],[9021,9180,"when he joined The Order in battle."],[9367,9492,"Are you eavesdropping,"],[9492,9555,"servant?"],[9672,9793,"I'm so sorry, Your Grace."],[10502,10527,"Out,"],[10556,10698,"you sniveling little rat!"],[10731,10881,"Go empty my chamber pot."],[11820,11916,"The Dragon Slayer"],[11916,12016,"joined the Knights Order"],[12016,12124,"five years ago?"],[12237,12291,"No,"],[12341,12458,"it can't be him."],[14093,14264,"It's been five years, Freya Swann."]],"5":[[1697,1772,"This way, sir."],[2756,2852,"We are gathered tonight"],[2873,3044,"to celebrate the fiercest warrior"],[3061,3199,"to ever grace this kingdom."],[3240,3303,"The first man"],[3303,3486,"to slay a dragon in a century,"],[3532,3620,"the knight who will become"],[3620,3762,"the next head of my guard."],[3816,3916,"He will be mine."],[4833,5005,"You spilled wine on my shoes!"],[5055,5150,"The Dragon Slayer will be here"],[5150,5201,"any moment,"],[5201,5372,"and now you've ruined everything!"],[5480,5530,"Do you want to sleep"],[5530,5659,"in the dungeons tonight?"],[5705,5843,"No, please, the rats..."],[5893,5997,"I... I'll clean it up right now."],[6423,6481,"Everyone,"],[6510,6735,"welcome our Dragon Slayer!"],[7052,7140,"Not now,"],[7161,7282,"you incompetent bitch!"],[10819,10877,"Tristan."]],"6":[[79,308,"Tristan is the Dragon Slayer?"],[1172,1247,"Good for you,"],[1267,1326,"Tristan."],[1480,1672,"Your family must be so proud of you."],[2306,2410,"Tristan, what are you doing here?"],[2481,2585,"It's Sir Blackwater."],[2882,3011,"I'm the youngest Dragon Slayer"],[3011,3090,"in over a century."],[3186,3299,"The new head of the King's Guard."],[3832,3903,"At least address me"],[3903,3999,"with some respect now."],[4266,4387,"Sir Blackwater."],[5255,5426,"It's been five years, Freya Swann."],[5472,5538,"Do you have anything"],[5538,5601,"to say to me?"],[5722,5839,"Congratulations?"],[5922,5993,"I'm sorry?"],[6156,6177,"I mean,"],[6177,6268,"don't you see how wrong"],[6268,6348,"you were now?"],[6690,6790,"Congratulations."],[7011,7086,"There, happy?"],[7127,7186,"Freya!"],[7232,7328,"Get back to work!"],[7520,7549,"Right,"],[7565,7657,"yeah, um..."],[7795,7916,"I'll just get out of your way then."],[8345,8412,"A toast"],[8420,8525,"to our kingdom's hero,"],[8571,8675,"Sir Tristan Blackwater."],[8858,8929,"I owe a debt to you"],[8929,9054,"for protecting my people."],[9075,9205,"What is it you'd like in return?"],[9230,9342,"I can give you riches"],[9342,9501,"beyond your wildest imagination."],[9584,9797,"My daughter's hand in marriage..."],[9947,10093,"I desire but one thing, My Lord."],[10318,10360,"Her!"]],"7":[[50,87,"Her!"],[325,425,"Ugh, uh..."],[596,658,"A maid."],[942,1121,"I want her to be my personal servant."],[1184,1363,"But she's a dirty chambermaid!"],[1401,1543,"And a dreadful one at that."],[1576,1726,"I shall be the judge of her skills."],[1789,1868,"Sir, we have"],[1868,2027,"all the servants you could want."],[2077,2164,"Now if you'd like to discuss"],[2164,2289,"our engagement,"],[2314,2364,"I- - Celeste,"],[2406,2602,"Sir Blackwater has named his price."],[2736,2844,"The girl is yours."],[3695,3770,"Mama!"],[4020,4058,"Mama!"],[4058,4141,"My son,"],[4158,4204,"what..."],[4279,4408,"are you doing here?"],[4408,4537,"You're supposed to be with Aunt Livia"],[4537,4637,"taking care of grandpa!"],[4650,4721,"I ran away!"],[4767,4946,"I want to meet the Dragon Slayer, too!"],[5238,5313,"Papa!"]],"8":[[95,166,"Papa!"],[412,492,"I am so sorry."],[492,583,"I know I shouldn't be here."],[809,871,"Is that-"],[1088,1146,"Hello,"],[1146,1288,"I'm the- - I know who you are!"],[1288,1401,"You're the Dragon Slayer!"],[1418,1539,"They look so much alike."],[1643,1705,"How did you do it?"],[1751,1839,"Did you get burned?"],[1864,1935,"Were you scared?"],[2293,2344,"Sorry..."],[2369,2460,"about that."],[2460,2623,"He has a wild imagination."],[2644,2706,"Yeah?"],[2831,2907,"Come on, Milo."],[2907,2965,"Let's get you home"],[2965,3107,"before we get Mama in trouble."],[3378,3470,"I have to go."],[3887,3995,"Freya, why didn't you tell me"],[3995,4074,"that you had a son?"],[4137,4250,"No, Tristan."],[4300,4429,"We have a son."],[4542,4583,"But..."],[4600,4704,"he can never know"],[4783,4909,"he has a son."],[4971,5084,"His name is Milo."],[5159,5213,"She left me"],[5213,5338,"for Baron the Blacksmith,"],[5384,5501,"and then named their child"],[5501,5634,"after the love we shared?"]],"9":[[287,442,"Tristan should be with me,"],[454,642,"not some disgusting servant."],[692,759,"After tonight,"],[800,925,"Freya won't be going anywhere"],[925,1088,"near my future husband."],[1142,1305,"I'll make quite sure of that."],[1755,1801,"Go see it"],[1801,1960,"that my room is adequately prepared."],[2302,2427,"You must be so tired"],[2427,2552,"after your long ride"],[2552,2660,"back to the kingdom."],[2769,2944,"You should have a nice warm bath"],[2944,3078,"before you go to sleep."],[3128,3257,"I'll have a page attend to you"],[3257,3349,"right away."],[3749,3862,"Thank you, Your Grace."],[4913,5063,"Wait until the king hears"],[5063,5238,"the chambermaid is sneaking"],[5238,5438,"into the Dragon Slayer's bath."],[5960,6056,"Are you lost?"],[6160,6197,"Uh..."],[6197,6289,"I'm so sorry,"],[6289,6439,"I've never been in the men's..."],[6456,6556,"wing before."],[6556,6669,"Could you please point me to the way"],[6669,6852,"to Sir Blackwater's quarters?"],[6852,6915,"Sure."],[6936,7032,"Just through that door"],[7032,7107,"at the end of the hall."],[7148,7223,"Thank you."],[7223,7286,"Of course."],[9467,9626,"I was expecting to see a page,"],[9709,9813,"but since you're here..."],[10231,10285,"Bathe me."]],"10":[[20,58,"Father,"],[95,141,"come quick!"],[187,241,"It's Freya."],[291,354,"She snuck into"],[354,546,"the Dragon Slayer's bathhouse!"],[604,650,"I think"],[679,792,"she's spying on him."],[813,880,"What?"],[905,992,"Let's go take a look."],[1397,1459,"Bathe me."],[1647,1685,"Yes,"],[1839,1931,"Sir Blackwater."],[4250,4304,"Lower."],[4608,4713,"I said go lower."],[6702,6735,"What?"],[6956,7127,"Not like you’ve never seen it befeore."],[7236,7378,"He is even more handsome"],[7378,7515,"than the day I left."],[7570,7707,"She's even more beautiful"],[7707,7824,"than the day I left."],[7945,8066,"I assure you father,"],[8066,8149,"Freya is in there..."],[8149,8254,"Oh, they cannot find me in here."]],"11":[[1234,1326,"Stay behind me."],[1376,1459,"Don't say a word."],[2035,2093,"Your Grace,"],[2147,2248,"I'm unclothed!"],[2277,2344,"Leave now."],[2398,2531,"I know Freya came in here!"],[2598,2756,"Where is that little whore hiding?"],[2873,2932,"My king!"],[3003,3078,"What is the meaning of this?"],[3078,3161,"Is there danger afoot?"],[3203,3290,"Not exactly,"],[3290,3453,"but Celeste claims the servant girl"],[3453,3607,"snuck into the bath to spy."],[3670,3832,"I cannot abide such an assault"],[3832,3966,"on our most honored hero!"],[3966,4099,"And now she will sleep"],[4099,4195,"in the dungeons"],[4195,4300,"with the diseased rats!"],[4350,4446,"Right where she belongs."],[4487,4533,"Your Grace,"],[4533,4675,"there's no one in here but me."],[4754,4779,"Now,"],[4829,4971,"how long do we plan to stand"],[4971,5088,"and stare at each other for?"]],"12":[[70,179,"Celeste, you dragged me"],[179,316,"into this men's bath for nothing."],[329,417,"That is not"],[417,563,"how a princess is to behave."],[600,709,"Go back to your room at once!"],[888,1009,"Sir Blackwater, please..."],[1076,1205,"continue to enjoy your bath."],[1205,1301,"Father, no."],[1301,1401,"Freya snuck in here!"],[1426,1539,"That desperate bitch"],[1539,1739,"is trying to seduce the Dragon Slayer!"],[1843,1881,"Stop!"],[1964,2097,"This is the men's bathhouse."],[2097,2198,"How is the princess allowed"],[2198,2293,"to just barge in here?"],[2327,2498,"Celeste, what is the matter with you?"],[2519,2590,"Let's go!"],[2590,2660,"But Father..."],[2698,2752,"Ah!"],[2815,2923,"I said, enough!"],[2948,3057,"You have embarrassed me,"],[3103,3203,"and the crown!"],[3232,3390,"Go back to your room and repent."],[3428,3503,"And don't come out until"],[3503,3582,"you've learned your lesson."],[3636,3778,"Father, I'm the princess!"],[3778,3953,"You can't lock me in my room!"],[3953,4024,"You're a princess,"],[4024,4154,"thus why you shouldn't behave"],[4154,4275,"like a common whore!"],[4738,4788,"I..."],[5046,5134,"I should go."],[5355,5509,"Leaving after I just saved you?"],[5780,5918,"I'm not done with you yet."]],"13":[[20,150,"Why didn't you tell me you had a son?"],[229,433,"Could I tell him the truth right now?"],[525,629,"Would he believe me?"],[742,800,"Tristan-"],[875,921,"Forget it."],[1042,1101,"Why would you tell me"],[1101,1180,"the truth anyway?"],[1263,1338,"You cast me off"],[1338,1463,"and then slid right into Baron"],[1463,1559,"the Blacksmith's bed."],[1584,1747,"I mean, how foolish was I?"],[1885,1985,"But look at you now,"],[2006,2214,"cleaning chamber pots for paltry pay."],[2281,2410,"And Baron is nowhere in sight."],[2485,2527,"That"],[2560,2660,"arrogant"],[2660,2748,"bastard!"],[2748,2923,"He doesn't deserve to know the truth."],[2957,3211,"I'd rather be cleaning Celeste's shit"],[3211,3336,"than go anywhere near you."],[4796,4892,"Why are you so scared"],[4892,4959,"to get close to me,"],[4959,4996,"huh?"],[5167,5284,"Obviously, it was a mistake"],[5313,5455,"leaving me five years ago."],[6986,7111,"Are you afraid you're gonna fall in love"],[7111,7228,"with me all over again?"],[7269,7336,"I am not"],[7407,7595,"a weak little girl anymore,"],[7699,7799,"Sir Blackwater."],[7932,8091,"If I am forced to be your servant,"],[8091,8270,"I am gonna be the best servant"],[8270,8404,"this kingdom has ever seen."],[8721,8837,"Just what I wanted to hear."]],"14":[[2706,2915,"Oh, Sir Blackwater, you saved me!"],[2977,3098,"How can I ever repay you?"],[3132,3211,"With a kiss."],[4099,4291,"Stupid girl, what are you doing?"]],"15":[[308,383,"Women servants"],[383,554,"shouldn't touch a knight's armor!"],[571,738,"That's a squire's job!"],[784,1021,"Women are too weak and too stupid"],[1042,1167,"to handle such things."],[1197,1334,"Sir Blackwater asked me to, okay?"],[1334,1397,"I was just following orders."],[1397,1488,"Don't lie!"],[1589,1701,"You think Tristan requested you"],[1701,1764,"as his servant"],[1764,1885,"because you were special?"],[2018,2185,"I'm his squire,"],[2218,2364,"his right hand in battle."],[2548,2623,"And you,"],[2673,2857,"are nothing more than a concubine"],[2857,3078,"who cleans his shit."],[3707,3812,"Wait until Tristan sees"],[3812,4045,"what you've done to his prized armor."],[4104,4304,"Then you'll see how disposable you are."],[4337,4517,"Sir Blackwater won't believe your lies."],[4662,4788,"You should ask him yourself"],[4788,4904,"who he trusts more with his armor."],[4971,5134,"And you should go back to cleaning"],[5134,5321,"chamber pots, bitch!"]],"16":[[12,87,"Go back to clean"],[87,208,"chamber pots, bitch!"],[396,554,"Don't you lay a finger on her again"],[604,684,"or you're dead."],[721,759,"Sir,"],[809,930,"she's just a chambermaid!"],[930,1034,"I'm your squire."],[1051,1121,"Not anymore!"],[1226,1297,"Go to my chamber"],[1297,1388,"and ready my clothes."],[1505,1534,"Freya."],[1710,1764,"Be careful."],[2122,2210,"I'll deal with you."],[2323,2444,"Where are you taking me?"],[2473,2531,"To the king!"],[2652,2740,"We'll see how he decides to"],[2740,2844,"punish the squire"],[2882,3044,"that dared to fight the Dragon Slayer."],[3148,3240,"And if you ever wanted"],[3240,3328,"to become a knight,"],[3432,3528,"that dream is over."],[3628,3703,"Now get up here!"],[3991,4162,"I just cost Tristan his squire."],[4233,4400,"How will he torture me this time?"],[4800,4942,"Your clothes are there,"],[5042,5167,"so if there's nothing else..."],[5759,5947,"I'm really sorry for causing trouble,"],[6018,6114,"Sir Blackwater."],[6293,6360,"Trouble?"],[6423,6602,"My squire is an insolent coward."],[6602,6706,"He means nothing to me."],[6936,7015,"Now,"],[7119,7211,"undress me."],[8750,8817,"The shirt too."],[10798,10865,"What's this?"],[11061,11169,"It's an old heirloom."],[11240,11340,"I wear it for good luck."],[11941,12003,"Keep going."],[12404,12529,"Can't you do these yourself?"],[12871,13021,"You are my personal servant."],[13021,13146,"I just gave you a command."]],"17":[[930,1038,"Sir Blackwater."],[1242,1393,"I must speak with you at once!"],[1568,1634,"Oh,"],[1714,1801,"you're here too."],[2039,2093,"Leave us."],[2135,2235,"I have something private"],[2235,2394,"to discuss with Sir Blackwater."],[2427,2456,"Well,"],[2477,2594,"she's my maid, she can stay."],[2656,2744,"You were saying, Your Grace?"],[2852,3015,"Father told me to tell you that"],[3015,3069,"tomorrow is"],[3069,3232,"the Festival of the Harvest."],[3278,3345,"We will once again"],[3345,3545,"honor your heroic achievements"],[3545,3657,"with a special seat"],[3657,3787,"at the festival table."],[3824,3937,"And a dance with the lady"],[3937,4049,"of your choice!"],[4066,4149,"The Harvest Dance"],[4149,4341,"is a symbol of abundance and"],[4416,4508,"fertility."],[4938,5050,"I'd like Freya to join me."],[5117,5226,"I want her to sit beside me"],[5226,5288,"at the table."],[5484,5601,"Absolutely not!"],[5651,5714,"The Royal Family"],[5714,5889,"does not commune with servants!"],[5905,6010,"I guess I won't be sitting"],[6010,6056,"at your table then."],[6093,6210,"I'll go ahead and find my own."],[6210,6302,"Thank you, Your Grace."],[6335,6427,"I just mean..."],[6510,6719,"She's not properly educated"],[6719,6827,"in royal etiquette."],[6844,7032,"She would just embarrass herself"],[7032,7211,"and you, Sir Blackwater."],[7236,7323,"Besides,"],[7378,7553,"she doesn't have anything to wear."],[7707,7786,"Your Grace is right."],[7974,8070,"I don't have anything to wear."],[8070,8341,"I will serve, as is my place."],[8420,8470,"No."],[8575,8654,"I have a page that will"],[8654,8775,"fetch her a dress in town."],[8829,8925,"But Tristan-"],[8925,9079,"Freya's coming and that's my decision."],[9142,9234,"If she can't come,"],[9284,9392,"I won't be attending at all."]],"18":[[354,529,"You broke my heart five years ago."],[604,713,"Don't let me down again."],[804,950,"Dance with me at the festival,"],[950,1076,"and wear this dress."],[1251,1401,"Arrogant prick."],[1797,1906,"Uh... Princess Celeste!"],[2022,2193,"Tristan must have spent a fortune"],[2193,2281,"on that dress."],[2323,2464,"It's unusual for masters"],[2464,2560,"to buy their servants"],[2560,2752,"such expensive gifts."],[2794,2919,"I didn't ask him to."],[2919,3207,"It's much too nice for a dirty maid,"],[3278,3353,"don't you think?"],[3378,3520,"We can fix that right away."],[3641,3695,"Ah!"],[3720,3908,"Tristan should be buying me gifts,"],[3908,3991,"not you!"],[3991,4045,"No!"],[4120,4237,"Everyone knows the hero"],[4237,4421,"always marries the princess."],[4617,4796,"I can't let a low-class whore"],[4813,4988,"like you get in my way!"],[5088,5284,"I'll tell Tristan you hated the dress."],[5313,5422,"That you wouldn't dance with him"],[5422,5576,"if he were the last man alive."],[5605,5814,"Then he'll ask for my hand in marriage,"],[5843,5964,"and you'll be back to"],[5964,6135,"scrubbing chamber pots"],[6135,6293,"and sleeping with the rats!"]],"19":[[905,1067,"Freya should be here by now."],[1522,1701,"It is time for the Harvest Dance!"],[1755,1822,"Our hero,"],[1835,1968,"Sir Tristan Blackwater,"],[1997,2273,"may take the hand of any eligible lady"],[2273,2348,"he thinks"],[2348,2527,"would make a suitable bride."],[3745,3883,"You broke my heart five years ago."],[3941,4049,"Don't let me down again."],[4149,4275,"I have to get to Tristan."],[4362,4458,"I cannot"],[4496,4671,"let Celeste spread lies about me."],[5868,6018,"Freya isn't coming, Tristan."],[6043,6218,"She doesn't want you or your gifts."],[6247,6456,"I told you she was an ungrateful witch."],[6602,6715,"I don't want you."],[6790,6865,"I never did."],[7052,7165,"She still doesn't want me,"],[7286,7432,"even after everything I've done."],[7499,7653,"The hero always chooses"],[7653,7745,"the princess."],[7778,7853,"It's tradition."],[10126,10193,"Tristan!"],[10239,10310,"Who is she?"]],"20":[[116,183,"Oh!"],[183,233,"Freya?"],[429,596,"What is the meaning of this?"],[621,671,"Father,"],[696,855,"I told you the Harvest Festival"],[855,1046,"was no place for a filthy servant."],[1155,1213,"Guards,"],[1247,1343,"get her out of here!"],[1443,1597,"Don't lay a finger on her!"],[2531,2627,"This is the maiden I choose"],[2627,2698,"to dance with."],[2865,3040,"Father, you must stop this!"],[3090,3257,"This servant whore is making a mockery"],[3257,3365,"of your celebration!"],[3449,3561,"Just look at her dress."],[3620,3820,"It's vulgar and tasteless,"],[3862,3958,"just like her."],[4208,4346,"When I delivered that dress to Freya,"],[4346,4521,"it was in pristine condition."],[4612,4721,"Tell me, Princess Celeste,"],[4750,5017,"what kind of ugly, cold-hearted person"],[5017,5155,"would destroy something"],[5155,5230,"that I got with the gold"],[5230,5405,"that I fought so hard for?"]],"21":[[29,83,"I wouldn't."],[333,429,"I didn't."],[433,546,"Well, I saw Celeste"],[546,700,"sneak into the servant's quarters"],[700,800,"not ten minutes ago."],[804,1005,"Silence, you slimy little rat!"],[1005,1071,"I could kill you!"],[1071,1126,"Celeste,"],[1163,1226,"is this true?"],[1284,1326,"No."],[1401,1451,"I..."],[1505,1568,"I didn't."],[1659,1689,"Oh,"],[1705,1801,"what does it matter?"],[1805,1931,"I'm the princess,"],[1931,2102,"and she's a dirty chambermaid!"],[2135,2256,"I should be dancing with Tristan,"],[2256,2339,"not her!"],[3219,3340,"Look what you did!"],[3353,3516,"You ruined my dress!"],[3536,3687,"You ruined Freya's first."],[4099,4266,"Freya won't get away with this."],[4300,4446,"Tristan will be mine,"],[4454,4700,"even if I have to kill to get to him."],[5288,5338,"Now..."],[5442,5559,"may I have this dance?"]],"22":[[1555,1668,"Everyone's staring..."],[1826,1906,"I don't care."],[2202,2306,"Neither should you."],[3094,3132,"I thought you"],[3132,3257,"turned your back on me again."],[3336,3432,"Maybe I should have."],[3536,3699,"Look how pathetic I've become."],[3770,3862,"Why would a hero like you"],[3862,3970,"want someone like me?"],[4195,4262,"You're not pathetic."],[4550,4583,"Freya,"],[4942,5017,"you're beautiful."],[5372,5434,"Tristan,"],[5588,5659,"you're a knight."],[5734,5814,"I'm a maid."],[5955,6043,"We're further apart"],[6043,6131,"than we've ever been."],[6147,6247,"Freya, just admit it."],[6527,6623,"Admit that you still have"],[6623,6715,"feelings for me."],[6890,7019,"Admit that you still love me."]],"23":[[62,216,"How can I kiss him"],[216,316,"when I still haven't told him"],[316,383,"he has a son?"],[571,625,"Tristan..."],[838,930,"I can't do this."],[1747,1818,"Leave me,"],[1856,1906,"Tristan!"],[2139,2306,"I risked my life every day"],[2306,2406,"for the last five years"],[2406,2523,"to get to where I am today."],[2560,2715,"Who do you think I did it for, Freya?"],[2886,3003,"For yourself!"],[3182,3274,"For your family."],[3649,3807,"You're destined for greater things."],[3878,3978,"Tristan, so please"],[3978,4083,"just leave me out of it."]],"24":[[25,154,"I mean, Celeste was right."],[517,700,"The hero belongs with the princess."],[700,779,"It's only fair."],[855,892,"Don't"],[913,1009,"you talk to me"],[1009,1076,"about fair."],[1238,1305,"Five years ago,"],[1305,1501,"you shattered my entire world."],[1580,1685,"Freya, don't forget that."],[1885,2002,"You insulted me."],[2264,2318,"You left me"],[2318,2427,"for some arrogant Blacksmith"],[2427,2535,"who you had a son with."],[2711,2823,"Tell me how that's fair."],[2957,3057,"What did you just say?"],[3073,3153,"Your son,"],[3174,3244,"Milo!"],[3353,3482,"He's Baron's child, right?"],[3687,3824,"God damn it, just answer me!"],[3858,3970,"Tell me the truth, Freya."]],"25":[[12,120,"Tell me the truth, Freya."],[196,392,"I command you to answer the question."],[450,588,"That's why your son isn't here, right?"],[625,717,"He's with his father?"],[746,784,"No,"],[800,925,"you are his father."],[992,1167,"If you truly love him,"],[1192,1355,"you will break his heart"],[1355,1609,"and vow to never see him again!"],[1689,1735,"You think"],[1735,1885,"after Tristan becomes a knight,"],[1885,1993,"he'll still want you?"],[2164,2314,"If this is what he believes,"],[2444,2531,"so be it."],[2694,2794,"You do not"],[2848,2919,"own me,"],[2986,3057,"Tristan."],[3269,3365,"And why would I tell you"],[3365,3490,"anything anyway?"],[3691,3803,"You could just use it against me,"],[3803,3874,"make me do some"],[3945,4133,"horrible thing for you."],[4329,4391,"Horrible?"],[4733,4913,"I am not like these other people, Freya."],[5209,5313,"That doesn't matter, does it?"],[5413,5526,"Because I've never been good enough"],[5526,5584,"for you."],[5709,5797,"Tristan..."],[6151,6214,"Right."],[6514,6625,"I'm just your servant now,"],[6625,6700,"nothing more."],[6769,6931,"If that's your answer, then so be it."]],"26":[[492,617,"Sir Blackwater, you called for me?"],[750,875,"I need you to go to the Blacksmith’s"],[875,959,"and pick up my sword."],[980,1076,"The Blacksmith?"],[1155,1205,"You mean-"],[1205,1251,"Baron."],[1305,1409,"It's not gonna be a problem, is it?"],[1480,1714,"I haven't seen Baron since that day,"],[1714,1797,"five years ago."],[2381,2414,"No."],[2535,2619,"No problem at all."],[2673,2777,"I'll be back before nightfall."],[2986,3111,"If Freya won't tell me the truth,"],[3144,3294,"then I'll have to find out for myself."],[3712,3832,"Just get what you need and go."],[3962,4033,"You can do this."],[4529,4717,"What the hell are you doing here?"]],"27":[[183,321,"I'm just here to pick up a sword"],[321,533,"for my master, Sir Tristan Blackwater."],[546,696,"Freya Swann."],[804,871,"It's been five years"],[871,1013,"since you tried to get in my pants."],[1038,1138,"Cheap whore."],[1151,1255,"It's a good thing I kicked you"],[1255,1409,"to the ground and never looked back."],[1618,1830,"You were so desperate"],[1830,1926,"to get a piece of me."],[2077,2156,"Did you come crawling back"],[2156,2210,"for more?"],[2323,2481,"I never wanted anything"],[2481,2619,"to do with you, Baron."],[2644,2786,"You were dying to sleep with me,"],[2819,2986,"because no other maiden would."],[3032,3190,"Even I wasn't that desperate."],[3403,3482,"Look at you,"],[3595,3741,"in a chambermaid's uniform?"],[3741,3858,"But what else would a used-up"],[3858,3995,"old whore do for money"],[3995,4170,"besides clean people's shit?"],[4287,4366,"Look."],[4562,4733,"Just give me the sword, alright?"],[4733,4817,"And I'll be on my way."],[5622,5722,"You still owe me."],[6389,6514,"What’s under this apron?"],[6664,6740,"You might've gotten older,"],[6740,6848,"but I’d still like a taste."],[6927,6990,"Ow!"],[6990,7082,"You're no one."],[7107,7165,"Nothing."],[7223,7319,"I will have you."],[7382,7490,"And no one is gonna stop me."],[7736,7887,"Stupid slimy bitch!"],[8266,8466,"If you ever lay a finger on her again,"],[8479,8571,"I'll kill you."]],"28":[[0,216,"If you ever lay a finger on her again,"],[229,321,"I'll kill you."],[412,483,"You..."],[959,1121,"You're that feeble loser she"],[1121,1234,"dumped five years ago."],[1276,1355,"What's your name?"],[1397,1505,"Guess it doesn't matter"],[1505,1609,"once I break your bones."],[2414,2565,"I'm Sir Tristan Blackwater,"],[2698,2836,"Slayer of the Dragon Nydros,"],[2836,2961,"and Head of the King’s Guard."],[3011,3086,"You're the Dragon Slayer?"],[3086,3115,"I’m..."],[3148,3194,"I'm sorry."],[3224,3324,"I'm sorry, I didn't know!"],[3445,3591,"You cast a hero aside,"],[3591,3691,"and now you're a servant?"],[3691,3762,"You’re pathetic."],[3791,3870,"Not as pathetic"],[3933,4062,"as impregnating a woman"],[4091,4204,"and then abandoning her!"],[4241,4320,"Impregnate?"],[4387,4537,"I never touched that wretched bitch!"],[4558,4629,"Tristan, no!"],[5814,5860,"Freya..."],[5930,6001,"Why didn't you tell me"],[6001,6118,"that you didn't sleep with Baron?"],[6147,6277,"Then who's Milo's father?"]],"29":[[0,125,"Then who's Milo's father?"],[329,371,"Freya."],[462,500,"Freya!"],[1993,2160,"Tristan, I am so sorry."],[4375,4429,"Why didn't you tell me"],[4429,4604,"Baron was such an awful man?"]],"30":[[137,216,"Why didn't you tell me"],[216,354,"Baron was such an awful man?"],[400,496,"I mean, what would you have done"],[496,563,"if I hadn't showed up?"],[654,754,"It's been years."],[892,1021,"I didn't know he would..."],[1263,1426,"And I wanted to follow your orders."],[1455,1589,"Well then, follow this order."],[1693,1910,"Don't ever put yourself in danger"],[1910,1985,"like that again."],[2143,2239,"Do you understand?"],[2727,2815,"I don't know what I'd do"],[2815,2911,"if something happened to you,"],[2911,2952,"Freya."],[3161,3303,"I can't lose you again."],[3541,3616,"Did he hurt you?"],[3787,3891,"I'm fine."],[3991,4079,"Show me."]],"31":[[529,608,"You are hurt."],[850,930,"Baron hurt you."],[942,996,"Tristan."],[1080,1222,"I'm gonna kill him. -Tristan, Tristan!"],[1238,1276,"No,"],[1297,1355,"please don't."],[1426,1468,"Okay?"],[1468,1593,"I don't wanna see you as a killer."],[1609,1701,"Well then, stay here."],[1839,1931,"I'm not gonna kill him."],[1947,2127,"But he can't get away with this."],[2677,2781,"Sir, sir..."],[2815,2902,"Blackwater, please..."],[2961,3028,"Spare me."],[3328,3386,"Please don't."],[3440,3495,"Okay?"],[3495,3628,"I don't wanna see you as a killer."],[3782,3891,"I cannot kill you now."],[3928,4012,"But I can leave you here"],[4012,4158,"for the wolves to finish you off."],[4738,4779,"No!"],[4846,4896,"No!"],[5359,5463,"I didn't kill him."],[5630,5764,"But he's never gonna mess with you"],[5764,5843,"ever again."],[6748,6906,"No one's ever gonna harm you again."]],"32":[[1172,1217,"Doctor?"],[1326,1380,"Yes."],[1493,1584,"Drink this."],[1614,1805,"You'll feel so much better."],[2585,2640,"Papa?"],[2756,2857,"Papa, are you alright?"],[4058,4262,"Oh how could I sleep with him again,"],[4262,4375,"when I still haven't told him"],[4375,4483,"about Milo?"],[4783,4846,"I have an urgent"],[4846,4929,"letter for your servant,"],[4929,4971,"Sir!"],[5451,5563,"My father is..."],[5709,5789,"dying."]],"33":[[16,196,"Father has fallen gravely ill,"],[221,371,"and I worry he won't last the night."],[442,613,"You need to tell Tristan the truth"],[613,671,"about Milo."],[754,892,"If he loses his grandfather,"],[892,988,"he will need his papa."],[1201,1272,"Freya, what is it?"],[1589,1710,"Tristan and I are finally"],[1710,1789,"growing closer."],[1801,1889,"Would he understand"],[1889,1997,"if I told him the truth?"],[2039,2339,"Or would he hate me again,"],[2410,2585,"if he knew I kept his son from him?"],[2723,2873,"If he knew I took away his chance"],[2873,2977,"of being a father."],[3019,3161,"I have some business"],[3161,3282,"I need to attend to in town."],[3328,3424,"Could I have the day off?"],[3453,3520,"I promise I'll make up"],[3520,3641,"all of my duties tomorrow."],[3874,3999,"But who's gonna wash my clothes?"],[4058,4133,"Pour my wine?"],[4304,4400,"Keep me company"],[4400,4542,"when the sun goes down?"],[4838,4975,"Sir Blackwater, please."],[5050,5134,"It's just one day."],[5155,5246,"Sir Blackwater?"],[5417,5518,"You had no problem calling me"],[5518,5613,"Tristan last night."],[5655,5759,"That was a mistake."],[5889,6001,"It's not appropriate for a maid"],[6001,6072,"to lie with a knight."],[6072,6160,"Don't worry, Freya."],[6318,6423,"Your secret is safe with me."],[6589,6619,"Hey."],[6756,6861,"Tell me where you're going."],[6915,6986,"What are you up to?"],[7086,7165,"I cannot."],[7186,7211,"Look,"],[7211,7378,"I know Baron is not Milo's father."],[7461,7570,"Tell me what else you're hiding."],[7907,8045,"What happened in Baron's shop?"],[8103,8241,"I'm not letting anyone hurt you"],[8241,8316,"ever again."],[8404,8495,"So wherever you're going,"],[8495,8571,"I'm coming with you."]],"34":[[421,479,"Okay."],[575,746,"I am safe here."],[775,842,"So you can go ahead"],[842,942,"and head back to the castle."],[975,1055,"I'm sure the king will miss"],[1055,1130,"the head of his guard."],[1138,1213,"The king can survive"],[1213,1322,"without me for a day."],[1372,1526,"Tell me the truth right now and I'll go."],[1689,1864,"Freya, you had a son five years ago,"],[1881,2014,"and Baron isn't the father."],[2031,2102,"Then who is it?"],[2198,2310,"Who is the other man?"],[2323,2398,"Are you going to see"],[2398,2540,"Milo's real father right now?"],[2606,2706,"Freya, did I really mean"],[2706,2798,"so little to you"],[2798,2882,"that you cannot tell me"],[2882,3036,"whose bed you ran to after I left?"],[3128,3165,"Freya?"],[3278,3345,"Come quick."],[3403,3478,"Father needs you."],[3661,3716,"Father?"]],"35":[[654,734,"What happened?"],[796,909,"I wish you could speak."],[967,1076,"Tell us what's wrong."],[1146,1305,"The doctor came by this morning."],[1334,1480,"He doesn't have the medicines"],[1480,1547,"to heal him."],[1589,1764,"And we can't afford better."],[1872,1951,"If we could afford it,"],[1951,2056,"I wouldn’t have had to become"],[2056,2181,"Celeste's chambermaid..."],[2569,2656,"It's a boy!"],[2719,2794,"No, please."],[2840,3069,"Tristan must never know"],[3069,3211,"that he has a child."],[3269,3357,"Hi Milo."],[3390,3520,"I'm your Auntie Livia."],[3549,3657,"That's your mommy, Freya."],[3770,3870,"He's got your eyes, Freya."],[3999,4108,"Swann family?"],[4154,4304,"You owe back taxes to the crown!"],[4333,4533,"Pay now, or your land will be seized."]],"36":[[16,75,"No, I'm..."],[137,221,"I'm so sorry."],[221,392,"Our father, he's very ill right now"],[392,475,"and he cannot work."],[475,546,"But uh..."],[546,675,"as soon as I'm healed,"],[721,863,"I'll work and I'll pay off the taxes."],[863,1013,"We just need an extension, okay?"],[1084,1192,"Preposterous."],[1251,1376,"How dare a lowly commoner"],[1376,1451,"such as yourself"],[1451,1601,"ask for a tax extension."],[1618,1726,"Either pay now,"],[1755,1868,"or sign a contract"],[1868,2027,"with the crown to repay your debts."],[2068,2131,"Princess Celeste"],[2131,2248,"needs a new chambermaid."],[2285,2339,"I'll sign."],[2723,2802,"No, Livia!"],[2802,2857,"Livia."],[2986,3119,"You cannot go to the castle."],[3174,3249,"Princess Celeste"],[3249,3370,"is known for her ill-manners."],[3370,3507,"You cannot go, I'll go."],[3541,3591,"I'll go."],[3657,3812,"You just had Milo- - I know."],[3945,3987,"I know."],[3987,4191,"That's exactly why I need you here,"],[4295,4479,"to take care of Milo and papa."],[4479,4592,"You've always been more maternal"],[4592,4675,"than I have."],[5055,5105,"I'll sign."],[5347,5392,"I'll sign."],[5447,5518,"We are nothing"],[5518,5651,"but a burden to Tristan."],[5747,5914,"How could someone as low as me"],[5914,6131,"ever be worthy of someone like him?"],[6172,6247,"I'm sorry."]],"37":[[33,125,"Freya, why didn't you tell me"],[125,225,"that your father was ill?"],[321,421,"Why'd you let me believe that"],[421,558,"you just ran off with some other man"],[558,675,"after we just shared a bed?"],[684,759,"You made me believe that"],[759,817,"you were trying to"],[817,875,"break my heart again."],[884,963,"Why'd you do that?"],[1038,1159,"Not all about you,"],[1213,1284,"Tristan."],[1334,1472,"Why would I tell you anything?"],[1518,1580,"You always assume"],[1580,1689,"the worst of me anyway."],[1705,1789,"Freya, I don't think-"],[1789,1864,"I told you,"],[2006,2077,"you should go."],[3244,3390,"If he really loved me,"],[3449,3653,"if he was really ready"],[3670,3820,"to be a father to our son,"],[3978,4070,"he would have stayed."],[4859,5005,"Freya's all wrong about me,"],[5063,5155,"but why do I even care"],[5155,5217,"what she thinks?"],[5301,5501,"I'm the Dragon Slayer and she's..."],[5605,5689,"the love of my life."],[5872,5968,"And I'm gonna prove it to her."]],"38":[[446,579,"I need you to do something for me."],[1109,1222,"I know I practically"],[1222,1355,"commanded him to leave,"],[1451,1547,"but I really wish"],[1547,1676,"Tristan was here right now."],[1726,1851,"Of course you do, Sister."],[1922,2018,"He's your first love,"],[2039,2164,"father of your son."],[2181,2318,"Those feelings don't just fade away."],[2339,2481,"I'm really scared"],[2540,2635,"about what's gonna happen"],[2635,2748,"if we lose papa."],[2823,3003,"I feel like I sacrificed everything"],[3061,3178,"to keep him alive,"],[3224,3424,"to keep you and Milo fed and happy."],[3478,3699,"Our family will be devastated."],[3995,4145,"Will it all have been for nothing?"],[4212,4291,"Not for nothing."],[4400,4521,"Could always hope for a miracle."],[4579,4708,"Yeah, I don't believe in miracles"],[4733,4842,"anymore, Livia."],[5367,5430,"Tristan,"],[5480,5563,"you came back."],[5597,5714,"I brought the king's doctor."],[5743,5851,"He's gonna heal your father."]],"39":[[0,154,"Thank you so much for coming, Sir,"],[154,179,"but..."],[258,358,"we don't have the gold."],[358,525,"Sir Blackwater has already paid."],[742,863,"He did this for me."],[938,1042,"For my family."],[1051,1184,"I need to take a closer look at him."],[1209,1280,"Kindly leave us."]],"40":[[1005,1263,"I'm so sorry for everything."],[1409,1543,"I don't know how to thank you,"],[1543,1655,"Sir Blackwater."],[1789,1868,"Don't call me that."],[2081,2248,"As much as you wanna protest it,"],[2289,2427,"you're always gonna be more"],[2427,2535,"than just a maid to me."],[2619,2715,"And for what it's worth,"],[2715,2819,"I don't think the worst of you."],[2840,2952,"In fact, I think you're the best thing"],[2952,3065,"that's ever happened to me."],[3420,3503,"And I don't ever wanna"],[3503,3591,"lose you again."],[4041,4191,"How I want to tell him the truth"],[4191,4291,"about his son."],[4358,4533,"I need to tell him the truth, but..."],[4692,4838,"I can't stop this now."]],"41":[[2248,2389,"Oh, I cannot do this again."],[2510,2673,"Not until I tell him about Milo."],[3082,3128,"What is it?"],[3357,3403,"Freya,"],[3403,3524,"if you don't want to do this, then..."],[3632,3695,"Mama?"],[4158,4316,"Mama, you brought Papa home!"]],"42":[[0,137,"Mama, you brought Papa home!"],[546,608,"Milo,"],[646,717,"my love,"],[742,942,"his name is Sir Blackwater."],[1009,1109,"Why did you come here?"],[1197,1288,"I was, uh..."],[1509,1626,"I was just checking on your mama"],[1651,1718,"and grandpapa."],[1889,1972,"Milo,"],[1985,2093,"let's get ready for bed!"],[2164,2227,"Alright."],[2306,2398,"You heard auntie,"],[2439,2548,"go run along and I'll be right there"],[2548,2615,"to tuck you in."],[2615,2752,"Can't Sir Blackwater tuck me in?"],[2994,3086,"I want to hear the story"],[3098,3236,"of how he slayed Nydros!"],[3328,3403,"Sir Blackwater"],[3403,3503,"is head of the King's Guard."],[3503,3561,"He cannot- - I'd love to."],[4012,4120,"If that's okay with your mama?"],[4170,4254,"Please, Mama."],[4316,4387,"Can Sir Blackwater"],[4387,4517,"tell me a bedtime story?"],[5050,5171,"You need to tell Tristan"],[5171,5280,"the truth about Milo."],[5296,5401,"He will need his papa."],[5597,5676,"Fine."],[5718,5910,"One short story."],[6056,6206,"Yay!"],[6231,6339,"Okay, go ahead."],[6765,6915,"He looks so much like you, Freya."],[7336,7486,"I think he looks more like his father."]],"43":[[145,300,"We tiptoed through the forest,"],[300,475,"encountering all sorts of wild,"],[475,613,"hungry animals."],[667,746,"Sir Blackwater,"],[763,905,"what is your favorite animal?"],[992,1101,"I'd probably say a wolf."],[1167,1247,"You know why?"],[1343,1522,"Because they're ferocious!"],[1622,1718,"But also,"],[1847,1960,"they're extremely loyal"],[1960,2064,"to the ones that they love."],[2360,2494,"That's my favorite too!"],[2627,2736,"Of course it is."],[2848,3015,"Milo takes after his father."],[3086,3169,"How did you slay the dragon"],[3169,3265,"once you found him?"],[3328,3411,"With nothing"],[3486,3599,"but a sword"],[3707,3774,"and a shield."],[3866,4004,"Can you teach me how to use a sword?"],[4095,4233,"Auntie says I'm quick on my feet,"],[4241,4354,"not clumsy like mama."],[4512,4675,"She often does need rescuing, huh?"],[4846,4946,"Which makes me wonder,"],[4984,5071,"where you..."],[5138,5309,"actually did get your skills from?"],[5342,5447,"From you, of course!"]],"44":[[20,120,"From you, of course!"],[120,229,"Okay, Milo."],[813,971,"I think it's time for bed, yeah?"],[1042,1142,"Goodnight, Sir Blackwater."],[1272,1338,"Goodnight, Milo."],[2773,2857,"Look, Tristan,"],[2990,3103,"I know what you want,"],[3269,3428,"but I'm afraid I cannot give it to you."],[3490,3607,"Are you sure you know what I want?"],[3691,3774,"Because five years ago"],[3774,3841,"you sent me away"],[3841,3949,"thinking I'd never return."],[4045,4133,"You thought I could just leave"],[4133,4241,"and never care about you again."],[4500,4612,"I hoped you wouldn't."],[5059,5125,"And I didn't."]],"45":[[79,204,"I could have taken the king's offer"],[204,304,"to sit next to Celeste"],[304,379,"and rule one day."],[475,621,"I could have traveled off to some,"],[679,775,"I don't know, foreign land"],[775,863,"and married off some other"],[863,934,"fair maiden."],[992,1034,"I know."],[1222,1326,"Alright, I know"],[1359,1459,"that you are strong"],[1459,1584,"and you are powerful"],[1593,1701,"and you are desired"],[1714,1851,"by fair maidens everywhere."],[1851,1956,"You don't have to remind me of that."],[1993,2077,"No, Freya."],[2181,2306,"Are you listening to me?"],[2406,2556,"I don't care about the glory,"],[2573,2648,"the riches,"],[2719,2786,"the honor."],[2969,3115,"I just want to know one thing."],[3319,3420,"Do you still love me?"],[3757,3866,"Come quick!"]],"46":[[20,91,"Father."],[241,358,"I've given him a healing tincture."],[371,483,"He should awaken any moment."],[575,779,"Does your father have any enemies?"],[825,934,"No, he's been bedridden"],[934,1005,"for many moons."],[1151,1234,"Why do you ask?"],[1280,1359,"Because..."],[1409,1526,"he was poisoned."],[2027,2093,"Father!"],[2256,2306,"Oh..."],[2381,2494,"my beautiful daughter."],[2606,2761,"Father, what happened last night?"],[2823,2882,"A woman..."],[2977,3053,"in a cloak..."],[3078,3140,"came to me..."],[3244,3332,"Made me drink..."],[3445,3566,"Said she was a doctor."],[3703,3849,"Your father may not have any enemies."],[3916,3991,"But do you?"],[4287,4354,"Celeste?"],[4496,4558,"Tristan."],[4667,4721,"My boy."],[4754,4875,"So good to have you back."],[4938,4996,"I..."],[5100,5201,"I haven't seen you"],[5288,5405,"since you asked for Freya's hand"],[5405,5480,"in marriage."]],"47":[[271,337,"I always wondered"],[337,467,"what went sour between you."],[529,667,"Freya loved you so much."],[742,896,"But it wasn't my place to pry,"],[975,1071,"even if she was pregnant-"],[1071,1126,"Father."],[1238,1351,"I think you should rest."],[1418,1509,"Tristan, I'll show you out."],[1968,2089,"You were really going to propose?"],[2147,2235,"Of course I was."],[2389,2481,"I loved you, Freya."],[2481,2523,"Stop."],[2786,2952,"You see what my life is like."],[3148,3265,"My father's ill."],[3299,3382,"I have a son"],[3382,3528,"and my sister to take care of."],[3649,3782,"You should go back to the castle."],[3782,3924,"Live your life as a hero."],[3978,4091,"Don't let me burden you."],[4137,4200,"Burden?"],[4412,4521,"You're no burden, Freya."],[4596,4696,"And if Celeste is trying to"],[4696,4754,"poison your father,"],[4754,4896,"then there's no way I'm leaving you"],[4896,4971,"without protection."],[5196,5292,"So go ahead."],[5588,5689,"Command me to leave."],[6168,6264,"Go ahead."]],"48":[[337,396,"Leave."],[863,913,"No."],[992,1134,"I'll sleep outside your door"],[1134,1242,"on the floor if I have to."],[1372,1476,"I'll do whatever it takes"],[1476,1664,"to keep you and your family safe."],[2210,2414,"Okay, I'll let him stay tonight."],[2477,2540,"And I'll tell him"],[2540,2640,"about his son tomorrow."],[4729,4850,"When I'm there laying"],[4850,5021,"on the ground outside your door,"],[5321,5522,"I'll wish I was with you instead."]],"49":[[2986,3053,"Sir Blackwater."],[3053,3161,"Sir Blackwater, wake up!"],[3361,3399,"What?"],[3478,3649,"Milo, where's your mama and auntie?"],[3674,3737,"Shh..."],[3791,3870,"Sleeping."],[3899,3970,"Will you teach me"],[3970,4066,"how to be a knight now?"]],"50":[[2631,2731,"Father and son,"],[2794,2932,"and they don't even know."],[3311,3374,"I think you're ready"],[3374,3457,"to become a knight now."],[4200,4254,"But first,"],[4254,4483,"let's clean some of this snow off of you."],[4533,4633,"Well, there you go."],[5242,5338,"You have a birthmark"],[5338,5405,"on your neck."],[5455,5647,"Mama says my papa has the same one."],[6281,6368,"Milo is..."],[6498,6569,"my son."]],"51":[[162,258,"You have a birthmark"],[258,325,"on your neck."],[767,842,"Papa!"],[1105,1247,"Mama, you brought Papa home."],[1347,1426,"Milo is..."],[1501,1572,"my son."],[1643,1793,"Sir Blackwater, is something wrong?"],[1847,1997,"I'm sorry, Milo, I gotta go."],[2498,2615,"Milo, where's Sir Blackwater?"],[2665,2752,"He saw my birthmark."],[2794,2861,"Then he fled."],[3161,3253,"Do you think he knows?"],[3328,3378,"Oh Gods,"],[3378,3524,"why didn't I tell Tristan earlier?"],[3549,3657,"Why didn't I do that?"],[3807,3920,"What if he's run off forever?"],[4083,4149,"What if he has the king"],[4149,4262,"lock me away in a dungeon?"],[4270,4325,"Freya."],[4325,4400,"Hmm."],[4533,4667,"Tristan would never do that."],[4758,4875,"But you've waited long enough."],[5050,5171,"Father's in better health,"],[5180,5330,"and I can take care of Milo."],[5413,5492,"Go to Tristan."],[5576,5709,"It's time you finally told him."],[5951,6081,"Why wouldn't she tell me?"],[6160,6206,"Why would she"],[6206,6348,"keep my son away from me"],[6368,6477,"for all these years?"],[6723,6773,"Tristan."]],"52":[[16,129,"Fetch me my tunic."],[225,417,"Yes, Sir Blackwater."],[2565,2652,"Clean my hands."],[2786,2923,"Yes, Sir Blackwater."],[3941,3995,"Kneel."]],"53":[[45,104,"Kneel."],[154,246,"Scrub my boots."],[638,692,"Don't."],[971,1096,"What are you doing, Freya?"],[1255,1326,"I mean, do you like"],[1326,1413,"being ordered around"],[1413,1497,"to be humiliated?"],[1701,1780,"Why didn't you tell me"],[1780,1901,"Milo was my son?"],[1972,2085,"I wanted to."],[2339,2385,"I..."],[2427,2527,"came here to tell you."],[2527,2635,"I wanted to tell you this morning."],[2660,2702,"But-"],[3007,3140,"You really think I believe that, Freya?"],[3140,3269,"How stupid do you think I am?"],[3390,3495,"The first time I saw your son,"],[3495,3666,"he ran right up to me and called me papa,"],[3666,3716,"don't you think"],[3716,3795,"that's a little weird?"],[3891,4016,"And he wants to be a knight too,"],[4016,4191,"and he's goddamn good with a sword."],[4245,4354,"He has the same"],[4354,4462,"diamond shaped birthmark"],[4462,4537,"that I have."],[4571,4646,"You don't know"],[4646,4733,"what happened,"],[4775,4829,"Tristan!"],[4863,5005,"Then tell me what happened!"],[5221,5267,"Why?"],[5326,5488,"Tell me why you hid my son from me?"],[5488,5601,"Because I love you,"],[5626,5689,"Tristan!"]],"54":[[513,617,"I knew Milo was your son"],[617,713,"and I didn't tell you."],[1005,1138,"Why do you keep pushing me away?"],[1213,1301,"Because you would've given up"],[1301,1426,"everything for me,"],[1463,1526,"Tristan."],[1722,1830,"I couldn't let you do that."],[1964,2085,"I mean, I didn't know for sure"],[2085,2189,"that I was pregnant when you left."],[2189,2260,"If I had, I..."],[2385,2581,"If you truly love him,"],[2648,2848,"you will break his heart"],[2877,3236,"and vow to never see him again!"],[3269,3315,"No!"],[3474,3653,"No! No! No!"],[3653,3741,"Do as I say, Freya,"],[3741,3903,"or I swear to the Gods,"],[3941,4170,"I'll kill you and your bastard child!"],[4483,4575,"Honestly, Tristan,"],[4738,4854,"I still would've made you"],[4854,4967,"join the Knights Order."]],"55":[[33,162,"You know how good of a father"],[162,275,"I could have been to Milo?"],[408,508,"And I could've taken care of"],[508,608,"you and Livia."],[692,775,"You wouldn't be sitting here"],[775,905,"working for Celeste."],[959,1046,"You don't know that."],[1067,1138,"You don't."],[1172,1380,"You could've been plagued with regret"],[1393,1568,"for ruining the Blackwater"],[1568,1659,"family legacy."],[1730,1789,"But still..."],[1843,2010,"I sat there, my belly growing,"],[2027,2193,"and my pain with it..."],[2352,2469,"When I was screaming"],[2494,2719,"in labor for endless hours."],[2848,3182,"Some insane part of me"],[3365,3482,"hoped that you would come back"],[3499,3582,"and tell me that"],[3582,3737,"you never should have left me."],[3799,3862,"Well I thought"],[3862,3974,"you were in love with Baron!"]],"56":[[4,62,"Well I thought"],[62,175,"you were in love with Baron!"],[229,329,"I thought you wouldn't look at me"],[329,508,"twice again unless I proved my worth."],[596,813,"That's why I vowed to slay Nydros!"],[1447,1614,"When I was out on that battlefield,"],[1710,1960,"face dirtied with the blood of my friends,"],[2010,2089,"enemies,"],[2122,2214,"as I trekked through"],[2214,2327,"the snow and the sleet"],[2327,2398,"and the rain..."],[2481,2631,"I slayed that dragon."],[2715,2806,"I slayed him."],[2861,2973,"This is for you, Freya."],[3123,3228,"All I could think about"],[3228,3353,"was seeing you,"],[3465,3536,"touching you."],[3707,3824,"I'm sorry."],[3866,4008,"I didn't tell you about Milo."],[4008,4099,"I am. It is..."],[4283,4529,"It is the biggest regret of my life."],[4646,4754,"But I'm not sorry"],[4846,4992,"that you got to become the man"],[4992,5084,"that you are today."],[5155,5226,"Freya."],[5413,5476,"I'm so sorry."],[5476,5597,"I should have told you the second"],[5597,5714,"that I saw you again."],[5918,6043,"But I'm still completely,"],[6131,6264,"completely and utterly"],[6264,6339,"in love with you."]],"57":[[988,1180,"Do I tell Tristan about his mother?"],[1242,1380,"Do I tell him the real reason"],[1380,1472,"I made him leave?"],[1534,1639,"Don't worry about anything else"],[1639,1739,"right now, Freya."],[1885,1997,"Just be here with me."],[2102,2214,"Because I want you."],[2268,2339,"I need you."],[2610,2681,"Okay?"],[4041,4112,"This is just"],[4112,4270,"like our first night together."],[4725,4792,"Freya..."],[4875,5013,"Tristan, I want to give you"],[5013,5155,"my most precious thing."],[5576,5647,"My virginity."]],"58":[[387,479,"Are you sure you don't want to wait"],[479,550,"until marriage?"],[725,788,"I'm sure."],[813,934,"I want you to have me,"],[980,1055,"tonight."],[4346,4433,"As you wish."],[4813,4904,"Tristan."],[5005,5055,"Freya."],[5363,5434,"I love you."],[7766,7907,"That was my most favorite night"],[7907,8016,"of my entire life."]],"59":[[175,316,"That was my most favorite night"],[316,425,"of my entire life."],[492,629,"I can't tell you how many times"],[629,746,"I've thought about that night."],[1697,1839,"You have no idea how many times"],[1839,1935,"I've wanted to kiss you again."],[2014,2164,"You can kiss me all you want."],[2231,2318,"As long as you promise"],[2318,2423,"it won't be the last."],[2460,2573,"I promise."],[3636,3724,"Tristan."]],"60":[[91,204,"Hey, I'm really sorry"],[204,329,"I didn't tell you about Milo."],[379,442,"For all the years"],[442,583,"you lost out on together."],[613,667,"Don't worry,"],[667,804,"we're gonna make up for it."],[967,1101,"I'm sorry that I didn't tell you"],[1101,1247,"that I wanted forever with you"],[1247,1334,"no matter what."],[1447,1501,"And..."],[1526,1659,"that I didn't challenge Baron"],[1659,1785,"to a duel right then and there"],[1785,1906,"for your affection."],[2010,2072,"We both know"],[2072,2181,"I would've won that one."],[2736,2836,"Now that Freya's off"],[2836,3019,"dealing with poor dead daddy,"],[3044,3236,"it's time to seduce Tristan."],[3407,3503,"Is that Freya?"],[3586,3782,"Did her poor useless father"],[3782,3949,"actually survive?"],[4104,4262,"I promise I'm gonna do everything I can"],[4262,4379,"to never lose you again."],[4608,4671,"And..."],[4679,4742,"Hmm?"],[4767,5009,"I'm gonna be the best father to Milo."],[5142,5213,"Milo?"],[5388,5576,"Gods, how are we gonna tell Milo that"],[5601,5693,"Sir Blackwater,"],[5693,5889,"the Dragon Slayer, is his father?"],[6160,6327,"Freya's bastard child"],[6327,6519,"is Tristan's son?"]],"61":[[704,784,"You know, it's not right"],[784,884,"that you're still my maid."],[1067,1197,"I'm gonna ask King Lancaster"],[1197,1376,"if he can relieve you from your duties."],[1534,1589,"And them I'm gonna have you"],[1589,1714,"throw Celeste into the dungeons"],[1714,1797,"for what she did to you."],[1981,2077,"And then"],[2093,2189,"I will..."],[2281,2406,"pay your dad's taxes off"],[2406,2531,"and I'll even- -Okay in time."],[2686,2756,"Tristan."],[2894,3044,"We have no proof that"],[3044,3228,"Celeste actually poisoned my father."],[3303,3516,"So for now, we need to focus on"],[3516,3657,"proving your worthiness"],[3657,3737,"to the king."],[3762,3812,"He won't allow"],[3812,3958,"such sordid affairs as ours"],[3958,4033,"if it’s interfering with"],[4033,4120,"his head guard's duty."],[4404,4471,"So..."],[4763,4979,"I'll do your washing today."],[5100,5205,"But don't get used to it."],[6122,6222,"Hello, Freya."],[6235,6348,"Glad to see you're washing"],[6348,6552,"Sir Blackwater's dirty laundry."],[6560,6710,"You've no place here as anything"],[6710,6940,"other than a filthy servant."],[7044,7144,"I know what you did,"],[7194,7257,"Celeste."],[7278,7436,"You can't get rid of me that easy."],[7678,7807,"We'll see about that."]],"62":[[291,429,"I've received word from the North."],[454,671,"The King of Ravaria is planning attacks."],[692,804,"Empty words, My Lord."],[804,896,"He makes these threats"],[896,967,"again and again."],[1026,1121,"Yet they never act."],[1334,1384,"Father!"],[1405,1459,"Father!"],[1468,1601,"Our family heirloom ring"],[1601,1697,"has been stolen!"],[1710,1743,"What?"],[1785,1851,"That ring is worth more than"],[1851,1976,"half the gold in this kingdom."],[1976,2014,"How on earth"],[2014,2198,"did you lose such a priceless item?"],[2198,2318,"Father, it wasn't me."],[2565,2690,"You know I would never lose"],[2690,2844,"mother's precious jewels."],[2844,2998,"That's all I have left of her."],[3153,3278,"Freya was practically"],[3278,3449,"stomping down the hallway earlier"],[3449,3595,"and crashed into me!"],[3616,3741,"I bet she stole it then!"],[3787,3958,"Give it back to me, you rat-faced thief!"]],"63":[[16,196,"Give it back to me, you rat-faced thief!"],[479,567,"Alright, Your Grace,"],[567,713,"you know I would never do that."],[713,859,"Of course I didn't take your ring."],[871,946,"Then prove it."],[975,1121,"Turn out your pockets."],[1146,1234,"Freya is not your servant"],[1234,1317,"to command."],[1534,1593,"Do it, girl."],[1689,1822,"Prove your innocence."],[2285,2356,"Go ahead, Freya."],[2423,2519,"Show him Celeste is wrong."],[2648,2777,"Of course."]],"64":[[633,688,"See?"],[721,871,"I knew she was a thief."],[1180,1434,"How could you steal from my daughter?"],[1480,1693,"You have disgraced the crown,"],[1705,1864,"and your family."],[1885,2006,"And the penalty for that..."],[2127,2214,"is death."],[2298,2373,"What?"],[2544,2602,"Guards,"],[2656,2744,"take her."],[2744,2898,"You'll hang for what you've done."],[2898,3007,"No, no!"],[3023,3199,"No, I didn't do it, Tristan!"],[3215,3282,"No, Freya!"],[3299,3428,"Forget the servant girl."],[3470,3541,"Sir Blackwater,"],[3541,3645,"I need you here with me."],[4049,4220,"Why do I suddenly feel so faint?"],[4341,4383,"Ugh!"]],"65":[[575,734,"Please, I didn't do anything!"],[784,930,"Don't leave me here, please!"],[959,1017,"Please!"],[1710,1797,"Find her son,"],[1939,2031,"and bring him to me."],[3599,3707,"What are you doing?"],[3728,3816,"Leave him alone!"],[3858,3933,"No!"]],"66":[[104,150,"Freya?"],[287,375,"Freya, are you there?"],[446,508,"Hello,"],[508,633,"Sir Blackwater."],[859,988,"Relax."],[1001,1126,"I'll take you to her."],[1589,1639,"Freya!"],[1701,1751,"Freya!"],[1793,1851,"Tristan..."],[1893,1960,"Tristan."],[1981,2102,"I thought you weren't coming."],[2152,2227,"I thought you believed"],[2227,2298,"that I was a thief."],[2298,2435,"I thought you were gonna let me die."],[2460,2548,"I would never believe"],[2548,2690,"Princess Celeste's lies."],[2719,2806,"She drugged me."],[2932,2998,"And I passed out"],[2998,3136,"before I could stop the guards."],[3161,3311,"You cannot prove that."],[3361,3470,"Release her now!"],[3470,3586,"I have a better idea."],[3603,3732,"Now that your servant whore"],[3732,3832,"is taken care of,"],[3895,4024,"you will propose to me."],[4266,4425,"Not if you were the last person on earth."],[4496,4562,"Guards."],[4625,4704,"Bring him in."],[4946,4988,"Milo!"],[5226,5376,"Tell my father you'll marry me,"],[5409,5638,"or I will have your son killed."]],"67":[[25,91,"My son?"],[91,166,"How did you..."],[216,383,"Sir Blackwater is my papa?"],[1209,1334,"That's right, child."],[1393,1634,"Your papa left you all these years."],[1634,1839,"so he could run off to fight dragons."],[1901,1972,"And now"],[2002,2156,"he's gonna let you die."],[2273,2394,"How sad..."],[2402,2569,"Don't listen to a word she says."],[2602,2673,"Mama?"],[2752,2827,"I want Mama!"],[2894,3132,"I know baby, I'm right here, okay?"],[3620,3841,"Tristan, you have to marry Celeste."],[3924,4083,"You have to save our son."],[5038,5171,"I vow to save you too, my love."],[5843,5922,"I shall do it."],[6039,6143,"I'll announce our engagement"],[6143,6256,"to the king right now."]],"68":[[4,104,"I'll announce our engagement"],[104,212,"to the king right now."],[1113,1159,"Hey."],[1572,1755,"I'll die before I lose you again,"],[1789,1835,"Freya."],[2802,2902,"We must start planning"],[2902,3032,"the ceremony immediately."],[3040,3136,"Once we talk to father,"],[3148,3203,"I just want-"],[3203,3261,"Ah!"],[3499,3574,"You'll have Freya"],[3574,3678,"released immediately."],[3820,3966,"Or I'll kill you right now."]],"69":[[41,125,"You wouldn't."],[171,304,"I'm the Princess of Velantis."],[617,721,"You've threatened the life"],[825,992,"of my son and my love."],[1076,1242,"I have nothing left to live for."],[1255,1313,"Fine,"],[1334,1393,"fine."],[1443,1509,"I'll come clean."],[1572,1647,"No, I won't."],[1701,1935,"Freya will be executed by sunrise."],[1968,2118,"And her bastard son."],[2139,2181,"Uh..."],[2198,2281,"Help!"],[2590,2635,"Hey!"],[3153,3211,"I have a message"],[3211,3378,"from King Rathard of Ravaria."],[3440,3524,"More men are coming."],[3524,3695,"And you'll all be dead."],[4041,4216,"I need you to go fight off our enemies,"],[4216,4387,"before they reach the castle gates."],[4479,4658,"In exchange for your service,"],[4721,4833,"and for saving my life,"],[4975,5130,"I'll give you anything you desire."],[5176,5321,"I request but one thing, my king."],[5422,5513,"For the servant girl,"],[5551,5714,"Freya Swann's hand in marriage."]],"70":[[29,183,"But Father, she's a criminal."],[233,291,"Liar!"],[383,496,"Freya has not done the crimes"],[496,638,"that she's been accused of."],[821,934,"I request that you release"],[934,1021,"her and her son."],[1113,1184,"And allow me"],[1184,1322,"to take her hand in marriage."],[1372,1505,"Is this truly what you want?"],[1726,1822,"Then it shall be so."],[1906,2102,"But only if you return from battle."],[2152,2235,"If you die out there,"],[2235,2360,"then the agreement is off."],[2877,2961,"Thank you, My Lord."],[3611,3749,"I have not forgotten my vow."],[3912,4029,"If you hurt Freya at all,"],[4133,4300,"I will end your life as you know it."],[4917,5134,"Not if you die in battle."],[5467,5734,"You will kill Tristan on the battlefield"],[5734,5855,"and make it look like he died"],[5855,5976,"by an enemy's blade."],[6231,6435,"And if you speak even a word"],[6435,6531,"about this,"],[6602,6773,"you'll be dead next."]],"71":[[162,221,"Mama,"],[237,408,"is Princess Celeste telling the truth?"],[500,542,"Yes,"],[592,663,"my love."],[750,871,"Sir Blackwater"],[934,980,"is..."],[1188,1284,"Your papa."],[1593,1701,"I want to go home."],[2068,2152,"You will soon."],[2231,2331,"But the Knights of Ravaria"],[2331,2419,"are invading."],[2444,2519,"I need to fight them"],[2519,2619,"in exchange for your freedom."],[2761,2877,"You won't die, will you?"],[3119,3253,"Don't worry, Milo."],[3461,3611,"Your papa is a great knight."],[3707,3837,"She just called me his papa."]],"72":[[333,462,"Last time I sent you away,"],[600,754,"I told you that I never wanted you."],[950,1009,"This time,"],[1034,1092,"I would wait"],[1092,1197,"until the end of time"],[1230,1322,"to have you back."],[1568,1735,"I came back for you once, Freya."],[1947,2043,"And I'm gonna do it again."],[3678,3782,"It's been five days."],[3878,3962,"Where are you, Tristan?"],[4329,4366,"What?"],[4383,4462,"Hey, hey!"],[4487,4512,"Get..."],[4542,4575,"No!"],[4808,5005,"I have some bad news for you, Freya."],[5046,5109,"Your lover,"],[5109,5226,"Sir Blackwater..."],[5359,5409,"dead."]],"73":[[50,116,"Your lover,"],[116,233,"Sir Blackwater..."],[375,417,"dead."],[875,984,"Papa is dead?"],[1001,1130,"He died on the battlefield."],[1192,1259,"No!"]],"74":[[62,204,"He made a deal with my father."],[296,383,"If he lives,"],[421,517,"you're spared."],[575,638,"What?"],[638,729,"If he dies..."],[809,896,"you do too."],[917,963,"No!"],[1305,1380,"No, no!"],[1380,1463,"No, Milo!"],[1472,1664,"No, Milo! Milo!"],[1701,1830,"No, Milo!"],[1830,1885,"No..."],[1914,1989,"no!"],[2394,2510,"You have committed"],[2510,2669,"falsehoods against the Crown,"],[2706,2940,"stealing precious items"],[2940,3053,"from my daughter,"],[3053,3207,"Princess Celeste Lancaster,"],[3253,3332,"for which"],[3461,3607,"the punishment is death."],[3695,3732,"No!"],[3732,3903,"Don't kill my mommy!"],[3937,4079,"Quiet, you little brat."],[4129,4212,"You're next."],[4245,4462,"I, King Lancaster,"],[4487,4625,"the first of my name,"],[4637,4808,"do hereby sentence you"],[4863,4959,"to death."],[5050,5150,"Look away, my love."],[5313,5372,"It's all over."],[5426,5547,"I've lost everything."],[5634,5697,"My love,"],[5734,5801,"my son,"],[5880,5935,"my life."],[6076,6193,"Drop the axe!"],[6569,6623,"Stop!"]],"75":[[150,204,"Stop!"],[325,400,"Drop the axe."],[583,725,"Drop it or I kill the traitor"],[725,913,"who tried to kill me on the battlefield."],[992,1188,"Don't let him kill me, King Lancaster."],[1226,1322,"Wasn't my idea"],[1322,1451,"to murder Sir Blackwater."],[1480,1572,"It was hers!"],[1797,1872,"She paid me."],[2306,2402,"Is this true?"],[2560,2627,"You paid Ogo"],[2627,2840,"to murder the head of my guard?"],[2957,3019,"No."],[3111,3169,"I didn't."],[3244,3311,"Father,"],[3349,3511,"he was in love with this"],[3603,3849,"poor, disgusting whore"],[4033,4120,"and not me."],[4295,4458,"He was ruining everything."],[4533,4642,"Seize her!"],[4783,4863,"Daddy, no!"],[4892,4984,"You can't kill me."],[5050,5267,"I cannot kill my only daughter,"],[5309,5455,"but I can lock you away"],[5455,5543,"in the highest room"],[5543,5651,"of the tallest tower"],[5672,5772,"where you will rot away"],[5772,5885,"for the rest of your life."]],"76":[[16,75,"Actually,"],[116,221,"I have a better idea."],[262,421,"King Rathard of Ravaria"],[517,608,"offered a truce..."],[679,809,"under the condition that I find him"],[809,905,"a suitable bride."],[963,1084,"Congratulations, Celeste."],[1184,1292,"Your dream of getting engaged"],[1292,1426,"is gonna come true after all."],[2122,2252,"You married me off to him?"],[2331,2394,"But Father,"],[2431,2556,"I'm your only living heir."],[2602,2727,"Who will rule when you're gone?"],[2798,2973,"Surely not this arrogant ass"],[2973,3094,"and his servant whore."],[4525,4637,"I'm more than happy"],[4675,4854,"to let Sir Blackwater and Freya"],[4854,4946,"rule this kingdom."],[4971,5100,"They're kind and capable,"],[5159,5234,"unlike you,"],[5259,5347,"selfish"],[5376,5492,"evil child."],[5555,5764,"Your mother would be disgusted."],[6498,6556,"You"],[6606,6706,"will never"],[6773,6906,"talk down to me again."]],"77":[[1084,1134,"Now that"],[1151,1280,"she's been taken care of,"],[1280,1451,"I believe we had an agreement,"],[1451,1547,"Sir Blackwater."],[1651,1689,"I,"],[1718,1805,"King Lancaster,"],[1851,1985,"do hereby pardon you,"],[2056,2164,"Freya Swann."],[3094,3144,"Mama!"],[3207,3253,"Hi!"],[3499,3553,"You..."],[3682,3803,"You came back to us."],[3937,4070,"I knew you would."],[4216,4295,"Sir Blackwater,"],[4295,4396,"if you're my papa now,"],[4396,4446,"does that mean"],[4446,4567,"you and Mama will marry?"],[4575,4621,"Oh,"],[4654,4688,"my love,"],[4725,4771,"I don't know..."],[4771,4825,"Yes."],[5096,5167,"That is the agreement"],[5167,5255,"I made with the king."],[5405,5501,"For your release"],[5576,5705,"and for your hand in marriage."],[5968,6018,"Freya Swann,"],[6018,6156,"will you do me the beloved honor"],[6156,6260,"of becoming my wife?"]],"78":[[4,54,"Freya Swann,"],[54,204,"will you do me the beloved honor"],[204,296,"of becoming my wife?"],[362,408,"Yes."],[467,684,"Yes, I'd love to."],[900,1026,"How long have you had this?"],[1163,1284,"I've kept it since the day I left"],[1284,1372,"for knight camp."],[1480,1630,"The day you were going to propose."],[1780,1872,"Freya Swann,"],[2052,2189,"I've always loved you."],[2335,2406,"For now"],[2502,2594,"and forever."],[2756,2890,"I love you, Tristan."],[4366,4529,"It is with great joy"],[4571,4825,"that I join the heroic Sir Blackwater"],[4875,5030,"with his love, Freya Swann"],[5030,5176,"in matrimony today."],[5205,5309,"If anyone"],[5309,5442,"has any cause"],[5442,5643,"to refuse the forming of this union,"],[5655,5747,"you may speak now"],[5797,5968,"or forever hold your peace."],[6072,6164,"I object!"],[6393,6443,"Mother?"]],"79":[[4,95,"I object!"],[316,375,"Mother?"],[625,725,"Mother, what are you doing here?"],[725,921,"I thought you retired to the outer plains?"],[959,1317,"I couldn't miss my only son's wedding."],[1747,1856,"Is the child yours?"],[1922,2002,"I thought"],[2022,2152,"I'd avoided that"],[2152,2314,"when I told Freya- - Told her to what?"],[2840,2936,"Five years ago,"],[3023,3194,"I forced her..."],[3340,3436,"to break your heart"],[3520,3716,"and tell you to join the Knights Order."],[3774,3891,"If she didn't,"],[3962,4099,"I threatened to kill her."],[4099,4183,"Are you serious, Mother?"],[4204,4308,"I wouldn't have."],[4341,4416,"Tristan,"],[4487,4567,"believe me,"],[4633,4779,"I'm not that evil."],[4796,4884,"So you're here to what?"],[4884,4975,"Ruin my marriage?"],[5059,5209,"Destroy our happiness"],[5209,5501,"again after all that we've been through."],[5509,5580,"No."],[5647,5935,"I came to apologize."],[6051,6181,"To both of you."],[6389,6485,"Freya, how come you didn't tell me"],[6485,6594,"that she did this?"],[6639,6698,"Huh?"],[6748,6840,"Why'd you let me believe that"],[6840,6936,"you never loved me?"]],"80":[[25,166,"I could've told you."],[271,400,"I was scared,"],[429,517,"Tristan."],[817,875,"And..."],[1009,1209,"I think a part of me, deep down,"],[1334,1463,"knew that she was right."],[1705,1856,"I mean, do I wish"],[1889,2052,"Milo and I hadn't lost"],[2052,2152,"out on five years with you?"],[2152,2260,"Absolutely, I do."],[2473,2581,"But I do think"],[2677,2861,"we needed that time apart to grow."],[2861,3065,"I mean, look at who you've become."],[3249,3370,"And find each other again"],[3370,3474,"when time is right."],[3666,3812,"I don't agree with what you did."],[3991,4099,"But I do forgive you."],[4233,4433,"I thank you for that, Freya."],[4483,4612,"I don't expect"],[4637,4817,"the same grace from you, son."],[4888,5088,"But I hope you can someday."],[5163,5392,"I'd like to get to know my grandson."]],"81":[[4,237,"I'd like to get to know my grandson"],[296,437,"when the time is right."],[1764,1835,"By the power"],[1872,1960,"vested in me."],[1997,2131,"By the Realm of Velantis,"],[2131,2243,"I, King Lancaster,"],[2243,2373,"the first of my name,"],[2389,2510,"do declare you"],[2556,2706,"husband and wife."],[4037,4158,"Come here."]],"82":[[233,408,"Let all present bear witness"],[408,542,"to the Coronation Ceremony"],[542,725,"of the Kingdom of Velantis."],[771,1021,"Now we, the consort of King Lancaster,"],[1021,1263,"crown Tristan, and Freya Blackwater,"],[1263,1559,"the new King and Queen of Velantis."],[3269,3420,"And a special gift for you,"],[3503,3632,"the Prince of Velantis."],[4024,4141,"Mama, look!"],[4141,4250,"I'm just like Papa!"],[4433,4504,"You are."],[4579,4742,"I'm so proud to be his father."],[4767,4892,"He's lucky to have you."],[5071,5150,"We both are."],[5196,5367,"I love you, King Tristan."],[5409,5584,"And I love you, Queen Freya."]]}