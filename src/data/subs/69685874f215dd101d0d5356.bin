{"1":[[23,173,"The results came in."],[173,427,"I'm sorry, we don't have better news."],[463,807,"Angelica, it's stage four."],[837,1034,"Without chemo and aggressive meds,"],[1054,1314,"the cancer is going to spread rapidly."],[1334,1514,"You have maybe three months."],[1544,1705,"You need to tell your family."],[1735,1801,"Family?"],[1971,2035,"No need."],[2112,2195,"My brother's hated me"],[2195,2335,"for as long as I can remember."],[2412,2572,"He once said he wished I was dead."],[2665,2809,"Well, I guess he got what he wanted."],[3313,3443,"Where the hell are you?"],[3480,3550,"It's Dad's birthday."],[3550,3650,"Get your ass home now!"],[4107,4237,"I'm dying, Chris."],[4384,4524,"I guess that'll make your day."],[4768,4891,"Happy birthday, Dad."],[4941,5018,"Thank you."],[5061,5195,"And this one's from me."],[5238,5345,"I baked it myself."],[5442,5632,"Madison got Dad the same cake?"],[5632,5709,"Uncle Martin,"],[5709,5815,"thank you for taking me in"],[5815,5919,"five years ago."],[5972,6189,"For giving me a real family,"],[6206,6322,"after I lost mine."],[6322,6586,"You kids, you've really grown up."],[6596,6776,"If your mom were still here,"],[6866,6986,"she'd be so proud of you."],[7243,7337,"Sorry, I'm late."],[7487,7654,"Dad, I got you a birthday cake too."],[7674,7717,"I'm full."],[7827,8001,"I need to get back to the hospital."],[8171,8231,"Dad."],[8762,8825,"Seriously?"],[8888,8982,"You've got the same exact"],[8982,9055,"cake as Maddie?"],[10407,10540,"Hey, it's because of you!"],[10593,10754,"You're always ruining everything!"],[10854,11017,"Was killing Mom not enough?"],[11114,11191,"If it weren't for you,"],[11191,11257,"she'd still be here,"],[11257,11354,"and we'd be a family,"],[11354,11461,"and Dad wouldn't have"],[11461,11554,"walked out on us!"],[11651,11755,"Now, why wasn't it you"],[11755,11895,"who died 16 years ago?"],[12048,12088,"Mm-mm."],[12088,12185,"Mom should've lived."],[12352,12415,"Not you."]],"2":[[106,210,"From the moment I was born,"],[256,413,"Dad lost the woman he loved most,"],[490,600,"and Christopher lost his mom."],[694,840,"That hate's been there since day one."],[1204,1408,"Please, save my baby!"],[1408,1554,"You stay with us, Stella."],[1641,1751,"Ah!"],[2145,2255,"It's a girl."],[2809,2922,"She's hemorrhaging."],[2922,3026,"We're losing her."],[3106,3173,"Let's move."],[3673,3763,"She's healthy."],[3853,3940,"She's a little girl."],[4057,4140,"But your wife..."],[4280,4411,"Your wife didn't make it."],[4481,4684,"And I am so sorry."],[5278,5372,"No!"],[5892,6066,"Shut up!"],[6152,6252,"Dad never looked at me,"],[6309,6436,"pretending I didn't exist."],[6516,6599,"The only person who"],[6599,6693,"ever showed me kindness"],[6693,6783,"was my brother."],[7270,7303,"Right."],[7320,7447,"Daddy, it's hurt. - Um, I'm gonna get"],[7447,7530,"that in a second here."],[8274,8345,"Eat this."],[8371,8458,"It's sweet."],[8745,8838,"Don't cry."],[9376,9609,"You're the best big brother ever."],[9783,9903,"But that kindness"],[9903,10100,"left when Madison came in the picture."],[10236,10306,"Come on, Chris."],[10357,10463,"Angie probably just"],[10463,10583,"got caught up somewhere,"],[10583,10700,"and forgot about the party."],[10780,10904,"Let's just go, okay?"],[11027,11081,"Move!"]],"3":[[56,120,"What the fuck-"],[120,223,"Uh, Christopher!"],[260,460,"You were going to take me to the game."],[460,570,"It's starting soon."],[657,727,"Let's go."],[774,907,"Clean this all up, okay?"],[927,1021,"Try to be useful."],[1037,1094,"For once."],[1324,1451,"Chris wasn't always like this."],[1531,1661,"He used to care about me."],[1735,1878,"Treated me like a real sister."],[1938,2055,"Take it all out!"],[2148,2415,"I don't wanna see this stuff ever again!"],[3116,3276,"I hid Mom's necklace."],[3333,3543,"It's the last piece we have from her."],[3613,3807,"Don't worry, I'll protect you."],[4044,4167,"But after Madison moved in,"],[4250,4341,"everything changed."],[4784,4881,"Maddie just moved in."],[4898,5041,"She's gonna love this pink towel."],[5995,6132,"Hey, that's my mom's stuff!"],[6189,6302,"That's my mom's necklace!"],[6302,6386,"Give it back!"],[6946,7037,"No!"],[7080,7253,"Oops, guess it's broken now."],[7327,7527,"Here, souvenir."],[7540,7640,"What's going on in here?"],[8108,8194,"What the hell happened?"],[8211,8391,"Angie broke it, Chris."],[8425,8578,"She broke your mom's necklace."],[8578,8755,"That was the last thing Mom left us!"],[8755,8868,"And you just broke it!"],[9135,9175,"No."],[9192,9265,"Oh, no, no, no, no!"],[9265,9339,"It wasn't me!"],[9339,9509,"What the hell is your problem?"],[9509,9649,"Mom died because of you!"],[9693,9796,"And now this!"],[9839,9943,"I tried, Angie."],[9943,10086,"I really tried to be nice to you."],[10086,10306,"But clearly, you just don't deserve it!"],[10570,10643,"That's when I knew."],[10730,10804,"He'd always blamed me"],[10804,10897,"for taking away the person"],[10897,10987,"he loved most."],[11404,11451,"Mom,"],[11531,11725,"why didn't you take me with you?"],[12018,12095,"It's okay."],[12145,12275,"We'll see each other soon."]],"4":[[874,1021,"It's a beautiful spot."],[1077,1131,"Peaceful."],[1221,1348,"Are you buying for your family?"],[1478,1571,"No, it's for me."],[1651,1795,"I'm sorry, sweetheart."],[1921,2118,"But you're still underage."],[2178,2262,"You'll need a parent"],[2262,2392,"or guardian's signature."],[2672,2739,"It's okay."],[2829,2906,"They'll sign it."],[3513,3643,"Dad, can you sign this?"],[3957,4024,"Next time,"],[4134,4247,"just ask your brother, okay?"],[4247,4337,"I don't have time for this."],[4624,4684,"Don't worry, Dad."],[4758,4808,"Soon."],[4851,4984,"You'll never have to see me again."],[5058,5148,"You sure we don't have to"],[5148,5261,"wait for Angelica?"],[5595,5692,"She's not getting in my car."],[5692,5789,"She'll just mess it up."],[6062,6109,"What?"],[6132,6202,"Okay."],[6259,6419,"You know, you're my only sister, right?"],[6499,6543,"Right?"],[8101,8224,"Maybe I went too far."],[8271,8375,"She's still my sister."],[8675,8782,"Oh, wait."],[8782,8982,"Isn't your mom's death anniversary"],[8982,9069,"coming up soon?"],[9289,9335,"Yeah."],[9452,9506,"Right."],[9646,9733,"How could I forget?"],[9773,9906,"She's the reason Mom's gone."],[9919,10066,"She doesn't deserve my pity."],[10610,10757,"Chris knows how to be a good brother."],[10834,10910,"Just not to me."]],"5":[[13,96,"There's only one"],[96,253,"Ivy League summer program spot."],[270,407,"How the hell did Madison get in?"],[420,473,"Right?"],[523,653,"She literally failed like"],[720,864,"three classes last semester."],[944,984,"Shh."],[984,1071,"Angelica's here."],[1454,1584,"I heard Christopher"],[1584,1748,"gave Madison Angelica's a spot."],[1808,1898,"Poor Angelica."],[1938,1985,"Yeah."],[2022,2145,"Everyone knows he treats Madison"],[2145,2292,"like she's some princess."],[2389,2605,"I fought so hard for this spot."],[2649,2816,"Chris just gave it away."],[2929,3026,"You think tearing that down"],[3026,3133,"is gonna change anything?"],[3133,3249,"So it's true?"],[3313,3426,"You gave her my spot?"],[3490,3690,"Oh, Maddie's my sister."],[3690,3833,"She deserves the best,"],[3833,3980,"and I'd do anything for her."],[4090,4154,"What?"],[4180,4347,"Did you have, did you actually think"],[4347,4551,"a freak like you stood a chance?"],[4674,4741,"Angie."],[4811,5055,"Uh, Angie, I didn't mean to take it."],[5055,5191,"If, if it means that much to you,"],[5191,5301,"I can give it back."],[5318,5465,"Cut the act, Madison."],[5518,5618,"I don't want your pity."],[5772,5825,"And no,"],[5975,6076,"I don't care anymore."],[6256,6419,"She's not fighting back,"],[6436,6509,"but she's wanted that"],[6509,6656,"summer program her whole life."],[7083,7290,"Angelica, are you sure?"],[7290,7450,"Yes, I'm sure."],[7577,7691,"I'm dropping out of school."]],"6":[[236,330,"Sorry, Mr. Daniels."],[330,413,"I just need a,"],[460,613,"need a word with Angelica."],[950,1017,"Seriously, Angie?"],[1017,1131,"Dropping out of school"],[1131,1284,"over a summer program?"],[1327,1381,"I mean, what,"],[1381,1501,"you think throwing this tantrum"],[1501,1634,"is gonna make me give that spot back?"],[1664,1721,"Huh?"],[1781,1881,"You fucking wish."],[1881,2028,"Isn't that what you've always wanted?"],[2065,2142,"For me to disappear,"],[2142,2278,"you don't have to see me anymore?"],[2382,2472,"I, that's-"],[2485,2552,"Angie,"],[2659,2839,"I'm so, so sorry."],[2869,3026,"I never should have told Chris"],[3026,3156,"how much the Ivy meant to me."],[3196,3266,"If I hadn't,"],[3266,3453,"he never would give me that spot."],[3636,3723,"Angie,"],[3723,3867,"it's all my fault."],[3867,4140,"Just please don't be mad at him, okay?"],[4197,4290,"Nice try!"],[4337,4471,"I'm not falling for your act!"],[4471,4604,"Angelica, what the hell"],[4604,4684,"is wrong with you?"],[4684,4801,"You were the one that wanted her"],[4801,4924,"to move into the house."],[4958,5095,"And now you're turning on her."],[5118,5291,"God, you are so unbelievable."],[5291,5472,"How, how did I end up with a sister"],[5472,5558,"like you?"],[5572,5769,"Yeah, I'm the mess."],[5875,5972,"Whatever I do,"],[6016,6209,"wherever I go, even if I die,"],[6229,6383,"it's none of your business."],[6499,6569,"Ah!"],[7207,7267,"Angie."],[7477,7604,"Why does this feel so wrong?"],[7657,7771,"I'm supposed to hate her."],[7771,7937,"Hey, Chris, it's okay."],[8014,8164,"I, I just don't want you two fighting"],[8164,8234,"because of me."],[8271,8408,"I'll talk to her, okay?"],[8661,8758,"Why wasn't it you"],[8758,8885,"16 years ago?"],[8905,9015,"Mom should've lived."],[9082,9132,"What?"],[9175,9352,"You actually think a freak like you"],[9352,9436,"stood a chance?"],[9502,9672,"God, you are so unbelievable."],[9672,9863,"How, how did I end up with a sister"],[9863,9933,"like you?"],[10013,10163,"I used to think Chris was the only one"],[10163,10303,"who actually cared about me."],[10336,10450,"But Madison made me realize"],[10450,10517,"that deep down,"],[10580,10680,"he wishes I was dead."],[11581,11664,"There you are."]],"7":[[363,403,"Stop!"],[437,527,"Stop! Stop!"],[527,607,"Let me go!"],[657,730,"Somebody help!"],[730,834,"Stop fighting back."],[887,1034,"No one's coming to save you."],[1424,1481,"Madison,"],[1481,1648,"I let you move into our house,"],[1675,1781,"I treated you like family,"],[1781,1908,"like a sister."],[1965,2065,"Why are you doing this?"],[2065,2122,"Why?"],[2142,2322,"Because I don't need your fake pity."],[2369,2555,"I hate you."],[2592,2692,"You should've died"],[2692,2826,"with your pathetic mom!"],[2889,3073,"Then Chris, he would be mine."],[3113,3249,"All mine."],[3306,3463,"He's all I have left."],[3490,3586,"And you"],[3596,3753,"keep stealing him from me!"],[3803,3957,"You fucking bitch!"],[4741,4818,"Shit."],[5478,5548,"Hold her down."],[5919,5989,"What's this?"],[6009,6042,"No."],[6079,6252,"No, no, no, no, Madison, please!"],[6282,6436,"Please give it back."],[6646,6713,"I bet nobody"],[6713,6810,"remembers my birthday"],[6810,6896,"this year either."],[7714,7767,"Take it."],[7781,7877,"I bought two."],[7991,8078,"It was the first gift"],[8078,8198,"Chris ever gave me."],[8234,8341,"I'm glad he still cared."],[8498,8702,"No, Madison, please!"],[8755,8848,"Please give it back!"],[8848,9062,"That's the only gift Chris ever gave me."],[9179,9269,"You wish."],[9486,9582,"No!"],[9602,9662,"No!"],[9679,9723,"No."],[10200,10410,"Why can't you just leave me alone?"],[10667,10764,"Are you crazy?"],[10787,10900,"Get away from me."],[10947,11104,"Go to hell, bitch."],[12215,12312,"Ah."],[12389,12532,"Ah."],[13743,13820,"Angelica!"]],"8":[[116,190,"Angelica."],[226,276,"Shit."],[380,553,"Quick, wash off the blood."],[1301,1348,"Angelica."],[1404,1494,"Hey, what happened?"],[1778,1828,"I..."],[1911,1961,"I..."],[3036,3143,"Madison, what happened?"],[3156,3253,"It was Angelica!"],[3293,3416,"She just lost it out of nowhere,"],[3416,3546,"and started choking Maddie."],[3546,3626,"Look at her neck!"],[3626,3780,"If we hadn't stopped Angelica,"],[3780,3913,"Maddie would have been dead."],[3957,4070,"She's only acting all innocent"],[4070,4157,"because you're here."],[4294,4454,"Angelica, have you lost your mind?"],[4728,4858,"Alright, oh, wow."],[5071,5231,"Chris, Chris, please."],[5231,5342,"Please don't go."],[5342,5502,"Don't leave me alone, Chris."],[5618,5689,"Drama queen."],[6332,6473,"Can Maddie stay with us, please?"],[6526,6629,"She just lost her parents."],[6629,6766,"I think she needs someone right now."],[6853,7023,"Plus it would be nice to have a sister."],[7100,7203,"Look, do whatever you want."],[7203,7300,"Taking care of you"],[7300,7407,"is already a headache."],[7427,7564,"And I'm not looking after her too."],[7731,7784,"Chris,"],[7847,7961,"it hurts so much."],[8018,8104,"Can you just turn around"],[8104,8221,"and look at me for once?"]],"9":[[390,470,"You're awake."],[590,697,"Your classmates got you here"],[697,794,"just in time."],[907,1031,"Angelica, we"],[1091,1281,"noticed signs of self harm."],[1461,1628,"You can't keep doing this."],[1668,1851,"We'll have to inform your family."],[1975,2052,"They won't care."],[2148,2315,"Angelica, I'm sure your family"],[2315,2409,"cares about you."],[2505,2665,"Your cancer is getting worse."],[2812,2982,"You don't have much time left."],[2982,3113,"You'll need your family with you,"],[3113,3229,"to take care of you,"],[3229,3400,"and remind you that you're loved."],[3423,3636,"That sort of support really helps a lot."],[3777,3893,"Thank you, doctor."],[4040,4144,"But I don't even know"],[4144,4260,"if I still have a family."],[4277,4461,"I know your father, Dr. Ray."],[4484,4564,"He's a new surgeon"],[4564,4684,"who just transferred here."],[4734,4831,"Let me give him a call."],[5412,5558,"Hi, Dr. Ray?"],[5665,5775,"This is Dr. Smith,"],[5775,5945,"your daughter Angelica's physician."],[5999,6092,"She's just been"],[6092,6202,"admitted to our hospital,"],[6202,6336,"and I think you should get here"],[6336,6529,"as soon as you can and be with her."],[6529,6669,"I don't care where she's being treated"],[6669,6776,"or what problem she's got."],[6776,6863,"I'll pay the bills."],[6910,7143,"But I'm not coming to see some brat"],[7143,7350,"who turned on her own cousin."],[7350,7484,"I'd rather tend to a dead body"],[7484,7580,"than go see her."],[7834,7877,"See?"],[7977,8051,"I told you."],[9753,9856,"I'll be fine, Chris."],[9856,10050,"You should go check on Angelica."],[10050,10190,"I heard she's here too."],[10190,10270,"Yeah, who cares?"],[10270,10397,"She's probably faking it."],[10450,10560,"And Madison,"],[10583,10777,"you are too nice."],[10777,10874,"That is why she keeps"],[10874,10944,"walking all over you."],[11024,11064,"Okay?"],[13039,13119,"What a loser."],[13246,13306,"Leave her alone."],[13306,13416,"Dude, chill."],[13416,13493,"It was a joke."],[13546,13670,"I don't care about her anyway."],[13693,13767,"I said go."],[13853,13927,"Okay, go!"],[14617,14768,"I should've faced it sooner."],[14804,14921,"I should've faced it sooner"],[14921,15038,"when he started acting weird."],[15141,15255,"You would've left me too,"],[15331,15428,"just like everyone else."]],"10":[[2609,2706,"No way, kid."],[2752,2879,"We don't ink minors"],[2879,3039,"unless your parents sign off."],[3116,3233,"My mom passed away."],[3960,4097,"I just wanna cover them up."],[4124,4197,"Look,"],[4227,4394,"I don't know what you've been through."],[4434,4504,"But if you promise to"],[4504,4627,"stop hurting yourself,"],[4794,4874,"I'll do it."],[6219,6353,"Ugh, how long are you gonna"],[6353,6469,"hog the bathroom for?"],[6469,6579,"Angie, come on."],[6940,6983,"Huh?"],[7861,7897,"What?"],[7897,7957,"What was..."],[8061,8148,"Is that a tattoo?"],[8211,8268,"Are you serious?"],[8268,8361,"When did you even get that?"],[8391,8508,"It's none of your business."],[8565,8651,"None of my business?"],[8651,8742,"You dropped out of school,"],[8742,8865,"you messed with Maddie,"],[8905,8988,"and now a tattoo?"],[8988,9102,"I mean, what's next?"],[9165,9319,"I mean, drugs?"],[9352,9502,"A freaking hookup party?"],[9836,9926,"Maddie was right."],[9926,9983,"You're gonna hang out"],[9983,10100,"with that punk Raven?"],[10100,10180,"Let go of me!"],[10196,10336,"Not until I see what else you're hiding."]],"11":[[226,283,"Wait."],[460,550,"Don't touch me!"],[667,744,"Oh my God."],[760,934,"Angie, did you just hit your brother?"],[1014,1077,"Are you okay?"],[1104,1207,"Do you need an ice pack?"],[1227,1327,"No, show me, show me"],[1327,1398,"your arms. - Stop."],[1398,1464,"No, you're not leaving"],[1464,1561,"until you wash - Stop!"],[1578,1708,"that crap off! - Wait, wait."],[1725,1791,"Let's, let's get you"],[1791,1905,"an ice pack first, okay?"],[1961,2078,"I, I can't believe"],[2078,2205,"that she turned out like this."],[2205,2282,"Not always."],[2435,2509,"Thank you, Maddie."],[2509,2722,"I just wish Angie could learn"],[2722,2822,"a thing or two from you."],[3566,3707,"Angelica, the cancer's"],[3707,3810,"spreading fast."],[3810,3967,"If you won't follow treatment,"],[4000,4170,"and you won't make it past a month."],[4928,5091,"Nobody wants me alive anyway."]],"12":[[1631,1738,"Thanks, Fiona."],[1838,1928,"You've been like a mom to me"],[1928,2012,"since I was little."],[2078,2125,"Aw."],[2188,2339,"Angie, you're such a good girl."],[2379,2549,"It's been a joy taking care of you."],[2652,2819,"Oh, check out the living room."],[2879,3089,"Your dad got you a beautiful dress."],[3283,3463,"Dad, he bought me a gift?"],[3463,3570,"Mm-hmm."],[3660,3793,"See, I told you,"],[3837,4017,"one day your dad and your brother"],[4017,4074,"will realize"],[4074,4214,"how much you care for them."],[4341,4394,"Go on."],[5382,5488,"I knew that dress"],[5488,5622,"would look perfect on you, Maddie."],[5762,5899,"And that suit"],[5899,6026,"looks amazing on you, son."],[6102,6206,"Thank you, Uncle Martin."],[6259,6493,"I've had my eye on this for ages."],[6713,6760,"Dad?"],[6973,7023,"Angelica,"],[7080,7177,"I didn't get you anything."],[7227,7323,"I figured you wouldn't wanna"],[7323,7434,"go to your brother's prom."],[7550,7667,"What was I expecting?"],[7721,7804,"There's no way Dad would"],[7804,7934,"actually get me anything."],[8191,8281,"Mr. Ray,"],[8401,8511,"Angelica actually-"],[8511,8762,"Angie, don't be mad at Chris."],[8822,9022,"He's going away to college soon and,"],[9022,9142,"you won't see him as often."],[9149,9349,"So why don't you"],[9349,9492,"come to prom with us?"],[9612,9686,"Chris,"],[9746,9899,"you want Angelica to come, right?"],[10006,10093,"I don't care."],[10233,10283,"Sure."],[10397,10453,"I'll go."],[10570,10737,"I don't have much time left, Chris."],[10830,10927,"This might be the last time"],[10927,11044,"we ever see each other."]],"13":[[1671,1901,"Oh, look who decided to show up, Angelica."],[1961,2128,"Too bad Christopher already has"],[2128,2238,"a dance partner."],[2275,2349,"Me."],[2409,2525,"Guess you'll just"],[2525,2702,"have to find someone else."],[2762,2859,"Leave me alone."],[3643,3720,"Hey, Tommy."],[3790,3873,"Angie's on the stage,"],[3873,4004,"if you wanna say hi."],[4317,4481,"Not a bad idea."],[5742,5885,"Get your hands off me, creep!"],[5919,6032,"Come on."],[6032,6142,"Everyone knows you're always"],[6142,6286,"ready to have sex."],[6406,6503,"What did you just say?"],[6579,6750,"Maddie told me all about you."],[6820,6960,"I could fuck you right here,"],[6960,7133,"and nobody would even care."],[7333,7444,"Get away from me!"],[8048,8104,"No!"],[8174,8234,"No!"],[8521,8625,"Playing hard to get?"],[8695,8765,"Fine."],[8862,8938,"Stay back!"],[8952,8988,"I mean it!"],[8988,9089,"Get away from me!"],[9089,9222,"You crazy bitch!"],[10103,10266,"Ah, Angie, stop!"],[10283,10430,"Stop, don't hurt me, please."],[10430,10553,"Angelica, stop!"]],"14":[[473,560,"Maddie, are you okay?"],[560,660,"What the hell happened?"],[660,804,"Dude, I have no clue."],[804,857,"I mean,"],[857,927,"she just flipped out and"],[927,1037,"pulled out a knife out of nowhere."],[1037,1217,"That bitch is crazy!"],[1451,1611,"It hurts so bad."],[1611,1745,"I, I didn't think Angie"],[1745,1911,"hated me that much but,"],[1911,2008,"for, for a second,"],[2008,2152,"I thought she was gonna kill me."],[2212,2369,"Angelica, what is wrong with you?"],[2392,2522,"Now look at what you did."],[2522,2649,"Why would you stab her?"],[2692,2832,"Apologize to Maddie now!"],[2899,3113,"No, just, just stay,"],[3203,3303,"stay away from me."],[3416,3576,"Okay, you're still not apologizing."],[3576,3623,"Fine."],[3977,4127,"Let me make myself more clear."],[4848,5001,"Apologize to Maddie now."],[5522,5575,"Ugh."],[5648,5782,"It's just a drink."],[5782,5902,"Seriously, you're,"],[5902,5985,"you're acting like you're"],[5985,6069,"dying or something."],[6302,6393,"I am."],[6506,6553,"What?"],[6810,6870,"What?"],[7484,7587,"I'm sick, Chris."],[7751,7897,"Your little sister is dying."],[8008,8154,"You must be so happy now."],[8278,8405,"Wait, what?"],[8441,8578,"Dude, that's your little sister?"],[8812,8878,"Shut up."],[8878,8918,"Hey, no, - No!"],[8918,8978,"you're not going - No!"],[8978,9109,"anywhere until you apologize."]],"15":[[1047,1097,"Angelica,"],[1097,1251,"what happened to your hair?"],[1281,1368,"Have you been wearing a wig"],[1368,1451,"this whole time?"],[1451,1554,"A wig?"],[1554,1675,"That's freaky."],[1831,1881,"Angelica,"],[1881,2005,"what, what do you mean you're dying?"],[2005,2132,"What do you mean you're dying?"],[2132,2178,"Chris!"],[2178,2268,"Angelica! - Chris, wait!"],[2312,2369,"Chris!"],[2412,2615,"Chris, it is your last prom night."],[2615,2742,"You can't just dip."],[2742,2869,"But, but Angie-"],[2896,3039,"Come on, you know her."],[3083,3256,"She's just overreacting."],[3319,3470,"The whole shaving her head,"],[3470,3570,"saying I'm dying."],[3570,3760,"She's doing it to embarrass you."],[3900,4057,"Remember Raven?"],[4057,4177,"That weird goth girl"],[4177,4304,"that Angelica's friends with?"],[4394,4471,"Hey, look."],[5452,5615,"She's really into this sort of thing."],[5615,5789,"The shaving your head."],[5789,5965,"Angelica's probably just copying her,"],[5965,6099,"saying she's dying."],[6159,6282,"Just to get your attention."],[6446,6623,"Chris, don't let her ruin your night."],[6673,6770,"I mean, come on."],[6770,6940,"Let's just go dance."],[7240,7354,"Don't worry, Christopher."],[7430,7570,"I'll never bother you again."],[7660,7817,"No, no no no, Angie."],[7857,7954,"Chris!"],[8898,8995,"Goodbye,"],[9155,9346,"to this cold, brutal world."],[9659,9756,"Angelica!"],[10276,10370,"Angelica!"]],"16":[[256,387,"Angie, Angie, Angie!"],[387,453,"Hey, hey,"],[453,553,"can you please stay with me?"],[553,710,"I, I'm so sorry, I'm so-"],[710,834,"Please, please. - Come on!"],[834,964,"Wait here, wait here!"],[1014,1197,"Chris, she acted impulsively."],[1264,1368,"This isn't your fault."],[1368,1481,"You two were just arguing."],[1481,1581,"She will be fine. - No."],[1581,1751,"No, I shouldn't have said those things."],[1768,1921,"I just didn't know she would actually-"],[1921,2015,"If you blame yourself,"],[2015,2158,"you're falling right into her trap."],[2425,2522,"What do you mean?"],[2826,3083,"I found this in her room."],[3249,3313,"Read it."],[3646,3800,"Chris, if I die, will you regret it?"],[3867,3960,"Ah, so all this"],[3960,4070,"was just to get back at me?"],[4127,4210,"She didn't even really"],[4210,4300,"want to kill herself."],[4300,4424,"I, I told you she was only doing it"],[4424,4524,"to get your attention."],[4581,4728,"Then why would she do this?"],[4824,4948,"Every time."]],"17":[[1111,1264,"Sorry, Raven."],[1264,1424,"I can't do this anymore."],[1614,1705,"What do you mean?"],[2158,2218,"Angie?"],[2262,2349,"Answer me."],[3249,3309,"Something's wrong."],[3309,3390,"I have to find her."],[4080,4187,"Chris, Uncle Martin."],[4237,4337,"The surgery went well."],[4337,4424,"She's stable now."],[4958,5055,"I'm still alive."],[5148,5251,"Dad and Chris are here."],[5372,5425,"Are they actually"],[5425,5525,"worried about me now?"],[5602,5668,"Chris."],[6049,6132,"Dad."],[6396,6543,"Don't call me Dad!"],[6576,6683,"After what you did,"],[6683,6860,"you're not my daughter anymore!"],[6900,7013,"Wanna kill yourself?"],[7030,7093,"Fine!"],[7147,7340,"Go give your life back to your mother!"],[7784,7854,"Chris."],[7924,8048,"Don't give me that pathetic look."],[8048,8224,"It's, it's disgusting."],[8274,8368,"It really is."],[8368,8498,"So you're not guilt-tripping me,"],[8498,8705,"Angelica, because I don't fucking care."],[8872,8928,"Alright, so you can do"],[8928,8992,"whatever you want."],[8992,9122,"Just stop dragging me into it."],[9239,9302,"Now, I see."],[9469,9629,"I don't have a family anymore."]],"18":[[106,170,"Hm?"],[487,597,"What did you just say?"],[857,930,"You?"],[1064,1134,"Hey!"],[1244,1408,"What are you doing?"],[1408,1638,"How dare you hit my patient!"],[1638,1721,"Back off!"],[1788,1855,"Mm-hmm."],[1855,2012,"Well, saving her is a waste of time."],[2032,2078,"Okay?"],[2078,2212,"Excuse me?"],[2255,2322,"What kind of brother"],[2322,2422,"says something like that?"],[2502,2612,"I wish I wasn't."],[2645,2729,"No wonder she"],[2729,2839,"keeps hurting herself."],[3033,3149,"What are you talking about?"],[3239,3329,"You don't know?"],[3503,3590,"Angelica."],[3760,3830,"Show him."],[5375,5522,"Angie, if you really wanted"],[5522,5655,"Christopher's attention,"],[5655,5775,"you could have just told him."],[5812,5972,"Why would you do that to yourself?"],[6012,6129,"Does making him feel sorry"],[6129,6269,"really make you happy?"],[6373,6459,"If you think hurting yourself"],[6459,6563,"is gonna mess with me,"],[6696,6860,"just please, don't flatter yourself."],[6910,6946,"Mm?"],[7047,7110,"Hurt you?"],[7267,7467,"You didn't even care when I almost died!"],[7534,7701,"Like you'd care about these scars!"],[8775,8832,"Chris,"],[8975,9085,"I really thought you were the one"],[9085,9235,"person I could trust."]],"19":[[37,125,"So I'm cruel?"],[225,333,"I'm sorry, I'm sorry."],[362,462,"I'm cruel?"],[542,617,"Newsflash,"],[617,709,"you are the one"],[709,850,"doing this to yourself!"],[850,1021,"The tattoos, cutting your wrists,"],[1021,1109,"shaving your head,"],[1109,1209,"the bathtub stunt."],[1209,1347,"All just to get back at me,"],[1363,1422,"won't you..."],[1526,1643,"You fucking embarrassed me"],[1643,1755,"in front of everyone."],[1847,1939,"And now if you think"],[1939,2085,"this is gonna make me feel bad,"],[2085,2227,"or, or fucking care about you,"],[2227,2310,"you're wrong."],[2327,2427,"Because I don't care."],[2427,2565,"I don't fucking care!"],[2865,2948,"There it is."],[3090,3186,"You finally said it."],[3361,3528,"You've hated me this whole time."],[3616,3732,"Just because Mom died"],[3732,3849,"giving birth to me."],[3912,4024,"Yeah, I hated you!"],[4233,4346,"And it should've been you."],[5213,5347,"Fine, if you really wanna come home,"],[5347,5484,"stop hanging out with Raven Blade."],[5484,5584,"She is a mess."],[5584,5722,"And you keep on following her,"],[5755,5885,"you're gonna turn into one too."],[6010,6147,"No, no."],[6247,6343,"She's not what you think."],[6669,6831,"You just don't learn, do you?"],[6948,7011,"You can say whatever"],[7011,7069,"you want to me."],[7161,7328,"You can insult me, you can hit me"],[7328,7432,"for all I care!"],[7478,7636,"Don't talk about her like that!"],[7716,7857,"She's my only real friend."],[8008,8179,"Chris, forget it."],[8233,8350,"She needs rest."],[8416,8504,"Let's just go."],[8967,9084,"So this is what it feels like"],[9084,9221,"when your heart goes numb."],[9467,9563,"Go away!"],[9759,9901,"Yeah, no chance, liar."],[10093,10164,"Raven!"]],"20":[[190,276,"Surprise."],[487,590,"What are you doing here?"],[640,770,"I came to check on you."],[1014,1151,"I should've died that night."],[1484,1558,"But Raven..."],[1751,1921,"She was the light that found me."],[2479,2515,"Hey."],[2535,2582,"Hey."],[2582,2702,"I'm taking you to the hospital, okay?"],[2702,2789,"Just stay with me."],[2846,2962,"It's okay, it's okay."],[3643,3687,"If it weren't for you,"],[3687,3863,"I would never made it out of that alley."],[4127,4210,"You really thought blocking me"],[4210,4347,"was gonna get rid of me that easy?"],[4461,4541,"Not gonna happen."],[4631,4781,"I just don't wanna hold you back."],[4804,4904,"And you worked so hard"],[4904,4991,"to get into Berklee."],[4991,5138,"Hey, you're not a burden."],[5171,5291,"You never will be one."],[5362,5418,"Don't worry."],[5418,5498,"I'm not going anywhere."],[5498,5612,"I'm gonna stay here with you."],[5682,5725,"Okay?"],[5855,6009,"For the first time in a long time,"],[6069,6149,"I wasn't alone."]],"21":[[276,370,"My scars are healing,"],[417,490,"little by little."],[560,680,"Dad and Chris, of course,"],[680,770,"never showed up again."],[864,1007,"But Raven stayed."],[1117,1277,"She kept begging me not to give up."],[1464,1641,"And I've promised her I wouldn't, but..."],[1775,1835,"Honestly,"],[1925,2008,"I don't know how much longer"],[2008,2138,"my body can take it."],[2228,2332,"Special delivery."],[2432,2562,"I walked three blocks for this,"],[2562,2662,"so you better finish it."],[2699,2759,"I will."],[3133,3179,"I..."],[3219,3306,"I brought you this."],[4134,4184,"You said you wanted to"],[4184,4327,"stargaze tonight, remember?"],[4384,4524,"Let's go to the rooftop tonight."],[4591,4754,"It's the best view in the hospital."],[4801,4904,"And guess what?"],[4964,5165,"I heard you're about to be discharged."],[5265,5405,"You look so happy, Raven."],[5505,5665,"I just can't bring myself to tell you"],[5765,5899,"that I won't make it through this month."]],"22":[[256,390,"I know you love this author."],[477,517,"Here,"],[567,707,"I got her to autograph it for you."],[867,984,"You're the best, Raven."],[1171,1401,"Can you, um, grab me some water?"],[1401,1474,"Of course."],[2676,2792,"Easy, Angelica."],[2902,2972,"Don't talk."],[3086,3256,"Breathe slowly."],[3373,3530,"Angelica, we've"],[3583,3770,"tried everything, but..."],[3873,3973,"It's too late."],[4184,4337,"How much longer do I have left?"],[4467,4547,"A month."],[4848,4881,"Doctor,"],[4881,5018,"can you please do me a favor?"],[5068,5125,"What is it?"],[5268,5385,"Please don't tell Raven."],[5615,5722,"I want her to stay happy."],[5822,5969,"At least for the last month."]],"23":[[1981,2115,"Doctor Smith cleared you."],[2142,2215,"You're all set."],[2352,2415,"It's been forever"],[2415,2525,"since you've been on my bike."],[2555,2659,"Wanna go for a ride?"],[2819,2859,"Yeah."],[2892,2956,"Yeah, let's go."],[2972,3016,"Okay."],[3029,3149,"Yeah, let's go."]],"24":[[463,593,"Are you sure you wanna go in there?"],[613,724,"Your family didn't even"],[724,817,"come to visit you."],[974,1111,"I'm just here to say goodbye."],[1184,1291,"Yeah, I'm sure."],[1358,1411,"I have a few things"],[1411,1494,"I need to take care of,"],[1494,1581,"but I'll call you."],[1705,1781,"Okay, fine."],[1891,1971,"Yeah, let me know if you need me."],[1971,2072,"I'll come right over."],[3553,3733,"Welcome home, Angelica!"],[3807,3863,"Oh."],[4047,4137,"I made extra."],[4137,4230,"Just in case."],[4230,4401,"I figured you came home hungry."],[4848,4944,"Thank you, Fiona."],[5025,5158,"Don't even say that."],[5235,5368,"I know I'm just a housekeeper,"],[5368,5508,"but I watched you grow up."],[5568,5709,"And you're a good girl."],[5819,5932,"Just promise me."],[5969,6049,"That you're going to take"],[6049,6162,"good care of yourself."],[6196,6242,"You're not going to do"],[6242,6366,"anything reckless."]],"25":[[20,133,"Just promise me."],[180,270,"That you're going to take"],[270,413,"good care of yourself."],[413,477,"You're not going to do"],[477,583,"anything reckless."],[684,737,"Okay?"],[817,924,"How are Dad and Chris doing?"],[1097,1201,"Your dad is"],[1234,1327,"still the same."],[1421,1611,"He practically lives at the hospital."],[1611,1721,"He's never home."],[1838,2018,"But thanks to those meals"],[2018,2115,"you planned out,"],[2115,2298,"his blood pressure is a lot better."],[2475,2582,"And Chris,"],[2672,2766,"he changed."],[2829,3006,"He gets angry more easily."],[3099,3286,"If it wasn't for Madison,"],[3393,3533,"maybe things between you two"],[3533,3690,"wouldn't be such a mess."],[3763,3987,"One day, he will see her"],[3987,4147,"for who she really is."],[4224,4371,"It doesn't matter anymore."],[4978,5055,"Ms. Ray,"],[5105,5235,"the plot next to your mother's grave"],[5235,5342,"has been secured."],[5402,5505,"Everything's ready."],[5785,5872,"What plot?"]],"26":[[13,116,"You know, just because you're home"],[116,206,"doesn't mean we're good."],[253,367,"And whatever you're planning,"],[387,597,"stay away from Mom's grave."],[633,704,"And I mean it."],[790,854,"Don't worry."],[920,980,"I will."],[1077,1164,"The plot's for me."],[1231,1307,"For my grave."],[1531,1755,"Why does her face look so pale?"],[1788,1921,"She looks worse than before."],[1981,2085,"Is she really okay?"],[2122,2342,"And hey, make extra for tonight."],[2342,2462,"There's three of us now."],[2525,2639,"And I'm not going hungry."],[2842,3006,"Your brother still cares about you."],[3063,3213,"You know boys at that age,"],[3233,3336,"they care about their ego"],[3336,3460,"more than anything else."],[3473,3620,"Yeah, I guess."],[3717,3770,"But Chris,"],[3863,3967,"I'm running out of time."],[4067,4184,"None of this will matter anymore"],[4184,4257,"once I'm gone."]],"27":[[53,123,"Mom,"],[253,363,"I came to say goodbye."],[740,1001,"Angie, look, it's Mom!"],[1024,1234,"I won't let them keep her down here."],[1267,1351,"Mom?"],[2916,3019,"Some people just don't know"],[3019,3136,"when to quit, huh?"],[3666,3860,"Too bad you didn't die at the hospital."],[3893,4024,"I'll make sure Christopher"],[4024,4197,"never looks at you again."],[4197,4411,"He only has room for one sister."],[4434,4521,"And that's me."]],"28":[[66,126,"Do you know what I'm thinking"],[126,186,"right now?"],[263,347,"Looking at you."],[403,460,"What?"],[527,670,"I used to be just like you."],[750,870,"Desperate for love."],[947,1124,"But real love doesn't have to be forced."],[1408,1561,"Oh, please."],[1621,1758,"You're so pathetic."],[1808,1958,"We're different, you and I."],[1981,2155,"Chris and Uncle Martin,"],[2208,2308,"they love me."],[2385,2629,"They are my family now, not yours."],[2936,3143,"So get out of my house!"],[3456,3566,"What are you doing?"],[4454,4554,"Mom!"],[5295,5365,"Ah!"]],"29":[[43,113,"Ah!"],[393,590,"You lost your real parents too."],[653,820,"How could you do this!"],[854,1067,"Christopher will only have me"],[1067,1174,"as a sister."],[1227,1484,"I'd do anything to make that happen."],[1771,1841,"That night,"],[1925,2145,"I was the one who sent the guys"],[2182,2375,"to teach you a lesson."],[2462,2602,"How'd it feel?"],[2872,3036,"How could you!"],[3263,3386,"Angelica, don't,"],[3386,3540,"I swear I won't tell Christopher!"],[3540,3640,"Just don't hurt me!"],[3683,3770,"Angelica!"],[3837,3923,"Angelica!"],[4177,4374,"When are you ever going to stop?"],[4404,4574,"Do you even know what she did to me?"]],"30":[[26,163,"She's the one who-"],[163,326,"It hurts, Chris."],[370,547,"I, I wasn't even doing anything."],[547,800,"And she, she just attacked me."],[870,1027,"No, no, no, Chris!"],[1027,1094,"That's not-"],[1094,1187,"Shut up!"],[1284,1394,"Shut up, alright?"],[1394,1501,"I saw it with my own eyes!"],[1501,1598,"I'm not blind, Angelica."],[1598,1731,"You were choking Maddie."],[1731,1878,"It's not even the first time."],[1988,2102,"How'd you end up like this?"],[2145,2245,"No matter what I do,"],[2315,2429,"you'll never believe me,"],[2502,2565,"will you?"],[2612,2682,"Chris."],[2756,2986,"Angie said that"],[2986,3166,"it was all Aunt Stella's fault."],[3206,3383,"And she said that,"],[3383,3506,"that your mom was weak"],[3506,3710,"for dying just from giving birth."],[3723,3920,"That she's the reason that"],[3920,4087,"you and Uncle Martin have hated her"],[4087,4277,"since the moment she was born."],[4477,4611,"No, no, no, I"],[4611,4714,"never said that! - Shut up!"],[4728,4791,"Shut up!"],[4868,4971,"Maddie, go on."],[5038,5231,"So, she destroyed"],[5231,5405,"that portrait of Aunt Stella."],[5505,5628,"Angelica, how could you?"]],"31":[[86,166,"I saw it."],[166,370,"It was not Angelica, it was Madison."],[443,704,"Of course, she's gonna side with her."],[754,854,"I, I know I haven't"],[854,1054,"actually been a part of this family"],[1054,1187,"since the beginning, but..."],[1271,1384,"I'm telling the truth, Chris,"],[1384,1544,"you have to believe me."],[1544,1631,"Of course I do, Maddie."],[1651,1745,"How much did Angie pay you"],[1745,1815,"to lie for her?"],[1865,1938,"No, she didn't."],[1938,2038,"I am not lying!"],[2055,2172,"Don't bother, Fiona."],[2272,2355,"You can't win against someone"],[2355,2455,"who's already picked a side."],[2475,2582,"No matter what I do,"],[2649,2772,"you'll always defend her."],[2772,2876,"I get it now."],[2946,3043,"You know, if hating me"],[3043,3149,"makes it easier for you,"],[3149,3239,"then go ahead."],[3283,3476,"It's all my fault!"],[3493,3543,"Ah!"],[3970,4084,"I don't wanna see you again,"],[4140,4187,"ever."],[4270,4361,"So get out."],[4417,4577,"Get the fuck out!"],[4644,4684,"Fine."],[4794,4861,"I'll go."],[4978,5021,"Chris,"],[5115,5255,"we'll never see each other again."],[5418,5548,"Because I'm dying,"],[5588,5702,"and there's nothing left in me"],[5702,5805,"to say goodbye."]],"32":[[670,834,"Raven, can I come live with you?"],[874,977,"Stay where you are."],[997,1094,"I'll be there in five."],[2258,2332,"Bye, Chris."],[2492,2562,"Bye, Dad."],[3063,3126,"Hop on, girl."],[3126,3216,"Let's get you out of here."],[3433,3490,"Okay."],[4868,4958,"Angelica."]],"33":[[807,937,"I must be seeing things."],[957,1051,"There was no way that"],[1051,1224,"was Angelica on a motorcycle."],[1351,1608,"Well, I have cheer practice after school."],[2152,2252,"Um, apple jam?"],[2288,2535,"Oh, that was Angie's special recipe."],[2535,2645,"She always made it for you."],[2759,2866,"She made it herself?"],[2926,3009,"Of course."],[3009,3149,"She knew it was your favorite."],[3149,3236,"But lately..."],[3313,3380,"Whatever."],[3636,3830,"She's faking it anyways, so."],[3907,3957,"Forget it."],[3967,4094,"And also, where is she?"],[4110,4140,"You know,"],[4140,4274,"she should be down here already."],[4330,4561,"I knocked on her door earlier."],[4584,4694,"She didn't answer."],[4761,4924,"She's probably still mad at you."],[5001,5135,"Don't take it to heart, Chris."],[5238,5358,"But she is the one that screwed up,"],[5358,5492,"and I'm supposed to feel guilty?"],[5528,5695,"Whatever, I'm done."],[6613,6740,"You're making the biggest"],[6740,6893,"mistake of your life, Christopher."],[6963,7070,"You're going to regret"],[7070,7240,"letting your sister go like that."]],"34":[[1004,1094,"It's your favorite."],[1144,1207,"It's sweet."],[1338,1481,"Thanks, Raven."],[1481,1578,"You're the best."],[2148,2195,"Um."],[2325,2442,"I'm gonna go to the bathroom,"],[2442,2515,"really quick."],[5345,5488,"The cancer is spreading."],[5535,5642,"I can't eat."],[5642,5739,"I can't drink."],[5802,5895,"Death's so close,"],[5895,6062,"I can feel it breathing down my neck."],[6146,6256,"But I'm not afraid."],[6316,6409,"I just wish"],[6466,6623,"I had more time to say goodbye."]],"35":[[120,266,"Angie, are you okay?"],[347,483,"Angie, answer me, please."],[527,633,"Yeah, I'm fine."],[790,860,"I'll be right out."],[1691,1728,"Angie."],[1911,2018,"Just be honest with me."],[2018,2125,"It's just us."],[2172,2268,"You don't have to lie."],[2382,2472,"I just need to know."],[2519,2659,"Will you obviously just tell me, like,"],[2732,2859,"how long do you have left?"],[2979,3023,"Hey."],[3103,3256,"Hey, you can't cry."],[3299,3413,"The Raven that I know,"],[3413,3603,"she rides her bike like a maniac."],[3603,3707,"She doen't cry."],[3893,4080,"Yeah, that's true."],[4257,4317,"Okay, well."],[4371,4541,"Here, I want you to have this."],[4587,4728,"And you know, it's my favorite novel."],[4771,4851,"I just,"],[4881,4974,"I don't know if I'm gonna get"],[4974,5071,"to the last page."],[5432,5538,"Will you read it for me,"],[5578,5658,"at my grave?"],[5689,5765,"Yeah, of course."],[5802,5895,"You know, I don't regret"],[5895,6042,"anything in this life, but,"],[6166,6296,"if there is another life,"],[6403,6546,"will you be my real family?"],[6653,6736,"My real sister?"],[6853,6943,"Yeah, I promise."]],"36":[[513,717,"Doctor, I know my time's almost up."],[917,1047,"Here's my body donation form,"],[1047,1167,"and my dad's letter of consent."],[2258,2472,"Angelica, I'm so sorry."],[2592,2749,"I wish I could have done more."],[2856,2932,"You did everything"],[2932,3033,"you could, doctor."],[3186,3289,"Time doesn't always play out"],[3289,3360,"how we want."],[3450,3550,"I couldn't choose"],[3550,3677,"how I came into this world."],[3783,3903,"It took my mother,"],[3990,4164,"my family, everything."],[4407,4537,"But I can choose how I leave."],[4691,4814,"If my body can give others"],[4814,4948,"the chance to be happy, then"],[5058,5175,"it's more than enough for me."],[5278,5328,"Okay."],[5395,5518,"I'll handle the donation,"],[5518,5638,"just like you wanted."],[5729,5789,"Thank you."]],"37":[[1805,2022,"I probably should apologize to Angie."],[2022,2114,"No matter what she's done,"],[2114,2248,"we're family after all."],[2248,2314,"Christopher?"],[2394,2452,"Hello?"],[2577,2677,"What are you doing here?"],[3299,3428,"Hey, have you seen Angie?"],[3490,3561,"Angie?"],[3674,3807,"She dropped out weeks ago."],[3949,4024,"You didn't know?"],[4608,4688,"Oh, shit."]],"38":[[10,83,"Angie!"],[176,266,"Hey, Angie!"],[397,480,"Angie!"],[627,697,"Ugh."],[914,1024,"Okay, uh, thank God."],[1024,1101,"I thought she was trying to"],[1101,1164,"hurt herself again."],[1307,1358,"Angie?"],[1524,1644,"Oh, um."],[1798,1915,"Sorry, I thought it was Angie."],[1988,2182,"Oh, she should be in school,"],[2242,2295,"isn't she?"],[2305,2342,"No."],[2465,2545,"No, she isn't."],[2599,2722,"Well, that's strange."],[2806,2886,"Where else could she-"],[2886,3006,"Whatever, whatever."],[3006,3103,"Who cares where she is?"],[3103,3249,"Even if she dropped out,"],[3249,3323,"I wouldn't care."],[3343,3420,"Christopher,"],[3480,3640,"I know this is not my place"],[3640,3760,"to say this, but,"],[3960,4047,"don't say things"],[4047,4144,"you're going to regret."],[4177,4294,"Your sister loves you,"],[4364,4497,"whether you see it or not."],[4534,4637,"And deep inside,"],[4637,4758,"I know you love her too."],[5121,5191,"Yeah, I don't know what you're"],[5191,5271,"talking about."]],"39":[[513,573,"Chris!"],[667,794,"Chris, what's going on with you today?"],[794,910,"You were supposed to wait for me,"],[910,1021,"so we could head home together,"],[1021,1141,"but you ditched me."],[1297,1498,"Ugh, I'm exhausted."],[1521,1745,"My Uber smelled disgusting."],[1818,1875,"Hey."],[2035,2118,"What's going on?"],[2132,2232,"Why are you zoning out?"],[2312,2382,"Uh."],[2472,2529,"Nothing."],[2702,2796,"Sorry, Madds."],[2832,3039,"I, um, something came up,"],[3093,3309,"and that's why I had to leave early."],[3333,3520,"Um, I went to the candy shop,"],[3520,3767,"and you love sweets, don't you?"],[3930,4090,"When did I ever say that?"],[4174,4314,"They're way too sweet."],[4314,4487,"And I'm trying to stay in shape."],[4587,4651,"Wait, really?"],[4651,4721,"No, it's..."],[4804,4914,"Oh, you don't love sweets."],[4931,4981,"Then..."]],"40":[[26,90,"Wait, really?"],[90,160,"No, it's..."],[243,353,"Oh, you don't love sweets."],[377,420,"Then..."],[540,617,"Then who..."],[934,1007,"Too sweet."],[1591,1668,"My God."],[1708,1858,"Chris, how did you know I love candy?"],[1958,2022,"Well, um."],[2178,2268,"It's all yours."],[2522,2639,"How could I forget?"],[2679,2839,"Angie's the one who loves candy."],[3003,3169,"Why is my chest hurting so badly?"],[3343,3476,"That's fine if you don't want them."],[3476,3620,"I'll just give them to Fiona."],[3620,3720,"She has a ton of kids."],[3800,3873,"Christopher!"],[3943,4094,"There's something wrong with Angie."],[4177,4330,"What's, what's going on with Angelica?"],[4404,4514,"She has cancer."]],"41":[[16,130,"Angie has cancer?"],[180,316,"It's just a drink."],[316,410,"Seriously?"],[410,500,"You're, you're acting like"],[500,610,"you're dying or something."],[650,740,"I am."],[780,830,"What?"],[907,1007,"I'm sick, Chris."],[1044,1181,"Your little sister is dying."],[1321,1438,"You must be so happy now."],[1651,1708,"Angelica,"],[1708,1825,"what do you mean you're dying?"],[1825,1868,"Chris!"],[1868,1951,"Angelica! - Chris, wait!"],[1978,2075,"So that's, so that's why"],[2075,2178,"she was acting so weird."],[2178,2288,"She was, she wasn't faking it."],[2288,2455,"She actually, she's actually sick."],[2505,2609,"I have to go see her."],[2632,2726,"Chris, wait."],[2739,2899,"Maddie, just let me go and see-"],[2899,3039,"Chris, calm down."],[3076,3169,"You, you can't just run off"],[3169,3229,"without knowing"],[3229,3319,"what's actually going on."],[3356,3443,"And people don't just"],[3443,3573,"get cancer overnight."],[3656,3797,"I'm telling you the truth."],[3837,4047,"I found these while cleaning her room."],[4457,4534,"How do you even know"],[4534,4647,"these are cancer meds?"],[4667,4868,"My husband died of stomach cancer."],[5025,5258,"I used to see these exact pills"],[5258,5331,"every day."],[5428,5532,"I would recognize them"],[5622,5705,"anywhere."],[5802,5932,"Angie has cancer."],[5965,6072,"Stomach cancer."],[6119,6302,"If she gets to the final stages,"],[6423,6673,"oh, she will be spitting up blood."],[6673,6800,"She will lose all her hair."],[6800,6930,"She won't be able to eat."],[6983,7103,"It's pure torture."]],"42":[[25,145,"It's pure torture."],[1597,1647,"No."],[1693,1810,"There is no way she has cancer."],[1810,1901,"She was fighting with me"],[1901,2106,"the other day to go after Maddie."],[2156,2293,"Right? There's no way she has cancer."],[2427,2489,"That, that's..."],[2594,2727,"No, that can't be real!"],[2761,2848,"I have to go see her."],[2848,2944,"I have to hear it from her-"],[2944,3023,"Chris, wait."],[3053,3224,"Chris, just, just look at this first."],[3378,3424,"See that?"],[3536,3661,"The seal's not even broken."],[3695,3874,"If she actually had cancer,"],[3874,4008,"she'd be taking her meds."],[4070,4233,"She's just trying to get into your head."],[4304,4441,"Don't fall for it."]],"43":[[26,120,"That can't be right."],[210,400,"No, she's not the kind of kid"],[400,493,"that would do that."],[553,660,"Shows how little you know."],[760,904,"She has done worse"],[917,1017,"to hurt Christopher."],[1081,1164,"Self-harm,"],[1221,1414,"suicide threats, you name it."],[1451,1541,"Running away,"],[1584,1681,"faking cancer?"],[1725,1818,"That's nothing for her."],[1888,1975,"Faking a disappearance,"],[1975,2125,"faking cancer, yeah."],[2232,2295,"Yeah, that's right."],[2295,2409,"She almost fooled me again."],[2515,2739,"She almost had me fooled again!"],[2769,2962,"Angie is perfectly fine."],[2962,3123,"There's no way she has cancer."],[3153,3219,"And when she"],[3219,3273,"spends all her money,"],[3273,3446,"she's gonna come crawling back home,"],[3446,3556,"and I'm gonna teach her a lesson"],[3556,3650,"for messing with us."],[3690,3863,"Teach her a lesson?"],[4044,4270,"Christopher, she's your sister!"]],"44":[[46,236,"Christopher, she's your sister!"],[293,490,"She's the kindest, the sweetest girl"],[490,600,"I've ever seen."],[600,744,"And you know that about her."],[744,894,"You really think she would lie"],[894,1021,"about something like this?"],[1057,1181,"A good kid, the sweetest,"],[1181,1314,"kindest girl you've ever seen?"],[1401,1451,"That's..."],[1518,1698,"Okay, so bullying Madison?"],[1825,2032,"Breaking my Mom's necklace?"],[2095,2265,"Slashing the portrait?"],[2375,2475,"You know what, Fiona?"],[2475,2599,"Let this get through your skull."],[2639,2842,"She's not as innocent as you think."],[2886,3096,"So I am done falling for this!"],[3403,3553,"Watch yourself, old lady."],[3570,3670,"Shut your mouth,"],[3670,3810,"or you're gonna be fired."],[4110,4257,"I don't care if I get fired."],[4374,4511,"Listen, Christopher Ray,"],[4587,4771,"your sister's room is empty."],[4834,4938,"She's gone!"]],"45":[[530,717,"If you ran away, where would you go?"],[1805,1931,"Why would you even still"],[1931,2052,"have candy wrappers?"],[2168,2332,"Oh, and this stupid notebook."],[2882,2979,"May 13th,"],[3103,3253,"Chris' first game."],[3253,3363,"I just knew he'd win."],[3463,3546,"June 2nd,"],[3580,3673,"Chris lost today."],[3780,3900,"He looked so upset."],[3900,4084,"What can I do to make him smile?"],[4260,4351,"August 30th,"],[4477,4587,"My brother will"],[4651,4844,"reach his dreams, I believe in him."],[5108,5201,"October 11th,"],[5201,5432,"Chris, if I die, will you regret it?"],[5575,5859,"Chris, if I die, will you regret it?"],[5919,6136,"So all this was just to get back at me?"],[6296,6443,"How could she do this to me?"],[6506,6603,"If you think hurting yourself"],[6603,6706,"is gonna mess with me,"],[6730,6890,"just please, don't flatter to yourself."],[6926,7083,"No, don't give me that pathetic look."],[7083,7177,"It's disgusting."],[7237,7384,"Is this all a misunderstanding?"],[7594,7684,"What have I done?"]],"46":[[840,897,"See?"],[937,1151,"Your sister really did care about you."],[1247,1504,"She just wanted you to love her back."],[1715,1815,"I gave her nothing."],[1961,2002,"Nothing."],[2232,2339,"Angie, where are you?"],[2462,2629,"Christopher's my brother."],[2929,3113,"Did you really have cancer?"],[3113,3219,"He's mine."],[3540,3636,"Oh, please."],[3697,3813,"Don't let her fool you."],[3850,3987,"Chris, your dad's a doctor,"],[3987,4137,"if she really had cancer,"],[4194,4260,"he would know."],[4517,4597,"Come on."],[4644,4738,"She'll be back."],[4768,4868,"You have playoffs"],[4868,4984,"and practice coming up."],[4984,5181,"You can't afford to lose focus now."],[5255,5375,"Yeah, yeah you're right."],[5375,5548,"If she was really sick, uh,"],[5662,5759,"Dad would've said something."],[6032,6219,"I'll just apologize when she gets back."],[6282,6356,"There's still time."]],"47":[[1828,2002,"What is, what is going on?"],[2038,2175,"For my favorite little sister."],[2362,2499,"Your dreams are coming true."],[2509,2612,"Oh, and we've got your"],[2612,2712,"Prince Charming."],[3113,3299,"Okay, if you could have one wish,"],[3299,3426,"anything, what would it be?"],[3543,3680,"It's kinda stupid."],[3750,3793,"Try me."],[4040,4284,"I've had a crush on Zack Hunter,"],[4310,4404,"the lead singer"],[4404,4501,"of Black Vibes. - Oh?"],[4597,4637,"Okay."],[4664,4868,"I always dreamed of kissing him."],[5185,5235,"Hey."],[5352,5412,"Hi."]],"48":[[160,250,"It's real."],[333,387,"No way."],[387,517,"You went to that store too?"],[527,663,"I know, crazy right?"],[707,810,"I wasn't studying guitar though,"],[810,927,"I was studying classical."],[977,1107,"Probably saw you back then."],[1197,1274,"What were you like?"],[1354,1461,"Probably a total jerk."],[1835,1918,"You know, Angie,"],[2002,2105,"you give me this feeling."],[2208,2298,"Something different."],[2412,2512,"Different like,"],[2545,2645,"different weird?"],[2645,2696,"No."],[2789,2912,"When I look into your eyes,"],[3033,3196,"it's like I can see my own soul."],[3947,4017,"Can I kiss you?"],[4147,4184,"Yeah."],[4451,4671,"No, no, no! Stop!"],[4671,4768,"Please don't!"],[4824,4911,"No!"],[5168,5241,"Angelica?"],[5358,5422,"I'm sorry."],[5468,5545,"I can't."],[6066,6099,"Angie."],[7163,7293,"Angie, it's, it's okay."],[7293,7404,"Angie, it's okay."],[7404,7527,"You're okay, you're okay."],[7527,7607,"Take a deep breath."],[7607,7714,"You're gonna be fine."],[7714,7784,"I can't. - It's okay."],[7784,7857,"I can't. - You can."],[7857,7941,"I can't do it. - You can do it."],[7941,8044,"I can't forget. - Take a deep"],[8044,8174,"I can't! - breath, no, no."],[8174,8274,"No, no, no."],[8274,8425,"Hey, I need some help in here, please!"],[8445,8515,"I need some help!"]],"49":[[642,729,"There's nothing more"],[729,859,"we can do for Angelica."],[930,1109,"She only has a couple of days."],[1301,1359,"You should"],[1388,1539,"start making arrangements."],[1843,1972,"I'm so sorry."],[3374,3440,"Angelica."],[3536,3678,"It's okay, it's okay."],[3837,3941,"Don't hurt yourself, okay?"],[3978,4045,"It hurts."],[4141,4295,"It hurts so much."],[4408,4462,"I can't,"],[4500,4692,"I can't take it anymore."],[4692,4779,"I know, I know."],[4863,4996,"Listen, if you can't hold on any longer,"],[4996,5080,"I'll let you go."],[5080,5176,"Okay, I'll let you go."]],"50":[[617,730,"Yeah, sorry about that."],[760,870,"I shouldn't have brought Zack"],[870,1047,"to the party without asking you first."],[1084,1211,"No, Raven, it's okay."],[1254,1327,"You're my best friend."],[1327,1421,"I know you were just trying to"],[1421,1514,"make me happy."],[1624,1795,"And, Zack's cute."],[1888,1975,"You know I like him."],[2165,2275,"Zack's a lucky guy."],[2505,2642,"Hey, don't be sad for me."],[2732,2812,"I've already been through"],[2812,2946,"so much already, and,"],[3076,3216,"death doesn't scare me anymore."],[3326,3453,"What I want now"],[3586,3677,"is peace."],[3677,3753,"Don't say that."],[3807,3953,"I don't wanna become your burden."],[4044,4244,"So promise me when I'm gone,"],[4317,4394,"you'll live."],[4497,4574,"Okay? You'll see the world"],[4574,4657,"for both of us."],[4764,4811,"Okay?"],[5021,5115,"I promise."],[5362,5422,"There's one last thing"],[5422,5565,"I wanna do before I'm gone."]],"51":[[96,150,"I wanna die"],[150,246,"somewhere beautiful."],[463,527,"Will you help me?"],[707,770,"Of course."],[834,887,"Anything."],[