7,5417,"I plan to make her my wife."],[5743,6006,"It is if she'll have me."],[6110,6206,"Dax, I..."],[6610,6760,"I'm really sorry."],[6902,7015,"I'm really sorry for ruining"],[7015,7073,"your birthday."],[7211,7323,"I'll leave."],[7474,7570,"Don't, Violet."],[7711,7828,"If you leave now, the person"],[7828,7903,"behind this wins."],[7970,8066,"We can't let that happen."],[8187,8279,"So stay with me."],[8341,8416,"I promise we can"],[8416,8525,"solve this together."],[8867,8950,"You're right."],[9104,9280,"This time,"],[9280,9463,"we'll face it together."],[9513,9659,"Aww, that's kind of sweet."],[9701,9834,"It doesn't look like an escort-client"],[9834,9922,"relationship to me."],[9964,9997,"Seems like"],[9997,10085,"they're really in love."],[10126,10281,"Dax's words actually"],[10281,10410,"make a lot of sense."],[10464,10585,"I mean, there's obviously"],[10585,10764,"someone behind this who's"],[10764,10860,"trying to smear"],[10860,10940,"the Kingsley name."],[10977,11015,"Oh, you think"],[11015,11081,"that's all I've got?"],[11140,11227,"Enjoy this, lovebirds."],[11302,11469,"Violet, my sweet girl."],[11574,11711,"I finally found you."],[12057,12291,"Please, please give the money"],[12291,12383,"back that was for"],[12383,12495,"your dad's surgery."],[12550,12650,"I know you're struggling to"],[12650,12779,"keep up this new fancy"],[12779,13017,"lifestyle, but becoming an"],[13017,13234,"escort and stealing from your"],[13234,13480,"own dad, it is not the way."]],"66":[[0,154,"What are you talking about?"],[154,229,"Don't touch me."],[262,479,"Oh, my God, like stealing"],[479,642,"from her own dying father?"],[696,1030,"I've been trying to find her for weeks."],[1030,1242,"Her dad's paralyzed in bed"],[1242,1334,"and needs that"],[1334,1480,"money to save his life."],[1530,1676,"She hasn't even taken any of"],[1676,1793,"our phone calls."],[1835,2052,"Please, her dad's dying."],[2139,2360,"I promise you, I promise you,"],[2389,2523,"after the surgery, I'll work more shifts,"],[2523,2623,"I'll clean toilets,"],[2656,2752,"I'll buy you"],[2752,2844,"new bags."],[2865,2986,"I'm begging you,Violet!"],[2986,3065,"Why can't you just"],[3065,3161,"leave me alone?"],[3199,3290,"I gave you every"],[3290,3411,"single penny I had."],[3411,3578,"You bled me dry and tried to"],[3578,3628,"sell me off to"],[3628,3707,"the highest bidder."],[3795,3895,"You took me through hell."],[3966,4079,"And you have the nerve to"],[4079,4149,"come back in here"],[4149,4270,"and call me a thief?"],[4270,4383,"Get your filthy hands off"],[4383,4487,"her, or do you want more"],[4487,4587,"marks on your face?"],[4700,4833,"Mr. Kingsley,"],[4833,4921,"don't let her fool you."],[4971,5117,"She's just using you"],[5117,5263,"to climb the ladder."],[5605,5822,"Please go home, to your dad."],[5822,6051,"Violet, he's dying."],[6164,6519,"All he wishes is to see his"],[6519,6927,"little girl one last time."],[7165,7361,"What a cold-blooded bitch!"],[7428,7557,"Who would steal from their"],[7557,7695,"own father's surgical money?"],[7736,7845,"She's such a good actress."],[7866,7932,"I can't believe I"],[7932,8024,"fell for her lies."],[8070,8095,"And now her"],[8095,8208,"mother called her out?"],[8241,8316,"She really is a"],[8316,8466,"filthy little gold digger."],[8521,8629,"Dax, stop"],[8629,8837,"embarrassing your family."],[8875,9029,"Cut your ties with this"],[9029,9263,"low-class tramp right now."],[9409,9463,"Violet."]],"67":[[116,175,"Dad, you're awake."],[241,304,"Oh, baby."],[337,458,"You've been through so much"],[458,592,"while I was out."],[600,725,"My poor girl."],[1059,1347,"She's a disgusting liar."],[1405,1643,"Even when I was paralyzed in bed,"],[1643,1755,"I heard everything."],[1793,1968,"She's the one who spent all"],[1968,2198,"my money, and she used my"],[2198,2394,"life as leverage to"],[2394,2527,"control my daughter."],[2585,2773,"She even tried to sell my"],[2773,2973,"daughter right in front of me"],[2973,3157,"to some disgustin