5,11983,"better puck, wax, and laser"],[11983,12159,"everything and not a word."],[12647,12738,"Have a plan?"],[12847,12939,"Sorry."],[12997,13034,"Yeah."],[13034,13281,"I have, umm, these sunglasses."],[13356,13610,"You look like you in large sunglasses."],[13673,13748,"Maybe try a funny"],[13748,13856,"nose and mustache."],[13919,14119,"Do you have a better idea?"],[14198,14394,"Is it okay if I have to make a stop?"],[14394,14532,"Laundry can't talk."],[15028,15128,"Run."],[15207,15283,"Ophelia! Ophelia!"],[15600,15679,"Ophelia! Ophelia!"]],"53":[[1,192,"After this, I'll want you to sit in"],[192,351,"on my weekly audience"],[351,476,"with the Prime Minister."],[568,705,"You'll be riveted."],[1848,1982,"You'll forgive me if I don't bow."],[1982,2094,"No, we won't forgive you."],[2094,2161,"Son."],[2161,2253,"It's disrespectful."],[2270,2315,"And what have you done"],[2315,2432,"that merits my respect,"],[2432,2520,"young prince?"],[2549,2682,"Apart from make a few headlines"],[2682,2787,"and stain the flag."],[2820,2945,"I understand what you stand for."],[3004,3175,"And while I disagree with you,"],[3175,3346,"I haven't come here to disrespect you."],[3346,3496,"But as this is Great Britain,"],[3496,3688,"and you are in fact, one of its children,"],[3688,3796,"you will not"],[3796,3892,"disrespect your king."],[4042,4126,"As you can understand,"],[4126,4213,"it's not often that the"],[4213,4384,"King of England asks to sit down"],[4384,4488,"with the very people"],[4488,4551,"whose mission"],[4551,4655,"it is to end his reign."],[4751,4835,"We do acknowledge that"],[4835,4922,"you're a fine king."],[4922,5018,"A great king."],[5218,5327,"A great king."],[5377,5477,"Do you see, Prince Liam?"],[5477,5677,"You advance our argument."],[5727,5840,"Who we bow down to"],[5840,5998,"shouldn't be left to chance"],[5998,6090,"or bloodline."],[6090,6236,"We have the right to choose our own"],[6236,6399,"leaders, our own kings."],[6503,6645,"And when your father is gone,"],[