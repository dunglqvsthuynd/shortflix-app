0,10245,"No one is holding anyone"],[10245,10354,"bow and arrow point."],[10483,10600,"Yeah, I know."],[10850,10962,"Poor guy."],[10962,11083,"He'll be okay."],[11088,11209,"He gets like this."],[11501,11617,"What kind of guy gets good at darts"],[11617,11734,"to impress girls?"],[11818,11934,"Worked with you."],[12009,12130,"Whatever."],[12189,12310,"Robert was a great dart player."],[12443,12556,"I practiced all the time so that"],[12556,12656,"someday I could beat him."],[12760,12881,"Never did."]],"105":[[450,566,"Well done."],[621,692,"Reconnecting with"],[692,867,"the king so soon upon his return."],[929,1038,"Very clever."],[1038,1159,"I didn't do it for you."],[1180,1309,"That doesn't matter, does it?"],[1367,1434,"When he goes out"],[1434,1580,"tonight, you follow him."],[1651,1784,"Otherwise, they're gonna love that"],[1784,1914,"pretty mouth of yours in prison."],[2760,2869,"All right, Beck."],[2873,2927,"Yeah, mate."],[3031,3102,"See you later."],[3119,3177,"See you later."],[3269,3340,"Hey."],[3390,3499,"Where did you disappear to?"],[3665,3782,"Well, I came back here"],[3782,3937,"to find the diplomatic bag,"],[3937,4137,"but all I could find was a ceremonial"],[4137,4324,"bow and arrow, so..."],[4354,4399,"That's odd."],[4533,4587,"Yeah."],[4641,4787,"Where are my drugs, Beck?"],[4871,5008,"In the bag I suppose."],[5551,5667,"Liam asked me to fly"],[5667,5784,"in because of Robert."],[5855,5909,"Because he knows what"],[5909,6030,"this place meant to you."],[6093,6193,"Well, you didn't have to do that."],[6193,6372,"I'm doing that bad."],[6464,6556,"You’re a shitshow and"],[6556,6677,"we both know it."],[6781,6889,"And you have your drugs"],[6889,7035,"and your guys and your darkness."],[7136,7219,"But you still can't"],[7219,7340,"diminish that light."],[7503,7624,"I don't have a light."],[7886,7974,"You have a light,"],[7974,8095,"Princess."],[8232,8345,"So brilliant it’s hard to"],[8345,8433,"look at you sometimes."],[9025,9142,"So you"],[9150,9284,"you only came here because"],[9284,9384,"Liam asked you to?"],[9542,9663,"No, Len."],[9834,9943,"I came because I wanted"],[9943,10030,"to see you."],[10243,10364,"Because I always want to see you."],[10489,10585,"I'd see you every day"],[10585,10702,"if I could."],[10760,10881,"That's not fair."],[10973,11094,"Excuse me."]],"106":[[1350,1466,"Remember the first time"],[1466,1586,"we ever got drunk together?"],[1641,1691,"Right here."],[1849,2070,"What were we, 13?"],[2120,2204,"12."],[2204,2358,"You didn't have to invite him."],[2479,2550,"It's our first time here"],[2550,2671,"without Robert."],[2696,2829,"Yeah, well, you don't"],[2829,2942,"have to worry about me."],[2975,3092,"I don't have to, but I do."],[3297,3376,"And I always will"],[3376,3497,"so deal with it."],[3497,3614,"Okay."],[3897,4014,"You remember the last time"],[4014,4193,"I was drug free all day?"],[4256,4289,"When?"],[4373,4502,"No. I'm asking you"],[4502,4623,"because I don't remember."],[4952,5073,"I'm going to bed"],[5182,5303,"alone."],[5403,5453,"Certainly"],[5453,5582,"is a night of firsts."],[11809,12214,"Hey. Perfect line."]],"107":[[370,477,"How'd you sleep?"],[652,810,"Really great, actually."],[931,1048,"Good."],[1052,1173,"I made you breakfast."],[1327,1448,"Is that bacon?"],[1448,1548,"Mmhm."],[1548,1698,"I love bacon."],[2312,2433,"I took the bag."],[2645,2787,"I knew you took my bag."],[2933,3054,"It's all still here."],[3379,3500,"You slept great."],[3609,3751,"And you look amazing."],[3813,3880,"Yeah, well."],[3880,4026,"And the bacon never tasted better."],[4276,4435,"Eat, and come hang"],[4435,4555,"out by the pool."],[4785,4860,"Beck."],[4885,4914,"Yeah?"],[5135,5235,"Thank you."],[6595,6712,"You're kidding me, right?"],[6758,6958,"You gamble away my McLaren,"],[6958,7025,"and now you're"],[7025,7121,"frolicking by the pool."],[7179,7308,"Relax, Ashok."],[7433,7496,"We have a plan"],[7496,7634,"to get your precious car back."],[7725,7796,"You do?"],[7905,8026,"What plan?"],[8388,8509,"What is this?"],[8614,8730,"An episode of Glee."],[8839,8956,"We'd like the car back."],[9010,9164,"You have something we want."],[9243,9369,"Maybe I have something"],[9369,9473,"you want."],[9627,9727,"Like what?"],[9761,9840,"Sex."],[9948,10111,"Virgin sex."],[10240,10382,"You expect me to believe"],[10382,10503,"you're a virgin?"],[10503,10624,"Not me, creep-o."],[10703,10824,"Her."],[11233,11308,"No deal."],[11433,11483,"I think you may"],[11483,11613,"like to reconsider."],[11642,11863,"I'm quite skilled in the blowy"],[11863,12042,"and handy department and, well,"],[12042,12176,"not to mention the five ounces"],[12176,12372,"of Bolivian cocaine I'm currently"],[12372,12547,"ferrying in my rectum."],[12664,12801,"Do you still have"],[12801,12922,"up there?"],[12985,13135,"I'm afraid I can't help you."],[13260,13381,"I won this car."],[13389,13473,"Fair and square."],[13473,13585,"In a game of chance."],[13840,13977,"Poker is a game of skill."],[14023,14144,"Not according to the casino."],[14203,14257,"So how about you"],[14257,14374,"let's us try to win the car back?"],[14453,14574,"In a game of skill."],[14653,14728,"I'm a man who"],[14728,14899,"appreciates a challenge."],[14920,15078,"And also a good anecdote about"],[15078,15283,"defeating the Crown Prince of England."],[15400,15462,"What's your game,"],[15462,15583,"Your Highness?"]],"108":[[167,304,"The game is 501."],[384,434,"First player"],[434,563,"to score 501 points"],[563,688,"without going over wins."],[717,842,"Outer rings count as double."],[842,1022,"Inner ring counts as triple."],[1076,1268,"Three darts per turn."],[1835,1881,"Did I mention"],[1881,2002,"I love my car?"],[2060,2110,"You know I'm"],[2110,2235,"a man of my word."],[2394,2515,"If I lose,"],[2623,2744,"you can have your car."],[2794,2915,"But I won't lose."],[4212,4388,"Great arrows, Omar!"],[4454,4563,"Triple 20."],[4563,4759,"Triple 20 and 20."],[4909,4984,"We're screwed."],[5038,5113,"How was your first day"],[5113,5184,"with Her Majesty?"],[5230,5347,"Without incident."],[5380,5472,"Normally, I'd commend you"],[5472,5597,"on your unprecedented rise"],[5597,5701,"to the Queen's detail."],[5701,5818,"However, in this instance,"],[5818,5956,"I feel a warning"],[5989,6098,"might be more prudent"],[6098,6214,"than a compliment."],[6235,6356,"A warning, sir."],[6369,6490,"The Queen asked for you personally."],[6515,6748,"She also has MI5 and MI6 vetting"],[6748,6873,"your security clearance."],[6894,7049,"Eventually, she will discover"],[7049,7178,"you're not the person"],[7178,7299,"you claim to be."],[7507,7624,"You think I didn't know?"],[7687,7808,"I'm the king's head of security."],[7812,7933,"We know a few things."],[8095,8221,"I'll speak to Princess Eleanor"],[8221,8362,"about the conditions of your transfer."],[8362,8513,"And as she refutes your claims,"],[8513,8688,"you will be tried for treason."],[8780,8900,"Until then,"],[8930,9042,"you are being watched"],[9042,9255,"closely. Mr. Frost."],[9330,9372,"Go."],[9968,10089,"Mr. Pryce, sir,"],[10256,10339,"if you knew about"],[10339,10410,"my past..."],[10410,10490,"Why did I hire you?"],[10661,10715,"Because as far"],[10715,10836,"as I can tell,"],[10915,11032,"you're not your parents."],[11153,11215,"Besides,"],[11215,11345,"everybody deserves a chance"],[11345,11461,"to rewrite their history."],[11591,11712,"Word of advice."],[11778,11945,"The queen tends to be threatened"],[11945,12091,"by her daughter's youth"],[12091,12233,"and attractiveness."],[12391,12512,"In case it comes up."]],"109":[[16,154,"343 for Liam."],[167,346,"469 for Omar."],[421,571,"Omar needs 32 points to win."],[675,796,"Double 16."],[1234,1405,"Oh. So close."],[1464,1539,"You must be living"],[1539,1660,"right, Your Highness."],[1685,1847,"But you know what?"],[1927,2131,"I only need 16 points."],[2210,2381,"You need 158."],[2506,2623,"Good luck."],[2698,2819,"Good luck."],[3474,3553,"You know, it's a funny thing,"],[3553,3641,"pressure."],[3712,3783,"Once you have the weight"],[3783,3904,"of the world on your shoulders..."],[4200,4321,"the rest of it is easy."],[4442,4546,"That's 120."],[4546,4663,"You need 38 points."],[4767,4884,"Double 19."],[4963,5080,"Ashok,"],[5243,5359,"do you like your car?"],[5484,5572,"I love my car."],[5839,5906,"Good."],[6006,6081,"Because it's yours."],[6790,6911,"Yeah, it's"],[6911,7153,"a good game, but,"],[7274,7345,"you know that thing"],[7345,7503,"that I said about my word?"],[7591,7691,"I lied."],[7691,7812,"I'm keeping the car."],[7903,7962,"Hey. Hey!"],[8108,8204,"It's mine now."],[8204,8254,"Okay!"],[8254,8325,"Give him the keys!"],[8362,8483,"Whoa. Hey! Whoa, whoa!"],[8492,8562,"Calm down."],[8562,8646,"Hey, whoa ho."],[8646,8767,"Look, I was raised in America"],[8767,8884,"where they decided guns are bad,"],[8884,9009,"but a bow and arrow is honorable."],[9009,9126,"So don't think I won't use this."],[9126,9205,"Oh, no, I'm not thinking."],[9205,9263,"I’m zen."],[9263,9384,"It’s slipping."],[9472,9526,"It’s slipping!"],[9526,9639,"All right. Okay! All right!"],[9639,9793,"Take the car. Take the car."],[9847,9964,"Crazy bitch."],[9997,10114,"Come on."],[10514,10635,"Oh! Oh!"],[10698,10740,"Ashok!"]],"110":[[9,114,"Ahhh."],[214,280,"Oh my God!"],[280,456,"Oh my god. I’m totally going to die."],[468,652,"I'm gonna bleed out and die."],[743,860,"You're not going to die, Ashok."],[885,977,"I have a rubber taste"],[977,1031,"in my mouth."],[1140,1202,"You should probably go"],[1202,1319,"and check on Ophelia."],[1352,1419,"You got this, Shok."],[1590,1711,"Hang in there, buddy."],[1811,1886,"Ashok."],[1886,2003,"Calm down. Listen to me."],[2070,2186,"You're going to be fine."],[2191,2316,"I just need to remove the arrow."],[2353,2470,"No, no, no. Bad idea."],[2470,2637,"You have to take me to the hospital."],[2658,2800,"-I can't do that. -Why not?"],[2858,2979,"Because you're best friends"],[2979,3100,"with the Crown Prince of England."],[3137,3254,"And there's a protocol."],[3321,3442,"Wait wait wait wait wait wait."],[3604,3709,"I’m not like you, Marcus."],[3709,3917,"I'm cowardly and I'm fragile."],[3930,4067,"You know, I play video games"],[4067,4143,"and read graphic novels."],[4143,4289,"I'm sarcastic, not ironic."],[4334,4372,"Please."],[4372,4439,"Boss."],[4439,4555,"When those girls out there"],[4555,4622,"see you manning up"],[4622,4739,"and taking one for the team,"],[4781,4906,"you're going to play the sympathy card"],[4906,5027,"for all it's worth."],[5189,5423,"One, two,"],[5548,5669,"three."],[6220,6341,"Oh, you poor thing."],[6345,6449,"Does it hurt?"],[6449,6532,"No, I can handle it."],[6804,6954,"I miss the effortless way"],[6987,7083,"he would navigate"],[7083,7200,"all the madness, you know."],[7379,7475,"Like he was always one"],[7475,7596,"step ahead of everyone."],[7817,7938,"He was everyone's hero,"],[8042,8134,"including mine."],[8322,8438,"And his eyes would light up"],[8438,8559,"when he’d talk about you."],[8726,8843,"He'd say, “Lenny’s"],[8843,8964,"going to be iconic.”"],[9127,9289,"She'll be the one that rewrites history."],[9827,9894,"I miss him."],[10261,10374,"Do you remember that night"],[10415,10495,"when he jumped off"],[10495,10574,"the roof into the pool?"]],"111":[[62,183,"You ready?"],[283,404,"No. Hold on."],[442,562,"Good idea."],[804,921,"It's unfortunate the way you've"],[921,1075,"let yourself go, Beck."],[1075,1196,"Shut up and jump."],[2235,2352,"What?"],[2352,2502,"You, happy."],[2552,2673,"It's nice."],[6335,6456,"Sometimes"],[6539,6648,"I sit and watch"],[6648,6785,"people at the bus stops."],[6969,7115,"I ride the tube and notice"],[7115,7236,"how nobody speaks."],[7398,7503,"They block each other out"],[7503,7624,"with their music"],[7690,7811,"and their phones"],[7916,8037,"and the headlines of the day."],[8070,8187,"And I wonder,"],[8224,8345,"what happened to us?"],[8349,8500,"When did the charlatans"],[8500,8616,"and the con men"],[8696,8800,"and the wicked among us"],[8800,8946,"drive us all away from each other?"],[9063,9113,"I think most"],[9113,9234,"people are good."],[9280,9375,"Some of them are simply"],[9375,9534,"trapped by their circumstances."],[9676,9755,"You're a good person,"],[9755,9876,"Prudence."],[9901,10018,"Whatever your struggle,"],[10201,10326,"whatever circumstance"],[10326,10447,"confines you."],[10547,10668,"I can help you."],[10752,10873,"And I'd like to try."],[10965,11085,"You can't."],[11190,11307,"Sorry."],[11511,11628,"Prudence."],[11961,12078,"You're a good man"],[12166,12287,"and a great king."],[12333,12483,"And that matters immensely"],[12658,12779,"to all of us."]],"112":[[182,336,"Tell me about your parents, Jasper."],[541,637,"Perhaps Your Majesty"],[637,754,"should tell me."],[808,945,"You're an orphan from Shoreditch."],[966,1108,"Hence the elocution lessons."],[1254,1438,"Unless MI6 says otherwise."],[1579,1696,"I must say"],[1696,1792,"your American accent"],[1792,1909,"barely peeks through."],[2101,2167,"Las Vegas"],[2167,2288,"grifters, weren't they?"],[2380,2497,"Swindlers"],[2501,2576,"who moved about like"],[2576,2776,"gypsies, coveting affluence"],[2776,2918,"and teaching their son well."],[2993,3110,"My parents only dreamed"],[3110,3194,"of life at the top."],[3194,3314,"But I touched it"],[3385,3506,"and used it."],[3586,3727,"And Samantha Cook,"],[3840,3982,"did you touch"],[3982,4174,"and use her to."],[4457,4637,"I've done some poking around"],[4637,4762,"into your poking around"],[4762,4883,"bodyguard."],[4924,4954,"You didn't"],[4954,5075,"leave Las Vegas."],[5091,5262,"You were banished by Cy Cooke."],[5283,5421,"The King of the Strip."],[5533,5583,"Apparently,"],[5583,5825,"someone got a little too close"],[5825,5971,"to the king's daughter."],[6134,6213,"You have a type?"],[6213,6347,"Jasper from Shoreditch."],[6547,6589,"You're right."],[6589,6710,"I do have a type."],[6910,7031,"Cy Cook wanted me"],[7031,7202,"gone, and his daughter"],[7202,7327,"was one hell of a girl."],[7327,7577,"But there's just one thing"],[7577,7727,"Your Majesty misconstrued."],[7902,7977,"Wasn't his daughter"],[7977,8094,"I wanted."],[8190,8311,"It was his wife."],[9250,9350,"You've caught me on a good day,"],[9350,9471,"bodyguard."],[9500,9621,"I'm melancholy,"],[9675,9796,"I'm stressed,"],[9838,9996,"and I'm severely horny."],[10130,10255,"Think you have what it takes to earn"],[10255,10372,"my silence?"],[10659,10801,"Don't, let's get ahead of ourselves."],[11068,11143,"Are you familiar"],[11143,11247,"with the expression"],[11318,11481,"at Her Majesty's pleasure?"]],"113":[[73,178,"Oh my God!"],[178,257,"Oh God!"],[257,361,"I’m totally going to die!"],[361,486,"I’m going to bleed out"],[503,620,"and die!"],[1604,1758,"Is this VIP for the girls"],[1758,1896,"who can't have the boys they want."],[2059,2188,"It's not the VIP"],[2188,2367,"for whiney heiresses."],[2522,2643,"I'm not whining."],[2680,2793,"I'll fly some guy out,"],[2793,2918,"be the life of the party,"],[2956,3072,"fake a few orgasms,"],[3072,3193,"and do it all again tomorrow."],[3256,3373,"It's what we do."],[3373,3494,"It's what you do."],[3794,3915,"Fine."],[3919,4015,"It's what we do."],[4407,4528,"I told her"],[4595,4770,"I could be her, but she couldn't be me."],[4945,5066,"But I can't be her."],[5095,5154,"I haven't been her"],[5154,5274,"in years."],[5350,5466,"Too late for that."],[5800,5904,"I get that."],[6196,6430,"But nobody's going to cry"],[6430,6584,"for a diamond heiress"],[6584,6705,"and a princess."],[6730,6847,"Nor should they."],[6951,7039,"But do you remember"],[7039,7197,"the last time you weren’t the girl"],[7197,7385,"the boy just wanted to sleep with?"],[7748,7869,"Tonight, actually."],[9245,9333,"I miss him more"],[9333,9454,"when you're around."],[9654,9775,"I think that's good."],[9992,10113,"I'm glad you're here."],[10192,10292,"I'm proud of you."],[10455,10492,"Why?"],[10609,10697,"You went another day"],[10697,10813,"without the bag."],[10913,11030,"I'm so tired."],[11185,11280,"And what most people do"],[11280,11547,"when they’re tired, they sleep."],[11714,11831,"It's nice"],[11935,12019,"being like this."],[12019,12206,"I almost forgot what it was like."],[12790,12911,"What?"],[13020,13061,"You shot"],[13061,13232,"a man with a ceremonial"],[13232,13353,"bow and arrow."],[13570,13691,"I didn't mean to."]],"114":[[2817,2880,"Apparently,"],[2880,3030,"what lays in Vegas does"],[3030,3226,"not, in fact, stay in Vegas."],[3401,3535,"You’ve served your queen well,"],[3535,3656,"bodyguard."],[7889,8010,"What?"],[8106,8227,"Just watching my girl."],[8269,8390,"It was perfect,"],[8431,8552,"this weekend."],[8569,8686,"Almost."],[8732,8840,"Why almost?"],[8869,9015,"You got all American on me,"],[9015,9157,"and wouldn't get topless at the pool."],[9178,9299,"Oh, really?"],[9370,9486,"You don't think I'll go topless?"],[9486,9553,"I don't think you will."],[9678,9799,"Fine."],[10091,10225,"Here you go, Monaco."],[10225,10346,"Enjoy the view."],[10512,10633,"I can't do it."],[10796,10917,"All part of my plan."],[10984,11101,"I'm glad you couldn’t."],[11234,11297,"Pretty selfish"],[11297,11418,"about the view."],[11559,11614,"I'm always going"],[11614,11735,"to remember this weekend"],[11830,11947,"being here with you."],[12122,12243,"The beginning of us."],[12364,12481,"A perfect line."]],"115":[[989,1110,"I won't do it."],[1143,1264,"The king deserves better."],[1293,1435,"Interesting choice."],[1514,1560,"I'll make sure"],[1560,1739,"the authorities have your home address."],[1744,1881,"And I'll make sure they have yours."],[2061,2140,"You need the monarchy"],[2140,2348,"to be looked upon in a favorable light."],[2373,2490,"So I don't think you'll be"],[2490,2682,"telling anyone about anything."],[2790,2945,"Besides, there isn't"],[2945,3057,"anything you can do to me"],[3057,3178,"that you haven't already done."],[4188,4309,"You ready to go?"],[4329,4446,"I've extended for a week."],[4475,4596,"I'm going to stay."],[5009,5126,"You sure?"],[5147,5293,"I just want to be by myself for a while."],[5293,5335,"You know?"],[6640,6761,"Going somewhere?"],[7053,7174,"To see the Prime Minister."],[7224,7341,"Regarding what?"],[7424,7537,"Nothing you need to know."],[7754,7879,"We all have our secrets,"],[7879,8000,"don't we?"],[8475,8613,"You could, you know?"],[8972,9226,"You said you'd see me every day"],[9226,9347,"if you could."],[9501,9618,"You can."],[9789,9906,"No, I can't."],[10256,10427,"Where was she this weekend?"],[10611,10769,"On tour with the guitar player?"],[11140,11261,"Len..."],[11687,11779,"She doesn't love you"],[11779,11900,"like I do."],[12204,12325,"She's my wife."],[12483,12554,"She wants to give it"],[12554,12675,"another try."],[12855,12976,"I at least owe her that."],[14006,14085,"She doesn't love"],[14085,14206,"you like I do."]],"116":[[273,373,"I think Gemma might have"],[373,457,"had the right idea."],[715,828,"We'll face it all together."],[961,1082,"Your dad."],[1112,1233,"My mum."],[1262,1383,"Press."],[1454,1570,"All of it."],[1954,2029,"You should show them"],[2029,2113,"this side of you."],[2150,2271,"The press, the world."],[2317,2467,"They’d love this version of you."],[2671,2738,"They don't want"],[2738,2859,"this version of me."],[3009,3064,"Try it."],[3159,3214,"When you step"],[3214,3330,"off the plane,"],[3356,3460,"show them the quiet,"],[3460,3660,"kind, enchanting girl I know."],[3760,3898,"Hey, I'm not wrong."],[4277,4398,"Maybe I will."],[4636,4753,"I got to go."],[7430,7539,"Hi, boys."],[7539,7660,"Did you miss me?"],[7873,7968,"Good thing you've already seen me"],[7968,8077,"throw up."],[8077,8114,"Come on."],[8114,8235,"We've done this before."],[8327,8436,"Not like this."],[8544,8569,"Hey."],[8857,8940,"I want you to know"],[9040,9120,"no matter what"],[9278,9370,"I will always be there"],[9370,9428,"for you."],[9583,9704,"There she is."],[9712,9829,"That's my girl."],[10246,10367,"Wait."],[10383,10504,"Say it again."],[10575,10696,"You're my girl."],[10759,10859,"And I want the world"],[10859,10980,"to know it."],[11188,11297,"Let's go to show you off."]],"117":[[4512,4621,"There she is."],[4788,4963,"Right where I want to be."],[5046,5242,"Let's grab coffee at that place you love."],[5242,5430,"Then I'll take you to the studio."],[5459,5584,"You have a rehearsal, right?"],[5584,5705,"I do."],[5851,5930,"You remembered."],[5930,6031,"I did."],[6110,6314,"But, I don't exactly know what it's for."],[6402,6535,"A guest choreographer's"],[6535,6656,"working with us this week."],[6685,6785,"He's a big deal."],[6785,6886,"So what time do you have to"],[6886,6998,"go be awesome?"],[7048,7169,"Mm, not for"],[7169,7290,"several hours."],[9059,9180,"Your Majesty."],[9296,9455,"This had better be damn important."]],"118":[[430,635,"Okay. I think we’re good."],[1444,1573,"Um..."],[1673,1777,"I don't think we are."],[2028,2161,"Oh, my God."],[2161,2282,"I’m so sorry, Ophelia."],[2282,2353,"They must've been hiding"],[2353,2453,"outside the villa."],[2512,2674,"I should've known better."],[2674,2841,"You shouldn't have to know better."],[2929,3083,"\"As riotous images from"],[3083,3150,"a young Royals'"],[3150,3275,"wild weekend go global,"],[3275,3371,"palace informants"],[3371,3588,"say King Simon is close to calling for a"],[3588,3671,"referendum to"],[3671,3809,"abolish the Monarchy.\""],[3905,4005,"Because of Monaco?"],[4005,4126,"There’s nothing between the stories."],[4126,4247,"It's all just gossip."],[4355,4426,"Doesn't mean the press won't"],[4426,4497,"try to make something"],[4497,4589,"out of nothing, though."],[4660,4810,"It's going to be mad out there today."],[4901,5127,"Okay. So what do we do?"],[5248,5423,"They can't change us."],[5481,5560,"I won't let them."],[6274,6365,"We’ll have an official response"],[6365,6432,"for you in one minute"],[6432,6536,"if you would just..."],[6561,6737,"stop talking... please."],[6766,6887,"No, we are not"],[6887,7008,"canceling any events."],[7008,7162,"Yes, the referendum is"],[7162,7283,"a baseless rumor."],[7283,7512,"Palace \"informants\" are misinformed."],[7512,7717,"Grievously misinformed."],[7717,7825,"No, we are not canceling"],[7825,7892,"any events."],[7892,8000,"Yes, the referendum was"],[8000,8130,"baseless rumor."],[8130,8351,"Misinformed... and very lucky we can"],[8351,8518,"no longer cut peoples' heads off."],[9393,9498,"Good morning, Your Royal Highness."],[9498,9619,"I trust you had a good night."],[9635,9706,"Sir, let me just say,"],[9706,9819,"it wasn't Ophelia's fault."],[9819,10023,"I'd like a word with my daughter. Alone."],[10153,10303,"I'll meet you at the car."]],"119":[[507,566,"How you doing,"],[566,649,"Hagrid?"],[866,978,"Where's Jasper?"],[1195,1279,"Perhaps you"],[1279,1362,"ate him?"],[1925,1992,"Come on, then,"],[1992,2117,"Gogmagog."],[2213,2380,"What every father dreams of, eh?"],[2413,2551,"I'm sorry."],[2551,2672,"Don't you realize that they'll brand"],[2672,2801,"you with this for the rest of your life?"],[2901,3060,"If you think I'm not devastated"],[3060,3218,"and beating myself up about this,"],[3218,3293,"then you know me even"],[3293,3406,"less than I thought you did."],[3564,3664,"I'm late for rehearsal."],[3664,3790,"You're not leaving palace grounds with"],[3790,3911,"this craziness going on."],[4006,4094,"It's important."],[4111,4248,"And your safety isn't?"],[4307,4394,"Liam's taking me."],[4394,4478,"Oh, nice."],[4499,4624,"Because he’s done such a great job of"],[4624,4736,"protecting you so far."],[4745,4912,"It's not his job to protect me."],[4920,5070,"No, but it is mine."],[5095,5266,"To shield them from the outside"],[5266,5516,"world, and to shield you from them."],[5637,5725,"I understand that you're"],[5725,5833,"upset with me and"],[5833,5988,"I understand that you're my father,"],[6042,6121,"but that moment was taken"],[6121,6242,"out of context."],[6263,6455,"If the press and the public don't believe"],[6455,6592,"that, or think less of me because"],[6592,6713,"of it, that's one thing."],[6759,6843,"They can decide I'm"],[6843,6964,"some horrible person."],[7105,7339,"But I'd like to think you wouldn't."],[8211,8298,"Hey, you."],[8298,8361,"Hi."],[8500,8561,"All right."],[8561,8765,"So the bad news is your tits"],[8765,8849,"were on the cover."],[8849,8953,"But the good news is that"],[8953,9078,"they look great."],[9178,9333,"They are always going to print"],[9333,9454,"something or other."],[9508,9629,"Try not to let it make"],[9629,9750,"you crazy, Phe."],[9766,9987,"It will get easier. I promise."],[10025,10117,"Thanks, Lenny."],[10117,10158,"Okay."],[10475,10592,"Oh, at least it wasn't"],[10592,10713,"your royal beaver."],[10926,11034,"I hate that you have to put up"],[11034,11172,"with all this scrutiny, just because"],[11172,11260,"you're my girlfriend."],[11456,11660,"Girlfriend, huh?"],[12348,12586,"Paper! Read all about it!"],[12586,12740,"Read all about it!"],[12740,12861,"Royal scandal!"]],"120":[[119,323,"Nothing against Jack and the"],[323,540,"Beanstalk, but I preferred"],[540,661,"the last guy."],[769,907,"Jasper's been reassigned."],[907,1061,"And I've given him a few days'"],[1061,1182,"compassionate leave."],[1295,1457,"Compassionate leave?"],[1457,1578,"The hell for?"],[1624,1845,"He claims that you said, or did, some"],[1845,1966,"things that put him in a"],[1966,2087,"compromising position."],[2166,2267,"You have got"],[2267,2354,"to be kidding me."],[2354,2513,"Well, if he's lying, he'll get three years"],[2513,2654,"for slander against the Crown, and I'll"],[2654,2788,"personally guarantee that you"],[2788,2909,"never have to see him again."],[3076,3309,"Just say the word, Your Highness."],[3572,3856,"Well, maybe I said a couple of things"],[3856,3968,"that might've made him feel"],[3968,4047,"\"uncomfortable\"."],[4264,4364,"Well, then it's all for the best that"],[4364,4485,"he's been reassigned, ey."],[4515,4631,"Reassigned to who?"],[4711,4815,"It's hardly the first time your"],[4815,4973,"offspring have acted out."],[4990,5115,"Parliament insiders have been"],[5115,5265,"gossiping amongst themselves for"],[5265,5315,"weeks about a"],[5315,5424,"possible referendum."],[5424,5566,"There's a big difference between"],[5566,5703,"insider gossip and rumors"],[5703,5841,"published across the globe."],[5841,6024,"Unconfirmed rumors that were"],[6024,6145,"bound to leak."],[6183,6262,"Stool tactics"],[6262,6383,"remain in place."],[6446,6575,"Holloway stands firm?"],[6650,6779,"Firm indeed."],[7080,7276,"I've never seen you this rattled."],[7372,7526,"What aren't you telling me?"],[7726,7885,"Simon went to see the"],[7885,8006,"Prime Minister."],[8006,8102,"Well they meet every week."],[8102,8181,"It's tradition."],[8197,8310,"It's tradition when the"],[8310,8431,"PM comes here."],[8519,8656,"The King went to him."],[8698,8761,"When?"],[8811,8906,"Yesterday."],[8927,9061,"And he was deliberately"],[9061,9182,"mysterious about it."],[9249,9470,"Find your brother, and find"],[9470,9678,"a way to reason with him, one"],[9678,9828,"way or another."],[10341,10454,"The next piece of news better be"],[10454,10521,"good, or I will"],[10521,10642,"indeed kill the messenger."],[10729,10863,"The Dragon King of Maruvia is demanding"],[10863,11025,"demanding a formal apology."],[11113,11288,"Apparently he noticed it was his"],[11288,11396,"ceremonial bow that was aimed"],[11396,11488,"Omar Kayif."],[11488,11559,"Kayif?"],[11613,11734,"As in the oil cartel?"],[12005,12197,"You bagsied my bodyguard?"],[12197,12281,"Get out."],[12281,12335,"You took Jasper"],[12335,12456,"for your detail?"],[12460,12552,"Now."],[12952,13098,"Could this day get any worse?"],[13344,13407,"What?"],[13599,13753,"The Grand Duchess of Oxford"],[13753,13828,"is at the gates."],[14074,14258,"F-M-L."]],"121":[[1239,1460,"All rise for the Grand Duchess"],[1460,1635,"Alexandra of Oxford!"],[1902,2081,"Your Majesty."],[2081,2165,"Mother."],[3908,4121,"I see you've re-decorated."],[4121,4217,"I'd love to know whatever"],[4217,4325,"possessed you to choose"],[4325,4451,"Vegas as your theme."],[4605,4784,"Oh, shoo, shoo, shoo, shoo."],[4784,5018,"I want to be alone with my baby."],[5397,5635,"Well, this is a goddamn mess."],[6265,6461,"They'll say anything to get a reaction."],[6519,6598,"Don't give it to them."],[6598,6694,"They'll capture it,"],[6736,6865,"and one frame is all they need."],[7287,7420,"No biggie."],[7583,7775,"You're beautiful. No wonder they"],[7775,7896,"want your picture."],[9593,9768,"Prince Liam! Your Highness!"],[9768,9848,"Over here!"],[9848,9969,"Bill. Oliver."],[9969,10089,"Will the King call for abolition?"],[10089,10177,"Is there a connection?"],[10177,10336,"Sam, you know you published"],[10336,10381,"those pictures"],[10381,10552,"out of context, so does he."],[10569,10686,"What do you say about referendum"],[10686,10807,"rumors? Will it happen?"],[10819,10986,"The King is a more than reasonable"],[10986,11153,"man who isn't about to do anything rash."],[11236,11382,"Now, sorry, gents, we have to go."],[11837,12058,"See? Like you said,"],[12121,12208,"no biggie."],[12275,12329,"Yeah."]],"122":[[1023,1157,"The Wedding Ring of England."],[1265,1461,"Thinking of getting a divorce?"],[1657,1878,"I am the product of a medieval"],[1878,2033,"hereditary sweepstake."],[2104,2325,"Here by chance, not by divine"],[2325,2462,"right as was once"],[2462,2583,"believed."],[2583,2663,"What do you believe"],[2663,2784,"in, brother?"],[2888,3067,"Destiny? Fate?"],[3067,3209,"Aren't those just other words"],[3209,3305,"for \"God\"?"],[3347,3568,"Fate put you on the throne,"],[3568,3726,"and fate dares you now to"],[3726,3835,"hold the line."],[3893,3989,"More than a thousand"],[3989,4110,"years of rule."],[4135,4314,"After all those centuries,"],[4314,4498,"this is what ends it?"],[4581,4752,"Your kids have too much fun."],[4786,4911,"Your wife doesn't wait up for"],[4911,5032,"you when you come home."],[5061,5161,"You're stronger than that,"],[5161,5324,"brother. I know you are."],[5386,5603,"Plagues, wars, communism,"],[5603,5724,"Nazis."],[5724,5849,"Everyone before you"],[5849,5970,"held the line."],[6028,6199,"And so will you, my King."],[6199,6354,"Save your breath."],[6642,6788,"The burden of this decision"],[6788,7029,"rests with me, brother."],[7230,7405,"When the Monarchy ends,"],[7513,7613,"I'll know my place in it."],[7834,8018,"Not when. If."],[8060,8222,"The people haven't spoken yet, and"],[8222,8402,"you might find they disagree."],[8464,8585,"They believe in the Monarchy."],[8602,8773,"I believe in the Monarchy."],[8802,8915,"The only one who"],[8915,9023,"doesn't is you."],[9081,9182,"If you try and do"],[9182,9286,"away with the Crown,"],[9286,9490,"they'll think you've lost your mind."],[9490,9578,"They won't understand"],[9578,9649,"your reasoning,"],[9649,9878,"and they won't vote yes."],[9928,10070,"The people need the"],[10070,10191,"magic, brother."],[10224,10324,"You'll be robbing them of the"],[10324,10470,"Kingdom's greatest and"],[10470,10658,"most defining virtue."],[10741,10950,"You really think so little of the"],[10950,11071,"people themselves?"],[11250,11409,"They are this Kingdom's"],[11409,11530,"greatest virtue."],[11588,11726,"Then perhaps they'll keep"],[11726,11847,"the Monarchy..."],[11872,12043,"and abolish you."]],"123":[[3837,4029,"Sorry. You were just so damn good."],[4054,4142,"Sir. We've been summoned"],[4142,4238,"back to the Palace."],[4271,4359,"We'll go when Ophelia's done."],[4400,4567,"I'm sorry, sir, but it was an order."],[4592,4726,"The Dragon King doesn't appreciate"],[4726,4851,"that his sacred bow and arrow"],[4851,4934,"was aimed at a petrol"],[4934,5105,"tycoon who's threatened an oil"],[5105,5305,"embargo, among other things."],[5326,5472,"The guy I almost shot?"],[5581,5681,"Oh, my God, Liam, go."],[5718,5852,"An international incident is"],[5852,5943,"slightly more important."],[5973,6060,"Marcus please, stay with her."],[6089,6260,"Sir, I need to stay with you."],[6260,6377,"But if I may suggest one of the others..."],[6377,6427,"No."],[6431,6586,"I want my best guy with Ophelia."],[6728,6903,"My last boyfriend gave me flowers."],[6903,7136,"This one gives me his best bodyguard."],[7136,7207,"So sweet."]],"124":[[176,247,"So..."],[368,434,"Is it true?"],[509,689,"They’re simply rumors."],[689,847,"Don't lie to me, Helena."],[943,1060,"You have failed."],[1060,1235,"As a wife, as a mother, as a"],[1235,1456,"daughter, and most devastatingly"],[1456,1694,"of all... as a queen."],[1794,1953,"Simon's only thinking about"],[1953,2049,"this nonsense, Mother."],[2078,2207,"He's not going to act on it."],[2207,2336,"Are you sure about that?"],[2407,2532,"Have you not forgotten everything"],[2532,2628,"that was done to get you on"],[2628,2791,"the throne in the first place?"],[2941,3087,"I'll never forget what you did."],[3150,3237,"Oh, grow up."],[3237,3421,"The most ridiculous con of the modern"],[3421,3596,"world is that everyone pretends"],[3596,3754,"not to be self-interested."],[3809,3900,"And I'm not ashamed to"],[3900,4009,"admit it."],[4009,4188,"Naked ambition and ruthless"],[4188,4409,"determination are what ensures"],[4409,4580,"the survival of the Monarchy."],[4689,4872,"So, for the sake of your family legacy, I"],[4872,5093,"sincerely hope that you can bolster"],[5093,5218,"Simon's backbone."],[5268,5398,"You always knew he was"],[5398,5477,"his own man."],[5477,5615,"Oh, forgive me."],[5631,5831,"There was only one King of England"],[5831,5952,"to choose from."],[5952,6069,"Don't I get any credit for"],[6069,6140,"what I did?"],[6157,6336,"Don't I get any credit for securing"],[6336,6470,"you that grand title you"],[6470,6607,"love so very dearly?"],[6670,6757,"Don't I get any credit for"],[6757,6903,"the sacrifices I made?"],[6937,7137,"Oh, please don't tell me that you are"],[7137,7350,"still pinning for that low-born"],[7350,7491,"Alistair Lacey."],[7533,7754,"How many times have I told you"],[7788,7946,"that having a little fling on the"],[7946,8067,"side can keep your"],[8067,8188,"marriage fresh."],[8217,8397,"But having feelings is quite"],[8397,8517,"another matter."],[8547,8672,"I've kept my feelings"],[8672,8793,"well contained."],[8793,9022,"Good. Because, in times of war, one"],[9022,9227,"must not be distracted by sentimentality."],[9227,9448,"You cannot possibly run a life, a family"],[9448,9635,"let alone an empire that way."],[9656,9852,"She who fears the thorn"],[9852,10073,"should never grasp the rose."],[10132,10323,"Get your house in order."],[10323,10519,"Things are under control, Mother."],[10519,10728,"Mm... Are they?"],[10791,10916,"They soon will be."],[10966,11149,"Roses and thorns, Helena."],[11170,11358,"And if this goes the way the papers are"],[11358,11571,"saying, history will never forgive"],[11571,11750,"you, and neither will I."],[11925,12121,"Speaking of roses, I'll take my tea in"],[12121,12275,"the ornamental gardens."],[12300,12401,"They were planted by Queen"],[12401,12521,"Victoria, you know."],[12609,12726,"Yes, mother."],[12726,12889,"Mm. She wouldn't have allowed"],[12889,13009,"this to happen."],[13072,13268,"Ah, me, well, I'd best go and enjoy it."],[13268,13406,"Perhaps the last tea that I'll"],[13406,13556,"ever take at this palace."]],"125":[[17,184,"Ophelia, you did a wonderful"],[184,264,"job today."],[314,426,"Oh, my gosh! Mr. Evans."],[426,547,"Thank you so much."],[572,764,"I'm sorry about all the... fuss."],[764,910,"Your life out there is your life."],[910,1043,"We leave all that at the door."],[1119,1310,"Lee Ballantine is a good friend of mine,"],[1310,1402,"and there’s a couple of spaces"],[1402,1515,"opening up in his company."],[1540,1736,"Mr. Evans, that would be amazing."],[1736,1831,"You deserve the shot."],[1888,1999,"You've worked hard for it."],[2078,2270,"Auditions start in one short week."],[2303,2449,"Don't let me down, honey."],[2837,3054,"That sounds like a big opportunity."],[3054,3246,"It's huge. Ballantine..."],[3246,3408,"His company, I mean..."],[3433,3634,"If I even got in..."],[3634,3763,"But it is in"],[3763,3846,"New York."],[4109,4272,"Marcus, don't tell Liam"],[4272,4393,"about this, okay?"],[4459,4564,"I don't want to tell him unless"],[4564,4655,"it becomes real."],[4655,4730,"Of course."],[4801,5018,"But... you'll get it."],[6065,6270,"You wanted to see me, Your Majesty?"],[6270,6453,"Where the hell is the King?"],[6453,6628,"I'm sorry, but I can't say."],[6716,6878,"The Queen of England is asking"],[6878,6999,"you where her husband is."],[7016,7154,"The King of England asked me"],[7154,7233,"not to tell you."],[7291,7404,"Have you any idea what"],[7404,7500,"your incompetence"],[7500,7688,"as a parent has cost my family?"],[7721,7921,"How deeply your child has done"],[7921,8042,"damage to mine?"],[8050,8121,"And what of the damage"],[8121,8209,"to Ophelia?"],[8267,8347,"Her reputation."],[8455,8626,"Some reputations are more"],[8626,8789,"important than others."],[8931,9152,"The nation's next in line should be here"],[9152,9360,"apologizing to international men of"],[9360,9498,"consequence, on your daughter's"],[9498,9619,"behalf, I might add."],[9665,9886,"But instead he had to accompany"],[9886,10086,"her to a ballet lesson."],[10111,10244,"His Highness insisted"],[10244,10315,"on accompanying"],[10315,10419,"Ophelia because she doesn't have"],[10419,10520,"her own detail yet."],[10520,10582,"Yet?"],[10820,11062,"Only an official, Palace-sanctioned"],[11062,11204,"relationship warrants"],[11204,11325,"a detail."],[11341,11546,"And far from being Palace-sanctioned,"],[11546,11717,"your daughter is just my son's"],[11717,11875,"trifle of the week."],[11904,12046,"She will never have"],[12046,12167,"her own detail."],[12180,12288,"Is that understood?"],[12367,12476,"Good."],[12526,12634,"Walk away."],[13106,13226,"Rachel!"],[13602,13748,"Get me whichever tabloid"],[13748,13869,"rat owes us a favor."],[13894,14086,"Clear the lines with MI5 for taps, and I"],[14086,14207,"only want to talk to the top."],[14207,14315,"Get me Rupert bloody Murdoch"],[14315,14436,"on the phone if you have to."],[14444,14499,"Yes, Your Majesty."]],"126":[[741,800,"Jeffries."],[1063,1154,"Your Majesty?"],[1313,1417,"Oi! American slut!"],[1417,1517,"Show us your tits!"],[1517,1667,"You'll make the wank bank."],[1701,1780,"What would your mother think"],[1780,1888,"of you now, Ophelia?"],[2080,2168,"What did you say?"],[2201,2255,"I said what would your"],[2255,2376,"mother think of you now?"],[2414,2489,"Your mother..."],[2489,2643,"Was she an American slut too?"],[2677,2827,"Shut up!"],[3569,3744,"My ducklings!"],[3744,3865,"Grand mama."],[3865,4086,"Pass the Dutchie!"],[4370,4545,"Oh, my poor old heart can hardly"],[4545,4812,"take it, you're both so divine."],[4862,5000,"Look at you."],[5000,5112,"A Demi-God since the"],[5112,5233,"day you were born."],[5263,5363,"And, Eleanor..."],[5492,5650,"Darling, you're much too thin."],[5655,5759,"Don't you know men like a bit of"],[5759,5851,"meat on the tail"],[5851,6001,"before they shuck the lobster."],[6026,6076,"You're not on another"],[6076,6143,"diet, are you?"],[6209,6372,"Just coke and caviar, Gran."],[6372,6539,"Oh caviar I approve."],[6539,6660,"It's a superfood."],[6697,6852,"But coke will rot your teeth."],[6973,7089,"Come on."],[7181,7377,"Well, it's alright for you to laugh."],[7377,7498,"I'll be dead soon enough,"],[7498,7619,"and then you'll be crying."],[7636,7803,"Grandma, you'll outlive us all."],[7803,7957,"You better tell your sister to eat."],[7957,8153,"She deserves the whole cake, and"],[8153,8274,"not just the crumbs."],[8274,8357,"Don't you agree?"],[8357,8499,"I do indeed."],[8520,8658,"Just think of all those poor women on"],[8658,8895,"on the Titanic that said no to dessert."],[8929,9029,"Uh, so sad."],[9100,9296,"What have I always told you, darling?"],[9296,9458,"\"A woman's mind must always be"],[9458,9663,"sharper than a man's, but her"],[9663,9846,"body must always be softer.”"],[9888,9980,"Perfect."],[10026,10167,"And now I have"],[10167,10288,"a little..."],[10313,10451,"Just a little something for you."],[10451,10543,"Oh!"],[10610,10851,"Oh... Dutchie!"],[11031,11160,"It isn't anything that I wouldn't"],[11160,11252,"have left you in my will."],[11252,11410,"But don't tell your mother."],[11460,11648,"She's always had her eye on it."],[11652,11794,"What have I always had my eye on?"]],"127":[[18,202,"Go on. Show it to her, otherwise"],[202,302,"she'll sulk."],[435,544,"The Prima Flame."],[611,731,"Really, Mother?"],[731,873,"Darling, you know that diamonds"],[873,973,"don't suit you."],[1023,1161,"Mum..."],[1219,1365,"I spoke with the Dragon King"],[1386,1474,"and the oil baron."],[1474,1582,"It's all getting sorted."],[1607,1712,"I'm taking them to the Chelsea"],[1712,1878,"match, next week, in the Royal box."],[1878,1970,"Let's hope there is a"],[1970,2112,"Royal box next week."],[2166,2283,"Have either of you seen your father?"],[2316,2450,"There are times when one should"],[2450,2617,"not know where one's husband is."],[2629,2771,"But this is not one of them."],[2834,3000,"The Grandest D of all."],[3046,3138,"Should've guessed you'd be"],[3138,3251,"paying a visit."],[3292,3438,"Come here and kiss"],[3438,3559,"the ring, you."],[3580,3789,"Ooh, darling, which one?"],[3839,4014,"Well, if I was a younger woman,"],[4014,4135,"I would say both."],[4281,4327,"What are you"],[4327,4548,"going to do if the Monarchy ends?"],[4573,4669,"Probably go on tour with a"],[4669,4840,"salacious autobiography."],[4840,4965,"You've certainly got enough"],[4965,5086,"material for that."],[5169,5294,"Oh, you are such"],[5294,5415,"a devil."],[5445,5666,"And I am a sucker for that"],[5666,5862,"cleft chin of yours."],[5862,5978,"And there I was thinking"],[5978,6095,"it was my hooves."],[6249,6329,"Cyrus."],[6429,6512,"Cyrus."],[7017,7163,"Liam, come."],[7163,7346,"Well?"],[7384,7605,"It's iffy at best."],[7676,7809,"I think I found Dad."],[7930,8060,"People of Great Britain and the"],[8060,8243,"Commonwealth, when crowned"],[8243,8485,"King, I took a solemn oath to"],[8485,8748,"serve you all, to put the welfare"],[8748,8902,"of this nation first."],[8965,9111,"I do so today..."],[9215,9386,"by formally calling for a"],[9386,9594,"referendum for the abolishment"],[9594,9695,"of the Monarchy."]],"128":[[80,226,"I have no speech written today."],[381,514,"I just want to talk to you from the"],[514,706,"heart, directly to"],[706,852,"you, the people..."],[881,1035,"in the hope that you understand"],[1035,1140,"my reasoning."],[1231,1377,"The modern Monarchy is nothing"],[1377,1548,"more than ceremonial window"],[1548,1794,"dressing, with pageantry and"],[1794,2078,"ritual, but no true impact on"],[2078,2237,"your very real lives."],[2332,2554,"I am ashamed of the blatant"],[2554,2820,"excesses of this family, who"],[2820,2991,"have done nothing to earn their"],[2991,3137,"elevated position."],[3250,3434,"A life so advantaged,"],[3538,3692,"and yet so uniquely"],[3692,3909,"constrained, has turned"],[3909,4034,"my once proud and"],[4034,4163,"principled family..."],[4347,4531,"into a pack of zoo animals."],[4581,4731,"They behave no better..."],[4797,4989,"and are merely gawked at by those"],[4989,5139,"they are meant to serve."],[5244,5465,"I have failed as a father to a family..."],[5590,5657,"and as a father"],[5657,5778,"of this nation."],[5844,6065,"For years I felt it was my duty"],[6065,6232,"to wear the crown."],[6232,6441,"But, like you, my"],[6441,6558,"first duty is to be a"],[6558,6779,"parent, a husband..."],[6891,7046,"a person of integrity who does"],[7046,7204,"what's best for his family."],[7304,7429,"I think this is what is best for"],[7429,7713,"mine, and for the family of this"],[7713,7846,"nation as a whole."],[7921,8072,"Look into your hearts."],[8130,8305,"I have looked into mine."],[8414,8635,"Britain will always be great."],[8664,8785,"Not because of the empty"],[8785,8968,"symbolism of a corrupted crown,"],[9027,9168,"but because of you..."],[9285,9410,"each one of you."],[9448,9586,"And this nation will be greater"],[9586,9786,"still once every citizen is his or"],[9786,9961,"her own king or queen."],[10061,10190,"This I firmly believe,"],[10349,10607,"and it is why, after much solemn"],[10607,10733,"thought, I have taken"],[10733,10808,"this action."],[10858,11004,"Your Prime Minister is in full"],[11004,11179,"agreement, and a bill"],[11179,11300,"is being prepared."],[11379,11446,"It will be brought to"],[11446,11550,"the floor of Parliament"],[11550,11671,"tomorrow morning, at which time"],[11671,11796,"I shall sign it."],[11996,12121,"Once I do this..."],[12288,12434,"the decision will be yours."],[12514,12701,"And I urge you, in the strongest"],[12701,12805,"of terms, to vote"],[12805,12926,"yes..."],[12960,13114,"to end my reign..."],[13439,13581,"to abolish the Monarchy."],[13690,13907,"Well, unprecedented."],[13907,14057,"After reporting on the Royal"],[14057,14269,"Family for more than 25 years,"],[14299,14420,"I'm simply stunned."],[14482,14603,"But there you have it, the King"],[14603,14657,"has spoken."],[14703,14920,"He made his position clear and"],[14920,14987,"it's now down to the"],[14987,15137,"electorate to decide..."],[15137,15433,"Oh... F-M-L!"]],"129":[[217,300,"Shit just got"],[300,421,"real, huh?"],[563,726,"The fading days of a crumbling"],[726,901,"empire, on our watch."],[1138,1180,"I never thought he'd"],[1180,1301,"actually do it."],[1418,1526,"And it's my fault."],[1822,1985,"Don't go there."],[2069,2223,"Those pictures from Monaco were"],[2223,2390,"bad, but not that bad."],[2390,2506,"I asked Dad for a chance to show him"],[2506,2711,"I could do better, and I failed."],[2736,2953,"All you did the whole weekend"],[2953,3099,"was love it up with Phe."],[3140,3316,"And Dad is thrilled that you're"],[3316,3470,"with a nice girl for once."],[3516,3699,"Yeah, she went all Robin"],[3699,3875,"Hood on some oil baron's"],[3875,4079,"ass, but she did it"],[4079,4200,"to protect you."],[4258,4404,"I think Ophelia deserves a"],[4404,4525,"medal for bravery."],[4763,4863,"\"Zoo animals.\""],[4863,4942,"Hey."],[5038,5184,"You're doing really great"],[5184,5430,"lately and Dad sees that."],[5522,5760,"This can't all be about Monaco."],[5864,6048,"To be honest, I don't think we're"],[6048,6177,"seeing the whole picture."],[6331,6373,"I think there's a"],[6373,6477,"whole piece missing."],[6586,6702,"I'll talk to Dad."],[6761,6886,"We'll have a heart-to-heart."],[6961,7132,"He'll get it. I promise."],[7345,7562,"Come here. It's okay."],[7974,8129,"Don't know what I'd do without you, Len."],[8129,8362,"Hey, what are sisters for?"],[8763,8892,"I know my announcement"],[8892,8984,"might have left"],[8984,9176,"some of you feeling anxious,"],[9292,9476,"but I'm making a personal guarantee"],[9476,9609,"that you will all be taken care of,"],[9609,9751,"no matter what happens."],[9893,9993,"I'd like you to convey this"],[9993,10114,"guarantee to the rest of the staff."],[10590,10748,"Is Prudence on duty today?"],[10827,11078,"I'm sorry, Your Majesty, but..."],[11078,11257,"we were instructed to let her go."],[11344,11420,"By whom?"]],"130":[[396,575,"You just couldn't help yourselves."],[675,867,"You had to run off the last person in"],[867,1038,"this house with integrity."],[1038,1276,"I'm sorry. Who are we talking about?"],[1276,1359,"Prudence."],[1464,1547,"Really?"],[1610,1831,"We just took care of your little crush"],[1831,2010,"before she became a problem."],[2010,2168,"You could've slept with her, instead of"],[2168,2323,"fawning like a teenager."],[2348,2473,"Shut your mouth."],[2565,2706,"It wasn't romantic."],[2752,2882,"It wasn't sexual."],[2982,3157,"No-one here would understand that."],[3157,3286,"You had to turn it into"],[3286,3407,"something it wasn't."],[3532,3699,"That's why this has to end."],[3762,3933,"A person with true nobility has"],[3933,4037,"been banished..."],[4141,4266,"But you're still here."],[4450,4567,"Well, not for long."],[4729,4854,"You should both be ashamed"],[4854,4925,"of yourselves."],[5434,5547,"You won't be seeing any of"],[5547,5668,"your lovers any more."],[6026,6131,"And you..."],[6310,6427,"You'll be stripped of all"],[6427,6548,"titles and capital."],[6752,6865,"You're out."],[7107,7198,"And you're out."],[7357,7515,"To hell with both of you."],[7570,7782,"For God's sake, get a hold of yourself."],[7958,8133,"The only reason you're still here is"],[8133,8337,"because you have a ring on our finger."],[8450,8667,"Not any more. Bitch."],[8850,9038,"Then you lied to the people."],[9038,9146,"You said you were going to be a better"],[9146,9351,"father, a better husband."],[9467,9555,"That's right."],[9676,9864,"I did lie to the people when I said"],[9864,10072,"I hope to be a better husband."],[10210,10397,"I don't plan on being your husband"],[10397,10493,"for another day."],[10598,10794,"Your reign of terror is over."],[10794,11006,"From now on, the throne"],[11111,11269,"is just a piece of furniture..."],[11386,11586,"and that ring on your finger"],[11586,11741,"is just a stone."],[11816,11987,"Marriages can end."],[12124,12216,"Monarchies"],[12216,12337,"can end."],[12516,12712,"It's over."]],"131":[[347,451,"Dad..."],[618,810,"Liam's really beating himself up."],[922,1114,"But honestly, Dad, those photos"],[1114,1314,"from Monaco were out of context."],[1594,1811,"Was your roll out of context?"],[1977,2148,"It wasn't like that this weekend."],[2278,2415,"I was sober the whole time."],[2507,2645,"And what about at the garden party?"],[2728,2845,"The charity events."],[2895,2962,"The drugs?"],[3137,3258,"The disrespect."],[3379,3571,"Eleanor, I go easy on you."],[3646,3767,"I know."],[3767,3892,"Waiting for you to be who"],[3892,4009,"I know you can be."],[4280,4401,"But I've waited too long."],[4509,4630,"You once asked"],[4651,4768,"if you disappoint me."],[4910,5093,"It breaks my heart to say it."],[5260,5389,"I am disappointed in you."],[5581,5702,"I really am."],[5869,6111,"At least give Liam another chance."],[6236,6365,"Dad, you can't deny he's"],[6365,6536,"the one person in this family"],[6595,6745,"who's been trying to change."],[6937,7057,"Please."],[7320,7441,"Len."],[7750,7883,"No, Dad, you're spot on."],[8096,8217,"We both know it."]],"132":[[811,932,"No, no. Ted."],[1023,1140,"Do come in."],[1244,1369,"Sorry to disturb, sir."],[1478,1578,"I just wanted to go over"],[1578,1711,"some security protocol,"],[1711,1887,"considering the changes"],[1887,2008,"that might be happening soon."],[2028,2145,"Of course."],[2174,2295,"I should have spoken with you."],[2633,2758,"What do you think about all this?"],[2829,2921,"I think it matters more"],[2921,2988,"what you think."],[3084,3225,"I think there's a chance"],[3246,3392,"of happiness out there."],[3455,3584,"Outside of these walls,"],[3618,3809,"I can rebuild my family."],[3905,4026,"We'll be together again."],[4168,4289,"A time to heal."],[4739,4860,"No time like the present."],[4931,5086,"We'll talk business later, Ted."],[5127,5248,"Of course, Your Majesty."],[6237,6362,"You said you failed as a father."],[6483,6558,"But the truth is,"],[6558,6687,"I failed as a son."],[6804,6862,"This is happening"],[6862,6983,"because I let you down."],[7263,7338,"There's a lot more"],[7338,7509,"goes into something as serious"],[7509,7626,"as this."],[7697,7863,"You deserve to hear everything."],[7997,8151,"Meet me in the tunnels tonight."],[8285,8406,"Take a walk with me."],[8514,8639,"Come see what I see."],[8806,8927,"Just me and you."],[9098,9265,"Not as king and heir."],[9423,9544,"Father and son."],[9674,9807,"I’ll be there."],[11146,11267,"Oh, I hate my mother."],[12268,12339,"What are you holding?"],[12439,12627,"Is the Queen of England"],[12627,12952,"asking me for drugs right now?"],[13002,13064,"Yes."],[13102,13248,"Don't make me ask twice, please."],[13507,13586,"Any other day,"],[13586,13711,"I'd be happy to help you"],[13711,13774,"Mum but Dad's"],[13774,13890,"disappointed in me, so..."],[14211,14374,"Well, he's not the only one."]],"133":[[232,344,"I’m going out tonight."],[365,486,"Just my father and me."],[507,603,"I need you to look the other way."],[603,724,"It's important for me."],[782,895,"How'd it go with the paps?"],[1024,1120,"You haven't seen?"],[1120,1220,"My phone was blowing up"],[1220,1366,"after that speech, so I shut it off."],[1487,1608,"What?"],[1662,1783,"What happened?"],[2242,2359,"Shut up!"],[2563,2638,"She's safe, Sir."],[2638,2755,"They didn't touch her."],[2784,2980,"Just said some things."],[3864,4015,"Ophelia and I are officially"],[4015,4131,"in a relationship."],[4173,4256,"She'll be getting her own"],[4256,4377,"security detail from now on."],[4536,4661,"It hardly matters now."],[6897,7018,"What are you doing here?"],[7080,7168,"You have so much to"],[7168,7297,"deal with right now."],[7672,7889,"Who? Future former Prince."],[8427,8548,"Where else would I want to be"],[8602,8723,"other than here with you?"],[8865,8986,"What are you reading?"],[9253,9374,"It was my mom's."],[9487,9608,"There's one page with the corner"],[9608,9729,"turned down, I."],[9766,9929,"I keep wondering why that page."],[10041,10162,"Have you figured it out?"],[10725,10855,"“Having a soul means"],[10855,10984,"being able to feel the love"],[11013,11180,"and loyalty and gratitude.”"],[11322,11443,"Maybe that line."],[11568,11689,"She was full of those things."],[11902,12023,"I’m sad I never got to know her."],[12114,12235,"But if she was anything like you, then"],[12235,12298,"then I know she was"],[12298,12377,"an amazing woman."],[12690,12811,"She was my best friend."],[12957,13074,"She's gone."],[13128,13366,"And my father is a stranger to me."],[13395,13482,"Hey."],[13762,13874,"You’re not alone."],[14729,15001,"Stay, just for a little while."]],"134":[[1252,1419,"Rhodesia was Britain's"],[1419,1540,"greatest warrior queen."],[1586,1724,"She had knives affixed"],[1724,1857,"to the wheels of her chariot"],[1874,1982,"to cut the legs off"],[1982,2116,"invading armies."],[2182,2379,"I suggest that you sharpen yours."],[2504,2637,"The vote has not yet reached"],[2637,2808,"the people, so you still have time."],[2937,3058,"Bleak as things are,"],[3100,3284,"the war is not over."],[3338,3496,"You will find the strength to do"],[3496,3617,"what's necessary."],[3722,3842,"Just as I did."],[4364,4481,"Courage."],[7192,7313,"What time is it?"],[7659,7780,"My dad."],[7817,7934,"I've got to go."]],"135":[[283,363,"What would your mother think of"],[363,509,"you now, Ophelia?"],[784,863,"What would your mother think of"],[863,1009,"you now, Ophelia?"],[1097,1176,"What would your mother think of"],[1176,1322,"you now, Ophelia?"],[1414,1493,"What would your mother think of"],[1493,1639,"you now, Ophelia?"],[1768,1847,"What would your mother think of"],[1847,1993,"you now, Ophelia?"],[2031,2185,"She'd be proud and happy that I found"],[2185,2306,"someone dear to my heart."],[4162,4279,"Holloway's out"],[4329,4450,"in more ways than one."],[4533,4684,"“Do to me what you will."],[4684,4846,"I cannot help you now.”"],[5851,6018,"There’s no way out of this."],[6127,6252,"There's always a way."]],"136":[[248,340,"Dad!?"],[607,669,"Dad!?"],[5645,5741,"It's almost over."],[6909,7026,"Here you go, Mum."],[11930,12025,"Out!"],[12273,12377,"Open the gate!"],[12444,12594,"Step away from the gates."],[12940,13061,"I am the King of England."],[13357,13478,"Open the gates!"],[13507,13628,"Open the gate!"],[13716,13833,"The King's been attacked."],[13920,14033,"The King is down!"]],"137":[[421,646,"I solemnly promise and swear"],[646,846,"to govern and rule the people"],[846,963,"of the United Kingdom,"],[1001,1121,"the British monarchy,"],[1188,1322,"and its overseas territories."],[1426,1543,"I promise to make law"],[1572,1672,"and cause justice"],[1672,1797,"to the utmost of my power."],[2035,2181,"I promise to maintain the true"],[2181,2302,"profession of the gospel."],[2523,2673,"I will execute my judgments"],[2673,2794,"with mercy."],[2877,3028,"I will be benevolent and noble"],[3028,3128,"in matters of conscience."],[3132,3328,"Where are you taking me?"],[3486,3616,"I will gravely castigate"],[3616,3745,"those who betrayed the crown."],[3883,4012,"All this I promise to do."],[4137,4245,"So help me God."],[4938,5055,"What is this?"],[5059,5163,"What's happening?"],[5163,5276,"If I were a betting man,"],[5276,5438,"I'd say we were under attack."],[5555,5676,"Where's Dad?"],[5976,6043,"Dad?"],[6227,6335,"Security level one."],[6335,6460,"Marcus, secure the tunnel."],[6460,6581,"Mr. Frost, with me."],[6756,6877,"Where's our father?"],[7282,7365,"A short while ago,"],[7365,7511,"His Majesty the King was found"],[7511,7582,"by Royal Guard"],[7582,7749,"just outside the gates of the palace."],[7836,7953,"He'd been attacked."],[8003,8128,"What type of attack?"],[8179,8350,"He was stabbed several times."],[8400,8500,"By who?"],[8500,8679,"His assailant is as yet undetermined."],[8683,8833,"We've initiated emergency protocol"],[8833,8971,"and both MI5 and MI6"],[8971,9042,"have been notified."],[9046,9171,"Where's the king now?"],[9171,9234,"In surgery."],[9242,9363,"But he's going to be okay?"],[9413,9492,"He'll live."],[9492,9630,"It's too soon to tell."],[9634,9780,"He's lost a lot of blood."],[9880,10001,"Who could have done this?"],[10372,10493,"Sir, it's Marcus."],[11298,11419,"Liam."],[11490,11615,"Absolutely not."],[11619,11790,"Sir, emergency protocol dictates..."],[11790,11941,"That Ophelia should not be here."],[11961,12078,"She's safest here."],[12103,12241,"You're out of line, Marcus."],[12266,12370,"Sir, with all due respect,"],[12370,12458,"she's the girlfriend of"],[12458,12533,"the Prince Regent."],[12604,12758,"This plan was instituted by you."],[12762,12958,"I'm simply following orders, sir."],[13121,13200,"What does it matter"],[13200,13321,"if Liam's slut of the hour"],[13321,13442,"is here or not?"],[13488,13617,"How long before"],[13617,13738,"any news of the King?"],[13738,13855,"I want to see him."],[13855,13959,"Nobody leaves this room"],[13959,14097,"until we are absolutely certain"],[14097,14218,"that the palace is secure."],[14218,14376,"Until then, we wait."],[14401,14522,"Ophelia."]],"138":[[135,256,"Liam."],[310,431,"Look at me."],[727,848,"Everything's different now."],[898,1015,"You need to be prepared."],[1061,1177,"I was supposed to be with him."],[1198,1273,"That doesn't matter."],[1273,1398,"How can you say it doesn't matter?"],[1457,1574,"Because it's done."],[1720,1907,"You are now the Prince Regent."],[2003,2124,"Do you understand me?"],[2158,2278,"Dad will be okay."],[2358,2479,"Darling..."],[2483,2645,"The moment your father was stricken,"],[2645,2837,"you became Prince Regent."],[3017,3138,"You are the acting"],[3138,3267,"King of England."],[4351,4468,"It's my fault."],[4572,4693,"I should have been with him."],[4739,4835,"He asked me to join him."],[4835,4864,"But I just-"],[4864,4981,"But you were with me."],[5090,5211,"I'm sorry."],[5248,5369,"What are they saying?"],[5382,5498,"Do you have an update?"],[5498,5619,"The King is in surgery."],[5619,5744,"Yes, the King is in surgery"],[5744,5828,"because he's been stabbed."],[5828,5936,"I understand. You said that,"],[5936,6053,"but when was he stabbed?"],[6057,6153,"How? Why?"],[6153,6282,"And why weren't you with him?"],[6287,6445,"We're still gathering information."],[6491,6624,"About why you weren't with him."],[6804,6883,"The King was stabbed"],[6883,7012,"twice with a large knife,"],[7104,7233,"once in his lower abdomen"],[7271,7375,"and a second time in his"],[7375,7505,"chest near his heart."],[7605,7667,"The doctors are"],[7667,7796,"amazed that he's still alive."],[8072,8147,"We’re reviewing"],[8147,8322,"security footage, both our own"],[8351,8522,"and every security camera within a"],[8522,8677,"two mile radius of the palace."],[8689,8810,"Why only two miles?"],[8810,8935,"It's not likely that he could have"],[8935,9027,"traveled very far."],[9031,9169,"Given how much blood he'd lost"],[9169,9315,"and the severity of his injuries."],[9398,9536,"As to my whereabouts,"],[9607,9678,"His Majesty and"],[9678,9798,"I had an understanding that"],[9798,10049,"I would look the other way for his"],[10049,10170,"occasional walk."],[10182,10303,"It's an understanding"],[10337,10457,"I deeply regret."],[10482,10599,"No shit."],[10653,10708,"You're proving"],[10708,10858,"quite adept at getting people"],[10858,10954,"killed, Pryce."],[10958,11079,"Not his fault."],[11129,11250,"It's mine."],[11254,11388,"It's not anyone's fault."],[11408,11529,"I think it is."],[11542,11638,"And I think it starts"],[11638,11788,"with your father's inability"],[11788,11871,"to do his job."],[11884,12005,"No, it doesn't."],[12022,12184,"Your father could die."],[12193,12359,"Don't say that."],[12364,12514,"The only person to blame"],[12514,12651,"is the person who did it."],[12655,12889,"It's important we remain calm."],[12985,13131,"Remain calm."],[13164,13331,"My father has been stabbed."],[13331,13552,"And we are stuck in this cage like..."],[13552,13636,"Zoo animals."],[13723,13840,"That's what he called us"],[13898,13978,"when he gave his address"],[13978,14057,"to disband the Monarchy."],[14074,14232,"He was a fool to say that."],[14236,14395,"I told him it was a mistake."],[14395,14516,"I'll bet you did."],[14612,14687,"But he disagreed"],[14687,14808,"with you, didn't he?"],[14812,14887,"He was going to sign the"],[14887,14966,"legislation today,"],[15070,15191,"and now he's being attacked."],[15208,15383,"Be careful boy."],[15383,15454,"Not boy!"],[15462,15579,"Prince Regent."]],"139":[[31,185,"What's wrong with you, anyway?"],[240,461,"Why are you so shifty and pale?"],[523,698,"We stay down here much longer, and"],[698,915,"you'll look the same way, Princess."],[961,1111,"No drugs down here for you."],[1111,1349,"Good luck going cold turkey."],[1349,1549,"Don't change the subject."],[1570,1720,"You hated him and you wanted"],[1720,1845,"the Monarchy preserved."],[1849,1975,"If anybody's got the king's"],[1975,2154,"blood on their hands, it's you."],[2158,2304,"I can see it from here."],[2367,2471,"It's paint."],[2471,2613,"He was endlessly"],[2613,2809,"disappointed in both of you."],[2871,2946,"He said as much,"],[2946,3059,"only yesterday."],[3167,3330,"It must have angered you."],[3363,3505,"Perhaps drove you"],[3505,3672,"to do something terrible."],[3701,3772,"You shut up!"],[3772,3889,"Who happens"],[3889,4127,"to be next in line to the throne?"],[4127,4314,"Thing one and thing two."],[4686,4752,"Marcus called it"],[4752,4848,"emergency protocol."],[4990,5032,"What happens"],[5032,5149,"after a threat like this?"],[5153,5311,"We notify military intelligence."],[5311,5478,"Go to level one and secure the family."],[5532,5674,"And who did you secure first?"],[5674,5791,"What does that matter?"],[5791,5912,"Was it the Queen?"],[5995,6029,"You're"],[6029,6150,"the Prince Regent, Your Highness."],[6154,6308,"We secure you first and then the others."],[6312,6433,"So if that's true,"],[6554,6671,"why was he already here"],[6671,6792,"when I arrived?"],[6834,7030,"I was already in the tunnels."],[7030,7092,"Why?"],[7213,7334,"Because you were coming back"],[7334,7509,"after attacking our father."],[7513,7605,"Go ahead."],[7605,7789,"Insinuate and accuse."],[7789,7968,"I, for one, will not lower myself"],[7968,8068,"to participate."],[8068,8193,"Oh, you just did."],[8273,8393,"Where the hell were you?"],[8410,8610,"I was on my way out, actually."],[8610,8685,"He's lying."],[8719,8856,"Oh, she's still here."],[8856,9015,"I saw you leaving the palace."],[9015,9111,"You're wrong."],[9111,9178,"I'm not."],[9203,9290,"I saw you."],[9290,9336,"What time?"],[9382,9486,"Pryce, silence"],[9486,9616,"the only bitch you have left"],[9616,9745,"or I'll do it myself!"],[9795,9849,"Dad!"],[10567,10679,"Like I said,"],[10679,10863,"it's important we all remain calm."],[11080,11180,"Chekhov's gun, Mr. Pryce."],[11459,11597,"If the gun isn't going to be fired,"],[11643,11764,"it shouldn't be hanging there."]],"140":[[779,887,"Chekhov was making a point."],[945,1058,"Remove everything that has"],[1058,1191,"no relevance to the story."],[1458,1546,"I have no doubt"],[1546,1675,"you'll vet everyone's"],[1675,1876,"alibis and whereabouts, Mr. Pryce."],[1909,2051,"And once the King recovers,"],[2051,2142,"we will quickly"],[2142,2293,"and summarily dismiss you"],[2293,2409,"as our head of security."],[2501,2651,"Because if we stick to the facts and"],[2651,2739,"dismiss all the emotional"],[2739,3014,"accusations, the hard truth is"],[3181,3281,"nobody's spouse"],[3281,3402,"is safe around you."],[3431,3481,"Are they?"],[3481,3602,"You're such a bitch."],[3694,3798,"We've yet to establish"],[3798,4003,"where Her Majesty was last night."],[4157,4194,"I was with"],[4194,4336,"Colonel Mustard in the library"],[4336,4453,"with the candlestick."],[4474,4632,"Keep to the facts, Mr. Pryce."],[4716,4783,"Why do you do that?"],[4933,5050,"Worry about your makeup like that."],[5158,5241,"You did the same thing"],[5241,5329,"when Robert died."],[5383,5600,"Liam, please don't say “died.”"],[5650,5829,"Dad is not going to die."],[5925,5967,"No matter"],[5967,6088,"what happens to your father"],[6196,6317,"when we leave this room,"],[6334,6422,"you'll find the world"],[6422,6547,"outside has changed."],[7018,7114,"And in the absence"],[7114,7231,"of the King's voice,"],[7302,7444,"people will look to the Queen."],[7573,7748,"And the Queen will be unwavering"],[7819,7948,"and unconquerable."],[8094,8215,"You want a purpose for the monarchy?"],[8265,8449,"I'll give you one."],[8449,8682,"To stand before a worried, confused,"],[8682,8803,"grieving people."],[8832,9045,"And in the face of profound tragedy,"],[9045,9154,"inspire them"],[9266,9387,"with our strength,"],[9421,9604,"nobility and grace."],[9871,9988,"We are under attack."],[10000,10084,"And eventually,"],[10084,10234,"this door is going to open."],[10255,10371,"And when it does,"],[10380,10542,"the world will look at us."],[10630,10714,"I suggest you"],[10714,10876,"all put your war paint on."],[11068,11185,"This is mine."],[11460,11577,"I have to get out of here."],[11577,11652,"Not until..."],[11652,11781,"Until the palace is secure."],[11781,11936,"I understand that, but if I have to"],[11936,12148,"stay in this room for one more minute,"],[12148,12223,"I'm going to..."],[12223,12269,"What?"],[12348,12465,"Kill someone."],[12507,12615,"Not kill someone."],[12615,12716,"I'm going to kill you."],[12749,12811,"Don't!"],[12816,12957,"Don't you touch me."],[12957,13045,"Sir, if I may."],[13045,13174,"The tunnel is secure."],[13203,13266,"Fine."],[13299,13379,"That’s absolutely fine."],[13379,13479,"I'll stay in the tunnel."],[13495,13633,"Please just let me out of here."]],"141":[[1026,1226,"Stay away from me!"],[1231,1310,"I just thought."],[1310,1352,"What?"],[1456,1577,"Thought we could hold hands."],[1618,1698,"Have a heart to heart,"],[1698,1815,"that I’d trust you."],[1931,2136,"I don't trust you, Jasper."],[2136,2302,"My father has been attacked"],[2302,2465,"and someone in here is lying."],[2624,2807,"And you have quite a track record,"],[2911,3032,"don't you?"],[5168,5276,"You want to be strong for the world."],[5385,5518,"Maybe start with your own daughter."],[5589,5706,"She's worried he's going to die."],[5952,6048,"We all are."],[6048,6169,"Where's the harm in telling someone"],[6169,6273,"everything is going to be okay?"],[6273,6394,"Giving them a little hope."],[6507,6582,"Some people have"],[6582,6682,"the privilege of hope."],[6744,6903,"We have the responsibility"],[6903,7032,"of being prepared."],[7111,7220,"After conducting a thorough"],[7220,7341,"search of the house and grounds,"],[7341,7462,"we feel it is now safe"],[7462,7583,"to go back to the palace."],[7612,7716,"Please understand that we are"],[7716,7800,"on high alert."],[7804,7921,"There will be a higher military"],[7921,8042,"and armed presence and"],[8042,8142,"very few staff."],[8192,8275,"There's a panic button"],[8275,8334,"in every room."],[8371,8484,"Use it."],[8484,8625,"And no one is to leave the premises."],[8671,8792,"When can we see him?"],[8826,8955,"The King remains in surgery."],[8955,9093,"As soon as he is out, we'll arrange"],[9093,9239,"a secure transport to the hospital."],[9797,9914,"What can I do?"],[9968,10089,"Pray for my father."],[10144,10265,"Marcus will get you home."],[10365,10473,"I’ll call you when I can."],[10523,10611,"But it will be difficult to see you."],[10611,10732,"I know, it's okay."],[10878,10995,"You can do this."],[11954,12075,"What do I do now?"],[12075,12192,"Stay close to me."],[12229,12308,"I'll help you."]],"142":[[90,181,"I want the Prime Minister"],[181,315,"here in the next 30 minutes."],[336,457,"I want to be updated on"],[457,594,"everything going on politically."],[607,744,"We need to control the press."],[753,882,"Make sure nothing gets out."],[936,1053,"What do they have so far?"],[1086,1253,"The Londoner has an unconfirmed"],[1253,1362,"source claiming a member of the"],[1362,1491,"Royal Family has been admitted to"],[1491,1612,"to Mount Margaret's."],[1675,1775,"Say it was Eleanor"],[1775,1896,"with flu like symptoms."],[1908,2025,"They'll think she OD'd."],[2037,2138,"And find out who the"],[2138,2267,"unconfirmed source is."],[2292,2425,"Vet everyone that comes"],[2425,2534,"into contact with the King."],[2571,2692,"If anything leaks, tell"],[2692,2822,"them careers will end."],[2822,2880,"Yes, ma’am."],[3009,3084,"Also, we'll need to"],[3084,3201,"prepare a statement."],[3218,3339,"I'll notify the team."],[3401,3556,"Any news on His Majesty's"],[3556,3614,"condition?"],[3660,3685,"No."],[3994,4102,"Make sure we have a direct"],[4102,4194,"line to the hospital."],[4244,4361,"They will only speak to me."],[4361,4507,"Not you, not anyone else."],[4577,4728,"Everything is going to be okay."],[4807,4932,"In case no one has said it yet."],[5111,5232,"Do you believe that's true?"],[5249,5378,"The Monarchy has been"],[5378,5458,"through worse."],[5458,5574,"Much worse."],[5616,5737,"So too has the Queen."],[5850,6004,"He wouldn't listen to reason."],[6050,6171,"No he wouldn't."],[6283,6425,"Some of us have dedicated"],[6425,6546,"our entire lives"],[6546,6663,"to this institution."],[6709,6867,"I have, and you have, ma'am."],[7038,7155,"The King has brought this"],[7197,7318,"upon himself."],[7393,7539,"This tempest was inevitable."],[7672,7793,"I'm sorry."],[7827,7947,"I will make all the arrangements."],[8160,8227,"Lucius."],[8264,8310,"Ma'am."],[8440,8556,"Thank you."],[8556,8719,"I am at Her Majesty's service."],[8773,8890,"Unequivocally."]],"143":[[477,527,"How are you?"],[648,769,"I don't know."],[802,848,"I was supposed"],[848,969,"to join him last night."],[1119,1240,"He asked me to."],[1248,1369,"Why didn't you?"],[1507,1628,"I was with Ophelia."],[2020,2195,"I'm going to give a live broadcast"],[2212,2328,"to tell the public that"],[2328,2458,"everything will be fine."],[2566,2683,"You were right."],[2771,2900,"The public needs a little hope"],[2900,3021,"now and then."],[3029,3150,"And so do you."],[3238,3442,"It's all going to be okay."],[3505,3588,"Is it mum?"],[3588,3759,"Yes it is."],[3817,3963,"Because of your father's condition,"],[4130,4251,"there will be a ceremony"],[4264,4410,"to officially recognize you"],[4426,4660,"as the acting King of England."],[4818,4977,"The Archbishop will stand here."],[5060,5181,"You will stand here."],[5269,5390,"He’ll recite some vows"],[5398,5519,"and you'll repeat them."],[5548,5632,"And then you'll kiss"],[5632,5753,"King James’ Bible."],[5807,5920,"And once you do,"],[5920,6040,"you will officially become"],[6057,6182,"the acting monarch."],[6278,6470,"Sovereign head of state,"],[6508,6695,"church and the armed forces."],[6758,6879,"Temporarily."],[6879,7000,"Until dad is well."],[7025,7087,"Sweetheart,"],[7196,7313,"your father's injuries"],[7313,7434,"are life threatening."],[7471,7621,"His recovery could take months,"],[7625,7746,"maybe years."],[7784,7842,"I know you don't"],[7842,7930,"want things to change,"],[7976,8093,"but they already have."],[8251,8368,"The life you've known"],[8389,8510,"is gone."],[8551,8647,"You have a bigger"],[8647,8764,"responsibility now."],[9081,9202,"I'm not ready for this, mum."],[9281,9419,"No one's ever ready for this."],[9502,9627,"You're a great man,"],[9661,9811,"and you have an immense heart."],[9886,9994,"And that's more than enough"],[9994,10111,"for now."]],"144":[[2173,2265,"I've been assigned"],[2265,2386,"to oversee the security"],[2386,2503,"of the King's Hospital."],[2565,2686,"We'll take the tunnels."],[2899,2949,"Let's go."],[2949,3070,"Before I change my mind."],[4142,4288,"Frost, you have the Princess with you."],[4350,4471,"She wants to see her father."],[4509,4651,"She is not to leave the palace."],[4651,4730,"Do you understand me?"],[4730,4859,"That is a direct order."],[4909,5013,"I’ll protect her with my life, sir."],[5013,5139,"You can find me later."],[5447,5789,"Dad, I know what I saw with Cyrus."],[5831,5981,"He was trying not to be seen"],[5981,6102,"sticking to the shadows."],[6102,6248,"I know, I looked at the footage."],[6319,6440,"Do you think he did it?"],[6465,6548,"This morning it looked like"],[6548,6669,"he had slept."],[6840,6882,"It wouldn't"],[6882,7011,"be the first time he's been out"],[7011,7132,"all night."],[7141,7237,"Things are about"],[7237,7366,"to get very messy around here."],[7395,7520,"I want you to stay out of it."],[7562,7779,"Just let me deal with this."],[7825,7908,"Okay."],[8112,8233,"I'm sorry about what they said"],[8417,8538,"about your mother."],[8571,8709,"There hasn't been a day"],[8709,8838,"gone by since it happened where"],[8838,8951,"I haven't wondered if I could have"],[8951,9097,"done more to protect her."],[9176,9297,"Protect you."],[9551,9589,"You did what"],[9589,9710,"you were trained to do."],[9764,9885,"You protected the King."],[9948,10069,"Mom would be proud of that."],[10181,10240,"Do you think so?"],[10402,10523,"Yeah, I do."],[11111,11307,"Dad. If you see Liam,"],[11307,11382,"will you please tell him"],[11382,11474,"I'm thinking about him."]],"145":[[684,805,"Cyrus."],[889,1006,"What is this?"],[1118,1210,"- Why am I? - Don't."],[1210,1327,"There are cameras."],[1327,1448,"Kiss me."],[1890,2011,"Follow me."],[3078,3195,"We can talk in here."],[3274,3383,"I couldn't go out"],[3383,3491,"and you can't come in."],[3491,3591,"Why can't you go out?"],[3591,3708,"They would have followed me."],[4371,4505,"The King has been attacked."],[4522,4601,"What?"],[4655,4747,"When?"],[4747,4851,"By whom?"],[4851,5005,"Last night. And I don't know."],[5051,5135,"But I need you to be"],[5135,5214,"my alibi."],[5214,5322,"Oh Cyrus."],[5322,5468,"I cover for you every time"],[5468,5552,"you need a fix."],[5568,5689,"Yeah, and I said I wanted out."],[5806,5927,"The King's been attacked."],[6040,6123,"How bad is it?"],[6123,6244,"We don't know."],[6252,6373,"Apparently bad."],[6511,6682,"I had nothing to do with it."],[6690,6882,"Cyrus, I will not perjure myself"],[6882,7032,"or lie to the authorities."],[7041,7183,"I'm a member of Parliament."],[7191,7312,"You did lines of blow off"],[7312,7470,"my dick last week, Holloway."],[7483,7641,"Don't get all sanctimonious now."],[7641,7708,"I won't do it."],[7708,7883,"You will do it, you flimsy bastard,"],[7883,7954,"or you will find"],[7954,8117,"yourself in a world of shit."],[8167,8296,"What? Like the King?"],[8492,8659,"James, please."],[8722,8809,"I simply need"],[8809,8938,"you to say I was with you"],[8938,9059,"last night."],[9059,9180,"And where were you?"],[9205,9360,"I was with you last night."],[9723,9806,"If I do this..."],[9806,9864,"Anything."],[10290,10411,"James..."],[10452,10594,"care to use your safe words"],[10594,10686,"in the safe room?"],[10819,10920,"You're reprehensible,"],[10920,11041,"you know that?"],[11107,11224,"You say no?"],[13247,13360,"Dad."],[13360,13514,"Wake up."],[13760,13898,"I'll do better."],[14123,14244,"I'll do better."]],"146":[[69,186,"Good evening."],[319,407,"I'm speaking to you"],[407,615,"today as a wife, a mother,"],[678,803,"a servant of the people,"],[861,982,"and as your Queen."],[1082,1145,"Following this"],[1145,1287,"address, you will hear the palace"],[1287,1462,"bells ring five times."],[1587,1662,"For centuries,"],[1662,1900,"it was a distress call warning the people"],[1900,2071,"that their kingdom was under attack."],[2175,2296,"And today"],[2313,2542,"we are once again under attack."],[2588,2755,"Yesterday your King spoke to you"],[2755,2876,"from the heart."],[2913,3080,"He spoke of his love of country"],[3122,3243,"and his love of family."],[3322,3443,"Sometime later,"],[3451,3551,"the King was attacked"],[3551,3714,"outside the gates of the palace."],[3756,3952,"He was assaulted, stabbed"],[4010,4102,"and left for dead."],[4206,4369,"The victim of a brutal attack"],[4411,4557,"by an unknown assailant."],[4611,4728,"Today,"],[4728,4911,"as your king fights for his life,"],[4965,5153,"I once again speak to you about"],[5153,5366,"love of family and country."],[5420,5558,"The next days and weeks will be"],[5558,5716,"emotional and challenging."],[5804,5987,"But I have every reason to believe"],[6008,6250,"your strong, compassionate king"],[6250,6371,"will recover."],[6567,6646,"The referendum"],[6646,6767,"to abolish the monarchy,"],[6788,6934,"still awaits his signature."],[7022,7143,"And when he's well."],[7193,7368,"If it's what your king desires,"],[7401,7539,"and it's what the people want,"],[7618,7697,"the referendum"],[7697,7831,"will be signed and placed"],[7831,7952,"before you."],[7977,8173,"For now, we need to refocus,"],[8239,8335,"band together"],[8335,8486,"and pray for his recovery."],[8723,8840,"Our family remains"],[8840,8974,"unified and resolute,"],[9003,9178,"and we will navigate this together"],[9178,9291,"with the support"],[9291,9503,"and comfort of our extended family."],[9574,9787,"You, England,"],[9833,10012,"this United Kingdom."],[10805,10946,"This attack is an act"],[10946,11180,"of terrorism, of cowardice."],[11263,11430,"The assailant will be found"],[11434,11610,"and justice will be served."],[11693,11801,"God bless you all."],[11901,12077,"And God save the King."]],"147":[[250,379,"People will demand justice."],[417,554,"What will we give them, Mr. Pryce?"],[596,721,"So far, we have three"],[721,863,"views of the King's assailant."],[863,984,"One taken just after"],[984,1059,"the King was attacked."],[1059,1201,"One moments before."],[1201,1309,"And we have a distant view"],[1309,1405,"from a nearby rooftop."],[1443,1584,"MI5 are trying to enhance it."],[1618,1734,"But the actual attack?"],[1797,1926,"Whoever did this"],[1926,2022,"was either very lucky"],[2022,2164,"and chose a moment"],[2164,2331,"and location that escapes detection,"],[2385,2569,"or it all seems very planned"],[2569,2685,"and premeditated."],[2719,2844,"Someone who knew his route."],[2873,3011,"In the second scenario, yes."],[3082,3299,"The King is now out of surgery."],[3324,3474,"He remains unconscious"],[3474,3574,"and the surgeons are waiting"],[3574,3699,"to speak to you. I have transport."],[3699,3753,"Well, let's go."],[3791,3849,"Where's Eleanor?"],[3849,3945,"She..."],[4037,4129,"The Princess is already"],[4129,4245,"at the King's bedside."],[4245,4291,"What?"],[4341,4437,"Who let that happen?"],[4437,4562,"Your security detail."],[4566,4650,"I'll deal with it."],[4650,4754,"I'll be just outside."],[4821,4871,"Ted."],[5067,5188,"Find out who did this."],[5330,5417,"No matter what."],[5526,5559,"Sir."],[5768,5876,"This is the first time"],[5876,5985,"the people will see you"],[5985,6106,"as Prince Regent."],[6160,6281,"Don't wear sunglasses."],[6302,6423,"Make eye contact."],[6452,6606,"Let them see your compassion."],[6735,6810,"Acknowledge them,"],[6810,6952,"but do not approach."],[7011,7127,"It's not safe yet."],[7649,7786,"Your father would be proud of you."],[8003,8070,"So am I."]],"148":[[588,709,"Hey."],[1743,1864,"Dad."],[1976,2097,"I'm sorry."],[2273,2369,"You waited for me, and I should"],[2369,2452,"have been there."],[2773,2907,"I'm sorry I failed you."],[3032,3165,"But I won't let you down again."],[3165,3282,"I promise."],[3311,3390,"I’ll be everything"],[3390,3461,"you want me to be."],[5238,5347,"Eleanor,"],[5347,5497,"can we have a moment alone?"],[5689,5718,"Yeah."],[5718,5839,"Of course."],[5860,5976,"I meant me and your brother."],[6114,6235,"Prince Regent matters."]],"149":[[224,345,"It's quiet."],[595,653,"I don't remember"],[653,841,"the last time I heard silence."],[1070,1204,"I don't think I ever have."],[1442,1562,"Can I get you anything?"],[2622,2743,"I miss you."],[3268,3506,"You realize I have trust issues. Yes?"],[3715,3798,"Yeah."],[4232,4328,"You have to trust"],[4328,4445,"somebody sometime."],[5650,5771,"Why are you here?"],[6092,6234,"I wanted to see you."],[6459,6547,"No."],[6613,6701,"Before this."],[6701,6834,"Why are you here?"],[7894,8015,"Why did you do that?"],[8031,8244,"Did you attack my father, Jasper?"],[8261,8315,"No."],[8348,8457,"Are you in love with my mother?"],[8457,8640,"So you tried to kill my father?"],[8686,8778,"What are you talking about?"],[8778,8899,"Did you?"],[8912,9032,"You know I wouldn't do that."],[9299,9495,"I don't know anything about you."],[9716,9875,"Jasper from Las Vegas."],[10129,10280,"Found that in the Queen's bed,"],[10396,10534,"which is also the King's bed."],[10813,10934,"Off you go."],[11059,11110,"Police!"],[11110,11176,"Get on the floor!"],[11251,11301,"Nobody move!"],[11301,11376,"On your knees!"],[11376,11452,"Get down on your knees!"],[11452,11518,"Get down!"],[11518,11635,"On your knees now!"],[11710,11752,"That's it."],[11923,12010,"Stay there."],[12010,12131,"Check him out."],[12140,12252,"Cuffs."],[12252,12319,"All right, cuffs."],[12448,12523,"All clear."]],"150":[[452,590,"That's also none of your business."],[661,744,"I was looking for Liam."],[744,865,"Shut up!"],[907,1115,"First of all, you bow"],[1128,1249,"in my presence."],[1270,1445,"Second, you refer to the"],[1445,1695,"Prince Regent as His Royal Highness"],[1695,1791,"Prince Liam."],[1862,1983,"Third,"],[1996,2167,"you need to shut that little whore"],[2167,2308,"of a mouth of yours before I"],[2308,2413,"shut it for good."],[2471,2642,"I told my father everything."],[2646,2788,"Well, daddy"],[2788,2921,"can't always protect you."],[3017,3138,"Just ask your mother."],[3293,3476,"How can you be so horrible?"],[4356,4477,"As opposed to what?"],[4527,4648,"Being nice."],[4715,4878,"Nice is for the simple"],[4878,5024,"and ignorant who muddle"],[5024,5161,"through their ordinary lives,"],[5161,5274,"telling themselves"],[5274,5386,"their big break is coming."],[5416,5591,"Love is just around the corner."],[5599,5862,"It's not and it ain't."],[5962,6125,"Some of us have more to lose."],[6125,6237,"And the truth is you"],[6237,6375,"don't know what you saw."],[6450,6563,"I saw you leaving."],[6563,6684,"And then what?"],[6930,7046,"Go on,"],[7109,7230,"cry wolf."],[7318,7526,"But when the real wolf is at your door,"],[7547,7710,"who's going to save you then?"],[8544,8756,"Jasper has been arrested."],[8840,8940,"For what?"],[8940,9061,"Attacking the King?"],[9169,9415,"No, for screwing the Queen."],[9574,9695,"Consider it a favor."],[9716,9824,"There was clearly something going on"],[9824,9891,"between the two of you."],[9891,10091,"I simply exposed his true colors"],[10091,10216,"before you got too attached."],[10229,10383,"Oh, well done, Queen."],[10433,10554,"Spin it."],[10617,10750,"Make it seem like"],[10750,10892,"you were trying to protect me."],[11017,11050,"Go on."],[11050,11192,"Pull Liam close and protect"],[11192,11309,"him, too."],[11342,11463,"You are reprehensible."],[11555,11693,"I wouldn't be surprised"],[11693,11839,"if you put the knife in dad's"],[11839,11918,"heart yourself, Mum."],[11918,12072,"You've been doing it for years."],[12076,12189,"Take it back."],[12189,12339,"You know how she is, Liam."],[12343,12464,"Stop it!"],[12489,12606,"Mum has been the only setting"],[12606,12765,"influence in all of this."],[12781,12902,"And you've been a mess."],[13007,13161,"Dad might die."],[13203,13324,"Exactly."],[13349,13469,"Pull it together."],[13874,13982,"Let her go."],[13982,14091,"You have to talk to her."],[14091,14179,"If you don't, she'll lash out"],[14179,14299,"and cause a scene."],[14312,14412,"When she does, it reflects"],[14412,14533,"poorly on all of us."],[14833,14954,"I'll be back."]],"151":[[553,674,"Len."],[766,870,"Liam."],[870,996,"She's just using you."],[996,1100,"Why don't you see that?"],[1100,1296,"All she cares about is her power."],[1308,1425,"Of course I see it."],[1438,1559,"What?"],[1625,1763,"We can't let her know that, can we?"],[2218,2372,"I’m sorry I couldn't tell you."],[2430,2514,"We have to be careful."],[2514,2635,"At least until we know the truth."],[2789,2910,"So it's still you?"],[2968,3089,"You're still in there?"],[3164,3285,"I’m still in there."],[3315,3456,"But I'm way in over my head."],[3661,3782,"I’ve been thinking about this a lot."],[4211,4295,"The way we all turned on"],[4295,4391,"each other in the safe room."],[4478,4537,"Dad was right."],[4537,4699,"Like a bunch wild animals."],[4766,4887,"It has to stop."],[5037,5158,"The referendum?"],[5387,5454,"Once I'm officially"],[5454,5575,"the acting king,"],[5592,5725,"the first thing I do is sign the bill"],[5725,5846,"to abolish the monarchy."],[5996,6113,"You okay with that?"],[6142,6263,"What do you think?"],[6426,6522,"I'm just so glad"],[6522,6639,"that you're still you."],[6660,6747,"It's always been me."],[6747,6897,"And it will always be us, I promise."],[7039,7160,"Dad was right."],[7223,7344,"All of this has to end,"],[7535,7615,"and I'm going to end it."],[10359,10434,"Your Highness, they're"],[10434,10555,"nearly ready for you."],[10559,10739,"And there's one more thing."],[11640,11719,"Hi."],[11760,11811,"Hi."],[12198,12315,"I thought you might want to hang out."],[12340,12424,"I mean, unless you have something"],[12424,12490,"else going on."],[12540,12682,"I feel like I'm going to throw up."],[12766,12845,"Yeah."],[12845,12966,"Been there."],[13129,13245,"Look, I know you blame yourself for"],[13245,13341,"what happened to your father."],[13437,13558,"But you shouldn’t."],[13733,13867,"I'm the one that asked you to stay."],[13946,14067,"I blame myself."],[14100,14217,"I could have said no."],[14263,14346,"But who knows what might have"],[14346,14467,"happened if you'd been there."],[14647,14763,"It could have been you."],[15181,15302,"Oh, Ophelia."],[15460,15531,"Liam."],[15531,15652,"It's time."]],"152":[[156,252,"I know you're nervous,"],[252,331,"but you shouldn't be."],[365,486,"This is your destiny."],[536,657,"You can do it."],[1558,1674,"I have to go."],[2171,2292,"Are you ready?"],[2338,2467,"You said no one was ever ready."],[4177,4252,"You understand"],[4252,4369,"the magnitude of this?"],[4423,4506,"I can see that you do."],[4640,4698,"So take a step"],[4698,4882,"back and ask yourself"],[4944,5153,"where your place is in all of it."],[5245,5361,"Don't be influenced by me"],[5378,5499,"or anything else."],[5603,5758,"Simply look into your heart"],[5816,5979,"and truly ask yourself"],[6050,6187,"where you belong."],[6333,6454,"Regardless of the answer."],[6592,6767,"He belongs to England now."],[8302,8419,"Where’s Cyrus?"],[8494,8719,"Crafting his alibi, I assume."]],"153":[[28,149,"I solemnly promise"],[203,324,"and swear to govern and rule"],[403,545,"the people of the United Kingdom,"],[624,741,"British monarchy"],[741,879,"and its overseas territories."],[945,1137,"I promise to make law and cause"],[1137,1379,"justice to the utmost of my power."],[1425,1546,"I promise to make law"],[1609,1692,"and cause justice"],[1692,1821,"to the utmost of my power."],[1871,2055,"I promise to maintain the true"],[2055,2205,"profession of the gospel."],[2255,2372,"I promise to maintain the true"],[2372,2493,"profession of the gospel."],[2535,2697,"I will execute my judgment"],[2697,2793,"with mercy."],[2818,2952,"I will execute my judgment"],[2952,3048,"with mercy."],[3077,3252,"I will be benevolent and noble"],[3252,3402,"in matters of conscience."],[3440,3631,"I will be benevolent and noble"],[3702,3819,"in matters of conscience."],[3827,3986,"I will gravely castigate"],[3986,4132,"those who betray the Crown."],[4190,4307,"I will gravely castigate"],[4307,4428,"those who betray the crown."],[4486,4662,"All this I promise to do."],[4666,4787,"So help me God."],[4833,4949,"All this I promise to do."],[5083,5204,"So help me God."],[5258,5458,"And now, before God and man"],[5496,5596,"with a kiss,"],[5596,5800,"you will seal your place in history."],[5838,5930,"And take your place"],[5930,6159,"upon the greatest throne on earth."],[6422,6543,"Stop!"],[6676,6751,"Kiss the book."],[6751,6876,"He will not kiss the book."],[6876,7026,"And he will not occupy the throne"],[7026,7227,"because he is not fit to do so."],[7306,7635,"Cyrus, turn around and walk away."],[7635,7752,"Or so help me God."],[7752,7873,"I will have you arrested"],[7873,8023,"and imprisoned for treason."],[8027,8219,"With what authority?"],[8224,8395,"I am the Queen of England."],[8395,8511,"Which means nothing compared"],[8511,8649,"to the King of England."],[8653,8862,"Then I will have you court martialed."],[8912,8987,"You? The spare?"],[9062,9250,"The spare who would be heir?"],[9250,9350,"You have no bearing"],[9350,9433,"to any of these proceedings"],[9433,9575,"and disgrace king and country,"],[9612,9729,"not to mention yourself."],[9733,9904,"I can assure you, young prince,"],[9904,10080,"that I do have bearing."],[10125,10326,"And if anyone is a disgrace to the Crown."],[10342,10538,"I'm quite certain it's you."],[10593,10747,"Isn't that right, Your Majesty?"],[10751,10885,"Cyrus."],[10885,11022,"Did you really think you would be"],[11022,11156,"King of England?"],[11218,11339,"You're not intelligent."],[11377,11535,"You're not inspiring."],[11535,11610,"Cyrus."],[11664,11936,"You're not even the King's son."],[12169,12323,"You bastard."],[12465,12586,"No, my Queen."],[12670,12953,"That would be him and her."],[13016,13158,"Mother, refute him."],[13212,13379,"Tell this room and the world"],[13433,13629,"And our father, the King, who at this"],[13629,13796,"very moment fights for his life..."],[13900,14042,"that these are the desperate"],[14042,14300,"lies of a pathetic, jealous man."],[14609,14776,"Tell us it isn't true."],[14834,14955,"Yeah."],[15005,15168,"Tell us, Queen."],[15326,15385,"Mum."]],"154":[[562,762,"These children are illegitimate."],[812,899,"They are not the blood"],[899,1058,"heirs of King Simon,"],[1058,1221,"and so are not eligible"],[1221,1367,"to ascend the throne."],[1425,1579,"I am the rightful heir"],[1579,1700,"to the Crown."],[1729,1942,"I am the next King of England."],[4849,4908,"It can't be true."],[4908,5012,"It just can't be."],[5012,5133,"Mum wouldn't do that."],[5291,5404,"Mum's a whore."],[5896,6021,"Sir, we found something."],[6384,6505,"Now watch this."],[6910,7051,"He stays like that for hours."],[8482,8603,"Who the hell are you?"],[10088,10213,"All the scotch on the"],[10213,10380,"planet won't help you now."],[10530,10576,"You made quite a"],[10576,10697,"spectacle of yourself."],[10738,10876,"He wasn't fit to be king."],[10930,11051,"It had to be done."],[11973,12115,"You didn't have to slap me"],[12115,12232,"so hard."],[12315,12444,"It had to look convincing."],[12982,13116,"To the next King of England."],[13199,13295,"Long live the Queen."]],"155":[[95,179,"Ladies and gentlemen, thank"],[179,312,"you all for coming this morning."],[325,496,"We have the results of these tests."],[529,625,"So I'm going to make a brief"],[625,767,"opening statement, after which"],[796,900,"I will throw the floor open"],[900,1021,"to questions."],[1105,1230,"Scientifically, each"],[1230,1405,"genetic marker is assigned"],[1405,1576,"with a paternity index"],[1576,1726,"showing the degree of relatedness"],[1726,1856,"between the alleged father"],[1856,1972,"and the child."],[1981,2077,"After examining"],[2077,2198,"these genetic markers,"],[2198,2419,"I can say with absolute"],[2419,2552,"and complete certainty"],[2660,2802,"that Princess Eleanor"],[2861,2973,"and His Royal Highness"],[2973,3019,"Prince Liam"],[3140,3370,"are not the genetic descendants of His"],[3370,3495,"Royal Majesty King Simon."],[6623,6827,"Something is definitely rotten."]],"156":[[349,507,"Bravo, Queen."],[520,645,"Darling, I want to explain."],[649,770,"Explain what?"],[816,1004,"Oh, oh. That you and Cyrus"],[1004,1146,"fixed this whole thing."],[1216,1337,"If only that were true."],[1412,1654,"I think we both know that you did."],[1934,2159,"But what kind of person"],[2284,2447,"would allow herself to face"],[2447,2689,"this kind of global ridicule"],[2743,2864,"if it weren't true?"],[3014,3131,"Eleanor!"],[3139,3277,"That pillow was older than America."],[3485,3807,"Someone who couldn't give it up."],[3923,4115,"The money, the power,"],[4219,4340,"the pillows."],[4424,4516,"You know how much I care"],[4516,4641,"about this family's image."],[4645,4820,"Not the family's image, though,"],[4820,4941,"Mother."],[4958,5100,"The monarchy's image."],[5141,5408,"No monarchy, no queen."],[5558,5675,"No pillows."],[5675,5796,"Don't."],[5992,6109,"I've been up all night"],[6109,6230,"thinking about it."],[6309,6422,"I walked the streets"],[6422,6568,"that my father walked."],[6668,6839,"And somewhere out there"],[6839,6960,"in the middle of the night"],[7172,7368,"it all made perfect sense."],[7481,7615,"The paternity test."],[7735,7856,"The King's attack."],[8069,8190,"Robert’s death."],[8386,8540,"Did you kill Robert, Mom?"],[8607,8728,"Walk away."],[8807,8928,"Well, I think you did."],[9008,9129,"I think you and Cyrus"],[9129,9224,"have been planning this"],[9224,9379,"for a long time."],[9454,9591,"Military accident wasn’t it?"],[9621,9888,"I said get out before I get angry."],[9896,10117,"Not until you admit it."],[10292,10484,"You killed your son,"],[10655,10855,"and then you tried to kill your husband."],[10859,11060,"I said walk away."],[11110,11231,"Admit it."],[11293,11402,"Maybe it will help you"],[11402,11606,"if you just say it out loud."],[11852,11990,"No one killed Robert"],[12152,12340,"because Robert killed himself."],[12628,12749,"He committed suicide."],[13024,13287,"Now. You tell me."],[13512,13679,"Does that make you feel better?"],[13683,13875,"Hearing me say it out loud."]],"157":[[658,775,"Your Highness asked for me."],[816,1054,"I want a full briefing on where we're at with"],[1054,1142,"the King's attack."],[1142,1238,"- We’re preparing... - In an hour."],[1308,1509,"I also removed the security detail"],[1509,1630,"from Liam and Eleanor,"],[1730,1851,"and I could use another drink."],[1863,2013,"You remove their security detail?"],[2063,2176,"They're illegitimate."],[2176,2314,"They're still the Queen's children."],[2314,2443,"They are not successors"],[2443,2564,"to the throne, and as such,"],[2564,2689,"do not merit nor deserve"],[2689,2810,"protection."],[2835,2964,"Not to mention the cost."],[2998,3098,"Is it any wonder I'm"],[3098,3190,"running low on cognac?"],[3194,3290,"And would Your Highness"],[3290,3336,"like an update"],[3336,3456,"on the King's condition?"],[3577,3694,"Be careful, Pryce."],[3723,3899,"You're insinuating that I don’t care"],[3899,4036,"about my brother's condition."],[4095,4195,"You're wrong."],[4241,4407,"Have it all in one hour."],[4462,4578,"Of course, Your Highness."],[4595,4825,"I believe you meant your Majesty,"],[4870,5058,"as I'm now the acting King."],[5104,5221,"With all due respect,"],[5221,5413,"His Majesty, the King is still alive."],[5413,5563,"In addition, you are not officially,"],[5563,5625,"Prince Regent..."],[5625,5788,"Until the ceremony."],[5892,6059,"Right, Archbishop."],[6063,6180,"Give me the book."],[6288,6376,"Prince Cyrus,"],[6376,6497,"do you solemnly promise...?"],[6505,6568,"There."],[6630,6739,"I'm the acting king."],[6843,6964,"Walk away."],[7227,7352,"One hour, Pryce."],[7777,7957,"Make the hems a little shorter."],[7957,8086,"You think I wear these socks"],[8086,8203,"for no one to see?"],[8628,8687,"What do you mean"],[8687,8820,"you're not on his detail anymore?"],[8849,8958,"You've been with him for..."],[8970,9020,"Six years."],[9037,9104,"Six years."],[9104,9212,"Who's guarding him?"],[9212,9254,"No one is."],[9258,9379,"How is that possible?"],[9379,9517,"Someone out there attacked the King."],[9517,9633,"And I've been calling him"],[9633,9671,"and texting."],[9671,9792,"And he hasn't responded."],[9817,9909,"What if he's in trouble?"],[9909,10051,"I'm just following orders, Ophelia."],[10088,10192,"I was told to stand down"],[10192,10297,"from Liam's detail and"],[10297,10380,"take you to the airport."],[10418,10539,"I can't go without seeing him."],[10559,10705,"Or at least hearing his voice."],[10718,10810,"Look, I'll find him, and"],[10810,10893,"I’ll have him call you."],[10897,11060,"But right now, your flight is leaving."],[11110,11231,"We have to go."],[11377,11490,"And he never asked about me?"],[12315,12432,"Can you help me with my bags?"],[13408,13517,"I know you're worried about him,"],[13517,13637,"but I really think..."],[14042,14088,"Right."]],"158":[[26,205,"No one’s saying be there."],[260,318,"No one’s saying"],[318,439,"stop that."],[489,547,"No one’s saying"],[547,668,"see here."],[744,1102,"Free to run around all day."],[1152,1461,"Free to do it all my way."],[1536,1903,"Oh, I just can't wait to be king."],[1970,2378,"No, I just can't wait to be king."],[2416,2996,"Oh, I just can't wait to be king."],[3822,3943,"I love that song."],[4985,5102,"Did she ever love you?"],[5565,5686,"You'd have to ask her that."],[5853,5974,"Do you ever love her?"],[6257,6437,"If you're asking if your mother was"],[6437,6566,"the love of my life, then"],[6566,6683,"no she wasn't."],[6875,6975,"But we did have some good years"],[6975,7050,"together."],[7146,7271,"But were the two of you ever in love?"],[7513,7634,"I suppose we were."],[7751,7880,"Over the years, that faded."],[7997,8209,"We became more of a partnership,"],[8284,8447,"a strategic alliance,"],[8576,8743,"eventually a quiet understanding."],[8927,8993,"Why?"],[8993,9114,"What changed it?"],[9260,9381,"It’s always the little things."],[9490,9611,"Never the big things."],[9698,9815,"Like anniversaries"],[9815,9915,"or holidays."],[9961,10065,"Or affairs."],[10086,10207,"Oh, no."],[10236,10357,"Affairs will do it."]],"159":[[207,336,"Have you spoken to Alistair yet?"],[461,582,"Not yet."],[928,1049,"Cyrus."],[1120,1183,"Do you think we've gone"],[1183,1258,"too far this time?"],[1291,1370,"He was going to"],[1370,1491,"disband the monarchy."],[1491,1612,"It had to be done."],[1683,1750,"You should have seen"],[1750,1871,"the look in Eleanor's eyes."],[2017,2134,"I knew it would be bad, but"],[2134,2267,"I'll never recover from this."],[2375,2663,"And there's no going back."],[2755,2872,"On the other hand,"],[2880,3001,"you're the Queen of England."],[3043,3185,"And you'll remain the Queen of"],[3185,3331,"England until I marry again."],[3527,3648,"As if."],[3794,3915,"What about Simon?"],[4248,4323,"Pryce?"],[4323,4440,"What do you have for us?"],[4498,4548,"The King"],[4548,4699,"remains in a critical condition."],[4699,4807,"He's unresponsive, and"],[4807,4928,"his breathing is assisted."],[4945,5061,"And his assailant?"],[5141,5295,"This man has become"],[5295,5416,"a person of interest."],[6083,6213,"He stands like that for hours."],[6359,6430,"Who is he?"],[6430,6613,"We've looped in MI5 and MI6,"],[6613,6696,"as well as several branches"],[6696,6788,"of American intelligence."],[6788,6901,"We should have an answer shortly."],[6901,6943,"Good."],[6943,7034,"I want to tell the people"],[7034,7201,"the King's attacker is in hand."],[7205,7305,"Like I said."],[7305,7418,"He's merely a suspect."],[7418,7602,"A psychotic in a hooded sweatshirt"],[7602,7781,"lingers for hours outside the gates."],[7781,7964,"And you don't see a connection."],[7977,8064,"If we arrested everyone"],[8064,8140,"who dressed poorly,"],[8140,8198,"the Prince Regent"],[8198,8298,"would also be in custody."],[8448,8594,"I can't wait to fire you."],[8986,9103,"What are you doing about security"],[9103,9157,"for the King?"],[9207,9391,"We have guards posted at each"],[9391,9574,"entrance to the building, on his floor"],[9574,9699,"and at the entrance to his room."],[9708,9800,"When he's well enough,"],[9800,9908,"I'd like to move him home."],[9933,10104,"Lucius will make all the arrangements."],[10104,10229,"To match to the King's condition is..."],[10229,10288,"Is critical."],[10350,10454,"When he's well enough,"],[10454,10575,"we're bringing him home."],[10650,10717,"I expect you"],[10717,10838,"to have a plan for that."],[10880,11001,"Do you understand me?"],[11034,11088,"As you wish."],[11455,11530,"The closer he is,"],[11530,11710,"the better we can monitor him."],[11797,11977,"See? That's the spirit."],[12031,12106,"Everything's"],[12106,12227,"going to work out."],[12227,12260,"Cyrus,"],[12273,12456,"have you heard anything I've said?"],[12498,12652,"My children hate me."],[12698,12798,"Boring."],[12798,12990,"My children have always hated me."],[13024,13220,"That's what those little bastards do."]],"160":[[165,269,"I can't stop thinking"],[269,373,"about Liam and Lenny."],[373,498,"It's also scandalous."],[502,690,"And to think, we curtsied"],[690,811,"to those halfies."],[853,974,"Can you imagine it?"],[999,1111,"One day you're a Royal,"],[1111,1278,"and the next day you're just people."],[1312,1453,"I feel terrible for them."],[1533,1654,"Yeah, I guess I do too."],[1662,1783,"That would be a nightmare."],[2179,2300,"At least a Queen's still their mum."],[2367,2529,"Yeah, but who cares about that?"],[2588,2692,"It only matters if your father is"],[2692,2892,"the king, those poor bastards."],[2963,3017,"That's the only way"],[3017,3138,"you can inherit the..."],[3251,3359,"Our father’s the king."],[3543,3664,"You know what that means."],[3918,4039,"I'm the next Queen of England."],[4052,4135,"I'm the next Queen of England"],[4135,4256,"if you die."],[4402,4519,"Oh! Come on."],[4598,4673,"Let’s go erase daddy’s"],[4673,4778,"surveillance tapes."],[4778,4940,"Wouldn't it be great if he died soon?"],[5324,5445,"Gemma. Hi."],[5474,5595,"Are you looking for Liam?"],[5599,5749,"I have an audience with the Queen."],[5783,5858,"You?"],[5858,5975,"I'm looking for Liam."],[5995,6083,"Have you spoken with him?"],[6100,6133,"No."],[6262,6325,"I should go."],[6325,6446,"The Queen doesn't like to wait."],[6588,6700,"Gemma, if you see Liam"],[6700,6838,"or hear from him, will you"],[6838,6913,"ask him to call me?"],[7063,7184,"No, I won't."],[7368,7434,"Great."],[7434,7543,"Thanks."],[7543,7664,"It's very telling, though."],[7701,7801,"Liam’s suddenly"],[7801,7952,"not the heir to the throne"],[7952,8068,"and you move on."],[8139,8260,"Maybe you'll sleep with Cyrus."],[8352,8406,"I didn't say"],[8406,8531,"I've moved on from Liam."],[8531,8652,"You said that."],[8661,8840,"I said I wouldn't ask him to call you."],[8857,8948,"Because I won't."],[9107,9257,"I stood by and"],[9257,9457,"let you have your moment with him."],[9520,9670,"I let your romance be"],[9674,9791,"whatever it was going to be."],[9820,10045,"And for a girl in my position, I was fairly"],[10045,10166,"gracious about it all."],[10179,10321,"How many times"],[10358,10450,"have you called"],[10450,10575,"him, or texted"],[10575,10721,"him, or sent word to him"],[10721,10888,"through Marcus or your father,"],[10888,11005,"since the King was attacked?"],[11009,11117,"And how many times"],[11117,11205,"has he replied?"],[11292,11413,"He's moved on."],[11426,11547,"Just as he did"],[11547,11697,"with all the others."],[11855,11985,"Eventually he'll call me"],[12022,12143,"because he always does."],[12248,12456,"And when he does, I will tell him"],[12456,12615,"nothing of your concern."],[12744,12852,"Why would I?"],[12852,12973,"You had your chance."],[12994,13115,"You took your turn."],[13115,13236,"And when you did."],[13244,13428,"How relevant were my feelings to you?"],[13591,13711,"And now you know."],[13878,13999,"I'm trying to find him because"],[13999,14120,"I'm concerned about him."],[14145,14304,"I'm worried that his world has just been"],[14304,14416,"destroyed and he's alone."],[14541,14633,"Maybe you can sit"],[14633,14771,"back and wait for him to call you."],[14771,14954,"But I can't, and I won't."],[15038,15121,"Not for me."],[15121,15242,"For him."],[15326,15447,"If that's your story."]],"161":[[188,371,"I can't imagine how hard this is"],[371,492,"all been for you."],[730,851,"Guilt."],[884,1018,"The pain you've been carrying"],[1018,1122,"around about Robert."],[1414,1543,"But dad,"],[1648,1802,"It wasn’t your fault."],[2044,2165,"It wasn’t."],[2498,2653,"I was supposed to call him dad."],[2657,2824,"I told him I'd call him."],[3228,3349,"Instead."],[3383,3520,"You went clubbing in Paris."],[3891,3979,"It wasn't your fault"],[3979,4100,"either, Lenny."],[5276,5393,"Your Majesty asked for me."],[5410,5531,"Please sit."],[6064,6185,"How long were you with my son?"],[6215,6331,"Six years, Your Majesty."],[6386,6502,"You've done well."],[6548,6686,"I know he likes you very much."],[6874,6995,"What do you know about this?"],[7266,7345,"Perhaps Her Majesty"],[7345,7437,"would prefer an audience"],[7437,7533,"with Mr. Pryce."],[7533,7654,"I've heard from Mr. Pryce."],[7720,7837,"I'm asking you."],[7887,8050,"The subject in question"],[8050,8179,"was observed standing"],[8179,8321,"essentially immobile"],[8329,8404,"for several hours"],[8404,8517,"on three separate occasions."],[8621,8680,"As far as I"],[8680,8859,"know, his identity is unknown."],[8951,9067,"What else?"],[9122,9230,"Ma’am?"],[9230,9434,"Who the hell is this, Marcus?"],[9485,9601,"Your Majesty,"],[9601,9697,"With all due respect."],[9697,9872,"You'd prefer not to speak out of turn."],[9935,10123,"So let me speak first."],[10194,10398,"We are at war, Mr. Jefferies,"],[10473,10648,"and it's becoming increasingly difficult"],[10648,10773,"to tell the heroes"],[10773,10898,"from the villains."],[10961,11086,"I know your service record."],[11195,11336,"I know what you've meant to my son."],[11336,11428,"And my instincts"],[11428,11624,"tell me you can be trusted."],[11708,11824,"So please,"],[11858,11991,"in your professional opinion,"],[12108,12229,"What am I looking at?"],[12471,12596,"The standing is very disciplined."],[12596,12717,"So he's likely ex-military,"],[12738,12859,"possibly Kingsguard."],[12900,12976,"He's carrying a weapon"],[12976,13063,"on his left side."],[13063,13180,"So he's right handed."],[13184,13276,"And he knows exactly"],[13276,13351,"where the cameras are."],[13359,13464,"Which suggests he wants"],[13464,13555,"someone to know is there."],[13676,13718,"He’s there to"],[13718,13814,"provoke a response."],[13964,14089,"I want you to investigate this further."],[14089,14302,"independent of Mr. Pryce,"],[14302,14490,"the MIs, or anyone else."],[14552,14610,"Is that a"],[14610,14731,"direct order, Your Majesty?"],[14877,14998,"Yes, it is."],[15224,15345,"Good luck."]],"162":[[147,268,"Oh, Rachel,"],[419,535,"I want you to arrange a meeting"],[535,648,"with Nigel Moorefield."],[648,781,"Of the anti-monarchist"],[781,823,"movement?"],[869,952,"That very one."],[952,1036,"See if he can come here"],[1036,1115,"as soon as possible."],[1136,1253,"Of course."],[1328,1449,"Rachel."],[1457,1545,"Where do you go"],[1545,1666,"when you're not here?"],[1712,1828,"What do you do?"],[1895,2012,"I'm a dominatrix,"],[2012,2133,"Your Majesty."],[2487,2612,"Well, I bet you're a good one."],[2733,2804,"The best,"],[2804,2925,"Your Majesty."],[2942,3175,"Discreet. Keeper of secrets."],[3292,3409,"Silent as a grave."],[3809,3905,"Nigel Moorefield."],[3955,4039,"Yes, ma'am."],[6254,6375,"Now you hiding from me?"],[6754,6896,"I just can't leave without seeing him."],[6925,7046,"You could have just told me that."],[7054,7175,"I tried."],[7225,7355,"Will you help me find him?"],[7471,7551,"I have direct orders"],[7551,7672,"from the Queen."],[7697,7813,"I'm sorry,"],[7943,8060,"but if I could,"],[8072,8206,"I'd start by tracking his phone."],[8206,8326,"Using your father's access."]],"163":[[17,67,"I don't know why"],[67,196,"you're asking me this again."],[330,522,"I'm the Prince Regent, and I’ve"],[522,684,"already answered these questions."],[688,784,"You've asked me to be thorough"],[784,880,"in this investigation."],[901,1085,"I've asked you to dedicate your time"],[1085,1231,"and energy into discovering the"],[1231,1397,"identity of the man at the gates."],[1564,1710,"And yet, here we are."],[1902,2048,"You don't like me, do you, Pryce?"],[2090,2182,"Prince Liam stated"],[2182,2315,"that you were in the tunnels before him."],[2315,2503,"And your daughter claimed she saw"],[2503,2611,"me lurking in the shadows."],[2611,2707,"Which you denied."],[2707,2828,"But you confirmed on the"],[2828,2932,"security footage."],[2932,3053,"So why lie?"],[3921,4146,"Because I was with James Holloway."],[4204,4325,"We were having sex."],[4367,4467,"He's a married man."],[4467,4592,"I was trying to be honorable"],[4672,4830,"and as honorable as one can be while"],[4830,4972,"sneaking around and having sex"],[4972,5059,"with a married man."],[5172,5272,"But these things are always"],[5272,5472,"a little sticky."],[5572,5760,"Should I spell fellatio for you?"],[6052,6215,"I'll speak with Mr. Holloway."],[6373,6494,"As always,"],[6498,6619,"I appreciate your time."],[6757,6878,"Pryce."],[6928,7003,"I answered"],[7003,7182,"all of your questions twice,"],[7245,7395,"but you never answered mine."],[7449,7570,"No, I didn't."],[7604,7741,"And no, I don't like you."],[7854,7975,"Well done, you."],[8029,8200,"Tell Holloway I said hello."],[8254,8359,"And if you're looking for him,"],[8359,8509,"you might try his closet."]],"164":[[32,149,"You were waiting in the tunnel"],[249,370,"and I was with Ophelia."],[545,666,"I’ll never forgive myself."],[670,791,"It’s not your fault."],[950,1071,"It's not Ophelia's fault."],[1246,1392,"And I think you already know that."],[2126,2214,"Besides, what was it"],[2214,2351,"I told you after Robert died?"],[2560,2681,"Choose love."],[2802,2923,"Choose your own path."],[3085,3211,"I'm choosing my own path."],[3248,3465,"And that own path leads directly to"],[3465,3582,"a hangover."],[4028,4120,"Are you okay, fella?"],[4253,4458,"Fella? Do you believe that?"],[4624,4745,"One day it’s “Your Highness.”"],[4762,4883,"And the next day, fella."],[4979,5100,"Who the hell are you talking to?"],[5363,5467,"Just pour the drinks"],[5467,5588,"Gogmagog."],[5588,5709,"What’d you call me?"],[5842,5963,"Google it."],[5972,6093,"Fella."],[6505,6585,"With all due respect,"],[6585,6635,"Your Majesty,"],[6635,6789,"may I ask what this is regarding?"],[6847,6981,"You have a very unlikable face,"],[6981,7119,"Mr. Moorefield."],[7148,7265,"You look shifty."],[7302,7427,"I've been told that, Your Majesty."],[7677,7736,"But if you're thinking"],[7736,7853,"I had anything to do with"],[7853,7911,"the King's attack..."],[7915,8032,"No. I'm not."],[8057,8182,"Because while you look shifty,"],[8253,8378,"you almost look cowardly."],[8449,8549,"Besides,"],[8549,8762,"anyone named Nigel could ever"],[8762,8966,"or will ever feel a king."],[9104,9221,"Assume that isn't news to you."],[9400,9467,"I didn't ask"],[9467,9588,"you here to accuse you"],[9592,9713,"or to insult you."],[9842,9992,"I asked you here because"],[10034,10209,"should His Majesty not recover,"],[10234,10364,"changes to the succession plan"],[10364,10493,"must be made."],[10535,10718,"You want to deny Cyrus the throne?"],[10735,10860,"Cyrus can have the throne."],[10993,11143,"But have you considered what happens"],[11143,11352,"following the reign of King Cyrus?"],[11623,11744,"Mr. Moorefield,"],[11919,11986,"meet the two"],[11986,12157,"most important British subjects"],[12157,12353,"next, the King and the Prince Regent."],[12432,12570,"Which one of you is next in line?"],[12632,12733,"I am."],[12733,12924,"Yeah, but she was born in a leap year."],[12949,13075,"So technically, she's six."],[13225,13396,"Your name is Moorefield, isn't it?"],[13567,13825,"I like a little more in my field."],[13959,14117,"By field, she means her vagina."]],"165":[[47,155,"Very good."],[155,276,"Walk away."],[668,789,"I see your point."],[1202,1310,"Surely you understand that"],[1310,1477,"this entire scenario"],[1477,1652,"greatly enhances my position."],[1677,1778,"I mean, not to mention"],[1778,1899,"Her Majesty's current"],[1907,2078,"position in the court of public opinion."],[2136,2249,"Anti-monarchist movement"],[2249,2386,"will never succeed."],[2453,2532,"You're like children"],[2532,2728,"casting stones at warships."],[3141,3267,"But what if I were to tell you"],[3267,3438,"you could have the very thing you seek."],[3584,3734,"The dismantling of the monarchy"],[3775,3909,"with your name attached to it"],[3909,4034,"for the rest of time."],[4126,4330,"Should the King not recover, and should"],[4330,4480,"something befall Cyrus,"],[4580,4705,"I need to ask Parliament"],[4705,4856,"to place the Queen in power."],[4910,5031,"I shall need your support."],[5102,5273,"And if I'm successful in return,"],[5331,5465,"you will have my support."],[5490,5648,"It will be England's final monarch."],[5702,5857,"And you'll be the architect of"],[5857,6036,"whatever is to follow."],[6382,6486,"Would you really do that"],[6486,6607,"to your family?"],[7275,7454,"My family's gone, Mr. Moorefield."],[7517,7638,"Once I'm also gone,"],[7742,7950,"you can burn it to the ground."],[9285,9406,"How's New York?"],[9435,9527,"I have to find him."],[9527,9602,"Ophelia."],[9606,9781,"I'm barely holding it together here."],[9819,9986,"You’re supposed to be in New York City."],[9986,10094,"Everything you're chasing"],[10094,10178,"is in New York."],[10182,10274,"Not everything."],[10274,10424,"And not the most important thing."],[10424,10490,"But are you the most"],[10490,10578,"important thing to him?"],[10611,10732,"He's royalty."],[10757,10874,"That'll always come first."],[10878,10999,"You don't know that."],[11024,11183,"He's not the heir to the throne anymore."],[11187,11279,"It doesn't matter."],[11279,11475,"He'll continue to put himself first."],[11475,11592,"When are you going to start"],[11592,11696,"putting yourself first?"],[11754,11950,"I am, dad. Right now."],[12063,12180,"It's worth everything, dad."],[12263,12384,"I have to try."],[13264,13318,"I’m sorry, Your Highness."],[13318,13414,"I can't let you in."],[13439,13523,"What?"],[13635,13744,"It's me."],[13744,13848,"Can you step aside?"],[13848,13994,"We've been told family only."],[14002,14123,"I'm sorry."],[14127,14244,"Family only."],[14411,14532,"Says who?"],[14599,14753,"Just a little eyebrow shaving"],[14753,14949,"and one of those bee pollen facials."],[15007,15087,"You!"],[15137,15258,"I have to go."]],"166":[[17,192,"I’m gonna kick your ass."],[455,626,"All the king's men!"],[701,876,"It’s that half breed blood in her."],[1060,1222,"You're sitting on the throne."],[1314,1452,"You got what you wanted."],[1452,1577,"What does it matter to you"],[1581,1819,"if I am at my father's bedside?"],[1835,2011,"He's not your father."],[2052,2165,"You must let it go."],[2165,2369,"This is going to come back to you."],[2373,2478,"When the King wakes up,"],[2478,2578,"and he will,"],[2578,2799,"your little reign of terror will be over."],[2799,2924,"So you better enjoy it."],[2928,3112,"Oh, I will. I am."],[3145,3241,"And I think you mean"],[3241,3387,"if not, when?"],[3666,3775,"You think you're good at this?"],[3896,4104,"You think you're the only one"],[4104,4271,"that can mess with people's lives?"],[4350,4463,"You're not."],[4484,4609,"You threatening me?"],[4621,4659,"No."],[4734,4872,"I'm promising you."],[4959,5059,"Your day of reckoning"],[5059,5114,"is coming."],[5134,5260,"So dramatic."],[5280,5397,"Yeah."],[5401,5631,"You can suck my dramatic dick."],[5660,5781,"You desperate,"],[5814,6019,"reprehensible failure."],[6177,6298,"You better watch your back."],[7091,7216,"The hell is this?"],[7249,7345,"We're redecorating."],[7345,7437,"Yeah, our new room."],[8225,8400,"Tell them we'll have a statement"],[8400,8538,"when we have a statement."],[8605,8742,"Well, the King's dying and all"],[8742,8917,"they want to talk about is who I slept"],[8917,9038,"with 20 years ago."],[9080,9247,"I am the goddamn Queen of England."],[9418,9539,"News?"],[9568,9702,"His name is Brandon Boone,"],[9714,9873,"24 years old, military."],[9881,9981,"But he's recently gone"],[9981,10089,"AWOL from his unit..."],[10089,10198,"Which was also Robert's unit."],[10235,10394,"MI5 has confirmed this information."],[10423,10561,"Agent Jeffries is correct."],[10561,10719,"Brandon Boone was a member"],[10719,10840,"of Robert's military company."],[10840,10953,"And do we still think"],[10953,11074,"it's all a coincidence,"],[11074,11124,"Mr. Pryce?"],[11124,11199,"What's going on here?"],[11291,11395,"I asked Mr. Jeffries"],[11395,11495,"to look into our suspect,"],[11495,11695,"independent of your investigation."],[11695,11845,"And while you were busy focusing on me,"],[11845,11983,"it seems your young charge"],[11983,12179,"has done your job for you, Pryce."],[12296,12413,"Good work."],[12413,12534,"But if you could give us a moment."],[12934,13076,"For more than 20 years, I've given"],[13076,13197,"my life to this family."],[13247,13359,"The King believed in me."],[13359,13447,"He trusted me."],[13447,13610,"And look where that got him."],[13835,14014,"Find this Boone, Mr. Pryce."],[14077,14219,"Earn that trust."],[14319,14385,"Walk away."],[14694,14802,"And tell your daughter"],[14802,14936,"the Prince Regent is now"],[14936,15078,"accepting apologies."]],"167":[[325,509,"It was a giant, Gogmagog."],[530,663,"A detestable monster."],[693,813,"They threw him off the cliff."],[905,1022,"You can read."],[1110,1193,"Well done, you."],[1222,1301,"I can also add."],[1356,1452,"Time for you to close up"],[1452,1573,"your bar tab."],[1998,2119,"Here's the thing."],[2144,2211,"Yesterday,"],[2211,2327,"I was supposed to become..."],[2327,2507,"The next king of England. So?"],[2644,2765,"So people usually take care"],[2765,2882,"of these things for me."],[2903,2953,"Right."],[2953,3120,"Ask my security detail."],[3550,3862,"I don't actually have security any longer."],[3875,3996,"Shame."],[4004,4121,"You could have used them."],[4175,4325,"You come into my bar, you sit there"],[4325,4442,"talking to yourself,"],[4455,4576,"you insult me."],[4626,4759,"And I don't want to pay for your drinks."],[4926,5043,"Perhaps I can make a call."],[5568,5689,"Right."],[5948,6069,"You know,"],[6094,6185,"Some people liked"],[6185,6306,"the Gogmagog"],[7245,7328,"Stay down."],[7374,7495,"Your Highness."],[8759,8859,"Stay down."],[9639,9756,"Leave it, mate."],[9827,9948,"Sit down, kid."],[10373,10494,"Have a pint"],[10569,10686,"on me."],[11161,11228,"See that, dad?"]],"168":[[400,521,"Daddy,"],[525,642,"will you tell Eleanor to give us back"],[642,734,"our new room?"],[788,905,"Tell her yourself."],[905,1088,"We tried but she yelled at us."],[1088,1176,"And she pushed our faces."],[1176,1289,"She can't do that, can she?"],[1289,1439,"No, but I can."],[1443,1564,"I just don't think it's fair"],[1564,1760,"that I am next in line to the throne,"],[1760,1835,"after you die."],[1835,1902,"Hopefully soon."],[1902,2064,"And she acts like she's the princess."],[2081,2235,"She is a princess."],[2273,2369,"Yeah, the Queen told that"],[2369,2498,"sexy Moorefield guy"],[2515,2665,"that we were the most important"],[2665,2803,"people next to you and the King."],[2819,2940,"What Moorefield guy?"],[2970,3107,"Nigel Moorefield?"],[3107,3291,"More like Nigel Yumfield"],[3303,3412,"When was this?"],[3412,3512,"It was a while ago."],[3512,3578,"He was nice."],[3578,3603,"Yeah."],[3704,3774,"You've done well,"],[3774,3941,"my incredibly dumb daughters."],[4037,4171,"Very well. Oh."],[4942,5042,"Let me ask you a question."],[5143,5263,"Why’d you keep getting up?"],[5397,5518,"Where'd you get that strength?"],[5618,5739,"My father."],[5918,5998,"He's dying."],[5998,6114,"I don't think he's gonna make it."],[6419,6494,"Well, if that's where"],[6494,6573,"your fight comes from,"],[6644,6761,"I wouldn't count 'em out."],[6978,7099,"Cheers."],[7541,7687,"Well, you look like shit."],[7753,8037,"Yeah, well, your timing sucks."],[8146,8266,"You need to return to the palace."],[8300,8513,"There are some things happening"],[8513,8633,"regarding the King's attack."],[8709,8763,"Not to mention"],[8763,8884,"Ophelia is worried about you."],[9021,9142,"I can't go back."],[9188,9234,"Not yet."],[9259,9284,"Sir."],[9284,9405,"Marcus, don't call me sir, okay?"],[9643,9764,"I can't go back just yet."],[9864,9972,"But I know you'll do everything"],[9972,10118,"you can to find justice for the King."],[10277,10394,"And Ophelia?"],[10648,10769,"Just tell her I'm okay."],[11728,11849,"You should tell her yourself."]],"169":[[934,1055,"I would tell the truth."],[1247,1364,"I know you've been waiting."],[1647,1735,"I wanted to see you"],[1735,1960,"because I know this news affects"],[1960,2077,"you as well."],[2106,2227,"You must be upset with me."],[2260,2377,"Why would I be upset with you?"],[2452,2548,"Liam was this close"],[2548,2652,"to being the next king."],[2707,2828,"You might have been his queen."],[3028,3170,"I really don't appreciate how"],[3170,3311,"everyone is underestimating"],[3311,3374,"me today."],[3411,3532,"Did you ever think"],[3574,3641,"maybe"],[3641,3816,"I actually had feelings for him?"],[3879,3933,"No."],[4029,4104,"Why?"],[4262,4383,"Because you're a lot like me."],[4517,4717,"And because you said “had.”"],[4821,4921,"He's no longer in line"],[4921,5042,"for the throne."],[5076,5172,"If you loved him,"],[5172,5313,"you'd have said, “have.”"],[5468,5530,"Have."],[5530,5785,"Then I do love him."],[5868,5985,"Whether anyone believes it"],[5985,6106,"or understands it or not,"],[6164,6227,"a girl has that"],[6227,6360,"prerogative when it comes to love."],[6394,6481,"Which is exactly what"],[6481,6602,"you should say to the press."],[6636,6744,"The King's been attacked."],[6744,6890,"People don't want to hear about love."],[6919,7015,"The people"],[7015,7169,"always want to hear about love."],[7211,7299,"They want their queen"],[7299,7445,"to be honest and raw"],[7449,7566,"and vulnerable."],[7607,7682,"They want to see you"],[7682,7799,"as one of them."],[7833,7954,"I’m the Queen of England."],[7970,8087,"You are now."],[8095,8200,"But once upon a time,"],[8200,8396,"you were simply a young girl who"],[8396,8475,"placed the duties"],[8475,8638,"of her family before her own"],[8638,8758,"heart's desire."],[8784,8929,"Eventually your heart got the better"],[8929,9046,"of you and you slipped."],[9313,9488,"I was married to the King by then."],[9534,9655,"And we had a son."],[9830,9960,"The heart wants what it wants."],[10139,10268,"But the marriage was arranged."],[10268,10389,"And you honored the pact like a"],[10389,10510,"dutiful daughter of England."],[10619,10740,"The people won't accept"],[10740,10865,"the idea of an arranged marriage."],[10890,10998,"They love the King."],[10998,11119,"And so do you."],[11186,11253,"With time,"],[11253,11369,"you found love again with"],[11369,11432,"your husband,"],[11432,11557,"the King of England."],[11691,11866,"You ask for time with your family,"],[11866,12016,"space for the children,"],[12016,12099,"and prayers for the King."],[12099,12220,"Blah blah blah."],[12416,12537,"Do you really love my son?"],[12704,12758,"I don't know."],[12758,12879,"Do I?"]],"170":[[2707,2828,"I thought I could do it."],[3062,3158,"Do what?"],[3158,3279,"Be king."],[3483,3604,"Be great."],[3683,3742,"Turns out"],[3742,3863,"you're not even my father."],[4092,4234,"At least now it's over."],[4342,4538,"It's hard sometimes, isn't it?"],[4743,4859,"It's hard for all of us."],[5089,5210,"Why can't life be fair?"],[5277,5569,"Reward the just and the kind"],[5669,5790,"and the good."],[5827,6023,"Life doesn't care about justice."],[6069,6152,"The world kicks"],[6152,6273,"your ass sometimes,"],[6415,6536,"but you work through it."],[6665,6786,"You ask for help."],[6866,6987,"Try again."],[7128,7391,"And sometimes you have to fight back."],[7495,7554,"Sometimes"],[7554,7679,"you have to fight your way in."],[8259,8392,"This is where the plot thickens."],[9222,9343,"Wait."],[9506,9627,"Don't leave me."],[9723,9985,"Please. Dad."]],"171":[[780,872,"They've moved him"],[872,993,"back to the palace."],[1005,1126,"I'm sorry."],[3249,3366,"Rachel."],[3449,3591,"I want to do a television interview."],[3649,3754,"Something seemingly"],[3754,3912,"informal, but controlled."],[3945,4066,"Call the team together."],[4167,4304,"If I could speak candidly,"],[4304,4425,"Your Majesty,"],[4509,4667,"More candidly than revealing"],[4667,4788,"you're a dominatrix."],[4851,4967,"Please do."],[4988,5109,"People pay me"],[5147,5339,"excessive amounts of money"],[5393,5580,"because their bodies and hearts"],[5601,5722,"need things."],[5843,6035,"The two things most people have"],[6093,6181,"are secrets"],[6348,6469,"and desires."],[6502,6769,"And quietly behind all the noise"],[6769,6932,"and the facade of their daily lives,"],[7074,7220,"they’ll understand those things."],[7466,7582,"And forgive them."],[8208,8271,"I understand"],[8271,8396,"you had a visitor today,"],[8396,8563,"Nigel Moorefield."],[8700,8934,"Simply keeping our enemies close."],[8934,9126,"And is that what I'm doing as well?"],[9222,9343,"You're not even technically"],[9343,9443,"on the throne yet, Cyrus."],[9447,9680,"It's a little early to be so paranoid."],[9685,9826,"I simply thought we had a full"],[9826,9993,"disclosure relationship."],[10114,10277,"Full disclosure works both ways."],[10281,10406,"Meaning what exactly?"],[10665,10752,"Meaning?"],[10752,10898,"I know where you went that night."]],"172":[[96,146,"When I said"],[146,267,"I was disappointed in you,"],[425,580,"it's because I see what you can be."],[776,984,"Robert used to say the same thing."],[1022,1155,"But when he needed me,"],[1155,1276,"I wasn't there."],[1518,1672,"I told him I'd call."],[2031,2165,"Knowing what you meant to Robert,"],[2327,2507,"knowing how much he loved you,"],[2661,2815,"do you really think he would have"],[2815,2957,"chosen to leave you?"],[3274,3408,"You already know the answer."],[3658,3779,"You just have to believe it."],[7341,7457,"Princess."],[7658,7779,"5 seconds, that alarm goes off."],[7779,7895,"So you need to listen to me."],[7916,8037,"I have information for you."],[8446,8567,"Is this about my father?"],[8567,8646,"It's about Robert."],[8725,8830,"You need to know you're not safe."],[8855,8976,"Who are you?"],[9013,9134,"That's not important."],[9205,9363,"The St. Christina Bridge in Holborn."],[9368,9493,"Meet me beneath it tomorrow"],[9493,9543,"at midnight."],[9597,9672,"And trust no one."],[9672,9785,"Especially not in the palace."],[9785,9922,"You expect me to just meet"],[9922,10089,"some psycho at midnight?"],[10098,10198,"If you want to know about"],[10198,10319,"Robert's death, you will."],[10481,10611,"My brother didn't kill himself,"],[10611,10665,"did he?"],[10698,10727,"No."],[10898,11019,"He was murdered."],[11069,11186,"Wait."],[11315,11403,"How do you know this?"],[11991,12095,"Because I'm the one that killed him."]],"173":[[12,183,"By the time you read these words,"],[208,329,"it will be done."],[350,508,"I only hope you can understand"],[525,679,"and accept why I did it."],[738,850,"And that someday"],[850,967,"you'll forgive me."],[967,1084,"Liam."],[1084,1176,"Seriously."],[1176,1343,"Call me back."],[1343,1493,"There is a very small"],[1493,1609,"possibility that I might"],[1659,1793,"actually be worried about you."],[4725,4846,"You okay?"],[5000,5050,"I had a dream."],[5050,5171,"We left the safe room"],[5263,5384,"and they declared me illegitimate."],[5438,5630,"And you got drunk, got in a fight,"],[5630,5751,"and blacked out in the rain."],[5851,5968,"Not so much a dream."],[6089,6222,"I brought you home through the tunnels."],[6264,6385,"It was as far as I could get you."],[6535,6652,"Sorry for going dark."],[6744,6865,"Wasn't fair to you."],[7027,7144,"I was just worried about you."],[7482,7536,"My father is..."],[7536,7603,"Still fighting."],[7736,7857,"They brought him home."],[7887,8008,"When you feel up to it, we can..."],[8028,8149,"I’m okay."],[8241,8270,"I mean"],[8400,8512,"hungover."],[8512,8633,"I could sleep for a week."],[8904,9025,"But for the first time in my life,"],[9292,9430,"I opened my eyes and I was free."]],"174":[[713,834,"A life lived"],[972,1093,"not destined."],[1222,1289,"What?"],[1564,1685,"Something my father said."],[1894,2015,"Let's get out of here."],[2090,2161,"Want to?"],[2186,2240,"Okay."],[2323,2402,"We can go to my place."],[2411,2482,"No, I mean somewhere else"],[2482,2548,"in the world."],[2628,2740,"Me and you."],[2757,2861,"Today."],[2978,3032,"But your father..."],[3032,3099,"would want this."],[3116,3237,"He told me as much."],[3303,3387,"Pick a place."],[3466,3512,"Anywhere."],[3512,3633,"First place that comes to mind."],[3850,3954,"Rio."],[3954,4054,"I’ve always wanted to go."],[4054,4112,"Perfect."],[4163,4217,"You in?"],[4396,4488,"Liam, we can't."],[4488,4617,"Actually, for the first time, we can."],[4663,4784,"We can get out."],[4834,4897,"Haven’t you ever thought"],[4897,5013,"about what that would be like?"],[5164,5284,"I always wanted you."],[5339,5405,"It was your world"],[5405,5526,"I didn't want."],[5693,5810,"So let us make our own world."],[5893,6089,"Me and you, starting today."],[6665,6786,"I can't tell my father."],[6957,7078,"Tell them when we land."],[7141,7249,"If we tell them before we go,"],[7249,7370,"they will never go."],[7666,7787,"Are you sure about this?"],[8062,8183,"Truth is,"],[8354,8471,"I'm not going without you."],[9117,9284,"You're going on a little trip."],[9384,9505,"I'm sorry."],[9505,9681,"Three years in Gibraltar caring"],[9681,9860,"for the deceased and infirm."],[9960,10106,"Your service is immensely"],[10106,10352,"noble and inspiring."],[10369,10544,"I did what you asked me to do."],[10619,10715,"I declared the prince and"],[10715,10815,"princess illegitimate."],[10819,10940,"Yes you did."],[10957,11053,"But someone might want"],[11053,11174,"to change those results."],[11174,11332,"And I'm not sure we can trust you."],[11349,11453,"Trust me?"],[11453,11578,"I don't even know the results."],[11582,11708,"We didn't even test the blood."],[11741,11870,"Furthermore, the King has been moved"],[11870,12000,"back into the palace and requires"],[12000,12116,"24 hour care."],[12116,12287,"His life hangs in the balance."],[12329,12483,"Machines are breathing for him."],[12492,12667,"It is imperative that I be here."],[12738,12859,"We'll take care of him."],[12946,13101,"The Royal jet is waiting."],[13163,13301,"Get on the plane, doc."],[13505,13609,"Or what?"],[13609,13730,"Lose my career."],[14006,14127,"Your career?"],[14177,14373,"Is that all you think you'll lose?"]],"175":[[1147,1264,"Liam,"],[1322,1381,"I'm afraid"],[1381,1527,"I must ask you to leave."],[1585,1727,"By order of the Prince Regent."],[1810,1927,"Family only."],[1981,2065,"If you're going to speak to me"],[2065,2186,"like that, Lucius,"],[2252,2373,"you can at least address me"],[2373,2511,"as His Royal Highness."],[2632,2753,"I'm afraid that title"],[2753,2920,"has been taken from you as well."],[2945,3066,"Cyrus can keep the title."],[3153,3274,"But I'm staying here."],[3345,3466,"If the Prince Regent"],[3466,3587,"has a problem with that,"],[3604,3783,"he can speak with me directly."],[4133,4254,"The King is my family."],[4354,4475,"But he's not yours,"],[4555,4671,"so get out."],[4717,4838,"Rules are rules."],[5764,5806,"So what?"],[5806,5927,"You missed the sex?"],[7320,7399,"I’ve rescinded the"],[7399,7495,"charges against you."],[7637,7758,"No apology?"],[7887,8079,"No. Get in."],[9480,9585,"The King is supposedly"],[9585,9706,"no longer my father."],[9731,9826,"Everyone is being"],[9826,9943,"manipulated by Cyrus."],[9943,10073,"No one is to be trusted."],[10073,10214,"And I can't find Liam."],[10256,10452,"So, ironically, I now turn to you."],[10473,10577,"The one person who I could"],[10577,10736,"never trust, who suddenly,"],[10736,10844,"may be the only person"],[10844,10915,"who can keep me"],[10915,10973,"from waking up dead."],[11094,11240,"Now get in."],[11478,11620,"Do you even know how to drive?"],[11716,11999,"No, but I am figuring it out."],[12558,12675,"I need you out."],[12725,12800,"Thank you."],[12888,13017,"We do what we have to do"],[13051,13167,"to protect the throne"],[13205,13342,"and to protect ourselves."],[13443,13564,"This is not the end."],[13626,13747,"I promise."],[13785,13906,"In many ways,"],[13985,14106,"it is our beginning."]],"176":[[421,551,"Comfortable at my desk?"],[638,734,"It's Simon's desk."],[734,918,"It's the ruling monarch's desk."],[918,993,"And I'm not sure if"],[993,1064,"you've heard,"],[1064,1180,"but that would be me."],[1235,1272,"Rachel."],[1631,1752,"Your Majesty."],[1789,1823,"I'd like to"],[1823,1965,"have this desk destroyed,"],[1994,2086,"preferably burned"],[2086,2207,"beyond recognition."],[2207,2378,"And I'd like to have the ashes sprinkled"],[2378,2448,"into something that'll"],[2448,2594,"fit up Cyrus's ass."],[2624,2749,"Oh, that shouldn't be a problem,"],[2749,2807,"Your Majesty."],[2861,3011,"Trust me, I know just the type."],[3041,3137,"I know you do."],[3137,3258,"Thank you. Rachel."],[3274,3395,"My pleasure."],[3408,3529,"Literally."],[3629,3758,"So we had a little tiff."],[3762,3837,"Fine."],[3837,3929,"But moving forward,"],[3929,3996,"we need each other."],[4071,4284,"Let's simply agree to full disclosure,"],[4284,4450,"and our alliance will be invincible."],[4525,4680,"We both have a monarchy to gain."],[4751,4805,"And yet I'm"],[4805,4963,"the only one with a great deal to lose."],[4963,5055,"Yeah. Yes."],[5055,5176,"Dear Alistair,"],[5189,5285,"what are we doing about"],[5285,5435,"our dashing loose end?"],[5468,5564,"I'm taking care of it."],[5610,5639,"How?"],[5743,5923,"I said I'm taking care of it."],[6010,6219,"So much for full disclosure."],[7124,7241,"I was joking, Rachel."],[7282,7445,"Oh, shit."]],"177":[[275,409,"Well, it's the other halfie."],[855,897,"Did you say"],[897,1018,"I couldn't see my father?"],[1030,1160,"Oh, not this again."],[1206,1343,"It's for the King's safety."],[1347,1468,"It's nothing personal."],[1468,1564,"It's completely personal."],[1564,1660,"And we both know it."],[1660,1777,"So now what? Do you"],[1777,1898,"plan to be a problem"],[1898,2098,"like your common blood sister?"],[2115,2232,"Actually,"],[2273,2390,"I’d like to concede"],[2498,2615,"I have a proposition for you."],[2770,2907,"This should be interesting."],[3228,3349,"You want me gone?"],[3379,3454,"You want to run the monarchy"],[3454,3575,"however you see fit."],[3641,3725,"Fine."],[3725,3791,"You can have it."],[3791,3912,"I'll leave today."],[3921,4038,"And what's the catch?"],[4079,4200,"I need the plane."],[4238,4338,"I assuming since I've been stripped"],[4338,4446,"of my title and restricted"],[4446,4530,"from seeing the King,"],[4596,4717,"The plane is off limits as well."],[4780,4909,"So if I give you access"],[4909,4968,"to the plane,"],[4968,5139,"you'll leave and not return."],[5143,5193,"That's right."],[5351,5406,"Fine."],[5406,5493,"I'll even arrange a"],[5493,5652,"car to take you to the airport."],[5652,5756,"I insist."],[5756,5814,"No, thanks."],[5877,5998,"I don't trust you."],[6006,6081,"Just the plane."],[6144,6273,"What? No hugs goodbye?"],[6940,7161,"So let me get this straight."],[7232,7349,"The King's been stabbed."],[7362,7466,"Liam's missing."],[7466,7595,"And you've agreed to meet"],[7595,7708,"some self-professed"],[7708,7879,"psychotic murderer under a bridge."],[7879,7954,"And you're not worried"],[7954,8000,"about that?"],[8042,8162,"Of course I'm worried about that."],[8162,8279,"What do you think you're doing here?"],[8371,8521,"Oh, I don't know."],[8521,8642,"What am I doing here?"],[8696,8859,"Well, as far as I can tell, you’re the"],[8859,9093,"go to guy for three things, Jasper."],[9113,9368,"To videotape and blackmail me,"],[9389,9510,"to go down on my mother,"],[9572,9672,"And to protect me"],[9672,9797,"from a psychotic murderer"],[9797,9952,"who wants to meet me under a bridge."],[10002,10081,"Considering we've"],[10081,10240,"already ticked the first two boxes,"],[10240,10365,"I figured you’d be up to the third."],[10515,10577,"Okay, but we have"],[10577,10694,"to go to the palace first."],[10698,10786,"That's fine, but you'll have to"],[10786,10861,"wait in the car."],[10861,10982,"Wait."],[11136,11182,"I thought you said"],[11182,11303,"the charges have been dropped."],[11307,11403,"Well, they have been."],[11412,11520,"Technically, you’re allowed"],[11520,11612,"in the palace."],[11637,11783,"We just don't have time for you"],[11783,11904,"to sleep with my mum."],[12020,12141,"You realize there was no videotape?"],[12150,12321,"Yes, I know that."],[12329,12450,"Thank you."]],"178":[[784,913,"Dad, you scared me."],[980,1101,"Are you going to New York now?"],[1255,1372,"Yeah."],[1430,1551,"It's a good opportunity."],[1597,1718,"I'm lucky to have it."],[1797,1918,"It's what I want."],[1918,2035,"And did Prince Liam"],[2035,2152,"have anything to do with this?"],[2239,2356,"I guess."],[2569,2685,"It's not going to work out."],[2848,2969,"I'm sorry, honey,"],[3007,3144,"but it's for the best."],[3219,3340,"Focus on your dancing."],[3340,3436,"Chase your dreams."],[3436,3603,"Everything else will fall into place."],[3641,3762,"You're right."],[3774,3895,"I'll call when I land."],[3908,4029,"And if I get it,"],[4079,4195,"you can send my stuff."],[4195,4316,"Hey, I'll bring your stuff."],[4450,4571,"And you'll get it."],[4612,4733,"And you'll deserve it."],[4813,4929,"Thanks, dad."],[5380,5501,"I love you, dad."],[5568,5688,"Trust that I do."],[5734,5855,"Oh, I do."],[5910,6031,"And I love you, too."],[6118,6239,"More than anything."],[6681,6802,"And I'm proud of you."],[9843,9964,"Lucius."],[10055,10164,"I'd like you to deliver"],[10164,10281,"this letter for me."],[10335,10460,"You're the only one I can trust."],[10618,10677,"I will guard it"],[10677,10794,"with my life, Your Majesty."],[10835,10944,"I know you will."],[10944,11061,"Is Your Majesty"],[11061,11211,"prepared for her interview"],[11211,11327,"this evening?"],[11382,11503,"As much as I'll ever be."],[11540,11640,"Will you tell her advisors"],[11640,11745,"to make sure the interview"],[11745,11874,"doesn't stray from our script."],[11882,12007,"I will see to it personally."]],"179":[[1218,1289,"Hello."],[1289,1389,"Go to your vanity."],[1389,1464,"Reach underneath it."],[1464,1585,"I need you to get me something."],[1597,1718,"Under my vanity."],[1739,1827,"In my room."],[1827,1856,"Yeah."],[1856,2006,"Where you kept her drugs for weeks."],[2119,2206,"Yes. Thank you."],[2206,2298,"But it's my room."],[2298,2411,"And they're my drugs."],[2411,2469,"Just hold on."],[2840,2890,"A gun?"],[2890,2940,"Yeah."],[2940,3024,"Be careful."],[3024,3149,"The safety zone. But it's loaded."],[3182,3328,"He kept a loaded gun in my room?"],[3332,3412,"Yes, I did."],[3412,3528,"Now set it down on the bed"],[3528,3604,"and go and check up"],[3604,3724,"above your fake armoire."],[3883,4037,"You’re a peice of work, Jasper."],[4142,4292,"It's my mother's vagina up there?"],[4342,4446,"You got to let that go."],[4571,4655,"Another gun."],[4655,4763,"You're so American."],[4763,4838,"Yeah. You should be glad"],[4838,4934,"I am right about now."],[4934,5038,"That one's also loaded."],[5038,5134,"Set it down on the bed"],[5134,5247,"and go over the fireplace."],[5247,5334,"You know you could have just asked me"],[5334,5426,"before you did this."],[5426,5564,"Considering our relationship,"],[5564,5685,"I didn't want you to have access"],[5685,5768,"to loaded firearms."],[5806,5935,"It wasn't a relationship."],[5973,6089,"I'm at the fireplace."],[6110,6139,"Okay."],[6139,6281,"Reach in and up."],[6481,6602,"Ridiculous."],[6807,6836,"Great."],[6836,6965,"I got your stash, Rambo."],[7053,7086,"Okay."],[7086,7207,"Put the guns in the bag"],[7207,7299,"and get out of there."],[7303,7370,"Use the tunnels."],[7370,7499,"Don't talk to anyone."],[7499,7591,"And be careful."],[7591,7712,"Copy that. Over and out."],[7737,7858,"We don't say that."],[7874,7991,"And it was a relationship."],[9030,9122,"Thank God."],[9122,9297,"I have been so worried about you."],[9305,9422,"I know, I'm sorry."],[9443,9564,"I have so much to tell you."],[9564,9676,"What happened to you?"],[9676,9797,"I've got in a little scuffle."],[9872,9918,"I have something"],[9918,10039,"to tell you as well."],[10173,10385,"I'm leaving with Ophelia."],[10427,10523,"What? When?"],[10523,10581,"Today. Right now."],[10581,10702,"I want you to come with us."],[10782,10848,"Liam, I can't."],[10848,10944,"We can. We can just go, Len."],[10944,10998,"Leave all this behind."],[11078,11169,"And when dad is well and we can"],[11169,11286,"make things right, we'll come home."],[11374,11445,"Come with us."],[11445,11561,"I don't want to go without you."],[11582,11707,"I can't. Not yet, Liam."],[11707,11791,"But you should go."],[11791,11828,"Len."],[11945,11974,"You know,"],[11974,12095,"I never thought you'd get out."],[12220,12362,"But it makes me so happy that you will."],[12417,12533,"And that you'll be with Ophelia."],[12633,12754,"But I'm going to miss my brother."],[12892,12988,"Promise me you'll join us."],[13109,13209,"There’s just a few things that I"],[13209,13330,"need to make right before I do."]],"180":[[321,371,"Your Highness."],[371,517,"Can't talk. Got to go. In a rush."],[859,934,"I understand"],[934,1163,"you've moved on to an actual suspect."],[1217,1355,"You bring me this man's head,"],[1355,1409,"and you might"],[1409,1601,"just save your job, Pryce."],[1764,1860,"I notice you haven't yet"],[1860,1981,"visited the King."],[2031,2156,"You might want to do so now."],[2189,2310,"Your mother's with him."],[2811,2932,"Mum."],[2965,3015,"Son."],[3428,3549,"They told me"],[3607,3787,"he's not doing so well."],[3820,4016,"He's strong. He'll pull through."],[4020,4141,"I don't think he will."],[4270,4483,"That would put you on the throne."],[4637,4767,"Yes, I suppose it would."],[5021,5142,"You can do it."],[5150,5242,"I've always known"],[5242,5330,"this time would come."],[5330,5555,"And when you did, you would handle it"],[5555,5793,"with grace and humility."],[5901,6051,"You've always been a good boy,"],[6114,6231,"and I'm proud of you."],[6347,6468,"Thank you, Mum."],[6648,6961,"Now, let me tell you something."],[6961,7098,"You have to be careful."],[7177,7361,"Especially with that brother of yours."],[7361,7507,"You can't trust him, Simon."],[7578,7632,"Mum?"],[7640,7707,"Cyrus"],[7711,7874,"has always been jealous of you."],[7874,7995,"You have to watch him."],[7999,8120,"He's not like you."],[8283,8404,"He never was."],[8462,8771,"And he never will be."],[8904,9025,"Your father"],[9046,9234,"doesn't have much time left."],[9296,9509,"This is your time now."],[9851,9968,"I'll do my best."],[11995,12358,"Mum, I know dad loved you."],[12358,12491,"And I love you too."],[12629,12758,"And so does Cyrus."],[12996,13138,"Do you think so?"],[13246,13405,"Of course he does."],[13555,13676,"Very much."]],"181":[[726,847,"What kind of mongrel leaves"],[847,968,"without saying goodbye?"],[1131,1235,"The private jet is waiting."],[1285,1360,"Rio, is it?"],[1390,1506,"Well, we thought it best to leave first,"],[1506,1586,"and say goodbye later."],[1606,1715,"That's a sound plan."],[1715,1828,"But I prefer my goodbyes"],[1828,1869,"in person."],[2570,2691,"Six years."],[2858,2899,"Can't believe"],[2899,3020,"I'm finally getting rid of you."],[3025,3150,"My thoughts exactly, sir."],[3546,3634,"Travel safe."],[3634,3754,"Stay in touch."],[3834,3955,"It's been my sincere pleasure"],[3955,4026,"knowing you."],[4084,4159,"Pleasure's mine."],[4272,4301,"Sir."],[6899,7033,"How noble of you, Marcus."],[7074,7229,"Watching the girl of your dreams"],[7229,7358,"ride off into the sunset"],[7358,7479,"and letting her go."],[7638,7742,"Too bad she won't be going to"],[7742,7900,"New York for that audition though."],[8171,8246,"We Kensington's"],[8246,8363,"are patrons of the arts."],[8405,8526,"My parents hear things."],[8593,8714,"She deserves to be happy."],[8772,8889,"They both do."],[8893,9014,"Of course they do."],[9014,9114,"But you've been around Liam"],[9114,9231,"for six years."],[9314,9356,"What happens"],[9356,9477,"when he grows tired of her?"],[9489,9610,"We both know he will."],[9627,9744,"He always does."],[9919,9990,"She’ll be the girl"],[9990,10111,"who gave up her dreams"],[10165,10303,"and can't get them back."],[10415,10615,"Because by then it'll be too late."]],"182":[[67,238,"What are we going to do for money?"],[313,434,"I brought a little cash."],[555,676,"And by a little,"],[718,839,"I mean a lot."],[922,1043,"We’ll be fine."],[1160,1281,"And then what?"],[1310,1431,"We have to do something."],[1669,1785,"Maybe I'll be a fisherman."],[1927,2044,"That was always my father's dream."],[2227,2348,"How about you?"],[2644,2803,"I'll have a flower stand,"],[2886,3049,"a little cart on a pretty corner"],[3049,3166,"somewhere."],[3337,3458,"Will you miss dancing?"],[3629,3750,"That's okay."],[3808,3908,"We can dance together."],[3908,4042,"And that will be more than enough."],[4355,4492,"What's that on your chain?"],[4534,4655,"Oh, you've seen my St. Christopher?"],[4659,4780,"I know, but why'd you change it?"],[6144,6177,"Yesterday,"],[6177,6298,"when you found me in that alley,"],[6394,6503,"What time was it?"],[6503,6632,"I didn't find you in an alley."],[6640,6761,"I found you in the park."],[7508,7587,"Prince Liam,"],[7587,7708,"There's a call for you."],[7966,8087,"Be right back."],[8254,8354,"By the way, you look beautiful."],[9735,9856,"Thank you."],[10014,10081,"Hello."]],"183":[[37,112,"This afternoon,"],[112,241,"in an unprecedented"],[241,358,"and historic event,"],[392,567,"Her Majesty, the Queen"],[567,646,"has agreed to speak"],[646,788,"candidly from"],[788,946,"within the walls of the palace."],[1046,1117,"Recently,"],[1117,1272,"the world was shocked to learn"],[1305,1397,"that Prince Liam"],[1397,1522,"and Princess Eleanor"],[1547,1684,"are not, in fact,"],[1684,1880,"legitimate heirs to the throne."],[1939,2077,"No, they are not."],[2110,2289,"Can you help us understand this?"],[2502,2623,"Before I was your queen,"],[2748,2936,"I was not an aristocrat."],[3040,3161,"I was not royalty."],[3332,3453,"I was just a girl."],[3641,3799,"And then I met a young prince"],[3928,4124,"who would one day become king."],[4504,4587,"Everything okay?"],[4587,4708,"Yeah."],[5054,5155,"Is this your phone?"],[5221,5251,"No."],[5830,5910,"When was Dr. Cohen"],[5910,5964,"on this plane?"],[6081,6172,"This morning,"],[6172,6281,"We took him to Gibraltar"],[6281,6410,"for an extended service mission."],[6506,6627,"I can take that."],[7353,7428,"At some point,"],[7428,7582,"I decided to live with the lie."]],"184":[[25,95,"I decided"],[95,275,"it was better for everyone"],[300,525,"if I remained quiet about the truth."],[625,750,"What was the truth?"],[871,1034,"The truth is that"],[1034,1172,"before I met the King,"],[1313,1434,"I was in love with a boy"],[1434,1568,"who worked for my father."],[1751,1889,"He was my first love."],[1977,2156,"And I thought he was my future."],[2327,2448,"But then I met Simon,"],[2631,2731,"The boy I had once"],[2731,2886,"loved enlisted in the army."],[3007,3073,"And I thought"],[3073,3199,"that we had both moved on"],[3199,3328,"with our lives, until..."],[3545,3703,"Until he returned on leave,"],[3812,3924,"shaken by what"],[3924,4041,"he'd seen in combat."],[4321,4450,"My heart went out to him."],[4450,4571,"And we..."],[4817,4946,"I'm not proud of that night."],[5142,5263,"It was a mistake."],[5380,5501,"But it was my mistake."],[5547,5668,"Until..."],[6014,6139,"I learned I was pregnant."],[6206,6431,"You haven't publicly disclosed"],[6431,6569,"the name of the soldier."],[6598,6719,"Are you prepared to do"],[6719,6836,"so this evening?"],[6848,6969,"This is a weight"],[6990,7186,"I've carried for most of my life."],[7336,7444,"But as a gesture"],[7444,7695,"to the British people whose faith"],[7695,7857,"I can only hope to restore"],[7857,7978,"one day."],[8116,8237,"I will tell you his name."],[8454,8575,"His name was..."],[8754,8875,"Henry."],[8975,9096,"He died in battle."],[9342,9463,"And I loved him very much."]],"185":[[21,142,"Five minutes to landing."],[251,372,"I want to see."],[418,451,"Wait!"],[451,568,"Don’t look out there."],[568,689,"Look at me."],[826,889,"In five minutes,"],[889,1006,"our lives are going to change."],[1122,1210,"And I want you to understand"],[1210,1398,"why, before it happens."],[1531,1652,"Okay?"],[1919,2002,"We talk about destiny"],[2002,2123,"all the time,"],[2169,2294,"but it's always about my destiny."],[2395,2478,"It's always been about me."],[2478,2599,"And that's not fair to you."],[2812,2924,"It's okay."],[2924,2987,"We're here now."],[2987,3108,"It's not okay."],[3208,3312,"I've been so selfish with you."],[3312,3362,"And I'm sorry."],[3362,3483,"Ophelia."],[3642,3763,"Liam, what did you do?"],[4296,4413,"It's New York."],[4572,4680,"Why are we in New York?"],[4826,4901,"Because you have your own"],[4901,5026,"destiny and your own dreams."],[5185,5256,"And I can't ask you"],[5256,5377,"to give them up."],[5431,5548,"Not yet."],[5631,5752,"Not ever."],[5856,5986,"You didn't have to do this."],[6082,6177,"I would have been happy"],[6177,6278,"without dancing."],[6457,6490,"But..."],[6711,6832,"We can be happy here too."],[7220,7341,"You're not staying."],[7546,7696,"We have our own destiny, Ophelia."],[7850,7967,"No matter what we tell ourselves."],[8071,8146,"But you're not the heir"],[8146,8267,"to the throne anymore."],[8442,8592,"What happened on that phone call?"],[8592,8709,"What changed everything?"],[8709,8826,"This pendant."],[9030,9151,"It's not mine."],[9235,9356,"Don’t know how it got here"],[9452,9573,"or what it means."],[9694,9814,"And Doctor Cohen's phone."],[9906,10006,"For 25 years, he's"],[10006,10127,"been with our family."],[10140,10236,"Why is he on the royal jet"],[10236,10336,"going to Gibraltar the day after"],[10336,10457,"a paternity scandal?"],[10715,10815,"My father believed"],[10815,10928,"in a better life for all of us."],[10928,11037,"And someone attacked him for it."],[11157,11287,"I have to go back and avenge him."],[11353,11499,"I have to go back and fight"],[11499,11620,"his battle."],[11758,11900,"It's always been my destiny."],[12033,12104,"No matter what."]],"186":[[838,959,"I met this kid on the plane tour."],[1221,1342,"He said, “There's our duty,"],[1576,1689,"and there’s our our someday.”"],[1918,2039,"You are my someday."],[2260,2427,"You'll always be the someday I want."],[2514,2627,"But I have to go back."],[2627,2748,"And you have to stay."],[2961,3082,"Easier this way."],[3570,3691,"Last time I heard that was"],[3691,3749,"when my mom"],[3749,3857,"dropped me off in the States."],[4008,4087,"And I accepted it"],[4087,4166,"because I thought there'd"],[4166,4237,"be a someday."],[4366,4483,"But there wasn't."],[4592,4708,"There was just..."],[4892,4988,"Wasted time."],[4988,5105,"And then she was gone."],[5326,5447,"I don't believe in someday."],[5580,5701,"Not anymore."],[6022,6139,"Lucky for you, I do."],[6335,6452,"And I always will."],[6627,6748,"I promise."]],"187":[[1359,1480,"She lied."],[1722,1781,"I thought she was going"],[1781,1902,"to tell the truth about us."],[1956,2081,"She was protecting you."],[2185,2331,"She was protecting herself."],[2790,2907,"Are the kid's mine or not?"],[3328,3449,"It's all in here."],[3753,3904,"Just tell me if it says goodbye."],[4241,4392,"Her Majesty apologizes"],[4392,4563,"for tarnishing Henry's legacy,"],[4754,4896,"and she asks that you forgive her"],[4896,5013,"for the fabrication."],[5184,5326,"She also requests"],[5326,5497,"that you do not contact her"],[5584,5685,"for a while."],[5685,5993,"A year or so until things improve."],[6177,6360,"She promises that she loves you"],[6448,6569,"and she will see you then."],[6702,6844,"But we both know that's not true,"],[6844,6965,"don't we, Lucius?"],[7023,7169,"The part about seeing me again."],[7169,7361,"It's too risky"],[7361,7436,"now that she's made such"],[7436,7620,"a detailed public confession."],[8091,8295,"Her Majesty is a radiant"],[8295,8517,"and brilliant queen, but"],[8517,8675,"she's always had a blind spot"],[8675,8796,"when it comes to you."],[9167,9271,"It's nothing personal,"],[9271,9392,"Captain Lacey."],[9497,9630,"Please tell Henry the same."]],"188":[[385,539,"Should have had Marcus back us up."],[539,735,"He said trust no one."],[789,852,"You have to trust"],[852,960,"somebody sometime."],[1015,1077,"I'm sorry."],[1077,1131,"Can..."],[1140,1302,"Can we not do this now?"],[1302,1411,"Now I might get shot in the face"],[1411,1490,"in a few minutes"],[1490,1611,"so you can just hear me out."],[1669,1890,"The Queen knew who I was."],[1895,2074,"She threatened to expose me."],[2157,2228,"They would have taken me"],[2228,2295,"away from you."],[2295,2416,"So I took a shot."],[2487,2591,"And you slept with her"],[2591,2683,"so that you could stay"],[2683,2750,"close to me."],[2762,2904,"You’re so sweet, Jasper."],[2904,2950,"You are."],[2950,3129,"Most of my life has been about odds."],[3208,3334,"I figured that"],[3334,3467,"I pretty much already"],[3467,3588,"lost you anyway, so I..."],[3738,3859,"I took a shot, and I."],[3972,4122,"thought maybe you wouldn't find out."],[4122,4239,"And if I didn't find out,"],[4364,4485,"you were just going to live with it."],[4514,4606,"We all have shit we"],[4606,4747,"got to live with, Princess."],[5106,5206,"Who's he?"],[5206,5302,"He's the only one"],[5302,5461,"more screwed up than you are."],[5494,5611,"And he's with me."],[5611,5669,"Just don’t be stupid."],[5669,5728,"I've got a gun."],[5744,5869,"That’s fine. I've got two."],[5919,6191,"You said you killed my brother. Why?"],[6295,6395,"Because where I come from,"],[6395,6508,"a little money is a lot of money."],[6508,6641,"So you killed him for money."],[6712,6841,"I killed a man with a hammer once."],[6958,7091,"Killed another man with my bare hands"],[7091,7212,"just for looking at my girl."],[7246,7404,"I'm sure she appreciated that."],[7450,7567,"Those times were for free."],[7621,7713,"You know, I never would have done"],[7713,7801,"what I've done to your brother"],[7801,7871,"if I'd known it was him"],[7930,8055,"and not because he was a prince."],[8126,8197,"Because it was him."],[8197,8355,"They said it was a military accident."],[8405,8476,"Of course they did."],[8576,8635,"You got to ask"],[8635,8756,"yourself who they are."],[8914,9006,"Who are they?"],[9006,9127,"I don't know."],[9202,9344,"I mostly operate UAVs."],[9498,9619,"Least I did."],[9778,9932,"Unmanned aerial vehicles."],[10094,10215,"Drones."],[10341,10428,"Now drones scare people,"],[10428,10549,"but there's a lot of money there."],[10674,10728,"Pretty soon,"],[10728,10845,"these kids playing video games"],[10845,10899,"are going to be fighting the world’s"],[10899,11020,"wars from their bedrooms."],[11070,11183,"What does this have to do"],[11183,11267,"with my brother?"],[11346,11458,"I was asked to take control"],[11458,11579,"of a manned aircraft."],[11642,11775,"I was offered a sum of money to do it."],[12021,12101,"I took the money"],[12101,12222,"and I scuttled the aircraft."],[12430,12551,"Your brother was the pilot."]],"189":[[79,200,"And what about the King?"],[259,380,"I don't know about that."],[492,551,"All I know is"],[551,667,"the major that contacted me"],[667,818,"is missing, and I expect to be next."],[1043,1130,"Least I can do is try and"],[1130,1214,"clear my conscience."],[1322,1389,"I'll take that into"],[1389,1506,"account when I get to hell."],[1572,1693,"They won't."],[2206,2273,"But that's it?"],[2273,2394,"That's all you got?"],[2611,2928,"Nah, I've also got this."],[3078,3191,"My major used to get calls"],[3191,3312,"from the palace."],[3341,3462,"We called it Oz."],[3570,3654,"So you might take care"],[3654,3741,"close to home, Dorothy."],[3891,4008,"Why did you do this?"],[4050,4183,"I told you, for the money."],[4204,4238,"No."],[4296,4413,"Why did you tell me?"],[4709,4830,"They left a note,"],[4930,5051,"called it a suicide."],[5218,5397,"It's not fair to him,"],[5397,5593,"or to you or to anyone left behind."],[5818,5910,"What kind of psychopath"],[5910,5981,"does that?"],[7595,7733,"So far, so good."],[7775,7900,"The public is praising you"],[7900,8100,"on your refreshing honesty."],[8112,8229,"Oh, that? Good."],[8304,8605,"Lucius, did you do as I asked?"],[8634,8776,"Yes, of course, Your Majesty."],[8871,9009,"Your message was delivered"],[9051,9172,"and received."],[9301,9422,"Very good."],[9485,9606,"Thank you."],[10444,10598,"And did you do as I asked?"],[10773,10857,"The Prince Regent's"],[10857,10999,"message was delivered"],[11082,11199,"and received."],[11211,11357,"It's in her best interest."],[11416,11537,"It had to be done."],[11628,11745,"I couldn't agree more."]],"190":[[70,287,"Hi. Ophelia Pryce."],[299,416,"Whenever you're ready."],[1288,1409,"Liam."],[1434,1488,"What happened?"],[1488,1605,"Why are you back?"],[1655,1776,"What's he doing here?"],[1809,1917,"It's a long story."],[1917,2038,"Where’s Phe?"],[2047,2168,"It's a long story too."],[5329,5442,"It just doesn't make any sense."],[5442,5588,"Everyone loved Robert."],[5621,5750,"Maybe it wasn't revenge."],[5755,5830,"Maybe it was someone who"],[5830,5917,"hated the monarchy."],[5959,6051,"Or someone who could benefit"],[6051,6172,"from his death."],[6255,6322,"He said the calls"],[6322,6443,"were made inside the palace."],[6455,6530,"Yeah."],[6831,6939,"Has to be Cyrus."],[6939,6989,"Liam."],[6989,7110,"What if it's not?"],[7294,7415,"If it’s not,"],[7523,7640,"he's got this coming anyway."],[8407,8457,"They told me"],[8457,8578,"you'd returned on the plane."],[8578,8699,"I thought we had a deal."],[8912,9029,"I changed my mind."],[9191,9287,"At least we got rid of"],[9287,9429,"that frolicking commoner."],[9600,9638,"A little"],[9638,9788,"dramatic, don't we think?"],[9813,9930,"You think I'm going to stab you?"],[10013,10134,"Like you stabbed my father?"],[10768,10889,"I'm not going to stab you."],[11031,11148,"That would be too quick."],[11702,11840,"You can't do that."],[12290,12407,"Sure I can."],[12724,12912,"You killed my brother."],[12949,13070,"You tried to kill my father."],[13074,13195,"Now it's time to confess."]],"191":[[396,517,"Abolition"],[542,733,"is such a cowardly choice."],[1159,1280,"Lucius?"],[1347,1468,"The Queen's asking for you."],[2606,2648,"Admit it!"],[2648,2769,"You wanted to kill my father!"],[2952,3082,"Of course I wanted to kill him."],[3082,3194,"I killed him every day."],[3194,3303,"I poisoned him,"],[3303,3386,"I drowned him,"],[3386,3553,"I shot him in the back."],[3553,3707,"I killed him every day of my life."],[3732,3895,"But only in my heart!"],[3899,3970,"You’re lying!"],[3970,4024,"I’m not!"],[4066,4154,"I couldn't do it."],[4154,4270,"He was my brother."],[5455,5576,"You're an idiot."],[5851,5993,"You tried to hit"],[5993,6118,"me with a fireplace poker."],[10222,10297,"Admit it!"],[10297,10410,"Help me!"],[10452,10510,"Admit it,"],[10510,10631,"you son of a bitch!"],[10756,10956,"Sir, please"],[10956,11090,"remove your hands"],[11090,11215,"from Great Britain's King."]],"192":[[3090,3140,"Godspeed"],[3140,3261,"my king."],[3511,3632,"And know that I’ll avenge you."],[4036,4111,"I'll miss you, dad."],[5882,5955,"Yes?"],[6197,6314,"I see."],[6556,6651,"I understand."],[6651,6772,"Thank you for calling."]],"193":[[6632,6753,"It's okay."],[6841,6961,"I'm here now."]],"194":[[4095,4253,"We are greatly saddened to report"],[4253,4378,"that His Royal Majesty"],[4378,4516,"King Simon is dead."],[4570,4720,"As was reported worldwide,"],[4745,4858,"King Simon has succumbed"],[4858,5058,"to injuries sustained in a vicious attack."],[5137,5196,"His assailant"],[5196,5363,"remains at large and will surely be"],[5363,5484,"the focus of attention."],[5504,5634,"Don't worry, baby boy."],[5892,6022,"Daddy just became king."]]}