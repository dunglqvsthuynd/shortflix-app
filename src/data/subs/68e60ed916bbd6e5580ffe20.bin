u home,"],[12559,12638,"I thought you didn't want me to"],[12638,12697,"see your house"],[12697,12847,"because you were embarrassed."],[12930,13047,"Who says I'm not?"],[13510,13631,"Normally, this is the moment I'd ask you"],[13631,13827,"out, but to be honest,"],[13827,13915,"I'm more of a dating,"],[13915,13977,"not hanging out"],[13977,14040,"kinda guy."],[14111,14177,"It's a problem."],[14177,14236,"I know."],[14278,14382,"That’s nice actually."],[14515,14632,"If you get it all sorted and want to"],[14632,14728,"have a proper date,"],[14782,14916,"you have my number."],[15037,15141,"Good luck with the paps."]],"55":[[51,139,"Our daughter"],[139,339,"finally dedicates herself"],[339,564,"to something other than self-sabotage,"],[631,773,"and you pilfer her location"],[773,952,"as well as her enthusiasm."],[1015,1194,"Have you not challenged Liam this week?"],[1232,1386,"But I haven't competed with him."],[1457,1574,"Eleanor does her best"],[1574,1678,"when she feels her"],[1678,1916,"whole life is one great injustice."],[1957,2062,"She needs a good adversary."],[2170,2283,"She needs a good mother."],[2370,2571,"She needs an adversary more."],[3171,3309,"I don't know how Robert did it."],[3434,3747,"Maybe he did loads of drugs,"],[3793,3939,"that we never knew about."],[3968,4001,"Here."],[4331,4410,"I have a ton of stuff left"],[4410,4493,"on my royal calendar."],[4493,4598,"I can't get high."],[4598,4789,"I got news for you, big brother"],[4789,4860,"by four minutes."],[4865,4948,"That calendar"],[4948,5086,"is the very reason"],[5086,5219,"they invented getting high."],[5273,5407,"Hit the bong. You want to."],[5407,5519,"You need to."],[5820,5891,"Here's a thought."],[5974,6095,"Why don't we go out tonight?"],[6095,6212,"Like old times?"],[6312,6479,"Yeah, I could do that."],[6479,6633,"Yeah, that's the spirit."],[6679,6779,"You know, I can tell when you need"],[6779,6867,"to get out of your head."],[6867,7017,"Especially about Ophelia."],[7196,7396,"So whatever you did"],[7421,7588,"or whoever did"],[7667,7751,"you know, we'll go out"],[7751,7884,"and we'll do something worse,"],[7884,8051,"and it won't seem so bad."],[8335,8468,"Man, it's just been one of those weeks,"],[8468,8564,"you know?"],[8564,8622,"Yeah."],[8622,8844,"Of course it has. It's Fashion Week,"],[8844,8889,"You know?"],[8889,9023,"It just makes everyone horny."],[9248,9311,"Really?"],[9494,9557,"What?"],[9769,9957,"This is to forget Ophelia."],[10070,10103,"Who?"],[10153,10278,"Well done."],[10316,10529,"And these for whatever whore"],[10529,10729,"you wake up with tomorrow."],[10745,10916,"Oh, hello, Gemma,"],[10916,11117,"I heard that, and I'm okay with it."],[11275,11384,"Cheers."],[11404,11513,"Cheers."],[11947,12147,"Oh, you have a problem."],[12222,12397,"The King and Prince Liam"],[12397,12476,"have recently met"],[12476,12606,"with the anti-monarchists."],[12631,12685,"And?"],[12685,12831,"If things develop, you'll know about it."],[12923,13023,"They trust me."],[13023,13098,"For now."],[13185,13344,"Someone's proving himself to be"],[13344,13540,"as capable outside the bedroom"],[13540,13619,"as he in."],[13636,13744,"And someone has"],[13744,13890,"been to the esthetician."],[13978,14178,"No use wasting a good bleaching."]],"56":[[314,384,"Back to the palace,"],[384,476,"Your Highness?"],[601,697,"Nice try."],[739,868,"We're following Liam and Gemma"],[868,977,"to an after hours."],[1052,1256,"So blackmail sex will have to wait"],[1256,1469,"tonight Jasper from Nevada."],[1569,1769,"Or is it Jasper from Shoreditch?"],[1949,2245,"Or is it a little orphan"],[2245,2478,"Jasper from the orphanage"],[2478,2678,"in Camden?"],[2820,3050,"Oh, advantage, Eleanor"],[3050,3279,"and Ophelia."],[4134,4217,"You’re certain you don't want"],[4217,4280,"me to drive, sir?"],[4280,4509,"You are not driving my car, Marcus."],[4547,4701,"So just sit back and disappear"],[4701,4793,"like you're supposed to."],[4797,4914,"I'm fine."],[5123,5185,"And you're fine"],[5185,5306,"too tonight, baby."],[5377,5577,"You look sexy in that suit."],[5669,5873,"I’ll bet you taste sexy too."],[6011,6086,"Gemma."],[6115,6174,"Whoa."],[6257,6407,"Just drive the car!"],[6407,6595,"I don't think this is very prudent, sir."],[6595,6699,"Gemma, seriously."],[6766,6853,"Look out!"]],"57":[[278,378,"Are you okay, sir."],[378,441,"Yeah. I'm fine."],[441,487,"Are you sure?"],[487,637,"Marcus, I'm fine. Gem?"],[720,804,"You okay?"],[804,879,"Ouch."],[879,954,"Let’s get you some air."],[954,1083,"I think we should go, sir."],[1083,1200,"I'm not leaving her like this."],[1200,1367,"I'll make a call. We need to go."],[1367,1463,"How could you even suggest that?"],[1463,1525,"Cause you're the next"],[1525,1584,"King of England, sir."],[1584,1713,"I'm not leaving her."],[1888,1992,"Remove your hands from"],[1992,2059,"His Royal Highness."],[2059,2147,"You're going to shoot me, Marcus"],[2147,2193,"for following"],[2193,2314,"extraction protocol?"],[2326,2451,"What happened? Is he okay?"],[2451,2539,"He was until Jasper"],[2539,2601,"knocked him out."],[2631,2685,"Why?"],[2685,2847,"I’m trying to get him out of here."],[2847,2964,"I suggested extraction,"],[2964,3043,"and His Royal Highness"],[3043,3156,"made a decision to stay."],[3156,3239,"Yeah, well, he's an idiot,"],[3239,3344,"but you aren't, Marcus."],[3344,3452,"You know he can't stay here like this."],[3452,3540,"Now let's go."],[3727,3857,"He's right. Go!"],[5262,5354,"You didn't have to punch me."],[5354,5421,"In crisis,"],[5421,5634,"we need to initiate an extraction protocol."],[5721,5867,"Gemma could have been injured."],[5867,6021,"Gemma wasn't injured."],[6122,6268,"She was just horny."],[6297,6401,"I blame Fashion Week."],[6443,6584,"My apologies if my actions"],[6584,6693,"seemed agreesive, Your Highness."],[6705,6926,"I needed to remove you from the scene."],[6926,7047,"He did get you out of there"],[7047,7218,"before anyone saw us."],[7231,7269,"Sir."],[7373,7477,"His Majesty, the King"],[7477,7619,"would like to see you immediately."],[7731,7865,"Maybe someone did see us."],[8274,8382,"Liam,"],[8453,8566,"if dad calls you on it,"],[8566,8699,"just tell him the truth."],[8799,8903,"Except the part about Jasper"],[8903,8999,"punching you."],[9629,9750,"It would be a shame"],[9834,10021,"for this little game of yours to end"],[10021,10151,"on a technicality"],[10151,10272,"right before I defeat you,"],[10272,10351,"fair and square."],[10584,10764,"Close the door behind you."],[10764,10901,"I need to find a new location"],[10901,11043,"for my fashion show."],[11122,11264,"One of the most important lessons I"],[11264,11377,"learned from my time in Vegas..."],[11377,11531,"Uh, allegedly."],[11573,11752,"Don't just play your hand."],[11802,11906,"Play your opponent's hand"],[11906,12002,"against them."]],"58":[[20,249,"Disappointing news about Gemma."],[286,416,"She's okay though."],[416,541,"Did you see her last night?"],[587,691,"Yeah, I saw her."],[758,862,"Page five."],[862,954,"I don't have to tell you where"],[954,1029,"the article appears,"],[1029,1154,"had you been in the car."],[1229,1358,"I'm glad you weren't."],[1471,1671,"For more reasons than just a headline."],[1688,1800,"Thanks, dad."],[1859,1980,"Fashion Week, ey?"],[2134,2255,"Makes everyone crazy."],[2305,2376,"Yeah."],[2422,2555,"Heard something like that."],[2626,2685,"Son..."],[2947,3156,"I asked you here"],[3310,3452,"because I know."],[3631,3832,"The effort you've been making."],[3932,4132,"Dedication to the crown."],[4236,4340,"I know how hard"],[4340,4436,"you've been working."],[4616,4749,"And I'm proud of you."],[5271,5392,"I’m not doing that great."],[9466,9596,"Hi, darling."],[9650,9733,"You're a bit early."],[9733,9913,"Are you here for the open bar?"],[9913,10146,"No, actually, I came to thank you,"],[10226,10346,"you know, for taking the bait."],[10413,10534,"Oh, and to give you an"],[10534,10643,"invitation to my show."],[10943,11081,"At the palace?"],[11081,11202,"My old location."],[11202,11393,"My new location."],[11393,11481,"See, I..."],[11481,11598,"I knew those two dimwits"],[11598,11681,"couldn't keep a secret."],[11681,11773,"It was your spot that"],[11773,11865,"I wanted all along."],[11973,12032,"Well..."],[12132,12236,"Well, as long as you're happy."],[12319,12378,"For me..."],[12407,12574,"Tunnel is the new palace."],[12574,12774,"Well, we'll let the press decide."],[12795,12966,"Until then, mother, I'll be at the palace."],[12966,13087,"And you?"],[13087,13233,"You enjoy your time down here with"],[13233,13383,"the rest of the rats."],[13537,13654,"Eleanor,"],[13946,14100,"This was something I cared about."],[14129,14221,"It was prestigious to be"],[14221,14342,"selected for my show."],[14396,14505,"But that doesn't matter to you."],[14572,14667,"Maybe this will."],[14809,14964,"I've spent my life cultivating"],[14964,15151,"the image of this family,"]],"59":[[37,162,"Deciding who sees us"],[162,267,"and how they see us."],[413,567,"Living your life in the public eye"],[567,654,"and making mistakes"],[654,767,"is one thing."],[896,996,"But to maliciously"],[996,1197,"undo the work I've done,"],[1230,1359,"the steps I've taken to"],[1359,1539,"protect you and this family,"],[1643,1785,"it's unforgivable."],[1826,2018,"You want the press to decide?"],[2073,2114,"Fine."],[2260,2423,"As far as I'm concerned,"],[2423,2535,"The press shouldn't decide"],[2535,2865,"anything for us or about us."],[2965,3111,"Ever."]],"60":[[314,356,"Yeah!"],[356,556,"You bitches better applaud."],[961,1123,"Hey! Oh!"],[1123,1286,"Hey, Gemma."],[1286,1395,"Are you okay?"],[1395,1545,"Of course. Why wouldn't I be?"],[1599,1691,"The car accident."],[1691,1828,"Oh, that."],[1828,2024,"Our lawyers will fix it."],[2024,2216,"First fashion week?"],[2216,2404,"First fashion show."],[2404,2592,"That's so cute."],[2592,2788,"Have you seen Liam?"],[2888,3017,"He's over there"],[3017,3200,"with that insanely beautiful woman."],[3200,3401,"Tiara. Right."],[3417,3618,"They have sex."],[3793,3993,"Doesn't that bother you?"],[3993,4181,"He's the heir to the throne."],[4181,4289,"Women love power."],[4289,4448,"Liam loves women."],[4448,4648,"It comes with the territory."],[5490,5690,"Always ducking me in a crowd."],[5732,5870,"I was just."],[5870,6028,"I mean, this is all so..."],[6028,6078,"I agree."],[6258,6358,"Come on."],[6988,7117,"How have you been?"],[7117,7188,"Good."],[7188,7255,"Have you been?"],[7330,7388,"Busy."],[7513,7572,"But it’s been good."],[7572,7701,"You know, there's a lot to learn and..."],[7784,7880,"And I've been busy too,"],[7943,8055,"school and rehearsing."],[8055,8205,"Same as ever, I guess."],[8502,8598,"I don’t wanna do this, you know."],[8702,8810,"Not with you."],[8894,9015,"Do what?"],[9015,9094,"Make small talk."],[9394,9565,"Gemma's car accident."],[9770,9886,"I was with her."],[10124,10274,"I didn’t lie to my father."],[10441,10620,"But I didn't tell him the truth either."],[10743,10821,"And I’m not proud of that."],[11012,11179,"I'm not proud of any of it."],[11179,11246,"I don’t even know why I’m telling"],[11246,11334,"you all this."],[11371,11484,"I don't know either."],[11567,11667,"But it’s okay that you are."],[11667,11767,"It's just, umm..."],[12134,12164,"I don't wanna"],[12164,12239,"lie to you about it."],[12447,12539,"Even when I’m not proud of it,"],[12539,12618,"it's important to me that"],[12618,12697,"you know the truth."],[13110,13206,"Can I ask you something?"],[13411,13511,"How did the press not know"],[13511,13632,"about you and Gemma?"],[13903,14053,"There’s an extraction protocol."],[14266,14445,"So you just left her there?"],[14533,14645,"Have to."]],"61":[[181,291,"It's good seeing you."],[536,653,"It always is."],[1629,1708,"So what's your impression"],[1708,1908,"of Liam's efforts so far?"],[1933,2092,"He cares now."],[2167,2275,"He has something to lose."],[2304,2504,"We all have something to lose."],[2630,2776,"Then he has something to gain."],[2863,3017,"Let's put him on the plane tour."],[3059,3243,"See how the people respond to him."],[3243,3305,"The plane tour?"],[3305,3414,"My plane tour?"],[3464,3610,"It's more important for Liam."],[3610,3781,"The plane tour is the one chance"],[3781,3985,"I have to curry favor with the people."],[3985,4077,"I understand."],[4198,4260,"But you're not the next"],[4260,4352,"King of England."],[6079,6212,"Enjoying your victory?"],[6300,6438,"The press certainly had nice things"],[6438,6538,"to say about your work."],[6638,6763,"They had nice things to say about"],[6763,6838,"your show too."],[6838,7080,"Yes, but they raved about yours."],[7343,7514,"Princess becomes"],[7514,7643,"Queen of Fashion Week."],[7743,7864,"Who wrote that one?"],[7864,8022,"Umm, Charlemagne Cullingford."],[8022,8177,"Oh, Charlemagne."],[8177,8314,"Did you see him at your show?"],[8314,8544,"No, but, you know, I was really busy"],[8544,8677,"backstage, so..."],[8802,9061,"Funny, I saw him at mine."],[9507,9657,"But how could he...?"],[9974,10104,"It was your first fashion"],[10104,10220,"show, sweetheart."],[10704,10888,"You told them to print these?"],[10888,11042,"When you succeed,"],[11080,11226,"the monarchy succeeds."],[11438,11676,"See, I can plant stories too."]],"62":[[1348,1444,"Just get out."],[1523,1615,"I heard what she said."],[1740,1836,"She's lying."],[1990,2190,"Well, you’d know about that."],[2524,2687,"I don't even know who you are?"],[3158,3283,"I’m a British orphan."],[3396,3642,"Or an American grifter."],[3871,3988,"One thing I do know is that"],[3988,4096,"I'm lying about something."],[4234,4334,"The queen,"],[4459,4593,"is lying about everything."],[4780,4914,"But those reviewers,"],[4985,5077,"they’re telling the truth."]],"63":[[514,723,"A simple thank you would suffice."],[1140,1236,"For what?"],[1236,1378,"For cleaning up your mess"],[1378,1498,"when you leave your drunk"],[1498,1628,"diamond heiress at the"],[1628,1720,"scene of the crime."],[1807,1916,"Drunken heiress"],[1916,2099,"destroys quaint telephone box."],[2120,2291,"An heir to the throne emerges"],[2291,2466,"with his trousers undone."],[2529,2654,"There are security cameras"],[2654,2758,"everywhere these days."],[2758,2846,"It wasn't like that."],[2879,2987,"When will you learn?"],[3058,3213,"it doesn't matter what it was like."],[3213,3388,"It matters what it looks like."],[3430,3538,"And even that no longer matters"],[3538,3776,"because I took care of it."],[4189,4247,"Okay."],[4289,4456,"You don't have to say thank you."],[4506,4597,"You don't have to show"],[4597,4743,"an ounce of gratitude."],[4802,4923,"But the next time you look at me"],[4923,5123,"with such disdain in your eyes,"],[5148,5348,"you consider how similar we are."],[5348,5448,"I'm nothing like you."],[5448,5515,"No?"],[5623,5686,"The spare"],[5686,5849,"who sleeps around,"],[5849,6028,"drinks to excess,"],[6028,6187,"slinks away from an accident"],[6187,6328,"and then lies about it."],[6441,6641,"No. You’re nothing like me at all."],[8531,8647,"I know I haven’t been at my"],[8647,8735,"best this week."],[8814,8948,"The truth is,"],[8948,9094,"it's the first family photo"],[9094,9210,"we've taken without Robert."],[9878,9965,"You need to be better"],[9965,10070,"to your children."],[10115,10295,"We may not always be a monarchy."],[10499,10695,"But we will always be a family."],[10841,11046,"It's a little late for that, isn’t it?"]],"64":[[1205,1330,"Oh."],[1497,1597,"There it is."],[1714,1893,"My hero, Doctor Cohen,"],[1893,2072,"as always."],[2135,2323,"How long will it take again?"],[2406,2565,"Well, as I told you the last time,"],[2565,2727,"Your Highness, the electrolytes"],[2727,2836,"and the vitamins in the I.V."],[2836,3044,"will take 10 to 15 minutes to remove"],[3044,3219,"the hangover, depending on"],[3219,3311,"the severity."],[3370,3624,"Oh, don't take a judgy tone, doc."],[3624,3941,"Okay. It is not easy entertaining foreign"],[3941,4145,"dignitaries myself with a family"],[4145,4241,"out of town."],[4358,4458,"Who would have thought"],[4458,4600,"that Crown Prince of Liechtenstein"],[4600,4692,"could put them back that easily?"],[4783,4900,"I mean, Liechtenstein."],[4996,5113,"Your Highness."],[8925,9029,"Morning, Princess."],[9029,9180,"I trust entertaining the Crown Prince"],[9180,9255,"of Liechtenstein"],[9255,9363,"went well last night."],[9363,9622,"Rachel, I'm nothing if not a good time."],[9622,9834,"Brilliant. On to the next matter."],[9834,9943,"I've arranged a little tour of some"],[9943,10126,"charities over the next few days."],[10126,10235,"It's vital that we capitalize"],[10235,10331,"on your good press"],[10331,10418,"since Fashion Week."],[10418,10518,"I'm not interested."],[10539,10689,"This smells a lot like my mother"],[10689,10873,"trying to control my headlines again."],[10873,11106,"No, I assure you, it's important that..."],[11106,11173,"What if I check in on"],[11173,11315,"one of Robert's charities?"],[11353,11532,"I mean, if it's good, press your after."],[11532,11753,"Surely any charity will do."],[11753,11874,"Apologies, Your Highness,"],[11874,12003,"but there just won't be any time."],[12003,12137,"Your schedule is packed"],[12137,12245,"with existing arrangements."],[12258,12550,"Okay, well, look, if I can't check in on"],[12550,12696,"at least one of Robert's charities,"],[12696,12791,"I won't do any."],[13029,13138,"What the hell are you looking at?"],[13271,13425,"Ugh! That bitch!"],[13872,13951,"- Hi. - Hey."],[13951,14026,"Are you on the plane?"],[14026,14080,"Yeah."],[14122,14176,"Is mum there?"],[14176,14226,"Yep."],[14226,14347,"Can you tell her..."],[14347,14602,"Shh. Relax. I'll talk to her."],[14668,14785,"You know how she meddles."],[14852,14973,"I'll fix it, Lenny. Okay?"],[14994,15073,"I got to go."],[15261,15402,"Gemma,"],[15402,15498,"what are you doing here?"]],"65":[[41,179,"I've chosen her as my lady"],[179,325,"in waiting on the rural tour."],[354,429,"Not everything is about"],[429,508,"you and Ophelia."],[600,734,"I heard she rebuffed you by the way."],[859,930,"Come on, Gemma."],[1026,1155,"Sex on the plane."],[1222,1297,"Just saying."],[1401,1509,"At least this time I don't"],[1509,1609,"have to drive."],[2189,2331,"Make sure you Instagram that."],[2464,2556,"You're late."],[2610,2736,"And you're miserable."],[2736,2848,"Go away."],[2882,3053,"The Queen wishes me to accompany"],[3053,3190,"you on your charity tour."],[3303,3490,"Either you stay or I stay."],[3507,3753,"Whatever you would like,"],[3753,3862,"Your Highness."],[3862,3949,"And absolutely no"],[3949,4095,"staff along the way or I bail."],[4095,4187,"Understood?"],[4237,4308,"Off you go."],[4341,4475,"They're all Team Helena,"],[4475,4633,"and they cock block my buzz."],[4633,4829,"And what's first up on this bloody tour?"],[4917,5109,"Gateway Assisted Living."],[5109,5226,"An old folks home."],[5226,5309,"Seriously?"],[5538,5655,"Unbelievable."],[5976,6085,"Jasper, have you ever hung"],[6085,6185,"out with old people"],[6185,6318,"while on ecstasy before?"],[6393,6464,"No."],[6548,6848,"No. Me neither."],[7603,7670,"Hey."],[7690,7732,"Hi."],[7753,7899,"I'm on my way to pick you up for that"],[7899,7987,"date you've been avoiding"],[7987,8078,"for two weeks."],[8099,8216,"I haven't been avoiding you."],[8216,8349,"I've seriously been really..."],[8349,8458,"Really busy."],[8458,8529,"I know."],[8596,8817,"But, I've decided I'm not going to accept"],[8817,8917,"any more excuses,"],[8950,9100,"no matter how legitimate."],[9188,9384,"Thing is, I can't right now."],[9384,9517,"Oh, shocker."],[9580,9676,"What is it this time?"],[9772,9951,"I was actually just about to"],[9951,10035,"wash my hair."],[10035,10155,"Come on."],[10201,10397,"What is this, 1963?"],[10431,10518,"Not even sorting your"],[10518,10681,"recycling was better than that."],[10681,10731,"Just..."],[10823,10927,"say you're not interested."],[10927,11061,"I can take it."],[11061,11236,"Okay, fine. Why don't you"],[11236,11352,"come by my place?"],[11378,11482,"We can hang out here."],[11482,11615,"Just to be clear, by your place,"],[11615,11782,"you mean the royal palace?"],[11815,11874,"Yes."],[12007,12103,"My dad and the King"],[12103,12220,"are still in Canada."],[12220,12333,"And the rest of the family is"],[12333,12441,"on the countryside tour."],[12479,12604,"So we'll have the whole place"],[12604,12704,"to ourselves."],[12808,13012,"And a day's worth of tourists"],[13012,13146,"and about a thousand staff"],[13146,13263,"members, give or take."],[13321,13492,"Sounds cozy."]],"66":[[512,633,"What the hell are you wearing?"],[666,808,"Kid thinks he's going for a night out"],[808,908,"in Soho."],[908,1037,"Absolutely not."],[1037,1166,"The stylists have already laid something"],[1166,1254,"more country appropriate"],[1254,1321,"on your bed."],[1367,1471,"What about you?"],[1521,1609,"I'm the queen."],[1659,1763,"People expect me to look"],[1763,1892,"like the Queen."],[1892,1996,"Now, please go change."],[2242,2430,"He seems about as enthusiastic"],[2430,2526,"as I am."],[2526,2743,"You used to love this annual tour."],[2801,2927,"You must have sired children"],[2927,3047,"all up and down the countryside."],[3047,3310,"It was fun when it was my tour."],[3310,3427,"Not since you got handed"],[3427,3560,"over to Prince Playboy."],[3656,3798,"At least now I don't have to"],[3798,4032,"step off the plane and ruin my new"],[4032,4224,"bespoke Jimmy Choos."],[4224,4395,"Or bump into any of your bastards."],[4395,4499,"Win, win."],[5542,5617,"Bloody hell!"],[5617,5729,"Don't stop there!"],[5909,6017,"Get it?"],[6017,6251,"I'm a lady in waiting."],[6251,6405,"It's a double entendre."],[6405,6639,"Yeah, I get it."],[6639,6797,"I never realized how hot you are"],[6797,6910,"when you're focused."],[6910,6943,"Gemma,"],[6943,7014,"I think perhaps we should..."],[7014,7068,"Don't worry."],[7068,7293,"I'm not staying."],[7293,7439,"You have a lot on your mind."],[7439,7535,"I know how important"],[7535,7690,"the tour is. The world"],[7690,7894,"finally getting a peek at the king"],[7894,7982,"I know you are."],[8111,8344,"I merely came to remind you what"],[8344,8586,"the next King of England gets..."],[8691,8724,"Me."],[8820,9120,"On a plane, tonight."],[9266,9441,"Make me proud out there, baby."],[9487,9692,"Don't keep this lady waiting too long."]],"67":[[139,206,"I cannot"],[206,352,"overstate the significance"],[352,506,"of the next couple of days."],[561,677,"This being the first time"],[677,886,"the public will see you as the new heir."],[932,1232,"Do not screw up."],[1245,1462,"Furthermore, to avoid epic press"],[1462,1570,"failures, you must stick"],[1570,1716,"only to the pre-approved script"],[1716,1937,"and topics. Don’t try and tell any jokes."],[1966,2196,"And we never talk about money,"],[2196,2429,"race, sexual identity, or religion."],[2475,2579,"Then what does that leave"],[2579,2634,"to talk about?"],[2692,2784,"Cheese."],[2784,2901,"They're very proud of their cheese"],[2901,2992,"in this part of the kingdom."],[3176,3401,"The unique import of this countryside"],[3401,3576,"tour is it allows us a chance"],[3576,3743,"to remind the people who we are"],[3743,3877,"and what we can do for them."],[3968,4106,"Robert would get so scrutinized"],[4106,4202,"on his appearances that even"],[4202,4319,"his socks would sell out"],[4319,4448,"when photos of him were published."],[4448,4573,"Maybe it had more to do"],[4573,4681,"with the man wearing them."],[4811,5044,"Well, we'll see, won’t we?"],[5153,5211,"Now then,"],[5224,5324,"try not to sleep with anyone"],[5324,5399,"in the villages."],[5428,5536,"As hard as that may be."],[5762,5866,"Thank you."],[6137,6241,"What's with the gloves, dear?"],[6337,6483,"People out here can be filthy."],[6500,6579,"Quite."],[6633,6721,"Nonsense."],[6892,7021,"Thank you, Darling."],[7021,7109,"Thank you."],[7672,7755,"Give me those gloves."],[8189,8239,"Thank you."],[8560,8635,"Thank you. Sir."],[8635,8706,"Mmm."],[8827,8902,