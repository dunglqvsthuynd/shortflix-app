{"1":[[1251,1384,"Three years of marriage,"],[1397,1476,"and tonight,"],[1476,1676,"he's finally taking my virginity."],[1910,1993,"Do you feel it?"],[2081,2160,"The bond."],[2231,2293,"Yeah."],[2318,2439,"I can feel it."],[2489,2556,"I knew it."],[2631,2727,"I still have a chance"],[2727,2836,"to make him believe me."],[2973,3103,"You went to a witch"],[3103,3328,"for a love potion, didn't you?"],[3374,3557,"So fucking desperate"],[3591,3703,"to make me love you."],[3832,3903,"You still think"],[3903,4037,"that I had something to do with it?"],[4149,4283,"That I betrayed you?"],[4396,4562,"It's been three years."],[4592,4721,"Won't you just believe me?"],[4758,4867,"Believe a Reed,"],[4913,5080,"from the Broken Forest Pack?"],[5397,5455,"Never."],[5518,5597,"You're a liar."],[5655,5780,"Just like your parents."],[6039,6156,"You'll scream my name"],[6247,6514,"because you'll always belong to me."],[6656,6906,"But I will never love you."],[7011,7065,"Dane."],[7190,7307,"Slower, please."],[7766,7832,"Dane!"],[7895,8087,"My orgasm tore through me."],[8112,8295,"Even as my heart tore in two."],[8692,8892,"I am so stupid."],[8892,9084,"I really thought this would fix us."],[9175,9296,"She's hurt."],[9330,9401,"Hug her."],[9522,9609,"I can't."],[10214,10331,"You were a virgin?"],[10543,10631,"Does it matter?"],[10756,10819,"No."],[10915,10977,"What is it?"],[11023,11211,"Blood cleanser, drink it."],[11248,11411,"I won't risk you carrying my heir."]],"2":[[25,95,"Blood cleanser?"],[95,196,"But I'm your wife."],[196,354,"I'd drink molten silver"],[354,563,"before I let my blood mix with anyone"],[563,704,"from the Broken Forest Pack."],[725,971,"But I told you I was a victim too."],[988,1126,"I almost died that night too."],[1126,1251,"I lost my wolf."],[1259,1501,"After all the lives lost because of you?"],[1501,1605,"I was drugged."],[1605,1726,"They were gonna kill me."],[1935,2056,"No!"],[2097,2268,"Dad, please, please."],[2268,2360,"Oh no."],[2360,2489,"No, no, no!"],[2498,2598,"Ah!"],[2673,2794,"You will do what we say"],[2794,2952,"whether you like it or not."],[2969,3032,"Leave her."],[3053,3207,"Let the Blue Ridge Pack's Alpha"],[3207,3274,"find her."],[3274,3561,"Then, we will attack."],[3812,3916,"It's your turn now."],[3941,4350,"Burn the Blue Ridge Pack into hell."],[4946,5005,"Help."],[5955,6026,"Stay with me."],[6272,6335,"What's your name?"],[6368,6435,"Ann."],[6435,6481,"I..."],[6527,6723,"my wolf, I don't feel it."],[6848,6944,"We've got healers."],[6973,7073,"No, no, no."],[7073,7144,"I'll take you to them."],[7144,7198,"They're gonna..."],[7832,7982,"There's something between us."],[8024,8095,"I can feel it."],[8546,8692,"He saved me that night,"],[8729,8879,"and I loved him ever since."],[9009,9104,"My parents."],[9180,9250,"My clan."],[9972,10181,"And the girl I carried in my arms"],[10201,10331,"was the bait"],[10343,10502,"they used to kill my family."],[10564,10748,"I swore that night"],[10769,10952,"I would never love her."],[11065,11286,"I would only make her suffer."],[11436,11574,"I'm not one of them."],[11586,11736,"They're monsters!"],[11770,11974,"Monster's blood runs"],[11974,12112,"in your veins, Ann."],[12183,12295,"Drink the potion"],[12320,12429,"or I'll make you."],[12641,12691,"No."]],"3":[[62,254,"Open your mouth."],[283,325,"No!"],[392,504,"You can't force me!"],[583,663,"Watch me."],[1997,2052,"Done."],[2394,2515,"I'm not feeling well."],[2515,2686,"I need you now, Alpha."],[2744,2911,"When will I finally admit it?"],[2911,3174,"His true love is Evelyn, not me."],[3307,3432,"One last question."],[3516,3712,"If I wasn't a Reed, would you love me?"],[3908,3958,"Never."],[4500,4608,"Well, if that's the case,"],[4608,4692,"then one of us"],[4692,4804,"should set the other free."],[4879,4988,"Let's cut the ribbon."]],"4":[[404,483,"The Council,"],[521,671,"the oldest Alphas and Lunas"],[671,734,"in the world,"],[734,834,"ordered this."],[850,984,"They said it was the only way"],[984,1167,"to stop a war between packs."],[1213,1338,"They called it peace,"],[1397,1509,"but it was a prison."],[2477,2665,"By the power of the Council,"],[2694,2907,"this mate bond is sealed."],[2936,3257,"Let the ribbon bind your souls as one."],[3536,3645,"You'll all pay"],[3695,3832,"for what you've done to my pack."],[3878,3987,"One day."],[4191,4358,"We're just two wounded animals"],[4358,4462,"chained together."],[4500,4621,"Maybe it's good if one of us"],[4621,4717,"sets the other free."],[4959,5109,"After all this time,"],[5142,5234,"in his eyes,"],[5234,5438,"I'm still nothing but his enemy."],[5480,5793,"Why does it still hurt when I see her cry?"],[5818,5885,"No."],[5889,6097,"I can't let myself feel that."],[6097,6260,"She's the reason my family is dead."],[6581,6790,"If you really hate me, then take it."],[6936,7007,"You kept it?"],[7077,7203,"It's our bond."],[7248,7374,"You're trying to trap me again."],[7394,7595,"No, I'm trying to free us."],[7628,7720,"We would still be married"],[7720,7811,"in the eyes of the Council"],[7811,7957,"if that's what you're worried about."],[8012,8204,"Stop it with your tricks."],[8241,8341,"You won't do it."],[8370,8450,"Without me,"],[8495,8587,"you have no connection"],[8587,8687,"to our kind at all."],[8704,8779,"No pack."],[8804,8892,"No wolf."],[8892,8958,"Nothing."],[8971,9096,"You don't know me."],[9146,9309,"I would rather die a rogue"],[9309,9501,"than to rot in a broken marriage."]],"5":[[742,967,"I, Ann Reed,"],[1009,1192,"Luna of the Blue Ridge Pack,"],[1201,1463,"reject Alpha Dane as my Alpha,"],[1559,1655,"and my mate."],[1768,1876,"Was that necessary?"],[1981,2156,"You knew our bond was fake."],[2193,2377,"If it's fake, then why hesitate?"],[2406,2510,"Just accept it."],[2898,3132,"I accept your rejection."],[3707,3832,"It felt like something"],[3832,3970,"was ripped out of me."],[4229,4391,"Consider this payment"],[4471,4579,"for your services."],[5109,5171,"He's gone."],[5246,5338,"It's really over."],[5505,5659,"That's all I was to him."],[5722,5880,"A mistake to erase."],[6014,6156,"Do I have it all wrong?"],[6239,6456,"Was she a victim, like she says?"],[6544,6694,"Why does her rejection"],[6694,6815,"hurt so much?"],[6856,7073,"Is she my fated mate?"]],"6":[[396,546,"I fell asleep waiting for you"],[546,688,"and had that nightmare again."],[738,804,"You know the one"],[804,934,"where I'm trapped in the dungeon?"],[975,1126,"I need you now, Dane."],[1230,1322,"I'll be right there."],[1472,1676,"I can't fall into Ann's trap again."],[1705,1947,"She's a liar who fed me a love potion"],[1947,2085,"to get what she wanted from me."],[2160,2348,"She's a Broken Forest werewolf,"],[2360,2435,"a Reed."],[2460,2631,"That ribbon meant nothing."],[2681,2857,"She will never be my mate."],[3015,3119,"I'm done begging,"],[3190,3299,"done believing."],[3349,3507,"Let him have his Evelyn."],[3962,4208,"Father, I'm so close now."],[4229,4454,"Dane Montague has poured all his hatred"],[4454,4679,"into the perfect scapegoat, Ann."],[4717,4854,"I'll finish what you started."],[4879,5125,"I'll burn the Blue Ridge Pack into hell."],[5501,5734,"Dane, you're finally here."],[5822,5960,"Evelyn, are you okay?"],[5980,6151,"I can't get over what happened to us"],[6151,6327,"in that dungeon when we were kids."],[6402,6552,"They doused me with liquid silver"],[6552,6752,"and it still weakens my wolf to this day."],[6781,6881,"I don't know how I had"],[6881,6998,"the strength to save you."],[7019,7198,"But you did save me."],[7286,7403,"I'll do anything for you."],[7628,7820,"Anything but leave Ann for me."],[7836,7987,"I'll do anything but that."],[8179,8291,"I can't marry you."],[8312,8466,"To my grandfather,"],[8525,8762,"only Ann can ever be my Luna."],[8921,9067,"I owe Evelyn gratitude"],[9067,9175,"for saving my life."],[9238,9346,"But I don't love her."],[9663,9864,"I can smell her all over you."],[9876,10010,"You didn't sleep with her, did you?"],[10101,10281,"I need Dane to keep hating her."],[10301,10485,"Only as his one and only Luna,"],[10485,10848,"can I take him and reclaim what's ours."],[11419,11569,"Do you think I wouldn't find out?"],[11582,11686,"You broke the ribbon"],[11686,11853,"and severed your bond with Ann?"],[11903,12070,"You will answer for it, tonight."]],"7":[[229,392,"So you think I wouldn't find out?"],[446,621,"You broke your bond with Ann Reed?"],[692,750,"Why?"],[788,1080,"I can't believe Ann would tell you"],[1080,1263,"she tore that useless rag in half."],[1263,1405,"Ann didn't tell us anything."],[1426,1622,"It was the council record keeper"],[1655,1789,"who saw it in the ledger."],[1805,1947,"But that ribbon was meaningless."],[1947,2018,"Wrong!"],[2035,2252,"You were risking your future"],[2252,2556,"as Alpha King with your antics."],[2556,2740,"The bond between you and Ann"],[2740,2873,"is what kept the other packs"],[2873,3065,"from ripping each other apart!"],[3115,3253,"She is your Luna."],[3315,3374,"No."],[3399,3507,"She's my enemy."],[3536,3737,"Ann and her parents are the same."],[3737,3858,"She was the bait."],[3878,4012,"If it weren't for her,"],[4029,4112,"our pack wouldn't"],[4112,4225,"have been massacred."],[4366,4462,"You know nothing."],[4483,4625,"She was a child."],[4667,4904,"She asked for none of this!"],[4938,5038,"Now find her,"],[5071,5184,"and make it right."],[5376,5576,"Ann is just emotional."],[5597,5709,"She'll never leave me"],[5739,5922,"with or without the bond."],[5964,6018,"Well,"],[6135,6239,"I hope you're right."],[6264,6331,"Have you discovered"],[6331,6606,"the whereabouts of the Luna Heiress"],[6606,6727,"from the High Alpine Pack?"],[6744,6877,"Because she is crucial"],[6877,6969,"in determining"],[6969,7102,"who between you"],[7102,7273,"and Holden Coleridge,"],[7273,7424,"will be the next Alpha King."],[7424,7561,"I haven't found her yet."],[7586,7678,"I'm working on it."],[7711,7778,"Well,"],[7982,8274,"I guess you've been distracted."],[8654,8888,"Now end it with that cheap singer"],[8888,9088,"from the Hundred Lakes Pack."],[9088,9221,"Never see her again!"],[9651,9784,"This is it, Dane."],[9843,9968,"I thought I could fix us,"],[9968,10064,"but I was wrong."],[10585,10744,"I guess we were't meant to be."],[11619,11703,"Goodbye, Dane."],[13067,13192,"Holden Coleridge."],[13213,13425,"He's Dane's biggest rival for Alpha King."],[13463,13567,"What's he doing here?"],[13617,13705,"Get in, gorgeous."],[13784,13918,"It's time you learn who you really are."],[15169,15331,"Boss, I just got intel that"],[15331,15473,"Ann booked a flight to Europe."],[15490,15653,"It leaves first thing in the morning."]],"8":[[867,921,"Ann."],[950,1084,"I knew you couldn't stay away."],[1380,1434,"Evelyn."],[1539,1697,"What the hell are you doing here?"],[1751,2006,"Dane, you left so fast earlier"],[2006,2256,"and I still feel sick."],[2423,2519,"I was hoping"],[2615,2744,"you would hold me tonight."],[2769,2836,"Not tonight."],[2894,2948,"Leave."],[2986,3082,"But Dane, I-"],[3082,3153,"Leave!"],[3228,3290,"Now!"],[4500,4642,"I guess we weren't meant to be."],[4667,4742,"Goodbye, Dane."],[5080,5155,"Come on."],[5359,5476,"Ann, pick up!"],[5576,5718,"Answer me, Ann."],[5751,5822,"You're mine."],[5864,6031,"And I'm not letting you disappear."],[6168,6256,"I'm certain"],[6327,6418,"you're the Luna Heiress"],[6418,6585,"to the European High Alpine Pack."],[6639,6719,"They've been searching for you"],[6719,6815,"for a long time."],[6894,6994,"You had no idea?"],[7082,7123,"No."],[7215,7361,"And I can hardly believe it,"],[7386,7515,"that I'm not a Reed."],[7532,7691,"One more thing, Ann."],[7866,7999,"Do you know you're pregnant?"]],"9":[[4,58,"What?"],[204,312,"How would you know that?"],[325,458,"I can hear the baby's heartbeat."],[767,934,"I'd drink molten silver"],[934,1126,"before I let my blood mix with anyone"],[1126,1280,"from the Broken Forest Pack."],[1543,1609,"Urgent."],[1643,1751,"Alpha Dane Montague"],[1751,1922,"has issued a missing persons alert."],[1960,2177,"He is searching for his wife, Ann Reed."],[2414,2594,"Anyone who provides information"],[2594,2806,"will be rewarded one million dollars."],[2873,3040,"One million dollars?"],[3098,3165,"Sounds like someone's"],[3165,3307,"getting desperate."],[3307,3586,"Dane will never allow this child to exist."],[3607,3845,"But this pup's the Moon Goddess's gift."],[3870,4041,"I have to protect my child."],[4066,4225,"I can't let Dane find me."],[4241,4329,"Alpha Holden,"],[4446,4571,"can you help me leave here?"],[4625,4713,"Of course."],[4804,4967,"It's my duty to send the Luna Heiress"],[4967,5046,"back to Europe."],[5814,6026,"Flight 790 to Europe just took off."],[6064,6160,"Ann was on it."],[6181,6247,"Find her!"],[6293,6360,"Now!"],[7082,7207,"I'm not running back to you"],[7207,7298,"this time, Dane."],[7482,7615,"Emergency lockdown."],[7620,7761,"Seal all terminals."],[7761,7991,"Alpha Dane has ordered a full search."],[8416,8550,"Ann, I'll find you."],[8600,8771,"And you'll pay for running from me."],[10606,10706,"Don't be afraid."],[10744,10898,"Mommy's taking you far,"],[10898,10998,"far away from him"],[10998,11215,"where he can never hurt us again."],[11286,11503,"Farewell, Dane."]],"10":[[1130,1242,"You called, Luna Heiress?"],[1384,1484,"The contracts are ready."],[1522,1564,"Let me know"],[1564,1659,"when they're countersigned."],[1659,1739,"Sure thing."],[1797,1985,"Oh, something came for you."],[2473,2623,"The Blue Ridge Pack seal."],[2673,2761,"This is from Dane."],[3507,3782,"As Luna Heiress of the High Alpine Pack,"],[3782,3916,"you are formally invited"],[3916,4133,"to the annual Pack Alliance meeting"],[4133,4312,"at the Blue Ridge Country Estate."],[4471,4612,"We've uncovered some new intel."],[4662,4838,"Your suspicion was right."],[4859,4950,"The Reed family has someone"],[4950,5059,"working for them in the shadows,"],[5059,5284,"like a gun for hire, handling everything."],[5338,5518,"So my memory of that night was real."],[6106,6264,"And the relic you've been searching for,"],[6285,6406,"it's resurfaced."],[6435,6627,"Both the relic and the man behind it"],[6627,6719,"were last seen."],[6727,6794,"Where?"],[6819,6977,"On the Blue Ridge Pack land."],[7215,7269,"I'll go."],[7386,7553,"RSVP on my behalf, Trajan."],[7578,7724,"But not to see you, Dane."],[7766,7924,"I need to know what the Reeds are up to"],[7924,8028,"and get back the relic"],[8028,8158,"they stole from my family."],[8779,8846,"Aurora."],[9154,9267,"Eager to go running back"],[9267,9401,"into Dane Montague's arms?"],[9471,9530,"Never."],[9634,9722,"If you say so."],[9880,9989,"And what about the twins?"],[10189,10281,"The twins are mine."],[10335,10452,"Dane will never know them."],[10477,10568,"Not now."],[10623,10689,"Not ever."],[12587,12837,"It's been a while, Dane Montague."]],"11":[[558,650,"Aurora Moon,"],[704,917,"Luna Heiress of the High Alpine Pack"],[917,1063,"is due at any second."],[1113,1297,"Treat her like the royalty she is."],[1326,1480,"No one's ever laid eyes"],[1480,1601,"on the Luna Heiress."],[1601,1818,"But they will tonight at my party."],[1860,1947,"On it, boss."],[1947,2014,"Good."],[2152,2252,"No fuck-ups."],[2289,2398,"The High Alpine Pack"],[2398,2535,"is the oldest werewolf pack"],[2535,2615,"in the world."],[2627,2823,"They're not to be messed with."],[2927,3103,"Any updates on Ann's whereabouts?"],[3119,3207,"Sorry, Dane."],[3219,3278,"Nothing."],[3299,3449,"It's like she's a ghost."],[3503,3557,"Look we've already spent"],[3557,3616,"so much money"],[3616,3712,"searching for her."],[3807,3958,"How about we just call it quits."],[4024,4258,"I don't care how much it costs."],[4258,4454,"I'll find her no matter what."],[4667,4729,"Hi."],[4971,5080,"Dane, honey."],[5130,5246,"Tell me we can finally"],[5246,5342,"announce our engagement"],[5342,5488,"to the council elders tonight."],[5593,5797,"You and I know we're engaged."],[5889,6051,"No need to say it out loud."],[6089,6373,"But, but it's been five years!"],[6493,6727,"And that heartless woman is long gone."],[6769,6973,"And I still suffer from that illness"],[6990,7215,"from when I shielded you in the dungeon!"],[7257,7432,"And you promised me"],[7432,7549,"that you would take care of me"],[7549,7678,"for the rest of your life!"],[8487,8533,"Fine."],[8596,8779,"I'll discuss it with Grandpa later."],[8942,9075,"No matter what I do,"],[9121,9338,"I can't get Ann out of my mind."],[9409,9492,"How can I move on"],[9492,9584,"with another woman?"],[9634,9709,"Alpha Dane,"],[9751,9922,"the High Alpine Luna Heiress"],[9922,10039,"has just arrived."],[12921,12987,"It's..."],[13017,13083,"her."]],"12":[[642,788,"Five years of searching"],[788,955,"and you waltz into my home"],[955,1063,"like it's nothing?"],[1105,1201,"How dare you?"],[1288,1493,"Pitiful and plain Ann Reed"],[1493,1772,"is the High Alpine Pack Luna Heiress?"],[1793,1881,"Impossible!"],[2231,2377,"Watch where you're going,"],[2377,2527,"you clumsy bitch!"],[2915,3073,"OMG."],[3119,3253,"That's Dane's ex-wife."],[3315,3428,"A woman he rejected"],[3428,3599,"for my bestie Evelyn years ago."],[3687,3749,"Look at her."],[3766,3937,"There's no way she's the Luna Heiress."],[4008,4179,"I know a phony when I see one."],[4237,4316,"Watch this."],[4517,4587,"Look at you."],[4671,4859,"You really expect us to believe"],[4913,5067,"that a wolfless slut like you"],[5067,5301,"is the High Alpine Pack's Luna Heiress?"],[5321,5392,"Please."],[5676,5843,"Careful mutt, I bite."],[5893,6006,"Now go make yourself useful"],[6006,6101,"and get me a drink."],[6114,6272,"She's not the same woman I knew"],[6272,6385,"all those years ago."],[6443,6544,"That much is clear."],[6581,6815,"Get your hands off me, imposter!"],[9167,9259,"Whatever this is,"],[9309,9438,"I've never felt it before."],[9509,9688,"After five years,"],[9738,9939,"why does my heart still race for him?"],[11669,11836,"I was so fucking wrong."],[11903,11970,"Ann-"],[12003,12266,"Aurora, is my fated mate."]],"13":[[988,1038,"Stop."],[2018,2110,"What am I doing?"],[2152,2335,"I can't fall for this man again."],[2360,2502,"Not like five years ago."],[2936,3140,"My name isn't Ann anymore."],[3228,3303,"It's Aurora."],[3365,3520,"And you can't just kiss me like that."],[3520,3632,"I don't belong to you."],[3845,4029,"Yes, you do."],[4074,4158,"We're mates."],[4245,4346,"I can feel it."],[4437,4537,"You can feel it too."],[4592,4662,"Mates?"],[4717,4788,"Please."],[4875,4934,"Are you sure it's not"],[4934,5055,"just another love spell?"],[5246,5321,"Was I wrong?"],[5413,5613,"Have I been wrong this entire time?"],[6573,6694,"Why did you ignore it?"],[6852,6965,"Is it your new lover?"],[7023,7178,"It's none of your damn business."],[8204,8425,"That's the last tear I'll shed over you,"],[8425,8533,"Dane Montague."],[10264,10377,"Five years."],[10431,10543,"Way too long."],[10543,10689,"It's good to see you, Connall."],[10706,10860,"Good to see you too, my dear."],[10906,11098,"I always hoped you'd come back for Dane."],[11144,11265,"I'm not here for Dane."],[11327,11473,"I came back to get what's mine."],[11519,11649,"The Reed family relic."],[11699,11840,"The magic in it will give werewolves"],[11840,11974,"the power and visibility"],[11974,12132,"we've craved for centuries."],[12174,12308,"I've heard of this relic."],[12354,12408,"Which is why"],[12408,12541,"I need your help retrieving it."],[12562,12741,"Allied, we can present it"],[12741,12858,"to the council and..."],[12987,13175,"There's no way in hell"],[13196,13405,"that a trashy liar like you"],[13438,13567,"is a Luna Heiress."]],"14":[[16,108,"Quiet, Evelyn."],[145,342,"This doesn't concern you."],[371,479,"Show some respect."],[517,617,"But it does concern me,"],[617,734,"Grand Alpha Connall,"],[734,884,"as I'm to be Dane's Luna."],[938,1142,"I would never acknowledge you"],[1142,1292,"as the Blue Ridge Luna."],[1317,1468,"You're Dane's plaything."],[1484,1568,"Nothing more!"],[1839,1981,"I still don't know what happened"],[1981,2072,"so many years ago"],[2072,2248,"between you and Dane."],[2323,2631,"But your proposal to work together"],[2631,2802,"to leverage the relic"],[2873,3003,"is worth considering."],[3040,3132,"Thank you, Connall."],[3132,3428,"If the request is made directly"],[3449,3716,"by the High Alpine Luna Heiress herself."],[3845,4037,"Looks like your lies didn't poison"],[4037,4149,"Grand Alpha Connall's mind"],[4149,4237,"after all."],[4237,4375,"Perhaps we should be"],[4375,4596,"asking the real question."],[4617,4946,"Is she who she truly says she is?"],[4946,5230,"Or is this another trick"],[5251,5430,"from Ann Reed?"],[5876,6060,"Well, as you can see,"],[6106,6318,"nobody here believes any of your lies."],[6339,6393,"Oops!"],[6468,6581,"Almost had a spill."],[6652,6719,"Would hate to ruin"],[6719,6948,"the only nice dress you can afford."],[7002,7273,"Even if it is, well, rented."],[7273,7674,"Renting a dress to fake a royal identity?"],[7674,7766,"Oh, that is low."],[7816,7941,"Even for a Reed."],[7941,8133,"And the only one who's defending her"],[8133,8299,"is Grand Alpha Connall."],[8350,8525,"He didn't even confirm her identity."],[8525,8571,"What?"],[8600,8708,"She must be lying."],[9046,9117,"What are you..."],[9501,9538,"Ah!"],[9538,9672,"Oh my God!"],[9763,9893,"What are you doing?"],[9893,9980,"Not anymore."],[10035,10189,"I've got bigger plates spinning."],[10214,10389,"And no time for petty games"],[10389,10543,"with pitiful wolves like you."],[10618,10698,"You."],[10714,10890,"This is the first and the last time"],[10890,10981,"I will say it."],[11056,11156,"I am Aurora."],[11198,11436,"I am the High Alpine Luna Heiress."]],"15":[[183,321,"Who are you, really?"],[350,471,"Are you the Luna Heiress?"],[513,625,"Or is it just another one"],[625,696,"of your games?"],[738,817,"Answer me."],[880,1021,"Tell me the truth for once."],[1026,1176,"Let go of me, Dane."],[1201,1317,"I don't have to explain"],[1317,1413,"myself to you."],[1468,1609,"In fact, I want nothing"],[1634,1722,"to do with you,"],[1793,1881,"ever again."],[2002,2139,"You've really changed."],[2206,2360,"You say that as if it's a bad thing."],[2402,2464,"Were you hoping"],[2464,2669,"I'd be the same pitiful little wolf"],[2669,2811,"who let everyone walk all over her?"],[2877,2944,"Listen,"],[2986,3111,"you can call yourself"],[3111,3215,"whatever you want to."],[3236,3361,"But to the rest of us?"],[3403,3536,"You will always be known"],[3536,3716,"as the Reed's cursed little traitor."],[3749,3949,"That's all you'll ever be."],[3987,4149,"I will say it one last time."],[4250,4396,"I have nothing to do"],[4396,4504,"with the Reed family."],[4575,4654,"Daughter!"],[4800,4871,"My Ann!"],[4917,5009,"You're back!"]],"16":[[4,108,"It can't be."],[125,266,"How did she show up here?"],[279,362,"Please!"],[525,642,"You will do what we say"],[642,804,"whether you like it or not!"],[1297,1438,"My daughter, Ann!"],[1589,1785,"So many years have passed"],[1814,1960,"and not a single letter,"],[1960,2093,"not a single call."],[2147,2214,"And now"],[2256,2352,"you show up"],[2352,2565,"pretending to be the Luna Heiress?"],[2585,2731,"Why are you doing this?"],[2731,2852,"I told you all,"],[2852,3107,"the maid is her mother, a Reed."],[3123,3286,"She even knew her daughter was a fake."],[3328,3436,"Too convenient."],[3436,3582,"Esther showing up now?"],[3595,3649,"Here?"],[3695,3887,"Dane would never let her near this place."],[3912,4095,"Not unless someone helped her get in."],[4141,4450,"Esther, you are nothing to me."],[4533,4700,"You would speak to your mother"],[4700,4792,"like this?"],[4867,5084,"The same mother who helped you"],[5084,5246,"acquire the love potion"],[5246,5397,"to fake the mate bond"],[5397,5518,"so you could marry Dane"],[5518,5638,"in the first place?"],[5663,5834,"You can stop acting, Esther."],[5889,5989,"We both know I'm not"],[5989,6072,"your real daughter."],[6306,6460,"When did she change?"],[6502,6573,"She's no longer"],[6573,6723,"that easily manipulated girl"],[6723,6815,"I could control."],[6861,7107,"And you know damn well"],[7152,7257,"what you did to me."]],"17":[[95,283,"I, I, don't, Aurora!"],[304,479,"You're mistaken, I, I, I-"],[479,550,"Aurora,"],[629,692,"what's going on?"],[717,829,"You're not a Reed?"],[880,1005,"Why didn't you tell me this"],[1005,1096,"from the start?"],[1117,1238,"Enough, Aurora!"],[1284,1426,"Esther doesn't deserve this."],[1455,1559,"You can't just throw around"],[1559,1718,"random accusations."],[1743,2002,"You two seem very in sync."],[2018,2164,"Is this really your first time meeting?"],[2456,2640,"Could Evelyn be the one"],[2640,2848,"working for the Reed family all along?"],[2915,3107,"Who let her in my house?"],[3136,3257,"You're not welcome here!"],[3332,3390,"Damn it!"],[3424,3532,"If this keeps going,"],[3532,3632,"they'll figure me out."],[3866,3958,"Aurora!"],[3991,4029,"My god,"],[4029,4225,"just because nobody believes your lies"],[4225,4408,"doesn't mean you can try to kill me!"],[4408,4571,"I didn't touch you!"],[4637,4842,"Oh, come on, Evelyn."],[4904,5105,"We all know what game you're playing."],[5167,5317,"Stop pretending to be sweet"],[5326,5492,"when everybody here knows"],[5518,5714,"you're a two-faced hag."],[5797,5943,"Is that Alpha Holden?"],[5985,6147,"From the Fall Line pack?"],[6235,6402,"He's our Alpha Dane's"],[6402,6589,"biggest rival for Alpha King."],[6785,6861,"You made it."],[6881,6994,"Change of plans."],[7082,7157,"I figured with you coming,"],[7157,7349,"there could be surprises."],[7374,7499,"No way I was gonna miss it."],[7607,7957,"Now, Evelyn, don't you owe an apology"],[7957,8091,"to Ms. Moon for,"],[8141,8216,"I don't know,"],[8266,8479,"falsely accusing her of pushing you?"],[8562,8612,"No, but..."],[8671,8871,"But, I didn't do anything wrong!"],[8913,9038,"Alpha Holden, you weren't even here!"],[9038,9180,"Why would you believe her?"],[9209,9476,"My Aurora would never lie."],[9609,9818,"Your Aurora?"],[9901,10068,"What the hell are you talking about?"],[10210,10310,"She didn't tell you."],[10356,10468,"Such a modest woman."],[10552,10731,"Not only is she the Luna Heiress"],[10731,10881,"of the High Alpine Pack,"],[10902,11106,"she's also my fiancée."],[11298,11498,"Soon to be the Luna Heiress"],[11498,11615,"of Fall Line pack."]],"18":[[112,216,"I need to talk to you."],[266,337,"Alone."],[383,496,"We've talked enough."],[529,613,"I'm done for tonight."],[613,679,"Let's go."],[704,884,"Let's go, Luna Heiress."],[963,1163,"How dare you show your face here?"],[1188,1292,"You weren't invited."],[1317,1443,"I go wherever I want,"],[1443,1539,"when I want Dane."],[1576,1780,"You have no sway over me."],[1876,2002,"Are you okay, Luna Heiress?"],[2039,2110,"I'm fine now."],[2223,2314,"As Luna Heiress,"],[2314,2431,"I've seen how Alpha Dane"],[2431,2544,"treats his guests."],[2569,2740,"It's clear that the Blue Ridge Pack"],[2773,2848,"has no interest"],[2848,2986,"in the High Alpine support."],[3478,3632,"It seems that Alpha Dane"],[3632,3807,"has made a grave mistake."],[4692,4850,"It, it can't be."],[4925,5146,"Is she truly the Luna Heiress?"],[5184,5359,"Have I been wrong this whole time?"],[5576,5784,"Mommy, we missed you!"]],"19":[[208,425,"It sounded like, something."],[513,700,"Boss, are you okay?"],[754,850,"Find out the truth."],[909,1138,"If Ann... Aurora is really"],[1138,1234,"who she says she is."],[1313,1463,"If she is the Luna Heiress,"],[1463,1551,"I need to know."],[2306,2377,"Show's over."],[2410,2464,"Let's get back"],[2464,2577,"to dancing and mingling."],[2615,2798,"This is a party after all, isn't it?"],[3299,3386,"She's back."],[3457,3649,"Should be there any minute."],[3687,3757,"Get ready."],[4821,5025,"Mommy, will we ever have a daddy?"],[5355,5451,"We're mates."],[5526,5613,"I can feel it."],[5701,5822,"You can feel it, too."],[6239,6381,"I've always been by your side."],[6468,6664,"And I always will be."]],"20":[[1793,1918,"Go up and get ready for bed."],[1964,2106,"I'll be up in a sec to tuck you in."],[2356,2435,"I could stay."],[2477,2623,"In the guest room, of course."],[2656,2736,"And in the morning"],[2736,2836,"we could take the kids to the park."],[2957,3199,"Thank you, Holden, for everything."],[3244,3357,"But, no."],[3382,3499,"You're always here for me"],[3524,3624,"and I appreciate it,"],[3624,3695,"but um,"],[3724,3928,"I don't have to rely on anyone anymore."],[3941,4004,"I get it."],[4095,4212,"After a night like this,"],[4241,4300,"I'm sure you,"],[4400,4471,"want to be alone."],[4529,4637,"I'm glad you understand."],[4758,4842,"Of course I do."],[5046,5138,"I'll never push you."],[5205,5292,"I'll call you tomorrow."],[5363,5426,"Okay."],[5430,5472,"Good night."],[5488,5543,"Night."],[5876,5943,"What is this?"],[5985,6131,"It's Aurora's address."],[6181,6277,"She's close."],[7165,7298,"I have to get to Aurora."],[7328,7407,"She's in danger."],[8112,8212,"Hey, little sister."],[8454,8671,"So good of you to finally come home."]],"21":[[325,462,"You never should have come back."],[508,604,"And you sure as hell shouldn't"],[604,796,"have touched what was never yours!"],[838,913,"I don't belong"],[913,1042,"to the Reed family anymore."],[1076,1205,"And I'm not afraid of you."],[1568,1710,"You bitch!"],[1793,1935,"You'll pay for that!"],[3653,3803,"Please hold on, Ann."],[4996,5163,"Get your hands off my mate!"]],"22":[[1484,1760,"It isn't over."],[2756,2815,"Dane."],[3028,3128,"Are you okay?"],[3148,3203,"You're hurt."],[3486,3707,"She's back after five years."],[3707,3899,"And we almost lost her again."],[3995,4074,"From now on,"],[4104,4283,"we can't let her out of our sight."],[4308,4396,"You're bleeding."],[4521,4608,"Don't worry about me."],[4667,4738,"I'm fine."],[4842,4900,"Are you okay?"],[4950,5100,"I gave him a little hell of my own"],[5100,5205,"before you got here."],[5280,5351,"I noticed."],[5488,5659,"I'm so glad I got here when I did."],[5918,6031,"Let's get you patched up."]],"23":[[521,625,"Since I lost my wolf,"],[625,825,"I don't heal as fast as I used to."],[842,992,"First aid kit's in the bathroom."],[992,1126,"Second door on the left."],[1330,1447,"I can't believe it."],[1484,1568,"He saved me."],[2218,2352,"How did you know to come here?"],[2431,2581,"It's like I said before,"],[2631,2715,"we're mates."],[2786,2852,"I'll always know"],[2852,2940,"when you're in trouble."],[3420,3582,"Stop acting like this."],[3816,3983,"We got divorced five years ago."],[4183,4291,"You disappeared,"],[4387,4479,"without a word."],[4533,4642,"And now that you're back,"],[4683,4838,"you aren't even the same person."],[5009,5142,"You got a whole new identity"],[5142,5242,"I don't recognize."],[5309,5505,"Ann, tell me."],[5622,5872,"What else are you hiding from me?"],[6110,6218,"What really happened"],[6218,6343,"during those five years?"]],"24":[[412,475,"Evelyn."],[629,813,"Has she been with you all these years?"],[892,1101,"Are you still jealous of Evelyn?"],[1134,1259,"Maybe that means,"],[1317,1426,"she still cares."],[1568,1710,"If Evelyn has been working"],[1710,1847,"for the Reeds this whole time,"],[1910,2047,"how the hell did she stay"],[2047,2143,"so well hidden?"],[2168,2364,"How do I prove who she really is?"],[2481,2665,"Do you think Evelyn knows Esther Reed?"],[2727,2819,"Esther Reed?"],[2898,2990,"Why would you ask?"],[3332,3490,"Don't hurt our Mommy!"]],"25":[[162,287,"Don't hurt our Mommy!"],[496,621,"She has kids"],[621,713,"with Holden?"],[909,1101,"I told you both to get ready for bed."],[1109,1338,"We were, but we heard scary noises,"],[1338,1530,"so we came down to save you."],[1593,1685,"You're hurt!"],[1805,1993,"Mommy, you okay?"],[2031,2260,"A bad man came and gave Mommy"],[2260,2419,"a few bumps and bruises, but..."],[2489,2544,"he's gone."],[2565,2665,"And I'm okay now."],[2711,2840,"You're the guy from TV"],[2840,2994,"looking for our mom!"],[3078,3182,"Daddy!"]],"26":[[129,333,"Seraphina, don't be silly."],[333,433,"That's not your father."],[483,784,"But they are your children."],[855,975,"They look just like you."],[1001,1242,"No, they're Beta Trajan's children."],[1317,1451,"I've just been taking care of them."],[1931,2010,"Come on, you two."],[2047,2122,"It's time for bed."],[2506,2623,"Glad you're alright, Mommy."],[2648,2756,"Good night, Daddy."],[2769,2965,"Seraphina, why do you keep"],[2965,3061,"calling him that?"],[3061,3232,"Because he's our dad,"],[3249,3399,"we can feel it."],[3599,3670,"Kid."],[3841,3924,"How old are you?"]],"27":[[29,79,"Three."],[116,216,"They're three years old."],[367,642,"But Mommy, me and sis are four."],[800,946,"Stop saying that, Tristan."],[1005,1092,"Come on, you two."],[1092,1163,"It's time for bed."],[1163,1209,"Come on."],[1222,1280,"Let's go."],[1605,1826,"Like I said, they're Trajan's kids."],[1868,1985,"They don't have a mother,"],[1985,2106,"so as their godmother,"],[2193,2273,"they call me Mommy."],[2360,2510,"You're hiding something from me."],[2569,2652,"What is it?"],[2702,2802,"There is something."],[2911,3048,"I spoke to your grandfather about it"],[3048,3132,"at the ball."],[3144,3269,"A possible alliance."],[3374,3465,"Now I think it's time"],[3465,3582,"you and I discuss it too."],[3624,3703,"Alliance?"],[3795,3962,"Why would we need an alliance?"],[4366,4450,"I remember this."],[4450,4537,"You always used to be"],[4537,4646,"so secretive about it."]],"28":[[296,408,"What language is this?"],[558,738,"One that took me years to decipher."],[955,1021,"It's a map,"],[1121,1276,"pointing to a powerful relic"],[1301,1443,"buried in my childhood home"],[1463,1530,"on the land"],[1530,1672,"that you seized from the Reeds."],[1718,1901,"Land they're fighting the Blue Ridge"],[1901,2064,"for every chance they get."],[2252,2419,"I still don't understand"],[2448,2606,"why you're seeking alliance with me."],[2606,2715,"We find the relic,"],[2861,2965,"and help me keep the Reeds"],[2965,3098,"from finding it before we do,"],[3111,3357,"together, we'll share the power"],[3357,3440,"that it holds."],[3511,3632,"The power that would help me"],[3632,3816,"secure my place as Alpha King?"],[3912,4012,"That and much more."],[4200,4383,"I never wanted to trust you again."],[4558,4696,"I don't have another choice now."],[4742,4850,"Tell me you'll help me."]],"29":[[33,141,"Tell me you'll help me."],[225,387,"We must help her."],[387,529,"It's how we'll prove"],[529,700,"that she belongs to us."],[900,1013,"If what you say is true,"],[1063,1322,"the relic and the High Alpine's backing"],[1322,1493,"could benefit the both of us."],[1593,1805,"So, we've got a deal."],[1976,2114,"Though I'm still surprised"],[2114,2239,"you'd come for me to help."],[2264,2385,"Your grandfather has always"],[2385,2464,"vouched for you."],[2535,2719,"Has always insisted I could trust you."],[2752,2907,"I guess I'm just testing his word."],[3178,3278,"The children are in bed."],[3432,3570,"Have you talked to him about the relic?"],[3695,3953,"Yes, he, um, he agreed to help."],[4029,4091,"I did."],[4195,4362,"But if the relic is as powerful"],[4362,4458,"as she says it is,"],[4496,4621,"she'll need more protection"],[4621,4846,"than one beta wolf."],[4921,5138,"I've been protecting her perfectly"],[5176,5288,"for five years."],[5321,5597,"And now, she's come to me for help,"],[5622,5714,"against enemies"],[5714,5980,"that would easily run through you."],[6014,6147,"Wait a minute, Dane."],[6160,6285,"You've asked for my help,"],[6306,6398,"and I'll give it to you."],[6418,6560,"But we're doing things my way."],[6702,6810,"Team here tomorrow"],[6810,6923,"to help watch over you."],[7002,7169,"He's as bullheaded as ever."],[7207,7290,"But he's right."],[7315,7520,"The Reeds in the Broken Forest Pack"],[7540,7716,"would blow right through Trajan."],[7753,7870,"If you think that's necessary,"],[7870,7932,"then fine."],[8012,8070,"Now go."],[8166,8258,"I'll see you tomorrow."],[8358,8546,"I'm not going anywhere."],[8746,8883,"I'm staying right here tonight."]],"30":[[342,483,"You will do what we say,"],[483,642,"whether you like it or not!"],[729,804,"No!"],[875,980,"Dad, please!"],[1017,1071,"No!"],[1313,1376,"Shift!"],[1388,1547,"Please, shift!"],[1601,1768,"My father took everything else"],[1768,1847,"away from me."],[1847,2056,"Please don't let him have my wolf."],[2790,2869,"It's gone."],[3766,3916,"It's okay, Aurora."],[3974,4041,"It's just me."],[4116,4312,"Dane, what are you doing in my room?"],[4425,4517,"You're making me regret"],[4517,4612,"letting you stay here."],[4754,4842,"I'm sorry."],[4842,5009,"I just heard you scream,"],[5009,5071,"and I was worried"],[5071,5188,"your attacker came back."],[5226,5280,"No."],[5422,5513,"Just a bad dream."],[5563,5751,"No wonder you're having bad dreams"],[5764,5910,"after that attack tonight."],[5997,6164,"Any idea who could have done it?"],[6185,6339,"I think it was my brother, Remington."],[6418,6523,"He had a mask on,"],[6523,6685,"but I recognized"],[6685,6819,"the tattoos on his hands."],[6844,7044,"Do you have any idea"],[7098,7203,"how much danger"],[7203,7344,"you and the kids were in"],[7344,7461,"if I hadn't showed up?"],[7511,7716,"You're the High Alpine Luna Heiress."],[7753,7912,"How could you be so careless?"],[7912,7995,"Stop."],[8087,8204,"You'll wake the children"],[8241,8329,"and I do not want them"],[8329,8425,"knowing you're here."],[8837,9025,"Meet me at Reed packlands."],[9025,9200,"I know about your mother's death."]],"31":[[83,212,"This could be Remington"],[212,392,"luring me out to attack me again."],[421,608,"Maybe I should ask Trajan to come."],[608,742,"Or maybe even Dane."],[763,829,"Are you okay?"],[963,1113,"Looks like you just saw a ghost."],[1201,1272,"I'm fine."],[1384,1443,"Ann."],[1480,1530,"I mean..."],[1609,1676,"Aurora."],[1739,1839,"I'm here to help."],[1947,2093,"Just, let me."],[2127,2235,"I'm going back to bed."],[2235,2327,"You should too."],[3015,3153,"It's obviously a trap."],[3194,3353,"But if I bring Holden or Dane,"],[3399,3549,"they'll get dragged into this."],[3578,3699,"I can't risk that."],[3699,3828,"I'll handle it myself."]],"32":[[1230,1384,"Do you have it, witch?"],[1718,2006,"One drop is all it takes."],[2089,2318,"Anyone who inhales its scent"],[2352,2464,"will become helplessly,"],[2464,2656,"deeply in love with you."],[2756,3007,"Even more than their mate."],[3090,3415,"Even more than life itself."],[3449,3616,"And it works on Alphas?"],[3616,3795,"Especially on Alphas."],[3837,3987,"It binds to their power"],[3987,4145,"and turns it into love."],[4696,4771,"Perfect."],[4813,4975,"Dane won't know what hit him."],[5050,5221,"This time you will listen to me."],[5680,5739,"It's done."],[5772,5893,"Your turn, Remington."],[5968,6060,"Kill her."],[6101,6231,"And don't fail this time."]],"33":[[304,487,"Yes, she'll be here."],[567,767,"If you have my back, I'll have yours."],[1017,1213,"She should be here any minute,"],[1234,1384,"and then I'll end her."],[1426,1584,"This pack belongs to me."],[1584,1672,"And I'm not gonna"],[1672,1789,"let her ruin my plan."],[2560,2644,"Is somebody there?"],[4016,4295,"That sound brings back memories."],[4466,4600,"Remember when we were kids,"],[4600,4758,"and I'd lock you in the closet?"],[4758,4867,"You'd scream,"],[4867,5005,"begging to be let out."],[5309,5392,"Let me go."],[5472,5568,"I wish I could,"],[5580,5889,"but you see, you're on Reed packlands,"],[5897,6047,"and seeing as you rejected us,"],[6047,6227,"that means I'll be dealing with you"],[6227,6377,"according to the law."],[6410,6510,"I'm only here"],[6510,6635,"because you lured me here."],[6681,6790,"I know it was you."],[6798,6990,"Maybe, maybe not."],[6990,7182,"Too bad you won't live long enough"],[7182,7253,"to prove it."]],"34":[[492,596,"Mommy in trouble!"],[596,767,"I saw it in my dream!"],[767,888,"I saw it too!"],[888,1063,"We have to go help her!"],[1330,1363,"Help!"],[1363,1472,"Mommy's in danger!"],[1539,1609,"What'd you say?"],[1647,1714,"Your mommy?"],[1722,1805,"They're hurting her"],[1805,1935,"in an abandoned building,"],[1956,2135,"Broken Woods pack land."],[2135,2318,"I saw it in my dream."],[2385,2590,"Dream sight is an Alpha power."],[2615,2798,"That beta can't be their father."],[2798,2940,"Come on, you have to hurry!"],[3399,3486,"Go save her! - Go save her!"],[3490,3611,"Go save her! - Go save her!"],[3649,3724,"What secrets"],[3724,3883,"have you been hiding, Ann?"],[3941,4037,"No matter what,"],[4037,4245,"I won't let anyone hurt you again."]],"35":[[454,738,"Tell me, why did you come back?"],[809,946,"I want the truth."],[1005,1142,"I came for the annual ball."],[1188,1284,"Lies!"],[1338,1409,"One of my men"],[1409,1505,"overheard you talking to"],[1505,1697,"Grand Alpha Connall Montague"],[1697,1785,"at the ball."],[1830,2014,"You mentioned a relic."],[2072,2260,"I don't know anything about a relic."],[2590,2736,"You must have bad intel."],[3240,3365,"Elder Baskin?"],[3432,3553,"What are you doing here?"],[3582,3737,"I'm here to make sure"],[3737,3874,"you do what you're told!"],[3983,4200,"Give us the relic, now!"],[4279,4416,"It belongs to the council."],[4521,4758,"I can't believe a council member"],[4758,4859,"is involved in this."],[4859,5163,"You are nothing but a con woman"],[5163,5380,"who came here to sow discord!"],[5430,5705,"You are a liar and a traitor!"],[5751,6060,"Give us what we want or else I..."],[6193,6314,"You really think"],[6314,6464,"dragging me here through the dirt"],[6464,6577,"makes you look strong?"],[6673,6823,"I'm not playing that game."],[6940,7040,"I'm not a Reed."],[7061,7161,"Which means I don't have to"],[7161,7286,"take your abuse anymore."],[7636,7832,"You're making all that up in your head."],[7866,8045,"We never abused you."]],"36":[[563,642,"How long should I"],[642,759,"leave you in here this time?"],[775,846,"Two days?"],[875,930,"A week?"],[955,1092,"Please Remington, I'm sorry."],[1092,1217,"Please don't lock me in."],[1259,1347,"A week it is."],[1526,1639,"When will you learn"],[1639,1876,"that the council holds all the power?"],[1876,1993,"Not some so-called"],[1993,2243,"High Alpine Luna Heiress!"],[2289,2473,"I'll never, ever"],[2473,2598,"let you control me again."],[3457,3553,"No!"],[4008,4112,"If you want to hit someone,"],[4112,4216,"you dirty mutt,"],[4245,4308,"hit me."]],"37":[[608,663,"It's okay."],[688,759,"I've got you."],[1609,1897,"He saved me, again."],[2010,2344,"Alpha Dane, your pack"],[2381,2502,"may pass freely."],[2665,2773,"That is your right"],[2815,2973,"after defeating ours."],[3044,3257,"But she, Ann Reed!"],[3445,3528,"Aurora."],[3566,3737,"She's not your concern."],[3737,3858,"She's under my protection."],[3878,4062,"You can protect your pack!"],[4083,4312,"But she's no pack member."],[4329,4471,"She's an outsider."],[4525,4804,"And as per Council law,"],[4950,5075,"mine to judge."],[5150,5271,"Don't listen to him, Dane."],[5309,5380,"Just go."],[5451,5488,"Just go-"],[5488,5613,"Not without you."],[5784,6068,"You'd risk your alliance"],[6068,6281,"with the Council for her?"],[6427,6581,"I'm not risking anything."]],"38":[[2523,2673,"Aurora Moon is my mate."],[2861,2990,"From this moment on,"],[3036,3165,"our lives are bound."],[3294,3420,"If you touch her again,"],[3503,3628,"you're declaring war"],[3653,3782,"on the Blue Ridge Pack."],[3828,3903,"That's..."],[3958,4066,"a violation."],[4087,4233,"Then take it to the Council."],[4325,4421,"But know this."],[4466,4679,"If you as much as breathe near her,"],[4817,5005,"I won't just defeat you."],[5088,5213,"I'll erase your name"],[5221,5355,"from the pack records."]],"39":[[2127,2243,"Make no mistake,"],[2268,2385,"Aurora is mine."],[2535,2927,"From this day on, no one will harm her."],[3541,3645,"We bond again."],[3691,3853,"And it feels so much stronger"],[3853,3966,"than the first time."],[3999,4212,"I never expected to feel this calm."],[4254,4387,"And I feel something else."],[4429,4533,"What I used to feel"],[4533,4671,"when I still had my wolf."],[5150,5526,"My wolf, has it returned to me?"],[6172,6327,"It's okay, Mommy is strong."],[6327,6448,"She'll come back."],[7102,7248,"You see it too, Sera?"],[7265,7428,"It's the magic mate bond."],[7428,7607,"Dane's gonna keep us safe now!"]],"40":[[1247,1288,"Dane."],[1313,1430,"What are you doing?"],[1463,1584,"Put me down, I can walk."],[1584,1618,"No."],[1697,1755,"Let me."],[2410,2519,"Thanks for saving me."],[2540,2648,"But I never asked for you"],[2648,2761,"to mate with me, Dane."],[2840,2973,"I didn't force you last time"],[2973,3103,"and I didn't force you this time."],[3240,3315,"I'm sorry."],[3474,3557,"For accusing you of"],[3557,3691,"using a love spell on me."],[3770,4016,"Dane is apologizing."],[4091,4237,"I thought it was the love potion"],[4270,4446,"that made me and my wolf crave you."],[4475,4558,"But now I know."],[4637,4729,"It wasn't that."]],"41":[[212,316,"It was our bond,"],[396,504,"our fated bond."],[588,658,"All along."],[763,967,"If this apology came seven years ago,"],[967,1130,"maybe things would be different."],[1159,1343,"But now, it's too late."],[1372,1476,"It's all in the past now."],[1639,1772,"No need to apologize."],[1793,1889,"But, Ann..."],[2160,2264,"Tell me to stop,"],[2318,2402,"and I will."],[3165,3328,"What the hell are you doing here,"],[3641,3757,"and carrying my fiancée?"]],"42":[[817,896,"You're hurt."],[934,1013,"Pretty badly."],[1042,1134,"Are you sure you're okay?"],[1134,1222,"I'm okay, Holden."],[1276,1355,"I can walk."],[1376,1451,"Really."],[1589,1659,"Hey."],[1659,1730,"Mommy."],[1956,2110,"I knew you'd be okay."],[2131,2352,"Tristan and I saw your bond form."],[2598,2781,"Thank you for saving my mommy."],[2986,3078,"There it is again."],[3107,3211,"Alpha sight."],[3236,3411,"They obviously have Alpha blood"],[3411,3566,"running through their veins."],[3566,3657,"Which could mean-"],[3657,3757,"Answer me, Dane!"],[3757,3920,"What gives you the right to be here?"],[4004,4208,"I'm here because none of the men"],[4208,4300,"in Aurora's life"],[4300,4441,"can protect her like I can."],[4487,4675,"She's my mate, after all."]],"43":[[20,179,"Five years ago, and just now."],[225,354,"We just bonded again."],[658,717,"Did you forget about"],[717,867,"abandoning her five years ago?"],[909,1080,"She's not your mate."],[1138,1251,"She's my fiancée."],[1455,1547,"Now get out!"],[1568,1639,"Make me."],[2202,2419,"Daddy, please don't fight."],[2419,2535,"It can't be."],[2610,2765,"Holden is their father?"],[2898,2973,"Come with me."],[3478,3578,"What is it, Dane?"],[3578,3695,"You're my mate."],[3695,3832,"How could you walk away from me"],[3832,3883,"five years ago,"],[3883,4054,"and crawl into my enemy's bed,"],[4054,4191,"and have his children?"]],"44":[[396,496,"Hit a nerve, huh?"],[533,613,"So it's true."],[646,771,"Holden's the father?"],[796,1055,"Tell me, are they three or"],[1055,1267,"did you hide their real age?"],[1267,1413,"What does their age have to do with it?"],[1413,1530,"Everything."],[1589,1735,"I want to know if my ex-wife"],[1735,1810,"cheated on me"],[1810,1956,"with my worst enemy"],[2010,2198,"before we even got divorced."],[2198,2389,"I have never betrayed my mate,"],[2456,2565,"or my marriage."],[2565,2640,"But you?"],[2690,2769,"What right do you have"],[2769,2902,"to talk about betrayal?"],[2923,3103,"From day one, Evelyn stood"],[3103,3232,"between us and you let her."],[3232,3345,"That's not the same thing."],[3399,3566,"Just, tell me now."],[3649,3858,"Is Holden their father or not?"],[3858,3987,"And don't bother telling me"],[3987,4099,"they're not your kids."],[4141,4266,"We both know the truth."],[4329,4421,"Who's their father?"],[4533,4654,"And what if I told you?"],[4692,4750,"What then?"],[4779,4850,"Would you finally cut"],[4850,4971,"Evelyn out of your life?"],[5075,5163,"Would you actually"],[5163,5280,"choose me this time?"]],"45":[[37,137,"If they're mine,"],[137,300,"I'll give them everything."],[379,692,"But Evelyn, she saved my life."],[738,905,"If not for her, I would have died"],[905,1030,"in the Reeds' dungeon."],[1105,1192,"I owe her."],[1192,1297,"Just as I thought."],[1380,1534,"You'll never let her go."],[1639,1747,"But good news, Dane."],[1747,1893,"You don't have to choose anymore."],[1972,2089,"They're not your kids."],[2122,2264,"And I have no interest"],[2298,2489,"in fighting Evelyn over a man again."],[3007,3178,"Thank you, Alpha Dane,"],[3178,3294,"for saving me today."],[3332,3511,"As promised, once I find the relic,"],[3561,3716,"I'll make sure you become Alpha King."],[3762,3912,"But as your business partner."],[3962,4049,"Here's a tip."],[4095,4283,"Investigate your fiancée,"],[4337,4416,"before she poisons"],[4416,4533,"more than just your heart."]],"46":[[930,1034,"Yes, Archer?"],[1034,1105,"I got the results"],[1105,1201,"of the background check"],[1201,1384,"you ordered on Holden Coleridge"],[1384,1484,"and Trajan Graves."],[1518,1651,"Neither have children, boss."],[1722,1906,"I know she's hiding something."],[1981,2064,"Thanks, Archer."],[2147,2231,"I'll be in touch."],[2594,2786,"Thank you for saving my mommy."],[3395,3607,"If she won't tell me who their father is,"],[3645,3782,"I'll get a DNA test,"],[3782,3928,"and find out on my own."],[3949,4158,"Investigate your fianceé,"],[4195,4279,"before she poisons"],[4279,4396,"more than just your heart."],[4562,4846,"First the kids, now Evelyn."],[4892,5017,"Ann, you came back"],[5017,5167,"and messed with my head."],[5251,5317,"Evelyn."],[5405,5505,"What's your secret?"]],"47":[[421,508,"You're late."],[583,734,"I was busy getting my ass"],[734,934,"kicked by your aggro fiancé."],[1251,1338,"Everybody knows that"],[1338,1534,"Dane is an Alpha through and through."],[1555,1697,"Can't say the same for you."],[1747,1968,"You couldn't even kill that tiny"],[1968,2227,"little wolfless worm, Aurora."],[2306,2435,"You're useless."],[2648,2790,"I'm not Dane."],[2848,3061,"I don't like to be toyed with."],[3315,3432,"Cut it out, you two."],[3453,3645,"We're on the same side, remember?"],[3682,3878,"We're Reeds."],[3999,4237,"And why are you so calm?"],[4266,4416,"If Aurora gets that relic,"],[4450,4579,"we won't be able to stop her"],[4579,4658,"from becoming the world's"],[4658,4792,"most powerful werewolf."],[4808,4934,"Don't you worry."],[4934,5088,"I have my own way"],[5088,5238,"of dealing with Aurora."]],"48":[[771,863,"It's been a long time"],[863,1042,"since I last saw this house."],[1067,1172,"These woods."],[1313,1443,"I'm here, Mom,"],[1443,1622,"to find the missing pages of the journal"],[1622,1776,"that will lead me to the relic."],[1822,1885,"You okay?"],[1989,2056,"I'm fine."],[2189,2302,"Let's just get this over with."],[2627,2811,"Never thought I'd step foot here again."],[3282,3336,"What's wrong?"],[3378,3478,"This place,"],[3499,3628,"it turns my stomach."],[3628,3691,"Nothing."],[3778,3841,"Come on."],[4191,4291,"I vaguely remember"],[4291,4383,"where I hid the missing"],[4383,4508,"journal pages."],[4717,4783,"Somewhere in the room"],[4783,4888,"I used to live in."],[5176,5284,"Your bedroom?"],[5555,5676,"If you can call it that."]],"49":[[779,846,"You brat!"],[880,1134,"Let me go, do not get in my way!"],[1309,1451,"Please, let him go!"],[1760,1922,"Run, Dane, run!"],[1922,2022,"I'll go get help."],[2831,2894,"We're here."],[3057,3186,"This was my bedroom."],[3249,3315,"My cage."],[3315,3574,"My worst nightmare."],[3603,3661,"This?"],[3770,3870,"This was your room?"],[4237,4329,"The little girl,"],[4383,4521,"the one who saved me,"],[4587,4729,"it was Aurora?"]],"50":[[212,387,"But if the little girl who saved me"],[387,492,"was Aurora,"],[508,621,"then who's Evelyn?"],[646,804,"And how did she know what happened"],[804,900,"in this house?"],[917,984,"Let's go."],[2064,2114,"Come on."],[2164,2339,"Sooner we find those journal pages,"],[2339,2398,"the better."],[2427,2569,"I can't spend another second"],[2569,2656,"in this place."],[2927,3236,"You lived down here"],[3236,3370,"in the basement as a kid?"],[3465,3574,"Why would the Reeds"],[3574,3661,"let their own daughter"],[3661,3745,"stay in a place like this?"],[3812,3970,"Because I wasn't their real daughter."],[4083,4179,"I didn't understand"],[4200,4387,"why they tortured me."],[4408,4604,"But they never let me die."],[4692,4754,"So..."],[4796,4917,"I guess a part of me felt that"],[4917,5230,"maybe they felt something for me."]],"51":[[12,75,"It wasn't until"],[75,208,"the High Alpine Pack found me"],[208,304,"that I learned the truth."],[408,633,"They used you to find the relic."],[679,800,"Just like the night"],[800,992,"they used her to destroy my pack."],[1063,1213,"She's never lied to me."],[1313,1376,"That's true."],[1505,1643,"The journal you showed me,"],[1701,1780,"whose is it?"],[1818,1918,"My mother's."],[2056,2193,"My biological mother's."],[2306,2369,"I don't know how the Reeds"],[2369,2502,"ended up with everything."],[2519,2677,"And I still don't know how my mom died."],[3395,3536,"I remember this place"],[3599,3695,"like it was yesterday."],[3766,3832,"Me too."],[4004,4141,"I don't remember every detail."],[4141,4404,"Not after years of torture"],[4404,4546,"and poison,"],[4546,4717,"but the pain,"],[4842,4921,"the fear,"],[5030,5163,"I remember that clearly."],[5180,5317,"Ask her, Dane."],[5355,5505,"Ask if she protected a boy"],[5505,5714,"from Waylon Reed years ago."],[5976,6039,"Aurora."],[6085,6202,"I need to ask you something."]],"52":[[120,171,"Wait."],[187,254,"I see it."],[2093,2356,"Is this what you were looking for?"],[2544,2610,"It is."],[2915,3011,"Let's get out of here."],[3795,3878,"That's weird."],[4095,4162,"What's wrong?"],[4262,4350,"It's locked."],[4408,4512,"We're trapped down here."],[4629,4692,"Move."],[4767,4863,"I'm gonna kick it open."],[5555,5638,"Esther?"],[5722,5818,"What are you doing here?"],[6348,6423,"Aurora."],[6498,6556,"Get down."]],"53":[[300,354,"Hey."],[425,542,"Hey, look at me."],[571,600,"Hey."],[1038,1134,"How pathetic."],[1222,1380,"So many years,"],[1388,1484,"and you're still obsessing"],[1484,1534,"over a man"],[1534,1689,"who hates you in his bone."],[1885,2022,"You just shot an Alpha."],[2064,2131,"If Dane dies,"],[2131,2298,"the Werewolf Council will come for you."],[2302,2389,"He won't die."],[2444,2640,"But as for you, I can't guarantee"],[2640,2840,"that you'll walk out of here alive."],[2911,3028,"What are you talking about?"],[3036,3136,"I've laced the bullet"],[3136,3269,"with Night's Truth Potion."],[3269,3478,"It forces whoever takes it"],[3507,3782,"to act on their deepest desire."],[3849,4099,"The kind they'd only whisper to the night."],[4099,4245,"And we both know that"],[4245,4416,"Dane's deepest desire"],[4416,4642,"is to destroy the girl"],[4642,4888,"who led to the death of both his parents."],[4921,5092,"To kill Ann Reed."],[5438,5538,"You'll all pay"],[5622,5764,"for what you've done to my pack."],[5805,5951,"And I'll be the one to kill you,"],[5985,6068,"Ann Reed."]],"54":[[100,158,"Why don't you just"],[158,312,"kill me yourself, Esther?"],[429,517,"Why bother?"],[583,775,"It's so much more poetic"],[775,988,"to watch the man you love"],[988,1280,"tear you apart with his own hands."],[1313,1476,"You'll find out soon enough."],[1514,1739,"Good luck, dear daughter."],[2790,2869,"Dane,"],[2869,3090,"after everything we've been through,"],[3132,3324,"do you still hate me that much?"],[3807,3853,"Hi."],[4099,4179,"Hey."],[4179,4283,"Get away from me!"],[4404,4633,"You're nothing but a liar and a cheat!"],[4971,5113,"I understand."],[5363,5534,"Dane, if this is who you truly are,"],[5580,5663,"then do it."],[5797,5926,"I won't fight you."]],"55":[[362,567,"I've wanted you for so long, Ann."],[650,846,"I'm so glad you're back."],[1664,1764,"Get away from me."],[1797,1997,"You're nothing but a liar and a cheat."],[1997,2306,"Dane, if this is who you truly are,"],[2373,2460,"then do it."],[2540,2665,"I won't fight you."],[2827,2940,"I won't fight you."],[3553,3624,"I want you."],[3953,4008,"Dane!"]],"56":[[125,225,"Shh...."],[404,492,"I can smell it,"],[517,613,"your arousal."],[759,867,"You want this,"],[934,1021,"just like I do."],[2544,2698,"Fuck, you feel incredible."],[3591,3699,"Tell me you want it."],[3745,4179,"Admit it, Aurora. You want him."],[5030,5150,"You belong to me, Ann."],[5259,5355,"Five years ago."],[5401,5455,"Now."],[5501,5576,"And forever."],[5655,5751,"You're mine, Dane."],[5976,6051,"Say it again."],[6051,6110,"Dane."],[6147,6252,"Say my name."],[6343,6406,"Dane."]],"57":[[529,800,"If the bullet reveals his deepest desires,"],[888,996,"what does this mean?"],[1263,1472,"Ann, I need to ask you something."],[1580,1814,"Did you ever save a boy from Waylon"],[1814,2014,"down here, when you were a kid?"],[2277,2356,"Yes, I..."],[2489,2560,"I did but,"],[2619,2731,"I barely remember it,"],[2731,2861,"it just flashes."],[2998,3057,"I don't know"],[3057,3128,"who I saved."],[3299,3378,"That boy,"],[3503,3574,"was me."],[4212,4312,"All these years,"],[4337,4441,"I thought it was Evelyn."],[4537,4671,"I kept her close,"],[4671,4738,"honored her,"],[4884,4992,"because I thought she was the one"],[4992,5100,"who saved me."],[5196,5296,"But after everything"],[5296,5388,"that happened today,"],[5643,5747,"I know she lied."],[5905,6064,"It wasn't her who saved me."],[6243,6297,"It was you."]],"58":[[796,880,"You brat!"],[892,980,"Let me go."],[980,1146,"Do not get in my way!"],[1180,1255,"Father!"],[1276,1468,"Please, let him go!"],[1659,1747,"Run, Dane!"],[1885,1960,"Run!"],[1960,2052,"I'll go get help."],[2389,2494,"Dane, I saw it."],[2665,2756,"I remembered."],[2902,3007,"But why is it only now"],[3007,3119,"just coming back to me?"],[3148,3282,"Coming back down here"],[3282,3399,"jogged my memory."],[3503,3645,"Maybe it did the same for you."],[3778,4058,"Now, I don't know how I ever thought"],[4058,4283,"Evelyn was the one who saved me."],[4379,4500,"So now that you know,"],[4633,4717,"what are you gonna do?"],[5442,5522,"I'll make sure"],[5559,5684,"what's in our future"],[5684,5784,"is possible."],[6068,6131,"There's something"],[6131,6227,"I need to tell you."],[6519,6644,"Now's the time to finally"],[6644,6835,"tell Dane the twins are his."],[6886,6944,"Dane!"],[7323,7415,"Don't trust her."],[7549,7691,"She confessed everything."],[7811,8108,"This was all part of Aurora's trap."]],"59":[[8,154,"What are you talking about?"],[187,333,"You can stop twisting things."],[333,383,"You're the one"],[383,554,"who's been lying to Dane from the start."],[750,867,"Aurora's right."],[942,1071,"I know the truth now."],[1176,1267,"You lied to me."],[1292,1397,"You claimed to be the one"],[1397,1555,"who saved me all those years ago."],[1630,1718,"But it wasn't you."],[1960,2022,"It was her."],[2423,2652,"Tell me, who are you, really?"],[2681,2802,"And how do you know what happened"],[2802,2894,"in this basement?"],[2986,3261,"Dane, how can you believe her lies?"],[3261,3415,"She's a Reed,"],[3415,3553,"Ann Reed."],[3557,3636,"The same girl"],[3636,3807,"that tricked and betrayed you."],[3807,3920,"Stop it!"],[3978,4124,"Tell me, what else"],[4124,4241,"have you been lying about?"],[4300,4454,"Fine, if you don't believe me,"],[4454,4567,"then listen to her."],[4629,4788,"Esther admitted everything."],[5292,5426,"My dear daughter."],[5442,5601,"Did the love potion work?"],[5709,5855,"What are you talking about?"],[5855,5964,"Sweetheart, don't you"],[5964,6135,"remember our plan?"],[6135,6281,"You wanted to get revenge"],[6281,6498,"for everything that Dane has done to us."],[6535,6669,"Esther, what?"],[6681,6881,"You gave me the love potion,"],[6881,6977,"and you told me to"],[6977,7127,"dip the bullet in it."],[7127,7282,"And then wait for the right moment"],[7282,7386,"to shoot him."],[7386,7570,"So that he would crave you."],[7611,7745,"And obsess over you."],[7745,7920,"I'm so sorry I got caught."],[7920,8124,"What is she talking about, Aurora?"],[8158,8333,"I did what you asked, Daughter."],[8350,8475,"You said you'd take care of me."],[8475,8579,"You promised me."],[8579,8725,"I did what she asked."],[8750,8892,"She wanted revenge."],[8913,9150,"She swore that you'd fall at her feet."]],"60":[[37,196,"Tell him, daughter."],[196,287,"Tell him."],[287,479,"I did exactly what you asked."],[479,638,"She wanted revenge."],[679,950,"She swore that you'd fall at her feet."],[1001,1080,"Dane, listen to me,"],[1080,1163,"she's lying."],[1359,1447,"She's lying."],[1505,1659,"Please tell him, daughter."],[1680,1755,"To let me go."],[1755,1864,"You promised me."],[2686,2865,"If you still can't trust me,"],[3111,3190,"then I'll disappear"],[3190,3299,"from your life for good."],[3520,3678,"I need to get away from you now,"],[3749,3820,"before I do something"],[3820,3928,"we'll both regret."],[4491,4571,"Of course."],[4604,4725,"Just like always."],[4750,4879,"When it comes to Evelyn,"],[4900,5050,"he'll never choose me."],[5288,5501,"There, there, dear daughter."],[5543,5722,"You should have known better."],[5768,6035,"A man may say sweet words,"],[6035,6256,"but it's his actions that count."],[6297,6610,"He chose Evelyn the way he always does."]],"61":[[41,275,"Don't you dare touch me."],[437,613,"Take one more step"],[613,850,"and I will shoot you full of silver."],[980,1105,"You're looking at me"],[1105,1355,"just the way your mother looked at me."],[1393,1568,"Just before I killed her."],[1735,1839,"You killed her?"],[1918,2052,"What if I did?"],[2068,2185,"What do you care?"],[2235,2389,"She sold you to me"],[2389,2581,"like a sack of flour."],[2581,2819,"But flour would have been more useful."],[2836,2982,"No, my mother didn't sell me."],[2982,3111,"She wouldn't have done that."],[3140,3278,"You didn't know her."],[3278,3374,"I did."],[3374,3541,"She was a strung out junkie"],[3541,3774,"and she didn't give a damn about you."],[3866,4091,"Now, give me the relic."],[4371,4475,"If you want it,"],[4717,4808,"come and get it."]],"62":[[41,112,"I'll do it."],[158,254,"I'll shoot you."],[383,487,"Just calm down."],[684,796,"Then at least"],[925,1034,"tell me the truth"],[1034,1134,"about my mother."],[1230,1409,"Why did you hate her so much?"],[1426,1639,"Tell me before I lose my patience."],[1755,1843,"You're, you're right."],[1864,2002,"Your mother didn't sell you."],[2085,2339,"We stole you out from under her."],[2373,2736,"She was Luna of the High Alpine Pack"],[2736,2936,"and she had the relic."],[2952,3094,"We couldn't let her use it."],[3123,3399,"So we robbed her and we just took you."],[3461,3549,"I knew it."],[3549,3687,"I knew my mother wouldn't have"],[3687,3853,"sold me to these monsters."],[4020,4162,"So did you really kill her?"],[4200,4304,"Not exactly."],[4325,4429,"Waylon was the one"],[4429,4612,"who ripped her throat out."],[4637,4738,"But I was there."],[4800,4929,"She was trying to save you"],[4929,5021,"and we couldn't let her."],[5438,5643,"You stood there and watched her die?"],[5643,5730,"I'm going to stop you"],[5730,5818,"just like I stopped her."],[5818,6001,"You took everything from me!"]],"63":[[0,191,"Please spare me."],[442,575,"Like you spared my mother?"],[638,750,"I don't think so."],[2318,2448,"My wolf is back."],[2485,2619,"Esther is dead."],[2656,2806,"And I finally know the truth"],[2806,2890,"about my mother."],[3999,4108,"The true power rests"],[4108,4250,"inside the chosen one."],[4287,4487,"The High Alpine Luna Heiress."],[4537,4708,"With the necklace in her possession,"],[4742,4909,"the power is activated."],[4954,5071,"And the Luna Heiress"],[5092,5176,"becomes..."],[5317,5405,"the relic."],[7882,7995,"I can't believe it."],[8274,8433,"That must be how I saved Dane."],[8487,8633,"I am the relic."]],"64":[[688,792,"Are you okay, Aurora?"],[846,934,"You've been so quiet"],[934,992,"since coming back"],[992,1067,"from the Reed house."],[1530,1701,"I'm sorry to say, I have some news"],[1701,1760,"that's going to make it"],[1760,1872,"a little more complicated."],[2827,2977,"And you're sure this is legit?"],[3128,3215,"It's legit."],[3278,3449,"I had my people triple check it."],[3578,3670,"I knew it."],[3766,3916,"Evelyn is Esther's daughter."],[3966,4137,"She's the true Reed Heiress."],[4166,4287,"All this time."],[4404,4546,"It all makes sense now."],[4621,4750,"That's how she knew that the Reeds"],[4750,4838,"once kidnapped Dane"],[4838,4925,"when he was a kid."],[4979,5088,"The Reeds are scum."],[5134,5271,"Always have been."],[5305,5388,"At least now we know"],[5388,5488,"why Evelyn has always been"],[5488,5630,"so invested in coming after you."],[5809,5893,"But I don't think she's"],[5893,6031,"just doing this for revenge."],[6143,6272,"She's after something bigger."],[6364,6452,"My guess?"],[6527,6635,"Securing her place"],[6635,6769,"as head of the Council."]],"65":[[29,166,"But Connall is the head of Council."],[462,533,"Oh my God."],[763,892,"Connall's in danger."],[1772,1918,"You always remind me"],[1918,2127,"why I should never trust anyone."],[2185,2285,"Everyone's a liar,"],[2293,2444,"for the right price."],[2469,2627,"You're my true mate."],[2698,2877,"I'll do anything for you, Evelyn."],[2902,2990,"Anything."],[3082,3319,"And you're my perfect little weapon."],[3620,3766,"He's going to help me get rid of"],[3766,3945,"everyone standing in the way"],[3945,4104,"of me ruling every"],[4104,4400,"werewolf pack in existence."]],"66":[[596,738,"All I dream about is that"],[738,863,"night in the dungeon."],[975,1134,"Did Evelyn really save me?"],[1217,1343,"Or was it Aurora?"],[1484,1609,"Trust Aurora."],[1639,1751,"She's your mate."],[1751,1856,"I can feel it."],[1964,2068,"Then that means..."],[2173,2277,"it's true that Evelyn's"],[2277,2377,"been lying to me."],[2464,2535,"But why?"],[2744,2915,"Unless she really is a Reed."],[4346,4404,"No."],[4416,4496,"No way."],[4600,4704,"She's one of them."],[4746,4838,"She's a Reed."],[4967,5196,"The Reeds never stopped hunting us."],[5217,5309,"All this time."],[5363,5526,"She never wanted to be my Luna."],[5559,5709,"She wanted to replace Aurora."],[5747,5834,"To erase her."],[5880,6060,"She's a Reed Assassin."]],"67":[[884,1055,"Ester and Waylon's daughter."],[1055,1176,"It wasn't Ann."],[1205,1359,"It was Evelyn all along."],[1384,1501,"The perfect spy."],[1555,1685,"The perfect killer,"],[1735,2056,"and now, she wants the perfect crown."],[2544,2610,"Dane."],[2644,2761,"You finally came to see me."],[3132,3228,"What are you doing?"],[3228,3319,"Let go of me!"],[3340,3516,"Give up the act, Evelyn."],[3553,3603,"Or should I say,"],[3603,3707,"Evelyn Reed?"],[3774,4020,"You're the filthy little Reed brat!"],[4020,4112,"Not Ann!"],[4283,4387,"You lied to me!"],[4433,4608,"Every damn second!"],[4729,5009,"So, you finally figured it out."],[6252,6293,"What"],[6373,6443,"did you do?"]],"68":[[325,400,"Plan B."],[492,633,"That was a love potion."],[975,1213,"And anyone who inhales it"],[1238,1488,"falls madly in love with me."],[1668,1906,"Customized just for you."],[2706,2886,"So what if you know the truth, Dane?"],[2952,3078,"You're still mine."],[3136,3453,"My little, loyal puppet."],[3749,4033,"Sweetheart, let's get married."],[4162,4521,"I want a big, beautiful wedding."],[4654,4854,"Whatever you want, my love."]],"69":[[404,554,"Now that Dane is our puppet,"],[600,717,"everything is in place."],[759,892,"When the Blue Ridge are dead,"],[996,1155,"the Council will be ours."],[1276,1384,"As soon as we get in touch"],[1384,1468,"with your mother,"],[1468,1589,"she'll give us the relic."],[1614,1747,"And then, together,"],[1747,1889,"we will rule the Council"],[1901,2056,"and all of werewolf kind!"],[2147,2260,"You're almost right."],[2765,2840,"Almost?"],[4008,4137,"Sorry, Archer baby."],[4179,4320,"But you know too much."],[4362,4496,"And I don't need you anymore."],[4867,5030,"I'm gonna rule the werewolves"],[5030,5221,"all on my own."]],"70":[[375,421,"Oh!"],[421,575,"You look gorgeous! - You look beautiful."],[575,646,"Oh my gosh."],[646,692,"Thanks."],[742,921,"I have no idea - Can you believe it?"],[921,1013,"how any of us"],[1013,1121,"are supposed to compete."],[1188,1338,"I'm so happy for you, girl."],[1380,1459,"You won."],[1493,1572,"And now,"],[1597,1714,"you're going to show everyone"],[1714,1868,"you can't be fucked with."],[2765,2873,"Did you bring the poison?"],[3069,3211,"Be careful with this."],[3269,3478,"A little dab on the glove will do."],[3557,3782,"It's very potent."],[3866,3933,"Good."],[3953,4054,"It better be."],[4066,4149,"Now go."],[4208,4329,"I have to finish getting ready."],[4796,4938,"I've gotta look perfect"],[4938,5217,"when I take over all of werewolf kind."],[5780,5918,"Everyone, leave us."],[5976,6047,"I'll see you out there."]],"71":[[112,342,"So, have you heard from mom yet?"],[371,533,"And did you get rid of Aurora's body?"],[646,800,"We didn't find Aurora's body."],[855,963,"And uh,"],[963,1222,"but, but, but, but we did find Mom's."],[1276,1430,"She looks like she's been dead"],[1430,1584,"for a long time."],[1618,1689,"What?"],[1710,1851,"Mom's dead."],[1868,2052,"And Aurora's nowhere to be found."],[2052,2306,"This is all gonna blow up in your face"],[2306,2473,"and I want no part of it."],[2473,2773,"Then go before I kill you, you coward!"],[3978,4149,"The show must go on."],[4191,4391,"And once I bring down Connall,"],[4471,4642,"I'll be the last one standing."]],"72":[[934,1105,"Who's that girl in that white dress?"],[1530,1685,"I don't know why you insisted on"],[1685,1755,"coming here."],[1797,1906,"It's not safe for you,"],[1935,2035,"or the twins."],[2077,2306,"I had to see Dane one last time."],[2435,2527,"I have to make sure"],[2527,2669,"nothing happens to Connall."],[2719,2861,"He's always been on my side."],[2882,2977,"And I have a feeling"],[2977,3107,"Evelyn's up to something."],[3107,3294,"Connall is Dane's responsibility."],[3340,3445,"Not yours."],[3445,3549,"It's time for the two of us"],[3549,3762,"to focus on our own life."],[3849,3916,"Together."],[5338,5476,"I'm here for my grandson."],[5534,5618,"And that's it."],[5697,5922,"Then take my hand, old man."],[5960,6031,"It's time for me"],[6031,6147,"to become part of the family."],[6748,6881,"Too bad you'll be dead"],[6881,7057,"before I take what's mine."]],"73":[[0,271,"The witch said this poison is potent."],[271,529,"So why isn't the old coot dead yet?"],[1380,1568,"Dane looks damn good."],[1593,1676,"Too bad I'm about to"],[1676,1851,"take everything he has."],[1876,2039,"As soon as I find Aurora,"],[2060,2264,"that bitch will suffer worst of all"],[2264,2402,"for my mother's death."],[2506,2619,"Mommy, who's that girl"],[2619,2736,"in the white dress?"],[2765,2877,"Is she marrying Dane?"],[2877,2998,"I don't like her."],[3040,3190,"She's a bad lady,"],[3190,3328,"I can feel it!"],[3328,3474,"Dane's acting strange."],[3474,3607,"He's not himself."],[3657,3807,"Dane, wake up, wake up!"],[3807,3916,"Dane, wake up! - Dane, wake up!"],[3920,4074,"Wake up! - Wake up, wake up."],[4074,4187,"Dane wake up! - Wake up."],[4287,4400,"What am I doing here?"],[4491,4846,"We are gathered here today to witness"],[4846,5138,"the Moon Goddess' blessed matrimony"],[5150,5522,"of Dane Montague and Evelyn Barclay."],[5676,5860,"Why aren't you dead, old man?"],[6335,6435,"I'm sorry, sir."],[6435,6531,"Don't you mean,"],[6589,6715,"Evelyn Reed?"],[7240,7378,"What did you just say?"],[7378,7486,"You heard me, Evelyn."],[7532,7640,"You're Esther"],[7682,7849,"and Waylon Reed's daughter."],[7899,8170,"The true Reed family heiress."]],"74":[[20,166,"What are you talking about, Dane?"],[191,442,"I'm not part of the Reed family."],[717,863,"She's a Reed!"],[1163,1267,"She's plotting to"],[1267,1422,"destroy the Blue Ridge,"],[1422,1597,"kill Dane and Connall."],[1597,1751,"And take over the Council!"],[1751,1881,"He's a liar!"],[1881,1964,"Nobody listen to a word"],[1964,2139,"this filthy Beta says."],[2227,2352,"I'm telling the truth."],[2369,2615,"I helped her because she was my mate."],[2652,2752,"And I loved her."],[2815,3003,"I tracked all of Dane's movements."],[3040,3244,"I did everything she asked me."],[3278,3424,"And how did she thank me?"],[3532,3670,"She tried to kill me."],[3687,3782,"Lies!"],[3908,3991,"It's true!"],[4024,4145,"She hired me"],[4145,4312,"to provide a love potion"],[4337,4596,"and a poison to kill Connall."],[4629,4892,"But the poison I gave was just water."],[5059,5372,"You disgusting murderess!"]],"75":[[50,100,"Ah!"],[179,325,"Evelyn, oh my God."],[358,425,"Girls."],[1059,1238,"You think you can ruin me?"],[1242,1480,"You rats, snakes, and vultures!"],[1514,1693,"You shattered my plan!"],[2102,2152,"What?"],[2177,2318,"And do you think this is over?"],[2327,2419,"Oh no,"],[2464,2660,"this has only just begun."],[2723,2982,"And you, Aurora."],[3044,3199,"You did this!"],[3236,3332,"And you will pay."],[3332,3503,"You will all pay!"],[3541,3737,"None of you will be able to stop me."],[3737,3845,"And the Reed family"],[3845,4099,"will finally get what's theirs!"],[4204,4325,"Someone get her out."],[4325,4383,"Now!"],[4604,4713,"Back the fuck up."],[5238,5355,"See these little rats,"],[5388,5580,"Dane? They're your children."],[5588,5705,"And that's the truth."],[5705,5897,"It was another one of Aurora's lies."],[5930,6131,"And they are finally"],[6131,6385,"gonna pay for what you both did."],[6406,6477,"No!"],[6493,6581,"My children!"],[7378,7415,"Daddy!"],[7419,7570,"Daddy!"]],"76":[[208,325,"No, no, no, no, hey!"],[358,396,"Hey."],[404,483,"Dane, wake up."],[513,563,"Wake up."],[563,633,"Please wake up."],[633,696,"Wake up."],[721,767,"Hey."],[838,892,"Hey."],[971,1017,"Dane?"],[1255,1347,"I'll kill you!"],[2118,2231,"Nice try, bitch."],[2256,2323,"But I win."],[2439,2569,"You'll pay for this."]],"77":[[229,325,"Hey."],[400,513,"Please, please,"],[513,617,"don't leave me, Dane."],[617,738,"Please don't leave me."],[2356,2452,"Come back to me."],[3265,3407,"Don't cry,"],[3445,3532,"beautiful."],[3574,3636,"Dane."],[3657,3770,"It's gonna be all right."],[3816,3916,"You're alive."],[4212,4458,"How did you do that?"],[4483,4567,"I should be dead."],[4587,4746,"I've got my wolf back"],[4775,4904,"and the, the relic."],[4904,5142,"It's... It's inside of me."],[5292,5347,"I think that's how"],[5347,5488,"I brought you back to life."],[5672,5747,"My savior,"],[5797,5885,"once again."],[5976,6193,"I'm sorry for ever doubting you."],[6385,6452,"I love you."],[6573,6777,"I always have,"],[6961,7082,"and always will."],[7190,7565,"Aurora, High Alpine Pack Heiress."],[7682,7903,"As Luna Heiress, whoever I choose"],[7903,8058,"will become the Alpha King."]],"78":[[33,162,"You really are - You really are"],[162,229,"our daddy? - our daddy?"],[337,408,"I really am."],[408,479,"Woah."],[1159,1280,"Follow your heart, Aurora."],[1493,1605,"I want you to be happy."],[2285,2414,"Thank you,"],[2414,2494,"for everything."],[3912,4095,"My whole life, I loved you."],[4183,4337,"Even when you turned away,"],[4454,4642,"when you believed every lie about me."],[4796,4938,"I waited, Dane."],[5088,5288,"I waited and it almost broke me."],[5397,5476,"I was blind."],[5547,5784,"I let hatred and anger ruin everything."],[5839,5935,"I thought I was protecting"],[5935,6093,"myself, my pack."],[6197,6339,"But the only thing I've ever done"],[6339,6418,"was hurt"],[6502,6594,"the only woman"],[6594,6685,"I've ever loved."],[6890,6981,"I'm so sorry."],[7132,7361,"My heart has always belonged to you."],[8612,8754,"I love you, my Alpha King."],[8821,8979,"I love you, Aurora."],[9046,9184,"And I love our kids,"],[9296,9538,"and I will never let you go ever again."]]}