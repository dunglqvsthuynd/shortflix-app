{"1":[[724,864,"Don't worry, I'll take care of you."],[867,947,"One second."],[990,1087,"No training for the"],[1087,1254,"next several days, okay?"],[2188,2449,"We came here to invite you, a rogue"],[2449,2619,"into the Dark Moon Pack."],[2659,2786,"Why'd you have to go so far?"],[2812,2999,"Because I have no interest in running"],[2999,3106,"with a pack of human"],[3106,3229,"slaughtering wolves like you."],[3303,3480,"I sense our mate."],[3876,4107,"Rogue spotted in the eastern forest."],[4124,4331,"All Dark Moon Pack stay alerted."],[4466,4589,"Is everything okay?"],[5290,5393,"My mate?"],[5431,5510,"You're injury!"],[6264,6383,"I heard there was an attack in the"],[6383,6495,"eastern forest."],[6567,6750,"Did you run into Rogue Xavier?"],[7023,7137,"Do you have any"],[7137,7285,"discomfort in your chest?"],[8200,8300,"You're not afraid of me?"],[8461,8552,"I'm a doctor."],[8629,8703,"Usually it's me that the"],[8703,8856,"patients are afraid of."],[10502,10673,"Is Rogue Xavier after you?"],[10756,10858,"Do you know him?"],[10952,11064,"He's a rogue Alpha."],[11064,11164,"I heard he's brutal."],[11271,11359,"You should be careful."],[11385,11491,"Afraid of him?"],[11567,11622,"No."],[11733,11897,"He wouldn't go so far as to hurt me."],[12302,12395,"Where are you going?"],[12482,12669,"Alpha Xavier, I'm sorry."],[12775,12879,"He got away."],[12962,13125,"You are Rogue Xavier?"]],"2":[[0,153,"You are Rogue Xavier?"],[633,940,"Xavier’s not after me... He’s after you."],[1688,1851,"What the hell is wrong with you?"],[1925,1988,"What’s your name?"],[2092,2188,"It's none of your business."],[2272,2352,"I should learn the name"],[2352,2425,"of my future bride,"],[2469,2519,"shouldn’t I?"],[2629,2729,"You're insane."],[2989,3159,"Find out everything you can about her."],[3346,3400,"Yes, Alpha."],[3536,3683,"Alpha, so many she-wolves"],[3683,3777,"are trying to get with you..."],[3793,3993,"Why her? She doesn't even own a wolf."],[4250,4284,"Because..."],[4454,4504,"she's my mate."],[4701,4764,"And the only woman"],[4764,4848,"that's not afraid of me."],[5435,5482,"Hey."],[5502,5638,"These are herbs that I found today."],[5638,5819,"They'll help you recover from your training."],[6329,6409,"What's wrong?"],[6599,6673,"Did something go wrong"],[6673,6773,"at the Pack Council?"],[6776,6876,"I didn't make it to..."],[6976,7100,"the Council today... I couldn't afford."],[7100,7153,"Your hard work is"],[7153,7247,"gonna pay off eventually."],[7387,7450,"I can give you"],[7450,7584,"everything I made from the clinic."],[7584,7654,"And if it's not enough,"],[7654,7731,"I'll borrow more."],[8148,8248,"I'm so lucky."],[8591,8708,"When things get settled down,"],[8708,8828,"we'll hold the marking ceremony."],[8905,8935,"Nice."],[9009,9059,"Of course."],[9796,9856,"Alpha,"],[9906,9949,"we've got"],[9949,10056,"the werewolf that ran away."],[10056,10126,"What should we do?"],[10600,10737,"Anyone who breaks the peace pact"],[10737,10904,"between wolves and humans..."],[10904,11000,"handle them by the rules."],[11201,11304,"This is everything on Isla."],[11975,12038,"We leave tomorrow."],[12132,12242,"To meet with the Dark Moon Alpha?"],[12322,12365,"No."],[12569,12716,"To meet the most important person."],[12896,13109,"My mate, Isla."]],"3":[[193,320,"All right, here's your medicine."],[767,840,"How charismatic..."],[1037,1101,"Who is that?"],[1151,1317,"He seems more intense than our Alpha!"],[1384,1431,"Doctor,"],[1611,1701,"your assistance is here."],[3293,3363,"Go on a date with me."],[3460,3550,"I don't have time to"],[3550,3683,"waste on people like you."],[3683,3780,"I have patients to treat."],[3833,4027,"Exactly! She's not going anywhere."],[4524,4624,"This will heal you instantly."],[4657,4741,"Take it and go."],[5125,5238,"This is a sacred remedy!"],[5315,5398,"Not even our own alpha"],[5398,5508,"has access to this!"],[5565,5699,"Hey, what about us?!"],[5712,5832,"What are we supposed to do?"],[5912,5955,"Everyone,"],[5955,6062,"take whatever you need and leave."],[6079,6162,"We're not hurting anyone."]],"4":[[233,306,"What do you want?"],[433,520,"I just want to spend a little bit"],[520,647,"more time with you."],[777,860,"Leave the box here."],[880,934,"Yes, Alpha."],[1618,1765,"I need to keep my distance from you."],[2452,2569,"Stop following me."],[2609,2706,"I don't like you."],[2706,2806,"And I already have a mate."],[2806,2862,"Yeah, I know."],[2939,3006,"It's me."],[3066,3129,"No, it's not."],[3143,3226,"Stop bothering me."],[3296,3380,"Who is he?"],[3456,3526,"Have you two mated?"],[3583,3720,"Shameless asshole!"],[3770,3793,"Okay."],[3827,3987,"If you keep bothering me,"],[3987,4110,"I'll bite your damn neck off."],[4260,4300,"Ah—!"],[4437,4521,"Get off!"],[4774,4854,"We’ll see about that."],[5291,5438,"Careful, don’t knock anything over."],[5592,5668,"Who’s this generous?"],[5719,5932,"Sending so many gifts to an Omega’s house?"],[6206,6529,"Oh thank you so much and please"],[6529,6723,"thank Benny for me."],[6723,6956,"He's so thoughtful."],[7030,7113,"Actually..."],[7487,7687,"Why is Xavier’s assistant in my house?"],[7837,8004,"What are you all doing here?"]],"5":[[16,143,"Um, what are you all doing here?"],[210,300,"Alpha just wanted to show"],[300,430,"his Luna that he loves her."],[430,570,"And he delivered these gifts for her."],[600,860,"No, please stop bringing stuff in. And get out!"],[1271,1488,"Benny treats you so well."],[1574,1788,"Jewelry, herbs,"],[1818,1925,"we brought everything in"],[1925,2078,"the room already for you."],[2132,2322,"Grandma, it's not like that, okay?"],[2322,2612,"Just please don't touch the boxes for now."],[2832,2912,"Isla?"],[3213,3249,"Benny!"],[3286,3460,"Isla, what is the rush?"],[3483,3656,"Let's hold the ceremony tomorrow, okay?"],[3690,3853,"What? Wait, are we gonna wait until"],[3853,3937,"everything's settled down?"],[4718,4814,"Whoa."],[4908,5071,"Oh my gosh, it's a blood moon crystal."],[5211,5315,"Nobody in all three packs can"],[5315,5398,"afford one of those."],[5568,5689,"I'll buy you one one day."],[5712,5912,"No, I don't care about any of that stuff."],[5962,6042,"Isla, meeting you..."],[6196,6346,"it's a blessing from the Moon Goddess."],[6399,6523,"Then listen to me."],[6556,6740,"Let's hold the ceremony soon."],[6756,6860,"No more delays, okay?"],[7047,7207,"Alright. Alright, yeah,"],[7207,7330,"I'll go talk to my dad."],[7514,7847,"Wow. Alright, cool, I'll go talk to him."],[7854,7947,"No way."],[8044,8144,"That wolfless girl,"],[8271,8435,"she doesn't deserve a Beta like you."],[8578,8768,"Dad, I've only been able to hold on to my"],[8768,8928,"Beta position these last few years"],[8928,9049,"because of the money"],[9049,9329,"that Isla has given me."],[9366,9512,"Nonsense. You should have"],[9512,9672,"went after an Alpha's daughter."],[10093,10226,"Stop daydreaming."],[10226,10427,"An Alpha's daughter is never gonna want me."],[10487,10530,"Alright?"],[10727,10807,"It is what it is."]],"6":[[413,507,"Benny is not coming."],[577,647,"Why would a Beta"],[647,797,"choose a wolf-less woman?"],[1054,1161,"I'm sure he'll show up."],[1444,1494,"Stop."],[1601,1725,"I've arranged a meeting for you"],[1778,1881,"with Alpha Drakar's daughter."],[2005,2118,"She hasn't found her mate yet."],[2235,2332,"An Alpha's daughter?"],[2872,2969,"What if she doesn't like me?"],[2986,3166,"She's a wolfless Omega."],[3383,3606,"You can be sweet to her anytime you want."],[4227,4347,"Alright, yeah. You're right."],[5665,5785,"Are the gifts ready?"],[5872,5912,"Yeah."],[6016,6142,"You almost bought out all three packs."],[6389,6443,"Alpha."],[6569,6743,"Isla's starting the marking ceremony."],[6800,6920,"Trying to steal my mate?"],[6993,7130,"Go to hell."],[7554,7734,"We've been waiting for two hours."],[7791,7974,"Looks like Benny is having second thoughts."],[8011,8164,"What a waste of time."],[8201,8284,"Let's go."],[8334,8471,"The ceremony's not happening."],[8531,8712,"The ceremony will begin soon."],[8748,8825,"Don't worry."],[9089,9195,"I know where Benny is."],[9289,9402,"Come with me."],[10577,10707,"Benny is waiting for you."],[10764,10827,"Benny?"]],"7":[[56,163,"Benny is waiting for you."],[240,310,"Benny?"],[550,647,"Hey, let me out!"],[1087,1247,"Young and full of energy."],[1301,1461,"Just as I expected."],[1471,1675,"Damn, your aunt was right."],[1761,1801,"Alpha."],[1851,1871,"And..."],[2055,2222,"Mating with you will extend my life."],[2222,2272,"No!"],[2382,2479,"I already have a mate."],[2605,2689,"So what?!"],[2716,2946,"Mating with me, an Alpha,"],[2946,3063,"is an honor."],[4187,4414,"All these evil things you do,"],[4547,4661,"you aren't afraid the Moon Goddess"],[4661,4784,"will punish you?"],[5135,5288,"Are you kidding me?"],[5318,5392,"Right here."],[5478,5642,"The Moon Goddess loves me."],[5759,5865,"Now when you're dead,"],[5985,6149,"you can tell her I was the"],[6149,6453,"one who sent you to the heavens."],[6736,6813,"No entry."],[8258,8411,"I'm fucking hungry right now."],[8611,8748,"You stupid bitch!"],[8782,8905,"Mating with me, an Alpha,"],[8905,9105,"is an honor, alright?"],[9416,9622,"Benny, where are you?"],[9686,9773,"Stop!"]],"8":[[20,90,"Stop!"],[160,306,"How dare you touch her!"],[1051,1141,"Who the hell are you?"],[1157,1294,"How dare you touch my Luna!"],[1454,1521,"Xavier?"],[1591,1745,"If you want her, take her."],[1765,1998,"See, what do you really need to fight?"],[2018,2118,"She's just an Omega."],[2195,2429,"Work with me to unite the forests."],[2429,2619,"You can have any fucking woman you want."],[2652,2802,"I'm too good for you to work with me."],[3069,3279,"Fucking rogue! How dare you!"],[3423,3493,"Take him away!"],[3583,3780,"Her aunt is the one who gave her to me."],[3807,3873,"If you want someone,"],[3873,3980,"go after her!"],[4047,4140,"Oh, fuck!"],[4454,4551,"You bastard?!"],[4551,4711,"Do you even know who he is?"],[4768,4861,"He's the Alpha of"],[4861,4961,"the Dark Moon Pack!"],[5015,5131,"I'm supposed to be scared of him?"],[5211,5275,"That's the rogue"],[5275,5398,"even the Alphas fear..."],[5468,5702,"Is he here to attack the Dark Moon Pack?"],[5759,5972,"He's that lunatic who killed an Alpha!"],[5972,6159,"Why is he holding an Alpha-less Omega?"],[6236,6393,"Isla is my mate."],[6443,6613,"What?! Isla has two mates?"]],"9":[[16,120,"How's that even possible?"],[183,300,"Isn’t Benny Isla’s mate?"],[300,380,"Does Benny know?"],[400,640,"No... I'm not your mate. I have Benny."],[780,837,"This is fate."],[920,1071,"Benny can't protect you. Only I can."],[1167,1277,"You will die!"],[1451,1551,"How dare you..."],[1571,1671,"Alpha,"],[1671,1788,"they ruined your plan"],[1788,1971,"and attacked me on your land!"],[1998,2138,"They don't respect you."],[2165,2208,"Shut up!"],[2305,2395,"She's the one who sent"],[2395,2495,"Isla to my bed."],[2562,2632,"You said,"],[2642,2772,"mating with Isla will slow"],[2772,2846,"your aging,"],[2872,2959,"that's why I..."],[2989,3079,"Stupid bitch!"],[3143,3189,"Alpha,"],[3266,3360,"what should we do with them?"],[4064,4197,"Take away his ability to mate."],[4210,4307,"Touching my Luna?"],[4351,4451,"It can be a lot worse."]],"10":[[347,457,"Isla is my mate."],[597,734,"I promise you to protect her."],[2429,2522,"I came here tonight to"],[2522,2622,"ask Isla to be my Luna."],[2665,2926,"If she agrees, no wolf from"],[2926,2996,"any of the Three Packs"],[2996,3086,"will ever harm you."],[3126,3216,"She agrees!"],[3216,3350,"We'll hold the ceremony tonight!"],[3436,3586,"Becoming Xavier's Luna is"],[3586,3737,"a once-in-a-lifetime blessing."],[4284,4387,"I raised Isla!"],[4417,4617,"Her decisions are mine to make."],[4678,4828,"You sold Isla for money,"],[4874,5078,"and you think you have a say in this?!"],[5195,5348,"I swear I won't do it again."],[5562,5642,"Luna!"]],"11":[[10,236,"Grandma, grandma these gifts are for you."],[313,513,"Isla should make her own decision on"],[513,633,"which mate she wants."],[684,804,"Thank you for saving me..."],[804,907,"But Benny is my mate."],[1000,1231,"I can work for you to repay the favor."],[1428,1474,"Fine."],[1658,1708,"Work for me."],[1941,2078,"Well... The Luna position"],[2078,2128,"is still open."],[2328,2499,"No! Put me down!"],[2822,2882,"Put me down."],[3176,3259,"So tell me,"],[3293,3410,"what do you want to do for work?"],[3463,3550,"I can treat your people..."],[3550,3683,"I can give you all the medicine I have."],[3833,3927,"You think I need medicine?"],[4144,4237,"Then what do you want?"],[4237,4367,"I don't know anything else."],[5241,5358,"You know exactly what I want."],[5638,5762,"There are she-wolves everywhere"],[5762,5872,"who would die to be with you."],[5892,6022,"You don't need to mess with me."],[6256,6543,"Because... you are my mate."],[8938,9065,"Stay with me for 24 hours."],[9135,9169,"What?"],[9249,9429,"Stay with me for 24 hours."],[9552,9672,"That'll be enough as repaying me."],[9959,10003,"Stop."],[10133,10200,"You’re in my bed."],[10390,10483,"If you keep moving around"],[10483,10637,"I can’t guarantee what’ll happen next."]],"12":[[1244,1348,"Xavier, that's enough."],[1348,1414,"Stop buying stuff!"],[1488,1604,"Well, you agreed to be my Luna."],[1745,1811,"So I made the calls."],[2295,2405,"I'm gonna grab something."],[2442,2489,"I'll be back."],[3293,3380,"You have great taste."],[3410,3570,"That piece is limited edition."],[3616,3703,"You should try it."],[3793,3970,"That's okay, I'm not interested in it."],[3970,4110,"Oh no, it'll look great on you."],[4240,4304,"Look. See?"],[4381,4554,"There's normally a waitlist,"],[4554,4771,"but this costs one million dollars."],[4771,4861,"Oh, no, no."],[4911,5091,"Once you wear it, you pay for it."],[5091,5228,"But you made me try it on."],[5268,5395,"Stop whining, and pay up."],[5452,5498,"Ouch..."],[5512,5598,"You're pulling my hair."],[5642,5702,"Stop it."],[5949,6022,"You broke it."],[6029,6152,"No, you're the one who broke it."],[6162,6282,"You're the one that was wearing it."],[6363,6449,"Stop denying-"],[6563,6606,"I'll pay."],[7227,7357,"Wait, what are you doing?"],[7384,7490,"Is that enough for a necklace?"],[7537,7637,"We'll take a few more things."],[7924,8007,"How much for this hand?"],[8565,8678,"So? Hand or foot?"]],"13":[[263,400,"Maybe you should be a little nicer."],[447,527,"Get rid of her."],[824,890,"We're kind wolves."],[934,1097,"Please kindly escort her..."],[1097,1221,"to meet with the Moon Goddess."],[1658,1725,"Try this on."],[1865,1928,"I'll wait here."],[3420,3506,"Luna!"],[3833,3933,"This is...?"],[3950,4127,"Luna, this is our future pack's home."],[4220,4320,"So other than this hall,"],[4354,4461,"there's twenty more rooms,"],[4461,4624,"a basement, and a clock tower."],[4738,4841,"I can't believe the"],[4841,4961,"Alpha brought a woman back."],[5031,5101,"Who is she?"],[5168,5241,"And how did she"],[5241,5372,"catch the Alpha's eyes?"],[5525,5635,"I can show you around."],[5752,5802,"I'm good."],[5959,6046,"Don't be so serious."],[6116,6259,"Tonight, you belong to me."],[6750,6806,"Care to dance?"],[7063,7113,"I'm scared..."],[7887,7954,"Scared of what?"]],"14":[[4000,4067,"I have to go."],[5008,5141,"Isla."],[5238,5412,"Isla… I had my reasons."],[5425,5512,"You had your reasons?"],[5542,5605,"Reasons for missing"],[5605,5705,"our marking ceremony?"],[5709,5775,"It was my dad."],[5879,5905,"Okay?"],[5905,6082,"He threatened to kill himself"],[6082,6259,"if I didn't go see the Alpha's daughter."],[6299,6383,"So you went?"],[6449,6553,"What was I supposed to do?"],[6636,6710,"Let him die?"],[6783,6866,"I mean, he had a"],[6866,7000,"silver dagger in his hand."],[7043,7163,"You know, I think your dad's right."],[7297,7420,"We shouldn't see each other anymore."],[7550,7701,"No, no, no, no, no."],[7701,7734,"No."],[7824,7951,"Please, I mean, I saved your life."],[8007,8131,"One more chance, please."],[8221,8251,"Okay?"],[8351,8508,"I mean, remember six years ago?"],[8615,8735,"In the South Forest,"],[8735,8845,"I ran in there"],[8845,8998,"without a second thought."],[9305,9436,"Isla, come on."],[9492,9549,"Come on."],[9639,9726,"Come on!"],[9759,9809,"Let's go."],[9869,10036,"I mean, I thought I could die."],[10046,10250,"I wouldn't go out without my life"],[10250,10340,"if I knew you were safe."],[10393,10527,"What if your dad still doesn't agree?"],[10533,10643,"There is hope."],[10677,10730,"You're my mate."],[10784,10994,"You're my lover, and if he doesn't agree,"],[10994,11191,"I'm happy to live as a rogue."],[11688,11798,"He forbade me from coming."],[11798,11895,"I forced my way out."],[11935,12058,"You're trying to get yourself killed?"],[12075,12165,"I had to see you."],[12232,12325,"Nothing else mattered."],[12399,12525,"You say you want to go to a bar?"],[12732,12789,"Let's go tonight."],[13697,13980,"Xavier. Your fiancée is here."]],"15":[[166,270,"Did you need something?"],[310,410,"Can’t I just miss you?"],[410,473,"I mean, you haven't"],[473,607,"sent any messages to me"],[607,754,"or my mother at the Scarlet Wolf pack."],[810,890,"Didn't your mother hire"],[890,1031,"someone to keep tabs on me?"],[1144,1247,"Did he not report back?"],[1321,1398,"Xavier, you know it's"],[1398,1501,"not like that with my mom."],[1501,1661,"She just wants us to mark soon."],[1851,2052,"That was her wish, not mine."],[2065,2088,"What?"],[2359,2445,"Tell her if she ever pulls"],[2445,2539,"anything like that again,"],[2575,2712,"I won't be so nice."],[3566,3653,"So... what else do we"],[3653,3737,"have planned this evening?"],[3770,3860,"Another human was"],[3860,3930,"murdered by a werewolf"],[3930,4047,"last night at the bar."],[4097,4147,"Let's go."],[4711,4754,"Hey."],[4761,4881,"Hi, thank you."],[4961,4994,"Cheers."],[5118,5191,"What did you hear?"],[5372,5442,"What?"],[5442,5508,"I don't know-"],[5812,5872,"You okay?"],[5872,5905,"Yeah."],[6289,6379,"Watch where you're going."],[6913,7010,"What’s going on over there?"],[7143,7273,"Probably just someone picking a fight."],[7727,7754,"I'm fine."],[7837,7977,"You're the one who bumped into me."],[7977,8084,"You should apologize."],[8084,8184,"A mutt with no wolf?"],[8198,8298,"What's a human doing?"],[8334,8391,"It doesn't matter"],[8391,8571,"if I'm a wolf or a human, apologize."],[8638,8768,"I ate one just like you yesterday."],[8768,8858,"Looks like I've got dinner."],[8882,8955,"Hey, no."],[9019,9092,"She's a werewolf."],[9152,9235,"Okay, she's actually"],[9235,9305,"already got her wolf,"],[9305,9446,"so I'll happily apologize for her."],[9602,9789,"Let it go, okay? This is not worth the fight."],[9829,9973,"A werewolf with no wolf."],[10060,10156,"Never tried one before."],[10183,10273,"Well, maybe she can keep"],[10273,10390,"me company for a full day."],[10457,10497,"Let me go!"]],"16":[[63,153,"Stop! Let me go!"],[193,316,"Please! That's my mate. Come on!"],[320,427,"Even better, let's share"],[427,507,"and make it more fun."],[543,573,"Stop!"],[630,707,"Stop! Stop!"],[744,770,"Please!"],[1127,1184,"Who the hell?"],[1474,1524,"Rogue…"],[1768,1808,"Apologize."],[1875,2068,"I’m sorry! I deserve to die!"],[2118,2258,"Who are you apologizing to?"],[2302,2459,"I’m sorry! It's all my fault!"],[2472,2555,"Please don't hold it"],[2555,2709,"against a nobody like me."],[2759,2852,"She forgives you."],[2896,3046,"But eating another human?"],[3179,3306,"That's something I can't forgive."],[4424,4467,"Benny!"],[4507,4564,"Oh my god."],[4904,5018,"What the hell was that for?!"],[5018,5121,"You've gone too far!"],[5121,5158,"Too far?"],[5225,5318,"Who's about to let you"],[5318,5405,"leave with another man?"],[5475,5598,"I'm just gonna teach him a lesson."],[5598,5682,"I don't need your help!"],[5732,5875,"Can't even protect his own mate?"],[5875,5975,"How fucking useless."],[6022,6176,"Why are you with him?"],[6259,6343,"No matter what you say—"],[6366,6486,"he's still stronger than you."],[6486,6609,"At least he's not a violent killer"],[6609,6703,"who only knows how to fight!"],[6770,6900,"Is that really what you think of me?"],[6980,7120,"Even though he's weak, at least he's"],[7120,7233,"not just a rogue like you."]],"17":[[650,734,"Why didn't you tell me"],[734,840,"Xavier was following you?"],[880,950,"What does it matter?"],[1067,1151,"You would have run away"],[1151,1247,"like you always do."],[1574,1634,"You're still mad"],[1634,1731,"I didn’t fight that wolf?"],[1865,1941,"I was scared that"],[1941,2032,"things were going to get ugly"],[2032,2132,"and you were going to get hurt."],[2158,2232,"Forget it."],[2315,2405,"It's over now."],[2522,2569,"Benny."],[2679,2732,"What's wrong?"],[2862,3206,"Oh, it's a mind link from the Alpha."],[3206,3309,"He probably needs me for some..."],[3309,3406,"You still haven't told him?"],[3470,3613,"I haven't seen him in a few days."],[3717,3890,"I'll tell him as soon as I see him."],[3997,4034,"Thank you."],[4387,4627,"Benny, I'm planning to bring you into"],[4627,4784,"the Pack Council next week."],[4811,4938,"It’s rare for a Beta"],[4938,5038,"to get this chance..."],[5061,5311,"But hey, my daughter Lola likes you."],[5372,5635,"Once I’ve got time, I’ll host your ceremony."],[5715,5835,"Thank you, Alpha Drakar!"],[5872,6012,"I'll treat her well, I promise!"],[6032,6119,"I actually just booked a"],[6119,6286,"restaurant to take Lola out to lunch."],[6626,6730,"I already made a reservation."],[7100,7354,"Hey, Alpha, isn’t that Luna’s other mate?"],[7927,8024,"Interesting."]],"18":[[196,260,"Luna?"],[357,473,"Our Alpha is waiting for you outside."],[857,960,"I'm busy, you need to go."],[2318,2379,"What do you want?"],[2469,2539,"Let's get a lunch."],[2686,2859,"I'm busy, I don't want to eat lunch with you."],[2859,3003,"Come on, this will be way more"],[3003,3149,"entertaining than normal."],[3466,3593,"You said you loved him."],[3723,3850,"Let's see if he's worth it."],[4537,4597,"Thank you."],[4597,4751,"I really liked this place."],[4794,4891,"I'm glad you liked it."],[5028,5201,"Let's go to the movies next week."],[6326,6359,"Benny?"],[6663,6713,"I can't believe"],[6713,6826,"you're still lying to me."]],"19":[[50,93,"I can't believe"],[93,210,"you're still lying to me."],[473,540,"You're coming with me."],[1251,1287,"Isla…"],[1368,1474,"I thought you said you had"],[1474,1594,"errands to run for the Alpha."],[1611,1688,"What are you doing here?"],[1711,1771,"I can explain!"],[1801,1861,"You're a cheater."],[1971,2052,"What's left to explain?"],[2185,2298,"How do you want to deal with him?"],[2399,2492,"You want to kill him?"],[2605,2659,"Break his legs?"],[3159,3370,"It's my problem. I'll handle it."],[3540,3616,"Let him go."],[4444,4577,"I only invited her to the restaurant"],[4577,4688,"to reject her."],[4741,4944,"Really? You had to take her"],[4944,5115,"on a date first before rejecting her?"],[5338,5405,"You don't trust me?"],[5558,5622,"After all this time,"],[5622,5709,"you still don't know me?"],[5709,5815,"I want to believe you,"],[5815,5949,"but the truth was right there."],[6012,6086,"It's not what it is."],[6156,6252,"It's not the whole truth."],[6473,6516,"What?"],[7133,7313,"You have no idea."],[7447,7664,"The Alpha told me to mark Lola."],[7664,7717,"He said that I'd"],[7717,7834,"take his place one day."],[7921,8128,"And I met her today to turn that down."],[8244,8304,"Benny, I—"],[8338,8605,"I will give up becoming an Alpha,"],[8605,8822,"just for you, and you don't even trust me."],[8908,9015,"Maybe we should just break up."],[9142,9209,"No, I'm sorry."],[9349,9492,"I got too angry before."],[9602,9769,"Yeah. Yeah, forget it."],[9769,9843,"I was being too harsh."],[10003,10110,"But don’t ever doubt me again."],[10457,10530,"Let's go see Grandma."],[10637,10767,"I still have to apologize to her"],[10767,10890,"about the marking ceremony."],[11401,11468,"Grandma!"]],"20":[[647,700,"Look at me."],[824,900,"Do not worry."],[967,1107,"All right, the witch will know what to do."],[1251,1284,"You sure?"],[1334,1358,"Yes."],[1411,1458,"I know so."],[1478,1544,"All right, come on."],[1775,1818,"Here we go."],[1921,1945,"Hi."],[2429,2555,"Your grandmother fainted"],[2555,2689,"because she was cursed."],[2832,2952,"Whether she wakes up"],[2952,3173,"depends on your generosity."],[3496,3543,"OK."],[3596,3660,"Yeah, we're ready."],[3853,4097,"That doesn't seem so generous to me."],[4240,4391,"Oh, I umm... here."],[4391,4471,"I have another."],[4834,4921,"So can you break"],[4921,5001,"my grandmother's curse?"],[5071,5151,"Two coins?"],[5352,5538,"She might wake up temporarily,"],[5538,5749,"but to break the curse completely,"],[5749,5932,"you will need to bring me"],[5932,6196,"a hundred coins within three days."],[6299,6376,"One... one hundred?"],[6469,6609,"I don't have that kind of money."],[7020,7250,"OK, I mean, I have gold at home."],[7303,7333,"OK."],[7333,7554,"I'll meet you here tomorrow"],[7554,7634,"at 3 in the afternoon."],[7634,7677,"Alright?"],[7677,7727,"OK."],[7727,7814,"Okay, I'll see you around."],[7824,7911,"Please don't go anywhere."],[8935,9085,"The Alpha's daughter already said yes."],[9149,9265,"No need to throw yourself"],[9265,9492,"at that wolf-less Omega."],[9519,9586,"Who knows..."],[9619,9719,"Lola might turn me down."],[9759,9863,"If she doesn't want me anymore."],[9863,9983,"At least Isla can give me kids."],[10043,10186,"A low-class werewolf like her?"],[10256,10336,"Just string her along"],[10336,10477,"and say some sweet things,"],[10477,10577,"no need to give her any money."],[11247,11374,"It's so late already."],[11491,11591,"Why isn't Benny here?"],[12429,12502,"I'm sorry, Isla."],[12565,12652,"I can't make it."],[12702,12846,"My dad grounded me."]],"21":[[894,960,"Wait!"],[1211,1327,"I heard your grandma's been cursed."],[1381,1421,"The coward"],[1484,1531,"bailed on you."],[1634,1691,"I'll help."],[1751,1858,"It's none of your business."],[2215,2355,"If you don't get enough coins,"],[2355,2515,"your grandmother might not ever wake up."],[2605,2689,"Are you sure you're not gonna"],[2689,2789,"regret being this stubborn?"],[2889,2979,"What do you want in return?"],[4050,4200,"Be my mistress."],[4220,4397,"Until I’m done with you,"],[4591,4634,"or..."],[5288,5358,"be my Luna."],[5545,5608,"For three months."],[5752,5859,"You're taking advantage of me."],[6026,6122,"You can walk away."],[6766,6890,"Or get your grandmother"],[6890,6956,"from the witch…"],[7183,7270,"and watch her lie"],[7270,7460,"unconscious day after day."]],"22":[[36,150,"You think I'll fall in love with you"],[150,260,"after three months, don't you?"],[694,767,"Let me prove you wrong."],[894,977,"You're my Luna now."],[1000,1154,"Forget about the celebration,"],[1154,1247,"but,"],[1331,1541,"do you think I should get a kiss?"],[1624,1791,"After you heal my grandmother."],[1888,1988,"You're not really in a position"],[1988,2085,"to bargain, are you?"],[3273,3370,"Can we go see the witch now?"],[3723,3877,"Right about now..."],[3877,4110,"the witch should be casting a spell."],[4174,4207,"What?"],[4371,4564,"Luna, Alpha already delivered the gold"],[4564,4674,"to the witch earlier,"],[4674,4838,"with ten warriors to help her."],[4928,5088,"Once your grandma is safe…"],[5248,5395,"I’ll throw grandest ceremony ever."],[6603,6666,"Luna!"],[6766,6920,"Luna, these are the servants Alpha"],[6920,7033,"Xavier provided for you."],[7093,7240,"Um, I don't need them."],[7300,7384,"They’re not for Isla."],[7487,7557,"They're for my Luna."]],"23":[[2048,2115,"What are you doing?"],[2459,2545,"Are you done pretending?"],[2599,2709,"You're so controlling."],[2799,2869,"You'll do whatever it takes to get"],[2869,2926,"what you want,"],[2926,3049,"even playing tricks on me."],[3049,3113,"Yeah, and here you are"],[3113,3233,"making the first move."],[3443,3536,"You know, I'm still injured"],[3536,3596,"because of you?"],[3753,3983,"Aren't you gonna help me take care of it?"],[4007,4164,"Get your assistant to do it."],[4357,4534,"All right... but you're my fated mate."],[4534,4711,"Why would I ask someone else to do it?"],[4764,4898,"You should be grateful for my help."],[4928,5111,"Grateful? For trapping me here?"]],"24":[[86,150,"You should go to bed."],[337,460,"I won’t force you into"],[460,557,"anything you don't want to do."],[607,760,"I'll wait until you want it too."],[2522,2679,"Don’t forget to eat breakfast, Doctor."],[2876,2959,"Childish."],[3336,3376,"Grandma!"],[3656,3843,"What the hell is wrong with you?!"],[3870,4034,"I just bought every drop of"],[4034,4204,"potion in this entire place."],[4250,4330,"She can go home and die."],[4330,4384,"No, I-"],[4414,4537,"I already paid for that,"],[4537,4614,"that's mine."],[5265,5355,"This isn't about money."],[5422,5515,"Do you have any decency?"],[5595,5689,"I paid for that."],[5795,5962,"You? An Omega?"],[6039,6162,"Talking to me that way?"],[6272,6366,"You and your grandma"],[6366,6446,"should be thankful"],[6446,6609,"that she even has a chair to sit in."],[6783,6926,"Oh… I see."],[6966,7113,"You want some more?"],[7494,7567,"Is it enough?"]],"25":[[30,103,"Is it enough?"],[830,947,"You wanna die today?"],[1217,1244,"Stop!"],[1771,1875,"Who the fuck are you?"],[1918,2025,"Some hero fuckin' wannabe?"],[2095,2158,"So..."],[2242,2345,"throwing money around means"],[2345,2475,"whoever's richer gets to keep the potion?"],[2629,2696,"I'm the richest person"],[2696,2772,"in this whole land"],[2792,2869,"in all three packs."],[2962,3099,"Maybe except Rogue Xavier."],[3957,4097,"Do we get to take the potion now?"],[4204,4300,"Is that all for me?"],[5899,5989,"What are you doing?"],[6062,6209,"You're my Luna now. I'll let you deal"],[6209,6326,"with this trash however you want."],[6533,6659,"No, no, no! Aah—!"],[6953,7020,"Okay, okay, stop!"],[7130,7240,"I get it!"],[7477,7604,"Who the fuck are you?"],[7721,7824,"I'm Xavier."],[7937,8074,"Rogue…Xavier?"]],"26":[[216,300,"Please spare me!"],[453,580,"Alpha, how should we handle him?"],[740,840,"He doesn't deserve to die."],[970,1041,"There's a convenient place"],[1041,1121,"to dispose of somebody"],[1121,1191,"at the witch's hut."],[1434,1544,"Please, please spare me."],[1568,1675,"Wait, wait, stop!"],[1745,1818,"Wait, no, stop!"],[1871,1955,"You're not hurt, are you?"],[2105,2225,"No... I'm fine, thank you."],[3129,3193,"That's my blood."],[3279,3360,"Now it will notify me"],[3360,3493,"if you're ever in danger instantly."],[3546,3626,"Now you're starting to"],[3626,3723,"look a little less annoying."],[5699,5815,"Let go of me!"],[5889,5982,"Are you looking for Isla?"],[6189,6276,"It's none of your business."],[6343,6469,"She is my business."],[6533,6626,"She's my Luna now."],[6750,6816,"Oh, come on."],[6963,6983,"No."],[7167,7323,"Get away, no, there's no way!"]],"27":[[66,166,"Isla would never like"],[166,253,"a werewolf like you."],[357,487,"What kind of wolf would I be?"],[563,633,"What about you?"],[757,814,"A coward?"],[1014,1034,"Yeah."],[1214,1271,"You got money."],[1444,1578,"But you don't show her."],[1688,1845,"You cheat on her,"],[1845,1991,"and you expect her to love you?"],[2122,2188,"Talk."],[2308,2429,"And she's done with you."],[2505,2595,"Unless I hear a word"],[2732,2849,"from Isla's mouth herself,"],[2949,3116,"I won't believe the thing you say."],[3430,3496,"Why are you here?"],[3563,3610,"Benny."],[3610,3677,"Jesus."],[3763,3840,"You okay?"],[3840,3947,"I'm fine."],[4200,4307,"What is wrong with you?"],[4617,4691,"Do you believe it now?"],[5115,5205,"Consider it a compensation."],[5352,5455,"Have two men follow Isla."],[5468,5535,"If he ever tries to"],[5535,5739,"touch her again, break his legs."],[5835,5919,"Copy that, Alpha."],[6139,6236,"When's my turn?"],[6256,6363,"Everyone be patient please,"],[6363,6463,"one at a time, ok?"],[6549,6609,"Stop yelling!"],[6703,6840,"And you, sit down and wait!"],[7217,7327,"No wonder she's so slow..."],[7327,7427,"she doesn't even have a wolf."],[7470,7604,"Do you not know what manners are?"],[7664,7744,"Who says I don't?"],[7797,7944,"Do you want to be treated or not?"],[8041,8128,"Screw this!"],[8178,8258,"Hey... it's your turn!"],[8328,8375,"Better hope I don't"],[8375,8468,"see you on the road later!"],[8601,8682,"Zero manners."],[8782,8862,"For the rest of you,"],[8902,8982,"watch your manners too."],[9155,9346,"Excuse me, you're scaring off"],[9346,9502,"my patients and getting in my way."],[9502,9556,"Please leave."],[9649,9769,"Alpha wanted us to protect you..."],[9799,9873,"We're gonna be here to"],[9873,9949,"the end of your shift."],[10160,10306,"Tell your men to back off."],[10367,10487,"You're scaring off all my patients."]],"28":[[704,807,"Just rest here, alright?"],[1194,1361,"Okay, you guys get out!"],[1394,1571,"Stop coming in here! Please, go."],[2022,2142,"Please don't be mad..."],[2298,2375,"See you, Luna!"],[2799,2876,"Don't be mad."],[2876,2966,"I was just trying to help."],[2966,3046,"You don't even care."],[3099,3239,"You're just entitled and reckless."],[3239,3286,"You're just trying to"],[3286,3380,"mark your territory."],[3443,3540,"I’ll fix it right now."],[3590,3650,"Are you still gonna"],[3650,3767,"send people to follow me?"],[3980,4167,"I swear to the Moon Goddess - no more."],[4337,4461,"Please, forgive me."],[4918,4961,"Rat!"],[5011,5111,"Rat, rat!"],[5185,5268,"Where? Where?"],[5525,5605,"Okay, it's gone."],[5735,5802,"You're safe right now."],[5802,5839,"Okay..."],[5872,5919,"Put me down."],[5919,5999,"Stop..."]],"29":[[200,286,"It’s gone now."],[296,377,"I think you’re safe now."],[457,527,"Put me down."],[704,867,"Ah, okay, yeah yeah."],[900,1111,"Alright, let's just go eat."],[1184,1277,"I have to go see Grandma."],[1324,1404,"Let's go together."],[1958,2098,"I've been fine for days."],[2175,2339,"I just wanna go home."],[2542,2589,"I know."],[2676,2759,"The witch said you just need"],[2759,2896,"10 more days of observation."],[2899,3053,"You can treat it like"],[3053,3153,"a little staycation."],[3196,3353,"But it's so boring here."],[3403,3530,"I don't have anyone to"],[3530,3733,"play crossword puzzles with."],[3873,3960,"I'll play with you."],[4441,4557,"I'll get everything ready, Alpha."],[4661,4818,"You're seriously entertaining her?"],[4908,5008,"This is the witch's hut."],[5051,5178,"So? if Grandma wants to"],[5178,5301,"play here, we play here."],[5742,6056,"\"B\"... something that flies."],[6126,6196,"Oh, bird!"],[6216,6246,"No."],[6483,6516,"\"B\"."],[6886,7173,"Maybe… “BO…”"],[7263,7367,"Bounce! That's it."],[7397,7490,"That's a good one."],[7514,7664,"Oh, that's one point for me!"],[7827,7921,"You're a genius, Grandma."],[7987,8198,"That's because of the Moon Goddess!"],[8294,8425,"You know, we've been"],[8425,8555,"playing all afternoon."],[8595,8768,"Are you guys thirsty?"],[8772,8945,"Oh yes! Very thirsty!"],[9082,9112,"Oh."]],"30":[[1184,1284,"I found a new herbal remedy"],[1284,1408,"that takes away the side effects"],[1408,1498,"of the medication."],[1561,1651,"It's also very refreshing"],[1651,1741,"if you'd like to try it."],[1775,2005,"Oh, that's so thoughtful, young man."],[2065,2158,"I'll give it a try."],[2182,2305,"Thank you so much."],[2352,2405,"You're my guest."],[2532,2599,"I'll go make another one"],[2599,2696,"in case you want more."],[2789,2852,"Thank you."],[3116,3426,"Oh, Xavier is so thoughtful!"],[3473,3653,"I can tell that his feelings for you"],[3653,3753,"are genuine,"],[3777,3877,"Isla."],[3877,4144,"Oh, we're just friends, Grandma."],[4330,4551,"I can see that he's in love with you,"],[4591,4911,"and he's way better than that Benny."],[4918,4938,"Ugh."],[5118,5268,"Oh, thank you."],[5712,5829,"Do you wanna go get some food?"],[5962,5992,"Really?"],[6096,6159,"You and me?"],[7787,7901,"So what do you think of the food?"],[7954,8001,"Pretty good."],[8078,8144,"What do you think?"],[8248,8294,"Anything tastes good"],[8294,8378,"when you’re with me."],[8682,8795,"I've got to get back to the clinic."],[8795,8858,"I need to work."],[8912,9012,"Don't you think working there"],[9012,9089,"is a bit stressful?"],[9219,9279,"I mean,"],[9412,9532,"I can take care of you."],[9669,9769,"I know the clinic is old..."],[9769,9899,"but I love being a doctor."],[9899,9993,"I love helping people."],[10136,10226,"If that's what you love."],[10283,10410,"of course, I’ll support you."],[10523,10620,"I would like to see you work"],[10620,10717,"in a better place."],[10750,10814,"What do you mean?"],[11004,11077,"You’ll see tomorrow."],[11204,11311,"There's nothing in the three packs"],[11311,11384,"that I can't do."]],"31":[[223,340,"From now on you'll be working"],[340,420,"in this new clinic."],[470,560,"Someone else is"],[560,697,"taking care of the old one."],[1204,1321,"Isla! Welcome!"],[1438,1548,"I am the head physician."],[1574,1661,"Just call me Simon."],[1738,1868,"Nice to meet you, Simon."],[1891,2022,"Now, don't be nervous."],[2022,2218,"Xavier has already filled me in."],[2268,2425,"If you ever need anything,"],[2425,2589,"please just let me know."],[2676,2829,"Thank you. I'm just here to do my job,"],[2829,2926,"so no special"],[2926,3013,"treatment is needed."],[3049,3169,"That I am not sure."],[3236,3360,"Xavier said to me that"],[3360,3466,"if you are mistreated here,"],[3540,3683,"I will not be spared."],[4184,4294,"Why does it look like"],[4294,4417,"they already knew each other?"],[4461,4614,"I heard Simon got marked last week..."],[4818,4894,"Could it be...?"],[5001,5258,"Is Isla... his lover?!"]],"32":[[36,130,"I knew it. How else can"],[130,310,"an Omega become a doctor?"],[347,573,"Obviously by being someone's mistress."],[667,814,"No wonder she has fancy stuff."],[1007,1137,"Must be his sugar baby."],[1501,1668,"Um, what's going on?"],[1721,1888,"Organize all of these before you are off."],[2098,2332,"Um, these look really old."],[2349,2495,"Is there a need for that?"],[2712,2869,"We decide what matters around here."],[2966,3106,"What's that supposed to mean?"],[3106,3206,"It's time somebody taught"],[3206,3360,"a slut like you a lesson."],[3503,3693,"You knew Simon had a mate,"],[3693,3863,"and you still threw yourself at him."],[3863,3940,"There's nothing going on"],[3940,4064,"between Simon and I."],[5128,5225,"You're just a fling."],[5225,5345,"Even if you die,"],[5398,5545,"Simon wouldn’t give a fuck."],[5835,6019,"Yes. Alright, that's what we'll do."],[6132,6169,"Okay."],[6296,6439,"Alpha, you're scheduled to attend a"],[6439,6563,"meeting in the South Forest later."],[6616,6706,"Reschedule it."],[6706,6853,"I told Isla I'd pick her up."],[7657,7761,"How dare you hit me?!"],[7837,8044,"You're just a fucking mistress."],[8288,8321,"Enough!"],[8445,8575,"Isla started this!"],[8675,8865,"Yes, she slapped me."],[8938,9045,"You're Simon's cousin."],[9045,9149,"Don't be on her side."],[9179,9416,"All I saw was you two ganging up on her."],[9489,9576,"Got no work to do?"],[9602,9783,"We’ll go organize the medicine."],[11044,11144,"You're hurt."],[11267,11368,"Thank you."],[12178,12465,"It's okay. Don't be afraid, Isla."],[12532,12599,"I just want to get"],[12599,12722,"a little bit..."],[12809,12886,"closer to you."]],"33":[[66,163,"I saved you."],[333,513,"So... what do you think"],[513,617,"you can do for me in return?"],[740,910,"Fuck off, what do you want?"],[1164,1321,"You don't seem to understand..."],[1434,1524,"If you want to get work"],[1524,1661,"around here, you need someone"],[1661,1785,"to support you."],[1878,1998,"I need to get back to work."],[2165,2292,"I am Simon's cousin."],[2399,2529,"If you become my mistress,"],[2529,2599,"no one here"],[2599,2759,"will ever lay a finger on you."],[2776,2876,"I already have a mate."],[3109,3376,"But you are a wolfless Omega."],[3430,3737,"Your mate is nothing compared to me."],[4240,4447,"You should be grateful"],[4447,4637,"that I'm willing to touch you."],[4871,4931,"You bitch."],[5161,5578,"Let's see if your mate compares to me."]],"34":[[967,1077,"Who are you guys?"],[1137,1368,"I'm the cousin of the head physician!"],[1391,1491,"How dare you..."],[1514,1581,"I’ll show you...."],[1581,1654,"Cousin!"],[1705,1785,"They’re attacking me!!"],[1965,2032,"Idiot!"],[2142,2258,"That's Alpha Xavier!"],[2706,2756,"I'm sorry!"],[2799,2849,"I'm sorry!"],[2849,2899,"It’s all my fault!"],[2899,3193,"Do what you want with him, Alpha Xavier."],[3323,3476,"Which hand did you use to hurt Isla?"],[3493,3570,"Which hand?"],[3717,3777,"Take them both."],[3810,3920,"No, no, no."],[3963,4144,"Nobody hurts Isla gets away with it."],[4164,4207,"I'm sorry."],[4207,4347,"Please, please forgive us."],[4467,4594,"Did you care about my feelings"],[4594,4754,"when you spread those lies about me?"],[4784,4884,"Fuck off."],[4938,5068,"I never wanna see you here again."],[5098,5238,"Please! We still want to be doctors!"]],"35":[[887,930,"Hey!"],[1091,1251,"I'm gonna head out and pick up Grandma."],[1878,1958,"I'll send someone else."],[2178,2349,"I really miss Grandma, okay?"],[2522,2659,"Whatever you want..."],[2659,2789,"you can wait until after your meeting."],[4014,4104,"Stop, stop. Hey!"],[4104,4174,"Stop. Wait."],[4224,4287,"What are you doing here?"],[4324,4474,"So it's true you really gave him."],[4584,4641,"Yeah."],[4893,5029,"Come on, Isla."],[5101,5255,"We are done."],[5255,5378,"Don't come looking for me again."],[5772,5822,"So that's it?"],[5895,6099,"Seriously, you just like his money?"],[6209,6279,"God, I..."],[6403,6529,"I cannot believe that you would"],[6529,6700,"sleep with a rogue just for money."],[6700,6793,"You know, I’ve known all along that"],[6793,6853,"you cheated on me."],[6853,6966,"I just didn't care to expose you."],[7017,7037,"Wha..."],[7147,7290,"What are you talking about...?"],[7337,7474,"Messing around with other girls while"],[7474,7620,"acting like you liked me."],[7797,8074,"It was my dad! Okay? He forced my hand."],[8161,8241,"Still lying."],[8301,8538,"Don't come looking for me ever again."]],"36":[[30,146,"Gold-digging bitch!"],[213,357,"You used to be so innocent,"],[357,447,"and now you're with Xavier,"],[447,567,"this is how you treat me?"],[2756,2912,"I believe I told you to stay away from her."],[2999,3216,"Oh no."],[3249,3343,"Oh no."],[3363,3530,"No, stop please please."],[3593,3693,"No no."],[7764,7984,"Don't ever go near Isla."],[8274,8391,"Or you won't see another moon."]],"37":[[453,507,"You're back."],[643,717,"You drunk?"],[854,984,"I'll go get you some medicine, ok?"],[1127,1204,"I went out for a meeting,"],[1204,1344,"and you already went on a date with Benny?"],[1434,1571,"You sent someone to follow me again?"],[2018,2108,"Answer me."],[2375,2455,"Xavier,"],[2549,2655,"I’m already your Luna, ok?"],[2709,2792,"You should trust me."],[3296,3376,"Then as my Luna..."],[3636,3790,"shouldn’t you fulfill your duties?"],[3990,4114,"Have you... mated with Benny?"],[4441,4657,"If you wanna doubt me, then just let me go,"],[4694,4761,"or kill me."],[4761,4838,"That would be easier."],[4978,5068,"You agreed to be my Luna"],[5068,5138,"for three months,"],[5138,5208,"not a minute less."],[6176,6376,"Isla, I’m sorry."],[6479,6603,"Get out."]],"38":[[603,714,"Drowning your sorrows?"],[894,940,"Your lips?"],[1037,1134,"What happened?"],[1187,1287,"Did someone bite you?"],[1438,1511,"Who is she?"],[1621,1661,"It's my Luna."],[1845,1951,"You're seeing someone else?"],[2068,2128,"But I'm the daughter"],[2128,2242,"of the Scarlet Alpha."],[2242,2298,"What does..."],[2298,2455,"What does she have that I don't?"],[2569,2649,"Shut up."],[2802,2966,"There was never an “us”."],[3480,3656,"If you speak negatively about her,"],[3727,3837,"I'll stop playing nice"],[3837,3943,"for your mother's sake."],[4504,4614,"First,"],[4644,4788,"I want to know who she is."],[4894,5141,"Then... I want her gone."],[6453,6566,"Do you like your gifts?"],[6750,6843,"I don't need anything."],[6983,7370,"I'm sorry, Isla… please forgive me."],[7640,7704,"What do you want?"],[7914,8001,"I think all I want is"],[8001,8148,"is trust and understanding."],[8324,8428,"Can you give me that?"]],"39":[[347,497,"What did I do wrong, David?"],[767,987,"If you can't figure it out, ask Grace."],[1067,1161,"After all,"],[1231,1277,"she knows Luna"],[1277,1381,"better than anyone else."],[1711,1758,"Grandma,"],[1915,1995,"I need your help."],[2385,2429,"Isla?"],[2552,2599,"Who are you?"],[2652,2746,"I'm Xavier's cousin."],[2759,2859,"He told me to pick you up."],[3003,3053,"What for?"],[3119,3203,"Don't worry about it."],[3203,3356,"Just come with me and you'll find out."],[3400,3486,"I mean, it's urgent."],[3590,3660,"Xavier's waiting."],[4474,4544,"What do you want?"],[4678,4791,"I thought Xavier had"],[4791,4948,"found some astonishing woman,"],[4948,5018,"but you..."],[5151,5321,"you're just a wolfless Omega."],[5372,5492,"Who the fuck are you?"],[5618,5702,"Have you ever heard"],[5702,5799,"of the Scarlet Pack?"],[5912,6009,"Yeah, well..."],[6066,6179,"I'm the Alpha's daughter,"],[6226,6259,"and"],[6363,6483,"Xavier's fiancee."],[7000,7103,"Trash like you."],[7207,7293,"What do you think you're doing,"],[7293,7394,"trying compete with me,"],[7394,7450,"for a man?"],[7664,7744,"Trash like you?"],[7844,7954,"What makes you think that you can"],[7954,8088,"compete with me for a man?"],[8298,8435,"Scarlet Pack is asking for war."]],"40":[[243,313,"I bet you don't even"],[313,403,"know how to handle a bow."],[503,570,"Watch and learn."],[850,930,"Let go of me!"],[1171,1304,"You can't even bond a wolf."],[1364,1501,"So what makes you think that"],[1501,1711,"you deserve to be Xavier's Luna?"],[2032,2118,"Don't move, Isla."],[2255,2365,"If I ruin that pretty face,"],[2365,2472,"not even the Moon Goddess"],[2472,2559,"can save you now."],[3646,3873,"Xavier, we were just having"],[3873,3990,"some fun. Don't overreact."],[4090,4160,"Fun?"],[4327,4454,"You've got some nerve."],[4561,4694,"Xavier, I am the daughter of"],[4694,4888,"the Alpha of the Scarlet Pack."],[4951,5061,"Let go of me!"],[5885,5932,"Isla,"],[6219,6269,"let me show you"],[6269,6339,"how to use the bow."],[6990,7143,"When you face an enemy,"],[7280,7387,"stay locked on her."],[7480,7550,"Don’t shake,"],[7681,7777,"don’t panic."],[7841,8074,"You have all lost your damn minds..."],[8118,8194,"Just focus,"],[8361,8425,"don't hesitate."],[9109,9179,"That's my Luna."],[9426,9552,"If you ever touch Isla again,"],[9659,9719,"I'd make sure"],[9719,9859,"the Scarlet Pack is wiped out."],[10013,10060,"Leave!"],[10947,11017,"Isla..."],[11191,11358,"I'm sorry for not keeping you safe."]],"41":[[143,223,"Thank you."],[337,380,"You don't need to"],[380,530,"feel guilty though. It's not your fault."],[714,740,"And..."],[767,904,"we've only got three months."],[984,1097,"Once the time is up, we'll have nothing to"],[1097,1184,"do with each other."],[1398,1538,"Just take my gift at least."],[1591,1701,"I already have enough gold and jewels,"],[1701,1815,"I don't need anything else."],[1895,2008,"What about this?"],[2505,2629,"How did you know I like that?"],[2969,3079,"Grandma told me."],[3119,3213,"You went to see Grandma?"],[3493,3553,"But this..."],[3626,3707,"this Moonblossom is"],[3707,3863,"extinct, how did you find it?"],[4651,4711,"Just heard that someone's seen"],[4711,4944,"Moonblossoms near the cliff, but..."],[4974,5025,"What?"],[5095,5131,"But everyone who"],[5131,5198,"attempted to pick it..."],[5251,5298,"died."],[5375,5428,"Maybe it's best to"],[5428,5525,"gift Luna something else."],[5689,5799,"I'll go pick it myself."],[5815,5942,"If she likes it, I'll bring it to her,"],[5942,6002,"no matter what."],[6366,6486,"I just had it in my house."],[6846,6946,"I don't want us to just be together"],[6946,7013,"for three months."],[7260,7397,"I'm sorry for doubting you before."]],"42":[[93,210,"I'm only great with fighting, not..."],[323,423,"with feelings."],[480,537,"And I know you need"],[537,630,"trust and understanding,"],[630,780,"so help me figure it out."],[854,887,"Together."],[1494,1541,"Let’s go home."],[3133,3253,"You bitch."],[3530,3586,"Why?"],[3713,3893,"Why do they get to live better than me?"],[5078,5195,"Benny, what are you doing here?"],[5218,5338,"Hey, I'm here to request"],[5338,5492,"the marking ceremony for Alpha."],[5645,5689,"This..."],[5882,5992,"is my gift for him."],[5999,6189,"You can leave. It's not gonna happen."],[6329,6406,"What?"],[6449,6539,"Why not?"],[6683,6783,"Call Alpha out."],[6836,6980,"I've been dating Lola for a long time now"],[6980,7087,"and he already said yes."],[7140,7173,"Who?"],[7474,7504,"Benny."],[7821,7957,"You're mating someone else?"],[8024,8481,"How dare you do that to my little Lola."],[8485,8635,"No, no, let me explain. I already"],[8635,8798,"cut her off a long time ago!"],[8798,8932,"Okay? It’s all that bitch’s fault!"],[8982,9279,"No. Enough! Alright."],[9315,9512,"You're nothing. Just a Beta."],[9529,9693,"You see, I would have allowed"],[9693,9873,"you to be with her, alright?"],[10006,10180,"But you’re nothing but a scum!"],[10263,10570,"And don't join the council anymore."],[10570,10820,"Okay? You're no longer a Beta."]],"43":[[704,807,"Damn it!"],[930,1047,"Your miserable state..."],[1227,1314,"It's all Isla's fault."],[1534,1588,"Who are you?"],[1785,1878,"Do you wanna get back at her?"],[2339,2405,"What do you want?"],[3550,3586,"Stop."],[3803,4037,"Benny, I already told you we're done."],[4090,4187,"Come to my house tonight."],[4337,4461,"If you don't, I wanna tell Xavier's"],[4461,4574,"enemies where he lives."],[4748,4818,"What are you talking about?"],[4968,5068,"Do you have any idea"],[5068,5231,"how many people Xavier's killed"],[5231,5392,"for his so-called peace pact?"],[5742,5922,"If you don’t come with me right now,"],[6086,6219,"I’ll tell his enemies where his pack is."],[6643,6683,"Let's go."],[8098,8218,"What do you want from me?"],[8268,8324,"No..."],[9132,9229,"Thirsty?"],[9866,9929,"Xavier?"],[10040,10230,"Are you sure Isla loves you?"],[10370,10437,"What do you want?"],[10677,10817,"Your Luna went to go see Benny."],[11007,11057,"She's probably"],[11057,11214,"enjoying herself right now."],[11264,11491,"Probably moaning with pleasure."]],"44":[[93,270,"She's probably enjoying herself right now."],[350,607,"Probably moaning with pleasure."],[1518,1628,"This water I gave you..."],[1875,2005,"It was an aphrodisiac."],[2138,2275,"When that rogue wolf of yours"],[2275,2455,"gets here, he’ll find"],[2455,2592,"you naked on top of me."],[2726,2859,"Do you really think he still want you?"],[3013,3143,"I’m going to ruin you tonight."],[3183,3263,"When he finds you,"],[3286,3466,"he's gonna abandon you."],[3640,3770,"Let go of me! You bastard!"],[3880,3947,"Luna!"],[4364,4454,"You’re asking for death!"],[6626,6723,"Are you alright?"]],"45":[[640,730,"Hey, just calm down,"],[787,850,"alright?"],[980,1031,"Don't go."],[1501,1631,"The drugs haven't worn off yet?"],[2946,3006,"You..."],[3109,3223,"you have your wolf!"],[3346,3363,"Mate!"],[3450,3513,"My mate!"],[4424,4521,"The dress you got me..."],[4614,4654,"it's wet."],[4724,4844,"I wasn't looking at the dress."]],"46":[[924,1024,"I’ll let you handle this."],[1054,1191,"Benny... how could you do this to me?"],[1338,1491,"You saved my life six years ago."],[1491,1611,"How could you change this much?"],[1875,1918,"Saved you?"],[2032,2198,"You really think a wolfless Omega"],[2198,2339,"is worth risking my life for?"],[2509,2569,"But..."],[2686,2742,"didn't you?"],[2886,3156,"It was deep winter in the South Forest."],[3229,3383,"The snow was knee-high."],[3413,3533,"When you got lost, I already started"],[3533,3663,"preparing your funeral."],[3973,4180,"Who would've thought you'd get lucky"],[4180,4314,"and make it out alive"],[4314,4451,"and treat me like your savior?"],[4484,4537,"You're the one who"],[4537,4698,"threw yourself at me."],[4748,4794,"Pathetic."],[5011,5058,"Kill him."],[5902,6002,"In the South Forest..."],[6036,6202,"were you wearing a red coat?"],[6229,6286,"How did you know?"],[6366,6489,"Because I was in the South Forest"],[6489,6563,"six years ago,"],[6649,6746,"where someone got lost."],[7283,7370,"Don’t die on me."],[7474,7560,"I'm gonna go find somebody"],[7560,7630,"from the Dark Moon pack"],[7630,7704,"to help you."],[8088,8161,"It was you?"]],"47":[[93,136,"It was you?"],[443,567,"Since you owe me your life..."],[727,890,"Hey, not now. There's people outside."],[950,1084,"Nobody dares to comes in here."],[1614,1775,"Huh... he was just here."],[3086,3179,"We're gonna have to hold"],[3179,3360,"the biggest marking ceremony ever."],[4554,4627,"Bad news!"],[4751,4824,"Luna's gone."],[4954,4978,"What?"],[5575,5839,"Xavier, if you want to see Isla again,"],[5885,6052,"come alone to Scarlet Forest."]],"48":[[857,937,"Let her go."],[974,1114,"Anything you want, you come to me."],[1137,1264,"Xavier, hold the"],[1264,1434,"marking ceremony with Celeste."],[1441,1531,"And join my pack."],[1531,1648,"And this will all end."],[1648,1738,"You'll both get to live,"],[1738,1868,"and you'll be the next Alpha"],[1868,1935,"of Scarlet."],[1975,2028,"No way."],[2072,2268,"Then don't blame me for being ruthless."],[2339,2442,"I've got a little present"],[2442,2545,"from the human world."],[2689,2819,"It's loaded with silver bullets."],[2822,2899,"If you hurt her,"],[2899,2992,"even just a little bit,"],[3013,3076,"I will burn"],[3076,3223,"the Scarlet Pack to the ground."],[3329,3373,"Interesting."],[3506,3613,"Since you're so bold,"],[3673,3797,"I'll give you a chance."],[3863,3973,"Let's play a little game."],[4057,4287,"If you win, you both walk free."],[4351,4401,"Lose?"],[4467,4551,"Your life is mine."],[4597,4664,"What do you say?"],[4734,4814,"Do you dare?"]],"49":[[16,106,"What do you say?"],[176,266,"Do you dare?"],[737,867,"Let her go first."],[1234,1434,"It's okay. I'll be fine."],[1451,1544,"Be careful."],[2469,2619,"The rules are simple."],[2652,2812,"The revolver has six bullets,"],[2859,3026,"but we're only leaving one."],[3209,3296,"You’ll take turns,"],[3350,3486,"pointing it at your own head."],[3513,3773,"Whoever the barrel turns to, goes first."]],"50":[[36,100,"Whoever the barrel"],[100,273,"turns to, goes for it."],[1327,1471,"Mom, how do you know that"],[1471,1608,"the silver bullet is going to hit him?"],[2198,2238,"It's ok."],[2392,2449,"I will be fine."],[2522,2699,"Xavier, you can still back out."],[2926,3116,"Isla, if you kill yourself right now,"],[3116,3243,"I'll let Xavier walk away."],[3880,3947,"I won‘t lose."],[5418,5475,"Your turn."],[5972,6106,"You think you'll win?"],[7033,7160,"Four shots. No bullet."],[7260,7300,"Moving on."],[7437,7670,"Xavier, 50/50 now."],[7714,7817,"Still want to play?"]],"51":[[43,276,"Xavier, 50/50 now."],[306,403,"Still want to play?"],[417,473,"Xavier,"],[557,660,"last chance to back out."],[687,777,"If you use that gun,"],[784,847,"shoot Isla,"],[884,970,"I'll forgive everything."],[1194,1324,"There's still time to mark with me."],[1601,1681,"You would die..."],[1751,1865,"for this woman?"],[1928,2068,"Have you forgotten who's holding the gun?"],[2078,2208,"Still want to talk like that?"],[2595,2639,"Isla!"]],"52":[[200,230,"Isla!"],[333,390,"Xavier,"],[427,500,"you still have your dream of"],[500,617,"peace to fulfill."],[857,910,"I love you."],[1011,1071,"Isla! No!"],[1107,1187,"Just let me take this."],[1304,1331,"Isla!"],[2068,2132,"Xavier won!"],[2168,2215,"Alpha,"],[2242,2442,"I swear! Everything was in place."],[2459,2602,"The bullet was supposed to kill her."],[3179,3283,"You're backing out now?"],[3370,3433,"Backing out?"],[3440,3466,"No."],[3513,3650,"I'm simply keeping my promise..."],[3713,3823,"Make sure you never leave."],[3903,3950,"Kill them."],[4177,4250,"Go to hell!"],[4924,4954,"Xavier!"],[5235,5251,"No!"],[5335,5372,"Xavier!"],[5552,5625,"No! Xavier!"],[6659,6693,"Xavier!"]],"53":[[447,520,"Isla… run."],[530,620,"I'm not leaving you behind…"],[787,874,"I have to save you."],[1034,1137,"Just focus,"],[1231,1321,"don’t hesitate."],[1688,1805,"Let me help you, Isla."],[2118,2185,"The rogue..."],[2232,2422,"even the Alphas couldn’t kill…"],[2489,2552,"But I--!"],[3536,3590,"Xavier."],[3817,3867,"You're okay?"],[4030,4067,"Alpha."],[4294,4447,"Make sure the Scarlet Pack burns."],[4541,4607,"Yes, Alpha!"]],"54":[[210,270,"Where are we going?"],[270,333,"You're injured."],[357,380,"No."],[613,714,"Something more important."],[1257,1371,"Here. Under the Moon Goddess."],[1501,1608,"I, Xavier,"],[1641,1748,"ask you Isla..."],[1801,1961,"to be my mate, my Luna,"],[2095,2268,"as long as the Moon remembers our names."],[2542,2749,"Yes, I'll be your mate,"],[2839,2942,"and your Luna,"],[3006,3146,"and accept all of you."],[3576,3847,"Congratulations on finding each other."],[3947,4050,"Is that the Moon Goddess?"],[4197,4220,"Yes."],[4351,4454,"Right here on this land,"],[4454,4587,"the wolves have long forgotten."],[4774,4948,"She guided me to become a rogue,"],[5095,5215,"and uphold the peace pact."],[5422,5598,"Xavier, you've done well."],[5662,5739,"Isla,"],[5739,5939,"congratulations on finding your wolf."],[6019,6222,"Together, may you strive for"],[6222,6483,"the harmony between wolves and humans."]]}