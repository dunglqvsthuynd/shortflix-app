5743,"All right now, Liam,"],[5747,5914,"enough games."],[5976,6089,"Tell us"],[6089,6185,"where is the bomb?"]],"60":[[241,442,"You fucking moron!"],[525,563,"Yeah."],[563,771,"I hate Mr. Kingsley,"],[771,859,"but not enough to blow up"],[859,1009,"the whole building."],[1151,1197,"You said"],[1197,1397,"there's a bomb threat, right?"],[1401,1551,"Why don't we just call 911?"],[1551,1647,"Let them handle it."],[1647,1772,"What is that number again?"],[1772,1843,"Oh, yeah."],[1843,2043,"It's 911."],[2093,2243,"Hello? Hi. Yes."],[2243,2398,"Apparently, there's a bomb"],[2398,2477,"in our office."],[2519,2606,"Send the bomb squad"],[2606,2744,"to Victory Group headquarters."],[2986,3186,"The police are on their way."],[3194,3311,"Let's see if the police buy"],[3311,3470,"your bullshit theory."],[3616,3732,"Is it not Liam?"],[3732,3862,"If it was really him,"],[3862,4095,"he wouldn't have called 911, unless..."],[4133,4237,"Okay,"],[4237,4437,"I see what game you're playing here."],[4437,4583,"You're just calling 911"],[4583,4775,"to make it seem like you're not guilty."],[4775,4975,"But you're still the primary suspect."],[4975,5142,"Damn you, Clyde."],[5142,5267,"You've been nothing but a"],[5267,5513,"pain in my ass all day!"],[5597,5714,"Liam, take Clyde"],[5714,5935,"outside and hand him off to the police"],[5935,6106,"as soon as they get here."],[6222,6302,"All right."],[6302,6452,"Time for the last resort."],[6452,6652,"I have to blow this deal."],[6660,6773,"That'll make Mr. Todd"],[6773,6898,"leave the office with Ivy."]],"61":[[212,412,"Look, I know he's your husband, okay?"],[429,479,"But right now,"],[479,563,"we have to focus"],[563,734,"on the most important thing"],[734,779,"right now,"],[779,1088,"and that's this business, okay?"],[1092,1180,"Look."],[1180,1338,"He's been interfering all day."],[1338,1501,"He had to go."],[1501,1714,"Oh, yes, I understand."],[1739,1822,"And"],[1822,2143,"Mr. Todd, I can't apologize enough,"],[2143,2181,"okay?"],[2185,2298,"He's so full of shit."],[2298,2435,"All those accusations"],[2435,2669,"completely false."],[2748,2848,"But you're not here for this."],[2848,2990,"You're here because of"],[2990,3094,"the deal!"],[3153,3257,"I'm going to have to defer back"],[3257,3399,"to Ivy on this one."],[3470,3670,"Ivy, what do you think?"],[3716,3937,"Well, based on the data and the other"],[3937,4099,"materials we've received,"],[4112,4245,"I believe that Victory Group"],[4245,4446,"is a company with a lot of potential."],[4458,4658,"I say we proceed."],[4667,4742,"Yes!"],[4783,4909,"Alrighty then."],[5021,5113,"Let’s sign that paperwork."],[5113,5238,"That's what I like to hear."],[5238,5417,"Liam, go fetch the contract."],[5417,5526,"Right this way, sir."],[6068,6101,"Hey!"],[6101,6168,"Hey, wait."],[6264,6398,"Mr. Todd, Ivy,"],[6398,6527,"don't sign that contract yet."]],"62":[[0,154,"You had one job."],[154,312,"What the hell is he still doing here?"],[312,479,"Clyde, what the hell are you doing?"],[479,600,"Look, I have something"],[600,675,"very important"],[675,859,"to tell you and Mr. Todd."],[859,950,"What's that?"],[996,1197,"These are documents"],[1222,1501,"that prove Mr. Kingsley"],[1501,1793,"is guilty of tax evasion,"],[1793,1964,"commercial bribery,"],[2031,2198,"and sexual misconduct"],[2198,2327,"in the workplace."],[2473,2644,"Victory Group"],[2644,2982,"is actually in very serious debt."],[3028,3086,"They've been fudging"],[3086,3178,"the numbers,"],[3178,3257,"making up data"],[3257,3365,"to seem more attractive"],[3365,3432,"to investors."],[3432,3632,"So if you guys invest with him,"],[3691,3766,"Eminent Group"],[3766,3912,"is going to get dragged down"],[3912,3953,"with him."],[3953,4108,"That's such bullshit!"],[4108,4341,"Victory Group is not in debt."],[4416,4704,"Victory Group is thriving."],[4813,4950,"You can't believe a word he says."],[4950,5180,"It's lie after lie after lie."],[5180,5276,"Lies?"],[5276,5355,"Then why did you just try to"],[5355,5476,"snatch this out of my hand?"]],"63":[[70,196,"Clyde,"],[196,283,"how do we know this isn't"],[283,437,"just another false accusation?"],[437,646,"Well, conveniently,"],[696,788,"my beautiful wife"],[788,896,"used to be an auditor,"],[900,1084,"so she will be able to make sense"],[1084,1201,"of all these files."],[1384,1564,"Try to steal them, Mr. Kingsley."],[1564,1726,"I've made plenty of copies."],[2068,2139,"Xavier."],[2139,2323,"Clyde's right."],[2323,2619,"This company is practically insolvent."],[3995,4170,"Jesus, Kingsley."],[4170,4366,"You really try to fuck us."],[4396,4642,"You mother fucker!"],[4683,4938,"I was just about to save my business."],[5163,5313,"Now I'm going"],[5313,5513,"to fucking kill you."]],"64":[[1217,1313,"Come on, honey."],[1313,1384,"We got to go."],[1384,1514,"This place is going up in flames"],[1514,1651,"in ten minutes."],[1651,1776,"Mr. Todd, I'm sorry."],[1776,1860,"I should have done a more"],[1860,1960,"thorough background check on"],[1960,2047,"on Victory Group"],[2047,2198,"because this could have cost us."],[2218,2314,"You couldn't have known"],[2314,2515,"they were falsifying their numbers."],[2565,2706,"Good thing Clyde was there to stop us"],[2706,2861,"from signing that contract."],[3219,3365,"Thank you."],[3432,3520,"Claire, here."],[3520,3616,"Get up."],[3616,3707,"Come on."],[3707,3862,"Let's leave this place forever."],[3862,4062,"It's a shithole."],[4099,4262,"Look Clyde."],[4262,4391,"Thank you so much"],[4391,4592,"for helping me out and everything."],[4658,4750,"But that doesn't mean I believe"],[4750,4838,"any of your"],[4838,4992,"bomb bullshit that you're pushing."]],"65":[[41,237,"You guys can go."],[237,266,"But I have"],[266,412,"unfinished business."],[412,521,"Liam!"],[521,613,"Don't just stand there."],[613,788,"Get your ass over here and help me."],[1121,1322,"In your dreams, Jay."],[1368,1514,"You drove this company"],[1514,1659,"into the ground for years."],[1659,1843,"And you still expect me to serve you?"],[1843,2047,"Go fuck yourself!"],[2289,2448,"You watch how you"],[2448,2648,"talk to me, little boy."],[2681,2882,"You think these are the only investors"],[2882,3082,"I have lined up?"],[3094,3386,"Jay, the King Kingsley,"],[3482,3657,"does not go out without a fight."]],"66":[[75,187,"I reached out"],[187,433,"to at least a dozen other investors."],[533,738,"And they all took the bait."],[946,1172,"If you stay with me,"],[1251,1401,"I will make sure"],[1401,1609,"that you are in charge"],[1609,1726,"of negotiating"],[1726,1981,"every single one of those contracts."],[2064,2264,"All we need is one,"],[2264,2469,"and we are golden."],[2560,2756,"Most importantly,"],[2898,3098,"I believe in you."],[3098,3299,"I believe in me, too."],[3645,3762,"I'm not letting you greedy jerks"],[3762,3891,"keep playing me like a fool."],[3891,4012,"Mr. Kingsley,"],[4012,4137,"you better promote me,"],[4137,4266,"or I swear to God,"],[4291,4491,"I'll have you me too'd by tomorrow."],[4508,4671,"Of course, Honey Bunny."],[4700,4833,"I would totally promote you."],[4892,5092,"If you stick with me, stick with us."],[5130,5326,"I'll make sure you get"],[5326,5455,"the biggest..."],[5455,5593,"most special promotion ever."],[5593,5709,"Okay?"],[5776,5976,"Forget these fools."],[6222,6285,"Hey, Clyde."]],"67":[[734,838,"Let me go!"],[838,1080,"Hey, hey! Let me go, okay?"],[1080,1172,"This whole place, it's"],[1172,1338,"about to blow in five minutes."],[1338,1447,"This,"],[1447,1693,"can go one of two ways, Clyde."],[1780,1876,"One,"],[1876,2060,"the building does blow up"],[2060,2202,"and you die."],[2206,2302,"Two,"],[2302,2469,"the building doesn't blow up,"],[2469,2594,"the authorities arrive,"],[2594,2719,"and you get arrested."],[2740,2873,"Either way,"],[2873,3065,"you lose."],[3924,4262,"No, no!"],[4525,4629,"Rough morning,"],[4629,4754,"but it happens."],[4754,4917,"Come on, let's grab some lunch."],[5263,5309,"What’s wrong?"],[5309,5426,"Where’s Clyde?"],[5426,5584,"I thought he’d be out by now."],[6514,6614,"You go ahead, Mr. Todd,"],[6614,6715,"I've got to find Clyde."]],"68":[[33,204,"Clyde!"],[279,404,"Clyde?"],[1209,1288,"What are you doing?"],[1288,1388,"Let him go!"],[1388,1530,"Ivy, what are you doing here, no!"],[1530,1664,"No, get out! Go!"],[1664,1718,"Go!"],[1718,1793,"Aww."],[1793,2010,"What a couple of love birds!"],[2010,2052,"Get her!"],[2052,2097,"No, no."],[2097,2289,"Don't you dare lay your hand on her!"],[2289,2402,"Run!"],[2402,2573,"No, let go of her, you sick fuck!"],[3244,3357,"Ivy..."],[3357,3503,"I'm so sorry."],[3503,3591,"If it wasn't for me,"],[3591,3737,"you and the baby would be safe."],[3812,3908,"I failed you."],[3908,4016,"Aww."],[4016,4170,"They're going to have a baby."],[4170,4383,"How terribly tragic!"],[4383,4579,"What the fuck do you want, Kingsley?"],[4600,4763,"What do I want?"],[5113,5242,"I want you"],[5242,5422,"to suffer!"],[5455,5580,"That's what I want!"],[5605,5747,"Do you have any idea how bad"],[5747,5847,"you fucked me today?"],[5947,6185,"I built this company from the ground up."],[6185,6327,"And now, because of you"],[6327,6485,"I'm going bankrupt."],[6556,6698,"Who are you working with?"],[6698,6956,"Who ordered you to do this to me?"],[6956,7152,"Who gave you those fucking files?"],[7219,7294,"I did."]],"69":[[4,200,"I did."],[200,362,"Dave!"],[362,475,"I'm here to talk to you."],[475,642,"Wait, Mr. Johnson. You have to leave."],[642,767,"The whole place is going to blow."],[767,813,"Go!"],[813,892,"Shut up!"],[1084,1238,"You're working with Clyde?"],[1238,1301,"That's right."],[1301,1413,"You gave him the files?"],[1413,1501,"That's right."],[1551,1751,"I gave him files to give to a lawyer,"],[1789,1943,"but he dropped the ball and exposed"],[1943,2072,"you in front of everyone."],[2147,2277,"What are you two fucking weirdos"],[2277,2352,"up to now?"],[2352,2423,"Hey."],[2473,2590,"Mr. Kingsley,"],[2590,2861,"I was just taking Clyde outside"],[2861,3023,"to have a talk about..."],[3028,3140,"you know, mental health."],[3140,3269,"Mental health?"],[3319,3461,"That's good. That's real good."],[3536,3661,"When I really think about it,"],[3661,3737,"I guess you are"],[3737,3937,"the only one in this entire building"],[3937,4137,"that he'll actually listen to."],[4170,4371,"So I'm going to wish you the best with"],[4458,4583,"talking some sense into this"],[4583,4683,"piece of work."],[4792,4842,"Enjoy."]],"70":[[150,204,"Mr. Johnson,"],[204,392,"the bomb is going to go off at 11 a.m."],[392,538,"and we need to get out of here now."],[538,713,"Clyde,"],[713,825,"I just found out my daughter"],[825,984,"Nancy passed away."],[1209,1343,"Nancy?"],[1497,1697,"I, I, I thought she was getting better."],[1735,1931,"I am, I'm so sorry."],[1939,2139,"I just hope she's in a better place."],[2173,2202,"Please."],[2202,2402,"If there's, there's anything I can do."],[2419,2565,"Right now,"],[2565,2711,"I need you to do this for me."],[2711,2877,"What’s this?"],[2877,3023,"Evidence of Kingsley's"],[3023,3169,"illegal business dealings."],[3490,3599,"I've been gathering stuff"],[3599,3732,"over the last few years."],[3732,3899,"Take it to a lawyer"],[3899,4095,"and get them to build a case."],[4095,4225,"Mr. Johnson!"],[4225,4320,"Take Ivy"],[4354,4571,"and get out of here now."],[5013,5180,"Why did he give this to me?"]],"71":[[8,208,"Oh, you fucking cripple!"],[221,421,"You are so fucking dead."],[1601,1705,"Dave,"],[1705,1801,"are you the bomber?"],[1851,1968,"There's an emergency exit"],[1968,2027,"out to the right."],[2027,2214,"Take Ivy, and get out of here!"],[2214,2293,"Now!"],[2293,2494,"Come on, let's go."],[2510,2581,"Come on!"],[2581,2623,"Let’s get out of here."],[2623,2794,"Go, go, go, go!"],[2794,2861,"Dave."],[2861,3007,"Hey Dave, listen to me, okay?"],[3007,3098,"Clyde. -Dave."],[3098,3182,"Get out of here!"],[3182,3282,"Get. -Dave."],[3282,3370,"Out! -Dave!"],[3386,3432,"Get out!"],[3432,3511,"Listen to me!"],[4129,4241,"Mr. Johnson!"],[4283,4408,"You don't have to do this!"],[4421,4562,"We can leave here together."]],"72":[[79,241,"Years ago,"],[241,433,"I co-founded the Victory Group"],[433,592,"with Jay Kingsley."],[592,792,"Everything was going swell"],[846,1076,"until he made a pass at my wife."],[1113,1301,"When I confronted him about it,"],[1301,1505,"he had me demoted to security"],[1505,1705,"and removed me from the board."],[1705,1868,"My wife left me."],[1906,2047,"I couldn't pay my daughter's"],[2047,2160,"medical bills."],[2160,2360,"And now she's gone!"],[2419,2544,"Because of Jay"],[2544,2673,"Kingsley!"],[2740,2877,"Mr. Johnson,"],[2877,3136,"Please, please! Don't do this."],[3228,3428,"I'm sorry, man, don't do this."],[3428,3532,"Now you're sorry?"],[3570,3712,"Now you're sorry?"],[3712,3820,"Were you sorry"],[3820,3962,"when you tried to fuck my wife?"],[4066,4195,"When you ordered me around like a"],[4195,4371,"peasant for 20 years?"],[4479,4587,"You're all evil."],[4587,4658,"All of you."],[4658,4859,"And I'm taking you to hell with me."],[4867,4954,"Please, Mr. Johnson"],[4954,5088,"I've never done anything to you."],[5088,5226,"Please, just let me go."],[5305,5405,"Oh, I’m gonna let you go."],[5647,5755,"Oops."],[5755,5876,"15 seconds."]],"73":[[16,216,"15 seconds."],[291,362,"Ivy."],[362,479,"Come on, we have to go!"],[496,633,"I'm coming home, Nancy."],[742,930,"I'm coming home, sweetheart."],[3728,3837,"Honey?"],[4337,4466,"You okay?"],[4466,4679,"I'm okay, we're okay."],[5347,5492,"That's right, my love."],[5563,5663,"We're okay."],[5697,5789,"We're okay!"],[6110,6197,"Clyde?"],[6327,6464,"Clyde?"],[6539,6656,"What's wrong?"]]}