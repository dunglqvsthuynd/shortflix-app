{"1":[[821,1109,"Well, well, look who it is."],[1109,1280,"Clyde."],[1280,1463,"Didn't you, uh, get fired last week?"],[1476,1643,"I did, I, I got fired."],[1643,1972,"I just got a delivery for the office."],[1972,2227,"You're delivering food now?"],[2227,2527,"Oh, my God, that is so pathetic."],[2602,2840,"You fell hard."],[2840,2994,"Wait, Mark!"],[2994,3169,"Must be so awkward going back"],[3169,3361,"there when they just threw you out."],[3365,3578,"Especially as a delivery boy."],[3578,3666,"Oof."],[3666,3770,"Mark, stop!"],[3770,3878,"Don’t touch me."],[3895,4054,"I don't want to catch your sad."],[4054,4304,"Hey, just listen to me, okay?"],[4304,4354,"Whatever you do,"],[4354,4429,"don't cross that road."],[4429,4629,"Because if you do, you're going to die."],[4704,4771,"What the hell is"],[4771,4896,"wrong with you man?"],[4896,4971,"I'm already late."],[4971,5163,"What, you want me to get fired too?"],[5246,5388,"Loser."],[5634,5830,"Hey, keep that food warm, alright?"],[6886,7048,"My name is Clyde Lane."],[7048,7144,"And three days ago,"],[7144,7399,"I developed a terrible superpower."],[7399,7524,"I see death,"],[7524,7657,"before it happens."],[7657,7920,"How, when, and why."],[7920,8058,"He’s the fourth one."],[8058,8208,"I've tried to save them all,"],[8208,8320,"but they ignored me."],[8320,8575,"Why won’t anyone just listen to me!"]],"2":[[867,946,"What?"],[946,1017,"Hey."],[1034,1109,"Hey!"],[1121,1255,"Hey, you, up there!"],[1255,1351,"Hey, come down!"],[1351,1418,"You're gonna fall!"],[1418,1472,"Hey!"],[1484,1547,"Hey!"],[1605,1655,"Clyde?"],[1718,1793,"It's good to see you, man,"],[1793,1868,"but what are you doing?"],[1868,1947,"Alan, Alan."],[1947,2056,"You see that window washer?"],[2056,2127,"Yeah."],[2127,2227,"He's about to fall, okay?"],[2227,2385,"I can, I can see a timer above his"],[2385,2648,"head that tells me exactly when and"],[2648,2715,"how he's gonna die."],[2715,2806,"And that guy is"],[2806,2952,"is about to die in 10 seconds!"],[2952,3019,"Hey."],[3019,3061,"Hey."],[3061,3128,"Get down."],[3128,3203,"Jesus, Clyde."],[3203,3303,"Get it together."],[3303,3382,"You gotta snap out of it."],[3382,3545,"You sound like a crazy person."],[3641,3678,"Ah!"],[3845,4020,"Holy fucking shit."],[4095,4191,"You just-"],[4229,4404,"What you just said, how did you,"],[4404,4558,"how did you know he was gonna die?"],[4558,5121,"He's the 5th person, I've tried to save."],[5121,5355,"5th in 3 days."],[5701,5768,"Why are you looking at me"],[5768,5864,"like that?"],[5864,6160,"Dude, seriously, what's wrong?"],[6160,6310,"You're scaring me."],[6310,6410,"That death timer..."],[6577,6685,"You have one too."]],"3":[[0,129,"Clyde, what the hell is wrong with you?"],[129,241,"Don't fuck with me like that."],[241,350,"It's not funny."],[350,550,"No, it's not a joke, Alan."],[550,646,"Okay?"],[646,725,"Yours says,"],[725,880,"you're going to die from a heart attack,"],[880,1071,"at 9:25 a.m."],[1071,1180,"Okay, predicting"],[1180,1313,"one random guy's death,"],[1338,1422,"doesn't mean you suddenly"],[1422,1568,"have superpowers."],[1568,1634,"And I've never had heart"],[1634,1764,"problems in my life."],[1764,1964,"You lost your damn mind."],[2006,2235,"Alan, I’ve known you for years."],[2235,2314,"Why would I pull"],[2314,2423,"something this messed up?"],[2423,2623,"Just please trust me, okay?"],[2827,3015,"In the last three days,"],[3015,3107,"I've seen five"],[3107,3319,"people with that exact same timer."],[3420,3620,"And now..."],[3803,3941,"They're all dead."],[3941,4062,"This is bullshit."],[4062,4154,"People don't just drop dead"],[4154,4354,"because you say they will."],[4383,4491,"Maybe if you had spent less"],[4491,4700,"time on comic book doomsday bullshit,"],[4742,4825,"and more on your job,"],[4825,4946,"you wouldn't have gotten fired."],[4946,5067,"Alan,"],[5092,5288,"just get yourself to a hospital, okay?"],[5288,5392,"Just get yourself checked out,"],[5392,5526,"please, for my sake, okay?"],[5526,5655,"Dude, I feel great."],[5655,5834,"No actually, I feel fucking amazing."],[5834,5935,"Or at least I did,"],[5935,6022,"until you showed up"],[6022,6156,"acting like a creep."],[6156,6247,"Maybe everybody at work"],[6247,6335,"was right about you."],[6335,6364,"You know what"],[6364,6585,"they’ve been saying?"],[6602,6731,"That you’re washed up."],[6731,6844,"You used to be good, man."],[6844,6936,"But when was the last time"],[6936,7086,"you actually closed a deal?"],[7086,7203,"Hell, even Liam,"],[7203,7361,"who started as your intern,"],[7361,7474,"got promoted to manager"],[7474,7557,"over you!"],[7557,7716,"It’s not about me, Alan."],[7716,7891,"I swear it's not, okay?"],[7891,7953,"Whatever."],[7953,8083,"I don't have time for this."],[8083,8283,"Thanks for making me late."],[8533,8641,"Those other people who died"],[8641,8879,"were just strangers, but this is different."],[8975,9184,"I can’t lose Alan."],[9409,9555,"I have to save him."]],"4":[[521,721,"Hey."],[738,905,"What are you doing here?"],[905,1105,"Hey, Claire."],[1130,1205,"Didn't think"],[1205,1388,"I'd be back here so soon, huh?"],[1534,1789,"I’ve got a delivery for"],[1789,1985,"Mr. Kingsley."],[2248,2423,"What are you looking at, creep?"],[2464,2577,"You're here to bring food,"],[2577,2777,"not look down my shirt."],[2802,2961,"Oh, no, no, I wasn't."],[2961,3015,"I was, I was-"],[3015,3148,"Is someone bothering you,"],[3148,3199,"babe?"],[3199,3399,"Yes, Liam! This pervert right here."],[3399,3628,"Didn’t I fire your ass last week?"],[3628,3774,"He just showed up,"],[3774,3970,"and he decided to look at my chest."],[3970,4070,"What? No, Claire,"],[4070,4225,"that is not what happened, okay?"],[4225,4295,"I was looking above your"],[4295,4437,"head because you have-"],[4704,4804,"Jesus Christ..."],[4804,4900,"Liam too?"],[4900,5046,"Hello?"]],"5":[[20,191,"Same time, same cause."],[191,383,"Earth to Clyde."],[383,529,"What are you doing here?"],[529,709,"He's dropping off lunch."],[709,880,"He's a delivery boy now."],[880,1101,"Oh, a delivery boy."],[1192,1317,"Wow."],[1351,1580,"It didn't take long for you to just"],[1651,1872,"hit rock bottom, huh?"],[1897,2097,"Cute vest though."],[2156,2356,"Now, be a good little delivery boy,"],[2373,2573,"drop off your food,"],[2590,2790,"and get the fuck out of here."],[2965,3090,"Look, look,"],[3090,3274,"I think you and Claire are in"],[3274,3403,"grave danger."],[3403,3591,"Okay, Liam, I know we've had-"],[3591,3657,"Liam?"],[3766,3970,"Are we on a first name basis?"],[4058,4179,"No!"],[4179,4362,"You are the help!"],[4362,4446,"And you will"],[4446,4596,"address me as"],[4596,4854,"Mr. Wellsley, boy!"],[7069,7236,"Oh my God."],[7323,7394,"Is there a bomb"],[7394,7503,"in this office?"]],"6":[[50,141,"Hey! Hey!"],[141,271,"Hey, listen up, everybody."],[271,446,"Uhm, can I just get your attention?"],[446,588,"Just, just for a second."],[588,734,"Clyde? What are you doing here?"],[742,838,"Didn’t you get fired?"],[900,946,"Yes."],[946,1146,"He was."],[1197,1380,"And now look at him."],[1380,1647,"A sad, needy delivery boy"],[1647,1810,"begging for attention."],[1810,1956,"Uhm, Liam."],[1956,2022,"Mr. Wellsley,"],[2022,2193,"I think there’s gonna be a bomb"],[2193,2277,"that goes off"],[2277,2494,"in this office at 9:30 a.m."],[2494,2565,"We need to get everyone"],[2565,2665,"out of here, now!"],[2665,2715,"Okay?"],[2769,2857,"A bomb?"],[2898,2994,"Oh, gosh."],[2994,3115,"Everybody come in."],[3115,3190,"Morning meeting."],[3190,3232,"Okay."],[3244,3311,"Okay."],[3395,3595,"This..."],[3666,3832,"is why you need to work hard."],[3832,4033,"Y'all remember Clyde?"],[4037,4237,"He used to be a good employee."],[4308,4366,"Hell,"],[4366,4450,"he was my boss,"],[4450,4650,"when I first started working here."],[4700,4813,"But Clyde"],[4813,5000,"got complacent,"],[5000,5201,"and all his clients dried up."],[5263,5438,"And now look at him."],[5438,5638,"He's a starving nobody,"],[5668,5868,"begging for attention so bad"],[5901,6093,"that he makes up a bomb threat."],[6352,6485,"Victory Group security team"],[6485,6652,"is world class."],[6652,6752,"No way someone snuck an"],[6752,6873,"explosive in here."],[6873,7015,"Yeah, chances of a bomb attack"],[7015,7148,"are about the same as us getting"],[7148,7248,"struck by lightning."],[7248,7332,"Or"],[7332,7511,"Clyde getting a real job."],[7620,7757,"Okay, everybody, please,"],[7757,7857,"just listen to me."],[7857,7941,"Everyone, please."],[7941,8112,"Please, I beg, listen to me."],[8112,8262,"Oh, look at him."],[8262,8475,"He's a frickin delivery boy."],[8533,8591,"And apparently,"],[8591,8767,"he can't even do that right."],[8767,8988,"Because he spilled it everywhere."],[10051,10452,"Ah!"]],"7":[[0,200,"Ah!"],[504,704,"These people are horrible."],[825,1026,"But I can’t just let them die."],[1317,1459,"Look,"],[1459,1530,"everybody."],[1530,1730,"I know it sounds crazy,"],[1730,1956,"but I know what I'm talking about, okay?"],[1993,2198,"I can sense when something bad"],[2198,2293,"is gonna happen."],[2402,2494,"Go get Alan, okay?"],[2494,2594,"He’ll back me up."],[2594,2786,"Don't listen to this pervert."],[2786,2923,"He's probably just here to stare down"],[2923,3019,"your shirts."],[3019,3140,"It's not about that"],[3140,3211,"right now! -Hey, hey."],[3211,3357,"What’s the matter, Clyde?"],[3399,3449,"Your wife"],[3449,3549,"not giving it up to you,"],[3549,3741,"since you lost your job?"],[3741,3870,"You're reduced to staring down"],[3870,3920,"chick’s shirts"],[3920,4045,"like a sex offender?"],[4070,4124,"Ugh!"],[4137,4229,"What a creep!"],[4229,4341,"Just get out of here, man."],[4350,4550,"Please, just go get Alan!"],[4579,4700,"He can explain what I can do."],[4700,4763,"Ah!"],[5317,5451,"We're not getting"],[5451,5601,"anyone."],[5668,5759,"Investors"],[5759,5918,"from the Eminent Investment Group"],[5918,6068,"are coming today."],[6068,6289,"It's a huge deal on the line for us."],[6360,6602,"If you screw this up, I swear to God,"],[6635,6781,"the only thing exploding"],[6781,6919,"today will be the bomb"],[6919,7140,"I'm putting on your pathetic bike."],[7140,7203,"Why won't you"],[7203,7340,"listen to me?"],[7340,7490,"What is wrong with you?"],[7490,7670,"There's nothing wrong with him."],[7670,7824,"You are almost forty"],[7824,7949,"and just got fired."],[8008,8212,"Stop embarrassing yourself and just go."],[8229,8375,"I can’t, okay?"],[8375,8475,"Please,"],[8475,8700,"just everybody leave the building."],[8725,8871,"I swear on my life!"],[8871,8913,"Okay, okay,"],[8913,8950,"That's it."],[8950,9063,"I, I'm done with you."],[9063,9280,"If you don't get out of here, I swear,"],[9280,9451,"I am going to hurt you."],[9451,9538,"Mr. Wellsley."]],"8":[[29,141,"What will it take for you guys to"],[141,233,"believe me?"],[233,279,"Huh?"],[329,471,"What will it take?"],[513,613,"If we don’t leave here,"],[613,813,"we are all gonna die!"],[813,842,"That’s it."],[842,984,"That's fucking it."],[1818,2131,"Mr. Wellsley, please believe me."],[2131,2293,"Your lives depend on it!"],[2293,2435,"Shut the fuck up!"],[2731,2827,"Mr. Wellsley, please!"],[2857,2923,"You know how Clyde"],[2923,3057,"gets sometimes."],[3148,3349,"Stupid old fucks."],[3353,3486,"No wonder they're friends."],[3495,3582,"Alan."],[3582,3691,"Thank God you're here, man."],[3691,3841,"Please, please,"],[3841,3949,"tell them what I can do, okay?"],[3974,4154,"Tell them about today."],[4154,4354,"That guy is about to die in ten seconds!"],[4354,4429,"You gotta snap out of it."],[4429,4550,"You sound like a crazy person."],[4900,5013,"Holy fucking shit."]],"9":[[112,275,"What the hell are you doing today?"],[275,333,"If you keep acting"],[333,458,"like a complete madman,"],[458,579,"you're gonna get me fired."],[579,700,"I don't want to be a DoorDasher"],[700,779,"in my forties."],[779,855,"Alan!"],[913,1134,"Tell them about the window cleaner."],[1167,1326,"Okay, tell them about the"],[1326,1401,"death timer."],[1401,1505,"It's real."],[1505,1689,"Please, Clyde, stop."],[1689,1835,"For your own good."],[1835,2122,"Look, everybody in here has a timer"],[2135,2173,"that says"],[2173,2252,"they're going to die"],[2252,2456,"from an explosion at 9:30!"],[2473,2527,"Right."],[2527,2573,"And earlier,"],[2573,2673,"you told me I was going to die"],[2673,2869,"from a heart attack at 9:25."],[2869,2982,"Which one is it?"],[2982,3032,"You can't even"],[3032,3232,"keep your own bullshit straight."],[3340,3453,"It's both."],[3453,3524,"It's both."],[3524,3628,"Both are real."],[3628,3795,"Your timer says you're going to die"],[3795,3995,"from a heart attack at 9:25."],[4108,4233,"That's it."],[4233,4446,"I'm done with this craziness."],[4675,4717,"Get your"],[4717,4917,"batshit crazy friend out of here,"],[5025,5159,"or I'm gonna fire"],[5159,5359,"you too."],[5422,5497,"Come on."],[5497,5572,"I'll walk you out of here."],[6076,6164,"I'm not going anywhere."],[6164,6239,"Okay?"],[6239,6410,"After everything we've been through."],[6410,6594,"Why don't you believe me?"],[6594,6673,"Look,"],[6673,6744,"I think if we get you"],[6744,6961,"to the hospital now, you still have time."],[6973,7119,"Give it a rest."],[7119,7244,"I'm trying to help you."],[7244,7303,"And you're telling me"],[7303,7436,"I'm about to drop dead?"],[7436,7482,"Yes."],[7482,7753,"Is this some stupid, sick, jealous thing?"],[7753,7866,"Because I still have my job?"],[7866,7962,"Is that what this really is?"],[7962,8145,"No, it is not some stupid"],[8145,8212,"jealousy thing."],[8212,8412,"I'm trying to save your life, man."],[8466,8621,"I didn't fucking ask you to."],[8621,8758,"Get out of my face."]],"10":[[1146,1347,"Can someone clean this shit up?"],[1347,1484,"And Claire!"],[1484,1685,"File a complaint with DoorDash."],[1689,1889,"I want this delivery boy fired."],[2110,2193,"Listen up."],[2193,2335,"This is not a drill."],[2335,2456,"There's a bomb in the building."],[2456,2698,"It's going to go off at exactly 9:30."],[2698,2857,"Everyone needs to evacuate."],[2857,2902,"Now!"],[2902,2982,"Damn!"],[2982,3136,"Clyde’s fully snapped."],[3136,3261,"Yeah, psycho."],[3261,3461,"Hey, if you're gonna talk shit,"],[3490,3636,"at least say it to his face."],[3636,3807,"Please exit the premises."],[3807,3891,"This is not a dri-"],[3891,3945,"Clyde!"],[4045,4170,"Are you serious right now?"],[4170,4304,"Yes, 100%."],[4304,4375,"I swear to you-"],[4375,4525,"You’re dead, moron!"],[4525,4621,"Clyde, are you out of your"],[4621,4758,"fucking mind?"],[4758,4892,"Get away from the intercom!"]],"11":[[0,137,"Get away from the intercom!"],[137,279,"Mr. Kingsley!"],[283,471,"Uh, Clyde has completely"],[471,571,"lost his mind."],[571,746,"He’s scaring everyone."],[746,934,"Trying to convince us all that,"],[934,1121,"there’s going to be an explosion here"],[1121,1197,"at 9:30."],[1201,1351,"Mr. Kingsley, it's true. Okay?"],[1351,1463,"There is an explosion"],[1463,1605,"happening at 9:30 a.m."],[1605,1785,"That’s enough!"],[1785,1981,"I need you to shut your fucking mouth"],[1981,2089,"and get the fuck out of here, okay?"],[2089,2160,"The people from"],[2160,2273,"Eminent Investment Group"],[2273,2414,"is already on their way."],[2414,2577,"And your bullshit, your craziness"],[2577,2727,"is the last thing anyone needs."],[2727,2957,"Mr. Kingsley, I am not crazy, okay?"],[2965,3153,"I guarantee you this is happening."],[3153,3219,"This is true!"],[3219,3294,"Okay?"],[3862,3966,"Security!"],[3966,4129,"Hold this man and call the authorities."],[4129,4187,"No-"],[4258,4396,"Don't even bother."],[4396,4517,"Okay?"],[4517,4658,"If none of you believe me."],[4658,4758,"Fine."],[4758,4825,"Stay."],[4825,4934,"See what happens."],[4934,5063,"I, for one,"],[5063,5217,"am leaving."],[5918,6064,"What's my wife doing here?"]],"12":[[37,204,"Oh no, I forgot"],[204,371,"Ivy was coming here today."],[617,817,"Here you go, honey."],[1101,1192,"Okay."],[1192,1276,"Stop, stop you’re"],[1276,1363,"wrinkling my blouse."],[1363,1434,"Look,"],[1434,1547,"I have an important meeting"],[1547,1680,"at your old office today,"],[1680,1893,"and I can't deal with any distractions."],[1914,2006,"I know that building"],[2006,2106,"gets a lot of deliveries,"],[2106,2256,"so if you get sent there,"],[2256,2373,"just do me a favor."],[2373,2565,"Don't mention that we're married."],[2565,2644,"All right?"],[2644,2748,"Of course, honey."],[2748,2865,"Yeah. -Okay."],[3265,3420,"Love you."],[3732,3878,"Mr. Todd!"],[3878,3983,"Ms. Lyndon!"],[3983,4033,"Nice to meet you."],[4033,4137,"Thanks for having us."],[4137,4283,"Let’s give a warm welcome to"],[4283,4416,"Xavier Todd and"],[4416,4508,"Ivy Lyndon from"],[4508,4763,"Eminent Investment Group!"],[5263,5405,"If Ivy stays, she'll die"],[5405,5522,"along with everyone else."],[5547,5693,"I need to get her out of here."],[5747,5822,"Ivy..."],[5822,5914,"Miss, uh..."],[5914,5989,"Lyndon!"],[5989,6106,"Please come with me."],[6106,6177,"There's actually an"],[6177,6306,"emergency situation."],[6335,6535,"Let me escort you off the premises."],[10794,10952,"What the hell are you doing?"],[10952,11040,"Let me go,"]],"13":[[0,45,"Clyde."],[45,154,"What the hell are you doing?"],[154,275,"Let Ms. Lyndon go."],[316,475,"My apologies."],[475,692,"This delivery boy's having himself"],[692,788,"a rough morning."],[788,875,"Liam!"],[875,1076,"I want him out of my sight."],[1355,1443,"How about some coffee?"],[1443,1580,"We have bagels."],[1580,1722,"That sounds like a plan."],[1835,1893,"Hey, Ivy!"],[1893,1960,"Look, there's a bomb"],[1960,1997,"in the building!"],[1997,2139,"We need to get out of here now!"],[2139,2323,"Let go of her, you fucking lunatic!"],[2398,2560,"There's gonna be an explosion-"],[2560,2723,"You two quit standing around"],[2723,2831,"and come help me!"],[2898,3007,"No, no!"],[3007,3098,"Ivy!"],[3407,3495,"Emily!"],[3520,3591,"Where the hell do you think"],[3591,3670,"you're going?"],[3670,3782,"I don't know about you,"],[3782,3991,"but I don't plan on dying at my desk."],[4008,4154,"Don't tell me you actually"],[4154,4216,"believe him."],[4216,4320,"Maybe he's lying."],[4320,4425,"Maybe he's not."],[4425,4625,"Either way, better safe than sorry."],[4637,4754,"I don't want my last moments"],[4754,4946,"to be working at The Victory Group."],[4946,5063,"Emily, get back here."],[5063,5171,"You're still on the clock."],[5259,5351,"You-"],[5455,5630,"Hey, where do you think you're going?"],[5630,5714,"People."],[5714,5797,"Hey!"],[5797,5926,"Come on."],[5926,6014,"Ms. Lyndon!"],[6014,6039,"Come on."],[6039,6101,"We have to go."]],"14":[[54,208,"Fucking hell, Clyde!"],[208,337,"Did you take this delivery just"],[337,421,"because you knew I’d be"],[421,492,"working here?"],[492,571,"Ivy, this-"],[571,734,"this is bigger than your job, okay?"],[734,938,"I’m trying to save our lives!"],[938,1042,"Oh please."],[1042,1180,"You’re jealous of Xavier,"],[1180,1301,"who’s just my boss,"],[1301,1430,"and so you’re trying to sabotage"],[1430,1501,"my meeting."],[1501,1634,"It’s not going to work."],[1634,1718,"Ivy, Ivy!"],[1718,1889,"Ivy, I’m not jealous okay!"],[1947,2027,"Of all the people,"],[2027,2210,"I thought you’d believe me!"],[2736,2936,"Mr. Todd, just ignore him."],[3053,3349,"Clyde's been struggling."],[3374,3557,"Whatever the case may be,"],[3557,3653,"a potential bomb threat"],[3653,3774,"is no trivial matter."],[3774,3941,"The woman who left had a point."],[3941,4016,"It would be smart to take this"],[4016,4137,"more seriously."],[4137,4266,"Absolutely."],[4266,4341,"Around here,"],[4341,4446,"safety first."],[4446,4567,"Always."],[4654,4692,"You said there's"],[4692,4800,"going to be an explosion."],[4800,4975,"Yes, Mr. Todd, absolutely."],[4975,5176,"You need to evacuate right now."],[5192,5338,"And you should take Ms. Lyndon here"],[5338,5434,"with you."],[5434,5522,"Please."],[5522,5618,"Not so fast."],[5709,5834,"How do you even know this?"],[5834,5976,"Where's your proof?"],[5976,6110,"Where's the bomb located?"],[6110,6227,"Who planted it?"],[6227,6377,"I, I, I don't know, I'm sorry."],[6502,6685,"So no location,"],[6685,6840,"no suspects,"],[6840,7015,"just blind panic?"],[7015,7178,"You really expect us to drop everything"],[7178,7269,"based on nothing?"],[7269,7478,"Look, I know, I get it."],[7478,7716,"It sounds crazy, but..."],[7899,8033,"I can see a death timer."],[8033,8133,"Okay?"],[8133,8333,"Above every single person's"],[8333,8541,"head, I see when they're going to die."],[8541,8646,"And right now,"],[8646,8858,"everybody here is going to die at 9:30"],[8858,8929,"from an explosion."],[9280,9459,"A death timer!"],[9613,9809,"Of course."],[9809,9943,"Are you hearing this?"],[9943,10135,"Like I said,"],[10135,10335,"Clyde isn’t well."],[10335,10506,"I'll take care of him, sir."],[10506,10623,"Come on, buddy, let's go."],[10623,10689,"They got a meeting to get to."],[10689,10844,"Stop-"],[11294,11382,"Mr. Todd."],[11432,11544,"In 30 seconds,"],[11757,11928,"This man, right here,"],[11928,12091,"is going to have a heart attack"],[12091,12187,"and die!"]],"15":[[4,137,"That's it!"],[137,337,"All I've done is try to help you."],[417,437,"You know,"],[437,542,"I really thought we were friends."],[542,675,"Alan, I-"],[675,750,"You what?"],[750,842,"You've been jammering on"],[842,930,"about my death"],[930,1021,"all morning."],[1021,1172,"Are you really that jealous?"],[1172,1284,"Because I'm done."],[1284,1434,"We're done."],[1434,1480,"Do you know why"],[1480,1543,"he's so obsessed"],[1543,1689,"with getting Ms. Lyndon to leave?"],[1689,1743,"No, no, no."],[1743,1889,"Because she's his wife!"],[2002,2093,"And as for me,"],[2093,2193,"I'm not going to die."],[2256,2381,"See this shit, Clyde?"],[2381,2502,"I could do this all day."],[2502,2560,"No, stop!"],[2560,2673,"That’s how healthy my heart is."],[2673,2715,"Stop!"],[2894,2982,"No, no, no, no."],[2982,3128,"Alan!"],[3128,3336,"No, no, Alan, no!"],[3449,3649,"See, I told you!"],[3870,4049,"He's having a heart attack right now!"]],"16":[[12,87,"Hey."],[112,175,"Hey."],[175,329,"Hey, buddy."],[467,734,"Shit, he’s not breathing."],[775,909,"He must be dead."],[1092,1276,"Alan's not dead."],[1276,1422,"He's just passed out."],[1422,1622,"Probably from all the dancing."],[1697,1768,"Clyde,"],[1768,1864,"it was your hysterics"],[1864,1968,"that caused this."],[1972,2081,"Me?"],[2102,2277,"Did Clyde just predict this?"],[2314,2523,"No, no way."],[2523,2665,"That’s ridiculous."],[2665,2886,"It’s just a freak coincidence."],[3687,3837,"You’ll be fine in no time, buddy."],[3837,3891,"Okay."],[3891,3958,"Clyde’s nonsense"],[3958,4079,"probably just stressed you out."],[4079,4149,"All right."],[4149,4216,"Good work."],[4300,4450,"You know,"],[4450,4583,"mornings aren't usually"],[4583,4783,"like this around here."],[4917,5063,"What do you say we get back"],[5063,5188,"to that meeting, huh?"],[5188,5280,"I'm ready."],[5280,5397,"You ready?"],[5397,5547,"Don't worry about it, Mr. Kingsley."],[5547,5718,"I can't judge an entire company off"],[5718,5847,"one employee's actions."],[5960,6118,"Let's get started. -Yeah."],[6118,6202,"This way."],[6202,6385,"After you."],[6485,6660,"Okay."],[6727,6806,"Hey."],[7328,7419,"Hey, hey."],[7419,7524,"Hey, hey, ah-"],[7590,7724,"Ivy! -Clyde!"],[7736,7878,"What the fuck are you trying to do?"],[7878,8058,"I'm trying to save your lives."],[8291,8433,"Wake the fuck up!"],[8433,8541,"I've never been more awake"],[8541,8625,"in my life."],[8725,8867,"What?"],[8942,9109,"Do you even know why you went"],[9109,9171,"from being a"],[9171,9313,"five time sales champion"],[9359,9496,"to getting fired?"],[9496,9638,"Why?"],[9638,9830,"Because you're a fossil."],[9830,10068,"The game changed, but you didn't."],[10114,10272,"Mr. Kingsley handed"],[10272,10414,"all his clients off to me."],[10422,10664,"In fact, your best pal, Alan."],[10664,10764,"He was pretty happy"],[10764,10898,"to steal from you, too."]],"17":[[145,308,"You all knew?"],[308,508,"You were hiding this from me?"],[588,663,"We didn't exactly"],[663,784,"have to hide."],[930,1042,"I mean, come on,"],[1042,1155,"Mr. Oblivious here"],[1155,1326,"didn't suspect a thing."],[1347,1547,"Okay, I get it."],[1605,1755,"So you were all ganging up on me"],[1755,1893,"from the start, huh?"],[1893,2089,"Well, you can all go to hell."],[2327,2444,"As for you,"],[2444,2602,"get out of my way."],[2602,2836,"Because I have got to save my wife."],[2907,2977,"Grab him!"],[2977,3040,"Ivy!"],[3048,3136,"Ivy!"],[3203,3315,"Let me go!"],[3315,3403,"Get somewhere safe"],[3403,3503,"while you still can!"],[3632,3778,"So here’s what I’m thinking,"],[3778,3978,"about this investment."],[4016,4070,"Ivy!"],[4079,4124,"Ivy!"],[4124,4237,"Hold on, hold on."],[4383,4504,"I’m sorry."],[4504,4729,"I’ll be right back."],[4863,4996,"Get off me!"],[5401,5543,"Stay back, stay back!"],[5547,5693,"I swear I'll kill you."],[5801,5889,"Clyde!"],[5960,6072,"Clyde?"],[6126,6327,"That's enough!"]],"18":[[1455,1655,"Get off me!"],[1985,2064,"There,"],[2110,2277,"there was no explosion?"],[2277,2548,"No explosion, no fire, no destruction,"],[2548,2694,"no big boom."],[2694,2865,"You dragged me out here for nothing."],[2865,3011,"No, no, no, no, no."],[3011,3115,"This doesn't make any sense."],[3115,3315,"It should have happened."],[3670,3870,"The timer above Ivy's head is gone."],[3912,4049,"Did I lose my power?"],[4049,4208,"Something is seriously wrong"],[4208,4304,"with you, Clyde."],[4304,4421,"Take your crazy theory"],[4421,4504,"somewhere else."],[4529,4650,"I need to get back to work."],[4700,4821,"Damn it."],[4821,4996,"I got distracted by all that yelling"],[4996,5125,"and it didn’t go off."],[5217,5301,"Fuck it."],[5397,5572,"They get a little more time."],[5689,5964,"And then they’re blown to pieces."]],"19":[[271,400,"Oh no, it didn't stop."],[400,525,"It just got delayed."],[525,688,"Wait, wait, wait!"],[688,796,"Ivy, Ivy, Ivy!"],[796,988,"The bomb is still going off, okay?"],[988,1188,"It just somehow got delayed."],[1222,1401,"Jesus, Clyde, just leave me alone"],[1401,1576,"and let me do my job."],[1576,1772,"I've been preparing for this for months."],[1805,1918,"No, Ivy."],[1918,2114,"This office is a time bomb."],[2114,2260,"Look, I get it right?"],[2260,2344,"You love your work,"],[2344,2464,"but at the end of the day,"],[2464,2565,"it's just money, okay?"],[2565,2631,"Please."],[2631,2823,"It's not worth your life."],[2823,3023,"Oh, Clyde."],[3069,3190,"You still don’t get it,"],[3190,3299,"do you?"],[3390,3524,"Money is everything."],[3524,3591,"Ivy..."],[3595,3716,"Do you even have any idea"],[3716,3820,"how much we spend"],[3820,3916,"every month?"],[4016,4062,"Ivy..."],[4062,4245,"Mortgage, car loans, utilities,"],[4245,4396,"groceries and all the junk"],[4396,4575,"you blow money on."],[4575,4775,"It's about ten grand per month."],[4813,4896,"It was fine back when you"],[4896,5025,"were bringing in real money."],[5025,5113,"But now,"],[5180,5313,"you don't even have a real job."],[5359,5572,"My job is the only reason we have"],[5572,5680,"food on the table."],[5722,5772,"I'm sorry."],[5772,5834,"Okay?"],[5834,5926,"I didn't mean-"],[5926,6060,"God damn you, Clyde!"],[6202,6281,"You know I could’ve"],[6281,6481,"lost my job over this, right?"],[6644,6890,"If Mr. Todd decides to fire me,"],[6894,7119,"we won't be able to survive."],[7165,7369,"I'm sorry I’ve neglected you."],[7378,7474,"I've been-"],[7565,7728,"I've been a terrible husband."],[7728,7928,"I have, and I promise"],[7957,8049,"I will do better."],[8049,8249,"I will, but right now, please,"],[8266,8441,"please, you just have to trust me, okay?"],[8441,8625,"Because this bomb, it’s gonna go-"],[8625,8808,"Oh my God!"],[8808,9009,"There is no bomb."],[9129,9309,"I swear to God,"],[9309,9455,"I can't lose my job today"],[9455,9693,"because we really need this money."],[10068,10268,"For the three of us."]],"20":[[120,187,"You’re-"],[187,408,"Yeah, Clyde."],[437,638,"I’m pregnant."],[829,950,"I’m gonna..."],[1030,1138,"I’m gonna be a dad."],[1138,1343,"And it’s time to start acting like one."],[1343,1543,"Now, calm down,"],[1543,1680,"and let me go in there"],[1680,1851,"and close this deal."],[1889,2043,"If she won’t leave,"],[2043,2181,"I’ll find the bomb myself."],[2181,2344,"Ivy, I swear,"],[2344,2565,"I’m going to save you and our baby."],[2827,2969,"Want some?"],[2969,3140,"I thought you left, Emily."],[3140,3324,"I did, but"],[3324,3524,"your little bomb didn’t go off."],[3649,3849,"Besides, the last time I ditched early,"],[3849,4049,"Mr. Kingsley docked my pay."],[4220,4421,"Honestly, I kind of wish this"],[4421,4621,"place had exploded."],[4621,4738,"Now I have to go back and work with"],[4738,4867,"these idiots again."],[4938,5030,"Where the hell did she"],[5030,5138,"get those chips?"],[5138,5221,"The closest store is"],[5221,5317,"a ten minute walk,"],[5317,5384,"and she wasn't gone"],[5384,5505,"long enough to go there."],[5588,5747,"Clyde, you coming?"],[5809,6097,"Uh, yeah, no, I’ll..."],[6160,6314,"I’ll be right there."]],"21":[[433,629,"So, genius,"],[629,738,"wasn’t this place supposed to"],[738,875,"blow up at 9:30?"],[930,1130,"What time is it now, huh?"],[1247,1384,"Yeah."],[1785,1956,"Where the hell did they put Alan?"],[1956,2060,"He was dead."],[2060,2131,"I saw him."],[2131,2314,"Hey, what did you do with Alan?"],[2314,2515,"Oh, great question."],[2519,2673,"Hey, hey."],[2673,2811,"Has anyone seen Alan?"],[2811,3011,"Uh, maybe he got blown up."],[3240,3290,"Stop trying"],[3290,3445,"to freak these people out."],[3445,3591,"You saw Alan doing jumping jacks,"],[3591,3649,"right?"],[3670,3862,"The guy’s perfectly fine."],[3862,4062,"So quit being a salty bitch"],[4062,4250,"and get the fuck out of here."],[4279,4421,"Bunch of idiots."],[4421,4562,"Who the hell"],[4562,4859,"stays in an office with a bomb threat?"],[4859,4975,"Okay, listen,"],[4975,5188,"everybody, it wasn't a false alarm, okay?"],[5188,5392,"The bomb is still going off."],[5422,5593,"It just got delayed somehow."],[5593,5822,"I don't know, but now it's 11 am-"],[5822,5955,"Jesus Christ, Clyde."],[5955,6122,"Know your place!"],[6122,6260,"I don’t need to remind you,"],[6260,6364,"you got fired."],[6393,6539,"So go!"],[6552,6719,"They're never gonna believe me."],[6719,6798,"Fine."],[6798,6965,"I'll find the bomber myself."],[6965,7165,"Anything to save my wife."],[7228,7365,"I wonder how she's doing in there?"]],"22":[[129,225,"Sorry, I, uh,"],[275,429,"I gotta take this."],[1247,1447,"I'm sorry, Mr. Todd."],[1447,1539,"I should have told you"],[1539,1618,"about my marriage."],[1618,1664,"I just,"],[1664,1864,"I wanted to keep things professional."],[1868,2014,"And besides, I,"],[2014,2089,"I never knew"],[2089,2289,"he would make a scene like that."],[2323,2423,"Ivy, relax."],[2423,2569,"It's not your fault."],[2569,2740,"He just happened to be here for delivery."],[2740,2786,"There's no way"],[2786,2969,"this could have been planned."],[2969,3082,"Besides,"],[3082,3123,"he doesn't have"],[3123,3324,"the power to ruin this deal."],[3332,3532,"Thank you for being so understanding."],[3578,3778,"The thing is, Ivy,"],[3870,3983,"I already knew."],[4070,4175,"About your marriage,"],[4175,4266,"about Clyde."],[4266,4337,"You did?"]],"23":[[29,120,"Ivy,"],[120,283,"you must have noticed."],[283,483,"I've grown"],[529,596,"quite fond of you"],[596,796,"over the years."],[800,1001,"So I did a little bit of research."],[1067,1209,"I was curious"],[1209,1351,"what kind of special man won over"],[1351,1568,"someone so brilliant?"],[1568,1768,"So stunning as you."],[1839,1985,"Oh."],[1985,2185,"But, Clyde, he,"],[2198,2281,"you could do so much"],[2281,2377,"better than him."],[2377,2527,"I mean,"],[2527,2644,"the guy's not all there."],[2644,2731,"Clyde's a good man."],[2731,2957,"He's just, you know, is having a bad day."],[2990,3132,"Hey,"],[3132,3236,"it's not my place to judge"],[3236,3436,"your personal decisions,"],[3524,3641,"but this isn't going to change the way"],[3641,3841,"I feel about you."],[3853,3995,"Ivy,"],[3995,4145,"you deserve more."],[4145,4304,"A better life."],[4304,4366,"Someone who actually"],[4366,4504,"sees your worth."],[4537,4738,"Someone,"],[4775,4975,"like me?"]],"24":[[162,367,"Okay, Mr. Todd, you're my boss."],[367,588,"Well, least I'm not crazy."],[700,863,"Really."],[863,1063,"Why are you so loyal to him?"],[1238,1430,"I’m gonna ask you to come with me."],[1430,1614,"We got a surprise for you."],[1614,1701,"Come on."],[1968,2110,"All right, people!"],[2135,2256,"It is time to show"],[2256,2439,"Mr. Todd and Ms. Lyndon"],[2439,2594,"what a tight knit,"],[2594,2798,"high energy family we are."],[2798,2894,"Y'all ready for a"],[2894,3003,"dance performance?"],[3036,3186,"Aye aye, Captain."],[3186,3374,"I can't hear you."],[3382,3578,"-Aye aye, Captain. -Dumbass."],[3595,3720,"Who said that?"],[3791,3945,"Clyde, was that you?"],[3945,4091,"What the hell are you doing here?"],[4154,4233,"You know what?"],[4233,4312,"Never mind."],[4312,4362,"Okay."],[4362,4600,"The priority is to show our investors"],[4600,4750,"our culture"],[4750,4934,"of mandatory dance routine."],[4934,5005,"What is this?"],[5005,5184,"Fucking kindergarten?"],[5184,5384,"Stupid fucking corporate bullshit."],[5484,5705,"Man, she really hates working here."],[5797,5880,"Wait."],[5880,5972,"Could Emily be"],[5972,6172,"the one who planted the bomb?"],[6235,6368,"All right team,"],[6368,6569,"let's get moving."],[6639,6840,"Alan, you’re alive!"],[6840,6948,"Come here."]],"25":[[221,300,"What doesn't kill you only"],[300,442,"makes you stronger, right?"],[442,588,"Look, Clyde,"],[588,663,"I think it was a"],[663,788,"minor heart episode."],[796,875,"I've had heart problems"],[875,934,"for the past year."],[934,1017,"Didn't tell anyone."],[1080,1197,"And Mr. Kingsley,"],[1197,1292,"if he found out,"],[1292,1380,"he’d think I was a liability"],[1380,1501,"and have me fired."],[1501,1693,"Luckily, someone grabbed my meds"],[1693,1839,"and gave me a few when I was out."],[1839,1939,"I'm good as new."],[1939,2077,"Scary stuff though."],[2077,2152,"I think I may have even"],[2152,2281,"stopped breathing for a second."],[2406,2506,"Alan."],[2506,2535,"Okay."],[2535,2640,"Whatever you do,"],[2640,2861,"do not join in this dance, okay?"],[2861,2969,"Your timer, it's changed."],[2969,3232,"Now it says you die at 9:55."],[3232,3390,"Jesus, Clyde, again with this?"],[3390,3453,"I'm done"],[3453,3536,"with your paranoia."],[3536,3620,"Alan, look,"],[3620,3807,"you're out of your meds, okay?"],[3807,3958,"I don't want to lose you again."],[3958,4045,"Not like this."],[4045,4175,"Get off me, Clyde."],[4175,4287,"If you really cared about me,"],[4287,4375,"you shut your mouth"],[4375,4483,"about my condition."],[4483,4579,"Mr. Kingsley can't"],[4579,4679,"know about my heart."],[4679,4733,"Alright,"],[4733,4925,"Alan, you're our best dancer."],[4925,5046,"Need you up at the front, buddy."],[5046,5142,"Wait, wait, wait, wait, wait."],[5142,5280,"No, no, no, no, no, I'm begging you."],[5280,5430,"Please just sit this one out."],[5430,5555,"I said get off of me!"],[5555,5634,"Are you jealous of my"],[5634,5705,"dance moves too?"],[5705,5914,"Hey, hey, listen to your friend, okay?"],[5930,6047,"I need you to fuck off."],[6047,6222,"I want you out of here."],[6222,6348,"I can't leave yet."],[6348,6535,"I need to save Ivy and the baby."],[6535,6715,"Look, Alan."],[6715,6886,"I'm sorry, okay?"],[6886,7015,"I don't know what else I can do."],[7015,7215,"If you are this determined to die,"],[7253,7349,"I can't stop you."]],"26":[[0,187,"All right, everyone, it's showtime."],[187,375,"Just like how we practiced."],[375,575,"Aye aye, Captain."],[942,1142,"Fuck my life."],[1180,1309,"Why didn't these assholes just"],[1309,1434,"die like they're supposed to?"],[1447,1589,"Could it be her?"],[1589,1768,"Did she plant the bomb?"],[1768,1893,"What if something went wrong"],[1893,2043,"and she had to reset the timer to"],[2043,2135,"11 o’clock?"],[3440,3524,"Hey, hey, hey, hey!"],[3524,3595,"Whoa, whoa, whoa!"],[3595,3782,"Alan, please stop this, okay?"],[3782,3883,"Your heart can't take it."],[3883,4083,"Let him dance!"],[4099,4304,"He was fine until you interrupted him."],[4333,4496,"Clyde!"],[4496,4592,"Get the hell out of here"],[4592,4792,"or I'm gonna call the cops."],[5017,5167,"I need to stay here."],[5167,5292,"I need to stop the bomb"],[5292,5392,"and save my wife."],[5422,5655,"All right, team, let's keep this going."],[5797,5880,"Mr. Kingsley, Mr. Kingsley,"],[5880,6047,"look at this energy."],[6047,6206,"This is what loyalty looks like."],[6206,6306,"No one works harder here"],[6306,6364,"than I do."],[6364,6431,"No one!"],[6431,6535,"You're killing it!"],[7094,7290,"Get up, Alan!"],[7290,7469,"Come on!"],[7469,7582,"We need you."],[7582,7724,"I won't let you down, sir."],[7724,7924,"Victory Group for life!"]],"27":[[191,375,"Holy shit."],[375,571,"He was right!"],[588,792,"So Alan only has three minutes"],[792,888,"left to live?"],[1155,1255,"Liam!"],[1255,1355,"Call an ambulance."],[1355,1539,"Why don't we go back into my office?"],[1539,1643,"Alan is going to be fine."],[1643,1689,"He's fine."],[1689,1956,"We have the best medical insurance"],[1956,2010,"in the business."],[2010,2168,"Come on, come on."],[2168,2248,"He's being silly."],[2248,2398,"Come on."],[2398,2448,"Right."],[2502,2606,"Sure."],[2731,2831,"Let's go."],[3028,3224,"Okay."],[3224,3424,"Come on."],[3837,3874,"All right."],[3874,4054,"Ambulance is on its way."],[4054,4124,"Come on."],[4124,4225,"Get him out of here, y’all."],[4225,4387,"Off of company property."],[4387,4575,"Outside, now!"],[4650,4779,"I’m off."],[4859,5042,"You know it doesn't matter, right?"],[5042,5138,"He's going to be dead"],[5138,5242,"in three minutes."],[5405,5459,"Is Clyde"],[5459,5659,"actually not crazy?"],[5663,5864,"He just predicted Alan's death."],[5864,5976,"Does that mean there's actually"],[5976,6064,"a bomb?"],[6089,6185,"Oh, God."],[6185,6310,"I'm not ready to die."]],"28":[[183,358,"Something happens to Alan,"],[358,513,"it's on you."],[513,663,"What?"],[663,779,"Are you stupid?"],[779,996,"I tried warning him, okay?"],[1009,1126,"He didn't listen."],[1126,1326,"And you know why?"],[1359,1559,"It's because he was terrified."],[1564,1693,"He was so scared"],[1693,1864,"that you were gonna fire him"],[1864,2035,"because of his heart condition."],[2035,2214,"This toxic company killed him."],[2214,2293,"Not me."],[2510,2610,"Mr. Todd, Ms Lyndon,"],[2610,2811,"I'm really sorry about this."],[2857,2994,"Can you just give me one minute?"],[2994,3148,"Okay, I'm gonna be right back."],[3148,3228,"Of course."],[3228,3357,"Employees come first."]],"29":[[709,900,"How's Alan?"],[900,1084,"I had him carried outside."],[1084,1201,"He should be in the ambulance"],[1201,1388,"by now, sir."],[1388,1589,"He's gone."],[1639,1830,"I'm so sick of your negativity."],[1830,2031,"I'm sure Alan is fine."],[2056,2156,"Look, I get it."],[2156,2281,"You're upset you got fired."],[2281,2356,"Move on, grow up."],[2356,2402,"No, no, no, no,"],[2402,2560,"I'm upset because nobody"],[2560,2761,"is listening to me."],[3028,3228,"Talk to me."],[3274,3474,"What?"],[3691,3891,"He’s dead."]],"30":[[12,187,"So Clyde was right."],[187,316,"He said Alan was going to die"],[316,367,"and boom!"],[367,513,"He's dead."],[513,688,"Look, look, look."],[688,784,"Listen up."],[784,917,"Everyone calm down."],[917,1017,"Okay."],[1017,1188,"This office is in one of the"],[1188,1472,"safest areas in the entire city, okay?"],[1472,1772,"There is no bomb."],[1772,2014,"Now, today's been tough."],[2018,2177,"It's been tough."],[2177,2427,"But let's not make it worse"],[2427,2698,"by feeding into silly rumors."],[2756,2957,"And let's just get back to work."],[3065,3236,"This is why I fired you."],[3236,3436,"You can't sell anything."],[3482,3641,"Not even a bomb threat."],[3641,3787,"You are one horrible salesman."],[3870,3966,"What?"],[4016,4116,"You know that's crazy."],[4116,4333,"I was the sales champ here,"],[4400,4562,"for five years straight."],[4562,4650,"And you know what?"],[4650,4825,"If you remember, that only changed"],[4825,4904,"when you and Liam"],[4904,5055,"started talking to my clients."],[5055,5138,"Whoa!"],[5192,5397,"Wait right there."],[5397,5522,"When an employee"],[5522,5830,"gets complacent, it is my job"],[6022,6172,"to motivate them."],[6172,6243,"Simple,"],[6243,6443,"when you really think about it, right?"],[6769,7065,"Where exactly did Alan die?"],[7111,7311,"He died on the way to the hospital, sir."],[7361,7586,"Okay, so not on company premises."],[7632,7732,"His family can’t sue!"]],"31":[[12,208,"You know, it doesn't matter"],[208,408,"where he died, right?"],[433,538,"He had a heart attack"],[538,717,"because you forced him to dance."],[717,817,"You're liable."],[817,1005,"So they're saying it's natural causes"],[1005,1188,"instead of a workplace injury."],[1188,1384,"God, capitalism is the worst!"],[1384,1676,"Listen, it's not what you think."],[1705,2077,"Obviously, I'm just trying to figure out"],[2077,2160,"what I'm going"],[2160,2331,"to tell the insurance company."],[2331,2448,"That's all."],[2448,2635,"Look, right now,"],[2635,2940,"let's not focus on horrible rumors."],[2948,3219,"Let's focus on sealing the deal"],[3240,3403,"with Eminent."],[3403,3603,"Because..."],[3762,3958,"that's what,"],[3958,4158,"that's what Alan"],[4175,4375,"would have wanted."]],"32":[[108,304,"I'm sorry."],[342,542,"You, with me."],[1422,1564,"I don't know what kind of fucking"],[1564,1672,"game you're playing today,"],[1672,1772,"but hear this,"],[1847,2047,"I can have your wife fired."],[2143,2268,"In a heartbeat."],[2268,2519,"I have to protect Ivy and her job."],[2519,2756,"No choice but to play along."],[2919,3057,"I'm sorry,"],[3057,3299,"Mr. Kingsley."],[3299,3407,"You won't hear another word"],[3407,3490,"out of me today."],[4621,4767,"What’d that monster have to say?"],[4800,4892,"What do you think?"],[4892,4988,"He wanted me to shut up"],[4988,5125,"about the explosion."],[5125,5280,"What an asshole."],[5363,5472,"I wish this place would just"],[5472,5555,"burn to the ground."],[5747,5943,"What’s up with that huge duffel bag?"]],"33":[[12,212,"What's up with that huge duffle bag?"],[212,329,"She normally only brings"],[329,475,"a small purse to work."],[475,675,"Is that where she's hiding the bomb?"],[679,859,"Clyde!"],[859,1076,"Earth to Clyde! Are you there?"],[1134,1405,"Uh, yeah, yeah, uhm."],[1405,1555,"Listen,"],[1555,1676,"Emily, I, I, I get it."],[1676,1864,"I mean, Mr. Kingsley, he's,"],[1864,2102,"he’s not exactly a saint, right? But,"],[2156,2293,"there are good people who work"],[2293,2427,"in this office."],[2427,2552,"You know that, right?"],[2552,2711,"Not exactly a saint?"],[2727,2927,"He’s straight up a demon!"],[3274,3340,"Hey."],[3407,3578,"Yea, yeah, I’ll be there in a minute."],[3578,3653,"I got to go."],[4704,4829,"Oh my God."],[4829,5013,"It sounds like a time bomb."],[5313,5426,"Ivy,"],[5426,5551,"it really does seem like your husband"],[5551,5647,"has a superpower."],[5680,5797,"He just predicted that heart attack!"],[5797,5976,"No, no, it was just a coincidence."],[5976,6114,"But what if it wasn’t?"],[6147,6256,"That would make the bomb,"],[6364,6439,"real."],[6439,6581,"Please, just ignore him."],[6581,6685,"It’s nonsense."],[6690,6802,"So you’d rather stick with someone"],[6802,6927,"who’s full of shit than be with me?"]],"34":[[4,100,"So you’d rather stick with someone"],[100,279,"who’s full of shit than be with me?"],[291,429,"Mr. Todd."],[429,629,"I know that Clyde seems strange,"],[650,775,"but he is a good guy,"],[775,884,"and he means well."],[888,1088,"I'm not leaving him."],[1609,1851,"Sorry about all the chaos."],[1856,2056,"Let's get back to business, huh?"],[2097,2252,"Hold on."],[2252,2369,"What about the bomb threat?"],[2369,2477,"Before we talk business,"],[2477,2631,"I need to make sure we're safe."],[2631,2752,"Mr. Todd,"],[2752,2861,"I can assure you"],[2861,3119,"I have everything under control."],[3144,3315,"Here at Victory Group,"],[3315,3632,"we take the safety of our visitors"],[3632,3832,"very seriously."],[4004,4141,"I'm sure you do."],[4141,4254,"But after everything that's happened"],[4254,4462,"today, I'd like to go see for myself."],[4479,4650,"Of course."],[4650,4733,"Whatever you say."],[4733,4829,"Absolutely."],[4829,4975,"Right this way, sir."],[4975,5109,"You coming?"],[5109,5205,"Yeah."],[5205,5288,"Let's see how much you"],[5288,5351,"love your husband"],[5351,5568,"after I expose him in front of everyone."]],"35":[[533,604,"Mr. Todd!"],[604,759,"Clyde,"],[763,871,"I gotta know."],[871,963,"This explosion you keep"],[963,1055,"talking about."],[1055,1184,"What's the deal with it?"],[1184,1334,"Do you believe me?"],[1334,1509,"Look, this is real."],[1509,1672,"Okay, this is, this is happening."],[1672,1801,"A bomb is going to go off"],[1801,2002,"in this building at 11 a.m, and the,"],[2039,2168,"the best thing you can do is,"],[2218,2389,"is get Ivy out of here now."],[2435,2598,"Clyde, I'm not going anywhere"],[2598,2698,"until you give us something"],[2698,2877,"we can actually work with."],[2877,3019,"You got to show us some evidence."],[3019,3128,"You have to trust me."],[3128,3165,"Okay?"],[3165,3294,"I, I wouldn't lie about"],[3294,3365,"something like this."],[3386,3628,"Mr. Kingsley, let's be real here."],[3649,3757,"How do you expect us"],[3757,3941,"to invest in your company"],[3941,4049,"when you can't even keep your"],[4049,4137,"office safe?"],[4137,4204,"Clyde,"],[4300,4404,"just drop this."],[4404,4475,"Okay?"],[4525,4604,"Uhm, look."],[4604,4713,"Think of it this way."],[4713,4842,"I know we've had our issues,"],[4842,5042,"but I was your intern."],[5055,5242,"Now, look how great I am."],[5242,5355,"You should be proud."],[5413,5593,"Look, Clyde."],[5593,5797,"I'm sorry that I didn't do more"],[5868,6051,"to make you feel valued,"],[6051,6164,"but I'm going to make it up to you."],[6164,6185,"Because I'm"],[6185,6277,"going to kick in a little"],[6277,6418,"extra severance."],[6418,6477,"All right?"],[6477,6673,"But please, can we just drop"],[6673,7027,"this whole bomb scam bullshit?"],[7048,7232,"No, it's not about the money, okay?"],[7232,7432,"It is not a prank."],[7469,7549,"This is happening."],[7549,7682,"This is real."],[7682,7799,"We have to find the person"],[7799,7903,"who planted the bomb"],[7903,8033,"before it's too late."],[8033,8149,"He's right."],[8237,8433,"It seems the person behind this"],[8433,8633,"would be right here in this office."],[8746,8958,"Tell me, who do you think it is?"],[9100,9234,"I don't think I should be"],[9234,9355,"making accusations, but-"],[9355,9455,"Cause I'll tell you who"],[9455,9655,"I think it is."],[9688,9826,"I think Clyde was the one who"],[9826,9880,"planted the bomb."]],"36":[[0,125,"Mr. Todd, Clyde wouldn't do"],[125,208,"something like that."],[208,304,"Yeah, Mr. Todd,"],[304,383,"that's insane."],[383,542,"Okay? Why would I plant the bomb"],[542,684,"in the building my wife is in?"],[684,875,"Who knows?"],[875,1026,"But it seems reasonable"],[1026,1226,"to suspect the guy who just got fired."],[1267,1418,"Honestly,"],[1418,1522,"I think you need to be searched."],[1522,1676,"Mr. Todd, please."],[1676,1851,"It’s, this is a bit much."],[1851,1985,"Is it?"],[1985,2185,"I'm trying to keep everyone safe."],[2281,2435,"Mr. Kingsley."],[2435,2523,"Do I have your permission"],[2523,2635,"to search his belongings?"],[2694,2852,"Be my guest."],[2852,3053,"No, no, no, you guys have no right."],[3065,3265,"Look Clyde, this is in fact,"],[3278,3420,"a real bomb scare,"],[3420,3620,"and according to you, it is,"],[3645,3778,"we have to check everything."],[3778,3870,"It's mandatory."],[3870,3966,"And you know that."],[3966,4149,"Dave, get in here!"],[4241,4346,"Yes, sir."],[4504,4729,"Mr. Kingsley, what can I do for you?"],[4733,4884,"We have reason to believe that"],[4884,4967,"Clyde here"],[4992,5167,"has planted a bomb."],[5167,5330,"So I want you to look through his little"],[5330,5413,"delivery bag and"],[5413,5472,"make sure there's"],[5472,5663,"nothing suspicious."],[5663,5780,"A bomb?"],[5914,6114,"That sounds intense."],[6114,6177,"Maybe we should let the"],[6177,6272,"cops handle this."],[6343,6477,"I like my idea better."],[6477,6644,"Why don't you listen to what I tell you?"],[6644,6752,"Hey, wow."],[6752,6844,"Hey."],[6844,7011,"Mr. Johnson, are you okay?"],[7011,7198,"Yeah, I'm fine."],[7198,7282,"And how many times have I"],[7282,7319,"told you,"],[7319,7453,"please call me Dave."],[7453,7565,"Come on."],[7565,7695,"You were my mentor when I"],[7695,7770,"arrived here."],[7816,7907,"Wouldn't be right to call you"],[7907,8033,"by your first name."],[8103,8270,"It was a long time ago."],[8270,8324,"Sorry, man."],[8324,8525,"I gotta search you bag."],[9159,9330,"No, no, no, no, no, no, no, no, no."]],"37":[[0,66,"No, no, no, no, no, no."],[108,158,"Please,"],[158,291,"Mr. Johnson, just don't open that,"],[291,342,"okay?"],[342,542,"Good God, it’s the bomb!"],[550,613,"Jesus!"],[613,738,"He's gonna blow us up."],[738,846,"No -No, no,"],[846,950,"it's not a bomb."],[955,1038,"Trust me."],[1038,1146,"What the hell is it?"],[1146,1305,"Dave, get it out of here."],[1305,1480,"Clyde, what's in the box?"],[1480,1601,"Please don't open it."],[1601,1743,"Clyde, give me the box."],[1743,1893,"Honey, please don't make me."],[1893,1914,"I-"],[1914,2110,"Give it to me."],[2110,2173,"Baby,"],[2173,2268,"stop, okay, don’t."],[2289,2352,"Don't."],[2352,2435,"Please."],[2435,2515,"Oh!"],[2669,2852,"Oh my God."],[2852,2961,"Have you been taking"],[2961,3061,"inappropriate pictures"],[3061,3207,"of the girls in the office?"],[3207,3386,"Fucking stalker creep."],[3457,3657,"I always knew you were a dirty perv."],[3682,3883,"You motherfucker!"],[3895,3999,"Ivy,"],[3999,4095,"are you sure your husband’s"],[4095,4191,"such a good man?"],[4270,4383,"Clyde,"],[4383,4583,"how could you do this to me"],[4600,4767,"after all I've done for us?"]],"38":[[0,208,"Honey, it's not like that, okay?"],[233,442,"Look, these are photos of us."],[1343,1543,"Ivy,"],[1555,1755,"you’re the love of my life."],[1785,1856,"Being with you"],[1856,2031,"makes me feel like the luckiest"],[2031,2231,"man on earth."],[2302,2423,"And I know"],[2423,2552,"things have been rough lately,"],[2552,2677,"with you working overtime to"],[2677,2723,"help us,"],[2723,2865,"but,"],[2865,2986,"I promise,"],[2986,3186,"this is only temporary."],[3203,3257,"I'm going to"],[3257,3557,"do everything I can to lighten your load."],[3661,3862,"Our future is bright,"],[3862,4062,"my love."],[4099,4141,"Why didn't"],[4141,4341,"you tell me about these?"],[4387,4525,"Well, I,"],[4525,4617,"I got the photos"],[4617,4671,"for our wedding"],[4671,4817,"anniversary."],[4817,4988,"It's supposed to be a surprise."],[4988,5130,"Well, you've ruined it now,"],[5130,5284,"silly."],[5697,5826,"Wow."],[5826,5901,"Look at them."],[5901,6039,"Not sure he's a great salesman,"],[6039,6239,"but he's definitely a good husband."],[6252,6393,"Yeah, right?"],[6393,6468,"I feel kind of bad"],[6468,6527,"I thought he was going to"],[6527,6623,"blow this place up."],[6648,6877,"Ivy, can we talk?"]],"39":[[20,204,"I'm so sorry, Ivy."],[204,291,"I shouldn't have tried to come"],[291,437,"between you and Clyde like this."],[437,629,"He’s a good man,"],[629,788,"and he deserves someone like you."],[788,896,"It’s okay."],[896,1042,"And I agree,"],[1042,1188,"he is a good man."],[1455,1614,"So,"],[1685,1881,"I won’t bother you anymore."],[1881,2031,"Clyde has my respect."],[2143,2248,"And I wish you two nothing"],[2248,2323,"but the best."],[2402,2590,"Thank you, Mr. Todd."],[2957,3157,"She's been gone forever."],[3169,3328,"It has to be her."],[3328,3528,"I'm checking her bag."],[4012,4087,"Clyde."]],"40":[[50,312,"Mr. Johnson, what's up?"],[342,538,"I need to talk to you outside."],[658,754,"Uhm."],[809,867,"Sure thing."],[1509,1655,"Well if it isn’t a couple of"],[1655,1739,"limp dicks."],[1739,1860,"What are you up to?"],[1860,1976,"Mr. Kingsley,"],[1976,2248,"I was just taking Clyde outside"],[2248,2410,"to have a talk about"],[2414,2527,"you know, mental health."],[2527,2656,"Mental health?"],[2706,2848,"That’s good, that’s real good."],[2923,3048,"When I really think about it,"],[3048,3123,"I guess you are"],[3123,3324,"the only one in this entire building"],[3324,3524,"that he’ll actually listen to."],[3557,3666,"So I’m going to wish you the best"],[3666,3757,"with uhm,"],[3845,3970,"talking some sense into this"],[3970,4070,"piece of work."],[4179,4241,"Enjoy."],[4241,4279,"Thanks."],[4279,4325,"Yeah."],[4375,4487,"See you around."],[4558,4642,"Or not."],[4683,4771,"Is it me?"],[4771,4988,"Or does that look like the necklace"],[4988,5063,"I sent you?"],[5063,5226,"It wasn’t cheap you know?"],[5280,5455,"Yes, it is."],[5455,5618,"And I love it so much."],[5618,5751,"You’re welcome."]],"41":[[1714,1885,"Clyde?"],[1885,1943,"What are you doing in"],[1943,2010,"my bag?"],[2010,2185,"Uhn, uh, uhm."],[2239,2427,"Sorry, I, uhm."],[2427,2544,"I was hungry, I was just"],[2544,2752,"I was looking for, uhm, snacks."],[2752,2840,"Do you, do you have any snacks?"],[2840,2944,"Tough shit."],[2944,3144,"Finished the last one today."],[3211,3282,"Emily,"],[3282,3411,"you can't just walk out like that"],[3411,3611,"during office hours."],[3682,3820,"I was just picking up my package."],[3820,4020,"You were gone for almost 20 minutes."],[4058,4225,"Does it take that long to"],[4225,4425,"walk to the front door and back?"],[4425,4542,"I stopped by the bathroom"],[4542,4625,"on my way back."],[4654,4750,"But what, do I need"],[4750,4950,"a hall pass to take a shit now?"],[5188,5388,"Watch your mouth, Emily."],[5397,5580,"I am your manager"],[5580,5780,"and you will respect me."],[5989,6093,"For what?"],[6093,6197,"For being the biggest kiss"],[6197,6431,"ass to our Lord Jay Kingsley?"],[6898,7098,"Laugh it up."],[7132,7253,"But when Mr. Kingsley hears"],[7253,7311,"about this."],[7436,7557,"you're fired."]],"42":[[0,162,"Oh, I'm so scared,"],[162,312,"Mr. Wet Blanket."],[312,479,"You think I want to be here?"],[479,558,"You don't even pay me"],[558,713,"enough to cover rent."],[713,884,"And you think any of us believe"],[884,1084,"you actually care about us?"],[1088,1180,"Alan died"],[1180,1347,"five minutes ago,"],[1347,1518,"and you did fuck all about it."],[1518,1805,"Do think any of us would follow you?"],[1843,1864,"Yeah."],[1864,1976,"She's right."],[2293,2339,"Emily,"],[2339,2540,"if you don't want to be here, then leave."],[2615,2752,"Good luck finding another job"],[2752,2952,"in this market."],[2965,3090,"I'll be fine."],[3090,3244,"Besides, I'd"],[3244,3445,"rather work in fast food"],[3449,3649,"than work for you."],[3657,3807,"Damn, these Gen Z kids"],[3807,3928,"have some spunk."],[3933,4037,"Emily!"],[4066,4241,"You’re way out of line!"],[4254,4316,"I'm telling"],[4316,4625,"Mr. Kingsley to fire you right now."],[4658,4859,"Please do."],[5109,5276,"Is that a bomb detonator?"],[5855,5930,"What the fuck?"],[5930,6085,"Ivy, don't come any closer!"],[6085,6193,"She has the bomb detonator."]],"43":[[4,158,"Ivy, Ivy, don't come any closer."],[158,308,"She has the bomb detonator!"],[542,633,"She's got a what?"],[633,729,"It's her."],[729,884,"She's the bomber!"],[884,988,"Stay right there."],[988,1151,"What the fuck are you talking about?"],[1151,1217,"You have it!"],[1217,1351,"You have the detonator!"],[1376,1576,"It's a toy, Clyde."],[1818,1968,"It's a toy."],[1989,2110,"Ah, don’t!"],[2189,2314,"My therapist recommended it for"],[2314,2373,"stress relief."],[2373,2485,"I got it off Amazon."],[2485,2648,"Is that a crime now?"],[2706,2794,"Ah!"],[3015,3136,"It’s, it’s, it’s."],[3203,3349,"It's a toy, it's a toy."],[3