{"1":[[154,279,"It's senior Nate Duncan's"],[279,412,"farewell championship."],[454,567,"Can he lead his team to"],[567,704,"back to back victories"],[717,909,"one last time before he graduates?"],[946,1059,"We'll find out tonight."],[1397,1522,"There goes Nate Duncan,"],[1559,1655,"passing it over"],[1693,1839,"to Zach Gates."],[2602,2711,"Goal!"],[2748,2865,"Can you believe it?"],[2865,3065,"Zach Gates has scored the final shot."],[3094,3357,"Freshman superstar gets the win."],[3370,3507,"Move over, Nate Duncan."],[3507,3636,"There's a new MVP"],[3636,3774,"of the Ice Wolves hockey team,"],[3774,3983,"and his name is Zach Gates!"],[5013,5109,"That game was supposed to be"],[5109,5213,"your victory lap."],[5234,5359,"Zach totally stole your moment."],[5701,5822,"It's so not fair."],[5851,5985,"He's the one- - It's done."],[6031,6131,"Nothing I can do now."],[6327,6564,"Nate Duncan, my step-brother,"],[6623,6877,"the one boy I should have never fallen for."],[8566,8700,"You know this is the men's locker room,"],[8700,8746,"right?"],[8779,8879,"You trying to catch the MVP"],[8879,8967,"coming out of the shower?"],[9017,9117,"Zach Gates."],[9142,9330,"The hockey team's resident bad boy."],[9371,9630,"Nate's worst rival and my biggest enemy."],[9763,9864,"Urgent paperwork."],[9876,10009,"Turn it in before 5 p.m."],[10009,10051,"Got it?"],[10076,10243,"Where's my please and thank you, glasses?"],[10272,10372,"You know, the hockey team's assistant"],[10372,10472,"should treat the superstar"],[10472,10535,"with respect."],[10552,10631,"Then why did you steal"],[10631,10748,"Nate's pass on purpose?"],[10773,10902,"He's supposed to be the superstar."],[10902,11010,"This was his last game."],[11061,11177,"Defending your step-brother's honor,"],[11177,11219,"huh?"],[11269,11398,"It's not my fault I'm better than him."],[11440,11561,"Nate Duncan's out."],[11603,11678,"I'm the star player of"],[11678,11774,"Maple University now."],[11795,11986,"Nate will always be the star play