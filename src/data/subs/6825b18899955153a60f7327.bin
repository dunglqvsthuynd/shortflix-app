,454,"or something?"],[467,550,"That's not what happened."],[563,675,"Listen, it's not a good look,"],[717,763,"alright?"],[775,921,"Now, you gotta keep your record clean"],[921,1001,"for rest of the season year,"],[1001,1076,"or it's gonna damage"],[1076,1230,"your career opportunities."],[1276,1351,"Harassing?"],[1368,1534,"They were the ones harassing Jane."],[1634,1710,"You understand?"],[1755,1847,"I understand, coach."],[2448,2652,"Zach, you were amazing out there."],[2681,2740,"Yeah?"],[2765,2894,"Enough to make me your star player?"],[3053,3132,"Nate will always be"],[3132,3244,"the star player to me."],[3311,3370,"Yes,"],[3399,3532,"you're the star player to me."],[3624,3762,"You know, it's tradition for the MVPs"],[3762,3899,"get a kiss from their girl."],[4091,4166,"But I'm not really"],[4166,4270,"your girl though, am I?"],[4270,4333,"So,"],[4408,4500,"you don't have to."],[5526,5647,"Damn, bro, your step-sister"],[5647,5743,"used to follow you around"],[5743,5847,"like a puppy, but now"],[5847,6006,"she can't get her hands off Zach."],[6039,6156,"You must be pissed."],[6156,6222,"Shut up."]],"40":[[337,492,"Melissa, you told Leah and Courtney"],[492,671,"to dogpile on Jane today, didn’t you?"],[692,779,"What?"],[817,988,"Why would I do that, Nate?"],[1030,1101,"I'm a nice girl-"],[1101,1276,"Enough with your lies."],[1317,1438,"I saw everything."],[1447,1509,"I can't believe"],[1509,1639,"I never saw through you before."],[1747,1814,"Nate,"],[1839,1960,"are you serious?"],[1960,2027,"I,"],[2052,2214,"I'm your girlfriend."],[2606,2727,"You really don't"],[2769,2932,"want to piss me off."],[3115,3194,"Otherwise"],[3382,3586,"you're never getting any of this,"],[3720,3795,"ever again."],[3958,4104,"Don't touch me."],[4183,4291,"We're over!"],[4458,4562,"Oh my God."],[4717,4775,"You,"],[4804,4913,"you like her."],[5096,5309,"You like your step-sister!"]],"41":[[16,125,"You like her."],[321,521,"You like your step-sister!"],[713,750,"What?"],[771,825,"Did you"],[859,950,"fall and hit your head"],[950,1092,"extra hard on the ice or something?"],[1092,1230,"What is wrong with you?"],[1230,1380,"She's a pathetic little loser."],[1409,1488,"Don't"],[1514,1630,"talk about her like that."],[1710,1826,"She's the nice girl."],[1826,1981,"She's genuine."],[2031,2185,"Unlike your fake ass."],[2335,2527,"Yeah, Jane is amazing!"],[2690,2781,"Too bad."],[2882,3011,"She's in a relationship"],[3011,3119,"with Zach now."],[3153,3244,"And,"],[3324,3457,"you hurt her so bad."],[3536,3687,"She'd never forgive you."],[3741,3891,"That was your fault!"],[4145,4233,"Aw."],[4254,4362,"Baby."],[4437,4554,"She's still my step-sister."],[4554,4650,"She'll understand."],[4700,4804,"And she'll see that Zach"],[4804,4946,"isn't good for her."],[5146,5280,"Seeing Jane and Zach together"],[5280,5426,"makes you so"],[5447,5530,"jealous."],[5609,5684,"Doesn't it?"],[5793,5868,"First, he"],[5926,6156,"steals your star player title,"],[6156,6260,"and then your"],[6343,6427,"precious"],[6456,6523,"little"],[6594,6677,"girlfriend."],[6835,6906,"It's a shame."],[7015,7152,"You'll never win against him."],[7261,7453,"Not on the rink or"],[7469,7565,"with girls."],[7653,7720,"I mean,"],[7803,8003,"if Zach hadn't rejected me,"],[8112,8258,"I never would have touched you."],[8420,8600,"I'm not the one you should be mad at."],[8687,8787,"Zach is the one who"],[8787,8921,"stole everything"],[8921,9021,"from you."],[9492,9563,"Jane"],[9563,9722,"will come back to me,"],[9809,9947,"no matter what it takes."]],"42":[[116,262,"Cheers!"],[675,771,"Hey, look,"],[771,863,"it's the man of the hour."],[863,1005,"And his beloved girlfriend."],[1067,1134,"Kiss her."],[1288,1426,"Kiss her. Bro, go! - Come on!"],[1426,1497,"What are you doing? - Alright,"],[1497,1547,"calm down."],[1739,1830,"I'm gonna get a drink."],[1830,1876,"Ok."],[2598,2694,"Jane, we need to talk."],[2744,2873,"I don't have anything to say to you."],[2936,3090,"You watched Melissa bully me,"],[3123,3207,