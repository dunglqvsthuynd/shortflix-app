[4133,4187,"brother."],[4187,4379,"And I'm not in charge of her. I don't care."],[4391,4517,"Looks like Nate doesn't care at all,"],[4517,4575,"Jane."],[4587,4688,"I'm curious to see"],[4688,4825,"how you and Zach will end up."],[4863,5059,"Are you the perfect couple or not?"],[5401,5534,"I'd love to kiss Zach."],[5613,5818,"58 seconds is nothing for us."],[6014,6131,"That literature essay?"],[6131,6318,"Guaranteed A+ if we win this."],[6364,6448,"I'll work extra hard"],[6448,6569,"and make it worth your while."],[8437,8608,"Zach's a really good kisser."],[9150,9271,"Hey, what the hell, bro?"],[9396,9522,"Nate, what the hell are you doing?"],[9538,9622,"Nate, let go."],[9672,9755,"Nate."],[9822,9884,"Don't you think"],[9884,9993,"you should be standing here,"],[9993,10143,"holding your girlfriend's hand?"],[10147,10243,"Not right now."],[10301,10452,"I need to have a talk with my sister."],[10452,10527,"Whatever you have to say,"],[10527,10631,"you can say right here."]],"22":[[41,150,"It's a family matter."],[233,329,"Jane, please."],[383,613,"I've wanted Nate to want me for so long."],[654,804,"How can I tell him no?"],[1351,1530,"Zach, I promise this is the last time."],[1584,1685,"I'll be right back."],[1760,1914,"Just wait."],[1943,2106,"Put on my jacket first."],[2648,2844,"Alright, pack it up guys. Party's over."],[3103,3215,"What are you doing?"],[3215,3336,"What are you doing acting like that?"],[3336,3424,"Throwing yourself at Zach"],[3424,3528,"in front of everybody?"],[3557,3745,"It makes you look slutty."],[3745,3978,"Slutty? You're a hockey bro,"],[3978,4058,"you've probably slept with"],[4058,4175,"like half the student body."],[4195,4341,"Besides, let's not pretend that"],[4341,4487,"you and Melissa didn't start it."],[4487,4583,"It's fine if you do it,"],[4583,4700,"but not me and my boyfriend."],[4700,4925,"You're a girl, it is different."],[4942,5034,"People call me a player,"],[5034,5125,"then move on with their day,"],[5125,5301,"but they'll call you a ran-through slut!"],[5342,5513,"Are you really calling me a slut right now,"],[5513,5634,"just for kissing Zach?"],[5638,5751,"You know"],[5751,5930,"that Zach is coming for my MVP spot."],[5935,6106,"You said it yourself last night,"],[6106,6181,"what a dick move it was"],[6181,6318,"that he stole my winning shot."],[6343,6456,"Why him,"],[6481,6606,"of all people?"],[6648,6765,"He's bad news, Jane."],[6798,6898,"I'm just trying to protect you here."],[6919,6952,"Really?"],[6961,7061,"Because it feels like you're trying to"],[7061,7119,"control me."],[7152,7257,"I'm trying to tell you that you need to"],[7257,7382,"break up with Zach."],[7449,7549,"You've slept with him, right?"],[7570,7686,"I swear to God, if he gets you pregnant,"],[7686,7811,"I will-"],[7924,8112,"I thought I knew you, Nate Duncan."],[8166,8241,"I thought you were different,"],[8241,8324,"but you're really just a"],[8324,8479,"selfish, arrogant bastard."],[8571,8700,"You like me anyways ."],[8825,8875,"What?"],[8929,9159,"The stories you wrote about me, I read them."],[9225,9321,"You have a crush on me,"],[9321,9451,"your own step-brother."]],"23":[[25,137,"How does he know?"],[166,291,"What did he read?"],[412,475,"I..."],[475,604,"Well, too bad, Jane."],[638,738,"It's never gonna happen."],[738,863,"I have a girlfriend."],[942,1076,"And I have a boyfriend."],[1151,1301,"Maybe I used to have a crush on you"],[1301,1434,"before we became step-siblings,"],[1434,1605,"but that was a long time ago."],[1647,1751,"Are you sure?"],[1835,1956,"You're really not just with my rival"],[1956,2097,"to make me jealous?"],[2198,2306,"You'd better watch out, Jane."],[2306,2410,"Because sooner or later"],[2410,2606,"he's gonna leave you with a bastard child,"],[2606,2719,"and you'll just become another"],[2719,2882,"college dropout single mother."],[2894,3115,"Don't you dare talk about him like that!"],[3165,3232,"You think you're such a"],[3232,3357,"good judge of character?"],[3357,3482,"What about th