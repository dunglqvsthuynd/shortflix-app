,[8787,8904,"scar herself?"],[8917,9084,"I'm scared of pain, too,"],[9100,9313,"but Nate just doesn't seem to care."],[9597,9793,"Or maybe he never did."]],"25":[[0,291,"You need to confess and apologize,"],[291,375,"and then maybe"],[375,550,"Melissa can find a way to forgive you."],[642,834,"It depends on how sincere"],[834,963,"the apology is."],[1021,1247,"I'm so sick of you always taking her side"],[1247,1438,"when she's so clearly out to get me."],[1509,1693,"Nate, I'm going to ask you one more time."],[1760,1897,"Do you believe her or me?"],[1910,2010,"Because if the answer is her,"],[2010,2156,"then you've lost me forever."],[2477,2702,"I believe what I see with my own eyes."],[2781,2865,"Your necklace"],[2865,3044,"left a bloody wound in Melissa's arm,"],[3044,3290,"and you need to apologize."],[3440,3536,"Fine."],[3641,3712,"From now on,"],[3712,3853,"we'll be just like this necklace."],[3987,4095,"I don't want anything to do"],[4095,4212,"with you anymore, Nate."],[4254,4429,"Jane, don't be like that, I just..."],[4479,4650,"Jane, what the hell happened?"],[4729,4838,"Zach, Melissa broke"],[4838,5030,"my necklace, my dad's necklace."],[5242,5380,"Jane broke the necklace herself,"],[5380,5505,"and used it to stab Melissa."],[5518,5651,"I just wanted her to apologize."],[5655,5789,"Jane won't be apologizing."],[5864,6022,"Let me apologize on her behalf."],[6064,6239,"I can treat that wound for you."]],"26":[[133,325,"Nate, it burns!"],[821,963,"This is your last warning."],[1013,1138,"You two stay away from Jane,"],[1138,1209,"or it's a lot worse"],[1209,1334,"than your arm that gets cut."],[1801,1876,"Would you really?"],[2027,2235,"No, I'm a hockey player not a murderer."],[2235,2439,"Just wanted to scare them shitless."],[3119,3190,"Done."],[3315,3470,"Thank you for sticking up for me today."],[3570,3778,"But did you really never doubt me?"],[3778,3895,"I mean for all you know,"],[3895,4024,"I could be a murderer."],[4112,4254,"You don't seem like the type."],[4254,4341,"And plus I know how much"],[4341,4475,"that necklace means to you."],[4517,4650,"You wear it every day."],[4775,4884,"And you're scared of pain."],[5071,5196,"Every time me and one of the guys"],[5196,5351,"falls on the ice, you flinch."],[5618,5722,"You held those broken pieces"],[5722,5880,"in your hand till you bled."],[6014,6172,"You know all those things about me?"],[6302,6414,"Even Nate didn't."],[6556,6677,"Jane Wellsy,"],[6710,6823,"are you playing dumb,"],[6823,6948,"or are you actually stupid?"],[7015,7132,"Do you really not know?"],[7144,7223,"What?"],[7407,7582,"Glasses, I like you."],[7766,7857,"I like you so much"],[7857,8049,"that I watch everything you do."],[8112,8220,"I watch all your little habits,"],[8220,8329,"what you like,"],[8358,8483,"what you're scared of,"],[8521,8616,"what makes you happy."]],"27":[[367,454,"Ha ha."],[529,604,"You know you really shouldn't joke"],[604,704,"like that."],[838,959,"Pretty good actor, right?"],[988,1071,"You fall for it?"],[1101,1201,"I knew it."],[1238,1384,"Next time you prank me like that,"],[1384,1472,"I won't forgive you."],[1497,1597,"Sure you won't."],[1680,1818,"At least your energy's up."],[1918,2022,"Life is much better without"],[2022,2168,"Nate Duncan, right?"],[2210,2264,"I'm thinking,"],[2264,2369,"why don't you just"],[2435,2606,"leave that guy and hang out with me?"],[2711,2940,"Can you be serious for like one second?"],[2998,3078,"Sure."],[3203,3269,"Stop!"],[3703,3841,"Thank you, Zach."],[3874,4037,"You really saved me tonight."],[4116,4329,"I appreciate the thanks but,"],[4379,4696,"I think I deserve a bit more of a reward."],[4821,4942,"What do you want?"],[4942,5088,"I'm already working on your essay."],[5130,5334,"Yeah, you already owe me that."],[5363,5505,"I want something new."],[5772,5876,"You."]],"28":[[25,112,"What?"],[212,300,"No."],[333,475,"Wait, let me finish."],[513,850,"I want you to wear my jersey to the game,"],[875,1021,"and cheer louder than anybody."],[