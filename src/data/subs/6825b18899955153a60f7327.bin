,"into it."],[1422,1518,"No, no way."],[1530,1609,"I mean,"],[1634,1760,"it wasn't the best I've ever had,"],[1760,1876,"if that's what you're asking."],[2018,2102,"Who am I kidding?"],[2102,2289,"He's the only guy I've ever kissed."],[2410,2573,"You know, most guys will take insults"],[2573,2752,"to their performance as a challenge."],[2798,3053,"Are you insulting me to try and provoke me?"],[3082,3232,"Asking for more?"],[3257,3395,"Are you messing with me again?"],[3395,3507,"I told you no more pranks."],[3511,3545,"It's okay"],[3545,3707,"if you don't think I'm a good kisser."],[3737,3820,"I have plenty of chances"],[3820,4024,"to change your mind."],[4162,4262,"It's getting late."],[4291,4387,"I should get back to my dorm."],[4404,4508,"Don't be late tomorrow."],[4621,4796,"My jersey smells pretty good, so,"],[4821,4979,"don't be afraid to give it a sniff."],[5017,5138,"You're an ass, you know that?"],[5205,5288,"And you love it."]],"31":[[104,250,"Zack Gates is a hockey star,"],[271,379,"a total player."],[379,542,"You can't let yourself fall for him."],[542,692,"You're his fake girlfriend,"],[692,796,"nothing more."],[1317,1555,"But Zach Gates isn't as bad as I thought."],[1580,1701,"He's not arrogant."],[1701,1926,"He's saved me so many times already."],[1985,2206,"He even called my stretch marks pretty."],[2277,2469,"He rejected Melissa, too."],[2485,2665,"Maybe he's not a player at all."],[4608,4854,"Oh my God, what the hell am I doing?"],[4854,4984,"Sniffing Zach Gate's jersey"],[4984,5121,"like a psycho creep?"],[5138,5242,"A couple days ago, I thought"],[5242,5367,"he was my worst enemy."],[5397,5597,"But he does smell nice."],[6193,6414,"I bet you're smelling my jersey right now."]],"32":[[171,354,"Did you hear, Jane Wellsy is wearing"],[354,525,"Zach's jersey to the game tonight?"],[554,675,"Oh my God, really?"],[692,775,"He's never given a girl"],[775,888,"his jersey before."],[1009,1226,"Jane is so not good enough for him."],[1251,1451,"Zach must think she's really special."],[1580,1701,"Are you seriously"],[1701,1872,"sticking up for Jane right now?"],[1956,2152,"I need these bitches on my side."],[2206,2381,"Time to throw Jane under the bus."],[2485,2681,"You have no idea what she says about you"],[2681,2798,"behind your back, Leah."],[2882,3053,"I heard her telling some old skank"],[3053,3165,"that you smell like old sweat,"],[3165,3319,"and you definitely have an STD."],[3386,3470,"What?"],[3516,3603,"That bitch!"],[3628,3724,"And Courtney,"],[3745,3916,"she said your eyes are so far apart"],[3916,4083,"that you look like a lazy-eyed catfish."],[4099,4316,"What? How dare she!"],[4558,4667,"Ladies,"],[4717,4934,"we need to teach this girl a lesson."]],"33":[[3207,3290,"Oh my God."],[3415,3465,"Oh my God,"],[3465,3611,"someone swapped my shampoo!"],[4654,4900,"Oh my God, is that Jane the Virgin?"],[4925,5117,"More like Jane the Slut."],[5130,5276,"She's naked under there."]],"34":[[25,300,"Walking around campus naked, Jane?"],[350,517,"God, you're such a slut!"],[517,650,"Trying to whore yourself up to"],[650,800,"the rest of the hockey team, too?"],[834,1034,"No, my clothes, someone took them."],[1034,1084,"Clothes?"],[1096,1355,"Oh, you mean these granny panties."],[1418,1668,"You want your training bra back, Jane?"],[1914,2010,"Why would you do this?"],[2010,2110,"I don't even know you."],[2118,2214,"Liar!"],[2227,2352,"I know what you said about me."],[2352,2477,"You had this coming."],[2694,2798,"It was you?"],[2915,3086,"Give me back my clothes!"],[3486,3716,"Mean, ugly girls like you"],[3716,3962,"don't deserve to date hockey stars."],[4049,4237,"And look at her arms!"],[4304,4562,"All crinkly like an old lady's."],[4604,4783,"Jane, if I were you, I'd cover that up."],[4829,4975,"You can't hurt me."],[5038,5134,"All you guys are doing is"],[5134,5317,"exposing your own insecurities."],[5476,5651,"How dare you fight back?"],[5939,6101,"Let go of her, now!"]],"35":[[642,775,"I guess one hockey MVP"],[77