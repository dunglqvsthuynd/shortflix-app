{"1":[[816,912,"You wanna go again?"],[1962,2106,"Hey, dear boss."],[2218,2356,"You're so bad."],[4192,4286,"Mrs. Bennett."],[7452,7628,"Darling, are you busy?"],[7734,7817,"Um..."],[7900,8033,"Baby, what are you doing here?"],[8090,8226,"Missed me that much?"],[8274,8336,"Pardon me."],[8404,8538,"Brought your favorite coffee."],[8554,8722,"Figured you need something cold."],[8818,8958,"You shouldn't have."],[8958,9032,"Next time,"],[9094,9238,"just let the maids do it."],[9290,9378,"I wanted to."],[9428,9724,"But that makes my heart ache."],[10388,10516,"Did you have someone over?"],[10516,10678,"Oh, um..."],[10824,11066,"Yeah. Just the client... had a few drinks."],[11346,11490,"What's that sound?"]],"2":[[1050,1345,"Baby, you are so gorgeous."],[1360,1484,"I couldn't resist."],[1594,1678,"And today's your birthday."],[1712,1760,"So..."],[1848,2086,"I prepared a little surprise for you."],[2104,2224,"What surprise?"],[2288,2392,"Wait until the night."],[2432,2506,"Alright?"],[2506,2780,"You will find a beautiful dress"],[2780,2952,"waiting for you at our suite"],[2952,3310,"at the Empire State Building."],[3310,3460,"Once I'm done with that file,"],[3612,3902,"I am all yours."],[4396,4484,"Okay."],[4940,5117,"I'll see you tonight."],[6172,6340,"Shall we continue, hubby?"],[6460,6674,"You've got guts,"],[6702,6740,"don't you?"],[6922,7130,"Isn't that what turns you on?"],[7410,7674,"Iris, Benjamin is mine."],[7690,7882,"He'll only ever be mine."]],"3":[[1054,1107,"Yvette,"],[1288,1425,"your law firm partner in Paris..."],[1464,1538,"I'm in."],[1622,1762,"Can you book me a ticket for two weeks?"],[1768,1900,"That's amazing."],[1900,2168,"Babe, finally! With you on board,"],[2168,2342,"our firm will soar."],[2342,2405,"Yeah."],[3160,3250,"Benjamin,"],[3300,3410,"I never thought"],[3418,3572,"our marriage would come down to"],[3572,3774,"a fifteen day countdown."],[3808,3952,"I wish we'd never met."],[4588,4820,"Madam, Mr. Bennett really adores you."],[4844,5047,"He snapped up this limited edition dress"],[5047,5173,"worth 30,000,000."],[5380,5540,"With no hesitation."],[5540,5632,"Really?"],[5780,5870,"Fireworks!"],[6202,6256,"Iris,"],[6332,6448,"every year on your birthday,"],[6454,6615,"I'll light up the sky with fireworks"],[6615,6736,"to prove my love."],[7472,7568,"Don't you know?"],[7598,7752,"It's Mrs. Bennett's birthday."],[7784,7936,"He does this every year."],[7976,8086,"Mr. and Mrs. Bennett"],[8086,8258,"have been childhood sweethearts."],[8272,8456,"His betrothal gifts back then"],[8456,8712,"included oceanfront estates worth billions."],[8736,8952,"He even donated a kidney for her."],[8984,9170,"The tycoon of love?"],[9170,9256,"No."],[9288,9464,"Nothing gold can stay."]],"4":[[24,92,"Benjamin."],[148,230,"When did the man"],[230,372,"who used to love me"],[372,576,"just stop existing?"],[904,981,"No."],[1016,1152,"I can't let you sign it."],[1152,1280,"I don't want your kidney."],[1280,1362,"Iris, what are you doing?"],[1362,1474,"-Give it back. -No. No..."],[1474,1586,"Give it back!"],[1738,1874,"Prepare for surgery."],[2004,2232,"How am I supposed to repay you?"],[2616,2714,"Sweetheart,"],[2738,2930,"I do this because I care."],[2938,3078,"Without you, I'd die."],[3178,3302,"No one is taking you away from me,"],[3322,3416,"not even death."],[3476,3560,"Because you are"],[3560,3650,"the most important"],[3650,3794,"person in my life."],[4050,4240,"How can I ever repay you?"],[4368,4502,"You don't have to."],[5304,5418,"Iris Kensington,"],[5526,5734,"will you marry me?"],[6106,6178,"Yeah."],[6388,6640,"If you really don't love me anymore,"],[6640,6764,"then as you wish."],[6804,6969,"In fifteen days,"],[7000,7216,"I'll disappear from your world forever."],[7316,7576,"Whatever it is, it will pass."],[7630,7767,"There's another day."],[8146,8226,"Thank you, sir."],[9606,9954,"Find out everything you can on Iris Bennett."]],"5":[[112,182,"Mrs. Bennett,"],[215,350,"this is a candlelight dinner"],[350,616,"specially designed for you by Mr. Bennett."],[616,728,"Please enjoy."],[772,988,"And a Jewel-Top Layered Cake."],[1032,1188,"The cake is wheeled in,"],[1188,1326,"tall, elegant,"],[1326,1535,"glowing with sparklers by the waiter."],[1880,1999,"Happy birthday, my love."],[2362,2454,"Thank you."],[2676,2730,"What's this?"],[2770,2954,"A tiara worn by a queen."],[2954,3122,"10 billion to acquire it."],[3138,3396,"And another 20 billion to customize it"],[3396,3706,"with handpicked diamonds that I polished myself."],[3730,3818,"Do you like it?"],[3950,4086,"It's beautiful."],[4208,4272,"Here,"],[4360,4456,"let me put it on you."],[6164,6444,"How is my wife this beautiful?"],[6524,6765,"Marrying you is the luckiest thing"],[6765,6882,"that ever happened to me."],[7220,7362,"Do you really mean that?"],[7426,7518,"Of course."],[7592,7659,"But,"],[7720,8023,"I think maybe we have more important"],[8023,8158,"matters to discuss."],[9289,9444,"Will you cheat on me?"],[9654,9816,"Iris, my queen."],[10434,10606,"As your loyal knight,"],[10642,10712,"I swear"],[10804,10952,"to love and protect you"],[11018,11164,"until my last breath."],[11417,11531,"Loyalty?"],[11574,11860,"Benjamin, this is so absurd."],[11892,12092,"Did you say the same things to Penny?"],[12154,12445,"May I die in disgrace by every value?"],[14024,14148,"What happened?"],[14346,14440,"Okay. I'm on my way."]],"6":[[16,120,"I'm sorry, baby."],[176,352,"There's an issue with the contracts,"],[392,608,"and I had to go back to work and handle it."],[610,863,"Alright? But when you head home and..."],[863,1020,"I'll see you back, okay?"],[1228,1298,"Ben..."],[2782,2902,"Babe, you said you weren't feeling well."],[2902,3008,"Why are you dressed like this?"],[3388,3496,"It hurts"],[3634,3754,"right here."],[4004,4178,"Only your touch can make it better."],[4242,4308,"You..."],[4400,4594,"Still hungry from this afternoon?"],[4730,4853,"You know me."],[4944,5114,"My appetite is enormous."],[5272,5456,"Your heart is definitely racing."],[5512,5714,"Looks like I'm gonna have to give you"],[5780,5912,"a full body exam."],[5954,6018,"Yeah."],[6693,6806,"Mm..."],[8580,8634,"Benjamin,"],[8634,8774,"every time you said"],[8774,8854,"you were working,"],[8854,9099,"you were here with Penny."]],"7":[[568,692,"Iris, my queen."],[738,880,"As your loyal knight,"],[896,991,"I swear"],[996,1170,"to love and protect you"],[1170,1321,"until my last breath."],[2218,2362,"When exactly"],[2372,2529,"did the Benjamin who was once"],[2529,2731,"willing to give his life for me"],[2758,2884,"disappear?"],[3582,3712,"Sorry, babe."],[3868,3958,"Work stuff."],[3974,4183,"I had to sleep at the office."],[4298,4458,"Guess what I brought you?"],[4674,4796,"Original buttercream"],[4796,5034,"cupcakes from Magnolia Bakery?"],[5098,5194,"Nailed it."],[5302,5466,"Your favorite cakes."],[5498,5650,"You always deserve the best, babe."],[5720,5882,"How could you betray me"],[5882,6088,"and still say such loving words?"],[6148,6268,"So..."],[6362,6502,"To make it up to you,"],[6532,6710,"I decided to book us"],[6766,6928,"a day at Quantum Raceway."],[7100,7150,"Babe,"],[7230,7354,"it'll be a good way to relax."],[7358,7412,"Okay?"],[7462,7600,"No. You should rest."],[7650,7780,"I'll go on my own."],[7792,7818,"No."],[7842,7986,"Babe, no way."],[8084,8172,"Okay."],[8188,8266,"Look,"],[8280,8378,"enjoy the cakes."],[8390,8532,"I'm gonna go shower."],[8532,8648,"And then after,"],[8662,8798,"we can just hang out."],[8822,8925,"Just the two of us."],[8925,8980,"Alright?"],[9440,9730,"Everything you bring me makes me sick."]],"8":[[1910,2124,"Isn't that Mr. and Mrs. Bennett?"],[2136,2326,"What an adorable power couple."],[2376,2482,"Mr. Bennett,"],[2482,2602,"rich, handsome,"],[2642,2844,"loving his wife so badly."],[2872,3054,"Total dream husband."],[3466,3540,"I'm tired."],[3584,3680,"Let's go take a rest."],[5936,6104,"Mr. and Mrs. Bennett?"],[6120,6330,"What a coincidence."],[6606,6669,"Yeah."],[6669,6862,"It's a pleasure to see you too."],[6880,7028,"I warned you."],[7038,7364,"Stay away from my wife."],[8762,8962,"Why you gotta be so tough?"],[8994,9266,"I came all this way just because I missed you."],[9290,9404,"Watch your mouth."],[9404,9599,"Or you will know the consequences."],[9680,9746,"Honey."],[9798,9960,"I'm gonna grab us some water."],[9992,10094,"Go ahead."],[10706,10967,"Miss Ashford."],[11018,11146,"Do you like racing too?"],[11146,11249,"Call me Penny."],[11249,11371,"I don't care for it much,"],[11371,11538,"but my boyfriend loves it."],[11578,11626,"You know,"],[11626,11745,"he actually gifted me"],[11745,11842,"this racetrack."],[11842,11966,"Isn't that sweet?"],[11966,12002,"What?"],[12022,12240,"He gifted you this racetrack?"],[12240,12386,"Are you surprised, Mrs. Bennett?"],[12494,12586,"I..."],[12768,12868,"Benjamin."],[12888,13088,"How could you?"],[13144,13368,"How could you give this racetrack to her?"],[13413,13566,"It was our symbol of love."],[13566,13744,"We fell in love here."],[13782,13949,"You make me sick."]],"9":[[308,438,"What are you two talking about?"],[526,596,"Track."],[626,794,"I was just having a casual chat"],[794,907,"with your wife."],[926,1010,"Iris,"],[1010,1302,"if you dare lay all the cards on the table,"],[1310,1432,"I'll play with you."],[1462,1632,"Do you know Penny's boyfriend?"],[1801,1907,"Um..."],[1910,1944,"Nope."],[2016,2110,"Never heard of him."],[2174,2250,"Here, babe."],[2270,2512,"And as long as I'm Mrs. Bennett,"],[2512,2663,"you'll forever be a mistress"],[2663,2802,"lurking in the shadows."],[3424,3494,"Baby,"],[3542,3728,"I waited on you all night"],[3760,3936,"and I'm totally exhausted."],[3968,4176,"I haven't even eaten anything yet."],[4676,4796,"Just wait."],[5214,5354,"Miss, your boyfriend"],[5354,5608,"prepared this delux set for you. Enjoy."],[5722,5816,"Holy shit."],[5816,6031,"They're all Upper East Side desserts."],[6031,6152,"So expensive."],[6158,6280,"I'm jealous."],[6296,6342,"Well,"],[6342,6475,"I never thought you would prepare"],[6475,6598,"all of this,"],[6598,6792,"just by me casually mentioning it."],[6832,7064,"You're so sweet."],[7198,7352,"Love you, hubby."],[7392,7460,"Tonight"],[7460,7646,"I've got a new surprise for you."],[8398,8494,"Even more tempting"],[8494,8648,"without clothes on... kneeling."],[8698,8955,"You're SO bad."],[8955,9096,"I love it!"],[9176,9358,"You two disgust."],[9430,9590,"Wo."],[9590,9691,"I wonder what"],[9691,9902,"Mrs. Bennett's racing skills are like."],[9958,10076,"Do you wanna race me, dear?"],[10094,10182,"What?"],[10364,10524,"That's a terrible idea."],[10526,10642,"My wife's no good at racing."],[10642,10687,"Sure."],[10688,10763,"She's..."],[10788,10880,"I'd love to."],[11086,11174,"Babe."],[11248,11360,"Don't worry, honey."],[11586,11638,"After all,"],[11638,11806,"I'm just playing with Penny."],[11832,11878,"Penny,"],[11904,12000,"what are you trying to do?"],[12000,12086,"Benjamin,"],[12102,12248,"I'm gonna make you see."],[12304,12525,"I'm the one who's truly right for you."]],"10":[[3792,3840,"Iris,"],[3894,4024,"go to hell."],[5182,5302,"Go to hell."],[5782,5844,"Iris!"],[5932,5992,"Iris!"],[5998,6083,"Iris."],[6112,6222,"Baby, easy."],[6222,6326,"I got you."],[6326,6384,"Slowly."],[6816,6862,"Are you okay?"],[6862,6950,"Did you get hurt?"],[7070,7126,"Oops."],[7534,7676,"You should be grateful that she's okay."],[7682,7748,"Or I swear,"],[7748,7900,"I'll make your life a living hell."],[7966,8072,"Cut the act!"],[8126,8311,"I know everything."],[8684,8770,"Babe, you..."],[8858,8940,"You know what?"],[9012,9147,"Of course I know."]],"11":[[0,162,"Of course I know."],[308,496,"I know that you love me the most."],[744,798,"Babe,"],[888,978,"of course I do."],[1026,1166,"You are the most important"],[1166,1298,"person in my life,"],[1298,1370,"remember?"],[1716,1782,"Look at you,"],[1804,2010,"roughing up your little mistress."],[2020,2173,"Such a touchy scene."],[2190,2416,"Almost makes it seem like you still love me."],[2540,2660,"Babe, are you okay?"],[2726,2770,"Hey."],[2946,3092,"Iris, you okay?"],[3150,3218,"Iris!"],[3226,3292,"Boss,"],[3354,3522,"you can't go to the ladies' bathroom."],[3522,3662,"I'll go check on her."],[4762,5058,"Wow. You're so fragile."],[5146,5394,"Can you even satisfy Mr. Bennett?"],[5418,5488,"I mean"],[5552,5626,"in bed."],[5910,5972,"You seem"],[5972,6076,"pretty concerned about"],[6076,6166,"my husband, huh?"],[6246,6296,"Iris,"],[6390,6638,"you're boring and prudish."],[6662,6857,"You don't deserve a man like Mr. Bennett."],[6908,7054,"And who do you think does?"],[7054,7100,"You?"],[7250,7526,"I'm just saying if a man can't be satisfied,"],[7550,7650,"he'll cheat."],[7676,7840,"You should give the title of Mrs. Bennett"],[7840,7898,"to someone"],[7898,8096,"who's not afraid to have a little fun."],[8270,8445,"Think about it. Hmm?"],[9300,9492,"Babe, aren't you out yet?"],[9492,9652,"Are you really okay?"],[9652,9768,"I'm not feeling well."],[9768,9848,"I'm going home."],[10234,10355,"I told you."],[10380,10498,"She's already left-"],[10522,10598,"Penny Ashford!"],[10598,10754,"You've crossed the line today."],[10754,10838,"I told you."],[10838,10916,"If you behave,"],[10916,11022,"you can have everything"],[11022,11146,"you ever wanted."],[11194,11308,"Upper class identity,"],[11320,11446,"money and job."],[11478,11600,"But if this happens again,"],[11600,11815,"I'll make sure your life is a living hell!"]],"12":[[100,152,"I swear."],[152,302,"I swear you've got it all wrong."],[302,480,"I would never dare to cross your wife."],[480,560,"Please."],[726,826,"Hey."],[912,1142,"Haven't you always wanted to do it?"],[1182,1266,"Right here."],[1666,1840,"Wore that thing that you like..."],[1966,2070,"Right underneath..."],[2230,2316,"Just for you."],[5682,5762,"Benjamin."],[5812,5915,"If you've already"],[5915,6030,"given our special place"],[6030,6170,"to somebody else,"],[6200,6274,"then what is the point"],[6274,6392,"of holding on to the gifts"],[6392,6486,"you gave me?"],[9890,9970,"Hi."],[10022,10182,"I'd like to sell these items."],[10446,10546,"How can I help you today?"],[10982,11070,"It's you."]],"13":[[46,230,"Small world! Do you work here?"],[302,382,"Sort of."],[532,630,"You having trouble?"],[720,966,"Not at all, just recycling some junk."],[1942,2126,"You're not gonna check them?"],[2232,2312,"For you?"],[2382,2462,"No need."],[2902,2982,"Thanks."],[4480,4706,"I heard that her husband is cheating."],[5090,5282,"13 days left."],[5290,5435,"Babe? Why did you sell"],[5435,5570,"all the gifts I gave you?"],[5610,5770,"Alexander saw them at the pawn shop."],[5770,5863,"I can't believe."],[5866,6196,"I saw the news about the kids in Africa."],[6222,6382,"I wanted to help, so..."],[6430,6570,"I sold the jewels to charity."],[6682,6762,"Thank God."],[6860,6992,"You really freaked me out."],[7030,7186,"I thought you didn't love me anymore."],[7432,7512,"Look,"],[7586,7732,"if you want to donate something,"],[7752,7880,"you can just tell me,"],[7910,7990,"alright?"],[8002,8142,"I'll handle the money stuff."],[8180,8260,"But..."],[8292,8377,"I don't understand why you sell"],[8377,8532,"our most cherished things"],[8552,8712,"You can sell some of the jewelry but..."],[8832,8924,"Not this."],[8978,9130,"This is our wedding ring,"],[9170,9250,"alright?"],[9280,9322,"Can't let you"],[9322,9450,"just let it go like that."],[9762,9940,"It was an honest mistake."],[10006,10074,"Okay."],[10180,10260,"Fine."],[10300,10380,"But..."],[10470,10566,"I'll let it slide."],[10586,10706,"If it happens again,"],[10752,11006,"I will have to teach you a lesson."],[11960,12040,"Babe?"],[12062,12140,"What does this mean?"]],"14":[[86,166,"Nothing."],[210,306,"I'm just..."],[370,510,"Closing some old accounts."],[602,682,"I see."],[812,1002,"Why didn't you come home last night?"],[1122,1422,"Oh, um, about that..."],[1480,1646,"There was a mare at the racetrack."],[1646,1800,"That was having complications."],[1800,2006,"I helped the staff deliver the foal and..."],[2062,2132,"It was touch and go."],[2132,2342,"But everything turned out just fine."],[2362,2490,"Delivering a foal?"],[2546,2870,"More like planting seeds for your mistress!"],[2890,2986,"Look,"],[3130,3262,"I even took some pictures"],[3380,3540,"Iris, hey."],[3586,3668,"Are you okay?"],[3700,3772,"What's wrong?"],[3772,3822,"Benjamin."],[3822,3958,"Your lies make me feel"],[3958,4070,"worse than your betrayal."],[4070,4186,"You've been feeling off."],[4186,4312,"How about I take you to the hospital?"],[4312,4542,"I'm fine, it's you-"],[4542,4798,"You smell horrendous. Go take a shower"],[4860,5012,"Okay, okay, fine."],[5012,5080,"My bad."],[5148,5196,"Go now."],[5766,5860,"Hey, Ben."],[5860,6050,"It's the bachelor party tonight."],[6050,6162,"Why aren't you here?"],[6346,6526,"I'm staying home with Iris, she's-"],[6566,6680,"She's not feeling well."],[6680,6950,"Glued to your wife 24/7."],[7012,7132,"But tonight's special."],[7132,7280,"You gotta be here!"],[7292,7380,"Is it Ethan?"]],"15":[[26,112,"Is it Ethan?"],[146,360,"-Yeah. -Ben. Bring Iris."],[360,490,"I have a couple of marriage questions."],[490,630,"Only you two can answer."],[662,806,"You're not going?"],[1002,1081,"You said you don't like"],[1081,1162,"hanging out with them."],[1162,1346,"So, I'm staying home with you."],[1390,1640,"He's your best friend. You have to go."],[1640,1760,"It's his bachelor party."],[2010,2100,"Take a shower."],[2120,2206,"We'll go together."],[2332,2412,"Alright."],[2530,2626,"We'll see you guys soon."],[3442,3566,"Hey, cheers."],[3582,3640,"Cheers."],[3722,3780,"Cheers."],[3892,4032,"A toast to our boy Ethan."],[4032,4166,"Giving up his wicked ways"],[4166,4352,"and entering the grave of love!"],[4466,4712,"No more wild nights for you, man!"],[4832,4960,"I never said that the marriage is"],[4960,5040,"the grave of love."],[5092,5202,"I mean,"],[5220,5404,"nowadays, it's easy for"],[5410,5632,"marriage couples to have an..."],[5720,5866,