{"1":[[100,266,"Attention!"],[888,971,"Welcome back, ma'am."],[1009,1176,"And congrats on another successful"],[1176,1276,"undercover mission."],[1309,1463,"You haven't even had time to change yet."],[1522,1626,"I'll have some formal attire"],[1626,1735,"sent over right away."],[1755,1810,"No time."],[1856,1926,"Take me straight to the"],[1926,2014,"Sterling Grand Hotel."],[2014,2077,"I can't be late"],[2077,2223,"for my sister's engagement party."],[2489,2631,"Move out!"],[3653,3695,"Whoa!"],[3695,3737,"Hey!"],[3903,4012,"That's not very nice."],[4024,4070,"Hee hee."],[4083,4283,"I'm just washing the stink off a janitor."],[4341,4404,"Attack."],[4425,4567,"Kill the stinky monster."],[5071,5192,"You tripped me!"],[5238,5492,"What the hell did you do to my son?"],[5659,5751,"It was her."],[5776,5893,"She pushed me."],[5905,6026,"Beat her up, Mommy."],[6131,6247,"What is wrong with you?"],[6247,6373,"He's just a kid."],[6381,6435,"For the record,"],[6435,6560,"I didn't touch your son."],[6560,6715,"Didn't lay a single finger on him."],[6752,6810,"You want to check"],[6810,6940,"security cameras, you can."],[6940,7032,"You know, he probably"],[7032,7161,"just wanted to play."],[7161,7303,"Instead of shoving him over,"],[7303,7465,"you could have politely declined."],[7507,7724,"You should feel lucky he even noticed you."],[7786,7891,"I don't have time for this."],[7891,7995,"I have an engagement party"],[7995,8058,"to get to."],[8108,8216,"You know, it's funny."],[8266,8324,"I'm going to the"],[8324,8454,"engagement party too."],[8491,8591,"And the bride-to-be,"],[8637,8746,"Grace Blackwood,"],[8787,9000,"California's brightest corporate star?"],[9059,9117,"Yeah."],[9125,9271,"She's my best friend."],[9359,9401,"Grace?"],[9401,9467,"Mm-hmm."],[9484,9630,"Same Grace who took her company"],[9630,9847,"to a hundred million in under a year."],[9893,10018,"And now she's marrying into the"],[10018,10114,"Grant family,"],[10126,10297,"which is one of the richest dynasties"],[10297,10360,"in the country."],[10360,10514,"But I wouldn't expect a janitor"],[10514,10639,"to know a name like that."],[12771,12954,"That's Grace Blackwood,"],[12954,13129,"founder of the Blackwood Group."],[13129,13242,"Play it smart, honey."],[13242,13421,"If she likes you, we're golden."],[13421,13475,"Okay, Mom."],[13475,13709,"I am so sorry I'm late."],[13730,13834,"Traffic was horrible."],[13834,13938,"Ms. Blackwood,"],[13938,14072,"that's quite alright."],[14101,14185,"Sis. - I have-"],[14347,14439,"Are you okay?"],[14560,14643,"Sis?"]],"2":[[8,91,"Sis?"],[246,375,"You, you know my sister?"],[475,588,"No, I-"],[621,809,"It wasn't exactly a warm introduction."],[1017,1126,"Take them away."],[1188,1326,"Grace, please."],[1397,1497,"I will make it up to you."],[1497,1576,"I swear, I..."],[1622,1747,"I, I can host both of you"],[1747,1826,"next time you're in-"],[1826,1935,"Anyone who disrespects"],[1935,2027,"my sister"],[2081,2223,"doesn't get a next time."],[2273,2352,"Guards."],[2610,2686,"No."],[2686,2756,"Wait."],[2777,2844,"Wait."],[3336,3645,"Ah, I miss you so much!"],[3878,4208,"You're getting married!"],[4279,4391,"And you were way too old"],[4391,4571,"to be clinging on to me like this."],[4679,4871,"Who cares if I'm getting married?"],[4871,4975,"You promised me that"],[4975,5130,"no matter how old we get,"],[5176,5351,"you'll always be there for me."],[5451,5572,"Don't worry, Grace."],[5593,5684,"Mommy and Daddy"],[5684,5818,"might not want us anymore,"],[5889,6018,"but you’re still with me."],[6068,6156,"From now on,"],[6189,6339,"I'll take care of you,"],[6339,6489,"I'll be your family."],[7152,7315,"You sacrificed so much"],[7315,7461,"putting me through school."],[7507,7757,"And now I, I, I'm doing great"],[7757,7916,"in the company and"],[7970,8191,"I'm marrying into the Grant family."],[8266,8512,"It is my turn to take care of you."],[8687,8850,"Well, it wasn't exactly a sacrifice"],[8850,9009,"to take care of my little sister."],[9063,9200,"Cat, there is no such thing"],[9200,9384,"as an easy life for a janitor."],[9384,9559,"Maybe it's time to tell her..."],[9605,9672,"Well."],[10060,10151,"Actually..."],[10251,10314,"Grace."],[10339,10414,"How much longer"],[10414,10539,"are you gonna make me wait?"],[12078,12157,"Cat,"],[12216,12404,"this is my fiancé,"],[12479,12550,"Tony."],[12637,12925,"Tony, this is my-"],[12946,13075,"Seriously, Grace?"],[13158,13271,"It's our engagement party."],[13271,13450,"Why'd you drag a janitor here?"],[13509,13621,"That filthy uniform,"],[13621,13705,"what else would she be"],[13705,13834,"besides a toilet scrubber?"],[13859,13963,"What, is she supposed to be"],[13963,14064,"some special guest?"],[14064,14130,"Tony,"],[14210,14339,"this is my sister."]],"3":[[33,120,"Oh, shoot!"],[133,258,"I forgot my purse in the car."],[304,421,"Keep my sister company."],[446,529,"I'll be right back."],[859,1001,"I never thought Grace's sister"],[1001,1192,"would be a janitor of all things."],[1226,1326,"I never thought my sister would"],[1326,1409,"settle for a man"],[1409,1530,"who treats people like shit."],[1555,1659,"The Grant family is"],[1659,1780,"way out of your league."],[1801,1881,"Today's guests"],[1881,2081,"are the elite of the elite."],[2081,2181,"Honestly, if I were you,"],[2181,2281,"I would leave before you"],[2281,2377,"embarrassed Grace,"],[2431,2523,"or yourself."],[2648,2765,"The only person I'm here to see"],[2765,2865,"is my sister."],[2865,2961,"What anyone else thinks"],[2961,3048,"doesn't matter."],[3311,3453,"Grace may put up with you,"],[3465,3611,"but my family won't."],[3653,3745,"Janitors"],[3745,3937,"don't belong at Grant parties."],[3962,4029,"Get"],[4066,4141,"out."],[4166,4266,"You don't have the status"],[4266,4391,"to order me around."],[4637,4767,"Take her to the garage."],[4767,4900,"Teach her some respect."],[4925,5013,"Guards!"],[5484,5572,"Should've walked away"],[5572,5701,"when you had the chance."],[5830,6014,"Ugh, disgusting."],[6377,6468,"Of all the people"],[6468,6569,"you could've pissed off,"],[6569,6706,"you picked Tony Grant?"],[6756,6840,"Dumb move."],[6902,7065,"Pretty face like yours,"],[7102,7278,"maybe cleaning floors"],[7344,7515,"isn't the only thing you're good at."],[7561,7757,"Yeah, clean us up, sweetheart."],[7791,7895,"Do a good job,"],[7895,8066,"and maybe we'll let you go."],[9017,9121,"Where's my sister?"],[9175,9300,"Oh, she said she had"],[9300,9401,"something to take care of."],[9513,9563,"Oh."],[9580,9655,"I did."],[9684,9738,"Handled it."],[11102,11290,"Bitch, now you're really asking for it."],[11319,11407,"Get her, boys."]],"4":[[12,158,"Those useless idiots."],[179,308,"Four of them against the woman,"],[308,442,"and they still lost?"],[479,625,"That fighting style."],[625,750,"Am I imagining things, or"],[750,855,"does she fight just like"],[855,1001,"those secret badass"],[1026,1155,"warlord mercenaries?"],[1167,1330,"But these guys are all men."],[1372,1597,"There's only ever been one woman."],[1785,1960,"The Warlord Queen!"],[2264,2318,"Tony?"],[2452,2531,"What's wrong?"],[2565,2627,"Nothing."],[2652,2798,"I've got to go call Mr. Cohen."],[3103,3203,"You know that Tony,"],[3203,3319,"whatever his name is,"],[3319,3432,"isn't good enough for you."],[3486,3741,"How about I set you up"],[3741,3933,"with someone better?"],[4262,4462,"Cat, that's Thomas Cohen!"],[4517,4617,"So what do you think?"],[4667,4804,"If you like him, I can set you up."],[4859,4913,"What?"],[4988,5113,"Cat, Mr. Thomas"],[5113,5288,"is in Forbes 30 under 30."],[5330,5518,"He's like on top of the world right now."],[5584,5697,"There's no way he would ever"],[5697,5839,"consider someone like me."],[5926,6072,"You're my sister, Grace."],[6151,6339,"If anyone is reaching here, it's him."],[6393,6527,"Stop messing with me."],[6631,6706,"Look, Tony said"],[6706,6865,"he's gonna give Mr. Cohen a call."],[6940,7061,"Who knows if he'll pick up,"],[7061,7248,"let alone actually attend the party."],[7248,7328,"Don't worry about that."],[7328,7490,"I'll send Thomas the invitation myself."]],"5":[[16,145,"Hello, Mr. Cohen."],[166,271,"This is Tony Grant."],[362,508,"You said you're from the Grant family?"],[554,750,"My father spoke with you a few days ago."],[796,896,"I was wondering if you could"],[896,971,"attend our family's"],[971,1076,"engagement banquet tonight."],[1146,1205,"Sorry, I have more"],[1205,1326,"important things to do."],[1326,1480,"I, I promise we won't take up"],[1480,1580,"too much of your time."],[1618,1793,"Tell Thomas the invitation's from me."],[1876,1956,"That voice,"],[1997,2227,"could it be the Warlord Queen?"],[2344,2506,"Shut up, you broke nobody!"],[2544,2652,"You're interrupting my call"],[2652,2748,"with Mr. Cohen!"],[2773,2927,"Tell him Catherine Blackwood"],[2927,3065,"sends him an invitation."],[3065,3194,"The second he hears my name,"],[3194,3307,"he'll come right over."],[3332,3545,"Grace, please control your sister."],[3545,3670,"If she pisses Thomas off,"],[3670,3812,"my family could lose everything."],[3832,3941,"Cat, please,"],[3941,4074,"please don't make this harder."],[4158,4200,"I-"],[4200,4341,"Please, I am begging you."],[4567,4633,"Fine."],[4688,4854,"I'll call Thomas myself."],[4979,5134,"Who, who was that voice just now?"],[5188,5351,"Just some stupid janitor."],[5405,5543,"I'm so sorry for the disturbance,"],[5543,5609,"Mr. Cohen."],[5647,5868,"Trust me, Cat, we don't wanna"],[5868,6026,"get on Mr. Cohen's bad side."],[6097,6243,"Please don't make any trouble."],[6243,6360,"It is not any trouble."],[6443,6610,"Look, I'll call him right now."],[6715,6911,"Why is she putting on this act?"],[6911,7077,"She doesn't need to impress me."],[7144,7403,"Forget it, no point in pushing her."],[7403,7607,"She's just trying to make me feel better"],[7607,7720,"about her job."],[7786,7853,"Fine."],[7899,8012,"I'm not stopping you."],[8095,8229,"I'll join Tony, just"],[8254,8383,"meet us inside when you're done."],[8491,8537,"Okay."],[8908,9046,"Please, Mr. Cohen, just"],[9046,9142,"give us a chance."],[9163,9246,"It would mean the world"],[9246,9355,"if you could make it tonight."],[9651,9768,"I have an urgent call."],[10276,10347,"What is it?"],[10414,10614,"I just heard a second phone ringing."],[10614,10735,"I've heard he has a private line,"],[10735,10931,"but only one person has access to it."],[10931,11015,"The woman who commands"],[11015,11148,"all the special forces,"],[11219,11369,"and sits on a near trillion-dollar"],[11369,11453,"war chest."],[11494,11615,"The Warlord Queen."],[11728,11882,"The Warlord Queen?"],[12303,12399,"Could it be..."]],"6":[[29,104,"Grace, what's wrong?"],[141,237,"Cat said she was"],[237,392,"gonna call Mr. Cohen."],[592,729,"You think this janitor is"],[729,863,"the Warlord Queen?"],[892,1042,"If that's the Warlord Queen,"],[1042,1247,"I'm the President of the United States."],[1313,1455,"Let's get inside and get ready."],[1530,1747,"My sister's just an ordinary person."],[1785,1910,"How could she possibly be"],[1910,2031,"the Warlord Queen?"],[2072,2218,"What am I even thinking?"],[2335,2419,"Come on."],[2665,2736,"Tommy."],[2806,2936,"Hi, yes, it's me."],[2994,3153,"Uh, it's a pleasant surprise to"],[3153,3219,"receive such a"],[3232,3324,"personal call from you."],[3357,3503,"Relax, I just have something to"],[3503,3591,"discuss with you."],[3824,3970,"You wanna introduce me to your sister?"],[4008,4149,"Wow, that's, that's an honor, I,"],[4162,4279,"I'll be at the Sterling right away."],[4400,4483,"I'll see you there."],[4642,4704,"Great."],[5538,5709,"Where do you think you're going,"],[5734,5801,"janitor?"],[5864,6006,"Sterling is only hosting"],[6006,6156,"private members today."],[6168,6285,"I am a member."],[6352,6564,"You dare stand in here?"],[6635,6773,"Open your eyes."],[6773,6986,"The Grant family has this whole place"],[6986,7127,"rented out today."],[7157,7365,"I'm here for the engagement party."],[7457,7611,"Engagement party?"],[7640,7811,"That's hilarious."],[7857,7937,"Get out."],[7991,8112,"We'll let you know if we have any"],[8112,8279,"toilets that need scrubbing."],[8354,8508,"You filthy janitor."],[8725,8954,"You've got a lot of nerve,"],[8975,9088,"coming in here,"],[9129,9280,"posing as a guest."],[9342,9446,"It's a death wish."],[9446,9505,"Um."],[9638,9709,"Cat?"]],"7":[[241,304,"What?"],[437,492,"Great."],[613,738,"Fantastic."],[771,842,"Understood."],[913,1038,"Thomas Cohen is attending our"],[1038,1126,"engagement banquet."],[1151,1242,"Hurry, let's get inside,"],[1242,1317,"and get prepared."],[1326,1438,"Don't do anything to offend him."],[1551,1714,"I think I heard my sister."],[1851,1993,"Your sister is a grown woman."],[2039,2264,"She doesn't need you to babysit her."],[2264,2469,"Thomas Cohen is all that matters."],[2469,2669,"Please don't mess this up, okay?"],[2936,3148,"Nothing matters more than my sister."],[3757,3849,"You must really think"],[3849,3983,"I can't live without you, huh?"],[4041,4108,"Well."],[4404,4496,"Alright."],[4512,4704,"I'm here for my sister's engagement."],[4829,5251,"You even printed out a fake invitation."],[5326,5417,"The Grants"],[5417,5580,"are hosting this engagement"],[5580,5722,"for the Blackwood Group."],[5734,5922,"You clearly don't belong here,"],[5922,6035,"so just get out."],[6056,6202,"Take yourself out with the trash."],[6202,6318,"And stop buzzing around here"],[6318,6414,"like a fly."],[6790,7169,"Or you could kneel, kiss my shoe."],[7169,7286,"I'll give it back to you."],[7315,7411,"Aren't you worried about"],[7411,7503,"what Grace is gonna think"],[7503,7665,"when she sees you treating me like this?"],[7778,8033,"We're about to be Grace's real family."],[8124,8283,"Who do you think she's gonna believe?"],[8299,8700,"Us or a lying toilet scrubber?"],[8775,8896,"Grace is my sister."],[8979,9159,"She's always gonna be on my side."],[9217,9313,"Pathetic."],[9313,9601,"Street trash posing as Grace's sister?"],[9617,9805,"Just to score a free meal."],[9893,9964,"Guards."],[10010,10160,"Take this bitch out!"],[10176,10381,"She is my sister!"],[10664,10831,"Cat, are you okay?"]],"8":[[16,241,"She is my sister."],[412,583,"Cat, are you okay?"],[583,654,"Don't worry."],[692,754,"I'm fine."],[850,1063,"Grace, don't be angry."],[1092,1292,"We didn't know your sister was"],[1313,1418,"like this."],[1447,1555,"You're the CEO."],[1564,1680,"Who ever would have thought that"],[1680,1822,"your sister would be a"],[1910,1972,"janitor?"],[2010,2227,"She is a janitor."],[2277,2489,"But every penny that she has ever made"],[2535,2711,"has been honest and clean!"],[2756,2815,"She's the one who"],[2815,2915,"got me through school."],[2952,3007,"Without her,"],[3007,3161,"I wouldn't even be here."],[3269,3478,"Cat, don't let their words get to you."],[3516,3582,"Please."],[3653,3741,"If it weren't for you,"],[3741,3812,"I wouldn't waste"],[3812,3912,"a single second on them."],[4074,4204,"I don't care what they say."],[4346,4421,"You!"],[4483,4754,"You are just a lowly janitor."],[4775,4842,"How dare you"],[4842,5034,"disrespect our family like that?"]],"9":[[41,162,"How dare you"],[162,400,"disrespect our family like that?"],[400,596,"Grace, this is your sister?"],[642,713,"That's right."],[713,779,"Well."],[779,992,"If you'd like her to attend the banquet,"],[992,1234,"then she needs to help cover the costs."],[1280,1447,"My son Tony has fronted"],[1447,1659,"every dime for today's event."],[1672,1881,"So if she pays her fair share,"],[1906,1997,"she may attend."],[2018,2135,"I'm sorry, what?"],[2160,2256,"That's crazy."],[2256,2456,"You have never made me contribute."],[2456,2598,"My dear, we thought"],[2598,2752,"you didn't have any family."],[2811,2965,"We feel bad for you."],[3003,3186,"And since you're marrying into ours,"],[3186,3336,"paying dues isn't necessary."],[3336,3566,"But now a sister shows up,"],[3616,3774,"yeah, she better chip in,"],[3820,3953,"as a show of good faith."],[4099,4258,"Do you support this?"],[4325,4525,"Grace, our family has a"],[4550,4671,"reputation to protect."],[4671,4779,"People are watching."],[4779,4909,"What are they gonna say if a"],[4942,5125,"janitor is amongst them?"],[5138,5301,"At least give her a chance to prove"],[5321,5509,"that she belongs here by contributing."],[5609,5697,"I'd be more than happy"],[5697,5776,"to pay anything"],[5776,5930,"for my sister's engagement."],[6031,6122,"But seeing the family"],[6122,6256,"that she's married into,"],[6448,6544,"I don't think so."],[6606,6723,"You don't deserve it."],[6798,7036,"Watch your mouth, janitor."],[7132,7273,"The only reason you're standing here"],[7273,7340,"is because Grace is"],[7340,7465,"marrying into our family."],[7503,7649,"Big talk for somebody with"],[7649,7816,"empty pockets."],[7836,7941,"It's okay, Cat."],[7982,8062,"I have money."],[8062,8124,"I'll pay."],[8174,8241,"Grace."],[8312,8429,"How much do you want?"],[8450,8579,"Oh, not much."],[8612,8783,"Just five million dollars."]],"10":[[75,141,"What?"],[162,271,"That's crazy!"],[271,429,"Five million dollars?"],[462,575,"Tony, this banquet didn't cost"],[575,729,"more than a hundred thousand!"],[1021,1101,"God."],[1172,1247,"Mom, what's wrong?"],[1263,1393,"It's your dad's project."],[1405,1564,"He's still short on funding."],[1580,1793,"Didn't I tell you to ask Grace"],[1793,1901,"for the money?"],[1901,2093,"She said she's pretty short on cash too."],[2093,2156,"Tony,"],[2189,2448,"I only signed off on this arrangement"],[2448,2627,"because of her resources."],[2648,2786,"She is supposed to help us."],[2786,2932,"If she can't even do that,"],[2932,3094,"why bother marrying her?"],[3103,3336,"She is my sister!"],[3374,3566,"What is all that ruckus?"],[3566,3741,"Just Grace's janitor sister."],[3741,3862,"She's been trying to force her way"],[3862,3978,"into our engagement party."],[4029,4124,"Really?"],[4279,4350,"Wow."],[4421,4583,"Well, if she wants in,"],[4604,4808,"then she'll have to pay to attend."],[4833,5138,"That should solve our funding problem."],[5488,5622,"That's straight up robbery!"],[5622,5880,"Marriage costs extend far beyond"],[5880,6093,"an engagement party, my dear."],[6131,6314,"Asking for five million"],[6314,6589,"is actually quite a modest request."],[6664,6715,"You're right,"],[6715,6873,"five million is pretty modest."],[6911,7002,"But you know what?"],[7048,7127,"The thing is,"],[7186,7403,"you're not even worth that much."],[7574,7782,"Who the hell do you think you are!"],[7782,7991,"Just admit you can't afford it."],[7991,8241,"How many lifetimes of picking up trash"],[8241,8375,"would it take you to get"],[8375,8537,"five million bucks?"],[8537,8742,"You're not fooling anyone."],[8742,8933,"Stop ganging up on my sister!"],[9067,9238,"You want five million dollars?"],[9238,9384,"Fine, I'll cover it."],[9893,9968,"Hi, I..."],[10055,10239,"I need five million transferred over."],[10347,10402,"What do you mean"],[10402,10556,"we can't afford that right now?"],[10710,10915,"Can't even scrape together"],[10915,11240,"a measly five million dollars."]],"11":[[1292,1480,"Can't even scrape together"],[1480,1793,"a measly five million dollar."],[1839,2002,"What a disgrace."],[2252,2369,"What the hell is this?"],[2369,2431,"What?"],[2548,2698,"He hasn't told you yet?"],[2794,2940,"Tony, who is this?"],[2940,3174,"She's the woman I love."],[3349,3424,"What?"],[3545,3636,"Tony,"],[3636,3858,"are you really gonna marry Grace?"],[3858,4037,"What does she have that I don't?"],[4058,4204,"Grace may not come from much,"],[4204,4371,"but she's a rising star"],[4371,4471,"with a lot of respect"],[4471,4583,"in the corporate world."],[4612,4750,"And with the way our family's projects"],[4750,4854,"are going right now,"],[4854,5021,"we need her financial support."],[5046,5330,"Then what am I supposed to do?"],[5588,5663,"Don't worry."],[5714,5897,"I might be marrying Grace, but"],[5926,6064,"I'm all yours, Eva."],[6594,6760,"This is how you treat my sister?"],[6815,6873,"You think you're gonna"],[6873,6981,"get away with this?"],[6981,7127,"Oh please."],[7127,7253,"I've known Tony"],[7253,7486,"way before your sister ever did."],[7524,7620,"If anything"],[7620,7891,"that makes you the mistress."],[7912,7995,"Oh, wait."],[7995,8208,"Isn't your sister's company in trouble?"],[8241,8420,"I bet she can't even scrape together"],[8420,8692,"five thousand dollars right now."],[8804,8883,"Whatever's going on"],[8883,8975,"with my sister's company"],[8975,9234,"is something that I can fix in seconds."],[9234,9409,"Don't kid yourself."],[9409,9459,"You know what?"],[9459,9772,"I'll give your sister two days,"],[9772,10051,"until she's completely bankrupt."],[10051,10185,"What did you just say?"],[10714,10810,"Mrs. Grant,"],[10935,11115,"the Sinclair Group may not be"],[11115,11340,"a top player in the business world,"],[11340,11540,"but my daddy did tell me that if"],[11540,11707,"you let me marry Tony,"],[11765,11957,"we will bankroll your company"],[11957,12166,"right through the rough patch."],[12166,12270,"Free of interest."],[12270,12525,"Now that is what a proper"],[12525,12670,"daughter-in-law looks like."]],"12":[[66,329,"Tony, you said I'd be yours forever."],[329,450,"You said that you would never-"],[450,575,"Grace, when I said that,"],[575,775,"your company was crushing it."],[775,930,"You met all my family's standards,"],[930,1059,"but now you're just a"],[1096,1226,"failed businesswoman."],[1255,1317,"Marrying you"],[1317,1480,"would only set the Grants back."],[1493,1576,"Face it, Grace."],[1576,1730,"You should take this as a wake-up call."],[1839,1960,"Now that you're no longer"],[1960,2156,"Tony's future bride,"],[2156,2306,"what are you still doing here?"],[2306,2460,"Overseeing your welcome?"],[2519,2598,"Get out!"],[2660,2706,"Cat."],[2740,2811,"But hey,"],[2811,3011,"it's not like you have nothing left."],[3011,3148,"You still have your"],[3148,3365,"garbage-sweeping sister."],[3390,3474,"And guess what?"],[3474,363