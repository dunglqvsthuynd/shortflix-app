],[5367,5588,"Absolutely reeks of poverty."],[5655,5818,"I feel gross just looking at her."],[5930,6085,"You're saying she's a janitor?"],[6110,6172,"Don't worry, sir."],[6172,6302,"It's my engagement day,"],[6314,6414,"and I'll be damned"],[6414,6544,"if I let a shit-scrubber"],[6569,6710,"ruin the vibe of my guest."],[6723,6861,"I'll go toss her out right now."],[7190,7248,"Aw."],[7323,7507,"The one who should be tossed out is you."]],"16":[[8,208,"The one who should be tossed out is you."],[396,538,"Tony, are you okay?"],[538,654,"What's going on here?"],[692,863,"This must be some kind of mistake."],[863,1005,"I don't understand why you guys"],[1005,1126,"are treating her like this."],[1126,1297,"She's just a lowly janitor."],[1297,1438,"A sorry-ass nobody!"],[1455,1564,"Mom, what's happening?"],[1718,1843,"I must say,"],[1843,1981,"we are touched that you wanna"],[1981,2198,"show our family such respect."],[2198,2323,"But Grace is no longer"],[2323,2456,"marrying my son."],[2456,2727,"So there is no need for this display."],[2727,2877,"You all probably haven't heard,"],[2877,2961,"but Grace's company"],[2961,3069,"is going bankrupt."],[3094,3257,"Her execs have already jumped ship."],[3257,3328,"So much for"],[3328,3536,"a rising star in the industry."],[3536,3870,"All that potential down the drain."],[4079,4162,"Hey, janitor!"],[4270,4354,"Mop that up."],[4700,4783,"Ah."],[4842,4913,"Do you have any idea"],[4913,5034,"who the hell you're disrespecting?"],[5071,5255,"Is she not just a janitor?"],[5288,5409,"Ignorant fool."],[5409,5634,"You cannot begin to imagine"],[5634,5764,"who she really is."],[5764,5947,"Listen, haha,"],[5964,6097,"we may rank a little"],[6097,6268,"lower than you folks,"],[6268,6410,"but I have met my share"],[6410,6548,"of heavyweights in my day."],[6548,6685,"And never have I ever"],[6702,6923,"heard of a janitor named Catherine"],[6923,7152,"who all the bigwigs are bowing down to."],[7240,7344,"Well, it's no surprise"],[7344,7436,"why you don't know me."],[7469,7620,"In fact, if it wasn't for my sister,"],[7620,7824,"you wouldn't even be qualified"],[7824,7995,"to stand anywhere near me."],[7995,8083,"Really now?"],[8103,8320,"Please then, do enlighten us."],[8358,8525,"Who the fuck are you?"]],"17":[[20,154,"Who the fuck are you?"],[383,525,"You're not worthy of knowing."],[550,809,"Oh, sounds like someone is afraid"],[809,1021,"to admit she's a nobody."],[1046,1247,"You really expect us to fall for this?"],[1247,1430,"You clearly hired these people"],[1430,1655,"to sell your little charade!"],[1676,1805,"Yeah, how much did you pay"],[1805,1968,"for them to hype you up?"],[2047,2156,"I didn't pay anyone."],[2202,2256,"God,"],[2256,2540,"we really did almost get duped,"],[2540,2602,"didn't we?"],[2635,2731,"I didn't realize"],[2731,2940,"you sisters were this crooked."],[2982,3161,"But listen here, Grace."],[3161,3370,"No matter how many tricks you pull,"],[3370,3486,"you will never"],[3486,3691,"marry into the Grant family."],[3699,3812,"Because you see,"],[3812,4133,"we don't take trash from the streets."],[4133,4362,"That's your job, not ours."],[4362,4512,"These sisters clearly"],[4512,4804,"banged these men to play along."],[4833,5125,"You two really have no shame."],[5125,5351,"No wonder Tony dumped you."],[5351,5705,"Oh, and by the way, he picked me."],[5743,5830,"Long, long, long, long,"],[5830,5964,"long, long, long, long time ago."],[6022,6106,"Grace, I thought you were"],[6106,6235,"just a stuck-up bitch,"],[6235,6339,"but it turns out"],[6339,6489,"you're a dirty little liar too."],[6519,6673,"Tell me, how many of these men"],[6673,6769,"did you hook up with?"],[6881,6998,"I never did that."],[7023,7161,"Stop slandering me!"],[7161,7290,"Ooh, she's triggered!"],[7290,7428,"You must have hit the target."],[7474,7549,"Silence!"],[7599,7766,"Who do you think you are,"],[7766,7870,"speaking to Grace,"],[7870,8012,"and her sister like this?"]],"18":[[4,129,"Still loyal to these"],[129,279,