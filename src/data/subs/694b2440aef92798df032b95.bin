],[10155,10377,"Who the hell did you mess with?"],[10377,10489,"Our company just went"],[10489,10660,"bankrupt thanks to you."],[10781,10877,"Bankrupt?"]],"22":[[8,171,"Bankrupt?"],[729,992,"Grace, you slut!"],[992,1096,"All you're good for"],[1096,1267,"is whoring yourself around men."],[1267,1347,"You think you can hide"],[1347,1426,"behind your sister,"],[1426,1555,"and that's gonna save you?"],[1922,2031,"I suggest"],[2081,2268,"you show my sister a little respect."],[2281,2356,"Fuck you!"],[2427,2610,"And your sister's a skank!"],[3078,3194,"And so are you!"],[3261,3370,"Ah!"],[3762,3924,"If you really love me, then"],[3924,4091,"beat that bitch to death right now!"],[4592,4742,"You know I told you"],[4846,4975,"that you would never hurt"],[4975,5117,"my sister ever again."],[5188,5330,"Now do you believe me?"],[5330,5555,"The Grants are the biggest family"],[5555,5659,"in California!"],[5659,5805,"What's a broke nobody like you"],[5805,5926,"gonna do, huh?"],[5926,6101,"You'll find out soon enough."],[6339,6448,"Alright."],[6456,6544,"Now."],[6756,6844,"Your turn."]],"23":[[4,70,"Thomas?"],[137,225,"I don't want these people"],[225,404,"stepping foot in California ever again."],[421,487,"Understood."],[525,588,"I'll take care of them."],[700,829,"Grace, you must be starving."],[884,996,"Why don't we get some food?"],[1042,1217,"Sis, what's gonna happen to them?"],[1267,1355,"Don't worry about that."],[1388,1488,"Tommy will handle it."],[1488,1547,"Mom?"],[1643,1814,"What do we do now?"],[1814,1947,"I think we really did mess"],[1947,2085,"with the wrong person."],[2085,2193,"Mr. Cohen?"],[2260,2352,"Who is she?"],[2377,2464,"They didn't tell you?"],[2523,2602,"Oh my God."],[2748,2865,"Don't tell me she's..."],[2944,2994,"That's right."],[3069,3140,"She commands all our"],[3140,3265,"special forces worldwide."],[3361,3486,"Has nearly a trillion dollars"],[3486,3574,"in assets."],[3661,3791,"She's the Warlord Queen."],[3895,4008,"Oh my God."],[4087,4195,"I can't