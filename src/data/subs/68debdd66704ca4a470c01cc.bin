{"1":[[625,804,"Oh no."],[855,988,"What did I do last night?"],[988,1130,"I've never done this before."],[2385,2569,"You've had a lot of drink."],[2652,2831,"Are you sure about this?"],[3098,3278,"I want you."],[4854,5055,"I know nothing about this man."],[5092,5176,"I don't even remember"],[5176,5242,"his face."],[5392,5459,"One night,"],[5459,5638,"two strangers."],[5784,5918,"Better we keep it that way."],[7570,7749,"Wait, the girl..."],[7820,7999,"She left?"],[8666,8783,"Find someone for me."],[9459,9613,"I'm pregnant from my"],[9613,9759,"one night stand?"]],"2":[[70,191,"It only took"],[191,383,"CEO Alex Morgan a month"],[383,471,"to seal this"],[471,600,"billion-dollar contract"],[600,696,"with the Walton Group."],[709,880,"He's the legend Bachelor."],[880,1026,"Young, rich"],[1026,1180,"and also handsome."],[1801,1910,"You think you've won,"],[1910,2089,"my stupid, stupid brother."],[2164,2360,"That money won't do you any good"],[2402,2494,"when you're dead."],[2506,2681,"And then that deal"],[2681,2861,"will be mine."],[2982,3061,"Boss,"],[3061,3148,"the girl you've been looking for"],[3148,3307,"for the past month, we've found her."],[3307,3432,"Her name's Daisy."],[3432,3632,"Tell me where she is"],[3632,3703,"now!"],[3716,3874,"Right away, boss."],[4099,4250,"Don't worry, baby."],[4250,4429,"Mommy will love and protect you."],[4441,4596,"I just wish..."],[4596,4775,"I wish I didn't have to do this alone."],[4859,5038,"I wish he'd come for me."],[5530,5684,"I'm coming for you, Daisy."],[6097,6202,"Hello, dear brother."],[6202,6481,"Congrats on landing the $10 billion deal"],[6510,6690,"for me."],[6873,7023,"You won't live to see it through."]],"3":[[329,375,"Do you want anything"],[375,475,"before we go?"],[729,825,"No."],[867,938,"Whoa whoa."],[938,1117,"I didn't say you could leave yet."],[1155,1242,"Burt, please,"],[1242,1368,"I really need to help her"],[1368,1468,"with the school project."],[1480,1572,"Work's more important"],[1572,1751,"than your stupid kid."],[1906,2110,"Is that what your mommy told you?"],[2177,2285,"That would explain why you're"],[2285,2356,"such a big,"],[2364,2423,"mean"],[2427,2548,"grump!"],[2927,3003,"Poppy!"],[4521,4700,"Daddy!"],[5793,5834,"Poppy!"],[5985,6131,"Poppy, what are you doing?"],[6185,6264,"Look, mommy."],[6277,6460,"I found daddy."],[7374,7474,"Daddy?"],[7595,7686,"What did you call me?"],[7686,7828,"I called you daddy."],[7828,8008,"Where have you been, Daddy?"],[8854,8946,"Help me, please!"],[8950,9079,"Get back here!"],[9088,9163,"I paid your mom"],[9163,9259,"good money for you."],[9334,9459,"You can't fool me."],[9459,9601,"He doesn't know you."],[10623,10856,"It can't be, can it?"]],"4":[[29,250,"I'm so sorry, sir,"],[250,312,"but..."],[392,571,"can I ask what your name is?"],[625,804,"Alex."],[984,1138,"I'm sorry."],[1138,1317,"Have we met?"],[1376,1555,"I got into a car accident"],[1618,1710,"and I don't remember"],[1710,1797,"anything before."],[1797,1926,"It's all a blur."],[1926,2106,"It's been five years."],[2131,2327,"I can't remember Poppy's dad's face,"],[2398,2686,"but he was in a suit and drinking"],[2698,2915,"at a five star hotel bar."],[2977,3053,"There's no way"],[3053,3157,"this homeless man is him."],[3190,3370,"No need to apologize."],[3390,3499,"We've never met."],[3499,3557,"My daughter"],[3557,3703,"thought you were someone else."],[3724,3832,"I'm sorry."],[3849,4029,"You don't remember daddy,"],[4041,4225,"but I know it's him."],[4258,4437,"I just know it."],[4450,4529,"Daddy's probably"],[4529,4629,"undercovering something."],[4654,4833,"That's why you can't tell it's him."],[4867,4946,"No, Poppy."],[4946,4984,"Honey,"],[4984,5188,"I know how much you want a daddy,"],[5188,5405,"but you can't just choose a person"],[5405,5613,"off the streets and decide that it's him."],[5689,5843,"Okay, now"],[5843,6006,"let's leave this nice man alone."],[6085,6206,"Please, mommy!"],[6214,6368,"You taught me to be nice"],[6373,6548,"and help anyone who needs it."],[6548,6752,"Can we please take daddy home?"],[6790,6969,"He needs us!"],[8537,8696,"Well, it..."],[8733,8842,"seems"],[8842,9025,"my daughter really likes you."],[9129,9280,"So"],[9280,9576,"why don't you come home with us?"]],"5":[[16,233,"Why don't you come home with us?"],[350,475,"For a hot meal"],[475,563,"at the very least."],[571,633,"Yes."],[646,759,"Yes, please."],[759,838,"But first,"],[838,967,"I'd like a strand of your hair."],[967,1126,"I know, I know, it sounds crazy,"],[1126,1313,"but I'd like to do a paternity test to"],[1376,1522,"put this to rest."],[1530,1710,"Otherwise, Poppy will never let it go."],[1822,1926,"We can drop it off"],[1926,2097,"on the way to my house."],[2110,2248,"Yeah. Sounds good."],[2344,2431,"Thank you."],[2431,2510,"Um..."],[2515,2615,"Daisy."],[2660,2748,"Daisy."],[2748,2977,"Why does that sound so familiar?"],[4312,4491,"Let's go home!"],[4662,4763,"I left some clean clothes"],[4763,4879,"on the bed for you."],[5096,5226,"Daddy,"],[5226,5413,"I don't think mommy recognizes you."],[5472,5651,"What if she kicks you out?"],[5672,5768,"You and your mommy"],[5768,6010,"are very kind to be helping me, Poppy."],[6110,6297,"But this is your mommy's house,"],[6364,6485,"and you have to respect"],[6485,6585,"her decisions."],[6694,6835,"Plus,"],[6911,7069,"the paternity test results"],[7069,7248,"should be coming in any minute."],[7269,7403,"Why do I feel so connected"],[7403,7582,"to this child?"],[7782,7912,"It's okay. Daddy."],[7932,8116,"I'll take care of you."],[8149,8312,"There's no way I slept"],[8312,8391,"with a homeless man"],[8391,8491,"and got pregnant."],[8512,8692,"Mommy, look!"],[8979,9109,"There's no way"],[9109,9292,"this is the same guy."],[9330,9522,"He looks like he just stepped straight"],[9522,9701,"off the cover of a magazine."],[9701,9851,"He is..."],[9872,10010,"so handsome!"]],"6":[[141,216,"Are you alright?"],[367,504,"You look a little concerned."],[621,800,"I can go if I'm bothering you?"],[859,942,"No, no,"],[942,1121,"I won't have you out on the street."],[1146,1313,"You can stay with us."],[1405,1530,"But"],[1634,1751,"my house,"],[1826,1964,"my rules."],[1985,2064,"You do as I say."],[2064,2185,"You got it?"],[2715,2861,"Yes, ma'am."],[2861,3040,"You got it."],[3136,3315,"Whatever you say."],[3353,3532,"My heart's racing."],[3532,3732,"His touch feels so familiar."],[3820,3999,"Well,"],[4116,4295,"I'll let you get some rest."],[4300,4483,"We can talk more tomorrow."],[4863,5021,"You too, little one."],[5021,5134,"I'll be in in a bit to read you"],[5134,5313,"a bedtime story."],[5747,5926,"What am I doing?"],[5968,6118,"Why do I feel so connected"],[6118,6297,"to this man?"],[7432,7499,"Mom,"],[7615,7699,"Harry,"],[7761,7849,"what are you doing here?"],[7866,7987,"You should feel honored"],[7987,8216,"that we'd even come to this shack"],[8216,8337,"you call a home."],[8341,8391,"Where is that"],[8391,8571,"fatherless little brat of yours?"],[8679,8746,"Did you finally get"],[8746,9004,"wise and throw her out on the street?"]],"7":[[4,179,"She is my daughter, Harry."],[179,283,"Watch your mouth."],[291,404,"And you watch yours"],[408,588,"when you talk to your stepbrother."],[646,742,"We've actually come with"],[742,813,"good news."],[825,988,"We found you a husband,"],[1001,1201,"a rich business associate,"],[1234,1359,"Michael Goldstein."],[1359,1551,"He says if you marry him,"],[1564,1722,"he'll take care of all of us."],[1722,1906,"Michael Goldstein?"],[1939,2093,"He's 80 years old."],[2118,2331,"This is about money, not love."],[2364,2506,"So you will marry him."],[2506,2660,"You've already been such"],[2660,2840,"a disappointment."],[2986,3123,"Don't disappoint me"],[3123,3261,"any further."],[3545,3624,"No."],[3799,4008,"I want to find a good father"],[4008,4062,"for Poppy."],[4062,4183,"I want to show her an example"],[4183,4325,"of what real love is."],[4375,4496,"Do you know how expensive"],[4496,4646,"it was to raise you?"],[4646,4729,"You owe me."],[4742,4821,"I do know"],[4821,4938,"because I have a daughter"],[4938,5017,"of my own."],[5046,5305,"And I would never do this to her."],[5776,5939,"You will marry Michael,"],[5939,6097,"and that's the end of it."],[6118,6281,"And if he wants to kiss you,"],[6281,6414,"you will kiss him."],[6418,6589,"And if he wants you naked in bed,"],[6589,6677,"you will strip!"],[6677,6823,"You can't make me."],[7686,7820,"Let me go!"],[7857,8016,"She said let her go!"],[8779,8846,"Hey, hey!"]],"8":[[175,354,"Hey, hey!"],[375,529,"Hey, get your hands off me!"],[533,721,"If I decide to let you go,"],[721,900,"I better not see you touch her again!"],[1534,1685,"Oh my God!"],[1685,1864,"Why is he naked?"],[2214,2398,"Why is there a man in your house?"],[2464,2610,"Oh..."],[2656,2794,"I'm her boyfriend."],[3090,3269,"And I suggest that you leave."],[3315,3424,"And you can forget about"],[3424,3549,"marrying her off"],[3549,3728,"to some sugar daddy."],[3991,4149,"She's mine."],[5109,5288,"You should go."],[5326,5472,"You..."],[5588,5768,"You have no shame!"],[5914,6043,"Harry!"],[6043,6139,"Yes, mother."],[6685,6865,"I'm sorry about the towel."],[6906,7090,"I just really missed a warm shower."],[7119,7244,"No. It's okay."],[7244,7336,"Really."],[7386,7486,"Thank you."],[7657,7774,"Mommy, look!"],[7828,7949,"The new pajamas you got me"],[7949,8199,"from Cozy Pixies on Shein!"],[8842,8933,"Do you like them?"],[8933,9079,"I love them, mommy."],[9096,9342,"But can we get daddy the PJs too?"],[9380,9471,"He did awesome."],[9471,9588,"My plan worked."],[9597,9726,"Wait."],[9976,10043,"Poppy,"],[10168,10343,"you told Alex to walk in on us"],[10343,10497,"half naked, didn't you?"],[11469,11561,"This just came for you,"],[11561,11636,"mommy!"],[11895,12012,"Mommy, open it!"],[12032,12162,"See what it says."],[12950,13104,"Oh my God!"]],"9":[[558,700,"He's the father."],[754,934,"Yeah!"],[1051,1134,"Oh!"],[1163,1284,"Hey, Daisy."],[1839,1960,"Was I drugged?"],[1989,2110,"Blackout drunk?"],[2127,2285,"What the hell was I thinking"],[2285,2406,"having a kid with some guy"],[2406,2485,"off the streets?"],[2923,2986,"Well,"],[2986,3199,"seeing as he's Poppy's father,"],[3211,3307,"I guess I should let him"],[3307,3395,"stay for a while."],[3395,3428,"stay for a while."],[4141,4262,"I'm sorry about today."],[4279,4429,"I know it must have been a lot for you."],[4483,4592,"I wish I had more answers."],[4592,4713,"I'm sorry for my amnesia."],[4733,4909,"You don't have to apologize."],[4963,5080,"It's not your fault."],[5092,5263,"If you want me to leave, I can go."],[5305,5467,"I don't mind going back to the streets."],[5497,5663,"No, no, I mean..."],[5897,6047,"You're Poppy's father,"],[6047,6118,"so..."],[6277,6435,"that means you're family."],[6514,6631,"You can stay."],[6844,6986,"Where am I going to sleep?"],[7173,7261,"Oh..."],[7298,7357,"I'm sorry,"],[7357,7494,"I don't have a spare bedroom."],[7645,7811,"You can sleep in my bed."],[8808,8929,"It's so soft."],[8975,9092,"Yeah."],[9517,9634,"Alex Morgan vanished"],[9634,9751,"five years ago."],[9772,9943,"Is he finally back?"],[9964,10114,"The City of the Skies project"],[10114,10285,"has been frozen ever since."],[10297,10468,"That $10 billion contract's"],[10468,10648,"still locked in his personal safe,"],[10648,10810,"and no one else knows the code."],[10927,11131,"Alex Morgan."]],"10":[[116,254,"Five fucking years and you"],[254,408,"still haven't found my brother!"],[909,975,"Either find him"],[975,1088,"by the end of the week,"],[1109,1159,"or you're going to be"],[1159,1280,"the one who disappears."],[1297,1418,"You got it?"],[1584,1735,"That $10 billion contract"],[1735,1856,"was supposed to be mine."],[1872,2002,"I was this close,"],[2014,2164,"but my brother locked it in a safe"],[2164,2281,"before I could take it,"],[2289,2444,"and the deal is about to expire."],[2460,2631,"Sir, we reached out to the world's"],[2631,2781,"top vault specialists."],[2827,2907,"We'll have that safe"],[2907,3028,"open within the week."],[3032,3153,"With the right price,"],[3161,3282,"any door can be open."],[3465,3586,"Good."],[4341,4496,"Somebody asked for some coffee?"],[4767,4888,"Thank you."],[4942,5059,"He's sweet"],[5155,5276,"and he's hot."],[5305,5409,"God help me."],[5409,5701,"What if he's even hotter in bed?"],[6139,6172,"You know,"],[6172,6322,"if you're Poppy's father,"],[6865,7086,"that means we've done this before."],[7152,7286,"Do you think"],[7336,7432,"if we do it again,"],[7432,7599,"you'll remember?"],[8166,8345,"Well, there's only one way to find out."],[9134,9255,"Are you ready for me?"],[9313,9388,"Yes."],[9388,9505,"Alex,"],[9567,9722,"I want you."],[10819,10944,"What the hell was I thinking?"],[11011,11156,"Why am I dreaming that?"],[11423,11540,"I need coffee."]],"11":[[1497,1672,"Am I dreaming?"],[2840,2957,"Good morning. Daisy."],[2994,3240,"Who told you to work out out here?"],[3286,3407,"Was it Poppy?"],[3457,3528,"Well, I don't want to"],[3528,3624,"throw her under the bus,"],[3624,3807,"but she may have suggested it."],[3903,4020,"Is that so?"],[4020,4099,"And,"],[4225,4437,"what else has she been saying?"],[4471,4621,"Well, she said"],[4621,4775,"it's okay that I'm poor,"],[4863,5005,"but if I don't maintain"],[5005,5125,"my six-pack,"],[5230,5309,"you'll throw me"],[5309,5430,"to the streets."],[5476,5559,"For the love of..."],[5559,5680,"Poppy!"],[6456,6577,"Morning, mommy."],[6635,6756,"Look!"],[7307,7399,"Daddy already helped me"],[7399,7499,"pick an outfit out"],[7499,7711,"from Cozy Pixies on Shein,"],[7732,7932,"and he's going to take me to school!"],[7966,8141,"You can sleep in!"],[8199,8387,"He's so good with her."],[8408,8500,"I've never trusted"],[8500,8712,"anyone with Poppy before. But..."],[8729,8863,"I trust him."],[8967,9088,"Well, then,"],[9125,9246,"you better get moving."],[9530,9622,"Ready?"],[10664,10785,"I've been played..."],[10831,10981,"played by a five year old"],[10981,11169,"and her forgetful father."],[11232,11298,"Her father who"],[11298,11423,"I can't stop dreaming about."],[11686,11857,"What am I going to do?"]],"12":[[37,108,"Daddy,"],[108,291,"I think mommy is starting to like you."],[421,538,"I like her too."],[558,696,"Like isn't enough."],[746,855,"Not even like-like."],[888,1051,"You need to marry her."],[1159,1347,"One annoying obstruction"],[1413,1664,"and one useless brat."],[1885,1968,"Once you both are"],[1968,2089,"out of the picture,"],[2147,2293,"James will give me a big"],[2314,2394,"fat"],[2419,2460,"check."],[2464,2652,"Daddy, You should do something"],[2652,2773,"to impress mommy"],[2781,2957,"like learning to cook."],[3028,3144,"You'll start today."],[3194,3357,"Very bold assumption to think"],[3357,3511,"I don't already cook."],[3520,3603,"How about I cook"],[3603,3724,"for you and mommy"],[3724,3845,"tonight?"],[4175,4295,"Poppy, watch out!"],[4775,4884,"Daddy?"],[4913,5017,"Daddy!"],[5163,5296,"Daddy, please wake up!"],[5338,5455,"Daddy!"],[5472,5593,"Wake up!"],[6010,6172,"I remember it all."],[6252,6327,"Please,"],[6327,6460,"please, please, brother."],[6489,6660,"You used our family's money"],[6698,6956,"to fund your illegal ventures."],[6990,7090,"I'm done"],[7090,7261,"covering for your scams."],[7449,7632,"You don't get one more cent."],[7657,7786,"Not now,"],[7791,7887,"not ever!"],[7945,8095,"Half of the Morgan fortune"],[8095,8212,"should be mine."],[8274,8433,"If you won't hand it over,"],[8454,8654,"I'll just have to take it myself."],[8779,8938,"I'm coming for you, Daisy."],[9046,9196,"You won't live to see it through."],[9930,10139,"I remember it all."]],"13":[[563,921,"Daddy got hit by a car to save me."],[1059,1180,"Mommy,"],[1201,1372,"is he going to die?"],[2268,2360,"Daddy!"],[2360,2481,"You're awake!"],[2660,2882,"I remember everything now,"],[2902,3036,"including..."],[3336,3457,"Don't cry, Poppy."],[3457,3574,"Daddy's okay."],[3636,3712,"Thank you"],[3712,3841,"for saving Poppy."],[3987,4108,"I swear."],[4137,4258,"As long as I live,"],[4275,4396,"I'll take care of you."],[4425,4546,"We're family now."],[5038,5230,"I would love nothing more than that."],[5401,5522,"Except there's..."],[5714,5868,"There's one thing."]],"14":[[37,154,"Call me Lex."],[208,346,"It's what my mother used to call me"],[346,508,"when she was still alive."],[696,817,"Lex."],[1893,1981,"What's that?"],[1981,2039,"Oh, nothing."],[2039,2177,"It's just an article"],[2177,2323,"about the Morgan Corporation"],[2323,2439,"press conference this week."],[2489,2610,"Oh."],[2731,2781,"We should go."],[2781,2902,"It sounds interesting."],[2965,3082,"How would we get in?"],[3140,3261,"Don't worry about that."],[3353,3482,"I'll figure something out."],[4371,4504,"Mr. Walton,"],[4546,4738,"let's get this contract started."],[4833,4954,"James,"],[4959,5125,"I signed that deal with your brother."],[5180,5288,"No contract,"],[5309,5380,"no deal."],[5463,5518,"That's why"],[5518,5643,"I brought his personal safe"],[5643,5764,"with me today."],[5768,5914,"As well as the top safecrackers"],[5922,6043,"in the world"],[6051,6293,"and a $10 million prize."],[6377,6510,"We'll have that contract out"],[6510,6639,"in no time"],[6660,6777,"with a little brute force."],[6810,6936,"If you try to force it open,"],[6936,7077,"it'll self-destruct."],[7111,7248,"Only the code can open that safe."],[7248,7449,"And only Alex Morgan knew it."],[7753,7870,"Hand them over,"],[7907,7999,"or you'll be walking out of here"],[7999,8116,"with nothing."],[8299,8362,"What's everyone"],[8362,8479,"looking at me for?"],[8525,8612,"I've nothing to do"],[8612,8783,"with my brother's disappearance."],[10577,10731,"You know, there's a $10 million prize"],[10731,10873,"for opening that safe in there."],[11119,11236,"Why don't you go ahead in?"],[11244,11348,"They're about to start."],[11348,11469,"I'll meet you in there."],[11632,11736,"Now I just need to do"],[11736,11815,"what daddy told me,"],[11815,11995,"and that money will be ours."]],"15":[[300,400,"This is the toughest safe"],[400,588,"I've ever had to crack."],[671,763,"10 million"],[763,988,"to whoever opens this safe."],[1013,1134,"No rules,"],[1151,1297,"no restrictions."],[1672,1830,"$10 million?"],[1901,2022,"That money is mine."],[2089,2231,"No! Get out of my way!"],[2231,2360,"I got here first!"],[2389,2535,"In your dreams."],[2535,2644,"That check's coming home"],[2644,2752,"with me."],[2948,3069,"Pathetic!"],[3111,3224,"Let me show you how it's done."],[3528,3616,"Looks like no one's"],[3616,3778,"getting that $10 million."],[4984,5105,"Move, people!"],[5338,5467,"I've got this."]],"16":[[421,588,"Did someone lose their kid?"],[633,750,"What's she doing here?"],[763,921,"James, your press conference"],[921,1042,"is turning into a circus."],[1059,1172,"Guards,"],[1172,1297,"get her out of here now!"],[1322,1443,"No, no, no, she's"],[1472,1530,"my daughter."],[1530,1609,"Don't touch her!"],[1618,1722,"I didn't hear you say"],[1722,1843,"kids weren't allowed."],[1860,1993,"What if I"],[1993,2139,"open the safe?"],[2494,2615,"Sure, Princess."],[2656,2765,"You open the safe,"],[2765,2944,"I'll personally hand you this check."],[3061,3182,"But if you can't,"],[3228,3399,"I'm throwing both of you out."],[3599,3749,"If that brat can open the safe,"],[3778,3899,"I'll swallow it whole."],[4212,4375,"You want that 10 million bucks?"],[4383,4504,"Of course."],[4525,4675,"But, daddy, making money"],[4675,4796,"isn't that easy."],[4825,4979,"Well, then you better listen closely"],[5038,5176,"when you see that safe,"],[5209,5363,"I want you to press"],[5363,5497,"0 4"],[5555,5689,"0 5"],[5734,5860,"2 0."],[5897,6018,"That's it."],[6026,6147,"What's that number?"],[6147,6268,"It's the first time"],[6356,6477,"I met your mommy."],[6514,6623,"And"],[6623,6806,"it's the code for the safe."],[6981,7102,"Pinky promise?"],[7136,7303,"Pinky promise."],[7766,7937,"This brat is just here"],[7937,8062,"to embarrass her mom."],[8591,8712,"Poppy, honey."],[8767,8829,"Where's your dad?"],[8829,8958,"What do you say we go find him?"],[9275,9401,"Give it five seconds"],[9401,9538,"before security steps in."]],"17":[[1359,1505,"How did she know the code?"],[1634,1739,"What?"],[1751,1860,"How?"],[1868,1989,"Impossible."],[2043,2214,"Alex Morgan should have been"],[2214,2394,"the only one able to open that safe."],[2452,2560,"Poppy, who gave you the code"],[2560,2681,"to that safe?"],[2965,3057,"Mister,"],[3082,3199,"I opened the safe."],[3228,3411,"Hand over that check."],[3966,4149,"Why do you know the code"],[4162,4350,"to my brother's safe?"],[4366,4471,"Who sent you?"],[4471,4587,"That's a secret."],[4654,4771,"Mine now."],[4867,4954,"Let's go, mommy."],[4954,5092,"Daddy's waiting for us."],[6093,6185,"This is it!"],[6193,6306,"This is it!"],[6406,6660,"The $10 billion contract!"],[6727,6861,"Mr. Walton,"],[6877,7052,"I trust everything is good to go now."],[7090,7257,"As long as the contract's real."],[8158,8279,"Is this some kind of joke?"],[8370,8479,"Well, you thought you could fool me"],[8479,8650,"with blank pages?"],[8900,9071,"What are you talking about?"],[9125,9192,"No, no!"],[9196,9271,"There's no way!"],[9271,9392,"How could they be blank?"],[9530,9634,"You two,"],[9634,9734,"stop right there!"]],"18":[[4,137,"Why the hell"],[137,404,"is my $10 billion contract"],[404,492,"blank?"],[504,629,"What are you talking about,"],[629,692,"mister?"],[700,896,"All I did was open the safe."],[934,1067,"I don't know anything about"],[1067,1213,"what was inside."],[1326,1501,"You said so yourself, James."],[1509,1639,"Whoever opens the safe"],[1639,1847,"gets $10 million."],[1856,1939,"You're not going to go back on"],[1939,2064,"your word, are you?"],[2110,2281,"If you'd like to take the check back."],[2423,2540,"Be my guest."],[2540,2660,"But"],[2681,2848,"I hope that you're aware of how"],[2848,3011,"that might affect your reputation."],[3132,3274,"Mr. Vice president."],[3332,3536,"I never said I was taking it back."],[3586,3724,"I just wanted to know..."],[3766,3895,"She already said she didn't know"],[3895,4012,"what was in the safe."],[4104,4229,"So unless you're planning on"],[4229,4396,"throwing a tantrum here,"],[4450,4583,"we'll be on our way."],[5155,5276,"Who did this?"],[5376,5572,"Who the hell is messing with me?"],[5751,5872,"We're rich now, daddy."],[5872,6026,"Let's get mommy something special."],[6051,6314,"I was thinking the exact same thing."],[6473,6544,"Wow."],[6544,6652,"Shein's trend store"],[6652,6823,"really has every style out there!"],[6848,6948,"Every dress here"],[6948,7119,"is what people wear right now!"],[7127,7248,"Even you,"],[7282,7432,"my little trend-setter,"],[7474,7595,"can find a store"],[7620,7732,"just for you."],[7732,7803,"Ooh!"],[7824,7949,"Look, daddy,"],[7949,8049,"that one!"],[8350,8466,"This store fits mommy's style"],[8466,8646,"of confident and pretty."],[8679,8850,"No one deserves a beautiful dress"],[8850,9025,"like this more than your mommy."],[9121,9192,"We'll tell mommy"],[9192,9313,"it's a gift from both of us."],[9330,9488,"She's going to be so surprised."],[9613,9734,"Pinky promise?"],[9922,10043,"Poppy?"],[10447,10568,"Poppy,"],[10593,10706,"why did you know the code"],[10706,10827,"to that safe?"],[10956,11077,"Daddy told me."],[11077,11294,"He made us 10 million bucks."],[11457,11561,"Lex,"],[11594,11795,"they said that only Alex Morgan"],[11845,11961,"could open that safe."],[12066,12266,"Are you Alex Morgan?"]],"19":[[45,129,"I haven't learned who"],[129,254,"James was working with"],[254,429,"to orchestrate my car crash"],[429,550,"five years ago."],[571,684,"If I tell Daisy"],[684,842,"my true identity now,"],[884,967,"they might go after"],[967,1088,"Daisy and Poppy."],[1113,1234,"I guess the code."],[1292,1380,"I thought it would be fun"],[1380,1501,"to let Poppy try."],[1693,1760,"Why didn't you"],[1760,1889,"come into the press conference hall"],[1889,1985,"with us?"],[2035,2152,"I had a stomachache."],[2227,2344,"I was in the bathroom."],[2402,2481,"I'm sorry I couldn't"],[2481,2602,"accompany you."],[2740,2802,"He barely"],[2802,2932,"remembers his own name."],[2965,3086,"I'm being ridiculous."],[3136,3257,"It's okay."],[3257,3378,"Don't worry about it."],[4037,4170,"My share of the rent."],[4558,4679,"Fine."],[4717,4838,"I'll take care of this for you."],[4838,4946,"But"],[4988,5105,"if you need any money,"],[5105,5271,"just ask me."],[5392,5513,"Mommy,"],[5576,5747,"daddy got us so much money."],[5797,5880,"Can we go shopping"],[5880,5993,"for him tomorrow?"],[6010,6143,"Let's buy him some new clothes."],[6143,6235,"Pretty please?"],[6368,6443,"Okay."],[6443,6564,"Whatever you want."],[7845,7962,"Thank you, honey."]],"20":[[45,162,"What was that for?"],[221,300,"Kisses are"],[300,421,"for people you like."],[454,575,"Daddy likes you!"],[934,1017,"I like mommy."],[1017,1155,"Mommy gets a kiss from me too."],[1488,1530,"Goodnight."],[1530,1651,"Poppy, wait."],[2369,2489,"What?"],[2515,2577,"Well, Daisy,"],[2577,2702,"my legs are feeling better."],[2873,2994,"And?"],[3315,3386,"And that means"],[3386,3532,"I can make you feel good."],[3687,3807,"Feel good?"],[3928,4024,"I'm feeling tired"],[4024,4162,"after today."],[4354,4525,"And I'll help you sleep better."]],"21":[[58,304,"Lex, not on the couch."],[1747,1864,"Daisy, my baby."],[1960,2089,"The day of the car accident,"],[2106,2268,"I was planning to propose to you."],[2323,2435,"Since our one night stand,"],[2435,2506,"I hadn't been able"],[2506,2623,"to get you off my mind."],[2690,2811,"Are you sure about this?"],[2944,3065,"Yes."],[3065,3157,"I know you're"],[3157,3278,"the one for me."],[3286,3403,"You really don't remember that night"],[3403,3570,"we spent together five years ago?"],[3728,3770,"No."],[3770,3891,"I mean, it was all a blur."],[4004,4112,"The only thing I remember"],[4112,4229,"is leaving your hotel room"],[4229,4320,"the next morning."],[4320,4441,"But..."],[4617,4704,"I really wish"],[4704,4825,"that I remembered..."],[4984,5134,"that I remembered you."],[5392,5497,"I think I have something"],[5497,5647,"that can jog your memory."],[6685,6877,"Tell me if this feels familiar."],[10915,11198,"You managed to give $10 million"],[11198,11365,"to some stupid brat?"],[11428,11553,"Well,"],[11553,11657,"did you figure out who Daisy's"],[11657,11778,"baby daddy is?"],[11828,11966,"And more importantly,"],[11966,12103,"is it my brother?"]],"22":[[62,183,"I looked into it."],[246,367,"I sent you something."],[875,938,"He's just some"],[938,1084,"fucking homeless guy."],[4266,4354,"Oh my God,"],[4354,4546,"last night was crazy."]],"23":[[779,921,"Lex, what are you wearing?"],[921,1113,"Where’re your pajamas?"],[1188,1334,"Well, I've only got one pair."],[1455,1597,"And you wore them last night."],[1705,1793,"So..."],[2060,2223,"Listen, um-"],[2356,2681,"You seem different than before."],[2719,2786,"Really?"],[2898,2977,"Well. How so?"],[3069,3299,"Well, last night-"],[3682,3795,"Oh!"],[3862,4016,"You mean how perfect we were for"],[4016,4149,"each other, right?"],[4258,4383,"Especially in bed."],[4383,4625,"A little too perfect. Like-"],[4758,4988,"you've had more experience"],[4988,5171,"than I would have expected."],[5372,5463,"Maybe your assumptions"],[5463,5597,"about me were wrong."],[6106,6202,"Mommy!"],[6202,6293,"Daddy!"]],"24":[[66,112,"Oh!"],[196,287,"One second, Poppy."],[287,446,"Daddy's not dress yet."],[638,817,"Okay, looks like we"],[817,921,"definitely do need to get you"],[921,1042,"some new clothes today."],[1172,1292,"Yeah."],[1509,1722,"Maybe after we're done."],[1889,2060,"Pick up where we left off."],[3269,3374,"Hello?"],[3599,3691,"What?"],[3799,3937,"You're firing me?"],[4312,4487,"What's wrong?"],[4542,4796,"The cafe hired my brother"],[4796,4913,"as the new manager,"],[4913,5088,"and he's firing me on his"],[5088,5180,"first day."],[5338,5409,"No."],[5476,5593,"No!"],[5593,5743,"I have given years of my life"],[5743,5805,"to that cafe."],[5805,5910,"I am not letting them"],[5910,6051,"walk over me like this."],[6126,6235,"Will you watch Poppy"],[6235,6327,"while I'm gone, please?"],[6327,6506,"Yes. Of course."],[6506,6627,"Whatever you need. Hey-"],[6677,6844,"I believe in you."],[8103,8266,"As you know,"],[8266,8454,"the big man has hired Harry here"],[8454,8650,"as our new manager."],[8650,8900,"That's right. I'm your boss now."],[8983,9100,"Do you like how I redecorated"],[9100,9188,"the place?"],[9417,9555,"As your new boss,"],[9555,9755,"my first order of business"],[9755,9909,"is firing you!"]],"25":[[25,108,"Does mom know"],[108,308,"that you're doing this?"],[333,650,"That you, my half brother,"],[650,809,"are trying to get me fired?"],[817,1017,"Oh, she knows."],[1088,1188,"It was her idea"],[1188,1455,"after you refused to marry that rich guy,"],[1455,1559,"Michael Goldstein."],[1722,1906,"You didn't want to help us."],[1906,2097,"So now,"],[2097,2248,"we don't want to help you."],[2327,2585,"You have always been a pathetic,"],[2585,2736,"petty, crying baby"],[2736,2857,"as we were children."],[2886,3078,"You take that back right now."],[3078,3328,"You know, in all fairness,"],[3403,3536,"Daisy has been a customer"],[3536,3666,"favorite waitress- -Hey!"],[3724,4045,"If you like my stupid sister so much,"],[4045,4233,"you can pack up your shit"],[4233,4358,"and leave with her."],[4462,4558,"All right."],[4596,4729,"Just sign here, sis."],[4833,4879,"This is your"],[4879,5013,"severance agreement."],[5013,5342,"I have worked at this cafe for years."],[5442,5647,"This is how I built a life for me"],[5647,5730,"and my child."],[5730,5922,"I am not letting you ruin this."],[5922,6293,"You know, I never liked you,"],[6293,6564,"even back when we were kids."],[6564,6956,"And now everything you have"],[6956,7119,"will be gone!"],[7152,7365,"If you won't give up willingly,"],[7365,7532,"I'll force you to give up."],[7803,7924,"What are you doing?"],[7924,8116,"You can't make me do this!"],[8116,8354,"Call the police this is assault!"],[8425,8537,"Pick up the pen!"],[8637,8817,"Sign the paper!"],[8929,9054,"You can't make you do this!"]],"26":[[379,575,"You dumb bitch!"],[734,846,"Ah!"],[996,1130,"Oh, fuck!"],[1309,1518,"How the fuck did he get in here?"],[1518,1647,"I locked the door."],[1768,1976,"Hey. You okay?"],[2227,2398,"I just wanna leave."],[2398,2577,"Leave?"],[2577,2790,"You can't leave until you sign"],[2790,2932,"your severance agreement."],[2969,3128,"Don't think some worthless bum"],[3128,3228,"is gonna keep me from"],[3228,3361,"getting you fired!"],[3661,3841,"You get your dirty hands off that!"],[3941,4195,"No, no! No!"],[4195,4333,"No, what are you doing?"],[4458,4650,"That was my revenge!"],[5171,5317,"Oh my God! You're-"],[5317,5426,"You're-"]],"27":[[41,179,"Smart people"],[287,392,"know how to recognize"],[392,521,"who's in charge."],[742,880,"Mr. Morgan is one of the most"],[880,984,"powerful businessmen"],[984,1130,"in the city."],[1130,1313,"If I go against him,"],[1313,1443,"he could have me killed."],[1459,1543,"Don't you ever try to"],[1543,1772,"fuck with Daisy again."],[1772,1901,"She's off limits."],[1901,2056,"Your pet street rat"],[2056,2310,"needs to learn some manners, sis."],[2310,2427,"If you won't discipline him"],[2427,2656,"yourself, I'll do it for you."],[2736,3094,"I'll beat him till he's crippled!"],[3094,3249,"He'll never walk again."],[3282,3574,"Harry, you can't do that, please."],[3574,3670,"I'd like to see you"],[3670,3895,"fucking try, little boy."],[3949,4074,"Harry, stop!"],[4074,4175,"What the fuck do you mean?"]],"28":[[150,291,"I’ve got some new information"],[291,379,"that the big boss man"],[379,462,"is gonna want to hear"],[462,642,"before we take any more action."],[654,855,"Are you fucking stupid?"],[855,1092,"This bitch is getting fired!"],[1092,1280,"Not until we've spoken"],[1280,1451,"to the big boss man."],[1484,1672,"Okay, we should leave now."],[1672,1943,"Daisy, you're free to go."],[1943,2147,"And I'll see you for your shift tomorrow."],[2177,2327,"Really?"],[2460,2569,"Yeah."],[2686,2811,"Okay. I-"],[2932,3023,"I don't know what made you"],[3023,3232,"change your mind, but"],[3349,3440,"thank you."],[3461,3649,"What the fuck are you talking about?"],[3699,3841,"Does the big boss know"],[3841,3995,"you're acting like a fucking idiot-"],[3995,4141,"Seriously, Harry!"],[4141,4412,"You should leave her alone."],[4471,4571,"Hey! No!"],[4571,4679,"Back up!"],[4679,4863,"This is bullshit!"],[4863,5092,"This isn't over!"],[5092,5284,"I'll be back!"],[5417,5509,"No!"],[6861,6952,"Hey,"],[7032,7215,"what do you say we just go get a drink?"],[7215,7386,"Just try to relax."],[7465,7595,"Yeah, it's like that."],[7670,7732,"Okay."]],"29":[[1568,1776,"You've had a lot to drink tonight."],[1776,1964,"I'm gonna get you some water."],[2064,2173,"I've always known that"],[2173,2302,"my mom like my brother"],[2302,2594,"more than me but"],[2594,2744,"I never thought that"],[2744,2952,"she would team up with Harry"],[2952,3136,"to ruin my life."],[3299,3511,"I'm her daughter, too."],[3628,3749,"But-"],[3987,4287,"I must have done something wrong."],[4362,4504,"Because why else wouldn't"],[4504,4679,"she love me?"],[4746,4859,"I think there must be"],[4859,5063,"something really wrong with me."],[5201,5321,"Daisy,"],[5392,5580,"listen to me."],[5580,5826,"You were brilliant."],[5826,6056,"And you're kind."],[6147,6268,"You were the best person"],[6268,6431,"in this entire world."],[6594,7086,"And I will spend the rest of my life"],[7086,7278,"proving this to you,"],[7278,7574,"that you deserve to be loved."],[7670,8003,"I raised my daughter by myself"],[8087,8387,"for five years, and I-"],[8512,8812,"I know it's a modest job, but it's-"],[8883,9079,"it's how I built a life for me"],[9079,9250,"and for my baby. And-"],[9401,9526,"I don't want to lose that to"],[9526,9718,"my cruel family. I-"],[9730,9847,"I just want to be a mom"],[9847,10060,"that Poppy can be proud of."],[10197,10301,"Hey,"],[10385,10573,"she's so proud of you."],[10573,10806,"She loves you."],[10806,10994,"I see it."]],"30":[[70,296,"I promise you,"],[296,483,"I will never let your family"],[483,784,"take anything away from you."],[896,1059,"I won't let anyone hurt you"],[1113,1317,"ever again."],[5226,5359,"Mommy,"],[5359,5455,"What's this?"]],"31":[[16,221,"Oh, um-"],[375,437,"Eh-"],[437,688,"Poppy, those are for grown ups, okay?"],[688,809,"They're not toys."],[834,1055,"But, what is it?"],[1292,1493,"Poppy, remember how I told you"],[1493,1597,"that the stork"],[1597,1776,"brought you to mommy?"],[1881,2235,"That is a note for the stork"],[2235,2540,"telling him not to bring any more"],[2540,2706,"babies to Mommy and Daddy"],[2706,2886,"for a while, okay?"],[2940,3073,"And Poppy,"],[3073,3153,"me and mommy have a little"],[3153,3319,"date tonight, okay?"],[3415,3549,"So we're gonna get you a nanny."],[3549,3620,"Is that okay?"],[3620,3791,"Totally a okay."],[3824,3962,"Okay. -Okay."],[4024,4104,"Shall we go make you"],[4104,4212,"some pancakes?"],[4425,4587,"I'll make the coffee."],[5426,5530,"You’re meanie!"],[5530,5634,"I want the stork to bring"],[5634,5809,"mommy a baby brother!"]],"32":[[62,254,"Poppy, breakfast!"],[1697,1885,"That dress is perfect."],[1885,2014,"You think so?"],[2106,2310,"I had it shipped in this morning"],[2310,2527,"from Musera on Shein."],[2652,2952,"You look beautiful in anything."],[3094,3294,"Or nothing at all."],[5893,6035,"Get anything you'd like."],[6110,6243,"It’s on me."],[6514,6639,"Wait, the Chef de Cuisine’s"],[6639,6944,"exclusive set is $8,000 per person."],[6944,7148,"Lex, are you sure about this?"],[7194,7378,"We have that 10 million"],[7378,7494,"from opening the safe."],[7570,7736,"Don't worry about it."],[7795,7970,"Big spender huh?"],[8629,8883,"Mr. Parker, what an honor. We-"],[8883,8958,"We didn't know you were"],[8958,9075,"coming tonight."],[9075,9255,"Should we clear the restaurant for you?"],[9321,9442,"No need."],[10364,10506,"Oh Shit!"],[10531,10660,"Mr. Morgan?"],[10744,10969,"I'm so screwed."]],"33":[[604,829,"Wait, Lex. Is he talking to you?"],[829,955,"Paul!"],[955,1121,"Fancy seeing you here!"],[1172,1297,"This is ah-"],[1359,1543,"This is Paul. He's a"],[1543,1714,"old friend."],[1714,1964,"Your old friend calls you Mr. Morgan?"],[1964,2122,"Well, you must have-"],[2122,2231,"You must have misheard him."],[2231,2373,"Right, Paul?"],[2402,2690,"Yes, you must have misheard."],[2690,2952,"What I meant to say was"],[2952,3253,"a bottle of Morgan Wine."],[3286,3449,"Oh, yeah."],[3449,3549,"I guess that-"],[3666,3816,"that makes sense."],[3903,4120,"Are you the General Manager"],[4120,4266,"of the Morgan Corporation?"],[4266,4466,"How- How do you know Lex?"],[4504,4692,"We met at a homeless shelter."],[4896,5084,"Long time ago."],[5138,5292,"Paul's eh-"],[5401,5538,"Paul's helped me a lot"],[5538,5663,"over the last few years."],[5693,5976,"Yes, a homeless shelter."],[6006,6110,"Well,"],[6177,6356,"you're very kind and generous."],[6356,6614,"Thank you for helping Lex."],[6731,6906,"I’m gonna use the restroom, okay?"],[6906,7011,"I'll be right back."]],"34":[[62,312,"Mr. Mor- Mr. Morgan!"],[367,500,"Where have you been for the past"],[500,600,"five years?"],[600,734,"We've all been looking for you."],[763,900,"Your brother told everyone"],[900,955,"that you would-"],[955,1138,"I know, I know."],[1284,1509,"And that car crash"],[1509,1730,"was no accident."],[1810,2027,"Listen, contact the board members"],[2027,2202,"for me privately."],[2248,2419,"Don't let my brother find out."],[2435,2602,"Yes I understand."],[2648,2769,"Shall I arrange for your return"],[2769,2882,"to headquarters?"],[2952,3032,"Not yet."],[3094,3274,"I need you to do two things for me."],[3307,3474,"Firstly,"],[3474,3724,"find every trace of misused"],[3724,4020,"funds over the last five years."],[4066,4241,"Secondly,"],[4421,4637,"book out the entire restaurant."],[4763,4846,"I don't want any more"],[4846,5038,"interruptions tonight."],[5038,5221,"Yes, sir."],[5351,5563,"It’s really happy to see you again, sir."],[5622,5709,"Yeah."],[6527,6627,"I apologize"],[6627,6810,"the restaurant has been booked"],[6810,6969,"for a private event this evening."],[7032,7219,"It would cost over half a million dollars"],[7219,7323,"to book the entire restaurant"],[7323,7436,"for one night."],[7461,7657,"Who the hell could pull that off?"],[7657,7799,"My apologies."]],"35":[[437,759,"Lex, this is weird."],[859,1009,"I mean, I read online"],[1009,1176,"that this place is usually packed."],[1180,1263,"I mean, it's impossible"],[1263,1397,"to get a reservation even"],[1397,1543,"three months in advance."],[1593,1701,"Why do you think we're the only ones"],[1701,1839,"here tonight?"],[2035,2122,"Maybe they're going out"],[2122,2243,"of business."],[2243,2377,"Dummy. No."],[2377,2548,"This is the hottest restaurant in LA."],[2548,2594,"There's no way"],[2594,2773,"they're going out of business."],[2911,3157,"Maybe it's our lucky night."],[4208,4350,"May I have this dance?"],[4350,4454,"Here?"],[4454,4650,"Just the two of us?"],[4662,4879,"Just the two of us."],[4879,5021,"Like we're the only two people"],[5021,5146,"in the world."],[6381,6493,"About what happened"],[6493,6861,"at the cafe earlier,"],[6861,7002,"thank you."],[7002,7161,"Well, I don't really think I did much."],[7161,7253,"I mean, I-"],[7357,7486,"I almost made matters worse."],[7486,7707,"No, no. It was like-"],[7836,8137,"like everything was closing in, and-"],[8199,8350,"and then you showed up and-"],[8558,8858,"It was like I wasn't alone anymore."],[8913,9213,"Sometimes I feel like this is"],[9255,9355,"all just a dream."],[9355,9446,"And I'm going to wake up"],[9446,9718,"and you're just going to be gone."],[9751,10001,"Daisy, this is not a dream."],[10101,10339,"And I'm not going"],[10339,10489,"anywhere."],[10489,10635,"I promise."],[10781,11156,"You and I will raise Poppy"],[11156,11353,"side by side."],[11578,11799,"Let's get married."]],"36":[[321,538,"I think you've had too much to drink."],[654,834,"No I haven't."],[859,1071,"Daisy, just give me a little more time."],[1071,1151,"Just"],[1151,1276,"until I finished dealing with my"],[1276,1434,"old enemies."],[1434,1689,"Wait for me, and I promise"],[1689,2014,"I'll give you a perfect proposal."],[5176,5372,"Honey,"],[5372,5609,"this is all for you."],[9989,10080,"Mr. Morgan,"],[10135,10285,"I've privately inform all shareholders"],[10285,10414,"of your return."],[10414,10589,"They've all chosen to support you."],[10589,10731,"The board has also verified that"],[10731,10919,"you are the only legal leader"],[10919,11027,"of the corporation."],[11056,11140,"James doesn't even know"],[11140,11248,"he's been cast off."],[11248,11361,"So the company is finally"],[11361,11453,"under my control, then?"],[11490,11703,"All evidence has been collected."],[11703,11840,"We just need your orders."],[12220,12324,"It's time, then."],[12433,12562,"Let's do this."],[12595,12666,"I'm going to take back"],[12666,12825,"everything that he's stolen from me"],[12825,13038,"over the last five years."]],"37":[[329,592,"Mommy, look at all the Shein."],[592,829,"I know, where did it all come from?"],[829,967,"I know."],[1176,1297,"I've prepared several outfits"],[1297,1413,"for you, Daisy."],[1438,1643,"These are the latest designs from"],[1643,1972,"Shein Icon, Shein Bae,"],[1972,2110,"and Shein Mod."],[2110,2302,"Each store focuses on"],[2302,2414,"every trendy style."],[2431,2610,"I picked out a cute dress"],[2610,2761,"for you too, Poppy."],[2806,3061,"It's in this Cozy Pixies bag."],[4066,4237,"I love it!"],[4237,4425,"Thank you, Daddy!"],[4692,5125,"All these outfits are so beautiful, Alex. I-"],[5125,5305,"I can't choose."],[5305,5451,"That's okay, Mommy."],[5451,5751,"I got you something from Shein Bae."],[6881,7144,"Oh, it's the perfect dress."],[7161,7248,"It's a perfect dress"],[7248,7407,"for perfect woman."],[8479,8608,"What are we doing here?"],[8608,8908,"There's a patent for auction here today"],[8908,9079,"that I really want."],[9113,9438,"It is now or never, all or nothing."],[9438,9551,"I need to win it."],[9563,9663,"But"],[9709,9918,"we don't have very much money."],[9918,10076,"Daisy, trust me."],[10076,10281,"Okay? Don't worry."],[10368,10560,"By the way."],[10956,11148,"You look gorgeous"],[11148,11344,"in that new gown from Shein Bae."],[11398,11665,"Oh, so this gown was you"],[11665,11811,"and Poppy sneaking"],[11811,11941,"behind my back?"],[11982,12112,"Guilty."],[12112,12195,"I thought you could use"],[12195,12295,"some extra armor today."],[12295,12395,"And she insisted on"],[12395,12541,"picking out the color."],[12541,12637,"It's beautiful."]],"38":[[158,271,"Well."],[271,571,"Look at you, sis."],[571,721,"What a mess."],[721,892,"Bringing in some filthy hobo"],[892,1134,"you probably picked up from the slums,"],[1134,1393,"and some smelly little brat barely"],[1393,1664,"out of diapers to a high end auction."],[1743,1881,"You're bringing the vibe down"],[1881,2077,"with the stench of poverty."],[2281,2485,"Don't talk about my daddy like that."],[2485,2698,"He's way better than a nasty bully"],[2698,2786,"like you!"],[2794,2944,"Sweetie,"],[2944,3128,"do you know why your mommy"],[3128,3336,"always loses to me?"],[3386,3636,"It's because she doesn't know"],[3636,3837,"when to throw out the trash"],[3837,4029,"that's dragging her down."],[4091,4341,"Insults don't win auctions, Harry."],[4425,4567,"This is about money."],[4612,4729,"You're right."],[4729,4909,"You actually have to have money"],[4909,5096,"to attend this auction."],[5134,5342,"Oh, did you have to mortgage"],[5342,5505,"your little house?"],[5584,5885,"Look at her, acting all high and mighty."],[5926,6064,"Just you wait."],[6064,6197,"Once the bidding starts,"],[6197,6348,"everyone will see that"],[6348,6569,"you and your pathetic homeless"],[6569,6827,"lover can't afford a thing."],[7816,8033,"I need to use the restroom."],[8608,9017,"That looks just like my brother Alex."]],"39":[[496,600,"And now,"],[600,804,"the last item on the auction block."],[804,917,"A patent set"],[917,1088,"to revolutionize the world"],[1088,1205,"of biotech innovation."],[1347,1430,"Neither you nor"],[1430,1568,"your homeless boyfriend"],[1568,1668,"have bid on anything"],[1668,1868,"this entire auction."],[1868,2043,"Are you all out of funds,"],[2043,2127,"or are you saving up"],[2127,2227,"for the big finale?"],[2273,2523,"This is the patent Lex said he wanted."],[2523,2731,"I have to get it for him."],[2786,2969,"Mister, why are you staring"],[2969,3086,"at my mommy?"],[3119,3324,"Do you think she's pretty, too?"],[3324,3470,"Hello again, brat."],[3532,3691,"You may have won 10 million"],[3691,3832,"from me last time."],[3858,4037,"But I'm afraid today you're gonna be"],[4037,4191,"leaving with nothing."],[4300,4446,"I'm not going to let you get a hold"],[4446,4650,"of what my daddy wants, Mister."],[4688,4871,"You don't stand a chance."],[4959,5271,"The starting price is 200 million going-"],[5276,5455,"300 million."],[5455,5563,"350."],[5680,5910,"You'll never beat me, Daisy."],[6039,6197,"500 million."],[6252,6322,"Lex told me"],[6322,6473,"how much he wanted this."],[6473,6623,"I have to keep bidding."],[6623,6760,"550 million."],[6760,7011,"800 million."],[7077,7219,"Well, Daisy."],[7219,7319,"There's no way"],[7319,7524,"I could get that kind of money."],[7524,7753,"Am I really going to let Lex down?"],[7786,8083,"You can stop bluffing now, sis."],[8083,8208,"I bet you're real sorry"],[8208,8295,"you shackled yourself"],[8295,8575,"to some useless bum now, huh?"],[8800,8975,"1 billion."]],"40":[[16,254,"Poppy, this isn't a game."],[254,404,"Mommy, Daddy said"],[404,617,"it was important we won this patent."],[850,1038,"We don't need to be scared of them."],[1071,1267,"You let your kid bid."],[1267,1376,"That's cute."],[1376,1618,"Can she even count past 100?"],[1772,1906,"I knew it."],[1906,2143,"You're just here to make a mess."],[2143,2360,"This is an auction, sis."],[2360,2502,"Not a landfill."],[2606,2806,"Oh, and where is your"],[2806,2932,"hobo boyfriend?"],[3011,3232,"Oh! Did he finally realize he should be"],[3232,3386,"embarrassed by that suit"],[3386,3657,"he probably dug out of some dumpster?"],[3895,4104,"Get these two out of here."],[4162,4362,"This is a high class auction,"],[4362,4562,"not a gathering space for losers."],[4600,4721,"We're just as qualified"],[4721,4859,"to bid as you."],[4859,4963,"Why are you trying so hard"],[4963,5150,"to get us thrown out anyways?"],[5150,5330,"Scared you're gonna lose?"],[5330,5643,"Fine. We'll play."],[5643,5876,"But I'll make sure that you leave"],[5876,5980,"bankrupt!"],[6051,6197,"James!"],[6197,6406,"A reminder to all of our patrons."],[6406,6619,"If you're unable to pay the final bid,"],[6619,6798,"you will be fined 50%"],[6798,6940,"of the final price."],[6973,7173,"One billion, one hundred"],[7173,7349,"million dollars!"],[7349,7561,"1.2 billion."],[7599,7832,"Sweetie, we really do not"],[7832,7924,"have that much money."],[7924,8062,"You have to stop."],[8062,8312,"Mommy, you've gotta trust me."],[8383,8529,"Does your little brat even know"],[8529,8737,"how much 1.2 billion is?"],[8792,8950,"Keep bluffing."],[8950,9088,"I'll have you kicked out."],[9150,9359,"Mister, are you scared?"],[9359,9488,"If you're out of money,"],[9488,9647,"you should leave."],[9793,9918,"One billion,"],[9918,10118,"five hundred million dollars!"],[10293,10427,"Well?"],[10427,10531,"What's wrong?"],[10568,10752,"Aren't you gonna keep bidding?"],[10835,11023,"The Morgan Corporation"],[11023,11261,"has bid 1.5 billion."],[11261,11407,"Do we have any other bids?"]],"41":[[408,696,"Has a patent ever gone for this much?"],[696,913,"I wonder if that little brat’s gonna raise."],[913,1071,"Sky's the limit."],[1071,1263,"Poppy, please."],[1263,1426,"I know that daddy wants that patent,"],[1426,1647,"but we really do not have the money."],[1647,1881,"Mommy, we have the money."],[1943,2156,"2 billion!"],[2740,2848,"Poppy!"],[2848,3007,"Are you crazy?"],[3007,3194,"$2 billion?"],[3194,3370,"I know your pathetic mom"],[3370,3545,"doesn't have that much money."],[3762,3949,"Verify their funds!"],[3949,4129,"There's no way they have that money!"]],"42":[[25,175,"Poppy!"],[175,487,"We really do not have $2 billion."],[588,821,"Oh my God."],[821,1030,"Are they going to arrest us? I-"],[1084,1288,"I can't even afford the fine."],[1288,1447,"Don't worry."],[1447,1601,"We have it covered."],[1714,1835,"Sweetie,"],[1835,2014,"when the auction starts"],[2014,2139,"and people start bidding,"],[2185,2318,"I need you to bid higher"],[2318,2477,"than everyone."],[2477,2669,"No matter what the price, okay?"],[2706,2944,"We need that patent."],[3186,3499,"Okay, Daddy. I got this."],[3628,3778,"According to policy,"],[3778,3874,"we need both parties"],[3874,4049,"to verify their funds."],[5213,5422,"The Ultra-Exclusive Black Card Deluxe!"],[5422,5501,"But there are only three"],[5501,5593,"in the whole world."],[5676,5818,"I heard you could buy a whole city"],[5818,5951,"with the funds on that card."],[5964,6010,"But why does that"],[6010,6135,"little girl have it?"],[6164,6256,"Here you go."]],"43":[[229,450,"You almost got me, you little brat."],[450,642,"I guess you're just a fraud"],[642,809,"trying to pull a fast one with your little"],[809,938,"toy card."],[980,1172,"I could get you out of this, you know?"],[1172,1313,"Begged nicely,"],[1313,1484,"and I'll take you in."],[1559,1760,"As a little maid,"],[1760,1897,"you'll be scrubbing my toilets"],[1897,2060,"for the rest of your life."],[2118,2339,"Harry, you've gone too far."],[2352,2473,"Poppy,"],[2556,2719,"where did you get that bank card?"],[2748,2940,"Daddy gave it to me."],[3119,3294,"That filthy stray?"],[3303,3553,"Daisy, you weren't seriously letting that"],[3553,3749,"dirty hobo trick you."],[3812,3991,"You've lost your mind!"],[3991,4112,"Ma'am,"],[4116,4266,"according to policy, you need to pay"],[4266,4517,"10% of the bidding price immediately."],[4533,4758,"Failure to pay will result in a fine."],[4758,4950,"50% of the final price."],[5067,5334,"That's $1 billion."],[5388,5534,"Not so fast."],[5534,5705,"You still haven't checked his card."],[5705,5868,"What if he doesn't have the money?"],[5868,6101,"Shouldn't he be kicked out first?"],[6260,6389,"The Morgan Corporation's a"],[6389,6560,"global conglomerate."],[6577,6835,"$1 billion is nothing to us."],[7862,8124,"I'm sorry, sir. But your account"],[8258,8387,"has been suspended."],[8641,8825,"Ah! No."],[8871,8958,"What?"]],"44":[[108,275,"Verify their funds!"],[275,475,"There's no way they have that money!"],[967,1092,"Suspend the Executive"],[1092,1263,"Morgan Corporation Card."],[1317,1539,"Yes, immediately."],[1618,1739,"Flank!"],[1993,2198,"Mr. Vice President."],[2198,2373,"What's the meaning of this?"],[2373,2606,"Why is my account suspended?"],[2606,2794,"Sir, I'm not sure."],[2944,3048,"Kick rocks!"],[3065,3165,"James!"],[3165,3319,"What's happening?"],[3553,3732,"This is your doing!"],[3732,3862,"You knew you couldn't pay,"],[3862,3978,"and so you sabotaged"],[3978,4104,"the machine ahead of time!"],[4129,4312,"I'm sure it'll reject every card."],[4329,4533,"No one likes a sore loser, Mister."],[4533,4667,"Your card got rejected."],[4667,4900,"Don't try to blame it on mommy and me."],[5071,5176,"Security!"],[5176,5301,"Get these two troublemakers"],[5301,5405,"out of here!"],[5438,5584,"They're disrupting the auction."],[5584,5772,"And they’re thieves."],[5784,5918,"They're probably using hackers"],[5918,5997,"to steal money"],[5997,6131,"from my family's accounts."]],"45":[[50,304,"Sold to our highest bidder,"],[304,504,"Ms. Daisy Laurent."],[963,1113,"10 billion?"],[1113,1242,"Impossible!"],[1242,1413,"How did she get that much money?"],[1793,2010,"The Morgan family symbol."],[2131,2281,"You little brat!"],[2281,2410,"You stole that black card"],[2410,2560,"from the Morgan family."],[2652,2898,"I've never seen that card before."],[2919,3098,"My family's the only one in America"],[3098,3311,"that can afford a card that exclusive."],[3311,3578,"No, it's my daddy's card!"],[3695,3878,"You little thief!"],[4099,4191,"Guards!"],[4191,4383,"Search them from head to toe!"],[4383,4642,"Everyone in here is worth millions!"],[4642,4783,"There's no telling what else that"],[4783,4963,"little rat has stolen."],[5009,5150,"You're lying!"],[5150,5234,"That's slander."],[5234,5463,"I will call the police on you!"],[5526,5743,"Don't you dare touch them!"]],"46":[[1192,1351,"Who is that?"],[1351,1551,"He's so intimidating."],[1551,1655,"I like that."],[1655,1735,"Wait!"],[1735,1881,"He looks just like-"],[1881,2135,"Daddy, I knew you'd come back."],[2160,2360,"Alex?"],[2360,2585,"No no no no no no no no. This-"],[2585,2736,"This is impossible."],[2852,2969,"How are you still alive?"],[2969,3057,"You should have been-"],[3057,3207,"Should have been killed"],[3207,3357,"in that car accident."],[3445,3624,"Oh, it's good to see you, little brother."],[3624,3799,"It's been a long time."],[3891,3970,"Are you disappointed"],[3970,4137,"to see me?"],[4145,4346,"Oh my God! Alex Morgan! Owner of"],[4346,4496,"the Morgan Corporation."],[4496,4721,"Did he say car crash?"],[4721,4838,"James has refused to speak"],[4838,4950,"about Alex's disappearance"],[4950,5109,"for the past five years."],[5488,5726,"Alex Morgan, huh?"],[5830,6039,"I thought you were a homeless man."]],"47":[[25,162,"So you were lying to me"],[162,367,"this whole time?"],[771,959,"Five years ago,"],[959,1105,"James arranged a car accident"],[1105,1247,"to have me killed."],[1247,1451,"He forged my will"],[1451,1526,"and embezzled money"],[1526,1730,"from Morgan Corporation."],[1730,1935,"I have the proof right here."],[1964,2264,"Congrats on landing the $10 billion deal"],[2369,2502,"for me."],[2869,3048,"You won't live to see it through."],[3582,3816,"No no no no no no."],[3816,3987,"There has to be doctored. This-"],[3987,4099,"This can't be real."],[4099,4237,"Alex is dead!"],[4262,4546,"Guards! He's an impostor!"],[4546,4650,"Throw him out!"],[4650,4921,"Starting today, I'm taking back"],[4921,5025,"my rightful position"],[5025,5259,"as CEO of Morgan Corporation."],[5522,5697,"And as for these two,"],[5697,5809,"they will deal"],[5809,5922,"with the consequences of"],[5922,6035,"their actions."],[6039,6297,"No no no!"],[6297,6456,"I will not lose to you."],[6577,6698,"Put down the gun!"],[7023,7211,"Let's see you survive this."],[7315,7424,"Stop!"]],"48":[[533,667,"Freeze!"],[667,825,"Hey! -Anyone moves,"],[825,938,"I shoot!"],[1017,1109,"James!"],[1142,1272,"I've got nothing to lose."],[1280,1426,"This is about you and me!"],[1501,1647,"Point the gun at me."],[1893,1976,"You always thought you're"],[1976,2193,"better than me, big brother."],[2239,2435,"Five years ago, I beat you."],[2510,2590,"And today I'm gonna"],[2590,2719,"beat you again."],[2727,3028,"James, you want me dead."],[3048,3169,"So kill me!"],[3169,3299,"Leave Daisy and my daughter"],[3299,3395,"out of this!"],[3511,3699,"You think I'm stupid?"],[3699,3778,"Everyone can see that they’re"],[3778,3903,"your Achilles heel."],[4554,4854,"Get on your knees and bark like a dog."],[5067,5251,"Maybe if I'm feeling nice,"],[5251,5392,"I'll let them go."],[6331,6385,"Lex!"],[6385,6519,"Daddy!"],[7657,7774,"Ah!"]],"49":[[4,179,"It's okay, Sweetie."],[179,346,"Daddy's okay. I'm safe."],[621,900,"Daisy, I told you I would never let"],[900,1030,"anything happen to you"],[1030,1267,"or Poppy ever again."],[1876,2014,"Mommy,"],[2014,2168,"isn’t Daddy coming?"],[2214,2452,"That man is not your daddy."],[2452,2577,"He's a liar. He's the reason"],[2577,2706,"why you were in danger."],[2706,2802,"Mommy,"],[2802,2986,"Daddy isn't a liar."],[2986,3157,"He just didn't remember."],[3190,3390,"And he was protecting me"],[3390,3503,"just now."],[3503,3707,"Daisy, let me explain!"],[3782,3970,"Explain what?"],[3970,4091,"How long you were pretending"],[4091,4270,"to have amnesia for?"],[4300,4500,"How many times did you put Poppy"],[4500,4738,"in danger while you hid in the shadows?"],[4750,4875,"Poppy, let's go!"],[5255,5367,"I’m sorry you got a bigger fight"],[5367,5505,"ahead of you, boss."],[6310,6460,"Daisy!"],[6710,6952,"Daisy, come on! Please open up."]],"50":[[216,517,"I thought he was sweet, kind,"],[563,684,"simple."],[771,1038,"And I trusted him. But"],[1188,1393,"it was all an act."],[1472,1768,"Mommy, can you please let daddy in?"],[1768,1981,"Maybe he has a good reason."],[1981,2264,"Don't you want to hear him out?"],[2264,2515,"Or if you won't let him in?"],[2515,2711,"Can I go out?"],[2711,2986,"Even if you don't want to know, I do."],[2986,3098,"You're not going to take off and"],[3098,3278,"run away with Daddy, are you?"],[3307,3390,"Never!"],[3390,3591,"Poppy is Mommy's baby."],[3645,3883,"I'll never leave Mommy."],[3883,4108,"But I want to know why Daddy lied and"],[4108,4241,"made you sad?"],[4366,4450,"Okay."],[4629,4738,"You can ask him."],[4996,5171,"Thank you, Mommy."],[6381,6448,"Oh, Sweetie."],[6448,6531,"Mommy might be mad"],[6531,6702,"if she finds you sneaking out."],[6702,6977,"Mommy said I could ask you questions."],[6990,7073,"Sweetie, I never meant to"],[7073,7194,"make you worry."],[7194,7386,"Then why did you lie to Mommy?"]],"51":[[16,279,"Then why did you lie to Mommy?"],[379,663,"I didn't mean to lie to Mommy."],[663,842,"I've been looking into my car accident"],[842,963,"from five years ago,"],[1017,1092,"and I knew that"],[1092,1259,"James wanted me dead."],[1313,1413,"But I thought that he would come"],[1413,1530,"after you two"],[1530,1768,"if everyone knew I was back."],[2398,2602,"You could have just told me!"],[2602,2773,"Instead, you kept me in the dark,"],[2773,2936,"hiding the truth from me like"],[2998,3148,"you couldn't even trust me?"],[3240,3474,"Mommy, don't be mad."],[3507,3678,"Daddy isn't a bad guy."],[3678,3978,"Poppy, this is a really big deal."],[4020,4220,"Lying isn't okay. And-"],[4220,4466,"And daddy put you in a lot of danger."],[4558,4879,"But Daddy was the one who saved us."],[4879,5017,"He said he would protect us"],[5017,5192,"and never leave."],[5192,5309,"Right?"],[5634,5751,"Sweetie, I promise you,"],[5751,5918,"I'll never leave you."],[5968,6202,"And I'll never hide anything from you"],[6410,6710,"or from Mommy ever again."],[7182,7440,"Daisy, please give me another chance."]],"52":[[296,442,"Okay. And anything else that"],[442,604,"I can get for you tonight?"],[675,804,"Great."],[804,963,"I’ll be right back for you guys."],[1280,1384,"What are you doing here?"],[1393,1488,"You're awfully busy today."],[1488,1551,"I thought I'd bring you"],[1551,1664,"some flowers and"],[1764,1847,"brighten your day."],[1856,2018,"Hand-delivered by the CEO"],[2018,2223,"of the Morgan Corporation, huh?"],[2310,2477,"Don't you make hundreds"],[2477,2694,"of thousands of dollars a minute?"],[2694,2794,"That makes that a very"],[2794,2919,"expensive bouquet."],[2961,3115,"Well, the CEO considers it"],[3115,3415,"part of his duty to bring his lover"],[3415,3536,"some flowers."],[3603,3732,"Well, you're a sweet talker,"],[3732,3878,"but did you really think that"],[3878,3978,"I gave you another chance"],[3978,4129,"just so you could pamper me?"],[4129,4425,"Well, you know that I can serve you well"],[4425,4546,"in bed."],[4596,4808,"Trust me, I don't mind"],[4808,4975,"doing a little extra work."],[5993,6172,"James is out on bail?"],[6690,6848,"Hey, Poppy."],[6848,6986,"You remember your uncle?"]],"53":[[20,316,"I remember you. You’re the bad guy."],[333,504,"It's all your fault."],[504,663,"Now I'm a cripple."],[721,959,"You little brat!"],[959,1101,"You're coming with us."],[1134,1247,"Do you guys like playing"],[1247,1376,"hide and seek?"],[1659,1805,"Ah! -Ah!"],[1805,2047,"My eyes! Ah! God!"],[2085,2173,"It's pepper spray."],[2173,2377,"My mommy taught me this move."],[2898,3003,"Oh! -Oh!"],[3003,3094,"I hate you!"],[3148,3219,"Ah-"],[3219,3378,"Oh! -Ah!"],[4087,4191,"Daddy!"],[4191,4316,"The bad guys are here."],[4316,4441,"But I caught them."],[4600,4754,"Poppy, are you okay?"],[4779,4875,"I'm okay."],[4875,5017,"The bad guys just tripped,"],[5017,5155,"all on their own."],[5155,5359,"I'm sure they get some rest."],[5413,5530,"That little demon!"],[5530,5684,"The brat tricked us!"],[5885,6085,"That's no normal kid!"],[6085,6243,"You guys are coming with me."],[6243,6385,"My leg! Oh!"],[6669,6819,"Good job, Poppy."],[7123,7340,"Hey, you okay?"],[7611,7736,"Poppy,"],[7736,7878,"why was there a needle in your bed?"],[7924,8012,"Are you all right?"],[8012,8199,"Wait, there was a needle in her bed?"],[8274,8350,"I thought that I kept"],[8350,8521,"all sharp objects out of reach."],[8521,8612,"I mean, do you think that"],[8612,8704,"somebody else could be trying to"],[8704,8767,"hurt her?"]],"54":[[4,216,"I'm sorry, Mommy. That was just me."],[216,367,"I was playing with it."],[367,462,"Why were you playing"],[462,538,"with a needle?"],[538,700,"To stab a little baggie."],[700,813,"What baggie?"],[813,925,"The mean little baggies"],[925,1046,"that are stopping mommy from"],[1046,1272,"having more babies."],[2214,2356,"You popped these?"],[2389,2598,"Yep! Every single one."],[2610,2756,"They're so mean!"],[2756,2844,"Why would they want to stop"],[2844,2940,"Mommy from having"],[2940,3040,"more babies?"],[3040,3199,"Mr. Morgan, why don't you take"],[3199,3361,"Ms. Laurent to the hospital?"],[3386,3520,"I think she should take"],[3520,3632,"a pregnancy test."],[3766,3920,"Oh, oh- Hey."],[4004,4187,"Yeah. Let's get you to the hospital."],[4204,4354,"Well, I get a baby brother"],[4354,4487,"or sister soon."],[4646,4763,"Maybe."],[4763,4971,"You little brat."],[5196,5463,"Congratulations, Ms. Daisy Laurent!"],[5463,5609,"You're six weeks pregnant."]],"55":[[29,162,"She's pregnant?"],[162,250,"Are you sure?"],[271,404,"Very sure."],[404,492,"And you'll be happy to know"],[492,592,"the baby's healthy."],[1434,1643,"Daisy,"],[1643,1843,"will you marry me?"],[1843,2006,"But I can't even remember the night"],[2006,2143,"that we met."],[2173,2394,"Well, then we'll start over again."],[2515,2815,"Daisy, I love you."],[2911,3261,"And not because of some obligation"],[3261,3528,"to our past,"],[3528,3745,"but because of who you are."],[3745,3912,"Even without our memories,"],[3912,4216,"we found a way back to each other."],[4225,4512,"And I got to fall in love with you"],[4512,4704,"all over again."],[4896,5050,"So,"],[5155,5330,"will you marry me?"],[5330,5580,"Of course I will."],[6585,6886,"Tell me every second of our story."],[6965,7203,"I don't want to miss a second of it."]]}