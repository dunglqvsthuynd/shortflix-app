found out before"],[6439,6639,"Mother gave you the company."],[6656,6769,"I guess"],[6769,6873,"Blaine and I will have"],[6873,7069,"to run it by ourselves."],[7069,7152,"Agnes, do you really want"],[7152,7236,"to give your company"],[7236,7307,"to the people who have"],[7307,7399,"been stealing from you?"]],"45":[[12,212,"Okay, that is enough."],[258,367,"It turns out that old"],[367,567,"man Blaine isn't really rich."],[579,738,"Just old."],[738,975,"We don't know what he's talking about."],[980,1180,"He lost everything years ago."],[1192,1322,"These two have been embezzling"],[1322,1380,"from the Sutter"],[1380,1530,"Corporation for years now."],[1530,1639,"Christia!"],[1639,1730,"Mother!"],[1747,1914,"Don't believe him."],[1914,2114,"There is no proof."],[2168,2227,"You're right."],[2227,2331,"I don't."],[2331,2460,"Actually, not anymore."],[2460,2540,"I turned it all in"],[2540,2740,"to the SCC yesterday."],[2786,2944,"Agnes, this whole time"],[2944,3115,"you had one good daughter"],[3115,3345,"and you treated her like absolute shit."],[3395,3545,"Now you're all going"],[3545,3745,"to get what you deserve."],[3899,3995,"As of today,"],[3995,4108,"the Prestige"],[4108,4162,"Industries"],[4162,4283,"will terminate all business"],[4283,4471,"with the Sutter Corporation."],[4471,4704,"And exactly on whose authority?"],[4704,4938,"On mine. You see, I'm-"]],"46":[[4,120,"On mine."],[120,221,"You see. I'm-"],[221,321,"A common"],[325,525,"con artist."],[571,692,"That's Vaughn Weathers,"],[692,892,"Senior VP of Prestige."],[996,1113,"In the flesh."],[1113,1213,"I want to apologize"],[1213,1355,"for this disturbance."],[1363,1422,"Security"],[1422,1488,"should have never let"],[1488,1626,"this man in here."],[1626,1676,"He has been"],[1676,1876,"terrorizing and taunting us."],[1901,1960,"He's spreading"],[1960,2027,"lies."],[2027,2127,"I want him arrested"],[2127,2227,"for slander."],[2227,2323,"Oh, he'll be arrested,"],[2323,2377,"all right."],[2377,2602,"Assault. Tres