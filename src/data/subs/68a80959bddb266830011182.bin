:[[12,83,"I will never take"],[83,208,"my father's money."],[208,371,"I swore it on my mother's grave."],[371,571,"Your vow to your mother is noble,"],[600,654,"but what about"],[654,834,"your foster mother, Grace?"],[834,1034,"You could save her with that money."],[1184,1368,"They're going to kick me out"],[1368,1505,"if I can't pay,"],[1505,1605,"Jack."],[1605,1893,"I need this machine to breath."],[2031,2181,"I'll get the money."],[2181,2369,"I swear."],[2369,2569,"I know that money's due today."],[2569,2806,"You're a stay at home dad, Jack."],[2831,3028,"Living off your wife's family."],[3028,3123,"You can't save Grace"],[3123,3304,"without this money."],[3436,3636,"I will find it another way."],[3674,3766,"Without taking a dime"],[3766,3883,"from that bastard."],[3883,4087,"Now, if you'll excuse me, I need to go"],[4087,4287,"talk to some banks about a loan."],[4633,4796,"Who is that guy?"],[4796,4854,"That is the"],[4854,5121,"richest man on planet Earth..."],[5238,5438,"even if he won't admit it yet."]],"6":[[1155,1284,"And so, Mother,"],[1284,1484,"for your retirement,"],[1501,1568,"my husband"],[1568,1768,"and I have gotten you this..."],[1918,2147,"diamond necklace."],[2156,2498,"Oh, it's so stunning."],[2510,2736,"Not as stunning as you, Agnes."],[3265,3374,"Well,"],[3374,3620,"our present is not as beautiful"],[3653,3862,"as my dear sisters, but"],[3920,4120,"it is faster."],[4375,4575,"I hope it fits."],[4842,5042,"Oh, my."],[5100,5359,"Guys... is it to the Maserati"],[5359,5555,"I wanted?"],[5572,5709,"It's almost too"],[5709,5910,"much."],[6147,6448,"Up next, our youngest sister,"],[6448,6785,"Sophia and her husband,"],[6840,7090,"Jack."],[7090,7182,"Oh! Um..."],[7215,7403,"Happy retirement, Mom."],[7407,7486,"I'm sorry."],[7486,7549,"I didn't realize"],[7549,7749,"we were giving gifts today."],[7912,8070,"Didn't realize or couldn't"],[8070,8270,"afford one?"],[8274,8324,"Aww."],[8400,8475,"Sophia,"],[8495,8575,"if you were having"],[8575,8767,"money problems, we could've"],[8767,8858,"given you a loan."],[8858,9059,"You're such a good son-in-law."],[9104,9280,"Unlike your husband, Sophia,"],[9280,9480,"who didn't even bother to show up."],[9488,9630,"I don't know where he is."],[9630,9705,"I've been trying"],[9705,9726,"to get"],[9726,9909,"a hold of him all day, but"],[9909,10051,"there must have been an emergency."],[10051,10155,"What kind of emergency"],[10155,10368,"could happen to a stay at home dad?"],[10377,10510,"Was there a life or death"],[10510,10610,"laundry disaster?"],[10823,11073,"Oh."],[11073,11102,"Hey!"],[11102,11273,"You be nice to my daddy!"],[11273,11319,"Or what?"],[11353,11553,"You little half-peasant brat."],[11557,11674,"What's wrong with you?"],[11674,11782,"She's a child."],[11782,11907,"Exactly."],[11907,12012,"And I specifically"],[12012,12132,"put on my invitation"],[12132,12208,"to this party,"],[12208,12370,"adults only."],[12370,12566,"I couldn't afford a sitter."],[12687,12816,"Well, here."],[12816,12958,"This should shut you up."],[13125,13284,"No! Christia!"],[13284,13346,"It's peanut butter!"],[13346,13484,"She's allergic!"],[13684,13767,"I told you."],[13767,13884,"Oh, Jesus."],[13884,13955,"It's always"],[13955,14080,"something with you!"],[14139,14176,"Darling,"],[14218,14301,"why don't you take"],[14301,14393,"the little urchin"],[14393,14501,"to where her crying won't"],[14501,14702,"ruin the party that she planned?"],[14702,14798,"Brilliant idea,"],[14798,14914,"my love."],[15065,15102,"Oh!"],[15102,15202,"No! No, Christia!"],[15202,15286,"Where are you going?"],[15286,15436,"She can't breathe!"]],"7":[[0,66,"No!"],[66,129,"Let go of me!"],[129,329,"No, Christia! What are you doing?"],[408,571,"She can't breathe!"],[613,713,"Calm down,"],[713,775,"my sweet"],[775,909,"sister-in-law."],[909,1009,"If you can't handle"],[1009,1088,"your spawn,"],[1088,1163,"we'll deal with her."],[1247,1334,"Leave her alone!"],[1334,1514,"She's having an allergic reaction!"],[1643,1739,"Mom!"],[1739,1851,"Haley, I'm coming!"],[1935,2127,"Can't...breathe..."],[2127,2185,"Please Christia,"],[2185,2323,"what are you doing?"],[2323,2414,"Punishing her."],[2414,2585,"Something you never do."],[2585,2652,"Just let her go!"],[2652,2773,"She needs her EpiPen!"],[2873,3023,"Oh! Calm down."],[3023,3148,"Please, she could die!"],[3148,3353,"Oh my God!"],[3411,3611,"Can you stop being so dramatic?"],[3624,3832,"Mother, you have to stop this, please!"],[3832,3945,"Well, she can come out"],[3945,4145,"when she starts behaving."],[4208,4300,"Please!"],[4300,4400,"- Mom! - Haley!"],[4400,4521,"I'm coming!"],[4521,4600,"Hey!"],[4704,4917,"Haley! Haley! I'm coming!"],[4917,5067,"Can't...breathe.."],[5067,5159,"Mom!"],[5201,5351,"Somebody help, please!"],[5814,5901,"Mom!"],[5947,6064,"What the hell is going on?"]],"8":[[41,175,"Where's my daughter?"],[175,337,"Jack! Help!"],[337,392,"Haley!"],[392,538,"Sophia. Here, here, here..."],[583,684,"I got you."],[684,788,"- It's okay. - Mom!"],[842,925,"Mom!"],[959,1067,"Back up. Back up."],[1284,1363,"Daddy!"],[1484,1534,"Honey,"],[1534,1634,"I need you to close your eyes"],[1634,1822,"for this, okay?"],[1822,2018,"You got this! Ready?"],[2485,2581,"Daddy."],[2723,2798,"Daddy."],[2798,2944,"Aunt Christia..."],[2944,3144,"she locked me in the closet."],[3636,3782,"What the hell is wrong with you?"],[3782,3974,"You don't talk to my wife that way."],[3974,4204,"I was taking care of the child"],[4225,4412,"as Sophia was having a hard time"],[4412,4471,"doing it."],[4471,4554,"And you just"],[4554,4671,"disappeared for the day."],[4671,4767,"You evil bitch-"],[4767,4867,"Jack!"],[4867,4942,"It's okay."],[4942,5142,"Let's just go."],[5142,5342,"No, we can't go yet."],[5397,5476,"I went to every bank"],[5476,5568,"in town today, and not a"],[5568,5689,"single one gave me a loan."],[5805,5897,"I'll get the money."],[5972,6068,"I swear."],[6193,6327,"There's no other choice, Sophia."],[6589,6781,"Agnes, can I talk to you"],[6781,6906