{"1":[[125,325,"Come on, hon. We're running late."],[663,863,"Why do we have to walk to school?"],[875,1076,"Why don't we have a car?"],[1259,1426,"Because we can't afford a car."],[1426,1634,"Daddy, are we poor?"],[1960,2031,"When I was younger,"],[2031,2227,"I had a lot of cars and money,"],[2227,2385,"but no love."],[2385,2585,"Now I don't have money, but..."],[2627,2802,"I have you and Mommy."],[2802,2919,"And that's more important to me"],[2919,3119,"than all the cars in the world."],[3148,3349,"I love you."],[3824,4100,"Now, go!"],[5726,5805,"Hey!"],[6510,6581,"Hey!"],[6690,6790,"Are you okay?"],[6790,6890,"Is anything hurt?"],[6890,7015,"Get away from my daughter, you"],[7015,7111,"sick pervert!"],[7111,7269,"Hey, hey, wait a minute, okay?"],[7269,7386,"Stay away from that man, Darcy."],[7386,7461,"Okay, just be careful,"],[7461,7578,"Back off,"],[7578,7728,"or I'll call the cops!"],[7728,7811,"Tell them some"],[7811,7899,"pedophile"],[7899,8028,"is hanging around"],[8028,8229,"outside the school."],[8266,8316,"Daddy?"]],"2":[[129,262,"Sweetie."],[262,304,"Okay."],[304,371,"All right, just"],[371,471,"calm down, all right?"],[471,575,"I just saved your daughter"],[575,679,"from being hit by a car."],[679,788,"I'm just trying to help."],[788,838,"Oh, really?"],[838,896,"Yeah."],[896,1021,"Because it looked to me"],[1021,1063,"like you were"],[1063,1263,"trying to cop a feel, you sicko."],[1284,1376,"W-What do you do?"],[1376,1539,"Just hanging around outside schools"],[1539,1739,"looking to grab little girls?"],[1805,2006,"Leave my dad alone."],[2018,2206,"You talk to me with respect,"],[2206,2406,"you dirty little brat."],[2452,2598,"You're not in your trailer park"],[2598,2652,"anymore."],[2723,2882,"Stop it! She's nine."],[2882,3011,"Darcy,"],[3011,3211,"do you know this little girl?"],[3319,3507,"I don't want you to talk to her."],[3507,3670,"I don't want you to look at her."],[3670,3728,"I don't want you"],[3728,3853,"to be friends with her."],[3853,4054,