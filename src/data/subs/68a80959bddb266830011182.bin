lose your eyes"],[4917,5105,"and take comfort"],[5105,5234,"in how much I'm"],[5234,5359,"going to enjoy"],[5359,5434,"this."],[5651,5734,"Sophia,"],[5734,5855,"I knew you would"],[5855,6018,"never let anything bad-"],[6018,6218,"Oh. Oh."],[6552,6715,"When you're in jail"],[6735,6915,"and they corner you in the shower,"],[7015,7186,"just close your eyes"],[7207,7307,"and take comfort in"],[7307,7507,"how much they're enjoying it."],[7511,7582,"No!"],[7607,7670,"No!"],[7728,7791,"No!"],[7807,7932,"I'm Vaughn!"],[7932,7974,"No!"]],"54":[[387,546,"Bravo Jack!"],[546,629,"Yeah."],[629,905,"I never trusted him anyways."],[909,1117,"We're all glad that he's gone."],[1167,1272,"I am glad"],[1272,1343,"that I'll never have"],[1343,1476,"to see him again."],[1476,1605,"Oh, well..."],[1605,1647,"then you're going"],[1647,1847,"to hate this next part."],[2052,2248,"What's wrong?"],[2293,2481,"Like I said earlier,"],[2481,2598,"I've already alerted the"],[2598,2711,"authorities on your embezzling"],[2711,2836,"and tax fraud."],[2836,2940,"So you'll be leaving with the"],[2940,3003,"police as well."],[3003,3174,"- Oh, pretty please! - Oh no!"],[3174,3207,"Mami."],[3228,3407,"Under my leadership,"],[3407,3616,"Prestige Industries will tolerate"],[3616,3787,"zero criminal activities"],[3787,3958,"from our employees and our"],[3958,4054,"partners."],[4145,4233,"Which leads me to my"],[4233,4387,"second announcement."],[4441,4554,"Concerning our partnership"],[4554,4754,"with the Sutter Corporation."],[4763,4963,"Jack, please."],[4971,5171,"I'm sorry, Agnes, I can't hear you."],[5205,5355,"Why don't you come up here and"],[5355,5463,"get on your knees and beg?"]],"55":[[16,291,"Oh, you can't be serious."],[329,529,"So, please, Jack."],[588,767,"I know we've had our differences,"],[767,792,"but"],[938,1092,"don't do this."],[1092,1234,"Do what?"],[1234,1384,"End our partnership?"],[1384,1480,"Thus bankrupting"],[1480,1680,"your entire company?"],[1780,1981,"Don't worry, I won't."],[2