 and sorry"],[4483,4629,"about your rose garden."],[4708,4817,"What about it?"],[5955,6156,"He destroyed my garden."],[6239,6448,"That's my dad."],[7695,7774,"Sir, your"],[7774,7974,"ride awaits."]],"13":[[221,283,"Congrats."],[283,354,"You now own"],[354,554,"Prestige Industries."],[571,692,"No one knew your father"],[692,880,"was ill before he died."],[880,963,"He changed towards"],[963,1084,"the end."],[1130,1422,"His biggest regret was abandoning you."],[1459,1639,"He wanted you to have this."],[1639,1714,"I never wanted to take"],[1714,1851,"my father's money,"],[1851,1893,"but if it'd"],[1893,2060,"save my foster mother,"],[2060,2189,"I have to take it."],[2189,2293,"Is it possible for me to get"],[2293,2494,"$100,000 today?"],[2527,2656,"You were one of the richest men"],[2656,2773,"in the world."],[2773,2902,"In the amount of time it took for us"],[2902,3103,"to walk down this hallway,"],[3119,3319,"you've made that much money."],[3386,3586,"This is your black diamond card."],[3628,3707,"It's the only one"],[3707,3849,"like it in the world."],[3849,4004,"And it's yours."],[4004,4033,"You could"],[4033,4141,"literally buy a small"],[4141,4337,"country with it."],[4479,4579,"I need this"],[4579,4775,"machine to breathe."],[4796,4954,"Why don't we have a car?"],[4954,5167,"Somebody help, please!"],[5167,5234,"Mom!"],[5826,5955,"Oh, Jack."],[5955,6147,"They're about to kick me out."],[6147,6331,"Doctor Barnes, wait! Okay?"],[6331,6414,"The bill is paid."],[6414,6523,"Don't unplug the machine."],[6535,6631,"The guy who comes in here"],[6631,6756,"looking homeless"],[6781,6902,"just magically comes up with"],[6902,7015,"a hundred grand?"],[7098,7261,"Sorry, rules are rules."],[7261,7328,"Oh..."],[7365,7403,"No,"],[7403,7561,"if you unplug her, she'll die."],[7590,7665,"You should've thought of that,"],[7665,7724,"Mr. Harrington"],[7724,7912,"before you stopped paying her bills."],[7974,8024,"Jack,"],[8024,8224,"what's happening?"],[8224,8354,"The bill is paid."],[8354,8495,"Okay, just wait for Doctor Olsen."],[8495,8604,"He can explain everything."],[8604,8729,"Doctor Olsen is the head"],[8729,8829,"of the hospital."],[8829,8996,"He's too busy to deal with"],[8996,9175,"charity cases."],[9175,9342,"Now get out of here before I have you"],[9342,9405,"arrested."]],"14":[[183,262,"I'm warning you."],[262,400,"You're making a big mistake!"],[400,583,"Doctor Barnes is a genius"],[583,734,"who doesn't make mistakes."],[734,834,"You should take it up with"],[834,934,"your insurance..."],[938,1105,"if you even have any."],[1113,1217,"I don't have time!"],[1217,1322,"She'll be dead in minutes without"],[1322,1405,"the machine."],[1405,1530,"Well, next time,"],[1530,1730,"don't be poor."],[1814,1856,"Jack,"],[1856,2056,"don't let them unplug me."],[2156,2356,"Wait until Dr. Olsen arrives!"],[2364,2473,"Last warning."],[2473,2686,"Are you stupid or what?"],[2798,2998,"Get out of here!"],[3023,3128,"Oh!"],[3315,3424,"Get security!"],[3553,3603,"Jack!"],[3603,3732,"I'm scared."],[3732,3816,"Don't be."],[3816,3920,"It'll be fine."],[3991,4099,"Besides,"],[4099,4237,"I knew you'd try to pull something"],[4237,4383,"even after I paid the bill,"],[4383,4567,"because you're a piece of shit."],[4567,4679,"So I decided to go around you."],[4783,4896,"What'd you do?"],[4929,5059,"Call a lawyer?"],[5059,5292,"No, I bought the hospital."],[5509,5668,"Sure, you just happened to"],[5668,5847,"have a hundred million dollars"],[5847,5935,"laying around?"],[5935,6022,"Actually, I'm"],[6022,6081,"now the owner of"],[6081,6197,"Prestige Industries."],[6197,6364,"You...fool!"],[6364,6452,"Everyone knows"],[6452,6644,"that Thomas Parker owns Prestige."],[6644,6815,"Thomas is dead."],[6815,6927,"I'm his son."],[6927,7052,"If you're gonna lie,"],[7052,7253,"at least make it believable."],[7257,7432,"Now get off of me,"],[7432,7578,"or you'll be in jail"],[7578,7665,"for your own"],[7665,7849,"bitch of a mother's funeral."],[8016,8078,"Oh!"],[8137,8233,"Finally."],[8287,8454,"Escort him out of here."],[8454,8554,"I wouldn't listen to him"],[8554,8666,"if I were you, gentlemen."],[8666,8812,"What are you waiting for?"],[8812,8917,"Get Mr. Harrington"],[8917,9071,"off the premises."],[9238,9313,"I'm no longer"],[9313,9442,"Mr. Harrington."],[9442,9626,"My real name is Jack Parker,"],[9626,9826,"CEO of Prestige Industries."],[9926,10047,"And right now,"],[10080,10214,"you're in my hospital."]],"15":[[16,133,"He's lying."],[133,333,"Grab him!"],[496,696,"Wait!"],[967,1138,"You punched me!"],[1138,1363,"No one punches me."],[1864,2039,"I want you to watch"],[2039,2131,"as your only"],[2131,2460,"parent struggles to wheeze her one"],[2485,2673,"last breath."],[2894,3128,"I'm going to make you pay for that!"],[3415,3611,"Please, dont!"],[3670,3745,"No!"],[4154,4216,"Jack..."],[4279,4387,"No, the bill is paid!"],[4387,4483,"Doctor, please."],[4483,4504,"Please."],[4504,4583,"You're killing her."],[4583,4688,"This is a hospital."],[4688,4821,"People die every day."],[4821,4867,"Please."],[4867,4950,"Grace, it'll be fine."],[4950,5134,"Wait for Doctor Olsen, please."],[5134,5259,"No one is coming"],[5259,5513,"for a poor old lady."],[5663,5843,"No!"],[6139,6222,"Shoot him!"],[6222,6402,"Now! Or you're fired."],[6402,6539,"Shoot me now if you have to,"],[6539,6715,"but I'm plugging her back in."],[6715,6848,"Shoot him now."],[7069,7290,"What the hell is going on?"],[7399,7582,"Dr. Olsen?"]],"16":[[375,513,"Grace?"],[513,629,"You're okay."],[629,829,"Oh, Jack."],[1001,1201,"You're here."],[1201,1351,"Doctor Barnes,"],[1351,1551,"your contract is terminated,"],[1576,1776,"effective immediately."],[1814,1976,"On whose authority?"],[1976,2160,"Our new owner's."],[2160,2252,"Is there anything else,"],[2252,2327,"Mr. Parker?"],[2327,2569,"No! He's Jack Harrington!"],[2615,2773,"I-It can't be!"],[2773,2873,"Doctor Olsen,"],[2873,2965,"I want you to personally"],[2965,3048,"take care of her treatments"],[3048,3115,"moving forward."],[3115,3249,"That would be my pleasure."],[3486,3528,"Let's check"],[3528,3728,"your vitals."],[4245,4333,"Have the medical board"],[4333,4375,"run a full"],[4375,4575,"investigation into your behavior."],[4621,4717,"Criminal malpractice"],[4717,4909,"can result in prison time."],[4909,5109,"Please."],[5184,5326,"Don't do this."],[5326,5526,"I wasn't really going to kill her."],[5618,5684,"Beg."],[5739,5809,"What?"],[5809,6010,"Beg for me not to throw you into jail."],[6222,6423,"Please."],[6431,6556,"Please."],[6556,6756,"Mr. Parker."],[6810,7011,"I am so sorry."],[7173,7374,"Have mercy."],[7553,7657,"Like the mercy you were going"],[7657,7778,"to show my foster mother?"]],"17":[[54,342,"No, don't do this."],[342,404,"He almost"],[404,571,"turned you into murderers."],[675,855,"Escort him out."],[855,942,"However you see fit."],[942,1146,"No, no, no, no."],[1146,1217,"Wait. Now."],[1217,1418,"Don't! Please."],[1981,2106,"Jack..."],[2185,2293,"I know you never"],[2293,2381,"wanted to take"],[2381,2581,"over your father's business,"],[2594,2698,"and I'm sorry"],[2698,2898,"you had to do it for me."],[2932,3040,"Grace,"],[3040,3115,"you took me in"],[3115,3286,"when no one else would."],[3286,3482,"I owe you everything."],[3536,3749,"I would take over a drug cartel"],[3749,3820,"for you"],[3820,3916,"and ship bodies"],[3916,4024,"to the Mojave Desert"],[4024,4141,"while punching the mailman"],[4141,4320,"if that meant keeping you safe."],[4320,4500,"Besides,"],[4500,4642,"I can now give my wife and daughter"],[4642,4842,"the lives they deserve."],[4850,4921,"Her family's done"],[4921,5021,"nothing but ridicule her"],[5021,5134,"since she married me."],[5134,5334,"It's time to change that."],[5422,5622,"Where are you going?"],[5659,5860,"I have a party to attend."],[6085,6285,"I'll be back."],[6769,6827,"I just want you"],[6827,6940,"to know we hated him."],[6940,7111,"We're so glad he's gone."],[7111,7215,"And now a real man"],[7215,7386,"is running this place."],[7386,7424,"We'd like"],[7424,7624,"to welcome you to the hospital."],[7691,7903,"Really welcome you."],[7903,7995,"Maybe with..."],[7995,8124,"A sponge bath?"],[8187,8320,"Have you ever had four"],[8320,8537,"hands caressing your body?"],[8600,8771,"Sorry ladies,"],[8771,8967,"but I'm married."],[8967,9042,"Excuse me."]],"18":[[8,346,"Sophia, your husband's stupid"],[346,533,"stunt just destroyed"],[533,742,"my million dollar garden."],[763,888,"Mom, please."],[888,971,"I'm sure he has a"],[971,1142,"good explanation for all of this."],[1142,1343,"I'm sure he doesn't."],[1405,1584,"Forget about him, Sophia."],[1584,1664,"It's better if you two"],[1664,1776,"just have a clean break."],[1776,1839,"Vaughn,"],[1839,2089,"I am so glad you showed up."],[2377,2515,"Ah, sorry I'm late."],[2515,2631,"It's not easy being the"],[2631,2836,"Senior VP at Prestige Industries,"],[2836,2869,"the most"],[2869,3065,"profitable company in the world."],[3219,3420,"A small token."],[3741,3962,"This is a Château"],[3962,4325,"Mouton Rothschild 1942?"],[4487,4562,"It's a million"],[4562,4671,"dollar bottle."],[4800,5134,"If only I could make you my heir."],[5276,5409,"Agnes, I've never wanted"],[5409,5543,"your company."],[5543,5593,"I've always had"],[5593,5805,"my eye on a more valuable"],[5805,6006,"asset of yours,"],[6010,6081,"Sophia."]],"19":[[225,291,"So,"],[291,508,"how's our little plan going?"],[550,646,"Perfectly."],[709,775,"Sophia just"],[775,900,"went upstairs to play"],[900,1030,"with her daughter."],[1030,1238,"I told Vaughn to follow."],[1447,1559,"He's too handsome"],[1559,1743,"for her to resist."],[1743,1968,"Well, even if she does,"],[1997,2064,"Vaughn has a"],[2064,2369,"reputation of being persuasive."],[2473,2615,"When it comes to women,"],[2615,2844,"he takes what he wants."],[2865,3053,"Serves the prissy bitch right."],[3053,3190,"Oh, Drea!"],[3211,3286,"What?"],[3286,3378,"She is!"],[3378,3545,"Besides, as soon as she gets a"],[3545,3778,"taste of a real man like Vaughn,"],[3812,4004,"she'll dump her sad sack of"],[4004,4129,"a husband in a heartbeat!"],[4129,4266,"And then,"],[4266,4412,"we will get a taste"],[4412,4612,"of Vaughn's money."],[4750,4821,"Cheers."],[4842,4954,"Cheers."],[5025,5213,"29 and 30."],[5217,5417,"Ready or not, here I come."],[5668,5739,"Vaughn!"],[5739,5860,"Looks like you found me."],[5860,6060,"You scared me."],[6085,6256,"What do you want?"],[6256,6435,"We both know what I want."],[6435,6485,"You."],[6556,6619,"Vaughn,"],[6619,6815,"I'm married."],[6948,7077,"Jesus, Sophia,"],[7111,7357,"is there even a diamond on that?"],[7357,7378,"Wouldn't"],[7378,7557,"you rather be with a..."],[7557,7691,"an alpha?"]],"20":[[41,150,"Mom..."],[221,296,"are you going to"],[296,496,"come look for me?"],[508,554,"Please,"],[554,688,"I think I hear my daughter."],[688,888,"I have to go."],[921,1042,"You're not going anywhere."],[1042,1205,"Please just get off of me!"],[1205,1267,"Hey."],[1267,1376,"Don't act like you haven't been"],[1376,1580,"been dying for this."],[1622,1689,"Stop."],[1730,1897,"Please Vaughn, just let me go!"],[1897,1972,"Mom?"],[2260,2423,"Please just..."],[2423,2481,"stop!"],[2844,2890,"Mom?"],[2998,3115,"Are you okay?"],[3132,3236,"Run along, kid."],[3478,3528,"Help!"],[3566,3724,"Everyone at this party wants"],[3724,3887,"this to happen."]],"21":[[145,225,"I see the lovebirds are"],[225,346,"missing."],[346,429,"And if we're lucky,"],[429,513,"Sophia's already"],[513,654,"forgotten all about her"],[654,892,"trailer trash husband, Jack."],[988,1151,"Can't even with him."],[1151,1242,"Trying to trick us"],[1242,1305,"into thinking he's"],[1305,1434,"some sort of heir."],[1434,1647,"She's so much better off with Vaughn."],[1780,1872,"I would like to"],[1872,2081,"thank everyone for coming"],[2118,2193,"and for bringing"],[2193,2460,"such inspired presents."],[2481,2702,"There is one last round of gifts."],[2998,3199,"Oh, oh."],[3199,3399,"More gifts?"],[3420,3511,"From whom?"],[3511,3661,"Agnes’s da