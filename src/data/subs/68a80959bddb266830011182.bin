hese"],[346,546,"obviously fake gifts, right?"],[546,629,"Yeah."],[729,892,"Well, it's not as humiliating"],[892,996,"as forcing you to get down"],[996,1209,"on your knees and tell everyone"],[1209,1397,"what a terrible mother you are."],[1539,1689,"Don't worry, Mother, we'll"],[1689,1939,"have this dog thrown out."],[2056,2198,"Get some security now!"],[2198,2327,"I don't think so."],[2385,2519,"I'm not leaving until my wife"],[2519,2656,"gets her gifts."],[2748,2848,"Where is she?"],[2848,2923,"We both know that"],[2923,3028,"you'd rather be with me"],[3028,3182,"than your trailer trash husband."],[3265,3386,"Never."],[3386,3570,"You're disgusting."],[3570,3770,"You think I'm disgusting?"],[3858,3974,"Well,"],[3974,4141,"then just close your eyes"],[4141,4391,"and take comfort in how much I'm"],[4391,4592,"going to enjoy this."],[4650,4875,"Vaughn, please just let me go!"],[4875,4938,"-Vaughn! - Come on,"],[4938,5042,"you don't mean that."],[5067,5155,"Mommy?"],[5155,5263,"Are you okay?"],[5263,5326,"Go away!"],[5326,5447,"Your mom is busy."],[6289,6414,"Where is my wife?"],[6715,6886,"One of you needs to start talking."],[6886,6990,"How dare you come"],[6990,7157,"in here and make demands."],[7223,7428,"Who do you think you are?"],[7453,7611,"I'll tell you exactly who I am."]],"24":[[25,196,"I'm the CEO of-"],[196,279,"Help!"],[329,387,"Help!"],[425,654,"Oh, honey! Hey hey hey..."],[658,688,"I'm here."],[688,729,"What's wrong?"],[792,880,"Vaughn..."],[880,1096,"He... he attacked me."],[1155,1255,"Attacked?"],[1255,1455,"How dare you?"],[1572,1730,"She tried to kiss"],[1730,1931,"me, and I told her"],[1943,2143,"I don't date married women."],[2156,2385,"But then she went nuts and started"],[2385,2473,"kicking me."],[2473,2590,"You're lying."],[2590,2669,"Sophia!"],[2719,2944,"Don't disrespect Mr. Weathers!"],[2944,3040,"He's a very"],[3040,3157,"powerful VP of the"],[3157,3357,"biggest company in the world."],[3357,3420,"Yeah."],[3420,3507,"You can't blame him"],[3507,3707,"for turning you down."],[3816,4016,"If you keep telling these lies,"],[4016,4141,"I'm going to have to punish you."],[4141,4179,"Don't"],[4179,4320,"you ever touch her"],[4320,4404,"again."],[4433,4525,"Who the hell are you?"],[4721,4863,"I'm her husband."],[4863,4925,"Daddy!"],[4925,5046,"You came back!"],[5055,5184,"Hey baby! Hey."],[5338,5426,"You look handsome."],[5426,5568,"Total VIP."],[5568,5668,"And you look beautiful,"],[5668,5784,"sweetie."],[5784,5955,"You're the husband."],[5955,6156,"You don't need to worry, Vaughn."],[6160,6322,"He's just some orphan"],[6322,6481,"that's nothing."],[6481,6606,"He'll die with nothing."],[6702,6735,"He'll just"],[6735,6936,"always be...nothing."],[7278,7457,"Can you go upstairs and play?"],[7457,7590,"Daddy has to take out the trash."]],"25":[[45,200,"Vaughn Wethers, right?"],[200,375,"I'll be honest with you."],[375,479,"I don't care"],[479,675,"about a stay at home dad."],[675,875,"I'm the most powerful man"],[938,1101,"at a party filled"],[1101,1301,"with very powerful people."],[1338,1422,"You're messing it"],[1422,1597,"with the Senior Vice President"],[1597,1797,"of Prestige Industries."],[1822,1951,"Dressing up in a knockoff"],[1951,2152,"tux is not going to change that."],[2168,2344,"These fools don't realize I'm"],[2344,2569,"Prestige Industries' owner and CEO."],[2585,2736,"Jackie boy,"],[2736,2882,"I know you probably put on deodorant"],[2882,3090,"for the first time, but you're way"],[3090,3290,"out of your league."],[3307,3507,"Scamper on home"],[3520,3724,"and let these two kids have some fun."],[3828,3933,"Oh, no, no, no."],[3933,4116,"You see, this man put his hands"],[4116,4241,"on my wife."],[4241,4337,"So I'm not leaving"],[4337,4537,"until he begs for forgiveness."],[4579,4725,"Do you have any idea"],[4725,4925,"how much you just fucked up?"],[4979,5055,"You're dead."],[5150,5326,"You're dead..."],[5326,5430,"sir."],[5430,5509,"What?"],[5509,5568,"You should address"],[5568,5680,"your new b