re"],[6368,6485,"to mow my lawn."],[6677,6911,"In fact, that's the idea."],[6940,7140,"If you want the money,"],[7152,7298,"then you can work for me"],[7298,7486,"and clean up after my doggies."],[7486,7665,"Jack, don't do that."],[7665,7757,"They have no idea."],[7757,7903,"With one phone call,"],[7903,7987,"I could have more money"],[7987,8041,"than they'll ever"],[8041,8124,"see in their lives."]],"10":[[25,154,"But no..."],[154,246,"I made a vow."],[287,325,"Agnes,"],[325,425,"if you give me the money,"],[525,675,"I'll do whatever you ask me to."],[675,796,"Okay?"],[796,884,"I'll be your lawn boy."],[884,996,"I'll clean up"],[996,1126,"after your dog's poop."],[1126,1234,"Okay?"],[1234,1401,"I just want to save my mom."],[1401,1488,"Foster mom!"],[1518,1672,"You're an orphan."],[1672,1830,"You have no family."],[1906,2047,"Yes, he does."],[2047,2331,"Sophia, be very careful."],[2377,2556,"You rely on my charity."],[2556,2677,"Charity,"],[2677,2756,"really?"],[2756,2861,"You work her 80 hours"],[2861,2898,"a week"],[2898,2965,"at your company,"],[2965,2990,"and yet"],[2990,3190,"you pay her next to nothing."],[3203,3357,"Daddy!"],[3357,3624,"How dare you come in here"],[3624,3712,"and tell me"],[3712,3912,"how to treat my daughter?"],[3953,4145,"You are a freeloading"],[4237,4308,"conman"],[4308,4475,"who stole her away from me."],[4508,4667,"If you want the money"],[4667,4717,"to save"],[4717,4917,"your precious little fake mommy,"],[4942,5092,"then you can get down"],[5092,5392,"on your knees and beg me for a job."],[5422,5580,"Jack, don't. Don't do that."],[5797,5939,"It's fine."],[5939,6043,"It's only the"],[6043,6193,"second worst way to get the money."],[6193,6227,"What can"],[6227,6427,"possibly be worse than this?"],[6464,6556,"I will never take"],[6556,6715,"my father's money."],[6715,6915,"I swore it on my mother's grave."],[6919,7119,"Breaking a vow."],[7882,8045,"Agnes,"],[8045,8199,"I beg you."],[8199,8400,"Can I get a job, please?"],[8479,8675,"Beg 