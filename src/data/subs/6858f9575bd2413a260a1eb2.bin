[5363,5534,"hire Charlotte for that."],[5563,5751,"She's a mid-level programmer at best."],[5751,5834,"You're a fool."],[5834,5930,"Even my mom can see through"],[5930,6014,"your lies."],[6014,6193,"Amber, open it."],[6556,6698,"You’re gonna regret this."],[6777,6911,"The only thing I regret is thinking"],[6911,7032,"that you were a good person."],[7119,7328,"Amber, I need what's on that file."],[7382,7557,"It's the key to getting sole custody"],[7557,7640,"of my daughter."]],"45":[[2485,2540,"Got it."],[2686,2815,"Too many failed attempts."],[2865,3044,"Data will now be destroyed."]],"46":[[321,496,"What the hell is going on here?"],[658,738,"Charlotte."],[1488,1685,"That is a serious puncture wound."],[1743,1876,"Why isn't anyone helping her?"],[1906,2035,"It's a busy hospital."],[2060,2227,"Doctors are looking at other patients."],[2227,2494,"In her condition, she needs attention now."],[2494,2590,"Her condition."],[2623,2677,"Please,"],[2677,2765,"she's being dramatic."],[2798,2877,"This woman's injured"],[2877,2994,"and she's not flopping around"],[2994,3082,"like a child."],[3082,3228,"How can you compare the two?"],[3240,3424,"She just has a scratch on her arm"],[3465,3607,"and Charlotte might be dying."],[3716,3978,"General, the drive,"],[4104,4191,"they destroyed it."],[4220,4275,"What?"],[4329,4529,"Do you have any idea what you've done?"],[4571,4654,"Whatever was on there"],[4654,4767,"couldn't be that important."],[4783,4900,"Especially if a nobody"],[4900,5017,"like Charlotte had it."],[5017,5080,"Calm down."],[5080,5246,"I'll pay for whatever's on the drive."]],"47":[[0,91,"You can't put a price"],[91,225,"on the safety of the country."],[250,358,"How dare you?"],[800,934,"With that file destroyed,"],[934,1096,"her survival is even more important."],[1130,1280,"Get her a doctor now."],[1280,1372,"Don't tell me what to do."],[1372,1493,"This is my hospital."],[1493,1593,"Not for long, boy."],[1626,1739,"You just wait to see the shitstorm"],[1739,1885,"I'm gonna rain down upon you."],[1922,1993,"Who are you?"],[2060,2268,"I'm the United States government."],[2268,2352,"Oh my God."],[2402,2481,"How do I know that"],[2481,2585,"you're not just some actor"],[2585,2752,"that Charlotte hired to intimidate me?"],[2781,2907,"I'm Thomas Ericsson."],[2948,3044,"Never heard of you."],[3044,3098,"That's because"],[3098,3224,"you're not important enough."],[3257,3503,"Now find me someone who is."],[3557,3624,"It's him."],[3699,3770,"That's his photo."],[3983,4141,"General Thomas Ericsson?"],[4258,4371,"Head of the NSA?"]],"48":[[963,1101,"Send in the doctors!"],[1835,2010,"Why are you hanging out with Charlotte?"],[2081,2285,"She's a mid-level programmer at best."],[2444,2590,"The fact that you think that tells me"],[2590,2744,"just how stupid you really are."],[2748,2798,"God."],[2798,2861,"She probably lied"],[2861,2944,"about her credentials."],[2944,3044,"She lies about everything."],[3065,3107,"She lied about"],[3107,3228,"our daughter being dead."],[3228,3420,"She even made a fake grave stone."],[3420,3549,"She lied to leave me"],[3549,3707,"to go hook up with this piece of shit."],[3707,3853,"You know none of that is true."],[3916,3966,"Really?"],[4066,4154,"Show me the proof."],[4229,4291,"Show me that"],[4291,4446,"my daughter is actually dead."],[4475,4629,"Show me a death certificate."],[4667,4825,"And then I'll get on my hands and knees"],[4825,4963,"and beg for forgiveness."],[5084,5230,"I don't want forgiveness."],[5359,5534,"I just want to never see you again."],[5709,5747,"Okay."],[5864,5955,"Show me the evidence."],[6006,6147,"I'll sign the divorce papers."],[6794,6856,"What about you?"],[6990,7065,"Can no one?"],[7127,7248,"No one show me proof"],[7248,7407,"about Charlotte's little story?"],[7636,7695,"I can."]],"49":[[37,83,"I can prove"],[83,212,"Ms. Hasting isn't lying."],[296,425,"That your daughter died that day"],[425,513,"because you diverted"],[513,617,"the entire staff."],[646,684,"No."],[709,800,"No, that's not true."],[859,950,"Show me proof."],[1326,1418,"Don't listen to her."],[1463,1659,"This nurse has been stealing pills"],[1659,1780,"and cannot be trusted."],[1780,1889,"Take your hand off her"],[1889,2010,"or I'll rip your arm off"],[2010,2156,"and shove it up your ass."],[2214,2310,"It's okay, little lady."],[2356,2489,"You might be in their hospital,"],[2489,2660,"but that hospital is in my country."],[2715,2781,"You're safe now."],[2877,3069,"Are we really going to listen to a nurse?"],[3069,3148,"Mr. General,"],[3148,3215,"surely we shouldn't"],[3215,3278,"be wasting your time."],[3278,3411,"I know everything"],[3411,3586,"and I have the evidence to prove it."],[3586,3657,"I'm the one"],[3657,3791,"who took care of Kayla that day."],[3949,4029,"Paul, please."],[4029,4091,"No."],[4425,4533,"Oh my head, Paul."],[4554,4629,"I need a doctor."],[4629,4713,"God, shut up!"],[4867,4942,"Tell me what happened."],[5063,5205,"I think that I'm gonna faint."],[5205,5351,"My God, shut up."],[5434,5501,"Tell me what happened"],[5501,5580,"to my daughter."]],"50":[[4,112,"She was having a severe"],[112,183,"asthma attack,"],[183,271,"that was intensified"],[271,396,"by the debris from the bomb."],[396,492,"She needed help."],[604,709,"More help than I could give her"],[709,771,"as a nurse."],[792,905,"But you instructed"],[905,996,"the rest of the doctors"],[996,1092,"to focus on her!"],[1259,1305,"No."],[1443,1580,"I'm sorry, I did what I could,"],[1580,1805,"but I just don't have the training."],[1893,1976,"I couldn't save her."],[2052,2127,"No."],[2268,2356,"No."],[2419,2531,"No, that didn't happen."],[2594,2719,"My daughter's not dead."],[2752,2857,"The look on her face"],[2857,2998,"as she was gasping for breath."],[3182,3353,"She looked so confused."],[3478,3557,"So alone."],[3557,3628,"No."],[3657,3737,"No!"],[3782,3903,"That couldn't have happened."],[3903,4041,"In my hospital, the next of kin"],[4041,4266,"are always contacted when someone dies."],[4308,4491,"No one contacted me when she died!"],[4491,4742,"I tried, but Dr. Mason wouldn't let me."],[4767,4842,"What?"],[4913,5005,"That is insane."],[5005,5130,"And then he and Ms. Vickers"],[5130,5234,"conspired to destroy"],[5234,5342,"all of the paperwork."],[5384,5588,"It was as if,"],[5588,5643,"Kayla just disappeared"],[5643,5693,"off the face"],[5693,5759,"of the Earth."],[5793,5905,"They tried to make it seem like"],[5905,6056,"Kayla's death never happened."]],"51":[[4,116,"You lying bitch!"],[116,212,"Where's the evidence?"],[212,316,"Show us the evidence."],[333,417,"Your drug addiction"],[417,579,"has caused you to hallucinate."],[625,834,"Please pay no mind to her ramblings."],[834,1059,"It's just empty claims of a drug user."],[1059,1209,"I have the evidence!"],[1209,1326,"I secretly hid a copy"],[1326,1426,"of the death certificate"],[1426,1547,"before you could destroy it."],[1705,1856,"The death certificate is upstairs"],[1856,1956,"in the nurse's office,"],[1956,2077,"taped underneath the desk."],[2464,2540,"Paul, wait!"],[2969,3115,"Paul, I don't know what's going on,"],[3115,3194,"but you have to believe me."],[3194,3353,"I would never do something like that."],[3353,3566,"Mr. Hasting, I have been a loyal doctor"],[3566,3757,"for your family for over 20 years!"],[3757,3845,"I would never do anything"],[3845,3928,"to harm you."],[3945,4058,"Charlotte must have paid that nurse"],[4058,4158,"to frame us."],[4537,4621,"Didn't you say"],[4621,4792,"she was in critical condition"],[4792,4892,"just a few minutes ago?"]],"52":[[166,387,"Mr. Hasting, it's Miss Vickers."],[387,575,"She's having complications."],[825,996,"Must have been a miraculous recovery."],[1201,1288,"Paul, I..."],[2043,2114,"It's..."],[2431,2569,"Oh God."],[2610,2673,"Oh, my God."],[2673,2769,"My Kayla."],[2819,2961,"My Kayla's dead."]],"53":[[70,337,"Okay, Mr. Hasting, listen."],[358,475,"I promise you-"],[475,658,"Get out!"],[675,763,"Paul, I understand"],[763,875,"that you are upset, but-"],[875,942,"Now!"],[1038,1176,"Paul, Paul, I can explain."],[1192,1438,"This is just a clerical error."],[1438,1534,"I swear! - Paul!"],[1534,1609,"Please, - Paul, you can't"],[1609,1693,"no! - do this."],[1856,1956,"It's my fault."],[2106,2189,"Oh, my Kayla."],[2189,2339,"My poor, sweet Kayla."],[2339,2431,"It's all my fault."],[2523,2681,"Oh, my beautiful daughter's dead."],[2769,2877,"And it's all my fault."],[2898,3128,"Charlotte, she was right all along."],[3228,3299,"Charlotte!"],[3703,3782,"Oh my God."],[3820,3995,"Charlotte, Charlotte, please stop."],[3995,4108,"I'm so sorry."],[4137,4245,"It's all my fault."],[4291,4416,"Charlotte, we'll get you"],[4416,4517,"whatever you need."],[4667,4879,"What I need is to never see"],[4879,5055,"either of you ever again."]],"54":[[54,221,"What I need is to never see"],[221,433,"either of you ever again."],[450,550,"No, Charlotte."],[550,688,"You said if you saw the evidence,"],[688,829,"I'd never have to see you again."],[946,1017,"Well, you've seen it."],[1088,1217,"Just get me out of here."],[1322,1434,"Wait, wait."],[1463,1564,"Please, Charlotte."],[1576,1743,"Get out of here."],[1743,1893,"She needs to be treated."],[1926,1981,"No!"],[1981,2060,"I swear to God,"],[2060,2248,"I will move Heaven and Earth for you."],[2293,2444,"I will have every doctor"],[2444,2544,"at your beck and call."],[2573,2652,"Please."],[2761,2919,"I'll stay with you night and day."],[2919,3032,"We'll take care of you."],[3090,3207,"We need to go."],[3249,3311,"Now!"],[3420,3486,"No!"],[3528,3632,"This is my hospital."],[3812,3953,"No one leaves here untreated."],[3970,4058,"And please stay,"],[4099,4258,"and you will get the proper care"],[4258,4391,"that you deserve."],[4562,4779,"Paul, it's over."],[5088,5217,"Just get me out of here."],[5442,5613,"No, no, no, Charlotte, please."],[5638,5722,"Please, no."],[5759,5885,"Charlotte, please."],[5943,6010,"No."],[6156,6206,"Don't."],[6206,6277,"Please."],[6331,6435,"Please."],[6477,6656,"Charlotte, no."],[6773,6919,"Charlotte, no."],[6940,7002,"Charlotte."]],"55":[[387,513,"Oh my God, Charlotte, please."],[513,558,"Stop."],[558,613,"Get off me."],[613,704,"She's my wife!"],[792,875,"Okay, stop."],[1322,1447,"What could you possibly"],[1447,1543,"have to say, Paul?"],[1689,1818,"I'm so sorry."],[1906,2018,"It's all my fault."],[2127,2189,"Please."],[2214,2268,"Please."],[2302,2406,"Just give me another chance."],[2414,2540,"We're gonna have a proper funeral"],[2540,2619,"for our daughter."],[2619,2765,"A real funeral."],[2765,2836,"Please."],[2944,3015,"I just,"],[3132,3269,"I just want one more chance."],[3349,3440,"What makes you think"],[3440,3603,"you deserve another chance?"],[3791,3899,"I was lied to."],[4004,4141,"Everyone lied to me."],[4162,4266,"It's my fault."],[4266,4387,"I should have trusted you."],[4450,4708,"I should have never, ever doubted you."],[4833,5017,"Charlotte, you've been"],[5017,5146,"like a daughter to me."],[5330,5476,"I don't want to lose you."],[5584,5705,"Just one more chance."],[5797,5868,"Please."],[6068,6222,"You wasted your last chance"],[6222,6352,"a long time ago."],[6510,6694,"I will never forgive you"],[6694,6898,"and I never want to see you again."],[6948,7086,"Charlotte, don't do this."],[7115,7178,"Please."],[7728,7799,"Aw."],[7862,7932,"Come here."],[8283,8379,"You had everything."],[8512,8600,"Perfect wife."],[8641,8733,"Perfect daughter."],[8762,8871,"The perfect life."],[8929,9054,"But you threw it all away."]],"56":[[621,771,"Paul, what are you gonna do to us?"],[821,875,"Nothing."],[1084,1192,"You're coming with me."],[1255,1409,"You compromised our national security"],[1409,1505,"and almost caused the death"],[1505,1689,"of our most valuable asset."],[1735,1818,"You're gonna go somewhere"],[1818,1893,"where you'll never cause"],[1893,2077,"any more harm ever again."],[2077,2177,"But you can't do that."],[2218,2344,"I demand a lawyer."],[2373,2431,"You're cute."],[2477,2623,"I am the NSA."],[2677,2773,"You're not gonna see a lawyer"],[2773,2915,"or anyone else for that matter."],[2957,3128,"Paul, you have to help us."],[3278,3449,"I hope he puts you in the same hell"],[3541,3661,"as you put me in."],[3845,3945,"No, Paul."],[3945,4087,"Paul, please! - Oh my God!"],[4095,4183,"Let us go!"],[4366,4533,"You do realize the only reason"],[4533,4633,"why you're not going with them"],[4633,4771,"is because your ex-wife"],[4771,4879,"made me promise"],[4879,5046,"not to put you in there with them."]],"57":[[709,884,"Oh, this place feels so much colder"],[884,975,"without Kayla."],[1067,1138,"Yeah, every day"],[1138,1247,"when I would come home from work,"],[1247,1297,"they would..."],[1747,1864,"Daddy."],[1914,2147,"Hey, come here."],[2823,2886,"Come on."],[2961,3015,"We should start"],[3015,3111,"putting their things away."],[5021,5180,"Alright, Kay-Kay, we're here."],[5201,5321,"What's the big surprise?"],[5321,5426,"Ta-da!"],[5455,5609,"Oh! - Wow!"],[5618,5851,"This is Nanny, this is Mommy,"],[5851,5976,"and the really biggest one"],[5976,6064,"is Daddy."],[6089,6302,"Wow, look at your muscles."],[6302,6423,"You've been working out."],[6423,6614,"I made Daddy extra big"],[6614,6819,"so he could take care of us."],[6998,7115,"Oh, Kay-Kay."],[7432,7574,"I'll always take care of you."],[7974,8103,"I didn't take care of her."],[8195,8308,"I let her die."]],"58":[[479,671,"Sir, sorry to barge in,"],[671,796,"but there's been an emergency."],[809,871,"There's a problem"],[871,1021,"with our KK AI product."],[1021,1192,"The whole system crashed."],[1205,1305,"Give me every designer"],[1305,1376,"that worked on it"],[1376,1514,"and get it up and running now."],[1547,1676,"That's just it, sir."],[1755,1922,"Your wife basically developed"],[1922,2089,"the entire program herself."],[2097,2189,"She's the only person"],[2189,2335,"who truly understands it."],[2364,2540,"If you want your company to survive,"],[2569,2698,"we need Charlotte."],[3307,3449,"A bit of sad news today."],[3495,3595,"The program you designed"],[3595,3741,"for Hasting Medical crashed."],[3787,4004,"Experts are saying if they can't fix it,"],[4058,4162,"it could lead to bankruptcy"],[4162,4250,"for the company."],[4316,4458,"I'm not surprised."],[4583,4675,"The product was good enough"],[4675,4758,"for the press launch,"],[4758,4929,"but I needed at least another month"],[4929,5030,"to flush out the bugs."],[5242,5326,"What?"],[5326,5459,"By pushing you away,"],[5480,5647,"he not only destroyed his family,"],[5768,5885,"he destroyed his company."],[6573,6698,"I still think you should rest"],[6698,6777,"a few more days."],[6794,6881,"I'm fine."],[6936,7090,"Besides, the country needs me."],[7236,7378,"Get your hands off me."],[7436,7582,"I need to speak to my wife!"],[7624,7674,"Charlotte!"],[7682,7728,"Charlotte."]],"59":[[33,120,"Charlotte, Charlotte."],[137,183,"Please."],[196,266,"I need your help."],[266,417,"Paul, you had your chance."],[437,592,"I want nothing to do with you."],[592,704,"No, no, it's not about us."],[704,788,"It's about the company."],[825,1017,"You need to come help us save the AI."],[1017,1188,"The company's gonna collapse."],[1201,1343,"How is that her problem?"],[1343,1534,"The AI, it's based on Kayla."],[1564,1689,"It's the last bit of, part of her"],[1689,1768,"that we have."],[1768,1914,"You can't just let her die."],[1947,2068,"Get off me."],[2173,2298,"Please, you want, you want me to"],[2298,2419,"get on my hands and knees and beg?"],[2419,2481,"I'll do it."],[2585,2652,"Please."],[2677,2865,"Just don't let the last bit of Kayla die."],[2969,3073,"I know I fucked up."],[3073,3182,"I'm so sorry."],[3211,3307,"You're everything."],[3307,3399,"I'm nothing."],[3415,3516,"Look, Hasting Medical"],[3516,3628,"would be nothing without you."],[3628,3766,"You made us what it is today."],[3816,3999,"I'll do anything to bring you back."],[3999,4054,"Please."],[4170,4329,"Do you regret what you've done?"],[4450,4521,"Yes."],[4871,5042,"Not as much as you're going to."],[5751,5847,"You're pathetic."],[5889,5943,"Charlotte!"],[6035,6097,"What are you..."],[6122,6164,"Come back!"],[6164,6260,"It's Kayla!"],[6293,6439,"You can't just let it die!"]],"60":[[955,1034,"Oh my God."],[1055,1126,"Yeah, Mom."],[1197,1509,"I just saw another rat in the apartment."],[1634,1726,"Well, let's just move"],[1726,1835,"into the Four Seasons then."],[1868,1972,"I hate it here."],[2064,2202,"I can't live like this."],[2281,2452,"I want my old life back."],[2660,2706,"I know."],[2752,2806,"I get it."],[2886,3132,"I'll get us back on our feet somehow."],[3169,3332,"Have you talked to Charlotte at all?"],[3432,3511,"Yeah."],[3511,3645,"I mean, I call her all the time."],[3645,3782,"She just doesn't answer."],[3903,3974,"She probably just-"],[3974,4049,"Excuse me!"],[4074,4300,"I'm not, I'm not paying you"],[4300,4421,"to chat on the phone."],[4604,4763,"If you can just leave me a review on Yelp,"],[4763,4825,"that would actually-"],[4825,4879,"Shh."],[4909,5034,"The wedding's starting."]],"61":[[3436,3524,"Excuse me!"],[3553,3741,"Unless they invited the help,"],[3799,3912,"you were not invited."],[3949,4033,"Stop staring."],[4058,4137,"Sorry, um,"],[4225,4391,"God, it's just a beautiful wedding."],[4437,4604,"Oh, it is."],[4654,4871,"Their company is worth trillions."],[4871,5009,"As in, with a T."],[5088,5217,"Shoo."],[5747,5885,"Everything okay, my love?"],[5930,6081,"Yes, I just,"],[6139,6348,"I just saw a glimpse of my past."],[6389,6473,"What was it?"],[6539,6660,"It doesn't matter."],[6785,6869,"It's gone."],[7044,7152,"Gone forever."]]}