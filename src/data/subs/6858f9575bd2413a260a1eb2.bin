{"1":[[429,579,"Okay, it's okay, my love, it's okay."],[600,779,"Paul, we need to get to a hospital now!"],[796,959,"Charlotte, she has asthma,"],[959,1092,"not the black plague."],[1092,1209,"She can't breathe."],[1317,1380,"But we're supposed to be"],[1380,1480,"meeting Amber for lunch."],[1480,1576,"We can't just keep cancelling"],[1576,1672,"on my best employee"],[1672,1810,"every time she acts up."],[1810,1935,"She's not acting up!"],[1935,2018,"How could you say that"],[2018,2127,"about your own daughter?"],[2185,2273,"Kayla, it's okay, honey."],[2273,2389,"Just use your inhaler, okay?"],[2510,2610,"we all know you're jealous of Amber,"],[2610,2752,"and you're just using our daughter."],[3144,3340,"Kayla, you're fine."],[3603,3728,"Your Mom's just delusional."],[3874,4112,"Incoming call from Amber Vickers."],[4187,4245,"Yeah,"],[4245,4295,"hey Amber."],[4320,4416,"I know, we're late."],[4446,4554,"My wife is being..."],[4612,4767,"Paul, they've closed down the street."],[4783,4892,"They're saying there's a bomb."],[4921,5005,"I'm scared!"],[5046,5096,"What?"],[5109,5176,"A bomb?"],[6006,6051,"Kayla?"],[6151,6281,"Kayla?"],[7069,7157,"Amber."],[7173,7269,"Amber!"],[7624,7695,"Get out."],[7995,8058,"Are you crazy?"],[8058,8216,"She can't breathe out here in this smoke!"],[8350,8445,"Go get some shelter."],[8458,8546,"Look, I gotta get back"],[8546,8625,"to the bomb site."],[8687,8742,"What?"],[8754,8821,"Amber needs me."],[8833,8933,"Paul, we need you."],[8933,9038,"Please, we need you!"]],"2":[[0,137,"I have to go back to the bomb site."],[137,258,"I need to find Amber."],[275,354,"Paul, we need you."],[354,462,"Please, we need you!"],[571,633,"Are you crazy?"],[633,800,"She can't breathe out here in this smoke!"],[1201,1343,"Okay, okay, it's okay, it's okay."],[1359,1413,"It's okay, baby."],[1413,1514,"Mommy's here, Mommy’s here,"],[1514,1597,"Mommy's here."],[2348,2481,"So far, what we know is that"],[2481,2640,"the terrorist attack has rocked the city."],[2640,2773,"At least twelve confirmed dead,"],[2773,2869,"with hundreds injured."],[2898,2940,"We're being told"],[2940,3036,"that federal authorities"],[3036,3115,"are on the scene,"],[3115,3203,"and that the president will make"],[3203,3311,"an announcement tonight."],[3324,3399,"It's okay, baby."],[3399,3440,"It's okay."],[3440,3520,"Just hold on, okay?"],[3520,3611,"We're gonna get you help."],[3661,3741,"You, you, Miss."],[3741,3832,"Please, please help me."],[3832,3887,"My daughter,"],[3887,4020,"she's having an asthma attack."],[4020,4099,"She was forced to breathe"],[4099,4225,"in some debris from the bomb."],[4225,4358,"She needs a doctor."],[4358,4425,"I'm sorry, ma'am."],[4425,4517,"There's none available."],[4517,4562,"What do you mean"],[4562,4625,"there's none available?"],[4625,4771,"My husband owns this hospital."],[4771,4863,"This is his daughter."],[4863,4984,"There has to be a doctor."],[4984,5084,"We're full with victims"],[5084,5142,"from the blast,"],[5142,5226,"and your husband just gave"],[5226,5376,"the last available room to a woman"],[5376,5526,"who suffered a minor cut in the blast."],[5526,5568,"An,"],[5568,5701,"Amber Vickers."],[5860,5980,"What did you just say?"]],"3":[[41,133,"What did you just say?"],[133,196,"It's okay."],[196,316,"Your husband and your mother-in-law"],[316,437,"are upstairs with Amber right now."],[437,550,"He can get you a doctor."],[1547,1739,"So sweet of you both to show up."],[1755,1856,"When my son told me"],[1856,1972,"that you were near the blast,"],[1972,2081,"I had to come."],[2139,2243,"So worried for you."],[2285,2439,"I hear your daughter is here, too."],[2527,2644,"You should go check on her."],[2644,2765,"She might need help."],[2806,2886,"I'll be okay."],[2986,3082,"It's okay, it’s okay."],[3115,3190,"Kayla's just having"],[3190,3336,"one of her normal asthma episodes."],[3336,3415,"This is more serious."],[3415,3574,"She's just being dramatic, you know."],[3628,3762,"Her mother encourages it."],[3953,4058,"That child needs"],[4058,4237,"a more disciplined mother figure"],[4237,4312,"in her life."],[4358,4500,"Or stepmother figure."],[4562,4733,"You would make such a good mom"],[4733,4833,"to that child."],[4879,5034,"She needs someone like you."],[5138,5213,"Instead of..."],[5455,5522,"You know who."],[6218,6439,"Charlotte, they were just joking around."],[6439,6556,"Amber, save your breath."],[6594,6681,"Whatever you say,"],[6681,6865,"she always just sees the worst of it."],[6865,6936,"You know, I don't have time"],[6936,6998,"to fight about this."],[6998,7127,"Your daughter is downstairs"],[7127,7286,"and she needs a doctor."],[7286,7403,"Jesus Christ, Charlotte."],[7403,7528,"Can you please just stop lying?"],[7549,7711,"She's just trying to scare us."],[7745,7957,"This is what I was talking about."],[7982,8112,"Kayla's fine."],[8112,8220,"Or she would be"],[8220,8433,"if you didn't coddle her so much."],[8454,8637,"She has serious asthma."],[8671,8817,"And you left her on the side of the road"],[8817,9017,"in the aftermath of a terrorist attack."],[9046,9159,"My daughter is downstairs"],[9159,9292,"struggling for each and every breath"],[9292,9467,"and you can't spare a single doctor?"],[9576,9738,"I've clearly upset your wife."],[9772,9851,"I should go."],[9851,9922,"Amber,"],[9951,10018,"No, no, no, Am-"],[10097,10251,"Don't get up."],[10418,10593,"No, you're not going anywhere."],[10635,10852,"You're the one who needs to leave."],[10881,11065,"Sylvia, your granddaughter"],[11065,11307,"is downstairs slowly suffocating."],[11357,11436,"And you!"],[11473,11628,"Her birthday is in two days, Paul."],[11628,11715,"She just wants to have a"],[11715,11778,"birthday party."],[11778,11828,"She just,"],[11828,11978,"she wants to have a birthday party!"],[11978,12045,"Enough, enough!"],[12057,12099,"Okay?"],[12103,12199,"Charlotte, seriously."],[12224,12374,"We all know you're jealous of Amber."],[12391,12487,"Everybody knows already,"],[12487,12600,"for God knows why."],[12637,12808,"She nearly just died."],[12833,12904,"Okay?"],[12946,13058,"Can you please just save your"],[13058,13221,"attention seeking antics for later?"],[13234,13380,"You always make me the bad guy."],[13480,13613,"I'm not apologizing for this."],[13676,13772,"Security!"],[13772,13817,"What?"],[13847,13930,"Security."],[13930,14068,"No, Paul, come on."],[14080,14172,"Are you serious, Paul?"],[14172,14285,"She needs a doctor!"],[14326,14360,"Stop!"],[14360,14493,"She needs a doctor!"],[15098,15190,"Mrs. Hastings,"],[15277,15465,"your daughter, she-"]],"4":[[2214,2289,"What are you doing?"],[2477,2656,"No, no, why would you do that?"],[3011,3057,"No."],[3294,3378,"No, no."],[3624,3707,"No, it's fine."],[3707,3787,"She's gonna wake up."],[3787,3878,"She's gonna be fine."],[3878,4062,"She's fine, she’s fine, she’s fine."],[4062,4166,"She's gonna wake up."],[4254,4300,"Right?"],[4437,4487,"Right, baby?"],[4487,4550,"You're gonna breathe."],[4612,4675,"You're gonna wake up"],[4675,4796,"and just breathe with Mommy, right?"],[4992,5059,"Kayla, hey."],[5209,5338,"Can you wake up, please?"],[5559,5701,"Can you wake up, please?"],[5876,5976,"What if we sing together,"],[5976,6081,"like we always do?"],[6118,6231,"That always helps, right?"],[6456,6806,"Hush little baby, don't say a word."],[7219,7582,"Mommy's gonna buy you a mockingbird"],[7987,8195,"And if the mockingbird"],[8195,8295,"don't sing,"],[8304,8616,"Momma's gonna buy you a diamond ring."],[8637,8742,"A diamond ring, huh?"],[9467,9659,"You want a new family with Amber?"],[9780,9893,"You can have it."],[10406,10548,"I'm done with Hasting Medical."],[10764,10910,"And I want out of the Hasting family."],[11123,11190,"Forever."]],"5":[[179,262,"Don't get me wrong,"],[354,554,"I was thrilled when I got your call."],[629,742,"But I'm confused."],[775,942,"And then you spent 10 years"],[980,1138,"pretty much single-handedly"],[1138,1334,"turning Hasting into a juggernaut."],[1455,1685,"And now you want to work"],[1685,1868,"on national security with me."],[2085,2143,"Why?"],[2815,2902,"I want to make sure"],[2902,3040,"the attack that happened yesterday"],[3040,3161,"never happens again."],[3440,3570,"And there's just not a place for me"],[3570,3657,"at Hasting anymore."],[3728,3978,"Well, my security company"],[3978,4166,"is working on a government backed"],[4166,4337,"anti-terrorism trial."],[4400,4592,"But if you lead the project,"],[4617,4817,"you'll be taken to a secure location."],[4888,5025,"Cut off from the whole world."],[5100,5259,"It'll be like you've disappeared."],[5392,5455,"That's fine."],[5843,5972,"That's a huge decision."],[6093,6172,"Take some time."],[6256,6414,"You have a month to decide."],[7520,7628,"My poor Kayla,"],[7661,7916,"you're just ashes in this box now."],[8199,8437,"And your father is nowhere to be found."],[8675,8796,"Amber, come on."],[8804,8896,"Make yourself at home."]],"6":[[0,108,"Amber, just come on."],[129,208,"Make yourself at home."],[229,362,"Charlotte's still mad."],[362,513,"Are you sure it's okay if I stay here?"],[513,663,"Yes, of course it's okay."],[692,809,"I would never let you stay alone"],[809,892,"while you recover."],[892,1155,"Besides, the house is in my son's name."],[1209,1313,"Not hers."],[1572,1685,"Charlotte,"],[1780,1839,"Amber's going to be"],[1839,1939,"staying here a few nights"],[1939,2027,"while she recovers"],[2027,2139,"so that we can help her."],[2202,2394,"Now, Amber was nice enough"],[2394,2452,"to forgive you"],[2452,2623,"for how you treated her yesterday."],[2736,2819,"Well?"],[3007,3190,"The least you can do is act civilized."],[3403,3528,"You gonna say something?"],[3661,3707,"Whatever."],[3707,3899,"I don't care anymore."],[4008,4154,"What is going on with her?"],[4187,4346,"She seems different."],[4400,4583,"The only problem is that"],[4583,4788,"we don't have any extra rooms."],[4842,4938,"Oh, don't worry."],[4967,5100,"I can stay on the couch for a night."],[5100,5176,"It won't be too hard. - No, no, no, no"],[5176,5296,"Nonsense, nonsense."],[5330,5455,"Kayla can go down into the basement."],[5455,5505,"It's fine."],[5522,5655,"Wait, what are you talking about?"],[5655,5739,"Charlotte, please."],[5739,5814,"Don't be dramatic."],[5851,5960,"We all know she's afraid of the dark,"],[5960,6006,"but who cares?"],[6006,6156,"She can survive for just a few nights."],[6156,6247,"It'll do her good."],[6268,6531,"Help her get over her fear of the dark."],[6594,6702,"They never even bothered"],[6702,6852,"checking on her at the hospital."],[6915,7152,"They don't realize that Kayla's dead."],[7394,7490,"Well?"],[7782,7957,"I'll move Kayla to the basement now."],[8295,8408,"Oh my God."],[8817,8871,"Well,"],[8958,9042,"where is she?"],[9104,9163,"Did she come home"],[9163,9255,"from the hospital last night?"],[9380,9496,"She didn't come home"],[9496,9597,"from the hospital."],[9672,9897,"She's never coming home again."]],"7":[[16,229,"She's never coming home again."],[333,375,"What do you mean"],[375,513,"she's not coming home?"],[600,771,"Oh my God, where is Kayla?"],[771,829,"Stop."],[829,1076,"Mom, she's just trying to scare us."],[1126,1292,"Why is my daughter not home?"],[1334,1409,"You."],[1493,1701,"You are the reason she's not home."],[1768,1918,"You practically put your hand"],[1918,2118,"around her throat and squeezed."],[2256,2506,"Stop talking crazy."],[2681,2806,"Why would you say that?"],[2932,3094,"I've been prepping for her birthday party"],[3094,3165,"this entire month."],[3165,3249,"What have you done?"],[3307,3361,"Nothing."],[3465,3670,"You always say such hurtful things to me."],[3762,3824,"You know, I don't care"],[3824,3983,"what you do in this room anymore."],[3983,4108,"The only thing"],[4270,4441,"that I care about is this."],[4517,4587,"What's this?"],[4667,4779,"I've never seen this before."],[4884,4946,"Stop."],[4988,5080,"Stop it!"],[6327,6406,"Oh my God."],[6418,6493,"My heart."],[6827,6998,"It's spilled flour!"],[7194,7282,"If you care so much about it,"],[7282,7428,"I'll pay you back for it."],[7444,7603,"No, you can't pay me back."],[7603,7828,"How could you ever repay me for this?"],[9013,9125,"Oh my God."]],"8":[[4,100,"Oh my God."],[316,375,"Charlotte,"],[467,563,"Charlotte, honey, you're,"],[608,692,"you're bleeding."],[1213,1288,"Oh, my head."],[1288,1338,"My head."],[1338,1426,"I'm going to pass out."],[1426,1514,"I need to sit down."],[1514,1672,"Paul, she needs medical attention."],[2056,2122,"Look, there's band-aids"],[2122,2173,"in the cabinets."],[2173,2327,"Just take care of yourself."],[2327,2469,"Amber needs to go to the hospital."],[3324,3499,"Oh, sweet, sweet girl."],[3678,3858,"I'm so sorry, I’m so sorry."],[3858,3920,"I couldn't,"],[4099,4254,"I couldn't even protect you"],[4254,4329,"when you were alive."],[4329,4400,"And I,"],[4491,4621,"I can't even protect you"],[4621,4808,"while you’re dead."],[5338,5492,"Looks like I win again."],[5605,5805,"You've made your choice, Paul."],[5897,6110,"Now it's time for me to make mine."],[6364,6427,"Xander?"],[6635,6723,"Come pick me up."]],"9":[[33,275,"Once this contract goes into effect,"],[312,429,"you will disappear,"],[471,642,"with no outside communication,"],[642,771,"until the project is done."],[825,938,"If you want to back out,"],[1009,1159,"this is your last chance."],[1188,1259,"Sign it."],[2118,2223,"Welcome to the team."],[2281,2394,"We can head to the black site"],[2394,2485,"whenever you're ready."],[2698,2790,"A reminder,"],[2806,2961,"the product launch is today."],[3111,3290,"I'd like to make one stop before we go."],[4358,4508,"Okay, okay."],[4558,4725,"What's the big surprise?"],[4738,4892,"The AI medical assistant"],[4892,4971,"that I've been working on?"],[5059,5142,"It's done!"],[5146,5255,"And look."],[5342,5530,"How may I help you today?"],[5538,5718,"Whoa, it's me!"],[5880,6047,"I based the AI on Kayla."],[6097,6185,"This AI Kayla"],[6185,6289,"is gonna to save millions,"],[6289,6464,"maybe billions of lives."],[6502,6648,"And make Hasting Medical"],[6648,6810,"the most important company"],[6810,6890,"in the world."],[6931,7098,"You're the best, Mommy!"],[7653,7807,"Years of sleepless nights"],[7807,7941,"developing that product."],[7941,8070,"All so my family's future"],[8070,8128,"could be secure"],[8128,8241,"so that Kayla could..."],[8550,8687,"Can you give me twenty minutes?"],[8908,9059,"I need to say goodbye to my past."]],"10":[[112,212,"Oh, look."],[212,333,"Charlotte's here."],[588,684,"Hi, Charlotte."],[684,900,"I was just smelling Paul's cologne."],[925,1038,"It helps me calm down."],[1038,1301,"I just get so nervous before big launches."],[1309,1459,"And why would you be nervous?"],[1514,1664,"Ladies and gentlemen,"],[1664,1789,"welcome to the launch"],[1789,1960,"of the KK 4000."],[1976,2223,"Hasting Medical's newest step forward"],[2223,2360,"in the field of AI."],[2389,2565,"Please welcome to the stage,"],[2581,2794,"the genius behind this product."],[3228,3286,"Not you."],[3340,3420,"What are you doing?"],[3949,4049,"You're already established."],[4116,4212,"She needs this, all right?"],[4212,4312,"This is going to do wonders"],[4312,4371,"for Amber's career."],[4371,4487,"But this is my product."],[4487,4633,"I built this for our family."],[4633,4721,"So just make another one"],[4721,4821,"if it's so important to you."],[4821,5000,"Ten years of my life went into this!"],[5000,5055,"Jesus, Charlotte."],[5055,5146,"Everything is about you."],[5146,5267,"Stop being so selfish."],[5267,5476,"This is better for the company, okay?"],[5513,5655,"Can you please be a better role model"],[5655,5718,"for our daughter?"],[6285,6373,"That was beautiful."],[6402,6510,"You were wonderful."],[6539,6656,"It was an honor, sir."],[6677,6802,"Oh, no, come here."],[6906,6956,"You were great."],[7211,7349,"Amazing speech."],[7369,7520,"Congratulations."],[7561,7745,"I understand you based the product"],[7745,7857,"on your daughter."],[7887,8045,"Yes, I'm glad you thought that."],[8045,8179,"It's based on our daughter, Kayla."],[8237,8462,"Wow, so you two work together"],[8462,8566,"as husband and wife?"],[8600,8704,"That's amazing."],[8717,8846,"Wow, so the first family"],[8846,8958,"of medical tech."],[8983,9096,"What a power couple."]],"11":[[4,116,"I just want to say,"],[116,275,"while you all are gathered here,"],[275,437,"that I couldn't have done this"],[437,517,"without you."],[604,779,"I would do anything for you."],[884,1205,"Oh my God, you two are so sweet."],[1205,1363,"Let's see a little kiss."],[1363,1413,"Come on,"],[1413,1497,"we know you've been married"],[1497,1576,"for ten years,"],[1576,1843,"but the spark is still clearly there."],[1893,1951,"Kiss."],[2006,2072,"Kiss."],[2110,2173,"Kiss."],[2193,2248,"Kiss!"],[2273,2327,"Kiss!"],[2352,2410,"Kiss!"],[2423,2477,"Kiss!"],[2502,2552,"Kiss!"],[2560,2619,"Kiss!"],[2619,2656,"Kiss."],[2677,2748,"Kiss."],[2769,2840,"Kiss."],[2861,2948,"Kiss."],[2965,3040,"Kiss."],[3061,3165,"Kiss."],[3453,3657,"Okay, now off to bed, young lady."],[3674,3753,"When I grow up,"],[3753,3883,"I'm going to have a husband"],[3883,3958,"that loves me"],[3958,4124,"as much as Daddy loves Mommy."],[4266,4433,"Kiss! Kiss! Kiss!"],[4454,4617,"Kiss! Kiss! Kiss!"],[4629,4763,"Kiss! Kiss! Kiss!"],[4788,4921,"Kiss! Kiss! Kiss!"],[4946,5117,"Paul, Charlotte is still here."],[5130,5271,"Kiss, kiss, kiss."],[5376,5518,"Your wife's not gonna care."],[6514,6681,"You've made your choice, Paul."],[6710,6844,"I hope you don't regret it."],[6965,7190,"Charlotte, it's time."],[7323,7419,"The escort is here."]],"12":[[12,175,"You've made your choice, Paul."],[191,325,"I hope you don't regret it."],[333,538,"Charlotte, it's time."],[558,667,"Your escort is here."],[1309,1397,"Who is that guy?"],[1422,1488,"I don't know."],[1509,1584,"Don't worry,"],[1584,1722,"she's just trying to make you jealous."],[1722,1889,"I swear to God, she always does this."],[1901,2081,"It's like I'm married to a mopey teenager."],[2135,2256,"She better behave herself"],[2256,2410,"at my daughter's birthday party."],[2669,2748,"My husband is hosting"],[2748,2802,"our daughter's"],[2802,2890,"birthday party tomorrow."],[2940,3065,"Can you be sure that this gets to him?"],[3128,3199,"Of course."],[3445,3595,"I'll never see you again, Paul."],[3666,3816,"I hope you can live with the choices"],[3816,3899,"that you've made."],[4792,4975,"Where is Kayla and Charlotte?"],[5025,5134,"They're over an hour late."],[5263,5559,"It is such a pleasure to have you around."],[5559,5747,"You are always on time."],[5797,6001,"Unlike some people."],[6001,6193,"Oh, I just try to have respect"],[6193,6327,"for others, you know?"],[6368,6523,"She's probably just still fussy"],[6523,6598,"about yesterday."],[6656,6831,"And so she takes it out on her daughter."],[6831,6886,"Exactly."],[6886,7065,"And makes her late"],[7086,7278,"for her own birthday party."],[7315,7386,"Maybe you guys"],[7386,7474,"should try calling her?"],[7953,8008,"We're sorry,"],[8008,8099,"this number cannot be"],[8099,8233,"completed as dialed."],[8324,8466,"Oh my God, did she block me?"]],"13":[[4,112,"Did she block me?"],[112,204,"Really, Paul?"],[225,321,"This is what you get"],[321,525,"for marrying a petulant child."],[608,675,"I'll try."],[817,880,"We're sorry,"],[880,975,"this number cannot be"],[975,1101,"completed as dialed."],[1130,1292,"She's blocked me, too!"],[1351,1514,"She couldn't have really taken Kayla"],[1514,1605,"and left, could she?"],[1605,1743,"No, she's not gonna do that."],[1743,1797,"Especially over,"],[1797,1939,"like, a little misunderstanding."],[1956,2031,"By the way, where would she be"],[2031,2122,"without me?"],[2410,2510,"Oh, there she is."],[2531,2686,"She always comes crawling back."],[3724,3799,"The hell is this?"],[3820,3941,"Where's my wife and daughter?"],[3962,4083,"Ms. Charlotte is gone,"],[4083,4208,"but before she left,"],[4208,4337,"she ordered this to be delivered"],[4337,4508,"to her ex-husband."],[4546,4646,"Ex-husband?"],[4646,4683,"Mhmm."],[4683,4846,"What the hell are you talking about?"],[5030,5146,"Divorce?"],[5226,5280,"What?"],[5363,5488,"She's leaving me?"]],"14":[[241,408,"What a disaster."],[421,538,"The real tragedy is that"],[538,658,"your wife forced Kayla"],[658,804,"to miss out on her birthday party."],[838,1038,"She was so excited."],[1038,1197,"She's been counting down the days"],[1197,1326,"on the calendar you gave her."],[1559,1718,"She hasn't touched this in days."],[1793,1910,"Alright, Kay-Kay."],[1956,2106,"so every single day"],[2131,2277,"leading up to your birthday,"],[2298,2431,"you get to open another box."],[2431,2606,"This is so exciting."],[2865,3011,"It's a chocolate."],[3011,3069,"Here, Daddy,"],[3069,3257,"I want you to have the first one."],[3482,3657,"The first thing she did every day"],[3657,3803,"was open that calendar"],[3803,4033,"and give one of us her chocolate."],[4062,4254,"I don't think she ever kept one for herself."],[4346,4487,"Oh, what's that smell?"],[5205,5326,"Oh, God."],[5355,5463,"The fish is dead."],[5472,5543,"Yeah, it must not"],[5543,5689,"have been fed for days."],[5705,5855,"Well, whose job is it to feed him?"],[5943,6026,"Kayla's."],[6189,6302,"Her mother's child,"],[6302,6448,"only thinks about herself."],[6627,6731,"Don't you dare"],[6731,6890,"talk about Kayla like that."]],"15":[[25,120,"Don't you dare"],[120,279,"talk about Kayla like that."],[350,500,"Kayla is a generous,"],[500,629,"selfless, young girl."],[1001,1292,"All right, Kayla, having a fish"],[1292,1497,"is a really big responsibility."],[1559,1826,"I'll feed him every day, no matter what."],[1826,1906,"No matter what..."],[1943,2139,"What if you're in a different country?"],[2210,2394,"I will fly back."],[2489,2623,"Okay, but what if"],[2623,2740,"you're in a different planet?"],[3023,3144,"I'll teleport!"],[3599,3858,"Even if Charlotte took her from us,"],[3891,3970,"she would have demanded"],[3970,4095,"to come back to the house"],[4095,4183,"to feed the fish."],[4220,4425,"She's so selfless for her age."],[4454,4629,"Despite all of Charlotte's craziness"],[4629,4758,"and arguing and yelling,"],[4788,4950,"Kayla was always happy."],[4979,5105,"She was a little ray of sunshine"],[5105,5180,"in the house."],[5201,5255,"God, but,"],[5401,5538,"why isn't Kayla here?"],[5609,5780,"Do you remember what Charlotte said?"],[5985,6101,"She didn't come home"],[6101,6185,"from the hospital."],[6185,6414,"She's never coming home again!"],[6439,6602,"You practically put your hand"],[6602,6798,"around her throat and squeezed."],[6986,7065,"Is Kayla..."],[8237,8370,"is my daughter dead?"],[8370,8504,"Oh my God."]],"16":[[25,104,"Ducky..."],[158,287,"this is Kayla's favorite toy."],[333,471,"What is Ducky doing in here?"],[796,946,"It's just spilled flour!"],[946,1051,"If you care so much about it,"],[1051,1142,"I'll pay for it!"],[1180,1368,"How could you ever pay me back?"],[1368,1584,"How could you ever repay me for this?"],[1689,1847,"No wonder Charlotte was acting so weird."],[1972,2064,"It's our daughter?"],[2281,2402,"What are you doing?"],[2419,2498,"Oh, come on."],[2498,2602,"You guys can't seriously"],[2602,2686,"believe this."],[2694,2844,"Charlotte is manipulating you."],[2865,2998,"She clearly planted all of this"],[2998,3061,"to make you guys think"],[3061,3153,"that Kayla was dead."],[3186,3365,"Paul, are you sure?"],[3916,4045,"This has Charlotte written all over it."],[4158,4262,"Oh my God."],[4358,4571,"She always lies about stuff like this."],[4571,4721,"She's so manipulative."],[4767,4884,"She abducted Kayla."],[4946,5134,"And tried to convince us that she's dead."],[5146,5359,"This has gone too far."],[5380,5584,"We need to get my granddaughter back"],[5584,5705,"from that witch!"],[5734,5818,"I swear to God,"],[5818,5968,"I'll move Heaven and Earth to find her."],[5989,6110,"I can help you guys."],[6126,6247,"I suspected Charlotte was"],[6247,6322,"up to something."],[6322,6506,"So I downloaded a tracker"],[6506,6606,"and put it in her purse."],[6644,6819,"I can tell you where she's at, right now."],[6840,6969,"So smart."],[7002,7194,"Where would we be without you, Amber?"],[7194,7353,"Okay, she's at,"],[7369,7407,"Where?"],[7407,7478,"Where are they?"],[7707,7791,"A cemetery."]],"17":[[225,408,"Normally it takes two days to prep."],[408,554,"But you did it in two hours."],[654,738,"We have some time"],[738,817,"before we need to leave"],[817,925,"for the Black Site."],[925,984,"I understand"],[984,1101,"it's your daughter's birthday."],[1121,1230,"Do you want to go to the party?"],[2469,2598,"Okay, we're here."],[2673,2756,"What do you have to do?"],[4333,4491,"Okay, she should be here now."],[4554,4733,"What is she doing at a graveyard,"],[4733,4833,"on our daughter's birthday?"]],"18":[[1155,1284,"Happy birthday, darling."],[1338,1609,"I am so, so sorry that"],[1609,1810,"you didn't get to have your birthday party."],[1830,1981,"So this is why you left Hasting"],[1981,2081,"to work with us?"],[2156,2327,"You want to prevent more attacks."],[2460,2560,"She just wanted to have"],[2560,2669,"a birthday party."],[2777,2886,"We brought you chocolate cake"],[2886,2973,"with sprinkles."],[3040,3128,"Your favorite."],[3324,3436,"And your birthday present"],[3436,3528,"was going to be horseback"],[3528,3628,"riding lessons."],[3753,3870,"Because you wanted to learn"],[3870,3983,"how to ride a horsie."],[5809,5922,"She's never going to learn"],[5922,6043,"how to ride a horse."],[6414,6493,"Oh, Charlotte,"],[6493,6610,"what is wrong with you?"],[6669,6802,"What are you doing?"],[6852,7119,"You horrible bitch!"],[7157,7440,"You embarrass us like that"],[7440,7645,"on your own daughter's birthday?"],[7645,7728,"Seriously,"],[7728,7882,"you owe us an explanation now."],[7945,8028,"There."],[8070,8266,"There's your fucking explanation!"]],"19":[[25,212,"There's your fucking explanation!"],[296,538,"Oh my God, my poor sweet Kayla!"],[538,684,"Mom, no, stop."],[738,804,"It's Charlotte."],[825,909,"This is all faked."],[909,980,"It's not even real."],[980,1101,"It's just another thread"],[1101,1201,"in her web of lies."],[1226,1343,"What is wrong with you?"],[1384,1476,"How can you say that?"],[1476,1589,"I'm talking to my wife here."],[1605,1672,"Interrupt me again,"],[1672,1760,"I'll put your head"],[1760,1839,"through that headstone."],[1839,1931,"Oh, you think so?"],[1931,1993,"Yeah. - Enough."],[1993,2056,"Enough."],[2181,2273,"Let's just go."],[2957,3086,"Where do you think you're going?"],[3178,3249,"No one leaves"],[3249,3349,"until we get an explanation."],[3349,3482,"The truth is right here,"],[3482,3532,"I don't know"],[3532,3636,"what else you want me to say."],[3636,3770,"I don't have time for your games."],[3807,3928,"Do you know how important today was"],[3928,3999,"for our daughter?"],[3999,4079,"I do."],[4124,4275,"It's the day she was buried."],[4275,4312,"Wrong!"],[4312,4496,"It's her sixth birthday party today."],[4542,4654,"Which you didn't show up to."],[4704,4800,"Always making everything"],[4800,4867,"about yourself."],[4867,5021,"You serve me divorce papers"],[5021,5121,"trying to embarrass me"],[5121,5238,"in front of everyone?"],[5238,5397,"Paul, Charlotte's just jealous"],[5397,5584,"of our close working relationship."],[5584,5734,"And she took it a bit too far."],[5734,5834,"Go easy on her."],[5851,5901,"Oh my God."],[5901,6010,"The way you treat Amber."],[6010,6056,"And look,"],[6072,6197,"she's the one defending you now."],[6197,6314,"I deserve an apology."],[6343,6414,"So does Mom."],[6443,6489,"And you know what?"],[6489,6681,"While you're at it, apologize to Amber."],[6731,6819,"Oh, Charlotte,"],[6819,6981,"you don't have to apologize to me."],[6981,7065,"Yes, she does."],[7065,7219,"Apologize!"],[7248,7323,"Now!"],[7323,7532,"And give us our Kayla back!"]],"20":[[104,229,"I'm not apologizing."],[229,400,"I haven't done anything wrong."],[454,675,"And I can't bring Kayla back."],[675,729,"Oh my God, Charlotte."],[729,775,"You can either"],[775,896,"give her to us now,"],[896,1001,"or I can have a judge"],[1001,1126,"give us sole custody of her."],[1159,1201,"You know what?"],[1201,1334,"I don't know why you fight me on this."],[1355,1514,"She's always better off with us."],[1514,1705,"In fact, she told me she's happier"],[1705,1780,"when she's with me."],[1780,1968,"My granddaughter loves me"],[1968,2106,"with all her heart."],[2106,2227,"Why are you doing this?"],[2227,2435,"I'm not doing anything."],[2527,2627,"Kayla is dead."],[2627,2769,"Enough of your lies!"],[2769,2882,"We all know you're jealous."],[2882,2923,"Okay?"],[2932,3073,"How many times do I have to tell you?"],[3073,3215,"She's just a colleague,"],[3253,3361,"but you still don't believe me."],[3382,3420,"You know what?"],[3420,3520,"This has to stop now."],[3520,3712,"You think all of this"],[3712,3853,"is because I'm jealous?"],[3908,3983,"Oh my God."],[3983,4066,"Of course!"],[4066,4195,"Oh my God."],[4254,4433,"You are so blind."],[4500,4633,"Our daughter was suffocating,"],[4633,4788,"and the only thing you could focus on"],[4788,4838,"was a bump"],[4838,4984,"on your little girlfriend's head."],[4984,5071,"And you never even"],[5071,5192,"came to check on her."],[5251,5513,"I had to go to the crematorium alone,"],[5534,5676,"and I had to carry out a jar"],[5676,5830,"that was once our daughter."],[5830,5968,"What are you even talking about?"],[5968,6039,"Just tell me,"],[6039,6181,"I want to see my daughter!"],[6181,6327,"You saw her yesterday."],[6339,6460,"Or have you forgotten?"],[6519,6664,"It's just spilled flour."],[6664,6752,"If you care so much about it,"],[6752,6873,"I'll pay for it!"]],"21":[[25,175,"You still think this is a game?"],[175,333,"Some pathetic attempt"],[333,554,"to win back my unfaithful husband?"],[571,734,"Charlotte, please calm down."],[734,838,"Oh, spare me."],[846,896,"God, you know,"],[896,1030,"one day when he grows bored of you,"],[1030,1205,"I hope he finds a new promising"],[1205,1288,"little employee,"],[1288,1418,"and you finally realize"],[1418,1522,"what it's like to be a third wheel"],[1522,1605,"in your own marriage."],[1605,1705,"Easy, Charlotte."],[1705,1751,"Easy."],[1772,1889,"You're embarrassing yourself now."],[1931,2014,"You're delusional."],[2052,2206,"God, I wish I was, Paul."],[2252,2510,"But you are the one that is delusional."],[2535,2673,"You keep hiding from the fact"],[2673,2898,"that you let our daughter die."],[2952,3044,"Oh my God!"],[3044,3186,"Enough of your games!"],[3244,3382,"Wait, what are you doing?"],[3382,3465,"Exposing your lies."],[3465,3536,"We all know that"],[3536,3636,"there's nothing in there."],[3636,3737,"No, Paul, please stop!"],[3766,3820,"Why?"],[3820,3858,"You don't want"],[3858,4049,"your new boyfriend to know"],[4049,4287,"that you're a liar and a fake?"],[4287,4421,"No, please, Paul, stop."],[4421,4525,"Your lies end here."],[4525,4646,"Where's my daughter?"],[5205,5338,"Tell me where my daughter is!"],[5726,5834,"She's right there."]],"22":[[20,137,"She's right there."],[1280,1334,"Kayla."],[1547,1639,"It's okay, baby."],[1655,1701,"It's okay."],[1701,1764,"Mommy's gonna"],[1764,1922,"take you some place safe, okay?"],[1951,2093,"Like everyone knows nothing's in here."],[2210,2314,"Will you stop lying?"],[2673,2836,"Don't touch her!"],[2882,2990,"You just hit me."],[3019,3136,"The divorce papers?"],[3182,3257,"Sign them."],[3328,3478,"I never want to see you again."],[3632,3703,"Charlotte!"],[3732,3832,"Get back here!"],[3891,3958,"Charlotte!"],[4024,4208,"Is she really?"],[4266,4346,"Was I wrong?"]],"23":[[62,133,"Was I wrong?"],[166,262,"Paul, I don't want to"],[262,429,"accuse your wife of anything,"],[450,633,"but isn't it just a little suspicious"],[633,800,"that she would run off like that?"],[855,913,"Wait, what do you mean?"],[925,1017,"I mean, if your daughter"],[1017,1146,"really was in that grave,"],[1146,1297,"would she really just take the remains"],[1297,1376,"and run off?"],[1405,1514,"Plus, that guy she's with,"],[1514,1605,"Xander Williams,"],[1605,1747,"her childhood best friend,"],[1747,1964,"he's also a rival in AI development."],[2035,2114,"This is a setup."],[2185,2273,"She's just gonna betray me."],[2489,2544,"God."],[2585,2723,"I'm going back to the hospital right now."],[2723,2848,"I need to know everything"],[2848,2952,"that happened to my daughter"],[2952,3073,"that day that she checked in."],[3482,3578,"Charlotte,"],[3628,3724,"I'm so sorry."],[3724,3791,"It's fine."],[3853,3937,"It's over now."],[3974,4070,"Take me to the Black Site."],[4070,4149,"I'm ready to work."],[4200,4308,"But you still have a day."],[4612,4804,"Driver, take us to the Black Site."]],"24":[[479,646,"Mr. Hasting, what an honor"],[646,829,"to have the CEO of Hasting Medical"],[829,875,"in the building."],[875,942,"Cut it, Mason."],[942,1026,"I don't have time."],[1026,1101,"I need you to find"],[1101,1209,"all the information you have"],[1209,1313,"on my daughter's stay here"],[1313,1451,"during the day of the attacks."],[1634,1714,"Of course, sir."],[1764,1968,"I'll get that for you immediately."],[2460,2598,"So, what did you find out?"],[2656,2786,"After looking at the files,"],[2786,2957,"your daughter did come in that day."],[3123,3357,"But it was just a minor asthma issue."],[3357,3507,"She was released to her mother"],[3507,3595,"almost immediately."],[3599,3699,"Yes, I knew it."],[3732,3803,"As her condition"],[3803,3949,"didn't require a doctor,"],[3949,4195,"the one who saw her was this nurse."],[4216,4412,"So, she's fine?"],[4792,4838,"Yes."],[4909,5042,"It happened just like he said."],[5042,5109,"I knew it."],[5109,5238,"So manipulative."],[5326,5480,"I know she literally did that."],[5480,5547,"She knew I was gonna"],[5547,5668,"have sole custody of Kayla."],[5680,5793,"She's trying to"],[5793,5972,"steal my little granddaughter."],[5989,6143,"You can't let it happen, Paul."],[6143,6247,"Mom."],[6285,6381,"Oh my God."],[6448,6639,"I'm gonna destroy that bitch."]],"25":[[517,692,"Well, how'd I do?"],[1234,1405,"You did very good."],[1868,2006,"He's never getting back together"],[2006,2089,"with that bitch."],[2110,2285,"Paul Hasting is mine,"],[2302,2523,"which means his company is mine."],[2540,2723,"If you get together with the boss,"],[2786,2894,"where does that leave me?"],[2907,2990,"Don't worry."],[3040,3194,"You can be my little mistress."],[3232,3395,"And I'm a very generous"],[3395,3465,"sugar daddy."],[3824,3970,"Oh, and one more thing."],[4020,4179,"I need you to destroy every file"],[4179,4312,"that you have on the daughter."],[4366,4450,"Understand?"]],"26":[[3474,3737,"Kayla, I miss you so much."]],"27":[[784,909,"Bravo, Charlotte."],[950,1001,"Oh!"],[1063,1121,"This is our"],[1121,1322,"government liaison, Mr..."],[1322,1447,"Just Mr. is fine."],[1468,1555,"We've had a chance"],[1555,1634,"to take a close look"],[1634,1726,"at what you've built."],[1726,1839,"You've done more"],[1839,2077,"for national security in one month,"],[2077,2223,"than the entire government"],[2223,2389,"has done in three years."],[2435,2523,"How did you do it?"],[2548,2594,"Oh."],[2615,2752,"When it comes to AI,"],[2752,2915,"Charlotte is the greatest mind"],[2915,2990,"in the world."],[3028,3165,"Well, it wasn't that hard."],[3211,3307,"I had the blueprint already"],[3307,3436,"from the work I did at Hasting."],[3436,3499,"And I just had to"],[3499,3595,"convert the objectives"],[3595,3741,"to security and counter-terrorism."],[3791,3987,"I think it's time to take a trip"],[3987,4079,"to the Pentagon."],[4079,4170,"The Pentagon?"],[4204,4266,"Yes."],[4266,4446,"The whole time, you were working"],[4446,4675,"on that small government trial."],[4704,4904,"You were actually working for the NSA."],[4921,5046,"The most powerful"],[5046,5263,"security organization in the world."]],"28":[[1493,1626,"General Thomas Ericsson,"],[1651,1789,"head of the National Security Agency,"],[1789,1881,"this country owes you"],[1881,2022,"a debt of gratitude."],[2052,2118,"Thank you, sir."],[2173,2252,"I just want to make sure"],[2252,2323,"what happened to my daughter"],[2323,2423,"never happens again."],[2444,2556,"That AI you developed?"],[2556,2677,"It is light years ahead"],[2677,2773,"of anyone else."],[2794,2894,"When it goes operational"],[2894,2936,"next week,"],[2936,3090,"it will effectively end terrorism"],[3090,3178,"as we know it."],[3219,3332,"No foreign adversary,"],[3332,3478,"no radical jihadist,"],[3478,3645,"no megalomaniacal billionaire,"],[3645,3757,"will be able to compete"],[3757,3874,"with the U.S. government."],[3920,4037,"We're honored to serve"],[4037,4141,"our country, sir."],[4158,4279,"There is, however,"],[4279,4375,"one problem."],[4421,4604,"You see, national security is at stake"],[4604,4671,"and it seems you two"],[4671,4783,"have been compromised."],[4808,4863,"Go ahead."],[4892,5063,"Type your name into a search engine."],[5814,5930,"These are all lies, sir."],[5947,6001,"We know."],[6056,6197,"We think it might be a foreign government"],[6197,6322,"trying to compromise the program."],[6322,6398,"It's not."],[6502,6660,"I know exactly who did this."]],"29":[[137,308,"Well, our plan worked."],[333,421,"Pretty much every site"],[421,529,"has picked up the story."],[563,742,"Your wife is getting destroyed"],[742,825,"in the press."],[892,1042,"We had such a happy life."],[1055,1301,"And you destroyed it all, Charlotte."],[1301,1434,"I hope you regret"],[1434,1643,"every decision you've made."],[1910,2064,"I know exactly who did this."],[2077,2173,"This slander campaign"],[2173,2318,"wasn't done by a foreign agency."],[2356,2515,"This was done by my ex-husband."],[2560,2690,"And I will take care of it."],[2719,2819,"That is a relief."],[2857,2932,"You see, I need to know"],[2932,3111,"that our program is not compromised."],[3153,3319,"The program data is all on its drive."],[3319,3374,"I designed"],[3374,3482,"the encryption personally."],[3482,3649,"No one on Earth could crack this."],[3670,3799,"I can attest to that, sir."],[3841,3987,"She's the best in the world."],[3987,4074,"I don't doubt it."],[4108,4283,"But if anyone gives you two a problem,"],[4283,4391,"you call me immediately."],[4425,4608,"I will bring down the full force"],[4608,4721,"of the NSA on them."],[4721,4796,"Thank you, sir."],[4821,4879,"Thank you, sir."],[5184,5296,"You did great in there."],[5422,5522,"That was nothing."],[5626,5847,"And that drive is going to make"],[5847,5993,"the world a safer place."]],"30":[[108,312,"Take Kayla home!"],[521,654,"Mr. Williams, how does it feel"],[654,767,"to destroy a family?"],[767,825,"Hey, Charlotte."],[825,892,"Charlotte!"],[892,992,"Where's your daughter?"],[1001,1059,"Why won't you let your"],[1059,1138,"husband see her?"],[1305,1355,"Keep rallying!"],[1355,1476,"I don't know what you've heard,"],[1476,1509,"but- - Stop!"],[1509,1626,"Give Paul back his daughter,"],[1626,1726,"you evil bitch!"],[1726,1922,"These allegations are all false!"],[1922,2022,"You're just saying that"],[2022,2173,"because you two are screwing."],[2173,2285,"You won't get away with this."],[2285,2448,"Little Kayla deserves to be with her father."],[2448,2573,"Charlotte, is this your first affair"],[2573,2686,"or do you have a habit of sleeping"],[2686,2781,"with other tech moguls?"],[2781,2932,"Stop spreading these lies."],[3028,3094,"The truth is,"],[3094,3303,"our relationship is purely professional."],[3303,3378,"But even if it wasn't,"],[3378,3453,"it wouldn't matter"],[3453,3553,"because Paul Hasting and I"],[3553,3649,"have divorced."],[3795,3828,"Ho!"],[4058,4137,"Lies!"],[4475,4608,"We are not divorced."]],"31":[[4,204,"My name is Paul Hasting,"],[204,291,"and I am Charlotte's"],[291,462,"lawfully wedded husband."],[508,654,"Paul, what are you doing?"],[654,792,"For those of you who don't believe me,"],[867,959,"I have evidence."],[1026,1155,"Our marriage certificate."],[1259,1401,"I am a