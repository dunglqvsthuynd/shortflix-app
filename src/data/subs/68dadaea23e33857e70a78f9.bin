rlfriend last night."],[5668,5718,"What?"]],"49":[[50,104,"What?"],[925,1013,"Emma Parker,"],[1105,1209,"will you be my girlfriend?"],[1288,1368,"Hmm."],[1497,1618,"I'll take that as a yes."],[2273,2427,"Thank God Mom believed me."],[2460,2519,"If she found out"],[2519,2623,"I wasn't at Hazel's,"],[2623,2736,"but actually spent the night"],[2736,2806,"with a guy,"],[2819,2911,"I would be dead."],[3399,3457,"At least he gave me"],[3457,3561,"something clean to wear."],[3649,3799,"This Dazy set from Shein."],[3816,3866,"Kinda cute."],[3920,3974,"Emma!"],[3995,4029,"Oh my God,"],[4029,4183,"your hair looks so perfect today."],[4216,4304,"So perfect."],[4316,4387,"Thank you."],[4637,4688,"Emma,"],[4729,4838,"can I get your number?"],[4871,4959,"You can use my phone."],[5017,5125,"Uh, I gotta go."],[5146,5196,"Sorry."],[5246,5317,"Hey, Emma."],[5359,5422,"Uh, do you wanna come to"],[5422,5568,"my party on Saturday?"],[5580,5680,"Let's get ready together."],[5680,5801,"Uh, I, maybe."],[5885,5968,"What's their deal?"],[6043,6214,"Why are they swarming me?"],[6406,6493,"Emma Parker!"],[6535,6639,"How dare you"],[6639,6848,"debauch our Perfect Prince Rowan!"],[6881,7023,"You're not even good enough for him."],[7115,7161,"Okay."],[7207,7311,"What did I do now?"],[7311,7407,"Wait, don't play dumb."]],"50":[[283,379,"This isn't true."],[504,558,"Right."],[646,704,"Like you're not the one"],[704,821,"who put these up."],[888,1021,"Stop playing the victim."],[1021,1142,"I'll teach you a lesson."],[1142,1188,"Hey."],[1188,1226,"Stop."],[1434,1518,"Let me go!"],[1622,1664,"Hey, hey, hey, hey."],[1664,1722,"What are you doing?"],[1735,1793,"What are you doing?"],[1885,1922,"Are you okay?"],[1960,2018,"Yeah."],[2127,2173,"Rowan,"],[2273,2394,"we were just teaching her a lesson"],[2394,2469,"for you."],[2498,2640,"She's been spreading lies saying"],[2640,2756,"she's your girlfriend."],[2794,2902,"Who says they're lies?"],[3003,3082,"What?"],[3215,3332,"I'm saying they're all true."],[