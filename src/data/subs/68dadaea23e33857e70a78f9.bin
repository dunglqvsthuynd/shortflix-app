hould I believe him?"],[3511,3712,"Okay, he's, he's bossy."],[3757,3966,"He's aggressive."],[4045,4312,"He's always picking fights with me,"],[4362,4583,"like he's one walking red flag"],[4583,4692,"after another."],[5050,5150,"Okay, I know"],[5176,5263,"you guys see me as"],[5263,5380,"some little commoner,"],[5488,5697,"but just because he's rich,"],[5722,5947,"it does not mean-"],[5947,6018,"Emma."],[6085,6210,"that I have to do - Emma, Emma,"],[6210,6302,"what he says. - Emma,"],[6302,6377,"I don't have to - Emma,"],[6377,6452,"follow his little - Hey."],[6452,6552,"whims, got it?"],[6552,6614,"Emma."],[6919,6961,"Rowan."],[7036,7148,"So that's how you see me?"],[7269,7411,"You don't think I could change?"],[7549,7657,"No matter what I do."],[7924,7982,"No."],[8112,8224,"Rowan, wait!"]],"66":[[1751,1860,"You always seem to be there"],[1860,1947,"when I need you."],[2147,2306,"Well, if you want to thank me,"],[2448,2552,"can I take you out on a date?"],[2919,3057,"Sorry, I uh,"],[3086,3236,"I have, just so much"],[3236,3345,"going through my mind right now."],[3345,3415,"No, it's okay."],[3470,3524,"I guess I just"],[3591,3661,"I want an excuse"],[3661,3766,"to spend more time with you."],[6143,6189,"Bro."],[6247,6293,"Rowan,"],[6327,6414,"are you really sulking over"],[6414,6502,"your girl problems?"],[6514,6589,"I mean, you've always just"],[6589,6652,"taken what you want."],[6652,6735,"Are you really just gonna like"],[6748,6827,"give up this time?"],[6911,7048,"Yeah, whatever."],[7157,7469,"I don't want to hear her name again."],[7524,7711,"Don't talk about her."],[7732,7791,"Oh."],[7849,7953,"But I heard she's going on her date"],[7953,8066,"with August today."],[8124,8191,"Yeah."],[8191,8270,"Thought you might want to know"],[8270,8337,"where they're headed."],[8429,8495,"Where are they going?"]],"67":[[4,62,"Maybe I should've gotten"],[62,208,"more strawberry but,"],[229,296,"I mean, next time."],[304,371,"No regrets."],[375,450,"No regrets."],[1063,1134,"I'm sorry."],[1242,1405,"It's like my first"],[1447,1543,"real date,"],[1559,1780,"so I'm a little nervous."],[1805,2002,"Didn't you go on a date with Rowan?"],[2068,2239,"Kind of, uh, except he"],[2277,2389,"got caught in the rain"],[2389,2598,"and then he got sick,"],[2610,2748,"so I had to take care of him."],[2748,2865,"And then,"],[2957,3015,"you know,"],[3111,3161,"he's like,"],[3215,3470,"ah, he's such a troublemaker."],[3486,3674,"And everywhere he goes,"],[3674,3824,"I swear, like,"],[3858,3937,"chaos follows-"],[3937,3991,"Careful."],[3991,4079,"Oh, I'm sorry."],[4079,4158,"No, no, it's fine."],[4158,4250,"It's fine, it's fine."],[4554,4725,"See, you're such a good guy."],[4750,4925,"Like, if, if that were Rowan,"],[4971,5167,"he would throw a fit, I think."],[5497,5659,"You know, Em."],[5714,5772,"Mhm?"],[5793,5901,"You're on a date with me,"],[5901,6068,"but I just, I can't help but feel"],[6068,6135,"that you're still"],[6135,6247,"thinking about Rowan."]],"68":[[225,296,"Yeah,"],[308,504,"uh, I'm sorry."],[596,734,"I won't talk about him anymore."],[738,917,"No, it's, it's okay."],[1038,1088,"Sorry."],[1222,1409,"I'm really happy to spend time with you."],[2627,2736,"Guess I got my answer."],[3174,3257,"I, uh,"],[3370,3436,"August."],[3595,3707,"I don't think I'm ready yet."],[3782,3883,"Yeah, that's fine."],[3953,4066,"I'm not going anywhere."],[4179,4229,"Okay."],[4437,4487,"Let's go."],[4487,4550,"Next stop."],[4550,4608,"Come on."],[5092,5163,"Oh, which one?"],[5167,5226,"Jesse."],[5255,5334,"Oh, I love Jesse."],[5334,5380,"Really?"],[5388,5447,"I love that song."],[5476,5513,"Do you?"],[5513,5584,"Yeah."],[5584,5668,"They have better ones,"],[5668,5789,"but I just can't get the better ones."],[5789,5880,"The chain is so good."],[5893,5968,"The chain is so good."],[5968,6035,"So good."],[6085,6147,"Hi."],[6147,6256,"Hi, welcome."],[6272,6348,"Thank you."],[6393,6498,"Uh, do you know what you want?"],[6498,6585,"What do you want?"],[6614,6744,"Emma Parker."],[6756,6973,"Just you wait."]],"69":[[241,479,"Yeah, I used to go to MEA."],[525,721,"You know, that super rich school"],[721,846,"with the Big Four."],[975,1242,"Bunch of insecure, spoiled brats."],[1251,1405,"Especially Rowan Calloway."],[1422,1488,"Really?"],[1601,1722,"I've heard of him."],[1730,1956,"He always seems so princely."],[1989,2089,"Please."],[2127,2198,"That guy's a bully."],[2198,2327,"He's the reason I got kicked out."],[2381,2448,"Everybody at school"],[2448,2535,"secretly hates Rowan."],[2535,2677,"They're just too scared to say it."],[2706,2752,"Deep down,"],[2752,2848,"we were all waiting for him to"],[2848,2936,"drop dead."],[3286,3390,"Hey, douchebag."],[3440,3516,"Remember me?"],[3549,3599,"Yeah."],[3653,3837,"Rowan is nothing like that!"],[3845,3928,"Emma Parker."],[3928,3995,"What are you-"],[4137,4216,"wait."],[4279,4546,"Are you seriously defending Rowan?"],[4600,4700,"He bullied you too."],[4700,4750,"What?"],[4763,4929,"You got feelings for your own bully?"],[4967,5075,"You got Stockholm Syndrome"],[5075,5150,"or something?"],[5163,5296,"You're the one who led that group."],[5472,5572,"Actually,"],[5593,5747,"he tried to rip my clothes off."],[5751,5847,"What?"],[5860,5972,"You did what?"],[6006,6143,"You pervert!"],[6331,6385,"Ah!"],[6410,6539,"Emma Parker!"],[6552,6727,"You think you can get away with this?"]],"70":[[20,141,"Oh, you should be very"],[141,300,"afraid of what I'm capable of."],[1234,1317,"August, I'm sorry."],[1317,1572,"I, I really had to step in there."],[1630,1697,"Rowan,"],[1730,1851,"would be over the moon if he heard"],[1851,1993,"that you didn't deny falling for him."],[2139,2198,"No."],[2235,2281,"What?"],[2435,2481,"Look,"],[2585,2719,"Emma, I, I get it."],[2765,2898,"Your heart chose him."],[2932,3069,"I, I understand that I was just,"],[3069,3236,"you know, too late."],[3282,3428,"August, I'm sorry."],[3449,3516,"Don't be."],[3962,4008,"We're even."],[4058,4137,"Still friends?"],[4195,4300,"Of course."],[4550,4667,"But can I, can I catch up"],[4667,4775,"with you in a bit?"],[4783,4875,"Yeah, of course."],[4875,4988,"Okay, thank you."]],"71":[[25,296,"A quiet day, without Rowan Calloway."],[392,696,"No bullying, no pranks, no trouble."],[846,1046,"I thought this was what I wanted."],[1109,1301,"So why do I feel so empty?"],[2927,2990,"Noah?"],[3065,3169,"What do you want?"],[3211,3353,"Emma Parker,"],[3424,3549,"if it weren't for you,"],[3549,3666,"Rowan Calloway"],[3666,3853,"wouldn't have kicked me out of MEA."],[3891,3987,"My family"],[3987,4175,"wouldn't have gone bankrupt."],[4216,4429,"And now I'm living on the streets,"],[4450,4642,"and it's all because of you"],[4642,4833,"and Rowan Calloway!"],[4900,5217,"It's time to pay the price!"]],"72":[[300,375,"All right, August."],[375,479,"What's the big announcement?"],[500,621,"Are you and Emma official now?"],[638,821,"I, I have something to say first."],[934,984,"Go ahead."],[1155,1330,"I've given up on Emma Parker."],[1368,1480,"You're my best friend, August."],[1559,1639,"You're like my brother."],[1726,1889,"I'm not gonna fight you over some girl."],[2068,2139,"She's all yours."],[2268,2302,"Oh."],[2435,2619,"Well, that's funny timing,"],[2619,2748,"because I was just about to say,"],[2781,2894,"I mean, Emma was great, but"],[2940,3090,"after I got what I wanted, I mean,"],[3123,3249,"there's not really much left to her."],[3249,3378,"What the hell did you just say?"],[3428,3495,"I said,"],[3507,3666,"I was just messing around with her."],[3712,3791,"You bastard!"],[3899,3949,"Woah!"],[3949,4037,"Come on brother, be chill."],[4037,4179,"I'm gonna fucking kill him!"],[4179,4295,"Rowan, calm down! - Let me go!"],[4295,4400,"I thought you said you were over her."],[4471,4558,"Why do you care?"],[4792,4875,"August Langford,"],[4900,5130,"the only reason I gave up on her"],[5130,5180,"is because I thought"],[5180,5305,"you were gonna treat her right!"],[5326,5388,"I thought you were gonna"],[5388,5488,"make her happy!"],[5563,5689,"I can't let you hurt her!"],[5693,5793,"So just admit it."],[5855,5968,"You care about her."],[6043,6114,"You couldn't leave her"],[6114,6197,"if you wanted."],[6331,6377,"What do you mean?"],[6431,6598,"The whole time I was with Emma,"],[6635,6781,"she kept talking about you."],[6835,7002,"She likes you, Rowan."]],"73":[[141,266,"Does she really like me?"],[1597,1697,"What do you want?"],[1835,1943,"Stay away from me."],[2002,2102,"What do we want?"],[2193,2314,"You're just the bait."],[2369,2460,"What we want"],[2565,2723,"is Rowan Calloway."],[2806,2902,"Too bad."],[2973,3078,"He hates me."],[3078,3174,"He's not coming."],[3215,3495,"So just leave me alone"],[3520,3624,"and don't do something"],[3624,3741,"you can't take back."],[3741,3945,"Oh, I'm sure he's coming."],[4045,4258,"Everyone knows he's obsessed with you."],[4279,4483,"I've sent him a text, come here alone."],[4500,4717,"He's probably on his way now."],[4746,4963,"What, what are you trying to do?"],[4988,5384,"Rowan humiliated every one of us."],[5405,5509,"Expelled,"],[5605,5668,"beaten,"],[5684,5955,"ruined in front of the whole school."],[6014,6118,"And we've waited a"],[6118,6402,"long time for payback!"],[6535,6648,"Rowan punished you"],[6702,6902,"because you're a repulsive creep."],[6902,7007,"Shut up!"],[7132,7424,"You're his little girl, huh?"],[7465,7645,"We'll see how he'll react"],[7665,7870,"when he walks in and sees you"],[7920,8033,"tied up."],[8216,8279,"Stop."],[8329,8454,"Please get away."],[8462,8596,"Please, stop!"],[8733,8812,"Help!"],[8837,8917,"Get away!"],[8958,9042,"Let her go!"]],"74":[[187,362,"Well, well,"],[362,617,"look who we finally have."],[671,1009,"Isn't this the Rowan Calloway?"],[1038,1155,"Your grudge is with me."],[1222,1297,"Let her go."],[1372,1488,"If you touch her again,"],[1497,1618,"I'll fucking bury you."],[1639,1760,"Oh, I'll let her go."],[1814,1893,"But first,"],[1981,2189,"we'll let our anger out on you."],[2323,2414,"Fight back,"],[2556,2698,"and I'll carve up her"],[2698,2902,"pretty little face!"],[2902,3103,"Okay, okay, okay."],[3169,3332,"Just don't touch her, okay?"],[3432,3478,"I'll do it."],[3524,3574,"Deal!"],[3687,3824,"No, no!"],[4004,4166,"No, stop!"],[4225,4295,"Deal! - No!"],[4350,4575,"No, Rowan, Stop!"],[4604,4813,"Look at you now, Rowan Calloway."],[4879,4988,"A perfect,"],[4988,5201,"spoiled prince,"],[5238,5455,"groveling like a loser."],[5559,5701,"How pathetic!"],[5701,5793,"No!"],[5947,6006,"Okay."],[6356,6531,"You hit like a scared little bitch."],[6623,6785,"I will fucking kill you!"],[6815,7002,"No, stop!"]],"75":[[154,325,"Oh, I'm gonna enjoy this."],[492,608,"This is for everything you've done!"],[988,1034,"Rowan."],[1084,1201,"Rowan, fight back."],[1242,1305,"Fight back."],[1305,1472,"You don't have to do this for me."],[1755,1830,"Don't cry, Emma."],[1847,1901,"It's okay."],[1951,2022,"I'm alright."],[2077,2139,"Rowan."],[2260,2394,"You think this is over?"],[2506,2660,"You like her, huh?"],[2736,2936,"Say that you'll give up on her."],[2965,3065,"Say it!"],[3069,3244,"I'll never say something like that."],[3378,3687,"Aw, aren't you such a cute couple."],[3807,3966,"So sweet."],[4204,4346,"It's disgusting!"],[4346,4421,"No!"]],"76":[[654,709,"No!"],[850,913,"Rowan!"],[1038,1146,"Calm down!"],[1234,1359,"Dude, stop."],[1839,2018,"Rowan, you're so stupid!"],[2018,2118,"You shouldn't have come!"],[2118,2206,"I'm so sorry."],[2210,2264,"You're,"],[2264,2339,"You're supposed to be mine."],[2339,2419,"I shouldn't have let anything"],[2419,2473,"happen to you."],[2590,2794,"Emma, I don't just like you."],[2848,2982,"There's so much more than that."],[3069,3115,"Just,"],[3240,3432,"just stay with me, okay?"],[3465,3541,"Just,"],[3545,3641,"just stay..."],[3653,3695,"No!"],[3845,4012,"Hey, hey, hey."],[4312,4366,"Hey."],[4667,4783,"Rowan, we're here."],[4938,5030,"Get the hell away from him,"],[5030,5117,"you psycho."],[6076,6114,"Emma."],[6114,6177,"Rowan."],[6177,6302,"Took you guys long enough."],[6439,6610,"Rowan, hey, stay with me."],[6644,6773,"Wake up, hey!"],[6856,7032,"Rowan, please!"]],"77":[[521,604,"Emma, are you okay?"],[608,696,"Rowan."],[729,829,"Rowan, where's Rowan?"],[863,963,"He's hurt worse than me."],[996,1059,"Take a breath."],[1080,1155,"Take a breath."],[1192,1242,"It's okay."],[1501,1580,"What happened?"],[1580,1685,"He's next door."],[1818,1872,"He didn't-"],[1901,1964,"What happened?"],[2031,2106,"No, wait!"],[3286,3345,"What's going on?"],[3445,3599,"The doctor said his brain was"],[3599,3699,"permanently damaged."],[3720,3757,"No."],[3866,3966,"They don't think he's gonna make it."],[3995,4045,"Hey!"],[4054,4108,"Hey!"],[4200,4333,"Rowan, wake up!"],[4341,4404,"No."]],"78":[[50,166,"Wake up, okay?"],[271,329,"There's so much"],[329,446,"I have to say to you."],[513,604,"Rowan, wake up."],[713,809,"Please, please!"],[867,963,"Please!"],[1076,1180,"Oh, God."],[1217,1468,"I hate you, I hate you."],[1468,1722,"You're just a big, mean bully!"],[1864,1981,"You never gave me the chance"],[1981,2056,"to tell you"],[2122,2310,"how much I care about you,"],[2444,2606,"how much you mean to me."],[2640,2836,"So please, please,"],[2869,2952,"wake up."],[3103,3186,"Wake up!"],[3482,3549,"Please!"],[3999,4124,"I knew you liked me."]],"79":[[20,137,"You're okay?"],[137,237,"Yeah."],[354,508,"Emma, that was beautiful."],[508,625,"Right, right?"],[638,750,"You like had me crying."],[750,842,"Oh, my God."],[842,917,"You idiots!"],[971,1096,"You all knew about this?"],[1113,1209,"August, you too?"],[1209,1338,"Sorry, it was the only way to"],[1338,1434,"get you to confess."],[1605,1826,"So, were you gonna tell me"],[1826,1939,"how you feel about me now?"],[2010,2181,"Oh, Rowan Calloway,"],[2181,2344,"another freaking prank?"],[2344,2398,"Ouch!"],[2398,2502,"Oh, be gentle!"],[2502,2702,"Hey, I'm still injured!"],[2715,2790,"Hey, alright."],[2802,2973,"Alright, alright, alright, okay."],[3036,3103,"Stop hitting me."],[3115,3269,"I surrender, okay?"],[3340,3436,"I know you care about me."],[3528,3620,"And I told you, Emma,"],[3699,3820,"I knew you were gonna fall for me."],[3853,3899,"Why,"],[3912,4062,"would I fall for a liar?"],[4062,4154,"Liar!"],[4366,4471,"If you didn't fall for me,"],[4521,4612,"then why were you crying?"],[4767,4892,"And why is your heart racing"],[4892,4950,"right now?"]],"80":[[62,241,"God, you're such an idiot."],[296,383,"Why would you let them"],[383,487,"beat you like that?"],[533,642,"I wasn't gonna sit back"],[642,734,"and let them hurt you."],[859,1026,"If anyone was gonna take the hits,"],[1076,1172,"it was gonna be me."],[1618,1685,"Rowan."],[2306,2369,"Hold on."],[2456,2548,"You can kiss me,"],[2656,2798,"but I'm only gonna kiss my girlfriend."],[2886,3007,"So are you my girlfriend?"],[3395,3453,"Duh."]],"81":[[571,709,"I like you, Emma Parker."],[746,984,"I really, really like you."],[1121,1276,"I didn't realize how much"],[1276,1384,"you meant to me"],[1455,1609,"until I almost lost you."],[2581,2635,"Oh."],[2698,2831,"They did kick my ass."],[2865,3036,"Alright, walk it off, soldier."],[3203,3353,"You should see the other guy."],[3516,3570,"He's fine."]]}