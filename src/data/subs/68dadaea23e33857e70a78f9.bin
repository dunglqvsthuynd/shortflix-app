{"1":[[734,888,"Rise and shine, Pumpkin!"],[925,1001,"Up, up, up!"],[1017,1051,"No."],[1051,1242,"It's your first day at your new school."],[1242,1305,"No it's not."],[1305,1472,"I don't wanna go to the super stuck-up"],[1472,1559,"Maple Elite Academy."],[1559,1676,"Please don't make me go."],[1676,1726,"I don't care."],[1726,1814,"You're going."],[1889,1997,"This could be your chance."],[2089,2168,"It's the last thing"],[2168,2273,"your father left you."],[2660,2748,"Mrs. Parker,"],[2765,2923,"on behalf of Maple Elite Academy,"],[2948,3190,"we offer our deepest condolences"],[3190,3311,"for the loss of your husband,"],[3319,3407,"Mr. Robert Parker."],[3486,3628,"Regarding the unfortunate"],[3649,3724,"construction accident,"],[3799,3895,"we're prepared to offer"],[3916,4124,"eight hundred thousand dollars."],[4346,4587,"We don't want your blood money."],[4679,4758,"Get out!"],[5271,5363,"We'll take the deal."],[5459,5509,"What?"],[5551,5609,"Mom."],[5609,5730,"Under one condition."],[5839,5951,"Emma gets a spot"],[5951,6068,"at Maple Elite Academy."],[6869,7082,"MEA has the best fencing team"],[7098,7203,"in the country."],[7290,7432,"Your father always dreamed about"],[7432,7565,"you winning gold."],[7657,7770,"Your dad's gone,"],[7820,7941,"but you're still here."],[8062,8179,"We have to keep living."],[9376,9451,"Watch your step!"],[9630,9734,"Asshole!"],[10064,10218,"Watch where you're going next time, huh?"],[10443,10535,"You should feel honored."],[10560,10689,"Not everyone gets to get baptized"],[10689,10865,"by the Rowan Calloway."],[10894,10952,"Excuse me?"],[11019,11144,"You wanna say that to my face?"],[11498,11757,"You smug, arrogant douchebag!"],[11782,12003,"Never show your face to me again!"]],"2":[[0,133,"Stupid school!"],[179,316,"Stupid rich kids!"],[492,546,"Excuse me?"],[579,638,"Hi."],[721,763,"What?"],[921,1184,"I got a spare t-shirt in this bag."],[1313,1480,"Seems like maybe you could use it."],[1526,1739,"Oh my God, you're a lifesaver."],[1776,1889,"The name's Hazel Jones."],[2022,2097,"Emma Parker."],[2252,2377,"This is so cute! - Perfect."],[2406,2464,"Thanks, girl."],[2523,2610,"Of course!"],[2648,2686,"It's from"],[2686,2769,"Missguided on Shein."],[2786,2894,"One of the latest drops."],[3090,3186,"Alright, newbie."],[3249,3465,"Welcome to Maple Elite Academy."],[3499,3545,"The motto?"],[3611,3657,"Money speaks"],[3657,3766,"louder than your GPA."],[3803,4091,"And looks are your currency."],[4421,4462,"Cool."],[4504,4646,"Sounds like my personal hell."],[4683,4721,"Yep."],[4833,4917,"Oh my God, oh my God!"],[4917,4984,"They're here!"],[5013,5059,"Ah!"],[5100,5176,"Ah!"],[5176,5251,"We have to go!"],[5251,5296,"What's happening?"],[5296,5376,"We have to go!"],[7786,7932,"Okay, who are these guys"],[7932,8087,"and why is everyone going nuts?"],[8103,8245,"These are the most"],[8245,8387,"popular boys at the school."],[8454,8671,"Also known as Big Four."],[8712,8792,"The what now?"],[8833,8917,"They're the heirs to like"],[8942,9113,"the richest families in the country?"],[9200,9338,"Liam Davenport."],[9363,9634,"Heir to the famous Davenport family."],[9730,9847,"Karl Reed."],[9905,10130,"His grandfather was an arms dealer."],[10164,10352,"Rumor is his family has got mafia ties."],[10377,10460,"And then"],[10531,10681,"there's August Langford."],[10714,10831,"He's the quiet one."],[10852,11056,"Super mysterious."],[11119,11236,"His family owns over a dozen"],[11236,11494,"auction houses around the world and"],[11494,11736,"August is a genius artist himself."],[11815,11920,"And finally."],[11957,12057,"The leader,"],[12057,12216,"Rowan Calloway,"],[12245,12391,"heir to an international"],[12391,12595,"conglomorate that stretches across"],[12595,12791,"all seven continents."],[12841,12979,"His family owns"],[12979,13092,"pretty much everything."],[13125,13209,"They're richer than"],[13209,13321,"the people on Forbes."],[13321,13601,"Like, they probably own Forbes."],[13667,13805,"And there they are."],[13851,13938,"The Big Four."],[14005,14122,"They're so hot!"],[14164,14222,"I can't even believe"],[14222,14314,"we're breathing the same air."],[14343,14489,"If one of them glances at me,"],[14527,14627,"I'll actually die."],[14643,14718,"I'm manifesting"],[14718,14806,"marrying one of them."],[14877,14944,"It's happening."],[14985,15085,"So they're just like"],[15140,15252,"four little rich boys?"],[15294,15415,"So, okay."],[15415,15544,"Why is everyone screaming?"],[15553,15728,"They're not just boys."],[15728,15911,"They are the boys."],[15986,16032,"You'll see."],[16107,16182,"Wait a sec..."],[16203,16349,"That's that asshole from this morning."],[16420,16478,"Shh!"],[16478,16629,"It's Rowan Calloway."],[16658,16762,"You do not wanna mess with him."],[16783,16871,"If you piss him off,"],[16871,16954,"you're good as dead!"]],"3":[[1785,1906,"You're looking for"],[1906,1972,"me sir? - Yeah."],[2006,2047,"You."],[2056,2143,"I'm looking for you."],[2143,2239,"Oh, my name is Noah-"],[2239,2448,"I don't give a fuck what your name is."],[2485,2615,"Wait, wait, wait."],[2731,2790,"August,"],[2840,2923,"hand me your juice."],[3236,3286,"No."],[3324,3403,"Not the juice."],[3566,3799,"I can't believe this rich bully."],[4016,4112,"Oh my God!"],[4112,4225,"I need to stop this."],[4466,4583,"You piss me off, Noah,"],[4633,4713,"you're dead."],[4733,4846,"Wait, wait, wait, what, what did I do?"],[4846,4963,"You know what you did."],[5693,5718,"Emma."],[5718,5772,"Emma, Emma."],[5772,5843,"Stop it!"],[5905,5993,"Oh my God."]],"4":[[8,171,"Did you just hit me?"],[408,513,"You're that girl from this morning."],[546,638,"You're damn right, I am."],[671,855,"First, you ruined my uniform"],[855,1001,"and don't even bother to apologize."],[1001,1080,"And now this?"],[1146,1226,"Picking on someone"],[1226,1355,"who won't even fight back."],[1472,1747,"Wow, yeah, real tough guy move."],[1747,1972,"You have no idea what's going on."],[2010,2118,"That guy deserves it."],[2147,2273,"Do 