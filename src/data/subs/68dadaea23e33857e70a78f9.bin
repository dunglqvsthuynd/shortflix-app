rested"],[2515,2660,"in those little rich boys,"],[2660,2919,"and I'm really not interested in"],[2919,3090,"whatever weird little fangirl club"],[3090,3165,"you have going on."],[3165,3315,"So, bye."],[3440,3486,"Come on."],[3712,3841,"That snobby bitch."],[3937,4004,"Looks like someone needs"],[4004,4175,"a little attitude adjustment."],[4283,4350,"Girls,"],[4404,4612,"let's teach the newbie a lesson."],[5005,5055,"Stop."],[5180,5246,"What the heck?"],[6335,6439,"Oh."],[6777,6844,"No, no, no."],[6844,6986,"Oh, my stuff!"],[7595,7691,"The next class is P.E."],[7691,7761,"You're gonna lose points"],[7761,7903,"if you show up with the wrong shoes!"],[7924,8070,"Oh, this is so messed up!"],[8153,8316,"Who would ever do anything like this?"],[8362,8450,"Who else?"],[8521,8633,"Better watch your back."],[8696,8929,"There's only one person at this school"],[8929,9063,"who gets away with everything,"],[9063,9117,"right?"],[9121,9434,"That bully Rowan Calloway."]],"6":[[362,442,"What was that, Rowan?"],[450,579,"Got some pent-up rage today?"],[579,688,"Blame Emma Parker."],[688,738,"Wow."],[817,913,"I think that's the first time"],[913,1046,"I heard you say a girl's full name."],[1046,1167,"Only because I have a score to settle."],[1213,1280,"What's the plan?"],[1347,1422,"How about"],[1468,1593,"we sneak a snake in her locker?"],[1639,1747,"Bet she'd freaking cry."],[1755,1839,"Whatever, Rowan."],[1868,1926,"You're all talk."],[2198,2314,"Rowan Calloway!"],[2936,3057,"You got a problem with me?"],[3069,3286,"You handle it face to face."],[3324,3407,"Do not"],[3424,3720,"hide behind dirty little pranks."],[3732,3853,"You wanted a fight?"],[3908,3999,"You got one."],[4037,4412,"And I don't lose."],[4412,4466,"We'll see."],[5288,5380,"Dude, what was that?"],[5434,5497,"Hey, Rowan."],[5497,5551,"That was, uh,"],[5551,5630,"that was kind of hot."],[5701,5772,"She knock the wind out of you"],[5772,5814,"or something?"],[5843,5910,"What are you looking at?"],[5926,5993,"She's gone."],[6051,6122,"Emma Parker?"],[6189,6252,"Alright."],[6343,6448,"I'll make you regret this."],[6652,6785,"Rowan Calloway!"],[6806,6886,"Big four?"],[6886,7082,"More like tiny dick four!"],[7107,7278,"I'll send you all straight to hell!"],[7682,7720,"Um."],[7766,7820,"Sorry."],[7895,8020,"I, I didn't mean to"],[8087,8179,"talk about your-"],[8237,8350,"I was trying to find, uh,"],[8350,8500,"some peace and quiet, but-"],[8500,8683,"Sorry, I disturbed you, I guess."],[9188,9230,"Here."],[9376,9455,"Drink this."],[9467,9572,"It'll help calm you down."],[9597,9655,"Thank you."],[9868,9993,"You're not like the others, huh?"],[10043,10118,"You didn't join in"],[10118,10222,"when they were hurting Noah."],[10222,10364,"Not everything is what it seems."],[10497,10581,"Especially Noah."]],"7":[[37,141,"She kicked my ass."],[162,196,"Like,"],[258,379,"she actually kicked my butt."],[450,592,"Who the hell does she think she is?"],[608,725,"Look at you, Rowan."],[725,829,"Getting all worked up over"],[829,909,"Emma Parker."],[925,988,"Admit it,"],[988,1084,"you got a thing for her."],[1084,1138,"What?"],[1205,1272,"No!"],[1280,1388,"It's just, I'm not gonna"],[1388,1501,"let her get the last laugh."],[1572,1689,"No one's ever made a fool of me."],[1776,1851,"She's just the first."],[1851,1906,"Sure."],[1956,1997,"I mean, what?"],[1997,2064,"She's like the"],[2097,2218,"first girl to get under your skin?"],[2260,2423,"Sounds like she might have a"],[2423,2577,"special place in your head."],[2610,2690,"Special?"],[2831,2894,"Special?"],[3303,3382,"That's it."],[3399,3595,"She's been provoking me on purpose."],[3691,3741,"Fine."],[3774,3874,"She wants my attention?"],[3903,3974,"She's got it."],[4008,4074,"Tomorrow,"],[4137,4258,"I'm gonna give her an ultimatum."],[4792,4850,"Oh."],[5121,5196,"Morning, Hazel!"],[5292,5347,"Um."],[5643,5768,"What is wrong with everyone"],[5768,5843,"this morning?"],[6952,7048,"Oh my God!"],[8045,8153,"You see what happens"],[8153,8258,"when you go against me?"],[8333,8479,"I can do whatever I want to you,"],[8479,8558,"Emma Parker."],[8591,8700,"I own this school."],[8746,8954,"I own you."]],"8":[[20,79,"That's what you get"],[79,221,"when you mess with our boys."],[275,412,"No friends."],[425,550,"No backups."],[613,729,"Just enemies."],[888,996,"Aw."],[996,1292,"Is the poor little baby gonna cry?"],[1409,1493,"Look at her,"],[1493,1668,"so dirty and pathetic."],[1876,2006,"I'll give you a way out of this, Parker."],[2081,2189,"Apologize to me"],[2268,2344,"and tell"],[2423,2569,"everyone in this room"],[2569,2719,"that you'll be my personal servant."],[2831,2998,"Beg me to save you."],[3015,3136,"And I can make this all stop."],[3186,3303,"You wanna hear me beg?"],[3349,3445,"Yes."],[3486,3553,"We're all waiting."],[3653,3699,"Okay."],[3841,3941,"Come a little closer."],[4254,4366,"Still too far."],[4671,4729,"There."],[4779,4829,"Happy?"],[4892,4942,"Now."],[5021,5100,"I'm all ears."],[5192,5363,"Tell me how sorry you are."],[6056,6147,"No, no, no."],[6147,6268,"Oh, what are you doing?"],[6277,6352,"Crazy!"],[6435,6539,"Let go of me."]],"9":[[141,367,"You listen up, Rowan Calloway."],[396,500,"I know you're obsessed with me."],[525,746,"But I will never ever"],[775,942,"apologize to you."],[1096,1205,"You want me to break?"],[1263,1376,"You want me to run?"],[1430,1626,"Not gonna happen."],[1726,1772,"So,"],[1893,1993,"do your worst."],[3720,3828,"I'm sorry, Emma."],[3862,4029,"I'm not brave enough to fight back,"],[4066,4216,"or good enough to be your friend."],[4241,4366,"My family went bankrupt."],[4425,4604,"I won't be at MEA anymore."],[4625,4750,"But here are new clothes"],[4750,4846,"from Missguided."],[4871,5013,"Figured you might need them today."],[6072,6264,"Your pranks were useless!"],[6314,6519,"She humiliated me again!"],[6598,6698,"I want Emma Parker"],[6727,6835,"to come to me,"],[6906,7069,"begging for forgiveness."],[7107,7157,"Got it?"],[7157,7228,"Understood."],[7228,7319,"Then go!"],[7682,7811,"Obsessed with her?"],[7845,7962,"Who does she think she is?"],[8033,8108,"How could someone"],[8141,8354,"as perfect as me"],[8387,8487,"be obsessed"],[8508,8754,"with a normie, peasant girl"],[8754,8817,"like her?"],[8817,8950,"He's totally obsessed with her."],[8988,9050,"Totally."]],"10":[[4,75,"Emma,"],[83,254,"what happened in school today?"],[283,337,"Mom,"],[367,454,"I don't belong"],[454,671,"with those rich assholes."],[671,850,"My only new friend is gone,"],[850,1038,"and I miss my old friends."],[1038,1088,"Please,"],[1088,1272,"I wanna go back to my old school."],[1309,1413,"I hate it there."],[1413,1655,"Please, don't make me go back, Mom."],[1726,1851,"This belonged to your father."],[1947,2068,"If it weren't for me"],[2068,2248,"getting pregnant with you in college."],[2281,2452,"Your father would have went pro."],[2581,2740,"You have his talent, Emma."],[2844,2957,"Don't give up now."],[3190,3261,"You're right."],[3620,3720,"Rowan Calloway,"],[3791,3991,"I will fight you to the very end."],[4808,4975,"Seriously, Rowan Calloway?"],[4992,5159,"Bullying students wasn't enough?"],[5159,5355,"Now you're torturing a kitten, too?"],[5417,5467,"Hey!"],[5484,5597,"Unhand that cat!"],[5976,6035,"Wait,"],[6118,6214,"he's helping it?"],[6306,6368,"It's okay."],[6448,6527,"Almost there."],[6635,6706,"There you go, buddy."],[7023,7073,"What?"],[7073,7157,"Did you come all this way"],[7157,7228,"just to see me?"],[7265,7315,"Ew."],[7344,7382,"No."],[7469,7611,"I have fencing, so..."],[7703,7757,"Bye."],[7782,7828,"Bye."],[7828,7887,"Shut up."],[8091,8241,"He didn't act like a bully."],[8341,8391,"He was"],[8445,8508,"gentle."]],"11":[[37,183,"You brought this on yourself."],[204,321,"Go beg Rowan for mercy."],[321,396,"Or better yet,"],[429,646,"transfer out while you still can."],[646,754,"Let me go!"],[817,1026,"Rowan Calloway, he sent them."],[1084,1205,"And I really thought"],[1205,1338,"for one second that"],[1388,1534,"maybe I misjudged him."],[1