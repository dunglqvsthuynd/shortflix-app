this"],[3949,4095,"worthless server has to say."],[4095,4233,"Take my mother somewhere quieter."],[4375,4487,"I'm fine."],[4487,4579,"I'll be right here."],[4667,4763,"Dani!"],[4842,4863,"Back-"],[4863,4984,"Hey, I said hands off!"],[4984,5142,"Unless you want to be carted off next."],[5363,5601,"What the hell was that about?"],[5889,6051,"I know you've all been anxiously"],[6051,6227,"awaiting the reveal of the designer"],[6227,6327,"I've chosen to partner with."],[6660,6748,"Brynn Maxwell,"],[6748,6948,"will you join me on stage?"],[7032,7157,"Oh! Oh my God."],[7211,7278,"She had a wardrobe"],[7278,7332,"malfunction."],[7557,7699,"Brynn, get the fuck over here. Come!"],[7799,7903,"What the fuck happened?"],[7903,8024,"I told you not to fuck it up."],[8024,8153,"I don't know."],[8266,8341,"Fix it!"],[8341,8491,"What are you looking at me for?"],[8521,8650,"You're the designer of the dress."],[8800,8975,"She wants to be a star designer so bad,"],[8975,9113,"Let's see if she has the skills"],[9113,9200,"to pull it off."],[9321,9597,"Someone needs to fix this now."],[9701,9784,"Dani, Dani,"],[9855,9980,"if that dress splits any more,"],[9980,10160,"this will be a major PR nightmare."],[10160,10281,"I know you can do it."],[10339,10439,"So, please,"],[10439,10573,"can you go ahead and fix the dress?"],[10694,10856,"Why would I be able to help?"],[10856,11052,"I mean, Brynn's the one that"],[11052,11148,"designed the dress."]],"50":[[20,200,"Did you fall and smack your"],[200,367,"little head on the sidewalk?"],[400,550,"Dani is a nepo baby"],[550,704,"intern who knows nothing."],[704,1001,"And Brynn is the creative genius."],[1001,1117,"Remember? Yes. Yes."],[1117,1188,"Right?"],[1209,1280,"Right."],[1280,1568,"I. I totally know what I'm doing."],[1680,1814,"Dani is just a frumpy"],[1814,1931,"little service worker"],[1931,2127,"who wants to play dress up."],[2627,2690,"Thanks, Dani."],[2690,2861,"I knew you were useless."],[2861,3040,"Thank God Brynn's here."],[3082,3224,"I can do this."],[3224,3395,"How hard can it be to fix"],[3395,3566,"a one of a kind couture gown?"],[3849,4033,"I put my heart and soul into a dress"],[4033,4149,"Soleia would be proud to wear"],[4149,4266,"at the Met Gala."],[4266,4475,"And you built your couture house"],[4475,4537,"from the ground up"],[4537,4683,"and made so many sacrifices"],[4683,4796,"to hire me."],[5038,5221,"I can't let Brynn ruin it all."],[5296,5451,"I have to show Soleia what I can do."],[5601,5759,"So go show them who you are."],[5876,6031,"Prove to Soleia that you are the genius"],[6031,6160,"behind that dress."],[6740,6815,"Brynn,"],[6865,6956,"the seams are delicate,"],[6956,7057,"the stitch has to be"],[7057,7194,"Shut up! You're ruining"],[7194,7328,"her concentration."],[7328,7461,"Umm, aren't you the girl who was,"],[7461,7620,"like, banned from the Met Gala"],[7620,7686,"for life?"],[7741,7845,"Yeah. She is."],[7845,8012,"She shouldn't even be here right now."],[8058,8191,"I shouldn't be here?"],[8191,8312,"Look at the way Brynn's holding"],[8312,8400,"that needle."],[8437,8533,"How much longer can you"],[8533,8600,"keep up this act?"],[8600,8725,"Just step aside and let me"],[9088,9125,"Okay."],[9125,9309,"Somebody has to call Hanna Summer."],[9309,9455,"The chair of the gala will know how to handle this dirty little party crasher."],[9455,9622,"to handle this dirty little party crasher."]],"51":[[112,225,"What now?"],[225,383,"We have a security situation."],[383,579,"Party crasher on the gala floor."],[579,796,"Someone named Dani Maxwell."],[875,1163,"Dani? Anya's star designer?"],[1463,1593,"I'm fine."],[1593,1860,"I am not some delicate little flower."],[1860,2160,"I had a heart attack, not a lobotomy."],[2356,2573,"Hanna, darling!"],[2786,2965,"Anya, I just got word that"],[2965,3107,"Dani Maxwell has been"],[3107,3207,"banned from the gala."],[3253,3386,"Your daughter is trying to get her"],[3386,3461,"kicked out."],[3465,3561,"What?"],[3670,3878,"I said I've got it."],[4012,4108,"Fine."],[4108,4245,"If that's the way you want it to be."],[4746,4796,"See?"],[4875,5084,"As the true genius behind this dress"],[5121,5180,"I fixed it."],[5234,5422,"Good as new."],[5576,5734,"Shout out to my hella talented"],[5734,5889,"designer, Brynn Maxwell of"],[5889,5993,"Anya Winter couture for"],[5993,6106,"dressing me tonight."],[6172,6352,"Thanks to her, I swerved a"],[6352,6519,"full on wardrobe malfunction."]],"52":[[8,204,"All of my hard work"],[204,392,"ruined by Brynn's ego."],[738,871,"You know, it takes a profound lack"],[871,942,"of talent"],[942,1130,"to destroy a gown so beautiful."],[1534,1622,"Yeah what kind of shoddy"],[1622,1722,"repair job was that?"],[1722,1901,"That girl is so not worthy of dressing"],[1901,1985,"Soleia."],[2056,2160,"Yes I am."],[2256,2402,"I'm suing Anya Winters"],[2402,2556,"for all your brand is worth."],[2602,2748,"This is all your fault."],[2773,2882,"My fault?"],[2982,3136,"I was trying to help."],[3136,3269,"I was trying to take your mom's little"],[3269,3407,"washed up brand and make it"],[3407,3574,"relevant by dressing the hottest,"],[3574,3745,"most famous woman in the world."],[3799,3987,"How dare you call my mother's brand"],[3987,4054,"washed up?"],[4054,4183,"You're got to pay for that."],[4183,4416,"How? Are you going to fire me like you"],[4416,4521,"fired Dani?"],[4688,4829,"When all those loser designers"],[4829,4921,"got let go,"],[4921,5071,"I replaced the staff with my"],[5071,5155,"own people."],[5155,5326,"If I go, they go."],[5430,5634,"How will Anya Winters keep its title"],[5634,5830,"as number one couture house"],[5830,5947,"without a design staff?"],[6056,6260,"You won't keep your spot number one"],[6260,6356,"as long as you have a fraud"],[6356,6448,"like Brynn"],[6448,6627,"as your creative director, either."],[6886,7015,"Dude, that girl is"],[7015,7161,"totally crashing out right now."],[7211,7353,"I'm calling my lawyers."],[7374,7649,"Brynn, this is all your fault."],[7649,7703,"Okay!"],[7703,7836,"If you guys all want someone to"],[7836,7920,"blame for this,"],[7920,8045,"why don't you blame Dani, okay?"],[8045,8237,"I didn't even make that stupid dress."],[8262,8312,"She did!"]],"53":[[454,704,"I didn't I didn't I didn't mean."],[800,938,"I think it's finally time to show them"],[938,1009,"who you really are."],[1134,1284,"Brynn's right."],[1284,1405,"I designed the dress"],[1526,1710,"and I'll prove it."],[2560,2773,"Soleia, will you meet me on stage?"],[2823,2894,"Don't."],[3003,3132,"You shouldn't trust that"],[3132,3249,"ugly, lying bitch."],[3249,3395,"I mean, look at her."],[3395,3495,"She's gonna drag down your"],[3495,3603,"whole image."],[3628,3791,"Image means nothing"],[3791,3887,"without substance,"],[3966,4058,"without talent."],[4137,4233,"A true fashion genius"],[4233,4312,"should know that."],[4416,4491,"Damn."],[4542,4629,"That's deep."],[4692,4771,"I agree."],[4821,4950,"I'm pretty sure you're the one"],[4950,5030,"I shouldn't trust."]],"54":[[287,442,"Dani Maxwell,"],[442,563,"you're a genius."],[938,1084,"I have never seen something"],[1084,1155,"so stunning."],[1176,1368,"I need her to dress me like that."],[1376,1447,"Wait."],[1534,1672,"This means that I fumbled a super"],[1672,1835,"talented baddie?"],[1889,2035,"Oh, fuck."],[2097,2306,"It's everything I've ever wanted."],[2352,2489,"You saved this night."],[2752,2852,"Holy cow."],[2965,3098,"This is the most beautiful collection"],[3098,3190,"I have ever seen."],[3269,3399,"You're a visionary."],[3440,3566,"And this time,"],[3645,3803,"everyone knows it."],[3816,3941,"Soleia!"],[3941,4062,"Who are you wearing?"],[4133,4270,"I'm wearing."],[4346,4466,"Dani Maxwell."],[4742,4917,"for Claude Saint-Jean Couture"],[4984,5171,"Oh, it can't be."],[5217,5380,"Dani's the superstar designer"],[5380,5488,"that I fired?"],[5488,5630,"This is what I've been trying"],[5630,5718,"to tell you."],[5718,5914,"Dani is a fashion icon."]],"55":[[91,300,"You. You were never"],[300,454,"the fashion prodigy of my mother's"],[454,546,"couture brand."],[650,834,"You were the brain dead nepo baby"],[834,1001,"idiot she warned me about!"],[1001,1121,"What is that"],[1121,1355,"strung out deadbeat intern"],[1355,1584,"doing at the fucking Met Gala?"],[1643,1826,"I thought you fired her."],[1860,2006,"I didn't fire her."],[2006,2081,"Umm..."],[2081,2218,"I actually promoted her"],[2218,2331,"to creative director."],[2356,2581,"You promoted this deadbeat,"],[2581,2690,"and you fired"],[2690,2848,"my star designer?"],[3111,3228,"Yeah, I did."],[3340,3486,"Do you know how hard I've worked?"],[3486,3661,"Do you know how much money"],[3661,3770,"I spent"],[3770,3928,"to get Dani Maxwell"],[3928,4070,"in my fashion house?"],[4137,4487,"She is the life blood of this brand."],[4521,4637,"And what did you do?"],[4729,4896,"You fired her."],[5105,5405,"So it was that Maxwell all along."],[5422,5572,"Vanessa."],[5572,5668,"You're fired."],[5668,5851,"No, Mom, please. Please, you can't I."],[5893,5960,"I, I need..."],[5960,6131,"I'm embarrassed to even call you"],[6131,6206,"my daughter."],[6235,6406,"When I turned this over to you,"],[6418,6656,"my fashion house dominated the"],[6656,6810,"entire world of couture."],[6810,6906,"And now look at it."],[6906,7040,"It's a laughingstock."],[7115,7211,"And you."],[7323,7428,"You did this."],[7490,7682,"I'm really sorry."],[7724,7895,"Shit, man, I fucked up."],[7895,8149,"Oh, no, I fucked up so bad."]],"56":[[20,312,"Hanna is the chair of the Met Gala,"],[312,542,"and she personally banned Dani."],[571,746,"You would not want a fashion outcast"],[746,875,"on your team, now, would you?"],[980,1184,"You have some nerve"],[1184,1509,"telling me what I did or didn't do."],[1564,1885,"You duped us all into thinking you're"],[1885,2022,"a fashion icon."],[2039,2210,"When you're nothing more than a"],[2210,2473,"dirty scammer in a designer dress."],[2677,2977,"Dani Maxwell is officially granted"],[2977,3215,"a lifetime invitation to the Met Gala."],[3349,3461,"But you"],[3536,3707,"are banned forever."],[3762,3937,"And you're fired, too."],[3937,4045,"Security!"],[4058,4254,"No, no no. Please! Take her away."],[4254,4366,"Hand over to the cops."],[4366,4575,"She needs to pay for her crimes"],[4575,4683,"against fashion."],[4725,4971,"No! Please! Ah!"],[5055,5150,"Dani,"],[5217,5401,"please come back to work for me."],[5472,5668,"You know how much I have"],[5668,5772,"done for you."],[5843,6031,"My fashion house can't survive"],[6031,6081,"without you."],[6081,6202,"I am begging you."]],"57":[[16,171,"Everything you gave me"],[171,266,"I gave it all back"],[266,421,"when your daughter accused me"],[421,521,"of sabotaging the thing"],[521,759,"I put my heart and soul into creating."],[771,917,"Oh. She's exaggerating."],[917,1017,"That's not what happened."],[1017,1117,"It was Brynn."],[1117,1276,"She was scheming to try to steal"],[1276,1434,"Dani's job the whole time."],[1530,1622,"That bitch duped me"],[1622,1772,"and got me all confused."],[1772,1922,"Seriously?"],[1922,2018,"Well, that confusion"],[2018,2135,"almost cost me my"],[2135,2239,"whole fashion career"],[2239,2381,"and everything I've worked for."],[2448,2565,"Did it feel good?"],[2565,2698,"Making me take the fall for your"],[2698,2798,"stupid mistakes?"],[2898,3032,"Dani, look,"],[3032,3236,"I'm so sorry."],[3282,3407,"I'm sorry, too."],[3532,3636,"I'm not coming back"],[3636,3787,"to Anya Winter Couture."],[3841,3978,"I'm staying where I know"],[3978,4091,"I'm appreciated."],[4091,4270,"Where no one's ever questioned"],[4270,4525,"my talent, my vision, my style."],[4567,4804,"So please step aside."],[5276,5397,"This is our moment."]],"58":[[75,204,"And we at Claude Saint-Jean Couture"],[204,396,"wish you nothing but the best, Anya."],[1134,1251,"You ruined it."],[1272,1572,"You have ruined everything I've built."],[1647,1718,"Okay."],[2047,2193,"Oh, wow."],[2193,2318,"Really going at you like a bunch of"],[2318,2423,"savages, aren't they?"],[2423,2573,"Oh, yes."],[2573,2769,"I'm sorry. Are you crying?"],[2769,2986,"Mm. God."],[2986,3161,"You're hot."],[3161,3257,"Have you ever wanted to be"],[3257,3407,"the face of a menswear line?"],[3457,3578,"Hell, yeah."],[3803,3912,"You better not show up"],[3912,4041,"at the office tomorrow."],[4104,4283,"I never should have hired you."],[4562,4692,"Oh, no."],[4692,4813,"I need a job."],[4813,4871,"Vanessa."],[4871,4934,"Vanessa."],[5167,5334,"Too hot to be on these streets."],[5855,5989,"Call me."],[6001,6302,"Dani, why did I ever leave you?"],[6435,6514,"We have to take some"],[6514,6631,"red carpet pics together."],[6631,6810,"I need all 900 million of my"],[6810,6969,"followers to know exactly who"],[6969,7052,"made my dress tonight."],[7119,7203,"Give me five minutes."]],"59":[[1447,1630,"I knew you'd take back your crown."],[1630,1885,"Thank you for believing in me."],[1885,2052,"I always have."],[2052,2198,"And I always will."],[3349,3457,"Congratulations."],[3653,3766,"You made it to the top."],[3891,4054,"And that's where I'll stay."]]}