the"],[7878,7999,"biggest night in fashion?"],[8162,8320,"You must be psychotic."],[8320,8408,"Really?"],[8408,8575,"And what's the word for stealing"],[8575,8704,"another designer's work"],[8704,8821,"and using it for clout?"]],"46":[[342,533,"Claude."],[629,725,"Did you come here to"],[725,1046,"fall at my feet and beg me for a job"],[1046,1326,"now that my fashion house officially"],[1326,1530,"has the Met Gala partnership"],[1530,1601,"and yours?"],[1714,1931,"Yours is dead in the water."],[1989,2135,"I'll bet you regret hiring that"],[2135,2248,"sneaky little weasel"],[2248,2339,"now, don't you?"],[2369,2494,"Not as much as you're going to"],[2494,2669,"regret putting your daughter in charge."],[2677,2781,"Excuse me?"],[3023,3115,"Look."],[3328,3603,"I know you and I haven't always seen"],[3603,3682,"eye to eye,"],[3908,4024,"But I need you to come to that"],[4024,4149,"Met Gala with me."],[4354,4496,"There's something you should see."]],"47":[[50,145,"Bitch!"],[145,367,"My star designer worked her fingers"],[367,467,"to the bone to make"],[467,558,"that dress for Soleia."],[575,767,"Don't you dare try to take credit"],[767,905,"for her creative genius."],[1272,1388,"Very soft."],[1388,1543,"But if she worked her fingers"],[1543,1655,"to the bone, then"],[1655,1743,"where are the calluses?"],[1797,1997,"How dare you assault me?"],[2047,2248,"Leave now."],[2323,2427,"Or what?"],[2456,2640,"So entitled."],[2640,2786,"You know, you should be grateful"],[2786,2936,"to my mother for even allowing you"],[2936,3098,"to step foot into her historic"],[3098,3228,"couture house."],[3253,3415,"I never said I wasn't."],[3415,3616,"Your mother is one of the best"],[3616,3716,"designers in the world"],[3716,3903,"and she took a chance on me."],[3903,4066,"I've always been grateful to her."],[4175,4283,"Grateful?"],[4283,4421,"You've tarnished her name"],[4421,4571,"and reputation, and now you're"],[4571,4729,"trying to sabotage the biggest night"],[4729,4884,"in the history o