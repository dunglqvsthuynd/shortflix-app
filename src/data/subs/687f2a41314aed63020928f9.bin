{"1":[[379,588,"They can't find the delivery anywhere."],[588,713,"The entire Anya Winter"],[713,863,"Spring collection is missing"],[863,1030,"hours before the Paris runway show."],[1030,1113,"I can't get the courier"],[1113,1201,"on the phone."],[1201,1334,"This is a nightmare!"],[1334,1409,"Bad news."],[1409,1555,"The delivery truck lost control."],[1780,2052,"30 couture gowns destroyed."],[2052,2227,"We're gonna have to cancel the show."],[2227,2293,"No, that's not happening."],[2293,2552,"This is Anya's biggest collection"],[2552,2665,"ever, okay?"],[2665,2811,"She worked on it for years."],[2811,2923,"And if she comes back"],[2923,3069,"and we have nothing to show,"],[3069,3174,"we're all dead."],[3190,3319,"What other designer besides"],[3319,3457,"Anya can make an entire"],[3457,3624,"couture collection in just hours?"],[3799,3962,"Don't worry, guys."],[4004,4149,"I can handle it."],[4149,4346,"Didn't you graduate college like"],[4346,4441,"yesterday?"],[4441,4558,"She def looks like she's pulled"],[4558,4683,"an all nighter in a library."],[4683,4796,"there's no way some intern"],[4796,4892,"who grabs coffee"],[4892,5034,"and schedules Anya's lunches"],[5034,5113,"can design a whole"],[5113,5221,"couture collection overnight."],[5221,5363,"Guys, there's no time to argue."],[5363,5572,"The show is in five hours."],[5572,5663,"What are we gonna do?"],[5780,5901,"Give me that."],[6535,6627,"And this."],[6952,7057,"What is she doing?"],[7457,7611,"She's not even using a pattern."],[7611,7732,"I've never seen someone"],[7732,7857,"bead so quickly."],[7857,7974,"Invisible stitching."],[7974,8204,"It's immaculate."],[8333,8466,"There you have it."],[8466,8754,"A gown fit for the Anya Winter"],[8754,8917,"Spring couture collection."]],"2":[[0,300,"This is impossible."],[354,454,"I thought you were just some"],[454,742,"delusional intern, but this dress."],[742,905,"Most designers could only dream of"],[905,1059,"making something so stunning."],[1109,1184,"This is going to launch"],[1184,1297,"a million dupes."],[1317,1426,"But none of them are going to"],[1426,1551,"come close to the real thing."],[1551,1685,"I heard Anya recently hired"],[1685,1818,"a fashion school prodigy"],[1818,1993,"who designed the iconic closing look"],[1993,2139,"in the fall collection."],[2218,2352,"Is that you?"],[2452,2740,"No, no, it still isn't right."],[2740,2840,"Oh."],[3403,3457,"Um"],[3545,3599,"Miss Winter,"],[3599,3716,"I'm here to..."],[3787,3933,"I'm here for the fall internship."],[3949,4083,"It's Anya."],[4175,4358,"Why would I have time to interview"],[4358,4437,"some useless"],[4437,4558,"errand-running baby,"],[4575,4725,"when the fall couture show is in"],[4725,4854,"two days and I haven't finished"],[4854,4942,"my final look."],[5013,5105,"May I?"],[5105,5205,"Sure."],[6089,6214,"So sorry that I"],[6214,6281,"ripped the fabric"],[6281,6377,"and destroyed the flowers."],[6377,6535,"Sacrifices do need to be made"],[6535,6681,"in the interest of good design."],[6781,6956,"Not everybody knows that."],[7019,7248,"An entire team of couture legends"],[7248,7386,"and nobody could come up with"],[7386,7615,"something this inspired."],[7691,7870,"Forget about the internship."],[7870,8170,"You are going to be my head designer."],[8254,8408,"There's no time to explain."],[8408,8562,"We need 29 more gowns to make"],[8562,8662,"before the show."],[8662,8787,"It's three in the morning."],[8787,8896,"Where are we going to find the fabric"],[8896,9025,"for 29 dresses?"],[9025,9209,"Take those crystals off the chandelier."],[9209,9334,"And someone cut 20 yards of"],[9334,9480,"silk velvet from the curtains"],[9580,9722,"and rip the fringe from the carpet"],[9751,9880,"and the leather from the couch cushions."],[9989,10143,"And I need flowers, STAT!"],[10439,10568,"But we're gonna destroy this place."],[10568,10744,"Sacrifices must be made"],[10744,10902,"in the interest of good design."],[10990,11123,"Anya will understand."]],"3":[[4,104,"Holy cow."],[216,354,"This is the most beautiful collection"],[354,454,"I have ever seen."],[454,542,"You're a visionary."],[542,717,"Now let's kill this fashion show."],[2072,2206,"I'm speechless."],[2252,2444,"I've never seen anything like this."],[2444,2610,"This is a stunning new direction"],[2610,2694,"for Anya."],[2694,2819,"Dior, who?"],[2819,2944,"Anya Winters is number one"],[2944,3098,"in the couture game now."],[4087,4233,"You all head back to the studio."],[4233,4325,"I'll grab some champagne"],[4325,4396,"to celebrate."],[4658,4792,"I can't believe Dani completed"],[4792,4963,"this entire collection overnight."],[4963,5092,"Where did she even come from?"],[5092,5238,"No clue, but her mind..."],[5238,5409,"it's fucking insane."],[5880,6101,"What the hell is going on here?"],[6101,6239,"This is disgusting."],[6322,6456,"Is this a design studio"],[6456,6644,"or the girls bathroom of a club?"],[6644,6765,"We make groundbreaking"],[6765,6936,"pieces with our hands,"],[6936,7094,"not our big fat mouths."],[7094,7240,"Jordan, who is this woman?"],[7240,7319,"Is she working with you"],[7319,7390,"on the PR team?"],[7407,7503,"PR?"],[7520,7661,"This woman"],[7686,7828,"is the daughter of Anya Winter."],[7907,8124,"Vanessa got her degree from"],[8124,8320,"Central St. Martins in London"],[8320,8546,"and is currently an editor for Vogue."],[8646,8850,"And she'll be acting as CEO while"],[8850,9021,"Anya recovers from a minor"],[9021,9125,"heart attack."],[9125,9292,"Is this really the design team"],[9292,9492,"that created the top couture collection"],[9492,9647,"at all of Paris Fashion Week?"],[9647,9809,"Because all I'm seeing is a bunch of"],[9809,9972,"incompetent yappers."],[9972,10151,"If this is about the original collection"],[10151,10452,"I didn't ask you to speak."],[10452,10543,"You're fired."],[10589,10735,"Pack up your bags and go back to"],[10735,10865,"bum fuck Ohio."],[11019,11161,"Thank you."],[11202,11353,"Anya Winter is now the top"],[11353,11582,"couture collection in the entire world."],[11582,11882,"Time to separate the fashion icons"],[11882,11995,"from the frauds."]],"4":[[8,87,"You think my mother's"],[87,179,"a hard ass?"],[179,275,"Just you wait."],[275,525,"I expect only the most original,"],[525,696,"exciting sketches,"],[696,875,"lightning fast designs"],[875,1126,"and perfect technicality"],[1126,1267,"and no unnecessary"],[1267,1376,"distractions."],[1405,1514,"Who does she think she is,"],[1514,1630,"Miranda Priestly?"],[1630,1839,"Oh, my God."],[2218,2394,"What is this?"],[2394,2540,"Stitching is disgusting"],[2540,2694,"and the fabric is worn."],[3032,3219,"No, that was the first thing"],[3219,3370,"my mom and I sewed together."],[3703,3799,"Well,"],[3799,3916,"you should have done a better job"],[3916,4074,"reinforcing your seams."],[4074,4208,"Jordan,"],[4208,4396,"be a doll and go get her a..."],[4450,4604,"souvenir Eiffel Tower keychain"],[4604,4796,"as a thank you for her hard work."],[4796,4888,"Oh, yeah, and by the way."],[4909,4988,"You're fired."],[5380,5543,"Okay."],[5543,5705,"Now, please, can somebody"],[5705,5826,"show me something?"],[5826,5930,"A collection?"],[6006,6139,"Congratulations!"],[6410,6519,"Who are you?"],[6519,6656,"You..."],[6656,6781,"you're the one who destroyed"],[6781,6890,"my mother's studio."],[6994,7086,"You're fired."]],"5":[[58,250,"Wait. You're firing me?"],[250,487,"Dani Maxwell."],[487,600,"Jordan,"],[600,771,"what does this lumpy little girl"],[771,867,"do here?"],[867,996,"Dani Maxwell is actually"],[996,1126,"one of our top interns."],[1126,1255,"She's an intern."],[1393,1576,"So what, you decided that"],[1576,1685,"you could take advantage of"],[1685,1785,"my mother's showroom"],[1785,1893,"to throw a rager"],[1910,2047,"the night before the biggest"],[2047,2160,"couture show in the"],[2160,2302,"history of this house?"],[2310,2460,"That's not what we..."],[2460,2652,"I would say take out the damages"],[2652,2773,"from your salary,"],[2836,3053,"but you're probably not getting paid."],[3053,3136,"Actually, she's our"],[3136,3236,"highest paid employee."],[3236,3465,"She's making over $500,000 a year."],[3465,3528,"Jordan!"],[3599,3766,"That's... That's confidential."],[3766,4016,"So you're scamming my mother?"],[4016,4175,"You know, she might be getting old"],[4175,4341,"but she's not an idiot."],[4346,4441,"And what?"],[4508,4662,"This is how you spend the money?"],[4662,4758,"No, no."],[4758,4959,"Look, the team was up all night working."],[4959,5084,"Our hands are cramping."],[5084,5167,"We're tired, but..."],[5230,5388,"we saved the spring show."],[5451,5722,"Don't we deserve to celebrate?"],[5739,5868,"Celebrate?"],[5968,6239,"By destroying a studio,"],[6272,6377,"lying,"],[6377,6631,"talking back to your superiors,"],[6631,6802,"drinking on the job?"],[6802,6877,"No wonder my mother"],[6877,6969,"had a heart attack."],[7082,7257,"Our PR team is supposed to"],[7257,7344,"be able to handle these"],[7344,7474,"types of liabilities."],[7511,7657,"Unless, of course, you're just as"],[7657,7807,"useless as she is."],[7807,7978,"Or do you actually care"],[7978,8128,"about this brand's legacy?"],[8158,8287,"Jordan and I have been dating"],[8287,8400,"for two years."],[8445,8666,"He knows how hard I work."],[8666,8771,"There's no way he's going to"],[8771,8896,"throw me under the bus."],[8896,9042,"Dani's my girlfriend,"],[9042,9163,"but if I take her side, I'll be"],[9163,9321,"committing career suicide."],[9388,9542,"You're right."],[9542,9772,"Dani's behavior is unacceptable"],[9772,9980,"in the House of Anya Winter."],[9980,10135,"Jordan, seriously?"],[10135,10427,"What are you still doing here, intern?"],[10468,10681,"Pack up your shit and get out of here."]],"6":[[8,120,"If that's how it's going to be."],[120,279,"This isn't Dani's fault."],[279,387,"She's the one who saved..."],[387,696,"Oh. Do you want to go with her?"],[821,1080,"If anyone else here helped Dani"],[1080,1338,"destroy this studio, please feel free to"],[1338,1426,"speak up now."],[1426,1551,"It's okay, guys."],[1551,1722,"Anya Winter is the top couture house"],[1722,1814,"in the world now"],[1814,2043,"and you've all earned your spots."],[2043,2193,"It was my fault."],[2498,2594,"I'm leaving."],[2919,3044,"How could you?"],[3390,3490,"I'll be back."],[3599,3899,"Dispose of that piece of shit."],[4049,4304,"Baby, I'm so sorry."],[4446,4512,"We've been together"],[4512,4562,"for two years."],[4562,4658,"You couldn't even defend me?"],[4658,4733,"She would have fired me"],[4733,4825,"on the spot."],[5000,5109,"Look,"],[5109,5238,"we both know that I"],[5238,5384,"don't have a degree,"],[5384,5551,"and it's a miracle"],[5551,5684,"that you got me this job."],[5759,5951,"And if I lose it, then..."],[6118,6272,"Then who's going to pay for all the"],[6272,6368,"expensive champagne that"],[6368,6452,"we're going to have at our"],[6452,6589,"anniversary dinner tonight."],[6710,6861,"Well, you better spring for"],[6861,7011,"caviar, too."],[7040,7349,"You owe me big time, Jordan."],[7407,7707,"I promise I'm gonna make it up to you."],[7741,7916,"Let's meet tonight at eight."],[7916,8028,"Okay?"],[8028,8141,"Let's have a"],[8141,8345,"magical last night in Paris."],[8345,8483,"I'll see you then."],[9050,9205,"Your frumpy little girlfriend"],[9205,9430,"is a recipe for bad press."],[9430,9676,"So are those other big mouth bitches."],[9801,9972,"Not a good look for the PR manager."],[9972,10114,"Dani's not my..."],[10114,10335,"She better not be."],[10560,10652,"You're hot, you know?"],[10798,10902,"My mother wants to start"],[10902,11069,"a menswear line."],[11069,11365,"You could be the PR director."],[11365,11453,"What do you prefer?"],[11453,11640,"An unemployed fashion flop,"],[11665,11966,"or a rich, powerful boss?"]],"7":[[204,308,"Say it."],[375,454,"Mommy."],[454,583,"What else?"],[646,734,"Goo goo ga ga."],[734,838,"What else?"],[900,1117,"Does baby need a change?"],[1117,1247,"Baby needs a change."],[1267,1393,"Yeah you do."],[1393,1480,"Stinky."],[1505,1647,"Stinky so bad."],[1735,1822,"Yes, mother?"],[2302,2444,"Stupid people."],[2444,2560,"They want to keep me here for"],[2560,2677,"two more weeks."],[3224,3345,"I need you to run things"],[3345,3436,"a little while longer."],[3436,3561,"I have stylists"],[3561,3724,"breathing down my neck after that"],[3724,3945,"marvel of a couture show."],[3945,4108,"I mean, I don't know how Maxwell"],[4108,4183,"pulled it off."],[4183,4458,"Thank God we have her on the team."],[4458,4758,"I know how you can be, Vanessa."],[4829,5130,"You better treat her right."],[5217,5467,"Maxwell? Oh, God."],[5467,5668,"Is that the frumpy intern I just fired?"],[5668,5768,"Hello?"],[5768,5905,"I'm speaking to you."],[5905,6097,"Yes, mother. One second."],[6243,6335,"Is there any other"],[6335,6477,"Maxwell on the design team?"],[6477,6552,"Anya must have sent me a"],[6552,6702,"staff list at some point."],[6702,6827,"Uh. Okay."],[6911,6977,"Idiot."],[7069,7211,"She single-handedly"],[7211,7361,"saved my last two shows,"],[7361,7511,"a creative genius."],[7540,7753,"I mean, I snatched her up"],[7753,7912,"right out of college to make sure"],[7912,8024,"those other couture houses"],[8024,8158,"couldn't get their hands on her."],[8158,8237,"Without her,"],[8512,8604,"this..."],[8637,8983,"This whole house will crumble."]],"8":[[0,133,"Don't worry, mother,"],[133,279,"I'll treat her like a queen."],[279,433,"You better."],[433,713,"And there's another Maxwell."],[713,884,"What is her name?"],[884,1105,"Anyway, she is a fucking disaster."],[1105,1355,"A brain dead nepo baby intern"],[1355,1476,"who never shows up."],[1476,1714,"And when she does, she's useless."],[1868,1985,"Do me a favor."],[1985,2097,"Fire her."],[2143,2277,"Thank god."],[2277,2435,"Of course that tasteless tornado"],[2435,2656,"I fired was just a pointless intern."],[2698,2948,"Don't worry mother, I already handled it"],[2948,3057,"Thank you."],[3299,3449,"I'll come check on things"],[3449,3678,"the second they discharge me"],[3678,3799,"from this hellhole."],[3812,4070,"Rest up and I'll take care of everything."],[4362,4642,"I knew that girlfriend of yours was a loser."],[4738,4913,"Now, where were we?"],[5484,5689,"What the hell do you want?"],[5689,5797,"The studio phone's"],[5797,5910,"been ringing off the hook."],[5910,6056,"Well, who is it?"],[6056,6218,"It's Soleia's team."],[6218,6318,"Soleia?"],[6318,6439,"As in the most famous"],[6439,6548,"actress in the world?"],[6548,6731,"She needs a dress for the Met Gala."],[6731,6956,"She wants to see sketches for five looks"],[6956,7107,"inspired by the new collection"],[7223,7332,"in one hour."],[7549,7716,"Well, let's hope"],[7716,7845,"Maxwell can pull this off."]],"9":[[83,266,"Where is Brynn Maxwell?"],[487,588,"Jordan."],[588,746,"Get Brynn on the phone and tell her nicely to get her ass here. Now"],[746,950,"nicely to get her ass here"],[950,1001,"now."],[1768,1851,"What happened?"],[1851,1985,"I thought everyone would hate me for"],[1985,2127,"causing the crash that destroyed"],[2127,2210,"the whole collection."],[2210,2268,"But..."],[2331,2510,"Guess they've got bigger problems."],[2698,2911,"Dani, that frumpy dumbass."],[2990,3161,"She left her old sketch portfolio."],[3240,3420,"Oh my god, these are iconic!"],[3499,3661,"No wonder Anya was obsessed with her."],[3941,4041,"I rolled up hungover"],[4041,4270,"five hours late after almost"],[4270,4441,"ruining the Paris fashion show."],[4558,4708,"I'm definitely getting fired."],[4775,4854,"Where are you?"],[4854,4963,"We need five sketches"],[4963,5096,"to send to Soleia's team"],[5096,5251,"for her Met Gala look, ASAP."],[5267,5467,"Miss Winter said if you pull this off,"],[5467,5655,"you'll be on fast track to becoming"],[5668,5876,"creative director."],[5876,5947,"Be right there."],[6197,6331,"Why would they ask me,"],[6331,6485,"a brand new intern, to dress"],[6485,6656,"the most famous woman in the world."],[6731,6840,"Whatever."],[6840,7011,"I'll use Dani's sketches"],[7011,7140,"and no one will know."],[7173,7444,"Oh my gosh. I'm going to be a star."]],"10":[[0,91,"Well?"],[91,246,"Brynn's handling it."],[246,350,"Nice work."],[442,592,"Man, dressing Soleia..."],[592,817,"That's, like, so sick."],[817,1001,"I know."],[1001,1163,"This partnership will take this brand"],[1163,1301,"to a whole new level."],[1413,1530,"And as acting CEO"],[1530,1651,"of this fashion house,"],[1651,1851,"I'll be invited to the best parties"],[1851,2027,"with the most rich and famous people."],[2143,2389,"And you could be my date."],[2389,2481,"Unless, of course,"],[2481,2690,"you want to go with Dani."],[3028,3123,"Where is Jordan?"],[3123,3257,"He's 20 minutes late."],[3449,3595,"I don't want her."],[3595,3699,"I was going to"],[3699,3807,"break up with her tonight anyway."],[3807,3858,"I..."],[3916,4045,"I want you."],[4170,4220,"Duh."],[4308,4433,"Good choice."],[4675,4833,"Guess I'll have to drag him here myself."],[5005,5184,"Gosh, you're so powerful."],[5184,5351,"So sexy."],[6160,6289,"It's our anniversary and you're"],[6289,6477,"fucking the woman who fired me?"],[6777,7002,"She is a fashion superstar, okay?"],[7002,7048,"And you're just"],[7211,7357,"an unemployed loser."],[7357,7553,"You spineless dick."]],"11":[[0,100,"You psycho bitch"],[100,254,"are you out of your fucking mind?"],[254,400,"That's it, you cheating piece of"],[446,575,"Dani, Dani, you are"],[575,746,"embarrassing yourself."],[746,938,"I'm the embarrassment?"],[938,1051,"Three hours ago,"],[1051,1230,"you were begging for my forgiveness."],[1230,1317,"And now you're shoving you"],[1317,1472,"tongue down your new boss's throat?"],[1647,1743,"Know your place,"],[1743,2043,"you tacky, talentless slut."],[2102,2402,"Face it, Dani, you're a failure."],[2402,2656,"And you can't get mad at me for"],[2656,2736,"upgrading."],[3082,3215,"I loved you, Jordan,"],[3319,3436,"and the only reason you're here"],[3436,3574,"is because of that."],[3574,3753,"Because I told Anya to make you"],[3753,3853,"PR manager."],[3853,3970,"Are you kidding me?"],[4012,4216,"More ridiculous lies."],[4216,4304,"You?"],[4304,4454,"You're a deadbeat intern."],[4454,4646,"As if my mother would have"],[4646,4754,"anything to do with you."],[4917,4992,"We"],[5075,5146,"are"],[5205,5263,"over."],[5351,5388,"Dani."]],"12":[[166,300,"I'm calling security."],[300,354,"Why don't you call"],[354,467,"your mother instead?"],[467,654,"The founder of this house."],[700,829,"She'll tell you that you're making"],[829,1013,"a huge mistake."],[1013,1088,"You know what, enough with the"],[1088,1180,"bullshit, Dani."],[1188,1276,"It's cringe."],[1292,1426,"Is this how you got your job here,"],[1426,1643,"by spewing insane lies?"],[1659,1776,"Hi security."],[1776,1926,"Yes. There's a delusional"],[1926,2097,"ex-employee who's refusing"],[2097,2198,"to leave my studio."],[2277,2344,"Thank you."],[2515,2706,"Aw, Dani, don't be sad."],[2706,2819,"Look, I get it."],[2877,3140,"I'm powerful, smart,"],[3207,3432,"experienced."],[3461,3570,"And you?"],[3632,3862,"Well you're jobless, talentless"],[3924,3987,"and irrelevant."],[4066,4366,"Look, if I were you, I would go on home"],[4366,4521,"and drown your sorrows in a bottle"],[4521,4667,"of cheap champagne."],[4683,4813,"Unless, of course, you'd rather spend"],[4813,4971,"your last night in Paris in a jail cell."],[4971,5067,"Fine."],[5217,5347,"I'm done here anyway."],[5710,5951,"And where do you think you're going, Dani?"],[5951,6135,"Guards! She's over here."]],"13":[[0,158,"Who the hell are you?"],[158,296,"I'm the creative mastermind behind"],[296,462,"the new spring couture collection."],[483,679,"Brynn Maxwell."],[709,1001,"Oh, wow. Well."],[1001,1109,"I can see when my mother"],[1109,1222,"sung your praises."],[1351,1651,"Oh, is that an archival Soleia bag?"],[1710,1931,"Well, you obviously have impeccable"],[1931,2010,"taste."],[2027,2181,"It's no wonder you created such a"],[2181,2327,"groundbreaking collection."],[2327,2481,"These dumbasses don't even know"],[2481,2656,"that I'm totally jacking Dani's glory."],[2690,2786,"Who cares?"],[2786,2915,"As long as Anya's daughter"],[2915,3040,"thinks I'm a genius,"],[3040,3203,"I'll get promoted to creative director"],[3203,3340,"without lifting a finger."],[3424,3674,"Vanessa, I know who's responsible"],[3674,3853,"for destroying Ayna's first"],[3853,3974,"spring collection."],[4079,4233,"She's the one that made the routing"],[4233,4379,"error that caused a truck to crash."],[4421,4542,"She's obviously trying to"],[4542,4683,"sabotage the brand."],[4683,4763,"What?"],[5472,5576,"Dani's done it again."],[5684,5809,"You know that one design school prodigy."],[5809,5930,"prodigy you've had your eye on,"],[5968,6047,"Dani Maxwell?"],[6097,6218,"She was just fired from"],[6218,6398,"Anya Winter's fashion house."],[6398,6548,"But the show was a hit. How is that possible?"],[6548,6719,"Apparently Anya's daughter Vanessa"],[6719,6802,"forced her out."],[6840,6911,"Of course."],[7086,7186,"Well I'd love to see the look on"],[7186,7361,"Anya Winter's face when she discovers"],[7361,7507,"her big headed bimbo of a daughter fired."],[7507,7645,"fired her star designer."],[7774,7853,"Call Dani up,"],[7853,7932,"let's get her here."],[7932,8078,"But Anya Winters is the number one"],[8078,8208,"fashion house in the world."],[8208,8362,"We're not even ranked top ten."],[8362,8495,"Dior and Chanel are probably"],[8495,8625,"banging down Dani's door already."],[8679,8804,"You really think she would work for us?"],[8804,8867,"I'll do anything"],[8867,8963,"to get Dani on this team."],[9054,9196,"Rumor has it Soleia's looking for"],[9196,9409,"a new designer for her Met Gala look."],[9467,9547,"And if we can dress"],[9547,9676,"the most famous woman on the"],[9676,9776,"planet on the biggest night"],[9776,9847,"in fashion,"],[9934,10051,"we'll be the new brand on top."],[10306,10377,"Get the jet ready."],[10377,10477,"I'm going to Paris."],[10581,10660,"And I'm not leaving"],[10660,10823,"without Dani Maxwell."]],"14":[[4,208,"Sabotage? Are you kidding me?"],[208,371,"You can take the fall for my"],[371,513,"stupid mistake, Dani."],[563,717,"Who will believe you over me?"],[717,834,"You were out partying all night"],[834,880,"when you should have been"],[880,1059,"confirming the route with the courier."],[1059,1255,"And you destroyed my mother's studio"],[1255,1393,"on your drunken bender."],[1418,1572,"You all see me as some incompetent"],[1572,1722,"intern just because I'm not wearing"],[1722,1922,"the latest off the runway clothes."],[1943,2064,"Maybe daddy's black card can"],[2064,2160,"buy you Celine."],[2160,2306,"But can it buy you talent too?"],[2394,2665,"You think I caused that disaster?"],[2665,2923,"You think she is your savior?"],[2923,3044,"Well, then, best of luck when Anya"],[3044,3169,"comes back and sees what a"],[3169,3253,"mess you've made."],[3274,3495,"This is your mess, Dani Maxwell."],[3566,3695,"I literally cannot stand another"],[3695,3899,"second of your desperate B.S."],[4004,4091,"Don't touch me!"],[4195,4337,"Jordan, don't let them do this."],[4337,4479,"We both know you're not capable"],[4479,4583,"of handling the outcome."],[4583,4804,"First you threaten Brynn,"],[4804,4900,"and then you threaten me."],[5009,5146,"You know, you shouldn't be such a"],[5146,5267,"bitter bitch, Dani."],[5351,5543,"You know, jealousy looks hideous"],[5543,5609,"on you."],[5609,5755,"So why don't you go ahead and"],[5755,5918,"pick up your mistakes"],[5918,6035,"and get the fuck out"],[6106,6247,"before you get locked up?"],[6281,6418,"What can they even arrest me for?"],[6439,6519,"Let's see."],[6556,6844,"Vandalism, insubordination,"],[6844,6927,"and that sweater"],[6927,7119,"is definitely a crime against fashion."],[7119,7203,"Don't you know that"],[7203,7332,"I can end your entire"],[7332,7499,"fashion career with one phone call"],[7499,7545,"to my mother?"],[7565,7661,"Then go ahead."],[7770,7832,"Do it."]],"15":[[0,221,"If Vanessa calls Anya, she'll find out"],[221,387,"that Dani's the real star designer."],[487,613,"Vanessa."],[613,767,"Your mom's in recovery."],[767,938,"Shouldn't you go to the Fashion Council"],[938,1067,"first instead?"],[1084,1163,"To make sure another"],[1163,1334,"fashion house isn't infected with"],[1334,1476,"Dani's terrible taste."],[1484,1555,"Brynn's right."],[1555,1726,"You should go right to the source."],[1726,1881,"Do not let her get away with this."],[2043,2168,"I have all my mother's"],[2168,2389,"industry contacts at my fingertips."],[2389,2598,"I'm texting the Fashion Council now."],[2598,2894,"Dani Maxwell is blacklisted"],[2894,3003,"from Anya Winter."],[3028,3232,"Other designers beware"],[3232,3440,"of this dangerous scammer."],[3524,3687,"No other fashion house will want you now."],[3687,3828,"Good luck getting a part time job"],[3828,3933,"at Forever 21."],[4041,4233,"Guess that's that then."],[4233,4425,"But before I go,"],[4425,4625,"I have one question for you, Vanessa."],[4625,4884,"Does Anya, the CEO and"],[4884,5013,"creator of this fashion house"],[5013,5184,"know that you fired me?"],[5184,5305,"What kind of idiot"],[5305,5472,"do you think I am, Dani?"],[5472,5613,"My mother practically begged"],[5613,5789,"me to fire your incompetent ass."],[5814,5955,"You thought you could roll up here"],[5955,6085,"in your bargain bin sweater"],[6085,6264,"and call yourself a fashion icon?"],[6493,6664,"Your career is so over."],[6664,6777,"Okay. Security."],[6777,6898,"Can you take her away and"],[6898,7032,"throw her to something?"],[7032,7178,"Jail cell, police, whatever."],[7332,7532,"Get your hands off of her!"],[7795,8016,"That is my new creative director."]],"16":[[0,187,"Dani Maxwell"],[187,312,"will join Claude Saint-Jean"],[312,396,"fashion house."],[421,554,"Claude Saint-Jean"],[554,675,"of Saint-Jean Couture?"],[692,796,"You came all the way from New York"],[796,875,"for me?"],[875,975,"Of course."],[1084,1205,"I flew straight here."],[1438,1572,"Nice to see you again, Dani."],[1626,1722,"I haven't seen you since"],[1722,1851,"I interned at Valentino"],[1851,1951,"my freshman year."],[1951,2285,"Wait, you went to Valentino with him?"],[2481,2652,"How'd you get that job, Dani?"],[2652,2865,"You scam your way into that one too?"],[2969,3103,"God, Dani."],[3103,3253,"When we went outt, I had no idea that"],[3253,3457,"you were such a grifter."],[3616,3845,"I feel so, so used."],[3916,4062,"So this is how Anya Winter treats"],[4062,4283,"their most talented designers?"],[4283,4421,"You know, I can't say I'm surprised"],[4421,4558,"with someone like you working here."],[4558,4633,"Claude. I"],[4633,4804,"That is Mr. Saint-Jean to you."],[4804,4925,"And actually, this matter concerns"],[4925,5100,"those with actual design talent."],[5196,5321,"Yeah, what are you, a mid-level"],[5321,5455,"PR pawn?"],[5455,5530,"Should probably know when to"],[5530,5659,"shut the hell up."],[5659,5797,"Mr. Saint-Jean,"],[5797,6051,"Dani here has done irreparable damage,"],[6051,6093,"and it's"],[6093,6197,"Sorry, who the hell are you?"],[6197,6314,"Obviously, I-"],[6314,6381,"Right."],[6381,6506,"I don't have time for your rambling."],[6506,6619,"Enough."],[6619,6819,"This idiot destroyed"],[6819,6940,"my mother's collection,"],[6940,7190,"wrecked her entire Paris fashion studio,"],[7190,7382,"ruined the entire couture show,"],[7382,7540,"almost lost us millions."],[7540,7749,"And why are we still talking about her?"],[7749,7870,"Did you not ask your mother who"],[7870,8049,"Dani was before you fired her?"]],"17":[[0,312,"What kind of idiot do you think I am?"],[337,525,"My mother runs this fashion house"],[525,658,"with an iron fist."],[675,796,"Of course I consulted her."],[796,917,"And you know what she said?"],[971,1205,"She said that this idiot Dani is a"],[1205,1384,"nepo baby intern who scammed"],[1384,1530,"her way into the job."],[1601,1710,"Brain dead."],[1768,1931,"Anya actually said this?"],[1931,2064,"And a useless disaster."],[2064,2264,"She quite literally said to me,"],[2264,2489,"do me a favor and fire this bitch."],[2527,2681,"Anya practically begged me to"],[2681,2815,"work for her."],[2815,2932,"She wouldn't walk back on a"],[2932,3040,"decision like that."],[3040,3199,"Okay, we all know Anya, okay?"],[3199,3382,"And she wouldn't beg anyone"],[3382,3499,"for anything."],[3507,3636,"Especially to work with"],[3636,3807,"a dead weight intern."],[3816,3941,"Then why are you still here?"],[3991,4091,"Why you little..."],[4091,4191,"Oh, don't even try it."],[4341,4383,"Dani."],[4533,4646,"Will you come with me and be my new"],[4646,4796,"creative director of Saint-Jean Couture?"],[4821,4909,"Claude, I don't know..."],[4909,5038,"Hey, whatever you are making,"],[5038,5125,"I will double it."],[5138,5180,"Okay."],[5180,5372,"Her salary is 500 K."],[5372,5572,"She's literally robbing us blind."],[5655,5755,"A million it is then."]],"18":[[29,250,"Please. $1 million salary?"],[250,421,"Your fashion house doesn't even rank"],[421,538,"in the top ten."],[538,696,"Are you clinically insane?"],[767,955,"You're an even bigger bullshitter"],[955,1067,"than Dani."],[1142,1438,"$1 million for a talentless intern."],[1514,1735,"Way to dig your own grave."],[1735,1906,"I thought I told you to shut up."],[2031,2193,"Cause I really appreciate what"],[2193,2352,"you're trying to do. Seriously."],[2352,2569,"But it's not about the money."],[2627,2711,"Dani."],[2769,2923,"If you joined my fashion house,"],[2923,3111,"the title of creative director will be yours."],[3153,3265,"Creative control over the next"],[3265,3378,"season's couture collection"],[3378,3474,"will be yours."],[3520,3695,"My designers, my studio."],[3695,3807,"My full trust."],[3991,4079,"And hell, if you want me,"],[4079,4158,"I'm even yours, too."]],"19":[[0,208,"Oh, Claude."],[208,358,"Okay, look, I get it."],[358,513,"You hustled from the bottom to"],[513,658,"build your own fashion brand."],[679,855,"And I respect you for that."],[855,1009,"So let me remind you"],[1009,1297,"that Dani is a lazy scam artist."],[1317,1522,"Even my mother says hiring her"],[1522,1651,"is a literal death wish."],[1664,1789,"In that case."],[2339,2460,"Okay, okay."],[2460,2610,"What is all this shit?"],[2610,2748,"This shit is everything that your"],[2748,2886,"mother gifted me."],[2886,3011,"Her one and only key"],[3011,3153,"to her personal studio,"],[3153,3324,"the business black card in my name,"],[3324,3424,"which I could have used to repair"],[3424,3516,"the damages, but"],[3595,3778,"I guess that's not my concern anymore."],[3874,4066,"You can tell Anya that I,"],[4104,4312,"Dani Maxwell, am more than happy"],[4312,4483,"to walk away from this fashion house"],[4483,4562,"and never,"],[4646,4854,"ever come back."],[4854,4925,"Aww."],[4988,5134,"So sad for us."],[5209,5309,"Not."],[5330,5509,"You did not deserve any special"],[5509,5613,"treatment, Dani."],[5613,5768,"I mean, just look at you."],[5768,5922,"You're a complete fashion flop."],[6031,6189,"You know, you're all so wrapped up in"],[6189,6293,"beauty standards and bullshit"],[6293,6431,"that you can't even see the design"],[6431,6594,"talent that is right in front of you."],[6831,6961,"Dani, it is true."],[7044,7173,"We have been struggling to beat out"],[7173,7328,"Anya Winter for the number one title spot."],[7328,7511,"Then I'm going to change that."],[7511,7691,"I'll join as creative director."],[7786,7937,"And by this time"],[7937,8158,"next season's runway show,"],[8158,8354,"Saint-Jean Couture will be number one."]],"20":[[0,100,"You know, I almost feel"],[100,250,"embarrassed for you, Dani."],[250,433,"Losing your spot at the number one"],[433,621,"fashion house to go and work for this"],[700,930,"desperate up and comer."],[1005,1284,"Although, who else would hire you?"],[1284,1472,"Embarrassed for her?"],[1472,1564,"You know, Vanessa's going to"],[1564,1664,"burn this place to the ground,"],[1664,1881,"and you are going to be left with this"],[1881,2018,"PR shitstorm to clean up."],[2056,2302,"And something tells me..."],[2302,2406,"that you're not qualified for that, are Qualified?"],[2406,2444,"are you?"],[2444,2494,"Qualified?"],[2494,2581,"And what exactly are you"],[2581,2731,"qualified for?"],[2731,2961,"Propositioning idiotic interns"],[3015,3103,"to go out and peddle out"],[3103,3324,"your hideous designs"],[3324,3461,"to some micro-influencers?"],[3570,3616,"What?"],[4045,4108,"I did."],[4346,4446,"She did?"],[4642,4746,"She will."],[4850,4946,"Who was that?"],[4946,5188,"That was Soleia's team."],[5188,5317,"They've asked for five sketches"],[5317,5463,"from Dani for her Met Gala look."],[5488,5647,"What was that about micro"],[5647,5789,"influencers?"],[5834,6043,"If I'm not mistaken, she has"],[6043,6210,"more followers than"],[6210,6348,"anyone in the world?"],[6364,6485,"Absolutely not."],[6485,6631,"Brynn is supposed to design"],[6631,6735,"Soleia's gown."],[6735,6806,"Brynn?"],[7011,7119,"Guess we got ourselves some"],[7119,7207,"competition."],[7207,7353,"This isn't a competition."],[7353,7582,"It's an all out fashion war."],[7582,7711,"Well, I hope you're ready to die on"],[7711,7795,"the battlefield."],[7862,7920,"Let's go, Dani."],[7920,8012,"Gladly."],[8028,8191,"I'm losing brain cells talking"],[8191,8329,"to these people."],[8412,8537,"May the best designer win."]],"21":[[16,208,"Don't worry about her, Vanessa."],[208,396,"Just send these to Soleia's team"],[396,504,"and there's no way"],[504,658,"she won't pick us."],[855,1101,"I'll beat Dani with her own designs."],[1101,1255,"Oh my God, Brynn,"],[1255,1401,"these are incredible."],[1480,1589,"Between these and"],[1589,1718,"the Spring couture collection,"],[1814,1960,"you've really proven yourself."],[2068,2264,"I'm officially naming you as"],[2264,2394,"creative director"],[2394,2565,"of Anya Winter Couture."],[2581,2736,"This is a dream come true."],[2836,2927,"Thank you."],[3086,3315,"And don't forget about me."],[3315,3528,"The new face of the menswear line."],[3749,3870,"Right."],[3870,4045,"One step at a time."],[4045,4200,"Stick with me and you'll be"],[4200,4358,"very satisfied."],[4554,4717,"Every designer will be gunning for"],[4717,4925,"our spot as top couture collection"],[4925,5063,"in the world."],[5063,5296,"That's why we need to dress Soleia"],[5296,5409,"at the Met Gala."],[5409,5597,"Then no one can touch us."],[5651,5897,"Not even Claude in that hack Dani."],[5897,6060,"I won't let you down, Vanessa."],[6093,6335,"Now, walk me through how you"],[6335,6460,"designed the couture collection"],[6460,6539,"in four hours."],[6594,6673,"How did I do it?"],[6994,7065,"Oh, God."],[7065,7232,"I can't design for crap."],[7232,7461,"I have no idea how Dani pulled that off."],[7461,7582,"What the hell am I going to tell her?"]],"22":[[12,300,"I used a highly specialized"],[300,425,"sewing technique that I learned"],[425,658,"in my final year of fashion school."],[750,880,"The details are really boring."],[880,1042,"I could show you later."],[1042,1142,"Of course."],[1142,1267,"You have your own technique."],[1267,1468,"You are the creative genius."],[1468,1580,"I mean, these are already"],[1580,1705,"Met Gala worthy."],[1705,1860,"If you can bring them to life half as"],[1860,2006,"well as you did the spring collection,"],[2064,2177,"You have nothing to worry about."],[2177,2314,"Nothing at all."],[2402,2615,"I am now the creative director"],[2615,2752,"of the number one fashion house"],[2752,2852,"in the world."],[2932,3090,"Step aside, Dani."],[3090,3253,"I'm the new couture queen now."],[3545,3787,"What do you want?"],[3787,3908,"Anya!"],[3908,4033,"It's Claude Saint-Jean."],[4033,4187,"Listen, I'm just calling to let you know"],[4187,4337,"that we are officially in the running"],[4337,4487,"to dress Soleia at the Met Gala."],[4612,4675,"What?"]],"23":[[0,262,"We are the number one couture house"],[262,362,"in the world right now."],[383,521,"Why would she want you"],[521,684,"to dress her as if some young,"],[684,846,"arrogant, dumbass could?"],[846,921,"Listen, I'm not"],[921,1009,"calling to discuss this."],[1009,1172,"I'm just simply letting you know."],[1547,1651,"Cheers."],[1810,2110,"What the hell is that rat up to?"],[2143,2360,"He knows I have a design prodigy"],[2360,2481,"at my right hand."],[2548,2840,"Why would he think anybody could beat"],[2840,3053,"a superstar like Dani?"],[3382,3553,"Unless..."],[3749,3941,"Mother, you'll never believe the"],[3941,4041,"sketches I got from"],[4041,4320,"Tell me you didn't fire my"],[4320,4562,"most talented designer."]],"24":[[45,233,"Calm down, mother, or else"],[233,346,"you'll have another heart attack."],[358,487,"Like I told you already."],[487,788,"I fired that brain dead slacker intern."],[800,1109,"Why the hell is Claude Saint-Jean"],[1109,1247,"competing with us for the"],[1247,1372,"Met Gala partnership?"],[1380,1651,"Well, I just figured it was pointless to"],[1651,1739,"talk him out of it when he's"],[1739,1914,"obviously going to crash and burn"],[1914,2077,"along with that talentless intern."],[2139,2248,"They'll design something"],[2248,2452,"cheap and tacky for Soleia,"],[2510,2673,"and then she'll tell everybody she"],[2673,2865,"she knows not to touch Saint-Jean"],[2865,3078,"Couture with a ten foot pole."],[3165,3303,"And then their sad,"],[3303,3445,"little fashion careers..."],[3445,3549,"They'll be over before they"],[3549,3641,"even started."],[3641,3999,"So you gaslit Claude"],[3999,4166,"into hiring our cast off?"],[4183,4295,"Sure did."],[4295,4454,"He's convinced that the talentless"],[4454,4654,"nepo baby is the creative genius"],[4654,4788,"behind our spring line."],[4800,4888,"That's brilliant."],[5113,5205,"And I thought you were a"],[5205,5422,"weak little pushover like your father,"],[5422,5467,"but..."],[5563,5805,"Maybe you're more like me than I knew."],[5805,6139,"Vanessa, I want you to take full control"],[6139,6289,"over the Met Gala partnership"],[6289,6439,"with Soleia."],[6464,6577,"Thank you."],[6577,6886,"No more talking. It's time to get to work."],[6886,7107,"And we need to make damn sure"],[7107,7319,"Soleia picks our gown for the gala."],[7378,7545,"We are going to make"],[7545,7757,"Claude Saint-Jean the laughing"],[7757,7949,"stock of the fashion industry."],[8241,8412,"Everyone's buzzing about this Met Gala"],[8412,8512,"partnership."],[8512,8658,"Vanessa has never run a fashion"],[8658,8779,"house before."],[8779,8917,"Are you sure she can handle this?"],[8917,9088,"Did I ask your opinion?"],[9200,9409,"My daughter can't fuck this up."],[9409,9659,"Not with Dani Maxwell designing"],[9659,9805,"the gown for Soleia."],[9855,10093,"Did I tell you that she actually"],[10093,10364,"convinced Claude Saint-Jean"],[10364,10614,"to hire our strung out, sad sack"],[10614,10685,"of an intern?"],[10727,11031,"I get to sit back and watch Dani"],[11031,11282,"work her magic for Soleia's gown."],[11323,11624,"While that hack of a talent"],[11644,11886,"completely tanks what's left of"],[11886,12062,"Claude's fashion house."]],"25":[[546,846,"So how does our studio compare"],[846,1034,"to the great Anya Winter’s?"],[1251,1326,"It's insane what"],[1326,1476,"you've accomplished."],[1476,1593,"I mean, four years ago, you were a"],[1593,1776,"glorified errand boy at Valentino, and"],[1847,1960,"now, look at you."],[2006,2139,"Your own couture line?"],[2243,2485,"It's everything you ever wanted."],[2485,2594,"Not everything."],[2802,2890,"Well, what about you, Dani?"],[2890,3032,"I mean, when I met you,"],[3032,3144,"you were a quiet little intern"],[3144,3411,"and now you're a fashion genius."],[3474,3557,"No. I'm serious."],[3557,3687,"I mean, that work you did"],[3687,3778,"on that spring collection."],[3778,3941,"It was... It was inspiring."],[4608,4692,"Yes."],[4963,5017,"Of course."],[5196,5276,"We'll be there."],[5480,5668,"Soleia loved your Met Gala sketches."],[5751,5843,"She chose her favorite from"],[5843,5922,"you and Brynn and she wants"],[5922,6051,"you both to show her a sample."],[6160,6310,"Oh, my God, when?"],[6464,6602,"Tomorrow afternoon?"],[6602,6790,"You have 24 hours to make this dress"],[6790,6881,"for Soleia."],[6881,6977,"Better get started."]],"26":[[12,91,"I mean, we just got back from"],[91,187,"New York, and I-"],[187,392,"You created an entire couture"],[392,571,"collection in, what, four hours?"],[671,784,"This should be a breeze, right?"],[784,875,"Right."],[875,1088,"I can totally pull this off."],[1088,1247,"Then do it."],[1247,1297,"Now."],[1639,1726,"You think you can pull off"],[1726,1876,"creating a Met Gala gown for triple"],[1876,2027,"A-list celeb in under 24 hours?"],[2043,2181,"Who do you think you're talking to?"],[2210,2410,"Well, whatever it is,"],[2410,2540,"it just needs to be better than this."],[2585,2723,"This is our competition."],[2798,2965,"That's my sketch."],[3174,3265,"That fraud Brynn's been"],[3265,3374,"stealing my designs."]],"27":[[200,316,"Of course."],[358,483,"She has no real talent of her own."],[946,1046,"Damn."],[1046,1247,"That dress is insane. I mean..."],[1288,1505,"A skirt made of stained glass?"],[1609,1714,"Insane is right."],[1714,1864,"It's going to be nearly impossible to"],[1864,1993,"sew a bodice that could support the"],[1993,2152,"weight of the skirt."],[2152,2385,"If Soleia puts on this gown, it's a"],[2385,2473,"wardrobe malfunction"],[2473,2569,"waiting to happen."],[2569,2806,"Brynn wants to be a fashion icon so bad."],[2919,3065,"How will she pull this off?"],[3065,3257,"Then it's an easy win, right?"],[3278,3411,"We just sit back and let the thieves"],[3411,3532,"crash and burn."],[3532,3674,"Not exactly."],[3782,3920,"I'm going to make the same exact"],[3920,4012,"dress."],[4012,4116,"Only better."],[4183,4308,"Then there'll be no question who the"],[4308,4446,"real designer is."],[4504,4583,"But I thought you said it was"],[4583,4717,"impossible to pull off."],[4909,5159,"I said nearly impossible."],[5538,5743,"Brynn can try to rip off my designs"],[5743,5989,"all she wants, but without the brains"],[5989,6231,"or skills to back it up, there’s no way"],[6231,6343,"she’s going to pull it off."],[6381,6502,"And if she tries,"],[6523,6735,"that gown is gonna fall apart faster"],[6735,6931,"than you can say fashion victim."],[7057,7123,"Madame."],[7261,7419,"Let's remember this day,"],[7419,7628,"the last day that Claude Saint-Jean"],[7628,7799,"Couture will be at the bottom of the"],[7799,7907,"fashion food chain."],[8074,8241,"By this time tomorrow,"],[8299,8437,"we'll be the new rulers of the"],[8437,8516,"couture kingdom."]],"28":[[33,187,"What the hell is this?"],[200,329,"Why can't you guys attach the top of the"],[329,500,"dress to the bottom of the dress?"],[700,892,"Brynn, the skirt is too heavy."],[892,1021,"No excuses!"],[1021,1188,"We have four hours to make"],[1188,1267,"a dress for Soleia."],[2010,2160,"Gosh, I wish I was getting trashed"],[2160,2239,"at a club right now."],[2239,2310,"Brynn!"],[2423,2615,"How's everything going? Great."],[2615,2827,"I just dropped my scissors."],[2827,3073,"We're putting on the finishing touches."],[3140,3240,"Phone call."],[3315,3503,"I need an update on the Met Gala."],[3541,3582,"Now."],[3582,3720,"Don't worry, mother."],[3720,3903,"I have everything under control."],[3903,4095,"That clown Claude and the fraud"],[4095,4237,"designer are going down."],[4358,4471,"Done."],[4471,4662,"You're killing it, Vanessa."],[4662,4909,"Your mother raised an amazing woman."],[5155,5305,"Keep it up."],[5305,5442,"There might be another promotion"],[5442,5563,"in your future."],[5947,6135,"If I can pull this off,"],[6135,6373,"I’ll go down in fashion history."],[6373,6506,"Who’s the braindead nepo"],[6506,6623,"baby now?"],[8066,8170,"Dani."],[8237,8312,"Dani."],[8395,8470,"Wake up."],[8529,8612,"Come on."],[8666,8729,"Come on."],[8800,8833,"Hey."],[8933,9042,"Let's get you to bed."]],"29":[[1096,1284,"Good morning, superstar."],[2460,2610,"This is it."],[2610,2819,"The gown that can make or break me."],[3553,3670,"You should be proud, Dani."],[3874,4008,"It's exceptional."],[4091,4204,"Just like you."],[4283,4396,"Thanks, I..."],[4679,4833,"I couldn't have done it without you."],[5397,5534,"Oh, God."],[5534,5643,"I need to change what I'm wearing"],[5643,5743,"to meet the most famous woman"],[5743,5809,"in the world."],[5809,5939,"Don't worry about it."],[6047,6172,"I had my editor friend Marco"],[6172,6285,"pull some things from the Vogue"],[6285,6381,"closet for you."],[6548,6656,"Pick anything you like."],[7378,7532,"See you at the meeting."],[8383,8579,"Gosh, this is a freaking disaster."],[8641,8833,"What am I going to do?"],[8833,8963,"Brynn."],[9442,9588,"That better be the best dress"],[9588,9693,"you've ever made."],[9809,9855,"Let's go."]],"30":[[233,408,"Ready to retire early, Claude?"],[454,538,"We're going to get that"],[538,646,"Met Gala partnership."],[688,817,"In your dreams, Vanessa."],[817,1042,"Where is your top secret weapon?"],[1042,1159,"She'll be here soon."],[1159,1292,"She'll make a big impression"],[1292,1405,"on Soleia."],[1405,1672,"Did she bother to iron out the lumps"],[1672,1810,"in today's big baggy sweater?"],[1835,1997,"I'm sure the most fashionable woman"],[1997,2164,"in the world will absolutely love"],[2164,2310,"her Walmart chic style."],[2318,2494,"Her talent speaks for itself."],[2494,2727,"Yeah, and it also says that she's a"],[2727,2794,"desperate,"],[2802,2998,"frumpy loser."],[3153,3345,"I just have to find a way to switch mine"],[3345,3449,"and Dani's garment bags"],[3449,3561,"when no one's looking."],[3561,3753,"It's not like Soleia would even trust"],[3753,3962,"that unstylish little piece of"]],"31":[[446,517,"Dani."],[692,754,"You look stunning."],[796,859,"Thanks."],[1151,1238,"Speechless."],[1297,1401,"Is that a first?"],[1438,1534,"Are those the"],[1534,1659,"one of a kind Anya Winter"],[1659,1739,"fall couture boots?"],[1876,2010,"Yes, I am."],[2093,2243,"Okay, but why would"],[2243,2323,"my mother give you those?"],[2323,2464,"She wouldn't even let me near them."],[2477,2698,"They were a gift for designing her final"],[2698,2823,"look in her fall collection."],[2840,2990,"What kind of delulu"],[2990,3169,"reality are you living in?"],[3169,3353,"Look, I always knew you were a lazy,"],[3353,3457,"deadbeat intern,"],[3457,3570,"but taking credit"],[3570,3724,"for another designer's work?"],[3724,3899,"That's a whole new low."],[3899,3978,"Taking credit for"],[3978,4141,"another designer's work..."],[4216,4396,"Brynn, you know a thing or two"],[4396,4466,"about that."],[4521,4617,"Watch it, you"],[4617,4738,"Careful now."],[4813,4971,"You think you're some design"],[4971,5096,"prodigy, Dani."],[5180,5251,"This."],[5280,5330,"Give me that."],[5355,5622,"This is what the work of a genuine"],[5622,5776,"fashion superstar looks like."],[5864,6010,"If Vanessa opens the bag,"],[6010,6143,"everyone's going to see that I'm a"],[6143,6227,"total fraud."]],"32":[[20,166,"Soleia will see you now."],[225,400,"Designers only."],[400,529,"For security reasons, the rest of"],[529,667,"you will have to wait in the lobby."],[913,975,"Hey,"],[1134,1213,"you've got this."],[1263,1355,"There's no way she's not going to"],[1355,1443,"pick you."],[1835,2014,"Everything is riding on this"],[2014,2135,"Met Gala partnership."],[2143,2293,"Don't fuck it up."],[2339,2473,"I won't let you down."],[2715,2882,"Soleia is expecting you in the studio"],[2882,2986,"in 15 minutes."],[3023,3144,"You two can prep your gowns"],[3144,3261,"and your models over here."],[3261,3532,"Just don't touch anything."],[3787,3883,"The dress you made, it's"],[3941,4162,"Is that an original Brynn Maxwell"],[4162,4254,"design, or..."],[4350,4433,"Is it stolen?"]],"33":[[16,166,"I don't know what you're talking about."],[166,412,"You mean you didn't steal"],[412,658,"my portfolio and pass off"],[658,804,"my sketches as yours so"],[804,938,"you could dress the most famous"],[938,1088,"woman in the world for the Met Gala?"],[1088,1201,"Tell me, Brynn,"],[1201,1447,"have you ever actually"],[1447,1551,"picked up a sewing needle?"],[1668,1764,"That dress you..."],[1843,1910,"designed..."],[1910,2164,"is beautiful, but very,"],[2264,2464,"very complicated."],[2464,2631,"How did you manage to pull that off?"],[2644,2727,"We'll just see."],[2865,2944,"Won't we?"],[2982,3073,"Yes. We will."],[3966,4166,"Oh, my gown is hideous."],[4166,4354,"If I don't do something fast,"],[4354,4446,"everyone's going to find out"],[4446,4617,"that I'm a total fraud."],[6051,6206,"I've just gotten a taste of"],[6206,6302,"fashion fame"],[6302,6489,"and I am not letting Dani the disaster"],[6489,6639,"take it from me."],[7774,7862,"Bye bye, Dani."]],"34":[[8,141,"Soleia is arriving now."],[141,233,"No photos."],[233,500,"No sucking up and no touching"],[500,575,"unless she touches you."],[604,675,"Got it?"],[675,775,"Got it."],[1593,1826,"Soleia, this is Brynn Maxwell."],[1826,2031,"It's so nice to meet you."],[2031,2152,"Where's the other one?"],[2152,2360,"She must be running a little bit late."],[2360,2577,"I hate people who waste my time."],[2577,2811,"I think she saw my gown and she felt"],[2811,2890,"inadequate."],[2932,3057,"Let's see it then."],[4879,5088,"Brynn knocked me out and stole"],[5088,5196,"my dress."],[5259,5434,"I knew she was a snake, but"],[5434,5647,"I didn’t realize she was psychotic."],[5905,6106,"The sample preview is starting now and"],[6177,6331,"I have nothing to show."],[6886,7044,"Or maybe..."],[7044,7182,"I do."],[7415,7540,"I present to you"],[7540,7761,"your Met Gala look."],[8053,8162,"Sorry, fam."],[8162,8324,"It's my Pisces moon."],[8383,8516,"This is, like, the most"],[8516,8633,"transcendental piece of art I've"],[8692,8783,"ever seen."],[8812,8908,"I feel connected to it"],[8908,9125,"on like a cosmic level."],[9125,9284,"I must wear this dress."],[9284,9455,"I knew you would love it."],[9455,9622,"But what about the other designer?"],[9622,9701,"She might..."],[9701,9813,"She's late."],[9813,9951,"I'll give her three seconds."],[9951,10060,"If she doesn't show up, then"],[10060,10210,"I've made my choice."],[10210,10414,"Three, two..."],[10414,10472,"Wait."]],"35":[[0,129,"I'm so sorry I'm late."],[129,262,"Soleia. I had a little"],[346,550,"bump in the road."],[604,759,"I suppose I can forgive you."],[759,938,"Mercury is in retrograde."],[1101,1255,"Nice gown, Brynn."],[1255,1509,"I wish I could say the same, Dani, but"],[1655,1793,"yours stinks."],[1860,2127,"Gee, I wonder why that is."],[2173,2473,"This dress is so trippy."],[2489,2640,"My mind is seriously being"],[2640,2831,"opened to a new dimension right now."],[2869,3015,"Okay, but you're not, like, crying."],[3015,3278,"I mean, like mine is still better,"],[3382,3457,"right?"],[3582,3699,"I wouldn't say that."],[3724,3812,"What?"],[3903,4062,"Isn't that crazy,"],[4062,4308,"that you stole my gown and"],[4308,4416,"tried to sabotage me,"],[4416,4717,"and Soleia still likes my design better?"],[4788,4921,"How much longer can you keep up"],[4921,5021,"this charade?"],[5046,5205,"I must know,"],[5205,5347,"what was your inspiration?"],[5463,5643,"I was inspired by those times"],[5643,5885,"when someone just tries to"],[5885,6031,"knock you out and"],[6181,6327,"you get the trash and"],[6381,6506,"make it treasure"],[6506,6690,"like the phoenix"],[6690,6819,"rises from the ashes again."],[6840,7094,"Or like a rat from a dumpster."],[7173,7369,"I've always felt spiritually"],[7369,7494,"connected to the phoenix."],[7536,7803,"Dani, I feel like you really get me."],[7803,8016,"You're a true artist with a true vision."],[8049,8287,"Okay, but what about my vision?"],[8287,8462,"What about my art?"],[8516,8616,"Brynn's right."],[8717,8967,"She should also have the chance to"],[8967,9084,"explain her design."],[9146,9175,"Brynn."],[9196,9547,"Tell us, how exactly did you craft"],[9547,9822,"such a exquisite gown?"],[9968,10047,"Crap."],[10047,10306,"I have no idea how Dani made this."],[10306,10385,"What do I say?"]],"36":[[16,87,"How did I do it?"],[87,162,"Umm..."],[279,500,"You're not gatekeeping"],[500,654,"your creative process from"],[654,788,"Soleia, are you?"],[934,1126,"If you want her to wear your gown"],[1126,1234,"at the Met Gala,"],[1380,1597,"doesn't she deserve to know how"],[1597,1680,"you made it?"],[1780,1851,"It's true."],[1851,2118,"Soleia doesn't like gatekeepers."],[2160,2364,"It's a simple question, Brynn."],[2364,2540,"If you can't answer it, then, like,"],[2540,2690,"did you really even make the dress?"],[2848,3036,"I think the real question here"],[3036,3269,"is, why is Dani so desperate to know"],[3269,3378,"my design secrets?"],[3428,3474,"Clearly,"],[3474,3582,"she's trying to steal my technique"],[3582,3720,"because she knows she doesn't"],[3720,3791,"measure up."],[3878,4087,"Okay, this taped together thing is"],[4087,4208,"not fashion, okay?"],[4212,4421,"It's an elementary school art project."]],"37":[[12,246,"Soleia, you cannot wear Dani's dress."],[246,300,"I mean, look at it."],[300,479,"It's a wardrobe malfunction"],[479,600,"waiting to happen."],[613,825,"Besides, it's made out of"],[863,996,"New York street trash."],[1151,1222,"She's right."],[1222,1380,"It does kind of have, like, a..."],[1380,1522,"a fishy smell to it."],[1622,1830,"It's giving I flopped so hard"],[1830,1960,"I ended up on the streets."],[2002,2206,"Well, obviously, this is just a sample."],[2206,2323,"The real dress would not be-"],[2323,2573,"Okay, but my sample is pristine."],[2573,2740,"I mean, Soleia, you could put this dress"],[2740,2977,"on right now and walk the runway,"],[2977,3028,"but..."],[3078,3182,"Dani's?"],[3228,3395,"Dani's is probably made out of"],[3428,3732,"Disease, rat feces and..."],[3732,3820,"meat juice."],[3945,4062,"Oh, God."],[4062,4270,"You know I'm a die hard vegan."],[4446,4562,"I made my decision."],[4629,4754,"The dress I've chosen to wear"],[4754,4929,"to the Met Gala is"],[5100,5196,"Brynn's."],[5430,5597,"I can't wear street trash"],[5597,5689,"to the MET Gala."],[5689,5989,"It's too big of a risk, even for me."],[5989,6197,"Oh, I'm sorry, Dani,"],[6218,6427,"but it's easier to go back to trash when"],[6481,6669,"you are trash."],[6740,7073,"But, you know, I do like the skirt"],[7073,7194,"on the trash dress better."],[7219,7332,"Brynn, can you resew yours"],[7332,7465,"so I can see what it would look like?"],[7528,7736,"Like, like right now?"],[7774,7987,"You made this dress in 24 hours."],[7987,8124,"Surely you can fix a skirt"],[8124,8245,"for an audience."],[8245,8404,"Once Soleia sees Brynn for the"],[8404,8500,"fraud she is,"],[8500,8629,"she'll have to reconsider"],[8629,8762,"her choice."],[8762,8938,"Yeah, Brynn,"],[8938,9113,"Why don't you show us all"],[9113,9292,"exactly what you can do."],[9355,9413,"Now."]],"38":[[358,629,"I really work better alone."],[629,750,"Not today, you don't."],[750,850,"Do you want me to wear your dress"],[850,975,"to the Met Gala or not?"],[1017,1163,"This is it."],[1188,1292,"This is it."],[1405,1564,"The moment everyone sees that"],[1564,1710,"I'm a total fraud."],[1760,1989,"The moment my talents will finally"],[1989,2077,"be recognized."],[2210,2277,"Soleia,"],[2356,2510,"Hanna Summer, the editor-in-chief"],[2510,2711,"of Rogue Magazine, is here to see you."],[2711,2777,"Oh, my God."],[2777,2998,"And she's the chair of the Met Gala board."],[2998,3090,"She must have heard I'm picking"],[3090,3215,"my dress today."],[3215,3278,"Maybe they're going to do"],[3278,3370,"a feature."],[3370,3478,"Oh, my God, she's coming up here"],[3478,3578,"right now."],[4054,4141,"Wait."],[4141,4266,"You're not Hanna."],[4304,4483,"Miss Summer had to take a call"],[4483,4625,"in the car and sent me up instead."],[4625,4859,"I'm her personal assistant"],[4859,4984,"here to deliver a message"],[5084,5280,"On Anya Winter's suggestion"],[5280,5543,"and by the Fashion Council's orders,"],[5543,5776,"Dani Maxwell has been blacklisted"],[5776,6001,"from the industry and banned"],[6001,6235,"from the Met Gala for life."],[6431,6498,"Banned?"],[6498,6639,"What the hell for?"],[6639,6794,"Insubordination,"],[6794,6931,"sabotage amounting to"],[6931,7157,"millions of dollars in potential losses,"],[7215,7570,"a general lack of personal style."],[7624,7874,"These aren't just baseless lies?"],[7891,8045,"I think we all know who the real"],[8045,8220,"liar is here, Dani."],[8262,8433,"How dare you come into Soleia's"],[8433,8525,"personal studio,"],[8525,8687,"waste her precious time"],[8687,8883,"knowing you are hated by literally"],[8883,9054,"everyone in the fashion industry."],[9088,9317,"Are you trying to tank her career?"],[9396,9676,"This is so unnecessarily toxic."],[9776,9914,"This volatile energy is totally"],[9914,10060,"throwing me off."],[10060,10268,"Get her out of here now!"],[10668,10806,"Congratulations."],[10806,10919,"I can't wait to wear your gown"],[10919,11061,"to the Met Gala."],[11102,11257,"I can't wait can't wait to steal"],[11257,11403,"all of Dani's glory."]],"39":[[0,75,"Hey..."],[91,183,"Dani, what the hell?"],[254,458,"Hey, get your hands off right now!"],[667,792,"You okay?"],[892,1051,"Okay, I'd stay back if I were you."],[1071,1184,"Unless you want to get banned"],[1184,1355,"from the Met Gala for life, too."],[1363,1493,"Banned?"],[1493,1605,"By who?"],[1614,1747,"Hanna Summer, herself."],[1893,2127,"The editor-in-chief of Vogue and the"],[2127,2394,"chair of the Met Gala banned Dani?"],[2460,2590,"This is the best day of my life."],[2690,2811,"Mine too."],[2811,2915,"Vanessa."],[2965,3094,"I bow to you."],[3094,3157,"Okay."],[3336,3524,"I am the real hero here."],[3524,3762,"I mean, Soleia is wearing my gown"],[3762,3841,"to the Met Gala."],[3891,4041,"And Dani here is going to get herself"],[4041,4191,"a little job at McDonald's."],[4237,4496,"The fashion world is not going to miss you."],[4512,4708,"I've given everything"],[4708,4813,"for this fashion house."],[4833,4959,"And how do you repay me?"],[5050,5217,"By turning everyone in the industry"],[5217,5267,"against me?"],[5384,5501,"Not everyone."],[5705,5768,"Let's go, Dani."]],"40":[[304,508,"I cannot believe those idiots"],[508,650,"managed to scam the most"],[650,754,"famous woman in the world."],[842,1063,"Believe it. Look at her latest post."],[1138,1292,"Can't wait to reveal my hashtag"],[1292,1426,"Met Gala look tomorrow."],[1455,1597,"I'll be giving the designer a"],[1597,1755,"very special shout out on stage"],[1755,1968,"after my exclusive performance."],[2227,2327,"That's my dress."],[2327,2435,"That should be me on the"],[2435,2540,"Met Gala stage."],[2677,2748,"Brynn and Vanessa"],[2748,2815,"can't get away with this."],[2815,3040,"They're arrogant liars, dirty thieves,"],[3040,3115,"and they just-"],[3253,3349,"And they're everything."],[3349,3461,"that you're not."],[3595,3858,"You deserve to be on that stage."],[3858,4004,"And the Dani that I know would never"],[4004,4104,"give up on that dream."],[4308,4471,"I know what I have to do."],[4771,4917,"I'm going to sneak in to the Met Gala."]],"41":[[104,283,"Hell, yes. You are."],[337,538,"I'm sneaking into the Met Gala tomorrow."],[538,650,"I have work to do."],[650,825,"Okay, hey."],[825,950,"Let me handle that."],[967,1096,"Now let's drink."],[1096,1192,"Celebrate your rise"],[1192,1309,"back to the top."],[1714,1830,"Well it hasn't happened yet."],[2022,2118,"But it will."],[2615,2761,"You know, a whole bottle."],[2761,2907,"That's a lot for you."],[2932,3098,"Didn't they used to call you"],[3098,3228,"one cup Claude?"],[3457,3591,"You're tall but"],[3591,3724,"you're quite the lightweight."],[3782,3903,"I'm hurt, Dani."],[3995,4145,"And just so you know, I..."],[4204,4337,"can handle my alcohol much,"],[4416,4558,"much better these days."],[6026,6214,"I knew you were a lightweight."],[6214,6377,"Speak for yourself."],[6648,6790,"Let's get you to bed."],[6919,7032,"Watch the champagne."],[7082,7240,"Seriously, I'm not kidding."],[7924,8049,"Whoa. What?"],[8362,8571,"I suddenly feel very sober."],[8666,8729,"Me too."]],"42":[[959,1088,"What do you think?"],[1105,1326,"I think the stitching is immaculate."],[1380,1509,"But what's it for?"],[1597,1705,"This?"],[1801,1872,"Yeah."],[1872,2081,"This is your party crashing uniform."],[2177,2281,"Marco's going to meet you on the"],[2281,2394,"side entrance of the Gala."],[2598,2740,"I owe you both my life."],[2844,2944,"I just want to make sure my"],[2944,3128,"star designer"],[3136,3274,"gets the recognition"],[3340,3420,"that she deserves."],[3807,3920,"I'll meet you there."],[3937,4041,"Where are you going?"],[4083,4154,"I"],[4154,4295,"am breaking Anya Winter"],[4295,4400,"out of the hospital."],[4458,4629,"When she finds out that her daughter"],[4642,4783,"ran you out of her fashion house"],[4783,4942,"and sent a fraud to the biggest event"],[4942,5063,"in fashion history."],[5109,5263,"It's going to be over for her and Brynn."],[5359,5447,"Thank you"],[5584,5689,"for everything."],[6072,6189,"I'll meet you there."],[6940,7002,"Good luck."]],"43":[[20,208,"We're here at fashion's"],[208,316,"biggest night,"],[316,479,"the Met Gala,"],[479,700,"where everyone who is anyone"],[700,888,"has gathered in New York City"],[888,1284,"to celebrate the best of fashion."],[1430,1634,"Oh my God, Soleia.."],[1634,1768,"Oh, darling, how are you?"],[1768,1926,"Oh, my God, I am"],[1926,2085,"freaking out right now."],[2085,2339,"I mean, this gown!"],[2439,2719,"Anyway, best dressed of the night"],[2765,2898,"hands down."],[2977,3119,"Now tell me who made this"],[3119,3278,"incredible creation."],[3319,3457,"I'm actually not revealing"],[3457,3545,"who made it yet,"],[3545,3695,"but it'll be a big surprise"],[3695,3816,"for everyone inside."],[3816,3916,"Cryptic."],[3916,4029,"I love it."],[4029,4204,"Well, whoever made it"],[4204,4358,"is insanely talented."],[4596,4713,"You know, that spring collection"],[4713,4867,"that you did was just like,"],[4950,5105,"whoa, you know?"],[5142,5351,"Yeah, I'm kind of like,"],[5626,5776,"a genius."],[6318,6427,"Brynn got me banned from the"],[6427,6506,"Met Gala."],[6506,6639,"But I made it in."],[6669,6794,"And soon she'll be exposed"],[6794,6944,"for the fraud she is."],[6969,7169,"How did that slut get in here?"],[7203,7353,"She’s gonna ruin everything."]],"44":[[116,229,"Champagne, Brynn?"],[354,550,"You cannot be here."],[550,679,"You competed against me"],[679,796,"to dress Soleia,"],[796,1017,"the biggest celebrity at the Met Gala,"],[1017,1130,"and you lost."],[1180,1263,"Okay."],[1263,1372,"Tonight is my special night,"],[1372,1522,"and I cannot have you ruining it."],[1609,1714,"I'm the one who designed"],[1714,1810,"Soleia's dress."],[1810,1956,"I'm the guest of honor."],[2031,2243,"After all the blood, sweat and tears"],[2243,2389,"I put into making that gown,"],[2398,2573,"she stole it from me"],[2573,2669,"and dragged my name"],[2669,2731,"through the mud."],[2731,2773,"Brynn,"],[2773,2948,"why are you so obsessed with"],[2948,3103,"taking credit for my work?"],[3157,3328,"I do not have to answer you."],[3436,3532,"Face it, Dani."],[3561,3782,"I have won the respect of everyone"],[3782,3937,"who matters in the fashion industry."],[3999,4191,"I'm going to be up there next to Soleia"],[4191,4320,"on that stage,"],[4320,4487,"basking in all your glory."],[4533,4629,"And you?"],[4696,4838,"You will still be"],[4838,4904,"a no one."],[5088,5201,"You come in here dressed up"],[5201,5313,"like a servant, expecting me"],[5313,5388,"to do what?"],[5401,5538,"Fall at your feet and go,"],[5538,5672,"\"Oh, I'm so sorry, Dani."],[5672,5972,"You are so smart and so talented.\""],[6043,6189,"Never going to happen."],[6252,6473,"I'm rubbing elbows with the hottest,"],[6473,6573,"most famous people"],[6573,6681,"