{"1":[[4,112,"Congrats to the winner"],[112,352,"of Annual Technology Excellence Award,"],[352,604,"the Zxus Algorithm R&D Team!"],[604,772,"They've transformed AI"],[772,952,"from cold lines of code into partners"],[952,1244,"capable of perceiving human emotions."],[1368,1544,"It's an honor to receive this award."],[1580,1748,"Thank you to everyone who follows Zxus."],[1748,1972,"We'll continue to innovate in this field,"],[1980,2092,"making AI truly walk"],[2092,2360,"side-by-side with humanity."],[2452,2504,"Ms. Hastings,"],[2524,2660,"we're investing 100 million dollars"],[2660,2768,"for an exclusive partnership!"],[2768,2852,"We'll put up a billion!"],[2864,2972,"We'll offer more!"],[2972,3124,"Please work with us!"],[3132,3224,"Miss Hastings,"],[3224,3344,"we'll offer a billion dollars!"],[3344,3428,"Miss Hastings!"],[3500,3556,"Holy sh*t."],[3576,3752,"Miss Hastings was just a hologram earlier!"],[3752,3860,"That's insane!"],[3860,3924,"She wasn't real."],[3924,4100,"As expected of Zxus' team."],[4316,4412,"Olivia,"],[4412,4760,"everyone was fighting to license Zxus."],[4780,4996,"How could you not even show up at the ceremony?"],[5036,5176,"I'm not selling Zxus."],[5192,5336,"I don't understand."],[5376,5600,"You're Healer, the AI god of the field."],[5600,5736,"Why play second fiddle"],[5736,5876,"to that social climbing Andy?"],[5900,6116,"You slaved away developing the whole system,"],[6124,6292,"hiding it so he wouldn't feel pressured."],[6312,6424,"But does he appreciate it?"],[6432,6576,"He's concerned about the company."],[6632,6804,"As long as the IPO goes smoothly,"],[6852,6948,"I believe he'll change."],[6976,7092,"Seven years"],[7120,7264,"is long enough for that miracle to happen."],[7276,7416,"Sure, he saved your life once,"],[7424,7580,"but you've spent years being a slave to him."],[7592,7724,"You repaid that debt long ago."],[7724,7904,"Like you said, it's been seven years."],[8216,8308,"I still believe"],[8364,8496,"that even a stone heart"],[8496,8636,"will melt with love one day."],[8648,8736,"I've got things to do."],[8736,8820,"I'll be going now."],[8840,9008,"Forget it, I won't say another word."],[9172,9336,"Here's a divorce agreement."],[9340,9516,"He'll leave with nothing."],[9552,9760,"If he ever hurts you,"],[9796,9912,"just sign and you can walk away."],[10360,10448,"Andy."],[10508,10796,"I've got the formula and diapers you asked for."],[10796,10948,"Did a relative have a baby?"],[11080,11244,"Why is there a baby crying?"],[12192,12260,"Candace Lawson?"],[12348,12436,"Why are you in my house?"],[12448,12560,"My son is my ticket here."],[12584,12784,"Andy moved us in, you know."],[12812,12936,"To take care of us."],[12940,13016,"Miss Lawson,"],[13060,13208,"Andy Sinclair is a married man."],[13208,13280,"You homerecker!"],[13280,13468,"Have you no shame?"],[13640,13748,"Homewrecker?"],[13792,14080,"Andy was going to marry me in the first place!"],[14188,14416,"Candy Tech."],[14428,14720,"Who do you think 'Candy' refers to?"],[14740,14812,"Olivia,"],[14828,15152,"you're nothing but part of our foreplay."],[15152,15228,"You're lying!"],[15304,15380,"He explicitly told me"],[15380,15540,"you two broke up long ago."],[15540,15732,"Besides, you dumped him for being poor"],[15732,15852,"and abandoned him to go abroad."],[15964,16096,"Wake up."],[16116,16252,"He doesn't love you."],[16268,16404,"He only signed off"],[16428,16608,"on this marriage because of your resources."],[16628,16772,"Andy didn't want me to suffer."],[16788,17164,"So he conveniently used you to fund his career."],[17184,17328,"Now that I'm back,"],[17416,17504,"I suggest"],[17524,17676,"you move out on your own."],[17700,17792,"Shut up!"],[17792,17892,"This is my house."],[17896,17996,"You don't belong here!"]],"2":[[84,184,"Hit me, don't hurt my child."],[224,324,"My child is innocent."],[480,552,"Olivia!"],[552,632,"What the heck?"],[772,832,"Candace,"],[864,984,"are you alright?"],[1364,1448,"Olivia,"],[1476,1568,"have you lost your mind?"],[1604,1824,"You're downright vicious hurting a baby!"],[1824,1916,"Vicious?"],[1948,2052,"Andy,"],[2052,2240,"she's faking it! Can't you see that?"],[2268,2380,"Look at Candace's injuries."],[2396,2512,"How could she fake that?"],[2520,2596,"Olivia,"],[2596,2728,"where are you fake injuries, huh?"],[2740,2848,"Fine."],[2948,3240,"What right do you have to point fingers?"],[3240,3388,"You moved your love child home!"],[3392,3480,"What nonsense is that?"],[3488,3596,"What love child?"],[3604,3796,"I'm not the father of Candace's child."],[3804,4044,"She had nowhere to go after the birth,"],[4068,4164,"and I took her in."],[4172,4300,"Nowhere to go?"],[4376,4576,"What if she's not the adopted Lawson anymore?"],[4580,4728,"Her birth parents and her friends"],[4728,4816,"will take care of her."],[4816,4956,"Does she really need a married man to play"],[4956,5044,"knight in shining armor?"],[5068,5196,"We grew up together."],[5216,5404,"Do you really want me to let her go homeless?"],[5428,5512,"Olivia,"],[5568,5688,"don't blame Andy."],[5696,5864,"I asked him to pick me up."],[5876,6028,"Candace, it's not your fault."],[6108,6220,"Olivia,"],[6220,6316,"that's enough."],[6316,6392,"Do we really"],[6392,6584,"have to keep fighting over a trivial matter?"],[6660,6864,"Go make some bird's nest soup for Candace."],[6864,6976,"She just had a baby."],[6976,7052,"She's frail."],[7052,7180,"Just give her a moment of peace."],[7188,7388,"Mr. Sinclair, you've really outdone yourself."],[7400,7700,"Making your wife serve the homewrecker."],[7708,7792,"Or is it that"],[7860,8156,"I've always been a live-in maid to you?"],[8156,8320,"Stop overreacting."],[8356,8540,"You're a stay-at-home wife with time to spare."],[8552,8668,"Can't you make one soup?"],[8668,8756,"Stay-at-home wife?"],[8832,9044,"Andy, do you have a conscience?"],[9060,9296,"Back then, you asked me to join your startup,"],[9312,9400,"that's why I turned down"],[9400,9620,"offers from top international AI teams."],[9640,9780,"Later, you said"],[9780,9892,"your mother and sister"],[9892,10052,"needed care in the countryside."],[10068,10192,"And I returned to domestic life."],[10192,10272,"Enough!"],[10368,10504,"What's the point of rehashing the past?"],[10536,10692,"Since you're married to me,"],[10708,10848,"just be a good wife."],[10848,10928,"Otherwise,"],[10964,11080,"we'll get a divorce."],[11220,11324,"Why are you still here?"],[11392,11532,"Get out if you're done here."],[11540,11704,"Give Candace and the baby some space."],[11868,11988,"Olivia,"],[12048,12380,"your seven years of devotion were a joke."],[12728,13040,"How could I ever hope to melt a stone heart?"],[13040,13124,"Andy,"],[13124,13320,"the baby's biting me."],[14160,14296,"It's already dark."],[14296,14476,"Why aren't you cooking yet?"],[14484,14660,"Candace needs to eat later."],[14680,14904,"How else will my grandson get his milk?"],[15444,15672,"You knew Andy had a love child long ago,"],[15672,15824,"didn't you?"],[15852,15984,"Big deal."],[16016,16292,"You've been barren for three years."],[16296,16560,"While Miss Lawson just gave birth to our heir."],[16560,16764,"What's wrong with Andy's love affair?"],[16772,16940,"If you had any sense,"],[16940,17136,"you should take care of Miss Lawson."],[17136,17360,"It's the only way to keep your rich life."],[17368,17476,"Otherwise,"],[17476,17680,"you're out of my house!"],[17680,17892,"This house is my dowry."],[17932,18024,"Dowry?"],[18064,18240,"You're a Sinclair now."],[18240,18408,"Everything you have is ours!"],[18424,18692,"And that includes the house in your dowry!"],[18700,19036,"If Andy finds out and gets mad,"],[19036,19208,"he'll divorce you immediately!"],[19236,19316,"Don't bother."],[19384,19676,"I don't want your precious son anymore!"],[19680,19776,"You don't want him?"],[19908,20028,"Olivia,"],[20060,20444,"you've been madly in love with my son for years."],[20560,20644,"Can you really bear to leave him?"],[20688,20900,"If you divorce him now,"],[20948,21136,"don't come crawling back to him"],[21144,21396,"when his company goes public!"],[21400,21504,"In your dreams."],[21568,21728,"Go public?"],[21764,21968,"As if your son could pull that off!"],[21968,22076,"What's that supposed to mean?"],[22164,22292,"I want an explanation!"]],"3":[[52,168,"What's all the noise?"],[620,752,"Why aren't you making the soup?"],[1004,1084,"Sign it."],[1756,1888,"What are you going crazy about now?"],[1944,2076,"I'm not crazy."],[2196,2328,"I've come around."],[2364,2628,"I don't want you anymore."],[2732,2880,"Now I'm claiming"],[3000,3224,"everything that belongs to me!"],[4424,4528,"Andy."],[4596,4696,"Olivia."],[4772,4980,"Nothing happened between Andy and me."],[5004,5172,"Drop the fake act."],[5288,5420,"Using a child as leverage."],[5452,5628,"Breastfeeding to seduce a married man."],[5676,5752,"You gross me out."],[5764,5844,"What nonsense are you spouting?"],[6080,6188,"Olivia."],[6228,6356,"Can you stop making a scene?"],[6388,6532,"You're scaring the baby."],[6984,7056,"Sign it."],[7104,7204,"Fine, I'll sign."],[7288,7504,"Don't come crawling back to me for remarriage!"],[8944,9012,"Olivia!"],[9072,9144,"Olivia!"],[9184,9264,"Olivia!"],[9292,9380,"Olivia!"],[9600,9832,"Andy, these seven years,"],[9832,9996,"I've paid my life debt to you."],[10020,10148,"We're even now."],[10216,10344,"See you in court."],[11372,11436,"Son,"],[11464,11516,"is she"],[11608,11720,"really divorcing you?"],[11720,11812,"Don't worry."],[11840,11984,"She's just throwing a tantrum."],[12024,12120,"I guarantee,"],[12160,12336,"she'll beg me for forgiveness tomorrow."],[12736,12876,"Congrats on being single."],[12876,13040,"I've arranged everything."],[13064,13352,"Tomorrow, you can go through mediation."],[13352,13492,"It's the same as a divorce certificate"],[13492,13644,"and you skip the cooling-off period."],[13688,13784,"I'm swamped today,"],[13784,13916,"won't be there for you."],[18236,18308,"This male model"],[18308,18436,"is pretty hot."],[18804,18932,"You're filing for a divorce?"]],"4":[[96,168,"This male model"],[184,312,"is pretty hot."],[340,416,"You're filing for a divorce?"],[668,780,"Yeah."],[816,924,"I'm getting a divorce."],[940,1016,"Why?"],[1092,1264,"You're just a gigolo."],[1264,1388,"Are you looking down on me?"],[1448,1656,"I'm the one paying you."],[1896,2092,"In college, you confessed to me thinking I was Andy,"],[2112,2264,"and now you mistake me for a gigolo."],[2672,2932,"How should we settle this score?"],[3268,3356,"Hayden?"],[3404,3524,"What are you doing here?"],[3572,3664,"And why do you"],[3664,3780,"still hold a grudge?"],[4116,4208,"That's not all."],[4212,4364,"You wrote so many love poems for him."],[4388,4520,"I can still recite them by heart."],[4536,4612,"Stop it."],[4744,4900,"That was a mistake."],[6040,6156,"Since it was a mistake,"],[6204,6364,"let's just make it real."],[7996,8068,"Brother,"],[8072,8212,"I saw it with my own eyes."],[8240,8468,"Olivia was drinking her sorrows away over you."],[8492,8544,"Here,"],[8564,8696,"I even have photos."],[8780,8836,"Heh."],[8868,8980,"I told you so."],[8984,9132,"Olivia is obesessed with me."],[9144,9416,"But are you really going to divorce her?"],[9428,9632,"What about my graduation project?"],[9632,9764,"I'm just scaring her."],[9764,9900,"She's loved me for seven years"],[9908,10028,"She can handle a little grievance."],[10048,10320,"But Candace majored in AI abroad."],[10332,10528,"She's the one who pulled strings to help me"],[10528,10672,"secure the license for the Zxus."],[10704,10860,"She's way better than Olivia."],[10868,11104,"You should learn from her."],[11104,11188,"That's great!"],[11220,11424,"Candace is pretty and capable."],[11424,11580,"Unlike that barren hen."],[11592,11804,"But on the way out,"],[11856,12092,"it looked like a man took Olivia away."],[12112,12236,"Spiting me?"],[12376,12728,"She'll come back to me with just one call."]],"5":[[1172,1236,"Hayden."],[1556,1636,"Olivia."],[1932,2116,"Do you know how I spent those seven years?"],[3152,3236,"Focus."],[8544,8664,"You finally picked up."],[8672,8816,"Mom fainted because of you."],[8832,8912,"Get home right now!"],[8912,9068,"I'm reminding you."],[9068,9140,"Don't forget."],[9140,9320,"See you at the City Hall later."],[10400,10468,"Fine."],[10480,10612,"Let's see what your game is!"],[10648,10728,"Son,"],[10732,10852,"she sounded serious."],[10868,10984,"Is she really getting a divorce?"],[11020,11092,"Mom,"],[11092,11232,"she's just throwing a tantrum."],[11232,11328,"Even if she wanted a divorce,"],[11328,11476,"there's still a cooling-off period."],[11484,11672,"She's just asking me to the breakfast stall"],[11672,11780,"we used to visit at college."],[11804,12036,"Trying to relive our memories and beg me back."],[12096,12196,"Olivia,"],[12212,12512,"all this trouble to get a piece of paper, huh?"],[12564,12688,"Once my company goes public,"],[12700,12904,"you'll beg me for a remarriage!"],[12908,13064,"We'll see how that goes."],[13208,13320,"Without me,"],[13336,13416,"how far do you think"],[13444,13648,"Miss Lawson can take your listing dream?"],[14012,14072,"Son."],[14072,14468,"Olivia just threw all our stuff out of the house!"],[14468,14588,"You need to come home!"]],"6":[[856,1036,"Miss Hastings, you don't sleep and dip."],[1044,1128,"That's not very cool."],[1236,1508,"We're just adults with needs."],[1508,1644,"What more do you want?"],[1664,1788,"It was my first time."],[1832,1944,"You have to take responsibility."],[2004,2084,"What a coincidence."],[2108,2180,"It was mine too."],[2200,2288,"Perfect."],[2288,2408,"Let's get married."],[2480,2572,"I'm not interested in"],[2572,2816,"jumping out of the frying pan into the fire."],[2844,2968,"If you haven't tried it,"],[2976,3120,"how do you know it's fire?"],[3140,3232,"Or are you scared?"],[3280,3372,"Hayden."],[3400,3520,"Back in college,"],[3520,3684,"we were known as nemesis."],[3716,3912,"Why do you suddenly want to marry me?"],[3912,4068,"I need to hear your reasons."],[4068,4128,"First,"],[4144,4256,"my dad hasn't been well lately."],[4256,4332,"He keeps pushing me."],[4332,4424,"I need to marry someone soon."],[4424,4500,"Second,"],[4528,4664,"my company's AI lab"],[4664,4872,"has all the top-tier equipment you need."],[4896,4996,"Third,"],[5356,5492,"it really was my first time."],[5932,6080,"Come on, let's get married."],[6192,6348,"To get back into the AI industry,"],[6348,6576,"Hayden's company will be a great help."],[6576,6676,"It's a sweet deal."],[7608,7688,"Why toss my ring?"],[7720,7832,"The trash can is where it belongs."],[8424,8592,"It's just a contract marriage."],[8592,8752,"You don't need to give me an expensive ring."],[8760,8880,"I'm marrying you now."],[8912,9036,"You deserve the best."],[9064,9112,"Andy."],[9152,9268,"Can I have this one as my wedding ring?"],[9292,9444,"It's too expensive."],[9456,9596,"Let's just get something cheap."],[9607,9711,"We'll take that one."]],"7":[[104,188,"This is my house."],[188,288,"You're trespassing!"],[616,668,"Mom."],[800,872,"Son."],[872,996,"That vicious woman"],[996,1144,"kicked us out."],[1148,1424,"We didn't even bring my grandson's formula."],[1440,1592,"You're trespassing on private property."],[1612,1752,"I'll sue you for everything!"],[1752,1960,"This is Miss Hastings' dowry, her pre-marital asset,"],[1960,2076,"which belongs to her only."],[2112,2172,"Besides,"],[2196,2320,"you're already divorced."],[2352,2416,"Ms. Currin,"],[2440,2624,"your son is a gold digger, huh?"],[2632,2804,"Using his wife's money to support a lover."],[2816,2904,"What the hell?"],[2920,3032,"I'll rip your mouth aprat!"],[3032,3108,"Mom,"],[3108,3176,"stop arguing."],[3208,3320,"Olivia is my wife."],[3360,3508,"She's just jealous and throwing a tantrum."],[3508,3584,"She'll get over it soon."],[3640,3704,"Everyone, move along."],[3816,3876,"Pah!"],[3896,4004,"Andy."],[4004,4272,"Olivia is really angry this time."],[4320,4428,"I have a newly furnished apartment."],[4464,4588,"You can stay there."],[4620,4720,"You're so sensible."],[4736,4948,"I've been too tolerant of Olivia,"],[4984,5160,"that's why she's walking all over me."],[5200,5340,"It's okay, Andy."],[5340,5484,"As long as I can help you,"],[5532,5656,"the baby and I can endure a little hardship."],[5656,5756,"It's fine."],[5776,5844,"Good."],[7308,7372,"Madam,"],[7400,7528,"you'll be living here in the future."],[7556,7704,"Your luggage at Cloud Court,"],[7704,7864,"Mr. Hayden had us pack it up for you."],[7880,7984,"We'll bring it over tomorrow."],[8000,8092,"Strange."],[8116,8196,"How did Hayden know"],[8196,8412,"I was living at Cloud Court?"],[8552,8704,"Welcome home, Madam."],[8828,8932,"How do you all know me?"],[8940,9036,"We don't just know you."],[9068,9116,"Madam."],[9116,9280,"Mr. Hayden has a photo of you in his room."],[9292,9356,"A photo?"],[9356,9420,"Mr. Sanders."],[11376,11488,"Is this your room?"],[11540,11644,"Starting today,"],[11768,11896,"it's ours."]],"8":[[588,696,"Hayden,"],[700,868,"this is a contract marriage."],[896,1136,"There's no need to act intimate in private."],[1164,1236,"Act?"],[1352,1404,"Olivia,"],[1420,1584,"even though we have a contract,"],[1656,1832,"divorce isn't an option in my life."],[1832,1900,"There's only widowhood."],[1932,2024,"Since I married you,"],[2056,2156,"it's for life."],[2300,2452,"Sweet talk."],[2504,2592,"Listen,"],[2632,2768,"starting tonight,"],[2780,2884,"we are sleeping in separate beds."],[2884,3032,"You can't force me"],[3032,3132,"to be intimate with you."],[3164,3268,"I'll give you time"],[3312,3404,"to fall in love with me."],[3468,3560,"Until then,"],[3580,3868,"I'm at your service if you change your mind."],[4012,4160,"I'm going to wash up."],[4800,4936,"Why aren't you sleeping on the floor?"],[5016,5136,"It's too hard."],[5196,5368,"Mrs. Wayne will add a quilt tomorrow."],[5672,5768,"Fine."],[5956,6040,"This is the dividing line."],[6040,6124,"Don't cross it."],[6440,6500,"Fine."],[8640,8740,"Hayden!"],[8840,8916,"My love,"],[9032,9184,"sharing a bed is inevitable."],[9236,9336,"You should get used to it."],[10004,10140,"The project payment is two weeks late."],[10168,10256,"Olivia's sly dad"],[10256,10372,"won't answer my calls."],[10400,10684,"She actually made the Hastings divest."],[10736,10820,"Andy."],[10836,10948,"Don't get so worked up."],[11024,11172,"I have a way to fix everything."],[11172,11240,"What is it?"],[11252,11416,"Grandpa's birthday banquet is this weekend."],[11416,11640,"You can come as the father of my child."],[11660,11912,"My uncle is bringing his new wife with him."],[11956,12092,"If we get on her good side"],[12116,12244,"and have her put in a good word,"],[12248,12348,"we'll have plenty of investors."]],"9":[[0,144,"And have her put in a good word."],[156,284,"We'll have plenty of investors."],[304,496,"What if Olivia finds out?"],[496,596,"It's just an act."],[652,720,"Andy,"],[728,1004,"I'm sure Olivia is generous enough."],[1016,1096,"You're right."],[1096,1300,"I'll be the father of your child for the company."],[1300,1496,"Olivia has no reason to make a scene."],[1616,1684,"Okay."],[1700,1768,"I'll go with you."],[1804,1904,"We'll choose a gift tomorrow."],[1940,1988,"Mhm."],[2092,2176,"We're having a family banquet."],[2184,2280,"I'll take you."],[2296,2416,"I've already prepared the gifts."],[2440,2528,"Don't worry about it."],[2532,2688,"I'll pick you up then."],[2700,2776,"It's okay."],[2820,3012,"I'd like to prepare the gifts myself. It's our"],[3012,3080,"first meeting, after all."],[3092,3156,"Bye."],[3388,3568,"Hello. Let me see this bracelet."],[3808,3928,"I'll take this bracelet."],[3928,4072,"My husband will pay for it."],[4128,4292,"First come, first served, understand?"],[4348,4444,"Or is it that"],[4476,4692,"you're used to taking what belongs to others?"],[4716,4816,"Olivia,"],[4884,4960,"I'm so sorry."],[4988,5304,"But this bracelet is Andy's gift to my new aunt."],[5316,5524,"Why don't you let me have it instead?"],[5544,5632,"New aunt?"],[5856,5920,"Sure."],[5932,6052,"Pay ten times the price,"],[6096,6172,"and it's yours."],[6172,6376,"You're kidding, right?"],[6384,6556,"I'm not throwing my money away."],[6568,6708,"What? You can't afford it?"],[6712,6836,"Don't snatch it then."],[6856,7100,"Your little tricks might help you snatch a guy,"],[7100,7212,"but here,"],[7232,7304,"they won't fly."],[7308,7396,"Olivia."],[7408,7580,"Do you enjoy giving me a hard time?"],[7632,7764,"It's just a bracelet, isn't it?"],[7832,7908,"I'll buy it."],[7912,8028,"You know what?"],[8116,8320,"What has Andy spent on me over the years"],[8336,8504,"is easily in the millions."],[8512,8672,"Let alone one bracelet."],[8724,8900,"Even if it were ten,"],[8928,9060,"he'd buy them for me."],[9076,9300,"Are homewreckers this arrogant now?"],[9428,9508,"Don't worry."],[9540,9844,"Whatever Andy has spent on you during our marriage,"],[9896,9988,"I'll have my lawyer"],[9988,10156,"claw it all back, with interest."],[10436,10596,"Your husband is paying, you say?"],[10624,10688,"Here he comes."],[10796,10896,"Miss, ring it up."],[11012,11076,"It's not true."],[11076,11144,"Andy."],[11188,11320,"Olivia and I happened"],[11320,11452,"to like the same bracelet."],[11468,11672,"I explained you needed it for business."],[11676,11848,"But not only did Olivia refuse,"],[11852,11940,"she also humiliated me,"],[11956,12120,"forcing me to pay ten times the price."],[12140,12216,"Olivia,"],[12252,12460,"We're buying this bracelet for Mrs. Lawson,"],[12484,12656,"so she can help my company go public."],[12676,12804,"Why are you fighting with Candace?"],[12832,12940,"Don't be unreasonable."],[12940,13028,"I told you,"],[13088,13280,"pay ten times the price and it's yours."],[13364,13540,"Don't tell me you can't afford it, Mr. Sinclair?"],[13788,13844,"Swipe the card."],[13924,14092,"You're going all out, huh?"],[14208,14372,"I'm just afraid Mrs. Lawson"],[14372,14512,"won't appreciate your gesture."],[14560,14708,"Don't let it blow up in your face."],[14728,14856,"Olivia."],[14928,15204,"Are you trying to jinx him now?"],[15380,15468,"Olivia,"],[15500,15680,"I hate how aggressive you still are."],[15736,15876,"You've let me down."],[15892,15996,"Don't bark at me."],[16036,16152,"I'm scared of mad dogs."],[16276,16468,"I can't be bothered with your little show."],[16540,16596,"Andy,"],[16612,16744,"she called you a mad dog!"],[16744,16796,"Olivia."],[16796,16972,"Run your mouth while you can,"],[17040,17224,"but one day you'll be on your knees begging me."]],"10":[[320,413,"Candace."],[457,553,"You had a child out of wedlock"],[553,720,"and brought him home?"],[743,910,"Are you trying to kill Grandpa?"],[943,1126,"You've completely disgraced the Lawsons."],[1130,1195,"Rae,"],[1266,1493,"I already gave my parents back to you."],[1493,1723,"Why do you still have to be so hostile?"],[1763,1900,"Don't give me that cr*p."],[1933,2110,"This has always been my home."],[2120,2283,"And they're my parents."],[2306,2480,"You stole my life from me."],[2490,2640,"Why play the victim now?"],[2653,2786,"I don't want to fight."],[2833,2990,"It's Grandpa's birthday."],[3000,3270,"I'm back for him and my parents."],[3286,3546,"Just take your little mistake and get lost"],[3573,3826,"before Grandpa kicks you to the curb."],[3850,3990,"What is all this noise?"],[4106,4180,"Grandpa,"],[4204,4430,"Candace brought her little mistake home."],[4430,4510,"Shut up."],[4663,4743,"Hmph."],[5193,5553,"Candace, I raised you with such care."],[5586,5920,"Not so you could have a child out of wedlock"],[5920,6186,"and humiliate the Lawson family!"],[6710,6863,"Grandpa, I'm married now."],[6933,7043,"This is my husband."],[7043,7142,"We came back"],[7142,7291,"to celebrate your birthday."],[7340,7506,"Grandpa, I'm Andy,"],[7553,7740,"Candace's lawful husband."],[7740,7903,"You look like a fine young man."],[7930,8123,"Which family are you from?"],[8123,8202,"Grandpa,"],[8228,8410,"Andy is a self-made man."],[8410,8620,"His company is about to go public."],[8620,8783,"Hm, not bad."],[8846,9006,"The younger generation is really something."],[9026,9243,"You haven't gone public yet. Drop the act."],[9343,9520,"Who knows if you came back"],[9520,9703,"to get something from us?"],[9726,10080,"Grandpa, did you hear my uncle got married?"],[10090,10170,"Father."]],"11":[[683,806,"It's her!"],[973,1150,"Happy birthday, sir."],[1381,1553,"Good."],[1553,1780,"This young lady is elegant."],[1786,1928,"Please, have a seat."],[2433,2650,"Is this my niece, Rae?"],[2666,2840,"I brought a gift for you."],[2840,3000,"Auntie, I'm Rae."],[3223,3303,"Olivia,"],[3400,3593,"this is our adopted daughter, Candace."],[3650,3883,"She should call you Auntie."],[3893,3986,"Oh."],[4053,4170,"My apologies."],[4206,4313,"Niece."],[4363,4483,"And who is this?"],[4680,4760,"He…"],[4826,4946,"He's the father of my child."],[5003,5120,"Nephew-in-law!"],[5143,5273,"We're all family."],[5280,5466,"I'll have Hayden look out for you."],[5480,5630,"Hurry up and thank your aunt."],[6040,6140,"Thank you, Auntie."],[6160,6260,"Thank you, Auntie."],[6300,6486,"We're family. No need for formalities."],[6503,6600,"Candace,"],[6623,6766,"didn't you just say"],[6766,6993,"you had a gift for your new aunt?"],[6993,7080,"Let's see it."],[7906,8033,"This is too valuable."],[8103,8226,"Niece,"],[8226,8386,"you should keep it for yourself."],[8460,8630,"Put it on your aunt."],[11486,11570,"Uncle,"],[11623,11787,"I'm curious."],[11814,12034,"How did you and Olivia meet?"],[12103,12543,"Olivia is divorcing her husband of three years."],[12590,12820,"How did she suddenly become your wife?"]],"12":[[3,90,"What does that mean?"],[120,230,"You two know each other?"],[420,486,"Grandpa,"],[504,735,"I've known Olivia for over ten years."],[753,910,"I wasn't going to say anything,"],[960,1273,"but I'm worried my uncle's being deceived."],[1273,1355,"That's why I…"],[1373,1435,"Shut up!"],[1500,1663,"It's not your place to worry about me."],[1743,1808,"Hayden,"],[1859,1976,"let our niece speak."],[2030,2265,"I'd like to hear what she has to say about my ex."],[2296,2413,"Candace,"],[2413,2646,"why don't you tell us who he is?"],[3002,3084,"Go ahead."],[3142,3287,"Why the silence?"],[3287,3377,"Olivia,"],[3406,3506,"don't be so smug."],[3530,3683,"Can you deny you've been married before?"],[3683,3858,"You hid your past marriage to marry my uncle."],[3858,4012,"Apparently, you have bad intentions."],[4090,4313,"Uncle, she's a divorcée."],[4317,4404,"Enough!"],[4480,4773,"It's not your place to question my wife."],[4826,5003,"Olivia is my lawfully wedded wife,"],[5033,5213,"and your elder, in every sense of the word."],[5263,5400,"If you're respecting your elders,"],[5433,5600,"I don't think you belong here."],[5720,5800,"Security,"],[5930,6030,"escort them out."],[6046,6411,"Grandpa, I specially flew back for your birthday."],[6420,6610,"I was just worried about my uncle,"],[6610,6760,"that's why I spoke out of turn."],[6793,6933,"What are you waiting for?"],[6940,7033,"Grandpa!"],[7070,7150,"That's enough."],[7226,7446,"We're family. Let's not fight."],[7526,7643,"Apologize to your uncle."],[7833,7980,"I'm sorry, Uncle."],[8000,8180,"I was just worried about you."],[8282,8355,"So,"],[8464,8593,"you're not gonna kneel?"]],"13":[[460,540,"Candace,"],[1033,1113,"are you okay?"],[1273,1335,"Mr. Lawson,"],[1413,1553,"Candace shouldn't have offended your wife."],[1553,1650,"She was in the wrong."],[1690,1779,"But she's innocent and kind."],[1799,1910,"Afraid you were being conned."],[2010,2250,"Please forgive her, Mr. Lawson."],[2333,2460,"I can forgive her."],[2623,2804,"But whether my wife forgives her"],[2804,2921,"is not up to me."],[3005,3090,"After all,"],[3230,3483,"I can't bear to see her treated unfairly."],[3538,3605,"Miss Hastings,"],[3670,3886,"please be the bigger person"],[3940,4043,"and forgive Candace."],[4123,4400,"She humiliated me on my first day back home."],[4420,4561,"You think a flimsy apology"],[4612,4732,"settles everything?"],[4843,4966,"What more do you want?"],[5013,5170,"Candace just had a baby."],[5180,5290,"She's weak."],[5290,5426,"She almost got hurt just now."],[5493,5572,"Miss Hastings,"],[5594,5883,"why must you make this so difficult?"],[5883,6013,"You certainly are considerate."],[6110,6300,"If you won't forgive her,"],[6313,6441,"I'll kneel in her place."],[6498,6632,"Go on."],[6986,7186,"Didn't you want to kneel for her sake?"],[7263,7433,"Why aren't you on your knees yet?"],[9326,9603,"Are you satisfied, Miss Hastings?"],[9790,9883,"Yeah."],[10086,10406,"We're even now."],[10726,10966,"It's right for elders to discipline juniors."],[11046,11306,"Olivia is my daughter-in-law."],[11340,11506,"Anyone who crosses her in the future"],[11506,11680,"will have to answer to me."],[11686,11766,"Alright."],[11826,11906,"Let's eat."],[13283,13413,"I'm sorry, Andy."],[13463,13590,"I dragged you into this."],[13680,13818,"How could you tell Hayden"],[13818,13970,"that Olivia's been married before?"],[13970,14206,"I just wanted to test her,"],[14226,14500,"who knew she hooked up with my uncle?"]],"14":[[0,149,"Olivia wouldn't hook up."],[234,392,"But she's jealous over the past."],[450,720,"Now she's married to Hayden"],[725,841,"to spite me."],[908,966,"True."],[1000,1158,"Olivia loves you so much."],[1258,1379,"I was being petty."],[1541,1604,"Forget it."],[1608,1754,"I don't blame you."],[1758,2116,"But things got ugly with my uncle."],[2120,2320,"The investment deal is definitely off."],[2355,2591,"But your company goes public next week."],[2595,2670,"What do we do?"],[2808,2883,"Don't worry."],[2916,3109,"We still have Zxus's patent rights."],[3148,3320,"The IPO will be fine."],[3366,3512,"As for the funding,"],[3564,3699,"I'll ask my father-in-law for help."],[3726,3916,"Don't take matters into your own hands."],[4204,4516,"Don't celebrate too soon, Olivia."],[4520,4822,"I'll make you pay once we go public!"],[5688,5796,"Andy went to my house."],[5862,6066,"I haven't told my family about us yet."],[6070,6229,"I don't know what nonsense he'll spread."],[6233,6304,"I need to go back."],[6308,6566,"Don't worry. I'll go with you."],[6570,6679,"No need."],[6683,6849,"I can handle my family matters myself."],[6854,6995,"We're family now."],[7000,7154,"Your problems are my problems."],[7408,7483,"Fine."],[7520,7679,"But my dad is stubborn as a bull."],[7683,7875,"If he finds out I flash-married you,"],[7879,8063,"he might beat you to death."],[8108,8233,"Don't say I didn't warn you."],[8283,8420,"Why wouldn't he beat you to death?"],[8625,8829,"He'll probably kill us both."],[9078,9186,"I'm not afraid."],[9398,9516,"Let's go."],[10169,10243,"Dad,"],[10292,10454,"Olivia's been throwing a tantrum lately."],[10475,10591,"Could you talk some sense into her?"],[10595,10704,"Why is she throwing a tantrum?"]],"15":[[0,166,"My company's about to go public,"],[175,341,"but we were stuck on some technical issues."],[429,591,"I asked a junior from college for help."],[595,804,"But Olivia thought we're having an affair"],[825,962,"and wanted a divorce."],[1345,1646,"Dad, you have to help me."],[1987,2112,"Olivia is my daughter."],[2145,2220,"I know her."],[2279,2541,"She isn't the jealous type."],[2595,2704,"There's no smoke without fire."],[2725,2912,"Are you sure she's the only one at fault?"],[2933,3141,"Dad, you don't know."],[3145,3287,"Over the years we've been married…"],[3312,3570,"Ever since Olivia stopped working,"],[3608,3720,"her temper has changed a lot."],[3770,3924,"You have the nerve to say that!"],[3944,4035,"My daughter"],[4101,4393,"used to be a top talent in the AI industry."],[4475,4604,"If you hadn't kept her at home"],[4608,4783,"babysitting your whole family,"],[4845,5104,"she'd have made a name for herself!"],[5133,5354,"Dad, that is my fault."],[5375,5629,"I've been so busy and neglected her."],[5666,5745,"Once we go public,"],[5750,5974,"I'll make it up to her."],[6191,6383,"You've been promising an IPO months ago,"],[6412,6649,"but it's been all talk and no action."],[6712,6841,"Did you run into trouble again?"],[7025,7283,"It's nothing major, just…"],[7341,7533,"Cash flow is a little tight."],[7570,7771,"Get your company sorted out quickly,"],[7825,8029,"and focus more on Olivia."],[8066,8224,"Don't make her worry about you"],[8229,8412,"or clean up your messes all the time."],[8561,8670,"I know."],[8729,8825,"Thanks, Dad."],[9087,9224,"Tell Finance to transfer"],[9229,9541,"fifty million dollars to Candy Tech's account."],[9570,9628,"Not so fast!"]],"16":[[50,99,"Not so fast!"],[222,326,"Why is Hayden here?"],[434,617,"Are they really together?"],[654,724,"Andy,"],[783,874,"what are you doing at my house?"],[1266,1340,"Olivia,"],[1378,1516,"I know you're mad at me."],[1568,1669,"You won't listen to me,"],[1697,1791,"but won't you listen to Dad?"],[1807,1892,"Andy,"],[1918,2069,"I've told you many times,"],[2075,2191,"we are already divorced."],[2195,2354,"Please leave."],[2358,2438,"Olivia,"],[2441,2634,"I signed that mediation agreement"],[2643,2773,"to let you cool off."],[2783,2912,"Let's say, hypothetically,"],[2916,3063,"even if we signed the agreement,"],[3083,3212,"we're still in the cooling-off period."],[3216,3383,"How can that be considered a divorce?"],[3391,3523,"Signing a mediation agreement"],[3523,3700,"automatically skips the cooling-off period"],[3700,3779,"and concludes the proceedings."],[3825,3954,"Don't you know that, Mr. Sinclair?"],[4000,4104,"I don't believe it."],[4108,4195,"Olivia,"],[4229,4408,"you're lying to me, right?"],[4425,4604,"Dad, say something for me."],[4616,4741,"What right do you have to call him Dad?"],[4762,5049,"Unless you want Candy Tech bankrupt tomorrow,"],[5091,5250,"stop harassing Olivia."],[5420,5549,"Get out now."],[6129,6208,"Insolent!"],[6225,6334,"Uncle."],[6337,6459,"Shut up!"],[6558,6633,"You ungrateful!"],[6712,6904,"Back then, you ignored my objections"],[6916,7084,"and insisted on marrying Andy."],[7137,7320,"Now you just divorce him on a whim."],[7400,7608,"Is marriage just a game to you?"],[7612,7697,"Why can't I end"],[7699,7858,"an unhappy marriage?"],[7858,7970,"I'm free."],[7979,8162,"I'm responsible for my own life."],[8183,8283,"Responsible my *ss!"],[8309,8452,"You wouldn't listen to me"],[8456,8602,"and married Andy behind my back."],[8666,8820,"Now you realize you're unhappy."],[8879,9024,"How can you be responsible?"],[9029,9116,"Dad."],[9187,9349,"- I'll be responsible for Olivia. - You!"],[9354,9479,"You can test me anytime."],[9537,9662,"What did you call me?"],[9662,9728,"Dad."],[9790,9954,"Olivia and I are already married."],[9958,10108,"Please bear with us."],[10198,10291,"You ungrateful brat!"],[10313,10439,"Kneel down!"],[10637,10854,"I've really spoiled you rotten."],[10866,11021,"You need to be punished for once!"]],"17":[[1120,1220,"Are you okay?"],[1320,1420,"I'm fine."],[1702,2053,"Dad, I pestered Olivia into marrying me."],[2065,2269,"Hit me instead. Don't hurt her."],[2356,2448,"Rowan!"],[2587,2674,"Rowan!"],[2683,2812,"- Don't you dare hurt my daughter! - I..."],[3008,3063,"You."],[3101,3379,"And you two, reflect on your actions."],[4145,4262,"How can you still smile?"],[4520,4637,"Are you okay?"],[4641,4779,"It's fine. No big deal."],[4962,5212,"Your family discipline is impressive, though."],[5216,5454,"I'll make sure to learn from Dad."],[5997,6160,"Come on, let's put some medicine."],[6172,6254,"Okay."],[6771,6846,"Back then,"],[6846,7104,"you wanted Olivia to marry the Lawson boy."],[7116,7224,"Look how hard you hit him."],[7307,7465,"I just lost my temper, didn't I?"],[7512,7708,"I was afraid he wouldn't treat her right."],[7791,7904,"You old fox."],[7970,8125,"People's hearts are fickle."],[8129,8262,"I'm reserving judgment"],[8304,8438,"and watching him closely."],[8616,8749,"Sure, sure."]],"18":[[399,504,"All done."],[554,695,"Be careful not to touch it."],[1069,1183,"You can go now."],[1316,1454,"Where do you want me to go?"],[1487,1591,"The guest room is ready."],[1612,1688,"Go sleep there."],[1700,1836,"Why are you so heartless?"],[1908,2029,"If my back hurts tonight,"],[2075,2149,"who's going to apply the medicine?"],[2300,2379,"Then I'm leaving."],[3968,4121,"Hayden, stop messing around."],[4379,4495,"The wound hurts."],[4500,4612,"Blow on it for me."],[5916,5995,"It still hurts."],[6220,6383,"I'll put more medicine on it."],[6720,6870,"You need to kiss it better."],[6890,7058,"Then I will really be mad at you."],[7145,7216,"Alright."],[7220,7391,"Relax. I won't mess with you anymore."],[8170,8233,"Hey."],[8287,8408,"Go to sleep. Don't talk."]],"19":[[404,529,"I need to take this call."],[716,904,"Congrats, Healer!"],[908,1141,"Your comeback work, Zxus, won a top award."],[1165,1363,"So, are you going to the class reunion?"],[1445,1542,"Yeah, I'm going."],[1579,1783,"I'm back in town. Let's hang out after."],[1816,2112,"Sure. Thanks, Dan."],[2145,2283,"See you this weekend."],[2339,2412,"By the way,"],[2458,2626,"my identity isn't public yet."],[2658,2820,"You have to keep my secret."],[2837,2977,"No problem. See you tomorrow."],[3005,3077,"See you tomorrow."],[3495,3635,"Just chased one guy away,"],[3675,3799,"and now a Dan shows up."],[3854,4029,"Why do I smell something sour?"],[4080,4190,"What?"],[4204,4336,"Is someone jealous?"],[4358,4474,"I don't eat sour things."],[4620,4854,"That was Dan, a senior from my college."],[4883,4983,"He's back to teach."],[4991,5084,"We're meeting this weekend."],[5245,5383,"What is this secret"],[5387,5533,"that you can tell him but not me?"],[5695,5962,"It's a secret, I can't tell you that."],[5966,6063,"Fine."],[6090,6174,"I'll find out soon."],[6231,6339,"Right?"],[6358,6454,"Ms. Healer."],[6716,6816,"How did you know?"],[6850,7112,"I know everything about you."],[7195,7313,"No, seriously, tell me."],[7408,7566,"That's my own secret."],[7612,7716,"It needs to be kept, too."],[7929,8162,"Fine, forget it."],[8312,8433,"Hello, nice to meet you."],[8571,8761,"Dan, I've heard a lot about you."],[8964,9120,"I'm Andy Sinclair from Candy Tech."],[9145,9313,"I've been wanting to ask for your advice."],[9316,9438,"Regarding the AI field."],[9549,9875,"Isn't that Olivia's deadbeat ex-husband?"],[9916,10024,"I wouldn't call it advice."],[10029,10295,"I assume you didn't come to me for that."],[10300,10454,"Then I'll get straight to the point."],[10504,10779,"Thanks to your authorization of the Zxus patent,"],[10825,10974,"our company is about to go public."],[11113,11249,"But we're still short on funds."],[11337,11511,"Zxus is your brainchild."],[11516,11733,"If you're investing more,"],[11780,11892,"once my company goes public,"],[11932,12048,"we'll split the profits forty-sixty."],[12200,12370,"Don't flatter me, Mr. Sinclair."],[12400,12574,"I didn't develop the Zxus Project."],[12739,12839,"How is that possible?"],[12903,13060,"Candace clearly told me that Zxus"],[13170,13233,"was brokered by her,"],[13237,13424,"and authorized by you."],[13474,13670,"I've already paid Dan off."],[13675,13750,"Rest assured,"],[13758,13854,"Miss Lawson,"],[13879,14120,"he'll certainly play along with your act."]],"20":[[8,87,"Dan,"],[141,274,"how did your chat with Andy go?"],[416,491,"Who are you?"],[541,754,"It's me, Candace. Your junior from school."],[758,854,"It's been so long."],[858,959,"Don't you remember me?"],[987,1058,"Miss,"],[1079,1224,"you must have the wrong person."],[1316,1391,"Candace,"],[1454,1542,"what is going on?"],[1762,2008,"Dan, stop joking around."],[2033,2183,"You authorized Zxus"],[2187,2279,"for our company, didn't you?"],[2479,2616,"Is there something wrong with you?"],[2625,2779,"What kind of nonsense are you spouting?"],[3029,3155,"What are you doing?"],[3159,3366,"It's pretty low to take money and not deliver."],[3387,3479,"Don't you start rumors."],[3483,3595,"I don't know you at all"],[3604,3712,"and never took your money."],[3775,3908,"Oh, I get it."],[3933,4012,"You're setting me up,"],[4033,4141,"trying to ruin my reputation."],[4204,4287,"Dan."],[4337,4429,"Olivia,"],[4433,4512,"you're finally here."],[4516,4641,"Someone set me up."],[4754,4954,"Let me introduce Olivia,"],[4983,5079,"my only junior from school."],[5090,5190,"She happens to be"],[5190,5390,"the developer of the Zxus patent."],[5458,5529,"Olivia?"],[5600,5679,"How?!"],[5716,5816,"That's impossible!"],[5854,6074,"Olivia's stayed at home for three years."],[6119,6310,"How could she have developed Zxus?"],[6345,6495,"Miss Lawson, you kept claiming"],[6500,6612,"you secured Zxus yourself,"],[6625,6854,"yet you don't even know who created it."],[6858,6966,"What a joke."],[7025,7112,"Olivia,"],[7141,7334,"I know you want to save face"],[7337,7462,"in front of Andy,"],[7466,7566,"but you didn't have to"],[7570,7774,"drag Dan into your lies."],[7783,7879,"Drop the act, Candace."],[7966,8116,"If you had half a brain"],[8166,8313,"and followed industry news,"],[8358,8591,"you'd know Zxus is my creation."],[8616,8849,"Miss Lawson's bribe didn't work, did it?"],[8916,9074,"I'm not that easy to buy off."],[9100,9254,"The truth is,"],[9258,9512,"Candace doesn't know Dan at all."],[9575,9813,"She knew he was famous in the AI field,"],[9862,10120,"so she used his name to run a scam."]],"21":[[458,542,"You lied to me!"],[575,783,"Andy, let me explain."],[787,892,"It's fact that you lied."],[894,1004,"What's left to explain?"],[1567,1779,"Let go, Mr. Sinclair!"],[1783,1875,"Show some respect."],[2025,2099,"Olivia,"],[2133,2287,"how long are you going to be mad?"],[2345,2445,"You still care about me."],[2450,2584,"Why won't you admit it?"],[2587,2758,"You're delusional. Go get help."],[2762,2908,"Then why did you secretly authorize"],[2912,3016,"the Zxus patent to me"],[3025,3154,"without telling me?"],[3162,3316,"I never tried to hide it."],[3350,3616,"You just never cared about anything regarding me."],[3712,3917,"Besides, we're over."],[3966,4074,"Please stop pestering me."],[4133,4245,"I know that because of Candace,"],[4250,4362,"you've been acting out of spite."],[4383,4554,"She was wrong in this instance,"],[4591,4745,"but she's not a bad person at heart."],[4750,4924,"No need to defend your sweetheart."],[4975,5120,"I don't care about your business."],[5245,5324,"Also."],[5454,5529,"Nephew-in-law,"],[5608,5712,"have some self-respect."],[5962,6199,"Olivia, I swear I never wanted to divorce you."],[6204,6399,"You're only with him to get back at me,"],[6404,6501,"aren't you?"],[6513,6651,"Let's stop fighting."],[6725,6798,"Let go of me!"],[6888,7001,"Let go!"],[7025,7137,"Let me go, Andy!"],[7141,7271,"Let's stop this nonsense."],[8291,8362,"Don't be afraid."],[8416,8487,"I'm here."],[9195,9266,"Andy."],[9383,9479,"This is the last time."],[9587,9699,"If it happens again,"],[9754,9949,"I'll send you to prison to clear your head."],[10195,10279,"Let's go."],[11133,11278,"Son, please come home."],[11285,11551,"Your sister is being expelled from school."]],"22":[[208,290,"Little O."],[308,456,"He passes my inspection,"],[478,640,"but he's still on probation."],[1195,1353,"He's overstepping his bounds."],[1491,1637,"Why does he call you Little O?"],[1748,1848,"Because there an O in my name."],[1925,2108,"Dan thinks Little O sounds cute."],[2287,2383,"Oh, really?"],[2387,2482,"His exclusive nickname, huh?"],[2554,2654,"Great."],[3066,3167,"You really think so?"],[3525,3770,"Why don't you call me Little O too?"],[3870,3945,"I'm not doing that."],[3950,4066,"It's childish."],[4229,4508,"Then I'll just let Dan call me that."],[4670,4745,"Olivia."],[4790,4861,"Are you done yet?"],[5166,5216,"Okay, okay."],[5225,5308,"Don't be mad."],[5333,5466,"I'm the childish one, okay?"],[6700,6792,"I don't care!"],[6808,7016,"Candace gave me that algorithm model."],[7033,7158,"She said it was her top-secret idea,"],[7162,7266,"and told me to use it."],[7295,7417,"Now the school says I plagiarized"],[7425,7512,"and wants to expel me."],[7516,7649,"Where's the justice in that?"],[7716,7962,"Andy, think of something."],[8008,8162,"If Jules gets expelled,"],[8187,8329,"her whole life will be ruined."],[8387,8495,"Andy Sinclair."],[8500,8667,"Go find that bi*ch right now,"],[8675,8829,"and make her testify for me."],[8858,9029,"Your taste is getting worse and worse."],[9050,9204,"This new girl is even worse than Olivia!"],[9208,9287,"Enough!"],[9325,9500,"You mess around all day,"],[9508,9683,"running with that bad crowd."],[9708,9837,"Now that you're getting expelled,"],[9845,9987,"you have the nerve to blame others?"],[10095,10238,"You bi*ch! How dare you come here!"]],"23":[[47,126,"Jules,"],[146,270,"the baby is still here."],[270,395,"Where can I go?"],[452,691,"Besides, this is my home."],[725,824,"Where am I supposed to go?"],[866,1045,"Stop using the house and the baby to pressure me."],[1066,1249,"Why you gave me something that's not yours?"],[1266,1404,"Now I'm getting expelled,"],[1408,1516,"you owe me an explanation!"],[1525,1762,"Jules, go back to your room!"],[1800,2029,"Keep causing trouble, and you'll fix it yourself."],[2471,2729,"Andy, I didn't mean to lie to you."],[2757,2941,"Back then, you were so overwhelmed"],[2950,3066,"with the IPO technology."],[3075,3188,"So when Zxus approached us,"],[3191,3345,"I accepted their offer after an evaluation."],[3375,3500,"You sure like taking shortcuts."],[3566,3699,"Do you know how humiliated"],[3702,3824,"I was in front of Olivia today?"],[3836,3901,"Andy,"],[3945,4084,"after all the years we've been together,"],[4087,4220,"do you not trust me?"],[4261,4420,"I did it all for you."],[4529,4649,"But Olivia,"],[4654,4816,"she was with you for so many years,"],[4829,4945,"yet she hid her skills so well."],[5050,5129,"Alright."],[5154,5283,"This isn't entirely your fault."],[5413,5502,"Olivia is doing this intentionally"],[5508,5579,"to take revenge on us."],[5645,5716,"Andy,"],[5725,5816,"don't worry."],[5837,5970,"I found a contact for that mysterious big shot,"],[5975,6029,"Healer."],[6058,6229,"Who's coming out of retirement."],[6254,6408,"As long as we can hire that guy,"],[6412,6649,"we can build a system ten times better than Zxus."],[6691,6837,"But the funding…"],[6837,6912,"Andy,"],[7016,7183,"this is my life savings."],[7216,7299,"Use it."],[7458,7529,"Candace."],[7605,7660,"I…"],[7660,7862,"Just treat me well in the future."],[8054,8125,"I will."],[8250,8367,"Olivia,"],[8391,8604,"once I get Healer's technology,"],[8608,8896,"I'll make you come crashing down."]],"24":[[166,241,"Mom."],[295,420,"Will our gifts work?"],[425,542,"Why wouldn't they?"],[558,745,"Money talks."],[750,862,"If it doesn't work,"],[866,1058,"it means we didn't spend enough."],[1095,1158,"Hmph."],[1229,1374,"It's all Candace's fault."],[1379,1466,"If it weren't for her,"],[1470,1599,"I wouldn't be so humiliated!"],[1604,1641,"Hey,"],[1820,1954,"isn't that Olivia?"],[1962,2091,"What is she doing here?"],[2212,2279,"Let's go."],[2762,2920,"After you divorced my son,"],[2925,3087,"you've been sleeping around, huh?"],[3091,3212,"Guess the rumors were true."],[3220,3308,"Olivia,"],[3316,3417,"did you come here"],[3425,3545,"planning to"],[3550,3704,"seduce these young men?"],[3708,3837,"You really have no shame."],[4583,4649,"Pick it up."],[4654,4795,"With your amateur skills,"],[4800,4945,"you think you can do research?"],[4950,5070,"If you had what it takes,"],[5087,5179,"would my son"],[5183,5354,"have sent you home to serve me?"],[5375,5608,"Back then, your son knelt and begged me."],[5612,5733,"To care for his mother"],[5737,5854,"suffering in the countryside."],[5858,6000,"In the end,"],[6004,6174,"I cared an ungrateful wretch."],[6179,6391,"Talk about biting the hand that fed you."],[6416,6599,"Stop acting so high and mighty."],[6616,6791,"Andy made you focus on the family"],[6808,6979,"to teach you manners for your parents."],[6983,7237,"To make you learn how to be a good wife."],[7241,7391,"Some wealthy heiress you are."],[7395,7579,"She can't even have kids."],[7583,7670,"Enough, Mom."],[7675,7829,"Why waste time on her?"],[7845,8037,"We still need to find Professor Summers."],[8054,8162,"What do you want with me?"]],"25":[[379,483,"My goodness."],[487,612,"Professor Summers, hello."],[662,824,"My child made a little mistake"],[829,1070,"and messed up her graduation project."],[1087,1249,"We were hoping you could let it slide."],[1254,1320,"Haha."],[1483,1599,"Keep your hands off me."],[1604,1720,"I've reviewed her graduation project."],[1725,1875,"Aside from a few insignificant parameters,"],[1904,2070,"the core architecture and design concepts"],[2075,2212,"are identical to the original author's."],[2241,2374,"This is serious plagiarism."],[2379,2508,"How can you call it plagiarism?"],[2512,2637,"You're all doing research."],[2641,2862,"It's normal to borrow ideas from each other."],[2887,3045,"I'll add another $50,000."],[3050,3195,"Academia is rigorous."],[3200,3337,"Stop with these crooked tricks."],[3345,3449,"The original author is standing right here."],[3454,3604,"Do you want to compare them now?"],[3608,3771,"Olivia?"],[3775,3870,"Professor,"],[3875,4004,"are you sure you're not mistaken?"],[4029,4241,"She's just a live-in maid in my house!"],[4245,4358,"I'm mistaken?"],[4370,4579,"If it weren't for that your loser brother,"],[4587,4787,"Olivia would have long been a rising star now."],[4791,4962,"How could you say that?"],[5454,5608,"Look, we got off on the wrong foot."],[5629,5799,"We're family."],[5804,5883,"Olivia, dear,"],[5887,6012,"talk to the school"],[6016,6112,"about Jules's graduation project."],[6116,6229,"You supervised her,"],[6233,6341,"it's not plagiarism."],[6345,6512,"How are we family?"],[6516,6737,"Why should I handle your daughter's mess?"],[6745,6924,"For old times' sake,"],[6929,7129,"you were still part of a family."],[7133,7254,"How can you not help her?"],[7258,7399,"Does your whole family"],[7404,7566,"really take me for a fool?"],[7575,7670,"Alright, look."],[7716,7917,"I know you still love my son."],[7920,8146,"If you help Jules just this once,"],[8150,8324,"I'll get you two back together."],[8329,8459,"That loser son of yours?"],[8516,8658,"I wouldn't take him for free."],[8662,8849,"Regarding Jules's academic fraud,"],[8854,8995,"I've already submitted the report."],[9008,9133,"It will be handled by the book."],[9191,9320,"If you keep causing a scene,"],[9325,9404,"I'll call security."],[9416,9524,"Let's go, Dan."],[9570,9649,"Dealing with scoundrels"],[9654,9808,"is a total waste of time."],[9812,9912,"Oh, I see!"],[9916,10049,"You've already"],[10054,10241,"hooked up with this pretty boy."],[10245,10608,"How dare you blame Andy for keeping a mistress?"],[10612,10808,"He did it to carry on the family line!"],[10812,10941,"You sl*t!"],[10945,11104,"I'll tear your face off!"]],"26":[[229,329,"Throw them out."],[383,499,"Get them out of my sight."],[529,704,"Olivia, you little sl*t!"],[737,879,"You've hooked up with so many men!"],[1079,1195,"Why are you here?"],[1212,1279,"I'm here to see Dan, too."],[1283,1387,"To discuss academics."],[1408,1499,"And also,"],[1516,1629,"to take you home."],[1658,1779,"I think someone"],[1783,1929,"has ulterior motives."],[2453,2552,"Let's go."],[2787,2937,"I went back to my school."],[2941,3058,"Thinking about our college days,"],[3062,3188,"you were always against me."],[3216,3387,"Now, you're giving me a massage."],[3416,3554,"It's such a strange feeling."],[3858,3924,"Andy."],[3929,3987,"Here."],[4925,5004,"Hayden!"],[5183,5299,"What are you doing?"],[5458,5604,"Sorry, I didn't see you."],[5816,5883,"Want a drink?"],[5887,5974,"Get it yourself."],[6108,6191,"You even threw away the scarf"],[6195,6370,"that I gave to Andy."],[6375,6487,"I was so pissed."],[6491,6679,"But thinking back, it's quite a coincidence."],[6716,6949,"If you hadn't fought with me all the time,"],[7004,7154,"we probably wouldn't be married."],[7158,7270,"Yeah."],[7275,7404,"It is a coincidence."],[7512,7637,"But I didn't throw away that scarf."],[7695,7787,"What's wrong?"],[7791,7887,"Are you upset?"]],"27":[[25,91,"No, I'm not."],[141,216,"Do you want me to keep going?"],[220,334,"Honestly,"],[400,545,"I still can't believe"],[590,778,"the one I used to butt heads with"],[825,1066,"has actually become my legal husband."],[1325,1375,"You…"],[1379,1516,"What did you just call me?"],[1645,1745,"Nothing."],[1770,1896,"Just do the massage,"],[1900,1987,"why do you keep asking?"],[2237,2304,"Fine."],[2308,2387,"I won't ask."],[2816,2896,"Call me Hubby."],[3133,3262,"Tomorrow's my first day"],[3266,3383,"at Lawson Group."],[3387,3495,"I'm going to sleep."],[3866,3966,"No, you're not."],[3970,4154,"You know I'm very persistent."],[4341,4399,"Hey,"],[4404,4574,"a Technical Director was parachuted in."],[4579,4698,"No idea where she came from."],[4698,4858,"Who cares where she's from?"],[4858,4979,"If she can't deliver,"],[4983,5183,"Mr. Lawson will fire her anyway."],[5204,5270,"Why isn't this bug fixed yet?"],[5395,5587,"You're stuck on the algorithm bug."],[5637,5766,"Mind if I give it a shot?"],[5779,5945,"I've been at it for a week."],[5986,6066,"You can fix it?"],[6070,6266,"Give me three minutes."],[7262,7349,"- Huh? - Done."],[7536,7592,"Boss,"],[7592,7747,"you're my idol from now on!"]],"28":[[20,170,"Let me introduce everyone"],[175,408,"to our new Technical Director,"],[412,549,"Olivia."],[589,683,"Holy cr*p."],[683,802,"It's you, Boss!"],[822,880,"Boss,"],[912,1012,"sorry for my disrespect."],[1016,1174,"Just say the word,"],[1179,1412,"and I'll be at your service!"],[1416,1524,"Hello, Boss."],[1529,1574,"Hey,"],[1579,1641,"don't call me Boss."],[1658,1762,"Just call me Olivia."],[1816,1959,"What do you want for dinner tonight?"],[1962,2012,"It's on me."],[2020,2158,"Thanks, Boss!"],[2337,2412,"Hey Boss,"],[2425,2554,"rumor has it that"],[2558,2766,"Healer is about to take on a big job."],[2770,2937,"The client offered a huge commission."],[2950,3112,"What kind of god-tier system they're making?"],[3125,3212,"Healer?"],[3216,3333,"You don't know Healer?"],[3350,3512,"That's an industry legend."],[3516,3641,"But your Zxus algorithm"],[3645,3779,"is really similar to Healer's style."],[3783,3824,"Yeah."],[3829,3883,"That's true."],[4137,4224,"It's getting late."],[4229,4362,"Why don't you head back now?"],[4366,4483,"Tomorrow, organize the project data"],[4487,4625,"you have on hand,"],[4629,4754,"and prepare for next month's AI Summit."],[4779,4929,"- Okay. - You got it, Boss."],[5100,5320,"You really know how to flatter yourself."],[5325,5595,"As if you could ever compare to Healer."],[5633,5741,"Who are you?"],[5758,5937,"Talking trash to our boss like that."],[5941,6204,"I'm Candace, Technical Director of Candy Tech."],[6225,6408,"Healer is working on our project"],[6412,6529,"that is about to take public."],[6533,6795,"Compared to our system, Zxus is just garbage."],[6816,6887,"Seriously?"],[6895,6999,"I have no idea."],[7116,7170,"Oh?"],[7200,7308,"Is that so?"],[7316,7508,"I wish you a successful IPO."],[8045,8237,"Just wait, Olivia."],[8241,8433,"I'll let you see"],[8437,8783,"what the top AI system is like, clown."],[9775,9912,"Why do you have a photo of me?"]],"29":[[4,124,"Actually, I wanted to establish"],[129,266,"my image as a married man."],[270,508,"Since you don't want to go public yet,"],[512,612,"I'll put it away."],[637,758,"Why does this photo look like"],[762,883,"it was printed ages ago?"],[887,974,"It's starting to yellow."],[979,1120,"Must be coffee stains."],[1137,1313,"I heard you managed to handle"],[1316,1459,"those troublemakers in the Tech Department?"],[1475,1637,"They never listen to anyone, you know."],[1700,1779,"Piece of cake."],[1804,1917,"This time,"],[1920,2133,"I hope you can truly shine on your own stage."],[2241,2316,"Thank you,"],[2320,2387,"Hayden."],[2833,2983,"That's all?"],[3529,3595,"Oh,"],[3600,3646,"by the way,"],[3650,3787,"when I was eating,"],[3791,3875,"I ran into Candace."],[3879,4029,"I don't know what got into her,"],[4037,4167,"but she said she hired Healer"],[4179,4391,"to work on a project for Candy Tech."],[4404,4512,"I know about that."],[4575,4649,"Let her play her games."],[4700,4787,"Alright."],[4825,4979,"I'm working overtime tonight,"],[4983,5037,"you should go home early."],[5041,5116,"Don't wait up for me."],[5137,5304,"Working hard on your first day?"],[5316,5491,"The AI Summit is next month."],[5554,5787,"I plan to implement new algorithmic updates"],[5791,5912,"on the Zxus system."],[6025,6124,"If it works,"],[6133,6237,"the Lawson Group's stock"],[6241,6374,"is going to skyrocket."],[6554,6812,"How should I reward you, Mrs. Lawson?"],[7245,7374,"Hayden."],[7387,7633,"Mr. Lawson, Ms. Bennett is here."],[7804,7920,"Send her in."],[8041,8174,"Hayden."],[8541,8667,"Hayden, look."],[9216,9337,"Who is Ms. Grace Bennett?"],[9341,9438,"Why do we always see her"],[9441,9595,"coming in and out of Mr. Lawson's office?"],[9604,9837,"She's Mr. Lawson's ex-girlfriend."],[9900,10099,"They used to be so in love."],[10104,10362,"Supposedly, because Ms. Bennett got injured"],[10404,10474,"and couldn't have children,"],[10479,10649,"his family disapproved, and they split."],[10654,10837,"That's wild."],[10870,11066,"Hey, have you noticed"],[11070,11241,"that the new Tech Director, Ms. Hastings,"],[11245,11412,"looks a lot like Ms. Bennett?"],[11569,11754,"Did Hayden marry me"],[11758,11962,"because I look like Grace?"]],"30":[[45,99,"Look."],[1012,1099,"What's on your mind?"],[1104,1224,"You look a bit pale."],[1237,1341,"It's nothing."],[1520,1813,"Is Ms. Bennett"],[1916,2020,"your friend?"],[2025,2154,"Our families are old friends."],[2179,2341,"I happened to need her help recently."],[2416,2491,"She's like a little sister to me."],[2537,2649,"Candace is like my sister."],[2654,2771,"Can you not be so sensitive?"],[2904,2959,"Oh."],[3151,3210,"I'm going to sleep."],[4175,4245,"Babe,"],[4250,4345,"how are you getting along"],[4350,4466,"with your contract husband?"],[4470,4579,"Let's grab lunch tomorrow."],[4616,4737,"Right, Olivia."],[4779,4929,"What are you so disappointed about?"],[4945,5129,"It's just a contract marriage."],[5670,5970,"Is it because I've been too forward lately"],[5975,6104,"and put too much pressure on her?"],[6570,6654,"Hi, two Americanos, please."],[6658,6766,"Isn't that Hayden?"],[6779,6938,"The girl next to him,"],[6941,7079,"why does she look a bit like you?"],[7466,7616,"That's his ex-girlfriend."],[7620,7754,"What?"],[7762,7875,"His ex?!"],[7891,7966,"No way."],[7970,8045,"I've got to go over there"],[8050,8095,"and give him a piece of my mind."]],"31":[[4,91,"I've got to go over there"],[95,158,"and give him a piece of my mind."],[170,233,"Hey, wait,"],[237,295,"don't go."],[362,512,"They're probably talking about work,"],[516,654,"let's not bother him."],[716,820,"Besides,"],[837,1062,"we're in a contract marriage."],[1350,1504,"Well, she doesn't look that much like you."],[1575,1641,"Yeah."],[1645,1929,"Anyway, I don't think Hayden is the type"],[1933,2062,"to collect lookalikes."],[2091,2212,"Don't overthink, okay?"],[2237,2329,"Forget it."],[2379,2483,"Work is more important than guys."],[2500,2625,"The summit is coming up."],[2629,2774,"I'd rather focus all my attention"],[2779,2924,"on upgrading the Zxus Project."],[3016,3091,"Don't worry."],[3095,3258,"If he ever cheats on you,"],[3262,3391,"I'll tear him limb from limb"],[3395,3483,"and skin him alive."],[3600,3683,"Alright,"],[3687,3808,"just drink up."],[4750,4912,"Olivia."],[5056,5162,"Have you been drinking?"],[5169,5272,"Is the alcohol smell bothering you?"],[5326,5451,"I'll sleep in the guest room."],[5520,5595,"It's fine."],[5670,5745,"It's getting late."],[5750,5834,"Get some sleep."],[5887,6024,"I met Grace to talk about work today"],[6029,6112,"and came home late."],[6116,6212,"You're not mad, are you?"],[6477,6727,"Was I really overthinking it?"],[6800,6912,"Olivia,"],[7000,7116,"let's have a baby."],[7179,7438,"Supposedly, because Ms. Bennett got injured"],[7441,7512,"and couldn't have children,"],[7516,7691,"his family disapproved, and they split."],[7984,8059,"No."],[8081,8185,"Why?"],[8316,8512,"We're not having children yet."],[8550,8642,"Unless…"],[8804,8945,"you're planning to leave me one day?"],[9116,9266,"I've never thought about that."],[9633,9712,"It's alright."],[9846,9945,"We have plenty of time."],[10000,10087,"I'll wait for you."]],"32":[[20,125,"Today, Candy Tech"],[129,358,"announced their core IPO patent, Txus."],[362,533,"It's a decoded rewrite of Zxus."],[608,824,"Which means our upgrades to the Zxus Project"],[829,954,"are useless."],[966,1154,"Didn't they spend a fortune to hire Healer?"],[1208,1412,"Rewriting Zxus is the best Healer can do?"],[1450,1524,"The person they hired"],[1529,1658,"is not the real Healer."],[1729,1812,"No big deal."],[1816,1896,"Switch plans."],[1900,2063,"Execute Plan B."],[2083,2174,"Meeting adjourned."],[2379,2516,"So,"],[2520,2662,"your deal with Hayden"],[2666,2887,"was for the Technical Director at Lawson Group."],[3000,3091,"Do you need something?"],[3116,3241,"Olivia,"],[3250,3374,"you're really underhanded."],[3383,3483,"Did you sabotage our partnership"],[3487,3583,"with Lawson Group?"],[3620,3716,"You're delusional, go get help."],[3725,3837,"Stop making a scene."],[3841,3945,"Don't play dumb."],[3950,4087,"If you didn't mess things up,"],[4091,4237,"why would Hayden refuse to work with us?"],[4250,4379,"Work with Lawson Group?"],[4383,4549,"You might wanna check your scorecard first."],[4562,4649,"Don't be smug."],[4654,4845,"Candy Tech is hot now."],[4850,5012,"If Lawson passes,"],[5016,5204,"ten others are already waiting!"],[5216,5299,"So?"],[5320,5438,"Are you showing yourself out,"],[5441,5608,"or should I call security?"],[5625,5704,"Olivia,"],[5758,5908,"Marrying up isn’t some fairytale shortcut."],[5912,6116,"That title he gave you is a trap."],[6120,6274,"A trap to squeeze you dry!"],[6283,6579,"At least he didn't bleed me dry for free like you!"],[6612,6737,"Olivia,"],[6787,7021,"do you really not regret divorcing me at all?"],[7025,7154,"Whatever Hayden offers,"],[7158,7295,"I can make it happen for you!"],[7320,7441,"Marrying you"],[7445,7595,"was my biggest regret."],[7600,7709,"Keep talking tough."],[7716,7866,"When I make it to the top,"],[7891,8091,"it's only a matter of time before you come back!"]],"33":[[0,124,"What about Candace?"],[129,283,"She had your child."],[287,459,"I told you a long time ago,"],[470,625,"that kid isn't mine."],[683,854,"If you come back to me,"],[858,1066,"I'll cut ties with her immediately."],[1116,1167,"Andy."],[1325,1449,"Your mom just called."],[1454,1566,"She's not feeling well."],[1595,1724,"You should go check on her."],[1729,1824,"Okay."],[1829,1954,"I'll head back now."],[2312,2387,"Olivia."],[2391,2554,"Candy Tech is about to go public."],[2558,2795,"You've always dreamed of being a rich wife."],[2800,2966,"But I got it without even lifting a finger."],[2970,3074,"Ironic, isn't it?"],[3100,3208,"You'd better keep a close eye on him."],[3245,3379,"He might replace you at any moment."],[3416,3479,"You!"],[3520,3574,"Hmph."],[3637,3749,"Olivia."],[3804,3979,"You can't lean on Hayden for long."],[3995,4112,"He'll divorce you."],[4154,4283,"Do you know"],[4320,4608,"he has a childhood sweetheart named Grace?"],[4620,4758,"The two of you look"],[4762,4916,"exactly alike."],[4933,5045,"Don't try anything."],[5070,5174,"He's not Andy,"],[5208,5337,"pining for the one that got away,"],[5341,5474,"while refusing to let go of the one he has."],[5479,5737,"Stop putting on a brave face."],[5787,6000,"First marriage or second,"],[6058,6212,"you're just a replacement."],[6216,6349,"So pathetic."],[6445,6545,"Just you wait."],[6558,6667,"You'll be crying soon."],[7212,7345,"I knew it."],[7379,7487,"Hayden,"],[7491,7633,"you still care about me."]],"34":[[845,949,"Andy,"],[1004,1095,"I brought you some soup."],[1320,1417,"You're back."],[1466,1563,"What were you looking at?"],[1575,1666,"You've got such a big smile."],[1708,1783,"Nothing."],[1787,1891,"Just browsing."],[2016,2292,"Was that a photo of Olivia?"],[2320,2387,"No."],[2420,2542,"Why do you keep bringing her up?"],[2545,2641,"She and I are history."],[2745,2837,"What about us?"],[2841,2929,"What do you mean, us?"],[2958,3033,"Andy,"],[3037,3229,"I know I can't compare to Olivia,"],[3237,3483,"but I want to stand by your side openly."],[3491,3566,"Candace,"],[3570,3712,"you know my situation."],[3716,3854,"My company hasn't gone public yet,"],[3858,3999,"and family matters aren't settled."],[4262,4341,"Just wait a little longer."],[4345,4474,"I promise I'll marry you."],[4537,4595,"Andy,"],[4616,4771,"tell me the truth."],[4833,4983,"Do you still love Olivia?"],[5100,5174,"Candace,"],[5179,5316,"stop being unreasonable."],[5354,5424,"I've told you"],[5429,5574,"not to bring up the past."],[5725,5808,"I'm sorry, Andy."],[5887,5966,"I was wrong."],[6070,6188,"Drink the soup while it's hot."],[6275,6349,"I'll go check on the baby."],[7141,7366,"Haven't you two wanted to make it up to me?"],[7436,7548,"Now's your chance."],[7766,7896,"The furnishings are fine."],[7916,8099,"The courtyard plan needs fine-tuning."],[8312,8412,"Hayden,"],[8450,8574,"you and Olivia…"],[8740,8816,"Grace."],[8891,8995,"We're discussing work."],[9000,9112,"I know."],[9176,9314,"Don't be so serious."]],"35":[[91,188,"Don't be so serious."],[270,362,"Leave the proposal,"],[412,483,"and you,"],[533,595,"get out."],[745,837,"Fine."],[850,966,"See you tomorrow."],[1391,1750,"Hayden is probably just infatuated with Olivia."],[1754,1845,"After all,"],[1850,2021,"she's a stand-in for me."],[2337,2412,"Olivia,"],[2470,2612,"I underestimated"],[2616,2813,"your place in Andy's heart."],[2873,2957,"But,"],[2962,3188,"I won't let someone else take my place."],[3237,3445,"The title of Mrs. Sinclair"],[3518,3693,"is going to be mine."],[4116,4170,"Andy,"],[4212,4308,"you're back."],[4350,4512,"Why aren't you at the office?"],[4520,4695,"I wasn't feeling well,"],[4720,4812,"so I came home early."],[4816,4962,"If you're sick, why are you wearing so little?"],[4975,5079,"I wore it for you."],[5116,5249,"Don't you like it?"],[5270,5399,"What are you doing?"],[5425,5641,"I'm doing what you've always wanted,"],[5645,5771,"but were too afraid to do."],[5887,5979,"Candace,"],[6004,6079,"don't do this."],[6083,6214,"I've always seen you as a sister."],[6244,6327,"A sister?"],[6359,6445,"Andy,"],[6475,6533,"I gave up everything"],[6537,6691,"to come back for you."],[6695,6754,"Now you're telling me"],[6758,6858,"I'm just a sister to you?"],[6900,7016,"That's not what I meant."],[7062,7137,"Andy."],[7204,7313,"If it weren't for Olivia,"],[7316,7479,"we would've been together long ago."],[7545,7674,"I know you have feelings for me."],[7687,7804,"I feel the same way."],[7808,7866,"Do you know that seeing"],[7870,7987,"you together with Olivia"],[8062,8216,"really broke my heart?"],[8345,8420,"All right,"],[8462,8566,"don't cry."],[8837,8991,"Even if you don't do anything,"],[9012,9174,"Olivia won't trust you anyway."],[9216,9396,"Why keep waiting for her?"],[9529,9637,"You're right."],[9670,9813,"Instead of doing nothing"],[9829,10000,"while Olivia suspects me of everything,"],[10016,10199,"I might as well make it real"],[10204,10324,"and take the blame."],[11612,11720,"You bastard!"]],"36":[[212,320,"You bast*rd!"],[325,458,"You seduced my daughter without a commitment,"],[462,570,"and now you're bullying her?"],[575,646,"Exactly!"],[650,795,"You slept with my daughter, you should marry her."],[800,933,"Otherwise, we won't let you off the hook!"],[937,1024,"What are you doing here?"],[1033,1116,"Stop spouting nonsense."],[1129,1212,"Nonsense?"],[1216,1349,"You were hanging all over each other"],[1354,1458,"Do you think I'm blind?"],[1470,1599,"I did it on my own!"],[1604,1709,"Don't misunderstand him."],[1837,1970,"It doesn't matter if you consented!"],[1975,2074,"My daughter was innocent,"],[2079,2191,"and you've ruined her purity."],[2195,2308,"Either you marry her,"],[2312,2487,"or I'm charging you with rape!"],[2491,2579,"Uncle, Auntie,"],[2583,2654,"you've got it wrong."],[2658,2716,"Candace and I…"],[2720,2816,"Stop forcing him!"],[2900,3054,"Andy isn't an irresponsible person."],[3083,3162,"He just…"],[3237,3358,"He just has his difficulties."],[3366,3504,"Difficulties, my *ss!"],[3508,3620,"Give us a straight answer today."],[3625,3729,"Are you marrying her or not?"],[3733,3862,"I need time."],[4012,4179,"Why do you need more time?"],[4183,4233,"Andy,"],[4237,4412,"Candace is such a good girl."],[4416,4524,"You must treat her right."],[4695,4771,"In-laws,"],[4775,4891,"don't be angry."],[4912,5104,"This is Andy's fault."],[5120,5295,"I'll make the decision."],[5329,5408,"I'll have Andy"],[5412,5491,"marry Candace"],[5495,5733,"- in a grand wedding. - Mom!"],[5737,5837,"what do you think?"],[5841,5999,"That's more like it."],[6395,6491,"Say something."],[6591,6691,"Fine."],[6733,6854,"We'll get the license tomorrow."],[6883,6945,"The wedding"],[6950,7087,"can wait after the summit."],[7116,7237,"Really, Andy?"],[7300,7512,"I've waited so long for this day."],[7700,7854,"Olivia,"],[7875,8045,"I'm going to show you"],[8050,8313,"that I can still live a grand life without you."]],"37":[[508,641,"Let's have dinner tonight."],[1383,1562,"I have a business meeting."],[1566,1745,"Don't wait up."],[2004,2191,"I have a business meeting."],[2195,2308,"Don't wait up."],[2562,2674,"Weird."],[2770,2941,"Why is she suddenly giving me the cold shoulder?"],[3054,3279,"Ms. Bennett has been hanging around you every day."],[3300,3383,"If I were her,"],[3387,3487,"I'd be mad, too."],[3666,3745,"Zip it."],[4287,4459,"She gets mad because she cares."],[4462,4654,"She's starting to care about me."],[4658,4762,"That's good."],[5037,5099,"The summit materials,"],[5104,5262,"is everyone about done preparing them?"],[5287,5358,"Yes."],[5362,5606,"Olivia, what a coincidence."],[5616,5820,"I have good news to share."],[5912,6037,"Andy and I got our marriage license."],[6232,6298,"Congratulations."],[6370,6529,"I thought you'd have locked him down long ago."],[6576,6679,"I didn't expect"],[6683,6866,"it would take all that drama to make it official."],[6932,7066,"Andy dotes on me."],[7116,7283,"He didn't want to skimp on the betrothal gifts,"],[7287,7399,"so he made me wait."],[7475,7612,"He even gave me shares of Candy Tech,"],[7616,7804,"worth over a billion."],[7841,7954,"That kind of sincerity,"],[7958,8108,"you've never experienced it, have you?"],[8195,8354,"Well, you'd better enjoy it."],[8425,8542,"Don't let those shares"],[8545,8679,"turn into a liability"],[8708,8813,"you can't get rid of."],[8891,9104,"Stop being so salty, Olivia."],[9108,9204,"Andy and I are already"],[9208,9299,"officially married."],[9316,9512,"You'd better know your place,"],[9550,9670,"and stop pestering him."],[9795,9920,"Olivia is actually"],[9925,10141,"a homewrecker meddling in a marriage."],[10158,10462,"No way. Olivia doesn't look like a homewrecker."],[10483,10604,"Looks can be deceiving."],[10629,10709,"Who knows?"],[11120,11216,"My wife has no interest"],[11220,11324,"in recycling trash."],[11483,11545,"Pestering him?"],[11616,11750,"As if Andy is worth it."]],"38":[[223,306,"My wife has no interest"],[310,415,"in recycling trash."],[493,561,"Pestering him?"],[642,780,"As if Andy is worth it."],[997,1097,"Why are you here?"],[1733,1820,"I'm here to back you up."],[2487,2715,"If you don't want Candy Tech to go bankrupt,"],[2862,2938,"you'd better"],[2966,3137,"show your aunt some respect."],[4139,4255,"Olivia."],[4288,4454,"You want to be the CEO's wife in peace?"],[4487,4598,"I won't let you."],[4608,4727,"This show"],[4795,4941,"needs some fuel!"],[5987,6037,"Mrs. Lawson,"],[6041,6137,"giving me the cold shoulder already?"],[6316,6462,"I thank you, Mr. Lawson,"],[6541,6650,"for taking precious time"],[6674,6841,"to bring backup to the rescue."],[7167,7370,"When Charlie called me,"],[7375,7499,"I was going over contracts with Grace,"],[7513,7612,"so I brought her along."],[7879,8000,"Jealous?"],[8125,8220,"No."],[8308,8412,"Bringing a colleague"],[8416,8549,"to a work event is normal."],[8710,8857,"Why are you so stubborn, Mrs. Lawson?"],[9383,9537,"Then I'll have to see"],[9687,10185,"how to make you tell the truth."],[10370,10470,"Hayden,"],[10483,10629,"can you be more serious?"],[10875,10954,"Fine."],[10966,11099,"Drive. It's late."],[11587,11841,"You mean Hayden married her"],[11845,11983,"because I can't have kids?"]],"39":[[79,258,"You mean Hayden married her"],[262,399,"because I can't have kids?"],[470,545,"Why else?"],[629,787,"She's just a divorcée."],[810,954,"Why else would the Lawsons accept her?"],[1025,1167,"The Lawson empire is huge,"],[1170,1295,"and it needs an heir."],[1370,1462,"Since you can't have children,"],[1533,1662,"he found someone to do it for you."],[1750,1820,"No wonder."],[1825,2054,"He asked me to design the river-view house,"],[2060,2274,"and specifically mentioned the nursery."],[2325,2417,"It all adds up!"],[2491,2649,"Once she's had the baby,"],[2695,2854,"she'll have to pack her bags and leave!"],[3029,3120,"I never realized"],[3166,3391,"Hayden's feelings for me were so deep."],[3430,3568,"I was worried for nothing."],[3616,3783,"What a fool."],[3887,4162,"But Olivia thinks she's the legitimate Mrs. Lawson."],[4200,4329,"You need to find a chance"],[4400,4537,"to put her in her place."],[4558,4724,"Let her know who the real Mrs. Lawson is."],[4795,4995,"Otherwise, you'll be the one regretting it!"],[5520,5658,"I know what to do."],[5770,5845,"Thanks,"],[5887,5991,"niece."],[6575,6617,"Mr. Lawson,"],[6637,6829,"the contracts have been signed."],[7338,7405,"Ms. Hastings,"],[7425,7566,"Mr. Lawson is in a meeting,"],[7570,7795,"but Ms. Bennett insisted on waiting."],[7875,7941,"I see."],[8029,8170,"You can go."],[8529,8720,"Ms. Bennett, I'll be going now."],[8754,8829,"Olivia."],[9125,9334,"I came specifically for you."],[9358,9470,"For me?"],[9529,9637,"Don't you think"],[9670,9862,"we look a lot alike?"],[10208,10374,"Ms. Bennett, just speak your mind."],[10412,10570,"I'll get straight to the point."],[10616,10813,"Hayden and I were childhood sweethearts."],[10850,10983,"We've always been close."],[11041,11212,"But sadly, my body was damaged,"],[11241,11334,"and I can't have children."],[11404,11533,"He needs a child"],[11537,11674,"to inherit the Lawson Group."],[11704,11762,"And you,"],[11816,11983,"are the perfect candidate."]],"40":[[29,128,"He needs a child"],[131,250,"to inherit the Lawson Group."],[291,366,"And you"],[370,533,"are the perfect candidate."],[845,904,"Why should I"],[908,1174,"doubt Hayden just because of a few words?"],[1225,1412,"He gave me a river-view house,"],[1425,1620,"let me design the interior myself,"],[1658,1720,"and specifically asked me"],[1725,1924,"to pick out a cradle for the nursery."],[1983,2074,"If you don't believe me,"],[2116,2271,"I can take you there right now."],[2441,2745,"Olivia, he will never love you."],[2770,2987,"I advise you to accept your position soon."],[2991,3112,"It's best for both of us."],[4491,4625,"Two guys,"],[4629,4754,"two marriages,"],[4758,5054,"I was just a tool to them."],[5245,5320,"Mr. Lawson."],[5475,5584,"Where is Ms. Hastings?"],[5633,5754,"Ms. Hastings wasn't feeling well,"],[5758,5866,"she took the afternoon off."],[5970,6058,"Not feeling well?"],[6162,6243,"Why wasn't I informed?"],[6287,6438,"Ms. Bennett came to see Ms. Hastings today."],[6441,6537,"They exchanged a few words,"],[6550,6745,"and Ms. Hastings left, looking really pale."],[6775,6912,"Alright, get back to work."],[7416,7487,"Hello?"],[7516,7620,"Pull the office surveillance footage."],[7625,7724,"Check Ms. Hastings' whereabouts."],[7737,7813,"Immediately!"],[8241,8341,"He needs a child,"],[8608,8766,"and you are the perfect candidate."],[9720,9774,"Mr. Lawson."],[9879,10004,"He needs a child,"],[10008,10199,"and you are the perfect candidate."],[10216,10304,"Idiot!"],[10337,10391,"Mr. Lawson,"],[10416,10591,"Mrs. Lawson went to the City Hospital"],[10595,10691,"to see an OB-GYN."]],"41":[[25,220,"Miss Hastings, the fetus is 12 weeks along,"],[225,324,"and is developing normally."],[333,499,"Are you really terminating the pregnancy?"],[632,705,"I…"],[720,790,"I don't agree!"],[1171,1262,"This is my child."],[1391,1545,"I have the right to decide whether to keep it."],[1612,1695,"Olivia,"],[1816,1912,"let me explain."],[1916,2033,"I don't want to hear it."],[2083,2141,"Doctor,"],[2162,2249,"please schedule the surgery."],[2270,2334,"Olivia,"],[2362,2495,"give me a chance to explain."],[2500,2599,"Just come with me, okay?"],[2628,2701,"Let go of me!"],[2753,2797,"Let go!"],[3200,3316,"Talk this over calmly."],[3325,3404,"Regarding the baby,"],[3408,3504,"you should go home and think it over,"],[3508,3608,"before making a final decision."],[3670,3741,"Come with me!"],[4858,4933,"Grace,"],[4991,5116,"right here in front of me,"],[5129,5258,"explain our relationship,"],[5321,5470,"word for word, to Olivia."],[5545,5674,"The Bennetts and the Lawsons"],[5679,5858,"only have business dealings."],[5945,6125,"Hayden did save my life once,"],[6212,6334,"but he never crossed the line."],[6370,6524,"It was all my own wishful thinking,"],[6566,6712,"and I said those things just to spite you."],[6800,6866,"Apologize to Olivia."],[6995,7091,"Hayden,"],[7116,7245,"I've said everything I need to say."],[7250,7383,"Did you have to push me this far?"],[7387,7674,"If you don't want me to cancel all cooperation,"],[7754,7912,"then give Olivia a sincere apology."],[8095,8174,"I'm sorry!"],[8308,8383,"Grace,"],[8450,8570,"this is the last time I tolerate you."],[8695,8854,"If you even think about"],[8858,8962,"provoking Olivia again,"],[9020,9095,"you'll face the consequences!"]],"42":[[229,329,"So,"],[350,474,"is this the river-view house"],[487,554,"that Grace mentioned?"],[1233,1320,"This is the dowry your mother"],[1325,1416,"carefully chose for you."],[1462,1566,"How could I let it be sold off?"],[1650,1795,"I know you love this house."],[1820,1979,"Whether it sits gathering dust"],[2050,2167,"or you move in,"],[2225,2466,"it belongs in your hands."],[2912,3124,"Aren't you afraid I'll pine for someone else here?"],[3571,3646,"Don't you dare."],[4004,4108,"When Grace fell into the water three years ago,"],[4112,4195,"I did save her."],[4275,4387,"But aside from that,"],[4441,4557,"there's nothing between us."],[4645,4729,"Olivia,"],[4814,4912,"you can verify"],[4960,5051,"every single word I've said."],[5154,5337,"I believe you."],[5462,5521,"But,"],[5558,5704,"how did you know I was pregnant?"],[6366,6537,"I'm the one who plowed the field."],[6612,6737,"If a sprout grows in my own field,"],[6783,6912,"how could I not know?"],[8486,8570,"What are these?"],[9308,9404,"You bought them."],[9466,9558,"When I was cleaning up the house,"],[9562,9679,"I found them in the storage room."],[9912,10024,"I know you love children."],[10158,10300,"I won't let your hopes be in vain."],[10479,10558,"Hayden,"],[10729,10779,"I think I've really"],[10783,10875,"fallen for you."],[11012,11125,"Olivia,"],[11195,11341,"I've always loved you."]],"43":[[87,120,"Go ahead."],[141,224,"Call me if you need anything."],[279,358,"Andy."],[395,566,"Come try on wedding dresses with me."],[675,813,"I still have work to handle."],[908,983,"Andy."],[1104,1250,"Do you regret marrying me?"],[1362,1529,"Alright, don't overthink it."],[1533,1608,"I'll go with you."],[2933,3074,"I picked the wrong day to go out."],[3079,3224,"What bad luck!"],[3429,3508,"Olivia."],[3606,3756,"You look beautiful."],[3791,3870,"Get out of my way!"],[3912,3987,"Olivia."],[4025,4141,"After seven years together,"],[4158,4287,"don't you have a single word to say to me?"],[4354,4512,"I have nothing to say to you."],[4545,4620,"Olivia."],[4650,4766,"To be honest,"],[4783,4870,"I regret it."],[4920,5170,"I'll get a divorce and remarry you now"],[5175,5250,"if you want."],[5408,5545,"You always want what you can't have."],[5620,5808,"You're selfish to the bone."],[5862,6063,"How could I be so blind"],[6066,6191,"as to love you before?"],[6254,6329,"Olivia."],[6366,6487,"Believe it or not,"],[6541,6637,"I do love you."],[6641,6745,"I'm pregnant."],[6841,6904,"That's impossible."],[6950,7058,"You still love me!"],[7062,7195,"The baby is already twelve weeks."],[7233,7416,"Hayden and I are very happy."],[7445,7616,"We're done forever, understand?"],[7775,7862,"Olivia."],[7908,8087,"You kept saying you loved me,"],[8108,8274,"why would you sleep with Hayden?"],[8283,8441,"No one is going to wait for you forever."],[8520,8646,"Don't bother me again."],[8912,8983,"Bother you?"],[9050,9124,"Olivia,"],[9150,9279,"how dare you betray me?"],[9283,9454,"You're just my sloppy seconds."],[9458,9558,"Have you forgotten"],[9562,9758,"how you used to follow me around like a dog?"]],"44":[[29,245,"You're just my sloppy seconds."],[279,358,"Have you forgotten"],[362,599,"how you used to follow me around like a dog?"],[809,959,"You deserved that slap."],[1074,1204,"You gross me out."],[1437,1545,"Olivia,"],[1570,1724,"why won't you leave us alone?"],[1745,1924,"You're going to pay."],[2337,2441,"Brother, come to the hospital!"],[2445,2563,"Mom's sick!"],[3400,3495,"Olivia,"],[3550,3920,"two-timing makes you happy, doesn't it?"],[3979,4066,"Of course."],[4108,4220,"You heard Andy."],[4245,4370,"Your husband wants to divorce you"],[4375,4487,"to be with me."],[4529,4608,"You!"],[4816,4891,"Hmph!"],[4916,5029,"I'm not like you."],[5087,5199,"Just because a man strays a little,"],[5204,5341,"you insist on a divorce."],[5379,5462,"In the end,"],[5466,5654,"doesn't it just benefit some other sl*t?"],[5737,5849,"I'm really curious,"],[5879,5938,"what exactly did you learn"],[5941,6070,"in all these years abroad?"],[6108,6266,"You're even cursing yourself."],[6454,6612,"Andy won't divorce me."],[6675,6795,"Where a man's money is"],[6800,6891,"is where his heart is."],[6950,7116,"He just spent ten million dollars"],[7120,7292,"to buy me a villa."],[7362,7449,"As for you,"],[7491,7674,"he's just paying lip service."],[7775,7824,"Is that so?"],[7895,8141,"I hope you two are stuck together forever."],[8292,8368,"Where are you going?"],[8439,8493,"Jealous?"],[8520,8679,"I'm not done talking yet!"],[8750,8908,"Candace, don't go too far!"]],"45":[[129,287,"Candace, don't go too far!"],[1529,1591,"Are you okay?"],[1645,1745,"Did you get hurt anywhere?"],[2070,2158,"What are you doing here?"],[2204,2313,"Luckily, I showed up,"],[2529,2666,"or you would've let yourself get bullied."],[2729,2938,"Uncle, let me explain."],[2954,3029,"Candace."],[3079,3208,"I've tolerated you enough."],[3450,3629,"I really didn't push her."],[3641,3834,"Auntie just lost her balance."],[3916,4066,"Out of respect for my dad,"],[4116,4220,"I've let you off the hook once."],[4325,4454,"But if you refuse to change,"],[4512,4677,"I'll have you shipped off abroad tomorrow."],[5037,5133,"Let's go."],[5958,6188,"Doctor, I'm Ruth Cury's son."],[6191,6262,"How is my mom?"],[6283,6554,"She's out of immediate danger."],[6679,6858,"She fell into a coma caused by"],[6862,6962,"an acute cerebral embolism."],[7045,7199,"Fortunately, we treated her in time."],[7233,7458,"Any later, and it would've been fatal."],[7504,7608,"My mom's cardiovascular condition"],[7612,7754,"has been well-controlled all these years!"],[7797,7883,"Why did it replase?"],[7929,8083,"May I see the medication she's been taking?"],[8325,8612,"Olivia has been managing the meds these years."],[8647,8748,"I'll call her."],[8837,8995,"Mom hasn't had an attack in years."],[9000,9087,"I bet Olivia deliberately"],[9091,9204,"switched the meds to hurt her."],[9216,9337,"She's so vicious!"],[9395,9558,"The number you dialed is not answering."],[9770,9874,"She blocked me."],[9904,10029,"Jules, call her from your phone."],[10033,10104,"Put it on speaker."]],"46":[[95,195,"Hello? Who's this?"],[229,362,"Olivia!"],[366,491,"What kind of meds did you give my mom?"],[495,641,"You put her in a coma!"],[670,866,"Take your anger out on me."],[870,995,"It takes a coward to hurt my mom."],[1037,1116,"Get to the point."],[1154,1258,"Hello, Doctor."],[1262,1408,"Can I add you on a messaging app?"],[1412,1491,"I'll send the medication list"],[1495,1654,"and the medical reports to you."],[1725,1804,"Okay."],[2270,2345,"Doctor,"],[2404,2558,"is there a problem with the medicine?"],[2604,2699,"There certainly is."],[2920,3029,"I knew it."],[3033,3283,"Olivia is such a vicious woman."],[3317,3454,"I was right to divorce her."],[3562,3729,"What kind of children are you?"],[3775,3904,"The patient's cerebral blockage"],[3908,4016,"has been critical for a long time."],[4050,4174,"She hasn't had an episode,"],[4187,4292,"thanks entirely to this lady"],[4295,4387,"and the medicine she provided."],[4500,4558,"Impossible!"],[4562,4737,"Mom's been healthy these past two years."],[4741,4854,"She must have poisoned her!"],[5045,5116,"These drugs"],[5158,5258,"are the most advanced"],[5262,5504,"vascular treatments in the world."],[5533,5649,"They're expensive and hard to get."],[5654,5854,"Ordinary people can't afford them."],[5910,5997,"It was these very drugs"],[6000,6257,"that kept your mother's condition stable."],[6325,6408,"What?"],[6502,6554,"You have the means"],[6557,6691,"to use such excellent medicine,"],[6726,6863,"why did you suddenly stop it?"],[6904,6966,"Do you have any idea"],[6970,7170,"how dangerous this is for the patient?"],[7334,7437,"What do we do now?"],[7516,7637,"The patient is awake."],[7650,7896,"But she won't be able to care for herself,"],[7908,7995,"she needs a caregiver."],[8041,8209,"You should discuss among yourselves"],[8237,8334,"and decide who will stay."],[8916,9116,"I bet Olivia stopped the meds on purpose."],[9166,9312,"She wants Mom dead!"],[9337,9441,"Shut your mouth!"],[9445,9616,"You goof off all day."],[9620,9779,"Can't even take good care of Mom."],[9787,9887,"From now on,"],[9925,10054,"you're staying at the hospital."],[10083,10158,"If I catch you fooling around again,"],[10170,10271,"I'll break your legs!"],[10516,10584,"Andy,"],[10616,10704,"is Mom okay?"],[10900,10987,"She's stable now."],[10991,11063,"The doctor says"],[11066,11204,"she needs round-the-clock family care."],[11220,11383,"I'm having Jules stay to watch her."],[11470,11574,"Where were you earlier?"],[11579,11795,"Now you come rushing over, pretending to care."],[11833,11912,"I was at the bridal shop."],[11916,12000,"Enough!"],[12004,12146,"Since you care so much,"],[12162,12262,"you can stay for Mom!"]],"47":[[0,149,"Since you care so much,"],[166,266,"you can stay for Mom!"],[874,948,"Andy."],[1004,1084,"I'll take care of Mom."],[1120,1271,"You focus on the summit."],[1454,1562,"Why are your eyes swollen?"],[1776,2021,"I ran into Olivia at the bridal shop earlier."],[2056,2176,"I wanted to say hello,"],[2245,2387,"but my uncle insisted I was bullying her."],[2447,2563,"We got into an argument."],[2650,2875,"Olivia is throwing her weight around these days."],[3033,3149,"I'm sorry you had to go through that."],[3333,3446,"Once my company goes public,"],[3472,3604,"even the Lawsons will have to respect us."],[3666,3857,"I'll see how long she can be so arrogant."],[3865,3940,"Andy,"],[4033,4112,"I'm fine."],[4200,4324,"Once our company goes public,"],[4330,4480,"all our hard work will finally pay off."],[4745,4862,"Olivia,"],[4866,4954,"just you wait."],[4958,5129,"You're going to regret it."],[5328,5392,"Hello?"],[5400,5508,"Don't worry."],[5512,5591,"Did you make it to the hospital?"],[5595,5679,"Yes."],[5695,5862,"It's just a routine prenatal checkup."],[5866,5979,"You focus on your meeting."],[5987,6095,"Okay."],[6916,7029,"Look who it is, the little sl*t"],[7033,7237,"who tried to stop my meds and kill me."],[7266,7362,"Unfortunately,"],[7366,7574,"I'm a tough old bird."],[7582,7720,"If I wanted to kill you,"],[7742,7908,"you'd be six feet under by now."],[7991,8033,"You!"],[8160,8269,"Don't be so smug."],[8300,8399,"My son's company"],[8404,8554,"goes public tomorrow."],[8600,8746,"You wouldn't give me my meds,"],[8761,9099,"but people will be lining up to give them to me."],[9278,9382,"You're sick in the head."],[9416,9508,"You do need more meds."],[9580,9672,"Olivia,"],[9687,9862,"is this your high-class upbringing?"],[9945,10099,"You refused to help me once."],[10129,10279,"Now that my brother's going public,"],[10283,10433,"I can still snag a director position."],[10475,10646,"Don't think you're so special."],[10650,10783,"You were just born with a silver spoon."],[10818,11054,"You better start praying,"],[11104,11266,"so your dream doesn't end too soon."],[11479,11866,"Olivia, please report to OB-GYN Clinic 3."],[12616,12704,"Pah!"],[12708,12858,"You little sl*t."],[12916,13074,"You couldn't pop one out in three years,"],[13100,13245,"but the moment you hook up with a rando,"],[13250,13366,"you get knocked up!"],[13575,13688,"You really are a wh*re."],[13800,14000,"Once my son makes it big,"],[14037,14195,"you'll be the one crying."],[14457,14527,"Let's go."]],"48":[[350,462,"After the massage, empty the bedpan."],[533,624,"Why don't you go?"],[641,804,"If not, ask your brother to hire a caregiver."],[833,912,"Stop bossing me around."],[962,1058,"When you spend my brother's money,"],[1062,1158,"why don't you find a replacement?"],[1204,1274,"In the past, Olivia"],[1279,1412,"watched over Mom for nights on end."],[1445,1570,"But you think emptying a bedpan is dirty."],[1600,1720,"Don't compare me to Olivia."],[1737,1845,"Your brother and I are in love."],[1850,1966,"Who is she anyway?"],[2004,2141,"I'm not dead yet,"],[2179,2292,"and you already want to quit?"],[2333,2479,"Hiring a caregiver costs money, you know."],[2495,2604,"You're a Sinclair now,"],[2633,2883,"stop acting like some spoiled fake heiress."],[2933,3158,"Serving your mother-in-law is your duty."],[3216,3304,"Don't wait there."],[3341,3479,"Empty the bedpan,"],[3500,3584,"then go buy some food!"],[3604,3695,"I want something light."],[3716,3799,"Do you hear her?"],[3841,4008,"If you want to be a lady of leisure,"],[4016,4154,"you have to keep Mom happy."],[4166,4212,"Otherwise,"],[4241,4366,"my brother won't be happy about it."],[4962,5250,"Olivia used to wait on me hand and foot."],[5254,5537,"Candace actually gave me attitude."],[6187,6308,"Olivia."],[6341,6508,"She's divorced, but she still haunts me."],[6658,6754,"This time,"],[6804,7004,"I'll make you pay for it!"],[7566,7629,"Andy,"],[7770,7916,"Mom has pretty much recovered."],[7983,8099,"Tomorrow is the summit."],[8170,8287,"I want to go with you."],[8320,8366,"Okay,"],[8404,8529,"go prepare your speech."],[8541,8733,"You dealt with Healer on the Txus Project."],[8737,8820,"You're more familiar with it."],[8866,8920,"Don't worry."],[8970,9084,"I'll be well-prepared."],[9316,9424,"D*mn old hag."],[9483,9620,"How dare you make me empty your bedpan?"],[9733,9834,"Once the company goes public,"],[9858,9970,"I'll kick you back to the countryside."]],"49":[[133,204,"Olivia."],[279,404,"I heard Zxus"],[429,599,"was selected as a top case at the summit."],[604,674,"Congratulations."],[750,799,"Thanks."],[816,896,"But,"],[908,1029,"the controversy surrounding Zxus"],[1033,1108,"is quite significant."],[1162,1341,"Some say Zxus only won awards"],[1404,1529,"because of good marketing."],[1683,1792,"Whether it's marketing,"],[1833,1974,"Miss Lawson, you should know best."],[2075,2220,"Otherwise, why would you"],[2225,2349,"steal Zxus's authorization"],[2395,2591,"to apply for Candy Tech's IPO?"],[2716,2779,"My mistake."],[2804,2924,"Talking tech with you"],[2937,3062,"is really a waste of breath."],[3087,3174,"I forgot the main business."],[3287,3391,"Let me introduce to everyone."],[3450,3529,"At this summit,"],[3533,3662,"the project our company submitted"],[3666,3745,"for the IPO review"],[3762,3929,"is exclusively authorized by Healer."],[3970,4049,"Those in the know"],[4091,4183,"understand the weight."],[4212,4312,"Healer?"],[4341,4549,"That invisible god of the AI world?"],[4583,4670,"Candy Tech"],[4691,4774,"really hit the jackpot."],[4804,4954,"They actually got such a badass."],[5166,5287,"Healer's technology,"],[5358,5462,"how can an entry-level like Zxus"],[5466,5584,"possibly compare?"],[5654,5720,"Olivia,"],[5745,5875,"if you're interested,"],[5895,6074,"you should listen closely to my presentation."],[6133,6337,"I'll show you what 'worlds apart' means."],[6362,6417,"Sure."],[6475,6612,"I'll be waiting, then."],[6933,7020,"Thank you, everyone."],[7045,7274,"Today, I'd like to present a disruptive technology"],[7279,7445,"that will reshape the entire industry."],[7491,7737,"Developed by Healer, the Txus Project."]],"50":[[12,209,"A peer just mentioned Zxus."],[279,354,"To be honest,"],[370,574,"I've always felt that industry awards"],[581,823,"should go to those who drive the industry forward,"],[858,1120,"not to the lucky ones who climbed up through"],[1129,1204,"packaging and sheer luck."],[1312,1462,"Some award-winning works"],[1467,1621,"that try to compare themselves to Healer"],[1623,1794,"aren't even in the same league."],[2283,2375,"Olivia,"],[2391,2495,"I'm waiting to see"],[2516,2683,"how you'll handle this today."],[2741,2824,"Ms. Lawson,"],[2858,3000,"the Txus Project"],[3004,3262,"overlaps significantly with a paper"],[3308,3404,"published by Healer years ago."],[3416,3591,"But you tampered with the parameters,"],[3595,3720,"which has created a fatal bug."],[3733,3891,"Please explain that."],[3895,4045,"This is one of Healer's early works."],[4066,4209,"This is strictly what we were authorized to use."],[4229,4412,"Healer'd optimize it later."],[4425,4512,"Healer is known for"],[4516,4662,"never releasing anything imperfect."],[4666,4762,"They would never"],[4766,4920,"authorize unfinished work."],[4925,5137,"We've tested this bug;"],[5141,5362,"there is absolutely no solution for it."],[5387,5474,"That's impossible."],[5527,5685,"This is the exact authorization we received!"],[5712,5837,"Don't talk nonsense!"],[6116,6237,"May I add a few words?"],[6271,6387,"Olivia."],[6454,6542,"You're everywhere."],[6570,6670,"Do you even know tech?"],[6708,6774,"I do."],[6833,6887,"Because…"],[6991,7074,"I'm Healer."],[7166,7233,"She's Healer?"],[7379,7474,"Olivia."],[7479,7658,"There's a time and place for showing off."],[7666,7795,"You're Healer?"],[7800,7912,"Do you even know"],[7916,8058,"that Healer is a man?"],[8062,8209,"What a joke."],[8308,8362,"Yeah,"],[8408,8529,"isn't Healer a man?"],[8570,8712,"Spouting nonsense without proof,"],[8716,8883,"you're just using Healer's name"],[8887,8979,"to get attention, right?"],[9112,9204,"I can prove it."]],"51":[[429,491,"Olivia"],[587,649,"is also known as Healer."],[695,804,"Every version of the code you've released,"],[820,1004,"conceptual drafts, initial notes,"],[1075,1199,"including adjustments and revisions,"],[1233,1362,"I've organized them all chronologically."],[1412,1474,"From scratch,"],[1512,1646,"every step is clear."],[1991,2104,"Every bit of your effort"],[2133,2204,"is documented."],[2441,2584,"The CEO of Lawson Group vouches for her,"],[2612,2699,"it can't be fake."],[2800,2974,"I can't believe Healer is a woman."],[3087,3233,"No wonder the Zxus Project"],[3262,3345,"won the Gold Award."],[3412,3470,"Candace,"],[3500,3579,"what is this?"],[3604,3674,"Explain yourself!"],[3725,3779,"Andy,"],[3795,3849,"believe me,"],[3854,3974,"this is all fake."],[4004,4188,"Olivia is just a housewife."],[4191,4324,"How could she be Healer?"],[4375,4604,"This is just her and Hayden's conspiracy."],[4637,4712,"Candace,"],[4762,4834,"you're still in denial."],[4891,5000,"Your so-called authorization"],[5037,5167,"was just a draft I left"],[5175,5316,"on an academic forum years ago."],[5387,5462,"Because it had flaws,"],[5475,5604,"I didn't even encrypt it."],[5612,5839,"Do you have such poor judgment?"],[5912,5987,"Ms. Lawson,"],[6018,6213,"do you take us for fools?"],[6311,6412,"Took a discarded draft"],[6416,6563,"and claim exclusive rights?"],[6609,6711,"That is simply outrageous."],[6712,6853,"Last time we worked with them,"],[6854,7004,"the proposal they gave was full of holes."],[7033,7137,"And they bragged about their prowess."],[7150,7250,"It's an absolute embarrassment."],[7294,7364,"It was you!"],[7364,7504,"You set me up on purpose,"],[7506,7610,"hiding your true identity"],[7610,7712,"just to watch me make a fool of myself!"],[7725,7854,"I warned you a long time ago."],[7933,7983,"But,"],[8058,8266,"you can't save someone from themselves."],[8291,8430,"Candace knew there were issues,"],[8433,8542,"but she deceived us anyway."],[8590,8744,"This is essentially corporate fraud."],[9120,9209,"Ms. Healer,"],[9216,9313,"may I interview you?"],[9345,9449,"What are your thoughts on"],[9454,9599,"Candy Tech's theft?"],[9629,9709,"Thank you for your support."],[9720,9837,"There will be a press conference later,"],[9869,10010,"I won't be taking individual questions."],[10233,10354,"Quick, check the financial news!"],[10366,10521,"Candy Tech's stock is about to crash!"],[10554,10641,"The regulators"],[10645,10754,"have already stepped in to investigate."]],"52":[[29,108,"Olivia!"],[158,245,"You ruined me."],[283,383,"Who are you to take everything from me"],[387,524,"with just a single word?"],[562,691,"Because you chose the wrong path."],[725,883,"Hitching yourself to a freeloading social climber"],[920,1029,"to fulfill your fantasy of marrying up"],[1062,1162,"was a joke from the start."],[1195,1262,"Besides,"],[1279,1433,"you only lost what was never yours."],[1445,1533,"Acting all mysterious"],[1537,1654,"and playing us for fools!"],[1716,1837,"I'm taking you down!"],[2095,2179,"Candace!"],[2183,2262,"Stop making a scene!"],[2316,2429,"You ending up like this"],[2441,2516,"is exactly what you deserve!"],[2595,2649,"Security!"],[3004,3045,"Are you okay?"],[3079,3137,"Did she hurt you?"],[3245,3313,"I'm fine."],[3383,3524,"But she's gonna be out for a few days."],[3562,3662,"I see you've still got it."],[3716,3834,"Your fighting skills are as sharp as ever."],[3862,3966,"You reacted even faster than I did."],[3995,4191,"I honed them by beating you up back then."],[4233,4274,"By the way,"],[4316,4462,"how did you get that notebook of mine?"],[4550,4599,"We"],[4647,4754,"used to be arch-enemies back in the day."],[4779,4891,"I had to do my homework"],[4895,4995,"to figure out how to beat you."],[5048,5098,"Come on."],[5230,5299,"Let's call it a day."],[5315,5382,"- Let's go. - Go home."],[5920,5991,"Candace,"],[6122,6168,"quick!"],[6233,6370,"Dump all your shares, now!"],[6375,6446,"Dump, my *ss."],[6461,6573,"The stock hit the limit down ages ago."],[6591,6716,"The company's gone bankrupt."],[6720,6962,"We're both completely broke now."],[6981,7045,"Impossible."],[7138,7196,"That's impossible."],[7428,7487,"Wait."],[7504,7679,"I have backup funds in my offshore account."],[7700,7780,"Think they can take me down?"],[7795,7874,"It won't be that easy."],[7900,8049,"I can still make a comeback!"]],"53":[[20,120,"Wake up."],[129,224,"Do you really think Olivia"],[229,341,"would leave us a lifeline?"],[354,433,"The regulators"],[437,658,"froze all the accounts ages ago."],[686,824,"Remember how you promised"],[837,987,"I'd live like a queen?"],[1016,1104,"Look at us now."],[1116,1212,"You have the nerve to say that?"],[1229,1299,"If you hadn't found"],[1304,1412,"a fake Healer to scam me,"],[1450,1545,"would I be bankrupt?"],[1566,1707,"I was blind to marry you!"],[1713,1866,"You're useless at R&D,"],[1870,2004,"and now you're taking it out on me."],[2020,2167,"I'm the one who's truly cursed"],[2204,2270,"to have married you!"],[2279,2354,"Candace,"],[2358,2483,"why are you causing a scene again?"],[2491,2563,"All the family's good luck"],[2566,2662,"is being driven away by your noise."],[2687,2812,"Your son is nothing but"],[2816,2941,"a broke loser in debt now."],[2958,3049,"What luck is left?"],[3062,3146,"What nonsense are you spouting?"],[3204,3345,"How dare you yell at me!"],[3375,3554,"Cut the cr*p, you old hag."],[3587,3658,"Give me back my son."],[3716,3841,"What gives you the right to take my grandson?"],[3850,3938,"Your grandson?"],[3970,4129,"My son isn't even that loser's child."],[4154,4250,"He was just a convenient father"],[4270,4412,"I found for my boy."],[4450,4537,"What did you say?"],[4616,4679,"Candace,"],[4754,4895,"did you have to tell my mom that?"],[4900,5029,"Why shouldn't I?"],[5058,5174,"I want a divorce."],[5233,5287,"You people."],[5325,5491,"Pack your things and get out of my house now."],[5520,5633,"You little sl*t."],[5650,5858,"How dare you do something so filthy?"],[5875,5941,"How can you look us in the eye"],[5945,6137,"after our family gave you everything?"],[6150,6295,"Shut up, you old hag!"],[6337,6512,"You're the most shameless one in this house."],[6529,6608,"Candace,"],[6629,6762,"don't you dare bully my mom."],[6762,6916,"Oh, good heavens."],[6916,7066,"What a sin."],[7091,7329,"I must have been blind"],[7341,7549,"to let a jinx like you into the family."],[7591,7804,"If I hadn't kicked Olivia out,"],[7825,8004,"would you ever have the chance to run wild here?"],[8020,8154,"You dare to mention Olivia to me?"],[8208,8392,"It's all your fault I'm this miserable."],[8402,8654,"You all helped Olivia destroy me."]],"54":[[275,358,"Have you lost your mind?"],[367,444,"Put the knife down!"],[520,583,"Stay back!"],[654,737,"If anyone comes closer,"],[812,920,"I'll take you down with me!"],[945,1028,"Give me the knife."],[1354,1438,"Jules!"],[1856,1932,"Jules!"],[1934,2079,"My poor Jules."],[2355,2507,"Mom, Dad, please eat."],[2995,3107,"I remember you love this."],[3108,3173,"Here."],[3176,3272,"I can do it myself."],[3553,3624,"Hayden,"],[3667,3799,"come to the study with me."],[4062,4141,"Oh no."],[4179,4337,"Dad still hasn't accepted Hayden."],[4900,5016,"Mom, Dad."],[5116,5209,"This…"],[5375,5449,"Olivia,"],[5545,5683,"these represent all the assets and shares"],[5733,5879,"I'll hold after inheriting the Lawson Group."],[6012,6137,"Today, witnessed by Mom and Dad,"],[6162,6279,"I'm transferring everything to your name."],[6804,6954,"You're the only woman I've ever loved."],[7025,7074,"This is"],[7086,7216,"just to provide you some security."],[7229,7333,"We rushed into our marriage,"],[7338,7441,"and I owe you a ceremony."],[7479,7583,"I'm making it up to you today."],[7829,7912,"Olivia,"],[8000,8091,"will you marry me?"],[8225,8287,"I will."],[9800,10049,"I've waited seven long years to hear that."],[10054,10154,"What?"]],"55":[[83,271,"Hayden just messaged to ask,"],[287,412,"saying if you're nervous,"],[433,554,"he'll come keep you company."],[650,745,"I'm not nervous."],[775,899,"He just wants an excuse to sneak in."],[929,1029,"Don't let him get his way."],[1150,1241,"Seriously?"],[1245,1312,"Not again."],[1337,1412,"Miss Hastings,"],[1495,1670,"the florist said there's an issue with the bouquet,"],[1683,1787,"I'm here to replace it."],[1820,1966,"These are fresh champagne roses."],[1979,2108,"They match the wedding dress better."],[2612,2804,"The wrapping does look more elegant."],[2975,3058,"Is there anything else?"],[3066,3214,"Oh, um."],[3245,3383,"I need to take the old bouquet back."],[3487,3545,"I'll get it."],[3587,3683,"I'll check the boutonnieres while I'm at it,"],[3712,3795,"just to make sure they're fine."],[3862,3929,"Thanks for the trouble."],[3933,4016,"Hurry back."],[5041,5129,"Andy?"],[5133,5220,"How did you get in here?"]],"56":[[20,112,"Andy?"],[118,408,"- How did you get in here? - How did I get in?"],[475,599,"I've lost everything."],[637,745,"You're all I have left, honey."],[787,904,"Come away with me. Let's start over."],[908,970,"Okay?"],[1012,1133,"You brought this on yourself."],[1187,1279,"We're through."],[1283,1362,"Get out!"],[1382,1449,"Through?"],[1471,1624,"I didn't agree to it. You don't get to decide."],[1658,1741,"You loved me for seven years."],[1779,1879,"How can you just end it?"],[1941,2021,"Is it just because I"],[2083,2229,"felt sorry for Candace and her son?"],[2283,2341,"Olivia,"],[2383,2542,"I... I've changed."],[2589,2694,"Let's get remarried, okay?"],[2733,2820,"Come with me."],[2829,2895,"We'll go get our license"],[2900,2987,"and get everything back on track."],[3025,3145,"Andy, have you lost your mind?"],[3150,3208,"Let go of me!"],[3233,3337,"There is no way I'm going with you!"],[3370,3449,"Get off me!"],[3612,3726,"You belong to me."],[3800,3875,"Didn't you use to try everything"],[3883,4026,"to get me into bed?"],[4048,4149,"I'll give you what you want right now."],[4154,4270,"Andy!"],[4275,4408,"Are you crazy? I'm pregnant!"],[4416,4524,"Don't do this!"],[4550,4716,"That makes it even more exciting."],[4733,4816,"Andy!"],[4879,4933,"Olivia?"],[4976,5062,"Olivia, are you in there?"],[5200,5255,"Hayden!"],[5288,5367,"Help!"]],"57":[[0,49,"Hayden!"],[66,149,"Help!"],[475,529,"Olivia."],[595,645,"Don't be scared."],[658,733,"It's all right. I'm here."],[1170,1237,"Hayden."],[1254,1295,"Stop hitting him."],[1337,1437,"Don't dirty your hands on a scum."],[1454,1549,"If you come near Olivia again,"],[1595,1674,"I'll kill you!"],[1783,1845,"Olivia,"],[1887,2000,"is this how you repay me?"],[2054,2183,"If I hadn't saved you seven years ago,"],[2237,2320,"you'd be dead by now."],[2391,2458,"Seven years?"],[2483,2537,"That's right."],[2570,2670,"I'm the reason she's alive."],[2716,2787,"For that alone,"],[2854,3012,"you will never compare to me in her heart."],[3316,3424,"Say that again."],[3508,3579,"You saved her?"],[3629,3856,"It was you?"]],"58":[[133,245,"We're police."],[295,337,"Excuse me,"],[362,479,"is Andy Sinclair here?"],[529,570,"That's him!"],[608,666,"Andy,"],[687,824,"you're suspected of massive embezzlement."],[862,983,"You need to come with us."],[1029,1079,"Take him away."],[1141,1199,"At the hospital,"],[1229,1370,"she saw me first!"],[1374,1498,"It's me she loves!"],[1816,2170,"Did you save me seven years ago?"],[2229,2358,"You passed out after falling down the stairs."],[2429,2545,"I had gotten you to the hospital"],[2608,2729,"when I learned Grandpa was seriously ill."],[2783,2862,"I had no choice but to rush back."],[2933,3129,"When Andy claimed he saved me,"],[3200,3345,"I believed him for seven years."],[3654,3737,"I did come looking for you."],[4141,4229,"Look at this."],[5804,5854,"Maybe,"],[5958,6095,"you liked him all along."],[6225,6313,"So, ho saved you"],[6316,6454,"didn't really matter."]],"59":[[1362,1529,"So, all this time…"],[1575,1641,"I love you."],[1945,2146,"Ever since the first time we met."],[2295,2391,"Hayden."],[2466,2545,"I'm sorry."],[2595,2699,"Don't apologize to me."],[2775,2858,"At least now,"],[2904,3054,"I'm the one standing by your side."],[3166,3334,"Fortunately, we didn't miss each other."],[5681,5795,"As time flows on,"],[5795,5951,"she has finally become"],[5955,6055,"the warmest presence in his life."],[6155,6330,"From an unreachable dream"],[6330,6554,"to the moonlight resting on his pillow."],[6638,6774,"He wishes to walk with her"],[6842,6978,"through the years to come."],[7054,7168,"May the rest of their lives"],[7236,7378,"be filled with light."]]}