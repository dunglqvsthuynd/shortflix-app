{"1":[[446,558,"So I'm flying the space shuttle"],[558,667,"for the second time,"],[704,838,"and this guy passes out."],[838,988,"Alright, it's about that time."],[1009,1117,"So are you"],[1117,1276,"kissing anybody at midnight?"],[1947,2110,"Yeah, him."],[2152,2239,"Hi."],[2277,2377,"Just play along."],[2427,2502,"Six,"],[2502,2602,"five,"],[2602,2694,"four,"],[2694,2798,"three,"],[2798,2877,"two,"],[2877,2965,"one!"],[2965,3203,"Happy New Year!"],[5355,5472,"You have a cute scar."],[5526,5676,"It's just my birthmark."],[5805,5964,"If you want me to stop, tell me now."],[6218,6356,"I don't want you to stop."],[9409,9705,"Uh, I was so drunk last night."],[9747,9905,"I can't remember who I was with."],[10256,10368,"I must return this to her,"],[10368,10506,"so I can see her again."],[11031,11140,"Happy New Year."],[11152,11227,"Sam, it's me."],[11286,11544,"Hey, find me the girl from last night."],[11557,11715,"I don't care how, just do it."],[11815,11932,"I will find you."]],"2":[[208,571,"Maximus, can't you get married already?"],[600,709,"Bring home a wife,"],[709,888,"or at least a girlfriend."],[888,1051,"I need grandkids."],[1051,1146,"I need you to-"],[1146,1272,"Message received, Mom."],[1297,1401,"I need to go now."],[1401,1584,"I have to inspect the new headquarters."],[2419,2544,"Seven years."],[2590,2761,"Why can't I ever find you?"],[2790,2952,"And why do you still haunt me?"],[3728,3899,"Still thinking about that girl?"],[3916,4099,"Boss, it's been years."],[4416,4567,"I'm ready to go to the inspection."],[4617,4725,"Your vest, sir."],[4821,4942,"But first, we found your"],[4942,5042,"fake Christmas wife."],[5042,5180,"She's waiting in the coffee shop."],[5180,5342,"Blonde hair, red top."],[5342,5613,"And sir, make sure you use an alias."],[5613,5697,"We can't have her know"],[5697,5805,"you're the Harrison Group CEO,"],[5805,5968,"or she'll jack up the price."],[5968,6010,"Good."],[6081,6268,"Finally, I can get my mother off my back."],[6556,6835,"Hi, one iced vanilla latte, please."],[6835,7019,"And one hot chocolate."],[7111,7273,"I can't wait to finally"],[7273,7403,"meet my new daddy."],[7440,7645,"Now Auntie Debbie and Pamela"],[7645,7870,"can't say I have no daddy anymore."],[7978,8170,"Sweetie, remember, it's just pretend."],[8179,8324,"It's just for Christmas."],[8329,8408,"But Mommy,"],[8408,8583,"why do we have to rent a daddy?"],[8583,8721,"Where's my real one?"],[8796,8854,"Uh..."],[9459,9580,"I'll tell you when you're older."],[9630,9688,"Sweetie, why don't you"],[9688,9801,"go find us a table?"],[10627,10723,"Daddy!"],[10723,10823,"Oh, whoa."]],"3":[[8,108,"Daddy!"],[108,258,"Oh, I'm sorry."],[379,508,"I'm not your dad."],[508,642,"No, I know you're my daddy,"],[642,813,"just as handsome as I thought."],[938,1063,"Mommy, hurry."],[1063,1288,"Your fake Christmas husband has arrived."],[2022,2147,"I asked the agency"],[2147,2310,"for an average looking guy."],[2310,2473,"He's gorgeous."],[3032,3115,"Why does she - Why does he"],[3115,3249,"feel so familiar? - feel so familiar?"],[3361,3516,"She's waiting in the coffee shop."],[3516,3670,"Blonde hair, red top."],[3707,3933,"You must be my new Christmas husband."],[3966,4200,"So, you're my new Christmas wife?"],[4225,4404,"See, I knew you were the new daddy"],[4404,4483,"we hired, right?"],[4483,4592,"Hi, my name's Piper."],[4592,4679,"What's your name?"],[4742,4950,"Sam didn't say anything about a kid."],[4984,5125,"Max Aurelius."],[5150,5217,"Eva."],[5313,5434,"I think we should probably sit"],[5434,5522,"and discuss the details"],[5522,5647,"of this fake marriage."],[5743,5943,"I just need a wife for the holidays."],[6014,6202,"I guess mom gets her grandkid too."],[6381,6577,"So, per our agreement,"],[6577,6927,"the rate is $1,000 per hour and-"],[6927,7061,"1,000 an hour?"],[7107,7190,"Oh, yeah."],[7311,7440,"It's 500 a day."],[7478,7582,"Is that enough?"],[7611,7757,"That's the most that I can pay you."],[7757,7945,"Wait, you're paying me 500 a day?"],[7953,8141,"That's what I agreed with the agency."],[8179,8274,"You'll make your thousands"],[8274,8362,"over the week."],[8362,8483,"Look, my requirements"],[8483,8596,"are simple, okay?"],[8596,8721,"Play my pretend husband,"],[8721,8875,"come with me to my hometown,"],[8875,8963,"and we all pretend to be"],[8963,9084,"one big happy family."],[9125,9309,"And then my family will get off my back,"],[9309,9446,"so Piper can have"],[9446,9588,"a good Christmas for once."],[9776,9884,"So, she's getting pressure"],[9884,10018,"from her folks too."],[10043,10264,"Fine, but you have to help me"],[10264,10435,"get my mom off my case too."],[10610,10773,"Okay, deal."],[11061,11161,"Ready to go get married?"]],"4":[[734,942,"Wow, you clean up nice."],[1009,1155,"It's my wedding day after all."],[1180,1330,"Pictures."],[1605,1672,"Thank you."],[2093,2285,"You guys are supposed to look like"],[2285,2406,"you're in love."],[4379,4546,"Ka-ching!"],[4608,4833,"Okay, I think we got it."],[4875,4921,"Oh,"],[4971,5163,"I need some photos of us together too."],[5226,5330,"To prove to my parents"],[5330,5442,"that I'm actually married,"],[5442,5580,"and have a happy family."],[5580,5751,"Yeah, of course."],[6731,6840,"Happy holidays, Mom."],[6931,7069,"From my family to you."],[7920,8041,"Bad news, boss."],[8041,8099,"The agency said"],[8099,8208,"that the girl that they recruited"],[8208,8316,"to be your fake wife"],[8316,8445,"bailed last minute."],[8445,8558,"Wait, she bailed?"],[8608,8687,"Then who is..."],[8992,9092,"Who is she?"]],"5":[[33,108,"Whatever."],[166,237,"It doesn't matter."],[333,458,"I've got what I need."],[654,784,"Sam, don't worry about it."],[838,942,"I already found someone."],[1438,1564,"Okay, well,"],[1647,1768,"I think it's time for us to go."],[1768,1939,"Christmas shopping waits for no one."],[1939,2047,"Christmas shopping?"],[2085,2218,"I should come."],[2310,2444,"Look, if you want me to be the husband in"],[2444,2569,"this fake-it-to-your-family"],[2569,2631,"plan,"],[2631,2781,"I think I should have some say"],[2781,2882,"in the gifts."],[2919,3048,"It'll make it more believable."],[3340,3549,"Fine, yeah, fine, okay."],[3603,3661,"You can come."],[4421,4496,"Let's go."],[4496,4612,"Which mall are we going to?"],[4700,4829,"Let's go to that way."],[4829,4975,"Oh, let's go to the bank."]],"6":[[58,116,"Oh."],[187,471,"What the actual fuck?"],[738,1034,"Sam, is Maximus pulling another one"],[1034,1117,"of his goddamn"],[1117,1263,"elaborate pranks again?"],[1305,1526,"Get me a DNA test for that little girl"],[1526,1622,"that he's with."],[1951,2135,"She does kind of look like him."],[2414,2531,"So when we give these gifts"],[2531,2619,"to my parents,"],[2619,2752,"we will say they're from you."],[2940,3061,"Here, let me get this."],[3207,3345,"They're gonna love you, Max."],[3486,3883,"Also, I was thinking that"],[3883,4024,"since we're married,"],[4079,4429,"we should probably kiss once or twice"],[4500,4604,"in front of them."],[4604,4679,"Okay."],[4750,4946,"Should we use our tongues or?"],[4946,5109,"No, no, definitely not."],[5130,5251,"And absolutely no..."],[5251,5342,"Sex?"],[5342,5438,"Yeah, shh."],[5518,5647,"This is strictly business."],[5751,5880,"Anything physical outside of that"],[5880,5985,"is not happening."],[6072,6335,"What, afraid you'll fall for me?"],[6510,6619,"I just don't want Piper"],[6619,6781,"to have messy complications"],[6781,6890,"getting in the way of her"],[6890,7015,"having a good Christmas."],[7127,7215,"Let's go."],[7811,7874,"Here."],[7920,7999,"What are you doing?"],[8028,8133,"I'd never let my woman"],[8133,8224,"pick up the tab."]],"7":[[8,166,"Well, I'm not your woman,"],[166,325,"and this isn't a real relationship,"],[325,492,"and I don't want your money."],[646,746,"Attention shoppers,"],[746,967,"all bakery items are now 50% off."],[967,1067,"50% off pies?"],[1096,1292,"Quick, go grab a dozen pumpkin pies."],[1292,1472,"12 pumpkin pies, I hear this right?"],[1472,1589,"They're the best kind."],[1609,1718,"Hurry up and go, go."],[1718,1847,"What are you standing here for?"],[2039,2156,"Hello there."],[2156,2235,"Hi. - You ready?"],[2235,2373,"Yes, yeah, just these things."],[2373,2489,"Okay, great."],[2544,2723,"We have a holiday special today."],[2723,2969,"Spend 500, get 10% off,"],[2969,3153,"and you are just short 15 bucks"],[3153,3199,"if you want to"],[3199,3294,"take advantage of the deal."],[3294,3440,"Oh, great, yeah."],[3474,3641,"What do you have that's just 15 bucks?"],[3661,3853,"Will you get a move on?"],[3912,4145,"I just got here, relax."],[4145,4254,"Yeah, yeah."],[4487,4617,"Here, this will do the trick."],[4642,4763,"Okay, thank you."],[4946,5067,"Hurry up and pay."],[5334,5505,"I will pay when I'm ready."],[5505,5718,"You can wait your turn."],[6026,6101,"Thank you."],[6101,6348,"Damn, my fake wife has some fire in her."]],"8":[[350,400,"Oh, wait, wait, wait."],[400,521,"Not the pies, not the pies."],[579,621,"I can just"],[650,729,"set those on top."],[950,1042,"I'll be back."],[1188,1276,"Hi, guys."],[1376,1672,"Gonna hand you all these pies."],[1864,1951,"Thank you."],[1951,2056,"Of course."],[2118,2218,"Thank you so much."],[2218,2369,"Of course, I hope you like pumpkin."],[2410,2498,"Thank you."],[2527,2665,"She bought all 12 pies."],[2665,2740,"Don't worry, I have enough"],[2740,2823,"for everybody."],[2844,2944,"Just to give it away."],[3048,3136,"Thank you."],[3136,3232,"Merry Christmas. - Thank you so much."],[3232,3378,"Merry Christmas. - Merry Christmas."],[3803,3870,"What?"],[3870,3970,"You do that often?"],[4108,4237,"As often as I can."],[4650,4842,"We should go, we gotta pick up Piper."],[5213,5296,"Watch out."]],"9":[[588,725,"You done feeling me up?"],[884,959,"Shut up."],[959,1192,"Sorry, I was just in character, wifey."],[1192,1330,"Well, stay out of character"],[1330,1451,"until Christmas."],[1922,2039,"And don't be late."],[3161,3265,"Harrison Group?"],[3328,3424,"Do you do construction"],[3424,3532,"for them or something?"],[3595,3687,"Sort of."],[3732,3832,"Not that I'm judging,"],[3832,4079,"I just need to get my story straight,"],[4079,4266,"or my mom will eat both of us alive."],[4383,4450,"Why don't we say"],[4450,4579,"that you do mid-level management"],[4579,4688,"for Harrison Group?"],[4708,4825,"I think that's respectable."],[4954,5096,"Can we pick another company?"],[5130,5372,"No, Harrison Group is perfect."],[5397,5513,"And they'll find it impressive."],[5513,5689,"My cousin's husband works for them too."],[5689,5847,"So, it's perfect."],[6252,6489,"Oh, and wear something nice"],[6498,6614,"for Christmas dinner."],[6614,6844,"Don't worry, okay, I clean up nicely."],[6844,6977,"I wouldn't embarrass you."],[7223,7303,"Too much."],[9334,9430,"Let's go, Sam."],[9480,9659,"It's time to check out the new HQ site."],[9701,9826,"Hold on, you're covered in water,"],[9826,9989,"and you have a hair on your shoulder,"],[9989,10101,"and it's not yours."],[10218,10310,"It's my daughter's."],[10397,10485,"Daughter's?"],[10577,10723,"Get me a DNA test"],[10723,10906,"for that little girl that he's with."]],"10":[[375,504,"Hey, there they are."],[550,675,"Grandma!"],[896,950,"Dad."],[950,1059,"So glad you made it."],[1088,1234,"Aw, I missed you."],[1280,1568,"So, where is this mysterious husband"],[1568,1672,"we've heard about?"],[1672,1760,"He's coming."],[1805,1997,"Please don't tell me Maximus bailed."],[1997,2097,"Good, good, good."],[2252,2590,"So, heard you got a new hubby, sweetie."],[2590,2752,"When's he arriving?"],[2752,2965,"Oh, it's probably just some story"],[2965,3065,"she cooked up"],[3065,3294,"to stop people talking, poor thing."],[3294,3399,"Not surprising."],[3399,3566,"I mean, she's 30."],[3566,3732,"Once a woman hits that age,"],[3732,3878,"you become undateable."],[3949,4312,"Plus, a kid looks so bad on dating apps."],[4525,4688,"This is exactly why I refuse"],[4688,4842,"to come home single this Christmas."],[4854,5059,"Auntie Pamela, Debbie,"],[5059,5171,"my dating life,"],[5171,5380,"quite frankly, is none of your concern."],[5380,5593,"We're only worried about you."],[5593,5822,"All these years without a husband."],[5826,5964,"Zip it, Pamela."],[6076,6177,"You know, you always"],[6177,6314,"spoiled her rotten."],[6335,6464,"And look what happened."],[6464,6648,"She got knocked up out of wedlock,"],[6648,6831,"raising a kid all alone."],[6831,6944,"I'm not alone."],[7065,7198,"And what does this"],[7198,7399,"mysterious husband do?"],[7665,7757,"He's a manager."],[7828,7916,"Manager?"],[7957,8045,"Of what?"],[8045,8128,"Trash?"],[8270,8541,"Probably a cover for criminal activity."],[8708,8892,"You don't have to lie to us, Eva."],[8954,9309,"Actually, he's right here."],[9501,9638,"Oh, wow."]],"11":[[0,316,"Wow, he is really good looking."],[362,571,"Ah, must be AI."],[633,779,"Congratulations, Eva,"],[779,959,"on your Photoshop skills."],[959,1009,"Fake."],[1009,1101,"That's enough."],[1101,1334,"She's our daughter and your niece."],[1334,1480,"Show some respect."],[1480,1601,"Remember last year"],[1601,1768,"when I introduced you"],[1768,2014,"to my husband's nephew, William,"],[2014,2156,"and you turned him down?"],[2210,2331,"Well, guess what?"],[2331,2590,"William works for the Harrison Group now."],[2598,2902,"Makes 500-grand a year."],[2902,3098,"That's half a million."],[3098,3269,"Half a million."],[3269,3428,"Girls are lining up for him"],[3428,3616,"all the way to New York."],[3641,3941,"And speak of the devil."],[4129,4400,"Willy, you made it."]],"12":[[863,1038,"There you are."],[1038,1418,"Oh, look at you now, living the dream."],[1438,1639,"Oh, just think, Eva."],[1639,1789,"Well, you could be driving around"],[1789,1881,"in a car like that"],[1881,1968,"had you not married"],[1968,2227,"that criminal waste manager."],[2227,2331,"So married, huh?"],[2419,2594,"Is it serious?"],[2669,2773,"That's what marriage is."],[2773,2873,"It's pretty serious."],[2973,3178,"Wow, you must've rushed"],[3178,3303,"into tying the knot, huh?"],[3349,3457,"Makes sense, though."],[3457,3570,"You're not being"],[3570,3745,"a hot young thing anymore,"],[3791,3908,"dragging that kid around"],[3908,4029,"with no daddy."],[4029,4262,"Yeah, a bullet dodged, Willy."],[4308,4437,"Meanwhile, you're climbing"],[4437,4617,"the Harrison Group ladder."],[4675,4763,"That's right."],[4846,5021,"Just bought this brand new suit"],[5021,5171,"with my Christmas bonus."],[5230,5401,"Women love a man in red."],[5434,5697,"Sexy, like Santa Claus."],[5709,5880,"Wanna sit on my lap?"],[5905,6031,"Don't touch me."],[6031,6272,"Oh, so entitled."],[6272,6431,"William is a successful"],[6431,6531,"man of taste,"],[6531,6652,"not waste."],[6652,6819,"And yet, for some reason,"],[6819,6952,"he's willing to overlook"],[6952,7073,"your baggage."],[7073,7294,"I mean, look at that car!"],[7315,7494,"Could your husband afford anything"],[7494,7624,"even close to that?"],[7624,7691,"Think of the life"],[7691,7795,"I can give you and Piper"],[7795,7970,"with all my Harrison Group money."],[7970,8191,"Ditch your nobody husband,"],[8216,8420,"and marry me instead."],[8458,8554,"I wouldn't marry you,"],[8554,8733,"if you were the last man on Earth."]],"13":[[0,129,"My mom will never marry you."],[129,241,"She already has a husband."],[241,404,"He's gonna kick your butt."],[804,909,"Is that so?"],[930,1138,"Well then, where is he?"],[1184,1334,"Because I don't see him."],[1334,1484,"Does anyone see him?"],[1718,1943,"No, just like I thought."],[1989,2231,"Telling lies just like Mommy."],[2273,2464,"That puts you on the naughty list."],[2535,2677,"And let me show you"],[2677,2848,"what happens to naughty children."],[3144,3236,"Mommy!"],[3253,3399,"Baby, are you okay?"],[3420,3499,"Let's see your hands."],[3528,3628,"Oh my God."],[3661,3732,"We are gonna take her in"],[3732,3841,"and get her patched up, okay?"],[3841,3937,"Come on, honey."],[3937,4037,"Let's go."],[4154,4308,"What the hell's the matter with you?"],[4404,4546,"How dare you put your filthy hands"],[4546,4646,"on my daughter?"],[4833,4917,"Let me go."],[4938,5059,"Now, why would I go"],[5059,5217,"and do a thing like that"],[5217,5434,"when I'm having such a good time?"],[5434,5551,"Let me go!"],[6977,7165,"Touch my wife again and I will snap"],[7165,7344,"every finger that you've got."]],"14":[[79,191,"Max, you came."],[266,354,"Don't worry, sweetie."],[638,721,"Where's Piper?"],[771,892,"William hit her."],[963,1121,"Mom and Dad have taken her inside."],[1163,1322,"It looks like we have a real grinch"],[1322,1434,"to dispose of."],[1455,1576,"Well, well, well."],[1605,1747,"If it isn't the waste manager"],[1747,1931,"I've been hearing so much about."],[1968,2039,"That's right."],[2181,2356,"Now I'm about to take out the trash."],[2565,2794,"Oh, Mr. and Mrs. Smith."],[2819,2923,"It's an honor to meet you."],[2944,3032,"I'm Max."],[3053,3211,"Eva told us all about you."],[3211,3449,"From New York, polite, handsome,"],[3499,3628,"just like she said."],[3712,3966,"Wow, he wasn't AI."],[3987,4154,"See, he's real."],[4225,4333,"And he's more of a man here"],[4333,4504,"than William would ever dream to be."],[4529,4633,"Son of a bitch!"],[4662,4792,"You almost ruined my suit."],[4792,4942,"And watch the way that you drive that,"],[4988,5180,"that pristine automobile."],[5234,5367,"That car?"],[5367,5472,"Oh my God,"],[5472,5663,"that's worth more than a house."],[5755,5839,"That car?"],[5839,5939,"It was all over the news"],[5939,6118,"when the CEO of the Harrison Group"],[6118,6177,"bought it."],[6314,6531,"Wait, are you?"]],"15":[[112,354,"Like I said, I'm just Eva's husband."],[429,583,"And that's all he needs to know."],[646,834,"I'm not here to put on a show for anyone."],[871,1030,"You really are a criminal, aren't you?"],[1059,1159,"You stole it."],[1180,1267,"That car belongs to"],[1267,1393,"the CEO of my company."],[1393,1639,"Jesus, how did he get away with it?"],[1659,1805,"That's what I wanna know."],[1843,1989,"Enough, please."],[2164,2289,"I trust my daughter."],[2381,2531,"She would never marry a criminal."],[2694,2890,"Max, be honest with me."],[2932,3065,"Where did that car come from?"],[3178,3299,"How much do you want for it?"],[3332,3465,"I'll pay you more money"],[3465,3682,"than you'd make in three lifetimes."],[3707,3966,"Sir, you need a breath mint."],[4237,4400,"Hey, that's it, I'm calling the cops!"],[4400,4600,"Oh, way ahead of you."],[4600,4662,"Wait."],[4700,4792,"What?"],[4842,5021,"Are you feeling nervous, Eva?"],[5142,5388,"Oh well, too late."]],"16":[[25,271,"Listen, hon, I believe you."],[304,521,"But how could Max"],[521,688,"afford a car like that?"],[700,859,"Mr. Smith, don't worry,"],[859,971,"it's my car, okay?"],[971,1076,"It's not stolen."],[1121,1192,"Yeah?"],[1192,1363,"If it's yours, then prove it."],[1393,1468,"Thank you."],[1468,1718,"Cops will be here in 15 minutes."],[1751,1893,"Enjoy Christmas behind bars."],[1893,2089,"Okay, I'll prove that it's mine."],[2139,2289,"But then you have to get lost."],[2318,2423,"And never show your face"],[2423,2573,"around my wife or child again."],[2590,2831,"Oh, so you're a tough guy, huh?"],[2831,2973,"Well, I hope they serve eggnog"],[2973,3115,"in prison, loser."],[3115,3228,"Say one more word,"],[3228,3336,"and I'll give them a real reason"],[3336,3428,"to take me in."],[3632,3874,"Jesus, maybe he is a crime boss."],[3937,4066,"It's kinda sexy, though."],[4308,4583,"Here, title and proof of ownership."],[5338,5643,"Mr. Harrison?"],[5784,5885,"Mr. Harrison?"]],"17":[[62,145,"Mr. Harrison?"],[225,329,"Just play along."],[458,575,"Merry Christmas, Willy."],[625,759,"Now get the fuck out of here,"],[779,875,"before I kick your ass"],[875,1001,"all the way up to the North Pole."],[1017,1113,"Yes, sir!"],[1113,1272,"I'm so sorry, sir."],[1272,1384,"I, I..."],[1384,1568,"Please, accept my sincere apologies."],[2681,2990,"That, that William, what a jerk, huh?"],[2990,3103,"He fooled me."],[3103,3215,"What can I say?"],[3215,3299,"Let's not let"],[3299,3470,"this little misunderstanding"],[3470,3607,"ruin the holidays."],[3607,3724,"Oh, now you don't wanna"],[3724,3812,"ruin Christmas?"],[3812,3916,"Oh, come on, Eva,"],[3945,4141,"we were just looking out for you."],[4166,4366,"Please forgive us, Mr. Harrison."],[4387,4496,"You know my youngest son"],[4496,4662,"is graduating soon."],[4662,4950,"Do, do you think that you could help him"],[4950,5034,"get his foot in the door?"],[5034,5234,"A job at the Harrison Group,"],[5234,5380,"even in the mail room"],[5380,5522,"would open doors."],[5522,5709,"We are family, aren't we?"],[5709,5885,"Family takes care of each other."]],"18":[[104,187,"If you guys want a job"],[187,266,"at the Harrison Group,"],[266,392,"you can put in an application"],[392,475,"like everyone else."],[513,821,"Abigail, come on, talk to her for us."],[880,975,"Didn't you just say"],[975,1155,"that my daughter was undateable?"],[1176,1351,"Yeah, I think you need to take care of"],[1351,1501,"your own issues first."],[1501,1776,"My daughter is just far too busy"],[1776,1885,"living her best life"],[1885,2018,"with my new son-in-law."],[2110,2248,"Come on, guys, let's go in."],[2248,2394,"Welcome to the family."],[2706,2777,"Welcome."],[2777,2919,"Come on in, come on in."],[3219,3436,"This is your fault, Pam."],[3453,3574,"You can't tell the difference"],[3574,3803,"between AI and reality?"],[3803,3899,"My fault?"],[3908,4054,"You were the one who was pushing her"],[4054,4262,"onto that worm, William?"]],"19":[[337,513,"Hey, how do you have that car?"],[525,613,"And how do you know"],[613,738,"the CEO of Harrison Group?"],[738,825,"And how do you-"],[825,888,"I told you,"],[888,1080,"I work for Harrison Group, remember?"],[1138,1305,"I have a friend in high places."],[1343,1539,"A friend who just hands you keys"],[1539,1643,"to a million-dollar,"],[1643,1801,"one-of-a-kind luxury cars?"],[1801,2056,"Yes, it's the season of giving."],[2089,2331,"He knows people, has connections."],[2348,2548,"He's a big-deal kind of guy."],[2610,2736,"You're a crime boss, aren't you?"],[2769,2861,"Yeah, and you best not"],[2861,2977,"forget it, capiche?"],[2977,3165,"Oh my God, just don't blow your cover."],[3353,3420,"Dad."],[3420,3495,"Mom."],[3549,3632,"Thank you so much"],[3632,3737,"for letting Max and I"],[3737,3845,"stay in your home."],[3853,4141,"Honey, we're just so happy that you found"],[4141,4454,"such a handsome, strong,"],[4454,4567,"good looking-"],[4567,4750,"I think they get it, hon."],[4913,5080,"Uh, how's Piper?"],[5080,5196,"Oh, she's fine."],[5196,5405,"Why don't you guys just get settled in"],[5405,5568,"and we will go check on her."],[5568,5822,"And after your mom takes a cold shower,"],[5822,5885,"we'll come back"],[5885,6039,"and finish decorating the tree."],[6064,6131,"Great."],[6143,6247,"Great. - See you there."],[6247,6302,"Shall we?"],[6364,6464,"What are you doing?"],[6669,6735,"Okay."],[6869,7182,"Hey, was that not a breach of contract?"]],"20":[[33,225,"Relax, it was just a hug."],[592,663,"We just got here,"],[663,796,"and I'm already exhausted."],[817,1046,"You'll be okay, it's just one week."],[1046,1159,"Kill me now."],[1180,1409,"Well, I would, but I need to get paid."],[1897,2010,"What are you doing?"],[2089,2198,"That's weird."],[2260,2377,"They were so lovey-dovey to me"],[2377,2469,"just a second ago."],[2519,2577,"I don't know,"],[2577,2681,"something just feels off."],[2681,2902,"Come on, that's ridiculous."],[2919,3082,"I mean, what do you want them to do?"],[3111,3278,"Make out in front of us to prove it?"],[3315,3420,"What about this?"],[3561,3636,"Later."],[3887,3958,"Let's go."]],"21":[[0,95,"Here we go."],[254,433,"Piper is all tucked in, honey."],[433,546,"Everything looks amazing,"],[546,696,"and happy holidays."],[696,800,"To the newest member"],[800,996,"of our family, Max."],[996,1055,"Aw."],[1151,1234,"Welcome."],[1259,1317,"Cheers."],[1317,1434,"Thank you, Mrs. Smith."],[1472,1572,"Looks great."],[1572,1747,"Oh, just call me mom, honey."],[1747,1947,"I had no idea what you liked,"],[1947,2072,"so I just whipped up"],[2072,2202,"a little bit of everything."],[2202,2318,"But we all know"],[2318,2452,"what Eva's favorite"],[2452,2573,"Christmas dish is, right?"],[2706,2877,"Oh no, mom's testing him."],[2877,3028,"She's trying to see if he's legit."],[3057,3194,"You mean to tell me you two are married,"],[3194,3282,"and you don't even know"],[3282,3445,"my baby girl's favorite food?"],[3824,3949,"Eva, sweetie."],[4024,4099,"Kicking my foot."],[4099,4233,"Oh, sorry Mom, I..."],[4308,4441,"Oh, jeez!"],[4562,4679,"It's okay, I,"],[4700,4867,"look, Mom, of course he knows it."],[4867,5046,"I would like to hear Max say it."],[6373,6573,"12 pumpkin pies, I hear this right?"],[6610,6727,"They're the best kind."],[6869,7123,"Well, of course, it's pumpkin pie."],[7178,7386,"See, are you happy now?"],[7415,7494,"That's good,"],[7494,7670,"but something still feels off."],[7670,7953,"Mom, don't make it weird, okay?"],[7978,8212,"We had a whirlwind romance,"],[8212,8320,"and we eloped"],[8320,8454,"before we got to know everything"],[8454,8537,"about each other,"],[8537,8712,"but our marriage is real."],[8775,8858,"I guess your mom's"],[8858,8967,"just watching too many"],[8967,9121,"of those ReelShort shows."],[9121,9442,"Ah, now those are quality."],[9530,9751,"Okay, well, then answer this."],[9847,9972,"Where's your wedding ring, Eva?"]],"22":[[20,154,"Where's your wedding ring, Eva?"],[429,625,"I knew it was a good idea to pick this up."],[704,930,"Well, um, it's-"],[930,1126,"Silly face dropped it outside"],[1126,1284,"on the sidewalk."],[1284,1401,"Luckily I was there"],[1401,1526,"to pick it up for her."],[1559,1639,"Silly face?"],[1810,1993,"I am not paying extra for this."],[1993,2152,"Consider it a Christmas gift."],[2189,2264,"These are beautiful."],[2264,2335,"Wowzers."],[2431,2494,"Nice."],[2569,2656,"You can afford this"],[2656,2827,"on a waste manager's salary?"],[2848,3007,"Well, believe it or not, Mrs. Smith,"],[3007,3199,"there is a lot of garbage out there."],[3211,3278,"And I'm not just"],[3278,3370,"talking about William."],[3636,3737,"I agree with you there."],[3807,3983,"So come on, guys, let's eat."],[4654,4721,"Thank you."],[4754,4900,"I don't belive it, either."],[5251,5518,"And this is where y'all will be staying."],[5559,5755,"I have another room set up for Piper."],[5822,6010,"Nice and festive for you."],[6056,6222,"No complications, right?"],[6247,6348,"Sorry, honey?"],[6368,6473,"Um, Mom, you know what?"],[6473,6660,"I should stay with Piper tonight."],[6660,6756,"Oh, honey,"],[6756,6956,"newlyweds shouldn't sleep apart."],[7152,7315,"Oh, I just remembered,"],[7315,7503,"the city's turning the water off at 10."],[7503,7716,"Something about water conservation."],[7716,7857,"That means you have 15 minutes"],[7857,7912,"to shower."],[7928,8028,"15 minutes?"],[8166,8283,"Honey, it's no big deal."],[8283,8445,"Just shower together."],[8525,8654,"Shower together? - Shower together?"]],"23":[[0,120,"Just shower together."],[179,358,"Okay, you guys have a good night, okay?"],[788,884,"You heard her."],[3003,3282,"Wow, why are you stripping?"],[3361,3470,"Well, I can't take a shower"],[3470,3566,"with my clothes on."],[3624,3724,"Come on, we're wasting time."],[3724,3841,"You have 15 minutes."],[3841,3908,"Nice try."],[3908,4049,"I am not showering with you."],[4091,4225,"Alright, suit yourself."],[4225,4341,"More room for me in there."],[4416,4575,"Not if I beat you there first."],[6231,6318,"Come on, Max."],[6410,6498,"Get out of the way."],[6573,6710,"We agreed nothing physical."],[6710,6781,"You're the one"],[6781,6923,"with the dirty thoughts, wifey."],[6923,7132,"Relax, I won't touch you."],[7240,7399,"Unless you say you want me to."],[7607,7766,"But that'll cost extra."],[8692,8800,"In your dreams."],[8958,9042,"Free to join me."]],"24":[[763,809,"You know, if you keep"],[809,909,"staring at my ass,"],[909,967,"you're not gonna have"],[967,1084,"any shower water left."],[1113,1205,"You wish."],[1251,1376,"Why aren't you getting in?"],[1426,1551,"Afraid you'll fall for me?"],[1680,1814,"It's you who has to worry about"],[1814,1893,"resisting me."],[1893,1976,"Oh yeah?"],[2052,2114,"Prove it."],[3261,3399,"Holy shit."],[3678,3720,"Um."],[3770,4029,"This is, this is might be harder"],[4029,4099,"than I thought."],[4200,4275,"I'll say."],[4320,4404,"What happened to all that"],[4404,4537,"cool guy confidence?"],[4621,4863,"You still think you can resist?"],[4879,5201,"Oh baby, I don't think I want to."],[5705,5830,"Max, we shouldn't have."],[6122,6289,"Or maybe we should."],[6335,6519,"God, he's such a good kisser."],[6614,6944,"Why does this feel so familiar?"]],"25":[[166,442,"Oh God, you are so sexy."],[1234,1401,"Max, we cannot do this."],[1493,1551,"What?"],[1551,1726,"I, I didn't mean to cross any-"],[1726,1843,"It's not you, Max."],[1843,1906,"It's us."],[1926,1993,"It's this."],[1993,2072,"This is all an act."],[2072,2173,"Let's, let's not make it"],[2173,2310,"more complicated than it is."],[2410,2477,"You're right."],[2615,2706,"I'm sorry."],[2802,2907,"You don't need to be sorry."],[2907,2969,"Just..."],[3799,3899,"That birthmark."],[4375,4454,"What is that?"],[4637,4713,"It's him."],[4713,4833,"The man from New Year's."],[4833,5055,"Is he Piper's father?"]],"26":[[212,354,"Why are you acting?"],[567,642,"Oh my God."],[679,867,"Max is Piper's father."],[950,1042,"Are you okay?"],[1080,1155,"Yeah."],[1213,1288,"I just, um,"],[1355,1468,"I just got lightheaded."],[1509,1772,"I just need a few more minutes alone."],[1951,2018,"Of course."],[2314,2439,"We have a daughter together."],[2489,2548,"Oh my God."],[2652,2727,"What do I do?"],[3336,3474,"I'm gonna sleep on the floor."],[3541,3632,"You can take the bed."],[3724,3787,"Thanks."],[3987,4045,"Hey."],[4145,4262,"Are you sure you're okay?"],[4350,4500,"Look, fake marriage aside,"],[4525,4704,"I'm your husband for the next few days."],[4729,4879,"So if there's something you need,"],[4900,4979,"I can help."],[5055,5146,"I wanna help."],[5213,5367,"He's Piper's father."],[5367,5509,"He has a right to know."],[5588,5643,"Um..."],[5668,6047,"Max, how would you feel"],[6047,6272,"if you found out you had a kid?"]],"27":[[83,158,"A child?"],[250,442,"No, no, no, that's, that's impossible."],[442,813,"I'm very careful, mostly."],[1001,1076,"I just mean"],[1076,1142,"I'm not the type of guy"],[1142,1242,"to sleep around."],[1242,1476,"Family to me is a big commitment,"],[1476,1609,"and I don't want"],[1609,1801,"any loose ends, you know?"],[1881,1910,"Right."],[2072,2243,"He wouldn't want a kid tying him down."],[2293,2464,"I shouldn't tell him about Piper."],[2556,2656,"Why do you ask?"],[2756,2986,"No reason, just, just curious."],[3036,3157,"You know, I feel like"],[3157,3361,"you're going somewhere with this."],[3361,3432,"What?"],[3561,3616,"No."],[3641,3912,"Well then, can I ask you a question?"],[3991,4058,"Shoot."],[4546,4675,"Where did you get these?"],[4725,4946,"And how did you know my exact size?"],[4946,5130,"I did not get those."],[5130,5292,"I don't know where those came from."],[5305,5430,"Are you sure you're just"],[5430,5668,"not trying to break the contract?"],[5868,5947,"Give me the purse."],[5947,5997,"Give me those."],[6018,6068,"Give me."],[6097,6156,"Give those-"],[7303,7695,"Eva, the truth is, is that I..."],[7932,8008,"Go, go, go, go, go."],[8141,8229,"Just a second."],[8270,8350,"Come in."]],"28":[[25,79,"Hey, hon."],[129,383,"Oh, sorry for interrupting,"],[383,700,"but Piper is asking for a bedtime story"],[700,804,"before I tuck her in."],[804,863,"Do you think you could"],[863,946,"take this one, dad?"],[946,1121,"We're kind of in the middle of something."],[1176,1280,"I can see that."],[1372,1526,"Well, why don't I read it to her?"],[1576,1735,"I mean, if you don't, if you don't mind."],[1805,1935,"Well, atta boy."],[1964,2127,"You know what, just put a shirt on."],[2127,2264,"I'm gonna go get her."],[2264,2344,"Piper!"],[2373,2502,"Here comes grandpa."],[2777,2915,"He sprang to his sleigh,"],[2915,3086,"to his team gave a whistle,"],[3119,3265,"and away they all flew,"],[3278,3432,"like the down of a thistle."],[3478,3616,"But I heard him exclaim,"],[3653,3782,"as he drove out of sight,"],[3878,4029,"Merry Christmas to all,"],[4083,4329,"and to all a good night."],[4587,4788,"If Piper knew he was her real dad,"],[4788,4917,"she'd be over the moon."],[4996,5088,"Goodnight, Piper."],[5509,5634,"Is her Dad still around?"],[5693,5893,"Yeah, but he doesn't know it,"],[5930,6110,"because you're her dad."],[6110,6189,"No."],[6247,6585,"That man has no idea what a treasure"],[6690,6810,"he's missing out on."],[7073,7223,"So you really think so?"],[7311,7428,"From the bottom of my heart."],[7557,7670,"Maybe I should tell him."],[7699,7795,"He deserves to know."],[8445,8525,"Max."]],"29":[[158,367,"You are Piper's father."],[1046,1201,"I'll tell you when the time is right."],[3641,3757,"Where's Piper?"],[3845,3962,"She must've snuck off"],[3962,4062,"while we were asleep."],[5647,5826,"God, he's such a good kisser."],[6677,6798,"Just gonna kiss and run?"],[6940,7052,"Not on my watch."],[7428,7586,"Yeah, this."],[7628,7757,"I remember this."]],"30":[[855,1076,"Good morning, you two love bugs."],[1096,1322,"How was your stay at Chateau Smith?"],[1422,1530,"Good morning, Mrs. Smith."],[1530,1655,"It was, was great."],[1701,1789,"It's wonderful."],[1789,1956,"Well, it's about to get even better."],[2210,2289,"Oh, no."],[2344,2419,"What is that?"],[2419,2577,"Sardines and saltines."],[2577,2794,"It's a Smith family classic."],[2794,2952,"It was my gram gram's favorite"],[2952,3065,"during wartime."],[3065,3140,"Don't be shy."],[3140,3265,"Go ahead, grab a handful."],[3432,3549,"Max, you don't have to."],[3549,3666,"No, no, it's okay."],[3666,3728,"It's a"],[3782,3974,"Smith family staple."],[4967,5005,"Here you go."]],"31":[[658,729,"Good?"],[875,942,"Good?"],[1005,1076,"Scrumptious."],[1205,1347,"Well, you two better get dressed."],[1347,1484,"You gotta go see Aunt Miranda."],[1735,1797,"Could I, um,"],[1830,1993,"could I have some water, please?"],[1993,2131,"That means there's no escaping"],[2131,2327,"Aunt Miranda and her brood this year."],[2402,2506,"What's the deal with them?"],[2535,2660,"Every year, Aunt Miranda"],[2660,2781,"bullies Piper and I."],[2798,3019,"Says Piper's a fatherless brat"],[3019,3086,"and I'm..."],[3244,3340,"Hey, don't worry."],[3386,3553,"I'll protect you and Piper."],[3820,3991,"Better have Sam on standby tonight,"],[3991,4087,"just in case."],[4158,4387,"Well, looks like it's time"],[4387,4508,"to get dressed up then."],[5580,5684,"Wait, that earring."]],"32":[[8,191,"Wait, that earring."],[250,312,"You like it?"],[400,492,"I was so bummed"],[492,604,"when I lost the matching one"],[604,667,"years ago."],[667,867,"Did you lose it seven years ago?"],[938,1026,"I don't really"],[1026,1105,"remember the details,"],[1105,1476,"but luckily I was able to find a new pair."],[1543,1780,"Right, it's just a common earring."],[1801,1914,"Anyone could have it."],[1914,2097,"Maybe I'm reading too much into it."],[2118,2218,"She can't be the woman"],[2218,2335,"from seven years ago."],[2565,2932,"So Eva and Piper still aren't here."],[3011,3199,"But Derek said that Eva got married."],[3299,3453,"What kind of man"],[3453,3632,"could she possibly have landed?"],[3666,4004,"Aging single mom, slim pickings."],[4004,4279,"I heard he's in waste management."],[4291,4408,"That explains it."],[4408,4587,"She's probably too embarrassed"],[4587,4696,"to show up."],[4729,4850,"Oh, please, Miranda."],[4850,4909,"You know,"],[4909,5063,"Eva is your niece."],[5063,5242,"Oh, come on, Grandpa."],[5242,5422,"Everyone knows Eva had a kid"],[5422,5613,"with a random one-night-stand."],[5626,5801,"Her track record speaks for itself."],[5801,5885,"Exactly."],[5885,6031,"Not like my Sierra,"],[6031,6210,"married to a legal adviser"],[6210,6368,"for Harrison Group."],[6569,6731,"Ah, they're here."],[6794,6923,"Merry Christmas, everybody."]],"33":[[45,162,"Merry Christmas, everybody."],[162,250,"Merry Christmas."],[429,571,"You must be Grandpa Harold."],[571,625,"I am."],[692,888,"I'm Eva's husband, Max."],[888,1021,"Pleasure to meet you, welcome."],[1021,1172,"You're Eva's husband."],[1242,1488,"But you're gorgeous."],[1659,1876,"But not as handsome as you."],[1897,1989,"Look at you two."],[2010,2056,"You look like"],[2056,2193,"you just stepped out of a movie."],[2223,2352,"Merry Christmas, Grandpa."],[2381,2460,"Merry Christmas."],[2544,2669,"This is from Max and I."],[2669,2781,"Oh my goodness."],[2781,2877,"Thank you, Eva."],[2894,3073,"Let me grab that for you, Daddy."],[3174,3345,"Oops, oh my bad."],[3345,3611,"Oh, a homemade gift."],[3611,3762,"How thrifty."],[3787,4008,"Not all gifts are about the price tag."],[4024,4258,"Mommy's right, you mean old hag."],[4258,4421,"You little..."],[4542,4642,"You will not lay a"],[4642,4800,"hand on my daughter."],[4800,4950,"Or you'll lose yours."],[4979,5309,"Ah, I think you broke my wrist."],[5309,5522,"Look what you just did to my mother!"],[5522,5693,"My husband is Harrison Group's"],[5693,5847,"top legal adviser."],[5847,6039,"He could ruin your life!"]],"34":[[421,563,"Honey, are you, are you okay?"],[579,650,"I'm fine."],[650,750,"I'm just wet, hon."],[796,859,"It's okay."],[880,934,"It's okay."],[1176,1263,"What are you-"],[1422,1543,"Don't you dare"],[1543,1705,"disrespect my husband."],[1705,1876,"Did you just slap me?"],[1876,2081,"Yeah, next time it'll be a closed fist."],[2081,2231,"You're a fucking psycho!"],[2231,2327,"You know what, Sierra?"],[2327,2448,"I can take your little insults,"],[2448,2677,"but leave my family out of this!"],[2894,3128,"Her family, she means me."]],"35":[[387,479,"You okay, honey?"],[479,721,"Do I look okay to you, dumbass?"],[721,813,"Do something."],[884,1046,"You don't know who you're messing with."],[1046,1146,"I've got the full weight"],[1146,1305,"of the Harrison Group behind me."],[1305,1480,"Oh wow, I'm sure the CEO"],[1480,1601,"would love to hear"],[1601,1805,"that you're using his company's name"],[1805,1914,"to bully people."],[1943,2093,"Like, like you'd have any idea"],[2093,2223,"how a CEO thinks."],[2223,2323,"Let's call him."],[2339,2489,"I'm sure he'd be more than happy"],[2489,2581,"to be on my side."],[2635,2831,"Please, who do you think you are?"],[2952,3044,"Enough!"],[3211,3336,"There will be no arguing"],[3336,3449,"during Christmas."],[3503,3595,"Fine, Dad."],[3653,3799,"Let it go, Nathan."],[3832,3995,"They're just jealous."],[4137,4229,"For Grandpa's sake,"],[4229,4346,"I'll let you off easy."],[4358,4717,"I think you owe Nathan a thank you."],[4750,4934,"I think you owe me a thank you"],[4934,5092,"for slapping some sense into you."],[5092,5217,"Do you want me to get the other cheek?"],[5217,5355,"All right, that's enough."],[5384,5668,"Everyone come inside and sit down."],[7657,7770,"Is this a joke?"],[7907,8074,"Can you please pass me some food?"],[8074,8149,"Hold it."],[8149,8341,"Who said you could eat anything else?"],[8370,8654,"My husband and I paid for this feast."]],"36":[[8,300,"My husband and I paid for this feast."],[362,604,"King crab, fresh from Alaska,"],[638,771,"and grass-fed Wagyu."],[850,975,"Three times the price,"],[1009,1180,"50 times the flavor,"],[1205,1401,"and you don't get a single bite."],[1438,1551,"It's just petty."],[1551,1805,"Maybe so, but gourmet food"],[1805,2089,"isn't meant for bottom feeders."],[2089,2177,"Fine."],[2248,2423,"And we won't stay and eat with you."],[2435,2527,"Come on, let's go."],[2527,2631,"No, no."],[2677,2961,"Don't you dare leave our family dinner."],[2998,3107,"Grandpa, I'm sorry,"],[3107,3274,"but they're treating us like-"],[3299,3390,"I know, dear."],[3424,3599,"I just want to have our family together."],[3599,3874,"Fine, we'll let the strays sit,"],[3874,3987,"and eat with us."],[3987,4158,"Better a stray than a bitch."],[4158,4237,"What was that?"]],"37":[[16,212,"I just want to have our family together."],[308,483,"Fine, we'll stay."],[588,767,"Can I have a little nibble?"],[767,875,"It's okay, sweetie."],[909,1088,"We'll get something right after."],[1088,1272,"Like drive-thru?"],[1292,1534,"I hope you enjoy food poisoning."],[1534,1697,"That will be a particularly"],[1697,1918,"memorable Christmas present."],[2035,2143,"No strays."],[2143,2214,"Aw."],[2214,2327,"Sweetie, sweetie, are you okay?"],[2377,2460,"Yeah, it's fine."],[2506,2665,"You hit my child!"],[2665,2790,"You're fucking crazy."],[2790,2990,"Well, if you teach her some manners,"],[2990,3165,"maybe I wouldn't have to."],[3516,3616,"Don't worry, baby."],[3616,3707,"I'll handle it."]],"38":[[20,112,"Don't worry, baby."],[112,204,"I'll handle it."],[579,621,"Piper,"],[700,821,"sweetie, are you ready"],[821,942,"to try the best food"],[942,1076,"you've ever had in your life?"],[1338,1430,"Okay, sweetheart."],[1455,1647,"Give me two minutes and one phone call."],[1668,1951,"As if you have a chef on speed dial."],[1951,2056,"Actually, I do."],[2160,2339,"He's such a liar."],[2339,2494,"This ought to be hilarious."],[2515,2694,"Oh, it will be."],[2882,2944,"Sam."],[3040,3157,"Yeah, send the troops,"],[3157,3324,"and bring that king crab"],[3324,3411,"from Antarctica."],[3411,3536,"I'm already on my way."]],"39":[[0,221,"Bring that king crab from Antarctica."],[221,358,"I'm already on my way."],[558,650,"You hear this guy?"],[650,813,"He wants the best king crab"],[813,913,"in the world."],[934,1063,"From Antarctica."],[1176,1384,"Now I get why you married him, Eva."],[1384,1664,"His silly delusions are just adorable."],[1689,1776,"Max,"],[1776,1889,"what are you doing?"],[1889,1997,"Don't worry about it, sweetheart."],[2027,2202,"Santa is already on his way."],[2202,2273,"Actually,"],[2356,2927,"five, four, three, two, one."],[3174,3328,"A helicopter?"],[3912,4079,"There's no way."]],"40":[[200,316,"How did you pull this off?"],[316,442,"Sam is like family."],[467,588,"Thought I'd introduce you two."],[588,675,"Thanks, boss."],[796,880,"Boss?"],[900,1101,"Eva's always been genuine with me."],[1126,1197,"Maybe it's time she"],[1197,1355,"knew who I really am."],[1355,1501,"Eva, I think it's time"],[1501,1651,"you actually know the truth."],[1722,1926,"I'm Maximus Harrison."],[2027,2394,"You're the CEO of Harrison Group?"],[2394,2464,"Mm-hmm."],[2731,2827,"Come on."],[2936,3123,"You can stop kidding around."],[3144,3261,"If you were the CEO,"],[3261,3349,"why would you be here"],[3349,3503,"pretending to be my husband?"],[3561,3712,"No, I actually am the CEO."],[3712,3903,"Come on, you can stop the charade."],[3928,4049,"Okay, this is just another favor"],[4049,4200,"from that big, big friend, isn't it?"],[4200,4396,"Eva, I'm not pretending."],[4575,4800,"Mr. Harrison, the Antarctic king crab,"],[4800,4938,"as you requested."]],"41":[[20,196,"How is this possible?"],[196,533,"This loser brings Antarctic king crab,"],[533,817,"and has his own personal chef?"],[846,996,"Who are you?"],[996,1201,"I told you, I'm Eva's husband."],[1272,1493,"That chef called him Mr. Harrison."],[1539,1714,"Wait, no, hold on."],[1872,1997,"You're the actual CEO"],[1997,2114,"of the Harrison Group?"],[2310,2427,"You're, you're worth more than"],[2427,2548,"some whole countries."],[2640,2752,"Some of the small ones."],[2831,2940,"I mean, you know that."],[3023,3107,"You work for me."],[3136,3207,"Oh God."],[3261,3411,"I insulted my own boss."],[3461,3574,"I'm finished."]],"42":[[33,291,"Oh God, I insulted my own boss."],[358,454,"I'm finished."],[492,558,"Didn't think"],[558,700,"Max would commit this hard."],[700,917,"Pretending to be CEO is a hell of a move."],[917,1105,"Worth every penny I'm paying him."],[1105,1343,"For tonight, your feast ends,"],[1372,1593,"and with that, your career."],[1647,1739,"You're fired."],[1760,1851,"Fired?"],[1881,1956,"Sam."],[2352,2423,"Fired?"],[2423,2652,"Oh God, I can't be fired!"],[2744,2836,"What?"],[2923,3040,"Mr. Harrison, please."],[3040,3169,"You can have as much crab"],[3169,3244,"as you want."],[3244,3478,"Please, Mr. Harrison, I'll do anything."],[3524,3732,"Guys, take out the trash."],[4283,4362,"And you."],[4383,4491,"Oh, me?"],[4592,4763,"Mr. Harrison, come on."],[4763,4934,"That was a Christmas joke."],[4954,5096,"Family tradition."],[5096,5180,"Yeah, well,"],[5180,5330,"there's a new family tradition."],[5380,5447,"Sam."],[5851,5955,"Will you do me the honors?"],[6118,6197,"Gladly."],[6556,6719,"Merry Christmas, Aunt Miranda."],[7011,7173,"Father, do something."],[7244,7411,"Yeah, you kind of deserve that."],[7411,7532,"I'm leaving!"],[7670,7811,"Pumpkin, my favorite."]],"43":[[95,171,"Come on, sweetie."],[196,379,"Daddy had this crab fly in just for you."],[450,563,"Eat as much as you want."],[563,700,"Thanks, Daddy."],[1013,1213,"I am so sorry I ruined your Christmas."],[1213,1313,"I just couldn't take them"],[1313,1418,"treating you like that."],[1418,1747,"Honestly, this is the best Christmas"],[1747,1839,"I've ever had."],[1839,2014,"Well, if you want, we can have many more."],[2031,2122,"Just like this."],[2231,2360,"Does he really mean that?"],[2389,2560,"Or is he just playing the part?"],[2560,2865,"I can't tell, and that terrifies me."]],"44":[[333,483,"Merry Christmas, Mrs. Harrison."],[483,600,"I brought you a gift."],[600,713,"Here's the paternity test"],[713,855,"between the boss and that little girl."],[1368,1651,"Oh, this is wonderful."],[1689,1956,"Sam, I have a granddaughter!"],[1997,2135,"Tell me everything."],[2152,2318,"Ms. Eva Smith, single mother,"],[2318,2439,"small town gal,"],[2460,2560,"didn't finish high school,"],[2560,2681,"currently works in retail."],[2761,2986,"Maximus, I thought I raised you better."],[3073,3244,"A high school dropout?"],[3286,3457,"In the Harrison family?"],[3561,3712,"Not a chance."],[3983,4179,"She is clearly unfit"],[4179,4350,"to raise my granddaughter."],[4350,4446,"Maximus seems to like her."],[4446,4529,"Silence."],[4567,4763,"Get me the address where she works."],[4763,4921,"It's Happy Heels on Broadway."],[4938,5063,"That's nice."],[5100,5238,"We own that one."],[5259,5347,"Good work."],[5363,5534,"But take off that stupid hat."],[6552,6598,"Thanks."],[6639,6873,"So your dad insisted that I try this wine"],[6873,7048,"that he's been saving for 20 years."],[7248,7332,"Sounds like he's happy"],[7332,7457,"with his new son-in-law."],[7457,7582,"And how about you?"],[7953,8016,"Me?"],[8058,8120,"Yeah."],[8258,8416,"Are you happy with your new husband?"],[8783,8863,"Eva."]],"45":[[450,550,"That birthmark."],[583,825,"Family to me is a big commitment,"],[825,1071,"and I don't want any loose ends,"],[1096,1163,"you know?"],[1217,1409,"Maximus, there's so much we don't know."],[1418,1584,"So much we're not telling each other."],[1810,1985,"No feelings, no complications."],[1985,2102,"That's what we agreed upon."],[2102,2248,"Yeah, I didn't sign a contract."],[2373,2464,"Max."],[2494,2598,"I guess you're right."],[2802,2877,"It's cold."],[3003,3186,"Maybe I'll go grab some more firewood."],[3315,3390,"Max."],[3566,3703,"I need to tell you something."],[3895,4029,"Something important."],[4066,4187,"What's gotten into her?"],[4295,4429,"Is she hiding something?"],[4446,4525,"Is this the part"],[4525,4667,"where you tell me there's no Santa?"],[4792,4909,"I haven't been completely"],[4909,5005,"honest with you."],[5209,5313,"Piper is..."]],"46":[[83,183,"Piper is-"],[200,421,"Mommy, Daddy, my hand hurts."],[442,554,"Oh, sweetie."],[579,663,"Oh my gosh."],[675,771,"It's all swollen."],[771,859,"Must've been when that witch"],[859,1026,"smacked her with the fork earlier."],[1026,1146,"Listen, you stay here with Daddy."],[1146,1222,"Mommy's gonna go get"],[1222,1326,"a first aid kit, okay?"],[1593,1680,"Come on, Piper."],[1922,1976,"Alright."],[1976,2081,"Okay, let me see."],[2398,2652,"I promise I won't let anyone"],[2652,2790,"hurt you or Mommy again."],[2811,2919,"But that's not true."],[2932,3103,"You're leaving after Christmas,"],[3103,3190,"aren't you?"],[3415,3486,"Daddy!"],[4258,4371,"Don't you dare"],[4371,4533,"disrespect my husband!"],[4817,4971,"Well, maybe I don't have to leave."]],"47":[[87,229,"Well, maybe I don't have to leave."],[229,304,"Really?"],[304,433,"Please stay, Daddy."],[800,942,"You think it will scar?"],[1397,1522,"I wouldn't worry about it."],[1522,1697,"Scars make you look like a badass."],[1718,1814,"I have one too."],[1914,1993,"That."],[2102,2173,"I got that one"],[2173,2293,"when I was about your age."],[2293,2406,"Some punk came at me"],[2406,2581,"with a switchblade."],[2598,2652,"Really?"],[2652,2744,"No way."],[2769,2994,"No, it was actually a cactus."],[3028,3144,"But it's still cool."],[3332,3445,"I have something like that"],[3445,3557,"on the back of my neck."],[3866,4087,"Piper, how long have you had that?"],[4099,4337,"My mom said I had that when I was four."],[4879,4988,"And how old are you?"],[4988,5075,"Six."],[5113,5201,"Six?"],[5201,5313,"That one-night-stand"],[5313,5455,"was about seven years ago."],[5501,5638,"Okay, I found the first aid kit."],[5663,5772,"Eva, are you sure"],[5772,5868,"we haven't met before?"]],"48":[[41,179,"What do I even say?"],[179,371,"And how do I explain it to Piper?"],[417,571,"Sorry, honey, this man's your dad"],[571,709,"and he didn't know you existed"],[709,792,"until now."],[892,1067,"Um, yeah."],[1297,1405,"Can I see your hand, sweetie?"],[1505,1589,"Eva."],[1989,2089,"Okay, look."],[2348,2431,"Piper is-"],[2982,3044,"Go on."],[3645,3791,"That must be an emergency."],[3916,3991,"Excuse me."],[4024,4162,"Sorry, I'll take this."],[4237,4295,"Yeah."],[4813,4950,"Mommy, are you okay?"],[5009,5075,"Yeah."],[5196,5313,"Mommy's just realizing"],[5313,5430,"she's a coward."],[5513,5643,"I don't even have the guts"],[5643,5751,"to tell the truth."]],"49":[[70,291,"Why haven't you picked up my calls?"],[316,450,"I'm telling you, Max,"],[450,646,"that woman is manipulating you."],[675,855,"She's a high school dropout,"],[855,1059,"doesn't even have a decent job,"],[1088,1159,"and she's unfit"],[1159,1309,"to raise my granddaughter."],[1368,1534,"I'm Eva's husband, Max."],[1534,1751,"That man has no idea"],[1751,2097,"what a treasure he's missing out on."],[2377,2519,"I'm sorry, Max."],[2519,2598,"You can't know"],[2598,2690,"Piper's your daughter."],[2690,2844,"Your mother would take her away."],[2844,3061,"After Christmas, it's over."],[3274,3349,"Eva?"],[3428,3699,"Maximus, are you even listening to me?"],[3774,3862,"No, Mom, Mom, listen,"],[3862,3991,"I'm sorry, okay?"],[3991,4104,"Eva's my wife,"],[4104,4216,"and I've made up my mind."],[4233,4325,"I'm not leaving her."],[4525,4587,"Eva?"]],"50":[[354,433,"Thank you."],[433,529,"Hey, I wanna give you this."],[679,738,"For me?"],[788,900,"Aw, thank you."],[900,1051,"This is for you, Grandma."],[1522,1626,"Oh, wow."],[1718,1810,"That's so cool."],[1810,1868,"Did you make it?"],[1960,2110,"Derek, this is from"],[2168,2235,"Eva and I."],[2260,2431,"Oh, thank you so much."],[2456,2510,"Just..."],[2510,2598,"Thanks, guys."],[2598,2702,"glad you're here."],[2861,2952,"What do we got?"],[3003,3073,"Wow."],[3098,3244,"Damn, these are nice."],[3274,3474,"Grandpa, language."],[3474,3578,"Little ears."],[3699,3753,"Sorry."],[4058,4283,"Piper, do you wanna go see your present?"],[4283,4446,"In the other room by the train set."],[4475,4550,"Here, I'll go with you."],[4550,4675,"Remember the song that we sing?"],[4704,4796,"Ready? - Mhm."],[4796,5025,"Grandma got run over by a reindeer."],[5025,5113,"We will be back, guys."],[5167,5292,"Walking home from our house,"],[5292,5401,"Christmas Eve."],[5780,5880,"You never told me."],[6160,6281,"Have we met before?"]],"51":[[0,108,"Have we met before?"],[266,529,"She's unfit to raise my granddaughter."],[792,955,"I don't know what you're getting at."],[1092,1413,"Eva, I have the same birthmark as Piper."],[2202,2310,"I don't know what you're talking about."],[2310,2423,"Lots of people have birthmarks."],[2423,2527,"They're very common."],[2556,2673,"I feel so awful."],[2673,2844,"But I can't lose my child."],[2898,3057,"No matter how I feel about him."],[3294,3357,"Maybe."],[3620,3695,"Are you okay?"],[3945,4095,"Were the clogs a bad idea?"],[4237,4408,"No, I'm fine."],[4546,4621,"Um."],[4725,4875,"Oh, I almost forgot."],[5121,5213,"I got you this."],[5255,5372,"You got me a gift, too?"],[5430,5530,"'Tis the season."],[5601,5684,"Open it."]],"52":[[913,996,"Gloves."],[1126,1226,"Did you make these?"],[1301,1363,"Yeah."],[1434,1576,"I know this is a fake marriage,"],[1576,1747,"but it's Christmas."],[1822,1947,"You've already done so much for me."],[1947,2043,"I just wanted to do"],[2043,2143,"a little something for you."],[2406,2489,"How do they feel?"],[2573,2648,"Warm, right?"],[2702,2752,"Yeah."],[2827,2898,"Warm."],[3036,3115,"Soft."],[3370,3449,"Perfect."],[3816,3908,"Thank you, Eva."],[4029,4129,"I've never gotten anything"],[4129,4250,"this meaningful before."],[4421,4479,"Really?"],[4600,4817,"Yeah, my mom, she partied all the time."],[4850,5150,"And I got gifts, plenty of them, but..."],[5292,5480,"I don't think she ever bought one herself."],[5584,5768,"Nothing personal."],[5851,5930,"Well, you deserve it."],[6081,6168,"You're a good guy."],[6260,6681,"And someday you'll find someone special"],[6681,6915,"to spend all your Christmases with."],[7036,7203,"What if that day's today?"],[7494,7582,"What if I already"],[7582,7707,"found someone special?"],[7920,7987,"Right here."]],"53":[[905,1067,"Max, we can't."],[1247,1363,"If you want me to stop,"],[1405,1530,"you better tell me right now."],[1972,2035,"I won't."],[2118,2235,"I don't want you to stop."],[2852,2990,"No matter how many years pass,"],[2990,3157,"I still can't resist him."],[4587,4667,"I want you."],[5547,5830,"God, you are driving me fucking insane."],[6181,6256,"Piper?"],[7102,7178,"Piper?"],[7353,7453,"She can't see-"]],"54":[[638,717,"Eva?"],[1046,1213,"Grandma, I'm up here."],[2469,2615,"That was way too close."],[2615,2681,"Yeah."],[2765,2840,"We would have gotten"],[2840,2948,"on the naughty list."],[3319,3486,"Sometimes it's fun to be naughty."],[3762,4012,"Can I still unwrap my present?"],[4216,4375,"You still haven't given me mine."],[4875,4971,"Let me give it to you."]],"55":[[2435,2619,"Who's calling me this early?"],[2994,3048,"Hello?"],[3048,3224,"Hello, Eva Smith."],[3244,3365,"I'm Max's mother."],[3390,3495,"Name your price."],[3528,3636,"What will it take for you"],[3636,3770,"to leave my son alone?"],[3870,3941,"What?"],[3962,4066,"We both know my son"],[4066,4258,"is way out of your league."],[4287,4400,"Take the money,"],[4400,4496,"leave my granddaughter"],[4496,4700,"with us, and go."],[4700,4888,"My son will find a better wife,"],[4888,5084,"and a better mother for his child."],[5084,5201,"Piper is my daughter,"],[5246,5372,"and no amount of money you offer"],[5372,5505,"could ever make me give her up."],[5547,5655,"So you keep your money,"],[5655,5751,"and I'll leave on my own,"],[5751,5964,"but I am not handing Piper over to you."],[6281,6414,"Well, there's my beautiful wife."],[6886,6961,"You okay?"],[7340,7465,"Look, we made it through Christmas,"],[7691,7782,"so I think it's best"],[7782,7907,"we go our separate ways."],[8078,8179,"What are you talking about?"],[8266,8354,"It's over."],[8395,8529,"It's not that hard to understand."],[8900,8992,"Eva, wait!"]],"56":[[258,433,"So last night meant nothing to you?"],[930,1121,"Max, it's not real."],[1180,1288,"None of it was real."],[1330,1526,"So, this is just a goodbye?"],[1743,1830,"I didn't realize I was so"],[1830,1947,"disposable for you."],[2022,2323,"Look, last night,"],[2515,2623,"I let my guard down,"],[2665,2756,"but I'm a mother,"],[2756,2940,"and my choices affect Piper."],[2940,3044,"And being with you can mess up"],[3044,3186,"everything between us."],[3207,3390,"Just tell me what you need."],[3470,3578,"I'll do whatever it takes"],[3578,3687,"to be a good husband,"],[3732,3824,"a good father."],[3916,4033,"Just say the word."],[4554,4654,"You don't get it."],[4808,4900,"You don't get it."],[5588,5659,"I think it's time"],[5659,5801,"Piper and I go back to New York."],[6302,6435,"I won't give up on us."]],"57":[[1280,1363,"Are we here?"],[1447,1518,"Yes."],[1609,1764,"As much as I don't want us to be,"],[1851,1931,"we're back."],[2235,2414,"Piper, sweetie, wake up."],[2427,2498,"We're home."],[2932,3086,"How can she just walk away?"],[3849,3891,"Don't forget,"],[3891,3995,"you have to meet my mom."],[4045,4170,"It's part of the agreement too."],[4279,4471,"Can I just pay you a little extra"],[4471,4550,"and skip it?"],[4571,4675,"Hey, you promised."],[4733,4909,"Eve, I haven't asked you for much."],[4938,5096,"Can you do this for me, please?"],[5309,5388,"All right, fine."],[5447,5513,"When?"],[5638,5722,"Two days."],[5784,5905,"I'll come pick you up."],[5905,5976,"No need."],[6039,6172,"Just send me the address,"],[6172,6260,"and I'll meet you there."],[6777,7002,"I know you and Mommy fought."],[7065,7286,"But she still really likes you."],[7286,7478,"So don't give up, okay, Daddy?"],[7553,7640,"Thank you, sweetie."],[7686,7761,"If there's one thing"],[7761,7874,"you should know about your Daddy,"],[7912,8141,"I always fight for the ones I love."]],"58":[[867,1009,"Eva is meeting my mother today."],[1046,1217,"Time to finally tell her the truth."],[1305,1372,"Boss?"],[1476,1543,"Boss?"],[1889,1964,"Lady and gentlemen,"],[1989,2114,"I am so sorry."],[2214,2352,"I need to go win back my family."],[2431,2498,"Family?"],[2544,2635,"Boss, you okay?"],[2702,2798,"Never better."],[3015,3119,"Go get her, Max."],[3465,3632,"Give us your best smile."],[3641,3874,"Ah, there he is."],[3874,4079,"Maximus, darling."],[4116,4316,"I have some prospects for you."],[4316,4625,"Nice high society girls from the city."],[4900,4967,"Oh."]],"59":[[45,120,"I told you,"],[120,271,"I already found the woman I love."],[525,571,"Well..."],[917,1117,"Maximus, stop this."],[1159,1455,"That Eva woman is scamming you, son."],[1526,1726,"Tell me what kind of woman you want"],[1726,1872,"and I'll find you another."],[1889,2193,"You are heir to the Harrison dynasty."],[2193,2331,"You- - No, I'm not."],[2494,2560,"Oh?"],[2573,2752,"I work in waste management,"],[2752,2982,"and I'm a secret crime boss."],[2982,3240,"I'm Eva's husband, and I'm a father."],[3440,3516,"What?"]],"60":[[1151,1247,"That's her."],[1272,1430,"The woman who got my son"],[1430,1580,"head-over-heels."],[1735,1893,"Hi, welcome in."],[1893,2014,"Can I help you find something?"],[2106,2243,"I want to try those."],[2527,2602,"Awesome, I'll get them"],[2602,2669,"for you right away."],[2840,3019,"Are you sure you wouldn't want"],[3019,3194,"something more sensible?"],[3399,3541,"No, no, no."],[3561,3682,"I know what I want."],[3716,3816,"Size seven."],[3970,4137,"Old bitty can't even walk,"],[4137,4329,"but she wants $3,000 heels."],[4379,4592,"Come on, she wants the white shoes."],[5088,5176,"Ignore her,"],[5176,5351,"she's just grumpy over the holidays."],[5405,5576,"Here, let me help you put them on."],[5943,6206,"She seems kind."]],"61":[[221,437,"I shouldn't be that impressed."],[437,629,"She's just doing her job."],[779,859,"How do they feel?"],[900,1046,"Well, I love the style."],[1109,1222,"But it's too small."],[1242,1418,"I think I need to size up."],[1480,1639,"Maybe my feet are still growing."],[1947,2022,"Right away."],[2064,2152,"I'll be right back."],[2227,2456,"She's not only kind, she's patient."],[2489,2619,"Was I wrong about her?"],[4116,4333,"Are you gluing the heel back on?"],[4487,4658,"Well, who gives a shit?"],[4658,4796,"She can't walk."],[5067,5321,"That's just pure evil."]],"62":[[0,229,"Oh, come on, Saint Eva."],[271,442,"She's in a wheelchair."],[442,508,"Who cares?"],[508,642,"It's the last pair."],[658,859,"I get paid commission."],[1372,1580,"I'm not doing that, Vanessa."],[1697,1755,"See?"],[1835,2077,"This is your whole problem."],[2139,2431,"This is why you'll always be broke."],[2531,2777,"I don't care if she can walk or not."],[2802,2982,"I'm not selling her junk."],[3078,3294,"She has to deal with people like this?"],[3370,3582,"People who insult her all day?"],[3645,3841,"I'm your manager."],[4170,4404,"Sell the old bitty the shoes,"],[4450,4558,"or you're fired."]],"63":[[196,329,"Did I stutter?"],[713,842,"You don't have to fire me."],[1084,1172,"I quit."],[1685,1818,"I don't work here anymore."],[1947,2181,"Listen, don't buy the shoes."],[2277,2335,"They're broken."],[2335,2419,"Spend your hard-earned money"],[2419,2506,"elsewhere, okay?"],[2519,2765,"You're a good person after all."],[2902,3061,"Looks like I misjudged you."],[3165,3244,"I'm sorry?"],[3424,3641,"Why are you still here, Eva?"],[3670,3757,"Get out."],[4162,4216,"No."],[4316,4446,"You're not disabled?"],[4475,4662,"Selling a broken heel to someone"],[4662,4829,"you thought was handicapped?"],[4892,5075,"Absolutely shameful."],[5113,5205,"Who are you?"],[5259,5426,"I am the chairwoman"],[5497,5663,"of the Harrison Group,"],[5672,5822,"and the owner of this store."],[5947,6089,"You're Eleanor Harrison?"],[6143,6331,"Mother of the CEO?"],[6331,6414,"I am."],[6498,6719,"And you, my dear, are fired."],[6848,6931,"What did I do?"],[7190,7369,"You are a good person."],[7486,7766,"From now on, this store is yours to run."],[8087,8233,"Are, are you serious?"]],"64":[[108,175,"That's right."],[283,446,"Don't be nervous, child."],[508,688,"You are professional,"],[688,809,"responsible,"],[809,1080,"far better than that two-bit manager."],[1376,1584,"You, out!"],[1647,1722,"I'll leave."],[2027,2089,"I'm leaving."],[2310,2635,"I, I feel like I'm dreaming."],[2694,2890,"No, don't worry."],[2927,3086,"You're getting a promotion."],[3157,3286,"You deserve it, my dear."],[3453,3561,"Thank you."],[3616,3920,"First assignment, I want that row,"],[3949,4095,"and that row,"],[4141,4341,"and the entire display case."],[4400,4662,"Pack it all up and bring it to my house."],[4746,4863,"Okay, yeah."],[5042,5163,"Once we're home,"],[5163,5380,"I'll tell her I'm her mother-in-law."],[5434,5559,"I can't wait to finally"],[5559,5701,"meet my granddaughter."],[6352,6477,"She's the mother of a CEO."],[6569,6698,"Of course she lives like this."],[7703,7786,"Mrs. Harrison?"],[7857,7978,"I'm here with your delivery."],[8258,8350,"Max?"],[8375,8441,"Eva."]],"65":[[50,158,"What are you doing here?"],[266,342,"I, uh..."],[392,583,"There you are, Eva!"],[684,817,"Wonderful, we can finally"],[817,955,"meet each other properly."],[988,1184,"My new daughter-in-law."],[1263,1393,"What are you talking..."],[1701,1797,"That means you really are"],[1797,1981,"the CEO of Harrison Group."],[2202,2327,"Well, I tried to tell you, but-"],[2327,2389,"Stop!"],[2552,2815,"And you, you lied to me at the store."],[2907,3098,"You, you were both just testing me?"],[3144,3240,"Is this some sick game"],[3240,3353,"rich people play?"],[3353,3486,"I'm sorry, Eva."],[3499,3695,"I thought you might be using my son"],[3695,3845,"just after his money,"],[3845,3978,"but I was wrong."],[4029,4087,"Eva, please."],[4087,4287,"I don't deserve to be treated like this."],[4320,4462,"Not every working-class girl"],[4462,4571,"is after your money."],[4667,4775,"How could you think that of me?"],[4850,5009,"It's not like that, dear."],[5080,5205,"Eva, what are you talking about?"],[5305,5484,"Mom, what did you do?"],[5509,5638,"I was just trying to"],[5638,5793,"get the two of you back together."],[5793,5922,"We're not together."],[6014,6131,"And I can't love something"],[6131,6231,"that was never real."],[6639,6861,"I made a horrible mistake."],[6961,7090,"What are you waiting for, son?"],[7090,7198,"Go after her."]],"66":[[154,225,"Eva."],[250,325,"Let me go!"],[325,513,"I swear, it's not what you think."],[538,604,"Look, we come from"],[604,713,"two completely different worlds."],[713,825,"Stop pretending like you care."],[825,963,"I'm not pretending!"],[1001,1159,"Okay, I can't fake what we have."],[1159,1288,"And everything I've done"],[1288,1409,"for you, and Piper,"],[1430,1539,"this is real."],[1972,2160,"Touch my wife again and I will snap"],[2160,2335,"every finger that you've got."],[2373,2489,"Max, you came."],[2523,2806,"God, you are driving me fucking insane."],[2982,3094,"I'll do whatever it takes"],[3094,3194,"to be a good husband,"],[3249,3340,"a good father."],[3370,3478,"Just say the word."],[3795,3858,"See?"],[4020,4145,"Stop fighting."],[4350,4462,"We belong together."],[4612,4700,"You're wrong."],[4758,4846,"Wrong about what?"],[4979,5059,"That you care?"],[5142,5259,"Or we belong together?"],[5259,5405,"Look, I already told you."],[5434,5497,"We're from"],[5497,5626,"two completely different worlds."],[5668,5805,"Now, I held up my end of the deal"],[5805,5889,"and I met your mother,"],[5889,5997,"like we discussed."],[6089,6181,"Now I want a fake divorce"],[6181,6297,"from my fake husband."],[6598,6673,"Eva."],[6952,7032,"Eva!"],[7207,7336,"I'm sorry, Maximus."],[7365,7590,"Walking away is the only choice I have."]],"67":[[437,479,"Ow."],[617,742,"Are you okay, Mommy?"],[804,930,"Yeah, sweetie, I'm fine."],[1046,1121,"Come, come."],[1889,2031,"No, you're not fine."],[2031,2106,"You're sad."],[2339,2460,"I'm okay, sweetie."],[2698,2857,"I miss Daddy, too."],[3148,3382,"I want Max to be my real Daddy."],[3628,3782,"Don't you want to be with him?"],[3995,4070,"Lovebug."],[4183,4254,"You're right."],[4341,4412,"What am I doing,"],[4412,4529,"running like a coward?"],[4733,4884,"I always taught you to be brave."],[5030,5125,"Now it's time for Mommy"],[5125,5217,"to be brave too."],[5342,5459,"I believe in you."],[5459,5613,"What are you gonna do, Mommy?"],[5722,5893,"I know exactly what to say to him."],[6197,6364,"Maximus deserves to know."],[6435,6585,"Piper is his daughter."]],"68":[[254,396,"Enough sulking."],[437,750,"Go get your wife and my grandbaby back."],[784,967,"Don't you think I want to?"],[1021,1176,"She doesn't want me."],[1201,1368,"I didn't raise you to give up."],[1368,1501,"Your daughter is still out there."],[1501,1672,"You can't abandon her."],[1705,1818,"Mom, you don't get it."],[1876,2127,"I made a deal with Eva to play my wife."],[2193,2523,"And Piper, she was an added bonus."],[2606,2748,"What are you talking about?"],[2773,2965,"I already ran a DNA test."],[3107,3261,"Piper is your daughter."],[3324,3386,"What?"],[3415,3541,"See for yourself."],[4154,4225,"I was right."],[4275,4371,"Seven years ago."],[4483,4658,"New Year's, that woman was Eva."],[5718,5772,"Eva."],[5910,6022,"Hey..."],[6101,6210,"Daddy!"]],"69":[[33,141,"Daddy!"],[141,212,"Piper!"],[346,400,"Oh,"],[513,675,"I missed you so much, sweetheart."],[1267,1359,"You came back."],[1597,1693,"I, uh..."],[1922,2131,"Don't forget to be brave, Mommy."],[2673,2769,"I, uh..."],[2902,2986,"I was scared."],[3048,3211,"But I don't want to be scared anymore."],[3311,3449,"Because what we have is real,"],[3449,3599,"and it's worth fighting for."],[3766,3924,"Sweetheart, I have"],[3924,4037,"something to tell you."],[4116,4237,"I have something to tell you too."],[4504,4558,"Piper is - Piper is"],[4558,4621,"our daughter. - your daughter."],[4721,4800,"You knew?"],[4863,5034,"My sweet granddaughter."],[5034,5134,"Grandma."],[5480,5618,"Well, I just found out for sure"],[5618,5705,"a few minutes ago,"],[5705,5822,"but you've known this whole time?"],[5897,5980,"I was scared."],[6026,6126,"Okay, I didn't know"],[6126,6256,"if you were gonna take her from me."],[6256,6443,"I didn't know how you were feeling."],[6589,6748,"How could you not know how I felt?"]],"70":[[829,938,"I love you, Eva."],[1167,1276,"I love you too."],[1368,1614,"I promise, for the rest of my life,"],[1614,1755,"I'm going to make it up to you."],[1918,2035,"As long as we're together,"],[2097,2227,"it doesn't matter where we are."],[3236,3345,"Will you marry me, Eva?"],[3495,3566,"For real this time?"],[3611,3724,"Yeah, yes!"],[3812,3983,"Yes, of course I'll marry you!"],[4366,4446,"Yes."],[5259,5359,"Looks like you're stuck with me"],[5359,5455,"the next Christmas,"],[5455,5601,"and the Christmas after that,"],[5601,5693,"and forever."],[5955,6101,"I wouldn't have it any other way."],[6669,6731,"Who's that?"],[6852,7002,"Eva!"],[7148,7307,"Take me back!"],[7428,7695,"I'm sorry I shoved your daughter!"],[7957,8028,"Looks like I have to"],[8028,8141,"take out the trash,"],[8224,8287,"again."],[8537,8679,"No, not funny?"]]}