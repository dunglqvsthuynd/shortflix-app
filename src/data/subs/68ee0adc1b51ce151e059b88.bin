{"1":[[924,1000,"Don't move."],[1546,1664,"You smell so good."],[2300,2379,"Final check."],[2400,2507,"Departments all in position?"],[2507,2623,"Livestream prepared?"],[2623,2780,"Remember that the cameras have to be pointed"],[2780,2885,"at the president's mark."],[2885,2967,"Confirmed."],[3066,3162,"Now."],[3162,3257,"Cue Mr. President."],[3353,3508,"This man is my husband."],[3556,3728,"There's no love in our marriage,"],[3740,3814,"just a contract."],[3882,3996,"Ever since yesterday."],[4084,4278,"About the banquet tomorrow,"],[4278,4360,"I want you to come."],[4415,4521,"Put on something nice."],[4557,4646,"What's the occasion?"],[5611,5688,"I'll see you tomorrow."],[5914,6032,"Ladies and gentlemen."],[6070,6214,"Lucas, are you finally"],[6214,6365,"going to make our marriage public?"],[6420,6565,"I'm honored to have you here"],[6565,6735,"on this very special occasion."],[6868,7154,"I would like to invite a truly special,"],[7228,7456,"beautiful, and elegant woman"],[7456,7595,"to join me on stage."],[8068,8220,"Please welcome"],[8709,8776,"Monica."]],"2":[[14,88,"Monica."],[867,1022,"Get out my way, rat."],[2485,2694,"Monica will be our new brand"],[2694,2898,"ambassador for the Wharton Group."],[3352,3629,"That secretary, she's such a clown,"],[3629,3861,"always trying to get Lucas's attention."],[4067,4278,"Great job today, dear secretary."],[4278,4396,"Lucas is lighting"],[4396,4567,"1,000 fireworks"],[4567,4653,"for me today."],[4685,4857,"Make sure to capture"],[4857,5042,"every single moment"],[5042,5200,"and put them on the socials."],[5200,5293,"Right, Lucas?"],[5607,5703,"That's right."],[5757,5846,"Set it up."],[5915,5982,"Yes, sir."],[6221,6314,"What's wrong with her?"],[6648,6770,"Let's have a drink."],[7104,7198,"Congratulations."],[7426,7562,"After tonight,"],[7562,7665,"you'll be mine."],[7962,8021,"Lucas?"],[8946,9018,"Come here."],[9104,9229,"You sure you want to do this?"],[13128,13508,"I can't image this will be our first time."],[13662,13819,"Damn it, where's Lucas?"],[13856,13962,"Find him now."]],"3":[[1122,1272,"We're getting a divorce."],[1272,1343,"Why?"],[1343,1572,"You broke the terms of our agreement."],[1583,1671,"You drugged my drink."],[1748,1851,"No, I didn't."],[1876,2010,"You came on to me last night,"],[2010,2087,"you kissed me."],[2114,2260,"You know very well that I was"],[2260,2448,"forced to marry you by my parents."],[2448,2551,"I never loved you."],[2551,2680,"My heart's with someone else."],[2762,2883,"Now you seriously"],[2883,2967,"cross the line."],[3250,3347,"You disgust me."],[3465,3621,"I didn't do anything wrong."],[3697,3806,"You've been pushing me away"],[3806,3989,"since we got married, please!"],[4015,4135,"Lucas, I'm your wife."],[4135,4175,"Enough!"],[4175,4203,"I-"],[4265,4317,"It's final."],[4579,4610,"Okay."],[4697,4724,"Now."],[4870,5106,"I'll divorce you if that's what you want."],[5235,5354,"But you have to come with me"],[5354,5459,"to one last place."],[5501,5550,"Fine."],[5617,5728,"But no more games."],[6371,6670,"Lucas, I will let you remember me."]],"4":[[68,281,"It's been seven years since that fire."],[308,521,"The ski lodge is now a commercial center."],[567,625,"But..."],[1319,1359,"You okay?"],[1685,1716,"Let‘s go."],[1812,1953,"If Lucas ever comes back here,"],[1953,2096,"he's bound to remember me."],[3166,3210,"Oops!"],[3346,3503,"Sorry, dear secretary."],[3570,3700,"But if you don't die,"],[3756,4007,"how am I supposed to become Mrs. Lucas?"],[4356,4403,"Hey, Monica."],[4475,4552,"Oh, Lucas!"],[4660,4825,"I suddenly felt so faint."],[4915,4984,"I'm worried it's"],[4984,5134,"gonna affect the shoot tomorrow."],[5174,5230,"Lucas..."],[5288,5403,"Save me, please!"],[5471,5571,"I heard your name."],[6180,6360,"Your health is what matters most right now."],[7573,7704,"You two are in love now?"],[7737,7779,"And me?"],[7821,7906,"Our marriage?"],[7931,8068,"It was just a fucking joke."],[8445,8593,"I'm sorry, Monica."],[8681,8771,"And I'm a married man."],[8790,8906,"I just don't want"],[8906,8990,"there to be any confusion."],[9012,9079,"Oh, babe."],[9093,9304,"I want nothing but the company's success."],[9321,9354,"Wow."],[9354,9462,"Why don't I..."],[9462,9631,"stay and learn about the job of it?"],[9631,9756,"I appreciate the thought."],[9756,9878,"Maybe it's another time."],[10295,10476,"Vera, what hell are you doing?"],[10521,10651,"Why don't you pick up the phone?"]],"5":[[494,675,"Who is that?"],[916,1009,"Victor Costa."],[1153,1275,"Head of one of the largest"],[1275,1433,"mafia families in the country."],[1480,1588,"Very well connected."],[1685,1771,"Even as tight in"],[1771,1839,"the White House."],[1910,1983,"Gosh!"],[2430,2585,"She lost too much blood."],[2621,2792,"There's nothing more we can do."],[3265,3414,"I want you to use every medical resource"],[3414,3575,"in this planet to save her life."],[3692,3814,"And if you fail,"],[3871,4050,"it would be the last thing that you do."],[4050,4144,"Chairman Costa..."],[4144,4274,"with all due respect…"],[4274,4432,"She's just an ordinary woman."],[4432,4510,"Ordinary?"],[4529,4675,"This is Vera Costa."],[4700,4877,"The heiress of the Costa family."],[4978,5043,"And the sister"],[5043,5235,"I've been looking for for 20 years."],[5364,5528,"Uh, Lucas?"],[5528,5685,"Why don't I drive you home?"],[5715,5852,"I have important things to deal with."],[5870,5928,"Go on ahead."],[6264,6471,"Leo, I can't find Vera anywhere."],[6490,6630,"Check the surveillance footage"],[6630,6745,"and do whatever you have to,"],[6745,6868,"but find her now!"],[7279,7343,"Chairman,"],[7381,7565,"Miss Vera is out of immediate danger…"],[7620,7685,"Thank God."],[7842,8131,"However, her brain trauma was severe."],[8131,8350,"It may have symptoms of memory loss."],[8350,8482,"I want you to be aware that"],[8482,8707,"there may be long-term effects."],[9145,9229,"Don't worry, Vera."],[9301,9379,"I'm here now."],[9456,9557,"I'll protect you."],[9954,10023,"Two weeks!"],[10048,10173,"It's been two weeks, Leo."],[10226,10329,"If you don't find her soon,"],[10343,10478,"I'm gonna tip you off to Antarctica"],[10478,10735,"to monitor the mating rituals of penguins."],[10757,10854,"Actually,"],[10890,10978,"we have a lead."],[11034,11073,"What?"],[11128,11271,"On the day she disappeared,"],[11321,11451,"there was an accident"],[11451,11557,"in the Queen's Square."],[11612,11743,"I'm afraid she"],[11743,11891,"might have been involved."],[11942,12030,"Queen's Square?"]],"6":[[26,156,"That place used to be"],[156,312,"an old ski lodge years ago."],[375,451,"There was a fire."],[516,679,"I was trapped inside, and this"],[725,903,"angel came and saved me."],[940,1088,"She didn't care about the danger."],[1088,1350,"She broke open the door and pulled me out."],[1430,1664,"Then why the hell did you marry Vera?"],[1751,1848,"Family protocol."],[1883,2136,"If I wanted to inherit the company,"],[2136,2251,"I had to be married."],[2287,2332,"And why do you"],[2332,2533,"look so anxious about her?"],[2533,2689,"I just wanna..."],[2782,2903,"finalize the divorce."],[2987,3162,"We found that there's a patient"],[3162,3338,"at St. George Hospital."],[3635,3696,"Hi, sorry."],[3696,3824,"Have you seen this girl anywhere?"],[4053,4107,"Excuse me."],[4438,4503,"Have you seen this girl?"],[6089,6270,"Hi, there was a patient admitted here."],[6270,6346,"Have you seen her?"],[7109,7276,"I can't remember anything,"],[7276,7431,"but this man..."],[7431,7640,"Why he look so familiar?"]],"7":[[150,235,"Hey, Vera."],[613,728,"You haven't got your memory back."],[728,864,"You can't just wander off like that."],[864,930,"Doctor said that"],[930,1067,"seeing familiar people might help."],[1167,1243,"And have you seen"],[1243,1356,"anyone familiar?"],[1456,1482,"No."],[1650,1698,"Come on,"],[1739,1819,"let's go."],[2230,2294,"Vera,"],[2394,2480,"where are you?"],[3119,3203,"Mr. Costa,"],[3296,3364,"welcome home."],[3478,3560,"May I take you bag?"],[3688,3739,"Sir?"],[3775,3857,"Thank you, Simon."],[4593,4714,"This... house"],[4714,4835,"is beautiful."],[4835,5047,"I don't remember any of it."],[5047,5325,"Listen, recovery takes time."],[5325,5488,"I don't want to spend most of my life"],[5488,5632,"being slow and forgetful..."],[5632,5765,"Who said you're slow?"],[5765,5857,"I'm going to make sure you get"],[5857,5988,"everything you deserve."],[6102,6178,"I've been having"],[6178,6286,"a dream about"],[6286,6374,"the Queen's Square..."],[6374,6634,"I wonder what happened more... Do you?"],[6634,6750,"Maybe you should come out"],[6750,6895,"to this event tonight."],[6895,6964,"Yeah?"],[6964,7087,"It might help you."],[7123,7285,"Plus, it's time for the Princess"],[7285,7398,"of the Costa family"],[7398,7587,"to make her dazzling debut."]],"8":[[401,525,"Oh, Mr. Costa,"],[525,601,"is this the sister"],[601,787,"who just returned from overseas?"],[787,864,"Right."],[888,940,"She's stunning!"],[940,1140,"Looks exactly like your mother"],[1140,1250,"when she was young."],[1272,1422,"It's Vera's first ball."],[1422,1619,"Hoping that everyone can take care of her."],[1762,1975,"Vera, do you remember this place?"],[2016,2119,"Before it was remodeled,"],[2119,2271,"it was a ski lodge."],[2353,2592,"Maybe we can take a walk around here."],[2592,2717,"And it might jog your memory."],[3083,3371,"Nah, Lucas, this party is dull,"],[3371,3652,"so you don't need to bother here coming."],[3921,3957,"Wait!"],[4034,4147,"Anything come to mind?"],[4260,4402,"Vera, are you okay?"],[4761,4943,"There was a fire, I..."],[4943,5424,"Lucas, you need to come over here right now."],[5510,5629,"Just one second."],[5629,5870,"I will miss you to go do some business."],[5870,6053,"I'll be right back. Are you okay to stay here?"],[6096,6139,"Yes."],[6175,6225,"Okay."],[7004,7118,"Finally found you!"]],"9":[[0,84,"What are you doing here?"],[136,264,"That man from the hospital."],[291,389,"Do we know each other?"],[416,533,"Do we know each..."],[578,624,"It's me."],[721,858,"I've been looking everywhere for you."],[885,1011,"Why didn't you answer my calls?"],[1025,1091,"Aw."],[1124,1182,"What's..."],[1182,1277,"What's wrong with you?"],[1277,1343,"It hurts."],[1500,1588,"What's going on here?"],[1664,1726,"Mr. Costa."],[1939,2017,"You two know each other?"],[2117,2142,"Yes."],[2207,2298,"Vera's with me."],[2342,2423,"Is that a problem,"],[2423,2485,"Mr. Wharton?"],[2548,2598,"No."],[2685,2728,"But..."],[2816,2878,"She's my..."],[2878,2948,"Lucas."],[3035,3142,"There you are."],[3220,3278,"Darling,"],[3320,3382,"don't forget."],[3438,3565,"When it comes to sleeping around,"],[3607,3714,"Vera's a total pro."],[3774,3893,"What's wrong with you?"],[3964,4114,"I don't even know you."],[4185,4339,"I don't know either of you."],[4374,4406,"Wow."],[4535,4661,"Let's show these people"],[4661,4838,"what kind of tramp you really are."],[4943,4964,"Ah!"],[5021,5160,"You bad luck."],[5247,5320,"Mr. Costa!"],[5652,5879,"Do you even know her past?"],[5996,6238,"Where this little rabid bitch come from, huh?"],[6315,6361,"Big man."],[6418,6521,"Clean this mess up."],[6543,6615,"No, no, no, wait,"],[6615,6690,"wait, wait, wait!"]],"10":[[0,143,"No, wait, wait, wait."],[143,283,"Mr. Costa, I'm sorry."],[283,433,"She mistook her for someone else."],[545,644,"I'll take her home."],[851,1033,"Vera, is this your revenge on me?"],[1419,1466,"It's okay."],[1530,1714,"She's just mistaken me for someone."],[1887,1951,"It's your call."],[2535,2662,"Cut the act, Vera."],[2733,2857,"What the hell is wrong with you?"],[2900,3039,"Cozying up to Victor,"],[3039,3192,"trying to make me jealous?"],[3224,3314,"What's wrong with you?"],[3339,3447,"Just be honest with me."],[3514,3600,"Did we know each other?"],[3638,3764,"Did something happen to you?"],[4034,4123,"What's wrong?"],[4171,4241,"Fine."],[4271,4396,"Vera?"],[4450,4475,"Vera?"],[4692,4893,"Get your fucking hands off her."],[5011,5143,"Don't you ever touch her again."],[5143,5265,"I'll fucking kill you."]],"11":[[167,405,"Victor won't let me near Vera again."],[445,650,"That divorce might..."],[650,712,"Boss."],[712,858,"Remember six months ago."],[896,1140,"Costa Group tried to acquire Comet Media,"],[1211,1485,"and you shut them down hard."],[1577,1637,"So,"],[1705,2087,"what if we offer them a partnership now?"],[2087,2323,"Use that deal to get close to her."],[2382,2496,"Brilliant."],[2566,2630,"Cheers."],[3338,3547,"Comet financial analysis."],[3560,3697,"What is that?"],[3738,3892,"Some little media firm"],[3892,4085,"that wants to partner with our company."],[4271,4438,"Media firms?"],[4438,4588,"You're so over the top."],[4664,4835,"Don't get involved in that mess."],[4835,4871,"Really?"],[4953,4979,"Huh."],[5243,5334,"Tell Mr. Wharton"],[5334,5432,"we're not interested in"],[5432,5564,"his little media company."],[5821,5892,"Wait, like..."],[5965,6089,"like Lucas Wharton?"],[6161,6250,"Yeah."],[6250,6356,"Don't you think that"],[6356,6506,"type of industry fits in well?"],[6601,6807,"You know, I think"],[6807,7012,"we should rethink the whole media thing."],[7112,7240,"I feel like media is"],[7240,7385,"the new wave of the future,"],[7385,7559,"and the group needs diversification."],[7659,7857,"And Rupert Murdoch is like totally my idol."],[7857,8017,"and Elon Musk bought Twitter."],[8017,8110,"I just, I think that"],[8110,8287,"media is a strategic investment."],[8312,8548,"Didn't you just say that"],[8548,8798,"media industry is such a mess"],[8798,8914,"and over the top?"],[8914,9042,"Didn't you say that"],[9042,9314,"you wanted me to toughen up?"],[9314,9365,"Fair enough."],[9509,9596,"I've made my decision."],[9676,9878,"I'm gonna go undercover at Comet Group."],[9878,9948,"Well,"],[10057,10162,"I look forward to it."]],"12":[[250,366,"Everybody,"],[366,612,"this is our new intern, Vera."],[612,759,"It's nice to meet you all."],[759,841,"Jessica."],[951,1072,"And over there is our"],[1072,1233,"top talent, Monica."],[1501,1633,"Well, well,"],[1657,1962,"if it isn't being illustrious Vera."],[1962,2082,"What happened?"],[2166,2321,"Just a few days in,"],[2321,2476,"and you're begging for a job?"],[2594,2792,"Congratulations, by the way."],[2792,2957,"Scrubbing toilets, is it?"],[2957,3087,"Monica, is it?"],[3087,3297,"You were the one who I saved last time"],[3297,3407,"when you were being crazy."],[3446,3625,"Guess you're not feeling grateful, huh?"],[3625,3746,"Spare me the bravado."],[3814,4006,"Clearly, Victor got bored of you"],[4006,4128,"and kicked you out."],[4210,4396,"Save your childish theories, Monica."],[4396,4457,"I'm here to work."],[4511,4661,"Too bad."],[4661,4871,"You're in my territory now."],[4871,4964,"What's your means?"],[5043,5167,"Well then, intern,"],[5167,5311,"tell me,"],[5311,5510,"how should I take care of you?"],[5546,5702,"You dare hit me?"]],"13":[[235,348,"That's enough."],[370,491,"This is a place of work."],[554,625,"Go back to work."],[733,991,"Oops. My bad."],[1025,1153,"But Lucas,"],[1153,1366,"why are you interfering in some"],[1366,1543,"intern's drama?"],[1543,1867,"Unless Vera here is somehow"],[1867,2066,"special to you?"],[2137,2257,"She is special to me."],[2353,2450,"Victor Costa invested"],[2450,2566,"heavily in this company,"],[2566,2821,"and given Vera's close ties with him."],[2821,3067,"I should oversee this transaction personally."],[3183,3320,"For the sake of our partnership."],[3492,3760,"So Lucas still won't admit it publicly."],[3861,4247,"Fine. Let's see how long that lasts."],[5282,5361,"Oh, boss, look."],[5421,5520,"There they are."]],"14":[[26,176,"There's definitely something going"],[176,270,"between them."],[291,381,"What are you doing here?"],[421,621,"What? I just stopped by and check in."],[621,711,"You want me to go upstairs"],[711,808,"and motivate the management?"],[838,1041,"No. You know, everyone misread."],[1041,1090,"Actually, they think"],[1090,1272,"I'm your girlfriend, so..."],[1272,1406,"At least no one will mess with me."],[1469,1577,"So, how's Lucas?"],[1648,1707,"Fine."],[1707,1767,"Good."],[1767,1828,"Why?"],[1828,1867,"He's..."],[1867,2114,"It's work. It's not like that."],[2132,2517,"Right. So, I have a meeting, and..."],[2517,2650,"Good luck in there."],[2855,2973,"How could she?"],[4557,4778,"Lucas, what are you doing?"],[4778,4902,"It's enough."],[4902,5146,"Flirting with Victor in front of me?"],[5146,5321,"What a twisted game is that?"],[5388,5517,"You're trying to make me jealous."],[5517,5628,"You know what? It's working."],[5628,5761,"I don't know what you're talking about."],[5761,5864,"You're the one making"],[5864,6007,"things up about me and Victor."],[6007,6107,"There's nothing going on"],[6107,6228,"between me and Victor."],[6228,6362,"And besides, what gives you the right"],[6362,6540,"to kiss me without my permission?"],[6540,6765,"Vera, Victor's not the kind of guy"],[6765,6923,"that's in this for the long haul."],[7051,7295,"Just stay with me, and let's talk this out."],[7395,7604,"Talk what out?"],[7604,7821,"Lucas, I don't remember anything."],[7821,7890,"Okay?"],[7890,8018,"You don't remember anything?"],[8081,8281,"No. I... I hit my head."],[8326,8468,"Did we have history?"],[8468,8590,"Vera, we..."]],"15":[[70,170,"Lucas,"],[210,437,"come help me pick out a wedding dress."],[437,704,"Our big day has to be unforgettable!"],[704,791,"What wedding?"],[791,996,"Our company's helping plan it."],[996,1106,"Didn't you hear?"],[1106,1235,"Is that so?"],[1235,1411,"Then why was your fiancé"],[1411,1583,"just kissing me in the elevator?"],[1583,1867,"Excuse me? You must've seduced him."],[1867,2037,"Vera, it's not what you think."],[2037,2182,"Okay, you don't want to save it."],[2182,2330,"With kissing skills that lousy,"],[2330,2485,"you shouldn't be juggling two women."],[2564,2689,"You're pathetic!"],[2742,2819,"Vera..."],[2819,2971,"Let's go, Lucas."],[2971,3098,"The director's waiting."],[3098,3306,"Monica, why did you tell Vera that"],[3306,3459,"this wedding commercial shoot"],[3459,3570,"was a real wedding?"],[3592,3861,"Weren't you trying to get divorced, anyway?"],[3861,4050,"I was just helping you out."],[4050,4174,"You know what?"],[4174,4296,"I'm going to hire a professional actor"],[4312,4415,"to play my role."],[4415,4546,"I'm not doing it."],[5028,5167,"Vera,"],[5167,5365,"you'll pay for this."],[5729,5843,"Vera, I need you to"],[5843,6096,"deliver this actor contract to Mr. Panta."],[6096,6189,"Sure."],[6189,6353,"I'll head up now."],[6570,6729,"By the way, Monica."],[6729,7012,"Make sure Mr. Panta knows who Vera is."],[7012,7257,"Don't worry. I'll call him right away."]],"16":[[536,714,"Thank you for signing the agreement,"],[714,786,"Mr. Panta."],[786,877,"We'll be in touch."],[908,975,"To us."],[2933,2980,"Stop."],[3083,3308,"Don't you dare lay hand on her."],[3308,3446,"You bastard!"],[3446,3614,"Have you ever touched her again!"],[3614,3717,"I'll kill you!"],[3717,3821,"Now get out!"],[4100,4234,"Let's take you to the hospital."],[5234,5317,"I can't believe that"],[5317,5474,"you thought that I was married to Monica."],[5500,5624,"You can leave me alone."],[5624,5721,"She's not my type."],[5743,5896,"Okay, fine."],[5896,6019,"You're a jerk."],[6019,6160,"I misunderstood the relationship"],[6160,6292,"between you and Monica."],[6292,6431,"Still calling me a jerk?"],[6431,6790,"Yes. Because you took advantage of me."],[6790,6878,"You're the one who"],[6878,7007,"assaulted me first."],[7007,7195,"Not assault you."],[7195,7329,"Oh, my heart."],[7521,7584,"Lucas,"],[7670,7809,"I don't know why but I..."],[7881,8057,"I feel like ever since I met you, I..."],[8121,8228,"I've known you."],[8364,8442,"Can you tell me"],[8442,8559,"something about our past?"],[8607,8681,"I'll telling you everything."],[8871,8954,"But first,"],[9065,9207,"what's the relationship between"],[9207,9301,"you and Victor Costa?"],[9387,9537,"Oh, Victor's my..."],[9570,9715,"Vera, open up!"]],"17":[[78,200,"Come on! Open up!"],[200,287,"No more games!"],[436,520,"I'm coming!"],[675,791,"Where's Vera?"],[791,833,"Vera?"],[919,991,"She's not here."],[991,1143,"This is the actor's room."],[1143,1251,"I'm just resting in here."],[1251,1328,"Oh my god. If my brother"],[1328,1453,"If my brother finds me here,"],[1453,1517,"he'll kill me."],[1546,1705,"Are you trying to play tricks on me?"],[1971,2066,"Mr. Costa!"],[2066,2246,"What's going on between you and Vera?"],[2335,2483,"I mean, why are you"],[2483,2557,"looking for her?"],[2607,2782,"She didn't come home last night."],[2885,3044,"I checked the security cameras."],[3211,3338,"She turned up here."],[3388,3514,"You're living together?"],[3588,3679,"I don't think you know"],[3679,3817,"how much Vera means to me."],[3860,4046,"You just met. How..."],[4046,4157,"You don't know anything about her."],[4253,4452,"I know everything about her."],[4507,4621,"All the way up from"],[4621,4782,"St. George's Orphanage"],[4782,4970,"to about three hours ago."],[5024,5370,"Yeah, I know every little details."]],"18":[[2,184,"Since you know everything about us,"],[302,467,"what will it take for you to let Vera"],[467,572,"come back to me?"],[596,696,"Back to him?"],[715,1017,"God, what exactly is my relationship with Lucas?"],[1082,1174,"Name your price."],[1540,1633,"Apologies."],[1633,1812,"I don't like how you phrase that."],[1812,1946,"I'II give you fifty million."],[2037,2194,"You're mafia, right? You..."],[2194,2369,"You can't say no to a profit."],[2626,2766,"Then I'm a scumbag, right?"],[3146,3300,"Two hundred million."],[3300,3382,"And..."],[3382,3600,"the Wharton family's European market."],[3600,3664,"All of it."],[3679,3889,"Brother, he truly loves me."],[3889,4051,"Please stop hurting him."],[4051,4364,"You wanted to get a divorce with her before,"],[4364,4537,"but now you're willing to pay me"],[4537,4674,"to keep her around."],[4782,4929,"Something's up,"],[4929,5134,"and I'm gonna get to the bottom of it."],[5414,5496,"Wait."],[5624,5724,"We're married?"]],"19":[[30,92,"We're married?"],[381,575,"Yes, I'm sorry."],[575,712,"I took you for granted."],[782,961,"I didn't cherish what we had."],[961,1172,"It's only when..."],[1172,1275,"you're gone that"],[1275,1367,"I realize how much you"],[1367,1450,"meant to me."],[1450,1525,"Please give me"],[1525,1616,"another chance."],[1701,1900,"I don't remember anything."],[1900,2071,"It doesn't matter."],[2071,2237,"Come home with me."],[2333,2480,"Follow your heart, Vera."],[2480,2698,"If you want to come back,"],[2698,2789,"I'll be here for you."],[3674,3800,"Is our place nearby?"],[3889,3953,"Hey!"],[4370,4450,"Who get that"],[4450,4511,"Motherfucker!"],[4750,4842,"Call the ambulance!"],[5343,5425,"Vera."],[5496,5602,"You're awake."],[5602,5792,"Lucas..."],[5792,5917,"I remember everything."]],"20":[[12,128,"I remember everything."],[216,279,"Do you remember that"],[279,327,"we're married?"],[524,720,"You disgust me."],[720,856,"You drugged my drink,"],[856,1011,"trying to use the cheap trick"],[1011,1116,"to get close to me."],[1201,1383,"But if you don't die,"],[1383,1605,"how am I supposed to become Mrs. Lucas?"],[1717,1933,"Lucas, save me, please."],[2721,2816,"We're getting a divorce."],[2866,2955,"Divorce?"],[3069,3239,"I won't agree to a divorce!"],[3239,3325,"Why this again?"],[3325,3439,"We were doing so well."],[3479,3671,"You're asking me that? Really?"],[3697,3810,"What? Do you have memory loss?"],[3810,3860,"You don't remember"],[3860,4070,"what you put me through the past year?"],[4070,4211,"I'm sorry."],[4211,4407,"I made mistakes."],[4407,4657,"But I've changed."],[4657,4865,"I'm trying to make things right."],[4865,4947,"For you."],[5038,5185,"I'm so sorry, Vera. I..."],[5356,5550,"You loved me once, didn't you?"],[5643,5782,"I want to go home."]],"21":[[202,327,"Sorry, Mr. Wharton."],[327,532,"I don't believe Vera wants you here."],[532,721,"I'm sorry, Mr. Costa."],[721,883,"But Comet Media is a"],[883,1051,"subsidiary of the Wharton Group."],[1051,1203,"As a board member,"],[1203,1296,"I suggest you rethink"],[1296,1383,"your tone with me."],[1583,1700,"Well, then, I will"],[1700,1862,"terminate our partnership."],[1862,2060,"I'll remove all Costa Group"],[2060,2380,"investments to Costa Comet Media,"],[2380,2471,"effective immediately."],[2528,2737,"The 200 million profit concession"],[2737,2835,"and full access to"],[2835,3033,"the European market still stands."],[3033,3260,"I suggest you consider our"],[3260,3361,"proposal carefully."],[3424,3510,"What is this?"],[3510,3639,"Some type of performance?"],[3706,3932,"No, strictly business."],[3960,4056,"Victor."],[4056,4317,"The Wharton-Costa Alliance"],[4317,4474,"entering the European market"],[4474,4656,"benefits both sides."],[4717,4915,"All I ask is for"],[4915,5175,"a fair chance to compete for Vera's heart."],[5175,5389,"Unless you're afraid of a little competition."],[5414,5538,"I'll have to decline your offer."],[5538,5665,"And I don't think that"],[5665,5850,"Vera will accept your proposal."],[5871,5950,"Who said I wouldn't?"],[6256,6464,"If this partnership can win the Costa Group"],[6464,6650,"entry into the European market,"],[6650,6757,"then I can separate"],[6757,6912,"business and personal matter."],[6995,7162,"However,"],[7162,7333,"there is one condition, Mr. Wharton."],[7395,7464,"Please."],[7493,7734,"Once the European project is over,"],[7734,7878,"you sign the divorce agreement."],[7956,8078,"Fine."],[8078,8168,"Great."],[8168,8334,"While they are settled,"],[8334,8542,"Vera will head the Costa Group,"],[8542,8650,"and she will make sure"],[8650,8820,"that our partnership goes forward."]],"22":[[165,212,"Come in."],[254,318,"Vera,"],[318,475,"the manager is meeting with"],[475,555,"EU officials."],[555,691,"They request your authorization"],[691,796,"for the algorithm key."],[796,969,"Sure. Just one moment."],[2042,2117,"The hard drive"],[2117,2276,"stores encryption key is gone."],[2578,2835,"Vera, I respect your background,"],[2835,3035,"but the encryption key was lost."],[3062,3215,"While under your custody,"],[3215,3389,"we need an explanation."],[3389,3556,"I'm deeply sorry that"],[3556,3646,"this happened."],[3646,3774,"But like all of you,"],[3774,4032,"I have no idea how that key was stolen."],[4135,4429,"Don't act like this doesn't concern you, Vera."],[4429,4643,"The safe was in your office,"],[4643,4842,"and you're the only one who knows the code."],[4842,5014,"This is your responsibility."],[5014,5089,"Okay, well then"],[5089,5271,"why don't we check the surveillance cameras?"],[5307,5432,"The cameras were down."],[5465,5686,"She probably disabled them in advance."],[5738,5838,"I never thought Vera"],[5838,6003,"could be a corporate spy."],[6074,6333,"The Costa Group is one of the main"],[6333,6492,"investors in this company."],[6492,6621,"Why would I steal for myself?"],[6654,6806,"Technically,"],[6806,7056,"it's one of our many shareholders."],[7134,7357,"While I trust you, Vera,"],[7357,7571,"my duty is to the company,"],[7571,7743,"and I have to follow procedures."],[7793,7887,"Okay."],[7887,8121,"Well, then tell me, Mr. Wharton,"],[8121,8214,"what is it"],[8214,8312,"that you want to do?"],[8371,8615,"If the key isn't found within 24 hours,"],[8615,8717,"I have to hand this case"],[8717,8844,"over to the authorities."]],"23":[[218,330,"Lucas?"],[331,461,"What the hell are you doing?"],[471,678,"Vera, I'm sorry."],[775,996,"As the CEO of the Wharton Group,"],[996,1140,"I have to be objective."],[1174,1400,"Why don't we look for the key together?"],[1812,1933,"Go to hell, Lucas."],[1933,2134,"Vera, don't be like that."],[2764,2932,"Believe me now?"],[2980,3187,"She's just an ungrateful bitch."],[3187,3456,"You poured billions into her,"],[3456,3606,"and look how she repays."],[3671,3846,"So what do you say?"],[3846,4006,"Why don't we grab a drink?"],[4700,4871,"So, finally."],[4993,5057,"Take this off."],[5803,5853,"Monica."],[6010,6188,"Why don't we..."],[6188,6314,"put some music on?"],[6314,6412,"I'll set the mood."],[6506,6565,"Okay."],[6665,6851,"Here, pick a song."],[6956,7106,"I'm gonna go take a quick shower."],[7331,7412,"Don't go anywhere."],[10265,10380,"Stop it, Lucas."]],"24":[[74,193,"Stop it, Lucas."],[316,466,"Did you really think"],[466,617,"I would be stupid enough"],[617,755,"to bring the USB home?"],[801,919,"So it was you."],[919,1009,"So what?"],[1009,1191,"You don't have evidence, Lucas."],[1232,1419,"I already switched my phones,"],[1419,1553,"so there's nothing on it."],[1583,1800,"This time, Vera will take the fall."],[1826,1900,"What will that take for you"],[1900,2010,"to leave Vera alone?"],[2030,2092,"Wow."],[2164,2337,"So you really do love her."],[2416,2503,"Look at you."],[2571,2728,"Begging for her?"],[2778,2866,"How pathetic."],[2967,3071,"Don't think I don't know"],[3071,3216,"what went on with you and her"],[3216,3339,"after she stopped you."],[3339,3482,"Name your price."],[3589,3761,"What will it take to get the key back?"],[3788,4000,"You already know my price"],[4000,4106,"and what I want."],[4170,4324,"So what will it be?"],[4324,4592,"One hot night with me?"],[4697,4821,"Or are you gonna go"],[4821,5097,"crawling back to your sweet little Vera?"],[5678,5800,"Vera,"],[5824,5993,"the final deadline."],[5993,6115,"Have you recovered the"],[6115,6257,"encryption key?"],[6257,6434,"No, I haven't."],[6485,6731,"Mr. President, should I call the police?"],[7084,7143,"Wait."],[7240,7451,"I'm gonna give you one last chance."],[7642,7834,"Is there something that you want to tell us all?"],[7915,7978,"Monica?"]],"25":[[0,294,"Mr. President, are you confused?"],[294,458,"Vera has the key."],[458,609,"What does that have to do with me?"],[609,804,"While the surveillance footage in the office"],[804,930,"may have been down,"],[930,1077,"the cameras outside the building"],[1077,1177,"were still working."],[1177,1346,"I checked the feet, Monica."],[1346,1456,"You were here the night"],[1456,1538,"the key went missing."],[1598,1692,"So what?"],[1692,1850,"I came in to do my makeup."],[1850,1953,"Is that a crime now?"],[2005,2123,"Explain this."],[2892,3085,"Impossible!"],[3085,3253,"How did you find that?"],[3307,3528,"I deleted everything."],[3528,3639,"This can't be happening."],[3678,3825,"Well, you may have deleted everything"],[3825,4032,"and wiped your hard drive."],[4032,4184,"It's backed up on the cloud."],[4288,4388,"Of course."],[4470,4614,"Here, pick a song."],[4692,4800,"And that doesn't lie."],[4870,5007,"You hacked into my cloud?"],[5211,5497,"Well, since there is absolutely no confusion"],[5497,5664,"about who stole the key."],[5732,5879,"We should be good now."],[5879,6017,"Monica."]],"26":[[0,229,"I will allow you to resign with your dignity,"],[229,470,"as long as you return the key immediately."],[1208,1285,"Thank you."],[1317,1593,"Thank you, Mr. Wharton. I..."],[1593,1766,"I owe you an apology."],[1766,1866,"I didn't realize that"],[1866,2032,"you were trying to clear my name."],[2069,2232,"I told you, Vera."],[2232,2460,"I'd do anything to earn your forgiveness."],[2460,2521,"I mean,"],[2626,2767,"you're betraying your lover as a coin"],[2767,2883,"to earn my forgiveness?"],[2919,2981,"Lover?"],[3284,3388,"There's nothing going on"],[3388,3502,"between me and Monica."],[3564,3717,"She wants to be my girlfriend,"],[3717,3771,"but..."],[3771,3892,"she doesn't have a chance."],[3920,4046,"There's nothing going on"],[4046,4132,"between you and Monica."],[4132,4302,"Ah, God. Of course not."],[4302,4529,"She's just a manipulative wizard."],[4638,4803,"The girl that I love"],[4835,4935,"is kind,"],[4967,5064,"generous,"],[5115,5242,"beautiful,"],[5271,5453,"like a rainbow in the month in May."],[5600,5797,"Okay. Well then go."]],"27":[[0,60,"Get out."],[60,229,"And go find your May rainbow."],[256,487,"Vera, I just meant that"],[487,588,"the girl that I was"],[588,779,"talking about from my past"],[779,841,"is the girl that"],[841,929,"I want to spend the rest"],[929,993,"of my life with."],[993,1043,"I swear."],[1122,1280,"It's too late, Lucas."],[1280,1446,"I loved you so much."],[1461,1651,"And all you ever did was neglect me."],[1739,1985,"You called me disgusting. You..."],[1985,2185,"You accused me of scheming."],[2185,2309,"You wanted the divorce."],[2309,2483,"You forced the divorce upon me."],[2483,2539,"Vera."],[2539,2731,"So what right do you have"],[2731,2903,"saying all of these things to me now?"],[2903,3087,"I've made mistakes,"],[3087,3267,"and I'm trying to make up for it."],[3329,3496,"I'm even willing to overlook the fact"],[3496,3739,"that you're with some mafia boss, right?"],[3739,3875,"Sleeping with him."],[3875,3928,"Wow."],[4043,4121,"Okay."],[4182,4334,"That's true."],[4334,4427,"Then why are you still"],[4427,4550,"begging for a partnership"],[4550,4647,"with the Costa Group?"],[4667,4864,"Just my way of being sincere."],[4864,5075,"Asking for your forgiveness."],[5100,5388,"It is over, Lucas."],[5388,5507,"I'm going to be announcing"],[5507,5607,"the end of our partnership"],[5607,5752,"at the press conference tomorrow."],[5771,5878,"No. Wait, wait, wait."],[5878,5936,"Don't."],[5936,6156,"My biggest regret"],[6156,6451,"is meeting you, Lucas Wharton."]],"28":[[763,1040,"Simon, I've made up my mind."],[1040,1243,"You tear Lucas and Vera apart,"],[1288,1474,"I'll give you whatever you want."],[2333,2464,"Breaking news."],[2464,2732,"Costa Group held an emergency press conference."],[2732,2932,"Thank you all for attending."],[2950,3080,"I hereby announce that"],[3080,3258,"the Costa Group will be terminating"],[3258,3520,"all business relations with the Wharton Group."],[3535,3611,"Additionally,"],[3611,3799,"on behalf of Chairman Victor Costa,"],[3799,4064,"I will be presenting our European Strategic Plan."],[4100,4224,"Stop!"],[4247,4417,"You can't represent Mr. Costa!"],[4597,4706,"You shouldn't be there."],[4706,4935,"No, Lucas. She's your wife."],[4978,5177,"She can't represent the Costa Group."]],"29":[[0,143,"Oh my God."],[143,378,"Lucas was really secretly married!"],[400,561,"Monica, my personal matters"],[561,748,"have nothing to do in company affairs."],[748,846,"Is that so?"],[846,992,"Then what is your relationship"],[992,1116,"with Mr. Costa?"],[1116,1236,"Enough, Monica."],[1236,1368,"No, Lucas."],[1368,1566,"Today is the day I will not shut up."],[1566,1801,"Explain. What is the relationship"],[1801,2044,"between Victor and your wife?"],[2044,2326,"Monica, if you're so curious to know,"],[2326,2528,"I will have Victor personally"],[2528,2699,"give an interview after the conference"],[2699,3010,"to clarify what our relationship is."],[3037,3282,"Let's air out the dirty laundry now."],[3429,3545,"Oh my God."],[3545,3697,"What's going on between them?"],[3697,3900,"Oh, it's so intimate."],[3979,4147,"So tell us, Vera."],[4147,4298,"Are you Lucas's wife"],[4314,4466,"or Victor's mistress?"],[4466,4718,"The press would obviously really like to know."],[4718,4887,"Monica, shut up."],[4896,5057,"Stop covering for her."],[5057,5232,"She slept with you for money."],[5232,5406,"And now it's Victor's turn."],[5414,5559,"There is nothing in those photos"],[5559,5685,"that proves that there's anything"],[5685,5810,"going on between them."],[5810,5948,"All I see there is"],[5948,6179,"Victor's care and consideration for her."],[6179,6287,"As a friend."],[6287,6382,"Nothing more."],[6389,6481,"Lucas."],[6554,6665,"There's something I need to tell you."]],"30":[[0,136,"There's something I need to tell you."],[212,335,"Don't worry, I don't want to hear."],[441,583,"It's obvious that"],[583,755,"Victor cares for Vera,"],[755,888,"but it's my fault."],[940,1100,"I haven't been a good husband."],[1161,1303,"I let her down."],[1403,1517,"And didn't give her the"],[1517,1789,"care and respect that she deserves."],[1916,2089,"Looking at these pictures,"],[2200,2337,"I feel ashamed."],[2400,2617,"You needed more from me as a husband,"],[2617,2744,"and I failed you."],[2744,2862,"Will you forgive me?"],[2887,3067,"And what I said the other night,"],[3067,3189,"I'm sorry."],[3189,3384,"Give me another chance."],[3384,3552,"Don't divorce me."],[3925,3989,"Go to hell!"],[4275,4310,"Vera!"],[4639,4697,"Monica!"]],"31":[[270,352,"I'm sorry, Simon."],[448,558,"I should've protect her."],[558,696,"Lucas."],[696,888,"Vera is one of our alliance."],[888,1041,"If anything happen to her,"],[1091,1251,"Victor won't spare you."],[1642,1798,"Doctor, how is she?"],[1798,1937,"She recently had a head trauma."],[1937,2112,"I'm worried that"],[2112,2269,"it might be something serious."],[2269,2350,"No need to worry."],[2350,2528,"You're just a superficial wound."],[2528,2759,"However, the tests show that"],[2759,2919,"she's already nine weeks pregnant."],[2994,3051,"What?"],[3256,3360,"I'm gonna be a father!"],[3443,3650,"Oh, doctor! Thank you!"],[3775,3952,"Mr. Wharton,"],[3952,4217,"you should check the test results first."],[4217,4453,"We performed an amniocentesis,"],[4453,4579,"and the results showed that"],[4579,4847,"the fetus shares genetic relationship"],[4847,5010,"with Mr. Costa."],[5085,5161,"What?"],[5221,5293,"What does that mean?"],[5347,5492,"It means the child"],[5492,5642,"isn't yours, Lucas."]],"32":[[0,143,"It means the child"],[143,294,"isn't yours, Lucas."],[396,487,"That's impossible."],[525,654,"Vera's not that kind of woman."],[654,808,"Mr. Wharton."],[808,935,"I'm sharing this with you"],[935,1127,"out of my professional responsibility."],[1127,1400,"If you question the reports' authenticity,"],[1400,1667,"I suggest you speak to Vera directly."],[1778,1955,"What's the matter, Lucas?"],[1955,2098,"Can't accept your own fate?"],[2296,2455,"I need to think about this."],[2866,3167,"Let's keep this between us."],[3167,3297,"The money is all yours."],[3534,3657,"That a boy."],[4152,4238,"Monica,"],[4243,4389,"you can come now."],[4464,4514,"Wow."],[4610,4732,"Where is Lucas?"],[4756,4910,"I have to tell him the good news."],[5597,5684,"It's weird."],[5834,5957,"Why isn't he answering?"],[6224,6288,"Lucas!"]],"33":[[141,220,"Lucas!"],[327,408,"Simon..."],[444,651,"We have to tell Lucas the good news."],[651,755,"Where is he?"],[778,859,"We can finally tell him"],[859,975,"the truth and the baby."],[975,1227,"The baby needs a complete family."],[1227,1359,"I'm sorry, Vera."],[1359,1500,"I regret to inform you that"],[1500,1703,"the blood sample used to identify you"],[1703,1785,"was incorrect."],[1826,1905,"Incorrect?"],[1973,2123,"What are you talking about?"],[2123,2287,"You're just a nobody."],[2287,2496,"We've already found the real heiress."],[2560,2780,"What? Who?"],[2780,2883,"Obviously,"],[2912,3030,"it's me."],[3192,3356,"Simon, that's unbelievable."],[3356,3607,"How could Monica possibly be Victor's sister?"],[3756,3850,"It's the truth."],[4120,4243,"Well, umm..."],[4243,4502,"I'm sorry... for taking"],[4502,4634,"someone else's identity,"],[4634,4815,"I'll leave the Costa family."],[4950,5032,"Leave?"],[5085,5278,"You think it's that simple?"],[5347,5493,"You thief!"],[5561,5770,"You stole my identity!"],[5770,5885,"Selfish bitch!"],[5885,5996,"What are you talking?"],[6302,6506,"Lucas, where are you?"],[6606,6668,"Stop!"]],"34":[[22,72,"Stop!"],[154,275,"What the hell are you doing?"],[341,470,"Stay away from her."],[558,645,"Vera,"],[645,748,"I've made up my mind."],[791,975,"I don't care if the baby is Victor's."],[988,1024,"What?"],[1024,1146,"Just give me a chance"],[1146,1222,"and I'll look after you"],[1222,1309,"for the rest of my life."],[1309,1419,"Are you crazy?"],[1419,1572,"How could the baby be Victor's?"],[1572,1735,"He's my brother."],[1814,1951,"No, Lucas!"],[1951,2092,"She has you fooled."],[2139,2323,"She stole my identity."],[2323,2553,"I am Victor's real sister."],[2553,2717,"Simon can vouch for me."],[2717,2826,"Is that true, Simon?"],[2826,2932,"What is she talking about?"],[2983,3062,"Go ahead."],[3062,3215,"Show them the necklace you had"],[3215,3338,"when you were adopted."],[3439,3603,"Tesoro della Famiglia."],[3660,3853,"In Italian, it means"],[3853,4006,"\"treasure of the family\"."],[4006,4152,"My grandmother gave it to me"],[4152,4275,"right before we parted."],[4338,4507,"Victor did mention that necklace."]],"35":[[32,186,"Victor did mention that necklace."],[256,366,"So, Lucas."],[366,509,"Do you get it now?"],[509,725,"Vera didn't just steal my identity."],[725,888,"The child belongs to Victor."],[946,1130,"No, Lucas, she's lying."],[1130,1335,"There's nothing between me and Victor."],[1335,1422,"You can call Victor"],[1422,1582,"and find that out for yourself."],[1582,1903,"Victor's already found his real sister."],[1903,2030,"Do you really think"],[2030,2189,"he'll care about you now?"],[2189,2285,"Enough."],[2328,2498,"I don't care if..."],[2498,2660,"I don't care if Vera's..."],[2660,2846,"a rich princess or"],[2846,3014,"an orphan from the slums."],[3126,3264,"She has my baby and"],[3264,3396,"I will take care of her."],[3500,3674,"Now get out, you buzzing flies."],[3674,3765,"And you!"],[3765,3915,"If you ever touch her again,"],[3915,4110,"you'll regret it for the rest of your life."],[4110,4178,"Get out."],[5453,5567,"Are you okay?"],[5682,5775,"It looks sore."],[5815,5896,"It's okay."],[5896,6085,"Lucas, I want to talk to you"],[6085,6169,"about everything."],[6192,6325,"There's no need, just..."],[6325,6448,"You should rest."],[6448,6620,"I just feel like I need to clarify everything"],[6620,6737,"that happened tonight."],[6737,6876,"Vera, let's talk tomorrow"],[6876,7045,"after you've rested, okay?"],[7045,7148,"Do you trust me?"],[7215,7385,"What I said in the hospital,"],[7385,7523,"even the baby's Victor's,"],[7523,7643,"I'll still take care of it."],[7723,7885,"You're such an idiot."],[7931,8078,"The baby's yours."],[8078,8265,"It's not Victor's."],[8378,8557,"We're gonna have a family."]],"36":[[124,180,"What's wrong?"],[245,425,"Just so much going on lately."],[582,700,"The prenatal report,"],[741,832,"Monica being"],[832,1077,"the heiress of the Costa family."],[1198,1356,"I don't know what to believe anymore."],[1464,1616,"Trust me."],[1616,1769,"I'm gonna get to the bottom of this."],[1869,1953,"I know that you're..."],[2133,2253,"You've left the Costa family"],[2253,2339,"what will you do now?"],[2457,2535,"Did you forget?"],[2612,2821,"I still have an unfinished job to do."],[3310,3424,"Damn it!"],[3446,3774,"Comet Media still hasn't fired Vera?"],[3774,3946,"You need to do something."],[3946,4092,"Get rid of that bitch for good."],[4175,4257,"I'm sorry."],[4257,4400,"That's outside my pay range."],[4438,4571,"Besides,"],[4571,4648,"I already helped you"],[4648,4828,"steal her family identity."],[4828,5007,"It's time you pay what's owed to me."],[5057,5265,"No, no, no! Simon."],[5265,5396,"The deal isn't over until"],[5396,5660,"she's completely out of our lives."],[5660,5807,"Fine, Monica."],[5807,5892,"But for that,"],[5925,6052,"I'll do it for this much."],[6634,6818,"Monica, what are you still doing here?"]],"37":[[10,189,"This is my family's company."],[189,312,"Why shouldn't I be here?"],[356,540,"You, on the other hand,"],[540,655,"stole my identity."],[751,941,"And now, it's all exposed."],[1035,1188,"Didn't expect Vera to be"],[1188,1301,"that kind of person."],[1301,1466,"What Miss? She's just a thief!"],[1524,1669,"Get out, Vera."],[1669,1907,"Comet Media doesn't welcome thieves."],[1907,1998,"I'm here because I'm"],[1998,2155,"working on a Wharton project"],[2155,2287,"Once that project is complete,"],[2287,2482,"I will leave on my own volition."],[2482,2596,"Oh, really?"],[2596,2755,"Here for another payday?"],[2812,2971,"Here's a million dollars."],[3096,3365,"Now, kneel down and apologize."],[3365,3507,"And maybe I'll throw you a bone."],[3507,3603,"You're pathetic."],[3653,3761,"Stay out of my work."],[3761,3875,"Don't run, Vera!"],[3875,4015,"You faked being a rich heiress"],[4015,4150,"and seduced Mr. Wharton."],[4150,4288,"Now you think you can just walk away?"],[4311,4393,"Monica,"],[4393,4493,"these two-faced women"],[4493,4634,"should be fired immediately."],[4664,4788,"Mind your business."],[4788,4939,"Oh yeah?"],[4939,5124,"Then let's see who Victor picks."],[5124,5307,"Me or you?"],[5307,5414,"Security!"],[5414,5593,"Get this tramp out of here."],[5739,5829,"Let go of me."],[5921,5964,"Stop!"]],"38":[[0,285,"Brother, she stole my identity."],[285,485,"Why are you still siding with her?"],[509,762,"Yes, Simon told me everything."],[762,898,"And thank you for bringing"],[898,1019,"Grandma's necklace back."],[1019,1161,"Then let's kick Vera out."],[1161,1356,"I don't want to see her anymore."],[1356,1671,"No, that won't be happening, Monica."],[1671,1810,"It was my mistake."],[1810,2037,"I misjudged Vera's identity."],[2037,2262,"So, I need to apologize."],[2350,2578,"Mr. Costa, since my identity was mistaken,"],[2578,2738,"I won't stay here"],[2738,2871,"taping up your resources."],[2926,3090,"Thank you for your kindness."],[3090,3250,"But I'll be resigning"],[3250,3428,"once the Wharton project is completed."],[3428,3565,"No need to resign."],[3643,3761,"I want you to work closely"],[3761,3871,"with the Wharton Group."],[3910,4132,"You and Lucas"],[4132,4320,"work good together."],[4393,4573,"And I hope that you can continue"],[4573,4711,"to represent us in the future."],[4711,4932,"No! You can't do that!"],[4967,5128,"Enough, Monica."],[5128,5254,"I have more important things"],[5254,5357,"for you to do."],[5357,5506,"Like first,"],[5506,5814,"send these two idiots to Ethiopia."],[5870,6015,"Second,"],[6015,6221,"I want you to apologize to Vera."],[6221,6392,"Right now."]],"39":[[10,158,"I'm your sister!"],[158,298,"Why should I apologize to that"],[298,379,"bitch?"],[379,733,"Don't use that word again."],[733,824,"Or do you want me"],[824,961,"to send you to Africa as well?"],[1030,1235,"Sorry, Vera."],[1235,1472,"Now, Vera, may I ask you"],[1472,1575,"to invite Lucas"],[1575,1751,"to the dinner tonight with me?"],[1751,1895,"I'll look at the DNA report"],[1895,2066,"and investigate it personally."],[2066,2192,"Make sure that you're clear"],[2192,2362,"of all our wrong doings."],[2416,2460,"Of course."],[2771,3037,"Vera, I just finished up here."],[3037,3140,"I'll be there soon."],[3224,3397,"Ten minutes?"],[3397,3489,"Okay, see you soon."],[3906,4024,"Lucas!"],[4024,4124,"You?"],[4175,4274,"What are you doing here?"],[4342,4402,"There's something"],[4402,4538,"I want to talk to you about."],[5403,5463,"Monica,"],[5463,5534,"what are you doing?"]],"40":[[389,441,"He's late."],[533,803,"I'm sorry. Maybe he's stuck in traffic."],[803,951,"But this Lucas guy."],[951,1117,"Can't he be on time for a dinner?"],[1117,1177,"You sure you want to"],[1177,1306,"restart things with him?"],[1306,1500,"Mr. Costa,"],[1500,1739,"I've liked Lucas for a really long time."],[1739,1819,"You know that"],[1819,1978,"story that I told you about the fire?"],[2057,2198,"He was the boy that I saved."],[2253,2417,"I just don't think he remembered that."],[2482,2648,"Alright, Vera."],[2648,2746,"I'm not getting to judge you"],[2746,2853,"on your personal life."],[2926,3062,"Can you tell me one thing?"],[3155,3339,"Why did you come to media company today?"],[3617,3839,"It was all due respect, Mr. Costa."],[3915,4071,"I just want to warn you"],[4071,4235,"about Monica."],[4235,4334,"I just don't..."],[4334,4511,"think that you should trust her."],[4511,4628,"You're absolutely right."],[4710,4906,"I haven't believed her from the beginning."],[4946,5043,"Not even once."],[5197,5374,"And stop calling Mr. Costa."],[5424,5571,"Because in my heart,"],[5828,5925,"you're my only sister."]],"41":[[375,545,"Final offer, Vera."],[800,901,"This 10 million..."],[1161,1258,"What are the conditions?"],[1291,1435,"Give up Lucas,"],[1435,1612,"and this 10 million is yours."],[1712,2017,"You know, you can't buy love for money, right?"],[2069,2264,"Since you refused my offer,"],[2264,2532,"don't be surprised at what happens next."],[2614,2662,"What are you doing?"],[2733,2898,"Who do you think my brother will believe?"],[2935,3085,"Me or you?"],[3692,3906,"I caught her stealing money and..."],[3906,4092,"then she tried to kill me."],[4092,4215,"She's lying."],[4215,4384,"She brought that money to bribe me"],[4384,4514,"and then she hit herself"],[4514,4685,"so that she could frame me."],[4685,4824,"You're my brother."],[4824,5011,"Why would I lie to you?"],[5011,5225,"You're right, Monica."],[5225,5402,"I should believe my real sister."],[5706,5761,"But..."],[5917,5996,"Are you?"]],"42":[[10,136,"Are you my real sister?"],[222,360,"What are you trying to say?"],[375,505,"You know exactly"],[505,628,"what he's trying to say."],[691,832,"You're a fraud."],[832,1016,"You colluded with an insider"],[1016,1108,"and impersonated me."],[1108,1194,"Why you didn't think that"],[1194,1282,"we weren't gonna find out?"],[1282,1351,"No!"],[1441,1680,"I'm definitely your real sister."],[1680,1892,"I even have our grandmother's necklace"],[1892,1979,"to prove it."],[2003,2174,"Mr. Simon can prove it."],[2187,2385,"I have Mr. Simon on the phone right now."],[2462,2714,"Yes, I did take Monica's money,"],[2714,2898,"but like I said, it was..."],[2964,3019,"I just..."],[3278,3579,"So you were acting this whole time?"],[3579,3753,"I suspected it for some time."],[3992,4149,"But I was just waiting for him"],[4149,4275,"to expose himself."],[4402,4517,"You were the one"],[4517,4720,"who crashed that car into me."],[4752,5030,"You were with Panta to assault me."],[5030,5180,"You stole the hard drive."],[5180,5355,"You orchestrated the entire"],[5355,5548,"press conference attack against me."],[5581,5761,"Now you're trying to frame me."],[5803,5879,"Again?"],[6064,6164,"You know what?"],[6242,6445,"I think it's time for you pay for that."],[6662,6900,"No! Please!"],[6900,7048,"I was just being jealous."],[7092,7150,"Please!"],[7150,7329,"Please just give me this one more time."],[7456,7535,"Please!"],[7535,7618,"Stop!"]],"43":[[26,130,"Don't hurt her."],[130,222,"What are you doing?"],[291,413,"No matter what she's done."],[413,474,"I'm begging you."],[474,682,"Please don't shoot her."],[758,874,"You idiot!"],[974,1193,"She's been trying to kill Vera all this time."],[1193,1250,"And now you're going to"],[1250,1383,"sacrifice your life for her?"],[1517,1633,"Get your head straight!"],[1700,1789,"Who did you marry?"],[1835,1942,"Victor,"],[1994,2178,"I know everything."],[2178,2269,"Monica?"],[2342,2487,"She's important to me."],[2542,2717,"I can't just stand by"],[2717,2855,"and let you hurt her."],[2855,3044,"What do you mean she's important to you?"],[3044,3221,"Why is she important to you?"],[3355,3742,"Look, it's complicated to get into it now, but..."],[3742,3920,"if I have to take the bullet for her,"],[4003,4085,"I will."],[4156,4235,"Lucas."],[4297,4415,"Is Monica the girl that"],[4415,4547,"you've talked to me before?"],[4750,4820,"There's something I want to"],[4820,4925,"talk to you about."],[5396,5579,"I don't have time for this right now."],[5684,5903,"Don't you remember the fire, Lucas?"],[5970,6085,"This scar."],[6156,6332,"I got it saving you."],[6332,6457,"What are you talking about?"],[6457,6600,"You were so terrified."],[6681,6885,"Crying like a baby."],[6885,7023,"I saved us."],[7135,7271,"I used the fire extinguisher"],[7271,7415,"to break down the door."],[7598,7745,"Are you choosing her right now?"],[7937,7981,"Yes."]],"44":[[66,119,"Yes."],[398,436,"Let's go."],[583,716,"I never want to see you again."],[796,846,"Vera..."],[927,1019,"Let me explain."],[1056,1324,"Don't you ever bother my sister again,"],[1324,1472,"or I'll make you disappear."],[1527,1600,"Literally."],[2289,2371,"Lucas!"],[2430,2516,"That's the kindest thing"],[2516,2650,"you've done in years."],[2650,2801,"I just did that to pay you back."],[2855,2937,"Now we're even."],[3001,3087,"Monica..."],[3185,3256,"I hope..."],[3393,3692,"you can get your life back together and..."],[3692,3811,"do something useful."],[3910,4079,"So you don't love me anymore?"],[4142,4353,"I don't know how to say this, but..."],[4452,4653,"it was never going to happen between us."],[4732,4864,"It was always Vera."],[4864,5065,"But she left you!"],[5065,5215,"Just stay out of my business."]],"45":[[119,184,"Hey, Nash."],[254,436,"That little trump card of yours"],[436,658,"was useless on Lucas."],[778,848,"He was the only one"],[848,1035,"moved by the girl from the fire."],[1127,1243,"And that was the secret"],[1243,1351,"that I found in his journal."],[1474,1554,"Whatever."],[1554,1698,"Just tell me what to do next."],[1698,1903,"Hey, wait."],[1903,2078,"Monica, this isn't for you, okay?"],[2171,2346,"Also, if you keep pushing it,"],[2346,2556,"I will have to tell him a little secret"],[2556,2764,"about how you've tricked Lucas."],[2826,2912,"Anyway."],[3050,3157,"My advice"],[3225,3325,"is that you leave now."],[4021,4238,"Vera, this is Nash."],[4238,4467,"He was the engineer at our MIT group."],[4507,4693,"Now, the reason I brought you two together"],[4693,4910,"is because Vera recently"],[4910,5125,"was burned by a scumbag."],[5125,5220,"Just saying,"],[5270,5371,"it happened,"],[5371,5521,"and now I just thought"],[5521,5697,"it would be great to partner you guys up."],[5802,5956,"It's an honor, truly."],[6025,6170,"I appreciate the opportunity."],[6217,6265,"Please,"],[6265,6315,"have a seat."]],"46":[[30,91,"Yeah, right."],[91,285,"Well, I'll leave you two to it."],[285,467,"I have some business to attend to."],[530,583,"Enjoy."],[938,1069,"Thank you for dinner, Nash."],[1108,1201,"I know you're pregnant,"],[1201,1348,"so I order you some juice."],[1403,1666,"Wow. Are all engineers this attentive?"],[1737,1912,"Well, please wait a moment."],[2119,2246,"I'm sorry if I offended you."],[2289,2382,"Wow."],[2382,2580,"With manners like that, I feel like"],[2580,2717,"I should listen to my brother"],[2717,2794,"and give you a chance."],[2821,2948,"I'm thankful."],[2948,3232,"But actually, I wanted to ask you that..."],[3232,3415,"if you would like to come"],[3415,3670,"to our family's banquet tomorrow."],[3670,3815,"Would you do me,"],[3815,3939,"I mean, the honor,"],[3939,4150,"of coming to the event as a guest?"],[4874,4935,"Cheers."],[4982,5078,"Well done there, Nash."],[5078,5178,"Thank you for coming."],[5178,5238,"Thank you so much."],[5339,5360,"Enjoy."],[5829,5871,"Nash."],[5979,6025,"Lucas."],[6139,6235,"It's been a long time."],[6278,6310,"Indeed."],[6406,6550,"How have you been?"],[6550,6670,"Business is great."],[6670,6771,"What about marriage?"],[6831,6881,"Complicated."],[6965,7284,"I don't mean to rub it into your face, but..."],[7284,7498,"I just met this amazing woman."],[7498,7650,"She's incredible."],[7650,7759,"Is that so...?"],[7859,7981,"Congratulations."],[8764,9000,"Oh. Here she is."],[9000,9062,"Whuh?"]],"47":[[300,508,"What's the meaning of this?"],[508,663,"Vera is my wife."],[663,787,"Not for long."],[787,881,"I've already found her"],[881,1022,"the best divorce lawyer."],[1022,1169,"You two know each other?"],[1169,1316,"Know him?"],[1316,1430,"Nash is my cousin."],[1538,1673,"He's one of the most..."],[1673,1780,"most victorious and christened"],[1780,1844,"in the family."],[1907,1987,"You know what, Lucas?"],[1987,2148,"Stay out of my business."],[2242,2362,"Let me explain."],[2362,2503,"It's not what I seemed."],[2503,2689,"Monica save my life."],[2689,2789,"I owe her."],[2850,2983,"Enough, Lucas."],[2983,3157,"I've done everything for you."],[3157,3335,"But what have you given me in return?"],[3335,3447,"You disgust me."],[3506,3706,"When I begged you to trust me,"],[3706,3846,"you told me so coldly."],[3846,3984,"Fine. But no more games."],[4046,4197,"At the banquet,"],[4197,4282,"you and Monica"],[4282,4450,"humiliated me in public."],[4585,4802,"When I was falling to death,"],[4802,5015,"you and Monica were falling in love."],[5169,5289,"When I made up my mind,"],[5304,5477,"trying to overcome the misunderstanding"],[5477,5635,"and get closer to you."],[5834,5956,"I was once touched by"],[5956,6125,"your influence and protection too."],[6202,6426,"As I thought everything could be restarted,"],[6426,6696,"you chose to block my gun with your chest"],[6696,6862,"to protect Monica,"],[6882,7000,"the one who's tried to kill me"],[7000,7126,"over and over again."],[7279,7385,"Save it, Lucas."],[7476,7520,"Well,"],[7520,7698,"you need to stop bothering anyone here"],[7698,7780,"and go back to Monica"],[7780,7950,"since you want to protect her so bad."]],"48":[[18,117,"There's nothing going on"],[117,233,"between us."],[233,322,"I swear."],[360,463,"Just give me a chance."],[504,779,"You hurt me over and over again."],[779,928,"And then you turn around"],[928,1058,"and you beg for forgiveness"],[1058,1214,"like it's nothing happened."],[1214,1356,"It's exhausting."],[1356,1550,"This toxic cycle that we're in,"],[1550,1751,"it's torture for both of us."],[1751,1926,"I've sent you the divorce papers."],[1926,2062,"You should expect closer."],[2150,2192,"Fine."],[2335,2441,"I deserve that."],[2542,2616,"Please."],[2707,2839,"Don't go with him."],[2839,2937,"He's not a good man."],[3001,3187,"Nash. Let's go."],[3232,3289,"Yes."],[4046,4179,"I am so sorry I didn't mean to"],[4179,4296,"cause you distress."],[4357,4617,"That slap was for abusing my trust."],[4617,4684,"Oh, you know what?"],[4684,4888,"Lucas is right. You're a snake."],[4888,4997,"What? Did you just bring me here"],[4997,5075,"to provoke him?"],[5075,5274,"I just wanted his blessing."],[5274,5328,"You know what?"],[5328,5560,"I've heard rumors about Lucas's scheming cousin"],[5560,5761,"who just wants to be the heir of the family."],[5838,5992,"Nash, people see through you."],[5992,6265,"Oh look, my feelings for you is genuine."],[6265,6390,"Would you say that if you didn't know that"],[6390,6521,"I was the Costa heiress?"],[6635,6742,"Save it."],[6742,6890,"I'm not an idiot."],[6890,7078,"Stop embarrassing yourself."],[7078,7150,"I..."],[7150,7284,"underestimated you."],[7428,7498,"Anyway,"],[7554,7609,"not for long,"],[7609,7715,"the result's gonna be the same."],[7879,7965,"No."],[7965,8087,"Where do you think you're going?"],[8448,8600,"Investigations Bureau."],[8628,8854,"Missing persons. FBI."],[8854,9042,"Silly bloodhound dog."],[9042,9179,"I don't care what you have to do."],[9179,9259,"Find her!"],[9426,9593,"I tried everything, Lucas."],[9593,9773,"Even Victor cannot find her."],[9773,9859,"And where's the damn"],[9859,10001,"cousin of mine, Nash?"],[10001,10154,"He was the last one to see her."],[10154,10295,"Hello, Lucas."],[10295,10515,"You don't have to let it out on your staff."],[10584,10659,"I'm here."]],"49":[[136,266,"I swear to God."],[283,574,"If you touch the hair of her head,"],[667,927,"I'll wipe your face off this plant."],[1203,1350,"What's the matter, Lucas?"],[1432,1630,"Is that fear I see in your eyes?"],[1800,1966,"Believe me when I say."],[1966,2089,"You make one wrong move,"],[2166,2355,"and you will never see her again."],[2355,2487,"Just tell me what you want."],[2557,2735,"Sit down and let's have a talk properly."],[3647,3828,"Sign this."],[3828,3971,"A few simple steps."],[3971,4246,"First, resign and hand over"],[4246,4374,"the company to me."],[4374,4525,"Make me the CEO."],[4635,4839,"Transfer billions will take time."],[4975,5060,"I could start with some"],[5060,5275,"personal saving investment."],[5275,5452,"No, no, no, no."],[5452,5603,"Dear cousin."],[5711,5997,"You're mistaken. You are in no position"],[5997,6193,"to negotiate with me right now."]],"50":[[198,398,"Somebody help! Help me!"],[528,604,"Lucas! Lucas!"],[604,687,"I got to save you."],[751,872,"Lucas, there's a bomb!"],[872,983,"There's a bomb!"],[1141,1303,"Stop! You don't have time."],[1303,1390,"Go!"],[1390,1572,"Save yourself! Go!"],[1648,1766,"No Vera."],[1766,1970,"I had plenty of time to be by your side"],[1970,2171,"day and night."],[2271,2403,"But I never realized"],[2403,2553,"the duty of being your husband."],[2817,2959,"Every rudeness, arrogance,"],[2959,3202,"and foolishness of mine has been nothing"],[3202,3434,"but a fucking disaster upon you."],[3765,3867,"Wounded as you were,"],[3867,4138,"you kept holding me, saving me,"],[4138,4342,"putting everything aside just for me…"],[4564,4765,"Now, Vera, my wife."],[4828,5003,"It's about time your damn husband"],[5003,5189,"shed blood to do something for you."],[5265,5393,"Vera,"],[5393,5550,"I made you a promise"],[5550,5668,"that I will protect you."],[5747,5864,"If you die,"],[5900,6038,"I will die with you."],[6278,6361,"I love you."],[6397,6540,"I love you."]],"51":[[2248,2433,"If it wasn't for Lucas this time,"],[2619,2796,"I would've lost Vera forever."],[2846,3001,"But once she awakes,"],[3001,3105,"how are we going to tell her?"],[3824,3897,"Where's Lucas?"],[4002,4157,"He... uh..."],[4256,4434,"Oh, Vera,"],[4434,4615,"you're very lucky."],[4615,4775,"When the explosion occurred,"],[4775,4971,"Mr. Lucas shielded you with his body."],[4971,5138,"So you just suffer quite a bit."],[5138,5261,"Where is Lucas?"]],"52":[[775,914,"Lucas, you have to wake up, please."],[914,951,"Please!"],[951,1046,"Please wake up."],[1214,1383,"The prognosis is not good."],[1464,1694,"He may remain in a long-term coma."],[1694,1821,"No."],[1821,2042,"No. Then when will he wake up?"],[2042,2216,"It depends on his willpower."],[2283,2380,"Vera."],[2380,2573,"The hospital will do everything we can."],[2573,2753,"But..."],[2753,2962,"you must be mentally prepared."],[2962,3076,"Please."],[3076,3257,"Lucas, you have to wake up."],[3257,3364,"You were the one that said that"],[3364,3488,"we could start over."],[3488,3679,"We could start fresh. We..."],[3679,3788,"I... I've"],[3788,3953,"I've withdrawn the divorce agreement."],[4002,4196,"Look at me, baby, we can be happy."],[4196,4296,"We can be together."],[4296,4365,"You just.."],[4365,4553,"You... Please, you need to wake up,"],[4553,4679,"Please."],[4714,4793,"Please..."],[5085,5224,"You said it."],[5329,5478,"And I want you till the last."],[5852,6056,"Lucas..."],[6056,6252,"Easy… I'm right here."],[6303,6468,"I'll call the doctor, okay?"],[6501,6548,"Wait."],[6804,6906,"Stay with me alone."]],"53":[[1080,1262,"20 years, every drop of blood"],[1262,1529,"I spilled in this road to Mafia world"],[1567,1748,"was for one thing."],[2105,2276,"Finding my sister."],[2503,2583,"Vera."],[2583,2738,"I want you to use every medical resource"],[2738,2878,"in this planet to save her life."],[2953,3121,"And if you fail,"],[3121,3293,"It'll be the last thing that you do."],[3402,3574,"She doesn't remember?"],[3574,3643,"Fine."],[3689,3879,"Let the world come at her."],[3897,4029,"I will tear it apart"],[4029,4302,"before it leaves a finger on my sister."],[4385,4579,"I don't care who it is."],[4610,4829,"I can see it in her eyes."],[4896,5088,"She's inching to remember,"],[5143,5365,"to pace it all by together."],[5392,5593,"But...damn it."],[5593,5725,"How could I stand by"],[5725,5846,"and watch her suffer?"],[5846,5885,"Vera."],[6093,6279,"Get your fucking hands off her."],[6379,6581,"No. Not ever."],[6581,6720,"Not while I'm breathing."],[6720,6935,"Sorry to interrupt, Mr. Costa."],[6935,7104,"There's something I need your help with."],[7295,7357,"Please."]],"54":[[202,327,"Take a good look at this agreement."],[428,582,"Lucas is history."],[582,678,"He's past."],[720,783,"On the other hand,"],[827,982,"starting from today."],[982,1167,"I... Nash Wharton,"],[1216,1422,"I am your king now."],[1422,1712,"I am the healer you don't deserve."],[1712,1926,"I am the devil you can't run from."],[1926,1996,"I?"],[2160,2214,"I am the CEO"],[2214,2330,"of this company."],[2394,2632,"I believe Nash lacks the experience for this."],[3183,3276,"Anyone objects"],[3276,3452,"me being the CEO?"],[3575,3632,"Excellent."],[4306,4420,"Apologies."],[4420,4606,"Us mafiosos"],[4606,4828,"love meddling other people's business."],[4870,4988,"Big man."],[5056,5206,"Get this motherfucker"],[5206,5300,"out of here!"]],"55":[[737,911,"Mr. Wharton."],[911,1058,"Is today's press conference to"],[1058,1219,"announce your marriage to Vera?"],[1261,1359,"Actually, no."],[1432,1630,"We've been husband and wife for a while."],[1630,1764,"Today is just to announce that"],[1764,1890,"Lucas is throwing me"],[1890,2017,"the wedding we never had."],[2114,2348,"Does this mean a formal alliance"],[2348,2455,"between the Wharton Group"],[2455,2603,"and the Costa family?"],[2603,2814,"No. We don't need a marriage"],[2814,2964,"to form a business partnership,"],[2964,3153,"because we're truly in love."],[3384,3500,"Hey, look here."],[3500,3653,"We gonna take a picture."],[3867,3950,"One more."],[4321,4385,"It's great."],[4429,4488,"I think so."],[4488,4611,"I heard you like that one."],[4611,4728,"Yeah."],[5056,5234,"Who told you two"],[5234,5471,"that it was okay to have a press conference"],[5471,5610,"and announce the wedding?"],[5610,5716,"Without me."]],"56":[[16,62,"Brother."],[100,239,"Listen, Lucas,"],[239,366,"everything that you've done,"],[366,467,"we're grateful."],[467,650,"But just step back and"],[650,893,"allow me to arrange things from now on."],[990,1041,"Fine."],[1225,1293,"But..."],[1540,1685,"The baby should have the Wharton name."],[1716,1937,"Ah. Maybe we talk"],[1937,2126,"a little bit more about this."],[2126,2330,"You're not planning my wedding."],[2330,2557,"I've already decided what wedding I want."],[2557,2712,"It's going to be on a sunny day."],[2712,2885,"And I'm going to wear a white dress."],[2885,3067,"And I'm going to wear grandma's necklace."],[3119,3279,"Well, I guess it's settled then."],[3357,3507,"So, about the Wharton name."],[3643,3741,"Are we sure about this?"],[3802,3934,"Yeah. I mean, you know,"],[3934,3996,"I'm the father."],[4043,4118,"Yeah. Right. I don't want"],[4118,4264,"my kid to have a war thing, huh?"],[4350,4397,"Come on."],[4632,4860,"Okay. So, looking confetti and streamers."],[4860,4939,"I'm going to go over there."],[4939,5003,"And then,"],[5003,5085,"for the drinks, I just have to"],[5085,5184,"double-check with my brother."],[5184,5238,"Pretty sure."],[5347,5392,"And he's..."],[5412,5475,"stressed."],[5703,5793,"Hey, Vera."],[5853,5946,"Could you come here and"],[5946,6056,"confirm something?"],[6056,6164,"I can't, Leo."],[6164,6315,"I'm not the secretary today!"],[6714,6878,"Okay, guys. Quickly."],[7800,7968,"Follow me, sweetheart."]],"57":[[10,99,"Ladies and gentlemen,"],[128,176,"the wedding of"],[176,333,"Miss Costa and Mr. Wharton"],[333,540,"will begin in 10 minutes."],[540,644,"Okay."],[644,790,"Dude, the last time to check, alright?"],[790,832,"Oh, good."],[1051,1214,"Well, the time has come."],[1280,1401,"Yes, it has."],[1416,1503,"Speaking of which,"],[1503,1600,"have you seen Vera?"],[1650,1792,"No. We should notify her."],[1792,1869,"Emergency."],[1969,2162,"Vera has been kidnapped by Monica."],[2239,2333,"She said,"],[2394,2550,"she will kill Vera."],[2550,2689,"That little bitch."],[2689,2855,"She touches her hair on Vera's head,"],[2855,2987,"she's dead."],[2987,3167,"Victor, I got this."],[3200,3342,"Stay here with the guest salute."],[3342,3489,"I'll go and bring her back."],[3489,3632,"She'll be fine, I promise."],[4934,5056,"What are you doing?"],[5110,5171,"Let me go!"],[5264,5470,"I told you to stay away"],[5470,5596,"from Lucas."],[5647,5702,"You're insane."],[5702,5810,"What do you want from me?"],[5906,6078,"Insane?"],[6078,6353,"I did so much for Lucas."],[6353,6645,"And you! You ruined everything!"],[7131,7251,"Do you..."],[7310,7465,"Do you really think that"],[7465,7751,"killing me is gonna get you Lucas?"],[7826,7885,"Oh, it's not."],[8004,8107,"Who said anything about"],[8107,8200,"killing you?"],[8276,8495,"I'm just gonna cut your pretty face"],[8523,8747,"and see if he wants you now!"],[8765,8828,"Stop!"]],"58":[[0,75,"Stop!"],[200,416,"Monica, let her go."],[416,537,"I'll give you whatever you want."],[616,861,"I want you, Lucas."],[861,1080,"I did so much for you."],[1080,1203,"Why can't you love me?"],[1322,1440,"Lucas,"],[1440,1617,"when I first time met you,"],[1617,1750,"I fell in love with you,"],[1750,2019,"although Leo told me that you already married."],[2064,2330,"But what I want..."],[2330,2476,"I will never let it"],[2476,2644,"slip through my fingers."],[2923,3243,"But Lucas, I love you so damn much."],[3243,3470,"Why do you keep ignoring me,"],[3470,3592,"pushing me away?"],[3857,3974,"Even your gaze,"],[3974,4134,"never spared me for"],[4134,4239,"one more second."],[4239,4324,"I don't have time for this right now."],[4417,4693,"I keep trying to reassure myself."],[4693,4925,"You are just a steady,"],[4925,5114,"slow-to-warm-off type."],[5161,5293,"But then,"],[5293,5546,"I saw how you were so wrapped up in Vera."],[5629,5764,"If you ever touch her again,"],[5764,5842,"you'll regret it"],[5842,5928,"for the rest of your life."]],"59":[[20,168,"I'm so jealous, Lucas."],[268,467,"If I can't have your love,"],[632,803,"then let everything go to hell."],[858,1038,"This is between you and me."],[1038,1196,"Vera's got nothing to do with this."],[1258,1632,"Alright. I should keep with you."],[1632,1900,"You love her so much."],[1989,2226,"The best revenge"],[2226,2362,"would be if I just"],[2362,2466,"killed her with now!"],[2466,2498,"No!"],[3307,3374,"Are you okay?"],[3374,3538,"I'm fine. Call the police!"],[3790,3952,"The police?"],[3952,4352,"Oh no! I don't want to go to jail."],[4639,4834,"Was that you begging for forgiveness?"],[4911,5082,"What are you talking about, Lucas?"],[5242,5403,"You always talk about the fire."],[5528,5624,"Why don't I give you"],[5624,5734,"one last memory?"],[5888,6088,"Let's all die together here."]],"60":[[0,214,"Let's all die together here."],[604,766,"Go to hell, bitch."],[766,858,"And stay there!"],[996,1093,"Let's get out of here."],[2555,2666,"You really are the girl"],[2666,2792,"from the fire that saved me."],[2955,3089,"You're so smart."],[3089,3297,"And only took you a year to figure out."],[3297,3493,"So when you asked me to marry you?"],[3575,3710,"It was love at first sight."]]}