{"1":[[129,229,"To most people,"],[275,446,"Christmas means love."],[575,638,"Or hope."],[750,809,"Happiness."],[913,967,"Birth."],[1101,1217,"Seven years ago,"],[1292,1405,"on Christmas Eve,"],[1539,1710,"I lost my wife."],[1910,2043,"She died because of me."],[2252,2419,"Her, our daughter,"],[2535,2690,"a daughter I never got to meet."],[2969,3140,"I don't deserve happiness."],[3228,3319,"I don't deserve hope."],[3415,3674,"My love died with my wife and child."],[3853,3953,"It should have been me."],[4220,4450,"To me, Christmas is..."],[4587,4758,"I saved up a whole year for this."],[4788,4921,"I hope this makes him smile."],[5159,5263,"You fool!"],[5280,5472,"When are you leaving that whore?"],[5538,5684,"Lucy is the love of my life,"],[5826,5997,"and I would rather die than leave her!"],[6006,6139,"Raphael, she's a nobody."],[6181,6410,"She'll never be a part of our family!"],[6456,6548,"Look, Raphael,"],[6602,6744,"I have a whole team of surgeons"],[6744,6986,"from Germany right here waiting."],[7065,7328,"Leave her, and I'll put you on the best"],[7365,7611,"experimental treatments."],[7682,7791,"I said,"],[7820,7866,"no!"],[8541,8633,"So it's me."],[8746,8892,"I'm the one who's killing him."]],"2":[[333,425,"Ah, Lucy."],[1192,1247,"Here."],[1397,1472,"Merry Christmas."],[1997,2193,"I know it isn't much,"],[2193,2452,"but we never got our wedding rings."],[2652,2752,"I don't deserve you."],[4934,5096,"Oh my god, Lucy."],[5267,5351,"Lucy,"],[5509,5605,"I'm so sorry,"],[5605,5672,"I couldn't give you"],[5672,5772,"the life you deserve."],[5985,6072,"When I get better,"],[6260,6360,"I'll make it up to you."],[6644,6710,"I promise."],[7123,7207,"You better."],[8058,8128,"Raphael,"],[8241,8366,"you're the love of my life,"],[8429,8662,"but me being here is killing you."],[9488,9659,"Goodbye, my love."],[12399,12445,"Lucy?"],[12762,12896,"My dearest Raphael,"],[13075,13250,"if you're reading this, I'm gone."],[13371,13521,"Loving you is the best thing"],[13521,13667,"that's ever happened to me."],[13709,13868,"But that's why I have to let you go."],[13955,14030,"I've contacted - Lucy!"],[14030,14105,"your father,"],[14105,14235,"and he'll pay for your treatment,"],[14243,14414,"so you can live the life you deserve."],[14443,14497,"Lucy!"],[14497,14581,"So forget me."],[14635,14723,"Forget us."],[14789,14935,"As for me and our child,"],[15027,15190,"we'll always love you from afar."],[15277,15365,"Yours always-"]],"3":[[183,233,"Move!"],[254,316,"Let me see!"],[725,788,"Lucy."],[788,867,"Oh my God!"],[980,1030,"Lucy!"],[1121,1276,"No, no, no!"],[1301,1580,"Oh my God, no, my baby!"],[1751,1893,"Oh my baby! - It's awful."],[1943,2068,"She looks so young."],[2077,2177,"And pregnant!"],[2235,2277,"Jeez."],[2277,2452,"A hit-and-run, on Christmas Eve."],[2548,2615,"Get off me!"],[2615,2656,"No!"],[2660,2869,"My baby, no."],[3082,3136,"No."],[5551,5613,"No pulse."],[5743,5818,"She's dead."],[5914,6072,"No, no, no."],[6097,6222,"Two lives at once,"],[6327,6410,"such a shame."],[6493,6548,"Let's go."],[6735,6835,"Take my son home."],[7132,7236,"Lucy, no!"],[7236,7432,"No, no, no!"],[7432,7561,"Lucy, no!"],[7599,7653,"No."],[7682,7749,"No."],[7799,7866,"No!"],[8391,8458,"No."],[8646,8821,"My Lucy, if it weren't for me,"],[8879,9159,"you, our daughter, would still be alive."],[9300,9376,"We'd be together,"],[9438,9588,"and she would be the most beautiful,"],[9588,9805,"sweet, happy little angel."],[9968,10080,"It's all my fault."],[11298,11465,"Woo, silver can."],[12324,12537,"Daddy, where are you?"],[12562,12662,"If you were here,"],[12662,12867,"you could help me take care of Mommy."],[13171,13259,"But it's okay."],[13259,13371,"I can do it myself."],[13425,13688,"If I work faster, and get enough money,"],[13722,13888,"Mommy won't be so cold anymore."],[14055,14218,"Hi, sweetheart."],[14222,14393,"Oh, poor little kid."],[14393,14506,"Mommy's a cripple,"],[14506,14718,"and Daddy's nowhere to be found."],[14718,14881,"It's a damn shame."],[14881,15044,"Life ended for little Lottie,"],[15044,15206,"even before it began."],[15528,15699,"Mommy, I got so many"],[15699,15828,"cans and bottles today."],[15870,15978,"I'll sell them tomorrow."],[16257,16320,"Mommy!"],[16383,16449,"Mommy!"],[16499,16549,"Help!"],[16587,16641,"Help!"],[16850,16971,"This is bad. - Lucy."],[16971,17100,"Oh, no, no, no, no."],[17100,17242,"I've never seen her like this-"],[17242,17296,"Oh, no, no!"],[17296,17354,"Lucy."],[17371,17421,"Lucy."],[17446,17492,"Lucy."],[17492,17580,"Oh no!"],[17580,17713,"We need to go to the hospital"],[17713,17796,"now! - Yes, yes!"],[19169,19219,"Help!"],[19269,19319,"Help!"],[19486,19748,"No, is that..."],[20357,20499,"Is that Lucy?"]],"4":[[454,492,"No."],[654,800,"I must be seeing things."],[1497,1576,"Miss Doctor,"],[1601,1739,"what's wrong with Mommy?"],[1960,2085,"We ran some tests."],[2173,2281,"She had a seizure."],[2331,2515,"There's a blood clot in her brain."],[2540,2744,"We think it's from a head injury."],[2786,2877,"Without surgery,"],[2890,3019,"her condition could be fatal."],[3069,3161,"What's fatal?"],[3244,3370,"It means that she could die."],[3774,3995,"Has she ever been in any car accident?"],[4020,4179,"We don't know her history."],[4208,4387,"She's always been unresponsive."],[4408,4579,"So you're not family then?"],[4596,4738,"Well, um."],[4738,4992,"No, but, well..."],[4992,5155,"Someone needs to decide for her."],[5209,5305,"I'm her family."],[5351,5422,"Miss Doctor,"],[5492,5588,"please save her."],[5588,5780,"It's going to be a costly procedure."],[5822,5901,"I have money!"],[6231,6343,"This is all I have."],[6343,6527,"Is this enough to save Mommy?"],[7528,7699,"I'm sorry, sweetheart, but..."],[7724,7782,"Here."],[7816,7874,"Here."],[8003,8224,"Is it enough now, Miss Doctor?"],[8375,8479,"Sweetie,"],[8612,8817,"it's gonna cost $70,000."],[8979,9117,"Well, what we can do,"],[9200,9426,"is take this as,"],[9480,9576,"as a deposit."],[9592,9780,"I'll take this to the accountant, but"],[9826,9943,"we'll need $70,000"],[9943,10110,"by tomorrow for her surgery."],[10285,10377,"Miss Doctor,"],[10397,10527,"what is $70,000"],[10527,10727,"divided by ten cents?"],[10744,10910,"That's 700,000."],[10990,11073,"Why?"],[11177,11382,"That's a lot of cans."],[11928,12128,"Miss Doctor, keep Mommy safe."],[12195,12366,"I'll be back with the money tomorrow."],[12445,12541,"Charlotte!"]],"5":[[1309,1493,"Thirty-seven."],[1543,1772,"Thirty-eight."],[1805,1956,"Thirty-nine."],[2060,2281,"Oh, that's not enough to save Mommy."],[3349,3616,"I just needed a few more cans."],[3653,3853,"Why couldn't I be faster?"],[3970,4095,"I'm sorry, Mommy."],[4149,4200,"I don't think"],[4200,4391,"I can get the money on time."],[4896,4975,"Daddy, sing it!"],[4975,5050,"- Is that not how? No!"],[5050,5309,"I wish I had Daddy like everyone else."],[5451,5622,"Then Daddy would be able to help."],[5801,5997,"And we could spend Christmas together."],[7182,7298,"Are you trying,"],[7344,7561,"to ruin our reputation?"],[7565,7670,"You just stood up"],[7678,7820,"the Patton heiress."],[7820,8003,"You just cannot keep doing this."],[8003,8083,"You can't."],[8149,8249,"I have no interest in any woman"],[8249,8329,"who's not Lucy."],[8408,8525,"She's dead, Raphael."],[8550,8762,"Been dead seven years."],[8762,8942,"Thanks to you."],[9009,9129,"You say that again!"],[9822,9897,"Merry Christmas."],[9934,10135,"You better get your ass back here, boy."],[10176,10331,"Get your ass back here now!"],[10798,10927,"I want that ring gone."],[10960,11069,"I want it out of here."],[11081,11265,"Sir, I beseech you-"],[11269,11515,"Barrett, I don't want Raphael,"],[11536,11720,"hung up on that dead girl,"],[11720,11907,"for his entire life!"],[11932,12016,"Please get that ring,"],[12016,12174,"and get it out of here now."],[12249,12299,"Yes, sir."],[15027,15148,"Oh, pizza."],[15582,15632,"Hmm?"],[16253,16395,"This looks like silver."],[16412,16574,"I think this can save Mommy!"]],"6":[[166,279,"Miss Doctor,"],[375,483,"is Mommy okay?"],[575,663,"She's the same."],[738,884,"Were you able to get money"],[884,975,"for her surgery?"],[1051,1322,"Do you have any other family"],[1322,1418,"you can ask?"],[1463,1630,"No, it's only me and Mommy."],[1685,1822,"But I have this ring."],[1839,1901,"It's silver."],[1914,2043,"That's expensive, right?"],[2060,2152,"Is it enough to pay"],[2152,2260,"for Mommy's surgery?"],[2706,2756,"Well..."],[2948,3040,"I'll be right back."],[3278,3332,"Morning."],[3407,3478,"Good morning."],[3632,3753,"Did you see the ring that was over here?"],[3887,3962,"I threw it away."],[4145,4308,"Why would you throw that ring away?"],[4337,4491,"You know that's Lucy's ring!"],[4596,4754,"Go get every single one of our men"],[4754,4850,"out to find that ring."],[4850,4921,"I don't care if you have to"],[4921,5025,"lock down the whole city."],[5055,5092,"Yes, sir."],[5125,5217,"Get that ring back."],[5326,5422,"It had to be done."],[5559,5676,"You gotta let her go."],[5701,5801,"I don't touch your shit,"],[5801,5901,"so you sure as hell"],[5901,6035,"better stop touching mine!"],[6076,6281,"Sir, I tracked the CCTV trail."],[6306,6398,"The thief that stole your ring"],[6398,6493,"just went inside this hospital."],[6523,6619,"Let's go get it back."],[7461,7515,"There, sir."],[7515,7582,"It's her!"]],"7":[[87,237,"Alright, you dirty little thief."],[275,346,"Hand over the ring."],[387,487,"It belongs to Mr. Stone."],[487,533,"No."],[533,608,"Finders keepers."],[608,692,"It's mine!"],[729,838,"Finders keepers?"],[850,950,"Were you raised by a rat?"],[1163,1217,"Give it back,"],[1217,1343,"or I'll snap your arm in half."],[1343,1484,"No, I found it."],[1522,1705,"Fine, we'll do this the hard way."],[1764,1805,"Wait!"],[2198,2293,"Did your father ever teach you,"],[2293,2394,"not to steal?"],[2394,2569,"I, I don't have a dad."],[2677,2756,"What about your mother?"],[2790,2932,"She must have told you not to lie."],[2990,3186,"My mom never tells me anything."],[3211,3303,"She can't talk."],[3349,3424,"I don't even know"],[3424,3524,"what her voice sounds like."],[3524,3591,"Alright."],[3628,3741,"Just give me back the ring,"],[3741,3853,"and we won't turn you in."],[3853,3908,"No!"],[4245,4320,"You want money?"],[4763,4808,"There."],[5005,5080,"There's money."],[5213,5359,"Give me back my ring!"]],"8":[[0,150,"Give me back my ring!"],[162,446,"No, I need $70,000!"],[467,533,"Mr. Stone,"],[533,629,"this is extortion."],[629,779,"She obviously knows you're rich."],[917,1046,"Don't push your luck, kid."],[1088,1217,"No, you don't understand."],[1217,1388,"I need the money for my Mommy."],[1518,1622,"Give me the ring!"],[1655,1710,"Now."],[2072,2127,"Now!"],[2373,2439,"Ow!"],[2444,2523,"You bit me!"],[2602,2731,"Mr. Stone, are you okay?"],[2911,3036,"Don't ever show your filthy"],[3036,3128,"face here again."],[3820,3878,"No!"],[3953,4016,"Please, sir,"],[4016,4195,"please, give me the ring back."],[4295,4512,"I need it to save Mommy, please."],[5351,5451,"No."],[5622,5709,"No!"],[5876,6047,"Miss Doctor, you can't kick her out."],[6060,6247,"She'll die if she leaves."],[6644,6835,"Sweetheart, keep the money."],[7019,7136,"You're on your own now."],[7178,7378,"No, wait, please keep the money!"],[7411,7499,"Sweetheart,"],[7565,7720,"it's not about the money anymore."],[7774,7903,"The man you just fought with?"],[7928,8062,"That's Raphael Stone."],[8128,8395,"He's the heir to the Stone Corporation."],[8437,8583,"He owns everything around here."],[8596,8679,"This hospital,"],[8725,8850,"the mall across the street."],[8917,8992,"Mr. Stone"],[8992,9134,"pretty much blacklisted you."],[9167,9317,"There's no amount of money"],[9317,9409,"in this world"],[9488,9601,"will get you out of it."],[9659,9780,"No, please."],[9914,9976,"I'm sorry."],[10030,10147,"Try another hospital."],[10301,10402,"No, Mommy!"],[11911,11978,"Wait,"],[12041,12099,"is that..."]],"9":[[729,771,"No,"],[804,888,"it's not her."],[1288,1393,"Please!"],[1626,1747,"I can't believe she said that-"],[1747,1818,"Please!"],[1818,2010,"My Mommy needs a big surgery."],[2010,2147,"Please save her."],[2198,2285,"That's the child"],[2285,2444,"that made Raphael Stone angry."],[2469,2569,"Avoid making eye contact."],[2794,2894,"Please help her."],[2894,2977,"Please."],[3015,3144,"Help my Mommy!"],[3545,3653,"Please, Mr. Doctor."],[3682,3870,"My Mommy needs a big surgery."],[3920,4045,"Can you please help her?"],[4166,4254,"I'm sorry, kid."],[4333,4425,"I can't help you."],[5184,5255,"What's going on?"],[5338,5459,"Please save my Mommy."],[5609,5668,"Listen,"],[5676,5793,"there's not a doctor in town"],[5793,5910,"who's gonna help your mother"],[5910,6081,"until you bring back proof"],[6101,6214,"that he's okay with it."],[6335,6493,"Something written and signed."],[6585,6648,"By him."],[6677,6760,"Personally."],[7182,7269,"How about this,"],[7415,7549,"you bring back his approval"],[7549,7628,"by midnight,"],[7665,7732,"and we'll organize"],[7732,7845,"your mother's surgery."],[7907,7953,"Okay?"],[8062,8128,"Keep her safe."],[8128,8274,"I'll be back by midnight."],[8495,8579,"Seven."],[8625,8792,"Seven Christmases!"],[8837,9013,"This place is like a funeral."],[9079,9275,"I have arranged for you"],[9275,9555,"to date Regina Lawrence."],[9634,9876,"You will court her for one month,"],[9897,10080,"and then you will marry her"],[10080,10193,"immediately."],[10206,10251,"No."],[10310,10439,"I'll do anything else."],[10439,10552,"I'm not gonna marry again."],[10581,10673,"I married Lucy."],[10714,10810,"Now and always."],[10831,10898,"Lucy is..."],[10927,11073,"She is dead, son."],[11115,11215,"She's dead."],[11248,11323,"Cold."],[11344,11436,"In the ground."],[11448,11503,"Buried!"],[11528,11644,"And whose fault is that?"],[11686,11924,"You pathetic, ungrateful..."],[11949,12091,"Ungrateful piece of crap!"],[12091,12153,"You're-"],[12183,12237,"Ah."],[12266,12358,"Sir,"],[12437,12579,"your medicine is overdue."],[12637,12721,"You must take better"],[12721,12846,"care of yourself, sir."],[13033,13150,"I insist, sir."],[13217,13288,"Alright."],[13450,13613,"There's a child at the door, sir."],[14727,14944,"Sweetheart, what are you doing here"],[14944,15077,"in the middle of the night?"],[15094,15290,"And where are your parents?"],[15511,15761,"Sir, where's Mr. Stone?"],[15811,15970,"Why do you need to speak with him?"],[16053,16395,"Mr. Stone needs to sign this."],[16537,16745,"My Mommy's gonna die soon."],[16929,17058,"I'm Mr. Stone."],[17075,17158,"Are you hurt?"],[17238,17400,"You're Mr. Stone?"],[17475,17534,"Umm,"],[17580,17726,"maybe I got the wrong house."],[17726,17801,"Sorry."],[18101,18201,"You little thief!"]],"10":[[45,125,"You little thief!"],[254,383,"I told you to stay out of my way!"],[563,646,"I'm sorry."],[658,863,"I shouldn't have taken your ring!"],[880,1080,"But please, save my Mommy!"],[1096,1163,"Raphael,"],[1184,1301,"what is she talking about?"],[1301,1368,"What are you"],[1368,1451,"not telling me? - Enough."],[1480,1564,"No, Father."],[1931,2072,"If it weren't for the car accident,"],[2173,2310,"my daughter would have been"],[2335,2448,"around her age."],[2489,2594,"Please, sir,"],[2623,2752,"can you sign this?"],[3090,3286,"The doctor said if you sign this,"],[3303,3457,"you can help Mommy."],[3666,3791,"Did she tell you to say that?"],[3803,3908,"Did she tell you to lie,"],[3953,4037,"so you could trick me"],[4037,4112,"to get my money?"],[4141,4275,"I'm not lying!"],[4320,4491,"My mommy is gonna to die soon."],[4508,4608,"Please, sir!"],[4633,4846,"Please save my mommy!"],[5601,5718,"You wouldn't say that if you knew,"],[5718,5868,"what it was like to lose someone."],[7357,7453,"Your mother's dying?"],[7757,7866,"Well, why don't we go to the hospital,"],[7866,8045,"and see just how dead she is?"],[8053,8145,"Raphael!"],[8195,8287,"If by some miracle"],[8287,8375,"you're telling the truth,"],[8462,8533,"I'll help her."],[8554,8641,"But if you're lying,"],[8717,8821,"I'll show you what happens"],[8821,8988,"to con artists who try to scam me."],[9438,9509,"Thank you."],[9663,9730,"Sir,"],[9876,10022,"the little girl outside,"],[10022,10235,"has a remarkable resemblance"],[10235,10335,"to Raphael."],[10335,10452,"I thought that too."],[10477,10539,"Yes, sir."],[10606,10944,"That's why I took a strand of hair."],[10985,11202,"Now I want you to call the hospital,"],[11202,11498,"and have a DNA test done tonight."],[11498,11590,"Very good, sir."],[11590,11724,"I'll take care of it right away."],[11724,11774,"Thank you."],[11803,11845,"Yes sir."],[14093,14243,"Mr. Stone doesn't look"],[14243,14426,"like a bad person."],[15186,15252,"Mommy!"],[15540,15598,"Mommy?"],[15632,15673,"Mommy,"],[15673,15778,"are you okay?"],[15836,16020,"You promised to help her!"],[16066,16174,"I'm sorry, Angel,"],[16174,16433,"but I needed the sign permission slip"],[16433,16587,"by midnight for my boss,"],[16587,16716,"and you didn't show up."],[16775,16908,"But I brought him!"],[17162,17242,"Mr. Stone,"],[17292,17438,"I wasn't expecting you."],[17446,17504,"Don't die. - It's fine."],[17517,17596,"Don't die."],[17596,17680,"Please."],[17701,17780,"Mommy!"],[17951,18059,"Don't die."],[18072,18138,"Mommy,"],[18159,18318,"please don't die!"],[18330,18526,"I don't wanna be alone, please!"],[19519,19569,"Mommy."],[19586,19669,"Mommy!"],[19736,19957,"How can this be..."],[20795,20929,"Lucy?"]],"11":[[867,1021,"She looks familiar."],[1021,1067,"She looks familiar."],[1067,1134,"But-"],[1134,1388,"Mommy, please don't die!"],[1418,1501,"Please!"],[1522,1701,"Is she..."],[1701,1906,"That's impossible."],[2427,2548,"Sir, Red Alert!"],[2590,2644,"Red Alert."],[2748,2827,"Sir, Red Alert!"],[3023,3123,"Don't die!"],[3144,3194,"Mommy!"],[3215,3307,"Mommy!"],[3345,3407,"Mommy."],[3428,3536,"Mommy!"],[3728,3803,"Sir, it's your father,"],[3803,3866,"we need to go now."],[3866,3924,"Stop it!"],[3924,3983,"We need to go now!"],[5601,5663,"Mommy!"],[5676,5764,"Mommy!"],[6539,6610,"Charlotte?"]],"12":[[387,475,"Charlotte?"],[504,583,"Mommy!"],[642,709,"Mommy!"],[863,992,"What is going on here?"],[992,1172,"I thought she could hardly talk."],[1184,1242,"Mommy?"],[1292,1422,"Did you just say my name?"],[2852,2940,"It was the fall."],[2940,3086,"I, I think it dislodged"],[3086,3269,"the blood clot from her brain."],[3582,3661,"Home."],[3849,3908,"Home."],[3953,4045,"Okay, Mommy."],[4045,4141,"I'll take you home."],[4988,5080,"I'll take you home, Mommy."],[5080,5184,"I'll take you home."],[5709,5880,"It's a Christmas Day miracle."],[6293,6368,"What's going on?"],[6744,6802,"Where's the threat?"],[7140,7215,"You lied."],[7248,7311,"You lied about"],[7311,7407,"the security threat, didn't you?"],[7407,7478,"I did."],[7570,7728,"Because you would not have come back,"],[7749,7849,"if I told the truth."],[7978,8087,"And where's the little girl?"],[8137,8216,"Why are you keeping that"],[8216,8329,"a secret from me?"],[8395,8470,"A secret?"],[8537,8629,"What secret?"],[8804,8879,"That little girl"],[8879,9075,"is your daughter, isn't she?"]],"13":[[95,150,"Don't."],[208,346,"Don't you fucking dare."],[867,1001,"The only daughter I've ever had,"],[1026,1180,"died in her mother's womb,"],[1217,1351,"from a car crash."],[1368,1584,"Well, I sent her DNA in"],[1584,1747,"for a paternity test."],[1772,1901,"And the results should be back"],[1922,1997,"any minute!"],[2064,2231,"I just wanted to hear you"],[2252,2548,"tell me the truth about that."],[2548,2673,"I'm not fucking doing this."],[2765,2831,"Not today."],[2840,3144,"Raphael, I raised you better than this."],[3161,3269,"If you have a little girl,"],[3269,3432,"you need to take responsibility-"],[3432,3553,"The only woman I was ever with"],[3553,3620,"was Lucy."],[3691,3753,"That's it."],[3799,3903,"I know you want an heir."],[3912,4058,"I know you wanna to be a grandpa."],[4058,4170,"But you're delusional,"],[4170,4291,"if you think that lying"],[4291,4412,"brat is my daughter."],[4483,4654,"Don't follow me."],[4821,4875,"Sir."],[5105,5238,"The DNA results, sir."]],"14":[[1155,1267,"I'm a grandpa."],[1280,1397,"I'm delighted, sir,"],[1443,1601,"but it seems your son"],[1639,1747,"doesn't want anything"],[1747,1843,"to do with her."],[2298,2394,"Well, I do."],[2665,2815,"I want you to get our best men."],[2886,2986,"I want you to contact"],[3003,3224,"every resource we have."],[3274,3524,"Turn that whole city"],[3607,3870,"upside down if you have to!"],[3908,4129,"But find my grand-daugh..."],[4204,4262,"Daughter!"],[4266,4316,"Yes, sir!"],[4316,4362,"Yes, sir."],[4371,4433,"Find her!"],[4525,4792,"We have discovered that Raphael Stone"],[4896,4979,"has a daughter."],[5125,5355,"And she has gone missing."],[5442,5538,"It's imperative"],[5538,5739,"that we bring this girl back."],[5889,5968,"Who are we after?"],[5968,6072,"Ms. Charlotte Stone."],[6072,6214,"Where do we want her?"],[6214,6268,"Home."],[6277,6418,"Who are we after!"],[6418,6535,"Ms. Charlotte Stone!"],[6535,6660,"Where do we want her!"],[6660,6723,"Home!"],[6748,6890,"Go, go, go!"],[6890,6969,"Yes, sir!"],[8637,8775,"Excuse me?"],[8804,8913,"The Stones"],[8913,9121,"are looking for a lost heiress?"],[11536,11649,"Hello, darling!"],[11669,11832,"Did you make it to the Stone's?"],[11857,12062,"Yes, but what is all of this"],[12062,12166,"about a lost heiress?"],[12191,12437,"You told me that Raphael was single!"]],"15":[[12,166,"Yesterday, Sean,"],[166,358,"the patriarch of the Stone family,"],[387,571,"announced that Raphael"],[650,846,"has a secret daughter."],[934,984,"What?"],[1017,1142,"I had no idea."],[1142,1380,"But now they've sent every guard"],[1380,1555,"into the city to look for her."],[1593,1655,"But I"],[1655,1822,"am supposed to marry Raphael!"],[1906,2010,"Are you telling me"],[2035,2264,"that I went through all of the trouble,"],[2264,2444,"faking a Harvard degree,"],[2444,2635,"chartering a helicopter,"],[2635,2815,"just to be his freaking babysitter?"],[2844,2957,"Don't worry,