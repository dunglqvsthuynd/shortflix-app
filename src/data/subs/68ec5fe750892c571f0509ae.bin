ong."],[1230,1313,"Ah!"],[1313,1380,"Oh my god."],[3103,3182,"Raph?"],[3228,3307,"Oh my god."],[3470,3557,"Lucy?"],[3799,3924,"You're alive."],[4129,4454,"Mr. Stone? - Lucy?"],[5855,5997,"Lucy, is that our daughter?"]],"23":[[54,179,"Lucy, is that our daughter?"],[266,329,"Char..."],[471,533,"Charlotte."],[746,871,"Charlotte, come here."],[2439,2652,"This is that wife of his."],[2669,2827,"I thought she was dead!"],[3123,3207,"I'm so sorry."],[3294,3403,"I'll make it up to you I promise."],[3403,3470,"Okay?"],[3653,3803,"My father said you were dead."],[3853,4008,"I thought you died on the hit and run."],[4104,4233,"What happened?"],[4312,4437,"Where have you been?"],[4971,5038,"No."],[5059,5125,"No!"],[5138,5205,"Mommy!"],[5976,6043,"Lucy."],[6089,6185,"Raphael?"],[6256,6373,"Who is this?"],[7353,7482,"Did you do this to them?"],[7574,7653,"Well,"],[7661,7799,"they ruined my car."],[8362,8562,"If I find one shred of evidence"],[8562,8671,"that you were the one that hurt them."],[8804,8971,"I'll show you a fate worse than death."]],"24":[[0,54,"What?"],[54,141,"Raphael,"],[216,375,"how could you do this to me?"],[437,563,"I'm your fiancée."],[563,633,"No you're not"],[633,738,"and you never will be."],[759,892,"I could never date someone like you,"],[892,1005,"let alone marry you."],[1084,1213,"Well, well, well,"],[1238,1368,"apparently she's not the future"],[1368,1488,"Mrs. Stone after all."],[1522,1655,"She must be one of those"],[1655,1847,"egotistical narcissists"],[1847,1981,"who get off on bullying the weak."],[2431,2502,"My God,"],[2502,2565,"are you okay?"],[2635,2715,"Mommy,"],[2748,2957,"I want go back to the tent."],[3011,3103,"I'm hungry."],[3186,3278,"I want to-"],[3319,3470,"No, no!"],[3499,3557,"Charlotte!"],[3632,3770,"Hospital, now!"],[3941,4183,"Raphael's supposed to be doting on me!"],[4183,4446,"I need to get rid of that kid."],[4558,4742,"I'm going to kill you, you stupid brat."]],"25":[[771,838,"Charlotte!"],[959,1017,"You're awake."],[1159,1297,"Mr. Stone,"],[1326,1488,"where am I?"],[1555,1697,"Where's Mommy?"],[2277,2356,"Charlotte, I'm,"],[2377,2473,"I'm sorry I was so cold"],[2473,2535,"with you earlier."],[2677,2802,"Could you please forgive me?"],[2907,2990,"It's okay."],[3019,3128,"Auntie June said"],[3128,3311,"everyone makes mistakes."],[3332,3440,"What's important is"],[3440,3549,"we don't do it again."],[3632,3728,"Who's Aunt June?"],[3778,3870,"She's our neighbor."],[3899,4024,"Her and her friend are the tent"],[4024,4191,"next to us, next to the bridge."],[4270,4450,"They've been living under a bridge,"],[4537,4637,"all this time?"],[5826,6022,"How could this have happened?"]],"26":[[371,479,"It's going to be okay now."],[479,554,"I promise."],[554,800,"Mr. Stone, I want to be next to Mommy."],[855,971,"Charlotte doesn't trust me yet."],[1001,1101,"I'll need to take it slow"],[1101,1242,"and show her I care about her."],[1242,1313,"Of course."],[1401,1480,"Up-up."],[1931,2022,"Okay Charlotte,"],[2022,2127,"can you tell me when..."],[2243,2398,"when did mom start being sick?"],[2865,2948,"Auntie June said"],[2948,3086,"she found me and Mommy"],[3107,3336,"in an alleyway outside of a hospital."],[3336,3524,"She said I was still a baby,"],[3557,3774,"so she took us in and helped raise me."],[3928,4074,"You're so lucky to have Aunt June."],[4095,4179,"And I'm here now."],[4295,4517,"And I promise I'll be here all the time."],[4571,4725,"And I'll do everything that I can"],[4725,4850,"to help Mommy get better."],[4850,4946,"Are you sure?"],[4946,5092,"You weren't really nice to me"],[5092,5180,"and Mommy before."],[5184,5317,"I know, I'm so sorry."],[5355,5467,"I was so cold before."],[5484,5655,"I should have never acted like that to"],[5676,5768,"anyone else."],[5860,6010,"And it will never happen again."],[6060,6110,"Ever."],[6202,6281,"Pinky promise?"],[6443,6610,"Okay, so now that mom is sleeping,"],[6710,6965,"I have some gifts for you."]],"27":[[241,425,"This is Deena, your designer."],[4