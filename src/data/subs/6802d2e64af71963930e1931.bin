{"1":[[628,700,"Tell me your name."],[824,880,"Olive."],[1156,1220,"Diego."],[1412,1496,"Say my name."],[1796,1864,"Diego."],[1916,2016,"Diego."],[2048,2128,"Diego."],[2544,2736,"I feel like this is meant to be."],[2736,2812,"I feel it too."],[3880,3916,"You know,"],[3916,4072,"you can tip a delivery boy"],[4072,4216,"with cash these days."],[4328,4468,"Bestie, if you're going to"],[4468,4572,"crash on my couch,"],[4572,4656,"then you can't judge"],[4656,4820,"my extracurricular activities."],[5048,5232,"Still looking for your lover boy?"],[5268,5444,"Can't believe I lost his number."],[5516,5596,"Oh, no."],[5680,5852,"Oh, no no no no no no."],[5852,5924,"What?"],[6132,6292,"You're invited to your family's"],[6292,6440,"gorgeous Hamptons mansion"],[6440,6544,"for the summer."],[6676,6812,"What's so bad about that?"],[6900,6972,"It says here,"],[7216,7408,"bring a girlfriend, or else."],[7472,7508,"Sam."],[7624,7800,"Last time I checked, you are like,"],[7836,7924,"super gay."],[7960,8088,"Olive, there's something"],[8088,8228,"I haven't told you."],[8276,8532,"I kind of lied to my parents"],[8532,8644,"and said that you were my girlfriend."],[8664,8736,"You what?"]],"2":[[28,116,"You know how they are."],[144,284,"I finally get access to"],[284,364,"my trust fund"],[364,452,"at the end of summer."],[480,536,"If they find out"],[536,592,"I'm gay,"],[632,712,"they'll disown me and"],[712,832,"take away everything I have."],[952,1128,"I've drained every cent I have"],[1128,1260,"trying to win back custody of"],[1260,1320,"my little brother."],[1340,1464,"And if it wasn't for Sam,"],[1464,1572,"I'd be out on the street."],[1604,1768,"Now’s my chance to return the favor."],[1932,2076,"I'll go with you to the Hamptons"],[2076,2232,"and pretend to be your fake girlfriend."],[2284,2384,"Wait, for real?"],[2412,2456,"Sam."],[2468,2632,"I'm broke, okay?"],[2648,2784,"Going to the Hamptons"],[2784,2908,"is like a vacation for me."],[2932,3052,"They won't suspect a thing"],[3084,3164,"and you'll get your trust fund"],[3164,3256,"by the end of the summer."],[3308,3420,"Oh, my God."],[3452,3536,"When I get the money,"],[3536,3644,"we can use it to"],[3644,3768,"get the best custody lawyer"],[3768,3860,"for your little brother."],[3948,4128,"And I can finally rescue Riley from"],[4128,4280,"his abusive foster mom and"],[4280,4352,"her wicked son."],[4416,4540,"Thank you, Sam."],[4740,4860,"But you know I would do this"],[4860,4976,"for you for free, right?"],[5000,5072,"Oh, God."],[5112,5216,"I do have to warn you about"],[5216,5284,"my brother."],[5388,5512,"My parents are a nightmare"],[5512,5772,"but my brother is even worse."],[5852,5956,"Just promise me"],[5956,6168,"you'll never, ever fall for him."],[6216,6312,"That, Olive,"],[6312,6448,"would be the ultimate betrayal."],[6556,6712,"I didn't even know you had a brother."],[6744,6832,"And why would you think"],[6832,6928,"I would fall for him?"],[6928,7060,"Because everyone does."],[7112,7228,"He's a golden child."],[7252,7392,"The ultimate nepo baby,"],[7572,7632,"smart,"],[7680,7752,"good-looking..."],[7828,7884,"Not gay."],[8008,8176,"I love him, but sometimes"],[8176,8384,"he makes me feel less."],[8480,8528,"I'm scared"],[8528,8696,"if he finds out the truth about me,"],[8696,8836,"then he'll see me differently."]],"3":[[20,100,"Just promise me"],[100,300,"you won't fall for his charms."],[300,336,"You don't know"],[336,416,"how many people"],[416,516,"have used me to get to him."],[556,624,"And right now,"],[668,740,"the only thing that"],[780,864,"he doesn't have"],[872,936,"that I do"],[1000,1040,"is you."],[1148,1344,"I would never betray you like that."],[2260,2452,"This is your house?"],[2480,2568,"Yeah."],[3052,3260,"Remember, you're in love with me."],[3260,3440,"You can't keep your hands off me."],[3452,3568,"If you look convincing enough,"],[3652,3744,"then my family will never know"],[3744,3812,"I'm gay."],[6272,6316,"DJ."],[6316,6472,"This is my girlfriend, Olive!"],[7232,7388,"Olive's Sam's girlfriend?"],[7388,7556,"She cheated on my brother with me?"],[7936,8140,"My unforgettable one night stand"],[8140,8376,"is my best friend's brother?"]],"4":[[24,88,"Sam!"],[88,128,"Mom!"],[180,228,"Dad!"],[432,540,"This is Olive."],[636,740,"Finally, we meet"],[740,860,"the mysterious girlfriend."],[1000,1112,"I started to think that"],[1112,1260,"you didn't actually exist."],[2004,2172,"Oh dear, what happened here?"],[2308,2408,"Butterfingers."],[2456,2568,"I'll grab the towel."],[2644,2800,"I'll get another vase for these."],[3192,3236,"So,"],[3412,3540,"how long have you two been together?"],[3584,3696,"- A few months. - Recently."],[3904,4004,"A few months?"],[4004,4108,"She was moaning my name"],[4108,4180,"a week ago."],[4868,4964,"So which is it?"],[5064,5140,"Oh god,"],[5168,5264,"he thinks I was with Sam"],[5264,5372,"when we hooked up last week!"],[5444,5520,"Sam dear,"],[5520,5576,"will you come"],[5576,5716,"help me with the cheese plate?"],[5996,6096,"Be nice, DJ."],[6324,6472,"So I didn't know"],[6472,6588,"you are Sam's older brother."],[6628,6756,"That's all you have to say for yourself?"],[6856,6964,"That’s why you didn’t call me, right?"],[7024,7072,"Because you're cheating on"],[7072,7168,"my brother with me."],[7292,7396,"Okay, okay,"],[7424,7476,"Diego,"],[7476,7584,"it's not what it looks like,"],[7584,7616,"I promise."],[7624,7664,"Really?"],[7724,7784,"Because it looks like"],[7784,7872,"you're playing us both."],[7984,8044,"It stops now."],[8276,8312,"Diego."],[8636,8736,"The truth is Sam is..."]],"5":[[16,188,"I can't out Sam."],[188,308,"I'm doing this for him"],[308,440,"and for my little brother."],[440,628,"It's better for Diego to hate me"],[628,740,"than to hurt them."],[820,1152,"Sam's had a really, really tough year."],[1152,1392,"And if he finds out about both of us,"],[1392,1460,"it would crush him."],[1524,1688,"And he really looks up to you DJ,"],[1688,1772,"and you wouldn't want to hurt him,"],[1772,1860,"would you?"],[2080,2144,"I guess that night"],[2144,2236,"meant nothing to her."],[2252,2376,"Why did I waste my time"],[2376,2464,"thinking it was special?"],[2584,2748,"That night meant everything to me."],[2776,2932,"If only I could tell him that."],[2984,3108,"Are you guys coming in or...?"],[3200,3352,"Yeah, you lead the way."],[4860,5040,"So where's your girl at?"],[5056,5120,"What girl?"],[5132,5300,"The girl you met at the party last week."],[5428,5476,"Wait."],[5516,5720,"He talked to Sam about that girl?"],[5720,5804,"About me?"]],"6":[[0,104,"Where's your girl at?"],[132,180,"What girl?"],[212,380,"The girl you met at the party last week."],[824,860,"Dude,"],[916,964,"I don't even know"],[964,1036,"what you're talking about."],[1168,1244,"Yeah, right."],[1244,1396,"You literally called me up last weekend"],[1396,1592,"and said, I think I met my future wife."],[1760,1872,"Future wife?"],[1924,2032,"He meets new girls, like,"],[2032,2116,"every other week."],[2256,2396,"But I can tell this one is different."],[2600,2644,"Different?"],[2688,2740,"How?"],[2860,3008,"I couldn't stop thinking about you,"],[3040,3116,"talking about you,"],[3156,3236,"trying to find you."],[3348,3400,"What did you say"],[3400,3468,"her name was again?"]],"7":[[24,192,"It doesn't matter."],[292,360,"I've moved on."],[456,504,"It turns out"],[504,604,"she's somebody else's girlfriend."],[804,936,"That skanky bitch."],[1000,1040,"I mean,"],[1188,1320,"Bros before hoes."],[1392,1484,"You're better off, dude."],[1516,1592,"I totally agree."],[1760,1856,"What do you think, Olive?"],[2000,2088,"I think..."],[2384,2488,"I need the restroom."],[3480,3616,"Keep it together, Olive."],[3748,3848,"Screw this up."],[3892,4032,"Sam will never forgive you."],[4100,4156,"And then you'll never"],[4156,4212,"have a chance of"],[4212,4324,"seeing your brother."],[6296,6380,"What do you want?"],[6448,6552,"Tell me something, Olive."],[6804,6908,"If you weren’t with my brother,"],[6908,7012,"would you want to see me again?"],[7188,7232,"Diego."],[7268,7328,"Actually,"],[7448,7516,"don't answer that."],[7780,7812,"I don't think"],[7812,7956,"I could resist you if you said yes."],[8204,8276,"We need to pretend like"],[8276,8368,"that night never happened."],[8480,8584,"Stay as far away from each other"],[8584,8640,"as possible."],[8640,8728,"Can you manage that?"],[8896,8932,"Of course."],[10568,10668,"What's going on in here?"]],"8":[[220,400,"DJ was helping me find my earring!"],[516,644,"I called up for you, but..."],[756,916,"You know, DJ was outside the door,"],[916,952,"and.."],[1324,1396,"Oh, look."],[1432,1512,"There it is."],[1780,1848,"Look at that!"],[1860,1984,"It was on the floor the whole time."],[2172,2228,"Oh,"],[2272,2432,"I was looking for you, DJ."],[2468,2560,"Stacy's here."],[3176,3376,"Stacy, this is my girlfriend, Olive."],[3700,3828,"Who the hell is that?"],[4016,4220,"I missed you so much, sweetheart."],[4304,4388,"Sweetheart?"],[4816,4976,"Diego’s calling me a cheater"],[4976,5060,"when he had a girlfriend"],[5060,5136,"this whole time?"],[5208,5292,"Stacy."],[5324,5380,"Wow."],[5452,5580,"I didn't think you were coming"],[5580,5616,"this summer I"],[5688,5796,"thought you took that internship"],[5796,5868,"in California."],[5992,6116,"I deferred a couple weeks!"],[6128,6240,"Couldn’t miss a Hamptons trip."],[6324,6428,"Don’t pretend like you’re not happy to"],[6428,6464,"see me."],[6900,6984,"How could I not be?"],[7172,7296,"Shall we head to the kitchen?"],[7296,7372,"There's cheese."],[8760,8824,"I don't know"],[8824,8960,"who you think you are,"],[9252,9396,"but stay away from my man."]],"9":[[76,260,"I already endured enough abuse"],[260,392,"from Riley's foster mom."],[392,516,"I am not taking it from"],[516,692,"Diego's jealous girlfriend too."],[760,880,"Your man?"],[1060,1224,"Funny, he hasn't even"],[1224,1332,"mentioned you."],[1420,1532,"You don't want to mess with me,"],[1532,1596,"bitch."],[1636,1764,"I saw you looking at Diego"],[1764,1948,"like you want to rip his clothes off."],[2100,2168,"How do you think"],[2168,2268,"Sam would feel about that?"],[2428,2528,"If she tells Sam,"],[2564,2696,"then my best friend will hate me,"],[2696,2808,"and our whole arrangement"],[2808,2904,"blows up."],[2968,3096,"I don't know what you're talking about."],[3140,3204,"Please,"],[3240,3440,"don't act all innocent."],[3588,3708,"You're using Sam"],[3708,3904,"to get to his hotter, older brother,"],[3904,3952,"aren't you?"],[4088,4156,"Trust me,"],[4156,4388,"that's the last thing that I'm doing."],[4452,4516,"Sure."],[4568,4712,"Well, it won't work anyway."],[4772,4852,"See this?"],[4952,5084,"Diego got this for me"],[5084,5160,"when we were eight."],[5268,5388,"We went to camp together"],[5388,5620,"at country club every summer."],[5700,5824,"What we have is special."],[5932,6032,"He's not going to pick some"],[6196,6408,"Bargain bin reject over me."],[6496,6712,"Well, what Sam and I have"],[6712,6820,"is also special,"],[6920,7128,"but I don't expect you to understand."],[7180,7392,"I don't want you talking to Diego,"],[7436,7544,"looking at him,"],[7544,7736,"or even thinking about him."],[7900,8028,"Get in my way"],[8028,8112,"and I'll make you regret"],[8112,8272,"ever stepping foot into this house."]],"10":[[800,836,"Oh babe,"],[836,892,"there you are."],[1060,1196,"I see you've met Stacy."],[1356,1480,"And this is her brother, Adam."],[1480,1664,"Adam, this is my girlfriend, Olive."],[2232,2332,"Lovely to meet you,"],[2332,2532,"Sam's girlfriend, Olive."],[3036,3152,"Follow me into the dining room,"],[3152,3200,"everyone."],[3240,3336,"It’s time for dinner!"],[4448,4700,"Why did Adam seem so surprised"],[4728,4848,"when you said girlfriend?"],[4900,5076,"We might have hooked up"],[5076,5188,"last summer."],[5188,5276,"What?"],[5276,5336,"Relax."],[5380,5488,"He is not going to tell."],[5500,5580,"He wouldn't embarrass me"],[5580,5632,"like that."],[6020,6068,"Olive,"],[6376,6432,"about Stacy."],[6436,6528,"I don't want to talk about"],[6528,6644,"your girlfriend."],[6800,6848,"Okay?"],[6904,7024,"We agreed to stay away from"],[7024,7064,"each other,"],[7064,7128,"remember?"],[9136,9344,"So, Senator Rodriguez,"],[9344,9444,"I heard you're running for"],[9444,9524,"re-election this year."],[9568,9652,"I am."],[9800,9948,"Which reminds me, Jane,"],[10092,10260,"did you fire the pool boy?"],[10412,10480,"Oh, yes."],[10480,10580,"He's long gone."],[10784,10956,"We found out he was gay."],[11092,11268,"It was a terrible disappointment."]],"11":[[108,312,"Are you two playing footsie?"],[332,432,"Guilty."],[840,896,"Thank God"],[896,1012,"we don't have to worry about"],[1012,1232,"any scandals like that in our family."],[1416,1528,"Can't afford anything"],[1528,1688,"ruining my reputation"],[1688,1812,"so close to the election."],[1896,2080,"Don't even speak such a thing,"],[2080,2136,"Romero."],[2192,2440,"Imagine having a gay child,"],[2520,2648,"it would kill me."],[3056,3212,"No need to worry about that, dear."],[3336,3472,"Our sons are perfect,"],[3652,3848,"especially this future senator."],[4416,4532,"Golden child."],[4776,4888,"It's our first night"],[4888,4980,"in the Hamptons,"],[5008,5172,"so you know what that means..."],[5200,5292,"Charades!"],[5420,5648,"Let's draw straws to pick teams."],[6292,6340,"Olive."],[6812,6920,"Please don’t be with Diego,"],[6920,7028,"please don’t be with Diego,"],[7028,7156,"please don’t be with..."]],"12":[[64,156,"I hope you're good at charades."],[220,312,"I've never lost a game."],[380,516,"I'm great at charades."],[516,644,"Thank you very much."],[1016,1204,"I knew that sneaky bitch"],[1204,1332,"was trying to steal my man."],[1372,1508,"Wait until she humiliates herself"],[1508,1672,"in front of everyone."],[1700,1824,"Now, choose a prompt."],[1824,2004,"And no peeking, no passing"],[2004,2124,"and no trading."],[2604,2748,"Shouldn't we be partners"],[2748,2820,"if you want to sell"],[2820,2944,"this fake relationship?"],[3388,3584,"I’d be worried if you had a thing for DJ,"],[3584,3720,"thank God you're not remotely"],[3720,3884,"attracted to my brother, right?"],[4172,4412,"Right, yeah. Totally, no like, I..."],[4820,4908,"Just be careful."],[5024,5232,"DJ can get super competitive."],[5232,5356,"Stacy is even worse."],[5788,5964,"As the honored guest,"],[5964,6172,"I think Olive should go first."],[6224,6384,"Oh, that's an excellent idea."],[6384,6464,"Olive,"],[6464,6688,"get up there, you too, Diego."],[7356,7520,"I can't act this out for Diego."],[7520,7684,"It's way too embarrassing."],[7784,7856,"Just wait"],[7856,7976,"until Diego sees"],[7976,8180,"her flopping around up there like a fish."],[8244,8348,"He'll get the ick and"],[8348,8468,"Sam will hate her for"],[8468,8544,"embarrassing him."],[8592,8720,"And then she'll never"],[8720,8828,"show her face here again."],[8936,9184,"Umm, I don’t know..."],[9296,9444,"Clock’s ticking Olive, just do it."],[9516,9620,"Come on."],[9636,9756,"Come on, Olive."],[9808,9840,"Let's go."],[9840,9932,"It's okay."]],"13":[[0,44,"Okay."],[68,132,"Here we go."],[252,340,"Here goes nothing..."],[5516,5620,"What the hell?"],[5628,5700,"She wasn’t supposed to"],[5700,5780,"be good at this!"],[7440,7552,"I'm sorry."],[7836,7988,"Sam, how can you sit there and"],[7988,8160,"watch this disgusting display?"],[8300,8564,"She is clearly a wannabe"],[8564,8728,"who is using you to get to your brother."],[9088,9148,"Oh my God."],[9148,9252,"Stacy set me up."],[9272,9424,"My bestie's going to hate me."],[9544,9688,"Mind your business."],[9688,9764,"You're just jealous"],[9764,9928,"because you dance like a drunk giraffe."],[11124,11236,"Lap dance?"],[11552,11580,"Olive,"],[11580,11668,"how can you write something"],[11668,11772,"so disgusting?"],[11956,12084,"Mr. and Mrs. Rodriguez..."],[12084,12220,"You should kick her out."],[12472,12536,"Give me that."],[12844,12996,"This isn't Olive's handwriting."],[13052,13128,"It's Stacy's."]],"14":[[20,108,"Olive was just acting out"],[108,220,"the prompt she was given."],[308,408,"That's not true."],[408,580,"I would never write such a vulgar thing."],[668,848,"I’ve known you my entire life, Stacy."],[848,1008,"I can recognize your handwriting."],[1048,1188,"Stacy. My God."],[1188,1288,"I thought your parents"],[1288,1356,"brought you up"],[1356,1440,"better than this."],[1704,1820,"Look, it..."],[1856,1968,"it was a joke."],[2008,2168,"Okay, a little hazing for"],[2168,2284,"Sam's new girlfriend."],[2340,2472,"That's not funny, sis."],[2472,2576,"Not funny at all."],[2616,2788,"It was a harmless prank."],[2944,3112,"You get it right, Diego?"],[3204,3344,"It wasn't just a joke, Stacy."],[3400,3484,"You cheated."],[3604,3696,"You know what happens to"],[3696,3748,"cheaters..."],[4748,4932,"You humiliated Olive."],[5028,5140,"Now it's your turn."],[5472,5552,"Act it out."],[5648,5840,"Diego, don't make me."],[5916,6008,"No passing."],[6160,6224,"Do it!"],[6404,6508,"Come on, Stacy."],[6552,6592,"Come on,"],[6592,6664,"Stacy."],[7064,7112,"Oh."],[7164,7252,"Yes, Stacy."],[7336,7488,"Come on, Stacy."],[8172,8352,"Stacy!"],[9360,9520,"Smile for the camera, Stace."],[10416,10628,"Okay, everyone, let's just go back"],[10628,10780,"to the dining room and have dessert."],[10892,10988,"Come on sis."],[11512,11572,"Sam."],[11572,11704,"Thank you so much for understanding."],[11704,11752,"I'm so sorry."],[11752,11892,"I need a minute, Olive"],[12176,12216,"Sam."],[12236,12276,"Olive."],[12612,12752,"What the hell was with that dance?"],[12752,12860,"Are you trying to turn me on?"]],"15":[[48,152,"And why would I do that?"],[240,312,"You tell me."],[384,592,"I was playing a game, Diego."],[656,812,"And you could have stopped it, but,"],[888,948,"you didn't."],[992,1080,"And you just fell right into"],[1080,1192,"your girlfriend's little trap."],[1328,1492,"And I could have stopped it."],[1568,1620,"Never again."],[1664,1840,"Olive, I stood up for you"],[1840,1892,"back