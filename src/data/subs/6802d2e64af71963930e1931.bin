ust fund!"],[3144,3400,"You poor people are so desperate to"],[3400,3468,"be like us."],[3544,3788,"I can't believe you would stoop so low."],[3856,3928,"See?"],[3928,4092,"No one believes your lies, Olive."],[4208,4304,"That's it."],[4304,4428,"You're leaving my house!"],[4484,4680,"But I didn't, I didn't do it."],[4680,4980,"Get out or I'll drag you out."],[5060,5148,"Don't touch her!"],[5852,6032,"Oliver didn't poison Sam."],[6032,6128,"Stacy did."]],"18":[[16,184,"Didn't you serve up the pie, Stacy?"],[236,280,"Diego,"],[280,400,"what are you accusing me of?"],[436,728,"I'm accusing you of poisoning Sam"],[728,820,"and blaming Olive."],[940,1024,"You've made it pretty clear"],[1024,1104,"that you don't like her."],[1172,1256,"Diego. Come on."],[1256,1396,"I would never do that."],[1432,1552,"Don't lie to me."],[1632,1748,"I have a clear view of the kitchen"],[1748,1856,"from the outside camera."],[1900,1956,"Shit."],[1988,2148,"How could I forget about the camera?"],[2252,2340,"Tell the truth,"],[2400,2512,"or I'll roll the tapes."],[2568,2656,"Please forgive me."],[2688,2796,"It's not what you think."],[2796,2964,"It was an honest mistake."],[2976,3248,"No, you poisoned my son"],[3292,3476,"and you blame it on his girlfriend."],[3588,3700,"What a disgrace."],[3960,4136,"I'm calling your father."],[4168,4268,"No, I"],[4368,4480,"You made this mess."],[4528,4620,"Now clean it up."],[4888,4984,"Diego you gave that"],[4984,5080,"to me when we were little."],[5104,5200,"You hurt my brother."],[5260,5376,"You hurt Olive."],[5456,5616,"You've shown me what you really are."],[5652,5792,"A psychotic, manipulative"],[5792,5856,"clout chaser."],[5988,6084,"You're not a friend to me."],[6220,6404,"You won't profit off my family anymore."],[6524,6588,"You are not welcomed to"],[6588,6632,"this house."],[6632,6684,"Get out!"],[7472,7548,"Diego, you don't know"],[7548,7628,"what you're saying."],[7664,7808,"Take your brother and leave."],[7936,8004,"Get her out!"],[8740,8952,