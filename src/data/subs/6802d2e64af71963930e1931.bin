 I don't."],[5628,5692,"I'm not done."],[5836,6016,"Tell Diego, Olive."],[6040,6120,"Tell everyone."],[6196,6348,"How the Rodriguez family"],[6376,6528,"isn't the only family"],[6528,6612,"you have tried to ruin."],[7092,7200,"This tramp,"],[7228,7464,"Olive Parry, if that's even her real name."],[7800,7996,"Sent an innocent man to jail."],[8244,8316,"Now,"],[8372,8528,"she's trying to do the same thing"],[8556,8672,"with the senator's sons."],[8764,8892,"He wasn't innocent."],[8892,9032,"That was my foster father."],[9032,9172,"He is the reason I have the scars."],[9536,9692,"Get her off the stage!"],[9764,9856,"I have proof!"]],"37":[[64,184,"I have proof!"],[500,636,"I'm tired of your lies, Stacy."],[788,888,"Get her out of here."],[1236,1276,"No!"],[1292,1344,"No!"],[1376,1488,"No! I..."],[1508,1592,"Please!"],[2028,2264,"She's the crazy one! I can prove it!"],[2284,2372,"I can prove it!"],[3264,3412,"As is the tradition of the night"],[3424,3528,"for the first bid,"],[3556,3732,"the bidder and the bachelor"],[3732,3844,"will take it on to the dance floor"],[3844,3956,"for our first dance."],[5940,6092,"Everybody is staring."],[6280,6368,"Don't worry about them."],[6520,6612,"Just focus on us."],[8872,9000,"You can dance too."],[9036,9100,"I told you."],[9224,9248,"There is a lot"],[9252,9328,"you don't know about me."],[11452,11488,"Sam!"],[11624,11820,"I'm such a terrible friend."],[11912,11960,"Friend?"]],"38":[[24,184,"Let Sam handle Olive."],[220,296,"These schemy skanks"],[300,364,"are going to ruin"],[376,500,"your father's campaign."],[576,712,"Don't choose her"],[712,876,"over our family reputation."],[956,1144,"Over your future as a senator."],[1436,1544,"Respectfully, mother,"],[1672,1824,"I'm not sure that's a future I want."],[2772,2864,"Riley what are you doing here?"],[2880,2980,"How did you find me?"],[3028,3148,"I ran away from home."],[3160,3232,"Lewis and Susan"],[3232,3328,"have been tracking you."],[3424,3488,"I stole her phone"],[3488,3560,"when she wasn't looking"],[3564,3632,"and I took a cab."],[3832,3964,"Does Susan know you left?"],[4000,4060,"I don't know."],[4096,4152,"She locked me up"],[4152,4228,"in the cupboard again."],[4324,4384,"I escaped"],[4384,4484,"but I couldn't stay there."],[4740,4784,"Olive,"],[4860,4904,"I..."],[4992,5024,"There!"],[5284,5464,"That's the girl that kidnapped my son!"],[5632,5712,"Arrest her!"]],"39":[[264,328,"Don't touch her!"],[472,540,"What's going on here?"],[628,760,"She kidnapped my son."],[804,1004,"I didn't kidnap my little brother."],[1064,1160,"You are such a liar."],[1260,1384,"She took him from me!"],[1436,1508,"And now she is lying"],[1508,1604,"to this family too."],[1696,1824,"You are the foster mom, aren't you?"],[1976,2068,"Your husband is the asshole"],[2068,2124,"who hurt Olive."],[2516,2656,"How dare you spread wicked lies"],[2656,2772,"about our family again?"],[2944,3016,"Unhand me!"],[3276,3384,"Come on Riley, we are leaving."],[3476,3572,"Don't touch him!"],[3792,3900,"She assaulted me."],[3900,3992,"She's insane."],[4016,4084,"Arrest her!"],[5004,5128,"Run Riley! Run!"],[5440,5604,"Come back here, you little monster."],[5704,5772,"Olive!"],[5920,6032,"I'll get you out, I promise."],[6132,6272,"Just please protect my brother."],[6272,6372,"He is all I have."],[6536,6592,"I will."]],"40":[[444,544,"What the hell was that for?"],[600,736,"Diego thinks he can smash my phone"],[736,836,"and destroy the evidence."],[932,1088,"Too bad it's all back up on my drive."],[2796,2896,"Olive?!"],[2908,2988,"Please Sam!"],[2988,3188,"Please help! I'm so sorry!"],[4208,4276,"Sam!"],[4452,4596,"I'll talk to you soon, but I have to go."],[4664,4804,"I don't want to talk, DJ."],[4952,5100,"I never want to talk to you again."]],"41":[[644,716,"Olive."],[928,1004,"Wow, wow, wow."],[1004,1072,"Ey, ey, ey."],[1072,1164,"I'm the lawyer."],[1248,1352,"Read this."],[2184,2396,"Olive, I'm so sorry."],[2400,2532,"I tried to protect Riley,"],[2572,2696,"but he is back with Susan."],[2856,2920,"But I brought somebody"],[2920,3012,"who might be able to help."],[3012,3120,"Miss Parry,"],[3216,3304,"I'm Robbie,"],[3328,3408,"one of the Rodriguez"],[3408,3516,"family lawyers."],[3548,3736,"Do your parents know about this?"],[3796,3848,"No,"],[3940,4076,"and I don't plan on telling them."],[4264,4360,"Miss Parry."],[4368,4428,"You've been charged"],[4428,4516,"with assault."],[4624,4708,"You won't win custody"],[4708,4840,"of your brother with a record."],[4864,4924,"If,"],[4936,5004,"you can convince"],[5004,5160,"his foster mother to drop the charges,"],[5268,5316,"you have a shot"],[5316,5460,"at getting Riley out of her house."],[5548,5628,"If you don't,"],[5720,5800,"the charges can lead"],[5800,5928,"to a restraining order."],[5976,6044,"And you won't see him"],[6044,6156,"until he turns 18."],[6608,6712,"Olive,"],[6884,7012,"we'll do everything we need to."],[7012,7064,"I promise."],[7204,7288,"We will get him back."],[7476,7560,"In the meantime,"],[7572,7700,"I recommend you lay low."],[7720,7752,"Don't bring"],[7752,7896,"any attention to yourselves."],[7964,8080,"Anything can be used against you"],[8080,8192,"in a custody battle."],[9320,9424,"Alright! Come on, guys."],[9424,9504,"All right, Diego."],[9504,9664,"Any comments for the Daily Planet?"],[10412,10508,"What is your father think,"],[10508,10600,"the senator"],[10628,10784,"about your criminal girlfriend?"],[10944,10996,"Any comment"],[10996,11112,"would be very helpful."],[11112,11208,"For the Daily Planet, please."],[11428,11552,"Please sir, anything."],[11568,11628,"How does this happen?"],[11656,11712,"What do you,"],[11712,11804,"what's your comments?"],[11808,11896,"Diego."]],"42":[[44,116,"About your"],[116,240,"criminal girlfriend..."],[240,344,"Any comment"],[344,412,"would be very helpful."],[412,488,"Just for the Daily Planet please..."],[552,696,"Please Sir, any..."],[696,784,"How does this happen?"],[792,832,"What is..."],[848,1000,"What’s your comment? Diego."],[1680,1724,"I'm so sorry."],[1724,1812,"I dragged your family"],[1812,1912,"into my mess."],[2028,2264,"Olive, my family's in politics."],[2348,2496,"We make plenty of our own messes."],[2584,2664,"Oh my God."],[2664,2796,"Sam, is he okay?"],[2828,2912,"I don't think so."],[3032,3152,"Somebody told him about us."],[3592,3696,"Sam, where are you?"],[3696,3792,"Sam? Sam."],[3960,4024,"So what did you get"],[4024,4140,"arrested for last night?"],[4240,4308,"Lying,"],[4308,4456,"making out with someone’s brother,"],[4516,4616,"being a terrible friend?"],[4668,4784,"Sam I'm sorry."],[4784,4876,"I can explain."],[4876,5048,"You know how humiliating it was"],[5048,5164,"to stand there watching you"],[5164,5256,"choose DJ in front of"],[5256,5336,"all those people?"],[5508,5652,"I thought you were the one person"],[5652,5828,"who'd always stand by my side,"],[5848,6000,"who would always pick me over him."],[6504,6716,"Sam, that was a mistake."],[6716,6804,"No."],[6804,6996,"Bringing you here with me,"],[7024,7236,"trusting you would help me,"],[7236,7360,"that was a mistake."],[7456,7524,"You don't mean that."],[7524,7620,"You're just drunk."],[7692,7836,"I’m sober enough to know"],[7836,7968,"that this friendship"],[7968,8044,"is over."],[8504,8576,"Sam."],[8604,8676,"Just go away."]],"43":[[312,432,"You have no idea"],[432,572,"what Olive went through last night."],[724,844,"Keep talking to her like that,"],[844,964,"you're going to lose her forever."],[996,1160,"Oh, you'd like that, wouldn't you?"],[1160,1248,"So you can swoop in"],[1248,1380,"and fix her broken heart."],[1452,1612,"I'd never want that for you, Sam."],[1612,1740,"I'm your brother."],[1740,1820,"I'm trying to help you"],[1820,1960,"keep the one person"],[1960,2172,"that if I had, I would never want to lose."],[2172,2304,"You've already had her."],[2392,2484,"Of course you have."],[2484,2652,"You're the golden child."],[2652,2812,"Gets everything you want."],[2868,3000,"\"DJ is my perfect boy."],[3000,3096,"DJ is going to be senator,"],[3096,3184,"just like dad.\""],[3204,3288,"Mom, dad never"],[3288,3396,"talk about me like that."],[3420,3628,"I don't even want to be a senator, okay?"],[3652,3776,"I'm not like mom and dad."],[3824,3912,"Figures."],[3932,4040,"Even when you don't want it,"],[4040,4160,"they still choose you."],[4380,4500,"Everyone always"],[4500,4596,"chooses you."],[5040,5088,"Sam."],[5812,5880,"What do you want?"]],"44":[[1164,1288,"Sam was drunk."],[1380,1492,"He didn't mean what he said."],[1556,1616,"Well,"],[1664,1800,"you tell the truth and you're drunk,"],[1800,1856,"so..."],[2048,2152,"Besides, he's right."],[2152,2364,"I have been a really shitty friend."],[2408,2456,"I've been"],[2456,2580,"the shittiest brother ever."],[2664,2784,"It's not just your fault, Olive"],[2784,2936,"Don't be so hard on yourself."],[3016,3364,"No, see, this is what cost me"],[3364,3496,"my friendship."],[3728,3844,"Olive, why didn't you tell me"],[3844,3996,"you and Sam weren't together?"],[3996,4128,"It's not important."],[4192,4340,"I just ruined my friendship."],[4412,4540,"I don't know what I was thinking"],[4540,4684,"getting close to you again."],[4716,4804,"Probably the same thing"],[4804,4884,"I was thinking?"],[4924,5124,"Olive, you have no idea how hard it is"],[5124,5196,"to see your brother"],[5196,5288,"bring home the girl"],[5288,5376,"you're falling in love with."],[5376,5408,"No. Stop."],[5408,5576,"I can't do this right now."],[5680,5808,"I need to focus on Riley."],[6032,6164,"It's packed"],[6164,6324,"before Sam comes back,"],[6432,6532,"Olive,"],[6736,6812,"you can't do anything"],[6812,6948,"until Susan drops the charges."],[7080,7176,"And Robbie's working on that"],[7176,7260,"as we speak."],[7296,7480,"Sam's sleeping it off on the couch."],[7532,7664,"Talk to him in the morning."],[7888,7992,"Just lay down."],[8076,8176,"Get some rest."],[8264,8380,"Will you stay with me?"],[8428,8580,"Just until I fall asleep."],[8648,8748,"Of course I will."],[9256,9400,"Maybe in another life,"],[9456,9596,"we could make this work."],[9640,9828,"I'd do anything to keep you with me."]],"45":[[848,1020,"Sam."],[1276,1576,"It's not what it looks like."],[1592,1644,"Diego."],[1644,1728,"Please leave."],[1776,1880,"I need to speak to Olive."],[2516,2604,"Are you sick?"],[2792,2904,"I guess I caught something"],[2904,2968,"while I was in..."],[2968,3024,"The slammer?"],[3112,3184,"Yea, the joint."],[3260,3368,"Can't believe you went to jail"],[3368,3444,"before me."],[3468,3580,"And I can't believe my best friend"],[3580,3660,"didn't bail me out."],[3876,4040,"I'm sorry for everything I said."],[4204,4340,"You've been through so much"],[4340,4496,"with Riley and that foster family."],[4496,4600,"You didn't deserve that."],[4676,4752,"No, no."],[4752,4864,"I'm sorry."],[5248,5408,"I came here for you."],[5456,5648,"And I let all my baggage"],[5648,5732,"get in the way."],[5860,6068,"And I lied to you."],[6156,6224,"About what?"],[6360,6560,"I have to come clean about Diego."],[6576,6728,"For falling for your brother."]],"46":[[36,136,"He was the mask guy"],[136,260,"at the masquerade party"],[260,384,"that I slept with the week before"],[384,472,"coming here."],[828,892,"He is"],[892,1128,"“the best sex of your life” stranger?"],[1132,1260,"Yeah, but I didn't know it was him."],[1260,1412,"I swear I didn't work it out"],[1412,1524,"until he opened the front door."],[1572,1640,"Does he know about"],[1640,1720,"our arrangement?"],[1884,2060,"No, no, I made that promise to you."],[2060,2136,"Nobody,"],[2136,2276,"nobody knows the secret."],[2432,2588,"Olive, do you love him?"],[2796,2888,"I do,"],[3048,3188,"but I'm here for you."],[3188,3312,"So I'll be your girlfriend"],[3312,3404,"as long as you need me."],[3404,3560,"Just till the end of the summer, okay?"],[3672,3716,"Just..."],[3816,3988,"You're okay with choosing me"],[3988,4056,"over him?"],[4212,4368,"I wish I didn't have to,"],[4368,4524,"but I can't lose my best friend."],[4612,4728,"You're my bestie,"],[4832,4936,"if you still have me."],[5080,5300,"Of course. I love you, Olive."]],"47":[[148,344,"Now, how can I help you with Riley?"],[376,468,"I need to clear"],[468,612,"Susan's charges against me."],[632,796,"Otherwise, I can't claim for custody."],[872,1064,"Surely the country club"],[1064,1172,"has security cams."],[1208,1332,"Maybe there's footage that"],[1332,1452,"can prove your innocence."],[1520,1552,"Yeah."],[2580,2720,"What the hell is she doing here?"],[2732,2892,"Mom, Olive is still my girlfriend."],[2904,2952,"Girlfriend?"],[2984,3052,"Actually, DJ,"],[3084,3212,"I'd like to talk to you first."],[3820,4040,"This girl is more trouble"],[4040,4120,"than she's worth."],[4168,4392,"I want her out of the house now."],[4536,4616,"Haven’t you caused"],[4616,4732,"enough drama already?"],[4752,4856,"Excuse me?"],[5328,5400,"I won't have"],[5400,5496,"you come between my sons"],[5596,5696,"or ruin my husband's"],[5696,5804,"election campaign!"],[5876,6016,"Leave now,"],[6068,6252,"or I will make you."],[6252,6524,"I'm here for Sam, and I'm not leaving."],[7168,7236,"Oh my God!"],[7348,7400,"Oh my God!"],[7404,7456,"Help!"],[7524,7576,"Help!"]],"48":[[840,912,"Olive told me"],[912,1092,"you both met at the masquerade party."],[1384,1468,"Sorry, Sam."],[1644,1768,"When I saw her the other day,"],[1768,1912,"I couldn't help but think she cheated."],[1912,2052,"I tried to stay away, but"],[2052,2148,"Do you love her?"],[2500,2600,"But I don't get it."],[2600,2700,"You saw that video of"],[2700,2820,"me and Olive kissing."],[2820,2952,"You knew we went behind your back."],[2952,3084,"Why are you still together?"],[3192,3264,"Me and Olive"],[3264,3400,"entered an agreement"],[3400,3532,"so I could get Mom and Dad"],[3532,3640,"off my back about dating."],[3696,3780,"You're right."],[3816,3916,"I do love Olive,"],[3936,4088,"just not in that way."],[4188,4276,"She's my best friend."],[4452,4584,"Then why are you pretending?"],[4604,4696,"What are you trying to hide?"],[4880,4972,"Just say it."],[4972,5060,"Diego,"],[5060,5132,"I'm gay."],[5680,5728,"Olive?"],[5900,5988,"We were just talking,"],[6012,6160,"and she collapsed."],[6320,6396,"She's bleeding."],[6616,6720,"I can't find a pulse."]],"49":[[492,556,"Olive,"],[684,764,"please wake up."],[852,952,"We need to know you’re okay."],[1608,1736,"You boys should go for a walk"],[1736,1844,"and get some fresh air."],[1896,1996,"I'll watch over her."],[2088,2140,"But, mom..."],[2176,2276,"Don't worry."],[2276,2444,"I'll call if she wakes up."],[3228,3444,"Now to make sure she doesn't"],[3444,3640,"bother our family again..."],[4124,4184,"Excuse me."],[4240,4352,"Are you part of the family?"],[4404,4488,"Yes, yes."],[4536,4628,"She's my daughter."],[4852,4968,"What? No."],[4968,5064,"Get her out of here."],[5064,5100,"No."],[5132,5176,"Honey,"],[5440,5572,"it's just me."],[5692,5740,"Olive,"],[5880,5972,"it's all right."],[5972,6128,"You've been in a minor accident,"],[6128,6244,"but you're going to be okay."],[6324,6496,"You and the baby are going to be fine."],[6620,6712,"Baby?"]],"50":[[36,68,"I..."],[100,192,"I thought you knew."],[472,624,"I'll give you both a moment, shall I?"],[688,844,"I'm pregnant with Diego's baby?"],[876,1020,"How am I going to tell him?"],[1036,1172,"How will I tell Sam?"],[1488,1708,"Are you trying to steal all our money"],[1708,1856,"and ruin our reputation"],[1856,2036,"with my husband up for re-election?"],[2072,2160,"Yesterday,"],[2160,2296,"you were photographed with"],[2296,2372,"Diego,"],[2400,2576,"and today the doctor is telling me"],[2576,2668,"that you're pregnant with"],[2668,2844,"Sam's bastard child?"],[2872,2948,"No, I'm..."],[3000,3204,"I promised to keep Sam’s secret."],[3228,3428,"I can’t tell her the baby isn’t his..."],[4136,4288,"That's half of Sam's trust fund."],[4636,4776,"You get rid of this baby,"],[4776,4912,"and you stay the hell"],[4912,5040,"away from my family."],[5080,5160,"Or what?"],[5424,5608,"Or I'll shove you even harder"],[5608,5660,"next time,"],[5660,5704,"Olive."],[5808,6088,"I will pour poison down your throat."],[6184,6500,"I will hire someone to remove"],[6500,6632,"all your belongings,"],[6632,6904,"and every single trace of you"],[6960,7084,"from our lives."],[7220,7336,"Sam's my boyfriend."],[7336,7504,"He'll never forgive you for this."],[7544,7668,"I'm his mother."],[7784,7920,"I know what's best for him."],[8300,8404,"And if you leave now"],[8404,8500,"without a word,"],[8536,8660,"I'll throw in this video."],[8732,8908,"that I bet can really help with your"],[8908,9008,"custody battle for"],[9008,9192,"your little brat brother."],[9600,9724,"If I show this to Susan,"],[9724,9860,"she’ll be forced to"],[9860,9988,"drop the charges on me."],[9988,10156,"And then we can be a happy family."],[10176,10392,"Me, Riley... And the baby."],[10544,10768,"Fine. I'll take your deal."]],"51":[[100,172,"Where's Olive?"],[300,444,"I went out to talk to the doctor,"],[444,528,"and when I came back,"],[528,600,"she was gone."],[1068,1184,"I can't do this anymore."],[1296,1360,"I’m sorry."],[1512,1584,"She would never..."],[1584,1668,"I’m trying her cell."],[1756,1856,"No! Stop."],[2056,2160,"We need to focus on"],[2160,2364,"helping your father win this election."],[2488,2652,"He has a very important"],[2652,2772,"press conference tonight."],[2772,3072,"And we need to do damage control,"],[3224,3448,"which means, Diego,"],[3448,3668,"you need to stand beside him"],[3688,3860,"with an appropriate date."],[3980,4076,"I don't want that, mom."],[4356,4440,"Diego."],[4592,4736,"Meet your new fiancée,"],[4820,4892,"Stacy."],[5204,5284,"What?"],[5308,5420,"Your father's voters"],[5420,5572,"believe in a nuclear family,"],[5772,5844,"which is why"],[5844,5976,"we need to show the world"],[5976,6120,"that we brought you both up"],[6120,6276,"with traditional values."],[6400,6464,"You and Stacy"],[6464,6604,"have known each other forever."],[6636,6760,"Her family's wealthy."],[6904,7064,"Just makes perfect sense."],[7188,7276,"What about me?"],[7416,7524,"You'd better stay home."],[7632,7824,"We can't risk any more drama."],[8052,8152,"That isn't fair, mom."],[8292,8440,"I don’t want to stand beside Stacy,"],[8440,8504,"and Sam is..."],[8504,8648,"It's not worth fighting this DJ."],[8768,8876,"Just get through tonight,"],[8920,9000,"and I'll find Olive."]],"52":[[460,672,"Oh, what the hell do you want?"],[672,972,"Get off our property"],[976,1088,"before I call the cops,"],[1088,1204,"you home-wrecking bitch!"],[1260,1280,"Yeah,"],[1324,1412,"drop the charges,"],[1412,1556,"give me back custody of Riley,"],[1556,1644,"or you see this?"],[1912,2020,"Straight to the cops!"],[2256,2284,"Fine."],[2360,2452,"I'll drop the charges,"],[2452,2556,"but you'll never get Riley."],[2696,2952,"Think of it as my insurance policy."],[3028,3152,"And if you even think about"],[3152,3256,"posting that video,"],[3376,3496,"I will hurt Riley,"],[3576,3784,"the way my husband hurt you."],[3904,4104,"Olive, is that you?"],[4204,4264,"Riley."],[4264,4324,"Riley, I'm here."],[4324,4416,"Riley! Riley."],[4436,4476,"Get out!"],[4708,4788,"Both of you,"],[4788,4932,"get off my property,"],[5000,5168,"before I call the police,"],[5168,5264,"and have you both charged"],[5264,5352,"with trespassing."],[5580,5652,"Sam!"],[5796,5872,"Thank God you're here."],[5872,5956,"I'm so sorry."],[5956,6080,"I'm just glad you're okay."],[6232,6348,"Diego's trapped on my father's"],[6348,6444,"press conference."],[6444,6480,"Come on."],[6568,6648,"Where are we going?"],[6696,6792,"We're going to crash it."]],"53":[[1144,1232,"I got your message about"],[1232,1384,"Susan dropping the charges."],[1444,1580,"I'm filing for custody now."],[1648,1764,"Can you sit tight a little longer?"],[1820,1880,"Thank you."],[1880,1980,"Just please."],[1980,2048,"Please hurry."],[2840,2932,"Your family heirloom"],[2932,3036,"ring looks perfect on me."],[3036,3108,"Don't you think?"],[3328,3464,"Don't get used to wearing it."],[3808,3900,"How do you feel about"],[3900,3996,"your engagement?"],[3996,4128,"I'm so happy."],[4504,4728,"OMFG"],[4804,4920,"Olive."],[4920,5084,"Tell me you're not pregnant."],[5132,5264,"Would you kill me if I was?"],[5360,5428,"Depends."],[5452,5560,"Is it Diego's?"],[5648,5720,"Yes."],[5748,5828,"You're pregnant?"]],"54":[[40,104,"Yes."],[348,516,"Is that why you left the hospital?"],[576,788,"Mrs. Rodriguez will kill me"],[788,896,"if I tell them the truth."],[1000,1096,"I was scared,"],[1096,1292,"and the whole situation with Riley."],[1292,1452,"I'm just really overwhelmed."],[1604,1672,"Marry me."],[1752,1804,"What?"],[1900,1972,"You heard me."],[2016,2192,"Marry me so I can protect you,"],[2192,2292,"Riley and the child."],[2904,3060,"Sam, I'm so sorry."],[3060,3160,"No. I'm sorry."],[3272,3356,"I'm not going to stand"],[3356,3492,"between you and true happiness"],[3492,3572,"anymore."],[3772,3828,"You no longer"],[3828,3916,"have to pick between"],[3916,3996,"me and my brother."],[4240,4320,"Sam,"],[4332,4444,"are you breaking up with me?"],[4476,4624,"As your fake boyfriend? Yes."],[4716,4872,"As your friend? Never."],[4936,5104,"If you have the chance to"],[5160,5268,"show true love."],[5316,5464,"Why am I to stand in the way of that?"],[5684,5744,"Diego."],[5896,5944,"Yes."],[5944,6072,"I thought I made it"],[6072,6208,"very clear that you were to leave"],[6208,6408,"and never speak to my sons again."],[6596,6708,"Officer."],[6708,6868,"Seize this whore!"],[7156,7216,"What do you mean,"],[7216,7364,"you made it very clear?"],[7452,7512,"Are you the reason"],[7512,7612,"she left the hospital?"]],"55":[[36,148,"Answer the question."],[328,420,"You're not supposed"],[420,536,"to be here either."],[604,824,"I'm your son, and you're hiding me"],[824,1008,"like some kind of stain on the family?"],[1164,1332,"It's not you, sweetie."],[1364,1608,"It's this girl. She's corrupting you."],[1644,1816,"She's tainting the family name"],[1816,1976,"by getting arrested in public,"],[1976,2144,"and baby trapping you."],[2400,2612,"It didn't take much to get her to leave."],[2688,2792,"All I had to do"],[2792,2888,"is show her the money."],[3084,3344,"Half of Sam's trust fund, to be exact."],[3344,3460,"I took that money"],[3460,3552,"to protect my little brother."],[3656,3724,"It's right here."],[3996,4124,"Sam. Take it."],[4632,4720,"Do what you want with it."],[5172,5352,"What on earth is all this noise?"],[5508,5688,"The press is just outside the door."],[5872,6044,"This bitch is pregnant with"],[6044,6124,"Sam's baby."],[6300,6460,"She's going to bleed us dry."],[6504,6716,"She's going to ruin our reputation."],[6864,7204,"Sam, you made this mess."],[7360,7484,"Come here, boy."],[7636,7708,"Don't touch him."],[7968,8092,"Sam's done nothing wrong."],[8148,8280,"You want to hit somebody, hit me."],[8328,8460,"I'm the one that got Olive pregnant."]],"56":[[72,372,"You slept with your brother's girlfriend?"],[644,796,"Yes, but not really."],[796,904,"It's complicated."],[972,1068,"It's wrong."],[1068,1208,"That's what it is."],[1428,1636,"You're getting rid of this baby."],[1664,1860,"We can't afford to have this scandal"],[1860,1980,"get out before the election."],[2112,2304,"No. I'm keeping the baby."],[2420,2528,"I could be a better farther"],[2528,2608,"than you ever would."],[2716,2912,"You're ruining your life, boy."],[3004,3108,"You're throwing away"],[3108,3256,"your career as a senator."],[3276,3376,"And for what?"],[3524,3720,"Some two-timing skank?"],[3904,4052,"I'm not going to be a senator, dad."],[4084,4224,"That's your dream, not mine."],[4364,4428,"If you say"],[4428,4584,"one more bad word about Olive,"],[4640,4752,"I will no longer be your son"],[4752,4808,"anymore either."],[4912,4988,"Diego."],[4988,5188,"You do what your father says or..."],[5196,5272,"Or what?"],[5428,5552,"Hurt him like you hurt me?"],[5612,5676,"Yeah,"],[5756,5928,"or I'll shove you even harder"],[5928,5988,"next time,"],[5988,6036,"Olive."],[6096,6280,"I will hire someone"],[6280,6468,"to remove all your belongings"],[6468,6752,"and every single trace of you"],[6780,6892,"from our lives."],[7020,7140,"Threaten me or my"],[7140,7356,"baby again, or I'll show this recording"],[7356,7524,"to the entire press conference."]],"57":[[68,164,"You threatened"],[164,312,"to poison the mother of my child?"],[348,464,"I wouldn't have given her"],[464,556,"a lethal dose."],[684,924,"We're not doing this right now."],[1128,1204,"Diego."],[1352,1504,"Your fiancé's waiting for you"],[1504,1584,"in the other room."],[1664,1852,"Sam, get over here."],[2032,2136,"Sam?"],[2228,2316,"Can I have everyone's"],[2316,2404,"attention, please?"],[2944,3092,"He's taken the podium."],[3404,3468,"I have some"],[3468,3596,"very important news to share."],[4052,4180,"Whatever you have to say,"],[4244,4376,"I'm sure it can wait."],[4404,4500,"No, dad."],[4500,4584,"You already treat me"],[4584,4676,"like a disposable member"],[4676,4776,"of this family."],[4820,4984,"It’s finally time I tell my truth."],[5100,5264,"Oh my God."],[5264,5376,"He's going to do it."],[5376,5456,"He's going to come out"],[5456,5580,"on national television."],[5940,6164,"I can't believe I'm about to say this,"],[6164,6240,"but."],[6992,7068,"I'm gay."],[7312,7404,"That's right."],[7404,7520,"Sam Rodriquez,"],[7564,7824,"son of Senator Romero Rodriguez,"],[7824,7912,"is gay."],[8132,8176,"Olive,"],[8232,8284,"did you know?"]],"58":[[24,236,"I made a promise to Sam, I wouldn't tell."],[236,336,"He wanted to tell you"],[336,448,"when he was ready. And that's."],[448,504,"That's why"],[504,652,"we faked our relationship."],[744,840,"Why didn't he tell me?"],[912,1040,"You should ask him that yourself."],[1496,1796,"I'm sorry for this brief interruption."],[1872,2004,"I'll be right back."],[2620,2760,"That stupid boy"],[2856,2956,"just ruined everything!"],[3008,3156,"It's all your fault."],[3156,3316,"You're always coddling him"],[3316,3440,"and calling him baby."],[3496,3636,"Me? What? What about you?"],[3636,3768,"You're the one that's always yelling"],[3768,3988,"and bitching about how to be a man."],[4368,4484,"Ladies and gentlemen,"],[4484,4564,"my father."],[5964,6064,"You mad at me?"],[6064,6128,"Are you kidding?"],[6188,6300,"I'm so proud of you."],[6348,6412,"But I’m sorry"],[6412,6532,"you felt like you couldn’t tell me."],[6544,6684,"I didn't want Mom and Dad"],[6684,6916,"to disown you for keeping my secret."],[7000,7092,"You know what happened to"],[7092,7180,"the person they knew"],[7180,7296,"who came out of recently?"],[7480,7572,"You mean the pool boy"],[7572,7736,"they fired for being gay?"],[8468,8488,"Sam."],[8628,8724,"You're my brother."],[8772,8900,"That's never going to change."],[9120,9296,"Even if our family did this on us,"],[9396,9520,"I'll always be there for you."],[9588,9680,"So do I."],[10324,10460,"Stay away from my fiancé."]],"59":[[12,72,"Stacy,"],[72,156,"could you come on stage"],[156,212,"for a moment?"],[944,1024,"See, Olive."],[1092,1268,"I'm the only woman for Diego."],[1688,1792,"Diego, what are you doing?"],[1864,1984,"Giving this ring to someone who"],[1984,2092,"actually deserves it."],[3008,3088,"Olive Parry,"],[3660,3772,"will you do me the honor of"],[3772,3856,"becoming my wife"],[3856,4032,"and mother of my child?"],[4672,4864,"Mother of your child?"],[4924,5092,"You're going to marry a homeless"],[5092,5224,"baby trapping criminal?"],[5412,5656,"I'm going to marry a beautiful, selfless,"],[5656,5724,"strong woman."],[5800,5888,"Olive is a better person"],[5888,5960,"than you'll ever be."],[6108,6188,"And even if"],[6188,6276,"she hadn't walked into my life,"],[6340,6420,"I never"],[6512,6588,"would have chosen you."]],"60":[[492,580,"I’m going to make you pay,"],[580,656,"you bitch!"],[688,856,"You're going to be rotting in a prison"],[856,996,"so I'd like to see you try."],[1324,1500,"Once you send me the security footage"],[1500,1564,"of Susan abusing"],[1564,1692,"your brother,"],[1692,1784,"it's clear she should be"],[1784,1864,"the one behind bars."],[2040,2096,"Thankfully,"],[2096,2180,"it made your custody case"],[2180,2248,"a done deal."],[2368,2472,"You are so amazing, Olive."],[2536,2640,"I'm so proud of you"],[2640,2752,"for standing up for your little brother."],[2844,2932,"Olive."],[3024,3084,"Riley!"],[3248,3348,"I finally got you."],[3404,3516,"You never have to"],[3516,3688,"see Susan or Lewis ever again."],[3764,3924,"You’re finally coming home."],[4228,4396,"This is my fiancé, Diego."],[4796,4856,"And this..."],[4884,5044,"is your new little niece and nephew."],[5044,5160,"I'm going to be an uncle?"],[5376,5496,"Where are we going to live?"],[5712,5788,"You stay with me"],[5788,5896,"until we find a bigger place."],[5952,6004,"I'm sure"],[6004,6128,"our mother's hush money"],[6128,6284,"would make for a nicer deposit."],[6488,6788,"Sam, this is your trust fund."],[6864,6924,"Are you sure?"],[6984,7064,"Of course."],[7092,7156,"I'm just glad"],[7156,7320,"you're finally leaving my couch."],[7404,7484,"Kidding."],[7548,7644,"You know I love you."],[8796,9000,"Oh, gotta run."],[9024,9152,"I have a hot date"],[9152,9280,"with a certain delivery boy."],[10068,10236,"I just want my little brother"],[10236,10388,"and my baby to grow up in a home"],[10388,10444,"where they know"],[10444,10540,"they can love anyone,"],[10572,10672,"and know they will always"],[10672,10732,"be loved back."],[10804,10892,"I promise, Olive."],[10952,11068,"As long as we're together,"],[11068,11184,"we will build that home."]]}