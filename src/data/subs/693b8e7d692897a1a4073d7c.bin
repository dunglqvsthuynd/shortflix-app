or once in my life,"],[6006,6097,"I want to do something for"],[6097,6168,"myself."],[7332,7515,"Booyah!"],[9013,9075,"That girl"],[9075,9217,"Hayley thinks that she's hot shit"],[9217,9313,"because she has some guy's"],[9313,9396,"attention?"],[9396,9667,"It's time to put that bitch in her"],[9667,9784,"place."],[10018,10160,"Oh."]],"46":[[350,421,"Oh!"],[421,529,"Oh my God!"],[529,771,"She bit my lip!"],[1138,1292,"Oh!"],[1388,1639,"Adam, can you help me?"],[1639,1780,"Have Kyle help you."],[2143,2248,"Tell me what hurts worse,"],[2248,2298,"Hayley."],[2298,2598,"The fall or the rejection?"],[2644,2706,"Way to prove"],[2706,2844,"that you're not over your ex."],[2844,2977,"Excuse me?"],[3007,3148,"You just kissed yours."],[3148,3390,"I just wanted to show that"],[3390,3545,"sex doesn't mean anything to me."],[3545,3695,"Really?"],[3695,3774,"So when we hooked up,"],[3774,3878,"it didn't mean anything?"],[3937,4091,"No. It did."],[4091,4216,"It meant everything."],[4216,4366,"But Lila ruined it"],[4366,4491,"by coming to the villa."],[4491,4692,"Hey, listen."],[4692,4788,"We have a really good thing"],[4788,4904,"going here."],[4904,5025,"All right?"],[5025,5205,"Don't let her ruin it."],[5205,5376,"You promise you're over her?"],[5376,5559,"I promise."],[5559,5651,"I'm over her the same way"],[5651,5818,"you're over Kyle."],[5818,5947,"All right?"],[5947,6031,"And me and Lila,"],[6031,6147,"haven't been together"],[6147,6331,"in a real way for..."],[6339,6402,"ever."],[6439,6535,"Really?"],[6581,6614,"Adam?"],[7240,7273,"No,"],[7273,7432,"Lila."],[7432,7503,"How long has it"],[7503,7803,"been since Adam and you hooked up?"],[7912,8070,"Do you want me to tell her?"],[8070,8204,"I'm not answering that."],[8341,8458,"I will."],[8458,8596,"It was the night before he"],[8596,8742,"left for Seduction Cove."]],"47":[[75,283,"We hooked up in the back of my car"],[283,583,"and it was so, so hot."],[625,788,"You hooked up with your ex before"],[788,905,"you came to the villa?"],[905,955,"Yeah."],[955,1084,"And he'll hook up with me again"],[1084,1163,"when he leaves."],[1163,1297,"Hayley, it's not what it sounds like."],[1297,1397,"It's one thing to hook up"],[1397,1472,"with your ex,"],[1472,1618,"but, Adam, you lied to me."],[1618,1743,"If you let me explain--"],[1743,1910,"She doesn't want your explanation,"],[1910,1960,"bro."],[1960,2097,"Do you, Hay?"],[2097,2181,"I..."],[2306,2423,"I don't know."],[2423,2552,"It doesn't matter what she wants."],[2552,2619,"Adam told me"],[2619,2698,"he was going to come to"],[2698,2794,"Seduction Cove,"],[2794,3053,"find the dumbest skank on the island"],[3053,3148,"and take all the money"],[3148,3261,"when he won."],[3261,3428,"If Adam and I leave the island together,"],[3428,3628,"he gets $100,000,"],[3628,3828,"or he can split it with me."],[3828,3937,"Has he really been"],[3937,4066,"playing me this whole time?"],[4162,4258,"So I'm just a stupid"],[4258,4454,"girl who's basically an ATM, huh?"],[4454,4567,"Don't listen to her."],[4567,4683,"You're the one who lied to me."],[4683,4871,"So maybe I shouldn't listen to you!"],[7332,7453,"What are you doing here?"]],"48":[[358,571,"Hey."],[571,696,"Just here as a friend."],[696,763,"Dude,"],[763,900,"everyone thought that I couldn't"],[900,1001,"get back with Hayley"],[1001,1209,"after I cheated on her,"],[1209,1522,"but she's so sad and desperate after"],[1522,1589,"Adam"],[1589,1647,"that I bet"],[1647,1805,"she'd throw a fuck my way"],[1805,2039,"just out of desperation."],[2039,2277,"Hey,"],[2277,2364,"Teddybear."],[2364,2523,"It's okay."],[2523,2798,"You can't call me Teddybear anymore."],[2798,2961,"But"],[2961,3169,"you are my Teddybear."],[3169,3290,"And like my Teddybear,"],[3290,3499,"you deserve all of the snuggles"],[3499,3707,"and the love..."],[3707,3874,"I should hate you."],[3874,3953,"If it weren't for you"],[3953,4079,"cheating on me with my sister,"],[4079,4266,"we wouldn't be on this island."],[4375,4529,"I was testing myself."],[4596,4763,"Okay, there's all these hot girls"],[4763,5009,"around, and I'm still chasing after you."],[5009,5309,"Dude, lying to Hayley is so easy."],[5355,5634,"She's so sweet and innocent that"],[5634,5801,"she'll believe anything."],[5893,6022,"Kyle's been an ass to me,"],[6022,6097,"but at least I know"],[6097,6202,"what to expect from him."],[6385,6485,"Come on, Hayley,"],[6485,6606,"let's go."],[6848,6961,"She's not going anywhere."]],"49":[[191,329,"Get away from her."],[379,417,"Why don't"],[417,596,"you go sleep with your ex-girlfriend?"],[754,884,"Lila got me drunk."],[959,1046,"That's why we hooked up."],[1046,1184,"So you admit it."],[1184,1297,"You hooked up with your ex"],[1297,1401,"before coming here?"],[1401,1451,"Yeah."],[1451,1505,"And I'm sorry"],[1505,1614,"I lied to you about it, but come on,"],[1614,1676,"I mean--"],[1676,1785,"I don’t even kown... -Stop it!"],[1889,2010,"I don't want to hear it."],[2010,2168,"Let me finish."],[2168,2389,"I would never use you for money,"],[2389,2423,"all right?"],[2423,2477,"And everything else"],[2477,2552,"that's happened between us"],[2552,2673,"that's been real."],[2673,2811,"Saving you was real."],[2811,2861,"You made me"],[2861,3073,"care about you and then humiliated me."],[3157,3286,"I should hate you."],[4112,4179,"If you don't want me here,"],[4179,4287,"tell me to leave."],[4325,4412,"Because if it's not for you,"],[4412,4579,"there's no reason for me to be here."],[5505,5551,"Leave."]],"50":[[166,271,"Leave."],[271,400,"Yeah, bro."],[400,675,"Fucking leave."],[763,1017,"I was talking to you."],[1234,1447,"This is bullshit."],[1447,1747,"You call me when you want a real man."],[2327,2419,"How can I believe you"],[2419,2719,"when you tell me you're here for me?"],[2836,2932,"How about instead of telling you,"],[2932,3048,"I show you?"],[3712,3920,"I'm still mad at you."],[3920,4091,"You should be."],[4587,4662,"You can't"],[4662,4863,"just win me over with sex."],[4988,5096,"I can try."],[5146,5238,"I mean, I'm not going back on"],[5238,5355,"that date."],[5455,5534,"Where should we go?"]],"51":[[396,696,"Are you sure you're still mad at me?"],[763,1017,"I'm going to make you work for it."],[1063,1317,"You always like when I did this."],[1480,1547,"Where were you?"],[1547,1622,"Where's Adam?"],[1622,1814,"Hayley and Adam told me to go get lost."],[1814,1960,"If they keep hooking up,"],[1960,2089,"we're not going to get the prize money."],[2089,2239,"Hayley may have Adam's"],[2239,2331,"attention now,"],[2331,2452,"but I have a secret weapon"],[2452,2644,"that's going to make me unstoppable."],[2644,2886,"And once Adam dumps Hayley,"],[2886,3111,"their money is as good as mine."],[3161,3382,"Yo soy Brent Williams"],[3382,3607,"Esta es Seducción Cove."],[3837,3920,"What? Hey!"],[3920,3995,"This isn't working."],[3995,4074,"You need to work harder"],[4074,4145,"to break them up."],[4145,4229,"Okay, look, those two"],[4229,4462,"have a very deep physical connection."],[4462,4675,"No one in their team can split them up."],[4675,4775,"Nobody."],[4775,5075,"Then you need to hide their identity."],[5088,5205,"And you"],[5205,5292,"can trick Adam"],[5292,5505,"into cheating on her and Hayley's"],[5505,5689,"such a dumb virgin she'll dump him."],[5997,6181,"I can make that happen."],[6247,6381,"Thanks, baby."],[6381,6531,"You know, there are some serious perks"],[6531,6656,"to sleeping with the host of the show."],[6690,6752,"Yeah."]],"52":[[271,392,"As we come to the end"],[392,625,"of our journey on the island,"],[625,725,"we've seen our players"],[725,967,"be tempted by each other's bodies."],[967,1234,"But can they be tempted"],[1234,1447,"with each other's minds?"],[1447,1622,"So tonight we have the first"],[1622,1839,"first ever Seduction Cove"],[1860,1972,"masquerade."],[1972,2102,"Tonight at the masquerade,"],[2102,2327,"everyone's identity will be hidden"],[2327,2431,"and who our players want"],[2431,2502,"to match with"],[2502,2673,"will entirely depend"],[2673,2886,"on their emotional connections."],[2886,3086,"As the old saying goes,"],[3086,3249,"the person behind the mask"],[3249,3595,"might not match with who it really is."],[3707,3757,"I know"],[3757,3924,"Adam and I have a strong connection."],[3924,4079,"We'll be able to find each other."],[4079,4137,"Tonight's the night"],[4137,4241,"I show Hayley that I'm the guy"],[4241,4400,"she actually needs."],[4637,4938,"So the masquerade starts now."],[7290,7444,"If I sleep with Hayley,"],[7444,7745,"I get 100 K."],[7891,7978,"And it's going to be hella"],[7978,8108,"easy to do that"],[8108,8262,"if she doesn't know it's me."],[8867,9054,"Hayley,"],[9054,9121,"it's your man."]],"53":[[79,333,"Kyle, is that you?"],[650,696,"We can't"],[696,996,"ask questions about who is who, right?"],[1080,1255,"Contestants at the masquerade."],[1255,1405,"You are expressly forbidden"],[1405,1551,"from using names."],[1551,1659,"Right."],[1906,2102,"Let me get you a drink."],[2102,2193,"Pineapple margarita,"],[2193,2327,"right?"],[2327,2419,"Yeah."],[2419,2610,"That's my favorite."],[3511,3641,"Pineapple margarita."],[3641,3745,"It's my favorite."],[3745,3920,"Who ordered me this?"],[3920,4079,"Hayley, you remember me?"],[4170,4358,"Adam is the only person"],[4358,4491,"who knows that my favorite drink"],[4491,4683,"is a pineapple margarita."],[4683,4909,"I knew it had to be him."],[5005,5146,"I had the producers"],[5146,5330,"tell me her favorite drink."],[5442,5743,"Thanks, it's perfect."],[6118,6268,"Where is she?"],[6448,6585,"Hayley?"],[6698,6802,"Looking for someone?"],[6802,7044,"Yeah. I'm looking for Hayley."],[7044,7244,"Maybe she's closer than you think."],[7323,7440,"Hayley?"],[7440,7607,"Shh. No names."],[7607,7653,"Haley's"],[7653,7786,"such a rule follower."],[7786,7870,"So when she refused"],[7870,7966,"to tell me who she was, it"],[7966,8212,"basically confirmed it for me."],[8212,8341,"This party's kinda boring."],[8479,8529,"Yeah, it is."],[8529,8675,"We should ditch it."],[8675,8779,"Let's go over to the hot tub."],[8779,8975,"When I get Adam in that hot tub,"],[8975,9209,"he won't care where Hayley is."],[9209,9309,"He'll be all mine."]],"54":[[120,246,"I wish we could..."],[246,325,"leave this party"],[325,521,"and go right back to our rooms."],[567,721,"I kind of like it."],[721,813,"Being here with you,"],[813,946,"without our exes,"],[1009,1263,"without Kyle being a complete"],[1263,1463,"slimeball creep."],[1564,1655,"That..."],[1693,1876,"he's not that bad."],[1876,2052,"Seriously?"],[2052,2389,"Childish, arrogant and a cheater too."],[2489,2715,"Well, you're not so perfect either."],[2781,2927,"Are you serious, Adam?"],[2927,3148,"You're defending Kyle?"],[3148,3269,"I'm out of here."],[3269,3415,"Hayley."],[3415,3482,"Sorry."],[3482,3661,"What I meant to say was,"],[3766,3966,"let's go dance."],[4183,4354,"I'd love to dance."]],"55":[[1659,1805,"You're not Adam."],[1968,2043,"I'm not?"],[2043,2093,"No."],[2093,2235,"I can tell by the kiss"],[2235,2444,"there were no fireworks."],[2577,2769,"I knew that I'd been caught."],[2769,3069,"I had to think, like, super fast."],[3082,3144,"Luckily, I'm"],[3144,3336,"really good at lying to Hayley."],[3474,3636,"Adam sent me here to distract you."],[3636,3716,"What?"],[3716,3791,"He wants to hook up"],[3791,3908,"with his ex-girlfriend."],[3908,4012,"But..."],[4696,4967,"Hey... what are you doing?"],[5096,5213,"Adam?"],[5338,5455,"Hayley?"]],"56":[[625,804,"If that's you..."],[804,1009,"Who's this?"],[1009,1076,"Stop, baby."],[1076,1217,"You know it's me."],[1263,1530,"Adam is where he belongs."],[1530,1639,"In my arms."],[1772,2031,"I can't believe you'd hook up with her."],[2523,2627,"I thought she was you."],[2627,2798,"Oh, really, Adam?"],[2798,2873,"Because I'm pretty sure"],[2873,2973,"you told me to distract"],[2973,3061,"Hayley here"],[3061,3361,"while you hooked up with Lila."],[3603,3820,"I can't believe you."],[3820,3978,"Hayley,"],[3978,4162,"you deserve better than this."],[4162,4337,"How are you gonna get mad at me?"],[4383,4508,"You were with him the whole night."],[4508,4662,"I was trying to find you."],[4662,4854,"We were talking."],[4854,4967,"And you know what?"],[4967,5046,"I need someone to talk"],[5046,5163,"to right now."],[5163,5296,"Let's get out of here."],[5296,5405,"We're done."]],"57":[[496,692,"I can't believe Adam would do this."],[800,996,"What if he's just pretending to like"],[996,1092,"me so he can win the money"],[1092,1209,"and run off with Lila?"],[1209,1372,"He's an a-hole."],[1372,1589,"I just want to find my person."],[1589,1676,"Someone who thinks I'm"],[1676,1826,"the most beautiful girl in the room."],[1826,2002,"Even when I'm not."],[2089,2231,"Someone who doesn't fall into"],[2231,2360,"temptation."],[2360,2510,"I thought that could be Adam."],[2644,2786,"Adam's a sucker."],[2786,3086,"All the guys in the house hate him."],[3090,3194,"Seriously?"],[3194,3349,"Dude,"],[3349,3603,"I am the master of lying to Hayley."],[3603,3674,"A few days ago,"],[3674,3870,"I would have never believe this."],[3870,4041,"Adam told me he was over his ex,"],[4041,4129,"and now he's making out"],[4129,4287,"with her by the pool."],[4287,4446,"What else is he lying about?"],[4562,4692,"Oh, yeah."],[4692,4929,"He's been telling everyone that he's"],[4929,5230,"been using you to get all the money."],[5238,5347,"And he's going to use that money"],[5347,5463,"to buy Lila"],[5463,5651,"a giant engagement ring."],[5651,5768,"Like a huge rock."],[6093,6252,"Hayley, we need to talk."],[6414,6573,"There's only one thing I need to do."]],"58":[[54,254,"Hayley, what the fuck?"],[321,429,"I could do a lot worse,"],[429,554,"considering what you did."],[554,646,"I'm not going anywhere"],[646,796,"until we sit down and talk."],[796,1013,"You must really want that prize money."],[1013,1121,"At the end of the season,"],[1121,1259,"each couple pairs off and gets"],[1259,1422,"$100,000."],[1443,1630,"The temptations can either split it"],[1630,1822,"or keep it for themselves."],[1922,2077,"Was I dumb enough to think Adam"],[2077,2206,"actually liked me?"],[2414,2531,"You think this is about money?"],[2531,2669,"Hayley, I don't need money."],[2669,2790,"Wow."],[2790,2940,"Cocky as hell, huh?"],[3094,3290,"Contestants, our masquerade"],[3290,3411,"is coming to an end."],[3411,3607,"Please take off your masks."],[3870,4170,"Don't mind if I do."],[4458,4583,"Kyle?"],[4833,4967,"I've got you for the night, Hay."],[5125,5213,"Everyone, choose your date"],[5213,5259,"for the night"],[5259,5384,"and go back to your room."],[5384,5484,"When the gong goes off,"],[5484,5559,"you'll lock arms with your"],[5559,5668,"partner for the night."],[5851,5901,"You come with me."]],"59":[[792,880,"I can't believe"],[880,996,"you hooked up with your ex"],[996,1084,"and now you're forcing me"],[1084,1172,"to spend the night with you."],[1172,1213,"It's the only"],[1213,1351,"way I can get you to talk to me."],[1351,1468,"I have no words."],[1468,1597,"You're still in love with your ex."],[1597,1655,"You're the one who"],[1655,1843,"spent the whole night with your ex."],[1843,2114,"Because I thought it was you."],[2114,2210,"Then maybe you'll believe me"],[2210,2252,"when I tell you"],[2252,2552,"that I thought my ex was you."],[2602,2898,"I, um..."],[2944,3103,"Please believe me."],[3103,3199,"You're the only person"],[3199,3386,"that I want to see tonight."],[4024,4233,"Hayley, let me in."],[4295,4408,"Hayley,"],[4408,4592,"I know you're in there."],[4662,4884,"Don't you dare let him in."],[4925,5067,"If you open that door, it's over."],[5067,5142,"Over?"],[5142,5334,"We never even started."],[6418,6573,"Hayley,"],[6573,6748,"I came to save you."],[6748,6844,"That's rich."],[6844,6923,"Especially coming from the guy"],[6923,7036,"who keeps on cheating on her."],[7036,7328,"Oh, you really want that money, huh?"],[7328,7444,"No, I don't want the money."],[7444,7603,"I want Hayley."],[7603,7707,"And I'm not leaving here without her."],[7895,8020,"Hayley,"],[8020,8191,"I, um..."],[8479,8600,"I love you."],[8833,9004,"Oh my goodness."],[9296,9567,"I love her and you don't."],[9567,9868,"So leave us alone."],[9943,10110,"I can't do this."],[10110,10301,"Both of you leave me alone!"],[10735,10973,"All I ever wanted was love."],[10973,11169,"And now I've had my heart broken..."],[11169,11273,"twice."],[11357,11482,"The only temptation left for"],[11482,11586,"me is the plane ride home."]],"60":[[1067,1226,"We're going to talk about Adam."],[1276,1405,"Leave me alone, Lila."],[1405,1514,"I know I haven't been the nicest"],[1514,1543,"to you,"],[1543,1714,"but I want to change that."],[1714,1789,"Starting"],[1789,1906,"now."],[1906,2014,"Sure."],[2014,2135,"If you're going to be with Adam,"],[2135,2323,"there's some things you have to know."],[2323,2706,"He's always after the shiny new thing."],[2706,2957,"And right now, that's you."],[3061,3361,"But if you leave this island with him,"],[3449,3632,"he's going to find someone else."],[3632,3716,"If you're trying to get in"],[3716,3828,"my head, it's not working."],[3828,4129,"I am trying to help you for once."],[4166,4362,"The entire time I was with Adam,"],[4362,4533,"he never told me he loved me."],[4533,4708,"Not once."],[4800,5075,"Do you really want that to be you?"],[5196,5317,"No."],[5380,5680,"And Kyle, he"],[5743,6031,"loves me in his own fucked up way."],[6072,6160,"Tomorrow's"],[6160,6310,"our last night on the island."],[6310,6468,"Do you really want to waste it on"],[6468,6598,"someone who will never love you?"],[7303,7436,"We've had a wild ride"],[7436,7615,"on this season of Seduction Cove."],[7615,7795,"But tonight is our last night."],[7795,7966,"And this last challenge is called"],[7966,8103,"Final Choice."],[8103,8245,"Each of our contestants"],[8245,8400,"get to select one person"],[8400,8441,"who they want"],[8441,8562,"to spend their final night with."],[8562,8616,"They can either"],[8616,8863,"stay or leave the villa altogether."],[8863,9092,"Hayley, you're up first."],[9092,9221,"Who do you choose"],[9221,9401,"to take to the bungalow?"],[10226,10443,"I, uh..."],[10472,10689,"I, uh..."],[10756,10935,"Before you choose, I have something"],[10935,11048,"to say."],[11428,11544,"Hayley,"],[11732,11803,"I love you."]],"61":[[0,191,"The entire time I was with Adam"],[191,358,"he never told me he loved me."],[358,508,"Not once."],[508,642,"Why are you saying this now?"],[642,800,"In front of everyone?"],[880,967,"Because I had to say it before"],[967,1126,"it's too late."],[1126,1309,"And it's true, I swear."],[1393,1543,"I think you're incredible."],[2189,2314,"I love you, too."],[2314,2389,"Yeah?"],[2535,2660,"At Seduction Cove"],[2660,2752,"Adam and Hayley"],[2752,2952,"found a deep physical connection."],[2952,3073,"But that's not it."],[3073,3194,"They also found a very deep"],[3194,3299,"love connection."],[3299,3445,"And that's why tonight"],[3445,3574,"we're offering a new twist."],[3574,3816,"A chance to spend the night together"],[3816,3983,"in the hideaway."],[3983,4116,"Go off, you two."],[4116,4275,"Have some fun, kids."],[4275,4421,"You've earned it."],[4971,5113,"Hayley!"],[5334,5409,"Sad."],[5409,5605,"Very, very sad."],[5605,5764,"But what they don't know..."],[5764,5947,"There's one more challenge"],[5947,6247,"that most couples will fail."],[6831,6936,"I can't wait to get you alone"],[6936,7036,"in the bungalow."],[7036,7161,"Yeah? What are you gonna do to me?"],[7966,8245,"I give you your first orgasm, right?"],[8245,8312,"Are you ready for"],[8312,8470,"two, three, four, and five?"],[8616,8708,"Let's go."],[8708,8904,"I can't wait any longer."],[10030,10151,"What is this?"],[10151,10414,"This is the tunnel of truth."]],"62":[[54,342,"What's the Tunnel of Truth?"],[342,546,"The Tunnel of Truth is a lie"],[546,671,"detector test"],[671,763,"that determines"],[763,938,"if the two of you have been honest"],[938,1213,"about your intentions with each other."],[1213,1384,"Pass the tunnel of truth"],[1384,1484,"and you will get your"],[1484,1668,"sexy private suite"],[1668,1947,"and your sweet cash prize."],[1947,2147,"Are you ready?"],[2293,2419,"Yes."],[2502,2598,"Adam,"],[2598,2794,"did you know that you were kissing,"],[2794,3032,"Lila by the pool?"],[3098,3207,"No."],[3319,3620,"We have determined that is true."],[3666,3757,"Hayley,"],[3757,4070,"did Adam give you your first orgasm?"],[4312,4446,"Yes."],[4617,4917,"We have determined that is true."],[4979,5084,"Adam,"],[5084,5271,"did you come to the island"],[5271,5526,"just to see Hayley?"],[5526,5709,"Yes."],[5709,6010,"We have determined that is true."],[6114,6410,"Hayley, do you trust Adam when he says"],[6410,6710,"he'd choose you over the money?"],[7970,8233,"Yes."],[8233,8458,"True."],[8458,8687,"Adam, do you see yourself"],[8687,8988,"marrying Hayley?"],[9234,9355,"I've told Adam"],[9355,9542,"I'm done with the chasing."],[9542,9726,"I want someone who loves me,"],[9726,9930,"who wants to marry me."],[9930,10064,"If he doesn't want to marry me,"],[10064,10218,"what are we doing?"],[10481,10560,"Adam, answer!"]],"63":[[196,271,"No."],[1426,1680,"Are you serious?"],[1680,1872,"Congratulations."],[1872,2168,"You have passed the Tunnel of Truth."],[2168,2469,"Please move on to your next destination."],[2489,2602,"I'm not going."],[2602,2669,"Hayley come on."],[2669,2806,"Please don't do this."],[2806,2894,"Do what?"],[2894,2986,"Go be with someone"],[2986,3253,"who doesn't want to marry me?"],[3253,3465,"I told you that I love you."],[3465,3766,"Isn't that good enough?"],[4166,4337,"Come on. Let's go to the bungalow."],[5609,5701,"Hayley."],[5701,5855,"What are you doing here?"],[6231,6331,"I came to win you back."]],"64":[[421,558,"What are you doing here?"],[558,700,"I couldn't let you spend the night"],[700,988,"with Mr. Toolkit of the year here."],[988,1067,"Not until you've heard"],[1067,1188,"what I have to say."],[1297,1447,"Dude, why don't you just fuck off?"],