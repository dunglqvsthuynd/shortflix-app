o give Hayley the money."],[6694,6827,"All of it."],[7102,7378,"And, Hayley, there's one final twist."],[7378,7511,"If you take the money,"],[7511,7674,"we're going to increase it to"],[7674,7849,"$500,000."],[7891,8137,"So I ask you, will you take the money"],[8249,8350,"or leave with Adam?"]],"66":[[112,342,"$500,000?"],[442,658,"Yes, half $1 million."],[658,900,"But if you take the money,"],[900,1113,"you and Adam leave the island"],[1113,1201,"alone."],[1372,1514,"Take the money,"],[1514,1580,"Hayley."],[1580,1651,"Seriously,"],[1651,1747,"you'd be an idiot"],[1747,1864,"not to."],[1901,2043,"America,"],[2064,2168,"what do you think?"],[2569,2706,"Woof!"],[2706,2852,"America has decided."],[2852,2973,"And, Hayley,"],[2973,3044,"they think you should take"],[3044,3157,"the money."],[3157,3332,"That's what the people want."],[3382,3603,"That $500,000 thing"],[3603,3895,"was my idea."],[3895,4133,"$500,000?"],[4133,4229,"After everything"],[4229,4412,"I've been through with Adam."],[4412,4713,"The fights, the tears, the hookups."],[4763,4884,"Can I really turn down"],[4884,5034,"that kind of money?"],[5034,5326,"Hayley, drown out the noise."],[5326,5409,"The money is just"],[5409,5555,"another temptation."],[5814,5901,"You're right, Adam."],[5943,6126,"I choose you."],[6126,6281,"It's always been you."],[7540,7720,"Let's get out of here."],[8842,9000,"We've had a wet and wild ride"],[9000,9200,"this season on Seduction Cove."],[9200,9471,"Now it's time for the reunion show."],[9471,9576,"And our former contestant"],[9576,9813,"Adam has a bombshell secret"],[9813,10005,"he'd like to share live."],[10005,10226,"Adam, welcome to the show."],[10756,10881,"Easy, you two."],[10881,11069,"So, what would you like to tell us,"],[11069,11156,"Adam?"],[11156,11290,"I don't want Hayley to"],[11290,11369,"be my girlfriend anymore."]],"67":[[16,154,"Let me get this straight."],[154,291,"You came on the show"],[291,462,"just to tell us that you don't want"],[462,650,"Hayley to be your girlfriend anymore?"],[650,804,"Yeah."],[804,1009,"I can't be Hayley's boyfriend anymore."],[1009,1209,"Well, we're gonna certainly unpack that."],[1209,1301,"But first,"],[1301,1509,"let's bring Hayley on to the show."],[1509,1810,"Come on in, Hayley."],[2306,2377,"Wow."],[2377,2606,"You two look so cute together."],[2773,2986,"How are things going with you and Adam?"],[2986,3090,"Things are going great."],[3090,3386,"We moved in and we never fight."],[3386,3545,"Except for the remote."],[3586,3787,"Adam, are you ready to tell Hayley"],[3787,3945,"your big secret?"],[4095,4212,"Yeah."],[4212,4333,"Hayley,"],[4404,4562,"I don't want you to be"],[4562,4729,"my girlfriend anymore."],[4971,5117,"What are you doing?"],[5117,5213,"Did you bring me back"],[5213,5363,"just to dump me in front of everyone?"],[5659,5860,"Talk about trouble in paradise."],[5860,6022,"I'm back,"],[6022,6235,"bitches."],[6844,7023,"Adam, honey,"],[7023,7152,"don't you want to tell her?"]],"68":[[16,196,"Lila, are you pregnant?"],[196,400,"Duh. Adam would know."],[400,529,"Is this why you're dumping me?"],[529,684,"Because you knocked up your ex?"],[684,763,"I haven't seen her since"],[763,909,"we got off the island."],[909,1084,"I don't know what's going on here."],[1084,1276,"Adam, don't deny our child"],[1276,1451,"in front of the world."],[1701,1830,"That baby is mine!"],[1843,1981,"Ew, like I would let some"],[1981,2089,"game show host"],[2089,2210,"knock me up."],[2306,2464,"Yeah, you did."],[2535,2635,"If the baby isn't yours,"],[2635,2815,"then why are you dumping me?"],[3182,3332,"I'm not dumping you."],[3370,3445,"I told you,"],[3445,3628,"I don't want you to be my girlfriend..."],[3745,3883,"because I want you to be my wife."]],"69":[[154,358,"You're proposing to me?"],[617,767,"I am, I told you,"],[767,842,"I want to be with you"],[842,1059,"alone away from the cameras"],[1059,1230,"and..."],[1230,1393,"crazy exes."],[1539,1722,"I love you, Hayley."],[1793,1922,"And I want to marry you."],[2631,2740,"Right now."],[2961,3103,"You want to marry me here?"],[3290,3395,"Right now."],[3586,3678,"I've waited too long"],[3678,3741,"to be with you"],[3741,3887,"and I can't wait any longer."],[4008,4095,"Maybe it's stupid."],[4095,4254,"Maybe it's love. Maybe it's crazy."],[4254,4295,"But..."],[4295,4433,"Yes."],[5363,5492,"Let's get married."],[5663,5818,"Well, in a Seduction Cove"],[5818,6072,"first, I'm here to officiate the wedding"],[6072,6231,"right here on the island."],[6231,6314,"Adam,"],[6314,6473,"you may make your vows"],[6473,6664,"to your blushing bride."],[6715,6965,"Hayley."],[6965,7069,"I vow to be with you"],[7069,7340,"through all the ups and downs."],[7340,7432,"You don't have to worry about me"],[7432,7503,"with temptation."],[7503,7620,"Because"],[7724,7874,"all I want is you."],[7987,8103,"Adam,"],[8103,8387,"I vow to love you through all the lies,"],[8387,8554,"all the drama,"],[8554,8712,"and never fall into temptation."],[8854,9013,"I love you, Adam."],[9134,9255,"Adam,"],[9255,9355,"you may kiss your bride."]]}