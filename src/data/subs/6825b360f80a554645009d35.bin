ou saying that"],[6902,6986,"you and that woman,"],[6986,7090,"that was just an act?"]],"35":[[54,204,"Vincent, are you telling me"],[208,266,"that you never"],[266,417,"actually cheated on me?"],[596,709,"Why?"],[713,846,"Why would you lie about that?"],[850,1013,"Why would you do that to me?"],[1238,1393,"Return to me"],[1468,1618,"before dawn"],[1651,1839,"and never"],[1839,1893,"see that"],[1897,2047,"woman again."],[2118,2252,"Or I’ll turn her..."],[2339,2515,"into a corpse."],[2890,2927,"Hey!"],[2932,2961,"Hey!"],[2965,3053,"Did something happen"],[3053,3169,"that day?"],[3174,3253,"Is that..."],[3411,3495,"It did."],[3553,3636,"Didn’t it?"],[3870,3916,"Is that why"],[3916,4066,"you're..."],[4204,4354,"different..."],[4396,4450,"than everyone"],[4450,4537,"else?"],[4800,4879,"Answer me!"],[4884,4971,"Okay?"],[4975,5096,"I deserve an explanation."],[5096,5167,"After all these years,"],[5167,5313,"don't you think?"],[5459,5609,"What good would telling the truth do?"],[5643,5793,"Nothing would change."],[5826,5951,"If anything, it would make her"],[5951,6101,"feel even worse."],[6289,6393,"I'm sorry,"],[6398,6481,"Ella."],[6723,6848,"But the less you know,"],[6848,6923,"the safer"],[6923,7019,"you're going to be."],[7023,7152,"That’s bullshit."],[7157,7269,"Plus, you haven't told me"],[7269,7419,"who Jimmy's father is."],[7557,7628,"I think it's just better"],[7628,7716,"if we keep our secrets"],[7716,7799,"to ourselves."],[8045,8112,"Let’s go home."],[8508,8529,"You're"],[8529,8596,"a spineless"],[8596,8650,"coward!"],[8650,8712,"You know that?"],[8858,8925,"I'm going to find"],[8925,8992,"out the truth!"],[8992,9075,"I’m..."],[9317,9467,"Sorry, cupcake."],[9513,9592,"It's a shame that you have"],[9592,9626,"to spend"],[9626,9776,"your final moments alone."],[9889,9976,"But your man’s father"],[9976,10014,"wants you"],[10014,10105,"dead."]],"36":[[446,571,"Ella!"],[1055,1188,"You can go to hell."],[2752,2797,"Vincent."],[2877,2948,"How did..."],[3061,3178,"Human