{"1":[[1280,1409,"Oh my God."],[1409,1614,"Is that the Vincent Price?"],[1651,1814,"He's like Pi Kappa Alpha legend."],[1910,2022,"What's he doing back on campus?"],[2022,2097,"I thought he graduated,"],[2097,2177,"like, last year."],[3132,3328,"Vincent says he has something special planned."],[3328,3424,"I wonder what it is."],[3486,3578,"Oh, my God, Tina."],[3578,3782,"You should totally go give him your number."],[3824,3949,"Oh my god you think so?"],[3970,4062,"Do I look hot today?"],[4091,4145,"Oh yeah."],[4629,4708,"Oh, my God."],[4708,4788,"He’s coming this way."],[5584,5663,"What?"],[6815,6881,"What?"],[6956,7011,"Oh."],[7236,7349,"Hello, Princess."],[7386,7428,"Hi."],[8066,8216,"We're here."],[8270,8420,"I made you a nail appointment."],[8462,8600,"Well, well, well."],[8604,8896,"Something is very fishy today."],[8933,9050,"Tell me to dress up."],[9054,9092,"Now, you made me"],[9092,9242,"a nail appointment."],[9317,9467,"What’s going on mister?"],[9476,9542,"That's a secret"],[9542,9693,"I'm never going to tell."],[9788,9893,"I’ll pick you up in an hour,"],[9893,9976,"all right?"],[9980,10047,"Nail appointment"],[10047,10197,"can only mean one thing."],[10256,10406,"He's going to propose."],[11361,11436,"Fine,"],[11436,11582,"keep your little secret."],[11582,11724,"Love you."],[11728,11878,"Love you."],[14343,14493,"What are you doing here?"],[14506,14614,"Have the humans taught you"],[14614,14764,"no manners?"],[14785,14935,"It's been a long time."],[15081,15198,"My son."]],"2":[[379,450,"I thought he said"],[450,579,"he'd be in an hour, but,"],[1067,1205,"Your call has been forwarded"],[1205,1434,"to an automatic voice message system."],[1434,1518,"Zero, one..."],[1826,1943,"That's hilarious."],[2056,2143,"Babe."],[2206,2360,"You have to call me next time, okay?"],[2360,2485,"I was worried."],[2494,2556,"Hey."],[4604,4729,"Vincent, what's going on?"],[4729,4775,"Is this..."],[5242,5363,"Is this some sort of joke?"],[5363,5463,"I don't like this game."],[5463,5563,"What's going on?"],[5776,5951,"So this is the clingy girlfriend"],[5951,6056,"you mentioned?"],[6085,6189,"She does look"],[6231,6339,"desperate."],[6560,6685,"Clingy girlfriend?"],[6831,6936,"That’s what you told her?"],[7173,7307,"Vincent, we live together."],[7307,7553,"You asked me to move in."],[7553,7620,"Don't act like that's"],[7620,7757,"something that I just made up."],[7928,8024,"Just an hour ago,"],[8024,8070,"you..."],[8112,8183,"You really thought"],[8183,8304,"I was going to propose to you?"],[8525,8650,"I just love messing with you,"],[8650,8708,"that's all."],[8767,8846,"It's so funny"],[8846,8971,"to see you get your hopes up."],[9038,9125,"What?"],[9205,9309,"I already packed your shit"],[9309,9446,"and sent it to your parents’ house."],[9534,9622,"I'm bored of you."],[9788,9830,"I need you"],[9830,9943,"to move out of my apartment."],[9943,10147,"But as for us."],[10552,10573,"Well,"],[10573,10668,"if you'd like to join us"],[10668,10777,"I'd love to fuck you"],[10777,10906,"both at the same time."],[11098,11232,"I hate you."],[11461,11561,"I hate you!"],[12883,12962,"Get off!"],[13017,13121,"Now that she's gone,"],[13121,13229,"I can't wait."],[13229,13334,"I said get the fuck"],[13334,13421,"out of my house!"]],"3":[[175,262,"I'm sorry Ella,"],[266,325,"but this is the"],[325,475,"only way to keep you safe."],[1130,1263,"What the hell do you want?"],[1267,1418,"I want you,"],[1459,1530,"my son."],[1547,1626,"It's time for you"],[1626,1776,"to join me"],[1851,2002,"and rule"],[2060,2206,"the night."],[3745,3853,"Take a sip,"],[3953,4070,"my son."],[4070,4175,"You're not my father."],[4275,4425,"I've allowed you"],[4425,4792,"to live long enough amongst humans."],[4829,4950,"Time for you"],[4959,5217,"to become a fully fledged vampire."],[5242,5338,"And,"],[5338,5555,"swear your loyalty to me."],[6406,6506,"You know what I think,"],[6506,6589,"I'll do?"],[6815,6965,"Your lady friend,"],[6986,7207,"Ella Montgomery."],[7240,7390,"She looks delicious."],[7440,7549,"Don't you dare!"],[7553,7699,"Bring me the girl."],[7703,7795,"If you touch her, I'm going"],[7795,7857,"to kill you."],[7862,7970,"With what power?"],[8095,8279,"You’re a pathetic human!"],[8316,8658,"I will not allow you"],[8658,8950,"to make the same mistake I did."],[8963,9238,"And taint the Tempes bloodline"],[9263,9438,"with a hybrid bastard!"],[9526,9609,"Kill her now!"],[9609,9688,"No!"],[9688,9818,"Okay, okay, okay."],[9822,9893,"I swear."],[9897,10047,"I'll never see her again!"],[10201,10251,"I swear,"],[10251,10385,"I'll go break up with her right now."],[10385,10535,"That's better,"],[10535,10668,"junior."],[10915,11090,"Return to me"],[11123,11273,"before dawn,"],[11302,11498,"and never"],[11498,11686,"see that woman again."],[11774,11991,"Or I’ll turn her"],[11991,12208,"into a corpse."],[13355,13463,"I love you, Ella."],[13463,13588,"But from now on,"],[13588,13742,"I can only live in darkness."]],"4":[[346,550,"You’re so useless."],[575,800,"You can’t even keep a man."],[817,980,"The only good thing you ever did is land"],[980,1117,"a wealthy man like Vincent."],[1117,1313,"And now he's sick of you."],[1434,1526,"That's right."],[1526,1659,"Go beg Vincent."],[1659,1906,"Our family needs his business."],[1906,2006,"I don't think you understand."],[2006,2118,"He cheated on me."],[2118,2202,"And you want me to go back"],[2202,2344,"and beg him for forgiveness?"],[2344,2431,"Shut up!"],[2431,2585,"How dare you speak to me"],[2585,2748,"like that in my own house?"],[2773,2932,"I watched him"],[2932,3032,"with another woman"],[3032,3128,"right in front of me."],[3128,3265,"I caught him right there."],[3265,3324,"He's..."],[3395,3449,"You know what?"],[3449,3607,"He's just like you,"],[3607,3757,"a spineless cheater."],[4024,4141,"With a mouth like that."],[4175,4275,"No wonder Vincent"],[4275,4425,"doesn't want to stick around."],[4425,4642,"The only reason I sent you to that good school,"],[4642,4817,"was you can find a rich husband"],[4817,4925,"like Vincent."],[4925,5034,"If he doesn't want you back,"],[5092,5205,"I'll just marry you off"],[5205,5380,"to Charles Beaufort."],[5430,5497,"What?"],[5497,5668,"Charles Beaufort."],[5668,5855,"He is almost 50, but,"],[5889,6097,"he's a very wealthy man."],[6097,6210,"And he did say"],[6210,6393,"Ella has a pretty face."],[6427,6619,"I bet if we marry Ella to Charles,"],[6619,6773,"he’ll give us a good price."],[6802,6890,"You can't."],[6948,7098,"Take your shit upstairs."],[7144,7328,"I'm taking you to see Charles,"],[7328,7511,"first thing in the morning."],[7724,7761,"No."],[7761,7870,"No, I cannot let them"],[7870,8062,"marry me off to a disgusting creep"],[8062,8208,"like Charles Beaufort."],[8262,8400,"I have to get out of here."],[9889,9993,"Oh my God,"],[10097,10251,"my period is late."],[10368,10460,"I can't be"],[10556,10660,"pregnant."],[10735,10819,"Can I?"],[11398,11465,"Okay."],[11932,12037,"Oh, God."],[12124,12249,"I'm pregnant."],[12383,12466,"What do I do?"]],"5":[[70,162,"Boss I'm sorry."],[162,283,"I'm so sorry."],[283,500,"I didn't know."],[542,667,"It was just a mistake."],[667,759,"It was a mistake."],[759,913,"Okay? Please just stop."],[913,1013,"Please."],[1013,1138,"Oh, no."],[1138,1230,"Oh!"],[1789,1910,"Delicious."],[2014,2122,"They always taste so good"],[2122,2243,"when they're scared."],[3257,3374,"Boss, it's been eight years."],[3374,3545,"Don't you want at least try"],[3545,3682,"some human blood?"],[3682,3770,"No."],[3816,3970,"Get that shit out of my face."],[3999,4079,"Get anything useful"],[4079,4141,"from that traitor"],[4141,4316,"before you recklessly drained him?"],[4316,4425,"Not really."],[4483,4567,"From what I gather,"],[4567,4721,"he's working for another vampire."],[4721,4875,"I suspect your father."],[4892,4996,"That old fool."],[5050,5130,"He should have killed me"],[5130,5263,"when he had the chance."],[5626,5776,"Let's go have some fun tonight."],[5801,5905,"Go book me the biggest room"],[5905,6010,"at Club Hypnotic."],[6022,6097,"I want to flush out"],[6097,6231,"all of my father spies."],[6252,6302,"But boss,"],[6302,6427,"that's a human club."],[6456,6585,"Vampires are most vulnerable"],[6585,6735,"when their thirst is being tested."],[6760,6890,"Someone's bound to slip up."],[6890,6994,"Understood."],[6994,7090,"You got it, boss."],[7440,7545,"Listen up, ladies."],[7545,7761,"We have a very special group of VIPs"],[7761,7870,"coming through tonight."],[7870,7962,"And they have booked"],[7962,8112,"our most exclusive"],[8145,8337,"Blue Sapphire room."],[8375,8458,"Which means"],[8458,8571,"if you all do your job right,"],[8571,8637,"you'll be looking at"],[8637,8729,"a big, fat paycheck."],[8787,8850,"Fiona."],[8850,8975,"You're on cleanup duty tonight."],[9029,9180,"But, ma'am, I can't."],[9180,9317,"My brother's in the hospital."],[9446,9609,"I do not want to"],[9609,9768,"hear your excuses."],[9809,9997,"Especially not tonight."],[9997,10047,"In fact,"],[10047,10301,"if any of you fuck this up,"],[10301,10393,"you're fired."],[10660,10760,"Is that clear?"],[10910,10944,"You know what?"],[10944,11048,"I'll stay back tonight."],[11086,11177,"Cover for Fiona."],[11294,11407,"You see, ladies,"],[11407,11611,"you should all learn from Ella."],[11674,11866,"She always works hard."],[11866,12141,"She covers for her coworkers,"],[12141,12420,"and she stays out of trouble."],[12495,12591,"And if any of you"],[12591,12650,"little skanks"],[12650,12821,"try to hit on my VIP clients,"],[12837,12917,"try to land yourself"],[12917,13017,"a little sugar daddy,"],[13038,13329,"you will be out of my club by morning."],[14406,14451,"Thank you."],[14451,14518,"Thank you."],[14585,14627,"See you."],[14668,14739,"Got you."],[14952,15023,"It doesn't matter"],[15023,15090,"who's coming."],[15140,15281,"I just have to make"],[15281,15352,"enough money to"],[15352,15440,"put Jimmy through school."]],"6":[[0,112,"You know the group of VIPs"],[112,191,"coming later."],[296,362,"I heard they're"],[362,592,"the biggest crime syndicate in Atlanta."],[600,642,"Yeah."],[642,829,"The boss is coming to celebrate tonight."],[829,1009,"Yeah, I heard their boss moved here,"],[1009,1167,"like, five years ago from Atlanta,"],[1167,1288,"and then overnight became"],[1288,1426,"the biggest crime boss."],[1426,1572,"If I can snag him,"],[1605,1697,"I'm never having to deal with"],[1697,1805,"this shit hole again."],[1939,2139,"I'm so glad I got that boob job."],[2185,2235,"Oh my God,"],[2235,2327,"they look so amazing."],[2348,2381,"Hey,"],[2381,2489,"clean up is over in 10 minutes"],[2489,2540,"just to let you know."],[2606,2702,"Oh look,"],[2702,2823,"it's little miss perfect."],[2823,2927,"Always trying to look good"],[2927,3023,"in front of management."],[3032,3169,"Little miss perfect?"],[3232,3399,"More like a little miss slut."],[3470,3636,"Single mom with a bastard kid."],[3636,3707,"She probably doesn't"],[3707,3858,"even know who the baby daddy is."],[3949,4124,"What the fuck, you bitch!"],[4149,4233,"Gross!"],[4241,4416,"Call my son a bastard again,"],[4454,4608,"It's not just going to be a dirty rag"],[4608,4742,"hitting you in the face next time."],[4742,4779,"Got it?"],[5284,5351,"I'm going to teach that"],[5351,5480,"fucking bitch a lesson."],[7649,7753,"Mr. Price,"],[7791,7887,"it is an honor"],[7887,7982,"to have you here."],[8008,8166,"Please allow me to show you"],[8166,8216,"and your guest"],[8216,8383,"to our most exclusive room,"],[8404,8516,"the Blue Sapphire."],[9242,9334,"Oh, what the hell?"],[9334,9480,"Do you want to lose your job?"],[9480,9617,"There's something wrong with them."],[9617,9738,"Those men in there."],[9738,9868,"Their teeth..."],[9868,10010,"I think I saw fangs."],[10010,10210,"I think they're vampires!"]],"7":[[37,133,"Vampires?"],[316,425,"Girl, you want fucking drugs?"],[425,487,"I do not tolerate"],[487,571,"crackheads in my club."],[571,667,"Get the fuck out of here!"],[667,754,"You're fired."],[959,1009,"Hey."],[1071,1163,"Where’s the drinks?"],[1488,1568,"Right away sir."],[1864,1985,"You two get in there now."],[2002,2139,"Go, get in there now."],[2139,2223,"Go, please."],[2335,2448,"Hustle!"],[5701,5822,"Serves you right."],[5822,5897,"That's what you get for"],[5897,6010,"disrespecting me."],[7432,7536,"Ella?"],[7661,7770,"Vincent?"]],"8":[[412,533,"You clumsy girl!"],[596,658,"Get out of here!"],[658,804,"Don't make an eyesore of yourself."],[934,1084,"I'm... I'm sorry."],[1084,1176,"I'll get"],[1176,1309,"a cleaner in right away."],[1363,1509,"Hold on a second."],[1664,1714,"Are you,"],[1714,1805,"are you hurt?"],[1835,1910,"I'm fine."],[2035,2152,"You don’t need to concern yourself"],[2152,2193,"with me."],[2227,2289,"Ella."],[2652,2706,"Don't"],[2786,2873,"touch me!"],[3007,3069,"Why are you here"],[3069,3161,"dressed like this?"],[3411,3536,"What is that supposed to mean?"],[3611,3670,"I work here."],[3670,3778,"This is my uniform."],[3778,3841,"Okay?"],[4024,4087,"Damn."],[4145,4283,"She's kind of hot too."],[4375,4471,"What's her name?"],[4504,4642,"Her name is not important."],[4696,4850,"She's not as fun as I am."],[4929,5042,"I promise."],[5109,5134,"Yeah,"],[5134,5330,"but she's got a great ass."],[5347,5463,"Shut the fuck up!"],[5776,5880,"Sorry, boss."],[5914,6022,"She's all yours."],[6227,6302,"Wow."],[6418,6498,"So this is the kind"],[6498,6589,"of man you've become."]],"9":[[0,112,"Hanging out with thugs,"],[112,196,"making your money off"],[196,287,"of other people's misery."],[287,350,"That's great."],[450,496,"Yeah?"],[496,533,"Don't."],[629,746,"And what about you?"],[746,813,"What?"],[863,913,"Why the hell are you"],[913,988,"dressed like this?"],[988,1034,"What are you doing"],[1034,1197,"working at a place like this?"],[1197,1276,"I thought you were going to"],[1276,1393,"go to the med school."],[1393,1509,"And what?"],[1509,1685,"The doctor path is too long for you."],[1685,1822,"I should just make a couple bucks off"],[1822,1906,"your good looks instead."],[2377,2435,"Yeah."],[2540,2610,"I'm a hoe,"],[2610,2706,"desperate for money."],[2706,2781,"Is that what you want to hear?"],[2781,2965,"You happy, now?"],[5246,5342,"Mommy!"],[5526,5693,"You have no idea"],[5693,5809,"what I have been through."],[5943,5972,"Yeah,"],[5972,6114,"I may be desperate for money,"],[6114,6231,"but at least I made my money"],[6231,6348,"with good, honest work."],[6348,6481,"Unlike,"],[6560,6644,"unlike this."],[6723,6819,"If it's money you need,"],[6819,6911,"I can give you money."],[6973,7107,"Ella, I'll give you 50 grand a month"],[7107,7194,"not to work here."],[7449,7511,"No, no,"],[7511,7674,"I don't need your dirty money."],[7816,7937,"Do you have a fucking death wish?"]],"10":[[37,187,"Sit the fuck down!"],[212,271,"But, Boss—"],[271,329,"Sit down,"],[329,533,"before I rip that arm off your body."],[654,804,"I apologize, Miss."],[1080,1151,"Ella,"],[1155,1305,"this is all your fault."],[1397,1493,"You splashed champagne"],[1493,1626,"all over our VIP guest"],[1626,1814,"and soured everyone's mood."],[1814,2010,"Wait till I tell Megan about this."],[2010,2097,"You’re going to tell Meg—"],[2097,2118,"I—"],[2118,2227,"It was an accident."],[2248,2285,"Okay?"],[2289,2356,"You know that."],[2452,2590,"We’ll see what she says."],[2594,2715,"You're the one who tripped her."],[2777,2831,"Jake."],[2919,2961,"Take her out"],[2961,3069,"and teach her a lesson."],[3078,3211,"Teach her a lesson?"],[3315,3390,"Wait!"],[3516,3561,"What does—"],[3599,3712,"Wait! No, let go of me!"],[3716,3787,"Wait! Ella!"],[3787,3866,"No, I'm sorry!"],[3866,3995,"Ella, save me!"],[4229,4300,"Wait!"],[4304,4412,"Ella! No, Help me!"],[4412,4454,"Wait, wait."],[4454,4525,"Ella!"],[4529,4604,"Ella!"],[4604,4708,"Ella! No, help me!"],[4708,4767,"Save me!"],[4767,4796,"Ella!"],[4800,4867,"No!"],[4888,4950,"No!"],[4959,5096,"Ella, save me!"],[5100,5205,"She's not allowed"],[5205,5347,"to bully you like that."],[5351,5472,"No one should."],[5476,5551,"Okay?"],[5764,5955,"What are you gonna do with her?"],[6076,6222,"You really have become a criminal."],[6222,6360,"She needs to be taught a lesson."],[6360,6435,"No, no."],[6435,6552,"I don't need your pity"],[6556,6677,"or your help."],[6681,6806,"You left me"],[6810,6873,"eight years ago,"],[6873,6981,"and I've been"],[6981,7057,"completely fine on my own"],[7057,7090,"since then."],[7090,7253,"So just stay out of my life, okay?"],[7474,7632,"Don't come back here."],[7836,7949,"This is for the best."],[8062,8137,"I’ve never seen"],[8137,8212,"boss like this before."],[8291,8466,"She's obviously an old flame."],[8537,8629,"Let's go boys."],[8683,8833,"This party’s over."],[9321,9459,"Hi, baby."],[9459,9501,"Mommy,"],[9501,9726,"Why are you still not home yet?"],[9726,9876,"I'm sorry, hun."],[9943,10206,"I did a cover for Aunt Fiona today."],[10293,10352,"But don't worry."],[10352,10456,"Go back to sleep,"],[10456,10502,"okay?"],[10656,10806,"I love you."],[10927,11065,"My lord."],[11069,11252,"I found Vincent's weakness."]],"11":[[1601,1651,"Boss,"],[1655,1735,"you were right."],[1872,2022,"Can you knock next time?"],[2060,2210,"Sorry, boss."],[2227,2314,"So, what’d you find?"],[2318,2414,"Show me."],[2419,2552,"We got our mole."],[2556,2690,"Right after the event at the club,"],[2690,2840,"a message was sent out."],[2998,3144,"Our tech team intercepted it."],[3311,3457,"There’s some bad news."],[3457,3595,"Spit it out."],[3599,3674,"We traced the message"],[3674,3824,"back to your father."],[3949,4083,"That means he knows,"],[4083,4158,"about Ella."],[4220,4304,"Fuck."],[4658,4771,"Jimmy's going to love this."]],"12":[[846,971,"Jessica."],[975,1034,"Jessica. What?"],[1038,1101,"What are you doing?"],[1105,1188,"You see my face?"],[1188,1305,"You fucking bitch!"],[1372,1509,"This is your fault."],[1514,1639,"I'm scarred"],[1639,1689,"for life."],[1797,1826,"No!"],[1826,1976,"I tried to save you."],[1981,2056,"I tried to stop them."],[2056,2089,"I did."],[2089,2147,"And stop trying"],[2147,2298,"to look like the good person!"],[2348,2477,"That's why I fucking hate you!"],[2540,2585,"You think you're"],[2585,2652,"so much better"],[2652,2744,"than everyone else."],[2748,2811,"No, I don't."],[2815,2902,"I don't."],[2973,3073,"You're just some skank"],[3078,3174,"who got knocked up"],[3178,3328,"by some dude."],[3361,3445,"Now you're gonna pay"],[3445,3595,"for what you did to me."],[3628,3745,"Ella!"],[4004,4095,"No!"],[5230,5330,"Let go!"]],"13":[[2027,2177,"What are you?"],[2256,2406,"Are you..."],[2427,2577,"Are you a vampire?"],[2623,2831,"Go to sleep Ella."],[2831,3065,"Forget everything you saw."],[3278,3428,"I have to protect Ella."],[3465,3520,"I can't let her"],[3520,3636,"know the truth about me,"],[3636,3749,"about vampires."],[3949,3999,"Oh, shit."],[3999,4149,"The sun's rising."],[6902,7007,"You're awake."],[7090,7190,"How are you feeling?"],[7194,7248,"You need me to take you"],[7248,7399,"to the hospital?"],[7778,7887,"Vincent."],[7916,8049,"Aren't you going to explain"],[8049,8337,"how you just saved me from falling"],[8337,8616,"26 stories to my death?"],[8654,8746,"My vampire powers"],[8746,8837,"don’t work on her."]],"14":[[12,158,"I could’ve—"],[171,379,"sworn I saw your hair turn white."],[417,567,"And you had—"],[704,913,"And you had vampire fangs."],[1080,1276,"Did I imagine that?"],[1322,1355,"I don’t know."],[1355,1451,"I’m foggy."],[1451,1555,"I don't—"],[1584,1647,"Ella."],[1689,1768,"You were just passed out"],[1768,1839,"on the roof."],[1881,1997,"I carried you down the stairs."],[1997,2118,"That’s all that happened."],[2122,2277,"And I had those two girls arrested."],[2277,2452,"That tried to kidnap you."],[2527,2598,"Really?"],[2602,2681,"Because—"],[2681,2748,"Ella."],[2752,2886,"I think you just had a bad dream"],[2886,2961,"when you were passed out."],[2961,3044,"Okay?"],[3073,3144,"Look."],[3249,3307,"I’m just happy"],[3307,3457,"you're alright now."],[3762,3858,"Thank you,"],[3858,4024,"Mr. Price for saving me."],[4083,4133,"But you don't"],[4133,4229,"have to pretend like you care."],[4229,4254,"Okay?"],[4254,4558,"You very obviously don't."],[4575,4667,"What were you doing there,"],[4667,4754,"anyway?"],[4813,4942,"I came to find you."],[4946,5171,"Your life is in danger, Ella."],[5205,5296,"After that little stunt"],[5296,5380,"you pulled at the club,"],[5380,5488,"there's some dangerous people"],[5488,5626,"after you, now."],[5663,5730,"I think it's best"],[5730,5822,"if you live with me now"],[5822,5955,"and live under my protection."],[5955,6131,"Wow, excuse me?"],[6164,6373,"Live under your protection?"],[6606,6694,"Now, who the hell"],[6694,6844,"do you think you are?"],[6869,6981,"I don't—"],[6981,7002,"No."],[7002,7077,"I don't have time for this."],[7077,7190,"I’m leaving."],[7862,7966,"Ella."],[8020,8070,"Ella."],[8074,8170,"You don't understand."],[8170,8224,"I'm doing this"],[8224,8358,"for your own good."],[8362,8512,"For my own good?"],[8608,8817,"Was dumping me for my own good?"],[8817,8892,"I mean, God,"],[8892,8992,"Vincent, you can't just"],[8992,9100,"waltz back into my life"],[9100,9171,"and expect everything"],[9171,9246,"to be normal."],[9246,9317,"Like—"],[9321,9471,"Like nothing happened."],[9496,9684,"I have been completely fine"],[9688,9801,"on my own without you"],[9801,9901,"these past eight years."],[9901,9989,"So just—"],[10139,10260,"Just stay out of my life."],[10264,10285,"Okay?"],[10285,10435,"Stop following me."],[10660,10723,"Mommy!"],[10727,10835,"Mommy!"],[10839,10990,"Hi. What—"],[11019,11094,"What are you doing?"],[11098,11182,"Where's Grandma Sasha?"],[11186,11394,"Grandma Sasha’s inside asleep,"],[11394,11419,"but"],[11432,11644,"I came out here to look for you,"],[11644,11782,"Mommy."],[11874,12024,"Mommy?"],[12112,12191,"Ella?"],[12195,12345,"You have a son?"],[12608,12758,"Daddy?"],[12917,13021,"You're my daddy!"]],"15":[[50,187,"Oh!"],[483,583,"He's my daddy, right?"],[583,671,"There's a photo of you"],[6