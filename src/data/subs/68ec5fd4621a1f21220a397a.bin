{"1":[[984,1030,"Brie,"],[1030,1180,"take this to Young Master Langford,"],[1180,1297,"and then go get changed"],[1297,1409,"into your school uniform."],[1430,1514,"Remember,"],[1514,1676,"Madame Langford paid for you"],[1676,1843,"to go to the same school as her son."],[1901,2014,"So study hard,"],[2043,2152,"and prove you're worth it."],[2181,2252,"I will, Mom."],[2406,2444,"And,"],[2548,2727,"don't ever get any ideas about him."],[2777,2927,"Just look at the Miller family,"],[2969,3061,"and what happened with that"],[3061,3178,"maid's daughter, Lola."],[3240,3370,"You don't want to end up like Lola,"],[3370,3420,"do you?"],[3887,3958,"That's right."],[4012,4149,"I'm the head maid's daughter,"],[4183,4266,"Brie Ellison."],[4337,4400,"My mom and I"],[4400,4546,"work for the Langford house,"],[4587,4713,"the most powerful family"],[4713,4829,"on the West Coast."],[6131,6252,"That's Teddy Langford."],[6335,6485,"Everyone from the football team"],[6485,6598,"calls him Iceman."],[6702,6869,"He's every girl's dream guy."],[7057,7178,"I've had a crush on Teddy"],[7178,7282,"since I was a kid,"],[7315,7419,"when we first met."],[7507,7724,"Madam, this is my daughter, Brie."],[7770,7962,"Brie, like my favorite cheese?"],[8024,8095,"That's right."],[8137,8266,"Then she's my favorite, too."],[8295,8395,"We should get married!"],[8412,8550,"Oh, no, no, sir."],[8554,8612,"You can't."],[8612,8733,"We're your servants."],[8775,8917,"You don't marry the help."],[9075,9184,"But what if I want to?"],[9376,9538,"But that's a secret I'll never tell."],[10201,10347,"I don't belong in his world."],[10418,10581,"No matter how much I like him."],[11144,11261,"You kiss me awake?"],[11432,11473,"No..."],[11524,11578,"No..."],[11628,11669,"Oh."],[11820,11978,"Sorry, I'll pick it up."],[12499,12570,"Do you like the view?"]],"2":[[16,204,"Sorry, that, that was an accident."],[375,471,"It's okay, Brie."],[483,621,"I've known you like ten years."],[654,784,"You can look at me however you like."],[988,1096,"Why does he have to be"],[1096,1288,"so damn attractive?"],[1351,1522,"And he obviously knows it, too."],[1601,1718,"Snap out of it, Brie."],[1780,1939,"He's something you can never have."],[2907,2977,"You can't tell me"],[2977,3103,"that wasn't on purpose."],[3282,3386,"No, no."],[3411,3503,"I mean,"],[3524,3682,"yes, it wasn't"],[3682,3845,"on purpose."],[3903,4016,"I didn't mean to"],[4095,4241,"fall on you like that."],[4596,4662,"Stop"],[4717,4850,"fooling around, Teddy."],[4892,4979,"It's the first day of school."],[4979,5084,"We can't be late."],[5155,5217,"Brie, why do you keep"],[5217,5309,"running away from me?"],[5363,5451,"You know why."],[5647,5772,"I'm just a maid's daughter."],[5976,6035,"Okay."],[6076,6122,"Well,"],[6156,6260,"I'm gonna go take a shower."],[6339,6393,"Um,"],[6418,6523,"could you bring me my underwear?"],[6602,6648,"What, what?"],[6648,6773,"Your, your underwear?"],[6785,6986,"Well, I mean, since you're just a maid,"],[7036,7140,"it's kind of your job, isn't it?"],[7490,7553,"A maid."],[7657,7711,"Right."],[7811,7920,"That's all I am."],[8646,8737,"Where's my boxers?"],[9063,9238,"Teddy, why, why are you naked?"],[9330,9417,"You want help me to put them on?"],[9501,9551,"No!"],[9563,9693,"That, that's gross."],[9693,9793,"Do it yourself."],[10402,10477,"Yo, get in."],[10581,10698,"I can walk to the bus stop."],[10785,10898,"We can do this the easy way,"],[10898,11006,"or we can do this the hard way."],[11353,11423,"Hard way it is."],[12107,12237,"Hey, what, what are you doing?"],[12237,12287,"Teddy!"],[12299,12416,"Put me down!"]],"3":[[692,767,"Wow, hey."],[900,967,"What are you doing?"],[1051,1146,"I don't want anyone"],[1146,1276,"seeing me getting out of your car."],[1426,1493,"Why not?"],[2619,2719,"Teddy, remember,"],[2719,2869,"our moms don't want us to get"],[2869,2927,"too close."],[3036,3153,"And I think we should"],[3153,3303,"keep our distance at school, too."],[3328,3445,"Keep our distance?"],[3712,3787,"Okay, fine."],[3816,3912,"If that's what you want."],[4191,4283,"I got practice."],[4291,4337,"So,"],[4416,4525,"take those to class for me."],[4558,4621,"Okay."],[5434,5505,"Oh, Mandy,"],[5505,5626,"it's all the same contestants"],[5626,5722,"as last year."],[5722,5935,"You've got first place on lock, for sure."],[5947,6035,"Obviously."],[6068,6151,"And this year I'm even"],[6151,6293,"accompanying myself on piano."],[6322,6489,"Threepeat, here I come."],[6610,6744,"Teddy's got three back-to-back"],[6744,6894,"football championships, too."],[6931,6998,"Me and him?"],[7036,7152,"That's destiny."],[7240,7286,"Wait,"],[7303,7624,"who's this Brie Ellison on the list?"],[7678,7741,"Never heard of her."],[7741,7811,"She must be new."],[7895,7987,"Yeah, she must be new."],[8145,8366,"Brie, like the cheese."],[8391,8491,"Yeah. - Ew."],[8491,8558,"Gross."],[9196,9263,"Ow."]],"4":[[446,575,"Teddy kept a picture of us"],[575,667,"in his textbook?"],[734,842,"Why would he do that?"],[1868,1956,"Oh my God, Mandy."],[1956,2143,"She has a photo of Teddy Langford"],[2143,2268,"hidden in her textbook."],[2377,2427,"What?"],[2531,2627,"They're making a heart."],[2681,2802,"This has to be photoshopped."],[2873,3023,"Oh my God, look at those shoes."],[3044,3123,"And that bag."],[3161,3311,"Total broke girl gear."],[3345,3499,"Why would Teddy ever wanna be"],[3499,3653,"with some charity case?"],[3928,3987,"Ow."],[4316,4425,"You know Teddy Langford"],[4425,4567,"is my man, right?"],[4621,4746,"Our families go way back."],[4934,4992,"Hello?"],[5046,5117,"Say something."],[5117,5226,"Why do you have this?"],[5355,5447,"I don't know."],[5447,5555,"I didn't even know it,"],[5555,5663,"that was there."],[5668,5722,"Liar."],[5730,5868,"I saw it fall out of your textbook."],[5868,5976,"Do you think I'm stupid?"],[6131,6293,"That, this isn't my textbook."],[6398,6443,"Uh,"],[6468,6623,"Mandy, it isn't hers."],[6623,6744,"It has Teddy's name on it."],[7040,7086,"What?"],[7086,7123,"So,"],[7152,7340,"so you stole Teddy's textbook,"],[7349,7507,"and planted a fake photo in it"],[7507,7624,"just to get his attention?"],[7678,7945,"That is next-level pathetic."],[7978,8183,"I, I didn't steal anything, okay?"],[8183,8433,"That's his textbook and his picture."],[8454,8566,"Do you really expect me"],[8566,8662,"to believe that Teddy,"],[8704,8825,"my Teddy,"],[8858,8950,"would carry around"],[8950,9092,"and hide a photo of you?"],[9129,9271,"Have you looked in a mirror?"],[9872,9930,"Mandy,"],[9997,10076,"look at the back."],[10147,10289,"Oh my God, she's Brie."],[10289,10368,"The new girl."],[10381,10585,"Not only is she coming after Teddy,"],[10606,10727,"but she's coming for your crown"],[10727,10844,"in the singing competition."],[10856,10915,"What?"]],"5":[[108,362,"So you're Brie, the new girl."],[400,579,"Well, actually that makes a lot of sense"],[579,717,"because I have ruled this school"],[717,829,"for three years."],[829,942,"And no one has ever dared"],[942,1067,"to challenge my spot."],[1092,1280,"It's just a singing competition."],[1280,1430,"Anyone can join."],[1455,1551,"Oh my God, Mandy."],[1551,1722,"She's totally disrespecting you."],[1797,1906,"I guess I just have to make sure"],[1906,2097,"she never forgets who I am."],[2193,2248,"Alisa,"],[2289,2398,"get the Reaper sauce."],[2398,2452,"On it."],[2560,2610,"What?"],[2815,2915,"What, what are you doing?"],[2977,3053,"Oh, just"],[3078,3165,"helping you warm up"],[3165,3269,"for the competition."],[3365,3532,"Since you wanna go against me so badly,"],[3532,3699,"this little bottle is just for you."],[3720,3878,"You can kiss your voice goodbye."],[3962,4041,"Let's see you try to sing"],[4041,4133,"with a scorched throat."],[4371,4416,"Stop."],[4421,4458,"Stop."],[4458,4575,"You can't do this."],[4846,4971,"This will teach you a lesson."],[6014,6122,"Get your hands off her!"],[7319,7390,"Brie, are you okay?"]],"6":[[79,137,"Teddy."],[187,250,"My nose,"],[250,354,"my nose is bleeding."],[383,508,"What