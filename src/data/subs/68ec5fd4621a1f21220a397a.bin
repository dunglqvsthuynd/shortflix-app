443,6569,"you've been chasing boys"],[6569,6673,"instead of studying,"],[6710,6861,"I'll cut you off immediately."],[6919,7044,"You'll have to leave school."],[7094,7378,"I will not waste support"],[7403,7611,"on a girl who doesn't respect herself."],[7691,7782,"Is that clear?"],[8033,8112,"Yes, ma'am."]],"61":[[387,450,"Hello?"],[663,796,"Oh, that's unfortunate."],[796,892,"I'll let her know."],[1251,1330,"What is it?"],[1368,1626,"The tailor says his car broke down."],[1693,1826,"He might not make it tonight."],[1885,1935,"What?"],[1935,2085,"I asked Brie to come down"],[2085,2147,"so the tailor could"],[2147,2252,"take her measurements."],[2306,2485,"Madam, are you having a dress"],[2485,2565,"made for Brie?"],[2752,2811,"Yes."],[2811,2877,"I was thinking of"],[2877,3157,"getting her a custom-made dress."],[3157,3274,"Since she's an adult,"],[3274,3478,"I figured that a formal dress"],[3478,3707,"would come in handy for school events."],[3728,3866,"Do you know Brie's measurements?"],[3962,4141,"Um, she's still growing,"],[4141,4379,"so her sizes could change at any time."],[4379,4579,"32B, 26, 33."],[4817,4975,"Teddy, how do you know that?"],[5513,5655,"I remember from last time I measured her."],[5676,5755,"Last time?"],[5797,5876,"When was that?"],[5918,6051,"Why don't I know about that?"],[6085,6264,"Did you take Brie to get measured"],[6264,6348,"without telling me?"]],"62":[[212,262,"Yeah."],[279,583,"It was her 18th birthday, I think."],[642,692,"You said something"],[692,784,"about getting her a gown,"],[784,946,"so I just took her myself."],[1088,1167,"That was the day"],[1167,1288,"I said I couldn't make it."],[1305,1505,"So in the end, I never went."],[1526,1839,"Well, if that's so, then which shop?"],[1947,2135,"I didn't really pay attention."],[2168,2235,"I think it was"],[2235,2335,"whatever was closest."],[2419,2635,"You know, I'm not too picky on my tailors."],[2744,2919,"Well, then Brie would remember."],[2919,3015,"Which shop was it?"],[3048,3228,"I have no idea which shop it was."],[3516,3682,"We were actually in a rush"],[3682,3795,"to get to school,"],[3849,4066,"so I didn't catch the name."],[4141,4320,"Well, there's only a handful of tailors"],[4320,4408,"in which we use,"],[4408,4596,"so if you really don't remember,"],[4596,4717,"then I'll just call around"],[4717,4863,"until one confirms it."],[4884,5075,"Harper, call them and ask"],[5075,5234,"who took Brie's measurements."],[5255,5342,"No, wait."],[5342,5455,"I remember."],[5476,5626,"Oh, you remember which shop?"],[5739,5960,"No, uh, who took the measurements."],[5989,6110,"What are you talking about?"]],"63":[[25,237,"Well, we did go to a shop,"],[262,671,"but then Brie had to go back to school"],[671,950,"to order her uniform."],[984,1192,"And actually, one of our classmates"],[1192,1284,"took her measurements"],[1284,1347,"on the spot."],[1384,1626,"So you're saying that Brie's classmate"],[1626,1760,"gave you her measurements?"],[1889,1964,"Yes."],[2039,2102,"You know me,"],[2102,2214,"I, I got that"],[2214,2356,"quarterback memory."],[2431,2652,"Madam, should I still make the calls?"],[2673,2819,"No, hold off for now."],[2819,2902,"Yes, ma'am."],[2936,3040,"Yeah, if you could just"],[3040,3286,"tell the, you know, tailor"],[3286,3349,"her measurements"],[3349,3432,"and get started on the gown,"],[3432,3541,"that would be great."],[3678,3766,"Yes, master."],[4992,5105,"After your father passed,"],[5105,5213,"it was..."],[5213,5430,"it was Mrs. Langford who took us in."],[5476,5618,"She gave us a safe home,"],[5618,5772,"she paid for your education."],[5793,5926,"You can't forget her kindness."],[5960,6031,"I won't."],[6160,6302,"She personally had this dress"],[6302,6381,"made for you."],[6381,6443,"Try it."],[6564,6673,"Call me when you're ready."],[6710,6769,"Okay."]],"64":[[45,137,"What are you doing in here?"],[137,237,"My mom's outside."],[237,333,"She went upstairs."],[412,487,"What?"],[508,613,"Yeah, but she could"],[613,704,"come down any minute."],[800,913,"Stop squirming."],[913,975,"The more you squirm,"],[975,1063,"the more it sticks."],[1405,1451,"Okay."],[1497,1543,"Okay."],[1601,1689,"You can go now."],[1718,1797,"Stop moving."],[1901,2056,"Just let me hold you for a second."],[2097,2235,"You haven't kissed me in forever."],[3440,3495,"No."],[3691,3774,"Not here."],[3870,3949,"Oh, come on."],[3949,4049,"You never miss me?"],[4170,4300,"Tell me the truth, don't lie to me."],[4562,4825,"It's, it's not that I haven't."],[4825,4913,"I just..."],[4942,5055,"How much have you missed me?"],[5292,5422,"I missed you a lot."],[5551,5647,"Scale from one to ten?"],[5822,5901,"Twelve."],[6856,6973,"Wait, wait."],[7044,7140,"I got something for you."],[7161,7223,"What?"],[7269,7332,"What?"],[7349,7399,"What?"],[7424,7494,"What is that?"],[7707,7761,"A gift."],[7957,8074,"But, but..."],[8158,8270,"You know, you could just say thank you."],[9417,9476,"Brie."],[9784,9901,"Just say thank you."]],"65":[[50,162,"Just say thank you."],[2940,3003,"Brie?"],[3003,3078,"Did Harper help you"],[3078,3194,"switch out your dress yet?"]],"66":[[0,87,"Open the door!"],[87,216,"I want to see if it fits."],[329,412,"Go! Go!"],[1001,1076,"Madame."],[1159,1305,"Why did it take so long to answer?"],[1368,1455,"Who's in here?"],[1572,1755,"No, no, no one's in here."],[1864,1993,"It's just, just me."],[2035,2097,"Okay."],[2097,2177,"Well, turn around."],[2177,2243,"Let me see it."],[2715,2932,"That actually looks pretty good."],[2944,3073,"A touch of elegance."],[3107,3253,"If I didn't know any better,"],[3253,3336,"I'd think you were"],[3336,3536,"a real high society debutante."],[4124,4212,"What is that?"]],"67":[[125,287,"This diamond bracelet."],[337,450,"Where did you get this?"],[454,579,"Pavé setting,"],[579,688,"limited edition."],[729,967,"Costs at least 25 grand."],[1046,1184,"Who gave this to you?"],[1234,1459,"Ma'am, you must be mistaken."],[1539,1634,"Are you saying that"],[1634,1768,"I don't know what I'm looking at?"],[1789,1889,"Tell me the truth."],[1931,2072,"Did a man give this to you?"],[2118,2193,"Who is it?"],[2414,2823,"No, it wasn't any of my classmates."],[2823,2977,"I don't have a boyfriend."],[2998,3165,"Of course none of your classmates"],[3165,3290,"would be able to afford that."],[3290,3403,"Who is it?"],[3595,3803,"Brie, I have known you"],[3803,3916,"since you were a kid."],[3916,4112,"And you have never held anything"],[4112,4204,"from me before."],[4233,4500,"But this sort of thing"],[4596,4742,"could cause a person to wonder."],[4888,5084,"Ma'am, what's going on?"],[5105,5296,"Oh, Harper, perfect timing."],[5351,5563,"Ask your daughter who she's dating."],[5634,5805,"Brie, who gave you that bracelet?"],[5897,6018,"Tell Mrs. Langford."],[6131,6227,"Mom, it..."],[6339,6435,"Go get Teddy."],[6456,6631,"Ma'am, this has nothing to do"],[6631,6702,"with Teddy."],[6806,6919,"He wasn't in his room."],[6936,7027,"Give me the phone."]],"68":[[212,346,"Mom, did you hear my phone ringing?"],[546,667,"Oh, there it is!."],[846,996,"Why is your phone in here?"],[996,1130,"Oh, I was studying earlier."],[1130,1213,"I must have left it."],[1338,1426,"What's going on?"],[1672,1764,"She won't tell me"],[1764,1889,"who gave her this bracelet."],[1960,2093,"I mean, Mom, she's in high school."],[2093,2177,"It's not that weird for someone"],[2177,2273,"to give her a gift."],[2452,2569,"Your classmates"],[2569,2723,"cannot afford this, okay?"],[2723,2940,"I am worried that she's gotten involved"],[2940,3065,"with someone who is older,"],[3103,3240,"wealthy and powerful."],[3286,3353,"Older?"],[3353,3424,"Yes."],[3457,3541,"Someone who's throwing"],[3541,3682,"this kind of money around."],[3716,3824,"It's not younger."],[3887,4016,"And I think that they may be"],[4016,4195,"using her for her looks."],[4270,4346,"Using her?"],[4400,4675,"Ugh, Teddy, this is serious."],[4733,4871,"Brie is still in high school."],[4871,4938,"I told her"],[4938,5109,"that I didn't want her dating anyone"],[5109,5180,"because I don't want her"],[5180,5305,"to be distracted by something"],[5305,5417,"that isn't going anywhere."],[5459,5543,"And now..."],[5634,5701,"Mom..."],[5889,6114,"I know that you think I'm overreacting."],[6139,6285,"One wrong turn with love"],[6285,6594,"and this could mess up her whole future."],[6727,6890,"You need to talk some sense into her."],[6998,7140,"Okay, fine."],[7140,7228,"Uh, step out"],[7228,7328,"and I'll have a word with her."],[8395,8541,"What's it gonna take to convince you?"]],"69":[[91,216,"I think we should just tell Mom."],[346,496,"If we're gonna be together,"],[521,629,"I feel like she should know."],[700,775,"Maybe."],[913,1030,"But in a little."],[1201,1338,"I think we should just give us"],[1338,1438,"a little bit more time."],[1826,1901,"Okay."],[2035,2152,"She's gonna come back any second."],[3449,3578,"Whoa, hey, what are you doing?"],[3616,3703,"I gave this to you."],[3703,3803,"You're going to keep it."],[3933,4024,"It's yours now."],[4133,4191,"Keep it."],[4842,5092,"Brie, did Teddy talk to you yesterday?"],[5163,5246,"How did it go?"],[5359,5422,"Uh..."],[5472,5530,"Madam,"],[5622,5860,"with Teddy there, I'm sure Brie listened."],[5935,5993,"Oh,"],[6035,6172,"they've gotten quite close, haven't they?"],[6268,6348,"All right, Mom."],[6348,6460,"I'm taking her to school."],[6489,6589,"I'll keep an eye on her."],[6589,6648,"Good."],[6681,6785,"And see if you can figure out"],[6785,6902,"who's been bothering her."],[6915,7115,"Brie, I'm giving you one week"],[7115,7273,"to cut things off with that guy,"],[7273,7407,"or I'll cut things off with you."],[7428,7515,"Yes, ma'am."],[7599,7665,"Okay."],[7665,7745,"Let's go."],[8087,8375,"Is Teddy getting too close to Brie?"]],"70":[[392,608,"Seriously, don't worry about the bracelet."],[608,709,"I'll give my mom an answer"],[709,821,"in, like, a few weeks."],[971,1188,"Just, I need you to be brave with me, too."],[1188,1255,"Okay?"],[2122,2281,"I just venmoed you 3000$."],[2281,2444,"Send me the photos now."],[2819,2919,"It's over, Brie."],[2994,3165,"I should have done this a long time ago."],[3566,3632,"Mrs. Langford,"],[3632,3770,"you left your phone upstairs."],[4304,4462,"Did you know Teddy's secretly"],[4462,4600,"dating someone at school?"],[4854,4921,"Teddy!"],[4954,5080,"Explain this!"]],"71":[[200,271,"Mom."],[271,337,"Oh my..."],[930,1051,"Mom, there's nothing to explain."],[1134,1255,"I'm in love with Brie,"],[1255,1317,"and nothing you say"],[1317,1388,"is going to change that."],[1559,1639,"Oh my..."],[1839,1981,"How dare you!"],[2077,2298,"Sneaking around behind my back,"],[2298,2423,"thinking you're clever?"],[2444,2619,"As long as I am in this house,"],[2619,2811,"you and Brie will never be together."],[2882,3065,"Mom, who I'm with is my choice,"],[3136,3236,"not yours."],[3440,3536,"No, no, no, ma'am."],[3570,3628,"Please."]],"72":[[8,112,"Don't hit him again."],[112,275,"If you're gonna hit someone,"],[275,346,"you can hit me."],[346,450,"Mom, don't touch her."],[521,617,"Whatever you got coming to me,"],[617,759,"just do it."],[884,946,"Wow."],[975,1051,"Look at you two."],[1051,1263,"You think you're Romeo and Juliet,"],[1263,1409,"and I'm the evil villain?"],[1409,1568,"Why can't you just let us be together?"],[1568,1718,"I truly love Brie."],[1743,1885,"One day, she's going to be my wife."],[2014,2185,"You're 18!"],[2227,2452,"You don't know the first thing about love."],[2489,2615,"I've said it before,"],[2615,2769,"and I will say it again."],[2769,3044,"You do not marry the help's daughter."],[3053,3203,"You marry someone you're equal,"],[3203,3353,"someone from your pedigree."],[3374,3566,"You think life is a fairy tale?"],[3607,3832,"Marriage is not playing house."],[3832,4066,"It is a contract between families,"],[4066,4287,"and hers will never measure up."],[4350,4650,"It is a match doomed to fail."],[4779,4884,"From now on,"],[4942,5092,"you will go to a different school."],[5134,5276,"You will get out of my house,"],[5313,5530,"and you will stay away from my son."],[5659,5797,"Mom, I swear to God,"],[5797,5889,"if you make her leave,"],[5889,5976,"then I'm gone too."],[6502,6619,"Mrs. Langford,"],[6810,6898,"it's fine."],[7052,7119,"I'll go."]],"73":[[25,100,"Really?"],[137,225,"Just like that?"],[287,358,"Yes, ma'am."],[588,721,"I will go, but..."],[938,1026,"I will never"],[1084,1172,"leave your son."],[1238,1351,"What's that supposed to mean?"],[1455,1768,"I appreciate everything"],[1805,1918,"you've done for me."],[1960,2218,"You put a roof over my head."],[2281,2435,"And you let me and Teddy"],[2435,2523,"go to school together."],[2523,2748,"And I appreciate everything."],[2756,3132,"But my appreciation for you"],[3161,3345,"is what's making me scared"],[3399,3595,"to face my feelings for Teddy."],[3595,3674,"I don't wanna"],[3674,3799,"let that happen anymore."],[3870,3983,"Teddy once told me"],[3983,4187,"that there's three things in life"],[4187,4300,"that he loves the most."],[4429,4875,"Family, football, and me."],[4954,5184,"He said he'd be willing to let go"],[5184,5334,"the first two for me."],[5380,5663,"How could I let a man"],[5663,5834,"that loves me this much"],[5834,5972,"fight by himself?"],[6151,6306,"I have to be brave too."],[6410,6531,"Look, I will"],[6619,6760,"put myself through college."],[6760,6906,"I will work so hard"],[6906,7040,"like my life depends on it."],[7040,7203,"I will do everything I can."],[7365,7478,"Because I want, I just"],[7478,7570,"want to be with him."],[7570,7707,"And I want to be worthy of him."],[7791,7928,"One way or another."],[8254,8337,"And I'm going too."],[8621,8679,"Wait."],[8988,9192,"You two finish out high school together."],[9230,9384,"And we'll talk about"],[9384,9484,"the rest after college."],[9592,9647,"Wait."],[9705,9784,"Mom, really?"],[9880,10010,"Are you giving us your blessing?"],[10030,10143,"It's not even close."],[10235,10485,"But I'm willing to give you two a chance."],[10581,10798,"Prove to me that your love can endure."]]}