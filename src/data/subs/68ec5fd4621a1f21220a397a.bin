ou."],[8529,8758,"Why does it feel so good kissing him?"],[9104,9184,"Why are you,"],[9275,9401,"kissing me like that?"],[9588,9751,"We shouldn't be doing this."],[9959,10064,"Isn't that obvious,"],[10093,10172,"Brie Ellison?"],[10460,10602,"I like you."],[11140,11257,"I want you to be my girlfriend."]],"8":[[58,237,"I want you to be my girlfriend."],[1993,2181,"Don't ever get any ideas about him."],[2202,2369,"You know he's off limits."],[2823,2869,"No."],[3073,3136,"I can't."],[3265,3386,"I'm not gonna be your girlfriend."],[3499,3561,"Why not?"],[3916,3978,"Because..."],[4041,4133,"Stop moving."],[4308,4454,"What is that?"],[4854,4929,"I'm hard."],[5455,5543,"Wait, no, no, no, no."],[5543,5672,"I, I can't be doing this."],[5709,5876,"Especially not with Teddy Langford."],[6031,6081,"Look."],[6101,6156,"Let's just"],[6222,6352,"forget that ever happened."],[6477,6594,"Maybe the heat just"],[6627,6748,"got to my head or something."],[7015,7132,"Brie, are you really gonna"],[7132,7257,"blame it on the hot sauce?"],[7882,8058,"That ice is making it so much better."],[8258,8408,"Okay, I'm gonna go to class."],[8425,8533,"Whoa, whoa, wait."],[8600,8700,"So what, you're gonna leave now"],[8700,8787,"that you feel better?"],[8875,8950,"What about me?"],[9138,9280,"My tongue is burning now."],[9542,9684,"We gotta kiss to make it feel better."],[9776,9838,"You can..."],[9939,10085,"get some ice from the freezer."],[10147,10226,"Help yourself."],[10518,10623,"Ungrateful little brat."]],"9":[[20,112,"Oh my gosh, Mandy,"],[112,212,"you look like shit."],[279,383,"This is all Brie's fault."],[400,500,"Should we tell your brother?"],[500,600,"He'd fuck her up."],[638,829,"I have to get on her good side."],[829,1017,"Teddy Langford is her half-brother."],[1017,1176,"God, Alisa, grow a brain cell."],[1272,1330,"Mandy,"],[1359,1597,"I thought you said Teddy likes you,"],[1597,1735,"but why would he beat you up"],[1735,1856,"for some random girl?"],[1856,1956,"It was an accident!"],[1976,2106,"And it wasn't some random girl."],[2114,2268,"That was his half-sister."],[2373,2489,"But are you sure"],[2489,2594,"Teddy likes you, though?"],[2594,2761,"It really did not seem like it."],[2786,2923,"Of course Teddy likes Mandy."],[2944,3032,"They already made out"],[3032,3194,"a bunch of times last season."],[3232,3315,"They just need some time"],[3315,3411,"to get reacquainted"],[3411,3532,"after summer break."],[3628,3766,"So he lied to me?"],[3799,3845,"It's not like"],[3845,3987,"I've kissed anyone before either."],[4070,4166,"What a jerk."],[4329,4529,"I actually didn't hang out with Teddy"],[4529,4608,"even once,"],[4608,4804,"but sooner or later we'll be a couple."],[4833,4992,"And these hoes don't need to know that."],[5134,5221,"Yeah, we actually made it"],[5221,5321,"to third base."],[5434,5584,"We're, like, basically a couple."],[5659,5751,"Third base?"],[5868,5985,"That means they..."],[6051,6118,"Oh my God."],[6168,6218,"Brie?"],[6948,7027,"Hi."],[7107,7178,"We were actually just"],[7178,7286,"talking about you."],[7390,7536,"Listen, Brie."],[7703,7803,"I had no idea that you were"],[7803,7953,"Teddy Langford's half-sister."],[8012,8174,"What I did this morning was wrong."],[8216,8337,"Could you ever forgive me?"],[8395,8525,"Wow, I never took Mandy"],[8525,8671,"to be the apologizing type."],[8696,8858,"Love makes people do crazy things."],[9079,9134,"It's okay."],[9171,9296,"It's not that big of a deal."],[9296,9401,"Amazing!"],[9467,9530,"Aww."],[9547,9713,"I knew you were a sweetheart."],[9743,9901,"So listen, Brie."],[9989,10172,"Is there any way you could help me"],[10172,10385,"get Teddy alone for a little bit?"]],"10":[[41,162,"I thought you two were"],[221,346,"already pretty close."],[496,625,"Why would you need my help?"],[625,775,"Yes, we are."],[775,996,"But you know, after summer,"],[996,1201,"and with what happened"],[1201,1284,"this morning,"],[1317,1488,"things are a little bit awkward."],[1488,1572,"So,"],[1605,1718,"you could help us patch things up,"],[1718,1764,"right?"],[1889,2077,"Mandy is exactly the kind of girl"],[2077,2252,"Mrs. Langford would pick for Teddy."],[2352,2552,"Rich, pretty,"],[2594,2727,"same social class."],[2811,2998,"I never stood a chance anyway."],[3098,3269,"Why not just help them be together?"],[3411,3457,"Yeah."],[3503,3691,"Yeah, I think Teddy's throwing a party"],[3691,3766,"this weekend."],[3787,3916,"I can probably get you into that."],[3937,4045,"Oh my God, Brie."],[4104,4245,"You're a godsend."],[4312,4400,"I cannot believe you didn't"],[4400,4521,"come to this school sooner."],[4521,4650,"I just know we would have been"],[4675,4846,"best friends."],[4967,5121,"Oh my God, are you sitting alone?"],[5271,5384,"No, that can't do."],[5417,5509,"Come, sit with us."],[6081,6185,"Alisa, move."],[6264,6368,"Come on."],[6848,6894,"Cool."],[6948,7082,"So, you know, this weekend,"],[7111,7190,"my Mom took me shopping"],[7190,7261,"for my homecoming party..."],[7261,7403,"I should feel relieved."],[7465,7761,"But why does my chest feel so tight?"]],"11":[[250,321,"That's pretty cool."],[408,475,"Oh, hey, Brie."],[950,1126,"Is she avoiding me?"],[3032,3098,"Hi, Brie!"],[3144,3345,"Thank you so much for inviting me."],[3353,3399,"And,"],[3424,3586,"oh my God, your house is to die for."],[3703,3770,"Thank you."],[3853,3945,"Uh, you can come on in."],[5326,5509,"Brie's been avoiding me all week,"],[5559,5668,"ever since the kiss."],[5726,5826,"So now is a good chance"],[5826,5914,"to talk it out with her."],[6064,6181,"Oh my God, there he is."],[6256,6306,"Brie,"],[6306,6381,"I wanted to introduce you"],[6381,6439,"to my team."],[6669,6723,"Oops!"],[7057,7215,"Her grand scheme is to trip"],[7215,7353,"and fall into his arms?"],[7415,7520,"How unoriginal."],[7590,7736,"Thanks for catching me, Teddy."],[7770,7874,"You're so sweet."],[7949,7991,"Um,"],[8041,8237,"but I actually think I twisted my ankle."],[8333,8412,"Do you think we could go up"],[8412,8587,"to your room and rest for a little bit?"]],"12":[[16,125,"Wait, what are you doing here?"],[175,287,"I don't remember inviting you."],[458,500,"Uh,"],[654,742,"I invited her."],[788,925,"We're friends,"],[988,1026,"now."],[1138,1238,"Brie, wasn't she bullying you"],[1238,1343,"like a few days ago?"],[1455,1576,"Total misunderstanding."],[1634,1672,"Teddy,"],[1697,1789,"I already told Brie"],[1789,2014,"how very sorry I was."],[2052,2147,"We're besties now."],[2268,2419,"Brie, I think we should go talk."],[2448,2531,"Like, right now."],[2998,3073,"What the hell?"],[3382,3528,"Okay, what the hell is going on?"],[3570,3687,"You avoid me all week,"],[3687,3749,"and now you bring"],[3749,3874,"some random girl here?"],[3937,3999,"For what?"],[4124,4216,"Random girl?"],[4258,4416,"You went to third base with her."],[4542,4592,"You know,"],[4671,4746,"I brought her here,"],[4746,4842,"so you two could try to"],[4879,4988,"figure things out."],[5050,5188,"I'm so tired of you"],[5209,5363,"playing these games with me, Teddy."],[5363,5484,"I know I'm just"],[5518,5659,"the maid's daughter, but"],[5659,5784,"I'd really appreciate it,"],[5784,5914,"if you'd just stay away from me,"],[5914,6097,"and stop messing with my feelings."],[6160,6264,"What does that even mean?"],[6418,6481,"Whatever."],[6548,6660,"Oh my God, wait, just..."],[6840,6927,"Just talk to me."],[6969,7082,"You don't think I see you"],[7107,7265,"waking up early to avoid me,"],[7265,7411,"or when we're in the halls"],[7411,7507,"and I wave hi,"],[7507,7645,"and you just walk past me?"],[7703,7832,"Are you mad or something?"],[7845,7962,"Just tell me what's going on."],[8078,8204,"You can't just"],[8270,8391,"kiss me like that,"],[8437,8641,"and, and then ask me to be your girlfriend,"],[8641,8842,"and then lie to me."],[8950,9075,"I know guys like you"],[9100,9238,"just like to play these games,"],[9238,9376,"and you think it's so funny and,"],[9417,9563,"but I'm not that type of girl."],[9626,9672,"Okay?"],[9672,97