{"1":[[133,291,"In a world ruled by werewolves,"],[321,362,"crossing into"],[362,500,"Bloodbane territory alone"],[500,658,"on a stormy night is a death wish,"],[679,846,"especially without a wolf."],[913,1063,"Hey Mason, what's up?"],[1063,1192,"Hey, what's up, little bro?"],[1213,1359,"I was just calling to check in"],[1359,1522,"my, uh, meeting with the Council went-"],[1664,1818,"Luca, where are you right now?"],[1818,1943,"I, I went for a jog,"],[1976,2127,"just barely passed the border and"],[2189,2335,"the Bloodbane Alpha caught my scent."],[2335,2385,"What?"],[2398,2544,"Are you out of your fucking mind?"],[2544,2598,"Hide!"],[2619,2756,"He'll be there any second."],[3169,3224,"Mason."],[3382,3449,"Now, the only one who can"],[3449,3528,"save me is,"],[3553,3657,"Alpha Dalton."],[3782,3912,"My pack caught you lurking"],[3912,4066,"near the she-wolve's quarters."],[4066,4195,"Do you know what we do"],[4195,4346,"to rogues who trespass?"],[4346,4446,"Alpha Dalton."],[4446,4579,"No, it was a mistake."],[4579,4767,"I swear by the Moon Goddess."],[4767,5042,"Keep her name out of your filthy mouth."],[5050,5171,"Fucking liar!"],[5568,5672,"Make it fast."],[5684,5801,"Alpha Dalton, it's Luca."],[5809,5897,"He went training alone"],[5897,6051,"and crossed into the Bloodbane territory,"],[6051,6189,"and Alpha Kane is after him."],[6256,6352,"I'm on my way."],[6798,6940,"I know you're there, little runt."],[6998,7048,"Come on."],[7077,7261,"Who's afraid of the big, bad wolf?"],[7365,7503,"I like the chase."],[8241,8337,"Let him go!"],[8387,8491,"Who the fuck is that?"],[8579,8671,"Alpha Dalton."]],"2":[[16,104,"Alpha Dalton."],[179,266,"I wouldn't expect you"],[266,321,"to stick your neck"],[321,421,"on the line for a uh,"],[471,575,"scrawny lost wolf."],[575,763,"Hey, stop fucking around, Kane."],[859,942,"But then again,"],[971,1055,"there's something different"],[1055,1130,"about that boy."],[1889,1985,"Hey, stay back!"],[2502,2648,"Stay away from my pack."],[2690,2802,"Come near us again,"],[2823,2898,"and I'll tear"],[2898,3053,"the Bloodbane pack apart!"],[3053,3178,"Just keep your dogs on a leash."],[3219,3345,"Unless you need me to train them."],[3632,3741,"Get the fuck out of here."],[3828,3958,"I'm sure I'll see you around."],[4496,4546,"Get up!"],[4721,4779,"Dalton."],[4821,4896,"Save it."],[4975,5121,"That's an order from your Alpha."],[5180,5255,"Go on."],[5739,5818,"You didn't need to save me."],[5818,5918,"I could have handled him."],[5918,5964,"Yeah?"],[5964,6076,"Kane would have slit your throat"],[6076,6181,"within seconds."],[6181,6327,"What the hell were you thinking, Luca?"],[6327,6435,"I wasn't, okay?"],[6493,6556,"I messed up,"],[6556,6606,"I just..."],[6702,6723,"What?"],[6723,6886,"I just wanted to prove myself."],[6886,6973,"Prove yourself?"],[6994,7165,"By being the clueless pup"],[7190,7382,"who stumbled his way into a pack war?"],[7419,7624,"You're reckless, Luca."],[7665,7799,"And way too mouthy"],[7799,7907,"for someone your size."],[7953,7999,"Yeah?"],[8045,8208,"Well, I think you're a control freak"],[8208,8345,"with a hero complex,"],[8345,8475,"and a stick so far up your-"],[8475,8541,"Careful."],[9000,9113,"That little mouth of yours"],[9113,9263,"is gonna get yourself into trouble."],[9480,9547,"Fuck."],[9572,9701,"Why does he have to look like that?"],[9743,9838,"I've crushed on Dalton"],[9838,9926,"since I was a kid."],[9968,10047,"But now?"],[10068,10260,"As the Alpha, he's just so..."],[10276,10381,"So hot."],[10564,10652,"What'd you just say?"],[10685,10781,"Hot..."],[10848,10923,"headed."],[10923,11090,"You're also hot-headed."],[11115,11244,"Does that come with being an Alpha?"],[11503,11561,"Fuck."],[11699,11749,"What?"],[12007,12132,"What are you doing?"]],"3":[[37,166,"What are you doing?"],[700,817,"Ow, shit!"],[959,1092,"Kane got you pretty deep."],[1188,1251,"Don't move!"],[1280,1338,"Come on."],[1547,1605,"Hey."],[1664,1710,"Ow."],[1710,1876,"At least this will scar up pretty nice."],[1964,2085,"You'll definitely look like a fighter."],[2206,2360,"I could have told him it wasn't Kain."],[2389,2494,"But how do I tell the Alpha"],[2494,2540,"I'm too weak"],[2540,2635,"to stand up to the bullies"],[2635,2727,"in our own pack?"],[2740,2831,"Get off me!"],[2923,3011,"Train all you want,"],[3011,3165,"you'll always be a fucking runt."],[3666,3720,"Right,"],[3741,3883,"until everyone finds out the Alpha"],[3883,3991,"had to rescue me."],[4012,4066,"No."],[4116,4187,"They won't."],[4379,4504,"You broke Pack protocol."],[4517,4637,"Trained by yourself,"],[4675,4788,"jumped the border."],[4863,5075,"No, Luca, this stays between us."],[5125,5221,"Don't lie for me just because"],[5221,5355,"you're my brother's best friend."],[5559,5768,"I think you forgot that I'm your Alpha."],[5809,5910,"Look in my eyes."],[5997,6068,"Say it."],[6389,6448,"Yes,"],[6544,6623,"you're my Alpha."],[6852,6961,"Good boy."]],"4":[[291,408,"Is this really happening?"],[763,921,"Oh God, you're trembling."],[1013,1159,"Uh, I, I'm cold."],[1830,1926,"I already gave you my jacket,"],[1926,2085,"so uh, I don't know what else"],[2085,2168,"I can give you."],[2168,2285,"You're still in your pants."],[2594,2673,"Let's get going."],[2673,2752,"Come on."],[3157,3203,"Yeah."],[3224,3286,"Thank you."],[3328,3495,"If my idiot brother can hear me,"],[3495,3595,"he's lucky I'm not there"],[3595,3699,"to kick his ass."],[3749,3866,"One more thing, Alpha."],[3866,3941,"The Council."],[3941,3983,"They want you to"],[3983,4099,"meet with Jasmine tonight."],[4145,4200,"They said it's time"],[4200,4312,"to give this pack an heir."],[4529,4617,"I'll talk to her."],[5188,5305,"You have ten minutes to get"],[5305,5372,"cleaned up."],[5392,5488,"Then meet me out back."],[5547,5601,"What?"],[5609,5663,"Why?"],[5755,5980,"You went off on your own, Luca."],[6010,6131,"Until your brother gets home,"],[6131,6256,"you're not leaving my side."],[6314,6456,"He only wants me by his side"],[6456,6610,"because my brother told him to."],[6669,6873,"But every second is like a dagger."],[6915,7032,"Watching him find the one thing"],[7032,7127,"I can never be."],[7178,7273,"His true Luna."]],"5":[[87,179,"Dalton, wait."],[225,358,"Please don't make this worse."],[387,504,"I know I fucked up, okay?"],[538,625,"But you don't get it."],[650,792,"In there, you're the Alpha"],[792,938,"and I'm the wolfless runt."],[975,1084,"It's too humiliating."],[1096,1201,"If I follow you all night,"],[1201,1301,"I won't hear the end of it."],[1476,1580,"Mason asked me-"],[1580,1668,"My brother doesn't know"],[1668,1755,"what I'm going through."],[1755,1810,"He's too busy"],[1810,1906,"trying to find you a she-wolf"],[1906,2035,"you'll keep around longer than a night."],[2068,2152,"Watch it!"],[2198,2318,"What happened to everyone"],[2318,2414,"respecting me?"],[2531,2802,"I said everyone in there respects you."],[2831,2973,"When did this little pup"],[2973,3240,"get such a nippy bite?"],[3261,3399,"Around the same time everyone else"],[3399,3528,"grew claws and fangs."],[3561,3687,"Am I interrupting something?"],[3837,4004,"No, you're not."],[4079,4287,"I was just handling a little situation"],[4287,4371,"for his brother."],[4454,4592,"I was just about to come find you."],[4604,4742,"Well, here I am."],[4867,4984,"I heard the Council was hoping"],[4984,5050,"we'd..."],[5113,5176,"talk."],[5246,5305,"Great."],[5342,5430,"Seems like you're too busy"],[5430,5518,"to be my bodyguard."],[5518,5601,"So why don't we just"],[5601,5709,"go our separate ways?"],[5789,5939,"If you behave yourself tonight"],[5939,6051,"at the Full Moon party,"],[6068,6147,"I'll leave you alone."],[6235,6281,"Deal?"],[6331,6468,"The Full Moon Fest."],[6468,6577,"A night when the whole pack"],[6577,6669,"shifts together."],[6706,6819,"Unless you're the only one"],[6819,6915,"without a wolf."],[6986,7123,"Of course, Alpha Dalton."],[7148,7253,"I promise to behave"],[7298,7374,"for tonight."],[7611,7820,"Well then, why don't we go"],[7820,7974,"prepare for the full moon"],[7974,8158,"somewhere a little bit more private?"]],"6":[[70,154,"Get it together."],[187,291,"You've been pining for this wolf"],[291,392,"since you were a kid."],[392,525,"But he's your brother's best friend,"],[554,629,"the Alpha,"],[654,779,"and probably the straightest guy"],[779,863,"you ever met."],[996,1121,"Not even a scratch?"],[1217,1297,"What's going on?"],[1338,1401,"Luca."],[1522,1580,"Chloe,"],[1580,1626,"get out."],[1626,1722,"I'm naked!"],[1730,1776,"Oh please,"],[1776,1856,"like I haven't seen that"],[1856,1997,"tiny waist and bubble butt."],[2060,2168,"Honey, what's wrong?"],[2198,2243,"Nothing."],[2243,2356,"Just got soap in my eyes."],[2373,2439,"Uh, huh."],[2494,2569,"And by soap,"],[2569,2669,"do you mean the big bad wolf"],[2669,2798,"you've been pining for all these years?"],[2798,2948,"I'm not talking about this sober."],[2961,3011,"Great."],[3011,3140,"Well, we got a party to crash."],[3207,3261,"Hurry up."],[3328,3432,"I said, hurry up."],[3670,3762,"You can do this."],[3832,4079,"It's time for you to get over your Alpha."],[4884,5117,"You clean up well for a rugged Alpha."],[5930,6001,"Dalton?"],[6035,6202,"Of course he'd bring the future Luna"],[6202,6302,"to the party."],[6544,6635,"Alpha Dalton."],[6685,6760,"We both know that"],[6760,6898,"the Council is pressuring you"],[6898,6990,"to find a mate."],[7032,7119,"So, why don't we"],[7119,7248,"go celebrate this full moon"],[7248,7507,"somewhere a little bit more private?"],[7674,7816,"This pup actually brought a date"],[7816,7916,"to the party."],[7966,8099,"He better not stir up any drama."],[8220,8291,"Lead the way."]],"7":[[342,475,"I'm gonna go get you a drink."],[1063,1138,"Enjoying the party?"],[1188,1359,"Didn't expect to see you after last night."],[1526,1622,"Get off me!"],[2414,2464,"Come on."],[2527,2665,"Don't be such a buzz kill."],[3061,3219,"Maybe this will take the edge off."],[4341,4466,"You're tonight's entertainment."],[5009,5196,"Listen up, you filthy animals."],[5196,5384,"I figured, with the full moon,"],[5409,5643,"this runt might have a shot at shifting."],[5680,5768,"Or at least,"],[5784,5997,"it'd be funny as hell to see him try."],[6093,6177,"What are you doing?"],[6594,6694,"There's something wrong."],[6698,6810,"What's wrong is the fact that"],[6810,6915,"you're still breathing."],[6931,7032,"In the wild,"],[7048,7307,"wolves would have killed a runt like you."],[7369,7474,"I say, it's time"],[7474,7691,"we start listening to our instincts."],[8258,8320,"Hold on."],[8500,8571,"Do you feel that?"],[8604,8687,"No, no,"],[8687,8762,"something's wrong."]],"8":[[0,50,"No,"],[50,120,"something's wrong."],[145,371,"The only thing wrong, Alpha Dalton,"],[404,709,"is how long we've waited to do this."],[829,988,"Let's give this pack an heir."],[1184,1234,"Luca!"],[1297,1355,"Are you okay?"],[1393,1443,"Luca."],[1710,1851,"Get away from my best friend!"],[1935,2102,"Get back or I'll do the same to you."],[2256,2427,"Luca Conri, everybody."],[2427,2640,"Conri is Irish for Wolf King."],[2773,2873,"What a joke."],[3449,3616,"Zander, I thought you said the Wolfsbane"],[3616,3712,"would've killed him by now."],[3766,4054,"So, the runt wants to play."],[4091,4258,"I am not a runt."],[4279,4366,"You're right."],[4412,4625,"You'd have to be a wolf to be a runt."],[4625,4804,"You're just a fucking coward,"],[4804,4984,"a mortal bitch."],[4984,5159,"And yet you can't seem to kill me!"],[5201,5271,"Careful."],[5317,5426,"With your brother not here,"],[5426,5522,"there's no one around"],[5522,5622,"to protect you."],[5747,5901,"I don't need anyone to protect me."]],"9":[[33,162,"If you're so confident,"],[183,358,"why don't we go right here?"],[367,454,"You and me."],[925,1071,"If Dalton had any balls,"],[1092,1247,"he would have kicked your ass out."],[1247,1372,"After I finish you,"],[1384,1501,"I'm going right for that"],[1501,1664,"Beta brother of yours."],[1822,2002,"Jealousy's eating you alive, huh?"],[2223,2323,"Let go of me!"],[2836,2902,"Luca."],[3224,3507,"Our pack is soft because of you!"],[3507,3682,"Time to cut the dead weight."],[5000,5088,"Did they hurt you?"]],"10":[[100,179,"Did they hurt you?"],[191,329,"Your dad never would have let"],[329,408,"a cock-sucking,"],[408,533,"wolfless bitch like that"],[533,608,"in the pack."],[621,788,"You're just as weak as he is."],[859,930,"Well, if you think"],[930,1046,"you could be a stronger Alpha"],[1046,1109,"than me,"],[1126,1301,"then why don't you prove it, right now?"],[1330,1380,"Come on."],[1685,1730,"No."],[2160,2210,"Dalton!"],[2273,2464,"I've always wanted to see you bleed."],[2552,2665,"Get off of him!"],[2740,2844,"Stay out of this, Luca."],[2898,3082,"I'll gut you both with one strike."],[3541,3628,"What is this?"],[3666,3757,"I can feel you."],[4383,4475,"I know you're there."],[4533,4608,"My wolf."],[4888,4996,"Stay out of this, Luca."],[5638,5714,"Oh my God!"],[5743,5876,"Luca hurt our Alpha!"],[5876,5951,"Enough!"]],"11":[[133,266,"If you two filthy"],[266,425,"excuses for werewolves"],[425,542,"want to stay breathing,"],[558,675,"then you'll both leave."],[721,855,"And never come back!"],[909,1096,"Let this serve as a reminder"],[1134,1338,"that if anyone wants to challenge me,"],[1372,1609,"now is the time to step up."],[1609,1672,"Come on!"],[1768,1814,"Huh?"],[2164,2277,"The festival's over."],[2298,2410,"Everybody clear out."],[2452,2506,"Now."],[2581,2648,"Party's over."],[2994,3069,"Not you."],[3107,3148,"Come on."],[3407,3474,"So is this what you meant"],[3474,3603,"by trying to prove yourself?"],[3624,3661,"Huh?"],[3687,3828,"Fighting those fucking assholes?"],[3828,3924,"I could have handled it."],[3953,4083,"What happened to leaving me alone?"],[4141,4245,"Don't give me that shit."],[4304,4404,"They could have killed you."],[4554,4662,"I'd rather go out fighting"],[4662,4817,"than be the Alpha's little pet."],[4825,4867,"No."],[4913,5113,"Everyone in this pack"],[5113,5221,"is under my protection."],[5221,5276,"Oh yeah?"],[5276,5317,"Yeah."],[5367,5513,"Would you have broken pack protocol"],[5513,5609,"for anyone else?"],[5655,5739,"Crossed the border?"],[5793,5901,"Jumped into a fight?"],[5943,6051,"Would you let any other wolf"],[6051,6114,"yell at you?"],[6114,6214,"Push you around?"],[6322,6439,"You've treated me differently"],[6439,6552,"since I was a kid."],[6660,6744,"Why me?"],[7273,7349,"You know what?"],[7432,7515,"Nevermind."],[8220,8345,"I didn't say you could leave."],[8504,8558,"Dalton."],[9776,9826,"Is..."],[9943,9993,"Is that..."],[10147,10226,"No."],[10331,10410,"It's impossible."],[10593,10660,"Dalton,"],[10735,10856,"are you my fated mate?"]],"12":[[525,675,"Shit, Dalton, you're bleeding."],[1101,1151,"Wait."],[1151,1201,"Did I..."],[1263,1397,"No, that's..."],[1405,1488,"I didn't mean to hurt you."],[1488,1593,"I'm so sorry."],[1689,1764,"It's fine."],[1801,1918,"A little scrawny pup like you"],[1918,1993,"couldn't hurt me."],[2081,2198,"Come on, tough guy."],[2198,2352,"At least let me get you patched up."],[3253,3345,"Take your shirt off."],[3603,3699,"Don't be shy."],[3720,3841,"I'm your mate now, right?"],[4108,4187,"Sorry."],[4675,4833,"After years of convincing myself"],[4833,4929,"it would never happen,"],[5009,5134,"fate is pulling us together."],[5234,5351,"Maybe there's still a chance."],[5459,5559,"So what does this mean?"],[5651,5755,"I've never heard of two males"],[5755,5847,"being fated before."],[5918,6135,"Yeah, that's because it's never happened."],[6256,6564,"Besides, it doesn't even make sense."],[6631,6765,"You don't even have full control"],[6765,6861,"over your wolf yet."],[6940,7127,"Actually, I saw something"],[7127,7207,"during the fight."],[7303,7394,"Just a glimpse."],[7494,7557,"Perfect."],[7636,7782,"So the Moon Goddess fated me"],[7782,8053,"to a male with a half-formed wolf."],[8183,8295,"Maybe she picked me"],[8295,8425,"for my good looks and sense of humor."],[8742,8875,"Can you please just be serious"],[8875,8946,"for a second?"],[8988,9192,"I seriously need you to sit still."],[9192,9334,"I said I'm fine!"],[9334,9384,"Oh."]],"13":[[54,116,"This is it."],[183,329,"Just tell him how you feel."],[392,542,"Give in to fate."],[596,650,"Dalton."],[1051,1101,"No."],[1138,1209,"This can't happen."],[1234,1284,"And you think"],[1284,1405,"I want to be fated to someone"],[1405,1472,"who thinks I'm weak"],[1472,1639,"and acts like a glorified bodyguard?"],[1685,1785,"If you hadn't tried to save me,"],[1785,1914,"we wouldn't be in this mess."],[1922,1997,"You know what?"],[2022,2114,"Maybe this whole thing"],[2114,2248,"is just some sort of mistake."],[2352,2402,"Right."],[2423,2494,"A mistake."],[2523,2660,"So why don't you reject me?"],[2798,2861,"Luca."],[2919,3015,"Rejecting a mate bond"],[3015,3207,"is like spitting in the face of the gods."],[3240,3378,"And they'll crush you for it."],[3407,3545,"I don't think I can sink much lower"],[3545,3653,"than a runt to the Pack."],[3757,3853,"It's not just that."],[3941,4162,"Alright, they say it's like carving out"],[4162,4275,"a piece of your heart,"],[4358,4487,"leaving an ache so deep"],[4487,4721,"that you'll never recover from it."],[4750,4921,"And I just can't do that to you, Luca."],[4946,5021,"Too late."]],"14":[[33,116,"Just give me some time."],[200,241,"Okay?"],[325,375,"Yeah,"],[375,475,"yeah, I'll figure this out."],[500,700,"But until then, just don't be reckless!"],[809,896,"Is that an order?"],[1163,1226,"I'll behave."],[1388,1463,"I should go to bed"],[1463,1601,"before I'm fated to anyone else."],[1747,1793,"Hey!"],[1989,2056,"Don't"],[2143,2198,"tell"],[2252,2323,"anyone"],[2394,2473,"about this."],[2560,2748,"Now that's an order, pup."],[2781,2923,"Stop calling me a pup."],[3165,3207,"Don't worry."],[3253,3399,"I'm used to keeping secrets."],[3499,3574,"Good night, Dalton."],[3687,3862,"And for what it's worth,"],[3887,4016,"there are worse wolves"],[4016,4141,"I could have been fated to."],[4262,4416,"I'd never call you a mistake."]],"15":[[8,137,"I'm hesitant to take in rogues"],[137,258,"from the Nightreign Pack."],[291,408,"I assume you're all as spineless"],[408,479,"as your Alpha."],[508,621,"We're done wasting our time"],[621,817,"with that pathetic excuse for a pack."],[892,980,"Let us fight for you"],[1055,1138,"for Bloodbane."],[1330,1488,"Then give me Dalton's little lapdog."],[1572,1672,"Maybe I'll let you in."],[2635,2715,"This isn't fate."],[2731,2819,"It's a curse."],[2840,2919,"Only one night in,"],[2919,2969,"and it feels like"],[2969,3103,"chains are pulling me to him."],[3132,3228,"If he won't reject me,"],[3228,3386,"then I'll find a way to set us both free."],[3566,3666,"There's gotta be a book here"],[3666,3741,"with a spell or something"],[3741,3820,"to break the bond."],[6293,6368,"Woah."],[6552,6727,"Dalton Grey, what are you up to?"],[6806,6902,"This is insane."]],"16":[[29,120,"Let me go!"],[316,575,"You know, with a nose like yours,"],[621,817,"you'd be dead in the battlefield"],[855,959,"within seconds."],[1142,1234,"So why don't you let me out"],[1234,1326,"and teach me how to fight?"],[1463,1680,"Luca, you don't get to pick and choose"],[1680,1801,"what rules apply to you."],[1810,2014,"This room is strictly forbidden."],[2022,2064,"What's this"],[2064,2156,"torture dungeon anyway?"],[2168,2302,"Some sort of kink of yours?"],[2427,2510,"This is the"],[2510,2711,"Nightreign Artillery Vault."],[2736,2886,"It's passed down by every Alpha."],[2894,3078,"It contains wolf traps,"],[3078,3232,"weapons, records."],[3261,3345,"And now me."],[3382,3445,"Yeah."],[3486,3724,"Like I said, weapons."],[3949,4112,"But you better not let me"],[4112,4250,"catch you in here again."],[4300,4375,"Oh yeah?"],[4450,4567,"What would you do if you did?"],[4629,4783,"Wouldn't you like to find out?"],[4875,4992,"There he goes, pulling me in."],[5025,5171,"Every time I try to put my guard up,"],[5171,5267,"he breaks them down."],[5818,5935,"Can you just let me free?"],[5976,6056,"Not yet."]],"17":[[37,91,"Tell me."],[208,312,"What were you doing in here?"],[346,433,"I was just trying to see"],[433,525,"if one of those books"],[525,608,"could break our bond."],[734,850,"I told you I'd handle that."],[880,1117,"Besides, you really that desperate"],[1117,1217,"to get away from me?"],[1334,1472,"Is this some kind of game to you?"],[1564,1609,"Why don't you just"],[1609,1697,"put that leash back on me"],[1697,1830,"if you're just gonna keep leading me on?"],[1830,1985,"It's this constant push and pull"],[1985,2018,"with you."],[2018,2114,"It always has been."],[2152,2298,"And I just thought after being fated,"],[2298,2439,"maybe there was a chance!"],[2481,2548,"Luca,"],[2756,2915,"I wasn't trying to lead you on."],[2915,3073,"So please, Dalton,"],[3115,3303,"if you don't feel anything,"],[3340,3628,"then for both our sakes, reject me."],[3628,3728,"No, no."],[3770,3866,"I already warned you."],[3908,4083,"Rejecting a bond, it's not that simple."],[4108,4254,"Anything's better than this."],[5638,5743,"Luca Conri. - Dalton Grey."],[5789,5885,"I reject you as - I reject you as"],[5885,5947,"my mate. - my mate."],[7069,7127,"Thank you."],[7369,7424,"Hey."],[7532,7586,"Hold on."],[8137,8179,"Alright."],[8370,8433,"Get out of here."]],"18":[[179,233,"What?"],[258,379,"I knew you were hiding something."],[379,433,"Shhh."],[433,517,"No one can know!"],[558,688,"Besides, we already broke the bond,"],[688,779,"so it doesn't matter anyway."],[779,813,"What?"],[867,1005,"Okay, you've been drooling"],[1005,1163,"for this guy for years."],[1242,1376,"You two have always had a weird thing."],[1376,1572,"Yeah, a one-sided thing,"],[1580,1680,"which doesn't change the fact that"],[1680,1776,"he's my brother's best friend"],[1776,1868,"and the Alpha."],[1893,1947,"That's right."],[1964,2072,"Off limits."],[2110,2248,"I couldn't keep torturing myself."],[2289,2452,"The mate bond only made things worse."],[2506,2590,"Every glance."],[2619,2711,"Every touch."],[2777,2873,"Just more false hope."],[2932,3069,"Maybe he does want you,"],[3069,3136,"but he just hasn't"],[3136,3232,"come to terms with it."],[3232,3286,"No."],[3286,3432,"He made it clear to me what he wants."],[3432,3532,"And it is not me."],[3586,3670,"And that's fine."],[3741,3853,"I want him to be happy."],[4362,4558,"And I will just have to"],[4558,4775,"deal with this empty pit inside of me"],[4796,4859,"until I find someone"],[4859,4959,"who actually wants me."],[4959,5142,"This isn't just a crush."],[5163,5321,"Luca, you love him."],[5392,5547,"Babe, you may have broken the bond,"],[5547,5718,"but that doesn't change"],[5718,5809,"what's inside here."],[6531,6644,"I smell a runt."]],"19":[[0,179,"So, should I even ask you"],[179,250,"if you've had any luck"],[250,337,"with your wolf yet?"],[337,400,"Oh!"],[400,496,"I didn't even tell you."],[496,671,"Last night at the party when Zander-"],[671,784,"When I what?"],[1046,1226,"When I was about to rip your throat out."],[1284,1413,"Why don't we try that again?"],[1488,1597,"But this time,"],[1597,1726,"your Alpha won't be able"],[1726,1926,"to save your pathetic neck."],[2039,2085,"Luca!"],[2268,2410,"Woah, woah, woah, easy, Zander."],[2431,2556,"I don't want him bruised."],[2644,2823,"No, you're too special for that."],[3157,3328,"The council's getting restless."],[3336,3482,"They said if you don't take a mate soon,"],[3482,3624,"there will be consequences."],[3645,3757,"So now they're threatening me."],[3778,3974,"They just want you to secure an heir"],[3974,4129,"before Kane grows too strong."],[4204,4270,"I'll handle it."],[4287,4320,"Good."],[4346,4412,"How's my brother?"],[4454,4525,"I hope he hasn't been"],[4525,4617,"driving you too crazy."],[4708,4854,"Crazy is putting in lightly."],[4904,4988,"Luca Conri. - Dalton Grey."],[5038,5121,"I reject you as - I reject you as"],[5121,5184,"my mate. - my mate."],[5301,5397,"Get your head together."],[5447,5509,"It's over."],[5555,5605,"Hello?"],[5605,5680,"Alpha Dalton."],[5697,5751,"Oh,"],[5801,5843,"uh."],[5914,5989,"Yeah sorry."],[6031,6097,"Luca."],[6193,6239,"He's..."],[6239,6318,"Stay back!"],[6318,6423,"Leave me alone."]],"20":[[279,400,"It's that scent."],[462,575,"I knew there was something special"],[575,629,"about you."],[684,863,"Let go of me. Dalton-"],[863,1021,"Oh, speaking of which."],[1101,1297,"Where is that big bad Alpha of yours?"],[1297,1368,"Get off!"],[1718,1768,"Luca."],[1876,1951,"Did they hurt you?"],[1976,2135,"Dalton, you need to leave."],[2214,2369,"Now that you two are rogues,"],[2394,2544,"there's no pack policies"],[2544,2786,"preventing me from slitting your throats!"],[2802,2898,"Oh, they have a pack."],[2898,3019,"A new Alpha."],[3061,3123,"No!"],[3228,3278,"No!"],[3570,3682,"No, Dalton!"],[3870,3953,"No!"]],"21":[[0,62,"Dalton!"],[104,196,"Let him go!"],[212,279,"At least you're living up"],[279,408,"to your father's legacy."],[579,813,"Dying in a pool of your own blood."],[871,942,"You can't go!"],[942,1034,"I need you."],[1034,1209,"Your old pack is a prison, pup."],[1259,1351,"Your Alpha is clueless"],[1351,1505,"to how valuable you truly are."],[1543,1710,"He doesn't deserve you."],[2077,2147,"End him."],[2210,2264,"Gladly."],[2264,2318,"No."],[2381,2473,"Stay back!"],[2494,2560,"Dalton."],[2652,2777,"I know you're in there, I can feel you."],[2777,2819,"I know you're in there, I can feel you."],[2819,2861,"I know you're in there, I can feel you."],[2919,3044,"Bursting to break free."],[3115,3290,"Now's your chance to fight for our mate."],[3290,3586,"I said, stay back!"],[4642,4758,"Oh, I knew it."],[4779,5121,"After all these years, the White Wolf."],[5643,5885,"Dalton, please, come back."],[7912,7966,"Luca."]],"22":[[29,137,"Capture that wolf!"],[250,392,"Touch him again,"],[450,679,"and I'll cover this floor in your blood!"],[813,867,"If I didn't know better,"],[867,1013,"I'd say you had feelings for the pup."],[1117,1267,"You're on Nightreign Territory,"],[1376,1434,"if you don't leave-"],[1434,1576,"Cut the theatrics."],[1601,1693,"Tonight's proved me right."],[1693,1818,"That pup is special."],[1856,2010,"Oh, the White Wolf is back,"],[2010,2093,"and with him,"],[2152,2285,"the power to cheat death."],[2385,2556,"Whoever claims that boy is unstoppable."],[2556,2606,"What?"],[2681,2777,"We're done here!"],[2977,3048,"For now."],[3899,4024,"Alpha Dalton, help!"],[4054,4112,"Luca!"],[4141,4195,"Luca,"],[4220,4279,"are you okay?"],[4483,4558,"I'm fine."],[4658,4729,"Better than fine."],[4804,4867,"What?"],[4996,5075,"My wolf,"],[5213,5284,"he's alive."],[5292,5417,"Is that the White Wolf?"],[5417,5492,"It can't be."],[5492,5609,"There hasn't been a White Wolf"],[5609,5755,"in over 500 years."],[5755,5834,"Enough!"],[5951,6227,"This pup is always causing trouble."],[6285,6331,"Okay?"],[6335,6456,"There's no White Wolf!"],[6468,6648,"Yeah, it was just a trick from the lights."],[6648,6765,"I know what I saw."],[6765,6877,"Save it, Chloe."],[6894,6969,"You're drunk."],[6990,7044,"Why don't you just"],[7044,7144,"get back to the Manor"],[7144,7236,"before you say something"],[7236,7307,"you'll regret."],[7374,7482,"Everyone get out!"],[7528,7586,"Now!"],[7866,7999,"Except you."]],"23":[[20,104,"The White Wolf."],[204,279,"What am I?"],[433,517,"Why were they looking at me"],[517,579,"like that?"],[579,625,"No."],[646,813,"You promised you wouldn't"],[813,988,"do anything reckless."],[1005,1146,"In one day, you've gone ahead"],[1146,1276,"and made yourself a target."],[1438,1534,"I can't keep up with you."],[1534,1618,"So stop!"],[1668,1789,"Just because my brother asked you"],[1789,1856,"to protect me doesn't-"],[1856,2018,"You think I'm doing this for your brother?"],[2018,2147,"You were supposed to die!"],[2218,2264,"How..."],[2356,2456,"how didn't you die?"],[2577,2711,"I guess I'm stronger than I look."],[2731,2769,"Sure."],[2861,2986,"Just please stop risking your life."],[3032,3082,"I can't..."],[3182,3345,"The pack can't lose you."],[3395,3445,"The pack?"],[3524,3720,"You know, you're not as subtle"],[3720,3795,"as you think."],[4045,4162,"How did you even find me?"],[4179,4225,"Huh?"],[4275,4350,"We're not fated anymore,"],[4350,4450,"so you can quit acting like"],[4450,4554,"my knight in shining armor."],[4554,4788,"It's not that easy."],[4979,5092,"We rejected the bond."],[5176,5259,"But our connection"],[5301,5413,"runs deeper than that."],[5668,5809,"Don't tell me you can't feel it."],[6072,6151,"I don't know what..."],[6293,6398,"I'm feeling"],[6473,6535,"anymore."],[6931,7032,"When you're in pain,"],[7207,7290,"I'm in pain."],[7511,7578,"When you're sad,"],[7674,7736,"I'm sad."],[7845,8049,"Our connection runs way deeper"],[8049,8108,"than you think."],[8183,8320,"I feel what you feel."],[8717,8867,"So what do you feel right now?"]],"24":[[250,312,"I'm sorry."],[342,487,"I, I..."],[487,554,"It's fine."],[554,600,"No."],[600,700,"It's not fine."],[738,850,"It's not fine,"],[850,992,"that I keep doing this to you."],[1063,1155,"But the Council"],[1155,1280,"is cracking down on me."],[1317,1418,"If I don't find a Luna"],[1418,1534,"to bear my pup soon,"],[1593,1705,"they're going to strip my title."],[1843,1989,"But you're the Alpha."],[1989,2223,"The youngest Alpha,"],[2248,2506,"with no heir, and rivals circling."],[2581,2715,"The Council is already"],[2715,2840,"looking to replace me."],[2877,3023,"So if you don't mate to a true Luna,"],[3023,3140,"you'll lose the pack?"],[3165,3294,"I wish it was that simple."],[3353,3620,"An Alpha doesn't just lose his pack."],[3745,3878,"They take my life."],[3920,3974,"What?"],[4049,4104,"No."],[4175,4241,"They can't."],[4287,4362,"We won't let them!"],[4425,4546,"The bond's already broken."],[4546,4654,"We just need to keep our feelings"],[4654,4725,"under control."],[4884,5034,"You say that like it's easy."]],"25":[[200,275,"He was right."],[312,396,"Now matter how much"],[396,500,"we avoid each other,"],[533,650,"my feelings are growing deeper."],[704,792,"Fated or not,"],[834,938,"I wanted him."],[2431,2548,"I want to see"],[2569,2819,"that pretty little face of yours"],[2865,3003,"between my thighs."],[3057,3232,"I don't go down for just anyone."],[3732,3828,"I'm your Alpha."],[3937,4049,"Get on your knees, pup."],[5601,5705,"It was just a dream."],[5805,5955,"What the fuck is happening to me?"],[5955,6014,"I'm going insane."],[6076,6197,"It's time to talk to him."],[6243,6364,"Figure this shit out."]],"26":[[296,483,"Alpha Dalton, are you sure?"],[492,567,"I'm positive."],[583,725,"Luca Conri's the White Wolf."],[796,934,"And Alpha Kane of the Bloodbane Pack"],[934,992,"knows it."],[1046,1167,"And he won't stop"],[1167,1326,"until he captures Luca."],[1347,1530,"The White Wolf is a healer."],[1564,1743,"Making any pack it belongs to"],[1743,1881,"nearly invincible."],[1881,1976,"Then I'll protect him."],[2160,2398,"Whatever you do, don't tell Luca."],[2494,2656,"He can barely control his wolf yet."],[2748,2907,"It'll only get him in more danger."],[2944,3044,"The White Wolf?"],[3123,3240,"That's what's inside of me."],[3353,3461,"If it's really that powerful,"],[3545,3641,"then maybe I could be strong enough"],[3641,3745,"to be Dalton's mate."],[3824,3970,"I just need to learn how to control it."],[4229,4366,"Dalton, I want you to train me."]],"27":[[29,187,"Yeah, that's, that's not gonna happen."],[387,571,"Let me excuse myself."],[734,842,"If you're gonna keep putting yourself"],[842,896,"on the line for me,"],[896,950,"then I at least"],[950,1046,"want to fight beside you."],[1046,1205,"I don't think it's a good idea for us"],[1205,1355,"to be rolling around on the mats."],[1409,1539,"Afraid you can't control yourself?"],[1910,1964,"Come on."],[2064,2156,"I wasn't asking."],[2936,3082,"We've been at this for hours."],[3203,3278,"Again."],[3766,4066,"I said, keep your guard up."],[4287,4400,"I knew this was a bad idea."],[4450,4575,"Maybe we should just call it."],[4746,4800,"No!"],[4833,4900,"Stop."],[4959,5075,"Keep your guard up."],[5242,5376,"I never thought I'd say it,"],[5397,5472,"but he's cute"],[5472,5622,"when he's a cocky little pup."],[5663,5793,"I need to be closer."],[5880,6139,"I can feel you, wanting me."],[6202,6352,"Can we just stop fighting this?"],[6548,6915,"I'm not fighting anything."],[7399,7461,"If I knew you were"],[7461,7586,"giving private lessons,"],[7586,7699,"I would have come sooner."]],"28":[[37,283,"Actually, we were just wrapping up."],[342,500,"You mind giving us a second Luca?"],[1109,1163,"Fine."],[1918,2027,"Hey, are you okay?"],[2077,2177,"I'm losing it."],[2331,2406,"My body."],[2431,2515,"These urges."],[2556,2665,"Every time I look at him."],[2815,3032,"Babe, you're fated to the Alpha."],[3065,3265,"So you were practically in heat."],[3265,3386,"And then you just cut that off"],[3386,3511,"by rejecting the bond."],[3557,3749,"If you don't, it'll get worse."],[3820,3978,"Well, now that we're alone,"],[3978,4041,"why don't we pick up"],[4041,4145,"where we left off?"],[4145,4371,"With your lips on my neck."],[4391,4483,"Now's not a good time."],[4550,4729,"The Alpha needs its Luna."],[4754,4921,"This is what the pack wants."],[5038,5192,"Are you questioning my leadership?"],[5205,5267,"No."],[5321,5501,"But there are people that are wondering"],[5526,5730,"why you're chasing after that runt"],[5764,5905,"and not chasing after me."],[6010,6118,"Come on, Dalton."],[6252,6456,"Just submit."]],"29":[[91,254,"He needs a female mate."],[254,329,"If I keep pushing,"],[329,433,"I could ruin everything."],[517,621,"I can't do that to him."],[704,813,"Luca, The Moon Goddess"],[813,938,"doesn't make mistakes."],[955,1051,"Rejected or not,"],[1051,1138,"if you two are fated,"],[1138,1251,"then it's meant to be."],[1292,1368,"She's right."],[1397,1526,"Dalton and I were fated."],[1526,1680,"It's time to make the Alpha mine."],[2035,2118,"Dalton, I..."],[2314,2419,"Sorry, I..."],[2594,2756,"I see the way you look at him."],[2773,2877,"It's pathetic."],[2919,2986,"But you've always been"],[2986,3249,"an embarrassing little freak."],[3265,3420,"And no amount of training"],[3420,3528,"will ever fix that."],[3528,3578,"No, I'm not-"],[3578,3737,"You're a burden, Luca."],[3799,3916,"Everyone knows it."],[3958,4341,"Your brother, your friend, even Dalton."],[4462,4517,"Tell him."],[4667,4713,"Yeah."],[4775,4884,"Why don't you just go?"],[4884,5000,"Run off, Luca."],[5034,5196,"Before you get this whole pack killed."],[5392,5476,"What about us?"],[5476,5759,"There is no us."],[6493,6639,"I've been so wrong about him."],[6652,6798,"How could I be so silly?"],[6840,7044,"Wake up, Luca, he's just your Alpha."],[7465,7520,"Gotcha."]],"30":[[25,104,"Get off me."],[175,229,"Get off me-"],[229,354,"Keep your fucking voice down"],[354,483,"or I'll slit your fucking throat."],[563,788,"Kane said to bring him back alive."],[963,1063,"What do we do if he shifts?"],[1514,1568,"He won't."],[1630,1689,"Come on,"],[1726,1918,"let's bring this bitch back to our Alpha."],[1972,2022,"Dalton."],[2152,2381,"Alpha Dalton, I think it's time"],[2381,2648,"we gave this pack their true Luna."],[2736,2890,"Make me yours."],[3011,3082,"Dalton."],[3140,3219,"Help."],[3390,3457,"Luca."],[3607,3720,"That's impossible."],[3753,3812,"Please."],[3887,3962,"I need you."],[4208,4270,"I'm coming."],[4279,4454,"That bitch must be erased,"],[4462,4571,"body and soul."]],"31":[[525,629,"What the fuck was that?"],[1751,1956,"Kane won't rest until he has Luca."],[1972,2089,"Well then, tell your Alpha"],[2089,2185,"this will be the fate"],[2185,2302,"of the Bloodbane pack."],[2302,2419,"Zander!"],[3132,3194,"Don't worry."],[3286,3395,"You're safe now."],[3908,4120,"You useless fucks."],[4120,4254,"You don't understand."],[4304,4504,"Dalton was like a wild animal."],[4533,4683,"Because they're tethered together."],[4733,4829,"I saw it when he broke out"],[4829,4954,"of my pheromone spell."],[5017,5096,"Not fated."],[5125,5226,"Something deeper."],[5376,5538,"Dalton and Luca are in love."]],"32":[[429,550,"Fuck, that's perfect."],[658,754,"No one's ever going to believe"],[754,838,"an Alpha like Dalton"],[838,959,"will claim a male Luna."],[1042,1172,"If we want the White Wolf,"],[1205,1359,"we hit him where it hurts."],[1388,1480,"Break his heart"],[1555,1647,"and he'll run away."],[1722,1839,"And I'll be waiting."],[2531,2665,"Just stay, Dalton."],[3236,3370,"What am I gonna do with you?"],[4888,5038,"Whatever you want, Alpha."]],"33":[[262,446,"I wanted to stay in that moment forever,"],[475,583,"wrapped in his arms."],[621,704,"But all I could think about"],[704,813,"was Zander's threat."],[813,909,"Kane was coming."],[1234,1326,"Where do you think you're going?"],[1368,1488,"I need to train."],[1505,1601,"No, no."],[1643,1772,"I don't want you to leave my side."],[1810,1901,"Not for a second."],[1935,2022,"No exceptions."],[2039,2189,"That's not going to fix anything."],[2198,2289,"Just teach me how to fight"],[2289,2439,"so I can at least stand beside you."],[2460,2711,"Luca, there is no beside me."],[2736,2773,"Okay,"],[2773,2944,"especially not when you're the target."],[2952,3090,"I know about my wolf, Dalton."],[3090,3094,"I remember that night at the club."],[3094,3215,"I remember that night at the club."],[3236,3432,"Stay back."],[4279,4425,"If I'm really that powerful,"],[4521,4654,"then why are you protecting me?"]],"34":[[33,171,"Then why are you protecting me?"],[191,396,"Because you can't control it, Luca."],[425,575,"The last pack that had a White Wolf"],[575,692,"led a reign of terror"],[692,838,"hundreds of years ago."],[867,1034,"And nobody could kill their Alpha"],[1034,1105,"due to the White Wolf's"],[1105,1192,"healing powers."],[1280,1605,"Luca, if Kane gets his hands on you,"],[1655,1780,"he'll become immortal."],[1805,1964,"So then teach me how to control it."],[2006,2110,"If I get strong enough,"],[2110,2223,"maybe the Council will accept me"],[2223,2293,"as your mate."],[2590,2648,"Okay."],[2723,2869,"So that's why"],[2869,2965,"you want to control it."],[2998,3078,"I just thought"],[3144,3249,"maybe it'd be a chance"],[3249,3353,"for us to be together."],[3636,3695,"Alright."],[3803,3849,"Pin me."],[3883,4029,"Then maybe I'll continue"],[4029,4137,"your private lessons."],[4195,4308,"I think you forgot."],[4350,4525,"I already pinned you down once."],[4833,5050,"I was going easy on you."]],"35":[[20,87,"Easy?"],[137,279,"Or is it just that you like the feeling"],[279,417,"of having me on top of you?"],[571,629,"Okay."],[713,800,"I should go take a shower."],[900,980,"I thought we were done"],[980,1109,"with this hot and cold bullshit."],[1255,1313,"Luca."],[1409,1555,"I can't control myself"],[1555,1643,"when I'm around you."],[1668,1931,"I'm supposed to be the Alpha."],[1976,2081,"I have duties."],[2118,2364,"And one of them is keeping you safe."],[2364,2552,"And the other is to find an heir."],[2594,2748,"Is that why I caught you with Jasmine?"],[2765,2873,"I don't know what you're talking about."],[2873,2932,"I know."],[2952,3073,"You have the pack's legacy to uphold."],[3073,3186,"I'm not blaming you."],[3211,3282,"I just hate that"],[3282,3374,"I allowed myself to believe"],[3374,3461,"that this was turning into"],[3461,3541,"something different."],[3591,3628,"Luca-"],[3628,3741,"Just take your shower."],[3766,3853,"But remember."],[3895,4045,"I feel what you feel."],[4083,4208,"And when you were kissing her,"],[4275,4429,"I know you were thinking of me."],[4688,4754,"Get"],[4800,4867,"out."],[5734,5784,"Fuck him."],[5955,6006,"Fuck."],[6143,6206,"Luca."],[6343,6398,"Fuck."],[7027,7094,"Fuck."],[7340,7415,"Luca."]],"36":[[33,87,"Sorry."],[87,225,"I didn't mean to..."],[329,458,"I thought I told you to leave."],[475,513,"No."],[513,558,"I..."],[717,759,"Wait."],[1009,1059,"Get in."],[1793,1956,"I'm done holding back."],[2031,2147,"I know you want to."],[2248,2298,"Yeah."],[2377,2506,"You're getting a little cocky"],[2506,2581,"for someone who was just"],[2581,2669,"moaning my name."],[2669,2731,"You don't know"],[2731,2857,"what you're doing to me pup."],[3040,3178,"I think I have an idea."],[3858,3924,"But wait,"],[3995,4091,"what about Jasmine,"],[4200,4275,"or the pack?"],[4308,4396,"Or my brother?"],[4446,4600,"Luca, every time"],[4600,4725,"I try to think straight,"],[4763,5021,"the only thing that's on my mind"],[5092,5150,"is you."],[5226,5313,"So I'm done."],[5397,5459,"Luca,"],[5568,5680,"I'm done pushing back"],[5680,5885,"the one thing that I actually want."],[5955,5997,"You."],[6168,6277,"You'd be risking everything-"],[6544,6677,"You're worth the risk."],[6765,6911,"Now shut up and kiss me."]],"37":[[417,533,"I didn't think you'd be,"],[554,692,"you know, into this."],[838,909,"Trust me."],[1109,1276,"I've thought about all the ways"],[1347,1443,"I'd make love to you."],[1493,1555,"Oh yeah?"],[1580,1680,"Why don't you show me?"],[1697,1826,"I want to see you beg"],[1851,1976,"for me, pup."],[2164,2268,"Claim me, Dalton."],[2394,2456,"No."],[2610,2656,"What's wrong?"],[2686,2811,"If I'm gonna claim you,"],[2844,2998,"it's gonna be under the full moon."],[3028,3115,"I want the stars"],[3115,3278,"to watch me make you my Luna."],[3311,3420,"Such a romantic."],[3470,3632,"It's too bad it's not full moon tonight."],[3766,3862,"But I don't wanna stop."],[3983,4074,"What did you have in mind, pup?"],[4183,4308,"Just like we did in the dream."]],"38":[[116,266,"You did it in the shower?"],[354,404,"How was it?"],[404,442,"Was he-"],[442,583,"I do not kiss and tell."],[650,734,"But let me just say,"],[813,950,"he lives up to the rumors."],[1130,1272,"What if he claims you tonight,"],[1272,1380,"during the First Hunt?"],[1413,1630,"Then I would be best friends"],[1630,1810,"with the first male Luna."],[2031,2252,"No, what's with the face?"],[2394,2498,"Is this a mistake?"],[2627,2827,"I mean, Kane's closing in,"],[2844,2932,"the Council wants Dalton"],[2932,3040,"with a female Luna,"],[3040,3140,"and now Jasmine's got her"],[3140,3211,"claws on him."],[3261,3386,"We already broke our fate bond,"],[3386,3582,"but if he claims me,"],[3691,3807,"there's no going back."],[3832,3962,"Luca, the Moon Goddess"],[3962,4120,"doesn't make mistakes."],[4149,4270,"Rejected or not,"],[4270,4366,"if you two are fated,"],[4366,4491,"then it's meant to be."],[5768,5839,"Thanks, Chloe."],[5905,5955,"Now,"],[5955,6260,"I want every last detail."],[6648,6715,"Well..."],[6848,7077,"Let's see how long true love lasts."]],"39":[[1418,1505,"I know who I want."],[1555,1722,"The one fate intended for me."],[1772,1843,"And tonight,"],[1881,2002,"I'm making it official,"],[2052,2223,"I'm finally going to claim..."],[2377,2439,"Luca?"],[2485,2552,"You shouldn't lead"],[2552,2740,"that poor pup on like that."],[2786,2911,"Jasmine, you can't be in here."],[2927,2994,"Why?"],[2994,3169,"Because it's against the rules?"],[3178,3357,"Or because you know you'll give in to me?"],[3411,3541,"Face it, Dalton."],[3595,3699,"You want me."],[3745,3945,"Look, I should have told you."],[3945,4004,"I'm fated to-"],[4004,4191,"Honey, I know your type."],[4275,4462,"How to please you."],[4517,4704,"How to break you."],[4758,5046,"How to control you."],[5046,5125,"I knew there was"],[5125,5217,"something wrong with you."],[5422,5697,"Just submit to me."]],"40":[[196,250,"I don't know"],[250,437,"why they put you males in charge."],[458,696,"You're so easy to seduce."],[775,896,"It's almost boring."],[1468,1518,"So,"],[1680,1760,"where's your Alpha?"],[1797,1960,"You know, you could actually"],[1960,2031,"find a mate tonight"],[2031,2106,"instead of being"],[2106,2268,"so invested in my relationship."],[2590,2765,"On this last night"],[2798,2977,"of the October full moon,"],[3023,3199,"we will commence the first hunt."],[3228,3378,"Fated pack members"],[3428,3653,"will take their mates into the woods,"],[3703,3837,"leaving as wolves"],[3883,4062,"and coming back united."],[4129,4195,"Go get him."]],"41":[[91,175,"Oh."],[216,304,"It's you."],[333,458,"I thought you'd be in bed by now"],[458,583,"with the other pups."],[654,704,"Dalton."],[725,792,"What's going on?"],[846,938,"Yeah, Dalton."],[992,1059,"Tell him."],[1180,1292,"This pack needs a Luna."],[1376,1493,"But last night, I thought-"],[1493,1559,"Thought what?"],[1589,1722,"Thought I'd sacrifice everything"],[1722,1864,"for a pathetic little runt?"],[1922,2035,"You can't satisfy me"],[2035,2139,"or my needs,"],[2164,2373,"let alone carry on my legacy."],[2515,2681,"You can't even fend for yourself."],[2882,2969,"You'll never"],[3044,3128,"be my Luna."],[3232,3340,"But we were fated."],[3357,3411,"Save it."]],"42":[[37,291,"I'd keep that sick fantasy to yourself."],[321,458,"This pack of predators"],[458,500,"isn't known"],[500,638,"for breaking tradition."],[667,775,"What did you do to him?"],[788,892,"I just reminded him"],[892,1038,"what it's like to be with a female."],[1163,1234,"You heard her."],[1247,1405,"It's over, Luca."],[1422,1472,"Now,"],[1539,1626,"show some respect"],[1634,1780,"to the pack's new Luna."],[1939,2114,"Let the first hunt commence."],[2173,2293,"Let's make things official."],[2314,2406,"Let's do it babe."],[2548,2594,"Here."],[2644,2694,"Come on."],[2819,2877,"Here."],[3107,3215,"What was that about?"],[3357,3453,"He chose his mate."],[3524,3586,"Jasmine?"],[3603,3728,"But what about you?"],[3878,4008,"He looked right through me,"],[4083,4208,"just like everyone else in the pack."],[4354,4450,"No, no, no,"],[4450,4537,"don't do this."],[4537,4667,"You know that's not like him."],[4700,4808,"He's your fated mate."],[4808,4963,"He's the Alpha, Chloe."],[5025,5167,"He has traditions to uphold."],[5259,5413,"But after everything that you two"],[5413,5463,"have been through,"],[5463,5497,"I just-"],[5497,5601,"We're just fated."],[5601,5689,"Like you said."],[5759,5926,"He can't help his urges, but that's it."],[6093,6206,"He doesn't love me."]],"43":[[513,600,"Settle down."],[600,725,"There's no breaking out."],[775,905,"That's old magic."],[1368,1438,"What are you?"],[1501,1643,"That's a fun question."],[1680,1801,"My mother was a sorceress"],[1801,1910,"of the dark arts,"],[1910,1981,"and my father"],[1981,2164,"was the strongest wolf of his time."],[2218,2306,"Together they had me"],[2306,2464,"and my brother, but,"],[2573,2723,"you've already met him."],[2806,2886,"Kane."],[2936,3015,"I knew it."],[3082,3253,"You seduced your way into this pack,"],[3299,3449,"just so you could try to kill me."],[3486,3653,"That was the idea."],[3691,3799,"But then your little mate"],[3799,4004,"decided to show his powers, and"],[4037,4262,"a new opportunity arose."]],"44":[[16,158,"Don't you dare try to kill him."],[158,262,"Kill him?"],[308,417,"Don't be an idiot."],[417,567,"I'm taking him to my brother."],[567,684,"With the White Wolf,"],[684,867,"Bloodbane will be invincible."],[880,1001,"And I will take my place"],[1001,1096,"beside the throne."],[1096,1163,"You're wrong."],[1234,1463,"Luca would never betray the pack."],[1497,1630,"You would be surprised"],[1630,1805,"how easily my spells"],[1805,1997,"can manipulate you males."],[2027,2122,"And thank you"],[2122,2406,"for breaking that poor pup's heart."],[2473,2544,"You'll never be my Luna."],[2544,2702,"You'll never be my Luna."],[2819,2927,"But we were fated."],[2940,3011,"Save it."],[3332,3545,"He'll be under my control by sunrise."],[3578,3778,"And there's nothing you can do"],[3778,3891,"but suffer."],[4124,4316,"Luca, I should have never"],[4316,4379,"dragged you into this."],[4379,4421,"dragged you into this."],[4525,4571,"Dalton."]],"45":[[41,100,"Are you okay?"],[171,237,"It's Dalton."],[237,325,"I can feel him."],[325,404,"He's in trouble."],[504,546,"Wait."],[575,704,"You can't control your wolf yet."],[717,825,"What if Zander's out there,"],[825,900,"or Kane?"],[955,1051,"This could be a trap."],[1071,1126,"A trap?"],[1151,1209,"Chloe."],[1209,1288,"You're a genius."],[2414,2548,"I'm coming, Dalton."],[2831,2969,"It's unfortunate, really."],[3015,3078,"You were a,"],[3140,3244,"decent kisser."],[3303,3553,"But sadly, I have no use for you anymore."],[3724,3762,"Do it."]],"46":[[29,141,"I have no use for you anymore."],[458,513,"Hey!"],[1230,1301,"I should have known"],[1301,1476,"you were a manipulative witch."],[1476,1572,"Literally."],[1689,1722,"No."],[1722,1789,"No, Luca."],[1801,1901,"Get back to the manor."],[1906,2006,"Not without you."],[2006,2160,"I'll let your Alpha live"],[2193,2352,"as long as you submit to me."],[2373,2435,"Luca."],[2627,2831,"Sorry, you're not my type."],[3103,3153,"Wow."],[3570,3620,"Luca."],[3795,3895,"All those things I said"],[3895,3945,"earlier- - Dalton."],[4016,4066,"I know."],[4099,4154,"It's okay."],[4195,4362,"Besides, it feels good"],[4362,4512,"saving your ass for a change."],[5409,5509,"So sweet."],[5534,5709,"But Kane's coming for you, Luca."],[5747,5839,"So if you want your lover"],[5839,5943,"to stand in his way,"],[5955,6172,"Dalton's blood will be on your hands."],[6352,6443,"Don't listen to her."],[6510,6589,"Come on, Luca."],[6619,6773,"Let's just go back to the manor."],[6794,6848,"Dalton."],[6911,6998,"We can't be together."],[7015,7073,"What?"],[7157,7223,"Luca, wait."]],"47":[[129,208,"You heard her."],[229,337,"Kane will do whatever it takes"],[337,417,"to get to me."],[458,579,"You don't think I can take him?"],[754,821,"Luca."],[821,1017,"She's putting us against each other."],[1038,1121,"It's old magic."],[1121,1209,"But she's right."],[1255,1326,"If I'm your mate,"],[1326,1505,"I'm just putting you into more danger."],[1630,1714,"I'm the Alpha."],[1843,1993,"I'm always in danger."],[2018,2118,"Not like this."],[2260,2439,"I know what Kane did to your father."],[2439,2556,"He's a fucking animal."],[2656,2794,"And I can't put you through that."],[2840,3098,"We just need to end this."],[3290,3365,"You're wrong."],[3499,3661,"Think about it, Luca."],[3703,3941,"Did breaking our bond prevent me"],[3941,4104,"from showing up for you?"],[4149,4300,"From being there by your side?"],[4458,4546,"From wanting you?"],[4704,4792,"What are you saying?"],[5105,5330,"It didn't take being fated"],[5513,5609,"for me to want you."],[5776,5851,"Dalton."]],"48":[[62,133,"Luca,"],[233,329,"fated or not,"],[483,750,"I've always felt something for you."],[880,1113,"I'm sorry that it took me this long"],[1130,1217,"to realize it."],[1288,1363,"But please,"],[1418,1539,"please don't push me away."],[1714,1993,"I'm sorry, but you've been stabbed"],[1993,2198,"and poisoned and nearly killed."],[2198,2314,"Whatever comes our way,"],[2348,2439,"we'll figure it out."],[2623,2677,"Together."],[2761,2831,"I don't know."],[2936,3057,"If it's not Kane,"],[3094,3274,"it's the Counsel or the pack."],[3274,3453,"Forget the pack."],[3490,3624,"Why not just for once?"],[3641,3741,"Just tell me."],[3866,3991,"What do you want, Luca?"],[4008,4137,"It's not that easy."],[4141,4175,"I-"],[4175,4225,"Luca."],[4266,4379,"I can't lose you."],[4379,4583,"Luca, tell me what you want."],[4592,4763,"I want you, okay?"],[4817,4913,"It's always been you,"],[4913,5063,"ever since I was a kid, Dalton."],[5100,5263,"And it will be for the rest of my life,"],[5263,5330,"because..."],[5397,5480,"I love you."],[6894,6990,"I love you, too."],[7169,7353,"Even if you're a little stubborn,"],[7453,7557,"pain in the ass."],[7720,7845,"I guess you've got a type."],[7912,7982,"I guess so."]],"49":[[500,563,"Luca."],[692,821,"If we do this,"],[1038,1172,"I won't be able to stop."],[1259,1363,"You said you'd claim me"],[1363,1451,"under a full moon."],[1505,1643,"It seems pretty full to me."],[3440,3528,"Why'd you stop?"],[3561,3624,"I just wanted to"],[3624,3766,"take one last look at you"],[3953,4074,"before I make you mine."],[4149,4333,"I've always been yours."],[4871,5009,"I feel what you feel."],[5568,5834,"I can feel you wanting me."],[8650,8737,"Finally..."],[8958,9046,"My Luna."]],"50":[[713,846,"I thought I could count on you."],[905,1005,"I'm sorry."],[1172,1305,"I can fix this."],[1388,1555,"Luca has a brother."],[1593,1672,"Mason Conri."],[1710,1801,"He's coming home."],[1868,2143,"I can lure him here and use him as bait."],[2506,2648,"If the White Wolf isn't kneeling"],[2648,2794,"before me by sunrise,"],[2882,2940,"I'll show you"],[2940,3023,"what true disappointment"],[3023,3094,"looks like."],[3557,3620,"So?"],[3661,3745,"How'd it go last night?"],[3753,3845,"Are you gonna tell me?"],[3887,3945,"Did he?"],[4016,4124,"Did he claim-"],[4608,4713,"Is everything okay here?"],[4754,4946,"Just trying a move for people"],[4946,5084,"who don't know when to shut up."],[5234,5480,"Actually, I'm a little lost here,"],[5480,5609,"can you help demonstrate"],[5630,5709,"on Luca?"]],"51":[[41,254,"Actually, you know what?"],[316,450,"That's a great idea."],[504,604,"Hey, hey everybody."],[650,863,"Luca here is gonna put me"],[913,988,"in a chokehold."],[1017,1080,"Chloe."],[1109,1263,"I'm going to kill you."],[1443,1543,"Ready whenever you are."],[1776,2072,"And remember, eye contact is key."],[2293,2364,"Yeah, Luca."],[2364,2540,"Lots of eye contact."],[4170,4279,"Keep it in your pants."],[4279,4400,"There are people watching."],[4992,5046,"Alright."],[5226,5321,"Who's next?"],[5901,6051,"Hello there, little pup."]],"52":[[20,145,"I just figured you'd wanna"],[145,296,"hear from that little Beta brother"],[296,358,"of yours."],[358,417,"Luca."],[433,533,"Don't listen to him."],[533,596,"Mason."],[621,663,"No."],[675,771,"If you touch him-"],[792,955,"I'm the one giving commands here."],[996,1180,"Come to Bloodbane Manor by nightfall."],[1230,1359,"And if you tell anyone,"],[1401,1626,"including that little Alpha of yours,"],[1664,1710,"I'll show you"],[1710,1856,"what your brother's insides look like."],[1993,2097,"Luca!"],[2177,2252,"It's all my fault."],[2886,2990,"Everything okay, pup?"],[3053,3090,"Yeah."],[3144,3203,"I'm fine."],[3370,3424,"Alright."],[3516,3553,"Come on."],[3566,3641,"Let's get back to it."]],"53":[[905,959,"Luca."],[1134,1201,"What's wrong?"],[1330,1605,"Look, if this is about earlier today"],[1605,1705,"during training,"],[1843,1989,"you know I can't control myself"],[1989,2047,"around you."],[2077,2139,"I'm okay."],[2210,2264,"Really."],[2306,2364,"Okay."],[2419,2581,"Are you excited to see your brother?"],[2627,2748,"He comes back tomorrow."],[2815,2869,"Yeah."],[2902,2961,"Can't wait."],[3353,3411,"Don't worry."],[3428,3549,"I'll talk to him about us."],[3591,3670,"He'll understand."],[3866,3937,"I promise."]],"54":[[629,725,"I'm sorry, Dalton."],[767,867,"But this is the only way to"],[867,971,"keep you safe."],[2919,2965,"Hello?"],[3028,3169,"I'm here like you asked."],[3244,3328,"Where's my brother?"],[4333,4554,"Did you kiss Dalton goodbye?"]],"55":[[542,596,"Luca."],[950,1063,"The Beta has a visitor."],[1505,1564,"Mason."],[1572,1664,"Please talk to me."],[1676,1739,"Mason."],[1751,1868,"What a touching reunion."],[1868,1943,"I'm here now."],[1947,2031,"Let him go."],[2064,2152,"I'll consider it"],[2152,2352,"after you break your bond with Dalton"],[2352,2469,"and you bind with me."],[2535,2698,"I'll never give my power to you."],[2765,2827,"Pity."],[2852,2898,"Well,"],[2898,2948,"guess I'll have to put him"],[2948,3053,"out of his misery then."],[3082,3144,"Stop."],[3178,3261,"You're killing him."],[3286,3390,"That's right, Luca."],[3428,3499,"And you're the only one"],[3499,3578,"who can save him."],[3624,3724,"Luca, don't."],[3937,4012,"Okay, then."],[4029,4091,"I'll do it."]],"56":[[54,120,"If you let him go,"],[120,229,"I'll let you bind me to you."],[375,467,"That's a good boy."],[583,734,"And with your power to cheat death,"],[734,829,"I'll be invincible."],[913,1159,"I will slaughter all of the Alphas."],[1192,1413,"I will rule over the Packs"],[1413,1626,"as the immortal Alpha God."],[1655,1801,"You're a fucking monster."],[1851,1976,"I'd never betray Dalton."],[2047,2168,"A deal is a deal, Luca."],[2210,2356,"It's your life for your brother's."],[2481,2656,"Use your magic to take his fate bond."],[2702,2827,"Dalton may have claimed him,"],[2827,2990,"but that connection dies tonight."],[3094,3178,"Yes, brother."],[3240,3445,"Dalton, please forgive me."],[4546,4642,"This is for Blaine."]],"57":[[342,421,"Where is he?"],[462,617,"Somewhere between heaven and hell."],[729,829,"Let me help you get to him."],[1768,1876,"Luca, no."],[1876,1960,"You have to fight this."],[2002,2143,"Don't let them do this to you."],[2143,2223,"It's too late."],[2277,2439,"Your brother will be my submissive mate"],[2439,2523,"by sunrise."],[2565,2702,"And with him under control"],[2719,2861,"the White Wolf's healing powers"],[2861,3032,"will make Bloodbane invincible."],[3069,3286,"No, I can feel us breaking,"],[3315,3420,"tearing apart."],[3457,3549,"It burns."],[3570,3795,"So much pain."],[3812,3903,"His wolf..."],[3974,4070,"it's too strong."],[4091,4191,"Then push!"],[4191,4329,"This is our only chance!"],[4416,4517,"He's resisting."],[4675,4833,"A deal is a deal, Luca."],[4875,5009,"Dalton may have claimed you,"],[5009,5209,"but your powers will belong to me."],[6014,6151,"You fucking mutt."],[6202,6314,"Where is Zander?"],[6331,6402,"Right here."]],"58":[[87,241,"You fucking psycho."],[241,337,"I was hoping you'd get to see me"],[337,417,"bind your mate."],[425,542,"I can't hold on."],[579,700,"You're not breaking the bond."],[767,850,"You're killing him."],[1263,1376,"I'm sorry, Dalton."],[1455,1526,"I love you."],[1597,1647,"No!"],[2006,2072,"You know that's where"],[2072,2156,"I killed your father?"],[2473,2594,"With his last breaths"],[2602,2761,"he screamed out for your name."],[2852,3182,"My father died a fucking hero."],[3182,3382,"And you will forever waste away"],[3382,3541,"in his shadow."],[3541,3695,"You piece of shit!"],[3707,3770,"No."],[3832,3978,"No!"],[4024,4108,"I almost had him."],[4175,4300,"I'm gonna make you pay."],[4421,4500,"What a shame."],[4617,4688,"All that work"],[4688,4817,"and no one gets the White Wolf."],[4884,4954,"What?"],[5096,5321,"And you fought so hard, damn it."],[5680,5743,"What do you mean?"],[6001,6060,"Luca."],[6060,6110,"No."]],"59":[[0,45,"Luca."],[208,271,"Luca!"],[296,479,"Come on, please, please wake up."],[479,554,"He's gone,"],[554,600,"Dalton."],[704,784,"He's gone, man."],[804,850,"No."],[884,925,"No."],[925,1021,"Don't say that."],[1067,1188,"He's gone. - He can come back."],[1380,1459,"I know he can."],[1539,1605,"Please."],[1614,1672,"Luca."],[1710,1780,"Come back."],[2110,2189,"I love you."],[4496,4558,"We"],[4617,4675,"are"],[4754,4825,"one."],[5434,5488,"Dalton."],[6352,6410,"God."],[6410,6514,"I thought I lost you."],[6573,6748,"I'm sorry, I didn't know"],[6748,6898,"what else to do to save my brother."],[6906,7032,"Shh, it's okay."]],"60":[[212,262,"Yo."],[508,650,"I've been gone for one week."],[696,767,"One."],[804,938,"And now you're the White Wolf, and"],[984,1092,"being attacked by Kane,"],[1092,1226,"and you're kissing the Alpha?"],[1338,1368,"But,"],[1368,1455,"it's uh..."],[1501,1609,"not really his fault."],[1647,1735,"He was fated to me-"],[1735,1897,"Respectfully, Alpha Dalton,"],[1897,2031,"this is between my brother and I."],[2081,2239,"Mason, I'm sorry."],[2306,2406,"I know a lot's happened."],[2406,2481,"A lot?"],[2540,2740,"No, no, this, this is insane."],[2773,2898,"You almost just died."],[2965,3028,"Luca..."],[3161,3311,"I don't know what I would've done"],[3340,3449,"if I would've lost you, bro."],[3545,3636,"You're not mad?"],[3812,3866,"Mad?"],[3937,3983,"No."],[4108,4225,"You're my little brother, bro."],[4354,4433,"I love you."],[4508,4596,"No matter what."],[4742,4842,"And I'm happy"],[4867,4984,"that you found someone"],[5134,5301,"who can put up with your bullshit."],[5372,5459,"He's got a lot of it."],[5543,5630,"I love you too."],[5797,5860,"Besides..."],[5943,6110,"I am so sick of begging you"],[6110,6239,"to find someone to mate with."],[6327,6485,"The Council's not gonna like it, but..."],[6585,6648,"you know..."],[6710,6806,"you have my support."],[6969,7115,"Hey, it's good to have you back."],[7211,7294,"Let's go home."]],"61":[[1338,1443,"You've come this far."],[1584,1664,"It's time."],[3094,3244,"I was nervous you got cold feet."],[3349,3420,"Still might."],[3536,3674,"What if the Pack doesn't accept me"],[3674,3745,"as their Luna?"],[3770,3841,"No. Just..."],[3916,4079,"Just be patient, Luca."],[4112,4245,"Eventually they'll see everything"],[4245,4312,"that I see."],[4366,4412,"Okay?"],[4475,4583,"Maybe not everything."],[4688,4825,"Some parts are just for me."],[5484,5588,"Well now I don't want to go out there"],[5588,5697,"for a different reason."],[5955,6010,"Okay."],[6156,6293,"We'll take care of that later."],[6348,6477,"But right now..."],[6481,6664,"the Pack needs to meet their new Luna."],[6723,6810,"You've got this."],[6923,6977,"Okay?"],[7077,7228,"I'll be by your side the whole time."]],"62":[[304,358,"Look."],[379,462,"Here they come."],[1005,1109,"To Luca Conri."],[1126,1217,"So it's true."],[1430,1593,"The Alpha of the Nightreign Pack"],[1593,1705,"took a male mate."],[1793,1847,"Yes."],[1931,2018,"It is true."],[2039,2210,"But Luca is more than capable of"],[2210,2323,"leading by my side."],[2344,2435,"He's- - Capable?"],[2456,2585,"He's an embarrassment"],[2594,2669,"to this Pack."],[2711,2936,"The Nightreign legacy ends"],[2936,3057,"when he becomes Luna."],[3082,3190,"Of course, she's behind this."],[3228,3374,"She's Kane's sister."],[3374,3486,"Careful, Luca."],[3499,3670,"I'm more convincing than you are."],[3795,3912,"She's a witch."],[3912,4054,"Enough! - Look at her eyes."],[4070,4225,"Jasmine has remained loyal"],[4225,4304,"to the Council"],[4304,4587,"in bringing this disgraceful violation"],[4587,4700,"to our attention."],[4729,4825,"Alpha Dalton,"],[4904,5021,"there are consequences for"],[5046,5284,"going against the Council's commands."],[5284,5513,"I was born to lead this Pack."],[5580,5764,"And I refuse to do it"],[5764,5964,"without Luca by my side."],[6018,6227,"So if that's grounds for punishment..."],[6302,6389,"then so be it."],[6464,6560,"Do your worst."],[6652,6719,"Pity."]],"63":[[29,66,"Dalton."],[66,154,"No, Luca, don't."],[183,312,"If you step in, they will kill you."],[342,483,"Not if I show them what I am."],[658,821,"You need to control it, Luca."],[875,934,"Breathe."],[1005,1084,"Focus."],[1401,1443,"No."],[1488,1593,"They can't see his wolf."],[1760,1835,"Try it."],[1851,1914,"I'd love a reason"],[1914,2052,"to ruin your pretty face."],[2118,2360,"We are one."],[3244,3486,"Never in my world..."],[3516,3695,"No, he can't be."],[3737,3945,"All the times we've picked on him."],[4004,4183,"The White Wolf."]],"64":[[533,600,"Are you okay?"],[675,746,"Luca."],[934,1071,"You controlled your wolf."],[1176,1247,"I did."],[1405,1501,"I don't know how, but,"],[1589,1722,"For the first time, I feel..."],[1851,1922,"powerful."],[2085,2206,"That's because you are."],[2464,2590,"The return of the White Wolf"],[2590,2694,"was foretold."],[2798,2911,"But, It's been so many years"],[2911,3040,"I never thought I'd see it."],[3249,3374,"Please, forgive us."],[3424,3578,"Forgive us. - Forgive us."],[3762,3824,"No."],[3849,3966,"It can't end like this."],[3966,4162,"That fucking runt deserves to die."],[4162,4304,"You've embarrassed yourself enough."],[4366,4575,"Now bow before the White Wolf."],[4629,4742,"My brother was right."],[4763,4946,"This pack is being led astray."],[4975,5351,"You're all a bunch of weak, pathetic dogs."],[5409,5689,"And like dogs, you will submit."]],"65":[[79,154,"You will"],[183,258,"submit."],[900,1026,"I said submit."],[1063,1197,"This pack is protected"],[1197,1305,"by the White Wolf."],[1334,1488,"Your magic is useless"],[1488,1601,"as long as I'm here."],[1647,1743,"Take her away."],[1876,1926,"No."],[1972,2135,"No, I said submit."],[2248,2335,"Bye, bitch."],[2515,2590,"Well, Luca."],[2652,2777,"I'm sure you know"],[2798,2898,"an Alpha is to choose"],[2898,2990,"a female Luna"],[2990,3157,"for her nurturing spirit."],[3194,3299,"It's tradition."],[3311,3390,"Alaric,"],[3440,3586,"but after a week of debating with you"],[3586,3695,"over who Alpha Dalton"],[3695,3803,"is going to choose to mate,"],[3853,3949,"I am begging you."],[3974,4079,"Uh, listen."],[4154,4212,"Please."],[4308,4421,"I didn't come here"],[4429,4596,"for the Council's approval."],[4713,4838,"I've already made my decision."],[4963,5046,"I see that."],[5209,5372,"What I was going to say is,"],[5413,5505,"some traditions come"],[5505,5789,"with a limited and narrow vision"],[5789,5926,"of what the world is."],[6051,6239,"Your pack was stronger"],[6239,6377,"because of you, Luca."],[6602,6769,"Dalton chose wisely."],[6823,6873,"Yeah."],[6936,6998,"He did."],[7161,7336,"And if there are no other objections..."],[7444,7611,"we have a ceremony to finish."]],"66":[[658,800,"It's an honor to welcome"],[800,959,"Nightreign Pack's new Luna."],[1013,1272,"And the love of my life."],[1405,1488,"Luca Conri."],[2331,2394,"Luca."],[2573,2631,"What's wrong?"],[2677,2744,"It's just"],[2865,2952,"after this,"],[3090,3274,"all the rival packs will know about us."],[3370,3457,"Yeah, just,"],[3582,3670,"remember what I said"],[3670,3799,"the night of the First Hunt."],[3841,3962,"Whatever comes our way..."],[4145,4237,"we'll take it on."],[4333,4391,"Together."],[4571,4621,"Yeah."],[5492,5609,"I just wanted to be strong,"],[5643,5701,"to prove that I was"],[5701,5826,"more than a wolfless runt."],[5868,6047,"But truth comes in numbers."],[6068,6197,"Standing beside your pack"],[6227,6364,"and the ones you love."]]}