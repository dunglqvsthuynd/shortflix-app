[3362,3466,"not even going?"],[3679,3779,"You know, I actually,"],[3779,3895,"I think I saw that painting"],[3895,3991,"at the conservatory."],[4062,4162,"It's called Fracture, right?"],[4254,4295,"Uh,"],[4362,4391,"yeah."],[4450,4579,"She still can't remember"],[4579,4675,"the name of my painting."],[4791,4912,"Let's see her fake her way"],[4912,4979,"through the rest."],[5095,5170,"I don't-"],[5170,5212,"It's actually-"],[5212,5300,"It's so interesting."],[5325,5412,"I was just curious"],[5412,5629,"what your, your inspiration"],[5629,5712,"for that piece was."],[5762,5825,"Well,"],[5916,5983,"Uh..."]],"35":[[4,325,"Basically, I was really inspired by,"],[391,704,"um, when things break."],[729,970,"And, um, also, you know,"],[1004,1370,"bad vibes and stuff, you know,"],[1400,1691,"when, when vibes are really bad"],[1704,1829,"and stuff."],[2050,2079,"Yeah,"],[2079,2204,"I guess I saw it a little differently."],[2316,2391,"What did you see?"],[2458,2604,"Well, to me, Fracture,"],[2604,2745,"it isn't about something breaking."],[2783,3041,"It's about the moment right after,"],[3141,3250,"where you can't really move forward,"],[3250,3391,"but you can't go back to change it."],[3441,3500,"So it's kind of like"],[3500,3583,"you're stuck in between"],[3583,3662,"becoming the person"],[3662,3750,"you're supposed to be"],[3754,3891,"and the person that you were."],[4129,4283,"This is our winning painting."],[4379,4475,"It's called Fracture."],[4608,4795,"It's powerful,"],[4883,5141,"like the moment you can't go back,"],[5208,5354,"but haven't figured out"],[5354,5475,"how to move forward either."],[5595,5695,"Being stuck between"],[5695,5775,"who you were"],[5941,6025,"and who you're supposed"],[6025,6091,"to become."],[6245,6325,"How did she know?"],[6412,6537,"This has to mean something."],[6629,6854,"She has to mean something."],[6937,7075,"Thanks for the TED Talk, Anna,"],[7075,7187,"but maybe don't pretend"],[7187,7283,"you know more about my art"],[7283,7350,"than I do."],[7441,7545,"Honestly, Anna,"],[7575,7700,"if you understand art"],[7700,7808,"as well as you claim to,"],[7808,7933,"then why aren't you"],[7933,8054,"in the program yourself?"]],"36":[[0,100,"Maybe she should be the one"],[100,195,"that goes to Paris."],[345,433,"I was gonna invite Anna"],[433,516,"to Paris tonight."],[570,650,"I can't let Brooks steal"],[650,720,"my thunder."],[1229,1279,"Anna,"],[1391,1566,"my family goes to Paris"],[1566,1633,"every summer."],[1670,1758,"Would you want to come with me?"],[2404,2475,"This is it."],[2491,2620,"My chance to escape."],[2654,2841,"This is everything I wanted."],[2870,2983,"Everything I worked for."],[3100,3166,"I'd love to."],[3208,3233,"Yeah."],[3295,3329,"Yeah."]],"37":[[300,345,"Fracture,"],[345,491,"it isn't about something breaking."],[529,795,"It's about the moment right after,"],[891,1000,"where you can't really move forward,"],[1000,1141,"but you can't go back to change it."],[1191,1250,"So it's kind of like"],[1250,1341,"you're stuck in between"],[1341,1408,"becoming the person"],[1408,1487,"you're supposed to be"],[1504,1629,"and the person that you were."],[1825,1987,"I mean, how vain do you have to be"],[1987,2137,"to think that I'd get a tattoo for you?"],[2208,2329,"I got this to cover up"],[2329,2408,"some old scars."],[2475,2591,"First the rose tattoo,"],[2654,2808,"then her take on Lila's painting."],[2870,3041,"It can't all be a coincidence."],[3095,3162,"She's everything"],[3162,3287,"I've ever wanted in a girl."],[3370,3450,"She's perfect."],[3550,3637,"Too perfect."],[3662,3941,"Brooks, I thought you left already."],[4037,4091,"I didn't realize"],[4091,4200,"you were keeping tabs on me."],[4237,4329,"What's up with you tonight?"],[4891,5045,"I have to take care of this."],[5079,5158,"Meet me downstairs."],[5862,5937,"What are you doing?"],[6500,6700,"I know your little plan, Anna."]],"38":[[100,150,"Brooks,"],[212,345,"I'm Preston's girlfriend."],[462,575,"I can't give you what you want."],[687,750,"Stop."],[837,1116,"Stop playing games with me, Anna."],[1254,1366,"You said the rose tattoo"],[1366,1462,"was a coincidence."],[1533,1675,"Okay, fine."],[1750,1829,"But then you come in here"],[1829,1912,"and say all that"],[1920,2033,"about Lila's painting?"],[2125,2270,"It was exactly what went through"],[2270,2383,"my head when I saw it."],[2483,2604,"How could you have known that?"],[2704,2750,"Wait."],[2875,3004,"He understood my painting?"],[3070,3220,"No one's ever seen my work like that."],[3291,3404,"Not even my teachers."],[3462,3587,"I can't let that get to me."],[3745,3829,"You seriously can't think"],[3829,3958,"all of this is about you."],[4154,4283,"Get over yourself."],[4337,4425,"I'm here for Preston,"],[4483,4616,"not some neurotic rich boy"],[4620,4745,"who thinks every girl in this city"],[4745,4925,"is just dying to fall at his feet."],[6650,6716,"If you think I'm some"],[6716,6820,"master manipulator,"],[6820,6937,"I think you have me confused"],[6937,7033,"with your girlfriend."],[7100,7241,"She's the one who can't even explain"],[7241,7387,"her prize winning painting."],[7479,7579,"Hey, what's going on?"]],"39":[[183,254,"We were just talking about"],[254,329,"Lila's painting."],[437,579,"Now it's, uh, getting late."],[595,675,"Uh, we should get going."],[720,754,"Yeah."],[858,916,"You coming?"],[1141,1191,"No."],[1279,1400,"You two love birds go ahead."],[2170,2362,"Let me know when you get home safe."],[2437,2483,"I will."],[2520,2554,"Yeah."],[2600,2637,"Thanks."],[4062,4158,"I need to ask you something."],[4216,4354,"What is it, Preston?"],[4508,4650,"Do you have feelings for Anna?"]],"40":[[154,245,"Are you kidding me?"],[341,441,"I wouldn't be caught dead"],[441,504,"with that girl."],[558,637,"Then why does it feel like"],[637,770,"you can't keep your eyes off of her?"],[937,1016,"Trust me, man."],[1100,1208,"When she breaks your heart,"],[1237,1370,"I'll be there to pick up the pieces."],[1470,1558,"You're wrong about her."],[1833,1912,"Whatever you say,"],[2020,2054,"P."],[3554,3762,"Do I have feelings for Anna?"],[4170,4266,"To convince the Kingsleys"],[4266,4383,"that you were my real parents."],[4583,4687,"As promised."]],"41":[[429,520,"Follow that taxi."],[1554,1612,"Where are we?"],[1662,1745,"Looks like one of those"],[1745,1875,"leftover housing projects"],[1875,1983,"they forgot to tear down."],[2266,2462,"Sam, I need your help."],[2525,2708,"This Anna girl is getting sketchier"],[2708,2775,"by the second."],[3241,3341,"You were totally right."],[3395,3579,"Anna is a fraud."],[3616,3745,"Look, I got two Instagrams."],[3766,3991,"One for Anna Sinclair the socialite"],[3991,4200,"and one for Anna Sinclair"],[4208,4325,"the nobody from nowhere."],[4379,4479,"Oh yeah, I looked her family up."],[4525,4570,"Turns out,"],[4570,4670,"not from the Upper East Side."],[4691,4879,"They're from Queens."],[5012,5116,"She's no socialite."],[5187,5362,"She's just another parasite"],[5362,5429,"like I thought."],[5450,5541,"Her parents are unemployed"],[5541,5600,"for years."],[5741,5808,"What's this?"],[5850,6058,"Well yeah, turns out she's an artist."],[6091,6120,"Goes to"],[6120,6262,"the Callahan Conservatory."],[6300,6379,"She went for that summer"],[6379,6441,"abroad thing"],[6441,6600,"until Lila won it instead."],[6845,6912,"If you think I'm some"],[6912,7020,"master manipulator,"],[7020,7125,"I think you have me confused"],[7125,7229,"with your girlfriend."],[7266,7395,"She's the one who can't even explain"],[7395,7554,"her prize winning painting."],[7650,7808,"We gotta get to that conservatory."],[7866,8012,"I have to find out exactly"],[8016,8137,"who Anna Sinclair is."]],"42":[[1266,1412,"You think you can ignore my calls"],[1412,1579,"and play fancy fucking artist"],[1579,1750,"while your mom and I rot back at home?"],[1766,1941,"If you don't send us more money,"],[1950,2062,"I'll come to that school"],[2079,2283,"and I'll make sure everyone knows"],[2295,2491,"what an ungrateful little liar"],[2491,2625,"you really are."],[2691,2866,"I can't let my parents drag me down."],[2929,3100,"Preston is my only hope."],[3387,3479,"This time,"],[3537,3712,"no one will stop me from escaping"],[3712,3795,"my family"],[3837,4029,"and finally getting what I deserve."]],"43":[[200,370,"Anna, you are the best artist"],[370,554,"we've had in this program in years."],[600,666,"I understand that"],[666,775,"that semester abroad"],[775,891,"was important to you,"],[920,1087,"but you can't quit on us now."],[1216,1275,"That program"],[1275,1379,"wasn't just important."],[1445,1545,"It was everything."],[1650,1770,"I didn't just lose Paris."],[1770,1891,"I lost the only shot I had"],[1891,2029,"at escaping my nightmare parents"],[2029,2141,"and following my dreams."],[2216,2358,"Preston's my last chance now,"],[2454,2529,"my only hope."],[2725,2800,"Thank you, sir."],[2916,3016,"It's time for me to go."],[3841,3933,"Mr. Whitmore,"],[3966,4100,"I am pleased to see you"],[4100,4229,"take such an interest"],[4229,4350,"in our students' work."],[4416,4616,"We would certainly be honored to have"],[4662,4787,"something from our program"],[4787,4958,"hanging in the Whitmore Gallery."],[5079,5166,"I remember this one"],[5166,5304,"from the competition."],[5350,5450,"Yes, of course."],[5450,5541,"This is the winner."],[5600,5816,"Are these by the same artist?"],[5854,5891,"No,"],[5891,6029,"Fracture was the only piece"],[6029,6237,"that Ms. Kingsley completed this year."],[6266,6362,"Those were completed"],[6362,6466,"by another student."],[6729,6966,"She is incredibly talented,"],[7000,7266,"puts her entire life on canvases."],[7329,7454,"An abusive father,"],[7512,7700,"a mother who sells her work"],[7700,7875,"to settle gambling payments."],[7950,8116,"All right here on display."],[8350,8525,"It's so similar to Fracture."],[8900,9095,"It's so raw."],[9233,9350,"It is, isn't it?"],[9466,9733,"It's a shame to see such talent wasted."],[9804,9975,"Anna just dropped out of our program"],[9975,10041,"this morning."],[10070,10112,"Anna?"],[10129,10208,"Anna Sinclair?"]],"44":[[83,133,"Yes."],[1570,1704,"She's the one who can't even explain"],[1704,1845,"her prize winning painting."],[1991,2125,"Lila didn't paint Fracture."],[2212,2275,"Anna did."],[2312,2408,"Why did she drop out?"],[2470,2704,"She lost a semester abroad competition"],[2704,2795,"to Ms. Kingsley."],[2795,2879,"And, well,"],[2941,3025,"let's just say"],[3075,3241,"she was really relying on it."],[3304,3354,"Where is she?"],[3354,3404,"Where is Anna?"],[3525,3675,"She's in the gallery packing up."]],"45":[[470,520,"Okay, wait."],[520,858,"So Lila stole Anna's shot"],[858,1020,"at the summer art program in Paris,"],[1020,1216,"so Anna gets all glammed up,"],[1216,1329,"becomes the perfect"],[1329,1458,"socialite girlfriend for Preston,"],[1458,1675,"and gets her own shot to Paris?"],[1720,1787,"Just keep looking."],[2516,2645,"My dream of becoming an artist"],[2645,2712,"started here."],[2816,2929,"If my parents had their way,"],[2929,3029,"it would die here too."],[3116,3216,"But I won't let that happen."],[3350,3462,"Paris, here I come."],[3920,4016,"What are you doing here?"]],"46":[[758,1041,"You stupid little girl."],[1125,1320,"How dare you quit this program?"],[1362,1454,"Why do you even care?"],[1545,1608,"You guys didn't want me"],[1608,1675,"to paint anyway."],[2116,2250,"If Lila hadn't stolen my painting,"],[2250,2341,"I would have been long gone"],[2341,2445,"by now. - She didn't steal"],[2445,2491,"your art."],[2491,2600,"I sold it to her."],[2695,2804,"You need to forget about this"],[2804,2929,"ridiculous dream"],[2929,3070,"of going to Paris."],[3108,3362,"You cannot escape your family."],[3420,3595,"You're not my family."],[3608,3704,"You're a monster."],[3791,3941,"Your mother and I"],[3958,4191,"wasted the best years of our lives"],[4208,4300,"raising you."],[4337,4458,"You don't deserve"],[4458,4620,"to live abroad peacefully"],[4641,4762,"while we suffer!"],[5158,5258,"Suffer!"],[5983,6158,"Where do you think you're going?"]],"47":[[87,158,"You can't hurt me."],[158,254,"This is a school."],[262,358,"They'll call the dean."],[416,508,"No!"],[566,620,"No, get-"],[704,737,"No!"],[737,837,"Get off of me!"],[925,1141,"I can see you drowning."],[1512,1633,"Get your hands off her!"]],"48":[[712,816,"Brooks, what are you doing here?"],[912,1029,"Anna, stay with me."],[1100,1216,"Sam, get in here now!"],[1387,1625,"Not so fast, old man."],[1650,1766,"Hold him down!"],[2000,2150,"What the hell is going on here?"],[2200,2350,"This asshole snuck on to campus"],[2350,2450,"and attacked Anna."],[2466,2554,"She's my daughter"],[2554,2787,"and I can discipline her how I want."],[2804,2950,"My father spends a lot of money"],[2950,3062,"at this school, Dean Blue."],[3104,3212,"I don't want this piece of shit"],[3212,3312,"setting foot in this building"],[3312,3379,"ever again."],[3404,3500,"Get him the fuck out."],[3504,3600,"Yes, sir, of course."],[3600,3700,"Of course, Mr. Whitmore."],[3700,3754,"Get him out."],[3775,3825,"Quick, quick."],[3829,4075,"Get off me, you brats."]],"49":[[66,262,"Mr. Whitmore, please don't sue!"],[304,391,"Mr. Whitmore!"],[570,658,"Why is Brooks here?"],[729,887,"And why is he holding Anna?"],[1004,1083,"Mr. Whitmore!"],[1095,1195,"Let me go."],[1237,1320,"She's my daughter."],[1320,1458,"I can do what I want."],[1545,1670,"That's the man who sold Fracture."],[1712,1804,"He's Anna's dad?"],[1833,1966,"That was her painting?"],[2029,2212,"Anna's dad is a total psycho."],[2245,2304,"I can't believe"],[2304,2383,"someone in our class"],[2383,2500,"has parents like that."],[2566,2604,"Wait."],[2687,2770,"Anna goes here?"],[2800,2937,"Yeah, she's like the best painter"],[2937,3041,"in the freshman class."],[3054,3133,"You would know that"],[3133,3237,"if you bothered to show up"],[3237,3379,"more than once a semester."],[3450,3533,"Her family's poor,"],[3533,3650,"but I didn't realize"],[3650,3787,"things were that bad."],[3804,3933,"That explains why she's dropping out."],[4083,4208,"Anna really is broke."],[4262,4358,"I knew she was pretending"],[4358,4500,"to be a rich socialite."],[4550,4650,"I stole her painting"],[4650,4795,"and I won the competition with it."],[4829,4950,"Now she's trying to steal my man"],[4950,5050,"to get revenge on me."],[5125,5254,"We'll see about that."]],"50":[[2150,2187,"Well,"],[2308,2400,"cops just called."],[2466,2570,"Anna's dad confessed"],[2570,2683,"to selling her paintings"],[2683,2812,"to settle his gambling debts."],[2854,3029,"That is how Lila got Fracture"],[3029,3129,"and won the competition."],[3262,3358,"She isn't a bad person,"],[3470,3570,"just a desperate one."],[3570,3700,"But after meeting her dad,"],[3820,3912,"can you even blame her?"],[4120,4200,"Can you give us a minute?"],[4608,4670,"I judged you"],[4670,4841,"before I ever tried to understand you."],[4929,5062,"Never gave you a chance."]],"51":[[16,66,"Where am I?"],[145,204,"My apartment."],[787,833,"Stay."],[920,995,"You need rest."],[1425,1504,"Why are you looking at me"],[1504,1562,"like that?"],[1591,1683,"I think you know."],[2054,2137,"Please don't tell me"],[2137,2254,"you think I staged all this"],[2254,2445,"just so I can end up in your bed."],[2620,2670,"No."],[2854,2933,"Anna Sinclair,"],[3029,3170,"Upper East Side socialite,"],[3295,3516,"daughter to a Wall Street tycoon?"],[3645,3762,"If all that was true,"],[3908,3987,"then what was that"],[3987,4108,"back at the art school?"]],"52":[[25,170,"Don't lie to me again,"],[241,287,"Anna."],[550,670,"You think you know everything,"],[670,729,"don't you?"],[858,929,"Why did you think"],[929,1037,"you could get away with this?"],[1116,1225,"Like everyone wouldn't see"],[1225,1345,"right through you?"],[1479,1537,"You're right,"],[1604,1708,"I'm not a socialite."],[1762,1879,"I wasn't born into"],[1891,2037,"a rich Manhattan family."],[2175,2354,"I grew up in public housing in Queens."],[2516,2620,"And we didn't have that much money,"],[2620,2658,"but,"],[2820,2891,"I could paint."],[2979,3116,"So I worked really hard"],[3212,3295,"and I got a scholarship"],[3295,3366,"in art school."],[3662,3779,"Do you know how hard it is"],[4004,4125,"to change your destiny"],[4125,4220,"when you have nothing?"],[4379,4412,"Anna,"],[4441,4483,"I-"],[4516,4562,"Brooks,"],[4658,4758,"don't say anything."],[5016,5129,"You don't get to judge me."],[5295,5387,"You have everything."],[5516,5591,"Everything."],[5666,5816,"And I just wanted one chance at,"],[6020,6083,"at something."],[6316,6391,"You can tell Preston"],[6391,6495,"whatever you want about me."],[6629,6708,"I'll stay out of your guys'"],[6708,6791,"lives forever."]],"53":[[270,316,"Sir,"],[358,491,"I have Ms. Sinclair's medicine."],[583,637,"Thank you."],[779,837,"I'll take you home"],[837,920,"when you're feeling better."],[2008,2066,"Thank you."],[2366,2466,"I don't mean to pry,"],[2466,2679,"but are you Brooks' girlfriend?"],[2779,2870,"Sorry, it's just that,"],[2870,2912,"well,"],[2970,3029,"you're the first girl"],[3029,3125,"he's ever brought home,"],[3125,3225,"so I thought maybe"],[3225,3375,"you were someone special to him."],[3791,3929,"What the hell is going on here?"],[4495,4616,"Get your hands off of her."],[4808,4933,"If Brooks wants nothing"],[4933,5008,"to do with me,"],[5075,5195,"then why does he treat me"],[5195,5316,"like I'm his to protect?"],[5620,5804,"Brooks, thank you for today."],[5979,6050,"I know I said"],[6050,6158,"that you could tell Preston"],[6183,6258,"whatever you wanted,"],[6258,6320,"but can you-"],[6341,6412,"I don't talk shit"],[6420,6570,"behind people's backs, Anna."],[6729,6791,"And you're right."],[6920,7041,"I did have everything"],[7041,7108,"handed to me."],[7250,7295,"That doesn't mean"],[7295,7375,"I don't know what it's like"],[7375,7558,"to want something and fight for it."],[7950,8050,"Your secret's safe with me."]],"54":[[45,145,"Your secret's safe with me."],[575,620,"Thank you."],[733,800,"Don't thank me."],[862,920,"Just..."],[1841,1879,"Go."],[1995,2066,"Get upstairs."],[2350,2395,"Okay."],[4912,5016,"Catching feelings for Brooks"],[5016,5125,"was not a part of my plan."],[5195,5416,"But after everything I've faked,"],[5495,5633,"he's the only part that feels real."],[6150,6241,"My idiot of a husband"],[6241,6325,"disappears again,"],[6341,6462,"and now my ungrateful daughter"],[6462,6583,"won't answer my calls."],[6616,6758,"That bitch still owes me money."],[7216,7287,"What do you want?"],[7570,7650,"Who the hell are you?"],[8191,8391,"Are you Anna Sinclair's mom?"]],"55":[[0,204,"Are you Anna Sinclair's mom?"],[250,304,"I am."],[337,416,"What are you doing here?"],[454,629,"What'd that little shit do now?"],[2604,2754,"Your daughter called the police"],[2754,2862,"on your husband,"],[2862,3012,"and he's been locked up"],[3012,3112,"for a few days now."],[3150,3304,"She's also been spending time"],[3304,3437,"with Preston Kingsley"],[3462,3687,"of the Upper East Side Kingsley's."],[3891,4000,"Sounds like one of those"],[4000,4125,"trust fund brats."],[4141,4212,"Sure is."],[4275,4500,"She is planning to go to Paris with him."],[4525,4600,"Paris?"],[4675,4816,"If that little tramp thinks"],[4816,4950,"she can go live the good life"],[4950,5050,"and leave us behind,"],[5050,5166,"she's got another thing coming."]],"56":[[87,204,"I thought you might say that."],[329,408,"I have a plan."],[537,637,"Why should I trust you?"],[662,741,"I don't even know you."],[779,820,"Hm."],[1000,1154,"How's this for an introduction?"],[1650,1850,"Do everything I say,"],[1929,2087,"and I will pay your husband's bail"],[2087,2216,"and teach Anna a lesson"],[2216,2391,"she will never forget."],[2737,2825,"Whatever you want,"],[2900,2950,"I'm in."],[3070,3208,"Your dirty secret's out, Anna."],[3279,3341,"And this Saturday"],[3341,3433,"at the Debutante Ball,"],[3433,3508,"I'm gonna make sure"],[3508,3583,"Brooke sees you"],[3583,3754,"for the poor little fraud you are."]],"57":[[179,250,"Do you really need me"],[250,345,"to help you pick a tux?"],[391,491,"Yes, dude."],[512,641,"This is the Debutante Ball."],[650,783,"I can't just wear any tux."],[916,1120,"I need something special."],[1220,1341,"Something Anna will really like."],[1683,1779,"Why didn't you just bring her then?"],[1962,2058,"You're her escort."],[2179,2275,"Actually, I..."],[4437,4625,"Anna, you look beautiful."],[4675,4725,"Thank you."],[4825,4950,"I didn't know Brooks was gonna be here."],[5333,5420,"Did you find your tux?"],[5512,5608,"Yes, wait here."],[5629,5695,"I'll go put it on now."]],"58":[[275,379,"Preston said you're not going"],[379,470,"to the Debutante Ball."],[625,904,"I'm not the escort type."],[1004,1041,"Hm."],[1520,1554,"Oh!"],[2950,3045,"Let me help you out with this."],[4837,4945,"What are you doing, Brooks?"]],"59":[[175,283,"What are you doing, Brooks?"],[404,454,"Nothing."],[629,675,"Hey."],[737,841,"Oh, what happened?"],[933,1033,"My necklace fell off."],[1083,1233,"He was just helping me fix it."],[1483,1687,"If you need help or anything,"],[1687,1791,"just ask me."],[2083,2166,"Ms. Sinclair,"],[2262,2437,"I have some shoes to show you."],[3225,3370,"Don't do this to me, Brooks."],[3458,3579,"What the hell are you talking about?"],[3654,3787,"I finally found the girl"],[3816,3904,"that makes me happy,"],[3904,3987,"and then you just-"],[4133,4170,"What?"],[4320,4466,"Listen to yourself, Preston."],[4545,4683,"You finally found someone?"],[4791,4891,"So what about Chloe?"],[4958,5100,"Do you really care about Anna"],[5237,5333,"or are you just using her"],[5370,5462,"as a distraction?"]],"60":[[712,754,"Bro."],[945,983,"Come on,"],[983,1175,"it is so obvious that you like Anna,"],[1175,1208,"but what,"],[1208,1408,"you, you are going to let her go"],[1408,1583,"to the Debutante Ball with Preston?"],[1708,1804,"It's what Preston wants,"],[1804,1983,"and honestly, it's what she needs."],[2037,2154,"I'm not getting in the way of that."],[2204,2262,"Okay, look,"],[2350,2404,"I get it."],[2425,2558,"Preston is your boy, okay?"],[2670,2912,"But what you have with Anna is real."],[2912,3070,"Don't you think that it's, it's, it's worth-"],[3070,3195,"I'm done talking about this."],[4512,4620,"Let me help you out with this."],[6391,6545,"I'm so close to getting out of here."],[6633,6758,"There's no going back now."]],"61":[[1008,1058,"Wow."],[1275,1329,"You look like"],[1329,1458,"you've stepped out of my dreams."],[1587,1700,"I kind of feel like I'm in one."],[2516,2570,"What's wrong?"],[2729,2870,"I, I, I'll be right back."],[3637,3716,"That was fast."]],"62":[[250,320,"I, uh,"],[458,533,"bought you something."],[1850,1920,"It's beautiful."],[1991,2129,"Yours kept falling off,"],[2129,2341,"so I thought you deserved something"],[2458,2508,"nicer."],[3262,3320,"I love it."]],"63":[[133,200,"I gotta go."],[633,754,"So you're really not coming to the ball?"],[954,1166,"I'm, uh, going to London."],[1470,1537,"So this is it?"],[2670,2720,"It is."],[2950,3062,"You can tell her how you feel."],[3133,3333,"But that's not why she's here."],[3370,3512,"I'm not what she wants."],[3529,3583,"Good luck."],[4095,4154,"Brooks!"]],"64":[[45,154,"Do I tell him how I feel?"],[229,333,"I mean, would he want me?"],[433,479,"Brooks."],[962,1041,"Have a safe flight."],[3466,3562,"So you, uh,"],[3641,3691,"did you tell her?"],[4091,4137,"Let's go."],[4558,4612,"I thought Brooks"],[4612,4750,"was just a cocky asshole."],[4800,4937,"I thought I could never trust him,"],[5016,5112,"but he kept my secret."],[5245,5304,"I'm going to be late."],[5420,5495,"Where's Preston?"],[5845,6020,"You've reached Preston's voicemail."],[6029,6195,"I'm not here right now but if you leave"],[6195,6312,"a message-"],[6479,6579,"It's, it's going to be okay."],[6704,6837,"Hey, don't cry."],[6870,7004,"It's going to be okay."],[7137,7187,"Preston?"],[7729,7791,"What's going on?"]],"65":[[8,54,"Hey."],[141,204,"What's going on?"],[262,304,"Uh."],[395,691,"This, this is a friend,"],[783,825,"Chloe."],[945,1266,"It's, um, nice meeting you."],[1379,1433,"Sorry,"],[1441,1791,"I just came to say bye to Preston"],[1791,1950,"before he leaves to Paris"],[1950,2025,"for the summer."],[2262,2525,"You look beautiful."],[2691,2737,"Thank you."],[2875,2933,"I should,"],[3041,3133,"I should go."],[3704,3775,"Shit, um,"],[3795,3975,"she used to do this all the time."],[4054,4179,"I should take her to a hospital."],[4212,4316,"You go without me."],[4337,4495,"And I'll meet you in there when I can."],[5854,5945,"Get here now."],[6025,6104,"It's show time."]],"66":[[216,279,"Good evening,"],[279,404,"ladies and gentlemen."],[437,554,"Please join me"],[554,695,"in welcoming the newest"],[695,970,"Debutantes of New York society."],[1175,1204,"Come on."],[1204,1337,"Preston, where are you?"],[1779,1983,"Miss Charlotte Pembroke,"],[2025,2170,"daughter of Richard"],[2187,2337,"and Helen Pembroke,"],[2362,2545,"accompanied by her escort,"],[2566,2787,"Mr. Harrison Wells."],[3529,3750,"Miss Madeline Worthington,"],[3762,3920,"daughter of Spencer"],[3937,4087,"and Vivian Worthington,"],[4116,4287,"accompanied by her escort,"],[4312,4479,"Mr. Carter Bellamy."],[5645,5833,"Miss Anna Sinclair,"],[5866,6175,"daughter of Joshua and Eliza Sinclair,"],[6200,6362,"accompanied by her escort,"],[6370,6587,"Mr. Preston Kingsley."]],"67":[[237,308,"Oh my God,"],[333,487,"I'm so second hand embarrassed"],[487,566,"for her right now."],[641,754,"Does her date not even bother"],[754,820,"to show up?"],[2825,2945,"Surprise, Anna."],[3429,3537,"The Debutante Ball"],[3537,3712,"is such an important night"],[3712,3837,"in any young woman's life."],[3837,4012,"I couldn't let your real parents"],[4012,4100,"miss out on it."]],"68":[[0,175,"I couldn't let your real parents"],[175,250,"miss out on it."],[266,408,"You think you're too good to invite us"],[408,541,"to your fancy party?"],[541,800,"I spent days in jail because of you."],[975,1145,"Did he seriously just say jail?"],[1175,1312,"Who let the criminals in?"],[1337,1491,"Anna, what's going on?"],[1529,1641,"Who are these people?"],[1654,1862,"This is Anna's real family."],[1912,2104,"Those are just actors she hired"],[2104,2254,"to pretend to be her parents."],[2325,2483,"She's not even rich."],[2554,2650,"She's a nobody."],[2704,2820,"Anna, is this true?"],[2887,3029,"What do you have to say for yourself?"],[3029,3200,"Are they your parents?"],[3245,3366,"I can't give up now."],[3470,3629,"I can't let them hurt me anymore."],[3791,3825,"No,"],[3962,4041,"they're not my parents."],[4041,4191,"You little shit!"],[4212,4408,"We raised that ungrateful brat"],[4425,4504,"and she acts like"],[4504,4604,"she doesn't even know us."],[4629,4737,"Cut the act."],[4770,4875,"You're a fraud"],[4900,5154,"and I'll prove it to everyone."],[6691,6816,"Game over, bitch."]],"69":[[0,366,"Anna Sinclair is a liar and a fraud."],[416,450,"She's just"],[450,583,"a broke-ass art student"],[583,637,"from Queens"],[637,783,"who's pretending to be a socialite"],[783,920,"so she can steal my man."],[933,1091,"And that stops now."],[1425,1462,"Lila,"],[1462,1583,"you've had a problem with me"],[1583,1695,"since the first night we met."],[1737,1829,"I know you're insecure"],[1829,1950,"so I tried to be understanding"],[1950,2166,"but I mean, come on."],[2166,2429,"To use fake photos?"],[2495,2566,"You're embarrassing me"],[2566,2650,"in front of my parents"],[2650,2941,"and I just, I can't forgive that."],[2987,3112,"Oh my God."],[3233,3316,"She's lying."],[3370,3491,"She's still lying."],[3579,3725,"She's still fucking lying!"],[3891,4000,"You're an embarrassment"],[4000,4079,"to this family."],[4133,4225,"I don't know you."],[4325,4408,"Give it up, Anna."],[4437,4529,"You're coming with me."],[4554,4633,"Hold on, hold on."],[4708,4837,"You say you're her parents."],[4895,4983,"Can you prove it?"],[5033,5083,"Yes."],[5145,5350,"Two years ago, she cut her leg."],[5416,5512,"There's still a scar there."],[5583,5650,"Only her real mother"],[5650,5708,"would know that."],[6870,6958,"Show them now!"]],"70":[[0,108,"Show them now!"],[179,287,"You can't tell me what to do."],[308,408,"Yes I can, you little-"],[408,520,"That's enough!"],[579,762,"You won't talk to my daughter that way."],[812,904,"Anna's my daughter"],[933,1045,"and I can promise you"],[1045,1229,"she doesn't have a scar on her leg."],[1262,1387,"Who the fuck are you, lady?"],[1425,1512,"I'm her mother."],[1550,1670,"Why don't we settle this?"],[1808,1854,"Anna,"],[1958,2062,"lift up your dress."],[2137,2295,"And if you don't have a scar there,"],[2295,2475,"then there's no problem, right?"],[2508,2616,"How dare you?"],[2633,2779,"This is a Debutante Ball,"],[2779,3029,"not some trailer park trash strip club!"],[3108,3237,"My daughter is not lifting up"],[3237,3358,"anything for anyone."],[3358,3583,"He's obviously stalling for her."],[3795,3887,"I'm sorry, Anna,"],[3887,4075,"but we need to know the truth."],[4191,4383,"If there's no scar, we'll believe you"],[4404,4500,"and make sure that Lila"],[4508,4637,"never bothers you ever again."],[4662,4854,"But, whoa, I'm not gonna allow this."],[4908,5045,"Our family has never been treated"],[5045,5191,"with such disrespect."],[5437,5500,"No, no,"],[5500,5591,"let go of me! - Get your hands"],[5591,5641,"off her!"],[5654,5733,"We'll show everyone"],[5733,5816,"who you really are,"],[5854,6012,"you ungrateful little slut!"],[6050,6158,"Hey, get off of me."],[6216,6333,"Fine, fine, stop."]],"71":[[550,612,"There's no scar."],[795,912,"I told you."],[1170,1245,"Are we done here?"],[1304,1420,"Lila, I think we're all pretty sick"],[1420,1495,"of your little game."],[1504,1625,"No, no, no, no."],[1645,1687,"There's a,"],[1695,1775,"there's a scar there."],[1775,1845,"She's just hiding it"],[1845,1958,"underneath that tattoo."],[2029,2112,"There's no way"],[2112,2250,"your little tramp stamp"],[2262,2387,"can cover up the truth."],[2483,2579,"Dr. Angelo."],[3375,3483,"Inspect the tattoo"],[3512,3658,"and tell us if there's a scar there."],[3829,3983,"This is ridiculous."],[4037,4141,"I'm calling my lawyer."],[4179,4358,"How dare you treat our daughter"],[4358,4429,"like this?"]],"72":[[45,79,"Well,"],[220,287,"is there a scar?"],[875,945,"There's no scar."],[970,1016,"What?"],[1037,1075,"What?"],[1100,1150,"No, no,"],[1150,1258,"there, there's a scar."],[1270,1362,"I put it there."],[1395,1491,"Shut up, you idiot."],[1550,1654,"They don't need to know that."],[1720,1825,"How is this possible?"],[2529,2562,"Yeah?"],[2625,2845,"Lila's going nuclear on Anna, dude."],[2875,2991,"She brought her real parents here."],[3075,3245,"Shit is hitting the fan."],[3295,3375,"Where's Preston?"],[3412,3466,"No idea."],[3466,3675,"But you need to get here now."],[3783,3887,"Turn around now."]],"73":[[175,358,"Look, if my real parents show up,"],[358,458,"you have to stay in character."],[487,583,"Alright, you can't back down."],[695,779,"So if they say something"],[779,837,"about a scar,"],[837,920,"just follow my lead."],[970,1058,"I had it removed years ago."],[1058,1175,"It should be totally untraceable."],[1395,1566,"Well, Mr. and Mrs. Kingsley,"],[1570,1633,"do you believe me now?"],[1820,1958,"I'm so sorry, Anna."],[2058,2162,"We should have believed you."],[2208,2354,"Your daughter needs to apologize."],[2520,2608,"There's no way"],[2616,2804,"I'm apologizing to this bitch."],[2825,2937,"She's a liar and-"],[3066,3150,"Shut your mouth!"],[3258,3337,"You have embarrassed"],[3337,3508,"this family enough for one day."],[3537,3600,"But, but Dad-"],[3600,3658,"Zip it!"],[3816,3941,"Credit cards, give them to me."],[4237,4383,"Dad, no!"],[4516,4600,"You're gonna live on your own money"],[4600,4658,"for a while,"],[4712,4825,"and the house in the Hamptons"],[4825,4920,"is gone for the summer."],[5279,5408,"You think I'm going to let you"],[5408,5487,"get away with this?"],[5725,5787,"Oh my God."],[5875,5962,"Security!"]],"74":[[0,83,"Security!"],[187,233,"Get back!"],[295,400,"Get back. - Put the knife down."],[466,558,"Put the knife down."],[558,633,"Let her go."],[870,941,"Get back."],[1066,1116,"Grab her."],[1158,1283,"Let's take her home where she belongs."],[1316,1366,"Get away."],[1433,1500,"Get away!"],[1641,1766,"No, get off of me."],[2529,2633,"Get your hands off of her."]],"75":[[16,125,"How dare you touch her?"],[895,979,"Call the police."],[1083,1283,"My family's pressing full charges."],[1416,1475,"Brooksy, you,"],[1479,1579,"you told me you were in London."],[1579,1612,"I-"],[1616,1729,"Get your hands off of me."],[1862,1991,"I can't even look at you."],[2170,2258,"Because of her?"],[2358,2441,"Are you kidding me?"],[2441,2525,"She's a liar."],[2554,2750,"If anyone's a liar, it's you."],[2900,3079,"I know all about your prize painting."],[3166,3262,"It wasn't yours."],[3400,3475,"It was Anna's."],[3641,3691,"What?"],[3800,3900,"What are you talking about?"],[3929,3991,"Yeah, yeah,"],[3991,4066,"it was, it was her."],[4066,4166,"She, she made us steal"],[4166,4308,"my daughter's paintings."],[5250,5279,"Yeah,"],[5354,5445,"we would have never"],[5479,5616,"sold our sweet Anna's work"],[5650,5783,"if that bitch hadn't made us."],[5783,5850,"Yeah, let us go."],[5850,5950,"We'll tell you all about it."],[6008,6083,"Get them out of here."],[6279,6350,"Take her out of here."],[6366,6391,"What?"],[6391,6429,"No."],[6462,6608,"Damn, this isn't fair."],[6608,6729,"She's the liar, not me!"],[6729,6908,"Get your hands off of me!"]],"76":[[312,366,"Are you okay?"],[500,562,"You came back."],[758,850,"I thought you were gone for good."],[1154,1200,"Anna,"],[1279,1345,"I'm sorry."],[1370,1500,"I should have never left you."],[1604,1670,"I should have never"],[1670,1808,"taken my eyes off you."],[1929,2100,"I promise I will never"],[2100,2208,"let that happen again."],[2483,2533,"It's all right."],[2620,2691,"I mean, you're here now."],[2766,2858,"That's what matters."],[3270,3362,"I should probably get down there."],[3404,3462,"I'm not letting you"],[3462,3550,"go down there alone."]],"77":[[125,187,"Brooks!"],[537,620,"I'll take it from here."],[708,791,"I don't think so."],[900,995,"What are you talking about?"],[1012,1166,"This has nothing to do with you."],[1216,1295,"You left Anna"],[1312,1433,"when she needed you most."],[1470,1525,"Go home."],[1620,1708,"You've already lost her."],[1737,1833,"I knew you were into her."],[1883,1991,"I could tell you were jealous"],[1991,2062,"the night I met her."],[2079,2116,"Maybe you should"],[2116,2216,"worry less about me,"],[2316,2383,"more about her."],[2404,2495,"You have no business"],[2512,2575,"being here."],[2600,2695,"She's my date."],[2737,2775,"Anna,"],[2808,2854,"tell him."],[3304,3354,"Preston,"],[3495,3650,"I'm sorry, but I can't be with you."]],"78":[[75,112,"What?"],[279,408,"The truth is I've been lying to you"],[408,475,"this whole time."],[650,766,"I'm not a real socialite."],[900,1029,"Your sister, she stole my painting"],[1029,1175,"and my chance to go to Paris, so,"],[1341,1420,"pretending to like you"],[1420,1575,"was my way to get that back."],[1837,1966,"I'm so sorry, Preston."],[2133,2179,"Okay."],[2529,2583,"No!"],[2670,2875,"I'm always second to you, Brooks,"],[2875,2950,"always!"],[3029,3158,"I have lived in your shadow"],[3195,3333,"and I've been fine with it."],[3404,3500,"You're just pushing me aside"],[3500,3612,"like I was never even there."],[3741,3770,"What,"],[3770,3916,"for someone like a fake nobody"],[3916,3966,"like her?"],[4333,4483,"Yeah, that's right."],[4504,4583,"You heard me."],[4612,4712,"She's a fake."],[4733,4925,"She told me everything."],[5037,5129,"She's not one of us."],[5162,5350,"She is totally broke."],[5370,5516,"You can't talk about her like that."],[5862,5916,"He's right."],[6150,6200,"He's right."],[6395,6454,"I'm broke."]],"79":[[25,279,"I wasn't raised in penthouses"],[279,379,"and private schools."],[554,737,"My real life is kind of a nightmare."],[887,975,"So I made a new one."],[1237,1354,"One where I could get close"],[1354,1475,"to someone who's rich enough"],[1691,1795,"to take me to Paris"],[1866,2075,"and I could pursue my dream"],[2075,2179,"of becoming an artist."],[2404,2483,"The truth is,"],[2641,2741,"I never needed anyone"],[2741,2833,"to take me to Paris."],[3075,3162,"I just needed to believe"],[3162,3245,"that I could do it."],[3404,3475,"I just needed to know"],[3475,3616,"that I didn't have to pretend"],[3616,3679,"to be someone else"],[3679,3762,"to chase my dreams,"],[3954,4079,"that only I can make my dreams"],[4079,4125,"come true."],[4379,4425,"And I will."]],"80":[[100,187,"Brooks, I'm so sorry."],[404,445,"Anna,"],[616,741,"I know the real you"],[883,1166,"and that's the girl I'm falling for."],[1316,1395,"Rich or poor,"],[1541,1645,"it doesn't matter."],[1829,1925,"I just want you."],[2075,2187,"I just want us."],[3316,3437,"My name is Anna Sinclair."],[3495,3600,"Public school art student"],[3604,3750,"turned Upper East Side scandal."],[4170,4262,"I used to think the only way"],[4262,4345,"I could be somebody"],[4379,4500,"was to fake it till you make it."],[4991,5045,"But now,"],[5112,5200,"for the first time,"],[5287,5454,"being me finally feels like enough."]]}