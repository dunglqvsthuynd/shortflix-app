{"1":[[475,675,"Whoa, who is she?"],[750,808,"I heard"],[841,979,"her dad is a Wall Street tycoon"],[979,1162,"and her mom is an opera singer."],[1245,1366,"I've heard she speaks"],[1366,1533,"over six languages."],[2295,2329,"Dude,"],[2329,2550,"she is totally checking you out"],[2550,2600,"right now."],[2641,2729,"She's headed straight"],[2729,2820,"for Brooks Whitmore."],[2833,2925,"Of course she is."],[2962,3091,"He owns the Upper East Side."],[3570,3679,"Holy shit,"],[3691,3875,"she totally swerved the richest"],[3875,3983,"and coolest guy in our class."],[5316,5429,"Your eyes are so..."],[5595,5670,"Are you okay?"],[5808,5858,"Thank you."],[5858,5908,"Um."],[6041,6095,"You're hurt."],[6112,6191,"Let's get you out of here."],[6266,6320,"Come on."],[6625,6675,"Oof."],[6800,6850,"Damn bro,"],[6916,7050,"I totally thought she was feeling you"],[7050,7216,"but, guess she's more into your boy"],[7216,7262,"Preston."],[7354,7412,"Whatever."],[7441,7595,"She'll be yesterday's news by brunch."],[8079,8208,"Oh, no, please."],[8495,8666,"Don't Jay-Z and Beyoncé"],[8666,8750,"own the penthouse?"],[8845,8995,"I'll tell them you said hi."],[9104,9191,"Thanks for the ride."],[9266,9304,"Wait."],[9320,9416,"You hurt your ankle."],[9516,9600,"Let me help you inside."],[9650,9779,"You've already done so much."],[9908,10016,"My security will help me up."],[10175,10241,"Thanks."],[11145,11212,"Your payment,"],[11266,11333,"as promised."],[11416,11520,"Pleasure doing business."],[11529,11620,"Next time you want to fool"],[11620,11754,"another trust-fund dimwit"],[11754,11908,"into believing you're a real socialite,"],[11920,12000,"you know who to call."]],"2":[[250,375,"My name is Anna Sinclair."],[462,562,"Art school scholarship student"],[562,625,"by day,"],[675,837,"fake New York socialite by night."],[925,1050,"I was nobody in this city"],[1062,1175,"until I started pretending"],[1175,1250,"that I wasn't."],[1462,1550,"Am I living a lie?"],[1712,1775,"Definitely."],[1866,1987,"But it's the only way to escape"],[1987,2137,"the hell my parents put me through."],[3137,3275,"OMG."],[3291,3375,"Have you seen"],[3375,3525,"the Gilded Gazette's Instagram?"],[3562,3750,"Girl, look at the comments."],[3779,3929,"Everyone is talking about you."],[3979,4041,"You said you wanted"],[4041,4187,"to break into the high society"],[4187,4366,"and here you are breaking the fuck in."],[4400,4500,"I know you need a rich boy"],[4500,4616,"to fund your escape,"],[4616,4775,"but promise me one thing."],[4816,5054,"You'll stay away from Brooks Whitmore."],[5129,5208,"He's a hottie,"],[5208,5262,"but"],[5262,5441,"he could blow your whole cover."],[5500,5541,"Don't worry."],[5612,5687,"I won't touch him."],[5762,5891,"Preston's no Brooks Whitmore,"],[5891,6150,"but he's rich, well-connected."],[6204,6287,"Becoming his girlfriend"],[6291,6400,"might be my best chance"],[6400,6512,"at starting a new life."],[6600,6766,"I'm not here to sleep with the enemy."],[7112,7229,"I just need a way out."]],"3":[[491,608,"You little brat!"],[629,741,"You think you can just run away"],[741,841,"and leave us behind?"],[866,962,"You're not going to Paris."],[962,1066,"You're not going anywhere."],[1091,1329,"Good luck trying to win your scholarship"],[1329,1416,"with all your work trashed."],[1416,1508,"with all your work trashed."],[1770,1858,"This is my work."],[1866,1979,"This is everything!"],[3404,3458,"Hello?"],[3508,3650,"I'm pretty sure there's a rule"],[3650,3795,"about calling a girl you just met"],[3795,3920,"within 24 hours."],[3991,4145,"But I'm breaking it."],[4158,4241,"I hope that's okay."],[4275,4391,"I won't hold it against you."],[4462,4625,"I found your necklace in my car."],[4666,4808,"I'm throwing a party tomorrow."],[4966,5087,"If you're free,"],[5100,5308,"why don't you come by and pick it up?"],[5358,5420,"I'd love to."],[5733,5891,"He's sweeter than I expected."],[5950,6087,"I wish I didn't have to lie to him,"],[6154,6250,"but it's the only way."]],"4":[[350,420,"Invitation?"],[466,595,"Preston Kingsley invited me."],[866,950,"Well, that's the tenth time"],[950,1058,"I've heard that one tonight."],[1125,1220,"Why don't you split an Uber"],[1220,1312,"back to New Jersey"],[1320,1454,"with the other party crashers?"],[1704,1745,"I-"],[1745,1850,"Just go get him."],[1850,1945,"He'll tell you that-"],[1954,2108,"Bitch, you're holding up the line."],[2133,2254,"What kind of loser shows up"],[2254,2433,"to a Kingsley party without an invite?"],[2433,2554,"Step aside, reject."],[2575,2733,"This is an exclusive event,"],[2754,2937,"not the sale racket at Forever 21."],[3491,3620,"That's Brooks Whitmore's car."],[4379,4525,"Oh my god, he's so hot."],[4533,4645,"I'm done playing nice."],[4654,4791,"You're blocking the VIP entrance."],[4820,4945,"Get out of the way."],[5487,5570,"Mr. Whitmore,"],[5583,5725,"she didn't have an invitation."],[5729,5883,"I couldn't let her in."],[5904,5995,"She's with me."],[6304,6433,"I'll take those invites, ladies."],[6833,6891,"Go home."],[6937,7070,"You're officially blacklisted"],[7095,7170,"from this club."],[7295,7345,"Let's go."]],"5":[[33,100,"Thank you."],[258,350,"I didn't do it for you."],[408,512,"I did it for Preston."],[1204,1266,"That's the girl"],[1266,1404,"from the Gilded Gazette post."],[1408,1679,"I heard she spends her summer holidays"],[1691,1816,"modeling for Balenciaga."],[2379,2487,"Anna, you made it."],[2491,2670,"You look incredible."],[2770,2891,"You kids go have fun."],[3045,3179,"You don't look too bad yourself,"],[3179,3241,"birthday boy."],[3312,3350,"Oh."],[3641,3729,"Thanks."],[3904,3995,"Now is it just me"],[3995,4220,"or is she even hotter"],[4229,4329,"than she was last time?"],[4345,4504,"There's something off about that girl."],[4529,4712,"Maybe it's because she's the first girl"],[4729,4929,"to ignore you in, like, forever."],[5075,5166,"Now, does the birthday boy"],[5166,5233,"want a drink?"],[5379,5504,"How can I say no to you?"],[5716,5841,"Time to pop bottles, Preston."]],"6":[[75,170,"I'm sorry."],[212,279,"What's the matter?"],[383,529,"Preston bored with you already?"],[1354,1545,"Anna, do you want some champagne?"],[1666,1745,"Little brother!"],[2320,2604,"All hail the painter of the Fracture."],[2604,2762,"Callahan Conservatory's"],[2762,3004,"most critically acclaimed artwork."],[3020,3175,"Her painting is everything."],[3204,3345,"She's an artistic genius."],[3366,3483,"I heard that the owner"],[3483,3629,"of the Empire State Building"],[3641,3841,"offered ten million to buy Fracture,"],[3845,3991,"but she's not accepting offers."],[4025,4091,"Fracture?"],[4375,4533,"Oh my God, it's her!"],[4645,4720,"Okay, okay,"],[4720,4862,"let's settle down."],[4941,5083,"And the winner of this year's"],[5083,5358,"coveted semester abroad scholarship"],[5358,5537,"in Paris goes to"],[5587,5733,"Lila Kingsley,"],[5987,6433,"for her work on the painting, Fracture."],[6525,6629,"That's my painting."],[6675,6762,"How'd she get it?"],[6900,7016,"This belongs to you."],[7091,7250,"No, sir, that's my painting."],[7554,7637,"You know how important"],[7637,7791,"the semester abroad to Paris is to me."],[7820,7870,"I just-"],[7879,8070,"Are you really trying to say"],[8070,8250,"this is your painting?"],[8262,8483,"I painted Fragments months ago."],[8483,8554,"Fracture."],[8583,8741,"The painting is called Fracture."],[8754,8816,"Sir, she doesn't even"],[8816,8900,"Enough! - know the name."],[8958,9187,"Lila is a very talented artist"],[9191,9300,"and a Kingsley."],[9320,9450,"Why would she lie?"],[9479,9637,"How dare you attack her work"],[9637,9841,"just because yours doesn't measure up?"],[9875,9941,"Sit down."],[10783,10883,"Happy birthday."],[10916,11237,"Lila Kingsley, the girl who stole my"],[11237,11420,"painting is Preston's sister?"]],"7":[[325,395,"Preston,"],[458,525,"you didn't tell me"],[525,629,"you were bringing a date."],[658,775,"Oh, we met last night."],[850,983,"Anna, Lila."],[987,1120,"Lila, Anna."],[1154,1266,"Does she recognize me?"],[1337,1487,"Who the hell is this bitch?"],[1570,1670,"I better keep an eye on her"],[1670,1820,"in case she's really after my man."],[1975,2029,"Wait."],[2062,2300,"There's something familiar about her."],[2320,2529,"Have we met before?"],[2654,2762,"Oh, she, uh, she went to"],[2762,2879,"a Swiss boarding school."],[2900,2991,"You could have never met her."],[3008,3229,"Oh my god, Switzerland!"],[3275,3400,"The holes in the cheese."],[3420,3566,"So genius."],[3629,3716,"Less calories."],[3850,3966,"That was close."],[4058,4133,"This Anna girl"],[4133,4258,"acts like she belongs here,"],[4287,4404,"but I've never even heard of her"],[4404,4508,"before last night."],[4545,4625,"Neither have I."],[4670,4808,"Let's put her to the test,"],[4833,5087,"see if she's really one of us."]],"8":[[104,154,"Yo!"],[275,333,"Let's be real."],[333,512,"This party's getting a little bit lame,"],[512,691,"so how about we spice it up"],[691,804,"with a competition?"],[850,1162,"How about a game of the burning bet?"],[1195,1300,"New girl, you in?"],[1362,1495,"It is the most popular game"],[1495,1595,"on the Upper East Side."],[1650,1837,"You are from the Upper East Side,"],[1895,1937,"aren't you?"],[2112,2191,"Of course I am."],[2350,2412,"Let's play."],[2587,2625,"Okay."],[2625,2691,"Well, you"],[2795,2925,"are going to need some competition."],[3320,3408,"You think you belong"],[3408,3545,"in New York high society?"],[3908,3970,"Then prove it."],[4095,4145,"You're on."]],"9":[[41,158,"So the name of the game"],[191,370,"is the burning bet."],[437,470,"Now see,"],[470,566,"one of these paintings"],[566,637,"is a Monet"],[637,766,"valued at millions of dollars"],[766,1045,"and the others are worthless fakes."],[1075,1270,"Each of you will pick one"],[1270,1445,"and, uh, burn it."],[1491,1562,"If you pick wrong,"],[1587,1700,"that is going to cost you"],[1716,1841,"three million dollars."],[2058,2170,"Okay, so,"],[2279,2404,"who wants to go first?"],[3187,3291,"Go easy on her, dude."],[3329,3475,"No chance, birthday boy."],[3608,3704,"No pressure, new girl."],[3720,3875,"Just three mil, alright?"],[4262,4325,"Three million?"],[4395,4554,"I can't even afford three hundred."],[4795,4879,"You know a masterpiece when"],[4879,4979,"you see one, Anna."],[5208,5295,"You can do this."]],"10":[[1108,1208,"It's a fake."],[1212,1470,"Anna survives round one."],[2050,2120,"Lucky guess?"],[2304,2437,"Of course it was."],[2479,2604,"What does she know about art?"],[3708,3795,"Yeah, well of course,"],[3795,3970,"Brooks knows his art."],[4004,4087,"Second fake."],[4570,4641,"Game over?"],[4712,4783,"Not quite."],[6925,7075,"Are you clinically insane?"],[7075,7200,"That was a three million"],[7200,7295,"dollar painting."],[7295,7358,"What are you-"],[7358,7508,"All three paintings were fake."],[7595,7712,"The real masterpiece,"],[7758,7845,"it's been right there."]],"11":[[704,870,"I guess you know your art after all."],[937,1033,"Oh my God."],[1054,1175,"How did Anna know that?"],[1204,1433,"She must be like real old money."],[1470,1600,"I bet she has a private gallery."],[1625,1791,"No one pulls off a move like that"],[1791,1941,"without knowing exactly"],[1950,2020,"what they're doing."],[2104,2170,"Who are you,"],[2216,2304,"Anna Sinclair?"],[2504,2600,"Who even is she?"],[2637,2716,"I've never seen someone"],[2716,2975,"walk in and just own a room like that."],[2983,3104,"I don't know where she came from,"],[3112,3333,"but she's got every guy in that room"],[3333,3383,"watching her."],[3383,3437,"Right?"],[3504,3600,"And did you see Brooks?"],[3637,3895,"He's never looked at Lila like that."],[3908,3995,"Oh my God,"],[3995,4220,"if I was Lila, I would totally-"],[4350,4387,"Lila."],[4491,4662,"I didn't even hear you come in."],[4708,4770,"Clearly."],[4870,4941,"We should go."],[4954,5220,"You look super cute tonight."],[5750,5937,"That little whore Anna better keep her"],[5937,6137,"hands off Brooks."],[6287,6395,"Hi, I'm so sorry."],[6395,6466,"I know I was supposed to"],[6466,6608,"return the dress I rented today, but-"],[6725,6800,"No, well you see,"],[6800,6895,"some, something came up"],[6912,7070,"and so I had to wear it tonight."],[7158,7362,"No, no, it's not damaged."],[7458,7591,"Okay, can I return it tomorrow?"],[7687,7870,"Okay, okay, thank you."],[9470,9541,"Oh my God,"],[9579,9716,"you are so not going to believe"],[9716,9804,"what I just heard."]],"12":[[54,145,"There she is."],[162,241,"Let's go, girls."],[554,666,"Oh my God."],[704,995,"Anna, that dress is gorge."],[1041,1120,"Is it custom?"],[1154,1229,"Uh, thanks."],[1229,1350,"It, it was actually my mom's."],[1466,1525,"Liar."],[1670,1795,"What are you talking about?"],[1804,1962,"That dress is second-hand,"],[2000,2300,"just as dirty and used-up as you."],[2370,2454,"Excuse me?"],[2462,2625,"Lila told us about your little scam."],[2670,2754,"This is couture."],[2783,2841,"If you so much"],[2841,2933,"as rip as one thread-"],[2933,3158,"You can act like you belong in"],[3158,3304,"Upper East Side high society"],[3304,3387,"all you want,"],[3387,3591,"but you will never be one of us."],[3654,3762,"Why don't you go back to"],[3762,3958,"whatever gutter you crawled out of?"],[5137,5262,"Just admit it."],[5354,5633,"You're a fake socialite, aren't you?"]],"13":[[137,266,"Lila told me you were taking her"],[266,416,"to the debutante ball."],[466,537,"I guess so."],[583,670,"You sound thrilled."],[691,766,"I thought her"],[766,895,"award-winning painting"],[895,995,"spoke to you."],[1075,1220,"Bro, it's pretty obvious"],[1220,1320,"you're not into her like that."],[1341,1575,"You know, maybe it's time to call it quits?"],[1583,1783,"You know, I'd trust you with my life, P,"],[1866,1962,"but I would never"],[1995,2158,"take relationship advice from you."],[2250,2345,"What's that supposed to mean?"],[2383,2516,"That girl you brought tonight,"],[2645,2741,"she's playing you."],[2766,2904,"I don't know what she's after"],[2912,3116,"but I'd say it has something to do"],[3116,3195,"with your last name."],[3258,3366,"That's bullshit."],[3379,3433,"Help!"],[3504,3529,"No-"],[3529,3662,"Oh shit, that's her!"],[3775,3958,"What do you want with my brother?"],[4000,4158,"Preston invited me here."],[4166,4270,"Of course he did."],[4308,4491,"We all saw your little damsel"],[4491,4662,"in distress act last night."],[4700,4812,"But let's see what he thinks of you"],[4812,4975,"when he finds out who you really are."],[5016,5162,"Is this about Preston"],[5225,5295,"or Brooks?"],[5316,5445,"Shut up."],[5541,5620,"I mean, he's hardly even"],[5620,5720,"acknowledged you all night-"],[5720,5841,"I said shut up."],[5937,6116,"You can use that pretty little face"],[6116,6212,"to fool the guys,"],[6241,6433,"but you cannot fool me."],[6741,6808,"Hold her down."],[7233,7395,"Brooks won't look at you twice"],[7395,7566,"if you have a face full of scars."],[7725,7837,"Get your hands off of her."]],"14":[[375,512,"What the hell is going on here?"],[1300,1420,"I said I want the money, bitch!"],[1420,1504,"Where's the money?"],[1516,1579,"Mommy!"],[1604,1662,"Mommy!"],[1675,1758,"No!"],[1945,2025,"Mommy!"],[2033,2120,"No!"],[2175,2237,"Mommy!"],[2250,2312,"Mommy!"],[2354,2483,"I don't know what Anna's hiding,"],[2495,2591,"but that tattoo,"],[2616,2754,"it makes me want to protect her."],[3100,3254,"What the hell is wrong with you, Lila?"],[3304,3450,"She's a, a fake."],[3450,3537,"She's a liar."],[3575,3729,"She's not even rich."],[3770,3883,"What are you even talking about?"],[3883,4062,"Her dress is rented."],[4079,4187,"She's a broke nobody"],[4187,4420,"who's only using you to get to Brooks."],[4466,4737,"I caught that fake ass charity case"],[4737,4904,"in the bathroom and I-"],[4920,4979,"Seriously?"],[5095,5329,"I wasn't going to do anything."],[5329,5500,"I just wanted her to come clean."],[5520,5716,"Go home, Lila."],[5754,5795,"No."],[5854,5925,"No way."],[5933,6058,"She's a fraud."],[6183,6333,"You believe me, don't you, Brooks?"]],"15":[[20,179,"You don't want me to leave, do you?"],[308,362,"Yes."],[441,591,"Escort Ms. Kingsley from the building."],[591,650,"What?"],[933,1058,"Do you seriously not remember"],[1058,1162,"where you are right now?"],[1241,1433,"My father owns this fucking place."],[1458,1516,"Do you really think"],[1516,1725,"I'm going to let you humiliate me here?"],[1775,1891,"You're going to regret this."],[1933,1995,"What?"],[2070,2154,"Get her out of here."],[2191,2295,"She's banned for life."],[2316,2370,"What?"],[2391,2454,"No."],[2675,2812,"I'm so sorry, Anna."],[2962,3020,"Come with me."]],"16":[[812,941,"Thank you so much, Preston."],[987,1216,"I don't know what Lila's deal is, Anna,"],[1291,1404,"but I promise you,"],[1450,1562,"I won't let her do that to you"],[1562,1629,"ever again."],[2154,2379,"Well, let me get you some dry clothes."],[4066,4150,"Mm, one minute."],[4500,4579,"What are you doing here?"],[4662,4779,"I should be asking you"],[4829,4929,"the same question."],[6100,6250,"I'm not buying your act."],[6300,6562,"I know who you really want."]],"17":[[8,91,"What act?"],[175,287,"You're cute, Brooks,"],[287,441,"but I want Preston."],[620,775,"Oh, yeah?"],[975,1195,"A beautiful girl with an eye for art"],[1225,1400,"and a tattoo of my favorite flower"],[1437,1637,"just waltzes in to my club,"],[1687,1800,"and I'm crazy"],[1808,1937,"for thinking she wants me?"],[1995,2229,"You ungrateful little shit!"],[2316,2629,"We made you, so we own you."],[4358,4500,"How could l want Brooks?"],[4537,4670,"That semester abroad was,"],[4716,4829,"was my ticket to Paris."],[4900,5050,"My one chance to escape, to have a"],[5050,5116,"better life."],[5162,5325,"He would never understand that."],[5437,5554,"Not everything is about you,"],[5554,5637,"Brooks Whitmore."],[6241,6420,"I hate shady girls."],[6520,6625,"Whatever you're up to,"],[6720,6908,"don't drag me into it."],[7129,7183,"Don't worry."],[7291,7395,"I never wanted you."],[7745,7795,"Anna?"],[7870,7920,"Preston."]],"18":[[166,300,"What's going on here?"],[416,466,"Nothing."],[591,695,"Brooks was looking for you."],[1204,1316,"Don't mind Brooks."],[1354,1545,"He's always got a stick up his ass."],[1641,1775,"He only cares about himself"],[1775,1950,"and stuffy shit like art."],[2000,2054,"And he's like,"],[2070,2291,"obsessed with this painting Lila did."],[2333,2475,"I think it's called, um..."],[2612,2666,"Fracture."],[2695,2783,"Fracture?"],[2854,2975,"That's not Lila's painting,"],[2975,3037,"it's mine."],[3054,3133,"You should put this on."],[3133,3283,"I brought it for you."],[3595,3750,"I wish all guys were as sweet as you."],[4237,4312,"Brooks!"],[4400,4575,"That little bitch is a liar."],[4625,4700,"She's not one of us."],[4700,4854,"She's not even in this tax bracket."],[4854,4970,"She just wants to get to Preston"],[4970,5008,"so she-"],[5145,5358,"Don't wear that necklace anymore."],[5487,5545,"Why?"],[5583,5645,"Roses."],[5741,5866,"They mean something to me."],[6575,6695,"Seeing that around your neck"],[6770,6854,"just makes me feel"],[6966,7016,"cheap."],[7295,7487,"First that little bitch turns my own brother"],[7487,7666,"against me, and now Brooks?"],[7708,7900,"The second l fnd out who she"],[7900,8200,"really is, l'm going to destroy her."]],"19":[[145,341,"So, I'm so sorry this is late."],[362,516,"I was hoping to return this."],[591,695,"Oh my God!"],[754,908,"What the hell did you do to it?"],[1091,1179,"It's ruined."],[1200,1333,"I can't take that back."],[1395,1616,"And you owe $75,000"],[1616,1720,"to replace it."],[1733,1887,"Can you even afford that?"],[1966,2008,"Uh."],[2033,2145,"No, but"],[2208,2329,"I, I was thinking"],[2329,2433,"maybe this would cover it."],[2741,2825,"Oh my God."],[2945,3020,"Is this"],[3100,3158,"custom?"],[3241,3300,"Yeah."],[3666,3833,"Lotus flower silk."],[3908,4045,"Impossible to find."],[4475,4612,"I'll give you $100,000 for it."],[4900,5050,"Thank you, Preston."],[5400,5579,"You've been ignoring my calls all day."],[5595,5716,"Then I find you here shopping."],[5812,5858,"How dare you"],[5858,5962,"spend thousands of dollars"],[5962,6045,"on useless gowns"],[6045,6129,"when you know your dad and I"],[6129,6191,"need money?"],[6204,6408,"Good thing I sold your stupid paintings"],[6420,6533,"before they started rotting away"],[6533,6595,"in the garage."],[6704,6920,"My paintings? ls that how Lila won"],[6920,7025,"my scholarship?"],[7025,7245,"Did my mom sell my art to Lila Kingsley?"],[7300,7445,"Mom, someone stole my paintings"],[7445,7541,"and my scholarship."],[7570,7683,"I mean, did you know about that?"],[7941,8041,"Did you have big dreams"],[8041,8154,"of running away to Paris"],[8154,8291,"and starting a new life?"],[8341,8395,"Wake up!"],[8429,8525,"That's not who you are."],[8587,8700,"You'll never escape us."],[9116,9187,"Are you okay?"],[9404,9483,"Fine."],[9900,10108,"I knew that grimy bitch was a fake."]],"20":[[54,170,"That scammer"],[170,370,"does not belong in our world."],[387,508,"And I'm going to make sure"],[508,662,"she never forgets it."],[945,1054,"What can you tell me about the girl"],[1054,1154,"who just walked out of here?"],[1529,1620,"Her name is Anna."],[1670,1804,"She comes in here all the time."],[1837,1983,"Never to buy, only to rent."],[1983,2137,"I think she's like broke or something."],[2150,2220,"But the owner lets her"],[2220,2345,"have discounts on rentals"],[2345,2441,"because her paintings are"],[2441,2516,"in the store."],[2516,2745,"But I think something else"],[2745,2837,"might be going on."],[2908,2958,"Huh."],[3025,3083,"Perfect."],[3650,3758,"What do you want, Lila?"],[3762,3829,"Presty,"],[3850,3958,"you're not still mad at me"],[3958,4083,"about yesterday, are you?"],[4100,4187,"I'm hanging up now."],[4200,4250,"Wait!"],[4287,4500,"I was wrong to call Anna out like that."],[4554,4787,"And I want to apologize."],[4866,4937,"Do you think"],[4950,5091,"maybe you could invite her"],[5091,5241,"to the Gatsby