ecause you're jealous."],[3854,3916,"Preston."],[4104,4191,"I'm inviting her parents"],[4191,4262,"over for dinner."],[4375,4558,"If you need proof she belongs here,"],[4604,4725,"why don't you come meet them yourself?"],[6425,6462,"Hello?"],[6504,6550,"Anna,"],[6612,6750,"I want you to come to Paris"],[6750,6841,"with me this summer."],[6933,7075,"Summering with Preston in Paris?"],[7075,7250,"This is what I've worked for."],[7291,7358,"The chance to finally"],[7358,7475,"escape my parents."],[8200,8316,"I, I'd love to-"],[8316,8591,"Wait, before I officially ask you,"],[8625,8762,"I want you to come to dinner"],[8779,8929,"with my family on Saturday."],[8979,9162,"Oh, bring your parents too."],[9191,9250,"My parents?"]],"32":[[37,112,"My parents?"],[179,350,"Are they still in Switzerland?"],[562,625,"Uh..."],[1129,1279,"If I want to go to Paris with Preston"],[1279,1404,"then he can't find out I've been faking my"],[1404,1566,"socialite status the whole time."],[1654,1854,"There's no way he can meet my parents."],[2000,2137,"At least not my real parents."],[2462,2566,"They'll be back next week."],[2608,2650,"Perfect."],[2675,2775,"I'll see you Saturday."],[3462,3562,"Roses?"],[3712,3837,"But that rose tattoo..."],[3891,3937,"Whatever."],[3962,4054,"I'm taking the stairs."],[4625,4737,"Why am I thinking about Brooks"],[4737,4787,"right now?"],[4862,5029,"Preston is my way out."],[6575,6675,"Brooks."],[6804,6887,"Take me."],[6937,7025,"I'm yours."],[10062,10154,"Dreaming about Anna?"],[10237,10362,"What the hell is wrong with me?"],[10900,10950,"It's cool."],[11025,11083,"I'll be there."]],"33":[[1587,1670,"Convince the Kingsleys"],[1670,1800,"that you're my real parents."],[1870,1983,"There's more where that came from."],[2283,2383,"You can count on us."],[2395,2562,"We've been acting together for years."],[2766,2866,"If I don't pull this off,"],[2933,3041,"then I'll lose my shot"],[3041,3158,"at finally escaping the hell"],[3158,3266,"my parents trapped me in."],[