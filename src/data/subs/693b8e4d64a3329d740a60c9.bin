cept for..."],[2665,2723,"Me."],[3003,3061,"All right then,"],[3140,3236,"no sex business."],[3294,3403,"Let's make another kind of deal."],[3549,3949,"I know all about you and Damien Vale."],[4074,4124,"Him and I"],[4124,4237,"are actually business rivals."],[4404,4508,"Take him down for me,"],[4608,4708,"and I'll set you free."],[4746,4838,"No more clients."],[4967,5117,"Not in a million years."],[5134,5321,"It's either him or you."],[5459,5551,"Think about it."]],"57":[[87,346,"I refuse to hurt him again."],[3424,3495,"It's you."],[3616,3699,"Vivienne, I'm sorry."],[3699,3728,"I didn't"],[3728,3791,"You think this is - do it-"],[3791,3891,"some kind of game?"],[3891,4016,"Getting back at me like this?"],[4016,4129,"No, I wasn't trying to mess with you,"],[4129,4166,"I just-"],[4166,4291,"Oh, whatever."],[4371,4425,"Whatever."],[4504,4604,"I guess we're even now."],[4846,4934,"Vivienne, wait."],[5434,5480,"What happened-"],[5480,5597,"Shut this place down."],[5597,5776,"Sir, I can get you another girl."],[5776,5930,"Someone who'll put out more."],[5972,6135,"Do you know who my boss is?"],[6135,6293,"This is Damien Vale."],[6644,6881,"You, you care about Vivienne?"],[6881,7015,"Damn right I do."],[7015,7136,"Places like this shouldn't exist,"],[7136,7278,"treating women like bargaining chips."],[7486,7649,"You need to treat Vivienne better."]],"58":[[104,379,"Hi, I, I got a call from my mom, Ariel Cross."],[379,496,"They said it was an emergency."],[496,692,"She's been moved to a private ward."],[792,850,"Private?"],[850,980,"Yeah, it's just down the hall."],[980,1034,"Thanks."],[1247,1355,"Aw, that's a cute story."],[1368,1401,"Yeah."],[1401,1522,"Did she ever wear braces?"],[1647,1697,"Yeah."],[1697,1797,"What was she like as a kid?"],[1818,1926,"She was the sweetest-"],[1926,2018,"Damien."],[2185,2256,"Viv."],[2339,2389,"Oh!"],[2389,2498,"Glad you're finally joining us."],[2631,2794,"Vivienne, sweetheart,"],[2794,2986,"you didn't tell me you got engaged."],[3061,3294,"And to think I was so worried about you"],[3294,3457,"after Martin passed."],[3511,3741,"Excuse us for one minute, Mom."]],"59":[[8,129,"What the hell are you doing here"],[129,196,"with my mom?"],[196,350,"Is this some sort of elaborate plot"],[350,421,"for revenge?"],[421,567,"I wanted to apologize."],[588,679,"Thought I'd pay my future"],[679,813,"mother-in-law a visit."],[867,1009,"Pay off her medical bills and everything."],[1009,1184,"I already gave you the ring back."],[1184,1238,"I told you"],[1238,1409,"the engagement is off."],[1559,1672,"Check your purse."],[2706,2798,"How did you?"],[3824,3958,"Queen Seductress"],[3958,4095,"didn't notice me slip that in?"],[4145,4287,"You're losing your touch, Miss V."],[4375,4546,"Now it's my turn to seduce you."]],"60":[[550,688,"We're in public."],[688,884,"Mr. Vale, have some decency."],[884,1038,"While you conduct your seduction"],[1038,1134,"in private,"],[1180,1292,"I like to keep my affairs out"],[1292,1384,"in the open."],[1447,1534,"As you've discovered,"],[1534,1609,"I'm an escort."],[1609,1910,"So why would you wanna be with me?"],[1968,2114,"You don't sleep with your clients,"],[2181,2469,"though you did break your no intimacy rule"],[2569,2665,"for me."],[2786,2944,"That was one time."],[3090,3253,"You want me, Viv."],[3294,3407,"I can feel it."],[3440,3586,"And I want you too."],[4688,4771,"What?"],[5347,5563,"Sabrina was found innocent for Martin."]],"61":[[25,79,"What?"],[333,404,"How?"],[425,521,"I mean,"],[521,663,"they still got her on child abuse,"],[663,855,"but they said they couldn't find"],[855,971,"your late husband's body."],[1042,1109,"They couldn't prove"],[1109,1188,"she murdered anyone."],[1280,1493,"No, that, that can't be true."],[1493,1718,"I, I buried him with my own hands."],[1718,1889,"I saw them seal the coffin."],[2022,2097,"Here, come with me."],[2473,2569,"Mr. Vale."],[2569,2731,"What did you guys do?"],[2752,2823,"Why did you touch"],[2823,2948,"my husband's grave?"],[2977,3128,"We dug and..."],[3232,3428,"Well, what did you find, boys?"],[3461,3582,"I'm sorry, Miss Vivienne."],[3582,3703,"Your late husband's body"],[3703,3828,"was nowhere to be found."],[3828,4033,"It's as if he was never here."],[4283,4362,"What?"],[4466,4579,"No, no, no, no, no."],[4617,4733,"This, this can't be."],[4733,5038,"I, I buried him myself, okay?"],[5038,5134,"Sabrina murdered him."],[5134,5313,"I, I even lost my baby."],[5388,5492,"What are you talking about?"],[5492,5572,"There was,"],[5668,5705,"there was,"],[5705,5834,"there was so much blood."],[6389,6464,"Martin."],[6523,6594,"Vivienne!"]],"62":[[266,342,"No."],[425,508,"No, no, no!"],[508,588,"I won't tell a soul."],[608,671,"I have a wife,"],[671,759,"and a baby coming. - No, no."],[759,817,"Please."],[846,959,"Don't hurt him, please."],[1046,1113,"Fuck!"],[1205,1276,"Martin."],[2890,2952,"It's okay."],[3090,3219,"You're safe with me."],[3749,3887,"Baby, no, no, no, no, no."],[3887,4016,"What are you doing?"],[4016,4099,"You're pregnant."],[4099,4183,"Come on."],[4183,4446,"I'm pregnant, not disabled,"],[4446,4683,"and you're already picking up"],[4683,4779,"so many extra shifts"],[4779,4959,"to get everything ready for the baby."],[5201,5292,"That's my honor,"],[5342,5434,"as your husband,"],[5480,5618,"and our baby's father."],[6385,6448,"I never left"],[6448,6577,"because I wanted to keep everything"],[6577,6840,"exactly the way it was."],[6915,7032,"To remember him,"],[7211,7482,"to remember my reason for revenge."],[7841,7987,"And where is he now?"]],"63":[[141,337,"Maybe it's time to let go of the past."],[396,554,"You're a good and kind soul, Viv."],[554,663,"Vengeance never swallowed"],[663,742,"your heart."],[771,888,"Even when you could have really hurt me,"],[888,1038,"you just walked away."],[1217,1584,"Sabrina ruined everything for me."],[2031,2189,"There was a baby in here."],[2252,2398,"A live, kicking fetus."],[2398,2498,"Two more weeks,"],[2602,2752,"and he could have seen the world."],[2857,2994,"Whatever Sabrina or others"],[2994,3098,"have done for you,"],[3178,3328,"let me take care of it."],[3520,3678,"I'll carry that weight for you."],[3745,3816,"Why?"],[3928,4045,"Because I want you to be mine,"],[4104,4179,"Vivienne."],[4425,4529,"Now if I give you the answers,"],[4529,4758,"will you promise me to move on?"]],"64":[[433,538,"What is this, Damien?"],[592,667,"I thought you said you were gonna"],[667,746,"give me answers."],[763,842,"Oh, I am."],[1013,1126,"My mother's engagement ring"],[1151,1247,"she left behind."],[1309,1418,"The one you protected and"],[1497,1593,"refused to take."],[1685,1797,"It's the key to this vault."],[1968,2043,"I wasn't joking"],[2043,2127,"when I said it was the key"],[2127,2231,"to endless riches."],[2277,2439,"I don't care about money, Damien."],[2477,2610,"You should know that by now."],[2686,2827,"I know you're not a gold-digger."],[2957,3019,"But go ahead,"],[3061,3207,"set this ring on the statue head."],[3253,3415,"It'll give you all the answers you need."],[4617,4692,"No."],[4804,4975,"I won't, and you can't make me."],[5042,5130,"But I can."],[5405,5484,"Martin?"]],"65":[[383,458,"Martin?"],[896,963,"What?"],[1026,1113,"You're alive."],[1284,1434,"No, no, it's not safe. - What? What?"],[1463,1609,"What, my husband is alive?"],[1609,1710,"I can't believe it."],[1710,1839,"Yeah, he faked his own death."],[1856,2039,"That's right, I did."],[2268,2364,"You discover things"],[2364,2527,"when you work at the Vale Mansion."],[2740,2865,"Sometimes ugly,"],[2927,3148,"as you've discovered as a maid, Vivienne."],[3148,3415,"Sometimes, a pleasant surprise."],[3470,3657,"I give this ring to my son, which opens"],[3657,3895,"a vault to my most prized possessions."],[3916,4216,"Such as the vault hidden in this room."],[4521,4704,"And the only one who can open it"],[4704,4863,"is the one who holds the engagement ring,"],[5271,5509,"the one Damien wishes to marry."]],"66":[[362,550,"Why won't any of you touch me?"],[550,696,"I knew Sabrina was never gonna"],[696,863,"get access to the vault."],[863,963,"Damien doesn't want"],[963,1163,"that crazy hyena at all."],[1230,1372,"But you, Vivienne,"],[1426,1847,"demure, pretty, and wicked clever."],[1976,2147,"Who wouldn't want you?"],[2193,2331,"You faked your death?"],[2402,2498,"You had Madame Rouge,"],[2498,2560,"your aunt-"],[2581,2652,"Miss V,"],[2694,2886,"your services have been requested."],[2919,3103,"groom me and manipulate me"],[3103,3282,"just to push me to Damien?"],[3407,3516,"Exactly."],[3561,3678,"I threatened Sabrina."],[3678,3766,"Stop!"],[3883,4058,"Or I'll have to tell your fiancé."],[4112,4287,"So she tried to kill me."],[4391,4483,"Little did she know,"],[4483,4696,"I paid off her man to let me go."],[4750,4917,"Then I faked my own death,"],[4917,5280,"so you, my loyal, beautiful wife,"],[5280,5509,"would go to my aunt for help."],[5605,5718,"And she delivered you"],[5718,5947,"to Damien like a doll."]],"67":[[0,100,"You used me."],[175,325,"I lost a child, our child,"],[325,483,"over what I thought was your murder."],[525,725,"Yes, yes, yes, yes."],[1076,1284,"I never really wanted a child, anyways."],[1405,1555,"I guess it all worked out for me."],[1605,1697,"Now,"],[1780,2022,"open the vault, woman."],[2093,2173,"Never."],[2565,2744,"Then I'll take it by force."],[2844,3007,"Vivienne, look out!"]],"68":[[467,667,"No, no, Damien, stay with me."],[667,750,"All you had to do"],[750,859,"was hand over the ring!"],[905,1042,"You want it that bad?"],[1105,1188,"Take it."],[1393,1564,"The key to the vault."],[1643,1889,"All the riches in the world."],[2131,2394,"Thanks for getting me this far."],[2394,2456,"I couldn't have done it"],[2456,2569,"without you, Viv."],[3157,3244,"Oof."],[4049,4154,"Wake up, Damien."],[4279,4396,"It's time for the finale."]],"69":[[1780,1897,"Rookie mistake."],[2352,2423,"Did you really think"],[2423,2598,"a vault filled with endless riches"],[2598,2736,"wouldn't be booby-trapped?"],[3161,3269,"We figured you weren't"],[3269,3370,"actually dead,"],[3370,3490,"and had ulterior motives,"],[3490,3724,"so... we came prepared."],[4008,4162,"I did everything for you."],[4200,4312,"I lost a baby."],[4312,4433,"I went penniless."],[4458,4671,"Even put myself in harm's way."],[4842,5059,"Just to avenge you."]],"70":[[604,792,"And now you've avenged your baby."],[1101,1197,"You don't get to use Viv,"],[1197,1284,"and get away with it."],[1430,1572,"Attempted murder and robbery."],[1572,1634,"No, no, no!"],[1634,1785,"That's a lifetime in prison."],[1822,1939,"Can't fake your way out of that."],[1960,2035,"Thank you,"],[2085,2135,"Martin."],[2160,2227,"If it wasn't for you,"],[2227,2327,"I wouldn't have the ring,"],[2360,2435,"the vault,"],[2485,2590,"and most importantly,"],[2823,2944,"the love of my life."],[3370,3411,"No, no, no!"],[3411,3490,"Wait, wait, wait!"],[3490,3595,"It was a joke!"],[3632,3766,"Where's your sense of humor?"],[3766,3874,"It was a joke!"],[4241,4325,"So you finally admit"],[4325,4487,"your feelings for me, Miss V?"]],"71":[[704,754,"You're really not"],[754,880,"holding back anymore, are you?"],[959,1096,"It feels so damn good."],[1864,1989,"After you, my lady."],[5551,5693,"Wanna do the honors?"]],"72":[[371,500,"This is beautiful."],[579,667,"My mother was one of the most"],[667,750,"sought-after designers"],[750,825,"in the world."],[850,980,"Before she gave it all up for my father."],[1121,1213,"These are all her designs."],[1343,1493,"All high-level techniques."],[3507,3770,"Damien, l'm sorry I couldn't give you"],[3770,3941,"the picture-perfect childhood."],[3941,4091,"l married the wrong man."],[4116,4187,"He was neither a"],[4187,4421,"good husband nor a good father..."],[5597,5722,"But you"],[5793,5893,"will be different."]],"73":[[296,450,"I don't have long to live,"],[521,704,"and it saddens me that I won't be able"],[704,821,"to see you grow up."],[888,1101,"I won't be able to see you get married,"],[1142,1384,"or meet any of my future grandchildren."],[2264,2431,"So I'm leaving behind"],[2431,2656,"everything I have to you,"],[2698,2831,"and your true love."],[2831,2936,"My true love."],[3428,3524,"A Queen Seductress"],[3524,3653,"who came for revenge,"],[3724,3933,"whose only goal was to seduce me,"],[4024,4116,"take my heart,"],[4187,4291,"make me fall for her."],[4408,4475,"Damien, I-"],[4508,4575,"Don't."],[4934,5042,"I'm glad you came."],[5180,5284,"And I'm glad I fell."],[5442,5551,"Because you fell with me."],[6243,6443,"Looks like I found my match."]],"74":[[3632,3837,"Bewitch the mind."],[3958,4295,"Ensnare the senses."],[4542,4637,"Arouse his..."],[4683,4988,"Arouse his imagination!"],[5430,5576,"You're perfect, Miss V."],[6831,6927,"Checkmate,"],[6981,7073,"Mr. V."]]}