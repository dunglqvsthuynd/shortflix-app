"Tonight,"],[5246,5442,"I want everyone to see"],[5442,5538,"who you really are."],[5634,5747,"You're kind,"],[5776,5943,"compassionate, brilliant,"],[5997,6114,"unbreakable."],[6160,6406,"And I mean no one will ever"],[6414,6556,"speak down to you again."],[6639,6760,"I don't need the world's approval,"],[6760,6794,"Mom."],[6877,6944,"I have everything"],[6944,7086,"I could ever want right here."],[7236,7344,"My sweet daughter."],[7745,7816,"Ladies and gentlemen,"],[7937,8012,"I have a very important"],[8012,8103,"announcement to make."]],"62":[[154,237,"Not only will my mother"],[237,321,"be coming back"],[417,513,"as the CEO,"],[538,663,"but I'm proud to announce as well,"],[763,855,"that my sister,"],[938,1001,"Grace,"],[1076,1188,"will be joining our team"],[1188,1272,"at the Phoenix Group"],[1363,1785,"as the youngest billionaire heiress."],[3123,3207,"To Grace. - To Grace."],[3249,3378,"To the Miller family. - To the Miller family."]]}