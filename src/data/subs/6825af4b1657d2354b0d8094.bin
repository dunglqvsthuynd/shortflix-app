{"1":[[1484,1534,"Doctor,"],[1568,1693,"is my mom going to be ok?"],[1710,1801,"I'm sorry Grace,"],[1847,2039,"she has a brain hemorrhage."],[2106,2227,"With immediate surgery,"],[2252,2381,"there is a chance,"],[2435,2477,"but..."],[2811,2969,"it'll will cost 500,000."],[2977,3048,"Five hundred?"],[3132,3311,"I don't have that kind of money,"],[3311,3449,"but mom needs me."],[3465,3599,"Oh, I'll find a way to get the money."],[3624,3778,"Please, just save my mom."],[3899,3978,"I can do that."],[4179,4312,"Grace Miller."],[4312,4400,"Oh, Rose."],[4425,4554,"Will, thank God you two are here."],[4600,4742,"Mom was working at the orphanage"],[4742,4850,"when she fainted, and"],[4850,5005,"it's going to cost 500 grand."],[5005,5142,"500 grand?"],[5276,5392,"And where are we supposed"],[5392,5459,"to get that?"],[5638,5747,"Call off the surgery, Doc."],[5747,5801,"There's no way"],[5801,5889,"we're paying for that."],[5955,5985,"Rose,"],[5985,6068,"what are you saying?"],[6110,6210,"She's our mom."],[6243,6398,"She adopted us, you can't just-"],[6398,6573,"And forced us to grow up dirt poor!"],[6589,6702,"She's a lowlife worker."],[6702,6848,"She doesn't deserve to be a mom."],[6848,6952,"If it wasn't for her,"],[6956,7044,"we could've been adopted"],[7044,7161,"by someone rich!"],[7165,7203,"What?"],[7244,7361,"Do you guys hear yourself?"],[7432,7624,"She took us in when we had nothing."],[7665,7766,"She gave us a home."],[7811,7853,"She made sure"],[7853,7974,"that we were never hungry"],[7974,8078,"and you're just mad at her"],[8078,8199,"because she's not rich?"],[8212,8295,"Speaking of money,"],[8370,8470,"today is Mom's payday."],[8808,8879,"This is Mom's."],[8917,9046,"Don't you dare touch it."],[9117,9205,"No, no!"],[9330,9480,"No, no, no, n-"],[10485,10598,"No."],[10839,10881,"No."],[10965,11094,"No, Mom worked hard for that."],[11119,11169,"Should be enough"],[11169,11294,"for a new iPhone though."],[11298,11386,"Mom needs that money"],[11386,11457,"for her surgery."],[11461,11561,"You can't just take it."],[11561,11628,"Sure we can."],[11653,11786,"That old hag's about to die."],[11820,11961,"Her money's ours now."],[12007,12091,"You want money?"],[12208,12266,"Pick it up."],[13505,13634,"Consider this our donation"],[13634,13726,"to Mom's surgery,"],[13918,13980,"or funeral."],[15223,15348,"I'll save you, Mom."],[15874,16061,"I can sell blood for money."],[16095,16199,"This is the only way"],[16199,16366,"I might be able to save Mom."]],"2":[[2648,2736,"Alright, take a seat guys."],[3036,3161,"Look, I've gathered you all here today"],[3161,3311,"for a very important announcement."],[3365,3440,"Fifteen years ago,"],[3449,3545,"my mother, Mary Miller,"],[3586,3737,"disappeared to live a quiet life"],[3737,3820,"in a small town."],[3874,3920,"But now,"],[4033,4129,"she is returning"],[4137,4270,"to take her rightful place"],[4270,4483,"as the CEO of the Phoenix Group,"],[4483,4546,"ladies and gentlemen."],[4546,4713,"The CEO has finally returned."],[4733,4929,"Ms. Miller raised her son alone"],[4942,5055,"to build Phoenix Group."],[5084,5246,"Now, after fifteen years,"],[5271,5384,"she is coming back."],[5405,5559,"Even out of the public eye,"],[5559,5676,"she remains a legend."],[5684,5830,"No one can match what she built."],[5864,5989,"So, although my mother's been living"],[5989,6068,"in seclusion,"],[6143,6243,"we've remained in contact"],[6243,6318,"over the years."],[6364,6510,"And she's adopted three children,"],[6552,6598,"who I believe"],[6598,6765,"will be joining our company very soon."],[6923,6956,"Sir,"],[7007,7094,"we can't find your mother,"],[7111,7232,"she isn't answering our calls."],[7311,7344,"What?"],[7411,7528,"My mother is missing?"],[7820,7941,"I want to sell my blood."],[8003,8058,"Please."],[8112,8262,"I, I have an extremely"],[8262,8333,"rare blood type."],[8362,8479,"Type AB negative."],[8546,8600,"You need it,"],[8600,8750,"and I need money"],[8750,8858,"for my mother's surgery."],[8900,8950,"Please."],[9317,9376,"Thank you."],[11031,11152,"We are at 400."],[11173,11332,"I have to stop now or you'll pass out."],[11332,11378,"No, no."],[11378,11453,"Don't, don't stop."],[11453,11557,"I, I can do it."],[11861,11941,"Just keep..."],[12024,12062,"Miss?"],[12062,12191,"Keep, keep going."],[12278,12320,"Miss?"],[12395,12437,"Miss?"],[12512,12558,"Miss?"],[12620,12666,"Miss?"]],"3":[[792,842,"Grace."],[925,1084,"I told you to go home and rest."],[1113,1213,"You just fainted"],[1213,1372,"from donating all that blood."],[1438,1530,"I'm fine, Doctor."],[1618,1685,"How's my mom?"],[1730,1893,"Well, the operation was a success,"],[1893,1926,"but..."],[2006,2047,"Grace,"],[2060,2173,"with your mother's condition,"],[2198,2248,"we're looking at"],[2248,2369,"some very expensive"],[2369,2456,"long-term care."],[2489,2656,"Oh, I, I got it, Doctor."],[2740,2823,"She's my mom."],[2902,3003,"I won't give up on her."],[3115,3236,"She's very lucky to have you."],[3286,3395,"I'll go work on the list"],[3395,3490,"of her medication."],[4099,4204,"You adopted me, Mom."],[4354,4596,"You taught me what family was..."],[4700,4792,"what love is."],[4854,4913,"Don't worry."],[4996,5125,"I'm not going to give up on you."],[5201,5334,"I'm going to make sure you get better."],[6310,6393,"It's been hours."],[6402,6502,"Where is Ms. Miller?"],[6539,6731,"If Ms. Miller says she's returning,"],[6756,6881,"then she will be coming back."],[6890,6956,"Otherwise,"],[6965,7165,"Mr. Miller will find her."],[7186,7369,"When she left fifteen years ago,"],[7386,7499,"she made all of us,"],[7499,7590,"even Mr. Miller,"],[7599,7766,"promise never to search for her."],[7966,8037,"Did you reach her?"],[8087,8145,"Her phone,"],[8208,8283,"it's completely dead."],[8283,8391,"She'd never let that happen,"],[8391,8429,"not on the day"],[8429,8554,"that she's supposed to return."],[8787,8896,"Something's not right."],[9096,9180,"Do whatever it takes,"],[9234,9355,"flip this city upside down."],[9355,9405,"I don't care,"],[9405,9567,"but we're going to find my mother."],[9613,9697,"Yes, sir. - Yes, sir."]],"4":[[462,546,"One day of work here"],[546,646,"will cover three days"],[646,759,"of Mom's medication."],[1484,1539,"Next."],[1543,1597,"No-"],[1643,1810,"Sir, I'm here to work."],[1822,1847,"Please,"],[1847,1972,"if, if there's any opportunity"],[1981,2047,"that you have,"],[2068,2198,"I would gladly take it."],[2210,2285,"Come on, Grace."],[2348,2402,"Everyone knows"],[2402,2489,"you passed out yesterday"],[2489,2556,"at the hospital."],[2560,2711,"I can't have you dying on my site."],[2731,2836,"I'll lose my damn job."],[2869,2940,"No, please, please."],[2969,3032,"I'm begging you."],[3090,3123,"Please,"],[3123,3244,"I really need the money."],[3282,3399,"My mom will die without it."],[3428,3574,"But with treatment,"],[3574,3607,"I mean,"],[3682,3753,"there's a chance"],[3753,3862,"that she may wake up."],[3958,4049,"But if I give up,"],[4049,4137,"it's over for her."],[4137,4191,"Please."],[4371,4412,"If I catch you"],[4412,4558,"slacking off one time,"],[4692,4884,"I won't pay you a single penny."],[5159,5255,"Thank you so much."],[5267,5334,"You can trust me."],[5342,5463,"I am a hard worker."],[5501,5551,"Thank you."],[5597,5659,"Next."],[5989,6068,"Don't worry, Mom."],[6097,6189,"I'll make enough money"],[6189,6281,"and you'll get better."],[8245,8341,"Alright, time for lunch!"],[8400,8462,"Get back to work"],[8462,8571,"as soon as you're finished!"],[8787,8833,"Grace."],[9063,9109,"Lucy."],[9109,9175,"What's wrong?"],[9184,9234,"You have to"],[9234,9380,"get home right now, Grace."],[9401,9471,"Your sister and brother"],[9471,9588,"are selling your mom's house."],[9642,9676,"What?"]],"5":[[221,346,"We've turned this whole house"],[350,450,"upside down."],[521,592,"I can't believe the old hag"],[592,721,"doesn't even have any savings."],[721,775,"Whatever,"],[775,846,"just forget it."],[846,942,"Let's get down to business."],[942,1063,"Where's the inheritance letter?"],[1151,1251,"You see this, Mom?"],[1388,1630,"You ruined our life at a better chance"],[1643,1755,"with a rich family."],[1810,2002,"Now with just one little stamp here,"],[2022,2143,"you'll give us what we deserve."],[2143,2331,"As if this old hag can hear you."],[2331,2469,"Just get it over with already."],[2877,2982,"What are you doing?"],[3303,3340,"Mom?"],[3374,3403,"Mom?"],[3403,3478,"Are you ok?"],[3987,4145,"You're trying to steal Mom's house?"],[4200,4270,"You can't do that."],[4270,4383,"Mom worked hard for it."],[4421,4454,"Fine."],[4504,4617,"If she doesn't want us to sell it,"],[4658,4717,"then we won't."],[4892,4934,"Go on,"],[4984,5025,"say it."],[5071,5138,"Say it!"],[5155,5238,"Hey, you old hag."],[5263,5342,"Is anyone there?"],[5367,5405,"Hello?"],[5426,5501,"Can you speak up?"],[5526,5584,"Speak up!"],[5643,5805,"Get your filthy hands off of her."],[5960,6022,"Be honest,"],[6035,6122,"you don't actually"],[6122,6231,"give a shit about Mom."],[6247,6402,"You're just putting on a little show,"],[6410,6569,"hoping she'll magically wake up"],[6569,6673,"and give you everything!"],[6677,6769,"No, that's not true."],[6777,6810,"That's-"],[6823,7007,"Oh, poor little Grace,"],[7019,7119,"trying so hard"],[7127,7290,"and your mommy can't even see."],[7494,7624,"If you don't want to take care of Mom,"],[7624,7699,"that's fine."],[7699,7799,"I'll do it myself."],[7820,7903,"But I'm not going to let you"],[7903,8028,"take anything away from her."],[8041,8153,"Try and stop us."],[8208,8237,"No."],[8879,8917,"Mom?"],[9096,9129,"Mom."],[9196,9292,"Your finger's moving."]],"6":[[16,120,"Would you look at that..."],[158,296,"she's actually losing it."],[492,558,"I saw it."],[558,663,"Her finger's moving."],[663,784,"She's trying to tell us something."],[784,963,"Mom's brain is mush."],[980,1138,"The only thing moving in her head"],[1159,1230,"are the worms"],[1230,1355,"eating the rest of it out."],[2911,3032,"You stupid bitch."],[3065,3257,"I'm tired of repeating myself."],[3282,3386,"Mom is dying."],[3407,3586,"Dead people don't need a house!"],[3707,3770,"You know,"],[3799,3883,"William and I"],[3883,4037,"just want the best for you,"],[4037,4108,"little sis."],[4175,4237,"Say,"],[4279,4391,"you and the mayor's son"],[4391,4521,"are the same age, right?"],[4550,4671,"Mayor's daughter-in-law"],[4671,4825,"sounds awfully nice."],[4954,4988,"What?"],[5075,5251,"The mayor's daughter-in-law?"],[5384,5526,"After you and the mayor's son"],[5534,5597,"tie the knot,"],[5605,5668,"we'll send..."],[5976,6331,"that to a nursing home far, far away."],[6385,6569,"She takes up too much space here."],[6606,6831,"So, there's the bride for my son?"],[7661,7724,"Well, son?"],[7761,7949,"She's the girl you said you liked, right?"],[8016,8091,"A real virgin,"],[8166,8241,"just like me."],[8312,8429,"All the other girls,"],[8429,8546,"they always run away,"],[8616,8671,"not you..."],[8783,8900,"You'll be my first."],[9021,9129,"Time to make you mine."],[9142,9205,"No, no!"],[9213,9313,"Don't touch me!"]],"7":[[4,66,"No, no!"],[75,175,"Don't touch me!"],[296,404,"You can't say no to me!"],[433,542,"My dad owns this town."],[542,729,"Nobody says no to me."],[767,825,"Look at you,"],[842,1030,"acting so high and mighty."],[1071,1201,"You're still selling your blood,"],[1209,1255,"aren't you?"],[1297,1409,"Just for a few pennies."],[1493,1747,"We offer you a way out of poverty,"],[1785,1985,"and this is the way you repay us?"],[2014,2227,"Do you know how rich and powerful"],[2227,2306,"the mayor is?"],[2360,2452,"Mom's gonna die"],[2481,2602,"because you're too proud"],[2610,2752,"to spread your legs for the mayor's son."],[2781,2932,"I'm not going to marry him."],[3086,3228,"Don't you see, Grace?"],[3244,3424,"William and I are doing this"],[3424,3503,"for you and Mom."],[3528,3636,"You should be grateful."],[3720,3782,"Half a million,"],[3782,3953,"and she's all yours tonight."],[3966,4120,"Steep price for an orphan."],[4154,4254,"I don't care, Dad."],[4287,4404,"You promised me I can have her,"],[4416,4500,"and I want her."],[4612,4696,"Give them what they want."],[4729,4850,"Do you want a grandson or not?"],[4854,5034,"She can work for us as the maid."],[5526,5626,"No, no."],[5626,5780,"Pleasure doing business with you,"],[5780,5818,"sir."],[5839,5985,"My sister is all yours."],[6272,6368,"No, no, no!"],[6418,6468,"No, Mom!"],[6493,6523,"Mom!"],[6523,6569,"Please."],[6594,6735,"Don't let them take me, Mom!"],[8725,8888,"No one sells my daughter."],[9884,10093,"Get away from my daughter."]],"8":[[300,412,"Oh, Mom."],[450,625,"Thank God you're awake."],[625,817,"Don't scare us like that again,"],[817,871,"okay?"],[892,1051,"We didn't know what to do."],[1063,1117,"Yeah, Mom,"],[1184,1322,"we're so happy to have you back."],[1405,1580,"It looks like you know exactly"],[1605,1685,"what you're doing."],[2097,2202,"Selling the house?"],[2298,2373,"No, Mom,"],[2385,2544,"you have the wrong idea."],[2552,2673,"We were selling the house"],[2673,2852,"to help pay for your treatment."],[2869,2927,"Treatment?"],[2952,3019,"You didn't even want to pay"],[3019,3111,"for Mom's surgery."],[3140,3374,"Don't listen to Grace's lies, Mom."],[3399,3457,"William and I"],[3457,3628,"have been working day and night"],[3628,3757,"to pay for your surgery."],[3799,3912,"No, that's not true."],[3945,4149,"I was selling my blood to pay back-"],[4149,4204,"Grace,"],[4212,4358,"I know you seduced the mayor's son"],[4358,4437,"and are about to marry"],[4437,4579,"into a powerful family,"],[4583,4675,"but that doesn't mean"],[4675,4800,"you can lie to Mom's face."],[4817,4909,"Grace was trying to marry"],[4909,5000,"into the mayor's family,"],[5021,5184,"so she didn't have to take care of you."],[5213,5305,"Rose and I had no choice"],[5305,5372,"but to sell the house."],[5372,5417,"Enough."],[5505,5776,"Just because I had my eyes closed,"],[5826,5955,"doesn't mean that I didn't hear"],[5985,6252,"everything you said."],[6289,6414,"And not only were you trying"],[6414,6539,"to just sell the house,"],[6577,6669,"but you were trying to"],[6669,6890,"sell your sister, Grace, as well."],[7115,7152,"Mom,"],[7207,7332,"I'm so glad you're awake."],[7349,7478,"I didn't know what else to do."],[7607,7803,"My sweet daughter,"],[7866,7987,"I heard everything."],[8045,8233,"Everything you did to keep me safe."],[8366,8629,"Your mother will make these ingrates"],[8629,8792,"pay for what they did to you."]],"9":[[12,62,"This,"],[141,346,"this is just a silly house,"],[400,525,"and I would have given it to you"],[592,709,"without a second thought."],[784,855,"But now,"],[892,1105,"after the stunt that you two pulled,"],[1167,1551,"you won't get anything."],[2114,2156,"Well,"],[2206,2373,"William and I would have considered"],[2385,2464,"looking after you"],[2464,2727,"if you were even moderately wealthy,"],[2756,2907,"but you're just poor."],[2936,2994,"Do you know"],[3007,3240,"how goddamn embarrassing it is"],[3240,3336,"to call you our mother?"],[3557,3636,"Embarrassing?"],[3757,3853,"When we were orphans,"],[3853,3970,"nobody wanted us."],[4033,4133,"Mom gave us a home."],[4133,4245,"She saved us."],[4266,4391,"Saved us?"],[4546,4767,"I didn't choose this shitty life"],[4767,4859,"she offered us."],[4884,5130,"Poor people shouldn't drag others"],[5130,5230,"into their suffering."],[5255,5359,"That's not fair."],[5392,5472,"Take it back."],[5780,5834,"You see this,"],[5843,5922,"you old hag?"],[5968,6085,"We already have your signature"],[6085,6181,"and fingerprint"],[6189,6322,"on the inheritance letter."],[6360,6489,"It's too late to stop us now."],[6627,6815,"You are not getting anything from me,"],[6869,7094,"not a single cent."],[7303,7361,"Grace,"],[7403,7490,"do you have my phone?"],[7699,7757,"Oh, Grace,"],[7791,7887,"this is your mom's phone."],[7928,8024,"You can keep it for now."],[8066,8116,"Doctor,"],[8116,8233,"this phone is really nice."],[8312,8458,"Are you sure it belongs to my mom?"],[8475,8579,"We took it from her pocket"],[8608,8704,"right before the surgery."],[9976,10039,"Ms. Miller."],[10377,10452,"Alexander?"],[10548,10589,"It's me."]],"10":[[312,400,"My mother was in danger."],[446,554,"Thanks to her adopted daughter,"],[554,608,"Grace,"],[667,784,"she's safe in a small town."],[825,888,"I'm heading over there"],[888,971,"to bring her back home."],[992,1088,"Someone who dares to"],[1088,1176,"threaten Ms. Miller"],[1176,1276,"must be insane!"],[1288,1397,"Let us come with you, sir."],[1422,1514,"We should all be there"],[1514,1614,"to welcome her back."],[1614,1705,"And we'll show those"],[1705,1764,"who crossed her"],[1764,1856,"who is boss!"],[2264,2302,"Sir,"],[2302,2398,"I've sent John Smith"],[2398,2485,"to check on your mother."],[2544,2648,"Make sure he keeps her safe"],[2648,2723,"until I get there."],[2752,2844,"These people are going to regret"],[2844,2919,"ever crossing her."],[2944,3011,"Yes, sir."],[3011,3111,"I'm coming, Mother."],[3169,3194,"Wait,"],[3194,3315,"she has another son?"],[3349,3465,"I have no idea who the guy is."],[3532,3649,"Wonder where she found this guy."],[3695,3828,"Probably fished him out of a dumpster."],[3858,4066,"Bet he's just as pathetic as she is."],[4066,4250,"Another worthless charity case."],[4329,4416,"Stop it."],[4462,4537,"That's your brother"],[4537,4633,"you're talking about."],[4704,4875,"Relax, Grace."],[4942,5109,"Soon they'll be on their knees,"],[5117,5301,"begging for forgiveness."],[5326,5422,"Who do you think you are,"],[5422,5501,"you old hag,"],[5509,5634,"some kind of superhero?"],[5643,5893,"The mayor is related to Mr. Smith,"],[5935,6064,"the man who transformed"],[6064,6164,"the Sterling Corp"],[6164,6272,"into the Phoenix Group's"],[6310,6456,"biggest subsidiary."],[6468,6698,"He can make any person disappear."],[6715,6810,"And guess what?"],[6869,6961,"They just called him"],[6961,7090,"about Gregory's wedding,"],[7090,7261,"so he should be here at any moment."],[7294,7378,"Mr. Smith?"],[7399,7528,"You mean, John?"],[7586,7661,"Speaking as if"],[7661,7795,"she knows him personally."],[7816,7974,"The man controls billions."],[7999,8162,"The nerve on this woman."],[8208,8370,"Let me explain something to you."],[8387,8483,"Phoenix Group"],[8495,8637,"isn't just some company."],[8666,8863,"They own everything."],[8908,9084,"They're untouchable."],[9100,9284,"Gods Among Men."],[9313,9467,"She probably thinks Phoenix Group"],[9467,9713,"is just some bird watching club."],[9751,9930,"Mark my words."],[9989,10130,"You'll all be on your knees,"],[10130,10281,"begging for mercy."],[10297,10502,"And when John Smith gets here,"],[10552,10618,"he's going to be"],[10618,10865,"trembling in his boots."]],"11":[[925,1071,"Mr. Smith has important business"],[1071,1138,"to attend to."],[1151,1230,"Starting now,"],[1247,1413,"all roads heading to the town"],[1413,1497,"are closed off."],[1522,1626,"I heard Mr. Smith"],[1626,1776,"has barely been seen in public"],[1776,1881,"ever since Ms. Miller"],[1881,1960,"went into hiding."],[1964,1993,"Wow."],[1997,2210,"If Mr. Smith is going out like this,"],[2214,2331,"he must be doing business"],[2331,2469,"with a really important person."],[2506,2602,"I never thought I'd ever"],[2602,2711,"meet Ms. Miller in person."],[2748,2948,"This is a once in a lifetime chance."],[3082,3224,"She's the pride of this city."],[3244,3294,"But sir,"],[3332,3461,"we don't even have a photo of her."],[3461,3549,"We don't know what she looks like."],[3549,3691,"I have other matters to attend to"],[3691,3787,"in that town anyway."],[3862,3924,"Let's move out."],[3966,4079,"We'll grab the photo later."],[4412,4450,"Wait,"],[4450,4696,"you think Mr. Smith will kneel"],[4696,4854,"before someone like you?"],[5030,5176,"Oh, don't make me laugh."],[5176,5355,"Oh, she's completely delusional."],[5509,5568,"Enough."],[5672,5764,"I won't stand here"],[5764,5968,"and let you insult my mother like this."],[6126,6252,"Know your place and shut up,"],[6252,6352,"you stupid bitch."],[7194,7332,"Lay a hand on my daughter"],[7332,7415,"one more time,"],[7453,7520,"and I'll make sure"],[7520,7670,"you don't use that hand again."],[7799,7841,"What's wrong?"],[7841,8024,"Our money not good enough for you?"],[8116,8191,"Fine."],[8262,8358,"Name your price."],[8387,8529,"Everything has one,"],[8604,8729,"just like you."],[8904,9167,"Oh, how amusing."],[9180,9280,"You think that you can..."],[9321,9484,"you can buy me off?"],[9542,9722,"I would love to see you try."]],"12":[[145,246,"The word is Ms. Miller"],[246,400,"has an adopted daughter Grace"],[400,529,"that's been taking care of her."],[554,629,"Without her,"],[629,775,"we might not see Ms. Miller again."],[788,867,"This Grace Miller"],[867,1005,"must be someone special."],[1017,1146,"There aren't a lot of daughters"],[1146,1226,"like her out there."],[1380,1430,"It's me."],[1514,1639,"Make sure to arrange"],[1639,1830,"an exceptional gift for Ms. Miller."],[1864,1968,"And prepare something special"],[1968,2056,"for Grace Miller."],[2106,2218,"Only the best for the girl"],[2218,2335,"that saved Ms. Miller."],[2590,2627,"Sir,"],[2665,2827,"John Smith should be arriving at town"],[2827,2902,"any moment now."],[2902,3069,"The signal there is terrible."],[3098,3249,"I just sent him a photo of Ms. Miller."],[3249,3374,"He should be receiving it shortly."],[3436,3457,"Look,"],[3457,3620,"my mother likes to keep a low profile."],[3674,3782,"So I want you to tell our people"],[3782,3828,"to shut down"],[3828,3924,"the entire neighborhood."],[3949,3983,"Okay?"],[3987,4129,"I don't want anyone seeing my mother."],[4141,4195,"Yes, sir."],[4312,4517,"You think that you can buy me?"],[4546,4667,"Well, just look at you,"],[4692,4833,"wearing those rags,"],[4833,5042,"living in this filthy place."],[5071,5226,"And you have the nerve"],[5226,5380,"to reject my son?"],[5405,5472,"People like you"],[5472,5601,"should be on your knees,"],[5609,5759,"kissing our feet."],[5797,6043,"Thanking us for the chance"],[6043,6172,"at a better life."],[6281,6652,"Your son is a worthless parasite"],[6673,6986,"that vultures would refuse to eat."],[7173,7323,"How dare you speak that way"],[7323,7444,"about my son?"],[8846,9046,"I was abandoned as a child."],[9150,9284,"When I was fifteen years old,"],[9321,9426,"my mom took me in"],[9426,9522,"and gave me a home."],[9580,9667,"You may just see her"],[9667,9826,"as another nobody,"],[9893,10147,"working lowly jobs with little money."],[10243,10306,"But to me,"],[10452,10614,"she's the greatest mom in the world."],[10648,10748,"She's my everything."],[10794,10940,"And I'm not just going to stand here"],[10952,11090,"and let you humiliate her."],[11111,11215,"Boo hoo,"],[11252,11365,"I'm in tears."],[11378,11578,"Who cares if we insult this old hag?"],[11615,11811,"My husband is the mayor."],[11853,12024,"And we can do anything we want."],[12037,12170,"As a matter of fact,"],[12208,12399,"my son can take you right here,"],[12424,12575,"and right now if he wants."],[12887,13054,"Time to teach my wife some manners."],[13083,13142,"No, no."],[13150,13179,"No!"],[13179,13254,"Stay back!"],[13254,13296,"Please!"],[13325,13505,"You will all regret this!"],[13701,13730,"No!"],[13730,13792,"Stay back!"],[13792,13855,"Please!"],[13884,13951,"Please!"]],"13":[[70,175,"Holy shit."],[200,308,"Is that John Smith?"],[337,437,"The mayor has got"],[437,554,"some family problems"],[554,638,"from what I hear, and uh"],[713,804,"he's probably just here"],[804,921,"to help them out."],[1351,1443,"What, what the hell? - Hey."],[1443,1472,"No, no, no."],[1472,1493,"Help-"],[1493,1543,"Go where?"],[1543,1609,"No. - Let me-"],[1755,1851,"I could assure you,"],[1851,2043,"the consequences for spreading"],[2043,2193,"unverified rumors"],[2206,2431,"in front of Mr. Smith are serious."],[2435,2502,"Mr. Smith,"],[2556,2627,"please let us go."],[2627,2669,"Please sir,"],[2669,2719,"let us go."],[2719,2848,"We had nothing to do with this."],[2865,2927,"You should be talking"],[2927,3053,"to that family over there"],[3069,3199,"who rejected the mayor's son."],[3432,3495,"You're lying."],[3557,3737,"Who dare reject Gregory Warren?"],[3737,3778,"Don't they know"],[3778,3916,"he's related to Mr. Smith?"],[3920,4079,"We're not lying, sir."],[4116,4229,"You can see for yourself,"],[4229,4400,"their house is at the end of this road."],[4400,4483,"Alright,"],[4596,4650,"looks like I'll have to"],[4650,4767,"take care of this myself."],[4909,4984,"Let go of me!"],[4984,5042,"Let go!"],[5847,5947,"Hit her again, Mother!"],[6001,6160,"We offer you everything"],[6160,6356,"and you choose to stay in this filth?"],[6385,6427,"Fine,"],[6448,6610,"stay here and rot!"],[6656,6731,"My mother's love"],[6731,6861,"means everything to me."],[6956,7152,"I'd rather stay in poverty by her side"],[7169,7303,"than live in a cage without her."],[7478,7520,"Too bad"],[7520,7674,"that's not your decision to make."]],"14":[[25,62,"Too bad"],[62,221,"that's not your decision to make."],[304,367,"Mr. Smith?"],[408,487,"He actually came."],[538,679,"Only the famous John Smith"],[679,829,"could arrive in such style."],[859,955,"Mr. Smith,"],[955,1063,"thank you for coming."],[1088,1155,"What's going on here?"],[1201,1343,"You're related to someone like me,"],[1359,1438,"finding your son a wife"],[1438,1559,"should be the easiest thing"],[1559,1626,"in the world."],[1659,1847,"It's these arrogant fools, sir."],[1847,1985,"They have no idea"],[1985,2152,"the privilege they're throwing away."],[2198,2302,"And Mr. Smith,"],[2302,2477,"they even had the audacity"],[2477,2535,"to threaten you."],[2569,2740,"Said you would tremble before her."],[2756,2790,"What?"],[2852,2990,"Someone dare threaten"],[3007,3144,"the John Smith?"],[3161,3299,"The head of Phoenix Group's"],[3299,3499,"most powerful subsidiary?"],[3528,3787,"The man that no one crosses?"],[3803,3849,"Yes."],[3849,4045,"It's that woman right over there."],[4700,4833,"Hello, John."],[4942,5146,"Why does her voice sound so familiar?"],[5326,5555,"Just now, Phoenix Group CEO"],[5555,5626,"Mary Miller,"],[5626,5855,"one of the most powerful figures"],[5855,5939,"in our city,"],[5939,6118,"has relinquished full control"],[6118,6318,"of the company to her son."],[6431,6460,"Mary,"],[6460,6564,"do you have anything to say?"],[6564,6694,"Anything to say at all, Mary,"],[6694,6873,"about the transition of power?"],[6894,6952,"Ms. Miller."],[7073,7127,"Ms. Miller."],[7311,7361,"Ms. Miller,"],[7428,7565,"I owe everything to you."],[7645,7745,"You started Sterling Corp,"],[7745,7862,"and gave me my position."],[7920,8024,"If... If you're really planning"],[8024,8128,"on leaving Phoenix Group,"],[8128,8166,"please,"],[8166,8462,"at, at least let me drive you home."],[8612,8692,"If you really want"],[8692,8800,"to show your gratitude,"],[8842,8983,"take good care of Sterling Group."],[9013,9104,"I'm counting on you."],[9626,9705,"How dare you"],[9705,9843,"use Mr. Smith's first name!"],[9897,9984,"Keep our boss' name"],[9984,10047,"out of your mouth"],[10047,10097,"or else I'll -"],[10097,10143,"Wait."]],"15":[[0,104,"You keep our boss's name"],[104,221,"out of your mouth or else I'll-"],[225,271,"Wait."],[446,504,"You."],[550,625,"You know who I am?"],[675,750,"Mr. Smith,"],[750,963,"listen to this filth trying to pretend"],[963,1051,"she knows you."],[1071,1355,"Yes, I do know you, John."],[1434,1530,"How dare you"],[1530,1705,"address Mr. Smith like that."],[1730,1847,"Trash like you"],[1847,2010,"should show respect."],[2018,2093,"Mr. Smith,"],[2118,2273,"this is just some old woman"],[2273,2435,"who works as a cheap laborer"],[2435,2590,"at the orphanage nearby."],[2610,2711,"A day laborer?"],[2761,2852,"I must have mistaken her"],[2852,2932,"for someone else."],[2965,3123,"What happened to all your threats?"],[3178,3257,"Weren't you just saying"],[3257,3395,"how Mr. Smith would tremble"],[3395,3557,"and fall to his knees?"],[3566,3649,"You said that?"],[3661,3720,"I did."],[3774,3899,"Who do you think you are, huh?"],[4012,4133,"Don't touch my mom."],[4316,4429,"Oh, you want to be brave too?"],[4788,4859,"Mr. Smith,"],[4888,5017,"it's a message from Mr. Miller."],[5055,5171,"It's the photo of Ms. Miller."]],"16":[[12,150,"It's the photo of Ms. Miller."],[254,362,"You mean, Ms. Miller?"],[392,425,"Yeah."],[442,621,"She's Phoenix Group CEO."],[646,838,"They, they say she controls all the city."],[888,967,"But she disappeared"],[967,1038,"years ago,"],[1084,1238,"when she gave control to her son"],[1238,1351,"when he turned eighteen."],[1376,1468,"We could have been living"],[1468,1534,"the high life"],[1534,1659,"if she had adopted us,"],[1659,1755,"instead of being stuck"],[1755,1893,"with this worthless woman."],[1989,2052,"Mr. Smith,"],[2052,2093,"you see,"],[2106,2281,"everything's ready for the wedding."],[2281,2385,"If you could just help us"],[2385,2535,"convince the bride."],[2560,2731,"Ms. Miller is here in town somewhere."],[2756,2902,"I have to find and greet her."],[2932,3073,"I can't let this petty situation"],[3082,3153,"get in the way."],[3224,3307,"Take her to the church."],[3407,3490,"No, let me go,"],[3490,3591,"I won't marry him."],[3628,3770,"I need to stay with my mom."],[3778,3878,"Try to get past me."],[3933,4033,"See how that works."]],"17":[[29,120,"Try to get past me."],[133,287,"See, see how that works out for you."],[287,383,"Move aside, ma'am."],[404,650,"Mr. Smith is due to welcome back"],[650,809,"the CEO of Phoenix Group."],[834,946,"If you and your daughter"],[946,1021,"get in the way,"],[1059,1138,"you'll pay the price."],[1422,1463,"So,"],[1589,1668,"this is how you run"],[1668,1772,"Sterling Group now?"],[1860,1968,"Torment the weak"],[2056,2189,"and throw your weight around?"],[2206,2323,"Shut your damn mouth."],[2398,2448,"Strip her."],[2606,2711,"Let her mother watch"],[2711,2823,"what happens to people"],[2823,2915,"who defy me."],[3148,3370,"You are making your last mistake."],[3411,3503,"You think I'm scared"],[3503,3611,"of some empty threats"],[3611,3803,"from an old hag in a wheelchair?"],[3837,3999,"What are you gonna do about it?"],[4133,4358,"No, no, no, no!"],[7069,7219,"How could I be so foolish?"],[7269,7494,"Ms. Miller, the CEO of Phoenix Group,"],[7511,7649,"is right in front of my eyes."]],"18":[[58,208,"Mr. Smith is about to teach"],[208,383,"this old woman a lesson,"],[383,479,"that she should never"],[479,567,"open her mouth."],[617,679,"Just watch."],[696,725,"Well,"],[725,892,"that'll teach her to disrespect someone"],[892,1001,"like Mr. Smith."],[1013,1096,"Crawl on the ground"],[1096,1226,"and beg for forgiveness,"],[1226,1351,"you pathetic old hag."],[1355,1418,"That's right!"],[1484,1530,"Go on,"],[1593,1810,"and grovel before he destroys you."],[1847,2056,"I have no need to apologize."],[2081,2306,"I meant every word that I said."],[2369,2565,"I said that when John Smith"],[2565,2627,"gets here,"],[2652,2861,"he will tremble and fall to his knees."],[2861,3073,"And that is exactly what will happen."],[3265,3490,"What planet are you even living on?"],[3570,3670,"You're not just a beggar."],[3703,3899,"You're a complete lunatic!"]],"19":[[784,880,"Sir, what's the matter?"],[900,971,"On your knees."],[1026,1130,"But sir, she's just some-"],[1130,1255,"I said on your knees!"],[1914,2068,"You, you're- - Are you all deaf?"],[2110,2239,"Get on your knees!"],[2373,2439,"Mr. Smith,"],[2439,2544,"what's this all about?"],[2573,2706,"Are you not feeling well?"],[2765,2923,"What did this brain-dead bitch"],[2923,2994,"do to him?"],[3032,3203,"Get him away before whatever's rotting"],[3203,3328,"in her head spreads!"],[3482,3549,"Mr. Smith,"],[3549,3632,"what are you doing?"],[3853,3941,"I'm warning you,"],[3987,4166,"do not disrespect this woman."],[4287,4379,"She is..."]],"20":[[29,108,"She is-"],[108,200,"She is nothing"],[200,383,"but a pathetic waste of space."],[412,517,"She can't even stand"],[517,629,"on her own two feet."],[675,817,"Her brain's rotted away"],[817,934,"and she doesn't have a penny"],[934,1005,"to her name."],[1067,1255,"Are you seriously going to defend"],[1255,1463,"this old witch?"],[1518,1576,"Ah!"],[1626,1685,"Ah!"],[1693,1751,"Ah!"],[1810,1964,"Looks like you remember me now,"],[1964,2006,"John."],[2064,2202,"Why don't you tell everyone else"],[2202,2260,"who I am?"],[2260,2314,"Go ahead."],[2569,2744,"Address him as Mr. Smith,"],[2773,2982,"you disrespectful old hag!"],[3194,3257,"Mr. Smith,"],[3349,3470,"we never wanted her as our mother."],[3528,3628,"We've already cut ties"],[3628,3687,"with this woman."],[3712,3953,"We don't support her behavior at all."],[3962,4012,"Please,"],[4079,4283,"don't punish us for her actions."],[4412,4537,"I understand you're upset,"],[4537,4596,"Mr. Smith."],[4596,4783,"Let me remove this worthless woman."],[4821,4879,"Ah!"],[4971,5034,"Ah!"],[5271,5317,"Leave!"],[5380,5434,"All of you."],[5647,5714,"Mr. Smith,"],[5714,5839,"why are you protecting her?"],[5860,5980,"She's beneath you."],[6001,6076,"Mr. Smith,"],[6118,6289,"please, we're family."],[6297,6360,"Family?"],[6439,6635,"You're just distant relatives."],[6677,6798,"The only reason"],[6815,6969,"I maintain contact with you"],[6977,7077,"is because someone told me"],[7077,7127,"to never forget"],[7127,7219,"where I came from."],[7223,7411,"And that someone was her."],[7586,7782,"She helped me build Sterling Corp"],[7782,7853,"from nothing."]],"21":[[58,95,"John,"],[158,296,"return my daughter to me"],[342,563,"and we'll discuss your actions later."],[604,675,"Yes, Ms. Miller."],[1922,1968,"Mom."],[2089,2293,"No one will ever hurt you again,"],[2364,2406,"okay?"],[2510,2660,"Who the hell are you?"],[3457,3586,"On behalf of Sterling Corp,"],[3678,3807,"I formally welcome you back"],[3807,3887,"to Phoenix Group."],[3912,4024,"Welcome back, boss."],[4275,4508,"She's the CEO of Phoenix Group?"]],"22":[[8,200,"Phoenix Group CEO?"],[300,412,"That's impossible."],[429,542,"There must be some mistake."],[542,684,"This old hag doesn't even have money."],[754,834,"Just look at her."],[859,896,"Yeah."],[930,1121,"The richest CEO in the country"],[1121,1276,"wearing bargain bin clothes,"],[1292,1413,"working at an orphanage,"],[1413,1559,"and living in this dump?"],[1580,1626,"Please."],[1626,1760,"Do you even hear yourself?"],[1843,1960,"If it wasn't for Ms. Miller"],[1960,2056,"living a modest life,"],[2056,2168,"you'd still be orphans."],[2193,2323,"You ungrateful brats."],[2610,2656,"And you,"],[2752,2869,"you must be the adoptive daughter"],[2869,2965,"who saved Ms. Miller."],[3044,3194,"Don't be afraid."],[3236,3324,"You're Ms. Miller's daughter"],[3361,3482,"and the only one who protected her."],[3495,3603,"And now Sterling Corp"],[3603,3674,"will protect you."],[3770,3953,"If anyone tries to harm you,"],[3995,4091,"they'll pay the price."],[4116,4254,"I just want to stay with my mom"],[4254,4341,"and take care of her."],[4508,4558,"Please,"],[4671,4758,"don't let them force me"],[4758,4854,"to marry this man."],[5205,5330,"My sweet girl."],[5534,5609,"No way!"],[5626,5789,"My parents paid good money for you,"],[5789,5897,"so you belong to me now."],[5955,6101,"Your mother can rot in a nursing home"],[6101,6172,"for all I care."],[6202,6364,"Nobody touches my daughter."],[6373,6502,"John, break his wrist!"]],"23":[[8,137,"John, break his wrist!"],[738,804,"Mr. Smith,"],[804,905,"please don't do this."],[921,946,"Please,"],[946,1046,"he's our only son."],[1059,1105,"Please,"],[1105,1230,"he's all we've got."],[1284,1388,"You love your son"],[1388,1547,"like I love my daughter."],[1589,1843,"And yet you let him terrorize Grace"],[1864,2027,"and you didn't say anything."],[2110,2310,"And now you want to apologize?"],[2419,2506,"It's too late."],[2506,2665,"But your daughter is fine."],[2736,2865,"Do you really have to do this?"],[2894,3048,"If I let this go today,"],[3115,3261,"then you'll keep terrorizing"],[3261,3361,"those weaker than you"],[3361,3457,"like my daughter."],[3482,3628,"So today there will be a lesson"],[3628,3770,"for not only your son,"],[3770,3920,"but for everyone else."],[3953,4208,"Mark my words."],[4287,4387,"Who do you think you are,"],[4391,4567,"barking at my parents and brother?"],[4612,4658,"Move,"],[4658,4771,"or I'll end you all."],[5096,5155,"Brittany,"],[5155,5280,"my sweet daughter,"],[5296,5405,"thank God you're here."],[5497,5576,"Don't worry, Dad."],[5609,5718,"I've got this under control."],[5847,5939,"Did you forget?"],[6081,6139,"My boyfriend"],[6139,6318,"is Alexander Miller's assistant."],[6456,6523,"So what,"],[6523,6589,"young lady?"],[6623,6752,"And this is Alexander's mother"],[6752,6815,"Ms. Miller,"],[6831,7015,"CEO of Phoenix Group."],[7140,7353,"She is not the CEO of Phoenix Group."],[7403,7524,"She's a fraud!"]],"24":[[16,125,"What are you talking about?"],[154,229,"Just because you're dating"],[229,329,"Alexander's lapdog,"],[329,429,"doesn't mean you can run your mouth"],[429,533,"and spread lies."],[550,625,"Lies?"],[684,896,"I've seen the Phoenix Group CEO"],[896,1026,"with my own two eyes."],[1084,1163,"She got me a present"],[1163,1238,"for my birthday."],[2131,2214,"Sean, what’s wrong?"],[2243,2381,"Today's my girlfriend's birthday,"],[2381,2527,"and she wants me to invite"],[2527,2706,"Ms. Mary Miller to her party."],[2890,2936,"What?"],[2986,3082,"She's so secluded,"],[3082,3232,"even her own son can't see her"],[3232,3324,"whenever he wants."],[3432,3557,"How do you expect her to agree"],[3557,3666,"to meet your girlfriend?"],[3862,3899,"Wait."],[4049,4170,"What if you pretend to be her?"],[4254,4496,"Nobody even knows what she looks like"],[4496,4621,"outside of the board anyway."],[4696,4808,"Pretend to be CEO"],[4838,5009,"for my girlfriend's birthday party,"],[5050,5180,"and I'll get working on that promotion"],[5180,5296,"that you've been wanting for years."],[5676,5734,"Oh yeah?"],[5897,5943,"Hm."],[5968,6006,"Fine,"],[6089,6139,"I'll do it."],[6310,6377,"Young lady,"],[6489,6644,"I don't know who your family is,"],[6690,6794,"but you better believe"],[6794,6940,"that I could destroy them"],[6944,7082,"with one phone call."],[7182,7290,"Everyone here sees"],[7290,7432,"that you're just broke"],[7432,7524,"and delusional."],[7628,7691,"Cut the act,"],[7691,7791,"you widowed hag!"],[8058,8199,"Don't say I didn't warn you."],[8249,8404,"I'm going to have my boyfriend"],[8404,8650,"expose you for the fraud you really are."]],"25":[[650,696,"Brittany?"],[934,1005,"I'm on my way."],[1021,1096,"My mother's coming back"],[1096,1201,"to the Phoenix Group today"],[1201,1288,"so I want you guys"],[1288,1368,"to get her something"],[1368,1555,"absolutely spectacular, okay?"],[1609,1722,"It's time to show this city"],[1722,1885,"who's really been behind our success."],[1956,2035,"Also, I want you to get something"],[2035,2097,"for that girl."],[2181,2277,"The one that she adopted,"],[2306,2410,"that's been taking care of her."],[2423,2515,"She's my sister now,"],[2515,2598,"so get her something grand"],[2598,2635,"as well."],[3023,3065,"Boss?"],[3103,3178,"Is everything ok?"],[3224,3340,"I need you to do something for me."],[3403,3478,"It's about Brittany."],[3507,3557,"Someone causing"],[3557,3641,"your girlfriend trouble?"],[3774,3820,"Don't worry,"],[3849,3912,"I'll handle it."],[3958,4070,"I'll make them beg for mercy"],[4070,4137,"for what they've done."],[4208,4275,"Take a right here."],[4391,4508,"Got to handle something for Sean."],[4579,4625,"Yes, sir."]],"26":[[154,216,"Hear that?"],[275,367,"My daughter's boyfriend"],[367,546,"is Alexander Miller's assistant."],[604,709,"He's one of Phoenix Group's"],[709,855,"rising stars."],[867,980,"You picked the wrong people"],[980,1042,"to mess with."],[1096,1180,"You're done for."],[1238,1363,"Thank God we cut ties with you,"],[1372,1472,"you crazy old witch!"],[1518,1718,"You almost gave me a heart attack,"],[1726,1810,"you old hag."],[18