{"1":[[700,800,"Senator Dobson."],[871,955,"Get out of here."],[1234,1297,"So..."],[1480,1568,"what's your name?"],[1743,1830,"I guess it wouldn't hurt"],[1830,1926,"to tell you my name."],[2110,2293,"Since you're a dead man walking."],[2894,3036,"I'm the Crimson Killer."],[4016,4216,"I'm the best assassin in New York."],[4400,4642,"And I'm always one step ahead."],[4662,4779,"Someone just killed the Senator."],[4783,4950,"The District Attorney is on his way."],[4979,5167,"The new D.A. just got sworn in today."],[5209,5284,"He'll be too busy"],[5284,5442,"partying to investigate anything."],[6310,6452,"So the Crimson Killer strikes again?"],[6489,6564,"District Attorney,"],[6594,6777,"the Senator was last seen with a woman."],[6777,6906,"Alright, we'll close all the exits"],[6906,7044,"to make sure no one goes in or out."],[7211,7319,"Did you just say a woman?"],[7703,7782,"After her."],[7807,7907,"Stop right there!"],[8149,8212,"Shit."],[8462,8533,"That way."],[8979,9104,"Sir, we can take over!"],[9104,9163,"No."],[9534,9601,"I made a promise"],[9601,9738,"that I would protect this city."],[9880,10035,"I never go back on my word."],[10097,10189,"Come on, boys."],[10256,10377,"We got a killer to catch."],[10639,10919,"My nemesis is Hayden Kent."],[10952,11140,"The only man I've ever loved."]],"2":[[875,946,"Okay."],[992,1163,"I have something to show you."],[1163,1267,"Something to show me?"],[1267,1322,"Okay."],[1363,1455,"Put your hands out."],[2035,2127,"What is that?"],[2218,2402,"Maddie, this is a promise to you."],[2427,2552,"I'm always gonna take care of you"],[2552,2690,"and everyone else that needs it."],[2794,2919,"I'm never gonna let them get away"],[2919,3036,"with what they did to you."],[3399,3486,"I love it."],[4029,4108,"Hayden!"],[4287,4487,"Did you just sleep with the Archer girl?"],[4529,4654,"Oh my God!"],[4654,4829,"Her dad is an alcoholic"],[4829,5000,"and a gambling addict!"],[5117,5296,"Get her out of my house"],[5296,5442,"or she's going to ruin us!"],[5442,5588,"Mom, are you serious?"],[5588,5634,"What the-"],[6031,6131,"I'm so sorry."],[6135,6214,"I'm so sorry."],[6222,6306,"Please, don't hurt him again."],[6306,6398,"Okay, I'll leave."],[6398,6644,"Stay away from my son, you little tramp!"],[6664,6848,"The best thing you could do for Hayden"],[6848,6986,"is to disappear"],[6986,7261,"and never show your face again."],[7282,7378,"Maddie, no!"],[7453,7540,"Wait, Maddie!"],[7640,7741,"Maddie!"],[7791,7866,"Oh, I'm sorry."],[7866,7899,"I wasn't,"],[7899,7953,"I wasn't listening."],[8145,8249,"Why don't you just"],[8262,8379,"try to get some sleep, okay?"],[8554,8637,"This is her last round"],[8637,8746,"of treatment, right?"],[8762,8817,"Yes."],[8817,8950,"Your sister will be out of here"],[8950,9025,"in no time."],[9067,9196,"She's lucky to have you."],[9246,9351,"I'm the lucky one."],[9488,9684,"Katie is all I have left in the world."],[9718,9884,"If I have to take lives so she can"],[9884,9984,"keep hers,"],[10014,10097,"so be it."],[10301,10364,"A word?"],[10894,11056,"What the hell are you doing here?"],[11086,11240,"Dante, you swore to me"],[11240,11423,"you'd keep my sister out of this life."],[11432,11540,"I had to congratulate"],[11540,11695,"my best assassin in person."],[11732,11932,"Dobson's your third kill this month."],[11932,12074,"And the last."],[12208,12291,"Katie's recovered."],[12308,12454,"I don't need your charity anymore."],[12454,12516,"I'm done."],[12537,12600,"Need?"],[12733,13029,"Since when was this about your needs?"],[13071,13158,"Help!"],[13238,13342,"Monster!"]],"3":[[442,525,"Oh, my-"],[571,667,"Maddie, look!"],[667,863,"Your friends are so good with guns!"],[917,1126,"Such a brave little girl."],[1201,1305,"Just beat cancer."],[1384,1493,"Sure would be a shame"],[1493,1651,"if she lost her life after that."],[2223,2515,"Hey...you said Dobson would be my last."],[2535,2640,"You said that to me."],[2660,2769,"And I wish he could have been."],[2773,2886,"But someone threw a wrench"],[2886,2990,"into my plans."],[3290,3407,"Your last target."],[3478,3620,"And I do mean it this time."],[3661,3732,"Take him out."],[3778,3862,"You're free."],[3995,4074,"Who is it?"],[4162,4425,"District Attorney, Hayden Kent."]],"4":[[112,200,"No, not him."],[425,546,"No, I, I just, I can't,"],[546,663,"I can't take this case."],[713,792,"You can't?"],[825,925,"Or you won't?"],[1046,1234,"Incompetence and disobedience"],[1234,1468,"mean the same thing to me, Maddie."],[2135,2256,"I'm having second thoughts"],[2256,2419,"about going after the D.A., that's all."],[2439,2573,"Second thoughts?"],[2602,2765,"I raised you better than that."],[3311,3415,"Where's my dad?"],[3474,3603,"Your dad's gone, kid."],[3724,3824,"You're with me now."],[3924,4012,"Do as I say."],[4070,4162,"I'll protect you."],[5284,5372,"I got it."],[5505,5663,"Dante, I won't let you down."],[5663,5730,"Good."],[5755,5864,"You have a lot on the line."],[6614,6794,"Oh, God, I'm so sorry, Hayden."],[6835,6986,"The next time I see you"],[6986,7157,"will be down the barrel of a gun."],[8095,8191,"All right, Crimson."],[8208,8304,"Your target is the D.A."],[8304,8433,"hosting a charity gala."],[8454,8529,"Neutralize him."],[8800,8933,"I have to do this."],[9088,9192,"For my sister."]],"5":[[0,133,"Mr. Kent, what's going on?"],[133,208,"Are you alright?"],[329,437,"I apologize, gentlemen."],[437,533,"I'm needed somewhere."],[725,842,"What the hell are you doing?"],[842,1013,"Hayden Kent is the other way!"],[1042,1159,"What is wrong with me?"],[1159,1330,"I've never lost my cool on a job before."],[1376,1568,"Get back in there now!"],[1647,1726,"Look, I'm not just..."],[1726,1885,"I'm waiting on an opening, Dante."],[2473,2535,"Whoa, whoa, miss."],[2535,2615,"You can't be here."],[3132,3219,"Hey, stop!"],[3728,3807,"You bitch!"],[3807,3937,"Identify yourself!"],[3937,4008,"Sorry."],[4929,5030,"You have about five seconds"],[5030,5130,"to tell me who you are"],[5130,5259,"and why you're following me."]],"6":[[33,145,"It really is him."],[229,312,"My Hayden."],[592,788,"No, I can't let him recognize me."],[859,946,"Ow!"],[1096,1184,"Answer me!"],[1226,1338,"Or I'm gonna hurt you."],[1405,1534,"You wouldn't hurt a fly."],[1572,1685,"What the hell are you talking about?"],[1739,1839,"Kill him now,"],[1839,1976,"or a bullet goes into"],[1976,2106,"your little sister's head."],[2335,2556,"I'm sorry, Hayden."],[2556,2615,"Wait."],[3069,3128,"Maddie."]],"7":[[70,129,"Maddie."],[266,346,"Why, Maddie?"],[346,404,"It's you."],[517,588,"Why, Maddie?"],[613,738,"How is this possible?"],[796,900,"I have to go."],[1038,1155,"Open the door now"],[1163,1267,"or we open fire!"],[1597,1664,"Yes?"],[1789,1851,"Wait."],[1872,1989,"You're the District Attorney."],[2022,2081,"Can I help you?"],[2106,2206,"Mr. Kent, sir!"],[2206,2314,"You need to leave!"],[2348,2452,"There's a woman here,"],[2452,2577,"armed and dangerous."],[2577,2715,"We think she's an assassin."],[2773,2865,"Did you see her, sir?"],[2898,2977,"Yeah, sure did."]],"8":[[221,304,"Red dress, right?"],[446,550,"Yeah, I saw her run that way."],[729,863,"But we just came from..."],[863,1063,"Anyway, thank you for your concern."],[1063,1197,"Uh, good luck finding her."],[1197,1343,"I can't wait to hear the good news."],[1822,2060,"So, are you gonna explain to me"],[2060,2164,"why my security team"],[2164,2456,"is chasing down my ex-girlfriend?"],[2531,2623,"I'm sorry,"],[2623,2765,"I think you have the wrong person."],[3073,3182,"Madeline Archer,"],[3336,3524,"do you know how long it's been?"],[3607,3828,"Crimson, what the hell is going on?"],[3841,3924,"Do you copy?"],[3995,4049,"Maddie!"],[4216,4287,"Okay, look."],[4362,4454,"I don't know you."],[4491,4579,"You don't know me."],[4637,4696,"Got it?"],[4738,4796,"No."],[4921,5105,"You're the one here chasing me."],[5142,5196,"Ten years"],[5196,5305,"and I recognized you right away,"],[5305,5438,"even underneath the mask."],[5547,5622,"Let go of me."],[5834,5935,"Madeline, what the hell"],[5935,6047,"do you think you're doing?"],[6076,6235,"I never broke my promise."],[6297,6402,"I've done everything I can"],[6402,6506,"to make you safe."],[6660,6790,"I never stopped loving you."],[6835,6990,"No, Maddie."],[7011,7136,"Think about your sister."],[7382,7532,"Would you die for me?"],[7553,7599,"Huh?"],[7682,7736,"What are you..."],[7874,7991,"Maddie, is that a..."],[8204,8362,"You said you loved me."],[8479,8633,"That you want to help me."],[8871,9200,"Would you die for me?"],[9259,9321,"I..."]],"9":[[41,108,"I..."],[120,221,"That's what I thought."],[779,1080,"If I stay, I'll only destroy you."],[1134,1301,"Hayden, I can't let that happen."],[1597,1768,"Mr. Kent, you're back on in two."],[1768,1818,"Copy?"],[1864,1943,"Forget that."],[1964,2089,"I need you to look someone up."],[2122,2248,"But sir, everyone's been"],[2248,2335,"waiting for your speech"],[2335,2435,"about the Crimson Killer."],[2519,2615,"I need you to find out"],[2615,2694,"everything you can"],[2694,2806,"about Madeline Archer."],[2831,2932,"Put the best teams on it."],[2932,3073,"I don't care how much it costs."],[3182,3319,"Maddie, we made a promise to"],[3319,3395,"each other."],[3411,3478,"I'm not letting you"],[3478,3645,"disappear on me this time."]],"10":[[179,279,"Relax."],[346,462,"I'm just here to talk."],[554,671,"If this is about the D.A...."],[692,855,"Of course it's about the fucking D.A."],[863,1013,"You walked into a room with him,"],[1042,1176,"and he walked out alive."],[1305,1468,"How the fuck does that happen?"],[1539,1597,"Guards."],[1685,1810,"There are too many witnesses."],[1856,1947,"Come on, Dante."],[1947,2039,"I need you to trust me."],[2106,2152,"Here."],[2281,2406,"I've never let you down before."],[3591,3641,"Well..."],[3812,3983,"Everyone has their off days."],[4204,4483,"But don't disappoint me again."],[4696,4758,"Fabian,"],[4867,5075,"Maddie's special gift."],[7424,7469,"No."],[7528,7595,"Katie!"]],"11":[[1063,1155,"Maddie, where have you been?"],[1155,1292,"You're super late."],[1322,1526,"Dante went after my fucking sister."],[1964,2039,"You're safe."],[2106,2173,"But how long"],[2173,2335,"until Dante changes his mind?"],[2656,2848,"I can't let my history with Hayden"],[2848,2936,"slow me down."],[2965,3082,"I have to kill him"],[3082,3190,"before he becomes a liability."],[3457,3607,"I'm looking for Madeline Archer."]],"12":[[312,400,"Fuck."],[1113,1184,"He's with me."],[1326,1397,"Client."],[3240,3349,"Are you stupid?"],[3457,3541,"What are you doing here?"],[3541,3695,"You are New York's District Attorney,"],[3695,3807,"if anyone finds you here-"],[3941,4091,"I'm giving you an invitation."],[4796,4992,"He walked into a viper's nest"],[5038,5238,"just to give me a party invite?"],[5459,5588,"How'd you even find me?"],[5626,5751,"Well, that's confidential."],[5951,6118,"These bars were run by a notorious"],[6118,6231,"crime boss named Dante."],[6260,6364,"You're not safe here."],[6527,6619,"You need to get out of here"],[6619,6698,"while you still can."],[6702,6956,"If only you knew, Hayden."],[7236,7332,"I can't leave."],[7365,7532,"Look, my office is looking for an aide."],[7895,8053,"I'm a killer, Hayden."],[8087,8254,"Our paths aren't meant to cross."],[8429,8662,"Oh, no, the hitman's watching us."],[8996,9142,"Finish the job, Crimson,"],[9175,9321,"or I'm turning Hayden Kent"],[9321,9476,"into an open bounty."],[9492,9647,"Up for grabs."],[9772,9884,"Maddie, what's wrong?"]],"13":[[1247,1359,"Gunman, 7 o'clock."],[1393,1564,"This should block his shot,"],[1589,1772,"and buy me some time."],[2640,2761,"I can disarm the killer."],[2761,2932,"I just can't have Hayden see."],[3269,3374,"Do you trust me?"],[3411,3478,"Uh-huh."],[3561,3687,"On the count of three,"],[3799,3928,"close your eyes."],[3987,4191,"And I want you to keep them closed"],[4258,4587,"until I say so."],[4625,4725,"Okay."],[4746,4829,"Awesome."],[4992,5084,"One."],[5184,5267,"Two."],[5522,5630,"Three."]],"14":[[1668,1726,"Maddie?"],[2060,2198,"Shit, he saw."],[2602,2702,"What the hell?"],[2702,2944,"My contract, my kill."],[3207,3365,"If you really meant to kill him,"],[3390,3524,"you would've done it yesterday."],[3553,3699,"You've gone so soft."],[3699,3787,"Deep inside,"],[3787,3966,"you know you can't pull the trigger."],[3999,4091,"So, I'll do it."],[4149,4291,"Keep the perfect streak"],[4291,4400,"for the Crimson Killer."],[4446,4529,"You..."],[4579,4683,"Not today, you won't."]],"15":[[12,108,"Tell me what you know about"],[108,208,"the Crimson Killer."],[233,496,"Well, well, D.A. loverboy."],[654,750,"Seems like I just got"],[750,855,"some leverage over you."],[855,988,"No. I can't die yet."],[1009,1163,"I need to protect my sister-"],[1163,1247,"Any business you have"],[1247,1338,"is between you and me."],[1338,1422,"She's innocent."],[1501,1668,"Justice really is blind."],[1668,1768,"Blind as a bat."],[1818,1951,"Did you really think your precious"],[1951,2206,"Maddie is just a clueless bartender?"],[2669,2727,"No."],[2811,2998,"Maddie, tell me it's not true."],[3053,3332,"Now, you put me in witness protection,"],[3407,3541,"and I hand you the Crimson Killer."],[3732,3787,"Hayden."],[3787,3862,"No, you won't!"],[4854,4988,"I swore an oath to justice,"],[4988,5046,"and today..."],[5409,5572,"I plan on serving it myself."]],"16":[[988,1126,"He shot the hitman."],[1146,1242,"To save me."],[1343,1422,"We gotta run!"],[2414,2506,"Who knew our"],[2506,2665,"perfect District Attorney"],[2665,2831,"was an adrenaline junkie?"],[2861,3007,"You, you shot him."],[3061,3190,"Temporary lapse in judgment."],[3224,3328,"So, what are you gonna do?"],[3541,3616,"I, uh..."],[3716,3878,"I'm gonna pass it off to my staff."],[3903,4029,"Someone else will take care of it."],[4191,4337,"But that's not what concerns me."],[4583,4733,"What concerns me is you, Maddie."]],"17":[[50,95,"No."],[133,229,"Does Hayden know"],[229,346,"I'm the Crimson Killer?"],[367,475,"Look, criminals say"],[475,592,"all sorts of shit when they're cornered."],[592,625,"So..."],[846,1021,"I'm not talking about the Crimson Killer."],[1155,1305,"I'm talking about you, Maddie."],[1397,1526,"You know, for a barmaid,"],[1651,1830,"you're a suspiciously good fighter."],[1947,2068,"I grew up on the streets."],[2068,2198,"It's basic self defense."],[2218,2339,"Yeah, is it basic self defense"],[2339,2431,"to take out assassins"],[2431,2552,"while giving lap dances?"],[2698,2744,"Huh?"],[2819,2907,"I'm the D.A."],[2932,3078,"Cooped up in my office all day."],[3194,3336,"It's very rare"],[3336,3528,"that I get to see action like this."],[4124,4225,"You're good, Maddie."],[4358,4475,"You're damn good."],[4575,4683,"I can use someone like you"],[4683,4771,"to watch my back."],[4884,4975,"Of all people, you..."],[5138,5213,"you want me?"],[5330,5463,"I never stopped wanting you."],[5622,5784,"Together we could take down..."],[5968,6118,"We could take down the Crimson Killer."],[6448,6677,"Don't disappoint me again, Crimson."],[6844,6915,"I'm sorry."],[6961,7027,"Maddie!"],[7148,7332,"How could I be so careless?"],[7332,7490,"I'm the Crimson Killer."],[7490,7582,"He's the D.A."],[7582,7745,"The best I'll ever be for him"],[7745,7874,"is a closed case."],[8033,8116,"Stop right there!"],[8379,8633,"You walked right into our trap."],[8737,8942,"Ready when you are, Hayden."]],"18":[[41,137,"Sorry, who the hell are you?"],[171,300,"Detective Annabel Dorset."],[300,408,"Lead investigator under"],[408,567,"District Attorney Hayden Kent."],[608,675,"No..."],[729,892,"Did Hayden set me up?"],[921,1130,"You're not going anywhere, scum."],[1263,1451,"Someone just got shot in Dante's club"],[1451,1584,"and I have a sneaking suspicion"],[1584,1680,"that you're the perp."],[1805,1876,"You're gonna make for"],[1876,1960,"the perfect witness"],[1960,2168,"in Hayden's investigation."],[2260,2356,"You're working together."],[2431,2527,"Of course we are."],[2581,2773,"Me and Hayden are the perfect duo."],[2815,2952,"I'm practically his other half."],[2998,3165,"So, Hayden never needed me."],[3199,3420,"It was all a lie to further his career."],[3428,3574,"Okay, look, I have a younger sister."],[3574,3620,"Her name is Katie-"],[3620,3720,"Shut up, criminal!"]],"19":[[4,91,"Hands off!"],[141,221,"Hayden."],[333,479,"Look, I caught your shooter."],[479,588,"Illegal detainment."],[588,742,"Excessive use of force."],[742,846,"Must I go on?"],[934,1030,"Detective Dorset,"],[1030,1167,"I have warned you once."],[1188,1301,"You only have this job"],[1301,1438,"because your dad is the governor."],[1459,1572,"Stay out of my way."],[1593,1651,"Well, there were"],[1651,1776,"two sets of prints on the gun,"],[1776,1910,"so I figured we'd just check hers"],[1910,1989,"just in case."],[1989,2097,"She is not involved."],[2127,2248,"Uncuff her right now."],[2281,2377,"You don't know that."],[2410,2548,"It's not like you shot the assassin."],[2548,2635,"And what if I did?"],[2777,2932,"Is he protecting me?"],[3007,3174,"I, Hayden Kent, shot the assassin."],[3174,3269,"If you have any questions,"],[3269,3382,"you can speak to my lawyer."],[3403,3453,"Me."]],"20":[[45,216,"Wait! You can't do that!"],[216,375,"There's no way you killed him."],[375,442,"And that would avoid"],[442,575,"your entire investigation."],[658,729,"You would have to"],[729,863,"give up prosecuting the case."],[913,1013,"I didn't take this job"],[1013,1188,"because I care about my reputation."],[1409,1505,"I took this job"],[1505,1664,"because I care about justice."],[1776,1960,"Now, if you would excuse me,"],[2060,2214,"I have a civilian to attend to."],[3724,3887,"You trashy little whore."],[3887,3991,"I'm not letting anyone"],[3991,4112,"take Hayden away from me."],[4859,4917,"Daddy?"],[5088,5221,"I need you to take care of someone."],[7595,7766,"I'm supposed to be killing him."],[7766,7916,"And here I am,"],[7916,8087,"letting him take care of me."],[8099,8224,"That sadistic woman."],[8817,8879,"Now..."],[9050,9221,"Tell me who you really are."]],"21":[[29,204,"Are you a part of Dante's operation?"],[312,525,"Maddie, I'm the District Attorney."],[563,696,"I have tools at my disposal"],[696,859,"that the police aren't even privy to."],[984,1130,"Maddie, I can keep you safe."],[1238,1380,"What if it's worse than that?"],[1468,1630,"Hayden, you have to stay away from me."],[1747,1856,"It's what's best for both of us."],[1856,1956,"It's safer that way."],[2310,2381,"Okay."],[2652,2769,"But after tonight."],[3645,3766,"I'm sorry, Hayden."],[3782,3883,"In the morning, we go back to"],[3883,3983,"being enemies."]],"22":[[1117,1305,"It's not really a good time, Dante."],[1305,1359,"Why?"],[1380,1480,"Having too much fun"],[1480,1601,"at your sleep over?"],[2131,2218,"Who do you have out there?"],[2364,2585,"You led the D.A. right to our hideout"],[2635,2761,"and killed one of our own?"],[2852,2986,"Give me one good reason"],[2986,3211,"I shouldn't plug you right now?"],[3265,3390,"Shots ready, Dante."]],"23":[[87,208,"I can't do this."],[287,433,"I am a murderer"],[433,546,"and Hayden swore an oath"],[546,671,"to take me down."],[713,855,"I'm working him."],[900,1071,"Dante, you think I'm stupid enough"],[1071,1242,"to kill without getting intel first?"],[1380,1514,"What did you just say?"],[1572,1689,"He's got different names."],[1714,1901,"Dante, I swear, I can figure it out."],[1906,2039,"You just have to trust me."],[2039,2210,"Did I train you to think?"],[2252,2431,"I make the rules, Crimson."],[2456,2652,"And I want him neutralized."],[2686,2744,"Kill him,"],[2786,2957,"or I start working your sister."],[3386,3486,"Dante, please,"],[3486,3666,"don't make me keep going, please."],[3766,3845,"Do it."],[4179,4254,"Again."],[5109,5213,"Again."],[5676,5772,"Again!"],[6135,6202,"Copy,"],[6289,6360,"Dante."],[6564,6669,"I'll kill the D.A."]],"24":[[517,713,"You have until midnight, Crimson."],[767,984,"Neutralize Hayden Kent."],[1059,1226,"I need to do what's best."],[1251,1326,"For my sister."],[2811,2861,"Good,"],[2873,2952,"Hayden's invite"],[2952,3115,"got me right past security."],[3728,3812,"Sleeping pill."],[3862,4029,"It'll take a bazooka to wake them up."],[4179,4287,"Skeleton's in the closet."],[4287,4358,"Skeleton's in the - He's so funny."],[4358,4408,"closet."],[4625,4775,"And Hayden, why don't you tell my dad"],[4775,4904,"about our new case?"],[4925,5080,"We did such a good job."]],"25":[[437,513,"Detective Dorset,"],[513,625,"I told you I'm very particular"],[625,684,"about my work."],[742,930,"I want my space and I want my privacy."],[1726,1964,"As much as Hayden says he wants me,"],[1964,2122,"he has his own life to live."],[2164,2293,"And I have mine."],[2389,2460,"It's time to say goodbye"],[2460,2548,"to my feelings."],[2686,3057,"Because tonight, I'm the Crimson Killer."],[3495,3574,"Heart rate's 40."],[3591,3641,"No."],[3687,3774,"42."],[3858,3970,"Yeah, he's asleep."],[6402,6552,"To Maddie."],[6648,6723,"Always."]],"26":[[350,542,"Wait, that's the matching pair"],[542,638,"to Hayden's ring."],[1409,1584,"Hayden, all this time,"],[1584,1793,"the ring you wore was for me."],[1814,1956,"You kept your promise."],[2581,2827,"I wish I could just go back into your arms."],[2911,3036,"Stay with you forever."],[3190,3307,"But I'm an assassin."],[3503,3699,"People like me don't get to love."],[4212,4270,"Freeze!"],[4458,4575,"Caught in the act."]],"27":[[296,471,"Well, well, well."],[592,704,"Crimson Killer."],[825,980,"Hayden caught you perfectly."],[1001,1205,"I was so naive."],[1205,1388,"Why would Hayden ever trust a criminal,"],[1388,1551,"when he has the governor's daughter"],[1551,1722,"hanging on to his every word?"],[1772,1897,"Dirty criminals like you"],[1943,2118,"don't get to look away."],[2389,2477,"I'm gonna show you"],[2477,2627,"just how undeserving"],[2690,2786,"you really are."],[3941,4099,"And I'm gonna make you pay"],[4099,4220,"for taking Hayden's attention"],[4220,4295,"away from me."],[4437,4554,"I don't think so."],[4729,4829,"You mutt!"]],"28":[[141,279,"Drop it, Dorset."],[392,592,"Hayden's standing up for a murderer"],[592,692,"over his partner?"],[692,788,"No violence."],[809,992,"My investigation, my rules."],[992,1151,"But she hit me first."],[1172,1276,"What's so special about her"],[1276,1393,"that you let her do that to me?"],[1418,1493,"A better officer"],[1493,1580,"would have dodged it."],[1889,2097,"Now, Crimson, talk,"],[2097,2202,"and we'll let you live."],[2260,2360,"Behind bars?"],[2360,2477,"I'd rather be dead."],[2477,2577,"I give you my word."],[2577,2744,"Your word means nothing."],[2840,2890,"I'm-"],[3048,3224,"I'm giving you an offer, goddammit."],[3361,3478,"Now listen,"],[3532,3682,"before I take it back, Maddie."]],"29":[[29,154,"Oh, he knows."],[162,350,"Hayden knows I'm the Crimson Killer."],[350,458,"Excuse me?"],[487,671,"My partner asked you a question."],[813,842,"I..."],[900,1184,"And he doesn't give a shit about you."],[1455,1609,"Can you promise protection?"],[1876,2318,"I killed because Dante has my sister."],[2356,2423,"Katie."],[2494,2581,"She's eight."],[2781,2898,"Why didn't you tell me?"],[2923,3011,"Why didn't you tell me?"],[3011,3098,"I could have helped you."],[3103,3203,"Well, that doesn't matter."],[3203,3299,"It's too late now."],[3361,3536,"That's a confession, right?"],[3678,3737,"Hayden?"],[3828,3924,"Come on, Hayden."],[3962,4062,"Let me arrest her."],[4158,4358,"It'll be the perfect case closed."],[4379,4608,"And then, we can do whatever you want."],[4692,4829,"However you want."],[4871,5055,"You'll be the most powerful D.A."],[5055,5196,"New York's ever seen,"],[5217,5351,"and I'll be right by your side."],[5467,5609,"Serving your every need."],[5638,5814,"Just keep Katie safe, okay?"],[5897,5964,"You're right."],[6001,6131,"I am the District Attorney."],[6135,6297,"My job is to protect and serve."],[6318,6452,"No matter what the circumstances"],[6452,6514,"may be."]],"30":[[642,742,"So what?"],[742,888,"What, this is all some farce?"],[888,938,"For me to-"],[1438,1609,"I promised I'd always protect you, right?"],[1718,1797,"Oh, God."],[1810,1881,"You're sick."],[1956,2027,"Hayden."],[2089,2193,"Sick in the head."],[2886,2973,"What would people say"],[2973,3119,"if they saw you kissing the criminal"],[3119,3253,"you're supposed to convict, huh?"],[7490,7620,"Do you feel that?"],[7899,8070,"That's what you fucking do to me."],[8149,8287,"Fuck everyone, I said it."]],"31":[[842,975,"So, if we're gonna be a team,"],[975,1180,"we have to figure out Dante."],[1180,1276,"I mean, I think"],[1292,1468,"Katie is safe at the hospital right now,"],[1468,1589,"but we, we've gotta, good, find a way"],[1589,1730,"to get her out of his grasp."],[1747,1960,"I cannot have her turning out like me."],[1960,2039,"I can't."],[2077,2164,"I'll just have a warrant"],[2164,2260,"put out for Dante's arrest."],[2260,2364,"No, no."],[2510,2623,"He would take her and he would run."],[2623,2815,"We cannot have him suspect anything."],[3691,3870,"I guess we need a foolproof plan then."],[4658,4859,"I've only ever been able to trust myself."],[4929,5071,"Now, working with someone else?"],[5171,5276,"Feels different."],[5718,5834,"That's her, officer."],[5935,6056,"Arrest that woman."],[6293,6339,"What?"],[6339,6377,"Hey!"],[6506,6573,"Shit."],[6573,6694,"That's Hayden's detective."]],"32":[[2093,2152,"You know what?"],[2152,2327,"This is unlawful arrest."],[2348,2456,"Shut up, whore."],[2565,2715,"My dad's the governor."],[2769,2857,"I am the law."],[2952,3019,"I can't believe"],[3019,3165,"I let the Crimson Killer get away."],[3194,3390,"I'll make up for it by torturing intel"],[3390,3520,"out of this bartender."],[3574,3745,"Hayden will be so grateful."],[3745,3891,"He'll have to sleep with me."],[4004,4108,"You know, I'm sure this is gonna go"],[4108,4279,"over great with the District Attorney."],[4362,4542,"You stupid bitch."],[4667,4804,"Morning, everybody!"],[5572,5651,"Oh, Hayden."],[6093,6147,"Keys."],[6631,6760,"I see you're seeing someone."]],"33":[[29,241,"Well, you know, we were just, uh..."],[296,337,"I didn't know"],[337,396,"you were coming in today-"],[396,483,"I believe I was addressing"],[483,579,"Officer Durge."],[625,696,"Sir, yes, sir."],[709,817,"We were going to question her."],[855,930,"Questioning."],[984,1055,"Great idea."],[1138,1213,"Officer Dorset,"],[1213,1351,"I don't believe you're authorized"],[1351,1418,"to do that."],[1418,1543,"But lucky for you, I am."],[1580,1651,"Officer Durge,"],[1697,1835,"go set up the polygraph test."],[1835,1897,"Yes, sir."],[2035,2139,"Detective Dorset."],[2231,2344,"Wait for us outside."],[2439,2485,"Let's go."],[4112,4229,"Is this really necessary,"],[4229,4350,"Mr. District Attorney?"],[4854,4925,"I'll be the one"],[4925,5100,"asking the questions here, Miss Archer."],[6969,7061,"Now, my first question,"],[7061,7161,"Miss Archer."],[7248,7315,"Are you gonna be"],[7315,7428,"a good girl and comply?"]],"34":[[50,250,"I'm deciding to trust you, Hayden."],[304,392,"Yes, sir."],[542,654,"Very good."],[1505,1609,"Hold still."],[4458,4554,"That slut."],[4637,4767,"He never touches me like that."],[5138,5276,"Now, when I ask you a question,"],[5276,5388,"you will answer immediately."],[5388,5509,"Understood?"],[5518,5593,"Yes, sir."],[5718,5764,"Now."],[6243,6356,"Are you ready to have some fun,"],[6356,6431,"Miss Archer?"]],"35":[[125,216,"We'll start off easy."],[454,542,"What's your name?"],[629,725,"Madeline Archer."],[796,859,"Age?"],[909,980,"26."],[1034,1105,"Family."],[1284,1455,"Dead, except my sister."],[1509,1593,"Biological?"],[1818,1889,"No."],[1914,2018,"No. Adopted."],[2110,2193,"Lover?"],[2423,2485,"A couple."],[2673,2736,"A couple?"],[2861,2952,"Officer Durge,"],[3007,3132,"we have a baseline reading."],[3365,3461,"All clear, sir."],[3624,3703,"Very good."],[4158,4437,"Let's see what else I can get out of you."]],"36":[[417,550,"You're a bartender, Madeline?"],[667,725,"Yeah."],[850,996,"Is that a dangerous job?"],[1130,1255,"Not really, but"],[1376,1559,"sometimes dangerous people"],[1559,1634,"come in."],[1668,1810,"And what do you do when that happens?"],[2006,2264,"I figure out what they want"],[2540,2660,"and then I serve them."],[2844,2952,"Officer Durge!"],[3032,3161,"Any erratic readings?"],[3186,3294,"None so far, sir."],[3670,3753,"Excellent."]],"37":[[158,291,"Miss Archer, do you know a guy"],[291,417,"named Dante Caprio?"],[846,1117,"He owns the bar where I work."],[1142,1192,"Yeah?"],[1192,1288,"And what else does he do?"],[1472,1551,"I don't know, uh,"],[1551,1914,"probably, um, owns other bars."],[2377,2477,"So what were you doing"],[2477,2615,"at 11 p.m. last night?"],[3098,3178,"Mr. Kent,"],[3228,3370,"her heart rate's erratic."],[3586,3682,"That's interesting."],[3766,3878,"Let me ask that again."],[3887,4133,"What were you doing at 11 p.m. last night?"],[4266,4366,"I, um..."]],"38":[[33,100,"I..."],[692,796,"I slept with a man"],[796,967,"that I probably shouldn't have."],[1405,1522,"He must have been quite a man"],[1522,1651,"to have this effect on you."],[1768,1822,"Yeah."],[1931,2018,"He was good."],[2085,2339,"But I shouldn't have let myself do that."],[2556,2635,"And yet,"],[2711,2769,"you did."],[2890,2940,"Yeah."],[3616,3728,"But I regret it."],[3887,4020,"Officer, do we have a reading?"],[4688,4754,"It's..."]],"39":[[279,379,"It's all true, sir."],[738,821,"Then, we're done here."],[1017,1167,"I hope that clears up any concerns,"],[1167,1263,"Detective Dorset."],[2177,2302,"Screw you, Hayden!"],[2339,2535,"I tried every trick in the book,"],[2560,2706,"but you'd still rather tramp around"],[2706,2848,"with a barmaid than the daughter"],[2848,2957,"of the governor of New York."],[2973,3169,"If I can't win you over with my charms,"],[3169,3324,"then the enemy of my enemy"],[3324,3457,"is now my friend."],[3545,3720,"Put me in contact with Dante Caprio."],[7077,7186,"You covered for me."],[7248,7361,"Of course, I did."],[7449,7615,"I told you I would always protect you Maddie."],[8128,8241,"Sir, are you in there?"],[8241,8295,"Sir."],[8333,8508,"Can I really trust Hayden?"],[8562,8621,"Sir."],[9513,9592,"You said you regretted"],[9592,9705,"being with me earlier."],[9763,9813,"Yeah."],[10352,10435,"You're lying."]],"40":[[50,200,"Why are you lying, Maddie?"],[200,325,"We're both on the same side."],[462,558,"The same side?"],[696,892,"You're the District Attorney."],[917,1051,"I'm the Crimson Killer."],[1172,1334,"I'd be your headline any day."],[1564,1735,"Mr. Kent, I have a message."],[1935,2047,"One minute, please."],[2969,3128,"But you don't regret picking me."],[3211,3286,"I do."],[3561,3653,"You're lying."],[3653,3724,"Again."],[3841,3978,"Of course I regret you,"],[4087,4187,"how could I not?"],[4679,4788,"You like that, don't you?"],[4904,5005,"You don't know that."],[5155,5234,"Yes, I do."],[5271,5309,"No."],[5351,5513,"I feel your pulse right now."],[5901,6014,"Just admit it, Maddie."],[6468,6585,"I don't regret you."],[6798,6986,"I just wish I could trust you."],[7298,7536,"Please, don't let this be a mistake."]],"41":[[2773,2840,"Hello."],[2840,2969,"This is Hope Hospital."],[2969,3157,"You have one message."],[3190,3269,"Hi, Maddie."],[3290,3457,"The doctor said I can go home early,"],[3457,3591,"so Uncle Dante picked me up."],[3795,3912,"Dante has my sister."]],"42":[[221,367,"You took my childhood."],[400,600,"You took my first love."],[600,679,"And now,"],[734,880,"now you've taken my sister."],[1297,1351,"Katie."],[1964,2031,"He says we're playing"],[2031,2139,"hide and seek, and you have to"],[2139,2210,"to come find us."],[2210,2310,"Bye, I love you."],[2456,2519,"No."],[2698,2944,"I don't care what I have to do, Dante."],[3011,3211,"But I won't let you raise another killer."],[3278,3528,"I won't let you ruin my sister."],[3541,3607,"Maddie?"],[3657,3762,"Maddie, is that you?"]],"43":[[250,367,"Hey, hey."],[521,633,"Can I take the blindfold off now?"],[633,717,"No, no, no, no."],[763,996,"Um, I still need to find Uncle Dante."],[1251,1368,"Did he tell you where he is?"],[1397,1505,"He just said to sit here"],[1505,1580,"with my eyes closed"],[1580,1676,"until you find me."],[1868,1951,"Come on."],[2018,2156,"Did he say what would happen next?"],[2198,2327,"He said I'll get to do something"],[2327,2406,"very special."],[2498,2602,"I'll get to shoot a gun"],[2602,2702,"for the first time."],[2777,2952,"Dante wants to make Katie shoot me."],[2952,3253,"He wants to initiate her into his gang"],[3332,3457,"to be my replacement."],[3991,4279,"You like my setup, Crimson Killer?"]],"44":[[58,162,"Stand down, boys."],[162,241,"It's okay."],[633,804,"Why don't you go outside and play"],[804,942,"while I talk to your sister?"],[942,1038,"Okay, sweetheart? Ok."],[1146,1263,"All right, I'll meet you out there."],[1384,1451,"Okay."],[1509,1580,"Bye."],[2118,2214,"This was your plan?"],[2235,2268,"Hm?"],[2414,2510,"You lure me here"],[2510,2761,"so my eight-year-old sister"],[2761,2915,"is forced to shoot me?"],[3023,3315,"No, so she chooses to shoot you."],[3403,3503,"At the end of the day,"],[3503,3649,"it's her decision to pull the trigger."],[3724,3807,"That's low,"],[3933,4033,"even for you."],[4116,4200,"What can I say?"],[4250,4400,"You refused my orders to kill."],[4425,4637,"You led the cops to our hideout twice."],[4854,5025,"You might be my best, Maddie,"],[5063,5313,"but there's always new blood."],[5805,5935,"What do you want me to do?"],[6006,6072,"Come back."],[6214,6322,"And if I refuse?"],[6402,6539,"Six assassins,"],[6552,6760,"spaced around the room."],[6877,7027,"Hired special for this occasion."],[7090,7294,"Make one wrong move,"],[7378,7482,"and you'll condemn your sister"],[7482,7603,"to the same hell you're in."],[7649,7707,"No."],[7749,7878,"No, I spent too long"],[7878,8078,"at your beck and call."],[8078,8345,"Dante, I refuse to blindly follow"],[8345,8450,"your orders anymore."],[8500,8646,"Then you die today."],[8804,8892,"Don't expect that"],[8892,9088,"your little District Attorney"],[9088,9159,"can save you."]],"45":[[8,200,"You don't think I know your plan?"],[638,775,"This is a hostage situation."],[775,892,"We need to get the elite teams on it."],[892,942,"No."],[1017,1121,"No, it has to be me."],[1539,1689,"We both know this is a trap."],[1876,1931,"I know."],[2102,2243,"That's why we have to outsmart Dante."],[2444,2548,"How did you-"],[2769,2890,"You had a mole."],[2927,3194,"You know, she reminds me of you."],[3236,3432,"So ambitious, so ruthless."],[3486,3645,"She knows exactly what she wants,"],[3670,3832,"and she'll do anything"],[3887,3953,"to get it."],[4099,4145,"What?"],[4579,4662,"Annabel?"],[4700,4763,"Checkmate."]],"46":[[104,175,"You remember"],[221,400,"my first lesson, Maddie?"],[613,855,"Never trust anyone outside the game."],[938,1238,"Your new allegiances are making you"],[1238,1305,"weak."],[1776,1922,"I will not"],[1947,2131,"back down to you again."],[2189,2252,"In a moment,"],[2252,2327,"Hayden's gonna bust"],[2327,2398,"through that door,"],[2444,2598,"but without his troops."],[2815,3103,"You will get over yourself,"],[3119,3194,"and shoot him."],[3194,3282,"Non-lethal,"],[3303,3545,"just make sure you injure him, seriously."],[3624,3841,"Our mole will testify"],[3841,3966,"with self defense."],[3970,4195,"Then we'll spin a tale"],[4250,4387,"of how Hayden went on"],[4387,4575,"this wild goose chase to"],[4575,4738,"catch his Crimson Killer."],[4808,4992,"And you stepped up to defend us."],[5017,5284,"They'll love your underdog story."],[5313,5422,"And Hayden's reputation"],[5422,5501,"will be ruined."],[5672,5784,"God, I get it now."],[5830,5980,"That means Hayden will be forced"],[5980,6206,"to rely on Annabel for everything."],[6239,6398,"That's how she plans to get her man."],[6423,6493,"You know what?"],[6493,6660,"It is a nice try, Dante."],[6869,6994,"But I'm not doing it."],[7036,7136,"You're not doing it?"],[7190,7248,"No."]],"47":[[45,145,"Let me remind you."],[158,266,"Your sister's outside."],[266,316,"Yeah."],[337,454,"Where she is safe."],[492,592,"It was a good plan."],[621,734,"Dante, but you,"],[754,1080,"you missed one critical step."],[1109,1334,"I just told you your plan."],[1418,1476,"Yeah."],[1614,1705,"Our old one."],[1805,1989,"Let's say Hayden comes in"],[2006,2081,"to save you."],[2089,2152,"Surely..."],[2431,2594,"you don't think you can take down"],[2631,2777,"all of these hitmen."],[2831,3144,"There's six of the most elite."],[3165,3211,"Five."],[3232,3294,"What?"],[3353,3741,"There are five of the most elite hitmen."],[4700,4875,"Unlike you, I only trust Maddie"],[4875,4975,"to watch my back."]],"48":[[3086,3161,"We did it."],[3203,3294,"It went perfect."],[3353,3453,"Oh my gosh."],[3603,3687,"Katie, where's Katie?"],[3687,3824,"Did you, did you get her?"],[3828,3891,"She's safe."],[3891,3924,"She's uh,"],[3941,4058,"she's with Detective Dorset."],[4112,4179,"No!"],[4362,4479,"No, no, no, no, no. - Maddie, Maddie!"],[4479,4542,"What's wrong?"],[4562,4629,"Oh my gosh."],[4875,5034,"Poor little Katie."],[5050,5209,"You should have heard her scream."]],"49":[[29,196,"What did you do to my sister?"],[196,275,"Shut up, whore!"],[304,392,"She's not dead."],[433,479,"Yet."],[579,784,"But she will be if you don't comply."],[1472,1609,"What do you want?"],[1797,1906,"Isn't it obvious?"],[2014,2164,"I want the District Attorney."],[2185,2306,"And it seems like I caught him"],[2306,2414,"colluding with a known"],[2414,2510,"gang member."],[2515,2627,"You don't know a damn thing"],[2627,2690,"about Maddie."],[2702,2861,"Maddie this, Maddie that."],[2877,3078,"I don't give a fuck about Maddie!"],[3336,3511,"Today, you're gonna pick me."],[3532,3674,"This is your blackmailing me,"],[3674,3707,"huh?"],[3732,3803,"Bingo."],[3866,4045,"So either, we're gonna"],[4045,4137,"arrest her together"],[4137,4312,"and live happily ever after."],[4346,4512,"Or I'm gonna shoot her"],[4512,4617,"and her brat sister,"],[4758,4859,"and end your career."],[4950,5038,"So what will it be?"],[5075,5171,"Financial ruin"],[5171,5355,"with your death-row prostitute?"],[5551,5668,"Or living the high life"],[5668,5776,"with the governor's daughter?"],[6235,6306,"I choose..."]],"50":[[100,162,"I choose..."],[296,392,"I choose Maddie."],[671,875,"You are really leaving me"],[875,984,"no other choice."],[984,1071,"Boys!"],[1238,1355,"If you're not gonna pick me willingly,"],[1355,1484,"then I'm just gonna have to"],[1484,1593,"take it by force."],[1622,1693,"Don't."],[1739,1856,"You're a public servant."],[1856,1976,"We stand for justice."],[1981,2131,"I don't care if your dad's the governor,"],[2131,2235,"you will be prosecuted"],[2235,2364,"to the fullest extent of the law"],[2364,2406,"if you do-"],[2406,2631,"I don't care about the law!"],[2857,3040,"Hayden, I just want you,"],[3061,3328,"and I will do anything to make you mine."],[3378,3549,"If anyone hears anything about this,"],[3549,3653,"Detective Dorset-"],[3674,3753,"They won't."],[3837,3941,"Because I'm gonna shoot."]],"51":[[62,179,"Because I'm gonna shoot."],[1584,1655,"Shots fired!"],[1664,1751,"Shots fired!"],[1751,1897,"We need to secure District Attorney,"],[1897,1993,"Hayden Kent!"],[1993,2052,"Right now!"],[2052,2118,"Come on!"],[2389,2469,"Wait!"],[2615,2798,"You have to let them catch me, okay?"],[2798,2936,"You have to keep your job,"],[2936,3115,"and you have to protect Katie."],[3199,3244,"No."],[3511,3661,"It took me years to find you."],[3661,3791,"I'm never losing you again."],[4079,4166,"Do you trust me?"],[4333,4391,"I do."],[5071,5105,"Hey,"],[5130,5192,"stop."],[5192,5351,"Hayden, look, there's still a chance."],[5367,5397,"Okay?"],[5397,5534,"We can say that I kidnapped you."],[5893,5964,"Stop it."]],"52":[[8,133,"Ok, we can't stay here."],[133,229,"They are gonna find us."],[279,354,"Eventually."],[529,608,"But not now."],[775,842,"Hey..."],[980,1192,"I've spent my entire life running."],[1351,1551,"And I don't want to do that anymore."],[1701,1918,"Just once, I want to do the right thing."],[1956,2164,"Maddie, you living is the right thing."],[2352,2448,"I'm a killer,"],[2519,2565,"Hayden."],[2602,2907,"We both know that I'm gonna fall eventually."],[2907,3086,"So, I would rather it be at your hands,"],[3086,3144,"okay?"],[3161,3324,"No, Maddie, that's not gonna happen."],[3324,3445,"Nothing's gonna happen to you."],[3445,3524,"I'm gonna take care of you."],[3524,3566,"I-"],[3628,3682,"Don't,"],[3703,3770,"don't worry."],[3995,4154,"We both know that's not true."],[4337,4508,"I just, I want you to promise me"],[4508,4621,"one thing, okay?"],[4792,4892,"Promise me"],[4942,5105,"that you will be in charge of my case."],[5105,5251,"Don't let those other guys touch me,"],[5251,5309,"okay?"],[5384,5505,"Can you promise me that?"],[5609,5680,"I will."],[5743,5905,"Maddie, I need to ask you one more thing"],[5905,6051,"before I let them take you from me."],[6252,6318,"Okay."],[7219,7349,"Be mine, Maddie."]],"53":[[95,262,"You're proposing to me?"],[442,517,"Now?"],[563,671,"Whatever happens next,"],[671,784,"I want everyone to know"],[784,880,"that you're my wife."],[2857,3065,"I just, I wish things were different."],[3265,3386,"I wish I was normal."],[3457,3574,"Maddie, I never would've fallen"],[3574,3678,"for you if you were anything"],[3678,3774,"but yourself."],[3883,3933,"Yeah."],[4383,4500,"Kent, do you copy?"],[4587,4671,"We're approaching"],[4671,4746,"safe house."],[4767,4833,"They're coming,"],[4833,4954,"we don't have much time."],[5088,5176,"Then, we better make every"],[5176,5271,"second count."],[8237,8324,"They're here."],[8508,8604,"Eyes on me."],[8758,8833,"Police!"],[8846,8913,"Open up!"]],"54":[[892,946,"Mr. Kent!"],[946,1059,"Mr. Kent, over here!"],[1059,1163,"Mr. Kent, Mr. Kent!"],[1163,1388,"Ray, Ray Garrison from CMS News."],[1413,1547,"Today marks the last day"],[1547,1710,"of the final investigation"],[1710,1889,"of the notorious Crimson Killer."],[1889,2035,"Are we getting any closer to the truth?"],[2139,2285,"New York City, I'm proud to announce"],[2285,2464,"that the investigation is now closed."],[2464,2548,"Yes!"],[2548,2652,"All right!"],[2698,2777,"We did it. - Yes!"],[2777,2873,"Additionally,"],[3003,3086,"we've identified"],[3086,3249,"the now deceased Crimson Killer."],[3290,3399,"She is none other than"],[3482,3657,"Detective Annabel Dorset,"],[3716,3791,"a former colleague."],[3791,3866,"No way."],[3962,4099,"How could that be, Mr. Kent?"],[4183,4266,"Did you know her?"],[4266,4366,"Did you work with her?"],[4396,4496,"What?"],[4529,4658,"No, that can't be right."],[4804,4913,"It makes no sense."],[4913,5017,"She's my neighbor."],[5034,5159,"No more further questions."],[5230,5284,"I cannot believe that."],[5284,5363,"That's insane."],[5380,5522,"There's no way that could be possible."],[5605,5676,"Good job."],[5747,5839,"Lieutenant Archer."],[6131,6202,"District Attorney!"],[6206,6281,"District Attorney! - Wait!"],[6285,6393,"District Attorney! - Sir, sir!"]],"55":[[462,571,"Wait."],[604,671,"Hey."],[721,871,"I give the orders around here."],[2139,2306,"Gentlemen, I believe Detective Dorset"],[2306,2406,"is working with the enemy."],[2448,2631,"You guys are my most trusted men"],[2660,2786,"in this entire department."],[2836,2957,"When it comes down to it,"],[3036,3174,"are you guys willing to turn on her?"],[3374,3453,"Of course, sir."],[3470,3661,"As captain of the police department,"],[3661,3853,"I, Danforth, and my team,"],[3853,3974,"give our loyalty to you."],[3974,4083,"Don't do it for me."],[4175,4279,"Do it for justice."],[4287,4375,"To justice!"],[4646,4763,"You will be prosecuted"],[4763,4909,"to the fullest extent of the law."],[4909,5038,"I don't care about the law!"],[5121,5263,"I just want you, Hayden."],[5305,5543,"I will do anything it takes"],[5563,5668,"to make you mine."]],"56":[[12,166,"If anyone hears anything about this,"],[166,212,"Detective Dorset-"],[212,342,"They are not going to hear anything"],[342,433,"because I'm gonna shoot."],[1801,1872,"Shots fired!"],[1876,1964,"Shots fired!"],[2068,2122,"Police!"],[2198,2281,"I said stop!"],[2281,2427,"Officer down! - I'm running!"],[2427,2498,"Officer down!"],[2498,2606,"10-21!"],[2644,2790,"We need to secure District Attorney,"],[2790,2932,"Hayden Kent, right now!"],[3115,3186,"Come on, boys."],[3332,3403,"You know what to do."],[3486,3557,"Gloves on."],[5096,5176,"Shit!"],[5276,5380,"Double homicide,"],[5380,5526,"with the Crimson Killer dead?"],[5551,5613,"Yeah, she's gone,"],[5613,5726,"but we can't worry about that right now."],[5739,5834,"We need to secure"],[5834,5985,"District Attorney, Hayden Kent."],[5985,6101,"He ran off with a civilian."],[6126,6285,"Radio 404."],[6285,6377,"We need to get eyes"],[6377,6577,"on District Attorney, Hayden Kent."],[6627,6681,"Let's roll."]],"57":[[379,454,"Hayden, there's something"],[454,546,"I have to tell you."],[650,784,"Are they messing with you out there?"],[838,909,"No, no, no, no."],[909,988,"It's nothing like that."],[988,1071,"Um..."],[1238,1326,"I'm pregnant."],[1751,1847,"Are you gonna get that?"],[1876,2068,"Um, I probably should, huh?"],[2540,2594,"What is it?"],[2594,2748,"New lead on the fraud case, Sir."],[2748,2819,"We need you"],[2819,2944,"and Lieutenant Archer STAT!"],[2957,3015,"Copy."],[3595,3687,"You ready, Lieutenant?"],[3837,3895,"Always."],[4437,4542,"I love you."]]}