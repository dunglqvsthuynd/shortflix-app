blew it."],[3430,3523,"Tough luck."],[3586,3646,"Your mouth."],[3767,3817,"Stand."],[3930,3993,"All of them."],[4050,4170,"With those numbers?"],[4170,4247,"She's out!"],[4277,4407,"He's feeding me low cards"],[4407,4531,"to make me feel safe."],[4594,4731,"The next one will be high."],[4811,4948,"He wants me to bust."],[5111,5188,"Guess it's my turn."]],"32":[[60,140,"Guess it's my turn."],[740,880,"She's a lucky girl indeed."],[990,1144,"The dealer drew 13."],[1191,1261,"He's stuck."],[1368,1478,"He has to draw again."],[1554,1631,"If he busts,"],[1741,1798,"she wins."],[2952,3076,"He wants to cheat now."],[3383,3440,"Shit!"],[3503,3626,"She knows I wanna cheat!"],[3690,3850,"Why don't we draw your next card together?"],[3903,4050,"I can lend you some of my luck."],[4354,4491,"Girl, I... that's, that's gross."],[4491,4561,"I, uh..."],[4627,4784,"been in this business for a long time."],[4784,4944,"I mean, stealing luck from a woman?"],[4944,5025,"Come on, please."],[5025,5148,"I'd be the laughing stock."],[5238,5305,"What a shame."],[5525,5595,"Damn it!"],[5655,5805,"Now, I have to risk it!"]],"33":[[1191,1274,"He busted!"],[1301,1444,"He busted!"],[1685,1908,"She just won $2 million!"],[1908,2038,"She's a killer!"],[2038,2148,"I'm so lucky!"],[2148,2278,"Lucky, lucky, lucky!"],[2415,2579,"Who the hell are you, really?"],[2752,2796,"Me?"],[2869,3033,"I'm Jay's wife, Scarlett."],[3089,3183,"Just a lucky girl."],[3253,3326,"And you owe me"],[3376,3480,"$2 million."],[3740,3780,"Fine."],[3907,4024,"A bet is a bet."],[4090,4174,"Bring me two million."],[4317,4537,"She's supposed to be a dumb housewife."],[4584,4724,"How did she see through my trick?"],[4801,5005,"Or am I overthinking it?"],[5071,5165,"There's your 2 million."],[5238,5382,"You can count it here if you like."],[5485,5555,"I trust you."],[5642,5705,"But,"],[5809,5912,"I wanna keep playing."]],"34":[[3,100,"I wanna keep playing."],[360,500,"Oh, yeah, she really is insane, huh?"],[540,623,"She just won big"],[623,810,"and now she wanna push it all back."],[837,1011,"What if she loses it all this time?"],[1011,1144,"You've got some nerve, girl."],[1264,1354,"Are you scared?"],[1588,1676,"Me scared?"],[1676,1730,"No."],[1730,1787,"Never."],[1805,1913,"I don't give jackshit"],[1913,2025,"about losing a few million."],[2025,2062,"But..."],[2092,2142,"you?"],[2218,2359,"If you lose this, then"],[2395,2475,"you'll have nothing."],[2679,2722,"Well..."],[2836,2952,"I guess I'll just have to bet"],[2952,3113,"something that money can't buy,"],[3166,3236,"like..."],[3463,3543,"myself."],[4404,4536,"Yourself?"],[4564,4631,"Hmm."],[4754,4961,"This bitch wants to keep going."],[4961,5058,"What a dumb idiot!"],[5098,5145,"Now,"],[5185,5468,"I'm gonna make sure you lose everything."],[5595,5649,"All right."],[5649,5789,"Enough of these child games."],[5789,5935,"Shall we play the real ones?"],[5962,6056,"Clear the table!"],[6076,6219,"We're raising the stakes."],[6536,6730,"Bring it on."]],"35":[[50,106,"All right."],[236,306,"Let's play."],[367,483,"If my read is right,"],[550,704,"this should be 15."],[1905,2012,"All right."],[2012,2102,"New round, but..."],[2152,2265,"I see you don't have any cash."],[2298,2399,"I could, uh..."],[2422,2509,"lend you four million."],[2509,2589,"How does that sound?"],[2682,2729,"Okay."],[2792,2872,"But..."],[2949,3019,"one condition."],[3096,3176,"What condition?"],[3283,3346,"You know, it's just a..."],[3400,3536,"little contract."],[3603,3720,"You'll be my slave,"],[3867,4030,"and you'll do exactly what I say"],[4054,4364,"until every penny is paid back."],[4701,4864,"Slavery contract?"],[4891,5028,"This is outrageous!"],[5028,5088,"Don't sign it."],[5135,5268,"I heard no one ever comes back."],[5331,5482,"Men get sold for organs."],[5508,5648,"Women get sold to brothels,"],[5682,5809,"and then for organs after."],[5829,5962,"That's horrible!"],[5962,6082,"She cannot sign!"],[6202,6249,"Well."],[6493,6563,"Do we have a deal?"],[6696,6736,"Deal."]],"36":[[173,216,"But..."],[260,350,"if I win,"],[350,470,"this contract is void."],[510,653,"You're not gonna back out, are you?"],[814,924,"Of course not."],[987,1141,"Everyone here is a witness, right?"],[1141,1231,"And..."],[1231,1324,"if you win, you could just"],[1374,1531,"tear that little contract up and"],[1558,1624,"throw it aside."],[1671,1715,"But..."],[1755,1878,"but I do have to ask,"],[1961,2165,"what makes you think you're so lucky?"],[3099,3176,"That's a good girl."],[3323,3380,"Four million."],[4594,4637,"All in!"],[5241,5301,"Let's play."],[5465,5505,"Hit."],[5618,5662,"Wait,"],[5779,5935,"I want three cards all at once."],[5975,6059,"Three hits?"],[6089,6262,"I've never seen anyone do that."],[6262,6339,"That's insane!"],[6349,6456,"You just signed your life away."],[6526,6639,"Is it against the rules?"],[6883,6986,"If that is what you want."],[7070,7143,"And it's what I want."],[7637,7744,"If I counted right,"],[7794,7987,"these three should bring me to 21."],[8568,8671,"That's twenty already."],[8752,8922,"One more card, and he's gonna bust you."],[8958,9029,"Told you,"],[9059,9155,"don't push your luck."],[9202,9315,"You're not the Gambling Queen."],[9636,9719,"Excuse me,"],[9769,9936,"but I am the Gambling Queen."]],"37":[[774,860,"Whoa!"],[880,1034,"She hits 21!"],[1167,1257,"Unless the dealer"],[1287,1371,"hits Blackjack,"],[1371,1451,"nobody beats that."],[1468,1518,"How..."],[1611,1795,"how is that possible?"],[1815,1928,"Who the hell is this bitch?"],[1928,2032,"Is she counting cards?"],[2092,2148,"Your turn."],[2225,2285,"Shut up."],[2308,2402,"Shut the fuck up!"],[2449,2485,"Hey..."],[2525,2652,"I still haven't drawn yet."],[2652,2762,"It's my turn."],[3350,3413,"Six shown."],[3853,3953,"Soft 17."],[3983,4070,"Dealer has to hit."],[4994,5071,"That's 12."],[5632,5715,"16!"],[6072,6176,"What's the matter, Tom?"],[6272,6443,"I just did 3 cards all at once"],[6443,6626,"after signing a slave contract."],[6690,6853,"But a big guy like you can't handle it?"],[7534,7587,"Tom,"],[7687,7811,"didn't I warn you already?"],[7937,8014,"Don't do that."],[8071,8118,"What..."],[8184,8267,"what are you talking..."],[8267,8391,"What are you fucking implying?"],[8458,8548,"If you cheat,"],[8548,8738,"this won't just end with me beating you."],[8782,8865,"Cheaters"],[8918,8995,"lose hands."]],"38":[[657,750,"He busted!"],[780,884,"He busted!"],[1057,1121,"Eight million!"],[1141,1341,"She just won 8 million in one go!"],[1381,1451,"Lucky girl!"],[1508,1581,"Told you."],[1808,1901,"Yeah!"],[2048,2118,"No, no, no..."],[2632,2706,"You..."],[2706,2779,"You!"],[2789,2862,"Eight million."],[2959,3006,"Pay up."],[4207,4387,"Who is that woman?"],[4494,4607,"Our record shows her name is"],[4607,4698,"Scarlett Hawkins,"],[4698,4801,"married to Jay Hawkins."],[4821,4871,"A nobody."],[4901,5031,"But, here's the strange part."],[5068,5251,"She has no record before age 18."],[5291,5345,"Nothing at all."],[5475,5595,"Interesting."],[6309,6490,"Could it really be her..."],[6619,6723,"Let's go to meet her."]],"39":[[33,163,"No, no, no, no, no!"],[193,266,"Eight million."],[360,420,"Pay up."],[457,537,"You fucking cheated!"],[537,714,"You... you counted these fucking cards!"],[714,784,"I cheated?"],[837,950,"Do you have any proof?"],[1021,1054,"You..."],[1124,1267,"you fucking cunt!"],[1267,1371,"Okay, Tom,"],[1478,1551,"why don't you tell us"],[1551,1681,"what's inside that card shoe?"],[1961,2122,"Someone was about to cheat."],[2122,2322,"Yeah, he was messing with the shoe"],[2322,2479,"before he drew the last card."],[2479,2625,"You were going for the switch,"],[2625,2712,"and she stopped you."],[2786,2936,"But if you're really so innocent,"],[3026,3093,"open the shoe."],[3119,3213,"Yeah, open the shoe."],[3283,3353,"Damn right!"],[3353,3503,"No wonder we keep losing here."],[3516,3653,"Sam, let's open it."],[3653,3743,"How dare you!"],[3837,3943,"Get the fuck out of here!"],[4034,4094,"Look at this."]],"40":[[0,63,"Look at this."],[143,250,"This is how he cheated."],[377,603,"The man behind my parents' deaths..."],[700,870,"How long are you going to hide?"],[934,1085,"Yeah, no wonder you're always"],[1085,1271,"hitting Blackjack at the end."],[1311,1418,"What a scumbag!"],[1438,1721,"How fucking dare you!"],[1721,1818,"Wow, Tom,"],[1818,2048,"I thought you were a prestige gambler, but..."],[2048,2195,"turns out you're just another cheat."],[2355,2442,"Who are you?"],[2505,2575,"You..."],[2575,2726,"you stupid bitch."],[2726,2896,"Who sent you?"],[3036,3243,"Scarlett Hawkins is a lucky girl."],[3326,3426,"Gambling God sent me to"],[3426,3590,"punish corrupt guys like you."],[3717,3783,"Fine."],[3810,3997,"We'll wait until my boss gets here."],[3997,4237,"You filthy little whore."],[4341,4397,"Oh, wait."],[4474,4534,"Remember?"],[4567,4694,"Cheaters lose their hands."],[4694,4764,"Yeah!"],[4764,4861,"Cut his hand!"],[4908,5001,"Yeah, cut his hand!"],[5001,5121,"Cut his hand!"],[5121,5258,"- Cut his hand! - Cut, cut, cut, cut!"],[5258,5385,"- Cut! - Cut his hand!"],[5385,5502,"What's going on here?"],[6379,6543,"You finally show yourself."],[6633,6711,"The man"],[6711,6946,"who masterminded my parents' deaths."]],"41":[[160,390,"Who's causing trouble in my casino?"],[463,617,"I've been looking for you"],[617,717,"for years."],[760,844,"So you're the owner."],[930,1034,"Be respectful, woman."],[1061,1177,"This is Mr. Luke Skylar,"],[1194,1271,"the Gambling King."],[1518,1601,"Mr. Skylar,"],[1705,1878,"Tom owes me eight million dollars,"],[1905,2035,"but, instead of paying,"],[2035,2125,"he tried to cheat."],[2242,2318,"Is that true?"],[2318,2412,"Yeah, we got proof."],[2412,2522,"We found the device."],[3099,3263,"You worthless freeloader."],[3553,3630,"Sir, let me..."],[3713,3827,"let me... let me explain."],[3867,3943,"All right, I..."],[3943,4044,"I didn't even get to..."],[4044,4140,"to cheat yet."],[4140,4254,"She... she already caught me."],[4284,4461,"You dare embarrass me here?"],[4604,4691,"So, he admits it."],[4768,4964,"Shouldn't we follow the casino rules?"],[4964,5105,"Yeah, follow the rules!"],[5105,5231,"Cheaters lose a hand!"],[5231,5392,"Yeah, cut his hand!"],[5392,5428,"Cut it."],[5438,5495,"Yeah."],[5495,5582,"Yeah, cut his hand!"],[5582,5638,"Cut it."],[5638,5705,"Cut his hand."],[5705,5789,"Sir, please..."],[6119,6189,"Do it."],[6206,6329,"No, no, no, no, please..."],[6329,6456,"- Do it! - No, no, Sir..."],[6456,6623,"Sir, please, please, I didn't mean it!"],[6649,6736,"I didn't mean it, Sir!"],[6906,7007,"No, no, no, no!"],[7007,7084,"Please, please..."],[7084,7230,"I'm begging you. Forgive me..."],[7564,7614,"Wait."]],"42":[[3,53,"Wait!"],[303,447,"Cut off the other hand instead."],[864,914,"Fine."],[927,1027,"No, please!"],[1037,1087,"Please..."],[1124,1221,"please... I'm begging you!"],[1401,1491,"My hand!"],[1518,1678,"My fucking hand!"],[1698,1925,"That hand is the price you paid"],[1925,2135,"for killing my parents on his behalf."],[2208,2335,"But that's not enough."],[2415,2495,"Take him out."],[3076,3153,"What a shame."],[3203,3329,"Wasn't done playing with him."],[3460,3553,"Then play with me."],[3843,3970,"Gladly, Mr. Skylar."],[4254,4320,"Miss,"],[4421,4497,"don't you know him?"],[4554,4721,"That's Luke Skylar, the Gambling King."],[4744,4831,"No one crosses him."],[4888,4994,"Yeah, you've won enough."],[5011,5078,"Just leave."],[5251,5398,"I think I'll stick to having fun."],[5602,5722,"I'll give you one game."],[5799,5895,"Old fox."],[5949,6176,"I've waited my whole life for this moment."],[6226,6476,"This is my final bet."]],"43":[[80,266,"Well, even if you are the Gambling King,"],[286,417,"I still trust my luck."],[1021,1083,"Your eight million"],[1083,1242,"has already been converted."],[1301,1471,"I run an honest house."],[1508,1648,"Your winnings are yours."],[1755,1858,"Thank you, Mr. Skylar."],[1961,2062,"What game should we play?"],[2082,2155,"You choose."],[2205,2325,"I can play anything."],[2455,2729,"Well, I have heard of this one challenge."],[2762,2856,"It's called the.."],[2956,3099,"the Three, um..."],[3256,3406,"Three-Round Challenge."],[3406,3480,"Yes, that one."],[3606,3710,"You really wanna play"],[3710,3896,"Three- Round Challenge with me?"],[4114,4250,"What's the Three-Round Challenge?"],[4297,4467,"Three consecutive all-in rounds."],[4501,4647,"You beat him three times in a row,"],[4684,4814,"or you lose everything!"],[4854,4924,"Holy crap!"],[4948,5061,"She really is nuts!"],[5081,5218,"In all those years,"],[5231,5445,"nobody dared challenge me."],[5485,5572,"So, if you win,"],[5632,5799,"you keep everything you took."],[5885,5949,"Plus,"],[5979,6086,"I double it."],[6146,6220,"Wow."],[6220,6319,"That sounds like fun."],[6413,6519,"For the first round,"],[6559,6666,"can we play dice?"],[6666,6736,"Of course."],[6853,6973,"Greg, bring the dice."],[7163,7223,"Please."],[7691,7771,"This check..."],[7817,7897,"8 million."],[8078,8128,"All in."],[8455,8515,"All in?"],[8585,8648,"Are you sure?"],[8735,8855,"Go ahead and laugh."],[8895,9045,"Your blood debt is due."]],"44":[[266,370,"I'll give you this."],[393,670,"It takes real guts to challenge me at dice."],[727,910,"My boss has never lost a dice match."],[944,1051,"You're done for."],[1161,1234,"Miss,"],[1301,1408,"poker might be luck,"],[1408,1571,"but dice takes real skills."],[1598,1691,"Maybe you should walk away."],[1778,1958,"Who says that dice can't rely on luck?"],[2018,2168,"And I have the best luck in the world."],[2305,2385,"Okay."],[2429,2522,"First round,"],[2542,2719,"high roll wins."],[2746,2796,"Well,"],[2859,2969,"you're the Gambling King."],[3039,3119,"You go first."],[3193,3239,"Teach me."],[3273,3370,"Watch carefully."],[4484,4678,"That strength and precision."],[4801,4974,"He really does deserve the title"],[4974,5091,"of the Gambling King."]],"45":[[260,400,"Impressive, Mr. Skylar!"],[400,603,"Those points must be worth a lot."],[620,724,"Getting scared?"],[837,980,"If you surrender now,"],[980,1074,"I'll be generous."],[1127,1234,"You just lose half."],[1354,1451,"So thoughtful of you."],[1558,1715,"Maybe you should listen to him."],[1755,1871,"Half is still a lot."],[1871,1995,"Yeah, that's 4 million."],[2018,2105,"Take it and leave."],[2268,2345,"I won't surrender."],[2385,2495,"Think carefully."],[2542,2696,"Once I lift this cup,"],[2799,2919,"there's no turning back."],[3013,3079,"Go ahead."],[3153,3309,"There's no way you could roll five sixes"],[3309,3413,"on a casual shake."],[3433,3493,"Well..."],[3596,3683,"I guess you're wrong."],[4254,4337,"What the hell?"]],"46":[[120,203,"Five sixes."],[240,320,"Every one of them!"],[410,587,"How is she supposed to beat that?"],[620,737,"If she'd surrendered earlier,"],[757,877,"she would have only lost half."],[894,1021,"Now look, everything's gone."],[1071,1194,"That's the Gambling King for you."],[1461,1618,"You're just a housewife"],[1618,1845,"with some little blind luck."],[1901,2058,"You really thought you could beat me?"],[2128,2285,"You were never in my league."],[2402,2706,"Isn't it a little early to declare victory?"],[2776,2872,"I haven't rolled yet."],[2936,3066,"I could roll five sixes."],[3066,3129,"Are you stupid?"],[3166,3363,"Even if you roll five sixes, you still lose."],[3393,3570,"The rule is, ties go to the house."],[3770,3807,"What?"],[4000,4137,"No, I... I didn't know that!"],[4137,4214,"That's not fair!"],[4237,4377,"Why wouldn't you tell me that earlier?"],[4391,4461,"You didn't ask."],[4504,4647,"Either way, you are done for."],[4811,4964,"She has zero chance now."],[4988,5048,"We warned her."],[5098,5191,"But she refused to listen."],[5348,5482,"As long as I haven't rolled,"],[5562,5662,"I still have a chance."],[5749,5872,"What's the point of rolling?"],[5892,6012,"You think you can roll a seven?"],[6012,6072,"Greg,"],[6172,6356,"how many times have I told you?"],[6399,6646,"Show some manners when you talk to a lady."],[6646,6743,"Let her roll!"]],"47":[[747,924,"You said you're gonna beat Mr. Skylar."],[924,1051,"I thought you knew some tricks."],[1074,1237,"Turns out you're really relying on luck."],[1267,1388,"Go home and cook, woman."],[1441,1518,"You're not playing."],[1604,1654,"Be quiet."],[1725,1801,"Okay."],[1801,1888,"Let's see what you got."],[2339,2485,"This is sloppy."],[2509,2759,"I thought she might be Rick Spade's daughter."],[2759,3006,"Turns out I overestimated her."],[3123,3186,"Done?"],[3353,3393,"Done."],[3430,3666,"Even when you were losing, you still rolled."],[3730,3790,"Losing?"],[3907,3993,"Who decided that?"],[4130,4320,"Are you gonna roll seven today?"],[4394,4481,"Open your eyes."],[4577,4631,"Let's find out."]],"48":[[320,467,"Oh my God!"],[530,767,"That's five sixes and a one."],[794,950,"How did she even do that?"],[950,1064,"What kind of trick is that?"],[1094,1241,"I didn't expect that."],[1241,1391,"I underestimated you."],[1464,1528,"Told you."],[1581,1644,"Lucky girl."],[1761,1911,"One of the dice broke in half."],[1951,2018,"Extra point."],[2122,2185,"I win."],[2335,2422,"Well, well..."],[2469,2792,"a housewife with some hidden skills."],[2812,2929,"Didn't see that coming."],[3136,3506,"She could really be Rick Spade's daughter."],[3530,3596,"Well,"],[3596,3727,"I'll take that 8 million now."],[3753,3953,"Hey, not so fast."],[3977,4120,"This is just the first round."],[4154,4364,"Even if you lose one of the three rounds,"],[4411,4521,"you will lose everything."],[4788,4941,"Well then, for the second round,"],[4971,5058,"I'll raise."],[5115,5208,"16 million."],[5271,5352,"If I win,"],[5398,5608,"you owe me $32 million."],[5882,5955,"Fine,"],[6002,6216,"if you think you're really that lucky."],[6426,6543,"We just played high dice."],[6586,6649,"This time,"],[6690,6776,"let's play low."],[6836,6896,"What do you think?"],[6930,7000,"Fine."],[7130,7210,"Low it is."],[7380,7597,"Dig up everything on that woman."],[7604,7867,"She is no ordinary housewife."]],"49":[[1027,1181,"You just rolled five sixes."],[1204,1418,"There's no way you could roll five ones."],[1441,1604,"Then you underestimate me."],[2105,2320,"This is the legendary Sky Pillar."],[2328,2419,"That counts as one."],[2432,2582,"I've never actually seen that."],[2605,2719,"The Gambling King really"],[2719,2826,"does live up to his name."],[2942,3126,"A housewife like you"],[3126,3376,"had no idea what a Sky Pillar is."],[3453,3580,"Never seen anything like it."],[3650,3813,"Impressive, Gambling King."],[3877,4047,"How is she supposed to beat that?"],[4200,4264,"I'll try."],[4364,4447,"Bring me a new die."],[5168,5231,"Watch me."]],"50":[[23,146,"Just so you know,"],[203,343,"don't break the dice again."],[360,520,"If anything leaks out,"],[520,770,"the exposed points still count."],[897,1061,"Then I guess I'm doomed, aren't I?"],[1354,1434,"I have to try."],[3073,3186,"Just surrender."],[3226,3373,"You cannot beat me."],[3500,3693,"What if I told you I've already won?"],[3727,3870,"Fine, lucky girl."],[3920,3993,"Open it."],[4127,4234,"I'm gonna show you something"],[4234,4367,"you've never seen before."]],"51":[[173,380,"What the fuck?"],[410,550,"Is this even possible?"],[597,684,"Mr. Skylar,"],[717,800,"you did say that"],[800,997,"no matter how damaged the dice are,"],[1027,1207,"whatever number they show still counts."],[1284,1445,"There's not a single pip left."],[1448,1530,"So,"],[1541,1651,"I present you with"],[1701,1741,"zero."],[1885,1941,"Zero!"],[1965,2112,"Absolutely zero!"],[2325,2532,"Who the hell are you?"],[2639,2766,"Does it matter who I am?"],[2799,2923,"I won fair and square."],[3079,3229,"And that's two rounds cleared."],[3259,3370,"If I win the next one,"],[3403,3666,"you owe me $64 million."],[3823,3877,"Fine."],[3977,4074,"For the last round,"],[4110,4264,"how about we do something simple?"],[4317,4427,"What does the Gambling King"],[4427,4501,"have in mind?"],[4531,4597,"Poker!"],[4684,4754,"Shuffle."],[4948,5048,"So, what are we playing?"],[5098,5191,"Texas Hold'em?"],[5248,5315,"Blackjack?"],[5372,5522,"After he's done shuffling,"],[5538,5729,"he'll toss the cards in the air."],[5789,6052,"Whoever grabs the Ace of Spades wins."],[6166,6299,"Never heard of this game before."],[6343,6556,"That's what it takes to win all three rounds."],[6646,6770,"Well, I hope you keep your word,"],[6793,6870,"Gambling King."],[6940,7013,"If I win,"],[7050,7350,"you owe me $64 million."],[7350,7474,"I always keep my word."],[7474,7687,"My reputation is worth far more than"],[7687,7801,"64 million."],[8108,8161,"I'm ready."],[8708,8762,"Now."],[8802,8878,"Here we go!"]],"52":[[1581,1691,"You seem relaxed."],[1761,1948,"Looks like you have the Ace of Spades."],[1978,2108,"Well, you seem confident, too."],[2185,2318,"Maybe it's you who has it."],[2365,2505,"There's only one Ace of Spades"],[2505,2629,"in the entire deck."],[2706,2896,"Between you and me, only one can win."],[3079,3213,"Oh God, I'm so pumped."],[3243,3373,"If she loses now,"],[3403,3590,"everything she won is lost."],[3623,3733,"Or maybe this time,"],[3810,3917,"I'm winning it all."],[4037,4140,"You're dreaming."],[4170,4357,"Let me show you who really has"],[4357,4487,"the Ace of Spades."]],"53":[[23,210,"Let me show you who really has"],[210,330,"the Ace of Spades."],[493,620,"Ladies and gentlemen!"],[730,827,"The verdict!"],[967,1074,"Oh my God!"],[1107,1207,"The Gambling King"],[1207,1368,"really got the Ace of Spades."],[1408,1521,"So damn close."],[1551,1678,"She really lost this time."],[1775,1811,"Yeah."],[1905,2042,"One round bad, and you're done."],[2095,2242,"You almost defeated me."],[2345,2499,"But the God of Gambling"],[2499,2629,"still favors me."],[2929,3063,"Does having the Ace of Spades"],[3063,3209,"necessarily make you the winner?"],[3326,3416,"Isn't that obvious?"],[3463,3660,"Whoever gets the Ace of Spades wins."],[3690,3827,"This time you really lost, really."],[3847,3987,"But you haven't seen my card yet."],[4110,4210,"Is it necessary?"],[4257,4320,"I can win,"],[4397,4521,"even without that card."],[4577,4778,"She's lost her damn mind."],[4914,5031,"You got me curious."],[5175,5275,"Show me what you have."],[5425,5512,"Open your eyes."],[5598,5675,"Look closely."],[6176,6249,"Boss, it's her!"],[6299,6339,"What?"],[6366,6423,"It's her!"]],"54":[[33,273,"Are you Rick Spades's daughter?"],[597,720,"I'm Scarlett Spades."],[777,934,"My father was Rick Spades,"],[967,1094,"the real Gambling King."],[1197,1274,"My father"],[1307,1448,"never cheated anyone."],[1561,1825,"You tried to rig games and scam people."],[2038,2178,"And my father refused."],[2318,2443,"So, you hired Tom,"],[2515,2739,"and you murdered my entire family."],[3003,3079,"I was lucky."],[3203,3289,"I survived."],[3593,3703,"But as she was dying,"],[3767,4084,"my mother begged me never to gamble again."],[4124,4337,"Stay away from casinos..."],[4337,4491,"She was afraid that you would discover"],[4491,4612,"I was still alive."],[4794,4901,"But all these years,"],[5015,5188,"you ruined so many families."],[5211,5432,"You nearly drove my husband to suicide."],[5612,5785,"I had no choice but to come after you."],[6112,6276,"And now I have all the evidence I need,"],[6413,6553,"and I'm taking it to the police."],[6856,6966,"Stupid woman,"],[7103,7337,"you came here alone to take revenge?"],[7434,7520,"Alone?"],[7684,7851,"I killed your parents."],[7851,8011,"I also can kill you."],[8154,8304,"My gosh, he's gonna kill her!"],[8304,8461,"Shut the fuck up!"],[8571,8728,"You drop dead."]],"55":[[643,720,"Police!"],[720,777,"Freeze!"],[777,860,"Protect the boss!"],[984,1151,"Someone, help me down."],[1351,1458,"Luke Skylar,"],[1498,1588,"we have evidence"],[1588,1721,"you ordered Tom Snyder"],[1721,1985,"to murder Rick Spades and Eve Spades."],[2025,2148,"You are under arrest."],[2202,2292,"Impossible."],[2328,2549,"How'd the police get here so fast?"],[2662,2786,"Who got the proof?"],[2936,3009,"I had help."],[3246,3346,"I was never alone."]],"56":[[46,123,"I had help."],[230,383,"I need your help with something else."],[540,623,"Help with what?"],[764,877,"You'll know soon enough."],[1217,1324,"Once I beat Tom,"],[1381,1528,"and I find out the name of the person"],[1528,1661,"who is really behind all this,"],[1695,1771,"I'll tell you."],[1855,2022,"And I need you to call the police right away."],[2102,2238,"Of course, anything."],[2282,2435,"I'm- I'm always with you, babe."],[2669,2829,"My fucking hand!"],[2829,3023,"That hand is the price you paid"],[3023,3239,"for killing my parents on his behalf."],[3343,3496,"But that's still not enough."],[3600,3663,"Take him out."],[4284,4334,"What?"],[4370,4591,"The man who murdered Scarlett's parents"],[4591,4704,"is Luke Skylar?"],[4850,4981,"Calling 911."],[7190,7257,"Mom..."],[7287,7427,"Family isn't perfect,"],[7464,7624,"but it's what keeps us standing."],[7704,7867,"We fight for the people we love,"],[7907,8058,"no matter how hard it gets."],[8151,8388,"That's what makes us who we are."]]}