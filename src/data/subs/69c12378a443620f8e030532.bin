{"1":[[897,1034,"I'm Scarlett Spades,"],[1144,1361,"the only heir of Rick Spades,"],[1361,1464,"the Gambling King."],[1531,1688,"My family used to have money,"],[1725,1788,"love..."],[1841,1908,"everything."],[2002,2162,"By the time I was six,"],[2162,2362,"I already learnt every gambling trick"],[2362,2415,"in the book,"],[2445,2649,"and Dad wanted me to take over his business"],[2649,2696,"one day."],[2802,2872,"Then one night,"],[3269,3356,"I lost it all."],[5405,5465,"Yes, Sir."],[5505,5572,"He's dead."],[7173,7223,"Dad..."],[7464,7520,"Dad..."],[7607,7721,"Dad, please wake up."],[7821,7874,"Mom..."],[8104,8194,"Scarlett,"],[8405,8491,"promise me,"],[8551,8752,"don't seek revenge for us..."],[8768,8882,"Don't let anyone know"],[8908,9165,"you're the daughter of the Gambling King."],[9279,9519,"Stay away from casinos,"],[9562,9672,"live a quiet life..."],[9739,9799,"Okay?"],[9956,9993,"No..."],[10056,10166,"No, no..."],[10260,10316,"Mom..."],[10326,10520,"No, you can't leave me! Please!"],[12088,12178,"Yes, Mom."],[12335,12435,"I promise."],[14000,14087,"Scarlett..."],[14180,14401,"Your husband is about to jump off the cliff."],[14401,14564,"I think he wanna kill himself!"],[15171,15221,"Jay!"]],"2":[[66,116,"Jay!"],[180,306,"Jay, please don't do this!"],[377,487,"Stay back, Scarlett."],[553,667,"What happened?"],[684,894,"Just a card game after work..."],[937,1014,"all of a sudden,"],[1064,1217,"I owed them a million dollars."],[1281,1418,"They made me sign a contract"],[1468,1574,"with a loan shark."],[1608,1818,"Daddy, don't leave us..."],[1971,2035,"Jay..."],[2115,2305,"whatever happened, we can fix this"],[2372,2442,"together!"],[2492,2665,"You don't have to do this!"],[2712,2756,"No!"],[2806,2876,"If I die,"],[2946,3079,"the debt dies with me."],[3480,3520,"No..."],[3543,3586,"Jay!"],[4374,4544,"Don't leave us, Daddy..."],[4574,4748,"I'm so sorry, sweetheart."],[4878,5021,"Jay, this wasn't your fault."],[5031,5238,"You've never gambled before you were set up."],[5785,5869,"Listen to me,"],[5912,6126,"stay away from casinos,"],[6166,6306,"live a quiet life..."],[6406,6596,"No, you can't leave me! Please!"],[6626,6706,"Sorry, Mom."],[6753,6906,"I have to break my promise."],[6970,7023,"Jay,"],[7237,7374,"let's go find your co-workers."],[7404,7524,"I want an eye for an eye."],[8635,8868,"Casinos only destroy families,"],[8868,9115,"ruin lives and feed greed."],[10190,10230,"Honey,"],[10360,10460,"maybe we should leave."],[10560,10724,"You... never even played."],[10807,10867,"Don't worry."],[10947,11084,"The Gambling God is on our side,"],[11197,11344,"because we're the righteous ones."],[11454,11528,"It's them."],[12702,12796,"Queens full!"],[12919,13049,"No way you can beat that!"],[13797,13933,"Cheap hand signals."],[13967,14097,"Pathetic amateurs."],[14140,14184,"Damn."],[14184,14280,"It's a good hand."],[14330,14397,"If I'm right,"],[14424,14557,"he's holding Kings full."],[14614,14721,"That's a winner."],[14778,14904,"Too bad it's not as good as mine!"],[14974,15045,"Kings full!"],[15115,15228,"Bring in the chips, babe."],[15428,15468,"No."],[15542,15645,"This is not happening."],[15775,15889,"Thank you for the chips!"],[15932,16039,"Oh!"],[16039,16157,"Look who's here!"],[16242,16339,"Loser Jay!"],[16463,16509,"With..."],[16683,16743,"a woman?"],[16820,16873,"What the..."],[17364,17494,"I'm Jay's wife, Scarlett."],[17594,17797,"Do you mind if I play with you guys?"]],"3":[[20,173,"Oh, Jay, look at that!"],[190,349,"You went and you brought your beautiful wife"],[349,578,"all the way down here to watch you lose."],[579,735,"Isn't that sweet and sugary?"],[744,774,"Oh!"],[838,960,"Jay's not playing."],[1014,1064,"I am."],[1307,1358,"You?"],[1528,1667,"You ever played poker before?"],[1685,1760,"No."],[1792,2010,"But I've watched lots of people play online."],[2042,2116,"Online?"],[2219,2300,"That's cute."],[2399,2572,"Oh well, suit yourself."],[2573,2665,"Scarlett, right?"],[2709,2802,"Maybe, uh..."],[2829,2973,"we can teach her a few rules tonight."],[2974,3080,"Oh, sure!"],[3333,3419,"All right."],[3433,3672,"So, our buy-in is 10 dollars,"],[3672,3830,"and after that, you are more than welcome to"],[3830,4057,"bet however much you like, darling, okay?"],[4150,4277,"A ten-dollar base?"],[4300,4441,"Even with bad cards,"],[4441,4597,"Jay couldn't lose a million dollars"],[4598,4691,"in one night."],[4724,4858,"Something else is going on."],[5138,5198,"Hon,"],[5252,5339,"don't play them."],[5575,5782,"I know $10 sounds small, but..."],[5787,5908,"it piles up fast."],[5909,5998,"Relax, Jay."],[6009,6114,"I'm a lucky girl."],[6273,6397,"I'll win it all back."],[6473,6516,"There you go."],[6516,6599,"That's the spirit!"],[6756,6810,"Come on, Jay."],[6810,6928,"Don't spoil the fun."],[6966,7017,"Let your..."],[7097,7263,"beautiful wife play a few rounds with us."],[7323,7440,"Plus, I've never played with a woman"],[7440,7504,"before you."],[7524,7644,"Oh yeah, all right."],[7984,8117,"You two must've been bleeding"],[8117,8322,"your co-workers dry for a while."],[8348,8398,"Today,"],[8451,8625,"I'll make sure you pay it all back."],[9546,9679,"They're cheating indeed."],[9943,10016,"Game time."]],"4":[[463,507,"Hon,"],[573,717,"you don't even know poker."],[727,877,"They've been playing for years."],[934,1014,"You'll lose."],[1014,1167,"Just... let me play instead."],[1167,1244,"- Okay? - Jay."],[1244,1404,"I haven't even started playing."],[1404,1534,"You're saying I'm gonna lose?"],[1558,1718,"Are you trying to jinx my game?"],[1781,1851,"Come on, Jay."],[1921,2022,"Listen to your wife."],[2068,2155,"Besides, you ever heard of"],[2155,2232,"beginner's luck?"],[2278,2339,"Who knows?"],[2385,2529,"Maybe she's gonna make a killing tonight."],[2582,2659,"Exactly!"],[2889,2952,"Let's play."],[2999,3083,"All right!"],[3083,3193,"Ten-dollar buy-in."],[3193,3309,"Go ahead and give me your chips."],[3646,3737,"Thank you."],[5945,6112,"Jay, I've got two pairs!"],[6272,6329,"Hon,"],[6359,6533,"you can't tell people your cards like that."]],"5":[[33,213,"Jay, I have two pairs already!"],[467,573,"Two pairs already?"],[620,700,"She's gonna win."],[717,834,"And you said it out loud?"],[870,1004,"What the hell am I supposed to do?"],[1127,1177,"I'm out."],[1267,1368,"Jay..."],[1381,1538,"control your wife."],[1601,1664,"Listen,"],[1695,1898,"we normally don't say our hands out loud"],[1898,2012,"at the table. Okay, darling?"],[2125,2188,"Hon,"],[2232,2328,"you..."],[2328,2525,"can't tell people your cards like that."],[2706,2779,"It's alright, Jay."],[2802,2882,"Give her a break."],[2896,2966,"It's her first time."],[3036,3089,"Right."],[3116,3179,"Sorry."],[3266,3323,"One hundred."],[3626,3757,"Hundred bucks right away?"],[3857,4054,"Maybe she does really have two pairs."],[4150,4277,"Two weak pairs,"],[4277,4457,"and she's celebrating already."],[4604,4714,"What an idiot."],[4764,4944,"They stacked the deck to bait me in."],[5125,5271,"All right, well then, I..."],[5325,5382,"I'll check."],[5428,5508,"See what you got."],[5508,5578,"Okay."],[5705,5772,"Raise."],[5825,5982,"Let's test your luck."],[6823,7093,"My flush already crushes her pairs."],[7243,7390,"But I'll wait."],[7624,7670,"Jay,"],[7694,7811,"they both called."],[7821,7987,"Do you think they have better cards than me?"],[8024,8151,"Should I keep playing?"],[8658,8775,"You've got a strong hand."],[8858,8935,"You go in."],[8998,9065,"Okay."],[9152,9215,"All in!"],[9229,9302,"One thousand."]],"6":[[20,70,"Really?"],[90,246,"Who's going all in this early?"],[266,423,"God. But hon... you..."],[467,660,"can't go all in like that."],[804,864,"Really?"],[890,947,"I can't?"],[947,1073,"No, no... you... You can."],[1074,1141,"Your choice."],[1261,1341,"Screw this."],[1458,1521,"I fold."],[1758,1885,"So easy to trick."],[2676,2756,"It's too rich for me."],[2836,2912,"I fold."],[3189,3316,"Let her win a few rounds."],[3356,3460,"Once she's hooked,"],[3503,3646,"we'll make her cry."],[3760,3920,"His hand was stronger than mine,"],[3943,4090,"but he folded on purpose."],[4157,4447,"Next round, they'll set a trap to drain me dry."],[4447,4501,"Wow!"],[4524,4744,"Jay, I've already won $2,000!"],[4918,4961,"Well,"],[4984,5108,"it's like you're really all lucky."],[5175,5245,"But, uh..."],[5408,5515,"ten-dollar games,"],[5592,5749,"how long do you think it's gonna take you to"],[5769,6076,"pay back the $1 million that your husband lost?"],[6092,6226,"How about we raise the stakes?"],[6326,6416,"Hundred dollars a chip?"],[6473,6656,"This is exactly how they tricked Jay"],[6656,6830,"into losing a million bucks last night."],[7147,7200,"I'm in!"],[7660,7771,"Laugh while you can."],[7827,7954,"You'll be begging soon."]],"7":[[1781,1985,"He actually gave me a suited hand."],[1998,2075,"If I'm right,"],[2112,2419,"the flop will be Queen, Jack and Ten of Hearts."],[3216,3259,"Hon,"],[3390,3513,"that's a straight flush."],[3540,3636,"That's gold."],[3680,3730,"Really?"],[3730,3773,"Yeah."],[3840,3987,"I'm so lucky today."],[4341,4447,"Thanks to Jeff,"],[4477,4724,"the Ace of Hearts is already in my hand."],[4798,5051,"I'm going to crush your bones, bitch."],[5121,5215,"I'll raise."],[5345,5428,"A thousand bucks."],[5455,5522,"Call!"],[5585,5632,"Hon,"],[5652,5772,"you... you gotta call."],[5772,5889,"Okay, I raise."],[5935,6009,"Two thousand."],[6776,7010,"The straight flush just got even"],[7057,7109,"bigger."],[7130,7186,"See?"],[7186,7276,"I told you,"],[7280,7368,"I know what I'm doing."],[7368,7472,"Don't bother me."],[7570,7674,"King of Hearts."],[7774,7921,"I've got the nuts."],[7937,8054,"But I will wait."],[8114,8365,"Watch me bleed you dry, bitch."],[8375,8555,"He must've gotten the Ace of Hearts."],[8565,8685,"Most people would lose"],[8685,8822,"with the cards I have now."],[8835,8968,"But I'm not most people."],[8992,9052,"Watch me."]],"8":[[10,143,"Looks like you really are on a roll."],[196,260,"But..."],[296,463,"I kind of feel like this game is boring."],[463,527,"Mm-mm!"],[577,674,"We're betting too small."],[674,730,"Mm-mm."],[750,834,"Do you want me to go..."],[887,950,"bigger?"],[977,1034,"See now?"],[1081,1244,"That's the problem playing with women."],[1388,1564,"Just as soon as things start"],[1564,1728,"getting a little bit interesting,"],[1741,1861,"they all get scared."],[1865,1978,"I'm not scared."],[1985,2038,"Mm-mm."],[2075,2155,"You want big?"],[2175,2235,"Yeah."],[2312,2355,"Fine."],[2936,3046,"The deed of my apartment,"],[3063,3193,"worth $500,000."],[3193,3246,"So..."],[3273,3361,"is that big enough?"],[3493,3626,"No, no, no..."],[3663,3770,"This is all we have."],[3827,4074,"Jay, you're kind of being a buzzkill…"],[4431,4654,"Geez... I cannot play anymore."],[4701,4744,"I'm out."],[4764,4824,"Fold."],[5028,5305,"Well, guess I'll just leave this right here."],[5375,5502,"And if I lose,"],[5602,5692,"it's all yours."],[6006,6092,"Well, that's..."],[6166,6332,"very generous of you, Scarlett."],[6366,6416,"But..."],[6536,6633,"I wanna go bigger."],[6826,6926,"How about this?"],[7083,7163,"This"],[7190,7293,"is the loan that"],[7293,7440,"your deadbeat husband"],[7440,7640,"signed yesterday for a million dollars."],[7687,7741,"Let's say that"],[7771,7827,"if you win,"],[7904,8032,"you guys don't owe us a dime."],[8204,8371,"The fish took the bait."]],"9":[[56,180,"But then we have a problem, don't we?"],[180,246,"Oh, do we?"],[273,313,"See,"],[360,547,"this loan is worth a million dollars."],[547,610,"And you just said that"],[610,807,"your apartment is worth 500k."],[817,914,"You're short half a mil."],[960,1141,"Well, I don't have anything else left."],[1471,1521,"Well then,"],[1544,1664,"here's what I propose."],[1675,1741,"If I win,"],[1785,1885,"I get your apartment,"],[1911,1985,"plus,"],[2042,2128,"you"],[2128,2302,"get to spend a whole year"],[2302,2409,"with Jeff and I."],[2429,2696,"You do everything that we ask of you,"],[2696,2769,"and I mean"],[2826,2936,"everything."],[2979,3043,"You"],[3139,3263,"become our girl."],[3380,3570,"What the hell is wrong with you?"],[3690,3780,"My wife"],[3903,4020,"is not a prostitute."],[4097,4170,"Jay!"],[4244,4467,"Relax, baby, it's just a bet."],[4514,4601,"I mean, after all,"],[4601,4671,"if you win,"],[4671,4823,"this entire million-dollar debt"],[4823,4924,"just goes away."],[5055,5151,"After all,"],[5175,5345,"isn't that what you came here for?"],[5585,5742,"Please, please, hon."],[5782,5905,"Don't do this."],[5925,6042,"I got us into this."],[6052,6162,"I have to get us out."],[6172,6350,"I would much rather die"],[6369,6459,"than have you do this."],[6526,6573,"Please..."],[6616,6656,"Jay,"],[6783,6846,"don't worry."],[7027,7093,"I'm gonna win."],[7721,7777,"Deal."],[7827,7961,"If I lose,"],[7961,8144,"you get the apartment, and"],[8174,8395,"I'm all yours for a whole year."],[8595,8698,"That's my girl!"],[8805,8915,"You're all buying this."],[8982,9025,"Good."]],"10":[[60,163,"That's my girl!"],[163,236,"Gentlemen,"],[270,417,"hold your horses, please."],[417,537,"If you're gonna price me,"],[577,670,"you should do it right."],[710,804,"A year of my time,"],[804,1121,"that has to be worth more than $500,000,"],[1121,1187,"right?"],[1217,1451,"I think that you should add another..."],[1538,1718,"$300,000 to the table."],[2185,2275,"What do you think?"],[2572,2702,"That's three..."],[2702,2902,"an extra 300 grand apart from the loan."],[2902,3013,"I don't feel too good about it."],[3013,3103,"Should I be worried?"],[3109,3153,"No."],[3186,3256,"I'm your brother."],[3256,3326,"I got your back."],[3326,3416,"You got this."],[3440,3503,"You're gonna win."],[3596,3666,"Are you sure?"],[3666,3760,"Yes, do it."],[3967,4010,"Well,"],[4100,4230,"if you're gonna fold,"],[4257,4431,"I guess I just better start collecting."],[4431,4557,"Wait, wait, wait a second here."],[4557,4681,"Wait, wait, wait, wait, just..."],[4738,4871,"give me a second to think here."],[5315,5362,"All right, fuck it."],[5362,5434,"I'm in."],[5525,5575,"Just..."],[5658,5855,"please call Tom and tell him that.."],[5855,5979,"I need to borrow 300 grand."],[6042,6082,"Mm-mm."],[7580,7707,"That snake tattoo..."],[7737,7891,"Why does it look so familiar?"],[8511,8778,"Could he be the one who killed my parents?"]],"11":[[86,387,"Well, well, well, Max."],[387,497,"How'd you end up borrowing"],[497,647,"so much money from me, hmm?"],[737,807,"Come on, Tom."],[880,1071,"All I need is some quick cash for a..."],[1071,1157,"a short play."],[1194,1321,"You know I'm good for it, right?"],[1321,1438,"I'll turn it around in no time."],[2532,2786,"You will play first."],[3043,3129,"I'll be around."],[3620,3683,"Thanks, brother."],[3780,3840,"Appreciate it."],[3953,4034,"Of course."],[5135,5205,"All right."],[5378,5428,"I'm in."]],"12":[[20,73,"Great."],[236,393,"But don't say that I didn't warn you."],[447,567,"You're gonna regret this."],[687,797,"Regret what?"],[797,920,"I've got the nuts."],[947,1124,"Prepare to serve us, bitch."],[1157,1287,"Cheat all you want."],[1287,1458,"I can still turn this around."],[1494,1578,"Watch me."],[1791,2212,"We're gonna play with this bitch real soon."],[2552,2639,"Let us see what you got."],[4898,5005,"Holy crap!"],[5005,5145,"That's a royal flush."],[5145,5245,"A royal flush?"],[5265,5331,"That's right!"],[5375,5448,"God..."],[5492,5655,"How did you pull that off?"],[5699,5749,"Wait a second."],[5749,5809,"It's a..."],[5852,5959,"the Ace of Hearts."],[6102,6232,"You can't have the Ace of Hearts!"],[6256,6416,"Why can't I have the Ace of Hearts?"],[6416,6613,"Because I have the fucking Ace of Hearts!"],[6686,6810,"Can't be two in the same deck now,"],[6810,6876,"can there?"],[6893,7013,"Well, I think that"],[7040,7227,"you wanted to win so badly"],[7227,7340,"you couldn't see straight,"],[7340,7577,"because the Ace of Hearts is right here."],[7807,7894,"You cheated,"],[7921,8048,"but I did it better."],[8064,8141,"Impossible."],[8218,8365,"This isn't over."],[8378,8578,"How do you explain this?"]],"13":[[33,83,"Max,"],[146,250,"Max, look at your cards."],[337,527,"Max, your cards. Look at your cards!"],[670,814,"What the fuck! Where's my Ace of Hearts?"],[894,1054,"How did it turn into the Ace of Spades?"],[1054,1141,"I told you."],[1197,1378,"You wanted to win so bad,"],[1378,1458,"you could only see"],[1458,1571,"what you wanted to see."],[1571,1638,"I win."],[1721,1788,"Again."],[1828,1878,"No."],[1878,2104,"No, no, no..."],[2104,2151,"No!"],[2151,2258,"How did this happen?"],[2312,2465,"What is going on?"],[2535,2692,"The Ace of Hearts was in my hand."],[2746,2886,"The deck never left my sight."],[2932,3143,"When did she switch it with the Ace of Spades?"],[3163,3410,"Who the hell is this bitch?"],[3460,3503,"Well,"],[3616,3677,"gentlemen,"],[3703,3817,"I'll be collecting now."],[4347,4464,"Don't touch those chips!"],[4464,4591,"Your fucking wife cheated!"],[4591,4657,"Cheated?"],[4788,4848,"No, no."],[4868,5108,"I am very loyal to my husband."],[5398,5502,"Don't be a smart-ass."],[5525,5689,"I had the Ace of Hearts."],[5712,5792,"I had it!"],[5792,5885,"You cheated!"],[5905,6052,"I never touched your cards."],[6082,6152,"Don't blame me"],[6152,6312,"because you had a bad hand."],[6322,6419,"You rigged the game."],[6463,6539,"You rigged the game."],[6539,6573,"You..."],[6583,6669,"You're trying to..."],[6960,7030,"Wait a second."],[7197,7243,"You?"],[7444,7577,"Is that you, you son of a bitch?"],[7577,7681,"Are you working with her?"],[7681,7747,"Max, I..."],[7747,7874,"Max, I'd never do that to you."],[7874,7977,"You're like a brother to me."],[7977,8194,"I... I'm the one who dealt you the card!"],[8512,8571,"What?"]],"14":[[110,196,"Sorry, what do you mean?"],[230,296,"Dealt?"],[447,657,"Did you two rig the game together?"],[890,1041,"No wonder why..."],[1071,1338,"They always let you win a few rounds first,"],[1348,1561,"then drain you dry later."],[1584,1731,"It's a total setup!"],[1771,1975,"Yeah, it's exactly what they did to me"],[1975,2075,"last night."],[2148,2235,"Same here!"],[2315,2432,"These two motherfuckers"],[2432,2672,"have been running the same scam on all of us!"],[2999,3089,"Hey, hey, hey, hey, hey."],[3089,3179,"Wait, wait, wait!"],[3179,3279,"Hold on, everybody!"],[3313,3366,"Listen!"],[3466,3773,"What I meant to say is I..."],[3803,4004,"I... I never touched his cards."],[4004,4157,"His cards never even left his hands."],[4157,4290,"So, I never had the opportunity"],[4290,4427,"to switch his cards."],[4597,4647,"Exactly."],[4701,4764,"She cheated."],[4764,4888,"She... she's the one who did it!"],[4914,5021,"I swapped your card?"],[5095,5216,"But where's your proof?"],[5552,5638,"Security cameras."],[5675,5739,"Go and check them out."],[5762,5802,"Now!"],[6246,6336,"Now we'll see"],[6423,6529,"who's got proof."]],"15":[[36,200,"Hon, what are we going to do?"],[223,390,"Those cameras, they picked up everything."],[417,570,"They'll cut our hands off."],[570,617,"Jay,"],[670,757,"it's gonna be okay."],[757,814,"Don't worry."],[840,994,"How can you be so sure?"],[994,1074,"I don't even know how you"],[1074,1161,"switched those cards."],[1187,1311,"They caught everything!"],[1504,1570,"Yeah."],[2118,2172,"Look."],[2322,2399,"I love you."],[2425,2498,"It's my mistake."],[2498,2602,"I'm going down for this."],[2602,2699,"I'm gonna tell them"],[2699,2789,"it was my idea."],[2899,3013,"I told you to cheat."],[3083,3126,"Jay,"],[3279,3346,"trust me."],[3416,3460,"Okay."],[3787,3940,"You two fucks are done!"]],"16":[[10,90,"Do it right, okay?"],[90,260,"Don't skip a single frame."],[260,303,"Mm-mm."],[383,493,"You better pray"],[493,617,"that I don't find anything in here,"],[617,700,"because if I do,"],[700,857,"you ain't leaving here with your hands."],[857,934,"And if you don't?"],[1084,1231,"Well, then I drop to my knees,"],[1231,1324,"and I'll apologize."],[1324,1428,"And you can keep the fucking money."],[1428,1524,"But this is not happening."],[1561,1618,"All right."],[1681,1718,"Deal."],[1745,1795,"Are you..."],[1831,1925,"sure about this, hon?"],[2138,2188,"Wait, what?"],[2222,2262,"What?"],[2282,2379,"You got that bitch, right?"],[2462,2532,"Tell me, you got her."],[2592,2652,"Max,"],[2652,2826,"she doesn't touch the cards."],[2826,2882,"Max, her..."],[2882,3023,"her hand doesn't even go near yours!"],[3099,3153,"What do you mean?"],[3296,3453,"Max, there's nothing..."],[3476,3530,"there!"],[3573,3703,"That's impossible!"]],"17":[[96,210,"How'd you pull this off?"],[280,407,"Even the cameras didn't catch it."],[570,607,"Well,"],[637,804,"everyone here saw the game, and..."],[830,997,"you just watched the footage yourself."],[1074,1251,"Are you trying to back out of our deal?"],[1481,1614,"Of course you found nothing."],[1671,1811,"The moment I walked in,"],[1831,2048,"I mapped every camera in this place."],[2342,2402,"Well,"],[2479,2609,"if you're gonna fold,"],[2642,2772,"guess I'll start collecting."],[2816,2986,"The deed wasn't just a bet."],[3066,3176,"It was a distraction."],[3293,3503,"The second I leaned forward for the deed,"],[3593,3740,"that's when I switched your card."],[4641,4771,"This round doesn't count!"],[5008,5075,"Doesn't count...?"],[5198,5338,"Doesn't count?"],[5418,5488,"You didn't say that"],[5488,5575,"when you were winning."],[5699,5775,"Pay up!"],[5925,5972,"Yeah."],[6042,6266,"Just lose like a man, Max."],[6349,6533,"You've rigged enough games already."],[6656,6743,"Pay what you owe,"],[6793,6990,"or you'll never show your face here again!"],[6990,7167,"Shut the fuck up, alright!?"],[7283,7330,"Here."],[7374,7484,"Here I got proof now!"]],"18":[[113,160,"Here."],[203,310,"Here I got proof now!"],[330,557,"There're two Aces of Spades in this deck!"],[587,804,"Oh, funny, because that only proves"],[804,957,"you two were the ones who were cheating."],[1378,1498,"Yeah, we cheated."],[1524,1682,"We stacked the deck and we dealt it"],[1682,1801,"how we wanted to."],[1801,2122,"But I never slipped in extra cards."],[2142,2248,"No