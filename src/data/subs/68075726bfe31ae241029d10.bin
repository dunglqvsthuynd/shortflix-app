{"1":[[579,729,"Congratulations on your engagement"],[729,829,"with Robert, Emily."],[930,980,"Thank you."],[1167,1267,"I'll be right back."],[1326,1430,"Please enjoy the party."],[1839,1868,"Mom,"],[1947,1981,"Dad,"],[2077,2202,"Robert and I are celebrating"],[2202,2360,"our third anniversary today."],[2706,2877,"He doesn't mind that I can't hear."],[3174,3269,"He makes me so happy."],[3386,3520,"You would be so proud of him,"],[3603,3620,"I mean,"],[3620,3774,"for what he's done for our company,"],[3970,4116,"and just what an amazing husband"],[4116,4245,"he's been for me."],[4291,4558,"And Stacy, my sweet stepsister."],[4675,4804,"I mean, she's so good to me."],[4884,5050,"There for me when I need her."],[5146,5238,"I was thinking"],[5492,5563,"of giving Robert"],[5563,5697,"50% of the company."],[6460,6527,"Ah!"],[8683,8762,"Those voices..."],[8929,9013,"that music..."],[9159,9259,"I can hear again!"],[9492,9609,"I have to tell Robert!"],[9939,10105,"To think my pathetic stepsister"],[10105,10256,"actually believes you love her."],[10314,10464,"Sweet, deaf Emily"],[10523,10668,"always so desperate"],[10668,10760,"to be loved."],[10919,11006,"Three years married"],[11006,11177,"to that worthless deaf bitch,"],[11265,11419,"just to take over her company."],[11582,11749,"Finally, today's the last step."],[11820,11945,"Once we have all the shares,"],[11982,12208,"we'll have all the money in the world."],[12683,12733,"What was that?"]],"2":[[91,133,"Emily!"],[196,250,"Oh, oh, oh!"],[250,300,"Hey, hey!"],[337,371,"Hey!"],[442,483,"Come on."],[592,617,"Hey!"],[746,771,"Hey!"],[863,992,"Oh, Jesus, God."],[1034,1080,"You okay?"],[1092,1167,"Aw."],[1247,1317,"Look at you,"],[1405,1497,"pretending you actually"],[1497,1589,"care about her."],[1630,1718,"She may be deaf,"],[1764,1881,"but she can still see, right?"],[1914,2039,"Don't forget, Robert."],[2081,2289,"Once we get those shares signed over,"],[2331,2477,"she'll be out of our lives forever."],[2515,2581,"I can't wait."],[2969,3078,"Our anniversary party"],[3140,3219,"is starting soon."],[3315,3378,"Ready, my love?"],[3616,3678,"Come here."],[3878,4037,"My husband and my stepsister."],[4095,4229,"God, the two people"],[4229,4337,"I trusted the most."],[4437,4529,"I can't let them find out"],[4529,4608,"that I can hear."],[4675,4742,"They'll kill me."],[5180,5417,"This is the happiest day of my life."],[5747,5864,"Let's go celebrate."]],"3":[[183,300,"Can't believe it's been three years"],[300,412,"since he married that deaf girl"],[412,546,"just to take her family's company."],[575,704,"If her parents hadn't died,"],[704,804,"she wouldn't be the CEO."],[855,984,"The board really wants Robert"],[984,1051,"to take over."],[1101,1184,"They're tired of pretending"],[1184,1380,"a deaf woman can run a company."],[1463,1622,"Three years my son has been married"],[1630,1772,"to that deaf idiot!"],[1839,1935,"It's been long enough!"],[2039,2214,"You know she can read lips."],[2256,2339,"Like I care!"],[2427,2560,"Once she signs Robert"],[2560,2669,"half the company shares,"],[2669,2806,"they're getting a divorce."],[2831,3015,"My baby boy deserves better!"],[3628,3749,"After my mother passed away,"],[3749,3795,"I never thought"],[3795,3937,"I'd find a mother's love again."],[4033,4216,"But you welcomed me into your family."],[4308,4375,"Thank you, Ana,"],[4546,4633,"for being the mother I needed"],[4633,4742,"these last three years."],[5059,5100,"To you."],[5501,5534,"Oh!"],[5801,6081,"You stupid girl!"],[6101,6210,"You're not just deaf,"],[6210,6352,"you must be blind too!"],[6368,6448,"Look at this!"],[7482,7611,"What the hell is wrong with you?"]],"4":[[79,141,"Mrs. Matthews!"],[141,312,"Please, don't be so upset!"],[342,504,"We need her to sign over those shares,"],[504,550,"remember?"],[621,775,"Just play nice a little longer!"],[1422,1614,"I'm so sorry, darling."],[1785,1843,"I promise,"],[1901,1976,"that won't happen again."],[2143,2189,"You okay?"],[2548,2594,"I'm fine."],[2640,2882,"Just hurt my hands when I fell."],[3032,3236,"Your hands still work well enough to"],[3315,3424,"sign the shares over me,"],[3532,3561,"right?"],[3649,3699,"Of course."],[4229,4366,"Savor this last moment"],[4366,4441,"with Robert."],[4517,4679,"Once we get those shares signed over,"],[4679,4850,"you'll be as good as dead."],[5063,5113,"Robert,"],[5213,5301,"love of my life."],[5434,5601,"I think my parents would be pleased"],[5822,5905,"with this decision."],[6202,6327,"I'm pleased to announce"],[6352,6452,"that Stewart Corporation"],[6452,6669,"will be transferring 50% of their shares"],[6744,6815,"to Robert-"]],"5":[[33,329,"To Robertson Lake Hospital."],[771,867,"What exactly does that mean?"],[963,1109,"It's a ten-year contract"],[1163,1355,"to help expand the hospital?"],[1426,1455,"Wait,"],[1455,1576,"so no one can touch those shares"],[1576,1697,"for the next ten years?"],[1751,1822,"Yes, Robert."],[1860,1947,"It's gonna help the children"],[1947,2081,"who are far away from the hospitals."],[2081,2152,"My parents,"],[2218,2335,"I mean, they dreamed of this."],[2377,2615,"You useless deaf bitch!"],[2727,2857,"Those shares were the only thing"],[2857,3032,"that made marrying you worthwhile!"],[3319,3370,"What's wrong with you?"],[3370,3465,"Those shares were mine!"],[3478,3516,"Mine!"],[3541,3624,"Robert, stop!"],[3649,3899,"She still owns 50% of the shares!"],[4571,4642,"I'm so,"],[4696,4754,"sorry, honey."],[4850,4892,"I was..."],[5084,5138,"shocked."],[5196,5255,"Five years ago,"],[5255,5430,"my parents died in a car accident."],[5522,5593,"And help wasn't able"],[5593,5684,"to get to them in time."],[5780,6014,"I won't ever let another child"],[6014,6106,"become an orphan"],[6206,6339,"because help was too far."],[6356,6427,"But Emily,"],[6544,6681,"Robert's worked so hard."],[6735,6865,"He deserves this, doesn't he?"],[6940,7073,"Unless something's changed?"],[7403,7524,"Once we have all the shares,"],[7595,7670,"we'll get rid of her."],[8112,8145,"No."],[8337,8450,"Nothing's changed my mind."],[8600,8662,"But I do think that"],[8662,8821,"there are more important things"],[8875,8967,"than money and power,"],[8975,9034,"don't you think?"],[9184,9351,"I couldn't agree more, honey."],[9768,9897,"I was deaf and blinded"],[9897,10047,"by my love for you, Robert."],[10126,10326,"And you used that against me."],[10397,10548,"Now that I can finally hear,"],[10560,10756,"the show is just about to begin."]],"6":[[2844,3032,"Sneaking away from your deaf wife"],[3032,3157,"to fuck her stepsister"],[3157,3269,"on your anniversary?"],[3353,3511,"You're such a bad husband."],[3566,3628,"Why waste time"],[3628,3795,"with that worthless bitch,"],[3899,4033,"when I can have a real woman?"],[4333,4396,"Who's there?"],[4984,5017,"See?"],[5071,5217,"Snoring like the pig she is,"],[5326,5417,"just like I told you."],[5576,5672,"Now, where were we?"],[5793,5901,"Something's not right."],[5972,6085,"She's been acting different"],[6085,6172,"since this morning."],[6214,6423,"We need to put her to some test."],[6539,6727,"Make sure she really can't hear us."],[6936,7011,"What if she can?"],[7119,7353,"Then we kill her"],[7353,7486,"sooner than we planned."],[7665,7782,"Can't have your deaf wife"],[7782,7920,"ruining everything we worked for,"],[7920,7970,"can we?"],[8925,9029,"Now they want to test me."],[9100,9213,"I'll have to be more careful."],[9309,9405,"One wrong reaction,"],[9413,9509,"and it's all over."]],"7":[[233,291,"So,"],[492,642,"what's going on?"],[713,967,"Stacy and I wanted to give you"],[967,1230,"a special anniversary gift."],[1301,1322,"See,"],[1322,1701,"we found some old family videos"],[1739,1801,"in the attic."],[3774,3908,"I thought this was lost."],[4016,4074,"Mom."],[4291,4341,"Dad."],[4466,4667,"Time to put you to the real test."],[4721,4871,"Someone tapered with the brakes!"],[4888,4979,"They aren't working!"],[5530,5797,"Robert, you're..."],[5935,6026,"Gotcha, bitch."]],"8":[[625,713,"This is the best gift"],[713,846,"anyone has ever given me!"],[846,971,"This is so hard."],[1076,1134,"Weren't you shocked"],[1134,1267,"by what you just heard, Emily?"],[1388,1459,"Heard?"],[1551,1685,"What, what do you mean, Stacy?"],[1718,1860,"I mean, weren't you shocked by"],[1893,2056,"how different you looked back then?"],[2081,2168,"Stacy, shut up!"],[2473,2598,"Nice try, but you've just confirmed"],[2598,2740,"what I suspected."],[2811,3011,"My parents' crash wasn't an accident"],[3086,3290,"and you both know something."],[3382,3499,"I'm gonna find out the truth"],[3499,3699,"even if it's the last thing that I do."],[3699,3845,"But first..."],[3874,3912,"Oh."],[4187,4266,"I actually, uh,"],[4479,4637,"got you an anniversary gift too."],[5576,5626,"Open it."]],"9":[[41,83,"Open it."],[775,859,"I want to appoint you"],[859,942,"the next CEO"],[942,1067,"of Stewart Corporation."],[1213,1347,"I already talked to the board and"],[1430,1505,"they all agreed."],[1580,1664,"Honey, thats..."],[1785,1826,"thank you."],[2994,3140,"Your stupid deaf wife"],[3140,3290,"just signed her death warrant."],[3357,3495,"Soon we'll have everything"],[3495,3566,"we wanted."],[4337,4471,"You think you've won."],[4662,4829,"But I am three steps ahead of you."],[4913,5055,"I'm just getting started."],[5305,5355,"Brian?"],[5476,5530,"It's time."]],"10":[[191,346,"Regarding the CEO position,"],[346,450,"Ms. Stewart has decided"],[450,529,"to step down."],[546,663,"It's about time."],[700,767,"Committing half"],[767,871,"the company's dividends"],[871,1021,"to a hospital fund?"],[1059,1176,"How can we trust her judgment?"],[1188,1376,"I never trusted that deaf woman"],[1388,1514,"to be the CEO anyway."],[1518,1609,"Please, everyone."],[1626,1830,"Emily is still my dearest wife."],[1968,2160,"Now I have the legal documents signed"],[2218,2293,"by my wife."],[2364,2506,"While it's still a done deal,"],[2535,2656,"I'd like to propose a vote"],[2715,2831,"to be fair and transparent."],[2882,2936,"After all,"],[3032,3236,"I did earn this position legitimately."],[3332,3411,"Any objections?"],[3611,3720,"Then I hereby announce"],[3724,3787,"that control"],[3787,3891,"of Stewart Corporation-"],[3891,3958,"I object!"]],"11":[[41,133,"This is a private meeting."],[154,200,"Security."],[233,354,"I have every right to be here."],[379,546,"Trust me, dear brother-in-law."],[696,784,"That's Brian Stewart,"],[825,921,"Ms. Stewart's brother."],[980,1042,"He disappeared"],[1042,1151,"after his parents' accident"],[1151,1226,"five years ago."],[1263,1393,"I thought he was dead."],[1630,1735,"Those shares in your hand,"],[1735,1876,"that you're so eager to claim?"],[1926,2052,"They're not Emily's to give away."],[2068,2177,"That half of the company"],[2252,2327,"belongs to me."],[2510,2590,"Emily's brother?"],[2765,2886,"How fortunate it is"],[2886,2994,"for you to show up now."],[3194,3282,"I'm Robert Matthews."],[3282,3499,"I know exactly who you are"],[3557,3645,"and what you've done."],[4550,4604,"Robert?"],[4637,4700,"What's wrong?"],[4738,4942,"That stupid, deaf bitch!"],[4984,5125,"First, she denies me my shares"],[5125,5217,"on our anniversary,"],[5217,5326,"then her brother shows up"],[5330,5430,"to take back the company!"],[5543,5593,"You know what?"],[5693,5730,"Fine."],[5885,5964,"You want to play games?"],[6001,6114,"I'll play your stupid games."]],"12":[[225,275,"Robert,"],[304,342,"no!"],[392,479,"We can't kill her now"],[483,642,"or else we can't take the company!"],[867,909,"Fine."],[1009,1117,"But I'm not gonna let this witch"],[1121,1213,"fool me like this."],[1559,1609,"You know what?"],[1664,1760,"That brother of hers,"],[1876,1997,"he's still back at the office."],[2110,2223,"I'm gonna take care of him tonight."],[2277,2339,"You mean you'll-"],[2352,2439,"Yeah, Stacy."],[2494,2560,"I won't kill her,"],[2602,2686,"but I'll take the only family"],[2686,2777,"she's got left from her."],[3374,3461,"Just pick up the phone!"],[4120,4279,"You've reached the voicemail of-"],[4387,4421,"Damnit!"],[4571,4654,"Something's not right,"],[4654,4771,"this feels like a trap."],[4821,4954,"That's Robert's car."]],"13":[[0,208,"My husband and brother are after me."],[504,679,"I know exactly who you are"],[725,809,"and what you've done."],[1042,1205,"What exactly do you mean, Brian?"],[1322,1451,"A little birdie told me"],[1451,1593,"about your special meetings"],[1593,1735,"with your mistress Stacy"],[1751,1860,"in the executive lounge."],[1901,2043,"I won't tell Emily or the board"],[2043,2206,"about your dirty little secret."],[2227,2281,"In fact,"],[2310,2431,"I want her gone from the company"],[2452,2556,"just as much as you do."],[2640,2731,"So let's get rid of her,"],[2794,2861,"once and for all."],[2919,2994,"What are you suggesting?"],[3032,3174,"Emily's always been trusting,"],[3190,3282,"but she's not a fool."],[3324,3516,"We need to test if she's still deaf."],[3561,3628,"Tell her that you plan"],[3628,3757,"to kill me tonight."],[3824,3891,"If she's not deaf,"],[3891,4029,"she'll hear every word"],[4029,4154,"and rush to come save me."],[4270,4487,"But the brakes in her car won't work."],[4604,4642,"Boom!"],[4904,4963,"She'll be gone."],[5342,5451,"They're going to kill me!"]],"14":[[329,462,"Like her parents before her,"],[479,613,"dying in a burning car."],[642,750,"How poetic."],[817,938,"You seem pleased with yourself,"],[967,1067,"killing your own wife."],[1188,1288,"We both wanted this."],[1334,1447,"Don't act so innocent now."],[1580,1735,"No, I wouldn't look in there."],[1772,1939,"I know what burning cars do to bodies."],[1964,2072,"I've seen it before, you know."],[2106,2189,"Your parents died what,"],[2189,2256,"five years ago?"],[2406,2464,"Get over it."],[2990,3019,"What?"],[3053,3115,"Where is she?"],[3332,3420,"You set me up."],[4074,4212,"I know you're out there, Emily."],[4387,4558,"You can't hide from me forever,"],[4562,4788,"not with this lovely trail of blood"],[4788,4884,"you left behind."],[5263,5313,"Found you!"]],"15":[[100,145,"Found you!"],[487,517,"No!"],[596,742,"God damn, this is impossible!"],[1597,1630,"So,"],[1685,1805,"is sweet little Emily"],[1805,1956,"burning like mommy and daddy?"],[1968,2081,"She's not in her damn car!"],[2122,2218,"Check her room, now!"],[3999,4087,"Sorry to disturb you, ma'am."],[4145,4275,"Apparently this man stole your car."],[4308,4387,"He crashed your vehicle"],[4387,4491,"and then he tried to escape."],[4496,4625,"The hell do you think you're doing?"],[4675,4771,"I asked you to find Emily."],[4792,4934,"This police officer is telling me"],[4934,4975,"that the car"],[4975,5088,"we thought Emily was in"],[5096,5184,"was stolen."],[5230,5351,"I don't give a damn about the car."],[5351,5513,"I need to know if Emily's in her room."],[5530,5572,"Wait, sir!"],[5572,5693,"If you want to press charges,"],[5693,5776,"you have to come with us."],[5793,5872,"I don't have time for this."],[5910,5993,"You deal with it yourself."],[6906,7040,"We stalled them, but not for long."],[7102,7190,"Where is Ms. Stewart?"]],"16":[[417,462,"Robert?"],[554,646,"What are you doing here?"],[746,921,"Stacy, you're here too?"],[1021,1113,"If I didn't know you better,"],[1113,1167,"I'd say"],[1167,1242,"there's something going on"],[1242,1326,"between you two."],[1422,1476,"I, uh,"],[1543,1693,"we were just going-"],[1906,2147,"Drunk man stole the car."],[2252,2369,"We wanted to make sure"],[2369,2494,"he didn't break in,"],[2577,2615,"hurt you."],[2648,2723,"Stole the car?"],[2736,2761,"Yeah."],[2857,2923,"That's awful."],[3011,3169,"I guess some unfortunate thieves"],[3224,3319,"can't stop taking things"],[3319,3411,"that don't belong to them."],[3616,3682,"That's right."],[3803,3866,"These thieves"],[3866,4095,"are absolutely shameless."],[4270,4304,"Well,"],[4404,4458,"sweetheart,"],[4575,4658,"are things okay,"],[4821,4884,"we'll let you rest."],[5764,5834,"What's this doing here?"]],"17":[[358,442,"Oh, um,"],[533,671,"I think the cleaning ladies"],[679,754,"might have left that"],[754,842,"when they were in our bedroom."],[1155,1192,"Okay."],[2385,2535,"You goddamn idiot!"],[2556,2627,"Crashing her car"],[2635,2731,"when she wasn't even in it!"],[2815,2973,"This bitch is on to us!"],[2986,3128,"Calm the fuck down, Stacy."],[3199,3228,"Okay?"],[3278,3336,"Don't worry."],[3365,3486,"I have other ways to test her."],[3536,3620,"She won't hide from us."],[3870,4004,"We're safe for now, Brian."],[4108,4216,"They bought it thanks to you."],[4308,4333,"No!"],[4416,4517,"Check her room, now!"],[5430,5476,"Emily!"]],"18":[[79,129,"Your arm,"],[187,229,"are you?"],[266,350,"No, don't worry about it."],[371,437,"It had to happen."],[550,608,"I had to take the hit"],[608,675,"to make it believable,"],[675,725,"so that Robert"],[725,800,"doesn't suspect you."],[834,917,"You have the company shares"],[917,980,"that he wants,"],[1026,1142,"and he's going to come for you."],[1226,1326,"But you're safe for now."],[1393,1480,"That's my sister."],[1551,1639,"Smart and brave,"],[1639,1714,"just like Mom."],[1814,1951,"Keep your wound hidden though."],[1972,2081,"If they know you can hear them,"],[2231,2377,"they will try something worse."],[4212,4471,"It's warm for long sleeves."],[4496,4571,"Just a little cold."],[4579,4700,"You know how my anemia gets."],[4738,4771,"Mm."],[4963,4992,"Come here."],[5689,5818,"You wouldn't be hiding anything"],[5864,5964,"from me under these sleeves,"],[5964,6010,"would you,"],[6089,6122,"honey?"],[6256,6406,"Did I come at a bad time?"],[6481,6527,"Brian!"],[6715,6823,"Well, I can't believe you're here!"],[6823,6852,"I mean,"],[6852,6931,"after you disappeared"],[6940,7052,"for five years!"],[7536,7811,"I wanted to bring him home."],[7862,7924,"Surprise."],[8266,8333,"After all,"],[8395,8495,"Stewart family"],[8554,8658,"really should stick together,"],[8658,8708,"shouldn't they?"]],"19":[[196,367,"Look what this disgusting maid"],[367,437,"served us."],[508,709,"She should stick to scrubbing toilets."],[1534,1701,"Don't touch my sister."],[1856,1935,"I'm so sorry!"],[1935,2060,"I, I didn't know you were there."],[2444,2544,"It's all my fault."],[2840,2923,"You get cleaned up."],[2977,3061,"I'll take care of this."],[3203,3253,"My hero."],[3457,3557,"What did I do to deserve"],[3557,3666,"such a sweet husband?"],[4275,4350,"Emily, watch out!"],[5009,5150,"Great reflex, sis."],[5201,5392,"I saw it out of the corner of my eye."],[5593,5663,"Duty calls."],[5701,5805,"Thanks for breakfast, Robert."],[6047,6135,"Can't you see, Robert?"],[6135,6306,"That bitch is lying to us!"],[6318,6460,"Her and that brother of hers."],[6477,6544,"Don't worry about Brian."],[6560,6681,"He was with me during the accident."],[6735,6802,"He's an ally."],[6852,6911,"But Emily,"],[6927,7086,"I don't think my sweet deaf wife"],[7086,7182,"is really deaf anymore."],[7328,7424,"Put her to the test."]],"20":[[108,154,"I don't like you"],[154,271,"staying in that house."],[296,379,"It's not safe."],[392,517,"If Robert and Stacy find out"],[517,621,"you're not deaf anymore,"],[642,729,"they will kill you."],[754,809,"The truth about"],[809,892,"Mom and Dad's death"],[892,1021,"has to be in that safe"],[1021,1121,"in Robert's study."],[1180,1338,"I just need more time to get to it."],[1455,1547,"And Brian,"],[1739,1843,"he's planning on forcing you"],[1843,1947,"to sign over your shares."],[2473,2515,"Robert,"],[2560,2602,"Stacy,"],[2602,2669,"what's going on?"],[2840,2915,"You mentioned"],[2923,3169,"your anemia was acting up."],[3211,3357,"So we brought you some medicine."],[3490,3632,"I told Robert he needed to be"],[3632,3741,"a better husband to you"],[3741,3858,"and take care of you."],[3908,4020,"What kind of stepsister"],[4020,4070,"would I be"],[4070,4195,"if I didn't look out for you?"],[5134,5255,"Oh, Emily,"],[5296,5422,"I've added something special"],[5422,5492,"to your drink."],[5530,5672,"Something to make you sleep"],[5693,5926,"very, very well."],[6410,6498,"Something wrong, honey?"],[6610,6677,"It's just water."],[6765,6819,"It won't hurt you."],[6873,6948,"Trust me, don't you?"],[7002,7057,"Of course I do."],[7057,7161,"I know you would never do anything"],[7169,7207,"to hurt me."]],"21":[[454,525,"Wrong pipe."],[696,754,"What's happening?"],[788,855,"She's supposed to be"],[855,955,"passed out by now!"],[984,1101,"How is this even possible!"],[1776,1947,"Sweet dreams, Emily."],[2047,2198,"Is the drug ready, Stacy?"],[2314,2489,"You can't wait to kill your lovely wife,"],[2489,2615,"can you, Mr. Matthews?"],[3887,3945,"You must have gotten"],[3945,4037,"the wrong glass."],[4091,4216,"Jesus Christ, Stacy!"],[4262,4396,"At least we know she can't hear,"],[4400,4500,"otherwise she would never drink"],[4500,4575,"that whole glass."],[4975,5088,"Are you coming to bed, Robert?"],[5488,5543,"Nice try."],[5638,5705,"Your plan failed"],[5705,5805,"before it even started."],[7811,7928,"The truth about my parents' death"],[7928,8058,"must be in his study."],[8687,8829,"Finally caught you, bitch."],[8863,8983,"Let's see what you're after."]],"22":[[613,688,"Where's she going?"],[1522,1559,"Mom,"],[1755,1801,"Dad,"],[1939,2135,"the psychic said on the darkest night"],[2135,2198,"that these words"],[2198,2281,"would bring you back."],[2640,2790,"Spiritus"],[2869,2982,"Veritas"],[3111,3194,"Revelio!"],[4437,4512,"It's impossible!"],[4971,5046,"That's impossible!"],[5046,5125,"You're supposed,"],[5205,5288,"you're supposed to be dead!"],[5426,5505,"Supposed to be dead!"],[6894,7036,"Sis, the actors are ready"],[7036,7144,"in Mom and Dad's bedroom."],[8829,8908,"Your fear of ghosts"],[8908,9075,"always made you weak, Robert."],[9146,9192,"Now let's see"],[9200,9305,"where your guilty conscience"],[9305,9355,"leads you."]],"23":[[133,179,"Okay."],[233,275,"They're dead."],[321,396,"I made sure of it."],[446,483,"They're dead."],[525,563,"They're dead."],[563,629,"They're fucking dead."],[629,713,"I made sure of it."],[1188,1259,"Death certificate."],[