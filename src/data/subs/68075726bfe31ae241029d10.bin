ound a document"],[3778,3874,"in Robert's safe."],[3903,4020,"It was co-signed by him"],[4020,4154,"and someone called The Chancellor."],[4233,4275,"He was there"],[4275,4362,"the night our parents died."],[4487,4604,"My private investigator says"],[4604,4763,"that this person might be family,"],[4779,4884,"or someone close"],[4934,5042,"like family."]],"33":[[508,658,"That deaf bitch and her brother"],[658,754,"have been plotting against me"],[754,829,"the whole time!"],[1034,1071,"What are,"],[1117,1213,"what are we going to do?"],[1434,1555,"We turn everyone against them."],[1697,1839,"Starting with that precious brother."],[1931,1981,"But how?"],[2068,2168,"Remember the documents"],[2168,2227,"in the safe?"],[2310,2419,"The emergency funds?"],[2460,2527,"We make it look like"],[2531,2677,"Brian transferred them overseas."],[2744,2786,"The company's"],[2786,2848,"gonna be bankrupt"],[2848,2898,"by morning."],[2911,2994,"But his signature?"],[3048,3165,"It's already taken care of."],[3236,3361,"And once the shareholders see"],[3370,3532,"what Brian did with their money,"],[3720,3903,"they'll want both him and Emily gone."],[4738,4808,"Ms. Stewart,"],[4829,4896,"your brother stole"],[4904,5034,"the company's emergency funds."],[5113,5155,"What?"],[5305,5388,"That's impossible."],[5413,5647,"The transfer papers have his signature."],[5689,5755,"He took everything."],[5789,5935,"All the money has gone overseas."],[5951,6122,"The company is finished."],[6327,6381,"Robert,"],[6464,6585,"he's behind this."]],"34":[[308,408,"Your brother transferred"],[417,596,"all the emergency funds overseas."],[663,742,"If you don't remove him"],[742,825,"from this company,"],[838,942,"everything is ruined."],[967,1084,"No, Brian would never do that."],[1096,1205,"You saw his signature"],[1205,1267,"on the paper."],[1334,1409,"If you don't do this,"],[1430,1547,"everything your parents built"],[1568,1655,"will be destroyed."],[2102,2185,"I'm sorry, Emily."],[2289,2344,"He's right."],[