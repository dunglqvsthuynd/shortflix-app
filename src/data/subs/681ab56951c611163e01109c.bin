{"1":[[980,1026,"Excuse me."],[1026,1084,"What are you doing?"],[1146,1305,"I'm opening my apartment door."],[1405,1480,"What's it look like?"],[1505,1714,"No, that is my apartment."],[1805,1926,"I just got the keys."],[2139,2160,"Yeah."],[2160,2327,"I think you're mixed up, princess."],[2406,2540,"Maybe you are in 105."],[2610,2690,"Nice try."],[2690,2848,"I think I know what my apartment is."],[2869,3015,"I think you're in 105."],[3019,3073,"So just..."],[3324,3486,"Yeah, I don't think so."],[3561,3624,"Bye bye now."],[3624,3787,"And, good luck with whatever"],[3787,3915,"it is you've got going on."],[3934,3974,"Wait!"],[5080,5188,"Case in point."],[5209,5259,"What? No, no."],[5259,5380,"What the hell are you doing?"],[5430,5568,"Let go of the door, as**ole?"],[5584,5676,"I am not an as**ole."],[5676,5793,"This is my door."],[5793,5955,"It's my apartment- No, it is not."],[5989,6035,"Stop!"],[6035,6143,"Quiet out there!"],[6143,6289,"I'm trying to watch the game!"]],"2":[[454,571,"Can you tell him/her this is my"],[571,654,"apartment?"],[763,859,"I checked."],[875,1038,"It seems my husband made a mistake in"],[1038,1217,"double-leased this apartment,"],[1217,1292,"to both of you."],[1326,1463,"Okay, well, is there another unit"],[1463,1572,"you could give her?"],[1572,1672,"Because I'm not leaving."],[1672,1776,"Well, I am not leaving."],[1810,1876,"Unfortunately,"],[1876,2043,"this is our last available unit."],[2114,2231,"Well, I sincerely hope"],[2231,2385,"that you can figure something else out."],[2439,2552,"I will pay double deposit"],[2552,2665,"if you let me have this place."],[2665,2752,"Excuse me?"],[2752,2848,"Ma'am-"],[2848,2919,"I'm serious."],[2919,3007,"You have no idea how badly"],[3007,3086,"I need this."],[3311,3392,"Here."],[3440,3528,"Take my credit card."],[4446,4533,"What?!"],[4558,4587,"How?!"]],"3":[[0,104,"How?"],[241,367,"Well, well, well."],[471,575,"Can I have the apartment now?"],[575,884,"No, no, I paid the deposit"],[888,975,"and got approved."],[975,1071,"Same as you."],[1084,1263,"Unfortunately, Mr. Rhodes did"],[1263,1372,"apply first."],[1372,1539,"Oh, please, call me Andy."],[1872,1985,"Andy!"],[1985,2218,"How could you be this cruel?"],[2302,2535,"First you leave me at the altar,"],[2535,2619,"and now you're trying"],[2619,2852,"to steal our apartment?"],[2873,3061,"I really thought that you loved me."],[3086,3153,"Are...are you two-"],[3153,3282,"No no no no no."],[3282,3357,"I don't know this woman."],[3357,3486,"I've never met her before"],[3486,3578,"in my life."],[3753,3891,"We celebrated our five year"],[3891,4062,"anniversary in April,"],[4062,4216,"and our first date was on the pier."],[4308,4471,"You won me an octopus, Andy!"],[4471,4646,"An octo-what? I..."],[4679,4850,"Seriously, I don't know this woman."],[4850,4992,"Ma'am, if he says he doesn't know you,"],[4992,5259,"I have to abide by policy and I..."],[5313,5355,"It's just..."],[5676,5747,"I'm pregnant."],[5855,6126,"You can't abandon me on the streets"],[6156,6264,"with a baby on the way."]],"4":[[4,137,"with a baby on the way."],[162,233,"No no no no no."],[233,387,"You can't believe a word she is saying."],[387,483,"She is crazy."],[492,600,"Mr. Rhodes,"],[600,775,"if you can't reconcile with your"],[775,892,"poor fiancée."],[938,1088,"I'm going to have to call security."],[1372,1526,"Since you both paid a deposit,"],[1526,1659,"the first two months rent is covered."],[2039,2085,"Okay."],[2085,2189,"Who are you?"],[2189,2298,"You don't recognize the girl"],[2298,2427,"you left at the altar?"],[2565,2652,"Really hurts."],[2652,2706,"Andy."],[3078,3211,"Okay, look, I had to do something."],[3211,3349,"Today was my wedding day,"],[3349,3449,"and I just really couldn't"],[3449,3599,"go through with it, so I ran."],[3599,3697,"I kinda gathered that-"],[3733,3816,"My credit cards were frozen."],[3816,3887,"Oh, my bank"],[3887,3999,"account is probably drained too."],[3999,4141,"Look, it was really an emergency."],[4141,4216,"Okay."],[4216,4279,"What"],[4279,4329,"is"],[4329,4425,"your"],[4425,4491,"name."],[4529,4608,"Corinne."],[4629,4825,"Corinne Carl- um..."],[4825,4988,"Um... Ca...Carter."],[5030,5201,"Okay, Corinne."],[5221,5246,"You know,"],[5246,5526,"you seem really nice and sane and all,"],[5526,5622,"but emergency or not."],[5622,5722,"You just manipulated"],[5722,5905,"your way into my apartment."],[5955,6106,"Your apartment?"],[6135,6277,"Well, you did hear her, right?"],[6277,6381,"I did pay half of the rent"],[6381,6539,"for the next two months."],[6544,6656,"Oh, well,"],[6656,6694,"how are you going to"],[6694,6777,"pay that when it's up?"],[6873,6961,"You're broke."],[7061,7236,"I will figure it out, okay?"],[7236,7386,"Just relax."],[7774,7882,"No don't"],[7928,8016,"don’t do this, Andy."],[8020,8112,"This is...this is a bad idea."],[8128,8208,"You don't even know her."],[8208,8299,"Why would you feel bad for her?"],[8299,8412,"Makes no sense."],[9868,10014,"I think you lost something there."],[10014,10155,"Magic Mike."]],"5":[[12,125,"I think you lost something there,"],[154,229,"Magic Mike."],[287,417,"On the contrary,"],[471,600,"I'm making myself at home."],[725,842,"This is my apartment."],[896,1051,"So I can wear or not"],[1051,1205,"wear whatever I want."],[1305,1368,"Are you sure you can handle"],[1368,1468,"this arrangement?"],[1564,1797,"You've never lived with a guy before."],[1918,2039,"You might want to back down."],[2139,2218,"I don't want to make you"],[2218,2314,"uncomfortable."],[3445,3541,"Rest assured,"],[3628,3732,"despite this"],[3795,3928,"tempting face"],[4066,4216,"and this nice body,"],[4350,4471,"I'll be just fine."],[4667,4804,"The real question"],[4884,5030,"is whether you will be."],[5305,5376,"What um..."],[5513,5705,"What's...what's this book?"],[5805,5834,"Well,"],[5834,5939,"you would know if it wasn't"],[5939,6047,"upside down."],[6798,6881,"I'm claiming this one."],[6881,6940,"What?"],[6940,7057,"Dibs on the master."],[7057,7186,"No, I wanted that room."],[7265,7344,"Come on."],[7344,7482,"It gets the good light and everything."],[7561,7653,"Should've moved faster then!"]],"6":[[471,608,"Hey, Corinne."],[608,750,"I heard what happened."],[750,859,"So sorry."],[859,992,"Nah, It's okay. Monica."],[992,1180,"I mean, it's probably for the best."],[1180,1326,"It was my choice after all."],[1326,1497,"That's good to hear."],[1534,1697,"So I sent your severance package"],[1697,1876,"to your personal email since"],[1876,2060,"your work email was deactivated."],[2060,2160,"Let's take a look and sign it"],[2160,2214,"when you can."],[2214,2293,"My-"],[2293,2360,"What?"],[2360,2531,"Your severance package."],[2531,2631,"Did your dad not-"],[2631,2769,"He's firing me??"],[2819,2994,"Oh my God."],[2994,3165,"Corinne, I'm so sorry."],[3207,3290,"I would love to help you,"],[3290,3461,"but your dad threatened me."],[3461,3616,"Yeah, well, it sounds like him."],[3616,3712,"No, it's..."],[3712,3803,"It's okay. Monica."],[3803,3895,"I..."],[3933,4029,"I got an apartment."],[4029,4166,"At least I have somewhere to live."],[4166,4279,"Well. That's good."],[4279,4425,"How's the new place?"],[4425,4529,"It's..."],[4637,4717,"fine."],[4771,4813,"Ugh."],[4813,4950,"My roommate."],[4950,5067,"He is kind of an asshole,"],[5088,5196,"but it's fine."],[5196,5251,"He?"],[5267,5426,"You're living with a guy?"],[5426,5572,"Yeah, it's a really long story."],[5572,5689,"Remind me to tell you about it"],[5689,5768,"at some point."],[5801,5951,"Is he hot at least?"],[6147,6206,"Ok, what."],[6206,6348,"Yeah, and it makes it kind of worse."],[6402,6481,"Well, you let me know"],[6481,6594,"if he tries anything."],[6594,6648,"I'll come over there"],[6648,6773,"and teach him a lesson."],[6798,6873,"I've got to go."],[6927,7086,"I'm really sorry, Cori."],[7086,7223,"I'll catch you later."],[7223,7323,"Bye."],[7682,7811,"And just when I thought"],[7811,7916,"it couldn't get any worse."],[8058,8141,"Great."]],"7":[[325,417,"Corinne, hurry up."],[417,525,"I need to pee."],[1434,1505,"Sorry, what did you say?"],[1505,1626,"It's loud in here."],[1785,1826,"Get out!"],[1826,1918,"I need to pee."],[2122,2173,"Get the..."],[2173,2281,"Just take your time."],[2281,2314,"It's not like"],[2314,2502,"the rest of us have bladders or anything."],[2502,2552,"Look,"],[2552,2677,"I have got a job interview"],[2677,2869,"and I've got to look my best, okay?"],[3011,3111,"Okay."],[3486,3549,"Hello?"],[3632,3749,"What are you still doing in here?"],[3770,3924,"I am not done with my hair."],[4024,4108,"You can go ahead."],[4108,4208,"I'm not going to look."],[4208,4283,"Are you insane?"],[4283,4396,"I can't use the bathroom"],[4396,4475,"while you're in it."],[4504,4579,"Wow."],[4579,4675,"I really didn't"],[4675,4842,"take you for a prude, Andy."],[4934,5046,"I guess you just have to wait"],[5046,5121,"a little bit longer."],[5121,5201,"I am serious."],[5201,5301,"I'm going to be late for work."],[5526,5672,"Okay, fine."],[5709,5805,"Catch you later."],[5989,6106,"Okay.Get it together."],[6106,6185,"She's just your roommate."]],"8":[[483,633,"Well, Corinne,"],[633,821,"your experience at the Carleton Group"],[821,1055,"speaks for itself."],[1080,1217,"And with a sharp wit like that,"],[1217,1376,"you will fit right in here"],[1376,1459,"at Turn Tide."],[1580,1672,"When can you start?"],[1705,1839,"I can actually start right now."],[1868,1972,"Excellent."],[2014,2135,"The boss will"],[2164,2243,"love you."],[2264,2394,"He has been looking for a decent"],[2394,2556,"person to fill this empty position"],[2556,2790,"on his team for months."],[2790,2894,"I can introduce you."],[2969,3057,"Wait, that would be perfect."],[3098,3165,"Let's go."],[3224,3265,"Great."],[3516,3603,"Come on in."],[3908,3966,"Meli..."],[4079,4162,"Corinne?"],[4216,4275,"Yes."],[4308,4416,"The promising candidate"],[4416,4537,"I was telling you about."],[4600,4750,"I just interviewed her."],[4750,4959,"I think she'll be a perfect fit."],[5005,5109,"I'll leave you guys to it."],[5472,5618,"So this is the interview that"],[5618,5780,"you spent an hour preparing for?"],[5951,6072,"Well, too bad you won't be getting"],[6072,6118,"the job."]],"9":[[41,116,"Well, too bad"],[116,254,"you won't be getting the job."],[329,446,"Wait, that's not fair."],[479,554,"I had no idea that"],[554,704,"this was your ad agency. Okay?"],[704,884,"And you cannot punish me"],[884,1042,"for an innocent mistake."],[1042,1297,"Well, actually, as it is my ad agency."],[1297,1426,"I can do whatever I want."],[1459,1488,"Okay, well,"],[1488,1572,"then how do you expect me"],[1572,1751,"to pay your precious little rent"],[1751,1864,"if I don't have a job?"],[1864,1939,"It's easy."],[1989,2156,"Go find a job somewhere else."],[2273,2339,"Leave."],[2473,2523,"Ugh."],[3386,3486,"Oh my God."],[3653,3707,"I am so sorry."],[3707,3862,"I was not looking where I was going."],[4083,4170,"Oh,"],[4220,4337,"are you reading Abacus?"],[4375,4446,"I love this book."],[4446,4567,"I read it in high school."],[4567,4679,"Oh, really? I've never met anyone"],[4679,4813,"who's actually read it."],[4850,5084,"Oh, Ms. Rosenberg."],[5109,5192,"I didn't know you were coming"],[5192,5267,"in today."],[5267,5384,"Please, step into my office"],[5384,5551,"so we can discuss the rebranding."],[5551,5676,"No worries at all. I was"],[5676,5709,"early."],[5709,5876,"I just met your very"],[5876,6056,"impressive associate."],[6081,6164,"I feel good about"],[6164,6373,"Turn Tide Media already."],[6410,6510,"You know, it's so nice to see"],[6510,6681,"such bright minds here."],[6681,6823,"Well, actually- Um...yes."],[6898,6936,"Thank you."],[6936,7027,"This is Corinne."],[7027,7136,"She is the newest addition to"],[7136,7219,"our marketing team."],[7244,7332,"It's her first day."],[7444,7490,"It is?"]],"10":[[8,79,"It is?"],[108,158,"Yep."],[221,296,"It is."],[296,362,"It is."],[412,475,"You go wait"],[475,529,"in the break room,"],[529,671,"I'll give you a tour in a second."],[717,863,"You better treat her nicely, Rhodes."],[863,1042,"I will steal her for my company"],[1042,1159,"in a heartbeat."],[3261,3349,"Hi."],[3349,3591,"I'm Corinne. I'm new to the team."],[3591,3770,"We saw."],[3770,3991,"You really put on a show out there."],[4095,4241,"Do you need anything, Corinne?"],[4241,4429,"Oh, wait, are you the coffee girl?"],[4429,4508,"You know, I would really,"],[4508,4671,"really love a matcha latte."],[4671,4859,"We only have coffee, I'm afraid."],[4917,5009,"I'll make you some."],[5009,5096,"Bummer."],[5096,5184,"Thank you."],[5580,5805,"So, what were your names again?"],[6393,6527,"Lilia."],[6527,6719,"Welcome to Turn Time Media."],[7761,7836,"Mr. Rhodes would like to"],[7836,7916,"see you in his office."]],"11":[[188,242,"Come in."],[947,1126,"What the hell happened to you?"],[1126,1156,"I..."],[1322,1418,"It was the coffee machine."],[1418,1523,"Super finicky."],[1618,1798,"Do you mind if I go home and change?"],[1840,1986,"You're living out of a duffel bag."],[1986,2094,"Do you even have anything to"],[2094,2177,"change into?"],[2282,2353,"Okay."],[2628,2682,"Here,"],[2782,2870,"take my card."],[2936,3066,"Go get yourself some new clothes."],[3128,3262,"We have a client meeting later tonight."],[3262,3374,"You can't go looking like that."],[3508,3708,"No, I couldn't take it- No, take it."],[3708,3846,"I see it as an investment"],[3846,4025,"in company talent."],[4025,4113,"Take it, Corinne."],[4371,4467,"All right then."],[4576,4692,"So I'll see you back at the apartment,"],[4692,4797,"and we can go from there?"],[4847,4926,"See you."],[5114,5197,"Have fun."],[5243,5301,"I will."],[5376,5451,"Bye."],[8037,8267,"What the f*ck is wrong with you?"]],"12":[[8,308,"What the f*ck is wrong with you?"],[529,600,"Huh?"],[750,871,"Who spent"],[884,1092,"$10,000 in one afternoon"],[1151,1359,"using somebody else's money?"],[1393,1551,"F*ck, brain freeze."],[1643,1693,"I'm sorry."],[1693,1876,"Did you just say $10,000?"],[1876,1939,"Yes!"],[1939,2014,"My bank called me"],[2014,2102,"they thought my credit card"],[2102,2177,"was stolen."],[2189,2231,"Oh my god."],[2231,2293,"What the hell, Corinne?"],[2293,2348,"I'm so sorry."],[2348,2444,"I didn't even look at the tags."],[2444,2585,"I just picked out things that I liked."],[2623,2669,"This."],[2669,2765,"This is how you shop"],[2790,2944,"at high end luxury stores"],[2944,3057,"without looking at the price?"],[3148,3240,"I mean, before you ran away,"],[3240,3303,"what were you?"],[3403,3532,"Look, I will return everything."],[3532,3653,"I have the receipt, okay?"],[3653,3695,"It's..."],[3695,3816,"It's somewhere."],[3903,4045,"I promise that this will all be"],[4045,4154,"resolved by tomorrow."],[4333,4500,"Corinne, just..."],[4571,4692,"I’m not happy about how this happened."],[4692,4738,"But,"],[4863,4967,"don't go to the trouble."],[4988,5088,"It's whatever."],[5088,5138,"Now come on,"],[5138,5255,"we have to go meet with that client."],[5255,5367,"So,"],[5367,5476,"chop, chop."],[5476,5647,"Whatever? You're not mad?"],[5647,5714,"I mean, I was"],[5714,5743,"when I thought"],[5743,5847,"you were taking advantage of me,"],[5847,6047,"but it turns out you were just completely"],[6047,6160,"financially irresponsible."],[6277,6318,"Hey!"],[6318,6423,"Am I wrong?"],[6519,6727,"Look, I can return everything, okay?"],[6727,6844,"No just forget it."],[6844,6956,"It's not a big deal."],[7378,7549,"$10,000 down the drain."],[7549,7657,"And it's just"],[7741,7853,"whatever."],[8062,8153,"Is he like..."]],"13":[[417,525,"Apologies for the delay,"],[525,725,"Mr. Kepner. Rush hour traffic."],[725,867,"No matter, boy."],[1109,1276,"Now, who do we have here?"],[1276,1422,"Oh, Corinne Carter."],[1422,1555,"I am the new marketing associate"],[1555,1689,"with Turn Tide Media."],[1689,1764,"Brought her along"],[1764,1922,"as part of the onboarding process."],[1922,2072,"She'll be shadowing this meeting."],[2173,2364,"If I had known you hire"],[2364,2565,"such magnificent specimens"],[2565,2752,"at your agency, Rhodes,"],[2781,2994,"I'd have given you the deal right there."],[3499,3724,"Well, of course we would be honored"],[3724,3899,"if you would choose us, but, um,"],[3928,4024,"Yeah, I would hope it's for less"],[4024,4191,"superficial reasons, but..."],[4258,4429,"I'm assuming you're joking."],[4496,4629,"How about I get us some drinks?"],[5092,5263,"I tell you what, Miss..."],[5317,5401,"Karen?"],[5484,5568,"Carla?"],[5689,5885,"Have a nightcap with me later,"],[5960,6122,"and the deal is yours."],[6206,6306,"Excuse me?"],[6331,6577,"Oh, it's a really good deal, honey."],[6577,6723,"It's just one night."],[6748,6936,"You do want to make your boss proud,"],[6944,7019,"don't you?"],[7232,7332,"Look! I don't know who the"],[7332,7457,"f*ck you think you are."],[7482,7574,"And you're probably too"],[7574,7691,"drunk to even realize."],[7691,7907,"But I am not that kind of girl, okay?"],[7907,8087,"I don't play nice with men like you."],[8087,8166,"So why don't you just"],[8166,8358,"keep your dirty hands off of me?"],[8546,8783,"You let an employee talk to a client"],[8783,8867,"like that."],[8904,9096,"You want our business or not?"],[9409,9496,"Well?"]],"14":[[316,379,"You mean, am I going to"],[379,454,"let a client talk"],[454,596,"to an employee like that?"],[642,754,"And the answer is NO!"],[804,917,"You punched me."],[917,1021,"You punched me!!"],[1105,1234,"You know who I am, boy?"],[1309,1372,"I do now."],[1472,1530,"Let's go."],[3582,3728,"Aww."],[3862,3945,"Oh! Sh*t!"],[4671,4750,"How"],[4750,4942,"to dust..."],[5593,5622,"Okay."],[5622,5793,"I don't have whatever that is."],[6281,6368,"Em!"],[7144,7261,"Sh*t!"],[7570,7649,"Okay!"],[7699,7841,"What are you doing in my..."],[8137,8204,"Oh my God."],[8283,8375,"What did you do?"],[8458,8529,"It was an accident."],[8529,8608,"I barely touched it."],[8608,8646,"It just."],[8646,8717,"It just fell."],[8717,8771,"You ruined"],[8771,8896,"the only thing I have left"],[8896,9025,"of my first dog!"],[9025,9142,"On accident?!"],[9200,9317,"Oh my God."],[9317,9430,"I am so"],[9430,9530,"sorry."],[9530,9655,"I'm going to sweep it up-"],[9655,9951,"No, no! Get out! Get out!"],[9951,9993,"Get out!"]],"15":[[16,87,"Get out!"],[221,321,"But you can't kick me out!"],[321,458,"This is my apartment too!"],[458,621,"I'll make sure you get the deposit back."],[621,700,"Leave!"],[942,967,"Wait."],[967,1055,"I don't have my phone,"],[1055,1201,"or wallet or anything."],[1201,1459,"Andy, look, I can't go anywhere!"],[1547,1643,"Andy!"],[2377,2544,"I'm sorry, little guy."],[2798,2907,"No more roommates."],[4220,4408,"Was she trying to..."],[4408,4550,"clean my room?"],[6035,6072,"Corinne!"]],"16":[[1180,1368,"Okay, I guess this will do."],[2648,2686,"Oh."],[2686,2836,"I wonder what happened to her"],[2865,3094,"sleeping in the office in pajamas."],[3094,3224,"That's a first."],[3224,3282,"Do you think she got"],[3282,3424,"kicked out of her apartment by"],[3424,3536,"her boyfriend?"],[3737,3916,"Is it morning already?"],[3953,4108,"Nice pajamas."],[4175,4308,"Just"],[4346,4487,"leave me alone."],[4884,5009,"Corinne."],[5009,5138,"Can I see you in my office, please."]],"17":[[817,921,"Go home and change."],[1172,1334,"I thought you evicted me."],[1405,1476,"Half of the office has"],[1476,1597,"already seen you like this."],[1630,1735,"Don't you want to change?"],[4842,5050,"This is not a good idea."],[5050,5230,"It's just not very..."],[5230,5380,"Have you guys seen Corinne yet?"],[5484,5643,"You mean, since this morning?"],[5693,5805,"No."],[5897,6076,"How unprofessional."],[6577,6685,"Corinne!"],[6919,6961,"Corinne?"]],"18":[[58,279,"Corinne? Corinne?"],[279,400,"Hey. Are you okay?"],[2143,2277,"Corinne."],[2510,2635,"My god. You're burning up."],[2635,2769,"I’m fine."],[2773,2923,"No, you have a fever."],[3044,3094,"Stay here."],[3094,3190,"I'll get some medicine."],[4012,4212,"Hey, come on, take this."],[4366,4471,"Come on."],[4471,4575,"Okay."],[5184,5288,"I'll let you sleep."],[5467,5568,"I'm sorry."],[5568,5659,"Just"],[5718,5843,"let me stay."],[8475,8546,"Why am I naked?"]],"19":[[504,558,"Um."],[629,684,"So, um."],[684,771,"So, um."],[892,971,"Relax."],[1042,1222,"I am familiar with the human body."],[1276,1384,"I even have one of my own."],[1438,1530,"But you want me to,"],[1530,1659,"take this off so that we're even."],[1814,1918,"Yeah? No. I've seen."],[1918,2022,"I've seen enough of you."],[2022,2114,"Thank you very much."],[2202,2327,"Let's just pretend that this"],[2385,2565,"never happened, all right?"],[2656,2719,"Okay."],[2756,2840,"Are you feeling better?"],[2894,2986,"I think so."],[3107,3182,"I'm starving."],[3299,3428,"There's muffins on the counter."],[4033,4145,"You got muffins?"],[4279,4408,"They were a gift from a client."],[4500,4592,"Don't eat them all."],[4717,4792,"Uh-huh."],[5351,5505,"Who the hell are you?"],[5555,5651,"Who the hell are you?"],[5726,5905,"What are you doing in Andy's apartment?"],[5905,6085,"Are you the maid or something?"],[6147,6218,"Excuse you."],[6218,6318,"I live here,"],[6318,6389,"and you haven't explained"],[6389,6481,"who you are yet."],[6577,6777,"I'm Betty, Andy’s fiancée."]],"20":[[54,271,"I'm Betty, Andy’s fiancée."],[271,487,"Not my fiancée."],[487,575,"Betty, just because our parents"],[575,779,"shook hands on it before we were born"],[779,909,"doesn't make it real."],[925,1151,"Now, please stop stalking me."],[1192,1326,"Well, I wouldn't have to stalk you"],[1326,1476,"if you hadn't ghosted me."],[1534,1672,"This apartment's even dingier"],[1672,1797,"than the last one."],[1843,1981,"You ghosted her?"],[1993,2177,"Oh, that is so bad."],[2398,2435,"You know,"],[2435,2498,"would you prefer that"],[2498,2619,"I file a restraining order?"],[2644,2827,"Ooh, that is really bad, too."],[2865,3011,"Girl, I would just cut in now."],[3065,3278,"Oh, you'd love that, wouldn't you?"],[3278,3390,"Oh, what? Do you think you're his"],[3390,3553,"girlfriend or something?"],[3820,3866,"Well, actually."],[3866,3933,"Yes."],[3962,4012,"What?"],[4033,4129,"Yes."],[4129,4412,"And we are very happy."],[4621,4733,"well, I guess this apartment came"],[4733,4879,"with more than one downgrade."],[4879,4950,"Excuse you!"],[5009,5100,"Come on! Andy."],[5159,5267,"Stop playing hard to get."],[5267,5430,"You know we belong together."],[5488,5559,"No."],[5593,5739,"Now leave before I call the police."],[5793,5905,"Seriously? No, no, no."],[6364,6439,"I knew it was weird"],[6439,6485,"for the owner"],[6485,6660,"of an advertising agency to"],[6660,6777,"be in this apartment."],[6819,6919,"How many girls are gonna come"],[6919,7119,"knocking on our door? Andy?"]],"21":[[0,54,"How many girls are going to"],[54,229,"be knocking on our door? Andy?"],[254,333,"Shut up!"],[367,467,"And it's none of your business!"],[538,613,"My big shot"],[613,771,"roommate is a playboy"],[771,938,"with a trail of broken hearts."],[1046,1105,"How lucky am I"],[1105,1247,"for the free entertainment."],[1693,1830,"Just so good to have you here today."],[1830,1943,"I'm so excited for you."],[1943,2035,"Mrs. Rhoades."],[2106,2173,"It's, um"],[2173,2377,"pleasure to have you here at Turn Tide."],[2523,2615,"Who's your guest?"],[2644,2919,"Oh, Andrew, this is Mr. Carlton!"],[2944,3057,"Of the Carlton Group?"],[3057,3182,"The one and only."],[3395,3449,"Mr. Carlton,"],[3449,3499,"would you mind"],[3499,3657,"if I had a word with Mrs. Rhoades?"],[3716,3841,"Melissa here will show you upstairs."],[3874,3941,"Okay."],[4512,4600,"What?"],[4600,4717,"Did I do something wrong?"],[4717,4863,"Why are you here?"],[4863,4946,"Again?"],[4946,5046,"To bring you"],[5046,5259,"another outstanding opportunity."],[5321,5405,"Andy!"],[5405,5668,"Mr. Carlton can improve your"],[5668,5743,"standing immensely."],[5743,5839,"Come on now."],[5839,6076,"Mom, I have told you a million times,"],[6076,6247,"I want to make a name for myself."],[6306,6539,"Stop meddling in my business."],[6539,6664,"No. You know what?"],[6664,6865,"You are going to hear him out."],[6865,6948,"Let's not keep him waiting."],[6948,6990,"Come on now."],[7157,7257,"Oh!"]],"22":[[975,1092,"What are you looking for?"],[1163,1267,"I can't seem to find the file"],[1267,1401,"in the Braxton project."],[1580,1614,"You know,"],[1614,1801,"I think Andy took that into his office."],[1826,1897,"Oh."],[2289,2531,"Somebody is about to get in trouble."],[3111,3190,"Okay."],[3190,3365,"Where is this file?"],[4141,4208,"Dad?"],[4262,4316,"Um, four."],[4316,4383,"As of now."],[4383,4554,"But, we're looking to expand"],[4554,4642,"in the next quarter."],[4683,4763,"Please."],[4959,5196,"So, what brings you here today?"],[5196,5321,"The Carlton group."],[5321,5530,"We are very interested in"],[5530,5622,"acquiring."]],"23":[[183,279,"Excuse me?"],[333,471,"Sorry. I, um..."],[575,671,"stubbed my toe."],[709,784,"Please continue."],[784,913,"But, like I was saying,"],[950,1251,"I'm interested in aquiring TTM."],[1459,1626,"I'm, I'm flattered,"],[1626,1718,"Mr. Carlton."],[1764,1876,"But we're not looking to be bought"],[1876,1985,"any time soon."],[2022,2106,"I'm very proud of"],[2106,2177,"how far we've come"],[2177,2302,"as an independent start-up,"],[2302,2406,"and I have plans"],[2406,2510,"to grow it further on my own."],[2510,2677,"I think it's a brilliant idea."],[2723,2877,"I mean, joining with the Carlton"],[2877,3015,"Group would give Turn Tide"],[3015,3215,"the much needed stability"],[3215,3395,"in this very competitive industry."],[3516,3720,"Our identity as a young"],[3720,3824,"contemporary brand"],[3824,4012,"distinguishes us in the marketplace."],[4012,4216,"I'm not so sure that Turn Tide"],[4216,4291,"would mesh well"],[4291,4462,"with the Carlton Group's long"],[4462,4587,"standing traditions."],[4587,4608,"Well,"],[4608,4775,"you would have to create a new identity,"],[4775,4884,"of course."],[4884,5100,"I mean, you're an ad agency."],[5100,5209,"That's your job, right?"],[5209,5334,"Your younger generation"],[5334,5459,"just doesn't"],[5459,5634,"appreciate the value"],[5634,5876,"of an established brand."],[5893,6010,"And do you really want to go"],[6010,6160,"into competition with us?"],[6160,6252,"Mr. Rhodes,"],[6252,6368,"I think"],[6368,6564,"this is an opportunity of a lifetime."],[6723,6890,"Thank you for the offer, Mr. Carlton,"],[6890,7069,"but I have to kindly refuse."],[7132,7265,"Oh, Ed, you know how this"],[7265,7382,"generation is."],[7419,7578,"Always changing their mind"],[7578,7720,"and so stubborn."],[7757,7862,"But, you know,"],[7862,8099,"they always do come around."],[8270,8404,"You have daughters, don't you?"],[8441,8521,"What is it?"],[8521,8717,"Chloe and... Corinne, isn’ t it?"],[8846,9100,"I only have one daughter, Chloe."]],"24":[[0,266,"I only have one daughter, Chloe."],[266,567,"Now you have a big pitch coming up"],[579,804,"with the Goldfield Beer Group"],[804,880,"next week."],[992,1205,"We're also bidding on that deal."],[1205,1434,"You want to make a bet to see who wins?"],[1434,1593,"How do you know about that?"],[1593,1668,"That was supposed to be a"],[1668,1735,"private pitch."],[1751,1864,"I'm a Carlton,"],[1864,2118,"and I have eyes everywhere."],[2118,2310,"If you win the Carlton deal,"],[2310,2610,"I will hand you three of my hand-picked"],[2627,2877,"most valuable clients."],[2957,3103,"But if I win,"],[3140,3274,"you sell me your company."],[3636,3770,"All right."],[3953,4058,"You have a deal."],[4058,4149,"Ah, alrihgt!"],[4325,4404,"I look forward to acquiring"],[4404,4483,"your company."],[5751,5897,"Oh, my bad."],[5897,6072,"So sorry for the interruption."],[6481,6573,"Well, I will see you later."],[6573,6652,"No, no, no."],[6652,6748,"What were you doing"],[6748,6936,"under my desk and in my office?"],[6936,7065,"I was just looking for a file,"],[7065,7228,"and I thought it would be in here."],[7257,7424,"And then I heard you coming and"],[7540,7745,"it just felt like the best idea."],[7745,7778,"Are you sure"],[7778,7866,"it doesn't have anything to do"],[7866,8003,"with Ed Carlton?"]],"25":[[16,116,"Well,"],[196,250,"look, I may"],[250,367,"or may not have hit him with my bike"],[367,442,"three years ago,"],[442,521,"and I thought he was going"],[521,600,"to recognize me."],[600,650,"Okay, well."],[650,775,"That's actually really funny,"],[775,946,"but I'm not really in a laughing mood."],[984,1126,"You heard everything that just happened."],[1146,1288,"You're making the right choice."],[1368,1493,"I know it's risky, but"],[1564,1605,"this could be"],[1605,1801,"your only shot to save Turn Tide."],[2056,2152,"If you need any help,"],[2152,2227,"let me know."],[2748,2877,"So, you deserve it."],[2902,3057,"I do, yeah."],[3336,3440,"Walk of shame."],[4433,4500,"Hey."],[4500,4633,"Congrats, man."],[4683,4746,"On what?"],[4829,5013,"She's a ten, for sure."],[5013,5155,"I don't blame you one bit"],[5155,5330,"for taking a bite of new hire."],[5434,5534,"If you think I hired Corinne"],[5534,5734,"for anything other than her skill set."],[5734,5826,"Maybe you should go find somewhere"],[5826,5922,"else to work."],[5922,5976,"All right."],[6072,6177,"Damn, man."],[6214,6327,"Forget I said anything."]],"26":[[12,175,"Yeah, we can definitely do that."],[262,321,"Oh, not a problem."],[321,392,"We should be able to have two"],[392,462,"by tomorrow."],[517,633,"I think it's..."],[721,846,"Let me, call you back."],[896,1017,"Bob."],[1017,1121,"Vince."],[1121,1305,"So what do I owe the pleasure?"],[1338,1434,"Your mother would like you"],[1434,1626,"at a fitting for your wedding suit."],[1634,1822,"We're here to escort you."],[1839,1964,"Well, that's not going to happen."],[2014,2185,"I have a really busy schedule today."],[2214,2364,"And also, I'm not getting married."],[2385,2577,"Well, your mother is very insistent,"],[2577,2777,"Mr. Rhodes, very."],[2857,2998,"Did my dad send them?"],[2998,3174,"Well, I'm just."],[3328,3490,"Guys- Hey! Let him go!"],[3490,3524,"Corinne."],[3524,3561,"Can we just..."],[3561,3716,"Oh, Jesus Christ."]],"27":[[145,283,"You didn't mean to do that."],[283,442,"I have been seeing these creeps around."],[442,483,"Okay?"],[483,596,"To be safe, get pepper spray."],[596,696,"Yeah, I'll look into that."],[784,855,"Oh, I think you've got some"],[855,925,"on my shirt."],[955,1055,"Oh, it's fine. I'll do laundry."],[1234,1305,"Now?"],[1305,1422,"I can do laundry."],[1564,1639,"I think."],[3486,3574,"Okay."],[5447,5534,"Oh, it burns,"],[5534,5643,"it burns, it burns."],[5860,5985,"Oh, do not laugh at me."],[5985,6072,"No!"],[6297,6427,"Oh!"],[7415,7524,"The other nail."],[7624,7745,"Oh!"],[7920,8016,"This one."],[8016,8108,"Thank you."],[8174,8262,"Uh huh."],[8466,8612,"Come on."],[9330,9547,"No no no."],[9663,9759,"Spoon."],[9759,9905,"Microwave. No."],[10005,10097,"No."],[10306,10381,"Here."],[10965,11002,"Okay."],[11002,11040,"Whatever"],[11040,11161,"My parents are paying the maids."],[11161,11277,"They need to double it."],[11690,11820,"Wax or oil?"],[12587,12754,"Oh, close enough."]],"28":[[554,613,"Hey,"],[738,900,"did you cook?"],[900,984,"Yeah."],[1017,1226,"And I used the recipe."],[1238,1397,"Oh, and the best part is."],[1789,1918,"I clean the floors."],[1951,2114,"You what?"],[2185,2369,"Oh, I just wanted to say thank you"],[2369,2473,"for all of your help and,"],[2473,2590,"you know, getting me a job"],[2640,2740,"and it’s Saturday."],[2798,2961,"So I clean the floors."],[3057,3165,"Thank you."],[3165,3265,"Looks great in here. And,"],[3365,3474,"smells great, too."],[3528,3611,"Yeah, get over here"],[3611,3753,"before it gets cold."],[4237,4341,"What the hell did you clean"],[4341,4433,"the floors with?"],[4433,4554,"Um, soap."],[4637,4792,"Oh, and then I polish them with oil."],[5059,5163,"Olive oil?"],[5234,5301,"I'm assuming"],[5301,5451,"that's not the right kind of oil."],[5451,5672,"No, not the right kind of oil."],[5701,5989,"We are going to walk very, very slowly"],[5989,6089,"to the towel closet."],[6147,6252,"Yeah."],[6398,6468,"Oh."],[6573,6660,"Okay. I’m going."],[6660,6769,"Yeah. Come up there."],[6785,6873,"Keep sliding."],[6911,6948,"Okay."],[6948,7040,"We'll move your foot."],[7040,7152,"Olive oli?"],[7173,7215,"Olive oli really?"],[7215,7286,"I thought that was a good idea."],[7286,7378,"Oh, wait the brussel sprouts! Wait-"]],"29":[[133,312,"Oh my God!"],[312,421,"Are you okay?"],[963,1101,"At least this smells good."],[1101,1192,"Smells so good."],[1192,1330,"It smells so good."],[1347,1463,"Smells really great."],[1722,1868,"I should- Brussel sprouts."],[1889,2018,"I'll go get the... the towels."],[2018,2118,"Yeah, yeah."],[2118,2152,"Yeah."],[2152,2218,"Yeah, you do that."],[2293,2369,"Okay."],[2831,2982,"Ok, new house rule."],[3028,3174,"No more chores without supervision."],[3232,3357,"Hey, dinner was edible,"],[4020,4166,"You need a hand over there?"],[4233,4308,"No."],[4909,5030,"I am all-powerful."],[5105,5196,"Yeah, the bruise on my ass"],[5196,5405,"would say otherwise, but..."],[5455,5522,"Sure."],[5609,5755,"I am really, really sorry about that."],[5755,6026,"There's... there's a lot I need to learn."],[6143,6210,"Yeah,"],[6310,6439,"there's a lot that you do know."],[6439,6523,"Yeah."],[6523,6660,"Like how to escape a wedding."],[6669,6802,"Oh, I saw those heels."],[6802,6994,"That could not have been easy."]],"30":[[0,246,"If you could be any animal,"],[246,371,"which one would you be?"],[371,508,"I'd be like a spider monkey."],[508,550,"Oh."],[596,734,"Okay, so which ones go?"],[734,850,"You need to jump, I don't know."],[850,892,"X, come on."],[900,938,"The x?"],[1117,1176,"Oh."],[1376,1526,"You know, my mom taught my sister"],[1526,1776,"and I how to have perfect posture"],[1776,1993,"and impeccable taste."],[1993,2056,"Enjoy."],[2198,2260,"But,"],[2431,2610,"she didn't teach us anything useful,"],[2665,2773,"like how to cook"],[2773,3073,"or clean or live independently."],[3094,3194,"I mean, I never really liked"],[3194,3294,"those lessons anyway."],[3315,3436,"I was always just questioning"],[3436,3545,"everything."],[3582,3787,"My sister was really good at it, though."],[3787,3928,"And then at some point, they just"],[3928,3995,"stopped trying."],[4129,4254,"So you have a sister?"],[4254,4312,"Yeah."],[4408,4508,"Older,"],[4508,4633,"Chloe."],[4833,5217,"She is the definition of golden child."],[5292,5409,"Brilliant, beautiful,"],[5409,5588,"and most importantly,"],[5588,5663,"obedient."],[5743,5772,"Yeah."],[5772,5855,"In my parents eyes,"],[5855,6085,"I was always the disappointing,"],[6085,6302,"troublemaking younger sister"],[6302,6564,"who was only really good for one thing."],[6660,6777,"Marriage."],[7002,7107,"And hopefully to a guy"],[7107,7273,"who would just shut me up for good."],[7298,7390,"I see."],[7515,7661,"An arranged marriage."],[7728,7782,"Yeah,"],[7782,7953,"you don't really seem that surprised."],[8037,8078,"Yeah."],[8078,8149,"It, um..."],[8187,8333,"It happened to a friend of mine."],[8541,8608,"Yeah."],[8775,8896,"I only met him, like, once"],[8896,9000,"before the wedding."],[9200,9250,"Well, you know what?"],[9250,9376,"I'm glad you ran away."],[9513,9580,"F*ck'em."],[9980,10043,"Yeah."],[10043,10105,"Yeah."],[10243,10272,"Okay, well,"],[10272,10431,"I haven't really brought much peace"],[10431,10539,"into your life."],[10623,10739,"I'm not good at everything like"],[10739,10839,"my sister, okay?"],[10919,11065,"I don't pick up on things easily."],[11094,11223,"You're smart, Corinne."],[11244,11336,"Scary smart,"],[11357,11411,"sometimes."],[11615,11699,"And I think that you"],[11699,11857,"just need to show them"],[11857,12003,"that you can live just as good of a life."],[12003,12162,"You know what? Hell better"],[12258,12370,"on your own terms."],[12504,12600,"Then you're not alone."],[12971,13075,"Why are you looking at me like that?"],[13200,13271,"No, I'm sorry."],[13271,13334,"I just."],[13521,13684,"I just really wanna kiss you right now."]],"31":[[1076,1251,"No no no."],[1434,1534,"Why?"],[1743,1830,"That better be something in your"],[1830,1885,"pocket."],[1981,2106,"What are you imagining?"],[2106,2181,"Oh, God."],[2736,2811,"We should."],[2844,2961,"Yeah, help."],[2961,3094,"Do anything else? Okay."],[3148,3236,"Okay. Yeah."],[3236,3286,"Okay."],[3286,3399,"Okay. Yep."],[3495,3603,"Was I snoring?"],[3636,3707,"You know I’m gonna get some water."],[3707,3770,"I’m gonna get some water."],[3770,3870,"Okay."],[4033,4158,"This apartment is depressing,"],[4158,4220,"you know that?"],[4475,4592,"The only thing you own is action"],[4592,4746,"figures and video games."],[4746,4934,"That is the definition of delinquency."],[5184,5267,"Excuse me?"],[5267,5380,"Look, we've lived in this apartment"],[5380,5501,"long enough, okay?"],[5501,5668,"Where's the decor?"],[5668,5834,"The books."],[5901,5980,"The books?"],[6035,6118,"I don't read books."],[6118,6214,"It's the 21st century."],[6214,6314,"Who owns books?"],[6314,6564,"Every sensible adult in the world."],[6589,6710,"Oh, well, I,"],[6710,6856,"didn't take you for a nerd, Cori."],[6961,7111,"Okay, This is unacceptable."],[7111,7273,"You need to read, Andy."],[7286,7361,"How can you be the founder"],[7361,7661,"of a media company if you don't read."],[7711,7811,"I listen to podcasts?"],[7845,7924,"Gross."],[8070,8191,"I gotta go run some errands."],[8199,8283,"I'll be home later."],[8316,8370,"Okay?"],[8370,8562,"You can just do whatever you want."],[8562,8708,"Unless you're asking me for a permission."],[8708,8800,"In that case."],[8800,8900,"No."],[9488,9684,"Did you forget your keys again?"],[10347,10402,"Dad?"]],"32":[[204,275,"Dad?"],[450,575,"So this is where you're spending"],[575,704,"your little vacation?"],[704,784,"No, um..."],[950,1130,"This is my home."],[1130,1242,"Home?"],[1242,1322,"Very funny."],[1322,1543,"This is merely a month long tantrum"],[1543,1722,"befitting of a brat"],[1810,1918,"who is ungrateful"],[1918,2031,"as you."],[2131,2202,"I like it."],[2202,2314,"When are you coming back?"],[2344,2544,"James does not like that stunt"],[2544,2610,"you pulled."],[2644,2786,"And you embarrassed us all."],[2823,3048,"And you almost cost us our connection"],[3048,3169,"with the Prescotts."],[3169,3240,"Luckily,"],[3240,3303,"James"],[3303,3566,"and his parents are willing to forgive."],[3611,3762,"How did you find me?"],[3762,3858,"Oh, please."],[3858,4045,"I hired a private investigator"],[4045,4179,"when you ran."],[4200,4350,"I've known about this place for weeks."],[4391,4542,"You cut me off completely"],[4542,4596,"just so you could"],[4596,4763,"secretly watch me suffer?"],[4783,4838,"No!"],[4909,5121,"This is my life now, okay?"],[5121,5226,"I have worked for it."],[5226,5392,"Just leave me alone!"],[5392,5580,"Cutting you off was your punishment."],[5580,5701,"It was to teach you a lesson."],[5701,5922,"But apparently, I guess it didn't."],[5922,6131,"You are a Carlton."],[6131,6214,"Act like it!"],[6214,6498,"Your sister is nearly ready to take over"],[6498,6702,"as the CEO of our company."],[6702,6785,"While,"],[6785,7107,"you are wasting our name."],[7136,7257,"The least that you could do"],[7257,7578,"is accept your place as a dutiful wife!"],[7599,7753,"I am not some complacent"],[7753,7932,"little prize for your business partners!"],[8087,8179,"You know what?"],[8237,8395,"My boyfriend is coming home soon"],[8395,8550,"and he really doesn't like it"],[8550,8666,"when I'm upset."],[8666,8779,"Boyfriend?"],[8817,8925,"What boyfriend?"]],"33":[[0,125,"What boyfriend?"],[125,283,"His name is Andy."],[283,379,"And if you don't know about it,"],[379,433,"maybe you should get"],[433,583,"a new private investigator."],[713,875,"Now get out!"],[896,1080,"You're gonna regret this little girl."],[3073,3169,"Andy?"],[3207,3365,"What are you doing here?"],[3528,3720,"I pass by this place every day."],[3720,3874,"You know, I just thought I'd"],[3874,3933,"stop in"],[3933,4204,"and see what all the hubbub is about."],[4245,4491,"Oh, did my comment get to you?"],[4491,4608,"That is so sweet."],[4608,4900,"No, no, I'm not buying anything."],[4900,4984,"Oh."],[5184,5384,"Oh, I am!"],[5384,5459,"Hold this."],[5805,5947,"Classic!"],[6097,6151,"Little women?"],[6177,6227,"Uh huh."],[6247,6352,"Are they like"],[6373,6443,"tinkerbell?"],[6443,6473,"Oh."],[6544,6644,"They are full sized!"],[6644,6723,"Okay."],[6723,6881,"You two are building quite the library"],[6881,6923,"there."]],"34":[[0,58,"You two are building"],[58,166,"quite the library there."],[166,300,"Oh, we are just getting started."],[300,379,"No kidding."],[425,479,"Well,"],[479,608,"we just got a very special"],[608,679,"shipment in."],[721,788,"A rare"],[788,980,"first edition of the Complete Poems"],[980,1192,"of Emily Dickinson by Thomas H. Johnson,"],[1255,1388,"which is widely regarded as"],[1388,1484,"the authoritative collection"],[1484,1559,"of her work."],[1576,1751,"And only for $200."],[1801,1968,"It's an opportunity you can't miss"],[1968,2089,"if you're a true collector."],[2231,2289,"Ma'am."],[2398,2615,"Johnson's Complete Emily Dickinson."],[2615,2665,"It may be her"],[2665,2811,"first full collection of her work,"],[2811,3036,"but it is far from authoritative."],[3036,3165,"I mean Miller's has been regarded"],[3165,3282,"as the leading version aomg"],[3282,3511,"scholars for, well, years."],[3511,3586,"And if I wanted to get"],[3586,3712,"a first edition Johnson,"],[3712,3853,"I could easily get it for $80."],[3853,3941,"So before you sell me"],[3941,4095,"an outdated and overpriced book."],[4095,4204,"Maybe you should just think about"],[4204,4333,"whether or not I'm an idiot."],[4562,4650,"Well, then."],[4979,5301,"So, you can't do chores."],[5301,5492,"But you're a literature expert."],[5492,5538,"Oh,"],[5726,5872,"this one is my favorite."],[5964,6006,"I've..."],[6006,6147,"I've never heard of it."],[6147,6352,"Oh! It is so juicy."],[6377,6514,"High society affairs."],[6527,6639,"Unrequited love."],[6677,6765,"Plot twists."],[6931,7044,"Oh, it is such a fun time."],[7194,7294,"We have so many."],[7440,7545,"Maybe next time."]],"35":[[880,1021,"Could you help me send a postcard?"],[1117,1217,"Um...I’m sorry."],[1230,1305,"Who's this?"],[1330,1547,"This... he..."],[1572,1743,"is- James Prescott,"],[1743,1835,"Corinne's fiancé."],[1864,2056,"And... you are?"],[2102,2202,"Andy Rhodes."],[2302,2439,"You have a fiancé?"],[2469,2548,"Okay."],[2610,2736,"You are not my fiancé, James."],[2736,2886,"And just quit telling people that."],[2886,3061,"Just because you left me at the altar"],[3061,3144,"doesn't mean"],[3144,3294,"we won't get married eventually."],[3340,3549,"Oh, you're that guy!"],[3566,3599,"Man."],[3636,3670,"You know,"],[3670,3862,"you really can't take no for an answer."],[3999,4087,"Stay out of this."],[4129,4337,"This is between me and her."],[4375,4500,"She can make her own decisions."],[4567,4625,"In fact, you know,"],[4625,4704,"why don't we ask her?"],[4704,4913,"Corinne, did you change your mind?"],[4984,5150,"No I didn't."],[5313,5484,"Well, there you have it."],[5538,5651,"No means no."],[5651,5730,"And she's here with me,"],[5730,5897,"so you can go on about your day."]],"36":[[0,120,"And she's here with me so,"],[120,246,"you can go on about your day."],[246,287,"Okay."],[287,371,"Look, man, I don’t know who you"],[371,383,"Look, man, I don’t know who you"],[383,433,"think you are."],[433,500,"Ok, guys."],[500,617,"We're in public."],[638,792,"James, I don't even know you. Okay?"],[792,930,"This was all of our parents idea."],[930,1005,"And I'm sure there is"],[1005,1201,"a lovely girl out there for you,"],[1201,1297,"who is not me."],[1401,1497,"There you go."],[1618,1701,"Bye bye now."],[1747,1851,"Look, I don't know who this punk"],[1851,1931,"thinks he is,"],[1976,2072,"but this isn't over."],[2135,2268,"I wonder what your father"],[2268,2352,"has to say about this."],[2352,2389,"has to say about this."],[2398,2435,"Corinne."],[2869,3036,"His hair is really shiny."],[3336,3503,"Did you get oat in my coffee?"],[3887,3974,"I'll get us some."],[4337,4408,"Oh!"],[4408,4592,"Oh my goodness."],[4662,4796,"I missed you so much."],[4796,4875,"Ditto."],[4875,5050,"Carlton just isn't the same without you."],[5196,5367,"So this is a new place, huh?"],[5367,5422,"Yeah!"],[5422,5543,"Turn Tide Media."],[5543,5668,"Oh, my God, let me give you a tour."],[5668,5705,"Yes!"],[5997,6051,"Woah."],[6523,6639,"Who's the storm cloud?"],[6639,6669,"Yeah."],[6669,6765,"Remember when I said I had a"],[6773,6840,"roommate?"],[6869,7144,"And now he's also my boss."],[7265,7361,"But he's not normally like that."],[7361,7469,"I wonder what happened."],[7524,7645,"I think I might know."],[7782,7924,"Someone published an exposé on"],[7924,8012,"Turn Tide Media."],[8045,8179,"It's all over the news."]],"37":[[141,225,"Oh, no."],[279,362,"That's really bad."],[362,500,"Yeah, I'd better go."],[500,596,"But dinner soon."],[596,725,"Okay? Yes, please."],[813,880,"Good luck."],[1017,1105,"Thanks."],[1505,1697,"Well, that's a good start to the morning."],[1697,1760,"I'm literally"],[1760,1901,"sick to my stomach right now."],[2289,2373,"What's going on?"],[2535,2631,"Didn't you hear?"],[2660,2773,"We're the new poster child"],[2773,2919,"for unethical advertising."],[2919,3053,"Apparently, there was a recall"],[3053,3165,"on the first product deal"],[3165,3307,"Andy ever did as CEO."],[3307,3432,"Oh, shit."],[3432,3549,"And the worst part."],[3549,3678,"The Carlton Group boosted the"],[3678,3820,"article immediately and said,"],[3924,4024,"this is what happens when"],[4024,4108,"you let a bunch of money"],[4108,4329,"hungry Gen Zers run an ad agency."],[4329,4441,"They got to be behind it."],[4458,4533,"Didn't Ed Carlton"],[4533,4642,"just visit the office a week ago?"],[4683,4733,"Yeah."],[4825,4946,"Can I see y’all in the conference room?"],[5088,5142,"Now."],[5171,5226,"Okay."],[5255,5326,"Okay."],[5709,5814,"As some of you may know,"],[5814,5901,"malicious headlines"],[5901,6106,"have been circling around Turn Tide."],[6318,6452,"And most of the report is false,"],[6452,6681,"but we do have some evidence"],[6681,6827,"of an internal data leak."],[6831,6923,"We have a mole?!"]],"38":[[0,75,"We have a mole?!"],[183,287,"It's too soon to say,"],[337,471,"But I will get to the bottom of this."],[471,754,"Well, if you ask me, everything was fine"],[754,1030,"until a certain someone was hired."],[1096,1301,"I guess the tabloids aren't the only one"],[1301,1372,"throwing around"],[1372,1526,"baseless accusations."],[1526,1643,"I'm just putting together"],[1643,1735,"two and two."],[1735,1818,"We didn't have a leak"],[1818,1947,"before you were hired."],[1947,2022,"Enough."],[2056,2143,"I didn't call this meeting"],[2143,2260,"so that people could point fingers"],[2260,2318,"at one another."],[2318,2473,"The Goldfield patch is coming up,"],[2473,2644,"and it is our top priority"],[2644,2740,"to secure this deal."],[2740,2848,"If we can win them over, who knows?"],[2848,2977,"Maybe we can regain the trust"],[2977,3086,"of some of our other clients."],[3194,3382,"This pitche is life or death for Turn Tied."],[3436,3553,"So I'm going to be presenting it."],[4049,4295,"So, mind you, he's fully naked"],[4295,4425,"when he drags me into the shower"],[4425,4600,"to show me his waterbending skills."],[4675,4758,"But it was just water"],[4758,4913,"dripping down his fingers."],[5042,5159,"Yeah, I was five."],[5167,5451,"You know, I recall having to call 911"],[5451,5751,"to, um, rescue you from a tree"],[5764,5901,"after your failed experiment"],[5901,6172,"with flying using helium balloons."],[6172,6464,"I was levitating off the ground"],[6464,6535,"for a little bit."],[6535,6756,"You know, that, that's considered flying."],[6756,6827,"He was."]],"39":[[608,684,"Shall we?"],[684,754,"Yeah."],[754,809,"Wait? Luke?"],[809,938,"Where the hell are you guys going?"],[1051,1192,"You enjoy your night, bro."],[1689,1876,"What the hell is happening?"],[1972,2002,"Okay."],[2002,2093,"You really have to learn"],[2093,2214,"how to read a room."],[2214,2318,"Their eyes have been glued"],[2318,2431,"to each other all night."],[2752,2911,"Well, good for them."],[3182,3286,"You're cute."],[3370,3595,"Come on water-bender,"],[3595,3707,"let's go home."],[4358,4487,"Well, I, for one,"],[4487,4587,"think Andy and Corinne would"],[4587,4692,"be great together."],[4808,5021,"And not just because Andy introduced me"],[5021,5163,"to his best friend."],[5338,5409,"Kismet."],[5730,5759,"Yeah."],[5759,5885,"I'm really rooting for him, too."],[5885,6014,"Just glad Corinne is doing well."],[6043,6097,"She's been through"],[6097,6297,"so much in such a short time."],[6523,6685,"Andy didn't tell you?"]],"40":[[95,196,"Andy didn't tell you?"],[196,396,"She got disowned by her rich family."],[404,542,"They're apparently a big deal."],[621,809,"They wanted her to marry some big shot,"],[809,946,"but she didn't love him."],[988,1109,"She's never been on her own before,"],[1109,1276,"so she had to learn from scratch."],[1372,1472,"Oh, wow."],[1605,1764,"No, I had no idea."],[2218,2414,"It's pretty funny, then how she met Andy,"],[2552,2756,"Like, it's ironic that she ran away"],[2756,2865,"from one rich guy"],[2865,3057,"straight into the arms of another."],[3111,3345,"Her family would be thrilled"],[3345,3499,"if they ever took their heads"],[3499,3595,"out of their asses."],[3674,3891,"Wait. Andy is rich?"],[4033,4162,"Yeah."],[4333,4529,"Haven't you heard of the Rhodes family?"],[4704,4808,"Oh my God."],[4808,4925,"Rhodes Hotels."],[4925,5067,"I never even put it together."],[5067,5209,"Yeah, he went out on his own"],[5209,5288,"a couple of years ago."],[5288,5484,"He wanted to make a name for himself,"],[5484,5563,"pave his own way."],[5563,5672,"Aside from his family."],[5672,5801,"And, um..."],[5926,6106,"You and Corinne don't know"],[6106,6218,"anything about Andy?"],[6218,6318,"And you and Andy don't know"],[6318,6377,"about Corinne."],[6577,6715,"Holy shit!"]],"41":[[383,521,"Hey, girl."],[542,642,"Okay! Tell me everything!"],[1155,1330,"Basking in the afterglow?"],[1438,1576,"I don't kiss and tell."],[1593,1726,"It was amazing. 10/10."],[1730,1843,"But before I give you details,"],[1860,2006,"there's something way more urgent"],[2006,2102,"I have to tell you."],[2102,2248,"You are never going to guess what"],[2248,2327,"I heard last night."],[2381,2540,"But, um, you got a sec?"],[2619,2723,"Yeah, sure."],[2723,2865,"I could...I could take a break."],[2902,2927,"Okay."],[2927,3007,"What?"],[3007,3107,"What is more important"],[3107,3228,"than your sex life?"],[3274,3336,"I heard one of"],[3336,3403,"the craziest things"],[3403,3503,"for Monica last night."],[3524,3636,"Did you know"],[3661,3753,"Corinne comes from"],[3753,3832,"one of the wealthiest"],[3832,3941,"families in the country?"],[3978,4074,"What did you say?!"],[4124,4179,"Corinne."],[4229,4437,"Andy comes from a rich family!"],[4458,4571,"Rhodes Hotels!"],[4592,4629,"What?"],[4629,4650,"Yeah!"],[4717,4871,"Dude. Corinne is"],[4904,5176,"or was, I guess, a Carlton."],[5286,5418,"Why would she hide that? Why wouldn't he say?"],[7032,7186,"You're a Carlton."]],"42":[[62,175,"You're a Carlton."],[208,275,"Yes."],[321,483,"I'm the Carltons' youngest daughter."],[508,625,"Not that they would acknowledge it."],[625,721,"You're a Carlton."],[721,813,"The same corporation"],[813,942,"that's been trying to buy me out"],[942,1105,"and badmouthing me in the press."],[1105,1238,"Are you the fucking mole?"],[1238,1338,"Is that why you showed up in this"],[1338,1443,"apartment in the first place?"],[1564,1639,"Do you really think that"],[1639,1739,"I would do that to you?"],[1739,1910,"After everything we've been through?"],[1910,1976,"You know me,"],[1976,2077,"Andy, you know that"],[2127,2318,"I have no loyalty to my family."],[2344,2494,"I don't know what to believe."],[2506,2606,"Why didn't you tell me"],[2606,2748,"that you come from a rich family too?"],[2748,2781,"I'm sorry."],[2781,2965,"How is that relevant right now?"],[2965,3082,"How is that relevant?"],[3082,3211,"You're accusing me of lying"],[3211,3286,"about my family, yet?"],[3286,3524,"You did the exact same thing."],[3553,3674,"Well, at least I have an excuse."],[3674,3757,"What's yours?"],[3757,3841,"Were you cut off from your"],[3841,3899,"family, too?"],[3908,4054,"No, no I wasn't."],[4054,4250,"Okay, well, then why are you here?"],[4250,4354,"You don't even need to live"],[4354,4462,"a normal life."],[4462,4542,"What? Are you just"],[4542,4683,"pretending for fun?"],[4683,4817,"I am not here for fun."],[4838,5030,"I went out on my own to prove myself."],[5030,5121,"Everybody just expected me"],[5121,5230,"to join the family business."],[5230,5409,"But I needed to make my own way"],[5409,5476,"in the world!"],[5518,5551,"Okay, well,"],[5551,5676,"then why didn't you just tell me that?"],[5676,5830,"Okay. Why don't you trust me?"],[5830,5955,"I didn't tell you because I thought"],[5955,6014,"that you could be a-"],[6014,6106,"Could be what?!"],[6164,6231,"I thought that you"],[6231,6352,"could be after my money!"]],"43":[[25,141,"I thought that you could be after"],[141,250,"my money!"],[471,571,"Okay, look, that came out bad-"],[571,717,"Yeah I fucking did."],[771,867,"First, I'm a traitor,"],[867,984,"and now I'm a gold digger."],[992,1034,"You know what?"],[1034,1217,"You are just a real class ass Andy!"],[1217,1368,"Stop deflecting!"],[1368,1468,"You heard the threats from"],[1468,1509,"Mr.Carlton"],[1526,1659,"while you were snooping around"],[1659,1772,"in my office, no less."],[1772,1889,"And you didn't say anything."],[1889,2052,"I have every right to be angry!"],[2052,2239,"I chose freedom!"],[2352,2544,"And I lost everything because of it."],[2640,2715,"Do you really think"],[2715,2827,"that I would turn around"],[2827,3094,"and just betray you like that?"],[3278,3420,"I opened up to you"],[3420,3549,"about everything,"],[3549,3649,"and you just turn around"],[3649,3791,"and throw it in my face!"],[3824,3941,"I even told you that my parents"],[3941,4120,"prefer my sister over me."],[4137,4262,"And you know how important it is"],[4262,4391,"for me to be treated as an equal."],[4391,4596,"And yet you still don't do it!"],[4596,4671,"When?"],[4671,4821,"When have I not treated you as an"],[4821,4879,"equal?"],[4879,4938,"You suspect"],[4938,5105,"your equal of ulterior motives."],[5105,5167,"So much"],[5167,5267,"so that you would"],[5267,5417,"accuse her of being the mole."],[5588,5805,"After living with her for weeks."],[5805,5922,"No, it doesn't matter."],[5997,6177,"I saw the door camera footage."],[6177,6281,"Ed Carlton was standing right here"],[6281,6360,"in this apartment."],[6360,6460,"Did you feed him information"],[6460,6531,"then?"],[7223,7282,"He was just trying"],[7282,7390,"to get me to come back."],[7407,7661,"I have seen you lie, Corinne!"],[7661,7824,"It comes as easily to you as breathing."],[7824,7924,"Ever since you showed up"],[7924,7978,"in this apartment,"],[7978,8158,"you have caused me nothing but trouble."],[8158,8258,"And I swear,"],[8258,8337,"if you're the reason"],[8337,8525,"that my agency is in jeopardy, I..."],[8771,8925,"Sounds like you already think"],[8925,9038,"I'm guilty."],[9154,9246,"So be it."],[10297,10456,"Oh, honey."],[10456,10564,"I'll get that ice cream."],[10656,10706,"Yeah."]],"44":[[183,300,"Enjoy."],[300,342,"Hi."],[342,450,"Welcome."],[817,909,"Corinne."],[1213,1372,"Why did you ask me here, James?"],[1384,1530,"Cutting right to the chase."],[1597,1668,"Okay."],[1668,1760,"Well,"],[1760,1856,"You see."],[1856,1960,"I haven't quite given up"],[1960,2081,"on our future nuptials."],[2198,2293,"Wait."],[2293,2364,"You're going to want to"],[2364,2485,"hear what I have to say."],[2548,2623,"Please."],[2623,2756,"What could you possibly say"],[2756,2848,"to convince me to go"],[2848,2990,"along with this arrangement?"],[2990,3107,"Your boy-toy isn't who he says"],[3107,3186,"he is."],[3211,3299,"Andy?"],[3361,3424,"I know."],[3490,3636,"He is part of the Rhodes family."],[3636,3728,"Big whoop."],[3795,3908,"Not that, Corinne."],[3991,4204,"He is engaged"],[4204,4525,"to this woman, Betty Camden, 25."],[4554,4700,"She's a childhood sweetheart of his."],[4750,4838,"No, no, no."],[4838,4917,"I met her."],[4917,5030,"She's crazy."],[5030,5138,"They've been engaged to be"],[5138,5305,"married since childhood."],[5305,5417,"If my sources are correct,"],[5417,5643,"which, trust me, it is."],[5680,5801,"The wedding is set for May."],[5801,5918,"Well, you're wrong."],[5964,6081,"Who's your source?"]],"45":[[487,563,"Okay, you know what?"],[563,650,"You still haven't said"],[650,821,"what that has to do with you and I."],[821,975,"So just get to the point."],[996,1176,"The point is, Corinne,"],[1226,1351,"I know you love him,"],[1351,1484,"but you can't have him."],[1484,1614,"He belongs to Miss Camden"],[1614,1830,"this past month. All of it."],[1830,1893,"It's been fake."],[1981,2043,"A dream."],[2060,2122,"F*uck you."],[2135,2339,"What I can offer you is real."],[2394,2506,"Yeah? What's that?"],[2506,2585,"Security."],[2585,2669,"A home."],[2669,2694,"Assurance"],[2694,2819,"that what you have won't disappear"],[2819,2894,"in an instant."],[2911,3136,"You will be taken care of forever."],[3136,3274,"You will never have to worry"],[3274,3436,"or doubt ever again."],[3436,3541,"Take some time."],[3636,3749,"Think about it."],[3803,3899,"I'll be waiting."],[4208,4329,"Do you remember, Andy?"],[4329,4608,"How her Easter dress got so muddy?"],[4608,4683,"That your parents"],[4683,4867,"had to cancel the press shoot?"],[4867,5096,"Oh, that was such a fun day."],[5096,5305,"Despite the looks on their faces."],[5334,5417,"Oh, God."],[5417,5467,"You know,"],[5467,5826,"you two made such a couple then and now."],[6218,6272,"Excuse me,"],[6272,6393,"I need to use the restroom."],[6681,6981,"This place is just so lovely, isn't it?"],[7044,7094,"Sorry,"],[7094,7294,"I just need to send a quick message."],[7315,7365,"No problem."],[7365,7444,"Dear."],[8529,8679,"Such a lovely evening."],[8700,8758,"Yes."]],"46":[[104,266,"There he is."],[1343,1405,"F*ck this."],[1743,1856,"Excuse me."],[2364,2477,"Is he taunting me?"],[2477,2669,"Is this psychological warfare?"],[2748,2861,"You know what James is right."],[2861,2998,"I really need to get myself"],[2998,3098,"out of this mess."],[3424,3770,"Corinne, what a coincidence."],[3770,3933,"I was just having dinner with Andy"],[3933,4037,"and his mother."],[4091,4200,"Would you like to join?"],[4266,4379,"Are you the one who texted me"],[4379,4483,"off on Andy's phone?"],[4637,4804,"Did you really think Andy wanted to talk"],[4804,4938,"things out and make up?"],[4938,5063,"How sad."],[6010,6135,"Hello there."],[6135,6356,"Didn't expect to hear from you so soon."],[6356,6527,"You're right."],[6527,6610,"Imagine that."],[6610,6715,"What will you do?"]],"47":[[0,79,"You know what?"],[79,266,"I would like to propose a toast."],[266,412,"To Turn Tide."],[412,592,"And all the success that you've had,"],[592,658,"Andy."],[658,959,"I am so proud of you."],[992,1101,"Cheers."],[1272,1313,"Thanks, mom."],[1313,1409,"That means a lot."],[1409,1710,"But I didn't propose this dinner to"],[1722,1801,"discuss work."],[1922,2014,"I brought you here because we"],[2014,2135,"need to put this matter to bed."],[2223,2277,"What's that?"],[2277,2377,"What's the matter?"],[2419,2552,"Betty and I's engagement."],[2619,2665,"Listen, mom,"],[2665,2698,"I know you"],[2698,2811,"and the Camden's have wanted this"],[2811,2961,"for my entire life,"],[3015,3132,"but just because you're telling people"],[3132,3203,"it's going to happen"],[3203,3340,"doesn't make it true."],[3340,3428,"I'm a grown man now."],[3428,3566,"I need to make my own decisions."],[3695,3803,"Andy."],[3920,3962,"You know what?"],[3962,4091,"I'm tired of this."],[4124,4308,"I have been nothing but patient"],[4308,4458,"and understanding for years."],[4458,4658,"And all you do is reject me."],[4658,4921,"I've been waiting for you my whole life."],[4921,5155,"What does she have that I don't?"],[5167,5280,"Who is she?"],[5363,5488,"She is the woman"],[5488,5630,"Andy is living with."],[5630,5768,"Andy, is that true?"]],"48":[[16,120,"She's just a roommate."],[120,216,"Her name is Corinne."],[262,396,"Betty, I can't marry you."],[396,517,"And it's not because of her."],[517,667,"It wouldn't be right."],[667,725,"I'm sorry."],[863,955,"Fix it."],[1009,1142,"I’m going to call my parents."],[1359,1443,"Andy."],[1509,1714,"Just because you have a startup"],[1714,1889,"does not mean that you have life"],[1889,1968,"figured out."],[1993,2185,"First, you turn down the Carlton's,"],[2185,2356,"and now the Camden's?"],[2356,2423,"God!"],[2456,2606,"What are you doing?"],[2606,2765,"Are you trying to run your career"],[2765,2927,"into the ground? Andy?"],[2998,3190,"Partnerships shouldn't be bought."],[3249,3365,"They should be earned."],[3382,3486,"And I want to marry somebody I love,"],[3486,3574,"not somebody that I see"],[3574,3716,"business value in."],[3716,3916,"You have known Betty your entire life,"],[3916,4054,"and our family approves of her."],[4054,4237,"And you stand the risk of"],[4237,4416,"insulting her family"],[4416,4646,"the longer you put off this marriage."],[4646,4779,"Do you understand?"],[4833,5017,"If I can't marry somebody that I love,"],[5017,5150,"then I'll just walk away from it all."],[5150,5276,"Oh God."],[5313,5480,"How dare you!"],[5480,5739,"Do you really think that I had a choice"],[5739,5847,"in who I married?"],[5897,6026,"Do you want the same for your child?"],[6197,6314,"You are young"],[6314,6477,"and I know what's best for you."],[6477,6690,"And this is not over!"],[6690,6844,"And you will figure it out."]],"49":[[504,600,"Are you leaving?"],[684,759,"Yes."],[855,913,"You could just keep"],[913,1159,"the rest of my stuff or throw it away."],[1159,1242,"I don't really care."],[1267,1443,"Is this about the other night?"],[1443,1518,"I mean, can you blame me"],[1518,1630,"for suspecting you?"],[1630,1826,"Do you know what's really ironic?"],[1826,1910,"You accuse me of"],[1910,2056,"being this big mastermind"],[2056,2243,"and saying all this bullshit about me?"],[2243,2264,"Yeah."],[2264,2327,"You are the one"],[2327,2448,"with the biggest secret of all."],[2448,2619,"What the hell are you talking about?"],[2694,2861,"Enjoy married life."],[3069,3140,"Oh. What?"],[3140,3282,"Cat got your tongue now?"],[3365,3390,"You know,"],[3390,3449,"I should have known"],[3449,3561,"that you were a player"],[3561,3695,"from the very beginning!"],[3753,3912,"Why are you even mad?"],[3912,4074,"We're just roommates!"]],"50":[[4,129,"What does it matter to you?"],[241,371,"Just roommates."],[417,654,"You know, that's low even for you, Andy."],[684,754,"What?"],[754,950,"We had moments. The flirting."],[950,1076,"Oh, we shared a kiss, for God's sake."],[1076,1217,"None of that mean anything to you?"],[1217,1343,"We were drinking."],[1397,1589,"Right? Got it!"],[1680,1793,"Where are you going?"],[1793,1876,"None of your business!"],[1876,2035,"Oh, you're going back to them,"],[2035,2177,"aren't you, to James?"],[2206,2268,"And I'm supposed to believe"],[2268,2369,"you're innocent now?"],[2423,2527,"I always was!"],[2527,2711,"If that's the case, then you're a coward."],[2711,2806,"What?"],[2806,2973,"After all of the progress"],[2973,3007,"you've made,"],[3007,3123,"the life that you built for yourself,"],[3123,3236,"the blood, sweat and tears."],[3236,3357,"You just going to give it all away?"],[3390,3541,"Take the easy way out?"],[3541,3670,"You're better than that, Corinne."],[3712,3883,"What does it matter to you?"],[3999,4104,"We're just roommates,"],[4104,4204,"remember?"],[4245,4337,"Well, not anymore."]],"51":[[212,371,"Look who decided to show up."],[412,513,"You look tired."],[596,679,"I'm here."],[1889,1960,"Mr. Fincher,"],[1960,2014,"Mr. Thompson,"],[2047,2118,"it's an honor"],[2118,2210,"to have you here today."],[2264,2385,"We will be presenting our pitch"],[2385,2635,"for Goldfield Beer as a team."],[2698,2806,"Here at Turn Tide."],[2827,2961,"We aim to pinpoint"],[2961,3019,"the core,"],[3019,3161,"makes a product attractive to"],[3161,3240,"consumers,"],[3253,3349,"and then elevated"],[3349,3495,"into the public consciousness."],[3516,3687,"Through meticulous research."],[3687,3828,"We have found that the two words"],[3828,4008,"most commonly associated with"],[4008,4104,"Goldfield"],[4104,4350,"is summer and taste."],[4350,4475,"Now accompanied"],[4475,4704,"with visual and auditory cues..."],[5505,5676,"And that brings us to the slogan"],[5676,5797,"that will transform"],[5797,6006,"goldfields presence in the market."],[6006,6131,"Goldfield."],[6131,6322,"The taste of summer."],[6698,6831,"Mr. Rhodes,"],[6831,6990,"you've certainly put a lot of effort"],[6990,7082,"into this."],[7152,7328,"It's an impeccable presentation."],[7328,7469,"Virtually flawless."],[7507,7607,"We can see the quality"],[7607,7749,"that comes out of Turn Tide."],[7749,7887,"That may also be your greatest"],[7887,7987,"weakness."],[7987,8083,"On the surface,"],[8083,8174,"The ad is perfect,"],[8174,8366,"but it doesn't possess anything"],[8366,8429,"beyond that."],[8429,8621,"I mean, the taste of summer?"],[8621,8754,"Come on. What does that even mean?"],[8800,9079,"I mean, it's... it's soulless."],[9096,9167,"Right!"],[9180,9267,"Basic."],[9321,9480,"And we cannot sign up for this."]],"52":[[41,237,"And we cannot sign up for this."],[375,571,"Well, you know, you you'd be surprised."],[571,721,"As I mentioned, studies show"],[721,855,"that the people"],[855,1067,"are very receptive to summer themes."],[1067,1213,"They produce neural responses"],[1213,1334,"akin in nostalgia."],[1334,1426,"Ads like this"],[1426,1584,"are almost guaranteed"],[1584,1768,"to bring in higher year round profits."],[1801,1906,"It's a safe bet."],[1943,2122,"You're well aware of the advantage"],[2122,2260,"of this type of marketing,"],[2260,2356,"Mr. Rhodes."],[2356,2452,"Other beer brands"],[2452,2627,"have been using it for decades."],[2627,2852,"Yeah, and we're not other beer brands."],[2852,2869,"I mean,"],[2869,3003,"we didn't take the risks of coming"],[3003,3140,"to a new up and coming"],[3140,3415,"ad agency to get a boring,"],[3482,3616,"safe pitch."],[3787,3945,"Well, you know, I can, um..."],[3991,4129,"We've seen enough from"],[4129,4258,"you, Mr. Rhodes."],[4258,4346,"Well,"],[4346,4546,"I don't have to give an ultimatum, but"],[4546,4612,"if you don't give us"],[4612,4733,"something impressive,"],[4733,4863,"like right now."],[4863,4975,"We're walking!"],[5005,5059,"Please,"],[5059,5167,"if you give us one more day,"],[5167,5305,"we can put together a presentation"],[5305,5476,"that is equally impressive."],[5476,5576,"We don't want another"],[5576,5668,"presentation."],[5680,5797,"We want a good idea."],[6398,6493,"Miss..."],[6493,6606,"Corinne Carlton."],[6606,6735,"Corinne Carlton..."],[6794,6961,"Isn't that um..."],[7073,7261,"What are you doing?"],[7261,7415,"I can pitch!"]],"53":[[54,154,"I can pitch!"],[396,504,"Well, then"],[533,613,"go ahead."],[855,1030,"I recently had the misfortune of losing"],[1030,1151,"almost everything I had."],[1184,1405,"And although it was my choice,"],[1405,1555,"it was still really hard."],[1555,1655,"And most people think that"],[1655,1830,"when you're struggling,"],[1830,2060,"you're focused on the basics."],[2060,2147,"Getting a job,"],[2147,2318,"finding a safe place to live."],[2318,2569,"Affording food and necessities,"],[2573,2656,"and surviving."],[2744,2894,"And for the most part, that is."],[2894,2990,"That's true."],[2990,3282,"But in the in-between moments,"],[3282,3474,"when everything is just hitting you,"],[3474,3620,"you're just looking for comfort."],[3636,3778,"Just about everywhere."],[3812,3916,"You're looking for anything"],[3916,4020,"and everything"],[4020,4095,"that'll give you a sense"],[4095,4291,"of belonging that you used to have."],[4325,4433,"And in one of those moments,"],[4433,4629,"someone gave me a Goldfield beer."],[4629,4817,"I had a really hard time opening it."],[4854,4967,"You know, weak hands."],[5663,5901,"But I couldn't believe how"],[5901,6202,"something so simple could mean so much."],[6243,6314,"It was just a beer."],[6314,6498,"But,"],[6498,6715,"you know, this may not resonate,"],[6715,6869,"but I keep thinking about this quote"],[6869,7019,"that Ernest Hemingway wrote."],[7019,7215,"I did not care what it was all about."],[7215,7365,"Life, you know?"],[7365,7520,"All I wanted to know"],[7520,7661,"was how to live in it."],[7661,7949,"And if I found out how to live in it,"],[7949,8091,"then you learn from what"],[8091,8241,"it was all about."],[8241,8504,"Goldfield... Live in it."],[8504,8671,"Sun also rises."],[8729,8787,"You'd have no way"],[8787,8921,"of knowing this, young lady."],[8921,9025,"But,"],[9025,9234,"our CEO is very fond of Hemingway."],[9259,9488,"If he were here right now, he'd be over"],[9488,9542,"the moon."],[9563,9730,"He'll love the idea of our ad"],[9730,9889,"referencing the favorite."]],"54":[[137,291,"Well, I can throw together"],[291,429,"some mock ads by the end of the week."],[563,692,"Excellent."],[692,821,"Look forward to seeing that."],[842,917,"Miss Carlton,"],[934,1034,"You have a bright future here."],[1113,1213,"Thank you."],[1272,1397,"That means a lot."],[3411,3470,"Mr. Thompson."],[3495,3611,"Mr. Fincher, please wait."],[3712,3891,"What more is it to discuss?"],[3891,4112,"We made ourselves very clear in there."],[4137,4254,"I don't know if you know this,"],[4254,4458,"but my father is Neil Martin."],[4512,4575,"Okay?"],[4575,4617,"And?"],[4700,4767,"He's the largest"],[4767,4971,"supplier of wheat on the west coast."],[4971,5142,"A connection with him"],[5142,5288,"would be very beneficial for"],[5288,5388,"Goldfield."],[5442,5559,"If you go back in there"],[5559,5655,"and tell my boss you're"],[5655,5826,"turning down Turn Tide's pitch"],[5826,5989,"and going with the Carlton Group."],[5989,6076,"I can make that happen."]],"55":[[0,129,"If you had done"],[129,279,"any research into our company,"],[279,379,"Miss Martin,"],[379,500,"you'd know we produce our own"],[500,542,"wheat."],[542,696,"Goldfield started as a farm."],[779,950,"And does Mr. Rhodes know"],[950,1092,"that you're trying to bribe us"],[1092,1251,"on behalf of another company?"],[1480,1726,"How about if you do it?"],[1810,1997,"I'll give you a night you won't forget."],[1997,2081,"Both of you."],[2577,2677,"Mr Rhodes,"],[2715,2886,"you need to control your people."],[2886,3103,"Never in my entire career experienced"],[3103,3265,"something so unprofessional."],[3265,3432,"Is this your corporate culture?"],[3490,3649,"Absolutely not."],[3649,3766,"And this is no longer"],[3766,3916,"an employee of Turned Tide."],[3916,4116,"My sincere apologies to both of you."],[4116,4195,"And we will make up"],[4195,4354,"for this violation tenfold."],[4437,4512,"If you can come through"],[4512,4738,"like your all star associate promised."],[4863,5046,"Maybe we can forget about this."],[5046,5113,"Thank you."],[5705,5772,"Mr. Rhodes, please I-"],[5772,5855,"So it was you."],[5855,6010,"What the fuck were you thinking?"],[6135,6410,"I've worked my ass off for this company."],[6439,6619,"I was here when it was nothing."],[6673,6744,"I should have been made"],[6744,6848,"a partner ages ago."],[6848,6973,"But you never even considered it."],[6973,7069,"Ed Carlton"],[7132,7319,"offered me an executive role"],[7319,7453,"just for doing a small favor."],[7570,7691,"So you betrayed us?"],[7736,7987,"Put the entire agency in jeopardy?"],[7987,8158,"If Corinne hadn't saved us back there-"],[8158,8224,"Please!"],[8224,8420,"I could have done the same thing."],[8420,8521,"Pack your things."],[8537,8646,"You're fired!"]],"56":[[1643,1780,"When did I ever bought that..."],[3007,3148,"Not one word,"],[3148,3286,"Not one gesture of yours"],[3286,3457,"shall I, could I,"],[3457,3599,"ever forget."],[4120,4162,"He read it."]],"57":[[679,746,"Mr. Carlton,"],[754,859,"figured you would,"],[859,984,"show up at some point."],[984,1126,"Come to hand over your clients to me?"],[1297,1476,"Enjoy them while you have them."],[1476,1526,"Because I'm sure"],[1526,1730,"they'll come crawling back soon."],[1797,1885,"Do you know who won the deal"],[1885,1972,"for us?"],[1972,2031,"Corinne."],[2068,2147,"Your daughter."],[2202,2381,"Seems like you lost your biggest asset"],[2381,2540,"when you cut her off from the family."],[2581,2652,"Corinne?"],[2740,2802,"How?"],[2848,2940,"I have a deal for you."],[3053,3132,"What?"],[3219,3482,"I will give you back these clients."],[3482,3666,"But you have to give up something else."],[3666,3795,"And that would be..."],[3824,3899,"Corinne."],[3928,4074,"Relinquish your control and"],[4074,4208,"let her live her own life"],[4208,4358,"on her own terms."],[4358,4512,"Stay out of her life for good."]],"58":[[0,137,"Stay out of her life for good."],[137,216,"Deal."],[1359,1388,"Betty,"],[1388,1514,"we need to talk about the wedding."],[1935,2031,"Hey, Melissa."],[2031,2135,"Have you seen Andy?"],[2135,2289,"I just really need to talk to him."],[2289,2448,"No, he's not in yet."],[2448,2615,"But did you hear what happened?"],[2615,2706,"No. What happened?"],[2761,2973,"Andy fired Lilia!"],[2973,3215,"Apparently, she's the Carlton mole."],[3215,3353,"It got really intense,"],[3353,3653,"so he sent her packing."],[3653,3803,"It was epic."],[3803,4008,"But he- Also super hot."],[4008,4191,"Okay, what do we."],[4191,4325,"How did I miss this?"],[4325,4508,"You were still in the meeting room."],[4508,4767,"I was the only witness."],[4767,4921,"Perks of being HR."],[4921,5084,"Okay. Do you know where he is?"],[5084,5188,"That's the craziest part."],[5188,5384,"He is at the courthouse"],[5384,5480,"downtown!"],[5480,5568,"What?"],[5568,5868,"He's getting married!"]],"59":[[120,246,"Andy!"],[592,654,"I'm so sorry."],[654,788,"I thought, um..."],[1438,1568,"Corinne."],[1739,1856,"Someone told me that you were"],[1856,1922,"at the courthouse."],[2081,2198,"Are you here to heroically stop"],[2198,2302,"my arranged marriage?"],[2406,2548,"Well, you don't belong with Betty,"],[2548,2585,"okay?"],[2585,2665,"You just don't."],[2706,2811,"You've worked so hard,"],[2811,2915,"and you deserve to be with somebody"],[2915,2973,"that loves you,"],[2973,3115,"like everything about you."],[3115,3178,"But maybe Betty does."],[3178,3236,"But you know what?"],[3236,3311,"I really don't think so."],[3311,3445,"She's kind of a b*tch."],[3541,3570,"Sorry."],[3570,3716,"I'm getting kind of sidetracked."],[3782,4020,"Do not laugh at me, okay?"],[4020,4175,"I am trying to give a speech!"],[4270,4354,"You um..."],[4491,4704,"You deserve to pick your own path,"],[4771,4875,"whatever that is."],[4909,4946,"And, you know,"],[4946,5113,"I've always kind of really admired"],[5113,5213,"that about you."],[5263,5380,"Just don't go through with it!"],[5413,5543,"If I can call off my wedding,"],[5543,5638,"then so can you!"],[5697,5755,"Are you done?"],[5860,5922,"Yes."],[5980,6143,"I'm not marrying Betty."]],"60":[[12,125,"I'm not marrying Betty."],[458,517,"Hey, Betty,"],[621,763,"can we talk about the marriage?"],[763,975,"Andy, can’t you just be happy with me?"],[975,1121,"Our mothers are so intent"],[1121,1180,"on the marriage,"],[1180,1276,"they've decided to forgo"],[1276,1376,"the wedding altogether."],[1376,1576,"Just get it over with in a courthouse."],[1601,1747,"Isn’t that enough for you?"],[1780,1960,"You need to stand up to them with me."],[1960,2006,"This whole time,"],[2006,2114,"you've been perfectly obedient."],[2114,2239,"This will not be over"],[2239,2394,"until you say no too."],[2452,2606,"It's not just obedience, Andy."],[2631,2798,"I've loved you since we were kids."],[2848,2944,"You don't love me."],[2944,3065,"You don't even know what love is."],[3240,3382,"I was never going to marry Betty,"],[3382,3561,"contrary to popular belief."],[3561,3803,"Just like I was never the mole,"],[3803,4004,"contrary to popular belief."],[4004,4129,"So is this where I get to say"],[4129,4241,"I told you so?"],[4350,4446,"I may or may not have made"],[4446,4546,"some assumptions."],[4546,4704,"Understatement of the year!"],[4750,5050,"And reacted without solid evidence."],[5125,5255,"I'm sorry for not trusting you, Cori."],[5384,5509,"Nothing that I said to you was true."],[5509,5680,"You haven't made my life any worse."],[5680,5876,"In fact, you have made it"],[5876,6047,"a hell of a lot better."],[6185,6310,"You can call it even."],[6698,6769,"Sure."],[6923,6973,"So."],[7082,7190,"What is Mr. Rhodes"],[7190,7353,"going to do now?"],[7415,7707,"Well, I actually have a very busy evening"],[7707,7841,"moving my roommate in."],[7862,7937,"Oh!"],[7937,8033,"Yeah."],[8033,8162,"It's going to be a workout, too."],[8162,8350,"She has a sh*t ton of books,"],[8491,8646,"but I love her anyways."],[8687,8775,"Question."],[8800,8933,"If it had been me at the altar,"],[8933,9113,"would you run?"],[9121,9309,"Well, I'll just have to see."],[9309,9438,"I'm gonna need some insurance."],[9438,9580,"Oh, shut up and kiss me."]]}